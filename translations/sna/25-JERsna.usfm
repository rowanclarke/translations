\id JER - Biblica® Open Shona Contemporary Bible 2017 
\h Jeremia 
\toc1 Jeremia 
\toc2 Jeremia 
\toc3 Jere 
\mt1 JEREMIA 
\c 1  
\p  
\v 1 Mashoko aJeremia mwanakomana waHirikia, mumwe wavaprista paAnatoti munyika yaBhenjamini.  
\v 2 Shoko raJehovha rakauya kwaari mugore regumi namatatu rokutonga kwaJosia mwanakomana waAmoni mambo weJudha,  
\v 3 uye nomunguva yokutonga kwaJehoyakimi mwanakomana waJosia mambo weJudha, kusvikira pamwedzi wechishanu wegore regumi nerimwe raZedhekia mwanakomana waJosia mambo weJudha, vanhu veJerusarema pavakazoenda kuutapwa. 
\s1 Kudanwa kwaJeremia 
\p  
\v 4 Shoko raJehovha rakauya kwandiri, richiti, 
\q1  
\v 5 “Ndisati ndakuumba mudumbu ramai vako, ndakakuziva iwe, 
\q2 usati waberekwa, ndakakutsaura; 
\q2 ndakakugadza somuprofita kumarudzi.” 
\p  
\v 6 Ini ndikati, “Haiwa, Ishe Jehovha, handigoni kutaura; ndinongova mwana hangu.” 
\p  
\v 7 Asi Jehovha akati kwandiri, “Usati, ‘Ndinongova mwana hangu.’ Unofanira kuenda kuna ani naani wandinokutuma kwaari undotaura zvose zvandinokurayira.  
\v 8 Usavatya, nokuti ini ndinewe uye ndichakurwira,” ndizvo zvinotaura Jehovha. 
\p  
\v 9 Ipapo Jehovha akatambanudza ruoko rwake akabata muromo wangu akati kwandiri, “Zvino ndaisa mashoko angu mumuromo mako.  
\v 10 Tarira, nhasi ndakugadza pamusoro pendudzi napamusoro poushe kuti udzure, ubvarure, uparadze, ukoromore, uvake uye usime.” 
\p  
\v 11 Shoko raJehovha rakauya kwandiri richiti, “Jeremia, uri kuonei?” 
\p Ndakapindura ndikati, “Ndiri kuona davi romuti womuarimondi.” 
\p  
\v 12 Jehovha akati kwandiri, “Waona zvakanaka, nokuti ndiri kutarira kuti ndione kuzadziswa kweshoko rangu.” 
\p  
\v 13 Shoko raJehovha rakauyazve kwandiri richiti, “Uri kuoneiko?” 
\p Ndakapindura ndikati, “Ndiri kuona hari iri kuvira, yakarerekera kubva kumusoro.” 
\p  
\v 14 Jehovha akati kwandiri, “Njodzi ichadururirwa pamusoro pavanhu vagere munyika ichibva nokumusoro.  
\v 15 Nokuti iye zvino ndiri kudana vanhu vose voushe hwokumusoro,” ndizvo zvinotaura Jehovha. 
\q1 “Madzimambo avo achauya achizoisa zvigaro zvavo zvoushe 
\q2 pamasuo eJerusarema; 
\q1 vachauya kuzorwisa masvingo aro ose akarikomberedza 
\q2 uye namaguta ose eJudha. 
\q1  
\v 16 Ndichareva zvandakatonga pamusoro pavanhu vangu 
\q2 nokuda kwezvakaipa zvavo zvavakaita vachindisiya, 
\q1 vachipisira zvinonhuhwira kuna vamwe vamwari 
\q2 uye vachinamata zvakaumbwa namaoko avo. 
\p  
\v 17 “Iwe chigadzirira! Simuka uvataurire zvose zvandinokurayira. Usavhundutswa navo, kuti ini ndirege kuzokuvhundutsa pamberi pavo.  
\v 18 Nhasi ndakuita guta rakakomberedzwa nembiru yesimbi namasvingo endarira, kuti urwe nenyika yose, urwe namadzimambo eJudha, namachinda avo, navaprista vavo uye navanhu venyika.  
\v 19 Vacharwa newe asi havangakukundi, nokuti ndinewe uye ndichakurwira,” ndizvo zvinotaura Jehovha. 
\c 2  
\s1 Israeri inosiya Mwari 
\p  
\v 1 Shoko raJehovha rakauya kwandiri richiti,  
\v 2 “Enda unoparidza munzeve dzeJerusarema uchiti: 
\q1 “ ‘Ndinorangarira kunamata kwouduku hwako, 
\q2 kuti somwenga waindida sei 
\q1 uye uchinditevera nomukati merenje, 
\q2 uye nomunyika isina munhu anogaramo. 
\q1  
\v 3 Israeri akanga ari mutsvene kuna Jehovha, 
\q2 ari chibereko chokutanga chokukohwa kwake; 
\q1 vose vakanga vachimudya vaipiwa mhosva, 
\q2 uye njodzi yakavawira,’ ” 
\q4 ndizvo zvinotaura Jehovha. 
\b  
\q1  
\v 4 Inzwai shoko raJehovha imi imba yaJakobho, 
\q2 nemi mose vorudzi rweimba yaIsraeri. 
\p  
\v 5 Zvanzi naJehovha: 
\q1 “Madzibaba enyu akawana mhosva yei kwandiri, 
\q2 zvavakaenda kure neni? 
\q1 Vakatevera zvifananidzo zvisina maturo 
\q2 ivo vakava vasina maturo pachavo. 
\q1  
\v 6 Havana kubvunza kuti, ‘Jehovha aripiko, 
\q2 iye akatibudisa kubva munyika yeIjipiti akatitungamirira nomugwenga risina miti, 
\q1 nomunyika yamarenje namakoronga, 
\q2 iyo nyika yakaoma uye yerima, 
\q1 nyika isina munhu anofambamo 
\q2 uye isina munhu anogaramo?’ 
\q1  
\v 7 Ndakakupinzai munyika yakaorera 
\q2 kuti mudye zvibereko zvayo nezvakanaka zvayo. 
\q1 Asi makasvika mukasvibisa nyika yangu, 
\q2 mukaita nhaka yangu kuti ive chinhu chinonyangadza. 
\q1  
\v 8 Vaprista havana kubvunza kuti, 
\q2 ‘Jehovha aripiko?’ 
\q1 Vakanga vachifambisa murayiro havana kundiziva; 
\q2 vatungamiri vakandimukira. 
\q1 Vaprofita vakaprofita naBhaari, 
\q2 vachitevera zvifananidzo zvisina maturo. 
\b  
\q1  
\v 9 “Naizvozvo ndinokupai mhosva zvakare,” 
\q4 ndizvo zvinotaura Jehovha. 
\q2 “Ndichapazve mhosva vana vavana venyu. 
\q1  
\v 10 Yambukirai kumiganhu yeKitimi muone, 
\q2 tumai vanhu kuKedhari mugonyatsocherechedza; 
\q2 muone kana pakambova nechimwe chinhu chakadai: 
\q1  
\v 11 Ko, rudzi rwakambotsinhanisa vamwari varwo here? 
\q2 Uye havasi vamwari zvachose. 
\q1 Asi vanhu vangu vakatsinhanisa kukudzwa kwavo 
\q2 nezvifananidzo zvisina maturo. 
\q1  
\v 12 Haiwa, imi matenga, shamiswai nechinhu ichi, 
\q2 uye mudedere nokutya kukuru,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 13 “Vanhu vangu vakaita zvakaipa zviviri: 
\q1 Vakandisiya ini, 
\q2 tsime remvura mhenyu, 
\q1 vakazvicherera zvirongo 
\q2 zvisingachengeti mvura. 
\q1  
\v 14 Ko, Israeri muranda here, kana nhapwa pakuberekwa? 
\q2 Nemhaka yeiko apambwa zvino? 
\q1  
\v 15 Shumba dzakaomba; 
\q2 dzikanguruma kwaari. 
\q1 Dzakaparadza nyika yake; 
\q2 maguta ake akapiswa uye haachina vanhu. 
\q1  
\v 16 Uyezve, vanhu veNofi neveTapanesi 
\q2 vakaveura musoro wako. 
\q1  
\v 17 Ko, hauna kuzvivigira izvozvo pachako here 
\q2 pawakasiya Jehovha Mwari 
\q2 wako paakanga achikutungamirira munzira? 
\q1  
\v 18 Zvino, unoendereiko kuIjipiti 
\q2 kundonwa mvura inobva muShihori? 
\q1 Uye unodireiko kuenda kuAsiria 
\q2 kundonwa mvura inobva murwizi? 
\q1  
\v 19 Zvakaipa zvako zvichakuranga; 
\q2 kudzokera shure kwako kuchakutuka. 
\q1 Rangarira uye uyeuke zvino kuti zvakaipa sei 
\q2 uye zvinovava sei kwauri, 
\q2 ukange wasiya Jehovha Mwari wako, 
\q2 uye usingandityi,” 
\q4 ndizvo zvinotaura Ishe, Jehovha Wamasimba Ose. 
\b  
\q1  
\v 20 “Wakavhuna joko rako kare kare 
\q2 uye wakadambura makashu ako; 
\q2 ukati, ‘Handidi kukushumirai!’ 
\q1 Zvirokwazvo, pamusoro pechikomo chirefu choga choga, 
\q2 uye pasi pomuti woga woga wakapfumvutira, 
\q2 wakarara pasi pawo sechifeve. 
\q1  
\v 21 Ndakanga ndakusima somuzambiringa wakanakisa, 
\q2 uri mbeu kwayo inovimbika. 
\q1 Ko, zvino wakazondishandukira 
\q2 sei ukava muzambiringa webundo wakaora? 
\q1  
\v 22 Kunyange ukazvishambidza nesoda 
\q2 uchishandisa sipo yakawanda, 
\q2 gwapa remhosva yako rinoramba riri mberi kwangu,” 
\q4 ndizvo zvinotaura Ishe Jehovha. 
\q1  
\v 23 “Unoreva sei, uchiti, ‘Handina kusvibiswa; 
\q2 handina kutevera Bhaari’? 
\q1 Tarisa zvawakaita mumupata; 
\q2 funga zvawakaita. 
\q1 Iwe uri ngamera yehadzi 
\q2 inomhanya apa nepapo, 
\q1  
\v 24 uri mbizi yakarovedzwa mugwenga, 
\q2 inofembedza mhepo mukushuva kwayo; 
\q2 ndiani angaidzora pakupfumvura kwayo? 
\q1 Mukono upi noupi unoitevera haufaniri kuzvinetesa; 
\q2 panguva yokusangana uchaiwana. 
\q1  
\v 25 Usamhanya kusvikira tsoka dzako 
\q2 dzisisina shangu nehuro yako yava nenyota. 
\q1 Asi iwe wakati, ‘Hazvibatsiri! 
\q2 Ndinoda vamwari vokumwe, 
\q2 uye ndinofanira kuvatevera.’ 
\b  
\q1  
\v 26 “Sokunyadziswa kwembavha yabatwa, 
\q2 saizvozvo imba yaIsraeri yanyadziswa, 
\q1 ivo namadzimambo avo uye namachinda avo, 
\q2 vaprista vavo navaprofita vavo. 
\q1  
\v 27 Vanoti kudanda, ‘Ndiwe baba vangu,’ 
\q2 uye kuibwe, ‘Ndiwe wakandibereka.’ 
\q1 Vakandifuratira ini 
\q2 asi zviso zvavo hazvina, 
\q1 nyamba pavanenge vava munhamo, vanoti kwandiri, 
\q2 ‘Uyai mutiponese!’ 
\q1  
\v 28 Ko, zvino vamwari vamakazviitira varipi? 
\q2 Ngavauye kana vachigona kukuponesai 
\q2 pamunenge mava munhamo! 
\q1 Nokuti muna vamwari vakawanda 
\q2 kupfuura maguta amunawo, imi Judha. 
\b  
\q1  
\v 29 “Seiko muchindipa mhosva? 
\q2 Imi mose makandimukira,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 30 “Ndakaranga vana venyu pasina; 
\q2 havana kuteerera kurangwa. 
\q1 Munondo wenyu wakamedza vaprofita, 
\q2 kufanana neshumba inoparadza. 
\b  
\q1  
\v 31 “Haiwa, imi vechizvarwa ichi, rangarirai Shoko raJehovha rinoti: 
\b  
\q1 “Ndanga ndiri renje kuna Israeri 
\q2 here kana nyika yerima guru? 
\q1 Ko, vanhu vangu vanotaurireiko vachiti, 
\q2 ‘Takasununguka kuenda kwatada; hatichazouyizve kwamuri?’ 
\q1  
\v 32 Ko, murandakadzi angakanganwa zvishongo zvake here, 
\q2 nomwenga angakanganwa nguo dzake dzomuchato here? 
\q1 Asi vanhu vangu vakandikanganwa ini, 
\q2 mazuva asingaverengeki. 
\q1  
\v 33 Mune ruzivo rwakadii pakutevera rudo! 
\q2 Kunyange vakadzi vakaipisisa vangadzidza kubva panzira dzenyu. 
\q1  
\v 34 Panguo dzako vanhu vanowanapo 
\q2 ropa ravarombo vasina mhaka, 
\q2 kunyange usina kuvabata vachipaza. 
\q1 Asi kunyange zvakadaro 
\q2  
\v 35 unoti, ‘Handina mhosva; 
\q2 uye haana kunditsamwira.’ 
\q1 Asi ndichatema mutongo wangu 
\q2 pauri nokuti unoti, ‘Handina kutadza.’ 
\q1  
\v 36 Ko, unofambireiko pose pose zvakadai, 
\q2 uchishandura nzira dzako? 
\q1 Iwe uchagumburwa neIjipiti, 
\q2 sezvawakaitwa neAsiria. 
\q1  
\v 37 Uchabvawo panzvimbo iyoyo 
\q2 wakaisa maoko ako pamusoro pako, 
\q1 nokuti Jehovha akaramba vose vaunovimba navo; 
\q2 iwe hauchazobatsirwi navo. 
\b  
\c 3  
\q1  
\v 1 “Kana murume akaramba mukadzi wake, 
\q2 iye akamusiya hake akandowanikwa nomumwe murume, 
\q1 murume uyu angadzokerazve kwaari here? 
\q2 Ko, nyika haingasvibiswi here? 
\q1 Asi iwe wakararama sechifeve navadiwa vazhinji, 
\q2 zvino ungadzokera kwandiri here?” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 2 “Tarira kunzvimbo dzakakwirira dzisina miti uone. 
\q2 Iripo here nzvimbo yausina kumboitira ufeve? 
\q1 Mujinga menzira wakagaramo wakamirira zvikomba, 
\q2 wakagara kunge vanhu vouragu vari murenje. 
\q1 Wakasvibisa nyika noufeve hwako 
\q2 uye nezvakaipa zvako. 
\q1  
\v 3 Naizvozvo wakanyimwa mvura inopfunha, 
\q2 uye nemvura yomuchirimo haina kunaya. 
\q1  
\v 4 Ko, handiti uchangobva pakundidana here uchiti, 
\q2 ‘Baba vangu, shamwari yangu kubva pauduku hwangu, 
\q1  
\v 5 muchagara makatsamwa here? 
\q2 Kutsamwa kwenyu kucharamba kuripo nokusingaperi here?’ 
\q1 Aya ndiwo matauriro ako, 
\q2 asi unoita zvakaipa zvose zvaunogona kuita.” 
\s1 Israeri woKusatendeka 
\p  
\v 6 Panguva yokutonga kwaMambo Josia, Jehovha akati kwandiri, “Waona here zvaitwa naIsraeri wokusatendeka? Ari kuenda pamusoro pezvikomo zvose zvakakwirira nepasi pemiti yose yakapfumvutira achindoita ufevepo.  
\v 7 Ndakafunga kuti mushure mokuita kwake izvi zvose, achadzokera kwandiri asi iye haana, uye mununʼuna wake Judha wokusatendeka akazviona.  
\v 8 Ndakapa Israeri wokusatendeka tsamba yokurambana ndikamudzinga nokuda kwoufeve hwake. Kunyange zvakadaro ndakaona kuti Judha mununʼuna wake wokusatenda haatyi; naiyewo akabuda akandoita ufeve.  
\v 9 Nokuti ufeve hwaIsraeri hahuna zvahwakareva kwaari, akasvibisa nyika nokufeva namabwe namatanda.  
\v 10 Kunyange izvi zvakadaro, mununʼuna wake Judha wokusatendeka haana kudzokera kwandiri nomwoyo wake wose, asi kunyengera chete,” ndizvo zvinotaura Jehovha. 
\p  
\v 11 Jehovha akati kwandiri, “Israeri wokusatenda akarurama kukunda Judha wokusatendeka.  
\v 12 Enda undoparidza shoko iri kurutivi rwokumusoro uchiti, 
\q1 “ ‘Dzokai imi Israeri vokusatenda,’ ndizvo zvinotaura Jehovha, 
\q2 ‘Handichazorambi ndakafinyamisa chiso changu kwamuri, 
\q1 nokuti ndizere nengoni,’ ndizvo zvinotaura Jehovha, 
\q2 ‘handingarambi ndakatsamwa nokusingaperi. 
\q1  
\v 13 Imi zivai mhosva yenyu chete, 
\q2 kuti makamukira Jehovha Mwari wenyu, 
\q1 mukafadza vamwari 
\q2 vavatorwa muri pasi pomuti mumwe nomumwe wakapfumvutira, 
\q2 uye hamuna kunditeerera,’ ” 
\q4 ndizvo zvinotaura Jehovha. 
\p  
\v 14 “Dzokai, imi vanhu vokusatenda,” ndizvo zvinotaura Jehovha, “nokuti ndini murume wenyu. Ndichakusarudzai, ndichatora mumwe chete kubva kune rimwe guta, uye vaviri kubva kuno rumwe rudzi, ndigokuuyisai kuZioni.  
\v 15 Ipapo ndichakupai vafudzi vanofadza mwoyo wangu, ivo vachakutungamirirai noruzivo nokunzwisisa.  
\v 16 Mumazuva iwayo, pamunenge mawanda zvikuru munyika,” ndizvo zvinotaura Jehovha, “vanhu havangazoti, ‘Areka yesungano yaJehovha.’ Hazvingazopindi mundangariro dzavo kana kurangarirwa; havazoishuvi, havangagadziri imwezve.  
\v 17 Panguva iyoyo vachatumidza Jerusarema kuti Chigaro choUshe chaJehovha, uye ndudzi dzose dzichaungana muJerusarema kuzokudza zita raJehovha. Havachazoteverizve kusindimara kwemwoyo yavo yakaipa.  
\v 18 Mumazuva iwayo imba yaJudha ichabatana neimba yaIsraeri, uye vose pamwe chete vachauya vachibva kunyika yokumusoro vachienda kunyika yandakapa madzibaba enyu kuti ive nhaka. 
\p  
\v 19 “Ini pachangu ndakati, 
\q1 “ ‘Ndichafara sei pakukubatai savanakomana vangu 
\q2 uye ndichikupai nyika inoyevedza, 
\q2 iyo nhaka yakaisvonaka yorudzi rupi zvarwo.’ 
\q1 Ndakafunga kuti muchanditi ‘Baba’ 
\q2 mukasazotsauka pakunditevera. 
\q1  
\v 20 Asi sezvinoita mukadzi asina kutendeka kumurume wake, 
\q2 saizvozvo makanga musina kutendeka kwandiri, imi imba yaIsraeri,” 
\q4 ndizvo zvinotaura Jehovha. 
\b  
\q1  
\v 21 Kuchema kunonzwika panzvimbo dzakakwirira dzisina miti, 
\q2 iko kuchema nokuteterera kwavanhu veIsraeri, 
\q1 nokuti vakaminamisa nzira dzavo 
\q2 uye vakakanganwa Jehovha Mwari wavo. 
\b  
\q1  
\v 22 “Dzokai, imi vanhu vokusatenda; 
\q2 ndichakurapai pakudzokera kwenyu shure.” 
\b  
\q1 “Hongu, tichauya kwamuri, 
\q2 nokuti imi muri Jehovha Mwari wedu. 
\q1  
\v 23 Zvirokwazvo mheremhere youfeve iri pazvikomo, 
\q2 napamakomo unyengeri; 
\q1 zvirokwazvo muna Jehovha Mwari wedu 
\q2 ndimo mune ruponeso rwaIsraeri. 
\q1  
\v 24 Kubva pauduku hwedu nyadzi dzakadya 
\q2 zvibereko zvamabasa amadzibaba edu, 
\q1 makwai avo, nemombe dzavo, 
\q2 vanakomana navanasikana vavo. 
\q1  
\v 25 Ngativatei pasi munyadzi dzedu, 
\q2 uye kunyara kwedu ngakutifukidze. 
\q1 Takatadzira Jehovha Mwari wedu, 
\q2 isu tose namadzibaba edu; 
\q1 kubva pauduku hwedu kusvikira nhasi 
\q2 hatina kuteerera Jehovha Mwari wedu.” 
\b  
\c 4  
\q1  
\v 1 “Haiwa Israeri, kana muchida kudzoka, 
\q2 dzokai kwandiri,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1 “Kana mukabvisa pamberi pangu zvifananidzo zvenyu 
\q2 zvinonyangadza uye mukasarasikazve, 
\q1  
\v 2 kana mukapika muchokwadi, 
\q2 nokururama uye nenzira yakarurama muchiti: 
\q1 ‘Zvirokwazvo naJehovha mupenyu,’ 
\q2 ipapo ndudzi dzicharopafadzwa naye uye dzichazvirumbidza maari.” 
\p  
\v 3 Izvi ndizvo zvinotaura Jehovha kuvanhu veJudha neJerusarema: 
\q1 “Zviundirei gombo 
\q2 murege kudyara pakati peminzwa. 
\q1  
\v 4 Zvidzingisirei kuna Jehovha, 
\q2 dzingisai mwoyo yenyu, 
\q2 imi varume veJudha nemi vanhu veJerusarema, 
\q1 kuti kutsamwa kwangu kurege kukubudirai kukapisa somoto, 
\q2 nokuda kwezvakaipa zvamakaita, 
\q2 iko kupisa kusina angakudzima. 
\s1 Njodzi inobva nokumusoro 
\q1  
\v 5 “Zivisai munyika yaJudha uye muparidze muJerusarema muchiti: 
\q2 ‘Ridzai hwamanda munyika yose!’ 
\q1 Danidzirai nesimba muchiti: 
\q2 ‘Unganai pamwe chete! 
\q2 Ngatitizirei kumaguta akakomberedzwa!’ 
\q1  
\v 6 Simudzai mureza wokuenda kuZioni! 
\q2 Tizai muvande musinganonoki! 
\q1 Nokuti ndiri kuuyisa njodzi inobva kumusoro, 
\q2 iko kuparadza kwakaipisisa.” 
\b  
\q1  
\v 7 Shumba yabuda mudenhere rayo; 
\q2 muparadzi wendudzi abuda. 
\q1 Asiya nzvimbo yake 
\q2 kuti aparadze nyika yenyu. 
\q1 Maguta enyu achava matongo 
\q2 pasina achagaramo. 
\q1  
\v 8 Naizvozvo pfekai masaga, 
\q2 chemai muungudze, 
\q1 nokuti kutsamwa kwaJehovha 
\q2 kunotyisa hakuna kubva kwatiri. 
\b  
\q1  
\v 9 “Pazuva iro,” ndizvo zvinotaura Jehovha, 
\q2 “mambo namachinda vachaora mwoyo, 
\q1 vaprista vachatyiswa, 
\q2 uye vaprofita vachavhundutswa.” 
\p  
\v 10 Ipapo ndakati, “Haiwa, Ishe Jehovha, makanyengera kwazvo vanhu ava neJerusarema muchiti, ‘Muchava norugare,’ nyamba munondo uri pahuro dzedu.” 
\p  
\v 11 Panguva iyoyo vanhu ava neJerusarema vachaudzwa kuti, “Mhepo inopisa inobva kunzvimbo dzakakwirira dzisina miti mugwenga inovhuvhuta yakananga vanhu vangu, asi isingapepeti kana kunatsa;  
\v 12 mhepo ine simba kwazvo kudarika iyoyo ichabva kwandiri. Zvino ndiwo wava mutongo wangu pamusoro pavo.” 
\q1  
\v 13 Tarirai! Ari kuuya samakore, 
\q2 ngoro dzake dzinouya sechamupupuri, 
\q1 mabhiza ake anomhanya kupfuura makondo, 
\q2 Tine nhamo! Taparara! 
\q1  
\v 14 Haiwa Jerusarema, shamba zvakaipa zviri mumwoyo mako ugoponeswa. 
\q2 Ucharamba uchingoviga pfungwa dzako dzakaipa kusvikira riini? 
\q1  
\v 15 Inzwi rinodanidzira richibva kuDhani, 
\q2 richizivisa nezvenjodzi inobva kuzvikomo zveEfuremu. 
\q1  
\v 16 “Zivisai izvi kumarudzi, 
\q2 zviparidzei kuJerusarema muchiti: 
\q1 ‘Hondo ichakukombai iri kuuya ichibva kunyika iri kure, 
\q2 ichidanidzira zvehondo yokurwisa maguta eJudha. 
\q1  
\v 17 Vanorikomba savanhu vakarinda munda, 
\q2 nokuti rakandimukira,’ ” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 18 “Tsika dzako namabasa ako ndizvo zvauyisa 
\q2 izvi pamusoro pako. 
\q1 Ichi ndicho chirango chako. 
\q2 Haiwa, zvinovava sei! 
\q2 Haiwa, zvinobaya sei mwoyo!” 
\b  
\q1  
\v 19 Maiwe, kurwadziwa kwangu, 
\q2 kurwadziwa kwangu! 
\q1 Ndiri kubidirika nokurwadziwa. 
\q2 Haiwa, kurwadza kwomwoyo wangu! 
\q2 Hana yangu inorova mukati mangu, handinganyarari. 
\q1 Nokuti ndanzwa kurira kwehwamanda; 
\q2 ndanzwa mheremhere yehondo. 
\q1  
\v 20 Njodzi inotevera njodzi; 
\q2 nyika yose yava dongo. 
\q1 Munguva shoma shoma, matende angu aparadzwa, 
\q2 musha wangu nenguva diki diki. 
\q1  
\v 21 Ndicharamba ndichiona mureza wehondo kusvikira riniko, 
\q2 uye ndichanzwa kurira kwehwamanda kusvikira riniko? 
\b  
\q1  
\v 22 “Vanhu vangu mapenzi; 
\q2 havandizivi ini. 
\q1 Vana vasina pfungwa; 
\q2 havanzwisisi. 
\q1 Vakangwarira kuita zvakaipa; 
\q2 havazivi kuita zvakanaka.” 
\b  
\q1  
\v 23 Ndakatarira nyika, 
\q2 yakanga isina kugadzirwa, isina chinhu; 
\q1 uye nokumatenga, 
\q2 chiedza chawo chakanga chisisipo. 
\q1  
\v 24 Ndakatarira pamakomo, 
\q2 tarirai, aidengenyeka; 
\q2 zvikomo zvose zvaizeya. 
\q1  
\v 25 Ndakatarira, ipapo pakanga pasina vanhu; 
\q2 shiri dzose dzedenga dzakanga dzabhururuka dzikaenda kure. 
\q1  
\v 26 Ndakatarira, ndokuona nyika yaibereka zvibereko yava gwenga; 
\q2 maguta ayo ose ava matongo pamberi paJehovha, 
\q2 pamberi pehasha dzake dzinotyisa. 
\p  
\v 27 Zvanzi naJehovha: 
\q1 “Nyika yose ichaparadzwa, 
\q2 kunyange hangu ndisingazoiparadzi zvachose. 
\q1  
\v 28 Naizvozvo nyika ichachema 
\q2 uye matenga kumusoro achava rima 
\q1 nokuti ndini ndazvitaura uye handingaregi kuzviita, 
\q2 ndini ndazvisarudza uye handingadzokeri shure.” 
\b  
\q1  
\v 29 Paanonzwa kutinhira kwavatasvi vamabhiza nokwavawemburi vouta, 
\q2 maguta ose anotiza. 
\q1 Vamwe vanopinda mumatenhere; 
\q2 vamwe vanokwira pakati pamatombo. 
\q1 Maguta ose asara asina munhu; 
\q2 hapana anogaramo. 
\b  
\q1  
\v 30 Uchaiteiko, iwe wokuparadzwa? 
\q2 Wapfekereiko nguo tsvuku, 
\q2 uye unoshongereiko zvishongo zvegoridhe? 
\q1 Wazorereiko meso ako pendi? 
\q2 Unongozvishongedzera pasina. 
\q1 Zvikomba zvako zvinokushora; 
\q2 zvinotsvaka kukuuraya. 
\b  
\q1  
\v 31 Ndiri kunzwa kuchema sekwomukadzi anorwadziwa pakusununguka, 
\q2 kugomera sekwomukadzi opona dangwe rake, 
\q1 kuchema kwoMwanasikana weZioni ari kufemedzeka, 
\q2 achitambanudza maoko ake achiti, 
\q1 “Maiwe! Ndoziya; 
\q2 upenyu hwangu hwaiswa kuvaurayi.” 
\c 5  
\s1 Hakuna akarurama 
\q1  
\v 1 “Kwirai nokudzika nemigwagwa yeJerusarema, 
\q2 tarirai pose pose mugofunga, 
\q2 tsvakai muzvivara zvaro muone 
\q1 kana mukawana kana munhu mumwe 
\q2 anoita zvakanaka uye anotsvaka zvokwadi, 
\q2 ipapo ndicharegerera guta iri. 
\q1  
\v 2 Kunyange vachiti havo, ‘NaJehovha mupenyu,’ 
\q2 vanenge vachingopika nhema.” 
\q1  
\v 3 Haiwa Jehovha, meso enyu haatsvaki chokwadi here? 
\q2 Makavarova, asi havana kunzwa kurwadziwa; 
\q2 Makavapwanya, asi vakaramba kurayirwa. 
\q1 Vakaomesa zviso zvavo kupfuura dombo 
\q2 uye vakaramba kutendeuka. 
\q1  
\v 4 Ndakafunga ndikati, “Ava varombo bedzi; 
\q2 mapenzi, 
\q1 nokuti havazivi nzira yaJehovha, 
\q2 nezvinodikanwa naMwari wavo. 
\q1  
\v 5 Naizvozvo ndichaenda kuvatungamiri 
\q2 ndigotaura navo; 
\q1 zvirokwazvo vanoziva nzira yaJehovha, 
\q2 zvinodiwa naMwari wavo.” 
\q1 Asi nomwoyo mumwe, naivowo vakanga vavhuna joko, 
\q2 vakadambura makashu. 
\q1  
\v 6 Saka shumba inobva musango ichavauraya, 
\q2 bere rinobva mugwenga richavabvambura, 
\q1 ingwe ichavavandira pedyo 
\q2 namaguta avo kuti ibvamburanye vose vanobudamo, 
\q1 nokuti kundimukira kwavo kukuru 
\q2 uye kudzokera shure kwavo kwawanda. 
\b  
\q1  
\v 7 “Ndingakukanganwirai seiko? 
\q2 Vana venyu vakandisiya, 
\q2 uye vakapika navamwari vasati vari vamwari. 
\q1 Ndakavapa zvose zvavaishayiwa, 
\q2 asi ivo vakaita ufeve 
\q2 vakandoungana kudzimba dzezvifeve. 
\q1  
\v 8 Ivo mabhiza anodya achiguta azere ruchiva, 
\q2 mumwe nomumwe achidokwairira mukadzi womumwe. 
\q1  
\v 9 Ko, handingavarangi nokuda kwaizvozvi here?” 
\q2 ndizvo zvinotaura Jehovha. 
\q1 “Ko, handingazvitsiviri 
\q2 here parudzi rwakadai? 
\b  
\q1  
\v 10 “Endai nomuminda yavo yamazambiringa muiparadze, 
\q2 asi musaiparadza zvachose. 
\q1 Bvisai matavi awo, 
\q2 nokuti vanhu ava havasi vaJehovha. 
\q1  
\v 11 Imba yaIsraeri neimba yaJudha 
\q2 vanga vasina kutendeka kwandiri zvachose,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 12 Vakarevera Jehovha nhema, 
\q2 vachiti, “Haana chaachaita! 
\q1 Hakuna chakaipa chichaitika kwatiri; 
\q2 hatichazombooni hondo kana nzara. 
\q1  
\v 13 Vaprofita vangova mhepo, 
\q2 uye shoko harimo mavari. 
\q2 Saka zvavanotaura ngazviitwe kwavari.” 
\p  
\v 14 Naizvozvo zvanzi naJehovha Mwari Wamasimba Ose: 
\q1 “Nokuti vanhu vakataura mashoko aya, 
\q2 ndichaita kuti mashoko angu 
\q1 ave moto mumuromo mako, 
\q2 uye vanhu ava kuti vave huni dzinopiswa nawo. 
\q1  
\v 15 Haiwa imi imba yaIsraeri,” ndizvo zvinotaura Jehovha, 
\q2 “ndiri kuuyisa rudzi runobva kure kuzokurwisai, 
\q1 rudzi rwakare kare uye rudzi rwakashinga, 
\q2 vanhu vane rurimi rwamusinganzwi, 
\q2 vano mutauro wamusinganzwisisi. 
\q1  
\v 16 Magoba avo akafanana neguva rakashama; 
\q2 vose zvavo varwi vane simba. 
\q1  
\v 17 Vachadya zvamakakohwa nezvokudya zvenyu, 
\q2 vachauraya vanakomana navanasikana venyu; 
\q1 vachadya makwai enyu nemombe dzenyu, 
\q2 vachadya mazambiringa namaonde enyu. 
\q1 Vachaparadza nomunondo, 
\q2 maguta enyu akakomberedzwa iwo amunovimba nawo. 
\p  
\v 18 “Kunyange mumazuva iwayo,” ndizvo zvinotaura Jehovha, “handingakuparadzei zvachose.  
\v 19 Zvino kana vanhu vakabvunza kuti, ‘Ko, Jehovha Mwari wedu aitirei izvi kwatiri?’ imi muchavaudza kuti, ‘Sezvo makandisiya mukandoshumira vamwari vavatorwa munyika yenyu chaiyo, saizvozvowo zvino muchashandira vatorwa munyika isiri yenyu.’ 
\q1  
\v 20 “Zivisai izvi kuimba yaJakobho 
\q2 mugozviparidza maJudha muchiti: 
\q1  
\v 21 Inzwai izvi imi mapenzi navanhu vasina pfungwa, 
\q2 vane meso, asi vasingaoni, 
\q2 vane nzeve, asi vasinganzwi: 
\q1  
\v 22 Ko, hamufaniri kunditya here?” ndizvo zvinotaura Jehovha. 
\q2 “Ko, hamufaniri kudedera pamberi pangu here? 
\q1 Ndakaita jecha kuti rive muganhu wegungwa, 
\q2 muganhu warisingadariki nokusingaperi. 
\q1 Mafungu angafashama, asi haangakundi; 
\q2 angavirima asi haangaudariki. 
\q1  
\v 23 Asi vanhu ava vane mwoyo yakasindimara uye inondimukira; 
\q2 vakatsauka vakaenda kure. 
\q1  
\v 24 Havati mumwoyo yavo, 
\q2 ‘Ngatityei Jehovha Mwari wedu, 
\q1 anotipa mvura yaMatsutso neyoMunakamwe nenguva yayo, 
\q2 anotitsidzira mavhiki akatarwa okukohwa.’ 
\q1  
\v 25 Zvakaipa zvenyu zvakadzingira izvi kure; 
\q2 zvivi zvenyu zvakadzivisa kuti zvinhu zvakanaka zviuye kwamuri. 
\b  
\q1  
\v 26 “Pakati pavanhu vangu pane vanhu vakaipa 
\q2 vanovandira kufanana savanhu vanoteya shiri nougombe 
\q2 uye savaya vanoisa misungo yokubata vanhu. 
\q1  
\v 27 Sedendere rizere neshiri, 
\q2 dzimba dzavo dzizere nokunyengera; 
\q1 vapfuma uye vava nesimba, 
\q2  
\v 28 uye vafuta uye vobwinya. 
\q2 Zvakaipa zvavo hazvina magumo, 
\q2 havatambi mhaka dzenherera kuti vakunde, 
\q2 havadziviriri kodzero dzavarombo. 
\q1  
\v 29 Ko, handifaniri kuvaranga pane izvi here?” 
\q2 ndizvo zvinotaura Jehovha. 
\q1 “Ko, handingazvitsiviri here 
\q2 parudzi rwakadai? 
\b  
\q1  
\v 30 “Chinhu chinosemesa uye chinovhundutsa 
\q2 chaitika panyika. 
\q1  
\v 31 Vaprofita vanoprofita nhema, 
\q2 vaprista vanotonga nesimba ravo 
\q1 uye vanhu vangu vanofarira izvozvo. 
\q2 Asi muchaiteiko pakupedzisira? 
\c 6  
\s1 Kukombwa kweJerusarema 
\q1  
\v 1 “Tizai kuti murarame, imi vana veBhenjamini! 
\q2 Tizai mubve muJerusarema! 
\q1 Ridzai hwamanda muTekoa! 
\q2 Simudzai chiratidzo pamusoro peBheti Hakeremu! 
\q1 Nokuti njodzi yava pedyo ichibva kumusoro, 
\q2 iko kuparadza kwakaipisisa. 
\q1  
\v 2 Ndichaparadza mwanasikana weZioni, 
\q2 akanakisa uye anoyevedza. 
\q1  
\v 3 Vafudzi namapoka amakwai avo vachauya kuzomurwisa; 
\q2 vachadzika matende avo vakamukomba, 
\q2 mumwe nomumwe achifudza chikamu chake.” 
\q1  
\v 4 Gadzirirai kurwa naye! 
\q2 Simukai, ngatimurwisei masikati! 
\q1 “Asi, yowe-e, zuva rovira, 
\q2 uye mimvuri yamadekwana yoreba. 
\q1  
\v 5 Naizvozvo simukai, ngatimurwisei usiku, 
\q2 uye tiparadze nhare dzake!” 
\b  
\q1  
\v 6 Zvanzi naJehovha Wamasimba Ose: 
\q1 “Temerai miti pasi, 
\q2 mugovakira Jerusarema mirwi yokurikomba. 
\q1 Guta iri rinofanira kurangwa; 
\q2 rizere nokumanikidza. 
\q1  
\v 7 Setsime rinoeredza mvura yaro, 
\q2 saizvozvo Jerusarema rinodurura zvakaipa zvaro. 
\q1 Kuita nechisimba nokuparadza zvinonzwikwa mariri, 
\q2 kurwara kwaro namavanga zvinoramba zviri pamberi pangu. 
\q1  
\v 8 Inzwa yambiro, iwe Jerusarema, 
\q2 kuti ndisakufuratira 
\q1 ndikaita nyika yako dongo, 
\q2 kuti isava nomunhu angagara mairi.” 
\p  
\v 9 Zvanzi naJehovha Wamasimba Ose: 
\q1 “Ngavatanhe zvakasara zvaIsraeri 
\q2 vatanhe zvachose samazambiringa; 
\q1 utambanudzirezve ruoko rwako kumatavi, 
\q2 sezvinoita munhu anounganidza mazambiringa.” 
\b  
\q1  
\v 10 Ndingataura naaniko wandingayambira? 
\q2 Ndianiko achandinzwa? 
\q1 Nzeve dzavo dzakadzivirwa 
\q2 kuti varege kunzwa. 
\q1 Shoko raJehovha chigumbuso kwavari; 
\q2 havawani mufaro mariri. 
\q1  
\v 11 Asi ini ndizere nehasha dzaJehovha, 
\q2 uye handichagoni kuzvidzora. 
\b  
\q1 “Dzidururire pamusoro pavana vari munzira dzomuguta, 
\q2 napamusoro pamajaya akaungana pamwe chete; 
\q1 zvose murume nomukadzi vachabatwa imomo, 
\q2 navatana, vaya vabva zera. 
\q1  
\v 12 Dzimba dzavo dzichapiwa vamwe, 
\q2 minda yavo pamwe chete navakadzi vavo, 
\q2 pandichatambanudza ruoko rwangu pamusoro pavagere panyika,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 13 “Kubva kumudiki kusvikira kuvakuru, 
\q2 vose vanokarira pfuma; 
\q1 vaprofita navaprista zvimwe chetezvo, 
\q2 vose vanoita zvokunyengera. 
\q1  
\v 14 Vanosunga ronda ravanhu vangu 
\q2 sokunge vasina kukuvara zvikuru. 
\q1 Vanoti, ‘Rugare, rugare,’ 
\q2 ipo pasina rugare. 
\q1  
\v 15 Ko, vanonyadziswa nokusemesa kwamafambiro avo here? 
\q2 Kwete, havana nyadzi zvachose; 
\q2 havambozivi kuratidza nyadzi. 
\q1 Naizvozvo vachawira pakati pavakawa; 
\q2 vachadzikiswa pandichavaranga,” 
\q4 ndizvo zvinotaura Jehovha. 
\p  
\v 16 Zvanzi naJehovha: 
\q1 “Mirai pamharadzano dzenzira muone; 
\q2 mubvunze nzira dzekare, 
\q1 mubvunze kune nzira yakanaka, mugofamba mairi, 
\q2 ipapo muchawana zororo remweya yenyu. 
\q2 Asi imi makati, ‘Hatizofambi mairi.’ 
\q1  
\v 17 Ndakagadza nharirire pamusoro penyu ndikati, 
\q2 ‘Teererai inzwi rehwamanda!’ 
\q2 Asi imi makati, ‘Hatizoteereri.’ 
\q1  
\v 18 Naizvozvo inzwai, imi ndudzi, 
\q2 nemi zvapupu, 
\q2 cherechedzai zvichaitika kwavari. 
\q1  
\v 19 Inzwa, iwe nyika: 
\q1 Ndiri kuuyisa njodzi pamusoro pavanhu ava, 
\q2 icho chibereko chendangariro dzavo, 
\q1 nokuti havana kuteerera mashoko angu, 
\q2 uye vakaramba murayiro wangu. 
\q1  
\v 20 Ndine hanya yeiko nezvinonhuhwira zvinobva kuShebha, 
\q2 kana karamisi inotapira inobva kunyika iri kure? 
\q1 Zvipiriso zvenyu zvinopiswa handizvidi; 
\q2 zvibayiro zvenyu hazvindifadzi.” 
\p  
\v 21 Naizvozvo zvanzi naJehovha: 
\q1 “Ndichaisa zvipinganidzo pamberi pavanhu ava. 
\q2 Madzibaba navanakomana vachagumburwa nazvo pamwe chete, 
\q2 vavakidzani neshamwari vachaparara.” 
\p  
\v 22 Zvanzi naJehovha: 
\q1 “Tarirai, hondo iri kuuya 
\q2 kubva kunyika yokumusoro; 
\q1 rudzi rukuru rwuri kumutswa 
\q2 kubva kumigumo yenyika. 
\q1  
\v 23 Vakapakata uta nepfumo; 
\q2 vane utsinye uye havana ngoni. 
\q1 Vanonzwikwa sokutinhira kwegungwa 
\q2 vakatasva mabhiza avo; 
\q2 vari kuuya savanhu vazvigadzirira kurwa hondo 
\q2 kuti vakurwise, iwe Mwanasikana weZioni.” 
\b  
\q1  
\v 24 Takanzwa guhu ravo, 
\q2 uye maoko edu oshayiwa simba. 
\q1 Tabatwa nokurwadziwa, 
\q2 kurwadziwa kwakaita sekwomukadzi ari kusununguka. 
\q1  
\v 25 Regai kuenda kumunda, 
\q2 kana kufamba mumigwagwa, 
\q1 nokuti muvengi ane munondo, 
\q2 uye kumativi ose kune zvinotyisa. 
\q1  
\v 26 Haiwa, vanhu vangu, pfekai masaga 
\q2 mugoumburuka mumadota; 
\q1 chemai nokuchema kukuru kwazvo 
\q2 kunge munochemera mwanakomana mumwe chete, 
\q1 nokuti muparadzi 
\q2 achatiwira pakarepo. 
\b  
\q1  
\v 27 “Ndakakuita muedzi wamatare 
\q2 navanhu vangu mhangura, 
\q1 kuti ucherechedze 
\q2 uye uedze nzira dzavo. 
\q1  
\v 28 Vose vamukiri vakaoma mwoyo, 
\q2 vanongofamba-famba vachiita makuhwa. 
\q1 Ivo indarira nesimbi; 
\q2 vose vanoita zvakaora. 
\q1  
\v 29 Mvuto inovhutira zvinotyisa 
\q2 kuti ipise mutobvu nomoto, 
\q1 asi kunatswa kunongova pasina; 
\q2 nokuti vakaipa havasi kubviswa. 
\q1  
\v 30 Vanonzi sirivha yakarambwa, 
\q2 nokuti Jehovha akavaramba.” 
\c 7  
\s1 Zvitendero zvenhema hazvina maturo 
\p  
\v 1 Iri ndiro shoko rakauya kuna Jeremia richibva kuna Jehovha:  
\v 2 “Mira pasuo reimba yaJehovha, uparidzepo shoko iri rokuti: 
\p “ ‘Inzwai shoko raJehovha imi mose vanhu veJudha vanopinda napamasuo aya kuzonamata Jehovha.  
\v 3 Zvanzi naJehovha Wamasimba Ose, Mwari waIsraeri: Shandurai nzira dzenyu namaitiro enyu, ndigokugarisai munzvimbo ino.  
\v 4 Musavimba namashoko anonyengedza muchiti, “Iyi ndiyo temberi yaJehovha, temberi yaJehovha, temberi yaJehovha!”  
\v 5 Kana mukashandura chaizvoizvo nzira dzenyu namaitiro enyu mukaitirana zvakarurama,  
\v 6 kana mukasamanikidza vatorwa, nenherera kana chirikadzi uye mukasateura ropa risina mhosva panzvimbo ino, uye kana mukasatevera vamwe vamwari muchizvipinza munjodzi,  
\v 7 ipapo ndichakugarisai munzvimbo ino, munyika yandakapa madzitateguru enyu nokusingaperi-peri.  
\v 8 Asi tarirai, munovimba namashoko okunyengera asina maturo. 
\p  
\v 9 “ ‘Mungaba mugouraya, mugoita upombwe mugopika nhema, muchipisira zvinonhuhwira kuna Bhaari, mugotevera vamwe vamwari vamusina kumboziva,  
\v 10 ndokuzouya zvino momira pamberi pangu muimba ino, iyo ine Zita rangu, muchiti, “Takasunungurwa,” makasunungurwa kuti muite izvi zvose zvinonyangadza here?  
\v 11 Ko, imba ino, inodanwa neZita rangu, yava bako ramakororo here? Asika, ndanga ndichizviona, ndizvo zvinotaura Jehovha. 
\p  
\v 12 “ ‘Chiendai zvino kunzvimbo iri muShiro pandakagarisa Zita rangu pakutanga mugoona zvandakuitirai nokuda kwezvakaipa zvavanhu vangu Israeri.  
\v 13 Pamakanga muchiita zvinhu zvose izvi, ndizvo zvinotaura Jehovha, ndakataura nemi ndataurazve asi hamuna kuteerera; ndakakudanai asi hamuna kupindura.  
\v 14 Naizvozvo, zvandakaitira Shiro ndizvo zvandichaita iye zvino kuimba inodanwa neZita rangu, iyo temberi yamunovimba nayo, nzvimbo yandakakupai imi namadzibaba enyu.  
\v 15 Ndichakubvisai pamberi pangu sezvandakaita kuhama dzenyu dzose, ivo vanhu vaEfuremu.’ 
\p  
\v 16 “Naizvozvo iwe chirega kunyengeterera vanhu ava kana kupa chikumbiro chipi zvacho kana kuvareverera; usavakumbirira kwandiri, nokuti handingakunzwi.  
\v 17 Hauoni here zvavari kuita mumaguta eJudha nomumigwagwa yeJerusarema?  
\v 18 Vana vanounganidza huni, madzibaba ndokubatidza moto, uye madzimai anokanya furawu ndokuitira Mambokadzi woKudenga makeke echingwa. Vanodurura zvipiriso zvokunwa kuna vamwe vamwari kuti vanditsamwise.  
\v 19 Asi ndini here wavanotsamwisa? ndizvo zvinotaura Jehovha. Ko, hakuzi kuzvikuvadza pachavo here kuti vanyadziswe? 
\p  
\v 20 “ ‘Naizvozvo Ishe Jehovha anoti: Kutsamwa kwangu nehasha dzangu zvichadururirwa pamusoro penzvimbo iyi, pamusoro pavanhu nezvipfuwo, napamusoro pemiti yesango napamusoro pezvibereko zvevhu, uye zvichatsva zvikasadzimwa. 
\p  
\v 21 “ ‘Zvanzi naJehovha Wamasimba Ose, Mwari weIsraeri: Endererai mberi, wedzerai zvipiriso zvenyu zvinopiswa pamusoro pezvimwe zvibayiro mugodya nyama yacho pachenyu!  
\v 22 Nokuti pandakabudisa madzitateguru enyu kubva muIjipiti ndikataura navo, handina kungovapa mirayiro pamusoro pezvipiriso zvinopiswa nezvibayiro,  
\v 23 asi ndakavapa murayiro uyu wokuti nditeererei, uye ndichava Mwari wenyu nemi muchava vanhu vangu. Mufambe munzira dzose dzandakakurayirai, kuti zvigova zvakanaka kwamuri.  
\v 24 Asi havana kuteerera kana kurereka nzeve dzavo; asi vakatevera kutsauka kwoukukutu hwemwoyo yavo yakaipa. Vakadzokera shure vakasaenda mberi.  
\v 25 Kubvira panguva yakabuda madzitateguru enyu muIjipiti kusvikira zvino, zuva nezuva, ndakatuma varanda vangu vaprofita ndavatumazve.  
\v 26 Asi havana kunditeerera kana kuita hanya. Vaiva nemitsipa mikukutu uye vakaita zvakaipa kupfuura madzitateguru avo.’ 
\p  
\v 27 “Pauchavataurira zvose izvi, havasi kuzokuteerera; pauchavadana, havasi kuzokupindura.  
\v 28 Naizvozvo iwe uti kwavari, ‘Urwu ndirwo rudzi rusina kuteerera Jehovha Mwari warwo kana kubvuma kurayirwa. Chokwadi chakaparara, hachisisipo pamiromo yavo.  
\v 29 Veurai bvudzi renyu mugorirasira kure; chemai muri pazvikomo zvisina miti, nokuti Jehovha akaramba uye akasiya chizvarwa ichi chaakatsamwira. 
\s1 Mupata woKuurayiwa kwaVanhu 
\p  
\v 30 “ ‘Vanhu veJudha vakaita zvakaipa pamberi pangu, ndizvo zvinotaura Jehovha. Vakamisa zvifananidzo zvavo zvinonyangadza mumba yakapiwa Zita rangu vakaisvibisa.  
\v 31 Vakavaka nzvimbo dzakakwirira dzeTofeti muMupata waBheni Hinomi kuti vapise vanakomana navasikana vavo mumoto, chinhu chandisina kuvarayira, chisina kumbopinda mupfungwa dzangu.  
\v 32 Saka chenjerai, mazuva anouya, ndizvo zvinotaura Jehovha, apo vanhu vasingazopadaidzi kuti Tofeti kana Mupata waBheni Hinomi, asi Mupata woKuurayiwa kwaVanhu, nokuti vachaviga vakafa muTofeti kusvikira pasisina nzvimbo.  
\v 33 Ipapo mitumbi yavanhu ava ichava zvokudya zveshiri dzedenga nemhuka dzenyika, uye hapazovi nomunhu angazvivhundutsira kuti zvibve.  
\v 34 Ndichaita kuti inzwi rokupembera nomufaro uye namanzwi omwenga nechikomba mumaguta eJudha nomumigwagwa yeJerusarema zvigume nokuti nyika ichava dongo. 
\c 8  
\p  
\v 1 “ ‘Panguva iyoyo, ndizvo zvinotaura Jehovha, mapfupa amadzimambo namachinda eJudha, namapfupa avaprista navaprofita, uye mapfupa avanhu veJerusarema, achabviswa kubva mumakuva avo.  
\v 2 Achava pamhene agorohwa nezuva uye achavhenekwa nomwedzi nenyeredzi dzose dzedenga, zvavakada vakazvishumira vakazvitevera uye vakabvunza kwazviri, vakazvinamata. Haangaunganidzwi kana kuvigwa, asi achafanana nomupfudze uri panyika.  
\v 3 Kwose zvako kwandichavadzingira, vakasara vose vorudzi urwu rwakaipa, vachademba rufu pachinzvimbo choupenyu, ndizvo zvinotaura Jehovha Wamasimba Ose.’ 
\s1 Chivi noKurangwa 
\p  
\v 4 “Uti kwavari, ‘Zvanzi naJehovha: 
\q1 “ ‘Vanhu pavanowira pasi, havamukizve here? 
\q2 Munhu akange ambotsauka, haadzokizve here? 
\q1  
\v 5 Zvino nemhaka yei ava vadzokera shure? 
\q2 Nemhaka yei Jerusarema richingogara richitsauka? 
\q1 Vanobatirira pakunyengera, 
\q2 vanoramba kudzoka. 
\q1  
\v 6 Ndakanyatsoteereresa, 
\q2 asi ivo havambotauri zvakarurama. 
\q1 Hakuna anotendeuka pane zvakaipa zvake achiti, 
\q2 “Ndaiteiko?” 
\q1 Mumwe nomumwe anongotevedza nzira yake 
\q2 sebhiza rinomhanyira kurwa hondo. 
\q1  
\v 7 Kunyange shohori riri mudenga 
\q2 rinoziva nguva dzaro dzakatarwa, 
\q1 uye njiva, nenyenganyenga nekondo 
\q2 zvinocherechedza nguva yazvo yokutama. 
\q1 Asi vanhu vangu havazivi 
\q2 zvinodikanwa naJehovha. 
\b  
\q1  
\v 8 “ ‘Munoreva seiko muchiti, “Takachenjera, 
\q2 nokuti tino murayiro waJehovha,” 
\q1 asi zvirokwazvo chinyoreso chenhema chavanyori 
\q2 chakanyora nhema? 
\q1  
\v 9 Vakachenjera vachanyadziswa, 
\q2 vachavhunduka uye vachabatwa. 
\q1 Sezvo vakaramba shoko raJehovha, 
\q2 kuchenjera kwavanako kwakadiniko? 
\q1  
\v 10 Naizvozvo ndichapa vakadzi vavo kuna vamwe varume, 
\q2 neminda yavo kuvaridzi vatsva. 
\q1 Kubva kumuduku kusvikira kumukuru vose 
\q2 vanokarira pfuma; 
\q1 vaprofita navaprista saizvozvo, 
\q2 vose vanoita nokunyengera. 
\q1  
\v 11 Vanosunga vanga ravanhu vangu 
\q2 sokunge duku duku. 
\q1 Vanoti, “Rugare, rugare,” 
\q2 ipo pasina rugare. 
\q1  
\v 12 Ko, vanonyadziswa netsika dzavo dzinonyangadza here? 
\q2 Kwete, havana kana nyadzi zvachose; 
\q2 havambozivi kuti zvinonyadzisa sei. 
\q1 Saka vachawa pakati pavakawa; 
\q2 vachaderedzwa pavacharangwa, 
\q4 ndizvo zvinotaura Jehovha. 
\b  
\q1  
\v 13 “ ‘Ndichavatorera zvavakakohwa, 
\q4 ndizvo zvinotaura Jehovha. 
\q2 Hapangazovi namazambiringa pamuzambiringa. 
\q1 Hakungazovi namaonde pamuti womuonde, 
\q2 uye mashizha azvo achaoma. 
\q1 Zvandakavapa 
\q2 vachazvitorerwa.’ ” 
\b  
\q1  
\v 14 “Ko, takagarireiko pano? 
\q2 Unganai pamwe chete! 
\q1 Ngatitizirei kumaguta akakomberedzwa 
\q2 tindofira ikoko! 
\q1 Nokuti Jehovha Mwari wedu atitongera kufa, 
\q2 nokuti akatipa mvura ino muchetura kuti tinwe, 
\q2 nokuti takamutadzira. 
\q1  
\v 15 Takanga takatarisira rugare 
\q2 asi hakuna chakanaka chakauya; 
\q1 takatarisira kuporeswa 
\q2 asi paingova nokuvhundutswa. 
\q1  
\v 16 Kufemedzeka kwamabhiza omuvengi 
\q2 kunonzwika kuchibva kuDhani; 
\q1 panorira makono awo 
\q2 nyika yose inodedera. 
\q1 Auya kuzoparadza 
\q2 nyika nezvose zviri mairi, 
\q2 guta navose vanogara imomo.” 
\b  
\q1  
\v 17 “Tarirai ndichatumira nyoka dzino uturu pakati penyu, 
\q2 mvumbi dzicharamba kuimbirwa, 
\q2 uye dzichakurumai,” 
\q4 ndizvo zvinotaura Jehovha. 
\b  
\q1  
\v 18 Haiwa, Munyaradzi wangu, pakuchema kwangu, 
\q2 mwoyo wangu woziya mukati mangu. 
\q1  
\v 19 Inzwai kuchema kwavanhu vangu 
\q2 kunobva kunyika iri kure kure: 
\q1 “Ko, Jehovha haazi muZioni here? 
\q2 Mambo waro haachimo here?” 
\b  
\q1 “Vakanditsamwisireiko nezvifananidzo zvavo, 
\q2 nezvifananidzo zvavo zvavatorwa zvisingabatsiri?” 
\b  
\q1  
\v 20 “Kucheka kwapfuura, 
\q2 zhizha rapera, 
\q2 asi tigere kuponeswa.” 
\b  
\q1  
\v 21 Sezvo vanhu vangu vapwanyiwa, neniwo ndapwanyiwa; 
\q2 ndiri kuchema, uye ndiri kutya zvikuru. 
\q1  
\v 22 Ko, muGireadhi hamuna muti webharisamu here? 
\q2 Hakuna murapi ikoko here? 
\q1 Seiko zvino ronda 
\q2 ravanhu vangu risina kurapwa? 
\c 9  
\q1  
\v 1 Haiwa, dai musoro wangu waiva chitubu chemvura 
\q2 uye meso angu riri tsime remisodzi! 
\q1 Ndingadai ndaichema masikati nousiku 
\q2 nokuda kwavakaurayiwa vavanhu vangu. 
\q1  
\v 2 Haiwa, dai ndaiva nenzvimbo 
\q2 mugwenga yokugara yavafambi, 
\q1 kuitira kuti ndisiye vanhu vangu 
\q2 ndiende kure navo; 
\q1 nokuti vose imhombwe, 
\q2 ungano yavanhu vasina kutendeka. 
\q1  
\v 3 “Vanokunga rurimi rwavo souta, 
\q2 kuti vapfure nhema; 
\q1 havaiti nechokwadi 
\q2 pakukunda kwavanoita munyika. 
\q1 Vanobva pane chimwe chivi vachienda pane chimwe; 
\q2 havandizivi ini,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 4 “Chenjererai shamwari dzenyu; 
\q2 musavimba nehama dzenyu. 
\q1 Nokuti hama ipi neipi inonyengera, 
\q2 uye shamwari ipi neipi inoita makuhwa. 
\q1  
\v 5 Shamwari inonyengera shamwari, 
\q2 uye hakuna anotaura chokwadi. 
\q1 Vakadzidzisa ndimi dzavo kureva nhema; 
\q2 vanozvinetsa nokuita zvakaipa. 
\q1  
\v 6 Munogara pakati pounyengeri; 
\q2 mukunyengera kwavo vanoramba kundiziva ini,” 
\q4 ndizvo zvinotaura Jehovha. 
\p  
\v 7 Naizvozvo zvanzi naJehovha Wamasimba Ose: 
\q1 “Tarirai, ndichavanatsa 
\q2 uye ndichavaedza, ndechipi chimwe chandingaita 
\q2 nokuda kwechivi chavanhu vangu? 
\q1  
\v 8 Rurimi rwavo museve unouraya; 
\q2 runotaura nokunyengera. 
\q1 Nomuromo wake mumwe nomumwe anotaura zvakanaka kune wokwake, 
\q2 asi mumwoyo make anomuteyera musungo. 
\q1  
\v 9 Ko, handigavarangi nokuda kwechinhu ichi here?” 
\q2 ndizvo zvinotaura Jehovha. 
\q1 “Ko, handingazvitsiviri 
\q2 pamusoro porudzi rwakadai here?” 
\b  
\q1  
\v 10 Ndichachema uye ndichaungudza nokuda kwamakomo, 
\q2 uye ndichachema pamusoro pamafuro egwenga. 
\q1 Aparara uye hakuna anofambako, 
\q2 uye kukuma kwemombe hakunzwiki. 
\q1 Shiri dzedenga dzatiza, 
\q2 uye mhuka dzaenda. 
\b  
\q1  
\v 11 “Ndichaita Jerusarema murwi wedongo, 
\q2 panogara makava; 
\q1 uye ndichaparadza maguta eJudha, 
\q2 kuti kurege kuva nomunhu anogarako.” 
\p  
\v 12 Ndoupiko munhu akachenjera zvokuti anganzwisisa izvi? Ndianiko akarayirwa naJehovha uye angatsanangura izvi? Nemhaka yeiko nyika yanyangadzwa yava dongo ikafanana negwenga risina angapfuura nomo? 
\p  
\v 13 Jehovha akati, “Nemhaka yokuti vakasiya murayiro wangu, wandakaisa pamberi pavo, havana kunditeerera kana kutevera murayiro wangu.  
\v 14 Asi, vakatevera kusindimara kwemwoyo yavo; vakatevera vanaBhaari, sezvavakadzidziswa namadzibaba avo.”  
\v 15 Naizvozvo zvanzi naJehovha Wamasimba Ose, Mwari weIsraeri, “Tarirai ndichaita kuti vanhu ava vadye zvinovava uye kuti vanwe mvura ino muchetura.  
\v 16 Ndichavaparadzira pakati pendudzi dzavasina kumboziva uye dzisina kumbozivikanwa namadzibaba avo, uye ndichavatevera nomunondo kusvikira ndavaparadza.” 
\p  
\v 17 Zvanzi naJehovha Wamasimba Ose: 
\q1 “Rangarirai zvino! Danai vakadzi vanochema vauye; 
\q2 danai vanogonesesa pakati pavo. 
\q1  
\v 18 Ngavakurumidze kuuya 
\q2 vagochema pamusoro pedu 
\q1 kusvikira maziso edu ayerera misodzi, 
\q2 nzizi dzoyerera mumaziso edu. 
\q1  
\v 19 Maungira okuchema anonzwika kubva kuZioni achiti: 
\q2 ‘Haiwa taparadzwa sei! 
\q2 Haiwa kunyadziswa kwedu kukuru sei! 
\q1 Tinofanira kusiya nyika yedu 
\q2 nokuti dzimba dzedu dzava matongo.’ ” 
\b  
\q1  
\v 20 Zvino, imi vakadzi, inzwai shoko raJehovha; 
\q2 dziurai nzeve dzenyu dzinzwe mashoko omuromo wake. 
\q1 Dzidzisai vanasikana venyu kuungudza; 
\q2 dzidzisanai kuchema. 
\q1  
\v 21 Rufu rwakapinda napamawindo edu 
\q2 uye rwapinda munhare dzedu; 
\q1 rwauraya vana mumigwagwa 
\q2 namajaya ari munzira dzeguta. 
\p  
\v 22 Uti, “Zvanzi naJehovha: 
\q1 “ ‘Zvitunha zvavanhu zvichavata 
\q2 somupfudze uri pamusoro pomunda, 
\q1 sezviyo zvakachekwa shure kwavacheki, 
\q2 zvisina achazviunganidza.’ ” 
\p  
\v 23 Zvanzi naJehovha: 
\q1 “Akachenjera ngaarege kuzvirumbidza pamusoro penjere dzake, 
\q2 kana munhu ane simba pamusoro pesimba rake, 
\q2 kana akapfuma pamusoro pepfuma yake, 
\q1  
\v 24 Asi anozvirumbidza ngaazvirumbidze pamusoro pezvizvi: 
\q2 kuti anondinzwisisa uye kuti anondiziva ini, 
\q1 kuti ndini Jehovha, anoita unyoro, 
\q2 nokukururamisira, nokururama panyika, 
\q2 nokuti ndinofarira izvozvi,” 
\q4 ndizvo zvinotaura Jehovha. 
\p  
\v 25 “Mazuva anouya,” ndizvo zvinotaura Jehovha, “andicharanga vose vakadzingiswa panyama chete,  
\v 26 Ijipiti, Judha, Edhomu, Amoni, Moabhu navose vanogara mugwenga kunzvimbo dziri kure. Nokuti ndudzi dzose idzi hadzina kumbodzingiswa, uye kunyange imba yose yaIsraeri haina kudzingiswa, mumwoyo.” 
\c 10  
\s1 Mwari neZvifananidzo 
\p  
\v 1 Inzwai zvinoreva Jehovha kwamuri, imi imba yaIsraeri.  
\v 2 Zvanzi naJehovha: 
\q1 “Regai kudzidza tsika dzendudzi 
\q2 kana kuvhundutswa nezviratidzo zviri kudenga 
\q2 kunyange hazvo ndudzi dzichivhundutswa nazvo. 
\q1  
\v 3 Nokuti tsika dzavanhu hadzina maturo; 
\q2 vanotema muti musango, 
\q2 muvezi ouveza nembezo. 
\q1  
\v 4 Vanoushongedza nesirivha negoridhe; 
\q2 vanourovera nenyundo nezvipikiri 
\q2 kuti urege kuzungunuka. 
\q1  
\v 5 Sedukununu kumucheto womunda wamavise, 
\q2 zvifananidzo zvavo hazvigoni kutaura; 
\q1 zvinofanira kutotakurwa nokuti hazvigoni kufamba. 
\q2 Musazvitya; hazvigoni kukukuvadzai, 
\q2 uye hazvina nebasa rose.” 
\b  
\q1  
\v 6 Hakuna akafanana nemi, imi Jehovha; 
\q2 muri mukuru, 
\q2 uye zita renyu iguru pasimba. 
\q1  
\v 7 Ndianiko angarega kukutyai, 
\q2 imi Mambo wendudzi? 
\q1 Izvi ndizvo zvakakufanirai. 
\q2 Pakati pavakachenjera vose vendudzi nomuushe hwavo hwose, 
\q2 hakuna akafanana nemi. 
\q1  
\v 8 Vose havana njere uye mapenzi; 
\q2 vanodzidziswa nezvifananidzo zvamatanda zvisingabatsiri. 
\q1  
\v 9 Sirivha yakapfurwa inotorwa kubva kuTashishi 
\q2 negoridhe richibva kuUfazi. 
\q1 Zvakaitwa nemhizha uye nomupfuri wegoridhe, 
\q2 zvopfekedzwa zvino nguo dzomucheka webhuruu nowepepuru, 
\q2 zvose zvinoitwa navabati vano umhizha. 
\q1  
\v 10 Asi Jehovha ndiye Mwari wechokwadi; ndiye Mwari mupenyu, 
\q2 mambo wokusingaperi. 
\q1 Kana iye atsamwa, nyika inodedera; 
\q2 ndudzi hadzigoni kumira pamberi pehasha dzake. 
\p  
\v 11 “Muvaudze kuti, ‘Vamwari ava, vasina kuita matenga nenyika, vachaparara panyika nepasi pamatenga.’ ” 
\q1  
\v 12 Asi Mwari akaita nyika nesimba rake, 
\q2 akateya nyika nouchenjeri hwake, 
\q2 uye akatambanudza matenga nokunzwisisa kwake. 
\q1  
\v 13 Paanotinhira, mvura zhinji iri mumatenga inoita mubvumo; 
\q2 anoita kuti makore asimuke kubva kumigumo yenyika. 
\q1 Anotuma mheni pamwe nemvura, 
\q2 uye anouyisa mhepo kubva mumatura ake. 
\b  
\q1  
\v 14 Mumwe nomumwe haafungi uye haana zivo; 
\q2 mupfuri mumwe nomumwe wegoridhe anonyadziswa nezvifananidzo zvake. 
\q1 Zvifananidzo zvake ndezvenhema; 
\q2 hazvina mweya mazviri. 
\q1  
\v 15 Hazvina maturo, zvinhu zvokutuka; 
\q2 kutongwa kwazvo pakunosvika, zvose zvichaparara. 
\q1  
\v 16 Iye anenge ari mugove waJakobho haana kufanana nazvo, 
\q2 nokuti ndiye Muiti wezvinhu zvose, 
\q1 kusanganisa naIsraeri, rudzi rwenhaka yake, 
\q2 Jehovha Wamasimba Ose ndiro zita rake. 
\s1 Kuparadzwa Kuri Kuuya 
\q1  
\v 17 Unganidzai nhumbi dzenyu mubve munyika, 
\q2 imi makakombwa. 
\q1  
\v 18 Nokuti zvanzi naJehovha: 
\q2 “Panguva ino ndichapotsera kure 
\q2 avo vanogara munyika ino; 
\q1 Ndichauyisa nhamo 
\q2 pamusoro pavo kuti vagotapwa.” 
\b  
\q1  
\v 19 Ndine nhamo nokuda kwokukuvara kwangu! 
\q2 Ronda rangu harirapiki! Asi ndakati, 
\q1 “Uku kurwara ndokwangu, 
\q2 uye ndinofanira kukutakura.” 
\q1  
\v 20 Tende rangu raparadzwa; 
\q2 mabote aro ose adamburwa. 
\q1 Vanakomana vangu vabva kwandiri uye havachipozve; 
\q2 hakuna asara zvino kuti amise tende rangu 
\q2 kana kumisa dumba rangu. 
\q1  
\v 21 Vafudzi havana njere, 
\q2 uye havabvunzi Jehovha; 
\q1 saka havabudiriri 
\q2 uye makwai avo ose apararira. 
\q1  
\v 22 Inzwai! Chiziviso chiri kuuya, 
\q2 bope guru richabva kunyika yokumusoro! 
\q1 Richaita kuti maguta eJudha aparare, 
\q2 agarwe namakava. 
\s1 Munyengetero waJeremia 
\q1  
\v 23 Haiwa Jehovha, ndinoziva kuti upenyu hwomunhu hahusi hwake; 
\q2 hazvizi kumunhu kuti aruramise nzira dzake. 
\q1  
\v 24 Ndirangei, Jehovha, asi chete nokururamisira, 
\q2 kwete mukutsamwa kwenyu, 
\q2 kuti murege kundiparadza zvachose. 
\q1  
\v 25 Dururirai kutsamwa kwenyu pamusoro pendudzi 
\q2 dzisingakurangarirei, 
\q2 pamusoro pavanhu vasingadani kuzita renyu. 
\q1 Nokuti vakadya Jakobho; 
\q2 vakamudya zvachose, 
\q2 uye vakaparadza nyika yake. 
\c 11  
\s1 Sungano Yaputswa 
\p  
\v 1 Iri ndiro shoko rakauya kuna Jeremia richibva kuna Jehovha:  
\v 2 “Inzwai mashoko esungano iyi mugoazivisa kuvanhu veJudha nokuna vanogara muJerusarema.  
\v 3 Muvaudze kuti zvanzi naJehovha Mwari waIsraeri, ‘Akatukwa munhu asingateereri mashoko esungano iyi,  
\v 4 mashoko andakarayira madzitateguru enyu pandakavabudisa muIjipiti kubva muchoto chamatare.’ Ndakati, ‘Nditeererei mugoita zvose zvandinokurayirai, mugova vanhu vangu, ini ndigova Mwari wenyu.  
\v 5 Ipapo ndichazadzisa mhiko yandakapika kumadzitateguru enyu, kuti ndichavapa nyika inoyerera mukaka nouchi,’ nyika yava yenyu nhasi.” 
\p Ndakapindura ndichiti, “Ameni, Jehovha.” 
\p  
\v 6 Jehovha akati kwandiri, “Paridza mashoko aya ose mumaguta eJudha nomumigwagwa yeJerusarema uchiti, ‘Inzwai mashoko esungano iyi muatevere.  
\v 7 Kubva panguva yandakabudisa madzitateguru enyu kubva muIjipiti kusvikira nhasi, ndakavayambira ndavayambirazve ndichiti, “Nditeererei.”  
\v 8 Asi havana kuteerera kana kuva nehanya; asi vakatevera kusindimara kwemwoyo yavo yakaipa. Saka ndakauyisa pamusoro pavo kutuka kwose kwesungano yandakanga ndavarayira kuti vatevere asi havana kuichengeta.’ ” 
\p  
\v 9 Ipapo Jehovha akati kwandiri, “Pane rangano pakati pavanhu veJudha navanogona kundimukira navanogara muJerusarema.  
\v 10 Vadzokera pazvakaipa zvamadzitateguru avo, avo vakaramba kuteerera mashoko angu. Vakatevera vamwe vamwari kuti vavashumire. Dzimba mbiri idzi, yaIsraeri neyaJudha dzakaputsa sungano yandakaita namadzitateguru avo.  
\v 11 Naizvozvo zvanzi naJehovha, ‘Ndichauyisa njodzi pamusoro pavo yavasingagoni kupunyuka. Kunyange vakachema kwandiri handingavateereri.  
\v 12 Maguta eJudha navanhu veJerusarema vachaenda kundodana kuna vamwari vavaipisira zvinonhuhwira, asi havazovabatsiri zvachose pavanosvikirwa nenjodzi.  
\v 13 Una vamwari vakawanda sokuwanda kwakaita maguta ako, iwe Judha; uye aritari dzamakamisa kuti mupisire zvinonhuhwira kuna mwari anonyadzisa, iye Bhaari, dzakawanda sokuwanda kwakaita migwagwa yeJerusarema.’ 
\p  
\v 14 “Usanyengeterera vanhu kana kupa chikumbiro chipi zvacho kana kuvakumbirira, nokuti handizoteereri pavanodana kwandiri panguva yokutambudzika kwavo. 
\q1  
\v 15 “Ko, mudiwa wangu ari kuitei mutemberi yangu, 
\q2 zvaari kuita mabasa ake akaipa navazhinji? 
\q1 Ko, nyama yakatsaurwa ingadzivisa kurohwa kwako here? 
\q1 Pamunoita zvakaipa zvenyu, 
\q2 ipapo imi mofara.” 
\b  
\q1  
\v 16 Jehovha akati ndiwe muti womuorivhi une upenyu, 
\q2 une michero yakanaka yakaurungana. 
\q1 Asi nokutinhira kwemhepo ine simba 
\q2 achautungidza nomoto, 
\q2 uye matavi awo achavhunika. 
\m  
\v 17 Jehovha Wamasimba Ose, iye akakusima, atema chirevo chezvakaipa kwauri, nokuti imba yaIsraeri neimba yaJudha vakaita zvakaipa, vakanditsamwisa nokupisira Bhaari zvinonhuhwira. 
\s1 Rangano pamusoro paJeremia 
\p  
\v 18 Nokuti Jehovha akandionesa rangano yavo, ndikaiziva, nokuti panguva iyoyo akandiratidza zvavakanga vachiita.  
\v 19 Ndakanga ndakaita segwayana rakapfava riri kuendeswa kundobayiwa; ndakanga ndisingazivi kuti vakanga vandirangana, vachiti, 
\q1 “Ngatiparadzei muti nemichero yawo; 
\q2 ngatimubvisei panyika yavapenyu, 
\q2 kuti zita rake rirege kuzorangarirwazve.” 
\q1  
\v 20 Asi imi Jehovha Wamasimba Ose, iyemi munotonga nokururama, 
\q2 uye munoedza mwoyo nendangariro, 
\q1 ngandione kutsiva kwenyu pamusoro pavo, 
\q2 nokuti ndakaisa mhaka yangu kwamuri. 
\p  
\v 21 “Naizvozvo zvanzi naJehovha pamusoro pavarume veAnatoti vari kutsvaka kukuuraya, vachiti, ‘Regai kuprofita nezita raJehovha nokuti ungafa namaoko edu,’  
\v 22 naizvozvo zvanzi naJehovha Wamasimba Ose, ‘Ndichavaranga. Majaya avo achafa nomunondo, vanakomana navanasikana vavo vachafa nenzara.  
\v 23 Hakuna kunyange mumwe achasara kwavari, nokuti ndichauyisa njodzi pamusoro pavarume veAnatoti mugore rokurangwa kwavo.’ ” 
\c 12  
\s1 Kugununʼuna kwaJeremia 
\q1  
\v 1 Imi munogara makarurama, iyemi Jehovha, 
\q2 pandinouya pamberi penyu nemhaka. 
\q1 Kunyange zvakadaro ndichataura nemi pamusoro pokururamisira kwenyu, ndichiti: 
\q2 Nemhaka yeiko nzira yavakaipa ichibudirira? 
\q2 Nemhaka yei vasingatendi vachirarama zvakanaka? 
\q1  
\v 2 Makavasima, uye vava nemidzi; 
\q2 vanokura uye vanobereka muchero. 
\q1 Imi munogara muri pamiromo yavo 
\q2 asi muri kure nemwoyo yavo. 
\q1  
\v 3 Asi munondiziva, imi Jehovha; 
\q2 munondiona uye munoedza ndangariro dzangu pamusoro penyu. 
\q1 Vakwekweredzei samakwai anondobayiwa! 
\q2 Muvagadzirire zuva rokubayiwa. 
\q1  
\v 4 Nyika ichasvika riniko yakangooma, 
\q2 nebundo resango rakangosvava? 
\q1 Nokuti vose vanogaramo vakaipa, 
\q2 mhuka neshiri zvaparara. 
\q1 Pamusoro paizvozvo, vanhu vanoti, 
\q2 “Haasi kuzoona zvinoitika kwatiri.” 
\s1 Mhinduro yaMwari 
\q1  
\v 5 “Kana wakaita nhangemutange navanhu netsoka, 
\q2 uye vakakunetesa 
\q2 ungagokwikwidzana sei namabhiza? 
\q1 Kana uchigumburwa panyika yakanaka, 
\q2 ungagara seiko mumatenhere eJorodhani? 
\q1  
\v 6 Hama dzako, mhuri yako chaiyo, 
\q2 kunyange naivowo vakakumukira; 
\q2 vakadanidzira zvikuru kwazvo pamusoro pako. 
\q1 Usavimba navo, 
\q2 kunyange vachitaura zvakanaka pamusoro pako. 
\b  
\q1  
\v 7 “Ndichasiya imba yangu, 
\q2 ndigorasa nhaka yangu; 
\q1 ndichapa mudikani wangu 
\q2 mumaoko avavengi vake. 
\q1  
\v 8 Nhaka yangu yava kwandiri 
\q2 seshumba iri musango. 
\q1 Anoomba pamberi pangu; 
\q2 naizvozvo ndinomuvenga. 
\q1  
\v 9 Ko, nhaka yangu haizova kwandiri segondo rina mavara here, 
\q2 iro rinokombwa 
\q2 uye rinorwiswa namamwe makondo? 
\q1 Endai munounganidza zvikara zvose; 
\q2 muuye nazvo zvidye. 
\q1  
\v 10 Vafudzi vazhinji vachaparadza munda 
\q2 wangu womuzambiringa, 
\q1 uye vachatsindira munda wangu; 
\q2 vachashandura munda wangu unofadza kuti uve dongo risina chinhu. 
\q1  
\v 11 Uchaitwa dongo rakaoma 
\q2 uye rakaparadzwa pamberi pangu; 
\q1 nyika yose ichava dongo 
\q2 nokuti hakuna ane hanya. 
\q1  
\v 12 Pamusoro pezvikomo zvisina miti zviri mugwenga, 
\q2 vaparadzi vachamomotera, 
\q1 nokuti munondo waJehovha uchaparadza, 
\q2 kubva kuno rumwe rutivi rwenyika kusvikira kuno rumwe, 
\q2 hakuna achava norugare. 
\q1  
\v 13 Vachadyara gorosi asi vachakohwa minzwa; 
\q2 vachazvinetesa asi hakuna chavachawana. 
\q1 Saka zvitakurirei kunyadziswa kwegohwo renyu, 
\q2 nokuda kwokutsamwa kunotyisa kwaJehovha.” 
\p  
\v 14 Zvanzi naJehovha: “Kana vari vakaipa vakavakidzana nemi vanopamba nhaka yandakapa vanhu vangu vaIsraeri ndichavadzura munyika dzavo uye ndichadzura imba yaJudha kubva pakati pavo.  
\v 15 Asi mushure mokuvadzura, ndichavanzwirazve tsitsi uye ndichadzosa mumwe nomumwe wavo kunhaka yake nokunyika yake.  
\v 16 Zvino kana vadzidza zvakanaka nzira dzavanhu vangu uye vakapika nezita rangu, vachiti, ‘Zvirokwazvo naJehovha mupenyu,’ kunyange havo vakambodzidzisa vanhu vangu kupika naBhaari, ipapo vachasimbiswa pakati pavanhu vangu.  
\v 17 Asi kana pano rudzi rusingateereri, ndicharudzura zvachose ndigoruparadza,” ndizvo zvinotaura Jehovha. 
\c 13  
\s1 Bhanhire roMucheka 
\p  
\v 1 Zvakanzi naJehovha kwandiri: “Enda unotenga bhanhire romucheka urisunge muchiuno chako, asi usarege richipinda mvura,”  
\v 2 Saka ndakatenga bhanhire, sezvandakarayirwa naJehovha, ndokurisunga muchiuno changu. 
\p  
\v 3 Ipapo shoko raJehovha rakauya kwandiri kechipiri richiti,  
\v 4 “Tora bhanhire rawakatenga, rawakasunga muchiuno chako uende iye zvino kuPerati undoriviga ikoko mumukaha wamatombo.”  
\v 5 Saka ndakaenda ndikandoriviga paPerati sezvandakaudzwa naJehovha. 
\p  
\v 6 Mazuva mazhinji akati apfuura Jehovha akati kwandiri, “Chienda zvino kuPerati undotora bhanhire randakati uvigeko.”  
\v 7 Naizvozvo ndakaenda kuPerati ndokufukunura bhanhire ndokuritora, uye risingachabatsiri zvachose. 
\p  
\v 8 Ipapo shoko raJehovha rakauya kwandiri, richiti,  
\v 9 “Zvanzi naJehovha: ‘Nenzira imwe cheteyo ndichaodza kuzvikudza kweJudha nokuzvikudza kukuru kweJerusarema.  
\v 10 Vanhu ava vakaipa, vanoramba kunzwa mashoko angu, vanotevera kusindimara kwemwoyo yavo uye vanoenda kuna vamwe vamwari kuti vavashumire uye vavanamate, vachafanana nebhanhire iri, risingabatsiri chose!  
\v 11 Nokuti sebhanhire rinosungwa muchiuno saizvozvo ndakasungira imba yose yaIsraeri neimba yose yaJudha kwandiri,’ ndizvo zvinotaura Jehovha, ‘kuti vave vanhu vemukurumbira wangu, kurumbidzwa kwangu nokukudzwa kwangu. Asi havana kuteerera.’ 
\s1 Hombodo dzeWaini Dzamatehwe 
\p  
\v 12 “Uti kwavari, ‘Zvanzi naJehovha, Mwari waIsraeri: Hombodo imwe neimwe yedehwe yewaini inofanira kuzadzwa newaini.’ Zvino kana vakati kwauri, ‘Ko, isu hatizivi here kuti hombodo imwe neimwe yedehwe yewaini inofanira kuzadzwa newaini?’  
\v 13 ipapo uvaudze kuti, ‘Zvanzi naJehovha: Ndichadhakisa vose vanogara munyika ino, pamwe chete namadzimambo anogara pachigaro choushe chaDhavhidhi, navaprista navaprofita navose vanogara muJerusarema.  
\v 14 Ndichavabonderedza mumwe kuno mumwe, madzibaba navanakomana saizvozvo, ndizvo zvinotaura Jehovha. Handingabvumiri tsitsi kana ngoni dzangu kuti zvindidzivise kuvaparadza.’ ” 
\s1 Dambudziko roKuendeswa kuUtapwa 
\q1  
\v 15 Inzwai, rerekai nenzeve dzenyu kwandiri, 
\q2 musazvikudza, 
\q2 nokuti Jehovha ataura. 
\q1  
\v 16 Rumbidzai Jehovha Mwari 
\q2 wenyu asati auyisa rima, 
\q1 makumbo enyu asati agumburwa 
\q2 pamakomo erima. 
\q1 Munotarisira chiedza, 
\q2 asi iye achachishandura kuti chive mumvuri worufu, 
\q2 uye achachiita rima guru. 
\q1  
\v 17 Asi kana musingateereri, 
\q2 ndichachema pakavanda 
\q2 nokuda kwokuzvikudza kwenyu; 
\q1 Meso angu achachema zvikuru, 
\q2 achiyerera misodzi, 
\q2 nokuti boka ramakwai aJehovha richaendeswa kuutapwa. 
\q1  
\v 18 Uti kuna mambo nokuna mai vamambo, 
\q2 “Burukai pazvigaro zvenyu zvoushe, 
\q1 nokuti korona dzenyu dzokukudzwa 
\q2 dzichawira pasi kubva pamisoro yenyu.” 
\q1  
\v 19 Maguta okuNegevhi achazarirwa, 
\q2 uye hakuna munhu achaazarura. 
\q1 VaJudha vose vachaendeswa kuutapwa, 
\q2 vachaendeswa kure zvachose. 
\b  
\q1  
\v 20 Simudza meso ako uone 
\q2 avo vanobva nechokumusoro. 
\q1 Ko, boka ramakwai rawakapiwa kuti urichengete riripi, 
\q2 iwo makwai awaizvirumbidza nawo? 
\q1  
\v 21 Uchati kudiniko kana Jehovha achiisa pamusoro pako 
\q2 avo vawakadzidzisa seshamwari dzako dzakasarudzika? 
\q1 Haungarwadziwi zvikuru here, 
\q2 somukadzi osununguka mwana? 
\q1  
\v 22 Zvino kana ukazvibvunza pachako, uchiti: 
\q2 “Sei izvi zvaitika kwandiri?” 
\q1 zvaitika nokuda kwezvivi zvako zvizhinji, 
\q2 kuti nguo dzako dzabvarurwa, 
\q2 uye muviri wako ukasabatwa zvakanaka. 
\q1  
\v 23 Ko, muEtiopia angashandura ganda rake here, 
\q2 kana ingwe mavara ayo? 
\q1 Saizvozvowo imi hamungagoni kuita zvakanaka, 
\q2 imi makarovedzera kuita zvakaipa. 
\b  
\q1  
\v 24 “Ndichakuparadzirai sehundi inopepereswa 
\q2 nemhepo yomugwenga. 
\q1  
\v 25 Uyu ndiwo mugove wako, 
\q2 ndicho chikamu chandakakutemera,” 
\q4 ndizvo zvinotaura Jehovha, 
\q1 “nokuti wakandikanganwa 
\q2 ukavimba navamwari venhema. 
\q1  
\v 26 Ndichafukura nguo dzako pamberi pako, 
\q2 kuti kunyadziswa kwako kuonekwe, 
\q1  
\v 27 upombwe hwako nokufemhedza kworuchiva rwako, 
\q2 iko kufeva kwako kusina nyadzi! 
\q1 Ndakaona mabasa ako anonyangadza 
\q2 awaiita pamusoro pezvikomo nomumunda. 
\q1 Une nhamo, iwe Jerusarema! 
\q2 Ucharamba usina kuchena kusvikira rinhiko?” 
\c 14  
\s1 Kusanaya kweMvura, Nzara, Munondo 
\p  
\v 1 Iri ndiro shoko raJehovha kuna Jeremia pamusoro pokusanaya kwemvura: 
\q1  
\v 2 “Judha anochema, 
\q2 maguta ake apera simba; 
\q1 vanoungudza nokuda kwenyika, 
\q2 uye kuchema kwokwira kuchibva kuJerusarema. 
\q1  
\v 3 Vanokudzwa vanotuma varanda vavo kundochera mvura; 
\q2 vanoenda kumatsime, 
\q2 asi vanoshayiwa mvura. 
\q1 Vanodzoka nezvirongo zvavo zvisina mvura; 
\q2 vaora mwoyo uye vasisina tariro, 
\q2 vanofukidza misoro yavo. 
\q1  
\v 4 Nyika yaparuka 
\q2 nokuti munyika hamuchina mvura; 
\q1 varimi vaora mwoyo 
\q2 uye vanofukidza misoro yavo. 
\q1  
\v 5 Kunyange nehadzi yenondo iri musango 
\q2 inosiya mhuru yayo ichangoberekwa 
\q2 nokuti hakuchina bundo. 
\q1  
\v 6 Mbizi dzinomira pazvikomo zvisina miti, 
\q2 uye dzinofemedzeka semakava; 
\q1 meso adzo haachaona zvakanaka 
\q2 nokuda kwokushaya mafuro.” 
\b  
\q1  
\v 7 Kunyange zvivi zvedu zvichipupura zvakaipa, 
\q2 imi Jehovha, onai zvamungaita nokuda kwezita renyu. 
\q1 Nokuti kudzokera kwedu shure kukuru; 
\q2 takakutadzirai. 
\q1  
\v 8 Imi Tariro yaIsraeri, 
\q2 Muponesi wavo panguva yokutambudzika, 
\q1 maitireiko somutorwa munyika, 
\q2 somufambi anongovata usiku humwe chete? 
\q1  
\v 9 Maitireiko somunhu ashamisika 
\q2 somurwi ashaya simba rokuponesa? 
\q1 Muri pakati pedu, imi Jehovha, 
\q2 uye takatumidzwa zita renyu; 
\q2 regai kutisiya! 
\p  
\v 10 Zvanzi naJehovha pamusoro pavanhu ava, 
\q1 “Vanofarira kungofamba-famba; 
\q2 havadzori tsoka dzavo. 
\q1 Saka Jehovha haavagamuchiri; 
\q2 zvino acharangarira zvakaipa zvavo 
\q2 uye achavaranga nokuda kwezvivi zvavo.” 
\p  
\v 11 Ipapo Jehovha akati kwandiri, “Rega kunyengeterera kugara zvakanaka kwavanhu ava.  
\v 12 Kunyange vakatsanya, handinganzwi kuchema kwavo; kunyange vakapa zvipiriso zvinopiswa nezvipiriso zvezviyo, handingazvigamuchiri. Asi ndichavaparadza nomunondo, nenzara uye nedenda.” 
\p  
\v 13 Asi ndakati, “Haiwa Ishe Jehovha, vaprofita vanogara vachivataurira kuti, ‘Hamungaoni munondo kana kufa nenzara. Zvirokwazvo ndichakupai rugare rusingaperi panzvimbo ino.’ ” 
\p  
\v 14 Ipapo Jehovha akati kwandiri, “Vaprofita vanoprofita nhema muzita rangu. Ini handina kuvatuma kana kuvagadza kana kutaura kwavari. Vanokuprofitirai zviratidzo zvenhema, nezvakavukwa, nezvifananidzo nokurasika kwendangariro dzavo.  
\v 15 Naizvozvo zvanzi naJehovha pamusoro pavaprofita vanoprofita muzita rangu: Handina kuvatuma, asi ivo vanoti, ‘Hakungavi nomunondo kana nzara ichawira nyika ino.’ Vaprofita vacho ivavo, vachaparara nomunondo nenzara.  
\v 16 Uye vanhu vavaiprofitira vacharasirwa munzira dzeJerusarema nokuda kwenzara nomunondo. Hakuna munhu achavaviga ivo, kana vakadzi vavo, kana vanakomana vavo, kana vanasikana vavo. Ndichadururira pamusoro pavo njodzi yakafanira. 
\p  
\v 17 “Taura shoko iri kwavari, uti, 
\q1 “ ‘Meso angu ngaayerere misodzi 
\q2 usiku namasikati asingaregi; 
\q1 nokuti mhandara mwanasikana wangu, vanhu vangu, 
\q2 vakuvadzwa vanga rakaipa, iko kurohwa kukuru. 
\q1  
\v 18 Kana ndikaenda mukati menyika, 
\q2 ndinoona vaya vakaurayiwa nomunondo; 
\q1 kana ndikaenda muguta, 
\q2 ndinoona vakaparadzwa nenzara. 
\q1 Vose, muprofita nomuprista 
\q2 vakaenda kunyika yavasingazivi.’ ” 
\b  
\q1  
\v 19 Ko, maramba Judha zvachose here? 
\q2 Munozvidza Zioni here? 
\q1 Sei makatirwadzisa 
\q2 zvokuti tirege kuporeswa? 
\q1 Takatarisira rugare 
\q2 asi hakuna chakanaka chakauya, 
\q1 takatarisira nguva yokuporeswa 
\q2 asi panongova nokuvhundutswa bedzi. 
\q1  
\v 20 Haiwa Jehovha, tinobvuma zvakaipa zvedu, 
\q2 uye nemhosva yamadzibaba edu; 
\q2 zvirokwazvo takakutadzirai. 
\q1  
\v 21 Nokuda kwezita renyu, musatizvidza; 
\q2 regai kushora chigaro chenyu chinobwinya. 
\q1 Rangarirai henyu sungano yenyu nesu 
\q2 mugorega kuiputsa. 
\q1  
\v 22 Ko, pazvifananidzo zvisina maturo zvendudzi, chiripo chinganayisa mvura here? 
\q2 Ko, matenga, anonayisa mvura oga here? 
\q1 Kwete, ndimi, iyemi Jehovha Mwari wedu. 
\q2 Naizvozvo tariro yedu iri mamuri, 
\q2 nokuti ndimi moga munoita izvi zvose. 
\c 15  
\p  
\v 1 Ipapo Jehovha akati kwandiri, “Kunyange dai Mozisi naSamueri vaimira pamberi pangu, mwoyo wangu hawaiva nehanya navanhu ava. Vadzingei pamberi pangu! Regai vaende!  
\v 2 Zvino kana vakakubvunza vachiti, ‘Tichaendepiko?’ Uvaudze kuti, ‘Zvanzi naJehovha: 
\q1 “ ‘Vakafanirwa norufu ngavaende kurufu, 
\q1 vakafanirwa nomunondo, kumunondo; 
\q1 vakafanirwa nenzara, kunzara; 
\q1 vakafanirwa noutapwa, kuutapwa.’ 
\p  
\v 3 “Ndichatumira mhando ina dzavaparadzi pamusoro pavo,” ndizvo zvinotaura Jehovha, “munondo kuti uuraye uye imbwa kuti dzikwekweredzere kure, neshiri dzedenga nemhuka dzenyika kuti dzidye uye dziparadze.  
\v 4 Ndichaita kuti vavengwe noushe hwose hwenyika nokuda kwezvakaitwa muJerusarema naManase, mwanakomana waHezekia mambo weJudha. 
\q1  
\v 5 “Ndianiko achakunzwira tsitsi, iwe Jerusarema? 
\q2 Ndianiko achakuchemera? 
\q2 Ndianiko achamira achikubvunza mufaro? 
\q1  
\v 6 Wakandiramba,” ndizvo zvinotaura Jehovha. 
\q2 “Unoramba uchidzokera shure. 
\q1 Saka ndichakubata noruoko rwangu ndigokuparadza; 
\q2 handichagoni kuramba ndichikunzwira tsitsi. 
\q1  
\v 7 Ndichavarudza neforogo yokurudzisa, 
\q2 pamasuo eguta renyika. 
\q1 Ndichauyisa kufirwa nokuparadzwa pamusoro pavanhu vangu, 
\q2 nokuti havana kushandura nzira dzavo. 
\q1  
\v 8 Ndichawanza chirikadzi dzavo 
\q2 kupfuura jecha regungwa. 
\q1 Panguva yamasikati ndichauyisa muparadzi, 
\q2 pamusoro pavanamai vamajaya avo; 
\q1 pakarepo, ndichaburutsa pamusoro pavo 
\q2 kurwadziwa nokutya. 
\q1  
\v 9 Mai vakabereka vana vanomwe vachaziya vagofa. 
\q1 Zuva rake richavira achiri masikati; 
\q2 achanyadziswa uye achaninipiswa. 
\q2 Vachapunyuka ndichavaisa kumunondo 
\q2 pamberi pavavengi vavo,” 
\q4 ndizvo zvinotaura Jehovha. 
\b  
\q1  
\v 10 Yowe-e, mai vangu, zvamakandibereka 
\q2 kuti ndive murume anorwiswa uye anomisidzanwa naye nenyika yose! 
\q1 Handina kumbopa munhu chikwereti, kana kutora chikwereti, 
\q2 asi zvakadaro vanhu vose vanondituka. 
\p  
\v 11 Jehovha akati, 
\q1 “Zvirokwazvo ndichakurwira nokuda kwechikonzero chakanaka; 
\q2 zvirokwazvo ndichaita kuti vavengi vako vakunyengetedze 
\q2 panguva yenjodzi nepanguva yokutambudzika. 
\b  
\q1  
\v 12 “Ko, munhu angavhuna simbi here, 
\q2 simbi inobva nechokumusoro, kana ndarira? 
\q1  
\v 13 Pfuma yako namatura ako 
\q2 ndichazvipa sezvakapambwa, pasina muripo, 
\q1 nokuda kwezvivi zvako zvose munyika yako yose. 
\q1  
\v 14 Ndichakuita muranda wavavengi vako 
\q2 kunyika yausingazivi, 
\q2 nokuti kutsamwa kwangu kuchabatidza moto 
\q2 uchapfuta kuti ukupise.” 
\q1  
\v 15 Haiwa Jehovha, imi munonzwisisa; 
\q2 ndirangarirei mugondichengeta. 
\q2 Munditsivire kuvatambudzi vangu. 
\q1 Imi mune mwoyo murefu, musandibvisa; 
\q2 fungai kuti ndakanyadziswa sei nokuda kwenyu. 
\q1  
\v 16 Mashoko enyu paakasvika ndakaadya; 
\q2 akanga ari mufaro wangu nokufadzwa kwomwoyo wangu, 
\q1 nokuti ndakatumidzwa zita renyu, 
\q2 imi Jehovha Mwari Wamasimba Ose. 
\q1  
\v 17 Handina kumbogara pakati peungano yavanozvifadza, 
\q2 handina kumbofara navo; 
\q1 ndakagara ndoga nokuti ruoko rwenyu rwaiva pamusoro pangu, 
\q2 uye makanga mandizadza nokutsamwa. 
\q1  
\v 18 Seiko kurwadziwa kwangu kusingaperi, 
\q2 uye ronda rangu richirwadza uye risingarapiki? 
\q1 Muchava kwandiri sorukova runonyengera, 
\q2 sechitubu chinopwa? 
\p  
\v 19 Naizvozvo zvanzi naJehovha: 
\q1 “Kana ukatendeuka, ndichakudzosazve 
\q2 kuti ugondishumira; 
\q1 kana ukataura zvakafanira, kwete mashoko asakafanira, 
\q2 uchava munhu anotaura akandimirira. 
\q1 Vanhu ava ngavadzokere kwauri, 
\q2 asi iwe usaenda kwavari. 
\q1  
\v 20 Ndichakuita rusvingo kuvanhu ava, 
\q2 nhare yorusvingo rwendarira; 
\q1 vacharwa newe, 
\q2 asi havangakukundi, 
\q1 nokuti ini ndinewe, 
\q2 kuti ndikurwire ndigokuponesa,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 21 “Ndichakuponesa kubva mumaoko avakaipa 
\q2 uye ndichakudzikinura pamaoko avano utsinye.” 
\c 16  
\s1 Zuva reNjodzi 
\p  
\v 1 Ipapo shoko raJehovha rakasvika kwandiri richiti,  
\v 2 “Haufaniri kuwana mukadzi kana kuva navanakomana kana vanasikana panzvimbo ino.”  
\v 3 Nokuti zvanzi naJehovha, pamusoro pavanakomana navanasikana vanoberekwa munyika ino napamusoro pavakadzi vanova vanamai vavo navarume vanova madzibaba avo:  
\v 4 “Vachafa nehosha dzakaipisisa. Havangazochemwi kana kuvigwa asi vachafanana nomupfudze uri pamusoro penyika. Vachaparara nomunondo nenzara, uye zvitunha zvavo zvichava zvokudya zveshiri dzedenga nemhuka dzepanyika.” 
\p  
\v 5 Nokuti zvanzi naJehovha: “Usapinda muimba mune zvokudya zvamariro: usaenda kundochema kana kuvanzwira tsitsi, nokuti ndabvisa maropafadzo norudo rwangu nengoni dzangu pavanhu ava,” ndizvo zvinotaura Jehovha.  
\v 6 “Vose, vakuru navaduku vachafa munyika ino. Havangavigwi kana kuchemwa, uye hakuna munhu achazvicheka kana kuveura musoro wake nokuda kwavo.  
\v 7 Hakuna munhu achavapa chokudya kuti vanyarare pakuchema kwavo vakafa, hakuna kunyange baba chaivo kana mai, hakuna kana achavapa mvura yokunwa chaiyo kuti vanyarare. 
\p  
\v 8 “Newe usapinda muimba inoitirwa mutambo kundogara pasi uchidya nokunwa.  
\v 9 Nokuti zvanzi naJehovha Wamasimba Ose, Mwari weIsraeri: Ndichagumisa panzvimbo ino, muchizviona pamazuva enyu, mheremhere yokupembera nenzwi romufaro uye nenzwi romwenga nerechikomba. 
\p  
\v 10 “Paunovaudza vanhu ava izvi zvose ivo vakakubvunza vachiti ‘Jehovha aisireiko kwatiri chirevo chenjodzi yakakura kudai? Chakaipa chatakaita ndecheiko? Chivi chedu ndecheiko? Chivi chedu ndecheiko chatakatadzira Jehovha Mwari wedu?’  
\v 11 ipapo uti kwavari, ‘Nemhaka yokuti madzibaba enyu akandisiya,’ ndizvo zvinotaura Jehovha, ‘vakatevera vamwe vamwari vakavashumira uye vakavanamata. Vakandisiya ini uye havana kuchengeta mirayiro yangu.  
\v 12 Asi imi makaita zvakaipa kupfuura madzibaba enyu. Tarirai kuti mumwe nomumwe wenyu anotevera sei kusindimara kwomwoyo wake wakaipa pano kuti anditeerere ini.  
\v 13 Saka ndichakudzingai panyika ino ndichikuisai kunyika yamusina kumboziva imi kana madzibaba enyu mugondoshumira vamwe vamwari ikoko masikati nousiku, nokuti handingakunzwirei nyasha.’ 
\p  
\v 14 “Kunyange zvakadaro, mazuva anouya,” ndizvo zvinotaura Jehovha, “avasingazotizve, ‘NaJehovha mupenyu iye akabudisa vaIsraeri muIjipiti,’  
\v 15 asi vachati, ‘NaJehovha mupenyu, akabudisa vaIsraeri kubva munyika yokumusoro uye nokubva munyika dzose dzaakanga avadzingira.’ Nokuti ndichavadzoserazve kunyika yandakapa madzitateguru avo. 
\p  
\v 16 “Asi zvino ndichavatumira varedzi vehove vazhinji,” ndizvo zvinotaura Jehovha, “vagozovabata. Mushure maizvozvo ndichatumira vavhimi vazhinji, vachavavhima pamusoro pegomo roga roga napamusoro pechikomo choga choga uye nomumapako amatombo.  
\v 17 Meso angu ari pamusoro penzira dzavo dzose; hadzina kuvanzika kwandiri, uye chivi chavo hachina kuvanzika pameso angu.  
\v 18 Ndichatsiva zvakaipa zvavo nechivi chavo, zvakapetwa kaviri, nokuti vakasvibisa nyika yangu nezvitunha zvezvifananidzo zvavo zvisina maturo, uye vakazadza nhaka yangu nezvifananidzo zvavo zvinonyangadza.” 
\q1  
\v 19 Imi Jehovha, simba rangu nenhare yangu, 
\q2 utiziro hwangu munguva yokutambudzika, 
\q1 ndudzi dzichauya kwamuri 
\q2 dzichibva kumagumo enyika, dzichiti, 
\q1 “Madzibaba edu akanga asina chaanacho asi vamwari venhema bedzi, 
\q2 izvo zvifananidzo zvisingabatsiri zvisina chakanaka chazvakavaitira. 
\q1  
\v 20 Ko, vanhu vanozviitira vamwari vavo here? 
\q2 Hongu, asi havasi vamwari!” 
\b  
\q1  
\v 21 “Naizvozvo ndichavadzidzisa, 
\q2 nguva ino ndichavadzidzisa 
\q2 simba rangu noukuru hwangu. 
\q1 Ipapo vachaziva 
\q2 kuti zita rangu ndiJehovha. 
\b  
\c 17  
\q1  
\v 1 “Chivi chaJudha chakanyorwa nechinyoreso chesimbi, 
\q2 chakanyorwa nomuromo webwe rakapinza kwazvo, 
\q1 pahwendefa dzemwoyo yavo 
\q2 nepanyanga dzearitari dzavo. 
\q1  
\v 2 Kunyange vana vavo vanorangarira 
\q2 aritari dzavo namatanda aAshera 
\q1 munyasi memiti yakapfumvutira 
\q2 uye napazvikomo zvakakwirira. 
\q1  
\v 3 Gomo rangu riri munyika 
\q2 uye pfuma yako namatura ako ose 
\q1 ndichazviendesa kuutapwa, 
\q2 pamwe chete nenzvimbo dzako dzakakwirira, 
\q2 nokuda kwechivi chiri munyika yako yose. 
\q1  
\v 4 Nokuda kwokutadza kwako, ucharasikirwa 
\q2 nenhaka yandakakupa. 
\q1 Ndichakuita muranda wavavengi vako 
\q2 munyika yausingazivi, 
\q1 nokuti wakabatidza kutsamwa kwangu, 
\q2 uye kuchapfuta nokusingaperi.” 
\p  
\v 5 Zvanzi naJehovha: 
\q1 “Ngaatukwe munhu uyo anovimba nomumwe munhu, 
\q2 anovimba nesimba renyama 
\q2 ano mwoyo unofuratira Jehovha. 
\q1  
\v 6 Achafanana negwenzi murenje; 
\q2 haangaoni kubudirira pakunosvika. 
\q1 Achagara munzvimbo dzakaoma dzemugwenga, 
\q2 munyika yomunyu isingagarwi nomunhu. 
\b  
\q1  
\v 7 “Asi akakomborerwa munhu anovimba naJehovha, 
\q2 akaisa chivimbo chake maari. 
\q1  
\v 8 Achafanana nomuti wakasimwa pamvura, 
\q2 unotuma midzi yawo kurukova. 
\q1 Hautyi kana kupisa kuchisvika; 
\q2 mashizha awo anogara ari manyoro. 
\q1 Haufunganyi mugore rokusanaya kwemvura, 
\q2 uye haumboshayiwi zvibereko.” 
\b  
\q1  
\v 9 Mwoyo unonyengera kupfuura zvinhu zvose, 
\q2 uye wakaora chose. 
\q2 Ndiani angauziva? 
\b  
\q1  
\v 10 “Ini Jehovha ndinonzvera mwoyo 
\q2 uye ndinoedza ndangariro, 
\q1 kuti ndipe munhu zvakaringana namafambiro ake, 
\q2 uye zvakafanira mabasa ake.” 
\b  
\q1  
\v 11 Sechikwari chinochochonya mazai achisina kukandira, 
\q2 ndizvo zvakaita munhu anowana pfuma nokusarurama. 
\q1 Pakati pamazuva ake, zvichamusiya, 
\q2 uye pakupedzisira achazviona kuti ibenzi. 
\b  
\q1  
\v 12 Chigaro choushe chinobwinya, chakanga chakasimudzirwa kubva pakutanga, 
\q2 ndicho nzvimbo yedu tsvene. 
\q1  
\v 13 Imi Jehovha, tariro yaIsraeri, 
\q2 vose vanokusiyai vachanyadziswa. 
\q1 Vose vanotsauka kwamuri vachanyorwa muvhu, 
\q2 nokuti vakasiya Jehovha, 
\q2 chitubu chemvura mhenyu. 
\b  
\q1  
\v 14 Haiwa Jehovha, ndiporesei, ipapo ndichaporeswa; 
\q2 ndiponesei, ipapo ndichaponeswa, 
\q2 nokuti imi ndimi wandinorumbidza. 
\q1  
\v 15 Vanogara vachiti kwandiri, 
\q2 “Shoko raJehovha riripiko? 
\q2 Ngarizadziswe iye zvino!” 
\q1  
\v 16 Handina kutiza pakuva mufudzi wenyu; 
\q2 munoziva kuti handina kushora zuva rokupera kwetariro. 
\q2 Zvinobuda mumuromo mangu zviri pachena pamberi penyu. 
\q1  
\v 17 Musava chinhu chinotyisa kwandiri; 
\q2 ndimi utiziro hwangu pazuva renjodzi. 
\q1  
\v 18 Vatambudzi vangu ngavanyadziswe, 
\q2 asi ini ndidzivirirei pakunyadziswa; 
\q1 ngavavhunduswe ivo, 
\q2 asi ini ndidzivirirei kuti ndisavhunduswa. 
\q1 Uyisai pamusoro pavo zuva renjodzi; 
\q2 vaparadzei nokuparadza kwakapetwa kaviri. 
\s1 Kuchengeta Sabata rive Dzvene 
\p  
\v 19 Izvi ndizvo zvakataurwa naJehovha kwandiri: “Enda undomira pasuo ravanhu, panopinda nokubuda namadzimambo eJudha; ugondomirazve pane mamwe masuo ose eJerusarema.  
\v 20 Uti kwavari, ‘Inzwai shoko raJehovha, imi madzimambo eJudha navanhu vose veJudha navose vanogara muJerusarema vanopinda napamasuo aya.  
\v 21 Zvanzi naJehovha: Zvichenjererei kuti murege kutakura mutoro nomusi weSabata kana kuupinza napasuo reJerusarema.  
\v 22 Musabudisa mitoro mudzimba dzenyu kana kuita basa ripi neripi pazuva reSabata, asi chengetai zuva reSabata rive dzvene, sezvandakarayira madzitateguru enyu.  
\v 23 Asi havana kunzwa kana kurereka nzeve dzavo; vakava nemitsipa mikukutu uye havana kumboteerera kana kugamuchira kurayirwa.  
\v 24 Asi kana mukachenjerera kuti munditeerere, ndizvo zvinotaura Jehovha, mukasauya nemitoro napamasuo eguta iri nomusi weSabata, asi muchichengeta zuva reSabata kuti rive dzvene nokusaita basa ripi neripi pazuva iroro,  
\v 25 ipapo madzimambo anogara pachigaro choushe chaDhavhidhi vachauya napamasuo eguta namachinda avo. Ivo namachinda avo vachauya vakakwira ngoro namabhiza, vachiperekedzwa navarume veJudha navose vanogara muJerusarema, uye guta rino richagarwa nokusingaperi.  
\v 26 Vanhu vachauya kumaguta eJudha uye nokumisha yakapoteredza Jerusarema, kubva kunyika yeBhenjamini nokujinga rezvikomo zvokumavirira, nokunyika yemakomo uye nokuNegevhi, vachiuyisa zvipiriso zvinopiswa nezvibayiro, uye zvipiriso zvezviyo, nezvinonhuhwira nezvipo zvokuvonga kuimba yaJehovha.  
\v 27 Asi kana mukarega kunditeerera kuti muchengete zuva reSabata kuti rive dzvene, musingaregi kutakura mutoro pamunopinda pamasuo eJerusarema nezuva reSabata, ipapo ndichabatidza moto usingadzimwe mumasuo eJerusarema uchapedza nharo dzaro.’ ” 
\c 18  
\s1 Paimba yoMuumbi weHari 
\p  
\v 1 Iri ndiro shoko rakauya kuna Jeremia richibva kuna Jehovha richiti,  
\v 2 “Buruka uende kuimba yomuumbi wehari, ndigokupa shoko rangu ikoko.”  
\v 3 Saka ndakaenda kuimba yomuumbi wehari, ndikamuona achishanda paguyo.  
\v 4 Asi hari yaakanga achiumba nevhu yakashatiswa mumaoko ake; saka muumbi akaita imwe hari akaiumba namaumbiro aaiona akanaka. 
\p  
\v 5 Ipapo shoko raJehovha rakasvika kwandiri richiti,  
\v 6 “Haiwa imba yaIsraeri, handingagoni kuita nemi sezvinoita muumbi wehari uyu here?” ndizvo zvinotaura Jehovha. “Sezvakaita ivhu muruoko rwomuumbi, ndizvo zvamakaita muruoko rwangu, imi imba yaIsraeri.  
\v 7 Kana ndikazivisa panguva ipi zvayo kuti rudzi kana ushe zvidzurwe nokubvarurwa uye zviparadzwe,  
\v 8 uye kana rudzi urwo rwandakayambira rukatendeuka pane zvakaipa zvarwo, ipapo ndichazvidemba ndigorega kuisa pamusoro pavo njodzi yandakanga ndavarongera.  
\v 9 Uye kana pane imwe nguva ndikazivisa kuti rudzi kana ushe zvivakwe uye zvisimwe,  
\v 10 uye kana rukaita zvakaipa pamberi pangu uye rukasanditeerera, ipapo ndicharangarirazve zvakanaka zvandakanga ndichida kuruitira. 
\p  
\v 11 “Naizvozvo zvino uti kuvanhu veJudha naavo vanogara muJerusarema, ‘Zvanzi naJehovha: Tarirai, ndiri kugadzirira njodzi uye ndiri kuronga urongwa hwakaipa pamusoro penyu. Saka dzokai mubve panzira dzenyu dzakaipa, mumwe nomumwe wenyu, uye mushandure nzira dzenyu namaitiro enyu.’  
\v 12 Asi vachapindura vachiti, ‘Hazvina maturo. Ticharambira pane zvatakafunga; mumwe nomumwe wedu achatevera kusindimara kwomwoyo wake wakaipa.’ ” 
\p  
\v 13 Naizvozvo zvanzi naJehovha: 
\q1 “Bvunzai pakati pevedzimwe ndudzi kuti: 
\q2 Ndiani akambonzwa chimwe chinhu chakadai? 
\q1 Chinhu chakaipa kwazvo chakaitwa 
\q2 neMhandara Israeri. 
\q1  
\v 14 Ko, chando cheRebhanoni 
\q2 chinomboshayikwawo pamawere ematombo here? 
\q1 Ko, mvura yaro inotonhorera inoyerera ichibva kure 
\q2 inombomira kuyerera here? 
\q1  
\v 15 Kunyange zvakadaro, vanhu vangu vakandikanganwa; 
\q2 vanopisira zvinonhuhwira kuzvifananidzo zvisina maturo, 
\q1 izvo zvakaita kuti vagumburwe munzira dzavo, 
\q2 uye napamakwara ekare kare. 
\q1 Vakavaita kuti vafambe mumakwara akatsauka 
\q2 nomumigwagwa isina kugadzirwa. 
\q1  
\v 16 Nyika yavo ichaitwa dongo, 
\q2 chiseko chisingaperi; 
\q1 vose vanopfuura nemo vachashamiswa 
\q2 uye vachadzungudza misoro yavo. 
\q1  
\v 17 Semhepo inobva kumabvazuva, 
\q2 ndichavaparadzira pamberi pavavengi vavo; 
\q1 ndichavaratidza musana wangu kwete uso hwangu, 
\q2 pazuva renjodzi yavo.” 
\p  
\v 18 Vakati, “Uyai tironge zvatingaita naJeremia; nokuti kudzidziswa kwomurayiro navaprista hakungaraswi, kunyange zano rinobva kuna vakachenjera, kana shoko rinobva kuvaprofita. Saka uyai, timurove nendimi dzedu tirege kuteerera chinhu chipi nechipi chaanoreva.” 
\q1  
\v 19 Haiwa Jehovha ndinzweiwo; 
\q2 inzwai zvinorehwa navapomeri vangu! 
\q1  
\v 20 Ko, zvakanaka zvingatsiviwa nezvakaipa here? 
\q2 Kunyange zvakadaro vakandicherera gomba. 
\q1 Rangarirai kuti ndakamira pamberi penyu 
\q2 ndichivareverera, 
\q2 kuti mudzore kutsamwa kwenyu kwavari; 
\q1  
\v 21 Saka sundirai vana vavo kunzara; 
\q2 vaisei kusimba romunondo. 
\q1 Vakadzi vavo ngavarege kuva navana uye ngavave chirikadzi; 
\q2 varume vavo ngavaurayiwe, 
\q2 majaya avo ngaaurayiwe nomunondo muhondo. 
\q1  
\v 22 Kuchema ngakunzwike kuchibva kudzimba dzavo, 
\q2 pamunouyisa vapambi pamusoro pavo pakarepo, 
\q1 nokuti vakachera hunza kuti vandibate, 
\q2 uye vakavanzira tsoka dzangu misungo. 
\q1  
\v 23 Asi munoziva, imi Jehovha, 
\q2 rangano dzavo dzose dzokundiuraya. 
\q1 Musavakanganwira mhaka dzavo 
\q2 kana kudzima zvivi zvavo pamberi penyu. 
\q1 Ngavawisirwe pasi pamberi penyu, 
\q2 muvarove panguva yokutsamwa kwenyu. 
\c 19  
\p  
\v 1 Zvanzi naJehovha: “Enda undotenga chirongo chevhu kumuumbi wehari. Uende navamwe vakuru vavanhu navaprista.  
\v 2 Muende kuMupata waBheni Hinomi, pedyo napamuromo weSuo reZvaenga. Uparidzepo mashoko andinokuudza,  
\v 3 uchiti, ‘Inzwai shoko raJehovha, imi madzimambo navanhu veJerusarema. Zvanzi naJehovha Mwari Wamasimba Ose, Mwari waIsraeri: Teererai, ndiri kuuyisa njodzi panzvimbo ino ichaita kuti nzeve yomumwe nomumwe anonzwa nezvayo iwunge.  
\v 4 Nokuti vakandisiya vakaita nzvimbo ino kuti ive yamwari wavatorwa; vakapisira zvibayiro mairi kuna vamwari vavasina kuziva ivo kana madzibaba avo kana madzimambo eJudha, uye vakazadza nzvimbo ino neropa ravasina mhosva.  
\v 5 Vakavaka nzvimbo dzakakwirira dzaBhaari kuti vapise vanakomana vavo mumoto sezvipiriso kuna Bhaari, chinhu chandisina kuvarayira kana kureva, uye hachina kumbopinda mupfungwa dzangu.  
\v 6 Saka chenjerai, mazuva anouya, ndizvo zvinotaura Jehovha, apo vanhu vasingazotumidzi nzvimbo ino kuti Tofeti kana kuti Mupata waBheni Hinomi, asi kuti Mupata Wokuuraya. 
\p  
\v 7 “ ‘Ndichaparadza urongwa hwaJudha neJerusarema munzvimbo ino. Ndichavawisira pasi nomunondo pamberi pavavengi vavo, pamaoko avanotsvaka kuvauraya, uye ndichapa zvitunha zvavo sezvokudya kushiri dzedenga nezvikara zvenyika.  
\v 8 Ndichaparadza guta rino uye ndichariita chinhu chinosekwa; vose vanopfuura napo vachashamiswa uye vacharihomera nokuda kwamaronda aro ose.  
\v 9 Ndichaita kuti vadye nyama yavanakomana vavo neyavanasikana vavo, uye nyama yomumwe nomumwe wavo panguva yokurema kwokukombwa kunenge kwaiswa pamusoro pavo navavengi vavo vanotsvaka kuvauraya.’ 
\p  
\v 10 “Ipapo uputse chirongo vaya vanoenda newe vakatarisa,  
\v 11 ugoti kwavari, ‘Zvanzi naJehovha Mwari Wamasimba Ose: Ndichaputsa rudzi urwu neguta rino sokuputsika kwechirongo chemuumbi wehari uye hachingagoni kugadzirwazve. Vachaviga vakafa muTofeti kusvikira pasisina nzvimbo.  
\v 12 Izvi ndizvo zvandichaitira nzvimbo ino nokuna vose vanogara muno, ndizvo zvinotaura Jehovha. Ndichaita guta rino seTofeti.  
\v 13 Dzimba dziri muJerusarema nedzamadzimambo eJudha dzichasvibiswa senzvimbo ino, Tofeti, dzimba dzose dzavaipisira zvinonhuhwira pamatenga adzo, vachipisira hondo dzenyeredzi dzose dzokudenga uye vachidururira vamwe vamwari zvipiriso zvokunwa.’ ” 
\p  
\v 14 Ipapo Jeremia akabva kuTofeti, kwaakanga atumwa naJehovha kundoprofita, akandomira muruvazhe rwetemberi yaJehovha ndokuti kuvanhu vose,  
\v 15 “Zvanzi naJehovha Mwari Wamasimba Ose, Mwari waIsraeri: ‘Inzwai! Ndichauyisa pamusoro peguta rino nemisha yakaripoteredza, njodzi imwe neimwe yandakazivisa pamusoro paro, nokuti ivo vakaomesa mitsipa yavo vakaramba kunzwa mashoko angu.’ ” 
\c 20  
\s1 Jeremia naPashuri 
\p  
\v 1 Muprista Pashuri mwanakomana waImeri, mutariri mukuru mutemberi yaJehovha, akati anzwa Jeremia achiprofita zvinhu izvi,  
\v 2 akarayira kuti Jeremia muprofita arohwe agoiswa muchitokisi paSuo Rokumusoro raBhenjamini raiva patemberi yaJehovha.  
\v 3 Chifumi chamangwana, Pashuri akati amusunungura kubva muchitokisi, Jeremia akati kwaari, “Zita rinopiwa kwauri naJehovha harisi Pashuri, asi Magori-Misabhibhi (zvichireva zvinotyisa kumativi ose).  
\v 4 Nokuti zvanzi naJehovha: ‘Ndichakuita chinhu chinokutyisa iwe pachako nokushamwari dzako dzose; uchadziona nemeso ako dzichiwisirwa pasi nomunondo wavavengi vavo. Ndichaisa Judha rose mumaoko amambo weBhabhironi, uye achavaendesa kuBhabhironi kana kuvauraya nomunondo.  
\v 5 Ndichaisa pfuma yose yeguta rino, nezvose zvavakawana, nezvose zvinokosha zvaro, nepfuma yose yamadzimambo eJudha, mumaoko avavengi vavo. Vachazvipamba ndokuzviendesa kuBhabhironi.  
\v 6 Zvino iwe Pashuri, navose vanogara mumba mako muchatapwa mugondogariswa kuBhabhironi. Uchandofira ikoko, iwe neshamwari dzako dzose dzawaiprofitira nhema.’ ” 
\s1 Kugununʼuna kwaJeremia 
\q1  
\v 7 Haiwa Jehovha makandinyengera, uye ndakanyengerwa; 
\q2 makandikurira uye mukakunda, 
\q1 vanondiseka zuva rose; 
\q2 munhu wose anondiseka. 
\q1  
\v 8 Pandinotaura pose, ndinodanidzira 
\q2 ndichitaura nezvokuita nechisimba nokuparadza. 
\q1 Saka shoko raJehovha rakandivigira 
\q2 kutukwa nokunyadziswa zuva rose. 
\q1  
\v 9 Asi kana ndikati, “Handicharevi zita rake, 
\q2 kana kutaurazve muzita rake,” 
\q1 shoko rake riri mumwoyo mangu rakaita somoto, 
\q2 moto wakapfigirwa mumapfupa angu. 
\q1 Ndaneta nokuridzivisa; 
\q2 zvirokwazvo, handigoni. 
\q1  
\v 10 Ndinonzwa vazhinji vachizevezera vachiti, 
\q2 “Zvinotyisa kumativi ose! 
\q2 Mureverei! Ngatimureverei!” 
\q1 Shamwari dzangu dzose 
\q2 dzakarindira kutedzemuka kwangu, dzichiti, 
\q1 “Zvimwe achanyengererwa; 
\q2 ipapo tigomukunda 
\q2 tigozvitsiva paari.” 
\q1  
\v 11 Asi Jehovha aneni semhare ine simba; 
\q2 saka vatambudzi vangu vachagumburwa, uye havangakundi. 
\q1 Vachakundikana uye vachanyadziswa kwazvo; 
\q2 kusakudzwa kwavo hakungatongokanganwiki. 
\q1  
\v 12 Haiwa Jehovha Wamasimba Ose, iyemi munoedza vakarurama 
\q2 uye munonzvera mwoyo nendangariro, 
\q1 regai ndione kutsiva kwenyu pamusoro pavo, 
\q2 nokuti ndaisa mhaka yangu kwamuri. 
\b  
\q1  
\v 13 Imbirai Jehovha! 
\q2 Ipai rumbidzo kuna Jehovha! 
\q1 Iye anorwira upenyu hwavanoshayiwa 
\q2 kubva mumaoko avakaipa. 
\b  
\q1  
\v 14 Ngaritukwe zuva randakaberekwa! 
\q2 Zuva randakaberekwa namai vangu ngarirege kuropafadzwa! 
\q1  
\v 15 Ngaatukwe munhu akazivisa baba vangu shoko, 
\q2 iye akaita kuti vafare kwazvo, achiti, 
\q2 “Waberekerwa mwana, iye mwanakomana!” 
\q1  
\v 16 Munhu uyo ngaave semaguta 
\q2 akaparadzwa naJehovha asingazvidembi. 
\q1 Ngaanzwe kuungudza mangwanani, 
\q2 nokudanidzirwa kwehondo masikati. 
\q1  
\v 17 Nokuti haana kundiuraya ndiri mudumbu, 
\q2 mai vangu vangadai vari guva rangu, 
\q2 vairamba vane mimba. 
\q1  
\v 18 Ndakambobudireiko mudumbu 
\q2 kuti ndione nhamo nokuchema 
\q2 uye ndigogumisa mazuva angu mukunyadziswa? 
\c 21  
\s1 Mwari anoramba Chikumbiro chaZedhekia 
\p  
\v 1 Shoko rakauya kuna Jeremia richibva kuna Jehovha panguva yakatuma mambo Zedhekia kwaari Pashuri mwanakomana waMarikiya, nomuprista Zefania mwanakomana waMaaseya. Vakati,  
\v 2 “Dotibvunzirawo kuna Jehovha iye zvino nokuti Nebhukadhinezari mambo weBhabhironi ari kurwa nesu. Zvichida Jehovha angatiitira zvishamiso sepanguva dzakapfuura kuitira kuti uyu abve kwatiri.” 
\p  
\v 3 Asi Jeremia akavapindura achiti, “Udzai Zedhekia kuti,  
\v 4 ‘Zvanzi naJehovha, Mwari waIsraeri: Ndava pedyo nokunangisa kwauri zvombo zvehondo zviri mumaoko ako, zvaunoshandisa kurwa namambo weBhabhironi navaBhabhironi vakakukombai kunze kwamasvingo. Uye ndichazviunganidza mukati meguta rino.  
\v 5 Ini ndimene ndicharwa newe noruoko rwakatambanudzwa noruoko rune simba mukutsamwa neshungu nehasha huru.  
\v 6 Ndicharova vanogara muguta rino, zvose vanhu nezvipfuwo, uye zvichafa nedenda rakaipisisa.  
\v 7 Shure kwaizvozvo, ndizvo zvinotaura Jehovha, ndichaisa Zedhekia mambo weJudha, namachinda ake navanhu vari muguta rino vanopunyuka padenda, napamunondo, nepanzara, kuna Nebhukadhinezari mambo weBhabhironi nokuvavengi vavo vanotsvaka kuvauraya. Achavaisa kumunondo; haangavanzwiri urombo, kana ngoni, kana tsitsi.’ 
\p  
\v 8 “Zvakare, uti kuvanhu, ‘Zvanzi naJehovha: Tarirai, ndiri kuisa pamberi penyu nzira youpenyu neyorufu.  
\v 9 Ani naani achagara muguta rino achafa nomunondo, nenzara kana nedenda. Asi ani naani achabuda akandozvipira kuvaBhabhironi vakakukombai achararama; achatiza noupenyu hwake.  
\v 10 Ndafunga kuitira guta rino zvakaipa kwete zvakanaka, ndizvo zvinotaura Jehovha. Richaiswa mumaoko amambo weBhabhironi, uye achariparadza nomoto.’ 
\p  
\v 11 “Pamusoro paizvozvo, uti kuimba youshe yaJudha, ‘Inzwai shoko raJehovha,  
\v 12 imi imba yaDhavhidhi. Zvanzi naJehovha: 
\q1 “ ‘Tongai nokururamisira mangwanani ari ose, 
\q2 nunurai akabirwa, kubva muruoko rwomudzvinyiriri wake, 
\q1 kuti kutsamwa kwangu kurege kubuda kukakupisai somoto, 
\q2 nokuda kwezvakaipa zvamakaita, 
\q2 kuchipfuta pasina angakudzima. 
\q1  
\v 13 Ndine mhosva newe, Jerusarema, 
\q2 iwe ugere pamusoro pomupata uno 
\q2 pamutunhu wematombo, 
\q4 ndizvo zvinotaura Jehovha, 
\q1 iyemi munoti, “Ndiani angatirwisa? 
\q2 Ndiani angapinda pautiziro hwedu?” 
\q1  
\v 14 Ndichakurovai sezvakafanira mabasa enyu, 
\q4 ndizvo zvinotaura Jehovha. 
\q1 Ndichabatidza moto mumasango enyu 
\q2 uchapisa zvose zvakakupoteredzai.’ ” 
\c 22  
\s1 Kutongwa kwaMadzimambo Akaipa 
\p  
\v 1 Zvanzi naJehovha: “Burukira kumuzinda wamambo weJudha undoparidza shoko iri ikoko uchiti,  
\v 2 ‘Inzwai shoko raJehovha, imi mambo weJudha, iyemi munogara pachigaro choushe chaDhavhidhi, imi namachinda enyu navanhu venyu vanopinda napamasuo aya.  
\v 3 Zvanzi naJehovha: Itai zvakanaka nezvakarurama. Rwirai akabirwa muruoko rwounomumanikidza. Regai kuitira zvakaipa kana chisimba kumutorwa nenherera kana chirikadzi, uye musateura ropa risina mhosva panzvimbo ino.  
\v 4 Nokuti kana mukachenjerera kuteerera mirayiro, ipapo madzimambo anogara pachigaro chaDhavhidhi achapinda napamasuo omuzinda uyu, vakakwira mungoro nepamabhiza vachiperekedzwa namachinda avo navanhu vavo.  
\v 5 Asi kana mukaramba kunzwa mirayiro iyi, ndizvo zvinotaura Jehovha, ndinopika neni ndimene kuti nzvimbo ino ichava dongo.’ ” 
\p  
\v 6 Nokuti zvanzi naJehovha pamusoro pomuzinda wamambo weJudha: 
\q1 “Kunyange wakaita seGireadhi kwandiri, 
\q2 wakaita somusoro weRebhanoni, 
\q1 zvirokwazvo ndichakuita segwenga, 
\q2 semaguta asingagarwi. 
\q1  
\v 7 Ndichatumira vaparadzi pamusoro penyu, 
\q2 mumwe nomumwe nezvombo zvake, 
\q1 uye vachatema matanda enyu emisidhari akanaka 
\q2 vagoakanda mumoto. 
\p  
\v 8 “Marudzi mazhinji avanhu achapfuura nepaguta rino uye vachabvunzana vachiti, ‘Jehovha aitireiko chinhu chakadai kuguta rino?’  
\v 9 Zvino mhinduro ichati, ‘Nokuti vakasiya sungano yaJehovha Mwari wavo vakanamata uye vakashumira vamwe vamwari.’ ” 
\q1  
\v 10 Musachema mambo akafa kana kuungudza nezvake; 
\q2 asi muchemere kwazvo uyo akatapwa, 
\q2 nokuti haachambodzoki kana kuzoonazve nyika yaakaberekerwa. 
\m  
\v 11 Nokuti zvanzi naJehovha pamusoro paSharumi mwanakomana waJosia, uyo akatevera Baba vake samambo weJudha asi akabva panzvimbo ino: “Haazombodzoki.  
\v 12 Achafira munzvimbo yavakamuendesa kuutapwa; haachazombooni nyika inozve.” 
\q1  
\v 13 “Ane nhamo uyo anovaka muzinda wake nokusarurama, 
\q2 namakamuri ake okumusoro nokusaruramisira, 
\q1 anoshandisa vanhu vokwake pasina chaanovapa, 
\q2 asingavaripiri pakushanda kwavo. 
\q1  
\v 14 Iye anoti, ‘Ndichazvivakira muzinda wakakura 
\q2 una makamuri okumusoro anoyevedza.’ 
\q1 Saka anoita mawindo makuru mairi, 
\q2 achiabatanidza nomusidhari, 
\q2 agoashongedza nezvitsvuku. 
\b  
\q1  
\v 15 “Izvozvo zvinokuita mambo here, 
\q2 kuva nemisidhari yakawandawanda? 
\q1 Ko, baba vako havana kuwana zvokudya nezvokunwa here? 
\q2 Iye akaita zvakarurama uye nokururamisira, 
\q2 saka zvose zvakamufambira zvakanaka. 
\q1  
\v 16 Akatongera varombo nevaishayiwa mhaka dzavo, 
\q2 nokudaro zvose zvakafamba zvakanaka. 
\q1 Hazvisizvo zvinoreva kundiziva here?” 
\q2 ndizvo zvinotaura Jehovha. 
\q1  
\v 17 “Asi meso enyu nemwoyo yenyu 
\q2 zvakangotarisa chete papfuma isakarurama, 
\q1 pakuteura ropa risina mhosva 
\q2 napakumanikidza nokuita nechisimba.” 
\m  
\v 18 Naizvozvo zvanzi naJehovha, pamusoro paJehoyakimi mwanakomana waJosia, mambo weJudha: 
\q1 “Havangamuchemi vachiti: 
\q2 ‘Yowe-e, mununʼuna wangu! Yowe-e, hanzvadzi yangu!’ 
\q1 Havangamuchemi vachiti: 
\q2 ‘Yowe-e, tenzi wangu! Yowe-e, ukuru hwake!’ 
\q1  
\v 19 Achavigwa sokuvigwa kunoitwa mbongoro, 
\q2 achakwekweredzwa agoraswa kure, 
\q2 kunze kwamasuo eJerusarema.” 
\b  
\q1  
\v 20 “Kwirai kuRebhanoni mudanidzire, 
\q2 inzwi renyu ngarinzwike paBhashani, 
\q1 danidzirai kubva paAbharimi, 
\q2 nokuti shamwari dzenyu dzose dzaparadzwa. 
\q1  
\v 21 Ndakakuyambira uchigere zvakanaka, 
\q2 asi iwe wakati, ‘Handidi kuteerera!’ 
\q1 Ndiyo yanga iri nzira yako kubva pauduku hwako; 
\q2 hauna kunditeerera. 
\q1  
\v 22 Mhepo ichadzingira kure vafudzi vako vose, 
\q2 uye shamwari dzako dzichaenda kuutapwa. 
\q1 Ipapo iwe uchanyara uye uchanyadziswa, 
\q2 nokuda kwokuipa kwako kwose. 
\q1  
\v 23 Imi mugere mu‘Rebhanoni,’ 
\q2 iyemi makavakirwa matendere mudzimba dzemisidhari, 
\q1 muchagomera sei kurwadza pakuchauya pamusoro penyu, 
\q2 kurwadziwa sekwomukadzi anosununguka! 
\p  
\v 24 “Zvirokwazvo, noupenyu hwangu,” ndizvo zvinotaura Jehovha, “kunyange kana iwe Jehoyakini mwanakomana waJehoyakimi mambo weJudha, wakanga uri mhete muruoko rwangu rworudyi, ndaingokubvisa zvakadaro.  
\v 25 Ndichakuisa mumaoko aavo vanotsvaka kukuuraya, ivo vaunotya, kuna Nebhukadhinezari mambo weBhabhironi nokuvaBhabhironi.  
\v 26 Ndichapotsera iwe namai vakakubereka kune imwe nyika kwamusina kuberekerwa, uye ikoko kwamuchandofira muri vaviri.  
\v 27 Hamuzombodzokizve kunyika yamunoshuva kudzokera kwairi.” 
\q1  
\v 28 Ko, murume uyu Jehoyakini munhu akazvidzika, ihari yakaputsika, 
\q2 chinhu chisina angada here? 
\q1 Seiko iye navana vake vapotserwa kunze, 
\q2 vakarasirwa kunyika yavasingazivi? 
\q1  
\v 29 Iwe nyika, nyika, nyika, 
\q2 inzwa shoko raJehovha! 
\q1  
\v 30 Zvanzi naJehovha: 
\q1 “Nyora munhu uyu seasina mwana, 
\q2 munhu asingazobudiriri pamazuva oupenyu hwake, 
\q1 nokuti hakuna mwana wake achapfuma, 
\q2 hakuna achagara pachigaro choushe chaDhavhidhi, 
\q2 kana kutongazve munyika yeJudha.” 
\c 23  
\s1 Davi Rakarurama 
\p  
\v 1 “Vane nhamo vafudzi vari kuparadza uye vari kuparadzira makwai amafuro angu!” ndizvo zvinotaura Jehovha.  
\v 2 Naizvozvo zvanzi naJehovha, Mwari waIsraeri, kuvafudzi vanofudza vanhu vangu: “Nemhaka yokuti makaparadzira makwai angu mukaadzingira kure uye mukasava nehanya nawo, ndichaisa rushamhu pamusoro penyu nokuda kwezvakaipa zvamakaita,” ndizvo zvinotaura Jehovha.  
\v 3 “Ini pachangu ndichaunganidza akasara amakwai angu kubva kunyika dzose dzandakanga ndaadzingira uye ndichaadzosera kumafuro awo, kwaachava nezvibereko uye kwaachawanda.  
\v 4 Ndichagadza vafudzi pamusoro pavo vachaafudza, uye havazotyi kana kuvhunduka, uye hakuna rimwe rawo ringashayikwa,” ndizvo zvinotaura Jehovha. 
\q1  
\v 5 “Mazuva achauya,” ndizvo zvinotaura Jehovha, 
\q2 “pandichamutsira Dhavhidhi Davi rakarurama, 
\q1 Mambo achatonga nouchenjeri 
\q2 nokururamisira uye nokuita zvakarurama munyika. 
\q1  
\v 6 Pamazuva ake Judha achaponeswa 
\q2 uye Israeri achagara norugare. 
\q1 Zita rake raachatumidzwa ndirori rokuti: 
\q2 Jehovha Ndiye Kururama Kwedu. 
\m  
\v 7 Naizvozvo zvino mazuva achauya,” ndizvo zvinotaura Jehovha, “avasingazoti, ‘NaJehovha mupenyu iye akabudisa vaIsraeri kubva muIjipiti,’  
\v 8 asi vachazoti, ‘NaJehovha mupenyu, akabudisa vana vaIsraeri kubva kunyika yokumusoro nokunyika dzose kwaakanga avadzingira.’ Ipapo vachagara munyika yavo.” 
\s1 Vaprofita venhema 
\p  
\v 9 Kana vari vaprofita: 
\q1 Mwoyo wangu waputsika mukati mangu; 
\q2 mapfupa angu ose anodedera. 
\q1 Ndakaita somunhu akadhakwa, 
\q2 somunhu akundwa newaini, 
\q1 nokuda kwaJehovha 
\q2 uye nokuda kwamashoko ake matsvene. 
\q1  
\v 10 Nyika izere nemhombwe; 
\q2 nyika yaoma nokuda kwokutukwa 
\q2 uye mafuro omugwenga aoma. 
\q1 Vaprofita votevera nzira yakaipa 
\q2 uye vanoshandisa simba ravo nokusarurama. 
\b  
\q1  
\v 11 “Muprofita nomuprista vose havana umwari; 
\q2 kunyange mutemberi yangu ndinowana kuipa kwavo,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 12 “Naizvozvo nzira yavo ichatsvedza; 
\q2 vachadzingirwa kurima 
\q2 uye ikoko ndiko kwavachawira. 
\q1 Ndichauyisa njodzi pamusoro pavo 
\q2 mugore ravacharangwa,” 
\q4 ndizvo zvinotaura Jehovha. 
\b  
\q1  
\v 13 “Pakati pavaprofita veSamaria 
\q2 ndakaona chinhu chinonyangadza ichi: 
\q1 Vakaprofita naBhaari, 
\q2 uye vakatungamirira vanhu vangu vaIsraeri mukurasika. 
\q1  
\v 14 Uye pakati pavaprofita veJerusarema 
\q2 ndakaona chimwe chinhu chinonyangadza: 
\q2 Vanoita upombwe uye vanoreva nhema. 
\q1 Vanosimbisa maoko evaiti vezvakaipa, 
\q2 zvokuti hakuna anodzoka pazvakaipa zvake. 
\q1 Vose vakaita seSodhomu kwandiri; 
\q2 vanhu veJerusarema vakaita seGomora.” 
\p  
\v 15 Naizvozvo, zvanzi naJehovha Mwari Wamasimba Ose, pamusoro pavaprofita: 
\q2 “Ndichaita kuti vadye kudya kunovava, 
\q2 uye kuti vanwe mvura ine muchetura, 
\q1 nokuti zvichibva nokumuprofita weJerusarema, 
\q2 kushaya umwari kwapararira panyika yose.” 
\p  
\v 16 Zvanzi naJehovha Wamasimba Ose: 
\q1 “Regai kuteerera zvamunoprofitirwa navaprofita; 
\q2 vanokuzadzai netariro dzenhema. 
\q1 Vanotaura zviratidzo zvinobva pandangariro dzavo, 
\q2 zvisingabvi mumuromo maJehovha. 
\q1  
\v 17 Vanoramba vachiti kuna avo vanondizvidza, 
\q2 ‘Jehovha anoti: Muchava norugare.’ 
\q1 Uye kuna vaya vose vanotevera kusindimara kwemwoyo yavo, 
\q2 vanoti, ‘Hakuna chakaipa chichakuwirai.’ 
\q1  
\v 18 Asi ndiani pakati pavo akamira parangano yaJehovha, 
\q2 kuti aone kana kunzwa shoko rake? 
\q2 Ndiani akateerera akanzwa shoko rake? 
\q1  
\v 19 Tarirai, dutu raJehovha 
\q2 richaputika muhasha dzake, 
\q1 chamupupuri chichimona chakananga 
\q2 pamisoro yavakaipa. 
\q1  
\v 20 Kutsamwa kwaJehovha hakungadzoki, 
\q2 kusvikira apedza 
\q2 zvinovavarirwa nomwoyo wake. 
\q1 Pamazuva achauya 
\q2 muchazvinzwisisa zvakanyatsojeka. 
\q1  
\v 21 Handina kutuma vaprofita ava, 
\q2 kunyange zvakadaro vakamhanya neshoko ravo; 
\q1 ini handina kutaura navo, 
\q2 kunyange zvakadaro vakaprofita. 
\q1  
\v 22 Asi dai vakamira parangano yangu, 
\q2 vangadai vakaparidza mashoko angu kuvanhu vangu, 
\q1 uye vangadai vakavadzora panzira dzavo dzakaipa, 
\q2 napamabasa avo akaipa. 
\b  
\q1  
\v 23 “Ko, ini ndinongori Mwari ari pedyo here,” 
\q4 ndizvo zvinotaura Jehovha, 
\q2 “ndisati ndiri Mwari ari kure? 
\q1  
\v 24 Pano munhu angavanda, panzvimbo dzakavanzika 
\q2 zvokuti handingamuoni here?” 
\q4 ndizvo zvinotaura Jehovha. 
\q2 “Ko, handizadzi denga nenyika here?” 
\q4 ndizvo zvinotaura Jehovha. 
\p  
\v 25 “Ndakanzwa zvakataurwa navaprofita vanoprofita nhema muzita rangu. Vanoti, ‘Ndakarota! Ndakarota!’  
\v 26 Ko, izvi zvicharamba zviri mumwoyo yavaprofita venhema ava kusvikira rinhi ivo vanoprofita zvokunyengera kwendangariro dzavo?  
\v 27 Vanofunga kuti zviroto zvavanoudzana zvichaita kuti vanhu vangu vakanganwe zita rangu sezvakaita madzibaba avo akakanganwa zita rangu nokuda kwokunamata Bhaari.  
\v 28 Muprofita ane chiroto ngaataure kurota kwake, asi ane shoko rangu ngaataure nokutendeka. Nokuti mashanga ane basa rei pazviyo?” ndizvo zvinotaura Jehovha.  
\v 29 “Shoko rangu harina kufanana nomoto here,” ndizvo zvinotaura Jehovha, “uye nenyundo inoputsanya dombo?” 
\p  
\v 30 “Naizvozvo,” ndizvo zvinotaura Jehovha, “handina ukama navaprofita vanobirana mashoko anofungidzirwa kuti anobva kwandiri.  
\v 31 Hongu,” ndizvo zvinotaura Jehovha, “handina ukama navaprofita vanoshandisa ndimi dzavo vachiti, ‘Jehovha ari kutaura.’  
\v 32 Zvirokwazvo handina ukama neavo vanoprofita zviroto zvenhema,” ndizvo zvinotaura Jehovha. “Vanovaudza uye vanotsausa vanhu vangu nenhema dzavo dzisina maturo, asi handina kuvatuma kana kuvagadza. Havambobatsiri vanhu ava napaduku pose,” ndizvo zvinotaura Jehovha. 
\s1 Chirevo Chenhema naVaprofita Venhema 
\p  
\v 33 “Paunobvunzwa navanhu ava, vaprofita kana vaprista, vachiti, ‘Chirevo ichi chaJehovha ndecheiko?’ uti kwavari, ‘Chirevo cheiko? Ndichakurasai, ndizvo zvinotaura Jehovha.’  
\v 34 Kana muprofita kana muprista kana ani zvake achiti, ‘Ichi ndicho chirevo chaJehovha,’ ndicharanga munhu uyo nemhuri yake.  
\v 35 Izvi ndizvo zvamunoramba muchitaura mumwe nomumwe wenyu kushamwari kana kuhama yake muchiti: ‘Mhinduro yaJehovha inoti kudiniko?’ kana kuti ‘Jehovha akataureiko?’  
\v 36 Hamufaniri kutaura ‘chirevo chaJehovha’ zvakare, nokuti shoko romunhu mumwe nomumwe richava chirevo chake, uye saizvozvo munominamisa mashoko aMwari mupenyu, Jehovha Wamasimba Ose, Mwari wedu.  
\v 37 Izvi ndizvo zvamucharamba muchitaura kumuprofita muchiti: ‘Jehovha akakupindurei?’ kana kuti ‘Jehovha akataurei?’  
\v 38 Kunyange muchiti, ‘Ichi ndicho chirevo chaJehovha,’ izvi ndizvo zvinotaura Jehovha: Makashandisa mashoko anoti, ‘Ichi ndicho chirevo chaJehovha,’ kunyange ndakanga ndakuudzai kuti musati, ‘Ichi ndicho chirevo chaJehovha’.  
\v 39 Naizvozvo, zvirokwazvo ndichakukanganwai uye ndichakurasai mubve pamberi pangu imi neguta randakakupai uye namadzibaba enyu.  
\v 40 Ndichauyisa pamusoro penyu kunyadziswa kusingaperi, nyadzi dzisingaperi dzisingazokanganwiki.” 
\c 24  
\s1 Tswanda Mbiri dzaMaonde 
\p  
\v 1 Shure kwokutapwa kwaJehoyakini mwanakomana waJehoyakimi mambo weJudha pamwe chete namachinda, navavezi, navapfuri vesimbi veJudha vachibviswa kuJerusarema vachiendeswa kuBhabhironi naNebhukadhinezari mambo weBhabhironi, Jehovha akandiratidza tswanda mbiri dzine maonde dzakaiswa pamberi petemberi yaJehovha.  
\v 2 Imwe tswanda yaiva namaonde akanaka kwazvo, akaita seaya anotanga kuibva; imwe yacho yaive namaonde akaipa chose, zvokuti akanga asingagoni kudyiwa. 
\p  
\v 3 Ipapo Jehovha akandibvunza achiti, “Uri kuoneiko Jeremia?” 
\p Ini ndakapindura ndikati, “Maonde. Akanaka acho, akanaka kwazvo, asi akaipa acho akaipa zvokuti haangadyiwi.” 
\p  
\v 4 Ipapo shoko raJehovha rakauya kwandiri rikati,  
\v 5 “Zvanzi naJehovha, Mwari weIsraeri, ‘Sezvakaita maonde aya akanaka, saizvozvo ndicharangarira zvakanaka vatapwa vakabva kuJudha vandakatuma kubva panzvimbo ino ndichivaendesa kunyika yeBhabhironi.  
\v 6 Meso angu acharingira kwavari nokuda kwokunaka kwavo, uye ndichavadzosazve munyika ino. Ndichavavaka uye handingavakoromori; ndichavasima uye handingavadzuri.  
\v 7 Ndichavapa mwoyo wokundiziva, kuti ndini Jehovha. Vachava vanhu vangu, uye ini ndichava Mwari wavo, nokuti vachadzokera kwandiri nomwoyo wavo wose. 
\p  
\v 8 “ ‘Asi sezvakaita maonde akaipa, iwo akaipa kwazvo zvokusagona kudyiwa,’ ndizvo zvinotaura Jehovha, ‘saizvozvo ndichaitira Zedhekia mambo weJudha, namachinda ake, navaya vakasara muJerusarema, kunyange vakasara munyika ino kana vagere muIjipiti.  
\v 9 Ndichavaita chinhu chinovengwa, nechinhu chakaipa kuushe hwose hwenyika, chinhu chinoshorwa, neshumo, chinhu chinosekwa nechinotukwa kwose kwose kwandinovadzingira.  
\v 10 Ndichavatumira munondo, nzara, nehasha pamusoro pavo kusvikira vaparadzwa kubva panyika yandakavapa ivo namadzibaba avo.’ ” 
\c 25  
\s1 Makore Makumi Manomwe oUtapwa 
\p  
\v 1 Shoko rakauya kuna Jeremia pamusoro pavanhu vose veJudha mugore rechina raJehoyakimi mwanakomana waJosia mambo weJudha, iro rakanga riri gore rokutanga raNebhukadhinezari mambo weBhabhironi.  
\v 2 Saka Jeremia muprofita akati kuvanhu vose veJudha nokuna vose vaigara muJerusarema:  
\v 3 Kwamakore makumi maviri namatatu, kubva pagore regumi namatatu raJosia mwanakomana waAmoni mambo weJudha kusvikira zuva ranhasi, shoko raJehovha ranga richiuya kwandiri uye ini ndikataura ndataurazve kwamuri, asi hamuna kuteerera. 
\p  
\v 4 Uye kunyange Jehovha akatuma varanda vake kwamuri ivo vaprofita nguva nenguva, imi hamuna kuteerera kana kurereka nzeve dzenyu.  
\v 5 Ivo vakati, “Dzokai zvino mumwe nomumwe wenyu, kubva panzira dzenyu dzakaipa nepamabasa enyu akaipa, mugogara munyika yamakapiwa naJehovha imi namadzibaba enyu nokusingaperi.  
\v 6 Regai kutevera vamwe vamwari kuti muvashumire uye muvanamate; murege kunditsamwisa nezvakaitwa namaoko enyu. Ipapo handingakuitirei zvakaipa.” 
\p  
\v 7 “Asi imi hamuna kunditeerera,” ndizvo zvinotaura Jehovha, “uye makanditsamwisa nezvakaitwa namaoko enyu, mukaita kuti zvakaipa zvikuwirei.” 
\p  
\v 8 Naizvozvo zvanzi naJehovha Wamasimba Ose: “Nemhaka yokuti hamuna kuteerera mashoko angu,  
\v 9 ndichadana marudzi ose okumusoro uye nomuranda wangu Nebhukadhinezari mambo weBhabhironi,” ndizvo zvinotaura Jehovha, “uye ndichavauyisa kuzorwa nenyika ino navanogaramo uye nendudzi dzose dzakavapoteredza. Ndichavaparadza zvachose uye ndichavaita chinhu chinovengwa nechinosekwa, nedongo nokusingaperi.  
\v 10 Ndichabvisa pakati pavo manzwi okupembera nomufaro, namanzwi emwenga neechikomba, nenzwi reguyo nechiedza chemwenje.  
\v 11 Nyika ino yose ichava dongo, uye marudzi aya achashandira mambo weBhabhironi kwemakore makumi manomwe. 
\p  
\v 12 “Asi kana makore makumi manomwe apera, ndicharova mambo weBhabhironi norudzi rwake, nenyika yavaBhabhironi, pamusoro pemhosva yavo,” ndizvo zvinotaura Jehovha, “uye ndichaiita dongo nokusingaperi.  
\v 13 Ndichauyisa pamusoro penyika iyo zvinhu zvose zvandakataura pamusoro payo, zvose zvakanyorwa mubhuku iri nezvakaprofitwa naJeremia pamusoro pendudzi dzose.  
\v 14 Ivo pachavo vachatapwa nendudzi zhinji namadzimambo makuru; ini ndichavaripira zvakaenzana nokubata kwavo uye namabasa emaoko avo.” 
\s1 Mukombe woKutsamwa kwaMwari 
\p  
\v 15 Izvi ndizvo zvakataurwa naJehovha, Mwari waIsraeri, kwandiri: “Tora kubva muruoko rwangu mukombe uyu wakazara newaini yokutsamwa kwangu unwise ndudzi dzose dzandinokutuma kwadziri.  
\v 16 Kana vachinge vainwa vachadzedzereka nokupenga nokuda kwomunondo wandichatuma pakati pavo.” 
\p  
\v 17 Saka ndakatora mukombe muruoko rwaJehovha ndikaita kuti ndudzi dzose dzaakandituma kwadziri dzinwe: 
\b  
\li1  
\v 18 Jerusarema namaguta eJudha, namadzimambo, namachinda aro, kuti aitwe matongo, chinhu chinovengwa nechinosekesa, nechinotukwa, sezvaakaita iye nhasi; 
\li1  
\v 19 Faro mambo weIjipiti, navaranda vake, namachinda ake uye navanhu vake vose,  
\v 20 navatorwa vose variko; 
\li1 namadzimambo ose eUzi; 
\li1 namadzimambo ose eFiristia (neavo veAshikeroni, neGaza, neEkironi, navanhu vakasiyiwa kuAshidhodhi); 
\li1  
\v 21 Edhomu neMoabhu neAmoni; 
\li1  
\v 22 namadzimambo ose eTire neSidhoni; 
\li1 namadzimambo emuzviwi mhiri kwegungwa; 
\li1  
\v 23 neDhedhani, neTema, neBhuzi navose vari kunzvimbo dziri kure; 
\li1  
\v 24 madzimambo ose eArabhia namadzimambo ose enyika dzavatorwa vanogara mugwenga; 
\li1  
\v 25 namadzimambo ose eZimuri, neEramu neFiristia, 
\li1  
\v 26 namadzimambo ose okumusoro vepedyo nevokure, mumwe achitevera mumwe, ushe hwose huri pamusoro penyika. 
\li1 Shure kwaivava vose, mambo weSheshaki achazoinwawo. 
\b  
\p  
\v 27 “Ipapo uvaudze kuti, ‘Zvanzi naJehovha Wamasimba Ose, Mwari weIsraeri: Inwai mudhakwe, murutse, muwe, uye murege kuzomukazve nokuda kwomunondo wandichatuma pakati penyu.’  
\v 28 Asi kana vakaramba kutora mukombe muruoko rwako kuti vamwe, uti kwavari, ‘Zvanzi naJehovha Wamasimba Ose: Munofanira kuinwa!  
\v 29 Tarirai, ndava kutanga kuuyisa njodzi pamusoro peguta rinodanwa neZita rangu, ko, imi mungarega kurangwa here? Hamungaregi kurangwa nokuti ndava kudana munondo pamusoro pavose vagere panyika, ndizvo zvinotaura Jehovha Wamasimba Ose.’ 
\p  
\v 30 “Zvino chiprofita mashoko aya ose pamusoro pavo uchiti: 
\q1 “ ‘Jehovha achaomba ari kumusoro; 
\q2 achatinhira ari pachigaro chake chitsvene 
\q2 uye achaomba zvikuru pamusoro penyika yake. 
\q1 Achadanidzira sezvinoita vanotsika mazambiringa, 
\q2 achidanidzira kuna vose vagere panyika. 
\q1  
\v 31 Bope richaunga kusvikira kumagumo enyika, 
\q2 nokuti Jehovha achapa ndudzi mhosva; 
\q1 achauyisa kutonga pamusoro pamarudzi ose avanhu 
\q2 uye achaisa vakaipa kumunondo,’ ” 
\q4 ndizvo zvinotaura Jehovha. 
\p  
\v 32 Zvanzi naJehovha Wamasimba Ose: 
\q1 “Tarirai, njodzi iri kupararira 
\q2 ichibva kuno rumwe rudzi ichienda kuno rumwe; 
\q1 dutu guru rasimuka 
\q2 richibva kumagumo enyika.” 
\m  
\v 33 Panguva iyo vakaurayiwa naJehovha vachava pose pose vachibva kuno mumwe mugumo wenyika kusvikira kuno mumwe. Havangachemwi kana kuunganidzwa, kana kuvigwa, asi vachava somupfudze uri pamusoro penyika. 
\q1  
\v 34 Chemai uye muungudze, imi vafudzi; 
\q2 umburukai muguruva, imi vatungamiri veboka. 
\q1 Nokuti nguva yokuurayiwa kwenyu yasvika; 
\q2 muchawa mugopwanyika somudziyo wakanaka wevhu. 
\q1  
\v 35 Vafudzi vachashayiwa kwokutizira, 
\q2 uye vakuru veboka vachashayiwa kwokutizira. 
\q1  
\v 36 Inzwai kuchema kwavafudzi, 
\q2 kuungudza kwavatungamiri veboka, 
\q2 nokuti Jehovha ari kuparadza mafuro avo. 
\q1  
\v 37 Mafuro ano runyararo achaparadzwa 
\q2 nokuda kwokutsamwa kunotyisa kwaJehovha. 
\q1  
\v 38 Seshumba, achabva panzvimbo yake yokuvanda, 
\q2 uye nyika yavo ichaparadzwa 
\q1 nokuda kwomunondo womumanikidzi, 
\q2 uye nokuda kwokutsamwa kunotyisa kwaJehovha. 
\c 26  
\s1 Vanotsvaka kuuraya Jeremia 
\p  
\v 1 Pamazuva okutanga kubata ushe kwaJehoyakimi mwanakomana waJosia mambo weJudha, shoko iri rakabva kuna Jehovha richiti,  
\v 2 “Zvanzi naJehovha: Mira paruvazhe rweimba yaJehovha utaure kuvanhu vose vomumaguta eJudha vanouya kuzonamata muimba yaJehovha. Uvaudze zvose zvandinokurayira, usadarikira kana shoko rimwe chete,  
\v 3 Zvimwe vachanzwa mumwe nomumwe akadzoka panzira dzake dzakaipa. Ipapo ndichazvidemba ndikarega kuisa pamusoro pavo njodzi yandanga ndichifunga kuvaitira nokuda kwezvakaipa zvavakaita.  
\v 4 Uti kwavari, ‘Zvanzi naJehovha: Kana musinganditeereri, uye musingateveri murayiro wangu, wandakaisa pamberi penyu,  
\v 5 uye kana musingateereri mashoko avaranda vangu ivo vaprofita, vandakatuma ndikatumazve kwamuri (Kunyange musina kuteerera),  
\v 6 ipapo ndichaita kuti imba ino ive seShiro uye guta rino kuti rive chinhu chinotukwa pakati pendudzi dzose dzepanyika.’ ” 
\p  
\v 7 Vaprista navaprofita navanhu vose vakanzwa Jeremia achitaura mashoko aya ari mumba maJehovha.  
\v 8 Asi Jeremia akati achangopedza kuudza vanhu vose zvose zvaakanga arayirwa naJehovha kuti ataure, vaprista navaprofita navanhu vose vakamubata vakati, “Unofanira kufa!  
\v 9 Unoprofitirei muzita raJehovha uchiti imba ino ichava seShiro uye guta rino richava dongo uye richashaya anogaramo?” Vanhu vose vakaunganira Jeremia mumba maJehovha. 
\p  
\v 10 Machinda eJudha akati anzwa nezvezvinhu izvi, vakakwidza vachibva kumuzinda wamambo vakaenda kuimba yaJehovha vakandogara pamukova wepaSuo Idzva weimba yaJehovha.  
\v 11 Ipapo vaprista navaprofita vakati kumachinda nokuvanhu vose, “Munhu uyu anofanira kutongerwa rufu nokuti akaprofita zvakaipa pamusoro peguta rino. Mazvinzwira imi nenzeve dzenyu!” 
\p  
\v 12 Ipapo Jeremia akati kumachinda ose nokuvanhu vose, “Jehovha akandituma kuzoprofita pamusoro peimba ino napamusoro peguta rino, zvinhu zvose zvamakanzwa.  
\v 13 Zvino, chinatsai nzira dzenyu nezviito zvenyu muteerere Jehovha Mwari wenyu. Ipapo Jehovha achazvidemba akarega kuuyisa pamusoro penyu njodzi yaakareva.  
\v 14 Asi kana ndirini, ndiri mumaoko enyu; itai henyu zvamunofunga pamusoro pangu sezvamunoona zvakanaka uye zvakarurama.  
\v 15 Kunyange zvakadaro hazvo, zivai kuti, kana mukandiuraya muchamisa mhosva yeropa risina mhaka pamusoro penyu uye napamusoro peguta rino, nepamusoro pevose vanogara mariri, nokuti zvirokwazvo Jehovha akandituma kwamuri kuti nditaure mashoko ose aya munzeve dzenyu.” 
\p  
\v 16 Ipapo machinda navanhu vose vakati kuvaprista nokuvaprofita, “Munhu uyu haafaniri kutongerwa rufu! Ataura kwatiri muzita raJehovha Mwari wedu.” 
\p  
\v 17 Vamwe vavakuru venyika vakasimuka vakati kuungano yose yavanhu,  
\v 18 “Mikaya wokuMorasheti akaprofita pamazuva aHezekia mambo weJudha. Akaudza vanhu vose veJudha kuti, ‘Zvanzi naJehovha Wamasimba Ose: 
\q1 “ ‘Zioni richarimwa somunda, 
\q2 Jerusarema richava murwi wamabwe, 
\q2 negomo retemberi richava chikomo chakamera miti.’ 
\m  
\v 19 Ko, Hezekia mambo weJudha kana mumwewo zvake weJudha ndiye akamuuraya here? Ko, Hezekia haana kutya Jehovha akatsvaka nyasha dzake here? Uye Jehovha haana kuzvidemba, akarega kuuyisa njodzi yaakanga ataura pamusoro pavo here? Tava kuda kuzviunzira dambudziko rakaipisisa pamusoro pedu!” 
\p  
\v 20 (Zvino Uria mwanakomana waShemaya aibva kuKiriati Tearimi ndiye mumwe murume akaprofita muzita raJehovha; akaprofita zvinhu zvimwe chetezvo pamusoro peguta rino nenyika ino sezvakangoitwawo naJeremia.  
\v 21 Mambo Jehoyakimi namakurukota ake ose namachinda ake vakati vanzwa mashoko ake, mambo akatsvaka kumuuraya. Asi Uria akazvinzwa akatya ndokubva atizira kuIjipiti.  
\v 22 Kunyange zvakadaro, mambo Jehoyakimi akatuma Erinatani mwanakomana waAkibhori kuIjipiti, pamwe chete navamwe varume.  
\v 23 Vakabudisa Uria kubva kuIjipiti vakamuendesa kuna Mambo Jehoyakimi uyo akaita kuti aurayiwe uye mutumbi wake ukakandwa kunzvimbo yaivigirwa vanhuwo zvavo). 
\p  
\v 24 Pamusoro paizvozvo Ahikami mwanakomana waShafani akatsigira Jeremia, nokudaro haana kuzoiswa mumaoko avanhu kuti aurayiwe. 
\c 27  
\s1 VaJudha vanofanira kushandira Nebhukadhinezari 
\p  
\v 1 Pakutanga kwokubata ushe kwaZedhekia mwanakomana waJosia mambo weJudha, shoko iri rakasvika kuna Jeremia richibva kuna Jehovha, richiti:  
\v 2 Izvi ndizvo zvataurwa naJehovha kwandiri: “Ita joko remakashu namatanda ugoriisa pamutsipa wako.  
\v 3 Ipapo ugotuma shoko kuna mambo weEdhomu, nokuna mambo weMoabhu, noweAmoni, noweTire neSidhoni noruoko rwenhume dzinouya kuJerusarema kuna Zedhekia mambo weJudha.  
\v 4 Uvape shoko ravanatenzi vavo uchiti, ‘Zvanzi naJehovha Wamasimba Ose iye Mwari waIsraeri, “Taurai izvi kuna vanatenzi venyu kuti:  
\v 5 Ndakaita nyika navanhu vayo, nemhuka dziri mairi nesimba rangu guru uye noruoko rwakatambanudzwa, uye ndinoipa kuna ani zvake anondifadza.  
\v 6 Zvino, ndichapa nyika dzako dzose kumuranda wangu Nebhukadhinezari mambo weBhabhironi; uye kuti kunyange zvikara zvesango zvive pasi pake.  
\v 7 Ndudzi dzose dzichamushandira, iye nemwanakomana wake, nomuzukuru wake, kusvikira nguva yenyika yake yasvika; ipapo ndudzi zhinji namadzimambo makuru vachamuita muranda. 
\p  
\v 8 “ ‘ “Kunyange zvakadaro, kana rudzi rupi norupi kana ushe hupi nohupi hukasazoshandira Nebhukadhinezari mambo weBhabhironi kana hukazoisa mutsipa warwo pasi pejoko rake, ndicharanga rudzi urwo nomunondo, nenzara uye nedenda, kusvikira ndarupedza noruoko rwake, ndizvo zvinotaura Jehovha.  
\v 9 Saka musateerera vaprofita venyu, navavuki venyu, kana vanodudzira hope kana vafemberi kana varoyi vanokuudzai kuti, ‘Hamungashandiri mambo weBhabhironi’.  
\v 10 Vanokuprofitirai nhema dzichangoita kuti mubviswe muendeswe kure nenyika dzenyu; ndichakudzingai uye muchaparara.  
\v 11 Asi kana rudzi rupi norupi rukazoisa mutsipa warwo pasi pejoko ramambo weBhabhironi rukamushandira, ndichaita kuti rudzi urwo rurambe rwuri munyika yarwo kuti varime vagogaramo, ndizvo zvinotaura Jehovha.” ’ ” 
\p  
\v 12 Ndakapa shoko rimwe chetero kuna Zedhekia mambo weJudha. Ndakati, “Isa mutsipa wako pasi pejoko ramambo weBhabhironi; umushandire iye navanhu vake, ugorarama.  
\v 13 Ko, iwe navanhu vako muchafireiko nomunondo, nenzara uye nedenda izvo zvakanzi naJehovha ndichaitira rudzi rupi norupi rucharega kushandira mambo weBhabhironi?  
\v 14 Regai kuteerera mashoko avaprofita vanoti kwamuri, ‘Hamungashandiri mambo weBhabhironi,’ nokuti vanoprofita nhema pamusoro penyu.  
\v 15 ‘Ini handina kuvatuma,’ ndizvo zvinotaura Jehovha. ‘Vari kuprofita nhema muzita rangu. Naizvozvo, ndichakudzingai, mugoparara mose imi navaprofita vanoprofita kwamuri.’ ” 
\p  
\v 16 Ipapo ndakati kuvaprista navanhu vose ava, “Zvanzi naJehovha: Regai kuteerera vaprofita vanoti, ‘Iye zvino, nokukurumidza, midziyo yakabviswa mutemberi yaJehovha ichadzoswazve kubva kuBhabhironi.’ Vari kukuprofitirai nhema.  
\v 17 Regai kuvateerera. Shandirai mambo weBhabhironi, mugorarama. Guta rino richaitireiko dongo?  
\v 18 Kana vari vaprofita uye vane shoko raJehovha ngavakumbirise kuna Jehovha, Wamasimba Ose kuti midziyo yakasara muimba yaJehovha, nomumuzinda wamambo weJudha neJerusarema irege kutakurwa ichiendeswa kuBhabhironi.  
\v 19 Nokuti izvi ndizvo zvinotaura Jehovha Wamasimba Ose pamusoro pembiru, neGungwa, napamusoro pezvigadziko zvinofambiswa nemimwe midziyo yakasara muguta rino,  
\v 20 zvisina kutorwa naNebhukadhinezari mambo weBhabhironi paakatapa Jehoyakini, mwanakomana waJehoyakimi mambo weJudha, pamwe chete navakuru vose veJudha neJerusarema, kubva kuJerusarema achivaendesa kuBhabhironi.  
\v 21 Hongu, zvanzi naJehovha Wamasimba Ose, Mwari waIsraeri, pamusoro pezvinhu zvakasiyiwa mutemberi yaJehovha nomumuzinda wamambo weJudha uye nomuJerusarema:  
\v 22 ‘Zvichatakurwa zvichiendeswa kuBhabhironi uye ndiko kwazvichagara kusvikira pazuva randichavavinga,’ ndizvo zvinotaura Jehovha. ‘Ipapo ndichavadzosa ndigovagarisazve panzvimbo ino.’ ” 
\c 28  
\s1 Hanania Muprofita Wenhema 
\p  
\v 1 Pakutanga kwokubata ushe kwaZedhekia mambo weJudha, mugore rechina, nomwedzi wechishanu wegore racho iroro, muprofita Hanania mwanakomana waAzuri, aibva kuGibheoni, akati kwandiri tiri mumba yaJehovha pamberi pavaprista navanhu vose,  
\v 2 “Zvanzi naJehovha Mwari Wamasimba Ose, Mwari waIsraeri, ‘Ndichavhuna joko ramambo weBhabhironi.  
\v 3 Makore maviri asati apera, ndichadzosa kunzvimbo ino midziyo yose yeimba yaJehovha yakanga yatorwa naNebhukadhinezari mambo weBhabhironi kubva kuno akaiendesa kuBhabhironi.  
\v 4 Ndichadzosazve kunzvimbo ino Jehoyakini mwanakomana waJehoyakimi mambo weJudha navose vakatapwa kubva kuJudha, vakaenda kuBhabhironi,’ ndizvo zvinotaura Jehovha, ‘nokuti ndichavhuna joko ramambo weBhabhironi.’ ” 
\p  
\v 5 Ipapo muprofita Jeremia akapindura muprofita Hanania pamberi pavaprista navanhu vose vakanga vamire muimba yaJehovha.  
\v 6 Akati, “Ameni! Jehovha ngaaite izvozvo! Jehovha ngaazadzise mashoko awakaprofita, nokudzosa midziyo yeimba yaJehovha nevakatapwa vose kunzvimbo ino vachibva kuBhabhironi.  
\v 7 Kunyange zvakadaro, chinzwa zvandinokutaurira munzeve dzako nomunzeve dzavanhu vose:  
\v 8 Kubva kare, vaprofita vakakutangira iwe neni vakaprofitira nyika zhinji noushe ukuru pamusoro pehondo, nenjodzi uye denda.  
\v 9 Asi muprofita anoprofita zvorugare ndiye achazivikanwa somunhu akatumwa naJehovha zvechokwadi kana chete shoko raakaprofita rikaitika.” 
\p  
\v 10 Ipapo muprofita Hanania akabvisa joko pamutsipa womuprofita Jeremia akarivhuna,  
\v 11 uye akati, pamberi pavanhu vose, “Zvanzi naJehovha: ‘Saizvozvi ndichavhuna joko raNebhukadhinezari mambo weBhabhironi kubva pamutsipa wendudzi dzose makore maviri asati apera.’ ” Adaro, muprofita Jeremia akaenda hake. 
\p  
\v 12 Mushure mokunge muprofita Hanania avhuna joko pamutsipa waJeremia, shoko raJehovha rakasvika kuna Jeremia richiti,  
\v 13 “Enda unoudza Hanania kuti, ‘Zvanzi naJehovha: Wavhuna joko redanda, asi panzvimbo yaro uchawana joko resimbi.  
\v 14 Zvanzi naJehovha Wamasimba Ose, Mwari weIsraeri, ndichaisa joko resimbi pamitsipa yendudzi idzi dzose kuti vashandire Nebhukadhinezari mambo weBhabhironi, uye vachamushandira. Ndichaita kuti ave nesimba kunyange nepamusoro pezvikara zvesango.’ ” 
\p  
\v 15 Ipapo muprofita Jeremia akati kuna Hanania muprofita, “Inzwa, Hanania! Jehovha haana kukutuma iwe, asi wakanyengera rudzi urwu kuti ruvimbe nenhema dzako.  
\v 16 Naizvozvo, zvanzi naJehovha, ‘Ndava pedyo nokukubvisa pamusoro penyika. Gore iro rino chairo uchafa, nokuti wakaparidza zvinomukira Jehovha.’ ” 
\p  
\v 17 Mumwedzi wechinomwe wegore racho iroro, muprofita Hanania akafa. 
\c 29  
\s1 Tsamba kuVatapwa 
\p  
\v 1 Zvino aya ndiwo mashoko etsamba yakatumwa nomuprofita Jeremia kubva kuJerusarema ichienda kuvakuru vakanga vachiri vapenyu pakati pavatapwa, nokuvaprista navaprofita, navamwe vanhu vose vakanga vaendeswa kuutapwa kuBhabhironi naNebhukadhinezari vachibviswa kuJerusarema.  
\v 2 (Izvi zvakaitika shure kwokunge Mambo Jehoyakini namai vake, namachinda omuruvazhe rwamambo, navatungamiri veJudha neJerusarema, navavezi, navapfuri, vaendeswa kuutapwa vachibviswa kuJerusarema.)  
\v 3 Akaendesa tsamba iyi noruoko rwaErasa, mwanakomana waShafani, naGemaria mwanakomana waHirikia, avo vakatumwa naZedhekia mambo waJudha kuna Mambo Nebhukadhinezari kuBhabhironi. Yaiti: 
\pm  
\v 4 Zvanzi naJehovha Wamasimba Ose, Mwari waIsraeri, kuna vose vandakaendesa kuutapwa kuBhabhironi vachibva kuJerusarema:  
\v 5 “Zvivakirei dzimba mugare; murime mapindu mugodya zvibereko zvawo.  
\v 6 Wananai mugova navanakomana navanasikana; tsvakirai vanakomana venyu vakadzi uye muwanise vanasikana venyu, kuti naivowo vave navanakomana navanasikana. Muwande ikoko; musadzikira pakuwanda.  
\v 7 Uyezve, mutsvake rugare nokubudirira kweguta randakakuendesai kuutapwa. Murinyengeterere kuna Jehovha, nokuti kana rikabudirira, nemiwo muchabudirira.”  
\v 8 Nokuti, zvanzi naJehovha Wamasimba Ose, Mwari weIsraeri, “Musarega vaprofita navavuki vari pakati penyu vachikunyengerai. Musateerera kurota kwamunovakurudzira kuti varote.  
\v 9 Vanokuprofitirai nhema muzita rangu. Handina kuvatuma,” ndizvo zvinotaura Jehovha. 
\pm  
\v 10 Nokuti zvanzi naJehovha: “Panopera makore makumi manomwe eBhabhironi, ndichauyazve kwamuri ndigozadzisa zvakanaka zvandakavimbisa kuti ndichakudzoserai kunzvimbo ino.  
\v 11 Nokuti ndinoziva urongwa hwandinahwo pamusoro penyu,” ndizvo zvinotaura Jehovha, “urongwa hwokuti mubudirire, kwete kukuitirai zvakaipa, urongwa hunokupai tariro neramangwana rakanaka.  
\v 12 Ipapo muchadana kwandiri uye muchauya kuzonyengetera kwandiri, neni ndichakunzwai.  
\v 13 Muchanditsvaka mukandiwana, pamunonditsvaka nemwoyo yenyu yose.  
\v 14 Ndichawanikwa nemi,” ndizvo zvinotaura Jehovha, “uye ndichakudzosai kubva kuutapwa. Ndichakuunganidzai kubva kundudzi dzose nokunzvimbo dzandakanga ndakudzingirai,” ndizvo zvinotaura Jehovha, “uye ndichakudzoseraizve kunzvimbo yandakanga ndakubudisai ndichikuendesai kuutapwa.” 
\pm  
\v 15 Imi mungati henyu, “Jehovha akatimutsira vaprofita muBhabhironi,”  
\v 16 asi zvanzi naJehovha pamusoro pamambo achagara pachigaro choushe chaDhavhidhi navanhu vose vanosara vari muguta rino, vanhu venyika yenyu vasina kuenda nemi kuutapwa,  
\v 17 hongu, zvanzi naJehovha Wamasimba Ose, “Ndichatuma munondo, nzara nedenda pamusoro pavo uye ndichavaita samaonde akaipa akaora zvokuti haangadyiwi.  
\v 18 Ndichavatevera nomunondo, nzara nedenda uye ndichavaita chinhu chinovengwa noushe hwose hwenyika uye chinhu chinotukwa, nechinotyisa, nechinosekwa, nechinoshorwa pakati pendudzi dzose kwandakavadzingira.  
\v 19 Nokuti havana kuteerera kumashoko angu,” ndizvo zvinotaura Jehovha, “mashoko andakatuma ndatumazve kwavari navaranda vangu vaprofita. Nemiwo vakatapwa makaramba kuateerera,” ndizvo zvinotaura Jehovha. 
\pm  
\v 20 Naizvozvo, chinzwai shoko raJehovha, imi mose makatapwa vandakadzingira kuBhabhironi muchibva kuJerusarema.  
\v 21 Zvanzi naJehovha Wamasimba Ose, Mwari weIsraeri, pamusoro paAhabhu mwanakomana waKoraya naZedhekia mwanakomana waMaaseya, vari kukuprofitirai nhema muzita rangu: “Ndichavaisa muruoko rwaNebhukadhinezari mambo weBhabhironi, uye achavauraya pamberi penyu muchizviona.  
\v 22 Nokuda kwavo, vatapwa vose vakabva kuJudha vari muBhabhironi vachashandisa chituko ichi: ‘Jehovha akuitire sezvaakaita kuna Zedhekia naAhabhu avo vakapiswa mumoto namambo weBhabhironi.’  
\v 23 Nokuti vakaita zvinhu zvinonyangadza muIsraeri; vakaita upombwe navakadzi vavavakidzani vavo uye vakareva nhema muzita rangu, izvo zvandisina kuvaudza kuti vaite. Ndinozviziva uye ndiri chapupu chazvo,” ndizvo zvinotaura Jehovha. 
\s1 Shoko kuna Shemaya 
\p  
\v 24 Udza Shemaya muNeherami kuti,  
\v 25 “Zvanzi naJehovha Wamasimba Ose, Mwari weIsraeri: Wakatumira matsamba muzita rako kuvanhu vose vomuJerusarema, kuna Zefania mwanakomana waMaaseya muprista, nokuna vamwe vaprista vose. Wakati kuna Zefania,  
\v 26 ‘Jehovha akakugadza kuva muprista panzvimbo yaJehoyadha kuti uve mutariri weimba yaJehovha; unofanira kuisa muchitokisi nomumangetani munhu upi zvake anopenga achiita somuprofita.  
\v 27 Saka wakaregererei kuranga Jeremia weAnatoti, anozviti muprofita pakati penyu?  
\v 28 Akatuma shoko iri kwatiri paBhabhironi, achiti: Zvichatora nguva yakareba. Naizvozvo zvivakirei dzimba mugogara; murime mapindu mugodya zvibereko zvawo.’ ” 
\p  
\v 29 Uye, Zefania muprista akaverengera muprofita Jeremia tsamba iyi.  
\v 30 Ipapo shoko raJehovha rakasvika kuna Jeremia, richiti,  
\v 31 “Tumira shoko iri kuvatapwa vose, uti, ‘Zvanzi naJehovha pamusoro paShemaya, muNeherami: Nokuti Shemaya akuprofitirai, kunyange ini ndisina kumutuma, uye aita kuti mutende nhema,  
\v 32 zvanzi naJehovha: Zvirokwazvo ndicharanga Shemaya muNeherami nezvizvarwa zvake. Haangavi nomunhu achasara pakati pavanhu ava, kana kuona zvinhu zvakanaka zvandichaitira vanhu vangu, ndizvo zvinotaura Jehovha, nokuti akaparidza zvokundimukira.’ ” 
\c 30  
\s1 Kuvandudzwa kweIsraeri 
\p  
\v 1 Iri ndiro shoko rakauya kuna Jeremia richibva kuna Jehovha richiti,  
\v 2 “Zvanzi naJehovha, Mwari waIsraeri, ‘Nyora mubhuku mashoko ose andakakuudza.  
\v 3 Mazuva anouya,’ ndizvo zvinotaura Jehovha, ‘andichadzosa vanhu vangu, vaIsraeri navaJudha kubva kuutapwa. Uye ndichavadzosera kunyika yandakapa madzitateguru avo kuti ive yavo,’ ndizvo zvinotaura Jehovha.” 
\p  
\v 4 Aya ndiwo mashoko akataurwa naJehovha pamusoro peIsraeri neJudha:  
\v 5 “Zvanzi naJehovha: 
\q1 “ ‘Tinonzwa kuchema kwevanotya, 
\q2 kwokutyisidzirwa, kwete kworugare. 
\q1  
\v 6 Bvunzai muone: 
\q2 Ko, murume angagona kusununguka mwana here? 
\q1 Zvino, seiko ndichiona murume mumwe nomumwe akasimba 
\q2 akabata padumbu pake namaoko ake somukadzi orwadziwa, 
\q2 zviso zvose zvachenuruka? 
\q1  
\v 7 Haiwa, zuva iro richatyisa seiko! 
\q2 Hakuna richafanana naro. 
\q1 Ichava nguva yaJakobho yokutambudzika, 
\q2 asi achaponeswa pairi. 
\b  
\q1  
\v 8 “ ‘Pazuva iro,’ ndizvo zvinotaura Jehovha Wamasimba Ose, 
\q2 ‘Ndichavhuna joko pamitsipa yavo 
\q1 uye ndichadambura zvisungo zvavo; 
\q2 havachazoitwizve varanda navatorwa. 
\q1  
\v 9 Asi, vachashumira Jehovha Mwari wavo 
\q2 naDhavhidhi mambo wavo, 
\q2 iye wandichavamutsira. 
\b  
\q1  
\v 10 “ ‘Saka, usatya, iwe Jakobho muranda wangu; 
\q2 usavhunduka, iwe Israeri,’ 
\q4 ndizvo zvinotaura Jehovha. 
\q1 ‘Zvirokwazvo ndichakuponesa kubva kunyika iri kure, 
\q2 zvizvarwa zvako kubva kunyika youtapwa hwavo. 
\q1 Jakobho achavazve norunyararo uye nokuchengetedzeka, 
\q2 uye hakuna achazomutyisa. 
\q1  
\v 11 Ndinewe uye ndichakuponesa,’ 
\q2 ndizvo zvinotaura Jehovha. 
\q1 ‘Kunyange zvazvo ndakaparadza chose ndudzi dzose 
\q2 dzandakakuparadzira pakati padzo, 
\q2 handingazokuparadze zvachose iwe. 
\q1 Ndichakuranga asi nokururamisira chete; 
\q2 handingakusiyi usina kurangwa zvachose.’ 
\p  
\v 12 “Zvanzi naJehovha: 
\q1 “ ‘Ronda rako harirapiki, 
\q2 kukuvadzwa kwako hakupori. 
\q1  
\v 13 Hakuna anokureverera mhaka yako, 
\q2 vanga rako harina mushonga, 
\q2 hapana kuporeswa kwako. 
\q1  
\v 14 Vose vaikuda vakakukanganwa; 
\q2 havachina hanya newe. 
\q1 Ndakakurova sezvinoitwa nomuvengi 
\q2 ndikakuranga sezvinoitwa neano utsinye 
\q1 nokuti mhosva yako ihuru 
\q2 uye zvivi zvako zvakawanda. 
\q1  
\v 15 Unochemeiko pamusoro pevanga rako, 
\q2 nokurwadziswa kwako kusingarapike? 
\q1 Nokuda kwokukura kwemhaka yako nezvivi zvizhinji 
\q2 ndakaita zvinhu izvi kwauri. 
\b  
\q1  
\v 16 “ ‘Asi vose vanokudya iwe vachadyiwawo; 
\q2 vavengi vako vose vachaenda kuutapwa. 
\q1 Vanokupamba, vachapambwawo; 
\q2 vose vanokuparadza, ndichavaparadzawo. 
\q1  
\v 17 Asi ndichakudzorera pautano 
\q2 uye ndichaporesa maronda ako,’ 
\q4 ndizvo zvinotaura Jehovha, 
\q1 ‘nokuti iwe wakanzi murashwa, 
\q2 Zioni zvaro risina ane hanya naro.’ 
\p  
\v 18 “Zvanzi naJehovha: 
\q1 “ ‘Ndichadzosazve pfuma yamatende aJakobho 
\q2 uye ndichanzwira ugaro hwake tsitsi; 
\q1 guta richavakwazve pamatongo aro, 
\q2 nomuzinda uchamira panzvimbo yawo yakafanira. 
\q1  
\v 19 Nziyo dzokuvonga dzichabva kwavari 
\q2 uye nenzwi romufaro. 
\q1 Ndichawedzera kuwanda kwavo, 
\q2 uye havangatapudzwi; 
\q1 ndichavavigira kukudzwa, 
\q2 uye havangadukupiswi, 
\q1  
\v 20 Vana vavo vachava sepamazuva ekare, 
\q2 uye ungano yavo ichasimbiswa pamberi pangu; 
\q2 ndicharanga vose vanovamanikidza. 
\q1  
\v 21 Mutungamiri wavo achava mumwe wokwavo; 
\q2 anovabata ushe achamutswa pakati pavo. 
\q1 Ndichamuswededza pedyo uye iye achaswedera pedyo neni, 
\q2 nokuti ndianiko achazvipira 
\q2 kuti ave pedyo neni?’ 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 22 ‘Saka muchava vanhu vangu, 
\q2 neni ndichava Mwari wenyu.’ ” 
\b  
\q1  
\v 23 Tarirai, dutu raJehovha 
\q2 richaputika mukutsamwa kwake, 
\q1 mhepo inovhuvhuta ichimona 
\q2 pamisoro yavakaipa. 
\q1  
\v 24 Kutsamwa kunotyisa kwaJehovha hakungadzoki, 
\q2 kusvikira apedza 
\q2 zvinovavarirwa nomwoyo wake. 
\q1 Mumazuva anouya 
\q2 muchanzwisisa izvozvi. 
\c 31  
\p  
\v 1 “Panguva iyo,” ndizvo zvinotaura Jehovha, “ndichava Mwari wamarudzi ose aIsraeri, naivo vachava vanhu vangu.” 
\p  
\v 2 Zvanzi naJehovha: 
\q1 “Vanhu vakapunyuka pamunondo 
\q2 vachawana nyasha mugwenga; 
\q2 ndichauya kuzopa zororo kuna Israeri.” 
\p  
\v 3 Jehovha akazviratidza kwatiri kare, achiti: 
\q1 “Ndakakudai norudo rusingaperi; 
\q2 ndakakukwevai nokunaka kworudo rwangu. 
\q1  
\v 4 Ndichakuvakazve, 
\q2 ipapo uchavakwa, iwe Mhandara Israeri. 
\q1 Uchatorazve matambureni ako 
\q2 ugoenda kundotamba navanofara. 
\q1  
\v 5 Zvakare, muchasima minda yemizambiringa 
\q2 pamusoro pezvikomo zveSamaria; 
\q1 varimi vachaisima, 
\q2 vagofadzwa nezvibereko zvayo. 
\q1  
\v 6 Pachava nezuva richadanidzira nharirire 
\q2 dziri pamusoro pezvikomo zveEfuremu, dzichiti, 
\q1 ‘Uyai, ngatikwidzei kuZioni, 
\q2 kuna Jehovha Mwari wedu.’ ” 
\p  
\v 7 Zvanzi naJehovha: 
\q1 “Imbirai Jakobho nomufaro; 
\q2 pururudzirai mukuru wendudzi. 
\q1 Paridzai, rumbidzai, muchiti, 
\q2 ‘Haiwa Jehovha, ponesai vanhu venyu, 
\q2 ivo vakasara vaIsraeri.’ 
\q1  
\v 8 Tarirai, ndichavauyisa vachibva kunyika yokumusoro, 
\q2 uye ndigovaunganidza kubva kumigumo yenyika. 
\q1 Pakati pavo pachava namapofu nezvirema, 
\q2 navanamai vane pamuviri navakadzi vanorwadziwa; 
\q2 boka guru richadzoka kuno. 
\q1  
\v 9 Vachauya vachichema; 
\q2 vachanyengetera pandinenge ndichivadzosa. 
\q1 Ndichavafambisa nepahova dzemvura, 
\q2 napanzira yakati chechetere yavasingagumburwi, 
\q1 nokuti ndiri baba vaIsraeri, 
\q2 uye Efuremu ndiye dangwe rangu. 
\b  
\q1  
\v 10 “Inzwai shoko raJehovha imi ndudzi dzose; 
\q2 muriparidze kuzviwi zviri kure muchiti: 
\q1 ‘Iye akaparadzira Israeri ndiye achavaunganidza, 
\q2 uye achavachengeta somufudzi anochengeta boka ramakwai ake.’ 
\q1  
\v 11 Nokuti Jehovha achasunungura Jakobho, 
\q2 uye agovadzikinura kubva muruoko rwaivo vane simba kupinda ivo. 
\q1  
\v 12 Vachauya vachipembera nomufaro pamusoro peZioni; 
\q2 vachafara nokupa zvakanaka kwaJehovha, 
\q1 nokuda kwezviyo, newaini itsva uye namafuta, 
\q2 makwayana nemombe. 
\q1 Vachafanana nebindu rakanyatsodiridzwa, 
\q2 uye havachazosuwazve. 
\q1  
\v 13 Ipapo varandakadzi vachatamba uye vachafara, 
\q2 majaya navatana vachafarawo. 
\q1 Ndichashandura kuchema kwavo kuti kuve mufaro; 
\q2 ndichavanyaradza uye ndichavapa mufaro pachinzvimbo chokusuwa. 
\q1  
\v 14 Ndichagutsa vaprista nezvakawanda, 
\q2 uye vanhu vangu vachazadzwa nokupa zvakanaka kwangu,” 
\q4 ndizvo zvinotaura Jehovha. 
\p  
\v 15 Zvanzi naJehovha: 
\q1 “Inzwi rinonzwikwa muRama, 
\q2 rokuungudza nokuchema kukuru, 
\q1 Rakeri achichema vana vake 
\q2 uye achiramba kunyaradzwa, 
\q2 nokuti vana vake havachipo.” 
\p  
\v 16 Zvanzi naJehovha: 
\q1 “Dzora inzwi rako pakuchema 
\q2 nameso ako pamisodzi, 
\q1 nokuti basa rako richaripirwa,” 
\q4 ndizvo zvinotaura Jehovha. 
\q2 “Vachadzoka vachibva kunyika yomuvengi. 
\q1  
\v 17 Saka ramangwana rako rine tariro,” 
\q4 ndizvo zvinotaura Jehovha. 
\q2 “Vana vako vachadzokera kunyika yavo.” 
\b  
\q1  
\v 18 “Zvirokwazvo ndanzwa kuchema kwaEfuremu achiti: 
\q2 ‘Makandirova semhuru isina kupingudzwa, 
\q2 nokudaro ndakarangwa. 
\q1 Ndidzorei, ipapo ndichadzoka, 
\q2 nokuti imi ndimi Jehovha Mwari wangu. 
\q1  
\v 19 Mushure mokutsauka kwangu, 
\q2 ndakatendeuka; 
\q1 ndakati ndanzwisisa 
\q2 ndakazvirova chipfuva. 
\q1 Ndakanyadziswa uye ndakaninipiswa 
\q2 nokuti ndakatakura nyadzi dzouduku hwangu.’ 
\q1  
\v 20 Ko, Efuremu haasi mwanakomana wangu anodikanwa, 
\q2 mwana anondifadza here? 
\q1 Kunyange ndichimupikisa kazhinji, 
\q2 ndinoramba ndichimurangarira. 
\q1 Naizvozvo, mwoyo wangu unomushuva; 
\q2 ndinomunzwira tsitsi kwazvo,” 
\q4 ndizvo zvinotaura Jehovha. 
\b  
\q1  
\v 21 “Zvimisirei shongwe dzenzira; 
\q2 misai zvikwangwani. 
\q1 Cherechedzai mugwagwa mukuru, 
\q2 mugwagwa wamunofamba nawo. 
\q1 Dzoka, iwe Mhandara Israeri, 
\q2 dzokera kumaguta ako. 
\q1  
\v 22 Uchadzungaira kusvikira rinhiko, 
\q2 iwe mwanasikana wokusatendeka? 
\q1 Jehovha achasika chinhu chitsva panyika, 
\q2 zvokuti mukadzi achambundikira murume.” 
\p  
\v 23 Zvanzi naJehovha Wamasimba Ose, Mwari weIsraeri: “Pandichavadzosazve kubva kuutapwa, vanhu vari munyika yeJudha nomumaguta ayo vachataurazve mashoko aya okuti, ‘Jehovha ngaakuropafadze, iwe ugaro hwakarurama, iwe gomo dzvene.’  
\v 24 Vanhu vachagara pamwe chete muJudha nomumaguta ayo ose, varimi navaya vanofamba namapoka avo.  
\v 25 Ndichasimbisa vanenge vaneta uye ndichagutsa vanenge vaziya.” 
\p  
\v 26 Ipapo ndakamuka ndokuringa-ringa. Ndakanga ndarara zvakanaka. 
\p  
\v 27 “Mazuva anouya,” ndizvo zvinotaura Jehovha, “andichasima muimba yaIsraeri nomuimba yaJudha zvibereko zvavanhu nezvibereko zvemhuka.  
\v 28 Sezvandakavarindira kuti ndidzure, ndikoromore, uye ndiwisire pasi, ndiparadze, ndiuyise njodzi, saizvozvo ndichavarindira, kuti ndivake uye ndisime,” ndizvo zvinotaura Jehovha.  
\v 29 “Mumazuva iwayo vanhu havangazoti, 
\q1 “ ‘Madzibaba akadya mazambiringa anovava, 
\q2 mazino avana akaita hwadzira.’ 
\m  
\v 30 Asi, mumwe nomumwe achafa nokuda kwezvakaipa zvake; ani naani anodya mazambiringa anovava, mazino ake achaita hwadzira. 
\q1  
\v 31 “Nguva inouya,” ndizvo zvinotaura Jehovha, 
\q2 “yandichaita sungano itsva 
\q1 neimba yaIsraeri 
\q2 uye neimba yaJudha. 
\q1  
\v 32 Haingazofanani nesungano 
\q2 yandakaita namadzitateguru avo, 
\q1 pandakavabata ruoko 
\q2 kuti ndivabudise munyika yeIjipiti, 
\q1 nokuti vakaputsa sungano yangu, 
\q2 kunyange ndakanga ndiri murume kwavari,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 33 “Iyi indiyo sungano yandichaita neimba yaIsraeri 
\q2 shure kwamazuva iwayo,” ndizvo zvinotaura Jehovha. 
\q1 “Ndichaisa murayiro wangu mundangariro dzavo 
\q2 uye ndigounyora mumwoyo yavo. 
\q2 Ndichava Mwari wavo, uye ivo vachava vanhu vangu. 
\q1  
\v 34 Hakuna munhu achadzidzisa muvakidzani wake 
\q2 kana hama yake, achiti, ‘Ziva Jehovha,’ 
\q1 nokuti vose vachandiziva, 
\q2 kubva kumuduku wavo kusvikira kumukuru,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1 “Nokuti ndichavakanganwira kuipa kwavo, 
\q2 uye handingarangaririzve zvivi zvavo.” 
\p  
\v 35 Zvanzi naJehovha, 
\q1 iye anogadza zuva 
\q2 kuti rivhenekere masikati, 
\q1 anoisa chirevo kumwedzi nenyeredzi 
\q2 kuti zvivhenekere usiku, 
\q1 iye anomutsa gungwa kuti mafungu aro atinhire, 
\q2 Jehovha Wamasimba Ose, ndiro zita rake: 
\q1  
\v 36 “Kana chete mitemo iyi ikabva pamberi pangu,” 
\q2 ndizvo zvinotaura Jehovha, 
\q1 “ndiko kuti zvizvarwa zvaIsraeri zvigume 
\q2 kuva rudzi pamberi pangu.” 
\p  
\v 37 Zvanzi naJehovha: 
\q1 “Kana chete matenga ari kumusoro akagona kuyerwa, 
\q2 uye nheyo dzenyika dziri pasi dzikagona kunzverwa, 
\q1 ipapo ndipo pandingarambe zvizvarwa zvaIsraeri 
\q2 nokuda kwezvose zvavakaita,” 
\q4 ndizvo zvinotaura Jehovha. 
\p  
\v 38 “Mazuva anouya,” ndizvo zvinotaura Jehovha, “andichavakirazve guta kubva paShongwe yeHananeri kusvikira paSuo reKona.  
\v 39 Rwodzi rwokuyera ruchatandavara kubva ipapo kusvikira kuchikomo cheGarebhi ndokudzoka ruchisvika kuGoa.  
\v 40 Mupata wose unorasirwa zvitunha namadota, neminda yose kusvikira kuMupata weKidhironi kumabvazuva kusvikira kukona reSuo raMabhiza, zvichava zvitsvene kuna Jehovha. Guta harichazombodzurwi kana kuparadzwazve.” 
\c 32  
\s1 Jeremia anotenga Munda 
\p  
\v 1 Iri ndiro shoko rakauya kuna Jeremia richibva kuna Jehovha mugore regumi raZedhekia mambo weJudha, riri gore regumi namasere raNebhukadhinezari.  
\v 2 Hondo yamambo Nebhukadhinezari yakanga yakakomberedza Jerusarema, uye Jeremia muprofita akanga akapfigirwa muruvazhe rwavarindi rwakanga rwuri mumuzinda wamambo weJudha. 
\p  
\v 3 Zvino Zedhekia mambo weJudha akanga amupfigira imomo, achiti, “Unoprofitirei sezvaunoita? Unoti, ‘Zvanzi naJehovha: Ndava kuda kuisa guta rino mumaoko amambo weBhabhironi, uye acharipamba.  
\v 4 Zedhekia mambo weJudha haangapukunyuki pamaoko avaBhabhironi, asi zvirokwazvo achaiswa muruoko rwamambo weBhabhironi, vagotaurirana vakatarisana chiso nechiso achimuona nameso ake.  
\v 5 Iye achaendesa Zedhekia kuBhabhironi, kwaachagara kusvikira ndagadzirisana naye, ndizvo zvinotaura Jehovha. Kana ukarwa navaBhabhironi haungavakundi.’ ” 
\p  
\v 6 Jeremia akati, “Shoko raJehovha rakasvika kwandiri richiti:  
\v 7 Hanameri mwanakomana wasekuru vako Sharumi achauya kwauri achiti, ‘Tenga munda wangu uri paAnatoti, nokuti sezvo uriwe hama yepedyo, ndiwe une kodzero yokuutenga.’ 
\p  
\v 8 “Ipapo, sokutaura kwakanga kwaita Jehovha, sekuru wangu Hanameri akauya kwandiri ndiri muruvazhe rwavarindi akati, ‘Tenga munda wangu uri paAnatoti munyika yeBhenjamini. Chizvitengera iwe kuti uve wako sezvo uriwe une kodzero yokuudzikinura.’ 
\p “Ndakazviziva kuti iri raiva shoko raJehovha;  
\v 9 saka ndakatenga munda waiva paAnatoti kubva kuna sekuru vangu Hanameri ndokumuyerera mashekeri gumi namanomwe\f + \fr 32:9 \ft magiramu angaita 200\f* esirivha.  
\v 10 Ndakanyora rugwaro rwokutenga ndikarunama, ndikaita kuti pave nezvapupu, ndikamuyerera sirivha pazviyero.  
\v 11 Ndakatora gwaro rokutengeserana, riya rakanga rakanamwa riine mirayiro nezvimwe, pamwe chete neriya rakanga risina kunamwa,  
\v 12 ndokupa gwaro iri kuna Bharuki mwanakomana waNeria, mwanakomana waMaseya, pamberi paHanameri mwanakomana wasekuru vangu napamberi pezvapupu zvakanga zvaisa runyoro pagwaro rokutengeserana, napamberi pavaJudha vose vakanga vagere muruvazhe rwavarindi. 
\p  
\v 13 “Ndakarayira Bharuki pamberi pavo, ndichiti,  
\v 14 ‘Zvanzi naJehovha Wamasimba Ose, Mwari weIsraeri: Tora magwaro aya, okutengeserana ari maviri akanamwa neasina kunamwa, ugoisa muhari yevhu kuitira kuti agare kwamazuva mazhinji.  
\v 15 Nokuti zvanzi naJehovha, Wamasimba Ose, Mwari waIsraeri: Dzimba, minda, uye minda yemizambiringa zvichatengwazve munyika ino.’ 
\p  
\v 16 “Mushure mokunge ndapa Bharuki mwanakomana waNeria gwaro rokutengeserana, ndakanyengetera kuna Jehovha, ndichiti: 
\pm  
\v 17 “Haiwa, Ishe Jehovha, ndimi makaita matenga nenyika nesimba renyu guru noruoko rwenyu rwakatambanudzwa. Hakuna chinhu chakaoma kwamuri.  
\v 18 Imi munoratidza rudo rwenyu kuzviuru nezviuru asi muchiuyisa shamhu yezvivi zvamadzibaba pamakumbo avana vavo vanovatevera. Haiwa imi Mwari mukuru ane simba guru, mune zita rinonzi Jehovha Wamasimba Ose,  
\v 19 zvinangwa zvenyu zvikuru uye mabasa enyu makuru. Meso enyu akasvinurira nzira dzose dzavanhu; munopa mumwe nomumwe zvakafanira mafambiro ake uye nezvakafanira mabasa ake.  
\v 20 Makaita zviratidzo nezvishamiso muIjipiti uye mukaramba muchizviita kusvikira pazuva ranhasi, pakati peIsraeri napakati pendudzi dzimwe dzose, uye mukazviwanira mukurumbira sezvazvakaita nanhasi.  
\v 21 Makabudisa vanhu venyu veIsraeri kubva muIjipiti nezviratidzo nezvishamiso, noruoko rune simba uye noruoko rwakatambanudzwa, uye nokutyisa kukuru.  
\v 22 Makavapa nyika ino yamakanga mapikira kupa madzibaba avo, nyika inoyerera mukaka nouchi.  
\v 23 Vakapinda vakaitora kuti ive yavo, asi havana kukuteererai kana kutevera murayiro wenyu; havana kuita zvamakanga mavarayira kuti vaite. Saka makauyisa njodzi yose iyi pamusoro pavo. 
\pm  
\v 24 “Tarirai mavakirwo ari kuitwa mirwi yokukomba kuti vatore guta. Nokuda kwomunondo, nenzara uye denda, guta richaiswa mumaoko avaBhabhironi vari kurirwisa. Zvamakataura zvaitika sezvamuri kuona zvino.  
\v 25 Kunyange hazvo guta rino richizoiswa mumaoko avaBhabhironi, imi, Ishe Jehovha makati kwandiri, ‘Zvitengere munda nesirivha uye uite kuti zvapupu zvivepo pakutengeserana uku.’ ” 
\p  
\v 26 Ipapo shoko raJehovha rakauya kuna Jeremia, richiti,  
\v 27 “Ndini Jehovha, Mwari wavanhu vose. Ko, pane chinhu chingandiomera here?  
\v 28 Naizvozvo zvanzi naJehovha: ndava pedyo nokuisa guta rino mumaoko avaBhabhironi, nokuna Nebhukadhinezari mambo weBhabhironi, uyo acharikunda.  
\v 29 VaBhabhironi vari kurwisa guta rino vachauya vagopinda vagoritungidza nomoto; vacharipisa, pamwe chete nedzimba dzavanhu vakanditsamwisa nokupisira zvinonhuhwira kuna Bhaari pamusoro pamatenga adzo uye nokudururira zvipiriso zvokunwa kuna vamwe vamwari. 
\p  
\v 30 “Vanhu veIsraeri navanhu veJudha havana kugona kuita chinhu chakanaka asi zvakaipa chete pamberi pangu kubva pauduku hwavo; zvirokwazvo vanhu veIsraeri havana kumbogona kuita zvakanaka asi vakanditsamwisa nezvavakaita namaoko avo, ndizvo zvinotaura Jehovha.  
\v 31 Kubva pazuva rakavakwa guta rino kusvikira zvino, guta rino rakamutsa hasha dzangu nokunditsamwisa zvikuru zvokuti ndinofanira kuribvisa pamberi pangu.  
\v 32 Vanhu veIsraeri navanhu veJudha vakanditsamwisa nezvakaipa zvose zvavakaita, ivo namadzimambo avo, namachinda avo, navaprista vavo, navaprofita vavo, ivo vanhu veJudha navanhu veJerusarema.  
\v 33 Vakandifuratira uye havana kunditarisa nezviso zvavo; kunyange ndakavadzidzisa ndadzidzisazve, havana kuteerera kana kutsiurika.  
\v 34 Vakaisa zvifananidzo zvavo zvinonyangadza mumba yakatumidzwa Zita rangu vakaisvibisa.  
\v 35 Vakavakira Bhaari nzvimbo dzakakwirira muMupata weBheni Hinomi kuti vabayire vanakomana navanasikana vavo kuna Moreki, kunyange ndisina kuvarayira, kana kuzviisa mupfungwa dzangu, kuti vaite chinhu chinonyangadza zvakadai, nokudaro vagoita kuti Judha itadze. 
\p  
\v 36 “Imi munotaura pamusoro peguta rino muchiti, ‘Guta rino richaiswa muruoko rwamambo weBhabhironi, nomunondo, nenzara, uye nedenda’; zvanzi naJehovha, Mwari weIsraeri:  
\v 37 Zvirokwazvo ndichavaunganidza kubva kunyika dzose dzandakanga ndavadzingira pakutsamwa kwangu kukuru nehasha dzangu huru; ndichavadzosazve kunzvimbo ino ndigovagarisa zvakanaka.  
\v 38 Vachava vanhu vangu, ini ndichava Mwari wavo.  
\v 39 Ndichavapa mwoyo mumwe namaitiro mamwe, kuitira kuti vagare vachinditya zvigovanakira ivo navana vavo vanovatevera.  
\v 40 Ndichaita sungano isingaperi navo: handingatongomiri pakuvaitira zvakanaka uye ndichavakurudzira kuti vanditye, kuitira kuti varege kuzotsauka kubva kwandiri.  
\v 41 Ndichafarira kuvaitira zvakanaka uye zvirokwazvo ndichavasima munyika ino, nomwoyo wangu wose uye nomweya wangu wose. 
\p  
\v 42 “Zvanzi naJehovha: Sezvandakauyisa njodzi huru yose iyi pamusoro pavanhu ava, saizvozvo ndichavapa kubudirira kwose kwandakavavimbisa.  
\v 43 Zvakare, minda ichatengwa munyika ino yamunoti, ‘Idongo, haina vanhu kana zvipfuwo, nokuti yakaiswa mumaoko avaBhabhironi.’  
\v 44 Minda ichatengwa nesirivha, uye magwaro okutengeserana achanyorwa, agonamwa uye agopupurirwa munyika yeBhenjamini, mumisha yakapoteredza Jerusarema, nomumaguta eJudha nomumaguta omunyika yezvikomo, nomujinga mezvikomo zvokumavirira, nokuNegevhi, nokuti ndichadzosazve pfuma yavo, ndizvo zvinotaura Jehovha.” 
\c 33  
\s1 Chivimbiso choKudzoredzanisa 
\p  
\v 1 Shoko raJehovha rakasvika kechipiri kuna Jeremia panguva yaakanga akapfigirwa muruvazhe rwavarindi richiti,  
\v 2 “Zvanzi naJehovha, iye akaita nyika, naiye akaiumba uye akaisimbisa, Jehovha ndiro zita rake,  
\v 3 ‘Danai kwandiri uye ndichakupindurai uye ndichakuudzai zvinhu zvikuru zvakavanzika zvamusingazivi.’  
\v 4 Nokuti zvanzi naJehovha, Mwari waIsraeri, pamusoro pedzimba dziri muguta rino uye nomuzinda wamadzimambo eJudha zvakakoromorerwa pasi kuti zvishandiswe pakuputsa mirwi yakakomba guta neminondo,  
\v 5 mukurwisana navaBhabhironi, ‘Zvichazadzwa nezvitunha zvavanhu vandichauraya pakutsamwa kwangu nehasha dzangu. Ndichavanzira guta rino chiso changu nokuda kwokuipa kwaro kwose. 
\p  
\v 6 “ ‘Kunyange zvakadaro hazvo, ndicharivigira utano nokurapwa; ndicharapa vanhu vangu uye ndichaita kuti vave norugare rwakawanda uye nokuchengetedzeka.  
\v 7 Ndichabvisazve Judha neIsraeri norugare kubva kuutapwa ndivavakezve sepakutanga.  
\v 8 Ndichavanatsa pachivi chose chavakanditadzira ndigovakanganwira zvivi zvavo zvose zvokundimukira.  
\v 9 Ipapo guta rino richandivigira mukurumbira, mufaro, kurumbidzwa nokukudzwa pamberi pendudzi dzose dzepanyika dzinonzwa zvakanaka zvose zvandinoriitira; dzichatya uye dzichadedera nokuda kwokukura kwokubudirira norugare rwandinoripa.’ 
\p  
\v 10 “Zvanzi naJehovha: ‘Munoti pamusoro penzvimbo ino, “Yaparara, haina vanhu vanogaramo kana mhuka dzinogaramo.” Asi mumaguta eJudha nomumigwagwa yeJerusarema makasiyiwa musina chinhu, musisagarwi navanhu kana nemhuka, muchanzwikwazve  
\v 11 manzwi nomufaro nokufarisisa, namanzwi emwenga nechikomba, namanzwi avaya vanouya nezvipo zvokuvonga kuimba yaJehovha, vachiti, 
\q1 “ ‘ “Vongai Jehovha Wamasimba Ose, 
\q2 nokuti Jehovha akanaka; 
\q2 rudo rwake runogara nokusingaperi.” 
\m Nokuti ndichadzosazve pfuma yenyika iyi sezvayaiva iri kare,’ ndizvo zvinotaura Jehovha. 
\p  
\v 12 “Zvanzi naJehovha Wamasimba Ose, ‘Munzvimbo ino, yakaparara uye isina vanhu kana mhuka, mumaguta ayo ose aripo muchava namafuro avafudzi okuvatisa makwai avo.  
\v 13 Mumaguta enyika yezvikomo, neemujinga mezvikomo zvokumavirira neokuNegevhi, munyika yaBhenjamini, nomumisha yakapoteredza Jerusarema nomumaguta eJudha, makwai achapfuurazve napasi poruoko rwounoaverenga,’ ndizvo zvinotaura Jehovha. 
\p  
\v 14 “ ‘Mazuva anouya,’ ndizvo zvinotaura Jehovha, andichazadzisa chivimbiso chenyasha chandakaita kuimba yaIsraeri nokuimba yaJudha. 
\q1  
\v 15 “ ‘Mumazuva iwayo uye nenguva iyoyo 
\q2 ndichameresa Davi rakarurama rinobva kurudzi rwaDhavhidhi; 
\q2 iye achatonga nyika nokururamisira uye nokururama. 
\q1  
\v 16 Mumazuva iwayo Judha achaponeswa, 
\q2 uye Jerusarema richagara rakachengetedzeka. 
\q1 Iri ndiro zita rarichatumidzwa: 
\q2 Jehovha Ndiye Kururama Kwedu.’ 
\m  
\v 17 Nokuti zvanzi naJehovha: ‘Dhavhidhi haangatongoshayiwi munhu angagara pachigaro choushe cheimba yaIsraeri,  
\v 18 Kana vaprista, vorudzi rwaRevhi, havangashayiwi munhu angamira pamberi pangu nguva dzose kuti apisire zvipiriso, apisire zvipiriso zvezviyo uye ape zvibayiro.’ ” 
\p  
\v 19 Shoko raJehovha rakasvika kuna Jeremia, richiti:  
\v 20 “Zvanzi naJehovha: ‘Kana mukagona kuputsa sungano yangu namasikati uye nesungano yangu nousiku, zvokuti masikati nousiku zvirege kuvapo nenguva yakatarwa,  
\v 21 ipapo sungano yangu naDhavhidhi muranda wangu, nesungano yangu navaRevhi avo vanova vaprista vanoshumira pamberi pangu, ingagona kuputsika uye Dhavhidhi haangazovizve nomwanakomana angatonga ari pachigaro chake choushe.  
\v 22 Ndichawanza vana vomuranda wangu Dhavhidhi navaRevhi vanoshumira pamberi pangu zvokusaverengeka senyeredzi dzedenga uye zvokusagona kuyerwa sejecha regungwa.’ ” 
\p  
\v 23 Shoko raJehovha rakasvika kuna Jeremia, richiti,  
\v 24 “Hauna kucherechedza here kuti vanhu ava vanoti, ‘Jehovha akaramba umambo hwose huri huviri hwaakanga asarudza’? Saka vari kushora vanhu vangu nokusavaona sorudzi.  
\v 25 Zvanzi naJehovha: ‘Kana ndikasasimbisa sungano yangu namasikati nousiku nemitemo yakatemwa yematenga napasi,  
\v 26 ipapo ndicharamba vana vaJakobho naDhavhidhi muranda wangu uye handingasarudzi mumwe wavanakomana vake kuti abate ushe pamusoro pavana vaAbhurahama, Isaka naJakobho. Nokuti ndichadzosa nhaka yavo uye ndichavanzwira tsitsi.’ ” 
\c 34  
\s1 Zedhekia anoyambirwa 
\p  
\v 1 Shoko iri rakasvika kuna Jeremia richibva kuna Jehovha, panguva iyo Nebhukadhinezari mambo weBhabhironi nehondo yake yose, noushe hwose hwapanyika hwaakanga akabata, navanhu vose vakanga vachirwa neJerusarema namaguta ose akanga akaripoteredza, richiti,  
\v 2 “Zvanzi naJehovha, Mwari waIsraeri: Enda kuna Zedhekia mambo weJudha umuudze kuti, ‘Zvanzi naJehovha: Ndava pedyo nokuisa guta rino muruoko rwamambo weBhabhironi, uye acharipisa.  
\v 3 Iwe haungapukunyuki muruoko rwake asi zvirokwazvo uchabatwa ugoiswa mumaoko ake. Uchaona mambo weBhabhironi nameso ako, uye achataura newe makatarisana. Uye iwe uchaenda kuBhabhironi. 
\p  
\v 4 “ ‘Asi chinzwa chivimbiso chaJehovha, iwe Zedhekia mambo weJudha. Zvanzi naJehovha pamusoro pako iwe: Haungafi nomunondo;  
\v 5 uchafa murunyararo. Vanhu sezvavakavesa moto pamariro vachiremekedza madzibaba ako, iwo madzimambo akare akakutangira, saizvozvo vachavesa moto vachikuremekedza vagochema vachiti, “Yowe-e, nhai tenzi!” Ndini pachangu ndavimbisa izvi, ndizvo zvinotaura Jehovha.’ ” 
\p  
\v 6 Ipapo muprofita Jeremia akataurira Zedhekia mambo weJudha zvose izvi, ari muJerusarema,  
\v 7 hondo yamambo weBhabhironi payakanga ichirwa neJerusarema namamwe maguta eJudha akanga achakashingirira, Rakishi neAzeka. Aya ndiwo chete maguta akanga asara muJudha akakomberedzwa namasvingo. 
\s1 Kusunungurwa kweNhapwa 
\p  
\v 8 Shoko rakasvika kuna Jeremia richibva kuna Jehovha mushure mokunge Mambo Zedhekia aita sungano navanhu vose vemuJerusarema kuti vadanidzire kusunungurwa kwenhapwa.  
\v 9 Mumwe nomumwe aifanira kusunungura varanda vake vechiHebheru, vose varume navakadzi; hakuna aifanira kurega hama yake yechiJudha iri pausungwa.  
\v 10 Saka machinda ose navanhu vose vakapinda pasungano iyi, vakatenderana ndokuvasunungura.  
\v 11 Asi mushure maizvozvo vakashandura pfungwa dzavo, vakadzosa nhapwa dzavakanga vasunungura ndokuvaita varanda zvakare. 
\p  
\v 12 Ipapo shoko raJehovha rakasvika kuna Jeremia, richiti,  
\v 13 “Zvanzi naJehovha, Mwari weIsraeri: Ndakaita sungano namadzitateguru enyu pandakavabudisa kubva muIjipiti, munyika youranda. Ndakati,  
\v 14 ‘Gore rechinomwe roga roga, mumwe nomumwe wenyu anofanira kusunungura hama ipi zvayo yechiHebheru yakazvitengesa kwaari. Mushure mokukushandira makore matanhatu, unofanira kumurega aende.’ Kunyange zvakadaro, madzibaba enyu haana kunditeerera kana kundirerekera nzeve dzavo.  
\v 15 Munguva shoma yakapfuura, makatendeuka mukaita zvakanaka pamberi pangu: Mumwe nomumwe wenyu akadanidzira rusununguko kuvanhu venyika yokwake. Makabva maita sungano pamberi pangu muimba inodanwa neZita rangu.  
\v 16 Asi zvino mashanduka ndokuzvidza zita rangu; mumwe nomumwe wenyu adzosa nhapwa dzavarume navakadzi vamakanga masunungura kuti vaende kwavaida. Mavamanikidza kuti vave nhapwa dzenyu zvakare. 
\p  
\v 17 “Naizvozvo zvanzi naJehovha: Hamuna kunditeerera; hamuna kudanidzira rusununguko kuvanhu venyika yokwenyu. Saka, zvino ini ndava kukudanidzirai rusununguko, ndizvo zvinotaura Jehovha, ‘rusununguko’ rwokufa nomunondo, nenzara uye nedenda. Ndichakuitai chinhu chinonyangadza kuushe hwose hwenyika.  
\v 18 Varume vakadarika sungano yangu uye vakasazadzisa zvakatemwa zvesungano yavakaita pamberi pangu, ndichavaita semhuru yavakagura kuita mapandi maviri vakafamba napakati pamapandi acho.  
\v 19 Vatungamiri veJudha neJerusarema, namachinda omuruvazhe, navaprista navanhu vose venyika vakafamba napakati pamapandi emhuru,  
\v 20 Ndichavaisa mumaoko avavengi vavo vanotsvaka kuvauraya. Zvitunha zvavo zvichava zvokudya zveshiri dzedenga nezvikara zvenyika. 
\p  
\v 21 “Ndichaisa Zedhekia mambo weJudha namachinda ake mumaoko avavengi vavo avo vanotsvaka kuvauraya, nomumaoko ehondo yamambo weBhabhironi, iyo yakabva kwamuri.  
\v 22 Ndicharayira, ndizvo zvinotaura Jehovha, uye ndichavadzosa kuguta rino. Vacharwa naro, vagorikunda, uye vagoripisa. Uye ndichaparadza maguta eJudha, zvokuti hakuna angagaramo.” 
\c 35  
\s1 VaRekabhi vanorumbidzwa 
\p  
\v 1 Iri ndiro shoko rakasvika kuna Jeremia richibva kuna Jehovha pamazuva okutonga kwaJehoyakimi, mwanakomana waJosia mambo weJudha, richiti,  
\v 2 “Enda kumhuri yavaRekabhi undovakoka kuti vauye mune rimwe kamuri raparutivi rweimba yaJehovha ugovapa waini vanwe.” 
\p  
\v 3 Saka ndakaenda ndikandotora Jaazania mwanakomana waJeremia, mwanakomana waHabhazinia, nehama dzake navakomana vake vose, mhuri yose yavaRekabhi.  
\v 4 Ndakavapinza mumba maJehovha, mukamuri ravanakomana vaHanani mwanakomana waIgidharia munhu waMwari. Yakanga iri pedyo nekamuri ramachinda, rakanga riri pamusoro peraMaaseya mwanakomana waSharumi, mutariri womukova.  
\v 5 Ipapo ndakagadzika hari dzizere newaini nemikombe pamberi pavarume vemhuri yavaRekabhi ndikati kwavari, “Inwai waini.” 
\p  
\v 6 Asi ivo vakapindura vakati, “Hatinwi waini, nokuti tateguru wedu Jonadhabhi mwanakomana waRekabhi akatipa murayiro uyu wokuti, ‘Imi kana vana venyu hamufaniri kunwa waini zvachose.  
\v 7 Zvakare, hamufaniri kutombovaka dzimba, kana kudyara mbeu kana kurima minda yemizambiringa; hamufaniri kuva nechimwe chezvinhu izvi, asi munofanira kugara mumatende nguva dzose. Ipapo muchararama mazuva akawanda munyika iyo yamuri vatorwa.’  
\v 8 Takateerera zvose zvatakarayirwa natateguru wedu Jonadhabhi mwanakomana waRekabhi. Hapana akambonwa waini, isu kana vakadzi vedu, kana vanakomana vedu, kana vanasikana vedu,  
\v 9 kana kuvaka dzimba dzokugara, kana kuva neminda yemizambiringa, kana minda, kana mbeu.  
\v 10 Takagara mumatende uye takanyatsoteerera zvose zvatakarayirwa natateguru wedu Jonadhabhi.  
\v 11 Asi Nebhukadhinezari mambo weBhabhironi akati apinda munyika ino, isu takati, ‘Uyai, tiende kuJerusarema titize hondo yavaBhabhironi neyavaAramu.’ Saka takaramba tiri muJerusarema.” 
\p  
\v 12 Ipapo shoko raJehovha rakasvika kuna Jeremia, richiti,  
\v 13 “Zvanzi naJehovha, Wamasimba Ose, Mwari waIsraeri: Enda unoudza varume veJudha navanhu veJerusarema kuti, ‘Hamudzidziwo chidzidzo here mugoteerera mashoko angu?’ ndizvo zvinotaura Jehovha.  
\v 14 ‘Jonadhabhi mwanakomana waRekabhi akarayira vanakomana vake kuti varege kunwa waini uye murayiro uyu wanga uchingochengetwa. Kusvikira zuva ranhasi havanwi waini, nokuti vanoteerera murayiro watateguru wavo. Asi ini ndakataura ndataurazve nemi, asi hamuna kunditeerera.  
\v 15 Ini ndakatuma ndatumazve kwamuri varanda vangu vose ivo vaprofita. Ivo vakati kwamuri, “Mumwe nomumwe wenyu anofanira kudzoka panzira dzakaipa dzake dzose mugonatsa zviito zvenyu; murege kutevera vamwe vamwari kuti muvashumire. Ipapo muchagara munyika yandakakupai imi namadzibaba enyu.” Asi hamuna kumborerekera nzeve dzenyu kwandiri kana kundinzwa.  
\v 16 Zvizvarwa zvaJonadhabhi mwanakomana waRekabhi vakachengeta murayiro wavakapiwa natateguru wavo, asi vanhu ava havana kunditeerera.’ 
\p  
\v 17 “Naizvozvo, zvanzi naJehovha Mwari Wamasimba Ose, Mwari weIsraeri: ‘Inzwai! Ndava kuuyisa pamusoro peJudha napamusoro pavose vagere muJerusarema njodzi dzose dzandakareva pamusoro pavo. Ndakataura kwavari, asi havana kuteerera; ndakavadana, asi havana kudavira.’ ” 
\p  
\v 18 Ipapo Jeremia akati kumhuri yavaRekabhi, “Zvanzi naJehovha Wamasimba Ose, Mwari waIsraeri: ‘Makateerera murayiro watateguru wenyu Jonadhabhi, mukatevera zvaakarayira zvose uye mukaita zvose zvaakatema.’  
\v 19 Naizvozvo, zvanzi naJehovha Wamasimba Ose, Mwari waIsraeri: ‘Jonadhabhi mwanakomana waRekabhi haangamboshayiwi munhu angandishumira.’ ” 
\c 36  
\s1 Jehoyakimi anopisa Gwaro raJeremia 
\p  
\v 1 Mugore rechina raJehoyakimi mwanakomana waJosia mambo weJudha, shoko iri rakauya kuna Jeremia richibva kuna Jehovha, richiti,  
\v 2 “Tora rugwaro rwakapetwa unyoremo mashoko ose andakataura kwauri pamusoro peIsraeri, napamusoro peJudha nedzimwe ndudzi dzose kubvira panguva yandakatanga kutaura kwauri panguva yokutonga kwaJosia kusvikira iye zvino.  
\v 3 Zvimwe vanhu veJudha vakanzwa pamusoro penjodzi imwe neimwe yandakaronga kuisa pamusoro pavo, vangadzoka mumwe nomumwe wavo kubva pazvakaipa zvake; ipapo ndichavakanganwira zvakaipa zvavo nechivi chavo.” 
\p  
\v 4 Saka Jeremia akadana Bharuki mwanakomana waNeria, naJeremia, paaimuverengera mashoko ose akanga ataurwa naJehovha kwaari, Bharuki ainge achianyora murugwaro rwakapetwa.  
\v 5 Ipapo Jeremia akataurira Bharuki kuti, “Ini ndakadziviswa, handigoni kuenda kutemberi yaJehovha.  
\v 6 Saka iwe enda kuimba yaJehovha pazuva rokutsanya undoverengera vanhu mashoko aJehovha awakanyora murugwaro rwakapetwa ini ndichikutaurira. Uverengere vanhu vose veJudha vanouya vachibva kumaguta avo.  
\v 7 Zvimwe vanganyengetera kuna Jehovha uye mumwe nomumwe wavo akadzoka kubva panzira dzake dzakaipa, nokuti kutsamwa nehasha dzakarehwa naJehovha pamusoro pavanhu ava kukuru.” 
\p  
\v 8 Bharuki mwanakomana waNeria akaita zvose zvaakataurirwa nomuprofita Jeremia kuti aite; akaverenga mashoko aJehovha kubva murugwaro rwakapetwa, ari patemberi yaJehovha.  
\v 9 Mumwedzi wepfumbamwe wegore rechishanu raJehoyakimi mwanakomana waJosia mambo weJudha, nguva yokutsanya pamberi paJehovha yakadanidzirwa kuvanhu vose muJerusarema navose vakanga vabva kumaguta eJudha.  
\v 10 Bharuki akaverengera vanhu vose mashoko aJeremia aiva murugwaro rwakapetwa, ari mumba maJehovha, mukamuri raGemaria mwanakomana waShafani munyori, raiva muruvazhe rwokumusoro pamuromo weSuo Idzva retemberi yaJehovha. 
\p  
\v 11 Mikaya mwanakomana waGemaria, mwanakomana waShafani, akati anzwa mashoko ose aJehovha aibva murugwaro rwakapetwa,  
\v 12 akaburuka akaenda kukamuri romunyori mumuzinda wamambo, makanga mugere machinda ose, aiti: Erishama munyori, Dheraya mwanakomana waShemaya, Erinatani mwanakomana waAkibhori, Gemaria mwanakomana waShafani, Zedhekia mwanakomana waHanania, nemamwe machinda ose.  
\v 13 Mushure mokunge Mikaya avaudza zvose zvaakanga anzwa Bharuki achiverengera vanhu kubva murugwaro rwakapetwa,  
\v 14 machinda ose akatuma Jehudhi mwanakomana waNetamia, mwanakomana waSheremia, mwanakomana waKushi, kundoti kuna Bharuki, “Tora rugwaro rwakapetwa rwawaverengera vanhu, ugouya kuno.” Saka Bharuki mwanakomana waNeria akaenda kwavari norugwaro rwakapetwa muruoko rwake.  
\v 15 Ivo vakati kwaari, “Tapota, gara pasi utiverengerewo.” 
\p Saka Bharuki akavaverengera.  
\v 16 Vakati vanzwa mashoko ose aya, vakatarisana vachitya ndokuti kuna Bharuki, “Tinofanira kuzivisa mashoko ose aya kuna mambo.”  
\v 17 Ipapo vakabvunza Bharuki, vakati, “Tiudze, wakanyora sei izvi zvose? Jeremia ndiye akakutaurira here?” 
\p  
\v 18 Bharuki akapindura akati, “Hongu, akanditaurira mashoko ose aya, ini ndikaanyora neingi murugwaro rwakapetwa.” 
\p  
\v 19 Ipapo machinda akati kuna Bharuki, “Iwe naJeremia endai munovanda. Ngakurege kuva nomunhu anoziva kwamunenge muri.” 
\p  
\v 20 Vakati vaisa rugwaro rwakapetwa mukamuri yomunyori Erishama, vakaenda kuna mambo muruvazhe ndokumuzivisa mashoko ose.  
\v 21 Mambo akatuma Jehudhi kundotora rugwaro rwakapetwa, Jehudhi ndokurutora mukamuri yaErishama munyori ndokuverengera mambo namachinda ose akanga amire parutivi rwake.  
\v 22 Wakanga uri mwedzi wepfumbamwe uye mambo akanga akagara muimba yakavakirwa nguva yechando, moto uchipfuta mumbaura yaiva pamberi pake.  
\v 23 Jehudhi aiti kana apedza kuverenga zvikamu zvitatu kana zvina zvorugwaro rwakapetwa, mambo aibva azvicheka nebanga ozvikanda mumbaura, kusvikira gwaro rose rapiswa mumoto.  
\v 24 Mambo navaranda vake vose vakanzwa mashoko aya ose havana kumboratidza kutya, kana kubvarura nguo dzavo.  
\v 25 Kunyange hazvo Erinatani, Dheraya, naGemaria vakakurudzira mambo kuti arege kupisa rugwaro rwakapetwa haana kuda kuvanzwa.  
\v 26 Pachinzvimbo chezvo, mambo akarayira Jerameeri, mwanakomana wamambo, naSeraya mwanakomana waAzirieri naSheremia mwanakomana waAbhudhieri kuti asunge Bharuki munyori naJeremia muprofita. Asi Jehovha akanga avaviga. 
\p  
\v 27 Mambo akati apisa rugwaro rwakapetwa rwaiva namashoko akanga anyorwa naBharuki achitaurirwa naJeremia, shoko raJehovha rakasvika kuna Jeremia, richiti,  
\v 28 “Tora rumwe rugwaro rwakapetwa unyore pamusoro parwo mashoko ose akanga ari parugwaro rwokutanga rwuya rwakapiswa naJehoyakimi mambo weJudha.  
\v 29 Uyezve uudze Jehoyakimi mambo weJudha, kuti, ‘Zvanzi naJehovha: Wakapisa rugwaro rwuya uchiti, “Wakanyorerei parwuri uchiti zvirokwazvo mambo weBhabhironi achauya kuzoparadza nyika ino nokuparadza zvose vanhu nezvipfuwo?”  
\v 30 Naizvozvo, zvanzi naJehovha pamusoro paJehoyakimi mambo weJudha: Haangawani mumwe achagara pachigaro choushe chaDhavhidhi; mutumbi wake uchakandwa kunze kunopisa masikati uye kune chando usiku.  
\v 31 Ndichamuranga navana vake uye navaranda vake nokuda kwezvakaipa zvavo; ndichauyisa pamusoro pavo navose vanogara muJerusarema navanhu veJudha njodzi imwe neimwe yandakareva pamusoro pavo, nokuti havana kuteerera.’ ” 
\p  
\v 32 Saka Jeremia akatora rumwe rugwaro rwakapetwa ndokurupa kuna Bharuki munyori, mwanakomana waNeria, Bharuki ndokunyora pamusoro parwo mashoko ose orugwaro rwakanga rwapiswa naJehoyakimi, mambo weJudha, Jeremia achimutaurira. Mashoko akawanda akafanana nawo akawedzerwa. 
\c 37  
\s1 Jeremia anopfigirwa muTorongo 
\p  
\v 1 Zedhekia mwanakomana waJosia akagadzwa kuva mambo weJudha naNebhukadhinezari mambo weBhabhironi; iye akabata ushe panzvimbo yaJehoyakini mwanakomana waJehoyakimi.  
\v 2 Asi iye kana varanda vake kana vanhu venyika iyoyo, havana kuteerera mashoko akanga ataurwa naJehovha kubudikidza naJeremia muprofita. 
\p  
\v 3 Kunyange zvakadaro, mambo Zedhekia akatuma Jehukari mwanakomana waSheremia, nomuprista Zefania mwanakomana waMaaseya kuna Jeremia muprofita namashoko aya: “Ndapota tinyengetererewo kuna Jehovha Mwari wedu.” 
\p  
\v 4 Zvino Jeremia akanga akasununguka kupinda nokubuda pakati pavanhu, nokuti akanga asati apfigirwa mutorongo.  
\v 5 Hondo yaFaro yakanga yauya ichibva kuIjipiti, zvino vaBhabhironi vakanga vakakomba Jerusarema vakati vanzwa shoko pamusoro pavo, vakabva paJerusarema. 
\p  
\v 6 Ipapo shoko raJehovha rakasvika kuna Jeremia muprofita, richiti,  
\v 7 “Zvanzi naJehovha, Mwari weIsraeri: Udza mambo weJudha, iye akakutuma kuzondibvunza, kuti, ‘Hondo yaFaro yakauya kuzokubatsirai, ichadzokera kuIjipiti kunyika yavo.  
\v 8 Ipapo vaBhabhironi vachadzokazve vagorwisa guta rino; vacharikunda uye vacharipisa nomoto.’ 
\p  
\v 9 “Zvanzi naJehovha: Musazvinyengera muchifunga kuti, ‘Zvirokwazvo vaBhabhironi vachabva kwatiri.’ Kwete, havangabvi!  
\v 10 Kunyange dai mungakunda hondo yose yavaBhabhironi iri kukurwisai uye kugosara vakakuvara bedzi mumatende, ivavo vachauya vagopisa guta rino.” 
\p  
\v 11 Shure kwokubva kwehondo yavaBhabhironi muJerusarema nokuda kwehondo yaFaro,  
\v 12 Jeremia akatanga kubuda muguta kuti aende kunyika yeBhenjamini kundotora mugove wake wenhaka pakati pavanhu ikoko.  
\v 13 Asi akati asvika paSuo raBhenjamini, mukuru wavarindi, ainzi Irija mwanakomana waSheremia, mwanakomana waHanania, akamusunga ndokuti, “Iwe wava kutiza uchienda kuvaBhabhironi!” 
\p  
\v 14 Jeremia akati, “Handizvo, kwete! Handizi kutiza ndichienda kuvaBhabhironi!” Asi Irija haana kuda kumunzwa; asi akasunga Jeremia ndokumuendesa kumachinda.  
\v 15 Ivo vakatsamwira Jeremia vakaita kuti arohwe uye kuti aiswe mutorongo mumba maJonatani munyori, yavakanga vaita torongo. 
\p  
\v 16 Jeremia akaiswa mutorongo romugomba, umo maakagara nguva yakareba.  
\v 17 Ipapo mambo Zedhekia akatuma nhume kundomutora akaita kuti aiswe kumuzinda, kwaakamubvunza pakavanda, achiti, “Pane shoko rabva kuna Jehovha here?” 
\p Jeremia akapindura akati, “Hongu, muchaiswa muruoko rwamambo weBhabhironi.” 
\p  
\v 18 Ipapo Jeremia akati kuna Mambo Zedhekia, “Mhaka yandakapara nemi kana machinda enyu kana navanhu ava, ndeyeiko kuti mundipfigire mutorongo?  
\v 19 Varipiko vaprofita venyu vakakuprofitirai vachiti, ‘Mambo weBhabhironi haazi kuzokurwisai kana kurwisa nyika ino’?  
\v 20 Asi zvino ishe wangu mambo, ndapota inzwai. Regai ndisvitse kwamuri chikumbiro changu: Musandidzoserazve kumba kwaJonatani munyori nokuti ndingafirako.” 
\p  
\v 21 Ipapo mambo Zedhekia akarayira kuti Jeremia aiswe muruvazhe rwavarindi uye kuti apiwe chingwa chaibva mumugwagwa wavabiki zuva rimwe nerimwe kusvikira musisina chingwa muguta. Saka Jeremia akaramba ari muruvazhe rwavarindi. 
\c 38  
\s1 Jeremia anokandwa muGomba 
\p  
\v 1 Shefania mwanakomana waMatani naGedharia mwanakomana waPashuri mwanakomana waMarikiya vakanzwa zvaitaurwa naJeremia kuvanhu vose paakati,  
\v 2 “Zvanzi naJehovha: ‘Ani naani achagara muguta rino achafa nomunondo, nenzara kana denda, asi ani naani achazvipira kuvaBhabhironi achararama. Achatiza noupenyu hwake; achararama.’  
\v 3 Zvakare, zvanzi naJehovha: ‘Zvirokwazvo guta rino richaiswa mumaoko ehondo yamambo weBhabhironi, ndiye acharikunda.’ ” 
\p  
\v 4 Ipapo machinda akati kuna mambo, “Munhu uyu anofanira kufa. Ari kuodza mwoyo yavarwi vakasara muguta rino, pamwe chete navanhu vose, nezvinhu zvaanotaura kwavari. Uyu munhu haatsvaki zvakanakira vanhu ava asi kuparadzwa kwavo.” 
\p  
\v 5 Mambo Zedhekia akapindura akati, “Ari mumaoko enyu, Mambo haana zvaangagona kupikisana nemi.” 
\p  
\v 6 Saka vakatora Jeremia vakamuisa mugomba raMarikiya, mwanakomana wamambo, rakanga riri muruvazhe rwavarindi. Vakaburutsira Jeremia mugomba netambo: rakanga risina mvura mariri, asi madhaka bedzi, nokudaro Jeremia akanyura mumadhaka. 
\p  
\v 7 Asi Ebhedhi-Mereki muEtiopia aiva muchinda mumuzinda woushe, akazvinzwa kuti vakanga vaisa Jeremia mugomba. Panguva yakanga yakagara mambo paSuo raBhenjamini,  
\v 8 Ebhedhi-Mereki akabuda mumuzinda woushe akati kwaari, “Ishe wangu mambo, varume ava vaita zvakaipa kwazvo pane zvose zvavaita kumuprofita Jeremia.  
\v 9 Vamukanda mugomba umo maachaziya nenzara akafa kana chingwa chapera muguta.” 
\p  
\v 10 Ipapo mambo akarayira Ebhedhi-Mereki muEtiopia, akati, “Tora varume makumi matatu pano uende navo munobudisa muprofita Jeremia mugomba asati afa.” 
\p  
\v 11 Saka Ebhedhi-Mereki akatora varume akaenda navo kumba yaiva pasi pechivigiro chepfuma mumuzinda wamambo. Akatorawo mamvemve nenguo tsaru kubva ipapo ndokuzvidzikisa pasi netambo kuna Jeremia mugomba.  
\v 12 Ebhedhi-Mereki muEtiopia akati kuna Jeremia, “Isa mamvemve nenguo dzakasakara idzi muhapwa dzako kuti zviputire tambo.” Jeremia akaita saizvozvo,  
\v 13 ndokubva vamukweva netambo ndokumubudisa kubva mugomba. Nokudaro Jeremia akaramba ari paruvazhe rwavarindi. 
\s1 Zedhekia anobvunzazve Jeremia 
\p  
\v 14 Ipapo mambo Zedhekia akatuma nhume akauyisa muprofita Jeremia pamukova wechitatu wokupinda patemberi yaJehovha. Mambo akati kuna Jeremia, “Ndinoda kukubvunza chimwe chinhu. Usandivanzira chinhu.” 
\p  
\v 15 Jeremia akati kuna Zedhekia, “Kana ndikakupai mhinduro, hamuzondiurayi here? Kunyange ndikakupai zano, hamunganditeereri.” 
\p  
\v 16 Asi mambo Zedhekia akapikira Jeremia mhiko iyi pakavanda achiti, “Zvirokwazvo naJehovha mupenyu, iye akatipa mweya watinofema, handingakuurayi kana kukuisa mumaoko eavo vanotsvaka kukuuraya.” 
\p  
\v 17 Ipapo Jeremia akati kuna Zedhekia, “Zvanzi naJehovha Mwari Wamasimba Ose, Mwari waIsraeri: ‘Kana ukazvipira kuvaranda vamambo weBhabhironi, upenyu hwenyu hucharwirwa uye guta rino haringapiswi; imi nemhuri muchararama.  
\v 18 Asi kana mukaramba kuzvipira kuvaranda vamambo weBhabhironi, guta rino richaiswa mumaoko avaBhabhironi uye vacharipisa; nemi pachenyu hamungapukunyuki pamaoko avo.’ ” 
\p  
\v 19 Mambo Zedhekia akati kuna Jeremia, “Ndinotya vaJudha vakaenda kuvaBhabhironi, kuti vaBhabhironi vangangondiisa mumaoko avo vakandiitira zvakaipa.” 
\p  
\v 20 Jeremia akati kwaari, “Havangakuisiyi kwavari. Teererai Jehovha nokuita zvandakuudzai. Ipapo zvichakunakirai imi, uye upenyu hwenyu huchararamiswa.  
\v 21 Asi kana mukaramba kuzvipira, hezvino zvandakaratidzwa naJehovha.  
\v 22 Vakadzi vose vakasara mumuzinda wamambo weJudha vachabudiswa vachiendeswa kumachinda amambo weBhabhironi. Vakadzi ivavo vachati kwamuri: 
\q1 “ ‘Vakakutsausai uye vakakukundai, 
\q2 ivo shamwari dzamaivimba nadzo. 
\q1 Tsoka dzenyu dzanyura mumadhaka; 
\q2 shamwari dzenyu dzakakutizai.’ 
\p  
\v 23 “Vakadzi venyu vose navana vachabudiswa vachiendeswa kuvaBhabhironi. Nemi pachenyu hamungapukunyuki mumaoko avo, asi muchabatwa namambo weBhabhironi; uye guta rino richapiswa.” 
\p  
\v 24 Ipapo Zedhekia akati kuna Jeremia, “Ngakurege kuva nomunhu anoziva zvatakurukura izvi nokuti ungafa.  
\v 25 Kana machinda akanzwa kuti ndakataura newe, vakauya kwauri vachiti, ‘Tiudze zvawataura kuna mambo uye zvarehwa namambo kwauri; usativanzira kuti tirege kukuuraya,’  
\v 26 ipapo uvaudze kuti, ‘Ndanga ndichikumbira kuna mambo kuti arege kundidzoserazve kuimba yaJonatani kuti ndinofirako.’ ” 
\p  
\v 27 Machinda ose akauya kuna Jeremia ndokumubvunza, iye akavaudza zvinhu zvose zvaakanga arayirwa namambo kuti ataure. Naizvozvo vakarega kutaura naye zvakare, nokuti hapana akanga anzwa zvaakanga akurukura namambo. 
\p  
\v 28 Naizvozvo Jeremia akaramba ari muruvazhe rwavarindi kusvikira pazuva rakapambwa Jerusarema. 
\c 39  
\s1 Kuwa kweJerusarema 
\p  
\v 1 Uku ndiko kutorwa kwakaitwa Jerusarema: Mugore repfumbamwe ramambo Zedhekia mambo weJudha, mumwedzi wegumi, Nebhukadhinezari mambo weBhabhironi akauya kuzorwisa Jerusarema nehondo yake yose uye akarikomba.  
\v 2 Zvino mugore regumi nerimwe raZedhekia, pazuva repfumbamwe romwedzi wechina, masvingo eguta akakoromorwa.  
\v 3 Ipapo machinda ose amambo weBhabhironi akauya ndokugara paSuo Rapakati, vaiti: Nerigari-Sharezeri weSamugari naNebho-Saresekimi mukuru wavaranda vamambo weBhabhironi, naNerigari-Sharezeri mukuru aiva nechinzvimbo chapamusoro, namamwe machinda ose amambo weBhabhironi.  
\v 4 Zedhekia mambo weJudha navarwi vose vakati vavaona, vakatiza; vakabuda muguta usiku vakaenda nenzira yokubindu ramambo, napasuo raiva pakati pamasvingo maviri, ndokunanga kuArabha. 
\p  
\v 5 Asi hondo yavaBhabhironi yakavadzinganisa ndokubatira Zedhekia mumapani eJeriko. Vakamubata ndokumuendesa kuna Nebhukadhinezari mambo weBhabhironi paRibhira munyika yeHamati kwaakamupa mutongo wake.  
\v 6 Ipapo paRibhira Mambo weBhabhironi akauraya vanakomana vaZedhekia pamberi pake uye akaurayawo makurukota ose eJudha.  
\v 7 Ipapo akatumbura meso aZedhekia ndokumusunga nengetani kuti aende naye kuBhabhironi. 
\p  
\v 8 VaBhabhironi vakapisa muzinda wamambo nedzimba dzavanhu vakakoromora masvingo eJerusarema.  
\v 9 Nebhuzaradhani mukuru wehondo yavarindi akaendesa kuBhabhironi vanhu vakanga vasara muguta pamwe chete navaya vakanga vazvipira kwaari uye noruzhinji rwavanhu.  
\v 10 Asi Nebhuzaradhani mukuru wavarindi akasiya munyika yeJudha vamwe varombo vakanga vasina chinhu; uye panguva iyoyo akavapa minda yemizambiringa nemimwe minda. 
\p  
\v 11 Zvino Nebhukadhinezari mambo weBhabhironi akanga arayira izvi pamusoro paJeremia kubudikidza naNebhuzaradhani mukuru wavarindi, achiti,  
\v 12 “Mutorei mumuchengete; musamuitira zvakaipa asi mumuitire zvose zvaanokumbira.”  
\v 13 Saka Nebhuzaradhani mukuru wavarindi, naNebhushazibhani mukuru wavaranda, naNerigari-Sharezeri aiva mukuru wenʼanga namamwe machinda ose amambo weBhabhironi  
\v 14 vakatumira nhume kuti Jeremia abviswe paruvazhe rwavarindi. Vakamuendesa kuna Gedharia mwanakomana waAhikami, mwanakomana waShafani, kuti vamudzosere kumusha kwake. Saka akaramba agere pakati pavanhu vokwake. 
\p  
\v 15 Shoko raJehovha rakasvika kuna Jeremia achakapfigirwa muruvazhe rwavarindi, richiti,  
\v 16 “Enda undoudza Ebhedhi-Mereki muEtiopia kuti, ‘Zvanzi naJehovha Wamasimba Ose, Mwari waIsraeri: Ndava pedyo kuzadzisa mashoko angu pamusoro peguta rino nenjodzi, kwete kubudirira. Panguva iyoyo zvichazadzisika pamberi pako.  
\v 17 Asi iwe ndichakurwira pazuva iro, ndizvo zvinotaura Jehovha, haungaiswi mumaoko evaunotya.  
\v 18 Ndichakuponesa; haungaurayiwi nomunondo asi uchatiza noupenyu hwako, nokuti unovimba neni, ndizvo zvinotaura Jehovha.’ ” 
\c 40  
\s1 Jeremia anosunungurwa 
\p  
\v 1 Shoko rakasvika kuna Jeremia richibva kuna Jehovha mushure mokusunungurwa kwake paRama naNebhuzaradhani mukuru wavarindi. Akanga awana Jeremia akasungwa nengetani ari pakati pavatapwa vose vaibva kuJerusarema neJudha avo vakanga vachiendeswa kuutapwa kuBhabhironi.  
\v 2 Mukuru wavarindi akati awana Jeremia, akati kwaari, “Jehovha Mwari wako akatenda kuti njodzi iyi iwire nzvimbo ino.  
\v 3 Zvino Jehovha aita kuti zviitike, aita sezvaakareva kuti achaita. Izvi zvose zvakaitika nokuti imi vanhu makatadzira Jehovha uye hamuna kumuteerera.  
\v 4 Asi nhasi ndinokusunungura kubva pangetani dziri mumaoko ako. Uya tiende tose kuBhabhironi, kana uchida, ini ndichakuchengeta; asi kana usingadi, usauya. Tarira, nyika yose iri pamberi pako; enda hako kwose kwaunoda.”  
\v 5 Kunyange zvakadaro hazvo, Jeremia asati atendeuka kuti aende, Nebhuzaradhani akaenderera mberi achiti, “Dzokera kuna Gedharia mwanakomana waAhikami, mwanakomana waShafani uyo akagadzwa namambo weBhabhironi kuti ave mubati wemaguta eJudha, undogara naye pakati pavanhu, kana kuti woenda kwose kwaunoda.” 
\p Ipapo mukuru wavarindi akamupa zvokudya zvokutakura nezvipo akamurega achienda.  
\v 6 Saka Jeremia akaenda kuna Gedharia mwanakomana waAhikami paMizipa akandogara naye pakati pavanhu vakanga vasara munyika. 
\s1 Gedharia anourayiwa 
\p  
\v 7 Vakuru vehondo navanhu vakanga vachigara mumasango enyika vakati vanzwa kuti mambo weBhabhironi akanga agadza Gedharia mwanakomana waAhikami kuti ave mubati wenyika uye kuti mambo akanga amuita mutariri wavarume, vakadzi navana, avo vakanga vari varombo zvakanyanya munyika uye vakanga vasina kuendeswa pautapwa kuBhabhironi,  
\v 8 vakauya kuna Gedharia paMizipa, Ishumaeri mwanakomana waNetania, Johanani naJonatani vanakomana vaKarea, naSeraya mwanakomana waTanhumeti, mwanakomana waEfai muNetofati, naJaazania mwanakomana womuMaakati, ivo navanhu vavo.  
\v 9 Gedharia mwanakomana waAhikami, mwanakomana waShafani, akapika mhiko yokuvasimbisa ivo navanhu vavo achiti, “Musatya kushandira vaBhabhironi. Garai henyu munyika mushandire mambo weBhabhironi, zvigokuitirai zvakanaka.  
\v 10 Ini pachangu ndichagara paMizipa kuti ndikumirirei pamberi pavaBhabhironi vanouya kwatiri, asi imi munofanira kukohwa waini, nezvibereko zvezhizha namafuta mugozviisa mumidziyo yenyu, mugogara mumaguta amakakunda.” 
\p  
\v 11 VaJudha vose vaiva muMoabhu, muAmoni, nevemuEdhomu nedzimwe nyika dzose vakati vanzwa kuti mambo weBhabhironi akanga asiya vamwe vanhu muJudha uye kuti akanga agadza Gedharia mwanakomana waAhikami, mwanakomana waShafani, somubati pamusoro pavo,  
\v 12 vose vakadzoka kunyika yeJudha, kuna Gedharia paMizipa, vachibva kunyika dzose kwavakanga vakaparadzirwa. Uye vakakohwa waini yakawanda nezvibereko zvezhizha zvizhinji kwazvo. 
\p  
\v 13 Johanani mwanakomana waKarea navakuru vose vehondo vakanga vachiri kumasango vakauya kuna Gedharia paMizipa.  
\v 14 Vakati kwaari, “Hauzivi here kuti Bhaarisi mambo wavaAmoni atuma Ishumaeri mwanakomana waNetania kuti azokuuraya?” Asi Gedharia mwanakomana waAhikami haana kuvatenda. 
\p  
\v 15 Ipapo Johanani mwanakomana waKarea akati kuna Gedharia muchivande vari paMizipa, “Rega ndinouraya Ishumaeri mwanakomana waNetania, uye hapana achazviziva. Anodirei kukuuraya nokuita kuti vaJudha vose vakaungana, vakakupoteredza, vaparadzirwe uye vakasara veJudha vaparare?” 
\p  
\v 16 Asi Gedharia mwanakomana waAhikami akati kuna Johanani mwanakomana waKarea, “Usaita chinhu chakadaro! Zvauri kutaura pamusoro paIshumaeri hazvisi zvechokwadi.” 
\c 41  
\p  
\v 1 Mumwedzi wechinomwe, Ishumaeri mwanakomana waNetania, mwanakomana waErishama, uyo akanga ari worudzi rwamambo, uye akanga ari mumwe wamachinda amambo, akauya ane varume gumi kuna Gedharia mwanakomana waAhikami, paMizipa. Vachiri kudya pamwe chete ipapo,  
\v 2 Ishumaeri mwanakomana waNetania navarume gumi vakanga vanaye vakasimuka vakabaya Gedharia mwanakomana waAhikami, mwanakomana waShafani, nomunondo, vakamuuraya iye akanga agadzwa namambo weBhabhironi kuti ave mubati wenyika iyo.  
\v 3 Ishumaeri akaurayawo vaJudha vose vaiva naGedharia paMizipa, pamwe chete navarwi veBhabhironi vaivapo. 
\p  
\v 4 Zuva rakatevera kuurayiwa kwaGedharia, pasati pava nomunhu aizviziva,  
\v 5 varume makumi masere vaibva kuShekemu, neShiro neSamaria vakasvikapo vakaveura ndebvu dzavo, vakabvarura nguo dzavo uye vakazvicheka-cheka, vachiuya nezvipiriso zvezviyo nezvinonhuhwira kuimba yaJehovha.  
\v 6 Ishumaeri mwanakomana waNetania akabuda paMizipa kuti andovachingamidza, akafamba achichema. Paakasangana navo, akati kwavari, “Uyai kuna Gedharia mwanakomana waAhikami.”  
\v 7 Vakati vapinda muguta, Ishumaeri mwanakomana waNetania navarume vakanga vanaye vakavauraya ndokuvakanda mugomba.  
\v 8 Asi vamwe vavo gumi vakati kuna Ishumaeri, “Musatiuraya! Isu tine gorosi nebhari, namafuta uye nouchi, zvakavigwa musango.” Naizvozvo akavarega akasavauraya pamwe chete navamwe.  
\v 9 Zvino gomba raakakandira mitumbi yose yavarume vaakanga auraya pamwe chete naGedharia ndiro rakanga racherwa naMambo Asa kuti azvidzivirire kubva kuna Bhaasha mambo weIsraeri. Ishumaeri mwanakomana waNetania akarizadza navakaurayiwa. 
\p  
\v 10 Ishumaeri akatapa vanhu vose vakanga vari paMizipa, vanasikana vamambo pamwe chete navamwe vose vakanga vasara ikoko, vaiswa naNebhuzaradhani mukuru wavarindi pasi paGedharia mwanakomana waAhikami. Ishumaeri mwanakomana waNetania akavatapa ndokubvapo achida kuti ayambukire kuvaAmoni. 
\p  
\v 11 Johanani mwanakomana waKarea namachinda ose ehondo vaiva naye vakati vanzwa pamusoro pemhaka dzose dzakanga dzaparwa naIshumaeri mwanakomana waNetania,  
\v 12 vakatora varume vose ndokuenda kundorwa naIshumaeri mwanakomana waNetania. Vakanomubatira pedyo nedziva guru reGibheoni.  
\v 13 Vanhu vose vaiva naIshumaeri vakati vachiona Johanani mwanakomana waKarea navakuru vehondo vakanga vainaye, vakafara.  
\v 14 Vanhu vose vakanga vatapwa naIshumaeri paMizipa vakadzoka vakaenda kuna Johanani mwanakomana waKarea.  
\v 15 Asi Ishumaeri mwanakomana waNetania navarume vasere vakapunyuka kubva kuna Johanani vakatizira kuvaAmoni. 
\s1 Kutizira kuIjipiti 
\p  
\v 16 Ipapo Johanani mwanakomana waKarea navakuru vose vehondo vaiva naye vakatungamirira vose vakasara kubva paMizipa avo vaakanga anunura kubva kuna Ishumaeri mwanakomana waNetania shure kwokunge auraya Gedharia mwanakomana waAhikami, vaiti: varwi, vakadzi, vana namachinda edare vaakanga abva navo kuGibheoni.  
\v 17 Vakaenderera mberi ndokunomira vava paGeruti Kimihami pedyo neBheterehema parwendo rwavo rwokuenda kuIjipiti  
\v 18 kuti vatize vaBhabhironi. Vakanga vachitya nokuti Ishumaeri mwanakomana waNetania akanga auraya Gedharia mwanakomana waAhikami, uyo akanga agadzwa kuti ave mubati wenyika iyo namambo weBhabhironi. 
\c 42  
\p  
\v 1 Ipapo vakuru vose vehondo, pamwe chete naJohanani mwanakomana waKarea naJezania mwanakomana waHoshaya, navanhu vose kubva kuvaduku kusvikira kuvakuru vakasvika  
\v 2 kuna Jeremia muprofita vakati kwaari, “Tapota inzwai chikumbiro chedu mutinyengeterere kuna Jehovha Mwari wenyu nokuda kwavose ava vakasara. Nokuti sezvamunoona zvino, kuti kunyange taiva vazhinji, iye zvino kwangosara vashoma chete.  
\v 3 Nyengeterai kuti Jehovha Mwari wenyu atiudze kwatinofanira kuenda uye zvatinofanira kuita.” 
\p  
\v 4 Jeremia muprofita akapindura achiti, “Ndakunzwai. Zvirokwazvo ndichakunyengetererai kuna Jehovha Mwari wenyu sezvamakumbira, ndichakuzivisai zvinhu zvose zvicharehwa naJehovha uye handingambokuvanzirai chinhu.” 
\p  
\v 5 Ipapo vakati kuna Jeremia, “Jehovha ngaave chapupu chezvokwadi uye chakatendeka pamusoro pedu kana tisingaiti zvose zvamunenge matumwa naJehovha kuzotiudza.  
\v 6 Kana zvakanaka, kana zvisina kunaka tichateerera Jehovha Mwari wedu, watinokutumai kwaari kuti zvigotiitira zvakanaka, nokuti tichateerera Jehovha Mwari wedu.” 
\p  
\v 7 Mazuva gumi akati apera, shoko raJehovha rakasvika kuna Jeremia.  
\v 8 Naizvozvo akaunganidza Johanani mwanakomana waKarea navakuru vose vehondo vaaiva navo navanhu vose kubva kuvaduku kusvikira kuvakuru.  
\v 9 Akati kwavari, “Zvanzi naJehovha, Mwari waIsraeri, iye wamakanditumira kwaari kuti ndisvitse chikumbiro chenyu:  
\v 10 ‘Kana mukagara munyika ino, ndichakuvakai handizokukoromorei; ndichakusimai uye handingakudzurei, nokuti ndinorwadziwa nokuda kwenjodzi yandakaisa pamusoro penyu.  
\v 11 Musatya mambo weBhabhironi, iye wamunotya zvino. Musamutya, ndizvo zvinotaura Jehovha, nokuti ndinemi uye ndichakuponesai nokukuponesai kubva mumaoko ake.  
\v 12 Ndichakunzwirai tsitsi kuitira kuti agokunzwirai tsitsi, agokudzoserai kunyika yenyu.’ 
\p  
\v 13 “Kunyange zvakadaro, kana mukati, ‘Hatidi kugara munyika ino,’ nokudaro musingateerere Jehovha Mwari wenyu,  
\v 14 uye kana mukati, ‘Kwete tichaenda kundogara kuIjipiti, kwatisingazooni hondo kana kunzwa hwamanda kana kunzwa nzara yechingwa,’  
\v 15 zvino chinzwai shoko raJehovha imi vakasara vaJudha. Zvanzi naJehovha Wamasimba Ose, Mwari waIsraeri, ‘Kana mashinga kuenda kuIjipiti kana mukaenda kundogarako,  
\v 16 ipapo munondo wamunotya uchakukundai ikoko uye nenzara yamunotya ichakuteverai kuIjipiti, uye muchafira ikoko.  
\v 17 Zvirokwazvo, vose vashinga kuenda kuIjipiti kundogarako vachafa nomunondo, nenzara uye nedenda; hakuna achasara pakati pavo kana kupukunyuka njodzi yandichauyisa pamusoro pavo.’  
\v 18 Zvanzi naJehovha Wamasimba Ose, Mwari waIsraeri, ‘Sokudururwa kwakaitwa hasha dzangu nokutsamwa kwangu pamusoro peavo vaigara muJerusarema, saizvozvo kutsamwa kwangu kuchadururirwa pamusoro penyu kana maenda kuIjipiti. Muchava chinhu chinotukwa nechinosemwa, nechinomhurwa, nokuzvidzwa; hamuchazombooni nzvimbo ino zvakare.’ 
\p  
\v 19 “Haiwa imi vakasara veJudha, Jehovha akuudzai kuti, ‘Musaenda kuIjipiti.’ Ivai nechokwadi: ndinokuyambirai nhasi  
\v 20 kuti makakanganisa kwazvo pamakandituma kuna Jehovha Mwari wenyu muchiti, ‘Tinyengeterere kuna Jehovha Mwari wedu, utiudze zvose zvaanoreva uye isu tichazviita.’  
\v 21 Ndakuudzai nhasi, asi kunyange zvakadaro hamuna kuteerera Jehovha Mwari wenyu pane zvose zvaakandituma kuzokuzivisai imi.  
\v 22 Saka zvino, ivai nechokwadi nezvizvi: Muchafa nomunondo, nenzara, uye nedenda kunzvimbo yamunoda kuenda kundogara.” 
\c 43  
\p  
\v 1 Jeremia akati apedza kuudza vanhu mashoko ose aJehovha Mwari wavo, zvose zvaakanga atumwa naJehovha kuti avaudze,  
\v 2 Azaria mwanakomana waHoshaya naJohanani mwanakomana waKarea navarume vose vaizvikudza vakati kuna Jeremia, “Unoreva nhema iwe! Jehovha Mwari wedu haana kukutuma kuti uzoti, ‘Hamufaniri kuenda kuIjipiti kundogara ikoko.’  
\v 3 Asi Bharuki mwanakomana waNeria ndiye anokukurudzirai pamusoro pedu kuti tiendeswe kuvaBhabhironi, kuti vagotiuraya kana kutitora vachitiendesa kuBhabhironi.” 
\p  
\v 4 Naizvozvo Johanani mwanakomana waKarea navakuru vose vehondo navanhu vose havana kuteerera murayiro waJehovha kuti vagare munyika yeJudha.  
\v 5 Panzvimbo paizvozvo Johanani mwanakomana waKarea navakuru vose vehondo vakatora vakasara vose veJudha vakanga vadzoka kuzogara munyika yeJudha kubva kundudzi dzose kwavakanga vaparadzirwa.  
\v 6 Vakatorawo varume vose, vakadzi navana navanasikana vamambo vakanga vasiyiwa naNebhuzaradhani mukuru wavarindi vamambo kuna Gedharia mwanakomana waShafani, naJeremia muprofita uye naBharuki mwanakomana waNeria.  
\v 7 Saka vakapinda muIjipiti vasingateereri Jehovha vakaenda zvokutosvika kuTapanesi. 
\p  
\v 8 Vari paTapanesi, shoko raJehovha rakasvika kuna Jeremia, richiti,  
\v 9 “Tora mabwe makuru uavige mudhaka pakati pezvitinha panopindwa napo kumuzinda waFaro uri paTapanesi, vaJudha vakatarisa.  
\v 10 Ipapo uti kwavari, ‘Zvanzi naJehovha Wamasimba Ose, Mwari waIsraeri: Ndichatuma shoko kumuranda wangu Nebhukadhinezari mambo weBhabhironi, uye ndichaisa chigaro chake choushe pamusoro pamabwe aya andaviga pano; achatambanudza denga rake roushe pamusoro pawo.  
\v 11 Achauya agorwisa Ijipiti, achivigira rufu kuna avo vakatongerwa rufu, kutapwa kuna vakatongerwa utapwa, nomunondo kuna avo vakatongerwa munondo.  
\v 12 Achapisa temberi dzavamwari veIjipiti; achapisa temberi dzavo agotapa vamwari vavo. Sokumonera kunoita mufudzi nguo yake, saizvozvo achamonera nyika yeIjipiti agobvako asina vanga.  
\v 13 Imomo, mutemberi yezuva iri muIjipiti, achaputsa mbiru dzinoera uye achapisa temberi dzavamwari veIjipiti.’ ” 
\c 44  
\s1 Njodzi nokuda kwoKunamata Zvifananidzo 
\p  
\v 1 Shoko iri rakasvika kuna Jeremia pamusoro pavaJudha vose vakanga vagere zasi kweIjipiti, muMigidhori nomuTapanesi nomuNofi, nokumusoro kweIjipiti, richiti,  
\v 2 “Zvanzi naJehovha Wamasimba Ose, Mwari waIsraeri: Makaona njodzi huru yandakauyisa pamusoro peJerusarema nomumaguta ose eJudha. Nhasi uno asiyiwa angova matongo  
\v 3 nokuda kwezvakaipa zvavakaita. Vakanditsamwisa nokuda kwokupisira zvinonhuhwira uye nokunamata vamwe vamwari vavasina kumboziva ivo kana imi kana madzibaba enyu.  
\v 4 Ndakatuma ndatumazve varanda vangu vaprofita kuti vati, ‘Regai kuita chinhu chinonyangadza chandinovenga!’  
\v 5 Asi havana kunzwa kana kuteerera: havana kudzoka kubva pane zvakaipa zvavo kana kurega kupisa zvinonhuhwira kuna vamwe vamwari.  
\v 6 Naizvozvo kutsamwa kwangu kunotyisa kwakadururwa; kukapisa maguta eJudha uye nenzira dzeJerusarema ndikazviparadza zvikava matongo sezvazvakaita nhasi. 
\p  
\v 7 “Zvino, zvanzi naJehovha, Wamasimba Ose, Mwari waIsraeri: Munouyisireiko njodzi yakakura kudai pamusoro penyu nokuparadzira kubva kuJudha varume navakadzi, navana, navacheche nokudaro muchisara musina kana nomumwe?  
\v 8 Munonditsamwisireiko nezvamunoita namaoko enyu, muchipisira zvinonhuhwira kuna vamwe vamwari vomuIjipiti kwamakaenda kundogara? Muchazviparadza pachenyu mukazviita chinhu chinotukwa nechinozvidzwa pakati pendudzi dzose dzepanyika.  
\v 9 Makanganwa here zvakashata zvakaitwa namadzibaba enyu namadzimambo navanamambokadzi veJudha uye zvakashata zvakaitwa nemi navakadzi venyu munyika yeJudha nomunzira dzeJerusarema?  
\v 10 Kusvikira pazuva ranhasi havana kuzvininipisa kana kuratidza rukudzo, kana kutevera murayiro wangu nezvirevo zvangu zvandakatema pamberi penyu napamberi pamadzibaba enyu. 
\p  
\v 11 “Naizvozvo, zvanzi naJehovha Wamasimba Ose, Mwari waIsraeri: Ndafunga kuuyisa njodzi pamusoro penyu ndigoparadza Judha yose.  
\v 12 Ndichabvisa vakasara veJudha vakanga vashinga kuenda kuIjipiti kundogarako. Vose vachafira muIjipiti, vachafa nomunondo kana kufa nenzara. Kubva kumuduku kusvikira kumukuru, vachafa nomunondo kana nenzara. Vachava chinhu chinotukwa nechinosemwa, chinhu chinoshorwa nechinonyadzisa.  
\v 13 Ndicharanga vaya vanogara kuIjipiti nomunondo, nenzara uye nedenda sokuranga kwandakaita Jerusarema.  
\v 14 Hakuna kuna vakasara veJudha vakaenda kunogara kuIjipiti vachapunyuka kana kurarama kuti vadzoke kunyika yeJudha, uko kwavanoshuva kuti vadzokere kundogara; hakuna achadzoka kunze kwavashoma vachatiza.” 
\p  
\v 15 Ipapo varume vose vaiziva kuti vakadzi vavo vaipisira zvinonhuhwira kuna vamwe vamwari, pamwe chete navakadzi vose vaivapo, ungano huru, navanhu vose vakanga vagere Kumusoro neZasi kweIjipiti, vakati kuna Jeremia,  
\v 16 “Hatingateereri shoko rawataura kwatiri muzita raJehovha!  
\v 17 Zvirokwazvo tichaita zvinhu zvose zvatakati tichaita. Tichapisira zvinonhuhwira kuna Mambokadzi woKudenga nokumudururira zvipiriso zvokunwa sezvatakaita isu namadzibaba edu, namadzimambo edu uye namachinda edu mumaguta eJudha nomunzira dzomuJerusarema. Panguva iyoyo takanga tine zvokudya zvizhinji uye takanga tigere zvakanaka tisina zvaitirwadza.  
\v 18 Asi kubva patakamira kupisira zvinonhuhwira kuna Mambokadzi woKudenga nokudururira zvipiriso zvokunwa kwaari, hapana chatakawana uye tanga tichingofa nomunondo nenzara.” 
\p  
\v 19 Vakadzi vakapamhidzira vachiti, “Patakapisira zvinonhuhwira kuna Mambokadzi woKudenga, uye tikadururira zvipiriso zvokunwa kwaari, varume vedu vakanga vasingazivi here kuti taimuitira makeke akaita somufananidzo wake uye tichimudururira zvipiriso zvinonwiwa?” 
\p  
\v 20 Ipapo Jeremia akati kuvanhu vose, varume navakadzi, vakanga vachimupindura,  
\v 21 “Ko, Jehovha haana kurangarira here uye akafunga pamusoro pezvinonhuhwira zvaipiswa mumaguta eJudha nomunzira dzeJerusarema nemi namadzibaba enyu namadzimambo enyu namachinda enyu uye navanhu venyika?  
\v 22 Jehovha akati haasisina mwoyo murefu pakuipa kwezviito zvenyu nezvinhu zvinonyangadza zvamakaita, nyika yenyu ikava chinhu chinotukwa uye nedongo risina anogaramo, sezvazvakaita nhasi.  
\v 23 Nokuda kwokuti makapisira zvinonhuhwira uye makatadzira Jehovha uye hamuna kumuteerera kana kutevera murayiro wake kana zvirevo zvake kana zvaakatema, njodzi iyi yaiswa pamusoro penyu sezvamunoona zvino.” 
\p  
\v 24 Ipapo Jeremia akati kuvanhu vose kusanganisira vakadzi, “Inzwai shoko raJehovha, imi vanhu vose veJudha vari muIjipiti.  
\v 25 Zvanzi naJehovha Wamasimba Ose, Mwari waIsraeri: Imi navakadzi venyu maratidza nezviito zvenyu, zvamakavimbisa pamakati, ‘Zvirokwazvo mhiko dzedu dzatakapika tichadzizadzisa nokupisa zvinonhuhwira uye nokudururira zvipiriso zvokunwa kuna Mambokadzi woKudenga.’ 
\p “Endererai henyu mberi zvino, itai zvamakavimbisa! Chengetai mhiko dzenyu!  
\v 26 Asi inzwai shoko raJehovha, imi vaJudha mose munogara muIjipiti: ‘Ndinopika nezita rangu guru,’ ndizvo zvinotaura Jehovha, ‘kuti hakuna anobva kuJudha agere papi napapi zvapo muIjipiti achadana zita rangu kana kupika achiti: “Zvirokwazvo naIshe Jehovha mupenyu,”  
\v 27 Nokuti ndinovarindira kuti ndivaitire zvakaipa kwete zvakanaka, vaJudha vari muIjipiti vachafa nomunondo uye nenzara kusvikira vose vaparadzwa.  
\v 28 Avo vachapunyuka pamunondo vakadzokera kunyika yeJudha vachibva kuIjipiti vachava vashoma kwazvo. Ipapo vose vakasara vavaJudha vakauya kuzogara kuIjipiti vachaziva kuti shoko rinogara nderani, rangu kana ravo. 
\p  
\v 29 “ ‘Ichi ndicho chichava chiratidzo kwauri chokuti ndichakuranga panzvimbo ino,’ ndizvo zvinotaura Jehovha, ‘kuitira kuti muzive kuti mashoko eyambiro yangu pamusoro penyu achamira zvirokwazvo.’  
\v 30 Zvanzi naJehovha: ‘Ndiri kuisa Faro Hofira mambo weIjipiti mumaoko avavengi vake vanotsvaka kumuuraya, sezvandakaita Zedhekia mambo weJudha mumaoko aNebhukadhinezari mambo weBhabhironi, iye muvengi akanga achitsvaka kumuuraya.’ ” 
\c 45  
\s1 Shoko kuna Bharuki 
\p  
\v 1 Izvi ndizvo zvakataurwa nomuprofita Jeremia kuna Bharuki mwanakomana waNeria, mugore rechina raJehoyakimi mwanakomana waJosia mambo weJudha, shure kwokunyora kwaBharuki rugwaro rwamashoko aJeremia aakanga achimudaidzira, achiti,  
\v 2 “Zvanzi naJehovha, Mwari waIsraeri, kunewe Bharuki:  
\v 3 Iwe wakati, ‘Ndine nhamo! Jehovha apamhidzira kusuwa pakurwadziwa kwangu; ndaneta nokugomera uye ndashayiwa zororo.’ ” 
\p  
\v 4 Jehovha akati, “Uti kwaari, ‘Zvanzi naJehovha: Ndichakoromora zvandakavaka uye ndichadzura zvandakasima panyika yose.  
\v 5 Iwe ungazvitsvakira zvinhu zvikuru here? Usazvitsvaka. Nokuti ndichauyisa njodzi pamusoro pavanhu vose, ndizvo zvinotaura Jehovha, asi ndichaita kuti utize noupenyu hwako kwose kwaunoenda.’ ” 
\c 46  
\s1 Shoko pamusoro peIjipiti 
\p  
\v 1 Iri ndiro shoko raJehovha rakauya kuna Jeremia muprofita pamusoro pendudzi: 
\p  
\v 2 Pamusoro peIjipiti: 
\p Iri ndiro shoko pamusoro pehondo yaFaro Neko mambo weIjipiti, yakakundwa paKarikemishi, paRwizi Yufuratesi naNebhukadhinezari mambo weBhabhironi mugore rechina raJehoyakimi mwanakomana waJosia mambo weJudha: 
\q1  
\v 3 “Gadzirai nhoo dzenyu, dzose huru neduku, 
\q2 mubude kundorwa! 
\q1  
\v 4 Sungai mabhiza, 
\q2 sungirirai zvigaro! 
\q1 Mirai panzvimbo yenyu 
\q2 makapfeka nguwani! 
\q1 Rodzai mapfumo enyu, 
\q2 pfekai nguo dzenyu dzokurwa! 
\q1  
\v 5 Ndinooneiko? 
\q2 Vavhundutswa, 
\q1 vari kudzokera shure, 
\q2 mhare dzavo dzakundwa. 
\q1 Vari kutiza nokukurumidza 
\q2 vasingacheuki, 
\q2 uye pano kutya kumativi ose,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 6 Vanogona kumhanya havangatizi, 
\q2 uye vakasimba havangapunyuki. 
\q1 Nechokumusoro paRwizi Yufuratesi 
\q2 vanogumburwa vagowa. 
\b  
\q1  
\v 7 Ndianiko uyu anozara serwizi Nairi, 
\q2 senzizi dzamapopopo emvura? 
\q1  
\v 8 Ijipiti yazara seNairi, 
\q2 senzizi dzamapopopo. 
\q1 Inoti, “Ndichazara ndigofukidza nyika; 
\q2 ndichaparadza maguta navanhu vawo.” 
\q1  
\v 9 Virimai, imi mabhiza! 
\q2 Chairai nehasha, imi vatasvi vengoro! 
\q1 Fambirai mberi, imi mhare, 
\q2 varume veEtiopia nePuti vanoitakura nhoo, 
\q2 varume veRidhia vanowembura uta. 
\q1  
\v 10 Asi zuva iro nderaShe, iye Jehovha Wamasimba Ose, 
\q2 iro zuva rokutsiva, rokutsiva vavengi vake. 
\q1 Munondo uchadya kusvikira waguta, 
\q2 kusvikira wapodza nyota yawo neropa. 
\q1 Nokuti Ishe, iye Jehovha Wamasimba Ose, achabayira chibayiro 
\q2 kunyika yokumusoro paRwizi Yufuratesi. 
\b  
\q1  
\v 11 “Kwidza kuGireadhi undotora bharimu, 
\q2 iwe Mwanasikana Mhandara yeIjipiti. 
\q1 Asi unongowanza mishonga pasina; 
\q2 kuporeswa kwako hapana. 
\q1  
\v 12 Ndudzi dzichanzwa nezvokunyadziswa kwako; 
\q2 kuchema kwako kuchazadza nyika. 
\q1 Mhare ichabondera pane imwe mhare; 
\q2 vachawira pasi pamwe chete.” 
\p  
\v 13 Iri ndiro shoko rakataurwa naJehovha kuna Jeremia muprofita, pamusoro pokuuya kwaNebhukadhinezari mambo weBhabhironi kuzorwa neIjipiti achiti: 
\q1  
\v 14 “Zivisai izvi muIjipiti, mugozviparidza paMigidhori; 
\q2 zviparidzeiwo paNofi neTapanesi muchiti: 
\q1 ‘Torai nzvimbo yenyu uye muzvigadzirire, 
\q2 nokuti munondo unodya vakakupoteredzai.’ 
\q1  
\v 15 Ko, mhare dzenyu dzingadzikisirwei? 
\q2 Havangagoni kumira, nokuti Jehovha achavadzikisa pasi. 
\q1  
\v 16 Vacharamba vachingogumburwa; 
\q2 vachawa mumwe nomumwe pamusoro pomumwe. 
\q1 Vachati, ‘Simukai, ngatidzokerei 
\q2 kuvanhu vokwedu nokunyika yedu, 
\q2 kure nomunondo womumanikidzi wedu.’ 
\q1  
\v 17 Ikoko vachadanidzira vachiti, 
\q2 ‘Faro mambo weIjipiti anongova ruzha chete; 
\q2 akatadza kushandisa mukana wake.’ 
\b  
\q1  
\v 18 “Zvirokwazvo noupenyu hwangu,” ndizvo zvinotaura Mambo, 
\q2 ane zita rinonzi Jehovha Wamasimba Ose, 
\q1 “pano mumwe achauya akaita seTabhori pakati pamakomo, 
\q2 seKarimeri pagungwa. 
\q1  
\v 19 Rongedzai zvinhu zvenyu, nokuti muchaenda kuutapwa, 
\q2 imi munogara muIjipiti, 
\q1 nokuti Nofi richaitwa dongo, 
\q2 uye richava dongo risina anogaramo. 
\b  
\q1  
\v 20 “Ijipiti itsiru rakaisvonaka, 
\q2 asi vuvo riri kuuya 
\q2 kuzorwisa richibva kumusoro. 
\q1  
\v 21 Varwi vanorwa kuti varipirwe mari chete vari mairi, 
\q2 vakaita semhuru dzakakodzwa. 
\q1 Naivowo vachatendeuka uye vachatiza pamwe chete, 
\q2 havangamiri panzvimbo yavo, 
\q1 nokuti zuva renjodzi riri kuuya pamusoro pavo, 
\q2 nguva yokurangwa kwavo. 
\q1  
\v 22 Ijipiti ichashinyira senyoka inotiza 
\q2 pakuuya nechisimba kwomuvengi; 
\q1 vachauya kuzorwa nayo namatemo, 
\q2 savarume vanotema miti. 
\q1  
\v 23 Vachatemera sango raro pasi,” 
\q4 ndizvo zvinotaura Jehovha, 
\q2 “kunyange risingapindiki zvaro. 
\q1 Vakawanda kupfuura mhashu, 
\q2 havaverengeki. 
\q1  
\v 24 Mwanasikana weIjipiti achanyadziswa, 
\q2 achaiswa mumaoko avanhu vokumusoro.” 
\p  
\v 25 Jehovha Wamasimba Ose, Mwari weIsraeri, anoti, “Ndava pedyo nokuuyisa shamhu pamusoro paAmoni mwari weTebhesi, napamusoro paFaro, neIjipiti navamwari vayo namadzimambo ayo, napamusoro peavo vanovimba naFaro.  
\v 26 Ndichavaisa mumaoko eavo vanotsvaka kuvauraya, nokuna Nebhukadhinezari mambo weBhabhironi namachinda ake. Shure kwaizvozvo, Ijipiti ichagarwa sepamazuva akare,” ndizvo zvinotaura Jehovha. 
\q1  
\v 27 “Usatya, iwe Jakobho muranda wangu; 
\q2 usavhunduka, iwe Israeri. 
\q1 Zvirokwazvo ndichakuponesa uri kunzvimbo iri kure, 
\q2 nezvizvarwa zvako kubva kunyika youtapwa hwavo, 
\q1 Jakobho achavazve norugare nokuchengetedzeka, 
\q2 uye hakuna achamutyisa. 
\q1  
\v 28 Usatya, iwe Jakobho muranda wangu, 
\q2 nokuti ndinewe,” ndizvo zvinotaura Jehovha. 
\q1 “Kunyange ndikaparadza chose marudzi ose 
\q2 andakakuparadzirai pakati pawo, 
\q2 handizokuparadzei imi zvachose. 
\q1 Ndichakurangai, asi chete nokururamisira; 
\q2 handingakuregei musina kurangwa zvachose.” 
\c 47  
\s1 Chirevo pamusoro pavaFiristia 
\p  
\v 1 Iri ndiro shoko raJehovha rakasvika kumuprofita Jeremia pamusoro pavaFiristia, Faro asati arwisa Gaza: 
\p  
\v 2 Zvanzi naJehovha: 
\q1 “Onai kukwira kunoita mvura zhinji yokumusoro; 
\q2 ivo vachava rwizi runofashukira nesimba. 
\q1 Vachafukidza nyika nezvose zviri mairi, 
\q2 maguta navose vanogaramo. 
\q1 Vanhu vachachema; 
\q2 vose vanogara munyika vachaungudza 
\q1  
\v 3 pavachanzwa mutsindo wemahwanda emabhiza, 
\q2 kutinhira kwengoro dzavavengi, 
\q2 nokurira kwemavhiri adzo. 
\q1 Madzibaba haangadzoki kuzobatsira vana vavo; 
\q2 maoko avo acharembera seakaremara. 
\q1  
\v 4 Nokuti zuva rasvika 
\q2 rokuparadza vaFiristia vose, 
\q1 uye nokuuraya vose vakasara 
\q2 vaigona kubatsira Tire neSidhoni. 
\q1 Jehovha ava pedyo nokuparadza vaFiristia, 
\q2 vaya vakasara vanobva kumahombekombe eKafitori. 
\q1  
\v 5 Gaza richaveura musoro waro mukuchema; 
\q2 Ashikeroni richati mwiro. 
\q1 Haiwa, imi vakasara vari pabani, 
\q2 muchapedza nguva yakadiiko muchizvicheka? 
\b  
\q1  
\v 6 “Muchachema muchiti, ‘Maiwe, munondo waJehovha, 
\q2 uchapedza nguva yakadiiko usati wazorora? 
\q1 Dzokera mumuhara wako; 
\q2 mira, unyarare.’ 
\q1  
\v 7 Asi ungazorora sei, 
\q2 Jehovha akaurayira, 
\q1 sezvo akaurayira 
\q2 kuti urwise Ashikeroni namahombekombe?” 
\c 48  
\s1 Chirevo pamusoro peMoabhu 
\p  
\v 1 Pamusoro peMoabhu: 
\p Zvanzi naJehovha Wamasimba Ose, Mwari waIsraeri: “Ine nhamo Nebho, nokuti ichaparadzwa. 
\q2 Kiriataimi ichanyadziswa uye ichakundwa; 
\q2 nhare dzichanyadziswa uye dzichaparadzwa. 
\q1  
\v 2 Moabhu haichazorumbidzwizve; 
\q2 muHeshibhoni varume vacharangana nezvokuwa kwaro, vachiti: ‘Uyai, tiparadze rudzi urwo.’ 
\q1 Newewo, iwe Madhimeni uchati mwiro; 
\q2 munondo uchakutevera. 
\q1  
\v 3 Inzwai kuchema kunobva kuHoronaimi, 
\q2 kuchema kwokukoromorwa nokuparadzwa kukuru. 
\q1  
\v 4 Moabhu ichaputswa; 
\q2 vana vadiki varo vacharidza mhere. 
\q1  
\v 5 Vachakwira nomukwidza weRuhiti, 
\q2 vachichema zvikuru pakuenda kwavo; 
\q1 pamateru enzira yokuHoronaimi 
\q2 kuchema kwokurwadziwa pamusoro pokuparadza kunonzwika. 
\q1  
\v 6 Tizai! Mhanyai muponese upenyu hwenyu; 
\q2 mufanane negwenzi riri mugwenga. 
\q1  
\v 7 Sezvo muchivimba namabasa uye nepfuma yenyu, 
\q2 nemiwo muchatapwa, 
\q1 uye Kemoshi ichaenda kuutapwa, 
\q2 pamwe chete navaprista namachinda ayo. 
\q1  
\v 8 Muparadzi acharwa namaguta ose ose, 
\q2 uye hapana guta richapunyuka. 
\q1 Mupata uchaparadzwa, 
\q2 uye mutunhu wakakwirira uchaparadzwa 
\q2 nokuti Jehovha azvitaura. 
\q1  
\v 9 Isai munyu pamusoro peMoabhu, 
\q2 nokuti ichaparadzwa; 
\q1 maguta ayo achava matongo, 
\q2 asina achazogaramo. 
\b  
\q1  
\v 10 “Ngaatukwe uyo anobata basa raJehovha asina hanya! 
\q2 Ngaatukwe uyo anodzora munondo wake pakuteura ropa! 
\b  
\q1  
\v 11 “Moabhu anga ane zororo kubvira pauduku hwake, 
\q2 sewaini yasarira mumasese, 
\q1 isina kudirwa kubva muno mumwe mudziyo ichiiswa muno mumwe, 
\q2 haana kuenda kuutapwa. 
\q1 Saka anongotapira sezvaakanga ari, 
\q2 uye kunhuhwira kwake hakuna kushanduka. 
\q1  
\v 12 Asi mazuva anouya,” 
\q2 ndizvo zvinotaura Jehovha, 
\q1 “andichatuma varume vanodurura zvinobva mumudziyo, 
\q2 uye vachadururira pasi; 
\q1 vachasiya midziyo isina chinhu 
\q2 uye vagoputsa midziyo yake. 
\q1  
\v 13 Ipapo Moabhu achanyadziswa neKemoshi, 
\q2 sokunyadziswa kwakaitwa imba yaIsraeri 
\q2 pavakavimba neBheteri. 
\b  
\q1  
\v 14 “Ungataura sei, uchiti, ‘Tiri mhare, 
\q2 varume vakatsunga muhondo’? 
\q1  
\v 15 Moabhu ichaparadzwa, uye maguta ayo acharwiswa; 
\q2 majaya ake akaisvonaka achaburukira kundourayiwa,” 
\q2 ndizvo zvinotaura Mambo, ane zita rinonzi Jehovha Wamasimba Ose. 
\q1  
\v 16 “Kuwa kweMoabhu kwava pedyo; 
\q2 njodzi yayo ichasvika nokukurumidza. 
\q1  
\v 17 Ichemei, imi mose mugere makaipoteredza, 
\q2 vose vanoziva mukurumbira wayo; 
\q1 muti, ‘Yavhunika seiko tsvimbo yakasimba, 
\q2 wavhunika seiko mudonzvo wakaisvonaka!’ 
\b  
\q1  
\v 18 “Burukai pakukudzwa kwenyu 
\q2 mugare pavhu rakaoma, 
\q2 imi vagari voMwanasikana weDhibhoni, 
\q1 nokuti iye anoparadza Moabhu 
\q2 achauya kuzokurwisai, 
\q2 uye agoparadza maguta enyu akakomberedzwa. 
\q1  
\v 19 Mirai panzira mutarire, 
\q2 imi vagari vemuAroeri. 
\q1 Bvunzai murume ari kutiza nomukadzi apunyuka, 
\q2 muvabvunze kuti, ‘Chii chaitika?’ 
\q1  
\v 20 Moabhu yanyadziswa, nokuti yaparadzwa. 
\q2 Ungudzai uye muridze mhere! 
\q1 Zvizivisei paArinoni 
\q2 kuti Moabhu yaparadzwa. 
\q1  
\v 21 Kutonga kwasvika kumutunhu wakakwirira, 
\q2 kuHoroni, Jahaza neMefaati, 
\q2  
\v 22 kuDhibhoni, Nebho neBheti Dhibhirataimu, 
\q2  
\v 23 kuKiriataimu, neBheti Gamuri neBheti Meoni, 
\q2  
\v 24 kuKerioti neBhozira, 
\q2 nokumaguta ose eMoabhu ari kure neari pedyo. 
\q1  
\v 25 Runyanga rweMoabhu rwagurwa; 
\q2 ruoko rwake rwavhunika,” 
\q4 ndizvo zvinotaura Jehovha. 
\b  
\q1  
\v 26 “Itai kuti adhakwe, 
\q2 nokuti iye azvidza Jehovha. 
\q1 Regai Moabhu aumburuke mumarutsi ake; 
\q2 ngaave chinhu chinosekwa. 
\q1  
\v 27 Ko, Israeri haana kuva chinhu chinosekwa nemi here? 
\q2 Ko, akabatwa ari pakati pembavha here, 
\q1 zvamunodzungudza musoro wenyu 
\q2 muchimushora pose pamunotaura nezvake? 
\q1  
\v 28 Siyai maguta enyu mundogara pakati pamatombo, 
\q2 imi mugere muMoabhu. 
\q1 Itai senjiva inovaka dendere rayo 
\q2 pamuromo webako. 
\b  
\q1  
\v 29 “Takanzwa nezvokuzvikudza kweMoabhu, 
\q2 manyawi nokudada kwavo kukuru 
\q1 uye kuzvikudza kwakanyanya, 
\q2 kuzvikudza kwavo nokuzvitutumadza namanyawi emwoyo wayo. 
\q1  
\v 30 Ndinoziva kusindimara kwayo asi hakuna maturo,” 
\q4 ndizvo zvinotaura Jehovha, 
\q2 “uye kuzvikudza kwake kuzhinji hakuna zvakunoreva. 
\q1  
\v 31 Naizvozvo ndinoungudza pamusoro peMoabhu, 
\q2 nokuda kweMoabhu yose ndinodanidzira, 
\q2 ndinochema varume veKiri Hareseti. 
\q1  
\v 32 Ndinokuchema sokuchema kunoita Jazeri, 
\q2 haiwa imi mazambiringa eGibhima. 
\q1 Matavi enyu akatandavara kundosvika kugungwa; 
\q2 akandosvika kugungwa reJazeri. 
\q1 Muparadzi awira pamichero yako 
\q2 yaibva namazambiringa. 
\q1  
\v 33 Mufaro nokufarisisa zvaenda, 
\q2 zvabva muminda yemichero nomuminda yeMoabhu. 
\q1 Ndagumisa kuyerera kwewaini inobva pazvisviniro; 
\q2 hakuna achazvitsika achidanidzira nomufaro. 
\q1 Kunyange pano kudanidzira, 
\q2 hakusi kudanidzira kwomufaro. 
\b  
\q1  
\v 34 “Inzwi rokuchema kwavo rinokwira 
\q2 richibva kuHeshibhoni kusvikira kuErieri neJahazi, 
\q1 kubva kuZoari kusvikira kuHoronaimi neEgirati Sherishiya, 
\q2 nokuti kunyange nemvura dzeNimirimi dzapwa. 
\q1  
\v 35 Ndichaisa magumo muMoabhu, 
\q2 kuna avo vanopa zvipiriso panzvimbo dzakakwirira, 
\q2 uye vanopisira zvinonhuhwira kuna vamwari vavo,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 36 “Saka mwoyo wangu unorira senyere pamusoro peMoabhu; 
\q2 unorira senyere pamusoro pavarume veKiri Hareseti. 
\q2 Pfuma yavakawana yapera. 
\q1  
\v 37 Musoro mumwe nomumwe wakaveurwa, 
\q2 uye ndebvu dzose dzakagurirwa; 
\q1 ruoko rumwe norumwe rwakagurwa, 
\q2 uye zviuno zvose zvakafukidzwa namasaga. 
\q1  
\v 38 Pamusoro pamatenga ose eMoabhu 
\q2 napazvivara 
\q1 hakuna chiriko kunze kwokuchema, 
\q2 nokuti ndaputsa Moabhu 
\q2 sedende risina anorida,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 39 “Akoromorwa sei! Vaungudza sei! 
\q2 Hoyo Moabhu afuratira nokuda kwokunyadziswa! 
\q1 Moabhu yava chinhu chinosekwa, 
\q2 chinhu chinonyangadza kuna vose vakaipoteredza.” 
\p  
\v 40 Zvanzi naJehovha: 
\q1 “Tarirai achabhururuka segondo, 
\q2 rakatambanudzira mapapiro aro pamusoro peMoabhu. 
\q1  
\v 41 Kerioti ichatapwa 
\q2 uye nhare dzichatorwa. 
\q1 Pazuva iro mwoyo yemhare dzeMoabhu 
\q2 ichafanana nomwoyo womukadzi ari kurwadziwa. 
\q1  
\v 42 Moabhu ichaparadzwa serudzi 
\q2 nokuti yakazvidza Jehovha. 
\q1  
\v 43 Kutya negomba nomusungo zvakakumirirai, 
\q2 imi vanhu veMoabhu,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 44 “Ani naani achatiza njodzi 
\q2 iyi achawira mugomba, 
\q1 ani naani achakwira achibuda mugomba, 
\q2 achabatwa mumusungo; 
\q1 nokuti ndichauyisa pamusoro peMoabhu 
\q2 gore rokurangwa kwake,” 
\q4 ndizvo zvinotaura Jehovha. 
\b  
\q1  
\v 45 “Mumumvuri weHeshibhoni 
\q2 vatizi vanomirapo vasina simba, 
\q1 nokuti moto wabuda uchibva kuHeshibhoni, 
\q2 murazvo pakati peSihoni; 
\q1 unopisa huma dzaMoabhu, 
\q2 misoro yavanozvikudza vemheremhere. 
\q1  
\v 46 Une nhamo, iwe Moabhu! 
\q2 Vanhu veKemoshi vaparara; 
\q1 vanakomana vako vakaendeswa kuutapwa 
\q2 navanasikana vako muutapwa. 
\b  
\q1  
\v 47 “Kunyange zvakadaro ndichadzosazve pfuma yeMoabhu 
\q2 pamazuva anouya,” 
\q4 ndizvo zvinotaura Jehovha. 
\p Pano ndipo panogumira kutongwa kweMoabhu. 
\c 49  
\s1 Chirevo pamusoro paAmoni 
\p  
\v 1 Pamusoro paAmoni: 
\p Zvanzi naJehovha: 
\q1 “Ko, Israeri haana mwanakomana here? 
\q2 Haana vadyi venhaka here? 
\q1 Ko, zvino Moreki atorerei nhaka yaGadhi? 
\q2 Nemhaka yeiko vanhu vake vachigara mumaguta ayo? 
\q1  
\v 2 Asi mazuva anouya,” 
\q2 ndizvo zvinotaura Jehovha, 
\q1 “andicharidza mhere yehondo 
\q2 pamusoro peRabha ravaAmoni; 
\q1 richaitwa murwi wamatongo, 
\q2 uye misha yakaripoteredza ichapiswa nomoto. 
\q1 Ipapo Israeri achadzinga 
\q2 vaya vakanga vamudzinga,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 3 “Ungudza, iwe Heshibhoni, nokuti Ai raparadzwa! 
\q2 Ridzai mhere, imi vanogara muRabha! 
\q1 Pfekai masaga mucheme, 
\q2 mhanyai pano nekoko pakati porusvingo, 
\q1 nokuti Moreki achaenda kuutapwa, 
\q2 pamwe chete navaprista vake namachinda ake. 
\q1  
\v 4 Unozvikudzireiko nemipata yako, 
\q2 kuzvikudza nemipata inobereka kwazvo? 
\q1 Haiwa mwanasikana wokusatendeka, 
\q2 unovimba nepfuma yako uchiti, 
\q2 ‘Ndiani acharwa neni?’ 
\q1  
\v 5 Ndichauyisa kutya pamusoro pako 
\q2 kunobva kuna avo vakakupoteredza,” 
\q4 ndizvo zvinotaura Jehovha Wamasimba Ose. 
\q1 “Mumwe nomumwe wenyu achadzingirwa kure, 
\q2 uye hakuna achaunganidza vatizi. 
\b  
\q1  
\v 6 “Asi shure kwaizvozvo, ndichadzosazve pfuma yavaAmoni,” 
\q4 ndizvo zvinotaura Jehovha. 
\s1 Chirevo pamusoro peEdhomu 
\p  
\v 7 Pamusoro peEdhomu: 
\p Zvanzi naJehovha Wamasimba Ose: 
\q1 “Ko, muTemani hamuchina uchenjeri here? 
\q2 Mano atsakatika here kuna vakangwara? 
\q2 Ko, uchenjeri hwavo hwaora here? 
\q1  
\v 8 Dzokai uye mutize, muwande mumapako akadzika, 
\q2 imi munogara muDhedhani, 
\q1 nokuti ndichauyisa njodzi pamusoro paEsau, 
\q2 panguva yandinomuranga. 
\q1  
\v 9 Kana vanononga mazambiringa vakasvika kwauri, 
\q2 havangasiyi mazambiringa mashoma here? 
\q1 Kana mbavha dzikasvika usiku, 
\q2 havangabi zvavanoda chete here? 
\q1  
\v 10 Asi ndichafukura Esau; 
\q2 ndichazarura nzvimbo dzake dzokuvanda, 
\q2 kuitira kuti akundikane kuzvivanza. 
\q1 Vana vake, nehama dzake navavakidzani vake vachafa, 
\q2 uye iye haachazovapozve. 
\q1  
\v 11 Siya nherera dzako; ini ndicharwira upenyu hwavo. 
\q2 Chirikadzi dzakowo dzichagona kuvimba neni.” 
\p  
\v 12 Zvanzi naJehovha: “Kana avo vakanga vasingafaniri kunwa pamukombe vakodzera kuunwa, iwe ucharegereiko kurangwa? Haungaregi kurangwa, asi unofanira kunwa pamukombe wacho.  
\v 13 Ndinopika neni ndimene,” ndizvo zvinotaura Jehovha, “kuti Bhozira richava dongo nechinhu chinonyangadza, nechinhu chinotyisa, chinozvidzwa nechinotukwa; uye maguta aro ose achava matongo nokusingaperi.” 
\q1  
\v 14 Ndakanzwa shoko rakabva kuna Jehovha, richiti: 
\q2 Nhume yakatumwa kundudzi kunoti, 
\q1 “Unganai kuti murwe naro! 
\q2 Simukai murwe!” 
\b  
\q1  
\v 15 “Zvino ndichakuita muduku pakati pendudzi, 
\q2 anozvidzwa pakati pavanhu. 
\q1  
\v 16 Kutyisa kwaunoita, 
\q2 nokuzvikudza kwomwoyo wako zvakunyengera, 
\q1 iwe unogara mumikaha yematombo, 
\q2 ugere panzvimbo dzakakwirira dzechikomo. 
\q1 Kunyange ukavaka dendere rako pakakwirira segondo, 
\q2 ndichakukoromora kubva ipapo,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 17 “Edhomu richava chinhu chinotyisa, 
\q2 vose vachapfuura napo vachashamiswa, 
\q2 uye vachaseka nokuda kwamavanga aro ose. 
\q1  
\v 18 Sokuparadzwa kwakaitwa Sodhomu neGomora, 
\q2 pamwe chete namaguta akanga akavakidzana nawo,” 
\q4 ndizvo zvinotaura Jehovha, 
\q1 “saka hakuna munhu achazogarako; 
\q2 hakuna munhu achagara mariri. 
\b  
\q1  
\v 19 “Seshumba inobuda mumatenhere eJorodhani 
\q2 ichienda kumafuro akapfuma, 
\q1 ndichadzinga Edhomu kubva munyika yake pakarepo. 
\q2 Ndianiko akasarudzwa wandichagadza kuti aite izvi? 
\q1 Ndiani akafanana neni uye ndiani angakwikwidzane neni? 
\q2 Uye ndoupi mufudzi angamisidzana neni?” 
\q1  
\v 20 Naizvozvo, inzwai zvakarongwa naJehovha pamusoro peEdhomu, 
\q2 zvaakafunga pamusoro peavo vagere muTemani: 
\q1 Achakwekweredza vaduku vemapoka; 
\q2 achaparadza chose mafuro avo nokuda kwavo. 
\q1  
\v 21 Nyika ichadedera nokuda kwomubvumo wokuwa kwavo; 
\q2 kuchema kwavo kuchanzwikwawo kusvikira kuGungwa Dzvuku. 
\q1  
\v 22 Tarirai gondo richabhururuka ndokudzika nesimba, 
\q2 rakatambanudza mapapiro aro pamusoro peBhozira. 
\q1 Pazuva iro mwoyo yemhare dzeEdhomu 
\q2 ichafanana nomwoyo womukadzi orwadziwa. 
\s1 Chirevo pamusoro peDhamasiko 
\p  
\v 23 Pamusoro peDhamasiko: 
\q1 “Hamati neAripadhi avhundutswa, 
\q2 nokuti agamuchira mashoko akaipa. 
\q1 Aora mwoyo, 
\q2 atambudzika segungwa risina zororo. 
\q1  
\v 24 Dhamasiko harichina simba, 
\q2 rakatendeuka kuti ritize, 
\q2 kuvhunduka kukaribata; 
\q1 kugomera nokurwadziwa zvakaribata, 
\q2 kurwadziwa sekwomukadzi osununguka. 
\q1  
\v 25 Guta remukurumbira harina kusiyiwa seiko, 
\q2 iro guta randinofarira? 
\q1  
\v 26 Zvirokwazvo majaya aro achawa mumigwagwa; 
\q2 varwi varo vose vachati mwiro pazuva iroro,” 
\q4 ndizvo zvinotaura Jehovha Wamasimba Ose. 
\q1  
\v 27 “Ndichatungidza moto kumasvingo eDhamasiko; 
\q2 uchaparadza nhare dzose dzaBheni-Hadhadhi.” 
\s1 Chirevo pamusoro peKedhari neHazori 
\p  
\v 28 Pamusoro peKedhari noumambo hweHazori, hwakarwiswa naNebhukadhinezari mambo weBhabhironi: 
\p Zvanzi naJehovha: 
\q1 “Simukai, murwise Kedhari 
\q2 uye muparadze vanhu vokuMabvazuva. 
\q1  
\v 29 Matende avo namapoka avo amakwai achatorwa; 
\q2 matumba avo achatorwa achiendwa nawo, 
\q2 nemidziyo yavo yose nengamera. 
\q1 Vanhu vachadanidzira kwavari vachiti, 
\q2 ‘Zvinhu zviri kutyisa kumativi ose!’ 
\b  
\q1  
\v 30 “Tizirai kure nokukurumidza! 
\q2 Garai mumapako akadzika, imi vagari vomuHazari,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1 “Nebhukadhinezari mambo weBhabhironi aita zvakaipa pamusoro penyu; 
\q2 aronga zano pamusoro penyu. 
\b  
\q1  
\v 31 “Simukai mundorwisa rudzi rwakazvigarira zvarwo, 
\q2 rugere zvarwo rusina hanya,” 
\q4 ndizvo zvinotaura Jehovha, 
\q1 “irwo rudzi rusina masuo kana mazariro; 
\q2 vanhu varwo vanogara voga zvavo. 
\q1  
\v 32 Ngamera dzavo dzichapambwa, 
\q2 uye mombe dzavo dzakawanda dzichapambwa. 
\q1 Ndichaparadzira kumhepo avo vari kunyika dzokure, 
\q2 uye ndichauyisa njodzi pamusoro pavo kubva kumativi ose,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 33 “Hazori richava ugaro hwamakava, 
\q2 dongo nokusingaperi. 
\q1 Hapana achagarako; 
\q2 hakuna munhu achagara mariri.” 
\s1 Chirevo pamusoro peEramu 
\p  
\v 34 Iri ndiro shoko raJehovha rakasvika kuna Jeremia muprofita pamusoro peEramu, pakutanga kwokubata ushe kwaZedhekia mambo weJudha, richiti: 
\p  
\v 35 Zvanzi naJehovha Wamasimba Ose: 
\q1 “Tarirai, ndichavhuna uta hweEramu, 
\q2 iwo musimboti wesimba ravo. 
\q1  
\v 36 Ndichauyisa pamusoro paEramu mhepo ina, 
\q2 kubva kumativi mana ematenga; 
\q1 ndichavaparadzira kumhepo ina 
\q2 uye hakungavi norudzi rumwe 
\q2 kusingaendwi navavakidzani veEramu. 
\q1  
\v 37 Ndichapwanya Eramu pamberi pavavengi vavo, 
\q2 pamberi paivo vanotsvaka kuvauraya; 
\q1 ndichauyisa njodzi pamusoro pavo, 
\q2 iko kutsamwa kwangu kunotyisa,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1 “Ndichavatevera nomunondo 
\q2 kusvikira ndavapedza. 
\q1  
\v 38 Ndichaisa chigaro changu choushe muEramu 
\q2 uye ndichaparadza mambo wayo namachinda ayo,” 
\q4 ndizvo zvinotaura Jehovha. 
\b  
\q1  
\v 39 “Asi ndichadzosa nhaka yeEramu 
\q2 mumazuva okupedzisira,” 
\q4 ndizvo zvinotaura Jehovha. 
\c 50  
\s1 Chirevo pamusoro peBhabhironi 
\p  
\v 1 Iri ndiro shoko rakataurwa naJehovha kubudikidza nomuprofita Jeremia pamusoro peBhabhironi nenyika yavaBhabhironi: 
\q1  
\v 2 “Zivisai, uye paridzai pakati pendudzi, 
\q2 simudzai mureza uye paridzai; 
\q2 musasiya kana chinhu, asi muti, 
\q1 ‘Bhabhironi richakundwa; 
\q2 Bheri richanyadziswa, 
\q2 Merodhaki richazara nokutya. 
\q1 Zvifananidzo zvaro zvichanyadziswa 
\q2 uye zvifananidzo zvaro zvichazara nokutya.’ 
\q1  
\v 3 Rudzi runobva kumusoro rucharirwisa, 
\q2 uye ruchaparadza nyika yaro. 
\q1 Hakuna munhu achagaramo; 
\q2 zvose vanhu nezvipfuwo zvichatizira kure. 
\b  
\q1  
\v 4 “Mumazuva iwayo, nenguva iyoyo,” 
\q2 ndizvo zvinotaura Jehovha, 
\q1 “vanhu veIsraeri navanhu veJudha pamwe chete 
\q2 vachaenda kundotsvaka Jehovha Mwari wavo vachichema. 
\q1  
\v 5 Vachabvunza nzira inoenda kuZioni, 
\q2 vagotendeutsira zviso zvavo kwairi. 
\q1 Vachauya vagozvisunga kuna Jehovha, 
\q2 nesungano isingaperi isingakanganwiki. 
\b  
\q1  
\v 6 “Vanhu vangu vanga vari makwai akarasika; 
\q2 vafudzi vavo vakavatsausa, 
\q2 uye vakavaita kuti vadzungaire pamusoro pamakomo. 
\q1 Vakadzungaira pamusoro pamakomo nezvikomo, 
\q2 ndokukanganwa nzvimbo yavo yokuzorora. 
\q1  
\v 7 Ani naani akavawana akavadya; 
\q2 vavengi vavo vakati, ‘Isu hatina mhosva, 
\q1 nokuti vakatadzira Jehovha, iye mafuro avo echokwadi, 
\q2 iye Jehovha, tariro yamadzibaba avo.’ 
\b  
\q1  
\v 8 “Tizai mubude muBhabhironi; 
\q2 siyai nyika yavaBhabhironi, 
\q2 mugoita sembudzi inotungamirira makwai. 
\q1  
\v 9 Nokuti ndichamutsa Bhabhironi 
\q2 uye ndichaisa pamusoro paro ndudzi huru dzakabatana dzinobva kumusoro. 
\q1 Vachazvigadzirira kurwa naro, 
\q2 uye richakundwa kubva nechokumusoro. 
\q1 Miseve yavo ichava semhare pakurwa, 
\q2 dzisingadzoki dzisina chadzakabata. 
\q1  
\v 10 Naizvozvo Bhabhironi richapambwa; 
\q2 vose vanoripamba vachawana mugove wavo,” 
\q4 ndizvo zvinotaura Jehovha. 
\b  
\q1  
\v 11 “Nokuda kwokuti munofara nokufarisisa, 
\q2 iyemi munopamba nhaka yangu, 
\q1 nokuti munokwakuka setsiru rinopura zviyo, 
\q2 muchirira samabhiza, 
\q1  
\v 12 mai venyu vachanyadziswa kwazvo; 
\q2 ivo vakakuberekai vachanyadziswa. 
\q1 Vachava mudiki pandudzi, renje, 
\q2 nenyika yakaoma, uye gwenga. 
\q1  
\v 13 Nokuda kwokutsamwa kwaJehovha hamungagarwi, 
\q2 asi richava dongo chose. 
\q1 Vose vanopfuura pedyo neBhabhironi vachatyiswa, 
\q2 uye vacharidza muridzo nokuda kwamavanga ake ose. 
\b  
\q1  
\v 14 “Mirai panzvimbo dzenyu makakomba Bhabhironi, 
\q2 imi mose munowembura uta. 
\q2 Ripfurei! Musasiye kana museve nokuti rakatadzira Jehovha. 
\q1  
\v 15 Pururudzai pamusoro pake kumativi ose! 
\q2 Rakanda mapfumo pasi, shongwe dzaro dzawa, 
\q2 masvingo aro akoromoka. 
\q1 Sezvo kuri kutsiva kwaJehovha, 
\q2 tsivai pariri; riitirei sezvarakaitira vamwe. 
\q1  
\v 16 Bvisai mudyari muBhabhironi, 
\q2 nomucheki nejeko rake pakukohwa. 
\q1 Nokuda kwomunondo womumanikidzi 
\q2 mumwe nomumwe ngaadzokere kuvanhu vake, 
\q2 mumwe nomumwe ngaatizire kunyika yake. 
\b  
\q1  
\v 17 “Israeri makwai akapararira 
\q2 akadzingirwa kure neshumba. 
\q1 Akatanga kumudya 
\q2 akanga ari mambo weAsiria; 
\q1 akapedzisira kupwanya mapfupa ake 
\q2 ndiNebhukadhinezari mambo weBhabhironi.” 
\p  
\v 18 Naizvozvo zvanzi naJehovha Wamasimba Ose, Mwari waIsraeri: 
\q1 “Ndicharanga mambo weBhabhironi nenyika yake, 
\q2 sokuranga kwandakaita mambo weAsiria. 
\q1  
\v 19 Asi ndichadzosera Israeri kumafuro ake, 
\q2 uye achafura paKarimeri nepaBhashani; 
\q1 achadya akaguta 
\q2 pazvikomo zveEfuremu neGireadhi. 
\q1  
\v 20 Mumazuva iwayo, panguva iyoyo,” 
\q2 ndizvo zvinotaura Jehovha, 
\q1 “mhaka yaIsraeri ichatsvakwa, 
\q2 asi pachange pasina mhosva, 
\q1 uye zvivi zveJudha zvichatsvakwa, 
\q2 asi hapana chichawanikwa, 
\q2 nokuti ndichakanganwira vakasara vandakasiya. 
\b  
\q1  
\v 21 “Rwisai nyika yeMarataimi 
\q2 neavo vagere muPekodhi. 
\q1 Dzingirirai, urayai uye muvaparadze zvachose,” 
\q4 ndizvo zvinotaura Jehovha. 
\q2 “Muite zvose zvandakurayirai. 
\q1  
\v 22 Mheremhere yehondo iri munyika, 
\q2 mheremhere yokuparadza kukuru! 
\q1  
\v 23 Yavhunika nokupwanyika 
\q2 seiko nyundo yenyika yose! 
\q1 Bhabhironi rava dongo 
\q2 seiko pakati pendudzi! 
\q1  
\v 24 Ndakakuisira musungo, iwe Bhabhironi, 
\q2 uye wakabatwa usati wazviziva; 
\q1 wakawanikwa ukapambwa 
\q2 nokuti wakapikisana naJehovha, 
\q1  
\v 25 Jehovha akazarura dura rezvombo 
\q2 ndokubudisa zvombo zvehasha dzake, 
\q1 nokuti Ishe Jehovha Wamasimba Ose 
\q2 ane basa rokuita munyika yavaBhabhironi. 
\q1  
\v 26 Uyai murwe naro muchibva kure. 
\q2 Zarurai matura aro; muriunganidze semirwi yezviyo. 
\q2 Riparadzei zvachose, parege kuva navanosara. 
\q1  
\v 27 Muuraye hondo diki dzaro dzose; 
\q2 ngadziendeswe kundobayiwa! Vane nhamo! 
\q1 Nokuti zuva ravo rasvika, 
\q2 nguva yokurangwa kwavo. 
\q1  
\v 28 Inzwai vanotiza navapoteri vanobva kuBhabhironi, 
\q2 vanoparidza muZioni 
\q1 kuti Jehovha Mwari wedu akatsiva sei, 
\q2 kutsivira temberi yake. 
\b  
\q1  
\v 29 “Kokerai vapfuri vemiseve varwe neBhabhironi, 
\q2 vose vanowembura uta. 
\q1 Rikombei rose; 
\q2 ngakurege kuva nounopukunyuka. 
\q1 Riripirei nokuda kwamabasa avo; 
\q2 riitireiwo sezvarakaita. 
\q1 Nokuti vakamhura Jehovha, 
\q2 Iye Mutsvene weIsraeri. 
\q1  
\v 30 Naizvozvo majaya aro achawira mumigwagwa; 
\q2 varwi varo vose vachanyarara kuti mwiro pazuva iro,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 31 “Tarira, ndinorwa newe, iwe wokuzvikudza,” 
\q2 ndizvo zvinotaura Ishe Jehovha Wamasimba Ose, 
\q1 “nokuti zuva rako rasvika, 
\q2 nguva yokurangwa kwako. 
\q1  
\v 32 Anozvikudza achagumburwa agowa, 
\q2 uye hapana achamusimudza; 
\q1 ndichatungidza moto mumaguta ake 
\q2 uchapisa vose vakamupoteredza.” 
\p  
\v 33 Zvanzi naJehovha Wamasimba Ose: 
\q1 “Vanhu veIsraeri vakamanikidzwa, 
\q2 navanhu veJudha vakamanikidzwawo, 
\q1 vapambi vavo vose vakavabata, zvakasimba, 
\q2 vanoramba kuvaregedza kuti vaende. 
\q1  
\v 34 Asi mudzikinuri wavo ane simba; 
\q2 Jehovha Wamasimba Ose ndiro zita rake. 
\q1 Achavareverera nhaka yavo 
\q2 nesimba kuti azorodze nyika yavo, 
\q2 asi achashayisa zororo kuna avo vanogara muBhabhironi. 
\b  
\q1  
\v 35 “Munondo pamusoro pavaBhabhironi!” 
\q2 ndizvo zvinotaura Jehovha, 
\q1 “pamusoro peavo vagere muBhabhironi, 
\q2 napamusoro pamachinda aro navakachenjera varo! 
\q1  
\v 36 Munondo pamusoro pavaprofita 
\q2 varo venhema! Vachava mapenzi. 
\q1 Munondo pamusoro pemhare dzaro! 
\q2 Vachazadzwa nokutya. 
\q1  
\v 37 Munondo pamusoro pamabhiza nengoro dzaro, 
\q2 napamusoro pavatorwa vose vari pazvigaro zvaro! 
\q2 Vachava vakadzi. 
\q1 Munondo pamusoro pepfuma yaro! 
\q2 Ichapambwa. 
\q1  
\v 38 Mvura yaro zhinji ngaipwe! 
\q2 Ichaoma. 
\q1 Nokuti inyika yezvifananidzo, 
\q2 zvifananidzo zvichapenga nokutya. 
\b  
\q1  
\v 39 “Saka mhuka dzomugwenga namapere zvichagarako, 
\q2 uye zizi richagara imomo. 
\q1 Haichazogarwizve, 
\q2 uye hapana achagaramo kusvikira kumarudzi namarudzi. 
\q1  
\v 40 Sokukoromorwa kwakaitwa Sodhomu neGomora naMwari 
\q2 pamwe chete namaguta akavakidzana nawo,” 
\q4 ndizvo zvinotaura Jehovha, 
\q1 “saizvozvo hakuna achagarako; 
\q2 hakuna munhu achagara mairi. 
\b  
\q1  
\v 41 “Tarirai! Hondo inobva nechokumusoro; 
\q2 rudzi rukuru namadzimambo mazhinji 
\q2 ari kumutswa kubva kumagumo enyika. 
\q1  
\v 42 Vakapakata uta namapfumo; 
\q2 vano utsinye uye havana tsitsi. 
\q1 Vanotinhira segungwa 
\q2 vakatasva mabhiza avo; 
\q1 vanouya vakaita savarume vakagadzirira kurwa, 
\q2 kuti vakurwise, iwe Mwanasikana weBhabhironi. 
\q1  
\v 43 Mambo weBhabhironi akanzwa guhu pamusoro pavo, 
\q2 maoko ake akapera simba. 
\q1 Kutya kwakamubata, 
\q2 kurwadziwa sekwomukadzi wosununguka. 
\q1  
\v 44 Seshumba inouya ichibva mudondo reJorodhani 
\q2 ichienda kumafuro akapfuma, 
\q1 ndichadzinga Bhabhironi kubva munyika yayo pakarepo. 
\q2 Ndianiko akatsaurwa wandichagadza pane izvi? 
\q1 Ndiani akaita seni uye ndiani achamisidzana neni? 
\q2 Uye ndoupi mufudzi angandidzivisa?” 
\q1  
\v 45 Naizvozvo, inzwai zvakarongwa naJehovha pamusoro peBhabhironi, 
\q2 zvaakaronga pamusoro penyika yavaBhabhironi: 
\q1 Makwayana emapoka avo achakwekweredzerwa kure; 
\q2 achaparadza mafuro awo zvachose nokuda kwavo. 
\q1  
\v 46 Pachanzwikwa kutinhira kwokukundwa kweBhabhironi, nyika ichadedera; 
\q2 kuchema kwayo kuchanzwikwa pakati pamarudzi. 
\c 51  
\p  
\v 1 Zvanzi naJehovha: 
\q1 “Tarirai, ndichamutsa mwoyo womuparadzi 
\q2 pamusoro peBhabhironi navanhu veRebhi Kamai. 
\q1  
\v 2 Ndichatumira vatorwa kuBhabhironi 
\q2 kundorirurudza nokuparadza nyika yaro; 
\q1 vacharirwisa kumativi ose, pazuva rokuparara kwaro. 
\q1  
\v 3 Musarega mupfuri achiwembura uta hwake, 
\q2 kana kumurega achipfeka nhumbi dzake dzokurwa. 
\q1 Regai kunzwira majaya aro tsitsi; 
\q2 paradzai hondo yaro zvachose. 
\q1  
\v 4 Vachawira pasi vaurayiwa muBhabhironi, 
\q2 vachakuvadzwa mumigwagwa zvokuti havazorarami. 
\q1  
\v 5 Nokuti Israeri neJudha havana kuraswa 
\q2 naMwari wavo, iye Jehovha Wamasimba Ose, 
\q1 kunyange nyika yavo yakazara nemhaka 
\q2 pamberi poMutsvene waIsraeri. 
\b  
\q1  
\v 6 “Tizai mubve muBhabhironi! 
\q2 Mhanyai muponese upenyu hwenyu! 
\q2 Regai kuparadzwa nokuda kwezvivi zvaro. 
\q1 Inguva yokutsiva kwaJehovha; 
\q2 iye achariripira zvarinokodzera. 
\q1  
\v 7 Bhabhironi rakanga riri mukombe wegoridhe muruoko rwaJehovha; 
\q2 rakadhakisa nyika yose. 
\q1 Ndudzi dzakanwa waini yaro; 
\q2 naizvozvo dzava kupenga. 
\q1  
\v 8 Bhabhironi richawa pakarepo rigoondomoka. 
\q2 Ungudzai pamusoro paro! 
\q1 Torai muti webharisamu murape kurwadziwa kwaro; 
\q2 zvimwe ringaporeswa. 
\b  
\q1  
\v 9 “ ‘Taida kuporesa Bhabhironi, 
\q2 asi haringaporeswi; 
\q1 ngatirisiyei mumwe nomumwe aende kunyika yake, 
\q2 nokuti kutongwa kwaro kunosvika kumatenga, 
\q2 kunokwira kusvikira kumakore.’ 
\b  
\q1  
\v 10 “ ‘Jehovha akati hatina mhosva; 
\q2 uyai, tiparidze muZioni 
\q2 zvakaitwa naJehovha Mwari wedu.’ 
\b  
\q1  
\v 11 “Rodzai miseve, 
\q2 torai nhoo! 
\q1 Jehovha akamutsa madzimambo avaMedhia, 
\q2 nokuti akaronga kuparadza Bhabhironi. 
\q1 Jehovha achatsiva, 
\q2 kutsivira temberi yake. 
\q1  
\v 12 Simudzai mureza pamusoro pamasvingo eBhabhironi! 
\q2 Simbisai varindi, 
\q1 isai nharirire panzvimbo dzavo, 
\q2 gadzirirai vanovandira. 
\q1 Jehovha achaita zvaakaronga, 
\q2 zvaakatema pamusoro pavanhu veBhabhironi. 
\q1  
\v 13 Imi mugere pedyo nemvura zhinji 
\q2 uye makapfuma kwazvo, 
\q1 magumo enyu asvika, 
\q2 nguva yokuti muparadzwe. 
\q1  
\v 14 Jehovha Wamasimba Ose akapika naiye amene achiti: 
\q2 Zvirokwazvo ndichakuzadza navarume, sezvinoitwa nechimokoto chemhashu, 
\q2 uye vachapembera nokuti vanenge vakukundai. 
\b  
\q1  
\v 15 “Akaita nyika nesimba rake; 
\q2 akateya nheyo dzenyika nouchenjeri hwake, 
\q2 akatatamura matenga nokunzwisisa kwake. 
\q1  
\v 16 Paanotinhira, mvura yomumatenga inotinhira; 
\q2 anokwidza makore kubva kumigumo yenyika. 
\q1 Anotuma mheni pamwe chete nemvura, 
\q2 uye anouyisa mhepo kubva mumatura ake. 
\b  
\q1  
\v 17 “Munhu mumwe nomumwe haana pfungwa uye haana zivo; 
\q2 mupfuri mumwe nomumwe wesimbi anonyadziswa nezvifananidzo zvake. 
\q1 Zvifananidzo zvake ndezvenhema; 
\q2 hazvina mweya mazviri. 
\q1  
\v 18 Hazvina maturo, zvinhu zvinosekwa; 
\q2 kana kutongwa kwazvo kwasvika, zvichaparadzwa. 
\q1  
\v 19 Iye Mugove waJakobho haana kufanana naizvozvi, 
\q2 nokuti ndiye Muiti wezvinhu zvose, 
\q1 pamwe chete norudzi rwenhaka yake, 
\q2 Jehovha Wamasimba Ose ndiro zita rake. 
\b  
\q1  
\v 20 “Ndiwe tsvimbo yangu yehondo, 
\q2 chombo changu chokurwa, 
\q1 newe ndinoparadza ndudzi, 
\q2 newe ndinoparadza umambo, 
\q1  
\v 21 newe ndinoparadza bhiza nomutasvi, 
\q2 newe ndinoparadza ngoro nomuchairi, 
\q1  
\v 22 newe ndinoparadza murume nomukadzi, 
\q2 newe ndinoparadza mutana nejaya, 
\q2 newe ndinoparadza jaya nomurandakadzi, 
\q1  
\v 23 newe ndinoparadza mufudzi neboka, 
\q2 newe ndinoparadza murimi nenzombe, 
\q2 newe ndinoparadza vatongi namachinda. 
\p  
\v 24 “Ndicharipira Bhabhironi navose vagere muBhabhironi pamberi pako, nokuda kwezvakaipa zvavakaita muZioni,” ndizvo zvinotaura Jehovha. 
\q1  
\v 25 “Ndine mhosva newe, iwe gomo rinoparadza, 
\q2 iwe unoparadza nyika yose,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1 “Ndichatambanudzira ruoko rwangu kuti ndikurwise, 
\q2 ndigokukungurusira kumawere, 
\q2 ndigokuita gomo rakatsva. 
\q1  
\v 26 Hapana dombo richabviswa kwauri kuti riitwe dombo rekona, 
\q2 kana dombo remhepo, 
\q2 nokuti uchaparadzwa nokusingaperi,” 
\q4 ndizvo zvinotaura Jehovha. 
\b  
\q1  
\v 27 “Simudzai mureza munyika! 
\q2 Ridzai hwamanda pakati pendudzi! 
\q1 Gadzirirai ndudzi kuti dzizorwa naye; 
\q2 kokai ushe uhu kuzorwa naye: 
\q2 Ararati, Mini neAshikenazi. 
\q1 Gadzai mukuru wehondo kuti arwe naye; 
\q2 tumirai mabhiza akaita sechimokoto chemhashu. 
\q1  
\v 28 Gadzirirai ndudzi kuti dzizorwa naye, 
\q2 madzimambo avaMedhia, 
\q1 vabati vavo namachinda avo ose, 
\q2 nenyika dzose dzavanotonga. 
\q1  
\v 29 Nyika inodedera uye yomonyoroka, 
\q2 nokuti zvakarongwa naJehovha pamusoro peBhabhironi hazvingatongokoni, 
\q1 zvokuparadza nyika yeBhabhironi 
\q2 kuti pasava nomunhu achagaramo. 
\q1  
\v 30 Mhare dzeBhabhironi dzarega kurwa; 
\q2 vakarambira munhare dzavo. 
\q1 Simba ravo rapera; 
\q2 vaita savakadzi. 
\q1 Ugaro hwake hwakapiswa nomoto; 
\q2 mazariro amasuo ake avhunika. 
\q1  
\v 31 Anotumwa namagwaro achatevera mumwe, 
\q2 uye nhume ichatevera nhume, 
\q1 kundozivisa mambo weBhabhironi 
\q2 kuti guta rake rose rapambwa, 
\q1  
\v 32 mazambuko abatwa, 
\q2 mapani apiswa nomoto, 
\q2 uye varwi vavhundutswa.” 
\p  
\v 33 Zvanzi naJehovha Wamasimba Ose, Mwari waIsraeri: 
\q1 “Mwanasikana weBhabhironi afanana neburiro 
\q2 panguva yokupura; 
\q2 nguva yokumukohwa ichasvika zvino zvino.” 
\b  
\q1  
\v 34 “Nebhukadhinezari mambo weBhabhironi akatidya, 
\q2 akatinyonganisa, 
\q2 akatiita chirongo chisina chinhu. 
\q1 Akatimedza senyoka, 
\q2 uye akazadza dumbu rake nezvinonaka zvedu, 
\q2 mushure maizvozvo akatisvipa. 
\q1  
\v 35 Zvechisimba zvakaitwa panyama yedu ngazvive pamusoro peBhabhironi,” 
\q2 ndizvo zvinotaura vanhu vomuZioni. 
\q1 Jerusarema rinoti: 
\q2 “Ropa redu ngarive pamusoro peavo vanogara muBhabhironi.” 
\p  
\v 36 Naizvozvo, zvanzi naJehovha: 
\q1 “Tarirai, ndichakurevererai mhaka yenyu 
\q2 uye ndichakutsivirai; 
\q1 ndichapwisa gungwa raro, 
\q2 ndichapwisa matsime aro. 
\q1  
\v 37 Bhabhironi richava murwi wamatombo, 
\q2 ugaro hwamakava, 
\q1 chinhu chinotyisa nechinosekesa, 
\q2 nzvimbo isina anogaramo. 
\q1  
\v 38 Vanhu vake vose vanoomba seshumba diki, 
\q2 vanobhonʼa sembwanana dzeshumba. 
\q1  
\v 39 Asi kana vamutswa, 
\q2 ndichavagadzirira mutambo 
\q2 ndigovadhakisa, 
\q1 kuitira kuti varidze mhere yokuseka, 
\q2 vagovata nokusingaperi uye varege kumuka,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 40 “Ndichavaburutsa pasi 
\q2 semakwayana ari kundourayiwa, 
\q2 semakondobwe nembudzi. 
\b  
\q1  
\v 41 “Haiwa, Sheshaki richakundwa sei, 
\q2 kuzvirumbidza kwenyika yose kwabatwa! 
\q1 Bhabhironi rava dongo sei 
\q2 pakati pendudzi! 
\q1  
\v 42 Gungwa richakwira pamusoro peBhabhironi; 
\q2 mafungu aro anovirima acharifukidza. 
\q1  
\v 43 Maguta aro achaparadzwa, 
\q2 achava nyika yakaoma negwenga, 
\q1 nyika isingagarwi nomunhu, 
\q2 isina angapfuura nemairi. 
\q1  
\v 44 Ndicharanga Bheri muBhabhironi 
\q2 ndigomuita kuti asvipe zvaamedza. 
\q1 Ndudzi hadzichazomhanyiri kwaari. 
\q2 Uye rusvingo rweBhabhironi ruchawa. 
\b  
\q1  
\v 45 “Budai mariri, imi vanhu vangu! 
\q2 Tizai kuti muponese upenyu hwenyu! 
\q2 Tizai mubve pakutsamwa kunotyisa kwaJehovha. 
\q1  
\v 46 Regai kuora mwoyo kana kutya 
\q2 panotekeshera, runyerekupe munyika; 
\q1 rumwe runyerekupe runonzwika gore rino, rumwe gore rinouya, 
\q2 runyerekupe rwokurwisana munyika 
\q2 uye rwomutongi achirwa nomumwe mutongi. 
\q1  
\v 47 Nokuti zvirokwazvo nguva ichasvika 
\q2 yandichatonga zvifananidzo zveBhabhironi; 
\q1 nyika yaro yose ichanyadziswa, 
\q2 uye vakaurayiwa varo vachawira pasi vose mukati maro. 
\q1  
\v 48 Ipapo denga nenyika nezvose zviri mazviri 
\q2 zvichapembera nomufaro pamusoro peBhabhironi, 
\q1 nokuti vachabva nechokumusoro 
\q2 vaparadzi vacharirwisa,” 
\q4 ndizvo zvinotaura Jehovha. 
\b  
\q1  
\v 49 “Bhabhironi rinofanira kuwa nokuda kwavakaurayiwa vaIsraeri, 
\q2 sezvakaita vakaurayiwa venyika yose 
\q2 vakawa nokuda kweBhabhironi. 
\q1  
\v 50 Imi makapunyuka pamunondo, 
\q2 endai uye musamira-mira! 
\q1 Murangarire Jehovha munyika iri kure, 
\q2 uye murangarire Jerusarema.” 
\b  
\q1  
\v 51 “Takanyadziswa, 
\q2 nokuti takatukwa 
\q2 uye nyadzi dzinofukidza zviso zvedu, 
\q1 nokuti vatorwa vakapinda 
\q2 munzvimbo tsvene dzeimba yaJehovha.” 
\b  
\q1  
\v 52 “Asi mazuva anouya,” ndizvo zvinotaura Jehovha, 
\q2 “andichatonga zvifananidzo zvaro, 
\q1 uye munyika yake yose 
\q2 vakakuvara vachagomera. 
\q1  
\v 53 Kunyange dai Bhabhironi rikasvika kudenga, 
\q2 uye rikasimbisa nhare yaro yakareba, 
\q2 ndichatumira vaparadzi kuzorirwisa,” 
\q4 ndizvo zvinotaura Jehovha. 
\b  
\q1  
\v 54 “Inzwi rokuchema rinobva kuBhabhironi, 
\q2 inzwi rokuparadza kukuru 
\q2 rinobva kunyika yavaBhabhironi. 
\q1  
\v 55 Jehovha achaparadza Bhabhironi; 
\q2 achanyaradza ruzha rwokunyongana kwaro. 
\q1 Mafungu avavengi achaomba semvura zhinji; 
\q2 kutinhira kwamanzwi avo kuchanzwikwa. 
\q1  
\v 56 Muparadzi achauya kuzorwisa Bhabhironi; 
\q2 varwi varo vachabatwa, 
\q2 uye uta hwavo huchavhunwa. 
\q1 Nokuti Jehovha ndiMwari wokutsiva; 
\q2 achatsiva zvizere. 
\q1  
\v 57 Ndichaita kuti machinda ake navakachenjera vake vadhakwe, 
\q2 vabati, namachinda uye navarwi vakewo; 
\q1 vachavata nokusingaperi uye havangamuki,” 
\q2 ndizvo zvinotaura Mambo, ane zita rinonzi Jehovha Wamasimba Ose. 
\p  
\v 58 Zvanzi naJehovha Wamasimba Ose: 
\q1 “Masvingo makobvu eBhabhironi achaparadzwa, 
\q2 uye masuo aro akakwirira achapiswa; 
\q1 vanhu vanongozvinetsa pasina, 
\q2 mabasa endudzi ihuni dzomurazvo bedzi.” 
\p  
\v 59 Iri ndiro shoko rakapiwa naJeremia kumuchinda Seraya mwanakomana waNeria, mwanakomana waMaseya, paakaenda kuBhabhironi naZedhekia mambo weJudha mugore rechina rokutonga kwake.  
\v 60 Jeremia akanga anyora murugwaro pamusoro penjodzi dzose dzaizouya pamusoro peBhabhironi, zvose zvakanga zvakanyorwa pamusoro peBhabhironi.  
\v 61 Akati kuna Seraya, “Paunosvika kuBhabhironi, uone kuti waverenga mashoko ose aya uchidanidzirisa.  
\v 62 Ipapo uti, ‘Haiwa Jehovha, makati muchaparadza nzvimbo ino, zvokuti hakuna munhu kana zvipfuwo zvingagaramo; ichaparadzwa nokusingaperi.’  
\v 63 Paunopedza kuverenga rugwaro urwu, sungira ibwe parwuri ugorukanda muna Yufuratesi.  
\v 64 Ipapo uti, ‘Saizvozvo Bhabhironi richanyura rikasazomukazve nokuda kwenjodzi yandichauyisa pamusoro paro. Uye vanhu varo vachawa.’ ” 
\p Mashoko aJeremia anogumira pano. 
\c 52  
\s1 Kuwa kweJerusarema 
\p  
\v 1 Zedhekia akanga ana makore makumi maviri nerimwe paakatanga kuva mambo, uye akatonga muJerusarema kwemakore gumi nerimwe. Zita ramai vake rainzi Hamutari mwanasikana waJeremia; aibva kuRibhina.  
\v 2 Akaita zvakaipa pamberi paJehovha, sezvakangoitwa naJehoyakimi.  
\v 3 Izvi zvakaitika kuJerusarema neJudha nokuda kwehasha dzaJehovha, uye pakupedzisira akavabvisa pamberi pake. 
\p Zvino Zedhekia akamukira mambo weBhabhironi. 
\p  
\v 4 Naizvozvo mugore rechipfumbamwe rokutonga kwaZedhekia, pazuva regumi romwedzi wegumi, Nebhukadhinezari mambo weBhabhironi akasvika muJerusarema nehondo yake yose. Vakadzika misasa yavo kunze kweguta ndokuvaka nhare dzairipoteredza.  
\v 5 Guta rakaramba rakakombwa kusvikira pagore regumi nerimwe ramambo Zedhekia. 
\p  
\v 6 Pazuva rechipfumbamwe romwedzi wechina nzara yakanyanya muguta zvokuti makanga musisina chokudya chokuti vanhu vadye.  
\v 7 Ipapo rusvingo rweguta rwakapwanyiwa, hondo yose ikatiza. Vakabuda muguta usiku napasuo raiva pakati pamasvingo maviri pedyo nebindu ramambo, kunyange zvazvo vaBhabhironi vakanga vakakomberedza guta. Vakatiza vakananga kuArabha,  
\v 8 asi hondo yavaBhabhironi yakatevera Mambo Zedhekia vakamubata mumapani eJeriko. Varwi vake vose vakaparadzaniswa naye ndokupararira,  
\v 9 iye akabatwa. 
\p Vakamutora vakaenda naye kuna mambo weBhabhironi paRibhira munyika yeHamati, iye akamutongerapo.  
\v 10 Mambo weBhabhironi akauraya vanakomana vaZedhekia paRibhira ipapo, iye achizviona; akaurayirwa machinda ose eJudha.  
\v 11 Ipapo akatumbura meso aZedhekia ndokumusunga namatare akamuendesa kuBhabhironi, uko kwaakamuisa mutorongo kusvikira pazuva rokufa kwake. 
\p  
\v 12 Pazuva regumi romwedzi wechishanu, mugore regumi namapfumbamwe raNebhukadhinezari mambo weBhabhironi, Nebhuzaradhani mukuru wavarindi vamambo, uyo akashandira mambo weBhabhironi, akauya kuJerusarema.  
\v 13 Akapisa temberi yaJehovha, nomuzinda wamambo nedzimba dzose dzeJerusarema. Dzimba dzose dzaikosha akadzipisa.  
\v 14 Hondo yose yavaBhabhironi yaiva pasi pemukuru wavarindi vamambo yakaputsira pasi masvingo ose aikomberedza Jerusarema.  
\v 15 Nebhuzaradhani mukuru wavarindi akaendesa kuutapwa vamwe vakanga vari varombo chaivo navaya vakasara muguta, pamwe chete noruzhinji rwemhizha navaya vakanga vazvipira kuna mambo weBhabhironi.  
\v 16 Asi Nebhuzaradhani akasiya ruzhinji rwavarombo chaivo venyika iyo kuti vashande muminda yemizambiringa uye nemimwewo minda. 
\p  
\v 17 VaBhabhironi vakaputsa mbiru dzendarira, nezvingoro zvinofamba neGungwa rendarira zvakanga zviri mutemberi yaJehovha vakatakura ndarira yose vakaenda nayo kuBhabhironi.  
\v 18 Vakatorawo hari, nefoshoro, nembato dzemwenje, nomukombe namadhishi nemidziyo yose yendarira yaishandiswa pabasa romutemberi.  
\v 19 Mukuru wavarindi vamambo akatakurawo mbiya, nezvaenga, nemikombe nehari, nezvigadziko zvemwenje, namadhishi nemikombe yaishandiswa pazvipiriso zvokunwa, zvose zvakanga zvakagadzirwa negoridhe yakanatswa kana sirivha. 
\p  
\v 20 Ndarira yaibva pambiru mbiri, neGungwa, nehando dzendarira gumi nembiri dzaiva pasi pacho, nezvingoro zvakanga zvaitirwa temberi yaJehovha namambo Soromoni, zvakanga zvisingagoni kuyerwa.  
\v 21 Mbiru imwe neimwe yakanga ina makubhiti gumi namasere\f + \fr 52:21 \ft mamita angaita 8.1\f* pakureba uye makubhiti gumi namaviri\f + \fr 52:21 \ft mamita angaita 5.5\f* pakupoterera; paukobvu imwe neimwe yaisvika minwe mina uye yaiva nemhango.  
\v 22 Musoro wendarira waiva pane imwe mbiru wakanga wakareba makubhiti anosvika mashanu\f + \fr 52:22 \ft mamita angaita 2.3 \f* uye wakashongedzwa nezvakarukwa namatamba endarira zvaipoteredza. Imwe mbiru yakanga yakafanana nayo namatamba ayowo.  
\v 23 Pakanga pane matamba makumi mapfumbamwe namatanhatu kumativi; uwandu hwamatamba aiva pamusoro pezvakarukwa zvakanga zvakapoteredzwa hwaiva zana. 
\p  
\v 24 Mukuru wavarindi akatora vasungwa vaiti, Seraya muprista mukuru, naZefania muprista aimutevera pachigaro uye navarindi vokumukova vatatu.  
\v 25 Kuna avo vaiva muguta akatora muchinda mukuru wavarwi, uye vapi vamazano vanomwe. Akatorawo munyori uyo akanga ari mubati mukuru aiva nebasa rokunyora mazita avanhu venyika uye navamwe varume makumi matanhatu vakawanikwa muguta.  
\v 26 Nebhuzaradhani mukuru wavarindi akavatora vose akavauyisa kuna mambo weBhabhironi paRibhira.  
\v 27 Ipapo paRibhira, munyika yeHamati, mambo akaita kuti vaurayiwe. 
\p Saka vaJudha vakaenda kuutapwa, kure nenyika yavo. 
\b  
\li4  
\v 28 Uhu ndihwo uwandu hwavanhu vakatorwa naNebhukadhinezari achienda navo kuutapwa: 
\b  
\li1 mugore rechinomwe, 
\li2 zviuru zvitatu zvina makumi maviri navatatu, zvavaJudha; 
\li1  
\v 29 mugore regumi namasere raNebhukadhinezari, 
\li2 mazana masere namakumi matatu navaviri avanhu vaibva kuJerusarema; 
\li1  
\v 30 mugore rake ramakumi maviri namatatu, 
\li2 vaJudha mazana manomwe namakumi mana navashanu vakaendeswa kuutapwa naNebhuzaradhani mukuru wavarindi vamambo. 
\b  
\li4 Vose vaiva zviuru zvina namazana matanhatu pamwe chete. 
\s1 Jehoyakini anosunungurwa 
\p  
\v 31 Mugore ramakumi matatu namanomwe rokutapwa kwaJehoyakini mambo weJudha, mugore rakava Evhiri-Merodhaki mambo weBhabhironi, akasunungura Jehoyakini mambo weJudha, uye akamusunungura kubva mutorongo pazuva ramakumi maviri namashanu romwedzi wegumi nemiviri.  
\v 32 Akataura zvakanaka kwaari uye akamupa chigaro chaikudzwa kupfuura zvigaro zvamamwe madzimambo vaakanga anavo muBhabhironi.  
\v 33 Saka Jehoyakini akabvisa nguo dzake dzousungwa akadya patafura yamambo nguva nenguva, mazuva ose oupenyu hwake.  
\v 34 Zuva nezuva mambo weBhabhironi akapa Jehoyakini mugove wenguva nenguva, mazuva ose oupenyu hwake, kusvikira pazuva rokufa kwake.