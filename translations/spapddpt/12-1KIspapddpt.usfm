\c 22
\s1 Josafat y Acab contra los invasores sirios
\p 
\v 1 \w Tres|strong="H7969"\w* \w años|strong="H8141"\w* \w pasaron|strong="H3427"\w* sin \w guerra|strong="H4421"\w* entre Siria \w e|strong="H3068"\w* \w Israel|strong="H3478"\w*.
