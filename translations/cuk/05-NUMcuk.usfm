\id NUM - Kuna, San Blas - Bible -Panama 2014 (DBL -2014)
\h Números
\toc1 Números-Garda
\toc2 Números
\toc3 Mn
\mt1 NÚMEROS-GARDA
\mt2 NÚMEROS
\imt2 GEBE-SOGLENAID
\imt1 Garda-nug
\ip \it Números-Garda.\it* We-garda, Garda-Sogataled-sogabakedid. Latín-gayabali, \it Liber numerorumʼye\it* sogleged. “Númerosʼye” bileged. Hebreo-gayabardina, \it Bemidbarʼye\it* nugad. We-sogleged, \it “Nega-dulesulidganbarye.”\it* Wede Sinaí-yalagi bukwamaladgi ibmar-gusadgi sunmaked.
\is1 Números-gardagi weyob sunmaklenaid
\ip We-gardagine, ilabo nega-dulesulidganba Israel-dulemar-ebislesadgi sunmaknaid. Gebe Sinaí-yalagi-naed-iduar ebislesad. Geb baidi, birga-dulabogwad-sorba (40), Moab-yalagi-bukwa ebislesbalid. Adi, dakega bule sorda-bila-onomaladi mergue, degidbali, ega napamar-uklegegar.
\ip We-gardagi anmarga oyonaid, igi Israel-dulemar nega-dulesulidganbali nadapi gusmala. Bonigan-abalagi nadapi gusmalad, degi, imbagwenale, bukib-itoardamalad, wiles itoardamalad. Degidbali, Bab-Dummadgi uayasuli guardamalad. Moisés-ega-ibmar-sogedba ibmar-imakbi dasurmalad. Imbagwenale, gannar Bab-Dummad-ega-ibmar-sogedba nanaardamalad. Degite, Bab-Dummad e-dulamargi gwen-bangussulid.
\ip We-gardagine, weyob ilemakar sunmaklenaid:
\io1 1. Israel-dulemar Sinaí-yargi ambikusmalad (1:1–10:10).
\io1 2. Israel-dulemar Moab-yarse nadapigusad (10:11–21:35).
\io1 3. Israel-dulemar Moab-nebagangi ambikudapmalad (22:1–36:13).
\ip Be itogua.
\c 1
\ms1 1. ISRAEL-DULEMAR SINAÍ-YARGI AMBIKUSMALAD
\mr (1:1–10:10)
\s1 Sinaí-yargi-Israel-dulemar-ebislesad
\p 
\v 1 Israel-dulemar birgabogus gaka nii-warbo-ibagwengusa Egipto-yargi-bukwa ainisgusmaladgine, Bab-Jehová Sinaí-nega-dulesulidganba, dulemarbo-ambikued-neggi, Moisésʼga sunmaksad. Weyob ega sogded:
\p 
\v 2 “Bela Israel-dulemar be ebiso, na e-dadgan-e-dadganba, na e-gwenadgan-e-gwenadganba be ebiso. Bela machergan-irba e-nug be meso.
\v 3 Bee be, be-ia-Aarónʼbo, dulemar-ilekwaa na e-sordamar-bukwadba machergan birga-durgwen (20) nikamalad, degi, birga-durgwen-obine (20+) nikamalad, sunna dule-bila-onogedse-namalad be ebiso.
\v 4 Bemar-bendakega bemar-dadgan-warambe-gakabogwad-war-wargwengi, neguyagi-dummadga-gudiid be suoed.”
\s1 Nug-weega-nugsalesmalad
\p 
\v 5 Bab-Jehová Moisésʼga sogdebalid: “We-dulemala, bemar-bendakmaloedid:
\q2 Rubén-e-wagansik, Sedeur-machi-Elisur.
\q2 
\v 6 Simeón-e-wagansik, Zurisadai-machi-Selumiel.
\q2 
\v 7 Judá-e-wagansik, Aminadab-machi-Naasón.
\q2 
\v 8 Isacar-e-wagansik, Zuar-machi-Natanael.
\q2 
\v 9 Zabulón, e-wagansik, Helón-machi-Eliab.
\q2 
\v 10 José-e-masmalasikdi:
\q3 Efraín-e-wagansik, Amiud-machi-Elisama.
\q3 Manasés-e-wagansik, Pedasur-machi-Gamaliel.
\q2 
\v 11 Benjamín-e-wagansik, Gedeoni-machi-Abidán.
\q2 
\v 12 Dan-e-wagansik, Amisadai-machi-Ahiezer.
\q2 
\v 13 Aser-e-wagansik, Ocrán-machi-Pagiel.
\q2 
\v 14 Gad-e-wagansik, Deuel-machi-Eliasaf.
\q2 
\v 15 Neftalí-e-wagansik, Enán-machi-Ahira.”
\q3 
\v 16 Wemala, dule-dummagan-nuga-nikamalad Israel-dulemar-dadgan-warambe-gakabogwad-abargi (12) onugsalesmalad-dake.
\q3 Wemala, Israel-dulemar-idumaladga nugsalesmaladid.
\s1 Dule-nug-welesmalad-ebislesad
\p 
\v 17 Degisoggu, Moisés, degi, Aarón, we-dulemar-nugsalesmaladse e-nugba ese gochasunnad.
\v 18 Nii-warbogwad gebe-iba-onodedgi, Moisés bela dulemar-danar urbisad. Geb degine, machergan na e-dadgan-e-dadganba, na e-gwenadgan-e-gwenadganba bela e-nugmar mesisad. Bela machergan birga-dulagwen-nikad (20), degine, birga-dulagwen-obine-nikamaladi (20+), e-nugmar narmaklesad.
\v 19 Ar Bab-Jehová igi Moisésʼga-sogsagusa, deyob, Moisés Sinaí-nega-dulesulidganba dulemar-ebichisad.
\p 
\v 20 Rubén, Israel-e-machi-sailagined, a-e-wagan, na e-dadgan-e-dadganba, degine, na e-gwenadgan-e-gwenadganba, na wala-walagwen,
\q1 bela machergan birga-durgwen-nikad (20), degine, birga-durgwen-obine-nikamaladi (20+), sunna dule-bila-onogedse-namalad-e-nugmar mesilesad.
\q2 
\v 21 Rubén-wagan, mili-dulabo-gakanergwa gaka dulataled-ilatar-mergu (46,500) dakleardo.
\p 
\v 22 Simeón-wagan, na-e-dadgan-e-dadganba, na e-gwenadgan-e-gwenadganba, na wala-walagwen,
\q1 bela machergan birga-durgwen-nikad (20), degine, birga-durgwen-obine-nikamaladi (20+), sunna dule-bila-onogedse-namalad-e-nugmar mesilesad.
\q2 
\v 23 Simeón-wagan, mili-dulabo-gakambe-gakabakebak gaka dulataled-ilapaa-mergu (59,300) dakleardo.
\p 
\v 24 Gad-wagan, na e-dadgan-e-dadganba, na e-gwenadgan-e-gwenadganba, na wala-walagwen,
\q1 bela machergan birga-durgwen-nikad (20), degine, birga-durgwen-obine-nikamaladi (20+), sunna dule-bila-onogedse-namalad-e-nugmar mesilesad.
\q2 
\v 25 Gad-wagan, mili-dulabo-gakatar gaka dulataled-ilanergwa gaka dulabo-gakambe-mergu (45,650) dakleardo.
\p 
\v 26 Judá-wagan, na e-dadgan-e-dadganba, na e-gwenadgan-e-gwenadganba, na wala-walagwen,
\q1 bela machergan birga-durgwen-nikad (20), degine, birga-durgwen-obine-nikamaladi (20+), sunna dule-bila-onogedse-namalad-e-nugmar mesilesad.
\q2 
\v 27 Judá-wagan, mili-dulapaa-gakambe-gakabake gaka dulataled-ilanergwa-mergu (74,600) dakleardo.
\p 
\v 28 Isacar-wagan, na e-dadgan-e-dadganba, na e-gwenadgan-e-gwenadganba, na wala-walagwen,
\q1 bela machergan birga-durgwen-nikad (20), degine, birga-durgwen-obine-nikamaladi (20+), sunna dule-bila-onogedse-namalad-e-nugmar mesilesad.
\q2 
\v 29 Isacar-wagan, mili-dulabo-gakambe-gakabake gaka dulataled-ilabake-mergu (54,400) dakleardo.
\p 
\v 30 Zabulón-wagan, na e-dadgan-e-dadganba, na e-gwenadgan-e-gwenadganba, na wala-walagwen,
\q1 bela machergan birga-durgwen-nikad (20), degine, birga-durgwen-obine-nikamaladi (20+), sunna dule-bila-onogedse-namalad-e-nugmar mesilesad.
\q2 
\v 31 Zabulón-wagan, mili-dulabo-gakambe-gakagugle gaka dulataled-ilabake-mergu (57,400) dakleardo.
\p 
\v 32 José-masmaladi, Efraín-wagansik, na e-dadgan-e-dadganba, na e-gwenadgan-e-gwenadganba, na wala-walagwen,
\q1 bela machergan birga-durgwen-nikad (20), degine, birga-durgwen-obine-nikamaladi (20+), sunna dule-bila-onogedse-namalad-e-nugmar mesilesad.
\q2 
\v 33 Efraín-wagan, mili-dulabo gaka dulataled-ilatar-mergu (40,500) dakleardo.
\p 
\v 34 Manasés-wagansikdi, na e-dadgan-e-dadganba, na e-gwenadgan-e-gwenadganba, na wala-walagwen,
\q1 bela machergan birga-durgwen-nikad (20), degine, birga-durgwen-obine-nikamaladi (20+), sunna dule-bila-onogedse-namalad-e-nugmar mesilesad.
\q2 
\v 35 Manasés-wagan, mili-dulagwen-gakambe-gakabo gaka dulataled-ilabo-mergu (32,200), dakleardo.
\p 
\v 36 Benjamín-wagan, na e-dadgan-e-dadganba, na e-gwenadgan-e-gwenadganba, na wala-walagwen,
\q1 bela machergan birga-durgwen-nikad (20), degine, birga-durgwen-obine-nikamaladi (20+), sunna dule-bila-onogedse-namalad-e-nugmar mesilesad.
\q2 
\v 37 Benjamín-wagan, mili-dulagwen-gakambe-gakatar gaka dulataled-ilabake-mergu (35,400), dakleardo.
\p 
\v 38 Dan-wagan, na e-dadgan-e-dadganba, na e-gwenadgan-e-gwenadganba, na wala-walagwen,
\q1 bela machergan birga-durgwen-nikad (20), degine, birga-durgwen-obine-nikamaladi (20+), sunna dule-bila-onogedse-namalad-e-nugmar mesilesad.
\q2 
\v 39 Dan-wagan, mili-dulapaa-gakabo gaka dulataled-ilagugle-mergu (62,700) dakleardo.
\p 
\v 40 Aser-e-wagan, na e-dadgan-e-dadganba, na e-gwenadgan-e-gwenadganba, na wala-walagwen,
\q1 bela machergan birga-durgwen-nikad (20), degine, birga-durgwen-obine-nikamaladi (20+), sunna dule-bila-onogedse-namalad-e-nugmar mesilesad.
\q2 
\v 41 Aser-wagan, mili-dulabo-gakagwensak gaka dulataled-ilatar-mergu (41,500) dakleardo.
\p 
\v 42 Neftalí-wagan, na e-dadgan-e-dadganba, na e-gwenadgan-e-gwenadganba, na wala-walagwen,
\q1 bela machergan birga-durgwen-nikad (20), degine, birga-durgwen-obine-nikamaladi (20+), sunna dule-bila-onogedse-namalad-e-nugmar mesilesad.
\q2 
\v 43 Neftalí-wagan, mili-dulabo-gakambe-gakapaa gaka dulataled-ilabake-mergu (53,400) dakleardo.
\p 
\v 44 Moisés, Aarón, degi, Israel-dummagan-na-e-dadgangi-war-wargwen-sulearmalad, we-dulemar-ebichismalad.
\q1 
\v 45 Bela Israel-dulemar birga-durgwen-nikad (20), degine, birga-durgwen-obine-nikamalad (20+), sunna dule-bila-onogedse-namalad-e-nugmar, na e-gwenadgan-e-gwenadganba bela mesilesad.
\q2 
\v 46 Bela Israel-dulemar-e-nug, mili-dulataled-ilanergwa-gakapaa gaka dulataled-ilatar gaka dulabo-gakambe-mergu (603,550) mesilesad.
\s1 Leví-wagan-nugsalesmalad
\p 
\v 47 Leví-wagandi, na e-gwenadgan-e-gwenadganba, amardi Israel-dulemar-baiganba ebislessurmalad.
\v 48 Ar ade, Bab-Jehová Moisésʼga sogsagusad:
\v 49 “Unnila Leví-waganbi Israel-dulemar-abargi be ebisosulid.
\v 50 Be, Levita-dulemar Dulemar-Anbo-Igar-Mesisad-E-Neg-dakega be imakoed. Degine, a-neggi-ibmar-ebulemalad, degi, bela a-negga-ibmar-ebulemalad-dakega, be imakbaloed. Levita-dulemala, anse-goled-neg-sunna-seleged, degine, bela e-ibmarmar-agi-ebulemalad semaloed. Degine, Levita-dulemarbi agi arbamaloed. Degine, a-neg-dikar-ebilis megmaloed. A-ular, Leví-e-wagan be ebisosulid.”
\p 
\v 51 Bab-Dummad Moisésʼga sogdebalid: “Anse-goled-neg-sunna-seleged seledsokalile, Levita-dulemar a-neg earoed. A-neg gannar osisokarmalale, Levita-dulemar osimarbaloed. Dule-baid, Levita-dulesulid a-negse warmaksale, oburgwilegoed.
\v 52 Israel-dulemar na danar-danar, degine, na e-bander-e-bander-urba ambikumaloed. E-sordamar-bila-onomalad-ilemakar ega soglesadba ambikumaloed.
\v 53 Levita-dulemardi, Dulemar-Anbo-Igar-Mesisad-E-Neg-dikar-ebilis ambikumaloed, adi, melle an-urwed Israel-dulemargi yolegegar. Levitaʼmar, Dulemar-Anbo-Igar-Mesisad-E-Neg edarboed.”
\p 
\v 54 Israel-dulemala bela Bab-Jehová-Moisésʼga-ibmar-sogsadba imaksamalad. Ar deyob bela imaksamardo.
\c 2
\s1 Israel-dulemar-danar-danar-ambikusmalad-igar
\p 
\v 1 Bab-Jehová Moisésʼga, degi, Aarónʼga sunmakded, amarga sogded:
\v 2 “Israel-dulemala dulemar-anbo-ambikued-neg-ebilis ambikumaloed, na egad-egad, e-dadgan-e-dadgan-e-bander-urba bukwa gumaloed.
\p 
\v 3 ”Wemala, dulemar-anbo-ambikued-neg-siid-dad-nakwedsik ambikumaloed:
\q1 Gebedgi, Judá-wagan, na e-bander-urba e-sordamarba ambikumaloed.
\q2 Judá-wagan-e-dummad Naasónʼye nugad. Naasónʼde Aminadab-e-machid.
\q3 
\v 4 E-sordamar ebislesmaladba,
\q3 mili-dulapaa-gakambe-gakabake gaka dulataled-ilanergwa (74,600) mergued.
\b
\q1 
\v 5 ”Judá-wagan-dikarba, Isacar-wagan ambikuoed.
\q2 Isacar-wagan-e-dummad Natanaelʼye nugad. Natanaelʼde Zuar-e-machid.
\q3 
\v 6 E-sordamar ebislesmaladba,
\q3 mili-dulabo-gakambe-gakabake gaka dulataled-ilabake (54,400) mergued.
\b
\q1 
\v 7 ”Baid-dikarsik Zabulón-wagan ambikumarmogoed.
\q2 Zabulón-wagan-e-dummad Eliabʼye nugad. Eliabʼde Helón-e-machid.
\q3 
\v 8 E-sordamar ebislesmaladba,
\q3 mili-dulabo-gakambe-gakagugle gaka dulataled-ilabake (57,400) mergued.
\b
\q1 
\v 9 ”Bela Judá-wagan-bukwamaladgi, sordamar-sogapaa-ebislesmaladba,
\q2 bular mili-dulabakebak-gakanergwa gaka dulataled-ilabake (186,400) mergued.
\q3 Judá-wagan, na e-sordamar-nanadapmalad idunadapi gumaloed.
\b
\q1 
\v 10 ”Rubén-wagan, na-e-bander-urba, e-sordamarba dulemar-anbo-ambikued-neg-siid-dad-nakwed-argan-nuedsik ambikumaloed.
\q2 Rubén-wagan-e-dummad Elisurʼye nugad. Elisurʼde Sedeur-e-machid.
\q3 
\v 11 E-sordamar ebislesmaladba,
\q3 mili-dulabo-gakanergwa gaka dulataled-ilatar (46,500) mergued.
\b
\q1 
\v 12 ”Rubén-wagan-dikarba, Simeón-wagan ambikuoed.
\q2 Simeón-wagan-e-dummad Selumielʼye nugad. Selumielʼde Zurisadai-e-machid.
\q3 
\v 13 E-sordamar ebislesmaladba,
\q3 mili-dulabo-gakambe-gakabakebak gaka dulataled-ilapaa (59,300) mergued.
\b
\q1 
\v 14 ”Baid-dikarsik Gad-wagan ambikumarmogoed.
\q2 Gad-wagan-e-dummad Eliasafʼye nugad. Eliasafʼde Reuel-e-machid.
\q3 
\v 15 E-sordamar ebislesmaladba,
\q3 mili-dulabo-gakatar gaka dulataled-ilanergwa gaka dulabo-gakambe (45,650) mergued.
\b
\q1 
\v 16 ”Bela Rubén-wagan-bukwamaladgi, sordamar-sogapaa-ebislesmaladba,
\q2 bular mili-dulagugle-gakambe-gakagwensak gaka dulataled-ilabake gaka dulabo-gakambe (151,450) mergued.
\q3 Rubén-wagan, Judá-sordamar-sorba, na e-sordamar-nanaimaladba nadapi gumaloed.
\p 
\v 17 ”Geb degine, a-sorbali, Levita-dulemar, dulemar-anbo-ambikued-neg semai gumaloed. We-negde, Israel-dulemar-negabargi siidaed. Ar igi Levita-dulemar na bukwa-daniki, deyob na e-bander-e-bander senadapi gumaloed.
\q1 
\v 18 Efraín-wagan e-bander-urba, dulemar-anbo-ambikued-neg-siid-dad-argwanedsik ambikumaloed.
\q2 Efraín-wagan-e-dummad Elisamaʼye nugad. Elisamaʼde Amiud-e-machid.
\q3 
\v 19 E-sordamar ebislesmaladba,
\q3 mili-dulabo gaka dulataled-ilatar (40,500) mergued.
\b
\q1 
\v 20 ”Efraín-wagan-dikarba, Manasés-wagan ambikuoed.
\q2 Manasés-wagan-e-dummad Gamalielʼye nugad. Gamalielʼde Pedasur-e-machid.
\q3 
\v 21 E-sordamar ebislesmaladba,
\q3 mili-dulagwen-gakambe-gakabo gaka dulataled-ilabo (32,200) mergued.
\b
\q1 
\v 22 ”Baid-dikarsik Benjamín-wagan ambikumarmogoed.
\q2 Benjamín-wagan-e-dummad Abidánʼye nugad. Abidánʼde Gedeoni-e-machid.
\q3 
\v 23 E-sordamar ebislesmaladba,
\q3 mili-dulagwen-gakambe-gakatar gaka dulataled-ilabake (35,400) mergued.
\b
\q1 
\v 24 ”Bela Efraín-wagan-bukwamaladgi, sordamar-sogapaa-ebislesmaladba,
\q2 bular mili-dulatar-gakabaabak gaka dulataled (108,100) mergued.
\q3 Efraín-wagan, na e-sordamar-nanaimaladba danakwaa-nadapmalad-sogapaagi nadapi gumaloed.
\b
\q1 
\v 25 ”Dan-wagan e-bander-urba, dulemar-anbo-ambikued-neg-siid-dad-nakwed-argan-sapiledsik ambikuoed.
\q2 Dan-wagan-e-dummad Ahiezerʼye nugad. Ahiezerʼde Amisadai-e-machid.
\q3 
\v 26 E-sordamar ebislesmaladba,
\q3 mili-dulapaa-gakabo gaka dulataled-ilagugle (62,700) mergued.
\b
\q1 
\v 27 ”Dan-wagan-dikarba, Aser-wagan ambikuoed.
\q2 Aser-wagan-e-dummad Pagielʼye nugad. Pagielʼde Ocrán-e-machid.
\q3 
\v 28 E-sordamar ebislesmaladba,
\q3 mili-dulabo-gakagwensak gaka dulataled-ilatar (41,500) mergued.
\b
\q1 
\v 29 ”Degine, baid-dikarsik Neftalí-wagan ambikumarmogoed.
\q2 Neftalí-wagan-e-dummad Ahiraʼye nugad. Ahiraʼde Enán-e-machid.
\q3 
\v 30 E-sordamar ebislesmaladba,
\q3 mili-dulabo-gakambe-gakapaa gaka dulataled-ilabake (53,400) mergued.
\b
\q1 
\v 31 ”Bela Dan-wagan-bukwamaladgi, sordamar-sogapaa-ebislesmaladba,
\q2 bular mili-dulagugle-gakambe-gakagugle gaka dulataled-ilanergwa (157,600) mergued.
\q3 Dan-wagan, napi-solaba na e-bander senadapi gumaloed.”
\p 
\v 32 Wemala, Israel-dulemar na e-gwenad-e-gwenadganba ebislesmaladid. Bela danar-danar-bukwamaladgi, na e-sorda-e-sordamar-ebislesmaladba, mili-dulataled-ilanergwa-gakapaa gaka dulataled-ilatar gaka dulabo-gakambe (603,550), bela mergued.
\v 33 Ar igi Bab-Jehová Moisésʼga igar-uksadba, Leví-wagandi we-Israel-dulemarba ebislessurmalad.
\p 
\v 34 Israel-dulemala bela Bab-Jehová-Moisésʼga-igar-uksadba imaksamalad. Bela na e-bander-e-bander-urba ambikusmalad, degine, na e-dadgan-e-dadganba, na e-gwenad-e-gwenadganba nadapi gusmalad.
\c 3
\s1 Leví-wagan-Aarónʼsikid
\p 
\v 1 Deun, Bab-Jehová Sinaí-yargi Moisésʼga sunmaksagusgu, weyobi, Aarón-wagan, degi, Moisés-wagan gardagi-narmaklegar mesilesad.
\q1 
\v 2 Weyobi, Aarón-masmala nugmalad:
\q2 Nadab, Abiú, Eleazar, Itamar.
\q3 Nadabʼde, e-machi-sailaginedid.
\p 
\v 3 We-Aarón-masmala, dule-irwa-Bab-Dummadse-gormaladga sulesmalad. Wemarde, Bab-Dummadse-dule-irwa-goledga-gumalaga nug-imaklesmalad.
\p 
\v 4 Sinaí-nega-dulesulidganba Nadab, degi, Abiúʼbo, igar-maisulidba Bab-Jehováʼga ibmar-ogumakar uksamalad. A-ular, amar Bab-Jehová-asabin burgwismarsunnad. Wemar-warbogwad mimmi-nikussurmalad. Unnila, Eleazar, degi, Itamar, wemarbi e-bab-Aarón-asabin dule-irwa-Bab-Dummadse-goledga arbananai gusmalad.
\s1 Leví-wagan-baigan-e-arbaed
\p 
\v 5 Bab-Jehová Moisésʼga sunmakded, ega sogded:
\v 6 “Leví-wagan, dule-irwa-anse-goled-Aarón-asabin be sedage. We-Leví-waganmar, Aarón-ibmar-imakedgi Aarón-bendakmaloed.
\v 7 Amala, dulemar-anbo-ambikued-neggi Aarónʼga, degi, bela Israel-dulemarga arbananai gumaloed.
\v 8 We-Leví-wagan dulemar-anbo-ambikued-neggi bela ibmarmar-ebulemalad akwemaloed. Degine, anse-goled-neg-sunna-selegedgi Israel-dulemar-ular ibmar imakoed.
\v 9 We-Leví-wagan, Aarón, degi, e-masmala-bendakega be imakoed. Wemala, Israel-dulemar-abargine bachikii sulesmalad, anga arbaegar.
\v 10 Aarón, degi, e-masmaladi, dule-irwa-anse-goledga be imakoed. Ar dule-baid, dule-irwa-anse-goledsulid anse-goled-negse warmakele, oburgwilegoed.”
\s1 Leví-wagan-baigan-onugsalesmalad
\p 
\v 11 Bab-Jehová Moisésʼga sunmakded, ega sogded:
\v 12 “Ani an Israel-dulemar-abargi Leví-wagan-baigan bela Israel-machi-sailaginmalad-anar an susad. Ar bela machimala-sailaginmalad angadsoggu, Leví-wagan-baigan angadga gusunnodo.
\v 13 Egipto-yalagi bela machi-sailaginmalad an oburgwisgua, ani an Israel-machi-sailaginmalad angadga-guega an susad. Deyob dulemar, degi, ibdurganse-bakale, an imaksad. Ar we-ibdurgan, bela angadid. Ani an Bab-Jehová gued.”
\s1 Leví-wagan-baigan-ebislesmalad
\p 
\v 14 Bab-Jehová Sinaí-nega-dulesulidganba, Moisésʼga sunmaksad, ega sogded:
\v 15 “Leví-wagan-baigan na e-dadgan-e-dadganba, degi, na e-gwenad-e-gwenadganba be ebiso. Bela-machergan be ebisoed, susmar-nii-wargwen-nikamaladse-bakar, be ebisoed.”
\p 
\v 16 Moisés, Bab-Jehová-ega-igar-uksadba, bela Leví-wagan-baigan ebichisad.
\q1 
\v 17 Leví-masmala, wemalad:
\q2 Gersón, Coat, degi, Merari.
\q1 
\v 18 Gersón-masmaladi, wemarmogad:
\q2 Libni, Simei.
\q1 
\v 19 Coat-masmaladi, wemarmogad:
\q2 Amram, Izhar, Hebrón, degi, Uziel.
\q1 
\v 20 Merari-masmaladi, wemarmogad:
\q2 Mahli, Musi.
\q3 Leví-wagan-baigan na e-dadgan-e-dadganba weyob gumalad, na e-gwenad-e-gwenadganba ebislesad.
\s1 Gersón-wagan
\q1 
\v 21 Libni-wagan-danaled, degi, Simei-wagan-danaled Gersónʼgi danimalad.
\q2 Wemala, Gersón-wagan gumardo.
\q1 
\v 22 We-e-sordamar bela machergan-ebislesmalad, susmala-nii-wargwen-nikamaladse-bakar-ebislesmaladi,
\q2 miligugle gaka dulataled-ilatar (7,500) mergued.
\q1 
\v 23 Gersón-wagan dad-argwanedsik Bab-Dummadse-goled-neg-sunna-seleged-yarganba, bukusmalad.
\q2 
\v 24 Gersón-wagan-e-dummad Eliasafʼye nugad. Eliasafʼde Lael-e-machid.
\b
\q1 
\v 25 Gersón-wagan we-ibmar-imakmalaga gumalad:
\q2 Bab-Dummad-dulemarbo-ambikued-neg-dakedga.
\q2 Ibmar-ukamar Bab-Dummadse-goled-neg e-uasga-gunaid-dakedga.
\q2 A-yawagak-dogedgi-mor-dummad-naid-dakedga.
\q2 
\v 26 Mor-dummad bela Bab-Dummadse-goled-neg, degi, ibmar-ogumakar-ukleged-aila-ebirnaid-dakedga.
\q2 Degine, e-yawagakgi mor-dummad-naid, bela urdubmar-agi-ebulemaladse-bakar-dakedga gumalad.
\s1 Coat-wagan
\q1 
\v 27 Amram-wagan-danaled, Izhar-wagan-danaled, Hebrón-wagan-danaled, degi, Uziel-wagan-danaled Coatʼgi danimalad.
\q2 Wemar, Coat-wagan gumalad.
\q1 
\v 28 We-e-sordamar bela machergan-ebislesmaladi, degi, susmala-nii-wargwen-nikamaladse-bakar-ebislemaladi,
\q2 milibaabak gaka dulataled-ilanergwa (8,600) mergued.
\q3 Wemala, Bab-Dummadse-goled-neg-dakmaladga gumalad.
\q1 
\v 29 Coat-wagan, dad-nakwed-argan-nuedsik Bab-Dummadse-goled-neg-sunna-seleged-dikarba, bukusmalad.
\q2 
\v 30 Coat-wagan-e-dummad Elizafánʼye nugad. Elizafánʼde Uziel-e-machid.
\b
\q1 
\v 31 Coat-wagan we-ibmar-imakmalaga gumalad:
\q2 Bab-Dummad-Israel-Dulemarbo-Igar-Mesisad-Ulu-dakedga.
\q2 Mese-dakedga.
\q2 Gwallumar-sied-dakedga.
\q2 Ibmar-ogumakar-uklemalad-ailamar-dakedga.
\q2 Bab-Dummadse-goled-neggi-ibmar-ebulemalad-dakedga.
\q2 Mor-dummagan-dakedga.
\q2 Degi, bela agi ibmarmar-ebulesiid dakedga gumalad.
\p 
\v 32 Leví-wagan-baigan-e-dummad Eleazarʼye nugad Aarón-e-machid. Aarónʼde dule-irwa-Bab-Dummadse-goledid. Eleazarʼde Bab-Dummadse-goled-neg-sunna-seleged-dakmalad-e-dummadid.
\s1 Merari-wagan
\q1 
\v 33 Mahli-wagan-danaled, degi, Musi-wagan-danaled, Merariʼgi danimalad.
\q2 Wemar, Merari-wagan gumalad.
\q1 
\v 34 We-e-sordamar, bela machergan-ebislesmalad, susmar-nii-wargwen-nikamaladse-bakar-ebislesmaladi,
\q2 milinergwa gaka dulataled-ilabo (6,200) mergued.
\q1 
\v 35 Merari-wagan, dad-nakwed-argan-sapiledsik Bab-Dummadse-goled-neg-sunna-seleged-dikarba bukusmalad.
\q2 Merari-wagan-e-dummad Zurielʼye nugad. Zurielʼde, Abihail-e-machid.
\b
\q1 
\v 36 Merari-wagan we-ibmar-dakmalaga gumalad:
\q2 Bab-Dummadse-goled-neg-sunna-seleged-e-urgomar-dakmaladga,
\q2 e-suarmar-dakmaladga,
\q2 e-buarmar-dakmaladga,
\q2 e-sigmalad-dakmaladga,
\q2 bela e-ibmarmar-dakmaladga,
\q2 degine, bela ibmar-egi-ebulemalad-dakmaladga.
\q2 
\v 37 Bab-Dummadse-goled-neg-e-galu-bubamar-dakmaladga,
\q2 e-sigmalad-dakmaladga,
\q2 e-bargamalad-dakmaladga,
\q2 e-dubmar-dakmaladga gumalad.
\s1 Leví-wagan
\p 
\v 38 Moisés, Aarón, degi, a-e-masmala, Bab-Dummadse-goled-neg-sunna-seleged-asabin mamaigusmalad. A-sogleged, Bab-Dummad-dulemarbo-ambikued-neg-dad-nakwedsik mamaigusmarye. Aarón, degi, e-masmala, Israel-dulemar-nuggine, Bab-Dummadse-goled-neg-sunna-seleged dakega gumalad. Dule-baigan dule-irwa-Babse-goledsulile, Bab-Dummadse-goled-negse warmaksale, oburgwilegoed.
\p 
\v 39 Moisés, degi, Aarón, Bab-Jehová-ega-sogsadba, bela Leví-wagan, machergan, degi, bela susmar-nii-wargwen-nikamaladse-bakar, na e-dadgan-e-dadganba ebichismargua, daklealid, mili-dulagwen-gakabo (22,000) mergue.
\s1 Masmala-gebesailagined-onolegoed-igar
\p 
\v 40 Bab-Jehová Moisésʼga sogded: “Israel-dulemar-e-masmala-sailaginmalad, nii-wargwen-nikamaladse-bakale, bela ebiso, degine, e-nugmar be narmakbalo.
\p 
\v 41 ”Geb degine, Israel-masmala-gebesailaginmalad-anar bela Leví-wagan be suo. Geb deginbali, bela Israel-dulemar-e-ibdurgan-gebemalad-anar, Leví-wagan-e-ibdurgan be subalo. Ani an Bab-Jehová gued.”
\p 
\v 42 Moisés Bab-Jehová-ega-sogsadba imaksad, bela Israel-masmala-gebesailaginmalad ebichisad.
\v 43 Bela masmala-sailaginmalad-nii-walagwen-nikamaladse-bakar-ebislesadi, a-e-nugmar-mesilesadi, mili-dulagwen-gakabo gaka dulataled-ilabo gaka dulapaa-gakambe-gakapaa (22,273) mergu daklealid.
\p 
\v 44 Geb degine, Bab-Jehová Moisésʼga sunmakded, ega sogded:
\v 45 “Bela Israel-masmala-gebesailagined-anar, Leví-wagan be suo. Degine, Israel-dulemar-e-molimar-anar, Leví-wagan-e-molimar be subalo. Leví-wagan angadga guoed. Ani an Bab-Jehová gued.
\p 
\v 46 ”Ar Israel-dulemar-e-masmala-gebesailaginmalad, Leví-wagangi dulataled-ilabo gaka dulapaa-gakambe-gakapaa (273) egi-obinedba, Israel-masmala burgoenad. Amar-onogega,
\v 47 dule-war-wargwengi mani-sibu-gwaatar be suo. A-mani Bab-Dummadse-goled-neggi-aidikuedba be suo. We-manide, gera-dulagwen (20) aidikued.
\v 48 We-manimala, bela Aarónʼga, degi, e-masmalaga be uko. We-manide Israel-masmala-gebesailaginmalad-onolesad-e-manid.”
\p 
\v 49 Moisésʼde Israel-masmala-gebesailaginmalad, Leví-wagan-obinedba manigi-onolesadi susad.
\v 50 Moisés we-mani abingasad, mani-sibu-miligwen gaka dulataled-ilapaa gaka-dulapaa-gakatar (1,365) aidikued. Bab-Dummadse-goled-neggi-mani-oaidikuedba we-mani oaidikusmalad.
\v 51 A-sorbali, Moisés, we-dule-onolesmalad-mani Aarónʼga, degi, a-e-masmalaga uksad. Moisés, ar Bab-Jehová-ega-sogsadba imaksad.
\c 4
\s1 Coat-wagan-arbamaloed
\p 
\v 1 Bab-Jehová Moisésʼga, degi, Aarónʼga sunmakded, ega sogded:
\p 
\v 2 “Leví-wagan-abargi, Coat-wagan na e-dadgan-e-dadganba, na e-gwenad-e-gwenadganba, be ebiso.
\v 3 Bela machergan birga-durgwen-gakambe-nikamalad (30), degi, birga-durbo-gakambe-nikamaladse (50), dulemar-anbo-ambikued-neggi sunna-arbamaloed, be ebiso.
\p 
\v 4 ”Coat-wagan dulemar-anbo-ambikued-neggi, ibmarmar-ise-islidikid akwega be imakoed:
\v 5 Bemar danar-danar-bukwamaladgi baid-negse-naesokarmalale, Aarón, degi, e-masmala nonimaloed, anse-goled-negse dogmaloed, mor-dummagan Nega-Ise-Islidikid-idu-nanaid weemaloed. A-morgi, Dulemar-Anbo-Igar-Mesisad-Ulu anwoed.
\v 6 A-birgine, ibdurgan-uka-nuegan oginmaloed. Geb agi, Aarón, degi, e-masmala, a-uka-birgi mor-aradbiid oginmarbaloed. Geb degine, Ulu-sedmalaga egi e-suarmar yomaloed.
\p 
\v 7 ”Madu-anga-ukleged-mese-birgi mor-arad oginmaloed. Geb agi, batemar, wesarmar, nogmar, degi, bormo-dukwa-ibmar-eogega-ebuleged urbemaloed. Madude a-mesegi bukwagu guoed.
\v 8 A-ibmarmar-birgine, mor-ginnid oginmaloed. Geb birgine, ibdurgan-uka-nuegan oginmarbaloed. Geb a-sorbali, mese-sedmalaga egi e-suarmar yomaloed.
\p 
\v 9 ”Geb degine, Aarón, degi, e-masmala mor-arad sumaloed. A-mor-aradgi gwallumar-sied anwemaloed, degi, e-gwallumar, gwallu-gwillodub-sikmalad-e-disla, e-bate-burwigana, degine, bela olivo-gwallu-simalad-e-nogmar agi anwemarbaloed.
\v 10 Geb degine, gwallumar-sied, degi, bela egi-ibmar-ebulemaladi, ibdurgan-uka-nuegangi anwemaloed. Geb degi, nabir-sedmalaga suar-wargwengi be nasikoed.
\p 
\v 11 ”Ibmar-ogumakar-ukleged-aila-olobiidi mor-aradgi anwemaloed, geb, ibdurgan-uka-nuegan e-birgi anwebaloed. Geb degine, nabir-sedmalaga e-suarmar egi yomarbaloed.
\p 
\v 12 ”Aarón, degi, e-masmala, bela ibmar-anse-goled-neggi-ebulemalad weemaloed. Geb mor-aradgi anwemaloed, degi, ibdurgan-uka-nuegangi anwemarbaloed. Geb degine, nabir-sedmalaga suar-wargwengi be nasikoed.
\p 
\v 13 ”Ibmar-ogumakar-ukleged-ailagi buru-bukwad weemaloed. Geb a-aila mor-suir-akwagiidgi anwemarbaloed.
\v 14 A-aila-birgi, bela e-ibmar-ebulemalad urbemarbaloed:
\q2 Buru-weemalad,
\q2 iko-san-obin-obin-imakmalad,
\q2 sianarmar,
\q2 degi, nog-dummagan.
\q3 A-ibmarmar-birgine, ibdurgan-uka-nuegan oginmaloed, degine, nabir-sedmalaga suarmargi nasikmaloed.
\p 
\v 15 ”Aarón, degi, e-masmala, bela anse-goled-neggi, degi, anse-goled-neggi-ibmar-ebulemalad-bukwad bela morgi anwisale, geb agi Israel-dulemar naega guakwagusale, Coat-wagan nonimaloed, a-ibmarmar sedmalagar. Degi-inigwele, ibmar-angadga-gusadi na e-argangi ebugosurmalad. Ar ebusmalale, burgwemaloed. Bela we-ibmarmar dulemarbo-an-ambikued-neggi-bukwadi, Coat-wagan sedmaloed.
\p 
\v 16 ”Eleazarʼdi, dule-irwa-anse-goled Aarónʼye-nugad-e-machid. We-Eleazarʼde gwalluga gwalludii-baloedid, degi, ina-wawadikmalad, ibmar-gwag-gusgu-ukleged, degine, olivo-gwallu-ibmarmargi-eolegega-ebuleged dakoedid. Deginbali, Eleazar bela anse-goled-neg, degine, agi bela-ibmarmar-bukwad dakbaloed. Deginbali, bela agi-ibmarmar-ebulesimalad dakbaloed.”
\p 
\v 17 Bab-Jehová Moisésʼga, degi, Aarónʼga sunmakdebalid, ega sogdebalid:
\v 18 “Leví-wagan-abargi, melle Coat-wagan-obelogega be imako.
\v 19 Coat-wagan ibmar-anga-nugsalesmaladse nonisogele, dula-gudigumalagala, melle burgwemalaga, weyob be imako.
\p ”Aarón, degi, e-masmala Coat-waganga sogoed, ibu-ibmar imakmaloe, degi, ega sogbaloed, ibu-ibmarmar sedmarbaloe.
\p 
\v 20 ”Aarón, degi, e-masmala ibmar-anga-nugsalesmalad anwelenaile, Coat-wagan dogosurmalad, degine, bipisaale dakosurmarbalid. Ar dogmalale, burgwemaloed.”
\s1 Gersón-wagan-e-arbaed
\p 
\v 21 Bab-Jehová Moisésʼga sunmakdebalid, ega sogdebalid:
\p 
\v 22 “Gersón-wagan, e-dadgan-e-dadganba, na e-gwenad-e-gwenadganba be ebiso.
\v 23 Bela machergan birga-dulagwen-gakambe-nikamalad (30), degi, birga-dulabo-gakambe-nikamaladse (50), dulemar-anbo-ambikued-neggi sunna-arbamaloed be ebiso.
\q1 
\v 24 Gersón-wagana we-ibmarmar-seedgi arbamaloed:
\q2 
\v 25 Anse-goled-neg-sunna-seleged, a-e-mor-dummagan,
\q2 Dulemar-anbo-ambikued-neg-e-mormar-anwemalad,
\q2 ibdurgan-uka-nuegan-a-neggi-akinnarmamaid,
\q2 dulemar-anbo-ambikued-neg-yawagakgi mor-dummad-naid,
\q2 
\v 26 mor-dummagan-bela-neg-imba-ebirnanaid sedmarbaloed.
\q2 Degi, ibmar-ogumakar-ukleged-ailase mor-dummagan warmaknaid,
\q2 degine, anse-goled-neg-yawagakgi mor-dummagan-warmaknanaibalid sedmarbaloed.
\q2 Geb a-e-dubmar,
\q2 degi, bela agi-ibmarmar-ebulemalad sedmarbaloed.
\p 
\v 27 ”Gersón-wagan bela na e-arbamaladgi, na ibmar semamaidgindibe, anse-goled-neggi arbananaidgindibe, bela Aarón, degi, e-masmala-sogedba ibmar imakmaloed. Gersón-waganga be sogoed, we-ibmarmar sedsokarmalale, nue salakarmaloye.
\v 28 Gersón-wagan dulemar-anbo-ambikued-neggi weyob ibmar imakmaloed.
\q1 Amarde, Itamar-ibmar-sogedba arbanai gumaloed.
\q2 We-Itamarʼde, Aarón-e-machid.
\q2 Aarónʼdi, dule-irwa-anse-goledid.”
\s1 Merari-wagan-e-arbaed
\p 
\v 29 Bab-Jehová Moisésʼga sogdebalid:
\p “Merari-wagan, e-dadgan-e-dadganba, na e-gwenad-e-gwenadganba, be ebiso.
\v 30 Bela machergan birga-dulagwen-gakambe-nikamalad (30), degi, birga-dulabo-gakambe-nikamaladse (50), sunna dulemar-anbo-ambikued-neggi arbamaloed be ebisoed.
\v 31 We-dulemar dulemar-anbo-ambikued-neggi urgomar-ebulesad sedmaloed.
\q1 A-urgomardina, wemalad:
\q2 E-suarmar,
\q2 e-buarmar,
\q2 e-sigmalad,
\q2 
\v 32 galu-ebirar buarwar-gwigwichid,
\q2 e-sigmalad,
\q2 e-bargamalad,
\q2 e-dubmar,
\q2 degi, bela e-ibmar-abelemalad sedmarbaloed.
\p ”Dule-war-wargwenga be sogoed, ibu-ibmarmar sedmaloe.
\v 33 We-arbaedi Merari-wagan, na e-dadgan-e-dadganba, degisadegu na e-arbaedgi dulemar-anbo-ambikued-neggi arbamaloed.
\q1 Itamar-ega-igar-ukedba arbamaloed.
\q2 We-Itamarʼde Aarón-e-machid.
\q2 Aarónʼdi, dule-irwa-anse-goledid.”
\s1 Coat-wagan na e-dadgan-e-dadganba-ebislesad
\p 
\v 34 Moisés, Aarón, degi, Israel-dulemar-danar-danar-bukwamalad-e-dummaganmala, Coat-wagan, na e-dadgan-e-dadganba, na e-gwenad-e-gwenadganba ebichismarsunnad.
\v 35 Bela machergan birga-durgwen-gakambe-nikamalad (30), degi, birga-durbo-gakambe-nikamaladse (50) bela sunna Bab-Dummad-dulemarbo-ambikued-neggi-arbamaloed ebichilesad.
\v 36 Weyob Coat-wagan na e-dadgan-e-dadganba ebislesmargu, milibo gaka dulataled-ilagugle gaka dulabo-gakambe (2,750) mergu daklealid.
\v 37 Weyob bela Coat-wagan e-dadgan-e-dadganba ebislesmalad. A-dulemarde bela sunna Bab-Dummad-dulemarbo-ambikued-neggi arbamaloed. Weyob Moisés, degi, Aarón, Coat-wagan ebichismalad. Bab-Jehová-Moisésʼga-igar-uksadba imaksamalad.
\s1 Gersón-wagan e-dadgan-e-dadganba-ebislesad
\p 
\v 38 Moisés, Aarón, degi, Israel-dulemar-danar-danar-bukmalad-e-dummaganmala, Gersón-wagan e-dadgan-e-dadganba, na e-gwenad-e-gwenadganba ebichismarmogad.
\v 39 Bela machergan birga-durgwen-gakambe-nikamalad (30), degi, birga-dulabo-gakambe-nikamaladse (50), sunna Bab-Dummad-dulemarbo-ambikued-neggi arbanonimaloed ebichilesad.
\v 40 Weyob Gersón-wagan e-dadgan-e-dadganba, degine, na e-gwenad-e-gwenadganba ebislesmargu, milibo gaka dulataled-ilanergwa gaka dulagwen-gakambe (2,630) mergu daklealid.
\v 41 Weyob bela Gersón-wagan, e-dadgan-e-dadganba, ebislesmalad. A-dulemarde bela sunna Bab-Dummad-dulemarbo-ambikued-neggi arbamaloed. Weyob Moisés, degi, Aarón, Gersón-wagan-ebichismalad. Bab-Jehová-Moisésʼga-igar-uksadba imaksamalad.
\s1 Merari-wagan e-dadgan-e-dadganba-ebislesad
\p 
\v 42 Moisés, Aarón, degi, Israel-dulemar-danar-danar-bukwamalad-e-dummaganmala, Merari-wagan, na e-dadgan-e-dadganba, na e-gwenad-e-gwenadganba ebichismarmogad.
\v 43 Bela machergan birga-durgwen-gakambe-nikamalad (30), degi, birga-dulabo-gakambe-nikamaladse (50) sunna Bab-Dummad-dulemarbo-ambikued-neggi arbanonimaloed ebichilesad.
\v 44 Weyob Merari-wagan na e-dadgan-e-dadganba ebislesmargu, milipaa gaka dulataled-ilabo (3,200) mergu daklealid.
\v 45 Weyobi Moisés, degi, Aarón, bela Merari-wagan, na e-dadgan-e-dadganba-mergue ebichismalad. Amar Bab-Jehová-Moisésʼga-igar-uksadba imaksamalad.
\s1 Leví-wagan e-dadgan-e-dadganba-ebislesad
\p 
\v 46 Moisés, Aarón, degi, Israel-girmar-dummagan bela Leví-wagan na e-dadgan-e-dadganba, na e-gwenad-e-gwenadganba ebichismaladi,
\v 47 machergan birga-durgwen-gakambe-nikamalad (30), degi, birga-durbo-gakambe-nikamaladse (50) sunna Bab-Dummad-dulemarbo-ambikued-neggi arbanonimaloedi, degine, sunna we-negsemaloedi,
\v 48 bela we-dulemar milibaabak gaka dulataled-ilatar gaka dulabake (8,580) mergu daklealid.
\v 49 Moisés, Bab-Jehová-igi-ega-igar-uksadba, dulemarga ibmar-imaked-igar uksad, degine, ibmar-sedmaloed-igar uksabalid.
\p Moisés, Bab-Jehová-ega-igar-uklesadba, weyob dulemar-ebichisad.
\c 5
\s1 Dule-boni-nikamalad-onolegoed-igar
\p 
\v 1 Bab-Jehová Moisésʼga sunmakded, ega sogded:
\v 2 “Israel-dulemarga be soge: ‘Bemar-danar-danar-bukwadgi bela Israel-dulemar ukagi-boni-yaa-akar-akar-nikamalad be onomalo. Dule-na-e-burba-daksamalad, degi, dule-burgwisad-ebusmalad, be onomarbalo. Ar ade, dule-burgwisad-ebussoggu, swilidiksuli gunonikid.
\v 3 Bemar-bukwadgi dule-boni-nikamalad, omedibe, igi, machereddibe, be onomaloed. Adi, wemar melle bemar-bukwadgi an-bemar-abargi-maid-neg oichogegar.’ ”
\p 
\v 4 Israel-dulemala Bab-Jehová-Moisésʼga-sogsadyobi imaksamalad: Dulemar-boni-nikamalad emar-bukwadgi onosmalad.
\s1 Dule-baid-ibe ibmar-oakalolesar igi-imaklegoe
\p 
\v 5 Bab-Jehová Moisésʼga sunmakdebalid, ega sogded:
\v 6 “Israel-dulemarga be soge: ‘Dule-machereddibe, igi, omedibe, dule-baid-ibe-ibmar-oakalosale, we-dule angi nue dummad-nosdo. Degisoggu, nue-odurdakleged ega igar mego.
\v 7 We-dulede e-isgusad na dukin barsogo. Degine, dule-baidgi-nosad-ular, ibmar-oakalosawilub ega ibmar-uko. A-ukine, ibmar-atargi gwensak napi ega ukbalo.
\v 8 Ar dule-naibi-gusad bato burgwisale e-gwenad-walikagwad-satele, ega-ibmar-uklegoenad anga uklego, degi, dule-irwa-anse-goledga uklemogo. Deginbali, dule-aimar-naibisasadi, e-isgusad-ular, sibad-wawaad-machered-ukbalo, adi, dule-irwa-anse-goled we-ibmar anga ogumakar ukegar.
\p 
\v 9 ” ’Israel-dulemar bela-ibmarmar-dule-irwa-anse-goledse-sedmaloedi, dule-irwa-anse-goledgadga guo.
\v 10 Ar dule anga ibmar-uksardi, we-ibmar na egadga guo. Ar dule-irwa-anse-goledga uksardi, adi, we-ibmar we-dule-irwa-anse-goledgadga guo.’ ”
\s1 Nobgumalad-igar
\p 
\v 11 Bab-Jehová Moisésʼga sogdebalid:
\v 12 “Israel-dulemarga be sunmak, ega be soge: ‘Binsa sogmalo, ome-gwensak abirgunagwar-gudiid-igargi yoledsunnad,
\v 13 we-ome e-sui-dikarba dukuar machered-baidbo negsichigi yoledsunnad, degi, bipisaale a-ome negsichigi-yolenai daklessulid.
\p 
\v 14 ” ’Degi-inigwele, e-sui e-omegi nue-nobe-itogele, degi, egi dodosye binsaele, igi amba e-ome egi nossurdibe,
\v 15 e-sui dule-irwa-anse-goledse e-ome-sedoed. Agi, madubur-cebadaʼye-nugad, nibiratar e-omegi nobed-ular anga we-ibmar ukoed. Ar we-ibmar, omegi-nobe-itoged-ular uklenaisoggu, we-ibmar-birgine olivo-gwallu eogosulid, degine, ibmar-wawadikmalad eogosurbalid. Deginbali, we-ibmar-uklesadi, isgusad wisguegalad.
\p 
\v 16 ” ’Dule-irwa-anse-goled, an-asabin we-ome ogwisoed.
\v 17 Geb degidgine, dule-irwa-anse-goled dii-nued-ditirmakaled napsa-noggi eogoed. Geb anse-goled-neg-sunna-seleged-e-napa-buru weoed, agine, we-olli dii-ebo oburoed.
\v 18 Geb degi, dule-irwa-anse-goled, we-ome an-asabin ogwisguoed, geb ome-e-sailagia ei esikoed, agine, ome-argangi ome-wisguega-nobedba-ibmar-uklegaledi, sioed. Dule-irwa-anse-goleddi, e-argangine dii-gagbid gani-gwisguoed. We-dii-gagbidye dule-ukabsaed-diid.
\v 19 Geb degidgine, dule-irwa-anse-goled ome ega ise-sogar-imaked saoed. A-omega sogoed: Dule bebo gabissulile, degine, be-suigi be nossulile, degine, egi be dodossulile, we-dii-gagbireged-iwir-dule-imakedgi be ollorguoed.
\v 20 Ar be-suigi be nosardi, egi be dodosardi, machered-baidbo be akar-akar-gusardi, be ukabsalegoed.
\p 
\v 21 ” ’Degidgine, dule-irwa-anse-goled we-ome-ukabsaoed, weyob ega sogoed:
\q1 Bab-Jehová iwiguega be-imaksun,
\q2 degine, be-dulamar-abargi dulemar sunnasuli-be-dakega be-imaksun.
\q1 Degine, we-dii-gagbid anagan-nikusuli be-imaksun,
\q2 deginbali, saban-muega be-imakbarsun.
\q1 
\v 22 We-dii-dule-iwisaed begi ubodele, be-saban odunguega-imaksun,
\q2 geg-anagan-nikuega be-imaksun.
\p ” ’Ome, dule-irwa-anse-goled-abin sogdoed: ¡Ar deyob gudo! ¡Ar deyob gudo!
\p 
\v 23 ” ’Dule-irwa-anse-goled iwisalesad-soglesad, gardagi narmakoed. Geb degine, a-gardagi-narmakaledi, dii-gagbiregedgi elioed.
\v 24 Geb a-dii-gagbiregedgi ome-ogoboed. Adi, ome nue-dummad-wiledii guegar.
\p 
\v 25 ” ’Geb a-sorbali, ome dule-irwa-anse-goledga ibmar-nobedba-uklenaid ukoed. Geb degine, dule-irwa-anse-goled, an-asabin ibmar-orosgi-dakleged-cebadaʼye-nugad bana-bana imakoed. Agine, ibmar-ogumakar-ukleged-ailase sedoed.
\v 26 Degine, dule-irwa-anse-goled argan-nukgwen orosgi-dakleged-cebada suoed. We sogleged, ebinsalegegaye. Geb degi, we-ibmar, ibmar-ogumakar-ukleged-aila-birgi ogumakoed.
\p ” ’Dule-irwa-anse-goledi, we-diigi ome-ogoboed.
\v 27 Ar we-ome, e-suigi nosale, we-dii-dule-iwisaed gobogu, ome-e-saban mudoed, geg-bar-mimmi-bake gudoed. Deyobi, we-ome na e-dulemar-abargi iwilesgudii gusunnoed.
\v 28 Ar we-ome e-suigi nossulile, galagwensuli-gussulile, adi, iwiguosulid, degisoggu, akar-guosulid sunna mimmi-bake guoed.
\p 
\v 29 ” ’Ome e-sui-dikarba nosa-sogele, e-suigi dodosale, weyobi nobgued-igar ega mai guoed.
\v 30 Machered nue e-omegi nobe-itoalile, an-asabin e-ome-sedoed. Geb degine, dule-irwa-anse-goled we-igar-maidba ega imakoed.
\v 31 Ome na e-isgusadba sabsur-odurdaklegodo, machereddi nosdeeye egi soglegosulid.’ ”
\c 6
\s1 Dule-Bab-Dummadga-san-uksamalad-igar
\p 
\v 1 Bab-Jehová Moisésʼga sunmakded, ega sogded:
\v 2 “Israel-dulemarga be sunmak, ega be soge: ‘Machered-gwensak-sokardibe, igi, ome-gwensak-sokardibe, Bab-Jehováʼgarbi an ibmar-imakdii guega Bab-Jehováʼga bela an-san an na ukoye, we-dule Nazareoʼye soglegoed.
\v 3 Deyob na imakele, vino gobosulid, degi, sisamar gobosurbalid. Deginbali, vinagre-vinoʼgi-danikid, degi, vinagre-sisamargi-danikid, gobosurbalid. Deginbali, uva-nis gobosurbalid, degine, uvaʼmar, degi uva-odinnolegarmalad gunnosurbalid.
\v 4 Dule Nazareoʼga-gudiid-ibagangine, e-ibagan-sogsad-berguedse bipisaale, uva-san, e-gwag, degi, e-ukase-bakale, gunnosulid.
\p 
\v 5 ” ’Ar dule na Nazareoʼga-gudiidgine, e-ibagan-sogsad-berguedse sailagia sikosulid. Unnila Bab-Jehováʼgarbi-ibmar-imakdii guoed, degine, e-sailagia suitii imakoed, ar ade, e-sailagia sikosulid. Geb ibagan-bergunonikile, a-sorba, sunna na e-sailagia sikoed.
\p 
\v 6 ” ’A-ukinbali, a-dule Bab-Jehováʼga na-san-uksad-ibagangine, dule-burgwaledse warmakosurbalid.
\v 7 Amba e-babdibe, igi, e-nan burgwisdibe, igi, e-urbadibe, igi, e-ia-burgwisdibe, igi, e-bundibe, ase-bakale, ese warmakosulid, ar ade, Bab-Jehováʼgarbi-ibmar-imakdiguega Bab-Jehováʼga na san-uksa gudiid.
\v 8 Dule Bab-Jehováʼga na san-uksad-ibagangine, unnila Bab-Jehováʼgarbi ibmar-imakdii guoed.
\p 
\v 9 ” ’Dule-Bab-Jehováʼga-na-san-uksad-walik, dule-wargwen ukiar burgwenonikile, we-dule-Nazareoʼga-gudiid-e-igar-maid oichogoed. Degisoggu, ibagugledgi (7), na san-uruked-e-ibagan-mosale, non-swirii imakoed.
\v 10 Degine, ibabaabakadgi (8) sapur-nuu-gwabo, igi, wagnuu-e-mimmi-gwabodibe, sedagoed. Bab-Dummad-dulemarbo-ambikued-neg-yawagakse, dule-irwa-Bab-Dummadse-goledse sedagoed.
\p 
\v 11 ” ’Ar dule-Bab-Jehováʼga-na-san-uksad, dule-burgwisad-ular isgunonisoggu, we-nuu-gwabo-ukoedi, dule-irwa-Bab-Dummadse-goled, we-nuu-gwagwen dule-isgued-osulogega Bab-Dummadga ukoed. Nuu-baiddi, ogumakar Bab-Dummadga ukbaloed. A-ibagangine, gannar na e-sailagia osuguoed, Bab-Dummadga sogegar, gannar an bega an-san ukbarye.
\v 12 Geb degi, we-dule Bab-Jehováʼga-na-san-uksad-ibagangi, Bab-Jehováʼgarbi nanadii guoed. E-isgusad-ular, sibad-wawaad-sapingwagwad-birgagwen-nikad Bab-Dummadga sedagoed, adi, e-isgusad ega osulogegar. Idu Bab-Jehováʼgarbi-arbadigusad-ibagan bar ebislegosulid. Ar dule-burgwisadi, ei ibagan oichossoggu, e-ibagan gannar onodoed.
\p 
\v 13 ” ’Weyobi, dule-Nazareoʼga-gudiid e-ibagan-sogsad bergunonikile, ega-igar-maidba imakoed. Bab-Dummad-dulemarbo-ambikued-neg-yawagakse na dagoed.
\v 14 Agi, Bab-Jehováʼga ibmar-ukleged sedagoed:
\q1 Sibad-wawaad-sapingwagwad-birgagwen-nikad uknonikoed.
\q2 We-sibad-wawaad swilidik, gwen boni-nikasuli ogumakar-uklegega senonikoed.
\q1 Degine, sibad-wawaad-ome-birgagwen-nikad-swilidikid, gwen boni-nikasulid, e-isgued-anar ukega senonibaloed.
\q2 Deginbali, dule gwenatigwar-guega,
\q2 sibad-wawaad-machered-swilidikid gwen boni-nikasulid ukbaloed.
\q1 
\v 15 Deginbali, Nazareo-dule ibmar-gwag-Bab-Jehováʼga-ukleged, degine, e-gobed-ega-uklebalid, sedabaloed.
\q2 Deginbali, garba-bipigi madu-inasulid, sedabaloed.
\q2 We-madude, madu-ologana madubur-nuedgi olivo-gwalluba-omukualedid,
\q2 degine, madu-matargana olivo-gwallugi-magaledid.
\q3 We-ibmarmar, we-Nazareo-dule sedagoed.
\p 
\v 16 ” ’Geb degine, dule-irwa-Bab-Dummadse-goled, we-Nazareo-dulega-isgued-osulogega, we-ibmar Bab-Jehováʼga ukoed. A-ukinbali, we-ibmar ogumakar Bab-Jehováʼga ukbaloed.
\v 17 Deginbali, gwenatigwar-guega, sibad-wawaad-machered oburgwebaloed. We-sibad-wawaadba-mesa garba-bipigi-madu-inasuli-bukwad dule-irwa-Bab-Dummadse-goled Bab-Jehováʼga ukbaloed. Deginbali, ibmar-gwagmar, degi, ibmar-eolemalad Bab-Jehováʼga ukbaloed.
\p 
\v 18 ” ’Geb degidgine, dule-na-Bab-Jehováʼga-san-uksad, Bab-Dummad-dulemarbo ambikued-neg-e-yawagak-walik na-e-sailagia ioed. Geb agine, e-sailagia soogi-ogumakega Bab-Dummadga-ibmar-uklenaid-urba soo-gasiidgi urboed. We-ibmarde gwenatigwar-guega uklenaid.
\p 
\v 19 ” ’Dule-Bab-Jehováʼga-san-uksad-sailagia-siksad-sorbali, dule-irwa-Bab-Dummadse-goled sibad-wawaad-machered-e-gukin-matar-dualed suoed, degine, garbagi madu-olo-inasulid-siid, madu-matar-e-inasulid-siid subaloed. Agi, geb Nazareo-dulega ukoed.
\v 20 Geb we-ibmar-ukoedi, gannar suoed. Geb dule-irwa-Bab-Dummadse-goled, bana-bana-imakar Bab-Jehováʼga ukoed. We-ibmar dule geg yogasaar sued, unnila dule-irwa-Bab-Dummadse-goledga uklegoed. Deginbali, sibad-wawaad-e-binasgar, degi, e-dua Bab-Jehováʼga-uklearbalid dule-irwa-Bab-Dummadse-goledga uklebaloed. Geb deyobi, a-sorbali, dule-Bab-Jehováʼga-na-san-uksad, sunna vino-gobe gunonisunnoed.
\p 
\v 21 ” ’Dule Bab-Jehováʼga-san-uksad-Nazareoʼye-bileged Bab-Jehováʼgarbi-ibmar-imakdigubiele, weyob ega igar-mai guoed. Weyobi, Bab-Jehováʼga ibmar-ukoed, degi, na ibmar-nikadba ukbaloed. Dule-Bab-Jehováʼga-na-san-urmaksadi igar-maidba na imakergebed, imaksuli guosulid, imakedsegad.’ ”
\s1 Bab-Dummad-dulemargi-nued-binsaed-igar
\p 
\v 22 Bab-Jehová Moisésʼga sunmakdebalid, ega sogdebalid:
\v 23 “Aarónʼga, degi, e-masmalaga be sunmak. Ega be soge: ‘Israel-dulemargi ise-nued be sunmakalile, weyobi, be sogoed:
\q1 
\v 24 Bab-Jehová ise-nued begi binsadii gusun,
\q2 nue be-akwedii gusun.
\q1 
\v 25 Bab-Jehová bela-bela nued be-dakdii gusun.
\q2 Bela-bela nue-be-sabgudii gusun.
\q1 
\v 26 Bab-Jehová nued-begi-binsaed bega-oyodii gusun.
\q2 Degi, ulubgi bogidikid bega ukdii gusun.’
\p 
\v 27 ”Weyobi Aarón, degi, e-masmala, Israel-dulemarga an-nuggi sogoed. Geb degine, Israel-dulemargi nued an binsaoed.”
\c 7
\s1 Bab-Dummadse-goled-negga ibmar-uksamalad
\p 
\v 1 Moisés Bab-Dummadse-goled-neg-seleged-sobsad-obelosgu, ina-wawadikid a-neggi bomi-bomi imaksad. Degine, bela agi ibmarmar-bukwad Bab-Dummadga nug-imaksad. Agi, we-neg Bab-Dummadgarbi-ebulegega nug-imaksasunnad. Geb ibmar-ogumakar-ukleged-ailagi ina-wawadikid egi bomi-bomi imaksabalid, degine, bela ailagi-ibmarmar-ebulemalad Bab-Dummadga nug-imaksabalid. Agi, we-ibmar bela Bab-Dummadgarbi-ebulegega nug-imaksad.
\p 
\v 2 Geb degine, Israel-dulemar-e-dummagan, a sogleged, na e-gwenad-e-gwenadgan-e-dummaganye, amala, e-dadgan-dummaganba-dulemar-ebislesmalad-e-dummagan gumalad. Amala, Bab-Jehováʼga ibmar uknonimalad.
\q1 
\v 3 We-ibmarmar senonimalad:
\q2 Dummagan ebo-ebo ur-napagined-ibmar-seed-wargwen senonimalad,
\q2 degine, dummagan-iliba moli-bebe-nikad-alugwasualed-war-wargwen senonimalad.
\q2 Degisoggu, bela ur-napagined-ibmar-seed walanergwasundo (6),
\q2 degine, moli-bebe-nikad-alugwasualed warambe-gakabosundo (12).
\q3 We-ibmarmala, Bab-Jehováʼga-ukega Bab-Dummadse-goled-neg-sunna-selegedse senonimalad.
\p 
\v 4 Bab-Jehová Moisésʼga sunmakded, ega sogded:
\v 5 “We-ibmarmar-bega-uknanaid e-abin be sue, adi, dulemar-anbo-ambikued-neggi ebulegegar. We-ibmarde Leví-wagan-baiganga, na e-ibmar-ebulegedba ega be ukoed.”
\p 
\v 6 Geb Moisés, we-urmar, degi, moli-alugwasuarmalad sussunnad. Geb degine, Leví-wagan-baiganga uksasunnad.
\v 7 Gersón-e-waganga urmar-napagined-ibmar-seed walabo ega uksad, degine, moli-bebe-nikad-alugwasualed walabake ega uksabalid, arbagedgi-ibmar-abemaladba ebugegar.
\v 8 Merari-e-waganga urmar-napagined-ibmar-seed walabake ega uksad, degine, moli-bebe-nikad-alugwasualed walabaabak (8) uksabalid, arbagedgi ibmar-abemaladba ebugegar. We-Leví-wagan-baigande dule-irwa-Bab-Dummadse-goled-Aarón-machi-Itamar-sogedba arbananai gusmalad.
\v 9 Moisés, Coat-wagangardi we-ibmarmar uksasulid, ar ade, wemala e-gukingi ibmarmar-Bab-Dummadgadga-gusadi, semamai gumaloed.
\s1 Ibmar-ogumakar-ukleged-aila Bab-Dummadga-nugsalesad
\p 
\v 10 Ibmar-ogumakar-ukleged-aila Bab-Dummadga nugsalesgu, we-dummagan ibmar-ogumakar-ukleged-aila-asabin, Bab-Dummadga ibmarmar uksamalad.
\v 11 Ar ade, Bab-Jehová, Moisésʼga sogsagusad: “Ibmar-ogumakleged-aila-anga-nugsalesadga-ibmar-ukegale, iba-ibagwengi dummagan-war-wargwen anga ibmar ukoed.”
\s1 Judá-wagan-e-dummad Bab-Jehováʼga-ibmar-uksad
\p 
\v 12 Iba-gebe-onodedgine, Aminadab-machi-Naasón-inse Bab-Jehováʼga ibmar senonikid. We-Naasónʼde, e-dad-dummad-Judáʼgi danikid.
\q1 
\v 13 Naasón Bab-Jehováʼga-ibmar-uksadi, wemalad:
\q2 Mani-bate-gwagwen, dulanergwa-gakambe-aidikued (130) senonikid.
\q3 E-aidikuedi, Bab-Dummadse-goled-neggi mani-aidikued-ebislegedyobid.
\q2 Degine, mani-nog-dummad, dulapaa-gakambe-aidikued (70) senonibalid.
\q3 E-aidikuedi, Bab-Dummadse-goled-neggi mani-aidikued-ebislegedyobid.
\q2 A-ibmargi, madubur-olivo-gwalluba-omukuar Bab-Dummadga-uklegedi, Bab-Dummadga-ukega senonikid.
\q2 
\v 14 Degine, or-wesar-dummad gagwen, mani-sibugan-gwaambe-aidikue-wilub (10) senonibalid.
\q3 A-or-wesargi, ina-wawadikid ena senonibalid.
\b
\q1 
\v 15 Deginbali, Bab-Dummadga ibmar-ogumakar-ukega we-ibmarmar senonibalid:
\q2 Moli-bebe-nikad-sapingwagwad, wargwen.
\q2 Sibad-wawaad-machered, wargwen.
\q2 Sibad-wawaad-sapingwagwad-birgagwen-nikad, wargwen.
\q2 
\v 16 Deginbali, e-isgued-osulogega, sibad-machered wargwen, Bab-Dummadga-ukega senonibalid.
\b
\q1 
\v 17 Deginbali, gwenatigwar-guega, we-ibdurgan senonibalid:
\q2 Moli-bebe-nikad-alugwasualed, warbo.
\q2 Sibad-wawaad-machered, walatar.
\q2 Sibad-machered, walatar.
\q2 Degi, sibad-wawaad-sapingwagwad-birgagwen-nikad, walatar senonikid.
\q3 We-ibmarmala, Aminadab-machi-Naasón, Bab-Jehováʼga senonikid.
\s1 Isacar-wagan-e-dummad Bab-Jehováʼga-ibmar-uksad
\p 
\v 18 Ibabogi, Zuar-machi-Natanael, Bab-Jehováʼga ibmar-senonimogad. We-Natanaelʼde dad-dummad-Isacarʼgi-danimalad-e-dummadid.
\q1 
\v 19 Natanael Bab-Jehováʼga-ibmar-uksadi, wemalad:
\q2 Mani-bate-gwagwen, dulanergwa-gakambe-aidikued (130) senonikid.
\q3 E-aidikuedi, Bab-Dummadse-goled-neggi mani-aidikued-ebislegedyobid.
\q2 Degine, mani-nog-dummad, dulapaa-gakambe-aidikued (70) senonibalid.
\q3 E-aidikuedi, Bab-Dummadse-goled-neggi mani-aidikued-ebislegedyobid.
\q2 A-ibmargi, madubur-olivo-gwalluba-omukuar Bab-Dummadga-uklegedi, Bab-Dummadga-ukega senonikid.
\q2 
\v 20 Degine, or-wesar-dummad gagwen, mani-sibugan-gwaambe-aidikue-wilub (10) senonibalid.
\q3 A-or-wesargi, ina-wawadikid ena senonibalid.
\b
\q1 
\v 21 Deginbali, Bab-Dummadga ibmar-ogumakar-ukega we-ibmarmar senonibalid:
\q2 Moli-bebe-nikad-sapingwagwad, wargwen.
\q2 Sibad-wawaad-machered, wargwen.
\q2 Sibad-wawaad-sapingwagwad-birgagwen-nikad, wargwen.
\q2 
\v 22 Deginbali, e-isgued-osulogega, sibad-machered wargwen, Bab-Dummadga-ukega senonibalid.
\b
\q1 
\v 23 Deginbali, gwenatigwar-guega, we-ibdurgan senonibalid:
\q2 Moli-bebe-nikad-alugwasualed, warbo.
\q2 Sibad-wawaad-machered, walatar.
\q2 Sibad-machered, walatar.
\q2 Degi, sibad-wawaad-sapingwagwad-birgagwen-nikad, walatar senonikid.
\q3 We-ibmarmala, Zuar-machi-Natanael, Bab-Jehováʼga senonikid.
\s1 Zabulón-wagan-e-dummad Bab-Jehováʼga-ibmar-uksad
\p 
