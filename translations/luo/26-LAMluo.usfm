\id LAM - Biblica® Open New Luo Translation 2020
\h Ywagruok
\toc1 Ywagruok
\toc2 Ywagruok
\toc3 Ywa
\mt1 Ywagruok
\c 1
\q1 
\v 1 Mano kaka dala maduongʼ mane ji ngʼenyie
\q2 odongʼ nono!
\q1 Kinde moro ne en dala malich miwuoro
\q2 to koro ochalo gi dhako ma chwore otho!
\q1 Ne en ruoth madhako e kind pinje,
\q2 to tinde osebedo misumba.
\b
\q1 
\v 2 Oywak malit gotieno,
\q2 pi wangʼe ridore e lembe.
\q1 Kuom joherane duto,
\q2 onge moro manyalo hoye.
\q1 Osiepene duto osendhoge
\q2 kendo gisebedo jowasike.
\b
\q1 
\v 3 Bangʼ sand gi tij achuna,
\q2 Juda oseter e twech.
\q1 Odak e dier ogendini
\q2 kendo oonge kar yweyo.
\q1 Jogo duto malawe osemake kapod en
\q2 e chandruok malich.
\b
\q1 
\v 4 Yore madhiyo Sayun ywagore,
\q2 nimar onge ngʼato mabiro e nyasi mag sewni moyier.
\q1 Dhorangeye duto odongʼ nono maonge ji,
\q2 jodologe ywak ka chur,
\q1 jotichge ma nyiri okuyo,
\q2 to en owuon en gi lit malich.
\b
\q1 
\v 5 Wasike ema tinde otelone,
\q2 kendo wasikego dhi maber.
\q1 Jehova Nyasaye osekelone chandruok
\q2 nikech richone mangʼeny.
\q1 Nyithinde oseter e twech, kendo gisebedo kaka joma omaki
\q2 e nyim wasigu.
\b
\q1 
\v 6 Duongʼ mar loch duto mane nyar Sayun nigo
\q2 oserumo.
\q1 Jodonge chalo gi mwanda modenyo
\q2 ma ok yud lum machamo,
\q1 giringo ka gionge
\q2 gi teko e nyim joma lawogi.
\b
\q1 
\v 7 E ndalo mane Jerusalem ni e chandruok kod chuny lit,
\q2 noparo mwandune duto mane en-go e ndalo machon.
\q1 Wasike nojare
\q2 kendo onyiero kuom thagruok mage.
\b
\q1 
\v 8 Jerusalem osetimo richo madongo
\q2 omiyo koro osebedo mochido.
\q1 Ji duto mane omiye luor koro ochaye,
\q2 nimar giseneno duge;
\q1 kendo koro oywak kochur
\q2 nikech wiye kuot.
\b
\q1 
\v 9 Chilo ma en-go omienore e lepe,
\q2 ne ok odewo gima biro timorene bangʼe.
\q1 Nopodho malich miwuoro,
\q2 to onge ngʼama ne nyalo hoye.
\q1 Yaye Jehova Nyasaye, neye chandruok ma an-go,
\q2 nimar wasigu oseloyo.
\b
\q1 
\v 10 Wasigu oseyako
\q2 mwandune duto;
\q1 oseneno ogendini ma jopiny
\q2 ka donjoe kare maler mar lemo,
\q1 jogo misekwero ni kik donji
\q2 e kari maler mar lemo.
\b
\q1 
\v 11 Joge duto chur kaywagore
\q2 ka gimanyo chiemo;
\q1 giloko mwandugi
\q2 mondo giyud chiemo,
\q2 mondo gibed mangima.
\q1 “Yaye Jehova Nyasaye, neye kendo iparae,
\q2 nimar ji ochaya.”
\b
\q1 
\v 12 Un ji duto makadho, onge lich muneno kuom gima timorenani?
\q2 Lokreuru anena mondo unee,
\q1 ka bende nitiere masira machielo
\q2 machalo gi masira moyudani,
\q1 ma Jehova Nyasaye oseketo kuoma
\q2 e odiechiengʼ mar mirimbe mager?
\b
\q1 
\v 13 Ne ooro mach koa e polo,
\q2 modonjo e chokena.
\q1 Nochiko obadho momako tiendena
\q2 kendo nodwoka chien.
\q1 Nomiya abedo modhier kadongʼ kenda
\q2 ka aol maonge teko odiechiengʼ duto.
\b
\q1 
\v 14 Richona osetwe e ngʼuta ka jok;
\q2 adier osetweyogi gi lwete owuon.
\q1 Oseketgi e ngʼuta
\q2 kendo Ruoth Nyasaye osetieko tekra,
\q1 bende osejwangʼa
\q2 e lwet joma ok anyal loyo.
\b
\q1 
\v 15 “Ruoth Nyasaye
\q2 osekwedo jolweny maga duto;
\q1 osechoko jolweny
\q2 mondo omonja,
\q1 kendo otiek yawuota ma jolweny.
\q1 Ruoth Nyasaye osekumo nyar Juda mapok ongʼeyo chwo
\q2 e kare mar biyo olemb mzabibu.
\b
\q1 
\v 16 “Ma emomiyo aywak
\q2 kendo pi wangʼa mol e lemba.
\q1 Onge ngʼat machiegni koda ma dihoya,
\q2 bende onge ngʼat ma dikwe chunya.
\q1 Nyithinda odongʼ kiye
\q2 nikech wasigu oselocho.”
\b
\q1 
\v 17 Sayun tingʼo bedene malo kaywak,
\q2 to onge ngʼama nyalo hoye.
\q1 Jehova Nyasaye oseketo chik ni Jakobo,
\q2 ni jogo modak bute,
\q2 mondo obed wasike;
\q1 Jerusalem osebedo gima ochido
\q2 e diergi.
\b
\q1 
\v 18 Jehova Nyasaye en Nyasaye makare,
\q2 to kata kamano ne angʼanyo ne chikene.
\q1 Winjuru, un ji duto;
\q2 kendo neeuru kaka achandora.
\q1 Yawuota gi nyiga osemaki
\q2 moter e twech.
\b
\q1 
\v 19 Ne aluongo osiepena,
\q2 to ne gindhoga.
\q1 Jodolo maga gi jodonga
\q2 notho e dala maduongʼ,
\q1 kane gimanyo chiemo
\q2 mondo gibed mangima.
\b
\q1 
\v 20 Yaye Jehova Nyasaye, nee kaka anie chandruok malich!
\q2 Iya nyawni,
\q1 kendo chunya chandore malich,
\q2 nikech ok aseluoro chikeni.
\q1 Lweny nego ji oko mar dala
\q2 to ei dala bende tho nekoe.
\b
\q1 
\v 21 Ji osewinjo ywakna,
\q2 to onge ngʼama dewa.
\q1 Wasika duto osewinjo chandruokna;
\q2 kendo gimor kuom gik ma isetimona.
\q1 Mad ikel odiechiengʼ mane iselando
\q2 mondo omi gichal koda.
\b
\q1 
\v 22 We mondo timbegi mamono ochop e nyimi;
\q2 kendo timnegi,
\q1 mana kaka isetimona
\q2 kuom richona duto.
\q1 An gi pek mangʼeny
\q2 kendo chunya onyosore.
\b
\b
\c 2
\q1 
\v 1 Mano kaka Ruoth Nyasaye osekumo Nyar Sayun
\q2 gi mirimbe motwere ka rumbi!
\q1 Duongʼ mar Israel ma yande otundo nyaka e polo,
\q2 osewito piny,
\q1 bende kuom mirimbe
\q2 ok oseparo ni en raten mar tiende.
\b
\q1 
\v 2 Ruoth Nyasaye oseketho
\q2 mier duto mag Jakobo ka ok odewo;
\q1 nikech mirimbe osemuko
\q2 kuonde mochiel motegno mag Nyar Juda.
\q1 Nokuodo wi jopinyno gi jotende
\q2 mi odwoko lochgi chien.
\b
\q1 
\v 3 Osetieko teko mar jo-Israel
\q2 gi mirimbe mager,
\q1 kendo osejwangʼogi
\q2 e lwet wasikgi.
\q1 Osewengʼo ka Jakobo kaka mach mager makakni
\q2 ma wangʼo gik moko duto molwore.
\b
\q1 
\v 4 Oseywayo atungʼe mar kedo
\q2 gi joge mana ka gima gin wasike.
\q1 Kaka jasigu neko,
\q2 osenego jogo duto mane nenore mabeyo e wangʼ,
\q1 kendo oseolo mirimbe oko
\q2 ka mach kuom hemb Nyar Sayun.
\b
\q1 
\v 5 Ruoth Nyasaye chalo gi jasigu;
\q2 kendo osetieko Israel!
\q1 Osemuko ute Israel duto mag ruoth
\q2 kendo oseketho mieche mochiel motegno.
\q1 Osemedo ywagruok
\q2 kod kuyo ne Nyar Juda.
\b
\q1 
\v 6 Oseketho kare mar dak mana ka puodho moketh chambe modongʼ nono,
\q2 kendo osemuko kare mar romo.
\q1 Jehova Nyasaye osemiyo Sayun wiye owil
\q2 kod sewni moyier gi Sabatoge;
\q1 kendo kuom mirimbe mager,
\q2 osejwangʼo ruoth kaachiel gi jadolo.
\b
\q1 
\v 7 Ruoth Nyasaye osedagi kendone mar misango
\q2 kendo jwangʼo kare maler mar lemo.
\q1 Osechiwo ohinga mag kuonde mag dak
\q2 e lwet wasigu;
\q1 gisegoyo koko e od Jehova Nyasaye
\q2 mana kaka ne itimo e odiechiengʼ mar sawo moyier.
\b
\q1 
\v 8 Jehova Nyasaye osechano muko ohinga
\q2 molworo Nyar Sayun.
\q1 Oserieyo rapim kendo ne ok ogengʼo lwete
\q2 mondo kik okethe.
\q1 Nomiyo chiel ma oko mar dala kod ohinga oyiengni,
\q2 giduto kaachiel ne gimukore mi gigore piny.
\b
\q1 
\v 9 Dhorangeyene osegore piny molal ei lowo,
\q2 oseturo lodi mage kendo kethogi.
\q1 Ruodhe gi jodonge oke e kind ogendini,
\q2 chik onge koro,
\q1 to jonabi mage koro ok yud fweny
\q2 moa kuom Jehova Nyasaye.
\b
\q1 
\v 10 Jodongo mag nyar Sayun,
\q2 obedo piny kolingʼ thi,
\q1 gisebuko wiyegi gi buru
\q2 kendo girwako piende gugru.
\q1 Nyi Jerusalem
\q2 osekulo wiyegi piny.
\b
\q1 
\v 11 Wangʼa ojony nikech ywak,
\q2 chunya ool,
\q1 kendo chandore malit
\q2 nikech joga osetieki,
\q1 kendo nyithindo kod nyithindo mayom kech nego
\q2 e yore mag dala maduongʼ.
\b
\q1 
\v 12 Kech negogi
\q2 e kor minegi,
\q1 ka jogo mohiny e lweny
\q2 e yore mag dala maduongʼ,
\q1 mi gipodhi,
\q2 omiyo gipenjo minegi niya, “Ere chiemo kod divai?”
\b
\q1 
\v 13 Yaye Nyar Jerusalem, en angʼo madawach kuomi?
\q2 Koso en angʼo ma dapimigo?
\q2 Yaye Nyar Sayun mapok ongʼeyo dichwo,
\q1 en angʼo ma dapimigo,
\q2 koso en angʼo ma dahoyigo?
\q1 Adhola ma in-go tut mana ka nam.
\q2 Ere ngʼama dithiedhnigo?
\b
\q1 
\v 14 Fweny mane jonabi magi oneno
\q2 ne ok adiera, to gin mana miriambo lilo,
\q1 ne ok ginyisi richoni
\q2 mondo omi kik teri e twech.
\q1 To fweny mane ginyisi
\q2 ne gin mana weche mag miriambo kendo ma wito ji.
\b
\q1 
\v 15 Ji duto makadho buti
\q2 pamo ni lwetegi;
\q1 gijari kendo gikino wigi
\q2 kuom gigo mosetimorene Nyar Jerusalem,
\q1 ka gipenjore niya, “Bende ma e dala maduongʼ
\q2 ma yande ongʼere ni dala maler,
\q2 kendo mor mar piny mangima?”
\b
\q1 
\v 16 Wasiki duto
\q2 wuoyo marach kuomi;
\q1 gijari ka gikayo lekegi
\q2 kagiwacho niya, “Wasetieke chuth.
\q1 Ma e ndalo mane wasebedo ka warito;
\q2 adier, osechopo ma wanene.”
\b
\q1 
\v 17 Jehova Nyasaye osetimo gima ne osechano;
\q2 osechopo mano mane owacho,
\q2 ma en gima nochiko chon.
\q1 Osetieki ma ok odewo,
\q2 kendo osemiyo wasigu goyoni siboi,
\q2 komedogi teko.
\b
\q1 
\v 18 Chunje ji ywak
\q2 ni Ruoth Nyasaye.
\q1 Yaye ohinga mar Nyar Sayun,
\q2 we pi wangʼi omol ka aora,
\q2 odiechiengʼ gotieno;
\q1 kik iywe kata matin,
\q2 kendo pi wangʼi kik chogi.
\b
\q1 
\v 19 Aa malo, ywagi otieno duto,
\q2 e kindego mag arita ma otieno chakore,
\q1 kendo weche duto manie chunyi ol oko ka pi
\q2 e nyim Ruoth Nyasaye.
\q1 Tingʼ bedeni malo kilame
\q2 nikech nyithindi,
\q1 ma kech nego
\q2 e wangʼ yore duto.
\b
\q1 
\v 20 Yaye Jehova Nyasaye winjie wachni:
\q2 En ngʼa misetimone gima lit machal kama?
\q1 Bende mon dicham nyithindgi
\q2 ma giserito maber kama?
\q1 Koso jodolo gi jonabi dinegi
\q2 e kama ler mar lemo mar Ruoth Nyasaye adier?
\b
\q1 
\v 21 Jomatindo gi jomadongo nindo
\q2 e yore motimo buru;
\q1 yawuota gi nyiga
\q2 oseneg gi ligangla.
\q1 Isenegogi ka in gi mirima
\q2 kendo isetiekogi ka ok idewo.
\b
\q1 
\v 22 Ne iluongo masira koa kuonde duto
\q2 mana ka ji mabiro e nyasi moro maduongʼ.
\q1 E odiechiengʼ mar mirimb Jehova Nyasaye
\q2 onge ngʼato mane otony kata mane odongʼ kangima.
\q1 Kuom joga mane apidho
\q2 kendo arito, wasika osetieko.
\b
\b
\c 3
\q1 
\v 1 An e ngʼat moseneno masira
\q2 mane ayudo koa e lwet Jehova Nyasaye.
\q1 
\v 2 Oseriemba mabor kendo miyo awuotho
\q2 e mudho kar wuotho e ler;
\q1 
\v 3 chutho osekuma
\q2 kinde ka kinde ndalo duto.
\b
\q1 
\v 4 Osemiyo denda odoko mool
\q2 kendo chokena osetur.
\q1 
\v 5 Osegoyona agengʼa kendo lwora
\q2 komiya abedo gi chuny malit kod olo.
\q1 
\v 6 Osemiyo adak ei mudho
\q2 kaka jogo mane osetho chon.
\b
\q1 
\v 7 Osechiela gi ohinga ma ok anyal ringo madhi;
\q2 kendo oseketa piny kotweya gi nyororo.
\q1 
\v 8 Kata ka aluongo kata kaywak ka dwaro kony,
\q2 to ogengʼo lamona.
\q1 
\v 9 Osedino yora gohinga moger gi kidi;
\q2 omiyo awuotho e yore mobam.
\b
\q1 
\v 10 Mana kaka ondieg bungu mobuto karito,
\q2 kata ka sibuor mopondo,
\q1 
\v 11 e kaka noywaya oko e yo mokidha
\q2 kendo oweya maonge kaka dakonyra.
\q1 
\v 12 Noywayo atungʼe
\q2 kendo oketa thoro mar aserni mage.
\b
\q1 
\v 13 Nochwoyo chunya gi aserene
\q2 mowuodho e olalo mare.
\q1 
\v 14 Nabedo ngʼat ma ji duto nyiero,
\q2 ne gijara gi wer pile ka pile.
\q1 
\v 15 Osepongʼo chunya
\q2 gi gik makech kod olo.
\b
\q1 
\v 16 Oseturo lekena gi kite mimuodo
\q2 kendo osenyona piny e buru.
\q1 
\v 17 Osemaya kwe;
\q2 kendo wiya osewil kod mor ma yande an godo.
\q1 
\v 18 Emomiyo awacho niya, “Chia mara oserumo
\q2 kod gigo mane ageno kuom Jehova Nyasaye.”
\b
\q1 
\v 19 Aparo chandruokna, wuodhena ma ok nikare,
\q2 kaachiel gi lit gi kuyo.
\q1 
\v 20 Aparogi maber,
\q2 kendo an kod kuyo e chunya.
\q1 
\v 21 To gima bende aparo
\q2 mamiyo abedo gi geno ema:
\b
\q1 
\v 22 Nikech hera maduongʼ mar Jehova Nyasaye osiko mochwere,
\q2 kendo ngʼwonone ok rum omiyo ok otiekwa.
\q1 
\v 23 Herani gi ngʼwononi nyien okinyi kokinyi,
\q2 kendo adiera mari duongʼ.
\q1 
\v 24 Abiro wacho kenda niya, “Jehova Nyasaye e pokna,
\q2 omiyo abiro geno kuome.”
\b
\q1 
\v 25 Jehova Nyasaye ber ne jogo ma genogi ni kuome,
\q2 kendo ne ngʼatno madware,
\q1 
\v 26 en gima ber
\q2 rito warruok mar Jehova Nyasaye.
\q1 
\v 27 Ber mondo ngʼato otingʼ jok
\q2 kapod en ngʼama tin.
\b
\q1 
\v 28 We obed kar kende owuon kolingʼ,
\q2 nimar Jehova Nyasaye osetweyone jokno.
\q1 
\v 29 We oik wiye ei buru,
\q2 dipoka pod en gi geno.
\q1 
\v 30 We ochiw lembe ne ngʼatno ma digoye
\q2 kendo oyie bedo ngʼat ma ji jaro,
\b
\q1 
\v 31 nikech Ruoth Nyasaye ok nyal jwangʼo ngʼato
\q2 nyaka chiengʼ.
\q1 
\v 32 Kata obedo ni okelo kuyo, to obiro nyiso ngʼwono,
\q2 nikech herane ma ok rum duongʼ ahinya,
\q1 
\v 33 nimar Nyasaye ok kel chandruok goyiem,
\q2 kata mana kuyo ni nyithind ji.
\b
\q1 
\v 34 Donge Jehova Nyasaye neno kisando ji duto
\q2 manie twech,
\q1 
\v 35 kata kitamo ngʼato e ratiro mare
\q2 e nyim Nyasaye Man Malo Moloyo,
\q1 
\v 36 kata ka iketho buch ngʼato,
\q2 donge Ruoth Nyasaye neno gik ma kamago?
\b
\q1 
\v 37 En ngʼa manyalo wuoyo kendo miyo gimoro timre
\q2 ka ok en Ruoth Nyasaye ema owacho?
\q1 
\v 38 Donge masiche kod ber wuok mana
\q2 koa kuom Nyasaye Man Malo Moloyo?
\q1 
\v 39 Ere gima omiyo ngʼato angʼata mangima ngʼur
\q2 ka okume nikech richoge?
\b
\q1 
\v 40 Weuru wanon timbewa kendo wapar ane kaka gichalo,
\q2 eka wadog ir Jehova Nyasaye.
\q1 
\v 41 Wachiwuru chunywa kendo watingʼ bedewa malo
\q2 e nyim Nyasaye manie polo, kawawacho niya,
\q1 
\v 42 Wasetimo richo kendo ngʼanyo,
\q2 to ok iseweyonwa.
\b
\q1 
\v 43 Iselawowa ka in gi mirima;
\q2 mi inegowa ka ok idewo.
\q1 
\v 44 Iseumori gi boche polo
\q2 mondo lemo moro amora kik chop iri.
\q1 
\v 45 Isemiyo wabedo ka yugi
\q2 kendo ka owuoyo e kind ogendini.
\b
\q1 
\v 46 “Wasikwa duto
\q2 wuoyo kuomwa marach gi ajara.
\q1 
\v 47 Luoro gi obadho ritowa
\q2 kendo kethruok gi masira ochomowa.”
\q1 
\v 48 Pi wangʼa mol ka aora
\q2 nikech joga osenegi.
\b
\q1 
\v 49 Pi wangʼa biro chwer ma ok chogi,
\q2 maonge ngʼama konyo,
\q1 
\v 50 nyaka chop Jehova Nyasaye nokul wangʼe piny
\q2 ma onena gie polo.
\q1 
\v 51 Gima aneno miyo chunya kuyo
\q2 nikech gik matimore ne mon duto mar dalawa maduongʼ.
\b
\q1 
\v 52 Jogo mane wasika kayiem nono
\q2 nomanya ka winyo.
\q1 
\v 53 Negitemo mondo gitiek ngimana ka giluta ei bur;
\q2 kendo negibaya gi kite;
\q1 
\v 54 pi noima mine aparo
\q2 ni achiegni tho.
\b
\q1 
\v 55 Naluongo nyingi, yaye Jehova Nyasaye,
\q2 ka an ei bur matut.
\q1 
\v 56 Kane akwayi ni mondo ikonya
\q2 to ne iwinjo ywakna.
\q1 
\v 57 Nibiro machiegni kane aluongi
\q2 kendo ne iwachona niya, “Kik iluor ngangʼ.”
\b
\q1 
\v 58 Yaye Ruoth Nyasaye ne itingʼo tingʼna,
\q2 kendo ne ireso ngimana.
\q1 
\v 59 Yaye Jehova Nyasaye, iseneno, rach mosetimna,
\q2 ngʼad bucha kare!
\q1 
\v 60 Iseneno kaka ne gichulona kuor,
\q2 kod timbe mamono mane gichano timona.
\b
\q1 
\v 61 Yaye Jehova Nyasaye, isewinjo ayany mag-gi,
\q2 kaachiel gi timbe mamono ma gichano timona,
\q1 
\v 62 ma gin gigo ma joma wasika wacho kuoma
\q2 kendo kuodhago lingʼ-lingʼ odiechiengʼ duto.
\q1 
\v 63 Koro negie nikech kata gibedo piny kata chungo to nyinga
\q2 ema giwuoyoe kokalo kuom wendegi.
\b
\q1 
\v 64 Yaye Jehova Nyasaye, migi kum moromo gi timbegi kaluwore
\q2 gi gik ma lwetgi osetimo.
\q1 
\v 65 Mi gibed gi chuny matek
\q2 kendo mad kwongʼ mari obed kuomgi.
\q1 
\v 66 Yaye Jehova Nyasaye, mad ilawgi gi mirima,
\q2 kendo itiekgi gia e piny mane ichweyo.
\b
\b
\c 4
\q1 
\v 1 Mano kaka dhahabu osewito berne,
\q2 dhahabu maberie moloyo obedo marach!
\q1 Kite maler okere
\q2 e akerkeke mag yore duto.
\b
\q1 
\v 2 Mano kaka yawuot Sayun mabeyo,
\q2 ma yande bergi ne romre gi pek mar dhahabu,
\q1 tinde ipimo mana gi agulni mag lowo,
\q2 ma en tich lwedo mar jachwe aguch lowo!
\b
\q1 
\v 3 Kata mana ondiegi chiwo thundegi
\q2 mondo nyithindgi odhodhi,
\q1 to joga osebedo jogo maonge chuny,
\q2 gichalo udo manie thim.
\b
\q1 
\v 4 Nikech riyo oloyo nyathi madhoth
\q2 mi koro lewe omoko e dande;
\q1 kendo nyithindo kwayo chiemo,
\q2 to onge ngʼama migi.
\b
\q1 
\v 5 Joma yande chamo chiemo mamit,
\q2 koro gin jokwecho mojwangʼ e wangʼ yore;
\q1 to jogo ma yande odak e ngima maber
\q2 koro nindo e pidh yugi.
\b
\q1 
\v 6 Kum mar joga
\q2 duongʼ moloyo mano mar Sodom,
\q1 mane lochne okethi mapiyo piyo nono
\q2 maonge ngʼama nobiro mondo okonye.
\b
\q1 
\v 7 Jotendgi ne ler marieny moloyo pe
\q2 kendo rachar maloyo chak,
\q1 dendgi ne pichni moloyo mo;
\q2 kendo nenruok margi ne chalo gi kidi ma nengone tek.
\b
\q1 
\v 8 To koro gin rotenge moloyo oyare
\q2 ma kata irom kodgi e wangʼ yore to ok nyal ngʼegi,
\q1 nimar pien ringregi osejowore kuom chokegi;
\q2 kendo osebedo motwo ka yien.
\b
\q1 
\v 9 Joma notho e lweny ber moloyo
\q2 jogo ma kech onego;
\q1 kech chamogi ma gidhero
\q2 nikech cham onge e puothe.
\b
\q1 
\v 10 Mon madhoth
\q2 notedo nyithindgi giwegi,
\q1 mobedo chiembgi
\q2 ka joga ne inego itieko.
\b
\q1 
\v 11 Jehova Nyasaye oseolo mirimbe mangʼeny
\q2 ka iye owangʼ.
\q1 Osemoko mach Sayun
\q2 moketho mise mage.
\b
\q1 
\v 12 Ruodhi mag piny ne ok oyie,
\q2 kata ji mag piny bende ne ok oyie,
\q1 ni wasigu kod jolweny nyalo donjo
\q2 e dhorangeye mag Jerusalem.
\b
\q1 
\v 13 To mano notimore
\q2 nikech richo mag jonabi mage,
\q1 kod kethruok mag jodolo mage
\q2 mane ochwero remb joma kare.
\b
\q1 
\v 14 Koro gidigni e wangʼ yore
\q2 ka joma muofni.
\q1 Gidwanyore gi remo
\q2 maonge ngʼato madihedhre mulo lepgi.
\b
\q1 
\v 15 Ji ywak kagoyonegi koko niya,
\q2 “Dhiuru kucha! Ok uler!”
\q1 Mabor kucha, mabor kucha!
\q2 Kik umulwa!
\q1 Ka giringo giaa kendo gibayo abaya,
\q2 ji mag ogendini wacho ni,
\q2 “Ok ginyal dak kodwa kendo.”
\b
\q1 
\v 16 Jehova Nyasaye owuon osekeyogi e pinje;
\q2 kendo koro ok odewgi.
\q1 Jodolo ok yud duongʼ,
\q2 kendo jodongo ok mi luor.
\b
\q1 
\v 17 Kata kamano, wengewa nojony,
\q2 ka warango gima dikonywa;
\q1 to oganda mane wageno kuome ni nyalo konyowa
\q2 ne ok nyal konyowa.
\b
\q1 
\v 18 Ji ne manyowa kamoro amora mawaluwo,
\q2 omiyo ne ok wanyal wuotho e wangʼ yorewa.
\q1 Luoro nomakowa nikech ndalowa nosechopo machiegni
\q2 kendo thowa ne osekayo.
\b
\q1 
\v 19 Jogo mane lawowa ne ringo mapiyo
\q2 maloyo ongo mafuyo e kor polo;
\q1 negilawowa e kor gode madongo
\q2 kendo negibutonwa e thim.
\b
\q1 
\v 20 Ngʼatno mowir mar Jehova Nyasaye,
\q2 mane wakwano kaka ngimawa,
\q2 nomaki e obadho mane gichiko.
\q1 Ne waparo ni e bwo tipone
\q2 wanyalo bedo mangima e dier ogendini.
\b
\q1 
\v 21 Moruru kendo beduru moil, yaye Nyar Edom,
\q2 un jogo modak e piny Uz.
\q1 To un bende, kikombeno ibiro miyou;
\q2 kendo ubiro mer mi udongʼ duge.
\b
\q1 
\v 22 Yaye jo-Sayun, kum mane okumugo biro rumo;
\q2 bende ok nochak omed ndalou mar twech.
\q1 To un jo-Edom, obiro kumou nikech richou
\q2 kendo timbeu mamono obiro elo e lela.
\b
\b
\c 5
\q1 
\v 1 Yaye Jehova Nyasaye, parie gima osetimorenwa;
\q2 rangwa mondo ineye wichkuot ma wan-go.
\q1 
\v 2 Girkeni mawa osemi jopinje mamoko,
\q2 to miechwa to osekaw gi ji ma welo.
\q1 
\v 3 Wasedongʼ kiye,
\q2 to minewa chalo mon ma chwogi otho.
\q1 
\v 4 Nyaka wangʼiew pi mawamodho;
\q2 yiendwa ma wachwako nyaka wachul nengo eka wayudgi.
\q1 
\v 5 Jogo malawowa nikodwa machiegni;
\q2 waol kendo waonge yweyo.
\q1 
\v 6 Ne wachiwore ni Misri kod Asuria
\q2 mondo wayud chiemo moromo.
\q1 
\v 7 Kwerewa notimo richo, to koro gionge,
\q2 to wan ema ikumowa kargi.
\q1 
\v 8 Wasumbini ema tinde otelonwa,
\q2 kendo onge ngʼama resowa e lwetgi.
\q1 
\v 9 Wayudo chiembwa e yo matek manyalo hinyo ngimawa
\q2 nikech lweny manie thim.
\q1 
\v 10 Dendwa owre mana ka mach
\q2 nikech tuo ma kech kelonwa.
\q1 
\v 11 Mon osemak githuon e Sayun,
\q2 to nyiri e miech Juda.
\q1 
\v 12 Jodong gwengʼ oselier gi lwetegi e yien,
\q2 to jomadongo ok osemi luor.
\q1 
\v 13 Jomatindo tiyo matek kuonde mag rego,
\q2 to yawuowi chandore ka gitingʼo yien mapek.
\q1 
\v 14 Jodongo onge e dhoranga dala maduongʼ;
\q2 kendo jomatindo oseweyo wero wendegi.
\q1 
\v 15 Mor oserumo e chunywa;
\q2 miendwa oselokore ywak.
\q1 
\v 16 Osimbo mar duongʼ oselwar oa e wiwa.
\q2 Yaye, masira omakowa, nikech wasetimo richo.
\q1 
\v 17 Nikech gik ma osetimorenwagi,
\q2 chunywa ool kendo wengewa osejony,
\q1 
\v 18 nimar got Sayun, osejwangʼ modongʼ gunda
\q2 ma ondiegi ema kwayoe.
\b
\q1 
\v 19 Yaye Jehova Nyasaye, lochni osiko manyaka chiengʼ
\q2 kendo ochwere e tiengʼ ka tiengʼ.
\q1 
\v 20 Ere gima omiyo wiyi wil kodwa kinde duto?
\q2 Ere gima omiyo ijwangʼowa kuom kinde malach kamano?
\q1 
\v 21 Yaye Jehova Nyasaye, dwogwa iri;
\q2 kendo ndalowa obed manyien kaka ne wan chon.
\q1 
\v 22 Ka ok itimonwa kamano, to nyiso ni isedagiwa
\q2 kendo in gi mirima kodwa ma ok nyal pim.
