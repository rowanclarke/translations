\v 29 \x - \xo 3.29 \xt Luk 12. 10.\x*\wj \+w Tedae|strong="G1161"\+w* \+w Mueihla|strong="G4151"\+w* \+w Cim|strong="G0040"\+w* \+w taengah|strong="G1519"\+w* aka \+w soehsal|strong="G0987"\+w* \+w te|strong="G3739"\+w* \+w tah|strong="G0302"\+w* \+w kumhal|strong="G0165"\+w* \+w duela|strong="G1519"\+w* \+w khodawkngainah|strong="G0859"\+w* \+w om|strong="G2192"\+w* \+w mahpawh|strong="G3756"\+w*\wj*,” a \w ti|strong="G3004"\w* nah.   
\p
\v 30 \w Tedae|strong="G0235"\w*, “\w Rhalawt|strong="G0169"\w* \w mueihla|strong="G4151"\w* a \w kaem|strong="G2192"\w*,” a \w ti|strong="G3004"\w* uh \w dongah|strong="G3754"\w* \w dungyan|strong="G0166"\w* \w tholhsainah|strong="G0265"\w* \w om|strong="G2076"\w* \w kuekluek|strong="G1777"\w* coeng.   
\s1 Jesuh kah Cako Parhaeng  
\p
\v 31 Te \w vaengah|strong="G2532"\w* \w a|strong="G0846"\w* \w manu|strong="G3384"\w* \w neh|strong="G2532"\w* \w a|strong="G0846"\w* \w mana|strong="G0080"\w* rhoek \w te|strong="G3588"\w* ha \w pawk|strong="G2064"\w* uh. \w Tedae|strong="G2532"\w* \w poengben|strong="G1854"\w* \w ah pai|strong="G4739"\w* uh tih \w Jesuh|strong="G2424"\w* aka \w khue|strong="G2564"\w* \w ham|strong="G4314"\w* te a \w tueih|strong="G0649"\w* uh.  
