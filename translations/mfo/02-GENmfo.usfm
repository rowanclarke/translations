\id GEN - Mbembe Okohm [MFNOk] 
\h Ittẹwọr 
\toc1 Nnwẹr kw'Ittẹwọr 
\toc2 Ittẹwọr 
\mt1 Nnwẹr kw'Ittẹwọr 
\c 1  
\s1 Ittẹwọr s'ọyagbin 
\p  
\v 1 K'ittẹwọr, Ibinọkpaabyi osi ẹrọng ọmaana irerek.  
\v 2 M'ogbe nwuma ọttọhk manda vani kode, ọyagbin ode idukhi, ibe kpenamkpen ipyi erungi \it bi kaang\it*. Egwugwuma ch'Ibinọkpaabyi erenga ẹbaabha asi. 
\li1  
\v 3 Mẹ wọ osi, Ibinọkpaabyi, oben bi, “Tte iyaan iwobha.” Wa iyaan iwobha.  
\v 4 Ibinọkpaabyi ore bi, iyaan ikk'ijibha, Ibinọkpaabyi ọbhaangi iyaan ide ngọmi ttara ipyerungi.  
\v 5 Mẹ wọ osi, Ibinọkpaabyi oyeri iyaan nnuma, ẹya, obiro oyeri ipyerungi, erungi. Wa ekpebha ọmaana ẹchọhkha bọ asi echedenwu m'ọyagbin. 
\li1  
\v 6 Ibinọkpaabyi oben bi, “Tte ọrọngkpakpa oyin k'ottem kw'asi. Tte ọbhaangi asi p'ẹrọng ọmaana asi p'irekh-irek.”  
\v 7 Mẹ wọ osi, Ibinọkpaabyi osi ọrọngkpakpa ọbhaangi asi. Asi bani awobha k'ọrọngkpakpa ebir-ebir, bani awobha k'ọrọngkpakpa irekh-irek. Iwa kwẹ ode mando.  
\v 8 Ibinọkpaabyi oyeri ẹrọng, ọrọngkpakpa. Wa ekpebha ọmaana ẹchọhkha bọ asi ottong iwu ifa m'oyagbin. 
\li1  
\v 9 Ibinọkpaabyi obiro oben bi, “Tte asi p'awobh k'ọrọngkpakpa irekh-irek atzobha ibe rani, ifha ogbin oyin.” Iwa kwẹ ode mando.  
\v 10 Ibinọkpaabyi oyeri irerek, ogbin, obiro oyeri asi p'atzobh ibe rani, araanga p'ideden. Ibinọkpaabyi ore bi, okk'ojibha. 
\pi1  
\v 11 Ibinọkpaabyi oben bi, “Tte irerek imen ekpo k'adem-k'adem: araraari p'áwọm amọma p'ámen ka ngera sabẹ ọmaana nchi si ńwọm aduk p'ási amọma pabẹ, k'odem kwa sẹ nde.” Iwa kwẹ ode mando.  
\v 12 Irerek imen araraari k'adem-k'adem, araraari awọm amọma p'afon k'amọma pabẹ ka for, nchi nwọm aduk p'afon k'amọma p'achiduk pabẹ ka for. Ibinọkpaabyi ore bi, okk'ojibha.  
\v 13 Wa ekpebha ọmaana ẹchọhkha bọ asi ottong iwu ittaan m'oyagbin. 
\li1  
\v 14 Ibinọkpaabyi oben bi, “Tte mkpon nwobha k'ọrọngkpakpa, sa ḿmaangi ẹya k'ipyerungi, tte sẹ nde ẹkhọhkha ch'igbe s'ọdadaami, ch'iwu ọmaana cha cho.  
\v 15 Tte mkpon nnuma mmaani k'ọrọngkpakpa, ifha sẹ ńnang iyaan k'irerek.” Iwa kwẹ ode mando.  
\v 16 Ibinọkpaabyi osi mkpon mfa sa ndeden. Wa osi ch'ẹbar-ọbar bi ẹkhaama ẹfa k'ẹya, ch'ẹkhar-ọkhara bi ekkeri erungi. Wa obiro osi ndodori.  
\v 17 Ibinọkpaabyi ohok mkpon nwobha k'ọrọngkpakpa bi, sẹ nnang iyaan k'irerek,  
\v 18 ọmaana bi, sẹ nkkeri ẹya ọmaana erungi, ọmaana bi sẹ mmaangi iyaan k'ipyerungi. Ibinọkpaabyi ore bi, okk'ojibha.  
\v 19 Iwa ekpebha ọmaana ẹchọhkha bọ asi ottong iwu inna m'ọyagbin. 
\li1  
\v 20 Ibinọkpaabyi oben bi, “Tte nden k'adem-k'adem mfu k'asi, sa nhaabh-ọhaabh, nwobha akpen. Tte ọnọhn f'ẹrọng okhur k'iwokhi s'ọyagbin k'ọrọngkpakpa.”  
\v 21 Mando wọ kw'Ibinọkpaabyi osi nden sa ndeden s'asi, ọmaana ọttọhk kpenamkpen f'orukhi akpen, obiro orenga k'asi, ọmaana ọnọhn k'adem-k'adem f'ọkhaam mbabaang. Ibinọkpaabyi ore bi, okk'ojibha.  
\v 22 Ibinọkpaabyi odo nden nnuma biphyir s'ọkk'ọsa, oben sẹ bi, “Bọng maan ayok k'ọhaabh abira afu k'asi p'araanga. Tte ọnọhn ọn-ọhaabh k'ọyagbin.”  
\v 23 Wa ekpebha ọmaana ẹchọhkha bọ asi ottong iwu izen m'ọyagbin. 
\li1  
\v 24 Ibinọkpaabyi obiro oben bi, “Tte irerek itzima nden sa nnukhi akpen k'adem pabẹ iyin, nden s'otzer, ọmaana ọttọhk kpenamkpen f'oreng k'irerek ttara nden s'ẹtzam otzor k'adem pabẹ.” Iwa kwẹ ode mando.  
\v 25 Mando wọ kw'iwa Ibinọkpaabyi osi nden s'ẹtzam, ọmaana nden s'otzer otzor k'adem pabẹ, ttara ọttọhk kpenamkpen f'oreng k'irerek otzor k'adem pabẹ. Ibinọkpaabyi ore bi, okk'ojibha. 
\pi1  
\v 26 Mẹ wọ, Ibinọkpaabyi oben bi, “Tte mosi anọngẹya ka ngera saman, p'akher man. Tte bẹ abaabha nden s'asi, ọmaana ọnọhn f'ẹrọng, ọmaana nden s'otzer, ọmaana irerek biphyir ttara ọttọhk kpenamkpen f'oreng k'irek.” 
\q1  
\v 27 Mẹ wọ, wa Ibinọkpaabyi oyok anọngẹya, 
\q2 oyok bẹ ka ngera sẹ. 
\q2 Wa oyok bẹ, ojinọng ọmaana kwanọng. 
\pi1  
\v 28 Ibinọkpaabyi odo bẹ, oben bẹ bi, “Bọng maan ayok, abira ahaabh, tte va pabọng afu ọyagbin, abira abaabha ọyagbin, ọmaana nden s'asi, ọmaana ọnọhn f'ẹrọng, ttara ọttọhk kpenamkpen f'owobh akpen, f'oreng k'irerek.” 
\pi1  
\v 29 Mẹ wọ osi, Ibinọkpaabyi oben bẹ bi, “Bọng kkeri, nkk'bọng achiduk ttara achimọma kpenamkpen p'awobh k'irerek nnanga, nchi biphyir sa nwọm aduk p'amọma awobh k'ẹtzaanga bi, sẹ ńde ọchattọhk fabọng.  
\v 30 Onode nden biphyir si nnukhi akpen k'irerek, ọmaana ọnọhn f'ẹrọng biphyir, ttara ọttọhk kpenamkpen f'oreng k'irerek, obiro oruk akpen, nkk'bẹ akwongitzọhng p'ẹtzam nnanga bi, bẹ achi, mach'ọchattọhk fabẹ.” Iwa kwẹ ode mando. 
\pi1  
\v 31 Iwa Ibinọkpaabyi ore bi, ọttọhk kpenamkpen f'ọkk'ọsa okk'ojibha kpọng-kpọng. Wa ekpebha ọmaana ẹchọhkha bọ asi ottong iwu izadani. 
\c 2  
\p  
\v 1 Iwa Ibinọkpaabyi okyera ọtzọhm f'ẹrọng, ọmaana irerek osisi, ttara ọttọhk kpenamkpen f'owobh k'ẹtzaanga kwabẹ. 
\li1  
\v 2 Ottong iwu izenamfa, Ibinọkpaabyi okk'ọtzọhm okyera f'om-osi, m'ewu ch'ettong iwu izenamfa okwokha ọwọhng k'ọtzọhm f'ọkk'ọm-ọsa.  
\v 3 Ibinọkpaabyi odo ewu nda ch'ettong izenamfa, ohok chẹ mach'ewu ch'ewur-owur, okhuri bi, m'ewu nda dọ ch'okwok ọwọhng, k'ọtzọhm f'ọyagbin osisi. 
\s1 Odem kw'iwa Ibinọkpaabyi oyokhi achedennọng 
\p  
\v 4 Ma wọ ode odem kw'iwa Ọvaar Ibinọkpaabyi oreng oyok ẹrọng ọmaana irek. 
\b  
\p K'ogbe kw'Ọvaar Ibinọkpaabyi osi ẹrọng ọmaana irerek,  
\v 5 iwa echi manda dani kemeni, ọraraari manda wani kobiro ommen, okhuri da Ọvaar Ibinọkpaabyi oni ẹrọng otzim ọsa bi, etzebh k'irerek, ttara bi, iwa ọnọng kw'ọyaabh irerek kode.  
\v 6 Yina, asi am-ayin k'irerek, asi irerek biphyir idiri. 
\p  
\v 7 Mẹ wọ, Ọvaar Ibinọkpaabyi otzima idọdọhbh ọbanga ojinọng, oji ọwọhng kw'akpen ọkhẹ-ẹ k'ahungmma, ojinọng nwa on-oruk akpen. 
\p  
\v 8 Ọvaar Ibinọkpaabyi osi owoni, kẹ da ewuchen em-eyin, k'Iden. Ọtzọkha ojinọng nwa kw'ọkk'ọbanga okhe mẹ.  
\v 9 Ọvaar Ibinọkpaabyi osi irerek imen nchi kpenamkpen k'adem-k'adem, nchi si njibhi ka chen, mbiri njibh k'ọchattọhk. Nchi mfa mbe k'ewonittem, echi dani ede ch'akpen, ndonggo ede ch'etzim-nonga ch'ejibha ọmaana epyibha. 
\p  
\v 10 Kẹ kw'ọraanga, kw'ofon k'Iden obhobhi ọkwọbha, obiro ọkhe asi m'ewonittem nduma, mẹ kw'ọraanga nwuma, obiro ọbhaangi k'araanga anna.  
\v 11 Ọraanga kw'ocheden okpen Pishọn, kẹ wọ obhobhi ochina k'irek sa Havila biphyir, kẹ da gol owobh.  
\v 12 Gol kw'irerek nnuma ode ọkkakkakwẹ. Wa ibe nnuma ibiri ikhaama ana p'adaami eruk, ọmaana atza p'ọniks.  
\v 13 Ọraanga kw'ottong afa okpena Gihọn, kẹ wọ obhobhi ọkhọri irek sa Kush biphyir.  
\v 14 Ọraanga kw'ottong attaan okpena Tigiris, kẹ wọ obhobhi k'okhubha kw'ewuchen em-eyin k'Asiriya. Ọraanga kw'ottong anna okpena Yupharetes. 
\p  
\v 15 Ọvaar Ibinọkpaabyi ọtzọkha ojinọng nwa ohok k'owoni kw'Iden, ifha ọyaabha owoni nwa obiro okker-ẹ.  
\v 16 Ọvaar Ibinọkpaabyi ọn-ọsana ojinọng nwa bi, “Kọ akhaam ọphaangi kẹ bi, achi achiduk kpenamkpen pa nchi si mbe m'owoni nwa.  
\v 17 Onode echi ch'etzim-nonga ch'ejibha ọmaana epyibha, kọ kàkhaambi, achi. Ewu ch'achi chẹ, akhaambi da ápe.” 
\p  
\v 18 Mẹ wọ, Ọvaar Ibinọkpaabyi on-oben bi, “Kojibhi bi, ojinọng nwa owobha mancheni, kaam ńsi oyok-ẹkhaan kw'ọ́baan-ẹ nnang-ẹ.” 
\p  
\v 19 Ode ch'Ọvaar Ibinọkpaabyi okk'idọdọhbh otzima ọbanga nden kpenamkpen s'ẹtzam, ọmaana ọnọhn f'ẹrọng. Ọtzọkha pyẹ biphyir ochena ojinọng nwa, ifha ore che-dema p'okpe pyẹ. Che ch'ojinọng nwa okpe ọttọhk kpenamkpen f'orukhi akpen, mando kwa fẹ okpen.  
\v 20 Mẹ wọ osi, ojinọng nwa okpe nden s'otzer biphyir che, ọmaana ọnọhn f'ẹrọng ttara nden s'ẹtzam biphyir. 
\p Yina, onode ojinọng oyok-ẹkhaan, kw'ọbaan-ẹ kode.  
\v 21 Mẹ wọ osi, Ọvaar Ibinọkpaabyi osi ojinọng nwa ọttaabha ẹdadim. Mada ojinọng otzim ọttaabh-ọttaabha, ọrọbh-ẹ ọtzẹtzẹngchikpa wani, obiro ọraakha ibe nnuma s'ọrọhbh ọtzẹtzẹngchikpa nwa ttara etzen-yaara.  
\v 22 Mẹ wọ osi, Ọvaar Ibinọkpaabyi ọtzọkha ọtzẹtzẹngchikpa kw'ọkk'ọrọbha k'ojinọng, otzima osi kwanọng, ọtzọkh-ẹ ochena ojinọng. 
\p  
\v 23 Ojinọng nwa oben bi, 
\q1 “Ma wọ on-ode ọkhọbhi kw'akhọbhi paam, 
\q1 ẹyaara ch'ẹyaara chaam. 
\q2 Kẹ bẹ áyer-ẹ, kwanọng, 
\q2 okhuri da bẹ arọbh-ẹ k'ojinọng ka for.” 
\p  
\v 24 Ofona mẹ, ojinọng óbina oji otte ttara ọkka, ọn-ọgbakha for sẹ ttara kwanọng kwẹ, ifha bẹ anọng afa an-ade ọnọng wani. 
\p  
\v 25 Wa ojinọng nwa ọmaana kwanọng kwẹ awobh irinikhum, bẹ mgbar karọbhi. 
\c 3  
\s1 Ocheden-jinọng ọmaana kwanọng kwẹ atzam ọsana 
\p  
\v 1 Iwa jọhk dọ edongi, ẹyọhnga nden s'ẹtzam biphyir, s'Ọvaar Ibinọkpaabyi ọkk'ọsa. Wa jọhk ẹtza ẹbọbh kwanọng nwa bi, “Ode odik-ọkka bi, Ibinọkpaabyi obeni bi, bọng aningi echi kpenamkpen m'owoni nwa achi o?” 
\p  
\v 2 Kwanọng nwa oben jọhk bi, “Nnh, nnh! Kwẹ mando kode! Ibinọkpaabyi obeni man bi, mofho ochi achiduk pa nchi si mbe mowoni ochi e,  
\v 3 yina, Ibinọkpaabyi on-obiro oben man bi, man kọ̀khaambi, ochi achiduk p'echi nduma ch'ebe m'ewonittem, man kọ̀khaambi ọttọhmi chẹ, oni mando ode, mópope.” 
\p  
\v 4 Jọhk nda eben kwanọng nwa bi, “Bọng kápe e,  
\v 5 okhinggẹ ode bi, Ibinọkpaabyi orong bi, idikha bọng achi achiduk mba, bọng are idik ittaani bọng \it bi ttaaan\it*, bọng an-abira ade mach'Ibinọkpaabyi kw'orong ejibha ọmaana epyibha.” 
\p  
\v 6 Mẹ wọ, mada kwanọng nwa ore bi, achiduk p'echi nda ajibh-ojibh k'ọchattọhk, bẹ abira anyu-onyu ka chen, ttara bi, bẹ afha anang ọnọng etzim-nonga, ọtzọkha bani ochi, obiro ọtzọkha ọnang odim kwẹ, kw'owobh mẹ ttara kẹ, odim obiro ọtzọkha ochi.  
\v 7 Mẹ ẹbaa nduma, chen attaani bẹ anọng afa, bẹ atzin bi, bẹ an-awobh irinikhum. Mẹ wọ, bẹ an-atzọkha akwongitzọhng p'echi cha fig, akhum ekpo abubha irinikhum sabẹ. 
\p  
\v 8 Okwu opyiri ma nchọhkha-bọhk, ojinọng ọmaana kwanọng kwẹ, an-abhaanga da Ọvaar Ibinọkpaabyi om-orenga m'owoni. Ofona mẹ, bẹ an-achubha Ọvaar Ibinọkpaabyi k'ottem kwa nchi s'owoni nwa.  
\v 9 Yina, Ọvaar Ibinọkpaabyi ogwon ojinọng, ọbọbh-ẹ bi, “Awobh man o?” 
\p  
\v 10 Kẹ obhina bi, “Kaam mmaang ndọkhi sọ, da am-arenga m'owoni, ojora osi-m, okhuri da ndim irinikhum, kẹ wọ osi nchubha e.” 
\p  
\v 11 Ọvaar Ibinọkpaabyi ọn-ọbọbh-ẹ bi, “Kọ anyi wọ ọgbaakh-ọ bi, atzim irinikhum? Akk'achiduk p'echi cha nsan-ọ, acha o?” 
\p  
\v 12 Ojinọng nwa obhin-ẹ bi, “Kwanọng kw'anang-m wọ ọnang-m achiduk p'afon m'echi nduma, yina kaam nchi e.” 
\p  
\v 13 Mẹ wọ osi, Ọvaar Ibinọkpaabyi ọn-ọbọbh kwanọng bi, “Bọng odik kw'asi ma?” 
\p Kwanọng nwa obhin-ẹ bi, “Jọhk dọ ẹbọhr-m, yina kaam ndọkha achiduk mbuma nchi e.” 
\s1 Ibinọkpaabyi ọkpaar aponga pabẹ 
\p  
\v 14 Mẹ wọ, Ọvaar Ibinọkpaabyi oben jọhk bi, 
\q1 “Okhuri odik nwa kw'asi ma, 
\q2 ópyibh-ópyibh ọnang-ọ, ọyọhnga nden s'otzer biphyir ọmaana nden s'ẹtzam biphyir, 
\q1 kọ átzọr ẹbhọr k'irek, 
\q2 ábira áchi ọkpọhm k'akpen pọ biphyir. 
\q1  
\v 15 Kaam ńge ittattaanga k'ottem kwa kọ ọmaana kwanọng nwa, 
\q2 ttara k'ottem kwa va pọ ọmaana va pẹ, 
\q2 bẹ awobha k'ittattaanga ttara ayok. 
\q1 Nnwa kwẹ ótzukhi eho chọ, 
\q2 kọ ákhimi ibhokhọkhọri sẹ.” 
\p  
\v 16 Ibinọkpaabyi on-oben kwanọng nwa bi, 
\q1 “Kaam ńttar-ọ ihem s'ideden, 
\q2 k'ogbe kpenamkpen kw'ám-amaan nnwa. 
\q1 Kaambi mẹ wọ, kọ ọm-ọdaakh-ọ bi, tte awobha abaanga odim kwọ, 
\q2 yina, odim wọ ọbaabh-ọ.” 
\p  
\v 17 Obiro oben Adam bi, 
\q1 “Kọ ayong kwanọng kwọ itzọhng, 
\q2 achi ochiduk kw'echi cha nsaan-ọ bi, aninga achi, 
\q1 kaam ńnang irerek ẹmma okhuri kọ. 
\q2 Kọ ám-are ihem s'ọtzọhm, yina áchi ọttọhk m'irek nna, 
\q2 k'akpen pọ biphyir. 
\q1  
\v 18 Afhodima ọmaana akkaangi ámen m'irerek. 
\q2 Kọ abira achi araraari p'owoni. 
\q1  
\v 19 Kọ ám-asi ọtzọhm maa arunga, 
\q2 yina ákhaama ọchattọhk f'áchi, 
\q1 ttẹwọr ma maa atza apyiri k'ogbe kw'ákpa nnam k'irerek, 
\q2 okhuri bi, bẹ atzim idọdọhbh asọ-ọ, 
\q2 m'idọdọhbh nnuma rani rọ s'ábira ábhakhi akpa nnam.” 
\p  
\v 20 Wa Adam\f + \fr 3.20 \ft K'eHiburu che nda \ft \+bd Adam\+bd* ekheri ọwọhng mach'oyeri ojinọng.\f* okpe kwanọng kwẹ Iv\f + \fr 3.20 \ft K'eHiburu, che cha \ft \+bd Iv\+bd* eyini, akpen.\f*, okhuri bi, kẹ wọ óde ọkka kw'anọng biphyir p'arukhi akpen. 
\p  
\v 21 Wa Ọvaar Ibinọkpaabyi ọtzọkha ndenkpa, otzima osi ekpo ẹfhọrapyẹ, ọnang Adam ọmaana kwanọng kwẹ, ifha bẹ afhọra, atzima abubha irinikhum sabẹ. 
\s1 Ibinọkpaabyi okhubh Adam ọmaana Iv k'owoni kw'Iden 
\p  
\v 22 Mẹ wọ osi, Ọvaar Ibinọkpaabyi oben bi, “Ojinọng nwa ọkk'ọn-ọda macha man, okk'ejibha ọmaana epyibha on-oronga. Kẹ kọ̀khaambi, onemi ọbọhk ọpha ochiduk m'echi ch'akpen ochi, oni mando ode, kẹ oruk akpen maa ogbe ode.” 
\p  
\v 23 Mẹ wọ osi, Ọvaar Ibinọkpaabyi okhubh Adam k'owoni kw'Iden, ifha ọyaabha irerek s'otzim ọbang-ẹ.  
\v 24 Mada Ibinọkpaabyi okhubhi Adam, ohok achẹrubim k'okhubha kw'ewuchen em-eyin k'owoni kw'Iden, ọmaana ọkkangkkaang kw'ode mach'okpondaak kw'ọwọm \it bi wuruwuru\it*, ọbhakhi iriring okkeri k'ibe kpenamkpen, ifha bẹ akpa eden ch'echin k'echi nduma ch'ẹnangi akpen. 
\c 4  
\s1 Ken ọmaana Ebẹl 
\p  
\v 1 Iwa Adam oyima kwanọng kwẹ Iv abẹ, Iv otzima ibhọr ọmaan Ken. Iv oben bi, “K'ẹkkaana ch'Ọvaar Ibinọkpaabyi ọnang-m, kaam nkk'nnwa kw'ijinọng mmaana.”  
\v 2 Wa Iv obiro otzima ibhọr ọmaan ọgbaanọkka kwa Ken, kw'ode Ebẹl. 
\p Iwa Ebẹl ode okkeri arukhimaan. Ken ode ọnọng kw'ọyaabh owoni. 
\p  
\v 3 Okwu otzuma k'ogbe mẹ, Ken otzima achiduk p'owoni kwẹ, osi ẹnanga ọnang Ọvaar Ibinọkpaabyi.  
\v 4 Ebẹl ọtzọkha acheden-va p'arukhimaan pẹ p'ajibhi for, otzima osi ẹnanga. Ọvaar Ibinọkpaabyi ọdaam ettem ttara Ebẹl ọmaana ẹnanga chẹ.  
\v 5 Onode Ken ọmaana ẹnanga chẹ, Ibinọkpaabyi ettem kẹ kẹdaami. Mẹ wọ osi, Ken ettem epyibh-ẹ, on-obhor itzitzikha. 
\p  
\v 6 Ọvaar Ibinọkpaabyi ọbọbh Ken bi, “Ode yan kw'ettem epyibh-ọ? Osi yan kw'abhori itzitzikha?  
\v 7 Idikha ira kọ akk'ejibha asa, ira kaam ettem kindaam ttar-ọ o? Yina, da ani ejibha asi, epyibha ẹm-ẹbaami bi, ẹbọkh-ọ. Kọ akhaambi, akhema chẹ.” 
\p  
\v 8 Wa Ken okwu ọkhaama nttọhna ttara ọgbaanọkka Ebẹl, oben-ẹ bi, “Tte moyin k'ẹtzam.” Mada abẹ awobh k'ẹtzam, Ken ottum ọgbaanọkka Ebẹl ofhu. 
\p  
\v 9 Mẹ wọ osi, Ọvaar Ibinọkpaabyi ọbọbh Ken bi, “Agbaanakka Ebẹl ko o?” 
\p Ken obhina bi, “Kaam kinnong, kaam wọ mminkkeri ọgbaanọkka kwaam o?” 
\p  
\v 10 Ọvaar Ibinọkpaabyi oben bi, “Bọng odik kw'asi ma? Izi s'agbaanakka im-ibhomi iyer-m k'irek, mach'ẹmọng ch'ebhomi eror ẹkkaana.  
\v 11 Mẹ wọ osi, nnang-ọ ẹmma, mbiri ngwubh-ọ k'irerek s'igwong ẹmma igwo izi s'agbaanakka kw'afhu.  
\v 12 Kọ ayaabh irerek, ekpo dọk kéjibh ẹnang-ọ. Kọ ẹwọr k'ibe rani kábọkha, án-ade ottettena-nọng m'ọyagbin.” 
\p  
\v 13 Ken oben Ọvaar Ibinọkpaabyi bi, “Ihem saam ibari iyọhng-m bi ndọhkha.  
\v 14 Mayina akk'aam akhubha m'irerek nna, ọmaana k'itzitzikha sọ, kaam nna nnọbh ebhon, mbiri nde ottettena-nọng m'ọyagbin, ọnọng kpenamkpen kw'óre-m ófhu-m ofhu.” 
\p  
\v 15 Yina, Ọvaar Ibinọkpaabyi on-oben Ken bi, “Ọnọng kpenamkpen kw'ọfhọ-ọ, ọ́tzọkha ọmmamma kw'ọ́yọhnga kwọ, igbe izenamfa.” Mẹ wọ osi, Ọvaar Ibinọkpaabyi okhe Ken ebhora ka for, ifha ọnọng kpenamkpen kw'ọ́rẹ-ẹ oning-ẹ ófhu.  
\v 16 Ken obina k'itzitzikha s'Ọvaar Ibinọkpaabyi ottena, otza oruk k'irek sa Nọd, k'okhubha kw'ewuchen em-eyin k'Iden. 
\s1 Efonamma cha Ken 
\p  
\v 17 Wa Ken oyima kwanọng kwẹ abẹ, kwanọng otzima ibhọr ọmaan Ẹnọk. M'ogbe nwa, wa Ken om-osi obhon. Che cha nnwa kwẹ Ẹnọk, ch'ọtzọk okpe obhon nwa. 
\q2  
\v 18 Wa Ẹnọk obhoni Irad. 
\q2 Irad obhon Mehujayẹl, 
\q2 Mehujayẹl obhon Metusayẹl 
\q2 Metusayẹl obiro obhon Lamẹk. 
\p  
\v 19 Wa Lamẹk ọtzọk panọng afa; wani okpen Ada, nwonggo okpena Zila.  
\v 20 Wa Ada ọmaan Jabal, kẹ wọ iwa ode otte kw'anọng p'iwa am-aruk k'okhira, abira atzir nden.  
\v 21 Ọgbaanọkka kwẹ okpena Jubal, kẹ wọ ode otte kw'anọng p'abhaa ogim-ogim okhikhir, am-abira agyi ophoropho. 
\p  
\v 22 Zila, obiro ọmaan Tubal-Ken, kw'om-oduk brons ọmaana akkonga otzima osi ekpo k'adem-k'adem. Ọgbaanọkka kwa Tubal-Ken kw'ikwanọng ode Naama. 
\p  
\v 23 Wa Lamẹk on-oben panọng pẹ bi, 
\q1 “Ada ọmaana Zila, 
\q2 Bọng panọng paam, 
\q2 bọng bhaanga atzim paam. 
\q1 Kaam nkk'ọnọng mfha, 
\q2 kw'omumum-m ọttọhk, 
\q1 odikkobh, kw'orim-m abẹ, 
\q2 kẹ wọ kwa mfhu. 
\q1  
\v 24 Idikha ọnọng manda wani ofhu Ken, 
\q2 kẹ óre ihem s'iyọhnga sa Ken igbe izenamfa, 
\q1 Yina, idikha ọnọng ofhu kaam Lamẹk, okhuri odikkobh kw'akaam mfhu, 
\q2 kẹ óre ihem s'iyọhnga s'ọnọng kw'ofhu Ken, igbe arọbh attaan obhiri chi obhiri afa.” 
\s1 Ẹmmaana cha Sẹt ọmaana Ẹnọs 
\p  
\v 25 Wa Adam obiro oyima kwanọng kwẹ abẹ, kwanọng otzima ibhọr ọmaan nnwa kw'ijinọng, ọkpẹ-ẹ Sẹt, oben bi, “Ibinọkpaabyi ọkk'aam nnwa ọdọdọk ọnanga kw'otzer eho ch'Ebẹl, kwa Ken ofhu.”  
\v 26 Sẹt obiro obhon nnwa kw'ijinọng, ọkpẹ-ẹ Ẹnọs. 
\p Wa k'ogbe kw'Ẹnọs wọ kw'anọng attẹwọr akpobha che ch'Ọvaar Ibinọkpaabyi. 
\c 5  
\s1 Efonamma ch'Adam 
\p  
\v 1 Ma wọ ode nnwẹr kw'odem kw'efonamma ch'Adam. 
\p Mada iwa Ibinọkpaabyi oyokhi anọngẹya, wa osi bẹ ka ngera sẹ.  
\v 2 Wa oyokhi bẹ, ojinọng ọmaana kwanọng, odo bẹ, oyeri bẹ, Anọngẹya. 
\p  
\v 3 Wa Adam okk'cho arọbh azadani obhiri jobh orukha, yina on-obhoni nnwa kw'ijinọng ka ngera sẹ, ọkpẹ-ẹ Sẹt.  
\v 4 Mada Adam okk'Sẹt obhona, wa obiro oruk cho nnọhna mfa, obiro obhon ajinọng ọmaana panọng adọdọk.  
\v 5 Biphyir-phyir, wa Adam orukhi cho nnọhna mfa obhiri arọbh azadani obhiri jobh, yina on-ope. 
\p  
\v 6 Mada Sẹt okk'cho arọbh azen obhiri azen orukha, obhon Ẹnọs.  
\v 7 Mada Sẹt okk'Ẹnọs obhona, wa obiro oruk cho nnọhna mfa obhiri azenamfa, obiro obhon ajinọng ọmaana panọng adọdọk.  
\v 8 Biphyir-phyir, wa Sẹt orukhi cho nnọhna mfa obhiri arọbh azen obhiri jobh obhiri afa, yina on-ope. 
\p  
\v 9 Mada Ẹnọs okk'cho arọbh anna obhiri jobh orukha, obhon Kenan.  
\v 10 Mada okk'Kenan obhona, wa obiro oruk cho nnọhna mfa obhiri chi, obiro obhon ajinọng ọmaana panọng adọdọk.  
\v 11 Biphyir-phyir, wa Ẹnọs orukhi cho nnọhna mfa obhiri arọbh azen obhiri azen, yina on-ope. 
\p  
\v 12 Mada Kenan okk'cho arọbh attaan obhiri jobh orukha, obhon Mahalalẹl.  
\v 13 Mada okk'Mahalalẹl obhona, wa obiro oruk cho nnọhna mfa obhiri arọbh afa, obiro obhon ajinọng ọmaana panọng adọdọk.  
\v 14 Biphyir-phyir, wa Kenan orukhi cho nnọhna mfa obhiri arọbh azen obhiri jobh, yina on-ope. 
\p  
\v 15 Mada Mahalalẹl okk'cho arọbh attaan obhiri azen orukha, obhon Jarẹd.  
\v 16 Mada Mahalalẹl okk'Jarẹd obhona, wa obiro oruk cho nnọhna mfa obhiri ẹrọbh obhiri jobh, obiro obhon ajinọng ọmaana panọng adọdọk.  
\v 17 Biphyir-phyir, wa Mahalalẹl orukhi cho nnọhna mfa obhiri arọbh anna obhiri chi, yina on-ope. 
\p  
\v 18 Mada Jarẹd okk'cho arọbh azenanttaan obhiri afa orukha, obhon Ẹnọk.  
\v 19 Mada Jarẹd okk'Ẹnọk obhona, obiro oruk cho nnọhna mfa, obiro obhon ajinọng ọmaana panọng adọdọk.  
\v 20 Biphyir-phyir, wa Jarẹd orukhi cho nnọhna mfa obhiri arọbh azenanttaan obhiri afa, yina on-ope. 
\p  
\v 21 Mada Ẹnọk okk'cho arọbh attaan obhiri azen orukha, obhon Mẹtusẹla.  
\v 22 Mada okk'Mẹtusẹla obhona, Ẹnọk ochina ororo ọtzọn Ibinọkpaabyi abẹ ka cho arọbh chi adọdọk, obiro obhon ajinọng ọmaana panọng adọdọk.  
\v 23 Biphyir-phyir, wa Ẹnọk orukhi cho arọbh chi obhiri arọbh attaan obhiri azen.  
\v 24 Wa Ẹnọk ochina ororo ọtzọn Ibinọkpaabyi abẹ, mẹ wọ, Ibinọkpaabyi otzim-ẹ ofona m'oyagbin nwa. 
\p  
\v 25 Mada Mẹtusẹla okk'cho arọbh ọhawani kwa jobh obhiri azenamfa orukha, obhon Lamẹk.  
\v 26 Mada okk'Lamẹk obhona, wa Mẹtusẹla obiro oruk cho ẹnọhna obhiri arọbh chi obhiri azenanttaan obhiri afa, obiro obhon ajinọng ọmaana panọng adọdọk.  
\v 27 Biphyir-phyir, wa Mẹtusẹla orukhi cho nnọhna mfa obhiri arọbh azenattaan obhiri ọhawani kwa jobh, yina on-ope. 
\p  
\v 28 Mada Lamẹk okk'cho arọbh ọhawani obhiri afa orukha, obhon nnwa kw'ijinọng,  
\v 29 ọkpẹ-ẹ Noa. Lamẹk on-oben bi, “Nnwa nwa ótzima ẹwọhngkwokha ochena man, k'ọtzọhm faman, ọmaana k'ihem saman, s'ifon k'irerek s'Ọvaar Ibinọkpaabyi ọkk'ẹmma ọnanga.” 
\p  
\v 30 Mada Lamẹk okk'Noa obhona, wa obiro oruk cho ẹnọhna obhiri arọbh ọhawani obhiri chi, obiro obhon ajinọng ọmaana panọng adọdọk.  
\v 31 Biphyir-phyir, wa Lamẹk orukhi cho ẹnọhna obhiri arọbh chi obhiri attaan obhiri chi obhiri afa, yina on-ope. 
\p  
\v 32 Mada Noa okk'cho ẹnọhna obhiri arọbh azen ọda, obhon va p'ijinọng attaan, p'ade Shẹm, ọmaana Ham, ọmaana Japhẹt. 
\c 6  
\s1 Itzama s'anọngẹya m'ọyagbin 
\p  
\v 1 Iwa anọngẹya attẹwọr ahaabh m'ọyagbin, bẹ abira amaan va p'ipanọng anang bẹ,  
\v 2 va p'Ibinọkpaabyi are bi, va mba p'ipanọng p'anọngẹya ajibh-ojibh. Mẹ wọ osi, bẹ an-atzekha ayok bani, atzọkha bẹ macha panọng pabẹ.  
\v 3 Mẹ wọ osi, Ọvaar Ibinọkpaabyi oben bi, “Egwugwuma chaam ch'esi anọng aruk akpen, ttara ọnọngẹya dọk kewobha matzẹmaa ikhina ogbe ode, okhuri bi, ọnọngẹya ode ọkpakpa. Ttẹwọr madeden, anọngẹya akpen dọk káruk ayongi cho arọbh azadani.” 
\p  
\v 4 K'ogbe nwuma, ttara kw'oyongi mẹ, wa aNẹphilim\f + \fr 6.4 \ft K'eHiburu, ọwọhng nwa kwa \ft \+bd Nephilim\+bd* oyini atzọhmi p'areng k'osisi kwabẹ atto k'Ibinọkpaabyi itzitzikha. Wa Nephilim ade atzọhmi pa panọng p'ọyagbin amaani, yina, abatte p'egwugwuma abhon bẹ.\f* awobh m'ọyagbin, mada va p'Ibinọkpaabyi ayim aminava p'anọngẹya abẹ, aminava mba atzima ọbhọr, amaan bẹ va. Va mba bọ iwa ade afa-nọng, bẹ abira ade ajinọng p'atza che. 
\p  
\v 5 Ọvaar Ibinọkpaabyi ore bi, itzama s'anọngẹya ikk'ibara kpọng-kpọng m'ọyagbin, ttara bi, achibhi p'anọngẹya biphyir an-ade epyibha, k'ogbe kpenamkpen.  
\v 6 Wa Ibinọkpaabyi for sẹ isẹ-ẹ nkwo, ettem ebire ẹmmẹ-ẹ, k'anọngẹya p'ọkk'ọsa m'ọyagbin.  
\v 7 Mẹ wọ osi, on-oben for sẹ bi, “Kaam ńdimi anọngẹya biphyir pa nkk'nsa, manda wani m'ọyagbin kórik. Kaam mbiri ńdimi nden biphyir, ọmaana ọnọhn f'ẹrọng biphyir, ọmaana ekpo py'ereng k'irerek biphyir. For saam isi-m nkwo bi, kaam nkk'pyẹ nyokha.” 
\p  
\v 8 Yina, iwa Noa ọtzọk ọphyaam k'itzitzikha s'Ọvaar Ibinọkpaabyi. 
\s1 Odem kw'okhuri Noa 
\p  
\v 9 Ma wọ ode odem kw'okhuri Noa. 
\p Wa Noa ode ọnọng kw'otzor-otzor, oponga-pyibha kobiro ọkhaama mach'anọng p'ogbe kwẹ. Kẹ wa ọtzọni Ibinọkpaabyi abẹ.  
\v 10 Wa Noa obhoni ajinọng attaan p'ade Shẹm, ọmaana Ham ttara Japhẹt. 
\p  
\v 11 Wa Ibinọkpaabyi on-ore bi, ọyagbin okk'okhibhi, obiro ore bi, ọyagbin on-ofu ttara ọgbaan.  
\v 12 Ibinọkpaabyi ore odem kw'ọyagbin okk'okhibhi opyiri, da anọngẹya biphyir k'ọyagbin akk'akpen pa bẹ akhibhi.  
\v 13 Mẹ wọ osi, Ibinọkpaabyi oben Noa bi, “Kaam nkk'ochibhi nsa bi, ńdimi anọngẹya biphyir, da ọyagbin on-ofu ttara ọgbaan, okhuri ọnọngẹya. Kker e, kaam ńdimi anọngẹya odimi biphyir ttara ọyagbin nwa.  
\v 14 Kọ Noa, tzima agbaakhakpa p'echi ch'ẹgaang-ọgaangi, amun ọkpaar kw'ideden anang for sọ. Si mmanggọ k'ọkpaar nwa ẹtzaanga, atzima ẹbaanttim akpa aphaangi pẹ k'iyaan, ọmaana k'ẹtzaanga, ifha asi aningi k'ọkpaar ẹtzaanga adimi.  
\v 15 Manda wọ kw'arenga amun ọkpaar nwa. Adum pẹ áde ndọkhi ẹnọhna obhiri arọbh afa obhiri jobh, ẹ̀kpá chẹ éde ndọkhi arọbh attaan obhiri chi, ebe chẹ éde ndọkhi arọbh afa obhiri nzen.  
\v 16 Si ittakhọhnga abubh-ẹ, ttẹwọr k'amma-kpabem pyiri k'ittakhọhnga, ahok ọphaangi kw'óde ẹtzọkhi k'obungi ọmaana igbokha makhọra. Si ọmma k'ẹbhabhaanga ch'okhubha wani kw'ọkpaar nwa, asi nyọng nttaan, dani k'irekh-irek, dani m'ottem, ndongo k'ẹrọng.  
\v 17 Kaam ńdọhm asi p'áchi ọttọhk kpenamkpen m'ọyagbin, ọttọhk kpenamkpen f'orukhi akpen. Ọttọhk kpenamkpen m'ọyagbin óbiro ópope.  
\v 18 Onode kọ, kaam ńsi echekhi chaam nnang kọ ọmaana va pọ, ttara kwanọng kwọ, ọmaana panọng pa va pọ, bọng biphyir adim k'ọkpaar nwa ẹtzaanga.  
\v 19 Kọ átzọkha adem afa-afa p'ọttọhk kpenamkpen f'orukhi akpen, ojinọng ọmaana kwanọng, adim k'ọkpaar nwa ẹtzaanga, ifha pyẹ eruk akpen ttara kọ k'ọkpaar.  
\v 20 Adem afa-afa p'ọnọhn kpenamkpen, ọmaana pa nden kpenamkpen, ttara p'ọttọhk kpenamkpen f'oreng k'irerek, ékwu ifha ahok pyẹ akpen.  
\v 21 Kọ tzobha ọttọhk kpenamkpen f'ode ọchattọhk ọnang bọng, f'obiro ode ọchattọhk ọnang nden nnonggo biphyir, aye k'ọkpaar.” 
\p  
\v 22 Noa osi odik kpenamkpen mach'Ibinọkpaabyi ọtzọhn-ẹ. 
\c 7  
\s1 Odem kw'iwa asi achi ọyagbin 
\p  
\v 1 Mẹ wọ osi, Ọvaar Ibinọkpaabyi oben Noa bi, “Kọ tzima ẹhọhmmọr chọ adim k'ọkpaar, okhuri bi, kaam nkk'nna bi, kọ wọ ade ọnọng kw'otzor-otzor m'ọgbọ nwa e.  
\v 2 K'ottem kwa nden sa mbaan bi, anọng atzima afọhni ẹja, k'adem kpenamkpen pabẹ, tọkha mfa-mfa, k'obe ozenamfa, odim ọmaana kwa, ayikha k'ọkpaar nwa. Onode nden sa nni k'ẹjafọhni mbaan, k'adem kpenamkpen pabẹ, tọkha odim ọmaana kwa,  
\v 3 abira atzọkha ọnọhn ozenamfa-ozenamfa, k'adem kpenamkpen pabẹ, odim ọmaana kwa, ifha fẹ oruk akpen obiro ohok adem pabẹ m'ọyagbin.  
\v 4 K'iwu izenamfa k'itzitzikha, kaam ńsi ẹrọng etzebh m'ọyagbin, k'iwu arọbh afa ọmaana ka nnungiwu arọbh afa, ńdima chẹ ńdimi ekpo kpenamkpen pya nkk'nsa, py'erukhi akpen m'ọyagbin.” 
\p  
\v 5 Iwa Noa osi odik kpenamkpen kw'Ọvaar Ibinọkpaabyi ọtzọhn-ẹ. 
\p  
\v 6 Wa Noa ode ojinọng kw'ode cho ẹnọhna obhiri arọbh jobh, mada asi anwa achi ọyagbin.  
\v 7 Wa Noa otzima va pẹ ttara kwanọng kwẹ ọmaana panọng pa va pẹ, bẹ adim k'ọkpaar nwa, ifha bẹ arọbh anaanga asi p'anwa.  
\v 8 Nden mfa-mfa sa mbaan k'ẹjafọhni, ọmaana sa nni k'ẹjafọhni mbaan, ọmaana ọnọhn, ttara ekpo biphyir py'ereng k'irerek,  
\v 9 odim ọmaana kwa, nnenga nkhebha Noa, mbiri ndim k'ọkpaar nwa, mach'Ibinọkpaabyi okk'Noa ọtzọhna.  
\v 10 Mada iwu nnuma izenamfa ikk'ikwọbha, asi anwa achi ọyagbin. 
\p  
\v 11 K'ogbe kw'iwa Noa okk'akpen orukha opyiri cho ẹnọhna obhiri arọbh jobh, k'iwu chi obhiri ifa s'ophe kw'ottong afa, m'ewu nduma akhekhaho amaam asi haabhada k'irerek, bẹ abira akwunga amma p'asi p'ọrọngkpakpa.  
\v 12 Wa ẹrọng etzebh m'ọyagbin k'iwu arọbh afa ọmaana ka nnungiwu arọbh afa. 
\p  
\v 13 M'ewu nduma dani, Noa ọmaana va pẹ p'ade Shẹm, ọmaana Ham, ọmaana Japhẹt ttara kwanọng kwa Noa ọmaana panọng pa va pẹ, adim k'ọkpaar nwa.  
\v 14 Wa bẹ awobh k'ọkpaar nwa ttara nden s'ẹtzam biphyir, atzor k'adem pabẹ, ọmaana nden s'otzer biphyir, atzor k'adem pabẹ, ọttọhk kpenamkpen f'oreng k'irerek, otzor k'odem kwẹ, ọmaana ọnọhn biphyir atzor k'adem pabẹ, ttara ọttọhk kpenamkpen f'ọkhaam mbabaang.  
\v 15 Ekpo ẹfa-ẹfa biphyir py'erukhi akpen, ẹtza ekhebha Noa, edim k'ọkpaar nwa.  
\v 16 Wa nden sa mmindim k'ọkpaar nwa nde odim ọmaana kwa, f'ọttọhk kpenamkpen f'orukhi akpen, atzor mach'Ibinọkpaabyi okk'Noa ọtzọhna. Mẹ wọ e, Ọvaar Ibinọpkaabyi obhen ọmma okpori Noa k'ẹtzaanga. 
\p  
\v 17 Asi achina ororo achi ọyagbin k'iwu arọbh afa, asi achina ororo anwa maa bẹ ayebh ọkpaar nwa anana k'asi ebir-ebir.  
\v 18 Asi anwa k'ọhaabh, bẹ achina ororo afu k'ọyagbin \it bi pyẹrrr\it*, ọkpaar on-obiro obhobh k'asi ebir-ebir.  
\v 19 Asi anwa maa bẹ abhọri mgbegbeho si ngor-ogori biphyir m'ọyagbin.  
\v 20 Asi anwa abhọri mgbegbeho maa ododong kw'asi ọyọhnga ndọkhi ẹrọbh.  
\v 21 Ọttọhk kpenamkpen f'oreng m'irerek ope, ọnọhn, ọmaana nden s'otzer, ọmaana nden s'ẹtzam ọmaana ekpo biphyir py'efu m'ọyagbin, ttara anọngẹya biphyir.  
\v 22 Ọttọhk kpenamkpen k'ogbin f'oji ọwọhng kw'akpen k'ahungmma, ope.  
\v 23 Mando kw'Ibinọkpaabyi odimi ekpo kpenamkpen py'erukhi akpen k'ọyagbin, anọngẹya ọmaana nden, ọmaana ekpo py'ereng k'irerek, ttara ọnọhn f'ẹrọng odimi pyẹ biphyir. Wa on-orik Noa ttara ọttọhk kpenamkpen f'owobh k'ọkpaar nwa ttar-ẹ. 
\p  
\v 24 Wa asi anwa achi ọyagbin k'iwu arọbh azenamfa obhiri jobh. 
\c 8  
\s1 Asi p'achi ọyagbin awọhri 
\p  
\v 1 M'ogbe nwuma kw'iwa asi akk'oyagbin acha, wa Ibinọkpaabyi Noa kọraam. Wa nden biphyir s'otzer ọmaana s'ẹtzam sa nwobh k'ọkpaar ẹtzaanga ttara Noa, kobiro ọraama. Ọn-ọtzọhm ọphapha ogwuma k'ọyagbin, kw'osi asi awọhri.  
\v 2 Akhekhaho p'irerek akka, bẹ akk'amma p'asi p'ọrọngkpakpa abira akpa, ẹrọng ẹkk'ẹkwọbha otze-tzebh k'ọyagbin.  
\v 3 Asi achina ororo awọhri k'ọyagbin. Okwu ottonga iwu arọbh azenamfa obhiri jobh, asi akk'an-awọhri.  
\v 4 Ottong iwu chi obhiri ifa, s'aphe azenamfa, ọkpaar ọtza ottima ka mgbegbeho s'Ararat\f + \fr 8.4 \fq Ararat \ft ode ibe sa mgbegbeho s'ideden.\f*.  
\v 5 Asi achina ororo awọhri maa opyiri echedenwu ch'aphe jobh, mgbegbeho ngọhkha. 
\p  
\v 6 Mada iwu arọbha afa ikk'ikwọbha, Noa okwunga ọphapha-mma kw'ọkpaar kw'ọkk'ọsa.  
\v 7 Ọtzọhm ẹtzọrikhukhu, ch'ekhuri echina ororo ẹkpa nnam, matzẹmaa opyiri k'ogbe kw'asi akk'akka k'ọyagbin.  
\v 8 Obiro ọtzọhm igbegbaa, ifha oronga idikha asi akk'akka k'irerek.  
\v 9 Yina, wa igbegbaa ibe s'ibe mmo kire, okhuri da asi atzima awobh k'irerek. Sẹ ikhuna itzor Noa k'ọkpaar. Noa onemi ọbọhk ọbọkha sẹ, okhe k'ọkpaar. 
\p  
\v 10 Noa owobha iwu izenamfa ọdọdọk, obiro ọtzọhm igbegbaa nnuma iyin k'ọkpaar.  
\v 11 Mada igbegbaa ikhun itzor-ẹ k'ẹchọhkha, itzima ikwongitzọhng s'oliv s'idẹkh-ọdẹkhi k'ẹmma. Mẹ wọ, Noa oronga bi, asi akk'awọhri k'ọyagbin.  
\v 12 Owobha iwu izenamfa idọdọk, obiro ọtzọhm igbegbaa. Yina, m'ogbe nwa sẹ kikhun. \fig |alt="Dove flying" src="hk00064c.jpg" size="col" loc="8.5" copy="Illustrations by Horace Knowles, © The British & Foreign Bible Society, 1954, 1967, 1972, 1995" ref="8.5" \fig* 
\p  
\v 13 K'echedenwu ch'ophe kw'ocheden, ch'esi Noa cho ẹnọhna obhiri arọbh jobh obhiri wani, asi akk'akka k'ọyagbin. Noa ogbe ẹpaho ch'ọkpaar, okkeri, ore bi, irerek ikk'ittẹwọr igwu.  
\v 14 K'iwu ẹrọbh obhiri izenamfa s'ophe kw'ottong afa, irerek ikk'in-igwa biphyir. 
\p  
\v 15 Mẹ wọ osi, Ibinọkpaabyi on-oben Noa bi,  
\v 16 “Tzima kwanọng kwọ, ọmaana va pọ, ọmaana panọng pa va pọ, bọng ayin k'iyaan.  
\v 17 Kọ biri tzima ọttọhk kpenamkpen f'orukhi akpen k'adem-k'adem, f'owobh ttar-ọ, ọnọhn, ọmaana nden ttara ekpo py'ereng k'irerek, ifha py'ẹhaabh k'irerek, py'ebire ẹ́maan ayok, ébire ẹ́haabh-ọhaabh k'obhik.” 
\p  
\v 18 Mẹ wọ, Noa oyin k'iyaan ọmaana va pẹ p'ijinọng, ọmaana kwanọng kwẹ, ttara panọng pa va pẹ.  
\v 19 Nden biphyir, ọmaana ekpo biphyir py'ereng k'irerek, ọmaana ọnọhn biphyir, ttara ọttọhk kpenamkpen f'oreng k'irerek oyin k'ọkpaar nwa, k'adem pabẹ. 
\p  
\v 20 Mẹ wọ osi, Noa osi ijafọhnibe ọnang Ọvaar Ibinọkpaabyi, ọtzọkha etzen dani-dani k'adem pa nden sa mbaan k'ẹjafọhni, ọmaana ọnọhn f'ọbaan k'ẹjafọhni, otzima osi ẹjafọhni ch'ẹnanga ẹkwọmichẹ m'ijafọhnibe nna.  
\v 21 Ọvaar Ibinọkpaabyi ọbhaang eruk damandaam ch'ẹja nda, on-oben k'ettem chẹ bi, “Kaam ikhina ọyagbin ẹmma dọk kińnang, okhuri ọnọngẹya, kaambi ode bi, ettem ch'ọnọngẹya en-efu ttara itzama ttẹwọr k'ẹvava. Yina rang ọdọk kwa kaam ndimi ekpo py'erukhi akpen biphyir, macha ndimi m'ogbe nwa. 
\q1  
\v 22 Ttẹwọr madẹdẹn maa apyiri k'okpong kw'ọyagbin, 
\q1 ogbe kw'ekpo ọyayaabha, ọmaana ogbe kw'ipha, 
\q1 ogbe kw'etzetzebhi ttara iyoma, 
\q1 ogbe kw'ẹya ttara erungi, 
\q1 idik nna biphyir okpong kíkhaama, íchina ororo matzẹmaa ogbe ode.” 
\c 9  
\s1 Echekhi ch'Ibinọkpaabyi osi ọnang Noa 
\p  
\v 1 Mẹ wọ osi, Ibinọkpaabyi odo Noa ttara va pẹ, oben bẹ bi, “Bọng mon va, tte va pabọng ahaabh-ọhaabh, abira anyaami, aruk k'ibe kpenamkpen m'ọyagbin.  
\v 2 Nden s'ẹtzam biphyir, ọmaana ọnọhn f'okhuri k'ẹrọng, ttara ekpo py'ereng k'irerek biphyir, ọmaana nden s'asi biphyir, pyẹ biphyir éruk ẹkhaama ojora fabọng. Kaam nhokhi pyẹ biphyir k'irekh-irek kwọ bi, akkeri.  
\v 3 Ọttọhk kpenamkpen f'orukhi akpen obiro oreng-orenga óde ọchattọhk ọnang bọng. Mach'iwa nnangi bọng araraari, nna mbiri nnang bọng ọttọhk kpenamkpen mach'ọchattọhk. 
\p  
\v 4 “Yina, ọkhaam ọttọhk f'án-achi. Kọ etzen ch'etzim ẹkhaam izi kachi, okhuri bi, izi rọ ide akpen.  
\v 5 Idikha ọnọng ofhu oyok ọnọngẹya, kaam ńnor akpen p'oyok mbọbh-ẹ. Etzen ch'efhu ọnọngẹya, ńnang chẹ ettuma. Ọnọng kw'ofhu oyok, ńnang-ẹ ettuma ch'ẹbaan-ẹ. 
\q1  
\v 6 Ọnọng kpenamkpen kw'ofhu oyok ọnọngẹya, 
\q2 mando wọ kw'ọnọng óbiro ófhu kẹ, 
\q2 okhuri bi, kẹ Ibinọkpaabyi osi ọnọngẹya ka ngera sẹ. 
\m  
\v 7 “Bọng mon va, tte va pabọng ahaabh-ọhaabh, anyaami aruk k'ibe kpenamkpen m'ọyagbin.” 
\p  
\v 8 Mẹ wọ osi, Ibinọkpaabyi oben Noa ọmaana va pẹ bi,  
\v 9 “Kker e, kaam nsi echekhi nnang bọng, ttara va pa va pabọng.  
\v 10 Echekhi nda ewobh ẹnang ọttọhk kpenamkpen f'orukhi akpen, ọmaana ọnọhn, ọmaana nden s'otzer, ttara nden s'ẹtzam, nnuma biphyir sa nyini k'ọkpaar ttara bọng, sa nnukhi akpen m'ọyagbin.  
\v 11 Kaam nsi echekhi nnang bọng bi, ogbe dọk kóde kw'asi an-abira achi ekpo py'erukhi akpen biphyir, ogbe dọk kóde kw'asi abira akhibhi ọyagbin.” 
\p  
\v 12 Ibinọkpaabyi obiro oben bi, “Ma wọ ode ẹkhọhkha ch'Echekhi chaam, cha mmingaama ttara bọng ọmaana ekpo py'erukhi akpen biphyir, echekhi nda éwobha ẹnang igbọ s'ikwu k'ogbe ororo.  
\v 13 Kaam nkk'esididibha chaam nhokha k'eboni, ch'éde ẹkhọhkha ch'Echekhi cha kaam ngaam ttara bọng, ọmaana ọyagbin biphyir.  
\v 14 Ogbe kwa ndọhmi eboni k'ọyagbin, esididibha eyini,  
\v 15 kaam ńjima echekhi chaam, ttara bọng ọmaana odem kpenamkpen kw'ekpo biphyir py'erukhi akpen. Ogbe dọk kode kw'asi ánwa adimi ekpo biphyir py'erukhi akpen.  
\v 16 Mẹ wọ osi, ogbe kpenamkpen kw'esididibha eyini k'eboni, ńne chẹ, mbiri ńjima echekhi nduma ch'Ibinọkpaabyi ọkhaam ọmaana ekpo biphyir py'erukhi akpen m'ọyagbin, k'adem-k'adem, py'ewobha m'ọyagbin maa ipemanitzor.” 
\p  
\v 17 Mẹ wọ osi, Ibinọkpaabyi oben Noa bi, “Esididibha dọ ede ẹkhọhkha ch'Echekhi cha kaam nsi nnang ẹkpo kpenamkpen py'erukhi akpen k'ọyagbin.” 
\s1 Odem kwa va pa Noa 
\p  
\v 18 Iwa va p'ijinọng pa Noa p'ayini k'ọkpaar nwa ade; Shẹm, ọmaana Ham, ttara Japhẹt. Ham wọ iwa ode otte kwa Kenaan.  
\v 19 Iwa ofon ma va mba attaan pa Noa, ọmaana va pabẹ, anọngẹya anyaami afhu ọyagbin \it bi pyẹrrr\it*. 
\p  
\v 20 Wa Noa ode ọnọng kw'ọyaabh owoni. Kẹ wọ iwa ode ocheden-nọng kw'ọttẹwọr ogbon nchi si mminwọm aduk p'agrep. Nchi nna s'agrep mminwọm aduk pa bẹ am-atzima asi atzuk.  
\v 21 K'ogbe wani, wa Noa ogwo atzuk p'achiduk mbuma matzẹmaa obumma, oyima irinikhum k'ikhira sẹ.  
\v 22 Mẹ wọ, Ham otte kwa Kenaan, ore irinikhum s'otte, ọtza ọgbaak abagbaanọkka k'iyaan.  
\v 23 Mẹ wọ osi, Shẹm ọmaana Japhẹt atzọkha ibara s'ideden anana ka mbabaang sabẹ, bẹ arenga nnama-nnam, akpa nnam abọra otte, abubh-ẹ irinikhum, ifha bẹ aningi irinikhum s'otte are.\fig Aduk p'agrep|alt="grapes and vine" src="hk00110c.tif" size="col" ref="9.20" \fig* 
\p  
\v 24 Mada Noa ọn-ọphyọbh, da atzuk akk'ẹ attoni, oronga odik kwa Ham, kw'ode nnwa kwẹ kw'ikhakhari ọkk'ọsa, ọnang-ẹ ẹmma oben bi, 
\q1  
\v 25 “Ẹmma ẹbọkha Kenaan! 
\q1 Kẹ óde obira kw'owobha k'irekh-irek kw'abira pa vọkka pẹ biphyir.” 
\q1  
\v 26 Wa obiro oben bi, 
\q1 “Tte ẹtzọhnga ewobha ẹnang Ọvaar Ibinọkpaabyi kwa Shẹm okpobh, 
\q1 tte Kenaan obiro ode obira kwa Shẹm. 
\q1  
\v 27 Tte Ibinọkpaabyi ọmmẹma nnem sa Japhẹt, 
\q1 tte Japhẹt oruk k'okhira fa Shẹm, 
\q1 tte Kenaan ode obira kwa Japhẹt.” 
\p  
\v 28 Mada asi p'achi ọyagbin akk'akka biphyir, Noa obiro oruk cho arọbh-chi-obhiri-afa obhiri jobh.  
\v 29 Mẹ wọ oyini bi, biphyir-phyir, wa Noa orukhi cho nnọhna mfa obhiri arọbh azenamfa obhiri jobh. 
\c 10  
\s1 Odem kw'efonamma cha Noa 
\p  
\v 1 Ma wọ ode odem kw'efonamma cha Noa ch'ede Shẹm, ọmaana Ham, ttara Japhẹt. Wa va mba akk'abhakhi abhon ayok, k'ogbe kw'iwa asi p'achi ọyagbin akk'akka. 
\s1 Ẹnọmma cha Japhẹt 
\li1  
\v 2 Va pa Japhẹt p'ijinọng wa bẹ ade: 
\li2 Goma, ọmaana Magọg, ọmaana Madai, ọmaana Javan, ọmaana Tubal, ọmaana Mẹshẹk, ttara Tiras. 
\li1  
\v 3 Wa va p'ijinọng pa Goma ade: 
\li2 Askenaz, ọmaana Riphat, ttara Togama. 
\li1  
\v 4 Va p'ijinọng pa Javan ade: 
\li2 Elisha, ọmaana Tarshish, ọmaana Kitim, ttara Dodanim.  
\v 5 Wa va pa va p'anọng mba, bọ iwa arukhi k'araanga akhaan-ọkhaan, an-abhaangi aruk k'orerek fabẹ, ka mfonamma sabẹ, ọmaana k'ibhon k'ibhon, anọng-ọnọng agbaak ebhon chabẹ. Ma wọ iwa ode ẹnọmma cha Japhẹt. 
\s1 Ẹnọmma cha Ham 
\li1  
\v 6 Va pa Ham p'ijinọng bẹ ade: 
\li2 Kush, ọmaana Ijip, ọmaana Put, ttara Kenaan. 
\li1  
\v 7 Kush ọn-ọbhakhi obhon: 
\li2 Seba, ọmaana Havila, ọmaana Sabata, ọmaana Rama, ttara Sabateka. 
\li1 Wa va pa Rama ade: 
\li2 Sheba, ọmaana Dedan. 
\b  
\p  
\v 8 Kush wọ iwa obiro ode otte kwa Nimrọd, kw'iwa ode okkenggitza kw'ideden k'ọyagbin.  
\v 9 Nimrọd wa ode ọgbaajijaa kw'ideden k'itzitzikha s'Ọvaar Ibinọkpaabyi. Kwẹ kwọ osi bẹ am-aben bi, “Macha Nimrọd, kw'ode ogbaajijaa kw'ideden kw'Ibinọkpaabyi ọkk'ọwọbh ọnanga.”  
\v 10 Ichedenmon s'iwa kẹ ọdabhi ẹvaar ide ibhon sa Babẹl, ọmaana Ẹrẹk, ọmaana Akad, ttara Kalnẹ. Ibhon nna biphyir wa s'iwobh k'okhubha kwa Shina.  
\v 11 Ma kw'iwa on-obin ochina k'okhubha kw'Asiriya, otza osi ibhon sa Ninevẹ, ọmaana Rehobot-Ir, ọmaana Kala,  
\v 12 ọmaana Resen, kw'owobh k'ottem kwa Ninevẹ, ttara odedenmon kwa Kala. 
\b  
\li1  
\v 13 Wa Ijip ọbhakhi obhon abaLud, ọmaana abAnam, ttara abaLehab, ọmaana abaNaphatu,  
\v 14 ọmaana abaPatarus, ọmaana abaKasalu, ttara abaKaphatọr. AbaKasalu bọ iwa an-abira abhakhi abhon ẹkhọma cha Philistiya. 
\li1  
\v 15 Kenaan, kẹ wa ocheden obhon Sidọn, obiro obhon abaHet.  
\v 16 Wa ngọma sa mfon ka Kenaan nde: abaJẹbus, ọmaana abAmọr, ọmaana abaGirgash,  
\v 17 ọmaana abaHiv ọmaana Ak, ọmaana abaSin,  
\v 18 ọmaana abAvad, ọmaana abaZẹma, ttara abaHamat. 
\p Wa nnọmma nna biphyir sẹ mfon ka Kenaan, nnyaami  
\v 19 Wa ẹkhọma cha Kenaan etzim maa epyiri Sidọn, ebir etzima ka Gẹra maa etzuma ka Gaza, ebir etzima echina ka Sodom, ọmaana Gomora, ọmaana Adama, ọmaana Zeboyim, maa apyiri ka Lasha. 
\p  
\v 20 Ma wọ iwa ode ẹnọmma cha Ham, ka mfonamma sabẹ, ọmaana ka mmon sabẹ, ọmaana k'orerek fabẹ ttara k'ibhon sabẹ. 
\s1 Ẹnọmma cha Shẹm 
\p  
\v 21 Shẹm, kw'iwa Japhẹt otzori nnam, wa obhoni Ẹbẹr, ttara va p'Ẹbẹr obhoni biphyir. 
\li1  
\v 22 Wa Shẹm obiro obhon va adọdọk p'ade: 
\li2 Ẹlam, ọmaana Ashur, ọmaana Arphaksad, ọmaana Lud, ttara Aram. 
\li1  
\v 23 Wa va p'Aram ọbhakhi obhon ade 
\li2 Uz, ọmaana Hul, ọmaana Gẹta, ttara Mash. 
\li1  
\v 24 Arphaksad obhon 
\li2 Shẹla, kw'obiro ọbhakhi obhon Ẹbẹr. 
\li1  
\v 25 Ẹbẹr, wa obhoni va p'ijinọng afa: Ocheden okpen 
\li2 Pẹlẹg, kw'oyini, ẹbhaangi. K'ogbe kwẹ wọ kw'iwa anọng abhaangi k'ọyagbin, bẹ anyaami aruk k'ibe kpenamkpen; ọgbaanọkka kwa Pẹlẹg okpena Jọktan. 
\li1  
\v 26 Jọktan wa obhoni 
\li2 Almodad, ọmaana Shẹlẹph, ọmaana Hazamavẹt, ọmaana Jẹra,  
\v 27 ọmaana Hadoram, ọmaana Uzal, ọmaana Dikala,  
\v 28 ọmaana Ọbal, ọmaana Abimayẹl, ọmaana Sheba,  
\v 29 ọmaana Ophir, ọmaana Havila, ttara Jobab. Anọng mba biphyir wa bẹ ade va pa Jọktan. 
\p  
\v 30 Wa ẹkhọma ch'anọng mba arukhi ẹttẹwọr ka Mẹsha maa achina ka Sẹphar, ka mgbegbeho sa nwobh k'okhubha kw'ewuchen em-eyin. 
\p  
\v 31 Ma wọ iwa ode ẹnọmma cha Shẹm ka mfonamma sabẹ, ọmaana ka mmon sabẹ, ọmaana k'orerek fabẹ, ttara k'ibhon sabẹ. 
\p  
\v 32 Ma wọ iwa ode mfonamma sa va pa Noa, atzor ka va pa va k'idibhon sabẹ. Wa ofon k'anọng mba, idibhon s'ọyagbin biphyir in-inyaami, k'ogbe kw'asi p'iwa achi ọyagbin akk'akka. 
\c 11  
\s1 Ẹnyọhng ch'egor-ogori ka Babẹl 
\p  
\v 1 Iwa anọng m'ọyagbin biphyir akhaam ebhon dani, bẹ am-abira agbaak odik wani.  
\v 2 Mada anọng areng achina k'okhubha kw'ewuchen em-eyin, bẹ akwu are ẹttẹri dani k'okhubha kwa Shina\f + \fr 11.2 \ft \+bd Shina\+bd* obiro okpena Babilọniya.\f*, bẹ atzima mẹ asi oruk kwabẹ. 
\p  
\v 3 Mẹ wọ ofon, bẹ an-aben ayok bi, “Bọng kwu ifha mọbanga idọdọhbh k'apyi, mọyaan sẹ maa, sẹ igwu igaangi \it bi kpọkhọdọ\it*.” Mẹ wọ ofon, bẹ abanga adọdọhbh-pyi atzima atzera atza p'ihọhm, bẹ atzima ana p'abang-ọbanga abira pyi \it bi kaang\it*, atzima atzera idọdọhbh idukhasẹ.  
\v 4 Mẹ wọ osi, bẹ aben bi, “Bọng kwu mosi odedenmon ttara ẹnyọhng ch'egori \it bi kotoong\it* maa, epyiri k'ọrọngkpakpa, ifha mosi che ọnang for sa man. Oni mando ode, mọraam-ọraami m'ọyagbin.” 
\p  
\v 5 Mẹ wọ ofon, Ọvaar Ibinọkpaabyi ọhakha okwu ore obhon nwa, ọmaana ẹnyọhng gorang-gor cha va p'anọngẹya am-asi.  
\v 6 Ọvaar Ibinọkpaabyi, oben bi, “Ojemi da bẹ atzima ade anọng p'ẹkhọma dani, p'agbaakhi ebhon dani, bẹ attẹwọr afha asi ọttọhk-dema mva, kw'oyini bi, ọttọhk fa bẹ ákham bi bẹ asi, fa bẹ án-afha asi kóde.  
\v 7 Bọng kwu mọhakha, mọtza ọdama ebhon chabẹ, ifha bẹ aningi ayok dọk abhaang.” 
\p  
\v 8 Mẹ wọ osi, Ọvaar Ibinọkpaabyi osi anọng mba araami k'ibe kpenamkpen m'ọyagbin, obiro ọkwọbha bẹ odedenmon nwuma osisi.  
\v 9 Kwẹ kwọ osi bẹ ayeri ibe nnuma Babẹl\f + \fr 11.9 \ft \+bd Babẹl\+bd* obiro okpena, Babilọn; k'eHiburu \+bd Babẹl\+bd* okheri ọwọhng kw'oyini, adama.\f*, okhuri bi, m'ibe nna rọ s'iwa Ọvaar Ibinọkpaabyi ọdam ebhon ch'ọyagbin biphyir. Ttẹwọr mẹ wọ kw'Ọvaar Ibinọkpaabyi opfuri bẹ, bẹ araami makhọra ọyagbin. 
\s1 Ẹnọmma cha Shẹm 
\p  
\v 10 Ma wọ ode ẹnọmma cha Shẹm. 
\p Wa cho afa akk'akwọbha kw'asi achi ọyagbin, k'ogbe kwa Shẹm on-ode cho arọbh azen, mẹ kw'obhoni Arphaksad.  
\v 11 Mada okk'Arphaksad obhona, wa Shẹm obiro oruk cho ẹnọhna obhiri arọbh azen, obiro obhon ajinọng ọmaana panọng adọdọk. 
\p  
\v 12 Mada Arphaksad okk'cho ẹrọbh obhiri chi orukha, obhon Shẹla.  
\v 13 Mada okk'Shẹla obhona, wa Arphaksad obiro oruk cho ẹnọhna obhiri attaan, obiro obhon ajinọng ọmaana panọng adọdọk. 
\p  
\v 14 Mada Shẹla okk'cho ẹrọbh obhiri jobh orukha, wa obhon Ẹbẹr.  
\v 15 Mada okk'Ẹbẹr obhona, wa Shẹla obiro oruk cho ẹnọhna obhiri attaan, obiro obhon ajinọng ọmaana panọng adọdọk. 
\p  
\v 16 Mada Ẹbẹr okk'cho ẹrọbh obhiri ọhawani-kwa-chi orukha, obhon Pẹlẹg.  
\v 17 Mada okk'Pẹlẹg obhona, wa Ẹbẹr obiro oruk cho ẹnọhna obhiri ẹrọbh obhiri jobh, obiro obhon ajinọng ọmaana panọng adọdọk. 
\p  
\v 18 Mada Pẹlẹg okk'cho ẹrọbh obhiri jobh orukha, obhon Rewu.  
\v 19 Mada okk'Rewu obhona, wa Pẹlẹg obiro oruk cho arọbh jobh obhiri ọhawani, obiro obhon ajinọng ọmaana panọng adọdọk. 
\p  
\v 20 Mada Rewu okk'cho ẹrọbh obhiri jobh obhiri afa orukha, obhon Serug.  
\v 21 Mada okk'Serug obhona, wa Rewu obiro oruk cho arọbh jobh obhiri azenamfa, obiro obhon ajinọng ọmaana panọng adọdọk. 
\p  
\v 22 Mada Serug okk'cho ẹrọbh obhiri jobh orukha, obhon Nahọr.  
\v 23 Mada okk'Nahọr obhona, wa Serug obiro oruk cho arọbh jobh, obiro obhon ajinọng ọmaana panọng adọdọk. 
\p  
\v 24 Mada Nahọr okk'cho ẹrọbh obhiri ọhawani orukha, obhon Tẹra.  
\v 25 Mada okk'Tẹra obhona, wa Nahọr obiro oruk cho arọbh azen obhiri ọhawani-kw'ẹrọbh, obiro obhon ajinọng ọmaana panọng adọdọk. 
\p  
\v 26 Mada Tẹra okk'cho arọbh attaan obhiri jobh orukha, obhon Abram, ọmaana Nahọr ttara Haran. 
\s1 Ẹnọmma cha Tẹra 
\p  
\v 27 Ma wọ ode ẹnọmma cha Tẹra. Tẹra obhoni Abram, ọmaana Nahọr ttara Haran. Haran obiro obhon Lọt.  
\v 28 Wa Haran ocheden ope, oji otte. M'ogbe nwuma, wa bẹ awobh ka Ur k'okhubha kw'abaKaldi kw'ode obhon kw'iwa Haran ọmaan.  
\v 29 Wa Abram ọmaana Nahọr an-abira atzọkha panọng. Kwanọng kw'Abram wa okpen Sarai. Yina, wa Nahọr ọtzọkha kwanọng kw'okpen Milka. Milka ọkhaam ọgbaanọkka kw'okpen Iska, Haran wọ iwa obhoni bẹ anọng afa.  
\v 30 Yina, Sarai wa ode ojididima, wa kẹ nnwa kọmaani. 
\p  
\v 31 Wa Tẹra ọtzọkha Abram kw'ode nnwa kwẹ, ọmaana Lọt kw'ode nnwa kwa Haran, ttara Sarai, kw'ode kwanọng kwa nnwa kwẹ Abram, bẹ biphyir abina orenga achina kw'okhubha kw'Ur kw'abaKaldi, ifha bẹ achina k'ẹkhọma cha Kenaan. Yina, mada bẹ areng maa aphyiri ka Haran, bẹ an-aruk mẹ. 
\p  
\v 32 Wa Tẹra okwu ope ma Haran da ode cho arọbh jobh obhiri azen. 
\c 12  
\s1 Ibinọkpaabyi oyeri Abram 
\p  
\v 1 Wa k'ogbe wani, Ọvaar Ibinọkpaabyi obeni Abram bi, “Bina ji ẹkhọma chọ, ọmaana anọng pọ, ttara ẹhọhmmọr ch'atte, achina k'ẹkhọma ch'akhaam ńdim-ọ nda. 
\q1  
\v 2 Kaam ńsọ-ọ ade otte kw'ẹkhọma ch'ideden. 
\q2 Kaam ńdọ-ọ, mbiri ńsọ-ọ atza che. 
\q1 Kaam ńnenga ka kọ ndo anọng haabhada. 
\q1  
\v 3 Ọnọng kpenamkpen kw'ọdọ-ọ, kaam mbiri ńdẹ-ẹ. 
\q1 Ọnọng kpenamkpen kw'ọrọ-ọ ọkhara, kaam ndim-ẹ m'ebubuni. 
\q2 Ayagbin \it bi waam\it* arenga ma kọ, atzọkha ẹdaa.” 
\p  
\v 4 Mẹ wọ ofon, Abram obina ọttẹwọr orenga mach'Ọvaar Ibinọkpaabyi ọkk'ẹ obena, Lọt obiro ọtzọhn-ẹ abẹ. Wa Abram ode cho arọbh attaan obhiri chi, mada obin k'obhon kwa Haran.  
\v 5 Abram otzima kwanọng kwẹ Sarai, ọmaana Lọt kw'ode nnwa kw'ọgbaanọkka, ọmaana ẹkhakhaama chabẹ biphyir, ttara anọng pa bẹ akk'akhaama ka Haran, bẹ abina orenga achina k'ẹkhọma cha Kenaan maa, bẹ apyiri kẹ. 
\p  
\v 6 Wa abAbram arenga ma Kenaan maa, bẹ apyiri kẹ da echi ch'ideden cha Morẹ ebe, ka Shẹkẹm. M'ogbe nwuma wa anọng pa Kenaan atzima am-aruk m'ẹkhọma nduma.  
\v 7 Ọvaar Ibinọkpaabyi oyin oben Abram bi, “Ńtte ẹkhọma nda ọbọhk ńnang efonamma chọ.” Mẹ wọ, Abram osi ijafọhnibe mẹ, ọnang Ọvaar Ibinọkpaabyi, kw'ọkk'ẹ abẹ oyina. 
\p  
\v 8 Mada Abram obin ka Shẹkẹm ochina ororo orenga maa opyiri ka mgbegbeho sa nwobh ka Bẹtẹl, osi ikhira sẹ mẹ, k'ottem kw'Ayi kẹ da ewuchen em-eyin ọmaana Bẹtẹl kẹ da ewuchen em-edimi. Mẹ kw'Abram osi ijafọhnibe ọnang Ọvaar Ibinọkpaabyi, om-obiro owobha mẹ okpobha Ọvaar Ibinọkpaabyi.  
\v 9 Mẹ wọ, Abram obina orenga, ochina ororo okkeri itzitzikha k'okhubha kwa Nẹgẹv. 
\s1 Abram ọmaana Sarai adim k'Ijip 
\p  
\v 10 M'ogbe nwuma, wa okwo f'ideden owobh m'ẹkhọma nduma. Mẹ wọ, Abram obina, ochina k'Ijip ọtza oruk kẹ k'igbegbaa \it bi kọbh\it*, okhuri okwo f'ideden.  
\v 11 Mada bẹ an-akkekkeni apyiri k'Ijip, Abram oben kwanọng kwẹ bi, “Sarai, kaam nkk'nnonga bi, kọ ajibhi kwanọng.  
\v 12 Idikha anọng p'Ijip arong bi, kọ ade kwanọng kwaam, mada bẹ áre ajibhada pọ, bẹ áfhu-m ofhu. Yina, bẹ átte kọ ọbọhk otte aruk.  
\v 13 Kọ gbaak bi, ade ọgbaanọkka kwaam, ifha bẹ atzim-m k'eden-ọkka o, ifha ńwobha akpen okhuri kọ.” 
\p  
\v 14 Mada Abram opyiri k'Ijip, anọng p'Ijip are bi, Sarai ode kwanọng kw'ojibh kpọng-kpọng.  
\v 15 Mada akhaan-nọng pa Phero, abira are kwanọng nwa, bẹ atzọhnga ajibhada pẹ anang ọvaarnọng. Bẹ atzim-ẹ achina k'ẹvaar-ttọhmma.  
\v 16 Wa Phero oreng ka nnam sa Sarai, ojibh idik otzima otzor Abram. Mẹ wọ osi, ọnang Abram nnanga sa nhaabh-ọkhaabh mach'arukhimaan, ọmaana abhaam, ọmaana anyanyaang-dim, ọmaana anyanyaang-papẹ, ttara abira p'ijinọng, ọmaana p'ipanọng, ọmaana akamẹl. 
\p  
\v 17 Mẹ wọ osi, Ọvaar Ibinọkpaabyi osi ikhọhmana s'ideden idim k'ẹhọhmmọr cha Phero, ibọkha kẹ ọmaana anọng p'ẹhọhmmọr chẹ biphyir, okhuri Sarai kw'ode kwanọng kw'Abram.  
\v 18 Mando kwa Phero ọtzọhmi bẹ ayeri Abram, ọbọbh-ẹ bi, “Bọng odik kw'asi ma? Osi yan kw'asi-m k'ọgbaan? Osi yan kaam kagbaakhi bi, Sarai ode kwanọng kwọ?  
\v 19 Areng mbọng-apfẹ agbaakh-m bi, kọ ọmaana kẹ bọng ade agbaanakka, abira akhera bi, kaam ndọkh-ẹ k'ọbada? Kkeri kwanọng kwọ mẹ e. Kọ tzọkh-ẹ, atzima arọhng e!” 
\p  
\v 20 Phero ọnang anọng pẹ ndọhna bi, bẹ atza atzọkha Abram atza arik k'enem ch'irek s'Ijip. Mẹ wọ, Abram obina oji Ijip, otzima kwanọng kwẹ ttara ekpo pyẹ biphyir ofona. 
\c 13  
\s1 Abram ọmaana Lọt akhọm ayok ẹkhaan 
\p  
\v 1 Mẹ wọ ofon, Abram obina orenga k'obhon ebira kw'Ijip, otzima kwanọng kwẹ ọmaana ekpo pyẹ biphyir, ochina k'ẹkhọma cha Nẹgẹv, wa Lọt ọtzọn-ẹ abẹ. 
\p  
\v 2 Wa Abram ọkk'ọkkọkkaa ọn-ọda, kw'ọkhaam etzirakpo, ọmaana silva ttara gol k'ọhaabh. 
\p  
\v 3 Ttẹwọr ma Nẹgẹv, Abram ochina ororo k'orenga kwẹ, om-obhing k'obe-k'obe matzẹmaa okwu opyiri ka Bẹtẹl, obiro owobha m'ibe nna s'iwobh k'ottem kwa Bẹtẹl ọmaana Ayi, kw'ode ibe s'iwa ikhira sẹ ichi eden iwobha,  
\v 4 kw'ode ibe s'iwa ọkk'eden ọcha osi ijafọhnibe. Ma wọ kw'iwa Abram owobh okpobha che ch'Ọvaar Ibinọkpaabyi. 
\p  
\v 5 Iwa Lọt kw'ọm-ọtzọn Abram abẹ, obiro ọkhaama arukhimaan, ọmaana abhaam, ttara okhira f'atzọhmnọng arukhi.  
\v 6 Yina, wa araraari p'abira abenga etzirakpo pyabẹ m'ibe nna dọk kade, da iwa ẹkhakhaama chabẹ ẹn-ẹhaabhi ẹyọhnga irek sa bẹ arukhi, maa bẹ ibe rani dọk kafha aruk.  
\v 7 Wa ẹkhọhr etto k'ottem kw'akkeri-etzirakpo py'Abram ttara akkeri-etzirakpo pya Lọt. M'ogbe nwa, aKenaan ọmaana aPẹriz bẹ atzọn aruk m'ẹkhọma nda dani. 
\p  
\v 8 Mẹ wọ osi, Abram on-oben Lọt bi, “Kọ ttara kaam mode votte. Tte ẹkhọhr eningi k'ottem kwaman anọng afa eyini, tte akkeri-etzirakpo pọ ttara paam aningi ẹkhọhr abira akhaama.  
\v 9 Irerek nna biphyir s'iwobh ma, iwobh ka maan ka mbọhk. Tte mọkhọm ayok ẹkhaan. Kọ tzekha okhubha kw'ọdaakh-ọ, ifha aruk. Idikha kọ atzọk okhubha kw'odimbọhk, kaam ńdọkha okhubha kwa kwabọhk. Idikha atzọk okhubha kwa kwabọhk, kaam ńdọkha okhubha kw'odimbọhk.” 
\p  
\v 10 Mẹ wọ ofon, Lọt otzini chen okkeri irek s'ẹttẹri cha Jọrdan, ore bi, sẹ ijibh-ojibh, okhuri da sẹ ihaabhi asi mach'owoni kw'Ọvaar Ibinọkpaabyi, ibiri ijibh mach'irek s'Ijip k'okhubha kwa Zoar. (M'ogbe nwa, wa Ọvaar Ibinọkpaabyi ibhon sa Sodom ọmaana Gomora otzima odimi.)  
\v 11 Mẹ wọ osi, Lọt otzekha ẹttẹri cha Jọrdan k'okhubha kw'ewuchen em-eyin ọnang for sẹ. Mando wọ kwa Lọt ọmaana Abram areng akhọm ayok ẹkhaan.  
\v 12 Wa Abram, orukhi k'ẹkhọma cha Kenaan, k'ogbe kwa Lọt orukhi k'ibhon s'ideden k'ẹttẹri, ottima ikhira sẹ ọbaanga Sodom.  
\v 13 Wa anọng pa Sodom ade anọng p'asi ọmmaana-tzama, bẹ am-abira asi ẹkhọngkwuri ayong-oyongi k'itzitzikha s'Ọvaar Ibinọkpaabyi. 
\p  
\v 14 Mada Abram ọmaana Lọt akk'ayok ẹkhaan akhọma, Ọvaar Ibinọkpaabyi okwu oben Abram bi, “Tzini chen ttẹwọr mẹ da abe, akkeri k'ebir-ebira, ttara k'ẹrakha-ẹrakha, abira akkeri kẹ da ewuchen em-eyin, ọmaana kẹ da ewuchen em-edimi.  
\v 15 Ẹkhọma nduma ch'are mẹ biphyir, kaam ńdọkha chẹ nnang kọ, ọmaana va pọ, ttara va pa va pọ, maa ogbe ode.  
\v 16 Kaam ńsi va pa va pọ ahaabh, akher oyeyeng kw'irerek kw'ọnọng on-ofha obhik.  
\v 17 Bina, arenga akhọri ẹkhọma nda k'adum ọmaana ẹ̀kpá chẹ biphyir, okhuri bi, chẹ dọ cha kaam ńnang-ọ.” 
\p  
\v 18 Mẹ wọ osi, Abram, orenga ọkhọri ẹkhọma nda maa opyiri ka Hẹbrọn. Okwu osi oruk kwẹ ọbaanga nchi sa ndeden sa Mamrẹ. M'ibe nna rọ s'iwa obiro osi ijafọhnibe ọnang Ọvaar Ibinọkpaabyi. 
\c 14  
\s1 Abram ọkkaan Lọt 
\p  
\v 1 M'ogbe nwa, wa Amaraphẹl wọ ode ọvaarnọng kwa Shina\f + \fr 14.1 \ft Obhon kwa Shina iwa on-okwu okpena Babiloniya. Madeden nwa owobh k'ẹrakh-ẹrakha kw'Iraq kwa Bagdad.\f*, Ariyok ode ọvaarnọng kw'Ẹlasa, Kedor-laomer ode ọvaarnọng kw'Ẹlam, Tidal ode ọvaarnọng kwa Goyim.  
\v 2 Wa avaarnọng mba anna biphyir an-akwu abhuna ẹfa, atza arima egbong ttara avaarnọng azen adọdọk. Avaarnọng mba azen p'iwa ayok atza arima abẹ akpen: 
\li1 Bera, ọvaarnọng kwa Sodom, 
\li1 Birasha, ọvaarnọng kwa Gomora, 
\li1 Shinab, ọvaarnọng kw'Adama, 
\li1 Shemebẹr, ọvaarnọng kwa Zeboyim, 
\li1 ttara ọvaarnọng kwa Bẹla, kw'obiro okpena Zoar. 
\p  
\v 3 Wa avaarnọng mba azen biphyir akwu abhuna ẹfa, bẹ atza arima egbong ọmaana Kedor-laomer k'Ẹttẹri cha Sidim, ch'ede ẹttẹri ch'Ọraanga kw'Onung.  
\v 4 Wa avaarnọng mba asi ọtzọhm anang Kedor-laomer ka cho jobh obhiri afa. Yina, ka cho kw'ottong jobh obhiri attaan, bẹ an-abhum ẹvaar chẹ. 
\p  
\v 5 Okwu opyiri cho ọhawani kwa chi, Kedor-laomer ọmaana avaar mbongo p'abhun for ọmaana kẹ, bẹ akwu arima egbong ọmaana avaarnọng mbongo p'ani dọk akher bi, awobha k'irekh-irek kwẹ. Bẹ akhema ẹkhọma cha Rephayim, ch'ewobh k'okhubha kw'Ashtẹrọt-Karnayim, bẹ abira akhema ẹkhọma cha Zuz ch'ewobh ka Ham, ttara ẹkhọma ch'Ẹm k'okhubha kwa Shavẹ-Kiriyatayim.  
\v 6 Bẹ abira atza akhema anọng p'ẹkhọma cha Họr p'arukhi ka mgbegbeho sa Seir, bẹ akhubh bẹ maa bẹ apyiri ka Ẹl-Paran kw'ọbaang k'ebherede.  
\v 7 Mada bẹ apyiri mẹ, bẹ akpa nnam k'Ẹn-Mishphat kw'obiro ode Kadẹsh, bẹ abira atza akhema anọng p'ẹkhọma ch'Amalẹk, ttara anọng p'ẹkhọma ch'Amọr ch'erukhi k'okhubha kwa Hazazọn-Tama. 
\p  
\v 8 Mẹ wọ osi, avaarnọng mba azen p'adabhi Sodom, ọmaana Gomora, ọmaana Adama ọmaana Zeboyim ttara Bẹla kw'obiro ode Zoar, abina ayin k'iyaan atza abe egbong k'Ẹttẹri cha Sidim,  
\v 9 arima avaarnọng mbongo anna abẹ, p'ade ọvaar Kedor-laomer kw'ọdabhi Ẹlam, ọmaana ọvaar Tidal kw'ọdabhi Goyim, ọmaana ọvaar Amaraphẹl kw'ọdabhi Shina, ttara ọvaar Ariyok kw'ọdabhi Ẹlasa. Kw'oyini bi avaarnọng anna an-abe k'okhubha wani, avaarnọng mbongo azen abe k'okhubha nwonggo bi, bẹ arima ayok abẹ. 
\p  
\v 10 Wa Ẹttẹri nda cha Sidim, ẹkhaam ape p'afu ttara ana p'abang-ọbanga abira apyi \it bi kaang.\it* Mẹ wọ ofon, mada iwa avaarnọng pa Sodom ọmaana Gomora an-arọbhi, ayok bani atto m'ape mba ẹtzaanga. Ayok mbongo arọbh achina ka mgbegbeho.  
\v 11 Wa avaarnọng mba anna, abọkha ayok ẹkhakhaama chabẹ kpenamkpen, ọmaana ọchattọhk fabẹ biphyir ka Sodom ọmaana ka Gomora ana, bẹ atzima afona.  
\v 12 Wa bẹ abira abọkha Lọt, kw'ode nnwa kw'ọgbaanọkka kw'Abram, ọmaana ẹkhakhaama chẹ. Wa obiro ode ọnọng wani kw'iwa bẹ abọk k'ẹmmọri, okhuri bi, kẹ wa orukhi ka Sodom k'ogbe kw'iwa egbong nda etto. 
\p  
\v 13 Yina, ojinọng wani kw'iwa ọrọbhi egbong ọnaanga, okwu ọgbaak Abram, kw'ode oHiburu-nọng bi, bẹ akk'Lọt abọkha k'ẹmmọri. M'ogbe nwa, wa Abram orukhi ọbaanga nchi sa Mamrẹ kw'ofon Amọr, ttara vọkka pẹ anọng afa, p'akpen Ẹshkol ọmaana Anẹr, p'iwa ade ayokh-ẹkhaan pẹ.  
\v 14 Mada Abram ọbhaang bi, bẹ akk'Lọt kw'ode nnwa kw'ọgbaanọkka abọkha k'ẹmmọri atzima afona, oyeri agbongnọng pẹ p'akk'arima-bọhk akpebhi, p'ade anọng p'amaan m'ọhọhm kwẹ, abira aruk ttar-ẹ. Wa agbongnọng mba ade anọng arọbh chi obhiri chi obhiri attaan. Wa otzima agbongnọng mba pẹ eden, okhubh anọng p'abọk Lọt, maa bẹ apyiri ka Dan.  
\v 15 Okwu opyiri m'erungi, Abram ọbhaangi ajinọng pẹ ka ngaan ka ngaan, bẹ akhọri attattaanga-nọng pabẹ akhe k'ottem. Mada bẹ akk'bẹ akhọri, bẹ arima bẹ abẹ, bẹ akhubh bẹ maa apyiri k'ẹkhọma cha Hoba, k'okhubha kwa Damaskọs.  
\v 16 Mẹ wọ, Abram ọbọkha anọng mba ekpo pya bẹ atzọk ka Sọdọm ọmaana Gọmọra ọna, obiro otzima Lọt, ọmaana ẹkhakhaama chẹ biphyir, ọmaana panọng pa bẹ abọk k'ẹmmọri, ttara anọng adọdọk pa bẹ abira abọkha k'ẹmmọri, okhuna. 
\s1 Mẹlkizẹdẹk osi Abram ittabọhng 
\p  
\v 17 Mada Abram on-okhun-okhuna da okk'ọvaar Kedor-laomer ọmaana avaarnọng mbongo p'awobh ttar-ẹ okhema k'egbong, ọvaarnọng kwa Sodom ofon otza okhebh-ẹ, k'Ẹttẹri cha Shavẹ, ch'ebire ekpena “Ẹttẹri ch'Ọvaarnọng.” 
\p  
\v 18 Mẹ wọ osi, Mẹlkizẹdẹk, kw'ode ọvaarnọng kwa Salẹm, obiro ode ọfọhnẹja kw'Ibinọkpaabyi kw'Ọyọhng, wa otzim brẹd ọmaana atzuk ochena Abram.  
\v 19 Kẹ Mẹlkizẹdẹk, osi Abram ittabọhng, obiro oben bi, 
\q1 “Tte Ibinọkpaabyi kw'Ọyọhng, 
\q2 kw'ọdabhi idik biphyir, 
\q2 kw'osi ẹrọng ọmaana irerek, 
\q1 odo kọ Abram. 
\q1  
\v 20 Tte ẹtzọhnga ewobha ẹnang Ibinọkpaabyi kw'Ọyọhng 
\q2 kw'ọdabhi idik biphyir, 
\q1 kw'ọkk'ọ ẹfa ọnanga 
\q2 ch'atzim akhema attattaanga-nọng pọ.” 
\m Mẹ wọ osi, Abram ọtzọkha ekpo kpenamkpen py'otzim k'egbong okhuna, okkema k'akhung jobh, ọtzọkha okhung wani k'akhung jobh, ọnang Mẹlkizẹdẹk. 
\p  
\v 21 Mẹ wọ osi, ọvaarnọng kwa Sodom on-oben Abram bi, “Kọ tzọkha ekpo kpenamkpen biphyir py'atzim k'egbong akhuna, yina, tte anọngẹya biphyir p'atzim k'egbong akhuna ọbọhk anang-m.” 
\p  
\v 22 Abram obhina ọvaarnọng kwa Sodom bi, “Kaam nkk'mbọhk saam ndini k'ẹrọng ndena Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'Ọyọhng, kw'osi ẹrọng ọmaana irerek. Kaam nkk'mbiri nchekhi bi,  
\v 23 kaam ọttọhk manda vani f'ode fọ, fa kaam ńdọkh-otzọkha kode, ttẹwọr k'ẹnaanga-dik maa, apyiri ka ndik s'ekpo-pya-mmo, ifha kọ aninga abeni bi, ojibhada kw'Abram ofon ka mbọhk sọ e.  
\v 24 Kaam ọttọhk kpenamkpen fọ, fa kaam ńdọkh-ọtzọkha kode, oyongi ọchattọhk f'ajinọng paam akk'acha, ttara ekkema ch'ajinọng p'atzor-m arima egbong. Tte Anẹr, ọmaana Ẹshkol ttara Mamrẹ, atzọkha ekkema chabẹ.” 
\c 15  
\s1 Ibinọkpaabyi osi echekhi ọnang Abram 
\p  
\v 1 Ayongi mẹ, Ọvaar Ibinọkpaabyi oyin Abram abẹ k'idachen, ọgbaakh-ẹ atzim, oben-ẹ bi, 
\q1 “Abram, oning-ọ ojor, 
\q2 kaam wọ nde ọkhọhnkpa kw'ókker-ọ, 
\q2 ńnang-ọ echora ch'ideden.” 
\p  
\v 2 Mada Abram ọbhaang idik nna, obhina bi, “O Ọvaar Ibinọkpaabyi kw'Ẹfa biphyir, mbọng fa kọ asi anang-m, da kaam nni nnwa mmoni, ọnọng kw'óchi-m obo ode Eliyeza kw'ofon Damaskọs.”  
\v 3 Abram oben bi, “Kọ kaam va atzima ananga; mẹ wọ, obira k'ẹhọhmmọr chaam wọ óchi-m obo.” 
\p  
\v 4 Mẹ wọ ofon, Ọvaar Ibinọkpaabyi ọgbaak Abram atzim, oben-ẹ bi, “Mma e, kwẹ mando kode. Obira nwa araang ọ́chọ-ọ obo, nnwa kw'ofon k'adima pọ, wọ ọ́chọ-ọ obo e.”  
\v 5 Mẹ wọ ofon, Ibinọkpaabyi otzim-ẹ oyin k'iyaan, ọkhọhkh-ẹ ndodori sa nwobh k'ọrọngkpakpa, oben-ẹ bi, “Akk'ara odem kwa ndodori nhaabhi, idikha afha abhik sẹ, mando kwa va pa va pọ ikhina bẹ áhaabh.” 
\p  
\v 6 Abram okhera idik nna s'Ọvaar Ibinọkpaabyi ọgbaakh-ẹ, k'odik-ọkka. Mẹ wọ, Ọvaar Ibinọkpaabyi ọtzọkh-ẹ mach'ọnọng kw'otzor-otzor k'itzitzikha sẹ. 
\p  
\v 7 Ọvaar Ibinọkpaabyi obiro oben Abram bi, “Kaam nde Ọvaarnọng kwọ, kaam wọ iwa ndọkh-ọ k'obhon kw'Ur k'ẹkhọma ch'anọng pa Kaldi, ndim-ọ nkwu nnang irerek nna, ifha atzọkha sẹ mach'ekkema chọ.” 
\p  
\v 8 Abram obhin-ẹ bi, “O Ọvaar Ibinọkpaabyi kw'Ẹfa biphyir, yan kwa kaam ńdima ńnonga bi, kaam ndọkha irek nna mach'ekkema chaam o?” 
\p  
\v 9 Ọvaar Ibinọkpaabyi obhin-ẹ bi, “Kọ rọhng, atza aror ọbhaamnwa-kwakwẹ, ọmaana ovu-gbokha, ttara erukhimaan-dim, p'ade cho attaan-attaan, ọmaana igbegbaa ttara ikpomikha, atzima akwu.” 
\p  
\v 10 Abram ọtzọkha nden nnuma biphyir otzima okwu, ọbhaakha kpenamkpen k'obe ọfa, ohok igbokha kpenamkpen ikkeri oyok. Yina, ọnọhn fẹ-fẹ f'oni agbokha afa ọbhaak.  
\v 11 Mada opyiri k'ogbe kw'attẹrẹ ahak bi akwu achi abukhi p'ekpo mbya, Abram okhubh bẹ. 
\p  
\v 12 Mada opyiri k'ẹchọhkha k'ogbe kw'ewu ẹn-ẹhak, ọda osi Abram, ọttaabha maa ọmọm, ipyerungi \it bi kaang\it* ibubha Abram maa ojora f'ideden ọsẹ-ẹ.  
\v 13 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Abram bi, “Ronga k'odik-ọkka bi, va pa va pọ áde akhekhen-nọng k'obhon kw'oni kwabẹ ode. Bẹ áruk mẹ mach'abira, anọng ahok bẹ k'ebira, bẹ ábira anang bẹ ihem, ọttọhk ka cho ẹnọhna.  
\v 14 Yina, kaam ńnang ẹkhọma nda ch'ekhe bẹ k'ebira ettuma. Ogbe kw'ebira ọkk'ọkwọbha, bẹ atzima ojibhada kw'ideden anaanga ebira ch'obhon nwuma.  
\v 15 Onode kọ, ma for sọ, áruk akpen matzẹmaa atzam, yina aning ape bẹ anọhng-ọ atzor abatte k'odidiri.  
\v 16 Ottong igbọ inna sa va pa va pọ, bẹ ákhuna m'irerek nna, okhuri bi, ogbe otzim opyiri, kwa kaam ńgwubh anọng p'Amọr m'ibe nna, okhuri itzama sabẹ.” 
\p  
\v 17 Mada okwu opyiri ogbe kw'ewuchen ekk'edimi, erungi epyi \it bi kaang\it*. Abram ore irọhkha s'irorong s'ekpon ewobh k'ẹtzaanga, ttara ikhebh sa iwọm ekpon, ch'ereng k'ottem kwa nden nna sa bẹ ajọhkhi k'abiri-biri, ẹkwọbha efona.  
\v 18 Mẹ ewu nda, Ọvaar Ibinọkpaabyi osi echekhi oben Abram bi, “Va pa va pọ bọ, pa kaam ńdọkha irerek nna ttẹwọr k'ọraanga kw'Ijip, maa apyiri k'ọraanga kwa Yupharetes ńnang, bẹ akhaama.  
\v 19 Anọng p'arukhi m'irerek nna ade: abaKen, ọmaana abaKeniz, ọmaana abaKadamọn,  
\v 20 ọmaana abaHet, ọmaana abaPẹriz, ọmaana abaRephayim,  
\v 21 ọmaana abAmọr, ọmaana abaKenaan, ọmaana abaGirgash, ttara abaJẹbus.” 
\c 16  
\s1 Hagar ọmaana nnwa kwẹ Ishimayẹl 
\p  
\v 1 Wa Sarai kw'ọba Abram, nnwa kọmaani. Ayongi mẹ, kẹ wa ọkhaam obira kw'ikwanọng kw'ofon Ijip kw'okpen Hagar.  
\v 2 Mẹ wọ osi, on-oben Abram bi, “Mada Ọvaar Ibinọkpaabyi ọni kaam ọmaan ọnangi, kaam mben bi mphyem-ọ bi, atzọkha obira nwa kwaam ayima abẹ. Asi mẹ, kaam mfha nnenga ma ndaak sẹ ngaama nnwa.” 
\p Abram okhera bi osi macha Sarai obeni.  
\v 3 Mada Abram okk'orukha k'ẹkhọma cha Kenaan ka cho jobh, Sarai ọtzọkha Hagar kw'ode obira kwẹ kw'ofon k'Ijip ọnang Abram bi, oyim-ẹ abẹ.  
\v 4 Abram oyima Hagar abẹ, okwu otzima ibhọr. 
\p Mada Hagar orong bi, okk'ibhọr otzima, ọttẹwọr ore ọkka kw'orukhi abẹ ọkhara.  
\v 5 Mẹ wọ ofon, Sarai ọdọkh-ẹ maa, on-oben Abram bi, “Ọmmamma kwaam ofon ka kọ e. Kaam wọ ndọk obira kwaam nnang-ọ bi, ayim-ẹ abẹ, yina, mada orong bi okk'ibhọr otzima, ọttẹwọr ore-m ọkhara. Tte Ọvaar Ibinọkpaabyi ọttọhna aponga pa kaam ọmaana kọ.” 
\p  
\v 6 Mẹ wọ ofon, Abram oben Sarai bi, “Kker e, ominanwa nwa ode obira kwọ, kọ sẹ-ẹ mach'ọdaakh-ọ.” Mẹ wọ osi, ttẹwọr mẹ, Sarai, Hagar k'eden ọkkakka dọk kotzim, ofona mẹ, Hagar ọrọbh. 
\p  
\v 7 Mada Hagar ọkk'ọrọbha, orenga-eden kw'Ọvaar Ibinọkpaabyi ọrẹ-ẹ k'esipe ch'ewobh k'ebherede, esipe ch'ewobh k'ọkkadeden kw'achin ka Shur.  
\v 8 Mẹ wọ osi, orenga-eden nwa oben Hagar bi, “Hagar, obira kwa Sarai, kọ afon maan o? Am-atza maan?” 
\p Hagar obhin-ẹ bi, “Kaam mminnọbh-ọrọbh k'inna kwaam ka mbọhk ma e.” 
\p  
\v 9 Orenga-eden kw'Ọvaar Ibinọkpaabyi, oben-ẹ bi, “Kọ kpa nnam atzor akka, abira ahakha eho anang-ẹ.”  
\v 10 Orenga-eden nwa kw'Ọvaar Ibinọkpaabyi obiro oben-ẹ bi, “Kaam ńsi va pa va pọ ahaabh-ọhaabh. Bẹ ahaabh k'odem kw'ọnọng ọni bẹ ofha obhik.”  
\v 11 Orenga-eden kw'Ọvaar Ibinọkpaabyi obiro oben-ẹ bi, 
\q1 “Kọ akk'ibhọr atzima, ámaan ojinọng, 
\q2 Kọ ákpẹ-ẹ Ishimayẹl,\f + \fr 16.11 \ft K'eHiburu, che ch'Ishimayẹl eyini, Ibinọkpaabyi ọbhaang idik. \f* 
\q2 okhuri bi Ọvaar Ibinọkpaabyi okk'ẹmọng ch'ihem sọ ọbhaanga. 
\q1  
\v 12 Kẹ ọ́raari mach'ẹnyanyaang ch'ẹtzam cha bẹ ani otzitzir atziri. 
\q1 Kẹ óde ọnọng kw'ọ́wọhngi akpen p'anọng biphyir, 
\q2 anọng biphyir ábira awọhngi akpen pẹ, 
\q1 kẹ óruk k'ittattaanga ttara votte pẹ biphyir.” 
\p  
\v 13 Mẹ wọ osi, Hagar on-oben for sẹ bi, “Ode bi, Ọvaar Ibinọkpaabyi wọ kwa kaam nne ma, yina ndimi nnukhi akpen ma o?” Mẹ wọ ofon, oyer-ẹ che ch'ikpokpobha bi, Ẹl-Roi\f + \fr 16.13 \ft K'eHiburu Ẹl-Roi oyini Kọ ade Ibinọkpaabyi kw'okker-m.\f*. On-oben bi, “Kaam nkk'Ibinọkpaabyi kw'Okker-m nna.” 
\p  
\v 14 Mẹ wọ ofon, anọng am-ayeri esipe nda, Beer-Lahai-Roi\f + \fr 16.14 \ft K'eHiburu, Beer-Lahai-Roi oyini, Esipe cha kẹ kw'orukhi akpen kw'ore-m.\f*, kw'oyini “Esipe cha kẹ kw'orukhi akpen, kw'ore-m.” Esipe nda ewobh k'ottem kwa Kadẹsh ọmaana Bẹrẹd. 
\p  
\v 15 Iwa Hagar ọmaan nnwa kw'ijinọng ọnang Abram. Abram ọkpẹ-ẹ Ishimayẹl.  
\v 16 K'ogbe kw'Abram ode cho arọbh anna obhiri azadani, Hagar ọmaan-ẹ Ishimayẹl. 
\c 17  
\s1 Echekhi ch'ẹkhaam ẹkhọkha ch'ọkpakkọrikkọ 
\p  
\v 1 K'ogbe kw'iwa Abram on-ode cho arọbh anna obhiri ọhawani kw'ẹrọbh, Ọvaar Ibinọkpaabyi oyin Abram abẹ, oben-ẹ bi, “Kaam wọ nde Ibinọkpaabyi kw'Ẹfa biphyir, kọ hok aphaangi paam, abira aruk akpen p'atzor-otzor.  
\v 2 Kaam ńsi mach'iwa nkk'nchekhi nnang-ọ bi, va pa va pọ, ikhina bẹ áhaabh-ọhaabh.” 
\p  
\v 3 Mada Abram ọbhaang idik nna, ọrakha ottima itzitzikha k'irerek. Mẹ wọ, Ibinọkpaabyi oben-ẹ bi,  
\v 4 “Ma wọ ode odik kwa kaam nchekhi nnang-ọ: kọ áde otte kwa ngọma haabhada.  
\v 5 Kaam mbiri ńnang-ọ che ẹbhachẹ, Abram dọk kàkpena, kọ án-akpena Abraham, kw'oyini otte kw'idibhon k'ọhaabh.  
\v 6 Kaam ńsọ-ọ abhon va k'ọhaabh, ngọma sa nhaabh-ọhaabh ḿfona ma kọ, ọmaana avaar p'ideden.  
\v 7 Kaam ńsi echekhi nda cha kaam ttara kọ ebire ede echekhi cha va pa va pọ, k'igbọ s'ikwu k'ogbe ororo m'ipemanitzor. Kaam ńde Ibinọkpaabyi kwọ, ọmaana Ibinọkpaabyi kwa va pa va pọ.  
\v 8 Kaam ńdọkha irek sa Kenaan biphyir sa kọ arukhi mach'okhekhennọng madẹdẹn nnang kọ, ọmaana efona chọ, bọng akhaama sẹ m'ipemanitzor. Kaam wọ ńde Ibinọkpaabyi kwabẹ.” 
\p  
\v 9 Mẹ wọ, Ibinọkpaabyi oben Abraham bi, “Onode kọ, akhaambi ahok echekhi nda chaam, kọ ọmaana va pa va ttara igbọ s'ikwu k'ogbe ororo.  
\v 10 Ma wọ ode echekhi cha kaam ttara kọ, ọmaana va pa va pọ, echekhi cha bọng áhok ede bi, ojinọng kpenamkpen kw'owobh ttara bọng ósi ọkpakkọrikkọ.  
\v 11 Bọng ási ọkpakkọrikkọ kw'ẹkpakpa, kw'óde ẹkhọhkha ch'Echekhi cha kaam ttara bọng.  
\v 12 K'igbọ s'íkwu k'ororo, ijinọnọnga kpenamkpen kw'ode iwu izenanttaan, bẹ akhaambi asẹ-ẹ ọkpakkọrikkọ. Ajinọng biphyir, p'amaan ka bọng k'ọhọhm, ọmaana ayok pa bọng adebhi k'agbukha p'ani va pa bọng ade, bẹ akhaambi asi ọkpakkọrikkọ.  
\v 13 Kaambi p'amaan kabọng k'ihọhm bọ, obiro ode pa bọng adebhi k'agbukha o, bọng akhaambi, asi bẹ ọkpakkọrikkọ. Mando wọ kw'echekhi chaam ch'éde ebhora ka bọng ka for, éde echekhi ch'ipemanitzor.  
\v 14 Ojinọng kpenamkpen kw'oni ọkpakkọrikkọ kw'ẹkpakpa osi, bọng kọm-ẹ ẹkhaan, okhuri bi, kẹ okk'echekhi chaam obhuma ohohok.” 
\s1 Echekhi ch'ẹmmaana ch'Isaak 
\p  
\v 15 Ibinọkpaabyi obiro oben Abraham bi, “Onode kwanọng kwọ, Sarai, kẹ Sarai dọk kokpena, kẹ ón-okpena Sara.  
\v 16 Kaam ńdẹ-ẹ, mbiri ńsẹ-ẹ ọmaan-ọ nnwa kw'ijinọng. Kaam ńdo Sara bi, óde ọkka kwa ngọma sa nhaabh-ọhaabh. Avaar p'ideden ábira afona ka ndaak sẹ.” 
\p  
\v 17 Mẹ wọ, Abraham otto okhubha itzitzikha sẹ m'irerek, ọnang Ibinọkpaabyi ikpokpobha, ọmma aha k'ettem oben bi, “Na ọnọng kw'on-ode cho arọbh azen macha kaam, obiro obhon nnwa o? Na Sara, kw'on-obiro ode cho arọbh anna obhiri jobh, obiro ọfha ọmaan nnwa dọkh o?”  
\v 18 Mẹ wọ, Abraham oben Ibinọkpaabyi bi, “Ira ode bi na ọdaakh-ọ, ira Ishimayẹl oruk ttara ẹdaa chọ.” 
\p  
\v 19 Mẹ wọ, Ibinọkpaabyi oben bi, “Mma e! Sara kw'ode kwanọng kwọ, wọ ọ́maan nnwa kw'ijinọng ọnang-ọ. Kọ ákpẹ-ẹ Isaak. Kaam ńttima echekhi chaam ttara kẹ aranga. Éde echekhi ch'ewobha ẹnang va pa va pẹ, m'ipemanitzor.  
\v 20 Onode odik kw'okhuri Ishimayẹl, kaam nkk'ọ mmaanga e, k'odik-ọkka kaam ńdẹ-ẹ odo e, kaam ńsẹ-ẹ obhon va, mbiri nttaar-ẹ ọhaabh. Kẹ óbhon avaar-va jobh obhiri afa. Kaam ḿbiri nsẹ-ẹ ode ẹkhọma ch'ideden.  
\v 21 Yina, kaam ńgaama echekhi chaam ttara Isaak, kwa Sara ọ́maan ọnang-ọ ikhina cho nnamanda.”  
\v 22 Mada Ibinọkpaabyi okk'odik nwa ọgbaakha okyera, ofona oji Abraham mẹ. 
\p  
\v 23 M'ewu nduma dani, Abraham osi mach'Ibinọkpaabyi ọkk'ẹ ọgbaakha bi, osi. Ọtzọkha nnwa kwẹ Ishimayẹl, ọmaana ajinọng biphyir p'amaan m'ọhọhm kwẹ, ttara ayok p'odebhi k'agbukha, ojinọng kpenamkpen k'ọhọhm kwẹ, osi ọkpakkọrikkọ kw'ẹkpakpa.  
\v 24 Wa Abraham ode cho arọbh anna obhiri ọhawani kw'ẹrọbh, k'ogbe kwa bẹ asẹ-ẹ ọkpakkọrikkọ.  
\v 25 Nnwa kwẹ, Ishimayẹl, ode cho jobh obhiri attaan, mada bẹ asẹ-ẹ ọkpakkọrikkọ.  
\v 26 Wa bẹ asi Abraham ọmaana nnwa kwẹ Ishimayẹl ọkpakkọrikkọ, m'ewu nduma dani.  
\v 27 Wa Abraham ọmaana ojinọng kpenamkpen kw'owobh k'ọhọhm kwẹ, ọmaana ayok p'amaan m'ọhọhm kwẹ, ttara ayok p'odebhi k'agbukha ka mbọhk s'okhekhennọng, bẹ abira asi bẹ ọkpakkọrikkọ. 
\c 18  
\s1 Ibinọkpaabyi obiro ochekhi bi, Sara ọ́maan nnwa kw'ijinọng 
\p  
\v 1 Wa Ọvaar Ibinọkpaabyi oyini Abraham abẹ k'ogbe kw'owobh ẹwọr k'ẹhọhmma ch'ikhira sẹ, ọbaanga kẹ da nchi sa Mamrẹ mbe, k'ọyakpattem kw'ewu ẹkhọmi \it bi gbaang.\it* 
\v 2 Mada Abraham otzini chen ore da ajinọng attaan abe abaang-ẹ, obina k'ẹhọhmma ch'ikhira sẹ, otzini mmo m'ẹbhar-ẹbhar ọtza okhebha bẹ, ọrakha ottima itzitzikha k'irerek orima bẹ. 
\p  
\v 3 Oben bi, “Itta kwaam, idikha kaam nkk'ọphyaam ngaama k'itzitzikha sọ, kọ kaam ọtzọhmnọng kwọ, kakwọbha.  
\v 4 Tte bẹ atzima asisaa akwu, ifha bọng agbobhi mmo, bọng abira akwokha ọwọhng m'echi nda irekhirek.  
\v 5 Tte ndima ichattọhk-ttọhkha nkwu bọng achi, ifha bọng akhaama ẹfa cha bọng achina ororo k'orenga kwabọng, mada bọng akk'apyiri m'ibe sa kaam ọtzọhmnọng kwabọng.” 
\p Bẹ abhin-ẹ bi, “Ojibhi kẹ, si mach'ettem chọ ẹpaan-ọ.” 
\p  
\v 6 Mẹ wọ ofon, Abraham obina ẹbhar-ẹbhar ọtza okhebha Sara k'ikhira ẹtzaanga, oben bi, “Kọ yoma agbobhi-mbọhk attaan p'abubuma atzima asi brẹd ẹbhar-ẹbhar.” 
\p  
\v 7 Mẹ wọ osi, Abraham ọrọbh ochina k'ivukwuri, ọtza otzekha ọbhaam-nwa ọkkakka ọnang nnwa wani kw'orukh-ẹ abẹ, ofhu chẹ m'ẹbhar-ẹbhar otzima osi ọchattọhk.  
\v 8 Yina on-obiro ọtzọkha abasi p'abang-ọbanga, ọmaana abasi ttara etzen ẹbhabhachẹ ch'ọbhaam-nwa, obera bẹ. Mada bẹ am-achi ọchattọhk mva, kẹ Abraham obe m'echi nduma irekhirek, cha bẹ awobh achi ọchattọhk. 
\p  
\v 9 Anọng mba an-abọbh Abraham bi, “Kwanọng kwọ, Sara khi?” 
\p Obhina bẹ bi, “Owobh k'ikhira ẹtzaanga e.” 
\p  
\v 10 Mẹ wọ ofon, ọnọng wani k'ottem kw'anọng mba, oben bi, “K'odik ọkkọkka, ikhina cho nnamanda kaam mbiri mkpa nnam nkwu ndibh bọng m'ibe nna. Sara kw'ode kwanọng kwọ, ọmaan nnwa kw'ijinọng.” 
\p Wa Sara owobh k'ekhiramma ẹtzaanga, ọkpa nnam ọbọra, om-oyonga bẹ itzọhng.  
\v 11 Iwa Abraham ọmaana Sara akk'an-atzama kpọng maa, Sara ọkwọbha ọphaangi kwa for ottotto.  
\v 12 Mẹ wọ ofon, Sara ọmma aha, oben for sẹ bi, “Mada nkk'ndama, itta kwaam ọtzam, na kaam mbiri mfha ngaama idadaakha s'ojinọng, sa mobiro ọtzọn oyima o?” 
\p  
\v 13 Mẹ wọ osi, Ọvaar Ibinọkpaabyi ọbọbh Abraham bi, “Sara oreng mbọng apfẹ ọmma aha, oben for sẹ bi, ‘Na kaam, mbiri mfha mmaan nnwa, m'atzam mba dọkh o?’  
\v 14 Odik owobh kẹ, kw'Ọvaar Ibinọkpaabyi on-ofha oso o? Ikhina cho nnamanda kaam ḿbiri mkpa nnam nkwu ndibh bọng, Sara, ọ́maan nnwa kw'ijinọng.” 
\p  
\v 15 Mada Sara ọbhaang odik nwa, ojor-ẹ. Mẹ wọ, okhona, oben bi, “Kaam aha kimma.” 
\p Ọvaar Ibinọkpaabyi oben-ẹ bi, “K'odik ọkkakka, kọ akk'aha amma e.” 
\s1 Abraham okhukhi Ibinọkpaabyi ka nho s'anọng pa Sọdọm 
\p  
\v 16 Mada anọng mba attaan abin bi, bẹ afona, bẹ atzini chen akkeri k'obhon kwa Sodom. Wa Abraham ọtzọn bẹ abẹ, ọtza orik bẹ k'eden.  
\v 17 Mẹ wọ, Ọvaar Ibinọkpaabyi oben for sẹ bi, “Odik nwa kwa mbeni bi nsi ma, kọbaan bi, ndubha Abraham.  
\v 18 Ode odik ọkkakka bi, va pa va p'Abraham akwuma akwu ade afanọng ọmaana ẹkhọma ch'ideden, on-orenga ma kẹ, idibhon s'ọyagbin ikhaama ẹdaa.  
\v 19 Da kaam nkk'ẹ ndekha bi, ọtzọhn va pẹ ọmaana ẹhọhmmọr chẹ bi, bẹ ahok abhaangi p'Ọvaar Ibinọkpaabyi, obiro oruk akpen p'atzori k'eden ch'Ọvaar Ibinọkpaabyi, ifha osi ẹjaakhi k'echekhi ch'ọkk'ọsa ọnang Abraham.” 
\p  
\v 20 Mẹ wọ, Ọvaar Ibinọkpaabyi oben bi, “Obhoma kw'okhuri idik-ttama sa Sodom ọmaana sa Gomora ọbari kpọng: ẹkhọngkwuri chabẹ ebire epyibh eyong-oyongi,  
\v 21 kw'osi kaam ńhakha, ifha nda ńne, s'itzama sa bẹ akk'asa ipyibhi ipyiri obhoma kwa kaam mmaang. Kwẹ oni mando obiro ode, kaam ńnonga-oronga.” 
\p  
\v 22 Mẹ wọ, ajinọng mba abhakhi nnam akkeri itzitzikha k'okhubha kwa Sodom. Yina, Abraham ochina ororo obe Ọvaar Ibinọkpaabyi k'itzitzikha.  
\v 23 Abraham orenga otzor Ọvaar Ibinọkpaabyi ka for, ọbọbh-ẹ bi, “Ma, na kọ atzọkha anọng p'asi ẹmmaana ọkkakka, afhu attara k'anọng p'asi ẹmmaana-tzama o?  
\v 24 Idikha ira kọ are, anọng arọbh afa obhiri jobh, p'asi ẹmmaana ọkkakka m'obhon nwa, na ira kọ akhọkha anọng mba nkwu-osisi, atte obhon nwa ọbọhk o?  
\v 25 Tzọmi-tzọmi okponga k'idachen bi, kọ atzọkha anọng p'asi ẹmmaana ọkkakka attara k'ayok p'asi ẹmmaana-tzama afhu. Ka yan wọ kw'ira ọkpaar-aponga kw'ọyagbin biphyir, oni odik kw'otzor-otzor osi o?” 
\p  
\v 26 Mẹ wọ, Ọvaar Ibinọkpaabyi obhin-ẹ bi, “Idikha kaam nne anọng arọbh afa obhiri jobh, p'asi ẹmmaana ọkkakka m'obhon nwa, kaam ńnenga anọng mba abẹ, ńtte obhon nwa ọbọhk.” 
\p  
\v 27 Mẹ wọ, Abraham obhin-ẹ, oben bi, “Tzotzokhaan, Ọvaar Ibinọkpaabyi kwaam, kaambi, ode bi, nde idọdọhbh, mbiri nde itzọtzọhng macha nde ma, kaam mbar ettem mgbaak atzim nnang-ọ.  
\v 28 Idikha on-ode bi, anọng azen kade k'anọng arọbh afa obhiri jobh ma obhon nwa, p'asi ẹmmaana ọkkakka khi, ma na ira kọ adimi obhon nwa, okhuri anọng azen o?” 
\p Ọvaar Ibinọkpaabyi obhin-ẹ bi, “Mma e, idikha kaam nne anọng arọbh afa obhiri azen, p'atzor-otzor, kaam ngọkha bẹ nkwu-osisi ọkhọkha, ńtte obhon nwa ọbọhk.” 
\p  
\v 29 Abraham ochina ororo ọbọbh-ẹ bi, “Idikha ira on-ode bi, kọ are anọng arọbh afa, p'asi ẹmmaana ọkkakka, ma na ira kọ adimi obhon nwa o?” 
\p Ọvaar Ibinọkpaabyi obhin-ẹ bi, “Mma e, okhuri anọng mba arọbh afa, kaam ńgọhkha bẹ nkwu-osisi ọkhọkha, ńtte obhon nwa ọbọhk.” 
\p  
\v 30 Mẹ wọ, Abraham obhin-ẹ bi, “Tzotzokhaan Itta, oning-ọ obhemi, tte nchina ororo mphyem-ọ. Idikha ira on-ode bi, kọ an-are anọng ẹrọbh obhiri jobh ma obhon nwa khi?” 
\p Ọvaar Ibinọkpaabyi obhin-ẹ bi, “Mma e, idikha kaam nne anọng ẹrọbh obhiri jobh, kaam ira ntte obhon nwa ọbọhk otte.” 
\p  
\v 31 Mẹ wọ, Abraham oben bi, “Mada kaam nkk'ettem mbara bi, mphyem-ọ, tte mbiri mbọbh-ọ. Idikha ira on-ode bi, anọng ẹrọbh bẹ-bẹ bọ p'are ma khi?” 
\p Ọvaar Ibinọkpaabyi obhin-ẹ bi, “K'odik ọkkakka, ira nne ọnọngmik-dema nwa, ka nho s'anọng mba ẹrọbh, kaam ira ntte obhon nwa ọbọhk otte.” 
\p  
\v 32 Mẹ wọ, Abraham oben bi, “Tzotzokhaan Itta, tte oning-ọ obhemi, tte nna mphyem ogbe nwa wani. Idikha ira bẹ an-ade anọng jobh bẹ-bẹ khi?” 
\p Obiro obhin-ẹ bi, “K'odik ọkkakka, ira nne ọnọngmik-dema nwa, ka nho s'anọng mba jobh, kaam ira ntte obhon nwa ọbọhk otte.” 
\p  
\v 33 Mada Ọvaar Ibinọkpaabyi okk'atzim ọgbaakha biphyir ttara Abraham, ofona. Abraham obiro ọkpa nnam k'ikhira sẹ. 
\c 19  
\s1 Mpyibha s'anọng pa Sọdọm 
\p  
\v 1 Okwu opyiri k'ẹchọhkha, arenga-eden mbuma afa p'Ibinọkpaabyi p'ahak Abraham, apyiri ka Sodom. M'ogbe nwa, Lọt owobh ẹwọr k'ẹbaakhamma cha Sodom. Mada ore bẹ, obina orenga otzor bẹ ka for, obiro ọrakha ottima itzitzikha k'irerek orima bẹ.  
\v 2 Oben bẹ bi, “Abitta paam, tzotzokhaan bọng kwu hakha k'ọhọhm kw'ọtzọhmnọng kwabọng, ifha kaam nnang bọng asi, pa bọng agbobhi mmo sabọng, bọng ayima ma m'erungiwu nda, ewu ekk'ehobha, k'ekpekpebha, bọng achina ororo k'orenga kwabọng.” 
\p Abẹ abhin-ẹ bi, “Mma e, maman ọtza oyima k'ipha.” 
\p  
\v 3 Yina, Lọt ochina ororo ọgbana bẹ maa, yina bẹ an-akher bi, atzọn-ẹ abẹ adim k'ọhọhm kwẹ. Osi brẹd kw'oni yist ọkhaam, ọnang bẹ, bẹ achi.  
\v 4 Yina Lọt ọmaana akhekhennọng pẹ, aninga yima, ajinọng biphyir adikkobh ttara adedennọng, p'obhon kwa Sodom akk'ọhọhm kwẹ akhọri akhe k'ottem. 
\p  
\v 5 Mando kwa bẹ agwoni Lọt abọbh-ẹ bi, “Akhekhen-nọng mbuma p'ahakh-ọ m'erungiwu cha mayina khi? Tzima bẹ yin k'iyaan, moyima bẹ abẹ.” 
\p  
\v 6 Lọt oyin k'iyaan ọtza okhebha bẹ, obhen ọmma okpori akhekhen-nọng pẹ k'ẹtzaanga,  
\v 7 oben bẹ bi, “Mma e, abayi, bọng itzama-dema nna kasi.  
\v 8 Bọng kker e, kaam ngaam aminava afa, p'ani ajinọng atzima aronga. Tte ntte bẹ ọbọhk nnang bọng, ifha bọng atzima bẹ asi, odik kpenamkpen kw'ọdaakhi bọng. Onode ajinọng mba, bọng bẹ itzama-dema nna kasi: kkeri bẹ awobh k'irekh-irek kw'ẹfa chaam.” 
\p  
\v 9 Bẹ an-abhina bi, “Kebh man eden, okhekhen-nọng macha kọ wọ ira on-okwu ode ọsi-aponga kwaman o? Ani man eden akhebhi mọkwọbha, itzama sa mọsọ-ọ iyọhnga s'ira mosi bẹ.” Anọng mba achina ororo ayak Lọt atzim maa, bẹ aben bi avọhkhi ọmma.  
\v 10 Yina, ajinọng mbuma p'awobh k'ọhọhm ẹtzaanga an-anemi mbọhk sabẹ, atzọr Lọt atzima adim k'ọhọhm ẹtzaanga, bẹ abhen ọmma.  
\v 11 Mẹ wọ e, bẹ asi ajinọng mba biphyir p'abe k'iyaan adikkobh ọmaana adeden-nọng akpa chen, ọn-ọkhọn bẹ, bẹ ẹhọhmma ọdọk kare. 
\s1 Ebina cha Lọt ka Sọdọm 
\p  
\v 12 Mẹ wọ, akhekhen-nọng mba abọbh Lọt bi, “Kọ akhaam, anọng adọdọk kẹ o? Rọhng atza atzọkha adim pa va pọ, ọmaana va pọ p'ijinọng, ttara p'ipanọng, ọmaana ọnọng kpenamkpen kw'ode kwọ, atzima bẹ biphyir abina m'obhon nwa,  
\v 13 okhuri bi, mon-odimi obhon nwa e. Itzama s'anọng p'obhon nwa akk'asa, ikk'ihaabha kpọng-kpọng k'itzitzikha s'Ọvaar Ibinọkpaabyi, kẹ wọ osi ọtzọhm man bi mokwu odimi obhon nwa e.” 
\p  
\v 14 Mẹ wọ, Lọt oyin k'iyaan ọtza ọgbaak ajinọng p'akk'for ada bi atzọkha va pẹ p'ipanọng k'ọbada. Oben bẹ bi, “Bọng s'ẹbhar-ẹbhar abina aji obhon nwa, kkeri Ọvaar Ibinọkpaabyi on-odimi obhon nwa e.” 
\p Chibhi da okk'bẹ ọgbaakha mẹ, adim pa va atzọkha kwẹ mach'okhiri-dik. 
\p  
\v 15 Mada ewu en-ehobh, arenga-eden mba adukha Lọt aben bi, “Tzima kwanọng kwọ ọmaana va pọ p'ipanọng p'awobh ma ttar-ọ, abina m'obhon nwa ẹbhar-ẹbhar. Oni mando ode, kọ abira atzọkha ekkema k'ọmmamma kw'ótto okhebha odedenmon nwa.” 
\p  
\v 16 Chibhi da arenga-eden mba adukh-ẹ, Lọt osi ma for \it bi zẹmẹnẹ\it*. Mando kw'arenga-eden mba aji Lọt ọmaana kwanọng kwẹ ttara aminava pẹ afa mbọhk \it bi kpẹẹbh,\it* atzima ayin k'obhon nwa, da Ọvaar Ibinọkpaabyi ọkhaam inọngkwo ttara bẹ.  
\v 17 Mada bẹ akk'ayina k'iyaan m'obhon nwa, ọnọng wani k'ottem kw'arenga-eden mba oben bẹ bi, “Bọng nọbh k'odem kwa bọng akkaana akpen pabọng o. Bọng nnam kàbhakh o, bọng k'ẹttẹri manda dani kàbira abe o. Bọng nọbh achina k'ibe sa mgbegbeho nwobh. Oni mando ode, bọng ápe-ope.” 
\p  
\v 18 Mẹ wọ, Lọt oben bẹ bi, “Mma e, abitta paam, tte nsi bọng nkwo.  
\v 19 Bọng akk'aam ọphyaam akhọkha, bọng akk'ejibha ch'ideden abira asa anang-m, akkaana akpen paam. Yina, ẹfa kaam kede cha mfha nnọbh nchina k'ibe sa mgbegbeho nwobh, okhuri bi itzama nna íkhọhbh-m ọkhọhbha, kaam ḿbiri mpe-ope.  
\v 20 Bọng kkeri obhon nwana kw'owobh ọbaanga ma, bina ma pyiri kẹ kpọng kobhiri. Ode ibhobhona, tte mọrọbh ochina kẹ ifha moruk akpen.” 
\p  
\v 21 Iwa orenga-eden nwa obhin-ẹ bi, “Kaam ńsi-osi mach'aphyem-m. Kaam ńtte obhon nwa ọbọhk otte, kẹ kíndimi.  
\v 22 Kọ rọbh ẹbhar-ẹbhar achina kẹ, okhuri bi, kaam odik manda wani kinkponga nsi ma kọ apyiri kẹ.” Kẹ wọ osi bẹ ayeri obhon nwuma Zoar\f + \fr 19.22 \ft K'eHiburu, Zoar oyini obhon kw'ikhakhari.\f*. 
\s1 Edimi cha Sọdọm ọmaana Gọmọra 
\p  
\v 23 Lọt ọmaana anọng pẹ apyiri ka Zoar k'ogbe kw'ewu ẹkk'ẹnyaana.  
\v 24 Wa Ọvaar Ibinọkpaabyi ọtzọhm atza p'awọm ekpon p'afon k'ẹrọng atzebh ka Sodom ọmaana Gomora.  
\v 25 Mando kw'iwa Ibinọkpaabyi oreng odimi ibhon nna, ọmaana ibhon biphyir s'egbegbeho nda, ttara anọng biphyir p'arukhi m'ibhon nna, ttara ekpo py'emeni m'irek nna.  
\v 26 Yina, kwanọng kwa Lọt ọbhakhi nnam, on-orengi ọtza kw'onung kw'obe \it bi gbẹẹng\it*. 
\p  
\v 27 Mada ewu en-ehọbh, k'ekpekpebha, Abraham obina ochina k'ibe s'iwa obe k'itzitzikha s'Ọvaar Ibinọkpaabyi.  
\v 28 Mada ọhak chen okkeri ka Sodom ọmaana Gomora, k'irek s'ẹttẹri biphyir, ore ororong-bina kw'om-oyin k'okhubha nwuma, mach'irorong s'ekpon cha nkwukha. 
\p  
\v 29 Mẹ wọ, mada iwa Ọvaar Ibinọkpaabyi odimi ibhon nna biphyir s'iwobh k'ẹttẹri, ojima Abraham. Ofona mẹ, ọrọbha Lọt ka mbọhk s'itzama s'itto ikhebha ibhon nna s'iwa Lọt orukhi. 
\s1 Ittẹwọr sa Moab ọmaana Ammọn 
\p  
\v 30 Wa ojora osi Lọt bi, ọtza oruk ka Zoar, on-otzima va pẹ p'ipanọng afa ọtza oruk k'okhubha kwa mgbegbeho. Wa kẹ ọmaana va pẹ afa arukhi k'ọmma kw'itzakpa.  
\v 31 Ewu dani, ochedennwa kwa Lọt, oben ọgbaanọkka bi, “Otte kwaman ọkk'ọtzama; akker-okkeri ojinọng ma ibe nna kode kw'oyima man abẹ mach'ẹmaana ch'ọnọngẹya ede, makhọra ọyagbin.  
\v 32 Tte mọnang otte kwaman atzuk ogwo obuma, ifha moyim-ẹ abẹ, morenga k'otte kwaman osi echimma chaman eningi edimi.” 
\p  
\v 33 M'erungiwu nduma, bẹ anang otte atzuk ogwo obuma, ochedennwa ọtza oyima otte abẹ. Otte ogbe kwa nnwa okwu oyima mẹ, ọmaana ogbe kw'obiro obina korong. 
\p  
\v 34 Ewu ehobh mẹ, ochedennwa oben ọgbaanọkka kw'ikhakhari bi, “Erungiwu ch'ikhena, kaam nkk'otte kwaman abẹ nyima e. Mobiro ọnang-ẹ atzuk ogwo mach'ikhena, m'erungiwu cha mayina, kọ rọhng abira atza ayim-ẹ abẹ, ifha morenga k'otte kwaman mosi echimma chaman eningi edimi.” 
\p  
\v 35 M'erungiwu nduma, bẹ anang otte atzuk ogwo obuma. Ọgbaanọkka kw'ikhakhari obiro ọtza oyima otte abẹ. Otte ogbe kwa nnwa okwu oyima mẹ, ọmaana ogbe kw'obiro obina korong. 
\p  
\v 36 Mẹ wọ, va mba pa Lọt afa p'ipanọng atzima ọbhọr anang otte kwabẹ.  
\v 37 Ochedennwa ọmaan ojinọng, ọkpẹ-ẹ Moab, kẹ wọ ode otte kw'ẹkhọma cha Moab maa apyiri ma.  
\v 38 Ọgbaanọkka kw'ikhakhari obiro ọmaan ojinọng, ọkpẹ-ẹ Bẹn-Ammi, kẹ wọ ode otte kw'ẹkhọma ch'Ammọn ma apyiri ma. 
\c 20  
\s1 Abraham ọmaana Abimẹlẹk 
\p  
\v 1 Abraham obina ochina k'ẹkhọma cha Nẹgẹv, oruk k'ottem kw'ibhon sa Kadẹsh ọmaana Shur. Ayongi mẹ, wa obiro obhing ka Gẹra k'igbegbaa.  
\v 2 Mẹ wọ kw'iwa Abraham ọgbaakhi anọng bi, kwanọng kwẹ, Sara, ode ọgbaanọkka kwẹ. Mẹ wọ, Abimẹlẹk kw'ode ọvaarnọng kwa Gẹra ọtzọhm anọng bi, bẹ atzima Sara akwu k'ọvaar-dimpa kwẹ, ọtzọkh-ẹ. 
\p  
\v 3 Yina, erungiwu dani Ibinọkpaabyi oyin Abimẹlẹk abẹ k'idachen, osi ẹjaakhi ọnang-ẹ bi, “Kọ an-ape e, okhuri bi, kwanọng nwa kw'atzọk ahok m'ọhọhm kwọ, ode kwanọng kw'ọkhaam odim e.” 
\p  
\v 4 Yina, wa Abimẹlẹk ọmaana Sara bẹ ayok for atzima aronga. Mẹ wọ, Abimẹlẹk ọbọbh Ibinọkpaabyi bi, “Itta, ma na kọ atzọkha ọnọng kw'oni itzama otzima ọsa afhu-o?  
\v 5 Abraham ma for sẹ wọ ọgbaakh-m bi, Sara ode ọgbaanotte kwẹ. Sara ọkhaam ma for sẹ obiro ọgbaakh-m bi, Abraham ode ọgbaanotte kwẹ. Ettem chaam ttara achibhi paam bẹ m'odik nwa kapyibhi.” 
\p  
\v 6 Mẹ wọ, Ibinọkpaabyi oben Abimẹlẹk k'idachen bi, “K'odik ọkkakka, kaam nkk'nnonga bi, odik nwa k'ọgbaan kasi, kẹ wọ osi kaam mkpọ-ọ eden ifha aningi ẹkhọngkwuri k'itzitzikha saam asi, mbiri mkpọ-ọ eden ifha bọng aningi ayok abẹ ayim.  
\v 7 Mẹ wọ, tte kwanọng nwuma ọbọhk anang odim kwẹ. Kkeri odim kwẹ ode ọsẹjaakhi, kẹ ózi njọhm ọnang-ọ áruk akpen. Yina, idikha anẹ-ẹ ọbọhk atte, kọ ronga k'odik ọkkakka bi, kọ ọmaana ẹhọhmmọr chọ biphyir ápe-ope.” 
\p  
\v 8 Mẹ wọ, k'ekpekpebha ch'ewu ehobh mẹ, Abimẹlẹk oyeri akhaan-nọng pẹ biphyir akwu, ọtzọkha odik kpenamkpen ọgbaak bẹ. Ojora f'ideden osi bẹ.  
\v 9 Mẹ wọ, Abimẹlẹk oyeri Abraham, ọbọbh-ẹ bi, “Bọng odik-dema kw'asi anang man ma? Yan wọ kwa kaam nkk'ntta ka kọ k'itzitzikha o, kw'ira arenga kwẹ abẹ anang kaam ttara ọvaarbhon kwaam ettuma-dema nda o? Odik nwa kw'asi anang-m ma, kọbaan.”  
\v 10 Abimẹlẹk ochina ororo ọbọbh Abraham bi, “Bọnga nttak kw'atzim asi odik nwa?” 
\p  
\v 11 Abraham obhin-ẹ bi, “Nsi mando da nchibhi bi, anọng p'obhon nwa ojora Ibinọkpaabyi kakhaam, bẹ afha afhu-m okhuri kwanọng kwaam.  
\v 12 Ayongi mẹ, kwanọng nwa ode ọgbaanotte kwaam, kw'otte wani obhoni man, yina, mọkhọmi abakka. Kaam mbiri ndọkh-ẹ macha kwanọng kwaam.  
\v 13 K'ogbe kw'iwa Ibinọkpaabyi osi-m mbina nji ẹhọhmmọr ch'otte kwaam, nnenga nchina k'obe-k'obe. Wa kaam mbeni Sara bi, k'ibe kpenamkpen sa mọtza, kọ gbaak anọng bi, kaam nde ọgbaanotte kwọ, ifha atzima mẹ akhọkh-m idadaakha.” 
\p  
\v 14 Iwa Abimẹlẹk ọtzọkha arukhimaan ọmaana abhaam, ttara abira p'ijinọng ọmaana p'ipanọng, ọnang Abraham. Ọtzọkha Sara ọkpa nnam ọnang Abraham.  
\v 15 Abimẹlẹk on-oben bi, “Kker e, irerek sa kaam ndabhi biphyir iwobh-ọ m'itzitzikha, kọ ruk k'ibe kpenamkpen s'idaakh-ọ.” 
\p  
\v 16 Abimẹlẹk on-obiro oben Sara bi, “Kker e, kaam nnaangi agbaanatte kwọ ashẹkẹl pa silva nnọhna mfa obhiri arọbh jobh. Ma wọ ode ẹkhọhkha bi, odik nwa ọkk'ọha e, ttara bi mbọhk sọ m'odik nwa kinde.” 
\p  
\v 17 Mẹ wọ, Abraham ozi njọhm ọnang Ibinọkpaabyi. Ibinọkpaabyi orenga ma njọhm nna osi Abimẹlẹk, ọmaana kwanọng kwẹ, ttara abira p'ipanọng bi, bẹ abira akhaama va,  
\v 18 okhuri da iwa Abimẹlẹk ọtzọk Sara kw'ode kwanọng kw'Abraham, wa Ọvaar Ibinọkpaabyi okk'panọng p'ẹhọhmmọr ch'Abimẹlẹk biphyir ọkpaana. 
\c 21  
\s1 Ẹmmaana cha Isaak 
\p  
\v 1 Wa Ọvaar Ibinọkpaabyi odo Sara, mach'iwa okk'ochekhi.  
\v 2 Sara okwu otzima ibhọr, ọmaan nnwa kw'ijinọng ọnang Abraham k'atzam. Wa nnwa nwa ọmaan otzor k'ogbe kw'iwa Ibinọkpaabyi okk'ochekhi bi ọmaana.  
\v 3 Mẹ wọ, Abraham okpe nnwa nwa kwa Sara ọmaani, Isaak.  
\v 4 Okwu opyiri iwu izenanttaan sa nnwa nwa kwẹ Isaak ọmaan, Abraham ọsẹ-ẹ ọkpakkọrikkọ otzor k'odem kw'Ibinọkpaabyi ọkk'ẹ ọtzọhna.  
\v 5 Wa Abraham ode cho arọbh azen, k'ogbe kwa nnwa kwẹ Isaak, ọmaan. 
\p  
\v 6 Mẹ wọ, Sara oben bi, “Ibinọkpaabyi ọkk'aam ọsa bi mma aha. Ọnọng kpenamkpen kw'ọbhaang odik nwa kw'Ibinọkpaabyi osi ọnang-m, obiro otzor-m ọmma aha.”  
\v 7 Ochina ororo oben bi, “Anyi wọ ira ọgbaak Abraham bi, na kaam Sara mfha nnọk nnwa? Yina, kaam nkk'nnwa kw'ijinọng mmaana nnang Abraham k'atzam pẹ.” 
\p  
\v 8 Nnwa nwa ọbar, ọkka otzim-ẹ ẹba, okwu opyiri k'ewu ch'ọkka otzimi Isaak ẹba, Abraham osi ọdadaami kw'ideden. 
\s1 Abraham okhubhi Hagar ọmaana Ishimayẹl 
\p  
\v 9 Wa Sara ore da nnwa nwa kwa Hagar kw'ofon Ijip ọmaani ọnang Abraham, om-osi ẹyaanga-tzama ttara Isaak.  
\v 10 Mẹ wọ, Sara oben Abraham bi, “Khubh obira-kwanọng nwa ttara nnwa kwẹ, bẹ arọhng afona. Nnwa nwa kw'obira-kwanọng kọbaan bi ọkhaama ekkema k'ojibhada kwọ, kwa nnwa kwaam Isaak ọ́tzọkha.”  
\v 11 Wa odik nwa ọyakhi Abraham atzim k'ettem kpọng-kpọng, da ore bi, Ishimayẹl obiro ode nnwa kwẹ.  
\v 12 Yina, Ibinọkpaabyi oben Abraham bi, “Ettem ening-ọ atzim ẹyakhi okhuri nnwa nwa ọmaana obira-kwanọng kwọ. Si odik kpenamkpen kwa Sara oben-ọ bi, asi, okhuri bi, orenga ma Isaak va pa va pọ, áhaabh-ọhaabh atzor k'echekhi ch'iwa nkk'nnanga.  
\v 13 Kaam ńsi nnwa kw'obira-kwanọng nwa obiro ọkhaama ẹkhọma chẹ, okhuri da kẹ obiro ode nnwa kwọ.” 
\p  
\v 14 Mẹ wọ e, Abraham obina k'ekpekpebha ọtzọkha ọchattọhk, obiro ọtzọkha asi, okhe k'ẹkpa ch'ede etzenkpa, ọnang Hagar. Abraham ọtzọkha pyẹ ọnan-ẹ ka mbabaang, okhubh-ẹ ọmaana nnwa kwẹ. Mẹ wọ, Hagar obina ochina k'ebherede, k'okhubha kwa Bẹrshẹba. 
\p  
\v 15 Mada asi mba p'awobh k'ẹkpa ch'ede etzenkpa akk'an-aha, Hagar ọtzọkha nnwa oruri k'ochi-gbagba wani.  
\v 16 Ọn-ọpaangi owobha ẹwọr k'oden-mir, oben for sẹ bi, “Kaam ettem kingaama nwobha ma nne nnwa kwaam ope.” Mada otzim owobh ẹwọr mẹ, nnwa kwẹ osẹ-ẹ nkwo, on-obhom ẹmọng k'ẹrọng. 
\p  
\v 17 Wa Ibinọkpaabyi ọbhaanga ẹmọng cha nnwa nwa obhomi. Orenga-eden kw'Ibinọkpaabyi kw'ẹrọng oben Hagar bi, “Bọng odik wọ o? Oning-ọ ojor, mada nnwa kwọ oyim mẹ, Ibinọkpaabyi okk'ẹmọng chẹ ch'obhomi, ọbhaanga.  
\v 18 Bina atza atzini nnwa kwọ, kkeri kaam ńsẹ-ẹ ode otte kw'ẹkhọma ch'ideden.” 
\p  
\v 19 Mẹ wọ, Ibinọkpaabyi osi Hagar ore esipe. Otzima ẹkpa ch'ede etzenkpa, ọtza ọkhaabha asi maa chẹ efhu, ọnang nnwa ogwo.  
\v 20 Wa Ibinọkpaabyi owobha ttara nnwa nwa mada ọm-ọbar. Wa nnwa nwa oruk k'ebherede, ode ọgbajijaa kw'ideden.  
\v 21 Mada iwa nnwa nwa orukhi k'ebherede ka Paran, ọkka kwẹ ọtza ọtzọkha ominanwa kw'ofon Ijip, ọnang-ẹ k'ọbada. 
\s1 Abraham ọmaana Abimẹlẹk asi echekhi 
\p  
\v 22 K'ogbe nwuma, Abimẹlẹk otzim Phikol kw'ode oho kw'agbongnọng pẹ, ọtza oben Abraham bi, “Ibinọkpaabyi owobh ttara kọ k'odik kpenamkpen kw'asi.  
\v 23 Mẹ wọ, kọ chekhi anang-m m'itzitzikha s'Ibinọkpaabyi bi, kaam kàbọhra ọmaana va paam, ttara va pa va paam. Kọ si ẹmmaana ọkkakka atzima atzor-m, ọmaana ẹkhọma nda cha kọ arukhi mach'okhekhen-nọng, atzor macha kaam nsi nnang-ọ.” 
\p  
\v 24 Abraham oben bi, “Kaam nkk'nchekhi.” 
\p  
\v 25 Mẹ wọ e, Abraham ọgbaak Abimẹlẹk odik okhuri esipe chẹ, ch'atzọhmnọng pa kẹ Abimẹlẹk akk'ẹ abọhkha ana.  
\v 26 Yina, Abimẹlẹk obhin-ẹ bi, “Kaam ọnọng kw'osi odik nwa kinnong, kọ kaam odik-dema nwa atzima am-agbaakha, mayina wọ kwa kaam nna mmaang kwẹ.” 
\p  
\v 27 Mẹ wọ, Abraham ọtzọkha arukhimaan ọmaana abhaam, ọnang Abimẹlẹk, bẹ anọng mba afa asi echekhi anang ayok.  
\v 28 Abraham ọtzọkha arukhimaan-papẹ azenamfa k'etzirakpo pyẹ, ọkhọm ohok.  
\v 29 Abimẹlẹk ọn-ọbọbh Abraham bi, “Arukhimaan-papẹ mba azenamfa p'akhọmi ahok ka, ayini yan o?” 
\p  
\v 30 Abraham obhin-ẹ bi, “Kọ khera bi, atzọkha arukhimaan-papẹ mba azenamfa pa kaam nnang-ọ, mando wọ ọkhọkha bi, kọ akk'akhera bi, kaam wọ ndumi esipe nda.” 
\p  
\v 31 Mẹ wọ, anọng ayeri ibe nna Bẹrshẹba, okhuri bi, mẹ wọ kw'ajinọng mba afa awobh asi echekhi anang ayok. 
\p  
\v 32 Mada bẹ akk'echekhi nda asa ka Beershẹba, Abimẹlẹk otzima Phikol nwa kw'ode oho kw'arim-egbong pẹ, ọkpa nnam abhana k'ẹkhọma cha Philistiya.  
\v 33 Wa Abraham ogboni echi cha tamaris ka Bẹrshẹba. M'ibe nna rọ sa kẹ, om-owobha okpobha Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'ipemanitzor.  
\v 34 Wa Abraham oruk m'ẹkhọma nda cha Philistiya k'ogbe-bhirada. 
\c 22  
\s1 Eyoma cha nnam-ophephe kw'Abraham 
\p  
\v 1 K'ogbe wani mẹ, Ibinọkpaabyi oyom nnam-ophephe kw'Abraham, oyer-ẹ bi, “Abraham!” 
\p Abraham obhina bi, “Kkeri kaam ma e.” 
\p  
\v 2 Mẹ wọ, Ibinọkpaabyi oben Abraham bi, “Kọ tzọkha nnwa kwọ Isaak, nnwa nwuma kwọ wani kw'ọdaakh-ọ ọdaak, achina k'ẹkhọma cha Moriya. Tzim-ẹ asi ẹnanga ẹkwọmichẹ k'ottem kwa mgbegbeho sa ńdibh-ọ.” 
\p  
\v 3 Ewu ehobh mẹ k'ekpekpebha, Abraham obina ọmaana atzọhmnọng pẹ afa, ttara nnwa kwẹ Isaak, ọtzọkha ekpo ọdabh k'ẹnyanyaang chẹ. Mada okk'ommen ọkpaara f'obenga ẹnanga ẹkwọmichẹ nda, obina orenga ochina k'ibe nnuma s'Ibinọkpaabyi ọkk'ẹ otzibha.  
\v 4 Ottong iwu ittaan s'orenga nwa, Abraham otzini chen, ore ibe nnuma k'ororo.  
\v 5 Ofona mẹ, Abraham on-oben atzọhmnọng pẹ bi, “Bọng wobha ma ttara ẹnyanyaang atzik man, da kaam ttara Isaak, mochina k'ororo, mótza okpobha Ibinọkpaabyi. Mokyerkyer, mọ́kpa nnam ọkpa okhebha bọng m'ibe nna.” 
\p  
\v 6 Wa Abraham otzini ommen fa bẹ atzima abaanga ekpon ch'ẹnanga ẹkwọmichẹ, ọnana nnwa kwẹ Isaak. Kẹ Abraham otzima ekpon, ọmaana imaana k'ọbọhk. Mada bẹ anọng afa areng m'eden,  
\v 7 Isaak, oben otte bi, “Itta kwaam.” Abraham okhera bi, “Nnwa kwaam.” 
\p Isaak ochina ororo oben bi, kaam mben bi, mbọbh-ọ bi, “Mada ommen owobh ma, ekpon ewobha, orukhimaan kw'am-otzima osi ẹnanga ẹkwọmichẹ kho o?” 
\p  
\v 8 Mẹ wọ, Abraham obhin-ẹ bi, “Nnwa kwaam, Ibinọkpaabyi ọkhaam ma for sẹ wọ, ọ́nang man orukhimaan kw'ẹnanga ẹkwọmichẹ nda e.” Mando wọ kwa bẹ anọng afa achin ororo arenga afona. 
\p  
\v 9 Mada bẹ apyiri k'ibe s'Ibinọkpaabyi ọkk'ẹ ọgbaakha, Abraham osi ijafọhnibe mẹ, ọtzọkha ommen otzobha nkwukha. Yina ọn-ọtzọk nnwa kwẹ Isaak, ọdabh ndik biphyir, otzin-ẹ ọnana k'ommen nvuma ebir-ebir.  
\v 10 Mẹ wọ, Abraham onemi ọbọhk ọtzọkha imaana bi, ofhu nnwa kwẹ.  
\v 11 Yina, orenga-eden kw'Ọvaar s'Ibinọkpaabyi owobha k'ẹrọng oyer-ẹ bi, “Abraham! Abraham!” 
\q1 Abraham obhin-ẹ bi, “Kkeri kaam ma e.” 
\p  
\v 12 Orenga-eden nwa oben bi, “Nnwa nwuma ọbọhk kàtọhmi, kẹ ọttọhk kàsi o! Kaam nkk'nna nnonga bi, kọ akhaam ojora f'Ibinọkpaabyi, okhuri da kọ akher bi, atzima nnwa kwọ wani kẹ-khẹ afọhni ẹja anang-m.” 
\p  
\v 13 Mẹ wọ, Abraham otzini chen ore erukhimaan-dim ch'etzim abhik ẹdama k'ọran, ofona ọtza ọtzọkha chẹ, otzima osi ẹnanga ẹkwọmichẹ k'eho cha nnwa kwẹ.  
\v 14 Mẹ wọ e, Abraham oyeri ibe nnuma bi, “Ọvaar Ibinọkpaabyi ọ́nang-ọnang.” Maa apyiri mayina, anọng an-ayeri ibe nnuma, “K'egbegbeho ch'Ọvaar Ibinọkpaabyi ọ́nang-ọnang.” 
\p  
\v 15 Wa orenga-eden kw'Ọvaar Ibinọkpaabyi owobha k'ẹrọng oyeri Abraham ottong igbe ifa,  
\v 16 oben bi, “Ọvaar Ibinọkpaabyi ochekhi ka che chẹ bi, okhuri da kọ akher bi atzima nnwa nwa wani kwọ afọhni ẹja anang-m,  
\v 17 k'odik-ọkka kaam ńdọ-ọ, mbiri ńsi va pọ bẹ ahaabh macha ndodori sa nwobh k'ọrọngkpakpa, ọmaana opfong kw'owobh k'ọraanga. Mẹ wọ, va pa va pọ abira atzọkha idedenmon s'iwobh m'ẹkhọma nduma ch'attattaanga-nọng pọ.  
\v 18 Órenga ka nnam sa va pa va pọ, ngọma s'ọyagbin biphyir ńdọkha ẹdaa, ọkhuri da, kọ ahak eho anang ndọhna saam.” 
\p  
\v 19 Mando kw'Abraham ọkpa nnam ọtza okhebha atzọhmnọng pẹ kẹ da bẹ atzikh-ẹ. Bẹ biphyir abina abhana ka Bẹrshẹba. Wa Abraham osi oruk kwẹ mẹ. 
\s1 Ẹnọmma cha Nahọr 
\p  
\v 20 Wa k'ogbe wani, bẹ agbaakhi Abraham bi, “Milka, kw'ode kwanọng kw'agbaanakka, Nahọr, okk'va p'ijinọng obiro ọmaana ọnang-ẹ. Wa va pa Milka ọmaani ọnang Nahọr bẹ ade: 
\li1  
\v 21 Uz, kw'ode ocheden-nwa. 
\li1 Wa Uz ọkhaam agbaanọkka p'akpen Buz, ọmaana Kẹmuẹl. 
\li1 Kẹmuẹl kẹ wa ode otte kw'Aram, 
\li1  
\v 22 obiro ode otte kwa Kẹsẹd, 
\li1 ọmaana Hazọr, 
\li1 ọmaana Pildash, 
\li1 ọmaana Jidlaph 
\li1 ttara Bẹtuẹl.”  
\v 23 Bẹtuẹl, ode otte kwa Rẹbẹka. Wa Milka ọmaani va azenanttaan ọnang Nahọr kw'ode ọgbaanọkka kw'Abraham. 
\p  
\v 24 Wa ọkkọra-kwanọng kwa Nahọr kw'okpen Reuma obiro ọmaan-ẹ va p'ade: Tẹba, ọmaana Gaham, ọmaana Tahash ttara Maaka. 
\c 23  
\s1 Obo ọmaana ẹnọhnga cha Sara 
\p  
\v 1 Wa Sara orukhi akpen ka cho arọbh azadani obhiri azenamfa.  
\v 2 Ope ka Kiriyat-Arba, kwa bẹ abira ayeri Hẹbrọn, k'ẹkhọma cha Kenaan. Wa Abraham ọtzọkha ogbe, obhom Sara kw'ọkk'ọpa. 
\p  
\v 3 Mẹ wọ, Abraham obina oji obukhi kwa kwanọng kwẹ ọtza okhebha anọng pa Het, oben bẹ bi,  
\v 4 “Kaam nde okhekhennọng ma bọng k'obhon. Bọng kpe-m irerek sa ndima nsi inọhng-anọng, ifha ode mẹ, ńnọhnga obukhi kwaam.” 
\p  
\v 5 Iwa anọng pa Het abhina Abraham bi,  
\v 6 “Itta, yonga man itzọhng, kọ ade ọvaar-nwa kw'ideden ma man k'ottem e, nọhnga kwanọng kwọ k'epekhubh kpenamkpen ch'ẹdaakh-ọ ọtzam, ma mpekhubh nna sa man. Ọnọng mada wani kw'ọraam-ọ ibe sa anọhnga kwanọng ma kode e.” 
\p  
\v 7 Mẹ wọ, Abraham obina ochunga eho k'ikpokpobha ọnang anọng pa Het.  
\v 8 Oben bẹ bi, “Idikha ọdaakhi bọng kẹ bi, kaam nnọhnga kwanọng kwaam manya bọng k'irerek, tte mphyem bọng odik wani bi, bọng aphyem Ẹphrọn, nnwa kwa Zoha anang-m,  
\v 9 ifha okpe-m ọmma kw'itzakpa, kw'owobh ka Makpẹla k'ikpiho s'owoni kwẹ. Bọng ben-ẹ bi, okpe-m sẹ k'ẹphya ch'ẹdaakh-ẹ, ifha ndima sẹ nsi inọhng-anọng ma bọng k'obhon.” 
\p  
\v 10 Iwa Ẹphrọn kw'ofon Het owobh ẹwọr mẹ ttara anọng pa Het, k'ogbe kw'Abraham ọm-ọgbaak odik nwa. Obina m'ottem kw'ayok, ọnang Abraham ebhina k'odik kw'ophyemi. Wa ọnọng kpenamkpen kw'owobh m'ẹbaakhamma ch'obhon ọbhaanga ebhina ch'Ẹphrọn kw'ofon Het ọnangi Abraham. 
\p  
\v 11 Wa Ẹphrọn on-obhina bi, “Mma e, itta kwaam yong-m itzọhng, kaam nnang-ọ irerek nna biphyir ttara ọmma nwa kw'itzakpa kw'owobh mẹ. Kaam nsi mando k'itzitzikha s'anọng mba paam biphyir, ifha kọ anọhnga obukhi kwọ.” 
\p  
\v 12 Iwa Abraham obiro ochunga eho ọkhọkha ikpokpobha k'itzitzikha s'anọng p'obhon nwa.  
\v 13 On-oben Ẹphrọn k'itzitzikha s'anọng mba bi, “Yong-m itzọhng, idikha ọdaakh-ọ, kaam ndebh irerek nna odebh. Kọ tzọkha agbukha pa kaam ńnang-ọ m'irerek nna, ifha nnọhnga kwanọng kwaam.” 
\p  
\v 14 Mẹ wọ, Ẹphrọn on-obhina Abraham, oben bi,  
\v 15 “Itta kwaam, yong-m itzọhng, irerek nna ipe ashẹkẹl ẹnọhna pa silva, yina, bẹ ape mbọng k'ottem kwaman anọng afa o? Nọnhga kwanọng kwọ k'irerekh e.” 
\p  
\v 16 Wa Abraham okhera mach'Ẹphrọn obeni, ọnang Ẹphrọn ogbukhabhik m'itzitzikha s'anọng pa Het otzor k'ẹphya ch'ọgbaakhi. Wa ọnang-ẹ ashẹkẹl ẹnọhna pa silva otzor k'ẹphya ch'aphya-phyaa. 
\p  
\v 17 Mẹ wọ, Ẹphrọn ọtzọkha irerek s'iwobh ka Makpẹla ọbaanga Mamrẹ, ọmaana ọmma kw'itzakpa ttara nchi kpenamkpen sa mbe m'ibe nnuma okpe pyẹ biphyir  
\v 18 ọnang Abraham, en-ede py'Abraham k'itzitzikha s'anọng pa Het biphyir, p'awobh m'ẹbaakhamma ch'obhon nwa.  
\v 19 Mada ntọhna s'irerek nna nkk'nha, Abraham ọnọhnga kwanọng kwẹ, Sara, k'ọmma kw'itzakpa kw'owobh ka Makpẹla, ọbaanga Mamrẹ kw'ode Hẹbrọn, k'ẹkhọma cha Kenaan.  
\v 20 Mẹ wọ e, anọng pa Het atzọkha irerek nnuma, ttara ọmma nwuma kw'itzakpa, akpe anang Abraham, otzima osi inọhng-anọng. 
\c 24  
\s1 Isaak ọmaana Rẹbẹka 
\p  
\v 1 K'ogbe kw'iwa Abraham ọkk'ọn-ọtzama, obiro ọhaabh cho. Iwa Ọvaar Ibinọkpaabyi ọkk'ẹ ọda ttara idik biphyir.  
\v 2 Wa Abraham oben oho kw'atzọhmnọng p'ẹhọhmmọr chẹ, ọmaana odik kpenamkpen kw'ode kwẹ bi, “Kọ khe ọbọhk kwọ ka ọtzaak kwaam irekhirek.  
\v 3 Kaam nnori bi anwọhngi ka che ch'Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'ẹrọng ọmaana kw'irerek bi, kọ kwanọng k'ottem kw'aminava p'anọng pa Kenaan, pa kaam nnukhi ma ttara, kátzọkha anang nnwa kwaam.  
\v 4 Yina, kọ áchina k'ẹkhọma chaam, k'anọng paam, atza atzọkha kwanọng anang nnwa kwaam, Isaak.” 
\p  
\v 5 Ọtzọhmnọng nwa kwẹ, ọbọbh-ẹ bi, “Idikha kwanọng nwuma onokher bi, ọtzọn-m abẹ okwu m'irek nna khi? Ode bi kaam ńdima nnwa kwọ mkpa nnam k'ẹkhọma chọ o?” 
\p  
\v 6 Abraham oben-ẹ bi, “K'eden kpenamkpen kọ kàkhaambi, atzima nnwa kwaam akpa nnam kẹ.  
\v 7 Ọvaar Ibinọkpaabyi, ode Ibinọkpaabyi kw'ẹrọng. Kẹ wọ otzim-m obina k'ẹhọhmmọr ch'otte kwaam, ọmaana k'ọmmaana-bhon kwaam. Kẹ ọgbaakh-m atzim obiro ọnwọhngi ọnang-m, oben bi, ‘Kaam ńnang va pa va pọ irerek nna.’ Kẹ ọ́tzọhm orenga-eden kwẹ, kw'otzibh-ọ eden ch'arenga ifha atzọkha kwanọng kẹ anang nnwa kwaam.  
\v 8 Idikha kwanọng nwa on-okher bi ọtzọn-ọ abẹ, ọnwọhngi nwa kọ kọ́bọkha. Yina, kọ nnwa kwaam kàtzima akpa nnam kẹ o.”  
\v 9 Mando wọ kw'ọtzọhmnọng nwa, okhe ọbọhk kwẹ k'ọtzaak kw'itta kwẹ, Abraham, ọnwọhngi bi kẹ osi-osi mach'itta kwẹ obeni. 
\p  
\v 10 Iwa ọtzọhmnọng nwa ọtzọkha akamẹl jobh p'itta kwẹ, obiro ọtzọkha ekpo ọkkakka k'adem-k'adem p'itta kwẹ, ọnana akamẹl mba. Obina orenga ochina k'Aram-Naharayim, orenga opyiri k'obhon kw'iwa Nahọr orukhi.  
\v 11 Okwu opyiri ma nchọhkha-bọhk, m'ogbe kwa panọng am-atza akhaabha asi, mando wọ kw'osi akamẹl mba attima ndudungi abaanga esipe ch'ewobh k'obhon ọkhaan-ọkhaan. 
\p  
\v 12 Mẹ wọ, on-ozi njọhm, oben bi, “O Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'itta kwaam, Abraham, si kaam ngaama ọwọbh k'ewu cha mayina, abira asi ọphyaam anang itta kwaam, Abraham.  
\v 13 Kker e, kaam mbe m'esipe nda ọkhaan-ọkhaan, da aminava p'obhon nwa am-akwu akhaabha asi.  
\v 14 Tte kwẹ ode bi, isaa mbeni ominanwa bi, ‘Tzotzokhaan, kọ nang-m asi ibebaa m'isi-rọhkha sọ ngwo,’ oben-m bi, ‘Gwo, ifha mbiri ńnang akamẹl pọ,’ tte ode bi, kẹ wọ kw'akk'atzekha anang ọtzọhmnọng kwọ Isaak. Ofona mẹ kaam ńnonga bi, kọ akk'ọphyaam asa anang itta kwaam.” 
\p  
\v 15 Yina okyera njọhm ozizi, Rẹbẹka oyin ka ttara isi-rọhkha ka mbabaang sẹ. Kẹ wa ode ominanwa kwa Bẹtuẹl kw'ode nnwa kw'ijinọng kwa Milka ọmaani ọnang Nahọr, kw'ode ọgbaanọkka kw'Abraham.  
\v 16 Wa kẹ ojibhi ominanwa, ojinọng otzim oronga. Mando kw'iwa ọhak k'esipe, otzima isi-rọhkha ọkhaabha asi maa sẹ ifu, otzima ovura. 
\p  
\v 17 Iwa ọtzọhmnọng kw'Abraham odukha ọtza okhebh-ẹ, oben bi, “Tzotzokhaan, kebh-m asisaa p'isi-rọhkha sọ, ngwo.” 
\p  
\v 18 Rẹbẹka oben-ẹ bi, “Itta kwaam, tọkha asi agwo.” Ọhakha isi-rọhkha m'ẹbhar-ẹbhar otzima ka mbọhk, ọnang-ẹ asi ogwo. 
\p  
\v 19 Mada ọkk'ẹ asi ọnanga ogwo, on-oben bi, “Kaam ḿbiri ńgaabha nnang akamẹl pọ, bẹ agwo maa bẹ abenga bẹ.”  
\v 20 M'ẹbhar-ẹbhar, ọtza ọwọna asi p'isi-rọhkha k'ọgbaakha, obiro ọrọbh ọkpa nnam k'esipe ọtza ọkhaabha asi ọnang akamẹl pẹ, bẹ agwo maa bẹ abenga bẹ.  
\v 21 Odik okkoni ojinọng nwa, ọn-ọkhẹ-ẹ otzum, ifha ore s'Ọvaar Ibinọkpaabyi okk'ejibha ọsa, k'orenga kw'ọtza. 
\p  
\v 22 Mada akamẹl akk'asi akyera, ọtzọhmnọng nwa ọtzọkha ẹbaanga cha gol ch'ahung ch'ẹdọhbhi epyiri ẹdọhbh ch'ishẹkẹl-gbokha, obiro ọtzọkha agimma afa pa gol pa mbọhk, p'adọbhi apyiri ẹdọhbh ch'ashẹkẹl jobh.  
\v 23 Ọbọbh-ẹ bi, “Kọ ade ominanwa kw'anyi o? Tzotzokhaan gbaakh-m, na iyimabe iwobha k'ọhọhm kw'atte, sa kaam mfha nyima ttara anọng paam k'erungiwu cha mayina o?” 
\p  
\v 24 Rẹbẹka obhin-ẹ bi, “Kaam nde nnwa kwa Bẹtuẹl, kwa Milka ọmaani ọnang Nahọr.  
\v 25 Maman ọkhaam araraari-bukhi ọmaana ọchattọhk fa nden kẹ k'ọhaabh, fa nden sọ nchi, ọmaana iyimabe sa bọng ayima k'erungiwu cha mayina.” 
\p  
\v 26 Iwa ọtzọhmnọng nwa kw'Abraham ochunga eho, ọnang Ọvaar Ibinọkpaabyi ikpokpobha,  
\v 27 oben bi, “Ẹtzọhnga ewobh ẹnang Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'itta kwaam, Abraham. Kẹ itta kwaam ọphyaam ọmaana idadaakha sẹ kọrami. Onode kaam, Ọvaar Ibinọkpaabyi ọkk'aam eden otzima \it bi bẹẹm\it*, nkwu ndim k'ọhọhm kw'anọng p'itta kwaam.” 
\p  
\v 28 Iwa ominanwa nwa ọrọbh ọtza ọgbaak ẹhọhmmọr ch'ọkka idik nna biphyir.  
\v 29 Wa Rẹbẹka ọkhaam ọgbaanọkka kw'ijinọng kw'okpen Laban, kw'obin m'ẹbhar-ẹbhar oyin k'iyaan, otza okhebha ojinọng nwa k'esipe.  
\v 30 Mada Laban ore ẹbaanga ch'ahung ọmaana agimma p'ọgbaanọkka okhe ka mbọhk, akwu attara k'idik s'ọkk'ọbhaanga sa Rẹbẹka ọgbaakhi okhuri ojinọng nwa, on-obina otza okhebha ojinọng nwa kẹ da obe ttara akamẹl, ọbaanga esipe.  
\v 31 Oben bi, “Kọ kwu, kọ kw'Ọvaar Ibinọkpaabyi ọkk'ọda, ode yan kw'atzima abe k'iyaan o? Kwu mofona, kkeri kaam nkk'ibe nda nhokh-ọ, ọmaana ibe s'akamẹl abira awobha.” 
\p  
\v 32 Mẹ wọ, ojinọng nwa ochina k'ọhọhm, bẹ achaari akamẹl ndọhkha, bẹ anang bẹ araraari-bukhi ọmaana ọchattọhk fa nden, bẹ abira anang ojinọng nwa ttara anọng p'atzọn-ẹ abẹ asi, bẹ agbobhi mmo sabẹ.  
\v 33 Bẹ abera bẹ ochattọhk, yina oben bi, “Kaam ọchattọhk kinchi maa, mgbaak bọng odik kwa ngaam bi, mgbaak.” 
\p Laban oben-ẹ bi, “Kọ gbaak man.” 
\p  
\v 34 Mẹ wọ, oben bi, “Kaam nde ọtzọhmnọng kw'Abraham.  
\v 35 Ọvaar Ibinọkpaabyi okk'itta kwaam ẹdaa ch'ideden ọnanga maa, on-ode ọkkọkkaa. Ọvaar Ibinọkpaabyi ọkk'ẹ arukhimaan, ọmaana abhaam, ọmaana silva, ọmaana gol, ọmaana atzọhmnọng p'ijinọng ttara p'ipanọng, ọmaana akamẹl ttara nnyanyaang ọnanga.  
\v 36 Sara kw'ode kwanọng kw'itta kwaam, okk'ẹ nnwa kw'ijinọng ọmaana k'atzam. Itta kwaam okk'ẹkhakhaama chẹ biphyir ọtzọkha ọnang nnwa nwa.  
\v 37 Itta kwaam osi-m ndọkha ọnwọhngi, oben bi, ‘Kọ kàkhaambi atzọkha kwanọng k'aminava p'anọng pa Kenaan, pa kaam nnukhi ma ttara, anang nnwa kwaam.  
\v 38 Yina, kọ rọhng k'efona chaam, ọmaana k'ẹnọmma chaam, atza atzọkha kwanọng anang nnwa kwaam.’ 
\p  
\v 39 “Mẹ wọ, kaam mbọbh itta kwaam bi, ‘Kaam nsi yan, idikha kwanọng nwa onokher bi, ọtzọn-m abẹ?’ 
\p  
\v 40 “Itta kwaam obhin-m bi, ‘Ọvaar Ibinọkpaabyi kwa kaam nkk'mkpobha k'eden ọkkakka, ọ́tzọhm orenga-eden kwẹ otzim-ọ eden, ọnang-ọ owujibha k'orenga kwọ, ifha kọ afha atzọkha kwanọng k'efona ch'otte kwaam, k'ẹnọmma chaam, anang nnwa kwaam.  
\v 41 Ọnwọhngi nwa kọ kọ́bọkha, idikha achin k'ẹnọmma chaam, kaambi ode bi, bẹ kọ ominanwa nwa kanangi, ọnwọhngi nwa kọ kọ́bọkha e.’ 
\p  
\v 42 “Mẹ wọ e, mada mpyiri m'esipe nda mayina, mben bi, ‘O Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'itta kwaam, Abraham, idikha ode ochibhi kwọ, tzotzokhaan, nang-m owujibha m'orenga nwa kwa nkk'nkwa ma o.  
\v 43 Kker e, kaam mbe m'esipe nda ọkhaan-ọkhaan, idikha ominanwa kw'obhon nwa okwu bi okwu akhaabha asi, mben-ẹ bi, “Tzotzokhaan kọ nang-m asi m'isi-rọhkha sọ ngwo ibebaa,”  
\v 44 idikha oben-m bi, “Kọ gwo, kaam ḿbiri ńgaabha nnang akamẹl pọ,” tte kẹ ode ominanwa nwuma kw'Ọvaar Ibinọkpaabyi okk'otzekha ọnang nnwa kw'itta kwaam.’ 
\p  
\v 45 “Yina nkyera njọhm ozizi k'ettem chaam, Rẹbẹka oyin ka ttara isi-rọhkha sẹ k'ẹbabaang, ọhakha k'esipe, ọtza ọkhaabha asi. Kaam mben-ẹ bi, ‘Tzotzokhaan nang-m asi ngwo.’ 
\p  
\v 46 “M'ẹbhar-ẹbhar, ọhakha isi-rọhkha k'ẹbabaang, oben bi, ‘Kọ gwo, mbiri ńgaabha nnang akamẹl pọ.’ Mẹ wọ, kaam ngwo, obiro ọkhaabha ọnang akamẹl paam. 
\p  
\v 47 “Kaam mbọbh-ẹ bi, ‘Kọ ade ominanwa kw'anyi o?’ 
\p “Obhina bi, ‘Kaam nde nnwa kwa Bẹtuẹl, kwa Nahọr obhoni ka ndaak sa Milka.’ 
\p “Mẹ wọ, kaam ngẹ-ẹ ẹbaanga ka hung, mbiri ngẹ-ẹ agimma ka mbọhk sẹ.  
\v 48 Nchunga eho mkpobha Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'itta kwaam, Abraham, kw'ọkk'aam eden otzima k'eden-ọkkakka maa, nkwu ndọkha nnwa-mmona kw'ọgbaanọkka kw'itta kwaam, nnang nnwa kwẹ-ẹ k'ọbada.  
\v 49 Mẹ wọ, idikha ási ọphyaam f'odik-ọkka osi anang itta kwaam, gbaakh-m. Idikha án-asi, gbaakh-m, ifha nnonga eden cha ńsi.” 
\p  
\v 50 Laban ọmaana Bẹtuẹl abhina bi, “Mada idik nna biphyir ifon k'Ọvaar Ibinọkpaabyi, maman odik kw'ojibh-ojibh ttara kw'opyibh-opyibh kọkhaam kwa mọfha ọgbaak.  
\v 51 Kkeri Rẹbẹka manya, tzọkh-ẹ atzima rọhng. Tte kẹ on-ode kwanọng kwa nnwa kw'itta kwọ, mach'Ọvaar Ibinọkpaabyi obeni.” 
\p  
\v 52 Mada ọtzọhmnọng kw'Abraham ọbhaang odik kwa bẹ agbaakhi, ochunga eho k'irerek, ọnang Ọvaar Ibinọkpaabyi ikpokpobha.  
\v 53 Mẹ wọ, ọtzọhmnọng nwa ọrọbha ẹfanginẹkpo pya gol ọmaana pya silva, okwu ọttara k'ọbara k'adem-k'adem, ọnang Rẹbẹka. Obiro tzọkha ekpo py'epe agbukha ọnang ọgbaanọkka kw'ijinọng ọmaana ọkka kwa Rẹbẹka. 
\p  
\v 54 Kẹ ọmaana anọng p'atzọn-ẹ abẹ achi ọchattọhk abira agwo atzuk, bẹ abira ayima mẹ maa, ewu ehobha. 
\p Mada bẹ aphyọbh k'ekpebha, oben bi, “Bọng dọhm-m mmana, ifha mkpa nnam ndor itta kwaam.” 
\p  
\v 55 Yina, ọgbaanọkka kwa Rẹbẹka ọmaana ọkka an-abhina bi, “Tte ominanwa nwa owobha ttara man k'iwu jobh yina bọng atzọn afona.” 
\p  
\v 56 Yina, ọtzọhmnọng nwa obhina bẹ bi, “Bọng kaam ka bọkha akhok manya, da Ọvaar Ibinọkpaabyi okk'orenga kwaam ọsa ojibh. Bọng dọhm-m mmana ifha mkpa nnam ndor itta kwaam.” 
\p  
\v 57 Mẹ wọ, bẹ an-aben bi, “Tte moyeri ominanwa ọkhaam, ifha mọbhaanga ka kẹ dọk.”  
\v 58 Wa bẹ ayeri Rẹbẹka abọbh-ẹ bi, “Na ọdaakh-ọ bi átzọn ojinọng nwa abẹ afona o?” 
\p Obhina bi, “Kaam ọdaakh-m kẹ bi, ndọn-ẹ abẹ mfona e.” 
\p  
\v 59 Mẹ wọ, bẹ atza arik ọgbaanọkka kwabẹ, Rẹbẹka k'eden, ọmaana ọrọrọkha kwẹ, ọmaana ọtzọhmnọng nwa kw'Abraham, ttara anọng p'atzọn-ẹ abẹ.  
\v 60 Bẹ abira asi Rẹbẹka ittabọhng, aben-ẹ bi, 
\q1 “Ọgbaanọkka kwaman, tte ọmaan ojibh-ọ, amaan va k'ọhaabh. 
\q2 Tte va pa va pọ ade nnọhna nabhik. 
\q1 Tte va pa va pọ atzọkha 
\q2 idedenmon s'attattaanga-nọng pabẹ.” 
\p  
\v 61 Mẹ wọ, Rẹbẹka ọmaana aminava p'arukh-ẹ abẹ, ado for avura akamẹl, atzọn ọtzọhmnọng kw'Abraham abẹ. Mando kw'ọtzọhnmnọng nwa otzim abaRẹbẹka ofona. 
\p  
\v 62 Iwa Isaak kw'orukhi k'okhubha kwa Nẹgẹv okk'ofona ka Beer-Lahai-Roi okhuna.  
\v 63 Wa k'ẹchọhkhawu dani, Isaak ofona ochina k'owoni bi, ọtza ọtzọkha ọphapha. Mada otzini chen okkeri k'ororo, ore da akamẹl am-akwu.  
\v 64 Rẹbẹka obiro otzini chen okkeri k'ororo ore Isaak, mando kw'ọhak ka kamẹl kwẹ,  
\v 65 ọbọbh ọtzọhnmnọng nwa bi, “Bọng ojinọng wọ kana kw'om-orenga otzor man ka o?” 
\p Ọtzọhmnọng nwa obhina bi, “Itta kwaam wọ ẹ.” Mando kwa Rẹbẹka ọtzọk ọphyọhng kwẹ obubha k'itzitzikha sẹ. 
\p  
\v 66 Mẹ wọ, ọtzọhmnọng nwa ọgbaak Isaak idik s'ọkk'ọsa biphyir.  
\v 67 Isaak otzim-ẹ odim k'ikhira s'ọkka kwẹ Sara, kw'ọkk'ọpa. Rẹbẹka on-ode kwanọng kw'Isaak. Isaak ọkhọhkha Rẹbẹka idadaakha, otzima mẹ odini for sẹ ettem k'obo kw'ọkka kwẹ. 
\c 25  
\s1 Obo kw'Abraham. 
\p  
\v 1 Wa Abraham okwu ọtzọkha kwanọng ọdọdọk kw'okpen Kẹtura. 
\li1  
\v 2 Kẹ wọ ọmaan-ẹ Zimran, ọmaana Jọkshan, ọmaana Medan, ọmaana Midiyan, ọmaana Ishbak ttara Shua. 
\li1  
\v 3 Jọkshan wa ode otte kwa Sheba ọmaana Dedan; va pa va pa Dedan ade abAshur, ọmaana abaLẹtush, ttara abaLeum. 
\li1  
\v 4 Va p'ijinọng pa Midiyan ade Ẹpha, ọmaana Ẹphẹr, ọmaana Hanọk, ọmaana Abida, ttara Ẹlda. Va mba biphyir wa bẹ ade va pa va pa Kẹtura. 
\p  
\v 5 Wa Isaak ọtzọk ekkema k'ẹkhakhaama chẹ biphyir ch'Abraham ope oji.  
\v 6 Yina, Abraham ọn-ọbhaangi va mbonggo pẹ biphyir, p'akkọra-panọng oruk, ttara ekpo pyẹ ẹdọdọk, oben bẹ akhọm aruk achina k'okhubha kw'ewuchen em-eyin, abhir Isaak eden. 
\p  
\v 7 Biphyir-phyir wa Abraham orukhi cho arọbh azenanttaan obhiri chi.  
\v 8 Mẹ wọ, wa Abraham oji ikponga-nnam-wọhng sẹ, ope k'atzam, bẹ anọhng-ẹ otzor anọng pẹ p'akk'apa.  
\v 9 Wa nnwa kwẹ Isaak ọmaana Ishimayẹl, anọhnga otte kwabẹ, k'ọmma kw'itzakpa kw'owobh ka Makpẹla, ọbaanga Mamrẹ, k'irerek s'iwa ide s'Ẹphrọn, kw'ode nnwa kwa Zoha kw'ofon Het.  
\v 10 Wa Abraham odebhi irerek nna ka mbọhk s'anọng pa Het. Wa bẹ anọhnga Abraham m'ibe nna rani s'iwa bẹ anọhng kwanọng kwẹ, Sara. 
\p  
\v 11 Mada Abraham ọkk'ọpa, Ibinọkpaabyi odo nnwa kwẹ Isaak, kw'iwa on-orukhi ọbaanga Beer-Lahai-Roi. 
\s1 Efona ch'Ishimayẹl 
\p  
\v 12 Ma wọ ode efonamma ch'Ishimayẹl, kw'ode nnwa kw'Abraham obhoni ka ndaak sa Hagar kw'ofon Ijip, kw'iwa ode obira kwa Sara. 
\p  
\v 13 Ma wọ ode che pa va p'Ishimayẹl k'odem kw'obhoni bẹ: 
\li1 Nẹbayọt kw'ode ocheden-nwa, ọmaana Kẹda, ọmaana Adbẹl, ọmaana Mibsam, 
\li1  
\v 14 ọmaana Mishma, ọmaana Duma, ọmaana Masa, 
\li1  
\v 15 ọmaana Hadad, ọmaana Tẹma, ọmaana Jetur, ọmaana Naphish, ttara Kẹdẹma. 
\p  
\v 16 Ma wọ iwa ode va p'ijinọng p'Ishimayẹl p'adabhi ngọma jobh obhiri mfa, sa mkpen che mmina bẹ, atzor k'aruk pabẹ ọmaana k'obhingabe fabẹ.  
\v 17 Biphyir-phyir wa Ishimayẹl orukhi cho arọbh azadani obhiri chi obhiri afa, ope, bẹ anọhng-ẹ otzor anọng pẹ p'akk'apa.  
\v 18 Wa va pa va pẹ arukhi ttẹwọr k'okhubha kwa Havila maa, apyiri k'okhuba kwa Shur, kw'owobh ọbaanga k'enem ch'Ijip, kẹ da achin k'okhubha kw'Ashur. Wa bẹ arukhi k'ittattaanga ttara votte pabẹ biphyir. 
\s1 Ẹmmaana ch'Ẹsau ọmaana Jekọb 
\p  
\v 19 Ma wọ ode efonamma ch'Isaak, kw'ode nnwa kw'Abraham. 
\p Abraham wọ iwa obhoni Isaak.  
\v 20 Iwa Isaak ode cho arọbh afa, k'ogbe kw'ọtzọk Rẹbẹka k'ọbada. Rẹbẹka ode nnwa kwa Bẹtuẹl kw'ofon Aram, kwa Padan-Aram, obiro ode ọgbaanọkka kwa Laban kw'ofon Aram. 
\p  
\v 21 Wa Rẹbẹka ọkpaan-ọkpaana, mẹ wọ, Isaak ozi njọhm ọnang Ọvaar Ibinọkpaabyi k'eho chẹ. Ọvaar Ibinọkpaabyi ọbhaanga njọhm sẹ, osi Rẹbẹka otzima ibhọr.  
\v 22 Wa va afa p'awobh-ẹ k'ẹbhọr am-arima ayok abẹ. Mẹ wọ, Rẹbẹka ọbọbh bi, “Bọng odik wọ om-okhebh-m ma o?” Mando kw'orori odik nwa ọbọbh Ọvaar Ibinọkpaabyi. 
\p  
\v 23 Ọvaar Ibinọkpaabyi obhin-ẹ bi, 
\q1 “Ngọma mfa rọ nwobh-ọ mẹ ẹbhọr, 
\q2 ngọma nna mfa s'iwobh-ọ m'ẹbhọr, ikhina sẹ ḿmaangi ayok, 
\q1 ẹkhọma dani ẹ́khaama ẹfa ẹyọhnga oyok. 
\q2 Ẹkhọma ch'echi eden ẹmmaana, ési ọtzọhm ẹnang ẹkhọma ch'ekpong nnam.” 
\p  
\v 24 Mada ogbe opyiri kw'ọmaan, va p'ijinọng afa bọ awobh-ẹ k'ẹbhọr.  
\v 25 Nnwa kw'ochi eden oyin okhor-okhor, ttara iphyubha ka for mach'ẹnọhmakpa ch'ede iphyubha-iphyubha. Mẹ wọ, bẹ akpẹ-ẹ Ẹsau.  
\v 26 Mada ocheden okk'oyina, ọgbaanọkka obiro oyin, ọbọkha Ẹsau k'ibhokhọkhọri. Mẹ wọ, bẹ an-akpẹ-ẹ Jekọb. Wa Isaak on-ode cho arọbh attaan, k'ogbe kwa Rẹbẹka ọmaani va mba. 
\p  
\v 27 Mada va mba akk'abara, Ẹsau okwu ode ọgbaajijaa kw'ideden, obiro ode ọnọng kw'orukhi k'ọyaankpa. Yina, Jekọb kẹ ode ọnọng kw'odiri akpen, kw'om-okwora k'ẹttọhmma.  
\v 28 Wa Isaak kẹ ọdaakhi ẹgbatzen ochichi, ofona mẹ, Ẹsau kw'ode ọgbaajijaa ọdaakh-ẹ idik. Yina, wa Jekọb wọ ọdaakhi Rẹbẹka. 
\p  
\v 29 K'ogbe wani kw'iwa Jekọb ọm-ọwọhn ọchattọhk, Ẹsau ofona k'ẹgbaaji okhuna, ttara okwo f'ọkk'ẹ ọkhaama maa, for imọm-ẹ.  
\v 30 Mẹ wọ, oben Jekọb bi, “Kebh-m ẹbọhnga nduma ch'ekhor-okhor nchi ẹbhar-ẹbhar, kkeri ẹfa ẹkk'aam ẹha itzam-itzama!” (Mẹ wọ ofon bẹ am-ayer-ẹ Edom\f + \fr 25.30 \ft K'eHiburu, che nda Edom eyini ekhora. \f*). 
\p  
\v 31 Jekọb obhin-ẹ bi, “Kọ chi eden anang-m ededen chọ ch'ocheden-nwa.” 
\p  
\v 32 Ẹsau on-obhin-ẹ bi, “Bọng ejibha ch'ededen ẹnang-m o, kwa kaam nwobha ma, okwo ofhu-m o?” 
\p  
\v 33 Yina, Jekọb oben bi, “Kọ chi eden chekhi bi, anang-m ededen chọ ọnang.” Mẹ wọ, Ẹsau ọtzọkha ọnwọhngi kw'ọnangi Jekọb ededen chẹ. 
\p  
\v 34 Mando kwa Jekọb ọtzọk brẹd ọttara k'ẹbọhnga ch'achen-meni ọnang Ẹsau, Ẹsau ochi obiro ọttaakhi ẹbọhnga, obina ofona. 
\p Mando wọ kw'iwa Ẹsau oreng olukhi ededen chẹ ch'ocheden-nwa. 
\c 26  
\s1 Isaak ọmaana Abimẹlẹk 
\p  
\v 1 M'ogbe nwa, wa okwo f'ideden owobh m'irek nna akhiri okwo f'ideden f'iwa ochi eden owobha k'ogbe kw'Abraham. Wa Isaak obina ochina ka Gẹra ọtza okhebha Abimẹlẹk kw'ode ọvaarnọng kw'ẹkhọma cha Philistiya.  
\v 2 Mẹ wọ, Ọvaar Ibinọkpaabyi oyin Isaak abẹ, oben-ẹ bi, “Kọ k'Ijip kahakha o. Kọ ruk m'irek nna sa mben ọ bi, aruk.  
\v 3 Kọ ruk m'irek nna k'igbegbaa \it bi kọbh\it*, kaam Ibinọkpaabyi ńwobha ttar-ọ, ḿbiri ndọ-ọ. Kaam ńdọkha irerek nna biphyir ńnang kọ, ọmaana va pa va pọ. Ḿbiri nsi idik s'iwa nchekhi nnang atte kwọ, Abraham.  
\v 4 Kaam Ibinọkpaabyi ńsi va pa va pọ ahaabh macha ndodori s'ọrọngkpakpa, ḿbiri nnang bẹ irerek nna biphyir. Orenga ka nnam sa va pa va pọ, idibhon biphyir íkhaama ẹdaa,  
\v 5 okhuri da, Abraham ọhak eho ọnang-m, osi odik kpenamkpen mach ndọhn ẹ. Obiro ohok asana paam, ọmaana akpebhi paam, ndọhna saam ttara aphaangi paam.”  
\v 6 Mẹ wọ, Isaak owobha ka Gẹra. 
\p  
\v 7 Mada ajinọng p'obhon nwuma an-abọbh-ẹ odik okhuri kwanọng kwẹ, okhuri ojora, ọn-ọgbaak bẹ bi, “Kẹ ode ọgbaanọkka kwaam.” Ochibhi k'ettem bi, “Ajinọng p'obhon nwa afha afhu-m, okhuri ajibhada pa Rẹbẹka.” 
\p  
\v 8 Mada Isaak okk'orukha mẹ k'ogbe-bhirada, Abimẹlẹk kw'ode ọvaarnọng kw'ẹkhọma cha Philistiya orenga k'ọphapha-mma, ore da Isaak om-osi idadaakha ttara kwanọng kwẹ, Rẹbẹka.  
\v 9 Mando kw'Abimẹlẹk oyeri Isaak oben-ẹ bi, “K'odik-ọkka, kwanọng kwọ wọ manya e. Kọ areng mbọng afẹ agbaakh-m bi, kẹ ode ọgbaanọkka kwọ o?” 
\p Isaak obhin-ẹ bi, “Nchibhi bi, bẹ afha afhu-m ofhu, okhuri kẹ.” 
\p  
\v 10 Iwa Abimẹlẹk ọbọbh-ẹ bi, “Osi yan kw'asi odik-dema nwa? Idikha ira ọnọng wani k'ottem kw'ajinọng p'obhon nwa, okk'kwanọng kwọ abẹ oyima, ira akk'man oponga-pyibha anana k'eho.” 
\p  
\v 11 Mando kw'Abimẹlẹk ọnangi ọsana makhọra obhon bi, “Ọnọng manda wani kw'osi ojinọng nwa ttara kwanọng kwẹ ọttọhk m'obhon nwa, bẹ akhaambi, afhẹ-ẹ.” 
\p  
\v 12 Ma cho nwuma wani, Isaak ọyaabha owoni m'irerek nna, ọpha ekpo p'ọyaabh k'ọhaabh, okhuri da Ọvaar Ibinọkpaabyi ọdẹ-ẹ.  
\v 13 Wa okwu ọkhaama ẹkhakhaama. Ojibhada kwẹ ochina ororo ọbar maa, ọn-ọkhaama ikkọ k'ọhaabh.  
\v 14 Wa ọkhaam etzirakpo k'ọhaabh, ọmaana atzọhmnọng k'ọhaabh maa, ettem ẹmma anọng pa Philistiya etzima etzor-ẹ.  
\v 15 Mẹ wọ, nsipe s'iwa atzọhmnọng p'otte akk'atzuma, k'ogbe kw'otte Abraham owobh k'akpen, anọng pa Philistiya akpa sẹ biphyir ttara idọdọhbh. 
\p  
\v 16 Iwa Abimẹlẹk oben Isaak bi, “Bina, aji obhon kwaman, akk'ẹfa an-akhaama kpọng-kpọng ayọhnga man.”  
\v 17 Mẹ wọ, Isaak obina mẹ, ọtza oruk k'Ẹttẹri cha Gẹra.  
\v 18 Obiro otzum nsipe nnuma s'anọng pa Philistiya akk'akpa, k'ogbe kw'Abraham ọkk'ọpa. Okpe sẹ che p'iwa otte Abraham okk'sẹ ọtzam ọnanga. 
\p  
\v 19 Yina, mada atzọhmnọng p'Isaak, abira atzum esipe ọdọdọk k'ẹttẹri maa, bẹ ayin k'esipe ch'asi akkakka p'abhobh-obhobh,  
\v 20 akkeri-etzirakpo p'obhon kwa Gẹra, attẹwọr asi ẹtta ọmaana akkeri-nden p'Isaak, bẹ aben bi, “Asi mba ade paman!” Ofona mẹ, okpe ẹsipe nda Ẹsẹk\f + \fr 26.20 \ft K'eHiburu, Ẹsẹk oyini ẹkhọhr.\f*, okhuri da bẹ akkaan esipe nda ttara kẹ.  
\v 21 Bẹ abira atzum ẹsipe ẹdọdọk, yina, bẹ abira asi ẹkhọhr okhuri esipe nda. Isaak okpe chẹ Sitina\f + \fr 26.21 \ft K'eHiburu, Sitina oyini ikhakhaanga.\f*.  
\v 22 Obina mẹ, ọtza otzum esipe ẹdọdọk, ọnọng kw'osi ẹkhọhr kode. On-okpe chẹ Rehobot\f + \fr 26.22 \ft K'eHiburu Rehobot oyini ọphaangi.\f*, oben bi, “Ọvaar Ibinọkpaabyi okk'man ọphaangi ọnanga. M'irerek nna rọ sa mówobha mosi ikkọ.” 
\p  
\v 23 Isaak on-obina mẹ ochina k'obhon kwa Bẹrshẹba.  
\v 24 M'erungiwu nduma, Ọvaar Ibinọkpaabyi oyin-ẹ abẹ, oben-ẹ bi, “Kaam wọ nde Ibinọkpaabyi kw'atte Abraham. Oning-ọ ojor, kaam nwobh ma ttar-ọ, kaam ndọ-ọ, mbiri nsi va pa va pọ ahaabh, okhuri echekhi cha ngaam ttara ọtzọhmnọng kwaam, Abraham.” 
\p  
\v 25 Iwa Isaak osi ijafọhnibe mẹ, owobha mẹ okpobha Ọvaar Ibinọkpaabyi obiro ottima ikhira sẹ mẹ, atzọhmnọng pẹ abira atzum esipe mẹ. 
\p  
\v 26 M'ogbe nwa, Abimẹlẹk okk'Ahuzat kw'ọm-ọtzọhn-ẹ atzim ọmaana Phikol kw'ode odenho kw'agbong-nọng, otzima obina ka Gẹra okwu.  
\v 27 Isaak ọbọbh bẹ bi, “Ode yan kwa bọng am-aror-m, kw'iwa bọng attaang-m maa bọng akhubh-m k'obhon kwabọng o?” 
\p  
\v 28 Bẹ abhina bi, “Mọkk'ọra k'odik-ọkka bi, Ọvaar Ibinọkpaabyi owobh ttar-ọ. Ofona mẹ, moben bi, ọbaan bi, echekhi ewobha k'ottem kwa kọ ọmaana maman. Tte mosi echekhi ttar-ọ  
\v 29 bi, kọ man itzama kási, mach'iwa maman ọnọ-ọ itzama osi, yina, mojibh akpen ttar-ọ maa, mottọ-ọ ọbọhk abina k'odidiri. Manya, Ọvaar Ibinọkpaabyi ọkk'ọ ọda.” 
\p  
\v 30 Mẹ wọ, Isaak ohok bẹ ewobha ch'ọdadaami, bẹ achi, abira agwo.  
\v 31 K'ekpekpebha ch'ewu ekhobh mẹ, bẹ atzọkha ọngwọhngi ttara ayok. Mẹ wọ, Isaak ọtza orik bẹ k'eden, bẹ akpa nnam abhana k'odidiri. 
\p  
\v 32 M'ewu nduma, atzọhmnọng p'Isaak akwu agbaakh-ẹ odik kw'okhuri esipe cha bẹ akk'atzuma. Bẹ aben bi, “Mokk'asi ọra e”  
\v 33 Mẹ wọ, Isaak oyeri esipe nda Shiba\f + \fr 26.33 \ft K'eHiburu, Shiba oyini ọnwọhngi, azenamfa.\f*, ttẹwọr mẹ ewu nduma obhon nwuma on-okpena Beershẹba\f + \fr 26.33 \ft K'eHiburu, Bẹrshẹba ofha oyin esipe ch'ọnwọhngi, ayongi mẹ, esipe ch'azenamfa.\f*. 
\p  
\v 34 Mada Ẹsau on-ode cho arọbh afa, ọtzọk kwanọng kw'okpen Judit kw'ode ominanwa kwa Beeri kw'ode ojinọng kw'ofon Het, ọmaana Basemat kw'ode ominanwa kw'Ẹlọn kw'obiro ofona Het.  
\v 35 Panọng mba afa, asi akpen akhọhn Isaak ọmaana Rẹbẹka. 
\c 27  
\s1 Isaak osi Jekọb ittabọhng 
\p  
\v 1 K'ogbe kw'iwa Isaak ọkk'ọn-ọtzama, owonikpa dọk kore, wa oyeri ocheden-nwa kwẹ, Ẹsau, oben-ẹ bi, “Nnwa kwaam.” 
\p Ẹsau obhina bi, “Itta kwaam, kkeri kaam ma e.” 
\p  
\v 2 Isaak oben bi, “Kaam nnande ọtzaminọng, ebowu chaam kimbiri nnonga.  
\v 3 Mẹ wọ, kọ tzọkha ẹgbaajikpo pyọ py'ede ọkhọhn-pa kwọ ọmaana oyuk kwọ, atzima ayin ẹgbaaji, atza afhu nden achen-m.  
\v 4 Si ọchattọhk f'ọdaam-ọdaam f'ọdaakh-m, achen-m nchi, ifha nsọ-ọ ittabọhng yina ḿpe.” 
\p  
\v 5 Wa Rẹbẹka om-oyonga itzọhng ọbhaanga idik s'Isaak ọm-ọgbaak nnwa kwẹ, Ẹsau. Mada Ẹsau okk'ẹgbaaji oyina bi ọtza ofhu nden otzima okhuna,  
\v 6 Rẹbẹka ọbhakhi kẹ ọtza oben nnwa kwẹ Jekọb bi, “Kker e, mfhu mmaang da atte om-oben agbaanakka Ẹsau mẹ bi,  
\v 7 ‘Rọhng atza afhu nden, atzima asi ọchattọhk f'ọdaam-ọdaam anang-m nchi, ifha nsọ-ọ ittabọhng k'itzitzikha s'Ọvaar Ibinọkpaabyi, yina ḿpe.’  
\v 8 Nnwa kwaam, tzọkha ogbe ayong-m itzọhng, asi odik kwa mgbaakh-ọ.  
\v 9 Rọhng kẹ da avu awobh, atzekha avu adem akkakka manda afa p'ajibhi for, ifha ndima nsi ọchattọhk f'ọdaam-ọdaam, nnang atte mach'ọm-ọdaakh-ẹ.  
\v 10 Kọ tzọkha fẹ chena atte ochi, ifha ọsọ-ọ ittabọhng yina ópe.” 
\p  
\v 11 Jekọb on-oben ọkka bi, “Ọgbaanọkka kwaam Ẹsau ọkhaam iphyubha s'ihaabh-ọhaabh ka for, yina, kaam nkwọhng ẹkpakpa.  
\v 12 Idikha otte kwaam ọn-ọttọhm-m ki? Okher mana kaam mbọhr-ẹ ọbọhra, kw'ọsẹ-ẹ ọn-ọnang-m ẹmma ottu kw'osi-m ittabọhng.” 
\p  
\v 13 Ọkka on-oben-ẹ bi, “Nnwa kwaam, tte ẹmma ch'atte ọnang-ọ ẹbọkha kaam e. Si macha mben-ọ, rọhng, atza atzọkha avu pa ndọhm-ọ, achen-m.” 
\p  
\v 14 Mẹ wọ e, Jekọb ofona ọtza tzọkha avu ochena ọkka. Ọkka otzima bẹ osi ọchattọhk f'ọdaam-ọdaam macha fẹ ọm-ọdaak otte.  
\v 15 Rẹbẹka ọtzọkha nnya nkkakka s'ocheden-nwa kwẹ kw'ode Ẹsau, ọfọra Jekọb kw'ode okponga-nnam-nwa kwẹ.  
\v 16 On-obiro ọtzọkha ndenkpa s'avu k'adem-k'adem sa ngaam ophyubha obubh-ẹ ka mbọhk, ọmaana k'obe vani f'ọkwọhng-ọkwọhnga f'ẹdọhngi chẹ.  
\v 17 Mẹ wọ, ọn-ọtzọkha ọchattọhk daama-ndaam mvuma, ọttara ka brẹd kw'ọkk'ọsa, ọnang nnwa kwẹ Jekọb. 
\p  
\v 18 Mando kwa Jekọb ofon ochina k'otte, oben bi, “Itta kwaam.” 
\p Otte obhina bi, “O o! Nnwa kwaam, kọ anyi wọ o?” 
\p  
\v 19 Jekọb obhin-ẹ bi, “Kaam ocheden-nwa kwọ Ẹsau wọ e, nkk'nsa mach'aben-m bi, nsi e. Tzotzokhaan, bina wobha ẹwọr achi ọchattọhk, ifha asi-m ittabọhng, sọ e.” 
\p  
\v 20 Isaak ọbọbh nnwa bi, “Nnwa kwaam, areng yan are etzen ẹbhar-ẹbhar mando?” 
\p Jekọb obhina bi “Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwọ, kẹ wọ ọnang-m owujibha e.” 
\p  
\v 21 Mẹ wọ, Isaak oben Jekọb bi, “Rọkhi atzor-m ka for ifha nttọhm-ọ, ifha mbiri nnonga k'odik-ọkka s'ode kọ nnwa kwaam Ẹsau wọ.” 
\p  
\v 22 Mẹ wọ, Jekọb ọrọkhi otzor otte Isaak ka for, kw'ọttọm-ẹ, oben bi, “K'ọwọhng akheri Jekọb, yina, mbọhk sọ nde macha mbọhk s'Ẹsau.”  
\v 23 Wa Isaak, Jekọb kotzini, okhuri bi, wa mbọhk sẹ nde ophyubh-ophyubha macha s'Ẹsau. Ofona mẹ, Isaak ọsẹ-ẹ ittabọhng.  
\v 24 On-obiro ọbọbh-ẹ bi, “Kọ nnwa kwaam Ẹsau wọ, k'odik-ọkka o?” 
\p Jekọb obhin-ẹ bi, “Itta, kaam wọ e.” 
\p  
\v 25 Mẹ wọ e, on-oben bi, “Nnwa kwaam, chen-m ọchattọhk fọ nchi, ifha nsọ-ọ ittabọhng saam.” 
\p Jekọb ochen-ẹ ọchattọhk ochi, obiro ọnang-ẹ atzuk ogwo. 
\p  
\v 26 Mando kw'Isaak oben-ẹ bi, “Nnwa kwaam, kwu baakh-m.” 
\p  
\v 27 Jekọb ọrọkhi otzor otte ka for, ọbaakh-ẹ. Mada Isaak ọbhaang eruk ch'ẹnya ch'ọfọr ka for, on-okhera bi, Ẹsau wọ, ọsẹ-ẹ ittabọhng, oben bi, 
\q1 “K'odik ọkkakka eruk cha nnwa kwaam 
\q2 ede mach'eruk ch'owoni 
\q2 kw'Ọvaar Ibinọkpaabyi ọkk'ọda. 
\q1  
\v 28 Tte Ibinọkpaabyi osi ẹrọng etzebh, 
\q2 obiro osi irek s'ayaabh ekpo ijibh, 
\q2 tte kẹ ọnang-ọ ọchattọhk ọmaana atzuk k'ọhaabh. 
\q1  
\v 29 Tte idibhon biphyir isi ọtzọhm inang-ọ, 
\q2 anọng biphyir ahakha nho anang-ọ. 
\q1 Kọ wọ áde ọvaarnọng kwa vọkka pọ, 
\q2 tte echimma chọ ẹhakha eho ẹnang-ọ. 
\q1 Tte ẹmma ẹbhakhi ẹbọkha anọng p'anang-ọ ẹmma, 
\q2 tte ẹdaa ebire éwobha ẹnang anọng p'adọ-ọ.” 
\p  
\v 30 Mada Isaak okk'Jekọb ittabọhng ọsa okyera, Jekọb ofona. Obin k'otte k'itzitzakha \it bi kpaarr\it*, ọgbaanọkka Ẹsau okhuna ẹgbaaji.  
\v 31 Wa Ẹsau obiro osi ọchattọhk f'ọdaam-ọdaam ọtzọkha ochena otte. Mẹ wọ, oben-ẹ bi, “Itta, tzotzokhaan bina achi ọttọhk fa nnwa kwọ, ifha asi-m ittabọhng sọ.” 
\p  
\v 32 Otte Isaak ọbọbh-ẹ bi, “Kọ anyi wọ?” 
\p On-obhina bi, “Kaam nnwa kwọ Ẹsau kw'ode ocheden-nwa kwọ wọ e.” 
\p  
\v 33 Isaak ọfhọni ka for \it bi tzikhi-tzikhi\it*, oben bi, “Anyi wọ ọn-ọtza ofhu nden otzima osi ọchattọhk ọnang-m o? Nchi fẹ, yina an-adimi ma e, nkk'ẹ ittabọhng mbiri nsa e. K'odik-ọkka, kẹ ójibh-ẹ ojibh e!” 
\p  
\v 34 Mada Ẹsau ọbhaang idik s'otte ọgbaakhi, otzini adimmọng obhom k'idọdọkhi, oben otte kwẹ bi, “Itta kwaam, si-m ittabọhng, biri si kaam ittabọhng!” 
\p  
\v 35 Yina, otte obhin-ẹ bi, “Agbaanakka ọkk'ọkwa, ọkwu ọbọhr-m, nsẹ-ẹ ittabọhng sọ e.” 
\p  
\v 36 Ẹsau on-oben bi, “Bẹ atzor-otzor akpẹ-ẹ Jekọb. Igbe ifa rọ ma s'okk'aam chen ọsa. K'ochedengbe, ọtzọk ededen chaam ch'ocheden-nwa. Manya, kẹ okk'ittabọhng saam obiro ọtzọkha.” Mẹ wọ ofon, Ẹsau ọn-ọbọbh otte bi, “Ode bi, kọ kaam ittabọhng manda rani karikh o?” 
\p  
\v 37 Isaak obhina Ẹsau bi, “Kaam nkk'ẹ ittabọhng nsa bi, ode oho kw'idibhon biphyir, ọmaana bi, anọng pẹ biphyir ade atzọhmnọng anang-ẹ. Nkk'ẹ mbiri nda ọmaana ọchattọhk k'ọhaabh ttara atzuk. Nnwa kwaam, bọng odik ọdọdọk kwa kaam mbiri ifha nsi nnang-ọ?” 
\p  
\v 38 Ẹsau ọbọbh otte bi, “Itta kwaam, ode bi kọ akhaam ittabọhng rani sẹ-sẹ o? Itta kwaam, biri si kaam ittabọhng!” Ofona mẹ, Ẹsau obhom adimmọng k'ẹrọng. 
\p  
\v 39 Isaak, obhin-ẹ bi, 
\q1 “Kker e, oruk kwọ 
\q2 k'irerek s'im-ijibh ekpo kówobha, 
\q2 ówobha kẹ da ẹrọng en-emetzebh. 
\q1  
\v 40 Kọ áruk agbong-kpen, 
\q2 ábira asi ọtzọhm anang agbaanakka. 
\q1 Yina, atzim ọmmakkakkari aruk akpen, 
\q2 árọbha ọyak kwẹ, 
\q2 k'ẹdọhngi chọ ọrọbha.” 
\s1 Jekọb ọrọbh otzor Laban 
\p  
\v 41 Ẹsau ọdọkhi ettem, okhuri ittabọhng s'otte okk'Jekọb ọsa, on-oben for sẹ bi, “Iwu sa nkwu-osisi s'obo kw'otte kwaam im-ifor e. Ọkk'ọpa, mosẹ-ẹ obo, kaam ḿfhu ọgbaanọkka kwaam Jekọb.” 
\p  
\v 42 Mada bẹ agbaakhi Rẹbẹka odik kwa nnwa kwẹ Ẹsau ọm-ọkham okhuri Jekọb, oyeri nnwa kwẹ Jekọb okwu, oben-ẹ bi, “Kker e, agbaanakka Ẹsau ọkhami bi ọfhọ-ọ, otzima odini for sẹ nttem.  
\v 43 Mẹ wọ, nnwa kwaam, ogbe kàkhibhi, si macha mgbaakh-ọ. Bina do for ẹbhar-ẹbhar arọbh achina k'ọgbaanọkka kwaam Laban, kw'orukhi ka Haran.  
\v 44 Kọ wobha mẹ ttar-ẹ maa, idọdọkhi s'agbaanakka iha.  
\v 45 Ikhina agbaanakka okk'odik kwa sẹ ọraama, idọdọkhi ibiri ihẹ-ẹ k'ettem, mẹ kwa kaam ńdọhm ẹkkaabha nnang-ọ akhuna. Okhuri yan kwa bọng anọng afa an-adim-m k'ewu dani o?” 
\p  
\v 46 Mẹ wọ e, Rẹbẹka ọgbaak Isaak bi, “Akpen akk'aam abenga, okhuri panọng mba p'afon Het. Idikha Jekọb obiro ọtza ọtzọkha kwanọng k'anọng pa Het, yan kw'akpen paam án-ade o?” 
\c 28  
\p  
\v 1 Mẹ wọ, Isaak oyeri Jekọb ọsẹ-ẹ ittabọhng, ọtzọr-ẹ itzọhng, oben-ẹ bi, “Kwanọng kpenamkpen kw'ofon m'ẹkhọma cha Kenaan kàtzọkha o.  
\v 2 Kọ rọhng ka Padan-Aram atza atzokha kwanọng k'obhon k'echimma cha Bẹtuẹl, kw'ode otte kw'akka, k'ottem kw'aminava p'agbaanakka kw'akka, kw'ode Laban.  
\v 3 Tte Ibinọkpaabyi kw'Ẹfa biphyir, ọdọ-ọ ttara va k'ọhaabh, obiro osi va pa va pọ bẹ ahaabh maa, bẹ an-asi ngọma sa nhaabh-ọhaabh.  
\v 4 Tte kẹ ọnang kọ ọmaana va pa va pọ ẹdaa ch'iwa ọnangi Abraham, ifha kọ afha atzọkha irerek nna s'arukhi mẹ mach'okhekhennọng, irerek nna s'iwa Ibinọkpaabyi ọnangi Abraham.”  
\v 5 Mẹ wọ, Isaak ọtzọhm Jekọb, ochina ka Padan-Aram, okhebha Laban kw'ode nnwa kwa Bẹtuẹl kw'ofon Aram, kw'obiro ode ọgbaanọkka kwa Rẹbẹka, kw'ode ọkka kwa Jekọb ọmaana Ẹsau. 
\s1 Ẹsau ọtzọk kwanọng ọdọdọk 
\p  
\v 6 Mada Ẹsau orong bi, otte kwabẹ Isaak, okk'Jekọb ittabọhng ọsa, obiro ọtzọhm-ẹ bi, ọrọhng ka Padan-Aram ọtza ọtzọkha kwanọng kẹ, obiro ọtzọr-ẹ itzọhng bi, “Kwanọng kw'ofon Kenaan kàtzọkha o.”  
\v 7 Obiro oronga bi, Jekọb okk'atzim p'otte ọmaana p'ọkka ọbhaanga, ochina ka Padan-Aram.  
\v 8 Wa Ẹsau on-otzin bi, panọng pa Kenaan bẹ otte Isaak kadaakhi.  
\v 9 Mando kw'Ẹsau obin ochina k'Ishimayẹl, ọtza ọtzọkha kwanọng ọdọdọk kw'okpen Mahalat, kw'ode ọgbaanọkka kw'ikwanọng kwa Nẹbayọt, kw'obiro ode nnwa kw'Ishimayẹl, kw'ode nnwa kw'Abraham. 
\s1 Jekọb ọttaar idachen ka Bẹtẹl 
\p  
\v 10 Mada Jekọb obin ka Bẹrshẹba, ochina ka Haran.  
\v 11 Okwu opyiri k'ibe rani, ọtzọkha ọtza oji, oyima ọnana eho mẹ ọttaabha, okhuri da erungi ẹkk'ẹpya.  
\v 12 Wa ọttaara idachen s'ore ọgbaakha kw'ottim ttẹwọr k'irerek, maa ebir-ebir ọttọhmi k'ọrọngkpakpa, obiro ore da arenga-eden p'Ibinọkpaabyi am-arenga m'ọgbaakha nwuma avura, abira am-arenga ahakha.  
\v 13 Obiro ore da Ọvaar Ibinọkpaabyi obe k'ebir-ebir kw'ọgbaakha nwa oben bi, “Kaam wọ nde Ibinọkpaabyi kw'abatte, Abraham ttara Isaak akpobh. Kaam ńnang kọ ọmaana va pa va pọ irerek nnuma s'ayim mẹ.  
\v 14 Va pa va pọ áhaabh akher oyeyeng kw'irerek, bẹ abira anyaami k'ibe kpenamkpen, kẹ da ewuchen em-eyin, ttara kẹ da ewuchen em-edimi, ọmaana k'ebira-ebira ttara k'ẹrakha-ẹrakha. Orenga ma kọ ttara va pa va pọ, ọyagbin biphyir, ọkhaama ẹdaa.  
\v 15 Kaam ńwobha ttar-ọ, mbiri ḿbaabh-ọ, k'ibe kpenamkpen s'áchina, ḿbiri ndim-ọ mkpa nnam m'irek nna. Kaam kọ ọbọhk kintte maa, nsi ẹjaakhi m'odik nwa kwa nkk'nchekhi nnang-ọ.” 
\p  
\v 16 Mada Jekọb ọphyọbh k'ọda, oben bi, “K'odik-ọkkakka, Ọvaar Ibinọkpaabyi owobh m'ibe nna, yina, kaam ira kinnong.”  
\v 17 Wa opoma ọsẹ-ẹ, on-oben bi, “Bọng ibe rọ ijor manda! Ibe nna idọdọk kifha ide iyongi ọhọhm kw'Ibinọkpaabyi; ma wọ ode ẹbaakhamma ch'ọvaarbhon kw'Ibinọkpaabyi.” 
\p  
\v 18 K'ekpekpebha ch'ewu ehobh, Jekọb otzini ọtza nwuma kw'ira oyim ọnana eho, ọfhẹ-ẹ iduduma k'irerek, ọtzọkha ana obyengi m'ọtza nwuma.  
\v 19 Kaambi ode bi iwa obhon nwa ochi eden okpena Luz, wa Jekọb on-oyer-ẹ Bẹtẹl. 
\p  
\v 20 Iwa Jekọb osi echekhi k'itzitzikha s'Ọvaar Ibinọkpaabyi, oben bi, “M'orenga nwa kwa nda ma, idikha Ibinọkpaabyi owobh ttar-m, okker-m, ọnang-m ọchattọhk fa nchi, ọmaana ọbara fa mfọra,  
\v 21 maa ikhina ngwuna k'otte kwaam k'ọhọhm k'odidiri, kẹ Ọvaar Ibinọkpaabyi wọ óde Ibinọkpaabyi kwa kaam ḿkpobha.  
\v 22 Ọtza nwa kwa nkk'mfha mach'ekpọmmachi, óde ọhọhm kw'Ibinọkpaabyi. Ọttọhk kpenamkpen f'anang-m, kaam mbiri ńkkema fẹ k'obe jobh, ńdọkha rani nnang-ọ.” 
\c 29  
\s1 Jekọb opyiri ka Padan-Aram 
\p  
\v 1 Wa Jekọb ochina ororo k'orenga kwẹ, matzẹmaa opyiri k'anọng p'arukhi k'okhubha kw'ewuchen em-eyin.  
\v 2 Ọtza opyiri m'ibe nnuma, ore esipe ch'ewobh mẹ, cha bẹ atzim ẹtzakpa ch'ẹbari ẹkpa abubha, obiro ore ngaan nttaan s'etzirakpo, py'eyim m'esipe nduma ọkhaan-ọkhaan, cha bẹ akhaabh asi anang bẹ. 
\p  
\v 3 K'ogbe kpenamkpen kw'akker-arukhimaan an-anang etzirakpo pyabẹ asi, bẹ am-abingi ẹtzakpa nduma ch'ebubh m'ẹmma ch'esipe ebir-ebir, ahok ọkhaan-ọkhaan, akhaabha asi anang arukhimaan, yina bẹ an-abira abingi chẹ abubha. 
\p  
\v 4 Mẹ wọ, Jekọb ọbọbh akkeri-arukhimaan mba bi, “Abayi paam, bọbọng afon man o?” 
\p Bẹ abhina bi, “Maman ofon ka Haran e.” 
\p  
\v 5 Obiro ọbọbh bẹ bi, “Bọng arong ojinọng kwa bẹ ayeri Laban ma, kwa Nahọr obhon o?” 
\p Bẹ abhin-ẹ bi, “O o, morong-ẹ ma e.” 
\p  
\v 6 Mẹ wọ, Jekọb ọn-ọbọbh bẹ bi, “For igaang-ẹ khẹ?” 
\p Bẹ abhin-ẹ bi, “K'odik ọkkakka, for igaang-ẹ khẹ e. Nnwa kwẹ kw'ikwanọng kw'okpen Rachẹl, kẹ wọ om-otzima arukhimaan okwu kana.” 
\p  
\v 7 Jekọb oben bi, “Kker e, ekpekhira etzim ẹkhọhm-ọkhọhm; ogbe otzim obenga kw'atzobha arukhimaan mba k'ibe rani, anang bẹ asi, ifha bọng atzima bẹ atza anang ọchattọhk.” 
\p  
\v 8 Iwa bẹ abhina bi, “Mma e, man kofha osi e, mọkhaambi otzobha arukhimaan biphyir k'ibe rani, yina mon-obingi ẹtzakpa ch'ebubh m'ẹmma ch'esipe. Mosisi mando, man biphyir mọ́nang arukhimaan paman asi e.” 
\p  
\v 9 Mada Jekọb, otzim ọm-ọgbaak atzim ttara akkeri-arukhimaan mba, Rachẹl otzima arukhimaan p'otte opyiri m'esipe nda.  
\v 10 Mada Jekọb ore Rachẹl kw'ode nnwa kwa Laban, kw'ode ọgbaanọkka kw'ọkka kwa Jekọb ttara arukhimaan pa Laban. Jekọb, ọrọbh otzor Rachẹl, ọtza obingi ẹtzakpa ch'ebubh m'ẹmma ch'esipe, ọkhaabha asi ọnang arukhimaan p'ọgbaanọkka kw'ọkka.  
\v 11 Mada Jekọb okk'mando ọsa, ọtza ọbaakha Rachẹl, obiro obhom ẹmọng k'ẹrọng.  
\v 12 Obiro ọgbaak Rachẹl bi, kẹ ode ochimmanọng kw'otte, Laban, obiro ode nnwa kw'ijinọng kwa Rẹbẹka. Mẹ wọ, Rachẹl ọrọbh ọtza ọgbaak otte. 
\p  
\v 13 Mada Laban ọbhaang idik nna s'ikhuri Jekọb kw'ode nnwa kw'ọgbaanọkka kwẹ, obina m'ẹbhar-ẹbhar otza okhebh-ẹ kẹ da owobh. Mada bẹ are ayok, Laban ọbaakh-ẹ, obiro otzim-ẹ ochina k'ọhọhm kwẹ. K'ọhọhm wọ kwa Jekọb ọn-ọgbaakhi Laban idik biphyir s'ikk'itta.  
\v 14 Mẹ wọ, Laban obhin-ẹ bi, “K'odik ọkkakka, kọ ade ochimmanọng kwaam e, mode izi rani e.” 
\s1 Jekọb ọtzọk Lea ọmaana Rachẹl k'ọbada 
\p Mẹ wọ, mada Jekọb okk'ophe wani owobha k'ọhọhm kwa Laban,  
\v 15 Laban on-oben-ẹ bi, “Kaambi ode bi, kaam ọmaana kọ mode anọng bani, mando rang osi, kọ an-asi ọtzọhm anang-m k'idukhi. Kọ gbaakh-m agbukha p'ọtzọhm fọ ope.” 
\p  
\v 16 Wa Laban ọkhaam va p'ipanọng afa, ocheden-nwa okpen Lea, ottong afa, okpena Rachẹl.  
\v 17 Wa Lea ọkhaam adadaakha-chen, yina, Rachẹl wọ ode ominnanwa kw'ojibhi for obiro ojibh ikkekkeri.  
\v 18 Wa Jekọb ọkhaam idadaakha ttara Rachẹl, oben bi, “Kaam ńsi ọtzọhm nnang-ọ ka cho azenamfa, k'eho cha Rachẹl kw'ode nnwa kwọ kw'ikwanọng kw'ikhakhari.” 
\p  
\v 19 Mẹ wọ, Laban oben bi, “Ode odik kw'ojibh-ojibh bi, ndọkh-ẹ nnang kọ, ọyọhnga bi, ndọkh-ẹ nnang ọnọng ọdọdọk. Kọ wobha ma ttar-m.”  
\v 20 Wa Jekọb osi ọtzọhm ka cho azenamfa, k'eho cha Rachẹl. Yina, okhuri idadaakha sa Jekọb ọkhaam ttara Rachẹl, wa cho azenamfa an-akher-ẹ awuwa. 
\p  
\v 21 Iwa Jekọb okwu oben Laban bi, “Cho p'ọtzọhm faam akk'attonga, kọ na nnang-m kwanọng kwaam, ifha nyim-ẹ abẹ.” 
\p  
\v 22 Laban obher anọng p'ibe nnuma biphyir atzobha, bẹ asi ọdadaami kw'ọbada.  
\v 23 Yina, okwu opyiri m'ẹchọhkha, Laban ọn-ọtzọkha nnwa kwẹ, Lea, ọnang Jekọb. Jekọb oyim-ẹ abẹ.  
\v 24 Wa Laban ọtzọkha ọtzọhmnọng kwẹ Zilpa, ọnang nnwa kwẹ Lea bi, orukh-ẹ abẹ. 
\p  
\v 25 Mada ewu en-ehobh, Jekọb on-ore bi, Lea wọ oyim kẹ. Ofona mẹ, Jekọb ọbọbh Laban bi, “Itta, ode yan kw'asi-m manda o? Kaam nsi ọtzọhm k'eho cha Rachẹl, mando arang o? Kọ an-asi yan abọhr-m?” 
\p  
\v 26 Mẹ wọ, Laban obhin-ẹ bi, “K'ẹmmaana cha man, kọbaan bi, otte kw'ọnọng ọtzọkha nnwa kwẹ kw'ikhakhari, ọnang k'ọbada, k'ogbe kw'ocheden oni odim otzim ọba.  
\v 27 Kọ kyera ẹphyawu dani chọ ch'ọdadaami kw'ọbada, akk'akyera, mobiro ọ́tzọkha oyok kw'ikhakhari ọnang-ọ. Yina, kọ abira asi ọtzọhm ka cho azenamfa adọdọkh e.” 
\p  
\v 28 Wa Jekọb okhera ttar-ẹ. Mada okk'ẹphyawu dani ch'ọdadaami okyera ttara Lea, Laban obiro ọtzọkha nnwa kwẹ Rachẹl ọnang-ẹ k'ọbada.  
\v 29 Wa Laban ọtzọkha ọtzọhmnọng kwẹ kw'ikwanọng, kw'okpen Bilha, ọnang Rachẹl bi, orukh-ẹ abẹ.  
\v 30 Jekọb obiro oyima Rachẹl abẹ. Wa Rachẹl ọdaakh-ẹ ọtzam ọyọhnga Lea. Mẹ wọ, wa osi ọtzọhm ka cho azenamfa adọdọk ọnang Laban. 
\s1 Odem kwa va pa Jekọb 
\p  
\v 31 Mada iwa Ọvaar Ibinọkpaabyi ore bi, Lea Jekọb idik kọdaakhi, on-odo Lea ttara ọmaan. Yina, osi Rachẹl ọkpaana.  
\v 32 Iwa Lea okwu otzima ibhọr, ọmaan nnwa kw'ijinọng, ọkpẹ-ẹ Reubẹn, oben bi, “Ofon da Ọvaar Ibinọkpaabyi ọkk'ọmmamma kwaam ọra. K'odik-ọkka, yina wọ kwa kaam nna ńdaak odim kwaam e.” 
\p  
\v 33 Lea obiro otzima ibhọr, ọmaan nnwa kw'ijinọng, ọkpẹ-ẹ Simeọn, on-oben bi, “Okhuri da, Ọvaar Ibinọkpaabyi ọbhaang bi, kaam odim kwaam kindaakhi, okk'kaam nnwa obiro ọnanga.” Mẹ wọ, Lea okpe nnwa kwẹ, Simeọn. 
\p  
\v 34 Lea obiro otzima ibhọr ọmaan nnwa kw'ijinọng oben bi, “Kaam nkk'odim kwaam va p'ijinọng attaan mmaana, yina wọ kwa kaam nna ndaak odim kwaam.” Mẹ wọ, ọkpẹ-ẹ Lẹvi. 
\p  
\v 35 Lea otzima ibhọr ottong igbe inna ọmaan ojinọng, oben bi, “M'ogbe nwa, kaam ńnang Ọvaar Ibinọkpaabyi ẹtzọhnga.” Mẹ wọ, ọn-ọkpẹ-ẹ Juda. Mada okk'nnwa kw'ottong anna ọmaana, ọn-ọkwọbha ọmaan. 
\c 30  
\p  
\v 1 Mada Rachẹl ore bi, ibhọr igaang-ẹ ọgaangi, ọn-ọkhaama ottem-mamma otzima otzor ọgbaanọkka Lea. Mẹ wọ, on-oben Jekọb bi, “Nang-m va oni mando ode ḿpe-ope.” 
\p  
\v 2 Jekọb ọdọkhi ettem ttara Rachẹl, ọbọbh bi, “Kaam wọ nde Ibinọkpaabyi, kw'ọkpọ-ọ bi, aningi va amaan o?” 
\p  
\v 3 Rachẹl oben bi, “Ode mando, kkeri Bilha kw'ode ọtzọhmnọng kwaam mẹ. Kọ tzọkh-ẹ ayima abẹ ifha ọmaan va ọnang-m, mbiri nnenga ma ndaak sẹ, nsi echimma chaam.” 
\p  
\v 4 Mando kw'ọtzọk ọtzọhmnọng kwẹ Bilha, ọnang Jekọb oyim-ẹ abẹ.  
\v 5 Bilha okwu otzima ibhọr ọmaan nnwa kw'ijinọng ọnang Jekọb.  
\v 6 Rachẹl okpe nnwa nwa Dan, oben bi, “Ibinọkpaabyi okk'aponga paam ọba, obiro ọbhaanga njọhm saam, ọnang-m nnwa kw'ijinọng.” 
\p  
\v 7 Iwa Bilha kw'ode ọtzọhmnọng kwa Rachẹl obiro otzima ibhọr, ọmaan nnwa kw'ijinọng kw'ottong afa ọnang Jekọb.  
\v 8 Rachẹl oben bi, “Kaam nkk'ẹfa ndima nsi erima ttara ọgbaanọkka kwaam Lea, mbiri ngem-ẹ.” Mẹ wọ, okpe nnwa nwa Naphtali. 
\p  
\v 9 Mada Lea ore bi, ọkk'ọmaan ọkwọbha, ọn-ọtzọkha ọtzọhmnọng kwẹ Zilpa ọnang Jekọb macha kwanọng kwẹ.  
\v 10 Zilpa ọmaan nnwa kw'ijinọng ọnang Jekọb.  
\v 11 Mẹ wọ, Lea oben bi, “Ma wọ ode ojibhaada ọkkakka.” Wa okpe nnwa nwa Gad. 
\p  
\v 12 Wa Zilpa kw'ode ọtzọhmnọng kwa Lea, obiro ọmaan nnwa kw'ijinọng kw'ottong afa ọnang Jekọb.  
\v 13 Mẹ wọ e, Lea okpe nnwa nwa Ashẹr, oben bi, “Ettem ẹdaam-m o, da ayokhi-panọng an-ayer-m, idadaama.” 
\p  
\v 14 K'ọphagbe kw'awit, Reubẹn oyin k'iwoni otza ore asitzen-kwongi\f + \fr 30.14 \ft Ositzen-kwongi ode okwongitzọng kw'om-osi kwanọng kw'ọkpaan-ọkpaana otzima ibhọr.\f* otzima ochena ọkka kwẹ, Lea. Mẹ wọ, Rachẹl oben Lea bi, “Tzotzokhaan kebh-m akwọngitzọhng bani pa nnwa kwọ, otzim okhuna.”  
\v 15 Yina, Lea ọbọbh Rachẹl bi, “Kw'oyini bi, odim kwaam kw'atzọk kọ kobeng? Kw'bira akwu bi, akwu atzọkha asitzen-kwongi pa nnwa kwaam o?” 
\p Rachẹl oben bi, “Ojibhi kẹ, ode mando, kọ tzọkha eyimawu cha mayina, anang-m asitzen-kwongi pa nnwa kwọ otzim okhuna.” 
\p  
\v 16 Mada Jekọb okhun eyina k'ẹchọhkha, Lea ọtza okhebh-ẹ, ọgbaakh-ẹ bi, “Mayina on-ode eyimawu chaam e, okhuri bi, kaam nkk'asitzen-kwongi pa nnwa kwaam ndima ndebh chẹ. Mẹ wọ, Jekọb oyima ọmaana Lea m'erungiwu nduma.” 
\p  
\v 17 Ibinọkpaabyi ọbhaanga njọhm sa Lea, otzima ibhọr, ọmaan nnwa kw'ijinọng kw'ottong azen ọnang Jekọb.  
\v 18 Lea oben bi, “Ibinọkpaabyi ọkk'aam ochora, okhuri da nnangi odim kwaam ọtzọhmnọng kwaam bi, oyima abẹ.” Wa okpe nnwa nwa Isaaka. 
\p  
\v 19 Lea obiro otzima ibhọr ọmaan nnwa kw'ijinọng kw'ottong azadani ọnang Jekọb.  
\v 20 Mẹ wọ, Lea oben bi, “Ibinọkpaabyi ọkk'aam ẹnanga ch'ideden obiro ọnanga, yina kwa kaam nna mbar odim kwaam odik, okhuri bi, nkk'ẹ va p'ijinọng azadani mmaana.” Mẹ wọ, okpe nnwa nwa Zẹbulun. 
\p  
\v 21 Ayongi mẹ, Lea obiro ọmaan nnwa kw'ikwanọng, ọkpẹ-ẹ Daina.  
\v 22 Mẹ wọ, Ibinọkpaabyi okwu ojima Rachẹl ọbhaanga njọhm sẹ, okwung-ẹ ẹbhọr.  
\v 23 Rachẹl okwu otzima ibhọr ọmaan nnwa kw'ijinọng, oben bi, “Ibinọkpaabyi ọkk'aam ka mgbar ọrọbha.”  
\v 24 Okpe nnwa nwa Josẹph, oben bi, “Tte Ọvaar Ibinọkpaabyi obiro ọttar-m nnwa kw'ijinọng ọdọdọk.” 
\s1 Ọhaabh f'etzirakpo pya Jekọb 
\p  
\v 25 K'ogbe kwa Rachẹl okk'Josẹph ọmaana, Jekọb oben Laban bi, “Tte-m ọbọhk mmaana ka man k'obhon.  
\v 26 Kọ nang-m panọng paam ttara va paam pa nkk'ọtzọhm nsa nnang-ọ, ndima mfona. Kọ arong ọtzọhm-dema fa kaam nkk'nsa nnang-ọ kẹ.” 
\p  
\v 27 Yina, Laban oben-ẹ bi, “Idikha kaam nkk'ọphyaam ndọkha k'itzitzikha sọ, tzọtzọkhaan kọ kàfona, kkeri kaam nkk'ose mmari, nnonga bi, Ọvaar Ibinọkpaabyi ọkk'aam ọda okhuri kọ.”  
\v 28 Laban obiro ọttara bi, “Kọ gbaak-m ekkema ch'ọtzọhm fọ, kkeri kaam ńnang-ọnang.” 
\p  
\v 29 Jekọb obhin-ẹ bi, “Kọ arong ọtzọhm fa nkk'nsa nnang-ọ kẹ, abira aronga eden cha nneng nkkeri etzirakpo pyọ, ejibh ẹnang-ọ.  
\v 30 Yina iwa kaam nkwu, wa etzirakpo pyọ kẹhaabhi macha pyẹ ẹn-ẹhaabhi madẹdẹn. Ọvaar Ibinọkpaabyi ọkk'ọ ọda k'ọtzọhm kpenamkpen fa nkk'nsa nnang-ọ. Yina, kọbaan bi abira atte kaam ọbọhk, mbiri nda nnor f'ẹhọhmmọr chaam, ebire etzima eruk akpen o?” 
\p  
\v 31 Laban ọbọbh-ẹ bi, “Mbọng f'áror bi, nsi nnang-ọ?” 
\p Jekọb on-obhina bi, “Kaam echora manda dani ka mbọhk sọ kinnori. Odik obungikwẹ kwa kaam nnori ode bi, kọ abira atte etzirakpo pyọ ọbọhk, anang-m nkkeri.  
\v 32 Tte nnenga k'ottem kwa arukhimaan-va pọ pa kaam mmi nkkeri, ndekha arukhimaan p'ade akkẹr-ankkẹr, ọmaana avu p'asi attẹttẹr, mach'echora chaam.  
\v 33 Mada ópyiri k'ogbe kwa kọ akwu akkeri etzirakpo pyọ, tte odik ọkkakka kwaam ọkhaama ẹjaakhi bi, idikha kọ are orukhimaan-nwa kpenamkpen kw'oni akkẹr-ankkẹr ode, ọmaana evu kpenamkpen ch'eni attẹttẹr esi k'ottem kwa nden saam, kọ tzọkha bi, mfhu-ofhu.” 
\p  
\v 34 Laban oben bi, “Kaam nkk'nkhera k'odik ọkkakka bi, kwẹ ode mach'agbaakhi.” 
\p  
\v 35 M'ewu nduma dani, Laban orenga ọrọbha avu-dim p'ade akkẹr-ankkẹr, ọmaana p'asi attẹttẹr, ọmaana avu-gbokha biphyir p'ade akkẹr-ankkẹr, ọmaana p'asi attẹttẹr, ttara arukhimaan-bina biphyir, ọtzọkha ọnang va pẹ bi, bẹ akkeri.  
\v 36 Mẹ wọ, otzima va pẹ obina orenga kw'iwu ittaan, bẹ aji Jekọb kẹ da okkeri etzirakpo mbyonggo pya Laban. 
\p  
\v 37 Mando kwa Jekọb ọtzọk achi-bọhnga abhapẹ p'echi cha pọpula ọmaana, abọhnga p'echi ch'almọn, ọmaana p'echi ch'ede \it bi waaar\it* obori akpakpa, osi bẹ an-awur \it bi gwaang\it*.  
\v 38 Mẹ wọ, Jekọb ọtzọkha achi-bọhnga p'okk'akpakpa obori, ohok m'agbaakha biphyir p'etzirakpo em-ekwu egwo asi, ttara nttak bi, idikha pyẹ eyim ayok abẹ m'ibe nnuma sa pyẹ em-egwo asi,  
\v 39 pyẹ ekkeri achi-bọhnga mba itzitzikha, pyẹ ẹmaan akkẹr-ankkẹr. 
\p  
\v 40 Mẹ wọ, Jekọb ọbhaangi arukhimaan-va ohok ngọmi, yina on-osi mbonggo p'arikhi bi, bẹ akkeri akkẹr-ankkẹr pa Laban itzitzikha. Mẹ wọ, kẹ ọn-ọkhaama etzirakpo pya kẹ ọkhaam, py'oni ka pya Laban dọk attar.  
\v 41 Ogbe kpenamkpen nwa kwa Jekọb ore bi, etzirakpo py'ipanọng py'egwengi for en-eyima ayok abẹ, ọtzọkha achi-bọhnga p'okk'akpakpa obori ohok m'agbaakha k'itzitzikha s'etzirakpo, ifha pyẹ eyima ayok abẹ ẹbaanga mẹ.  
\v 42 Yina, etzirakpo py'eni egwengi, pyẹ achi-bọhnga mbuma kọkpa. Mẹ wọ, mbuma py'egweng-ogwengi en-ede pya kẹ Jekọb. Py'eni egwengi ede pya Laban.  
\v 43 Mando wọ kw'iwa Jekọb otzim okpena ọkkọkkaa kw'okhaam etzirakpo k'ọhaabh, ọmaana atzọhmnọng p'ipanọng ttara p'ijinọng, ọmaana akamẹl ọttara nnyanyaang. 
\c 31  
\s1 Jekọb ọrọbhi ka Laban ka mbọhk 
\p  
\v 1 K'ogbe wani, wa Jekọb okwu ọbhaanga bi, va pa Laban an-am-aben bi, “Ọnyẹ kwaman Jekọb, ọkk'ọttọhk kpenamkpen f'otte kwaman ọtzọkha biphyir ọkhaama. Ẹkhakhaama chẹ biphyir efon k'otte kwaman e.”  
\v 2 Jekọb on-obiro ore bi, Laban kẹ itzitzikha ọkkakka dọk kọm-ọnang. 
\p  
\v 3 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Jekọb bi, “Kọ rọhng abhana atzor anọng pọ, ttara ẹhọhmmọr ch'atte. Kaam ńwobha ttar-ọ, mbiri ńkkaan-ọ.” 
\p  
\v 4 Iwa Jekọb ọtzọhm ọnọng bi, bẹ ayeri panọng pẹ, Rachẹl ọmaana Lea, ifha bẹ akhebh-ẹ kẹ da om-okkeri etzirakpo pyẹ.  
\v 5 Mada bẹ akk'apyiri, oben bẹ bi, “Kaam nkk'nna bi, atte kwabọng kaam itzitzikha ọkkakka dọk om-okkeri m'iwu nna. Yina, kaam nnong bi, Ibinọkpaabyi kw'otte kwaam okpobh okk'owobha ttar-m.  
\v 6 Bọng anọng afa arong bi, kaam nkk'ọtzọhm nsa ttara ettem-obungichẹ nnang atte kwabọng.  
\v 7 Yina, atte ọkk'aam echora ch'ọtzọhm faam ọbọhra k'igbe jobh. Kaambi mẹ wọ, Ibinọkpaabyi kẹ ọbọhk kotte bi, osi-m itzama manda rani.  
\v 8 Idikha obeni bi, ‘Etzirakpo py'esi akkẹr-ankkẹr bọ éde echora chọ,’ etzirakpo biphyir ẹn-ẹmaan ayok p'asi akkẹr-ankkẹr. Yina, obeni bi, ‘Etzirakpo py'esi attẹttẹr byọ éde echora chọ,’ etzirakpo biphyir ẹn-ẹmaan ayok p'asi attẹttẹr.  
\v 9 Mẹ wọ, Ibinọkpaabyi okk'etzirakpo py'atte kwabọng ọtzọkha ọnang-m. 
\p  
\v 10 “Wa ewu dani, k'ogbe kw'etzirakpo em-eyima ayok abẹ, nttaar idachen. K'idachen, ndini chen nne da, avu-dim p'am-avura avugbokha bẹ asi attẹttẹr, bẹ abira asi akkẹr-ankkẹr.  
\v 11 K'idachen, orenga-eden kw'Ibinọkpaabyi oyer-m bi, ‘Jekọb.’ Kaam nkhera bi, ‘O o, kkeri kaam ma e.’  
\v 12 Kẹ on-oben-m bi, ‘Kọ tzini chen akkeri k'ẹrọng, are bi, avu-dim p'avur ayok biphyir asi attẹttẹr, abira asi akkẹr-ankkẹr. Kaam nsi kwẹ ode mando okhuri da nkk'odik kpenamkpen kwa Laban ọkk'ọsa nna e.  
\v 13 Kaam wọ nde Ibinọkpaabyi kwa Bẹtẹl, kẹ da abyengi ọtza ana k'eho, abira asi echekhi ọnang-m. Kọ na bina aji obhon nwa, akpa nnam abhana k'ọmmaana-bhon kwọ.’ ”  
\v 14 Mando kwa Rachẹl ọmaana Lea an-abhin odim kwabẹ, Jekọb bi, “Ọttọhk fa maman obiro ochi otte kwaman obo k'ẹkhakhaama chẹ biphyir dọk kode.  
\v 15 Otte kwaman ọn-ọtzọk man mach'akhekhennọng, okpe-okpe kẹ-khẹ arang kw'okpe man, okk'amina-gbukha paman obiro ọcha mancheni.  
\v 16 K'odik ọkkakka, kọ si odik kpenamkpen kw'Ibinọkpaabyi okk'obena bi asi, k'eden bi, Ibinọkpaabyi okk'ẹkhakhaama ch'otte kwaman ọtzọkha, ọn-ọnang maman, ttara va paman.” 
\p  
\v 17 Mẹ wọ, Jekọb obina ọtzọkha va pẹ ọmaana panọng pẹ afa, ọnanna k'akamẹl,  
\v 18 on-otzima etzirakpo pyẹ biphyir, ọmaana ẹkhakhaama chẹ biphyir ch'ọkk'ọkhaama ka Padan-Aram obina orenga, okhuna otzor otte kwẹ, Isaak k'ẹkhọma cha Kenaan.  
\v 19 Mada Laban okk'ofona bi, ọtza ophyiri ophyubha f'arukhimaan pẹ, kwanọng kwẹ, Rachẹl ofona ọtza ofhu agbatza p'ẹhọhmmọr ch'otte.  
\v 20 Ayongi mẹ, wa Jekọb ọbọhr Laban kw'ofon Aram ọbọhra, kẹ kọgbaakhi bi, ọn-ọrọbh ofona.  
\v 21 Mẹ wọ, wa Jekọb ọtzọkha ẹkhakhaama chẹ biphyir, ojekha ọraanga kwa Yupharetes, okkeri itzitzikha k'okhuba kw'egbegbeho cha Gilead, ọrọbh ofona. 
\s1 Laban okhubh Jekọb 
\p  
\v 22 Ottong iwu ittaan sa Jekọb ọkk'ọrọbha ofona, mẹ kwa Laban on-orong bi, Jekọb ọkk'ọrọbha.  
\v 23 Mẹ wọ, Laban otzima vọkka pẹ p'atzọn-ẹ abẹ, akhubh Jekọb k'eden k'iwu izenamfa, matzẹmaa bẹ akwu abọkh-ẹ ka mgbegbeho sa Gilead.  
\v 24 Mẹ wọ, Ibinọkpaabyi oyin Laban kw'ofon Aram abẹ k'erungi k'idachen, oben-ẹ bi, “Ndọr-ọ itzọhng bi, aningi Jekọb atzim p'agaang-ọgaangi agbaakhi.”  
\v 25 Mada Laban okhebh Jekọb, Jekọb okk'ikhira sẹ ọsa ka mgbegbeho sa Gilead, wa Laban ọmaana vọkka pẹ akwu asi ibhingabe sabẹ abaanga mẹ dọk.  
\v 26 Mada bẹ akhebh ayok, Laban ọbọbh Jekọb bi, “Osi yan kwa kọ abọhr-m, atzima aminava paam afona mach'anọng p'abẹ abọhk k'ẹmmọri ch'egbong.  
\v 27 Okhuri yan kw'abọhr-m, afhu-ofhu arọbh afona o? Osi yan kaam kagbaakhi bi, an-afona ifha kaam nsi ọdadaami kwa ndima ọkkọhna, ọmaana achachaak ttara ogim-ogim mben-ọ bi, yima o?  
\v 28 Kọ kaam ọbọhk katte bi, mbaakha va pa va paam ttara aminava paam da bẹ afon. Odidingi-dik wọ kw'asi ma e.  
\v 29 Kaam ngaam ẹfa kẹ ch'ira nsọ-ọ itzama e. Yina, erungiwu ch'ikhena Ibinọkpaabyi kw'atte ọtzọr-m itzọhng bi, ‘Kọ bọkh-ọ for, odik manda wani kagbaak anang Jekọb o, ode bi kw'ejibh-ojibh obiro ode bi kwẹ opyibh-opyibh.’  
\v 30 Kaam nnong odem kw'oyibh-ọ bi, abhana k'atte k'obhon kẹ e, yina, kọ asi yan afhu agbatza paam atzima arọbh o?” 
\p  
\v 31 Iwa Jekọb obhina Laban bi, “Kaam mfon mando okhuri ojora f'osi-m, nna nchibhi bi, kọ afha abọkh-m aminava pọ ana k'ẹfa.  
\v 32 Yina, idikha kọ are ọnọng manda wani k'ottem kwaman kw'otzim agbatza pọ, tte ọnọng nwuma oningi akpen orukhi. M'itzitzikha s'anọng paman, kọ ọkhaam kkeri, idikha atzini ọttọhk kpenamkpen f'ode fọ, tọkha.” Wa Jekọb korong bi, Rachẹl ọkk'agbatza p'otte ọfha.  
\v 33 Mẹ wọ e, Laban odim k'ikhira sa Jekọb, ọmaana sa Lea ttara s'atzọhmnọng p'ipanọng afa oror agbatza pẹ. Yina, ọttọhk manda vani kore. Mada oyini k'ikhira sa Lea, on-odim k'ikhira sa Rachẹl.  
\v 34 Wa Rachẹl ọkk'agbatza p'otte ọtzọkha okhe k'ẹkpa ch'ebubh ẹwọr-wobha cha kamẹl ka nnam, owobha ẹwọr obubha. Laban ọfọhngi k'ikhira biphyir, agbatza pẹ kore. 
\p  
\v 35 Mando kwa Rachẹl oben otte bi, “Itta kwaam, tte oning-ọ ọdọkhi da kaam nnimfha mbina mbe k'itzitzikha sọ, okhuri bi, kaam ndim for e.” Laban ọfọhngi k'ibe kpenamkpen biphyir, agbatza pẹ kore. 
\p  
\v 36 Jekọb ọdọkhi ettem, oyin Laban abẹ, ọbọbh-ẹ bi, “Kaam nji bọng odikh o? Ottotto kwaam ode yan, kw'areng abẹ akhubh-m ẹkhọm-ẹkhọma manda o?  
\v 37 Mada akk'ọttọhk kpenamkpen f'ode faam afọhngi biphyir, mbọng f'are f'ode fọ ọ? Ji pyẹ m'itzitzikha s'anọng paman, ifha bẹ are ọnọng kw'otzor-otzor k'ottem kwa man anọng afa. 
\p  
\v 38 “Kaam nkk'ọtzọhm nsa nnang-ọ ka cho ẹrọbh. Ma cho mbuma biphyir, arukhimaan-kwa ọmaana avu pọ p'ibhọhr iyini kade. Arukhimaan-dim pọ pa ndim nsi ọchattọhk nchi kade.  
\v 39 Etzen cha nden s'ẹtzam ifhu, cha ndim nchen-ọ kede. Ọttọhk kpenamkpen fa bẹ afhu ka mbọhk saam, ode k'erungi obiro ode k'ẹya f'arori, fa kaam nnọ-ọ ndukhi kode.  
\v 40 Kaam wa akpen paam ade p'ekpikhira ẹmaani k'ẹya, ekhokhokhi esi-m k'erungi, chen abira akhur-m.  
\v 41 Kaam nnukh-ọ abẹ ka cho ẹrọbh biphyir. Nsi ọtzọhm nnang-ọ ka cho ọhawani kwa chi, ifha ndọkha aminava pọ afa k'ọbada, mbiri nkkeri nden sọ nnang-ọ ka cho azadani. Nkyera e, abọhr-m echora ch'ọtzọhm faam k'igbe jobh.  
\v 42 Idikha ira Ibinọkpaabyi kw'otte kwaam, kw'ode Ibinọkpaabyi kw'Abraham ttara Ojora f'Isaak, on-owobh ttar-m, ira kọ akk'aam mbọhk-mbọhk akhubha. Yina, Ibinọkpaabyi okk'ọmmamma kwaam ọra, obiro ore ihem saam, kẹ wọ osi ọkpọ-ọ eden ihena k'erungi.” 
\p  
\v 43 Ofona mẹ, Laban on-obhina Jekọb bi, “Panọng mba ade va paam, va mba biphyir ade va pa va paam, nden nna biphyir mbiri nde saam. Ọttọhk kpenamkpen f'are bi akhaam ma ode faam. Akker-okkeri, yina wọ kwa kaam mbiri ndọkha va paam, ttara va pa va paam amaani ka mbọhk sọ o?  
\v 44 Mẹ wọ, tte mosi echekhi ọnang ayok, ch'ebe macha nttẹsẹ kwa kaam ttara kọ.”  
\v 45 Mẹ wọ, Jekọb ọtzọkha ọtza, ọfhẹ-ẹ ebebe mach'ẹkpọmmachi.  
\v 46 Jekọb on-oben anọng pẹ bi, “Bọng dobha atza.” Bẹ atzọkha atza atzobha k'okhung, bẹ an-abira awobha abaanga ọtza-khung nwuma achi ọchattọhk.  
\v 47 Wa Laban oyeri ọtza-khung Jega-Sahaduta, Jekọb oyer-ẹ Galeed\f + \fr 31.47 \fq Galeed\ft k'eHeburu oyini okhung kwa nttẹsẹ.\f*. 
\p  
\v 48 Laban on-oben bi, “K'ewu cha mayina, ọtza-khung nwa obe macha nttẹsẹ kwa kaam ọmaana kọ.” Kẹ wọ osi, bẹ ayeri ibe nna Galeed.  
\v 49 Wa Laban obiro oyeri ibe nna Mizpa, oben bi, “Tte Ọvaar Ibinọkpaabyi okkeri man mada motte ayok ọbọhk, ọnọng-ọnọng ofona kwẹ.  
\v 50 Idikha kọ atzim va paam k'ihem, ode bi kọ an-abira atza atzọkha panọng adọdọk p'ayongi va paam, kaambi ode bi ọnọng man kore, jima bi, Ibinọkpaabyi wọ ode nttẹsẹ kwa kaam ọmaana kọ.” 
\p  
\v 51 Mẹ wọ, Laban oben Jekọb bi, “Manya wọ ode ọtza-khung, manya wọ obiro ode ẹkpọmmachi cha kaam nkk'nttima k'ottem kwa kaam ttara kọ.  
\v 52 Ọtza-khung nwa ode nttẹsẹ, ẹkpọmmachi nda ebire ede macha nttẹsẹ bi, ogbe dọk kode kwa kaam mbiri njekha ibe nna nkwu nsọ-ọ itzama, ọmaana bi, ogbe dọk kode kwa kọ abira ajekha k'okhubha kwaam akwu asi-m itzama.  
\v 53 Tte Ibinọkpaabyi kw'Abraham, ọmaana Nahọr, Ibinọpkaabyi kw'otte kwabẹ okpobh, osi ochibhi kwẹ m'echekhi nda cha kaam ọmaana kọ.” 
\p Mẹ wọ, Jekọb on-ọtzọkha ọnwọhngi ka che ch'ojora f'otte kwẹ, Isaak.  
\v 54 Jekọb ọtzọkha orukhimaan ofhu otzima osi ẹjafọhni ọnang Ibinọkpaabyi k'okhubha kwa mgbegbeho, obiro oyeri anọng pẹ bẹ akwu achi ọchattọhk mẹ. Mada bẹ akk'ọchattọhk acha akyera, bẹ an-ayima mẹ maa, ewu ehobha.  
\v 55 Mada ewu ekk'ehobha, Laban obina odo for s'ofona, ọtzọkha va pa va pẹ, ọmaana aminava pẹ ọbaakha, obiro osi bẹ ittabọhng. Laban obina ọbhana ka kẹ k'obhon. 
\c 32  
\s1 Jekọb odibh for bi otza okhebha Ẹsau 
\p  
\v 1 Iwa Jekọb obina orenga, arenga-eden p'Ibinọkpaabyi ayin-ẹ abẹ.  
\v 2 Mada Jekọb ore arenga-eden mba p'Ibinọkpaabyi, oben bi, “Ibe nna ide ibhingabe s'Ibinọkpaabyi.” Mẹ wọ, oyeri sẹ Mahanayim.\f + \fr 32.2 \ft K'eHiburu, Mahanayim oyini obhingabe ọfa.\f* 
\p  
\v 3 Jekọb ọtzọhm akkaabh-nkkaabha pẹ bi, bẹ acheden atza akhebha ọgbaanọkka Ẹsau k'ẹkhọma cha Seir, k'okhuba kw'Edom.  
\v 4 Ọnang bẹ ẹkkaabha, oben bẹ bi, “Bọng gbaak itta kwaam Ẹsau bi, ‘Kaam ọtzọhmnọng kwọ, Jekọb, mbeni bi, nkk'nwobha ttara Laban ttẹwọr mada mfofon maa apyiri ma.  
\v 5 Kaam nkk'abhaam, ọmaana nnyanyaang, ọmaana arukhimaan, ọmaana avu, ọmaana atzọhmnọng p'ijinọng ttara p'ipanọng ngaama. Kaam nna ndọhmi ẹkkaabha nda nchena itta kwaam, ifha ndọkha ọphyaam k'itzitzikha sọ.’ ” 
\p  
\v 6 Mada akkaabh-nkkaabha pa Jekọb akhun atzor-ẹ, bẹ agbaakh-ẹ bi, “Mokk'agbaanakka Ẹsau ọtza ọra, kẹ oreng k'eden okwuma bi, okwu ọrọ-ọ e. Kẹ ọkhaam anọng ẹnọhna p'atzọn-ẹ abẹ.” 
\p  
\v 7 Wa Jekọb ojor-ẹ, ettem ẹyakh-ẹ atzim. Mẹ wọ, ọbhaangi anọng p'otzim ka ngaan mfa, obiro ọbhaangi arukhimaan, ọmaana abhaam, ttara akamẹl.  
\v 8 Jekọb on-oben for sẹ bi, “Idikha Ẹsau orim ẹkhaan dani abẹ, ẹkhaan ndonggo ch'erikhi ẹrọbh-ọrọbh ẹnaanga.” 
\p  
\v 9 Iwa Jekọb ozi njọhm, oben bi, “Ọvaar Ibinọkpaabyi kw'itta kwaam Abraham, ọmaana kw'otte kwaam Isaak, Ọvaar Ibinọkpaabyi kw'oben-m bi, rọhng abhana k'ẹkhọma chọ, atzor anọng pọ, obiro ochekhi bi, kaam nsi idik ijibh inang-ọ.  
\v 10 Kaam ọtzọhmnọng kwọ k'ọphyaam fọ, ọmaana k'idadaakha sọ biphyir, kimbaan. Wa kaam ndim ochikhura kwaam kẹ-khẹ njekha ọraanga kwa Jọrdan, manya, kaam nkk'ẹkhakhaama nsa, matzẹmaa nna mmaangi chẹ ka ngaan mfa.  
\v 11 Tzotzokhaan, kkaan-m, arọbh-m ka mbọhk s'ọgbaanọkka kwaam Ẹsau, okhuri bi, ojora faam ode bi, kẹ ófha okwu ofhu man biphyir, ttara va ọmaana abọkka.  
\v 12 Yina, kọ akk'achekhi anang kaam bi, asi-m ńgaama ẹkhakhaama, abira ási va pa va paam ahaabh mach'oyeyeng kw'ọraanga ọkhaan-ọkhaan, kw'ọnọng on-ofha obhik.” 
\p  
\v 13 Iwa Jekọb oyima m'ibe nna m'erungiwu nduma. Otzekha ẹnanga k'ottem kw'ekpo py'ọkhaam ọnang ọgbaanọkka Ẹsau.  
\v 14 Obhik kw'ekpo py'otzek bi ọnang-ẹ ode: avu-gbokha arọbh jobh, ọmaana abhumkpẹ ẹrọbh, ọmaana arukhimaan-kwa arọbh jobh, ttara arukhimaan-dim ẹrọbh,  
\v 15 ọmaana akamẹl-papẹ ẹrọbh obhiri jobh ttara va pabẹ p'atzima ajaabh ẹba, ọmaana abhaam-papẹ arọbh afa, ọmaana abhaam-dim jobh, ọmaana anyanyaang-papẹ ẹrobh, ttara anyanyaang-dim jobh.  
\v 16 Jekọb ọtzọkha sẹ ohok ka ngaan, ka ngaan. Ọtzọkha ẹkhaan kpenamkpen ọnang ọtzọhmnọng wani bi okkeri, oben bẹ bi, “Bọng chi kaam eden arọhng, bọng abira anang ayok ọphaangi k'orenga kwabọng.” 
\p  
\v 17 Ọn-ọtzọr oyok kw'ochi eden itzọhng, oben bi, “Idikha ọgbaanọkka kwaam Ẹsau ottem-ọ abẹ, ọbọbh-ọ bi, ‘Kọ ade kw'anyi? Kọ am-atza maan ma? Nden s'anyi rọ sa kọ am-akkeri?’  
\v 18 Kọ abhin-ẹ bi, ‘Itta kwaam, ekpo mbya biphyir ede py'ọtzọhmnọng kwọ, Jekọb. Pyẹ ede ẹnanga ch'ọtzọhmi ochena itta kwaam Ẹsau, kẹ ọkhaam oreng k'eden okwuma e.’ ” 
\p  
\v 19 Wa Jekọb obiro oben ẹkhaan ch'ettong mfa, ọmaana ch'ettong nttaan, ttara ayok mbonggo biphyir p'atzori etzirakpo nnam bi, “Mada bọng akhebha Ẹsau, bọng gbaakh-ẹ odik nwuma wani kwa mgbaakhi ochedennọng.  
\v 20 Bọng jima bi agbaakh-ẹ bi, ọtzọhmnọng kwọ, Jekọb, otzori man nnam okwuma k'eden e.” Da kẹ, Jekọb ochibhi bi, “Kaam ncheden ndọhm ẹnanga nda bi, ndima ndir-ẹ nttem, ifha sa on-ore-m, asi mẹ, okhera bi ọtzọkh-m.”  
\v 21 Mẹ wọ, atzọhmnọng pa Jekọb acheden atzima ẹnanga akwọbha, yina, kẹ ọkhaam oyima m'ibhingabe sẹ m'erungiwu nduma. 
\s1 Jekọb osi orima ttara Ibinọkpaabyi 
\p  
\v 22 M'erungiwu nduma dani, Jekọb obina ọtzọkha panọng pẹ afa, ọmaana atzọhmnọng pẹ p'ipanọng afa, ttara va pẹ p'ijinọng jobh obhiri wani, ọtzọhm bẹ arenga k'okhubha kw'ogbin-ogbini ajekha ọraanga kwa Jabọk.  
\v 23 Mada ọkk'anọng mba biphyir ọtzọhma ajekha ekhekha, obiro okwu ọtzọhm anọng ttara ẹkhakhaama chẹ biphyir.  
\v 24 Mẹ wọ e, Jekọb on-owobha mancheni. Ojinọng wani oyin-ẹ abẹ, osi erima ttar-ẹ, matzẹmaa ewu ehobha.  
\v 25 Mada ojinọng nwa ore bi, Jekọb mkpaan kofha ọyọhnga, on-obun-ẹ ọttọhk k'ogbok osi ọkhọbhi kw'ogbok ọkpara eho, da bẹ atzima asi erima osi.  
\v 26 Mẹ wọ, ọnọng nwa oben Jekọb bi, “Tte kaam ọbọhk mfona, kkeri ewu em-ehobh.” 
\p Yina, Jekọb obhin-ẹ bi, “Kaam kọ ọbọhk kintte, kw'oyongi bi ado-m.” 
\p  
\v 27 Mẹ wọ, ọnọng nwa ọbọbh-ẹ bi, “Kọ akpen yan?” 
\p Obhin-ẹ bi, “Kaam mkpen Jekọb.” 
\p  
\v 28 Ọnọng nwuma on-oben-ẹ bi, “Ttẹwọr mayina, kọ Jekọb dọk kàkpena, an-akpena Israẹl, okhuri bi, kọ akk'erima asa ttara Ibinọkpaabyi, ọmaana anọngẹya, yina, kọ akk'akhema.” 
\p  
\v 29 Iwa Jekọb on-oben bi, “Tzotzokhaan, kọ gbaak-m che chọ.” 
\p Ọnọng nwa ọbọbh-ẹ bi, “Osi yan kw'abọbh-m che chaam?” Mando kw'ọnọng nwa odo Jekọb m'ibe nnuma. 
\p  
\v 30 Wa Jekọb on-oyeri ibe nna Pẹniẹl\f + \fr 32.30 \ft K'eHiburu, Pẹniẹl oyini itzitzikha s'Ibinọkpaabyi.\f*, oben bi, “Kaam nkk'Ibinọkpaabyi nna itzitzikha ttara itzitzikha, yina, kaam kimpe, ndimi nnukhi akpen.” 
\p  
\v 31 K'ogbe kw'ewuchen eyini wọ kwa Jekọb om-ogbekhi ọkwọbha Pẹniyẹl, okhuri ọkhọbhi kwẹ kw'ogbok kw'ọkpar eho.  
\v 32 Kẹ wọ osi, mapyiri k'ewu cha mayina, anọng p'Israẹl bẹ ayara p'abọk eje ch'ogbok kachi, okhuri eje ch'ogbok kwa Jekọb ch'iwa ọnọng obuni ọttọhk. 
\c 33  
\s1 Ẹmẹm cha Jekọb ọmaana Ẹsau 
\p  
\v 1 Mada Jekọb otzini chen, ore ọgbaanọkka Ẹsau da om-otzima anọng pẹ ẹnọhna okwu. Mando kw'ọtzọk va pẹ okkema ọnang abọkka. Ọtzọkha ọnang Lea, ọmaana Rachẹl, obiro ọtzọkha ọnang atzọhmnọng pabẹ p'ipanọng afa.  
\v 2 Wa ọtzọkha atzọhmnọng mba p'ipanọng ttara va pabẹ otzima ochi eden, Lea ttara va pẹ atzor bẹ nnam, yina Rachẹl ttara Josẹph an-akponga nnam.  
\v 3 Wa Jekọb ma for sẹ ochi eden orenga otzor ọgbaanọkka ka for. Mada ọbaang-ẹ ka for, ọrakha ottima itzitzikha k'irerek igbe izenamfa. 
\p  
\v 4 Yina, Ẹsau ọrọbh ọtza ọgọhma Jekọb, ọkhaar-ẹ mbọhk k'ekhokhora, obira ọbaakh-ẹ. Bẹ anọng afa abhom.  
\v 5 Mada Ẹsau otzini chen ore panọng ttara va, ọn-ọbọbh bi, “Bọng anọng bọ bọng atzọni kẹ-ẹ?” 
\p Jekọb obhin-ẹ bi, “Va p'Ibinọkpaabyi ọkk'ọtzọhmnọng kwọ ọnanga k'ọphyaam, bọ mẹ e.” 
\p  
\v 6 Mẹ wọ, atzọhmnọng p'ipanọng ọmaana va pabẹ arenga atzor-ẹ ka for, bẹ arakha attima otzitzikha k'irerek anang-ẹ ikpokpobha.  
\v 7 Lea ttara va pẹ ajema, bẹ abira attima otzitzikha k'irerek, yina Rachẹl ttara Josẹph an-akpong nnam akwu attima itzitzikha k'irerek anang-ẹ ikpokpobha. 
\p  
\v 8 Ẹsau ọn-ọbọbh bi, “Anọng mba p'ira ngebh, ttara ngaan s'etzirakpo pya bẹ atzima akwu, atzọhmi bẹ bi, bẹ akwu asi yan o?” 
\p Jekọb oben bi, “Itta kwaam, ndim pyẹ bi ndọkha ọphyaam k'itzitzikha sọ e.” 
\p  
\v 9 Yina, Ẹsau on-oben bi, “Mma e, ọgbaanọkka kwaam, kọ khaama ekpo pyọ, kaam nkk'ekpo ngaama k'ọhaabh py'ebeng-m e.” 
\p  
\v 10 Jekọb, obhin-ẹ bi, “Mma o, ngwukh-ọ okhukhi. Kọ tzọkha ẹnanga cha nnang-ọ, idikha ọphyaam f'asi anang-m, ofon-ọ k'ettem. Ẹra cha kaam nnọ-ọ ma, okheri macha nne itzitzikha s'Ibinọkpaabyi e, da kọ atzọkh-m k'ọphyaam.  
\v 11 Tzotzokhaan, khera bi atzọkha ẹnanga nda cha nnang-ọ, da Ibinọkpaabyi okk'aam ọda ttara ọttọhk kpenamkpen fa kaam nnori.” Mada Jekọb ochin ororo ọgbana bi, ọgbaanọkka ọtzọkha ẹnanga cha ọnang-ẹ, Ẹsau okhera ọtzọkha. 
\p  
\v 12 Mando kw'Ẹsau on-obeni bi, “Tte mofona, kaam ńchọ-ọ eden.” 
\p  
\v 13 Yina, Jekọb oben-ẹ bi, “Itta kwaam, kọ arong kẹ bi, va paam atzima akhar-ọkhara, bẹ ẹfa kakhaam, ttara bi, etzirakpo pyaam etzim ẹrọkhi ayok p'ikhakhari ọrọk. Idikha motzim pyẹ orenga m'ẹbhar-ẹbhar, k'ewu dani chẹ-chẹ, pyẹ épe-ope biphyir.  
\v 14 Mẹ wọ, tte itta kwaam ochi ọtzọhmnọng kwẹ eden, ifha kaam ndima etzirakpo mbya ọmaana va mba, mfumetzen nnenga, matzẹmaa mokhebha ayok ka Seir.” 
\p  
\v 15 Mẹ wọ, Ẹsau on-oben bi, “Tte ntte anọng paam bani ọbọhk, bẹ atzọn-ọ abẹ.” 
\p Jekọb on-obhin-ẹ bi, “Sam e, itta kwaam, okhuri yan kw'abira ayak for sọ atzim o? Tte kaam ndọkha ọphyaam fọ fẹ-fẹ.” 
\p  
\v 16 M'ewu nduma dani, Ẹsau obina orenga okhuna ka Seir.  
\v 17 Yina, Jekọb ochina ka Sukọt. Kẹ wọ kw'iwa osi ọhọhm kw'owobh, obiro osi okhira f'etzirakpo pyẹ. Kẹ wọ osi bẹ ayeri ibe nnuma Sukọt.\f + \fr 33.17 \ft K'eHiburu Sukọt oyini okhira.\f* 
\p  
\v 18 Wa k'ekponga-nnam, Jekọb ofon ka Padan-Aram orenga maa okwu opyiri k'odedenmon kwa Shẹkẹm, k'ẹkhọma cha Kenaan, osi ibhingabe mẹ ọbaanga odedenmon nwa.  
\v 19 Wa Jekọb okwu odebh okhubha kw'irerek kw'ottim ikhira, ka mbọhk sa va pa Hamọr, kw'ode otte kwa Shẹkẹm, k'asilva arọbh azen.  
\v 20 M'ibe nna rọ sa Jekọb osi ijafọhnibe, obiro oyeri ibe nna Ibinọkpaabyi ode Ibinọkpaabyi kw'Israẹl. 
\c 34  
\s1 Daina ọmaana anọng pa Shẹkẹm 
\p  
\v 1 Wa k'ogbe wani, Daina, kw'ode nnwa kw'ikwanọng kwa Lea ọkk'ọmaana ọnang Jekọb, oyini k'iyaan ọtza odibh panọng p'obhon nwuma.  
\v 2 Mada Shẹkẹm kw'ode nnwa kwa Hamọr, kw'ode ọvaarnọng kw'anọng pa Hiv ore Daina, ọbọkh-ẹ k'ẹfa oyima abẹ.  
\v 3 Mando kwa Shẹkẹm ọtzọkha ettem chẹ biphyir ọgbana ka Daina, kw'ode ominanwa kwa Jekọb. Wa Daina ọdaakh-ẹ oyong-oyongi, on-okhonga bi, ọsẹ-ẹ okhera eyonga chẹ.  
\v 4 Mẹ wọ, Shẹkẹm oben otte kwẹ Hamọr bi, “Itta, kọ tzọkha ominanwa nwa anang-m, mọba ayok.” 
\p  
\v 5 Iwa va pa Jekọb p'ijinọng atzim awobh k'owoni, da bẹ atza anang etzirakpo pyẹ ọchattọhk, k'ogbe kwa Jekọb ọbhaang bi, bẹ akk'ominanwa kwẹ, Daina, ọgbasadik asa. Mando kw'omyi odik nwa maa va pẹ akhuna. 
\p  
\v 6 Iwa Hamọr kw'ode otte kwa Shẹkẹm ofona bi ọtza ọttọhna odik nwa ttara Jekọb.  
\v 7 Mada va pa Jekọb an-afon kẹ da bẹ akkeri etzirakpo akhuna, bẹ abhaanga odik kw'otto da bẹ anade. For ipe bẹ, nttem mbiri mpyibh bẹ okhuri ọgbasa-dik kwa Shẹkẹm ọkk'ọsa k'Israẹl bi, ọbọkha ominanwa kwa Jekọb oyima abẹ k'ẹfa, odik kw'oni ọbabaana ọbaan. 
\p  
\v 8 Yina, Hamọr oben bẹ bi, “Tzotzokhaan, bọng tte nnwa kwaam Shẹkẹm ọbọhk ọtzọkha ominanwa kwabọng, ettem chẹ biphyir ẹn-ẹgban ma kẹ e.  
\v 9 Bọng mọtzọkha ayok k'ọbada, tte ajinọng paman atzọkha aminava pabọng, ifha bọbọng abira atzọkha aminava paman.  
\v 10 Bọng afha aruk ma ttara man, irerek iyim mẹ maa arọhng bi, bọng aruk abira arenga mphya kpenamkpen, ttara bi bọng abira afha akhaama orerek fabọng ọkhaam.” 
\p  
\v 11 Mẹ wọ, Shẹkẹm oben otte ttara agbaanatte pa Daina bi, “Bọng tte kaam ndọkha ọphyaam kabọng k'itzitzikha, kaam ndo for bi, nnang bọng ọttọhk kpenamkpen fa bọng aben bi, ńnang k'eho ch'ominanwa kwabong.  
\v 12 Bọng gbaakh-m ẹphya ch'imina sẹ, ọmaana ekpo kpenamkpen biphyir py'ẹbari macha kọ, pya kaam mbaan bi idima nkwu, k'odem kw'ọdaakhi bọng. Kaam ńnang bọng ọnang, bọng kinggẹ nang-m ominanwa nwa ndọkh-ẹ k'ọbada.” 
\p  
\v 13 Wa va pa Jekọb arenga ọgbasa-dik kw'ọkk'ọtta okhebha ọgbaanotte kwabẹ Daina abẹ, abọhra Shẹkẹm ttara otte kwẹ Hamọr.  
\v 14 Bẹ aben bi, “Man odik-dema nwa kofha osi. Ode ọgbasa-dik ọnang man bi, mọtzọkha ọgbaanotte kwaman ọnang ọnọng kw'oni ọkpakkọrikkọ osi, k'ọbada.  
\v 15 Eden obungichẹ cha mókhera ttara bọng ede bi, bọng an-ade macha man, ojinọng kpenamkpen k'ottem kwabọng ọkhaambi osi ọkpakkọrikkọ.  
\v 16 Mẹ wọ kwa maman ótzima okhera ttara bọng bi, ajinọng pabọng átzọkha panọng paman, maman obiro okhera bi mọ́tzọkha panọng pabọng. Mẹ kwa móbiro oruk ttara bọng, man biphyir món-ode wani, macha bọng aphyemi.  
\v 17 Yina, idikha bọng ánakhera bi, asi ọkpakkọrikkọ, man kokhera bi, bọng atzọkha ominanwa kwaman k'ọbada, mótzim-ẹ otzima ofona e.” 
\p  
\v 18 Wa Hamọr, ttara nnwa kwẹ Shẹkẹm are bi, ochibhi kwa va pa Jekọb asi ojibh-ojibh.  
\v 19 Wa Shẹkẹm ode ojinọng kw'efona chẹ biphyir ẹm-ẹnang ikpokpobha, okhuri da ominanwa kwa Jekọb ọkk'ẹ ọdaakha, ogbe dọk kokhibhi, okhera bi, osi ọkpakkọrikkọ.  
\v 20 Mẹ wọ, Hamọr ọmaana nnwa kwẹ Shẹkẹm afona achina k'ipha s'obhon bi, bẹ atza agbaak anọng pabẹ ochibhi nwa.  
\v 21 Bẹ agbaak ajinọng p'obhon nwa bi, “Ajinọng mba ajibhi ẹmmaana atzima atzor man. Tte bẹ aruk m'irerek saman, bẹ abira arenga mphya, mgba irerek ibar-ọbar s'ibenga be. Mọfha ọtzọkha aminava pabẹ, bẹ abira afha atzọkha aminava paman.  
\v 22 Ajinọng mba akhera bi, aruk ttara man mach'anọng bani ka nttak bi, mọkhaambi osi ajinọng paman ọkpakkọrikkọ, macha bẹ-bẹ asi.  
\v 23 Mokker-okkeri, ẹkhakhaama chabẹ biphyir, ọmaana etzirakpo pya bẹ biphyir éde pyaman. Mẹ wọ, tte mokhera ttara bẹ, mosi mando, ifha bẹ an-aruk ttara man.” 
\p  
\v 24 Wa anọng mba biphyir p'awobh m'ipha akhera ttara Hamọr ọmaana nnwa kwẹ Shẹkẹm. Ofona mẹ, ojinọng kpenamkpen kw'obhon nwa, ofona ochina k'ipha s'obhon bi, bẹ asẹ-ẹ ọkpakkọrikkọ. 
\p  
\v 25 Mada iwu ittaan ikk'ikwọbha sa bẹ asi bẹ ọkpakkọrikkọ, da bẹ atzima awobh k'ọmmamma, va pa Jekọb afa kw'ode Simeọn ttara Lẹvi, vọkka pa Daina, atzini akkangkkaang pabẹ, k'ogbe kw'anọng p'obhon ani chen ahokhi, bẹ afhu ajinọng biphyir.  
\v 26 Bẹ atzima akkangkkaang pabẹ afhu Hamọr ọmaana nnwa kwẹ, Shẹkẹm. Bẹ abira adim k'ọhọhm kwa Shẹkẹm, atzọkha Daina atzima afona.  
\v 27 Mada va mbonggo pa Jekọb akwu are bi, ajinọng p'obhon an-ayim abukhi-abukhi biphyir, bẹ an-adim k'obhon kw'anọng p'asi ọgbaanotte kwabẹ ọgbasadik, achi ọgbọm.  
\v 28 Bẹ atzọkha etzirakpo, ọmaana abhaam, ọmaana nnyanyaang, ttara ekpo kpenamkpen m'obhon nwa, atzima afona.  
\v 29 Bẹ achi ọgbọm k'ọttọhk kpenamkpen fa bẹ are m'obhon nwa, ẹkhakhaama kpenamkpen, ọmaana panọng biphyir, ttara va pabẹ k'ihọhm, atzima afona. 
\p  
\v 30 Mẹ wọ, mada Jekọb okwu oronga odik nwa, oben Simeọn ttara Lẹvi bi, “Bọng akk'aam akha ka dama-dama, bọng abira asi-m mkpukhi anọng pa Kenaan idik, ọmaana anọng pa Pẹriz p'ade anọng p'arukhi m'irek nna. Bọng akk'ara bi, ọnọng-mik ajinọng paman kọhaabi. Anọng mba agbak mbọhk bi, arim-m abẹ, bẹ adim-m ttara ẹhọhmmọr chaam biphyir.” 
\p  
\v 31 Yina, bẹ abhin-ẹ bi, “Shẹkẹm wọ ira ọn-ọtzọk ọgbaanotte kwaman mach'ọzaza o?” 
\c 35  
\s1 Jekọb ọkpa nnam ka Bẹtẹl 
\p  
\v 1 Iwa Ibinọkpaabyi oben Jekọb bi, “Vura achina ka Bẹtẹl, asi oruk kwọ mẹ, abira asi ijafọhnibe mẹ anang Ibinọkpaabyi kw'oyin-ọ abẹ k'ogbe kw'iwa arọbhi ka mbọhk s'agbaanakka, Ẹsau.” 
\p  
\v 2 Mando kwa Jekọb obeni ẹhọhmmọr chẹ, ọmaana anọng biphyir p'awobh ttar-ẹ bi, “Bọng nọbha agbatza p'ikhekhenmon p'awobh k'ottem kwabọng, bọng ahok for sabọng iwur-owur, bọng abira abhona ẹmmaana chabọng.  
\v 3 Mẹ wọ, bọng kwu movura ochina ka Bẹtẹl, kẹ da kaam ńsi ijafọhnibe nnang Ibinọkpaabyi, kw'ọbhaang-m k'ogbe kw'ọmmamma, kw'okk'obiro owobha ttar-m k'ibe kpenamkpen sa nkk'nda.”  
\v 4 Mando kwa bẹ ọtzọk agbatza p'ikhekhenmon biphyir pa bẹ akhaam, ọmaana ekpo py'itzọhng pya bẹ akhe, atte ọbọhk anang Jekọb. Jekọb ọtzọkha pyẹ ọnọhnga k'echirin ch'oak ka Shẹkẹm.  
\v 5 Mẹ wọ, bẹ abina orenga, ojora f'ideden f'Ibinọkpaabyi ọnwa ibhon biphyir s'ibaang bẹ, maa ọnọng kw'ọfha okhubh va pa Jekọb kode. 
\p  
\v 6 Jekọb ọmaana anọng pẹ biphyir apyiri ka Luz, kw'obiro okpena Bẹtẹl, k'ẹkhọma cha Kenaan.  
\v 7 Mẹ wọ kwa Jekọb osi ijafọhnibe, okpe ibe nna, Ẹl-Bẹtẹl\f + \fr 35.7 \ft K'eHiburu, Ẹl-Bẹtẹl oyini Ibinọkpaabyi kwa Bẹtẹl.\f*, okhuri bi, mẹ wọ kw'iwa Ibinọkpaabyi osi ẹjaakhi cha for sẹ ọnang-ẹ, k'ogbe kw'iwa ọrọbhi oji ọgbaanọkka Ẹsau. 
\p  
\v 8 Wa Dẹbọra kw'ode ọrọrọkha kwa Rẹbẹka ope. Bẹ anọhng-ẹ k'echirin ch'oak ch'ewobh k'ebhonho cha Bẹtẹl. Mẹ wọ, bẹ ayeri ibe nnuma “Oak kw'Obhoma.”\f + \fr 35.8 \ft K'eHiburu, bẹ ayeri ibe nna Alon-Bakut, kw'oyini “Oak kw'Obhoma.” \f* 
\p  
\v 9 Mada Jekọb ofon ka Padan-Aram okhuna, Ibinọkpaabyi obiro oyin-ẹ abẹ, ọdẹ-ẹ.  
\v 10 Ibinọkpaabyi oben-ẹ bi, “Kọ akpen Jekọb, yina, Jekọb dọk kakpena, án-akpena Israẹl.” Mẹ wọ, Ibinọkpaabyi ọkpẹ-ẹ Israẹl. 
\p  
\v 11 Ọvaar Ibinọkpaabyi oben-ẹ bi, “Kaam wọ nde Ibinọkpaabyi kw'Ẹfa biphyir; kọ bhon va k'ọhaabh. Ẹkhọma, ọmaana obhon kwa ngọma mfona ma ndaak sọ, avaar abira áfona ka va pa va pọ.  
\v 12 Irek s'iwa nnangi Abraham ọmaana Isaak, rọ sa kaam ńnang-ọ, sẹ rọ sa kaam mbiri ńnang va pa va pọ.”  
\v 13 Mẹ wọ, Ibinọkpaabyi obina oji Jekọb m'ibe nnuma s'okk'atzim ọgbaakha ttar-ẹ, ofona. 
\p  
\v 14 Jekọb ọtzọkha ọtza ofhu m'ibe nnuma s'Ibinọkpaabyi okk'atzim ọgbaakha ọnang-ẹ, osi ẹnanga-ebyengichẹ mẹ, obiro osi ẹnanga ch'etzuk-byengi m'ọtza nwa.  
\v 15 Wa Jekọb oyeri ibe nnuma s'ibinọkpaabyi okk'atzim ọgbaakha ttar-ẹ, Bẹtẹl. 
\s1 Obo kwa Rachẹl ọmaana Isaak 
\p  
\v 16 Wa bẹ abin orenga ka Bẹtẹl, am-achina k'ẹkhọma ch'Ẹphrat. Mada bẹ abhiri eden k'Ẹphrat, ọmaan f'ọgaang-ọgaangi ọttẹwọr osi Rachẹl.  
\v 17 Mada ọm-ọtzọkha ọmmamma bara-mbar kw'ọmaan, kwanọng kw'om-okkeri ọmaan oben-ẹ bi, “Oning-ọ ojor, kkeri kọ akk'nnwa kw'ijinọng abira amaana.”  
\v 18 Mada oji ikponga-nnam-wọhng s'on-ope, okpe nnwa kwẹ Bẹn-Oni.\f + \fr 35.18 \ft K'eHiburu, Bẹn-Oni oyini nnwa kw'ihem saam.\f* Yina, otte Jekọb ọkpẹ-ẹ, Bẹnjamin. \f + \fr 35.18 \ft K'eHiburu, Bẹnjamin oyini nnwa kw'odimbọhk kwaam.\f* 
\p  
\v 19 Mẹ wọ, Rachẹl ope, bẹ anọhng-ẹ k'eden ch'echin k'Ẹphrat, kw'ode Bẹtẹlẹhẹm.  
\v 20 Jekọb ọtzọkha ọtza ofhu ebebe k'epekhubh cha Rachẹl. Maa pyiri ma, ọtza nwuma wọ ode ẹkhọhkha ch'epekhubh cha Rachẹl. 
\p  
\v 21 Jekọb kw'on-okpen Israẹl ochina ororo k'orenga kwẹ, obiro osi ikhira oyongi k'okhubha kwa Migdal-Eder.  
\v 22 Mada Israẹl orukhi m'ẹkhọma nduma, wa Reubẹn odim kẹ oyima Bilha kw'ode ọkkọra-kwanọng kw'otte abẹ, iwa Israẹl okwu ọbhaanga odik nwa. 
\b  
\m Iwa Jekọb obhoni va p'ijinọng jobh obhiri afa: 
\li1  
\v 23 Va p'ijinọng pa Lea ade: 
\li2 Reubẹn kw'ode ocheden nnwa kwa Jekọb, 
\li2 ọmaana Simeọn, ọmaana Lẹvi, ọmaana Juda, ọmaana Isaaka, ttara Zẹbulun. 
\li1  
\v 24 Va pa Rachẹl ade: 
\li2 Josẹph, ọmaana Bẹnjamin. 
\li1  
\v 25 Va p'ijinọng pa Bilha kw'ode ọtzọhmnọng kwa Rachẹl bẹ ade: 
\li2 Dan, ọmaana Naphtali. 
\li1  
\v 26 Va p'ijinọng pa Zilpa kw'ode ọtzọhmnọng kwa Lea bẹ ade: 
\li2 Gad, ọmaana Ashẹr. 
\p Ma wọ ode va p'ijinọng p'iwa Jekọb obhoni ka Padan-Aram. 
\b  
\p  
\v 27 Wa Jekọb ọkpa nnam otzor otte Isaak ka Mamrẹ, kw'ọbaang Kiriyat-Arba (kwa bẹ abira ayeri Hẹbrọn), kẹ da Abraham ọmaana Isaak akk'arurukha.  
\v 28 Biphyir-phyir wa Isaak orukhi cho arọbh ọhawani.  
\v 29 Mẹ wọ, wa Isaak ope k'atzam otzor anọng pẹ p'akk'apa. Wa va pẹ Ẹsau ọmaana Jekọb, anọhng-ẹ. 
\c 36  
\s1 Efonamma ch'Ẹsau 
\p  
\v 1 Ma wọ ode efonamma ch'Ẹsau, kw'obiro okpena Edom. 
\pi1  
\v 2 Wa Ẹsau ọtzọk panọng p'afon Kenaan. Oyok wani okpen Ada, kw'ode nnwa kw'Ẹlọn kw'ofon Het. Ottong panọng afa okpena Oholibama, kw'ode nnwa kw'Ana. Ana wa ode nnwa kwa Zibeọn kw'ofon Hiv.  
\v 3 Ottong panọng attaan okpena Basemat kw'ode nnwa kw'Ishimayẹl, obiro ode ọgbaanọkka kwa Nẹbayọt. 
\pi1  
\v 4 Wa Ada ọmaani Ẹliphaz ọnang Ẹsau, Basemat ọmaan Reuẹl,  
\v 5 Oholibama ọmaan Jeush, ọmaana Jalam, ttara Kora. Ma wọ ode va p'iwa bẹ amaani anang Ẹsau k'ẹkhọma cha Kenaan. 
\pi1  
\v 6 Ẹsau ọtzọkha panọng pẹ, ọmaana va pẹ, ọmaana anọng p'ọhọhm kwẹ biphyir, ọmaana etzirakpo pyẹ ttara nden sẹ, ttara ẹkhakhaama ch'ọkk'ọsa ka Kenaan biphyir, obina oji ọgbaanọkka Jekọb, ọtza oruk k'ibe s'ibhir-obhiri.  
\v 7 Wa irerek sa bẹ anọng afa arukhi bẹ dọk kibeng, okhuri etzirakpo pyabẹ, da ẹkhakhaama chabẹ ẹkk'ẹn-ẹhaahba maa, eyongi k'odem kwa bẹ anọng afa abira aruk ibe rani.  
\v 8 Mẹ wọ, Ẹsau kw'obiro okpena Edom ọtza osi oruk kwẹ k'okhubha kwa mgbegbeho sa Seir. 
\p  
\v 9 Ma wọ ode efonamma ch'Ẹsau kw'ode otte kw'ideden kw'anọng p'Edom k'okhubha kwa mgbegbeho sa Seir. 
\b  
\li1  
\v 10 Ma wọ ode che pa va p'ijinọng p'Ẹsau: 
\li2 Ẹliphaz, nnwa kw'Ada ọmaani 
\li2 Reuẹl, nnwa kwa Basemat ọmaani. 
\li1  
\v 11 Va p'ijinọng p'Ẹliphaz obhoni ade: Teman, ọmaana Ọma, ọmaana Zepho, ọmaana Gatam, ttara Kenaz.  
\v 12 Ẹliphaz kw'ode nnwa kw'Ẹsau wa obiro ọkhaama ọkkọra-kwanọng kw'okpen Timna, kw'ọmaan-ẹ nnwa kw'okpen Amalẹk. Ada kw'iwa ode kwanọng kw'Ẹsau wọ iwa ode ọkka kw'ideden kwa va mba biphyir. 
\li1  
\v 13 Va pa Reuẹl bẹ ade: Nahat, ọmaana Zẹra, ọmaana Shama, ttara Miza. Basemat kw'ode kwanọng kw'Ẹsau wọ iwa ode ọkka kw'ideden kwa va mba biphyir. 
\b  
\li1  
\v 14 Va p'Oholibama kw'ode nnwa kw'Ana, kwa Zibeọn obhoni, p'iwa ọmaani ọnang Ẹsau bẹ ade: Jeush, ọmaana Jalam, ọmaana Kora.  
\v 15 Ma wọ ode avaar-efona p'efonamma ch'Ẹsau p'afon k'ẹnọmma ch'Ẹliphaz, kw'ode ocheden nnwa kw'Ẹsau obhoni. Va mba wa bẹ ade: Teman, ọmaana Ọma, ọmaana Zepho, ọmaana Kenaz, 
\li2  
\v 16 ọmaana Kora, ọmaana Gatam, ttara Amalẹk. Anọng mba bọ iwa atzim mvaar k'ẹnọmma ch'Ẹliphaz k'Edom. Ada wọ wa ode ọkka kw'ideden kw'avaar-efona mba biphyir. 
\li1  
\v 17 Avaar-efona p'afon k'ẹnọmma cha Reuẹl kw'ode nnwa kw'Ẹsau obhoni k'ẹkhọma ch'Edom ade: Nahat, ọmaana Zẹra, ọmaana Shama, ttara Miza. Basemat wọ wa ode ọkka kw'ideden kw'avaar-efona mba biphyir. 
\li1  
\v 18 Avaar-efona p'afon ka ndaak s'Oholibama kw'ode kwanọng kw'Ẹsau, obiro ode nnwa kw'Ana, bẹ ade: Jeush, ọmaana Jalam, ttara Kora. 
\p  
\v 19 Ma wọ ode va p'Ẹsau kw'obiro okpena Edom, ttara avaar-efona pa nnọmma sabẹ biphyir. 
\b  
\p  
\v 20 Ma wọ ode va p'ijinọng pa Seir kw'ofon Họr, p'iwa arukhi m'ẹkhọma nda: 
\li1 Lotan, ọmaana Shobal, ọmaana Zibeọn ttara Ana, 
\li1  
\v 21 ọmaana Dishọn, ọmaana Ẹzẹr, ttara Dishan. Ma wọ ode avaar-efona p'abaHọr, p'afon k'ẹnọmma cha Seir k'Edom. 
\li1  
\v 22 Wa va pa Lotan ade: Hori, ọmaana Homam. Timna kẹ wọ iwa ode ọgbaanọkka kw'ikwanọng kwa Lotan. 
\li1  
\v 23 Wa va pa Shobal bẹ ade: Alvan, ọmaana Manahat, ọmaana Ebal, ọmaana Shepho, ttara Ọnam. 
\li1  
\v 24 Wa Zibeọn obhoni Aiya, ttara Ana. Wa Ana nwa wọ ocheden ọtza ore ngekha s'asi akhọm-ọkhọm, k'ebherede, mada otzim nnyanyaang s'otte Zibeọn, ọtza ọnang ọchattọhk. 
\li1  
\v 25 Wa Ana obhoni Dishọn kw'ode ojinọng, ttara Oholibama kw'ode nnwa kw'ikwanọng. 
\li1  
\v 26 Va pa Dishọn wa bẹ ade: Hẹmdan, ọmaana Ẹshban, ọmaana Itiran, ttara Keran. 
\li1  
\v 27 Va p'Ẹzẹr ade: Bilhan, ọmaana Zaavan, ttara Akan. 
\li1  
\v 28 Va pa Dishan ade: Uz, ttara Aran. 
\li1  
\v 29 Ma wọ ode avaar-efona p'abaHọr: Lotan, ọmaana Shobal, ọmaana Zibeọn, ọmaana Ana,  
\v 30 ọmaana Dishọn, ọmaana Ẹzẹr, ttara Dishan. Ma wọ ode avaar-efona p'abaHọr atzor ka ngọma sabẹ k'irek sa Seir. 
\s1 Avaar-efona p'Edom 
\p  
\v 31 Ma wọ ode avaar-efona p'iwa adabhi Edom yina iwa ọvaarnọng kpenamkpen ọn-ọdabhi anọng p'Israẹl: 
\li1  
\v 32 Bẹla kw'ode nnwa kw'ijinọng kwa Beọr, wa okwu ode ọvaarnọng kw'Edom. Wa odedenmon kwẹ okpen Dinhaba. 
\li1  
\v 33 Mada Bẹla ope, Jobab kw'ode nnwa kwa Zẹra kw'ofon Bozra, on-okwu ode ọvaarnọng. 
\li1  
\v 34 Mada Jobab ope, Husham kw'ofon k'okhubha kwa Teman, on-okwu ode ọvaarnọng. 
\li1  
\v 35 Mada Husham ope, Hadad kw'ode nnwa kwa Bedad on-okwu ode ọvaarnọng. Hadad nwa wọ iwa orim anọng pa Midiyan abẹ k'ẹkhọma cha Moab, okhema bẹ. Wa odedenmon kwẹ okpen Avit. 
\li1  
\v 36 Mada Hadad ope, Samla kw'ofon Masareka, on-okwu ode ọvaarnọng. 
\li1  
\v 37 Mada Samla ope, Shaul kw'ofon Rehobot kw'owobh ọbaanga ọraanga, on-okwu ode ọvaarnọng. 
\li1  
\v 38 Mada Shaul ope, Baal-Hanan kw'ode nnwa kw'Akbọ, on-okwu ode ọvaarnọng. 
\li1  
\v 39 Mada Baal-Hanan kw'ode nnwa kw'Akbọ ope, Hadad on-okwu ọdabh. Wa odedenmon kwẹ okpen Pau. Wa kwanọng okpen Mehetabẹl kw'ode nnwa kw'ikwanọng kwa Matarẹd. Matarẹd wa ode nnwa kw'ikwanọng kwa Me-Zahab. 
\b  
\p  
\v 40 Ma wọ ode avaar-efona p'ẹnọmma ch'Ẹsau atzor ka che pabẹ, ọmaana ka nnọmma sabẹ, ttara ka ngọma sabẹ: 
\li1 Timna, ọmaana Alva, ttara Jetẹt, 
\li1  
\v 41 ọmaana avaar Oholibama, ọmaana Ẹla ttara Pinọn,  
\v 42 ọmaana avaar Kenaz, ọmaana Teman, ttara Mibzar,  
\v 43 ọmaana Magdiyẹl, ttara Iram. Ma wọ ode avaar-efona p'Edom, atzor k'odem kw'iwa bẹ arukhi k'irerek sa bẹ asi oruk kwabẹ. 
\p Wa Ẹsau wọ ode itta kw'ideden kw'anọng p'Edom. 
\c 37  
\s1 Ọdachen fa Josẹph ọttaar 
\p  
\v 1 Wa Jekọb orukhi k'obhon kw'otte okk'orurukha, kw'ode irek sa Kenaan. 
\p  
\v 2 Ma wọ ode odem kw'ẹhọhmmọr cha Jekọb. 
\b  
\p K'ogbe kw'iwa Josẹph ode odikkobh kw'ode cho chi obhiri afa, iwa ọm-ọtzọn votte pẹ abẹ, va pa Bilha ọmaana pa Zilpa am-akkeri etzirakpo py'otte. Wa Josẹph okwu ọpọhra osisi kw'ayok ọnang otte. 
\p  
\v 3 K'ottem kwa va pa Jekọb biphyir, Josẹph wọ iwa ọdaakhi otte ọtzam ọyọhnga va mbonggo, okhuri da iwa obhon-ẹ k'atzam. Mẹ wọ, okhum ọnọhma-baba kw'ọkkẹri adem ọnang-ẹ.  
\v 4 Mada votte are bi, Josẹph ọdaakhi otte kwabẹ idik ọyọhnga bẹ, bẹ an-attaang-ẹ maa, bẹ atzim p'amọm-ọmọm dọk kakhaam pa bẹ agbaakhi anang-ẹ. 
\p  
\v 5 Wa Josẹph okwu ọttaara idachen, mada ọgbaakhi votte pẹ idachen nna, bẹ an-adẹ-ẹ attaanga-ọttaanga.  
\v 6 Oben bẹ bi, “Tzotzokhaan, bọng yonga itzọhng abhaanga idachen sa kaam nttaar e.  
\v 7 K'idachen, kaam nttaar da mowobh k'owoni ọm-ọdabh abarli-khe, nna ngen-okheni nne da ekhe chaam en-ebe idumsẹ, egori ẹyọhnga akhe pabọng. Akhe pabọng an-akhọri chaam akhe k'ottem, bẹ abira arakha nho anang ekhe chaam k'ikpokpobha.” 
\p  
\v 8 Votte pẹ abhin-ẹ bi, “Ode bi kọ am-achibhi bi, maman owobha k'irekh-irek kwọ o? Kọ achibhi k'odik ọkkakka bi, kọ wọ áde man ọvaarnọng o?” Mẹ wọ, bẹ an-adẹ-ẹ attaanga-ọttaanga, okhuri idachen sẹ ọmaana idik s'okk'bẹ ọgbaakha. 
\p  
\v 9 Wa Josẹph obiro okwu ọttaara idachen idọdọk, ọtzọkha sẹ ọgbaak votte pẹ, oben bi, “Bọng yong-m itzọhng, kaam nkk'idachen idọdọk mbiri nttaara e. Nttaar da ewuchen, ọmaana ophe, ttara ndodori jobh obhiri wani nchung nnang-m ikpokpobha.” 
\p  
\v 10 Mada Josẹph obiro ọgbaak otte idachen s'ọttaar, otte ọkpẹ-ẹ eden bi, tte oningi odik-dema nwa dọk ọgbaakhi, oben bi, “Bọng idachen-dema s'attaar mẹ? Ode bi kọ ahokhi k'odik ọkkakka bi, kaam ọmaana akka, ttara votte pọ mochunga nho k'irerek ọnang-ọ ikpokpobha o?”  
\v 11 Mẹ wọ, wa votte pa Josẹph an-akhaama ottemmama ttar-ẹ. Yina, Jekọb kw'ode otte kwẹ on-okhe idik nna k'ettem. 
\s1 Votte pa Josẹph akpẹ-ẹ anang aphyaphya p'Ishmayẹl 
\p  
\v 12 Wa ewu dani votte pa Josẹph an-atzima etzirakpo py'otte kwabẹ, atza anang ọchattọhk kẹ ọbaanga Shẹkẹm.  
\v 13 Iwa Jekọb oben Josẹph bi, “Kọ arong kẹ bi votte pọ awobh kẹ da bẹ anangi etzirakpo ọchattọhk kẹ ọbaanga Shẹkẹm. Kaam nna ndọhm-ọ kẹ da bẹ awobh.” 
\p Josẹph obhina bi, “Iya itta, tzọhm-m e.” 
\p  
\v 14 Iwa Israẹl ttara Josẹph awobh k'Ẹttẹri cha Hẹbrọn, mẹ wọ, Israẹl ọtzọhm Josẹph bi, ọtza oror votte pẹ ọmaana etzirakpo, kẹ da bẹ awobh abaanga Shẹkẹm. 
\p Mada Josẹph opyiri ka Shẹkẹm,  
\v 15 ojinọng wani ọrẹ-ẹ kẹ da om-ottena k'iwoni, ọbọbh-ẹ bi, “Mbọng f'am-aror o?” 
\p  
\v 16 Josẹph obhin-ẹ bi, “Kaam mminnor votte paam e, tzotzokhaan na afha agbaakh-m ibe sa bẹ am-anang etzirakpo ọchattọhk o?” 
\p  
\v 17 Ojinọng nwa obhina bi, “Bẹ akk'abina manya e. Kaam mmaang da bẹ abeni ayok bi, ‘Tte mochina ka Dọtan.’ ” 
\p Mando kwa Josẹph ofon ọtza okhebha votte pẹ ka Dọtan.  
\v 18 Yina, bẹ arẹ-ẹ da om-orenga okwu k'odenmir. Yina ọbaanga kẹ da bẹ awobh, bẹ akk'nttọhna akyera sa bẹ afhẹ-ẹ. 
\p  
\v 19 Wa bẹ aben ayok bi, “Bọng kker e, ọttaar-ọdachen nwuma wọ om-okwu kana e.  
\v 20 Bọng kwu, tte mọfhẹ-ẹ ọbhari k'ipekhuma rani mẹ, ifha mọkk'ọbhana, mọtza ọgbaak otte kwaman bi, etzen ch'ẹtzam dani dọ ẹfhẹ-ẹ, ifha mowobha ma ore, odem kw'ọdachen mvuma fẹ obiro okwu ode mach'ochibhi.” 
\p  
\v 21 Yina, mada Reubẹn ọbhaang odik nwa, okhonga bi, ọkkaan-ẹ ka mbọhk sa bẹ, oben bẹ bi, “Tte moning-ẹ ofhufhu-ofhu e.  
\v 22 Tte mokhinggẹ ọbhar-ẹ m'ipekhuma nna s'ebherede. Bọng ọnọng kàfhu.” Iwa Reubẹn ọgbaakhi odik nwa ifha ọkkaana akpen pa Josẹph, ifha obiro otzim-ẹ ochena otte kwabẹ. 
\p  
\v 23 Mada Josẹph opyiri kẹ da votte awobh, bẹ abọkh-ẹ awọra ọnọhma-baba jibh-anjibh kw'ọfọr ka for.  
\v 24 Bẹ atzọkh-ẹ abhari k'ipekhuma s'asi anade. 
\p  
\v 25 Mada bẹ an-awobh ẹwọr bi bẹ achi ọchattọhk, bẹ atzini chen akkeri k'ororo, are da ẹkhaan ch'aphyaphyaa p'Ishimayẹl p'am-atza orenga, am-afona k'obhon kwa Gilead ahakha, ttara akamẹl pabẹ p'atzọhk ekpo py'ẹdaami eruk, ọmaana ana p'adaami eruk k'adem-k'adem, pa bẹ atzim am-ahakha achina k'Ijip. 
\p  
\v 26 Mẹ wọ, Juda ọbọbh votte pẹ bi, “Mbọng vọ óde iru saman idikha mofhu ọgbaanotte kwaman modubha obo kwẹ o?  
\v 27 Tte mọkpẹ-ẹ ọnang anọng mba p'Ishimayẹl. Tte mọning-ẹ ofhu, mgba kẹ ode ọgbaanotte kwaman kwa mofon k'izi rani.” Mẹ wọ, bẹ biphyir akhera odik kwa Juda ọgbaakhi. 
\p  
\v 28 Mada aphyaphyaa mba p'Ishimayẹl p'abira ade anọng pa Midiyan abembi akwọbha, votte pa Josẹph arọbh-ẹ k'ipekhuma sa bẹ akk'ẹ abhari. Bẹ akpẹ-ẹ anang aphyaphyaa mba k'ashẹkẹl p'asilva ẹrọbh, bẹ atzima Josẹph afona k'Ijip. 
\p  
\v 29 Mada Reubẹn ọkpa nnam k'ipekhuma nnuma s'ira abẹ abhari Josẹph, ore bi kẹ dọk kode, ọjaakhi ọbara f'ọfọr.  
\v 30 Ofona otza okhebha votte kẹ da bẹ awobh, ọgbaak bẹ bi, “Nnwa nwuma kẹ dọk kode! Ma kaam nna nsi yan ma o?” 
\p  
\v 31 Mẹ wọ, bẹ atzọkha evu dani afhu, bẹ atzọkha ọnọhma kwa Josẹph arana k'izi s'evu cha bẹ afhu.  
\v 32 Bẹ atzima ọnọhma-baba nwuma abhana atza akhọhkha otte kwabẹ, agbaakh-ẹ bi, “Itta, kkeri ọnọhma-baba kw'am-ore. Kwa nnwa kwọ wọ o?” 
\p  
\v 33 Otte otzin ọnọhma nwa, oben bi, “Ọnọhma kwa nnwa kwaam wọ ma e! Etzen ch'etzam dani ẹkk'ẹfha, k'odik ọkkakka bẹ akk'Josẹph achikhi k'abir-ibiri.” 
\p  
\v 34 Mẹ wọ, Jekọb ọjaakhi ọbara f'ọfọr ka for, ọtzọkha abara-bina ọfọra, on-owobha ka nkwu-osisi sa nnwa kwẹ k'iwu haabhada.  
\v 35 Va pẹ p'ijinọng ọmaana p'ipanọng biphyir akwu adema ttar-ẹ, ifha bẹ adin-ẹ nttem. Yina, Jekọb kokher bi va ndin-ẹ nttem, on-oben bi, “Mma e, kaam nwobha ka nkwu-osisi sa nnwa kwaam maa, mpe ndor-ẹ.” Mẹ wọ, otte obhom! 
\p  
\v 36 Ayongi mẹ, anọng mba pa Midiyan akk'Josẹph akpa k'Ijip anang Pọtipha, kw'ode ọkhaan-nọng wani kwa Phero, obiro ode oho kw'anọng p'am-abaabh-ẹ. 
\c 38  
\s1 Juda ọmaana Tamar 
\p  
\v 1 K'ogbe nwuma, Juda obina oji votte pẹ, ọtza oruk ọbaanga ojinọng wani kw'okpen Hira, kw'ofon Adulam.  
\v 2 Kẹnya Adulam wọ kw'iwa Juda okhebh ominanwa wani kw'okpen Shua kw'otte ofon Kenaan. Ọtzọk ominanwa nwa k'ọbada, obiro oyim-ẹ abẹ. 
\p  
\v 3 Ominanwa nwa okwu otzima ibhọr, ọmaan nnwa kw'ijinọng, kwa bẹ akpe Ẹr. 
\p  
\v 4 Ominanwa nwa obiro okwu otzima ibhọr, ọmaan ojinọng, ọkka ọkpẹ-ẹ Ọnan.  
\v 5 K'ogbe kw'iwa Juda owobh ka Kezib, wa ominanwa nwa obiro okwu otzima ibhọr, ọmaan nnwa kw'ijinọng ọdọdọk, ọkpẹ-ẹ Shẹla. 
\p  
\v 6 Mada va mba abari, otte kwabẹ Juda ọtzọkha kwanọng kw'okpen Tamar ọnang ocheden-nwa kwẹ Ẹr, k'ọbada. 
\p  
\v 7 Yina, Ẹr kw'ode ocheden-nwa kwa Juda osi ẹmmaana-tzama k'itzitzikha s'Ọvaar Ibinọkpaabyi. Mando kw'Ọvaar Ibinọkpaabyi ọtzọkha akpen pẹ, ope. 
\p  
\v 8 Mada Ẹr ọkk'ọpa, Juda oben Ọnan bi, “Kọ akhaambi asi mach'ẹmmaana chaman ede. Rọhng atza ayima ttara kwanọng kw'agbaanakka opfunọng, ifha orenga ma kọ, agbaanakka ọkhaama va.”  
\v 9 Yina, mada Ọnan orong bi, nnwa kpenamkpen kw'obhon ma ndaak sa kwanọng kw'ọgbaanọkka, kwẹ kode. Ogbe kpenamkpen kw'oyim kwanọng ọgbaanọkka abẹ, ọm-ọja adima ọbhari k'iyaan ifha kwanọng nwa oningi ibhọr otzim, ọmaan va ọnang ọgbaanọkka kw'ọkk'ọpa.  
\v 10 Wa odik nwa ode odik-ttama k'itzitzikha s'Ọvaar Ibinọkpaabyi. Mẹ wọ, Ọvaar Ibinọkpaabyi ọtzọkha akpen p'Ọnan. 
\p  
\v 11 Mẹ wọ, Juda oben ọnyẹ kwẹ Tamar bi, “Kọ rọhng atza awobha epopa k'atte k'ọhọhm, matzẹmaa nnwa kwaam Shẹla opyiri k'odem kw'ọtzọkh-ọ k'ọbada e.” Wa obeni mando okhuri da ojor-ẹ bi, “Bẹ afha afhu Shẹla ofhu macha bẹ afhu ayok.” Wa Tamar obina ọkpa nnam k'otte k'ọhọhm.  
\v 12 Okwu otzuma k'ogbe mẹ, kwanọng kwa Juda, kw'ode nnwa kwa Shua okwu ope. K'ogbe kwa Juda okk'ottem-dini k'obo kwa kwanọng ọn-ọkhaama, obina ochina ka Timna, kẹ da bẹ am-aphyiri arukhimaan pẹ ophyubha, oyokh-odikkobh kwẹ Hira kw'ofon Adulam ọtzọn-e abẹ. 
\p  
\v 13 Mada bẹ agbaakhi Tamar bi, “Otte kw'odim kwọ oreng k'eden okwuma k'obhon kwa Timna bi, ọtza ophyiri arukhimaan pẹ ophyubha.”  
\v 14 Tamar ọtza ọwọra epopa-nya, ọtzọkha ibara s'ide ọphyọhng-ọphyọhng obubha itzitzikha sẹ, ọtza owobha ẹwọr k'ẹbaakhamma ch'obhon kw'Ẹnayim, kw'owobh k'eden ch'achin k'obhon kwa Timna. Wa Tamar ore bi, Shẹla ọkk'ọn-ọbara k'odem kw'ira ọn-ọtzọkh-ẹ k'ọbada, wa mando kosi.  
\v 15 Mada Juda ọrẹ-ẹ, ochibhi bi ọzaza-kwanọng wọ, da ọkk'ọphyọhng otzima obubha itzitzikha sẹ.  
\v 16 Wa Juda korong bi, kwanọng kwa nnwa kwẹ wọ, on-ojekha okhebh-ẹ k'eden okhubha, oben bi, “Kọ kwu, tte nyim-ọ abẹ.” Kwanọng kwa nnwa ọbọbh-ẹ bi, “Kọ ánang-m mbọng idikha kaam nkher bi, nyim-ọ abẹ o?” 
\p  
\v 17 Juda oben bi, “Kaam ńnọbha ovu-nwa k'avu paam ńdọhm ńchen-ọ.” 
\p Ọn-ọbọbh-ẹ bi, “Kọ na abhikha ọttọhk kpenamkpen fọ, fa kaam nhok maa, atzima ovu-nwa nwuma akwu o?” 
\p  
\v 18 Mẹ wọ, Juda ọben bi, “Mbọng fa kaam mfha mmikha ma o?” 
\p Kwanọng nwa obhin-ẹ bi, “Kọ bhikha ogimma kwọ kw'ẹdọhngi kw'otzim che chọ, ọmaana ochikhura kw'atzim k'ọbọhk.” Mẹ wọ, ọtzọkha ekpo mbya otte ọbọhk ọnang-ẹ. Mada ọkk'ọsa mando, kwanọng nwa okhera oyim-ẹ abẹ, mẹ wọ, Tamar otzima ibhọr sa Juda ọkhẹ-ẹ. 
\p  
\v 19 Mẹ wọ, Tamar ofona ọtza obhona ọbara, obiro ọtzọkha ẹnya chẹ ch'epopa, ọfọra. 
\p  
\v 20 Mada Juda ọn-ọtzọhmi oyokh-odikkobh kwẹ Hira kw'ofon Adulam, ttara ovu-nwa kw'otzima obhek ekpo pyẹ py'obhik ka kwanọng nwa ka mbọhk, ọtza opyiri, kwanọng nwa kokhebh. 
\p  
\v 21 Iwa Hira ọn-ọbọbh ajinọng bani p'obhon nwa bi, “Ọzaza-kwanọng nwa kw'ira owobh m'ọkkadeden ọkhaan-ọkhaan kw'Ẹnayim, ko o?” 
\p Bẹ abhin-ẹ bi, “Ọzaza-kwanọng manda wani ma otzim-om-owobha.” 
\p  
\v 22 Mẹ wọ, Hira ofona ọkpa nnam kẹ da Juda owobh, ọgbaakh-ẹ bi, “Kaam kẹ kinne e. Ayongi mẹ, ajinọng p'arukhi abaanga mẹ agbaakh-m bi, ọzaza-kwanọng manda wani m'ibe nnuma otzim-om-owobha.” 
\p  
\v 23 Mẹ wọ, Juda oben bi, “Tte kẹ otzima ekpo mbyuma ọrọhng, oni mando ode, mon-óde ọhamma-dik k'anọng k'itzitzikha e. Kaam arang nna mbiri nsi, mgba nkk'ọ ovu-nwa nnanga bi achen-ẹ, kẹ kare.” 
\p  
\v 24 Okwu opyiri ọttọhk k'aphe attaan, Juda okwu ọbhaanga bi, “Tamar kw'ode kwanọng kwa nnwa kwọ osi azaza-kpen maa, okk'ibhọhr otzima.” 
\p Iwa Juda ọn-ọnang ẹfa bi, “Bẹ atzim-ẹ ayin k'iyaan, ifha bẹ akwọm-ẹ ekhekhebhi.” 
\p  
\v 25 Mada bẹ atzim-ẹ ayin k'iyaan bi bẹ akwọmi, Tamar ọtzọhm ẹkkaabha ọnang otte kw'odim, oben bi, “Kaam ndim ibhọr nnang ojinọng kw'ọkhaam ekpo mbya e. Kọ kkeri ogimma nwa kw'ẹdọhngi, ọmaana ochikhura nwa s'ode na afha atzin pyẹ ka more.” 
\p  
\v 26 Mada Juda ore ekpo mbyuma, otzin pyẹ, oben bi, “Kẹ wọ otzor-otzor e, kaam nkk'ntta k'osisi kwaam da nnẹ-ẹ ndọk, nnang nnwa kwaam Shẹla.” Wa Juda Tamar abẹ dọk koyim. 
\p  
\v 27 Mada ogbe on-opyiri kw'ọmaan, wa va afa p'ijinọng bọ awobh-ẹ k'ẹbhọr.  
\v 28 Mada om-okhonga bi ọmaan, nnwa wani oyin ọbọhk k'iyaan, kwanọng kw'okker-ẹ ọmaan ọtzọkha ididikha ọkpẹ-ẹ k'ọbọhk oben bi, “Oyok nwa wọ ochi eden oyin.”  
\v 29 Mada nnwa nwa on-obiro ọkpa nnam okhe ọbọhk k'ẹtzaanga, ọgbaanọkka on-ochi eden oyin, kwanọng kw'okker-ẹ ọmaan on-oben bi, “Manda wọ kwa kọ an-areng ayin o!” Mẹ wọ, bẹ kpẹ-ẹ Pẹrẹz.\f + \fr 38.29 \ft K'eHiburu, Pẹrẹz oyini odem kw'oreng oyin.\f* 
\v 30 Ayongi mẹ, ọgbaanọkka obiro oyin ttara edik ch'ekhori-ihiho k'ọbọhk, bẹ akpẹ-ẹ Zẹra.\f + \fr 38.30 \ft K'eHiburu, Zẹra oyini iyaan, obiro oyin okhor-izizi.\f* 
\c 39  
\s1 Josẹph ọmaana kwanọng kwa Pọtipha 
\p  
\v 1 Mada iwa anọng p'Ishimayẹl akk'Josẹph atzima achina k'Ijip, wa Pọtipha kw'ode ọkhaan-nọng wani kwa Phero, obiro ode oho kw'anọng p'abaabh-ẹ, odebh Josẹph ka mbọhk anọng mba. 
\p  
\v 2 Mada Josẹph orukhi k'ọhọhm kw'itta kwẹ kw'ofon Ijip, wa Ọvaar Ibinọkpaabyi owobh ttar-ẹ, obiro osi idik ijibh inang-ẹ.  
\v 3 Mada itta kwẹ on-ore bi, Ọvaar Ibinọkpaabyi owobh ttara Josẹph, obiro ore bi, Ọvaar Ibinọkpaabyi ọnang-ẹ owujibha k'idik kpenamkpen s'osi,  
\v 4 wa Josẹph ọtzọkha ọphyaam k'itzitzikha sẹ, ọn-ọtzọkh-ẹ mach'ọtzọhmnọng kwẹ. Mẹ wọ, Pọtipha ọn-ọtzọkha ọttọhk kpenamkpen f'ọkhaam ọnang-ẹ bi, okkeri.  
\v 5 Ttẹwọr k'ogbe kw'iwa otte ẹhọhmmọr chẹ ọmaana ọttọhk kpenamkpen f'ọkhaam ọbọhk ọnang Josẹph bi okkeri, wa Ọvaar Ibinọkpaabyi oreng Josẹph abẹ odo ẹhọhmmọr ch'Ojipnọng nwa. Wa ẹdaa ch'Ọvaar Ibinọkpaabyi en-ewobh k'ọttọhk kpenamkpen f'ọkhaam k'ọhọhm ttara k'iwoni sẹ.  
\v 6 Mẹ wọ, odik kw'iwa obiro ọkpakha Pọtipha oyongi ọchattọhk f'ochi kode, da okk'idik biphyir s'ọkhaam ọbọhk ọtta ọnang Josẹph bi, okkeri. 
\p Wa Josẹph ojibhi odikkobh obiro ode ọnọng kw'ofhu ka for \it bi gbuk\it*.  
\v 7 Okwu opyiri k'ogbe mẹ, kwanọng kw'itta kwẹ om-otzini chen okkeri Josẹph adadaakha-chen, oben-ẹ bi, “Kwu yim-m abẹ.” 
\p  
\v 8 Yina, Josẹph obhum, oben kwanọng nwa bi, “Itta kwaam okk'idik sẹ s'ọkhaam biphyir ọbọhk ọtta ọnang-m bi, nkkeri. Odik manda wani kw'obiro ọkpakh-ẹ dọk kode.  
\v 9 M'ọhọhm nwa, ọnọng ọdọdọk kw'ọkhaam ẹfa ọyọhnga kaam kode. Odik manda wani kw'itta kwaam obiro ọram-m, kw'oyongi kọ kw'ade kwanọng kwẹ, kode. Kaam nna nnenga yan nsi itzama, ttara ọkhọngkwuri-dik-dema nwa, mpyibh k'itzitzikha s'Ibinọkpaabyi o?”  
\v 10 Chibhi da kwanọng nwa ọyakhi Josẹph atzim k'ewu kpenamkpen bi, oyim-ẹ abẹ, Josẹph kokher. 
\p  
\v 11 Wa ewu dani, Josẹph ọtza odim k'ọhọhm bi, otza osi itzọhmbọhk sẹ, k'ogbe kw'ọtzọhmnọng ọdọdọk manda wani oni k'ọhọhm ode.  
\v 12 Kwanọng nwa ọbọkha Josẹph k'ittọhk-kwuma s'ọpaabh k'erin, ọben bi, “Kwu yim-m abẹ!” Yina, Josẹph otte ittọhk-kwuma sẹ ọbọhk ọnang-ẹ, ọrọbh oyin k'iyaan. 
\p  
\v 13 Mada kwanọng nwa ore bi, ọkk'ọrọbha ọjẹ-ẹ ittọhk-kwuma sẹ ka mbọhk sẹ oyin k'iyaan,  
\v 14 on-oyeri atzọhmnọng pẹ p'ọhọhm, oben bẹ bi, “Bọng akk'ara, odim kwaam otzim oHiburu-nọng nwa okwu ma bi, okwu ọnang man che-tzama! Odimi okhebh-m k'ọhọhm bi, okwu oyim-m abẹ, yina, kaam nna mkpẹbhi ẹmọng k'ẹrọng e.  
\v 15 Mada ọbhaang ẹmọng cha mkpẹbhi nnor ẹkkaana, mẹ kw'ọn-ọrọbhi oji ittọhk-kwuma sẹ ma oyin k'iyaan e.” 
\p  
\v 16 Ọn-ọtzọkha ittọhk-kwuma nna ohok maa, itta kwa Josẹph okhuna.  
\v 17 Mẹ wọ, ọtzọkha odik nwa ọgbaakh-ẹ bi, “Obira nwa kw'ode oHiburu-nọng, kw'atzim achena man ma, odimi okhebh-m k'ọhọhm bi, okwu oyim-m abẹ ọnang-m che-tzama.  
\v 18 Mada ọn-ọbhaang ẹmọng cha kaam mkpẹbhi nnor ẹkkaana, ọn-ọrọbh oyin k'iyaan oji ittọhk-kwuma sẹ ma ttar-m.” 
\p  
\v 19 Mada itta kwa Josẹph ọbhaang odik kwa kwanọng kwẹ ọgbaakh-ẹ, oben bi, “Manda wọ kw'obira kwọ osi-m e”, ettem ẹdọkh-ẹ k'idendama.  
\v 20 Mẹ wọ, itta kwa Josẹph, ọbọkha Josẹph ọtzọhm mgbakkọhbh, k'ibe sa bẹ agbakhi agbakkọkkọhbha p'ọvaarnọng. Wa bẹ ahokh-ẹ kẹ. 
\p Yina, mada Josẹph owobh ka mgbakkọhbh,  
\v 21 wa Ọvaar Ibinọkpaabyi owobh ttara Josẹph, osi ejibha ọnang-ẹ, obiro ọsẹ-ẹ ọtzọkha ọphyaam k'itzitzikha s'oho kw'akker-agbakkọkkọhbha.  
\v 22 Mẹ wọ, oho nwa kw'akker-agbakkọkkọhbha ọtzọkha Josẹph osi oho kw'agbakkọkkọhbha biphyir, obiro ọnang-ẹ ẹfa ch'odik kpenamkpen k'ọgbakkọbh-họhm.  
\v 23 Wa oho kw'akker-agbakkọkkọhbha ọn-ọrọbha mbọhk sẹ k'odik kpenamkpen kw'oyim ọnang Josẹph bi okkeri, okhuri da Ọvaar Ibinọkpaabyi owobh ttara Josẹph, obiro ọnang-ẹ owujibha k'odik kpenamkpen kw'osi. 
\c 40  
\s1 Josẹph osi ẹjaakhi ch'ọdachen f'agbakkọkkọhbha attaar 
\p  
\v 1 K'ogbe wani, wa ọnọng kw'ọm-ọnang ọvaarnọng kw'Ijip atzuk, ọmaana ọnọng kw'om-osi ọchattọhk fẹ, akhaam ottotto ttara itta kwabẹ, kw'ode Phero, ọvaarnọng kw'Ijip.  
\v 2 Wa Phero ọdọkh-ẹ ttara atzọhmnọng mba pẹ afa, p'ade oho kw'anọng p'am-anang ọvaarnọng atzuk, ọmaana oho kw'anọng p'am-asi ọchattọhk anang ọvaarnọng.  
\v 3 Wa ọtzọkha bẹ ọgbak k'ọhọhm kw'oho kw'akker-agbakkọkkọhbha, k'ọgbakkọhbh-họhm nwuma wani kwa bẹ agbakhi Josẹph.  
\v 4 Mando kw'oho kw'akker-agbakkọkkọhbha ọtzọk bẹ otte ọbọhk anang Josẹph, Josẹph okkeri bẹ. 
\p Mada anọng mba afa akk'mgbakkọhbh ayima k'ogbe mẹ,  
\v 5 k'erungiwu dani, ajinọng mba afa, oyok kw'om-okhe atzuk ọnang ọvaarnọng kw'Ijip, ọmaana oyok kw'om-osi ọchattọhk, pa bẹ agbakhi k'ọgbakkọhbh-họhm, ọnọng-ọnọng ọttaara idachen sẹ s'ikhaam ẹjaakhi ch'ede ngọmi ka s'oyok ọttaar. 
\p  
\v 6 Mada Josẹph okwu k'ekpebha, on-ore bi, bẹ awobh nkwu-osisi.  
\v 7 Mẹ wọ, ọn-ọbọbh akhaan-nọng pa Phero pa bẹ atzọni ayima mgbakkọhbh, k'ọhọhm kw'itta kwẹ bi, “Ode yan kwa nttem ibhemi bọng mando mayina o?” 
\p  
\v 8 Bẹ abhin-ẹ bi, “Man anọng afa ọttaar ọdachen. Yina, ọnọng kw'osi ẹjaakhi ch'ọdachen mva ọnang man kode.” 
\p Josẹph on-oben bẹ bi, “Tzotzokhaan bọng gbaakh-m ọdachen fabọng, Ibinọkpaabyi wọ ọm-ọnang ẹjaakhi ch'ọdachen biphyir e.” 
\p  
\v 9 Mẹ wọ, oho kw'anọng p'am-anang ọvaarnọng atzuk, ọgbaak Josẹph idachen sẹ, oben-ẹ bi, “Kaam nttaar idachen da echi cha grep ebe-m k'itzitzikha.  
\v 10 Echi nda cha grep ẹkhaam abọhnga attaan. Mada abọhnga mba ayini agbok \it bi kpaar\it*, bẹ attẹwọr asi adodo, an-awọm aduk p'agrep bẹ abira akhor.  
\v 11 K'ọbọhk kwaam, ndima nkkọbh kw'ọvaar Phero, kwa myaan aduk mba p'agrep ngẹ.” 
\p  
\v 12 Mẹ wọ, Josẹph ọgbaakh-ẹ bi, “Ẹjaakhi ch'idachen sọ ede bi, abọhnga mba attaan, abe anang iwu ittaan.  
\v 13 K'iwu ittaan k'itzitzikha, Phero ọ́rọbh-ọrọbha ka mgbakkọhbh, obiro ọkpa nnam ọ́nang-ọ ewobha chọ. Kọ ábira ákhẹ-ẹ nkkọbh ka mbọhk, mach'iwa am-akkekkeni asi.  
\v 14 Yina, mada idik ijibh inang-ọ, k'ọphyaam fọ, tzotzokhaan kaam karaama o. Gbaak Phero bi, kaam nwobh ka o, ifha akkaan-m nyin ma mgbakkọhbh nna.  
\v 15 Kaam iwa bẹ abọkh-m k'ẹfa k'irek s'aHiburu atzima akwu ma. Kaambi ma wọ, kaam odik manda wani kinji kw'ira on-orenga mẹ nyima mgbakkọhbh nna.” 
\p  
\v 16 Mẹ wọ, mada oho kw'anọng p'am-asi ọchattọhk f'ọvaarnọng ore bi, ẹjaakhi ch'idachen s'oyok ekk'ejibha ẹnang-ẹ, on-oben Josẹph bi, “Kaam mbiri nttaara idachen e. K'idachen, ndọhk okhiriba ọttaan fa brẹd k'eho.  
\v 17 K'ikhiriba s'inan k'ebir-ebir kw'ayok, ẹchakpo k'adem-k'adem pya Phero om-ochi pya bẹ akk'asa ewobha kẹ. Yina, ọnọhn f'ẹrọng om-okwu ochi ẹchakpo mbya pya ndọhk k'eho.” 
\p  
\v 18 Josẹph oben bi, “Ẹjaakhi ede bi, okhiriba mva ọttaan, obe ọnang iwu ittaan.  
\v 19 K'iwu ittaan k'itzitzikha, Phero ọ́rọbh-ọrọbha ka mgbakkọhbh, obiro ọ́nang ẹfa bi, bẹ akpaar-ọ eho, bẹ abira ádabh obukhi kwọ k'echi, ọnọhn mach'attẹrẹ áchi ayaara pọ biphyir.” 
\p  
\v 20 M'ewu nduma ch'ettong ittaan, Phero obher atzọhmnọng pẹ biphyir, osi ọdadaami kw'otzim ojima ewu ch'ọmaan. Ọnang ẹfa bẹ atza arọbha oho kw'anọng p'am-anang ọvaarnọng atzuk, ọmaana oho kw'anọng p'am-asi ọchattọhk anang ọvaarnọng, obe bẹ k'ottem kw'ayok:  
\v 21 ọkpa nnam ọnang oho kw'anọng p'am-anang-ẹ atzuk ewobha chẹ maa, om-obiro okhe Phero atzuk ka mbọhk, mach'iwa om-okkekkeni osi.  
\v 22 Yina, ọn-ọnang ẹfa bi, bẹ akpaara eho ch'oho kw'anọng p'am-asi ọchattọhk anang ọvaarnọng, bẹ abira adabh obukhi kwẹ k'echi atzor macha Josẹph ọkk'ẹjaakhi ọtzam ọsa. 
\p  
\v 23 Yina, oho kw'anọng p'am-anang ọvaarnọng atzuk, ọn-ọraama bi ọgbaak ọvaarnọng odik okhuri Josẹph kw'iwa otzim owobh ka mgbakkọhbh. 
\c 41  
\s1 Idachen sa Phero ọttaar 
\p  
\v 1 Mada cho afa akk'akwọbha, Phero ọttaara idachen: k'idachen ọttaar da obe k'ọraanga kwa Nile ọkhaan-ọkhaan,  
\v 2 ore da abhaam azenamfa p'ajibhi for, abira ade \it bi dọrọdọrọ\it* ayini k'ọraanga kwa Nile akwu achi araraari p'ameni m'ọraanga ọkhaan-ọkhaan.  
\v 3 Ayongi mẹ, abhaam azenamfa adọdọk p'akkokh-okkokhi abira apyibh ka for, ayin abaanga mbonggo p'ajibhi for p'awobh m'ọraanga kwa Nile ọkhaan-ọkhaan.  
\v 4 Abhaam mba p'akkokh-okkokhi abira apyibh ka for achi p'ajibhi ka for. Wa Phero ọphyọbha k'ọda. 
\p  
\v 5 Iwa Phero obiro ọtza oyima, ọn-ọttaara idachen idọdọk. Ore ẹbọkparin dani ch'etzim abhọra azenamfa p'abari ẹfa, abira ajibh-ojibh.  
\v 6 Ayongi mba, abọkpa-bhọra azenamfa adọdọk p'akkokh-okkokhi, p'ọphapha kw'ofon k'okhubha kw'ewuchen em-eyin ogwum, abira ayin.  
\v 7 Mẹ wọ, abọkpa-bhọra mba azenamfa p'akkokh-okkokhi amyi azenamfa p'ajibhi for biphyir. Mada Phero ọkk'ọda ọphyọbha, mẹ kw'on-orong bi, idachen s'ọttaar. 
\p  
\v 8 Mada ewu en-ehobh, achibhi ayak Phero atzim, ofona mẹ, ọtzọhm anọng bi, bẹ ayeri anọng p'am-asi mbọhng biphyir, ọmaana atzim-nọnga-nọng kpenamkpen makhọra Ijip. Mada bẹ akwu apyiri, ọgbaak bẹ ọdachen f'ọttaar. Yina, ọnọng manda wani kw'ofha osi ẹjaakhi ch'ọdachen fa Phero kode. 
\p  
\v 9 Mẹ wọ, oho kw'anọng p'am-anang Phero atzuk, oben bi, “Mayina kaam nkk'ottotto kwaam njima.  
\v 10 Wa ọkhaam ogbe kwa Phero ọdọkhi ettem ttara atzọhmnọng pẹ, wa ọtzọhm kaam, ọmaana oho kw'anọng p'am-asi ọchattọhk mgbakkọhbh, k'ọhọhm kw'oho kw'akker-agbakkọkkọhbha.  
\v 11 Wa k'erungiwu dani, man anọng afa mọttaar ọdachen ngọmi-ngọmi, idachen kpenamkpen ikhaama ẹjaakhi chẹ.  
\v 12 Wa mọtzọkha ọdachen mva ọgbaak oHiburu-dikkobh wani kw'ode ọtzọhmnọng kw'oho kw'akker-agbakkọkkọhbha. Wa mọgbaakh-ẹ ọdachen faman, kẹ obiro osi ẹjaakhi ch'ọdachen mva ọnang man.  
\v 13 Wa idik nnuma iyini itzor mach'osi ẹjaakhi. Kaam wa bẹ ọkpa nnam ọnang-m ewobha chaam, yina, wa bẹ arena oyok k'edik.” 
\p  
\v 14 Iwa Phero ọtzọhm anọng bi, bẹ atzima Josẹph akwu. Mẹ ẹba mẹ, bẹ atza arọbh-ẹ k'ọgbakkọhbh-họhm atzima akwu. Mada Josẹph okk'agbaphyubha pẹ ophyiri, obiro obhona ọbara f'ọfọr ka for, ofona ọtza okhebha Phero. 
\p  
\v 15 Phero oben Josẹph bi, “Kaam nttaar idachen, s'ọnọng manda wani oni ẹjaakhi ọfha ọnang. Yina, kaam nkk'mmaanga bi, kọ am-asi ẹjaakhi ch'ọdachen anang anọng.” 
\p  
\v 16 Josẹph obhina Phero bi, “Kaam ẹfa kingaam bi, mminsi ẹjaakhi ch'ọdachen nnang anọng e. Yina, Ibinọkpaabyi wọ ọ́nang ebhina ẹkkakka e.” 
\p  
\v 17 Phero ọgbaak Josẹph bi, “Kaam nttaar idachen da mbe k'ọraanga kwa Nile ọkhaan-ọkhaan.  
\v 18 Nne da abhaam azenamfa p'ajibhi for ayini k'ọraanga kwa Nile, akwu achi araraari m'ọraanga ọkhaan-ọkhaan.  
\v 19 Ogbe k'obhiri, abhaam azenamfa adọdọk p'akkokh-okkokhi abira aphyibh ka for, ayin m'ọraanga. Kaam mada ogbe odede e, abhaam p'akkokhi ka for mando ndimi mminna m'irek nna s'Ijip.  
\v 20 Abhaam mba p'akkokh-okkokhi, abira aphyibh ka for an-achi p'ajibhi ka for p'ira achi eden ayin.  
\v 21 Chibhi da bẹ akk'ayok acha biphyir, bẹ atzima akkeri ka for macha bẹ adede. Mando kwa mgbe mphyọbha k'ọda. 
\p  
\v 22 “K'idachen ọdọdọk, kaam nne da abọkpa-bhọra azenamfa p'ajibhi for ameni k'erin dani.  
\v 23 Ayongi mbuma, abọkpa-bhọra azenamfa adọdọk p'akkokh-okkokhi abira amen k'ebọkparin dani, ọphapha kw'iyoma kw'ofon kẹ da ewuchen em-eyin ogwuma bẹ.  
\v 24 Mẹ wọ, abọkpa-bhọra mba azenamfa p'akkokh-okkokhi amyi azenamfa p'ajibhi for biphyir. Kaam ndọkha idik nna biphyir mgbaak anọng p'am-asi mbọhng biphyir, yina, ọnọng kw'ọfha osi ẹjaakhi ọnang-m kode.” 
\p  
\v 25 Mẹ wọ, Josẹph ọgbaak Phero bi, “Ọdachen mva ode odem wani, fẹ obiro ọkhaama ẹjaakhi dani. Ibinọkpaabyi ọkk'ẹjaakhi ọsa ọnang Phero k'odik kw'ọkhami bi osi.  
\v 26 Ọdachen mva ọkhaam ẹjaakhi dani, ch'ede bi: Abhaam mbuma azenamfa p'ajibhi for, abe anang cho azenamfa. Abọkpa-bhọra mbuma azenamfa p'ajibhi for, abira abe anang cho azenamfa.  
\v 27 Abhaam mbuma azenamfa p'akkokh-okkokhi p'akpong-nnam ayin, ọmaana abọkpa-bhọra mbuma azenamfa p'ani for ajibhi, p'ọphapha kw'ofon k'okhubha kw'ewuchen em-eyin, abe anang cho azenamfa p'okwo f'ideden. 
\p  
\v 28 “Itta, ode macha mgbaakh-ọ bi, Ibinọkpaabyi ọkk'ẹjaakhi ọsa ọnang Phero k'odik kw'ọkhami bi, osi.  
\v 29 Ka cho azenamfa k'itzitzikha, irek s'Ijip ikhaama ọchattọhk k'ọhaabh.  
\v 30 Yina, cho azenamfa p'okwo f'ideden án-atzor cho p'ọhaabh nnam. Mẹ wọ, anọng áraama ọhaabh f'Ijip ọraama, okwo f'ideden obiro ọ́nyaami ochi irek nna. 
\p  
\v 31 “Anọng ogbe kw'ọhaabh f'irek nna dọk ájima, okhuri da okwo mva f'ideden ọ́n-ọgaangi oyong-oyongi.  
\v 32 Wa Phero ọttaar idachen nna rani k'adem afa, okhuri da iwa Ibinọkpaabyi okk'ochibhi ọtzam ọsa. Ogbe kobhir, Ibinọkpaabyi osi kwẹ osi. 
\p  
\v 33 “Mẹ wọ, tte Phero oror ojinọng wani kw'ọkhaam etzina, ọmaana ekkoji, ifha ọnang ojinọng nwa ẹfa ch'otzima okkeri irek s'Ijip.  
\v 34 Tte Phero otzekha atzọhmnọng p'akkeri irek nna bi, bẹ atzọkha ọchattọhk k'Ijip, okhung wani k'akhung azen ahok, ka cho azenamfa mba p'ọhaabh.  
\v 35 Tte ofona k'ẹfa cha Phero bi, ka cho azenamfa mba p'ọhaabh p'akwu, anọng mba atzọkha ọchattọhk ahok k'idedenmon.  
\v 36 Bẹ aye ọchattọhk mva anang anọng p'ẹkhọma nda, ifha bẹ atzima fẹ ka cho azenamfa mba p'okwo f'ideden okwu k'Ijip, ifha okwo mva f'ideden oningi ẹkhọma nda odimi.” 
\p  
\v 37 Iwa Phero ọmaana akhaan-nọng pẹ biphyir are bi, kwẹ okk'ojibha.  
\v 38 Mẹ wọ, Phero ọbọbh atzọhmnọng pẹ bi, “Na mofha ore ọnọng kw'ode mach'ojinọng nwa, kw'ọkhaam ekkoji ch'efon k'Ibinọkpaabyi o?” 
\p  
\v 39 Mẹ wọ, Phero oben Josẹph bi, “Mada Ibinọkpaabyi ọkk'ọ ẹjaakhi ch'idik nna biphyir ọnanga, ọnọng ọdọdọk kw'ọkhaam etzina ọmaana ekkoji cha kọ akhaam kode.  
\v 40 Kọ án-ade oho k'ọvaar-dimpa kwaam, anọng paam biphyir an-ahakha eho anang ndọhna sọ. Orenga k'ikpokpobha s'ẹvaar sẹ-sẹ s'akhaam ńna ndima mbar nyọhng-ọ.” 
\s1 Josẹph otzim ededen k'Ijip 
\p  
\v 41 Iwa Phero oben Josẹph bi, “Kaam nkk'ọ ọbọhk k'eho nnana bi, adabh irek s'Ijip makhọra.”  
\v 42 Mando kwa Phero ọwọr ẹbaanga chẹ ch'ẹnọhna, okhe Josẹph. Ọtzọkha ẹnya cha bẹ atzim ndik-nyokhasẹ ọkkakka asi, ọfọr-ẹ, yina ọn-ọtzọk ogimma kwa gol ọkhẹ-ẹ k'ẹdọhngi.  
\v 43 Ọtzọkh-ẹ ọnana k'ọkpaar kwa nnyanyaang mmindọr, bẹ ayaar-ẹ mach'ojukwa kwẹ, anọng arenga k'itzitzikha am-awuri amọng aben bi, “Bọng kebh-ẹ eden!” Mẹ wọ, Phero ọnang Josẹph ẹfa ch'ọdabh irek s'Ijip biphyir. 
\p  
\v 44 Phero obiro oben Josẹph bi, “Kaam Phero wọ nde ọvaarnọng, yina, ẹfa eni ka kọ efon, ọnọng kw'ọ́khaama ẹfa ch'oyebh ọbọhk kwẹ obiro ode obho kwẹ o, makhọra irek s'Ijip kode.”  
\v 45 Phero on-okpe Josẹph, Zaphenat-Panea. Obiro ọtzọkha ominanwa kw'okpen Asenat kw'ode nnwa kwa Potiphera, ọnang-ẹ k'ọbada. Wa Potiphera ode ọfọhnẹja kwa On. Wa Josẹph orenga ọkhọri irek s'Ijip \it bi waam\it*. 
\p  
\v 46 Mando kwa Josẹph obin k'itzitzikha sa Phero, orenga ọkpaanga irek s'Ijip biphyir. Wa Josẹph ode ojinọng kw'ode cho ẹrọbh obhiri jobh, k'ogbe kw'ọttẹwọr osi ọtzọhm ọmaana Phero, kw'ode ọvaarnọng kw'Ijip.  
\v 47 Ma cho mba azenamfa p'ọhaabh, wa irerek ihak for ijibh ekpo.  
\v 48 Josẹph ọtzọkha ọchattọhk k'Ijip biphyir, ma cho mba azenamfa p'ọhaabh, ohok k'ideden-mon. K'odedenmon kpenamkpen, wa ohokhi ọchattọhk-dem fa bẹ ayaabh m'obhon nwuma.  
\v 49 Mando kwa Josẹph oye ẹchakpo mach'abọkpa k'ọhaabh mach'oyeyeng kw'ọraanga kw'ideden. Wa ọchattọhk mva ọhaabhi maa, ọkwọbha obhik ohohok, da bẹ ani dọk afha abhik. 
\p  
\v 50 Yina ogbe kw'okwo mva f'ideden opyiri, wa Asenat kw'ode ominanwa kwa Potiphera kw'ode ọfọhnẹja kwa On, okk'va afa p'ijinọng ọmaana ọnang Josẹph.  
\v 51 Josẹph okpe ocheden-nwa kwẹ, Manasẹ, oben bi, “Ofon da Ibinọkpaabyi ọkk'ọsa bi, kaam nnaama ihem saam biphyir, ọmaana efonamma ch'otte kwaam biphyir.”  
\v 52 Okpe nnwa kw'ottong afa Ephraim, oben bi, “Ofon da Ibinọkpaabyi ọkk'aam ọsa bi, ngaama va m'irek nna s'ihem saam.” 
\p  
\v 53 Mada cho azenamfa mba p'ọhaabh k'irek s'Ijip akk'akwa akwọbha,  
\v 54 cho mbonggo azenamfa p'okwo f'ideden attẹwọr, mach'iwa Josẹph ọkk'ẹjaakhi ọtzam ọsa. Wa okwo f'ideden owobh makhọra idibhon biphyir. Yina, wa ọchattọhk owobh k'ọhaabh makhọra Ijip.  
\v 55 K'ogbe kw'okwo ọn-ọttẹwọr ọkhaama anọng p'Ijip, bẹ atza abhom amọng p'ọchattọhk akpẹkhi Phero. Ofona mẹ, Phero oben anọng p'Ijip biphyir bi, “Bọng nọhng ka Josẹph, bọng asi odik kpenamkpen kw'oben bi, bọng asi.” 
\p  
\v 56 K'ogbe kw'okwo mva f'ideden ọkk'ọn-ọnyaami k'ẹkhọma nda biphyir, Josẹph okwunga ihọhm s'iwa bẹ aye ọchattọhk, okpe ọchattọhk anang anọng p'Ijip, okhuri bi, wa okwo f'ideden owobh k'Ijip makhọra.  
\v 57 Wa anọng abina k'idibhon biphyir atza adebh ọchattọhk ka mbọhk sa Josẹph k'Ijip, okhuri bi, wa okwo f'ideden ọgaang-ọgaangi makhọra. 
\c 42  
\s1 Votte pa Josẹph atza k'Ijip 
\p  
\v 1 Mada Jekọb ọbhaang bi, ọchattọhk owobh k'Ijip, ọbọbh va pẹ p'ijinọng bi, “Ode yan kwa bọng atzima am-abe akkeri ayok k'ikkokkon o?”  
\v 2 On-ochina ororo oben bẹ bi, “Kaam nkk'mmaanga bi, ọchattọhk owobh k'ẹkhọma ch'Ijip. Bọng hakha atza adebh ọchattọhk atzima akwu mochi, ifha moning ope k'okwo.” 
\p  
\v 3 Mẹ wọ, votte pa Josẹph anọng-ho jobh abina achina k'Ijip bi, bẹ atza adebh ọchattọhk.  
\v 4 Yina, wa Jekọb Bẹnjamin kw'ode ọgbaanọkka kwa Josẹph ọbọhk kotte bi, ọtzọn abọgbaanotte abẹ, okhuri da ojor-ẹ bi, itzama ifha itto ikhebh-ẹ.  
\v 5 Mẹ wọ, wa va pa Jekọb attar k'ẹkhaan ch'anọng p'achin k'Ijip bi, bẹ atza adebh ọchattọhk, okhuri da iwa okwo f'ideden obiro owobha k'ẹkhọma cha Kenaan. 
\p  
\v 6 M'ogbe nwuma, wa Josẹph on-otzim ededen k'Ijip, obiro ode ọnọng kw'om-okpe ọchattọhk ọnang anọng biphyir. Mẹ wọ, mada votte pa Josẹph apyiri k'Ijip, bẹ arakha attima otzitzikha fabẹ k'irerek k'ikpokpobha.  
\v 7 Mada Josẹph ore votte pẹ \it bi kpaar\it* otzin bẹ. Yina, wa osi nkkari bi bẹ kotzini, on-otzima ọwọhng kw'ọgaang-ọgaangi ọgbaak bẹ atzim, ọbọbh bẹ bi, “Bọng afon man akwu ma?” 
\p Bẹ abhina bi, “Mofon k'ẹkhọma cha Kenaan okwu bi, mokwu odebh ọchattọhk e.” 
\p  
\v 8 Kaambi ode bi wa Josẹph okk'votte pẹ otzina, wa bẹ kẹ katzini.  
\v 9 Mẹ wọ, Josẹph ojima ọdachen f'iwa ọkk'ọttaara okhuri bẹ, on-oben bẹ bi, “Bọng ade nttọ, bọng akk'akwa bi, akwu arom obhon kwaman, ifha bọng aronga irinikhum s'irerek saman.” 
\p  
\v 10 Bẹ abhina bi, “Mma e, itta kwaman, kwẹ mando kode. Atzọhmnọng pọ akwu bi, akwu adebh ọchattọhk.  
\v 11 Man biphyir mode ajinọng p'afon k'otte wani. Atzọhmnọng pọ agbaakhi odik-ọkka e, man nttọ kode e.” 
\p  
\v 12 Josẹph oben bẹ bi, “Ibhora! Bọng akwu bi, akwu aronga irinikhum s'irerek saman.” 
\p  
\v 13 Bẹ an-abhina bi, “Itta, iwa maman atzọhmnọng pọ mode anọng jobh obhiri afa, p'otte wani kw'orukhi ka Kenaan obhoni e. Okpong-nnam kwaman owobh kẹ ttara otte kwaman e, yina, oyok wani k'ottem kwa man anọng jobh obhiri afa, k'akpen dọk kode.” 
\p  
\v 14 Josẹph ochina ororo oben bẹ bi, “Odik nwa ode macha mgbaakhi bọng bi, bọng ade nttọ!  
\v 15 Ifha ode mẹ moronga odik-ọkka, eyoma chabọng éde bi, bọng atza atzima okpong-nnam kwabọng atzima akwu. Kaam nwọhngi ttara akpen pa Phero bi, kw'oyongi bi bọng asi mando, bọng kábhana e.  
\v 16 Bọng dọhm ọnọng wani k'ottem kwabọng ọkpa nnam, ọtza otzima okpong-nnam nwuma kwabọng okwu, ayok mbangga awobha ka mgbakkọhbh maa bẹ akhuna akhebha bọng ma, ifha moyoma bọng ore sa bọng am-agbaak odik-ọkkakka. Idikha oni mando ode, nwọhngi ttara akpen pa Phero bi, bọng ade nttọ!”  
\v 17 Mando kw'ọtzọk bẹ biphyir ọgbak k'iwu ittaan. 
\p  
\v 18 Ottong iwu ittaan nnuma, Josẹph oben bẹ bi, “Kaam ngaam ojora f'Ibinọkpaabyi e. Bọng si macha mgbaakhi, ifha bọng aruk akpen.  
\v 19 Idikha bọng ade anọng p'am-agbaak odik-ọkka, bọng tte ọnọng wani k'ottem kwabọng owobha mgbakkọhbh ma, ifha ayok atzọkha ọchattọhk fa bọng akk'adebha, achena anọng pabọng ka nhọhmmọr, p'ayim okwo kẹ.  
\v 20 Yina nkhera bi, bọng ibhora kasi, ifha bọng aning abira ape, bọng akhaambi atza atzima okpong-nnam kwabọng achen-m.” Wa bẹ akhera asi mach'obeni bẹ. 
\p  
\v 21 Bẹ an-abhakhi aben ayok bi, “K'odik ọkkọkka, oponga-pyibha nwa kw'am-ọtzọk ma, ofon k'itzama s'iwa mosi ọnang ọgbaanọtte kwaman e. Mojim odem kw'iwa odik nwuma ọmmẹ-ẹ kẹ, ọmaana odem kw'iwa om-okhukhi man bi, mọkkaan-ẹ. Yina, wa ọnọng kw'oyong-ẹ itzọhng kode, kẹ wọ osi mokk'ọmmamma ọtzọkha.” 
\p  
\v 22 Reubẹn obhina bẹ bi, “Wa bọng itzọhng kindọri bi, bọng aningi nnwa nwa itzama asi? Yina, ọnọng kw'iwa oyong-m itzọhng kode. Bọng na tzọkha mẹ ttaakhi khi, mọkhaambi da more ọmmamma k'eho cha nnwa nwa.”  
\v 23 Mada bẹ am-agbaak idik nna mẹ biphyir, bẹ karong bi Josẹph ọm-ọbhaang bẹ, okhuri da iwa om-otzima ọbhakh-ebhon ọgbaak bẹ atzim. 
\p  
\v 24 Wa Josẹph on-obina oji bẹ mẹ da bẹ awobh, ọtza obhom ẹmọng, yina ọn-ọkpa nnam okhebha bẹ k'ibe sa bẹ awobh, obiro ọgbaak bẹ atzim. Ọbọkha Simeọn m'ottem kw'ayok ọdabh ndik m'itzitzikha sabẹ. 
\p  
\v 25 Mẹ wọ, Josẹph ọnang anọng pẹ ẹfa bi, bẹ atza akhe anọng mba abọkpa ka mkpa sabẹ atzim akwu, bẹ abira akpa nnam arik agbukha p'ọnọng-ọnọng otzim odebh abọkpa k'ẹkpa chẹ, bẹ abira attara ọchattọhk f'anọng mba achi k'eden. Mada bẹ akk'mando asa,  
\v 26 anọng mba atzọkha ọchattọhk fa bẹ akk'bẹ ananga adabh ka nnyanyaang sabẹ abhana. 
\p  
\v 27 Mada abẹ apyiri k'ibe sa bẹ abhingi da erungi epyi, oyok wani ọchaari ẹkpa chẹ ifha ọnang ẹnyanyaang chẹ ọchattọhk, on-ore asilva pẹ k'ẹkpa chẹ ẹtzaanga.  
\v 28 Ọgbaak ayok bi, “Bẹ akk'asilva paam arikha e, kkeri bẹ k'ẹkpa chaam e.” Mada bẹ abhaang odik kw'oyok ọgbaakhi bẹ, nttem iyọhn bẹ, ojora osi bẹ, bẹ afọhni abọbh ayok bi, “Ma bọng odik wọ kw'Ibinọkpaabyi osi man ma o?” 
\p  
\v 29 Mada abẹ akwu apyiri k'ẹkhọma cha Kenaan, bẹ agbaak otte kwabẹ Jekọb, odik kpenamkpen kw'ọkk'ọtta okhebha bẹ k'orenga kwa bẹ atza, aben bi,  
\v 30 “Ojinọng kw'ọdabhi obhon nwuma ọkkaam-ọkkaam, obiro ọtzọkha man macha nttọ, sa nkwu bi, nkwu nnom irek nnuma.  
\v 31 Yina, mọgbaakh-ẹ bi, ‘Mode anọng ọkkọkka, man nttọ kode.  
\v 32 Wa mode votte jobh obhiri afa e, va p'otte wani obhoni. Yina, oyok wani k'ottem kwa man anọng-ho jobh obhiri afa, k'akpen dọk kode. Okpong-nnam kwaman wọ on-owobh k'ẹkhọma cha Kenaan ttara otte kwaman.’ 
\p  
\v 33 “Mẹ wọ, ojinọng kw'otzim ededen ch'irek nnuma, oben man bi, ‘Odem kwa kẹ otzima oronga sa mode anọng ọkkọkka ode bi, bọng tte ọnọng wani ọbọhk k'ottem kwabọng, owobha ma ttar-m, ifha ayok mbangga atzọkha ọchattọhk achena anọng pa nhọhmmọr sabẹ, s'iwobh k'okwo f'ideden.  
\v 34 Kw'oyongi bi motzim okpong-nnam kwaman ochen-ẹ, kẹ kókhera bi, man nttọ kode, kóbiro okhera bi, mode anọng ọkkọkka. Amokk'mando ọsa, kẹ ótte ọgbaanọtte kwaman ọbọhk otte ọnang man, ifha mobiro ofha órenga mphya m'irek nnuma.’ ” 
\p  
\v 35 Mada abẹ an-awọhn ekpo py'ewobh ka mkpa sa bẹ atzim akhuna, ọnọng-ọnọng on-ore ikwa sẹ sa silva s'ira otzim odebh abọkpa k'ẹkpa chẹ ẹtzaanga. Mada bẹ biphyir ọmaana otte kwabẹ an-abira are ọkwa fa silva fa bẹ arọbh ka mkpa sabẹ, ojora osi bẹ biphyir.  
\v 36 Mẹ wọ, otte kwabẹ Jekọb oben bẹ bi, “Bọng akk'aam va paam arama. Josẹph ọmaana Simeọn k'akpen dọk kade, ma, bọng an-abira akwu bi akwu atzọkha Bẹnjamin atzima afona. Idik nna biphyir itto ikhebha kaam mancheni!” 
\p  
\v 37 Mẹ wọ e, Reubẹn oben otte bi, “Tte Bẹnjamin ọbọhk anang-m, kaam ndima va paam afa, ndera eho chẹ, idikha kaam nnẹ-ẹ ndim ngwuna nchen-ọ. Ọttọhk kpenamkpen f'ọdaakh-ọ bi asi va paam, si bẹ.” 
\p  
\v 38 Yina, Jekọb obhina bi, “Kaam nnwa kwaam, ọbọhk kintte nnang bọng, okhuri bi, ọgbaanọkka kwẹ ọkk'ọpa, on-orik kẹ-khẹ. Idikha itzama kpenamkpen itto ikhebh-ẹ k'orenga kwa bọng átza, mẹ wọ ode bi, bọng ánọhng-m m'atzam mba ka nkwu-osisi.” 
\c 43  
\s1 Votte pa Josẹph atzim Bẹnjamin akpa nnam k'Ijip 
\p  
\v 1 Wa okwo f'ideden otzim owobh k'ẹkhọma cha Kenaan.  
\v 2 Mada Jekọb ọmaana ẹhọhmmọr chẹ akk'abọkpa p'iwa bẹ adebhi k'Ijip acha biphyir akyera, otte oben bẹ bi, “Bọng kpa nnam k'Ijip atza adebh ichattọhk-ttọhkha atzima akwu.” 
\p  
\v 3 Yina, wa Juda oben otte bi, “Ojinọng nwuma kw'ọdabhi Ijip, ọtzọri man itzọhng k'eden ọkkakka bi, ‘Bọng kaam k'itzitzikha kàbe, kw'oyongi bi, bọng atzim ọgbaanọtte nwuma kwabọng akwu.’  
\v 4 Idikha akher bi, ọgbaanọtte kwaman ọtzọn man abẹ, mọhakha-ọhakha otza odebh ọchattọhk ochen-ọ.  
\v 5 Yina, idikha annẹ-ẹ ọbọhk atte bi ọtzọn man abẹ, man kọtza, okhuri bi, ojinọng nwuma obeni man bi, ‘Bọng kaam k'itzitzikha kàbe, kw'oyongi bi, bọng atzim ọgbaanọtte nwuma kwabọng akwu.’ ” 
\p  
\v 6 Iwa Jekọb kw'obiro okpena Israẹl, ọbọbh bi, “Ka yan kwa bọng anang-m ọmmamma-dem nwa k'ettem, bi, bọng agbaak ojinọng nwuma bi, bọng akhaam ọgbaanotte ọdọdọk ka o?” 
\p  
\v 7 Bẹ abhina bi, “Ojinọng nwuma ọbọbhi man idik haabhada s'ikhuri for saman ttara ẹhọhmmọr chaman bi, otte kwabọng otzim orukhi akpen kẹ o? Bọng akhaam ọgbaanotte ọdọdọk kẹ? Odik obungikwẹ kw'am-osi ode bi, mọgbaakh-ẹ idik s'ọbọbhi man biphyir. Yan wọ kw'ira motzima oronga bi, kẹ oben man motzima ọgbaanotte kwaman okwu o?” 
\p  
\v 8 Mẹ wọ, Juda on-oben Israẹl bi, “Tte nnwa nwa ọbọhk anang kaam, ifha ode mẹ, mofona eden dani, ọtza odebh abọkpa otzima okwu, ifha kọ, ọmaana maman, ttara va paman moning ope k'okwo.  
\v 9 Kaam ọkhaam wọ nkker-ẹ, ọttọhk manda vani ọsẹ-ẹ, ror-ẹ bọbh-m. Tte kaam ndima akpen paam ndera eho chẹ, idikha nnẹ-ẹ ndim ngwuna nchen-ọ.  
\v 10 Idikha ira oni egbekhibhi nda ode, nnamanda ira mokk'igbe ifa ọtza okhuna.” 
\p  
\v 11 Mẹ wọ, otte Jekọb on-oben bẹ bi, “Ah ho, ode mando, bọng dekha ẹnanga k'ekpo ẹkkakka mbyuma pya m'ọkhaam m'irek nna, mach'ana p'adaami eruk ibebaa, ọmaana akhọkhọhnana, ọmaana amọma pa kashu, ttara amọma p'almọn achena ojinọng nwuma.  
\v 12 Bọng biri tzọkha asilva p'ade igbe ifa ka mbuma p'ewunda bọng are ka mkpa sabọng. Bọng apyiri kẹ, bọng nik asilva mbuma pa bọng are ka mma sa mkpa sabọng. Kkeri, asi mẹ, bẹ asi epina akhe bẹ mẹ.  
\v 13 Bọng biri tzima ọgbaanotte kwabọng anemi eden arọhng k'ojinọng nwuma.  
\v 14 Tte njọhm saman ide bi, Ọvaar Ibinọkpaabyi kw'Ẹfa biphyir, ọsi ojinọng nwuma ọkhọkha bọng inọngkwo, ifha ótte ọgbaanotte nwonggo kwabọng ọbọhk, ttara Bẹnjamin bẹ atzọn bọng abẹ akhuna. On-ode kaam, idikha va paam adim-m odimi, tte bẹ adim-m ko o.” 
\p  
\v 15 Mẹ wọ, ajinọng mba atzọkha nnanga nnuma, attara asilva p'ade igbe ifa ka p'iwa bẹ atzim, akwu attara ka Bẹnjamin, atzima afona. Bẹ arenga m'ẹbhar k'ẹbhar apyiri k'Ijip, anemi eden achina ka Josẹph.  
\v 16 Mada, Josẹph ore Bẹnjamin ọmaana bẹ, oben ọtzọhmnọng kwẹ kw'ọhọhm bi, “Kọ tzima ajinọng mba achina k'ọhọhm kwaam, bọng fhu etzen atzima asi ọchattọhk, kkeri sa bẹ áchi ọchattọhk ttar-m k'ẹya.” 
\p  
\v 17 Wa ọtzọhmnọng nwa osi macha Josẹph ọgbaakh-ẹ, otzima ajinọng mba ochina k'ọhọhm kwa Josẹph.  
\v 18 Mada bẹ apyiri k'ọhọhm kwa Josẹph, ajinọng mba ojora bẹ, bẹ achibhi bi, “Asi mẹ asilva mba p'ewunda bẹ akpa nnam akhe ka mkpa saman bọ, pa bẹ areng abẹ atzima man akwu m'ibe na e. Kẹ oben bi, órima man abẹ, óbiro ọna man ẹfa, óbiro ọbọkha man nnyanyaang saman ọna, óbiro otzima man osi abira pẹ.” 
\p  
\v 19 Mẹ wọ, bẹ afona atza akhebha ọtzọhmnọng kwa Josẹph k'ẹbaakhamma ch'ọhọhm nwuma, agbaakh-ẹ atzim.  
\v 20 Bẹ aben bi, “Tzotzokhaan itta kwaman, wa mokwu odebh ọchattọhk ma k'ochedengbe.  
\v 21 Mada mopyiri k'ibe sa mobhingi, ọnọng-ọnọng on-ore obhik nwuma wani kw'asilva pa otzim odebh ọchattọhk k'ẹmma ch'ẹkpa chẹ ẹtzaanga. Mẹ wọ, motzim bẹ ma bi, morikh e.  
\v 22 Mada mọni ọnọng orong kw'iwa okhe asilva mbonggo ka mkpa saman, motzim asilva adọdọk okwu p'amotzima odebh ọchattọhk ma e.” 
\p  
\v 23 Ọtzọhmnọng nwa oben bi, “Tte oningi bọng ojor, odik m'ẹtzaanga kode. Ibinọkpaabyi kwabọng, kw'ode Ibinọkpaabyi kw'otte kwabọng, okk'bọng agbukha ọnanga ka mkpa sabọng. Kaam wa nkk'asilva pabọng atzim adebh ọchattọhk ndọkha.” Mẹ wọ, ọtzọkha ọgbaanotte kwabẹ Simeọn otzima oyin kanya iyaan, ọnang bẹ.  
\v 24 Ọtzọhmnọng nwa otzima ajinọng mba odim k'ọhọhm kwa Josẹph, ọnang bẹ asi pa bẹ atzim agbobhi mmo mach'ẹmaana chabẹ ede, obiro ọnang nnyanyaang sabẹ ọchattọhk.  
\v 25 Bẹ ado for ttara nnanga sabẹ atzima atzik ogbe kwa Josẹph opyiri, da bẹ akk'abhaanga bi, sa bẹ awobha mẹ achi ọchattọhk. 
\p  
\v 26 Mada Josẹph opyiri k'ọhọhm, bẹ atzọkha nnanga nnuma sa bẹ akk'atzima akwu m'ọhọhm, anang-ẹ. Bẹ abira arakha attima otzitzikha fabẹ k'irerek, akhọkha Josẹph ikpokpobha.  
\v 27 Ọbọbh bẹ bi, “Osi bọng yan o? Itta kw'ewunda bọng agbaakh-m odik okhuri, otzim orukhi akpen kẹ o? Ọsẹ-ẹ yan?” 
\p  
\v 28 Bẹ abhina bi, “Ọtzọhmnọng kwọ kw'ode otte kwaman otzim orukhi akpen kẹ e, for ibiri igaang-ẹ kẹ e.” Mẹ wọ, bẹ achunga ahokpadim, abira aruri for sabẹ k'irerek, anang Josẹph ikpokpobha. 
\p  
\v 29 Mada Josẹph otzini chen ore ọgbaanọkka Bẹnjamin, kw'ọkka wani ọmaani bẹ, ọn-obọbh bi, “Agbaanatte nwuma kwabọng kw'ikhakhari kw'ewunda bọng agbaakh-m odik okhuri wọ ma o?” On-oben bi, “Nnwa kwaam, tte Ibinọkpaabyi, ọkhọkh-ọ ọphyaam.”  
\v 30 Mada Josẹph ore ọgbaanọkka kwẹ \it bi kpaar\it*, ẹmọng ebir-ẹ ttara inọngkwo s'ifẹ-ẹ k'ettem. Obina m'ẹbhar-ẹbhar oji bẹ mẹ, oyin k'iyaan oror ibe s'obhom ẹmọng. On-ochina k'ẹmaanggọ chẹ ẹtzaanga, ọtza obhom ẹmọng. 
\p  
\v 31 Mada okk'itzitzikha oruma, ofona k'ẹmaanggọ oyin k'iyaan, ọbọkha for sẹ, oben bi, “Bọng bera bẹ ọchattọhk.” 
\p  
\v 32 Wa bẹ abera Josẹph ọchattọhk fẹ ngọmi, bẹ abera abọgbaanotte ngọmi, bẹ abira abera anọng p'Ijip p'awobh ttara Josẹph ọchattọhk fabẹ ngọmi. Wa kwẹ ode mando okhuri da, anọng p'Ijip atzọk bi, ode ọbhaangi bi, bẹ achi ọchattọhk ibe rani ttara anọng pa Hiburu.  
\v 33 Wa bẹ ahokhi votte mba ẹwọr atzor k'ọgbọ kwa bẹ ade, ttẹwọr k'ocheden maa apyiri k'okpong-nnam kwabẹ. Wa bẹ an-abhakhi akkeri ayok, odik okkoni bẹ k'odem kwa bẹ areng ahok bẹ ẹwọr, atzor k'ọgbọ.  
\v 34 K'ogbe kwa bẹ akkem ọchattọhk f'ofon k'okpokkoro kwa Josẹph, ekkema cha Bẹnjamin ẹhaabh igbe izen ẹyọhnga ch'ayok biphyir. Wa bẹ biphyir achi ọchattọhk, abira agwo atzuk ttara Josẹph, maa ettem ẹdaam ọnọng kpenamkpen. 
\c 44  
\s1 Josẹph ọnang votte pẹ eyoma 
\p  
\v 1 Wa Josẹph otzọhn ọtzọhmnọng kw'ọhọhm kwẹ bi, “Yikha ọchattọhk k'ajinọng mba ka mkpa k'odem kwa bẹ afha atzọhkha, biri khe asilva p'ọnọng-ọnọng ọkk'ọnanga k'ẹmma ch'ẹkpa chẹ.  
\v 2 Atzọkha nkkọbh kwaam kwa silva akhe k'ẹmma ch'ẹkpa ch'oyok kw'ikhakhari, abira atzọkha asilva p'otzim odebh ọchattọhk akhẹ-ẹ k'ẹkpa.” Wa ọtzọhmnọng nwa osi macha Josẹph ọtzọhn-ẹ. 
\p  
\v 3 Okwu otzuma m'owuhobha, bẹ atzọhm ajinọng mba abhana ttara nnyanyaang sabẹ.  
\v 4 Mada bẹ an-atzima afona aji obhon k'ibe s'ibhir-obhir, ogbe k'obhiri Josẹph oben ọtzọhmnọng kwẹ bi, “Rọhng akhubh ajinọng mbuma k'eden. Akhebh bẹ, bọbh bẹ bi, ode yan kwa bọng an-atzim itzama, achora ejibha cha bẹ asi anang bọng o?  
\v 5 Okhuri yan kwa bọng afhu nkkọbh kw'itta kwaam kw'om-otzima ogwo asi, om-obiro otzima ọbhari ose o? Odik-ttama wọ kwa bọng asi ma e.” 
\p  
\v 6 Mada okhebh bẹ k'eden, ọmọnga atzim mba bani agbaak bẹ.  
\v 7 Yina, bẹ aben-ẹ bi, “Tzọmi-tzọmi okponga k'idachen! Yan kw'itta kwaman ochibhi bi, maman atzọhmnọng pẹ ofha osi odik-dema nwa o?  
\v 8 Motzer otzima asilva p'ewunda more ka mma sa mkpa saman ẹtzaanga, ttẹwọr k'irek sa Kenaan okwu orik ma. Mbọng vọ ira on-otzima man mofhu silva obiro ode gol, k'ọhọhm kw'itta kwabọng o?  
\v 9 Idikha are ọnọng m'ottem kw'atzọhmnọng pọ kw'otzim nkkọbh nwuma, ọnọng-dema nwuma ópe-ope, maman ka biphyir mon-obiro ode abira p'itta kwọ.” 
\p  
\v 10 Ọtzọhmnọng nwa on-oben bi, “Odik-jibhada kwa bọng agbaakhi. Tte ode macha bọng abeni. Ọnọng kpenamkpen kw'am-ore nkkọbh nwuma k'ẹkpa chẹ, kẹ ón-ode obira kwaam. Yina, ayok kẹ biphyir ánaanga oponga-pyibha kw'odik nwa ọnaanga.” 
\p  
\v 11 Mando kw'ọnọng-ọnọng ọhak ẹkpa chẹ k'irerek m'ẹbhar-ẹbhar, obiro ọchari ẹkpamma chẹ.  
\v 12 Mando kw'ọtzọhmnọng nwa ọttẹwọr ka mkpa s'adeden-nọng ọm-ọfọhngi, maa okwu opyiri ch'oyok kw'ikhakhari. Wa okwu ore nkkọbh nwuma k'ẹkpa cha Bẹnjamin.  
\v 13 Ofona mẹ, votte an-abọkha ọbara fabẹ afọr ajaakhi, bẹ atzini ndọhkha sabẹ anana ka nnyanyaang sabẹ, abhakhi eho akpa nnam k'obhon kw'ira bẹ afon. 
\p  
\v 14 Iwa Josẹph otzim owobh k'ọhọhm mada Juda ọmaana votte apyiri. Bẹ atto abaangi m'irerek, abhom amọng m'itzitzikha sẹ. 
\p  
\v 15 Mẹ wọ, Josẹph oben bẹ bi, “Bọng odik-dema kwa bọng asi ma? Bọng karong bi, ọnọng macha kaam mmindima ose nnonga idik s'ítto k'ororo o?” 
\p  
\v 16 Juda on-obhina bi, “Bọng odik kwa mobiro ọfha ọgbaak itta kwaman o? Bọng odik kwa mọgbaakh-ẹ o? Yan kwa mọkhọkha bi, mbọhk saman iwur-owur m'odik nwa o? Ibinọkpaabyi okk'oponga-pyibha kw'atzọhmnọng pọ ọjaakhi k'ọyaankpa. Mon-ode abira p'itta kwaman ma e, maman ma for saman magbakha oyok kwa bẹ are nkkọbh k'ẹkpa chẹ.” 
\p  
\v 17 Yina, Josẹph oben bi, “Tzọmi-tzọmi okponga k'idachen bi, kaam nsi odik-dema nwa. Ọnọng kw'ira bẹ are nkkọbh k'ẹkpa chẹ, wọ óde obira kwaam. Bọbọng kẹ biphyir, bọng nọhng abhana atza akhebha atte kwabọng k'odidiri.” 
\p  
\v 18 Mẹ wọ, Juda ofona ọtza okhebha Josẹph, oben-ẹ bi, “Itta kwaam, ngaam atzim pa mben bi mgbaak nnang-ọ abhaanga. Tzotzokhaan, oning-ọ ọdọkhi ọmaana kaam ọtzọhmnọng kwọ. Kaam nnong kẹ bi, ẹfa chọ ede ebengambọhk ttara Phero ọkhaam ma for sẹ. 
\p  
\v 19 “Wa itta kwaam ọbọbhi atzọhmnọng pẹ bi, ‘Bọng akhaam atte ttara ọgbaanọkka ọdọdọk kẹ o?’  
\v 20 Wa mobhin bi, ‘Mọkhaam otte kẹ kw'ọkk'ọtzama, mobiro ọkhaama ọgbaanọtte kw'otte kwaman obhoni k'atzam. Ọgbaanọkka kwa bẹ ade ọkka wani, wa ọkk'ọpa, kẹ-khẹ wọ on-orikhi k'ọkka kwabẹ e, kẹ ọdaakhi otte idik kpọnkpọng e.’ 
\p  
\v 21 “Mẹ wọ, wa aben atzọhmnọng pọ bi, ‘Bọng nọhng atza atzim-ẹ akwu, ifha nnẹ ttara chen paam.’  
\v 22 Wa mọgbaakh-ọ bi, otte kwaman kókhera bi otte nnwa nwa ọbọhk ofona ọjẹ-ẹ e, okhuri bi, ofon ọjẹ-ẹ, otte ópe-ope.  
\v 23 Yina, wa aben atzọhmnọng pọ bi, ‘Bọng itzitzikha saam dọk kínnang, bọng ani agbaanatte kw'ode bọng okpong-nnam atzim akwu bi, nnẹ-ẹ.’  
\v 24 Mada mọkpa nnam ọtza okhebha ọtzọhmnọng kwọ, kw'ode otte kwaman, mọgbaakh-ẹ eden cha kọ, itta kwaam, akk'man agbaakha. 
\p  
\v 25 “Mẹ wọ, mada otte kwaman obeni bi, ‘Bọng nọhng abira atza adebh ọchattọhk ibebaa.’  
\v 26 Yina, wa moben bi, ‘Man kọfha ọtza idikha an-akher bi, motzima ọgbaanotte kwaman ọtza. Man itzitzikha s'ojinọng nwuma kw'om-okpe ọchattọhk kofha ore, idikha ọgbaanotte kwaman kw'ikhakhari oni man abẹ ọtzọni otza odebh ọchattọhk.’ 
\p  
\v 27 “Otte kwaman kw'ode ọtzọhmnọng kwọ obeni man bi, ‘Bọng akk'aronga bi, wa kwanọng kwaam ọmaan-m va afa p'ijinọng.  
\v 28 Oyok wani k'akpen dọk kode. K'odik-ọkka nden nkk'ẹ nchikhi k'abir-ibiri. Ttẹwọr kẹ maa apyiri ma, kaam kẹ ka chen kinne.  
\v 29 Idikha bọng abira atzima oyok nwa afona, itzama kpenamkpen ikhebh-ẹ k'eden, nnam kọkpa, kw'oyini bi, bọng ánọhng-m k'atzam ttara nkwu-osisi.’ 
\p  
\v 30 “Mẹ wọ ode bi, idikha nnwa nwa oni man abẹ ọtzọni, mada mkpa nnam k'otte kwaam kw'ode ọtzọhmnọng kwọ, kw'ettem chẹ biphyir ẹgban ma nnwa nwa,  
\v 31 on-ore bi nnwa nwa man abẹ kọtzọni, kẹ ópe-ope e. Atzọhmnọng pọ án-awọhkhi otte kwaman ope k'atzam, mọnọhng-ẹ ttara izen ka chen e.  
\v 32 Kaam ọtzọhmnọng kwọ wọ nnwọhngi k'itzitzikha s'otte kwaam, mben-ẹ bi, ‘Tte kaam ndima akpen paam ndera eho chẹ, idikha nnẹ-ẹ ndim ngwuna nchen-ọ!’ 
\p  
\v 33 “Mẹ wọ, itta kwaam, kaam ngwukhọ-okhukhi, tzima kaam ọtzọhmnọng kwọ mach'obira atzer eho cha nnwa nwa, ifha attẹ-ẹ ọbọhk ọtzọn votte pẹ abẹ ọbhana.  
\v 34 Kaam eden kinnong cha kaam mmana ndor otte kwaman, idikha nnwa nwa oni kaam abẹ ọtzọni ọbhana. Mma e! Kaam ọbọhk katte bi, nda nne ọmmamma kw'odik nwa ọnang otte kwaam e.” 
\c 45  
\s1 Josẹph osi ẹjaakhi cha for sẹ ọnang votte 
\p  
\v 1 Mada Josẹph oni for sẹ dọk ọfha ọbọkha k'itzitzikha s'atzọhmnọng pẹ, ọhọbhi ẹmọng obhom, “Ọnọng kpenamkpen obina k'itzitzikha saam!” Mẹ wọ, wa okkekkeminọng ọdọdọk kw'owobh mẹ kode, k'ogbe Josẹph osi ẹjaakhi cha for sẹ ọnang votte pẹ. 
\p  
\v 2 Wa Josẹph on-obhom ẹmọng k'ẹrọng maa anọng p'Ijip abhaanga, maa ẹhọhmmọr cha Phero ebire ẹbhaanga ẹmọng ch'obhomi. 
\p  
\v 3 Josẹph oben votte pẹ bi, “Kaam wọ nde Josẹph e! Otte kwaam otzim orukhi akpen kẹ o?” Yina, wa votte kẹ ebhina kafha anang, okhuri opoma-dem f'ọbọk bẹ k'itzitzikha sẹ. 
\p  
\v 4 Josẹph oben votte bi, “Bọng nọkhi baang-m ka for.” Mada bẹ akk'mando asa, on-oben bi, “Kaam wọ nde Josẹph, ọgbaanọtte kwabọng, kw'iwa bọng akpe anang aphyaphya p'Ijip.  
\v 5 Nttem nningi bọng atzim iyakhi. Bọng ayok kabira apyima bi, bọng akpe-m anang ma, okhuri bi, Ibinọkpaabyi ochi eden ọtzọhm kaam ma bi, ifha orenga ka nnam saam ọkkaana akpen p'anọng.  
\v 6 Onode cho afa ma p'okwo f'ideden owobh m'irek nna e, ka cho azen p'am-akwu k'itzitzikha anọng bẹ ekpo káyaabha, bẹ kabira apha.  
\v 7 Yina, wa Ibinọkpaabyi ochi eden ọtzọhm kaam ma bi, nkkaana nhok bọng ayok bani akpen m'ọyagbin, ifha mbiri nnang bọng ẹnaanga ch'ideden. 
\p  
\v 8 “Mẹ wọ, bọbọng arang asi, Ibinọkpaabyi wọ iwa ọtzọhm-m ma e. Osi-m bi, nde ọvaar kw'ajukwa pa Phero biphyir, ọmaana itta kw'ọhọhm kwẹ, ttara ọdabhi kw'anọng p'Ijip makhọra.  
\v 9 M'ẹbhar-ẹbhar, bọng kpa nnam k'otte kwaam atza agbaakh-ẹ bi, ‘Nnwa kwọ Josẹph ọtzọhmi ẹkkaabha ochen-ọ bi, Ibinọkpaabyi ọkk'aam ẹvaar ch'Ijip biphyir ọnanga. Kọ ogbe kàkhibhi, jekha akwu akhebh-m ka da nwobh.  
\v 10 Kọ otte kwaam, ọmaana va pọ, ọmaana va pa va pọ, ọmaana etzirakpo pyọ, ọmaana abhaam pọ, ttara ọttọhk kpenamkpen fọ biphyir, an-aruk k'okhubha kwa Goshẹn, ifha moruk ọbaanga ayok.  
\v 11 Ka Goshẹn wọ kwa kaam nkker-ọ, okhuri bi, cho azen p'okwo f'ideden awobh k'itzitzikha. Oni mando ode, kọ ọmaana ẹhọhmmọr chọ, ọmaana etzirakpo pyọ biphyir, bọng awobha k'ogbor.’ 
\p  
\v 12 “Bọng biphyir akk'ara, ọgbaanọkka kwaam Bẹnjamin obiro ore bi, k'odik-ọkka kaam wọ mimgbaak bọng atzim ma e.  
\v 13 Bọng gbaak otte kwaam abarada pa kaam ngaam k'Ijip, bọng biri gbaakh-ẹ odik kpenamkpen kwa bọng akk'ara. M'ẹbhar-ẹbhar, bọng nọhng atza atzima otte kwaam akwu.” 
\p  
\v 14 Mẹ wọ, Josẹph ọkhaara ọgbaanọkka Bẹnjamin mbọhk, bẹ abaakha ayok, abira abhom.  
\v 15 Wa Josẹph obhom ẹmọng nduma otzima ọbaakha votte pẹ biphyir. Mada okk'mando ọsa, mẹ wọ kwa votte pẹ an-akhaam ottembara bi, bẹ agbaak atzim ttar-ẹ. 
\p  
\v 16 Mada ẹgọmi nda epyiri k'ọvaar-dimpa kwa Phero bi, votte pa Josẹph akk'akwa m'Ijip, wa ettem ẹdaam Phero ọmaana akhaan-nọng pẹ biphyir.  
\v 17 Phero oben Josẹph bi, “Ben votte pọ bi, ‘Odik kwa bọng asi ode bi, bọng dọkha ekpo pyabọng anana etzirakpo pyabọng, ifha bọng abhana k'ẹkhọma cha Kenaan,  
\v 18 bọng biri tzima atte kwabọng, ọmaana nhọhmmọr sabọng akwu k'Ijip. Kaam ńnang bọng okhubha kw'irerek s'ijibhi ọtzam, ifha bọng akhaama ekpo k'ọhaabh py'efona mẹ.’ 
\p  
\v 19 “Kọ biri gbaak bẹ bi, ‘Odik kwa bọng asi ode bi: Bọng dọkha akpaar p'ideden pa nnyanyaang mmindọr m'Ijip, atzima atza atzọkha va pabọng, ọmaana panọng pabọng, ttara atte kwabọng atzima akwu.  
\v 20 Bọng ẹkhakhaama chabọng kare mach'odik kw'ọyak bọng atzim, okhuri bi, okhubha kw'irerek s'ijibhi ọtzam k'Ijip, ọkhaam bọbọng.’ ” 
\p  
\v 21 Mẹ wọ, wa va pa Jekọb asi odik kpenamkpen kwa bẹ atzọni bẹ. Josẹph ọnang votte pẹ akpaar p'ẹbhar p'ideden otzor k'ẹfa ch'ọvaar Phero ọkk'ọnanga, obiro ọnang bẹ ọchattọhk fa bẹ achi k'eden.  
\v 22 Ọnang ọnọng-ọnọng ọbara ọbhapfẹ, oyongi Bẹnjamin kw'ọnangi ashẹkẹl arọbh chi pa silva ọmaana ọbara adem azen ọdọdọk.  
\v 23 Wa Josẹph ọtzọkha anyanyaang-dim jobh p'atzọhk ekpo ẹkkakka py'Ijip, ọmaana anyanyaang-papẹ jobh p'atzọhk abọkpa ttara brẹd, ttara ọchattọhk ọdọdọk f'otte otzima orenga k'eden.  
\v 24 Mẹ wọ, mada okk'bẹ ekpo mbya okkema biphyir, oben bẹ arọhng. Mada bẹ an-abina orenga, oben bẹ bi, “Bọng ẹkhọhr k'eden kasi o!” 
\p  
\v 25 Mẹ wọ, bẹ abina k'Ijip akwu akhebha otte kwabẹ Jekọb k'ẹkhọma cha Kenaan.  
\v 26 Mada bẹ akwu apyiri, bẹ agbaak otte bi, “Josẹph otzim orukhi akpen kẹ e! Kẹ wọ ode ọvaarnọng kw'irek s'Ijip biphyir.” Jekọb okkon-ẹ, odik nwa k'odik-ọkka kọtzọk.  
\v 27 Yina, mada bẹ an-agbaakh-ẹ odik kpenamkpen kwa Josẹph okk'bẹ ọgbaakha, obiro ore akpaar p'ideden pa nnyanyaang mmindọr pa Josẹph ọkk'ọtzọhma bi, bẹ atzima akwu atzin-ẹ atzima achina k'Ijip, ẹfa ebire ewobha Jekọb.  
\v 28 Mẹ wọ, Jekọb oben bi, “Kwẹ ode odik ọkkakka e, nnwa kwaam Josẹph otzim orukhi akpen kẹ e. Kaam ngaam bi, ńda k'Ijip nda nnẹ-ẹ yina kaam ḿpe e.” 
\c 46  
\s1 Jekọb ọmaana ẹhọhmmọr chẹ achin k'Ijip 
\p  
\v 1 Mando kwa Jekọb obin orenga ttara ọttọhk kpenamkpen f'ode fẹ. Mada okwu opyiri ka Bẹrshẹba, osi njafọhni mẹ ọnang Ibinọkpaabyi kw'otte kwẹ Isaak okpobh. 
\p  
\v 2 Okwu opyiri k'erungi, Ibinọkpaabyi oyin Jekọb abẹ k'idachen, oyer-ẹ bi, “Jekọb! Jekọb!” 
\p Jekọb okhera bi, “Kkeri kaam ma e.” 
\p  
\v 3 Mẹ wọ, oben bi, “Kaam wọ nde Ibinọkpaabyi, Ibinọkpaabyi kw'atte kwọ okpobh, oning-ọ ojor bi achina k'Ijip, okhuri bi, kẹ wọ kwa kaam ńsọ-ọ bi, ade ẹkhọma ch'ideden.  
\v 4 Kaam ńdọn-ọ abẹ nchina k'Ijip, mbiri ńdim-ọ mkpa nnam. Josẹph wọ óde ọnọng kw'obubh-ọ chen k'obo.” 
\p  
\v 5 Iwa Jekọb obina ka Bẹrshẹba, va pẹ atzima kẹ kw'ode otte kwabẹ, ọmaana va pabẹ, ttara panọng pabẹ, ayikha k'akpaar p'ideden pa nnyanyaang mindọr, pa Phero ọkk'ọtzọhma bi, bẹ atzima atzini otte.  
\v 6 Wa Jekọb, ọmaana va pa va pẹ biphyir atzima etzirakpo pyabẹ, ọmaana ẹkhakhaama cha bẹ akk'asa k'ẹkhọma cha Kenaan, achina k'Ijip.  
\v 7 Jekọb otzima va pẹ p'ijinọng ọmaana va pabẹ, ttara va pẹ p'ipanọng ọmaana va pabẹ, ẹhọhmmọr chẹ biphyir, ochina k'Ijip. 
\p  
\v 8 Ma wọ ode che pa va p'ijinọng pa Jekọb, p'achin k'Ijip. 
\q1 Reubẹn kw'ode ocheden-nwa kwa Jekọb. 
\p  
\v 9 Va p'ijinọng pa Reubẹn ade, 
\q2 Hanọk, ọmaana Palu, 
\q3 Hẹzrọn, ttara Karmi. 
\p  
\v 10 Va p'ijinọng pa Simeọn ade: 
\q2 Jemuyẹl, ọmaana Jamin, 
\q3 ọmaana Ọhad, ọmaana Jakin, 
\q3 ọmaana Zoha, 
\q3 ọmaana Shaul kw'ode nnwa kw'ijinọng kwa kwanọng kwẹ kw'ofon Kenaan ọmaani. 
\p  
\v 11 Va p'ijinọng pa Lẹvi ade: 
\q2 Gẹrshọn, ọmaana Kohat 
\q3 ọmaana Mẹrari. 
\p  
\v 12 Va p'ijinọng pa Juda ade: 
\q2 Ẹr, ọmaana Ọnan, ọmaana Shẹla, 
\q3 ọmaana Pẹrẹz ttara Zẹra (yina, wa Ẹr ọmaana Ọnan akk'apa k'irek sa Kenaan). 
\q1 Va p'ijinọng pa Pẹrẹz ade: 
\q2 Hẹzrọn ọmaana Hamul. 
\p  
\v 13 Va p'ijinọng pa Isaaka ade: 
\q2 Tola, ọmaana Pua, ọmaana Jashub 
\q3 ọmaana Shimrọn. 
\p  
\v 14 Va p'ijinọng pa Zẹbulun ade: 
\q2 Sẹrẹd, ọmaana Ẹlọn, ọmaana Jalẹl. 
\p  
\v 15 Ma wọ ode va p'ijinọng p'iwa Lea ọmaani ọnang Jekọb k'obhon kwa Padan-Aram, akhiri ominanwa kwẹ Daina ájì. Wa va mba pẹ biphyir, adikkobh ọmaana aminava ade ẹrọbh obhiri jobh obhiri attaan. 
\p  
\v 16 Va p'ijinọng pa Gad ade: 
\q2 Ziphon, ọmaana Hagi, 
\q3 ọmaana Shuni, ọmaana Ẹzbọn, 
\q3 ọmaana Ẹri, ọmaana Arodi, 
\q3 ttara Areli. 
\p  
\v 17 Va p'ijinọng p'Ashẹr ade: 
\q2 Imna, 
\q3 ọmaana Ishva, ọmaana Ishvi, 
\q3 ttara Beriya. 
\q2 Ọgbaanọkka kwabẹ kw'ikwanọng wa ode Sẹra. 
\q2 Va pa Beriya p'ijinọng ade: 
\q2 Hebẹr, ọmaana Malkiyẹl. 
\p  
\v 18 Wa va chi obhiri wani bọ pa Zilpa ọmaani ọnang Jekọb. Zilpa wa ode obira kwa Laban ọkk'ọtzọkha ọnang ominanwa kwẹ Lea bi, oruk Lea abẹ. 
\p  
\v 19 Ajinọng pa Jekọb obhoni ka kwanọng kwẹ Rachẹl ade, Josẹph ọmaana Bẹnjamin.  
\v 20 Asenat kw'ode ominanwa kwa Potiphera, kw'ode ọfọhnẹja k'obhon kw'On, ọmaani Manasẹ ttara Ephraim ọnang Josẹph k'Ijip. 
\p  
\v 21 Va p'ijinọng pa Bẹnjamin ade: Bẹla, ọmaana Bẹkẹr, ọmaana Ashbẹl, ọmaana Gẹra, ọmaana Naaman, ọmaana Ehi, ọmaana Rosh, ọmaana Mupim, ọmaana Hupim, ttara Ard. 
\p  
\v 22 Va p'ijinọng biphyir pa Rachẹl ọmaani ọnang Jekọb ade ọhawani kwa chi. 
\p  
\v 23 Dan obhoni ojinọng kw'okpen Hushim. 
\p  
\v 24 Va p'ijinọng pa Naphtali ade: Jazẹl, ọmaana Guni, ọmaana Jẹzẹr ttara Shilẹm. 
\p  
\v 25 Biphyir-phyir Bilha kw'ode obira kw'iwa Laban ọtzọk ọnang ominanwa kwẹ Rachẹl, ọmaani va azenamfa ọnang Jekọb. 
\p  
\v 26 Wa ọnọng-mik kw'ọtzọni Jekọb abẹ ochina k'Ijip, ode arọbh attaan obhiri azadani akhiri panọng pa va aji, anọng mba biphyir wa bẹ afon k'ẹnọmma cha Jekọb.  
\v 27 An-atzọk va afa p'ijinọng pa Josẹph obhoni k'Ijip attara, biphyir-phyir ọnọng-mik kw'ẹhọhmmọr cha Jekọb kw'ochin k'Ijip ode: anọng arọbh attaan obhiri jobh. 
\p  
\v 28 Mẹ wọ, Jekọb ọtzọhm Juda bi, ochi eden ọkwọbha ọtza okhebha Josẹph, ọbọbh ibe sa Goshẹn owobh. Mada bẹ apyiri k'okhubha kwa Goshẹn,  
\v 29 Josẹph ọnang ẹfa bi, bẹ atzọkha akpaar p'ideden pa nnyanyaang mmindọr atzima akwu, ifha otza ore otte Israẹl kw'opyiri ka Goshẹn. Mada Josẹph ore otte \it bi kpaar\it* ọkhaara otte mbọhk k'ekhokhora, obiro obhom ẹmọng k'ogbe-bhirada. 
\p  
\v 30 Jekọb oben Josẹph bi, “Mada kaam nkk'nna k'odik-ọkka bi, kọ atzima arukhi akpen ka, kaam nna mpe yina e.” 
\p  
\v 31 Mẹ wọ, Josẹph oben votte pẹ ọmaana ẹhọhmmọr ch'otte kwẹ bi, “Kaam ńchina ka Phero nda ḿgbaakh-ẹ bi, ‘Votte paam ọmaana ẹhọhmmọr ch'otte kwaam, p'iwa arukhi k'irek sa Kenaan, akk'aam atzora ka e.  
\v 32 Ajinọng mba ade akkeri-arukhimaan, bẹ akk'akwa ttara nden sabẹ, ọmaana ọttọhk kpenamkpen fabẹ biphyir.’  
\v 33 Ọn-ọbhakhi oben votte pẹ bi, Phero oyeri bọng, ọbọbh bọng bi, ‘Mbọng vọ ode ọtzọhmbọhk fabọng?’  
\v 34 Bọng abhina bi, ‘Itta, maman atzọhmnọng pọ mọttẹwọr k'ẹvava chaman om-otzir nden, mach'abatte paman e.’ Mẹ kẹ-khẹ wọ kwa bẹ atzima átte bọng ọbọhk, bọng aruk ka Goshẹn, okhuri bi, anọng p'akkeri-arukhimaan akpukhi anọng p'Ijip idik k'eden dama.” 
\c 47  
\p  
\v 1 Wa Josẹph obina ọtza ọgbaak Phero bi, “Otte kwaam ọmaana votte paam akk'etzirakpo pyabẹ, ọmaana abhaam, ttara ọttọhk kpenamkpen fabẹ akhaam, atzima abina k'irek sa Kenaan apyiri ma Goshẹn.”  
\v 2 Josẹph otzekha votte pẹ anọng azen, otzima bẹ ọtza ọkhọhkha Phero. 
\p  
\v 3 Phero ọbọbh votte pa Josẹph bi, “Mbọng vọ ode ọtzọhmbọhk fabọng?” 
\p Bẹ abhin-ẹ bi, “Itta, maman atzọhmnọng pọ mode akkeri-arukhimaan e, mach'iwa abatte paman ade e.”  
\v 4 Bẹ abira aben Phero bi, “Maman ọkk'ọkwa bi, mokwu oruk m'irek nna k'igbegbaa \it bi kọbh,\it* okhuri bi, okwo f'ideden owobh ka Kenaan, ttara bi, araraari kẹ dọk kade p'etzirakpo py'atzọhmnọng pọ echi. Mẹ wọ, tzotzokhaan, tte maman atzọhmnọng pọ oruk k'irek sa Goshẹn.” 
\p  
\v 5 Iwa Phero oben Josẹph bi, “Mada atte ọmaana votte pọ akk'ọ akwa akhebha ka,  
\v 6 irek s'Ijip biphyir iwobh ka mbọhk sọ, kọ tzekha ibe s'arong bi, ijibh-ojibh anang bẹ, bẹ wobha. Tte bẹ aruk k'okhubha kwa Goshẹn. Idikha arong anọng k'ottem kwabẹ p'akhaam emengkka ch'ọtzọhm, kọ tzọkha etzirakpo pyaam anang bẹ, akkeri.” 
\p  
\v 7 Mẹ wọ, Josẹph obiro otzima otte Jekọb ọtza ọkhọhkha Phero. Wa Jekọb osi Phero ittabọhng, ọdẹ-ẹ.  
\v 8 Phero ọn-ọbọbh Jekọb bi, “Kọ an-ade cho aphaang o?” 
\p  
\v 9 Jekọb obhina Phero bi, “Kaam nkk'cho arọbh azadani obhiri jobh nnukha. Cho pa kaam nkk'nnukha kahaabhi, bẹ abira ayakh-ọyak. Bẹ macha cho p'iwa abatte paam arukhi kapyiri.”  
\v 10 Mẹ wọ, Jekọb obiro osi Phero ittabọhng, ọdẹ-ẹ, yina on-obin ofona. 
\p  
\v 11 Iwa Josẹph ọtzọkha irerek ọkkọkka nnuma s'okk'otzekha k'Ijip, k'ẹkhọma cha Rameses, ọnang otte ttara votte pẹ bi bẹ aruk, macha Phero ọtzọhn-ẹ bi, ọsi.  
\v 12 Josẹph obiro ọtzọkha ọchattọhk f'obenga otte, ọmaana votte pẹ, ttara ẹhọhmmọr ch'otte biphyir ekkema, ọnang bẹ otzor k'obhik kwa va pabẹ. 
\s1 Okwo f'ideden ochin ororo k'Ijip 
\p  
\v 13 Iwa ọchattọhk mebubuni kode, okhuri da okwo f'ideden ochin ororo owobha m'ẹkhọma nda biphyir. Wa anọng p'Ijip, ọmaana anọng pa Kenaan an-are ihem okhuri okwo f'ideden.  
\v 14 Wa Josẹph otzobha agbukha p'awobh k'Ijip biphyir ọmaana agbukha p'anọng pa Kenaan am-adebh ọchattọhk, otzima ochina k'ọvaar-họhm kwa Phero.  
\v 15 K'ogbe kw'agbukha akk'anọng p'Ijip ọmaana anọng pa Kenaan aha ka mbọhk, anọng p'Ijip biphyir abina atza akhebha Josẹph aben bi, “Agbukha akk'man aha ka mbọhkh e. Ka yan kw'akkeri man ma mope k'okwo o? Nang man ọchattọhk.” 
\p  
\v 16 Mẹ wọ, Josẹph obhina bẹ bi, “Mada agbukha akk'bọng ka mbọhk aha, bọng dima etzirakpo pyabọng akwu, ifha mosi obhona ttara ọchattọhk.”  
\v 17 Mando kw'anọng mba afon atza atzọkha etzirakpo pyabẹ py'ede nnyanyaang, ọmaana arukhimaan, ọmaana avu, ọmaana abhaam, ttara nnyanyaang dọk, atza anang Josẹph. Wa ọnang bẹ ọchattọhk ma cho nwuma biphyir, k'obhona kw'etzirakpo pyabẹ. 
\p  
\v 18 Mada cho nwuma ọkwọbh, anọng mba afona atza aben Josẹph bi, “Odik kode kwa modubha itta kwaman, odik ode bi, mada agbukha paman ahaha, etzirakpo pyaman en-ede pyọ. Ayongi for saman, ttara irerek saman, ọttọhk fa mobiro ọnang-ọ, itta kwaman dọk kode.  
\v 19 Man ọbọhk katte, ttara irerek saman mope k'okwo k'itzitzikha sọ. Debh man ttara irerek saman, anang man ọchattọhk. Maman ttara irerek saman okk'for ọda bi, mowobha k'ebira cha Phero. Kọ nang man akpo-mọma pa mọyaabha otzima oruk akpen, ifha irerek saman iningi idukhi ibiri iwobha.” 
\p  
\v 20 Mando kwa Josẹph odebhi irerek s'Ijip biphyir ọnang Phero. Anọng p'Ijip biphyir atzọkha iwoni sabẹ akpe, okhuri da okwo f'ideden ọn-ọgaangi kpọng ọnang bẹ. Wa irerek s'Ijip biphyir in-ide sa Phero.  
\v 21 Wa Josẹph on-osi anọng mba ade abira, ttẹwọr k'ebhonho dani ch'Ijip maa, apyiri k'okpong.  
\v 22 Kaambi mẹ wọ, wa irerek s'afọhnẹja kodebhi, okhuri ekkema cha bẹ am-atzọkha ka mbọhk sa Phero, f'osi bẹ abira akhaama ọchattọhk k'ọhaabh f'ofon k'ekkema cha Phero ọnangi bẹ. Kẹ wọ osi wa bẹ irerek sabẹ kakpe e. 
\p  
\v 23 Wa Josẹph on-oben anọng mba bi, “Bọng akk'ara bi, kaam nkk'bọng ndebha ọmaana irerek sabọng biphyir mayina, nnang ọvaar Phero. Bọng na tzọkha achimọma mba atza ayaabha.  
\v 24 Yina, mada bọng asi ipha, bọng kkema ọchattọhk mva k'obe ozen, bọng atzọkha okhung wani ahok Phero. Bọng dọkha ahung mbonggo anna ahok k'ọyayaabha, ọmaana k'ọchattọhk fa bọng, ọmaana nhọhmmọr sabọng, ttara va pabọng.” 
\p  
\v 25 Mẹ wọ, bẹ an-aben bi, “Iyaa, kọ akk'akpen paman akkaana e. Tte mọtzọkha ọphyaam k'itzitzikha s'itta kwaman, mokk'okhera bi, móde abira pa Phero.” 
\p  
\v 26 Iwa Josẹph on-otzini odik nwa ohok mach'ọphaangi kw'okhuri irerek s'Ijip bi, tzọni m'ewu nduma maa apyiri mayina, bẹ am-anang Phero okhung wani k'akhung azen, k'ekpo pya bẹ apha. Oyongi irerek s'afọhnẹja sẹ-sẹ rọ, s'iwa ini sa Phero ide. 
\s1 Odik kwa Josẹph ophyemi 
\p  
\v 27 Wa anọng p'Israẹl aruk k'okhubha kwa Goshẹn k'Ijip. Akpen ajibh bẹ, bẹ akhaama ẹkhakhaama k'ọhaabh, abira amaan ayok k'ọhaabh, obhik kwabẹ obiro ọhaabh. 
\p  
\v 28 Wa Jekọb orukhi k'irek s'Ijip cho chi obhiri afa. Biphyir-phyir wa Jekọb orukhi cho arọbh azenamfa obhiri azenamfa.  
\v 29 Mada ebowu ch'Israẹl ẹm-ẹbaang, oyeri nnwa kwẹ Josẹph, oben-ẹ bi, “Idikha nkk'ọphyaam ndọkha ka kọ k'itzitzikha, kẹ ọbọhk kwọ ka ndaak saam achekhi bi, kọ akhọhkh-m ejibha k'odik-ọkka bi, kaam m'Ijip kánọhnga.  
\v 30 Yina, mada ḿpe ndor abitta paam, kọ tzini obukhi kwaam m'Ijip atza anọhnga kẹ da bẹ anọhng bẹ.” 
\p Mẹ wọ, Josẹph oben bi, “Kaam ńsi-osi mach'abeni.” 
\p  
\v 31 Jekọb on-oben bi, “Kọ chekhi anang-m.” Mẹ wọ e, Josẹph ochekhi ọnang-ẹ. Wa Jekọb, kw'obiro okpena Israẹl ọrakha eho ọnana k'ochikhura kwẹ, ọnang Ibinọkpaabyi ikpokpobha. 
\c 48  
\s1 Jekọb osi va pa Josẹph ittabọhng 
\p  
\v 1 Mada ogbe nwuma ọkk'ọkwọbha, bẹ agbaak Josẹph bi, “Atte ọmmẹ-ẹ ọmma.” Mẹ wọ, Josẹph obina ttara va pẹ p'ijinọng afa p'ade; Manasẹ ttara Ephraim, otza ore otte.  
\v 2 Mada bẹ agbaakhi Jekọb bi, “Nnwa kwọ Josẹph ọkk'ọkwa bi, okwu ọrọ-ọ e,” Jekọb okhonga obina k'ebin ch'oyim, owobha ẹwọr. 
\p  
\v 3 Jekọb on-oben Josẹph bi, “Ibinọkpaabyi kw'Ẹfa biphyir oyin-m abẹ obiro odo-m ka Luz, k'irerek sa Kenaan,  
\v 4 obiro oben-m bi, ‘Kaam ńdọ-ọ ttara ọhaabh, mbiri nttar-ọ ọnọng-mik. Kaam ńsọ-ọ ade obhon k'obungi, mbiri ńdọkha irerek nnang va pa va pọ mach'ekkema chabẹ maa, ogbe ode.’ 
\p  
\v 5 “Mẹ wọ, va mba afa p'ade Manasẹ ọmaana Ephraim p'abhoni k'irek s'Ijip yina kaam nna nkwu, bẹ áde va paam, macha Reubẹn, ọmaana Simeọn ade.  
\v 6 Va adọdọk p'an-abhon bọ án-ade va pọ. Ekkema cha va mba p'án-ade pọ, éfona ka ngọma s'Ephraim, ọmaana Manasẹ.  
\v 7 Wa ode odik kwa nkwu-osisi s'ideden bi, mada mfon ka Padan-Aram ngwuna, wa Rachẹl okwu ope k'eden kẹ da motzim om-orenga k'ẹkhọma cha Kenaan, kw'ọbaang Ẹphrat. Mẹ wọ, wa kaam nnọhng-ẹ k'eden ch'echin Ẹphrat (kw'ode Bẹtẹlẹhẹm).” 
\p  
\v 8 Mẹ wọ, mada Jekọb ore va pa Josẹph, ọbọbh bi, “Bọng anọng bọ kẹ o?” 
\p  
\v 9 Josẹph obhina otte bi, “Va p'Ibinọkpaabyi akk'aam ọnanga bọ ma e.” 
\p Mẹ wọ, Jekọb on-oben bi, “Tzima bẹ akwu, ifha nsi bẹ ittabọhng.” 
\p  
\v 10 M'ogbe nwa, wa Jekọb owonikpa \it bi kpaar\it* dọk komo-ore okhuri atzam. Mẹ wọ, wa Josẹph otzima va mba pẹ afa ọrọkhi otzor otte ka for, otte ọbaakha bẹ. 
\p  
\v 11 Mada okk'bẹ ọbaakha, Israẹl on-oben Josẹph bi, “Kaam chen kinkhokhi bi, na mbiri nne itzitzikha sọ. Yina, itzitzikha sọ sẹ-sẹ arang sa kaam nna mbiri nne, Ibinọkpaabyi ọkk'ọsa bi, mbiri nne va pọ.” 
\p  
\v 12 Mẹ wọ, Josẹph ọn-ọrọbha va mba ka ndaak s'otte, ọrakha ottima itzitzikha k'irerek ọnang Jekọb ikpokpobha.  
\v 13 Mẹ wọ, Josẹph ọbọkha Ephraim k'odimbọhk kwẹ kw'ode kwabọhk kwa Jekọb, obiro ọbọkha Manasẹ ka kwabọhk kwẹ, kw'ode k'odimbọhk kwa Jekọb, ọrọkhi bẹ ọbaanga otte ka for.  
\v 14 Yina, wa Jekọb otzini mbọhk sẹ ọnana va mba ka nho. Ọnana Ephraim kw'ode nnwa-nnwa, odimbọhk, ọnana Manasẹ kw'ode ocheden-nwa, kwabọhk. 
\p  
\v 15 Mẹ wọ, osi Josẹph ittabọhng oben bi, 
\q1 “Tte Ọvaar Ibinọkpaabyi kw'abatte paam Abraham, ọmaana Isaak akpobh, 
\q1 Ibinọkpaabyi kw'ọkk'aam okkeri k'akpen paam biphyir maa, apyiri ma, 
\q1  
\v 16 tte Orenga-eden, kw'ọkk'aam ọkkaana, k'itzama kpenamkpen, odo va mba. 
\q1 Tte va mba akpena che pabẹ abhina kaam, 
\q2 tte bẹ abira akpena che pabẹ abhina, abatte paam Abraham ọmaana Isaak. 
\q2 Tte bẹ ahaabh ayong-oyongi m'ọyagbin.” 
\p  
\v 17 Mada Josẹph ore bi, odimbọhk kw'otte ọnan Ephraim k'eho, ettem ebhem-ẹ. Mẹ wọ e, ọtza bi otza otzini ọbọhk kw'otte ọnan Ephraim k'eho bi, ọnana Manasẹ.  
\v 18 Josẹph oben otte bi, “Mma e itta kwaam, nana oyok nwa kw'ode ocheden odimbọhk kwọ k'eho e.” 
\p  
\v 19 Yina, otte obhum, oben bi, “Nnwa kwaam, nnong ọttọhk fa minsi kẹ e, kaam nnong kẹ bi va pa va pa Manasẹ áde ẹkhọma ch'ideden, ch'ebire ẹtza che. Ayongi mẹ, Ephraim ọ́khaama ẹfa ọyọhnga Manasẹ, va pa va pẹ áde idibhon s'ihaabh-ọhaabh.”  
\v 20 Mando kwa Jekọb osi va mba ittabọhng m'ewu nduma, oben bi, 
\q1 “Anọng p'Israẹl átzima che chọ asi ayok ittabọhng. 
\q2 Tte Ibinọkpaabyi ọsọ-ọ ade mach'Ephraim ọmaana Manasẹ.” 
\p Mẹ wọ, osi Ephraim ode odedennọng ọnang Manasẹ. 
\p  
\v 21 Mẹ wọ e, Jekọb on-oben Josẹph bi, “Ebowu chaam em-efor, yina, Ibinọkpaabyi ówobha ttara bọng, obiro ótzim bọng ọkpa nnam k'irerek s'abatte.  
\v 22 Onode kọ, kaam nnang-ọ irerek nnuma s'egbegbeho, s'iwa kaam ndim ọkkangkkaang kwaam, ọmaana oyuk kwaam mbọkha anọng p'Amọr nna.” 
\c 49  
\s1 Jekọb osi va pẹ ittabọhng 
\p  
\v 1 Iwa Jekọb oyeri va pẹ, oben bi, “Bọng dobha ibe rani, ifha mfha mgbaak bọng eden ch'akpen pabọng áde, k'ogbe ororo. 
\b  
\q1  
\v 2 “Bọng va pa Jekọb, bọng dobha ma, ayonga itzọhng, 
\q2 bọng yonga itzọhng anang kaam atte kwabọng Jekọb, kw'obiro okpena Israẹl. 
\b  
\q1  
\v 3 “Reubẹn, kọ wọ ade ocheden-nwa kwaam, 
\q2 abira ade ẹfa chaam, 
\q1 kọ wọ ade ẹkhọhkha ch'ejinọng chaam, 
\q2 abira ade ọnọng kwa kaam ndim nkkaara ẹmma. 
\q1  
\v 4 Kọ áde mach'asi p'abobh-obobh, kọ ojibhada dọk kàre, 
\q1 da kọ atzam ọtta, arẹkhi eyima ch'atte, 
\q2 ayima ọkkọra-kwanọng kwẹ abẹ. 
\b  
\q1  
\v 5 “Simeọn ọmaana Lẹvi asi ẹmmaana dani, 
\q2 akkangkkaang pabẹ ade egbongkpo py'ọgbaan. 
\q1  
\v 6 Tte kaam nningi ẹkhaan chabẹ ndọni, 
\q2 tte kaam nningi wani k'ottem kw'ewobha chabẹ nde, 
\q1 okhuri bi, bẹ akk'ittemdọkhiji sabẹ atzima afhu anọng haabhada. 
\q1 Bẹ abira am-asi abhaam ọgbaan, 
\q2 abọkha pyẹ aphyakhi mmo mach'ọdaakhi bẹ. 
\q1  
\v 7 Opyibh-opyibh ọnang ittemdọkhiji sabẹ, 
\q1 ottem-gọma otzim bẹ ofhu anọng ẹgagaangi. 
\q2 Opyibh-opyibh ọnang ottem-gọma kwabẹ, 
\q2 kw'otzim bẹ osi ọgbaan. 
\q1 Kaam ńsi va pa va aningi k'ibẹ rani arukhi k'ẹkhọma cha Jekọb. 
\q2 Mbiri ńsi bẹ an-akhọmikha aruk, makhọra Israẹl. 
\b  
\q1  
\v 8 “Onode kọ Juda, 
\q1 votte pọ ánang-ọ ikpokpobha. 
\q2 Attattaanga-nọng pọ ábira awobha irekh-irek kwọ, 
\q2 votte pọ biphyir áhakha nho anang-ọ. 
\q1  
\v 9 Kọ Juda, nnwa kwaam, ade okye-nwa; 
\q2 kw'ofhu etzen ochi, ofona ọbhana k'ibe s'ofon okwu, 
\q1 mach'okye-dim, kw'oyim ọkpẹ-ọkpẹ, 
\q2 mach'okye-kwa, ọnọng kw'ofha ogbikh-ọ kode. 
\q1  
\v 10 Ọnọng kw'ọfha ọtzọkha ẹfa ka mbọhk s'ẹkhọma cha Juda kode e, 
\q2 ẹfa échina ororo ewobha ka mbọhk sa va pa va pa Juda, 
\q1 matzẹmaa opyiri k'ogbe kw'idibhon ichen-ẹ ndumma, 
\q2 ngọma biphyir awobha irekh-irek kwẹ. 
\q1  
\v 11 Kẹ ọgbana ẹnyanyaang chẹ k'echi cha grep, 
\q2 ọgbana nnwa kw'ọnyanyaang-kwakwẹ k'echibọhnga ch'ẹdaakh-ẹ. 
\q1 Kẹ ọ́khaama atzuk matzẹmaa on-otzima bẹ ogbobhi anọhma-baba pẹ, 
\q2 otzima asi-khora pa grep ogbobhi ọbara fẹ. 
\q1  
\v 12 Kẹ ókhor chen okhuri atzuk haabha p'ọgwo, 
\q2 aha pẹ áwur ayong-oyongi okhuri abasi haabha p'ogwo. 
\b  
\q1  
\v 13 “Zẹbulun ósi obhon kwẹ k'ẹraangakha, 
\q2 ẹkha ch'éde ibe s'anzurikkaang am-attima akwokha ọnwọhng. 
\q2 Enem chẹ étzima maa, etzuma k'okhubha kwa Sidọn. 
\b  
\q1  
\v 14 “Isaaka ode ẹnyanyaang ch'ẹkhaam ẹfa, 
\q2 ch'eyim k'ottem kw'avukwuri. 
\q1  
\v 15 Mada ore odem kw'iwọhngkwokhabe sẹ ijibhi, 
\q2 omaana odem kw'irerek sẹ ibiri ijibh ewobha, 
\q1 ọ́hakha ẹbabaang chẹ ọtzọkha ẹtzọhkha, 
\q2 obiro ókhera bi, osi ọtzọhm f'ihem mach'obira. 
\b  
\q1  
\v 16 “Dan ọ́nang anọng pẹ eponga-ttọhna ẹkkakka, 
\q2 mach'efonamma dani ch'Israẹl. 
\q1  
\v 17 Dan ójora macha jọhk ch'ewobh k'eden ọkhaan-ọkhaan, 
\q2 mach'ọfhọfhọbhi kw'oyim k'eden, 
\q1 mach'ọfhọfhọbhi kw'okhimi ẹnyanyaang k'abhokhọkhọri, 
\q2 ch'esi ọyaar-ẹnyanyaang ogina otto nnama-nnam. 
\b  
\q1  
\v 18 “O Ọvaar Ibinọkpaabyi, kaam nwobh ndik ẹnaanga chọ. 
\b  
\q1  
\v 19 “Ẹkhaan ch'ariribha erima Gad abẹ, 
\q2 yina, kẹ ómuma bẹ ekpo k'abhokhọkhọri da bẹ arọbh mkpaana-kpaana. 
\b  
\q1  
\v 20 “Ashẹr ọ́khaam ọchattọhk ọkkakka f'ọdaam-ọdaam, 
\q2 kẹ ósi ọchattọhk ọkkakka f'ọbaana bi, bẹ anang ọvaarnọng ochi. 
\b  
\q1  
\v 21 “Naphtali ode mach'ojibh-kwa, kw'oreng ka for sẹ, 
\q2 ojibh-kwa, kw'ọmaani va p'ajibh-ojibh. 
\b  
\q1  
\v 22 “Josẹph ode mach'echi cha grep ch'ebe ẹbaanga ekhekha, 
\q2 va pẹ ade mach'abọhnga p'anyaami avura k'egbegbeho. 
\q1  
\v 23 Atta-ayuk átzima idọdọkhi arim-ẹ abẹ, 
\q2 bẹ am-arim-ẹ abẹ ttara ittattaanga s'ideden. 
\q1  
\v 24 Yina, kọ akhema bẹ achina ororo, 
\q1 okhuri da kọ abọk oyuk kwọ, m'ejinọng-ejinọng. 
\q2 Ofona k'ẹfa ch'Ibinọkpaabyi kw'Ẹfa biphyir, kwa Jekọb okpobh, 
\q2 osi mbọhk sọ ngaang-ọgaangi. 
\q1 Okkeri-arukhimaan kw'ode Ẹtzakpa ch'Israẹl, 
\q1  
\v 25 kw'ode Ibinọkpaabyi kw'atte okpobh kw'ọkkaan-ọ, 
\q2 ode Ibinọkpaabyi kw'Ẹfa biphyir kw'ọdọ-ọ 
\q2 ttara ẹdaa ch'ẹrọng ẹnangi, 
\q1 ttara ẹdaa ch'asi p'awobha k'irerek ẹtzaanga, 
\q2 ttara ẹdaa ch'ọmaan ọmaana abasi k'ọhaabh. 
\q1  
\v 26 Ojibhada kw'atzọk k'atte kwọ, 
\q1 ode ojibhada kw'ofon ka mgbegbeho s'iwa kẹ-khẹ, 
\q2 Ọyọhnga idik ọkkakka s'ifon ka mgbegbeho ndamsẹ. 
\q1 Tte Josẹph ọtzọkha ojibhada nwa biphyir ọkhaama, 
\q2 tte kẹ ode oho kwa bẹ akk'atzekha k'ottem kwa votte pẹ. 
\b  
\q1  
\v 27 “Bẹnjamin ode mach'etzen ch'ẹkkaam-ọkkaam, 
\q2 ch'echin ororo echi ayok k'ekpebha, 
\q2 ebire ekkema ọgbọm f'echi k'ẹchọhkha.” 
\p  
\v 28 Anọng mba biphyir bọ iwa asi mfonamma jobh obhiri mfa s'Israẹl. Ma wọ ode idik s'iwa otte ọgbaakhi k'ogbe kw'osi bẹ ittabọhng. Wa osi ọnọng-ọnọng ittabọhng sẹ s'ibaan-ẹ. 
\s1 Obo kwa Jekọb 
\p  
\v 29 Mẹ wọ, ọn-ọtzọhn bẹ bi, “Ebowu chaam em-efor cha mpe ndor abitta e. Bọng nọhng-m kẹ da abitta paam anọhng, k'ọmma kw'itzakpa kw'owobh k'owoni kw'Ẹphrọn kw'ofon Het.  
\v 30 K'ọmma kw'itzakpa kw'owobh ka Makpẹla, ọbaanga Mamrẹ k'irek sa Kenaan, kw'iwa Abraham odebhi ttara k'owoni ka mbọhk s'Ẹphrọn kw'ofon Het, otzima osi inọhng-anọng.  
\v 31 Mẹ wọ kw'iwa bẹ anọhng Abraham, ttara kwanọng kwẹ, Sara. M'ibe nna rani rọ s'iwa bẹ abira anọhng Isaak, ttara kwanọng kwẹ, Rẹbẹka. Mẹ wọ kw'iwa kaam mbiri nnọhnga Lea.  
\v 32 Wa Abraham odebhi owoni nwa, ọmaana ọmma kw'itzakpa kw'owobh mẹ, ka mbọhk s'anọng pa Het.” 
\p  
\v 33 Mada Jekọb okk'va pẹ ndọhna ọnanga biphyir, oyebh mmo sẹ ọnana k'ebin, ope otzor anọng pẹ. 
\c 50  
\p  
\v 1 Josẹph otto ọkpẹkhi obukhi kw'otte, obhom obiro ọbaakh-ẹ.  
\v 2 Mẹ wọ, Josẹph ọtzọhn akkeri-akhọkhọma p'atzọhmnọng pẹ bi, bẹ atzini obukhi kw'otte Jekọb atza aye, bẹ abira akker-ẹ ifha oningi ochu.  
\v 3 Wa bẹ ayẹ-ẹ k'iwu arọbh afa biphyir mach'ẹmmaana ch'apfura oyeye ede k'Ijip. Wa anọng p'Ijip awobh ka nkwu-osisi k'iwu arọbh attaan obhiri jobh. 
\p  
\v 4 Mada iwu nna sa nkwu-osisi ikk'ittonga, Josẹph oben akhaan-nọng pa Phero bi, “Idikha kaam nkk'ọphyaam ndọkha ka bọng k'itzitzikha, bọng kkaan-m agbaak Phero atzim anang-m bi,  
\v 5 wa otte kwaam osi-m ndọkha ọnwọhngi da oben-m bi, ‘Ebowu chaam em-efor, mpe, rọhng atza anọhng-m k'epekhubh cha ndumi k'ẹkhọma cha Kenaan nnang for saam.’ Mẹ wọ, tte nda nnọhnga otte kwaam, nkk'ẹ nnọhnga, kaam ńkhun-okhuna e.” 
\p  
\v 6 Mẹ wọ, Phero oben-ẹ bi, “Kọ rọhng atza anọhnga atte, atzor k'ọnwọhngi kw'iwa atte ọkk'ọsa atzọkha.” 
\p  
\v 7 Mando kwa Josẹph ofon bi, ọtza ọnọhnga otte. Wa akhaan-nọng pa Phero biphyir, ọmaana adedennọng p'ọvaar-dimpa kwa Phero, ọmaana adedennọng p'irek s'Ijip biphyir,  
\v 8 akwu attara k'ẹhọhmmọr cha Josẹph biphyir, ọmaana votte pẹ, ttara anọng p'ẹhọhmmọr ch'otte Jekọb, atzọni Josẹph abẹ. Wa va bẹ-bẹ, ọmaana etzirakpo bọ an-arikhi ka Goshẹn.  
\v 9 Wa akpaar p'ideden pa nnyanyaang mindọr, ọmaana ayaari-nnyanyaang abira atzọn-ẹ abẹ. Wa ode ẹkhaan ch'ẹhaabh-ọhaabh. 
\p  
\v 10 Mada bẹ apyiri k'ibe sa bẹ am-awobha akhaani abarli-mọma k'Atad, ka Jọrdan okhubha, bẹ abhom abomọng p'adọkhi bẹ ọdọkhi k'ẹrọng. M'ibe nna rani rọ s'iwa Josẹph owobh ka nkwu-osisi s'obo kw'otte k'iwu izenamfa.  
\v 11 Wa anọng pa Kenaan p'arukhi m'ibe nna sa bẹ am-akhaani abarli-mọma k'Atad, p'are obo kwa Josẹph osi kw'otte, an-ayeri ibe nnuma s'iwobh k'okhubha kwa Jọrdan, Abẹl-Mizrayim, aben bi, “Anọng p'Ijip awobh ka nkwu-osisi s'obo!” 
\p  
\v 12 Mẹ wọ, wa va pa Jekọb asi mach'otte okk'bẹ ọtzọhna.  
\v 13 Iwa va pẹ atzini obukhi kw'otte achina k'irek sa Kenaan, atza anọhnga k'ọmma kw'itzakpa kw'owobh ka Makpẹla, ọbaanga Mamrẹ. Wa Abraham ọkk'ọmma nwa kw'itzakpa odebha ttara owoni kw'owobh mẹ, ka mbọhk s'Ẹphrọn kw'ofon Het, otzima osi inọhng-anọng.  
\v 14 Mada Josẹph okk'otte ọnọhnga, kẹ ọmaana votte pẹ, ttara anọng p'akhubhi bẹ obo biphyir, akpa nnam abhana k'Ijip. 
\s1 Josẹph odini votte pẹ nttem. 
\p  
\v 15 Mada bẹ akk'obo akhuna, votte pa Josẹph atzin bi, otte kwabẹ k'akpen dọk kode. Bẹ an-abọbh for sabẹ bi, “Idikha Josẹph on-obe mayina ochibhi bi otzukha itzama kpenamkpen sa mọkk'ẹ ọsa khi?”  
\v 16 Mẹ wọ, bẹ atzọhm ẹkkaabha anang Josẹph bi, “Wa atte ọnangi man ndọhna yina on-ope e:  
\v 17 Wa oben bi, ‘Bọng gbaak Josẹph bi, kaam mbeni bi, tte obina ọnang bọng k'itzama kpenamkpen sa bọng akk'ẹ asa.’ Mẹ wọ, mokhukh-ọ okhukhi bi, tte obina ọnang ottotto kw'atzọhmnọng p'Ibinọkpaabyi kw'iwa atte kwọ okpobh.” Mada ẹkkaabha nda epyiri Josẹph k'itzọhng, obhom. 
\p  
\v 18 Mẹ wọ, votte afona atza akhebh-ẹ, atto abangi m'irerek abhom amọng m'itzitzikha sẹ, aben bi, “Maman ode abira pọ e.” 
\p  
\v 19 Yina, Josẹph oben bẹ bi, “Ojora oningi bọng osi. Kaam wọ nde Ibinọkpaabyi o?  
\v 20 Wa bọng achibhi bi, bọng asi kaam itzama. Yina, wa Ibinọkpaabyi otzim ochibhi ọkkọkka otte odik nwa ọbọhk bi, kwẹ ode, ifha ọkkaana akpen p'anọng haabhada, macha kwẹ ode ma.  
\v 21 Mẹ wọ, ojora oningi bọng osi. Kaam ńkkeri bọng okkeri ttara va pa bọng.” Josẹph ochina ororo ọnang votte pẹ ottembara, obiro ọgbaak bẹ attem-dinitzim. 
\s1 Obo kwa Josẹph. 
\p  
\v 22 Wa Josẹph ọmaana ẹhọhmmọr ch'otte biphyir achina ororo aruk k'Ijip. Wa Josẹph orukhi cho arọbh azen obhiri jobh,  
\v 23 matzẹmaa ore va pa va p'Ephraim. Wa Josẹph obiro otzin bi, va p'afon ka ndaak sa Makir kw'ode nnwa kwa Manasẹ, abira ade va pẹ. 
\p  
\v 24 Iwa Josẹph ọgbaak votte pẹ bi, “Kaam ebowu chaam em-efor e, yina, mpe, Ibinọkpaabyi óhok echekhi chẹ ohok bi, otzima bọng obina m'irerek nna, ọtza ọnang bọng irerek s'iwa ọnwọhngi bi, ọnang Abraham, ọmaana Isaak, ttara Jekọb.”  
\v 25 Mẹ wọ, Josẹph osi votte pẹ p'ade va p'Israẹl atzọkha ọnwọhngi k'itzitzikha sẹ, aben bi, “K'odik ọkkọkka, Ibinọkpaabyi ọ́nang bọng ẹkkaana ọnang, bọng akhaambi atzini akhọbhi paam m'irek nna atzima afona.” 
\p  
\v 26 Mẹ wọ e, wa Josẹph ope da ode cho arọbh azen obhiri jobh. Mada anọng akk'obukhi kwẹ aya, bẹ atzin-ẹ akhe k'Ẹkkọhbhi k'Ijip.