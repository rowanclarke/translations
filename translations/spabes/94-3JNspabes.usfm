\v 12 \w Todos|strong="G3956"\w* dan buen \w testimonio|strong="G3141"\w* \w de|strong="G5259"\w* \w Demetrio|strong="G1216"\w*, \w y|strong="G2532"\w* \w también|strong="G2532"\w* \w la|strong="G3588"\w* verdad \w misma|strong="G5259"\w*. \w Nosotros|strong="G2249"\w* \w también|strong="G2532"\w* damos \w testimonio|strong="G3141"\w* \w de|strong="G5259"\w* \w él|strong="G3588"\w*, \w y|strong="G2532"\w* \w tú|strong="G3588"\w* \w sabes|strong="G1492"\w* \w que|strong="G3754"\w* \w nuestro|strong="G2249"\w* \w testimonio|strong="G3141"\w* es verdadero.   
\p
\v 13 \w Tenía|strong="G2192"\w* \w muchas|strong="G4183"\w* cosas \w que|strong="G2532"\w* \w escribirte|strong="G1125"\w*, \w pero|strong="G2532"\w* \w no|strong="G3756"\w* \w quiero|strong="G2309"\w* hacerlo \w con|strong="G1223"\w* \w tinta|strong="G3188"\w* \w y|strong="G2532"\w* \w pluma|strong="G2563"\w*.   
