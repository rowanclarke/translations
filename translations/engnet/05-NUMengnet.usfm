\v 11 “\w Phinehas|strong="H6372"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Eleazar, \w the|strong="H5921"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Aaron \w the|strong="H5921"\w* \w priest|strong="H3548"\w*, \w has|strong="H3478"\w* \w turned|strong="H7725"\w* \w my|strong="H5921"\w* \w anger|strong="H2534"\w* \w away|strong="H7725"\w* \w from|strong="H7725"\w* \w the|strong="H5921"\w* \w Israelites|strong="H3478"\w*, \w when|strong="H3615"\w* \w he|strong="H3808"\w* manifested \w such|strong="H3808"\w* \w zeal|strong="H7068"\w* \w for|strong="H5921"\w* \w my|strong="H5921"\w* \w sake|strong="H5921"\w* \w among|strong="H8432"\w* \w them|strong="H5921"\w*, \w so|strong="H3808"\w* \w that|strong="H3478"\w* \w I|strong="H5921"\w* \w did|strong="H3478"\w* \w not|strong="H3808"\w* \w consume|strong="H3615"\w* \w the|strong="H5921"\w* \w Israelites|strong="H3478"\w* \w in|strong="H5921"\w* \w my|strong="H5921"\w* \w zeal|strong="H7068"\w*.  
