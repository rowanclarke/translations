\v 14 \w David|strong="H1732"\w* estaba entonces en el refugio, y la guarnición filistea estaba en Belén.
\p 
\v 15 \w David|strong="H1732"\w* tuvo un deseo y exclamó: ¡\w Quién|strong="H4310"\w* \w me|strong="H4310"\w* diera \w a|strong="H3068"\w* \w beber|strong="H8248"\w* \w agua|strong="H4325"\w* del pozo \w de|strong="H4325"\w* Belén, \w que|strong="H4310"\w* está junto \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w*!
\v 16 \w Y|strong="H3068"\w* los \w tres|strong="H7969"\w* \w valientes|strong="H1368"\w* irrumpieron en \w el|strong="H4264"\w* \w campamento|strong="H4264"\w* \w filisteo|strong="H6430"\w* y \w sacaron|strong="H7579"\w* \w agua|strong="H4325"\w* \w del|strong="H8354"\w* pozo, junto \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w* \w de|strong="H4325"\w* Belén, y \w se|strong="H3808"\w* la \w llevaron|strong="H5375"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*. Pero \w él|strong="H4264"\w* \w no|strong="H3808"\w* quiso \w beberla|strong="H8354"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* la derramó como ofrenda \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, y dijo:
\p 
\v 17 ¡\w Lejos|strong="H2486"\w* \w esté|strong="H2063"\w* \w de|strong="H1818"\w* \w mí|strong="H5315"\w*, oh \nd \w Yavé|strong="H3068"\w*\nd*, \w hacer|strong="H6213"\w* \w esto|strong="H2063"\w*! ¿\w Beberé|strong="H8354"\w* \w yo|strong="H5315"\w* \w la|strong="H2063"\w* \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* los varones \w que|strong="H3808"\w* \w fueron|strong="H1980"\w* con riesgo \w de|strong="H1818"\w* sus \w vidas|strong="H5315"\w*? \w Y|strong="H3068"\w* \w no|strong="H3808"\w* quiso \w beberla|strong="H8354"\w*. Tales cosas \w hicieron|strong="H6213"\w* \w estos|strong="H2063"\w* \w tres|strong="H7969"\w* \w valientes|strong="H1368"\w*.
\p 
\v 18 \w Y|strong="H3068"\w* \w Abisai|strong="H7969"\w*, hermano \w de|strong="H5921"\w* \w Joab|strong="H3097"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Sarvia, \w era|strong="H1931"\w* \w el|strong="H1931"\w* \w principal|strong="H7218"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* 30. \w Éste|strong="H1931"\w* \w blandió|strong="H5782"\w* \w su|strong="H1931"\w* \w lanza|strong="H2595"\w* \w contra|strong="H5921"\w* 300 \w que|strong="H1931"\w* fueron traspasados, \w y|strong="H5921"\w* tuvo renombre \w entre|strong="H5921"\w* \w los|strong="H1121"\w* \w tres|strong="H7969"\w*.
\v 19 \add Abisai\add* \w fue|strong="H1961"\w* \w el|strong="H3588"\w* \w más|strong="H3588"\w* renombrado \w de|strong="H4480"\w* \w los|strong="H1961"\w* 30 \w y|strong="H3588"\w* \w fue|strong="H1961"\w* \w su|strong="H3588"\w* \w jefe|strong="H8269"\w*, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w fue|strong="H1961"\w* incluido \w entre|strong="H3808"\w* \w los|strong="H1961"\w* \w tres|strong="H7969"\w*.
\p 
\v 20 Después, \w Benaía|strong="H1141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joiada|strong="H3077"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* un \w hombre|strong="H1121"\w* valiente \w de|strong="H1121"\w* múltiples proezas, natural \w de|strong="H1121"\w* \w Cabseel|strong="H6909"\w*, \w mató|strong="H5221"\w* \w a|strong="H3068"\w* \w ambos|strong="H8147"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Ariel \w de|strong="H1121"\w* \w Moab|strong="H4124"\w*. \w En|strong="H8432"\w* un \w día|strong="H3117"\w* \w de|strong="H1121"\w* nieve, bajó y \w mató|strong="H5221"\w* \w a|strong="H3068"\w* un león \w dentro|strong="H8432"\w* \w de|strong="H1121"\w* un foso.
\v 21 También \w mató|strong="H2026"\w* \w a|strong="H3068"\w* un \w egipcio|strong="H4713"\w* de enorme \w estatura|strong="H4758"\w*. \w El|strong="H1931"\w* \w egipcio|strong="H4713"\w* llevaba una \w lanza|strong="H2595"\w* \w en|strong="H5221"\w* \w la|strong="H1931"\w* \w mano|strong="H3027"\w*. Benaía \w fue|strong="H1931"\w* contra \w él|strong="H1931"\w* con un cayado, arrebató \w la|strong="H1931"\w* \w lanza|strong="H2595"\w* de \w la|strong="H1931"\w* \w mano|strong="H3027"\w* del \w egipcio|strong="H4713"\w* y \w lo|strong="H1931"\w* \w mató|strong="H2026"\w* con \w su|strong="H1931"\w* propia \w lanza|strong="H2595"\w*.
\v 22 \w Benaía|strong="H1141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joiada|strong="H3077"\w*, \w hizo|strong="H6213"\w* \w esto|strong="H6213"\w* y \w tuvo|strong="H6213"\w* renombre entre \w los|strong="H1121"\w* 30 \w valientes|strong="H1368"\w*.
\v 23 \w Fue|strong="H3808"\w* distinguido \w entre|strong="H3808"\w* los 30, pero \w no|strong="H3808"\w* alcanzó \w a|strong="H3068"\w* los \w tres|strong="H7969"\w*. \w David|strong="H1732"\w* \w lo|strong="H3808"\w* \w puso|strong="H7760"\w* \w al|strong="H4480"\w* frente \w de|strong="H4480"\w* su guardia personal.
\p 
\v 24 \w Asael|strong="H6214"\w*, hermano \w de|strong="H1121"\w* \w Joab|strong="H3097"\w*, fue \w de|strong="H1121"\w* \w los|strong="H1121"\w* 30, así como Elhanán, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Dodo, \w de|strong="H1121"\w* Belén,
\v 25 Samá harodita, Elica harodita,
\v 26 \w Heles|strong="H2503"\w* paltita, \w Ira|strong="H5896"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Iques, \w tecoíta|strong="H8621"\w*,
\v 27 Abiezer anatotita, Mebunai \w husatita|strong="H2843"\w*,
\v 28 Salmón ahohíta, \w Maharai|strong="H4121"\w* \w netofatita|strong="H5200"\w*,
\v 29 Heleb, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Baana|strong="H1196"\w*, \w netofatita|strong="H5200"\w*, Itai, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ribai, \w de|strong="H1121"\w* \w Gabaa|strong="H1390"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Benjamín|strong="H1144"\w*,
\v 30 \w Benaía|strong="H1141"\w* \w piratonita|strong="H6553"\w*, Hidai, de los \w arroyos|strong="H5158"\w* de \w Gaas|strong="H1608"\w*,
\v 31 Abi-albón arbatita, Azmavet barhumita,
\v 32 Eliaba \w saalbonita|strong="H8170"\w*, Jonatán, \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jasén,
\v 33 Samá \w ararita|strong="H2043"\w*, Ahíam, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sarar, \w ararita|strong="H2043"\w*,
\v 34 Elifelet, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahasbai, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Maaca, Eliam, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahitofel, \w gilonita|strong="H1526"\w*,
\v 35 Hezri \w carmelita|strong="H3761"\w*, Paarai arbita,
\v 36 \w Igal|strong="H3008"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Natán, \w de|strong="H1121"\w* Soba, \w Bani|strong="H1137"\w* gadita,
\v 37 \w Selec|strong="H6768"\w* amonita, \w Naharai|strong="H5171"\w* beerotita, \w escudero|strong="H5375"\w* \w de|strong="H1121"\w* \w Joab|strong="H3097"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sarvia,
\v 38 \w Ira|strong="H5896"\w* itrita, \w Gareb|strong="H1619"\w* itrita,
\v 39 y Urías heteo. Total: 37.
\c 24
\s1 Censo ordenado como castigo por \nd Yavé\nd*
\p 
\v 1 La \w ira|strong="H3212"\w* de \nd \w Yavé|strong="H3068"\w*\nd* \w volvió|strong="H3254"\w* \w a|strong="H3068"\w* encenderse \w contra|strong="H3478"\w* \w Israel|strong="H3478"\w*, \w e|strong="H3068"\w* incitó \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w contra|strong="H3478"\w* ellos para que dijera: \w Vé|strong="H3212"\w*, haz un censo de \w Israel|strong="H3478"\w* y de \w Judá|strong="H3063"\w*.
\p 
\v 2 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* dijo \w a|strong="H3068"\w* \w Joab|strong="H3097"\w*, \w general|strong="H8269"\w* del \w ejército|strong="H2428"\w*, \w que|strong="H4994"\w* estaba \w con|strong="H5704"\w* \w él|strong="H3605"\w*: Recorre \w todas|strong="H3605"\w* las \w tribus|strong="H7626"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w*, \w desde|strong="H5704"\w* \w Dan|strong="H1835"\w* \w hasta|strong="H5704"\w* Beerseba, \w y|strong="H5704"\w* haz un censo del \w pueblo|strong="H5971"\w*, \w para|strong="H5704"\w* \w que|strong="H4994"\w* \w yo|strong="H4994"\w* \w sepa|strong="H3045"\w* \w el|strong="H3605"\w* \w número|strong="H4557"\w* \w de|strong="H5704"\w* \w la|strong="H3605"\w* \w gente|strong="H5971"\w*.
\p 
\v 3 Pero \w Joab|strong="H3097"\w* dijo \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: ¡\nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w añada|strong="H3254"\w* \w al|strong="H4428"\w* \w pueblo|strong="H5971"\w* 100 \w veces|strong="H6471"\w* \w más|strong="H3254"\w*, y \w que|strong="H4100"\w* mi \tl ʼadón\tl* \w el|strong="H1992"\w* \w rey|strong="H4428"\w* \w lo|strong="H1697"\w* \w vea|strong="H7200"\w*! Pero, ¿\w por|strong="H1697"\w* \w qué|strong="H4100"\w* \w desea|strong="H2654"\w* \w esto|strong="H2088"\w* mi \tl ʼadón\tl* \w el|strong="H1992"\w* \w rey|strong="H4428"\w*?
\p 
\v 4 Pero \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w prevaleció|strong="H2388"\w* \w contra|strong="H5921"\w* \w Joab|strong="H3097"\w* \w y|strong="H5921"\w* \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w jefes|strong="H8269"\w* \w del|strong="H5921"\w* \w ejército|strong="H2428"\w*. \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w* \w Joab|strong="H3097"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w jefes|strong="H8269"\w* \w del|strong="H5921"\w* \w ejército|strong="H2428"\w* \w salieron|strong="H3318"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w presencia|strong="H6440"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w para|strong="H5921"\w* hacer \w el|strong="H5921"\w* censo \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.
\p 
\v 5 Cruzaron \w el|strong="H5674"\w* \w Jordán|strong="H3383"\w* y acamparon \w en|strong="H8432"\w* \w Aroer|strong="H6177"\w*, \w a|strong="H3068"\w* la \w derecha|strong="H3225"\w* de la \w ciudad|strong="H5892"\w* que está \w en|strong="H8432"\w* \w medio|strong="H8432"\w* del valle de \w Gad|strong="H1410"\w*, junto \w a|strong="H3068"\w* \w Jazer|strong="H3270"\w*.
\v 6 Después fueron \w a|strong="H3068"\w* \w Galaad|strong="H1568"\w* y la tierra de los hititas, y de allí \w a|strong="H3068"\w* Dan, Haán y los \w alrededores|strong="H5439"\w* de \w Sidón|strong="H6721"\w*.
\v 7 Fueron \w luego|strong="H3318"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w fortaleza|strong="H4013"\w* de \w Tiro|strong="H6865"\w* y \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* de \w los|strong="H3605"\w* \w heveos|strong="H2340"\w* y \w los|strong="H3605"\w* \w cananeos|strong="H3669"\w*, y por último se dirigieron al sur de \w Judá|strong="H3063"\w* hasta Beerseba.
\p 
\v 8 \w Y|strong="H3068"\w* después de recorrer \w el|strong="H3605"\w* país, volvieron \w a|strong="H3068"\w* Jerusalén al final de \w nueve|strong="H8672"\w* \w meses|strong="H2320"\w* y 20 \w días|strong="H3117"\w*.
\p 
\v 9 \w Joab|strong="H3097"\w* \w entregó|strong="H5414"\w* el censo del \w pueblo|strong="H5971"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*. \w Los|strong="H1961"\w* \w de|strong="H2568"\w* \w Israel|strong="H3478"\w* \w fueron|strong="H1961"\w* 800.000 guerreros \w que|strong="H5971"\w* portaban \w espada|strong="H2719"\w*, y \w los|strong="H1961"\w* \w de|strong="H2568"\w* \w Judá|strong="H3063"\w*, 500.000 hombres.
\p 
\v 10 \w Pero|strong="H3588"\w* después \w que|strong="H3588"\w* \w David|strong="H1732"\w* \w hizo|strong="H6213"\w* \w contar|strong="H5608"\w* al \w pueblo|strong="H5971"\w*, le remordió \w el|strong="H3588"\w* \w corazón|strong="H3820"\w*. \w Así|strong="H3651"\w* \w que|strong="H3588"\w* \w David|strong="H1732"\w* dijo \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*: \w Pequé|strong="H2398"\w* \w gravemente|strong="H3966"\w* al \w hacer|strong="H6213"\w* \w esto|strong="H3651"\w*. \w Ahora|strong="H6258"\w*, oh \nd \w Yavé|strong="H3068"\w*\nd*, \w te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* perdones \w la|strong="H3588"\w* \w iniquidad|strong="H5771"\w* \w de|strong="H3588"\w* \w tu|strong="H6213"\w* esclavo, \w porque|strong="H3588"\w* obré \w neciamente|strong="H5528"\w*.
\v 11 \w Cuando|strong="H1961"\w* \w David|strong="H1732"\w* \w se|strong="H1961"\w* \w levantó|strong="H6965"\w* \w por|strong="H1697"\w* la \w mañana|strong="H1242"\w*, la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w vino|strong="H1961"\w* al \w profeta|strong="H5030"\w* \w Gad|strong="H1410"\w*, \w vidente|strong="H2374"\w* \w de|strong="H1697"\w* \w David|strong="H1732"\w*:
\v 12 \wj \w Vé|strong="H1980"\w* \w y|strong="H5921"\w* \w dí|strong="H1696"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*: \nd \w Yavé|strong="H3068"\w*\nd* \w dice|strong="H1696"\w*: \w Tres|strong="H7969"\w* \w cosas|strong="H1992"\w* \w te|strong="H5921"\w* propongo. Escoge una \w de|strong="H5921"\w* \w ellas|strong="H1992"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w Yo|strong="H6213"\w* \w te|strong="H5921"\w* \w la|strong="H5921"\w* \w haga|strong="H6213"\w*.\wj*
\p 
\v 13 \w Gad|strong="H1410"\w* \w fue|strong="H1961"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* y \w le|strong="H1931"\w* preguntó: \wj ¿\w Qué|strong="H4100"\w* vengan \w siete|strong="H7651"\w* \w años|strong="H8141"\w* \w de|strong="H6440"\w* hambruna en tu tierra, \w qué|strong="H4100"\w* huyas \w tres|strong="H7969"\w* \w meses|strong="H2320"\w* \w de|strong="H6440"\w* tus \w adversarios|strong="H6862"\w* mientras te \w persiguen|strong="H7291"\w*, \w o|strong="H3068"\w* \w qué|strong="H4100"\w* vengan \w tres|strong="H7969"\w* \w días|strong="H3117"\w* \w de|strong="H6440"\w* \w pestilencia|strong="H1698"\w* en tu tierra? \wj* \w Considera|strong="H3045"\w* \w ahora|strong="H6258"\w* \w qué|strong="H4100"\w* debo \w responder|strong="H7725"\w* al \w que|strong="H4100"\w* me \w envía|strong="H7971"\w*.
\p 
\v 14 \w David|strong="H1732"\w* respondió \w a|strong="H3068"\w* \w Gad|strong="H1410"\w*: \w Estoy|strong="H6862"\w* \w en|strong="H3588"\w* \w gran|strong="H3966"\w* \w angustia|strong="H6862"\w*. \w Es|strong="H3027"\w* preferible \w caer|strong="H5307"\w* \w en|strong="H3588"\w* \w manos|strong="H3027"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w que|strong="H3588"\w* \w caer|strong="H5307"\w* \w en|strong="H3588"\w* \w manos|strong="H3027"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* hombres, \w porque|strong="H3588"\w* \w muchas|strong="H7227"\w* \w son|strong="H3588"\w* las \w misericordias|strong="H7356"\w* \w de|strong="H3588"\w* \w Él|strong="H3588"\w*.
\p 
\v 15 \nd \w Yavé|strong="H3068"\w*\nd* envió la peste \w sobre|strong="H4480"\w* \w Israel|strong="H3478"\w* \w desde|strong="H4480"\w* la \w mañana|strong="H1242"\w* \w hasta|strong="H5704"\w* el \w tiempo|strong="H6256"\w* \w señalado|strong="H4150"\w*. \w Desde|strong="H4480"\w* \w Dan|strong="H1835"\w* \w hasta|strong="H5704"\w* Beerseba \w murieron|strong="H4191"\w* 70.000 hombres \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w*.
\v 16 Pero \w cuando|strong="H1961"\w* \w el|strong="H5973"\w* \w Ángel|strong="H4397"\w* \w extendió|strong="H7971"\w* su \w mano|strong="H3027"\w* hacia Jerusalén \w para|strong="H1961"\w* destruirla, \nd \w Yavé|strong="H3068"\w*\nd* cambió \w de|strong="H5973"\w* parecer \w con|strong="H5973"\w* respecto \w a|strong="H3068"\w* aquel \w mal|strong="H7451"\w* y dijo al \w Ángel|strong="H4397"\w* \w que|strong="H6258"\w* \w destruía|strong="H7843"\w* al \w pueblo|strong="H5971"\w*: \wj ¡\w Basta|strong="H7227"\w* \w ya|strong="H6258"\w*! ¡\w Detén|strong="H7503"\w* tu \w mano|strong="H3027"\w*!\wj* \w El|strong="H5973"\w* \w Ángel|strong="H4397"\w* \w de|strong="H5973"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w estaba|strong="H1961"\w* \w junto|strong="H5973"\w* \w a|strong="H3068"\w* la \w era|strong="H1961"\w* \w de|strong="H5973"\w* Arauna, \w el|strong="H5973"\w* \w jebuseo|strong="H2983"\w*.
\p 
\v 17 \w David|strong="H1732"\w*, \w cuando|strong="H4100"\w* \w vio|strong="H7200"\w* \w que|strong="H4100"\w* \w el|strong="H6213"\w* \w Ángel|strong="H4397"\w* \w hería|strong="H5221"\w* al \w pueblo|strong="H5971"\w*, habló \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*: \w Yo|strong="H2009"\w* mismo \w soy|strong="H1961"\w* \w el|strong="H6213"\w* \w que|strong="H4100"\w* \w pecó|strong="H2398"\w*. \w Yo|strong="H2009"\w* \w soy|strong="H1961"\w* \w el|strong="H6213"\w* \w que|strong="H4100"\w* procedió perversamente. Pero \w estas|strong="H6213"\w* \w ovejas|strong="H6629"\w*, ¿\w qué|strong="H4100"\w* \w hicieron|strong="H6213"\w*? ¡\w Sea|strong="H1961"\w* \w ahora|strong="H4994"\w* \w tu|strong="H6213"\w* \w mano|strong="H3027"\w* \w contra|strong="H1961"\w* \w mí|strong="H2009"\w* y \w contra|strong="H1961"\w* la \w casa|strong="H1004"\w* \w de|strong="H5971"\w* \w mi|strong="H2009"\w* padre!
\p 
\v 18 \w Gad|strong="H1410"\w* \w fue|strong="H1931"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* y \w le|strong="H1931"\w* dijo: \w Sube|strong="H5927"\w* y levanta un \w altar|strong="H4196"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* en \w la|strong="H1931"\w* \w era|strong="H1931"\w* de Arauna \w el|strong="H1931"\w* \w jebuseo|strong="H2983"\w*.
\v 19 \w Subió|strong="H5927"\w* \w David|strong="H1732"\w* según la \w Palabra|strong="H1697"\w* \w que|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w mandó|strong="H6680"\w* \w por|strong="H1697"\w* medio \w de|strong="H1697"\w* \w Gad|strong="H1410"\w*.
\v 20 Arauna \w vio|strong="H7200"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w y|strong="H5921"\w* sus esclavos \w que|strong="H5921"\w* avanzaban \w hacia|strong="H5921"\w* \w él|strong="H5921"\w*. Arauna \w salió|strong="H3318"\w*, \w se|strong="H5921"\w* inclinó rostro \w en|strong="H5921"\w* tierra ante \w el|strong="H5921"\w* \w rey|strong="H4428"\w*
\v 21 \w y|strong="H5921"\w* preguntó: ¿\w Por|strong="H5921"\w* \w qué|strong="H5921"\w* viene \w mi|strong="H5921"\w* \tl ʼadón\tl* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w a|strong="H3068"\w* su esclavo?
\p \w Y|strong="H3068"\w* \w David|strong="H1732"\w* respondió: \w A|strong="H3068"\w* comprarte \w la|strong="H5921"\w* era \w para|strong="H5921"\w* \w edificar|strong="H1129"\w* un \w altar|strong="H4196"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* \w detener|strong="H6113"\w* \w la|strong="H5921"\w* \w mortandad|strong="H4046"\w* \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w*.
\p 
\v 22 Arauna respondió \w a|strong="H3068"\w* \w David|strong="H1732"\w*: \w Tómala|strong="H3947"\w* \w y|strong="H1241"\w* ofrezca mi \tl ʼadón\tl* el \w rey|strong="H4428"\w* lo que \w le|strong="H5869"\w* \w parezca|strong="H7200"\w* \w bien|strong="H2896"\w*. ¡Aquí están los becerros para el \w holocausto|strong="H5930"\w*, los trillos \w y|strong="H1241"\w* los yugos \w de|strong="H5869"\w* los \w bueyes|strong="H1241"\w* para \w leña|strong="H6086"\w*!
\v 23 ¡\w Todo|strong="H3605"\w*, oh \w rey|strong="H4428"\w*, \w lo|strong="H3605"\w* \w da|strong="H5414"\w* Arauna \w al|strong="H4428"\w* \w rey|strong="H4428"\w*! Arauna también dijo \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: ¡\nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* te acepte!
\p 
\v 24 \w Pero|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* dijo \w a|strong="H3068"\w* Arauna: \w No|strong="H3808"\w*, \w ciertamente|strong="H3588"\w* \w te|strong="H3588"\w* \w lo|strong="H3808"\w* \w compraré|strong="H7069"\w* \w por|strong="H3588"\w* \w precio|strong="H3701"\w*, \w pues|strong="H3588"\w* \w no|strong="H3808"\w* \w ofreceré|strong="H5927"\w* \w holocaustos|strong="H5930"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* mi \nd ʼElohim\nd* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H3588"\w* cuesten algo. \w Así|strong="H3588"\w* \w David|strong="H1732"\w* \w compró|strong="H7069"\w* \w la|strong="H3588"\w* era \w y|strong="H3588"\w* \w los|strong="H3588"\w* becerros \w por|strong="H3588"\w* 5,5 kilogramos \w de|strong="H3588"\w* \w plata|strong="H3701"\w*.
\p 
\v 25 Entonces \w David|strong="H1732"\w* \w edificó|strong="H1129"\w* \w allí|strong="H8033"\w* un \w altar|strong="H4196"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w y|strong="H5921"\w* \w ofreció|strong="H5927"\w* \w holocaustos|strong="H5930"\w* \w y|strong="H5921"\w* sacrificios \w de|strong="H5921"\w* paz.
\p Así \nd \w Yavé|strong="H3068"\w*\nd* fue conmovido \w por|strong="H5921"\w* \w la|strong="H5921"\w* oración \w a|strong="H3068"\w* favor \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w plaga|strong="H4046"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* cesó. 
