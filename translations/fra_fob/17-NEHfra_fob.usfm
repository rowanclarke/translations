\v 1 \w Mais|strong="H3588"\w* \w il|strong="H3389"\w* \w arriva|strong="H3389"\w* \w que|strong="H3588"\w* Samballat, ayant \w appris|strong="H8085"\w* \w que|strong="H3588"\w* \w nous|strong="H3588"\w* rebâtissions \w la|strong="H8085"\w* \w muraille|strong="H2346"\w*, \w fut|strong="H1961"\w* \w fort|strong="H3966"\w* indigné \w et|strong="H5927"\w* \w fort|strong="H3966"\w* \w irrité|strong="H2734"\w*. \w Et|strong="H5927"\w* \w il|strong="H3389"\w* \w se|strong="H3588"\w* moqua \w des|strong="H5927"\w* Juifs,  
\v 2 \w Et|strong="H6213"\w* \w dit|strong="H3389"\w*, \w en|strong="H6213"\w* \w la|strong="H6213"\w* \w présence|strong="H6213"\w* \w de|strong="H6213"\w* \w ses|strong="H6213"\w* \w frères|strong="H6213"\w* \w et|strong="H6213"\w* \w des|strong="H6213"\w* \w gens|strong="H6213"\w* \w de|strong="H6213"\w* \w guerre|strong="H3898"\w* \w de|strong="H6213"\w* Samarie: \w Que|strong="H6213"\w* \w font|strong="H6213"\w* \w ces|strong="H6213"\w* \w Juifs|strong="H6213"\w* languissants? \w Les|strong="H6213"\w* \w laissera-t-on|strong="H6213"\w* \w faire|strong="H6213"\w*? Sacrifieront-ils? Achèveront-ils maintenant? \w De|strong="H6213"\w* \w ces|strong="H6213"\w* \w monceaux|strong="H6213"\w* \w de|strong="H6213"\w* \w décombres|strong="H6213"\w* feront-ils renaître \w les|strong="H6213"\w* \w pierres|strong="H6213"\w*, \w quand|strong="H6213"\w* \w elles|strong="H6213"\w* \w sont|strong="H3162"\w* brûlées?  
\v 3 \w Et|strong="H6440"\w* Tobija, Ammonite, \w qui|strong="H6440"\w* \w était|strong="H6440"\w* \w auprès|strong="H5921"\w* \w de|strong="H6440"\w* \w lui|strong="H6440"\w*, \w dit|strong="H6440"\w*: Quoi qu'\w ils|strong="H6440"\w* bâtissent, si \w un|strong="H6440"\w* renard montait, \w il|strong="H5921"\w* romprait \w leur|strong="H6440"\w* \w muraille|strong="H6440"\w* \w de|strong="H6440"\w* \w pierre|strong="H6440"\w*.  
\v 4 \w O|strong="H3068"\w* \w notre|strong="H3808"\w* \w Dieu|strong="H3808"\w*! écoute, car \w nous|strong="H1129"\w* \w sommes|strong="H3808"\w* \w en|strong="H3808"\w* mépris! \w Fais|strong="H3808"\w* \w retourner|strong="H3808"\w* \w sur|strong="H2346"\w* \w leur|strong="H3063"\w* tête l'opprobre \w dont|strong="H3063"\w* \w ils|strong="H3063"\w* \w nous|strong="H1129"\w* couvrent, \w et|strong="H3063"\w* \w livre-les|strong="H3063"\w* \w au|strong="H3063"\w* \w pillage|strong="H3063"\w* \w dans|strong="H3808"\w* \w un|strong="H1129"\w* \w pays|strong="H7235"\w* \w de|strong="H7235"\w* captivité;  
\v 5 \w Ne|strong="H3808"\w* couvre \w point|strong="H3808"\w* \w leur|strong="H7200"\w* iniquité, \w et|strong="H7200"\w* \w que|strong="H7200"\w* \w leur|strong="H7200"\w* \w péché|strong="H7200"\w* \w ne|strong="H3808"\w* \w soit|strong="H3808"\w* \w point|strong="H3808"\w* \w effacé|strong="H3808"\w* \w en|strong="H7200"\w* \w ta|strong="H7200"\w* présence; car \w ils|strong="H3045"\w* \w ont|strong="H3045"\w* offensé \w ceux|strong="H7200"\w* \w qui|strong="H3045"\w* bâtissent.  
\v 6 \w Nous|strong="H6471"\w* \w rebâtîmes|strong="H6471"\w* \w donc|strong="H3427"\w* \w la|strong="H5921"\w* muraille, \w et|strong="H7725"\w* \w toute|strong="H3605"\w* \w la|strong="H5921"\w* muraille \w fut|strong="H1961"\w* fermée jusqu'\w à|strong="H3427"\w* \w la|strong="H5921"\w* \w moitié|strong="H7725"\w* \w de|strong="H3427"\w* \w sa|strong="H7725"\w* hauteur; \w et|strong="H7725"\w* \w le|strong="H7725"\w* peuple prenait \w à|strong="H3427"\w* \w cœur|strong="H3427"\w* \w le|strong="H7725"\w* travail.  
\v 7 Mais quand Samballat, Tobija, \w les|strong="H5975"\w* Arabes, \w les|strong="H5975"\w* \w Ammonites|strong="H5975"\w* \w et|strong="H5971"\w* \w les|strong="H5975"\w* Asdodiens eurent appris \w que|strong="H4725"\w* \w la|strong="H5975"\w* \w muraille|strong="H2346"\w* \w de|strong="H5971"\w* Jérusalem \w se|strong="H5971"\w* relevait, \w et|strong="H5971"\w* qu'\w on|strong="H5971"\w* \w avait|strong="H5971"\w* commencé \w à|strong="H5975"\w* fermer \w les|strong="H5975"\w* brèches, \w ils|strong="H5971"\w* \w furent|strong="H5971"\w* fort \w en|strong="H5971"\w* colère.  
\v 8 \w Et|strong="H1121"\w* \w ils|strong="H1121"\w* \w se|strong="H5971"\w* \w liguèrent|strong="H5971"\w* \w tous|strong="H5971"\w* \w ensemble|strong="H5971"\w* \w pour|strong="H6440"\w* \w venir|strong="H6440"\w* \w faire|strong="H5971"\w* \w la|strong="H6440"\w* \w guerre|strong="H3898"\w* \w contre|strong="H6440"\w* \w Jérusalem|strong="H1121"\w*, \w et|strong="H1121"\w* \w pour|strong="H6440"\w* \w y|strong="H5971"\w* \w porter|strong="H1121"\w* \w le|strong="H6440"\w* trouble.  
\v 9 \w Alors|strong="H3045"\w* \w nous|strong="H3588"\w* priâmes \w notre|strong="H3588"\w* \w Dieu|strong="H3588"\w*, \w et|strong="H7725"\w* \w nous|strong="H3588"\w* mîmes \w des|strong="H1961"\w* gardes \w contre|strong="H8085"\w* \w eux|strong="H3588"\w*, \w de|strong="H7725"\w* \w jour|strong="H3045"\w* \w et|strong="H7725"\w* \w de|strong="H7725"\w* \w nuit|strong="H7725"\w*, \w pour|strong="H3588"\w* \w nous|strong="H3588"\w* garantir d'\w eux|strong="H3588"\w*.  
\v 10 \w Et|strong="H3117"\w* \w Juda|strong="H3063"\w* disait: \w Les|strong="H6213"\w* \w forces|strong="H2388"\w* \w des|strong="H6213"\w* \w ouvriers|strong="H6213"\w* faiblissent; \w et|strong="H3117"\w* \w il|strong="H3117"\w* \w y|strong="H1004"\w* \w a|strong="H3068"\w* beaucoup \w de|strong="H1004"\w* \w décombres|strong="H6213"\w*; \w nous|strong="H6213"\w* \w ne|strong="H5288"\w* \w pourrons|strong="H6213"\w* \w pas|strong="H6213"\w* \w bâtir|strong="H3117"\w* \w la|strong="H6213"\w* \w muraille|strong="H2388"\w*!  
\v 11 \w Et|strong="H3027"\w* \w nos|strong="H6213"\w* \w ennemis|strong="H6213"\w* disaient: \w Ils|strong="H6213"\w* \w ne|strong="H3027"\w* \w sauront|strong="H3027"\w* \w et|strong="H3027"\w* \w ne|strong="H3027"\w* verront \w rien|strong="H3027"\w*, jusqu'\w à|strong="H6213"\w* \w ce|strong="H6213"\w* \w que|strong="H3027"\w* \w nous|strong="H6213"\w* entrions \w au|strong="H6213"\w* \w milieu|strong="H6213"\w* d'\w eux|strong="H3027"\w*. \w Nous|strong="H6213"\w* \w les|strong="H6213"\w* tuerons, \w et|strong="H3027"\w* \w nous|strong="H6213"\w* \w ferons|strong="H6213"\w* cesser l'\w ouvrage|strong="H4399"\w*.  
\v 12 Mais \w il|strong="H5921"\w* arriva \w que|strong="H5921"\w* \w les|strong="H1129"\w* \w Juifs|strong="H1129"\w* \w qui|strong="H1129"\w* \w habitaient|strong="H1129"\w* \w près|strong="H5921"\w* d'\w eux|strong="H5921"\w*, vinrent, jusqu'\w à|strong="H1129"\w* dix fois, \w nous|strong="H1129"\w* dire \w leur|strong="H5921"\w* dessein, \w de|strong="H5921"\w* \w tous|strong="H5921"\w* \w les|strong="H1129"\w* \w lieux|strong="H1129"\w* d'où \w ils|strong="H2719"\w* revenaient vers \w nous|strong="H1129"\w*.  
\v 13 \w Je|strong="H3068"\w* plaçai donc \w dans|strong="H5921"\w* \w le|strong="H5971"\w* bas, \w derrière|strong="H5971"\w* \w la|strong="H5921"\w* \w muraille|strong="H2346"\w*, \w aux|strong="H5971"\w* endroits découverts, \w le|strong="H5971"\w* \w peuple|strong="H5971"\w*, \w par|strong="H5921"\w* \w familles|strong="H5971"\w*, \w avec|strong="H5971"\w* \w leurs|strong="H7235"\w* épées, \w leurs|strong="H7235"\w* javelines \w et|strong="H5921"\w* \w leurs|strong="H7235"\w* arcs.  
\v 14 Puis \w je|strong="H6963"\w* regardai; \w et|strong="H8085"\w* \w je|strong="H6963"\w* me levai, \w et|strong="H8085"\w* \w je|strong="H6963"\w* \w dis|strong="H6963"\w* \w aux|strong="H8085"\w* principaux, \w aux|strong="H8085"\w* magistrats, \w et|strong="H8085"\w* \w au|strong="H8085"\w* \w reste|strong="H8085"\w* \w du|strong="H6963"\w* peuple: \w Ne|strong="H4725"\w* \w les|strong="H8085"\w* \w craignez|strong="H8085"\w* \w point|strong="H8085"\w*; souvenez-vous \w du|strong="H6963"\w* \w Seigneur|strong="H8085"\w*, \w qui|strong="H6963"\w* \w est|strong="H4725"\w* grand \w et|strong="H8085"\w* redoutable, \w et|strong="H8085"\w* \w combattez|strong="H3898"\w* \w pour|strong="H8085"\w* \w vos|strong="H8085"\w* \w frères|strong="H8085"\w*, \w vos|strong="H8085"\w* \w fils|strong="H8085"\w* \w et|strong="H8085"\w* \w vos|strong="H8085"\w* filles, \w vos|strong="H8085"\w* \w femmes|strong="H8085"\w* \w et|strong="H8085"\w* \w vos|strong="H8085"\w* maisons.  
\v 15 Or, \w après|strong="H5927"\w* \w que|strong="H5704"\w* \w nos|strong="H6213"\w* \w ennemis|strong="H6213"\w* \w eurent|strong="H6213"\w* appris \w que|strong="H5704"\w* \w nous|strong="H6213"\w* \w avions|strong="H6213"\w* \w été|strong="H6213"\w* avertis, \w Dieu|strong="H6213"\w* dissipa \w leur|strong="H5927"\w* conseil; \w et|strong="H3318"\w* \w nous|strong="H6213"\w* \w retournâmes|strong="H6213"\w* \w tous|strong="H6213"\w* \w aux|strong="H6213"\w* murailles, \w chacun|strong="H3318"\w* \w à|strong="H6213"\w* \w son|strong="H6213"\w* \w travail|strong="H4399"\w*.  
\v 16 \w Depuis|strong="H3117"\w* \w ce|strong="H1931"\w* \w jour-là|strong="H1931"\w* \w une|strong="H3117"\w* \w moitié|strong="H3117"\w* \w de|strong="H3117"\w* \w mes|strong="H3117"\w* \w gens|strong="H5971"\w* travaillait \w à|strong="H3117"\w* \w l|strong="H5971"\w*'\w œuvre|strong="H4399"\w* \w et|strong="H3117"\w* \w l|strong="H5971"\w*'\w autre|strong="H6256"\w* \w moitié|strong="H3117"\w* \w était|strong="H1961"\w* \w armée|strong="H5971"\w* \w de|strong="H3117"\w* lances, \w de|strong="H3117"\w* boucliers, d'arcs \w et|strong="H3117"\w* \w de|strong="H3117"\w* cuirasses; \w et|strong="H3117"\w* \w les|strong="H3117"\w* \w chefs|strong="H3117"\w* \w suivaient|strong="H5971"\w* chaque \w famille|strong="H3117"\w* \w de|strong="H3117"\w* Juda.  
\v 17 \w Ceux|strong="H5288"\w* \w qui|strong="H4325"\w* \w bâtissaient|strong="H5288"\w* \w la|strong="H6584"\w* muraille, \w et|strong="H5288"\w* \w ceux|strong="H5288"\w* \w qui|strong="H4325"\w* portaient ou chargeaient \w les|strong="H4325"\w* fardeaux, travaillaient d'une main, \w et|strong="H5288"\w* \w de|strong="H4325"\w* l'autre ils tenaient une \w arme|strong="H7973"\w*.  
\v 18 Car chacun de ceux qui bâtissaient, avait les reins ceints d'une épée; c'est ainsi qu'ils bâtissaient; et celui qui sonnait de la trompette était près de moi.  
\v 19 \w Je|strong="H3068"\w* dis aux principaux, aux magistrats, et au reste du peuple: \w L|strong="H3068"\w*'ouvrage est considérable et étendu, et nous sommes dispersés sur la muraille, loin l'un de l'autre;  
\v 20 En quelque lieu donc que vous entendiez le son de la trompette, rassemblez-vous-y vers nous; notre Dieu combattra pour nous.  
\v 21 C'est ainsi que nous travaillions; et la moitié des gens tenait des javelines depuis le point du jour, jusqu'à ce que les étoiles parussent.  
\v 22 En ce temps-là je dis aussi au peuple: Que chacun passe la nuit dans Jérusalem, avec son serviteur, afin qu'ils nous servent la nuit pour faire le guet, et le jour pour travailler.  
\v 23 Et pour moi, mes frères, mes serviteurs et les gens de la garde qui me suivent, nous ne quitterons point nos habits, chacun aura son épée et de l'eau.   
\c 5
\p
\v 1 Or, \w il|strong="H5971"\w* \w y|strong="H5971"\w* \w eut|strong="H5971"\w* \w une|strong="H1961"\w* \w grande|strong="H1419"\w* clameur \w du|strong="H5971"\w* \w peuple|strong="H5971"\w* \w et|strong="H1419"\w* \w de|strong="H5971"\w* \w leurs|strong="H1961"\w* femmes \w contre|strong="H5971"\w* \w les|strong="H5971"\w* \w Juifs|strong="H3064"\w*, \w leurs|strong="H1961"\w* \w frères|strong="H5971"\w*.  
