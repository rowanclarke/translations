\s3 I. \sc Chap. vi, 9-15 : Acte symbolique : le couronnement du grand prêtre.\sc*
\p 
\v 9 \w La|strong="H03068"\w* \w parole|strong="H01697"\w* \w de|strong="H01697"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w me|strong="H03068"\w* \w fut|strong="H03068"\w* \w adressée|strong="H01697"\w* \w en|strong="H03068"\w* \w ces|strong="H01697"\w* \w termes|strong="H00559"\w* :
\v 10 \w Prends|strong="H03947"\w* \w de|strong="H01121"\w* \w la|strong="H03947"\w* \w main|strong="H03027"\w* \w des|strong="H03117"\w* \w exilés|strong="H01473"\w*\f + \fr 6:10 \ft — On traduit aussi : \it Prends des hommes de l’exil\it*, des familles \it de Holdaï, de Tobia et d’Idaïa\it*. Les \it exilés\it* seraient en réalité des rapatriés revenus depuis peu au pays ; les noms propres seraient des noms de famille (Van Hoonacker). Zacharie prendrait ainsi des témoins avant de se rendre chez Josias. — \it Chez qui ils se sont rendus en arrivant de Babylone\it*. Traduction problématique : Le mot à mot serait plus simplement : \it qui sont revenus de Babylone\it*. LXX \it qui est revenu\it*, se rapportant à Josias.\f*, \w de|strong="H01121"\w* Holdaï, \w de|strong="H01121"\w* Tobia \w et|strong="H03117"\w* d’Idaïa, — \w tu|strong="H03117"\w* \w iras|strong="H00935"\w* \w toi-même|strong="H03947"\w* \w en|strong="H03117"\w* \w ce|strong="H01931"\w* \w jour-là|strong="H01931"\w*, \w tu|strong="H03117"\w* \w iras|strong="H00935"\w* \w dans|strong="H03117"\w* \w la|strong="H03947"\w* \w maison|strong="H01004"\w* \w de|strong="H01121"\w* \w Josias|strong="H02977"\w*, \w chez|strong="H01004"\w* \w qui|strong="H01121"\w* \w ils|strong="H01121"\w* \w se|strong="H03117"\w* \w sont|strong="H03117"\w* \w rendus|strong="H05307"\w* \w en|strong="H03117"\w* \w arrivant|strong="H00935"\w* \w de|strong="H01121"\w* \w Babylone|strong="H00894"\w*, —
\v 11 \w et|strong="H01419"\w* \w tu|strong="H00834"\w* \w prendras|strong="H03947"\w* \w de|strong="H01121"\w* l’\w argent|strong="H03701"\w* \w et|strong="H01419"\w* \w de|strong="H01121"\w* l’\w or|strong="H02091"\w*, \w et|strong="H01419"\w* \w tu|strong="H00834"\w* \w feras|strong="H06213"\w* \w des|strong="H06213"\w* \w couronnes|strong="H05850"\w*, \w et|strong="H01419"\w* \w tu|strong="H00834"\w* \w les|strong="H06213"\w* \w poseras|strong="H07760"\w* \w sur|strong="H07760"\w* \w la|strong="H06213"\w* \w tête|strong="H07218"\w* \w de|strong="H01121"\w* Jésus, \w fils|strong="H01121"\w* \w de|strong="H01121"\w* Josédec, \w le|strong="H06213"\w* \w grand|strong="H01419"\w* \w prêtre|strong="H03548"\w*.
\v 12 \w Tu|strong="H00834"\w* \w lui|strong="H03068"\w* \w parleras|strong="H01696"\w* \w en|strong="H03068"\w* \w ces|strong="H06635"\w* \w termes|strong="H00559"\w* : \w Ainsi|strong="H03541"\w* \w parle|strong="H00559"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w* : \w Voici|strong="H02009"\w* \w un|strong="H01129"\w* \w homme|strong="H00376"\w* \w dont|strong="H03068"\w* \w le|strong="H03068"\w* \w nom|strong="H08034"\w* \w est|strong="H03068"\w* \w Germe|strong="H06780"\w*\f + \fr 6:12 \ft \it Germe\it* (voir iii, 8). — \it Il lèvera en son lieu\it* ; litt., \it de sous lui\it*. D’autres : \it et il y aura une termination sous lui\it*. Le Germe sera le point de départ nouveau de la lignée messianique.\f* ; \w il|strong="H03068"\w* \w lèvera|strong="H06965"\w* \w en|strong="H03068"\w* \w son|strong="H03068"\w* \w lieu|strong="H08478"\w*, \w et|strong="H03068"\w* \w il|strong="H03068"\w* \w bâtira|strong="H01129"\w* \w le|strong="H03068"\w* \w temple|strong="H01964"\w* \w de|strong="H08034"\w* \nd \w Yahweh|strong="H03068"\w*\nd*.
\v 13 \w Il|strong="H03548"\w* \w bâtira|strong="H01129"\w* \w le|strong="H05375"\w* \w temple|strong="H01964"\w* \w de|strong="H03427"\w* \nd \w Yahweh|strong="H03068"\w*\nd*, \w et|strong="H03068"\w* \w sera|strong="H03068"\w* \w revêtu|strong="H03847"\w* \w de|strong="H03427"\w* \w majesté|strong="H01935"\w* ; \w il|strong="H03548"\w* \w sera|strong="H03068"\w* \w assis|strong="H03427"\w* \w en|strong="H03427"\w* \w souverain|strong="H04910"\w* \w sur|strong="H04910"\w* \w son|strong="H05375"\w* \w trône|strong="H03678"\w*, \w et|strong="H03068"\w* \w il|strong="H03548"\w* \w sera|strong="H03068"\w* \w prêtre|strong="H03548"\w* \w sur|strong="H04910"\w* \w son|strong="H05375"\w* \w trône|strong="H03678"\w*\f + \fr 6:13 \ft \it Et il sera prêtre sur son trône\it* ; LXX, \it Et le prêtre sera à sa droite\it* (du Germe).\f*, \w et|strong="H03068"\w* \w entre|strong="H07965"\w* \w eux|strong="H00310"\w* \w deux|strong="H08147"\w* \w il|strong="H03548"\w* \w y|strong="H03548"\w* \w aura|strong="H03068"\w* \w un|strong="H01129"\w* \w conseil|strong="H06098"\w* \w de|strong="H03427"\w* \w paix|strong="H07965"\w*.
\v 14 \w Et|strong="H01121"\w* \w la|strong="H03068"\w* \w couronne|strong="H05850"\w*\f + \fr 6:14 \ft \it Et la couronne\it* ; litt. \it et les couronnes\it*, avec le verbe au singulier. — \it Et pour Hen\it*. D’autres voient ici un nom commun : \it et pour la générosité du fils de Sophonie\it* (LXX).\f* \w sera|strong="H03068"\w* \w pour|strong="H03068"\w* \w Hélem|strong="H02494"\w*, \w pour|strong="H03068"\w* Tobia, \w pour|strong="H03068"\w* Idaïa \w et|strong="H01121"\w* \w pour|strong="H03068"\w* \w Hen|strong="H02581"\w*, \w fils|strong="H01121"\w* \w de|strong="H01121"\w* \w Sophonie|strong="H06846"\w*, \w en|strong="H03068"\w* \w souvenir|strong="H02146"\w* \w dans|strong="H02146"\w* \w le|strong="H03068"\w* \w temple|strong="H01964"\w* \w de|strong="H01121"\w* \nd \w Yahweh|strong="H03068"\w*\nd*.
\v 15 \w Des|strong="H03068"\w* \w hommes|strong="H00582"\w* \w qui|strong="H03068"\w* \w sont|strong="H03068"\w* \w au|strong="H03068"\w* \w loin|strong="H07350"\w* \w viendront|strong="H00935"\w* \w et|strong="H03068"\w* \w travailleront|strong="H01129"\w* \w à|strong="H03068"\w* \w la|strong="H08085"\w* \w construction|strong="H01129"\w* \w du|strong="H06963"\w* \w temple|strong="H01964"\w* \w de|strong="H06963"\w* \nd \w Yahweh|strong="H03068"\w*\nd*, \w et|strong="H03068"\w* \w vous|strong="H03068"\w* \w saurez|strong="H03045"\w* \w que|strong="H08085"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w* m’\w a|strong="H03068"\w* \w envoyé|strong="H07971"\w* \w vers|strong="H07971"\w* \w vous|strong="H03068"\w*. \w Cela|strong="H01697"\w* \w arrivera|strong="H00935"\w* \w si|strong="H03588"\w* \w vous|strong="H03068"\w* \w obéissez|strong="H08085"\w* \w fidèlement|strong="H00571"\w* \w à|strong="H03068"\w* \w la|strong="H08085"\w* \w voix|strong="H06963"\w* \w de|strong="H06963"\w* \nd \w Yahweh|strong="H03068"\w*\nd*.
\c 7
\s2 \sc 3. Chap. vii, 1 — viii, 23 : Réponse de Yahweh à une consultation touchant les anciens jours de deuil.\sc* — La consultation des envoyés de Béthel (vii, 1-3). Réponse divine : on n’a jeûné que pour des motifs personnels (vii, 4-6), suivant en cela les errements condamnés par les prophètes, et qui ont amené le malheur du peuple (vii, 7-14). Mais Yahweh qui aime Sion (viii, 1, 2), y est revenu (viii, 3) ; elle va être repeuplée (viii, 4, 5), son peuple va lui être merveilleusement ramené (viii, 6-8). Changements déjà réalisés depuis la reprise des travaux du Temple (viii, (9-13) : conditions à observer (viii, 14-17). Fin des deuils (viii, 18, 19). Affluence des nations à Jérusalem (viii, 20-23.)
\p 
\v 1 \w La|strong="H03068"\w* \w quatrième|strong="H07243"\w* \w année|strong="H08141"\w* \w du|strong="H08141"\w* \w roi|strong="H04428"\w* \w Darius|strong="H01867"\w*\f + \fr 7:1 \ft \it La quatrième année de Darius\it*, l’an 518 av. J.-C. Il y avait près de deux ans que les travaux du temple avaient été repris.\f*, \w la|strong="H03068"\w* \w parole|strong="H01697"\w* \w de|strong="H04428"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w fut|strong="H03068"\w* \w adressée|strong="H01697"\w* \w à|strong="H03068"\w* \w Zacharie|strong="H02148"\w*, \w au|strong="H03068"\w* \w quatrième|strong="H07243"\w* \w jour|strong="H02320"\w* \w du|strong="H08141"\w* \w neuvième|strong="H08671"\w* \w mois|strong="H02320"\w*, \w en|strong="H04428"\w* Casleu.
\v 2 \w Béthel|strong="H01008"\w* \w avait|strong="H03068"\w* \w envoyé|strong="H07971"\w* Sarasar \w et|strong="H03068"\w* Rogommélech, \w avec|strong="H06440"\w* \w ses|strong="H07971"\w* \w gens|strong="H00582"\w*, \w pour|strong="H07971"\w* \w implorer|strong="H02470"\w* \nd \w Yahweh|strong="H03068"\w*\nd*,
\v 3 \w pour|strong="H06213"\w* \w parler|strong="H01696"\w* \w aux|strong="H06213"\w* \w prêtres|strong="H03548"\w* \w de|strong="H01004"\w* \w la|strong="H06213"\w* \w maison|strong="H01004"\w* \w de|strong="H01004"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w* \w et|strong="H03068"\w* \w aux|strong="H06213"\w* \w prophètes|strong="H05030"\w*, \w en|strong="H06213"\w* \w ces|strong="H06213"\w* \w termes|strong="H00559"\w* : « \w Dois-je|strong="H04100"\w* \w pleurer|strong="H01058"\w* \w au|strong="H06213"\w* \w cinquième|strong="H02549"\w* \w mois|strong="H02320"\w*, \w et|strong="H03068"\w* \w faire|strong="H06213"\w* \w abstinence|strong="H05144"\w*, \w comme|strong="H06213"\w* \w j|strong="H03068"\w*’\w ai|strong="H03068"\w* \w fait|strong="H06213"\w* \w depuis|strong="H03068"\w* \w tant|strong="H03117"\w* d’\w années|strong="H08141"\w* ? »\f + \fr 7:3 \ft Maintenant que Dieu a rendu sa faveur à son peuple, convient-il d’observer les jeûnes commémoratifs de la destruction de Jérusalem ?\f*
\p 
\v 4 \w La|strong="H03068"\w* \w parole|strong="H01697"\w* \w de|strong="H01697"\w* \nd \w Yahweh|strong="H03068"\w*\nd*\f + \fr 7:4 \ft \it La parole de Yahweh\it* etc. Dieu ne répond qu’indirectement à la question proposée : les cérémonies de deuil n’ont de valeur et d’intérêt que dans la mesure où elles correspondent aux sentiments du cœur, repentir et humiliation.\f* \w des|strong="H03068"\w* \w armées|strong="H06635"\w* \w me|strong="H03068"\w* \w fut|strong="H03068"\w* \w adressée|strong="H01697"\w* \w en|strong="H03068"\w* \w ces|strong="H01697"\w* \w termes|strong="H00559"\w* :
\v 5 \w Parle|strong="H00559"\w* \w à|strong="H08141"\w* \w tout|strong="H03605"\w* \w le|strong="H05971"\w* \w peuple|strong="H05971"\w* \w du|strong="H05971"\w* \w pays|strong="H00776"\w* \w et|strong="H03548"\w* \w aux|strong="H05971"\w* \w prêtres|strong="H03548"\w*, \w en|strong="H05971"\w* \w ces|strong="H08141"\w* \w termes|strong="H00559"\w* : \w Quand|strong="H03588"\w* \w vous|strong="H03068"\w* \w avez|strong="H03426"\w* \w jeûné|strong="H06684"\w* \w et|strong="H03548"\w* \w célébré|strong="H03034"\w* \w le|strong="H05971"\w* \w deuil|strong="H05594"\w* \w au|strong="H05971"\w* \w cinquième|strong="H02549"\w* \w et|strong="H03548"\w* \w au|strong="H05971"\w* \w septième|strong="H07637"\w* \w mois|strong="H02320"\w*, \w et|strong="H03548"\w* \w cela|strong="H02088"\w* \w depuis|strong="H03117"\w* \w soixante-dix|strong="H08141"\w* \w ans|strong="H08141"\w*, \w est-ce|strong="H00482"\w* \w pour|strong="H05971"\w* \w moi|strong="H06440"\w* \w que|strong="H03588"\w* \w vous|strong="H03068"\w* jeûniez ?\f + \fr 7:5 \ft Quand vous jeûniez, c’était, non pour m’honorer, mais pour des motifs personnels. Il en était de vos jeûnes comme de vos festins, dans lesquels vous ne recherchez que votre avantage.\f*
\v 6 \w Et|strong="H08354"\w* \w quand|strong="H03808"\w* \w vous|strong="H03068"\w* \w mangez|strong="H00398"\w* \w et|strong="H08354"\w* \w buvez|strong="H08354"\w*, n’est-ce \w pas|strong="H03808"\w* \w vous|strong="H03068"\w* \w qui|strong="H00376"\w* \w mangez|strong="H00398"\w* \w et|strong="H08354"\w* \w vous|strong="H03068"\w* \w qui|strong="H00376"\w* \w buvez|strong="H08354"\w* ?
\v 7 N’\w y|strong="H03068"\w* \w a-t-il|strong="H02450"\w* \w pas|strong="H03808"\w* \w les|strong="H03068"\w* \w paroles|strong="H01697"\w* \w qu|strong="H01697"\w*’\w a|strong="H03068"\w* \w proclamées|strong="H07121"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w par|strong="H03027"\w* \w l|strong="H05892"\w*’\w intermédiaire|strong="H03027"\w* \w des|strong="H03068"\w* \w anciens|strong="H07223"\w* \w prophètes|strong="H05030"\w*, \w quand|strong="H03808"\w* \w Jérusalem|strong="H03389"\w* \w était|strong="H05892"\w* \w habitée|strong="H03427"\w* \w et|strong="H03068"\w* \w tranquille|strong="H07961"\w*, \w avec|strong="H03427"\w* \w ses|strong="H03027"\w* \w villes|strong="H05892"\w* \w autour|strong="H05439"\w* d’\w elle|strong="H03027"\w*, \w et|strong="H03068"\w* \w que|strong="H01697"\w* \w le|strong="H07121"\w* négéb \w et|strong="H03068"\w* \w la|strong="H07121"\w* sephélah \w étaient|strong="H03027"\w* \w habités|strong="H03427"\w* ?
\p 
