\id TIT  
\h AR TITO 
\toc1 AR TITO Ar he̱ꞌmi bi ꞌyotꞌa ar Pablo bi me̱mpa ar Tito 
\toc2 AR TITO 
\toc3 Tit. 
\mt1 AR TITO 
\mt2 Ar he̱ꞌmi bi ꞌyotꞌa ar Pablo bi me̱mpa ar Tito 
\c 1  
\s1 Ar nze̱ngwa 
\p  
\v 1 Nuga dar Pablo, ár ꞌbe̱gogi Jö ne ár mpo̱tegi ar tsi Hmu Hesukristo. Gehnu̱ xi me̱nkagi ga tsi da ñꞌemu̱i nuꞌu̱ togo xi hwañꞌö da bö nöꞌö majöni, ne da mꞌu̱ nꞌar hogamꞌu̱i. 
\p  
\v 2 Ne di to̱ꞌma ar te hiñhamꞌu̱ da götsꞌi, ngu xi ñötkagihu̱ Jö núꞌmu̱ hinxki hyokta ar ximha̱i, ha nöꞌö hingar kate. 
\p  
\v 3 Nu mi zo̱ ar pa bi ñꞌudi nöꞌö xki ñötkagihu̱ Jö ma Po̱ho̱tehu̱, bi ꞌbe̱nkagi ga mömba nunár mhönu̱. 
\p  
\v 4 Nuꞌge Tito, di pe̱ñꞌa nunar he̱ꞌminu̱, ngu di ꞌñenö ma tꞌu̱ꞌi, ngetho go da ꞌraꞌa nunar mhönu̱ di jamfihu̱. Jö ar Dada ne ar tsi Hmu Hesukristo ma Po̱ho̱tehu̱, da hwëkꞌa yá ñho, ne da ko ár mu̱i da ma̱xꞌi gi ꞌbu̱ nꞌar hogamꞌu̱i. 
\s1 Hanja da mꞌu̱ yá ꞌbe̱go Jö. 
\p  
\v 5 Núꞌmu̱ nda tsokꞌaꞌi núnu̱ Nkreta, da japꞌu̱ ngi jwata nunar ꞌbe̱fi mi ꞌbe̱di, ne ngi ꞌñexa ya ndö ha ya nijö ha gatho ya hnini, ngu da xiꞌaꞌi ngi ꞌyo̱tꞌe. 
\p  
\v 6 Nuya ku togo gi ꞌñetsꞌi, mahyoni hinte di pe̱ꞌsa te da nkꞌaꞌspabi, di ꞌñe nꞌadar ꞌbe̱hñö, nuyá bötsi di ñꞌemu̱i xiñho, hindar ntsꞌo ne di o̱ta yá dada. 
\p  
\v 7 Ngetho mahyoni nunár ꞌbe̱go Jö di ꞌbu̱ nꞌar hogamꞌu̱i, hindar ñꞌetsꞌi, hindar kwe̱, hingar nti, hindi ntuhni, hindar nzibjö. 
\p  
\v 8 Di pödi da unga nse̱ki hár ngu, ar hogajöꞌi, di pödi te di pe̱fi, di o̱tꞌa nöꞌö xiñho, di pe̱ꞌsa ar mfeni xintꞌaxi, di pödi da nsuse̱. 
\p  
\v 9 Mahyoni di pödi da su nöꞌö ar mhö majöni ngu bi nsipabi. Njapꞌu̱ da ꞌyotꞌwa ar ꞌñu maꞌra di uta nꞌar hoga ntꞌuti, ne da hñuꞌmba yá hmi nuꞌu̱ togo to̱xa nunar mhönu̱. 
\p  
\v 10 Ngetho pongda nze̱ye̱ togo hingi ne da ꞌyo̱tꞌa nöꞌö nsipabi, hingi pödi te möñꞌu̱ ne njapꞌu̱ ka maꞌra, töte nuꞌu̱ te̱mda yá ntꞌumbi ya xodyo. 
\p  
\v 11 Nuya jöꞌiyu̱ mahyoni da jotwa yá ne, ngetho tsꞌomba yá mfeni ya jöꞌi ne gatho nuꞌu̱ ꞌbu̱ ha yá nguyu̱. Utwa nöꞌö hingi ho, ne njapꞌu̱ da tsa̱ da gu̱kwa ar bojö. 
\p  
\v 12 Nꞌár mꞌe̱hni yá jö ya me Nkreta bi ꞌñembase̱ꞌu̱: Nuya me Nkreta, xa ya nemhñö, ñhe̱hwi yá ntsꞌo ya ma̱ngazuꞌwe, te yá tsꞌoꞌyo ne xa thotyá döhñe. 
\p  
\v 13 Nuna bi mönga nor mꞌe̱hniꞌö, majöni. Jange tsu̱ ya ku ne toꞌmbabi, xipabi da hye̱pꞌu̱ nöꞌö hingi ho, ne da de̱nga ar ñꞌemu̱i majöni. 
\p  
\v 14 Hinda de̱mba yá ꞌbede xi bense̱ ya xodyo, ne hinda de̱mba yá ꞌbe̱pate ya jöꞌi xi hye̱pꞌu̱ ar ꞌñu majöni. 
\p  
\v 15 Nuꞌu̱ xintꞌaxi, gatho handi xintꞌaxi, ha nuꞌu̱ xi ntsꞌomba yá mfeni ne hinxi jamfi, gatho handi xi ntsꞌotho, ngetho xi tsꞌokyá mfeni, ne hingi pödi da hyanda ndana xiñho ne ndana hingi ho. 
\p  
\v 16 Eñꞌu̱ xi bö Jö, ha nu ha yá tsꞌoꞌbe̱fi nheki hinꞌö. Ngetho ya tsꞌomꞌu̱i, ne hingi ne da ꞌyo̱de, jange hinte mañho tsa̱ da ꞌyo̱tꞌe. 
\c 2  
\s1 Ar hoga ntꞌuti 
\p  
\v 1 Ha nuꞌge mönga ho̱nse̱ ngu mönga ar hoga ntꞌuti. 
\p  
\v 2 Xipa nuya dönzia, di pödi tema di pe̱fi, di pe̱ꞌsa ar nsu, di nhumañho ár hyoya. Di pe̱ꞌsa nꞌar hoga ñꞌemu̱i, nꞌar hoga mhöte, ne di tse̱ta gatho nöꞌö di ꞌñepabi. 
\p  
\v 3 Nuya tsi txu nꞌehe, mahyoni di pe̱ꞌsa nꞌar hogamꞌu̱i, hindi ju̱xa ya nhemhñö, hindar mihni, di uta ho̱ntꞌa nöꞌö xiñho. 
\p  
\v 4 Da uta nuya ꞌbe̱hñö nxutsitho hanja da mö yá döme ne yá bötsi. 
\p  
\v 5 Da xokwa yá da̱ da bödi teme pe̱fi, da uti hanja da mꞌu̱i xiñho, da su yá ngu, da ñhogajöꞌi ne da ꞌyo̱ta yá döme. Ne njapꞌu̱ hinto da ñömañꞌu̱ ár mhö Jö. 
\p  
\v 6 Xipa ya bötsi da bödi xiñho hanja da ñꞌo. 
\p  
\v 7 Jange mahyoni gi ꞌyoge xiñho da de̱ntꞌa ri mꞌu̱i. Núꞌmu̱ gi uti, utwabi nöꞌö majöni xka jamfi, hinge nöꞌö oxta mañö. 
\p  
\v 8 Mönga ar hoga mhö nöꞌö hinto tsa̱ da kꞌatsꞌi, ne njapꞌu̱ da ꞌbe̱ yá tsa̱ nuꞌu̱ to u̱tsagihu̱, ne hinda tsa̱ da ñömañꞌu̱gihu̱. 
\p  
\v 9 Xipa ya ꞌbe̱go di pe̱ꞌsa nꞌar hogamu̱i da ꞌyo̱ta yá hmu, ne hinda dötatho nuꞌu̱ te mꞌe̱pabi. 
\p  
\v 10 Hinda bëpyá hmu, da supa nöꞌö te xi tꞌe̱ntꞌwa ha yá ꞌye̱, ne njapꞌu̱ da tsa̱ da ñhömañho ár mhö Jö ma Po̱ho̱tehu̱. 
\p  
\v 11 Ngetho Jö xi ñꞌu ár mhöte xi hwëkwa gatho ya meximha̱i da za̱ da mpo̱ho̱. 
\p  
\v 12 Ne utkagihu̱ ga he̱hu̱pꞌu̱ ar tsꞌoki ne yá tsꞌoꞌbe̱fi ar ximha̱i, ga pöhu̱ hanja ga ꞌbu̱hu̱, ga ñhogajöꞌihu̱, ne ga nsundabihu̱ Jö nuya payu̱. 
\p  
\v 13 Ga johyahu̱ ga to̱ꞌmhu̱ ar hoga ndo̱ꞌmi xta penga ma Jöhu̱, gehnu̱ ma Po̱ho̱tehu̱ Hesukristo bi e ha nꞌar nsunda. 
\p  
\v 14 Togo ba e bi unse̱ ár te bi zimgagihu̱ xki dökagihu̱ ar tsꞌoki, ne bi xu̱gagihu̱ ár hnini bi nubgagihu̱ ár me̱ti, jange xa di umba ma mu̱ihu̱ di o̱thu̱ ar ñho. 
\p  
\v 15 Xipa ya ku nuya mhöyu̱, zofo, ne tsu̱i ju̱ nunar tsꞌe̱di xi ꞌraꞌa Jö, hinto da ꞌñenö hinter me̱ꞌö nöꞌö gi utwabi. 
\c 3  
\s1 Bi nhwëgagihu̱ ar pumbate 
\p  
\v 1 Bemba ya ku da ꞌyo̱ta ya nza̱ya̱ ne ya tsꞌu̱tꞌwi, da ꞌyo̱ta nöꞌö nsipabi, ne di netho da ꞌyo̱tꞌa gatho nöꞌö xiñho. 
\p  
\v 2 Hinda ñömañꞌu̱ maꞌra, hinda ntunkwi yá ñꞌohu̱, mahyoni da me̱ꞌsa ar mhöte ne da numañho gatho nu maꞌra. 
\p  
\v 3 Ngetho nuju̱ nꞌehe, mamꞌe̱tꞌo te gatho ndi benthu̱, hinge ndi o̱thu̱ Jö, ndi mꞌe̱thohu̱ ha ya tsꞌoki. Ya tsꞌomfeni mi jakagihu̱ nga o̱thu̱ gatho nöꞌö mi neꞌö. Ndi ꞌbu̱hu̱ har tsꞌomꞌu̱i, ndi hyo̱kwabihu̱ nöꞌö te pe̱ꞌsa maꞌra, ndar ñꞌu̱tsatehu̱, nꞌa ngu nꞌa ndi ñꞌu̱tsahu̱. 
\p  
\v 4 Ha núꞌmu̱ mi nheki ár nhwëki Jö ma Po̱ho̱tehu̱, ne bi utwa ár mhöte ya meximha̱i, 
\p  
\v 5 bi po̱kagihu̱, mödi hinge ndi o̱thu̱ ar ñho. Bi po̱kagihu̱ ngetho xa döta ár nhwëki. Bi xu̱gagihu̱ ma tsꞌokihu̱ ne njapꞌu̱ da mꞌu̱hu̱ manꞌagi, ne hár Hñö Jö bi ꞌrakagihu̱ nꞌar ꞌraꞌyo mꞌu̱i. 
\p  
\v 6 Jö ba pe̱nkagihu̱ ár Hñö, ne bi gobgathogihu̱ ár tsꞌe̱di, ngetho da ñꞌemu̱ihu̱ ar tsi Hmu Hesukristo togo bi po̱kagihu̱. 
\p  
\v 7 Bi hwëgagihu̱ da thanju̱ hinte ma tsꞌoki di tuhu̱, ne di to̱ꞌmhu̱pya ar te hiñhamꞌu̱ da götsꞌi, ngu to̱ꞌmi da tꞌumba yá ñho nꞌar tꞌu̱. 
\p  
\v 8 Majöni nunar mhönu̱ di xiꞌi. Jange xa gi xipa ya ku, ne njapꞌu̱ gatho nuꞌu̱ xi ñꞌemu̱i Jö, da umba yá mu̱i da ꞌyo̱tꞌa nöꞌö xiñho, gehyu̱ da ma̱xa gatho da ꞌñepabi nöꞌö xiñho. 
\p  
\v 9 Yo ma gi ntsa̱hñökiwi nuꞌu̱ xi ꞌbe̱ yá mfeni ne no̱ñꞌu̱ yá pale mamꞌe̱tꞌo. Yo ma gi ntsa̱wi, hingi nto̱xkwi nuꞌu̱ no̱mba yá ꞌbe̱pate ar Moise, ngetho hinte mañho, ne hinte gi ju̱ju̱. 
\p  
\v 10 Nöꞌö ar ñꞌo̱ho̱ ꞌweka ya ku, nuꞌmu̱ xka zofo yoꞌgi ne hingi o̱de, ꞌye̱nga har nijö. 
\p  
\v 11 Ngetho gi pödi nunar ñꞌo̱ho̱ꞌö xi hye̱pꞌu̱ nöꞌö majöni ne o̱tꞌa ar tsꞌoki, zo̱ ár da̱ ñho̱tꞌa ar tsibi. 
\s1 Ar Pablo xipase̱ teme da ꞌyo̱tꞌa ar Tito 
\p  
\v 12 Núꞌmu̱ xka pe̱ñꞌapꞌu̱ ar ku Artemas wa ar ku Tikiko, já gi ꞌñehnu̱ ngutꞌa Nikopolis ne ga nthe̱winu̱, ngetho xta beni ma ga ꞌbu̱hnu̱ nuya pa ya tse̱. 
\p  
\v 13 Fa̱xa ar ku Sena nöꞌö pötwa yá ꞌbe̱pate ya ndö, ne ar ku Polo. Fa̱tsꞌi da mengi da ne yá ꞌñu, ne hinte da kꞌatꞌwi. 
\p  
\v 14 Uta njapꞌu̱ ya ku da bödi da ꞌyo̱tꞌwa nꞌar ñho nuꞌu̱ thor kꞌatꞌi, ne hinda mꞌu̱tho hindi pödi da ꞌyo̱tꞌa nꞌar ñho. 
\s1 Ar Pablo edi ya gamfi ne a̱pa Jö da ma̱tsꞌi 
\p  
\v 15 Pe̱ñꞌa nze̱ngwa gatho ya ku ꞌbu̱kwa. Ze̱ngwagihepꞌu̱ nuya gamfi mökagihe. Ar tsi Dada da hwëkꞌahu̱ yá ñho gi gathohu̱. Dá njapꞌu̱.