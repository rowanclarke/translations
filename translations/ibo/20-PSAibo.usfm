\id PSA - Biblica® Open Igbo Contemporary Bible 2020
\h Abụ Ọma
\toc1 Abụ Ọma
\toc2 Abụ Ọma
\toc3 Abụ
\mt1 Abụ Ọma
\c 1
\ms1 Nchịkọta Akwụkwọ nke mbụ
\mr Abụ Ọma 1–41
\cl Abụ Ọma 1
\s1 Onye ihe na-agara nke ọma
\q1 
\v 1 Onye ihe na-agara nke ọma ka mmadụ ahụ bụ,
\q2 onye na-adịghị aga ije na ndụmọdụ ndị na-emebi iwu;
\q1 onye na-adịghị eguzokwa nʼụzọ ndị mmehie
\q2 maọbụ soro nʼotu ndị nkwutọ.
\q1 
\v 2 Kama ihe na-atọ ya ụtọ bụ ime ihe niile dị nʼiwu \nd Onyenwe anyị\nd*.
\q2 Ọ na-atụgharịkwa uche ya nʼiwu \nd Onyenwe anyị\nd* ehihie na abalị,
\q1 
\v 3 Ọ dị ka osisi a kụrụ nʼakụkụ iyi,
\q2 nke na-amịpụta mkpụrụ ya nʼoge ya,
\q1 nke ahịhịa ya na-adịghị akpọnwụ akpọnwụ.
\q2 Ihe niile ọ na-eme na-agara ya nke ọma.
\b
\q1 
\v 4 Ma ndị ajọ omume adịghị otu a.
\q2 Ha dị ka igbugbo ọka
\q2 nke oke ifufe na-efesasị.
\q1 
\v 5 Ya mere, ndị ajọ omume agaghị eguzosi ike nʼụbọchị ikpe;
\q2 ndị mmehie agaghị eguzokwa na nzukọ ndị ezi omume.
\b
\q1 
\v 6 Nʼihi na \nd Onyenwe anyị\nd* na-eche ụzọ ndị ezi omume nche.
\q2 Ma ụzọ ndị ajọ omume ga-eduba ha nʼịla nʼiyi.
\c 2
\cl Abụ Ọma 2
\s1 Onye Chineke tere mmanụ
\q1 
\v 1 Gịnị mere mba niile ji agba izu nzuzo?\f + \fr 2:1 \ft Ya bụ, ịgbakọta nʼihi izu ọjọọ\f*
\q2 Gịnị mere ndị mmadụ ji na-apịa ọpịpịa nke na-abaghị uru?
\q1 
\v 2 Ndị eze nke ụwa na-eguzokwa onwe ha,
\q2 ndị na-achị achị na-agbakọtakwa
\q2 imegide \nd Onyenwe anyị\nd* na imegide Onye ya e tere mmanụ.
\q1 
\v 3 Ha na-asị, “Ka anyị tijie mkpọrọ igwe niile ha kere anyị
\q2 ma tufukwaa ha, nwere onwe anyị.”
\b
\q1 
\v 4 Onye na-anọdụ nʼeluigwe na-achị ọchị.
\q2 Onyenwe anyị na-akwa ha emo.
\q1 
\v 5 Mgbe ahụ, ọ na-eji iwe baara ha mba
\q2 mee ka ụjọ jupụta ha obi nʼihi oke iwe ya.
\q1 
\v 6 “Mụ onwe m eguzobela m eze m
\q2 na Zayọn, ugwu m dị nsọ.”
\p 
\v 7 Aga m ekwusa iwu \nd Onyenwe anyị\nd*:
\q1 Ọ sịrị m, “Ị bụ Ọkpara m;
\q2 taa abụrụla m nna gị.
\q1 
\v 8 Rịọọ m,
\q2 aga m enye gị mba niile nke ụwa
\q2 ka ha bụrụ ihe nketa gị.
\q1 
\v 9 Ị ga-eji mkpara igwe chịa ha,
\q2 tipịa ha dịka onye na-akpụ ite si etipịa ite ndị ọ kpụrụ na-adịghị mma.”
\b
\q1 
\v 10 Nʼihi nke a, unu ndị eze, bụrụnụ ndị nwere uche;
\q2 ka nke a bụrụkwa ihe ịdọ aka na ntị nye ndị na-achị achị nʼụwa.
\q1 
\v 11 Jirinụ ịtụ egwu fee \nd Onyenwe anyị\nd* ofufe;
\q2 jirikwanụ ịma jijiji ṅụrịa ọṅụ nʼihu ya.
\q1 
\v 12 Sutukwanụ Ọkpara ahụ ọnụ ka iwe ghara iwe ya,
\q2 ka unu ghara ị bụ ndị a lara nʼiyi nʼụzọ unu.
\q1 Nʼihi na iwe ya pụrụ ịmalite nʼotu ntabi anya.
\q2 Ndị niile na-eme ya ebe mgbaba ha bụ ndị a gọziri agọzi.
\c 3
\cl Abụ Ọma 3
\d Abụ Ọma Devid. Nke o dere mgbe o si nʼihu Absalọm gbapụ ọsọ ndụ.
\s1 Ekpere maka enyemaka
\q1 
\v 1 O \nd Onyenwe anyị\nd*, ọnụọgụgụ ndị iro m dị ọtụtụ.
\q2 Ọtụtụ ndị mmadụ na-ebili imegide m.
\q1 
\v 2 Ọtụtụ nʼime ha na-ekwu banyere m sị,
\q2 “Chineke agaghị azọpụta ya.” \qs Sela\qs*\f + \fr 3:2 \ft Okwu Hibru nʼusoro abụ nke a na-amaghị ihe ọ pụtara, ụfọdụ na-eche na ọ bụ okwu ntụziaka nye ndị ọbụ abụ banyere ihe ha ga-eme\f*
\b
\q1 
\v 3 Ma gị, \nd Onyenwe anyị\nd* bụ ọta na-ekpuchi m;
\q2 I na-ebuli isi m elu na-eme ka m bụrụ onye nwere nsọpụrụ.
\q1 
\v 4 Etikuru m \nd Onyenwe anyị\nd* mkpu akwa,
\q2 ọ nụkwara olu m, sitekwa nʼugwu nsọ ya za m. \qs Sela\qs*
\b
\q1 
\v 5 Edinara m ala, hie ụra,
\q2 ma bilikwa nʼụtụtụ nʼudo, nʼihi na \nd Onyenwe anyị\nd* na-eche m nche.
\q1 
\v 6 A sịkwa na iri puku kwụrụ puku ndị iro agbaa m gburugburu,
\q2 agaghị m atụ egwu ọbụla.
\b
\q1 
\v 7 Bilie \nd Onyenwe anyị\nd*!
\q2 Zọpụta m Chineke m!
\q1 Tie ndị iro m niile aka nʼagba;\f + \fr 3:7 \ft \xt Job 16:10\xt*\f*
\q2 tipụkwa ndị ajọ omume eze nʼọnụ.
\b
\q1 
\v 8 Nʼihi na nzọpụta na-esite nʼebe \nd Onyenwe anyị\nd* nọ na-abịa.
\q2 Ka ngọzị gị dịịrị ndị gị niile. \qs Sela\qs*
\c 4
\cl Abụ Ọma 4
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ Ọma Devid nke a na-eji ụbọ akwara akpọ.
\s1 Ntụgharị uche nke abalị
\q1 
\v 1 Zaa m mgbe m na-akpọku gị
\q2 Chineke m, gị onye ezi omume;
\q1 Napụta m site nʼihe mgbu m,
\q2 meere m ebere, nụrụkwa ekpere m.
\b
\q1 
\v 2 Unu ụmụ mmadụ, ruo ole mgbe ka unu ga-atụgharịa ebube m, mee ka ọ bụrụ ihe ihere?
\q2 Ruo ole mgbe ka unu ga-ahụ ihe efu nʼanya na-achọ chi ndị ahụ na-abụghị chi nʼezie?\f + \fr 4:2 \ft Nke unu maara na ha bụ okwu ụgha\f*\qs Sela\qs*
\q1 
\v 3 Matanụ nke ọma na \nd Onyenwe anyị\nd* ahọpụtala ndị ezi omume nye onwe ya;
\q2 ọ ga-egekwa ntị nʼolu m mgbe ọbụla m kpọkuru ya.
\b
\q1 
\v 4 Maanụ jijiji, unu emehiekwala;
\q2 mgbe unu nọ nʼelu ihe ndina unu;
\q2 nọọnụ jụụ na-enyocha obi unu. \qs Sela\qs*
\q1 
\v 5 Tụkwasịnụ \nd Onyenwe anyị\nd* obi unu,
\q2 chụkwaranụ ya aja ezi omume.
\b
\q1 
\v 6 Ọtụtụ ndị mmadụ na-ajụ, “Onye pụrụ imere anyị ihe ọma?”
\q2 Ma \nd Onyenwe anyị\nd*, biko mee ka ìhè nke ihu gị mụkwasị anyị.
\q1 
\v 7 Were ọṅụ mejupụta obi m
\q2 karịa mgbe mkpụrụ ubi, ya na mmanya ọhụrụ ha bara ụba nke ukwuu.
\b
\q1 
\v 8 Aga m edina ala ma rahụ ụra nʼudo,
\q2 nʼihi na ọ bụ naanị gị \nd Onyenwe anyị\nd*,
\q2 na-eme ka m nọrọ na-enweghị ihe egwu ọbụla.
\c 5
\cl Abụ Ọma 5
\d Abụ Ọma. Abụ Ọma nke dịrị onyeisi abụ. Ọ bụ opi ka e ji abụ ya. Abụ Ọma nke Devid.
\s1 Ekpere ụtụtụ
\q1 
\v 1 \nd Onyenwe anyị\nd*, biko, nụrụ ekpere m
\q2 tulee ịsụ ude m.
\q1 
\v 2 Geekwa ntị nʼakwa arịrịọ m,
\q2 gị Chineke onye bụ eze m.
\q2 Nʼihi na ọ bụ naanị gị ka m na-akpọku.
\b
\q1 
\v 3 Ụtụtụ ụbọchị niile, O \nd Onyenwe anyị\nd*, ị ga-anụ olu m;
\q2 aga m ekwupụtara gị ihe niile na-akpa m mkpa.
\q2 Aga m elekwa anya ọsịsa gị.
\q1 
\v 4 Ị bụ Chineke, onye ihe ọjọọ ọbụla anaghị atọ ụtọ;
\q2 gị na ndị ajọ omume apụghị ibikọta.
\q1 
\v 5 Ndị mpako agaghị eguzo
\q2 nʼihu gị.
\q1 Ị kpọrọ ndị niile na-eme ihe ọjọọ asị.
\q2 
\v 6 Ị ga-ala ndị niile na-agha ụgha nʼiyi;
\q1 \nd Onyenwe anyị\nd* kpọrọ ndị ogbu mmadụ niile
\q2 na ndị aghụghọ niile asị.
\q1 
\v 7 Ma mụ onwe m, aga m abata nʼime ụlọ gị,
\q2 site nʼoke ịhụnanya gị;
\q1 aga m ejikwa ịtụ egwu kpọọ isiala
\q2 nʼebe ụlọnsọ ukwuu gị dị.
\b
\q1 
\v 8 \nd Onyenwe anyị\nd*, biko, duo m nʼime ezi omume gị
\q2 nʼihi ndị iro m;
\q2 mee ka ụzọ gị zie ezi nʼihu m.
\q1 
\v 9 Obi ha jupụtara nʼechiche ịla nʼiyi,
\q2 a pụghị ịtụkwasị okwu ọbụla si ha nʼọnụ pụta obi.
\q1 Akpịrị ha bụ ili ghere oghe;
\q2 ha ji ire ha ekwu okwu ụgha.
\q1 
\v 10 Maa ha ikpe, Chineke.
\q2 Mee ka nzube ọjọọ ha niile bụrụ ọdịda ha.
\q1 Chụpụ ha nʼihi ịba ụba nke ọtụtụ mmehie ha,
\q2 nʼihi na ha enupula isi megide gị.
\q1 
\v 11 Ma mee ka onye ọbụla na-agbaba nʼime gị ṅụrịa;
\q2 mee ka ha nọgide na-eti mkpu ọṅụ.
\q1 Were aka nchebe gị kpuchie ha,
\q2 ka ndị niile hụrụ aha gị nʼanya ṅụrịa ọṅụ nʼime gị.
\b
\q1 
\v 12 Nʼezie, O \nd Onyenwe anyị\nd*, ị na-agọzi onye ezi omume.
\q2 Ị na-eji ihuọma gị gbaa ha gburugburu dịka ọta.
\c 6
\cl Abụ Ọma 6
\d Abụ Ọma nke dịrị onyeisi abụ. Nke e ji ụbọ akwara abụ. Nʼusoro Sheminit. Abụ Ọma Devid.
\s1 Ekpere nʼoge nsogbu
\q1 
\v 1 O \nd Onyenwe anyị\nd*, abarala m mba mgbe ị na-ewe iwe.
\q2 Atala m ahụhụ nʼoge ọnụma gị.
\q1 
\v 2 Biko, meere m ebere \nd Onyenwe anyị\nd*, nʼihi na adịghị m ike.
\q2 Gwọọ m, nʼihi na ọkpụkpụ m niile nọ nʼihe mgbu.
\q1 
\v 3 Mkpụrụobi m nọ nʼọnọdụ ihe mgbu.
\q2 Ruo ole mgbe, O \nd Onyenwe anyị\nd*, ka ị ga-anọgide na-agba m nkịtị?
\b
\q1 
\v 4 \nd Onyenwe anyị\nd*, biko, bịa zọpụta m;
\q2 nʼihi ịhụnanya gị na-enweghị ọgwụgwụ, napụta m.
\q1 
\v 5 Nʼetiti ndị nwụrụ anwụ ọ dịghị onye na-ekwupụta aha gị.
\q2 O nwere onye na-eto gị site nʼala ili?
\b
\q1 
\v 6 Ike agwụla m nʼihi ịsụ ude.
\b
\q1 Abalị niile, ana m eji ịkwa akwa mee ka ihe ndina m jupụta na mmiri,
\q2 ana m eji anya mmiri dee ihe ndina m.
\q1 
\v 7 Anya m adịghị ahụzikwa ụzọ nke ọma nʼihi ihe mwute;
\q2 ọ kaala nka nʼihi mmeso ndị iro m.
\b
\q1 
\v 8 Sitenụ nʼebe m nọ wezuga onwe unu, unu ndị na-eme ajọ ihe,
\q2 nʼihi na \nd Onyenwe anyị\nd* anụla akwa m niile.
\q1 
\v 9 \nd Onyenwe anyị\nd* anụla akwa m; ọ nụla arịrịọ nke m na-arịọ ya ka o meere m ebere.
\q2 Ọ nabatala ekpere m.
\q1 
\v 10 Ka ndị iro m niile bụrụ ndị ihere ga-eme.
\q2 Ha ga-ada mba, bụrụkwa ndị ga-eji ihere laghachi ebe ha si bịa.
\c 7
\cl Abụ Ọma 7
\d Abụ Shiggaion nke Devid, nke ọ bụkuru Onyenwe anyị banyere Kush, onye Benjamin.
\s1 Arịrịọ maka ikpe ziri ezi
\q1 
\v 1 \nd Onyenwe anyị\nd* Chineke m, nʼime gị ka m gbabara;
\q2 zọpụta m, ma napụta m site nʼaka ndị niile na-achụ m ọsọ,
\q1 
\v 2 ma ọ bụ ha adọkaa m dịka ọdụm,
\q2 ha ga-adọsasịkwa m ebe mmadụ ọbụla enweghị ike ịnapụta m.
\b
\q1 
\v 3 O \nd Onyenwe anyị\nd* Chineke m, ọ bụrụ na m mere ihe dị otu a;
\q2 ọ bụrụkwa na aka m adịghị ọcha.
\q1 
\v 4 Ọ bụrụ na m jiri ihe ọjọọ kwụghachi onye mụ na ya nọ nʼudo ụgwọ,
\q2 maọbụ site nʼụzọ na-ezighị ezi zuo ihe onye iro m.
\q1 
\v 5 Mgbe ahụ, ka onye iro m chụọ m ọsọ, jide m;
\q2 ka ọ tụọ m nʼala zọpịa ndụ m,
\q2 mee ka m bụrụ onye a ga-ahapụ nʼuzuzu nʼọnọdụ ọdịndụ-ọnwụkamma. \qs Sela\qs*
\b
\q1 
\v 6 Bilie, \nd Onyenwe anyị\nd*, nʼiwe gị,
\q2 bilie megide oke iwe ndị iro m;
\q2 teta Chineke m, kpee ikpe ziri ezi.
\q1 
\v 7 Ka nzukọ niile chịkọtara onwe ha ọnụ gbaa gị gburugburu,
\q2 ebe ị na-anọkwasịkwa nʼebe dị elu na-achị ha.
\q2 
\v 8 Ka \nd Onyenwe anyị\nd* kpee ụmụ mmadụ niile ikpe.
\q1 Kpee m ikpe, O \nd Onyenwe anyị\nd*, dịka ezi omume m si dị,
\q2 na dịka izuoke m si dị, gị Onye kachasị ihe niile elu.
\q1 
\v 9 O Chineke onye ezi omume,
\q2 onye na-enyochapụta echiche na obi mmadụ,
\q1 mee ka ihe ike ndị ajọ omume bịa na njedebe
\q2 meekwa ka ndị ezi omume guzosie ike.
\b
\q1 
\v 10 Chineke nke kachasị ihe niile elu, bụ ọta\f + \fr 7:10 \ft Maọbụ, \fqa Onyenwe m\f* m,
\q2 ọ na-azọpụta ndị niile obi ha ziri ezi.
\q1 
\v 11 Chineke bụ onye na-ekpe ikpe ziri ezi,
\q2 Chineke, onye na-ezipụta oke iwe ya kwa ụbọchị.
\q1 
\v 12 Ọ bụrụ na onye ahụ echegharịghị,
\q2 ọ ga-amụ mma agha ya ka ọ dịrị nkọ,
\q2 ọ ga-arọgọ ụta ya, kwadokwa ịgba ya.
\q1 
\v 13 Ọ kwadoola ngwa agha niile nke ọnwụ;
\q2 ọ na-eme ka àkụ ya bụrụ nke na-ere ọkụ.
\b
\q1 
\v 14 Onye ọbụla dị ime ajọ ihe,\f + \fr 7:14 \ft Nʼoge ochie, ndị agha izipụta echiche ime ajọ ihe ha, na-eji ihe na-aghọrọ ọkụ ọsịịsọ, techie nʼọnụ àkụ ha, mụnye ha ọkụ, tụnye ha nʼelu ụlọ ndị iro ha, i gbaa ha ọkụ.\f*
\q2 na-atụrụ ime okwu na ụka mụpụtakwa ngharịpụ nke ụgha na-eweta.
\q1 
\v 15 Ma onye ahụ na-egwu olulu na-adaba
\q2 nʼime olulu ahụ o gwuru.
\q1 
\v 16 Nsogbu ahụ ọ kpaliri na-abịakwasị ya
\q2 ihe ike ahụ ọ kwadooro na-alaghachikwa azụ dakwasị ya nʼisi.
\b
\q1 
\v 17 Aga m enye \nd Onyenwe anyị\nd* ekele nʼihi ezi omume ya,
\q2 aga m abụku aha \nd Onyenwe anyị\nd*, Onye kachasị ihe niile elu abụ otuto.
\c 8
\cl Abụ Ọma 8
\d Abụ Ọma dịrị onyeisi abụ. Abụ Ọma Devid nʼusoro gittit.
\s1 Ịdị ebube Chineke na nsọpụrụ nke mmadụ
\q1 
\v 1 O \nd Onyenwe anyị\nd* Onyenwe anyị,
\q2 lee ka ịdị ukwuu nke aha gị si jupụta ụwa niile!
\b
\q1 I meela ka ebube gị dị elu
\q2 nʼime eluigwe.
\q1 
\v 2 Site nʼotuto\f + \fr 8:2 \ft \xt Mat 21:16\xt*\f* ụmụntakịrị na ụmụ na-aṅụ ara,
\q2 ị tọọla ntọala siri ike megide ndị iro gị,
\q2 ka e si otu a mechie ọnụ onye iro na onye ahụ na-abọ ọbọ.
\q1 
\v 3 Mgbe ọbụla m lere anya na mbara eluigwe,
\q2 hụ ọrụ niile nke aka gị rụrụ,
\q1 mgbe m lere anya nʼelu hụ ọnwa na kpakpando
\q2 i tinyere nʼọnọdụ ha,
\q1 
\v 4 gịnị ka mmadụ bụ i ji na-eche banyere ha?
\q2 Gịnịkwa ka mmadụ bụ iji na-elekọta\f + \fr 8:4 \ft Gịnị ka nwa nke mmadụ bụ na ihe banyere ya na-emetụ gị nʼobi\f* ha?
\b
\q1 
\v 5 I mere ka ha\f + \fr 8:5 \ft Maọbụ, \fqa ya\f* dị ala nwantakịrị nʼebe ndị mmụọ ozi\f + \fr 8:5 \ft Maọbụ, \fqa Chineke\f* nọ,
\q2 I jikwa ebube na nsọpụrụ kpube ya nʼisi dịka okpueze.
\q1 
\v 6 I mekwaala ya ka ọ bụrụ onyeisi nke ihe niile i kere eke,
\q2 tinyekwa ihe niile nʼokpuru ụkwụ ya.
\q1 
\v 7 Ọ na-achị igwe ewu na atụrụ, na ehi,
\q2 na ụmụ anụ ọhịa ndị ọzọ niile,
\q1 
\v 8 na nnụnụ niile,
\q2 na azụ niile,
\q2 na anụ ndị ọzọ na-ebi nʼime mmiri.
\b
\q1 
\v 9 O \nd Onyenwe anyị\nd*, Onyenwe anyị,
\q2 lee ka ịdị ukwuu nke aha gị si jupụta ụwa niile.
\c 9
\cl Abụ Ọma 9
\d Abụ Ọma. Abụ Ọma nke dịrị onyeisi abụ. Nʼusoro olu abụ “Ọnwụ nke Ọkpara.” Abụ ọma Devid.
\s1 Ekele nʼihi nnapụta Chineke
\q1 
\v 1 O \nd Onyenwe anyị\nd*, aga m esite nʼala ala obi m too gị,
\q2 aga m agwakwa onye ọbụla ihe ọma niile ị na-eme.
\q1 
\v 2 Obi ga-atọ m ụtọ; obi m ga-ejupụta nʼọṅụ nʼihi gị,
\q2 aga m abụrụ gị abụ otuto, gị Onye kachasị ihe niile elu.
\b
\q1 
\v 3 Ndị iro m na-alaghachi azụ,
\q2 ha na-asọ ngọngọ na-alakwa nʼiyi nʼihu gị.
\q1 
\v 4 I kpeela ikpe m nʼụzọ ziri ezi,
\q2 nʼocheeze gị ka ị nọdụrụ na-ekpe ikpe ziri ezi.
\q1 
\v 5 I baarala mba niile mba ma laa ndị ajọ omume nʼiyi,
\q2 hichapụkwa aha ha ruo mgbe ebighị ebi.
\q1 
\v 6 Mbibi nke na-enweghị ọgwụgwụ adakwasịla ndị iro m,
\q2 I hopukwala obodo ha niile.
\q2 Ọ dịghị onye na-echetakwa ha ọzọ.
\b
\q1 
\v 7 \nd Onyenwe anyị\nd* bụ eze ruo mgbe ebighị ebi.
\q2 Ọ kwadoola ocheeze ya maka ikpe ikpe ziri ezi.
\q1 
\v 8 Ọ ga-eji ezi omume kpee mba niile ikpe;
\q2 jirikwa ikpe ziri ezi chịa mba niile.
\q1 
\v 9 \nd Onyenwe anyị\nd* bụ ebe mgbaba nye ndị niile a na-emegbu emegbu.
\q2 Ọ bụụrụ ha ebe mgbaba e wusiri ike nʼoge nsogbu.
\q1 
\v 10 \nd Onyenwe anyị\nd*, ndị niile maara aha gị ga-atụkwasị gị obi,
\q2 nʼihi na ọ dịghị mgbe ị na-agbakụta ndị niile na-atụkwasị gị obi azụ.
\b
\q1 
\v 11 Bụkuonụ \nd Onyenwe anyị\nd* abụ otuto, bụ onye nọ nʼocheeze ya na Zayọn.
\q2 Kwusaaranụ mba niile ihe banyere ọrụ ebube ya.
\q1 
\v 12 Nʼihi na onye ahụ na-abọrọ ndị e gburu egbu ọbọ anaghị echefu ihe;
\q2 ọ dịghị elefu mkpu akwa nke ndị a na-akpagbu anya.
\b
\q1 
\v 13 O \nd Onyenwe anyị\nd*, lee ka ndị iro m si akpagbu m!
\q2 Meere m ebere ma napụta m site nʼọnụ ọnwụ,
\q1 
\v 14 ka m nwee ike ikwusa banyere otuto gị
\q2 nʼọnụ ụzọ ama\f + \fr 9:14 \ft Ọ bụ nʼụzọ ama obodo ka a na-anọ akparị ụka niile dị mkpa. \xt Rut 4:1\xt*\f* niile nke ada Zayọn,
\q2 nọrọkwa ebe ahụ ṅụrịa ọṅụ nʼime nzọpụta gị.
\b
\q1 
\v 15 Ndị mba niile adabala nʼime olulu ahụ ha gwuru;
\q2 ọnya ahụ ha siri, zoo, amaala ha.
\q1 
\v 16 Ihe e ji mara \nd Onyenwe anyị\nd* bụ ikpe ya ziri ezi;
\q2 ọrụ aka ndị na-emebi iwu na-ama ha dịka ọnya. \qs Sela\qs*
\q1 
\v 17 Ndị niile na-eme ajọ omume na-alaghachi nʼili;
\q2 nke a bụkwa ọnọdụ mba niile na-echefu Chineke.
\q1 
\v 18 Ma ọ bụghị ruo mgbe ebighị ebi ka a ga-echefu ndị nọ na mkpa;
\q2 olileanya ndị a na-akpagbu agaghị abụkwa nke efu.
\b
\q1 
\v 19 O \nd Onyenwe anyị\nd*, bilie! Ekwela ka mmadụ nwee mmeri ọbụla nʼebe ị nọ;
\q2 ka e kpee mba niile ikpe nʼihu gị.
\q1 
\v 20 O \nd Onyenwe anyị\nd*! Mee ka ha maa jijiji nʼoke egwu;
\q2 mee ka mba niile ghọta na ha bụ naanị mmadụ. \qs Sela\qs*
\c 10
\cl Abụ Ọma 10
\s1 Arịrịọ maka ikpe ziri ezi
\q1 
\v 1 \nd Onyenwe anyị\nd*, gịnị mere i ji na-eguzoro onwe gị nʼebe dị anya?
\q2 Gịnị mere ị na-ezo onwe gị nʼoge nsogbu?
\b
\q1 
\v 2 Site na mpako, onye ajọ omume na-emegbu ndị na-adịghị ike,
\q2 ndị mpịa mpịa aghụghọ ya mara dịka ọnya.
\q1 
\v 3 Ọ na-anya isi banyere ọchịchọ niile nke obi ya,
\q2 ọ na-elelị \nd Onyenwe anyị\nd* anya ma na-agọzi ndị oke ọchịchọ.
\q1 
\v 4 Nʼọnọdụ mpako ya, onye ajọ omume anaghị achọ Chineke,
\q2 nʼechiche ya niile, ọ naghị eche banyere ya.
\q1 
\v 5 Ma ihe niile ọ na-eme na-agara ya nke ọma;
\q2 ọ bụ onye na-ebuli onwe ya elu, iwu gị niile dịkwa anya site nʼebe ọ nọ;
\q2 ọ na-elelị ndị iro ya niile.
\q1 
\v 6 Nʼime obi ya, ọ na-asị, “Ọ dịghị ihe ga-emetụta m.
\q2 Aga m anọ nʼọnọdụ ọṅụ mgbe niile. Nsogbu ọbụla agaghị adakwasị m.”\f + \fr 10:6 \ft Ọ na-asị nʼime obi ya, \fqa “Agaghị ewezuga m nʼọnọdụ m”; \ft Ọ na-aṅụkwa iyi sị, \fqa “Ọ dịghị onye ọbụla ga-eme m ihe ọjọọ”\f*
\b
\q1 
\v 7 Ọnụ ya jupụtara nʼokwu ụgha na ịba mba ime ihe ọjọọ,\f + \fr 10:7 \ft Ya bụ, ịgba iyi\f*
\q2 nʼokpuru ire ya ka nsogbu na ajọ ihe dịkwa.
\q1 
\v 8 Ha na-ezo onwe ha nʼobodo nta dị iche iche,
\q2 nʼebe zooro ezo ka ha na-anọ,
\q1 na-eche itigbu ndị aka ha dị ọcha.
\q2 
\v 9 Dịka ọdụm, ha anaghị eme mkpọtụ ọbụla,
\q1 ọ na-eche ịdakwasị ụmụ ogbenye.
\q2 Dịka ndị bụ dinta si ejide ụmụ anụmanụ nʼọnya ha siri, otu a ka ha si ejide ụmụ ogbenye.
\q1 
\v 10 Ụmụ ogbenye ndị a na-ada nʼala nʼihi ịdị ike ya,
\q2 ọ na-azọpịakwa ha.
\q1 
\v 11 Nʼime obi ya, ọ na-asị, “Chineke echefuola.
\q2 O zofuola ihu ya, ọ dịghị mgbe ọ hụrụ ya.”\f + \fr 10:11 \ft O mechiri anya ya, ọ naghị ahụ ya\f*
\b
\q1 
\v 12 Bilie O \nd Onyenwe anyị\nd*! O Chineke welie aka gị,
\q2 echefukwala ndị na-enweghị onye inyeaka.
\q1 
\v 13 Gịnị mere onye ajọ omume ji na-eleda Chineke anya?
\q2 Gịnị mere o ji na-asị nʼime obi ya,
\q2 “Ọ gaghị akpọ m ka m zaa ajụjụ banyere omume m”?
\q1 
\v 14 Ma gị, O Chineke, ị na-ahụ nsogbu na ihe mwute,
\q2 ị na-atule ihe ị ga-eme banyere ha.
\q1 Ndị a na-emegbu na-atụkwasị gị obi,
\q2 nʼihi na ị bụ onye inyeaka ndị na-enweghị nna.
\q1 
\v 15 Gbajie aka onye ajọ omume a na-eme ihe ọjọọ,
\q2 kpọọ ya ka ọ zaa ajụjụ banyere ajọ omume ya niile
\q2 nke a na-apụghị ịchọpụta.
\b
\q1 
\v 16 \nd Onyenwe anyị\nd* bụ eze ruo mgbe ebighị ebi.
\q2 Ọ ga-esite nʼala ya kpochapụ mba niile.
\q1 
\v 17 O \nd Onyenwe anyị\nd*, ị maara ọchịchọ obi ndị niile a na-akpagbu;
\q2 ị na-ege ntị na mkpu akwa ha ma kasịekwa ha obi,
\q1 
\v 18 Ị na-echedo ndị na-enweghị nna na ndị niile a na-emegbu emegbu,
\q2 ka mmadụ efu, onye e kere eke,
\q2 ghara imenye ha egwu ọzọ.
\c 11
\cl Abụ Ọma 11
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ ọma Devid.
\s1 Onyenwe anyị ebe mgbaba
\q1 
\v 1 Nʼime \nd Onyenwe anyị\nd* ka m mere ebe mgbaba m.
\q2 Gịnị mere i ji na-agwa m okwu sị,
\q2 “Felagaa nʼelu ugwu gị dịka nnụnụ.”
\q1 
\v 2 Nʼihi na ndị ajọ omume ekweela ụta ha;
\q2 ha edoziela àkụ nʼelu eriri ụta ha,
\q1 zoo onwe ha nʼakụkụ ụzọ,
\q2 ịnọ nʼọchịchịrị, gbaa ndị obi ha ziri ezi ụta.
\q1 
\v 3 Mgbe a na-ebibi ntọala niile,
\q2 gịnị ka ndị ezi omume pụrụ ime?
\b
\q1 
\v 4 \nd Onyenwe anyị\nd* nọ nʼụlọnsọ ukwuu ya;
\q2 \nd Onyenwe anyị\nd* nọkwa nʼelu ocheeze ya dị nʼeluigwe.\f + \fr 11:4 \ft Nke a bụ maka ocheeze Onyenwe anyị\f*
\q1 Ọ na-ahụzu ihe niile ụmụ mmadụ na-eme;
\q2 anya ya na-anwalekwa ụzọ ha.
\q1 
\v 5 \nd Onyenwe anyị\nd* na-ele onye ezi omume ule,
\q2 ma onye ajọ omume na ndị niile hụrụ imebi iwu nʼanya,
\q2 ka ọ na-akpọ asị nke ukwuu.
\q1 
\v 6 Ọ ga-eme ka nkume ọkụ zokwasị ndị ajọ omume
\q2 dịka mmiri ozuzo;
\q2 oke ifufe dị ọkụ ga-abụ ihe nketa ha.
\b
\q1 
\v 7 Nʼihi na \nd Onyenwe anyị\nd* bụ onye ezi omume,
\q2 ọ hụkwara ikpe ziri ezi nʼanya;
\q2 ndị ezi omume niile ga-ahụkwa ihu ya anya.
\c 12
\cl Abụ Ọma 12
\d Abụ Ọma nke dịrị onyeisi abụ. Nʼusoro Sheminit. Abụ Ọma nke Devid.
\s1 Ekpere maka enyemaka nʼoge ihe egwu
\q1 
\v 1 \nd Onyenwe anyị\nd*, nyere anyị aka! Nʼihi na ndị ezi omume agwụla!
\q2 Ndị kwesiri ntụkwasị obi anọkwaghị nʼetiti ụmụ mmadụ.
\q1 
\v 2 O nwekwaghị onye eziokwu dị nʼọnụ ya nye onye agbataobi ya.
\q2 Egbugbere ọnụ onye ọbụla na-ekwukwa okwu ire ụtọ,
\q2 maọbụ aghụghọ dị nʼobi ha.
\b
\q1 
\v 3 Ka \nd Onyenwe anyị\nd* wezuga egbugbere ọnụ niile na-ekwu okwu ire ụtọ
\q2 na ire niile na-ekwu okwu ịnya isi.
\q1 
\v 4 Ndị na-asị,
\q2 “Ọ bụ site nʼire anyị ka anyị ga-enwe mmeri;
\q2 egbugbere ọnụ anyị ga-echebe anyị, ọ bụ onye na-achị anyị?”
\b
\q1 
\v 5 “Nʼihi na a na-apụnara ndị ogbenye ihe nʼihi ndị nọ na mkpa na-asụ ude,
\q2 aga m ebili ugbu a, ka \nd Onyenwe anyị\nd* kwuru.
\q2 Aga m zọpụta ha pụọ nʼaka ndị ahụ ji iwe ekwulu ha.”
\q1 
\v 6 Okwu ọnụ \nd Onyenwe anyị\nd* niile zuruoke,
\q2 ha dịka ọlaọcha a nụchara nʼọkụ,
\q2 nke a nụchara ugboro asaa.
\b
\q1 
\v 7 O \nd Onyenwe anyị\nd*, i ga-edebe anyị nʼudo
\q2 ma sitekwa nʼaka ndị dị otu a chebe anyị ruo mgbe ebighị ebi.
\q1 
\v 8 Ndị ajọ omume na-ejegharị nʼebe niile
\q2 mgbe a na-eto ihe ọjọọ nʼetiti ụmụ mmadụ.
\c 13
\cl Abụ Ọma 13
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ ọma Devid.
\s1 Ekpere maka nnapụta
\q1 
\v 1 Ruo ole mgbe ka i ga-echefu m \nd Onyenwe anyị\nd*?
\q2 Ruo ole mgbe ka i ga-ezonarị m ihu gị?\f + \fr 13:1 \ft \xt Job 13:24; Abụ 89:46\xt*\f*
\q1 
\v 2 Ruo ole mgbe ka mụ na mmụọ m ga na-agba mgba
\q2 nọdụkwa na-eru ụjụ kwa ụbọchị nʼime mkpụrụobi m?
\q2 Ruo ole mgbe ka ndị iro m ga-anọgide na-emeri m?
\b
\q1 
\v 3 Lekwasị m anya, ma zaa m, O \nd Onyenwe anyị\nd* Chineke m.
\q2 Nyeghachi m ìhè nke anya m ka m ghara ịnwụ;
\q1 
\v 4 mgbe ahụ onye iro m ga-asị, “Emeriela m ya,”
\q2 mgbe m ga-ada, ndị kpọrọ m asị ga-aṅụrịkwa ọṅụ.
\b
\q1 
\v 5 Ma atụkwasịrị m obi nʼịhụnanya gị nke na-enweghị ọgwụgwụ;
\q2 mkpụrụobi m na-aṅụrị ọṅụ na nzọpụta gị.
\q1 
\v 6 Aga m abụku \nd Onyenwe anyị\nd* abụ,
\q2 nʼihi na o mesoro m mmeso ọma.
\c 14
\cl Abụ Ọma 14
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ ọma Devid.
\s1 Ajọ omume nke ndị na-emebi iwu
\q1 
\v 1 Onye nzuzu na-asị\f + \fr 14:1 \ft Maọbụ, \fqa na-eche\f* nʼime obi ya,
\q2 “Ọ dịghị Chineke ọbụla dị.”
\q1 Ha bụ ndị ajọ omume riri ahụ, ọrụ aka ha niile bụkwa ihe arụ;
\q2 ọ dịghị onye ọbụla na-eme ezi ihe.
\b
\q1 
\v 2 \nd Onyenwe anyị\nd* sitere nʼeluigwe
\q2 na-ele ụmụ mmadụ anya
\q1 ịhụ ma ọ ga-achọta onye ọbụla nwere nghọta
\q2 onye nke na-achọ Chineke.
\q1 
\v 3 Mmadụ niile ewezugala onwe ha, ha niile abụrụla ndị ajọ omume riri ahụ;
\q2 ọ dịghị onye ọbụla na-eme ihe ziri ezi,
\q2 ọ dịghị ọ bụladị, otu onye.
\b
\q1 
\v 4 Ndị niile na-eme ajọ ihe, ha amaghị ihe?
\b
\q1 Ha na-eripịa ndị m dịka mmadụ si eri nri,
\q2 ha adịghị akpọkukwa \nd Onyenwe anyị\nd*.
\q1 
\v 5 Ma nʼebe ahụ ka ha nọ, nʼọnọdụ oke egwu,
\q2 nʼihi na Chineke nọ nʼetiti ndị ezi omume.
\q1 
\v 6 Unu ndị ajọ omume na-emebi atụmatụ ndị ogbenye,
\q2 ma \nd Onyenwe anyị\nd* bụ ebe mgbaba ha.
\b
\q1 
\v 7 A sịkwarị na nzọpụta Izrel ga-esi na Zayọn pụta!
\q2 Mgbe \nd Onyenwe anyị\nd* ga-akpọghachite ndị ya nʼọnọdụ ha,
\q2 ka Jekọb ṅụrịa ọṅụ, ka Izrel nwekwaa obi ụtọ!
\c 15
\cl Abụ Ọma 15
\d Abụ Ọma Devid.
\s1 Onye ga-ebi nʼugwu nsọ Onyenwe anyị?
\q1 
\v 1 \nd Onyenwe anyị\nd*, onye pụrụ ịnọgide nʼụlọnsọ ukwu gị?
\q2 Onye pụrụ ibi nʼugwu nsọ gị?
\b
\q1 
\v 2 Onye na-ebi ndụ nke na-enweghị ịta ụta,
\q2 onye na-arụ ọrụ ezi omume,
\q2 onye na-ekwu eziokwu site nʼobi ya.
\q1 
\v 3 Onye jụrụ ikwutọsị ndị ọzọ,
\q2 onye na-adịghị eme onye agbataobi ya ihe ọjọọ,
\q2 na onye na-adịghị ekwulu mmadụ ibe ya,
\q1 
\v 4 onye na-eleda onye ajọ omume anya,
\q2 ma na-asọpụrụ ndị ahụ na-atụ egwu \nd Onyenwe anyị\nd*,
\q1 onye na-adịghị agbanwe nkwa ọbụla o kwere,
\q2 ọ bụladị mgbe nkwa ahụ na-emegide ya,
\q1 
\v 5 onye na-agbazinye mmadụ ego na-anaghị ụma,
\q2 onye na-adịghị a nara ngarị imegide onye aka ya dị ọcha.
\b
\q1 Onye na-eme ihe ndị a
\q2 agaghị ama jijiji nʼọnọdụ ya, mgbe ọbụla.
\c 16
\cl Abụ Ọma 16
\d Abụ miktam nke Devid.
\s1 Ekpere maka iguzosi ike
\q1 
\v 1 Chebe m, O Chineke,
\q2 nʼihi na nʼime gị ka m gbabara izere ndụ.
\b
\q1 
\v 2 A gwara m \nd Onyenwe anyị\nd*, “Ị bụ Onyenwe m,
\q2 e wezuga gị, enwekwaghị m ọdịmma ọbụla.”
\q1 
\v 3 Ana m asị maka ndị nsọ bụ ndị nọ nʼala a,
\q2 “Ha bụ ndị a na-asọpụrụ, ndị ihe ha nʼatọ m ụtọ.”
\q1 
\v 4 Iru ụjụ nke ndị ahụ na-agbaso chi ndị ọzọ ga-aba ụba.
\q2 Agaghị m eso ha wụsa aja ihe ọṅụṅụ ọbara\f + \fr 16:4 \ft Nʼọtụtụ mba, mmanya bụ ihe e ji agọ ọfọ, ma nʼomenaala mba ụfọdụ, ọbara onye ahụ eji achụ aja ka a na-ewere gwakọọ na mmanya, wụpụ nʼebe ịchụ aja, nke ka a maara dịka aja ọbara. Ọ bụ omenaala mba ndị ahụ na-amaghị Chineke ka onye dere abụ ọma a na-emegide. \xt Lev 18:21; Lev 20:1-2; 2Ez 16:3; 2Ez 23:10.\xt*\f* nye chi ndị a,
\q2 maọbụ were egbugbere ọnụ m kpọọ aha ha.
\b
\q1 
\v 5 \nd Onyenwe anyị\nd*, i nyeela m oke m na iko m;\f + \fr 16:5 \ft Iko a na-ekwu ihe banyere ya nʼebe a bụ iko a na-enye ndị akpọrọ oriri nʼoge mmemme. \xt Dan 5:1-4\xt*\f*
\q2 ị na-elekọta ihe niile bụ nke m site nʼife nza.
\q1 
\v 6 Ọtụtụ oke ala niile dabara m nʼebe dị ezi mma;
\q2 nʼezie, e nwere m ihe nketa nke na-enye m ọṅụ.
\q1 
\v 7 Aga m eto \nd Onyenwe anyị\nd*, onye na-adụ m ọdụ;
\q2 ọ bụladị nʼabalị, obi m na-agwa m ihe m ga-eme.
\q1 
\v 8 Ana m elekwasị \nd Onyenwe anyị\nd* anya mgbe niile.
\q2 Ebe ọ nọ nʼaka nri m, agaghị m ama jijiji.
\b
\q1 
\v 9 Nʼihi nke a, obi dị m ụtọ, ire m jupụtakwara nʼọṅụ;
\q2 aga m anọkwa nʼudo.
\q1 
\v 10 Nʼihi na ị gaghị ahapụ m nʼala mmụọ,
\q2 ị gaghị ekwekwa ka Onye gị kwesiri ntụkwasị obi\f + \fr 16:10 \ft Maọbụ, \fqa onye gị dị nsọ\f* hụ ire ure.
\q1 
\v 11 I gosila m ụzọ ndụ;
\q2 ị ga-eji ọṅụ mejupụta obi m nʼihu gị;
\q2 ya na ihe ụtọ ndị dị nʼaka nri gị ruo ebighị ebi.
\c 17
\cl Abụ Ọma 17
\d Ekpere Devid.
\s1 Ekpere maka nnapụta
\q1 
\v 1 O \nd Onyenwe anyị\nd*, nụrụ arịrịọ m ziri ezi,
\q2 nụrụkwa mkpu akwa m.
\q1 Gee ntị nʼekpere m
\q2 nʼihi na o siteghị nʼegbugbere ọnụ na-ekwu okwu aghụghọ.
\q1 
\v 2 Ka mkpepụta m si nʼaka gị bịa;
\q2 ka anya gị hụ ihe ziri ezi.
\b
\q1 
\v 3 Ọ bụ ezie na ị nyochaala obi m,
\q2 i letala m nʼabalị, nwalekwaa m,
\q1 ị ga-achọpụta na o nweghị ihe ọ ọjọọ bụla m zubere,
\q2 na ọnụ m ekwuhiebeghị.
\q1 
\v 4 Ndị mmadụ agbalịala inye m ngarị
\q2 ma anaghị m ekwe ka mụ na ndị na-eme ihe ike nwee mmekọrịta
\q2 nʼihi iwu sitere nʼegbugbere ọnụ gị.
\q1 
\v 5 Nzọ ụkwụ m akpafubeghị site nʼụzọ gị,
\q2 ụkwụ m agbụchapụghịkwa site nʼọnọdụ ya.
\b
\q1 
\v 6 Ana m akpọku gị, O Chineke, nʼihi na amaara m na ị ga-aza m;
\q2 gee m ntị ma nụrụ ekpere m.
\q1 
\v 7 Zipụta ịhụnanya gị dị oke ebube;
\q2 gị onye na-eji aka nri gị dị ike azọpụta
\q2 ndị niile gbabara na gị site nʼaka ndị iro ha.
\q1 
\v 8 Chebe m dịka mkpụrụ anya gị;
\q2 zoo m na ndo nke nku gị,
\q1 
\v 9 site nʼaka ndị ajọ omume gbara m gburugburu,
\q2 ọ bụladị ndị iro m, ndị chọrọ igbu m.
\b
\q1 
\v 10 Ha anaghị eme ebere, ha bụ ndị afọ tara mmiri,
\q2 okwu ịnya isi juru ha ọnụ.
\q1 
\v 11 Ha achọpụtala ebe m nọ, ugbu a, ha gbara m gburugburu,
\q2 ha ji anya nkọ, jikerekwa ịtụ m nʼala.
\q1 
\v 12 Ha ka ọdụm agụụ na-agụ nke zoro onwe ya nʼọhịa,
\q2 dịka ọdụm dị ike na-eche ihe ọ ga-adọgbu.
\b
\q1 
\v 13 \nd Onyenwe anyị\nd*, bilie guzogide ha, tigbuo ha.
\q2 Jiri mma agha gị zọpụta m site nʼaka ndị ajọ omume.
\q1 
\v 14 O \nd Onyenwe anyị\nd*, zọpụta m site nʼaka ndị dị otu a,
\q2 site nʼaka ndị ụgwọ ọrụ ha bụ nʼụwa a.
\q1 Ka ihe ịkpakọbara debere ndị ajọ omume jupụta afọ ha,
\q2 ka afọ jukwa ụmụ site nʼihe ndị a,
\q2 ka ha hapụrụ ihe fọdụrụ nye ụmụntakịrị ha.
\b
\q1 
\v 15 Ma mụ onwe m ga-ahụ ihu gị site nʼezi omume;
\q2 mgbe m ga-ebili, afọ ga-eju m nke ọma, nʼihi na aga m ahụ gị ihu na ihu.
\c 18
\cl Abụ Ọma 18
\d Abụ ọma Devid. Abụ Devid ohu \nd Onyenwe anyị\nd*. Ọ bụụrụ \nd Onyenwe anyị\nd* okwu niile nke abụ a mgbe \nd Onyenwe anyị\nd* napụtara ya site nʼaka ndị iro ya niile, nakwa nʼaka Sọl. Ọ sịrị:
\s1 Abụ mmeri
\q1 
\v 1 O \nd Onyenwe anyị\nd*, ahụrụ m gị nʼanya, gị bụ ike m.
\b
\q1 
\v 2 \nd Onyenwe anyị\nd* bụ oke nkume m, na ebe mgbaba m e wusiri ike, na onye nnapụta m.
\q2 Chineke m bụ oke nkume m, onye m gbabara nʼime ya.
\q2 Ọ bụ ọta m, na mpi nzọpụta m, na oke nkume m nke onye ọbụla na-apụghị ịba nʼime ya.
\b
\q1 
\v 3 Akpọkuru m \nd Onyenwe anyị\nd*, onye e kwesiri inye otuto,
\q2 ọ zọpụtara m site nʼaka ndị iro m.
\q1 
\v 4 Ụdọ niile nke ọnwụ kere m agbụ;
\q2 ịchị ọkụ nke mbibi ọjọọ kpuchiri m.
\q1 
\v 5 Ụdọ nke ili kere m gburugburu,
\q2 ọnya nke ọnwụ guzogidere m.
\b
\q1 
\v 6 Nʼọnọdụ oke mkpagbu m, akpọkuru m \nd Onyenwe anyị\nd*;
\q2 etiri m mkpu akwa, kpọkuo Chineke m ka o nyere m aka;
\q1 akwa m rutekwara ya ntị,
\q2 o sitekwara nʼụlọnsọ ukwu ya nụ olu m.
\q1 
\v 7 Ụwa mere mkpọtụ, maa jijiji,
\q2 ntọala niile nke ugwu niile makwara jijiji,
\q2 ha mara jijiji nʼihi iwe nke na-ewe ya.
\q1 
\v 8 Anwụrụ ọkụ sitere ya nʼimi pụta,
\q2 ọkụ na-erepịa erepịa sikwa nʼọnụ ya pụta;
\q2 icheku ọkụ na-ere ọkụ sitekwara nʼebe ahụ nwupụta.
\q1 
\v 9 O kewara mbara eluigwe, rịdata;
\q2 oke igwe ojii dịkwa nʼokpuru ụkwụ ya.
\q1 
\v 10 Ọ nọkwasịrị nʼelu cherubim\f + \fr 18:10 \ft Cherubim bụ mmụọ ndị ahụ dị ike na ndị jupụtara nʼebube nke anya na-adịghị ahụ. Ọrụ ha bụ ibu ocheeze Ebube ahụ. \xt Izk 1:26\xt*\f* felie elu,
\q2 o feliri elu nʼelu nku nke ifufe.
\q1 
\v 11 O mere ọchịchịrị ebe nzuzo ya, ihe mkpuchi nke gbara ya gburugburu,
\q2 bụ ọchịchịrị mmiri igwe ojii nke mbara eluigwe.
\q1 
\v 12 Site nʼìhè nke na-enwupụta nʼahụ ya, igwe ojii
\q2 ji mkpụrụ mmiri na amụma egbe eluigwe gabiga.
\q1 
\v 13 \nd Onyenwe anyị\nd* sitere nʼeluigwe bigbọọ;
\q2 olu Onye kachasị ihe niile elu dara ụda.
\q1 
\v 14 Ọ gbara àkụ ya, mee ka ndị iro gbasasịa,
\q2 o jikwa oke amụma nke egbe eluigwe chụsaa ha.
\q1 
\v 15 E kpughere ala ala nke oke osimiri,
\q2 gbakwa ntọala niile nke ụwa ọtọ,
\q1 site nʼịba mba gị, O \nd Onyenwe anyị\nd*,
\q2 na nkuume si gị nʼimi pụta.
\b
\q1 
\v 16 O sitere nʼelu setịpụ aka ya,
\q2 jidesie m aka ike, ọ dọpụtara m site nʼogbu mmiri niile.
\q1 
\v 17 Ọ napụtara m site nʼaka ndị iro m dị ike,
\q2 bụ ndị kpọrọ m asị, ndị dịkwa ike karịa m.
\q1 
\v 18 Ha guzogidere m nʼụbọchị ihe ndakwasị m,
\q2 ma \nd Onyenwe anyị\nd* bụrụ m ihe ndabere.
\q1 
\v 19 Ọ kpọpụtara m gaa nʼebe sara mbara,
\q2 ọ napụtara m nʼihi na ihe m na-atọ ya ụtọ.
\b
\q1 
\v 20 \nd Onyenwe anyị\nd* mesoro m dịka ezi omume m si dị;
\q2 ọ kwụghachiri m dịka ịdị ọcha nke aka m si dị.
\q1 
\v 21 Nʼihi na edebezuola m ụzọ niile nke \nd Onyenwe anyị\nd*,
\q2 ikpe amaghị m nʼihi ịgbakụta Chineke azụ.
\q1 
\v 22 Iwu ya niile dị nʼihu m,
\q2 esibekwaghị m nʼụkpụrụ ya wezuga onwe m.
\q1 
\v 23 Abụ m onye na-enweghị ịta ụta nʼihu ya,
\q2 edebekwara m onwe m pụọ na mmehie.
\q1 
\v 24 \nd Onyenwe anyị\nd* kwụghachiri m dịka ezi omume m si dị,
\q2 dịka ịdị ọcha nke aka m abụọ si dị nʼanya ya.
\b
\q1 
\v 25 Nʼebe onye kwesiri ntụkwasị obi nọ, i na-egosi onwe gị onye kwesiri ntụkwasị obi,
\q2 nʼebe onye zuruoke nọ, ị na-egosi onwe gị onye zuruoke.
\q1 
\v 26 Nʼebe onye dị ọcha nọ, ị na-egosi onwe gị onye dị ọcha,
\q2 ma nye ndị ụzọ ha na-ezighị ezi, ị na-egosi onwe gị dịka onye dị aghụghọ.
\q1 
\v 27 Ị na-azọpụta ndị dị umeala nʼobi,
\q2 ma ị na-eme ka ndị nwere anya mpako dị ala.
\q1 
\v 28 Ọ bụ gị, \nd Onyenwe anyị\nd*, na-eme ka oriọna m na-enwu,
\q2 Chineke m na-eme ka ọchịchịrị m ghọọ ìhè.
\q1 
\v 29 Site nʼinyeaka gị, apụrụ m ịlụso igwe ndị agha ọgụ,
\q2 sitekwa na Chineke m, apụkwara m ịwụfe mgbidi ọbụla.
\b
\q1 
\v 30 Ma banyere Chineke, ụzọ ya zuruoke,
\q2 okwu ọnụ \nd Onyenwe anyị\nd* bụ ihe a nụchara anụcha;
\q2 ọ bụ ọta\f + \fr 18:30 \ft Ya bụ, ebe nchebe\f* nke onye ọbụla na-ezo onwe ya nʼokpuru ya.
\q1 
\v 31 Nʼihi na onye bụ Chineke, ma ọ bụghị naanị \nd Onyenwe anyị\nd*?
\q2 Onye bụkwa oke Nkume ahụ, ma ọ bụghị naanị Chineke anyị?
\q1 
\v 32 Ọ bụ Chineke na-enye m ike,
\q2 na-echebekwa ụzọ m nʼizuoke.
\q1 
\v 33 Ọ na-eme ka ụkwụ m dị gara gara, dịka nke nne ele;
\q2 Ọ na-emekwa ka m kwụrụ chịm nʼebe niile dị elu.
\q1 
\v 34 Ọ na-azụ aka m abụọ ibu agha,
\q2 ogwe aka m abụọ pụrụ ịrọji ụta bronz.
\q1 
\v 35 Ị na-eme ka inyeaka nke nzọpụta gị bụrụ ọta m,
\q2 aka nri gị na-akwagidekwa m,
\q2 inyeaka gị emeela m ka m dị ukwuu.
\q1 
\v 36 Ị na-edozi ụzọ sara mbara nye ụkwụ,
\q2 ka nkwonkwo ụkwụ m ghara ịgbụchapụ.
\b
\q1 
\v 37 Achụrụ m ndị iro m ọsọ, jidekwa ha;
\q2 alaghachighị m azụ tutu ruo mgbe ha niile lara nʼiyi.
\q1 
\v 38 Etidara m ha nʼala ebe ha enwekwaghị ike ibilite.
\q2 Ha dara nʼokpuru ụkwụ m.
\q1 
\v 39 Ọ bụ gị nyere m ike ibu agha,
\q2 i wedara ndị niile na-emegide m nʼala nʼihu m.
\q1 
\v 40 I mere ka ndị iro m tụgharịa gbapụ ọsọ.
\q2 Ebibikwara m ndị kpọrọ m asị.
\q1 
\v 41 Ha bere akwa maka enyemaka, ma ọ dịghị onye na-azọpụta ha.
\q2 Ha kpọkuru \nd Onyenwe anyị\nd*, ma ọ zaghị ha.
\q1 
\v 42 Egwepịara m ha nke ọma dịka ntụ nke ikuku na-ebufu;
\q2 a zọtọrọ m ha dịka apịtị nke okporoụzọ.
\q1 
\v 43 Ị napụtala m site nʼaka ndị na-alụso m ọgụ
\q2 ị meela m onyeisi nke ọtụtụ mba;
\q1 ndị m na-amaghị na mbụ na-ejekwara m ozi.
\q2 
\v 44 Ndị ala ọzọ na-ehulata nʼihu m nʼihi egwu,
\q2 ngwangwa ha nụrụ olu m, ha na-erube isi nye m.
\q1 
\v 45 Obi na-ada ha mba;
\q2 ha na-ama jijiji mgbe ha na-esite nʼebe niile ha e wusiri ike na-apụta.
\b
\q1 
\v 46 \nd Onyenwe anyị\nd* na-adị ndụ! Otuto dịrị oke nkume m!
\q2 Mbuli elu dịrị Chineke, Onye nzọpụta m.
\q1 
\v 47 Ọ bụ Chineke ahụ onye na-abọrọ m ọbọ,
\q2 onye na-emekwa ka mba dị iche iche nọrọ nʼokpuru m,
\q2 
\v 48 onye na-anapụta m site nʼaka ndị iro m.
\q1 I mere ka m dị elu karịa ndị iro,
\q2 napụtakwa m site nʼaka nwoke na-eme ihe ike.
\q1 
\v 49 Nʼihi nke a, \nd Onyenwe anyị\nd*, aga m eto gị nʼetiti mba niile dị iche iche,
\q2 aga m abụku aha gị abụ otuto.
\b
\q1 
\v 50 Ọ na-enye eze ya mmeri dị ukwuu;
\q2 Ọ na-egosikwa onye ya onye e tere mmanụ ịhụnanya na-adịghị ada ada,
\q2 nye Devid na ndị agbụrụ ya ruo mgbe ebighị ebi.
\c 19
\cl Abụ Ọma 19
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ ọma Devid.
\s1 Akaọrụ Chineke na iwu ya
\q1 
\v 1 Eluigwe na-ezipụta ebube Chineke;
\q2 mbara eluigwe na-egosikwa ọrụ aka ya.
\q1 
\v 2 Ụbọchị niile, ha na-ekwupụta okwu,
\q2 ehihie na abalị, ha na-egosipụta ihe ọmụma.
\q1 
\v 3 Ha nweghị asụsụ, ha nweghị okwu,
\q2 ma a na-anụ ụda ha.
\q1 
\v 4 Nʼụwa niile ka olu ha na-apụ gazuo,
\q2 okwu ọnụ ha niile erukwaala nʼebe ụwa sọtụrụ.
\q1 Ọ bụ na mbara eluigwe ka Chineke maara ụlọ ikwu nye anyanwụ.
\q2 
\v 5 Ọ dị ka nwokorobịa lụrụ nwunye ọhụrụ mgbe o si nʼụlọ ndina ya na-apụta,
\q2 dịka ọgba ọsọ nke ọ na-anụ ọkụ nʼobi ịgba ọsọ ịsọ mpi.
\q1 
\v 6 Ọ na-esite nʼotu nsọtụ nke mbara eluigwe,
\q2 bido ije ya, gafee ruo na nsọtụ nke ọzọ.
\q2 Ọ dịkwaghị ihe ọbụla na-ezonarị onwe ya site nʼokpomọkụ ya.
\b
\q1 
\v 7 Iwu \nd Onyenwe anyị\nd* zuruoke;
\q2 ọ na-eweghachi mkpụrụobi.
\q1 Ụkpụrụ \nd Onyenwe anyị\nd* niile kwesiri ntụkwasị obi;
\q2 ọ na-eme ka onye na-enweghị uche mara ihe.
\q1 
\v 8 Iwu \nd Onyenwe anyị\nd* ziri ezi,
\q2 ọ na-enye mkpụrụobi ọṅụ.
\q1 Iwu \nd Onyenwe anyị\nd* na-amụke amụke,
\q2 ọ na-enye anya ìhè.
\q1 
\v 9 Ịtụ egwu \nd Onyenwe anyị\nd* dị ọcha,
\q2 ọ na-adịgide ruo mgbe ebighị ebi;
\q1 ụkpụrụ niile nke \nd Onyenwe anyị\nd* na-eguzosi ike,
\q2 ha niile bụkwa ihe ziri ezi.
\b
\q1 
\v 10 Ha dị oke ọnụ karịa ọlaedo,
\q2 karịa ọlaedo a nụchara anụcha;
\q1 ha na-atọkwa ụtọ karịa mmanụ aṅụ,
\q2 karịa mmanụ aṅụ si nʼụbụbọ aṅụ.
\q1 
\v 11 Ọ bụ site na ha ka a na-adọ ohu gị aka na ntị;
\q2 ụgwọ ọrụ dị ukwuu dị nʼidebe ha.
\q1 
\v 12 Onye pụrụ ịghọta amaghị ama ya niile?
\q2 Gbaghara m ihe niile zoro ezo nke adịghị ike m.
\q1 
\v 13 Chebe m, ka m ghara ilezi anya mehie megide gị.
\q2 Ekwela ka ha na-achị achị na ndụ m.
\q1 Mgbe ahụ ka m ga-abụ onye zuruoke,
\q2 onye nwere onwe ya site nʼebe ihe ọjọọ niile nke mmehie dị.
\b
\q1 
\v 14 Kwere \nd Onyenwe anyị\nd*, Onye mgbapụta m, na Oke nkume nchebe m,
\q2 ka okwu ọnụ m niile, na echiche obi m niile,
\q2 bụrụ ihe na-atọ gị ụtọ, na nke ị na-anabata.
\c 20
\cl Abụ Ọma 20
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ Ọma Devid.
\s1 Ekpere maka enyemaka
\q1 
\v 1 Ka \nd Onyenwe anyị\nd* zaa gị nʼụbọchị nsogbu gị;
\q2 ka aha Chineke nke Jekọb chebe gị.
\q1 
\v 2 Ya sitekwa nʼebe nsọ ya zitere gị inyeaka,
\q2 ma site na Zayọn kwagide gị.
\q1 
\v 3 Ya chetakwa aja niile ị chụrụ,
\q2 ma nabata aja nsure ọkụ niile ị chụrụ nye ya. \qs Sela\qs*
\q1 
\v 4 Ya mezukwara gị ihe niile nke obi gị na-achọ,
\q2 mekwaa ka atụmatụ gị niile gaa nke ọma.
\q1 
\v 5 Anyị ga-eti mkpu ọṅụ maka mmeri i meriri,
\q2 buliekwa ọkọlọtọ anyị elu nʼaha Chineke anyị.
\b
\q1 Ka \nd Onyenwe anyị\nd* mezuo arịrịọ gị niile.
\b
\q1 
\v 6 Ugbu a, amaara m
\q2 na \nd Onyenwe anyị\nd* na-azọpụta onye ya o tere mmanụ;
\q1 ọ na-esite nʼebe nsọ ya nʼeluigwe jiri aka nri ya,
\q2 zọpụta ma zakwaa ya.
\q1 
\v 7 Ụfọdụ na-atụkwasị obi ha na ịnyịnya, ndị ọzọ nʼụgbọ agha;
\q2 ma anyị na-atụkwasị aha \nd Onyenwe anyị\nd*, Chineke anyị, obi.
\q1 
\v 8 Ha na-egbu ikpere nʼala ma daa,
\q2 ma anyị ga-ebili, kwụrụ chịm.
\q1 
\v 9 O \nd Onyenwe anyị\nd*, zọpụta eze!
\q2 Zakwaa anyị mgbe anyị kpọkuru gị!
\c 21
\cl Abụ Ọma 21
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ Ọma Devid.
\s1 Ekele maka mmeri
\q1 
\v 1 O \nd Onyenwe anyị\nd*, lee na eze na-aṅụrị ọṅụ nʼike gị.
\q2 Obi na-atọkwa ya ụtọ nke ukwuu nʼihi mmeri niile i nyere ya!
\b
\q1 
\v 2 I nyela ya ihe obi ya chọrọ;
\q2 i mekwaara ya ihe niile ọ rịọrọ gị! \qs Sela\qs*
\q1 
\v 3 I ji ngọzị bara ụba nabata ya,
\q2 ọ bụkwa okpueze e ji ọlaedo a ṅụchara nke ọma kpụọ ka i kpukwasịrị ya nʼisi.
\q1 
\v 4 Ọ rịọrọ ka i nye ya ndụ, i zara ekpere ya
\q2 mekwaa ka o nwee ogologo ndụ nke ga-adịgide ruo mgbe ebighị ebi.
\q1 
\v 5 Nsọpụrụ ya dị ukwuu site na mmeri niile i nyere ya,
\q2 ebube na ịma mma bụ onyinye i nyere ya.
\q1 
\v 6 Nʼezie, i nyela ya ngọzị na-adịgide ruo mgbe ebighị ebi,
\q2 i mere ka o nwee obi ụtọ nke na-esite nʼọṅụ nke nọnyere gị.
\q1 
\v 7 Nʼihi na eze na-atụkwasị \nd Onyenwe anyị\nd* obi,
\q2 agaghị ewezuga ya nʼọnọdụ ya site nʼịhụnanya
\q2 nke Onye kachasị ihe niile elu nke na-enweghị ọgwụgwụ.
\b
\q1 
\v 8 Ị ga-anwụchi ndị iro gị niile;
\q2 aka nri gị ga-ejidekwa ndị kpọrọ gị asị.
\q1 
\v 9 Mgbe ị pụtara ịlụ ọgụ,
\q2 ị ga-erepịa ha dịka ọkụ nke na-enwu ajọ onwunwu.
\q1 Nʼoke iwe ya, \nd Onyenwe anyị\nd* ga-elo ha,
\q2 ọkụ ya ga-erepịakwa ha.
\q1 
\v 10 Ị ga-esite nʼelu ụwa laa agbụrụ ha niile nʼiyi,
\q2 ụmụ ha kwa site, nʼetiti ụmụ mmadụ.
\q1 
\v 11 Nʼagbanyeghị na ha nwere ike ịpịa ọpịpịa ọjọọ megide gị,
\q2 maọbụ tụpụta atụmatụ ọjọọ, ha agaghị emezu ebumnuche ha.
\q1 
\v 12 Nʼihi na i ga-eme ka ha gbaghachi azụ
\q2 mgbe i kwere ụta gị tụgide ha nʼihu.
\b
\q1 
\v 13 O \nd Onyenwe anyị\nd*, ka e bulie gị elu nʼihi ike gị;
\q2 anyị ga-abụ abụ ma tokwaa ike gị.
\c 22
\cl Abụ Ọma 22
\d Abụ Ọma dịrị onyeisi abụ. Nʼusoro olu abụ nke “Nne ele nke ụtụtụ.” Abụ Ọma Devid.
\s1 Akwa na abụ ekele
\q1 
\v 1 Chineke m, Chineke m, gịnị mere i jiri hapụ m?
\q2 Gịnị mere i ji nọ ebe dị anya ịzọpụta m,
\q2 nʼebe dị anya site nʼịsụ ude m niile?
\q1 
\v 2 O Chineke m, ana m akpọku gị nʼehihie, ma ị dịghị aza m,
\q2 nʼabalị kwa, ma ọ dịghị izuike m nwere.\f + \fr 22:2 \ft Maọbụ, \fqa Nʼabalị, adịghị m emechikwa ọnụ m\f*
\b
\q1 
\v 3 Nʼezie, i nọ nʼocheeze gị dịka Onye ahụ dị Nsọ;
\q2 ị bụ otuto ndị Izrel.
\q1 
\v 4 Nna anyị ha tụkwasịrị gị obi;
\q2 ha tụkwasịrị gị obi, ị zọpụtakwara ha.
\q1 
\v 5 Ha kpọkuru gị si otu a bụrụ ndị a zọpụtara;
\q2 ihere emeghị ha nʼihi na ha tụkwasịrị gị obi.
\b
\q1 
\v 6 Abụ m idide, abụghị m mmadụ;
\q2 onye ndị ọzọ na-akwa emo, onye ndị mmadụ na-eleda anya.
\q1 
\v 7 Ndị niile hụrụ m na-achị m ọchị;
\q2 na-emiri m ọnụ ịkwa emo, na-efufekwa isi ha na-asị.
\q1 
\v 8 “O na-atụkwasị \nd Onyenwe anyị\nd* obi;
\q2 ka \nd Onyenwe anyị\nd* bịa gbapụta ya.
\q1 Ya napụta ya ebe ọ bụ
\q2 na ihe ya masịrị ya.”
\b
\q1 
\v 9 Ma \nd Onyenwe anyị\nd*, ọ bụ gị wepụtara m site nʼafọ nne m.
\q2 Ọ bụ gị mere ka m tụkwasị gị obi, ọ bụladị mgbe m ka na-aṅụ ara.
\q1 
\v 10 Site nʼoge amụrụ m ka e nyefere m nʼaka gị.
\q2 Site nʼafọ nne m, ka gị onwe gị bụ Chineke m.
\b
\q1 
\v 11 Anọla m ebe dị anya,
\q2 nʼihi na nsogbu dị nso.
\q2 Ọ dịkwaghị onye inyeaka nọ nso.
\b
\q1 
\v 12 Ọtụtụ oke ehi gbara m gburugburu;
\q2 oke ehi dị ike nke Bashan\f + \fr 22:12 \ft Bashan bụ obodo e ji oke ehi gbara abụba ma dịkwa ike maara. Ọ dị na mpaghara ugwu nʼọwụwa anyanwụ ala Filistia. \xt Dit 3:1; Ems 4:1\xt*\f* gbara m gburugburu.
\q1 
\v 13 Ọdụm ndị na-agbọ ụja mgbe ha na-adọgbu anụ ọhịa
\q2 asaghepụla ọnụ ha megide m.
\q1 
\v 14 A wụpụla m dịka mmiri,
\q2 ọkpụkpụ m niile apụkwaala nʼọnọdụ ha.
\q1 Obi m agbazela dịka mmanụ,
\q2 obi ịlọ mmiri ewerela ọnọdụ nʼime m.
\q1 
\v 15 Ike ọbụla adịghịkwa m nʼahụ, dịka a ga-asị na m bụ ụrọ nke anwụ mịkọọrọ mmiri dị ya nʼime.
\q2 Ire m na-araparakwa m nʼọnụ,
\q2 nʼihi na ị tọgbọrọ m nʼọnụ ọnwụ.
\b
\q1 
\v 16 Ọtụtụ nkịta agbaala m gburugburu;
\q2 otù ndị na-eme ihe ọjọọ agbaala m gburugburu,
\q2 ha adupuola m aka m na ụkwụ m.
\q1 
\v 17 A pụrụ ịgụta ọkpụkpụ m niile ọnụ;
\q2 ndị mmadụ na-ele m anya na-emikwa ọnụ ọchị
\q1 
\v 18 Ha na-eke uwe m nʼetiti ha,
\q2 ha sitere nʼife nza kee uwe m.
\b
\q1 
\v 19 Ma gị, \nd Onyenwe anyị\nd*, anọla m ebe dị anya;
\q2 gị Onye bụ ike m, mee ngwangwa bịa nyere m aka.
\q1 
\v 20 Napụta ndụ m site na mma agha,
\q2 site nʼike ụmụ nkịta, napụta ndụ m nke dị oke ọnụahịa.
\q1 
\v 21 Gbapụta m site nʼọnụ ọdụm ndị a,
\q2 zọpụta m site na mpi atụ ndị a.
\b
\q1 
\v 22 Aga m ekwupụta aha gị nye ụmụnna m;
\q2 nʼetiti ọha mmadụ aga m enye gị otuto.
\q1 
\v 23 Toonu \nd Onyenwe anyị\nd*! Unu niile bụ ndị na-atụ egwu ya;
\q2 unu bụ ndị agbụrụ Jekọb, sọpụrụnụ ya!
\q2 Tụọnụ ya egwu, unu agbụrụ Izrel!
\q1 
\v 24 Nʼihi na o ledaghị ahụhụ onye a na-akpagbu anya
\q2 maọbụ kwaa ya emo;
\q1 o lefughị ya anya
\q2 kama mgbe ọ kpọkuru ya, ọ nụrụ olu akwa ya.
\b
\q1 
\v 25 Isiokwu otuto m nʼetiti ọha mmadụ sitere na gị;
\q2 aga m emezukwa nkwa niile m kwere gị nʼihu ndị ahụ na-atụ egwu gị.
\q1 
\v 26 Ndị ogbenye ga-eri nri, rijuo afọ ha,
\q2 ndị niile na-achọ \nd Onyenwe anyị\nd* ga-eto ya
\q2 ka mkpụrụobi unu dị ndụ ruo mgbe ebighị ebi.
\b
\q1 
\v 27 Nsọtụ elu ụwa niile ga-echeta,
\q2 ma laghachikwute \nd Onyenwe anyị\nd*.
\q1 Ezinaụlọ nke mba niile dị iche iche
\q2 ga-akpọ isiala nʼihu ya.
\q1 
\v 28 Nʼihi na ike ọchịchị bụ nke \nd Onyenwe anyị\nd*,
\q2 ọ na-achịkwa mba niile.
\b
\q1 
\v 29 Ndị ọgaranya niile nke elu ụwa ga-eri oriri ma fee ya;
\q2 ihe niile na-anwụ anwụ ga-akpọ isiala nʼihu ya;
\q2 ndị na-apụghị idebe onwe ha ndụ.
\q1 
\v 30 Agbụrụ anyị ga-ejere ya ozi;
\q2 a ga-akọrọ ọgbọ ndị na-abịa nʼihu ihe banyere onyenwe anyị.
\q1 
\v 31 Ha ga-ekwusa ezi omume ya
\q2 nye ọgbọ niile na-abịa nʼihu, bụ ndị a na-amụbeghị
\q2 nʼihi na o meela ya.
\c 23
\cl Abụ Ọma 23
\d Abụ Ọma Devid.
\s1 Onyenwe anyị na-azụ anyị dị ka atụrụ
\q1 
\v 1 \nd Onyenwe anyị\nd* na-azụ m dịka atụrụ, ọ dịghị ihe akọrọ m.
\q2 
\v 2 Ọ na-eme ka m dinaa ala nʼebe ahịhịa ndụ na-eto,
\q1 ọ na-edugharị m nʼakụkụ mmiri dị jụụ,
\q2 
\v 3 ọ na-atụte mkpụrụobi m.
\q1 Ọ na-edu m nʼụzọ niile nke ezi omume
\q2 nʼihi aha ya.
\q1 
\v 4 A sịkwarị na m na-aga ije,
\q2 na ndagwurugwu nke ọchịchịrị ọnwụ,
\q1 agaghị m atụ egwu ihe ọjọọ ọbụla;
\q2 nʼihi na ị nọnyeere m,
\q1 mkpọrọ gị na mkpanaka gị
\q2 na-akasị m obi.
\b
\q1 
\v 5 Ị na-akwado tebul\f + \fr 23:5 \ft Nʼoge ochie, ọ bụ nʼebe iri nri (tebul) ka enyi na enyi na-anọ agba ndụ, maọbụ nwe nkwekọrịta. Oriri a na-egosi na ọgbụgba ndụ bụ ihe ọṅụ na ezi mmekọrịta nke enyi na enyi. Eze ahụ nke na-azụ ndị ya dịka atụrụ, nabatara ohu ya bụ Devid nʼebe iri nri, dịka e dere ya nʼabụ ọma a.\f* nʼihu m,
\q2 nʼanya ndị iro m.
\q1 I tere isi m mmanụ\f + \fr 23:5 \ft Mmanụ a na-ete nʼisi na-esi isi ụtọ, ọ bụ mmanụ a na-ete onye a kporo oriri iji kwanyere ya ugwu. \xt Luk 7:46\xt*\ft Ndị ọzụzụ atụrụ na-ejikwa ya achụ ụmụ ahụhụ na ndanda na-achọ ịrịbanye atụrụ ndị ha na-azụ nʼimi.\f*
\q2 iko m na-ejubiga oke.
\q1 
\v 6 Nʼezie, ịdị mma na ebere ga-agbaso m
\q2 ogologo ụbọchị niile nke ndụ m,
\q1 m ga-ebikwa nʼụlọ \nd Onyenwe anyị\nd*
\q2 mgbe niile ebighị ebi.
\c 24
\cl Abụ Ọma 24
\d Abụ Ọma Devid.
\s1 Eze onyenwe ebube
\q1 
\v 1 Ụwa na ihe niile dị nʼime ya bụ nke \nd Onyenwe anyị\nd*;
\q2 ụwa na ndị niile bi nʼime ya.
\q1 
\v 2 Ọ tọrọ ntọala ya nʼime oke osimiri niile,
\q2 o mekwara ka o guzosie ike.
\b
\q1 
\v 3 Onye bụ onye ahụ nwere ike irigo nʼelu ugwu \nd Onyenwe anyị\nd*?
\q2 Onye nwere ike ịbata guzo nʼime ụlọnsọ ya?
\q1 
\v 4 Ọ bụ onye aka ya emeghị ihe ọjọọ, obi ya dịkwa ọcha,
\q2 onye na-adịghị atụkwasị obi na chi arụsị,
\q2 maọbụ ṅụọ iyi aghụghọ.
\b
\q1 
\v 5 Ha ga-anata ngọzị site nʼaka \nd Onyenwe anyị\nd*,
\q2 natakwa mkpepụta site nʼaka Chineke Onye nzọpụta ha.
\q1 
\v 6 Otu a ka ọ ga-adịrị ọgbọ ndị ya,
\q2 bụ ndị na-achọ ihu gị, Chineke nke Jekọb. \qs Sela\qs*
\b
\q1 
\v 7 Welitenụ isi unu, unu ọnụ ụzọ ama,
\q2 meenụ ka isi unu bụrụ ihe e welitere, unu ọnụ ụzọ ama ochie,
\q2 ka eze ebube nwee ike ịbata.
\q1 
\v 8 Onye bụ eze ebube\f + \fr 24:8 \ft \xt Mkp 19:11-16\xt*\f* a?
\q2 Ọ bụ \nd Onyenwe anyị\nd*, onye bụ dimkpa na dike.
\q2 Ọ bụ \nd Onyenwe anyị\nd*, onye bụ dike nʼagha.
\q1 
\v 9 Welitenụ isi unu, unu ọnụ ụzọ ama,
\q2 buliekwanụ ha elu, unu ọnụ ụzọ ama ochie,
\q2 ka Eze ebube nwee ike ịbatakwa.
\q1 
\v 10 Onye bụ eze ebube a?
\q2 Ọ bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile,
\q2 ọ bụ ya bụ Eze ebube! \qs Sela\qs*
\c 25
\cl Abụ Ọma 25
\d Abụ Ọma Devid.
\s1 Ekpere maka odudu na nnapụta
\q1 
\v 1 Ọ bụ na gị \nd Onyenwe anyị\nd*
\q2 ka m tụkwasịrị obi m.
\b
\q1 
\v 2 O Chineke m, ọ bụ gị ka m tụkwasịrị obi m.
\q2 Ekwela ka ihere mee m,
\q2 ekwekwala ka ndị iro m merie m.
\q1 
\v 3 Ihere agaghị eme
\q2 onye ọbụla olileanya ya dị na gị,
\q1 ma ihere ga-eme ha
\q2 bụ ndị niile ịghọ aghụghọ jụrụ ahụ.
\b
\q1 
\v 4 O \nd Onyenwe anyị\nd*, zi m ụzọ gị niile,
\q2 kuzikwaara m ụzọ gị niile.
\q1 
\v 5 Duo m nʼeziokwu gị, kuzikwaara m ihe,
\q2 nʼihi na ị bụ Chineke, onye Nzọpụta m, ụbọchị niile,
\q2 olileanya m dị na gị.
\q1 
\v 6 Cheta, \nd Onyenwe anyị\nd*, oke obi ebere na ịhụnanya gị,
\q2 nʼihi na ha na-adị siterị na mgbe ochie.
\q1 
\v 7 Echetala mmehie m mere nʼokorobịa m,
\q2 ya na nnupu isi m niile.
\q1 Kama site nʼịhụnanya gị cheta m,
\q2 \nd Onyenwe anyị\nd*, nʼihi na onye dị mma ka ị bụ.
\b
\q1 
\v 8 Onye dị mma na onye ezi omume ka \nd Onyenwe anyị\nd* bụ;
\q2 ọ bụ ya mere ọ na-ezi ndị mmehie ụzọ ya.
\q1 
\v 9 Ọ na-edu ndị dị umeala nʼobi nʼụzọ ziri ezi,
\q2 na-ezikwa ha ụzọ nke ya.
\q1 
\v 10 Ụzọ niile nke \nd Onyenwe anyị\nd* jupụtara nʼịhụnanya na ikwesi ntụkwasị obi,
\q2 nye ndị niile na-edebe iwu ọgbụgba ndụ ya.
\q1 
\v 11 Nʼihi aha gị, O \nd Onyenwe anyị\nd*,
\q2 gbaghara m ajọ omume m nʼagbanyeghị na ha dị ukwuu.
\b
\q1 
\v 12 Olee mmadụ ahụ nke na-atụ egwu \nd Onyenwe anyị\nd*?
\q2 O ga-ezi ya ihe nʼụzọ ahụ a họpụtaara ya.
\q1 
\v 13 Ọ ga-ebi ogologo ụbọchị nke ndụ ya nʼime ịba ụba,
\q2 ndị agbụrụ ha ga-eketa ala ahụ.
\q1 
\v 14 \nd Onyenwe anyị\nd* na-eme ka ndị ahụ na-atụ egwu ya mara
\q2 ọgbụgba ndụ ya na izu nzuzo ya.
\q1 
\v 15 Anya m abụọ na-elegide \nd Onyenwe anyị\nd* mgbe niile;
\q2 nʼihi na ọ bụ naanị ya ga-eme ka ụkwụ m abụọ site nʼọnya pụta.
\b
\q1 
\v 16 Chee m ihu ma gosi m ebere gị,
\q2 nʼihi na abụ m onye nọ na nsogbu, naanị m nọkwa.
\q1 
\v 17 Ihe mgbu nke obi m abaala ụba,
\q2 napụta m site nʼobi mwute.
\q1 
\v 18 Lekwasị nsogbu m na ihe mgbu m anya.
\q2 Biko, gbaghara m mmehie m niile.
\q1 
\v 19 Lee ka ndị iro m si mụbaa,
\q2 ha ji oke iwe kpọọ m asị.
\b
\q1 
\v 20 Chebe ndụ m ma gbapụta m;
\q2 ekwela ka m bụrụ onye ihere ga-eme,
\q2 nʼihi na nʼime gị ka m gbabara izere ndụ
\q1 
\v 21 Kwere ka ezi omume na izuoke bụrụ ihe ga-agba m gburugburu,
\q2 nʼihi na olileanya m dị nʼime gị.
\b
\q1 
\v 22 O Chineke, Gbapụtakwa Izrel,
\q2 site na nsogbu ya niile.
\c 26
\cl Abụ Ọma 26
\d Abụ Ọma Devid.
\s1 Ekpere nke ezi mmadụ
\q1 
\v 1 \nd Onyenwe anyị\nd*, biko kpepụta m,
\q2 nʼihi na ebiela m ndụ zuruoke;\f + \fr 26:1 \ft \xt 2Ez 20:2; Ilu 20:7\xt*\f*
\q1 atụkwasịrị m \nd Onyenwe anyị\nd* obi,
\q2 na-eleghị anya nʼazụ.
\q1 
\v 2 Tulee m, O \nd Onyenwe anyị\nd*, ma nwakwaa m,
\q2 nyochaa obi m na echiche m.
\q1 
\v 3 Nʼihi na ejirila m ịhụnanya gị mere ihe nlere anya nye onwe m.
\q2 Ana m ejegharịkwa nʼime eziokwu gị.
\b
\q1 
\v 4 Mụ na ndị na-aghọ aghụghọ adịghị enwe mmekọ ọbụla.
\q2 Otu a kwa, nnwekọ ọbụla adịghịkwa nʼetiti mụ na ndị ihu abụọ.
\q1 
\v 5 Akpọrọ m otu ndị na-emebi iwu asị.
\q2 Mụ na ndị ajọ omume agaghị anọkọkwa.
\q1 
\v 6 Ana m asacha aka\f + \fr 26:6 \ft Ọ bụrụ na mmadụ asacha maọbụ kwọọ aka ya nʼihu ọha, ọ na-apụta ngọpụ site nʼihe na-ezighị ezi, maọbụ onye dị otu a na-asị, ikpe amaghị m. \xt Abụ 73:13\xt*\f* m abụọ nʼọnọdụ emeghị ihe ọjọọ,
\q2 na-eje ozi nʼebe ịchụ aja gị ife gị ofufe, o \nd Onyenwe anyị\nd*.
\q1 
\v 7 Ana m abụkwa abụ ekele,
\q2 jiri iti mkpu na-ekwusa otuto gị, na ọrụ ebube gị niile.
\b
\q1 
\v 8 O \nd Onyenwe anyị\nd*, ahụrụ m ụlọ obibi gị nʼanya,
\q2 ụlọ ahụ ebe ebube gị na-adịgide nʼime ya.
\q1 
\v 9 Ebibikọtala mụ na ndị mmehie,
\q2 ewezugakọtala ndụ m na nke ndị na-awụfu ọbara,
\q1 
\v 10 ndị aka ha jupụtara nʼatụmatụ ọjọọ,
\q2 aka nri ha jupụtakwara na ngarị.
\q1 
\v 11 Ma mụ onwe m na-ebi ndụ zuruoke;
\q2 gbapụta m ma meere m ebere.
\b
\q1 
\v 12 Ụkwụ m na-eguzo nʼala dị larịị;
\q2 aga m eto \nd Onyenwe anyị\nd* nʼetiti ọha mmadụ.
\c 27
\cl Abụ Ọma 27
\d Abụ Ọma Devid.
\s1 Abụ nke iguzosi ike
\q1 
\v 1 \nd Onyenwe anyị\nd* bụ ìhè\f + \fr 27:1 \ft \xt Aịz 60:19-20; Mai 7:8\xt*\f* m na nzọpụta m,
\q2 onye ka m ga-atụ egwu ya?
\q1 \nd Onyenwe anyị\nd* bụ ebe siri ike nke ndụ m,
\q2 ọ bụkwa onye ka m ga-atụ egwu?
\b
\q1 
\v 2 Mgbe ndị na-eme ihe ọjọọ busoro m agha
\q2 ka ha ripịa anụ ahụ m,
\q1 ọ bụ ndị iro m na ndị kpọrọ m asị,
\q2 bụ ndị ga-asọ ngọngọ ma dakwaa.
\q1 
\v 3 Ọ bụrụ na usuu ndị agha agbaa m gburugburu,
\q2 obi m agaghị atụ ụjọ ọbụla;
\q1 ọ bụladị na agha adaa imegide m,
\q2 nʼoge ahụ, ka m ga-enwe ntụkwasị obi.
\b
\q1 
\v 4 Naanị otu ihe ka m rịọrọ nʼaka \nd Onyenwe anyị\nd*,
\q2 nke ahụ bụkwa ihe m na-achọsi ike;
\q1 ka m biri nʼụlọ \nd Onyenwe anyị\nd*
\q2 ụbọchị niile nke ndụ m,
\q1 na ka m lekwasị ịma mma \nd Onyenwe anyị\nd*,
\q2 na ka m chọọ ya nʼime ụlọnsọ ukwuu ya.
\q1 
\v 5 Nʼihi na nʼụbọchị nsogbu,
\q2 ọ ga-echebe m nʼime ebe obibi ya;
\q1 ọ ga-ezo m nʼime ụlọ ikwu ya;
\q2 ma bulie m elu, debe m nʼelu oke nkume.
\b
\q1 
\v 6 Mgbe ahụ, a ga-eweli isi m elu
\q2 karịa ndị iro m gbara m gburugburu;
\q1 aga m eji iti mkpu ọṅụ, chụọ aja nʼụlọ ikwu ya;
\q2 aga m abụ abụ, kụọ egwu nye \nd Onyenwe anyị\nd*.
\b
\q1 
\v 7 Gee ntị mgbe m na-akpọku gị \nd Onyenwe anyị\nd*.
\q2 Meere m ebere, zaa m.
\q1 
\v 8 Obi m na-ekwu banyere gị, “Chọọ ihu ya!”
\q2 Ihu gị, \nd Onyenwe anyị\nd*, ka m ga-achọ.
\q1 
\v 9 Ezonarịla m ihu gị,
\q2 agbakụtala ohu gị azụ nʼiwe;
\q2 nʼihi na ị bụrịị onye inyeaka m.
\q1 O Chineke, Onye nzọpụta m,
\q2 ahapụkwala m.
\q1 
\v 10 Ọ bụrụrị na nne na nna m ahapụ m,
\q2 \nd Onyenwe anyị\nd* ga-anabata m.
\q1 
\v 11 Zi m ụzọ gị, O \nd Onyenwe anyị\nd*;
\q2 duo m nʼụzọ kwesiri
\q2 nʼihi ndị na-akpagbu m.
\q1 
\v 12 Ararala m nyefee nʼaka ndị kpọrọ m asị nʼihi ọchịchọ ha,
\q2 ọtụtụ ndị ama ụgha ebiliela imegide m,
\q2 ha na-ekupụ ihe ike dịka ume.
\b
\q1 
\v 13 Olileanya m bụ nke a:
\q2 Aga m ahụ ịdị mma \nd Onyenwe anyị\nd*
\q2 nʼala ndị dị ndụ.
\q1 
\v 14 Chere \nd Onyenwe anyị\nd*;
\q2 dịrị ike, nwekwaa ume,
\q2 ma chere \nd Onyenwe anyị\nd*.
\c 28
\cl Abụ Ọma 28
\d Abụ Ọma Devid.
\s1 Ekpere maka enyemaka na-ekele
\q1 
\v 1 Gị \nd Onyenwe anyị\nd* ka m na-akpọku;
\q2 gị bụ Oke nkume m,
\q2 agbala m nkịtị.
\q1 Ọ bụrụ na ị jụ ịza m,
\q2 aga m eyi otu nʼime ndị ahụ na-arịda nʼolulu.
\q1 
\v 2 Nụrụ arịrịọ m maka ebere
\q2 dịka m na-akpọku gị maka enyemaka,
\q1 mgbe m chịlịri aka m abụọ elu
\q2 nʼEbe gị Kachasị Nsọ.
\b
\q1 
\v 3 Adọkpụrụla m tinyere ndị ajọ mmadụ,
\q2 tinyekwara ndị na-eme ajọ ihe,
\q1 ndị ji ire ụtọ agwa ndị agbataobi ha okwu udo,
\q2 ma ha bu iro nʼime obi ha.
\q1 
\v 4 Kwụghachi ha dịka ọrụ ọjọọ ha
\q2 na omume ha kwesiri;
\q1 kwụghachi ha maka ihe aka ha mere,
\q2 ka ihe ga-adakwasị ha bụrụ ihe ha kwesiri iketa.
\b
\q1 
\v 5 Nʼihi na ha adịghị aghọta ọrụ niile nke \nd Onyenwe anyị\nd*,
\q2 ha adịghịkwa aghọta ihe aka ya abụọ rụrụ,
\q1 ọ ga-akwada ha nʼala,
\q2 ọ gaghị ewulikwa ha elu ọzọ.
\b
\q1 
\v 6 Toonu \nd Onyenwe anyị\nd*,
\q2 nʼihi na o gere ntị nʼarịrịọ m rịọrọ ya ka o meere m ebere.
\q1 
\v 7 \nd Onyenwe anyị\nd* bụ ike m na ọta m;
\q2 ana m atụkwasị ya obi m, si otu a bụrụ onye a na-enyere aka.
\q1 Obi m na-awuli elu nʼihi ọṅụ,
\q2 aga m ejikwa abụ m na-eto ya.
\b
\q1 
\v 8 \nd Onyenwe anyị\nd* bụ ike nke ndị ya,
\q2 ebe mgbaba e wusiri ike nke nzọpụta dịịrị onye ya etere mmanụ.
\q1 
\v 9 Zọpụta ndị gị, gọzikwaa ihe nketa gị;\f + \fr 28:9 \ft Maọbụ, \fqa ndị nke gị\f*
\q2 buuru ha onye ọzụzụ atụrụ, na-ekukwa ha ruo mgbe ebighị ebi.
\c 29
\cl Abụ Ọma 29
\d Abụ Ọma Devid.
\s1 Olu Onyenwe anyị
\q1 
\v 1 Toonu \nd Onyenwe anyị\nd*, unu ndị bi nʼeluigwe,
\q2 nyenụ \nd Onyenwe anyị\nd* nsọpụrụ nʼihi ebube na ike ya.
\q1 
\v 2 Nyenụ \nd Onyenwe anyị\nd* nsọpụrụ kwesiri aha ya;
\q2 kpọọ isiala nye \nd Onyenwe anyị\nd* nʼebube nke ịdị nsọ ya.
\b
\q1 
\v 3 Olu \nd Onyenwe anyị\nd* na-ada nʼelu osimiri;
\q2 olu Chineke dị ebube na-ada ike ike,
\q2 olu \nd Onyenwe anyị\nd* na-ada dịka egbe eluigwe\f + \fr 29:3 \ft \xt Job 37:4-5; Abụ 18:13\xt*\f* nʼelu oke osimiri.
\q1 
\v 4 Olu \nd Onyenwe anyị\nd* dị ike,
\q2 olu \nd Onyenwe anyị\nd* jupụtakwara nʼebube.
\q1 
\v 5 Olu \nd Onyenwe anyị\nd* na-etiwa osisi ukwu sida;
\q2 \nd Onyenwe anyị\nd* na-etiwasị osisi ukwu sida nke Lebanọn.
\q1 
\v 6 Ọ na-eme ka Lebanọn wulie elu dịka nwa ehi,
\q2 ọ na-eme ka Siriọn\f + \fr 29:6 \ft Nke a bụ aha ndị Fonikisi bi na mpaghara ugwu Hemon na-akpọ ugwu ahụ. Hemon dị nʼoke ala nkwa ahụ nʼebe ugwu. \xt Dit 3:9; Abụ 42:6\xt*\f* wulie elu dịka nwa atụ.
\q1 
\v 7 Olu \nd Onyenwe anyị\nd* na-agba dịka egbe eluigwe
\q2 mgbe amụma na-egbu.
\q1 
\v 8 Olu \nd Onyenwe anyị\nd* na-eme ka ọzara maa jijiji;
\q2 \nd Onyenwe anyị\nd* na-eme ka ọzara Kadesh maa jijiji.
\q1 
\v 9 Olu \nd Onyenwe anyị\nd* na-eme ka osisi ook gbagọọ\f + \fr 29:9 \ft Ime na-eme nne ele\f*
\q2 na-agbuchapụkwa akwụkwọ niile nke oke ọhịa.
\q1 Nʼime ụlọnsọ ukwuu ya mmadụ niile na-eti, “Ebube!”
\b
\q1 
\v 10 \nd Onyenwe anyị\nd* nọ nʼocheeze ya nʼelu uju mmiri;
\q2 \nd Onyenwe anyị\nd* na-achị dịka eze ruo mgbe ebighị ebi.
\q1 
\v 11 \nd Onyenwe anyị\nd* na-enye ndị ya ike,
\q2 ọ ga-ejikwa udo gọzie ndị ya.
\c 30
\cl Abụ Ọma 30
\d Abụ Ọma. Abụ nke ido obieze Devid nsọ.
\s1 Abụ mgbapụta
\q1 
\v 1 Aga m eto gị, O \nd Onyenwe anyị\nd*,
\q2 nʼihi na i sitere nʼebe dị omimi dọpụta m.
\q2 I kweghị ka ndị iro m chịa m ọchị.
\q1 
\v 2 O \nd Onyenwe anyị\nd* Chineke m, akpọkuru m gị, ka i nyere m aka,
\q2 ị gwọkwara m.
\q1 
\v 3 O \nd Onyenwe anyị\nd*, i si nʼala ili kpọpụta m,
\q2 i mere ka m dịrị ndụ.
\b
\q1 
\v 4 Bụkuonụ \nd Onyenwe anyị\nd* abụ, unu ndị nsọ ya,
\q2 toonu aha nsọ ya.
\q1 
\v 5 Iwe ya adịghị adịgide tee anya,
\q2 ma ime amara ya na-adị ruo ebighị ebi!
\q1 Ịkwa akwa nwere ike dịrị ogologo abalị niile,
\q2 ma iti mkpu ọṅụ ga-adị nʼụtụtụ.
\b
\q1 
\v 6 Mgbe m nọ nʼudo, asịrị m,
\q2 “Ihe ọbụla apụghị ịnapụ m udo m.”
\q1 
\v 7 O \nd Onyenwe anyị\nd*, mgbe i gosiri m ihuọma,
\q2 i mere ka m kwụrụ chịm dịka ugwu;
\q1 ma mgbe i zoro ihu gị site nʼebe m nọ,
\q2 adara m mba.
\b
\q1 
\v 8 Ọ bụ gị, \nd Onyenwe anyị\nd*, ka m kpọkuru;
\q2 ọ bụkwa onyenwe anyị ka m rịọrọ arịrịọ amara sị,
\q1 
\v 9 “Uru gịnị dị ma m laa nʼiyi?
\q2 Uru gịnị dị ma m rịda nʼili?
\q1 Uzuzu aja ọ ga-enye gị otuto?
\q2 Ọ ga-ekwusa banyere ikwesi ntụkwasị obi gị?”
\q1 
\v 10 O \nd Onyenwe anyị\nd*, gee m ntị ma meere m ebere;
\q2 O \nd Onyenwe anyị\nd*, bụụrụ m onye inyeaka.
\b
\q1 
\v 11 I meela ka iti mkpu akwa m ghọọ ite egwu;
\q2 ị napụrụ m akwa mkpe m, ma yinye m ọṅụ dịka akwa mmemme.
\q1 
\v 12 I mere nke a ka obi m bụọ maka otuto gị, ghara ịnọ nwayọọ.
\q2 O \nd Onyenwe anyị\nd* Chineke m, aga m eto gị ruo mgbe ebighị ebi.
\c 31
\cl Abụ Ọma 31
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ Ọma Devid.
\s1 Oge m dị gị nʼaka
\q1 
\v 1 \nd Onyenwe anyị\nd*, nʼime gị, ka m gbabara izere ndụ;
\q2 ekwela ka ihere\f + \fr 31:1 \fq Ihere \ft Maọbụ, \fqa ihe na-eweta ọnụma \ft ma ọ bụkwanụ, \fqa ọnọdụ ịkwa emo\f* mee m;
\q2 site nʼezi omume gị gbapụta m.
\q1 
\v 2 Tọọ ntị gị nʼala nụrụ olu m,
\q2 bịa ngwangwa gbapụta m;
\q1 ghọọrọ m oke nkume nke ebe mgbaba,
\q2 ebe mgbaba e wusiri ike maka nzọpụta m.
\q1 
\v 3 Ebe ị bụ oke nkume m na ebe mgbaba m e wusiri ike,
\q2 nʼihi aha gị, duo m ma na-edukwa m.
\q1 
\v 4 Napụta m site nʼọnya nke e zobere nʼihi m,
\q2 nʼihi na ọ bụ naanị gị bụ ebe mgbaba m siri ike.
\q1 
\v 5 Nʼaka gị ka m na-enyefe mmụọ m;
\q2 gbapụta m, o \nd Onyenwe anyị\nd*, Chineke, onye eziokwu.
\b
\q1 
\v 6 Akpọrọ m ha asị bụ ndị niile na-efe chi mba ọzọ ndị na-abaghị uru;
\q2 ana m atụkwasị \nd Onyenwe anyị\nd* obi m.
\q1 
\v 7 Aga m enwe obi ụtọ ma ṅụrịkwaa ọṅụ nʼime ịhụnanya gị,
\q2 nʼihi na ị hụrụ nsogbu m
\q2 marakwa ihe mgbu nke mmụọ m.
\q1 
\v 8 I wereghị m nyefee nʼaka ndị iro m,
\q2 kama i nyela m ohere ijegharị ebe ọbụla m chọrọ.
\b
\q1 
\v 9 O \nd Onyenwe anyị\nd*, meere m amara nʼọnọdụ ihe mgbu m.
\q2 Anya m abụọ na-acha uhie uhie nʼihi ịkwa akwa;
\q2 ike adịghịkwa m.
\q1 
\v 10 Iru ụjụ eriela m ahụ;
\q2 ịkwa akwa m ewepụla ihe nʼafọ m;
\q1 ihe mgbu m mere ka ike gwụsịa m
\q2 ruo na ume adịghịkwa nʼọkpụkpụ m.
\q1 
\v 11 Nʼihi ndị iro m niile;
\q2 ndị agbataobi m na-elelị m anya.
\q1 Ndị enyi m na-atụ ụjọ ịbịakwute m,
\q2 ndị hụrụ m nʼokporoụzọ na-esite ụzọ ọzọ gafee.
\q1 
\v 12 Aghọọla m onye e chefuru echefu, dị ka a ga-asị na m nwụrụ anwụ.
\q2 A pụrụ iji ite kụwara akwụwa tụnyere m.
\q1 
\v 13 Anụla m nkwulu ha megide m;
\q2 oke egwu dị nʼakụkụ niile;
\q1 ha na-agba izu megide m,
\q2 na-agba izu nzuzo iji napụ m ndụ m.
\b
\q1 
\v 14 Ma ana m atụkwasị gị obi \nd Onyenwe anyị\nd*.
\q2 Ekwuola m ya sị, “Naanị gị bụ Chineke m.”
\q1 
\v 15 Oge m niile dị gị nʼaka.
\q2 Napụta m nʼaka ndị iro m
\q2 na nʼaka ndị ahụ na-adịghị ezu ike ịchụ m ọsọ.
\q1 
\v 16 Mee ka amara gị mụkwasị ohu gị dịka anyanwụ;
\q2 zọpụta m nʼihi ịhụnanya gị na-enweghị ọgwụgwụ.
\q1 
\v 17 O \nd Onyenwe anyị\nd*, ekwela ka ihere mee m,
\q2 nʼihi na akpọkuola m gị;
\q1 kama mee ka ihere mee ndị na-eme ihe ọjọọ,
\q2 ka ha tọgbọrọ nʼala mmụọ debe ọnụ ha duu.
\q1 
\v 18 Ka ọnụ ahụ ha ji ekwu okwu ụgha mechie kpamkpam;
\q2 nʼihi na ọ bụ site na mpako na nlelị
\q2 ka ha ji na-ekwu okwu megide ndị ezi omume.
\b
\q1 
\v 19 Lee ka ịdị mma gị si baa ụba,
\q2 nke i na-edebere ndị niile na-atụ egwu gị,
\q1 nke ị na-enye ndị na-agbaba nʼime gị,
\q2 nʼihu ọha mmadụ.
\q1 
\v 20 I na-ezobe ha nʼebe nzuzo gị
\q2 pụọ nʼizu nzuzo nke ụmụ mmadụ;
\q1 ị na-echebe ha nʼime ebe obibi gị;
\q2 ka ha pụọ nʼebubo nke ire dị iche iche.
\b
\q1 
\v 21 Otuto dịrị \nd Onyenwe anyị\nd*
\q2 nʼihi na o gosila m ịhụnanya ya dị ukwuu
\q2 mgbe m nọ nʼobodo ndị iro gbara gburugburu.
\q1 
\v 22 Akụjara m, kwuo okwu nʼụjọ sị,
\q2 “Ewezugala m site nʼihu ya!”
\q1 Ma ị nụrụ arịrịọ m maka ebere
\q2 mgbe m kpọkuru gị ka i nyere m aka.
\b
\q1 
\v 23 Hụnụ \nd Onyenwe anyị\nd* nʼanya, unu ndị ya niile kwesiri ntụkwasị obi,
\q2 nʼihi na \nd Onyenwe anyị\nd* na-anapụta ndị niile kwesiri ntụkwasị obi nye ya,
\q2 ma ọ na-akwụghachi ndị mpako oke zuru ezu.
\q1 
\v 24 Ya mere, dịrịnụ ike, ka obi siekwa unu ike,
\q2 unu niile ndị olileanya ha dị nʼime \nd Onyenwe anyị\nd*.
\c 32
\cl Abụ Ọma 32
\d Abụ Ọma Devid. Abụ \tl Maskil.\tl*
\s1 Nkwupụta na mgbaghara mmehie
\q1 
\v 1 Onye a gọziri agọzi ka mmadụ ahụ bụ,
\q2 onye a gbaghaara ajọ omume ya niile,
\q2 onye e kpuchikwaara mmehie ya niile.
\q1 
\v 2 Ngọzị na-adịrị nwoke ahụ,
\q2 onye \nd Onyenwe anyị\nd* na-adịghị agụnyere mmehie ya,
\q2 onye ahụ nke aghụghọ ọbụla na-adịghịkwa nʼime mmụọ ya.
\b
\q1 
\v 3 Mgbe m gbachiri nkịtị,
\q2 ọkpụkpụ m rere ure
\q2 site nʼịsụ ude m ogologo ụbọchị niile.
\q1 
\v 4 Ehihie niile na abalị niile,
\q2 ị tara m ahụhụ,
\q1 ume dị m nʼobi gwụchara,
\q2 dịka mgbe okpomọkụ nke ọkọchị.\f + \fr 32:4 \ft Mgbe anwụ na-amịkọrọ mmiri dị nʼala\f*\qs Sela\qs*
\b
\q1 
\v 5 Mgbe ahụ, ekwupụtara m mmehie m niile nʼihu gị,
\q2 kwụsịkwa izo ha ezo.
\q1 Agwara m onwe m okwu sị,
\q2 “Aga m ekwupụta mmehie m niile nʼihu \nd Onyenwe anyị\nd*.”
\q1 Ị gbaghakwaara m
\q2 ikpe ọmụma nke mmehie m niile. \qs Sela\qs*
\b
\q1 
\v 6 Ya mere, ka ndị niile bụ ndị ezi omume kpọkuo gị nʼekpere
\q2 mgbe e nwere ike ịchọta gị;
\q1 nʼụzọ dị otu a, ọ bụrụ na uju mmiri abịa,
\q2 ọ gaghị erute ha.
\q1 
\v 7 Gị onwe gị bụụrụ m ebe nzuzo;
\q2 Ị ga-echebekwa m ka nsogbu ọbụla hapụ irute m nso.
\q2 Ọ bụkwa abụ nzọpụta ka i ji gbaa m gburugburu. \qs Sela\qs*
\b
\q1 
\v 8 Aga m eme ka ị nwee uche, zikwa gị ụzọ i kwesiri ịgbaso;
\q2 Aga m adụ gị ọdụ, anya m ga-adịkwasịkwa nʼahụ gị.
\q1 
\v 9 Adịkwala ka ịnyịnya maọbụ ịnyịnya ibu
\q2 nke na-enweghị akọnuche,
\q1 nke a na-aghaghị iji mkpụmkpụ igwe na eriri kechie ọnụ ya, ijide ya,
\q2 ma emeghị otu a, ọ gaghị abịakwute gị.
\q1 
\v 10 Ọtụtụ ihe mgbu na-abịakwasị ndị na-eme ihe ọjọọ,
\q2 ma ịhụnanya \nd Onyenwe anyị\nd* nke na-enweghị ọgwụgwụ,
\q2 na-agba onye ahụ tụkwasịrị ya obi gburugburu.
\b
\q1 
\v 11 Ṅụrianụ ọṅụ nʼime \nd Onyenwe anyị\nd*, nweekwanụ obi ụtọ, unu ndị ezi omume;
\q2 bụọ abụ, unu ndị obi ha ziri ezi.
\c 33
\cl Abụ Ọma 33
\s1 Ịdị mma na ịdị ukwuu Onyenwe anyị
\q1 
\v 1 Tienụ mkpu ọṅụ nye \nd Onyenwe anyị\nd*, unu ndị ezi omume;
\q2 nʼihi na ọ bụ ihe ziri ezi ka ndị obi ha ziri ezi too ya.
\q1 
\v 2 Werenụ ụbọ akwara too \nd Onyenwe anyị\nd*;
\q2 werenụ une nke nwere akwara iri kpọọrọ ya egwu.
\q1 
\v 3 Bụkuonụ ya abụ ọhụrụ;
\q2 were ǹka kpọọ ụbọ akwara ma tiekwa mkpu ọṅụ.
\b
\q1 
\v 4 Nʼihi na okwu \nd Onyenwe anyị\nd* niile ziri ezi bụrụkwa eziokwu;
\q2 o kwesiri ntụkwasị obi nʼọrụ ya niile.
\q1 
\v 5 \nd Onyenwe anyị\nd* na-ahụ ezi omume na ikpe ziri ezi nʼanya;
\q2 ụwa niile jupụtara nʼịhụnanya ya nke na-enweghị ọgwụgwụ.
\b
\q1 
\v 6 Ọ bụ site nʼokwu ọnụ \nd Onyenwe anyị\nd* ka e ji kee eluigwe niile,
\q2 jirikwa nkuume nke ọnụ ya mee anwụ, na ọnwa na kpakpando niile.
\q1 
\v 7 Ọ bụ ya kekwara osimiri niile chịkọta ha nʼotu ebe,
\q2 kpaa oke ebe ha ga-anọ dịka ụlọakụ dị ukwuu.
\q1 
\v 8 Ka ụwa niile tụọ \nd Onyenwe anyị\nd* egwu;
\q2 ka mmadụ niile bi nʼụwa sọpụrụ ya.
\q1 
\v 9 Nʼihi na o kwuru okwu, okwu ahụ mezukwara;
\q2 o nyere iwu, iwu ahụ guzokwara chịm.
\b
\q1 
\v 10 \nd Onyenwe anyị\nd* na-emebi atụmatụ mba niile;
\q2 ọ na-emebi ebumnobi ụmụ mmadụ.
\q1 
\v 11 Atụmatụ \nd Onyenwe anyị\nd* na-adịgide ruo mgbe ebighị ebi,
\q2 ebumnobi ya ruo ọgbọ niile.
\b
\q1 
\v 12 Mba a gọziri agọzi ka mba ahụ bụ, bụ ndị Chineke bụ \nd Onyenwe anyị\nd* ha;
\q2 bụ ndị ọ họpụtara ka ha bụrụ ihe nketa ya.
\q1 
\v 13 \nd Onyenwe anyị\nd* si nʼeluigwe na-ele ndị mmadụ bi nʼụwa anya.
\q2 Ọ na-ahụzu ụmụ mmadụ niile anya.
\q1 
\v 14 O sitere nʼebe obibi ya na-ele
\q2 onye ọbụla bi nʼelu ụwa anya.
\q1 
\v 15 Ebe ọ bụ ya kpụrụ obi mmadụ niile nʼotu na otu;
\q2 ọ na-ahụzu, na-amazukwa ihe niile ha na-eme.
\b
\q1 
\v 16 Ọnụọgụgụ ndị agha eze apụghị ịzọpụta ya;
\q2 o nweghị onye agha ọbụla na-azọpụta onwe ya, site nʼịdị ukwuu nke ike ya.
\q1 
\v 17 Ịnyịnya agha ezukwaghị iwetara ndị na-agba ha mmeri nʼagha.
\q2 Ọ bụ ezie na ịnyịnya dị ike, ma ha apụghị ịzọpụta ndị nwe ha.
\q1 
\v 18 Ma \nd Onyenwe anyị\nd* ji anya ya na-eche ndị niile na-atụ ya egwu nche,
\q2 ya bụ ndị niile na-atụkwasị obi ha nʼịhụnanya ya, nke na-adịghị agwụ agwụ.
\q1 
\v 19 Ọ ga-anapụta ha site nʼaka ọnwụ.
\q2 Ọ ga-echebekwa ha ọ bụladị nʼoge ụnwụ.
\b
\q1 
\v 20 Anyị ji olileanya eche \nd Onyenwe anyị\nd*;
\q2 ọ bụ ya bụ inyeaka anyị na ọta anyị.
\q1 
\v 21 Obi anyị na-aṅụrị ọṅụ nʼime ya;
\q2 nʼihi na anyị tụkwasịrị aha nsọ ya obi.
\q1 
\v 22 O \nd Onyenwe anyị\nd*, ka ịhụnanya gị na-adịgidere anyị,
\q2 dịka olileanya anyị dị na gị.
\c 34
\cl Abụ Ọma 34
\d Abụ Ọma Devid. Mgbe ọ gbanwere omume ya mee ka onye na-ayị ara nʼihu Abimelek, onye nke chụpụrụ ya, ya a pụọ.
\s1 Chineke dị mma
\q1 
\v 1 Aga m eto \nd Onyenwe anyị\nd* mgbe niile.
\q2 Mgbe niile ka otuto ya ga-adị nʼọnụ m.
\q1 
\v 2 Mkpụrụobi m ga-anya isi na \nd Onyenwe anyị\nd*;
\q2 ka ndị niile a na-akpagbu gee ntị ṅụrịa ọṅụ.
\q1 
\v 3 Soro m too \nd Onyenwe anyị\nd*;
\q2 ka anyị bulie aha ya elu.
\b
\q1 
\v 4 Nʼihi na etikuru m \nd Onyenwe anyị\nd* mkpu akwa, ọ zakwara m,
\q2 napụta m site nʼaka ịtụ ụjọ m niile.
\q1 
\v 5 Ihu ndị na-elekwasị ya anya na-enwu dịka ihe;
\q2 ihere adịghị eme ha.
\q1 
\v 6 Onye ogbenye a kpọkuru \nd Onyenwe anyị\nd*, ọ zakwara ya;
\q2 ọ zọpụtara ya site na nsogbu ya niile.
\q1 
\v 7 Mmụọ ozi \nd Onyenwe anyị\nd* na-agba ndị niile na-atụ egwu ya gburugburu
\q2 na-anapụtakwa ha.
\b
\q1 
\v 8 Jiri aka gị tulee ma hụkwa na \nd Onyenwe anyị\nd* dị mma;
\q2 onye a gọziri agọzi ka onye ahụ bụ, onye nke na-agbaba nʼime ya.
\q1 
\v 9 Tụọnụ egwu \nd Onyenwe anyị\nd*, unu ndị nsọ ya,
\q2 nʼihi na ọ dịghị ihe na-akọ ndị niile na-atụ egwu ya.
\q1 
\v 10 Agụụ nwere ike ịgụ ụmụ ọdụm, ike pụkwara ịgwụ ha,
\q2 ma ihe ọbụla bụ ihe ọma agaghị akọ ndị niile na-achọ \nd Onyenwe anyị\nd*.
\q1 
\v 11 Ụmụ m, bịanụ gee m ntị;
\q2 aga m ezi unu ihe ịtụ egwu \nd Onyenwe anyị\nd* bụ.
\q1 
\v 12 Onye ọbụla nʼime unu hụrụ ndụ nʼanya,
\q2 ma nwee ọchịchọ ihu ọtụtụ ụbọchị ndị dị mma,
\q1 
\v 13 chezie ire gị ka ọ ghara ikwu ihe ọjọọ,
\q2 chezikwaa egbugbere ọnụ gị ka ọ gharakwa ịgha ụgha.
\q1 
\v 14 Site nʼihe ọjọọ wezuga onwe gị ma mee ezi ihe,
\q2 chọọ udo ma gbasookwa ya.
\b
\q1 
\v 15 Anya \nd Onyenwe anyị\nd* dị nʼahụ ndị ezi omume,
\q2 ntị ya gheekwa oghe nye mkpu akwa ha;
\q1 
\v 16 ma ihu \nd Onyenwe anyị\nd* na-emegide ndị na-eme ihe ọjọọ,
\q2 ime ka a hapụ ichetakwa ihe banyere ha nʼụwa.
\b
\q1 
\v 17 \nd Onyenwe anyị\nd* na-anụ olu ndị ezi omume, mgbe ha na-akpọku ya ka o nyere ha aka;
\q2 ọ na-azọpụtakwa ha site na nsogbu ha niile.
\q1 
\v 18 \nd Onyenwe anyị\nd* na-anọ ndị niile obi ha tiwara etiwa nso,
\q2 ọ na-anapụta ndị niile olileanya ha gwụrụ.
\b
\q1 
\v 19 Nsogbu na-adakwasị ndị ezi omume na-adị ukwuu,
\q2 ma \nd Onyenwe anyị\nd* na-anapụta ha site na nsogbu ndị ahụ niile.
\q1 
\v 20 Ọ na-anapụtakwa ha kpamkpam.
\q2 Ọ gaghị ekwe ka ọ bụladị otu ọkpụkpụ dị ha nʼahụ gbajie.
\b
\q1 
\v 21 Ihe ọjọọ ga-eme ka onye ajọ omume nwụọ;
\q2 ndị na-akpọ onye ezi omume asị ka a ga-ama ikpe ọnwụ.
\q1 
\v 22 \nd Onyenwe anyị\nd* na-agbapụta ndị ohu ya;
\q2 ọ dịghị onye ọbụla nke na-agbaba nʼime ya a ga-ama ikpe ọnwụ.
\c 35
\cl Abụ Ọma 35
\d Abụ Ọma Devid.
\s1 Ekpere maka enyemaka
\q1 
\v 1 O \nd Onyenwe anyị\nd*, lụso ha ọgụ bụ ndị na-alụso m ọgụ;
\q2 buso ha agha bụ ndị na-ebuso m agha.
\q1 
\v 2 Yikwasị uwe agha gị, werekwa ọta gị;
\q2 bilie bịa nyere m aka.
\q1 
\v 3 Sepụta ùbe gị na anyụike agha gị;
\q2 bịa zute ndị na-achụ m ọsọ.
\q1 Gwa mkpụrụobi m,
\q2 “Abụ m nzọpụta gị.”
\b
\q1 
\v 4 Mee ka ihere mee
\q2 ndị niile na-agbalịsị ike igbu m.
\q1 Ka ndị na-agba izuzu igbu m bụrụkwa ndị a chụghachiri azụ,
\q2 na ndị ihere mere.
\q1 
\v 5 Ka ha dịka igbugbo ọka mgbe oke ifufe na-efe,
\q2 ka mmụọ ozi \nd Onyenwe anyị\nd* bụrụ onye na-achụfu ha.
\q1 
\v 6 Mee ka ụzọ ha gbaa ọchịchịrị, bụrụkwa ebe na-amị amị;
\q2 ka mmụọ ozi \nd Onyenwe anyị\nd* bụrụ onye na-achụ ha ọsọ.
\b
\q1 
\v 7 Ọ bụ ezie na ọ dịghị ihe ọjọọ ọbụla m mere ha,
\q2 ma ha siere m ọnya, gwukwaara m olulu nʼụzọ m.
\q1 
\v 8 Ka mbibi bịakwasị ha na mberede,
\q2 ka ụgbụ ha zobeere m kee ha;
\q2 ka ha lakwaa nʼiyi site nʼidaba nʼolulu ahụ ha gwuru.
\q1 
\v 9 Mgbe ahụ, mkpụrụobi m ga-aṅụrị ọṅụ na \nd Onyenwe anyị\nd*,
\q2 ọ ga-enwekwa obi ụtọ nʼime nzọpụta ya.
\q1 
\v 10 Ihe niile dị nʼime m ga-eti mkpu sị,
\q2 “O \nd Onyenwe anyị\nd*, ọ bụ onye dịka gị?
\q1 Ị na-agbapụta ndị na-adịghị ike site nʼaka ndị dị ike karịa ha,
\q2 ma na-anapụta ndị ogbenye ndị chọrọ enyemaka site nʼaka ndị na-apụnara ha ihe ha nwere nʼike.”
\b
\q1 
\v 11 Ndị akaebe, ndị kwara obi nʼazụ na-apụkwute m;
\q2 ha na-ebo m ebubo ihe ndị m na-anụbeghị ihe banyere ha na mbụ.
\q1 
\v 12 Ana m emere ha ihe ọma, ma ha na-akwụghachi m ihe ọjọọ.
\q2 Nke a na-ewute mmụọ m ruo nʼọnwụ.
\q1 
\v 13 Mgbe ha na-arịa ọrịa, eyiri m akwa mkpe,
\q2 site na ibu ọnụ weda onwe m nʼala.
\q1 Mgbe ekpere m lọghachikwutere m na-enweghị ọsịsa,
\q2 
\v 14 ejegharịrị m nʼọnọdụ iru ụjụ,
\q2 dịka a ga-asị na ọ bụ nwanne m, maọbụ enyi m,
\q1 jegharịakwa nʼobi ọjọọ dịka a ga-asị
\q2 na ọ bụ nne m na-arịa ọrịa ahụ.
\q1 
\v 15 Ma mgbe m dahiere, ha zukọtara na-aṅụrị ọṅụ;
\q2 mgbe m na-adịghị ele anya, ha biliri imegide m.
\q2 Ha na-ekwulu m na-esepụghị aka.
\q1 
\v 16 Dịka ndị ajọ omume, ha na-akwa m emo nʼiwe,
\q2 na-atakwara m ikikere eze ha.
\b
\q1 
\v 17 O Onyenwe anyị, ọ bụ ruo ole mgbe ka ị ga-anọ na-ele ihe na-eme?
\q2 Gbapụta ndụ m site na mbibi ha niile,
\q2 site nʼaka ụmụ ọdụm ndị a, gbapụta ndụ m dị oke ọnụahịa.
\q1 
\v 18 Aga m enye gị ekele nʼihu ọha mmadụ dị ukwuu,
\q2 nʼetiti ọha kachasị ibe ya dị ukwuu, ka m ga-anọ too gị.
\q1 
\v 19 Ekwekwala ka ndị ahụ bụ ndị iro m,
\q2 mgbe o nweghị ihe m mere ha, chịa m ọchị;
\q1 ekwekwala ka ndị ahụ kpọrọ m asị nʼihi iro,
\q2 mgbe o nweghị ihe m mere ha nwee izuike.
\q1 
\v 20 Nʼihi na ọ bụghị okwu udo ka ha na-ekwu,
\q2 kama ha na-echepụta ebubo ụgha dị iche iche
\q2 megide ndị ahụ na-anọrọ onwe ha jụụ nʼime ala ahụ.
\q1 
\v 21 Nʼiju anya, ha na-ele m anya na-eti mkpu na-asị,
\q2 “Ewoo! Ewoo! Anya anyị abụọ ka anyị ji hụ ya.”
\b
\q1 
\v 22 O \nd Onyenwe anyị\nd*, ị hụla nke a, agbakwala nkịtị;
\q2 anọkwala m nʼebe dị anya, O Onyenwe anyị.
\q1 
\v 23 Teta, bilie bụụrụ m onye mkpepụta m.
\q2 Kpechitere m ọnụ m, Chineke m na onyenwe m.
\q1 
\v 24 O \nd Onyenwe anyị\nd* Chineke m, kpepụta m nʼihi ezi omume gị;
\q2 ekwekwala ka ha chịa m ọchị.
\q1 
\v 25 Ekwekwala ka ha sị, “Ahaa, ọ dị ka anyị tụrụ anya ya!”
\q2 Maọbụ sị, “Anyị eloola ya!”
\b
\q1 
\v 26 Mee ka ihere na ọgbaaghara
\q2 bụrụ nke ndị na-achị m ọchị nʼime mkpagbu m;
\q1 were ihere na nweda nʼala yinye ha dịka uwe,
\q2 bụ ndị niile na-ebuli onwe ha elu imegide m.
\q1 
\v 27 Ka ndị niile mkpepụta m dị mma
\q2 were obi ụtọ tie mkpu ọṅụ;
\q1 ka ha na-asị mgbe niile, “Ka e bulie \nd Onyenwe anyị\nd* elu,
\q2 onye ọdịmma nke ohu ya na-amasị.”
\b
\q1 
\v 28 Ire m ga-ekwu banyere ezi omume gị
\q2 na otuto gị niile ogologo ụbọchị niile.
\c 36
\cl Abụ Ọma 36
\d Abụ Ọma dịrị onyeisi abụ. Abụ Ọma Devid, bụ ohu \nd Onyenwe anyị\nd*.
\s1 Ajọ omume mmadụ na ịdị mma Chineke
\q1 
\v 1 E nwere m ozi dị nʼime obi nke sitere nʼaka Chineke
\q2 banyere ndụ mmehie nke ndị na-eme ajọ ihe:\f + \fr 36:1 \ft Maọbụ, \fqa Ozi si nʼaka Chineke: Mmebi iwu nke ndị ajọ omume bi nʼime obi ha.\f*
\q1 Ọ dịghị ịtụ egwu Chineke
\q2 dị nʼanya ha.
\b
\q1 
\v 2 Nʼihi ha na-agwarịta onwe ha okwu ire ụtọ nʼanya ha onwe ha,
\q2 na o nweghị ụzọ a ga-esi nwe ike ịchọpụta mmehie ha maọbụ kpọọ ya asị.
\q1 
\v 3 Okwu ọnụ ha niile bụ ihe ọjọọ na aghụghọ;
\q2 ha adịghị eji uche eme ihe maọbụ mee ihe dị mma.
\q1 
\v 4 Ọ bụladị mgbe ha nọ nʼelu ihe ndina ha, ha na-eche echiche ajọ ihe;
\q2 ha enyefeela onwe ha nʼaka ndụ ajọ omume,
\q2 ha adịghị ajụkwa ihe na-ezighị ezi.
\b
\q1 
\v 5 O \nd Onyenwe anyị\nd*, ịhụnanya gị na-eru mbara eluigwe,
\q2 ikwesi ntụkwasị obi gị na-erukwa igwe ojii nke eluigwe.
\q1 
\v 6 Ezi omume gị dịka ugwu dị ukwuu,
\q2 ikpe ikpe ziri ezi gị dịka omimi nke oke osimiri.
\q2 O \nd Onyenwe anyị\nd*, ị na-echebe ụmụ mmadụ na anụmanụ.
\q1 
\v 7 Lee ka ịhụnanya gị nke na-adịghị agwụ agwụ si dị oke ọnụahịa, O Chineke!
\q2 Ụmụ mmadụ na-agbaba nʼokpuru ndo nke nku gị abụọ.
\q1 
\v 8 Ha na-eri oriri site nʼịba ụba nke ụlọakụ gị;
\q2 Ị na-enyekwa ha mmiri site nʼiyi nke obi ụtọ gị.
\q1 
\v 9 Nʼihi na mmiri na-enye ndụ dị na gị;
\q2 ọ bụkwa nʼìhè gị ka anyị na-ahụ ìhè.
\b
\q1 
\v 10 Mee ka ịhụnanya gị na-adịgidere ndị maara gị,
\q2 ka ezi omume gị na-adịgidekwara ndị ziri ezi nʼobi.
\q1 
\v 11 Ekwela ka ndị mpako a zọọ m ụkwụ nʼisi,
\q2 ekwekwala ka aka ndị ajọ omume nupu m nʼebe m guzo.
\q1 
\v 12 Lee ka ndị na-eme ajọ ihe si daa nʼala,
\q2 a kwatuola ha nʼala, ha apụghịkwa ibilite ọzọ.
\c 37
\cl Abụ Ọma 37
\d Abụ Ọma Devid.
\s1 Ọgwụgwụ ndụ mmadụ
\q1 
\v 1 Echegbula onwe gị nʼihi ndị na-eme ihe ọjọọ,
\q2 maọbụ kwosa ndị na-eme ihe ọjọọ ekworo;
\q1 
\v 2 nʼihi na mgbe na-adịghị anya, ha ga-akpọnwụ dịka ahịhịa,
\q2 dịka ahịhịa ndụ, ha ga-anwụkwa.
\b
\q1 
\v 3 Tụkwasị \nd Onyenwe anyị\nd* obi meekwa ihe ziri ezi;
\q2 biri nʼala na nchebe, rijuokwa afọ.
\q1 
\v 4 Ka ihe \nd Onyenwe anyị\nd* tọọ gị ụtọ.
\q2 Ọ ga-enyekwa gị ihe niile bụ ọchịchọ nke obi gị.
\b
\q1 
\v 5 Nyefee onwe gị nʼaka \nd Onyenwe anyị\nd*;
\q2 tụkwasị ya obi, ọ ga-emere gị nke a:
\q1 
\v 6 Ọ ga-eme ka ezi omume gị pụta ìhè dịka ihe nke chị ọbụbọ,
\q2 meekwa ka izi ezi nke ikpe gị dịka ihe nke anyanwụ nʼehihie.
\b
\q1 
\v 7 Dere duu nʼihu \nd Onyenwe anyị\nd*,
\q2 were ndidi chere ya;
\q1 echegbula onwe gị mgbe ndị ọzọ na-enwe ọganihu,
\q2 mgbe ha na-emezu atụmatụ ọjọọ ha niile.
\b
\q1 
\v 8 Kwụsị iwe iwe, kwụsịkwa oke iwe;
\q2 echegbula onwe gị, ọ na-eduba naanị nʼihe ọjọọ.
\q1 
\v 9 Nʼihi na a ga-ala ndị ajọ omume nʼiyi,
\q2 ma ndị niile olileanya ha dị na \nd Onyenwe anyị\nd* ga-eketa ala ahụ dịka ihe nketa ha.
\b
\q1 
\v 10 Ọ fọdụrụ nwa oge nta, ndị ajọ omume ga-agabiga;
\q2 ọ bụ ezie na ị ga-achọ ha, ma ị gaghị achọta ha.
\q1 
\v 11 Ma ndị niile dị nwayọọ nʼobi ga-eketa ala a dịka ihe nketa ha,
\q2 ha ga-enwekwa udo dị ukwuu.
\b
\q1 
\v 12 Ndị ajọ omume na-agba izu ọjọọ megide ndị ezi omume,
\q2 na-ata ikekere eze megide ha;
\q1 
\v 13 ma onyenwe anyị na-achị ndị ajọ omume ọchị,
\q2 nʼihi na ọ maara na ụbọchị ha na-abịa.
\b
\q1 
\v 14 Ndị ajọ omume amịpụtala mma agha ha,
\q2 kwee ụta ha
\q1 ime ka ndị nọ na mkpa na ndị ogbenye daa,
\q2 igbu ndị ụzọ ha ziri ezi.
\q1 
\v 15 Ma ha ga-ewere mma agha ha gbuo onwe ha,
\q2 kụrisiekwa ụta ha.
\b
\q1 
\v 16 Ihe ntakịrị nke onye ezi omume nwere
\q2 dị mma karịa akụnụba ọtụtụ ndị ajọ omume;
\q1 
\v 17 nʼihi na a ga-etiji ike niile nke ndị ajọ omume,
\q2 ma \nd Onyenwe anyị\nd* ga-akwagide ndị ezi omume.
\b
\q1 
\v 18 Ndị na-enweghị ịta ụta na-ebi ndụ ha nʼokpuru nlekọta \nd Onyenwe anyị\nd*,
\q2 ihe nketa ha ga-adịgide ruo mgbe ebighị ebi.
\q1 
\v 19 Nʼoge ihe ndakwasị, ha agaghị akpọnwụ;
\q2 ha ga-erijukwa afọ nʼụbọchị ụnwụ.
\b
\q1 
\v 20 Ma ndị ajọ omume ga-ala nʼiyi.
\q2 Nʼagbanyeghị na ndị iro \nd Onyenwe anyị\nd* dịka ịma mma nke ubi ahịhịa ndụ,
\q2 ha ga-agabigakwa ngwangwa nʼanya dịka anwụrụ ọkụ.
\b
\q1 
\v 21 Ndị na-eme ihe ọjọọ na-ebiri mmadụ ihe ma ha adịghị akwụghachi ya,
\q2 ma onye ezi omume na-eme amara na-enye ndị ọzọ ihe o nwere.
\q1 
\v 22 Ndị \nd Onyenwe anyị\nd* gọziri agọzi ga-eketa akụ nke ụwa,
\q2 ma ndị ọ bụrụ ọnụ ka a ga-egbuchapụ.
\b
\q1 
\v 23 Ọ bụrụ na \nd Onyenwe anyị\nd* nwere mmasị na ndụ mmadụ,
\q2 ọ ga-eme ka nzọ ụkwụ ya guzosie ike;
\q1 
\v 24 ọ bụrụ na ọ kpọbie ụkwụ, ọ gaghị ada,
\q2 nʼihi na \nd Onyenwe anyị\nd* na-eji aka ya ejigide ya.
\b
\q1 
\v 25 Abụ m nwantakịrị na mbụ, ugbu a, abụ m agadi,
\q2 ma ahụbeghị m ebe e chefuru ndị ezi omume,
\q2 maọbụ ebe ụmụ ha na-arịọ nri.
\q1 
\v 26 Mgbe niile, ha na-eme amara jiri obi ha na-agbazinye ndị mmadụ ihe,
\q2 ụmụ ha ga-abụ ngọzị.
\b
\q1 
\v 27 Site nʼihe ọjọọ pụọ, mee ezi ihe,
\q2 mgbe ahụ, i ga-ebi nʼala a ruo mgbe ebighị ebi.
\q1 
\v 28 \nd Onyenwe anyị\nd* na-ahụ onye ezi omume na ikpe ziri ezi nʼanya.
\q2 Ọ gaghị ahapụkwa ndị ya kwesiri ntụkwasị obi.
\b
\q1 A ga-echebe ha ruo mgbe ebighị ebi,
\q2 ma ụmụ ndị ajọ omume ka a ga-egbuchapụ;
\q1 
\v 29 ndị ezi omume ga-eketa ala ahụ dịka ihe nketa ha,
\q2 ha ga-ebikwa nʼime ya ruo mgbe ebighị ebi.
\b
\q1 
\v 30 Okwu amamihe na-esi nʼọnụ onye ezi omume pụta,
\q2 ire ya na-ekwukwa ihe ziri ezi.
\q1 
\v 31 Iwu Chineke ya dị ya nʼobi;
\q2 nzọ ukwu ha adịghị agbụchapụ.
\b
\q1 
\v 32 Ndị ajọ omume na-echere ndị ezi omume na nzuzo,
\q2 na-achọ ịnapụ ha ndụ ha;
\q1 
\v 33 ma \nd Onyenwe anyị\nd* agaghị ahapụ ha nʼaka ha,
\q2 ọ gaghị ekwe ka a maa ha ikpe mgbe a na-ekpe ha ikpe.
\b
\q1 
\v 34 Chere \nd Onyenwe anyị\nd*,
\q2 debekwa ụzọ ya.
\q1 Ọ ga-ebuli gị elu ka i nweta ala ahụ dịka ihe nketa;
\q2 mgbe a na-egbuchapụ ndị ajọ omume, ị ga-eji anya gị hụ ya.
\b
\q1 
\v 35 Ahụla m onye ajọ omume na nwoke na-eme ihe ike,
\q2 ka ọ na-eto, na-awasa, dịka osisi dị ndụ nʼezi ala,
\q1 
\v 36 ma ọ dịghị anya, ọ nwụrụ,
\q2 nʼagbanyeghị na m chọgharịrị ya, ọ dịghị ebe ọbụla a hụrụ ya.
\b
\q1 
\v 37 Ma tụgharịa uche banyere ndị ezi omume, rịbaa ndị ụzọ ha ziri ezi ama;
\q2 ọganihu dịịrị onye udo.
\q1 
\v 38 Ma a ga-ala ndị mmehie niile nʼiyi;
\q2 ọ dịghị olileanya dịịrị ndị ajọ omume.
\b
\q1 
\v 39 Nzọpụta nke ndị ezi omume si nʼaka \nd Onyenwe anyị\nd* bịa;
\q2 ọ bụ ebe ha e wusiri ike nʼoge nsogbu.\f + \fr 37:39 \ft \xt Abụ 9:9; Nhu 1:7\xt*\f*
\q1 
\v 40 \nd Onyenwe anyị\nd* na-enyere ha aka, na-anapụtakwa ha
\q2 ma na-azọpụtakwa ha site nʼaka ndị ajọ omume,
\q2 nʼihi na ha mere ya ebe mgbaba ha.
\c 38
\cl Abụ Ọma 38
\d Abụ Ọma Devid. Arịrịọ.
\s1 Arịrịọ nʼoge nsogbu
\q1 
\v 1 Biko, \nd Onyenwe anyị\nd*, abarala m mba nʼiwe,
\q2 maọbụ taa m ahụhụ mgbe iwe gị dị ọkụ.
\q1 
\v 2 Nʼihi na àkụ gị niile amapuola m ahụ,
\q2 aka gị adakwasịkwala m, dịka ọ bụ ọkpọ.
\q1 
\v 3 Nʼihi oke iwe gị, ọ dịghị izuoke dị nʼime anụ ahụ;
\q2 enweghịkwa m udo nʼime ọkpụkpụ m niile nʼihi mmehie m.
\q1 
\v 4 Mmetụta ikpe ọmụma m na-adakwasị m
\q2 dịka ibu arọ nke dị arọ karịa m.
\b
\q1 
\v 5 Ọnya m na-ere ure na-asọ oyi
\q2 nʼihi mmehie enweghị uche m.
\q1 
\v 6 Abụ m onye a nyidara ma kwatukwaa nʼala
\q2 ogologo ụbọchị niile, ana m agagharị nʼiru ụjụ.
\q1 
\v 7 Azụ na-egbu m mgbu nke ukwuu
\q2 ahụ adịghịkwa m.
\q1 
\v 8 Ume ọbụla adịghịkwa nʼime. Adị m ka onye e gwepịara egwepịa.
\q2 Ana m asụ ude nʼihi oke ihe mgbu nke obi.
\b
\q1 
\v 9 O Onyenwe m, ị maara agụụ niile nke na-agụ obi m;
\q2 ịsụ ude m ezokwaghị ezo nʼebe ị nọ.
\q1 
\v 10 Obi na-alọ m mmiri, ike na-agwụkwa m,
\q2 ìhè esitekwala nʼanya m pụọ.
\q1 
\v 11 Ndị m hụrụ nʼanya na ndị enyi m na-asọ m oyi nʼihi ọnya m,
\q2 ndị agbataobi m na-anọ m ebe dị anya.
\q1 
\v 12 Ndị na-achọ igbu m na-esiri m ọnya,
\q2 ndị ahụ chọrọ imerụ m ahụ na-ekwu maka ihe dakwasịrị m;
\q2 ogologo ụbọchị niile ha na-agba izuzu aghụghọ.
\b
\q1 
\v 13 Adị m ka onye ntị chiri, onye na-apụghị ịnụ ihe ọbụla,
\q2 dịka onye ogbu, onye na-apụghị imeghe ọnụ ya.
\q1 
\v 14 Adịla m dịka onye na-anaghị anụ ihe,
\q2 onye ọnụ ya apụghị ịsa okwu.
\q1 
\v 15 O \nd Onyenwe anyị\nd*, ana m eche gị;
\q2 o Onyenwe m Chineke m, ị ga-aza.
\q1 
\v 16 Nʼihi na asịrị m, “Ekwela ka ha ṅụrịa ọṅụ nʼisi m;
\q2 maọbụ bulie onwe ha elu nʼebe m nọ mgbe ụkwụ m na-agbuchapụ.”
\b
\q1 
\v 17 Nʼihi na lee, ana m achọ ịda ada.
\q2 Anọkwa m nʼọnọdụ oke mgbu.
\q1 
\v 18 Ana m ekwupụta mmehie m;
\q2 mmehie m na-ewute m.
\q1 
\v 19 Ndị iro m, ndị na-eme ihe ike dị ọtụtụ,
\q2 ndị na-akpọ m asị, na-enweghị ihe m mere, bara ụba.
\q1 
\v 20 Ndị na-eji ihe ọjọọ akwụghachi m ezi ihe,
\q2 na-ebo ebubo megide m
\q2 nʼagbanyeghị na m na-achọ ime naanị ezi ihe.
\b
\q1 
\v 21 O \nd Onyenwe anyị\nd*, ahapụkwala m;
\q2 O Chineke m, anọkwala m ebe dị anya.
\q1 
\v 22 Bịa ọsịịsọ inyere m aka
\q2 Onyenwe m na Onye nzọpụta m.
\c 39
\cl Abụ Ọma 39
\d Abụ Ọma nke dịrị onyeisi abụ maka Jedutun. Abụ Ọma Devid.
\s1 Nkwupụta mmehie
\q1 
\v 1 Asịrị m, “Aga m elezi anya nʼụzọ m niile
\q2 ma debe ire m ka m ghara ikwuhie\f + \fr 39:1 \ft \xt Job 2:10; Abụ 34:13; Jem 3:5-12\xt*\f*;
\q1 aga m eji ihe kechie ọnụ m
\q2 mgbe m nọ nʼetiti ndị ajọ omume.”
\q1 
\v 2 Ma mgbe m mechiri ọnụ m ma nọrọ duu,
\q2 jụ ikwu ọ bụladị ihe ọbụla dị mma,
\q1 oke ihe mgbu m mụbara.
\q2 
\v 3 Obi m kporo ọkụ nʼime m,
\q1 ma mgbe m na-atụgharị ihe ndị a nʼuche, ọkụ ahụ nọ na-ere;
\q2 mgbe ahụ ekwuru m okwu sị:
\b
\q1 
\v 4 “O \nd Onyenwe anyị\nd*, gosi m ọgwụgwụ nke ndụ m
\q2 na ọnụọgụgụ ụbọchị m niile;
\q2 mee ka m mara na ndụ m na-agafe ngwangwa.
\q1 
\v 5 I meela ka ụbọchị m niile bụrụ naanị ihe dị nta;
\q2 ogologo afọ m niile adịghị ka ihe ọbụla nʼihu gị.
\q1 Ndụ onye ọbụla bụ naanị otu nkuume
\q2 ọbụladị ndị dịka ha guzosirike. \qs Sela\qs*
\b
\q1 
\v 6 “Nʼezie onye ọbụla na-ejegharị dịka onyinyo
\q2 nʼefu ka ha na-ekwogharị nʼotu ebe na nke ọzọ, na-akpakọba akụ,
\q2 na-amaghị onye ọ ga-abụ nke ya nʼikpeazụ.
\b
\q1 
\v 7 “Ma ugbu a, Onyenwe m, gịnị ka m na-ele anya ya?
\q2 Olileanya m dị nʼime gị.
\q1 
\v 8 Zọpụta m site na mmehie m niile;
\q2 ekwela ka m bụrụ ihe ọchị nye ndị nzuzu.
\q1 
\v 9 Agbachiri m nkịtị, ajụrụ m ikwu okwu,
\q2 nʼihi na ọ bụ gị mere ihe a.
\q1 
\v 10 Kwụsị iti m ihe;
\q2 ihe otiti nke aka gị ezuola m ahụ.
\q1 
\v 11 Ị na-abara ndị mmadụ mba ma na-ata ha ahụhụ nʼihi mmehie ha;
\q2 ị na-eripịa akụnụba ha dịka nla,
\q2 mmadụ ọbụla bụ naanị otu nkuume. \qs Sela\qs*
\b
\q1 
\v 12 “O \nd Onyenwe anyị\nd*, nụrụ ekpere m,
\q2 gekwaa ntị nʼakwa m maka enyemaka;
\q2 emechila ntị gị nye ibe akwa m.
\q1 Nʼihi ana m ebinyere gị dịka onye ọbịa,
\q2 dịka onye ije, dịka nna nna m ha mere.
\q1 
\v 13 Lepụ anya na-ebe m nọ, ka m nwee ike kporie ndụ ọzọ,
\q2 tupu m hapụ ebe a laa, a gaghị ahụkwa m ọzọ.”
\c 40
\cl Abụ Ọma 40
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ Ọma Devid.
\s1 Abụ ekele
\q1 
\v 1 Eji m ndidi chere \nd Onyenwe anyị\nd*,
\q2 ọ tụgharịkwutere m, ọ nụkwaara akwa m.
\q1 
\v 2 O sitere nʼolulu na-amị amị,
\q2 nke apịtị na ụrọ juru, sepụta m;
\q1 o guzobere ụkwụ m abụọ nʼelu oke nkume,
\q2 nyekwa m ebe siri ike ka m guzo.
\q1 
\v 3 O tinyere abụ ọhụrụ nʼọnụ m,
\q2 abụ otuto nye Chineke anyị.
\q1 Ọtụtụ ga-ahụ ya ma tụọ egwu,
\q2 ha ga-atụkwasị obi ha nʼime \nd Onyenwe anyị\nd*.
\b
\q1 
\v 4 Onye a gọziri agọzi ka onye ahụ bụ,
\q2 onye na-eme \nd Onyenwe anyị\nd* ebe ntụkwasị obi ya;
\q1 onye na-adịghị ele ndị mpako anya
\q2 maọbụ ndị na-atụgharị gbasoo arụsị.\f + \fr 40:4 \ft Maọbụ, \fqa gbasoo okwu ụgha\f*
\q1 
\v 5 O \nd Onyenwe anyị\nd* Chineke m,
\q2 ọrụ ebube ị rụrụ dị ọtụtụ,
\q2 ọ dịghị onye pụrụ ịgụkọta ihe niile
\q1 ị kwadooro maka inye anyị;
\q2 a sịkwarị na aga m ekwu ma kọsaa ihe banyere ha,
\q2 ha karịrị ihe ọnụ pụrụ ikwu.
\b
\q1 
\v 6 Aja na onyinye\f + \fr 40:6 \ft \xt 1Sa 15:22; Abụ 51:16-17; Aịz 1:11; Jer 7:22-23; Mai 6:6-8; Hib 10:5-9\xt*\f* abụghị ihe ị chọrọ
\q2 ma ị megheela ntị abụọ;
\q2 aja nsure ọkụ na aja a chụrụ maka mmehie abụghị ihe ị chọrọ.
\q1 
\v 7 Mgbe ahụ, ekwuru m sị, “Lee m, abịala m,
\q2 e dere banyere m nʼime akwụkwọ mpịakọta.
\q1 
\v 8 O Chineke m, ọ bụ ọchịchọ m ime ihe ị na-achọ,
\q2 iwu gị dị nʼime obi m.”
\b
\q1 
\v 9 Ana m anọ nʼetiti ọgbakọ ukwuu na-ekwusa ihe ziri ezi;
\q2 dịka ị maara, o \nd Onyenwe anyị\nd*,
\q2 anaghị m emechi ọnụ m.
\q1 
\v 10 Ekpuchighị m ezi omume gị nʼime obi m,
\q2 ana m ekwupụta maka ikwesi ntụkwasị obi gị na nzọpụta gị.
\q1 Adịghị m ekpuchi ịhụnanya na eziokwu gị,
\q2 nʼebe ọgbakọ ukwuu nọ.
\b
\q1 
\v 11 O \nd Onyenwe anyị\nd*, ezonarịla m ebere gị,
\q2 ka ịhụnanya gị na eziokwu gị chebe m oge niile.
\q1 
\v 12 Nʼihi na ọtụtụ nsogbu a na-apụghị ịgụta ọnụ gbara m gburugburu;
\q2 mmehie m niile akarịala m, apụghịkwa m ịhụ ụzọ:
\q1 ha karịrị agịrị isi dị m nʼisi,
\q2 obi m na-adakwa mba nʼime m.
\q1 
\v 13 O \nd Onyenwe anyị\nd*, ya masị gị ịzọpụta m;
\q2 O \nd Onyenwe anyị\nd*, bịa ngwangwa inyere m aka.
\b
\q1 
\v 14 Ka ndị niile na-achọ ịnapụ m ndụ m,
\q2 bụrụ ndị a ga-etinye nʼọnọdụ ihere na ọgbaaghara;
\q1 ka ndị niile ọ na-amasị ịhụ ịla nʼiyi m,
\q2 laghachi azụ nʼihere.
\q1 
\v 15 Ka ndị ahụ na-asị m,
\q2 “Ehee! Ehee!” kụja nʼihi ihere onwe ha.
\q1 
\v 16 Ma ka ndị niile na-achọ gị
\q2 ṅụrịa ọṅụ, nweekwa obi ụtọ nʼime gị;
\q1 ka ndị ahụ hụrụ nzọpụta gị nʼanya na-ekwu mgbe niile,
\q2 “\nd Onyenwe anyị\nd* dị ukwuu.”
\b
\q1 
\v 17 Ma mụ onwe m bụ m ogbenye na onye nọ na mkpa;
\q2 ka \nd Onyenwe anyị\nd* cheta m.
\q1 Ị bụ onye inyeaka m na onye mgbapụta m;
\q2 Ị bụ Chineke m, anọla ọdụ ịbịa.
\c 41
\cl Abụ Ọma 41
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ Ọma Devid.
\s1 Ekpere onye ọrịa
\q1 
\v 1 Ndị a gọziri agọzi ka ha bụ ndị nwere uche na-eleta ndị ogbenye;
\q2 \nd Onyenwe anyị\nd* na-azọpụta ha nʼoge nsogbu.
\q1 
\v 2 \nd Onyenwe anyị\nd* ga-echebe ha, debekwa ha ndụ;
\q2 ọ ga-eme ka ihe na-agara ha nke ọma nʼala ahụ,
\q2 ọ gaghị arara ha nye nʼọchịchọ ndị iro ha.
\q1 
\v 3 \nd Onyenwe anyị\nd* na-elekọta ha mgbe ahụ na-esighị ha ike,
\q2 meekwa ka ahụ dị ha mma.
\b
\q1 
\v 4 Ekwuru m sị, “O \nd Onyenwe anyị\nd*, meere m ebere;
\q2 gwọọ m, nʼihi na emehiela m megide gị.”
\q1 
\v 5 Ndị iro m na-esite nʼiro ha ekwu okwu megide m
\q2 na-asị, “Olee mgbe ọ ga-anwụ ka aha ya laa nʼiyi?”
\q1 
\v 6 Mgbe otu nʼime ha bịara ịhụ m,
\q2 ọ na-ekwu okwu ụgha, ma obi ya na-achịkọta ihe nkwulu;
\q2 mgbe ahụ ọ na-apụ, ga kọsaa ya.
\b
\q1 
\v 7 Ndị niile kpọrọ m asị na-agbarịta izu megide m;
\q2 ha na-echekwa echiche ọjọọ banyere m, na-asịrịta onwe ha:
\q1 
\v 8 “Ọrịa ọjọọ adakwasịla ya;
\q2 ọ gaghị esite na ihe ndina ya bilie ọtọ ọzọ.”
\q1 
\v 9 Ọ bụladị ezigbo enyi m,
\q2 onye m tụkwasịrị obi,
\q1 onye mụ na ya na-eso erikọ nri m,
\q2 ebiliela imegide m.
\b
\q1 
\v 10 Ma gị, O \nd Onyenwe anyị\nd*, meere m ebere,
\q2 mee ka ahụ sie m ike ọzọ, ka m nwee ike kwụghachi ha ụgwọ.
\q1 
\v 11 Amaara m na ihe banyere m na-atọ gị ụtọ nʼobi,
\q2 nʼihi na i kwebeghị ka ndị iro m nwee mmeri nʼebe m nọ.
\q1 
\v 12 Nʼihi ikwesi ntụkwasị obi m, ị na-akwagide m,
\q2 mee ka m nọrọ nʼihu gị ruo mgbe ebighị ebi.
\b
\b
\q1 
\v 13 Otuto dịrị \nd Onyenwe anyị\nd*, Chineke nke Izrel,
\q2 site nʼebighị ebi ruo ebighị ebi.
\qc Amen na Amen.
\c 42
\ms1 Nchịkọta Akwụkwọ nke Abụọ
\mr Abụ Ọma 42–72
\cl Abụ Ọma 42
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ \tl Maskil\tl* nke ụmụ Kora.
\s1 Iru ụjụ na nkasiobi onye ezi omume
\q1 
\v 1 Dịka agụụ ịṅụ mmiri si na-agụ nne ele,
\q2 otu a ka agụụ ihe banyere gị si na-agụ m, O Chineke.
\q1 
\v 2 Akpịrị nke ihe banyere Chineke, bụ Chineke ahụ dị ndụ, na-akpọ m nkụ.
\q2 Olee mgbe m pụrụ ịga zute Chineke?
\q1 
\v 3 Anya mmiri m aghọọlara m ihe oriri
\q2 nʼehihie ma nʼabalị,
\q1 mgbe ndị mmadụ na-asị m ogologo ụbọchị niile,
\q2 “Olee ebe Chineke gị nọ?”
\q1 
\v 4 Ihe ndị a ka m na-echeta
\q2 mgbe m na-ekwupụta ihe mgbu nke obi m:
\q1 ma m cheta mgbe mụ na igwe mmadụ so aga,
\q2 mgbe m ji iti mkpu ọṅụ na ekele na-edu ha
\q1 nʼetiti ọha kachasị ibe ya, ndị ọṅụ juru obi,
\q2 na-aga nʼụlọ Chineke.
\b
\q1 
\v 5 O mkpụrụobi m, gịnị mere i ji daa mba?
\q2 Gịnị mere i ji na-asụ ude nʼime m?
\q1 Nwee olileanya na Chineke,
\q2 nʼihi na m ka ga-eto ya,
\q2 Onye nzọpụta m na Chineke m.
\b
\q1 
\v 6 Mkpụrụobi m na-ada mba nʼime m;
\q2 ya mere, aga m echeta gị
\q1 site nʼala Jọdan,
\q2 na ebe dị elu nke Hemon,\f + \fr 42:6 \ft Hemon bụ obodo dị nʼoke ala nkwa ahụ nʼebe ugwu.\f* na sitekwa nʼugwu Miza.
\q1 
\v 7 Ogbu mmiri na-akpọku ogbu mmiri
\q2 mgbe olu ha na-ada ụda nʼetiti nruda mmiri gị niile;
\q1 ebili mmiri gị niile na mmali mmiri gị niile
\q2 ekpuchiela isi m.
\b
\q1 
\v 8 Nʼehihie, \nd Onyenwe anyị\nd* na-awụkwasị m ịhụnanya ya,
\q2 nʼabalị abụ ya dị m nʼobi,
\q2 ekpere nye Chineke nke ndụ m.
\b
\q1 
\v 9 Ana m asị Chineke, oke nkume m,
\q2 “Gịnị mere i ji chefuo m?
\q1 Gịnị mere m ga-eji na-ejegharị nʼiru ụjụ
\q2 nʼihi mmegbu nke onye iro?”
\q1 
\v 10 Ọkpụkpụ m na-agabiga oke ihe mgbu,
\q2 mgbe ndị iro m ji m na-eme ihe ọchị,
\q1 ogologo ụbọchị niile ha na-ajụ m,
\q2 “Olee ebe Chineke gị nọ?”
\b
\q1 
\v 11 O mkpụrụobi m, gịnị mere i ji daa mba?
\q2 Gịnị mere i ji na-asụ ude nʼime m?
\q1 Nwee olileanya na Chineke,
\q2 nʼihi na m ka ga-eto ya ọzọ,
\q2 Onye nzọpụta m na Chineke m.
\c 43
\cl Abụ Ọma 43
\s1 Arịrịọ maka enyemaka
\q1 
\v 1 O Chineke, kpepụta m,
\q2 kpechitere m ikpe m
\q2 nʼebe mba na-amaghị Chineke nọ;
\q1 gbapụta m site nʼaka
\q2 ndị ajọ omume na ndị aghụghọ.
\q1 
\v 2 Ị bụ Chineke, ebe m e wusiri ike.
\q2 Gịnị mere i ji jụ m?
\q1 Gịnị mere m ga-eji na-ejegharị nʼiru ụjụ,
\q2 nʼihi mmegbu nke onye iro?
\q1 
\v 3 Zipụ ìhè gị na eziokwu gị,
\q2 ka ha duo m;
\q1 ka ha kpọbata m nʼugwu nsọ gị,
\q2 bụ ebe i bi.
\q1 
\v 4 Mgbe ahụ, aga m aga nʼebe ịchụ aja Chineke,
\q2 gakwuru Chineke, bụ ọṅụ m na obi ụtọ m.
\q1 Aga m eji ụbọ akwara too gị,
\q2 O Chineke, bụ Chineke m.
\b
\q1 
\v 5 O mkpụrụobi m, gịnị mere i ji daa mba?
\q2 Gịnị mere i ji na-asụ ude nʼime m?
\q1 Nwee olileanya na Chineke,
\q2 nʼihi na m ka ga-eto ya ọzọ,
\q2 onye Nzọpụta m na Chineke m.
\c 44
\cl Abụ Ọma 44
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ \tl maskil\tl* nke ụmụ Kora.
\s1 Ekpere maka mgbapụta
\q1 
\v 1 O Chineke, anyị anụla;
\q2 nna anyị ha agwakwala anyị
\q1 ihe ndị i mere nʼoge ha,
\q2 nʼoge gara aga.
\q1 
\v 2 I ji aka gị chụpụ ndị mba ọzọ,
\q2 ma kụnye nna nna anyị ha dịka osisi.
\q1 I gwepịara ndị ahụ
\q2 ma mee ka ndị nna anyị na-eto na-awasa.
\q1 
\v 3 Ọ bụghị site na mma agha ha ka ha ji merie nweta ala a,
\q2 ha emerighị site nʼike nke aka ha;
\q1 ọ bụ aka nri gị, aka gị,
\q2 na ìhè nke ihu gị nyere ha mmeri, nʼihi na ị hụrụ ha nʼanya.
\b
\q1 
\v 4 Ị bụ eze m na Chineke m,
\q2 onye na-ekpebi na Jekọb aghaghị inwe mmeri.
\q1 
\v 5 Nʼihi ọ bụ naanị site nʼike gị, ya na aha gị,
\q2 ka anyị ji zọda ndị iro anyị nʼokpuru ụkwụ anyị.
\q1 
\v 6 Atụkwasịghị m obi m nʼụta m,
\q2 mma agha m anaghị enye m mmeri;
\q1 
\v 7 ma i na-enye anyị mmeri nʼebe ndị iro anyị nọ,
\q2 ị na-eme ka ihere mee ndị na-eguzogide anyị.
\q1 
\v 8 Nʼime Chineke ka ịnya isi anyị dị ogologo ụbọchị niile,
\q2 anyị ga-eto aha gị ruo mgbe ebighị ebi. \qs Sela\qs*
\b
\q1 
\v 9 Ma ugbu a, ị jụla anyị ma weda anyị nʼala;
\q2 ị naghị esokwa ndị agha anyị apụ ọzọ.
\q1 
\v 10 I mere ka anyị site nʼihu ndị iro anyị gbalaga,
\q2 i meela ka ndị na-emegide anyị were aka ike napụ anyị ihe bụ nke anyị.
\q1 
\v 11 Ị gbakụtara anyị azụ ka e ripịa anyị dịka atụrụ,
\q2 ma chụsasịa anyị nʼetiti mba niile.
\q1 
\v 12 I rere ndị gị ọnụ ala,
\q2 ihe i retara ha abaghị uru nye gị.
\b
\q1 
\v 13 I meela ka anyị bụrụ nkọcha nye ndị agbataobi anyị,
\q2 anyị bụ ihe ịkwa emo na ihe ọchị nye ndị gbara anyị gburugburu.
\q1 
\v 14 I meela anyị ka anyị bụrụ ihe ịmaatụ ọchị nʼetiti mba niile,
\q2 ndị ọbụla hụrụ anyị na-efufe isi na mkparị.
\q1 
\v 15 Ogologo ụbọchị niile, ihere m dị m nʼihu,
\q2 ihere m na-ekpuchikwa m ihu,
\q1 
\v 16 mgbe ndị nkwulu na ndị nkọcha na-eji m eme ihe ọchị,
\q2 nʼihi onye iro, onye kpebiri ịbọ ọbọ.
\b
\q1 
\v 17 Ọ bụ ezie na ihe ndị a adakwasịla anyị,
\q2 ma anyị echefubeghị gị.
\q2 Anyị enupubeghị isi nʼọgbụgba ndụ anyị na gị.
\q1 
\v 18 Obi anyị ahapụbeghị gị!
\q2 Anyị ahapụbekwaghị iso ụzọ gị.
\q1 
\v 19 Ma i gwepịara anyị mee ka anyị bụrụ ebe nkịta ọhịa na-akpagharị,
\q2 jirikwa oke ọchịchịrị kpuchie anyị.
\b
\q1 
\v 20 Ọ bụrụ na anyị chefuru aha Chineke anyị,
\q2 maọbụ na anyị gbasaara chi mba ọzọ aka anyị,
\q1 
\v 21 ọ bụ na Chineke agaraghị achọpụta ya,
\q2 ebe ọ maara ihe nzuzo niile dị nʼobi?
\q1 
\v 22 Ọ bụ nʼihi gị ka anyị na ọnwụ ji agba mgba, ogologo ụbọchị niile.
\q2 A na-ele anyị anya dịka atụrụ a gaje igbu egbu.
\b
\q1 
\v 23 O, Onyenwe m teta! Gịnị mere i ji arahụ ụra?
\q2 Kpọtee onwe gị! Ajụkwala anyị ruo mgbe ebighị ebi.
\q1 
\v 24 Gịnị mere i ji ezopụ ihu gị,
\q2 ma chefuo mmegbu na ịta ahụhụ anyị?
\b
\q1 
\v 25 E tidala anyị nʼala, nʼuzuzu,
\q2 ahụ anyị rapara nʼaja
\q1 
\v 26 Bilie ma nyere anyị aka;
\q2 gbapụta anyị maka ịhụnanya gị nke na-adịghị agwụ agwụ.
\c 45
\cl Abụ Ọma 45
\d Abụ Ọma nke dịrị onyeisi abụ. Nʼusoro olu abụ “Okoko osisi lili.” Abụ maskil ụmụ Kora. Abụ maka agbamakwụkwọ.
\s1 Abụ ọlụlụ nwunye eze
\q1 
\v 1 Isi okwu dị ebube na-akpali mkpụrụobi m,
\q2 mgbe m na-agụgharị abụ m nye eze;
\q2 ire m bụ mkpisi akwụkwọ dị nʼaka ọka ode akwụkwọ.
\b
\q1 
\v 2 I bụ onye kachasị mma nʼetiti ụmụ mmadụ,
\q2 e ji amara tee egbugbere ọnụ gị mmanụ,
\q2 ebe ọ bụ na Chineke agọziela gị ruo mgbe ebighị ebi.
\b
\q1 
\v 3 Kenye mma agha gị nʼukwu gị, gị onye dị ike;
\q2 yikwasị onwe gị ebube na ịma mma dịka uwe.
\q1 
\v 4 Nʼebube gị, gaa nʼihu nʼime mmeri,
\q2 nʼihi eziokwu, na ịdị obi umeala, na ezi omume;
\q2 ka aka nri gị gosipụta ọrụ gị niile nke na-eju anya.
\q1 
\v 5 Ka àkụ gị niile dị nkọ mapuo mkpụrụobi ndị iro niile nke eze;
\q2 ka mba niile na-adakwa nʼokpuru ụkwụ gị.
\q1 
\v 6 O Chineke, ocheeze gị ga-adịgide ruo mgbe ebighị ebi,
\q2 mkpara omume ziri ezi ka mkpara alaeze gị ga-abụ
\q1 
\v 7 Ị hụrụ ezi omume nʼanya, ma kpọọ ihe ọjọọ asị;
\q2 ya mere, Chineke, onye bụ Chineke gị, emeela ka ịdị elu karịa ndị ibe gị,
\q2 site na ite gị mmanụ nke ọṅụ.
\q1 
\v 8 Uwe gị niile jupụtara nʼisisi ụtọ nke si na mmanụ\f + \fr 45:8 \ft Nke a bụ mmanụ isi ọma a na-efesa nʼuwe. Ọ nọ nʼọnọdụ ihe anyị na-akpọ senti taa. \xt Abk 1:12-13.\xt*\f* máá na aloos na akashia;
\q2 ha sitere nʼụlọeze niile, e ji ọdụ enyi chọọ mma.
\q2 Egwu sitere nʼụbọ akwara na-eme ka i nwee obi ụtọ.
\q1 
\v 9 Ụmụ agbọghọ eze nọ nʼetiti ndị inyom gị ka a na-asọpụrụ;
\q2 nwunye eze, onye yikwasịrị ọlaedo nke Ọfịa na-eguzo nʼaka nri gị.
\b
\q1 
\v 10 Gee ntị, gị nwaagbọghọ, tulee ma nụrụkwa ihe m na-ekwu:
\q2 “Chefuo ndị gị na ezinaụlọ nna gị.
\q1 
\v 11 Nʼihi na ịma mma gị ga-eme ka eze chọsie gị ike.
\q2 Sọpụrụ ya nʼihi na ọ bụ onyenwe gị.”
\q1 
\v 12 Ada Taịa\f + \fr 45:12 \ft Eze mbụ kwụnyeere ọchịchị alaeze Devid bụ eze obodo Taịa, nʼihi Solomọn na eze Taịa nweere ezigbo mmekọrịta dị mma. Taịa bụ isi obodo ebe niile a na-azụ ahịa nʼakụkụ osimiri Mediterenịan.\f* ga-eji onyinye bịa;
\q2 ndị ọgaranya ga-achọkwa ka i gosi ha ihuọma.
\q1 
\v 13 Adaeze, lee ka o si maa mma dị ukwuu nʼime ụlọ ya;
\q2 ọ bụ akwa a kpanyere ọlaedo ka e ji dụọ uwe mwụda ya.
\q1 
\v 14 Ụmụ agbọghọ ibe ya, ndị na-amaghị nwoke, na-eso ya bịakwute gị;
\q2 ọ bụ uwe mwụda a kpanyere ihe ọkpụkpa ka o yi
\q2 mgbe e dubatara ya nʼụlọeze.
\q1 
\v 15 E ji ọṅụ na obi ụtọ dubata ha;
\q2 ha bara nʼime ụlọeze.
\b
\q1 
\v 16 Ụmụ gị ndị ikom ga-anọchi anya nna nna gị;
\q2 ị ga-eme ka ha bụrụ ndịisi nʼala ahụ niile.
\b
\q1 
\v 17 Aga m eme ka echeta ihe banyere gị ruo ọgbọ niile;
\q2 nʼihi nke a, mba niile ga-eto gị ruo mgbe niile ebighị ebi.
\c 46
\cl Abụ Ọma 46
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ ụmụ Kora. Nʼusoro olu abụ alamot. Otu Abụ.
\s1 Chineke bụ ebe mgbaba anyị
\q1 
\v 1 Chineke bụ ebe mgbaba anyị, na ike anyị,
\q2 onye inyeaka anyị ka ọ bụ nʼoge nsogbu.
\q1 
\v 2 Nʼihi ya, anyị agaghị atụ egwu, ọ bụladị mgbe ụwa niile na-emebi,
\q2 maọbụ mgbe a na-ewezuga ugwu nʼọnọdụ ha, mee ka ha daba nʼoke osimiri.
\q1 
\v 3 Nʼagbanyeghị na mmiri ya na-agba aghara, na-asụkwa ụfụfụ,
\q2 maọbụ na ugwu niile na-eme mkpọtụ site nʼoke mbili elu ha. \qs Sela\qs*
\b
\q1 
\v 4 Otu iyi dị nke na-asọbata na-eweta ọṅụ nʼime obodo Chineke,
\q2 nʼime ebe obibi dị nsọ nke Onye kachasị ihe niile elu.
\q1 
\v 5 Chineke bi nʼime ya, ọ gaghị ada;
\q2 Chineke ga-enyere ya aka mgbe chi bọrọ.
\q1 
\v 6 Mba niile na-agba aghara, alaeze niile na-adakwa;
\q2 o welitere olu ya elu, ụwa na-agbaze.
\b
\q1 
\v 7 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile nọnyere anyị;
\q2 Chineke nke Jekọb bụ ebe mgbaba anyị e wusiri ike. \qs Sela\qs*
\b
\q1 
\v 8 Bịa, hụrụ ihe ebube niile \nd Onyenwe anyị\nd* mere,
\q2 lee oke ịla nʼiyi niile o webatara nʼelu ụwa.
\q1 
\v 9 Ọ na-eme ka agha kwụsị
\q2 ruo nsọtụ nke elu ụwa niile.
\q1 Ọ na-agbaji ụta, na-ebibi ùbe,
\q2 ma na-esu ọta\f + \fr 46:9 \ft Maọbụ, \fqa ụgbọ agha\f* agha niile ọkụ.
\q1 
\v 10 Ọ na-asị, “Nọọnụ juu! Maranụ na mụ onwe m bụ Chineke!
\q2 A ga-ebuli m elu nʼetiti mba niile,
\q2 a ga-ebulikwa m elu nʼụwa.”
\b
\q1 
\v 11 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile nọnyere anyị;
\q2 Chineke nke Jekọb bụ ebe mgbaba anyị e wusiri ike. \qs Sela\qs*
\c 47
\cl Abụ Ọma 47
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ ụmụ Kora. Abụ Ọma.
\s1 Chineke bụ eze nke ụwa
\q1 
\v 1 Kụọnụ aka unu, unu mba niile;
\q2 jiri iti mkpu ọṅụ tikuo Chineke.
\b
\q1 
\v 2 Nʼihi na \nd Onyenwe anyị\nd* bụ Chineke kachasị ihe niile elu.
\q2 Ọ dị egwu! Ọ bụ eze ukwu na-achị ụwa niile.
\q1 
\v 3 O wedara mba niile mee ka ha nọọ nʼokpuru anyị;
\q2 ndị mmadụ niile nọ nʼokpuru ụkwụ anyị.
\q1 
\v 4 Ọ họpụtaara anyị ihe nketa anyị,
\q2 ihe ịnya isi nke Jekọb, onye ọ hụrụ nʼanya. \qs Sela\qs*
\b
\q1 
\v 5 Chineke ewerela iti mkpu ọṅụ rigoro nʼeluigwe.
\q2 \nd Onyenwe anyị\nd* ewerela olu opi ike rigoo.
\q1 
\v 6 Bụkuonụ Chineke abụ otuto, bụọ abụ otuto;
\q2 bụkuonụ eze anyị abụ otuto, bụọ abụ otuto.\f + \fr 47:6 \ft Ngwa egwu eji mpi anụmanụ mee, a na-akpọ Shọfa, ka eji abụ abụ. Ọ bụkwa ya ka a eji akpọsa afọ ọhụrụ nye ndị mmadụ.\f*
\q1 
\v 7 Nʼihi na Chineke anyị bụ eze ụwa niile.
\q2 Jirinụ abụ too ya.
\b
\q1 
\v 8 Chineke bụ eze mba niile;
\q2 ọ na-anọkwasị nʼocheeze ya dị nsọ na-achị mba niile.
\q1 
\v 9 Ndị niile a ma ama na mba niile ezukọtaala,
\q2 dịka ndị Chineke nke Ebraham,
\q1 nʼihi na ndị eze\f + \fr 47:9 \ft Maọbụ, \fqa ọta\f* niile dị nʼụwa bụ nke Chineke;
\q2 ọ bụ onye e buliri elu nʼebe ọ dị ukwuu.
\c 48
\cl Abụ Ọma 48
\d Otu Abụ. Abụ Ọma nke ụmụ Kora.
\s1 Abụ nke Zayọn
\q1 
\v 1 \nd Onyenwe anyị\nd* dị ukwuu, bụrụkwa onye kwesiri ịnata otuto,
\q2 nʼime obodo Chineke anyị, nʼugwu nsọ ya.
\b
\q1 
\v 2 Ọ mara mma nʼịdị elu ya,
\q2 bụkwa ọṅụ elu ụwa niile.
\q1 Ugwu Zayọn, obodo eze ahụ dị ukwuu,
\q2 dịka ebe kachasị elu nke Zafọn.
\q1 
\v 3 Chineke nọ nʼime ebe ya e wusiri ike;
\q2 o gosila onwe ya dịka ebe mgbaba ha e wusiri ike.
\b
\q1 
\v 4 Mgbe ndị eze jikọtara ndị agha ha ọnụ,
\q2 mgbe ha bịakọtara nso,
\q1 
\v 5 ihe ha hụrụ juru ha anya;
\q2 nʼihi oke egwu, ha gbara ọsọ.
\q1 
\v 6 Ahụ ọma jijiji bidoro ha nʼebe ahụ,
\q2 ihe mgbu ha dịka nke nwanyị na-achọ ịmụ nwa.
\q1 
\v 7 Ị lara ha nʼiyi dịka oke ifufe si nʼọwụwa anyanwụ
\q2 si ala ụgbọ mmiri ukwuu nke Tashish nʼiyi.
\b
\q1 
\v 8 Dịka anyị nụrụ,
\q2 otu a ka anyị hụrụ,
\q1 nʼime obodo \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile,
\q2 nʼime obodo Chineke anyị:
\q1 Chineke na-eme ka o guzosie ike
\q2 ruo mgbe ebighị ebi. \qs Sela\qs*
\b
\q1 
\v 9 O Chineke, nʼime ụlọnsọ ukwuu gị,
\q2 ka anyị nọ na-atụgharị uche nʼịhụnanya gị nke na-enweghị ọgwụgwụ.
\q1 
\v 10 O Chineke, dịka aha gị,
\q2 otuto gị na-eru na nsọtụ ụwa niile;
\q2 aka nri gị jupụtara nʼezi omume.
\q1 
\v 11 Ugwu Zayọn na-aṅụrị ọṅụ,
\q2 obodo nta niile nke Juda nwere obi ụtọ
\q2 nʼihi ikpe gị niile.
\b
\q1 
\v 12 Gaanụ Zayọn gburugburu, Jegharịa ya gburugburu,
\q2 gụọkwanụ ụlọ elu ya niile ọnụ.
\q1 
\v 13 Lezienụ mgbidi ya niile anya,
\q2 nyochakwaanụ ebe ya niile e wusiri ike,
\q1 ka unu nwee ike ịkọrọ
\q2 ọgbọ na-abịa nʼihu akụkọ ndị a.
\b
\q1 
\v 14 Nʼihi na Chineke a, bụ Chineke anyị ruo mgbe niile ebighị ebi,
\q2 ọ ga-abụ onyendu anyị, ọ bụladị ruo nʼọgwụgwụ.
\c 49
\cl Abụ Ọma 49
\d Abụ Ọma dịrị onyeisi abụ. Abụ ụmụ Kora. Abụ Ọma.
\s1 Nzuzu ndị na-atụkwasị obi nʼakụnụba
\q1 
\v 1 Nụrụnụ nke a, unu mmadụ niile!
\q2 Geenụ ntị, unu ndị niile bi nʼụwa,
\q1 
\v 2 ma ndị dị ala ma ndị dị elu,\f + \fr 49:2 \ft E nwekwara ike gụọ ya otu a, \fqa ma ụmụ mmadụ ma ụmụ nwoke.\f*
\q2 ma onye ọgaranya ma onye ogbenye.
\q1 
\v 3 Aga m ekwu okwu amamihe,
\q2 ihe sị nʼobi m ga-enye nghọta.
\q1 
\v 4 Aga m aṅa ntị nye ilu,
\q2 aga m e ji ụbọ akwara kọwaa ilu m.
\b
\q1 
\v 5 Nʼihi gịnị ka m ga-eji tụọ egwu mgbe ụbọchị ọjọọ bịara,
\q2 mgbe ndị aghụghọ ọjọọ gbara m gburugburu,
\q1 
\v 6 ndị na-atụkwasị obi nʼakụnụba ha
\q2 ma na-anyakwa isi nʼihi oke ụba ha.
\q1 
\v 7 O nweghị onye pụrụ ịgbapụta ndụ onye ọzọ,
\q2 maọbụ nye Chineke ụgwọ e ji agbara onye ahụ,
\q1 
\v 8 nʼihi na ụgwọ e ji agbara ndụ dị oke ọnụ,
\q2 o nweghị ụgwọ a ga-akwụ nke ga-ezu,\f + \fr 49:8 \ft \xt Mat 16:26\xt*\f*
\q1 
\v 9 nke ga-eme ka mmadụ dịrị ndụ ruo ebighị ebi,
\q2 ma hapụ ịnwụ.
\q1 
\v 10 Nʼihi na mmadụ niile na-ahụ na ndị amamihe na-anwụ,
\q2 ndị nzuzu na ndị na-enweghị uche na-anwụkwa,
\q2 si otu a hapụrụ ndị ọzọ akụnụba ha.
\q1 
\v 11 Ili ha na-aghọ ụlọ ha ruo ebighị ebi,
\q2 ebe obibi ha ruo ọgbọ niile
\q2 nʼagbanyeghị na ha gụrụ ọtụtụ ala aha ha.
\b
\q1 
\v 12 Ma mmadụ, nʼagbanyeghị akụnụba ya, aghaghị ịnwụ,
\q2 dịka anụ ọhịa, ọ ga-anwụkwa.
\b
\q1 
\v 13 Nke a bụ ihe na-adakwasị ndị na-atụkwasị obi nʼonwe ha,
\q2 na ndị na-eso ụzọ ha, ndị na-akwado okwu ha. \qs Sela\qs*
\q1 
\v 14 Dịka atụrụ, ọ bụ ala mmụọ ka a kwadooro ha,
\q2 ọnwụ ga-abụ onye na-azụ ha dịka atụrụ,
\q2 ma ndị na-eme ihe ziri ezi ga-emeri ha nʼụtụtụ.
\q1 Ozu ha ga-erekasị nʼime ili
\q2 nʼebe dị anya site nʼụlọeze ha.
\q1 
\v 15 Ma Chineke ga-agbapụta ndụ m site nʼili,\f + \fr 49:15 \ft \xt Hos 13:4; Mak 16:6-7\xt*\f*
\q2 nʼezie, ọ ga-akpọrọ m nye onwe ya. \qs Sela\qs*
\q1 
\v 16 Amala jijiji mgbe mmadụ na-aba oke ụba,
\q2 mgbe ịdị ebube nke ụlọ ya na-amụba,
\q1 
\v 17 nʼihi na ọ ga-agba aka laa ma ọ nwụọ,
\q2 ịdị ebube ya agaghị eso ya banye nʼili.
\q1 
\v 18 Nʼagbanyeghị na ọ gụrụ onwe ya dịka onye a gọziri agọzi mgbe ọ dị ndụ,
\q2 ọ bụ ezie na ndị mmadụ na-eto gị mgbe ị na-enwe ọganihu,
\q1 
\v 19 ọ ga-eso ọgbọ ndị nna nna ya
\q2 ndị na-agaghị ahụkwa ìhè ọzọ.
\b
\q1 
\v 20 Ndị bara ụba nke na-enweghị nghọta
\q2 dịka anụ ọhịa nke ga-ala nʼiyi.
\c 50
\cl Abụ Ọma 50
\d Abụ Ọma Asaf.
\s1 Ofufe zuruoke
\q1 
\v 1 \nd Onyenwe anyị\nd*, Chineke, Onye kachasị chi niile,
\q2 ekwuola okwu ma kpọkọta ụwa niile,
\q2 site na ọwụwa anyanwụ ruo na ọdịda ya.
\q1 
\v 2 Chineke na-enwupụta dịka ìhè, site na Zayọn,
\q2 nke zuruoke nʼime ịma mma.
\q1 
\v 3 Chineke anyị na-abịa,
\q2 ọ gaghị emechikwa ọnụ;
\q1 ọkụ na-erepịa erepịa dị nʼihu ya,
\q2 oke ifufe na-efesi ike gbakwara ya gburugburu.
\q1 
\v 4 Ọ na-akpọku eluigwe
\q2 na ụwa ka o kpee ndị ya ikpe: Ọ na-asị,
\q1 
\v 5 “Chikọtaranụ m ndị m e doro nsọ,
\q2 bụ ndị mụ na ha ji ịchụ aja gbaa ndụ.”
\q1 
\v 6 Eluigwe na-ekwupụta ezi omume ya,
\q2 nʼihi na Chineke nʼonwe ya bụ onye ikpe. \qs Sela\qs*
\b
\q1 
\v 7 “Nụrụnụ, ndị m, m ga-ekwukwa,
\q2 Izrel, aga m agba ama megide unu,
\q2 Abụ m Chineke, Chineke unu.
\q1 
\v 8 Anaghị m abara unu mba nʼihi ịchụ aja unu,
\q2 na aja nsure ọkụ unu nke na-adị m nʼihu oge niile.
\q1 
\v 9 Enweghị m mkpa maka oke ehi unu site nʼụlọ anụmanụ unu
\q2 maọbụ mkpi site nʼọgba igwe ewu na atụrụ unu,
\q1 
\v 10 nʼihi na ụmụ anụmanụ niile nke oke ọhịa bụ nke m,
\q2 ha na ehi niile nọ nʼelu otu puku ugwu.
\q1 
\v 11 Amaara m ụmụ nnụnụ niile nọ nʼelu ugwu niile,
\q2 ihe niile e kere eke nọ nʼọhịa bụ nke m.
\q1 
\v 12 Ọ bụrụ na agụụ agụọ m, agaghị m agwa gị ya,
\q2 nʼihi na ụwa na ihe niile dị nʼime ya bụ nke m.
\q1 
\v 13 Ana m ata anụ oke ehi,
\q2 ka ọ bụ ọbara mkpi ka m ga-aṅụ?
\b
\q1 
\v 14 “Chụọrọ Chineke aja ekele,
\q2 mezuo nkwa i kwere Onye kachasị ihe niile elu,
\q1 
\v 15 ma kpọkuo m nʼụbọchị nsogbu gị,
\q2 aga m agbapụta unu, unu ga-enyekwa m nsọpụrụ.”
\p 
\v 16 Ma Chineke na-agwa ndị na-eme ihe ọjọọ okwu sị,
\q1 “Olee, nkwuwa okwu unu nwere ịgụgharị iwu m,
\q2 maọbụ kwupụta ọgbụgba ndụ m nʼọnụ unu?
\q1 
\v 17 Unu kpọrọ ndụmọdụ m asị,
\q2 na-atụfekwa okwu m nʼazụ unu.
\q1 
\v 18 Mgbe unu hụrụ onye ohi, unu na ya na-ejikọta aka;
\q2 unu na ndị na-akwa iko na-ekekọkwa oke.
\q1 
\v 19 Ọnụ unu na-eme ọsịịsọ ikwu okwu ọjọọ,
\q2 okwu aghụghọ na nke rere ure na-esikwa nʼọnụ unu na-asọpụta dịka iyi.
\q1 
\v 20 Unu na-ekwugide ụmụnna unu mgbe niile,
\q2 na-ekwutọkwa nwanne unu nwoke.
\q1 
\v 21 Ihe ndị a ka unu mere ma agbachiri m nkịtị;
\q2 unu chekwara na adị m ka unu.
\q1 Ma aga m abara unu mba
\q2 ma bokwaa unu ebubo unu nʼihu unu.
\b
\q1 
\v 22 “Tụgharịa uche na nke a, unu ndị na-echefu Chineke,
\q2 ma ọ bụghị ya, aga m adọrisi unu, ọ dịkwaghị onye ga-agbapụta unu.
\q1 
\v 23 Onye na-eji ekele achụrụ m aja, na-asọpụrụ m,
\q2 ọ bụkwa onye na-edozi ụzọ ya, ka m ga-eme ka ọ hụ nzọpụta Chineke.”
\c 51
\cl Abụ Ọma 51
\d Abụ dịrị onyeisi abụ. Abụ Ọma Devid. Mgbe Netan bụ onye amụma bịakwutere Devid nʼoge ya na Batsheba kwara iko.
\s1 Ekpere maka mgbaghara mmehie
\q1 
\v 1 O Chineke, meere m ebere,
\q2 nʼihi ịhụnanya gị nke na-adịgide adịgide;
\q1 nʼihi oke ọmịiko gị,
\q2 hichapụ njehie m niile.
\q1 
\v 2 Sachapụ mmehie m niile,\f + \fr 51:2 \ft \xt Aịz 43:25; Aịz 44:22; Kọl 2:14.\xt*\f*
\q2 ma mee m ka m dị ọcha.
\b
\q1 
\v 3 Nʼihi na amaara m njehie m niile,
\q2 mmehie m dịkwa nʼihu m mgbe niile.
\q1 
\v 4 Ọ bụkwa naanị gị ka m mehiere megide,
\q2 mee ihe ahụ bụ ihe ọjọọ nʼihu gị,
\q1 nke mere na ị bụ onye na-ekpe ikpe ziri ezi mgbe ị na-ekwu okwu,
\q2 na onye ezi omume mgbe ị na-ekpe ikpe.
\q1 
\v 5 Nʼezie, onye mmehie ka m bụ site nʼoge amụrụ m;
\q2 bụrụkwa onye mmehie site nʼoge nne m tụrụ ime m.
\q1 
\v 6 Nʼezie, ị na-achọ eziokwu nʼakụkụ niile zoro ezo;
\q2 ị na-akụziri m amamihe nʼakụkụ niile zoro ezo.
\b
\q1 
\v 7 Were hisọp\f + \fr 51:7 \ft Nʼoge mmemme idebe ihe ọcha, ọ bụ ahịhịa hisọp ka a na-eji efesa ọbara.\f* sachaa m, aga m adị ọcha;
\q2 sachaa m ka m dị ọcha karịa snoo.
\q1 
\v 8 Mee ka m nụrụ olu obi ụtọ na ọṅụ;
\q2 ka okpukpu ndị i gwepịara ṅụrịkwaa.
\q1 
\v 9 Zopu ihu gị nʼebe mmehie m niile dị,
\q2 hichapụkwa mmehie m niile.
\b
\q1 
\v 10 Kee obi dị ọcha nʼime m, O Chineke,
\q2 nwogharịa ezi mmụọ nʼime m.
\q1 
\v 11 Achụpụla m nʼihu gị,
\q2 anapụkwala m Mmụọ Nsọ gị.
\q1 
\v 12 Nyeghachikwa m ọṅụ nke nzọpụta gị,
\q2 ma jiri ezi mmụọ kwagide m.
\b
\q1 
\v 13 Mgbe ahụ, aga m enwe ike izi ndị njehie ụzọ gị,
\q2 ndị mmehie ga-echegharị lọghachikwute gị.
\q1 
\v 14 O Chineke, zọpụta m site nʼikpe ọmụma nke mwụfu ọbara,
\q2 Chineke, gị bụ Chineke Onye nzọpụta m,
\q2 ire m ga-abụ abụ banyere ezi omume gị.
\q1 
\v 15 O, Onyenwe m, meghee ọnụ m,
\q2 ka m kwupụta otuto gị.
\q1 
\v 16 Ị naghị enwe mmasị nʼaja, ma ọ bụghị ya, agaara m eweta ya.
\q2 Ị naghị enwe mmasị nʼaja nsure ọkụ.
\q1 
\v 17 Aja Chineke chọrọ bụ mmụọ tiwara etiwa,
\q2 O Chineke, ị naghị elefu anya,
\q2 nʼobi tiwara etiwa na nke nwere ezi nchegharị.
\b
\q1 
\v 18 Ka ọ masị gị inye Zayọn ọganihu;
\q2 i wulie mgbidi niile nke Jerusalem.
\q1 
\v 19 Mgbe ahụ, a ga-enwe ezi aja,
\q2 aja nsure ọkụ nke ga-atọ gị ụtọ;
\q2 mgbe ahụ, a ga-achụkwa aja ọtụtụ oke ehi nʼelu ebe ịchụ aja gị.
\c 52
\cl Abụ Ọma 52
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ maskil Devid. Nke o bụrụ mgbe Doeg onye Edọm gara gwa Sọl sị, “Devid gara hụ Ahimelek nʼụlọ ya.”
\s1 Ihe na-eche ndị ajọ omume
\q1 
\v 1 Gịnị mere i ji na-anya isi nʼihe ọjọọ, gị nwoke dị ike?
\q2 Gịnị mere na ogologo ụbọchị niile, ị na-anya isi,
\q2 gị onye Chineke na-eleda anya?
\q1 
\v 2 Ire gị na-atụ atụmatụ ịla nʼiyi;
\q2 ọ dị ka agụba dị nkọ,
\q2 gị onye na-ebi ndụ aghụghọ.
\q1 
\v 3 Ị hụrụ ihe ọjọọ nʼanya karịa ihe ọma,
\q2 ị hụrụ okwu ụgha nʼanya karịa eziokwu. \qs Sela\qs*
\q1 
\v 4 O onye ire aghụghọ!
\q2 Ị hụrụ okwu ọbụla nke na-emegide mmadụ nʼanya.
\b
\q1 
\v 5 Nʼezie, Chineke ga-akwatu gị ruo mgbe ebighị ebi.
\q2 Ọ ga-ejide gị, dọpụta gị site nʼụlọ ikwu gị,\f + \fr 52:5 \ft Ya bụ, ebe obibi ya\f*
\q2 ọ ga-ehopukwa gị site nʼala ndị dị ndụ. \qs Sela\qs*
\q1 
\v 6 Ndị ezi omume ga-ahụ ya tụkwaa egwu;
\q2 ha ga-achị ya ọchị na-asị,
\q1 
\v 7 “Ugbu a, lee nwoke ahụ,
\q2 onye jụrụ ime Chineke ebe mgbaba ya.
\q1 Ọ tụkwasịrị obi ya na akụnụba ya nke dị ukwuu.
\q2 O sitekwara na ibibi ndị ọzọ ghọọ onye dị ike!”
\b
\q1 
\v 8 Ma adị m ka osisi oliv,
\q2 nke na-eto na-awasa nʼụlọnsọ ukwu Chineke.
\q1 Ana m atụkwasị obi m nʼịhụnanya Chineke,
\q2 nke na-adịgide ruo mgbe niile ebighị ebi.
\q1 
\v 9 Aga m eto gị ruo mgbe niile ebighị ebi nʼihi ihe i mere;
\q2 aga m eto gị nʼihu ndị gị dị nsọ.
\q1 Olileanya m ga-adị nʼime aha gị,
\q2 nʼihi na aha gị dị mma.
\c 53
\cl Abụ Ọma 53
\d Abụ Ọma nke dịrị onyeisi abụ. Nʼusoro Mahalat. Abụ \tl maskil\tl* Devid.
\s1 Nzuzu nke ndị na-emebi iwu
\q1 
\v 1 Onye nzuzu na-asị nʼime obi ya,
\q2 “Ọ dịghị Chineke ọbụla dị.”
\q1 Ha bụ ndị ajọ omume riri ahụ, ụzọ ha niile bụkwa ihe arụ;
\q2 ọ dịghị onye ọbụla na-eme ezi ihe.
\b
\q1 
\v 2 Chineke sitere nʼeluigwe
\q2 na-ele ụmụ mmadụ anya,
\q1 ịhụ ma ọ ga-achọta onye ọbụla nwere nghọta,
\q2 onye nke na-achọ Chineke.
\q1 
\v 3 Onye ọbụla, nʼotu nʼotu ewezugala onwe ha, ha niile abụrụla ndị ajọ omume riri ahụ;
\q2 ọ dịghị onye ọbụla na-eme ihe ziri ezi,
\q2 ọ dịghị ọ bụladị otu onye.
\b
\q1 
\v 4 Ndị niile na-eme ajọ ihe, ha amaghị ihe?
\b
\q1 Ha na-eripịa ndị m dịka mmadụ si eri nri,
\q2 ha adịghị akpọkukwa Chineke.
\q1 
\v 5 Ma nʼebe ahụ ka ha nọ, nʼọnọdụ oke egwu,
\q2 ebe ọ dịghị ihe egwu na-adịghị.
\q1 Chineke fesasịrị ọkpụkpụ ndị niile megidere gị;
\q2 i mere ka ihere mee ha, nʼihi na Chineke ajụla ha.
\b
\q1 
\v 6 O, a sịkwarị na nzọpụta Izrel ga-esi na Zayọn pụta!
\q2 Mgbe Chineke ga-akpọghachite ndị ya nʼọnọdụ ha,
\q2 ka Jekọb ṅụrịa ọṅụ, ka Izrel nwekwaa obi ụtọ!
\c 54
\cl Abụ Ọma 54
\d Abụ Ọma Devid. Abụ eji ụbọ akwara akpọ. Abụ \tl maskil\tl* Devid. Mgbe ndị Zif gara sị Sọl, “Devid ọ dịghị ezo nʼetiti anyị?”
\s1 Ekpere maka nchebe
\q1 
\v 1 O Chineke, jiri aha gị zọpụta m;
\q2 jirikwa ike gị kpepụta m.
\q1 
\v 2 O Chineke, nụrụ ekpere m;
\q2 gee ntị nʼokwu ọnụ m.
\b
\q1 
\v 3 Ndị m na-amaghị na-ebuso m agha;
\q2 ndị na-eme ihe ike na-achọ ịnapụ m ndụ m,
\q2 ndị na-akpọghị Chineke ihe ọbụla. \qs Sela\qs*
\b
\q1 
\v 4 Nʼezie, Chineke bụ onye inyeaka m;
\q2 onyenwe m bụ onye na-agba m ume.
\b
\q1 
\v 5 Mee ka ihe ọjọọ lọghachikwute ndị na-ekwulu m;
\q2 nʼime ikwesi ntụkwasị obi gị, laa ha nʼiyi.
\b
\q1 
\v 6 Aga m eji onyinye afọ ofufu chụọrọ gị aja;
\q2 O \nd Onyenwe anyị\nd*, aga m eto aha gị, nʼihi na ọ dị mma.
\q1 
\v 7 Nʼihi na ọ gbapụtala m site na nsogbu m niile,
\q2 ọ bụ anya mmeri ka m ji na-ele ndị iro m anya.
\c 55
\cl Abụ Ọma 55
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ eji ụbọ akwara akpọ. Abụ \tl maskil\tl* Devid.
\s1 Ekpere nke onye enyi ya ghọrọ ya aghụghọ
\q1 
\v 1 O Chineke, nụrụ ekpere m,
\q2 agbakwala arịrịọ m nkịtị;
\q2 
\v 2 ṅaa m ntị, zaakwa m.
\q1 Echiche m na-esogbu m; ana m asụkwa oke ude
\q2 
\v 3 nʼihi ihe onye iro m na-ekwu,
\q2 nʼihi ịba mba nke ndị ajọ mmadụ,
\q1 nʼihi na ha na-ewetara m ntaramahụhụ,
\q2 na-akpagbu m nʼiwe ha.
\b
\q1 
\v 4 Obi m nọ nʼọnọdụ oke ihe mgbu nʼime m;
\q2 oke ụjọ nke ọnwụ abịakwasịla m.
\q1 
\v 5 Ịtụ egwu na ahụ ịma jijiji abịakwasịkwala m;
\q2 oke egwu ekpuchiela m.
\q1 
\v 6 Agwara m onwe m okwu sị, “A sịkwarị na m nwere nku dịka nduru!
\q2 Agaara m efelaga ebe ọzọ gaa zuru ike.
\q1 
\v 7 Agaara m efelaga ebe dị anya,
\q2 ga nọrọ nʼọzara; \qs Sela\qs*
\q1 
\v 8 Agaara m eme ngwangwa gaa nʼebe mgbaba m,
\q2 ebe dị anya site nʼebe ifufe siri ike na oke ifufe dị.”
\b
\q1 
\v 9 O Onyenwe anyị, gbagwojuo ndị ajọ omume anya, mee ka ha ghara ịghọta ihe ibe ha na-ekwu,
\q2 nʼihi na ana m ahụ ihe ike na ịlụ ọgụ nʼime obodo.
\q1 
\v 10 Ehihie na abalị, ha na-ejegharị nʼelu mgbidi ya;
\q2 iro na mmegbu dị nʼime ya.
\q1 
\v 11 A na-ahụta akaọrụ ihe ịla nʼiyi nʼime obodo;
\q2 ihe ike na ụgha ewerela ọnọdụ ha nʼime obodo.
\b
\q1 
\v 12 A sị na ọ bụ onye iro ji m eme ihe ọchị,
\q2 apụrụ m ịnagide ya;
\q1 a sịkwa na ọ bụ onye iro na-eweli onwe ya megide m,
\q2 apụrụ m izonarị onwe m site nʼebe ọ nọ.
\q1 
\v 13 Maọbụ gị, nwoke dịka m,
\q2 onye mụ na ya dị na mma, enyi m ọma,
\q1 
\v 14 onye mụ na ya na-enwe mmekọrịta dị ụtọ na mbụ,
\q2 nʼụlọ Chineke,
\q1 ka anyị na-ejegharị
\q2 nʼetiti ọha mmadụ bịara ife ofufe.
\b
\q1 
\v 15 Ka ọnwụ bịakwasị ndị iro m na mberede;
\q2 ka ha rịdaa ala mmụọ na ndụ,
\q2 nʼihi na ihe ọjọọ na-achọta ebe ọnọdụ nʼetiti ha.
\b
\q1 
\v 16 Ma akpọkuru m Chineke,
\q2 \nd Onyenwe anyị\nd* na-azọpụtakwa m.
\q1 
\v 17 Nʼụtụtụ, ma nʼehihie, ma nʼabalị,
\q2 ka m sitere nʼoke ihe mgbu, na-akpọku ya
\q2 ma ọ na-anụkwa olu m.
\q1 
\v 18 Ọ na-agbapụta m, mee ka m ghara imerụ ahụ,
\q2 site nʼagha niile e busoro m,
\q2 nʼagbanyeghị nʼọtụtụ biliri megide m.
\q1 
\v 19 Chineke, onye nọkwasịrị nʼocheeze ya ruo mgbe ebighị ebi,
\q2 onye na-adịghị agbanwe,
\q1 ga-anụ olu ha, taakwa ha ahụhụ,
\q2 nʼihi na ha adịghị atụ egwu Chineke. \qs Sela\qs*
\b
\q1 
\v 20 Onye mụ na ya dị na mma na-emegide ndị enyi ya,
\q2 ọ na-emerụ ọgbụgba ndụ ya ka ọ ghara ịdị nsọ.
\q1 
\v 21 Okwu ọnụ ya dị mụrụmụrụ\f + \fr 55:21 \ft Ya bụ, okwu ire ụtọ\f* ka bọta,
\q2 ma ibu agha juru ya obi;
\q1 okwu ya niile dị nro karịa mmanụ,
\q2 ma ha bụ mma agha e welitere maka ibu agha.
\b
\q1 
\v 22 Tụkwasị \nd Onyenwe anyị\nd* mkpa gị niile,
\q2 ọ ga-agba gị ume;
\q1 ọ gaghị ekwe
\q2 ka ewezuga onye ezi omume.
\q1 
\v 23 Ma gị, O Chineke, ga-adọtu ndị ajọ omume
\q2 nʼime olulu nke jupụtara nʼire ure;
\q1 ndị ogbu mmadụ na ndị aghụghọ
\q2 agaghị ebi ọ bụladị ọkara ndụ ha.
\b
\q1 Ma mụ onwe m, ọ bụ na gị ka m na-atụkwasị obi m.
\c 56
\cl Abụ Ọma 56
\d Abụ Ọma nke dịrị onyeisi abụ. Ọ bụ olu abụ “Nduru nọ nʼosisi Ook dị ebe dị anya.” Abụ nke Devid ka eji agụ ya. Abụ miktam. Mgbe ndị Filistia nọchibidoro ya nʼobodo Gat.
\s1 Ekpere maka mgbapụta
\q1 
\v 1 O Chineke, meere m ebere,
\q2 nʼihi na ndị mmadụ ji ike na-achụso m;
\q2 ogologo ụbọchị niile, ha na-ebu agha imegide m.
\q1 
\v 2 Ogologo ụbọchị niile ndị iro m na-achụso m;
\q2 site na nganga ha, ọtụtụ na-ebu agha megide m.
\b
\q1 
\v 3 Ma mgbe ụjọ na-atụ m, ọ bụ na gị ka m na-atụkwasị obi m.
\q2 
\v 4 Nʼime Chineke onye m na-eto okwu ya,
\q1 nʼime Chineke ka m na-atụkwasị obi; ụjọ agaghị atụ m.
\q2 Gịnị ka mmadụ efu pụrụ ime m?
\b
\q1 
\v 5 Ogologo ụbọchị niile, ha na-asụgharị okwu m kwuru isi;
\q2 oge niile ka ha na-atụ atụmatụ imerụ m ahụ.
\q1 
\v 6 Ha na-agba izu nzuzo na-ezokwa onwe ha,
\q2 ha na-enyochapụta nzọ ụkwụ m niile,
\q2 dịkwa njikere ịnapụ m ndụ m.
\q1 
\v 7 Nʼihi ajọ omume ha, ekwekwala ka ha gbapụ;
\q2 o Chineke, nʼime iwe gị, wedaa mba ndị a niile dị iche iche nʼala.
\b
\q1 
\v 8 Depụta akwa arịrị m;
\q2 chekọtasịa anya mmiri akwa m niile nʼime karama gị.
\q2 Ọ bụ na ha adịghị nʼakwụkwọ ndepụta gị?
\q1 
\v 9 Mgbe m ga-akpọku gị maka enyemaka,
\q2 ndị iro m ga-agbaghachi azụ.
\q2 Site nʼụzọ dị otu a, aga m amara na Chineke nọnyeere m.
\b
\q1 
\v 10 Nʼime Chineke, onye m na-eto okwu ya,
\q2 nʼime \nd Onyenwe anyị\nd*, onye m na-eto okwu ya,
\q1 
\v 11 nʼime Chineke ka m na-atụkwasị obi; ụjọ agaghị atụ m.
\q2 Gịnị ka mmadụ pụrụ ime m?
\b
\q1 
\v 12 O Chineke m, nʼisi m ka nkwa niile m kwere gị dị;
\q2 aga m ewetara gị onyinye ekele m niile.
\q1 
\v 13 Nʼihi na ị zọpụtala m site nʼọnwụ,
\q2 ma napụta ụkwụ m site nʼịsọ ngọngọ,
\q1 ka m nwee ike jegharịa nʼihu Chineke,
\q2 nʼìhè nke ndụ.
\c 57
\cl Abụ Ọma 57
\d Abụ Ọma nke dịrị onyeisi abụ. Nke olu abụ “E bibikwala” Devid. Abụ miktam. Mgbe ọ gbapụrụ ga biri nʼime ọgba nkume nʼihi Sọl.
\s1 Ntụkwasị obi nʼime Chineke
\q1 
\v 1 Meere m ebere, O Chineke, meere m ebere,
\q2 nʼihi na ọ bụ gị ka mkpụrụobi m ji mere ebe mgbaba.
\q1 Ọ bụ na ndo nke nku gị abụọ ka m ga-agbaba
\q2 tutuu ihe mbibi ndị a agafesịa.
\b
\q1 
\v 2 Aga m akpọku Chineke nke kachasị ihe niile elu,
\q2 Chineke na-emezuru m ihe niile na-akpa m mkpa.
\q1 
\v 3 Ọ na-esite nʼeluigwe zidata inyeaka ma zọpụta m
\q2 na-abara ndị ahụ ji ike na-achụ m mba; \qs Sela\qs*
\q2 Chineke na-ezite ịhụnanya ya na ikwesi ntụkwasị obi ya.
\b
\q1 
\v 4 Anọ m nʼetiti ọtụtụ ọdụm;
\q2 amanyere m ka m dina nʼetiti ajọ anụ ọhịa,
\q1 ụmụ mmadụ ndị eze ha dị nkọ dịka àkụ na ùbe,
\q2 ire ha dịkwa nkọ dịka mma agha.
\b
\q1 
\v 5 O Chineke, ka e bulie gị elu karịa eluigwe niile;
\q2 ka ebube gị dị nʼelu ụwa niile.
\b
\q1 
\v 6 Ha gbasaara ụkwụ m ụgbụ,
\q2 ihe mgbu nyịturu m.
\q1 Ha egwuola olulu nʼụzọ m si agafe,
\q2 ma ha onwe ha adabala nʼime ya. \qs Sela\qs*
\b
\q1 
\v 7 Obi m dị njikere, o Chineke,
\q2 obi m dị njikere sikwaa ike;
\q2 aga m abụ abụ, kụkwaa egwu.
\q1 
\v 8 Teta nʼụra mkpụrụobi m!
\q2 Teta, ụbọ akwara na une!
\q2 Aga m akpọte chi ọbụbọ.
\b
\q1 
\v 9 O Onyenwe anyị, aga m eto gị nʼetiti mba niile;
\q2 aga m abụ abụ banyere gị nʼetiti ndị niile dị iche iche.
\q1 
\v 10 Nʼihi na ịhụnanya gị dị ukwuu na-eru na mbara eluigwe;
\q2 ikwesi ntụkwasị obi gị na-erukwa mbara eluigwe.
\b
\q1 
\v 11 O Chineke, ka e bulie gị elu karịa eluigwe;
\q2 ka ebube gị dị nʼelu ụwa niile.
\c 58
\cl Abụ Ọma 58
\d Abụ Ọma nke dịrị onyeisi abụ. Nke olu abụ “E bibikwala.” Abụ Devid. Abụ miktam.
\s1 Ahụhụ nke ndị na-emebi iwu
\q1 
\v 1 Unu ndị na-achị achị, O nweela oge unu na-ekwu ihe ziri ezi?
\q2 O nweela oge unu na-ekpe ikpe ziri ezi nʼetiti mmadụ?
\q1 
\v 2 Mba, nʼime obi unu, unu na-echepụta mmegbu,
\q2 aka unu na-emepụta ihe ike nʼelu ụwa.
\b
\q1 
\v 3 Ọ bụladị site nʼọmụmụ, ndị ajọ omume na-akpafu;
\q2 site nʼime afọ, ha na-akpafu akpafu na-ekwusa okwu ụgha.
\q1 
\v 4 Ha na-agbọpụta nsi nʼọnụ ha dịka agwọ,
\q2 na-emechi ntị ha dịka ajụala ntị chiri,
\q1 
\v 5 nke na-adịghị anụ olu onye mgbaasị na-akpọpụta ya,
\q2 nʼagbanyeghị otu ǹka onye ahụ si dị.
\b
\q1 
\v 6 O Chineke, tijie eze niile dị ha nʼọnụ;
\q2 o \nd Onyenwe anyị\nd*, dọpụta eze ọdụm ndị a!
\q1 
\v 7 Mee ka ha sọfuo dịka mmiri na-asọ asọ;
\q2 mgbe ha na-eseti ụta ha, mee ka ọnụ àkụ ha gbajie.
\q1 
\v 8 Dịka ejula nke na-agbaze mgbe ọ na-aga nʼụzọ ya;
\q2 dịka nwa nwụrụ nʼafọ nne ya, ka ha ghara ịhụ anyanwụ.
\b
\q1 
\v 9 Tupu ite unu amata okpomọkụ nke osisi ogwu,
\q2 ma ha dị ndụ, ma ha kpọnwụrụ akpọnwụ, a ga-azachapụ ndị ajọ omume.
\q1 
\v 10 Ndị ezi omume ga-enwe obi ụtọ mgbe a bọọrọ ha ọbọ,
\q2 mgbe ha ga-asacha ụkwụ ha nʼime ọbara ndị ajọ omume.
\q1 
\v 11 Mgbe ahụ, ndị mmadụ ga-ekwu sị,
\q2 “Nʼezie, a na-akwụghachi ndị ezi omume ụgwọ;
\q2 nʼezie, e nwere Chineke onye na-ekpe ụwa ikpe.”
\c 59
\cl Abụ Ọma 59
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ Devid. Abụ miktam nke eji olu abụ “E bibikwala,” abụ. Mgbe Sọl zipụrụ ndị ikom ka e chee ụlọ Devid nche nʼihi igbu ya.
\s1 Ekpere maka nnapụta
\q1 
\v 1 O Chineke, site nʼaka ndị iro m gbapụta m,
\q2 chebe m site nʼaka ndị na-ebili imegide m.
\q1 
\v 2 Gbapụta m site nʼaka ndị na-eme ajọ ihe,
\q2 zọpụtakwa m site nʼaka ndị ogbu mmadụ.
\b
\q1 
\v 3 Lee ka ha siri zoo onwe ha nʼihi ịnapụ m ndụ!
\q2 Ndị na-eme ihe ike na-agba izu megide m,
\q2 o \nd Onyenwe anyị\nd*, ma ọ bụghị nʼihi ihe m mere maọbụ mmehie m.
\q1 
\v 4 Mgbe ọ na-adịghị ihe ọjọọ m mere, ma lee ha dị njikere imegide m.
\q2 Bilie, bịa nyere m aka; lee ihe ọjọọ dakwasịrị m!
\q1 
\v 5 Gị, \nd Onyenwe anyị\nd* Chineke Onye pụrụ ime ihe niile,
\q2 gị onye bụ Chineke nke Izrel,
\q1 kpọtee onwe gị ịta mba niile dị iche iche ahụhụ;
\q2 e gosikwala ndị na-ezube nzube ọjọọ obi ebere. \qs Sela\qs*
\b
\q1 
\v 6 Nʼanyasị, ha na-alaghachi,
\q2 na-eme mkpọtụ dịka ụmụ nkịta
\q2 mgbe ha na-akpagharị nʼime obodo.
\q1 
\v 7 Lee ihe ha si nʼọnụ ha na-aghụpụta,
\q2 okwu si nʼọnụ ha na-agbụpụta dị nkọ dịka mma agha,
\q2 ha na-asịkwa, “Onye pụrụ ịnụ ihe anyị na-ekwu?”
\q1 
\v 8 Ma gị \nd Onyenwe anyị\nd*, na-achị ha ọchị;
\q2 ị na-akwa mba ndị a niile emo.
\b
\q1 
\v 9 O, gị onye bụ ike m, ana m ele anya gị;
\q2 gị, o Chineke, bụ ebe mgbaba m e wusiri ike.
\q2 
\v 10 Chineke m, onye m tụkwasịrị obi.
\b
\q1 Chineke ga-ebutere m ụzọ
\q2 mekwaa ka m chịa ndị niile na-ekwulu m ọchị.
\q1 
\v 11 O Onyenwe anyị na ọta anyị, egbukwala ha,
\q2 ma ọ bụghị ya, ndị m ga-echefu.
\q1 Were ike gị mee ka ha wagharịa,\f + \fr 59:11 \ft Were ike gị hopu ha\f*
\q2 wedakwaa ha nʼala.
\q1 
\v 12 Ka e jide ha nʼime nganga ha,
\q2 nʼihi mmehie si ha nʼọnụ na-apụta,
\q2 na nʼihi okwu ọnụ ha.
\q1 Nʼihi okwu ọbụbụ ọnụ ha na okwu ụgha ha,
\q2 
\v 13 jiri iwe ọkụ repịa ha,
\q2 repịa ha ruo mgbe ha ga-aghọ ntụ.
\q1 Mgbe ahụ, a ga-amata ruo na nsọtụ nke ụwa,
\q2 na Chineke na-achị Jekọb.
\b
\q1 
\v 14 Nʼanyasị ha na-alaghachi;
\q2 na-eme mkpọtụ dịka ụmụ nkịta,
\q2 mgbe ha na-akpagharị nʼime obodo.
\q1 
\v 15 Ha na-awagharị na-achọ nri,
\q2 na-etikwa mkpu ma ọ bụrụ na afọ ejughị ha.
\q1 
\v 16 Ma aga m abụ abụ banyere ike gị,
\q2 nʼụtụtụ aga m abụ abụ banyere ịhụnanya gị;
\q1 ị bụ ebe mgbaba m e wusiri ike,
\q2 ebe mgbaba m nʼoge nsogbu.
\b
\q1 
\v 17 O, gị onye bụ ike m, ana m abụku gị abụ otuto;
\q2 gị, o Chineke, bụ ebe mgbaba m e wusiri ike,
\q2 Chineke m, onye m na-adabere.
\c 60
\cl Abụ Ọma 60
\d Abụ Ọma nke dịrị onyeisi Abụ. Ọ bụ olu abụ eji ekwe “Okoko lili nke Ọgbụgba Ndụ.” Abụ miktam nke Devid maka izi ihe. Mgbe ọ lụsoro Aram Naharaim na Aram Zoba ọgụ, nakwa mgbe Joab lọghachitara, tigbuo narị ndị Edọm iri nʼabụọ na Ndagwurugwu Nnu.
\s1 Ekpere maka nnapụta
\q1 
\v 1 O Chineke, ị jụla anyị, ị tịwawo anyị nʼike;
\q2 i wesola anyị iwe, ugbu a, kpọghachi anyị.
\q1 
\v 2 I meela ka ala a maa jijiji, ị dọwakwala ya;
\q2 mezie ntiwa ya niile, nʼihi na ọ na-ama jijiji.
\q1 
\v 3 I meela ka ndị gị gabiga ọnọdụ ihe isi ike;
\q2 i nyela anyị mmanya nke mere ka anyị na-adagharị.
\q1 
\v 4 Ma nye ndị na-atụ egwu gị, i weliela otu ọkọlọtọ
\q2 nke a ga-agbasa nʼihi eziokwu imegide ụta nke ndị iro. \qs Sela\qs*
\b
\q1 
\v 5 Were aka nri gị zọpụta anyị ma nyere anyị aka,
\q2 ka a gbapụta ndị ị hụrụ nʼanya.
\q1 
\v 6 Chineke esitela nʼịdị nsọ ya kwuo, sị,
\q2 “Nʼọnọdụ ọṅụ nke mmeri, aga m ekesa Shekem,\f + \fr 60:6 \ft Shekem bụ isi obodo ọchịchị mbụ ndị Izrel. \xt Jen 12:6\xt*\f*
\q2 tụkwaa Ndagwurugwu Sukọt nʼihe ọtụtụ nyepụ ya.
\q1 
\v 7 Gilead bụ nke m,\f + \fr 60:7 \ft Gilead, bụ ala ndị dị nʼakụkụ ọwụwa anyanwụ obodo ahụ. \xt Jos 13:24-32\xt*\f* otu a kwa, Manase bụkwa nke m;\f + \fr 60:7 \ft Manase, bụkwa ala ndị dị nʼakụkụ ọwụwa anyanwụ obodo ahụ. \xt Jos 13:24-32\xt*\f*
\q2 Ifrem bụ okpu igwe m,
\q2 Juda bụ mkpara eze m.
\q1 
\v 8 Moab bụ efere ịkwọ aka m,
\q2 aga m atụsa akpụkpọụkwụ m nʼelu Edọm;
\q2 nʼelu isi Filistia, ana m eti mkpu mmeri.”
\b
\q1 
\v 9 Onye ga-akpọrọ m gaa nʼobodo e wusiri ike?
\q2 Onye ga-edu m gaa Edọm?
\q1 
\v 10 Ọ bụghị gị, O Chineke? Gị onye jụrụ anyị,
\q2 onye na-adịghị esokwa ndị agha anyị aga agha?
\q1 
\v 11 Nyere anyị aka ka anyị pụọ nʼaka ndị iro,
\q2 nʼihi na inyeaka mmadụ bụ ihe efu.
\q1 
\v 12 Site na Chineke, anyị ga-enwe mmeri,
\q2 ọ ga-azọpịa ndị iro anyị niile nʼala.
\c 61
\cl Abụ Ọma 61
\d Abụ Ọma nke dịrị onyeisi abụ. Abụ ọma Devid nke eji ụbọ akwara akpọ.
\s1 Ekpere nke onye nọ na nsogbu
\q1 
\v 1 Nụrụ akwa m, O Chineke,
\q2 gee ntị nʼekpere m.
\b
\q1 
\v 2 Ana m akpọku gị site na nsọtụ nke ụwa,
\q2 ana m akpọku gị mgbe obi m na-ada mba;
\q2 duru m gaa nʼoke nkume ahụ nke karịrị m elu.
\q1 
\v 3 Nʼihi na ị bụrịị ebe mgbaba m,
\q2 na ụlọ ahụ dịkarịrị elu, sie ike imegide onye iro ahụ.\f + \fr 61:3 \ft \xt Ilu 18:10\xt*\f*
\b
\q1 
\v 4 Ọ na-agụ m ibi nʼụlọ ikwu gị ruo mgbe ebighị ebi,
\q2 ka m gbaba, zere ndụ nʼokpuru nku gị abụọ. \qs Sela\qs*
\q1 
\v 5 Nʼihi na gị onwe gị, Chineke, anụla nkwa niile m kwere;
\q2 i nyela m ihe nketa nke ndị na-atụ egwu aha gị.
\b
\q1 
\v 6 Tụkwasị ọtụtụ ụbọchị na ndụ eze,
\q2 mee ka afọ ya ruo ọtụtụ ọgbọ.
\q1 
\v 7 Kwere ka ọ nọrọ nʼocheeze nʼihu Chineke ruo mgbe ebighị ebi;
\q2 zidata ịhụnanya gị na ikwesi ntụkwasị obi gị, ka ha na-echezikwa ya.
\b
\q1 
\v 8 Mgbe ahụ, aga m abụ abụ otuto nye aha gị, ruo mgbe ebighị ebi.
\q2 Aga m emezukwa nkwa m kwere gị ụbọchị niile.
\c 62
\cl Abụ Ọma 62
\d Abụ Ọma nke dịrị onyeisi abụ. Maka Jedutun. Abụ Ọma Devid.
\s1 Ịnọgide nʼokwukwe
\q1 
\v 1 Ọ bụ naanị nʼime Chineke ka mkpụrụobi m na-achọta izuike.
\q2 Nzọpụta m na-esite na ya na-abịa.
\q1 
\v 2 Naanị ya bụ oke nkume m na nzọpụta m;
\q2 ọ bụ ebe mgbaba m e wusiri ike, agaghị m ama jijiji nʼọnọdụ m.
\b
\q1 
\v 3 Ruo ole mgbe ka unu ga-anọgide na-ebuso agha megide nwoke a?
\q2 Unu niile, unu chọrọ ịkwatu ya,
\q2 ebe ọ bụ naanị mgbidi na-ada ada, mgbidi na-esighị ike e ji osisi wuo?
\q1 
\v 4 Ha ekpebiela
\q2 isite nʼọnọdụ ya dị elu kwatuo ya;
\q2 okwu ụgha na-atọ ha ụtọ.
\q1 Ha na-eji ọnụ ha na-agọzi,
\q2 ma nʼime obi ha, ha na-abụ ọnụ. \qs Sela\qs*
\b
\q1 
\v 5 O mkpụrụobi m, chọta ezumike naanị nʼime Chineke;
\q2 olileanya m na-esite na ya na-abịa.
\q1 
\v 6 Naanị ya bụ oke nkume m, na onye nzọpụta m.
\q2 Naanị ya kwa bụ ebe mgbaba m e wusiri ike, agaghị m ama jijiji nʼọnọdụ m.
\q1 
\v 7 Nzọpụta m na nsọpụrụ m dabeere na Chineke,\f + \fr 62:7 \ft Maọbụ, \fqa Chineke nke kachasị ihe niile elu, bụ nzọpụta m na ugwu m\f*
\q2 Ọ bụ oke nkume m, ebe mgbaba m.
\q1 
\v 8 Tụkwasịnụ ya obi mgbe niile, unu ndị mmadụ;
\q2 kwupụtaranụ ya obi unu,
\q2 nʼihi na Chineke bụ ebe mgbaba anyị. \qs Sela\qs*
\b
\q1 
\v 9 Ndị nta nʼetiti ụmụ mmadụ bụ naanị otu nkuume,
\q2 ndị ukwu bụ naanị ụgha;
\q1 ọ bụrụ na a tụọ ha nʼihe ọtụtụ, ha bụ ihe efu;
\q2 ha niile bụ naanị otu nkuume.
\q1 
\v 10 Unu atụkwasịla obi unu nʼiji aka ike kpata ego,
\q2 maọbụ tụkwasị olileanya unu nʼihe e zuru ezu;
\q1 akụ unu nwere ike mụbaa,
\q2 unu atụkwasịla ha obi.
\b
\q1 
\v 11 Chineke ekwuola otu ihe,
\q2 ihe abụọ ka m nụrụ:
\q1 “Na gị, O Chineke, dị ike,
\q2 
\v 12 na gị, Onyenwe anyị, jupụtara nʼịhụnanya.
\q1 Nʼezie, ị ga-akwụghachi onye ọbụla
\q2 dịka ọrụ ya si dị.”
\c 63
\cl Abụ Ọma 63
\d Abụ Ọma Devid, mgbe ọ nọ nʼọzara Juda.
\s1 Onye ihe Chineke na-agụsị agụụ ike
\q1 
\v 1 O Chineke, ị bụ Chineke m,
\q2 e ji m obi m niile na-achọ gị;
\q1 akpịrị na-akpọ mkpụrụobi m nkụ,
\q2 anụ ahụ m na-achọsi gị ike,
\q1 nʼala kpọrọ nkụ na nke ịda mba
\q2 ebe mmiri na-adịghị nʼime ya.
\b
\q1 
\v 2 Ahụla m gị nʼụlọnsọ gị,
\q2 hụkwa ike gị na ebube gị.
\q1 
\v 3 Nʼihi na ịhụnanya gị dị mma karịa ndụ,
\q2 aga m eji egbugbere ọnụ m jaa gị mma.
\q1 
\v 4 Ogologo ụbọchị m niile ka m ga-eto gị,
\q2 aga m eweli aka m abụọ elu kpọkuo aha gị.
\q1 
\v 5 Mkpụrụobi m ga-enwe afọ ojuju dịka onye ji ezi nri rijuo afọ;
\q2 aga m eji egbugbere ọnụ jupụtara nʼabụ too gị.
\b
\q1 
\v 6 Nʼelu ihe ndina m, ana m echeta gị,
\q2 ana m atụgharị uche nʼihe banyere gị, ogologo abalị niile.
\q1 
\v 7 Nʼihi na ị bụ onye inyeaka m,
\q2 ana m abụ abụ nʼokpuru ndo nke nku gị.
\q1 
\v 8 Mkpụrụobi m na-arapara gị nʼahụ;
\q2 aka nri gị na-ejigide m.
\b
\q1 
\v 9 A ga-ala ndị na-achọ ndụ m nʼiyi;
\q2 ha ga-arịda ruo ebe omimi nke ụwa.
\q1 
\v 10 A ga-eji mma agha laa ha nʼiyi,
\q2 ha ga-abụkwa nri nye nkịta ọhịa.
\b
\q1 
\v 11 Ma eze ga-aṅụrị ọṅụ nʼime Chineke;
\q2 ndị niile na-eji aha Chineke aṅụ iyi ga-eto ya,
\q2 ma a ga-eme ka ọnụ ndị niile na-agha ụgha dere duu.
\c 64
\cl Abụ Ọma 64
\d Abụ Ọma dịrị onyeisi abụ. Abụ Ọma Devid.
\s1 Ekpere maka nchekwa
\q1 
\v 1 Nụrụ olu m O Chineke, mgbe m na-akọsara gị ihe na-esogbu m.
\q2 Chebe ndụ m site nʼaka ndị iro m.
\b
\q1 
\v 2 Zopu m pụọ nʼizu nzuzo niile nke ndị ọjọọ,
\q2 site nʼatụmatụ ndị na-eme ajọ ihe.
\q1 
\v 3 Ha na-amụ ire ha dịka e si amụ mma agha,
\q2 na-agbapụ okwu dịka àkụ ọjọọ.
\q1 
\v 4 Ha na-agba onye na-enweghị ihe o mere àkụ site nʼebe nzuzo,
\q2 na mberede ka ha na-agba ya, na-atụghị egwu.
\b
\q1 
\v 5 Ha na-agbarịta ibe ha ume na-atụmatụ ọjọọ,
\q2 ha na-ekwu banyere isi ọnya ha na nzuzo,
\q2 ha na-asị, “Onye ga-ahụ ya\f + \fr 64:5 \ft Maọbụ, \fqa onye ga-ahụ anyị\f*?”
\q1 
\v 6 Ha na-atụpụta atụmatụ ọjọọ na-asị,
\q2 “Anyị echepụtala atụmatụ zuruoke!”
\q2 Nʼezie, uche na obi mmadụ dị aghụghọ.
\b
\q1 
\v 7 Ma Chineke ga-agba ha àkụ,
\q2 na mberede ka a ga-etida ha.
\q1 
\v 8 Ọ ga-atụgharị okwu ọnụ ha megide ha,
\q2 mee ka ha laa nʼiyi;
\q2 ndị niile hụrụ ha ga-efufe isi ha nʼịkwa emo.
\q1 
\v 9 Mmadụ niile ga-atụ egwu,
\q2 ha ga-ekwupụta ọrụ niile nke Chineke,
\q2 ma tụgharịa uche nke ọma banyere ihe o mere.
\b
\q1 
\v 10 Ndị ezi omume ga-aṅụrị ọṅụ nʼime \nd Onyenwe anyị\nd*,
\q2 ha ga-agbabakwa nʼime ya;
\q2 ndị niile obi ha ziri ezi ga-anyakwa isi nʼime ya.
\c 65
\cl Abụ Ọma 65
\d Abụ Ọma dịrị onyeisi abụ. Abụ Ọma Devid. Otu Abụ.
\s1 Ịdị mma na ịdị ike nke Chineke
\q1 
\v 1 I kwesiri otuto, O Chineke, nʼime Zayọn;
\q2 ọ bụ gị ka anyị ga-emezuru nkwa anyị,
\q1 
\v 2 O gị onye na-anụ ekpere,
\q2 ọ bụ gị ka mmadụ niile ga-abịakwute,\f + \fr 65:2 \ft \xt Aịz 66:23\xt*\f*
\q1 
\v 3 Mgbe mmehie na-anyịgbu anyị,
\q2 ị gbaghara anyị njehie anyị niile.
\q1 
\v 4 Ngọzị na-adịrị ndị ahụ ị họpụtara,
\q2 ka ha bịaruo nso, ibi nʼebe obibi gị!
\q1 E ji ọtụtụ ezi ihe nke ụlọ gị, nke ụlọnsọ ukwuu gị,
\q2 mee ka afọ ju anyị.
\b
\q1 
\v 5 O Chineke, Onye nzọpụta anyị,
\q2 i ji ọrụ ezi omume dị oke egwu na-aza anyị,
\q1 ị bụ olileanya ndị niile bi na nsọtụ nke ụwa,
\q2 na osimiri niile dị ebe dị anya,
\q1 
\v 6 onye ji ike ya kpụọ ugwu niile,
\q2 ebe i yikwasịrị onwe gị ike dịka ngwa agha,
\q1 
\v 7 onye mere ka ụda olu oke osimiri niile
\q2 na ụda olu ebili mmiri,
\q2 na ọgbaaghara mba niile deere duu.
\q1 
\v 8 Ụwa niile jupụtara nʼịtụnanya nʼihi ọrụ ebube gị niile,
\q2 nʼebe chi na-abọ, ebe anyanwụ na-ada,
\q2 ka ị na-akpọlite abụ ọṅụ.
\b
\q1 
\v 9 Ị na-elekọta ala na-agba ya mmiri;
\q2 ị na-eme ka ọ bụrụ ala dị mma.
\q1 Isi iyi Chineke adịghị ata ata,
\q2 nʼihi inye ndị mmadụ mkpụrụ ubi,
\q2 nʼihi na ọ bụ otu a ka ị chọrọ ka ọ dịrị.
\q1 
\v 10 Ị na-eme ka mmiri jupụta nʼala a kọrọ akọ mee ka elu aja a kọrọ akọ dị larịị;
\q2 ị na-eji mmiri ozuzo eme ka ọ dị nro, na-agọzikwa ihe ndị akụnyere na ya.
\q1 
\v 11 Ị na-eji owuwe ihe ubi bara ụba kpukwasị afọ ọbụla dịka okpueze,
\q2 ụgbọ na-ebu ihe owuwe ubi na-ejubiga oke.
\q1 
\v 12 Ala ebe ahịhịa na-epu nʼọzara na-ejupụta nʼahịhịa ndụ,
\q2 e yikwasịrị ugwu niile obi ụtọ dịka uwe.
\q1 
\v 13 E were igwe anụ ụlọ kpuchie nʼelu ala niile ebe ahịhịa dị ndụ puru,
\q2 ọka kpuchikwara ndagwurugwu niile;
\q2 ha na-eti mkpu ọṅụ na-abụkwa abụ.
\c 66
\cl Abụ Ọma 66
\d Abụ dịrị onyeisi abụ. Otu Abụ. Abụ Ọma.
\s1 Abụ ekele
\q1 
\v 1 Ụwa niile, jirinụ ọṅụ tikuo Chineke!
\q2 
\v 2 Bụọ abụ banyere ebube aha ya;
\q2 meenụ ka otuto ya bụrụ ihe dị ebube!
\q1 
\v 3 Gwa Chineke okwu sị ya, “Lee ka ọrụ gị niile si dị oke egwu!
\q2 Ike gị dị nnọọ ukwu,
\q2 ya mere ndị iro gị, na-ada nʼihu gị nʼihi ụjọ.
\q1 
\v 4 Ndị niile bi nʼụwa na-akpọ isiala nye gị;
\q2 ha na-abụku gị abụ otuto,
\q2 ha na-abụ abụ otuto nye aha gị.” \qs Sela\qs*
\b
\q1 
\v 5 Bịa lee ihe Chineke mere,
\q2 ụdị ọrụ oke egwu ọ na-arụ nʼihi mmadụ!
\q1 
\v 6 O mere ka osimiri ghọọ ala akọrọ,\f + \fr 66:6 \ft \xt Ọpụ 14:22\xt*\f*
\q2 ha ji ụkwụ si nʼetiti osimiri gafee\f + \fr 66:6 \ft \xt Jos 3:14-16\xt*\f*;
\q2 bịanụ ka anyị ṅụrịa nʼime ya.
\q1 
\v 7 Ọ na-achị ruo mgbe ebighị ebi site nʼike ya,
\q2 anya ya na-elekwa mba niile,
\q2 ka ndị nnupu isi ghara ịfụlị onwe ha elu megide ya. \qs Sela\qs*
\b
\q1 
\v 8 Toonu Chineke anyị, unu mmadụ niile,
\q2 kwere ka a nụ ụda otuto ya;
\q1 
\v 9 O chebela ndụ anyị,
\q2 ma mee ka ụkwụ anyị ghara ịmịchapụ.
\q1 
\v 10 Nʼihi na ọ bụ gị, O Chineke, nwara anyị;
\q2 ị nụchara anyị dịka ọlaọcha.
\q1 
\v 11 Ị kpọbatara anyị nʼụlọ mkpọrọ,
\q2 ma bokwasị ibu dị arọ nʼazụ anyị.
\q1 
\v 12 I kwere ka ndị mmadụ rịa anyị elu;
\q2 anyị esitela nʼime ọkụ na nʼime mmiri gafee.
\q2 Ị kpọbatala anyị ebe anyị nwezuru ihe niile.
\b
\q1 
\v 13 Aga m e ji aja nsure ọkụ bata nʼime ụlọnsọ ukwu gị,
\q2 imezu nkwa m kwere gị
\q1 
\v 14 nʼihi na nke a bụ ihe m ji ọnụ m kwuo,
\q2 ọ bụkwa nke a ka egbugbere ọnụ m kwupụtara na m ga-eme nʼoge nsogbu m.
\q1 
\v 15 Aga m eji anụ ndị gbara abụba chụọrọ gị aja,
\q2 ya na aja onyinye nke ọtụtụ ebule;
\q2 Aga m achụkwa aja onyinye nke ọtụtụ oke ehi na mkpi. \qs Sela\qs*
\b
\q1 
\v 16 Bịanụ nụrụ, unu niile na-atụ egwu Chineke;
\q2 ka m kọọrọ unu ihe o meere m.
\q1 
\v 17 Eji m ọnụ m kpọkuo ya;
\q2 otuto ya dị m nʼire.
\q1 
\v 18 Ọ bụrụ na mmehie na-amasị m nʼime obi m,
\q2 Onyenwe anyị agaraghị ege m ntị;
\q1 
\v 19 ma Chineke gere ntị nʼezie,
\q2 nụrụkwa olu arịrịọ m.
\q1 
\v 20 Otuto dịrị Chineke,
\q2 onye na-ajụghị ekpere m
\q2 maọbụ ghara izi m ịhụnanya ya!
\c 67
\cl Abụ Ọma 67
\d Abụ Ọma dịrị onyeisi abụ. Abụ eji ụbọ akwara akpọ. Abụ Ọma. Otu Abụ.
\s1 Abụ ekele
\q1 
\v 1 Ka Chineke meere anyị amara ma gọzie anyị,
\q2 ma mee ka ihu ya chakwasị anyị,\f + \fr 67:1 \ft \xt Ọnụ 6:25\xt*\f*\qs Sela\qs*
\q1 
\v 2 Ka a mara ụzọ gị niile nʼụwa,
\q2 marakwa nzọpụta gị nʼetiti mba niile.
\b
\q1 
\v 3 Ka mmadụ niile too gị, O Chineke;
\q2 ka mmadụ niile too gị.
\q1 
\v 4 Ka mba niile ṅụrịa ma bụọ abụ ọṅụ,
\q2 nʼihi na ị na-eji ikpe ziri ezi na-achị ndị mmadụ,
\q2 na-edukwa mba niile nke ụwa. \qs Sela\qs*
\q1 
\v 5 Ka mmadụ niile too gị, O Chineke;
\q2 ka mmadụ niile too gị.
\b
\q1 
\v 6 Mgbe ahụ, ala ga-amịpụta ihe owuwe ubi ya,
\q2 Chineke, onye bụ Chineke anyị, ga-agọzikwa anyị.
\q1 
\v 7 Chineke ga-agọzi anyị,
\q2 nsọtụ niile nke ụwa ga-atụ egwu ya.
\c 68
\cl Abụ Ọma 68
\d Abụ Ọma dịrị onyeisi abụ. Nke Devid. Abụ Ọma. Otu Abụ.
\s1 Chineke nke ụwa niile
\q1 
\v 1 Ka Chineke bilie, ka ndị iro ya bụrụ ndị a chụsasịrị;
\q2 ka ndị iro ya site nʼihu ya gbalaga.
\q1 
\v 2 Dịka ikuku si achụsa anwụrụ ọkụ,\f + \fr 68:2 \ft \xt Hos 13:3\xt*\f* sikwa otu a chụsaa ha.
\q2 Dịka mmanụ na-ehi ụra si agbaze nʼọkụ,
\q2 ka ndị na-eme ihe ọjọọ laa nʼiyi nʼihu Chineke.
\q1 
\v 3 Ka ndị ezi omume bụrụ ndị nwere obi ụtọ,
\q2 ma ṅụrịa nʼihu Chineke;
\q2 ka ha bụrụ ndị nwere obi ụtọ, jupụtakwa nʼọṅụ.
\b
\q1 
\v 4 Bụkuo Chineke abụ, bụkuonụ aha ya abụ otuto,
\q2 toonu onye na-agba igwe ojii dịka ịnyịnya,
\q2 \nd Onyenwe anyị\nd* bụ aha ya, ṅụrịa ọṅụ nʼihu ya.
\q1 
\v 5 Ọ bụ nna ndị nke na-enweghị nna, onye na-ekpechitere ndị di ha nwụrụ anwụ ọnụ ha,
\q2 onye a bụ Chineke, onye bi nʼebe ya dị nsọ.
\q1 
\v 6 Chineke na-eme ka ndị naanị ha nọ nwee ezinaụlọ,
\q2 ọ na-eji ịbụ abụ dupụta ndị nọ nʼụlọ mkpọrọ,
\q2 ma ndị nnupu isi ka ọ na-eme ka ha biri, nʼala kpọrọ nkụ.
\b
\q1 
\v 7 Mgbe i buteere ndị gị ụzọ, O Chineke,
\q2 mgbe i gabigara nʼala tọgbọrọ nʼefu, \qs Sela\qs*
\q1 
\v 8 elu ụwa mara jijiji, eluigwe wụpụrụ mmiri ozuzo,
\q2 nʼihu Chineke, Onye Saịnaị,
\q2 nʼihu Chineke, Chineke nke Izrel.
\q1 
\v 9 I nyere mmiri ozuzo nʼebe ọ dị ukwuu, O Chineke,
\q2 i tutere ihe nketa gị nke ike gwụrụ.
\q1 
\v 10 Ndị gị biri nʼime ya,
\q2 site nʼoke akụnụba gị, O Chineke, ị rọpụtaara ndị ogbenye mkpa ha.
\b
\q1 
\v 11 Onyenwe anyị kpọsara okwu ahụ,
\q2 ọnụọgụgụ ndị inyom kwusara ya bụ igwe dị ọtụtụ;
\q1 
\v 12 ndị eze na ndị agha ha ji ọsọ gbalaa;
\q2 ndị mmadụ kere ihe a dọtara nʼagha, nʼime ọmụma ụlọ ikwu.
\q1 
\v 13 Ọ bụladị mgbe ị na-arahụ ụra nʼetiti ọgba atụrụ,
\q2 nku abụọ nke nduru m bụ ihe e ji ọlaọcha kpuchie,
\q2 jirikwa ọlaedo nke na-enwuke kpuchie abụba ya.
\q1 
\v 14 Mgbe Onye pụrụ ime ihe niile chụsasịrị ndị eze bi nʼala a,
\q2 ọ dị ka snoo dara nʼelu Zalmon.
\b
\q1 
\v 15 Ugwu Bashan, ugwu mara mma nke ukwuu,
\q2 ugwu Bashan, ugwu nwere nʼelu ya ọtụtụ ugwu dị iche iche.
\q1 
\v 16 Gị ugwu nwere ọtụtụ ugwu, gịnị mere i ji ele anya site nʼekworo
\q2 nʼugwu Chineke họọrọ ị bụ ebe ọ ga-anọ chịa,
\q2 ebe \nd Onyenwe anyị\nd* nʼonwe ya ga-ebi, ruo ebighị ebi?
\q1 
\v 17 Ọnụọgụgụ ụgbọ agha Chineke dị iri puku kwụrụ puku, a pụghị ịgụta ha;
\q2 ha dịkwa puku kwụrụ puku;
\q2 Onyenwe anyị sitere Saịnaị bata nʼụlọnsọ ya.
\q1 
\v 18 Mgbe i rigoro gaa nʼelu,\f + \fr 68:18 \ft \xt Mak 16:19; Ọrụ 1:9; Kọl 3:1\xt*\f*
\q2 i duuru ndị a dọtara nʼagha\f + \fr 68:18 \ft \xt Nkp 5:12; Efe 4:8\xt*\f*;
\q2 ị natara onyinye dị iche iche nʼaka ndị mmadụ,
\q1 ọ bụladị nʼaka ndị na-enupu isi,
\q2 ka gị, O \nd Onyenwe anyị\nd* Chineke, biri nʼebe ahụ.
\b
\q1 
\v 19 Otuto dịrị Onyenwe anyị, Chineke anyị, na Onye Nzọpụta anyị,
\q2 Onye na-ebu ibu arọ anyị ụbọchị niile. \qs Sela\qs*
\q1 
\v 20 Chineke anyị bụ Chineke na-azọpụta;
\q2 mgbapụta pụọ nʼọnwụ na-esite nʼaka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*.
\q1 
\v 21 Nʼezie, Chineke ga-egwepịa isi ndị iro ya niile,
\q2 isi ndị niile na-aga nʼihu ibi ndụ mmehie.
\q1 
\v 22 Onyenwe anyị kwuru sị, “Aga m esite na Bashan kpọlata ha,
\q2 aga m adọpụta ha site nʼebe omimi nke osimiri,
\q1 
\v 23 ka unu nwee ike saa ụkwụ unu nʼime ọbara ndị iro unu,
\q2 ka ire nkịta unu niile ketakwa oke nke ha.”
\b
\q1 
\v 24 O Chineke, ahụla igwe ahịrị mmadụ ndị na-eso gị,
\q2 bụ igwe ahịrị mmadụ nke so Chineke m, na Eze m na-aba nʼebe nsọ ahụ.
\q1 
\v 25 Ndị na-abụ abụ nọ nʼihu, ndị na-eti egwu, na-eso ha nʼazụ;
\q2 ụmụ agbọghọ na-akpọ ụbọ sokwa ha.
\q1 
\v 26 Too Chineke nʼetiti nzukọ ukwuu ahụ;
\q2 toonu \nd Onyenwe anyị\nd* nʼetiti nzukọ ụmụ Izrel.
\q1 
\v 27 Lee Benjamin bụ agbụrụ dịkarịsịrị nta, ka ọ na-edu ha,
\q2 lekwaa igwe ụmụ ndị eze Juda
\q2 na nke Zebụlọn na Naftalị.
\b
\q1 
\v 28 O Chineke, kpọlite ike gị;
\q2 mee ka ike gị pụta ìhè, O Chineke, dịka i mere na mbụ.
\q1 
\v 29 Nʼihi ụlọnsọ ukwu gị nke dị na Jerusalem,
\q2 ndị eze ga-ewetara gị onyinye dị iche iche.
\q1 
\v 30 Baara anụ ọhịa ahụ zoro nʼetiti riidi mba,
\q2 igwe oke ehi nọ nʼetiti ụmụ ehi nke mba niile.
\q1 Site na nweda nʼala, ka o wetara gị ogbe ọlaọcha.
\q2 Chụsasịa mba niile, bụ ndị na-enwe mmasị nʼibu agha.
\q1 
\v 31 Ndị nnọchi anya obodo, ga-esite nʼIjipt bịa,
\q2 Kush ga-etinye onwe ya nʼokpuru Chineke.
\b
\q1 
\v 32 Bụkuo Chineke abụ, unu alaeze niile nke ụwa,
\q2 bụkuo Onyenwe anyị abụ otuto, \qs Sela\qs*
\q1 
\v 33 Bụọ abụ nye onye na-agba ịnyịnya nʼeluigwe, e, ọ bụladị eluigwe nke dịrị site na mgbe ochie,
\q2 onye olu ike ya dịka egbe eluigwe.
\q1 
\v 34 Kwusaa ike Chineke,
\q2 onye ịdị ukwuu nke ịma mma ya na-ekpuchi Izrel,
\q2 onye ike ya dị nʼeluigwe.
\q1 
\v 35 O Chineke, ị dị oke egwu nʼime ụlọnsọ gị;
\q2 Chineke nke Izrel na-enye ndị ya ume na ike.
\b
\q1 Toonu Chineke!
\c 69
\cl Abụ Ọma 69
\d Abụ Ọma dịrị onyeisi abụ. Eji olu abụ “Okoko Lili.” Abụ Devid.
\s1 Ekpere maka nnapụta
\q1 
\v 1 O Chineke, zọpụta m,
\q2 nʼihi na mmiri abịaruola m nʼolu.
\q1 
\v 2 Ana m emikpu nʼụrụrọ ebe dị omimi,
\q2 e nwekwaghị ebe ịzọkwasị ụkwụ dị.
\q1 Abịala m nʼebe mmiri dị omimi;
\q2 uju mmiri na-achọkwa ikpuchigide m.
\q1 
\v 3 Akpịrị akpọọla m nkụ;
\q2 ike agwụla m ebe m na-akpọ oku maka enyemaka.
\q1 Anya m agbaala ọchịchịrị
\q2 ebe m na-ele anya Chineke.\f + \fr 69:3 \ft \xt Abụ 119:82,123\xt*\f*
\q1 
\v 4 Ndị kpọrọ m asị nʼefu dị ukwuu
\q2 karịa agịrị isi dị m nʼisi.
\q1 Ndị na-achọ ịla ndụ m nʼiyi dị ukwuu,
\q2 bụ ndị họọrọ ịbụ ndị iro m, mgbe ọ na-adịghị ihe ọbụla m mere ha.
\q1 Ha nọgidesịrị m ike mee ka m nyeghachi
\q2 ihe m na-ezughị nʼohi.
\b
\q1 
\v 5 Gị, Chineke, ị maara enweghị uche m niile;
\q2 ikpe ọmụma m abụghị ihe zoro ezo nʼihu gị.
\b
\q1 
\v 6 Ekwela ka ihere mee ndị
\q2 na-atụkwasị gị obi nʼihi m,
\q2 O Onyenwe m, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile;
\q1 ka ndị na-achọ gị
\q2 ghara ịbụ ndị a ga-eme ihe ihere nʼihi m,
\q2 O Chineke nke Izrel.
\q1 
\v 7 Ọ bụ nʼihi gị ka m na-anagide ịkwa emo,
\q2 ihere ekpuchiela m ihu.
\q1 
\v 8 Abụ m ọbịa nʼebe ụmụnna m nọ,
\q2 nʼebe ụmụnne nọ, abụ m onye mba ọzọ.
\q1 
\v 9 Nʼihi na ihe gbasara ụlọ gị na-anụ m ọkụ nʼobi,
\q2 ịta ụta niile nke ndị na-akparị gị adakwasịla m.
\q1 
\v 10 Mgbe m na-ebe akwa na-ebukwa ọnụ,
\q2 ha kparịrị m nʼihi na m na-eme nke a.
\q1 
\v 11 Mgbe m yikwasịrị uwe iru ụjụ m,
\q2 a ghọrọ m ihe ha ji eme ihe ọchị.
\q1 
\v 12 Ndị na-anọ ọnọdụ ala nʼọnụ ụzọ ama, na-akwa m emo, na-akọ m ọnụ,
\q2 abụ m isi abụ nke ndị na-aṅụbiga mmanya oke na-abụ.
\b
\q1 
\v 13 O \nd Onyenwe anyị\nd*, ana m akpọku gị nʼekpere,
\q2 nʼoge ihuọma gị;
\q1 na oke ịhụnanya gị, O Chineke m,
\q2 zaa m nʼeziokwu nke nzọpụta gị.
\q1 
\v 14 Dọpụta m site nʼụrụrọ,
\q2 ekwela ka m mikpuo;
\q1 zọpụta m site nʼaka ndị kpọrọ m asị,
\q2 site na mmiri miri emi.
\q1 
\v 15 Ekwela ka uju mmiri kpuchie m,
\q2 maọbụ ka ebe dị omimi loda m,
\q2 ma ọ bụkwanụ ka olulu lomie m, kpuchie m nʼime ọnụ ya.
\b
\q1 
\v 16 O \nd Onyenwe anyị\nd*, zaa m, site nʼịdị mma nke ịhụnanya gị,
\q2 nʼime ịdị ukwuu nke oke ebere gị, chee m ihu.
\q1 
\v 17 Ezonarịla mụ bụ ohu gị ihu gị.
\q2 Anọ m na nsogbu, mee ngwangwa zaa m!
\q1 
\v 18 Bịa m nso zọpụta m.
\q2 Gbapụta m site nʼaka ndị iro m.
\b
\q1 
\v 19 Ị maara ihe niile banyere ihe ọchị ha ji m mee, mweda nʼala m na ihe ihere:
\q2 ndị iro m niile nọkwa gị nʼihu.
\q1 
\v 20 Ọchị ha na-achị m etiwaala m obi,
\q2 ma hapụ m nʼọnọdụ enweghị inyeaka.
\q1 Elere m anya onye ga-emere m ebere, ma ọ dịghị onye ọbụla m hụrụ;
\q2 lee anya ndị ga-akasị m obi, ma ọ dịkwaghị onye m chọtara.
\q1 
\v 21 Ha tinyere oluilu nʼime nri m,
\q2 nyekwa m mmanya gbara ụka ka m ṅụọ.
\b
\q1 
\v 22 Ka tebul e debere nʼihu ha ghọrọ ha ọnya;
\q2 ka ọ bụrụ ha ihe ịbọ ọbọ mgbe ha nọ nʼudo ya ghọrọ ha ọnya igbudu.
\q1 
\v 23 Ka anya ha gbaa ọchịchịrị, ka ha gharakwa ịhụ ụzọ ọzọ,
\q2 mekwa ka ụkwụ ha na-ama jijiji mgbe niile.
\q1 
\v 24 Wụkwasị ha oke iwe gị,
\q2 ka iwe gị dị ọkụ zute ha.
\q1 
\v 25 Ka ebe obibi ha tọgbọrọ nʼefu,
\q2 ka mmadụ ọbụla gharakwa ibi nʼime ụlọ ikwu ha.
\q1 
\v 26 Ha na-akpagbu ndị ahụ i merụrụ ahụ,
\q2 na-ekwukwa banyere ihe mgbu ndị ahụ i kwohịara ahụ.
\q1 
\v 27 Boo ha ebubo ajọ omume tụkwasị nʼelu ajọ omume,
\q2 ekwekwala ka ha keta oke na ezi omume\f + \fr 69:27 \ft Maọbụ, \fqa nzọpụta\f* gị.
\q1 
\v 28 Mee ka e hichapụ aha ha site nʼakwụkwọ nke ndụ,
\q2 ka a hapụ idekọta aha ha na nke ndị ezi omume.
\b
\q1 
\v 29 Anọ m nʼụfụ na ihe mgbu,
\q2 O Chineke, mee ka nzọpụta gị kpuchie m.
\b
\q1 
\v 30 Aga m eji ịbụ abụ too aha Chineke,
\q2 jirikwa ekele bulie ya elu.
\q1 
\v 31 Nke a ga-atọ \nd Onyenwe anyị\nd* ụtọ karịa oke ehi,
\q2 karịa oke ehi, nke mpi ya na ụkwụ ya ka dị.
\q1 
\v 32 Ndị ogbenye ga-ahụ ya ma ṅụrịakwa ọṅụ;
\q2 unu ndị na-achọ Chineke, ka obi unu na-adị ndụ.
\q1 
\v 33 \nd Onyenwe anyị\nd* na-anụ ekpere ndị nọ na mkpa,
\q2 ọ naghị eledakwa ndị ya a dọtara nʼagha anya.
\b
\q1 
\v 34 Ka eluigwe na ụwa too ya,
\q2 osimiri niile na ihe niile bi nʼime ha.
\q1 
\v 35 Nʼihi na Chineke ga-azọpụta Zayọn;
\q2 ọ ga-ewugharị obodo niile nke Juda.
\q1 Mgbe ahụ, ndị mmadụ ga-ebi nʼime ya, mee ya ihe nweta ha.
\q2 
\v 36 Ụmụ ndị na-ejere ya ozi ga-eketa ya,
\q2 ndị hụrụ aha ya nʼanya ga-ebikwa ebe ahụ nʼime ya.
\c 70
\cl Abụ Ọma 70
\d Abụ Ọma dịrị onyeisi abụ. Nke Devid. Arịrịọ.
\s1 Ekpere maka nnapụta
\q1 
\v 1 O Chineke, gbata ọsọ bịa zọpụta m,
\q2 O \nd Onyenwe anyị\nd*, bịa ngwangwa inyere m aka.
\b
\q1 
\v 2 Ka ndị niile na-achọ ịnapụ m ndụ m,
\q2 bụrụ ndị a ga-etinye nʼọnọdụ ihere na ọgbaaghara.
\q1 Ka ndị ọ na-amasị ịhụ ịla nʼiyi m
\q2 laghachi azụ nʼihere.
\q1 
\v 3 Ka ndị ahụ na-asị m, “Ehee! Ehee!”
\q2 laghachi azụ nʼihi ihere ha.
\q1 
\v 4 Ma ka ndị niile na-achọ gị
\q2 ṅụrịa ọṅụ, nweekwa obi ụtọ nʼime gị,
\q1 ka ndị ahụ hụrụ nzọpụta gị nʼanya na-ekwu mgbe niile,
\q2 “\nd Onyenwe anyị\nd* dị ukwuu.”
\b
\q1 
\v 5 Ma mụ onwe m bụ ogbenye na onye nọ na mkpa;
\q2 O Chineke, mee ngwangwa bịakwute m.
\q1 Ị bụ onye inyeaka m na onye mgbapụta m;
\q2 O \nd Onyenwe anyị\nd*, anọla ọdụ ịbịa.
\c 71
\cl Abụ Ọma 71
\s1 Ekpere maka ndụ ogologo
\q1 
\v 1 \nd Onyenwe anyị\nd*, nʼime gị ka m gbabara izere ndụ;
\q2 ekwela ka ihere mee m.
\q1 
\v 2 Site nʼezi omume gị, gbapụta m, mee ka m nwere onwe m;
\q2 tọọ ntị gị nʼala nụrụ olu m ma zọpụta m.
\q1 
\v 3 Ghọọrọ m oke nkume nke ebe mgbaba,
\q2 ebe m nwere ike ịgbaba mgbe ọbụla;
\q1 nye iwu maka nzọpụta m,
\q2 nʼihi na ị bụ oke nkume m na ebe m e wusiri ike.
\q1 
\v 4 O Chineke m, site nʼaka ndị ajọ omume na ndị mmadụ na-eme ihe ọjọọ,
\q2 ndị afọ tara mmiri, gbapụta m.
\b
\q1 
\v 5 Nʼihi na gị onwe gị bụrịị olileanya m, Onyenwe m \nd Onyenwe anyị\nd*,
\q2 ntụkwasị obi m site na mgbe m bụ nwantakịrị.\f + \fr 71:5 \ft \xt Jer 14:8; Jer 17:7,13\xt*\f*
\q1 
\v 6 Ọ bụ gị ka m tụkwasịrị obi, site nʼoge amụrụ m;
\q2 gị onwe gị wepụtara m site nʼafọ nne m.
\q2 Aga m anọgide na-eto gị.
\q1 
\v 7 Adịla m ka ihe ama nye ọtụtụ mmadụ,
\q2 ma ị bụ ebe mgbaba m siri ike.
\q1 
\v 8 Ọnụ m jupụtara nʼotuto gị,
\q2 ọ na-ekwupụta ịma mma gị ogologo ụbọchị niile.
\b
\q1 
\v 9 Agbakụtala m azụ mgbe m mere agadi;
\q2 ahapụkwala m mgbe ike adịghịkwa m.
\q1 
\v 10 Nʼihi na ndị iro m na-ekwu okwu megide m;
\q2 ndị ahụ na-achọ igbu m na-agbarịta izu nzuzo.
\q1 
\v 11 Ha na-asị, “Chineke agbakụtala ya azụ;
\q2 chụọ ya ọsọ, jidekwa ya,
\q2 nʼihi na o nweghị onye ọbụla ga-agbapụta ya.”
\q1 
\v 12 O Chineke, anọla m ebe dị anya;
\q2 O Chineke m, bịa ngwangwa nyere m aka.
\q1 
\v 13 Ka e were ihere kpuchie ndị na-ebo m ebubo ụgha;
\q2 ka ihere na nleda anya bụrụ ihe ga-ekpuchi
\q2 ndị ahụ na-achọ imerụ m ahụ.
\b
\q1 
\v 14 Ma mụ onwe m ga-anọgide na-enwe olileanya mgbe niile;
\q2 aga m eto gị mgbe niile karịa otu m toro gị na mbụ.
\b
\q1 
\v 15 Ọnụ m ga-ekwu banyere ezi omume gị
\q2 na nzọpụta gị ogologo ụbọchị niile,
\q2 ọ bụ ezie na-amaghị m ọtụtụ ya.
\q1 
\v 16 Aga m abịa kwusaakwa ịdị ukwu ọrụ gị niile, Onyenwe m \nd Onyenwe anyị\nd*,
\q2 aga m ekwusa ezi omume gị, e, naanị nke gị.
\q1 
\v 17 O Chineke, site na mgbe m bụ nwantakịrị, i kuzielera m ihe,
\q2 ruo taa, ana m ekwupụta banyere ọrụ ebube gị niile.
\q1 
\v 18 O Chineke m, ọ bụladị mgbe m mere agadi,
\q2 mgbe isi awọ juru m isi, ahapụla m,
\q1 tutu ruo mgbe m ga-ekwupụta ike gị nye ọgbọ nke na-abịa,
\q2 na ịdị ike gị nye ndị niile na-abịa nʼoge dị nʼihu.
\b
\q1 
\v 19 O Chineke, ezi omume gị na-eru nʼeluigwe,
\q2 gị onye merela ọtụtụ ihe dị ukwu.
\q2 O Chineke, onye dị ka gị?
\q1 
\v 20 Nʼagbanyeghị na i meela ka m gabiga ọtụtụ nsogbu
\q2 nke dị ilu,
\q2 ị ga-atụte ndụ m ọzọ;
\q1 site nʼebe dị omimi nke ụwa,
\q2 ị ga-adọkpụpụta m ọzọ.
\q1 
\v 21 Ị ga-eme m ka m dịrị ukwuu karịa ka m dị na mbụ.
\q2 Ị ga-akasịkwa m obi ọzọ.
\b
\q1 
\v 22 O Chineke m, aga m eji ụbọ akwara too gị,
\q2 nʼihi ikwesi ntụkwasị obi gị;
\q1 aga m eji une bụkuo gị abụ otuto,
\q2 gị Onye nsọ nke Izrel.
\q1 
\v 23 Egbugbere ọnụ m ga-eti mkpu ọṅụ
\q2 mgbe m na-abụku gị abụ otuto,
\q2 mụ, onye ị gbapụtara.
\q1 
\v 24 Ogologo ụbọchị niile, aga m ekwupụta
\q2 ọrụ ezi omume gị niile,
\q1 nʼihi na ndị ahụ chọrọ imerụ m ahụ,
\q2 ka e tinyere nʼọnọdụ ihere na ọgbaaghara.
\c 72
\cl Abụ Ọma 72
\d Abụ nke Solomọn.
\s1 Ekpere maka eze
\q1 
\v 1 O Chineke, jiri ikpe ziri ezi mejupụta eze.
\q2 Nyekwa nwa eze ezi omume gị.
\q1 
\v 2 Ọ ga-eji ezi omume chịa ndị gị,
\q2 jiri ikpe ziri ezi chịa ndị a na-emegbu.
\b
\q1 
\v 3 Ka ugwu niile wetara ndị mmadụ ịba ụba;
\q2 ugwu nta niile wetakwara ha mkpụrụ ezi omume.
\q1 
\v 4 Ọ ga-ekpepụta ndị a na-emegbu nʼetiti ndị mmadụ,
\q2 zọpụtakwa ụmụntakịrị ndị nọ na mkpa;
\q2 ọ ga-egwepịa onye mmegbu.
\q1 
\v 5 Ka ọ dịgide ruo mgbe niile dịka anyanwụ na-adịgide,
\q2 dịka ọnwa na-adịgidekwa ruo ọgbọ niile.
\q1 
\v 6 Ọ ga-adị ka mmiri na-ezokwasị ala ubi a sụrụ asụ,
\q2 dịka mmiri ozuzo na-ede elu ala.
\q1 
\v 7 Nʼoge ndụ ya, ka ndị ezi omume too, na-awasa;
\q2 ịba ụba ga-ejupụta ebe niile ruo mgbe ọnwa agaghị adịkwa.
\b
\q1 
\v 8 Ọ ga-achị site nʼosimiri ruo osimiri,
\q2 na-esite nʼiyi ukwu.\f + \fr 72:8 \ft Nke a na-ekwu banyere osimiri Yufretis. Mgbe Solomọn na-achị, ọ bụ nʼakụkụ ọwụwa anyanwụ ala Izrel ka ọ dị. Ọ bụ otu ihe e kwere ndị Izrel na nkwa mgbe ha si nʼọnọdụ ohu na-ahapụ Ijipt. \xt Ọpụ 23:31; Zek 9:10\xt*\f* ruo na nsọtụ niile nke ụwa\f + \fr 72:8 \ft Ọ bụ site nʼosimiri Mediterenịa ruo nʼosimiri Nwụrụ anwụ, ka a maara dị ka nsọtụ ụwa nʼoge ahụ.\f*
\q1 
\v 9 Ebo niile ndị bi nʼọzara ga-akpọ isiala nye ya,
\q2 ndị iro ya niile ga-abụ ndị e wedara nʼala.
\q1 
\v 10 Ndị eze Tashish\f + \fr 72:10 \ft Obodo Tashish dị nʼala Spen, ọ nọchiri anya nsọtụ nke ụwa, \xt 2Ih 9:21\xt*\f* na mba niile dị nʼebe dị anya,
\q2 ga-atụ ụtụ wetara ya;
\q1 e, ọ bụladị ndị eze si Sheba na Seba,\f + \fr 72:10 \ft Ala Sheba dị nʼArebịa, ebe ala Seba dị nʼAfrika.\f*
\q2 ga-ewetara ya ọtụtụ onyinye.
\q1 
\v 11 Ndị eze niile ga-akpọ isiala nye ya,
\q2 mba niile ga-ejekwara ya ozi.
\b
\q1 
\v 12 Nʼihi na ọ ga-azọpụta ndị nọ na mkpa mgbe ha kpọkuru ya.
\q2 Ọ ga-azọpụtakwa ndị ogbenye na-enweghị onye ga-enyere ha aka.
\q1 
\v 13 Ọ ga-enwe ọmịiko nʼahụ ndị na-enweghị ike, na ndị nọ na mkpa,
\q2 ọ ga-azọpụta ndị nọ na mkpa site nʼọnwụ.
\q1 
\v 14 Ọ ga-azọpụta ha site na mkpagbu na ihe ike,
\q2 nʼihi na ndụ ha dị oke ọnụahịa nʼanya ya.
\b
\q1 
\v 15 Ka ọ dị ogologo ndụ!
\q2 Ka e nye ya ọlaọcha e wetara na Sheba.
\q1 Ka ndị mmadụ na-ekpere ya ekpere mgbe niile,
\q2 ma gọziekwa ya ogologo ụbọchị niile.
\q1 
\v 16 Ka mkpụrụ ọka jupụta nʼebe niile nʼala a;
\q2 ka ha na-efufegharị nʼelu ugwu niile.
\q1 Ka mkpụrụ ubi ya wasaa dịka Lebanọn;
\q2 ka mmadụ jupụta nke ọma nʼobodo dịka ahịhịa ndụ nke ọhịa.
\q1 
\v 17 Ka aha ya na-adịgide ruo mgbe ebighị ebi;
\q2 ka ọ na-adịgide ruo mgbe niile dịka anyanwụ si adịgide.
\b
\q1 A ga-esite na ya gọzie mba niile,
\q2 a ga-akpọ ya onye a gọziri agọzi.
\b
\b
\q1 
\v 18 Otuto dịrị \nd Onyenwe anyị\nd* Chineke, Chineke nke Izrel,
\q2 onye naanị ya na-arụ ọrụ ebube dị iche iche.
\q1 
\v 19 Otuto dịrị aha ya dị ebube ruo ebighị ebi;
\q2 ka ụwa niile jupụta nʼebube ya.
\qc Amen na Amen.
\b
\b
\q1 
\v 20 Nke a bụ ọgwụgwụ ekpere Devid nwa Jesi.
\c 73
\ms1 Nchịkọta Akwụkwọ nke atọ
\mr Abụ Ọma 73–89
\cl Abụ Ọma 73
\d Abụ Ọma Asaf.
\s1 Ọgwụgwụ nke ndị na-emebi iwu
\q1 
\v 1 Nʼezie, Chineke dịịrị Izrel mma,
\q2 dịkwara ndị obi ha dị ọcha.
\b
\q1 
\v 2 Ma mụ onwe m, ọ fọdụrụ nwantịị ka m zọhie ụkwụ,
\q2 ọ fọdụrụ nwantịị ka ụkwụ m gbụchapụ.
\q1 
\v 3 Nʼihi na e kwosara m ndị mpako ekworo\f + \fr 73:3 \ft \xt Abụ 37:1,7; Ilu 23:17\xt*\f*;
\q2 mgbe m hụrụ ịba ụba\f + \fr 73:3 \ft Maọbụ, \fqa udo\f* nke ndị ajọ omume.\f + \fr 73:3 \ft \xt Job 21:5-16; Jer 12:1\xt*\f*
\b
\q1 
\v 4 Ha anaghị adọgbu onwe ha;
\q2 ahụ ha gbara abụba, siekwa ike.
\q1 
\v 5 Nsogbu niile mmadụ ibe ha na-enwe adịghị erute ha.
\q2 Ha enweghị mkpa ọbụla nke na-akpa ha dịka ndị ọzọ nwere.
\q1 
\v 6 Nʼihi nke a, nganga bụ ihe ịnya nʼolu ha;
\q2 ha jikwa ihe ike kpuchie onwe ha dịka uwe.
\q1 
\v 7 Mmehie na-esite nʼobi ọjọọ ha apụta;
\q2 echiche ọjọọ ha enweghị ngụta.
\q1 
\v 8 Ha na-akwa emo, na-ejikwa iro ekwu okwu;
\q2 nʼime mpako ha, ha na-aba mba imegbu ndị ọzọ.
\q1 
\v 9 Ha ji ọnụ ha na-ekwu na eluigwe bụ nke ha,
\q2 ha jikwa ire ha kwuo na ụwa niile bụ nke ha.
\q1 
\v 10 Nʼihi nke a, ndị ha na-eso ha,
\q2 na-aṅụrụ okwu ha ebe ọ bara ụba dịka mmiri.
\q1 
\v 11 Ha na-asị, “Olee otu Chineke ga-esi mara?
\q2 Ọ dịkwanụ ihe Onye kachasị ihe niile elu maara?”
\b
\q1 
\v 12 Otu a ka ndị ajọ omume dị,
\q2 ha na-ebi ndụ na-enweghị nsogbu; akụnụba ha na-amụbakwa.
\b
\q1 
\v 13 Nʼezie, ọ bụ naanị nʼefu ka m debere obi m ọcha,
\q2 nʼefu ka m kwọrọ aka\f + \fr 73:13 \ft Biri ndụ na-enweghị ntụpọ\f* m abụọ nʼemeghị ihe ọjọọ.
\q1 
\v 14 Ogologo ụbọchị niile, anọ m na nsogbu;
\q2 ụtụtụ niile ka m na-anata ntaramahụhụ.
\b
\q1 
\v 15 Ọ bụrụ na m kwuru sị, “Nke a ka m ga-ekwu,”
\q2 agaara m abụ onye na-ekwesighị ntụkwasị obi nʼetiti ụmụ gị.
\q1 
\v 16 Mgbe m gbalịrị ịghọta ihe ndị a niile,
\q2 ọ ghọọrọ m ihe mwute,
\q1 
\v 17 tutu ruo mgbe m bara nʼebe nsọ Chineke;
\q2 mgbe ahụ ka m ghọtara ihe ga-eme ha nʼikpeazụ.
\b
\q1 
\v 18 Nʼezie, ị na-eguzo ha nʼala na-achị achị;
\q2 ị na-atụda ha, laa ha nʼiyi.
\q1 
\v 19 Lee, ka ha si laa nʼiyi nʼotu ntabi anya,
\q2 bụrụ ndị ihe egwu dị iche iche kpochapụrụ kpamkpam!
\q1 
\v 20 Dịka nrọ, mgbe mmadụ na-eteta,
\q2 otu a, O Onyenwe anyị, mgbe i tetara,
\q2 ị ga-eleda ha anya dịka echiche na-agaghị emezu.
\b
\q1 
\v 21 Mgbe m nọ nʼobi mwute;
\q2 mmụọ m dara mba.
\q1 
\v 22 Abụ m onye nzuzu na onye na-amaghị ihe.
\q2 Adị m ka anụ ọhịa nʼihu gị.
\b
\q1 
\v 23 Ma ana m anọnyere gị mgbe niile;
\q2 ị na-ejide m nʼaka nri m.
\q1 
\v 24 Ị na-eji ndụmọdụ gị na-edu m,
\q2 ma emesịa, ị ga-anabata m nʼebube gị.
\q1 
\v 25 Onye ka m nwere nʼeluigwe ma ọ bụghị gị?
\q2 Ọ dịghị ihe ụwa a nwere nke m ga-achọsi ike karịa gị.
\q1 
\v 26 Anụ ahụ m na mkpụrụobi m nwere ike ịda mba,
\q2 ma Chineke bụ ike nke obi m,
\q2 na ihe nketa m ruo ebighị ebi.
\b
\q1 
\v 27 Ndị niile nọpụrụ gị nʼebe dị anya ga-ala nʼiyi.
\q2 Ị ga-alakwa ndị niile na-ekwesighị ntụkwasị obi, nye gị nʼiyi.
\q1 
\v 28 Ma nye mụ onwe m, ọ dị mma ịnọ Chineke nso.
\q2 Emeela m Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* ebe mgbaba m.
\q2 Aga m akọ banyere ọrụ gị niile dị iche iche.
\c 74
\cl Abụ Ọma 74
\d Abụ maskil nke Asaf.
\s1 Ekpere maka enyemaka
\q1 
\v 1 Chineke, gịnị mere i ji jụ anyị ruo mgbe ebighị ebi?
\q2 Gịnị mere iwe gị ji akwụ anwụrụ megide igwe atụrụ ndị ị na-azụ?
\q1 
\v 2 Cheta mba ahụ nke ị zụtara na mgbe ochie,
\q2 ebo ahụ bụ ihe nketa gị, ndị ị gbapụtara,
\q2 nʼugwu Zayọn ebe i biri.
\q1 
\v 3 Tụgharịa nzọ ụkwụ gị bịa na mbibi ebighị ebi ndị a.
\q2 Ọ bụ onye iro wetara ịla nʼiyi a niile nʼụlọnsọ a.
\b
\q1 
\v 4 Ndị iro gị gbọrọ ụja nʼebe i zutere anyị.
\q2 Ha weliri ọkọlọtọ ha dịka ihe ịrịbama.
\q1 
\v 5 Ha kpara agwa dịka ndị ikom ji anyụike
\q2 ha ga-eji gbutuo ọtụtụ osisi dị nʼoke ọhịa.
\q1 
\v 6 Ha ji anyụike na egbugbu ha
\q2 kụjisie ihe niile eji amachi ihe bụ nke egbunyere ihe.
\q1 
\v 7 Ha kpọkwara ụlọnsọ gị ọkụ, mee ya ka o repịa.
\q2 Ha merụrụ ụlọ obibi ahụ a kpọkwasịrị aha gị.
\q1 
\v 8 Ha sịrị nʼobi ha, “Anyị ga-etipịa ha kpamkpam!”
\q2 Ha kpọrọ ebe niile a na-anọ efe Chineke nʼala a ọkụ.
\b
\q1 
\v 9 Enyeghị anyị ihe ịrịbama ọbụla site nʼaka Chineke.
\q2 Ọ dịkwaghị ndị amụma fọdụrụ.
\q2 Ọ dịkwaghị onye ọbụla nʼetiti anyị onye maara, mgbe ihe a ga-agwụ.
\q1 
\v 10 O Chineke, ruo ole mgbe ka ndị iro ga-anọgide na-achị gị ọchị?
\q2 Onye iro, ọ ga-eleli aha gị ruo mgbe ebighị ebi?
\q1 
\v 11 Gịnị mere ị na-eseghachi aka gị azụ, e aka nri gị?
\q2 Sepụta aka gị laa ha nʼiyi!
\b
\q1 
\v 12 Ma gị, O Chineke, bụrịị eze m site na mgbe ochie.
\q2 Ọ bụ gị na-arụpụta nzọpụta nʼelu ụwa.
\b
\q1 
\v 13 Site nʼike gị dị ukwuu i mere ka osimiri kewaa abụọ.
\q2 Ọ bụ gị gwepịara isi anụ ọjọọ ahụ nʼime mmiri.
\q1 
\v 14 Ọ bụ gị gwepịara isi anụ ọjọọ ahụ a na-akpọ leviatan,
\q2 mee ka ọ ghọọ nri nye ụmụ anụmanụ bi nʼọzara.
\q1 
\v 15 Ọ bụ gị mere ka isi iyi na mmiri iyi na-asọ.
\q2 I mere ka osimiri na-eru eru mgbe niile taa.
\q1 
\v 16 Ehihie na abalị bụ nke gị.
\q2 I mere ka anyanwụ na ọnwa guzosie ike.
\q1 
\v 17 Ọ bụ gị kewapụtara oke ala niile nke ụwa.
\q2 Ọ bụ gị mere ka ọkọchị na udu mmiri dị.
\b
\q1 
\v 18 O \nd Onyenwe anyị\nd*, cheta otu onye iro si chịa gị ọchị,
\q2 na otu ndị nzuzu si kwaa aha gị emo.
\q1 
\v 19 Ewerala ndụ nduru gị nyefee anụ ọhịa ọjọọ nʼaka.
\q2 Echefukwala ndụ ndị gị a na-akpagbu ruo mgbe ebighị ebi.
\q1 
\v 20 Chetakwa ọgbụgba ndụ gị,
\q2 nʼihi na ihe ike na-ejupụta ebe niile gbara ọchịchịrị nʼala a.
\q1 
\v 21 Ekwela ka ndị a na-akpagbu gbaghachi azụ nʼihere;
\q2 ka ndị ogbenye na ndị nọ na mkpa too aha gị.
\q1 
\v 22 O Chineke, bilie, kpechitara onwe gị ikpe.
\q2 Chetakwa otu ndị nzuzu si kọọ gị ọnụ ogologo ụbọchị niile.
\q1 
\v 23 Elepụla mkpọtụ nke ndị iro gị niile anya,
\q2 olu mkpọtụ nke ndị iro gị na-aga nʼihu na-ala elu.
\c 75
\cl Abụ Ọma 75
\d Abụ Ọma nke dịrị onyeisi abụ. Nke olu abụ “E bibikwala.” Abụ Ọma Asaf. Otu Abụ.
\s1 Ikpe ikpe ziri ezi nke Chineke
\q1 
\v 1 Anyị na-eto gị, O Chineke.
\q2 Anyị na-eto gị, nʼihi na aha gị dị nso.
\q2 Ndị mmadụ na-ekwu banyere ọrụ ebube gị dị iche iche.
\b
\q1 
\v 2 Ị na-asị, “Ana m ahọpụta oge a kara aka.
\q2 Ọ bụ m na-ekpe ikpe ziri ezi.
\q1 
\v 3 Mgbe ụwa na mmadụ niile bi nʼime ya na-ama jijiji,
\q2 ọ bụ m na-ejidesi ogidi\f + \fr 75:3 \ft Ya bụ, ntọala\f* ya ike ka o guzo chịm. \qs Sela\qs*
\q1 
\v 4 Nye ndị mpako, ana m asị, ‘Unu etukwala ọnụ ọzọ,
\q2 nye ndị ajọ omume, ana m asị, Unu ewelila mpi\f + \fr 75:4 \ft Mpi na-anọchite anya ike nʼebe a\f* unu elu.
\q1 
\v 5 Unu ewelila mpi unu megide eluigwe;
\q2 unu ejila nnupu isi kwuo okwu.’ ”
\b
\q1 
\v 6 Ọ dịghị onye ọbụla sitere nʼọwụwa anyanwụ, maọbụ nʼọdịda anyanwụ,
\q2 maọbụ nʼọzara nke pụrụ ibuli mmadụ elu.
\q1 
\v 7 Kama ọ bụ Chineke, onye na-ekpe ikpe;
\q2 ọ na-eweli otu onye elu, wedakwa onye ọzọ ala.
\q1 
\v 8 Otu iko dị nʼaka \nd Onyenwe anyị\nd*
\q2 nke jupụtara na mmanya na-agba ụfụfụ nke a gwanyekọtara ụda dị iche iche.
\q1 Ọ na-awụpụ ya, ndị ajọ omume niile nke ụwa
\q2 na-aṅụ ya ruo mgbe ọ gwụsịrị.
\b
\q1 
\v 9 Ma mụ onwe m, aga m ekwupụta nke a ruo mgbe ebighị ebi.
\q2 Aga m abụku Chineke nke Jekọb abụ otuto,
\q1 
\v 10 bụ onye sịrị, “Aga m ebipụ mpi ndị ajọ omume niile,
\q2 ma a ga-ebuli mpi ndị ezi omume elu.”
\c 76
\cl Abụ Ọma 76
\d Abụ Ọma dịrị onyeisi abụ. Nke eji ụbọ akwara akpọ. Abụ Ọma Asaf. Otu Abụ.
\s1 Ike mmeri nke Chineke
\q1 
\v 1 A maara Chineke nʼobodo Juda;
\q2 aha ya dị ukwuu nʼobodo Izrel.
\q1 
\v 2 Ụlọ ikwu ya dị na Salem,
\q2 ebe obibi ya dị na Zayọn
\q1 
\v 3 Ebe ahụ ka o tijisịrị àkụ niile na-egbu amụma,
\q2 na ọta niile, na mma agha niile, na ngwa agha niile. \qs Sela\qs*
\b
\q1 
\v 4 Ị jupụtara nʼìhè,
\q2 ị dị oke ebube karịa ọtụtụ ugwu nke anụmanụ jupụtara.
\q1 
\v 5 A pụnarịla ndị nwere obi ike ihe ha,
\q2 ha na-arahụkwa ụra ikpeazụ ha;
\q1 o nweghị otu onye nʼime ndị dike nʼagha ndị a
\q2 pụrụ iweli aka ya abụọ elu.
\q1 
\v 6 Nʼihi ịba mba gị, O Chineke nke Jekọb,
\q2 ịnyịnya na ụgbọ agha na-anọ juu.\f + \fr 76:6 \ft \xt Ọpụ 15:1-6\xt*\f*
\b
\q1 
\v 7 Ọ bụ naanị gị ka e kwesiri ịtụ egwu.
\q2 Onye pụrụ iguzo nʼihu gị mgbe i na-ewe iwe?
\q1 
\v 8 I sitere nʼeluigwe mee ka a nụ olu ikpe ikpe gị.
\q2 Ụwa tụkwara egwu, dere duu,
\q1 
\v 9 mgbe gị, O Chineke, biliri ikpe ikpe,
\q2 ịzọpụta ndị niile a na-akpagbu nʼala a. \qs Sela\qs*
\q1 
\v 10 Nʼezie, oke iwe gị megide ụmụ mmadụ na-ewetara gị otuto,\f + \fr 76:10 \ft \xt Ọpụ 9:16-18; Rom 9:17\xt*\f*
\q2 ndị fọdụrụ mgbe oke iwe gị gabigasịrị, na-anọ juu.
\b
\q1 
\v 11 Kwenụ \nd Onyenwe anyị\nd* Chineke nkwa ma mezuokwa ha;
\q2 ka ndị ala niile bụ agbataobi unu
\q2 wetara onye ahụ e kwesiri ịtụ egwu onyinye dị iche iche.
\q1 
\v 12 Ọ na-eweda ndị na-achị achị nʼala;
\q2 ndị eze niile nke ụwa na-atụ ya egwu.
\c 77
\cl Abụ Ọma 77
\d Abụ Ọma nke dịrị onyeisi abụ. Maka Jedutun. Abụ nke Asaf. Abụ Ọma.
\s1 Nkasiobi nʼoge nsogbu
\q1 
\v 1 Etikuru m Chineke nʼoke olu maka enyemaka;
\q2 etikuru m Chineke mkpu ka ọ nụrụ olu m.
\q1 
\v 2 Mgbe m nọ nʼihe mgbu, ọ bụ Onyenwe anyị ka m chọrọ.
\q2 Nʼanyasị, esetipụrụ m aka m abụọ, ike na-agwụghị,
\q2 mmụọ m jụkwara ka a akasịe ya obi.
\b
\q1 
\v 3 O Chineke, echetara m gị, sụkwaa ude;
\q2 echere m echiche, mkpụrụobi m dakwara mba. \qs Sela\qs*
\q1 
\v 4 I kweghị ka anya m abụọ mechie;
\q2 nʼihi oke mwute m, enweghị m ike kwuo okwu.
\q1 
\v 5 Echere m echiche banyere ụbọchị niile gara aga,
\q2 na afọ niile ndị gara aga.
\q1 
\v 6 Echetara m abụ niile m na-abụ nʼime anyasị.
\q2 Mkpụrụobi m nọ nʼọnọdụ ntụgharị uche, mmụọ m jụkwara ajụjụ.
\b
\q1 
\v 7 “Onyenwe anyị ọ ga-agbakụta m azụ ruo mgbe ebighị ebi?
\q2 Ọ pụtara na ọ gaghị egosi ihuọma ya ọzọ?
\q1 
\v 8 Ọ pụtara na ịhụnanya ya nke na-adịgide ruo ebighị ebi agwụla?
\q2 Ọ pụtara na nkwa ya agaghị emezu ruo ebighị ebi?
\q1 
\v 9 Chineke, o chefuola i mere anyị ebere?
\q2 O jichiela ọmịiko ya nʼihi iwe?” \qs Sela\qs*
\b
\q1 
\v 10 Mgbe ahụ, ekwuru m, “Lee ọnọdụ ọjọọ m,
\q2 afọ niile mgbe Onye kachasị ihe niile elu setịpụrụ aka nri ya.
\q1 
\v 11 Aga m echeta ọrụ niile \nd Onyenwe anyị\nd* rụrụ;
\q2 e, aga m echeta ihe ịrịbama niile i mere nʼoge gara aga.
\q1 
\v 12 Aga m atụgharịa uche m nʼọrụ gị niile,
\q2 tuleekwa ọrụ ukwuu gị niile dị iche iche.”
\b
\q1 
\v 13 O Chineke, ụzọ gị niile dị nsọ.
\q2 Olee chi dị ukwuu dịka Chineke anyị?
\q1 
\v 14 Ị bụ Chineke onye na-arụ ọrụ ebube dị iche iche;
\q2 ị na-egosipụta ike gị nʼetiti ụmụ mmadụ.
\q1 
\v 15 I ji aka gị dị ike gbapụta ndị gị,
\q2 bụ ụmụ ụmụ Jekọb na Josef. \qs Sela\qs*
\b
\q1 
\v 16 Osimiri hụrụ gị, O Chineke,
\q2 osimiri hụrụ gị, taa;
\q2 ogbu mmiri mere mkpọtụ.
\q1 
\v 17 Igwe ojii wụpụrụ mmiri,
\q2 mkpọtụ egbe eluigwe jupụtara mbara eluigwe;
\q2 àkụ gị gburu amụma ebe niile.
\q1 
\v 18 A nụrụ ụda egbe eluigwe gị nʼoke ifufe,
\q2 amụma gị nyere ụwa niile ihe;
\q2 elu ụwa niile mara jijiji, tụkwaa oke egwu.
\q1 
\v 19 Ọ bụ nʼosimiri ka nzọ ụkwụ gị gara,
\q2 ụzọ gị gara nʼetiti oke osimiri,
\q2 ọ bụ ezie na ahụghị m nzọ ụkwụ gị anya.
\b
\q1 
\v 20 I sitere nʼaka Mosis na Erọn
\q2 duo ndị gị dịka igwe atụrụ.
\c 78
\cl Abụ Ọma 78
\d Abụ \tl maskil\tl* nke Asaf.
\s1 Chineke na ndị ya
\q1 
\v 1 Ndị m, nụrụnụ ihe m na-ezi;
\q2 geenụ ntị nʼokwu ọnụ m.
\q1 
\v 2 Aga m eji ilu malite okwu m,
\q2 aga m ekwu ọtụtụ ihe omimi, ihe ndị sitere na mgbe ochie;
\q1 
\v 3 ihe ndị anyị nụrụla, marakwa,
\q2 ihe ndị nna nna anyị ha gwara anyị.
\q1 
\v 4 Anyị agaghị ezonarị ụmụ anyị ihe ndị a,
\q2 kama anyị ga-akọrọ ọgbọ nke na-abịa nʼihu
\q1 akụkọ ịdị ike \nd Onyenwe anyị\nd*,
\q2 na ọrụ ebube ya, na ihe ịtụnanya niile o mere.
\q1 
\v 5 O nyere Jekọb iwu banyere ụkpụrụ ya,
\q2 mekwaa ka iwu ahụ guzosie ike nʼIzrel,
\q1 bụ nke ọ dọrọ nna nna anyị ha aka na ntị,
\q2 ka ha kuziere ụmụ ha,
\q1 
\v 6 ka ọgbọ na-eso ha nwee ike mụta ya,
\q2 ọ bụladị ọgbọ nke a ka amụbeghị,
\q2 ndị nke ga-agwakwa ha ụmụ ha.
\q1 
\v 7 Mgbe ahụ, ha ga-atụkwasị Chineke obi ha,
\q2 ma ghara ichefu ọrụ ya niile dị iche iche.
\q2 Ha ga-edebekwa iwu ya niile.
\q1 
\v 8 Ha agakwaghị adị ka ndị nna nna ha,
\q2 ọgbọ ndị nnupu isi na ndị isiike;
\q1 ndị obi ha na-adịghị nʼebe Chineke nọ,
\q2 ndị mmụọ ha na-ekwesighị ntụkwasị obi nye ya.
\b
\q1 
\v 9 Ndị ikom Ifrem, nʼagbanyeghị na ha kwere ụta ha,
\q2 chigharịrị azụ, gbaa ọsọ nʼụbọchị agha.
\q1 
\v 10 Ha edebeghị ọgbụgba ndụ Chineke.
\q2 Ha jụkwara ibi ndụ dịka iwu ya si dị.
\q1 
\v 11 Ha chefuru ihe o mere,
\q2 ọrụ ịtụnanya o gosiri ha.
\q1 
\v 12 Chineke rụrụ ọrụ ebube ndị a nʼihu nna nna ha
\q2 nʼala Ijipt na nʼọhịa Zoan.
\q1 
\v 13 O kewara oke osimiri, site nʼetiti ya dufee ha.
\q2 O mere ka mmiri ahụ guzo ọtọ dịka mgbidi.
\q1 
\v 14 O ji igwe ojii duo ha nʼije nʼehihie,
\q2 jirikwa ìhè sitere nʼọkụ ahụ, duo ha ogologo abalị niile.
\q1 
\v 15 Ọ gbawara oke nkume dị nʼọzara,
\q2 si otu a nye ha mmiri hiri nne, dịka a ga-asị na ọ bụ mmiri si nʼọtụtụ oke osimiri.
\q1 
\v 16 O mere ka mmiri iyi site na nkume gbapụta,
\q2 mee ka mmiri rudata dịka osimiri.
\b
\q1 
\v 17 Ha nọgidere na-emehie megide ya.
\q2 Ha nupuru isi nʼọzara megide Onye kachasị ihe niile elu.
\q1 
\v 18 Ha kpachara anya nwaa Chineke ọnwụnwa,
\q2 mgbe ha rịọrọ ya nri nke obi ha chọrọ.
\q1 
\v 19 Ha kwuhiere Chineke;
\q2 jụọ ya ọnụ sị, “Chineke ọ pụrụ inye anyị
\q2 ezi nri na mmiri ọṅụṅụ nʼọzara a?
\q1 
\v 20 Ọ bụ ezie na o tiri nkume ahụ ihe,
\q2 mee ka mmiri sọpụta,
\q2 mmiri iyi sọpụtara nʼebe o hiri nne,
\q1 ma ọ pụrụ inye anyị nri?
\q2 Ọ pụrụ inye ndị ya anụ?”
\q1 
\v 21 Mgbe \nd Onyenwe anyị\nd* nụrụ ihe ha kwuru, iwe were ya;
\q2 ọkụ ya repịara Jekọb,
\q2 iwe ọkụ ya biliri megide Izrel.
\q1 
\v 22 Nʼihi na ha ekwenyeghị na Chineke,
\q2 maọbụ tụkwasị obi na nzọpụta ya.
\q1 
\v 23 Nʼagbanyeghị ihe ndị a, o nyere mbara eluigwe iwu
\q2 meghekwa ọnụ ụzọ niile nke eluigwe.
\q1 
\v 24 O mere ka mánà zokwasị ndị mmadụ a dịka mmiri, ka ha rie.
\q2 O nyere ha mkpụrụ ọka nke si nʼeluigwe.
\q1 
\v 25 Ndị mmadụ tara achịcha ndị mmụọ ozi.
\q2 O zitere ha nri niile ha nwere ike iri.
\q1 
\v 26 O sitere nʼeluigwe tọpụ ikuku nke ọwụwa anyanwụ,
\q2 o jikwa ike ya duo ikuku nke ndịda.
\q1 
\v 27 O zidatara ha anụ dị ukwuu dịka ọ bụ uzuzu,
\q2 anụ ufe ọnụọgụgụ ha dịka ọnụọgụgụ aja dị nʼala ọnụ oke osimiri.
\q1 
\v 28 O mere ka ụmụ anụ ufe ndị a daara ha nʼala nʼetiti ọmụma ụlọ ikwu ha
\q2 nakwa gburugburu ụlọ ikwu ha.
\q1 
\v 29 Ha riri ihe tutu ruo mgbe ha enwekwaghị ike iri ọzọ,
\q2 nʼihi na o nyere ha ihe obi ha chọrọ.
\q1 
\v 30 Ha erisibeghị nri ahụ obi ha chọrọ,
\q2 anụ ụfọdụ dịkwa ha nʼọnụ,
\q1 
\v 31 mgbe iwe Chineke biliri imegide ha;
\q2 o tigburu ndị kachasị ike nʼetiti ha,
\q2 tigbukwaa ụmụ okorobịa ndị Izrel.
\b
\q1 
\v 32 Ma na-eleghị ihe ndị a anya, ha gakwara nʼihu na mmehie ha,
\q2 jụkwa ikwere nʼọrụ ebube niile Onyenwe anyị rụrụ.
\q1 
\v 33 O mere ka ụbọchị ndụ ha bụrụ ihe efu.
\q2 O mekwara ka afọ ha gwụsịa nʼobi ọlụlọ mmiri.
\q1 
\v 34 Mgbe ọbụla Chineke tigburu ha, ha na-achọ ya;
\q2 ha na-alaghachi azụ, chọsie ya ike.
\q1 
\v 35 Ha na-echeta na Chineke bụ Oke nkume ha,
\q2 na Chineke nke kachasị ihe niile elu bụrụ ha Onye Mgbapụta.
\q1 
\v 36 Ma mgbe ahụ, ha ga-eji naanị okwu efu fee ya ofufe,
\q2 were ire ha na-aghara ya ụgha.
\q1 
\v 37 Obi ha ekwesịkwaghị ike nye ya.
\q2 Ha ekwesighị ntụkwasị obi nye ọgbụgba ndụ ya.
\q1 
\v 38 Ma o meere ha ebere.
\q2 Ọ gbaghara ha mmehie ha.
\q2 Ọ laghị ha nʼiyi.
\q1 Ọtụtụ oge ka o jidere iwe ya.
\q2 Ọ kpalịkwaghị oke iwe ya.
\q1 
\v 39 Nʼihi na o chetara na ha bụ naanị anụ ahụ nke o kere eke,
\q2 chetakwa na ha dịka ikuku nke na-adịghị alọghachi azụ mgbe ọ gabigasịrị.
\b
\q1 
\v 40 Ọtụtụ oge ka ha nupuru isi megide ya nʼọzara;
\q2 ha kpasuru ya iwe nʼala ahụ tọgbọrọ nʼefu.
\q1 
\v 41 Mgbe mgbe, ha nwara Chineke;
\q2 ha kpasuru Onye Nsọ nke Izrel iwe.
\q1 
\v 42 Ha echetaghị ike ya,
\q2 ụbọchị ahụ ọ gbapụtara ha site nʼaka ndị na-emegbu ha;
\q1 
\v 43 nʼụbọchị o gosipụtara ihe ịrịbama niile nʼala Ijipt,
\q2 ọrụ ebube ya niile nʼọhịa Zoan.
\q1 
\v 44 O mere ka osimiri ha niile ghọọ ọbara.
\q2 Ha enwekwaghị ike ịṅụ mmiri si na ha.
\q1 
\v 45 O zigakwara igwe ijiji nʼetiti ha, nke tara ha,
\q2 zitekwa awọ nʼala ha, nke bibiri ha.
\q1 
\v 46 O zitekwara ụmụ ụkpana ndị tachapụrụ mkpụrụ a kụrụ nʼubi ha,
\q2 zitekwa igurube nke ripịara ihe niile a gaara eweta dịka ihe ubi.
\q1 
\v 47 O ji oke mkpụrụ mmiri mebie osisi vaịnị ha,
\q2 jirikwa igirigi jụrụ oke oyi bibie osisi sikamọ ha niile.
\q1 
\v 48 O weere ehi ha niile nyefee mkpụrụ mmiri,
\q2 werekwa anụ ụlọ ha nyefee amụma egbe eluigwe.
\q1 
\v 49 O zipụrụ iwe ọkụ ya nʼetiti ha,
\q2 oke iwe ya, na iwe ya, na mmeso nke iwe ya,
\q2 ndị mmụọ ozi na-ebibi ihe na-eleghị anya nʼazụ.
\q1 
\v 50 O doziri ụzọ nke iwe ya ga-eso;
\q2 o gbochighị ka ha ghara ịnwụ;
\q2 kama o nyefere ndụ ha nʼaka ọrịa na-efe efe.
\q1 
\v 51 O tigburu nwa ọbụla e bụ ụzọ mụọ nʼala Ijipt,
\q2 mkpụrụ mbụ nke ndị ikom nʼime ụlọ ikwu Ham.
\q1 
\v 52 Ma o dupụtara ndị nke ya dịka igwe atụrụ;
\q2 o duuru ha dịka atụrụ gafee ọzara.
\q1 
\v 53 O duuru ha nʼudo, ụjọ atụkwaghị ha,
\q2 ma osimiri kpuchigidere ndị iro ha.
\q1 
\v 54 Otu a ka o si duru ha bịaruo nʼoke ala nsọ ya,
\q2 ala ugwu ugwu ahụ nke aka nri ya nwetara.
\q1 
\v 55 Ọ chụpụrụ mba niile nʼihu ha,
\q2 tụọ ala ha kesara ha dịka ihe nketa;
\q2 o mere ka ebo niile nke Izrel biri nʼụlọ nke aka ha.
\b
\q1 
\v 56 Ma ha nwara Chineke ọnwụnwa,
\q2 nupu isi megide Onye kachasị ihe niile elu;
\q2 ha edebeghị ụkpụrụ ya.
\q1 
\v 57 Dịka nna nna ha, ha bụ ndị na-ekwesighị ntụkwasị obi, na ndị aghụghọ,
\q2 ha dịka ụta a na-ekweghị nke ọma.
\q1 
\v 58 Nʼihi ebe nchụaja ha wuru, ha mere ka iwe wee ya;
\q2 sitekwa nʼarụsị ha pịrị apị, ha kpaliri ekworo ya.
\q1 
\v 59 Mgbe Chineke nụrụ ha, iwe were ya nke ukwuu.
\q2 Ọ jụrụ ndị Izrel kpamkpam.
\q1 
\v 60 Ọ gbakụtara ụlọ nzute ya nke dị na Shaịlo\f + \fr 78:60 \ft Shaịlo dị nʼoke ala ebo Ifrem, nʼetiti Betel na Shekem. Ọ bụ ala nsọ ochie nʼoge Joshua, ebe ụmụ Izrel dọbara igbe ọgbụgba ndụ ahụ tutu ruo nʼoge Samuel. Ma ndị Filistia mesịrị bibie obodo a.\f* azụ,
\q2 ụlọ ikwu ahụ ọ mara nʼetiti ndị mmadụ.
\q1 
\v 61 O nyefere igbe ọgbụgba ndụ ike ya ka a dọta ya nʼagha,
\q2 o nyefekwara onye iro ahụ ebube ya nʼaka.
\q1 
\v 62 O kwere ka e gbuo ndị ya nʼagha;
\q2 iwe ya dị ọkụ megide ihe nketa ya.
\q1 
\v 63 Ọkụ repịara ụmụ okorobịa ha,
\q2 ọ dịkwaghị onye a gụụrụ egwu ọlụlụ di na nwunye, nʼetiti ụmụ agbọghọ ha;
\q1 
\v 64 E gburu ndị nchụaja ha nʼagha;
\q2 ndị inyom ha ndị di ha nwụrụ enwekwaghị ike iru ụjụ.
\b
\q1 
\v 65 Mgbe ahụ, onyenwe anyị tetara dịka onye si nʼụra teta,
\q2 dịka dike si nʼụra mmanya teta.
\q1 
\v 66 Ọ chụghachiri ndị iro ya azụ,
\q2 mee ha ihe ihere nke ga-adịgide ruo ebighị ebi.
\q1 
\v 67 Ọ jụrụ ụlọ ikwu Josef,
\q2 ọ họpụtaghị ebo Ifrem;
\q1 
\v 68 ma ọ họọrọ ebo Juda,
\q2 na ugwu Zayọn, nke ọ hụrụ nʼanya.
\q1 
\v 69 O wuru ụlọnsọ ya ka ọ dị ka ebe dị elu,
\q2 dịka ụwa nke o mere ka o guzosie ike ruo mgbe ebighị ebi.
\q1 
\v 70 Ọ họpụtara Devid, ohu ya,
\q2 kpọrọ ya site nʼọgba igwe atụrụ;
\q1 
\v 71 o si nʼebe ọ nọ na-azụ atụrụ kpọrọ ya,
\q2 ka ọ bịa bụrụ onye na-azụ ndị ya Jekọb,
\q2 na Izrel, ihe nketa ya dịka atụrụ.
\q1 
\v 72 Devid ji izuoke nke obi ya zụọ ha,
\q2 aka nke maara ihe ọ na-eme ka o ji duo ha.
\c 79
\cl Abụ Ọma 79
\d Abụ Ọma Asaf.
\s1 Akwa nʼihi mbibi Jerusalem
\q1 
\v 1 O Chineke, mba dị iche iche abatala nʼihe nketa gị;
\q2 ha emerụọla ụlọnsọ ukwuu gị,
\q2 ha etikpọọla Jerusalem, mee ka ọ tọgbọrọ nʼefu.
\q1 
\v 2 Ha ewerela ozu ndị ohu gị nye anụ ufe niile nke eluigwe
\q2 ka ọ bụrụ ihe oriri nye ha,
\q2 werekwa ozu nke ndị nsọ gị nye anụ ọhịa niile nke ụwa.
\q1 
\v 3 Ha awụpụla ọbara dịka mmiri
\q2 nʼakụkụ niile nke Jerusalem,
\q2 ọ dịghị otu onye fọdụrụ nke ga-eli ndị nwụrụ anwụ.
\q1 
\v 4 Anyị aghọọla ihe ịta ụta nʼebe ndị agbataobi anyị nọ,
\q2 ghọọkwara ndị gbara anyị gburugburu ihe ịchị ọchị, na ihe ịkwa emo.
\b
\q1 
\v 5 O \nd Onyenwe anyị\nd*, ruo olee mgbe? Ị ga-ewe iwe ruo mgbe ebighị ebi?
\q2 Ruo olee mgbe ka ekworo gị ga na-ere dịka ọkụ?
\q1 
\v 6 Wụkwasị mba niile ndị na-amaghị gị
\q2 dịka Chineke oke iwe gị,
\q1 bụ alaeze niile ndị ahụ
\q2 na-adịghị akpọku aha gị;
\q1 
\v 7 nʼihi na ha eripịala Jekọb
\q2 mekwaa ka ebe obibi ya tọgbọrọ nʼefu.
\b
\q1 
\v 8 Atala anyị ahụhụ mmehie nke nna nna anyị mere;
\q2 ka ebere gị bịa ngwangwa zute anyị,
\q2 nʼihi na anyị nọ nʼọnọdụ oke mkpa.
\q1 
\v 9 Nyere anyị aka, O Chineke, Onye Nzọpụta anyị,
\q2 nʼihi ebube nke aha gị;
\q1 napụta anyị, gbaghara mmehie anyị niile
\q2 nʼihi aha gị.
\q1 
\v 10 Gịnị mere ndị mba ọzọ ji na-ajụ ajụjụ sị,
\q2 “Olee ebe Chineke ha nọ?”
\b
\q1 Nʼihu anyị, mee ka a mara nʼetiti ndị mba ọzọ,
\q2 na ị na-abọ ọbọ ọbara ndị ohu gị niile a wufuru.
\q1 
\v 11 Gee ntị nʼịsụ ude nke ndị nọ nʼụlọ mkpọrọ;
\q2 site nʼike nke aka gị chebe ndị niile a mara ikpe ọnwụ.
\q1 
\v 12 Bọọ ọbọ ugboro asaa megide ndị agbataobi anyị
\q2 nʼihi ụta ha tara gị, O Onyenwe anyị.
\q1 
\v 13 Mgbe ahụ, anyị bụ ndị gị, ụmụ igwe atụrụ gị
\q2 ga-eto gị ruo mgbe niile ebighị ebi;
\q1 anyị ga na-ekwupụta otuto gị,
\q2 site nʼọgbọ ruo nʼọgbọ.
\c 80
\cl Abụ Ọma 80
\d Abụ Ọma nke dịrị onyeisi Abụ. Ọ bụ olu abụ eji ekwe “Okoko lili nke Ọgbụgba Ndụ” Abụ Ọma nke Asaf.
\s1 Ekpere maka nnapụta
\q1 
\v 1 Nụrụ olu anyị, O Onye ọzụzụ atụrụ nke Izrel,
\q2 gị onye na-edu Josef dịka igwe atụrụ.
\q1 Gị onye na-anọdụ dịka eze, nʼetiti cherubim,
\q2 nwupụta Ìhè
\v 2 nʼihu Ifrem, Benjamin na Manase.\f + \fr 80:2 \ft Ebo atọ ndị a bụ ụmụ ụmụ Rechel, bụ ndị soo igbe ọgbụgba ndụ ahụ nʼazụ mgbe ndị Izrel na-ala nʼala nkwa ahụ.\f*
\q1 Kpọtee ịdị ike gị,
\q2 bịa zọpụta anyị.
\b
\q1 
\v 3 O Chineke, kpọghachi anyị azụ,
\q2 mee ka ihu gị nwukwasị anyị,
\q2 ka e nwee ike ịzọpụta anyị.
\b
\q1 
\v 4 O \nd Onyenwe anyị\nd*, Chineke, Onye pụrụ ime ihe niile
\q2 ruo ole mgbe ka iwe gị ga-adị ọkụ
\q2 megide ekpere ndị gị?
\q1 
\v 5 I jirila anya mmiri dịka a ga-asị na ọ bụ achịcha zụọ ha nri;
\q2 i meela ka ha ṅụọ anya mmiri nʼihe ọtụtụ.
\q1 
\v 6 I meela ka anyị bụrụ ihe na-eweta esemokwu nʼetiti ndị agbataobi anyị,
\q2 ndị iro anyị na-achịkwa anyị ọchị.
\b
\q1 
\v 7 O Chineke, Onye pụrụ ime ihe niile, kpọghachi anyị azụ,
\q2 mee ka ihu gị nwukwasị anyị,
\q2 ka e nwee ike ịzọpụta anyị.
\b
\q1 
\v 8 I sitere nʼala Ijipt wepụta osisi vaịnị;
\q2 ị chụpụrụ mba ndị ọzọ, kụọ ya.
\q1 
\v 9 Ị sụchaara ya ala,
\q2 mgbọrọgwụ ya bara nʼime ala nke ọma, o jupụtakwara ala ahụ niile.
\q1 
\v 10 Ndo ya kpuchiri ugwu niile,
\q2 alaka ya gbasara kpuchie osisi sida ukwu sida.
\q1 
\v 11 Ọ wasaala alaka ya ruo oke osimiri
\q2 wasaakwa ume ya ruo osimiri.\f + \fr 80:11 \ft Eleghị anya osimiri ndị a bụ osimiri Mediterenịa na Yufretis. Nʼoge ọchịchị eze Devid na Solomọn, alaeze ha kwụsịrị nʼosimiri abụọ ndị a.\f*
\b
\q1 
\v 12 Gịnị mere i ji tiwasịa mgbidi ya niile
\q2 si otu a mee ka ndị niile na-agafe ghọrọ mkpụrụ ya?
\q1 
\v 13 Oke ezi si nʼoke ọhịa na-emebisi ya,
\q2 ụmụ ahụhụ si nʼọhịa dị iche iche na-ejikwa ya emere ihe oriri.
\q1 
\v 14 Lọghachikwute anyị, O Chineke, Onye pụrụ ime ihe niile.
\q2 Si nʼeluigwe ledata anya ma hụ!
\q1 Letakwa osisi vaịnị a,
\q2 
\v 15 mgbọrọgwụ nke aka nri gị kụrụ,
\q2 ọkpara nke ị zụlitere nye onwe gị.
\b
\q1 
\v 16 E gbutuola osisi vaịnị gị, e ji ọkụ repịa ya;
\q2 mgbe ị bara mba, ndị gị na-ala nʼiyi.
\q1 
\v 17 Ka aka gị dịkwasị nwoke ahụ nọ nʼaka nri gị,
\q2 nwa nke mmadụ onye ị zụlitere nye onwe gị.
\q1 
\v 18 Mgbe ahụ, anyị agaghị esikwa nʼebe ị nọ laghachi azụ;
\q2 tutee anyị, anyị ga-akpọkukwa aha gị.
\b
\q1 
\v 19 Kpọghachi anyị azụ, O \nd Onyenwe anyị\nd*, Chineke, Onye pụrụ ime ihe niile
\q2 mee ka ihu gị nwukwasị anyị,
\q2 ka e nwee ike zọpụta anyị.
\c 81
\cl Abụ Ọma 81
\d Abụ Ọma nke dịrị onyeisi Abụ. Abụ nke Asaf nʼusoro gittit.
\s1 Ịdị mma nke Chineke
\q1 
\v 1 Bụkuo Chineke bụ ike anyị abụ ọṅụ,
\q2 tikusie Chineke Jekọb mkpu ike!
\q1 
\v 2 Bidonụ iti egwu, kụọ ihe iti egwu,
\q2 kpọọnụ ụbọ akwara na-enye abụ ụtọ na une.
\b
\q1 
\v 3 Fụọnụ opi ike nʼoge ọnwa ọhụrụ,
\q2 na mgbe ọnwa gbapụtara nʼuju ya, nʼụbọchị mmemme anyị;
\q1 
\v 4 nke a bụ iwu dịrị Izrel,
\q2 ụkpụrụ Chineke nke Jekọb.
\q1 
\v 5 O mere ka o guzosie ike dịka iwu nye Josef
\q2 mgbe ọ pụrụ imegide Ijipt.
\b
\q1 Anụkwara m olu nʼasụsụ nke m na-amaghị, ka ọ na-asị:
\b
\q1 
\v 6 “Ewezugala m ibu arọ site nʼubu ha;
\q2 aka ha abụọ nwere onwe ha site nʼịrụ ọrụ.
\q1 
\v 7 Nʼime ihe mgbu unu, unu kpọrọ oku, anapụtara m unu,
\q2 azara m unu site nʼegbe eluigwe;
\q2 anwara m unu na mmiri nke Meriba. \qs Sela\qs*
\b
\q1 
\v 8 “Nụrụnụ, ndị m, aga m adọ unu aka na ntị,
\q2 a sịkwarị na unu ga-ege m ntị, unu ndị Izrel!
\q1 
\v 9 Unu agaghị enwe chi ndị mba ọzọ nʼetiti unu;
\q2 unu agaghị akpọkwa isiala nye chi si ala ọzọ.
\q1 
\v 10 Abụ m \nd Onyenwe anyị\nd* Chineke unu,
\q2 onye kpọpụtara unu site nʼala Ijipt.
\q1 Meghe ọnụ unu ka ọ saa mbara, aga m emeju ya.
\b
\q1 
\v 11 “Ma ndị m ekweghị ige m ntị.
\q2 Izrel emekwaghị dịka m gwara ha.
\q1 
\v 12 Ya mere, ahapụrụ m ha na ndụ isiike ha,
\q2 ka ha soro nchepụta nke echiche ha.
\b
\q1 
\v 13 “Ewoo, a sị na ndị m gaara ege m ntị,
\q2 a sịkwa na Izrel ga-eso ụzọ m niile.
\q1 
\v 14 Ọ gaghị adị anya mgbe m ga-eji ike m, wezuga ndị iro ya site nʼọnọdụ ha.
\q2 Aga m eweli aka m, megide ndị iro ya niile.
\q1 
\v 15 Ndị niile kpọrọ \nd Onyenwe anyị\nd* asị, ga-ada nʼihu ya nʼụjọ.
\q2 Ịta ahụhụ ha ga-adịgidekwa, ruo ebighị ebi.
\q1 
\v 16 Ma a ga-eji ụtụ ọka wiiti kachasị mma, nyejuo unu afọ;
\q2 aga m ejikwa mmanụ aṅụ nke sitere nʼoke nkume, nyejuo unu afọ.”
\c 82
\cl Abụ Ọma 82
\d Abụ Ọma Asaf.
\s1 Chineke onye ikpe kachasị ndị ikpe
\q1 
\v 1 Chineke na-ewere ọnọdụ ịchị isi nʼetiti ọgbakọ dị ukwuu;
\q2 ọ na-ekpebi ikpe nʼetiti chi niile.
\b
\q1 
\v 2 Ruo ole mgbe ka unu ga-anọgide na-ekpe ikpe na-ezighị ezi?
\q2 Ruo ole mgbe ka unu ga na-egosi ndị ajọ omume ihuọma? \qs Sela\qs*
\q1 
\v 3 Kperenụ ndị na-adịghị ike na ndị na-enweghị nna ikpe ziri ezi;
\q2 hụnụ na ndị ogbenye na ndị a na-emegbu nwetara ihe ruuru ha.
\q1 
\v 4 Gbapụtanụ ndị na-adịghị ike na ndị nọ na mkpa;
\q2 napụta ha site nʼaka ndị ajọ omume.
\b
\q1 
\v 5 Ha\f + \fr 82:5 \ft Maọbụ, \fqa chi ndị a\f* amaghị ihe ọbụla, ha aghọtaghị ihe ọbụla.
\q2 Ha na-ejegharị nʼọchịchịrị;
\q2 ntọala niile nke ụwa na-ama jijiji.
\b
\q1 
\v 6 “Asịrị m, ‘Unu bụ “chi,”
\q2 unu niile bụ ụmụ ndị ikom nke Onye kachasị ihe niile elu.’
\q1 
\v 7 Ma unu ga-anwụ ọnwụ dịka mmadụ ndị ọzọ;
\q2 unu ga-ada dịka ndị ọchịchị ọzọ.”
\b
\q1 
\v 8 O Chineke, bilie kpee ụwa ikpe,
\q2 nʼihi na mba niile bụ ihe nketa gị.
\c 83
\cl Abụ Ọma 83
\d Abụ, bụ Abụ Ọma Asaf.
\s1 Ekpere maka mmeri
\q1 
\v 1 O! Chineke agbachikwala nkịtị.
\q2 Biko, Chineke, ahapụkwala ikwu okwu,
\q2 anọkwala jụụ.
\q1 
\v 2 Lee na ndị iro gị nọ na-ebigbọ,
\q2 ndị kpọrọ gị asị na-eweli isi ha.
\q1 
\v 3 Ha ji aghụghọ na-agba izu imegide ndị gị;
\q2 ha na-atụ atụmatụ ọjọọ megide ndị ị hụrụ nʼanya.
\q1 
\v 4 Ha na-asị, “Bịanụ ka anyị laa mba a nʼiyi,
\q2 ka a ghara ichetakwa aha Izrel ọzọ.”
\b
\q1 
\v 5 Ha ji otu obi na-agbarịta izu;
\q2 ha agbaala ndụ imegide gị,
\q1 
\v 6 ụlọ ikwu niile nke ndị Edọm, na ndị Ishmel,
\q2 na ndị Moab, na ndị Haga,
\q1 
\v 7 na ndị Gebal, na ndị Amọn, na ndị Amalek,
\q2 na ndị Filistia, ha na ndị Taịa.
\q1 
\v 8 Ọ bụladị ndị Asịrịa esorokwala ha,
\q2 ịgba ndị agbụrụ Lọt ume. \qs Sela\qs*
\b
\q1 
\v 9 Mee ha dịka i si mee ndị Midia,
\q2 na dịka i mere Sisera na Jabin,\f + \fr 83:9 \ft Eze Jabin na nwa ya Sisera, bụ ndị Debọra meriri nʼagha nʼugwu Taboa. \xt Nkp 4:15-24; 5:20-21.\xt*\f* nʼakụkụ iyi Kishọn,
\q1 
\v 10 ndị lara nʼiyi nʼEndoa
\q2 ma ghọọ ihe dịka nsị anụ e kpofuru ekpofu nʼala.
\q1 
\v 11 Mee ka ndị ọgaranya ha dịka Oreb na Zeeb,\f + \fr 83:11 \ft Ha bụ ndị eze, bụrụkwa ndị ọchịagha ndị Midia. Ha so na ndị Gidiọn meriri nʼagha, \xt Nkp 7:25\xt*\f*
\q2 ka ụmụ ndị ikom eze ha niile dịka Zeba na Zalmuna,
\q1 
\v 12 ndị sịrị, “Ka anyị nwetara onwe anyị,
\q2 ebe ịta nri ụmụ anụmanụ niile nke Chineke.”
\b
\q1 
\v 13 O Chineke m, mee ha ka dịka ahịhịa ifufe na-efegharị gburugburu,
\q2 maọbụ dịka igbugbo ọka nʼebe ifufe dị.
\q1 
\v 14 Dịka ọkụ na-erepịa oke ọhịa,
\q2 maọbụ nke na-ere nʼelu ugwu,
\q1 
\v 15 si otu a were oke ifufe chụọ ha ọsọ,
\q2 jiri oke ifufe nke na-eso mmiri ozuzo mee ka ha nọrọ nʼọnọdụ obi ọlụlọ mmiri.
\q1 
\v 16 Were ihere kpuchie ha ihu,
\q2 ka ndị mmadụ si otu a chọọ aha gị, O \nd Onyenwe anyị\nd*.
\b
\q1 
\v 17 Ka ha nọdụ nʼọnọdụ ihere na ịda mba mgbe niile;
\q2 ka ha laa nʼiyi nʼọnọdụ mweda nʼala.
\q1 
\v 18 Mee ka ha mata na gị, onye aha ya bụ \nd Onyenwe anyị\nd*,
\q2 na ọ bụ naanị gị bụ Onye kachasị ihe niile elu nʼụwa niile.
\c 84
\cl Abụ Ọma 84
\d Abụ Ọma nke dịrị onyeisi Abụ. Abụ Ọma ụmụ Kora nʼusoro gittit.
\s1 Agụụ nke ụlọnsọ Chineke
\q1 
\v 1 Lee ka ebe obibi gị sị maa mma,
\q2 O \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile!
\q1 
\v 2 Ọ na-agụsị mkpụrụobi m agụụ ike, e mkpụrụobi m na-adakwa mba,
\q2 ịbata nʼogige \nd Onyenwe anyị\nd*;
\q1 mkpụrụobi m na anụ ahụ m na-eti mkpu
\q2 na-achọ Chineke dị ndụ.
\q1 
\v 3 Ọ bụladị ụmụ nnụnụ nta nke eluigwe, achọtala ebe obibi;
\q2 eleke achọtakwarala onwe ya akwụ,
\q2 ebe ọ ga na-edebe ụmụ ya,
\q1 nʼakụkụ ebe ịchụ aja nsọ gị,
\q2 O \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, Eze m na Chineke m.
\q1 
\v 4 Ndị a gọziri agọzi ka ndị bi nʼụlọ gị bụ;
\q2 ha na-eto gị mgbe niile. \qs Sela\qs*
\b
\q1 
\v 5 Ndị a gọziri agọzi ka ha bụ, bụ ndị ike ha nwere dị na gị,
\q2 ndị kpebiri nʼobi ha ịga njem.
\q1 
\v 6 Mgbe ha na-esite na Ndagwurugwu Baka na-agafe,
\q2 ha na-eme ya ka ọ bụrụ ebe isi iyi dị iche iche na-asọpụta;
\q2 mmiri ozuzo mbụ na-ewere ngọzị niile kpuchie ya.\f + \fr 84:6 \ft Na-ewere ọdọ mmiri kpuchie ya\f*
\q1 
\v 7 Ike ha na-abawanye abawanye,
\q2 tutu ha niile nʼotu na otu, abịa guzo nʼihu Chineke na Zayọn.
\b
\q1 
\v 8 O \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, nụrụ ekpere m.
\q2 Gee m ntị, gị Chineke nke Jekọb.
\q1 
\v 9 Lekwasị anya nʼọta anyị, O Chineke,
\q2 jiri ihuọma lekwasị onye gị e tere mmanụ anya.
\b
\q1 
\v 10 Otu mkpụrụ ụbọchị a nọrọ nʼime ogige gị,
\q2 karịrị puku ụbọchị a nọrọ ebe ọzọ;
\q1 ọ ga-akara m mma ịbụ onye nche nʼọnụ ụzọ ụlọnsọ Chineke m,
\q2 karịa ibi nʼụlọ ikwu nke ndị ajọ omume.
\q1 
\v 11 \nd Onyenwe anyị\nd* Chineke bụ anyanwụ\f + \fr 84:11 \ft \xt Aịz 60:19,20; Mkp 21:23\xt*\f* na ọta;
\q2 Onyenwe anyị na-enye ihuọma na nsọpụrụ;
\q1 ọ naghị egbochi ihe ọma ọbụla
\q2 site nʼebe ndị na-eje ije nʼizuoke nọ.
\b
\q1 
\v 12 O \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile,
\q2 ngọzị na-adịrị ndị niile na-atụkwasị gị obi.
\c 85
\cl Abụ Ọma 85
\d Abụ Ọma nke dịrị onyeisi Abụ. Abụ Ọma ụmụ Kora.
\s1 Ekpere maka ihuọma
\q1 
\v 1 O \nd Onyenwe anyị\nd*, i gosila ala gị ihuọma;
\q2 i nyeghachila Jekọb akụnụba ya.
\q1 
\v 2 I gbagharala ajọ omume ndị gị,
\q2 kpuchikwaa mmehie ha niile. \qs Sela\qs*
\q1 
\v 3 Ị kwụsịla iwe oke iwe gị,
\q2 I sikwala nʼịdị ọkụ nke iwe gị chigharịa.
\b
\q1 
\v 4 Kpọghachi anyị azụ, O Chineke, Onye Nzọpụta anyị,
\q2 wezuga iwe gị site nʼebe anyị nọ.
\q1 
\v 5 Ọ bụ ruo mgbe ebighị ebi, ka ị ga na-eweso anyị iwe:
\q2 Ị ga-eme ka iwe gị dịgide ruo ọgbọ niile?
\q1 
\v 6 Ị gaghị eme ka anyị dịkwa ndụ ọzọ
\q2 ka ndị gị ṅụrịa ọṅụ nʼime gị?
\q1 
\v 7 O \nd Onyenwe anyị\nd*, gosi anyị ịhụnanya gị nke na-adịgide,
\q2 nyekwa anyị nzọpụta gị.
\b
\q1 
\v 8 Aga m ege ntị mara ihe Chineke, onye bụ \nd Onyenwe anyị\nd* ga-ekwu;
\q2 ọ na-ekwe ndị ya, ndị nsọ ya nkwa udo,
\q2 ma ka ha ghara ịlọghachi na nzuzu.
\q1 
\v 9 Nʼezie, nzọpụta ya dị nso\f + \fr 85:9 \ft \xt Aịz 46:13\xt*\f* ndị na-atụ egwu ya,
\q2 ka ebube ya si otu a dịgide nʼala anyị.
\b
\q1 
\v 10 Ịhụnanya na ikwesi ntụkwasị obi ezukọtala;
\q2 ezi omume na udo esutula ọnụ.
\q1 
\v 11 Ikwesi ntụkwasị obi ga-esite nʼala pupụta,
\q2 ezi omume ga-esite nʼeluigwe ledata anya.
\q1 
\v 12 Nʼezie, \nd Onyenwe anyị\nd* ga-enye ihe dị mma,
\q2 ala anyị ga-amịkwa mkpụrụ ubi ya.
\q1 
\v 13 Ezi omume ga-aga nʼihu ya,
\q2 idoziri ya ụzọ ọ ga-esi gaa.
\c 86
\cl Abụ Ọma 86
\d Ekpere Devid.
\s1 Ekpere maka enyemaka
\q1 
\v 1 Gee m ntị, O \nd Onyenwe anyị\nd*, ma zakwa m,
\q2 nʼihi na abụ m ogbenye na onye nọ na mkpa.
\q1 
\v 2 Chebe ndụ m, nʼihi na m na-erubere gị isi;
\q2 zọpụta ohu gị onye nke na-atụkwasị gị obi.
\q1 Ị bụ Chineke m;
\v 3 meere m ebere, O Onyenwe m,
\q2 nʼihi na ana m akpọku gị ogologo ụbọchị niile.
\q1 
\v 4 Wetara ohu gị ọṅụ, nʼihi na ọ bụ gị, O Onyenwe m,
\q2 ka m na-eweliri mkpụrụobi m.
\b
\q1 
\v 5 Ị bụ onye na-agbaghara ajọ omume na onye dị mma, O Onyenwe m,
\q2 i jupụtara nʼịhụnanya nye ndị niile na-akpọku gị.
\q1 
\v 6 O \nd Onyenwe anyị\nd*, nụrụ ekpere m;
\q2 gekwaa ntị nʼakwa arịrịọ m maka ebere.
\q1 
\v 7 Nʼụbọchị nsogbu m, aga m akpọku gị,
\q2 nʼihi na ị ga-aza m.
\b
\q1 
\v 8 Nʼetiti chi niile, i nweghị oyiri, O Onyenwe m;
\q2 ọ dịghị ọrụ ebube ọbụla a pụrụ ị sị na ọ dị ka nke ị na-arụ.
\q1 
\v 9 Mba niile i kere ga-abịa nʼihu gị,
\q2 fee gị ofufe, O Onyenwe anyị;
\q2 ha ga-ebutere aha gị ebube.
\q1 
\v 10 Nʼihi na ị dị ukwuu na-arụkwa ọrụ ebube dị iche iche;
\q2 ọ bụ naanị gị bụ Chineke.
\b
\q1 
\v 11 Kuziere m ụzọ gị, O \nd Onyenwe anyị\nd*,
\q2 ka m dabere nʼikwesị ntụkwasị obi gị;
\q1 nye m obi na-adịghị agba abụọ,
\q2 ka m nwee ike tụọ egwu aha gị.
\q1 
\v 12 Aga m eji obi m niile too gị, O Onyenwe anyị, na Chineke m;
\q2 aga m ebulikwa aha gị elu ruo mgbe niile ebighị ebi.
\q1 
\v 13 Nʼihi na ịhụnanya gị nʼebe m nọ dị ukwuu;
\q2 i sitela nʼomimi nke dị ala
\q2 site nʼala ndị nwụrụ anwụ dọpụta m.
\b
\q1 
\v 14 O Chineke, ndị mpako na-emegide m;
\q2 otù ndị mmadụ na-eme ihe ike na-achọ igbu m,
\q2 ha bụ ndị na-ejighị gị kpọrọ ihe ọbụla.
\q1 
\v 15 Ma gị, Onyenwe anyị, ị bụ Chineke onye ọmịiko na onye amara,
\q2 iwe adịghị ewe gị ngwangwa, i jupụtara nʼịhụnanya na ikwesi ntụkwasị obi.
\q1 
\v 16 Chee m ihu, mekwaara m amara.
\q2 Nye ohu gị ike gị,
\q1 zọpụtakwa nwa ohu gị nwanyị
\q2 nʼihi na m na-ejere gị ozi.
\q1 
\v 17 Gosi m ihe ịrịbama nke ga-egosipụta ịdị mma gị,
\q2 ka ndị iro m hụ ya si otu a bụrụ ndị ihere ga-eme,
\q2 nʼihi na gị, O \nd Onyenwe anyị\nd*, nyere m aka ma kasịekwa m obi.
\c 87
\cl Abụ Ọma 87
\d Abụ Ọma ụmụ Kora. Otu Abụ.
\s1 Abụ maka Zayọn
\q1 
\v 1 Chineke atọọla ntọala ya nʼelu ugwu nsọ ahụ;
\q1 
\v 2 \nd Onyenwe anyị\nd* hụrụ ọnụ ụzọ ama Zayọn nʼanya,
\q2 karịa ebe obibi niile nke Jekọb.
\b
\q1 
\v 3 Ihe dị iche iche nke dị ebube ka a na-ekwu banyere gị,
\q2 O obodo Chineke; \qs Sela\qs*
\q1 
\v 4 “Aga m agụnye Rehab na Babilọn,
\q2 dịka ndị na-asọpụrụ m,
\q1 aga m agụnyekwa ndị Filistia, na ndị Taịa, na ndị Kush,
\q2 aga m asị, ‘A mụrụ nke a na Zayọn.’ ”
\q1 
\v 5 Nʼezie, a ga-ekwu okwu banyere Zayọn sị,
\q2 “A mụrụ nke a na nke ọzọ nʼime ya,
\q2 ya onwe ya, bụ Onye kachasị ihe niile elu, ga-eme ka o guzosie ike.”
\q1 
\v 6 \nd Onyenwe anyị\nd* ga-ede nʼime akwụkwọ usoro nke ndị mmadụ:
\q2 “A mụrụ onye a na Zayọn.”
\b
\q1 
\v 7 Dịka ha na-eti egwu, ha ga-abụ abụ sị,
\q2 “Isi iyi m niile dị na gị.”
\c 88
\cl Abụ Ọma 88
\d Abụ, bụ Abụ Ọma ụmụ Kora, nke dịrị onyeisi Abụ. Nʼusoro olu abụ \tl Mahalat leannot.\tl* Abụ \tl Maskil\tl* nke Heman onye Ezra.
\s1 Akwa maka enyemaka
\q1 
\v 1 O \nd Onyenwe anyị\nd*, Chineke onye na-azọpụta m,
\q2 nʼehihie na abalị ka m na-eti mkpu akwa nʼihu gị.
\q1 
\v 2 Ka ekpere m bịa nʼihu gị.
\q2 Chee ntị gị nụrụ akwa m.
\b
\q1 
\v 3 Nʼihi na ọtụtụ nsogbu ejupụtala mkpụrụobi m,
\q2 anọ m nso nʼọnụ ụzọ ọnwụ.
\q1 
\v 4 Agụnyela m nʼetiti ndị na-arịda nʼolulu.
\q2 Adị m dịka onye na-enweghị ike.
\q1 
\v 5 A họpụtara mụ na ndị nwụrụ anwụ iche,
\q2 dịka ndị e gburu egbu na-edina nʼili,
\q1 ndị ị nakwaghị echeta ọzọ,
\q2 ndị e kewapụrụ site na nlekọta gị.
\b
\q1 
\v 6 Ị tụbanyela m nʼime olulu dịkarịrị omimi,
\q2 olulu nke ọchịchịrị jupụtara nʼime ya.
\q1 
\v 7 Oke iwe gị na-anyịgide m nke ukwuu;
\q2 i jirila ebili mmiri gị niile kpuchigide m. \qs Sela\qs*
\q1 
\v 8 Ị napụla m ndị enyi m, ndị m hụrụ nʼanya,
\q2 mee ka m bụrụ ihe a na-asọ oyi nʼebe ha nọ.
\q1 Abụ m onye emechibidoro ụzọ; nke nʼenweghị ike ịpụ ezi;
\q2 
\v 9 anya m adịghị ahụkwa ụzọ nʼihi iru ụjụ.
\b
\q1 O \nd Onyenwe anyị\nd*, ụbọchị niile ka m na-akpọku gị;
\q2 ana m agbasa aka m abụọ nʼihu gị,
\q1 
\v 10 ọ bụ ndị nwụrụ anwụ ka ị na-egosi ọrụ ebube gị?
\q2 Ndị nwụrụ anwụ, ha na-ebili too gị? \qs Sela\qs*
\q1 
\v 11 Ọ bụ nʼime ili ka a na-ekwupụta ịhụnanya gị?
\q2 A na-ekwupụta ikwesi ntụkwasị obi gị nʼebe ịla nʼiyi?
\q1 
\v 12 A na-amata banyere ọrụ ebube gị nʼebe ọchịchịrị dị?
\q2 Ma ọ bụ ọrụ ezi omume gị, na ịdị mma gị niile nʼala ndị e chezọrọ echezọ?
\b
\q1 
\v 13 Ma \nd Onyenwe anyị\nd* m, ọ bụ gị ka m na-akpọku.
\q2 Ụtụtụ niile ka ekpere m ga na-abịa nʼebe ị nọ.
\q1 
\v 14 O \nd Onyenwe anyị\nd*, gịnị mere i jiri jụ m?
\q2 Gịnị mekwara i jiri zonarị m ihu gị?
\b
\q1 
\v 15 Site na mgbe okorobịa m, abụ m onye a na-esogbu, onye nọkwa ọnwụ nso;
\q2 ataala m ahụhụ oke ụjọ gị, anọ m nʼọnọdụ ịda mba.
\q1 
\v 16 Oke iwe gị agabigala nʼahụ m;
\q2 ihe egwu gị alaala m nʼiyi.
\q1 
\v 17 Ha na-agba m gburugburu ụbọchị niile dịka idee mmiri;
\q2 ha gbara m gburugburu nʼakụkụ niile.
\q1 
\v 18 Ị napụla m ndị enyi m na ndị m hụrụ nʼanya;
\q2 ọchịchịrị bụ enyi m nọkarịsịrị m nso.
\c 89
\cl Abụ Ọma 89
\d Abụ \tl maskil\tl* nke Etan, onye Ezra.
\s1 Ọgbụgba ndụ Chineke na Devid
\q1 
\v 1 Aga m abụ abụ banyere oke ịhụnanya \nd Onyenwe anyị\nd* ruo mgbe ebighị ebi;
\q2 aga m eji ọnụ m mee ka ọgbọ niile mara
\q2 maka ikwesi ntụkwasị obi gị.
\q1 
\v 2 Aga m ekwupụta na ịhụnanya gị na-adịgide ruo mgbe ebighị ebi;
\q2 na i mere ka ikwesi ntụkwasị obi gị, guzosie ike nʼeluigwe.
\q1 
\v 3 Onyenwe anyị sịrị, “Mụ na onye m họpụtara agbaala ndụ.
\q2 Aṅụọkwala m iyi nye ohu m Devid sị,
\q1 
\v 4 ‘Aga m eme ka agbụrụ gị guzosie ike ruo mgbe ebighị ebi
\q2 meekwa ka ocheeze gị dịgide ruo ọgbọ niile.’ ” \qs Sela\qs*
\b
\q1 
\v 5 O \nd Onyenwe anyị\nd*, eluigwe na-eto ọrụ ebube gị niile,
\q2 na ikwesi ntụkwasị obi gị, nʼetiti nzukọ ndị dị nsọ.
\q1 
\v 6 Nʼihi, ọ bụ onye nʼeluigwe niile, ka a ga-eji tụnyere \nd Onyenwe anyị\nd*?
\q2 Onye yiri \nd Onyenwe anyị\nd* nʼetiti ndị mmụọ ozi niile?
\q1 
\v 7 Na nzukọ ndị nsọ, Chineke bụ onye a na-atụ oke egwu;
\q2 ọ dị oke egwu karịa ndị niile gbara ya gburugburu.
\q1 
\v 8 O \nd Onyenwe anyị\nd* Chineke Onye pụrụ ime ihe niile, onye dịka gị?
\q2 Gị, O \nd Onyenwe anyị\nd*, dị ike nke ukwuu, ikwesi ntụkwasị obi gị na-agba gị gburugburu.
\b
\q1 
\v 9 Ị na-achị osimiri nke ji ike na-asọ;
\q2 mgbe ebili mmiri ya na-amali elu; i na-eme ka ha dajụọ.
\q1 
\v 10 Ị zọpịara Rehab dịka otu nʼime ndị ahụ e gburu egbu;
\q2 jiri aka gị dị ike chụsasịa ndị iro gị.
\q1 
\v 11 Ọ bụ gị nwe eluigwe; gị nwekwa ụwa,
\q2 ọ bụ gị tọrọ ntọala elu ụwa dum, na ihe niile dị nʼime ya.
\q1 
\v 12 Ọ bụ gị kere ugwu na ndịda;
\q2 Taboa na Hemon na-abụ abụ ọṅụ nʼihi aha gị.
\q1 
\v 13 Aka gị ka e mejupụtara nʼike;
\q2 aka gị dị ike, a na-ebuli aka nri gị elu.
\b
\q1 
\v 14 Ezi omume na ikpe ziri ezi, bụ ntọala ocheeze gị;
\q2 ịhụnanya na ikwesi ntụkwasị obi, na-aga nʼihu gị.
\q1 
\v 15 Ndị a gọziri agọzi ka ndị ahụ bụ ndị na-eji olu iti mkpu ọṅụ na-abụku gị abụ,
\q2 ndị na-ejegharịkwa nʼìhè nke ihu gị, O \nd Onyenwe anyị\nd*.
\q1 
\v 16 Ha na-aṅụrị ọṅụ nʼaha gị ogologo ụbọchị niile;
\q2 ha na-aṅụrị nʼezi omume gị.
\q1 
\v 17 Nʼihi na ị bụ ebube na ike ha,
\q2 site nʼihuọma gị, ị na-ebuli mpi anyị elu.
\q1 
\v 18 Nʼezie, ọta anyị bụ nke \nd Onyenwe anyị\nd*,
\q2 eze anyị bụkwa nke Onye nsọ Izrel.
\b
\q1 
\v 19 I kwuru okwu otu mgbe site nʼọhụ,
\q2 nye ndị gị kwesiri ntụkwasị obi sị:
\q1 “Enyela m otu onye dị ike agha ike;
\q2 Ebuliela m otu nwa okorobịa elu site nʼetiti ndị m.
\q1 
\v 20 Achọtala m Devid ohu m,
\q2 were mmanụ nsọ m tee ya.
\q1 
\v 21 Aka m ga-agba ya ume;
\q2 nʼezie, aka m ga-eme ka ọ dị ike.
\q1 
\v 22 Ọ dịghị onye iro ga-abịakwasị ya, na mberede;
\q2 ọ dịghị onye ajọ omume ga-emegbu ya.
\q1 
\v 23 Aga m etigbu ndị iro ya niile nʼihu ya.
\q2 Aga m emekwa ka ndị niile na-akpọ ya asị laa nʼiyi.
\q1 
\v 24 Ịhụnanya m kwesiri ntụkwasị obi ga-adịnyere ya,
\q2 site nʼaha m, a ga-ebuli mpi ya elu.
\q1 
\v 25 M ga-edo aka ya nʼoke osimiri,\f + \fr 89:25 \ft Ọ ga-achị oke osimiri na osimiri niile\f*
\q2 dokwaa aka nri ya nʼosimiri niile.\f + \fr 89:25 \ft Oke osimiri na osimiri niile a na-ekwu banyere ha nʼebe a, bụ osimiri Mediterenịa na Yufretis, na osimiri ndị ọzọ niile na-asọbanye nʼime ha. Oke ala ochie ahụ e kwere Devid na Solomọn na nkwa jedebere nʼosimiri ndị a.\f*
\q1 
\v 26 Ọ ga-akpọ m sị m, ‘Ị bụ Nna m,
\q2 bụrụkwa Chineke m, na oke Nkume nzọpụta m.’
\q1 
\v 27 Aga m eme ya nwa mbụ m,
\q2 onye kachasị dị elu nʼebe eze niile nke ụwa nọ.
\q1 
\v 28 Aga m eme ka ịhụnanya m nwere nʼebe ọ nọ dịgide ruo ebighị ebi,
\q2 ọgbụgba ndụ mụ na ya ga-adịgidekwa.
\q1 
\v 29 Aga m eme ka agbụrụ ya guzosie ike ruo mgbe ebighị ebi,
\q2 ocheeze ya ga-adịgidekwa dịka eluigwe na-adịgide.
\b
\q1 
\v 30 “Ọ bụrụ na ụmụ ya elefuo iwu m niile anya,
\q2 gharakwa ijegharị nʼụzọ m niile,
\q1 
\v 31 ọ bụrụ na ha elelịa ụkpụrụ m niile anya,
\q2 hapụkwa idebe ihe m nyere ha nʼiwu,
\q1 
\v 32 aga m eji mkpọrọ taa ha ahụhụ maka mmehie ha,
\q2 tikwaa ha ụtarị maka njehie ha;
\q1 
\v 33 ma agaghị m ewezuga ịhụnanya m, nʼebe ha nọ.
\q2 Ma ọ bụ laa azụ nʼikwesị ntụkwasị obi m.
\q1 
\v 34 Agaghị m emerụ ọgbụgba ndụ m.
\q2 Agakwaghị m agbanwe ihe ọbụla siterela nʼọnụ m pụta.
\q1 
\v 35 Ejirila m ịdị nsọ m ṅụọ iyi, kpebie
\q2 na m apụghị ịghara Devid ụgha,
\q1 
\v 36 na agbụrụ ya ga-adịgide ruo mgbe ebighị ebi,
\q2 ocheeze ya ga-adịgidekwa nʼihu m ka anyanwụ na-adịgide.
\q1 
\v 37 Ọ ga-adịgide ruo ebighị ebi dịka ọnwa.
\q2 E, dịka ọnwa ahụ, onye akaebe m kwesiri ntụkwasị obi na mbara eluigwe.” \qs Sela\qs*
\b
\q1 
\v 38 Ma ị jụla, i werela nlelị jụkwa,
\q2 i na-ewe iwe dị ukwu megide onye gị e tere mmanụ.
\q1 
\v 39 Ị jụla ọgbụgba ndụ gị na ohu gị gbara
\q2 i merụọla okpueze ya nʼime ntụ dị nʼala.
\q1 
\v 40 Ị kụtuola mgbidi gbara ya gburugburu,
\q2 i meela ka ebe ya niile e wusiri ike bụrụ ihe dapịara adapịa.
\q1 
\v 41 Ndị niile si ụzọ ahụ na-agafe, ezuruchaala ihe niile o nwere.
\q2 Ndị agbataobi ya na-akwakwa ya emo.
\q1 
\v 42 I meela ka aka nri ndị iro ya dị elu;
\q2 mekwaa ka ndị iro ya ṅụrịa ọṅụ.
\q1 
\v 43 I meela ka aka o ji jide mma agha ya sụọ ngọngọ,
\q2 i nyereghị ya aka mgbe agha dara.
\q1 
\v 44 I meela ka ịma mma ya gwụsịa.
\q2 Ị tụdakwala ocheeze ya nʼala.
\q1 
\v 45 I meela ka ụbọchị ndụ nke okorobịa ya dị mkpụmkpụ.
\q2 I ji ihere dịka akwa kpuchie ya.
\b
\q1 
\v 46 Ruo ole mgbe \nd Onyenwe anyị\nd*, ka ị ga-ezonarị onwe gị?
\q2 Ruo ole mgbe ka iwe gị dị ukwuu ga-eregide dịka ọkụ?
\q1 
\v 47 Cheta, na ndụ m bụ ihe na-agafe ngwangwa.
\q2 Nʼihi ihe efu gịnị ka i ji kee mmadụ niile!
\q1 
\v 48 Olee onye ahụ nwere ike ịdị ndụ ghara ịhụ ọnwụ anya,
\q2 maọbụ zọpụta onwe ya site nʼike nke ili\f + \fr 89:48 \ft Ya bụ, ala mmụọ\f*? \qs Sela\qs*
\q1 
\v 49 O Onyenwe anyị, olee ebe oke ịhụnanya mbụ dị,
\q2 nke i sitere nʼikwesị ntụkwasị obi gị ṅụọrọ Devid nʼiyi?
\q1 
\v 50 Onyenwe m, cheta otu e si leda ndị ohu gị anya,
\q2 otu m si anagide nʼime obi m ịchị ọchị niile nke ndị mba niile.
\q1 
\v 51 O \nd Onyenwe anyị\nd*, ịchị ọchị nke ndị iro gị ji akwa m emo,
\q2 nke ha ji lelịa nzọ ụkwụ niile nke onye gị i tere mmanụ.
\b
\b
\q1 
\v 52 Otuto dịrị \nd Onyenwe anyị\nd* ruo mgbe ebighị ebi.
\qc Amen na Amen.
\c 90
\ms1 Nchịkọta nke anọ
\mr Abụ Ọma 90–106
\cl Abụ Ọma 90
\d Ekpere Mosis, bụ onyeozi Chineke.
\s1 Ebighị ebi Chineke na ịdị mkpụmkpụ nke ndụ mmadụ
\q1 
\v 1 O Onyenwe anyị, ebe obibi ka gị onwe gị bụrịị nye anyị
\q2 nʼọgbọ niile.
\q1 
\v 2 Tupu e kee ugwu niile,\f + \fr 90:2 \ft \xt Job 15:7; Ilu 8:25\xt*\f*
\q2 na tupu a kpụọ ụwa na elu ụwa,
\q2 siterị na mgbe ebighị ebi ruo ebighị ebi, ị bụ Chineke.
\b
\q1 
\v 3 Ị na-eme ka mmadụ laghachi bụrụ aja
\q2 mgbe i kwuru okwu sị, “Unu ụmụ mmadụ, laghachi bụrụ aja.”
\q1 
\v 4 Puku afọ dị nʼanya gị dịka otu ụbọchị;
\q2 ha dịka ụnyaahụ gafere agafe
\q2 maọbụ ka otu awa nke anyasị.\f + \fr 90:4 \ft \xt 2Pt 3:8\xt*\f*
\q1 
\v 5 Nʼime ụra nke ọnwụ ka ị na-ekpochapụ mmadụ;
\q2 ha dịka ahịhịa ọhụrụ nke na-epupụta nʼisi ụtụtụ,
\q1 
\v 6 ọ bụ ezie na ọ na-agbawa ụzarị na-etokwa eto nʼụtụtụ,
\q2 ma nʼanyasị, ọ na-akpọnwụ ma-achanwụkwaa.
\b
\q1 
\v 7 E meela ka anyị gwụsịa nʼihi oke iwe gị megide anyị;
\q2 anyị na-amakwa jijiji nʼihi ọnụma gị.
\q1 
\v 8 Ị gbasaala njehie anyị niile nʼihu gị.
\q2 Ị na-ahụzukwa mmehie nzuzo anyị niile.
\q1 
\v 9 Ogologo ụbọchị anyị niile na-agabiga nʼoke iwe gị;
\q2 afọ ndụ anyị nke fọdụrụ ka anyị na-ebi dịka okwu e ji nwayọọ kwuo na mwute.
\q1 
\v 10 Ogologo ụbọchị anyị niile nwere ike ruo afọ iri asaa,
\q2 maọbụ afọ iri asatọ, ma ọ bụrụ na ike anyị adịgide,
\q1 ma otu ọ dị, nke a ga-asị na ọ bụ ya kachasị mma na-ejupụta na nsogbu na ịsụ ude,
\q2 nʼihi na ha na-agabiga ọsịịsọ, anyị onwe anyị na-efelakwa.
\q1 
\v 11 Onye pụrụ ịghọta ịdị ike nke oke iwe gị?
\q2 Nʼihi na oke iwe gị dị ukwuu dịka ịtụ egwu kwesiri gị si dị ukwuu.
\q1 
\v 12 Kuziere anyị ịgụ ụbọchị niile nke ndụ anyị ọnụ,
\q2 ka anyị si otu a nweta obi amamihe jupụtara.
\b
\q1 
\v 13 O \nd Onyenwe anyị\nd*, nwee ntụgharị obi! Tutu ruo ole mgbe ka ọ ga-adị?
\q2 Meere ndị ohu gị ebere.
\q1 
\v 14 Jiri ịhụnanya gị nke na-adịgide adịgide, mejupụta anyị nʼụtụtụ,
\q2 ka anyị nwee ike ịbụ abụ ọṅụ ma nwekwaa obi ụtọ ogologo ụbọchị ndụ anyị niile.
\q1 
\v 15 Mee ka anyị nwee obi ụtọ, nke ọnụọgụgụ ụbọchị ya ga-adịkwa ka ọnụọgụgụ ụbọchị niile ị tara anyị ahụhụ,
\q2 ka ọnụọgụgụ afọ ya dịkwa ka ọnụọgụgụ afọ niile anyị hụrụla nsogbu.
\q1 
\v 16 Kwere ka ndị ohu gị hụ ọrụ gị dị iche iche,
\q2 ka ụmụ ha hụkwa ịma mma gị.
\b
\q1 
\v 17 Ka ihuọma Chineke, Onyenwe anyị dịkwasị anyị;
\q2 mee ka ọrụ aka anyị guzosie ike,
\q2 e, mee ka ọrụ aka anyị guzosie ike.
\c 91
\cl Abụ Ọma 91
\s1 Chineke onye na-echebe anyị
\q1 
\v 1 Onye ahụ na-ebi nʼebe mgbaba Onye kachasị ihe niile elu
\q2 ga-ezu ike nʼokpuru ndo Onye pụrụ ime ihe niile.
\q1 
\v 2 Nke a ka m ga-ekwu maka \nd Onyenwe anyị\nd*, “Ọ bụ ebe mgbaba m na ebe nchebe m e wusiri ike,
\q2 Chineke m, onye m na-atụkwasị obi m.”
\b
\q1 
\v 3 Nʼezie, ọ ga-anapụta gị
\q2 site nʼọnya nke onye osi ọnya
\q2 na site nʼaka ajọ ọrịa na-efe efe na-eweta ịla nʼiyi.
\q1 
\v 4 Ọ ga-eji nku ya kpuchie gị.
\q2 Ọ bụkwa nʼokpuru nku ya abụọ, ka ị ga-agbaba zere ndụ,
\q2 ikwesi ntụkwasị obi ya ga-echebe gị, ghọkwaara gị ọta.
\q1 
\v 5 Ị gaghị atụ egwu ihe ịtụ oke egwu nke abalị,
\q2 maọbụ àkụ na-efegharị nʼehihie,
\q1 
\v 6 maọbụ ajọ ọrịa na-efe efe, nke na-ejegharị nʼọchịchịrị,
\q2 ma ọ bụkwanụ ihe mbibi mberede na-eme nʼehihie.
\q1 
\v 7 Puku mmadụ pụrụ ịda nʼakụkụ gị,
\q2 iri puku mmadụ nwekwara ike ịda nʼakụkụ aka nri gị,
\q2 ma ihe ọjọọ ndị a agaghị erute gị nso.
\q1 
\v 8 Ọ bụ naanị anya gị abụọ ka ị ga-eji hụ
\q2 ntaramahụhụ nke ndị ajọ omume.
\b
\q1 
\v 9 Ọ bụrụ na i mee Onye kachasị ihe niile elu ebe obibi gị,
\q2 ọ bụladị \nd Onyenwe anyị\nd*, onye bụ ebe mgbaba m,
\q1 
\v 10 mgbe ahụ, ihe ọjọọ ọbụla enweghị ike ịdakwasị gị;
\q2 ihe ike ọbụla enweghị ike ịbịaru ụlọ obibi gị nso.
\q1 
\v 11 Nʼihi na ọ ga-enye ndị mmụọ ozi ya iwu banyere gị,
\q2 ka ha chebe gị nʼụzọ gị niile.\f + \fr 91:11 \ft \xt Abụ 34:7; Mat 4:6; Luk 4:10; Hib 1:14\xt*\f*
\q1 
\v 12 Ha ga-eji ọbụ aka ha,
\q2 bulie gị elu ime ka ị ghara ịkpọbi ụkwụ gị na nkume.
\q1 
\v 13 Ị ga-azọkwasị ọdụm na ajụala ụkwụ,
\q2 zọgbukwaa ọdụm na-akpa ike, na agwọ ọjọọ.
\b
\q1 
\v 14 “Nʼihi na ọ hụrụ m nʼanya, Mụ onwe m ga-agbapụta ya, ka \nd Onyenwe anyị\nd* kwuru;
\q2 aga m echebe ya, nʼihi na ọ maara aha m.
\q1 
\v 15 Ọ ga-akpọku m, aga m azakwa ya.
\q2 Aga m anọnyere ya nʼime nsogbu ya,
\q2 aga m adọpụta, ma sọpụrụkwa ya.\f + \fr 91:15 \ft \xt Job 12:4; Abụ 50:15; Aịz 43:2\xt*\f*
\q1 
\v 16 Aga m eji ogologo ndụ mee ka afọ ju ya,
\q2 gosikwa ya nzọpụta m.”
\c 92
\cl Abụ Ọma 92
\d Abụ Ọma. Abụ maka ụbọchị izuike.
\s1 Ekele maka ịdị mma Chineke
\q1 
\v 1 Ọ bụ ihe ziri ezi ito \nd Onyenwe anyị\nd*,
\q2 na iti egwu nye aha gị, gị Onye kachasị ihe niile elu,
\q1 
\v 2 ikwupụta ịhụnanya gị nʼụtụtụ,
\q2 na ikwesi ntụkwasị obi gị nʼabalị,
\q1 
\v 3 jiri ihe iti egwu ụbọ akwara
\q2 na une bụọrọ gị abụ dị ụtọ.
\b
\q1 
\v 4 Nʼihi na ị na-eme ka obi dị m ụtọ, site nʼọrụ gị niile, o \nd Onyenwe anyị\nd*,
\q2 Ọ bụ ya mere m ji na-abụ abụ ọṅụ.
\q1 
\v 5 Lee ka ọrụ gị si dị ukwuu, \nd Onyenwe anyị\nd*.
\q2 Leekwa ụdị echiche miri emi ị na-eche.
\q1 
\v 6 Ndị uche kọrọ amaghị nke a,
\q2 ndị nzuzu enweghị nghọta,
\q1 
\v 7 ọ bụ ezie na ndị ajọ omume na-etopụta dịka ahịhịa
\q2 ndị na-emekwa ajọ ihe na-eto na-awasa,
\q2 a ga-ala ha nʼiyi ruo mgbe ebighị ebi.
\b
\q1 
\v 8 Ma gị, O \nd Onyenwe anyị\nd*, bụ onye e buliri elu ruo mgbe ebighị ebi.
\b
\q1 
\v 9 Nʼezie, ndị iro gị niile, \nd Onyenwe anyị\nd*,
\q2 e ndị iro gị niile ga-ala nʼiyi;
\q2 ndị niile na-eme ajọ ihe ka a ga-achụsasị.
\q1 
\v 10 I meela ka mpi m dị elu dịka oke ehi na-akpa ike;
\q2 awụsala m mmanụ dị mma.
\q1 
\v 11 Ejirila m anya m abụọ hụ ka e meriri ndị iro m;
\q2 ejirila m ntị m nụ maka ịla nʼiyi nke ndị iro m afọ tara mmiri.
\b
\q1 
\v 12 Ma ndị ezi omume ga-awa igu dịka osisi nkwụ;
\q2 ha ga-ebukwa ibu dịka osisi ukwu sida nke Lebanọn,
\q1 
\v 13 nke a kụrụ nʼime ụlọ \nd Onyenwe anyị\nd*,
\q2 ha ga-eto, wasaakwa nʼime ogige Chineke anyị.
\q1 
\v 14 Ha ga-amị mkpụrụ, ọ bụladị mgbe ha mere agadi.
\q2 Ha ga-ejupụtakwa nʼahịhịa ndụ,
\q1 
\v 15 na-ekwupụta, “\nd Onyenwe anyị\nd* bụ Onye ziri ezi;
\q2 ọ bụ Oke Nkume m, ọ dịkwaghị ajọ omume dị nʼime ya.”
\c 93
\cl Abụ Ọma 93
\s1 Ịdị ukwuu nke Onyenwe anyị
\q1 
\v 1 \nd Onyenwe anyị\nd* bụ eze, ọ na-eyikwasị ịma mma dịka uwe;
\q2 \nd Onyenwe anyị\nd* na-eyikwasị ịma mma dịka uwe, ọ dịkwa ike nke ukwuu;
\q2 nʼezie, ụwa niile na-eguzosikwa ike; apụghịkwa iwezuga ya nʼọnọdụ ya.
\q1 
\v 2 Ocheeze gị eguzosiela ike siterị na mgbe ochie;
\q2 ị na-adịkwa site nʼebighị ebi ruo ebighị.
\b
\q1 
\v 3 Oke osimiri niile amaliela elu, O \nd Onyenwe anyị\nd*;
\q2 oke osimiri niile eweliela olu ha elu;
\q2 ebili mmiri niile nke oke osimiri na-amali elu na-eme mkpọtụ.
\q1 
\v 4 \nd Onyenwe anyị\nd* onye nọ nʼelu, dị ukwuu
\q2 karịa mkpọtụ nke oke osimiri niile na-eme,
\q2 ma karịakwa ụda nke ebili mmiri nke oke osimiri.
\b
\q1 
\v 5 Ụkpụrụ gị niile, \nd Onyenwe anyị\nd* na-eguzosi ike;
\q2 ịdị nsọ bụ ihe e ji chọọ ụlọ gị mma
\q2 ruo ụbọchị na-enweghị ọgwụgwụ.
\c 94
\cl Abụ Ọma 94
\s1 Chineke, onye ikpe nke mmadụ niile
\q1 
\v 1 O \nd Onyenwe anyị\nd*, Chineke onye na-abọ ọbọ,
\q2 o Chineke, onye na-abọ ọbọ, zipụta onwe gị.
\q1 
\v 2 Bilie, o Onye Ikpe nke ụwa;
\q2 kwụghachi ndị nganga ụgwọ ọrụ ruuru ha.
\q1 
\v 3 \nd Onyenwe anyị\nd*, ọ bụ ruo ole mgbe?
\q2 Ọ bụ ruo ole mgbe ka ndị na-eme ajọ omume ga-anọgide na-aṅụrị ọṅụ?
\b
\q1 
\v 4 Ha na-ekwuwapụ okwu mpako;
\q2 ndị niile na-eme ajọ ihe jupụtara nʼitu ọnụ.
\q1 
\v 5 Ha na-azọpịa ndị gị, O \nd Onyenwe anyị\nd*;
\q2 ha na-emegbu ihe nketa gị.
\q1 
\v 6 Ha na-egbu ndị di ha nwụrụ na ndị ọbịa;
\q2 ha na-egbu ndị na-enweghị nna.
\q1 
\v 7 Ha na-asị, “\nd Onyenwe anyị\nd* anaghị ahụ ihe ndị a;
\q2 Chineke Jekọb na-agba nkịtị.”
\b
\q1 
\v 8 Lezienụ anya, unu ndị amamihe kọrọ nʼetiti ndị m;
\q2 unu ndị nzuzu, olee mgbe unu ga-amụta ihe?
\q1 
\v 9 Ọ pụtara na onye kpụrụ ntị anaghị anụ ihe?
\q2 Ọ pụtara na onye kere anya anaghị ahụ ụzọ?
\q1 
\v 10 Ọ pụtara na onye na-adọ mba niile aka na ntị agaghị ata ha ahụhụ?
\q2 Ọ pụtara na onye na-ezi mmadụ ihe enweghị ihe ọmụma?
\q1 
\v 11 \nd Onyenwe anyị\nd* maara echiche obi mmadụ;
\q2 ọ maara na ihe mmadụ na-eche nʼobi ya bụ naanị ihe na-enweghị isi.
\b
\q1 
\v 12 Onye a gọziri agọzi ka mmadụ ahụ bụ, onye ị na-adọ aka na ntị, O \nd Onyenwe anyị\nd*,
\q2 onye ahụ ị na-akụziri ihe site nʼiwu gị;
\q1 
\v 13 ị na-enye ya izuike site nʼụbọchị nsogbu;
\q2 tutu ruo mgbe a ga-egwuru ndị ajọ omume olulu.
\q1 
\v 14 Nʼihi na \nd Onyenwe anyị\nd* agaghị ajụ ndị ya;
\q2 ọ gaghị agbakụta ihe nketa ya azụ.
\q1 
\v 15 Ezi omume ga-abụ ntọala ikpe ikpe niile;
\q2 ndị niile ndị ziri ezi nʼobi ga-agbasokwa ya.
\b
\q1 
\v 16 Onye ga-ebiliri m imegide ndị ajọ omume?
\q2 Onye ga-eguzo nʼọnọdụ m imegide ndị na-eme ajọ ihe?
\q1 
\v 17 A sị na \nd Onyenwe anyị\nd* abịaghị nyere m aka,
\q2 agaara m rịị abụ onye nwụrụ anwụ.
\q1 
\v 18 Mgbe m kwuru sị, “Ụkwụ m na-agbuchapụ,”
\q2 ọ bụ ịhụnanya gị, O \nd Onyenwe anyị\nd*, kwagidere m.
\q1 
\v 19 Mgbe oke nchekasị obi batara nʼime m,
\q2 nkasiobi gị wetara mkpụrụobi m ọṅụ.
\b
\q1 
\v 20 A ga-ejikọta gị na ocheeze ọchịchị ya rụrụ arụ,
\q2 nke na-eweta mmekpa ahụ site nʼiwu ya?
\q1 
\v 21 Ndị ajọ omume na-ejikọta onwe ha imegide ndị ezi omume
\q2 na-amakwa ndị aka ha dị ọcha ikpe ọnwụ.
\q1 
\v 22 Ma \nd Onyenwe anyị\nd* a bụrụla ebe mgbaba e wusiri ike nye m,
\q2 na Chineke m na oke nkume ebe m na-ezere ndụ.
\q1 
\v 23 Ọ ga-akwụghachi ha ụgwọ ọrụ kwesiri mmehie ha,
\q2 lakwaa ha nʼiyi nʼihi ajọ omume ha;
\q2 \nd Onyenwe anyị\nd* Chineke anyị ga-ala ha nʼiyi.
\c 95
\cl Abụ Ọma 95
\s1 Toonu Onyenwe anyị
\q1 
\v 1 Bịanụ ka anyị jiri ọṅụ bụkuo \nd Onyenwe anyị\nd* abụ;
\q2 ka anyị tikuo oke nkume nzọpụta anyị mkpu ọṅụ.
\q1 
\v 2 Ka anyị jiri ekele bịakwute ya
\q2 jirikwa iti egwu na ịbụ abụ jaa ya mma.
\b
\q1 
\v 3 Nʼihi na \nd Onyenwe anyị\nd* bụ Chineke dị ukwuu,
\q2 eze ukwuu kachasị chi niile elu.
\q1 
\v 4 Ebe niile michasịrị emi nke ụwa dị nʼaka ya,
\q2 ebe kachasị elu nke ugwu niile bụkwa nke ya.
\q1 
\v 5 Osimiri niile bụ nke ya, nʼihi na ọ bụ ya kere ha,
\q2 aka ya kpụrụ ala akọrọ niile.
\b
\q1 
\v 6 Bịanụ ka anyị kpọọ isiala nʼofufe,
\q2 ka anyị gbuo ikpere nʼala nʼihu \nd Onyenwe anyị\nd*, onye kere anyị;
\q1 
\v 7 nʼihi na ọ bụ Chineke anyị
\q2 anyị bụkwa ndị ọ na-azụ dịka atụrụ,
\q2 igwe atụrụ ọ na-elekọta anya.
\b
\q1 Taa, ọ bụrụ na unu anụ olu ya,
\q1 
\v 8 “Unu emela ka obi unu sie ike dịka unu mere na Meriba,
\q2 maọbụ dịka unu mere nʼụbọchị ahụ na Masa nʼime ọzara,
\q1 
\v 9 ebe nna nna unu ha nwara m,
\q2 nʼagbanyeghị na ha hụrụ ihe niile m mere.
\q1 
\v 10 Iri afọ anọ ka m were iwe megide ọgbọ ahụ;
\q2 ekwuru m sị, ‘Ndị a bụ ndị obi ha na-akpafu akpafu site nʼebe m nọ,
\q2 ha amatabeghị ụzọ m niile.’
\q1 
\v 11 Nʼihi nke a, aṅụrụ m iyi nʼiwe, sị,
\q2 ‘Ha agaghị abanye nʼizuike m ma ọlị.’ ”
\c 96
\cl Abụ Ọma 96
\s1 Kpọọnụ isiala nye Onyenwe anyị
\q1 
\v 1 Bụkuonụ \nd Onyenwe anyị\nd* abụ ọhụrụ,
\q2 bụkuonụ \nd Onyenwe anyị\nd* abụ, unu ụwa niile.
\q1 
\v 2 Bụkuonụ \nd Onyenwe anyị\nd* abụ, toonu aha ya;
\q2 kwupụtanụ nzọpụta ya site nʼotu ụbọchị ruo nʼụbọchị nke ọzọ.
\q1 
\v 3 Kwusaanụ ebube ya nʼetiti mba niile,
\q2 kọsakwanụ banyere oke ọrụ ya niile nʼetiti ndị niile dị iche iche.
\b
\q1 
\v 4 Nʼihi na \nd Onyenwe anyị\nd* dị ukwuu, bụrụkwa onye kwesiri ịnata otuto;
\q2 onye a na-atụ egwu karịa chi ọzọ niile ka ọ bụkwa.
\q1 
\v 5 Nʼihi na chi niile nke mba niile dị iche iche bụ arụsị efu,
\q2 maọbụ \nd Onyenwe anyị\nd* kere eluigwe niile.
\q1 
\v 6 Ịma mma na ebube dị nʼihu ya;
\q2 ike na otuto dị nʼebe nsọ ya.
\b
\q1 
\v 7 Nyenụ \nd Onyenwe anyị\nd*, unu ezinaụlọ nke mba niile dị iche iche,
\q2 nyenụ \nd Onyenwe anyị\nd* nsọpụrụ na ike.
\q1 
\v 8 Nyenụ \nd Onyenwe anyị\nd* nsọpụrụ ruuru aha ya;
\q2 werenụ onyinye bata nʼime ogige ya.
\q1 
\v 9 Kpọọnụ isiala nye \nd Onyenwe anyị\nd* nʼịma mma nke ịdị nsọ ya;
\q2 maa jijiji nʼihu ya, unu ụwa niile.
\q1 
\v 10 Kwusaa nʼetiti mba niile sị, “\nd Onyenwe anyị\nd* na-achị.”
\q2 Elu ụwa kwụ chịm, a pụghị iwezuga ya nʼọnọdụ ya;
\q2 ọ ga-eji ikpe ziri ezi kpee ndị niile ikpe.
\b
\q1 
\v 11 Ka mbara eluigwe ṅụrịa, ka ụwa nwekwa obi ụtọ;
\q2 ka osimiri bigbọọ, na ihe niile dị nʼime ya.
\q1 
\v 12 Ka ala ubi niile na ihe niile dị nʼime ha jupụta nʼobi ụtọ.
\q2 Ka osisi niile nke oke ọhịa bụọ abụ nʼihi ọṅụ.
\q1 
\v 13 Ka ihe niile e kere eke ṅụrịa ọṅụ nʼihu \nd Onyenwe anyị\nd*, nʼihi na ọ na-abịa,
\q2 ọ na-abịa ikpe ụwa ikpe.
\q1 Ọ ga-eji ezi omume kpee elu ụwa ikpe,
\q2 jirikwa ikwesi ntụkwasị obi kpee ndị niile dị iche iche ikpe.
\c 97
\cl Abụ Ọma 97
\s1 Chineke onye na-achị ihe niile
\q1 
\v 1 \nd Onyenwe anyị\nd* bụ eze,\f + \fr 97:1 \ft \xt Abụ 96:10; Abụ 99:1\xt*\f* ka ụwa niile nwee obi ụtọ;
\q2 ka ndị niile bi nʼebe dị anya ṅụrịa.
\q1 
\v 2 Igwe ojii na oke ọchịchịrị gbara ya gburugburu;
\q2 ezi omume na ikpe ziri ezi bụ ntọala ocheeze ya.
\q1 
\v 3 Ọkụ na-enwu enwu na-aga nʼihu ya
\q2 ọ na-erepịasị ndị iro ya nʼakụkụ ya ọbụla.
\q1 
\v 4 Amụma ya na-acha chazuo elu ụwa niile;
\q2 ụwa niile na-ahụ ya na-ama jijiji.
\q1 
\v 5 Ugwu niile na-agbaze dịka mmanụ nʼihu \nd Onyenwe anyị\nd*,
\q2 nʼihu Onyenwe ụwa niile.
\q1 
\v 6 Eluigwe na-ekwuwapụta ezi omume ya;
\q2 ndị niile bi nʼụwa na-ahụkwa ebube ya.
\b
\q1 
\v 7 A na-eme ka ihere mee ndị niile na-efe arụsị niile a pịrị apị ofufe,
\q2 ndị na-anya isi na chi niile e jiri aka mee
\q2 feenụ ya ofufe, unu chi niile!
\b
\q1 
\v 8 Zayọn na-anụ ma na-aṅụrịkwa ọṅụ,
\q2 obodo nta niile nke Juda na-enwekwa obi ụtọ
\q2 nʼihi ikpe gị, O \nd Onyenwe anyị\nd*.
\q1 
\v 9 Nʼihi na gị, O \nd Onyenwe anyị\nd*, bụ Onye kachasị ihe niile elu nʼụwa niile;
\q2 ị bụ onye e buliri elu karịa chi ndị ọzọ niile.
\q1 
\v 10 Ka unu, ndị hụrụ \nd Onyenwe anyị\nd* nʼanya, kpọọ ihe ọjọọ asị,
\q2 nʼihi na ọ na-echebe ndụ ndị nke ya, ndị tụkwasịrị ya obi
\q2 ma na-anapụtakwa ha site nʼaka ndị ajọ omume.
\q1 
\v 11 Ìhè na-amụkwasị onye ezi omume,
\q2 ọṅụ na-adịkwa nʼime obi onye na-eme ihe ziri ezi.
\q1 
\v 12 Ṅụrịanụ ọṅụ nʼime \nd Onyenwe anyị\nd*, unu ndị ezi omume,
\q2 tookwanụ aha nsọ ya.
\c 98
\cl Abụ Ọma 98
\d Abụ Ọma.
\s1 Toonu Onyenwe anyị onye ezi omume
\q1 
\v 1 Bụkuonụ \nd Onyenwe anyị\nd* abụ ọhụrụ,\f + \fr 98:1 \ft \xt Abụ 96:1\xt*\f*
\q2 nʼihi na ọ rụọla ọtụtụ ọrụ dị ebube;
\q1 aka nri ya na aka nsọ ya
\q2 arụpụtarala ya nzọpụta.
\q1 
\v 2 \nd Onyenwe anyị\nd* emeela ka a mata nzọpụta ya
\q2 o kpugheela ezi omume ya nye mba niile.
\q1 
\v 3 O chetala ịhụnanya ya
\q2 na ikwesi ntụkwasị obi ya nʼebe ụlọ Izrel dị;
\q1 nsọtụ nke ụwa niile ahụla
\q2 nzọpụta Chineke anyị.
\b
\q1 
\v 4 Tikusienụ \nd Onyenwe anyị\nd* mkpu ọṅụ ike, ụwa niile
\q2 jirinụ iti egwu tiwaa mkpu abụ ọṅụ;
\q1 
\v 5 werenụ ụbọ akwara bụkuo \nd Onyenwe anyị\nd* abụ,
\q2 e, were ụbọ akwara na olu abụ ọma,
\q1 
\v 6 jirinụ opi na opi ike,
\q2 tisie mkpu ọṅụ ike nʼihu \nd Onyenwe anyị\nd*, Onye bụ Eze.
\b
\q1 
\v 7 Ka oke osimiri niile gbọọ ụja, ya na ihe niile dị nʼime ya,
\q2 ụwa na ndị niile bi nʼime ya.
\q1 
\v 8 Ka osimiri na iyi niile kụọ aka ha,
\q2 ka ugwu niile bụkuokwa ya abụ nʼihi ọṅụ;
\q1 
\v 9 ka ha bụọ abụ nʼihu \nd Onyenwe anyị\nd*,
\q2 nʼihi na ọ na-abịa ikpe ụwa ikpe.
\q1 Ọ ga-eji ezi omume kpee ụwa ikpe.
\q2 Ọ ga-eji ikpe ziri ezi kpee ndị niile ikpe.
\c 99
\cl Abụ Ọma 99
\s1 Toonu Chineke dị nsọ
\q1 
\v 1 \nd Onyenwe anyị\nd* bụ eze,
\q2 ka mba niile maa jijiji!
\q1 O wuru ocheeze ya nʼetiti cherubim,
\q2 ka elu ụwa maa jijiji.
\q1 
\v 2 \nd Onyenwe anyị\nd* dị ukwuu nʼime Zayọn;
\q2 ọ bụ onye e buliri elu karịa mba niile dị iche iche.
\q1 
\v 3 Ka ha too aha gị nke dị ukwuu, dịkwa oke egwu,
\q2 ọ dị nsọ.
\b
\q1 
\v 4 Eze bụ onye dị ike, ọ hụrụ ikpe ziri ezi nʼanya,
\q2 i meela ka ihe ziri ezi guzosie ike;
\q1 nʼime Jekọb ka i mere
\q2 ihe ziri ezi na ihe dị mma.
\q1 
\v 5 Bulienụ \nd Onyenwe anyị\nd* Chineke anyị elu,
\q2 feenụ ofufe nʼihu ebe ihe ịtụkwasị ụkwụ ya;
\q2 ọ dị nsọ.
\b
\q1 
\v 6 Mosis na Erọn so nʼetiti ndị nchụaja ya,
\q2 Samuel sokwa nʼetiti ndị kpọkuru aha ya;
\q1 ha kpọkuru \nd Onyenwe anyị\nd*
\q2 ọ zakwara ha.
\q1 
\v 7 Ọ gwara ha okwu site nʼogidi igwe ojii.
\q2 Ha debere ụkpụrụ ya na iwu niile o nyere ha.
\b
\q1 
\v 8 O \nd Onyenwe anyị\nd*, Chineke anyị,
\q2 ị zara ha;
\q1 ị bụụrụ Izrel Chineke onye na-agbaghara mmehie,
\q2 nʼagbanyeghị na ị tara ha ahụhụ nʼihi mmehie ha.
\q1 
\v 9 Bulienụ \nd Onyenwe anyị\nd* Chineke anyị elu;
\q2 na-efe ya ofufe nʼelu ugwu ya dị nsọ,
\q2 nʼihi na onye dị nsọ ka \nd Onyenwe anyị\nd* Chineke anyị bụ.
\c 100
\cl Abụ Ọma 100
\d Abụ Ọma maka ikele ekele afọ ojuju.
\s1 Toonu Chineke
\q1 
\v 1 Tikusienụ \nd Onyenwe anyị\nd* mkpu ọṅụ ike, ụwa niile.
\q2 
\v 2 Jiri obi ụtọ fee \nd Onyenwe anyị\nd* ofufe;
\q2 jirinụ ịbụ abụ ọṅụ bịa nʼihu ya
\q1 
\v 3 Matanụ na \nd Onyenwe anyị\nd* bụ Chineke.
\q2 Ọ bụ ya onwe ya kere anyị,\f + \fr 100:3 \ft \xt Job 10:3; Efe 2:10\xt*\f* ọ bụkwa ya nwe anyị,
\q2 anyị bụ ndị ya, igwe atụrụ nke ọ na-azụ.
\b
\q1 
\v 4 Jirinụ ekele banye nʼọnụ ụzọ ama ya
\q2 jiri otuto baa nʼogige ya;
\q2 keleenụ ya, tookwa aha ya.
\q1 
\v 5 Nʼihi na \nd Onyenwe anyị\nd* dị mma, ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q2 Ruo ọgbọ niile ka ikwesi ntụkwasị obi ya na-adịgidekwa.
\c 101
\cl Abụ Ọma 101
\d Abụ Ọma Devid.
\s1 Nkwa eze
\q1 
\v 1 Aga m abụ abụ banyere ịhụnanya gị na ikpe gị ziri ezi;
\q2 o \nd Onyenwe anyị\nd*, ọ bụ gị ka m ga-abụku abụ otuto.
\q1 
\v 2 Aga m enwe uche ị hụ na m biri ndụ na-enweghị ịta ụta ọbụla,
\q2 olee mgbe ị ga-abịakwute m?
\b
\q1 Aga m ejikwa obi nke a na-agaghị ata ụta ọbụla
\q2 jegharịa nʼime ụlọ m.
\q1 
\v 3 Agaghị m edo ihe jọgburu onwe ya
\q2 nʼihu m.
\b
\q1 Ana m akpọ ọrụ ndị na-ekwesighị ntụkwasị obi asị.
\q2 Agaghị m enwekwa oke nʼime ya.
\q1 
\v 4 Ndị obi ha gbagọrọ agbagọ agaghị anọ m nso.
\q2 Agakwaghị m etinye aka nʼọrụ ọjọọ ọbụla.
\b
\q1 
\v 5 Onye ọbụla na-ekwulu onye agbataobi ya na nzuzo,
\q2 onye ahụ ka m ga-emechi ọnụ;
\q1 agaghị m anabata
\q2 onye ọbụla dị mpako ma nwee obi nganga.
\b
\q1 
\v 6 Aga m elekwasị ndị kwesiri ntụkwasị obi nʼala a anya,
\q2 ka mụ na ha biri;
\q1 onye ahụ na-eje ije na-enweghị ịta ụta ọbụla
\q2 ga-ejere m ozi.
\b
\q1 
\v 7 Onye ọbụla na-aghọ aghụghọ
\q2 agaghị ebi nʼụlọ m;
\q1 onye ọbụla na-ekwu okwu ụgha
\q2 agaghị eguzokwa nʼihu m.
\b
\q1 
\v 8 Ụtụtụ niile ka m na-eme ka ha dere duu
\q2 bụ ndị ajọ omume niile nọ nʼala a;
\q1 Aga m ebipụ ndị niile na-eme ajọ ihe
\q2 site nʼobodo \nd Onyenwe anyị\nd*.
\c 102
\cl Abụ Ọma 102
\d Ekpere nke onye nọ na mmekpa ahụ na ọnọdụ ịda mba, na-ekwupụta otu o si dịrị ya nʼihu \nd Onyenwe anyị\nd*.
\s1 Arịrịọ maka ime ebere
\q1 
\v 1 Nụrụ ekpere m, O \nd Onyenwe anyị\nd*;
\q2 ka ịkwa akwa m maka inyeaka ruo gị ntị.
\q1 
\v 2 Ezonarịla m ihu gị
\q2 nʼụbọchị nsogbu m.
\q1 Gee ntị nʼekpere m,
\q2 zakwaa m ngwangwa.
\b
\q1 
\v 3 Nʼihi na ụbọchị m niile na-agabiga, dịka anwụrụ ọkụ;
\q2 ọkpụkpụ m niile dịkwa ka ọlọkọ ọkụ.
\q1 
\v 4 Mkpụrụobi m etiwaala abụọ na-achanwụkwa dịka ahịhịa;
\q2 ana m echefu iri nri m.
\q1 
\v 5 Nʼihi oke ịsụ ude m na-asụ,
\q2 enwekwaghị m anụ ahụ ọbụla nʼahụ m. Abụ m naanị ọkpụkpụ.
\q1 
\v 6 Adị m ka ikwighịkwighị nke ọzara,
\q2 a dị m ka ikwighịkwighị nʼetiti ebe dakpọsịrị adakpọsị.
\q1 
\v 7 Ana m amụ anya abalị niile;
\q2 adị m ka nwa nnụnụ naanị ya bekwasịrị nʼelu ụlọ.
\q1 
\v 8 Ụbọchị niile, ndị iro m na-eji m eme ihe ọchị;
\q2 ndị na-akwa m emo na-eji aha m mere ihe ịbụ ọnụ.
\q1 
\v 9 Nʼihi na ejirila m ntụ mere ihe oriri m,
\q2 anya mmiri m na-agwakọta nʼiko ihe ọṅụṅụ m
\q1 
\v 10 nʼihi oke iwe gị,
\q2 i bulitela m, ma tụpụ m nʼakụkụ.
\q1 
\v 11 Ụbọchị m niile dịka onyinyo nke a na-ahụ anya mgbe anwụ na-ada.
\q2 Ana m akpọnwụ akpọnwụ, dịka ahịhịa.
\b
\q1 
\v 12 Ma gị \nd Onyenwe anyị\nd*, na-anọgide nʼocheeze gị ruo mgbe ebighị ebi;
\q2 aha gị ga-adịgide site nʼọgbọ ruo nʼọgbọ.
\q1 
\v 13 Ị ga-ebili nwee ọmịiko nʼebe Zayọn nọ,
\q2 nʼihi na oge izi ya ihuọma eruola;
\q2 oge ahụ a kara aka eruola.
\q1 
\v 14 Nʼihi na nkume ya niile dị oke ọnụahịa nye ndị ohu gị;
\q2 mgbe ha hụrụ uzuzu ya, ha na-emere ya ebere.
\q1 
\v 15 Mba niile ga-atụ egwu aha \nd Onyenwe anyị\nd*,
\q2 ndị eze niile nke ụwa ga-asọpụrụkwa ebube gị.
\q1 
\v 16 Nʼihi na \nd Onyenwe anyị\nd* ga-ewugharị Zayọn,
\q2 ọ ga-apụta ihe nʼebube ya.
\q1 
\v 17 Ọ ga-aza ekpere ndị nọ na mkpa;
\q2 ọ gaghị eleda arịrịọ ha anya.
\b
\q1 
\v 18 Ka e depụta ihe ndị a maka ọgbọ nke dị nʼihu,
\q2 ka ndị a na-amụbeghị nwee ike too \nd Onyenwe anyị\nd*:
\q1 
\v 19 “\nd Onyenwe anyị\nd* sitere nʼebe nsọ ya dị elu ledata anya,
\q2 o sitere nʼeluigwe ledata anya ya nʼụwa,
\q1 
\v 20 ịnụ ịsụ ude nke ndị a tụrụ mkpọrọ
\q2 na ịgbapụta ndị a mara ikpe ọnwụ.”
\q1 
\v 21 Nʼihi nke a, a ga-ekwuwapụta aha \nd Onyenwe anyị\nd* na Zayọn;
\q2 a ga-eto ya na Jerusalem,
\q1 
\v 22 mgbe mba niile na alaeze niile,
\q2 ga-ezukọta nʼotu ebe, ife Onyenwe anyị ofufe.
\b
\q1 
\v 23 O meela ka ike gwụ m nʼoge ndụ m;
\q2 o meela ka ndụ m dịrị mkpụmkpụ.
\q1 
\v 24 Nʼihi ya, ekwuru m sị,
\q1 “Anapụla m ndụ m, o Chineke m, ugbu a m ka dị ndụ;
\q2 ị na-adịgide ndụ site nʼọgbọ ruo nʼọgbọ.
\q1 
\v 25 Na mmalite, ị tọrọ ntọala ụwa,
\q2 eluigwe bụkwa ọrụ aka gị.
\q1 
\v 26 Ha ga-ala nʼiyi, ma ị ga-adịgide;
\q2 ha ga-erichasị dịka akwa ochie.
\q1 Ị ga-agbanwe ha dịka mmadụ si agbanwe uwe ya,
\q2 ha ga-abụ ndị ewezugara ewezuga.
\q1 
\v 27 Ma gị onwe gị enweghị mgbanwe,\f + \fr 102:27 \ft \xt Aịz 41:1; Aịz 43:10; Mal 3:6; Hib 13:8; Jem 1:17\xt*\f*
\q2 ọnụọgụgụ afọ gị adịghị agwụkwa agwụ.
\q1 
\v 28 Ụmụ ndị ohu gị ga-ebigide;
\q2 ụmụ ụmụ ha ga-eguzosie ike nʼihu gị.”
\c 103
\cl Abụ Ọma 103
\d Abụ Ọma Devid.
\s1 Gọzie Onyenwe anyị
\q1 
\v 1 Mkpụrụobi m, too \nd Onyenwe anyị\nd*;
\q2 ka ihe niile dị nʼime m too aha nsọ ya.
\q1 
\v 2 Mkpụrụobi m, too \nd Onyenwe anyị\nd*;
\q2 echefukwala mmeso ọma ya niile,
\q1 
\v 3 ọ bụ ya na-agbaghara gị mmehie gị niile;
\q2 na-agwọkwa gị ọrịa gị niile,
\q1 
\v 4 onye na-agbapụta ndụ gị site nʼolulu
\q2 werekwa ịhụnanya na ọmịiko kpukwasị gị dịka okpueze,
\q1 
\v 5 onye na-eji ezi ihe na-emejupụta ọchịchọ gị niile,
\q2 ka oge okorobịa gị bụrụ ihe a gbanwere dịka nke ugo.\f + \fr 103:5 \fk Ugo \ft Ọ bụ ịdị ike na ndụ ogologo ka e ji mara nnụnụ ugo.\f*
\b
\q1 
\v 6 \nd Onyenwe anyị\nd* na-arụ ọrụ ezi omume,
\q2 na-ekpe ikpe ziri ezi nye ndị a na-emegbu emegbu.
\b
\q1 
\v 7 O mere ka Mosis mata ụzọ ya,
\q2 mekwaa ka ụmụ Izrel mara ọrụ ya dị iche iche:
\q1 
\v 8 \nd Onyenwe anyị\nd* nwere obi ọmịiko na-emekwa amara.
\q2 Ọ dịghị ewe iwe ọsịịsọ, o jupụtara nʼịhụnanya.
\q1 
\v 9 Iwe ya anaghị adịgide ruo mgbe ebighị ebi,
\q2 ọ bụghị oge niile ka ọ na-anọgide na-ata mmadụ ụta;
\q1 
\v 10 ọ bụghị dịka mmehie anyị si dị ka ọ na-emeso anyị,
\q2 ọ dịghị akwụghachi anyị dịka ajọ omume anyị si dị.
\q1 
\v 11 Nʼihi na dịka eluigwe si dị elu karịa ụwa,
\q2 otu a ka ịhụnanya ya si dị ukwuu nʼebe ndị na-atụ egwu ya nọ.
\q1 
\v 12 Dịka ọwụwa anyanwụ si dị anya, site nʼọdịda anyanwụ,
\q2 otu a ka o sirila mee ka mmehie anyị niile dịrị anya site nʼebe anyị nọ.
\b
\q1 
\v 13 Dịka nna si enwe obi ebere nʼebe ụmụ ya nọ,
\q2 otu a ka \nd Onyenwe anyị\nd* si enwe obi ebere nʼebe ndị na-atụ egwu ya nọ,
\q1 
\v 14 nʼihi na ya onwe ya maara otu e si kpụọ anyị,
\q2 ọ na-echeta na anyị bụ aja.
\q1 
\v 15 Ebe mmadụ nọ, ụbọchị ya niile dị ka ahịhịa,
\q2 ọ na-etopụta, na-awasa dịka okoko osisi ọhịa,
\q1 
\v 16 ifufe na-efesi ya ike, ọ na-adakwa,
\q2 adịghị echetakwa ya nʼọnọdụ mbụ ya.
\q1 
\v 17 Ma ịhụnanya \nd Onyenwe anyị\nd* na-adịgide site
\q2 nʼebighị ebi ruo ebighị ebi nʼetiti ndị na-atụ egwu ya.
\q2 Ezi omume ya na-adịgidekwara ụmụ ụmụ ha,
\q1 
\v 18 nye ndị ahụ niile na-edebe ọgbụgba ndụ ya
\q2 na ndị na-echeta irubere ụkpụrụ ya isi.
\b
\q1 
\v 19 \nd Onyenwe anyị\nd* emeela ka ocheeze ya guzosie ike nʼeluigwe,
\q2 alaeze ya na-achị ihe niile.
\b
\q1 
\v 20 Toonu \nd Onyenwe anyị\nd*, unu ndị mmụọ ozi ya,
\q2 unu ndị dị ike ndị na-eme ihe ọ chọrọ,
\q2 na-erubere okwu ya isi.
\q1 
\v 21 Toonu \nd Onyenwe anyị\nd* unu usuu ndị agha ya niile;
\q2 unu ndị na-ejere ya ozi, ndị na-eme uche ya.
\q1 
\v 22 Toonu \nd Onyenwe anyị\nd*, ọrụ aka ya niile
\q2 nʼebe ọbụla ọ na-achị.
\b
\q1 Mkpụrụobi m, too \nd Onyenwe anyị\nd*.
\c 104
\cl Abụ Ọma 104
\s1 Toonu Chineke onye okike
\q1 
\v 1 Mkpụrụobi m, too \nd Onyenwe anyị\nd*.
\b
\q1 O \nd Onyenwe anyị\nd* na Chineke m, ị dị ukwu nke ukwuu;
\q2 ị na-eyikwasị ịma mma na ebube dịka uwe.
\b
\q1 
\v 2 Ọ na-eji ìhè kpuchie onwe ya dịka akwa;
\q2 ọ na-agbasa eluigwe dịka ụlọ ikwu
\q2 
\v 3 na-atọ ntọala ụlọ elu ya nʼelu mmiri.\f + \fr 104:3 \ft \xt Ems 9:6\xt*\f*
\q1 Ọ na-eji igwe ojii emere onwe ya ụgbọ agha
\q2 na-ejirikwa nku nke ifufe felie elu.
\q1 
\v 4 O ji oke ifufe mere ihe na-ejere ya ozi,
\q2 meekwa ka ọkụ na-enwu enwu bụrụ ndị na-ejere ya ozi.
\b
\q1 
\v 5 Ọ bụ ya tọrọ ntọala ụwa;
\q2 agaghị ewezugakwa ya site nʼọnọdụ ya.
\q1 
\v 6 I gbokwasịrị ogbu mmiri nʼelu ya dịka ọ bụ uwe ka i yikwasịrị ya,
\q2 mmiri tokpukwara ugwu niile.
\q1 
\v 7 Ma mgbe ị bara mba, mmiri ahụ gbapụrụ,
\q2 nʼụda oke olu nke egbe eluigwe gị, ha gbapụrụ ọsọ.
\q1 
\v 8 Ha sitere nʼelu ugwu niile,
\q2 sọrọ gaa na ndagwurugwu,
\q2 ruokwa nʼebe ahụ ị kpara oke na ha ga-anọ.
\q1 
\v 9 Ị kpara oke nye ha, nke ha na-agaghị agafe,
\q2 gbochie ha ikpuchi elu ụwa ọzọ.
\b
\q1 
\v 10 Ọ na-eme ka mmiri, site nʼala na-asọpụta na ndagwurugwu,
\q2 meekwa ka iyi niile site nʼetiti ugwu na-asọfe.
\q1 
\v 11 Ha na-enye anụ ọhịa niile mmiri ọṅụṅụ
\q2 bụrụkwa ebe akpịrị ịkpọ nkụ nke ịnyịnya ibu ọhịa na-adajụ.
\q1 
\v 12 Nʼosisi dị nʼakụkụ ha ka ụmụ anụ ufe nke eluigwe ga-anọ wuo akwụ ha;
\q2 nọrọkwa nʼalaka ha bụọ abụ.
\q1 
\v 13 Ọ na-esite nʼeluigwe na-ezidata mmiri ozuzo nʼelu ugwu niile;
\q2 ụwa niile na-ejupụtakwa na mkpụrụ nke ọrụ aka ya.
\q1 
\v 14 Ọ na-eme ka ahịhịa puputara anụ ụlọ,
\q2 na-emekwa ka ihe a kụrụ nʼala puoro mmadụ nʼubi ya,
\q2 ime ka nri site nʼala pupụta;
\q1 
\v 15 mmanya nke na-enye obi mmadụ aṅụrị,
\q2 mmanụ nke na-eme ka ihu na-egbupụ amụma,
\q2 na achịcha nke na-enye ya ume nʼobi.
\q1 
\v 16 A na-agba osisi niile nke \nd Onyenwe anyị\nd* mmiri nke ọma,
\q2 osisi sida nke Lebanọn nke ọ kụrụ.
\q1 
\v 17 Ụmụ nnụnụ na-ewu akwụ ha;
\q2 nʼosisi fịa ka ụgbala na-ewu akwụ ya.
\q1 
\v 18 Ugwu niile dị elu dịịrị ewu ọhịa;
\q2 nʼọgba dị na nkume ka ewi nkume na-ezo onwe ha.
\b
\q1 
\v 19 I mere ọnwa ka ọ bụrụ ihe a ga-eji na-agụ oge na mgbe dị iche iche;
\q2 anyanwụ makwaara mgbe ọ ga-eji daa.
\q1 
\v 20 Ị na-eme ka ọchịchịrị bịa, ọ bụrụ abalị;
\q2 ụmụ anụ ọhịa niile nke oke ọhịa na-akpagharị.
\q1 
\v 21 Ụmụ ọdụm na-agbọ ụja ha na-elegharị anya anụ ha ga-adọgbu,
\q2 ịchọrọ onwe ha ihe oriri ahụ Chineke na-enye ha.
\q1 
\v 22 Nʼisi ụtụtụ mgbe anwụ wara,
\q2 ha na-alaghachi zoo onwe ha nʼebe nzuzo ha.
\q1 
\v 23 Ụmụ mmadụ na-amalitekwa ọrụ ha nʼisi ụtụtụ,
\q2 kwụsịkwa nʼanyasị mgbe ọchịchịrị bidoro ịgba.
\b
\q1 
\v 24 \nd Onyenwe anyị\nd*, ọrụ aka gị dị ọtụtụ.
\q2 Ọ bụ site nʼamamihe ka i ji kee ha.
\q2 Elu ụwa niile jupụtara nʼihe niile i kere eke.
\q1 
\v 25 Leenụ osimiri nke buru ibu saakwa mbara;
\q2 jupụtara nʼihe e kere eke na-akpụ akpụ nke a na-apụghị ịgụta ọnụ bi,
\q2 anụ dị ndụ ma ndị ukwu ma ndị nta.
\q1 
\v 26 Nʼebe ahụ ka ụgbọ mmiri niile na-ejegharị,
\q2 nʼime ya kwa ka leviatan, nke gị onwe gị kere, na-anọ egwuri egwu.
\b
\q1 
\v 27 Ha niile na-adabere na gị,
\q2 ka i nye ha nri nʼotu nʼotu, mgbe oge iri nri ha ruru.
\q1 
\v 28 Ị na-enye ha nri;
\q2 ha na-erikwa ya.
\q1 Mgbe i meghere ọbụ aka gị nye ha nri,
\q2 afọ na-eju ha nke ọma.
\q1 
\v 29 Mgbe i zonarịrị ha ihu gị,
\q2 egwu na-eju ha obi.
\q1 Mgbe ị napụkwara ha ume ndụ i nyere ha,
\q2 ha na-ekubi ume, nwụọ, laghachikwa nʼaja ebe ha siri pụta.
\q1 
\v 30 Mgbe i zipụrụ mmụọ gị,
\q2 a na-eke ha;
\q2 ị na-agbanwekwa ihu elu ụwa.
\b
\q1 
\v 31 Ka ebube \nd Onyenwe anyị\nd* dịgide site nʼebighị ebi ruo nʼebighị ebi;
\q2 ka ọrụ aka \nd Onyenwe anyị\nd* niile wetara ya ọṅụ,
\q1 
\v 32 onye na-ele ụwa anya, ụwa amaa jijiji,
\q2 onye na-emetụ ugwu niile aka, ha na-akwụ anwụrụ ọkụ.
\b
\q1 
\v 33 Aga m abụku \nd Onyenwe anyị\nd* abụ ogologo ụbọchị niile nke ndụ m;
\q2 aga m abụku Chineke m abụ otuto oge niile m na-adị ndụ.
\q1 
\v 34 Ka ntụgharị uche m niile bụrụ ihe na-atọ ya ụtọ,
\q2 dịka m na-aṅụrị ọṅụ nʼime \nd Onyenwe anyị\nd*.
\q1 
\v 35 Ka e kpochapụ ndị mmehie niile site nʼụwa.
\q2 Ka ndị niile na-emebi iwu gharakwa ịdị ọzọ.
\b
\q1 Too \nd Onyenwe anyị\nd* gị mkpụrụobi m!
\b
\q1 Toonu \nd Onyenwe anyị\nd*!
\c 105
\cl Abụ Ọma 105
\s1 Toonu Chineke onye na-edebe ọgbụgba ndụ
\q1 
\v 1 Nyenụ \nd Onyenwe anyị\nd* otuto, kwupụtakwa aha ya.
\q2 Meenụ ka amata nʼetiti mba niile banyere ihe niile ọ rụrụ.
\q1 
\v 2 Bụkuo ya abụ, bụkuo ya abụ otuto;
\q2 kwupụtanụ ọrụ ihe ịrịbama ya niile.
\q1 
\v 3 Ṅụrianụ nʼime aha nsọ ya;
\q2 ka obi ndị niile na-achọ \nd Onyenwe anyị\nd* ṅụrịa.
\q1 
\v 4 Na-achọnụ \nd Onyenwe anyị\nd* na ike ya,
\q2 chọọnụ ihu ya mgbe niile.
\b
\q1 
\v 5 Chetanụ ọrụ ebube niile nke ọ rụrụ,
\q2 ihe ịrịbama ya niile na ikpe ziri ezi niile si nʼọnụ ya pụta,
\q1 
\v 6 unu ụmụ ụmụ Ebraham, bụ ohu ya,
\q2 unu ụmụ ụmụ Jekọb, ndị ọ họpụtara.
\q1 
\v 7 Ya onwe ya bụ \nd Onyenwe anyị\nd* Chineke anyị;
\q2 ikpe ya dị nʼụwa niile.
\b
\q1 
\v 8 Ọ na-echeta ọgbụgba ndụ ya ruo mgbe ebighị ebi,
\q2 bụ nkwa o kwere nye puku ọgbọ,
\q1 
\v 9 ọgbụgba ndụ ahụ nke ya na Ebraham gbara
\q2 na iyi ọ ṅụrụ nye Aịzik.
\q1 
\v 10 O mere ka o guzoro nye Jekọb dịka ụkpụrụ,
\q2 ma nʼebe Izrel nọ, dịka ọgbụgba ndụ ebighị ebi:
\q1 
\v 11 “Aga m enye gị ala Kenan
\q2 dịka oke i ga-eketa.”
\b
\q1 
\v 12 Mgbe ha dị ole na ole nʼọnụọgụgụ,
\q2 nʼezie ha dị ole na ole, bụrụkwa ọbịa nʼime ya.
\q1 
\v 13 Ha wagharịrị site nʼotu mba gaa na mba ọzọ,
\q2 sitekwa nʼotu alaeze gaa alaeze ọzọ.
\q1 
\v 14 O kweghị ka onye ọbụla mekpaa ha ahụ;
\q2 ọ baara ndị eze mba nʼihi ha;
\q1 
\v 15 sị, “Unu emetụkwala ndị m e tere mmanụ aka;
\q2 unu emekpakwala ndị amụma m ahụ.”
\b
\q1 
\v 16 O zitere ụnwụ nʼala ahụ,
\q2 bibie ụzọ niile ha si enweta ihe oriri;
\q1 
\v 17 o zipụrụ otu nwoke ka ọ gaa nʼihu ha,
\q2 Josef, onye e refuru dịka ohu.
\q1 
\v 18 Ha ji mkpọrọ igwe merụọ ya ahụ nʼụkwụ,
\q2 nyanyekwa ya mkpọrọ igwe nʼolu,
\q1 
\v 19 tutu ruo mgbe ihe ahụ o kwuru na ọ ga-eme mezuru,
\q2 tutu ruo mgbe okwu \nd Onyenwe anyị\nd* nwapụtara ya dịka onye eziokwu.
\q1 
\v 20 Eze ahụ zipụrụ ozi ka a tọpụ ya,
\q2 onye ahụ na-achị ndị dị iche iche mere ka o nwere onwe ya.
\q1 
\v 21 O mere ya ka ọ bụrụ onyenwe ezinaụlọ ya,
\q2 onye na-achị ihe niile o nwere,
\q1 
\v 22 ikuziri ụmụ eze ndị ikom dịka o si masị ya,
\q2 na izi ndị okenye ya amamihe.
\b
\q1 
\v 23 Mgbe ahụ, Izrel bara nʼala Ijipt;
\q2 Jekọb bikwara nʼala Ham dịka onye si mba ọzọ bịa.
\q1 
\v 24 \nd Onyenwe anyị\nd* mere ka ndị ya mụbaa nke ukwuu;
\q2 o mere ka ndị ya dị ukwuu nʼọnụọgụgụ karịa ndị iro ha,
\q1 
\v 25 ndị ọ tụgharịrị obi ha ka ha kpọọ ndị ya asị,
\q2 ka ha gbaa izu nzuzo megide ndị ohu ya.
\q1 
\v 26 O zipụrụ Mosis, ohu ya,
\q2 na Erọn, onye ọ họpụtara.
\q1 
\v 27 Ha mere ọtụtụ ihe ịrịbama dị iche iche nʼetiti ha,
\q2 ọrụ ebube ya dị iche iche nʼala Ham.
\q1 
\v 28 O zipụrụ ọchịchịrị, mee ka ala ahụ gbaa ọchịchịrị,
\q2 nʼihi na ha nupuru isi megide okwu ya.
\q1 
\v 29 O mere ka mmiri ha niile ghọọ ọbara,
\q2 nke mere ka azụ niile dị nʼime ya nwụsịa.
\q1 
\v 30 Ala ha niile jupụtara nʼawọ
\q2 ọ bụladị nʼime ọnụụlọ ndina nke ndị na-achị achị.
\q1 
\v 31 O kwuru okwu, igwe ijiji na anwụ nta
\q2 dị iche iche ejupụta nʼala ha niile.
\q1 
\v 32 Nʼọnọdụ mmiri ozuzo, o zitere ha
\q2 mkpụrụ mmiri na amụma egbe eluigwe nʼala ha niile;
\q1 
\v 33 o tijisịrị osisi vaịnị na osisi fiig niile ha,
\q2 kwatusịakwa osisi niile dị nʼala ha.
\q1 
\v 34 O kwuru okwu, igurube na ụkpana
\q2 a na-apụghị ịgụta ọnụ jupụtara ebe niile;
\q1 
\v 35 ha richapụrụ ihe niile bụ ahịhịa ndụ dị nʼala ahụ,
\q2 ripịakwa mkpụrụ niile ha kụrụ nʼubi ha.
\q1 
\v 36 Mgbe ahụ, o gburu ndị niile e buru ụzọ mụọ nʼala ahụ,
\q2 mkpụrụ mbụ nke ndị ikom ha.
\q1 
\v 37 Ọ kpọpụtara ụmụ Izrel, ndị chịịrị ọlaọcha na ọlaedo,
\q2 ọ dịghị otu onye nʼime ebo ya niile nke ahụ na-esighị ike.
\q1 
\v 38 Obi dị Ijipt ụtọ mgbe ha pụrụ,
\q2 nʼihi na oke egwu ndị Izrel dakwasịrị ha.
\b
\q1 
\v 39 Ọ gbasara igwe ojii dịka ihe mkpuchi,
\q2 na ọkụ na-enye ìhè nʼabalị.
\q1 
\v 40 Ha rịọrọ ya, o zitere ha ụmụ nnụnụ kweel,
\q2 jirikwa achịcha si nʼeluigwe nyejuo ha afọ.
\q1 
\v 41 O tiwara nkume ahụ, mmiri sọpụtara;
\q2 ọ sọgharịrị nʼime ọzara dịka iyi.
\b
\q1 
\v 42 Nʼihi na o chetara nkwa ya dị nsọ,
\q2 nke o kwere ohu ya Ebraham.
\q1 
\v 43 O ji aṅụrị dupụta ndị ya,
\q2 jirikwa ọnọdụ iti mkpu ọṅụ dupụta ndị ya ọ họpụtara;
\q1 
\v 44 o nyere ha ala niile nke mba dị iche iche,
\q2 ha ghọrọ ndị nnweta nke ihe ndị ọzọ rụpụta,
\q1 
\v 45 ka ha nwee ike debe ụkpụrụ ya niile
\q2 ma na-erubekwa isi nʼiwu ya niile.
\b
\q1 Toonu \nd Onyenwe anyị\nd*.
\c 106
\cl Abụ Ọma 106
\s1 Toonu Chineke onye ebere
\q1 
\v 1 Toonu \nd Onyenwe anyị\nd*.
\b
\q1 Keleenụ \nd Onyenwe anyị\nd* nʼihi na ọ dị mma;
\q2 Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\b
\q1 
\v 2 Onye pụrụ ikwupụtasịcha ihe ukwu niile nke \nd Onyenwe anyị\nd* na-arụ
\q2 maọbụ kwupụta otuto ya niile?
\q1 
\v 3 Ndị a gọziri agọzi ka ha bụ, bụ ndị na-edebe ikpe ziri ezi,
\q2 ndị ahụ na-eme ezi ihe mgbe niile.
\b
\q1 
\v 4 O \nd Onyenwe anyị\nd*, cheta m mgbe ị ga-egosi ndị gị ihuọma,
\q2 bịa leta m, mgbe ị na-azọpụta ha,
\q1 
\v 5 ka m soro keta oke na ngọzị ndị gị ị họpụtara,
\q2 ka m keta oke nʼọṅụ ahụ dịrị mba gị
\q2 sorokwa ihe nketa gị nye otuto.
\b
\q1 
\v 6 Anyị emehiela, dịka nna nna anyị ha mehiere;
\q2 anyị emeela ihe ọjọọ, rụọkwa ọrụ ajọ omume.
\q1 
\v 7 Mgbe nna nna anyị ha nọ nʼIjipt,
\q2 ha echeghị uche banyere ọrụ ebube gị niile;
\q1 ha echetakwaghị ịba ụba nke ebere gị niile,
\q2 kama ha nupuru isi nʼakụkụ oke osimiri ahụ, bụ Osimiri Uhie.
\q1 
\v 8 Ma ọ zọpụtara ha nʼihi aha ya,
\q2 ime ka a mara ike ya dị ukwuu.
\q1 
\v 9 Ọ baara Osimiri Uhie mba, ọ tachaa;
\q2 o dufere ndị ya site nʼebe dị omimi gafee dịka ọ bụ ọzara.
\q1 
\v 10 Ọ zọpụtara ha site nʼaka ndị kpọrọ ha asị;
\q2 gbapụtakwa ha site nʼaka ndị iro ha.
\q1 
\v 11 Mmiri ahụ riri ndị iro ha niile;
\q2 ọ dịghị otu onye nʼime ha fọdụrụ.
\q1 
\v 12 Mgbe ahụ, ha kweere okwu gị niile,
\q2 ma bụkuo gị abụ otuto.
\b
\q1 
\v 13 Ma o teghị aka, ha chefuru ihe niile ọ rụrụ,
\q2 ha e chereghị ka ndụmọdụ ya pụta ìhè.
\q1 
\v 14 Nʼọzara, ha sooro ọchịchọ nke obi ha;
\q2 nʼala tọgbọrọ nʼefu, ha nwara Chineke ọnwụnwa.
\q1 
\v 15 Nʼihi ya, o nyere ha ihe ha rịọrọ ya,
\q2 ma zite ọrịa na-efe efe ka ọ dakwasị ha.
\b
\q1 
\v 16 Nʼetiti ọmụma ụlọ ikwu ha, ha kworo ekworo megide Mosis
\q2 na Erọn, ndị e doro nsọ nye Onyenwe anyị.
\q1 
\v 17 Ala meghere loda Datan,
\q2 o likwara Abiram, na ndị otù ya.
\q1 
\v 18 Ọkụ repịara ndị niile sonyere ha;
\q2 ire ọkụ repịara ndị ajọ omume.
\q1 
\v 19 Na Horeb, ha kpụrụ nwa ehi,
\q2 kpọọ isiala nye arụsị e jiri igwe pịa.
\q1 
\v 20 Ha jiri oyiyi oke ehi nke na-ata ahịhịa
\q2 gbanwere Ebube ha.
\q1 
\v 21 Ha chefuru Chineke, onye zọpụtara ha,
\q2 onye rụrụ ọtụtụ ọrụ dị ukwuu nʼIjipt,
\q1 
\v 22 ọtụtụ ihe ịrịbama nʼala Ham,
\q2 na ọtụtụ ọrụ ịtụnanya nʼakụkụ Osimiri Uhie.
\q1 
\v 23 Nʼihi ya, o kwuru na ọ ga-ala ha nʼiyi,
\q2 ma Mosis, onye ya ọ họpụtara,
\q1 guzoro nʼetiti ndị ahụ na Chineke,
\q2 ka oke iwe ya ghara ịla ha nʼiyi.
\b
\q1 
\v 24 Emesịa, ha ledara ala ọma ahụ anya,
\q2 ha ekwenyeghị na nkwa ya.
\q1 
\v 25 Ha tamuru ntamu nʼime ụlọ ikwu ha;
\q2 ha erubekwaghị isi nye \nd Onyenwe anyị\nd*.
\q1 
\v 26 Nʼihi nke a, o weliri aka ya elu ṅụọrọ ha iyi
\q2 na ọ ga-eme ka ha niile nwụọ nʼọzara,
\q1 
\v 27 mee ka agbụrụ ha daa nʼetiti mba dị iche iche,
\q2 ma chụsasịa ha nʼala niile.
\b
\q1 
\v 28 Ha dịnyeere ndị na-efe arụsị Baal nke Peoa,
\q2 riekwa ihe e ji chụọrọ chi na-enweghị ndụ aja;
\q1 
\v 29 ha sitere nʼajọ omume ha kpasuo \nd Onyenwe anyị\nd* iwe,
\q2 nke mere ka ọrịa na-efe efe dakwasị ha.
\q1 
\v 30 Ma Finehaz guzoro ọtọ, mee ihe ziri ezi,
\q2 ọrịa ahụ na-efe efe kwụsịkwara.
\q1 
\v 31 A gụnyere nke a dịka ezi omume nye ya
\q2 site nʼọgbọ ruo nʼọgbọ.
\q1 
\v 32 Nʼakụkụ mmiri Meriba, ha kpasuru \nd Onyenwe anyị\nd* iwe,
\q2 nʼihi ha, nsogbu dakwasịrị Mosis;
\q1 
\v 33 nʼihi na ha nupuru isi megide Mmụọ nke Chineke,
\q2 Mosis kwuru okwu, na-echeghị echiche banyere ihe ọ na-ekwu.
\b
\q1 
\v 34 Ha egbuchapụghị mba niile bi nʼala ahụ
\q2 dịka \nd Onyenwe anyị\nd* dọrọ ha aka na ntị ka ha mee.
\q1 
\v 35 Kama ha gwakọtara onwe ha na mba niile nke ala ahụ,
\q2 site otu a, mụta ime ka ha na-eme.
\q1 
\v 36 Ha fere arụsị ha ofufe,
\q2 nke ghọrọ ihe ịma nʼọnya nye ha.
\q1 
\v 37 Ha gara nʼihu were ụmụ ha ndị ikom na ndị
\q2 inyom chụọrọ chi na-abụghị chi aja.\f + \fr 106:37 \ft Maọbụ, \fqa ajọ mmụọ\f*
\q1 
\v 38 Ha na-awụfu ọbara ndị na-emeghị ihe ọbụla,
\q2 ọbara ụmụ ha ndị ikom na ndị inyom,
\q1 bụ ndị ha chụrụ dịka aja nye arụsị niile nke ala Kenan,
\q2 si otu a jiri ọbara ha merụọ ala ahụ.
\q1 
\v 39 Ha sitere nʼihe ha na-eme merụọ onwe ha;
\q2 site nʼaka ọrụ ha, maka uru ha nyefere onwe ha nʼaka ndị na-emerụ ha.
\b
\q1 
\v 40 Nʼihi nke a, iwe were \nd Onyenwe anyị\nd* megide ndị ya;
\q2 ọ gụkwara ihe nketa ya dịka ihe rụrụ arụ.
\q1 
\v 41 Ọ raara ha nye nʼaka ndị mba ọzọ dị iche iche,
\q2 ndị kpọrọ ha asị chịkwara ha.
\q1 
\v 42 Ndị iro ha mekpara ha ahụ
\q2 chie ha ọnụ nʼala nʼokpuru ike ha.
\q1 
\v 43 Ọtụtụ oge, ọ napụtara ha,
\q2 ma ha nọgidesịrị ike nʼinupu isi site na ndụmọdụ ya,
\q2 bụrụ ndị lara nʼiyi nʼime mmehie ha.
\q1 
\v 44 Ma mgbe ọ nụrụ mkpu akwa ha,
\q2 ọnọdụ mkpagbu ha metụtara ya;
\q1 
\v 45 nʼihi ha, o chetara ọgbụgba ndụ ya,
\q2 sitekwa nʼoke ịhụnanya ya, meere ha ebere.
\q1 
\v 46 Ọ na-emekwa ka ndị ahụ dọtara ha nʼagha
\q2 nwee ọmịiko nʼahụ ha.
\b
\q1 
\v 47 O \nd Onyenwe anyị\nd* Chineke anyị, zọpụta anyị,
\q2 chịkọta anyị site nʼaka mba dị iche iche,
\q1 ka anyị nwee ike nye aha nsọ gị ekele
\q2 ma nyaakwa isi nʼime otuto gị.
\b
\b
\q1 
\v 48 Otuto dịrị \nd Onyenwe anyị\nd*, bụ Chineke nke Izrel,
\q2 site nʼebighị ebi ruo ebighị ebi.
\b
\q1 Ka mmadụ niile sị, “Amen!”
\b
\q1 Toonu \nd Onyenwe anyị\nd*.
\c 107
\ms1 Nchịkọta nke ise
\mr Abụ Ọma 107–150
\cl Abụ Ọma 107
\s1 Ekele maka Chineke onye na-anapụta
\q1 
\v 1 Keleenụ \nd Onyenwe anyị\nd*, nʼihi na ọ dị mma;
\q2 ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\b
\q1 
\v 2 Ka ndị niile \nd Onyenwe anyị\nd* gbapụtara kwuo otu a,
\q2 ndị niile ọ gbapụtara site nʼaka onye kpọrọ ha asị,
\q1 
\v 3 ndị ọ kpọlatara site nʼala niile dị iche iche,
\q2 site nʼọwụwa anyanwụ na ọdịda anyanwụ, site nʼugwu na ndịda.
\b
\q1 
\v 4 Ụfọdụ wagharịrị nʼọzara, ala nke tọgbọrọ nʼefu,
\q2 ha enweghị ike ịchọta ụzọ nke ga-eduba ha nʼobodo ebe ha ga-ebi.
\q1 
\v 5 Agụụ gụrụ ha, akpịrị kpọkwara ha nkụ,
\q2 olileanya gwụrụ ha nʼobi.
\q1 
\v 6 Mgbe ahụ, ha kpọkuru \nd Onyenwe anyị\nd*, nʼime nsogbu ha,
\q2 ọ napụtakwara ha site na mkpagbu ha niile.
\q1 
\v 7 O duuru ha nʼụzọ ziri ezi
\q2 baa nʼobodo ha ga-ebi.
\q1 
\v 8 Ka ha kelee \nd Onyenwe anyị\nd* nʼihi ịhụnanya ya nke na-adịghị agwụ agwụ
\q2 na nʼihi ọrụ ebube ya niile nye ụmụ mmadụ,
\q1 
\v 9 nʼihi na o jirila ọtụtụ ezi ihe nyejuo ndị agụụ na-agụ afọ
\q2 meekwa ka onye akpịrị na-akpọ nkụ ṅụjuo afọ.
\b
\q1 
\v 10 Ụfọdụ nọdụrụ ala nʼọchịchịrị na nʼọnọdụ oke ihe mwute nke obi,
\q2 ndị nọ nʼụlọ mkpọrọ na-ata ahụhụ ndị e ji mkpọrọ igwe kee ha agbụ,
\q1 
\v 11 nʼihi na ha nupuru isi megide okwu niile nke Chineke
\q2 ma lelikwaa ndụmọdụ niile nke Onye kachasị ihe niile elu.
\q1 
\v 12 Nʼihi ya, Chineke mere ka ha hụjuo anya site nʼịdọgbu onwe ha nʼọrụ,
\q2 ha sụrụ ngọngọ daa, ma ọ dịghị onye ọbụla nyeere ha aka ibilite ọtọ.
\q1 
\v 13 Mgbe ahụ, ha kpọkuru \nd Onyenwe anyị\nd* nʼime nsogbu ha,
\q2 ọ zọpụtara ha site na mkpagbu ha niile.
\q1 
\v 14 O mere ka ha site nʼọchịchịrị na oke ihe mwute nke obi pụta.
\q2 O tijikwara agbụ ha niile.
\q1 
\v 15 Ka ha kelee \nd Onyenwe anyị\nd* nʼihi ịhụnanya ya, nke na-adịghị agwụ agwụ
\q2 na nʼihi ọrụ ebube ya niile nye ụmụ mmadụ,
\q1 
\v 16 nʼihi na o tijisiela ọnụ ụzọ ama niile e ji bronz kpụọ
\q2 gbujiekwa mkpọrọ ịkpọchi ụzọ niile e ji igwe kpụọ.
\b
\q1 
\v 17 Ụfọdụ ghọrọ ndị nzuzu site na nnupu isi
\q2 taakwa ahụhụ nʼihi njehie ha niile.
\q1 
\v 18 Ihe oriri ọbụla ghọọrọ ha ihe rụrụ arụ
\q2 ha bịakwara ọnụ ụzọ ama ọnwụ nso.
\q1 
\v 19 Mgbe ahụ, ha kpọkuru \nd Onyenwe anyị\nd* nʼime nsogbu ha
\q2 ọ zọpụtara ha site na mkpagbu ahụ niile.
\q1 
\v 20 O zipụrụ okwu ọnụ ya, gwọọ ha;
\q2 ọ napụtara ha site nʼili.
\q1 
\v 21 Ka ha kelee \nd Onyenwe anyị\nd* nʼihi ịhụnanya ya nke na-adịghị agwụ agwụ
\q2 na nʼihi ọrụ ebube ya niile nye ụmụ mmadụ.
\q1 
\v 22 Ka ha chụọ aja ekele nye ya
\q2 jirikwa ọtụtụ abụ ọṅụ kwupụta banyere ọrụ ya niile.
\b
\q1 
\v 23 Ụfọdụ ji ụgbọ mmiri na-ejegharị nʼelu oke osimiri;
\q2 ha bụ ndị na-azụ ahịa ma na-ebugharịkwa ngwa ahịa nʼelu oke osimiri.
\q1 
\v 24 Ha hụrụ ọrụ niile nke \nd Onyenwe anyị\nd*,
\q2 ọtụtụ ọrụ ebube ya nʼogbu mmiri.
\q1 
\v 25 Nʼihi na o kwuru okwu mere ka oke ifufe kuo
\q2 nke buliri ebili mmiri elu.
\q1 
\v 26 Ha bụ ndị e buliri nnọọ ezigbo elu, ma budatakwa ruo ogbu mmiri niile;
\q2 nʼọnọdụ ihe egwu ahụ, obi lọrọ ha mmiri.
\q1 
\v 27 Ha na-adagharị, na-aṅagharịkwa dịka ndị ṅụbigara mmanya oke.
\q2 Mmụta ha banyere ịnya ụgbọ mmiri adịghị enyekwara ha aka nʼoge dị otu a.
\q1 
\v 28 Mgbe ahụ, ha kpọkuru \nd Onyenwe anyị\nd* nʼime nsogbu ha,
\q2 o mere ka ha pụta na mkpagbu ahụ niile.
\q1 
\v 29 O mere ka oke ifufe dere duu;
\q2 o mekwara ka ebili mmiri nke oke osimiri dajụọ.
\q1 
\v 30 Ha ṅụrịrị ọṅụ mgbe ọ dajụrụ,
\q2 o duuru ha ruo ebe ha na-aga nʼudo.
\q1 
\v 31 Ka ha kelee \nd Onyenwe anyị\nd* nʼihi ịhụnanya ya nke na-adịghị agwụ agwụ
\q2 na nʼihi ọrụ ebube ya niile nye ụmụ mmadụ.
\q1 
\v 32 Ka ha bulie ya elu nʼetiti ọgbakọ ukwu ụmụ mmadụ
\q2 ma tookwa ya na nzukọ ndị okenye.
\b
\q1 
\v 33 Ọ na-eme ka iyi ghọọ ọzara;
\q2 na-emekwa ka ebe mmiri si asọpụta ghọọ ala kpọrọ nkụ.
\q1 
\v 34 Ọ na-eme ka ala na-amị mkpụrụ hiri nne ghọọ ọzara,
\q2 nʼihi ajọ omume nke ndị bi nʼime ya.
\q1 
\v 35 Ọ na-eme ka ọzara ghọọ ala nke ọdọ mmiri jupụtara
\q2 mee ka ala akọrọ ghọọ isi iyi nke na-asọ asọ;
\q1 
\v 36 ebe ahụ ka ọ kpọbatara ndị agụụ na-agụ ka ha biri,
\q2 ebe ahụ ka ha wuru obodo ebe ha ga-ebi.
\q1 
\v 37 Ha ghara mkpụrụ nʼubi ha dị iche iche, kụọkwa ọtụtụ ubi vaịnị
\q2 ndị mịrị mkpụrụ dị ukwuu;
\q1 
\v 38 ọ gọziri ha, ọnụọgụgụ ha bakwara ụba,
\q2 o mekwara ka anụ ụlọ ha mụbaa.
\b
\q1 
\v 39 Mgbe ahụ, ọnụọgụgụ ha adịghịkwa ka ọ dị na mbụ,
\q2 ha bụ ndị e ji mkpagbu na ihe ndakwasị na iru ụjụ wedata nʼala;
\q1 
\v 40 onye ahụ na-eleda ndị na-achị achị anya
\q2 mere ka ha wagharịa nʼọzara, ebe ụzọ na-adịghị.
\q1 
\v 41 Ma ọ na-anapụta ndị mkpa na-akpa site na nhụju anya ha,
\q2 mee ka ezinaụlọ ha mụbaa dịka igwe anụ ụlọ.
\q1 
\v 42 Ndị ezi omume na-ahụ ya na-aṅụrị ọṅụ,
\q2 ma ndị ajọ omume na-emechi ọnụ ha nọọ duu.
\b
\q1 
\v 43 Onye ọbụla maara ihe ga-echezi echiche banyere ihe ndị a,
\q2 ma tuleekwa ọrụ ịhụnanya \nd Onyenwe anyị\nd* nke dị ukwuu.
\c 108
\cl Abụ Ọma 108
\d Abụ, Abụ Ọma Devid.
\s1 Ekpere nʼoge nsogbu
\q1 
\v 1 Obi m dị njikere, o Chineke;
\q2 aga m eji mkpụrụobi m niile bụọ abụ ma kụkwaa egwu.
\q1 
\v 2 Teta! Ụbọ akwara na une!
\q2 Aga m akpọte chi ọbụbọ.
\q1 
\v 3 Aga m eto gị, O \nd Onyenwe anyị\nd*, nʼetiti mba niile;
\q2 aga m abụ abụ banyere gị nʼetiti ndị niile dị iche iche.
\q1 
\v 4 Nʼihi na ịhụnanya gị dị ukwuu karịa eluigwe;
\q2 ikwesi ntụkwasị obi gị na-erukwa mbara eluigwe.
\q1 
\v 5 Ka e bulie gị elu, o Chineke, karịa eluigwe niile,
\q2 ka ebube gị dị nʼelu ụwa niile.
\b
\q1 
\v 6 Were aka nri gị zọpụta anyị ma nyere anyị aka,
\q2 ka a gbapụta ndị ị hụrụ nʼanya.
\q1 
\v 7 Chineke esitela nʼịdị nsọ ya kwuo, sị,
\q2 “Nʼọnọdụ ọṅụ nke mmeri, aga m ekesa Shekem,
\q2 tụkwaa Ndagwurugwu Sukọt nʼihe ọtụtụ, nyepụ ya.
\q1 
\v 8 Gilead bụ nke m, Manase bụkwa nke m;
\q2 Ifrem bụ okpu igwe m,
\q2 Juda bụ mkpara eze m.
\q1 
\v 9 Moab bụ efere ịkwọ aka m,
\q2 aga m atụsa akpụkpọụkwụ m nʼelu Edọm
\q2 nʼelu isi Filistia, ana m eti mkpu mmeri.”
\b
\q1 
\v 10 Onye ga-akpọrọ m gaa nʼobodo e wusiri ike?
\q2 Onye ga-edu m gaa Edọm?
\q1 
\v 11 Ọ bụghị gị, o Chineke? Gị onye jụrụ anyị,
\q2 onye na-adịghị esokwa ndị agha anyị aga agha?
\q1 
\v 12 Nyere anyị aka ka anyị pụọ nʼaka ndị iro,
\q2 nʼihi na inyeaka mmadụ bụ ihe efu.
\q1 
\v 13 Site na Chineke, anyị ga-enwe mmeri,
\q2 ọ ga-azọpịa ndị iro anyị niile nʼala.
\c 109
\cl Abụ Ọma 109
\d Abụ Ọma nke dịrị onyeisi Abụ. Abụ Ọma Devid.
\s1 Ntamu nʼoge nsogbu
\q1 
\v 1 O Chineke, onye m na-eto,
\q2 anọgidekwala na-agba nkịtị,
\q1 
\v 2 nʼihi na ndị ajọ omume na ndị aghụghọ
\q2 emegheela ọnụ ha megide m;
\q2 ha aghaala ụgha megide m.
\q1 
\v 3 Ha na-eji okwu ịkpọ asị gbaa m gburugburu;
\q2 na-ebuso m agha nʼefu.
\q1 
\v 4 Nʼọnọdụ ịhụnanya m hụrụ ha, ha na-ebo m ebubo
\q2 ma abụ m nwoke onye ekpere.
\q1 
\v 5 Ha ji ihe ọjọọ na-akwụ m ụgwọ ihe ọma m mere,
\q2 ịkpọ asị nʼọnọdụ ịhụnanya.
\b
\q1 
\v 6 Họpụta otu onye ajọ omume ka o guzogide ya;
\q2 ka onye na-ebo ebubo ụgha guzokwa nʼaka nri ya.
\q1 
\v 7 Mgbe a ga-ekpe ya ikpe, ka ọ bụrụ onye ikpe mara,
\q2 ka ekpere ya maa ya ikpe ọnwụ.
\q1 
\v 8 Ka ụbọchị ndụ ya dị ole na ole,
\q2 ka onye ọzọ nara ya ọkwa ya.
\q1 
\v 9 Ka ụmụ ya ghọọ ndị na-enweghị nna,
\q2 ka nwunye ya bụrụ nwanyị na-enweghị di.
\q1 
\v 10 Ka ụmụ ya ghọọ ndị arịrịọ na-enweghị ebe obibi,
\q2 ndị e si na mkpọmkpọ ebe ha bi chụpụ.
\q1 
\v 11 Ka ndị o ji ụgwọ kwakọrọ ihe niile o nwere,
\q2 ka ndị ọbịa baa bukọrọ ihe niile ọ rụpụtaara onwe ya.
\q1 
\v 12 Ka onye ọbụla ghara igosi ya obiọma;
\q2 ka onye ọbụla gharakwa imere ụmụ ya ndị ọ hapụrụ ebere.
\q1 
\v 13 Kama ka ụmụ ụmụ ya niile nwụsịa,
\q2 ka a ehichapụkwa aha ha nʼọgbọ nke na-abịa nʼihu.
\q1 
\v 14 Ka \nd Onyenwe anyị\nd* chetakwa mmehie niile nke nna nna ya ha,
\q2 ka Onyenwe anyị hapụkwa ịgbaghara mmehie nne ya.
\q1 
\v 15 Ka \nd Onyenwe anyị\nd* na-echeta mmehie ha oge niile;
\q2 ma ka o mee ka ha bụrụ ndị a ga-echefu echefu nʼọgbọ niile.
\b
\q1 
\v 16 Nʼihi na ọ dịghị mgbe o chere echiche banyere imere onye ọzọ obi ebere,
\q2 ọ kpagburu ndị ogbenye, ndị nọ na mkpa
\q2 na ndị obi ha tiwara etiwa ruo nʼọnwụ.
\q1 
\v 17 Ọ hụrụ ịbụ ndị ọzọ ọnụ nʼanya,
\q2 ka ọbụbụ ọnụ bịakwasị ya;
\q1 ọ dịghị atọ ya ụtọ ịgọzi onye ọbụla,
\q2 ka ngọzị dị anya site nʼebe ọ nọ.
\q1 
\v 18 O yikwasịrị ịbụ ọnụ dịka uwe ya;
\q2 ọ bara nʼime ahụ ya dịka mmiri,
\q2 bakwaa nʼime ọkpụkpụ ya dịka mmanụ.
\q1 
\v 19 Ka ọ dịịrị ya ka uwe mwụda nke e kere ya gburugburu dịka akwa,
\q2 dịka belịt e kegidere ya gburugburu ruo mgbe ebighị ebi.
\q1 
\v 20 \nd Onyenwe anyị\nd*, mee ka nke a bụrụ ụdị ụgwọ ọrụ ndị iro m ga-anata,
\q2 bụ ndị ahụ niile na-ekwu okwu ọjọọ megide m.
\b
\q1 
\v 21 Ma gị onwe gị, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*
\q2 nyere m aka nʼihi aha gị,
\q2 site nʼịdị mma nke ịhụnanya gị, napụta m.
\q1 
\v 22 Nʼihi na abụ m ogbenye na onye nọ na mkpa,
\q2 obi m tiwakwara etiwa nʼime m.
\q1 
\v 23 Ana m efu\f + \fr 109:23 \ft Maọbụ, \fqa agba barịị\f* dịka onyinyo nke a na-ahụ anya mgbe anwụ dara;
\q2 adịkwa m ka igurube nke onye m bekwasịrị nʼahụ ya na-efechapụ.
\q1 
\v 24 Ike agwụla ikpere m, nʼihi ibu ọnụ;
\q2 ataakwala m ahụ, bụrụ naanị ọkpụkpụ.
\q1 
\v 25 Aghọọla m onye e ji eme ihe ọchị nye ndị na-ebo m ebubo,
\q2 mgbe ha hụrụ m, ha na-efufe isi ha.
\b
\q1 
\v 26 Nyere m aka, o \nd Onyenwe anyị\nd* Chineke m;
\q2 zọpụta m dịka ịhụnanya gị si dị.
\q1 
\v 27 Ka ha mara na ọ bụ aka gị,
\q2 na ọ bụ gị, o \nd Onyenwe anyị\nd*, mere ya.
\q1 
\v 28 Ha nwere ike nọgide na-abụ ọnụ, ma ị ga-agọzi;
\q2 mgbe ha ga-abịa ọgụ, a ga-eme ha ihe ihere,
\q2 ma ohu gị ga-aṅụrị ọṅụ.
\q1 
\v 29 A ga-eji ihere yikwasị ndị na-ebo m ebubo dịka uwe
\q2 werekwa ihere kee ha gburugburu dịka uwe mwụda.
\b
\q1 
\v 30 Aga m eji ọnụ m jaa \nd Onyenwe anyị\nd* mma nke ukwuu;
\q2 nʼetiti ọha mmadụ dị ukwuu, aga m eto ya.
\q1 
\v 31 Nʼihi na ọ na-eguzo nʼaka nri nke onye nọ na mkpa,
\q2 ịzọpụta ya site nʼaka ndị na-ama ya ikpe ọnwụ.
\c 110
\cl Abụ Ọma 110
\d Abụ Ọma Devid.
\s1 Onyenwe anyị na onye ya o tere mmanụ
\q1 
\v 1 \nd Onyenwe anyị\nd* gwara Onyenwe m okwu sị ya:
\b
\q1 “Nọdụ ala nʼaka nri m
\q2 ruo mgbe m ga-eme ndị iro gị
\q2 ihe mgbakwasị ụkwụ nye ụkwụ gị.”\f + \fr 110:1 \ft Nʼoge ochie, a na-arụ ocheeze nʼebe dị elu, ma nwee ihe nrigo e ji arịgoru ya. Mgbe ahụ, ndị eze na-achịkwasa ụkwụ ha nʼolu ndị ha meriri nʼagha, \xt Mat 22:44; Mak 12:36; Luk 20:42-43; Hib 1:13; 1Kọ 15:25.\xt*\f*
\b
\q1 
\v 2 \nd Onyenwe anyị\nd* ga-eme ka ike ọchịchị gị site na Zayọn ruo ala ndị ọzọ;
\q2 ị ga-achị nʼetiti ndị iro gị niile.
\q1 
\v 3 Nʼụbọchị ị ga-ebu agha,
\q2 ndị agha gị niile ga-ahọrọ nʼonwe ha i soro gị.
\q1 Ndị yikwasịrị ịma mma nke ịdị nsọ ka uwe,
\q2 bụ ụmụ okorobịa gị ga-abịakwute gị
\q2 dịka igirigi site nʼafọ ụtụtụ.
\b
\q1 
\v 4 \nd Onyenwe anyị\nd* aṅụọla iyi,
\q2 ọ gaghị agbanwe uche ya:
\q1 “Gị onwe gị bụ onye nchụaja ruo mgbe ebighị ebi,
\q2 nʼusoro Melkizedek.”
\b
\q1 
\v 5 Onyenwe anyị nọ nʼaka nri gị.
\q2 Ọ ga-egwepịa ndị eze nʼụbọchị oke iwe ya.
\q1 
\v 6 Ọ ga-ekpe mba niile ikpe, na-atụkọta ndị nwụrụ anwụ,
\q2 ma gwepịa ndị na-achị achị nʼelu ụwa niile.
\q1 
\v 7 Ọ ga-aṅụ mmiri site nʼiyi nta nke dị nʼakụkụ ụzọ;
\q2 nʼihi nke a, ọ ga-eweli isi ya elu.
\c 111
\cl Abụ Ọma 111
\s1 Toonu Onyenwe anyị
\q1 
\v 1 Toonu \nd Onyenwe anyị\nd*!
\b
\q1 Aga m eji obi m niile jaa \nd Onyenwe anyị\nd* mma
\q2 nʼime nzukọ ndị ụzọ ha ziri ezi na nʼime ọgbakọ ukwuu.
\b
\q1 
\v 2 Ọrụ niile \nd Onyenwe anyị\nd* na-arụ dị ukwuu;
\q2 ndị niile na-enwe mmasị na ha na-atụgharị uche nʼime ha.
\q1 
\v 3 Ọrụ ya jupụtara nʼebube na ịma mma,
\q2 ezi omume ya na-adịgidekwa ruo mgbe ebighị ebi.
\q1 
\v 4 O meela ka e cheta ọrụ ebube ya niile;
\q2 \nd Onyenwe anyị\nd* bụ onye amara na onye ọmịiko.
\q1 
\v 5 Ọ na-egboro ndị na-atụ egwu ya mkpa ihe oriri;
\q2 ọ na-echetakwa ọgbụgba ndụ ya ruo mgbe ebighị ebi.
\b
\q1 
\v 6 O gosila ndị ya ike nke ọrụ ya niile,
\q2 site nʼinye ha ala niile nke ndị mba ọzọ.
\q1 
\v 7 Ọrụ aka ya niile bụ ihe kwesiri ekwesi na ikpe ziri ezi;
\q2 ụkpụrụ ya niile bụ ihe kwesiri ntụkwasị obi.
\q1 
\v 8 E hiwere ha ịdị ruo mgbe niile ebighị ebi,
\q2 ha bụ ihe e mere nʼikwesị ntụkwasị obi na izi ezi.
\q1 
\v 9 O wetaara ndị ya mgbapụta;
\q2 o meela ka ọgbụgba ndụ ya guzosie ike ruo ebighị ebi,
\q2 aha ya dị nsọ dịkwa oke egwu.
\b
\q1 
\v 10 Ịtụ egwu \nd Onyenwe anyị\nd* bụ mmalite amamihe;
\q2 ndị niile na-edebe ụkpụrụ ya nwere ezi nghọta.
\q2 Otuto ya na-adị ruo mgbe ebighị ebi.
\c 112
\cl Abụ Ọma 112
\s1 Ụgwọ ọrụ nke onye ezi omume
\q1 
\v 1 Toonu \nd Onyenwe anyị\nd*.
\b
\q1 Onye a gọziri agọzi ka nwoke ahụ bụ onye na-atụ egwu \nd Onyenwe anyị\nd*;
\q2 onye na-enwe oke mmasị idebe iwu ya niile.
\b
\q1 
\v 2 Ụmụ ya ga-abụ ndị dị ike nʼala ahụ;
\q2 ọgbọ ndị na-eme ihe ziri ezi ga-abụ ndị a gọziri agọzi.
\q1 
\v 3 Akụnụba na-adịgide nʼụlọ ya;
\q2 ezi omume ya na-adịgidekwa ruo mgbe ebighị ebi.
\q1 
\v 4 Ìhè na-enwuru ndị na-eme ihe ziri ezi, ọ bụladị nʼime ọchịchịrị,
\q2 nyekwa ndị na-eme amara, ndị obiọma na ndị ezi omume.
\q1 
\v 5 Ihe ọma ga-abịara onye ahụ na-eme ebere na-ejikwa obi ya agbazinye ndị mmadụ ihe,
\q2 onye na-eji ikpe ziri ezi arụ ọrụ ya niile.
\b
\q1 
\v 6 Nʼezie, agaghị ewezuga ya nʼọnọdụ ya;
\q2 a ga-echeta onye ezi omume ruo mgbe ebighị ebi.
\q1 
\v 7 Ọ gaghị atụ egwu akụkọ ọjọọ;
\q2 obi ya na-eguzosi ike, na-atụkwasị \nd Onyenwe anyị\nd* obi.
\q1 
\v 8 Obi ya siri ike, ọ gaghị atụ egwu ihe ọbụla;
\q2 nʼikpeazụ, ọ ga-ele ndị na-akpọ ya asị anya na mmeri.
\q1 
\v 9 Ọ gbasapụrụ aka ya nye ndị ogbenye onyinye dị iche iche,
\q2 ezi omume ya na-adịgide ruo mgbe ebighị ebi;
\q2 a ga-ewere nsọpụrụ welie mpi ya elu.
\b
\q1 
\v 10 Iwe ga-ewe onye ajọ omume mgbe ọ ga-ahụ ya,
\q2 ọ ga-atagide ikikere eze tutu ọ nwụọ;
\q2 olileanya niile nke ndị ajọ omume ga-ala nʼiyi.
\c 113
\cl Abụ Ọma 113
\s1 Abụ otuto
\q1 
\v 1 Toonu \nd Onyenwe anyị\nd*!
\b
\q1 Toonu \nd Onyenwe anyị\nd* unu ndị ohu ya.
\q2 Toonu aha \nd Onyenwe anyị\nd*.
\q1 
\v 2 Ka aha \nd Onyenwe anyị\nd* bụrụ ihe a gọziri agọzi
\q2 site ugbu a ruo mgbe ebighị ebi.
\q1 
\v 3 Site nʼọwụwa anyanwụ ruo nʼọdịda ya,
\q2 aha \nd Onyenwe anyị\nd* ga-abụ ihe a na-eto eto.
\b
\q1 
\v 4 \nd Onyenwe anyị\nd* dị elu karịa mba niile,
\q2 ebube ya dị elu karịa eluigwe.
\q1 
\v 5 Onye dị ka \nd Onyenwe anyị\nd* Chineke anyị,
\q2 onye nọkwasịrị ocheeze nʼebe dị elu,
\q1 
\v 6 onye na-eme onwe ya ka ọ dị ala ilekwasị
\q2 eluigwe na ụwa anya?
\b
\q1 
\v 7 Ọ na-esi nʼuzuzu bulie ogbenye elu
\q2 sitekwa nʼebe ikpofu ahịhịa bulie onye nọ na mkpa elu;
\q1 
\v 8 ọ na-eme ka ya na ụmụ eze ndị ikom nọkọọ,
\q2 ọ na-eme ka o soro ndị a maara aha ha nʼetiti ụmụ mmadụ nọkọọ.
\q1 
\v 9 Ọ na-eme ka nwanyị aga biri nʼụlọ nke ya
\q2 dịka nne mụrụ ọtụtụ ụmụ ọṅụ juru obi.
\b
\q1 Toonu \nd Onyenwe anyị\nd*.
\c 114
\cl Abụ Ọma 114
\s1 Abụ ncheta ngabiga
\q1 
\v 1 Mgbe ụmụ Izrel si nʼala Ijipt pụta,
\q2 mgbe ezinaụlọ Jekọb sitekwara nʼebe ndị asụsụ ha dị iche pụta,
\q1 
\v 2 Juda ghọrọ ebe nsọ Chineke,
\q2 Izrel ghọrọ ala ọ na-achị.
\b
\q1 
\v 3 Osimiri hụrụ ya, gbaa ọsọ,\f + \fr 114:3 \ft \xt Ọpụ 14:21\xt*\f*
\q2 osimiri Jọdan hụkwara ya chigharịa laa azụ\f + \fr 114:3 \ft \xt Jos 3:12-16\xt*\f*;
\q1 
\v 4 Ugwu ukwu niile wụliri elu dịka ebule;
\q2 ugwu nta niile wụlikwara elu dịka ụmụ atụrụ.
\b
\q1 
\v 5 Gịnị mere gị oke osimiri, i ji na-agba ọsọ?
\q2 Osimiri Jọdan, gịnị na-eme gị i ji chigharịa laa azụ?
\q1 
\v 6 Gịnị na-eme unu, ugwu ukwu niile unu ji na-awụli elu dịka ụmụ ebule?
\q2 Gịnị na-emekwa unu, ugwu nta niile, unu ji na-awụli elu dịka ụmụ atụrụ?
\b
\q1 
\v 7 Ka ụwa niile maa jijiji nʼihu Onyenwe anyị,
\q2 ka ọ maakwa jijiji nʼihu Chineke nke Jekọb,
\q1 
\v 8 onye mere ka oke nkume ghọọ ọdọ mmiri,
\q2 onye mere ka ọmụ nkume ghọọ isi iyi mmiri.\f + \fr 114:8 \ft \xt Aịz 48:21; 1Kọ 10:4\xt*\f*
\c 115
\cl Abụ Ọma 115
\s1 Nyenụ Chineke otuto
\q1 
\v 1 Ọ bụghị anyị ka ọ dịrị, o \nd Onyenwe anyị\nd*, ọ bụghị anyị ka ọ dịrị,
\q2 kama ọ bụ aha gị ka ebube na-adịrị,
\q2 nʼihi ịhụnanya gị na ikwesi ntụkwasị obi gị.
\b
\q1 
\v 2 Gịnị mere ọtụtụ mba niile nke ụwa ji na-ajụ sị,
\q2 “Olee ebe Chineke ha nọ?”
\q1 
\v 3 Chineke anyị bi nʼeluigwe.
\q2 Ọ bụkwa ihe tọrọ ya ụtọ nʼobi ka ọ na-eme.
\q1 
\v 4 Arụsị ha niile bụ ọlaọcha na ọlaedo ka e ji kpụọ ha,
\q2 ha bụ ọrụ aka mmadụ.
\q1 
\v 5 Ha nwere ọnụ ma ha adịghị ekwu okwu,
\q2 ha nwere anya abụọ ma ha adịghị ahụ ụzọ;
\q1 
\v 6 ha nwere ntị ma ha adịghị anụ ihe,
\q2 ha nwekwara imi ma ha adịghị anụ isisi ọbụla;
\q1 
\v 7 ha nwere aka, ma ha adịghị emetụ ihe ọbụla aka,
\q2 ha nwere ụkwụ, ma ha adịghị eje ije;
\q2 ha enweghị ike iji akpịrị ha mee mkpọtụ ọbụla.
\q1 
\v 8 Ndị na-eme ha ga-adịkwa ka ha.
\q2 Ndị na-atụkwasị ha obi ga-adịkwa ka ha.
\b
\q1 
\v 9 Ụmụ Izrel, tụkwasịnụ \nd Onyenwe anyị\nd* obi
\q2 ọ bụ onye inyeaka ha na ọta ha.
\q1 
\v 10 Ezinaụlọ Erọn, tụkwasịnụ \nd Onyenwe anyị\nd* obi.
\q2 Ọ bụ ya bụ onye inyeaka ha na ọta ha.
\q1 
\v 11 Unu ndị na-atụ egwu ya, tụkwasịnụ \nd Onyenwe anyị\nd* obi
\q2 ọ bụ onye inyeaka ha na ọta ha.
\b
\q1 
\v 12 \nd Onyenwe anyị\nd* na-echeta anyị, ọ ga-agọzikwa anyị,
\q2 ọ ga-agọzi ndị ya bụ Izrel,
\q2 ọ ga-agọzi ezinaụlọ Erọn,
\q1 
\v 13 ọ ga-agọzi ndị niile na-atụ egwu \nd Onyenwe anyị\nd*,
\q2 ma onye nta ma onye ukwu.
\b
\q1 
\v 14 Ka \nd Onyenwe anyị\nd* mee ka unu mụbaa,
\q2 unu na ụmụ unu.
\q1 
\v 15 Ka \nd Onyenwe anyị\nd* onye kere eluigwe na elu ụwa
\q2 gọzie unu.
\b
\q1 
\v 16 Eluigwe niile bụ nke \nd Onyenwe anyị\nd*,
\q2 ọ bụkwa ya nyere ụmụ mmadụ elu ụwa niile.
\q1 
\v 17 Ọ bụghị ndị nwụrụ anwụ na-eto \nd Onyenwe anyị\nd*,
\q2 ndị na-arịda nʼebe ịnọ duu;
\q1 
\v 18 ọ bụ anyị ga-aja \nd Onyenwe anyị\nd* mma,
\q2 site ugbu a ruo mgbe ebighị ebi.
\b
\q1 Toonu \nd Onyenwe anyị\nd*.
\c 116
\cl Abụ Ọma 116
\s1 Chineke na-anapụta
\q1 
\v 1 Ahụrụ m \nd Onyenwe anyị\nd* nʼanya, nʼihi na ọ nụrụ olu m;
\q2 ọ nụrụ mkpu akwa m maka ebere.
\q1 
\v 2 Nʼihi na o gere m ntị,
\q2 aga m akpọku ya oge ndụ m niile.
\b
\q1 
\v 3 Agbụ nke ọnwụ kekọrọ m,
\q2 oke ihe mgbu nke ili bịakwasịrị m;
\q2 nsogbu na iru ụjụ dakwasịrị m.
\q1 
\v 4 Mgbe ahụ, akpọkuru m aha \nd Onyenwe anyị\nd*:
\q2 “O \nd Onyenwe anyị\nd*, zọpụta m!”
\b
\q1 
\v 5 \nd Onyenwe anyị\nd* bụ onye na-eme ebere na onye ezi omume.
\q2 Chineke anyị jupụtakwara nʼọmịiko.
\q1 
\v 6 \nd Onyenwe anyị\nd* na-echebe ndị na-enweghị uche;
\q2 mgbe m nọ nʼọnọdụ mkpa, ọ zọpụtara m.
\b
\q1 
\v 7 Laghachi azụ zuru ike, gị mkpụrụobi m,
\q2 nʼihi na \nd Onyenwe anyị\nd* emesola gị mmeso ọma.
\b
\q1 
\v 8 Nʼihi na gị, o \nd Onyenwe anyị\nd*, napụtara mkpụrụobi m site nʼọnwụ,
\q2 anya m site na anya mmiri akwa,
\q2 napụtakwa ụkwụ m site nʼịsọ ngọngọ,
\q1 
\v 9 ka m nwee ike jegharịa nʼihu \nd Onyenwe anyị\nd*
\q2 nʼime ala ebe ndị dị ndụ bi.
\b
\q1 
\v 10 Ekwenyere m na \nd Onyenwe anyị\nd* mgbe m kwuru sị,
\q2 “Abụ m onye nọ nʼoke nsogbu,”
\q1 
\v 11 nʼime ịda mba m, ekwuru m sị,
\q2 “Mmadụ niile bụ ndị ụgha.”
\b
\q1 
\v 12 Gịnị ka m ga-enyeghachi \nd Onyenwe anyị\nd*
\q2 nʼihi mmeso ọma niile o mesoro m?
\b
\q1 
\v 13 Aga m eweli iko nke nzọpụta m elu
\q2 kpọkuokwa aha \nd Onyenwe anyị\nd*.
\q1 
\v 14 Nʼihu ndị ya niile ka m ga-anọ
\q2 mezuo nkwa m kwere \nd Onyenwe anyị\nd*.
\b
\q1 
\v 15 Ọnwụ nke ndị nsọ ya
\q2 dị oke ọnụahịa nʼanya \nd Onyenwe anyị\nd*.
\q1 
\v 16 O \nd Onyenwe anyị\nd*, nʼezie, abụ m ohu gị;
\q2 abụ m ohu gị, nwa nwoke nke ohu gị nwanyị;
\q2 ị zọpụtala m site na agbụ e kere m.
\b
\q1 
\v 17 Aga m achụrụ gị aja ekele
\q2 kpọkuokwa aha \nd Onyenwe anyị\nd*.
\q1 
\v 18 Ọ bụkwa nʼihu ndị ya niile
\q2 ka m ga-anọ kwụghachi \nd Onyenwe anyị\nd* nkwa m kwere,
\q1 
\v 19 nʼime ogige ụlọ \nd Onyenwe anyị\nd*,
\q2 nʼetiti gị, O Jerusalem.
\b
\q1 Toonu \nd Onyenwe anyị\nd*.
\c 117
\cl Abụ Ọma 117
\s1 Too ya nʼihi ịhụnanya ya
\q1 
\v 1 Toonu \nd Onyenwe anyị\nd*, unu mba niile dị iche iche.
\q2 Jaakwa ya mma, unu ndị niile dị iche iche.
\q1 
\v 2 Nʼihi na ịhụnanya ya nʼebe anyị nọ dị ukwuu.
\q2 Ikwesi ntụkwasị obi \nd Onyenwe anyị\nd* na-adịkwa ruo mgbe ebighị ebi.
\b
\q1 Toonu \nd Onyenwe anyị\nd*!
\c 118
\cl Abụ Ọma 118
\s1 Kelee Onyenwe anyị
\q1 
\v 1 Keleenụ \nd Onyenwe anyị\nd* nʼihi na ọ dị mma;
\q2 ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\b
\q1 
\v 2 Ka ụmụ Izrel kwupụta nʼonwe ha sị,
\q2 “Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.”
\q1 
\v 3 Ka ndị ezinaụlọ Erọn kwuokwa sị,
\q2 “Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.”
\q1 
\v 4 Ka ndị niile na-atụ egwu \nd Onyenwe anyị\nd* kwuo sị,
\q2 “Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.”
\b
\q1 
\v 5 Nʼọnọdụ oke ihe mgbu m, akpọkuru m \nd Onyenwe anyị\nd*,
\q2 ọ zara m, mee ka m nwere onwe m.
\q1 
\v 6 \nd Onyenwe anyị\nd* nọnyeere m, agaghị m atụ egwu.
\q2 Gịnị ka mmadụ pụrụ ime m?
\q1 
\v 7 \nd Onyenwe anyị\nd* nọnyere m; ọ bụ onye na-enyere m aka.
\q2 Aga m ele ndị iro m anya na mmeri.
\b
\q1 
\v 8 Ọ kachasị mma ịgbaba nʼime \nd Onyenwe anyị\nd*
\q2 karịa ịtụkwasị ụmụ mmadụ obi.
\q1 
\v 9 Ọ kachasị mma ịgbaba nʼime \nd Onyenwe anyị\nd*
\q2 karịa ịtụkwasị ndị amara aha ha obi.
\q1 
\v 10 Mba niile gbara m gburugburu
\q2 ma site nʼaha \nd Onyenwe anyị\nd* aga m ala ha nʼiyi.
\q1 
\v 11 Ha gbara m gburugburu,
\q2 ma site nʼaha \nd Onyenwe anyị\nd* ka m na-egbuda ha.
\q1 
\v 12 Ha gbara m gburugburu dịka aṅụ,
\q2 ma e menyụọla ha dịka ogwu na-ere ọkụ;
\q2 site nʼaha \nd Onyenwe anyị\nd*, ka m na-egbuda ha.
\q1 
\v 13 Akwaghachiri m azụ, agaara m ada,
\q2 ma \nd Onyenwe anyị\nd* nyere m aka.
\q1 
\v 14 \nd Onyenwe anyị\nd* bụ ike m na abụ m;
\q2 ọ ghọọla nzọpụta m.
\b
\q1 
\v 15 Olu iti mkpu ọṅụ na mmeri
\q2 na-ada nʼime ụlọ ikwu ndị ezi omume:
\q1 “Aka nri \nd Onyenwe anyị\nd* emeela ọtụtụ ihe dị ukwuu!
\q2 
\v 16 Aka nri \nd Onyenwe anyị\nd* bụ ihe e weliri elu;
\q2 aka nri \nd Onyenwe anyị\nd* emeela ọtụtụ ihe dị ukwuu!”
\q1 
\v 17 Agaghị m anwụ,
\q2 kama aga m adị ndụ kwusaara ndị ọzọ ọrụ ebube \nd Onyenwe anyị\nd* rụrụ.
\q1 
\v 18 \nd Onyenwe anyị\nd* tara m ahụhụ nke ukwuu,
\q2 ma o nyefeeghị m nʼaka ọnwụ.
\q1 
\v 19 Megheere m ọnụ ụzọ ama nke ezi omume;
\q2 aga m abanye nye \nd Onyenwe anyị\nd* ekele.
\q1 
\v 20 Nke a bụ ọnụ ụzọ ụlọnsọ \nd Onyenwe anyị\nd*,
\q2 ebe ndị ezi omume ga-esite na ya banye.
\q1 
\v 21 Aga m enye gị ekele, nʼihi na ị zara m;
\q2 ị ghọọla nzọpụta m.
\b
\q1 
\v 22 Nkume ahụ ndị na-ewu ụlọ jụrụ,
\q2 aghọọla nkume isi ntọala\f + \fr 118:22 \ft Ya bụ, isi nkuku ụlọ\f* ụlọ;
\q1 
\v 23 nke a bụ ọrụ aka \nd Onyenwe anyị\nd*,
\q2 ọ bụkwa ihe ịtụnanya nʼanya anyị.
\q1 
\v 24 Nke a bụ ụbọchị \nd Onyenwe anyị\nd* anyị mere,
\q2 ka anyị ṅụrịa ọṅụ, nweekwa obi ụtọ nʼime ya.
\b
\q1 
\v 25 O \nd Onyenwe anyị\nd*, zọpụta anyị;
\q2 o \nd Onyenwe anyị\nd*, mee ka ihe gaara anyị nke ọma.
\b
\q1 
\v 26 Onye a gọziri agọzi ka onye ahụ bụ, nke na-abịa nʼaha \nd Onyenwe anyị\nd*.
\q2 Anyị sitere nʼụlọ \nd Onyenwe anyị\nd* na-agọzi gị.
\q1 
\v 27 \nd Onyenwe anyị\nd* bụ Chineke,
\q2 ọ bụ ya mere ka ìhè ya mụkwasị anyị.
\q1 Chịrị igu nkwụ nʼaka gị, soro ndị ji ọṅụ bata nʼogige Chineke
\q2 bịaruo nʼebe ịchụ aja.
\b
\q1 
\v 28 Ị bụ Chineke m, aga m eto gị;
\q2 ị bụ Chineke m, aga m ebuli gị elu.
\b
\q1 
\v 29 Keleenụ \nd Onyenwe anyị\nd* nʼihi na ọ dị mma,
\q2 ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\c 119
\cl Abụ Ọma 119
\qa א Alef
\q1 
\v 1 Ndị a gọziri agọzi ka ha bụ, bụ ndị ụzọ ha na-enweghị ihe ịta ụta ọbụla,
\q2 ndị na-ejegharị dịka iwu \nd Onyenwe anyị\nd* si dị.
\q1 
\v 2 Ndị a gọziri agọzi ka ha bụ, bụ ndị na-edebe ụkpụrụ ya
\q2 ma jirikwa obi ha niile na-achọsi ya ike.
\q1 
\v 3 Ha adịghị eme ihe ọjọọ ọbụla;
\q2 ha na-ejegharị nʼụzọ ya niile.
\q1 
\v 4 I doola ụkpụrụ
\q2 ndị a ga-erubekwara isi.
\q1 
\v 5 Ọ ga-adị m mma ma ọ bụrụ na m anọgidesie ike
\q2 na-erube isi nye iwu gị niile!
\q1 
\v 6 Mgbe ahụ, ihere agaghị eme m
\q2 mgbe m tulere uche nʼiwu gị niile.
\q1 
\v 7 Aga m eji obi ziri ezi too gị
\q2 dịka m na-amụ ihe banyere iwu gị ziri ezi.
\q1 
\v 8 Aga m erubere iwu gị niile isi;
\q2 biko ahapụkwala m.
\qa ב Bet
\q1 
\v 9 Olee ụzọ nwa okorobịa ga-esi bie ndụ dị nsọ?
\q2 Ọ bụ site nʼibi ndụ dịka okwu gị si dị.
\q1 
\v 10 Eji m obi m niile na-achọsi gị ike.
\q2 Ekwela ka m kpafuo site nʼihe niile i nyere nʼiwu.
\q1 
\v 11 Ezoola m okwu gị niile nʼobi m,
\q2 igbochi m imehie imegide gị.
\q1 
\v 12 Otuto dịrị gị, o \nd Onyenwe anyị\nd*;
\q2 kuziere m iwu gị niile.
\q1 
\v 13 Aga m eji egbugbere ọnụ m gụgharịa
\q2 iwu niile nke si nʼọnụ gị.
\q1 
\v 14 Ana m aṅụrị ọṅụ nʼịgbaso iwu gị niile
\q2 dịka mmadụ si aṅụrị ọṅụ nʼime oke ịba ụba.
\q1 
\v 15 Ana m atụgharị uche nʼụkpụrụ gị
\q2 na-atulekwa uche nʼụzọ gị niile.
\q1 
\v 16 Iwu gị na-amasị m;
\q2 agaghị m elefu okwu gị anya.
\qa ג Gimel
\q1 
\v 17 Meere ohu gị ihe ọma, ka m nwe ike dị ndụ;
\q2 aga m erubere okwu gị isi.
\q1 
\v 18 Kpughee anya m abụọ
\q2 ka m hụ oke ihe ebube niile dị iche iche dị nʼime okwu gị.
\q1 
\v 19 Abụ m onye ọbịa nʼelu ụwa;
\q2 ezonarịla m iwu gị niile.
\q1 
\v 20 Nʼoge niile, ihe banyere iwu gị niile
\q2 na-agụ mkpụrụobi m agụụ.
\q1 
\v 21 Ị na-abara ndị mpako mba, ha bụ ndị a bụrụ ọnụ
\q2 na ndị na-anaghị agbaso iwu gị.
\q1 
\v 22 Site nʼebe m nọ wepụ ịchị ọchị na nlelị,
\q2 nʼihi na m na-edebe ụkpụrụ gị niile.
\q1 
\v 23 Nʼagbanyeghị na ndịisi nọkọrọ na-ekwulu m,
\q2 ohu gị ga-atụgharị uche nʼiwu gị.
\q1 
\v 24 Ụkpụrụ gị niile bụ ihe na-amasị m;
\q2 ha bụ ndị ndụmọdụ m.
\qa ד Dalet
\q1 
\v 25 Mkpụrụobi m na-arapara nʼuzuzu;
\q2 kpọghachite ndụ m dịka okwu gị si dị.
\q1 
\v 26 Akọwaara m gị ụzọ m niile, ị zakwara m;
\q2 ugbu a, kuziere m iwu gị.
\q1 
\v 27 Mee ka m ghọta ozizi ụkpụrụ gị;
\q2 ka m nwe ike tụgharịa uche nʼọrụ ebube gị niile.
\q1 
\v 28 Iru ụjụ emeela ka mkpụrụobi m daa mba;
\q2 gbaa m ume dịka okwu gị si dị.
\q1 
\v 29 Chebe m pụọ nʼụzọ aghụghọ niile;
\q2 site nʼiwu gị meere m amara.
\q1 
\v 30 Ahọrọla m ụzọ ikwesi ntụkwasị obi;
\q2 e kpebiela m idebe obi m nʼiwu gị niile.
\q1 
\v 31 O \nd Onyenwe anyị\nd*, ana m ejigidesi iwu gị niile aka ike;
\q2 ekwela ka ihere mee m.
\q1 
\v 32 Aga m agbaso iwu gị niile
\q2 nʼihi na i meela ka obi m nwere onwe ya.
\qa ה He
\q1 
\v 33 O \nd Onyenwe anyị\nd*, zi m ụzọ m ga-esi gbasoo iwu gị niile;
\q2 mgbe ahụ, aga m edebe ha ruo nʼọgwụgwụ.
\q1 
\v 34 Nye m nghọta, aga m edebe iwu gị
\q2 ma jiri obi m niile rubere ya isi.
\q1 
\v 35 Duo m nʼụzọ nke iwu gị niile,
\q2 nʼihi na ọ bụ nʼime ha ka m na-achọta obi ụtọ.
\q1 
\v 36 Mee ka obi m chee ihu nʼiwu gị niile
\q2 ọ bụghị nye uru na-esite nʼọchịchọ nke onwe.
\q1 
\v 37 Wepụ anya m site nʼihe na-abaghị uru;
\q2 chebe ndụ m dịka okwu gị si dị.\f + \fr 119:37 \ft Mee ka m dị ndụ nʼụzọ gị\f*
\q1 
\v 38 Mezuo nkwa i kwere ohu gị,
\q2 ka a tụọ egwu gị.
\q1 
\v 39 Wepụ nkọcha nke m na-atụ egwu ya,
\q2 nʼihi na iwu gị niile ziri ezi.
\q1 
\v 40 Ụkpụrụ gị na-agụsị m agụụ ike!
\q2 Chebe ndụ m site nʼezi omume gị.
\qa ו Waw
\q1 
\v 41 O \nd Onyenwe anyị\nd*, ka ịhụnanya gị nke na-adịgide bịakwasị m,
\q2 nzọpụta gị dịka nkwa i kwere si dị;
\q1 
\v 42 mgbe ahụ, aga m azaghachi onye ahụ na-achị m ọchị,
\q2 nʼihi na ana m atụkwasị obi m nʼokwu gị.
\q1 
\v 43 Esitela nʼọnụ m napụ okwu nke eziokwu,
\q2 nʼihi na olileanya m dị nʼiwu gị niile.
\q1 
\v 44 Aga m anọgide na-erubere iwu gị isi
\q2 ruo mgbe ebighị ebi.
\q1 
\v 45 Aga m ejegharị nʼọnọdụ inwere onwe
\q2 nʼihi na achọpụtala m ụkpụrụ gị niile.
\q1 
\v 46 Aga m ekwupụta banyere ụkpụrụ gị nʼihu ndị eze
\q2 ma ihere agaghị eme m,
\q1 
\v 47 nʼihi na iwu gị na-amasị m
\q2 nʼihi na ahụrụ m ha nʼanya.
\q1 
\v 48 Ana m eweliri iwu gị niile aka elu, bụ ndị m hụrụ nʼanya,
\q2 ana m atụgharịkwa uche nʼiwu gị niile.
\qa ז Zayin
\q1 
\v 49 Cheta okwu i nyere ohu gị,
\q2 nʼihi na i nyela m olileanya.
\q1 
\v 50 Nkasiobi m nʼime ịta ahụhụ m bụ nke a:
\q2 nkwa gị na-echebe ndụ m.
\q1 
\v 51 Ndị mpako na-akwa m emo na-esepụghị aka,
\q2 ma anaghị m esite nʼiwu gị wezuga onwe m.
\q1 
\v 52 O \nd Onyenwe anyị\nd*, ana m echeta iwu gị niile, ndị dị site na mgbe ochie,
\q2 ha na-ewetara m nkasiobi.
\q1 
\v 53 Ana m ewe iwe nke ukwu nʼihi ndị ajọ omume,
\q2 ndị gbakụtara iwu gị azụ.
\q1 
\v 54 Iwu gị niile bụ isi okwu abụ m
\q2 ebe ọbụla m na-anọ.
\q1 
\v 55 Nʼabalị, o \nd Onyenwe anyị\nd*, ana m echeta aha gị,
\q2 aga m edebekwa iwu gị.
\q1 
\v 56 Nke a bụrịị ihe m na-eme oge niile:
\q2 ana m erubere ụkpụrụ gị isi.
\qa ח Het
\q1 
\v 57 O \nd Onyenwe anyị\nd*, ị bụ ihe nketa m;
\q2 ekweela m nkwa irube isi nye okwu gị niile.
\q1 
\v 58 Ejirila m obi m niile chọọ ihu gị;
\q2 meere m ebere dịka nkwa gị si dị.
\q1 
\v 59 Echeela m echiche banyere ụzọ m niile,
\q2 chigharịakwa na-agbaso ụkpụrụ gị niile.
\q1 
\v 60 Aga m eme ngwangwa, agaghị atụfu oge
\q2 irubere iwu gị niile isi.
\q1 
\v 61 A sịkwarị na ndị ajọ omume ejiri ụdọ kee m agbụ,
\q2 agaghị m echefu iwu gị.
\q1 
\v 62 Nʼetiti abalị, aga m ebili nye gị ekele
\q2 nʼihi iwu gị niile ziri ezi.\f + \fr 119:62 \ft \xt Ọrụ 16:25\xt*\f*
\q1 
\v 63 Abụ m enyi ndị niile na-atụ egwu gị,
\q2 ndị niile na-agbaso ụkpụrụ gị.
\q1 
\v 64 O \nd Onyenwe anyị\nd*, ụwa niile jupụtara nʼịhụnanya gị;
\q2 kuziere m iwu gị niile.
\qa ט Tet
\q1 
\v 65 Meere ohu gị ihe ọma
\q2 dịka okwu gị si dị, o \nd Onyenwe anyị\nd*.
\q1 
\v 66 Zi m ihe ọmụma na ikpe ziri ezi
\q2 nʼihi na ekwenyere m nʼiwu gị niile.
\q1 
\v 67 Tupu m nwee nsogbu, a kpafuru m,
\q2 ma ugbu a, ana m erubere okwu gị isi.
\q1 
\v 68 I dị mma, ihe i na-eme ziri ezi;
\q2 kuziere m iwu gị niile.
\q1 
\v 69 Nʼagbanyeghị na ndị mpako a gbasaala okwu ụgha techie m,
\q2 ana m eji obi m niile na-edebe ụkpụrụ gị.
\q1 
\v 70 Obi ha siri ike, ọ dịghị ihe na-emetụta ha,
\q2 ma ana m enwe mmasị nʼiwu gị.
\q1 
\v 71 Ọ dị mma na m tara ahụhụ
\q2 ka m nwee ike mụta iwu gị niile.
\q1 
\v 72 Iwu si nʼọnụ gị pụta dị oke ọnụahịa nye m
\q2 karịa imerime puku ọlaọcha na ọlaedo.
\qa י Yod
\q1 
\v 73 Aka gị kere m, kpụọkwa m;
\q2 nye m nghọta ka m mụta iwu gị niile.
\q1 
\v 74 Ka ndị na-atụ egwu gị ṅụrịa mgbe ha hụrụ m,
\q2 nʼihi na olileanya m dị nʼokwu gị.
\q1 
\v 75 O \nd Onyenwe anyị\nd*, amaara m na iwu gị niile ziri ezi,
\q2 ọ bụkwa nʼikwesị ntụkwasị obi ka ị tara m ahụhụ.
\q1 
\v 76 Ka ịhụnanya gị nke na-adịghị agwụ agwụ kasịe m obi,
\q2 dịka nkwa i kwere ohu gị si dị.
\q1 
\v 77 Ka ọmịiko gị bịakwasị m, ka m nwee ike dị ndụ,
\q2 nʼihi na iwu gị na-amasị m.
\q1 
\v 78 Ka ihere mee ndị mpako nʼihi ihe ọjọọ ha mere m na-enweghị ihe m mere;
\q2 ma aga m atụgharị uche nʼụkpụrụ gị.
\q1 
\v 79 Ka ndị niile na-atụ egwu gị bịakwute m,
\q2 ndị na-aghọta ụkpụrụ gị niile.
\q1 
\v 80 Ka m were obi zuruoke na-agbaso ụkpụrụ gị niile,
\q2 ka ihere ghara ime m.
\qa כ Kap
\q1 
\v 81 Mkpụrụobi m na-ada mba site nʼọchịchọ ya maka nzọpụta gị,
\q2 ma olileanya m dị nʼokwu gị.
\q1 
\v 82 Anya na-egbu m mgbu ebe m na-ele anya nkwa gị;
\q2 ana m asị, “Olee mgbe ị ga-akasị m obi?”
\q1 
\v 83 Nʼagbanyeghị na adị m ka karama akpụkpọ\f + \fr 119:83 \ft Ọ bụ ihe eji agbanye mmanya, nʼelu ekwu isi nri a kwanyere ọkụ ka a na-ekonye karama akpụkpọ anụ a gbanyere mmanye ọhụrụ. Nke a bụ iji mee ka mmanya ahụ nwee ike gbaa ụka ọsịịsọ. Nʼihi na-edebere ya nʼọkụ, akpụkpọ anụ ahụ na-akpọ nku, taa ahụ, dị ochie, bụrụkwa ihe na-abaghị uru ọzọ na ihe a na-atụfu atụfu.\f* nke dị nʼanwụrụ ọkụ,
\q2 anaghị m echefu iwu gị niile.
\q1 
\v 84 Ruo olee mgbe ka ohu gị ga-anọgide na-eche?
\q2 Olee mgbe ka ị ga-ata ndị na-akpagbu m ahụhụ?
\q1 
\v 85 Ndị mpako na-egwuru m olulu,
\q2 bụ ihe nke na-adịghị ka iwu gị si dị.
\q1 
\v 86 Iwu gị niile kwesiri ntụkwasị obi;
\q2 nyere m aka, nʼihi na ndị mmadụ na-akpagbu m ma o nweghị ihe m mere ha.
\q1 
\v 87 Ọ fọdụrụ ntakịrị ihe, ha gaara ala m nʼiyi,
\q2 ma agbakụtaghị m ụkpụrụ gị azụ.
\q1 
\v 88 Site nʼịhụnanya gị nke na-adịgide chebe ndụ m,
\q2 ka m nwe ike rube isi nʼiwu nke ọnụ gị.
\qa ל Lamed
\q1 
\v 89 O \nd Onyenwe anyị\nd*, okwu gị na-adịgide ruo mgbe ebighị ebi;\f + \fr 119:89 \ft \xt Aịz 40:8; Mat 24:35; 1Pt 1:25\xt*\f*
\q2 ọ na-eguzosi ike nʼeluigwe.
\q1 
\v 90 Ikwesi ntụkwasị obi gị na-adịgide site nʼọgbọ ruo nʼọgbọ;
\q2 ọ bụ gị kere ụwa, ọ na-eguzosikwa ike.
\q1 
\v 91 Ruo taa, iwu gị niile na-eguzosi ike,
\q2 nʼihi na ihe niile na-ejere gị ozi.
\q1 
\v 92 A sịkwarị na iwu gị anaghị amasị m,
\q2 agaara m anwụ nʼime nsogbu m.
\q1 
\v 93 Agaghị m echefu ụkpụrụ gị niile,
\q2 nʼihi na ọ bụ ha ka i ji chebe ndụ m.
\q1 
\v 94 Zọpụta m, nʼihi na abụ m nke gị;
\q2 achọpụtala m ụkpụrụ gị niile.
\q1 
\v 95 Ndị ajọ omume na-eche ịla m nʼiyi,
\q2 ma aga m atụgharị uche nʼụkpụrụ gị.
\q1 
\v 96 Ana m ahụ nsọtụ ihe niile zuruoke,
\q2 ma iwu gị niile enweghị nsọtụ.
\qa מ Mem
\q1 
\v 97 O, otu m si hụ iwu gị nʼanya!
\q2 Ana m atụgharị uche na ya ogologo ụbọchị niile.
\q1 
\v 98 Iwu gị na-eme ka amamihe m karịa nke ndị iro m,
\q2 ha na-anọnyere m oge niile.
\q1 
\v 99 Enwere m nghọta karịa ndị na-ezi m ihe,
\q2 nʼihi na ana m atụgharịa uche nʼiwu gị niile.
\q1 
\v 100 Enwere m nghọta karịa ndị okenye
\q2 nʼihi na ana m erubere ụkpụrụ gị niile isi.
\q1 
\v 101 Ajụrụ m ajụ ije ije nʼụzọ ọjọọ ọbụla
\q2 ka m nwee ike rubere okwu gị isi
\q1 
\v 102 Ewezugaghị m onwe m nʼiwu gị niile,
\q2 nʼihi na ọ bụ gị onwe gị ziri m ha.
\q1 
\v 103 Lee ka okwu gị niile si atọ m ụtọ,
\q2 ha dị ụtọ nʼọnụ m karịa mmanụ aṅụ!
\q1 
\v 104 A na-enweta nghọta site nʼụkpụrụ gị niile;
\q2 ya mere ana m akpọ ụzọ ọjọọ ọbụla asị.
\qa נ Nun
\q1 
\v 105 Okwu gị bụ oriọna dịrị ụkwụ m
\q2 bụrụkwa ìhè nʼụzọ m.
\q1 
\v 106 Aṅụọla m iyi, mee ka o guzosie ike,
\q2 na aga m agbaso iwu ezi omume gị niile.
\q1 
\v 107 Ataala m ahụhụ nke ukwuu;
\q2 chebe ndụ m, o \nd Onyenwe anyị\nd*, dịka okwu gị si dị.
\q1 
\v 108 O \nd Onyenwe anyị\nd*, nabata otuto afọ ofufu niile nke si nʼọnụ m,
\q2 kuziekwara m iwu gị niile.
\q1 
\v 109 Mkpụrụobi m na-adị m nʼọbụaka m oge niile,
\q2 ma echezọghị m iwu gị.
\q1 
\v 110 Ndị ajọ omume esielera m ọnya,
\q2 ma esitebeghị m nʼụkpụrụ gị kpafuo.
\q1 
\v 111 Iwu gị niile bụ ihe nketa m ruo mgbe ebighị ebi;
\q2 ha bụ ihe na-enye obi m ọṅụ.
\q1 
\v 112 Obi m ekpebiela idebe ụkpụrụ gị
\q2 ruo na ngwụcha.
\qa ס Samek
\q1 
\v 113 Ana m akpọ ndị na-enwe obi abụọ asị,
\q2 ma ahụrụ m iwu gị nʼanya.
\q1 
\v 114 Ị bụ ebe mgbaba m na ọta m;
\q2 olileanya m dị nʼokwu gị.
\q1 
\v 115 Sitenụ nʼebe m nọ pụọ, unu ndị na-eme ihe ọjọọ,
\q2 ka m nwee ike idebe iwu niile nke Chineke m!
\q1 
\v 116 Gbaa m ume dịka nkwa gị si dị, aga m adịkwa ndụ;
\q2 ekwekwala ka olileanya m daa.
\q1 
\v 117 Kwagide m, aga m abụ onye a gbapụtara;
\q2 aga m anọgide na-asọpụrụ iwu gị niile.
\q1 
\v 118 Ị na-ajụ ndị niile na-adịghị edebe iwu gị,
\q2 nzube aghụghọ ha niile bụ ihe na-enweghị isi.
\q1 
\v 119 Ị na-ekpochapụ ndị ajọ omume dịka unyi a na-ekpofu ekpofu;
\q2 nʼihi ya, ahụrụ m ụkpụrụ gị niile nʼanya.
\q1 
\v 120 Anụ ahụ m na-ama jijiji nʼihi ịtụ egwu gị;
\q2 ana m eguzo nʼoke egwu nʼihi iwu gị niile.
\qa ע Ayin
\q1 
\v 121 Emeela m ihe dị mma na ihe ziri ezi;
\q2 ahapụkwala m nʼaka ndị na-emegbu m.
\q1 
\v 122 Kwee ohu gị nkwa na ị ga-elekọta ya;
\q2 ekwela ka ndị mpako kpagbuo m.
\q1 
\v 123 Anya na-egbu m mgbu ebe m na-ele anya nzọpụta gị
\q2 ebe m na-ele anya nkwa gị ziri ezi.
\q1 
\v 124 Biko mesoo ohu gị mmeso dịka ịhụnanya gị si dị
\q2 ma kuziekwara m ụkpụrụ gị niile.
\q1 
\v 125 Abụ m ohu gị, nye m nghọta,
\q2 ka m nwee ike mara ụkpụrụ gị niile.
\q1 
\v 126 O \nd Onyenwe anyị\nd*, oge eruola mgbe ị ga-arụ ọrụ,
\q2 nʼihi na a na-emebi iwu gị.
\q1 
\v 127 Nʼihi na ahụrụ m iwu gị niile nʼanya
\q2 karịa ọlaedo, e karịa ọlaedo a nụchara anụcha,
\q1 
\v 128 nʼihi na m na-ahụta ụkpụrụ gị niile ka ihe ziri ezi,
\q2 akpọrọ m ụzọ niile na-ezighị ezi asị.
\qa פ Pe
\q1 
\v 129 Iwu gị niile dị ịtụnanya;
\q2 ya mere, ana m erubere ha isi.
\q1 
\v 130 Mkpughepụ na nkọwa nke okwu gị na-enye ìhè;
\q2 ọ na-eme ka ndị na-enweghị uche ghọta ihe.
\q1 
\v 131 Ana m asaghe ọnụ m na-ekupụ ume ike ike,
\q2 na-achọsi iwu gị niile ike.
\q1 
\v 132 Chee m ihu, meere m ebere,
\q2 dịka i si emere ndị niile hụrụ aha gị nʼanya ebere.
\q1 
\v 133 Mee ka nzọ ụkwụ m niile na-aga dịka okwu gị si dị;
\q2 ekwela ka mmehie chịa m.
\q1 
\v 134 Gbapụta m site nʼaka ndị na-emegbu m,
\q2 ka m nwee ike debe iwu gị.
\q1 
\v 135 Mee ka ihuọma gị dịkwasị nʼahụ ohu gị.
\q2 Kuziere m ụkpụrụ gị niile.
\q1 
\v 136 Anya mmiri akwa na-agba m nke ukwuu
\q2 nʼihi na ndị mmadụ adịghị erube isi nye iwu gị.
\qa צ Tsade
\q1 
\v 137 O \nd Onyenwe anyị\nd*, ị bụ onye ezi omume,
\q2 iwu gị niile zikwara ezi.
\q1 
\v 138 Ụkpụrụ gị niile ziri ezi;
\q2 ha kwesiri ntụkwasị obi.
\q1 
\v 139 Nʼihi na ndị iro m na-elefu okwu gị anya,
\q2 ịnụ ọkụ nʼobi m na-ada mba.
\q1 
\v 140 Nkwa gị niile bụ ihe enyochara nke ọma,
\q2 ohu gị na-ahụkwa ha nʼanya.
\q1 
\v 141 Ọ bụ ezie na m bụ onye dị ala, na onye a na-eleda anya,
\q2 ma adịghị m eleda ụkpụrụ gị niile anya.
\q1 
\v 142 Ezi omume gị na-adị ruo mgbe ebighị ebi.
\q2 Iwu gị niile bụkwa eziokwu.
\q1 
\v 143 Nsogbu na ihe mgbu adakwasịla m,
\q2 ma iwu gị niile bụ ihe na-amasị m.
\q1 
\v 144 Iwu gị niile bụ ezi omume ruo mgbe ebighị ebi;
\q2 nye m nghọta, ka m nwe ike dị ndụ.
\qa ק Kwof
\q1 
\v 145 Eji m obi m niile na-akpọ oku; zaa m o \nd Onyenwe anyị\nd*,
\q2 aga m erubekwa isi nye ụkpụrụ gị niile.
\q1 
\v 146 Ana m akpọku gị; zọpụta m
\q2 aga m erube isi nye ụkpụrụ gị niile.
\q1 
\v 147 Tupu chị na-abọ, ana m ebili, na-akwa akwa maka enyemaka;
\q2 olileanya m dị nʼokwu gị.
\q1 
\v 148 Ana m amụ anya abalị nʼelu ihe ndina m,
\q2 nʼihi ịtụgharị uche na nkwa gị niile.
\q1 
\v 149 Nụrụ olu m dịka ịhụnanya gị si dị;
\q2 chebe ndụ m, o \nd Onyenwe anyị\nd*, dịka iwu gị niile si dị.
\q1 
\v 150 Ndị na-atụpụta atụmatụ ọjọọ nọ nso
\q2 ma ha nọ iwu gị niile nʼebe dị anya.
\q1 
\v 151 Ma ị nọ nso, \nd Onyenwe anyị\nd*;
\q2 ihe niile i nyere nʼiwu bụ eziokwu.
\q1 
\v 152 Site na mgbe ochie ka m mụtara site nʼụkpụrụ gị,
\q2 na i mere ka ha guzosie ike ruo mgbe ebighị ebi.
\qa ר Resh
\q1 
\v 153 Ledata anya ka ị hụ ịta ahụhụ m ma gbapụta m,
\q2 nʼihi na echefughị m iwu gị.
\q1 
\v 154 Kpepụta m, gbapụta m,
\q2 chebe ndụ m dịka nkwa gị si dị.
\q1 
\v 155 Nzọpụta dị anya nʼebe ndị na-eme ihe ọjọọ nọ,
\q2 nʼihi na ha anaghị agbaso ụkpụrụ gị niile.
\q1 
\v 156 O \nd Onyenwe anyị\nd*, ọmịiko gị dị ukwuu;
\q2 chebe ndụ m dịka iwu gị niile si dị.
\q1 
\v 157 Ndị iro m na ndị na-akpagbu m dị ọtụtụ,
\q2 ma aga m anọgide na-edebe iwu gị.
\q1 
\v 158 Ana m asọ ndị niile na-enweghị okwukwe nʼime gị oyi,
\q2 nʼihi na ha anaghị erubere okwu gị isi.
\q1 
\v 159 Lee ka m si hụ ụkpụrụ gị niile nʼanya;
\q2 chebe ndụ m, o \nd Onyenwe anyị\nd*, dịka ịhụnanya gị si dị.
\q1 
\v 160 Okwu gị niile bụ eziokwu;
\q2 iwu gị niile ziri ezi na-adịgide ruo mgbe ebighị ebi.
\qa ש Sin na Shin
\q1 
\v 161 Ndịisi na-emegbu m na-enweghị ihe m mere,
\q2 ma obi m na-ama jijiji nʼihi okwu gị.
\q1 
\v 162 Ana m aṅụrị ọṅụ nʼime nkwa gị
\q2 dịka onye chọtara ọtụtụ ihe nkwata nʼagha.
\q1 
\v 163 Akpọrọ m okwu ụgha asị, ọ bụkwa ihe arụ nʼebe m nọ,
\q2 ma ahụrụ m iwu gị nʼanya.
\q1 
\v 164 Aga m eto gị ugboro asaa nʼụbọchị,
\q2 nʼihi iwu gị ziri ezi.
\q1 
\v 165 Ndị hụrụ iwu gị nʼanya nwere udo dị ukwuu,
\q2 ọ dịghị ihe ga-eme ka ha sụọ ngọngọ.
\q1 
\v 166 Ana m echere nzọpụta gị, o \nd Onyenwe anyị\nd*,
\q2 na-agbasokwa iwu gị niile.
\q1 
\v 167 Ana m erubere ụkpụrụ gị niile isi
\q2 nʼihi na m hụrụ ha nʼanya nke ukwuu.
\q1 
\v 168 Ana m erubere ụkpụrụ na iwu gị niile isi,
\q2 nʼihi na ị maara ụzọ m niile.
\qa ת Taw
\q1 
\v 169 Ka akwa m ruo gị ntị, o \nd Onyenwe anyị\nd*;
\q2 nye m nghọta dịka okwu gị si dị.
\q1 
\v 170 Ka arịrịọ m ruo gị ntị;
\q2 gbapụta m dịka nkwa gị si dị.
\q1 
\v 171 Ka ọnụ m jupụta nʼotuto,
\q2 nʼihi na ị na-ezi m iwu gị niile.
\q1 
\v 172 Ka m jiri ire m bụọ abụ banyere okwu gị,
\q2 nʼihi na iwu gị niile ziri ezi.
\q1 
\v 173 Nọọ na njikere oge niile inyere m aka,
\q2 nʼihi na ahọrọla m ụkpụrụ gị niile.
\q1 
\v 174 Ana m ele anya nzọpụta gị, o \nd Onyenwe anyị\nd*,
\q2 iwu gị bụ ihe na-amasị m.
\q1 
\v 175 Kwere ka m dịrị ndụ ka m nwee ike ito gị,
\q2 ka iwu gị niile gbaa m ume.
\q1 
\v 176 Akpafuola m dịka atụrụ nke furu efu,
\q2 chọọ ohu gị,
\q2 nʼihi na echefubeghị m iwu gị niile.
\c 120
\cl Abụ Ọma 120
\d Abụ nrigo.
\s1 Ekpere maka nnapụta
\q1 
\v 1 Ana m akpọku \nd Onyenwe anyị\nd* nʼime nsogbu m,
\q2 ọ na-azakwa m.
\q1 
\v 2 O \nd Onyenwe anyị\nd*, zọpụta m
\q2 site nʼegbugbere ọnụ okwu ụgha
\q2 na ire na-ekwu okwu aghụghọ.
\b
\q1 
\v 3 Gịnị ka a ga-eme gị,
\q2 ọ bụkwa gịnị ọzọ ka a gatụkwasịri gị,
\q2 gị ire aghụghọ?
\q1 
\v 4 Ọ ga-eji àkụ dị nkọ nke dike nʼagha taa gị ahụhụ,
\q2 ya na icheku ọkụ osisi brum na-ere ere.
\b
\q1 
\v 5 Ahụhụ dịịrị m nʼihi na m bi na Meshek,
\q2 nʼihi na m bikwa nʼetiti ụlọ ikwu ndị Keda!
\q1 
\v 6 Ogologo oge
\q2 ka m binyere ndị kpọrọ udo asị.
\q1 
\v 7 Abụ m onye udo;
\q2 ma mgbe m kwuru okwu, okwu ha bụ okwu agha.
\c 121
\cl Abụ Ọma 121
\d Abụ nrigo.
\s1 Inyeaka si nʼebe Onyenwe anyị nọ
\q1 
\v 1 Aga m eweli anya m abụọ elu, lee ha nʼelu ugwu niile,
\q2 olee ebe inyeaka ga-esi bịara m?
\q1 
\v 2 Inyeaka m na-esite nʼaka \nd Onyenwe anyị\nd*,\f + \fr 121:2 \ft \xt Abụ 124:8\xt*\f*
\q2 onye kere eluigwe na ụwa bịa.
\b
\q1 
\v 3 Ọ gaghị ekwe ka ụkwụ gị gbụchapụ,
\q2 onye na-eche gị nche na-amụ anya oge niile;
\q1 
\v 4 nʼezie onye na-eche Izrel nche
\q2 adịghị arahụ ụra, ọ dịghị atụkwa oru ụra.
\b
\q1 
\v 5 \nd Onyenwe anyị\nd* na-eche gị nche,
\q2 \nd Onyenwe anyị\nd* bụ ndo\f + \fr 121:5 \ft \xt Aịz 25:4\xt*\f* gị nʼaka nri gị;
\q1 
\v 6 anyanwụ agaghị achagbu gị nʼehihie,
\q2 ọnwa agaghị etigbukwa gị nʼabalị.
\b
\q1 
\v 7 \nd Onyenwe anyị\nd* ga-edebe gị ka ihe ọjọọ ọbụla ghara ịdakwasị gị.
\q2 Ọ ga na-eche ndụ gị nche mgbe niile.
\q1 
\v 8 \nd Onyenwe anyị\nd* ga-echebe gị mgbe ị na-apụ na mgbe ị na-abata abata,
\q2 site ugbu a ruo mgbe niile ebighị ebi.
\c 122
\cl Abụ Ọma 122
\d Abụ nrigo, nke Devid.
\s1 Ekpere maka udo Jerusalem
\q1 
\v 1 Aṅụrịrị m ọṅụ mgbe ha sị m,
\q2 “Ka anyị gaa nʼụlọnsọ \nd Onyenwe anyị\nd*.”\f + \fr 122:1 \ft \xt Aịz 2:3; Mai 4:2; Zek 8:21\xt*\f*
\q1 
\v 2 Ụkwụ anyị eguzola ugbu a
\q2 nʼọnụ ụzọ ama gị niile, gị obodo Jerusalem.
\b
\q1 
\v 3 E wuru Jerusalem dịka obodo
\q2 a chịkọtara ọnụ nke ọma.
\q1 
\v 4 Ọ bụ ebe ahụ ka ebo niile na-arịgo,
\q2 bụ ebo niile nke \nd Onyenwe anyị\nd*,
\q1 ịbụku aha \nd Onyenwe anyị\nd* abụ
\q2 dịka iwu o nyere ndị Izrel si dị.
\q1 
\v 5 Nʼebe ahụ ka ocheeze niile nke ikpe ikpe dị,
\q2 bụ ocheeze niile nke ezinaụlọ Devid.
\b
\q1 
\v 6 Kpeenụ ekpere maka udo Jerusalem:
\q2 “Ka ndị niile hụrụ gị nʼanya nọọ nʼudo.
\q1 
\v 7 Ka udo dịrị nʼime mgbidi gị niile
\q2 nchekwa dịrịkwa nʼime ebe nche gị niile e wusiri ike.”
\q1 
\v 8 Nʼihi ụmụnne m na ndị enyi m,
\q2 ana m ekwu okwu sị, “Udo dịrị gị.”
\q1 
\v 9 Nʼihi ụlọ \nd Onyenwe anyị\nd*, Chineke anyị,
\q2 aga m achọ ọganihu gị.
\c 123
\cl Abụ Ọma 123
\d Abụ nrigo.
\s1 Ekpere maka ebere
\q1 
\v 1 Ana m eweli anya m abụọ elu ile gị,
\q2 gị onye ocheeze ya dị nʼeluigwe.
\q1 
\v 2 Dịka ohu si elekwasị nna ya ukwu anya ya,
\q2 na dịka ohu nwanyị na-eje ozi si elekwasị nne ya ukwu anya, ịnata ozi ọ ga-eje,\f + \fr 123:2 \ft Nʼoge ochie, ndị nwere ohu adịghị e kwuru ha okwu mgbe a na-ezi ha ozi, kama ọ bụ aka ka nne ha ukwu maọbụ nna ha ukwu ji agwa ha ihe ha kwesiri ime.\f*
\q1 otu a ka anyị si na-elekwasị \nd Onyenwe anyị\nd* bụ Chineke anyị anya,
\q2 ruo mgbe ọ ga-emere anyị ebere.
\b
\q1 
\v 3 Meere anyị ebere, O \nd Onyenwe anyị\nd*, meere anyị ebere,
\q2 nʼihi na anyị abụrụla ndị a na-akọcha akọcha.
\q1 
\v 4 Nʼihi na nnagide anyị na-anagide
\q2 ịchị ọchị ndị nganga,
\q2 na ileda anya ndị mpako adịla ukwuu.
\c 124
\cl Abụ Ọma 124
\d Abụ nrigo. Nke Devid.
\s1 Ekele maka mgbapụta
\q1 
\v 1 A sị na \nd Onyenwe anyị\nd* adịnyereghị anyị,
\q2 ka Izrel kwuo,
\q1 
\v 2 a sị na \nd Onyenwe anyị\nd* adịnyereghị anyị,
\q2 mgbe ndị mmadụ biliri imegide anyị,
\q1 
\v 3 mgbe iwe ha rere dịka ọkụ megide anyị,
\q2 ha gaara eloda anyị na ndụ;
\q1 
\v 4 idee mmiri gaara iri anyị,
\q2 oke mmiri gaara ebufu anyị,
\q1 
\v 5 ebili mmiri niile
\q2 gaara ebufu anyị.
\b
\q1 
\v 6 Ma otuto dịrị \nd Onyenwe anyị\nd*, onye na-ekweghị
\q2 ka ha jiri eze ha dọrie anyị.
\q1 
\v 7 Anyị agbanarịla ha dịka nwa nnụnụ si
\q2 gbanarị ọnya osi ọnya chọrọ iji jide ya;
\q1 ọnya ahụ agbajiela,
\q2 anyị ewezugakwala onwe anyị, nwere onwe anyị.
\q1 
\v 8 Inyeaka anyị dị nʼaha \nd Onyenwe anyị\nd*,
\q2 onye kere eluigwe na ụwa.
\c 125
\cl Abụ Ọma 125
\d Abụ nrigo.
\s1 Chineke onye na-echebe ndị ya
\q1 
\v 1 Ndị niile na-atụkwasị \nd Onyenwe anyị\nd* obi na-anọgidesi ike dị ka ugwu Zayọn
\q2 nke a na-apụghị inugharị, nke na-adịgidekwa nʼọnọdụ ya ruo mgbe ebighị ebi.
\q1 
\v 2 Dịka ugwu niile si gbaa obodo Jerusalem gburugburu,
\q2 otu a ka \nd Onyenwe anyị\nd* na-agba ndị ya gburugburu
\q2 ugbu a na ruo mgbe ebighị ebi.
\b
\q1 
\v 3 Mkpara ọchịchị ndị ajọ omume agaghị adịgide\f + \fr 125:3 \ft \xt Aịz 14:5\xt*\f*
\q2 nʼala ndị ezi omume ketara nʼife nza,
\q1 nʼihi na ndị ezi omume nwere ike
\q2 itinye aka ha na-ime ihe ọjọọ.
\b
\q1 
\v 4 O \nd Onyenwe anyị\nd*, meere ndị niile na-eme ezi omume ihe ọma,
\q2 ya bụ, ndị niile obi ha ziri ezi.
\q1 
\v 5 Ma \nd Onyenwe anyị\nd* ga-achụpụ ndị niile na-agbaso ụzọ aghụghọ
\q2 na ndị niile na-eme ajọ ihe.
\b
\q1 Ka udo dịrị Izrel.
\c 126
\cl Abụ Ọma 126
\d Abụ nrigo.
\s1 Abụ ekele maka mgbapụta
\q1 
\v 1 Mgbe \nd Onyenwe anyị\nd* kpọghachitere ndị e mere ka ha lọta na Zayọn,\f + \fr 126:1 \ft \xt Jer 29:14; Jul 3:1\xt*\f*
\q2 anyị dị ka ndị na-arọ nrọ.
\q1 
\v 2 Ọchị juru anyị ọnụ,
\q2 abụ ọṅụ jukwara anyị ire.
\q1 Mgbe ahụ, e kwukwara ya na mba niile sị,
\q2 “\nd Onyenwe anyị\nd* emeerela ha ọtụtụ ihe dị ukwuu.”
\q1 
\v 3 \nd Onyenwe anyị\nd* emeerala anyị ọtụtụ ihe dị ukwuu,
\q2 obi anyị jupụtakwara nʼọṅụ.
\b
\q1 
\v 4 Nyeghachi anyị akụnụba anyị, o \nd Onyenwe anyị\nd*,
\q2 dịka mmiri iyi na-asọ nʼala Negev.
\q1 
\v 5 Ndị niile na-eji anya mmiri na-arụ ọrụ ịkụ mkpụrụ
\q2 ga-emesịa jiri abụ ọṅụ wee ihe ubi ahụ.
\q1 
\v 6 Onye ji ịkwa akwa
\q2 buru mkpụrụ ubi ọ ga-agha na-aga,
\q1 ga-emesịa jiri abụ ọṅụ na-alọghachi azụ,
\q2 mgbe ha bu ukwu ọka ha.
\c 127
\cl Abụ Ọma 127
\d Abụ nrigo, nke Solomọn.
\s1 Chineke dị mkpa
\q1 
\v 1 Ọ bụrụ na \nd Onyenwe anyị\nd* ewughị ụlọ,
\q2 ndị na-ewu ya na-adọgbu onwe ha nʼọrụ nʼefu.
\q1 Ọ bụrụ na \nd Onyenwe anyị\nd* echeghị obodo,
\q2 nʼefu ka ndị nche na-amụ anya.
\q1 
\v 2 Ọ bụ nʼefu ka ị na-ebili nʼisi ụtụtụ
\q2 na-adọgbu onwe gị nʼọrụ
\q1 ịchọta ihe ị ga-eri ruo nʼabalị,
\q2 nʼihi na ọ na-eme ka ndị niile ọ hụrụ nʼanya hie ụra nʼudo.
\b
\q1 
\v 3 Ụmụntakịrị bụ ihe nketa si nʼaka \nd Onyenwe anyị\nd*,
\q2 ụmụntakịrị bụ ụgwọ ọrụ ọ na-enye.
\q1 
\v 4 Dịka àkụ nʼaka dike nʼagha,
\q2 otu a, ka ụmụ a mụtaara na mgbe okorobịa dị.
\q1 
\v 5 Onye a gọziri agọzi ka nwoke ahụ bụ
\q2 onye kpojuru àkụ ndị a nʼakpa àkụ ya.
\q1 Ihere agaghị eme ha mgbe ha na ndị iro
\q2 na-arụrịta ụka nʼama.
\c 128
\cl Abụ Ọma 128
\d Abụ nrigo.
\s1 Ngọzị dịrị ndị na-atụ egwu Onyenwe anyị
\q1 
\v 1 Ngọzị na-adịrị ndị niile na-atụ egwu \nd Onyenwe anyị\nd*,
\q2 ndị na-aga ije nʼirube isi nye ya.
\q1 
\v 2 Ị ga-eri mkpụrụ ọrụ aka gị;
\q2 ọtụtụ ngọzị na ihe ịga nke ọma ga-abụ nke gị.
\q1 
\v 3 Nwunye gị ga-adị ka osisi vaịnị
\q2 na-amị mkpụrụ nʼime ụlọ gị;
\q1 ụmụ gị ndị ikom ga-adịkwa ka ome osisi oliv
\q2 gburugburu tebul gị.
\q1 
\v 4 Otu a ka a ga-esi gọzie nwoke ahụ
\q2 na-atụ egwu \nd Onyenwe anyị\nd*.
\b
\q1 
\v 5 Ka \nd Onyenwe anyị\nd* gọzie gị site na Zayọn
\q2 ụbọchị niile nke ndụ gị;
\q2 ka i hụkwa ọdịmma Jerusalem,
\q1 
\v 6 ka ị dị ndụ hụ ụmụ ụmụ gị.
\q2 Ka udo dịrị Izrel.\f + \fr 128:6 \ft \xt Abụ 125:5\xt*\f*
\c 129
\cl Abụ Ọma 129
\d Abụ nrigo.
\s1 Ekpere megide ndị iro Izrel
\q1 
\v 1 Site na mgbe m bụ nwantakịrị, ha kpagburu m ọtụtụ oge,
\q2 ka Izrel kwuo.
\q1 
\v 2 “Site na mgbe m bụ nwantakịrị, ha kpagburu m ọtụtụ oge,
\q2 ma ha enweghị ike merie m.
\q1 
\v 3 Ndị ikom na-akọ ubi akọgharịala azụ m dịka ala ubi,
\q2 mee ebe ha kọrọ akọ ka ọ dị ogologo.
\q1 
\v 4 Ma \nd Onyenwe anyị\nd* bụ onye ezi omume;
\q2 ọ tọpụla m site nʼagbụ niile nke ndị ajọ omume.”
\b
\q1 
\v 5 Ka ndị niile kpọrọ Zayọn asị
\q2 bụrụ ndị ga-alaghachi azụ nʼihere.
\q1 
\v 6 Ka ha niile dịrị ka ahịhịa na-epu nʼelu ụlọ
\q2 nke na-akpọnwụ tupu o pupụta;\f + \fr 129:6 \ft Ọ bụ ụrọ a gwakọtara ntụ na aja ka e ji emechi elu ụlọ nʼIzrel. Nʼoge mmiri ozuzo, ahịhịa na-epu nʼelu ụlọ ndị a nʼihi na ha dị larịị, ma ha adịghị adịgide. Mgbe ọkọchị bịara, nʼihi na mgbọrọgwụ ha abanyeghị nʼime aja elu ụlọ ndị a, ha na-akpọnwụ \xt Abụ 37:2\xt*\f*
\q1 
\v 7 nke onye na-ewe ihe ubi na-adịghị eji ha kpojuo aka ya abụọ,
\q2 maọbụ onye mkpokọta e nwee ike kpojuo aka ya.
\q1 
\v 8 Ka ndị si nʼụzọ na-agafe hapụ ị sị ha,
\q2 “Ngọzị \nd Onyenwe anyị\nd* dịrị unu.
\q2 Anyị na-agọzi unu nʼaha \nd Onyenwe anyị\nd*.”\f + \fr 129:8 \ft \xt Rut 2:4\xt*\f*
\c 130
\cl Abụ Ọma 130
\d Abụ nrigo.
\s1 Mkpụrụobi na-ele anya Chineke
\q1 
\v 1 O \nd Onyenwe anyị\nd*, ọ bụ site nʼebe dị omimi ka m na-ebeku gị akwa.
\q2 
\v 2 Onyenwe anyị, nụrụ olu m.
\q1 Ka ntị gị na-aṅakwa ntị
\q2 nʼolu arịrịọ m, maka amara.
\b
\q1 
\v 3 O \nd Onyenwe anyị\nd*, a sị na i detuo mmehie niile,
\q2 Onyenwe anyị, onye pụrụ iguzo?
\q1 
\v 4 Ma ọ bụ nʼaka gị ka mgbaghara mmehie\f + \fr 130:4 \ft \xt Ọpụ 34:7; Neh 9:17; Dan 9:9\xt*\f* dị;
\q2 ime ka anyị tụọ gị egwu, ma jeere gị ozi.
\b
\q1 
\v 5 Ana m echere \nd Onyenwe anyị\nd*, mkpụrụobi m na-echekwa ya,
\q2 ọ bụ nʼokwu ya ka olileanya m dị.
\q1 
\v 6 Mkpụrụobi m na-echere Onyenwe anyị
\q2 karịa ndị nche abalị na-echere chị ọbụbọ,
\q2 e, karịa ndị nche abalị na-echere chị ọbụbọ.
\b
\q1 
\v 7 Ndị Izrel, ka olileanya unu dịrị na \nd Onyenwe anyị\nd*,
\q2 nʼihi na ịhụnanya ya na-adịgide adịgide,
\q2 nʼaka ya ka nzọpụta zuruoke dịkwa.
\q1 
\v 8 Ya onwe ya, ga-agbapụta Izrel
\q2 site na mmehie ya niile.
\c 131
\cl Abụ Ọma 131
\d Abụ nrigo, nke Devid.
\s1 Abụ nke ndị dị nwayọọ nʼobi
\q1 
\v 1 O \nd Onyenwe anyị\nd*, nganga adịghị nʼobi m,
\q2 ndụ mpako abụkwaghị ọchịchọ m;
\q1 adịghị m etinye onwe m nʼokwu karịrị m
\q2 maọbụ nʼihe ndị dị ukwuu karịa m.
\q1 
\v 2 Ma ana m edere duu, mkpụrụobi m nọkwa jụụ;
\q2 dịka nwantakịrị a napụrụ ara, ya na nne ya nọ,
\q2 e, dịka nwantakịrị a napụrụ ara, otu a ka mkpụrụobi m nọ nʼime m.
\b
\q1 
\v 3 Ndị Izrel, ka olileanya unu dịrị na \nd Onyenwe anyị\nd*\f + \fr 131:3 \ft \xt Abụ 130:7\xt*\f*
\q2 ugbu a na mgbe niile ebighị ebi.
\c 132
\cl Abụ Ọma 132
\d Abụ nrigo.
\s1 Devid na igbe ọgbụgba ndụ Onyenwe anyị
\q1 
\v 1 O \nd Onyenwe anyị\nd*, cheta Devid,
\q2 nʼihe niile bụ ndị ọ gbakụtara azụ.
\b
\q1 
\v 2 Ọ ṅụrụ iyi nye \nd Onyenwe anyị\nd*,
\q2 kwee nkwa nye Onye dị ukwuu nke Jekọb:
\q1 
\v 3 “Agaghị m abanye nʼime ụlọ m
\q2 maọbụ rigoo nʼihe ndina m,
\q1 
\v 4 agaghị m arahụ ụra,
\q2 egbugbere anya m agaghị atụ oru ụra,
\q1 
\v 5 tutu ruo mgbe m chọtaara \nd Onyenwe anyị\nd* ọnọdụ
\q2 ebe obibi nye Onye dị ukwuu nke Jekọb.”
\b
\q1 
\v 6 Anyị nụrụ ihe banyere ya nʼEfrata,
\q2 anyị chọtara ya nʼubi niile nke Jearim.
\q1 
\v 7 “Ka anyị gaa na-ebe obibi ya;
\q2 ka anyị kpọọ isiala nʼebe ihe mgbakwasị ụkwụ ya.
\q1 
\v 8 ‘Bilie, \nd Onyenwe anyị\nd*, bata nʼebe izuike gị,
\q2 gị na igbe ọgbụgba ndụ nke ike gị.
\q1 
\v 9 Ka ndị nchụaja gị yiri ezi omume gị dịka uwe;
\q2 ka ndị gị kwesiri ntụkwasị obi bụọ abụ nʼihi ọṅụ.’ ”
\b
\q1 
\v 10 Nʼihi ohu gị, bụ Devid,
\q2 agbakụtala onye gị e tere mmanụ azụ.
\b
\q1 
\v 11 \nd Onyenwe anyị\nd* ṅụrụ Devid iyi nʼeziokwu,
\q2 bụ iyi nke ọ gaghị esi na ya laghachi azụ:
\q1 “Otu nʼime ụmụ gị,
\q2 ka m ga-eme ka ọ nọdụ nʼocheeze gị,
\q1 
\v 12 ọ bụrụ na ụmụ ndị ikom gị edebe ọgbụgba ndụ m
\q2 na ụkpụrụ niile m kuziri ha,
\q1 mgbe ahụ ụmụ ha ga-anọdụ ala
\q2 nʼocheeze gị ruo mgbe ebighị ebi.”
\b
\q1 
\v 13 Nʼihi na \nd Onyenwe anyị\nd* ahọrọla Zayọn,
\q2 ọ bụ ọchịchọ obi ya ime ya ebe obibi ya;
\q1 
\v 14 “Ebe a bụ ebe izuike m ruo mgbe ebighị ebi,
\q2 ebe a ka ocheeze m ga-adịkwa, nʼihi na ọ bụ ihe m chọrọ.
\q1 
\v 15 Aga m eji ọtụtụ nri dị iche iche gọzie ya;
\q2 aga m eji nri mee ka afọ ju ndị ogbenye ya.
\q1 
\v 16 Aga m eji nzọpụta yinye ndị nchụaja ya niile dịka uwe,
\q2 ndị nsọ ya ga-abụ abụ nʼihi ọṅụ.
\b
\q1 
\v 17 “Nʼebe a ka m ga-eme ka mpi\f + \fr 132:17 \ft Nʼebe a mpi na-egosi ịdị ike\f* puputara Devid
\q2 ma debekwa oriọna nʼihi onye m e tere mmanụ.
\q1 
\v 18 Aga m eyikwasị ndị iro ya ihere dịka uwe
\q2 ma aga eji okpueze mara mma chọọ isi ya mma.”
\c 133
\cl Abụ Ọma 133
\d Abụ nrigo, nke Devid.
\s1 Ngọzị nke ibi nʼotu
\q1 
\v 1 Lee ka o si bụrụ ihe dị mma
\q2 na ihe ọṅụ mgbe ụmụnne na-ebikọ nʼotu!\f + \fr 133:1 \ft \xt Hib 13:1\xt*\f*
\b
\q1 
\v 2 Ọ dị ka mmanụ dị oke ọnụahịa a wụrụ nʼisi,
\q2 nke na-asọdata ruo nʼahụọnụ,
\q1 e, nke na-asọdata ruo nʼahụọnụ Erọn,
\q2 ruokwa nʼolu uwe mwụda ya.
\q1 
\v 3 Ọ dị ka a ga-asị na igirigi si na Hemon
\q2 na-ada nʼelu nʼugwu Zayọn.
\q1 Nʼihi na nʼebe ahụ ka \nd Onyenwe anyị\nd* na-enye onyinye ngọzị ya,
\q2 ọ bụladị ndụ na-adị ruo mgbe ebighị ebi.
\c 134
\cl Abụ Ọma 134
\d Abụ nrigo.
\s1 Toonu Onyenwe anyị
\q1 
\v 1 Toonu \nd Onyenwe anyị\nd*, unu ndị ohu \nd Onyenwe anyị\nd* niile
\q2 ndị na-eje ozi nʼime ụlọ \nd Onyenwe anyị\nd* nʼoge abalị.
\q1 
\v 2 Chilienụ aka unu abụọ elu nʼime ụlọnsọ ya\f + \fr 134:2 \ft \xt 1Tm 2:8\xt*\f*
\q2 ma toonu \nd Onyenwe anyị\nd*.
\b
\q1 
\v 3 Ka \nd Onyenwe anyị\nd*, onye kere eluigwe na ụwa
\q2 site na Zayọn gọzie unu.
\c 135
\cl Abụ Ọma 135
\s1 Toonu Onyenwe anyị
\q1 
\v 1 Toonu \nd Onyenwe anyị\nd*.
\b
\q1 Toonu aha \nd Onyenwe anyị\nd*,
\q2 toonu ya, unu ndị ohu \nd Onyenwe anyị\nd* niile,
\q1 
\v 2 unu ndị na-eje ozi nʼime ụlọ \nd Onyenwe anyị\nd*,
\q2 nʼime ogige ụlọ Chineke anyị.
\b
\q1 
\v 3 Toonu \nd Onyenwe anyị\nd*, nʼihi na \nd Onyenwe anyị\nd* dị mma;
\q2 bụkuo aha ya abụ otuto, nʼihi na ọ bụ ihe ziri ezi.
\q1 
\v 4 Nʼihi na \nd Onyenwe anyị\nd* ahọpụtala Jekọb nye onwe ya,
\q2 ọ họpụtala Izrel ka ọ bụrụ ihe oke ọnụahịa nke aka ya.
\b
\q1 
\v 5 Amaara m na \nd Onyenwe anyị\nd* dị ukwuu,
\q2 na Onyenwe anyị dị ukwuu karịa chi niile.
\q1 
\v 6 \nd Onyenwe anyị\nd* na-eme ihe ọbụla masịrị ya
\q2 nʼeluigwe na elu ụwa
\q2 na nʼoke osimiri na nʼime ogbu mmiri niile.
\q1 
\v 7 Ọ bụ ya na-eme ka igwe ojii na-apụta site nʼakụkụ niile nke ụwa.
\q2 Ọ bụkwa ya na-ezite amụma nke na-eweta mmiri ozuzo.
\q2 Ọ na-ewepụtakwa ifufe site nʼụlọ ifufe ya niile.
\b
\q1 
\v 8 O tigburu ụmụ niile e buru ụzọ mụọ nʼala Ijipt,
\q2 ụmụ mmadụ buru ụzọ mụọ na ụmụ anụ ụlọ e buru ụzọ mụọ.
\q1 
\v 9 O zipụrụ ihe ịrịbama ya dị iche iche na ọrụ ebube ya niile nʼetiti unu, o Ijipt,
\q2 megide Fero na ndị niile na-ejere ya ozi.
\q1 
\v 10 O tigburu ọtụtụ mba dị ukwuu nʼọnụọgụgụ,
\q2 tigbukwaa ndị eze ha, ndị dị ike nʼagha.
\q1 
\v 11 Ụfọdụ nʼime ha bụ Saịhọn, eze ndị Amọrait,
\q2 na Ọg eze Bashan,
\q2 na ndị eze niile dị na Kenan.
\q1 
\v 12 O weere ala ndị obodo ahụ niile nye ndị ya,
\q2 nye ya ụmụ Izrel dịka ihe nketa ha.
\b
\q1 
\v 13 O \nd Onyenwe anyị\nd*, aha gị na-adịgide ruo mgbe ebighị ebi
\q2 a maara aha gị ruo ọgbọ niile.
\q1 
\v 14 Nʼihi na \nd Onyenwe anyị\nd* ga-ekpepụta ndị ya.
\q2 Ọ ga-enwekwa ọmịiko nʼahụ ndị ohu ya.
\b
\q1 
\v 15 Chi ndị mba ọzọ bụ arụsị e jiri aka kpụọ,
\q2 nke e ji ọlaọcha na ọlaedo kpụọ.
\q1 
\v 16 Ha nwere ọnụ ma ha adịghị ekwu okwu,
\q2 ha nwere anya ma ha adịghị ahụ ụzọ.
\q1 
\v 17 Ha nwere ntị ma ha adịghị anụ ihe,
\q2 ọ dịkwaghị nkuume dị nʼime ọnụ ha.
\q1 
\v 18 Ndị na-eme ha ga-adị ka ha.
\q2 Ọ bụkwa otu a ka ndị na-atụkwasị ha obi ga-adị.
\b
\q1 
\v 19 Ndị Izrel, toonu \nd Onyenwe anyị\nd*.
\q2 Unu ndị ụlọ Erọn, toonu \nd Onyenwe anyị\nd*.
\q1 
\v 20 Unu ndị ụlọ Livayị, toonu \nd Onyenwe anyị\nd*;
\q2 unu ndị na-atụ egwu ya, toonu \nd Onyenwe anyị\nd*.
\q1 
\v 21 Ka otuto dịrị \nd Onyenwe anyị\nd* site na Zayọn,
\q2 nye onye ahụ na-ebi na Jerusalem.
\b
\q1 Toonu \nd Onyenwe anyị\nd*.
\c 136
\cl Abụ Ọma 136
\s1 Abụ ekele
\q1 
\v 1 Keleenụ \nd Onyenwe anyị\nd*, nʼihi na ọ dị mma.
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 2 Keleenụ Chineke kachasị chi niile elu.
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 3 Keleenụ Onyenwenụ kachasị ndị nwenụ niile.
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\b
\q1 
\v 4 Keleenụ onye ahụ naanị ya na-arụ ọrụ ebube dị iche iche,
\qr ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 5 Keleenụ onye ahụ ji nghọta ya kee mbara eluigwe niile,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 6 Keleenụ onye wuru ụwa nʼelu ogbu mmiri,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 7 Keleenụ onye ahụ kere anyanwụ na ọnwa,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 8 Onye mere anyanwụ ka ọ na-acha nʼehihie,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 9 Onye mere ka ọnwa na kpakpando na-achị nʼabalị,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\b
\q1 
\v 10 Onye ahụ tigburu ụmụ niile e buru ụzọ mụọ nʼIjipt,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 11 O duuru ndị Izrel site nʼIjipt pụta,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 12 O ji aka ya dị ike nke o setịpụrụ esetipụ dupụta ha;
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\b
\q1 
\v 13 Onye ahụ kewara Osimiri Uhie abụọ,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 14 Onye duuru ndị Izrel gafee nʼetiti ya,
\qr nʼihi na ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 15 Ma Osimiri Uhie riri Fero na ndị agha ya niile;
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\b
\q1 
\v 16 Keleenụ onye duuru ndị ya gafee ọzara,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\b
\q1 
\v 17 Onye ahụ tigburu ndị eze dị ukwuu,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 18 O gbukwara ndị eze dị ike nke ukwuu,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 19 O gburu Saịhọn eze ndị Amọrait,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 20 Na Ọg eze Bashan,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 21 Were ala ha nye dịka ihe nketa,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 22 O nyere ohu ya Izrel ala ahụ ka ọ bụrụ ihe nketa ha,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\b
\q1 
\v 23 Onye chetara anyị mgbe anyị na-adịghị ike,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 24 Mee ka anyị nwere onwe anyị site nʼaka ndị iro anyị,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 25 Ọ na-enye ihe niile dị ndụ nri,
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\b
\q1 
\v 26 Keleenụ Chineke nke eluigwe ekele.
\qr Ịhụnanya ya na-adịgide ruo mgbe ebighị ebi.
\c 137
\cl Abụ Ọma 137
\s1 Abụ ndị a dọtara nʼagha
\q1 
\v 1 Nʼakụkụ iyi niile Babilọn ka anyị nọdụrụ ala kwaa akwa
\q2 mgbe anyị chetara Zayọn.
\q1 
\v 2 Ọ bụ nʼosisi pọpla
\q2 ka anyị kokwasịrị ụbọ akwara anyị niile.
\q1 
\v 3 Nʼebe ahụ ka ndị dọtara anyị nʼagha gwara anyị ka anyị bụọrọ ha abụ,
\q2 ndị na-emekpa anyị ahụ rịọrọ anyị ka anyị bụọrọ ha abụ ọṅụ;
\q2 ha kwuru sị, “Bụọrọnụ anyị otu abụ nʼime abụ Zayọn!”
\b
\q1 
\v 4 Ma, olee otu anyị ga-esi bụọ abụ \nd Onyenwe anyị\nd*
\q2 ebe anyị nọ nʼala ọzọ?
\q1 
\v 5 Ọ bụrụ na m echezọọ gị, Jerusalem,
\q2 ka aka nri m chefuo ǹka ya.
\q1 
\v 6 Ọ bụrụ na m echezọọ gị,
\q2 ọ bụrụkwa na m akwụsị iche echiche
\q1 banyere Jerusalem, oke ọṅụ m,
\q2 ka ire m rapara nʼokpo ọnụ m.
\b
\q1 
\v 7 Cheta, o \nd Onyenwe anyị\nd*, ihe ndị Edọm mere
\q2 nʼụbọchị ahụ a dọtara Jerusalem nʼagha.\f + \fr 137:7 \ft Mgbe Nebukadneza meriri Jerusalem, ma bibiekwa ya, ndị Edọm ṅụrịrị oke ọnụ nʼihi na ndị Izrel bụ ndị iro ha. Ma omume a ezighị ezi nʼihi na ndị Edọm na ndị Izrel bụ ụmụnna. Ndị Edọm bụ ụmụ ụmụ Ịsọ, \xt Izk 25:12-14; Ems 1:11; Ọbd 10-14\xt*\f*
\q1 “Tikpọsịa ya,” ka ha tiri,
\q2 “Tikpọsịa ya ruo na ntọala ya niile!”
\q1 
\v 8 Gị ada Babilọn, onye a ghaghị ịla nʼiyi,
\q2 ọṅụ ga-abụ nke onye ahụ ga-akwụghachi gị ụgwọ ọrụ ruru gị
\q2 nʼihi ihe i mere anyị,
\q1 
\v 9 onye ahụ ga-achịrị ụmụ gị ndị na-aṅụ ara
\q2 tụpịa ha nʼelu nkume.\f + \fr 137:9 \ft Nʼoge agha, ndị meriri nʼagha na-achịkọta ụmụaka niile dị nʼobodo ahụ ha meriri, tụpịasịa ha isi na nkume. Ha na-eme nke a i ji mesie mmeri ha meriri obodo ahụ ike, nakwa i ji mee ka a ghara inwe ọgbọ ọzọ ga-ebili nʼobodo ahụ. \xt 2Ez 8:12; Aịz 13:16; Hos 13:16; Nhu 3:10\xt*\f*
\c 138
\cl Abụ Ọma 138
\d Abụ Ọma Devid.
\s1 Onyenwe anyị bụ onye kwesiri ntụkwasị obi
\q1 
\v 1 O \nd Onyenwe anyị\nd*, aga m eji obi m niile too gị;
\q2 nʼihu chi niile dị iche iche ka m ga-abụku gị abụ otuto.
\q1 
\v 2 Aga m akpọ isiala nʼebe ụlọnsọ ukwu gị dị
\q2 aga m etokwa aha gị
\q2 nʼihi ịhụnanya gị na ikwesi ntụkwasị obi gị,
\q1 nʼihi na i meela ka aha gị na okwu gị
\q2 dị elu karịa ihe niile.\f + \fr 138:2 \ft \xt Aịz 42:21\xt*\f*
\q1 
\v 3 Mgbe m kpọkuru gị, ị zara m;
\q2 i mere m ka m nwee nkwuwa okwu ma guzosiekwa ike.
\b
\q1 
\v 4 O \nd Onyenwe anyị\nd*, ka ndị eze niile nọ nʼụwa too gị,
\q2 mgbe ha nụrụ ihe niile i nyere nʼiwu.
\q1 
\v 5 Ka ha bụọ abụ banyere ụzọ niile nke \nd Onyenwe anyị\nd*,
\q2 nʼihi na ebube \nd Onyenwe anyị\nd* dị ukwuu.
\b
\q1 
\v 6 Nʼagbanyeghị na \nd Onyenwe anyị\nd* dị ukwuu, ọ na-elekwasị ndị dị umeala nʼobi anya,
\q2 ma ọ naghị ekwe ka ndị nganga bịa ya nso.
\q1 
\v 7 A sịkwarị na m na-eje ije nʼetiti nsogbu,
\q2 ị na-echebe ndụ m;
\q1 ị na-esetipụ aka gị megide iwe ndị kpọrọ m asị,
\q2 ị na-eji aka nri gị zọpụta m.\f + \fr 138:7 \ft \xt Abụ 23:3-4\xt*\f*
\q1 
\v 8 \nd Onyenwe anyị\nd* ga-emezuru m ihe niile o kwadoro m;\f + \fr 138:8 \ft \xt Fil 1:6\xt*\f*
\q2 ịhụnanya gị, o \nd Onyenwe anyị\nd*, na-adịgide ruo mgbe ebighị ebi,
\q2 ahapụkwala ọrụ aka gị niile.
\c 139
\cl Abụ Ọma 139
\d Abụ nke dịrị onyeisi abụ. Abụ Ọma Devid.
\s1 Chineke maara ihe niile
\q1 
\v 1 O \nd Onyenwe anyị\nd*, ị nyochaala m,
\q2 ị makwaara m nke ọma
\q1 
\v 2 Ị maara mgbe m na-anọdụ ala na mgbe m na-eguzo ọtọ;
\q2 site nʼebe dị anya, ị na-aghọta echiche obi m niile.
\q1 
\v 3 Ị na-ahụzu ọpụpụ m na ndina ala m;
\q2 ị mazukwara ụzọ m niile.
\q1 
\v 4 O \nd Onyenwe anyị\nd*, ị maara ihe m gaje ikwu
\q2 tupu m kwuo ya.
\q1 
\v 5 Ị na-anọ m nʼihu, ma na-esokwa m nʼazụ,
\q2 ị tụkwasịla m aka gị.
\q1 
\v 6 Ihe ọmụma dị otu a dị oke omimi nye m,
\q2 ọ dịkwa elu apụghị m iru ya.
\b
\q1 
\v 7 Ebee ka m ga-ezo onwe m si otu a zonarị Mmụọ gị?
\q2 Ebeekwa ka m pụrụ ịgbaga ka m si nʼihu gị zoo onwe m?
\q1 
\v 8 Ọ bụrụ na m arịgoro nʼeluigwe ị nọ nʼebe ahụ.
\q2 Ọ bụrụkwa na m arịda zoo onwe m nʼala mmụọ, ị nọkwa nʼebe ahụ.
\q1 
\v 9 Ọ bụrụ na m efepụ nʼisi ụtụtụ dịka nwa nnụnụ, felagaa
\q2 nʼebe dị nnọọ anya nke oke osimiri,
\q1 
\v 10 ọ bụladị nʼebe ahụ ka aka gị ga na-edu m
\q2 aka nri gị ga-ejidesi m ike.
\q1 
\v 11 Ọ bụrụ na m asị, “Nʼezie, ọchịchịrị ga-ekpuchi m
\q2 ìhè ga-aghọ abalị gbaa m gburugburu.”
\q1 
\v 12 Ọ bụladị ọchịchịrị agaghị abụ ọchịchịrị nʼebe ị nọ;
\q2 abalị ga-enye ìhè dịka ehihie,
\q2 nʼihi na ọchịchịrị dị ka ìhè nʼebe ị nọ.\f + \fr 139:12 \ft \xt Job 26:6; Job 34:22; Hib 4:13\xt*\f*
\b
\q1 
\v 13 Ọ bụ gị kpụrụ akụkụ niile dị m nʼahụ.
\q2 Ọ bụkwa gị jikọtara ha niile ka ha bụrụ otu mmadụ nʼime afọ nne m.
\q1 
\v 14 Ana m eto gị nʼihi na abụ m onye e sitere nʼoke egwu na ebube kee;
\q2 ọrụ gị niile dị ebube;
\q2 amaara m nke a nke ọma.
\q1 
\v 15 Ụdịdị m abụghị ihe zoro ezo nʼebe ị nọ
\q2 mgbe a kpụrụ m nʼebe nzuzo ahụ,
\q2 mgbe a kpakọtara m nʼebe omimi nke ụwa.
\q1 
\v 16 Anya gị abụọ hụrụ ahụ m mgbe ọ na-enweghị ụdịdị ọbụla.
\q2 E dere ụbọchị niile a kwadoro m nʼime akwụkwọ gị
\q2 tupu otu nʼime ha adịrị.
\q1 
\v 17 Lee ka echiche ị na-eche banyere m si dị oke ọnụahịa, o Chineke!
\q2 Leekwa ka ha si dị ukwuu.
\q1 
\v 18 Ọ bụrụ na m agụọ ha ọnụ,
\q2 ha ga-adị ukwuu karịa ọnụọgụgụ aja dị nʼala.
\q2 Mgbe m tetara, mụ na gị ka nọ.
\b
\q1 
\v 19 O Chineke, a sịkwarị na ị ga-ala ndị ajọ omume niile nʼiyi!
\q2 Sitenụ nʼebe m nọ pụọ, unu ndị na-akwafu ọbara!
\q1 
\v 20 Site nʼechiche ọjọọ, ha na-ekwu okwu banyere gị;
\q2 ndị iro gị na-ekwutọ aha gị.
\q1 
\v 21 O \nd Onyenwe anyị\nd*, ọ bụ na m akpọghị ha asị bụ ndị kpọrọ gị asị,
\q2 na-asọkwa ndị na-enupu isi megide gị oyi?
\q1 
\v 22 Ọ bụ naanị ịkpọ asị ka m nwere nʼebe ha nọ?
\q2 Ana m agụnye ha dịka ndị iro m.
\q1 
\v 23 O Chineke, nyochaa m, mara obi m.
\q2 Nwaa m, matakwa echiche uche m niile.
\q1 
\v 24 Chọpụta ma o nwere ihe ọjọọ dị nʼime m,
\q2 ma duo m nʼụzọ ebighị ebi.
\c 140
\cl Abụ Ọma 140
\d Abụ nke dịrị onyeisi abụ. Abụ Ọma Devid.
\s1 Ekpere maka nchebe
\q1 
\v 1 O \nd Onyenwe anyị\nd*, dọpụta m site nʼaka ndị na-eme ihe ọjọọ.
\q2 Chebe m ka m ghara ịdaba nʼaka ndị na-eme ihe ike dị iche iche.
\q1 
\v 2 Ndị na-atụ atụmatụ ime ihe ọjọọ nʼobi ha
\q2 na-akpali agha ụbọchị niile.
\q1 
\v 3 Ha na-eme ire ha ka ha dị nkọ dịka nke agwọ;
\q2 elo ajụala dị nʼegbugbere ọnụ ha.\f + \fr 140:3 \ft \xt Rom 3:13; Jem 3:8\xt*\f*\qs Sela\qs*
\b
\q1 
\v 4 Chebe m \nd Onyenwe anyị\nd*, ka m ghara ịdaba nʼaka ndị na-emebi iwu;
\q2 chebe m ka m ghara ịdaba nʼaka ndị na-eme ihe ike,
\q2 ndị na-eche echiche ọdịda m.
\q1 
\v 5 Ndị mpako esielera m ọnya igbudu;
\q2 ha agbasaala ụgbụ ha na udo ha,
\q2 siekwara m ọnya dị iche iche nʼụzọ m na-aga. \qs Sela\qs*
\b
\q1 
\v 6 A sịrị m \nd Onyenwe anyị\nd*, “Gị onwe gị bụ Chineke m.”
\q2 Nụrụ, O \nd Onyenwe anyị\nd*, olu arịrịọ m maka amara.
\q1 
\v 7 Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* Onye nzọpụta m dị ike,
\q2 ị na-ekpuchi isi m nʼụbọchị agha.
\q1 
\v 8 Ekwekwala ka ndị ajọ omume chọta ihe ha na-achọ, o \nd Onyenwe anyị\nd*,
\q2 ekwekwala ka nzube ha mezuo. \qs Sela\qs*
\b
\q1 
\v 9 Ndị niile gbara m gburugburu na-ebuli isi ha elu na nganga
\q2 ka ndụ ọjọọ nke egbugbere ọnụ ha rikpuo ha.
\q1 
\v 10 Ka icheku ọkụ na-ere ere dakwasị ha;
\q2 ka a tụba ha nʼime ọkụ na-ere ere,
\q2 nʼime olulu apịtị jupụtara, nke ha na-enweghị ike isite nʼime ya pụta ọzọ.
\q1 
\v 11 Ekwela ka ndị na-ekwu okwu nkwulu guzosie ike nʼala,
\q2 ka ihe ọjọọ chụda ndị na-eme ihe ike.
\b
\q1 
\v 12 Amaara m na \nd Onyenwe anyị\nd* ga-ekpe ikpe ziri ezi nye ndị ogbenye
\q2 na-emekwa ka ndị nọ na mkpa nweta ihe ruuru ha.
\q1 
\v 13 Nʼezie, ndị ezi omume ga-eto aha gị,
\q2 ndị ziri ezi ga-ebikwa nʼihu gị.
\c 141
\cl Abụ Ọma 141
\d Abụ Ọma Devid.
\s1 Arịrịọ nke ezi mmadụ
\q1 
\v 1 O \nd Onyenwe anyị\nd*, ana m akpọku gị; bịakwute m ọsịịsọ.
\q2 Nụrụ olu m mgbe m na-akpọku gị.
\q1 
\v 2 Ka ekpere m bịa nʼihu gị dịka ihe na-esi isi ụtọ;
\q2 ka nchili elu nke m chịlịri aka m abụọ dịrị ka aja a na-achụ nʼanyasị.
\b
\q1 
\v 3 Nyere m aka ka m mechie ọnụ m, o \nd Onyenwe anyị\nd*;
\q2 na-echekwa egbugbere ọnụ m nche.
\q1 
\v 4 Ekwela ka obi m nwee mmasị nʼihe ọjọọ,
\q2 isonye ndị na-eme ihe ọjọọ
\q1 rụọ ọrụ ajọ omume niile dị iche iche;
\q2 ekwela ka m soro ha rikọọ ihe ụtọ ha niile.\f + \fr 141:4 \ft \xt Ilu 23:6\xt*\f*
\b
\q1 
\v 5 Ka onye ezi omume tie m ihe, nke a na-egosi obi ebere;
\q2 ka ọ baara m mba, nke a bụ mmanụ nʼelu isi m.
\q1 Isi m agaghị ajụ ya.
\q2 Otu ọ dị, ekpere m na-emegide ọrụ niile nke ndị na-eme ihe ọjọọ.
\b
\q1 
\v 6 A ga-esite nʼelu nkume dị elu tụda ndị na-achị ha,
\q2 mgbe ahụ, ndị ajọ omume ga-amata na okwu m niile bụ eziokwu.
\q1 
\v 7 Ha ga-ekwu sị, “Dịka mmadụ na-egburi, na-akọgharị ala,
\q2 otu a ka a ghasasịrị ọkpụkpụ anyị nʼọnụ ili.”
\b
\q1 
\v 8 Ma olileanya m dị na gị, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*
\q2 nʼime gị ka m gbabara izere ndụ, ararala m nyefee nʼaka ọnwụ.
\q1 
\v 9 Napụta m ka m ghara ịdaba nʼime ọnya igbudu niile nke ndị na-eme ajọ ihe siiri,
\q2 sitekwa nʼọnya niile ha siiri m.
\q1 
\v 10 Ka ndị ajọ omume daba nʼime ụgbụ ha,
\q2 ma mụ onwe m ga-agabiga na-emerụghị ahụ ọbụla.
\c 142
\cl Abụ Ọma 142
\d Abụ \tl maskil\tl* nke Devid. Mgbe ọ nọ nʼọgba nkume. Ekpere.
\s1 Ekpere nke onye mkpọrọ
\q1 
\v 1 Etikuru m \nd Onyenwe anyị\nd* mkpu akwa;
\q2 ewelitara m olu m rịọ \nd Onyenwe anyị\nd* ka o meere m ebere.
\q1 
\v 2 Ekwupụtara m ihe na-esogbu m nʼihu ya,
\q2 gwakwa ya ahụhụ nke m nọ nʼime ya.
\b
\q1 
\v 3 Mgbe mmụọ m dara mba nʼime m,
\q2 ọ bụ gị maara ụzọ m.
\q1 Nʼụzọ ebe m na-esi aga
\q2 ka ndị mmadụ siiri m ọnya.
\q1 
\v 4 Lee anya nʼaka nri m ma hụ
\q2 na ọ dịghị onye ọbụla na-eche ihe banyere m.
\q1 Enweghị m ebe mgbaba.
\q2 Ọ dịghị onye ọbụla ihe banyere m na-emetụta nʼobi.
\b
\q1 
\v 5 Ana m etiku gị mkpu akwa, o \nd Onyenwe anyị\nd*,
\q2 na-asị, “Gị bụ ebe mgbaba m,
\q2 oke m nʼala ndị dị ndụ.”
\b
\q1 
\v 6 Gee ntị na mkpu akwa m,
\q2 nʼihi na anọ m nʼọnọdụ ihe isiike;
\q1 gbapụta m site nʼaka ndị na-achụ m ọsọ,
\q2 nʼihi na ha siri ike karịa m.
\q1 
\v 7 Mee ka m nwere onwe m site nʼụlọ mkpọrọ,
\q2 ka m nwee ike too aha gị.
\q1 Mgbe ahụ ndị ezi omume ga-agba m gburugburu
\q2 nʼihi ịdị mma gị nʼebe m nọ.
\c 143
\cl Abụ Ọma 143
\d Abụ Ọma Devid.
\s1 Ekpere maka enyemaka
\q1 
\v 1 O \nd Onyenwe anyị\nd*, nụrụ ekpere m,
\q2 gekwaa ntị nʼakwa arịrịọ m maka amara;
\q1 nʼihi ikwesi ntụkwasị obi gị na ezi omume gị,
\q2 bịa nyere m aka.
\q1 
\v 2 Edubatala m nʼọnọdụ ikpe m ikpe,
\q2 nʼihi na ọ dịghị onye ọbụla dị ndụ bụ onye ezi omume nʼihu gị.\f + \fr 143:2 \ft \xt Job 4:17; 9:2; Ekl 7:20\xt*\f*
\q1 
\v 3 Onye iro na-achụ m ọsọ,
\q2 ọ na-azọpịa ndụ m nʼala;
\q1 na-emekwa ka m nọdụ nʼọchịchịrị,
\q2 dịka ndị nwụrụ anwụ nʼogologo oge gara aga.
\q1 
\v 4 Ya mere mmụọ m na-ada mba nʼime m
\q2 ụjọ jupụtakwara m nʼobi.
\q1 
\v 5 Ana m echeta ụbọchị niile ndị ahụ gara aga;
\q2 ana m atụgharị uche nʼọrụ gị niile
\q2 na-echekwa echiche banyere ihe niile aka gị rụrụ.
\q1 
\v 6 Ana m agbasa aka m abụọ nye gị;
\q2 agụụ gị na-agụ mkpụrụobi m dịka agụụ mmiri ozuzo si agụ ala kpọrọ nkụ. \qs Sela\qs*
\b
\q1 
\v 7 O \nd Onyenwe anyị\nd*, zaa m ọsịịsọ;
\q2 mmụọ m na-ada mba.
\q1 Ezonarịla m ihu gị,
\q2 ma ọ bụghị ya, aga m adị ka ndị na-arịda ruo nʼili.
\q1 
\v 8 Mee ka m nụrụ okwu ịhụnanya gị nke na-adịghị agharịpụ nʼisi ụtụtụ,
\q2 nʼihi na ọ bụ gị ka m tụkwasịrị obi.
\q1 Zi m ụzọ m kwesiri ịgbaso,
\q2 nʼihi na ọ bụ gị ka m na-eweli mkpụrụobi m nye.
\q1 
\v 9 O \nd Onyenwe anyị\nd*, gbapụta m site nʼaka ndị iro m,
\q2 nʼihi na ọ bụ nʼime gị ka m na-ezo onwe m.
\q1 
\v 10 Kuziere m ime uche gị,
\q2 nʼihi na ị bụ Chineke m;
\q1 ka ezi Mmụọ gị
\q2 duo m nʼala dị larịị.
\b
\q1 
\v 11 O \nd Onyenwe anyị\nd*, nʼihi aha gị chebe ndụ m;
\q2 nʼime ezi omume gị, napụta m site na nsogbu.
\q1 
\v 12 Nʼime ịhụnanya gị na-adịghị agharịpụ, kpochapụ ndị iro m;
\q2 laa ndị niile kpọrọ m asị nʼiyi,
\q2 nʼihi na abụ m ohu gị.
\c 144
\cl Abụ Ọma 144
\d Abụ Ọma nke Devid.
\s1 Abụ nke dike nʼagha
\q1 
\v 1 Otuto dịrị \nd Onyenwe anyị\nd*, onye bụ oke nkume m,
\q2 onye na-ezi aka m abụọ ibu agha,
\q2 na mkpịsịaka m ịlụ ọgụ.
\q1 
\v 2 Ọ bụ Chineke m, onye jupụtara nʼịhụnanya, bụrụkwa ebe mgbaba m e wusiri ike,
\q2 ebe m e wusiri ike na onye mgbapụta m,
\q1 ọ bụ ọta m, onye m na-agbaba nʼime ya,
\q2 onye ji aka ike mee ka ndị dị iche iche nọdụ nʼokpuru m.
\b
\q1 
\v 3 O \nd Onyenwe anyị\nd*, gịnị ka mmadụ bụ i ji na-eche echiche banyere ya,\f + \fr 144:3 \ft \xt Abụ 8:4\xt*\f*
\q2 gịnị ka nwa nke mmadụ bụ ihe banyere ya ji na-emetụ gị nʼobi?
\q1 
\v 4 Mmadụ dị ka otu nkuume;
\q2 ụbọchị ndụ ya niile na-agafe ngwangwa dịka onyinyo.
\b
\q1 
\v 5 O \nd Onyenwe anyị\nd*, kewaa eluigwe rịdata;
\q2 metụ ugwu niile aka ka ha kwụọ anwụrụ ọkụ.
\q1 
\v 6 Zipụ amụma ka o chụsasịa ndị iro niile;
\q2 gbaa ha àkụ gị niile ma chụsasịa ha.
\q1 
\v 7 Site nʼelu setịpụ aka gị;
\q2 gbapụta m, napụtakwa m
\q1 site nʼoke osimiri,
\q2 site nʼaka ndị si mba ọzọ,
\q1 
\v 8 ndị ọnụ ha jupụtara nʼụgha,
\q2 ndị aka nri ha jupụtakwara nʼaghụghọ.
\b
\q1 
\v 9 O Chineke, aga m abụku gị abụ ọhụrụ.
\q2 Une e ji akwara iri mee ka m ga-eji kpọọrọ gị egwu;
\q1 
\v 10 gị onye na-enye ndị eze mmeri,
\q2 onye na-agbapụta ohu ya Devid.
\b
\q1 Site na mma agha dị njọ
\v 11 gbapụta m;
\q2 napụtakwa m site nʼaka ndị si mba ọzọ
\q1 ndị ọnụ ha jupụtara nʼụgha,
\q2 ndị aka nri ha jupụtakwara nʼaghụghọ.
\b
\q1 
\v 12 Mgbe ahụ, ụmụ ndị ikom anyị, nʼoge okorobịa ha,
\q2 ga-adị ka ihe a kụrụ nʼala e lekọtara anya nke ọma,
\q1 ụmụ anyị ndị inyom ga-adị ka ogidi a pịrị apị
\q2 e ji achọ ụlọeze mma.
\q1 
\v 13 Ọba anyị niile ga-ejupụta nʼihe oriri
\q2 dị iche iche si nʼubi anyị.
\q1 Atụrụ anyị ga-amụba nʼọtụtụ puku nʼọnụọgụgụ,
\q2 ha ga-adị iri puku kwụrụ puku nʼubi anyị;
\q2 
\v 14 igwe ehi anyị ga-adọkpụ ibu dị arọ.
\q1 A gaghị enwe ntipu na mgbidi anyị niile,
\q2 a gaghị adọta anyị nʼagha gaa obodo ọzọ,
\q2 akwa ihe mgbu agaghị adị nʼokporoụzọ anyị niile.
\q1 
\v 15 Ndị a gọziri agọzi ka ndị ahụ bụ, ndị ihe ndị a dịịrị;
\q2 ndị a gọziri agọzi ka ndị ahụ bụ, ndị Chineke bụ \nd Onyenwe anyị\nd* ha.
\c 145
\cl Abụ Ọma 145
\d Abụ Ọma otuto, nke Devid.
\s1 Ịdị mma nke Chineke
\q1 
\v 1 Aga m ebuli gị elu, Chineke m onye bụ eze;
\q2 aga m eto aha gị, site nʼebighị ebi ruo ebighị ebi.
\q1 
\v 2 Ụbọchị niile ka m ga-eto gị
\q2 jaakwa aha gị mma site nʼebighị ebi ruo ebighị ebi.
\b
\q1 
\v 3 \nd Onyenwe anyị\nd* dị ukwuu, bụrụkwa onye kwesiri ịnata otuto;
\q2 ịdị ukwuu ya karịrị ihe onye ọbụla pụrụ ịghọta.
\q1 
\v 4 Otu ọgbọ ga-eto ọrụ gị niile nʼihu ọgbọ ọzọ;
\q2 ha ga-ekwupụta maka ọrụ ukwuu gị niile dị iche iche.
\q1 
\v 5 Ha ga-ekwupụta ihe banyere ịdị ebube nke ịma mma gị,
\q2 aga m atụgharịkwa uche nʼọrụ ebube gị niile.
\q1 
\v 6 Ha ga-ekwupụta ihe banyere ike nke ọrụ ịtụnanya gị niile,
\q2 aga m ekwusakwa ọrụ ukwuu gị niile.
\q1 
\v 7 Ha ga-eme mmemme nʼihi ịdị mma gị dị ukwuu
\q2 jirikwa ọṅụ bụọ abụ banyere ezi omume gị.
\b
\q1 
\v 8 \nd Onyenwe anyị\nd* na-eme amara nweekwa obi ọmịiko,
\q2 ọ dịghị ewe iwe ọsịịsọ, ọ bara ụba nʼịhụnanya.
\b
\q1 
\v 9 \nd Onyenwe anyị\nd* dị mma nʼebe mmadụ niile dị;
\q2 o nwere ọmịiko nʼebe ihe niile o kere eke dị.
\q1 
\v 10 O \nd Onyenwe anyị\nd*, ihe niile i kere eke ga-eto gị;
\q2 ndị nsọ gị na-aja gị mma.
\q1 
\v 11 Ha ga-ekwupụta banyere ebube nke alaeze gị.
\q2 Kwupụtakwa maka ịdị ike gị,
\q1 
\v 12 ka mmadụ niile mata ihe banyere ọrụ ukwuu gị niile dị iche iche
\q2 na ebube nke ịdị mma alaeze gị.
\q1 
\v 13 Alaeze gị bụ alaeze na-adịgide ruo mgbe ebighị ebi,
\q2 ọchịchị gị na-adịgidekwa site nʼọgbọ ruo nʼọgbọ.
\b
\q1 \nd Onyenwe anyị\nd* na-emezu nkwa ya niile
\q2 na-ahụkwa ihe niile o kere eke nʼanya.
\q1 
\v 14 \nd Onyenwe anyị\nd* na-ekulite ndị niile dara ada
\q2 na-akwagide ndị niile dara mba.
\q1 
\v 15 Olileanya ihe niile dị na gị,
\q2 ị na-enye ha nri ha mgbe oge ya ruru.
\q1 
\v 16 I na-asaghepụ aka gị
\q2 na-emezu ọchịchọ ihe niile dị ndụ.
\b
\q1 
\v 17 Ụzọ \nd Onyenwe anyị\nd* niile ziri ezi;
\q2 ọ na-ahụkwa ihe niile o kere eke nʼanya.
\q1 
\v 18 \nd Onyenwe anyị\nd* na-anọ nso ndị niile na-akpọku ya,
\q2 bụ ndị niile na-akpọku ya nʼeziokwu.
\q1 
\v 19 Ọ na-emezu ọchịchọ niile nke ndị na-atụ egwu ya;
\q2 ọ na-anụ akwa ha na-azọpụtakwa ha.
\q1 
\v 20 \nd Onyenwe anyị\nd* na-echebe ndị niile hụrụ ya nʼanya,
\q2 ma ọ ga-ala ndị ajọ omume niile nʼiyi.
\b
\q1 
\v 21 Ọnụ m ga-ekwupụta otuto \nd Onyenwe anyị\nd*;
\q2 ka ihe niile e kere eke too aha nsọ ya
\q2 ruo mgbe ebighị ebi.
\c 146
\cl Abụ Ọma 146
\s1 Tụkwasị Chineke obi
\q1 
\v 1 Toonu \nd Onyenwe anyị\nd*.
\b
\q1 O mkpụrụobi m, too \nd Onyenwe anyị\nd*.
\b
\q1 
\v 2 Aga m eto \nd Onyenwe anyị\nd* ogologo ndụ m niile;
\q2 aga m abụ abụ otuto nye Chineke m mgbe m nọ na-adị ndụ.
\q1 
\v 3 Atụkwasịla ụmụ eze obi gị,
\q2 ndị bụ mmadụ efu na-apụghị ịzọpụta.
\q1 
\v 4 Mgbe mmụọ ha pụrụ, ha na-alaghachi nʼaja\f + \fr 146:4 \ft \xt Ekl 12:7\xt*\f*;
\q2 nʼụbọchị ahụ, atụmatụ ha na-aghọ ihe efu.
\q1 
\v 5 Onye a gọziri agọzi ka onye ahụ bụ, onye inyeaka ya bụ Chineke nke Jekọb,
\q2 onye olileanya ya dị na \nd Onyenwe anyị\nd*, Chineke ya.
\b
\q1 
\v 6 Onye kere eluigwe na ụwa,
\q2 na osimiri, na ihe niile dị nʼime ha,
\q2 \nd Onyenwe anyị\nd*, onye ikwesi ntụkwasị obi ya na-adịgide ruo mgbe ebighị ebi.
\q1 
\v 7 Ọ na-ekpe ikpe ziri ezi nye ndị a na-akpagbu
\q2 na-enyekwa ndị agụụ na-agụ nri.
\q1 \nd Onyenwe anyị\nd* na-eme ka ndị nọ nʼụlọ mkpọrọ nwere onwe ha,
\q2 
\v 8 \nd Onyenwe anyị\nd* na-emeghe anya ndị kpuru ìsì,
\q1 \nd Onyenwe anyị\nd* na-akwagide ndị niile dara mba,
\q2 \nd Onyenwe anyị\nd* hụrụ ndị ezi omume niile nʼanya.
\q1 
\v 9 \nd Onyenwe anyị\nd* na-echebe ndị ọbịa,
\q2 na-elekọtakwa ndị na-enweghị nna na ndị di ha nwụrụ anwụ,
\q2 ma ọ na-eme ka ihe ghara ịgara ndị ajọ omume nke ọma.
\b
\q1 
\v 10 \nd Onyenwe anyị\nd* na-achị ruo ebighị ebi,
\q2 Chineke gị, o Zayọn, site nʼọgbọ ruo nʼọgbọ.
\b
\q1 Toonu \nd Onyenwe anyị\nd*.
\c 147
\cl Abụ Ọma 147
\s1 Onyenwe anyị dike, na onye amara
\q1 
\v 1 Toonu \nd Onyenwe anyị\nd*!
\b
\q1 Ọ bụ ihe dị mma ịbụku Chineke anyị abụ otuto.
\q2 Ọ bụ ihe na-eweta mmasị, bụrụkwa ihe ziri ezi ito ya!
\b
\q1 
\v 2 \nd Onyenwe anyị\nd* na-ewu Jerusalem:
\q2 ọ na-akpọghachita ụmụ Izrel ndị a dọọrọ nʼagha gaa nʼala ọzọ.
\q1 
\v 3 Ọ na-agwọ ndị niile obi ha tiwara etiwa
\q2 na-ekechikọtakwa ebe niile ha merụrụ ahụ.
\q1 
\v 4 Ọ bụ ya na-ekpebi ọnụọgụgụ kpakpando niile
\q2 na-akpọkwa ha nʼotu na otu.\f + \fr 147:4 \ft \xt Aịz 40:26\xt*\f*
\q1 
\v 5 Onyenwe anyị dị ukwuu, ike ya dịkwa ukwuu;
\q2 nghọta ya enweghị nsọtụ.
\q1 
\v 6 \nd Onyenwe anyị\nd* na-agba ndị dị umeala nʼobi ume
\q2 ma ọ na-atụda ndị ajọ omume nʼala.
\b
\q1 
\v 7 Jirinụ ekele bụkuo \nd Onyenwe anyị\nd* abụ;
\q2 jirinụ ụbọ akwara kpọọrọ Chineke anyị egwu.
\b
\q1 
\v 8 Ọ na-eji igwe ojii na-ekpuchi mbara eluigwe;
\q2 ọ na-ewetara elu ụwa mmiri ozuzo
\q2 na-eme ka ahịhịa puo nʼelu ugwu niile.
\q1 
\v 9 Ọ na-enye ehi niile nri
\q2 na-enyekwa ụmụ ugolọma nri mgbe ha na-ebeku ya akwa nʼihi nri.
\b
\q1 
\v 10 Mmasị ya adịghị nʼike nke ịnyịnya,
\q2 maọbụ nʼike ụkwụ nke mmadụ.
\q1 
\v 11 \nd Onyenwe anyị\nd* na-enwe mmasị nʼebe ndị na-atụ egwu ya nọ,
\q2 ndị olileanya ha dị na ịhụnanya ya nke na-adịghị agharịpụ.
\b
\q1 
\v 12 O Jerusalem, jaa \nd Onyenwe anyị\nd* mma;
\q2 o Zayọn, too Chineke gị.
\b
\q1 
\v 13 Nʼihi na o wusiela mkpọrọ ọnụ ụzọ ama gị niile ike,
\q2 na-agọzikwa ndị niile bi nʼime gị.
\q1 
\v 14 Ọ na-eme ka oke ala gị nwee udo,
\q2 jirikwa ọka wiiti kachasị mma nyejuo gị afọ.
\b
\q1 
\v 15 Ọ na-ezipụ iwu ya nʼelu ụwa niile;
\q2 okwu ya na-agbasa ngwangwa.
\q1 
\v 16 Ọ na-atụsa snoo nʼala dịka ajị anụ,
\q2 na-efesasị igirigi snoo dịka ntụ.
\q1 
\v 17 Ọ na-atụdata mkpụrụ mmiri ya dị ka mkpụrụ okwute.
\q2 Onye pụrụ iguzogide oke ifufe oyi ya?
\q1 
\v 18 Ọ na-ezipụ okwu ya na-agbaze ha;
\q2 ọ na-akpalịte ikuku ya mee ka mmiri bido ịsọgharị.
\b
\q1 
\v 19 O kpugheela okwu ya nye Jekọb,
\q2 iwu ya na ụkpụrụ ya niile nye Izrel.
\q1 
\v 20 O mesobeghị mba ọzọ ụdị mmeso dị otu a.
\q2 Ha amakwaghị iwu ya niile.
\b
\q1 Toonu \nd Onyenwe anyị\nd*!
\c 148
\cl Abụ Ọma 148
\s1 Toonu Onyenwe ihe niile
\q1 
\v 1 Toonu \nd Onyenwe anyị\nd*.
\b
\q1 Toonu \nd Onyenwe anyị\nd* site nʼeluigwe,
\q2 toonu ya nʼebe niile kachasị elu.
\q1 
\v 2 Toonu ya, ndị mmụọ ozi ya niile,
\q2 toonu ya, unu usuu ndị agha ya niile.
\q1 
\v 3 Toonu ya, anyanwụ na ọnwa
\q2 toonu ya, kpakpando niile.
\q1 
\v 4 Toonu ya, unu eluigwe kachasị elu
\q2 na unu mmiri dị nʼelu mbara eluigwe.
\b
\q1 
\v 5 Ka ha niile too aha \nd Onyenwe anyị\nd*,
\q2 nʼihi na ha niile malitere ịdị site nʼokwu ọnụ ya.
\q1 
\v 6 O doro ha nʼọnọdụ ha ga-anọ ruo mgbe ebighị ebi;
\q2 o nyere iwu nke a na-agaghị agabiga.
\b
\q1 
\v 7 Toonu \nd Onyenwe anyị\nd*, site nʼụwa,
\q2 unu oke anụ mmiri niile na ogbu mmiri niile,
\q1 
\v 8 na amụma, na mkpụrụ mmiri, na snoo na igwe ojii niile,
\q2 na oke ifufe niile na-eme ihe o nyere nʼiwu,
\q1 
\v 9 unu ugwu ukwu niile, na ugwu nta niile
\q2 na osisi niile na-amị mkpụrụ na osisi sida niile
\q1 
\v 10 na anụ ọhịa, na anụ ụlọ niile,
\q2 na ihe niile na-akpụ akpụ nʼala na nnụnụ niile,
\q1 
\v 11 ndị eze niile nke ụwa na mba niile dị iche iche,
\q2 unu ụmụ eze na ndị niile na-achị achị nʼụwa,
\q1 
\v 12 ụmụ okorobịa na ụmụ agbọghọ,
\q2 ndị okenye na ụmụntakịrị.
\b
\q1 
\v 13 Ka ha niile too aha \nd Onyenwe anyị\nd*,
\q2 nʼihi na ọ bụ naanị aha ya ka e buliri elu;
\q2 ebube ya dị ukwuu karịa eluigwe na ụwa.
\q1 
\v 14 O meela ka mpi\f + \fr 148:14 \ft Mpi bụ ihe na-egosipụta ike, gụọ akwụkwọ \xt 1Sa 2:1\xt*\f* ndị ya dị elu,
\q2 otuto ndị nsọ ya niile,
\q2 nke Izrel ndị ọ hụrụ nʼanya.
\b
\q1 Toonu \nd Onyenwe anyị\nd*.
\c 149
\cl Abụ Ọma 149
\s1 Abụ otuto
\q1 
\v 1 Toonu \nd Onyenwe anyị\nd*!
\b
\q1 Bụkuonụ \nd Onyenwe anyị\nd* abụ ọhụrụ.
\q2 Bụọnụ abụ ito ya nʼetiti ndị nsọ ya.
\b
\q1 
\v 2 Ka Izrel ṅụrịa ọṅụ nʼime onye kere ha;
\q2 ka ndị bi na Zayọn nwee obi ụtọ nʼime Eze\f + \fr 149:2 \ft \xt Nkp 8:23; Zek 9:9; Mat 21:5\xt*\f* ha.
\q1 
\v 3 Ka ha jiri ite egwu too aha ya
\q2 ka ha jiri ọyọ na ụbọ akwara kpọọrọ ya egwu.
\q1 
\v 4 Nʼihi na ihe banyere ndị ya na-atọ \nd Onyenwe anyị\nd* ụtọ.
\q2 Ọ na-eji nzọpụta\f + \fr 149:4 \ft \xt Abụ 132:16; Aịz 61:10\xt*\f* kpukwasị ndị dị umeala nʼobi nʼisi dịka okpueze.
\q1 
\v 5 Ka ndị nsọ ṅụrịa ọṅụ nʼime nsọpụrụ a,
\q2 bụkwaa abụ nʼihi ọṅụ nʼelu ihe ndina ha.
\b
\q1 
\v 6 Ka otuto Chineke dịrị nʼọnụ ha,
\q2 ka mma agha ihu abụọ\f + \fr 149:6 \ft \xt Hib 4:12; Mkp 1:16\xt*\f* dịrịkwa nʼaka ha,
\q1 
\v 7 iji bọọrọ mba niile ọbọ
\q2 taakwa ndị niile dị iche iche ahụhụ,
\q1 
\v 8 iji mkpọrọ igwe kee ndị eze ha
\q2 na ndị ha a na-asọpụrụ agbụ igwe,
\q1 
\v 9 imezu ihe ahụ e kpebiri, depụtakwa megide ha.
\q2 Nke a bụ nsọpụrụ dịrị ndị nsọ ya.
\b
\q1 Toonu \nd Onyenwe anyị\nd*.
\c 150
\cl Abụ Ọma 150
\s1 Ka ihe niile too Onyenwe anyị
\q1 
\v 1 Toonu \nd Onyenwe anyị\nd*.
\b
\q1 Toonu Chineke nʼime ụlọnsọ ya.
\q2 Toonu ya, na mbara igwe nke ike ya.
\q1 
\v 2 Toonu ya, nʼihi ọrụ niile ọ rụrụ site nʼike ya.
\q2 Toonu ya, nʼihi ịdị ukwuu ya nke kachasị ịdị ukwuu niile.
\q1 
\v 3 Werenụ opi ike too ya,
\q2 werekwanụ ụbọ akwara na une too ya,
\q1 
\v 4 jirinụ ihe iti egwu na ite egwu too ya,
\q2 jirikwanụ ụbọ akwara dị iche iche na ọja too ya,
\q1 
\v 5 werenụ ogene too ya,
\q2 werekwanụ ogene na-ada oke ụda too ya.
\b
\q1 
\v 6 Ka ihe niile na-eku ume too \nd Onyenwe anyị\nd*.
\b
\q1 Toonu \nd Onyenwe anyị\nd*.\f + \fr 150:6 \ft Mgbe mmadụ na-eti, Toonu Onyenwe anyị, ya na onye na-eti Haleluya, na-ekwu otu ihe ahụ.\f*
