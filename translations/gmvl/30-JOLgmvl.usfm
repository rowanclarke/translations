\id JOL - Gamo Full Bible final version
\h Iyu7eele Tinbite
\toc1 Iyu7eele Tinbite
\toc2 Iyu7eele Tinbite
\toc3 Iyu
\mt1 Iyu7eele Tinbite
\imt1 Giddo Qofa
\ip Nabe Iyu7eeli hayssa biitta bolla aydeppe ayde gakkanaas de7idaakko iza duussa gishshas erettiza daro miishshi deenna; gido attiin maxaafazi beettiday Kirstoosi yelettanaappe kase 500 layththa heeran woykko 400 layththa heeran gidana geetetti qofettees. Hessi he wodezikka Paarise kawoteththa wodenna; Iyu7eeli Isra7eele deren wolqqama booley dendidi daro miish mooriin koshay biitta bolla dendidayssa yootees; heyti he hanoti Godaa yuussa gallassay matishin iza geeshsha qofaara eqettizayta ubbaa izi qaxxayanayssa gujjidi erisees. Nabezi derey maaroteththan gelana mala Xoossi asaa xeygizayssa qoncciseththan asay maaroteththan gelikko izikka beni dereza hanoteththaako simmidi deraa anjjanayssa asaa qofsees; iza tinbiteza giddofe keehi qoncci beettiza ufayssa qaalay Xoossi maccanne attuma naateththata bolla, cimata bolla, dereza ubbaa bollaka ba Ayana yeddanayssa qonccisees.
\iot Ha Maxaafay Oykkida Kumeththa Qofa
\io1 Boolenne morkke ola \ior 1:1—2:17\ior*
\io1 Godaa gallas \ior 2:18-32\ior*
\io1 GODAY kawoteththata qaxxayana qaxxayo \ior 3:1-21\ior*
\c 1
\s1 Booley Gaththida Qoho
\p 
\v 1 Sinththafe hananayssa Xoossi Iyu7eeles yootida qaalay hayssa;
\q2 
\v 2 intte cimati hayssa siyite;
\q2 Yuhuda deren dizayti wurikka
\q2 hayssa ezgi siyite.
\q1 Hayssa mala hanoy kase
\q2 intte wode gidiin woykko
\q2 kase intte aawata wode
\q2 hani erizee?
\q1 
\v 3 Intte hayssa intte naytas yootite;
\q2 intte nayti qasse
\q2 bantta naytas yootetto;
\q2 nayta naytikka
\q2 kaalliza yeletas yootetto.
\q1 
\v 4 Gondoy mishin attida kaththaa
\q2 biitta maate
\q2 booley mides;
\q2 izappe attidayssa uusho carkoththo
\q2 shociza di7o mala booley dhayssides;
\q2 izappe attidayssa qasse
\q2 gumbaroy mides.
\q1 
\v 5 Hessafe guye woyne ushshu
\q2 intte demmontta
\q2 gishshas yeekkite;
\q2 intteno maththottizaytoo!
\q2 Intte dhiskizasoppe
\q2 beeggidi waassite;
\q2 intteno wonttan wonttan
\q2 woyne ushshu uyizaytoo!
\q2 Camo yeeho yeekkite.
\q1 
\v 6 Qooday baynda booley
\q2 ola asa mala
\q2 ta dereza bolla yides;
\q2 iza achchay
\q2 gaammo achcha mala;
\q2 iza gaagina achchay
\q2 macca gaammo
\q2 gaagina achcha mala.\x - \xo 1:6 \xt Ajju 9:8\x*
\q1 
\v 7 Ta woyne miththa ayfeza
\q2 mulera dhayssides;
\q2 balase geetettiza miththa
\q2 ubbaa menththereththides;
\q2 miththa haggati
\q2 mulera booxxana gakkanaas
\q2 poqoza mulera poqqi
\q2 denththichides.
\q1 
\v 8 Hessa gishshas izo ekkana
\q2 giigsidayssi hayqqiin
\q2 maaqa may7ada yeekkiza
\q2 geela7oy mala intteka yeekkite.
\q1 
\v 9 GODAA Keeththan yarshos shiiqana
\q2 kath gidiin woykko
\q2 woyne ushshay baynda gishshas
\q2 GODAAS ooththiza qeeseti
\q2 yeekkeettes.
\q1 
\v 10 Goyidi zerida kaththay meli dhayiin
\q2 woyne miththay tokettidi
\q2 melida gishshas zaytey dhaydes;
\q2 hessa gishshas
\q2 biittaya yeekkawus.
\q1 
\v 11 Gistteynne banggay haraykka
\q2 bone kaththi wurikka
\q2 dhayda gishshas
\q2 intteno goshshanchchatoo
\q2 ceecite;
\q2 intteno, woyne miththata
\q2 godatikka yeekkite.
\q1 
\v 12 Woyne miththatinne balase
\q2 miththati shullida;
\q2 oroomaanenne temire miththati,
\q2 laadeynne hara ayfe ayfiza
\q2 miththati wurikka melida;
\q2 hessa gaason addafe
\q2 ufayssi asappe haakkides.\f + \fr 1:12 \fqa Laade: \ft Laade geetettizayssi issi issi bagga gamoththo qaalan dhano geetettees.\f*
\q1 
\v 13 Intte intte Xoossa
\q2 yarsho shiishshiza kath gidiin
\q2 woykko woyne ushshi
\q2 baynda gishshas
\q2 intteno ta Godaa
\q2 oosanchchata gidida
\q2 qeesetoo! Ane haa yiidi
\q2 maaqa may7idi
\q2 kumeththa omars yeekkite.
\q2 Intteno yarsho yarshizason
\q2 ooththizaytoo!
\q2 Intte, «Wuu! Wuy!» gi waassite.
\q1 
\v 14 Dumma xooma gallas awajjite;
\q2 ayana shiiqos asa xeygite;
\q2 deren diza cimatanne asaa ubbaa
\q2 nu GODAA keeththan shiishshidi
\q2 pude GODAAKKO waassite.
\q1 
\v 15 Aye ana! GODAA gallassi matides.
\q2 Ubbaa dandayza Xoossay
\q2 dhayssizaaz ehiza
\q2 gallassi gakkides.
\q2 He gallassays aayye ana!\x - \xo 1:15 \xt Isa 13:6\x*
\q1 
\v 16 Kaththi nu sinththafe dhaydes;
\q2 ufayssinne ilisi nu Xoossa
\q2 Keeththafe mule dhaydes.
\q1 
\v 17 Zerettida kaththay wuri
\q2 biitta garsan
\q2 wooqqi dhaydes;
\q2 kaththi biittafe dhayda gishshas
\q2 kase kath woththiza miishshati
\q2 wurikka mela deettes.
\q2 Gootaratikka laalettida.
\q1 
\v 18 Mehey miza maatay gaden
\q2 baynda gishshas
\q2 meheti koshattidi waasseettes;
\q2 dorsa wudetikka maatay dhayiin
\q2 daro waaye bolla deettes.
\q1 
\v 19 GODAWU! Demba maata ubbaa
\q2 tamay mida gishshas
\q2 wora miththaaka
\q2 tamay mida gishshas
\q2 ta neekko waassays.
\q1 
\v 20 Shaafati melida gishshas
\q2 demban diza maatay wurikka
\q2 xuugettida gishshas
\q2 wora do7atikka
\q2 neekko waasseettes.
\c 2
\s1 Xoossa Yuussa Gallas Bessiza Malata
\q1 
\v 1 Xiyoonen zaye zayite;
\q2 geeshsha zuma bolla waassite!
\q2 GODAA yuussa
\q2 gallassi gakkida gishshas
\q2 biitta bolla dizay
\q2 wurikka kokkoro.
\q1 
\v 2 He gallassay dhumanne
\q2 tulala gallassa;
\q2 shaaranne sakkanna
\q2 dhuma gallassa;
\q2 wontta poo7oy eeson
\q2 zumata gakkiza mala
\q2 wolqqama booley
\q2 biitta ubbaan may7ana;
\q2 hessa malay
\q2 hayssafe kase hanibeenna;
\q2 hayssafe guyenkka
\q2 wodenkka hanenna.
\q1 
\v 3 He booleti ba sinththan beettidaazi
\q2 ubbaa tama mala maana;
\q2 tama laco mala xuuggana;
\q2 buro istta gakkontta biittay
\q2 Edene gannate mala
\q2 cilila biitta shin
\q2 istti gakki aadhdhida biittay
\q2 aykkoy baynda
\q2 bazzo biitta gidana;
\q2 booleti mishin attida
\q2 miishshika beettenna.
\q1 
\v 4 Isttas medhay para mala;
\q2 istta buussay
\q2 ola para buussa mala.
\q1 
\v 5 Para-gaare giirissa mala
\q2 giiris sissishe
\q2 zumata bollara guppeettes;
\q2 tamay buura miza mala
\q2 beettida miishsha
\q2 ubbaa xuuggana;
\q2 giigettida mino olanchchata
\q2 salfe mala giireettes.\x - \xo 2:4-5 \xt Ajju 9:7-9\x*
\q1 
\v 6 Istta be7idi derey kokkorana;
\q2 asa ayfesoy wurikka
\q2 babon boottana.
\q1 
\v 7 Ola qarata mala
\q2 gede sinththe beettes;
\q2 olanchchata mala
\q2 dirsa bollara guppi aadhdhana;
\q2 wurikka sitti giidi
\q2 gede sinththe baana;
\q2 ba biza ogeppe hara oge beettenna.
\q1 
\v 8 Issoy issaara sugetettenna;
\q2 issoy issoy ba oge yeddenna;
\q2 ba morkke ola miish ubbaa
\q2 dhayssidi aadhdhi baana;
\q2 aykkoyka istta teqqenna.
\q1 
\v 9 Istti katamaza worajjana;
\q2 katama gimbeza bolla
\q2 istti woxxana;
\q2 guppi guppidi
\q2 keeththata bolla kezana;
\q2 kayso mala maskootera
\q2 soo gelana.
\q1 
\v 10 Biittay istta sinththan kokkorana
\q2 saloykka qaaxxana;
\q2 awa ayfeynne aginay dhumana;
\q2 xoolintteyka poo7o immenna.\x - \xo 2:10 \xt Ajju 8:12\x*
\q1 
\v 11 GODAY ba olanchchata
\q2 sinththan dada mala guummana;
\q2 iza olanchchati ay mala daroo!
\q2 Iza azazo ooththizayti
\q2 ay mala wolqqamaa!
\q2 tumappeka GODAA gallassay
\q2 keehi wolqqama;
\q2 keehi babisiza he gallassaa
\q2 danday eqqanay oonee?\x - \xo 2:11 \xt Ajju 6:17\x*
\s1 Maareteththa Xeys
\p 
\v 12 GODAY, «Ha7ikka gidikko
\q2 xooman yeehoninne ceecen intte
\q2 kumeththa wozinappe
\q2 ha taakko simmite.
\q1 
\v 13 Intte intte kayo bessanaas
\q2 may7o daaketh xalla gidenna;
\q2 hessafe bollara intte wozinay
\q2 meqqiin maarettite;
\q2 GODAA intte Xoossay
\q2 kiyanne maariza Xoossa,
\q2 hanqoska eesotenna;
\q2 mernaa siiqon izi durenne
\q2 qaxxayanaas eesotontta Xoossa;
\q2 hessa gishshas
\q2 intte izakko simmite.
\q1 
\v 14 Oonee erizay GODAA intte Xoossay
\q2 ba hanqoza zaaridi
\q2 inttena anjjanaakko,
\q2 intteka he wode
\q2 GODAA intte Xoossas
\q2 kaththa yarshonne
\q2 ushsha yarsho shiishshandeta.
\q1 
\v 15 Xiyoone zuma bolla zaye punnite;
\q2 dereza ayana shiiqos xeygite;
\q2 xoomakka awajjite.
\q1 
\v 16 Dereza ubbaa issi soo shiishshite;
\q2 geeshsha duulatas giigsite;
\q2 cimata xeygite;
\q2 naytanne buro dhammiza
\q2 naytakka ubbaa shiishshite;
\q2 mishiratikka mishira keeththafe
\q2 attontta kezetto.
\q1 
\v 17 GODAAS ooththiza qeesetikka
\q2 yarsho yarshizasozassinne
\q2 asi simerettizaso
\q2 giddon eqqidi yeekketto;
\m GODAWU! Neni ne derezas qadhetta;
\q2 kawoteththati istta Xoossay
\q2 awan dizee?
\q2 giidi nuna kadhanaassinne
\q2 istti nu bolla
\q2 miicci kaa7ana mala
\q2 ne istta ooththofa» getto.
\s1 Goday Ba Deraas Immida Hidota
\b
\q1 
\v 18 GODAY biittays diza
\q2 misheteththafe dendidayssan
\q2 ba derezas qadhettides.
\q1 
\v 19 Hessa gishshas GODAY,
\q2 «Intte kath, woyne ushshinne
\q2 wogara zayte kallana gakkanaas
\q2 ta inttes immanaas
\q2 hayssafe guye
\q2 kawoteththati inttena
\q2 baas kaassa miish histtana mala
\q2 ta isttas aaththa immike.
\q1 
\v 20 Pudehappe yaana olanchchata
\q2 ta inttefe haassana;
\q2 duge bazzo zaara gooddana;
\q2 sinththati yizayta duge
\q2 hayqo abban yeddana;
\q2 guyera yizayta Mediteraane
\q2 abban yeddana;
\q2 heen istta ahay zeeqqana;
\q2 tumappe tani GODAY
\q2 gita miish ooththadis.
\m 
\v 21 Biittayee babbofa;
\q2 GODAY nees ooththida
\q2 gita miishsha gishshas ufayetta!
\q1 
\v 22 Intteno biitta bolla diza
\q2 do7atoo babbofte;
\q2 kase intte izan heemettiza
\q2 gadey cililides;
\q2 miththatikka ayfida; balaseynne
\q2 woyne miththay
\q2 keehi daro ayfides.
\q1 
\v 23 Intteno Xiyoone deretoo,
\q2 GODAAN intte Xoossan
\q2 ufayssi ooththite;
\q2 izi tumu pirdidi
\q2 badhdhesa iranne
\q2 ofinththa ira wogara immides.
\q1 
\v 24 Intte kase kath bukkiza balen
\q2 kaththi kumana;
\q2 woyne ushshinne
\q2 wogara miththa zaytey
\q2 kase isttan gum7ettiza
\q2 ollata kumi palahana.
\q1 
\v 25 Hayssafe kase wolqqama olanchcha
\q2 misatiza ta yeddida uusho
\q2 carkoththo shociza booleti,
\q2 gumbarotinne gondoti,
\q2 kase mida kaththaa gishshas
\q2 ta inttes zaara immana.
\q1 
\v 26 Intte buro daro miidi kallana;
\q2 inttes malalisiza miishshata
\q2 ta ooththida gishshas
\q2 intte tana GODAA
\q2 intte Xoossaa galatana;
\q2 hayssafe guye ta deraa
\q2 yeellay gakkenna.
\q1 
\v 27 Isra7eele asatoo
\q2 tani intte giddon dizayssanne
\q2 GODAA intte Xoossi
\q2 tana xalla gididayssanne
\q2 taappe haray bayndayssa
\q2 intte erana;
\q2 hessafe guye ta dereza
\q2 yeellay gakkenna» gides.
\s1 Godaa Gallassa
\p 
\v 28 GODAY, «Hayssafe guye
\q2 tani asa ubbaa bolla
\q2 ta Ayana gussana;
\q2 intte macca naytinne attuma
\q2 nayti tinbite haasayana;
\q2 cima asaykka agumo agumettana;
\q2 yelaga naateththati ajjuuta beyana.\x - \xo 2:28-32 \xt Hawa 2:17-21\x*
\q1 
\v 29 Hessaththoka he gallassatan
\q2 taas ooththiza maccassa bollanne
\q2 attumasa bolla tani
\q2 ta Ayana gussana.
\q1 
\v 30 Saloninne sa7an malalisiza
\q2 miishshata ta bessana;
\q2 suuththi, tamaynne
\q2 cuwa tuussi beettana.
\q1 
\v 31 Gita babisiza Godaa gallassay
\q2 yaanaappe kasetidi
\q2 arshey dhumana;
\q2 aginaykka suuth aaththana.\x - \xo 2:31 \xt Mato 24:29; Mar 13:24-25; Luqa 21:25; Ajju 6:12-13\x*
\q1 
\v 32 GODAA sunth xeygizay
\q2 wurikka attana;
\q2 GODAY kase
\q2 yootida mala
\q2 Xiyoone zuma bollafenne
\q2 Yerusalaameppe
\q2 atoteththi beettana;
\q2 attanayta garsan GODAY
\q2 xeygidayti daana» gides.\x - \xo 2:32 \xt Oro 10:13\x*
\c 3
\s1 Kawoteththata Bolla Yida Pirda
\p 
\v 1 Xoossi,
\q1 «He wode tani Yerusalaameppenne
\q2 Yuhudappe di7etti ekettida
\q2 miish ubbaa zaarana.
\q1 
\v 2 Tani kawoteththata
\q2 ubbaa shiishshada
\q2 duge Iyoosaafixe\f + \fr 3:2 \ft Ibraaweta qaalara Iyoosaafixe guussi Xoossi pirdees guussa.\f*
\q2 zulle woththana;
\q2 heenkka ta istta bolla pirdana;
\q2 gaasoykka ta dere Isra7eele asaa
\q2 kawoteththata giddon laallidi
\q2 istti biitta gishetti
\q2 ekkida gishshassa.
\q1 
\v 3 Istti ba di7i ehida
\q2 ta dereta gishetti ekkanaas
\q2 istta bolla saama yeggida;
\q2 layma maccassata demmanaas
\q2 attuma nayta aaththi immida;
\q2 woyne ushshu uyanaas
\q2 macca nayta
\q2 aylleteththas bayzida.
\q1 
\v 4 Intteno Xiroose,
\q2 Sidoonanne Filisxeeme asatoo!
\q2 Intte ay ooththishe deetii?
\q2 Intte ta bolla
\q2 halo kessana qoppeetii?
\q2 Intte hessa mala qoppiko
\q2 tanikka kasetada intte bolla
\q2 halo kessana.\x - \xo 3:4-8 \xt Er 47:1-7; Hizi 25:15—28:26; Amo 1:6-10; Sofo 2:4-7; Zaka 9:1-7; Mato 11:21-22; Luqa 10:13-14\x*
\q1 
\v 5 Ta bira, worqqanne
\q2 taas diza al7o miish
\q2 ubbaa intte bonqqi ekkidi
\q2 intte eeqa keeth gelththideta.
\q1 
\v 6 Yuhudanne Yerusalaame yeletata
\q2 istta dere dhassafe haassi efidi
\q2 Girike asas bayzideta.
\p 
\v 7 «Hekko tani ha7i istti bayzetti dizasoppe istta denththeththada zaarana; intte istta bolla gaththida qohoza ta intte bolla zaara ehana.
\v 8 Intte macca naytinne attuma nayti Yuhuda asaas bayzettana mala ta ooththana; isttika haaho deren diza Saabaane asaas aaththi bayzana; hayssa wursa yootiday tana GODAA.
\q1 
\v 9 «Hayssa ubbaa
\q2 kawoteththatas awajjite!
\q2 olas giigettite!
\q2 ola qarata denththeththite!
\q2 Intte olanchchati ubbay
\q2 kezidi morkketa oletto!
\q1 
\v 10 Maarasha giththa mashsha qoxxite;
\q2 baaca qasse toora qoxxite;
\q2 laafaykka bana,
\q2 ‹Tani mino asa› go.\x - \xo 3:10 \xt Isa 2:4; Miki 4:3\x*
\q1 
\v 11 Intteno yuuyi aadhdhanaas diza kawoteththatoo!
\q2 Intte wurikka eeson kezite!
\q2 Hirki shoobban issi bolla shiiqite.
\q2 GODAWU, neni
\q2 ne olanchchata kiita!
\b
\q1 
\v 12 «Kawoteththati ubbay dendidi
\q2 duge Iyoosaafixe shoobba betto;
\q2 tani Xoossay intte yuushon diza
\q2 kawoteththata bolla pirdanaas
\q2 ta heen uttana.
\q1 
\v 13 Istta iitateththi keehi darides;
\q2 hessa gishshas kaxxida kaththi
\q2 baacan cakettiza mala
\q2 istta cakkite;
\q2 woyne miththa ayfey
\q2 gum7ettizason kumidi
\q2 yedhettiza mala
\q2 intte istta yedhettite» gides.\x - \xo 3:13 \xt Ajju 14:14-16,19-20; 19:15\x*
\b
\q1 
\v 14 Yo7o pirdiza zullen
\q2 GODAY pirdiza gallassi gakkides;
\q2 hessa gishshas daro derey
\q2 heen shiiqi uttides.
\q1 
\v 15 He gallas arsheynne
\q2 aginay dhumana;
\q2 xoolintteyka poo7enna.
\q1 
\v 16 GODAY Xiyoone zumaa bolla
\q2 Yerusalaamen dishe
\q2 babisiza ba qaala giiris sissana;
\q2 saloynne sa7ay qaaxxana;
\q2 GODAY gidikko
\q2 ba dere Isra7eeles
\q2 shiiqi attizaso gidana.
\s1 Xoossa Deraa Anjjeteth
\q1 
\v 17 «Isra7eele asawu! He wode tani
\q2 GODAA intte Xoossa gididayssa
\q2 intte erana;
\q2 tani geesh gidida ta zuma
\q2 Xiyoone bolla de7ana;
\q2 Yerusalaamey anjjettida
\q2 katama gidana;
\q2 hessafe guye hara allaga wottadaray
\q2 izo worajjenna.
\b
\q1 
\v 18 «He wode zumati wurikka
\q2 woyne miththan kumana;
\q2 zumbullan daro maaththa miizati
\q2 heemettana;
\q2 GODAA Keeththafe
\q2 pulttoy pulttana;
\q2 Yuhuda deren diza shaafata
\q2 ubbaa haaththi kumana;
\q2 Shiixime shoobbay haath kallana.
\q1 
\v 19 Gibxe asaynne Eedoome asay
\q2 Yuhuda asaa bolla
\q2 gene ooththida gishshas
\q2 qasseka xillo asaa wodhida gishshas
\q2 Gibxey bazzo gidana;
\q2 Eedoomey asi bayndaso gidana.
\q1 
\v 20-21 Hessa gakkanawu tani
\q2 halo kessontta aggida
\q2 xillota suuththa gishshas
\q2 halo kessana;
\q2 Yuhudaynne Yerusalaamey
\q2 qasse mernaas ta derey
\q2 de7izaso gidana;
\q2 tanikka Xoossay
\q2 Xiyoone zuma bolla
\q2 de7ana» gides.
