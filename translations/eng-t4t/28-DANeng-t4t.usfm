\p
\v 16 \w Shadrach|strong="H7715"\w*, \w Meshach|strong="H4336"\w*, \w and|strong="H6032"\w* Abednego \w replied|strong="H6032"\w*, “\w Nebuchadnezzar|strong="H5020"\w*, \w we|strong="H3068"\w* \w do|strong="H5922"\w* \w not|strong="H3809"\w* \w need|strong="H2818"\w* \w to|strong="H5922"\w* defend our \add actions\add* \w to|strong="H5922"\w* \w you|strong="H5922"\w* \w in|strong="H5922"\w* \w this|strong="H1836"\w* \w matter|strong="H6600"\w*.  
\v 17 \w If|strong="H2006"\w* \w we|strong="H3068"\w* \w are|strong="H1768"\w* thrown into \w the|strong="H4481"\w* \w blazing|strong="H3345"\w* furnace, \w the|strong="H4481"\w* God \w whom|strong="H1768"\w* \w we|strong="H3068"\w* worship \w is|strong="H1768"\w* \w able|strong="H3202"\w* \w to|strong="H3202"\w* \w rescue|strong="H7804"\w* \w us|strong="H7804"\w*. Sir, \w he|strong="H1768"\w* \w will|strong="H1768"\w* \w rescue|strong="H7804"\w* \w us|strong="H7804"\w* \w from|strong="H4481"\w* \w your|strong="H6399"\w* \w power|strong="H3028"\w*.  
\v 18 \w But|strong="H1768"\w* \add even\add* \w if|strong="H2006"\w* \w he|strong="H1768"\w* \w does|strong="H1934"\w* \w not|strong="H3809"\w* \add rescue us\add*, \w you|strong="H1768"\w* need \w to|strong="H3046"\w* \w know|strong="H3046"\w* \w that|strong="H1768"\w* \w we|strong="H3068"\w* \w will|strong="H1768"\w* never \w worship|strong="H5457"\w* \w your|strong="H6399"\w* gods \w or|strong="H2006"\w* \w the|strong="H1768"\w* \w gold|strong="H1722"\w* \w statue|strong="H6755"\w* \w that|strong="H1768"\w* \w you|strong="H1768"\w* \w have|strong="H1934"\w* \w set|strong="H6966"\w* \w up|strong="H6966"\w*.”   
\p
\v 19 \w Nebuchadnezzar|strong="H5020"\w* \w was|strong="H5020"\w* extremely angry. \add His being very angry even\add* showed \w on|strong="H5922"\w* \w his|strong="H5922"\w* face. \w He|strong="H1768"\w* commanded \w that|strong="H1768"\w* \w the|strong="H5922"\w* furnace should be made \w seven|strong="H7655"\w* \w times|strong="H7655"\w* \w as|strong="H1768"\w* hot \w as|strong="H1768"\w* usual.  
\v 20  \add After that was done,\add* \w he|strong="H1768"\w* commanded some \w of|strong="H1768"\w* \w the|strong="H1768"\w* \add very\add* \w strong|strong="H1401"\w* \w men|strong="H1400"\w* \w of|strong="H1768"\w* \w his|strong="H1768"\w* \w army|strong="H2429"\w* \w to|strong="H2429"\w* \w tie|strong="H3729"\w* \w Shadrach|strong="H7715"\w*, \w Meshach|strong="H4336"\w* \w and|strong="H4336"\w* Abednego, \w and|strong="H4336"\w* \add then\add* \w to|strong="H2429"\w* throw them \w into|strong="H7412"\w* \w the|strong="H1768"\w* \w blazing|strong="H3345"\w* furnace.  
\v 21 So \add the soldiers\add* \w tied|strong="H3729"\w* them \w up|strong="H3729"\w* and threw them \w into|strong="H1459"\w* the furnace, while they \w were|strong="H1400"\w* wearing their \w clothes|strong="H3831"\w*.  
\v 22 \w Because|strong="H6903"\w* \w the|strong="H3606"\w* \w fire|strong="H5135"\w* \w had|strong="H4430"\w* been made very hot \w because|strong="H6903"\w* \w the|strong="H3606"\w* \w king|strong="H4430"\w* \w had|strong="H4430"\w* very strongly ordered \w them|strong="H1994"\w* \w to|strong="H1994"\w* do \w that|strong="H1768"\w*, \w the|strong="H3606"\w* \w flames|strong="H7631"\w* \add leaped out and\add* \w killed|strong="H6992"\w* \w the|strong="H3606"\w* soldiers \w as|strong="H3606"\w* \w they|strong="H3606"\w* \w were|strong="H1400"\w* throwing \w the|strong="H3606"\w* \w men|strong="H1400"\w* into \w the|strong="H3606"\w* \w fire|strong="H5135"\w*!  
\v 23 So \w Shadrach|strong="H7715"\w*, \w Meshach|strong="H4336"\w*, \w and|strong="H4336"\w* Abednego \w fell|strong="H5308"\w* \w into|strong="H1459"\w* the roaring \w flames|strong="H5135"\w*.   
\p
\v 24 But as \w Nebuchadnezzar|strong="H5020"\w* \w was|strong="H4430"\w* watching, \w he|strong="H5020"\w* \w was|strong="H4430"\w* amazed. \w He|strong="H5020"\w* suddenly jumped \w up|strong="H6966"\w* \w and|strong="H6032"\w* shouted \w to|strong="H4430"\w* \w his|strong="H5020"\w* advisors, “Did \w we|strong="H3068"\w* \w tie|strong="H3729"\w* \w up|strong="H6966"\w* \w three|strong="H8532"\w* \w men|strong="H1400"\w* \w and|strong="H6032"\w* throw them \w into|strong="H1459"\w* \w the|strong="H5020"\w* \w flames|strong="H5135"\w*, \w or|strong="H3809"\w* \w not|strong="H3809"\w*?”  
\p \w They|strong="H3809"\w* \w replied|strong="H6032"\w*, “Yes, \w O|strong="H3068"\w* \w king|strong="H4430"\w*, \add we did\add*.”   
\p
\v 25 Nebuchadnezzar shouted, “\add Look\add*! \w I|strong="H1768"\w* \w see|strong="H2370"\w* four \w men|strong="H1400"\w* \w in|strong="H1981"\w* \w the|strong="H1768"\w* \w fire|strong="H5135"\w*! \w They|strong="H1768"\w* \w have|strong="H1768"\w* \w no|strong="H3809"\w* ropes on them, \w they|strong="H1768"\w* \w are|strong="H1768"\w* \w walking|strong="H1981"\w* around, \w and|strong="H6032"\w* \add the flames\add* \w are|strong="H1768"\w* \w not|strong="H3809"\w* hurting them! \w And|strong="H6032"\w* \w the|strong="H1768"\w* \w fourth|strong="H7244"\w* \w man|strong="H1400"\w* looks \w like|strong="H1821"\w* \w a|strong="H3068"\w* divine being!”   
\p
\v 26 \w Nebuchadnezzar|strong="H5020"\w* \w came|strong="H7127"\w* closer \w to|strong="H5312"\w* \w the|strong="H4481"\w* opening \w of|strong="H4481"\w* \w the|strong="H4481"\w* flaming furnace, \w and|strong="H6032"\w* \w he|strong="H1768"\w* shouted, “\w Shadrach|strong="H7715"\w*, \w Meshach|strong="H4336"\w*, \w and|strong="H6032"\w* Abednego, \w you|strong="H1768"\w* \w who|strong="H1768"\w* worship \w the|strong="H4481"\w* Supreme God, \w come|strong="H7127"\w* \w out|strong="H5312"\w* \w of|strong="H4481"\w* \w there|strong="H1768"\w*! \w Come|strong="H7127"\w* \w here|strong="H5312"\w*!” \w So|strong="H1768"\w* \w they|strong="H1768"\w* stepped \w out|strong="H5312"\w* \w of|strong="H4481"\w* \w the|strong="H4481"\w* \w fire|strong="H5135"\w*.   
\p
\v 27 \w Then|strong="H4430"\w* all \w the|strong="H1768"\w* \w king|strong="H4430"\w*’s \w officials|strong="H1907"\w* crowded \w around|strong="H3673"\w* them. \w They|strong="H1768"\w* \w saw|strong="H2370"\w* \w that|strong="H1768"\w* \w the|strong="H1768"\w* \w flames|strong="H5135"\w* \w had|strong="H4430"\w* \w not|strong="H3809"\w* harmed them. \w The|strong="H1768"\w* \w flames|strong="H5135"\w* \w had|strong="H4430"\w* \w not|strong="H3809"\w* \add even\add* \w singed|strong="H2761"\w* any \w of|strong="H4430"\w* \w the|strong="H1768"\w* \w hair|strong="H8177"\w* \w on|strong="H7981"\w* their \w heads|strong="H7217"\w* \w or|strong="H3809"\w* scorched any \w of|strong="H4430"\w* their clothes! \w There|strong="H1768"\w* \w was|strong="H1655"\w* \w not|strong="H3809"\w* \add even\add* any \w smell|strong="H7382"\w* \w of|strong="H4430"\w* smoke \w on|strong="H7981"\w* them!   
\p
\v 28  \add Then\add* \w Nebuchadnezzar|strong="H5020"\w* \w said|strong="H6032"\w*, “Praise \w the|strong="H3606"\w* God \w whom|strong="H1768"\w* \w Shadrach|strong="H7715"\w*, \w Meshach|strong="H4336"\w*, \w and|strong="H6032"\w* Abednego \add worship\add*! \w He|strong="H1768"\w* \w sent|strong="H7972"\w* one \w of|strong="H4430"\w* \w his|strong="H5922"\w* angels \w to|strong="H5922"\w* \w rescue|strong="H7804"\w* these \add three\add* men \w who|strong="H1768"\w* \w worship|strong="H5457"\w* \w him|strong="H5922"\w* \w and|strong="H6032"\w* \w trust|strong="H7365"\w* \w in|strong="H5922"\w* \w him|strong="H5922"\w*. \w They|strong="H1768"\w* ignored \w my|strong="H5922"\w* \w command|strong="H4406"\w*; \w they|strong="H1768"\w* insisted \w that|strong="H1768"\w* \w they|strong="H1768"\w* would \w worship|strong="H5457"\w* only \w their|strong="H3606"\w* God, \w and|strong="H6032"\w* \w were|strong="H1768"\w* willing \w to|strong="H5922"\w* die \w instead|strong="H5922"\w* \w of|strong="H4430"\w* worshiping \w any|strong="H3606"\w* \w other|strong="H3861"\w* god.  
\v 29 \w Therefore|strong="H3606"\w*, \w I|strong="H4481"\w* am \add now\add* making \w this|strong="H1836"\w* \w decree|strong="H2942"\w*: ‘If \w any|strong="H3606"\w* \w people|strong="H5972"\w*, \w from|strong="H4481"\w* \w any|strong="H3606"\w* country \w or|strong="H3809"\w* people-group \w or|strong="H3809"\w* \w any|strong="H3606"\w* \w language|strong="H3961"\w* group, criticize \w the|strong="H3606"\w* God \w whom|strong="H1768"\w* \w Shadrach|strong="H7715"\w*, \w Meshach|strong="H4336"\w*, \w and|strong="H4336"\w* Abednego worship, \w they|strong="H1768"\w* \w will|strong="H1768"\w* \w be|strong="H3809"\w* \w cut|strong="H5648"\w* \w in|strong="H5922"\w* \w pieces|strong="H1917"\w* \w and|strong="H4336"\w* \w their|strong="H3606"\w* \w houses|strong="H1005"\w* \add will be torn down and\add* \w made|strong="H5648"\w* into \w a|strong="H3068"\w* pile \w of|strong="H4481"\w* rubble. \w There|strong="H1768"\w* \w is|strong="H1768"\w* \w no|strong="H3809"\w* other god \w who|strong="H1768"\w* \w can|strong="H3202"\w* \w rescue|strong="H5338"\w* \w people|strong="H5972"\w* like \w this|strong="H1836"\w*!’ ”   
\p
\v 30 \w Then|strong="H4430"\w* \w the|strong="H4430"\w* \w king|strong="H4430"\w* gave \w Shadrach|strong="H7715"\w*, \w Meshach|strong="H4336"\w*, \w and|strong="H4336"\w* Abednego more important positions \w in|strong="H4430"\w* Babylon \w province|strong="H4083"\w* than they \w had|strong="H4430"\w* before.   
\c 4  
\s1 Nebuchadnezzar dreamed about a tree  
\p
\v 1  \add Several years after \add* \w Nebuchadnezzar|strong="H5020"\w* \add started to rule, he sent this message \add* \w to|strong="H1934"\w* \add the people of \add* every nation \w and|strong="H1005"\w* people-group \w and|strong="H1005"\w* all language groups \w in|strong="H1965"\w* \w his|strong="H5020"\w* empire. \add He wrote,\add*  
\pi1 “I wish/hope \w that|strong="H1965"\w* everything is going very well with you!   
\pi1
\v 2 I want \w you|strong="H5922"\w* \w to|strong="H5922"\w* know \w about|strong="H5922"\w* \add all\add* \w the|strong="H5922"\w* wonderful miracles [DOU] \w that|strong="H2370"\w* \w the|strong="H5922"\w* Supreme God has performed \w for|strong="H5922"\w* \w me|strong="H5922"\w*.   
\q1
\v 3 \w He|strong="H1768"\w* performs great miracles,  
\q2 \w and|strong="H2493"\w* does wonderful \w things|strong="H3606"\w*.  
\q1 \w His|strong="H6925"\w* kingdom \w will|strong="H1768"\w* last forever;  
\q2 \w his|strong="H6925"\w* rule \add over people\add* \w will|strong="H1768"\w* never end.   
\b  
\pi1
\v 4 I, Nebuchadnezzar, was living \w in|strong="H5954"\w* my palace. I was living luxuriantly, \w and|strong="H2493"\w* everything was going very well \w for|strong="H3046"\w* \w me|strong="H6925"\w*.  
\v 5 \w But|strong="H1768"\w* \w one|strong="H6922"\w* night \w I|strong="H1768"\w* \w had|strong="H1768"\w* \w a|strong="H3068"\w* \w dream|strong="H2493"\w* \w that|strong="H1768"\w* caused \w me|strong="H6925"\w* \w to|strong="H6925"\w* \w be|strong="H1841"\w* very afraid. \w I|strong="H1768"\w* saw visions \w that|strong="H1768"\w* terrified \w me|strong="H6925"\w* \w as|strong="H1768"\w* \w I|strong="H1768"\w* lay \w on|strong="H5705"\w* \w my|strong="H1768"\w* bed.  
\v 6 \w So|strong="H1768"\w* \w I|strong="H1768"\w* summoned \w all|strong="H3606"\w* \w the|strong="H3606"\w* wise men \w in|strong="H1768"\w* Babylon, \w in|strong="H1768"\w* order \w that|strong="H1768"\w* \w they|strong="H1768"\w* would come \w and|strong="H7229"\w* tell me \w what|strong="H1768"\w* it meant.  
\v 7 All \w the|strong="H5922"\w* men who worked magic, \w the|strong="H5922"\w* fortune-tellers, \w the|strong="H5922"\w* men who worked sorcery, \w and|strong="H1934"\w* men who studied \w the|strong="H5922"\w* stars came \w to|strong="H5922"\w* \w me|strong="H5922"\w*. I told \w them|strong="H5922"\w* what I \w had|strong="H2370"\w* dreamed, but they could not tell \w me|strong="H5922"\w* what \w it|strong="H5922"\w* meant.  
\v 8 Finally, Daniel \w came|strong="H4291"\w* \w to|strong="H8065"\w* me, \w and|strong="H8065"\w* I \add decided to\add* tell him what I had dreamed. One \w of|strong="H3606"\w* my officials had given him \w a|strong="H3068"\w* new name, Belteshazzar, \w to|strong="H8065"\w* honor my own god. I knew \w that|strong="H3606"\w* \w the|strong="H3606"\w* spirit \w of|strong="H3606"\w* \w the|strong="H3606"\w* holy gods \w was|strong="H3606"\w* \w in|strong="H8631"\w* him.   
\pi1
\v 9 \w So|strong="H4481"\w*, \add using the name that had been given to him\add*, \w I|strong="H4481"\w* said, ‘Belteshazzar, \w you|strong="H4481"\w* are \w the|strong="H3606"\w* most important \w of|strong="H4481"\w* \w all|strong="H3606"\w* \w my|strong="H4481"\w* fortune-tellers. \w I|strong="H4481"\w* know \w that|strong="H3606"\w* \w the|strong="H3606"\w* spirit \w of|strong="H4481"\w* \w the|strong="H3606"\w* holy gods \w is|strong="H3606"\w* \w in|strong="H1753"\w* \w you|strong="H4481"\w*, \w and|strong="H8065"\w* \w that|strong="H3606"\w* \w you|strong="H4481"\w* can reveal \w all|strong="H3606"\w* mysteries. There \w is|strong="H3606"\w* \w none|strong="H3606"\w* \w that|strong="H3606"\w* \w is|strong="H3606"\w* too difficult \w for|strong="H4203"\w* \w you|strong="H4481"\w*. \w So|strong="H4481"\w*, tell \w me|strong="H4481"\w* what \w my|strong="H4481"\w* dream means.  
\v 10 \w This|strong="H5922"\w* is what \w I|strong="H4481"\w* dreamed while \w I|strong="H4481"\w* \w was|strong="H1934"\w* lying \w on|strong="H5922"\w* \w my|strong="H5922"\w* \w bed|strong="H4903"\w*: \w I|strong="H4481"\w* \w saw|strong="H2370"\w* \w a|strong="H3068"\w* large tree \add growing\add* \w in|strong="H5922"\w* \w the|strong="H5922"\w* middle \w of|strong="H4481"\w* \w the|strong="H5922"\w* land.  
\v 11 \w The|strong="H4481"\w* tree \w was|strong="H2423"\w* very strong \w and|strong="H3652"\w* had grown very tall; \add it seemed that\add* \w its|strong="H7113"\w* top reached up \w to|strong="H2429"\w* \w the|strong="H4481"\w* sky, with \w the|strong="H4481"\w* result \w that|strong="H2423"\w* everyone in \w the|strong="H4481"\w* world [HYP] could see \w it|strong="H4481"\w*.  
\v 12 It \w had|strong="H1768"\w* beautiful leaves, \w and|strong="H6523"\w* it \w had|strong="H1768"\w* produced \w a|strong="H3068"\w* lot \w of|strong="H2920"\w* fruit \w for|strong="H1768"\w* people \w to|strong="H5974"\w* eat. \w Wild|strong="H1251"\w* \w animals|strong="H2423"\w* rested \w in|strong="H2508"\w* \w the|strong="H1768"\w* shade \w of|strong="H2920"\w* \w that|strong="H1768"\w* tree, \w and|strong="H6523"\w* birds built nests \w in|strong="H2508"\w* its branches. All \w the|strong="H1768"\w* living creatures everywhere \w in|strong="H2508"\w* \w the|strong="H1768"\w* world got food \w from|strong="H1768"\w* \w that|strong="H1768"\w* tree.   
\pi1
\v 13 While \w I|strong="H4481"\w* \w was|strong="H3825"\w* still lying \w on|strong="H5922"\w* \w my|strong="H5922"\w* bed, \w I|strong="H4481"\w* saw another vision. \w In|strong="H5922"\w* \w the|strong="H5922"\w* vision \w I|strong="H4481"\w* saw \w a|strong="H3068"\w* holy angel coming down \w from|strong="H4481"\w* heaven.  
\v 14 \w The|strong="H5922"\w* angel shouted, “Cut down \w the|strong="H5922"\w* tree, \w and|strong="H4437"\w* cut off \w its|strong="H3046"\w* branches! Strip/Shake off all \w of|strong="H4437"\w* \w its|strong="H3046"\w* leaves, \w and|strong="H4437"\w* scatter \w its|strong="H3046"\w* fruit. Chase away \w the|strong="H5922"\w* animals \w that|strong="H1768"\w* \w are|strong="H1768"\w* lying \w in|strong="H5922"\w* \w the|strong="H5922"\w* shade \w of|strong="H4437"\w* \w the|strong="H5922"\w* tree, \w and|strong="H4437"\w* \w the|strong="H5922"\w* birds \w that|strong="H1768"\w* \w are|strong="H1768"\w* \w in|strong="H5922"\w* \w its|strong="H3046"\w* branches.  
\v 15 \w But|strong="H3606"\w* leave \w the|strong="H3606"\w* stump \w of|strong="H4437"\w* \w the|strong="H3606"\w* tree \w and|strong="H4430"\w* \w its|strong="H6591"\w* roots \w in|strong="H5020"\w* \w the|strong="H3606"\w* ground. Fasten \w a|strong="H3068"\w* band \w of|strong="H4437"\w* iron \w and|strong="H4430"\w* bronze around \w the|strong="H3606"\w* stump, \w and|strong="H4430"\w* allow it \w to|strong="H3202"\w* stay \w there|strong="H6903"\w* \w with|strong="H6903"\w* grass around it.”   
\pi1
\v 16  \add That tree seems to have represented a man, because the angel also said\add*, “Cause \w that|strong="H1768"\w* man \w to|strong="H8036"\w* live \add out in the fields\add* among \w the|strong="H1768"\w* animals \w and|strong="H6032"\w* plants. Cause \w the|strong="H1768"\w* dew \w from|strong="H1768"\w* \w the|strong="H1768"\w* sky \w to|strong="H8036"\w* make \w his|strong="H1768"\w* body damp \add each morning\add*. Do not allow him \w to|strong="H8036"\w* \add continue to\add* \w have|strong="H1768"\w* \w a|strong="H3068"\w* mind like humans; instead, cause him \w to|strong="H8036"\w* \w have|strong="H1768"\w* \w a|strong="H3068"\w* mind like animals \w have|strong="H1768"\w*, \w for|strong="H1768"\w* \w seven|strong="H2298"\w* years.   
\pi1
\v 17 \w The|strong="H3606"\w* holy angels \w have|strong="H1768"\w* decided \w what|strong="H1768"\w* must happen. \w They|strong="H1768"\w* want \w to|strong="H8065"\w* inform \w everyone|strong="H3606"\w* \w that|strong="H1768"\w* \w the|strong="H3606"\w* Supreme God rules over \w all|strong="H3606"\w* \w the|strong="H3606"\w* kingdoms \w in|strong="H8631"\w* \w this|strong="H3606"\w* world. \w He|strong="H1768"\w* \w is|strong="H1768"\w* \w the|strong="H3606"\w* one \w who|strong="H1768"\w* chooses \w who|strong="H1768"\w* \w will|strong="H1768"\w* rule these kingdoms. \w He|strong="H1768"\w* \add sometimes\add* allows very unimportant people \w to|strong="H8065"\w* \w become|strong="H7236"\w* rulers.”   
\pi1
\v 18 Belteshazzar, \w that|strong="H3606"\w* \w is|strong="H3606"\w* what I, King Nebuchadnezzar, saw \w in|strong="H1753"\w* my dream. Now tell me what \w the|strong="H3606"\w* dream means. \w No|strong="H3606"\w* one else can tell me. \add I asked\add* \w all|strong="H3606"\w* \w the|strong="H3606"\w* \w very|strong="H7690"\w* wise men \w in|strong="H1753"\w* my kingdom \add to tell me\add* what \w it|strong="H8460"\w* means, \add but they were unable to do that\add*. \w But|strong="H3606"\w* you can \add tell me\add*, \w because|strong="H3606"\w* \w the|strong="H3606"\w* spirit \w of|strong="H1753"\w* \w the|strong="H3606"\w* holy gods \w is|strong="H3606"\w* \w in|strong="H1753"\w* you.”   
\s1 Daniel explained the dream  
\pi1
\v 19 \w I|strong="H1768"\w*, \w whose|strong="H1768"\w* \add new\add* name \w was|strong="H4430"\w* Belteshazzar, did not say anything \w for|strong="H1768"\w* some time, \add because\add* \w I|strong="H1768"\w* \w was|strong="H4430"\w* very worried/disturbed \add about the meaning of the dream. Finally\add*, \w the|strong="H1768"\w* \w king|strong="H4430"\w* said \w to|strong="H4430"\w* me, “Belteshazzar, \w do|strong="H8065"\w* not be afraid about \w the|strong="H1768"\w* dream \w and|strong="H4430"\w* about \w what|strong="H1768"\w* it means.” \w I|strong="H1768"\w* replied, “Sir, \w I|strong="H1768"\w* wish \w that|strong="H1768"\w* \w the|strong="H1768"\w* events \w that|strong="H1768"\w* \w were|strong="H1768"\w* predicted \w in|strong="H4430"\w* \w your|strong="H1768"\w* dream would happen \w to|strong="H4430"\w* \w your|strong="H1768"\w* enemies, \add and not to you\add*.   
\pi1
\v 20  \add In your dream/vision\add* \w you|strong="H1768"\w* \w saw|strong="H2370"\w* \w a|strong="H3068"\w* very strong \w and|strong="H4430"\w* very tall tree. \w It|strong="H5922"\w* \add seemed to\add* reach \w to|strong="H5922"\w* \w the|strong="H5922"\w* \w sky|strong="H8065"\w*, \add with the result that \add* everyone \w in|strong="H5922"\w* \w the|strong="H5922"\w* world \w could|strong="H1768"\w* \w see|strong="H2370"\w* \w it|strong="H5922"\w*.  
\v 21 \w It|strong="H1932"\w* \w had|strong="H4430"\w* beautiful leaves \w and|strong="H4430"\w* \w it|strong="H1932"\w* \w had|strong="H4430"\w* produced \w a|strong="H3068"\w* lot \w of|strong="H4430"\w* fruit \w for|strong="H5922"\w* people \w to|strong="H5922"\w* eat. Wild animals rested \w in|strong="H5922"\w* \w the|strong="H5922"\w* shade \w of|strong="H4430"\w* \w that|strong="H1768"\w* tree, \w and|strong="H4430"\w* birds built nests \w in|strong="H5922"\w* \w its|strong="H6591"\w* branches.  
\v 22 ◄\w Your|strong="H1768"\w* majesty/\w O|strong="H3068"\w* King►, \w that|strong="H1768"\w* tree \add represents\add* \w you|strong="H1768"\w*! \w You|strong="H1768"\w* \w have|strong="H1934"\w* become very powerful. \add It is as though\add* \w your|strong="H1768"\w* greatness reaches \w up|strong="H1934"\w* \w to|strong="H5922"\w* \w the|strong="H5922"\w* \w sky|strong="H8065"\w*, \w and|strong="H4437"\w* \w you|strong="H1768"\w* \w rule|strong="H7990"\w* people all \w over|strong="H5922"\w* \w the|strong="H5922"\w* world.   
\pi1
\v 23  \add Then\add* \w you|strong="H1768"\w* saw \w a|strong="H3068"\w* holy angel coming down \w from|strong="H4481"\w* \w heaven|strong="H8065"\w*. \w That|strong="H1768"\w* angel said, ‘Cut down \w the|strong="H4481"\w* tree, \w and|strong="H4437"\w* cut off \w its|strong="H3046"\w* branches! Strip/Shake off all \w of|strong="H4481"\w* \w its|strong="H3046"\w* leaves, \w and|strong="H4437"\w* scatter \w its|strong="H3046"\w* fruit. \w But|strong="H1768"\w* \w leave|strong="H7662"\w* \w the|strong="H4481"\w* \w stump|strong="H6136"\w* \w of|strong="H4481"\w* \w the|strong="H4481"\w* tree \w and|strong="H4437"\w* \w its|strong="H3046"\w* \w roots|strong="H8330"\w* \w in|strong="H4437"\w* \w the|strong="H4481"\w* ground. Fasten \w a|strong="H3068"\w* band \w of|strong="H4481"\w* iron \w and|strong="H4437"\w* bronze around \w the|strong="H4481"\w* \w stump|strong="H6136"\w* \w and|strong="H4437"\w* \add allow it to stay there\add* with grass around \w it|strong="H4481"\w*. \add Each morning\add* cause \w the|strong="H4481"\w* dew \w from|strong="H4481"\w* \w the|strong="H4481"\w* \w sky|strong="H8065"\w* \w to|strong="H3046"\w* \w make|strong="H3046"\w* \w this|strong="H4481"\w* man, \add who was represented by the tree\add*, damp. Cause \w him|strong="H4481"\w* \w to|strong="H3046"\w* live \w in|strong="H4437"\w* \w the|strong="H4481"\w* fields with \w the|strong="H4481"\w* animals \w for|strong="H1768"\w* seven years.’   
\pi1
\v 24 ◄\w Your|strong="H5922"\w* Majesty/\w O|strong="H3068"\w* \w King|strong="H4430"\w*►, \w that|strong="H2006"\w* is what \w your|strong="H5922"\w* dream means. \w That|strong="H2006"\w* is what \w the|strong="H5922"\w* Supreme God \w has|strong="H4430"\w* declared \w will|strong="H4430"\w* happen \w to|strong="H5922"\w* \w you|strong="H2006"\w*.  
\v 25  \add Your advisors\add* \w will|strong="H4430"\w* force \w you|strong="H5922"\w* \w to|strong="H5922"\w* live away from other people. \w You|strong="H5922"\w* \w will|strong="H4430"\w* live \w in|strong="H5922"\w* \w the|strong="H3606"\w* fields \w with|strong="H5922"\w* \w the|strong="H3606"\w* wild animals. \w You|strong="H5922"\w* \w will|strong="H4430"\w* eat grass like cows \w do|strong="H5922"\w*, \w and|strong="H4430"\w* dew from \w the|strong="H3606"\w* sky \w will|strong="H4430"\w* \w cause|strong="H3606"\w* \w your|strong="H5020"\w* \add body\add* \w to|strong="H5922"\w* be damp/wet \add every morning\add*. \w You|strong="H5922"\w* \w will|strong="H4430"\w* live \w that|strong="H3606"\w* way \w for|strong="H5922"\w* seven years, until \w you|strong="H5922"\w* learn \w that|strong="H3606"\w* \w it|strong="H5922"\w* \w is|strong="H3606"\w* \w the|strong="H3606"\w* Supreme God who rules \w over|strong="H5922"\w* \w the|strong="H3606"\w* kingdoms \w of|strong="H4430"\w* \w the|strong="H3606"\w* world, \w and|strong="H4430"\w* \w he|strong="H5020"\w* appoints \w the|strong="H3606"\w* ones whom \w he|strong="H5020"\w* chooses \add to rule them\add*.  
\v 26 \w But|strong="H1768"\w* \w the|strong="H5922"\w* stump \w of|strong="H4437"\w* \w the|strong="H5922"\w* tree \w and|strong="H4437"\w* its roots \w were|strong="H1934"\w* left \add in the ground\add*. \w That|strong="H1768"\w* means \w that|strong="H1768"\w* \w you|strong="H1768"\w* \w will|strong="H1768"\w* rule \w your|strong="H1768"\w* \w kingdom|strong="H4437"\w* again \w when|strong="H1768"\w* \w you|strong="H1768"\w* learn \w that|strong="H1768"\w* \w it|strong="H5922"\w* \w is|strong="H1768"\w* God [MTY] \w who|strong="H1768"\w* \w is|strong="H1768"\w* \add really\add* \w the|strong="H5922"\w* ruler.  
\v 27 ◄\w Your|strong="H1768"\w* \w Majesty|strong="H1923"\w*/\w O|strong="H3068"\w* \w King|strong="H4430"\w*►, please do \w what|strong="H1768"\w* \w I|strong="H1768"\w* am telling \w you|strong="H1768"\w* \w to|strong="H4430"\w* do. Stop sinning, \w and|strong="H6032"\w* do \w what|strong="H1768"\w* \w is|strong="H1768"\w* right. Turn away \w from|strong="H1768"\w* \w your|strong="H1768"\w* evil behavior. Act mercifully \w to|strong="H4430"\w* poor people. If \w you|strong="H1768"\w* do \w that|strong="H1768"\w*, perhaps \w you|strong="H1768"\w* \w will|strong="H1768"\w* continue \w to|strong="H4430"\w* \w be|strong="H3809"\w* sucessful.”   
\s1 The dream was fulfilled  
\pi1
\v 28 \w But|strong="H4481"\w* \add the king refused to stop sinning. So what was predicted in the dream is\add* \w what|strong="H4406"\w* happened \w to|strong="H5308"\w* \w him|strong="H4481"\w*.  
\v 29 Twelve months later, \add one day\add* \w he|strong="H1768"\w* \w was|strong="H2423"\w* walking \add on the flat roof\add* \w of|strong="H4481"\w* \w his|strong="H5922"\w* palace \w in|strong="H5922"\w* Babylon.  
\v 30 \w As|strong="H6211"\w* \w he|strong="H1768"\w* \add looked out over/across the city\add*, \w he|strong="H1768"\w* said \add to those around him\add*, “\w I|strong="H4481"\w* \w have|strong="H5020"\w* built \w this|strong="H4406"\w* \w great|strong="H7236"\w* \add city of\add* Babylon \w to|strong="H5922"\w* \w be|strong="H8160"\w* \w the|strong="H5922"\w* place \w where|strong="H1768"\w* \w I|strong="H4481"\w* rule! \w I|strong="H4481"\w* \w have|strong="H5020"\w* built \w it|strong="H5922"\w* \w to|strong="H5922"\w* display \w my|strong="H5922"\w* own power, \w in|strong="H5922"\w* \w order|strong="H5705"\w* \add to show people\add* \w my|strong="H5922"\w* glory, \w to|strong="H5922"\w* show \w them|strong="H5922"\w* \w that|strong="H1768"\w* \w I|strong="H4481"\w* am very \w great|strong="H7236"\w*!”   
\pi1
\v 31 While \w he|strong="H1768"\w* \w was|strong="H7985"\w* still saying \w this|strong="H5922"\w*, God [MTY] \w spoke|strong="H8421"\w* \w from|strong="H1768"\w* \w heaven|strong="H8065"\w* \w and|strong="H4437"\w* said, “King \w Nebuchadnezzar|strong="H5020"\w*, \w this|strong="H5922"\w* \w is|strong="H1768"\w* \w what|strong="H1768"\w* \w I|strong="H1768"\w* am saying \w to|strong="H5922"\w* \w you|strong="H1768"\w*: \w You|strong="H1768"\w* \w are|strong="H1768"\w* no longer \w the|strong="H5922"\w* ruler \w of|strong="H4437"\w* \w this|strong="H5922"\w* \w kingdom|strong="H4437"\w*!  
\v 32  \add Your advisors\add* \w will|strong="H6634"\w* force \w you|strong="H1768"\w* \w to|strong="H2429"\w* \w live|strong="H1753"\w* away \w from|strong="H1768"\w* \add other\add* people. \w You|strong="H1768"\w* \w will|strong="H6634"\w* \w live|strong="H1753"\w* \w in|strong="H1753"\w* \w the|strong="H3606"\w* fields \w with|strong="H5648"\w* wild animals, \w and|strong="H8065"\w* \w you|strong="H1768"\w* \w will|strong="H6634"\w* eat grass like cows \w do|strong="H5648"\w*. \w You|strong="H1768"\w* \w will|strong="H6634"\w* \w live|strong="H1753"\w* \w that|strong="H1768"\w* way \w for|strong="H1768"\w* seven years, until \w you|strong="H1768"\w* learn \w that|strong="H1768"\w* \add it is\add* \w I|strong="H1768"\w*, \w the|strong="H3606"\w* Supreme God, \w who|strong="H1768"\w* rules over \w the|strong="H3606"\w* kingdoms \w of|strong="H1768"\w* \w this|strong="H3606"\w* world, \w and|strong="H8065"\w* \w I|strong="H1768"\w* appoint \w the|strong="H3606"\w* ones \w whom|strong="H1768"\w* \w I|strong="H1768"\w* \w have|strong="H1768"\w* chosen \w to|strong="H2429"\w* rule them.”   
\pi1
\v 33 Immediately what \add God\add* predicted happened. Nebuchadnezzar \add became insane, so his advisors\add* forced \w him|strong="H5922"\w* \w to|strong="H5922"\w* live away \w from|strong="H3367"\w* other people. He ate grass like cows \add do\add*, \w and|strong="H4437"\w* dew \w from|strong="H3367"\w* \w the|strong="H5922"\w* sky caused \w his|strong="H5922"\w* body \w to|strong="H5922"\w* \w be|strong="H2122"\w* damp/wet \add every morning. He lived like that\add* until \w his|strong="H5922"\w* hair \w was|strong="H2122"\w* \w as|strong="H4437"\w* long \w as|strong="H4437"\w* eagles’ feathers, \w and|strong="H4437"\w* \w his|strong="H5922"\w* fingernails became like birds’ claws.   
\b  
\pi1
\v 34 “After \w those|strong="H1768"\w* \add seven\add* years ended, \w I|strong="H1768"\w*, \w Nebuchadnezzar|strong="H5020"\w*, looked \w up|strong="H7313"\w* toward \w heaven|strong="H8065"\w*, \add and I acknowledged that what God said was true\add*. \w Then|strong="H4430"\w* \w I|strong="H1768"\w* \w could|strong="H3202"\w* think correctly again. \w I|strong="H1768"\w* \w praised|strong="H7624"\w* \w and|strong="H4430"\w* worshiped \w the|strong="H3606"\w* Supreme God, \w and|strong="H4430"\w* \w I|strong="H1768"\w* \w honored|strong="H1922"\w* him, \w the|strong="H3606"\w* one \w who|strong="H1768"\w* lives forever.  
\b  
\q1 \w He|strong="H1768"\w* rules forever;  
\q2 \w his|strong="H3606"\w* kingdom \w will|strong="H1768"\w* never end.   
\q1
\v 35 All the people in the world are very insignificant;  
\q2 \w we|strong="H3068"\w* are not like him.  
\q1 He has the power to do whatever he wants to do,  
\q2 among the angels in heaven and among us people who live on the earth.  
\q1 \add So\add* no one can stop him [SYN],  
\q2 and no one can \add challenge him\add*,  
\q2 saying to him, ‘Why \add are you doing these things\add*?’   
\b  
\pi1
\v 36 When I was able to think correctly again, I was honored again, and I \add was able to\add* rule my glorious/great kingdom again. My advisors came to me again \add to talk about what should be done\add*, and I became greater and more powerful than I was before.  
\v 37 Now I, Nebuchadnezzar, praise and honor [DOU] \add God\add*, the king who rules in heaven. All of his actions are just and right. And he is able to cause to become humble those who are proud, \add like I was\add*.”   
\c 5  
\s1 The writing on the wall  
\p
\v 1  \add Several years later,\add* \w Belshazzar|strong="H1113"\w* \add became the\add* \w king|strong="H4430"\w* \add of Babylon. One day \add* \w he|strong="H6903"\w* invited 1,000 \w of|strong="H4430"\w* his officers \w to|strong="H4430"\w* \w a|strong="H3068"\w* big \w feast|strong="H3900"\w*, \w and|strong="H4430"\w* \w he|strong="H6903"\w* \w drank|strong="H8355"\w* \add a lot of\add* \w wine|strong="H2562"\w* \w with|strong="H5648"\w* them.  
\v 2 While \w he|strong="H1768"\w* \w was|strong="H4430"\w* \w drinking|strong="H8355"\w*, \w he|strong="H1768"\w* \w commanded|strong="H4481"\w* \w that|strong="H1768"\w*\add his servants\add* bring \w to|strong="H4481"\w* \w him|strong="H4481"\w* \w the|strong="H4481"\w* \w gold|strong="H1722"\w* \w and|strong="H4430"\w* \w silver|strong="H3702"\w* cups \w that|strong="H1768"\w* \w the|strong="H4481"\w* previous \w king|strong="H4430"\w*, \w Nebuchadnezzar|strong="H5020"\w*, \w had|strong="H4430"\w* \w taken|strong="H5312"\w* \w from|strong="H4481"\w* \w the|strong="H4481"\w* \w temple|strong="H1965"\w* \w in|strong="H5020"\w* \w Jerusalem|strong="H3390"\w*. \add He did that\add* \w because|strong="H4481"\w* \w he|strong="H1768"\w* wanted himself \w and|strong="H4430"\w* \w his|strong="H4481"\w* officials, \w his|strong="H4481"\w* \w wives|strong="H7695"\w*, \w and|strong="H4430"\w* \add even\add* \w his|strong="H4481"\w* ◄\w concubines|strong="H3904"\w*/slave \w wives|strong="H7695"\w*► \w to|strong="H4481"\w* \w drink|strong="H8355"\w* \w from|strong="H4481"\w* them, \add making fun of the god that we Israelis worshiped\add*.  
\v 3 \w So|strong="H1768"\w* \w his|strong="H4481"\w* servants \w brought|strong="H5312"\w* \w in|strong="H1965"\w* \add all\add* \w those|strong="H1768"\w* \w gold|strong="H1722"\w* cups, \w that|strong="H1768"\w* \w had|strong="H4430"\w* been \w taken|strong="H5312"\w* \add many years previously \add* \w from|strong="H4481"\w* \w the|strong="H4481"\w* \w temple|strong="H1005"\w* \w of|strong="H4481"\w* \add the true \add* God \w in|strong="H1965"\w* \w Jerusalem|strong="H3390"\w*. \w Then|strong="H1768"\w* \w the|strong="H4481"\w* \w king|strong="H4430"\w* \w and|strong="H4430"\w* \w his|strong="H4481"\w* officials \w and|strong="H4430"\w* \w his|strong="H4481"\w* \w wives|strong="H7695"\w* \w and|strong="H4430"\w* \w his|strong="H4481"\w* slave \w wives|strong="H7695"\w* \w drank|strong="H8355"\w* \add wine \add* \w from|strong="H4481"\w* \w those|strong="H1768"\w* cups.  
\v 4 They \w drank|strong="H8355"\w* to \w praise|strong="H7624"\w*/honor their idols \w that|strong="H6523"\w* \w were|strong="H1722"\w* made of \w gold|strong="H1722"\w*, \w silver|strong="H3702"\w*, \w bronze|strong="H5174"\w*, \w iron|strong="H6523"\w*, \w and|strong="H6523"\w* \add even\add* wood \w and|strong="H6523"\w* stone.   
\p
\v 5 \w Suddenly|strong="H8160"\w* \w they|strong="H1768"\w* \w saw|strong="H2370"\w* \w a|strong="H3068"\w* man’s \w hand|strong="H3028"\w* \w writing|strong="H3790"\w* \w on|strong="H5922"\w* \w the|strong="H5922"\w* \w plaster|strong="H1528"\w* \w of|strong="H4430"\w* \w the|strong="H5922"\w* \w wall|strong="H3797"\w* \w opposite|strong="H6903"\w* \w the|strong="H5922"\w* \w lampstand|strong="H5043"\w*. \w The|strong="H5922"\w* \w king|strong="H4430"\w* \w also|strong="H4430"\w* \w saw|strong="H2370"\w* \w the|strong="H5922"\w* \w hand|strong="H3028"\w* \w as|strong="H6903"\w* \w it|strong="H5922"\w* \w was|strong="H4430"\w* \w writing|strong="H3790"\w*.  
\v 6 He became very frightened, \w and|strong="H4430"\w* his \w face|strong="H2122"\w* became \w pale|strong="H8133"\w*/white. His knees started shaking, \w and|strong="H4430"\w* his legs became very weak, \w with|strong="H8271"\w* \w the|strong="H4430"\w* result \w that|strong="H4430"\w* he could \w not|strong="H1668"\w* stand up.   
\p
\v 7  \add Then\add* \w he|strong="H1768"\w* \w shouted|strong="H7123"\w* \w to|strong="H5922"\w* \w summon|strong="H7123"\w* \w the|strong="H3606"\w* \w men|strong="H2445"\w* \w who|strong="H1768"\w* worked magic, \w the|strong="H3606"\w* \w men|strong="H2445"\w* \w who|strong="H1768"\w* studied \w the|strong="H3606"\w* stars, \w and|strong="H6032"\w* \w the|strong="H3606"\w* fortune-tellers. \w He|strong="H1768"\w* \w said|strong="H6032"\w*, “\w I|strong="H1836"\w* \w will|strong="H1768"\w* \add greatly honor \add* \w any|strong="H3606"\w* \w one|strong="H1836"\w* \w of|strong="H4437"\w* \w them|strong="H5922"\w* \w who|strong="H1768"\w* \w can|strong="H1768"\w* \w read|strong="H7123"\w* \w this|strong="H1836"\w* \w writing|strong="H3792"\w* \w and|strong="H6032"\w* tell \w me|strong="H5922"\w* \w what|strong="H1768"\w* \w it|strong="H5922"\w* means. \w I|strong="H1836"\w* \w will|strong="H1768"\w* give \w him|strong="H5922"\w* \w a|strong="H3068"\w* purple \add robe like I wear because I am the king\add*, \w and|strong="H6032"\w* \w I|strong="H1836"\w* \w will|strong="H1768"\w* put \w a|strong="H3068"\w* \w gold|strong="H1722"\w* \w chain|strong="H2002"\w* \w around|strong="H5922"\w* \w his|strong="H5922"\w* \w neck|strong="H6676"\w*. \w He|strong="H1768"\w* \w will|strong="H1768"\w* become \w a|strong="H3068"\w* very important official \w in|strong="H5954"\w* \w my|strong="H5922"\w* \w kingdom|strong="H4437"\w*; \w there|strong="H1768"\w* \w will|strong="H1768"\w* be only two others \w who|strong="H1768"\w* \w will|strong="H1768"\w* be \w more|strong="H5922"\w* important \w than|strong="H1768"\w* \w he|strong="H1768"\w* \w will|strong="H1768"\w* be.”   
\p
\v 8 \w But|strong="H3606"\w* when \w all|strong="H3606"\w* those \w wise|strong="H2445"\w* \w men|strong="H2445"\w* \w came|strong="H5954"\w* \w in|strong="H5954"\w*, \w none|strong="H3809"\w* \w of|strong="H4430"\w* them \w could|strong="H3546"\w* \w read|strong="H7123"\w* \w the|strong="H3606"\w* \w writing|strong="H3792"\w*, \w or|strong="H3809"\w* tell him what it meant.  
\v 9 So \w King|strong="H4430"\w* \w Belshazzar|strong="H1113"\w* became \w more|strong="H5922"\w* afraid. \w His|strong="H5922"\w* \w face|strong="H2122"\w* became \add even\add* \w paler|strong="H8133"\w*/whiter. \w And|strong="H4430"\w* \add all\add* \w his|strong="H5922"\w* officials \add who were there at the feast\add* did not know what \w to|strong="H5922"\w* \w do|strong="H5922"\w*.   
\p
\v 10 \w But|strong="H6903"\w* when \w the|strong="H6903"\w* mother \w of|strong="H1005"\w* \w the|strong="H6903"\w* \w king|strong="H4430"\w* (\w OR|strong="H3068"\w*, \w of|strong="H1005"\w* \w the|strong="H6903"\w* previous \w king|strong="H4430"\w*) heard \w the|strong="H6903"\w* \w king|strong="H4430"\w* \w and|strong="H6032"\w* \w his|strong="H5954"\w* officials talking \add loudly about what had happened\add*, \w she|strong="H4433"\w* \w entered|strong="H5954"\w* \w the|strong="H6903"\w* \w room|strong="H1005"\w* where they \w were|strong="H7261"\w* having \w the|strong="H6903"\w* feast. \w She|strong="H4433"\w* \w said|strong="H6032"\w* \add to Belshazzar\add*, “◄Your majesty/\w O|strong="H3068"\w* \w King|strong="H4430"\w*►, I hope \w you|strong="H6903"\w* \w will|strong="H4430"\w* \w live|strong="H2418"\w* \w for|strong="H2418"\w* \w a|strong="H3068"\w* \w long|strong="H5957"\w* time! \w But|strong="H6903"\w* do not \w be|strong="H2122"\w* \w pale|strong="H8133"\w* \w and|strong="H6032"\w* afraid about \w this|strong="H4406"\w*.  
\v 11 \w There|strong="H1768"\w* \w is|strong="H1768"\w* \w a|strong="H3068"\w* \w man|strong="H1400"\w* \w in|strong="H6966"\w* \w your|strong="H5020"\w* \w kingdom|strong="H4437"\w* \w who|strong="H1768"\w* \w has|strong="H1768"\w* \w the|strong="H5020"\w* \w spirit|strong="H7308"\w* \w of|strong="H4437"\w* \w the|strong="H5020"\w* \w holy|strong="H6922"\w* gods \w in|strong="H6966"\w* \w him|strong="H6966"\w*. \w When|strong="H1768"\w* \w Nebuchadnezzar|strong="H5020"\w* \w was|strong="H4430"\w* ruling, \w they|strong="H1768"\w* \w discovered|strong="H7912"\w* \w that|strong="H1768"\w* this \w man|strong="H1400"\w* understood many things \w and|strong="H4430"\w* \w was|strong="H4430"\w* wise, just like \w the|strong="H5020"\w* gods. \w The|strong="H5020"\w* \w man|strong="H1400"\w* \w who|strong="H1768"\w* \w was|strong="H4430"\w* \w king|strong="H4430"\w* previously, \w Nebuchadnezzar|strong="H5020"\w*, \w appointed|strong="H6966"\w* \w him|strong="H6966"\w* \w to|strong="H4430"\w* be \w in|strong="H6966"\w* charge \w of|strong="H4437"\w* all \w the|strong="H5020"\w* \w men|strong="H1400"\w* \add in Babylon\add* \w who|strong="H1768"\w* worked magic, \w the|strong="H5020"\w* \w men|strong="H1400"\w* \w who|strong="H1768"\w* worked sorcery, \w the|strong="H5020"\w* \w men|strong="H1400"\w* \w who|strong="H1768"\w* studied \w the|strong="H5020"\w* stars, \w and|strong="H4430"\w* \w the|strong="H5020"\w* fortune-tellers.  
\v 12 \w That|strong="H1768"\w* man’s \w name|strong="H8036"\w* \w is|strong="H1768"\w* \w Daniel|strong="H1841"\w*; \w the|strong="H3606"\w* \w king|strong="H4430"\w* \w gave|strong="H7761"\w* him \w a|strong="H3068"\w* \add new\add* \w name|strong="H8036"\w*, \w Belteshazzar|strong="H1096"\w*. \w He|strong="H1768"\w* \w is|strong="H1768"\w* very intelligent \w and|strong="H4430"\w* \w is|strong="H1768"\w* able \w to|strong="H8036"\w* know \w and|strong="H4430"\w* understand many \w things|strong="H3606"\w*. \w He|strong="H1768"\w* \w is|strong="H1768"\w* \add even\add* able \w to|strong="H8036"\w* tell \w the|strong="H3606"\w* meaning \w of|strong="H4430"\w* \w dreams|strong="H2493"\w*, \w and|strong="H4430"\w* explain riddles, \w and|strong="H4430"\w* explain \w things|strong="H3606"\w* \w that|strong="H1768"\w* \w are|strong="H1768"\w* very \w difficult|strong="H7001"\w* \w to|strong="H8036"\w* understand. \w Summon|strong="H7123"\w* him, \w and|strong="H4430"\w* \w he|strong="H1768"\w* \w will|strong="H1768"\w* tell \w you|strong="H1768"\w* \w what|strong="H1768"\w* \add this writing\add* \w means|strong="H6903"\w*.”   
\s1 Daniel interpreted the writing  
\p
\v 13 \w So|strong="H1768"\w* \w they|strong="H1768"\w* \add went and\add* \w brought|strong="H5954"\w* \w me|strong="H6925"\w* \w in|strong="H5954"\w*. \w The|strong="H4481"\w* \w king|strong="H4430"\w* asked \w me|strong="H6925"\w*, “\w You|strong="H1768"\w* \add must\add* \w be|strong="H1841"\w* \w Daniel|strong="H1841"\w* [RHQ]! \add They told me that you are\add* one \w of|strong="H4481"\w* \w those|strong="H1768"\w* \w who|strong="H1768"\w* \w was|strong="H4430"\w* \w brought|strong="H5954"\w* \add here\add* \w from|strong="H4481"\w* \w Judah|strong="H3061"\w* \w by|strong="H4481"\w* \w the|strong="H4481"\w* previous \w king|strong="H4430"\w*.  
\v 14 \w I|strong="H1768"\w* \w have|strong="H1768"\w* \add also\add* \w heard|strong="H8086"\w* \w that|strong="H1768"\w* \w the|strong="H5922"\w* \w spirit|strong="H7308"\w* \w of|strong="H5922"\w* \w the|strong="H5922"\w* gods \w is|strong="H1768"\w* \w in|strong="H5922"\w* \w you|strong="H1768"\w*, \w and|strong="H7924"\w* \w that|strong="H1768"\w* \w you|strong="H1768"\w* \w are|strong="H1768"\w* very wise \w and|strong="H7924"\w* understand many things.  
\v 15 \w My|strong="H1768"\w* \w wise|strong="H2445"\w* \w men|strong="H2445"\w* \w and|strong="H3792"\w* \w men|strong="H2445"\w* \w who|strong="H1768"\w* work magic \w have|strong="H1768"\w* tried \w to|strong="H6925"\w* \w read|strong="H7123"\w* \w the|strong="H6925"\w* \w writing|strong="H3792"\w* on \w this|strong="H1836"\w* wall \w and|strong="H3792"\w* tell \w me|strong="H6925"\w* \w what|strong="H1768"\w* \w it|strong="H6925"\w* means, \w but|strong="H1768"\w* \w they|strong="H1768"\w* \w are|strong="H1768"\w* \w not|strong="H3809"\w* \w able|strong="H3546"\w* \w to|strong="H6925"\w* do \w it|strong="H6925"\w*.  
\v 16  \add Someone\add* told \w me|strong="H5922"\w* \w that|strong="H1768"\w* \w you|strong="H1768"\w* \w can|strong="H3202"\w* tell \w what|strong="H1768"\w* dreams mean \w and|strong="H1722"\w* explain things \w that|strong="H1768"\w* \w are|strong="H1768"\w* very \w difficult|strong="H7001"\w* \w to|strong="H5922"\w* \w understand|strong="H3046"\w*. \w If|strong="H2006"\w* \w you|strong="H1768"\w* \w can|strong="H3202"\w* \w read|strong="H7123"\w* these words \w and|strong="H1722"\w* tell \w me|strong="H5922"\w* \w what|strong="H1768"\w* \w they|strong="H1768"\w* mean, \add I \add*\w will|strong="H1768"\w* \w give|strong="H6590"\w* \w you|strong="H1768"\w* \w a|strong="H3068"\w* purple robe \add like I wear because I am the king\add*, \w and|strong="H1722"\w* \w I|strong="H1768"\w* \w will|strong="H1768"\w* put \w a|strong="H3068"\w* \w gold|strong="H1722"\w* \w chain|strong="H2002"\w* \w around|strong="H5922"\w* \w your|strong="H1768"\w* \w neck|strong="H6676"\w*. \w You|strong="H1768"\w* \w will|strong="H1768"\w* become \w a|strong="H3068"\w* very important official \w in|strong="H5922"\w* \w my|strong="H5922"\w* \w kingdom|strong="H4437"\w*; \w there|strong="H1768"\w* \w will|strong="H1768"\w* \w be|strong="H3705"\w* only two others \w who|strong="H1768"\w* \w will|strong="H1768"\w* \w be|strong="H3705"\w* \w more|strong="H5922"\w* important \w than|strong="H1768"\w* \w you|strong="H1768"\w* \w will|strong="H1768"\w* \w be|strong="H3705"\w*.”   
\p
\v 17 I \w replied|strong="H6032"\w*, “\add I do not want\add* \w your|strong="H3052"\w* \w gifts|strong="H4978"\w*; keep \w them|strong="H3052"\w*, \w or|strong="H4430"\w* \w give|strong="H3052"\w* \w them|strong="H3052"\w* \w to|strong="H6925"\w* someone else. \w But|strong="H1297"\w* I \w will|strong="H4430"\w* \w read|strong="H7123"\w* \w for|strong="H3046"\w* you \w the|strong="H6925"\w* \w writing|strong="H3792"\w* \add on the wall\add*, \w and|strong="H6032"\w* I \w will|strong="H4430"\w* tell you what \w it|strong="H1934"\w* means.   
\p
\v 18 ◄\w Your|strong="H5020"\w* \w Majesty|strong="H7238"\w*/\w O|strong="H3068"\w* \w king|strong="H4430"\w*►, \w the|strong="H5020"\w* Supreme God caused \w the|strong="H5020"\w* man who \w was|strong="H4430"\w* \w king|strong="H4430"\w* before you, \w Nebuchadnezzar|strong="H5020"\w*, \w to|strong="H4430"\w* become \w a|strong="H3068"\w* great ruler, who \w was|strong="H4430"\w* greatly praised \w and|strong="H4430"\w* honored.  
\v 19 \w Because|strong="H4481"\w* God caused \w him|strong="H6925"\w* \w to|strong="H6925"\w* become \add very\add* great, \w people|strong="H5972"\w* \w of|strong="H4481"\w* many [HYP] people-groups \w and|strong="H1763"\w* nations \w and|strong="H1763"\w* \w who|strong="H1768"\w* spoke many different \w languages|strong="H3961"\w* \w were|strong="H1934"\w* very much \w afraid|strong="H1763"\w* \w of|strong="H4481"\w* \w him|strong="H6925"\w*. \w He|strong="H1768"\w* \add commanded his soldiers to\add* \w kill|strong="H6992"\w* \w those|strong="H8214"\w* \w whom|strong="H1768"\w* \w he|strong="H1768"\w* wanted \w to|strong="H6925"\w* \w be|strong="H1934"\w* \w killed|strong="H6992"\w*, \w and|strong="H1763"\w* \w he|strong="H1768"\w* ◄\w spared|strong="H2418"\w*/allowed \w to|strong="H6925"\w* \w live|strong="H2418"\w*► \w those|strong="H8214"\w* \w whom|strong="H1768"\w* \w he|strong="H1768"\w* wanted \w to|strong="H6925"\w* spare. \w He|strong="H1768"\w* honored \w those|strong="H8214"\w* \w whom|strong="H1768"\w* \w he|strong="H1768"\w* wanted \w to|strong="H6925"\w* honor, \w and|strong="H1763"\w* \w he|strong="H1768"\w* caused \w to|strong="H6925"\w* \w be|strong="H1934"\w* disgraced \w those|strong="H8214"\w* \w whom|strong="H1768"\w* \w he|strong="H1768"\w* wanted \w to|strong="H6925"\w* \w be|strong="H1934"\w* disgraced.  
\v 20 \w But|strong="H1768"\w* \w when|strong="H1768"\w* \w he|strong="H1768"\w* \w became|strong="H8631"\w* very \w proud|strong="H8631"\w* \w and|strong="H4437"\w* stubborn [IDM], \w he|strong="H1768"\w* \w was|strong="H3825"\w* \w removed|strong="H5709"\w* \w from|strong="H4481"\w* being king [MTY]. People did not consider \w him|strong="H4481"\w* \w to|strong="H4481"\w* \w be|strong="H3825"\w* glorious/great any \w more|strong="H4481"\w*.  
\v 21  \add His officials \add* sent \w him|strong="H5922"\w* \w away|strong="H2957"\w* \w in|strong="H5922"\w* \w order|strong="H5705"\w* \w that|strong="H1768"\w* \w he|strong="H1768"\w* \w would|strong="H6634"\w* not \w be|strong="H3825"\w* near \add other\add* people. \add God\add* caused \w him|strong="H5922"\w* \w to|strong="H5922"\w* \w have|strong="H1768"\w* \w a|strong="H3068"\w* \w mind|strong="H3825"\w* \w like|strong="H2939"\w* \w animals|strong="H2423"\w* \w have|strong="H1768"\w*. \w He|strong="H1768"\w* lived \w among|strong="H5974"\w* \w the|strong="H5922"\w* \w wild|strong="H6167"\w* \w donkeys|strong="H6167"\w*. \w He|strong="H1768"\w* ate \w grass|strong="H6211"\w* \w like|strong="H2939"\w* cows \w do|strong="H8065"\w*, \w and|strong="H8065"\w* \w dew|strong="H2920"\w* \w from|strong="H4481"\w* \w the|strong="H5922"\w* \w sky|strong="H8065"\w* caused \w his|strong="H5922"\w* \w body|strong="H1655"\w* \w to|strong="H5922"\w* \w be|strong="H3825"\w* \w damp|strong="H6647"\w*/\w wet|strong="H6647"\w* \add each morning\add*. \add He was like that\add* \w until|strong="H5705"\w* \w he|strong="H1768"\w* learned \w that|strong="H1768"\w* \w the|strong="H5922"\w* Supreme God \w is|strong="H1768"\w* \add really the one who\add* \w rules|strong="H7990"\w* \w the|strong="H5922"\w* \w kingdoms|strong="H4437"\w* \w of|strong="H4481"\w* \w this|strong="H4481"\w* world, \w and|strong="H8065"\w* \w that|strong="H1768"\w* \w he|strong="H1768"\w* appoints \w whomever|strong="H1768"\w* \w he|strong="H1768"\w* chooses \w to|strong="H5922"\w* \w rule|strong="H7990"\w* \w those|strong="H1768"\w* \w kingdoms|strong="H4437"\w*.   
\p
\v 22 \w Now|strong="H1836"\w*, \w Belshazzar|strong="H1113"\w*, \w you|strong="H1768"\w* \w have|strong="H1768"\w* become \w the|strong="H3606"\w* king. \w You|strong="H1768"\w* \add also\add* \w knew|strong="H3046"\w* \w all|strong="H3606"\w* \w those|strong="H8214"\w* \w things|strong="H3606"\w*, \w but|strong="H3606"\w* \w you|strong="H1768"\w* \w have|strong="H1768"\w* \w not|strong="H3809"\w* \w made|strong="H3046"\w* \w yourself|strong="H3825"\w* \w humble|strong="H8214"\w*.  
\v 23 \w You|strong="H1768"\w* \w have|strong="H1768"\w* considered \w yourself|strong="H7313"\w* \w to|strong="H5922"\w* \w be|strong="H3809"\w* greater \w than|strong="H1768"\w* \add God\add*, \w the|strong="H3606"\w* \w Lord|strong="H4756"\w* \w of|strong="H1005"\w* \w heaven|strong="H8065"\w*. \add So you have commanded your servants to\add* bring \w to|strong="H5922"\w* \w you|strong="H1768"\w* these sacred cups, \add which were dedicated to the Supreme God, and which were taken\add* \w from|strong="H1768"\w* \w his|strong="H5922"\w* \w temple|strong="H1005"\w* \add in Jerusalem\add*. \w You|strong="H1768"\w* \w and|strong="H6523"\w* \w your|strong="H1768"\w* officials \w and|strong="H6523"\w* \w your|strong="H1768"\w* \w wives|strong="H7695"\w* \w and|strong="H6523"\w* \w your|strong="H1768"\w* ◄\w concubines|strong="H3904"\w*/slave \w wives|strong="H7695"\w*► \w have|strong="H1768"\w* been \w drinking|strong="H8355"\w* \w wine|strong="H2562"\w* \w from|strong="H1768"\w* these cups, while \w you|strong="H1768"\w* \w have|strong="H1768"\w* been praising \add your own\add* gods—gods \w which|strong="H1768"\w* \w are|strong="H1768"\w* \w made|strong="H3046"\w* \w of|strong="H1005"\w* \w gold|strong="H1722"\w* \w and|strong="H6523"\w* \w silver|strong="H3702"\w* \w and|strong="H6523"\w* \w bronze|strong="H5174"\w* \w and|strong="H6523"\w* \w iron|strong="H6523"\w* \w and|strong="H6523"\w* wood \w and|strong="H6523"\w* stone. \add Those are gods\add* \w that|strong="H1768"\w* \w cannot|strong="H3809"\w* \w see|strong="H2370"\w*, \w that|strong="H1768"\w* \w cannot|strong="H3809"\w* \w hear|strong="H8086"\w*, \w and|strong="H6523"\w* \w that|strong="H1768"\w* \w do|strong="H5922"\w* \w not|strong="H3809"\w* \w know|strong="H3046"\w* anything! \w You|strong="H1768"\w* \w have|strong="H1768"\w* \w not|strong="H3809"\w* \w honored|strong="H1922"\w* \w the|strong="H3606"\w* God \w who|strong="H1768"\w* gives \w you|strong="H1768"\w* \w breath|strong="H5396"\w* \w and|strong="H6523"\w* \w who|strong="H1768"\w* controls \w everything|strong="H3606"\w* \w that|strong="H1768"\w* happens \w to|strong="H5922"\w* \w you|strong="H1768"\w*.  
\v 24 \w So|strong="H1768"\w* God \w sent|strong="H7972"\w* \w that|strong="H1768"\w* \w hand|strong="H3028"\w* \w to|strong="H6925"\w* write \w a|strong="H3068"\w* message \add for you\add*.   
\p
\v 25 \w This|strong="H1836"\w* \w is|strong="H1768"\w* \w the|strong="H1768"\w* message \w that|strong="H1768"\w* it wrote: ‘\sc \+w Mene|strong="H4484"\+w*, \+w mene|strong="H4484"\+w*, \+w tekel|strong="H8625"\+w*, parsin.\sc*’   
\p
\v 26 \w This|strong="H1836"\w* \w is|strong="H4437"\w* \w what|strong="H4406"\w* those \w words|strong="H4406"\w* mean:  
\li1 \sc Mene\sc* \add means\add* ‘numbered/counted’. \add That means that\add* God has been counting the days that you will rule, and he has \add now\add* decided that you will not rule any more.   
\li1
\v 27  \sc Tekel\sc* \add means ‘weighed’. It is as though God\add* has weighed you on a scale, and you do not weigh what you should, \add which means that you have not been doing what you should; you are not fit to be a king\add* [MET].   
\li1
\v 28  \sc Parsin\sc* \add means ‘divided’. That means that God\add* has divided your kingdom. Some of it will be ruled by people from Media and some will be ruled by people from Persia.”   
\p
\v 29 \w Then|strong="H1768"\w* \w Belshazzar|strong="H1113"\w* \add did what he had promised\add*. \w He|strong="H1768"\w* put \w on|strong="H5922"\w* \w me|strong="H5922"\w* \w a|strong="H3068"\w* purple robe \add like the one he himself wore. He\add* put \w a|strong="H3068"\w* \w gold|strong="H1722"\w* \w chain|strong="H2002"\w* \w around|strong="H5922"\w* \w my|strong="H5922"\w* \w neck|strong="H6676"\w*. \w And|strong="H1722"\w* \w he|strong="H1768"\w* \w proclaimed|strong="H3745"\w* \w that|strong="H1768"\w* \w there|strong="H1768"\w* \w would|strong="H1934"\w* \w be|strong="H1934"\w* only two others \w who|strong="H1768"\w* \w would|strong="H1934"\w* \w be|strong="H1934"\w* \w more|strong="H5922"\w* important \w than|strong="H1768"\w* \w me|strong="H5922"\w* \w in|strong="H5922"\w* \w his|strong="H5922"\w* \w kingdom|strong="H4437"\w*.   
\p
\v 30 But \w that|strong="H4430"\w* same \w night|strong="H3916"\w* \add soldiers from Media entered the city and\add* \w killed|strong="H6992"\w* \w Belshazzar|strong="H1113"\w*, \w the|strong="H4430"\w* \w King|strong="H4430"\w* \w of|strong="H4430"\w* Babylonia.  
\v 31 Darius, the King of Media, became the King \add of Babylonia\add* when he was 62 years old.   
\c 6  
\s1 Daniel was thrown into the lions’ den  
\p
\v 1 King \w Darius|strong="H1868"\w* decided \w to|strong="H1868"\w* divide his \w kingdom|strong="H4437"\w* into 120 provinces. He appointed \w a|strong="H3068"\w* governor \w to|strong="H1868"\w* rule each province.  
\v 2 \w He|strong="H1768"\w* also \w appointed|strong="H6966"\w* \w me|strong="H5922"\w* \w and|strong="H4437"\w* two other \w men|strong="H4437"\w* \w to|strong="H5922"\w* \w be|strong="H1934"\w* administrators, \w to|strong="H5922"\w* supervise \w the|strong="H3606"\w* governors \w and|strong="H4437"\w* \w to|strong="H5922"\w* \w be|strong="H1934"\w* sure \w that|strong="H1768"\w* \w they|strong="H1768"\w* \w did|strong="H1934"\w* \w the|strong="H3606"\w* king’s work \add properly\add*, \w in|strong="H5922"\w* order \w that|strong="H1768"\w* \w the|strong="H3606"\w* king \w would|strong="H1934"\w* not \w have|strong="H1934"\w* \w to|strong="H5922"\w* worry \w about|strong="H5922"\w* anything.  
\v 3 \w I|strong="H4481"\w* \w soon|strong="H4481"\w* showed \w that|strong="H1768"\w* \w I|strong="H4481"\w* \w was|strong="H1934"\w* ◄\w more|strong="H4481"\w* capable/able \w to|strong="H4430"\w* \w do|strong="H1934"\w* \w the|strong="H4481"\w* work better► \w than|strong="H4481"\w* all \w the|strong="H4481"\w* other administrators \w and|strong="H4430"\w* \w the|strong="H4481"\w* governors. \w Because|strong="H4481"\w* \w of|strong="H4481"\w* \w that|strong="H1768"\w*, \w the|strong="H4481"\w* \w king|strong="H4430"\w* planned \w to|strong="H4430"\w* appoint \w me|strong="H3052"\w* \w to|strong="H4430"\w* \w be|strong="H1934"\w* \w in|strong="H4430"\w* charge \w of|strong="H4481"\w* \w the|strong="H4481"\w* entire empire.  
\v 4 \w Then|strong="H6903"\w*, \w the|strong="H3606"\w* \add other\add* administrators \w and|strong="H4430"\w* \w the|strong="H3606"\w* governors \add became jealous. So they began to\add* try \w to|strong="H5922"\w* find something \w that|strong="H1768"\w* \w they|strong="H3606"\w* \w could|strong="H1768"\w* criticize \w about|strong="H5922"\w* \w the|strong="H3606"\w* way \w I|strong="H1836"\w* \w was|strong="H1934"\w* working \w for|strong="H5922"\w* \w the|strong="H3606"\w* \w king|strong="H4430"\w*. \w But|strong="H3606"\w* \w I|strong="H1836"\w* always \w did|strong="H1934"\w* \w my|strong="H5922"\w* work faithfully \w and|strong="H4430"\w* honestly, \w and|strong="H4430"\w* \w was|strong="H1934"\w* never lazy. \w So|strong="H1768"\w* \w they|strong="H3606"\w* \w could|strong="H1768"\w* not find anything \w to|strong="H5922"\w* criticize.  
\v 5 \w They|strong="H3606"\w* concluded, “\w The|strong="H3606"\w* only way \w we|strong="H3068"\w* \w can|strong="H3202"\w* \w find|strong="H7912"\w* something \w for|strong="H5922"\w* \w which|strong="H1768"\w* \w we|strong="H3068"\w* \w can|strong="H3202"\w* criticize \w Daniel|strong="H1841"\w* \w will|strong="H1768"\w* \w be|strong="H1934"\w* something \w concerning|strong="H5922"\w* \w the|strong="H3606"\w* laws \w that|strong="H1768"\w* \w his|strong="H5922"\w* god \add his given him\add*.”   
\p
\v 6 \w So|strong="H1768"\w* \w the|strong="H3606"\w* administrators \w and|strong="H1841"\w* governors \w went|strong="H1841"\w* \w as|strong="H3606"\w* \w one|strong="H1836"\w* group \w to|strong="H5922"\w* \w the|strong="H3606"\w* king \w and|strong="H1841"\w* said, “◄\w Your|strong="H5922"\w* Majesty/\w O|strong="H3068"\w* king►, \w we|strong="H3068"\w* wish \w that|strong="H1768"\w* \w you|strong="H1768"\w* \w will|strong="H1768"\w* live \w a|strong="H3068"\w* long time!  
\v 7  \add We\add* administrators \w and|strong="H4430"\w* governors \w and|strong="H4430"\w* district governors \w and|strong="H4430"\w* advisors \w and|strong="H4430"\w* other officials \w have|strong="H4430"\w* \w all|strong="H5957"\w* agreed \w that|strong="H5922"\w* \w you|strong="H5922"\w* \w should|strong="H4430"\w* make \w a|strong="H3068"\w* law \w that|strong="H5922"\w* everyone must obey. We want \w you|strong="H5922"\w* \w to|strong="H5922"\w* command \w that|strong="H5922"\w* \w for|strong="H5922"\w* \w the|strong="H5922"\w* next thirty days people may pray only \w to|strong="H5922"\w* \w you|strong="H5922"\w*. If anyone prays \w to|strong="H5922"\w* anyone else, either \w to|strong="H5922"\w* \w a|strong="H3068"\w* human \w or|strong="H4430"\w* \w to|strong="H5922"\w* \w a|strong="H3068"\w* god, \w he|strong="H3652"\w* must \w be|strong="H5957"\w* thrown into \add a pit of \add* lions.  
\v 8 \w And|strong="H4430"\w* \w because|strong="H4481"\w* laws \w made|strong="H6966"\w* \w by|strong="H4481"\w* \add our governments of\add* Media \w and|strong="H4430"\w* Persia cannot be changed, \add we want\add* \w you|strong="H1768"\w*, \add the head of our government\add*, \w to|strong="H5705"\w* sign \w it|strong="H4481"\w*.”  
\v 9 \w So|strong="H1768"\w* \w King|strong="H4430"\w* Darius \add wrote\add* \w the|strong="H1768"\w* \w law|strong="H1882"\w* \w and|strong="H4430"\w* \w signed|strong="H7560"\w* it.   
\p
\v 10 \w But|strong="H3606"\w* when \w I|strong="H1836"\w* found out \w that|strong="H3606"\w* \add the king\add* \w had|strong="H4430"\w* \add written and\add* \w signed|strong="H7560"\w* \w that|strong="H3606"\w* law, \w I|strong="H1836"\w* went home. \w I|strong="H1836"\w* knelt down \w in|strong="H4430"\w* \w my|strong="H4430"\w* upstairs room \w and|strong="H4430"\w* prayed. \w I|strong="H1836"\w* looked toward Jerusalem, \w and|strong="H4430"\w* \w the|strong="H3606"\w* windows were open \add with the result that everyone could see me while I was praying\add*. \w I|strong="H1836"\w* prayed three times each day, \w just|strong="H6903"\w* \w as|strong="H3606"\w* \w I|strong="H1836"\w* always did, thanking God.  
\v 11 \w The|strong="H3606"\w* officials \w went|strong="H5954"\w* together \add to my house\add* \w and|strong="H3792"\w* \w they|strong="H1768"\w* \w saw|strong="H1934"\w* \w me|strong="H5922"\w* \w praying|strong="H6739"\w* \w and|strong="H3792"\w* requesting God \w to|strong="H5922"\w* help \w me|strong="H5922"\w*.  
\v 12 So they returned \w to|strong="H6925"\w* \w the|strong="H6925"\w* king \w and|strong="H1156"\w* said \w to|strong="H6925"\w* \w him|strong="H6925"\w*, “\add Do you remember\add* \w that|strong="H1400"\w* you wrote \w a|strong="H3068"\w* law stating \w that|strong="H1400"\w* \w for|strong="H1156"\w* \w the|strong="H6925"\w* next thirty days \w people|strong="H1400"\w* may pray only \w to|strong="H6925"\w* you, \w and|strong="H1156"\w* if anyone \w prays|strong="H1156"\w* \w to|strong="H6925"\w* anyone else, either \w to|strong="H6925"\w* \w a|strong="H3068"\w* human or \w to|strong="H6925"\w* \w a|strong="H3068"\w* god, \w he|strong="H1841"\w* will \w be|strong="H1841"\w* thrown into \add a pit of\add* lions?”  
\p \w The|strong="H6925"\w* king replied, “\add Yes, that is the law that I wrote\add*. \w It|strong="H6925"\w* is \w a|strong="H3068"\w* law \w of|strong="H6925"\w* \add our governments of\add* Media \w and|strong="H1156"\w* Persia, which cannot \w be|strong="H1841"\w* canceled.”   
\p
\v 13 \w Then|strong="H1768"\w* \w they|strong="H3606"\w* \w said|strong="H6032"\w* \w to|strong="H5922"\w* \w the|strong="H3606"\w* \w king|strong="H4430"\w*, “Well, \w that|strong="H1768"\w* \add man\add* Daniel, one \w of|strong="H4481"\w* \w the|strong="H3606"\w* men \w who|strong="H1768"\w* \w were|strong="H1768"\w* brought \w from|strong="H4481"\w* Judah, \w is|strong="H1768"\w* \w not|strong="H3809"\w* paying \w any|strong="H3606"\w* attention \w to|strong="H5922"\w* \w you|strong="H1768"\w* \w or|strong="H3809"\w* \w the|strong="H3606"\w* \w law|strong="H1882"\w* \w that|strong="H1768"\w* \w you|strong="H1768"\w* \add signed\add*. \w He|strong="H1768"\w* \w prays|strong="H1156"\w* \add to his god\add* three times each \w day|strong="H3118"\w*!”  
\v 14 \w When|strong="H1768"\w* \w the|strong="H5922"\w* \w king|strong="H4430"\w* heard \w that|strong="H1768"\w*, \w he|strong="H1768"\w* \w was|strong="H4430"\w* very distressed. \w He|strong="H1768"\w* tried \w to|strong="H5922"\w* find \w a|strong="H3068"\w* way \w to|strong="H5922"\w* save \w me|strong="H5922"\w*. All \w the|strong="H5922"\w* rest \w of|strong="H4481"\w* \w that|strong="H1768"\w* \w day|strong="H3118"\w* \w he|strong="H1768"\w* tried \w to|strong="H5922"\w* think \w of|strong="H4481"\w* \w a|strong="H3068"\w* way \w to|strong="H5922"\w* rescue \w me|strong="H5922"\w*.   
\p
\v 15  \add In the evening, many of\add* [HYP] \w the|strong="H5922"\w* officials \w went|strong="H1841"\w* together \w to|strong="H5922"\w* \w the|strong="H5922"\w* \w king|strong="H4430"\w* \w and|strong="H4430"\w* said, “◄\w Your|strong="H5922"\w* Majesty/\w O|strong="H3068"\w* \w king|strong="H4430"\w*►, \w you|strong="H1768"\w* know \w that|strong="H1768"\w* \add our governments of\add* Media \w and|strong="H4430"\w* Persia \w have|strong="H1934"\w* declared \w that|strong="H1768"\w* no law \w that|strong="H1768"\w* \w the|strong="H5922"\w* \w king|strong="H4430"\w* signs \w can|strong="H1768"\w* \w be|strong="H1934"\w* canceled/changed. \add So Daniel must be thrown to the lions!\add*”   
\p
\v 16 \w So|strong="H1768"\w* \w the|strong="H3606"\w* \w king|strong="H4430"\w* gave \w the|strong="H3606"\w* order, \w and|strong="H4430"\w* \w his|strong="H5922"\w* servants brought \w me|strong="H5922"\w* \w and|strong="H4430"\w* threw \w me|strong="H5922"\w* into \w a|strong="H3068"\w* pit \w where|strong="H1768"\w* \w the|strong="H3606"\w* lions \add were\add*. \add Before they threw me in\add*, \w the|strong="H3606"\w* \w king|strong="H4430"\w* said \w to|strong="H5922"\w* \w me|strong="H5922"\w*, “\w I|strong="H1768"\w* hope/wish \w that|strong="H1768"\w* \w your|strong="H1768"\w* God, \w whom|strong="H1768"\w* \w you|strong="H1768"\w* worship regularly, \w will|strong="H1768"\w* rescue \w you|strong="H1768"\w*!”   
\p
\v 17 \w They|strong="H1768"\w* rolled \w a|strong="H3068"\w* huge stone across \w the|strong="H1768"\w* entrance \w to|strong="H4430"\w* \w the|strong="H1768"\w* pit. \w Then|strong="H4430"\w* \w the|strong="H1768"\w* \w king|strong="H4430"\w* \add fastened a string across the entrance and put wax at each end, and stamped the wax with\add* \w the|strong="H1768"\w* seal \w from|strong="H1768"\w* \w his|strong="H7804"\w* \add ring\add* \w and|strong="H6032"\w* \w the|strong="H1768"\w* seals \add of the rings\add* \w of|strong="H4430"\w* \w his|strong="H7804"\w* officials, \w in|strong="H4430"\w* order \w that|strong="H1768"\w* no \w one|strong="H1932"\w* \w could|strong="H1768"\w* \add secretly\add* \w rescue|strong="H7804"\w* me.  
\v 18 \w Then|strong="H4430"\w* \w the|strong="H5922"\w* \w king|strong="H4430"\w* returned \w to|strong="H5922"\w* \w his|strong="H5922"\w* palace. \w That|strong="H1768"\w* night \w he|strong="H1768"\w* refused \w to|strong="H5922"\w* eat any food. \w He|strong="H1768"\w* would \w not|strong="H3809"\w* allow anyone \w to|strong="H5922"\w* entertain \w him|strong="H5922"\w* \add because he did not want to be happy, with the result that he would forget about me. And that night \add* \w he|strong="H1768"\w* \w was|strong="H4430"\w* unable \w to|strong="H5922"\w* sleep \add because he was worried about me\add*.   
\p
\v 19 At dawn \w the|strong="H5922"\w* next morning, \w the|strong="H5922"\w* \w king|strong="H4430"\w* got \w up|strong="H6925"\w* \w and|strong="H4430"\w* \w went|strong="H5954"\w* quickly \w to|strong="H5922"\w* \w the|strong="H5922"\w* pit where \w the|strong="H5922"\w* lions \w were|strong="H3809"\w*.  
\v 20 \w When|strong="H1768"\w* \w he|strong="H1768"\w* \w came|strong="H1768"\w* near it, \w he|strong="H1768"\w* \w was|strong="H4430"\w* \w very|strong="H6966"\w* worried. \w He|strong="H1768"\w* called \w out|strong="H6966"\w*, “Daniel, \w you|strong="H1768"\w* \w who|strong="H1768"\w* serve \w the|strong="H1768"\w* all-powerful God! \w Was|strong="H4430"\w* \w your|strong="H1768"\w* God, \w whom|strong="H1768"\w* \w you|strong="H1768"\w* worship regularly, able \w to|strong="H4430"\w* save \w you|strong="H1768"\w* \w from|strong="H1768"\w* \w the|strong="H1768"\w* lions?”   
\p
\v 21 \w I|strong="H4481"\w* \w answered|strong="H6032"\w*, “◄\w Your|strong="H6399"\w* Majesty/\w O|strong="H3068"\w* \w king|strong="H4430"\w*►, \w I|strong="H4481"\w* hope \w that|strong="H1768"\w* \w you|strong="H1768"\w* \w will|strong="H1768"\w* live \w a|strong="H3068"\w* long time!  
\v 22  \add Yes\add*, \w my|strong="H4430"\w* God sent his angel \w to|strong="H5974"\w* shut \w the|strong="H5974"\w* lions’ mouths, \w in|strong="H4430"\w* order \w that|strong="H4430"\w* they would not harm me! \add He did that\add* because \add he knows that\add* I \w have|strong="H4430"\w* done nothing \w that|strong="H4430"\w* \w he|strong="H1841"\w* thinks is wrong. \w And|strong="H4430"\w*, ◄Your Majesty/\w O|strong="H3068"\w* \w king|strong="H4430"\w*►, I \w never|strong="H5957"\w* did anything wrong \w to|strong="H5974"\w* you!”   
\p
\v 23 \w The|strong="H3606"\w* \w king|strong="H4430"\w* \w was|strong="H4430"\w* extremely happy, \w and|strong="H4430"\w* \w he|strong="H1768"\w* commanded \add his servants\add* \w to|strong="H6925"\w* lift \w me|strong="H6925"\w* \w out|strong="H5648"\w* \w of|strong="H4430"\w* \w the|strong="H3606"\w* pit. \add When they did that, they\add* saw \w that|strong="H1768"\w* \w the|strong="H3606"\w* lions \w had|strong="H4430"\w* \w not|strong="H3809"\w* wounded \w me|strong="H6925"\w* \w at|strong="H6903"\w* \w all|strong="H3606"\w*. \add God had protected me\add* \w because|strong="H6903"\w* \w I|strong="H1768"\w* trusted \w in|strong="H7912"\w* \w him|strong="H6925"\w*.   
\p
\v 24 \w Then|strong="H4430"\w* \w the|strong="H3606"\w* \w king|strong="H4430"\w* \w commanded|strong="H4481"\w* \w that|strong="H1768"\w* \w the|strong="H3606"\w* men \w who|strong="H1768"\w* \w had|strong="H4430"\w* accused \w me|strong="H5922"\w* \w should|strong="H4430"\w* \w be|strong="H3809"\w* seized \w and|strong="H4430"\w* \w be|strong="H3809"\w* thrown, along \w with|strong="H1841"\w* \w their|strong="H3606"\w* wives \w and|strong="H4430"\w* children, into \w the|strong="H3606"\w* pit \w where|strong="H1768"\w* \w the|strong="H3606"\w* lions \w were|strong="H1768"\w*. \add When they were thrown into the pit\add*, \w the|strong="H3606"\w* lions leaped \w on|strong="H5922"\w* \w them|strong="H5922"\w* \w and|strong="H4430"\w* crushed \w their|strong="H3606"\w* bones \w before|strong="H4481"\w* \w they|strong="H3606"\w* fell onto \w the|strong="H3606"\w* bottom \w of|strong="H4481"\w* \w the|strong="H3606"\w* pit!   
\p
\v 25 \w Then|strong="H4430"\w* \w King|strong="H4430"\w* Darius wrote \add this message and sent it throughout his kingdom\add* \w to|strong="H5705"\w* \w the|strong="H3606"\w* \w people|strong="H1400"\w* \w of|strong="H4430"\w* \w every|strong="H3606"\w* people-group \w and|strong="H4430"\w* nation \w and|strong="H4430"\w* \w from|strong="H1768"\w* \w all|strong="H3606"\w* language groups:  
\b  
\pi1 “\w I|strong="H1768"\w* wish/hope \w that|strong="H1768"\w* \w everything|strong="H3606"\w* \w is|strong="H1768"\w* going very well \w with|strong="H1841"\w* \w you|strong="H1768"\w*!   
\pi1
\v 26 \w I|strong="H1768"\w* command \w that|strong="H1768"\w* \w everyone|strong="H3606"\w* \w in|strong="H1753"\w* \w my|strong="H1768"\w* kingdom \w should|strong="H4430"\w* fear \w and|strong="H4430"\w* revere \w the|strong="H3606"\w* God \w that|strong="H1768"\w* Daniel \add worships\add*.  
\q1 \w He|strong="H1768"\w* \w is|strong="H1768"\w* \w the|strong="H3606"\w* all-powerful God,  
\q2 \w and|strong="H4430"\w* \w he|strong="H1768"\w* \w will|strong="H1768"\w* \w live|strong="H1753"\w* forever.  
\q1 \w His|strong="H1768"\w* kingdom \w will|strong="H1768"\w* never \w be|strong="H8001"\w* destroyed;  
\q2 \w he|strong="H1768"\w* \w will|strong="H1768"\w* rule forever.   
\q1
\v 27 \w He|strong="H1768"\w* rescues \w and|strong="H4437"\w* saves \add his people\add*.  
\q2 \w He|strong="H1768"\w* performs \w all|strong="H3606"\w* kinds \w of|strong="H4481"\w* miracles  
\q2 \w in|strong="H4437"\w* heaven \w and|strong="H4437"\w* \w on|strong="H5705"\w* \w the|strong="H3606"\w* earth.  
\q1 \w He|strong="H1768"\w* rescued \w Daniel|strong="H1841"\w* \w from|strong="H4481"\w* \w the|strong="H3606"\w* power \w of|strong="H4481"\w* \w the|strong="H3606"\w* lions!”   
\p
\v 28 \w So|strong="H1768"\w* \w I|strong="H4481"\w* \w was|strong="H1841"\w* successful \add all\add* during \w the|strong="H4481"\w* time \w that|strong="H1768"\w* Darius ruled \w and|strong="H8065"\w* during \w the|strong="H4481"\w* time \w that|strong="H1768"\w* Cyrus, \add the King\add* \w of|strong="H4481"\w* Persia, ruled.   
\c 7  
\s1 Daniel dreamed about four beasts  
\p
\v 1  \add Previously,\add* during \w the|strong="H5922"\w* \w first|strong="H2298"\w* \w year|strong="H8140"\w* \w that|strong="H4430"\w* \w Belshazzar|strong="H1113"\w* \w was|strong="H4430"\w* \w the|strong="H5922"\w* \w king|strong="H4430"\w* \w of|strong="H4430"\w* Babylonia, I \w had|strong="H4430"\w* \w a|strong="H3068"\w* \w dream|strong="H2493"\w* \w and|strong="H4430"\w* \w a|strong="H3068"\w* \w vision|strong="H2376"\w* \w one|strong="H2298"\w* night as I lay \w on|strong="H5922"\w* \w my|strong="H5922"\w* \w bed|strong="H4903"\w*. \add The next morning\add* I \w wrote|strong="H3790"\w* \w down|strong="H3790"\w* \w what|strong="H4406"\w* I \w had|strong="H4430"\w* dreamed. \w This|strong="H5922"\w* \w is|strong="H4406"\w* \w what|strong="H4406"\w* I \w wrote|strong="H3790"\w*:   
\p
