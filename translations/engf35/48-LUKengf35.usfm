\v 31 \w of|strong="G3588"\w* \w Melea|strong="G3190"\w*, \w of|strong="G3588"\w* \w Menan|strong="G3104"\w*, \w of|strong="G3588"\w* \w Mattatha|strong="G3160"\w*, \w of|strong="G3588"\w* \w Nathan|strong="G3481"\w*, \w of|strong="G3588"\w* \w David|strong="G1138"\w*,
