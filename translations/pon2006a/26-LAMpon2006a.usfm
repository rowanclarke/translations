\id LAM Pohnpeian Bible 
\h KOULEN KEDEPWIDEPW KAN 
\toc1 KOULEN KEDEPWIDEPW KAN 
\toc2 KOULEN KEDEPWIDEPW KAN 
\toc3 Koul. 
\mt1 KOULEN KEDEPWIDEPW KAN  
\is1 Oaralap en Pwuhk wet  
\ip Pwuhken \bk Koulen Kedepwidepw kan\bk*, iei koul limau me audepahr iei kedepwidepw en ohlahn Serusalem ni pahr 586 mwohn Krais, oh paisuwedlahn aramas akan me wiawi mwurin ohlao oh kalipilipalahn aramas akan sang Serusalem. Ni nsensuwed laud eh kadirelahr pwuhk wet, ahpw iet pwe koapworopworki Koht oh pil koapworopworpen ahnsou kohkohdo me pil sansal mehlel. Mehn Suhs ako kin doadoahngki koul pwukat ni ar kaudok kan ni rahnen kaisihsol oh kedepwidepw kan pwe re en kin wiahki katamanpen ohlahn arail wehi ni pahr 586 mwohn Krais.  
\iot Audepe ni Oaralap  
\io1 Kapahtou kan en Serusalem 1.1-22  
\io1 Kalokolok en Serusalem 2.1-22  
\io1 Kalokolok oh koapworopwor 3.1-66  
\io1 Serusalem ohla 4.1-22  
\io1 Kapakap en peki mahk oh kalahngan 5.1-22  
\c 1  
\s1 Kapahtou kan en Serusalem  
\q1
\v 1 Meid kansensuwed eh solahr tohn Serusalem, kahnimw me kin diren aramas mahs!  
\q2 Sampah pwon kin wauneki mahs, met e duwelahr liohdi men;  
\q2 Kahnimw keieu wauno wialahr lidu met.\x - \xo 1.1 \xt Par. 4.12.\x*   
\b  
\q1
\v 2 E kin wie sengiseng pwohng ehu pwon; pilen mese kin kerekeredi likinsepe.  
\q2 Sohte emen kompoakepah en mahs ako mihmi reh pwe en kaloalamwahwihala.  
\q2 Kompoakepah kan koaros pangalahr oh kin uhd uhwong met.   
\b  
\q1
\v 3 Mehn Suda kan kalipilipasangehr nan uhdakarail, oh milahr nan kahpwal oh mour en lidu.  
\q2 Re kousoanlahr nan wehi teikan, oh sohte wasa kis me re kak kahdaneki uhdakarail—  
\q2 Imwintihti kan kapilirailpenehr, oh sohte wasa re kak pitla ie.   
\b  
\q1
\v 4 Solahr me kolahng nan Tehnpas Sarawio met pwe en wia kaudok ni rahn sarawi kan.  
\q2 Serepein kan me kin kokoul wasao mahs milahr nan lokolok, oh ihte weirek me samworo kan wiewia.  
\q2 Ewen kelen kahnimwo tehnlahr, oh Saion wie weiweirekehr.   
\b  
\q1
\v 5 Eh imwintihti kan powedier; e milahr pahn ar manaman.  
\q2 KAUN-O ketin kaloke pwehki dihp tohto me e wiadahr;  
\q2 Nah seri kan lohdier oh wisiksangehr.   
\b  
\q1
\v 6 Lingan en Serusalem sohralahr.  
\q2 Nah kaun akan duwelahr tie kei me luwetkilahr ar duhpek,  
\q2 Me ar kehl sosohralahr nindokon ar tangatangasang sounkesikmen kan.   
\b  
\q1
\v 7 Serusalem wialahr mohn ihmw met, oh e tamanda eh lingan en mahs.  
\q2 Ni eh lohdi pahn imwintihtio sohte emen mehn sewese;  
\q2 Eh imwintihti kan kouruhrki eh pwupwudi.   
\b  
\q1
\v 8 Solahr wahupe; e kilisoudahr oh mwahllahr.  
\q2 E kin weiweirek oh ekihla mese pwehki eh sarohdier.  
\q2 Serusalem kasaminehkilahr pein ih dihp suwed ehu.   
\b  
\q1
\v 9 Eh samin me inenen sansal mehlel, ahpw e sohte mwomwen nsenohki dahme pahn lelohng.  
\q2 Eh pwupwudi me kapwuriamwei mehlel; sohte emen me kak koaloalamwahwihala.  
\q2 Eh imwintihti kan powedier, e ahpw pekipeki KAUN-O en ketin kupwur mahkohng.   
\b  
\q1
\v 10 Imwintihti kan pirapahsangehr eh kepwe kesempwal koaros.  
\q2 Pein ih kilang duwen imwintihti kan ar pedelong nan Tehnpas Sarawio,  
\q2 Wasa me KAUN-O ketin keinapwihasang mehn liki kan en pedolong ie.   
\b  
\q1
\v 11 Nah aramas akan kin wie sengiseng nindokon ar kin raparapahki dahme re en tungoale;  
\q2 Re kin wiliankihda ar dipwisou kesempwal kan ong ni kisin tungoal pwe re en momourki.  
\q2 Kahnimwo kin wie sengiseng pekipeki, “Maing KAUN, komw ketin mahsanih ie, komw ketin mahsanih ei apwal.”   
\b  
\q1
\v 12 Eh kin sengiseng pekipeki rehn aramas koaros me kin keid limwah, “Kumwail kilang ie.  
\q2 Sohte emen me ahneki medek duwehte ngehi,  
\q2 Medek me KAUN-O ketikidohng pohi nan sapwellime engieng.   
\b  
\q1
\v 13 “E ketikihdo kisiniei sang powe, kisiniei ehu me isikalahr loalei.  
\q2 E ketikidier lidip ehu mwohi oh keseiedier nanpwel.  
\q2 E ahpw ketin keseiehla nan medek poatopoat.   
\b  
\q1
\v 14 “E ketin kilelehdi dipei koaros oh ketin pirepene;  
\q2 E ketin tenekidahng pahn tepinwerei, I ahpw toutoukihla oh luwetkihla.  
\q2 KAUN-O ketikilahng ie rehn ei imwintihti kan, oh sohla mehn sewese ie rehrail.   
\b  
\q1
\v 15 “Kaun-o ketin kiparamatki nei sounpei keieu kehlail kan;  
\q2 E ketikihdo karis ehu pwe re en kamwomwala nei mwahnakapw akan.  
\q2 E ketin tiakpeseng nei aramas akan rasehng wahn wain ni wasahn tiak wain.   
\b  
\q1
\v 16 “Ih kahrepen pilen mesei eh kereker.  
\q2 Sohte me pahn koaloalamwahwihiehla; sohte me kak kakehlahda nan kapehdi.  
\q2 Imwintihtio kaloweiedier; solahr en nei aramas akan mehkot me luhwehdi.   
\b  
\q1
\v 17 “I kapawehr pehi kat, ahpw sohte me pahn sewesei ie.  
\q2 KAUN-O ketin malipedohr imwintihti kan sang wasa koaros pwe re en uhwong ie;  
\q2 Re kin wiahkin ie mehkot saut.   
\b  
\q1
\v 18 “Ahpw KAUN-O me ketin pwung, pwehki ngehi me sapeikiong ih.  
\q2 Kumwail rong ie, kumwail wehi koaros; kumwail kilengdohng ei lokolok wet.  
\q2 Nei mwahnakapw oh peinakapw akan seldier oh wisiksangehr.   
\b  
\q1
\v 19 “I likwerih kompoakepahi kan, ahpw re sohte men sewesei ie.  
\q2 Samworo kan oh kaun akan mehla nanial akan en kahnimwo,  
\q2 Ni ar raparapahki arail kisin tungoal pwe re en kak mourkihla.   
\b  
\q1
\v 20 “Maing KAUN, komw mahsanih ei medek mwuledek, tihwolahn nan kapehdiet!  
\q2 Mohngiongi ohkilahr ei pahtoukihla dipei kan.  
\q2 Kamaramas wiewiawi nanial akan; mehla pil mie nan ihmw kan.   
\b  
\q1
\v 21 “Komw ketin karonge ngilen ei weirek; sohte me pahn koaloalamwahwihiehla.  
\q2 Ei imwintihti kan perenkihda omwi ketikidohng pohi kahpwal wet.  
\q2 Komwi ketikihdo rahno me komwi ketin inoukidahr; komwi ketin kaloke ei imwintihti duwehte me komwi wiahiongieier.   
\b  
\q1
\v 22 “Komwi ketin kerieirailla pwehki ar wiewia suwed kan;  
\q2 Komw ketin kalokehkin irail diparail kan duwehte omwi ketin kalokehkinieier dipei kan.  
\q2 I wie weiweirek nan ei apwal, oh mohngiongi weikeklahr.”   
\c 2  
\s1 Sapwellimen Kaun-o Kalokolok ong Serusalem  
\q1
\v 1 Kaun-o nan sapwellime engieng ketin kipehkidier Saion rotorot.  
\q2 E ketin kauwelahr eh lingan koaros.  
\q2 E pil ketin kesehla sapwellime Tehnpas Sarawio ni rahn me e engiengdao.   
\b  
\q1
\v 2 Kaun-o ketin kamwomwala ni sohte mahk kisin kahnimw koaros en Suda  
\q2 Oh ketin karangkehdi kelen mahwen kan me kin doandoare wehio.  
\q2 E ketin kasarowehdi wehio oh eh kaun akan.   
\b  
\q1
\v 3 Nan sapwellime engieng e ketin kauwehla kehlail en Israel;  
\q2 E ketin soikala oh sohte kupwurki sewesei kitail ni ahnsou me imwintihtio leledo.  
\q2 E ketin engiengda pahtail rasehng kisiniei, me kamwomwala mehkoaros.   
\b  
\q1
\v 4 E ketin rasehng imwintihti men me kadarodohng kitail sapwellime arep;  
\q2 E ketin kemehla irail koaros me kin wia atail peren oh nsenamwahu.  
\q2 Met nan Serusalem se kehn engin sapwellime engieng laud.   
\b  
\q1
\v 5 Kaun-o ketin kamwomwala Israel, rasehng imwintihti men;  
\q2 E ketin kauwehla eh kelen mahwen kan oh tehnpesen nanmwarki kan.  
\q2 E ketikidohng pohn Suda pahtou ehu me sohte pahn imwisekla.   
\b  
\q1
\v 6 E ketin kiedpeseng Tehnpas Sarawio wasa me se kin kaudokiong ih ie;  
\q2 E ketin katokehdi rahn sarawi kan oh rahnen Sapad kan.  
\q2 Nanmwarki oh pil samworo iang kehn engin sapwellime engieng.   
\b  
\q1
\v 7 Kaun-o ketin soikalahr sapwellime pei sarawio oh kesehla sapwellime Tehnpas Sarawio;  
\q2 E ketin mweidohng imwintihtio en karangkehdi kele kan.  
\q2 Re wie kadekadekedek en powehdi wasa me se kin pereperen wiewia ie at kaudok mahs.   
\b  
\q1
\v 8 KAUN-O ketin koasoanedier pwe kelen Saion kan en rengkidi;  
\q2 E ketin sohngdier pwe en mwahngih uwen mwomwla me pahn wiawi.  
\q2 Wasahn iroir kan oh kehl kan wonohnehr nanpwel ohlahr.   
\b  
\q1
\v 9 Ewen kehl kan seridier nanpwel, wenihmw mete kan mwerpesengier.  
\q2 Nanmwarkio oh soupeidi kan kalipilipalahr.  
\q2 Solahr me sukuhlki Kosonnedo, oh soukohp kan solahr ale kaudiahl sang rehn KAUN-O.   
\b  
\q1
\v 10 Ohl mah kan en Serusalem mwomwohdehr nanpwel solahr mwekid,  
\q2 Pwelpar mi pohn moangarail kan oh re likawih likoun nsensuwed.  
\q2 Peinakapw akan itiekdier nanpwel.   
\b  
\q1
\v 11 Pwoaren mesei kat medengkilahr ei sengiseng; ngeni tihwolahr.  
\q2 Solahr angihki ei pahtouki mwomwlahn nei aramas akan.  
\q2 Seri oh seri pwelel kan lupwolupwongmas nan ahl akan en kahnimwo.   
\b  
\q1
\v 12 Re duhpeklahr oh men nimpildahr, oh kin wie sengisengiong ar nohno kan;  
\q2 Re kin pwupwudi nanial akan likamwete re soahn,  
\q2 Re ahpw kin wie luhluwetala oh mehla nan pehn ar nohno kan.   
\b  
\q1
\v 13 Oh Serusalem! Kompoakepahi Serusalem, dahme I kak nda?  
\q2 Ia duwen ei pahn kak koaloalamwahwihiukala? Saikinte me iang ale soangen lokolok wet.  
\q2 Omw apwal rasehng madau me sohte irepe; sohte mehkot me ke kak koapworopworki.   
\b  
\q1
\v 14 Solahr me omw soukohp kan pahn kohpada pwe kokohp likamwte;  
\q2 Arail padahk pitihiuk ni eh sohte kasalehiong uhk dipomw kan.  
\q2 Re soh mwahn kasalehiong uhk dipomw kan pwe ke en koluhkihla oh wiliakapwala.   
\b  
\q1
\v 15 Aramas akan me kin keid limwahn kahnimwo kin kangkakil uhk ni mwamwahl.  
\q2 Re kin itikala moangarail kan oh kouruhrki ohlahn Serusalem:  
\q2 “Ih kahnimw kaselelo met? Ih kahnimwo met me sampah kin pohnmwahsohki?”   
\b  
\q1
\v 16 Omw imwintihti koaros kin kouruhrkin uhk oh kangkakilkin uhk ar kailok.  
\q2 Re kin kepirek oh nda, “Se kamwomwalahr!  
\q2 Iei ih rahnwet me se kin kasikasik!”   
\b  
\q1
\v 17 KAUN-O ketin kapwaiadahr dahme e kupwuredahr en ketin wia.  
\q2 E ketin kamwomwkitala ni sohte kupwur mahk, nin duwen e ketin kehkehlingkihong kiht mahsie.  
\q2 E ketin mweidohng at imwintihti kan en poweikitedi, oh re en perenkihda at pwupwudi.   
\b  
\q1
\v 18 Oh Serusalem, omw kehl kan en peki sawas rehn Kaun-o!  
\q2 Pilen mesomw kan en kereker nin rahn nipwong rasehng pwilipwil en pillap;  
\q2 Ke en mwohtohtkihla omw sengiseng oh pahtou!   
\b  
\q1
\v 19 Ke en kin pirida pak tohto nipwong kan, pwe ke en kin pekipeki sawas rehn Kaun-o;  
\q2 Nan omw mohngiong unsek ke en pekipeki pahn kupwure— kalahngan ong noumw seri kan—  
\q2 Seri kan me pahn mehkilahr ar duhduhpek wasa koaros pohn ahl akan!   
\b  
\q1
\v 20 Maing KAUN, komwi ketin kupwure irail kan me milahr pahn engieng en kupwuromwi!  
\q2 Lih akan tungutungoalehier paliweren seri kan me re kin poakohng!  
\q2 Samworo oh soukohp kan kamakamalahr nan Tehnpas Sarawio!   
\b  
\q1
\v 21 Koaros me mah oh pwulopwul kan wonohnehr mehla nanial akan,  
\q2 Nein imwintihti kan kedlahs kemelahr mwahnakapw oh peinakapw akan,  
\q2 Komwi ketin kemeiraillahr ni sohte kupwur mahk ni rahnen omwi engiengo.   
\b  
\q1
\v 22 Komw ketin lukedohr ei imwintihti kan pwe re en kamasak ie sang pali koaros, rasehng omwi pahn ketin lukeiraildohng ni kamadipw ehu.  
\q2 Oh sohte me kak pitsang rahnen omwi engiengo.  
\q2 Re kemelahr nei seri kan, me I kairada oh kin poakohng.   
\c 3  
\s1 Kalokolok, Wiliakapwala, oh Koapworopwor  
\q1
\v 1 Iei ngehi me patohwan ese dahkot kalokolok sang rehn Koht.   
\q2
\v 2 E ketin pwakihielahng nan rotorot mosul.   
\q2
\v 3 Oh ketin wokiwokih ie ni sohte kupwur mahk.   
\b  
\q1
\v 4 E ketin kalipwelipwehda paliwereiet, oh katimpeseng tih kat.   
\q2
\v 5 E ketin salihiehdiong nan lokolok oh pwunod.   
\q2
\v 6 E ketin idingohng ie I en mihla nan rotorot en mehla.   
\b  
\q1
\v 7 E ketin salihkiniehdi selmete; ngehi aramas selidi men me sohte ahneki koapworopwor en pitla.   
\q2
\v 8 I liklikwer pekipeki sawas, ahpw Koht sohte ketin karonge ie;   
\q2
\v 9 I kin alialu wasawasasseli; kehl takai kin pereiehla wasa koaros me I kin keidla ie.   
\b  
\q1
\v 10 E ketin awiawih ie rasehng pehr men; e ketin lusdohng pohi rasehng laion men.   
\q2
\v 11 E ketin pwakihiehsang pohn ahl, e ahpw tehriepeseng oh keseiehla.   
\q2
\v 12 E ketikihda sapwellime kisik ketieu, oh wiahkin ie wasa me e pahn ketin kainenehiong sapwellime arep kan.   
\b  
\q1
\v 13 E ketin kadar sapwellime arep kan oh pwarolong nan paliwereiet.   
\q2
\v 14 Aramas akan kin wie kokouruhrkin ie rahn ehu pwon; I wialahr mehn kepit pahrail.   
\q2
\v 15 Lokolok mwuledek me e ketin katungoalehkin ie oh kanampilehkin ie.   
\b  
\q1
\v 16 E ketin itondiong meseiet nanpwel oh kauwehkihla ngih kat takai.   
\q2
\v 17 I sehselahr dahkot roson en paliwar, popohl oh nsenamwahu.   
\q2
\v 18 Ei mour mwotomwotalahr; ei koapworopworki KAUN-O sohralahr.   
\b  
\q1
\v 19 Medemedewen ei medek, ei saruwaru, iei pwoisin katik ehu.   
\q2
\v 20 I kin medemedewe mepwukat poatopoat, oh ngeni kin pwunodkihla.   
\q2
\v 21 Ahpw iet pwe ei koapworopwor kin mihiehla ni ei kin tamanda soahngteieu:   
\b  
\q1
\v 22 Sapwelimen KAUN-O limpoak poatopoat oh kupwur mahk sohte kin tokedi,   
\q2
\v 23 E kin kansenamwahu duwehte kansenamwahu en nimenseng, oh poatopoat duwehte dakadahn ketipin.   
\q2
\v 24 KAUN-O kelehpw me ahi, ihme kahrehda ih me I koapworopworki.   
\b  
\q1
\v 25 KAUN-O kin ketin kupwuramwahu ong koaros me kin likih,   
\q2
\v 26 Eri, ih me mwahu kitail koaros en kin kanengamah oh awiawih—awiawih pwe en ketin kamourkitailla—   
\q2
\v 27 Oh me mwahu kitail en esehla soangen kanengamah wet ni atail wie pwulopwulte.   
\b  
\q1
\v 28 Ni atail kin ale lokolok, kitail pahn mwohndi oh nennenla ni kanengamah;   
\q2
\v 29 Kitail pahn poaridi ni aktikitik, pwe ele e pahn miehte koapworopwor.   
\q2
\v 30 Mehnda ma kitail ale kamakam oh saroh, ahpw kitail pahn perenkihda.   
\b  
\q1
\v 31 Kaun-o me kupwurkalahngan oh sohte pahn soingkitailla kohkohlahte.   
\q2
\v 32 Ele e pahn ketikidohng pohtail pahtou, ahpw sapwellime limpoak ong kitail me mehlel oh kehlail.   
\q2
\v 33 E sohte kin kupwurperenkihda ni eh kin ketikidohng kitail pahtou de medek.   
\b  
\q1
\v 34 Kaun-o mwahngih ahnsou me ngenitail kan kin pahtoula nan imweteng kan;   
\q2
\v 35 E mwahngih ahnsou me kitail sohte kin paieki pwung en aramas me e ketikihong kitail;   
\q2
\v 36 Ni ahnsou me pwuhng kin pirekla nan mwoalen kopwung, e kin mwahngih.   
\b  
\q1
\v 37 Kupwur en Kaun-ohte me kin pweida ahnsou koaros.   
\q2
\v 38 Me mwahu oh suwed kin pweida sang ni sapwellime koasoandi.   
\q2
\v 39 Dahme kitail kin kaulimki atail kin ale kalokepen dipatail kan?   
\b  
\q1
\v 40 Kitail en kasawih atail wiewia kan oh sohpeiong KAUN-O.   
\q2
\v 41 Kitail ritingada mohngiongitail kan ong Koht nanleng oh kapakapohng, patohwan,   
\q2
\v 42 “Maing KAUN, se dipadahr oh kahngodiong komwi, ahpw komwi sohte kupwur mahkohng kiht.   
\b  
\q1
\v 43 “Komwi ketin idawehnkitodo oh kemeikitala; sapwellimomwi kupwurkalahngan rirlahr nan omwi engieng,   
\q2
\v 44 E rirlahr pahn pelien depwek mosul pali kahrehda at pekipek solahr kak lelewohng komwi.   
\q2
\v 45 Komwi wiahkinkitalahr wasahn kihd en sampah.   
\b  
\q1
\v 46 “Se wialahr mehn kepit rehn at imwintihti kan me kin kapailokei kiht.   
\q2
\v 47 Se milahr nan kahpwal oh paisuwed; se milahr nan mour keper oh kamasepwehk.   
\q2
\v 48 Pilen mesei kin pwilipwiliwei pwehki mwomwlahn nei aramas akan.   
\b  
\q1
\v 49 “Pilen mesei pahn pwilipwilwei sohte tokedi   
\q2
\v 50 Lao KAUN-O pahn mahsendihdo sang nanleng oh mahsanihkitada.   
\q2
\v 51 Mohngiongi toutoula ni ei kilang dahme wiawihongehr lih akan en kahnimwo.   
\b  
\q1
\v 52 “Ei imwintihti kan lidipihiehdi ni sohte kahrepe rasehng menpihr men.   
\q2
\v 53 Re keseiehdi nan pwoahr ehu ni ei momourte oh katapwurehiong takai ehu ni ewen pwoahro.   
\q2
\v 54 Pihl ahpw tapihada loalada pohi, I ahpw mengimengloalki me ei mehla keredohngieier.   
\b  
\q1
\v 55 “Maing KAUN, I ahpw likwerih komwi sang nan kepin pwoahro,   
\q2
\v 56 Oh ni ei peki komwi en ketin karonge ie, komwi ahpw ketin karonge ei pekipek.   
\q2
\v 57 Komwi ketin sapeng ie oh mahsanihong ie I en dehr masak.   
\b  
\q1
\v 58 “Maing ei Kaun, komwi ketin doareiehla, oh kamouriehla.   
\q2
\v 59 Komwi ketin uhpalihkin ie; komwi mwahngih duwen sapwung kan me wiawihongieier.   
\q2
\v 60 Komwi mwahngih duwen ei imwintihti kan ar kailongkin ie oh wiewia koasoandi suwed en uhwong ie.   
\b  
\q1
\v 61 “Maing KAUN, komwi ketin karongeier ar kepitkin ie, oh mwahngih ar koasoandi suwed kan.   
\q2
\v 62 Re kin ndinda ie oh wiewia ar koasoandi suwed kan rahn ehu pwon.   
\q2
\v 63 Re kin kokouruhrkin ie sang nimenseng lel nipwong.   
\b  
\q1
\v 64 “Maing KAUN, komwi ketin kalokehkin irail ar wiewia kan,   
\q2
\v 65 Komwi ketin kerieirailla oh kadirehkinirailla pwunod!   
\q2
\v 66 Komwi ketin koliraildi oh kamwomwirailla sang nin sampah!”   
\c 4  
\s1 Serusalem Mwurin Eh Pwupwudi  
\q1
\v 1 Atail kohl melengileng kan pohsuwedlahr;  
\q2 takai kan en Tehnpas Sarawio mwerediongehr nan ahl akan.   
\b  
\q1
\v 2 Mwahnakapw akan en Saion me kesempwal pahtail duwehte kohl,  
\q2 ahpw met re wiakaulahr duwehte einpwoat me wiawihkihda pwehl.   
\b  
\q1
\v 3 Kidi en wel kan pil kin kadihdi wahrail kan,  
\q2 ahpw nei aramas akan duwelahr mahn en nan sapwtehn kan, me lemeiong neirail seri kan.   
\b  
\q1
\v 4 Re kin mweidohng neirail seri kan en mehkihla duhpek oh men nimpil;  
\q2 seri kan kin wie pekipeki atail kisin tungoal oh sohte me men katungoaleirail.   
\b  
\q1
\v 5 Aramas akan me kin tungoale kisin tungoal keieu kaselel mahs, met re mehkilahr ar duhpwek nanial akan;  
\q2 irail kan me tikida nan mour mwahu mahs wie senserseli nan kihd kan reperepen mwenge.   
\b  
\q1
\v 6 Nei aramas akan aleier lokolok me laudsang lokolok en tohn Sodom,  
\q2 kalokolok ehu me lelohng irail ni ahnsou mwadang sang nin limen Koht.\x - \xo 4.6 \xt Sen. 19.24.\x*   
\b  
\q1
\v 7 Atail soupeidi kan me mwakelekel oh pwetepwet sang sinoh,  
\q2 paliwaramwahu oh kehlail, wie melengilengki roson mwahu.   
\b  
\q1
\v 8 Eri, met re wonohnehr nanial akan solahr me ese irail, masarail kan toantoalkilahr ar melahr;  
\q2 kilirail kan ngalangalahr duwehte tuhke, oh mwerekidier pohn tihrail kan.   
\b  
\q1
\v 9 Irail kan me mehla nan mahwen paiamwahusang irail kan me mehla mwuhr,  
\q2 me wie luhluhwetala oh mehkihla duhpek, me sohte kisin tungoal kis mehn komourirailla.   
\b  
\q1
\v 10 Kahpwal me lelohng nei aramas akan me kamasepwehk mehlel;  
\q2 nohno kan me kin poakohng nair seri kan pwoailihalahr nair seri kan pwe re en tungoale.\x - \xo 4.10 \xt Deud. 28.57; Esek. 5.10.\x*   
\b  
\q1
\v 11 KAUN-O ketin sapwadada sapwellime engieng mwuledek;  
\q2 e ketin isikada kisiniei ehu nan Saion, me kamwasikahla douluhl kahnimwo.   
\b  
\q1
\v 12 Sohte emen wasa kis, pil sohte kaunen wehin liki men,  
\q2 me kamehlele me imwintihti men kak pedolong nan ewen kelen Serusalem.   
\b  
\q1
\v 13 Ahpw met wiawiher, pwehki nah soukohp kan oh samworo kan ar wiadahr dihp  
\q2 ni ar kakeredier ntahn aramas mwakelekel kan.   
\b  
\q1
\v 14 Nah kaun akan kakahnseli nanial akan duwehte maskun kei,  
\q2 re saminkilahr nta me kahrehda sohte emen men sair irail.   
\b  
\q1
\v 15 Aramas akan kin weriwer ndinda, “Kumwail keiwei! Kumwail me samin! Kumwail dehr sair ie!”  
\q2 eri, kahrehda ar sansaruwaruseli sang nan ehu wehi kolahng ehu wehi pwe sohte me men kasamwo irail.   
\b  
\q1
\v 16 KAUN-O solahr kupwurohkin irail; pein ih me ketin kamwarakirailseli.  
\q2 E sohte ketin kasalehda wahu ong samworo kan oh kaun akan.   
\b  
\q1
\v 17 Se pwangadahr kasikasik sawas me sohte pahn leledo.  
\q2 Se awiawih sawas sang wehi ehu me sohte kak katehda mehkot.   
\b  
\q1
\v 18 Imwintihtio mwasamwasahn kiht; se pil sohte kak aluseli pohn ahl akan.  
\q2 At ahnsou imwiseklahr; imwin mehkoaros leledohr.   
\b  
\q1
\v 19 Marahra sang ikel kan me kin pihrdihsang pahnlahng, iei duwen at imwintihti kan ar pwakihkitedi.  
\q2 Re kaloweikitdi pohn dohl kan; re kolkitedi nan sapwtehno ni at sasairki.   
\b  
\q1
\v 20 Re kalowehdi pwarer en at mour, nanmwarkio me KAUN-O ketin piladahr,  
\q2 me se likih me pahn doareikitala sang at imwintihti koaros.   
\b  
\q1
\v 21 Kumwail kouruhr, kumwail mehn Edom oh Us; kumwail pereperen nindokon amwail kak.  
\q2 Kahpwal pil kokodohng kumwail; kumwail pil pahn iang wasawasasseli kilisou ni namenek.   
\b  
\q1
\v 22 Saion aleier dupukpen dipe; KAUN-O solahr pahn kolokol kitail wasa me kitail kalipilipalahngehr ie.  
\q2 Ahpw kowe Edom, KAUN-O pahn ketin kalokeiuk; e pahn ketin kasalehda omw wiewia sapwung kan.   
\c 5  
\s1 Kapakap en Peki Mahk oh Kalahngan  
\q1
\v 1 Maing KAUN, komwi ketin tamanda dahme wiawihong kiht.  
\q2 Komwi ketin mahsendohng kiht, oh mahsanih duwen at sarohdier.   
\b  
\q1
\v 2 At tungoal sohso milahr nan pehn mehn liki kan;  
\q2 mehn liki kan kousoanlahr nan at tungoal ihmw kan.   
\b  
\q1
\v 3 Imwintihti kan kemelahr at pahpa kan,  
\q2 oh met at nohno kan wialahr liohdi kei.   
\b  
\q1
\v 4 Se uhdahn pahn pwain pihl me se kin patohwan nim;  
\q2 se uhdahn pahn pwain tuhke me se kin wiahki tuwi.   
\b  
\q1
\v 5 Se pahkarewei rasehng ahs de kamel,  
\q2 me pwangadahr, ahpw sohte kak kommoal.   
\b  
\q1
\v 6 Se kin pekipeki rehn mehn Isip oh Asiria,  
\q2 kisin tungoal pwe se en kak mourki.   
\b  
\q1
\v 7 At pahpa kahlap ako dipadahr, ahpw met re solahr mie,  
\q2 oh se wie lokolongkier diparail kan.   
\b  
\q1
\v 8 Se milahr pahn manaman en aramas ekei me sohte siksang lidu kan,  
\q2 oh sohte me kak kapitasang kiht pahn ar manaman.   
\b  
\q1
\v 9 Sounkam aramas akan kohkohseli nan sahpwo;  
\q2 at mour kin mihla nan keper ni at kin raparapahki at tungoal kisin mwenge.   
\b  
\q1
\v 10 Duhpek kin kahrehda at soumwahu karakar laud  
\q2 lao kilit kan kin karakarala duwehte nan uhmw ehu.   
\b  
\q1
\v 11 Angkehlail wiawihong at pwoud kan nin Nahna Saion;  
\q2 nan kisin kahnimw koaros en Suda nait serepein kan idihdiong re en mweidala paliwararail kan.   
\b  
\q1
\v 12 At kaun akan wisiksangehr oh langadahr nin tuhke kan;  
\q2 nait ohl mah kan solahr wahuparail.   
\b  
\q1
\v 13 Nait mwahnakapw akan idihdiong re en ngidarpene kohn duwehte lidu kei;  
\q2 kisin pwutak kan kin wasawasasseli pahn ar wisik toutou en tuhke kan.   
\b  
\q1
\v 14 Me mah kan solahr mwomwohdseli ni ewen kelen kahnimwo,  
\q2 oh me pwulopwul kan solahr kesekeseng.   
\b  
\q1
\v 15 Peren sohrasangehr nan at mour;  
\q2 pahtou wiliandier kahlek kan.   
\b  
\q1
\v 16 Sohte mehkot me se kin pohnmwahsohki me luhwehdi.  
\q2 Se dipadahr, oh met se pahn melahr.   
\b  
\q1
\v 17 At mohngiong kan soumwahulahr  
\q2 oh se solahr kak kilangki wasa pilen masat akan,   
\b  
\q1
\v 18 pwehki Nahna Saion eh kalehpwlahr oh tehnlahr,  
\q2 oh mahn lawalo kan wie kohkohseli nan mohn ihmw kan.   
\b  
\q1
\v 19 Ahpw komwi, Maing KAUN, me wia nanmwarki kohkohlahte,  
\q2 oh pahn kakaun erein dih koaros kohkohlahte.   
\b  
\q1
\v 20 Dahme komwi ketin likidmeliekinkitala ahnsou reirei?  
\q2 Komwi pahn pwurehng ketin tamankitada?   
\b  
\q1
\v 21 Maing KAUN, komwi kasapahlkitewei pahn kupwuromwi! Komwi kasapahlkitewei!  
\q2 Komwi kasapahldohng kiht at lingan en mahs.   
\b  
\q1
\v 22 De komwi soh ketin soingkitalahr kohkohlahte?  
\q2 Ia duwe, sohte irepen sapwellimomwi engieng?   