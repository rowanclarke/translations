\id GAL - Yagua NT -Peru 2008 (web -2013)
\h Cadásiya
\toc1 Cadasiya Ja̱nvamyuju̱ra Catera
\toc2 Cadásiya
\toc3 Cad
\mt1 Cadasiya Ja̱nvamyuju̱ra Catera
\c 1
\s1 Pávurubay nu̱yada rijyu̱ra catera, samu̱chuveda variryi Ju̱denu siityari̱vavyedabay
\p 
\v 1 Ray Pávuru jiryatiy nusu̱chi̱ darye, ne vadumyusiy jti̱nu darye, dantyamu̱y ne nijya̱nvay jpa̱jadamu ray, Jesucrístu ji̱ta jpa̱jada darye, Vu̱jye̱ Ju̱denu jarye sisa̱ju̱, ni̱tiy mi̱sadeda diibyimusiñi̱ Jesús.
\v 2 Nu̱myu̱chuvay risa̱ vichavay taryi̱vedata ti̱ta̱ju̱ jirye, jiryatiy Cadásiyamu Ju̱denu siityari̱vajyuu jiryedye.
\v 3-4 Sa̱vichaniy Vu̱jye̱ Ju̱denu samirya jirye, jirya̱tidye vicha samirya variy, Vu̱yntyityu̱ Jesucrístu jarye ra̱vichaniy samirya variy jirye, tapi sara̱yadamu jidyiiyada vu̱jyuuchuveda jiyadaju̱. Ramusiy sa̱ntyuy vuryiva racabyimusiy, va̱cha vicha̱da rundajisiy, nu̱tyu sava̱tasara Vu̱jye̱ Ju̱denu vu̱jyu̱ darya.
\v 5 ¡Ra̱numa jasa̱jeya̱sara sadá ju̱na̱reju̱! ¡Daryanuma ra̱chajaya̱sara ti̱ta̱ju̱!
\s1 Vinu rani̱day samitu̱choda, ne tara jna̱y jadchiñu̱day, ranuma rani̱cha vuryeyada ra̱tya̱
\p 
\v 6 Ru̱ntama̱ ray, ratyi̱tta varirya jiryatiy varenu jaryuve jiryejiintyeryu̱y simusiy Crístu daryaju̱, ni̱tiy natuyada ramityadedaju̱ jirye. Jirye paru̱ryu̱ñuma riva simu tuva̱choda, jirya̱tidye tuva̱chu variy taji tu̱chodamu nta, jiryatimyu̱ ne si̱tenu samitu̱choda darya, ramutimyu̱ ne vu̱ryamityaniryu̱y nta varirya vu̱jyuuchuveda.
\v 7 Ne tara jna̱y ratarya samitu̱choda, mitya, mitya rirya̱tachuru̱y tavay ra̱jisiy jirye, jiryatiy riyataniryi̱ tajijyu̱ra samitu̱choda daryaju̱ jiryatiy Crístumusidyerya.
\v 8 ¡Dañuma nu̱y, dañuma jarichumusiy Ju̱denu tuunu vichi̱ raryityu̱chu tajiñe̱cho̱ju̱ra ramityadeda tu̱choda jiryiva, ne darya ratyu̱choda jiryiva day, sa̱ma̱ murichenutaniy Ju̱denu paruti̱si̱ju̱ rivasiñi̱!
\v 9 Daryatiy nu̱ñi̱teda ta̱riy jiryiva, ri̱tay diye jiryivantidye: ¡Ti̱ vidye raryityu̱chu jiryivara taji samitu̱choda day, jiryatimyu̱ ne darya jiryi̱mutya̱jada dárya, sa̱ma̱ murichenutaniy Ju̱denu paruti̱si̱ju̱ rivasiñi̱!
\p 
\v 10 ¿Rirya̱vidye jcanuy nijya̱nvarya rivaarya, rirya̱? Ne vinu Ju̱denu ju̱canuyadaju̱ dyetyara. ¿Ta̱raju̱ra raryi jvaaryu̱y nijya̱nvay jcanuyadaju̱, ta̱raju̱? Ratyi raryi jvaay nijya̱nvay jcanuyadaju̱, ne raryicha Crístu muchechiy variñu̱ndye.
\s1 Ju̱denu jaryeta̱dani̱ Pávurubay sa̱tidye datyanura vu̱ryamitya̱da tu̱choda
\p 
\v 11 Radyetyataniy daryaju̱ jirye ratyeryi̱veda, jiryatiy jiryetyuva̱chodara samitu̱choda rimusiy, tama̱ nijya̱mi̱ jachipiya̱jadamusidyerya, tama̱, mitya.
\v 12 Dantyamu̱y ne ri̱mutya̱jada nijya̱mi̱musirya, dantyamu̱y ne ti̱ datyadoda rarya, ni̱day Jesucrístu ji̱ta dityadoda radyerya.
\v 13 Jiryetyuva̱chuma̱ daryaju̱ dárya, jiryatiy ravyichanu̱yada ta̱riy daryá, daryatiy rivyichanu̱yada Judíyuveda Ju̱denunijyu̱ jachipiya̱vantyidye; jiryetyuva̱chuma̱ntirya nu̱tyu rayasantanu̱yada jaryiryi Ju̱denu siityari̱vajyuu, racya̱siryu̱ñu̱yada variy risa̱ju̱ riy.
\v 14 Rañi datyanu̱yadara Judíyuveda datyadoda, raryamichaniryi ti̱ta̱ju̱ risa̱ nu̱vye variy, ravyichanu̱yada vani̱rava̱ju̱ ta̱rijye̱myi datyadoda jto̱tadedamu.
\v 15-17 Sajaryeta̱da ji̱ta Ju̱denu raryupedajisiy yisa̱ju̱ ray, jadchintyi sanatuyada mitya jivya̱ta̱damu ray, ra̱tidye diy variy siva sadenu Jesús, ra̱tidye tu̱chunumaya̱ variy sanchiy nijya̱nvavya, jiryatimyu̱ ne Judíyuveda daryi. Varicha̱ra̱ju̱ netimyu̱ ne ratyu̱choda sisa̱ nijya̱mi̱ didye, dantyamu̱y ne raya̱da Jerusarí̱muju̱ didye, ruumuju̱ rityi vichanu̱yada Crístu nusu̱byimiy ra̱jisiy, raya̱da ji̱ta variy Arábiya mucadimuju̱, jadchintyi ratye̱rya̱da Damáscumuju̱ntiy.
\p 
\v 18 Jadchintyi, mumunijya̱mimyusiy rajeñu̱yada simu Pyítru jiryatiy su̱teda Jesúsni̱ Séjasiy, raryicheyada vu̱yaju̱y runda jasiy sisa̱, tadajyo runda ranchaju̱.
\v 19 Ne radyiyada ti̱va sisa̱ju̱ nusu̱byi tenu, vinu Santiyácu, Vu̱yntyityu̱ taryi̱.
\v 20 Jirya ji̱ta jiryatiy rañu̱y cateramu jiryejyu̱ra, ri̱tay Ju̱denu diya, ne raquivu̱y.
\v 21 Jadchintyi raya̱da Síriya mucadimuju̱, Sidísiya mucadimuju̱ jarye.
\v 22 Ne ridyiyada Crístu siityari̱vajyuu riva didye, jiryatiy Judéya mucadimu vichavadyeryi.
\v 23-24 Vinu rityuva̱chunu̱yada raynchiy: Ni̱tiy jiyasantanu̱yada vu̱y, diye satu̱chura samitu̱choda jiryatiy ta̱riy sani ca̱siryu̱ñu̱yadara, ramutiy ji̱ta riichana̱tya̱dani̱ Ju̱denu variy.
\c 2
\s1 Ridyiryejada nusu̱chavavyedabañi Pávurubay
\p 
\v 1 Jadchiy ji̱tantiy, vu̱yaju̱y nijya̱, dañijya̱ju̱yu ranchaju̱, na̱dyeya̱da ju̱na̱y Jerusarí̱muju̱ntiy, Bernabéta. Ra̱ra̱yada na̱dyisa̱ju̱ni̱ Títuntiy.
\v 2 Raya̱da ji̱ta, Ju̱denu dityadoda daryaju̱ ray ra̱tidye jiya, ratyu̱choda variy ruuvara samitu̱choda daryatiy ratyu̱chunumaya̱jada ruuva nijya̱nvantyidyerya, jiryatimyu̱ ne Judíyuveda daryi. Ratyu̱choda munatya dutya̱damusiy ruuva jatichevye, ridyetya̱daju̱ samirya vidye ráni̱cha rivaayada, mitya dyetya ravichanu̱yada. Ne ridyi taji nta riva rivaayada variy, mitya.
\v 3 Dantyamu̱y ne ru̱mutyonutaniñi̱ risa̱ jañu̱ñu Títu jtyati̱, dañuma sani̱cha Curiyécu ja̱mi̱.
\v 4 Dañuma jiryatiy riityejada daryaju̱ tavay riquebyimuyu, nu̱tyunuma nu̱ñi taryi̱veda nta riñi̱cha variy, ru̱mutyonutaniryu̱yada variñi̱ Títu. Riityejada jnu̱chodana̱cho̱ nta vu̱ñiya̱resiyu, rirya̱tidye datya varirya ratyadoda, jiryatiy saratyanuma̱ Jesucrístu vinu rityuva̱chodamu variryi jiryatimyu̱ ne judíyuveda daryi, ne jiryatiy vuryito̱tanirya Ju̱denu niquejada daryaju̱. Riberyu̱yada ji̱ta jivye nijya̱nvantyirya Muyisésibe niquejadantiy, ratyadoda ju̱bivaju̱ntiy, samitu̱choda ju̱bivaju̱, rirya̱tidye vuunu variy rata vu̱y.
\v 5 Ne nu̱vyuunutaniryu̱yada taraquideju̱ ramusiyu, ra̱tidye ma̱cho̱jasiy si̱tenu samitu̱choda jiryejyu̱, ratatiy vu̱dyetya, nu̱tyuramusiy saramityaniy Ju̱denu mitya vuryivara vu̱jyuuchuveda, nu̱tyuramusiy.
\p 
\v 6 Jatichevye ji̱ta, ne ribeyada tara vadi datyadoda ranchaju̱ variñu̱dantyi. Dañuma jatichevye rirye̱cha, ne jiryi̱nu̱y ne sajaryeta̱da Ju̱denuni̱ nijya̱mi̱ day, ti̱ta̱ju̱ samirya saju̱ni̱, sa̱tidye datyanu tarani̱.
\v 7 Rityi jteda jatichevyeyu, tama̱ riñi datyanu tara variy nu̱day, tama̱, riñi diryejada jidchavu̱ variy nu̱y, variñumatiy ridyetya̱da sabayada Ju̱denu tu̱chu̱ju̱ ray, samitu̱choda tu̱chodaju̱ ruuva jiryatimyu̱ ne Judíyuveda daryi, daryatiy sabayadani̱ Pyítru tu̱chu̱ Judíyuvedaju̱ntiy.
\v 8 Daryatiy savanu̱tyadeda Ju̱denuni̱ Pyítru samitu̱choda tu̱chu̱ju̱ Judíyuvedamuju̱, daryaday savanu̱tyadedantidyerye, ra̱tidye tu̱chu ruuvara, jiryatimyu̱ ne Judíyuveda daryi.
\p 
\v 9 Jadchiy ji̱ta jiryatiy rivyicha̱da surravay daryaju̱ Ju̱denu siityari̱vay cabyimu Santiyácu, Pyítru, Juán jarye, varityi ridyetya̱da darya sasa̱yada Ju̱denu rivaayadaju̱ ray, varicha̱ra̱ju̱ ru̱mutya̱jada Bernabéveda jidchavu̱ yisa̱ju̱ ray, rureda variy na̱jyomu, ridyityanu variy ratara samirya rijyu̱, jiryatiy na̱dyeyata̱dara samitu̱choda ruumuju̱ jiryatimyu̱ ne Judíyuveda daryi, riy ji̱ta jiyata̱da Judíyuvedamuju̱ra samitu̱choda day.
\v 10 Vinu jantyuyadavañe̱cho̱ ru̱teda na̱ña̱jnu̱y samiy, ranuma rañi jachipityaja̱sara diye sa̱ra̱ju̱ ti̱ta̱ju̱.
\s1 Pávurubay niquejada jamiryamu siva Pyítrubay
\p 
\v 11 Tarundamu ji̱ta siti̱jada Pyítru Antiyuquíya vicha̱damu, rañiquejada variy samo̱va jiryatiy ráyasayada va̱cha sivaayadayu.
\v 12 Si̱myiñu̱yada munatya jiryi̱nu̱y rusa̱ siityari̱vay jiryatimyu̱ ne Judíyuveda daryi. Ruti̱jadanumatiy Judíyuveda Santiyácumusiy variy, saparu̱yada riva jbyeda variy rusa̱, tapi sasuvu̱yada daryaju̱ riy rityi jmutyonutaniryu̱ryi jiryatimyu̱ ne Judíyuveda daryi, (ne jiryi̱nu̱y riñi jteda ju̱bachara darya rusa̱ jibyeda day, jiryatimyu̱ ne Judíyuveda daryi.)
\v 13 Tavamyiñi̱ Judíyuveda jvaayada yitu̱yada jidchavu̱ sisa̱ Pyítru varidye, jiryatiy ripyaru̱yada riva jbyeda vatajuu rusa̱ jiryatimyu̱ ne Judíyuveda daryi, Bernabé sa̱ra̱ju̱ ti̱ta̱ju̱ ruvaayada yitu̱yada sisa̱.
\v 14 Jiryatiy ri̱nu̱yada: Ne sarupi vase nú̱va, samitu̱choda nú̱va, rañique̱tya̱da variy rajuu diyadajacheni̱ Pyítru: Jiryatiy jiñi̱cha Judíyu, nu̱tyuramusiy jimyiñu̱je rusa̱ jiryatimyu̱ ne Judíyuveda daryi, nu̱tyuramusiy. Jiryatiy diye jipyaru̱y riva jbyeda rusa̱, jiñi dityanuru̱y riryivyichasara nu̱tyu Judíyuveda nta rirya̱tidye jnu̱jeya̱sara ju̱na̱reju̱ variy.
\s1 Ju̱denu ra̱y riyada Judíyuveda jiryatiy rityuva̱chu daryaju̱ simu
\p 
\v 15 Nu̱ñi̱cha ji̱ta Judíyuveda nu̱pyi̱ru̱yadamusidye, ne juuchatavay nu̱dye, mitya, ne nu̱tyu munu̱ñumiryapu̱ryamiy nu̱dye.
\v 16 Ramuni̱tiy vu̱dyetya: Tama̱ sa̱jtay Ju̱denu vase vichara ti̱, tama̱, vinu varityi sito̱tanirya saniquejada, jiryatimyu̱ ne vana̱y sito̱taniy samiryamusirya saniquejada. Jiryatiy vu̱tyuva̱choda simu Jesucrístu, ramuni̱tiy su̱tay Ju̱denu vase vichavay varivyu̱y. Ramuni̱ vu̱jerye tuva̱chuma̱ simu Jesucrístu, sa̱tidye jtay Ju̱denu variy vase vichavantyidyevyu̱y. Su̱tay daryá, vinu varityi vu̱tyuva̱chu simu Crístu, ne vinu varityi vuryito̱tanirya saniquejada, ti̱ vitya jiryi̱nu̱y vana̱y jto̱taniy ti̱ta̱ju̱ra saniquejada, jiryatiy nijya̱mi̱ rapu̱rya daryaju̱davyu̱y.
\p 
\v 17 Ramuni̱ jiryatiy vu̱ñi̱cha Judíyuveda, vu̱vya̱tatiy rana̱cho̱, sa̱tidye jtay Ju̱denu vase vichavay Crístumu varivyu̱y, vu̱dyetya ji̱ta variy ramusiy: Si̱tenu juuchatavay ni̱davyu̱y. ¿Rani̱tiy jirya rañi jtaryu̱y: sani̱cha Crístu ramusiy juuchuveda jmu̱tyi̱ varintyidye? jiryatiy vu̱pyaru̱y riva niquejada jto̱tadeda simu tuva̱choda jiyasachiy. ¡Ne dyetya!
\v 18 Vu̱tyi jo̱ta̱da jvaayada ju̱na̱ntyirya jiryatiy vu̱pyaru̱mya̱ riva, jiryatimyu̱ ne vana̱y raratyanu daryaju̱ vu̱y, vu̱dyityanu si̱tenu ratara: Si̱tenu juuchatavay ni̱davyu̱y.
\v 19 Jiryatiy sadiiyadata jimyurichedoda Cristura rajyuuchuveda, sadiy Ju̱denu variy riva nu̱tyu diibyi nta rañi̱cha saniquejadamuju̱, ra̱tidye jnu̱jeya̱sara ti̱ta̱ju̱ rundamu variy saju̱.
\v 20 Nu̱tyu munusi̱ ravyichanu̱yada daryaju̱ Crístusa̱, jiryatiy crusitya̱sa samurichenutadeda Ju̱denura rajyuuchuveda Crístu batyedata; ne ri̱nu̱y ray variñu̱ndye, Crístu ji̱ta jnu̱y diye ri̱bivaju̱ day. Jiryatiy ri̱nu̱y diye ravyu̱mu, ratyuva̱chodamusiy ri̱nu̱y, jiryatiy ratyuva̱chu simu Ju̱denu denu daryaju̱, jiryatiy sava̱ta̱damu jibetyeda rayadaju̱.
\v 21 Tama̱ ra̱rrachura jiryatiy sasa̱y Ju̱denu darya mitya vu̱y, tama̱. Ne jiryi̱nu̱y vu̱ryityi saryera samirya vicha̱da, niquejada jto̱tadedamusiy, ra̱ma̱cho̱ mitya variy Crístu batyeda vuryeyadaju̱.
\c 3
\s1 Ru̱mutya̱jadani̱ Ju̱denu Jnutu si̱tenu rityuva̱chodamu
\p 
\v 1 ¡Datyi̱sa̱miy jirye, Cadásiya mucadi ja̱nvay! ¿Chi̱na̱ jatachu si̱tenu nú̱jisiy jirye, chi̱? Nu̱dyityanumá̱ jiryerya nu̱tyu jiryedyiya nta day sani batyeda Jesucrístu crusitya̱sa variy.
\v 2 Ritaja̱nu ji̱ta vinu jirya niquejadata jirye: ¿Nu̱tyuramusiy jiryi̱mutya̱ni̱ Ju̱denu Jnutu, nu̱tyuramusiy? ¿Niquejada jto̱tadedamusiy vidye rani̱cha day? ¿Ne viy jiryetyuva̱chodamu? Jo.
\v 3 ¿Ta̱ jaryi datyi̱sa̱miñi̱ jiryeñi̱cha day, ta̱ju̱? Jiryatiy jirye jo̱ta̱da Su̱ntuta jityuva̱chodamu, ¿nu̱tyuramusiña̱ jirya̱ca̱siryu̱y jidyirya datya̱datara, nu̱tyuramusiy?
\v 4 ¿Ne taraju̱ ravichaniy jiryejyu̱ jiryatiy jirye paru̱tya̱da rajuura raju̱yu? ¡Si̱tenutiy raryicha tara jiryejyu̱!
\p 
\v 5 Ni̱ni̱ ji̱ta jiryatiy sasa̱chara mitya Yintu jirye, sivaarya ti̱ttasara jiryequebyimuntiy, sivaavya̱ niquejada jto̱tadedamura; jiryatiy jiryetyuva̱choda simu daryaju̱ yivaayadara.
\s1 Ju̱denu jteda sami̱ni̱ Avurá̱bay si̱tenu satuva̱chodamu
\p 
\v 6 Ramuni̱tiy satuva̱choda Avurá̱bay simu Ju̱denu, sajaryeta̱da Ju̱denu variñi̱ samiy nijya̱mi̱ju̱, satuva̱chodamusiy.
\v 7 Jirya̱ntya datya ramusiy: Rityi tuva̱chusara simu, riñi̱day Avurá̱bay dadyeñu day, jiryatiy rivyichasara daryá.
\v 8 Catera nu̱charamu jiryi̱nu̱y sabaya̱jada Ju̱denu Jnutu daryá, sa̱diy Ju̱denu samivye ruuva, dañumamu̱y ne rirye̱cha Judíyuveda day. Rityuva̱choda jiyadaju̱ sa̱diy samivye yiva, jiryatiy satu̱chodara samitu̱choda Avurá̱bavya daryaju̱:
\q1 Riñi ra̱chasara ti̱ta̱ju̱ nijya̱nvay Ju̱denu jmu̱tyasavajyu̱ yimu.
\m 
\v 9 Ramuni̱tiy rityi tuva̱chu simu Ju̱denu daryatiy satuva̱choda Avurá̱bay, rirye̱cha jmu̱tyasavay sisa̱ ramu.
\p 
\v 10 Riy ji̱ta jiryi̱nu̱y jiryatiy ruto̱taniryu̱rya niquejada day jiryatiy nu̱chara darya, paruti̱savadye, darya nu̱charantidyeryacu̱:
\q1 Paruti̱savay riñi̱cha ti̱ta̱ju̱ rityimyu̱ ne jiriryi̱ jto̱tadeda ti̱ta̱ju̱ra su̱teda, catera padyevya nu̱chara niquejada.
\m 
\v 11 Ramuni̱ vadichara darya, jiryatimyu̱ ne vana̱y savichasara nijya̱mi̱ sami̱ Ju̱denu diya, nu̱tyu nu̱charatiy daryantiy:
\q1 Jiryatiy Ju̱denumu tuva̱chu̱ ni̱, sa̱jtay variy sami̱ ni̱, sa̱jnu̱jeya̱sara ju̱na̱reju̱ variy.
\m 
\v 12 Niquejada jto̱tadeda ji̱ta ra̱cha vuryivaayadamusidye, ne vu̱tyuva̱chodamusidyerya, nu̱tyu nu̱charatiy daryantiy:
\q1 Ni̱tiy jto̱taniy yivaayadamusiy ti̱ta̱ju̱ra, ni̱ni̱ ji̱ta ra̱jnu̱jeya̱sara varidye.
\s1 Crístumusiy vurya̱ramityasara
\p 
\v 13 Sata̱ryu̱mya̱ ji̱ta Crístu, Ju̱denu jiyasayadajisivyu̱y, jiryatiy samurichenutadeda Ju̱denu daryaju̱ vuryeyadaju̱ ni̱, darya nu̱charani̱day:
\q1 Diiyasi̱ sani̱cha day ni̱tiy so̱tay jiiputa̱sa.
\m 
\v 14 Ramusiy ji̱ta rirye̱cha Ju̱denu jmu̱tyasavay ti̱ta̱ju̱ nijya̱nvay Jesucrístumu, daryani̱ savichanu̱yada Avurá̱bay jmu̱tyasi̱, vurya̱tidye jmutya̱ vu̱tyuva̱chodamu variñi̱ Ju̱denu Jnutu, daryatiy saniquejada Ju̱denu si̱tenu ta̱riy: Ra̱sa̱y jiryeñi̱ ri̱ntu.
\s1 Vu̱jye̱ ra̱sa̱y jidyedyeñura ju̱na̱reju̱ jnu̱yada
\p 
\v 15 Ratyeryi̱veda, ratyu̱chu diye nijya̱mi̱ jachipiya̱jadata jiryiva: Saryityi ju̱tay ti̱qui vanu vadiiryo̱ ji̱tyaju̱ nadiva jivyaturu̱y: Sa̱na̱sa̱yasiy vu̱dyenura raberya, ne vana̱y ti̱ vichadedasa̱ra̱ tara nu̱ndyerya, dantyamu̱y ne vana̱y ti̱ barya taji niquejada ranchaju̱ntiy, mitya.
\v 16 Daryantiy jiryatiy su̱teda Ju̱denu Avurá̱bavya, su̱ndenuva jarye yisa̱ju̱. Su̱tedatya su̱ndevavya nu̱tyu rajuuvadyeryi. Su̱teda ji̱ta su̱ndenuva, jiryatiy ti̱quide sani̱cha, sabaya̱jada variy sanijyu̱ Crístu.
\v 17 Jiryatiy su̱teda si̱tenu ta̱riy Avurá̱bavya, ne vana̱y ti̱ vichadedasa̱ra̱ tara variñu̱ndyerya. Jiryatiy su̱tedara jiñiquejada tarundamu Muyisésibemyusintyi, ne vana̱y ti̱ vichanichara varirya su̱teda Avurá̱bavya nu̱ndye, mitya. Ne jiryi̱nu̱y Muyisésibemyusiy ji̱ta ru̱ndayada rijyu̱ saniquejada day, daryaju̱yu pacha nijya̱, mumuri̱ vu̱yaju̱y nijya̱ ranchaju̱ntiy, ramuni̱mu̱y ne vana̱y ti̱ vichanichara tara variñu̱darya munatya su̱teda nu̱day.
\v 18 Saryityi sa̱y Ju̱denu sayaru̱rya nijya̱mi̱yu, vinu varityi saryijto̱tanirya saniquejada, jiryatiy su̱teda Muyisésibemyusirya, saryi sa̱vya̱ vinu su̱tedamuju̱ varidyerya cay, tii, mitya. Sasa̱yada ji̱ta Ju̱denu yitedamuju̱ sayaru̱rya Avurá̱bayu, Muyisésibe jisidye sasa̱yada dañi̱.
\v 19 ¿Ta̱ju̱numa sabayada Ju̱denu varirya jiñiquejada Muyisésibemyusintyi, ta̱ju̱? Sabayada ji̱tara vurya̱tidye datya ramusiy ta̱ra rani̱cha juuchuveda Ju̱denu diya, ta̱ra. Sabayadara jiñiquejada Avurá̱bay ju̱debi jdeda sa̱ra̱ju̱, ni̱tiy ra̱jmutya̱ra jiyaru̱rya. Muyisésibe ji̱ta jmutya̱jada Ju̱denu jpa̱vamyusirya saniquejada day, sa̱tidye bay Ju̱denu ju̱bivaju̱ Irayénuveda jto̱tadedaju̱ra.
\v 20 Ni̱tiy nique ti̱ju̱, ne sanique vinu jidyirya, Ju̱denu ji̱ta niquejada jidyirya day, varityi su̱teda Avurá̱bavya.
\s1 Vu̱vyichasara Ju̱denu dadyeñu, ne vu̱vyichasara samuchechimyi
\p 
\v 21 Vuryi̱tay ji̱ta varidye: Jiryatiy su̱teda Ju̱denu Muyisésibemyusirya jiñiquejada, ne sa̱numitya̱da tajiñe̱cho̱ju̱ra jiryatiy su̱teda Avurá̱bavyara. Tapi saryityi bayadara niquejada ratatiy saryi jnu̱tyanichara ju̱na̱reju̱ vu̱y, ramusityi saryi jteda samivye varivyu̱y.
\v 22 Saniquejadamu ji̱ta jiryatiy nu̱charara, sani dityadoda ji̱ta ti̱ta̱ju̱ nijya̱nvay juuchatavadyerya, sa̱tidye sa̱y mitya vu̱rya vuryeyaru̱rya, Jesucrístu samiy jvaayadamusiy, varityi vu̱tyuva̱chu simu.
\p 
\v 23 Netimyu̱ ne siti̱jada Crístu didye vurya̱tidye tuva̱chu simu, vu̱vyichanu̱yada nu̱tyu tanuvu̱nusavay, nu̱tyu nu̱tyasavay niquejadata, samitu̱choda dityadoda jiju̱.
\v 24 Ramuni̱, ravichanu̱yada niquejada nu̱tyu muchechiy vu̱jyu̱ra. Jiryatiy vu̱vyichanu̱yada nu̱tyu deramiy datyi̱sa̱miy, rito̱ta̱da ji̱ta niquejada Crístumu varivyu̱y, nu̱tyu muchechiy jto̱ta̱da riy deramiy catera nu̱jyomu daryá. Vu̱tyuva̱chutiy Crístumu, sa̱jtay Ju̱denu samivye varivyu̱y.
\v 25-26 Varityi vu̱tyuva̱chu simu, ne vu̱vya̱ta muchechiy variñu̱day, jiryatiy vu̱ñi̱cha Ju̱denu dadyeñu daryaju̱ day, ja̱ñuma ti̱ta̱ju̱ varivyu̱y, Jesucrístumu tuva̱chodamu.
\v 27 Ti̱ta̱ju̱ jiryi̱nu̱y jiryatiy vu̱vyicha ji̱tyu̱vye Crístumu, vu̱vyichasara ramusiy nu̱tyu sujatyavay nta saramityadedata.
\v 28 Ne vurya̱jtay variy ti̱nijyu̱ nu̱ndye: Ni̱ni̱ Judíyu day, ti̱nijyu̱ntiy: Ni̱ni̱ munu̱ñu day, ti̱nijyu̱ntiy: Ni̱ni̱ muchechidye, ti̱nijyu̱ntiy: Ni̱ni̱ jijyu̱ jvaarya day, ti̱nijyu̱ntiy: Ni̱ni̱ vanu day, ti̱nijyu̱ntiy: Ni̱ni̱ vatura day. Ti̱ta̱ju̱ jiryi̱nu̱y vu̱vyichanuma jidchavu̱ nu̱ñi tevay Jesucrístumu day.
\v 29 Varityi vu̱ñi̱cha Crístumu, vu̱vyicha ramusiy Avurá̱bay dadyeñuntiy, vurya̱jmutya̱sara jidchavu̱ Crístusa̱ varirya jiryatiy su̱teda ta̱riy Ju̱denu ya̱sa̱y Avurá̱ra.
\c 4
\s1 Nu̱tyu riñi̱chanu̱yada ta̱riy nijya̱nvay Jesucrístu jti̱jadajisiy, nu̱tyu
\p 
\v 1 Ri̱tay ji̱ta variy, vu̱ñi̱cha nu̱tyu curaca denu, ni̱timyu̱ ne ja̱y didye, sama̱cho̱ nu̱tyu muchechiy, dañuma sa̱cha curaca denu.
\v 2 Sama̱cho̱ datyanusi̱ rarunda sa̱ra̱ju̱ varityi sa̱jay jijye̱ ju̱bivaju̱.
\v 3 Daryadantyivyu̱y, varityi vu̱vyichanu̱yada nu̱tyu deramiy, datyi̱sa̱miy varidyevyu̱y, nu̱tyu muchechimyi vu̱vyicha variy raju̱, jiryatiy vuryivaayada paru̱cha̱rimyusiy nijya̱mi̱ niquejada rapu̱rya jto̱tadedaju̱ra.
\v 4-5 Variryundamu ji̱ta jiryatiy sabayada Ju̱denu raju̱, su̱pa̱jada ji̱ta variñi̱ jidyenu, vaturu̱myusiy rupi̱. Sarupeda, Muyisésibemyusiy niquejada jto̱tadedaju̱, sa̱tidye ra̱y vuryeyada, jiryatimyu̱ ne vana̱y vuryito̱tanirya niquejada vu̱y, sa̱tidye jmutya̱ Ju̱denu variy nu̱tyu si̱tenu jidyedyeñu varivyu̱y.
\v 6 Jiryatiy vu̱ñi̱cha variy sadadyeñu daryaju̱, su̱pa̱jada ji̱tani̱ jidyenu jnutu vu̱jechimyuju̱, vurya̱tidye sa̱ñe̱ya̱ variy sanijyu̱: ¡Ye̱ye̱! ¡Ye̱ye̱dyera!
\p 
\v 7 Ramutimyu̱ ne muchechimyiñu̱davyu̱y, sadadyeñunuma varidyevyu̱y. Jiryatiy vu̱vyicha sadadyeñu, vurya̱jmutya̱ variy sa̱ntyutya̱damuju̱ra jiberya.
\s1 Ne vu̱ryi ta̱rya̱ru̱y rana̱cho̱ niquejadamu vuudoda nu̱day
\p 
\v 8 Ta̱riy, netimyu̱ ne jiryedyetya didyeñi si̱tenu Vuryi̱ndenu didye, jiryivaañu̱yada paru̱cha̱rimyusiy rusa̱ jiryatimyu̱ ne si̱tenu ju̱denumidyeryi.
\v 9 Diye ji̱ta variñumatiy jiryedyetyama̱ni̱ si̱tenu Vuryi̱ndenu, ri̱tay samivya̱ju̱, variñumatiy jirye̱cha sajaryetasavay, ¿nu̱tyuramusiña̱ jirya̱numityeryu̱y ju̱na̱y nijya̱mi̱ niquejadamuju̱ntiy, nu̱tyuramusiy? jirya̱tidye jvaay paru̱cha̱rimyusiy risa̱ntiy jiryatimyu̱ ne vana̱y ra̱ra̱y vuryeyada.
\v 10 Jiryebe ji̱tara runda, jarimyuni̱, vichtya, vaata jarye ti̱ta̱ju̱, jirye jto̱tadeda variy tara ramu sa̱tidye jnu̱y nta samirya Ju̱denu variy jiryeñe̱cho̱.
\v 11 ¡Ri̱ntañu̱ ji̱ta jiryeñiya̱re rañuma ma̱cho̱ mitya rivaayada jirye̱ntyutya̱da jiyadaju̱!
\s1 Pávurubay jachipityaja̱ra
\p 
\v 12 Rayasanta jaryi jirye, ratyeryi̱veda, jirye̱cha nu̱tyu ray jiryatiy rapyaru̱yada riva niquejada jto̱tadeda, Crístumu tuva̱choda jiyasachiy. Rañi̱cha variy nu̱tyu jiryetyi vichanu̱yada Ju̱denu niquejada datyi̱sa̱miy. Ne jiryevyichadeda taji nta varirye.
\v 13 Jiryedyetya daryaju̱ nu̱tyu ri̱diva̱jadanube ratyu̱choda munatyara samitu̱choda jiryiva.
\v 14 Ne jirye rrachoda varirye, dantyamu̱y ne jirya̱vityeda ri̱diva̱jadamu ray. Jiryeñi diryejada ji̱ta nu̱tyu Ju̱denu jpa̱nu varirye, nu̱tyu nta jiryedyiryeni̱ Jesucrístu.
\v 15 ¿Tena̱ diyera jiryi̱chana̱tya̱da, te? Ri̱tay ji̱ta vijyo̱mujache jiryenchiy daryaju̱, jiryi̱chana̱tya̱da darya sa̱ra̱ju̱ varirye jiryeñi sa̱ryu̱yadanuma jiñi̱siy varintyirye.
\v 16 ¿Jiryatiy ri̱tachara si̱tenu jiryiva, jiryedyi variy nu̱tyu jimyityasiy nta riva?
\v 17 Rijyiintyeru̱y ji̱ta tavay Crístumu tuva̱chodajisiy jirye, rirye̱tya̱damu, ne samirya jachipiya̱jadamu, jirya̱tidye ra̱tya variy rivantiryi.
\v 18 Samirya raryicha varityi rirya̱ra̱tyasara samiryaju̱ jiryiva, ne vinu variy varityi ravyicha jiryisa̱.
\v 19 Ri̱tay jiryiva, radyedyeñu, rañuvay daryaju̱ jiryivasiy nu̱tyu ray ntanuma rupachu ju̱na̱y jiryentyi, vadi vicha̱daju̱, rañuvay, jasicha̱ra̱ju̱tiy su̱nde Ju̱denuni̱ Crístu jiryimu.
\v 20 Nu̱tyichitya ravyicha̱da jiryisa̱cu̱, nu̱tyichiy, varityi ra̱nique taji nta jiryisa̱ntidye, ne radyetya daryaju̱ nu̱tyu ra̱jachipiya̱ jiryenchiy, nu̱tyu.
\s1 Riti̱jada samitu̱choda Muyisésibe niquejada ju̱bivaju̱
\p 
\v 21 Jirya̱ma̱ tu̱chu riva, jiryatiy jiryevyicharu̱y Muyisésibe niquejada jto̱tanivye, ¿jiryeñi tuva̱chu̱sani̱virya nu̱tyu ranique saniquejada?
\v 22-23 Nu̱chara daryaju̱ ramu day: Varityi danu̱ju̱y denuti̱ savicha̱da Avurá̱, ti̱qui vichanu̱yada samuchechityodaniy detuchi̱, nu̱ntiy vichanu̱yada si̱tenu savaturu̱ñiy detuchi̱. Samuchechityoda denu ji̱ta pi̱ru̱yada vinu jijye̱ va̱ta̱damuju̱, savaturu̱dyenu ji̱ta pi̱ru̱yada Ju̱denu jtedamuju̱ntidye, jiryatiy savichanu̱yada suru̱tyu su̱no̱dáju̱si̱ yajisiy.
\v 24-25 Rani̱ ji̱ta samitu̱choda day, jiryatiy ra̱datyanu tara vu̱y. Daryatiy nanuvicha̱da danu̱ju̱y vaturu̱jyu̱y mityiji denutanu̱jyu̱be, daryaday ravicha daraju̱y niquejadantiy, jiryatiy su̱teda Ju̱denura: taraqui su̱teda Sinayí musimyu, Arábiya mucadimu, rani vuunuru̱ryi rityi rañi jto̱taniryu̱rya. Rani̱ ji̱ta nanubaya̱jada muchechityoda Acáraju̱y jtyatanu̱be, jiryatiy muchechimyijyu̱ nanudetuñu̱yada. Daryadantyi Jerusarí̱ diye, ti̱ta̱ju̱ rumu vichavatya Judíyuveda, rivyicha nu̱tyu muchechimyi, niquejada jiyadaju̱.
\v 26 Avurá̱bay vaturu̱y Sáraju̱be baya̱ ratarya Jerusarí̱ nijyu̱, jiryatiy jaryinranuma varidyerya, jiryatiy nu̱tyu vuryi̱no̱da daryaju̱ nada day.
\v 27 Darya nu̱charani̱day daryaju̱ra:
\q1 Ya̱jchana̱y suru̱tyu jiryatimyu̱ ne deti̱ ji, ya̱sa̱ñe̱ya̱ jichana̱yadamu, dañumamu̱y ne jiñuvaday rupachodamu, tapi rirye̱cha jaryivya̱ju̱ rajuuvay jidyedyeñu nadimusiy jiryatiy nanuvicha jivyanusa̱.
\m 
\v 28 Ratyeryi̱veda, vu̱ñi̱cha nu̱tyu Isácubay, Sáraju̱be denu, jiryatiy sarupeda Ju̱denu jtedamuju̱. Daryaday vu̱ñi̱cha Ju̱denu dadyeñu su̱tedamuju̱ntidye.
\v 29 Daryatidye sa̱rupantanu̱yada muchechityodabay denuni̱ Sáraju̱be denu, jiryatiy Ju̱denu Jnutu jtedamuju̱ rupi̱ni̱, daryadantyi diye (Judíyuveda jarupanta riy jiryatiy Ju̱denu jtedamuju̱ rivyicha jidyedyeñu, rityuva̱choda mirya̱damu rirya̱rupantayu.)
\v 30 Su̱teda ji̱ta siva Avurá̱bay daryá catera nu̱chara niquejadamu:
\q1 Ya̱jatya bimuju̱ nada jimyuchechityoda, nanudenuta, tapi ne sa̱jmutya̱ra jiberya jidchavu̱ jivyaturu̱dyenusa̱.
\m 
\v 31 Ramuni̱, ratyeryi̱veda, vu̱ñi̱cha nu̱tyu Sáraju̱be denu, vurya̱tidye jmutya̱ra vu̱jye̱myu vichasa̱da, ne vu̱ñi̱cha nu̱tyu muchechityoda denu, jatyasi̱.
\c 5
\s1 Vurya̱ntya vanu̱tya ratyadodaju̱ vu̱y
\p 
\v 1 Saratyanuma̱ ji̱ta Crístu vu̱y, vurya̱tidye vichasara ratyanusavay variy. Jirya̱vanu̱tya daryaju̱ variy raju̱ ratyadodayu; ne ji̱rya̱sabuy ju̱na̱y riva Muyisésibe niquejada jto̱tadeda nu̱day.
\v 2 Jirya̱ntya jnu̱y, rañi̱ rañi̱cha Pávuruntiy, jiryatiy ri̱tay jiryiva: Jiryetyi jmutyonutaniyu, sa̱tidye jtay Ju̱denu variy samivye jirye, jiryi̱tay variy rata: Ne rasa̱ra̱ vu̱jyu̱ra Crístu diiyada vu̱ryamityanicha̱daju̱ nu̱day. Ne vana̱y sa̱jantyuy Crístu variy jiryiva nu̱day.
\v 3 Ra̱jatyi tu̱choda vijyo̱mujache jiryivantiy: Ni̱tiy jmutyonutaniyu, sa̱dyetya jto̱tanirya Muyisésibe niquejada ti̱ta̱ju̱ variy jiryamityanicha̱daju̱.
\v 4 Jiryetyi jto̱taniryu̱rya niquejada, sa̱tidye jtay Ju̱denu samivye variy jirye, jirye̱cha variy jiintyasavay Crístusa̱siy, ne vana̱y sa̱sa̱y mitya variy jiryerya ju̱na̱reju̱ jnu̱yada nu̱day.
\v 5 Su̱ntumusiy ji̱ta vu̱yntuy jaryi vu̱ñi̱ru̱yadamu ra̱jiju̱ jiryatiy sa̱jtay Ju̱denu samivyevyu̱y, jiryatiy vu̱tyuva̱chu daryaju̱ simu.
\v 6 Jesucrístumu ji̱ta vu̱ñi̱cha samivye varityi vu̱dyityanura vu̱tyuva̱choda jiryatiy vuryivaayada jaryi vu̱vya̱ta̱damura, dañuma vurye̱cha jmutyonusavay, dañumamu̱y ne.
\p 
\v 7 Jirye ji̱ta vichaniñu̱yada samiy munatya. ¿Chi̱ra paru̱tyaniy riva si̱tenu tuva̱choda jirye, chi̱?
\v 8 Tama̱ Ju̱denumusiy rani̱cha paru̱yada day, tama̱. Ni̱ni̱ ji̱ta natuchara tuva̱chodamu vu̱y.
\v 9 Jirya̱ntya jnu̱y ra̱jisiy taji datyadoda, daryatiy jiryi̱nu̱y pasidyeramusiy rijeryenura varapu buya̱dinube, racasiyadaju̱, daryaday rajaryenu nicyara̱y tu̱chodantirya samitu̱chodantiy, ra̱jarapu̱y samitu̱choda variy.
\v 10 Jiryatiy ratyuva̱chu simu Vu̱yntyityu̱, radyetya variy jiryenchiy: Ne jirya̱jachipiya̱ru̱y tajiñe̱cho̱ju̱; sa̱day murichenutaniy Ju̱denuni̱ ni̱tiy jarupantaru̱y jirye, dañuma sa̱cha ti̱.
\v 11 Ritaja̱nu ji̱ta variy jirye, ratyeryi̱veda: Raryityi datyanura jmutyonutadeda, daryatiy ru̱tañu̱y tavay rañijyu̱, ¿ta̱raju̱ riyasanta variy mitya riva ray, ta̱raju̱? Nevidye jiryatiy radyetyanusara darya: Vu̱ryamitya vinu jiryatiy sabatyeda Crístu crusitya̱sa vuryeyadaju̱, vinu rani̱ radyetyanu day. Ne rirrachuru̱rya crusinchiy datyadoda raryityi datyadodara jmutyonutadeda variy risa̱ju̱.
\v 12 ¡Jaryiñi̱ riryi jmutyonutaniryu̱y jirye! ¡Rirya̱ma̱ jmyisityasara variy risa̱ju̱yu!
\p 
\v 13 Jirya̱jnu̱y, ratyeryi̱veda, sanatuyada Ju̱denu jirye ratyanusavajyu̱, jirya̱tidye jmu̱tya nu̱ñi jiryedyeyu, jiryevya̱ta̱damu. Ne vurya̱jvaay vu̱ryetyadodamura va̱cha ni̱ru̱yada, daryatiy vu̱ñi̱ru̱y vu̱dyirya day.
\v 14 Tapi vuryito̱taniy ti̱ta̱ju̱ra Ju̱denu jteda, varityi vuryito̱tanirya jirya niquejada:
\q1 Vurya̱ntya va̱tani̱ vu̱tyuunu vichi̱ nu̱tyu vu̱vya̱ta daryantidyevyu̱y.
\m 
\v 15 Netimyu̱ ne jiryevya̱tayu, jiryechu̱y nta nu̱ñi jiryeyu, jiryi̱myimyu̱y variy nu̱ñi jirye risa̱ju̱yu, jatyi jiryepyarutamu̱y tamityayu.
\s1 Va̱cha ni̱ru̱yadacanumiy vu̱ñi̱cha vu̱dyirya jvaayadamu
\p 
\v 16 Ri̱tay ji̱ta variy: Jirya̱ntya vichasara Ju̱denu Jnutumu, ne jirya̱jvaay varirya jiryedyirya ni̱ru̱yada nu̱day.
\v 17 Tapi jiryatiy vu̱ñi̱ru̱y vu̱dyirya darya, rani̱ ji̱ta ra̱cha Ju̱denu Jnutu jiyaro̱ju̱ day; Ju̱denu Jnutu ni̱ru̱rya ji̱ta, vu̱dyirya ni̱ru̱yada jiyaro̱ju̱ntidye; ramutimyu̱ ne vana̱y nta vuryivaarya si̱tenu vu̱ñi̱ru̱yada.
\v 18 Varityi vu̱vyichasara Ju̱denu Jnutu datyadodamu, ne ra̱vuunu niquejada variñu̱ndyevyu̱y, jiryatiy Su̱ntumusiñuma vuryito̱taniy daryaju̱ darya.
\v 19-21 Jvadichara jiryi̱nu̱rya vu̱dyirya ni̱ru̱yada day: ti̱ vaturu̱jsa̱ rupiyada, va̱cha jvaayada jarye, cadnaveda, jiipu tera jvaachi̱ nijyu̱ jachipiya̱jada risa̱ju̱, nuvoda, mityasiiyada, jvatyiyada, ra̱tya̱da, nique̱yada, mitya vu̱ñijyu̱ jachipiya̱jada jarye, tajiñe̱cho̱ju̱ jachipiya̱jada jaryentiy, tajiñe̱cho̱ju̱ datyadoda, ju̱nnuva̱yada, nijya̱mi̱ ju̱vedacanuyada jarye risa̱ju̱ntiy, niyu̱yadacanuyada, vaturu̱jsa̱ jarupadodacanuyada jarye, ti̱ta̱ju̱ darya jvaayada jarye risa̱ju̱ra. Ratyu̱choda ta̱riy ra̱jisiy jiryiva, ratyu̱chu ju̱na̱y ra̱jisiy jiryivantiy, tapi rityi jvaacharara darya jvaayada, ne rirya̱jmutya̱ra jiyaru̱rya Ju̱denu nusu̱jyomu.
\s1 Samirya ni̱ru̱yadacanuvye vu̱ryicha Ju̱denu Jnutumusiy
\p 
\v 22-23 Ju̱denu Jnutu jvaayadamusiy ji̱ta vu̱dyetyara va̱ta̱da; ramusintyirya jchana̱yadantiy, samirya vicha̱da, tapi vicha̱da tavañijyu̱, samirya jachityavay vicha̱da jarye, samirya jvaayada tavay jiyadaju̱, paru̱yasa̱ jvaayada, nique̱yasa̱ vichasa̱da jarye, vase jachipiya̱jada jarye risa̱ju̱ ti̱ta̱ju̱. Ne tara ju̱na̱y ra̱cha tara niquejada rayaro̱ju̱ jadchiñu̱day, darya jvaayada jiyaro̱ju̱ nu̱day.
\v 24 Vu̱y ji̱ta jiryatiy Jesucrístu nijya̱nvadyevyu̱y, vuryi̱vattama̱ sacrusitya̱sa vu̱dyirya ni̱ru̱yadajisivyu̱y.
\v 25 Jiryatiy jnu̱yasavay Ju̱denu Jnutumusidyevyu̱y, vurya̱ntya vichasara sadatyadodamuju̱ntiy.
\v 26 Ne vurye̱cha vuryinnuva̱vye, ne yinu̱y vu̱jyo̱ta rata riy vu̱tyevay, rirya̱mirye varivyu̱y.
\c 6
\s1 Pávurubay niquejada ruuva
\p 
\v 1 Ratyeryi̱veda, variñumatiy vu̱dyi siva vu̱tyeryi̱ jiryatiy sajiintyemya̱ ramusiy samirya niquejada jiryatiy Ju̱denu niquejada darya, mi̱ni̱tyi vicha jaryi datyara vu̱quebyimu, sa̱ntya jmu̱tya variy samiryamuju̱ni̱. Vurya̱ntya jnu̱tyantidyevyu̱y, vu̱ñuma jiintye ranchiy juuchuvedamuntidye.
\v 2-3 Vurya̱ntya jmu̱tyasara nu̱ñi vajyuu vu̱y, vuryeyaru̱ryamu, vurya̱jto̱tanichara varirya Crístu niquejada; tapi ni̱tiy jachipiya̱ jiñijyu̱: Ray ji̱ta Ju̱denu niquejada datyanu̱ day, ¿Va̱ Ju̱denu niquejada datyanu̱ sani̱cha cay? Ni̱day jiquivu̱chudayu.
\v 4-5 Nu̱ñi ti̱musiy vurya̱ntya jantyara vuryivaayada, samiryavidye rani̱cha, samiryantye, vuryi̱chana̱tya̱da jiju̱ra; ne vurya̱jnu̱y ti̱ jchana̱tya̱da jiju̱ nu̱day, nu̱ñi ti̱musiy jiryi̱nu̱y nu̱dyetya darya yivaayada day.
\v 6 Ni̱tiy ra̱jmutya̱ datyanu̱musirya Ju̱denu niquejada, daryaday sa̱sa̱y tara varintyidyeñi̱. Jidchavu̱ nana̱sa̱y variyu.
\v 7 Ne jirya̱quivu̱chu nu̱ñi jiryeyu, jirya̱tiy jtavya̱: Ne sadatya Ju̱denura vuryivaayada. ¡Sadatya jasirya! Ne vana̱y quivu̱chusi̱ variñi̱, ne jiryi̱nu̱y daryatiy vu̱ryi nutara tara, daryaday vu̱ryi jmutya̱ ru̱co̱sintyi daryatiy vu̱vyichaniy ti̱, daryaday sa̱chaniy Ju̱denu rivantidyevyu̱y.
\v 8 Ni̱tiy vichasara jivyu̱ ni̱ru̱yada jvaayada jiyadaju̱, ya̱jmutya̱ rivasirya jidyiitya̱ju̱sara; ni̱ni̱ ji̱ta ni̱tiy vichasara Ju̱denu Jnutu jmu̱tya̱data, ya̱jmutya̱ variy simusirya ju̱na̱reju̱ jnu̱yada day.
\v 9 Ne vurya̱paru̱y riva samirya jvaayada; samiryundamu ji̱ta vurya̱jmutya̱ simusirya samirya jnu̱yada, netimyu̱ ne vurya̱diiryo̱vay ra̱jisiy.
\v 10 Ramuni̱tiy jasicha̱ra̱ju̱tiy vu̱ryicha, vurya̱ntya jvaañumaya̱ variy samiryaju̱ ti̱ta̱ju̱ nijya̱nvajyu̱, jaryinra ji̱ta rijyu̱ jiryatiy vu̱tyeryi̱veda vuryi̱taryi, jiryatiy rityuva̱chu vatajuu Ju̱denumu vuryisa̱ day.
\s1 Pávurubay niquetacheda
\p 
\v 11 ¡Jirya̱jnu̱y ta̱ ja̱mura nu̱charata rañu̱y, si̱tenu rajyomututa rañu̱rya!
\v 12 Rityi vicharu̱y vadichavay nijya̱nvajyu̱, riñi̱ ji̱ta jmutyonutaniryu̱y jiryedye, jiryatimyu̱ ne rivyicharu̱y jiyasantasavay Crístu crusiy jiyadaju̱, jiryatiy ju̱vajadasara daryaju̱ rijyu̱ darya Crístu diiyada crusitya̱sa vu̱jyuuchuveda jiyadaju̱ day.
\v 13 Dantyamu̱y ne ruto̱tadeda jmutyonusavay samiryamusirya Muyisésibe niquejada, dañuma ru̱mutyonutaniryu̱y jirye, rirya̱tidye jchana̱tya variyu, jiryatiy riñu̱tyanirya jiryevyu̱, riñi jtay variy Ju̱denu niquejada jto̱tanivye jirye.
\v 14 Ray ji̱tamu̱y ne ra̱jchana̱tya tara, vinu Vu̱yntyityu̱ Jesucrístu crusiy nichiy ra̱jchana̱tya day, jiryatiy sadiiyada rata̱sa rajyuuchuveda jiyadaju̱. Ramutiy ji̱ta ne ratyuva̱churu̱y ray nijya̱nvay ni̱ru̱yadamu day, tapi ravyicha nu̱tyu diibyi raju̱ daryaju̱ day, nu̱tyu radyiiy ntama̱ crusitya̱sa Jesucrístu jsa̱ju̱ntidye.
\v 15 Dañuma vu̱ñi̱cha jmutyonusavay, varimyatamu̱y ne jmutyonusavay, rama̱cho̱ mitya variy; rani̱ ji̱ta vuryi̱nu̱yadaju̱ day, jiryatiy vu̱vyicha vadi nijya̱nvay Ju̱denu jtedamuju̱.
\v 16 Ti̱ta̱ju̱ rityi vichasara jirya niquejadamusiy, sa̱bay Ju̱denu samirya vicha̱daju̱ riy, sa̱ntyutya variy risa̱ju̱ riy, ti̱ta̱ju̱ jiryatiy Ju̱denu dadyeñu daryi, jiryatiy rityuva̱chu samiy ramu simu.
\p 
\v 17 Diye ji̱ta ne rirya̱jarupanta ju̱na̱y riva nu̱nrye, tapi rabajyo̱viñu ravyu̱va, Jesucrístu jiyadaju̱ jarupantasa̱da bajyo̱ daryaju̱ra. Ramuni̱tiy rirya̱ma̱ datya jiryatiy si̱tenu Jesucrístu muchechiy darye.
\p 
\v 18 Sa̱vichaniy Vu̱yntyityu̱ Jesucrístu samiñi̱ jiryi̱ntu. Daryanuma ra̱ma̱cho̱ ti̱ta̱ju̱.
\cls Sayanuma Pávuru
