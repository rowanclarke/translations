\c 15
\s1 La conspiración de Absalón
\p 
\v 1 \w Después|strong="H1961"\w* \w de|strong="H6440"\w* \w esto|strong="H3651"\w*, \w aconteció|strong="H1961"\w* \w que|strong="H1961"\w* Absalón consiguió una carroza y \w caballos|strong="H5483"\w*, y 50 hombres \w para|strong="H1961"\w* \w que|strong="H1961"\w* corrieran \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H6213"\w*.
\v 2 Absalón \w se|strong="H1961"\w* levantaba temprano \w y|strong="H5921"\w* \w se|strong="H1961"\w* colocaba \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w camino|strong="H1870"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w*. \w A|strong="H3068"\w* \w cualquiera|strong="H3605"\w* \w que|strong="H5921"\w* \w tenía|strong="H1961"\w* un \w pleito|strong="H7379"\w* \w y|strong="H5921"\w* acudía \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* aplicara \w juicio|strong="H4941"\w*, Absalón \w lo|strong="H2088"\w* \w llamaba|strong="H7121"\w* \w y|strong="H5921"\w* \w le|strong="H5921"\w* decía: ¿\w De|strong="H5921"\w* \w qué|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w eres|strong="H1961"\w*? \w Y|strong="H3068"\w* \w él|strong="H5921"\w* decía: Tu esclavo \w es|strong="H1961"\w* \w de|strong="H5921"\w* una \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w tribus|strong="H7626"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.
\v 3 Entonces Absalón le decía: \w Mira|strong="H7200"\w*, tu \w causa|strong="H1697"\w* \w es|strong="H1697"\w* \w buena|strong="H2896"\w* y justa, pero no tienes quien \w escuche|strong="H8085"\w* \w de|strong="H1697"\w* parte del \w rey|strong="H4428"\w*.
\v 4 \w Y|strong="H3068"\w* Absalón decía: ¡\w Oh|strong="H4310"\w*, \w que|strong="H4310"\w* \w alguno|strong="H3605"\w* \w me|strong="H5921"\w* designara \w juez|strong="H8199"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w pues|strong="H1961"\w* entonces \w todo|strong="H3605"\w* hombre \w que|strong="H4310"\w* \w tenga|strong="H1961"\w* un \w pleito|strong="H7379"\w* \w o|strong="H3068"\w* una \w causa|strong="H7379"\w* podría venir \w a|strong="H3068"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* yo \w le|strong="H5921"\w* haría \w justicia|strong="H4941"\w*!
\p 
\v 5 Acontecía \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* alguien \w se|strong="H1961"\w* acercaba \w para|strong="H1961"\w* inclinarse ante él, \add Absalón\add* extendía su \w mano|strong="H3027"\w*, lo agarraba y lo besaba.
\v 6 Absalón trataba \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w de|strong="H1697"\w* \w este|strong="H2088"\w* modo cuando acudían \w al|strong="H4428"\w* \w rey|strong="H4428"\w* para \w que|strong="H1697"\w* juzgara. \w Así|strong="H2088"\w* Absalón robaba \w los|strong="H3605"\w* corazones \w de|strong="H1697"\w* \w los|strong="H3605"\w* hombres \w de|strong="H1697"\w* \w Israel|strong="H3478"\w*.
\p 
\v 7 \w Después|strong="H1961"\w* de cuatro \w años|strong="H8141"\w*, \w aconteció|strong="H1961"\w* \w que|strong="H4994"\w* Absalón dijo \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* me permitas \w ir|strong="H3212"\w* \w a|strong="H3068"\w* \w Hebrón|strong="H2275"\w* \w a|strong="H3068"\w* cumplir un \w voto|strong="H5087"\w* \w que|strong="H4994"\w* hice \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 8 \w Porque|strong="H3588"\w* \w cuando|strong="H3588"\w* \w estaba|strong="H3427"\w* \w en|strong="H3588"\w* Gesur, \w en|strong="H3588"\w* Siria, tu esclavo juró \w y|strong="H3588"\w* dijo: \w Si|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w ciertamente|strong="H3588"\w* \w me|strong="H3588"\w* devuelve \w a|strong="H3068"\w* Jerusalén, \w entonces|strong="H3588"\w* serviré \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
