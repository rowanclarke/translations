\p
\v 39 \w Then|strong="H3045"\w* \w Pharaoh|strong="H6547"\w* said \w to|strong="H3045"\w* \w Joseph|strong="H3130"\w*, “God showed \w you|strong="H3605"\w* \w what|strong="H3045"\w* \w is|strong="H3605"\w* going \w to|strong="H3045"\w* happen, \w and|strong="H6547"\w* \w he|strong="H3605"\w* told \w you|strong="H3605"\w* \w what|strong="H3045"\w* \w to|strong="H3045"\w* \w do|strong="H3605"\w*. \w So|strong="H2063"\w* \w I|strong="H3045"\w* \w know|strong="H3045"\w* \w that|strong="H3045"\w* \w you|strong="H3605"\w* \w are|strong="H2450"\w* \w more|strong="H2450"\w* \w wise|strong="H2450"\w* \w than|strong="H3605"\w* everybody \w else|strong="H3605"\w*. \w You|strong="H3605"\w* really \w know|strong="H3045"\w* \w how|strong="H3045"\w* \w to|strong="H3045"\w* think properly.  
\v 40 \w So|strong="H4480"\w* \w now|strong="H1961"\w* \w I|strong="H5921"\w* \w will|strong="H1961"\w* \w make|strong="H1431"\w* \w you|strong="H3605"\w* \w my|strong="H3605"\w* \w most|strong="H4480"\w* important worker, \w and|strong="H1004"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* \w in|strong="H5921"\w* Egypt \w will|strong="H1961"\w* \w have|strong="H1961"\w* \w to|strong="H1961"\w* \w do|strong="H5401"\w* \w what|strong="H6310"\w* \w you|strong="H3605"\w* \w say|strong="H6310"\w*. \w I|strong="H5921"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w the|strong="H3605"\w* \w only|strong="H7535"\w* \w one|strong="H3605"\w* \w that|strong="H5971"\w* \w is|strong="H3605"\w* \w more|strong="H4480"\w* important \w than|strong="H4480"\w* \w you|strong="H3605"\w*, \w because|strong="H5921"\w* \w I|strong="H5921"\w* \w am|strong="H1961"\w* \w the|strong="H3605"\w* \w big|strong="H1431"\w* boss.”\x * \xo 41:40 \xt Acts 7:10\x*   
\p
\v 41 \w After|strong="H5921"\w* \w Pharaoh|strong="H6547"\w* said \w those|strong="H3605"\w* \w things|strong="H3605"\w*, \w he|strong="H3605"\w* said \w to|strong="H5921"\w* \w Joseph|strong="H3130"\w*, “\w Now|strong="H5414"\w* \w I|strong="H5414"\w*’m \w putting|strong="H5414"\w* \w you|strong="H5414"\w* \w in|strong="H5921"\w* \w charge|strong="H5921"\w* \w of|strong="H5921"\w* \w all|strong="H3605"\w* \w of|strong="H5921"\w* \w Egypt|strong="H4714"\w* country.”   
\p
\v 42 \w Pharaoh|strong="H6547"\w* \w was|strong="H6547"\w* wearing \w a|strong="H3068"\w* \w ring|strong="H2885"\w* \w with|strong="H3847"\w* \w a|strong="H3068"\w* special \w mark|strong="H7760"\w* \w on|strong="H5921"\w* \w it|strong="H5414"\w*. \w That|strong="H5414"\w* \w ring|strong="H2885"\w* \w showed|strong="H5414"\w* \w that|strong="H5414"\w* \w Pharaoh|strong="H6547"\w* \w was|strong="H6547"\w* \w the|strong="H5921"\w* big boss. \w So|strong="H5414"\w* \w Pharaoh|strong="H6547"\w* \w took|strong="H5493"\w* \w off|strong="H5493"\w* \w that|strong="H5414"\w* special \w ring|strong="H2885"\w*, \w and|strong="H3027"\w* \w he|strong="H5414"\w* \w put|strong="H5414"\w* \w it|strong="H5414"\w* \w on|strong="H5921"\w* \w Joseph|strong="H3130"\w*’s \w finger|strong="H2885"\w*, \w to|strong="H5921"\w* \w show|strong="H5414"\w* \w that|strong="H5414"\w* \w Joseph|strong="H3130"\w* \w was|strong="H6547"\w* \w in|strong="H5921"\w* \w charge|strong="H5921"\w*.\fig Pharaoh put Jospeh in charge of Egypt country, and he gave Joseph his special ring|src="ai jo 10 pharaoh ring.jpg" size="col" copy="Maryanne Cameron (I need to check if this is copyright Bible Society Australia.)" ref="41:42" \fig* \w And|strong="H3027"\w* \w Pharaoh|strong="H6547"\w* \w gave|strong="H5414"\w* \w Joseph|strong="H3130"\w* \w some|strong="H3027"\w* new \w clothes|strong="H3847"\w* \w to|strong="H5921"\w* \w wear|strong="H3847"\w*. \w Those|strong="H5921"\w* \w clothes|strong="H3847"\w* \w were|strong="H3027"\w* \w made|strong="H7760"\w* \w out|strong="H5414"\w* \w of|strong="H3027"\w* \w a|strong="H3068"\w* \w really|strong="H7760"\w* good cloth, \w called|strong="H7760"\w* \w linen|strong="H8336"\w*. \w And|strong="H3027"\w* \w Pharaoh|strong="H6547"\w* \w put|strong="H5414"\w* \w a|strong="H3068"\w* \w gold|strong="H2091"\w* \w necklace|strong="H7242"\w* \w around|strong="H5921"\w* \w Joseph|strong="H3130"\w*’s \w neck|strong="H6677"\w*.\x * \xo 41:42 \xt Daniel 5:29\x*  
\v 43 \w Then|strong="H5414"\w* \w Pharaoh|strong="H7392"\w* got \w a|strong="H3068"\w* special trailer \w with|strong="H5921"\w* horses pulling \w it|strong="H5414"\w*, \w and|strong="H4714"\w* \w he|strong="H3605"\w* got Joseph \w to|strong="H5921"\w* \w ride|strong="H7392"\w* \w in|strong="H5921"\w* \w that|strong="H3605"\w* special trailer \w to|strong="H5921"\w* \w show|strong="H5414"\w* \w that|strong="H3605"\w* \w he|strong="H3605"\w* \w was|strong="H4714"\w* \w the|strong="H3605"\w* 2nd boss \w over|strong="H5921"\w* \w Egypt|strong="H4714"\w* country. \w Pharaoh|strong="H7392"\w*’s soldiers \w went|strong="H6440"\w* \w with|strong="H5921"\w* Joseph, \w and|strong="H4714"\w* \w they|strong="H5921"\w* \w shouted|strong="H5414"\w* \w out|strong="H5414"\w* \w to|strong="H5921"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* people, “Joseph \w is|strong="H3605"\w* coming. \w Show|strong="H5414"\w* \w him|strong="H5414"\w* \w respect|strong="H5921"\w*.”  
\p \w In|strong="H5921"\w* \w that|strong="H3605"\w* \w way|strong="H6440"\w*, \w Pharaoh|strong="H7392"\w* \w put|strong="H5414"\w* Joseph \w in|strong="H5921"\w* \w charge|strong="H5921"\w* \w of|strong="H6440"\w* \w all|strong="H3605"\w* \w of|strong="H6440"\w* \w Egypt|strong="H4714"\w* country.   
\p
\v 44 \w Pharaoh|strong="H6547"\w* said \w to|strong="H3027"\w* \w Joseph|strong="H3130"\w*, “\w I|strong="H4714"\w* am \w the|strong="H3605"\w* big boss, \w and|strong="H3027"\w* \w you|strong="H3605"\w* \w are|strong="H3027"\w* \w my|strong="H3605"\w* most important worker. If anybody \w in|strong="H3027"\w* \w Egypt|strong="H4714"\w* country wants \w to|strong="H3027"\w* \w do|strong="H3027"\w* \w something|strong="H3605"\w*, \w they|strong="H3808"\w* \w have|strong="H3027"\w* \w to|strong="H3027"\w* ask \w you|strong="H3605"\w* first, \w and|strong="H3027"\w* \w you|strong="H3605"\w* \w can|strong="H3808"\w* say \em yes\em* \w or|strong="H3808"\w* \em no\em*.”   
\p
\v 45-46 Then Pharaoh gave Joseph \w a|strong="H3068"\w* name in the Egypt language. That name was \em Zafenath-Pania\em*. Pharaoh also gave Joseph \w a|strong="H3068"\w* woman to marry. That woman’s name was Asenath, and her father’s name was Potifera. He was \w a|strong="H3068"\w* ceremony leader for the Egypt people, at the town called Onn.  
\p That’s the story about how Joseph became Pharaoh’s most important worker, and he started to be in charge of Egypt country. At that time, Joseph was 30 years old. Then Joseph left Pharaoh’s house, and he went all around Egypt country.   
\s1 Joseph got the Egypt people to put food in sheds  
\p
\v 47 \w The|strong="H6213"\w* next 7 \w years|strong="H8141"\w* \w were|strong="H8141"\w* really good \w years|strong="H8141"\w* \w in|strong="H8141"\w* Egypt country, because lots \w and|strong="H6213"\w* lots \w of|strong="H8141"\w* food grew \w on|strong="H6213"\w* \w the|strong="H6213"\w* land.  
\v 48 \w So|strong="H1961"\w* \w for|strong="H4714"\w* \w those|strong="H3605"\w* 7 \w years|strong="H8141"\w*, \w Joseph|strong="H6908"\w* told \w the|strong="H3605"\w* \w Egypt|strong="H4714"\w* \w people|strong="H6908"\w* \w to|strong="H1961"\w* \w get|strong="H8432"\w* food \w from|strong="H1961"\w* \w the|strong="H3605"\w* farms \w and|strong="H5892"\w* \w take|strong="H1961"\w* \w it|strong="H5414"\w* \w into|strong="H8432"\w* \w the|strong="H3605"\w* \w towns|strong="H5892"\w*. \w And|strong="H5892"\w* \w the|strong="H3605"\w* \w people|strong="H6908"\w* \w did|strong="H8141"\w* what \w Joseph|strong="H6908"\w* said. \w Everywhere|strong="H3605"\w* \w in|strong="H8141"\w* \w Egypt|strong="H4714"\w* \w country|strong="H7704"\w*, \w the|strong="H3605"\w* \w people|strong="H6908"\w* got food \w from|strong="H1961"\w* \w the|strong="H3605"\w* farms, \w and|strong="H5892"\w* \w they|strong="H8141"\w* \w took|strong="H1961"\w* \w that|strong="H3605"\w* food \w into|strong="H8432"\w* \w the|strong="H3605"\w* \w towns|strong="H5892"\w* \w that|strong="H3605"\w* \w were|strong="H1961"\w* near \w the|strong="H3605"\w* farms. \w Then|strong="H1961"\w* \w they|strong="H8141"\w* \w put|strong="H5414"\w* \w that|strong="H3605"\w* food \w into|strong="H8432"\w* big sheds, \w to|strong="H1961"\w* \w keep|strong="H1961"\w* \w it|strong="H5414"\w* safe.  
\v 49 \w There|strong="H5704"\w* \w was|strong="H3130"\w* \w so|strong="H3966"\w* \w much|strong="H7235"\w* food \w in|strong="H3220"\w* \w those|strong="H3588"\w* sheds \w that|strong="H3588"\w* nobody could \w count|strong="H5608"\w* \w it|strong="H3588"\w*, just \w like|strong="H5704"\w* nobody can \w count|strong="H5608"\w* \w all|strong="H5704"\w* \w those|strong="H3588"\w* \w little|strong="H5704"\w* bits \w of|strong="H4557"\w* \w sand|strong="H2344"\w* \w that|strong="H3588"\w* \w are|strong="H3130"\w* \w at|strong="H3220"\w* \w the|strong="H3588"\w* beaches \w by|strong="H5704"\w* \w the|strong="H3588"\w* \w sea|strong="H3220"\w*.   
\s1 Joseph had 2 sons  
\p
\v 50 \w Joseph|strong="H3130"\w*’s wife \w was|strong="H1121"\w* called Asenath, \w and|strong="H1121"\w* \w her|strong="H3205"\w* \w father|strong="H3205"\w*’s name \w was|strong="H1121"\w* Potifera. \w He|strong="H8147"\w* \w was|strong="H1121"\w* \w a|strong="H3068"\w* ceremony leader \w for|strong="H1121"\w* \w the|strong="H3205"\w* Egypt \w people|strong="H1121"\w*, \w at|strong="H1121"\w* \w the|strong="H3205"\w* town called Onn.  
\p \w Joseph|strong="H3130"\w* \w and|strong="H1121"\w* Asenath \w had|strong="H3205"\w* 2 \w sons|strong="H1121"\w*. \w Both|strong="H8147"\w* \w those|strong="H1121"\w* \w sons|strong="H1121"\w* \w were|strong="H1121"\w* \w born|strong="H3205"\w* \w at|strong="H1121"\w* \w the|strong="H3205"\w* \w time|strong="H8147"\w* \w when|strong="H1121"\w* there \w was|strong="H1121"\w* still lots \w of|strong="H1121"\w* food growing \w in|strong="H8141"\w* Egypt country.   
\p
\v 51 \w Joseph|strong="H3130"\w* \w named|strong="H7121"\w* \w his|strong="H3605"\w* 1st \w son|strong="H1060"\w* \em Manasseh\em*. \w That|strong="H3588"\w* \w name|strong="H8034"\w* means \em he let me forget\em*. \w Joseph|strong="H3130"\w* \w said|strong="H7121"\w*, “\w You|strong="H3588"\w* see, God \w was|strong="H8034"\w* good \w to|strong="H1004"\w* \w me|strong="H7121"\w*. \w He|strong="H3588"\w* let \w me|strong="H7121"\w* \w forget|strong="H5382"\w* \w about|strong="H1004"\w* \w all|strong="H3605"\w* \w that|strong="H3588"\w* \w trouble|strong="H5999"\w* \w I|strong="H3588"\w* \w had|strong="H3588"\w*, \w and|strong="H1004"\w* \w he|strong="H3588"\w* \w even|strong="H3588"\w* let \w me|strong="H7121"\w* \w forget|strong="H5382"\w* \w that|strong="H3588"\w* \w I|strong="H3588"\w* miss \w my|strong="H3605"\w* \w family|strong="H1004"\w*.”   
\p
\v 52 Joseph \w named|strong="H7121"\w* \w his|strong="H7121"\w* 2nd son \em Ephraim\em*. \w That|strong="H3588"\w* \w name|strong="H8034"\w* means \em he let me have kids\em*. Joseph \w said|strong="H7121"\w*, “\w You|strong="H3588"\w* see, God \w was|strong="H8034"\w* good \w to|strong="H7121"\w* \w me|strong="H7121"\w*. \w He|strong="H3588"\w* let \w me|strong="H7121"\w* \w have|strong="H3588"\w* kids \w in|strong="H8034"\w* \w this|strong="H3588"\w* country, \w even|strong="H3588"\w* \w though|strong="H3588"\w* \w I|strong="H3588"\w* \w had|strong="H3588"\w* lots \w of|strong="H8034"\w* \w trouble|strong="H6040"\w* here.”   
\s1 There was no rain and no food plants  
\p
\v 53 \w For|strong="H4714"\w* \w those|strong="H1961"\w* 7 \w years|strong="H8141"\w*, lots \w and|strong="H4714"\w* lots \w of|strong="H8141"\w* food plants grew \w in|strong="H8141"\w* \w Egypt|strong="H4714"\w* country. \w But|strong="H1961"\w* \w at|strong="H1961"\w* \w the|strong="H1961"\w* \w end|strong="H3615"\w* \w of|strong="H8141"\w* \w those|strong="H1961"\w* 7 good \w years|strong="H8141"\w*, \w the|strong="H1961"\w* rain stopped coming.  
\v 54 \w Then|strong="H1961"\w* \w the|strong="H3605"\w* 7 dry \w years|strong="H8141"\w* \w started|strong="H2490"\w*. \w There|strong="H1961"\w* \w was|strong="H1961"\w* \w no|strong="H3605"\w* rain, \w and|strong="H3899"\w* \w the|strong="H3605"\w* \w food|strong="H3899"\w* plants stopped growing. \w It|strong="H1961"\w* \w happened|strong="H1961"\w* \w just|strong="H3605"\w* \w like|strong="H1961"\w* \w Joseph|strong="H3130"\w* said.\x * \xo 41:54 \xt Acts 7:11\x*  
\p \w The|strong="H3605"\w* same \w thing|strong="H3605"\w* \w happened|strong="H1961"\w* \w in|strong="H8141"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w other|strong="H3605"\w* countries around \w Egypt|strong="H4714"\w* \w too|strong="H1961"\w*. \w There|strong="H1961"\w* \w was|strong="H1961"\w* \w no|strong="H3605"\w* rain \w and|strong="H3899"\w* \w no|strong="H3605"\w* \w food|strong="H3899"\w* plants growing \w in|strong="H8141"\w* \w those|strong="H3605"\w* countries, \w so|strong="H1961"\w* \w the|strong="H3605"\w* \w people|strong="H2490"\w* \w in|strong="H8141"\w* \w those|strong="H3605"\w* countries didn’t \w have|strong="H1961"\w* \w enough|strong="H3605"\w* \w food|strong="H3899"\w*. \w But|strong="H1961"\w* \w there|strong="H1961"\w* \w was|strong="H1961"\w* still lots \w of|strong="H8141"\w* \w food|strong="H3899"\w* \w in|strong="H8141"\w* \w those|strong="H3605"\w* big sheds \w in|strong="H8141"\w* \w Egypt|strong="H4714"\w*.   
\p
\v 55-56 This is what happened in Egypt country at the time when the rain stopped coming. It got dry all over Egypt country, and the food plants everywhere stopped growing. It got really bad, and all the Egypt people started to get hungry. So they went to Pharaoh, and they said to him, “Please, please give us food.”  
\p Then Pharaoh said to all the Egypt people, “Go to Joseph, and do whatever he tells you.”\x * \xo 41:55-56 \xt John 2:5\x*  
\p So they went to Joseph, and they asked him for food. Then Joseph got his workers to go to all the towns in Egypt country and open those big sheds. There was lots of food in those sheds from the 7 good years. So Joseph’s workers started to sell that food to the Egypt people.   
\p
\v 57 \w And|strong="H4714"\w* \w there|strong="H3605"\w* \w was|strong="H7458"\w* \w no|strong="H3605"\w* rain \w in|strong="H7458"\w* \w other|strong="H3605"\w* countries too. \w It|strong="H3588"\w* \w was|strong="H7458"\w* really bad \w everywhere|strong="H3605"\w*. \w So|strong="H3588"\w* \w the|strong="H3605"\w* people \w that|strong="H3588"\w* lived \w in|strong="H7458"\w* \w those|strong="H3605"\w* \w other|strong="H3605"\w* countries, \w they|strong="H3588"\w* \w went|strong="H3130"\w* \w to|strong="H4714"\w* \w Egypt|strong="H4714"\w*, \w and|strong="H4714"\w* \w they|strong="H3588"\w* \w bought|strong="H7666"\w* food \w from|strong="H4714"\w* \w Joseph|strong="H3130"\w*’s workers too.   
\c 42  
\s1 Joseph’s brothers went to Egypt country  
\p
\v 1 Joseph’s \w father|strong="H1121"\w* \w Jacob|strong="H3290"\w*, \w he|strong="H3588"\w* lived \w in|strong="H1121"\w* Canaan country \w with|strong="H4714"\w* \w his|strong="H7200"\w* other \w sons|strong="H1121"\w*. \w At|strong="H7200"\w* \w that|strong="H3588"\w* time, \w there|strong="H3426"\w* \w was|strong="H1121"\w* \w no|strong="H7200"\w* rain \w and|strong="H1121"\w* \w no|strong="H7200"\w* food plants growing \w in|strong="H1121"\w* Canaan country. \w Then|strong="H7200"\w* somebody said \w to|strong="H4714"\w* \w Jacob|strong="H3290"\w*, “\w There|strong="H3426"\w* \w is|strong="H3426"\w* lots \w of|strong="H1121"\w* food \w in|strong="H1121"\w* \w Egypt|strong="H4714"\w* country.”  
\p \w So|strong="H3588"\w* \w Jacob|strong="H3290"\w* talked \w to|strong="H4714"\w* \w his|strong="H7200"\w* \w sons|strong="H1121"\w*, \w and|strong="H1121"\w* \w he|strong="H3588"\w* said \w to|strong="H4714"\w* \w them|strong="H7200"\w*, “Don’t just stand around doing \w nothing|strong="H4100"\w*.  
\v 2 Somebody \w told|strong="H8085"\w* \w me|strong="H2421"\w* \w that|strong="H3588"\w* \w there|strong="H8033"\w* \w is|strong="H3426"\w* lots \w of|strong="H4191"\w* food \w in|strong="H8085"\w* \w Egypt|strong="H4714"\w* country. \w Go|strong="H3381"\w* \w there|strong="H8033"\w* \w and|strong="H4714"\w* \w buy|strong="H7666"\w* food \w for|strong="H3588"\w* \w all|strong="H2009"\w* \w of|strong="H4191"\w* \w us|strong="H3588"\w*. \w If|strong="H3588"\w* \w you|strong="H3588"\w* don’t \w go|strong="H3381"\w* \w and|strong="H4714"\w* \w buy|strong="H7666"\w* food \w for|strong="H3588"\w* \w us|strong="H3588"\w*, \w we|strong="H3068"\w* \w will|strong="H4714"\w* \w die|strong="H4191"\w*.”\x * \xo 42:2 \xt Acts 7:12\x*   
\p
\v 3 \w So|strong="H3381"\w* 10 \w of|strong="H4714"\w* Jacob’s sons \w left|strong="H3381"\w* Canaan country, \w and|strong="H4714"\w* they \w went|strong="H3381"\w* \w to|strong="H3381"\w* \w Egypt|strong="H4714"\w* country \w to|strong="H3381"\w* \w buy|strong="H7666"\w* food there. Those 10 men \w were|strong="H4714"\w* \w Joseph|strong="H3130"\w*’s half-brothers. They \w had|strong="H3130"\w* \w the|strong="H3381"\w* same father \w as|strong="H3381"\w* \w Joseph|strong="H3130"\w*, but different mothers.  
\v 4 \w You|strong="H3588"\w* know, \w Joseph|strong="H3130"\w* \w had|strong="H3588"\w* \w one|strong="H3808"\w* other brother \w too|strong="H3808"\w*. \w His|strong="H7971"\w* name \w was|strong="H3290"\w* \w Benjamin|strong="H1144"\w*. \w Joseph|strong="H3130"\w* \w and|strong="H7971"\w* \w Benjamin|strong="H1144"\w* \w had|strong="H3588"\w* \w the|strong="H3588"\w* same father \w and|strong="H7971"\w* mother. \w Their|strong="H3588"\w* father \w Jacob|strong="H3290"\w* really loved \w Benjamin|strong="H1144"\w*. \w So|strong="H6435"\w* \w Jacob|strong="H3290"\w* didn’t \w want|strong="H3808"\w* \w Benjamin|strong="H1144"\w* \w to|strong="H7971"\w* \w go|strong="H7971"\w* \w to|strong="H7971"\w* Egypt \w with|strong="H7971"\w* \w his|strong="H7971"\w* brothers. \w He|strong="H3588"\w* thought, “\w Benjamin|strong="H1144"\w* \w might|strong="H6435"\w* \w get|strong="H7971"\w* hurt, \w or|strong="H3808"\w* \w he|strong="H3588"\w* \w might|strong="H6435"\w* die.” \w So|strong="H6435"\w* \w Benjamin|strong="H1144"\w* stayed \w at|strong="H3808"\w* home \w with|strong="H7971"\w* \w his|strong="H7971"\w* father.   
\p
\v 5 \w In|strong="H3478"\w* Egypt country, Jacob’s \w sons|strong="H1121"\w* \w went|strong="H3478"\w* \w to|strong="H3478"\w* \w buy|strong="H7666"\w* food, \w and|strong="H1121"\w* \w there|strong="H1961"\w* \w were|strong="H3478"\w* lots \w of|strong="H1121"\w* other \w people|strong="H1121"\w* \w from|strong="H3478"\w* \w Canaan|strong="H3667"\w* country \w there|strong="H1961"\w* \w too|strong="H1961"\w*. \w You|strong="H3588"\w* see, \w there|strong="H1961"\w* \w was|strong="H1961"\w* \w no|strong="H3478"\w* rain \w and|strong="H1121"\w* \w no|strong="H3478"\w* food plants growing anywhere \w in|strong="H3478"\w* \w Canaan|strong="H3667"\w*, \w so|strong="H1961"\w* \w the|strong="H3588"\w* \w Canaan|strong="H3667"\w* \w people|strong="H1121"\w* \w had|strong="H1961"\w* \w to|strong="H3478"\w* \w go|strong="H1961"\w* \w to|strong="H3478"\w* Egypt \w to|strong="H3478"\w* \w buy|strong="H7666"\w* food.   
\s1 Joseph pretended that he didn’t know his brothers  
\p
\v 6 \w At|strong="H5921"\w* \w that|strong="H5971"\w* \w time|strong="H5921"\w*, \w Joseph|strong="H3130"\w* \w was|strong="H1931"\w* \w in|strong="H5921"\w* \w charge|strong="H5921"\w* \w of|strong="H5971"\w* Egypt country, \w and|strong="H5971"\w* \w he|strong="H1931"\w* \w was|strong="H1931"\w* \w the|strong="H3605"\w* \w one|strong="H3605"\w* \w that|strong="H5971"\w* \w sold|strong="H7666"\w* food \w to|strong="H5921"\w* everybody. \w So|strong="H5921"\w* \w Joseph|strong="H3130"\w*’s brothers \w came|strong="H5971"\w* \w to|strong="H5921"\w* \w him|strong="H5921"\w*, \w and|strong="H5971"\w* \w they|strong="H5921"\w* got \w down|strong="H7812"\w* \w on|strong="H5921"\w* \w their|strong="H3605"\w* knees \w and|strong="H5971"\w* put \w their|strong="H3605"\w* \w faces|strong="H5921"\w* \w near|strong="H5921"\w* \w the|strong="H3605"\w* ground, \w to|strong="H5921"\w* show \w him|strong="H5921"\w* \w respect|strong="H5921"\w*.\x * \xo 42:6 \xt Genesis 37:7\x*\fig Joseph’s brothers went to Egypt to get food|src="GR-lllb10n.tif" size="col" copy="GRN" ref="42:6" \fig*  
\v 7-8 But they didn’t know that he was their brother Joseph. They thought that he was one of the Egypt people.  
\p Joseph looked at those men, and he saw that they were his brothers. But Joseph pretended that he didn’t know them. He talked to them in the Egypt language, and somebody else talked to Joseph’s brothers in their own language and told them the things Joseph said. And Joseph talked in \w a|strong="H3068"\w* rough way to them. He said, “Where do you mob come from?”  
\p His brothers said, “We come from Canaan country. We want to buy food here in Egypt.”   
\p
\v 9 \w Then|strong="H7200"\w* \w Joseph|strong="H3130"\w* \w remembered|strong="H2142"\w* those \w dreams|strong="H2472"\w* \w that|strong="H7200"\w* \w he|strong="H3130"\w* \w had|strong="H2492"\w* \w a|strong="H3068"\w* long time \w before|strong="H7200"\w*. Those \w dreams|strong="H2472"\w* \w showed|strong="H7200"\w* \w that|strong="H7200"\w* \w one|strong="H7200"\w* day, \w Joseph|strong="H3130"\w*’s brothers \w will|strong="H3130"\w* \w all|strong="H7200"\w* bend down \w in|strong="H7200"\w* front \w of|strong="H7200"\w* \w him|strong="H7200"\w*, \w to|strong="H7200"\w* \w show|strong="H7200"\w* \w him|strong="H7200"\w* \w respect|strong="H7200"\w*.\x * \xo 42:9 \xt Genesis 37:5-10\x*  
\p \w Joseph|strong="H3130"\w* kept \w on|strong="H7200"\w* pretending \w that|strong="H7200"\w* \w he|strong="H3130"\w* didn’t know \w them|strong="H7200"\w*. \w He|strong="H3130"\w* said \w to|strong="H7200"\w* \w his|strong="H7200"\w* brothers, “\w I|strong="H7200"\w* reckon \w you|strong="H7200"\w* mob \w are|strong="H2472"\w* lying \w to|strong="H7200"\w* \w me|strong="H7200"\w*. \w I|strong="H7200"\w* reckon \w you|strong="H7200"\w* \w are|strong="H2472"\w* \w my|strong="H7200"\w* enemies. \w You|strong="H7200"\w* \w came|strong="H3130"\w* here \w to|strong="H7200"\w* \w find|strong="H7200"\w* \w out|strong="H7270"\w* \w about|strong="H3130"\w* \w our|strong="H7200"\w* country, \w so|strong="H7200"\w* \w that|strong="H7200"\w* \w your|strong="H7200"\w* \w people|strong="H7200"\w* \w can|strong="H7200"\w* attack \w us|strong="H7200"\w*.”   
\p
\v 10 \w But|strong="H3808"\w* \w they|strong="H3808"\w* said \w to|strong="H5650"\w* him, “\w No|strong="H3808"\w*, sir, \w that|strong="H5650"\w*’s \w not|strong="H3808"\w* true. We respect \w you|strong="H3808"\w*. We \w came|strong="H5650"\w* here \w to|strong="H5650"\w* \w buy|strong="H7666"\w* food.  
\v 11 \w You|strong="H3605"\w* know, \w we|strong="H3068"\w* \w are|strong="H1121"\w* \w all|strong="H3605"\w* \w brothers|strong="H1121"\w*, \w with|strong="H3605"\w* \w the|strong="H3605"\w* \w same|strong="H3651"\w* \w father|strong="H1121"\w*. \w We|strong="H5168"\w* \w are|strong="H1121"\w* good \w men|strong="H1121"\w*, \w and|strong="H1121"\w* \w we|strong="H3068"\w* don’t \w tell|strong="H3605"\w* \w lies|strong="H1961"\w*. \w We|strong="H5168"\w* \w are|strong="H1121"\w* \w not|strong="H3808"\w* \w your|strong="H3605"\w* enemies.”   
\p
\v 12 \w Joseph|strong="H3808"\w* said, “\w I|strong="H3588"\w* don’t believe \w you|strong="H3588"\w*. \w I|strong="H3588"\w* reckon \w you|strong="H3588"\w* came here \w to|strong="H7200"\w* \w find|strong="H7200"\w* \w out|strong="H7200"\w* about \w our|strong="H7200"\w* country, \w so|strong="H3808"\w* \w that|strong="H3588"\w* \w your|strong="H7200"\w* \w people|strong="H3808"\w* \w can|strong="H7200"\w* attack \w us|strong="H3588"\w*.”   
\p
\v 13 \w They|strong="H3117"\w* said, “No, sir. \w Those|strong="H1121"\w* \w things|strong="H8147"\w* \w that|strong="H3117"\w* \w we|strong="H3068"\w* told \w you|strong="H3117"\w*, \w they|strong="H3117"\w* \w are|strong="H3117"\w* true. \w We|strong="H3117"\w* \w are|strong="H3117"\w* \w from|strong="H1121"\w* \w a|strong="H3068"\w* family \w of|strong="H1121"\w* 12 \w brothers|strong="H1121"\w*. \w We|strong="H3117"\w* \w all|strong="H3117"\w* \w have|strong="H1121"\w* \w the|strong="H3117"\w* same \w father|strong="H1121"\w*, \w and|strong="H1121"\w* \w he|strong="H3117"\w* lives \w in|strong="H3117"\w* \w Canaan|strong="H3667"\w* country. \w Our|strong="H5650"\w* \w youngest|strong="H6996"\w* brother stayed \w at|strong="H3117"\w* home \w with|strong="H3117"\w* \w our|strong="H5650"\w* \w father|strong="H1121"\w*, \w and|strong="H1121"\w* \w our|strong="H5650"\w* \w other|strong="H8147"\w* brother isn’t \w with|strong="H3117"\w* \w us|strong="H3117"\w* any more.”   
\p
\v 14 \w But|strong="H1696"\w* \w Joseph|strong="H3130"\w* \w said|strong="H1696"\w*, “Stop \w talking|strong="H1696"\w*, \w you|strong="H1696"\w* mob. I know \w for|strong="H1931"\w* sure \w that|strong="H1931"\w* \w you|strong="H1696"\w* \w are|strong="H3130"\w* \w my|strong="H1696"\w* enemies.  
