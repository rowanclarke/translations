\c 28
\s1 The daily offerings
\p 
\v 1 \w Yahweh|strong="H3068"\w* \w said|strong="H1696"\w* \w this|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1696"\w*:
