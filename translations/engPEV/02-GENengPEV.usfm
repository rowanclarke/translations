\p
\v 29 \w Joseph|strong="H3130"\w*’s brother \w Reuben|strong="H7205"\w* \w was|strong="H3130"\w* somewhere else, \w so|strong="H7725"\w* \w he|strong="H7725"\w* didn’t \w see|strong="H2009"\w* \w his|strong="H7725"\w* brothers sell \w Joseph|strong="H3130"\w* \w to|strong="H7725"\w* \w that|strong="H7725"\w* Midian mob. \w He|strong="H7725"\w* thought \w that|strong="H7725"\w* \w Joseph|strong="H3130"\w* \w was|strong="H3130"\w* \w still|strong="H7725"\w* \w in|strong="H7725"\w* \w that|strong="H7725"\w* hole \w in|strong="H7725"\w* \w the|strong="H7725"\w* ground. \w And|strong="H7725"\w* \w Reuben|strong="H7205"\w* wanted \w to|strong="H7725"\w* save \w Joseph|strong="H3130"\w*, \w so|strong="H7725"\w* \w he|strong="H7725"\w* \w went|strong="H7725"\w* \w to|strong="H7725"\w* \w that|strong="H7725"\w* hole \w to|strong="H7725"\w* \w get|strong="H7725"\w* \w him|strong="H7725"\w* \w out|strong="H7725"\w*. \w But|strong="H2009"\w* \w he|strong="H7725"\w* \w saw|strong="H2009"\w* \w that|strong="H7725"\w* \w Joseph|strong="H3130"\w* wasn’t \w in|strong="H7725"\w* \w that|strong="H7725"\w* hole any \w more|strong="H7725"\w*, \w and|strong="H7725"\w* \w he|strong="H7725"\w* got \w really|strong="H7725"\w* upset. \w He|strong="H7725"\w* \w was|strong="H3130"\w* \w so|strong="H7725"\w* upset \w that|strong="H7725"\w* \w he|strong="H7725"\w* \w tore|strong="H7167"\w* \w his|strong="H7725"\w* clothes.  
