\c 20  
\s1 Actuación perversa del sacerdote Pasur  
\p
\v 1 \w El|strong="H1931"\w* \w sacerdote|strong="H3548"\w* Pasur, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Imer, \w quien|strong="H1931"\w* presidía \w como|strong="H1931"\w* \w jefe|strong="H6496"\w* en \w la|strong="H1931"\w* \w Casa|strong="H1004"\w* \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w oyó|strong="H8085"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* cuando profetizaba estas \w cosas|strong="H1697"\w*.  
\v 2 Pasur azotó \w al|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w puso|strong="H5414"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w cepo|strong="H4115"\w* \w que|strong="H5921"\w* \w estaba|strong="H1004"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Puerta|strong="H8179"\w* Superior \w de|strong="H5921"\w* \w Benjamín|strong="H1144"\w*, \w la|strong="H5921"\w* cual \w estaba|strong="H1004"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 3 \w En|strong="H4480"\w* \w la|strong="H3588"\w* mañana \w siguiente|strong="H4283"\w*, Pasur \w sacó|strong="H3318"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w del|strong="H4480"\w* \w cepo|strong="H4115"\w*, \w y|strong="H3588"\w* \w Jeremías|strong="H3414"\w* le dijo: \nd \+w Yavé|strong="H3068"\+w*\nd* \w no|strong="H3808"\w* \w te|strong="H4480"\w* \w llama|strong="H7121"\w* Pasur, \w sino|strong="H3588"\w* Terror \w en|strong="H4480"\w* torno.   
\p
\v 4 \w Porque|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* dice: \wj \+w Mira|strong="H7200"\+w*, \+w Yo|strong="H3588"\+w* \+w te|strong="H5869"\+w* convierto \+w en|strong="H3588"\+w* terror \+w para|strong="H3588"\+w* ti \+w y|strong="H3588"\+w* \+w para|strong="H3588"\+w* \+w todos|strong="H3605"\+w* tus amigos. \+w Caerán|strong="H5307"\+w* \+w por|strong="H3588"\+w* \+w la|strong="H3588"\+w* \+w espada|strong="H2719"\+w* \+w de|strong="H3588"\+w* sus enemigos, \+w y|strong="H3588"\+w* tus \+w ojos|strong="H5869"\+w* \+w lo|strong="H3605"\+w* \+w verán|strong="H7200"\+w*. \+w Entregaré|strong="H5414"\+w* \+w a|strong="H3068"\+w* \+w todo|strong="H3605"\+w* \+w Judá|strong="H3063"\+w* \+w en|strong="H3588"\+w* \+w mano|strong="H3027"\+w* del \+w rey|strong="H4428"\+w* \+w de|strong="H3588"\+w* Babilonia, \+w quien|strong="H3605"\+w* \+w los|strong="H3605"\+w* llevará \+w cautivos|strong="H1540"\+w* \+w a|strong="H3068"\+w* Babilonia \+w y|strong="H3588"\+w* \+w los|strong="H3605"\+w* matará \+w a|strong="H3068"\+w* \+w espada|strong="H2719"\+w*.\wj*  
\v 5 \wj \+w Entregaré|strong="H5414"\+w* también \+w todas|strong="H3605"\+w* las riquezas \+w de|strong="H5414"\+w* \+w esta|strong="H2063"\+w* \+w ciudad|strong="H5892"\+w*, \+w todo|strong="H3605"\+w* \+w el|strong="H3605"\+w* producto \+w de|strong="H5414"\+w* su labor y \+w todos|strong="H3605"\+w* \+w los|strong="H3605"\+w* tesoros \+w de|strong="H5414"\+w* \+w los|strong="H3605"\+w* \+w reyes|strong="H4428"\+w* \+w de|strong="H5414"\+w* \+w Judá|strong="H3063"\+w*, y \+w los|strong="H3605"\+w* saqueará. \+w Los|strong="H3605"\+w* \+w tomarán|strong="H3947"\+w* y \+w los|strong="H3605"\+w* llevarán \+w a|strong="H3068"\+w* Babilonia.\wj*  
\v 6 \wj \+w Y|strong="H3068"\+w* tú, Pasur, y \+w todos|strong="H3605"\+w* \+w los|strong="H1992"\+w* \+w que|strong="H1992"\+w* viven \+w en|strong="H6912"\+w* tu \+w casa|strong="H1004"\+w* \+w irán|strong="H3212"\+w* \+w cautivos|strong="H7628"\+w*. Entrarás \+w en|strong="H6912"\+w* Babilonia y \+w allí|strong="H8033"\+w* \+w morirás|strong="H4191"\+w*. \+w Allí|strong="H8033"\+w* \+w serán|strong="H1992"\+w* \+w sepultados|strong="H6912"\+w*, tú y \+w todos|strong="H3605"\+w* tus amigos, \+w a|strong="H3068"\+w* \+w los|strong="H1992"\+w* cuales \+w profetizaste|strong="H5012"\+w* \+w mentira|strong="H8267"\+w*.\wj*   
\s1 Lamentación de Jeremías  
\p
\v 7 Me sedujiste, oh \nd \+w Yavé|strong="H3068"\+w*\nd*, y \w fui|strong="H1961"\w* seducido. \w Fuiste|strong="H1961"\w* más fuerte \w que|strong="H3117"\w* yo, y me venciste. \w Cada|strong="H3605"\w* \w día|strong="H3117"\w* \w soy|strong="H1961"\w* objeto de burla. \w Cada|strong="H3605"\w* uno \w se|strong="H1961"\w* burla de \w mí|strong="H1961"\w*.  
\v 8 \w Porque|strong="H3588"\w* cuantas veces \w hablo|strong="H1696"\w*, \w proclamo|strong="H7121"\w*, \w grito|strong="H2199"\w*: ¡\w Violencia|strong="H2555"\w* \w y|strong="H3588"\w* \w destrucción|strong="H7701"\w*! \w La|strong="H3588"\w* \w Palabra|strong="H1697"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* resulta \w para|strong="H3588"\w* \w mí|strong="H1961"\w* reproche \w y|strong="H3588"\w* burla \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w*.   
\p
\v 9 \w Y|strong="H3068"\w* \w si|strong="H3808"\w* digo: \w No|strong="H3808"\w* \w lo|strong="H3808"\w* recordaré \w a|strong="H3068"\w* Él, \w ni|strong="H3808"\w* \w hablaré|strong="H1696"\w* \w más|strong="H5750"\w* \w en|strong="H5750"\w* su \w Nombre|strong="H8034"\w*, entonces \w mi|strong="H1961"\w* \w corazón|strong="H3820"\w* \w es|strong="H1961"\w* \w como|strong="H1961"\w* un fuego abrasador \w encerrado|strong="H6113"\w* \w en|strong="H5750"\w* mis \w huesos|strong="H6106"\w*. Me esfuerzo \w en|strong="H5750"\w* contenerlo, pero \w no|strong="H3808"\w* \w puedo|strong="H3201"\w*.  
\v 10 \w Porque|strong="H3588"\w* \w oí|strong="H8085"\w* \w la|strong="H3588"\w* murmuración \w de|strong="H4480"\w* \w muchos|strong="H7227"\w*: ¡Terror \w por|strong="H3588"\w* \w todas|strong="H3605"\w* \w partes|strong="H5439"\w*! ¡Denúncienlo, denunciémoslo! \w Todos|strong="H3605"\w* mis \w amigos|strong="H7227"\w* \w que|strong="H3588"\w* esperan mi caída dicen: Quizás sea \w engañado|strong="H6601"\w*. \w Entonces|strong="H3588"\w* prevaleceremos \w contra|strong="H4480"\w* \w él|strong="H3588"\w* \w y|strong="H3588"\w* \w tomaremos|strong="H3947"\w* nuestra \w venganza|strong="H5360"\w*.  
\v 11 \w Pero|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w está|strong="H3651"\w* conmigo \w como|strong="H3588"\w* \w poderoso|strong="H1368"\w* \w Gigante|strong="H6184"\w*. \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, mis \w perseguidores|strong="H7291"\w* \w tropezarán|strong="H3782"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w prevalecerán|strong="H3201"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*. Sentirán \w perpetua|strong="H5769"\w* \w confusión|strong="H3639"\w* \w que|strong="H3588"\w* \w nunca|strong="H3808"\w* \w será|strong="H3808"\w* \w olvidada|strong="H7911"\w*.  
\v 12 Oh \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H3588"\w* \w las|strong="H1992"\w* huestes. Tú escudriñas al \w justo|strong="H6662"\w* \w y|strong="H3588"\w* \w ves|strong="H7200"\w* \w la|strong="H3588"\w* mente \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w corazón|strong="H3820"\w*. Permite \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w vea|strong="H7200"\w* tu \w venganza|strong="H5360"\w* \w de|strong="H3588"\w* \w ellos|strong="H1992"\w*, \w pues|strong="H3588"\w* \w a|strong="H3068"\w* Ti expuse mi \w causa|strong="H7379"\w*.   
\p
\v 13 ¡Canten \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w alaben|strong="H1984"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, Quien \w libró|strong="H5337"\w* \w la|strong="H3588"\w* \w vida|strong="H5315"\w* del pobre \w de|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* malhechores!  
\v 14 Maldito el \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \w nací|strong="H3205"\w*. \w No|strong="H1961"\w* \w sea|strong="H1961"\w* bendecido el \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \w mi|strong="H1961"\w* madre me dio \w a|strong="H3068"\w* luz.  
\v 15 Maldito \w el|strong="H1121"\w* \w hombre|strong="H1121"\w* \w que|strong="H1121"\w* dio noticias \w a|strong="H3068"\w* mi padre, y dijo: ¡Te \w nació|strong="H3205"\w* un \w hijo|strong="H1121"\w* \w varón|strong="H2145"\w*! \w Y|strong="H3068"\w* le causó gran alegría.  
\v 16 \w Sea|strong="H1961"\w* tal hombre \w como|strong="H1961"\w* las \w ciudades|strong="H5892"\w* \w que|strong="H1931"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* destruyó \w sin|strong="H3808"\w* misericordia, \w Que|strong="H1931"\w* \w oiga|strong="H8085"\w* \w alarma|strong="H8643"\w* por \w la|strong="H1931"\w* \w mañana|strong="H1242"\w* y \w gritos|strong="H8643"\w* \w de|strong="H6256"\w* guerra \w al|strong="H6256"\w* mediodía.  
\v 17 \w Porque|strong="H3808"\w* \w no|strong="H3808"\w* me mataste en el vientre, y \w mi|strong="H1961"\w* madre \w sería|strong="H1961"\w* \w mi|strong="H1961"\w* \w sepulcro|strong="H6913"\w*, y su vientre estaría embarazado \w para|strong="H1961"\w* \w siempre|strong="H5769"\w*.  
\v 18 ¿Para \w qué|strong="H4100"\w* \w salí|strong="H3318"\w* del vientre? ¿Para \w ver|strong="H7200"\w* aflicción y \w dolor|strong="H5999"\w*, y \w que|strong="H4100"\w* mis \w días|strong="H3117"\w* \w se|strong="H4100"\w* gasten \w en|strong="H3318"\w* vergüenza?   
\c 21  
\s1 Destrucción del reino de Judá  
\p
\v 1 La \w Palabra|strong="H1697"\w* \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*, \w cuando|strong="H1961"\w* \w el|strong="H1121"\w* \w rey|strong="H4428"\w* Sedequías le \w envió|strong="H7971"\w* \w a|strong="H3068"\w* Pasur, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Malquías y \w al|strong="H4428"\w* \w sacerdote|strong="H3548"\w* \w Sofonías|strong="H6846"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Maasías|strong="H4641"\w*, \w para|strong="H1961"\w* \w que|strong="H1697"\w* le dijeran:  
\v 2 \w Te|strong="H5921"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* consultes \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w por|strong="H5921"\w* \w nosotros|strong="H3605"\w*, \w porque|strong="H3588"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, guerrea \w contra|strong="H5921"\w* \w nosotros|strong="H3605"\w*. Tal vez \nd \+w Yavé|strong="H3068"\+w*\nd* \w nos|strong="H5921"\w* trate \w según|strong="H5921"\w* \w todas|strong="H3605"\w* sus \w maravillosas|strong="H6381"\w* obras, \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* \w que|strong="H3588"\w* \w aquél|strong="H3605"\w* \w se|strong="H5921"\w* retire \w de|strong="H5921"\w* \w nosotros|strong="H3605"\w*.   
\p
\v 3 \w Y|strong="H3068"\w* \w Jeremías|strong="H3414"\w* les respondió: Digan \w así|strong="H3541"\w* \w a|strong="H3068"\w* Sedequías:  
