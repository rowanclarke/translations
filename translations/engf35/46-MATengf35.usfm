\p
\v 29 “\w Woe|strong="G3759"\w* \w to|strong="G2532"\w* \w you|strong="G5210"\w* \w scribes|strong="G1122"\w* \w and|strong="G2532"\w* \w Pharisees|strong="G5330"\w*, \w hypocrites|strong="G5273"\w*!!!! \w Because|strong="G3754"\w* \w you|strong="G5210"\w* \w build|strong="G3618"\w* \w the|strong="G2532"\w* \w tombs|strong="G3419"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w prophets|strong="G4396"\w* \w and|strong="G2532"\w* \w adorn|strong="G2885"\w* \w the|strong="G2532"\w* \w monuments|strong="G3419"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w righteous|strong="G1342"\w*;  
