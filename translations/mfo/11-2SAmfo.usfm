\id 2SA - Mbembe Okohm [MFNOk]
\h 2 Samwẹl
\toc2 2 Samwẹl
\toc2 Nnwẹr kw'ottong afa kwa Samwẹl
\toc1 Nnwẹr kw'ottong afa kwa Samwẹl
\mt1 Nnwẹr kw'ottong afa kwa Samwẹl
\c 1
\s1 Devid ọbhaang obo kwa Saul
\p 
\v 1 K'ogbe kwa Saul ọkk'ọpa, Devid obina kẹ da okk'anọng p'Amalẹk okhema okhuna, okwu owobha iwu ifa ka Ziklag.
\v 2 Ottong iwu ittaan, ojinọng wani kw'ofon k'ibhingabe sa Saul okwu, ttara ọbara f'ọkk'ẹ ọjaakhi ka for, ọmaana ọkpọhm k'eho. Mada opyiri k'ibe sa Devid owobh, otto okhubha m'irerek k'ikpokpobha.
\p 
\v 3 Devid e, ọbọbh-ẹ bi, “Kọ afon man akwu ma o?”
\p Ojinọng nwa obhina bi, “Kaam nnọbhi k'ibhingabe s'agbong-nọng p'Israẹl e.”
\p 
\v 4 Devid ọbọbh bi, “Bọng odik wọ otto? Gbaakh-m.”
\p Ojinọng nwa obhina bi, “Asoja haabhada p'Israẹl arọbhi k'egbong-dam, haabhada abira ape. Saul ọmaana nnwa kwẹ Jonatan akk'abira apa e.”
\p 
\v 5 Mẹ wọ, Devid ọbọbh odikkobh nwa kw'otzim ẹkkaabha nda okwu bi, “Kọ areng yan aronga bi, Saul ọmaana nnwa kwẹ Jonatan akk'apa?”
\p 
\v 6 Odikkobh nwa oben bi, “Odik ode bi, kaam nda k'egbegbeho cha Gilboa, nna nda nttema da Saul on-otto ọkpẹkhi ọkhọhn fẹ, ttara bi, akpaar pa nnyanyaang mmindọr, ọmaana ayaari-nnyanyaang am-akhubh-ẹ ẹkhọma-ẹkhọma.
\v 7 Mada ọbhakhi ore-m, oyer-m, nkhera mben bi, ‘Kkeri kaam ma e.’
\p 
\v 8 “Ọbọbh-m bi, ‘Kọ ade bọng ọnọng o?’
\p “Kaam e, mmina bi, ‘Kaam mfon Amalẹk e.’
\p 
\v 9 “Mẹ wọ, oben-m bi, ‘Rọkhi abaang-m, afhu-m! Kaam nna nwobh ka mbọhk s'obo, yina, ndimi nji iwọhng ka e.’
\p 
\v 10 “Mẹ wọ, mbẹ-ẹ m'ẹbhabhaanga, mfhẹ-ẹ, okhuri da nne bi, mada ọkk'ọtta mẹ, akpen dọk kofha oruk. Nnwọr-ẹ ivaarkpo s'ọfọr k'eho, ọmaana ogimma kw'okhe k'ọbọhk. Nkk'pyẹ ndima nkwu ma bi, nnang kọ itta kwaam e.”
\p 
\v 11 Mẹ wọ, Devid ọmaana ajinọng pẹ biphyir abọkha ọbara fa bẹ afọr ka for ajaakhi.
\v 12 Bẹ awobha ka nkwu-osisi, abira abhom amọng, atzim ọchattọhk maa, ẹchọhkha etto. Wa bẹ asi mando, okhuri obo kwa Saul ope ọmaana nnwa kwẹ Jonatan, ọmaana agbong-nọng p'anọng p'Ọvaar Ibinọkpaabyi, ttara anọng p'Israẹl, okhuri bi, bẹ atzim ọkkangkkaang afhu bẹ.
\p 
\v 13 Devid e, ọbọbh odikkobh nwuma kw'otzim ẹkkaabha nda okwu bi, “Kọ afon man o?”
\p Ojinọng nwuma obhina bi, “Kaam nde nnwa kw'okhekhen-nọng kw'ofon Amalẹk.”
\p 
\v 14 Mẹ wọ, Devid ọbọbh-ẹ bi, “Osi yan kw'ira on-ojor bi, ayaangi ọbọhk kwọ, afhu ọnọng kw'Ọvaar Ibinọkpaabyi okk'ana obyengi k'eho?”
\p 
\v 15 Mẹ wọ, Devid oyeri ojinọng kwẹ wani, oben bi, “Rọhng, atza afhẹ-ẹ!” Ofona mẹ, obun-ẹ ofhu, ojinọng nwuma ope.
\v 16 Ode cha Devid ọkk'ẹ obena bi, “Izi sọ ibhaakhi ikpan kọ ọkhaam. Da akk'ẹmma chọ atzima asi ẹjaakhi bi, ‘Kaam nkk'ọnọng kw'Ọvaar Ibinọkpaabyi okk'ana obyengi k'eho mfha e.’ ”
\s1 Ebomọng cha Devid ọkkọhni k'obo kwa Saul ọmaana Jonatan
\p 
\v 17 Devid ọkkọhni ebomọng nda otzima ojima Saul ọmaana nnwa kwẹ Jonatan.
\v 18 Obiro ọnang ẹfa bi, bẹ akpebhi ajinọng pa Juda ebomọng nda ch'oyuk. (Bẹ akkẹri ẹmọng nda ka nnwẹr kwa Jasha).
\q1 
\v 19 “Israẹl o, ajibhada pọ ape ayima ka mgbegbeho sọ.
\q2 Kpebh e, kkeri odem kw'afanọng atto e!
\b
\q1 
\v 20 “Bọng odik nwa ka Gat kàgbaak,
\q2 Bọng kwẹ ka mkpaanga-den s'Ashkẹlọn kàgbaak,
\q1 oni mando ode, aminava p'anọng pa Philistiya, awobha k'ọdadaami,
\q2 oni mando ode, aminava p'anọng p'ani ọkpakkọrikkọ asi, awobha k'ọdadaami.
\b
\q1 
\v 21 “Mgbegbeho sa Gilboa o,
\q2 bọng abonisi obiro ode ẹrọng, káre e.
\q2 Kaambi k'iwoni rọ, achimọma pa nnanga káwọm,
\q1 okhuri bi, mẹ wọ kwa bẹ alukhi ọkhọhnkpa kw'afanọng,
\q2 bẹ ọkhọhnkpa kwa Saul ana dọk kabọhr.
\q1 
\v 22 Ofon k'izi s'anọng pa ape,
\q2 ofona k'ayaara p'afanọng,
\q1 oyuk kwa Jonatan nnama-nnam kọkpa.
\q2 Ọkkangkkaang kwa Saul nnam k'idukhi kobiro ọkpa.
\b
\q1 
\v 23 “Mada iwa Saul ọmaana Jonatan arukhi akpen,
\q2 bẹ akhaam idadaakha, abira asi ọphyaam anang ayok;
\q2 k'obo, bẹ ayok kabira abhaangi.
\q1 Wa bẹ aphyebhi ayọhnga okye-nọhn,
\q2 bẹ akhaama ẹfa ayọhnga nkye.
\b
\q1 
\v 24 “Aminava p'Israẹl o,
\q2 bọng mom Saul e,
\q1 kw'ọnangi bọng ọbara fa for f'ode iho-iho, ọmaana agimma,
\q2 kw'odok nnya sabọng ttara ẹfanginẹ-kpo pya gol.
\b
\q1 
\v 25 “Kpebh e! Kkeri odem kw'afanọng akk'atta k'egbong e!
\q2 Jonatan ope oyima ka mgbegbeho sọ.
\q1 
\v 26 Jonatan ọgbaanọkka kwaam o, kaam mmomi kọ e,
\q2 kọ wa abar-m odik kpọng-kpọng.
\q1 Idadaakha s'iwa akhaam ttar-m ikkoni-okkoni,
\q2 ikkoni ọtzam iyọhnga idadaakha sa kwanọng.
\b
\q1 
\v 27 “Kkeri odem kw'afanọng akk'atta!
\q2 Egbongkpo ekk'ekhibhi biphyir-phyir!”
\c 2
\s1 Bẹ abyengi Devid ana k'eho ode ọvaarnọng kwa Juda
\p 
\v 1 Okwu opyiri k'ogbe mẹ, Devid ọdọhn Ọvaar Ibinọkpaabyi, ọbọbh bi, “Na kaam mfha mvura k'obhon wani kw'ẹkhọma cha Juda o?”
\p Ọvaar Ibinọkpaabyi obhin-ẹ bi, “Rọhng atza avura.”
\p Devid ọbọbh bi, “Nchina ka bọng okhubha o?”
\p Ọvaar Ibinọkpaabyi obhin-ẹ bi, “China ka Hẹbrọn.”
\p 
\v 2 Mẹ wọ, Devid ochina ka Hẹbrọn ttara panọng pẹ afa p'ade, Ahinoam kw'ofon Jẹzrẹl ọmaana Abigẹl, kw'ode opopa kwanọng kwa Nabal kw'ofon Kaamẹl.
\v 3 Iwa Devid obiro otzima ajinọng p'awobh ttar-ẹ, ọnọng-ọnọng ttara ẹhọhmmọr chẹ, bẹ atza aruk k'ibhon sa Hẹbrọn.
\v 4 Wa ajinọng pa Juda abina akwu ka Hẹbrọn, mẹ wọ kwa bẹ abyengi Devid ana k'eho, on-ode ọvaarnọng kwa Juda.
\p Mada bẹ agbaakhi Devid bi, ajinọng pa Jabẹsh-Gilead bọ anọhng Saul,
\v 5 mando kwa Devid ọtzọhmi akkaabh-nkkaabha, atza agbaak ajinọng pa Jabẹsh-Gilead bi, “Tte Ọvaar Ibinọkpaabyi odo bọng k'ọphyaam fa bọng asi anang itta kwabọng Saul, da bọng anọhng-ẹ.
\v 6 Tte Ọvaar Ibinọkpaabyi osi ọphyaam ọnang bọng, obiro ọkhọhkha bọng idadaakha, kaam mbiri nsi ọphyaam nnang bọng, okhuri odik nwa kwa bọng akk'asa.
\v 7 Mẹ wọ, bọng gaangi for, ade ajinọng \it bi gbuk \it* da Saul kw'ode itta kwabọng ọkk'ọpa e. Kẹ wọ osi, ajinọng pa Juda akk'aam ana abyengi k'eho bi, nde ọvaarnọng kwabẹ.”
\s1 Egbong ch'anọng pa Devid ọmaana va pa va pa Saul
\p 
\v 8 Ayongi mẹ, nnwa kw'ijinọng kwa Nẹr, kw'okpen Abnẹr kw'ode oho kw'agbong-nọng pa Saul, okk'Ish-Boshẹt kw'ode nnwa kw'ijinọng kwa Saul, otzima ojekha ka Mahanayim.
\v 9 Ọsẹ-ẹ ọvaarnọng kw'anọng pa Gilead, ọmaana Ashur, ọmaana Jẹzrẹl, ọmaana Ephraim, ọmaana Bẹnjamin ttara Israẹl biphyir.
\p 
\v 10 Wa Ish-Boshẹt kw'ode nnwa kwa Saul, ode cho arọbh afa, mada ode ọvaarnọng kw'Israẹl, ọdabh bẹ ka cho afa. Yina, wa ẹkhọma cha Juda ẹtzọn Devid abẹ.
\v 11 Wa Devid orukhi ka Hẹbrọn, ode ọvaarnọng kw'anọng pa Juda, ka cho azenamfa ọmaana aphe azadani.
\p 
\v 12 Abnẹr kw'ode nnwa kwa Nẹr, ọmaana ajinọng p'Ish-Boshẹt kw'ode nnwa kwa Saul, abina ka Mahanayim achina ka Gibeọn.
\v 13 Wa Joab nnwa kwa Zeruya, ọmaana ajinọng pa Devid atza attema ayok abẹ k'esipe cha Gibeọn. Ẹkhaan dani ewobh ẹwọr k'okhubha wani kw'esipe, ẹkhaan ndonggo ewobha ẹwọr k'okhubha nwonggo.
\p 
\v 14 Mẹ wọ e, Abnẹr oben Joab bi, “Tte m'otzekha adikkobh paman bani, bẹ atzima mbọhk-mbọhk arima ayok abẹ ma man k'itzitzikha.”
\p Joab e, oben bi, “Ojibhi kẹ! Tte bẹ arima.”
\p 
\v 15 Mando kwa bẹ atzek ajinọng jobh obhiri afa pa Bẹnjamin ọmaana Ish-Boshẹt nnwa kw'ijinọng kwa Saul. Bẹ abira atzekha ajinọng jobh obhiri afa pa Devid.
\v 16 Mẹ wọ, ojinọng kpenamkpen ọdabh oyok m'eho, okhum-ẹ ọkkangkkaang m'abhọribom, bẹ atto m'irerek ape. Ofona mẹ, bẹ ayeri ibe nnuma ka Gibeọn, Helkat-Hazurim.\f + \fr 2.16 \fq Helkat-Hazurim\ft Odem kw'ọwọhng nwa oyini k'eHiburu bi mkpaar kọttaani. Yina, anwẹr bani abeni bi, ofha oyin irek s'amamaana, obiro ofha oyin irek s'ẹkhọhr. \f*
\p 
\v 17 Iwa egbong ẹgaangi m'ewu nduma maa, ajinọng pa Devid akhema ajinọng p'Abnẹr ọmaana ajinọng p'Israẹl.
\p 
\v 18 Iwa va attaan pa Zeruya awobh mẹ p'ade: Joab, ọmaana Abishayi, ọmaana Asahẹl. Wa Asahẹl ode ọnọng kw'okpo ẹbhar mach'otzen-wuri k'ẹtzam.
\v 19 Asahẹl okhubh Abnẹr, nnam kọbhakhi bi okkeri k'odimbọhk, ọmaana kwabọhk.
\v 20 Abnẹr ọbhakhi nnam ọbọbh bi, “Asahẹl kọ wọ mẹ o?”
\p Asahẹl obhina bi, “O o kaam wọ e.”
\p 
\v 21 Abnẹr oben-ẹ bi, “Kkeri k'odimbọhk abira akkeri ka kwabọhk kwọ, abọkha odikkobh wani egbongkpo pyẹ ana.” Kaambi mẹ wọ, Asahẹl kokher bi ọkwọbh-ẹ okhukhubh.
\p 
\v 22 Abnẹr obiro oben Asahẹl bi, “Kwọbh-m okhukhubh! Okhuri yan kwa kaam mfhọ-ọ o mmari m'irerek? Yan kwa kaam nkkeri agbaanakka Joab k'itzitzikha o?”
\p 
\v 23 Yina, Asahẹl kokher bi ọkwọbha Abnẹr okhukhubh. Ofona mẹ, Abnẹr otzima ẹkhọhnma chẹ okhum Asahẹl k'ẹbhọr maa, ọkhọhn oyin ka nnam. Asahẹl otto m'ẹbaa ope. Ojinọng kpenamkpen kw'opyiri m'ibe s'Asahẹl oyim ope, obe mẹ k'ikpokpobha.
\p 
\v 24 Yina, Joab ọmaana Abishayi akhubh Abnẹr, mada ewuchen ẹm-ẹkhakha, bẹ apyiri k'egbegbeho ch'Ama, ọbaanga Giya, k'ọkkadeden kw'ochin k'ibe s'anọng anarukhi sa Gibeọn.
\v 25 Mẹ wọ, ajinọng p'ẹkhọma cha Bẹnjamin abe Abnẹr ka nnam. Bẹ atzobha k'ẹkhaan dani, atza abe k'egbegbeho-ebira, ado for s'egbong.
\p 
\v 26 Mando kw'Abnẹr, oyeri Joab, oben bi, “Ode bi ọkkangkkaang ochina ororo ofhu anọng maa, ogbe ode o? Kọ katzini bi, okpong kw'odik nwa, otzima ọmmamma okwu o? Ogbe obhir otzuma yan, yina aben ajinọng pọ akwọbha vọkka pabẹ okhukhubh o?”
\p 
\v 27 Joab obhina bi, “Odem nwa kw'Ibinọkpaabyi orukhi akpen, idikha ira ani ẹmọng asi, ira bi, ajinọng mba achina ororo akhubh vọkka pabẹ maa, ewu ehobha.”
\p 
\v 28 Ofona mẹ e, Joab ogyi obukpọhng, otzima oyeri ajinọng pẹ biphyir, bẹ akwọbha anọng p'Israẹl okhukhubh, bẹ abira akwọbha erima.
\p 
\v 29 M'erungiwu nduma biphyir, Abnẹr ọmaana ajinọng pẹ asi orenga akwọbha Araba, bẹ ajekha Ẹttẹri cha Jọrdan, achina ororo m'ekpebhawu nduma biphyir, akwọbha obhon kwa Bitrọn akwu apyiri ka Mahanayim.
\p 
\v 30 Mẹ wọ, Joab ọkpa nnam okhuna kẹ da okhubhi Abnẹr, obiro otzobha ajinọng pẹ biphyir. Oyongi Asahẹl, ajinọng ọhawani kw'ẹrọbh pa Devid bọ ani nnam akpa.
\v 31 Yina, wa ajinọng pa Devid, akk'ajinọng pa Bẹnjamin, anọng arọbh chi obhiri arọbh attaan, p'atzọni Abnẹr abẹ afha.
\v 32 Iwa bẹ atzọkha Asahẹl anọhnga k'epekhubh ch'otte kwẹ, ka Bẹtẹlẹhẹm. Mẹ wọ e, Joab ọmaana ajinọng pẹ atzima erungi nduma biphyir asi orenga maa, bẹ apyiri ka Hẹbrọn k'owuhobha.
\c 3
\p 
\v 1 Iwa egbong cha va pa va pa Saul ttara anọng pa Devid, ewobh k'ogbe-bhirada. Wa anọng pa Devid an-ado ẹfa akhaama, yina, ẹfa echina ororo ẹha va pa va pa Saul.
\p 
\v 2 Iwa bẹ amaan va p'ijinọng anang Devid mada orukhi ka Hẹbrọn.
\li1 Wa ocheden-nwa okpen Amnọn kw'Ahinoam kw'ofon Jẹzrẹl ọmaani;
\li1 
\v 3 ottong afa okpena Kilẹab kw'Abigẹl, kw'ode opopa kwa Nabal kw'ofon Kaamẹl ọmaani.
\li1 Ottong attaan okpena Absalọm kw'ode nnwa kwa Maaka ọmaani. Wa Maaka ode nnwa kw'ikwanọng kwa Talmayi kw'ode ọvaarnọng kwa Geshur.
\li1 
\v 4 Ottong anna okpena Adonija kw'ode nnwa kw'ijinọng kwa Hagit;
\li1 ottong azen okpena Shẹphatiya kw'ode nnwa kw'Abital.
\li1 
\v 5 Ottong azadani okpena Itreyam kw'ode nnwa kw'ijinọng kw'Ẹgla ọmaani ọnang Devid.
\li1 Va mba bọ p'iwa bẹ amaani anang Devid k'obhon kwa Hẹbrọn.
\s1 Abnẹr ojek otzor Devid
\p 
\v 6 K'ogbe kwa va pa va pa Saul ọmaana anọng pa Devid atzima arim egbong, Abnẹr om-otzima ogbe nwuma odo for sẹ ẹfa okhe, k'ottem kwa va pa va pa Saul.
\v 7 M'ogbe nwa, Saul ọkk'ọkkọra-kwanọng ọkhaama kw'okpen Rizpa, kw'ode nnwa kw'ikwanọng kw'Aiya. Wa Ish-Boshẹt oben Abnẹr bi, “Okhuri yan kw'ayim ọkkọra-kwanọng kw'otte kwaam abẹ o?”
\p 
\v 8 Iwa ettem epyibh Abnẹr, okhuri odik kw'Ish-Boshẹt ọgbaakhi. Mẹ wọ, obhina bi, “Kaam nde oho kw'ẹpfa ch'esi ọtzọhm ẹnang anọng pa Juda ra a? Mayina, kaam nhak eho nnang atte Saul, ọmaana efona chẹ, ttara ayokh-ẹkhaan pẹ. Kaam kọ ọbọhk ndim mintta nnang Devid. Yina, kọ abar ettem abubh-m odik mayina, kw'okhuri kwanọng nwa.
\v 9 Tte Ibinọkpaabyi osi-m k'eden kpenamkpen ch'ẹdaakh-ẹ, idikha kaam nni ọttọhk f'Ọvaar Ibinọkpaabyi ochekhi ttara ọnwọhngi ọnang Devid, nsi.
\v 10 Ibinọkpaabyi obeni bi, ọtzọkha ẹvaar ch'ọhọhm kwa Saul ọnang Devid, on-ottima ẹvaarchi cha Devid aranga k'Israẹl ọmaana Juda, ttẹwọr ka Dan maa apyiri ka Beershẹba.”
\v 11 Wa Ish-Boshẹt dọk koyom bi, ọgbaak atzim adọdọk ọnang Abnẹr, da Abnẹr ojor-ẹ.
\p 
\v 12 Mẹ wọ, wa Abnẹr ọtzọhm akkaabh-nkkaabha bẹ atza abọbh Devid bi, “Irerek s'anyi rọ ma o? Kọ si echekhi ttara kaam, ifha kaam ndima ebhonmọr ch'Israẹl biphyir njekha ndor-ọ.”
\p 
\v 13 Devid obhina bi, “Ojibhi kẹ, kaam ńsi echekhi osi ttar-ọ. Yina, tte mphyem-ọ odik wani, kọ kaam k'itzitzikha kabe kw'oyongi bi, atzim Mikal kw'ode nnwa kw'ikwanọng kwa Saul, mada akwu bi akwu are-m.”
\v 14 Mẹ wọ, Devid ọtzọhm akkaabh-nkkaabha k'Ish-Boshẹt kw'ode nnwa kwa Saul, oben bi, “Bọng nang-m kwanọng kwaam kwa kaam ndim mkpatzọr arọbh azen s'aPhilistiya ndọkha.”
\p 
\v 15 Mando kw'Ish-Boshẹt ọnang ẹfa, bẹ arọbha Mikal k'ọbada kwa Paltiyẹl kw'ode nnwa kwa Laish, atzima afona.
\v 16 Odim om-obhom ẹmọng ọtzọn-ẹ abẹ maa opyiri k'obhon kwa Bahurim. Mẹ wọ, Abnẹr oben-ẹ bi, “Kọ kpa nnam abhana!” Iwa ọkpa nnam ọbhana.
\p 
\v 17 Iwa Abnẹr agbaak atzim ttara adenho p'Israẹl, oben bi, “K'ogbe kw'ọkk'ọkwọbha, bọng akk'am-akhonga bi, asi Devid ọvaarnọng.
\v 18 Ogbe okk'on-obenga e, bọng na si mando! Da iwa Ọvaar Ibinọkpaabyi ochekhi ọnang Devid bi, ‘Kaam ńnenga k'ọtzọhmnọng kwaam Devid nkkaana anọng paam p'Israẹl ka mbọhk s'anọng pa Philistiya, ọmaana ka mbọhk s'attattaanga-nọng pabẹ biphyir.’ ”
\p 
\v 19 Abnẹr obiro ọgbaak atzim ọnang anọng pa Bẹnjamin. Mẹ wọ, obina ochina ka Hẹbrọn bi, ọtza ọgbaak Devid odik kpenamkpen kw'ojibh-ojibh k'itzitzikha s'anọng p'Israẹl, ọmaana ẹkhọma cha Bẹnjamin echibhi bi, esi.
\v 20 Mada Abnẹr otzim ajinọng ẹrọbh okwu okhebha Devid ka Hẹbrọn, Devid osi ọdadaami otzima ọtzaam Abnẹr ọmaana ajinọng pẹ.
\v 21 Mẹ wọ, Abnẹr oben Devid bi, “Tte kaam mfona madẹdẹn ifha nda ndobha anọng p'Israẹl biphyir nhok itta kwaam, kw'ode ọvaarnọng, ifha bẹ asi echekhi ttar-ọ. Kọ ábira ade ọvaarnọng kw'ọdabh kpenamkpen mach'ochibhi kwọ ode.” Mẹ wọ, wa Devid oben Abnẹr ọbhana k'odidiri.
\s1 Joab ofhu Abnẹr
\p 
\v 22 Mẹ ẹba mẹ, ajinọng pa Devid ọmaana Joab afona k'egbong ttara ọgbọm-barada fa bẹ achi. Yina, wa Abnẹr ka Hẹbrọn ttara Devid dọk kowobh, da Devid okk'ẹ ọtzọhma ọbhana k'odidiri.
\v 23 Mada Joab ọmaana agbong-nọng pẹ biphyir apyiri, bẹ agbaakh-ẹ bi, Abnẹr kw'ode nnwa kw'ijinọng kwa Nẹr ọkk'ọkwa m'ọvaarnọng, ttara bi, ọvaarnọng okk'ẹ ọtzọhma ọbhana k'odidiri e.
\p 
\v 24 Mẹ wọ e, Joab ofona ọtza okhebha ọvaarnọng ọbọbh-ẹ bi, “Bọng odik kw'asi ma? Mmaang bi, ira Abnẹr okwu ma, okhuri yan kw'attẹ-ẹ ọbọhk ofona? Ma okk'ofona!
\v 25 Kọ arong ọnọng-dema kw'Abnẹr kw'ode nnwa kw'ijinọng kwa Nẹr ode kẹ. Kẹ okwu bi, okwu ọbọhr-ọ, ifha oronga orenga kwọ, obiro oronga odik kpenamkpen kw'am-asi.”
\p 
\v 26 Joab e, obina oji Devid, ọtzọhm akkaabh-nkkaabha akhubh Abnẹr ka nnam, bẹ abọkh-ẹ k'esipe cha Sira atzim-ẹ akpa nnam. Yina, iwa Devid odik nwa korong.
\v 27 Mẹ wọ e, mada Abnẹr ọkpa nnam ka Hẹbrọn, Joab otzim-ẹ ọpaangi k'ottem kw'ẹbaakhamma, osi mach'oben bi ọgbaakh-ẹ atzim k'idafa. Mando kwa Joab okhum-ẹ imaana k'ẹbhọr ope, otzima otzukha obo kw'ọgbaanọkka kwẹ, Asahẹl.
\p 
\v 28 Mada Devid ọbhaang odik nwa, oben bi, “K'itzitzikha s'Ọvaar Ibinọkpaabyi, mbọhk saam ttara s'anọng p'ọvaarbhon kwaam, m'odik kw'okhuri obo kw'Abnẹr, kw'ode nnwa kwa Nẹr, kinde o.
\v 29 Tte izi s'Abnẹr inana Joab ọmaana ẹhọhmmọr ch'otte kwẹ biphyir k'eho! Tte ẹhọhmmọr cha Joab eningi ọnọng kw'osi edem, ọmaana okkikkima, ode ọnọng kw'ọrẹkh-ọrekhi, obiro ode ọnọng kw'ope obo kw'ọkkangkkaang, obiro ode ọnọng kw'ọchattọhk owori, ewori.”
\p 
\v 30 (Wa Joab ọmaana ọgbaanọkka Abishayi afhu Abnẹr, okhuri da ọkk'ọgbaanọkka kwabẹ Asahẹl ọfha k'egbong ka Gibeọn).
\p 
\v 31 Mẹ wọ, Devid oben Joab ọmaana anọng biphyir p'atzọn-ẹ abẹ bi, “Bọng jaakhi ọbara fabọng afọr ka for, bọng an-afọra abara-bina awobha ka nkwu-osisi s'Abnẹr.” Ọvaar Devid ọkhaam otzor igbaang s'itzọhk epfura-kkọhbhi nnam.
\v 32 Wa bẹ anọhnga Abnẹr ma Hẹbrọn, ọvaar Devid obhom ẹmọng k'ẹrọng m'epekhubh ch'Abnẹr. Anọng biphyir abira abhom.
\p 
\v 33 Ọvaar Devid ọkkọhn ebomọng ọnang Abnẹr:
\q1 “Ma, ọbaan kẹ bi Abnẹr ope mach'odidingi-nọng o?
\q2 
\v 34 Bẹ ndik katzim adabh-ọ mbọhk,
\q2 Bẹ kọ mgbakkọhbh ka mmo kakpa.
\q1 Kọ ape mach'ọnọng kw'ope ka mbọhk s'anọng-dama.”
\p Anọng abira abhom ẹmọng k'ẹrọng.
\p 
\v 35 Mẹ wọ, bẹ biphyir akwu akhukhi Devid bi ochi ọchattọhk, da ewu etzim-ewobh, yina, wa Devid ọtzọkha ọnwọhngi oben bi, “Tte Ibinọkpaabyi osi-m k'eden kpenamkpen ch'ẹdaakh-ẹ, idikha kaam nchi brẹd obiro ode ọttọhk kpenamkpen, yina s'ẹchọhkha etto!”
\p 
\v 36 Iwa anọng mba biphyir atzin odik nwa, kwẹ obiro ọdaam bẹ ettem. K'odik-ọkka, odik kpenamkpen kw'ọvaarnọng osi, ọdaam bẹ ettem.
\v 37 Mẹ wọ, m'ewu nduma, anọng pa Juda biphyir ọmaana anọng p'Israẹl biphyir aronga bi, ọvaar Devid ọbọhk k'obo kw'Abnẹr, kw'ode nnwa kwa Nẹr, kọkhaam.
\p 
\v 38 Mẹ wọ, ọvaarnọng oben ajinọng pẹ bi, “Ode bi, bọng karong bi nnwa kw'ọvaarnọng ọmaana ọfanọng kw'ideden wọ ope mayina m'Israẹl o?
\v 39 Mayina, kaambi ode bi kaam wọ nde ọvaarnọng kwa bẹ abyengi ana k'eho, ẹfa ẹkk'aam ẹha. Va mba pa Zeruya akhaam ẹfa ayọhng-m e. Tte Ọvaar Ibinọkpaabyi ochora obibyanọng otzor k'ibibyadik sẹ!”
\c 4
\s1 Obo kw'Ish-Boshẹt
\p 
\v 1 Mada Ish-Boshẹt kw'ode nnwa kwa Saul, ọbhaang bi Abnẹr okk'ọpa ka Hẹbrọn, ẹfa ẹhẹ-ẹ. Ebhonmọr ch'Israẹl biphyir ebire ewobha k'ojora.
\v 2 Wa nnwa nwa kwa Saul ọkhaam va p'ijinọng afa p'iwa ade adenho p'agbong-nọng. Wa oyok wani okpen Baana, nwonggo okpena Rekab. Wa bẹ ade va pa Rimọn kw'ofon Berot k'ẹkhọma cha Bẹnjamin. Wa bẹ am-atzọkha Berot attara k'ibhon s'isi ẹkhọma cha Bẹnjamin,
\v 3 okhuri da iwa anọng pa Berot arọbhi achina ka Gitayim, aruk mẹ mach'akhekhen-nọng maa apyiri k'ewu cha mayina.
\p 
\v 4 (Iwa Jonatan kw'ode nnwa kwa Saul ọkhaam nnwa kw'ijinọng kw'ọrẹkh-ọrẹkhi. Wa nnwa nwa ode cho azen mada bẹ atzim ẹkkaabha ch'obo kwa Saul ọmaana Jonatan ka Jẹzrẹl akwu. Wa kwanọng kw'om-okker-ẹ, otzin-ẹ otzima ọrọbh. Yina, mada oduk bi otzim-ẹ ofona, nnwa nwa ọnaang-ẹ otto ọphyakhi mmo. Wa nnwa nwa okpen Mẹphiboshẹt).
\p 
\v 5 Mẹ wọ, Rekab ọmaana Baana p'ade va pa Rimọn kw'ofon ka Berot, abina achina k'ọhọhm kw'Ish-Boshẹt. Wa bẹ apyiri kẹ k'ọyakpattem, k'ogbe kw'Ish-Boshẹt oyim k'ibe s'okwokha ọwọhng.
\v 6 Bẹ adim k'ọhọhm ẹtzaanga macha bẹ atza wit ọtzọtzọkha, bẹ akhum-ẹ imaana k'ẹbhọr afhẹ-ẹ. Rekab ọmaana ọgbaanọkka Baana arọbh afona.
\v 7 Mada bẹ akk'k'ọhọhm adima, bẹ achina k'ẹmaanggọ ch'Ish-Boshẹt akhebh-ẹ k'ebin ch'oyim afhẹ-ẹ. Bẹ akpaar-ẹ eho, atzima chẹ arenga k'eden ch'Araba k'erungiwu nduma biphyir.
\v 8 Bẹ atzima eho nda ch'Ish-Boshẹt achena Devid ka Hẹbrọn, aben ọvaarnọng bi, “Kkeri eho ch'Ish-Boshẹt ma, kw'ode nnwa kw'ọttattaanga-nọng kwọ Saul, kw'ọkhami bi, ọfhọ-ọ. Mayina, Ọvaar Ibinọkpaabyi okk'odik nwa otzukha ma Saul ọmaana va pa va pẹ, k'eho ch'itta kwaam, kw'ode ọvaarnọng.”
\p 
\v 9 Yina, Devid obhina Rekab ọmaana ọgbaanọkka Baana p'ade va pa Rimọn, kw'ofon Berot bi, “Mach'Ọvaar Ibinọkpaabyi orukhi akpen, kw'ọkk'aam ọkkaana ka mbọhk sa dama-dama kpenamkpen.
\v 10 K'ogbe kw'ọnọng wani okwu ọgbaakh-m bi, kker e, Saul okk'ọpa, ttara ochibhi bi ochen-m ẹkkaabha ọkkakka. Iwa kaam mbọkh-ẹ mfhu k'obhon kwa Ziklag. Echora ch'iwa kaam nnang-ẹ k'ẹkkaabha nduma dọ mẹ!
\v 11 Ọn-ọyọhng ma da anọng-dama akk'ọnọng kw'oni oponga-pyibha ọkhaam, akhebha k'ọhọhm kwẹ afhu k'ebin. Ọbaan-ọbaana bi nnor izi sẹ, mbọbh bọng, mbiri ndimi bọng m'ọyagbin nwa!”
\p 
\v 12 Mẹ wọ, Devid ọnang ajinọng pẹ ẹfa bi, bẹ afhu bẹ. Wa bẹ akpaara mbọhk ọmaana mmo sabẹ, bẹ agbana sẹ abaanga esipe ka Hẹbrọn. Yina, wa bẹ atzọkha eho ch'Ish-Boshẹt atza anọhnga k'epekhubh ch'Abnẹr ka Hẹbrọn.
\c 5
\s1 Devid ode ọvaarnọng kw'Israẹl
\p 
\v 1 Iwa ngọma s'Israẹl biphyir nkwu ngebha Devid ka Hẹbrọn mben bi, “K'odik-ọkka, kọ ade ofona-nọng kwaman, mode izi rani.
\v 2 K'ogbe kw'ọkk'ọkwọbha, iwa Saul ode ọvaarnọng kwaman, kọ wọ iwa ade ọnọng kw'om-otzima agbong-nọng p'Israẹl eden ka mgbong. Wa Ọvaar Ibinọkpaabyi oben-ọ bi, ‘Kọ wọ áde ọnọng kw'okkeri anọng paam p'Israẹl, kọ ábira ade ọvaarnọng kwabẹ.’ ”
\p 
\v 3 Mada adeden-nọng biphyir p'Israẹl akk'ọvaar Devid akhebha ka Hẹbrọn, ọvaarnọng osi echekhi ọmaana bẹ m'itzitzikha s'Ọvaar Ibinọkpaabyi. Wa bẹ abyengi Devid ana k'eho, asẹ-ẹ ọvaarnọng kw'Israẹl.
\p 
\v 4 Iwa Devid ode cho ẹrọbh obhiri jobh, mada ọdabhi ẹvaar. Wa ọdabhi ẹvaar ka cho arọbh afa.
\v 5 Ka Hẹbrọn, Devid ọdabhi Juda ka cho azenamfa ọmaana aphe azadani, obiro ọdabh anọng biphyir p'Israẹl ọmaana pa Juda ka Jẹrusalẹm, ka cho ẹrọbh obhiri jobh obhiri attaan.
\s1 Devid okhem anọng pa Jẹrusalẹm
\p 
\v 6 Ọvaarnọng ọmaana ajinọng pẹ arenga achina ka Jẹrusalẹm bi, bẹ atza arima abaJẹbus p'iwa arukhi mẹ, abẹ. AbaJẹbus aben Devid bi, “Ma kádim, kaambi akpa-chechena ọmaana anọng p'arẹkh-ọrẹkhi bọ, bẹ afha okhubh-ọ okhubh.” Iwa bẹ achibhi bi, “Na bẹ afha akpa Devid eden.”
\v 7 Kaambi mẹ wọ, Devid ọbọkha ichubhabe sa Ziyọn, kw'ode odedenmon kwa Devid.
\p 
\v 8 M'ewu nduma, Devid okk'obena bi, “Ọnọng manda wani kw'ókhema abaJẹbus, ọkhaambi da órenga k'akhekhaho, yina okhebha ‘akpa-chechena, ọmaana anọng p'arẹkh-ọrẹkhi’ p'ade attattaanga-nọng pa Devid.” Kẹ wọ osi bẹ aben bi, “Akpa-chechena ọmaana anọng p'arẹkh-ọrẹkhi k'ẹvaar-ttọhmma kádim.”
\p 
\v 9 Devid ọbọkha ichubhabe nna obiro oruk mẹ, oyeri ibẹ nna Odedenmon kwa Devid. Iwa osi odedenmon nwa ọkhọri, ttẹwọr k'igbo maa apyiri k'ẹtzaanga.
\v 10 Devid on-odo ẹfa ọkhaama okhuri da Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'Ẹfa biphyir owobh ttar-ẹ.
\p 
\v 11 Mẹ wọ, Hiram kw'ode ọvaarnọng kwa Tyrẹ ọtzọhm akkaabh-nkkaabha ka Devid, p'ọnangi achi-khuma p'ọbhọhmi mancheni, ọmaana akarpẹnta ttara amuni-nchumi s'ihọhm bi, bẹ atza asi ẹvaar-ttọhmma anang Devid.
\v 12 Ofona mẹ, Devid otzin bi, Ọvaar Ibinọkpaabyi okk'ẹ araanga ottima mach'ọvaarnọng k'Israẹl, ọttara bi, okk'ọvaarbhon kwẹ abarada ọnanga okhuri anọng pẹ p'Israẹl.
\p 
\v 13 Mada Devid obin ka Hẹbrọn, ọkhaam akkọra-panọng k'ọhaabh, ọmaana panọng p'ọtzọkh-ọtzọkha ka Jẹrusalẹm. Wa bẹ amaan-ẹ va p'ijinọng ọmaana p'ipanọng k'ọhaabh.
\v 14 Ma wọ ode che pa va p'iwa obhoni ka Jẹrusalẹm: Shamua ọmaana Shobab, ọmaana Natan, ọmaana Sọlọmọn,
\v 15 ọmaana Ibha, ọmaana Elishua, ọmaana Nẹphẹg, ọmaana Japhiya,
\v 16 ọmaana Elishama, ọmaana Eliyada ttara Ẹliphẹlẹt.
\s1 Devid okhem aPhilistiya
\p 
\v 17 Mada aPhilistiya abhaang bi, bẹ akk'Devid ana abyengi k'eho asẹ-ẹ ọvaarnọng kw'Israẹl, bẹ abina k'ẹfa atza aror Devid bi, bẹ abọkha. Iwa Devid ọbhaanga kwẹ, obina ọhakha k'ichubhabe.
\v 18 Mando kw'aPhilistiya akk'akwa akpẹ k'ẹttẹri cha Rephayim.
\v 19 Mẹ wọ, wa Devid ọtza ọdọhn Ọvaar Ibinọkpaabyi, ọbọbh-ẹ bi, “Nda ńnima aPhilistiya abẹ o? Na átte bẹ ọbọhk anang-m o?”
\p Ọvaar Ibinọkpaabyi obhin-ẹ bi, “Kọ rọhng, k'odik-ọkka, kaam ńtte aPhilistiya ọbọhk otte nnang-ọ.”
\p 
\v 20 Mẹ wọ, Devid ofona ochina ka Baal-Pẹrazim, kẹ kw'obiro okhema bẹ. Wa oben bi, “Odem nwa kw'asi am-amaam, mando kw'Ọvaar Ibinọkpaabyi ọmaam k'ibe s'attattaanga-nọng paam k'itzitzikha saam.” Ofona mẹ, oyeri ibe nnuma Baal-Pẹrazim\f + \fr 5.20 \fq Baal-Pẹrazim\ft K'eHiburu oyini Ọvaar Ibinọkpaabyi kw'ọm-ọmaam k'ibe.\f*.
\v 21 Iwa Devid ọmaana ajinọng pẹ atzini agbatza p'aPhilistiya arọbhi aji, atzima afona.
\p 
\v 22 APhilistiya abira ayin ka, atza akpẹ k'Ẹttẹri cha Rephayim.
\v 23 Mẹ wọ e Devid obiro ọdọhn Ọvaar Ibinọkpaabyi, Ọvaar Ibinọkpaabyi obhina bi, “Bọng bi gbẹng karenga avura, yina, bọng khọri bẹ ka nnam-annam akhe k'ottem. Bọng arima bẹ abẹ k'itzitzikha-itzitzikha kwa nchi sa balsam.
\v 24 Bọng abhaang iyọkhi s'agbong-nọng am-arenga k'ebira kwa nchi sa balsam \it bi kpaar\it*, bọng jaabhi mmo, mẹ wọ oyini bi, Ọvaar Ibinọkpaabyi okk'bọng eden ọcha, ọtza orima agbong-nọng p'aPhilistiya abẹ k'ibhingabe.”
\v 25 Mẹ wọ, iwa Devid osi mach'Ọvaar Ibinọkpaabyi okk'ẹ ọtzọhna. Ofhu aPhilistiya tzọni ka Gibeọn maa apyiri ka Gẹzẹr.
\c 6
\s1 Bẹ atzim Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi achina ka Jẹrusalẹm
\p 
\v 1 Iwa Devid obiro otzobha adikkobh p'Israẹl p'agaangi for, anọng nnọhna arọbh attaan obhiri chi.
\v 2 Kẹ ọmaana ajinọng pẹ biphyir afona achina ka Baala\f + \fr 6.2 \fq Baala\ft K'eHiburu obiro okpena Kiriyat Jerim. Ode odem wani ka 1Krọnikle 13:6.\f* k'ẹkhọma cha Juda bi, bẹ atza atzọkha Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi atzima akwu. Ẹkkọhbhi nda cha bẹ ayeri ka Che, kw'ode che ch'Ọvaar Ibinọkpaabyi kw'Ẹfa biphyir, kwa bẹ ahokhi ẹwọr k'ottem kw'achẹrubim, k'Ẹkkọhbhi nda ch'Echekhi.
\v 3 Bẹ atzọkha Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi anana k'ọkpaar ọbhakwẹ kwa nnyanyaang mmindọr, atzima chẹ abina k'ọhọhm kw'Abinadab, kw'owobh k'egbegbeho. Uza ọmaana Ahiyo p'ade va p'Abinadab, bọ iwa am-atzima ọkpaar nwa ọbhakwẹ eden,
\v 4 ọmaana Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi ch'ẹnan k'egbegbeho, cha bẹ anan mẹ. Wa Ahiyo om-orenga k'itzitzikha s'ọkpaar nwa.
\v 5 Iwa Devid ọmaana anọng p'Israẹl biphyir atzim ọkkọhna, ọmaana abukpọhng, ọmaana agim-agim, ọmaana agang-gaang, ọmaana achachaak, ọmaana ngorokpa p'echi ẹkkakka ttara achang-changkpa, am-asi ọdadaami ttara ẹfa chabẹ biphyir, k'itzitzikha s'Ọvaar Ibinọkpaabyi.
\p 
\v 6 Mada bẹ apyiri k'ibe sa bẹ am-awobha agwuma abarli-mọma sa Nakọn, Uza onemi ọbọhk ọbọkha Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi, da abhaam asar bi atto.
\v 7 Ọvaar Ibinọkpaabyi ọdọkhi ettem otzima otzor Uza okhuri irẹrẹkhi sẹ. Mẹ wọ, Ibinọkpaabyi obun-ẹ ofhu, otto ọbaanga Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi, ope.
\p 
\v 8 Mẹ wọ, iwa Devid ọdọkh-ẹ okhuri idọdọkhi s'Ọvaar Ibinọkpaabyi otzim otzor Uza. Tzọni kẹ maa apyiri k'ewu cha mayina, be ayeri ibe nnuma Pẹrẹz-Uza.\f + \fr 6.8 \ft Pẹrẹz Uza\ft K'eHiburu oyini ettuma ch'Uza.\f*
\p 
\v 9 M'ewu nduma, Devid ọkhaama ojora f'Ọvaar Ibinọkpaabyi, oben bi, “Yan wọ kw'Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi en-erenga etzor kaam o?”
\v 10 Iwa for kodo bi, ọtzọkha Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi bi, ewobha ttar-ẹ k'odedenmon kwa Devid. Wa otzer ọpaangi chẹ ochina k'ọhọhm kw'Ọbẹd-Edom kw'ofon Git.
\v 11 Wa Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi ewobh k'ọhọhm kw'Ọbẹd-Edom kw'ofon Git k'aphe attaan. Wa Ọvaar Ibinọkpaabyi odo Ọbẹd-Edom ọmaana ẹhọhmmọr chẹ biphyir.
\p 
\v 12 Mẹ wọ, bẹ agbaak ọvaar Devid bi, “Ọvaar Ibinọkpaabyi okk'ẹhọhmmọr ch'Ọbẹd-Edom ọda, ọmaana ọttọhk kpenamkpen fẹ, okhuri Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi e.” Wa Devid ofona ttara ọdadaami, ọtza ọtzọkha Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi k'ọhọhm kw'Ọbẹd-Edom, otzima okwu k'Odedenmon kwa Devid.
\v 13 Mada anọng p'atzọhk Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi akk'ndọkhi nzadani arenga, Devid ọtzọkha ọbhaam-dim ọmaana ọbhaamnwa kw'ojibhi for otzima osi ẹjafọhni.
\v 14 Wa Devid ọfọr ẹphọd om-otzima otzubh ebin ttara ẹfa chẹ biphyir k'itzitzikha s'Ọvaar Ibinọkpaabyi,
\v 15 k'ogbe kwa Devid ọmaana anọng p'Israẹl biphyir atzim ọkkọhna, ọmaana abukpọhng am-atzima Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi akwu.
\p 
\v 16 Mada bẹ am-atzima Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi anwa k'Odedenmon kwa Devid, Mikal kw'ode nnwa kw'ikwanọng kwa Saul, obe k'ọphapha-mma om-okkeri k'iyaan. Mada ore da Devid om-ogbe akhura, obiro otzubh ebin k'itzitzikha s'Ọvaar Ibinọkpaabyi, Devid e, okpukhi Mikal idik.
\p 
\v 17 Bẹ atzima Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi akwu attima k'ibe sa chẹ ẹbaan bi ewobha, k'ikhira sa Devid ọkk'ọsa ohok chẹ. Wa Devid osi njafọhni nkwọmisẹ ọmaana nnanga s'odidiri ọnang Ọvaar Ibinọkpaabyi.
\v 18 Mada Devid okk'njafọhni nkwọmisẹ ọmaana nnanga s'odidiri okyera osisi, on-odo anọng mba ka che ch'Ọvaar Ibinọkpaabyi kw'Ẹfa biphyir.
\v 19 Ọtzọkha brẹd, ọmaana itzen-gbugbukhi, okwu ọttara k'ittukha s'agrep p'agwu-ogwu ọnang ọnọng-ọnọng, ajinọng ọmaana panọng m'ẹkhaan ch'anọng p'Israẹl biphyir. Wa anọng mba biphyir abhana k'ihọhm sabẹ.
\p 
\v 20 Mada Devid okhun k'ọhọhm bi, okwu odo ẹhọhmmọr chẹ, Mikal kw'ode nnwa kw'ikwanọng kwa Saul oyin okhebh-ẹ k'iyaan, oben bi, “Mayina ọvaarnọng kw'Israẹl okk'for sẹ otzekha ohok ngọmi e. Okk'ikpakpa-dukhi otzima mach'odidingi-nọng k'itzitzikha s'abira-minava p'ade atzọhmnọng p'akhaan-nọng pẹ!”
\p 
\v 21 Devid oben Mikal bi, “Kaam nsi ọdadaami k'itzitzikha s'Ọvaar Ibinọkpaabyi kw'okhiri atte ọmaana ẹhọhmmọr chẹ oji, k'ogbe kw'otzekh-m bi, nde ọvaarnọng kw'anọng p'Ọvaar Ibinọkpaabyi p'Israẹl. Kaam ńsi ọdadaami k'itzitzikha s'Ọvaar Ibinọkpaabyi.
\v 22 O o! Kaam nkk'for nda bi ńdo odidingi-nọng ńger e, mbiri ńlukhi for saam nyọhnga ma. Yina, k'itzitzikha s'abira-minava mbuma p'ade atzọhmnọng p'agbaakhi odik okhuri, bẹ ánang-m ikpokpobha ọnang e.”
\p 
\v 23 Iwa Mikal, kw'ode nnwa kw'ikwanọng kwa Saul, nnwa kọmaani maa opyiri k'ewu ch'iwa ope.
\c 7
\s1 Echekhi ch'Ibinọkpaabyi osi ọnang Devid
\p 
\v 1 K'ogbe mẹ, wa ọvaar Devid ọkk'ẹwọr ọbọkha k'ẹvaar-ttọhmma chẹ. Ọvaar Ibinọkpaabyi ọkk'ẹ odidiri obiro ọnanga k'attattaanga-nọng pẹ biphyir, p'arukhi akhọr-ẹ.
\v 2 Wa Devid oben Natan kw'ode ọsẹjaakhi kw'Ibinọkpaabyi bi, “Kker e, kaam nnukhi k'ẹvaar-ttọhmma ẹkkakka cha bẹ atzim nchi s'ọbhọhmi mancheni asi, k'ogbe kw'Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi ekpong k'ikhira.”
\p 
\v 3 Natan obhina ọvaarnọng bi, “China ororo asi odik kpenamkpen kw'ọpaan-ọ, kkeri Ọvaar Ibinọkpaabyi owobh mẹ ttar-ọ.”
\p 
\v 4 M'erungiwu nduma, Ọvaar Ibinọkpaabyi oben Natan bi,
\pm 
\v 5 “Rọhng atza agbaak ọtzọhmnọng kwaam Devid bi, ‘Ọvaar Ibinọkpaabyi obeni bi, kọ rang ási ọhọhm kwa kaam ńnukh e.
\v 6 Kaam k'ọhọhm, ndimi nnukha ttẹwọr k'ewu cha kaam ndim anọng p'Israẹl mbina k'Ijip, maa apyiri k'ewu cha mayina. Kaam nkk'mminnukha k'obe-k'obe k'ikhira, mach'ọhọhm kwaam.
\v 7 Wa kaam nnangi adabhi pa ngọma s'anọng p'Israẹl ẹfa bi, bẹ atzima anọng pabẹ eden mach'akkeri-arukhimaan atzim arukhimaan pabẹ eden. Kaam nkk'nnenga k'obe-k'obe ttara bẹ, mbiri mming k'obe-k'obe k'ikhira. Ogbe kode kwa kaam nkk'adabhi mba mbena bi, “Bẹ atzima ọbhọhmi mancheni asi ọhọhm anang-m.” ’
\pm 
\v 8 “Mẹ wọ, gbaak ọtzọhmnọng kwaam Devid bi, ‘Ọvaar Ibinọkpaabyi kw'Ẹfa biphyir obeni bi, kaam ndọkh-ọ k'owoni kẹ da am-akkeri arukhimaan, nkwu nsọ-ọ ọdabhi kw'anọng paam, p'Israẹl.
\v 9 Kaam nkk'nwobha ttara kọ k'ibe kpenamkpen s'akk'atza, mbiri mfhu attattaanga-nọng p'am-arim-ọ abẹ biphyir. Mẹ wọ, kaam nna ńsọ-ọ atza che, macha che p'anọng p'atza che ọtzam k'ọyagbin.
\v 10 Mẹ wọ, kaam ńnang anọng paam p'Israẹl ibe, mbiri nttima bẹ aranga, bẹ ákhaama oruk kw'ode kwabẹ, ifha bẹ aningi bẹ atzim dọk ayakhi. Anọng-dama bẹ, bẹ ihem dọk kánang, mach'iwa ode k'ittẹwọr,
\v 11 ọmaana k'ogbe kwa ndek asi-aponga p'anọng paam Israẹl. Kaam ḿbiri nsọ-ọ awobha k'odidiri ọmaana attattaanga-nọng pọ biphyir.
\pm “ ‘Ọvaar Ibinọkpaabyi osi ẹjaakhi bi, kẹ Ọvaar Ibinọkpaabyi ma for sẹ wọ óttima ẹhọhmmọr chọ aranga, ọnang kọ ọmaana va pa va pọ.
\v 12 Mada iwu sọ íttonga m'ọyagbin bi, atza akwokha ọwọhng ttara abitta pọ, kaam ńnọbha nnwa wani k'ottem kwa va pọ, kw'óde izi sọ ọkhaam, ḿbiri nttima ọvaarbhon kwẹ aranga.
\v 13 Kẹ wọ ósi ọhọhm ọnang-m ka che chaam. Kaam ḿbiri nttima ẹvaar ch'ọvaarbhon kwẹ aranga maa ogbe ode.
\v 14 Kaam wọ ńde otte kwẹ, kẹ obiro óde nnwa kwaam. K'ogbe kw'osi epina, ńdima ẹyaangi-chi ch'anọngẹya nttum-ẹ, ḿbiri ndima mbọhk s'anọngẹya ḿmum-ẹ ekpo.
\v 15 Yina, ọnọng kode kw'ọ́tzọkha idadaakha saam ka kẹ, mach'iwa ndọk sẹ ka Saul, kw'iwa nnọbh k'ẹvaar chẹ m'itzitzikha sọ.
\v 16 Ọhọhm kwọ ọmaana ọvaarbhon kwọ óttima aranga m'ikhina ogbe ode.’ ”
\p 
\v 17 Mẹ wọ, wa Natan ọgbaak Devid atzim p'ẹjaakhi nda biphyir.
\s1 Njọhm sa Devid
\p 
\v 18 Iwa ọvaar Devid odim k'ẹtzaanga otza owobha ẹwọr k'itzitzikha s'Ọvaar Ibinọkpaabyi, ozi njọhm oben bi,
\pm “O Ọvaar Ibinọkpaabyi kw'Ọyọhng, kaam nde macha bọng ọnọng o, ẹhọhmmọr chaam epe mbọng o, kw'atzin-m anana k'ebe-dema nda o?
\v 19 Yina, ka chen pọ, kwẹ mẹ kokpong. Ọvaar kw'Ọyọhng, kọ akk'ẹjaakhi asa ch'ekhuri ẹvaar ch'ọtzọhmnọng kwọ k'ogbe ororo. O Ọvaar Ibinọkpaabyi kw'Ọyọhng, ndọhna nna nde s'anọngẹya o?
\pm 
\v 20 “O Ọvaar Ibinọkpaabyi kw'Ọyọhng, kọ arong kaam ọtzọhmnọng kwọ kẹ, bọng odik wọ kwa kaam Devid mbiri mgbaak nnang-ọ o?
\v 21 Kọ akk'odik-barada asa, abira asi ẹjaakhi anang kaam ọtzọhmnọng kwọ, okhuri atzim pọ ọmaana ochibhi kwọ.
\pm 
\v 22 “O Ọvaar Ibinọkpaabyi kw'Ọyọhng, ma kw'abar e! Ọnọng kw'ode mach-ọ kode, ọkha f'obeng kọ Ibinọkpaabyi abẹ kode, macha mokk'ọbhaanga.
\v 23 Bọng anọng bọ ade mach'anọng pọ p'Israẹl o? Obhon manda wani kw'ode mach'obhon kw'Israẹl m'ọyagbin kode, kw'Ibinọkpaabyi ọtza obhek mach'anọng ọnang for sẹ bi, osi che ọnang for sẹ, obiro osi idik-barada s'ipe anọng for ọmaana ikkokkoni-dik bi, okhubh idibhon ọmaana akha pabẹ k'itzitzikha s'anọng pọ, pa abhekhi k'Ijip.
\v 24 Kọ akk'anọng pọ p'Israẹl aranga attima mach'anọng pa kọ ọkhaam. Kọ Ọvaar Ibinọkpaabyi, akk'Ibinọkpaabyi kwabẹ abira akwa ada, maa ogbe ode.
\pm 
\v 25 “Mẹ wọ, O Ọvaar Ibinọkpaabyi, kọ hok echekhi cha akk'asa okhuri ọtzọhmnọng kwọ ọmaana ẹhọhmmọr chẹ, maa ogbe ode. Kọ si mach'akk'achekhi,
\v 26 ifha kọ atza che maa ogbe ode. Mẹ wọ, anọng án-aben bi, ‘Ọvaar Ibinọkpaabyi kw'Ẹfa biphyir wọ ode Ibinọkpaabyi kw'Israẹl!’ Ẹhọhmmọr ch'ọtzọhmnọng kwọ Devid éttima aranga k'itzitzikha sọ.
\pm 
\v 27 “O Ọvaar Ibinọkpaabyi kw'Ẹfa biphyir, kw'ode Ibinọkpaabyi kw'Israẹl, kọ akk'ẹjaakhi nda asa anang ọtzọhmnọng kwọ, aben bi, ‘Kaam Ọvaar Ibinọkpaabyi ńsi ọhọhm nnang-ọ.’ Mẹ wọ, ọtzọhmnọng kwọ okk'ottem-bara ọkhaama bi, ozi njọhm nna ọnang-ọ.
\v 28 O Ọvaar Ibinọkpaabyi kw'Ọyọhng, kọ wọ ade Ibinọkpaabyi! Echekhi chọ ede odik-ọkkakka. Kọ akk'idik nna abira achekhi anang ọtzọhmnọng kwọ.
\v 29 Tte ettem ẹdaam-ọ bi, ẹdaa ch'ado va pa va paam échina ororo k'itzitzikha sọ, maa ogbe ode; da kọ Ọvaar Ibinọkpaabyi kw'Ọyọhng akk'agbaakha. Ofona k'ẹdaa chọ, va pa va p'ọtzọhmnọng kwọ ákhaama ẹdaa maa ogbe.”
\c 8
\s1 Ngema sa Devid
\p 
\v 1 Okwu opyiri k'ogbe mẹ, Devid okhema anọng pa Philistiya, obiro ohok bẹ awobha k'irekh-irek kwẹ. Ọtzọkha obhon kwa Mẹtẹg-Ama ka mbọhk s'anọng pa Philistiya.
\p 
\v 2 Wa Devid obiro okhema anọng pa Moab. Osi bẹ ayima k'irerek k'adik attaan, ọtzọkha adik afa ofhu, otte odik wani biphyir ọbọhk oruk akpen. Wa anọng pa Moab an-aruk k'irekh-irek kwa Devid, bẹ am-abira achen-ẹ nnduma.
\p 
\v 3 Ayongi mẹ, wa Devid obiro okhema Hadadẹzẹr kw'ode ọvaarnọng kwa Zoba, obiro ode nnwa kwa Rehob. Wa okhem-ẹ k'ogbe kw'ọtza bi, obiro ọtza ottima ẹvaar chẹ aranga k'okhubha kw'Ọraanga kwa Yupharetes.
\v 4 Wa Devid ọbọkha akpaar pa nnyanyaang mmindọr nnọhna mfa obhiri arọbh jobh, ọmaana ayaari-nnyanyaang nnọhna chi obhiri mfa obhiri arọbh jobh, ttara agbong-nọng nnọhna arọbh afa obhiri jobh. Wa Devid ọrẹkhi nnyanyaang sa mmindọr akpaar biphyir, kw'oyongi nnyanyaang s'akpaar arọbh azen s'irikhi.
\p 
\v 5 Mada anọng p'Aram p'afon Damaskọs akwu bi akwu akkaana Hadadẹzẹr kw'ode ọvaarnọng kwa Zoba, wa Devid ofhu bẹ anọng nnọhna arọbh afa obhiri chi.
\v 6 Wa obiro ohok agbong-nọng p'abaabh ẹbaakhamma ch'ẹkhọma ch'anọng p'Aram p'afon Damaskọs. Anọng p'Aram an-awobha k'irekh-irek kwẹ, bẹ abira achen-ẹ nnduma. Wa Ọvaar Ibinọkpaabyi ọnangi Devid ekhema k'ibe kpenamkpen s'ochin.
\p 
\v 7 Wa Devid ọtzọkha akhọhnkpa pa gol p'akhaan-nọng pa Hadadẹzẹr, otzima okhuna ka Jẹrusalẹm.
\v 8 Ttẹwọr ka Teba ọmaana Bẹrotayi p'ade ibhon sa Hadadẹzẹr. Wa ọvaar Devid ọtzọkha brons k'ọhaabh.
\p 
\v 9 Mada Toi kw'ode ọvaarnọng kwa Hamat ọbhaang bi, Devid okk'agbong-nọng pa Hadadẹzẹr biphyir okhema,
\v 10 ọtzọhm nnwa kwẹ Joram bi, ọtza orima ọvaar Devid da okhem Hadadẹzẹr k'egbong, kw'okk'Toi abẹ om-orima. Wa Joram otzim nnanga sa silva ọmaana gol, ttara brons, otzima ọtza.
\p 
\v 11 Wa ọvaar Devid otte nnanga nna ọbọhk ọnang Ọvaar Ibinọkpaabyi, mach'ọkk'ọsa ttara silva ọmaana gol p'iwa ọtzọk k'idibhon biphyir s'okk'okhema,
\v 12 sa nde ẹkhọma ch'Edom ọmaana Moab, ọmaana Ammọn, ọmaana Philistiya, ttara Amalẹk. Wa obiro otte ọgbọm f'ochi ka Hadadẹzẹr, kw'ode ọvaarnọng kwa Zoba kw'Aram, obiro ode nnwa kwa Rehob, otte ọbọhk ọnang Ibinọkpaabyi.
\p 
\v 13 Wa Devid obiro ọtza che da okhun egbong ch'orim ttara anọng p'Aram, ch'ofhu anọng p'Edom nnọhna arọbh afa obhiri nzen k'Ẹttẹri ch'Onung.
\p 
\v 14 Wa ohok agbong-nọng p'abaabh mbaakhamma s'Edom makhọra, anọng p'Edom biphyir an-awobha irekh-irek kwa Devid. Wa Ọvaar Ibinọkpaabyi ọnangi Devid ekhema k'ibe kpenamkpen s'ochin.
\s1 Akhaan-nọng pa Devid
\p 
\v 15 Wa Devid ọdabhi Israẹl makhọra, om-obiro ọttọhna aponga p'atzor-otzor abira ajibh-ojibh ọnang anọng pẹ biphyir.
\v 16 Wa Joab kw'ode nnwa kwa Zeruya wọ ode odenho kw'agbong-nọng; Jehoshaphat kw'ode nnwa kwa Ahilud ode ọkkẹri kw'idik sa ikk'itta.
\v 17 Zadọk kw'ode nnwa kw'Ahitub ọmaana Ahimẹlẹk kw'ode nnwa kw'Abiyata, bọ wa ade afọhnẹja; Sẹraya ode ọkkẹri;
\v 18 Bẹnaya kw'ode nnwa kwa Jẹhoyada wọ ode odenho kw'anọng pa Kẹrẹt ọmaana anọng pa Pẹlẹt. Va pa Devid p'ijinọng ade afọhnẹja.
\c 9
\s1 Devid ọmaana Mẹphiboshẹt
\p 
\v 1 Iwa Devid ọbọbh bi, “Ọnọng manda wani otzim orikhi k'ẹhọhmmọr cha Saul, kwa kaam mfha nsi ọphyaam nnang k'eho cha Jonatan o?”
\p 
\v 2 Wa ọkhaam ọtzọhmnọng kw'om-okkeri ẹhọhmmọr cha Saul kw'okpen Ziba, kw'iwa bẹ ayeri anang Devid. Ọvaar Devid ọbọbh-ẹ bi, “Kọ wọ akpen Ziba o?”
\p Obhina bi, “O o, kaam ọtzọhmnọng kwọ wọ e.”
\p 
\v 3 Iwa ọvaarnọng ọbọbh bi, “Ọnọng manda wani otzim orikhi k'ẹhọhmmọr cha Saul, kwa kaam mfha nsi ọphyaam f'Ibinọkpaabyi nnang o?”
\p Ziba obhina ọvaarnọng bi, “Nnwa kw'ijinọng kwa Jonatan otzim orikhi kẹ e, kẹ ọrẹkh-ọrẹkhi e.”
\p 
\v 4 Ọvaarnọng ọbọbh bi, “Owobh man?”
\p Ziba obhina bi, “Kẹ owobh ka Lo-Debar ttara Makir, nnwa kw'ijinọng kw'Amiyẹl.”
\p 
\v 5 Mẹ wọ e, ọvaar Devid ọtzọhm bẹ ka Lo-Debar k'ọhọhm kwa Makir, k'ode nnwa kw'Amiyẹl bi, bẹ atza atzim-ẹ akwu.
\p 
\v 6 Mada Mẹphiboshẹt kw'ode nnwa kw'ijinọng kwa Jonatan kwa Saul obhoni opyiri, ọrakha ọnang ọvaar Devid ikpokpobha.
\p Devid oyer-ẹ bi, “Mẹphiboshẹt!”
\p Obhina bi, “Itta kwaam, kaam ọtzọhmnọng kwọ wọ e.”
\p 
\v 7 Devid oben-ẹ bi, “Oning-ọ ojor, kaam ńsi ọphyaam nnang-ọ k'eho ch'atte Jonatan. Kaam ḿbiri mkpa nnam ndọkha irerek s'atte kw'ideden saul, biphyir ńnang-ọ, kọ am-abira achi ọchattọhk k'ọgbaakha kwaam ttara kaam, k'ogbe kpenamkpen.”
\p 
\v 8 Mẹ wọ, Mẹphiboshẹt ọrakha k'ikpokpobha, oben bi, “Kaam ọtzọhmnọng kwọ nde mach'anyi o, kw'asi ọphyaam-dema mva anang inọng-dukhi macha kaam o?”
\p 
\v 9 Mẹ wọ, ọvaarnọng oyeri Ziba kw'ode ọtzọhmnọng kwa Saul, ọgbaakh-ẹ bi, “Kaam nkk'ọttọhk kpenamkpen fa Saul kw'ode itta kwọ ọmaana ẹhọhmmọr chẹ biphyir ọbọhk ntta nnang nnwa-mmona kw'itta kwọ.
\v 10 Kọ ọmaana va pọ p'ijinọng, ọmaana atzọhmnọng pọ áyaabha owoni ánang-ẹ, ifha ọchattọhk owobha fa nnwa-mmona kw'itta kwọ óm-ochi. Mẹphiboshẹt kw'ode nnwa-mmona kw'itta kwọ óm-ochi ọchattọhk ttar-m k'okpokkoro kwaam.” (Wa Ziba ọkhaam va p'ijinọng chi, ttara atzọhmnọng ẹrọbh.)
\p 
\v 11 Iwa Ziba oben ọvaarnọng bi, “Ọtzọhmnọng kwọ ósi-osi mach'itta kwaam, kw'ode ọvaarnọng obeni.” Mẹ wọ, Mẹphiboshẹt ochi ọchattọhk k'okpokkoro ttara ọvaar Devid mach'ọvaar-nnwa kw'ijinọng.
\p 
\v 12 Iwa Mẹphiboshẹt ọkhaam ijinọnọnga kw'okpen Mika. Wa anọng p'arukhi k'ẹhọhmmọr cha Ziba biphyir ade atzọhmnọng pa Mẹphiboshẹt.
\v 13 Iwa Mẹphiboshẹt oruk ka Jẹrusalẹm; da iwa om-ochi ọchattọhk k'okpokkoro kw'ọvaarnọng. Iwa kẹ ọrẹkh-ọrẹkhi.
\c 10
\s1 Devid okhem ab'Ammọn
\p 
\v 1 Okwu opyiri k'ogbe mẹ, ọvaarnọng kw'anọng p'Ammọn okwu opẹ, nnwa kwẹ kw'ijinọng kw'okpen Hanun ọn-ọdabh ẹvaar chẹ.
\p 
\v 2 Iwa Devid oben bẹ bi, “Kaam ńsi ọphyaam nnang Hanun kw'ode nnwa kw'ijinọng kwa Nahash, mach'iwa otte osi ọphyaam ọnang-m.” Mẹ wọ, Devid ọtzọhm anọng bi bẹ atza adini Hanun nttem k'obo kw'otte. Mada atzọhmnọng pa Devid apyiri k'irerek s'Ammọn,
\v 3 adenho p'Ammọn aben Hanun kw'ode itta kwabẹ bi, “Kọ achibhi bi ikpokpobha rọ sa Devid ọkhọk k'obo kw'atte yina ọtzọhm ajinọng mba bi, bẹ adin-ọ nttem o? Kwẹ mando kode e, ọtzọhmi bẹ bi, bẹ akwu arom obhon nwa, ifha oronga nden s'otzima orima obhon nwa abẹ o?”
\v 4 Mẹ wọ, Hanun ọbọkha anọng mba pa Devid ọtzọhmi ophyiri agba-phyubha okhubha wani, obiro ọbọkha anọhma-baba pabẹ ọjaakhi m'awọriba, okhubh bẹ abhana.
\p 
\v 5 Mada Devid ọbhaang odik nwa, ọtzọhm akkaabh-nkkaabha bi bẹ atza akhebha anọng mba, da bẹ akk'bẹ ọgbasadik-barada ananga. Ọvaarnọng on-oben bi, “Bọng wobha ka Jeriko maa agba-phyubha pabọng amen yina bọng akhuna.”
\p 
\v 6 Mada anọng p'Ammọn an-are bi, bẹ akk'asa ettem epyibh Devid ttara bẹ, bẹ abher agbong-nọng p'Aram p'areng ka mmo nnọhna arọbh afa obhiri jobh, p'afon Bet-Rehob ọmaana Zoba. Wa ajinọng nnọhna mfa obhiri arọbh jobh abira afona k'ọvaarnọng kwa Maaka, nnọhna ẹrọbh obhiri jobh afona Tob.
\p 
\v 7 Mada Devid ọbhaang odik nwa, ọtzọhm Joab otzima agbong-nọng pẹ p'erima biphyir ọtza.
\v 8 Wa agbong-nọng p'Ammọn ado igbong-for, atza atzobha kẹ da adimi k'ẹbaakhamma ch'odedenmon. Agbong-nọng p'Aram kwa Zoba ọmaana Rehob, ọmaana ajinọng pa Tob ttara pa Maaka, apaangi atzobha k'ettegweng ch'ẹbaang mẹ.
\p 
\v 9 Mada Joab ore bi, bẹ akk'for ada s'egbong atzikh-ẹ k'itzitzikha ttara ka nnama-nnam, otzekha agbong-nọng akkakka p'Israẹl otzobha bẹ atza arima agbong-nọng p'Aram abẹ.
\v 10 Wa ọtzọkha agbong-nọng mbongo p'arikhi otte ọbọhk ọnang ọgbaanọkka Abishayi kw'otzobh bẹ, otzima bẹ ọtza orima agbong-nọng p'Ammọn abẹ.
\v 11 Joab oben bi, “Idikha anọng p'Aram agaangi kpọng ayọhng-m, kọ kwu kkaan-m o. Yina, idikha anọng p'Ammọn bẹ agaangi kpọng ayọhng-ọ, kaam ńkwu okwu ńkwu nkkaan-ọ.
\v 12 Kọ gaangi for morima erima nda mach'akkakkaama ka nho s'anọng paman, ọmaana ka nho s'idedenmon s'Ibinọkpaabyi kwaman. Ọvaar Ibinọkpaabyi ósi-osi mach'ojibh-ẹ ka chen.”
\p 
\v 13 Mẹ wọ, Joab ọmaana agbong-nọng pẹ afona atza arima anọng p'Aram abẹ, anọng p'Aram arọbh ma bẹ k'itzitzikha.
\v 14 Mada anọng p'Ammọn are bi anọng p'Aram am-arọbhi, bẹ arọbh aji Abishayi adim k'odedenmon. Mẹ wọ, Joab ọkwọhbha anọng p'Ammọn abẹ oririma, ọkpa nnam ọbhana ka Jẹrusalẹm.
\p 
\v 15 Mada agbong-nọng p'Aram an-are bi, agbong-nọng p'Israẹl akk'bẹ akhema, bẹ afona abira atza ado atzobha.
\v 16 Wa Hadadẹzẹr ofona ọtza ọtzọkha agbong-nọng p'Aram k'Ọraanga okhubha kwa Yupharetes, bẹ akwu apyiri k'obhon kwa Helam. Wa Shobak kw'ode odenho kw'agbong-nọng pa Hadadẹzẹr, otzima bẹ eden.
\p 
\v 17 Mada bẹ agbaakhi Devid odik nwa, otzobha anọng p'Israẹl biphyir, otzima bẹ ojekha Jọrdan ochina ka Helam. Wa anọng p'Aram abe k'adik p'egbong atzik Devid bi, ifha bẹ arim-ẹ abẹ.
\v 18 Yina, aSiriya arọbh m'itzitzikha s'anọng p'Israẹl. Wa Devid ofhu ayaar-akpaar pa nnyanyaang mmindọr anọng ẹnọhna obhiri arọbh chi, ọmaana agbong-nọng p'areng k'irerek anọng nnọhna arọbh azen. Wa obiro obun Shobak kw'ode odenho kw'agbong-nọng pabẹ ofhu.
\v 19 Mada avaar biphyir p'awobh k'irekh-irek kwa Hadadẹzẹr are bi, anọng p'Israẹl akk'bẹ akhema, bẹ afona atza asi ẹmẹm ttara anọng p'Israẹl, bẹ an-abira awobha k'irekh-irek kwabẹ.
\p Mẹ wọ e, wa ojora osi anọng p'Aram bi, bẹ abira atza anang anọng p'Ammọn ẹkkaana.
\c 11
\s1 Devid ọmaana Batshẹba
\p 
\v 1 M'ope-yaabhagbe, k'ogbe kw'avaar am-atza egbong, wa Devid ọtzọhm Joab ọmaana akhaan-nọng p'ọvaarnọng ttara anọng p'Israẹl biphyir egbong. Bẹ atza afhu anọng p'Ammọn, abira akhọri obhon kwa Raba akhe k'ottem. Yina, wa Devid owobha ka Jẹrusalẹm.
\p 
\v 2 K'ẹchọhkhawu dani, Devid obina k'ebin ọtza orenga ọkhọri ebir-ebir kw'ẹvaar-ttọhmma. Owobha kẹ ore kwanọng wani kw'om-ogbobha asi. Wa kwanọng nwuma ojibh-ojibh.
\v 3 Wa Devid ọtzọhm ọnọng bi, otza oronga ọnọng kwa kwanọng nwa ode. Ojinọng nwuma ọgbaak Devid bi, “Batshẹba kw'ode nnwa kw'ikwanọng kw'Eliyam, obiro ode kwanọng kw'Uriya kw'ofon Het wọ e.”
\v 4 Mẹ wọ, Devid ọtzọhm akkaabh-nkkaabha pẹ atza atzim-ẹ akwu. Okwu opyiri, oyim-ẹ abẹ. Yina kw'iwa kwanọng nwa ọrami ọmmaana-dik kw'awurada pa for ottotto okyera mẹ. Iwa ọkpa nnam ọbhana.
\v 5 Iwa kwanọng nwa otzima ibhọr, ọtzọhm ẹkkaabha ọnang Devid, oben bi, “Kaam nkk'ibhọr ndima e.”
\p 
\v 6 Mẹ wọ, Devid ọtzọhm ẹkkaabha ọnang Joab oben bi, “Tzọhm Uriya kw'ofon Het chen-m.” Wa Joab ọtzọhm-ẹ ochena Devid.
\v 7 Mada Uriya okhebh-ẹ, Devid ọbọbh-ẹ odem kwa Joab owobh, ọmaana odem kw'agbong-nọng awobh ttara eden ch'egbong ede.
\v 8 Mẹ wọ, Devid oben Uriya bi, “Rọhng atza agbobhi mmo k'ọhọhm kwọ.” Uriya otte ẹvaar-ttọhmma ọbọhk ofona, ọvaarnọng obiro ọtzọhm ẹnanga ochen-ẹ.
\v 9 Yina, iwa Uriya okponga mẹ ẹbaakhamma ch'ẹvaar-ttọhmma oyima ttara atzọhmnọng p'itta kwẹ, k'ọhọhm kwẹ kọtza.
\p 
\v 10 Mada bẹ agbaakhi Devid bi, “Uriya k'ọhọhm kwẹ k'ọbhan e,” Devid ọbọbh-ẹ bi, “Yina rang kw'afon k'oden-mir akwu ma o? Ode yan kw'ani k'ọhọhm kwọ abhan?”
\p 
\v 11 Uriya oben Devid bi, “Ẹkkọhbhi ch'Echekhi ọmaana anọng p'Israẹl ttara pa Juda ayim k'okhira, Joab kw'ode oho kwaam ọmaana atzọhmnọng p'itta kwaam, abhingi k'ọyaankpa. Okhuri yan kwa kaam nna mmana k'ọhọhm kwaam bi, nda nchi mbiri ngwo mbiri nyima ttara kwanọng kwaam o? Odem nwa kwa kọ arukhi akpen, kaam odik-dema nwa kinsi!”
\p 
\v 12 Mẹ wọ e, Devid on-oben-ẹ bi, “Kọ biri wobha ma mayina, ophyini kaam ńdọhm-ọ akpa nnam.” Wa Uriya owobha ma Jẹrusalẹm m'ewu nduma ọmaana ewu ch'ehobh mẹ.
\v 13 Devid oyer-ẹ okwu ochi ọchattọhk obiro agwo atzuk ttar-ẹ. Iwa Devid ọnang-ẹ atzuk maa obuma. Yina, m'ẹchọhkha, Uriya oyin k'iyaan otza oyima k'obhirikpa kwẹ, k'ottem kw'atzọhmnọng p'itta kwẹ; k'ọhọhm kwẹ kọbhan.
\p 
\v 14 K'ekpebha, Devid ọkkẹr ẹkkaabha k'ẹnwẹrkpa ọnang Uriya bi, ochena Joab.
\v 15 Ọkkẹri m'ẹnwẹrkpa nduma bi, “Hok Uriya k'itzitzikha s'egbong, kw'erima ẹkhọhm-ọkhọhm. Atzọr akpa nnam ifha bẹ abun-ẹ afhu, ope.”
\p 
\v 16 Mẹ wọ, mada Joab okk'odedenmon ọkhọri okhe k'ottem, ọtzọkha Uriya ohok k'ibe s'orong bi akkakkaama p'attattaanga-nọng pabẹ awobh.
\v 17 Mada ajinọng p'odedenmon nwuma ayini k'iyaan bi, bẹ akwu arima Joab abẹ, wa bẹ afhu agbong-nọng bani pa Devid. Ayongi mẹ, wa Uriya kw'ofon Het obiro ope.
\p 
\v 18 Iwa Joab ọtzọhm Devid ẹkkaabha ch'odik kpenamkpen kw'otto k'egbong-dam.
\v 19 Oben ọkkaabh-ẹkkaabha bi, “Idikha akk'ọvaarnọng odem kw'egbong ede agbaakha okpo,
\v 20 ọvaarnọng ọfha ọdọkh-ẹ, ọbọbh-ọ bi, ‘Okhuri yan kwa bọng atza arima egbong abaanga k'odedenmon o? Ode bi bọng karong bi, bẹ afha awobha k'echumiho atta ayukh o?
\v 21 Anyi wọ ofhu Abimẹlẹk kw'ode nnwa kw'ijinọng kwa Jerub-Bẹshẹt? Kwanọng arang owobh k'echumiho obingi ẹtzakpa ch'ẹfhẹ-ẹ ka Tẹbẹz o? Okhuri yan kwa bọng areng abaanga k'echum o?’ Idikha ọbọbh-ọ idik nna, kọ gbaakh-ẹ bi, ‘Ayongi mẹ, ọtzọhmnọng kwọ Uriya kw'ofon Het obiro ope e.’ ”
\p 
\v 22 Mẹ wọ e, ọkkaabh-ẹkkaabha nwuma obina ofona, mada opyiri, ọtzọkha odik kpenamkpen kwa Joab ọkk'ẹ ọtzọhma, ọgbaak Devid.
\v 23 Ọkkaabh-ẹkkaabha nwuma oben Devid bi, “Ajinọng mbuma ayọhng man mkpaan, bẹ ayini k'iyaan akwu arima man abẹ k'ọyaankpa. Yina, mokhubhi bẹ maa bẹ akpa nnam k'ẹbaakhamma ch'odedenmon.
\v 24 Mẹ wọ kw'atta-ayuk awobh k'echumiho atta atzọhmnọng pọ ayuk, ofona mẹ, atzọhmnọng bani p'ọvaarnọng ape. Ayongi mẹ, ọtzọhmnọng kwọ Uriya kw'ofon Het ọkk'ọpa.”
\p 
\v 25 Devid e, oben ọkkaabh-ẹkkaabha nwa bi, “Ben Joab bi, ‘Odik nwa oning-ọ ottem-pyibha ọnangi; ọkkangkkaang kw'ofhu ọnọng, óbiro ofhu ọnọng ọdọdọk. Tte ochina ororo orima odedenmon nwa abẹ obiro odim-ẹ.’ Kọ gbaak odik nwa atzim akhe Joab ẹfa.”
\p 
\v 26 Mada kwanọng kw'Uriya ọbhaang bi odim kwẹ ọkk'ọpa, owobha epopa ch'odim.
\v 27 Mada ogbe kw'epopa ottong, Devid e, ọtza ọtzọkh-ẹ otzima ochina k'ọhọhm kwẹ, on-ode kwanọng kwẹ, ọmaan-ẹ nnwa kw'ijinọng. Yina, odik nwuma kwa Devid ọkk'ọsa, Ọvaar Ibinọkpaabyi ettem kọdaami.
\c 12
\s1 Natan opyim Devid k'osisi kwẹ
\p 
\v 1 Iwa Ọvaar Ibinọkpaabyi ọtzọhm Natan ọtza okhebha Devid. Mada okhebh-ẹ, oben bi, “Iwa ọkhaam ajinọng afa p'afon k'obhon wani, oyok wani ode ọkkakkaa, nwonggo ode ogbogbora.
\v 2 Ọkkakkaa nwa ọkhaam arukhimaan ọmaana abhaam k'ọhaabh.
\v 3 Yina, ogbogbora ọttọhk kọkhaam, kw'oyongi orukhimaan-nwa-kwakwẹ kẹ-khẹ kw'okk'odebha. Ọrọkh-ẹ maa, orukhimaan-nwa nwa ọbar ọmaana va p'ojinọng nwa. Orukhimaan nwa om-ochi ọchattọhk ttara ojinọng nwa, om-obiro ogwo asi ka nkọbh kw'ojinọng nwa, obiro ọttaabh-ẹ ka mbọhk. Wa orukhimaan-nwa nwa on-ode macha nnwa kw'ikwanọng ọnang-ẹ.
\p 
\v 4 “Iwa okhekhen-nọng wani okwu ọhakha ọkkakkaa nwa, yina, ọkkakkaa nwa obhum bi ọtzọkha arukhimaan pẹ, obiro ode abhaam pẹ bi, otzima osi ọchattọhk ọtzaam okhekhen-nọng kw'ọkk'ẹ ọhakha. Ottu kw'osi mando, ọn-ọtza ọtzọkha orukhimaan-nwa-kwakwẹ kw'ogbogbora otzima osi ọchattọhk ọtzaam okhekhen-nọng kw'ọkk'ẹ ọhakha.”
\p 
\v 5 Odik nwuma ọdọkhi Devid maa, oben Natan bi, “Odem nwa kw'Ọvaar Ibinọkpaabyi orukhi akpen, ojinọng kw'osi odik-dema nwa ọbaan bi ope!
\v 6 Kẹ ọkhaambi otzuk orukhimaan nwa k'igbe inna, okhuri bi, inọngkwo kọkhaam m'odik nwa.”
\p 
\v 7 Mẹ wọ, Natan oben Devid bi, “Kọ wọ ade ojinọng nwuma! Ma wọ ode odik kw'Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'Israẹl ọgbaakhi: ‘Kaam mbyeng-ọ ana k'eho, nsọ-ọ ọvaarnọng kw'Israẹl. Mbiri nkkaan-ọ nnọbh-ọ ka mbọhk sa Saul.
\v 8 Kaam ndọk ẹhọhmmọr ch'itta kwọ nnang-ọ, mbiri ndọkha panọng pẹ nnang-ọ. Nsọ-ọ ọvaarnọng kw'Israẹl ọmaana kwa Juda. Idikha ira idik nna in-ihaabhi, kaam ira nnang-ọ nyongi mẹ.
\v 9 Ode yan kwa kọ abhumi atzim p'Ọvaar Ibinọkpaabyi bi, kọ asi obibya-dik-dema nwa k'itzitzikha sẹ o? Kọ atzim ọkkangkkaang afhu Uriya kw'ofon Het, abira atzọkha kwanọng kwẹ aba. Kọ atzim ọkkangkkaang kw'anọng p'Ammọn afhẹ-ẹ.
\v 10 Kẹ wọ osi, ọkkangkkaang ẹhọhmmọr chọ ọbọhk kótte, okhuri da kọ abhumi atzim paam, afona atza atzọkha kwanọng kw'Uriya kw'ofon Het aba.’
\p 
\v 11 “Ma wọ ode odik kw'Ọvaar Ibinọkpaabyi obeni: ‘Kaam ńdọhm itzama s'ítto ikhebh-ọ k'ẹhọhmmọr chọ. Kọ atzima chen pọ are da ńdọkha panọng pọ nnang oyokh-ẹbaanga kwọ, kẹ óyima panọng pọ abẹ k'ọyaankpa.
\v 12 Kọ asi odik nwa ka ndubhama, yina, kaam ńna nsi kwẹ k'ọyaankpa k'itzitzikha s'anọng p'Israẹl biphyir.’ ”
\p 
\v 13 Mẹ wọ, Devid oben Natan bi, “Kaam nkk'ẹkhọhngkwuri nsa k'itzitzikha s'Ọvaar Ibinọkpaabyi.”
\p Natan obhina bi, “Ọvaar Ibinọkpaabyi ọkk'ọ obina ọnang k'ẹkhọngkwuri chọ. Kọ kápe.
\v 14 Yina, okhuri da akk'asa bi attattaanga-nọng p'Ọvaar Ibinọkpaabyi alukh-ẹ, nnwa nwuma kw'ijinọng kwa bẹ amaani anang-ọ, ópe-ope.”
\p 
\v 15 Mada Natan okk'nnam ọkpa ọbhana k'ọhọhm kwẹ, Ọvaar Ibinọkpaabyi osi nnwa nwuma kwa kwanọng kw'Uriya ọkk'ọmaana ọnang Devid, otto ọkhọhmana.
\v 16 Wa Devid okhukhi Ibinọkpaabyi okhuri nnwa nwa. Otzim ọchattọhk obiro ọfọra abara-bina oyima k'irerek m'erungiwu nduma.
\v 17 Wa adedennọng pẹ am-akhonga bi abọhkh-ẹ obina k'irerek, yina, obhum bi obina. Obiro obhum bi ochi ọchattọhk kpenamkpen ttara bẹ.
\p 
\v 18 Ottong iwu izenamfa nnwa nwuma ope. Wa akhaan-nọng pa Devid ojor bẹ ojora bi, bẹ agbaakh-ẹ bi, nnwa nwa ọkk'ọpa, da bẹ achibhi bi, “K'ogbe kw'iwa nnwa nwa otzim orukhi akpen, idikha mọgbaakhi Devid atzim, man itzọhng kokher bi oyonga. Morenga yan ọgbaakh-ẹ bi, nnwa nwuma ọkk'ọpa o? Kẹ ofha osi odik-ttama, ọnang fọr sẹ.”
\p 
\v 19 Mada Devid ore da akhaan-nọng pẹ an-am-akkaabha ayok iyaabhi, otzin bi nnwa nwuma ọkk'ọpa. Mẹ wọ, ọbọbh bi, “Nnwa nwuma ọkk'ọpa?”
\p Bẹ abhina bi, “O o, ọkk'ọpa e.”
\p 
\v 20 Mẹ wọ, Devid obina k'irerek. Mada okk'asi ogbobha obiro ọkpan ana, obhona ẹnya, obina ochina k'ọhọhm kw'Ọvaar Ibinọkpaabyi, ọtza okpobh-ẹ. Yina on-ochin k'ọhọhm kwẹ, oben bẹ anang-ẹ ọchattọhk, ochi.
\p 
\v 21 Akhaan-nọng pẹ abọbh-ẹ bi, “Kọ am-asi yan ma o? K'ogbe kw'iwa nnwa nwa otzim orukhi akpen, atzimi ọchattọhk abira awobha k'obhoma, mada nnwa nwa ọkk'ọn-ọpa, an-abina achi ọttọhk!”
\p 
\v 22 Obhina bi, “K'ogbe kw'iwa nnwa nwa otzim orukhi akpen, kaam ndimi ọchattọhk nwobha k'obhoma. Iwa nchibhi bi, ‘K'odik-ọkka, Ọvaar Ibinọkpaabyi ọfha ọkhaama inọngkwo ttar-m, otte nnwa nwa ọbọhk oruk akpen.’
\v 23 Yina, mada ọkk'ọn-ọpa, kaam nna nchina ororo ndim ọchattọhk fa mbọng o? Na kaam mfha ndima akpen pẹ mkpa nnam o? Kaam wọ nder ńgebha kẹ kẹ e, kẹ arang obiro ọkpa nnam okhebh-m ka e!”
\s1 Ẹmmaana cha Sọlọmọn
\p 
\v 24 Mẹ wọ, Devid odini kwanọng kwẹ Batshẹba nttem, otza oyim-ẹ abẹ, otzima ibhọr, ọmaan-ẹ nnwa kw'ijinọng, bẹ akpẹ-ẹ Sọlọmọn. Nnwa nwa ọdaak Ọvaar Ibinọkpaabyi;
\v 25 okhuri idadaakha nnuma, Ọvaar Ibinọkpaabyi ọtzọhm Natan, kw'ode ọsẹjaakhi ọtza sẹ che ọkpẹ-ẹ, Jedidiya\f + \fr 12.25 \ft K'eHiburu, che cha Jedidiya eyini, kẹ ọdaakhi Ọvaar Ibinọkpaabyi.\f*.
\p 
\v 26 M'ogbe nwuma wa Joab orim egbong ttara obhon kwa Raba kw'ode kw'anọng p'Ammọn, obiro ọbọkha ọvaarbhon kwabẹ otzima.
\v 27 Iwa Joab ọtzọhm akkaabh-nkkaabha atza akhebha Devid aben bi, “Kaam nkk'Raba abẹ nnima, mbiri ndọkha odedenmon kw'asi pẹ.
\v 28 Bọng dobha agbong-nọng p'arikhi, akhọri odedenmon nwa akhe k'ottem, bọng abira abọkh-ẹ atzima. Oni mando ode, kaam mbọkha odedenmon nwa ndima, mkpẹ-ẹ che mmina kaam.”
\p 
\v 29 Mando kwa Devid otzobh agbong-nọng biphyir otzima ochina ka Raba, orima bẹ abẹ maa okhema bẹ.
\v 30 Wa ọwọra ọvaarnọng kwabẹ ivaar-kpo k'eho, bẹ atzọkha fọr-ẹ. Ivaar-kpo nna idọhbhi ipyiri talẹn wani kwa gol, bẹ abira dokha sẹ ttara atza ọkkakka. Wa Devid obiro ochi ọgbọm k'ọhaabh m'odedenmon nwuma.
\v 31 Ọtzọkha anọng p'awobh mẹ ọnang itzọhm sa bẹ atzim ọkkaangi ọmaana s'akkonga, ọmaana s'ochitzọhkhi ttara sa mbar asi, obiro osi bẹ asi ọtzọhm f'idọdọhbh ọbabanga. Wa Devid osi odik nwa k'ibhon s'anọng p'Ammọn biphyir. Mẹ wọ e, kẹ Devid ọmaana agbong-nọng pẹ biphyir akpa nnam abhana ka Jẹrusalẹm.
\c 13
\s1 Amnọn ọmaana Tamar
\p 
\v 1 Iwa Absalọm kw'ode nnwa kw'ijinọng kwa Devid ọkhaam ọgbaanọkka kw'ikwanọng kw'ojobh-ojibh kw'okpen Tama. Wa k'ogbe wani, Amnọn kw'ode nnwa kwa Devid okwu ọkhaama idadaakha ttara Tamar.
\p 
\v 2 Iwa Amnọn otto ọkhọhmana okhuri da okhe ettem chẹ k'ọgbaanotte Tama. Wa Tama ojinọng otzim oronga, kw'osi Amnọn ore kwẹ bi, ode odik kw'ọgaang-ẹ ọgaangi bi, oyim-ẹ abẹ.
\p 
\v 3 Yina, wa Amnọn ọkhaam oyokh-odikkobh kw'okpen Jonadab, kw'ode nnwa kw'ijinọng kwa Shimeyi, kw'ode ọgbaanọtte kwa Devid. Jonadab kẹ wa ode ojinọng kw'odongi-odongi.
\v 4 Ọbọbh Amnọn bi, “Ode yan kwa kọ nnwa kw'ọvaarnọng, am-akkeri idọdọkhi-idọdọkhi ekpebha kpenamkpen manda o? Gbaak-m odik.”
\p Amnọn obhin-ẹ bi, “Tama kw'ode ọgbaanọkka kw'Absalọm kwa mode ọgbaanotte ọkk'aam ọdaakha e.”
\p 
\v 5 Jonadab oben bi, “Rọhng atza ayima k'ebin asi nkkari bi, ọmmọ-ọ ọmma. Mada isa atte okwu bi ọrọ-ọ ben-ẹ bi, ‘Kaam ira ọdaakh-m bi ọgbaanotte kwaam Tama okwu osi ọchattọhk ọnang-m e. Tte owobha m'itzitzikha saam osi ọchattọhk mva, ifha nnẹ-ẹ mbiri nchi fẹ ma mbọhk sẹ.’ ”
\p 
\v 6 Mẹ wọ, Amnọn osi nkkari otza oyima mach'ọmmẹ-ẹ ọmma. Mada ọvaar Devid okwu bi ọrẹ-ẹ, Amnọn oben-ẹ bi, “Kaam ira ọdaakh-m bi, ọgbaanotte kwaam Tama okwu osi ọchattọhk f'ọm-ọdaakh-m m'itzitzikha ọnang-m, ifha oreng-mmo ọyọkh-m fẹ.”
\p 
\v 7 Iwa Devid ọtzọhm bẹ ayeri Tama k'ẹvaar-ttọhmma, oben-ẹ bi, “Rọhng k'ọhọhm kw'agbaanatte Amnọn, atza asi ọchattọhk anang-ẹ.”
\v 8 Mando kwa Tama obin ochina k'ọhọhm kw'ọgbaanotte Amnọn, kw'okhebh da oyim k'ebin. Tama ọtzọkha abubuma ọbhakhi otzima osi brẹd m'itzitzikha sẹ.
\v 9 Ọtzọkha brẹd nwa okhe k'ikkoriya otza ober-ẹ, yina, obhum ochichi.
\p Amnọn on-oben bi, “Bọng ben ọnọng kpenamkpen oyin k'iyaan.” Mẹ wọ, ọnọng kpenamkpen obina oyin k'iyaan.
\v 10 Amnọn e oben Tama bi, “Tzini ọchattọhk mvuma achen-m k'ẹmaanggọ chaam, ifha areng-mmo ọyọkh-m fẹ.” Tama otzini brẹd nwa kw'ọkk'ọsa otzima odim k'ẹmaanggọ ch'ọgbaanotte, Amnọn.
\v 11 Yina, mada otzini ochattọhk mvuma ochen-ẹ bi ochi, ọkhaabh-ẹ, oben bi, “Ọgbaanotte kwaam, vura k'ebin, akwu mọtzọn oyima.”
\p 
\v 12 Oben-ẹ bi, “Mma e, ọgbaanotte kwaam! Kaam k'ẹfa kàbọkha ayima abẹ! Anọng odik-dema nwa k'Israẹl atzima abhaanga o! Odik-ttama-dema nwa kàsi.
\v 13 Kaam ọmaana kọ móruk yan ttara ọgbasa-dik nwa o? Kọ an-ade mach'odidingi-nọng wani m'Israẹl e. Tzotzokhaan, gbaak ọvaarnọng, kẹ kọ eden kọkpa bi, atzọkh-m k'ọbada.”
\v 14 Kaambi mẹ wọ, itzọhng koyong ọnang-ẹ, ọbọkh-ẹ oyima abẹ k'ẹfa, okhuri da ọkhaam ẹfa ọyọhng-ẹ.
\p 
\v 15 Mẹ wọ, Amnọn ọn-ọttaang-ẹ itzam-itzama. K'odik-ọkka, wa ọn-ọttaang-ẹ maa ọyọhnga eden ch'iwa ọdaakh-ẹ. Amnọn on-oben-ẹ bi, “Bina ayin k'iyaan afona!”
\p 
\v 16 Tamar oben-ẹ bi, “Mma e! Akhubh-m okhubh, mẹ wọ on-opyibhi ọtzam ọyọhnga odik kw'akk'aam atzama asa e.”
\p Kaambi mẹ wọ, Amnọn itzọhng koyong ọnang-ẹ.
\v 17 On-oyeri ọtzọhmnọng kwẹ oben bi, “Tzima kwanọng nwa ayin k'iyaan, agbakh-ẹ ọmma!”
\v 18 Mando kw'ọtzọhmnọng kwẹ ọbhar-ẹ k'iyaan, ọgbakh-ẹ ọmma. Wa Tamar ọfọr owura-baba kw'ọgaangi ẹphya, kw'ode owura-baba kw'iwa aminava p'ọvaarnọng p'ani ojinọng atzim aronga am-afọra.
\v 19 Tama ọtza okpokhi itzọtzọhng obum-ẹ k'eho, ọbọkha owura-baba kw'ọfọr ka for ọjaakhi. Otzini mbọhk ọtzọhkha k'eho, obhom k'ẹrọng ofona.
\p 
\v 20 Ọgbaanọkka Absalọm ọbọbh-ẹ bi, “Agbaanatte Amnọn, ọkk'ọ abẹ oyima? Ọgbaanọkka kwaam, dọk kàbhom; kẹ ode ọgbaanotte kwọ e. Odik nwa k'ettem kàkhe.” Tama on-oruk ttara nkwu-osisi k'ọhọhm kw'ọgbaanọkka, Absalọm.
\p 
\v 21 Mada ọvaar Devid ọbhaang idik nna, ettem epyibh-ẹ.
\v 22 Absalọm odik manda wani kw'ojibh-ojibh obiro opyibh-opyibh kw'okhuri odik nwa, kọgbaakhi ọnang Amnọn. Yina, ọttaanga Amnọn k'ọgbarsadik kw'ọkk'ọsa ọnang ọgbaanọkka, Tama.
\s1 Absalọm ofhu Amnọn
\p 
\v 23 Mada cho afa akk'akwọbha, k'ogbe kw'atzọhmnọng p'Absalọm p'am-aphyiri arukhimaan ophyubha awobh ka Baal-Hazọr, kẹ ọbaanga Ephraim, wa Absalọm obher va p'ijinọng biphyir p'ọvaarnọng m'ẹrọm nduma.
\v 24 Mẹ wọ, Absalọm ofona ọtza okhebha ọvaarnọng oben bi, “Atzọhmnọng paam am-aphyiri arukhimaan ophyubha. Tzotzokhaan, tte ọvaarnọng ọmaana akhaan-nọng pẹ akwu awobha ttar-m!”
\p 
\v 25 Ọvaarnọng oben bi, “Mma e, nnwa kwaam, tte man biphyir oningi ọtza e. Kwẹ ọdọhbh-ọ kpọng e.” Chibhi da Absalọm ọgban-ẹ, kokher bi ọtza, yina, okhinggẹ ọsẹ-ẹ ittabọhng.
\p 
\v 26 Mẹ wọ, Absalọm oben bi, “Idikha an-afha akwu, tzotzokhaan, tte ọgbaanotte kwaam Amnọn ọbọhk ọtzọn man abẹ.”
\p Ọvaarnọng ọbọbh-ẹ bi, “Ka yan kwa kẹ ọtzọn-ọ abẹ o?”
\v 27 Yina, Absalọm ochina ororo ọgban-ẹ maa, ọvaarnọng otte Amnọn ọmaana va mbonggo p'ijinọng ọbọhk, bẹ atzọn Absalọm abẹ, afona.
\p 
\v 28 Mada bẹ apyiri kẹ, Absalọm oben atzọhmnọng pẹ bi, “Bọng yonga itzọhng! Mada isa atzuk asi ettem ẹdaam Amnọn, mbeni bọng bi, ‘Bọng fhu Amnọn,’ bọng afhẹ-ẹ, oningi bọng ojor. Kaam wọ nnangi bọng ẹfa. Bọng bar ettem asi ejinọng.”
\v 29 Wa atzọhmnọng p'Absalọm asi Amnọn mach'okk'bẹ ẹfa ọnanga. Mẹ wọ e, va p'ijinọng biphyir p'ọvaarnọng abina atza avura nnyanyaang sabẹ arọbh afona.
\p 
\v 30 Mada bẹ am-arenga k'eden, ẹkkaabha epyiri Devid bi, “Absalọm okk'va p'ijinọng biphyir p'ọvaarnọng ọfha, ọnọng manda wani korikhi.”
\v 31 Ọvaarnọng obina obe, ọjaakhi ẹnya ch'ọfọr obiro oyima k'irerek; akhaan-nọng pẹ biphyir ajaakhi nnya sa bẹ fọr abira awobha mẹ ttar-ẹ.
\p 
\v 32 Yina, Jonadab kw'ode nnwa kw'ijinọng kwa Shimeyi, kw'ode ọgbaanotte kwa Devid oben bi, “Itta kwaam oningi ọtzọk bi, bẹ afhu avaar-va p'ijinọng biphyir; Amnọn kẹ-khẹ wọ ope e. Ode ochibhi kw'Absalọm ọkk'ọtzam ọkhaama, ttẹwọr k'ewu ch'Amnọn oyim ọgbaanọkka Tama abẹ k'ẹfa e.
\v 33 Itta ọvaarnọng kwaam, ettem ening-ọ atzim ẹyakhi k'ẹkkaabha ch'epyir-ọ bi, avaar-va p'ijinọng biphyir akk'apa e. Amnọn kẹ-khẹ wọ ope.”
\p 
\v 34 Ayongi mẹ, Absalọm ọkk'ọrọbha.
\p Mada ojinọng kw'om-okkeri ibe otzini chen okkeri k'ororo, ore anọng k'ọhaabh k'eden k'okhubha kw'ewuchen em-edimi, p'am-ahakha k'egbegbeho ọkhaan-ọkhaan. Okker-ibe nwa ofona ọtza ọgbaak ọvaarnọng bi, “Nne ajinọng k'okhubha kwa Horonayim k'egbegbeho ọkhaan-ọkhaan e.”
\p 
\v 35 Jonadab oben ọvaarnọng bi, “Kker e, va p'ijinọng p'ọvaarnọng akk'akwa e; kwẹ ọkk'ọda macha kaam ọtzọhmnọng kwọ, mbeni.”
\p 
\v 36 Okyer atzim ọgbagbaak mẹ, va p'ijinọng p'ọvaarnọng apyiri ttara obhoma k'ẹrọng. Wa ọvaarnọng ọmaana akhaan-nọng pẹ biphyir abira abhom k'idọdọhkhi.
\p 
\v 37 Wa Absalọm ọrọbhi ochina ka Talmayi kw'ode nnwa kw'ijinọng kw'Amihud, kw'ode ọvaarnọng kwa Geshur. Yina, wa ọvaar Devid owobha ka nkwu-osisi s'obo kwa nnwa kwẹ Amnọn, k'ewu kpenamkpen.
\p 
\v 38 Mada Absalọm ọrọbhi ochina ka Geshur, wa owobh kẹ ka cho attaan.
\v 39 Wa ọvaar Devid odini for sẹ nttem k'obo kw'Amnọn, obiro ọdaakh-ẹ bi, ira ore Absalọm.
\c 14
\s1 Absalọm ọkpa nnam ka Jẹrusalẹm
\p 
\v 1 Iwa Joab kw'ode nnwa kwa Zeruya, orong bi, ettem ch'ọvaarnọng ẹgban k'Absalọm.
\v 2 Mẹ wọ, iwa Joab ọtzọhm ọnọng k'obhon kwa Tẹkoa, bẹ atza atzọkha kwanọng wani kw'odongi-odongi atzima akwu. Wa Joab oben-ẹ bi, “Kọ si nkkari bi awobh epopa. Afọra abara-bina. Ana manda bani kàkpan. Si mach'ọnọng kw'okk'epopa owobha k'iwu-haabhada.
\v 3 Rọhng k'ọvaarnọng atza agbaakh-ẹ atzim mba.” Wa Joab, ọtzaakh-ẹ atzim p'ọtza ọgbaak.
\p 
\v 4 Mada kwanọng nwa kw'ofon Tẹkoa ọgbaakhi ọvaarnọng atzim, ọrakha ottima itzitzikha m'irerek ọnang ọvaarnọng ikpokpobha, oben bi, “Ọvaarnọng, kkaan-m e!”
\p 
\v 5 Ọvaarnọng ọbọbh-ẹ bi, “Mbọng vọ ode odik kw'ọyakh-ọ atzim?”
\p Kwanọng nwa oben bi, “Kaam nde opopa-kwanọng, da odim kwaam ọkk'ọpa e.
\v 6 Kaam ọtzọhmnọng kwọ, ngaam va afa p'ijinọng. Wa bẹ akwu arima ayok abẹ k'owoni, k'ogbe kw'ọnọng on'ode kw'ọkkaan bẹ erima. Wa oyok wani obun oyok ofhu.
\v 7 Mẹ wọ, efona chaam biphyir ẹkk'ẹttaanga ẹnang ọtzọhmnọng kwọ. Bẹ am-aben-m bi, ‘Nang man oyok kw'ofhu ọgbaanọkka, ifha mọfhẹ-ẹ, k'akpen p'ọgbaanọkka p'odimi, kaambi ode bi, modimi ọnọng kw'ọbaan k'ebocha.’ Ma, bẹ an-adimi akpen pa nnwa wani kẹ-khẹ kw'orikh-m. Bẹ abira adimi odim kwaam che, ọmaana ẹhọhmmọr chẹ m'ọyagbin.”
\p 
\v 8 Iwa ọvaarnọng oben kwanọng nwa bi, “Rọhng abhana, kaam ńsi ẹmọng osi m'odik nwa.”
\p 
\v 9 Kaambi mẹ wọ, kwanọng nwa kw'ofon Tẹkoa oben-ẹ bi, “Tte itta ọvaarnọng kwaam, obina ọnang kaam ọmaana ẹhọhmmọr ch'otte kwaam. Tte ọvaarnọng ọmaana ẹvaar chẹ, bẹ aningi oponga-pyibha atzọk.”
\p 
\v 10 Ọvaarnọng obhina bi, “Idikha ọnọng manda wani ọyakh-ọ atzim, kọ tzim-ẹ akwu. Kẹ kọ ọttọhk kósi.”
\p 
\v 11 Kwanọng nwa obhina bi, “Tte ọvaarnọng ochekhi ka che ch'Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwẹ bi, kẹ ọnọng manda wani ọbọhk kotte bi, otzukha ẹnọngmon-barada nda, ifha bẹ aningi akpen pa nwa kwaam adimi.”
\p Ọvaarnọng obhina bi, “Da Ọvaar Ibinọkpaabyi orukhi akpen, esisa-naanga cha nnwa kwọ ch'etto k'irerek kede.”
\p 
\v 12 Mẹ wọ, kwanọng nwa oben bi, “Tte kaam ọtzọhmnọng kwọ mgbaak atzim nnang itta ọvaarnọng kwaam.”
\p Ọvaarnọng obhin-ẹ bi, “Kọ gbaak.”
\p 
\v 13 Kwanọng nwa on-oben bi, “Okhuri yan kwa kọ aphaari itzama-dema nna atzima atzor anọng p'Ibinọkpaabyi o?” Idikha ọvaarnọng ọgbaakhi odik-dema nwa, for sẹ arang s'ọbhakhi opyima ma o, da ọvaarnọng oni nnwa kwẹ kw'okhubhi, otzim-otzima ọkpa nnam o?
\v 14 Mọkhaambi ope mach'asi abyengi k'irerek, p'ọnọng oni dọk ọfha otzima ọkpa nnam. Ochibhi kw'Ibinọkpaabyi mando kode. Yina, kẹ om-otzer ohok aphaangi bi, ọnọng kwa bẹ akk'akhubha ofona, obiro orenga mẹ ọkpa nnam otzor-ẹ.
\p 
\v 15 “Kaam nkk'nkwa bi, nkwu mgbaak itta ọvaarnọng kwaam odik nwa, okhuri bi, anọng mba akk'asa bi ojor-m. Ọtzọhmnọng kwọ okk'ochibhi bi, ‘Kaam ḿgbaak itta ọvaarnọng kwaam atzim, asi mẹ, kẹ ósi-osi otzor k'ephyema ch'ọtzọhmnọng kwẹ.
\v 16 Asi mẹ, ọvaarnọng okher-okhera bi, ọkkaana ọrọbha ọtzọhmnọng kwẹ ka mbọhk s'ojinọng kw'om-okhonga bi, odimi ekkema cha kaam ọmaana nnwa kwaam ch'Ibinọkpaabyi ọnangi man.’
\p 
\v 17 “Kẹ wọ osi ọtzọhmnọng kwọ oben bi, ‘Tte atzim p'itta ọvaarnọng kwaam anang-m ẹwọhng-kwokha, da itta ọvaarnọng kwaam, ode mach'orenga-eden kw'Ibinọkpaabyi kw'orong ejibha ọmaana epyibha. Tte ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwọ, owobha ttar-ọ.’ ”
\p 
\v 18 Mẹ wọ, ọvaarnọng e oben kwaanọng nwa bi, “Kaam ebhina ch'odik kwa ḿbọbh-ọ ma, kàdubha.”
\p Kwanọng nwa oben bi, “Tte itta ọvaarnọng kwaam, ọbọbh.”
\p 
\v 19 Ọvaarnọng ọbọbh bi, “Kachibhi bi, ọbọhk kwa Joab owobh m'odik nwa?”
\p Kwanọng nwa obhina bi, “Da kọ itta ọvaarnọng kwaam arukhi akpen, ọnọng manda wani kw'ósi odik ngọmi oyongi kw'itta ọvaarnọng kwaam ọgbaakhi kode. Ode mando bi, ọtzọhmnọng kwọ Joab wọ ọtzọhn-m bi, nsi odik nwa. Kẹ wọ obiro ọtzaakhi kaam ọtzọhmnọng kwọ atzim mba biphyir.
\v 20 Wa Joab kw'ode ọtzọhmnọng kwọ osi odik nwa, ifha otzima ọbhakhi idik ewobha. Itta kwaam ọkhaam ekkoji mach'orenga-eden kw'Ibinọkpaabyi, kẹ orong odik kpenamkpen kw'otto m'irerek nna.”
\p 
\v 21 Mẹ wọ, ọvaarnọng oben Joab bi, “Ojibhi kẹ, kaam ńsi-osi mando. Kọ rọhng atza atzima Absalọm, kw'ode odikkobh akpa nnam.”
\p 
\v 22 Joab otto okhubha itzitzikha sẹ m'irerek ọnang-ẹ ikpokpobha, obiro odo ọvaarnọng. Joab oben bi, “Kaam ọtzọhmnọng kwọ nkk'nnonga bi, nkk'ọphyaam ndọkha k'itzitzikha s'itta ọvaarnọng kwaam mayina e, okhuri da, ọvaarnọng ọkk'ọtzọhmnọng kwẹ ephyema chẹ ọnanga.”
\p 
\v 23 Mẹ wọ, Joab ofona ochina ka Geshur ọtza ọtzọkha Absalọm otzima ọkpa nnam ka Jẹrusalẹm.
\v 24 Yina, ọvaarnọng oben bi, “Kẹ ọkhaambi ochina k'ọhọhm kwẹ. Kọkhaambi ore itzitzikha saam.” Mando kw'iwa Absalọm ọkpa nnam ochina k'ọhọhm kwẹ, itzitzikha s'ọvaarnọng kore.
\p 
\v 25 Iwa k'Israẹl biphyir ojinọng kwa bẹ atzọhng k'ajibhada mach'Absalọm kode. Ttẹwọr k'eho maa ahakha ka mmokpatzọkhi sẹ, enyu kọkhaam.
\v 26 Iwa kẹ om-ophyiri isisa s'eho chẹ, da cho ọn-ọha, okhuri da sẹ im-idọhbh-ẹ ọdọhbh. Ogbe kpenamkpen kw'ophyiri isisa sẹ, edọhbh ch'isisa sẹ im-ipyiri ashẹkẹl arọbh jobh, atzor k'odem kwa bẹ am-ayoma ẹdọhbh ch'ekpo k'ọvaar-họhm.
\p 
\v 27 Iwa Absalọm obhoni va p'ijinọng attaan ọmaana nnwa kw'ikwanọng. Wa nnwa kw'ikwanọng okpen Tamar, ojibh kwanọng.
\p 
\v 28 Iwa Absalọm orukhi ka Jẹrusalẹm cho afa, yina, itzitzikha s'ọvaarnọng kọfha ore.
\v 29 Absalọm ọtzọhm bi, bẹ ayeri Joab anang-ẹ, ifha ọtzọhm-ẹ k'ọvaarnọng. Yina, Joab obhum eyeri nduma. Absalọm obiro ọtzọhm ottong igbe ifa bi, bẹ ayer-ẹ, obiro obhum eyeri nduma.
\v 30 Mando kw'obeni atzọhmnọng pẹ bi, “Bọng kker e, owoni kwa Joab kw'owobh ọbaanga kwaam, ọkhaam abarli. Bọng nọhng atza akwọm-ẹ.” Mando kw'atzọhmnọng p'Absalọm akwọmi owoni kwa Joab.
\p 
\v 31 Joab ofona ọtza okhebha Absalọm oben-ẹ bi, “Okhuri yan kw'atzọhmnọng pọ atza akwọmi owoni kwaam o?”
\p 
\v 32 Absalọm oben Joab bi, “Kker e, kaam ndọhmi ẹkkaabha, mben bi, ‘Kwu ifha ndọhm-ọ atza abọbh ọvaarnọng bi, okhuri yan kwa kaam mfon ka Geshur ngwuna ma o? Ira ojibh ọtzam ọnang-m bi, nwobh ka Geshur!’ Ma, kaam nna nnori bi nne itzitzikha s'ọvaarnọng e. Idikha ngaam oponga-pyibha manda wani kẹ, tte kẹ ofhu-m e.”
\p 
\v 33 Mẹ wọ, Joab ofona ochina k'ọvaarnọng otza ọgbaakh-ẹ odik nwa. Wa ọvaarnọng oyeri Absalọm, kw'okwu ọrakha ọvaarnọng m'itzitzikha, ottima itzitzikha m'irerek. Iwa ọvaarnọng ọbaakha Absalọm.
\c 15
\s1 Achibhi-tzama p'Absalọm osi
\p 
\v 1 Okwu otzuma k'ogbe mẹ, Absalọm otzini ọkpaar kwa nnyanyaang mmindọr, ọmaana nnyanyaang, okwu ọttara k'ajinọng arọbh afa obhiri jobh bi, bẹ achẹ-ẹ eden.
\v 2 Iwa kẹ ọm-ọphyọbha k'ekpekpebha ọtza obe k'eden ọkhaan-ọkhaan ch'echin k'ẹbaakhamma ch'odedenmon. Ogbe kpenamkpen kw'ọnọng otzim aponga bi, ọtza okhebha ọvaarnọng, ifha ọttọhna, Absalọm om-oyeri ọnọng nwuma ọbọbh-ẹ bi, “Kọ afon bọng obhon?” Ọnọng nwuma obhina bi, “Ọtzọhmnọng kwọ ofon k'ẹkhọma dani ch'Israẹl.”
\v 3 Mẹ wọ, Absalọm on-oben-ẹ bi, “Kker e, aponga mba adaami kọ, bẹ abira otzor-otzor, yina, ọnọng kw'oyong-ọ itzọhng k'eho ch'ọvaarnọng kode e.”
\v 4 Absalọm ọttara bi, “Idikha ira bẹ asi-m osi-aponga m'irerek nna e! Ira ọnọng kpenamkpen ọkhaam odik kw'ọyakh-ẹ atzim, obiro ode iponga o, ofha okwu okhebh-m, kaam ńsi aponga pẹ adaam-ẹ.”
\p 
\v 5 Ogbe kpenamkpen kw'ọnọng oreng otzor Absalọm ka for bi, ọrakha ottima itzitzikha k'irerek orim-ẹ, Absalọm om-onemi ọbọhk ọbọkh-ẹ obina, ọbaakh-ẹ.
\v 6 Wa Absalọm om-osi mando ọnang anọng p'Israẹl biphyir, p'akwu aror eponga-ttọhna ch'etzor-otzor k'ọvaarnọng. Wa om-osi mando otzima odebh nttem s'anọng p'Israẹl.
\p 
\v 7 Mada cho anna akk'akwọbha, iwa Absalọm oben ọvaarnọng bi, “Tte kaam nda ka Hẹbrọn, ifha nda ńsi ẹjaakhi ch'echekhi ch'iwa nsi nnang Ọvaar Ibinọkpaabyi.
\v 8 Mada iwa ọtzọhmnọng kwọ orukhi ka Geshur k'ẹkhọma ch'Aram, iwa kaam nsi echekhi bi: ‘Idikha Ọvaar Ibinọkpaabyi otzim-m ọkpa nnam ka Jẹrusalẹm, kaam ḿkpobha Ọvaar Ibinọkpaabyi ka Hẹbrọn.’ ”
\p 
\v 9 Ọvaarnọng oben-ẹ bi, “Rọhng k'odidiri.” Mando kw'Absalọm ofon ochina ka Hẹbrọn.
\p 
\v 10 Iwa Absalọm ọtzọhm nttọ ka ngọma s'Israẹl makhọra bi, bẹ atza aben bi, “Isa bọng abhaang da bẹ agyi abukpọhng \it bi kpaar\it*, bọng kpebh amọng aben bi, Absalọm ọkk'ọvaarnọng ọda ka Hẹbrọn e!”
\v 11 Wa ajinọng arọbh jobh p'afon ka Jẹrusalẹm bọ atzọni Absalọm abẹ. Wa obheri bẹ mach'anọng p'akwu odik kw'abẹ an-arong.
\v 12 Mada Absalọm om-osi njafọhni, wa obiro ọtzọhm bẹ ayeri Ahitophẹl kw'ofon Gilo, kw'ọm-ọnang Devid ndọhna, ofona ka Gilo kw'ode obhon kwẹ okwu. Mẹ wọ, achibhi-tzama p'Absalọm an-ado ẹfa akhaama, anọng p'atzọni Absalọm abẹ, abira ochina ororo ahaabh.
\s1 Devid ọrọbhi oji Jẹrusalẹm
\p 
\v 13 Iwa ọkkaabh-ẹkkaabha wani okwu ọgbaak Devid bi, “Nttem s'anọng p'Israẹl nwobh k'Absalọm.”
\p 
\v 14 Mando kwa Devid obeni atzọhmnọng pẹ biphyir p'awobh ttar-ẹ ka Jẹrusalẹm bi, “Bọng kwu! Mọrọbh, oni mando ode, ọnọng manda wani kw'ọnaanga ka mbọhk s'Absalọm kóde. Mọkhaambi obina ofona ẹbhar-ẹbhar, oni mando ode, kẹ ọ́tza ọ́khọbha man ọkhọbha ódimi man, óbiro otzima ọkkangkkaang ofhu anọng p'odedenmon.”
\p 
\v 15 Akhaan-nọng p'ọvaarnọng abhin-ẹ bi, “Atzọhmnọng pọ akk'for ada atzik bi, bẹ asi kpenamkpen f'itta ọvaarnọng kwaman ochibhi.”
\p 
\v 16 Mando kw'ọvaarnọng obin orenga, anọng p'ẹhọhmmọr chẹ biphyir atzọn-ẹ abẹ. Yina, iwa obin oji akkọra-panọng pẹ jobh bi, bẹ awobha akkeri ẹvaar-ttọhmma.
\v 17 Wa ọvaarnọng otzima anọng biphyir p'atzọn-ẹ abẹ obina orenga, bẹ abe k'odedenmon ọkhaan-ọkhaan.
\v 18 Wa atzọhmnọng pẹ biphyir achẹ-ẹ eden akwọbha. Ajinọng pa Kẹrẹt ọmaana pa Pẹlẹt ttara pa Git p'ade ẹnọhna obhiri arọbh jobh biphyir p'atzọn-ẹ abina ka Gat, am-abira arenga ọvaarnọng k'itzitzikha.
\p 
\v 19 Ọvaarnọng on-oben Ittayi kw'ofon Git bi, “Okhuri yan kwa kọ atzọn man abẹ o? Kọ ade okhekhennọng kw'arọbhi ebira k'obhon kwọ. Kpa nnam atza awobha ttara ọvaar Absalọm.
\v 20 Ikhena-ikhena wọ kw'akwu. On-orenga yan kaam nttọ-ọ ọbọhk awenna ttara man, k'ogbe kwa nni ibe nnong sa mminda-ọtza o? Kọ tzima anọng pọ biphyir kpa nnam. Tte Ọvaar Ibinọkpaabyi osi ọphyaam ọnang bọng, obiro ọkhọhkha bọng idadaakha.”
\p 
\v 21 Yina, Ittayi on-obhina ọvaarnọng bi, “Odem kw'Ọvaar Ibinọkpaabyi orukhi akpen, ọmaana k'odem kw'itta ọvaarnọng kwaam obiro oruk akpen, ibe kpenamkpen s'itta ọvaarnọng kwaam owobh, kaambi ode obo, obiro ode akpen o, mẹ wọ kwa kaam ọtzọhmnọng kwọ, ńwobha.”
\p 
\v 22 Devid oben Ittayi bi, “Kọ rọhng, abina orenga.” Mando kw'Ittayi kw'ofon Git obin orenga ọmaana ajinọng pẹ, ttara nhọhmmọr sa nwobh ttar-ẹ.
\p 
\v 23 Iwa anọng biphyir p'ẹkhọma nda abhom amọng k'ẹrọng, k'ogbe kw'anọng mba am-arenga akwọbha. K'ogbe kw'ọvaarnọng om-ojekha Ẹttẹri cha Kidrọn, akhaan-nọng pẹ biphyir atzọn-ẹ abẹ, arenga achina k'okhubha kw'anọng anarukhi.
\p 
\v 24 Iwa Zadọk obiro owobha mẹ, ttara abaLẹvi biphyir p'am-atzini Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi. Wa bẹ abera Ẹkkọhbhi nda ch'Echekhi ch'Ibinọkpaabyi k'irerek. Abiyata osi njafọhni maa anọng mba, atte odedenmon nwa ọbọhk.
\p 
\v 25 Ọvaarnọng oben Zadọk bi, “Tzima Ẹkkọhbhi nda ch'Echekhi ch'Ibinọkpaabyi akpa nnam k'odedenmon. Idikha kaam ngaam ọphyaam k'itzitzikha s'Ọvaar Ibinọkpaabyi, kẹ ótzim-m otzima mkpa nnam ma. Kẹ óbiro osi-m nne Ẹkkọhbhi nda ore, ọmaana irukhabe sẹ.
\v 26 Yina, idikha obeni bi, ‘Ettem kaam kẹdaami ttar-ọ,’ kkeri, kaam nkk'for nda; tte osi-m mach'ọdaakh-ẹ.”
\p 
\v 27 Iwa ọvaarnọng obiro oben Zadọk kw'ode ọfọhnẹja bi, “Kwẹ kọ kọttaan o? Kpa nnam k'odedenmon ttara ẹdaa chaam. Tzima Ahimaz kw'ode nnwa kwọ, ọmaana Jonatan kw'ode nnwa kw'Abiyata akpa nnam. Kọ ọmaana Abiyata, bọng dima va pabọng afa akpa nnam.
\v 28 Kaam ńwobha ndik, k'ibe s'anọng am-arenga ajekha achina k'ibe s'anọng anarukhi, maa atzọhm-m ẹkkaabha.”
\v 29 Mando kw'iwa Zadọk ọmaana Abiyata atzim Ẹkkọhbhi nda ch'Echekhi ch'Ibinọkpaabyi akpa nnam, atza awobha ka Jẹrusalẹm.
\p 
\v 30 Yina, wa Devid ochina ororo om-ovura Egbegbeho ch'Oliv. Wa obubha ọttọhk k'eho, otzima mmo-dukhi om-obhom ẹmọng otzima orenga. Anọng biphyir p'awobh ttar-ẹ abira abubha nho sabẹ, am-abhom amọng atzima avura egbegbeho.
\v 31 Mada bẹ akk'Devid agbaakha bi, “Ahitophẹl obiro ode wani k'ottem kw'anọng p'asi mphaari-tzama ttara Absalọm.” Mando kwa Devid ozi njọhm, oben bi, “O Ọvaar Ibinọkpaabyi, si ndọhna s'Ahitophẹl mmakhi nde edidingi.”
\p 
\v 32 Mada Devid opyiri k'egbegbeho ebira, kẹ da anọng am-awobha akpobha Ibinọkpaabyi, wa Hushayi kw'ofon Ark ọtza okhebha Devid kẹ, ọmaana owura-baba kwẹ kw'ọkk'ọjaakhi ttara ọkpọhm k'eho chẹ.
\v 33 Devid oben-ẹ bi, “Idikha kọ atzọn-m abẹ, kọ áde ẹtzọhkha anang-m.
\v 34 Yina, idikha akpa nnam k'odedenmon atza aben Absalọm bi, ‘Itta ọvaarnọng, kaam ńde ọtzọhmnọng kwọ. Iwa kaam nde ọtzọhmnọng kw'atte, kaam nna ńde ọtzọhmnọng kwọ.’ Mẹ kw'áfha akkaan-m akhibhi ndọhna s'Ahitophẹl.
\v 35 Zadọk ọmaana Abiyata p'ade afọhnẹja, áwobh-owobha kẹ ttar-ọ. Gbaak bẹ odik kpenamkpen kw'abhaang k'ẹvaar-ttọhmma.
\v 36 Va pabẹ p'ijinọng afa p'ade; Ahimaz kwa Zadọk obhoni ọmaana Jonatan kw'Abiyata obhoni, awobh mẹ ttara bẹ. Tzọhm bẹ akwu agbaakh-m odik kpenamkpen kw'abhaang.”
\p 
\v 37 Mando kwa Hushayi kw'ode oyok-odikkobh kwa Devid opyiri ka Jẹrusalẹm, k'ogbe kw'Absalọm om-odim k'odedenmon.
\c 16
\s1 Devid ọmaana Ziba
\p 
\v 1 Mada Devid okk'orenga ọkwọbha egbegbeho nduma ibebaa, on-ore Ziba kw'ode ọtzọhmnọng kwa Mẹphiboshẹt. Wa ọdabh nwọr-wobha ka nnyanyaang, obiro ọtzọkha brẹd-duk arọbh jobh, ọmaana attukha-pyi arọbh azen p'agrep p'agwu-ogwu, ọmaana attukha-pyi arọbh azen pa fig, okwu ọttara k'atzuk pa bẹ akhe k'ẹkpa cha bẹ atzim etzenkpa asi, otzima otzik Devid.
\p 
\v 2 Iwa ọvaarnọng ọbọbh Ziba bi, “Atzim ekpo mbya akwu mbọng o?”
\p Ziba obhina bi, “Nnyanyaang nna nde s'ẹhọhmmọr ch'ọvaarnọng ẹyaar e. Brẹd ọmaana achiduk ade p'adikkobh mba áchi. Atzuk mba ábira asi for igaangi ayok p'ẹfa ẹkk'ẹha k'ibe s'anọng anarukhi.”
\p 
\v 3 Ọvaarnọng ọn-ọbọbh bi, “Nnwa-mmona kw'itta kwọ kho?”
\p Ziba oben bi, “Kẹ owobh ka Jẹrusalẹm, okhuri da ochibhi bi, ‘Mayina s'anọng p'Israẹl ánang-m ọvaarbhon kw'otte kwaam kw'ideden, ọnang.’ ”
\p 
\v 4 Mẹ wọ, ọvaarnọng oben Ziba bi, “Ọttọhk kpenamkpen fa Mẹphiboshẹt ọkhaam on-ode fọ.”
\p Ziba oben bi, “Itta ọvaarnọng kwaam, nnak k'ikpokpobha, tte kaam ngaama ọphyaam k'itzitzikha sọ.”
\s1 Shimeyi olukhi Devid
\p 
\v 5 Mada ọvaar Devid opyiri k'obhon kwa Bahurim, ojinọng wani kw'ofon k'ẹnọmma dani ttara ẹhọhmmọr cha Saul oyin ka, ọttẹwọr ọm-ọgbaak olukhi. Ojinọng nwa okpen Shimeyi, kw'ode nnwa kwa Gẹra.
\v 6 Wa ọm-ọbhari Devid ọmaana akhaan-nọng p'ọvaarnọng biphyir atza. Iwa agbong-nọng biphyir ọmaana abaabhi awobh Devid k'odimbọhk ọmaana ka kwabọhk.
\v 7 Wa Shimeyi om-olukhi Devid, oben bi, “Bina ma, rọhng afona! Ọnọng-dama mach-ọ, ọfhu-anọng macha kọ!
\v 8 Ọvaar Ibinọkpaabyi ọkk'ọ ọmmamma ọnanga k'anọng p'afhu k'ẹhọhmmọr cha Saul, kw'atzọk ẹvaar ka mbọhk sẹ adabh. Ọvaar Ibinọkpaabyi okk'ọvaarbhon nwa ọtzọkha ka mbọhk sọ, ọnang nnwa kwọ Absalọm. Kọ an-awobh k'ihem, okhuri bi, ade ọfhu-anọng!”
\p 
\v 9 Mẹ wọ, Abishayi kw'ode nnwa kwa Zeruya, oben ọvaarnọng bi, “Okhuri yan kw'ọpfa-bukhi nwa om-olukhi, itta ọvaarnọng kwaam o? Tte nda mkpaar-ẹ eho.”
\p 
\v 10 Iwa ọvaarnọng oben bi, “Odik nwa on-oreng yan ọkpakha bọbọng va pa Zeruya o? Idikha ode Ọvaar Ibinọkpaabyi wọ oben-ẹ bi, ‘Lukhi Devid,’ anyi wọ ọfha ọbọbh bi, ‘Okhuri yan kw'am-asi odik nwa o?’ ”
\p 
\v 11 Mando kwa Devid obeni Abishayi ọmaana atzọhmnọng pẹ biphyir bi, “Ojemi nnwa kwa kaam ọkhaam, om-oror nden s'ofhu-m, ọn-ọyọhng oBẹnjamin-nọng nwa o! Bọng ttẹ-ẹ ọbọhk, olukh-m e; Ọvaar Ibinọkpaabyi wọ ọkk'ẹ obena bi, osi mando.
\v 12 Asi mẹ, Ọvaar Ibinọkpaabyi ọfha ore ọmmamma kwaam, on-otzera ilulukhi sa Shimeyi mayina, ttara ẹdaa ch'echekhi chẹ.”
\p 
\v 13 Iwa Devid ọmaana atzọhmnọng pẹ, achina ororo am-arenga k'ọkkadeden k'ogbe kwa Shimeyi, obiro orenga k'okhubha kw'egbegbeho kw'okker-ẹ itzitzikha. Om-olukhi Devid, ọbhar-ẹ atza, obiro obhon-ẹ ọkpọhm.
\v 14 Wa ọvaarnọng ọmaana anọng p'atzọn-ẹ abẹ biphyir, apyiri k'ibe sa bẹ akhami k'ọkhọkhọhni. Mẹ wọ kw'iwa Devid okwok ọwọhng.
\s1 Ndọhna sa Hushayi ọmaana Ahitophẹl
\p 
\v 15 Iwa Absalọm ọmaana ajinọng p'Israẹl biphyir akk'apyiri ka Jẹrusalẹm. Wa Ahitophẹl obiro ọtzọn-ẹ abẹ okwu.
\v 16 Oyok-odikkobh kwa Devid kw'okpen Hushayi kw'ofon Ark, ọtza okhebha Absalọm, oben-ẹ bi, “Tte ọvaarnọng oruk akpen p'adum-odum! Tte ọvaarnọng oruk akpen p'adum-odum!”
\p 
\v 17 Absalọm ọbọbh Hushayi bi, “Ma wọ ode idadaakha s'afha akhọhkha oyokh-odikkobh o? Bọng areng iyok, osi yan kw'anẹ-ẹ abẹ atzọni afona?”
\p 
\v 18 Hushayi oben Absalọm bi, “Mma e, kaam nwobha ttara ọnọng kw'Ọvaar Ibinọkpaabyi okk'otzekha. Kẹ wọ ode ọnọng kw'anọng mba ọmaana ajinọng p'Israẹl biphyir akk'atzekha e.
\v 19 Ọttara bi, anyi kwa kaam nsi ọtzọhm nnang o? Kaam nsi ọtzọhm nnang nnwa kwẹ. Odem nwa kw'iwa nsi nnang atte, mando kwa kaam nsi ọtzọhm nnang-ọ.”
\p 
\v 20 Absalọm oben Ahitophẹl bi, “Nang man ndọhna sọ. Mosi yan?”
\p 
\v 21 Ahitophẹl obhina Absalọm bi, “Yima akkọra-panọng p'atte abẹ p'okhokhi bi, bẹ akkeri ẹvaar-ttọhmma. Mẹ wọ osi, anọng p'Israẹl biphyir ábhaanga bi, akk'atte idik akpukhi. Anọng p'atzum-ọ mbọhk ka nnam án-abira ado ẹfa akhaama.”
\v 22 Mando kwa bẹ asi ikhira k'ọhohm ebir-ebir, s'Absalọm owobh oyima akkọra-panọng p'otte abẹ, k'itzitzikha s'anọng p'Israẹl biphyir.
\p 
\v 23 K'ogbe nwuma, iwa ndọhna s'Ahitophẹl nde mach'ọnọng ọdọhni Ibinọkpaabyi. Mando kw'iwa Devid ọmaana Absalọm am-atzọkha ndọhna kpenamkpen s'Ahitophẹl.
\c 17
\p 
\v 1 Ahitophẹl oben Absalọm bi, “Tte ndekha ajinọng nnọhna ẹrọbh obhiri jobh, ndima bẹ ngwubh Devid k'erungiwu cha mayina.
\v 2 Kaam ńnim-ẹ abẹ, k'ogbe kw'ọkk'ẹ ọkhọhna, ẹfa ebire ẹhẹ-ẹ. Kaam ngẹ-ẹ ojora f'ideden ka for, ifha anọng p'awobh ttar-ẹ, árọbh. Kaam ḿfhu ọvaarnọng kẹ-khẹ,
\v 3 ḿbiri ndima anọng mbuma biphyir mkpa nnam nchen-ọ. Obo kw'ọnọng kw'am-aror, óde ekhuna ch'ayok biphyir; anọng mbuma biphyir, áwobha k'odidiri.”
\v 4 Absalọm ọmaana adeden-nọng p'Israẹl biphyir, are mphaari nna mach'odik-ọkka.
\p 
\v 5 Mẹ wọ, Absalọm on-oben bi, “Bọng yeri Hushayi kw'ofon Ark okwu, ifha mobiro ọbhaanga ochibhi kwẹ.”
\v 6 Mada Hushayi opyiri, Absalọm oben-ẹ bi, “Kkeri ndọhna s'Ahitophẹl okk'man ọnanga ma e. Mósi mach'ọgbaakh o? Oni mando ode, gbaak man ochibhi kwọ.”
\p 
\v 7 Hushayi e, obhina Absalọm bi, “Ndọhna s'Ahitophẹl ọnangi m'ogbe nwa kinjibhi.
\v 8 Hushayi oben bi, kọ arong atte ọmaana ajinọng pẹ kẹ; bẹ ade agbong-nọng p'ajor mach'ekye, cha bẹ abọk va ana k'ẹtzam. Ayongi mẹ, atte ode ogbong-nọng kw'ekkoji; kẹ ma kóyima ttara agbong-nọng pẹ m'erungiwu nda.
\v 9 Madeden nwa, ochubh k'ọmma kw'itzakpa wani, asi mẹ, ochubh k'ibe ọdọdọk. Idikha kẹ ochi eden orima agbong-nọng pọ abẹ, ọnọng kpenamkpen kw'ọbhaang kwẹ, óben bi, ‘Ẹnọng-fha ẹkk'ẹbara kpọng k'ottem kw'agbong-nọng p'atzọni Absalọm abẹ.’
\v 10 Mẹ wọ, kaambi ogbong-nọng kw'ọbari ettem mach'ekye wọ, ojora ọnẹ-ẹ ẹfa maa, ope ka for biphyir, okhuri bi, anọng p'Israẹl biphyir arong bi, atte ode ogbong-nọng. Anọng p'abira awobha ttar-ẹ ade akkenggitza.
\p 
\v 11 “Kẹ wọ osi, ndọhna saam nde bi, kkeri anọng p'Israẹl biphyir, ttẹwọr k'ẹkhọma cha Dan maa, apyiri k'ẹkhọma cha Beershẹba, kkeri odem nwa kwa bẹ ahaabhi mach'oyeyeng kw'ẹraanga-kha, tte bẹ biphyir awobha ttar-ọ. Kọ ọkhaam atzima bẹ eden atza egbong.
\v 12 Ibe kpenamkpen sa mọfha ore atte, mórim-ẹ abẹ. Mokwuri kẹ nkwuri mach'eboni ebubh irerek. Kẹ akpen kóruk, ojinọng manda wani kwẹ kw'órik kode.
\v 13 Idikha ọrọbhi odim k'odedenmon, anọng p'Israẹl biphyir átzima ndik atzọr nchumi s'obhon nwuma abhari k'ẹttẹri, maa itzatzaa manda wani kw'orik kóde.”
\p 
\v 14 Mando kw'Absalọm ọmaana ajinọng p'Israẹl biphyir abeni bi, “Ndọhna sa Hushayi kw'ofon Ark njibhi ọtzam nyọhnga s'Ahitophẹl.” Wa Ọvaar Ibinọkpaabyi ọkk'ọkhama bi, opfuri ndọhna ọkkakka s'Ahitophẹl, ifha otte itzama ọbọhk ikhebha Absalọm.
\p 
\v 15 Iwa Hushayi oben Zadọk ọmaana Abiyata p'ade afọhnẹja bi, “Ahitophẹl okk'Absalọm ọmaana adeden-nọng p'Israẹl ọtzọhna eden cha bẹ asi. Yina, kaam nkk'bẹ eden ọdọdọk ndọhna cha bẹ asi.
\v 16 Tzọhm ẹkkaabha m'ẹbaa nda achena Devid bi, ‘Kọ k'ibe s'anọng am-arenga ajekha achina k'ibe s'anọng anarukhi m'erungiwu nda, kàtaabha. Yina, echuni kakhaama bi, ajekha k'okhubha. Oni mando ode, ọvaarnọng ọmaana anọng biphyir p'awobh ttar-ẹ, bẹ ábọkha bẹ, afhu-ofhu.’ ”
\p 
\v 17 Iwa Jonatan ọmaana Ahimaz awobh k'Ẹn-Rogẹl, da iwa bẹ an-arori bi, anọng are bi bẹ am-adim k'odedenmon. Wa ominanwa wọ ọm-ọtza ọgbaak bẹ idik, yina bẹ-bẹ an-atza agbaak ọvaar Devid.
\v 18 Yina, wa odikkobh wani ore bẹ, ọtza ọgbaak Absalọm. Mando kwa bẹ arọbhi ẹbhar-ẹbhar, achina k'ọhọhm kw'ojinọng wani ka Bahurim, kw'ọkhaam esipe k'ettọhmmattem chẹ. Wa bẹ ahakha achubha k'esipe ẹtzaanga.
\v 19 Mando kwa kwanọng kw'ẹttọhmma nda ọtzọk ọttọhk obubha esipe nda, obiro ọtzọkha abọkpa-mọma ọyaan mẹ. Wa ọnọng kw'orong bi, ajinọng mba achubh mẹ kode.
\p 
\v 20 Mada ajinọng p'Absalọm akwu akhebha kwanọng nwa m'ọhọhm, bẹ abọbh-ẹ bi, “Ahimaz ọmaana Jonatan awobh man?”
\p Kwanọng nwa obhina bẹ bi, “Bẹ ajek k'okhubha nwonggo kw'ekhekha e.” Wa ajinọng mba aror bẹ, yina, bẹ ọnọng kare. Mando kwa bẹ akpa nnam ka Jẹrusalẹm.
\p 
\v 21 Mada ajinọng mba akk'afona, Ahimaz ọmaana Jonatan ayin k'esipe, atza agbaak ọvaar Devid odik nwa. Bẹ aben bi, “Do for ẹbhar-ẹbhar ajekha k'ọraanga okhubha; kkeri Ahitophẹl okk'bẹ ọtzọhna odem kwa bẹ asi.”
\v 22 Mẹ wọ, Devid ọmaana anọng biphyir p'awobh ttar-ẹ abina orenga, ajekha k'okhubha kwa Jọrdan. Yina ewu ehobha, anọng korikhi kw'oni Jọrdan ajekha.
\p 
\v 23 Mada Ahitophẹl ore bi, bẹ ndọhna s'ọnangi bẹ katzọk, ọyaar ẹnyanyaang chẹ ọbhana k'obhon kwẹ. Odo ẹhọhmmọr chẹ biphyir, obina ọtza ọgbana edik. Ofona mẹ, wa ope, bẹ anọhng-ẹ k'epekhubh ch'otte.
\p 
\v 24 Mẹ wọ, Devid obina ochina k'obhon kwa Mahanayim. Wa Absalọm obiro otzima ajinọng p'Israẹl biphyir ojekha k'okhubha kwa Jọrdan.
\v 25 Wa Absalọm okk'Amasa ọrọbha mach'oho kw'agbong-nọng, otzima otzer eho cha Joab. Wa Amasa ode nnwa kw'ojinọng kw'okpen Jẹtẹr kw'ofon Ishmayẹl, kw'ọtzọk Abigẹl kw'ode nnwa kw'ikwanọng kwa Nahash obiro ode ọgbaanotte kwa Zeruya kw'ode ọkka kwa Joab.
\v 26 Anọng p'Israẹl ọmaana Absalọm abhing k'ẹkhọma ch'anọng pa Gilead.
\p 
\v 27 Mada Devid opyiri k'obhon kwa Mahanayim, Shobi kw'ode nnwa kw'ijinọng kwa Nahash, kw'ofon Raba k'ẹkhọma ch'Ammọn, ọmaana Makir kw'ode nnwa kw'ijinọng kw'Amiyẹl kw'ofon Lo-Debar, ttara Barzilayi kw'ofon Rogẹlim k'ẹkhọma cha Gilead
\v 28 atzima ekpo py'eyima, ọmaana agbang-gbang, ttara ibanga-rọhkha. Bẹ abira atzima wit ọmaana abarli, ọmaana abubuma, ọmaana abọkpa-bhaabha, ọmaana ngirigiri ttara achen-meni.
\v 29 Bẹ atzima akhọkhọhnana, ọmaana abasi p'akk'agaangi, ọmaana arukhimaan, ọmaana abukpa p'afon k'abasi p'andamogbodo achena Devid ọmaana anọng pẹ bi, bẹ achi. Bẹ aben bi, “Anọng mba okk'bẹ ọkhọhna, okwo ọkhaama bẹ, asi abira adaak bẹ, k'ibe s'anọng anarukhi.”
\c 18
\s1 Obo kw'Absalọm
\p 
\v 1 Wa Devid otzobha ajinọng p'awobh ttar-ẹ, osi ayok bani adenho p'agbong-nọng nnọhna-nnọhna, bani adenho p'agbong-nọng arọbh azen-azen.
\v 2 Devid ọbhaangi agbong-nọng mba ka ngaan nttaan, osi Joab odenho kw'ẹkhaan dani. Osi Abishayi kw'ode nnwa kwa Zeruya, kw'obiro ode ọgbaanotte kwa Joab odenho kw'ẹkhaan dani. Osi Ittayi kw'ofon Git odenho kw'ẹkhaan dani. Wa ọvaarnọng oben ajinọng mba bi, “Kaam ọkhaam ḿbiri ndọn bọng abẹ.”
\p 
\v 3 Yina, ajinọng mba aben bi, “Itta, kọ k'iyaan kakhaambi ayin. Idikha mọrọbhi, man attattaanganọng odik kọkpakha. Idikha man ibhaakha rani ope, man bẹ odik kọkpakha. Yina, kọ abari odik ayọhnga man anọng nnọhna ẹrọbh obhiri nzen. Kẹ wọ osi ọbaana bi, kọ awobha m'odedenmon, atzọhm man ẹkkaana e.”
\v 4 Iwa ọvaarnọng on-obhina bi, “Kaam ńsi odik kpenamkpen osi kwa bọng are bi, ojibh-ojibh.”
\p Mẹ wọ, iwa ọvaarnọng obe k'ẹbaakhamma ọkhaan-ọkhaan, mada ajinọng mba abin attọma ka ngaan s'arọbh azen-azen, ọmaana ka ngaan sa nnọhna-nnọhna, afona.
\v 5 Wa ọvaarnọng ọtzọr Joab, ọmaana Abishayi ttara Ittayi itzọhng bi, “Bọng nenga kaam abẹ, ayobh odikkobh nwuma Absalọm oyobh o.” Wa agbong-nọng biphyir abhaanga da ọvaarnọng ọm-ọtzọr adenho itzọhng okhuri Absalọm.
\p 
\v 6 Iwa agbong-nọng attọma ẹkhaan ayin k'odedenmon, atza arima anọng p'Israẹl abẹ. Wa egbong nda ewobh k'ẹtzam ch'Ephraim.
\v 7 Mẹ kw'iwa ajinọng pa Devid akhem agbong-nọng p'Israẹl. Anọng p'ape ewu nduma ahaabhi apyiri nnọhna arọbh afa obhiri jobh.
\v 8 Wa erima nda ẹnyaami makhọra ẹkhọma nda biphyir. Ọnọng-mik kw'iwa ope k'ẹtzam, ọyọhng kw'ope k'ọkkangkkaang.
\p 
\v 9 Iwa Absalọm ọtza ottema ajinọng pa Devid abẹ. Wa ọm-ọyaar ẹnyanyaang chẹ. Mada ẹnyanyaang nda ereng bi, ẹkwọbha k'irekh-irek kw'echi cha oak ch'ideden, ch'abọhnga pẹ akpa-ọkpa, isisaa s'Absalọm igbaama k'echi nda. Wa ọn-ọyọhn m'ottem kw'ẹrọng ọmaana irerek. Ẹnyanyaang chẹ echina ororo ẹm-ẹrọbh efona.
\p 
\v 10 Mando kw'ojinọng wani kw'ore odik kw'ọkk'ọtta, ofon ọtza ọgbaak Joab bi, “Kaam nne Absalọm da ọyọhni k'echi ch'oak.”
\p 
\v 11 Joab oben ojinọng kw'ọgbaakh-ẹ odik nwa bi, “Obi! Are Absalọm o? Osi yan kẹ eden dani kafhu abhari m'irerek? Kaam ira nkk'ọ ashẹkẹl jobh pa silva ọmaana odikpa kw'ọkkakkaama nnanga.”
\p 
\v 12 Yina, Joab obhina bi, “Kaambi akhe-m ashẹkẹl p'adọhbhi apyiri nnọhna mfa obhiri arọbh jobh ma mbọhk, kaam nnwa kw'ọvaarnọng ọbọhk kinttọmi e. Mowobh mẹ ọbhaanga da ọvaarnọng ọtzọri kọ, ọmaana Abishayi ttara Ittayi itzọhng bi, ‘Bọng nnenga kaam abẹ, ayobh odikkobh nwuma Absalọm.’
\v 13 Idikha ira kaam nkk'Absalọm mfha, nge akpen paam ka dama-dama, da odik on-ode kw'ọvaarnọng on-om-oronga, ira akk'arọbha aji-m.”
\p 
\v 14 Joab oben bi, “Kaam manda dọk kimbe ndikh-ọ.” Mando kw'ọtzọk akhọhn attaan p'otzim ka mbọhk, okhum Absalọm k'ettem, mẹ da Absalọm otzim om-oji iwọhng m'echi ch'oak.
\v 15 Adikkobh jobh p'ade atzim-egbongkpo pa Joab akhọri Absalọm akhe k'ottem, akyer-ẹ abun afhu.
\p 
\v 16 Mando kwa Joab ogyi obukpọhng, otzima oben agbong-nọng bi, bẹ akwọbha ajinọng p'Israẹl okhukhubh.
\v 17 Bẹ atzini obukhi kw'Absalọm atza abhari k'ipekhuma s'idong-odong k'ẹtzam. Bẹ atzọkha ọtzakpa-hung abubh-ẹ. M'ogbe nwuma, anọng p'Israẹl biphyir arọbh achina k'ihọhm sabẹ.
\p 
\v 18 K'ogbe kw'Absalọm otzim orukhi akpen, wa ọtzọk ọtza ottima ebebe k'Ẹttẹri ch'Ọvaarnọng mach'ojima ọnang for sẹ, da iwa ochibhi bi, “Kaam nnwa kw'ijinọng kingaam kw'osi che chaam eningi edimi.” Iwa oyeri ọtza nwa obhina che chẹ. Ọtza nwa okpen Ejima ch'Absalọm maa apyiri k'ewu cha mayina.
\s1 Devid owobh ka nkwu-osisi sa Absalọm
\p 
\v 19 Iwa Ahimaz kw'ode nnwa kwa Zadọk oben bi, “Tte nnọbh nda mgbaak ọvaarnọng ẹkkaabha nda bi, Ọvaar Ibinọkpaabyi ọkk'ẹ ọkkaana ka mbọhk s'attattaanga-nọng pẹ.”
\p 
\v 20 Joab oben-ẹ bi, “Kọ arang atza agbaak ẹkkaabha nda mayina. Kọ atza ogbe ọdọdọk, mayina kàtza, okhuri bi, nnwa kw'ọvaarnọng ọkk'ọpa.”
\p 
\v 21 Mẹ wọ, Joab oben ọnọng wani kw'ofon Kush bi, “Rọhng atza agbaak ọvaarnọng odik kw'akk'ara.” Ọnọng nwa kw'ofon Kush ọrakha ọnang Joab ikpokpobha, yina ọn-ọrọbhi ofona.
\p 
\v 22 Ahimaz kw'ode nnwa kwa Zadọk obiro oben bi, “Kaambi ode yan, tzotzokhaan, tte nnọbh ndor ayi nwa kw'ofon Kush nnam.”
\p Kaambi mẹ wọ, Joab obhina bi, “Nnwa kwaam, osi yan kw'aben bi atza? Ẹkkaabha manda dani ch'ẹnang-ọ echora kakhaam.”
\p 
\v 23 Oben bi, “Kaambi ode yan, kaam nnọbh nda-ọtza.”
\p Mẹ wọ, Joab oben bi, “Rọbh rọhng!” Mando kw'Ahimaz ọrọbhi orenga k'okhubha kw'ẹtteri, on-ochi ọnọng nwa kw'ofon Kush eden.
\p 
\v 24 Mada Devid owobh ẹwọr k'ottem kw'ẹbaakhamma ch'iyaan ọmaana ch'ẹtzaanga, okker-ibe ovura k'ittakhọhnga s'echumi ch'ẹbaakhamma. Mada okkeri k'iyaan, on-ore ojinọng kw'ọm-ọrọbh kẹ mancheni.
\v 25 Okker-ibe oyeri ọvaarnọng, ọgbaakh-ẹ!
\p Ọvaarnọng oben bi, “Idikha ode mancheni, kw'oyini bi, otzim ẹkkaabha ẹkkakka.” Wa ojinọng nwa kw'ọm-ọrọbh ẹbhar nda, on-odo ọbaang-ọbaanga.
\p 
\v 26 Okker-ibe nwa obiro ore ọnọng ọdọdọk kw'ọm-ọrọbh okwu. Oyeri okker-ẹbaakhamma, oben bi, “Kkeri e, ojinọng ọdọdọk ọm-ọrọbhi okwu mancheni!”
\p Ọvaarnọng oben bi, “Asi mẹ, kẹ obiro otzima ẹkkaabha ẹkkakka.”
\p 
\v 27 Okker-ibe oben bi, “Okher-m mana ocheden nwuma ọm-ọrọbh ẹbhar-dem ch'Ahimaz kw'ode nnwa kwa Zadọk.”
\p Ọvaarnọng oben bi, “Kẹ ode ojinọng ọkkakka. Kẹ otzim ẹkkaabha ẹkkakka.”
\p 
\v 28 Mando kw'Ahimaz oyeri ọvaarnọng, oben bi, “Itta, okk'ojibha ọnang man e!” Ọrakha ottima itzitzikha k'irerek ọnang ọvaarnọng ikpokpobha, oben bi, “Ẹtzọhnga ewobha ẹnang Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwọ! Kẹ okk'anọng p'arim itta ọvaarnọng kwaam abẹ okhema.”
\p 
\v 29 Ọvaarnọng ọbọbh bi, “Odikkobh nwuma Absalọm orukhi akpen kẹ o?”
\p Ahimaz obhina bi, “Mada Joab om-oben bi, ọtzọhm kaam ọtzọhmnọng kwọ, ọmaana ọtzọhmnọng kw'ọvaarnọng, nne dama-dama kw'ideden, yina, kwẹ kaam kọttaani.”
\p 
\v 30 Ọvaarnọng oben bi, “Be ma ọkhaan-ọkhaan, atzik.” Mando kw'ọpaangi obe ọkhaan-ọkhaan.
\p 
\v 31 Mando kw'ọnọng nwuma kw'ofon Kush opyiri, oben bi, “Itta ọvaarnọng kwaam, bhaanga ẹkkaabha ẹkkakka! Ọvaar Ibinọkpaabyi ọkk'ọ ọkkaana ka mbọhk s'attattaanga-nọng pọ biphyir.”
\p 
\v 32 Ọvaarnọng ọbọbh ọnọng nwa kwa Kush bi, “Odikkobh nwuma Absalọm orukhi akpen kẹ o?”
\p Ọnọng nwa kwa Kush obhina bi, “Tte attattaanga-nọng p'itta ọvaarnọng kwaam, ọmaana anọng biphyir p'akhami bi, asọ-ọ itzama, ade mach'odikkobh nwuma.”
\p 
\v 33 Mando kwa for ipe ọvaarnọng. Obina ovura k'ẹmaanggọ-ebira ch'ewobh k'ẹbaakhamma, ọtza obhom ẹmọng. Mada om-ofona, oben bi, “Nnwa kwaam Absalọm o! Nnwa kwaam Absalọm o! Ottu kw'ira kọ ape, kaam wọ ira mpe e! Nnwa kwaam Absalọm o, nnwa kwaam o, nnwa kwaam!”
\c 19
\p 
\v 1 Iwa bẹ agbaak Joab bi, “Ọvaarnọng obhomi amọng kẹ, obiro owobha ka nkwu-osisi s'Absalọm ope e.”
\v 2 Ewu nduma, agbong-nọng biphyir an-akhiri ọdadaami kw'ekhema chabẹ aji. Bẹ an-abhakhi awobha ka nkwu-osisi, da bẹ abhaang bi, “Ọvaarnọng owobh ka nkwu-osisi sa nnwa kwẹ kw'ope.”
\v 3 M'ewu nduma, ajinọng mba abẹkhi atza adim k'odedenmon mach'ajinọng pa mgbar nsi, da bẹ arọbhi k'egbong.
\v 4 Ọvaarnọng obubha mbọhk k'itzitzikha, obhom ẹmọng k'ẹrọng, oben bi, “Nnwa kwaam Absalọm o! Absalọm o! Nnwa kwaam o! Nnwa kwaam!”
\p 
\v 5 Mando kwa Joab ọtza odim k'ọhọhm kw'ọvaarnọng oben-ẹ bi, “Kọ akk'ajinọng pọ biphyir aha ka mgbar mayina, p'akkaan akpen pọ, ọmaana akpen pa va pọ p'ijinọng ọmaana p'ipanọng, ọmaana akpen pa panọng pọ, ttara p'akkọra-panọng pọ.
\v 6 Kọ ahọk attattaanga-nọng pọ idadaakha, attaanga anọng p'akhọhkh-ọ idadaakha. Kọ akk'ẹjaakhi asa mayina bi, adenho p'agbong-nọng ọmaana agbong-nọng pabẹ, ọttọhk kape k'itzitzikha sọ. Kaam nkk'nna k'ewu cha mayina bi, ira ọdaam-ọ ọdaam, ira man biphyir ope, Absalọm oruk akpen.
\v 7 Bina atza akhe anọng pọ ottem-bara. Kaam nchekhi ka che ch'Ọvaar Ibinọkpaabyi bi, idikha ani k'iyaan ayini afona, yina erungi epyi, ojinọng manda wani kwọ kw'oyima ma ttar-ọ kóde. Itzama nna íyọhnga, idik-ttama kpenamkpen s'ikk'itta ikhebh-ọ k'akpen, ttẹwọr k'edikkobh chọ maa apyiri ma.”
\p 
\v 8 Mẹ wọ e, ọvaarnọng obina ọtza owobha ẹwọr k'ẹbaakhamma. Mada bẹ agbaakhi anọng mba bi, Ọvaarnọng owobh ẹwọr k'ẹbaakhamma e, bẹ biphyir afona atza akhebh-ẹ kẹ.
\s1 Devid ọkpa nnam ka Jẹrusalẹm
\p M'ogbe nwuma, anọng p'Israẹl akk'arọbha achina k'ihọhm sabẹ.
\v 9 Makhọra ngọma s'Israẹl, anọng biphyir am-akhaanga ayok atzim, aben bi, “Ọvaarnọng wọ iwa ọkkaan man ka mbọhk s'attattaanga-nọng paman. Kẹ wọ iwa obiro ọrọbha man ka mbọhk s'anọng pa Philistiya. Yina, kẹ ọkk'ọrọbha oji obhon okhuri Absalọm.
\v 10 Ma, Absalọm kw'iwa mobyengi ana k'eho bi, ọdabh man, ọkk'ọpa k'egbong-dam. Osi yan kwa bọng amyi manda, bọng ọvaarnọng kabeni ọkpa nnam o?”
\p 
\v 11 Ọvaar Devid ọtzọhm ẹkkaabha ochena Zadọk ọmaana Abiyata p'ade afọhnẹja bi, “Bọng bọbh adeden-nọng pa Juda bi, mada idik sa bẹ am-agbaak makhọra Israẹl ikk'ọvaarnọng ipyiri k'ẹttọhmma chẹ, ‘Orenga yan bọng an-ade akponga-nnam-nọng p'atzim ọvaarnọng akpa nnam k'ẹvaar-ttọhmma chẹ o?
\v 12 Bọng ade afona-nọng paam, mode izi rani. Mẹ wọ, okhuri yan kwa bọng án-ade akponga-nnam-nọng p'ákwu bi, átzima ọvaarnọng abhana o?’
\v 13 Bọng ben Amasa bi, ‘Kọ mode izi rani, mobiro ode efona dani. Tte Ibinọkpaabyi osi-m k'eden kpenamkpen ch'ẹdaakh-ẹ, idikha nnọ-ọ odenho kw'agbong-nọng paam nsi k'akpen pọ biphyir, ndima ndera eho cha Joab.’ ”
\p 
\v 14 Iwa odebh nttem s'ajinọng pa Juda biphyir, osi bẹ akhaama ochibhi wani. Bẹ atzọhm ẹkkaabha anang ọvaarnọng aben bi, “Kọ ttara ajinọng pọ biphyir, bọng kpa nnam.”
\v 15 Mando kw'ọvaarnọng ọkpa nnam, okwu opyiri k'Ọraanga kwa Jọrdan.
\p Anọng pa Juda akk'akwa k'obhon kwa Gilgal bi, bẹ akwu akhebha ọvaarnọng mẹ, ifha bẹ atzima ọvaarnọng ajekha Jọrdan.
\v 16 Shimeyi kw'ode nnwa kwa Gẹra, kw'ofon k'obhon kwa Bahurim k'ẹkhọma cha Bẹnjamin, otzima ajinọng pa Juda obina ẹbhar-ẹbhar, ọtza okhebha ọvaar Devid.
\v 17 Anọng nnọhna mfa obhiri arọbh jobh pa afon Bẹnjamin bọ iwa atzọn-ẹ abẹ. Wa Ziba kw'ode ọtzọhmnọng kw'ẹhọhmmọr cha Saul, ọmaana va pẹ p'ijinọng chi, ttara atzọhmnọng ẹrọbh abira awobha ttar-ẹ. Wa bẹ adukh-odukha ahakha ka Jọrdan, kẹ da ọvaarnọng owobh.
\v 18 Bẹ atzima ẹhọhmmọr ch'ọvaarnọng arenga k'ibe s'anọng am-arenga ajekha, ajekha k'okhubha. Bẹ abira asi odik kpenamkpen kw'ọvaarnọng ochibhi.
\p Mada ọvaarnọng om-odo for s'ojekha Jọrdan, Shimeyi kw'ode nnwa kwa Gẹra, oruri m'irerek m'itzitzikha s'ọvaarnọng,
\v 19 oben-ẹ bi, “Tte itta kwaam, oning-m oponga-pyibha ọnangi. Kọ ottotto kwa khaam ọtzọhmnọng k'ewu ch'iwa kọ itta ọvaarnọng kwaam, abin ka Jẹrusalẹm, kajima. Tte ọvaarnọng oningi odik nwa k'ettem okhe.
\v 20 Kkeri kaam ọtzọhmnọng kwọ nnong bi, nkk'ẹkhọhngkwuri nsa. Yina, nkk'nkwa mayina mach'ocheden-nọng kw'ofon ka ngọma sa Josẹph bi, nkwu ngebha itta ọvaarnọng kwaam.”
\p 
\v 21 Mẹ wọ, Abishayi kw'ode nnwa kwa Zeruya oben bi, “Shimeyi ọbaan k'obo m'odik nwa e. Kẹ olukhi ọnọng kw'Ọvaar Ibinọkpaabyi okk'ana obyengi k'eho.”
\p 
\v 22 Devid obhina bi, “Bọbọng va pa Zeruya, odik nwa on-oreng yan ọkpakha bọng o? Bọng ẹfa kakhaam bi, bọng akhe ittattaanga m'odik nwa. Ọbaan kẹ bi, bẹ afhu ọnọng m'Israẹl mayina o? Kaam nnong kẹ bi, kaam wọ nde ọvaarnọng kw'Israẹl, mayina e.”
\v 23 Mẹ wọ, ọvaarnọng ochekhi ọtzọkha ọnwọhngi, oben Shimeyi bi, “Kọ kápe e.”
\p 
\v 24 Iwa Mẹphiboshẹt kw'ode nnwa-mmona kwa Saul obiro ọtza okhebha ọvaarnọng. Wa mmo sẹ kogbobhi, agba-phyubha kobiro ophyiri, ọbara fa for kogbobhi, tzọni k'ewu ch'ọvaarnọng ofon, maa apyiri k'ewu ch'ọkpa nnam k'odidiri.
\v 25 Mada ofon ka Jẹrusalẹm bi, okwu okhebha ọvaarnọng, ọvaarnọng ọbọbh-ẹ bi, “Mẹphiboshẹt, okhuri yan kw'iwa ana-m abẹ atzọni afona o?”
\p 
\v 26 Oben bi, “Itta ọvaarnọng kwaam, mada kaam ọtzọhmnọng kwọ ndumi-mbọhbhi, nna ben bi, ‘Kaam ńdabh ẹwọr-wobha ka ẹnyanyaang chaam, ḿbiri nyaar chẹ, ifha ndọn ọvaarnọng abẹ mofona.’ Iwa Ziba kw'ode ọtzọhmnọng kwaam, wọ ọbọr-m.
\v 27 Okk'kaam ọtzọhmnọng kwọ idik obubha, ọnang kọ itta ọvaarnọng kwaam. Itta ọvaarnọng kwaam ode mach'orenga-eden kw'Ibinọkpaabyi. Si odik kw'are bi, ojibh-ojibh ọnang-ọ.
\v 28 Iwa va pa va p'otte kwaam biphyir abaan-ọbaana k'obo, ka mbọhk s'itta ọvaarnọng kwaam. Yina, atzer anang ọtzọhmnọng kwọ ewobha k'ottem kw'anọng p'achi ọchattọhk k'okpokkoro kwọ. Mẹ wọ, kaam ngaam bọng ẹfa bi, nchina ororo mphyem ọvaarnọng idikh o?”
\p 
\v 29 Ọvaarnọng e, oben-ẹ bi, “Odik nwuma dọk kàgbaak. Kaam nkk'kọ ọmaana Ziba ẹfa nnanga bi, bọng atza akkema irerek sa Saul anang for sabọng.”
\p 
\v 30 Mẹphiboshẹt oben ọvaarnọng bi, “Mada itta ọvaarnọng kwaam okk'okhuna k'odidiri. Tte kẹ ọtzọkha ọttọhk kpenamkpen biphyir.”
\p 
\v 31 Wa Barzilayi kw'ofon k'ẹkhọma cha Gilead obiro obina k'obhon kwa Rogẹlim okwu bi, ọtzọn ọvaarnọng abẹ ojekha Jọrdan, ifha obiro orikh-ẹ k'eden.
\v 32 Iwa Barzilayi ọkk'ọn-ọtzama kpọng, da iwa on-ode cho arọbh ana. Wa obiro ode ọkkakkaa, kw'okkeri ọvaarnọng k'ogbe kw'owobh k'obhon kwa Mahanayim.
\v 33 Ọvaarnọng oben Barzilayi bi, “Tzọhn-m abẹ mojekha ka Jẹrusalẹm. Kaam ńkker-ọ okkeri.”
\p 
\v 34 Yina, Barzilayi obhina ọvaarnọng bi, “Da kaam ḿbiri nnuk akpen ka cho aphaang, kw'ira kaam nna ńdọn ọvaarnọng abẹ nchina ka Jẹrusalẹm o?
\v 35 Kaam nna nde cho arọbh ana. Na kaam mbiri mfha nnonga odik kw'ojibh-ojibh ọmaana kw'on-ojibh o? Kaam ọdadaami ọmaana ọmmamma dọk kinnọng. Ọtzọhmnọng kwọ idadaama s'ẹchakpo ttara itzuk dọk kọphaang. Amọng p'akkọhn-amọng p'ijinọng ọmaana p'ipanọng dọk kimmaang. Ka yan kw'ọtzọhmnọng kwọ, on-obiro okwu ọttara kọ itta ọvaarnọng kwaam ẹtzọhkha o?
\v 36 Kaam k'echora nda ch'ọvaarnọng kimbaan. Ọtzọhmnọng kwọ okhinggẹ ọ́tzọhn ọvaarnọng abẹ ojekha ka Jọrdan ibebaa, orikh-ẹ k'oden-gwuma.
\v 37 Tte ọtzọhmnọng kwọ ọkpa nnam e, ifha mpe k'obhon kwaam mbaanga epekhubh s'otte ttara ọkka kwaam e. Yina, kkeri ọtzọhmnọng kwọ Kimham ma. Tte kẹ ọtzọn itta ọvaarnọng kwaam abẹ ojekha k'okhubha. Si kpenamkpen f'achibhi bi asi, anang-ẹ.”
\p 
\v 38 Ọvaarnọng oben bi, “Kimham ójekha ttar-m. Kaam ńsi kpenamkpen fa nchibhi nnang-ẹ. Ọttọhk kpenamkpen f'ábira aror, kaam ńsi-osi nnang-ọ.”
\p 
\v 39 Mẹ wọ, anọng biphyir ọmaana ọvaarnọng ajekha ka Jọrdan. Ọvaarnọng e, ọbaakha Barzilayi obiro ọsẹ-ẹ ittabọhng. Mando kwa Barzilayi ọkpa nnam ọbhana k'obhon kwẹ.
\p 
\v 40 Mada ọvaarnọng ojek k'okhubha kwa Gilgal, Kimham ọtzọhn-ẹ abẹ ojekha. Asoja pa Juda biphyir ọmaana ibhaakha rani s'agbong-nọng p'Israẹl akk'ọvaarnọng atzima ajekha k'okhubha.
\p 
\v 41 Ogbe kobhiri, ajinọng p'Israẹl biphyir am-akwu k'ọvaarnọng, akwu aben-ẹ bi, “Osi yan kwa votte paman pa Juda afhu ọvaarnọng atzim-ẹ ọmaana ẹhọhmmọr chẹ, ọttara ajinọng pa Devid biphyir ajekha Jọrdan afona o?”
\p 
\v 42 Iwa ajinọng pa Juda biphyir abhina ajinọng p'Israẹl bi, “Iwa mosi mando okhuri bi, ọvaarnọng mode anọng bani. Mbọng vọ on-ode ittemdọkhiji sabọng o? Mokk'ọttọhk manda vani f'ọvaarnọng ọtzọkha ochi o? Mokk'ọttọhk manda vani ọtzọkha ọnang for saman o?”
\p 
\v 43 Mẹ wọ, ajinọng p'Israẹl an-abhina ajinọng pa Juda bi, “Maman ọkhaam ngọma jobh m'ẹvaar nda ẹ, mẹ wọ, mọkhaam Devid ọtzam ọyọhnga bọng e. Osi yan kwa bọng arẹkhi man manda o? Maman arang iwa ode acheden-nọng oben bi, ọvaarnọng kwaman ọkpa nnam.”
\p Kaambi mẹ wọ, ajinọng pa Juda achina ororo agbana odik nwa.
\c 20
\s1 Shẹba okhe Devid ẹkhọhr
\p 
\v 1 Iwa ọkhọkhọra wani owobh mẹ kw'okpen Shẹba kw'ode nnwa kw'ijinọng kwa Bikiri, kw'ofon k'ẹkhọma cha Bẹnjamin. Wa ogyi obukpọhng, ọkpẹbh oben bi,
\q1 “Maman ekkema ka Devid kọkhaam,
\q2 man ekkema ka nnwa kwa Jẹsẹ kọkhaam!
\q1 Anọng p'Israẹl o, ọnọng-ọnọng ochina k'ọhọhm kwẹ e!”
\p 
\v 2 Mando kw'ajinọng p'Israẹl biphyir abin aji Devid, atza atzọn Shẹba kw'ode nnwa kwa Bikiri, abẹ. Yina, ajinọng pa Juda ttẹwọr ka Jọrdan maa, apyiri ka Jẹrusalẹm, abe k'okhubha kw'ọvaarnọng.
\p 
\v 3 Mada Devid okhun k'ẹvaar-ttọhmma chẹ ka Jẹrusalẹm, ọtzọkha akkọra-panọng pẹ jobh p'okk'ofona oji bi, bẹ akkeri ẹvaar-ttọhmma, ohok k'ọhọhm wani, ọtzọkha bẹ ohok k'irekh-irek kw'abaabhi. Iwa om-okkeri bẹ, yina, bẹ abẹ koyim. Iwa panọng mba awobh m'ibe rani mach'apopa maa, bẹ ape.
\p 
\v 4 Iwa ọvaarnọng oben Amasa bi, “Tzima iwu ittaan ayeri ajinọng pa Juda ttara kọ ọkhaam, bọng akwu.”
\v 5 Yina, mada Amasa ofon bi, otza oyeri ajinọng pa Juda, okponga kẹ maa, ogbe kw'ọvaarnọng ọkk'ẹ ọkha, ọkwọbha.
\p 
\v 6 Mẹ wọ ẹ, Devid on-oben Abishayi bi, “Kker e, itzama sa Shẹba kw'ode nnwa kwa Bikiri ósi man, íyọhnga s'iwa Absalọm osi e. Kọ tzima ajinọng p'itta kwọ akhubh-ẹ. Oni mando ode, kẹ óre idedenmon s'igaang-ọgaangi ore, ọtza ochubha mẹ, ọnaanga man.”
\v 7 Mando kw'ajinọng pa Joab, ọmaana anọng pa Kẹrẹt ọmaana anọng pa Pẹlẹt, ttara akkenggitza biphyir, atzori ka ndọhna s'Abishayi kw'ode odenho, afona. Wa bẹ abina ka Jẹrusalẹm akhubh Shẹba, kw'ode nnwa kwa Bikiri.
\p 
\v 8 Mada bẹ awobh k'ẹtzakpa ch'ideden ka Gibeọn, Amasa okwu okhebha bẹ mẹ. Wa Joab ọfọr egbong-nya chẹ, ọkpa mkpasin k'erin kw'ọdabhi imaana s'ijaabhi nnam mfa s'okhe k'ọpa. Mada oreng bi ochina ororo, sẹ irọbha k'ọpa itto.
\p 
\v 9 Joab oben Amasa bi, “Ọgbaanotte kwaam, ọsọ-ọ yan?” Joab otzima odimbọhk kwẹ ọbọkha Amasa k'agba-phyubha mach'oben bi, ọbaakh-ẹ ọbaakha.
\v 10 Amasa otzum kokhe k'imaana sa Joab otzim k'ọbọhk. Joab okhum-ẹ imaana nnuma k'ẹbhọr maa, abhọri ayin atto m'irerek. Okhum-ẹ ogbe nwuma wani kẹ-khẹ, Amasa ope. Mẹ wọ, Joab ọmaana ọgbaanotte Abishayi akhubh Shẹba kw'ode nnwa kwa Bikiri.
\p 
\v 11 Iwa ojinọng wani k'ottem kw'anọng pa Joab, obe Amasa k'ẹbhabhaanga, oben bi, “Ọnọng kpenamkpen kw'orong bi, owobh ka Joab ọmaana ka Devid, tte ọtzọn Joab abẹ!”
\v 12 Amasa oyim ọbangi m'izi sẹ m'eden-ttem. Ojinọng nwa on-ore bi, agbong-nọng biphyir am-atza abe mẹ. Mada ore bi ọnọng kpenamkpen kw'opyiri m'ibe s'Amasa oyim, om-ọpaangi obe, ọn-ọtzọr Amasa obina k'eden orur-ẹ k'owoni wani, ọtzọkha ibara obubh-ẹ.
\v 13 Mada bẹ akk'Amasa atzini abina k'eden, ajinọng biphyir afona atza atzọn Joab abẹ bi, bẹ akhubh Shẹba kw'ode nnwa kwa Bikiri.
\p 
\v 14 Shẹba ọkpaanga ngọma s'Israẹl biphyir maa, opyiri k'Abẹl Bẹt-Maka, obiro ọkpaanga ẹkhọma ch'anọng pa Bikiri p'iwa atzobh for sabẹ, atzọn Shẹba abẹ.
\v 15 Agbong-nọng biphyir p'atzọni Joab abẹ, akwu akhọri Shẹba akhe k'ottem k'Abẹl Bẹt-Maka. Bẹ ayaabha igbo atzima abọkha iyaan-iyaan kw'echumi ch'odedenmon. Bẹ am-akhonga bi, avọhkhi echumi nda.
\v 16 Yina, kwanọng wani kw'odongi-odongi owobha k'odedenmon ọkpẹbh bi, “Bọng yonga itzọhng e! Bọng yonga itzọhng e! Bọng yeri Joab orenga ọbaang-m, ifha ḿgbaakh-ẹ atzim.”
\v 17 Joab orenga otzor-ẹ ka for, kwanọng nwa ọbọbh-ẹ bi, “Kọ wọ ade Joab o?”
\p Obhina bi, “Kaam wọ e.”
\p Kwanọng nwa oben-ẹ bi, “Yong itzọhng abhaanga odik kwa kaam ọtzọhmnọng kwọ ngaam bi, ọgbaak.”
\p Oben-ẹ bi, “Kaam mminyong itzọhng e.”
\p 
\v 18 Kwanọng nwa ochina ororo oben bi, “Iwa anọng am-aben bi, ‘Ọkk'ọha kwẹ ode bi, abeni bi akhaama ebhina, china k'Abẹl.
\v 19 Maman bọ ode anọng p'arori ẹmẹm, mobiro ode anọng p'akhaam nnam-ophephe k'Israẹl e. Kọ am-akhonga bi, adimi odedenmon kw'ode ẹranga ch'Israẹl e. Osi yan kwa kọ am-aben bi, adimi ekkema ch'Ọvaar Ibinọkpaabyi o?”
\p 
\v 20 Joab obhina bi, “Tzọmi-tzọmi okponga k'idachen! Tzọmi-tzọmi okponga k'idachen bi, kaam arang ngibhi, ayongi mẹ ndimi obhon!
\v 21 Kwẹ mando kode. Ode bi, ojinọng wani kw'okpen Shẹba, kw'ode nnwa kwa Bikiri kw'ofon ka mgbegbeho s'Ephraim, kẹ wọ ọkk'ọbọhk kwẹ ọyaangi bi, obun ọvaar Devid. Bọng anang-m ojinọng nwa wani, kaam ńtte obhon nwa ọbọhk otte.”
\p Kwanọng nwa on-oben Joab bi, “Mọbhari eho chẹ k'ọbaakha okhubha ọnang-ọ.”
\p 
\v 22 Mando kwa kwanọng nwa oreng makhọra, otza okhebha anọng biphyir ttara adongiji pẹ, bẹ akpaara Shẹba kw'ode nwa kwa Bikiri eho, abhari Joab k'ọbaakha okhubha. Mẹ wọ, Joab ogyi obukpọhng otzima oben anọng pẹ biphyir atte odedenmon nwa ọbọhk, ọnọng-ọnọng ọkpa nnam k'ọhọhm kwẹ. Wa Joab obiro ọkpa nnam k'ọvaarnọng ka Jẹrusalẹm.
\s1 Akhaan-nọng pa Devid
\p 
\v 23 Iwa Joab wọ ode odenho kw'agbong-nọng p'Israẹl \it bi waam\it*; Bẹnaya kw'ode nnwa kwa Jẹhoyada ode odenho kw'agbong-nọng pa Kẹrẹt ọmaana agbong-nọng pa Pẹlẹt.
\v 24 Adoniram ode oho kw'asi-itzọhm. Jehoshaphat nnwa kw'Ahilud ode ọkkẹr-idik s'ikk'itta.
\v 25 Sheva ode ọkkẹri; Zadọk ọmaana Abiyata ade afọhnẹja.
\v 26 Iwa Ira kw'ofon Jair ode ọfọhnẹja kwa Devid.
\c 21
\s1 Devid otzuk odik kwa Saul osi anọng pa Gibeọn
\p 
\v 1 K'ogbe kw'iwa Devid ọdabhi ẹvaar, wa okwo f'ideden owobh ka cho manda attaan. Wa Devid oror itzitzikha s'Ọvaar Ibinọkpaabyi m'odik nwa. Ọvaar Ibinọkpaabyi oben bi, “Okwo mva oreng k'osisi kwa Saul, ọmaana ẹnọmma chẹ, da bẹ afhu anọng pa Gibeọn.”
\v 2 Ọvaarnọng oyeri anọng pa Gibeọn, ọgbaak bẹ atzim. (Wa anọng pa Gibeọn Israẹl kafon, bẹ ade anọng p'Amọr p'arikhi. Wa anọng p'Israẹl akk'achekhi bi, bẹ atte bẹ ọbọhk aruk akpen. Yina, Saul ọkham bi ofhu bẹ okhuri eyibhi ch'oyibh-ẹ bi, ọkkaana anọng p'Israẹl ọmaana pa Juda.)
\v 3 Devid ọbọbh anọng pa Gibeọn bi, “Mbọng fa kaam ńsi nnang bọng? Yan wọ kwa ńnenga nsi ephyokhi, ifha bọng ádo ekkema ch'Ọvaar Ibinọkpaabyi?”
\v 4 Anọng pa Gibeọn abhin-ẹ bi, “Maman ẹfa kọkhaam bi, moror gol ọmaana silva ka mbọhk sa Saul, obiro ode ẹhọhmmọr chẹ. Maman ẹfa kobiro ọkhaama bi, mofhu ọnọng manda wani k'Israẹl.”
\p Devid on-obiro ọbọbh bi, “Mbọng fa bọng arori bi, nsi nnang bọng o?”
\p 
\v 5 Bẹ abhina ọvaarnọng bi, “Ọnọng nwuma kw'odimi man, ọkhami bi odimi man biphyir-phyir, man ibe manda rani k'ẹkhọma ch'Israẹl kọkhaam.
\v 6 Tte bẹ anang man va pa va pẹ p'ijinọng azenamfa mofhu, mọjana abukhi pabẹ k'itzitzikha s'Ọvaar Ibinọkpaabyi, ka Gibea kw'ode obhon kwa Saul, kẹ nwuma kw'Ọvaar Ibinọkpaabyi okk'otzekha.”
\p Mẹ wọ, ọvaarnọng oben bi, “Kaam ńtte bẹ ọbọhk otte ńnang bọng e.”
\p 
\v 7 Wa ọvaarnọng otte Mẹphiboshẹt kw'ode nnwa kwa Jonatan, kw'ode nnwa kwa Saul ọbọhk oruk akpen, okhuri ọnwọhngi kwa Devid ọmaana Jonatan kw'ode nnwa kwa Saul, akk'atzọkha k'itzitzikha s'Ọvaar Ibinọkpaabyi.
\v 8 Yina, ọvaarnọng ọtzọkha Armoni ọmaana Mẹphiboshẹt, p'ade va p'Aiya kw'ode nnwa kwa Rizpa ọmaani ọnang Saul. Obiro ọtzọkha va p'ijinọng azen pa Mẹrab kw'ode nnwa kw'ikwanọng kwa Saul, p'ọmaani ọnang Adriyẹl kw'ode nnwa kwa Barzilayi kw'ofon Mẹhola.
\v 9 Ọtzọkha bẹ ọnang anọng pa Gibeọn, p'afhu bẹ abira ajana abukhi pabẹ k'egbegbeho, k'itzitzikha s'Ọvaar Ibinọkpaabyi. Bẹ anọng azenamfa biphyir ape ogbe wani. Wa bẹ afhu bẹ k'echedenwu ch'ipha, da ipha s'abarli im-ittẹwọr.
\p 
\v 10 Rizpa kw'ode nnwa kw'ikwanọng kw'Aiya ọtzọkha ọbara-bina oruri k'itzakpa ọnang for sẹ. Owobha mẹ ttẹwọr m'ọphagbe maa, ẹrọng efona k'ọrọngkpakpa etzebh abukhi mbuma. Wa osi mando ifha anọnọhna aningi abukhi mba achi k'ẹya, nden s'ẹtzam nningi bẹ mbiri nchi k'erungi.
\v 11 K'ogbe kwa bẹ agbaakhi Devid odik kwa Rizpa kw'ode nnwa kw'ikwanọng kw'Aiya, kw'ode ọkkọra-kwanọng kwa Saul ọkk'ọsa,
\v 12 Devid ọtza ọtzọkha akhọbhi pa Saul ọmaana pa nnwa kwẹ Jonatan, k'anọng pa Jabẹsh-Gilead. (Wa anọng mba afhu abukhi pabẹ k'ipha sa Bẹt-Shan, kẹ da iwa anọng pa Philistiya akk'bẹ agbana, k'ogbe kwa bẹ akk'Saul afha ka Gilboa).
\v 13 Mando kwa Devid ọtza ọtzọkha akhọbhi pa Saul ọmaana pa nnwa kwẹ Jonatan kẹ. Obiro otzobha akhọbhi p'anọng pa bẹ akk'afha abira ajana abukhi pabẹ kẹ.
\p 
\v 14 Bẹ anọhnga akhọbhi pa Saul ọmaana pa nnwa kwẹ Jonatan k'epekhubh cha Kish kw'ode otte kwa Saul, ka Zẹla k'ẹkhọma cha Bẹnjamin. Bẹ abira asi odik kpenamkpen kw'ọvaarnọng obeni. Mada bẹ akk'mando asa, Ibinọkpaabyi ọbhaanga njọhm sabẹ s'irerek nna.
\s1 Mgbong s'aPhilistiya arim
\p 
\v 15 Wa anọng p'Israẹl ọmaana pa Philistiya abira arima egbong. Devid otzima anọng pẹ ọhakha, otza orima anọng pa Philistiya abẹ, maa ẹfa ẹhẹ-ẹ.
\v 16 Ishbi-Bẹnọb, nnwa wani k'ottem kwa va pa va pa Rapha, kw'ẹkhọhnma chẹ cha brons, ẹdọhbhi epyiri ẹdọhbh ch'ashẹkẹl arọbh chi, obiro otzima ọkkangkkaang ọbhakwẹ kw'ọkpa k'erin, oben bi, kẹ ofhu Devid.
\v 17 Yina, Abishayi nnwa kwa Zeruya okwu ọkkaana Devid. Obun oPhilistiya-nọng nwa, ọfhẹ-ẹ. Ajinọng pa Devid achekhi anang-ẹ bi, “Kọ man abẹ dọk kàtzọn atza egbong, ifha iyaan s'Israẹl iningi idimi.”
\p 
\v 18 Okwu opyiri k'ogbe mẹ, egbong ebire etto ọmaana anọng pa Philistiya ka Gọb. M'ogbe nwuma, Sibẹkayi kw'ofon Hushat ofhu Saph, kw'ode nnwa wani k'ottem kwa va pa va pa Rapha.
\p 
\v 19 K'egbong ẹdọdọk ọmaana anọng pa Philistiya ka Gọb, Ẹlhanan kw'ode nnwa kwa Jair kw'ofon Bẹtẹlẹhẹm, ofhu Golayat kw'ofon Git, kw'ọkhaam ọkhọhn kw'ọdọhni mach'echi ch'oyokhi-ekpo.
\p 
\v 20 K'egbong ẹdọdọk ch'etto ka Gat, wa ọkhaam ojinọng wani kw'ofu \it bi gbuk\it*, kw'ọkhaam nnọhna nzadani k'ọbọhk kpenamkpen, ọmaana nnọhna nzadani k'obho kpenamkpen, biphyir-phyir wa ọkhaam nnọhna ẹrọbh obhiri nna. Wa obiro ode nnwa-mmona kwa Rapha.
\v 21 Wa mada olukhi Israẹl, Jonatan kw'ode nnwa kwa Shimeyi kw'ode ọgbaanotte kwa Devid, ọfhẹ-ẹ.
\p 
\v 22 Iwa anọng mba anna ade, va pa va pa Rapha kw'ofon Gat. Wa Devid ọmaana ajinọng pẹ bọ afhu bẹ.
\c 22
\s1 Ẹmọng cha Devid ch'ẹtzọhnga
\p 
\v 1 Mada Ọvaar Ibinọkpaabyi ọkkaan ọrọbha Devid ka mbọhk s'attattaanga-nọng pẹ biphyir, ọmaana ka mbọhk sa Saul, wa ọkkọhn ẹmọng ọnang Ọvaar Ibinọkpaabyi.
\v 2 Oben bi:
\q1 “Ọvaar Ibinọkpaabyi wọ ode ẹtzakpa chaam,
\q2 obiro ode ichubhabe saam,
\q2 ọmaana ọkkaan kwaam;
\q1 
\v 3 Ibinọkpaabyi kwaam wọ ode ẹtzakpa chaam, cha kaam nchubh,
\q2 ode ọkhọhnkpa ọmaana ẹfa ch'ẹnaanga chaam.
\q1 Kẹ wọ ode etzumi-nnam chaam, ichubhabe saam ọmaana ọkkaan kwaam,
\q2 kẹ wọ ọkkaan-m ka mbọhk s'agbagbaana.
\b
\q1 
\v 4 “Kaam nyeri Ọvaar Ibinọkpaabyi, kw'ọbaan k'ẹtzọhnga,
\q2 kw'ọkk'aam ọkkaana ka mbọhk s'attattaanga-nọng paam.
\q1 
\v 5 “Ebukhaya ch'obo ẹkk'aam ẹbhọri,
\q2 nttẹri s'ekhibhi ẹkk'aam ẹfa ẹna.
\q1 
\v 6 Ndik s'epekhubh nkk'nyokha ngọr-m,
\q2 agbagbara p'obo akk'aam abẹ ayina.
\b
\q1 
\v 7 “Kaam nyeri Ọvaar Ibinọkpaabyi k'iyayakhi-dik saam,
\q2 Kaam nyeri Ibinọkpaabyi kwaam bi ọkkaan-m.
\q1 Ọvaar Ibinọkpaabyi ọbhaanga ẹmọng chaam k'ọhọhm kwẹ;
\q2 ẹmọng cha mmomi ẹkk'ẹ ẹtta k'itzọhng.
\b
\q1 
\v 8 “Ọyagbin ọfhọni obiro ọkhaama opoma,
\q2 agbaari p'ọrọngkpakpa anyengi,
\q2 bẹ afhọni okhuri idọdọkhi sẹ.
\q1 
\v 9 Irorong iyin-ẹ k'ahung-mma,
\q2 ekpon ch'echi ibe eyin-ẹ k'ẹmma,
\q2 akpongkkang abira awọma ekpon mẹ.
\q1 
\v 10 Kẹ ọbhaangi ọrọngkpakpa orenga mẹ ọhakha,
\q2 eboni ch'epyi \it bi kaang\it* ewobh ka mmokpatzọkhi sẹ.
\q1 
\v 11 Kẹ ovur ka chẹrubim okhur,
\q2 orenga ka mbabaang s'ọphapha okhur.
\q1 
\v 12 Otzim orungibanga osi ikhira s'ikhọr-ẹ,
\q2 osi eboni ch'ẹrọng ch'epyi erungi \it bi kkaang\it* k'ọrọngkpakpa.
\q1 
\v 13 K'ottem kw'ọyaanttaani, k'itzitzikha sẹ,
\q2 akpongkkang p'ekpon awọma.
\q1 
\v 14 Ọvaar Ibinọkpaabyi otto etzum mach'ẹbhaang-kpon k'ọvaarbhon kwẹ.
\q2 Ọvaar Ibinọkpaabyi kw'Ọyọhng obiro ọkpẹbh ẹmọng k'ẹrọng.
\q1 
\v 15 Kẹ ọtta ayuk, okwuri attattaanga-nọng,
\q2 otzima akpongkkang p'awọm ekpon ch'ideden okhubh bẹ.
\q1 
\v 16 Ẹmọng ch'Ọvaar Ibinọkpaabyi ọkpẹbhi,
\q2 ọwọhng kw'oji k'ahung-mma pẹ,
\q1 osi nttẹri s'araanga p'ideden njana,
\q2 osi agbaari p'ọyagbin abira atte eje.
\b
\q1 
\v 17 “Kẹ owobh k'ẹrọng, onemi ọbọhk ọbọkh-m,
\q2 ọrọbh-m k'asi p'adong-odong, otzima oyin ka.
\q1 
\v 18 Kẹ ọrọbh-m ka mbọhk s'ẹfa ch'attattaanga-nọng paam,
\q2 ka mbọhk s'attattaanga-nọng paam, p'agaangi ayọhng-m.
\q1 
\v 19 Bẹ arim-m abẹ, k'ewu ch'idik ikhebh-m,
\q2 kaambi mẹ wọ, Ọvaar Ibinọkpaabyi wọ iwa ode etzumi-nnam chaam.
\q1 
\v 20 Kẹ ohokh-m k'ibe s'iwoni-owoni,
\q2 ọkkaan-m, okhuri da ọdaami ettem ttar-m.
\b
\q1 
\v 21 “Ọvaar Ibinọkpaabyi ọkk'aam ochora otzor k'etzora chaam,
\q2 ọkk'aam ochora otzor k'awurada pa mbọhk saam.
\q1 
\v 22 Da kaam nkk'ndora ka nden s'Ọvaar Ibinọkpaabyi,
\q2 aponga kaam kapyibhi, da nni nnam mkpa mbọra Ibinọkpaabyi kwaam.
\q1 
\v 23 Kaam nkk'aphaangi pẹ biphyir nhokha,
\q2 kaam nnam kimbiri mkpa mbọra ndọhna sẹ.
\q1 
\v 24 Kaam oponga-pyibha k'itzitzikha sẹ kingaam,
\q2 nkk'for saam ndọra k'ẹkhọngkwuri.
\q1 
\v 25 Ọvaar Ibinọkpaabyi ọkk'aam ochora k'etzora chaam,
\q2 ọkk'aam ochora otzor k'awurada paam p'ore.
\b
\q1 
\v 26 “Ọnọng nwuma kw'ọhak eho ọnang-ọ,
\q2 kẹ wọ kwa kọ ahọk idadaakha sọ.
\q2 Kọ asi ejibha atzima atzor, ọnọng kw'oni oponga-pyibha ọkhaam.
\q1 
\v 27 Ọnọng kw'owur-owur, kẹ kw'akhọhk awurada pọ,
\q2 yina, ọnọng kw'osi ebibya, kọ asẹ-ẹ ọgbaan.
\q1 
\v 28 Kọ akkaan ọnọng kw'okhom for sẹ,
\q2 yina, ahak ọnọng kw'are bi, oge for ewobha.
\q1 
\v 29 Ọvaar Ibinọkpaabyi, kọ wọ ade ottwikkaang kwaam,
\q2 Ọvaar Ibinọkpaabyi osi ipyerungi saam, in-ide iyaan.
\q1 
\v 30 Kọ akkaan-m bi, nnọbh mmaam k'ottem kw'agbong-nọng p'attaang-m,
\q2 k'ẹfa ch'Ibinọkpaabyi kwaam, kaam mfha ngwur abaakha pabẹ njekha.
\b
\q1 
\v 31 “Eden ch'Ibinọkpaabyi etzor-otzor:
\q2 Atzim p'Ọvaar Ibinọkpaabyi epina kakhaam
\q1 Kẹ ode ọkhọhnkpa kw'ọbaabh anọng p'achubh ka kẹ.
\q1 
\v 32 Anyi wọ kw'ám-okpobha oyongi Ọvaar Ibinọkpaabyi o?
\q2 Anyi wọ ode Ẹtzakpa chaman, oyongi Ibinọkpaabyi o?
\q1 
\v 33 Kẹ Ibinọkpaabyi wọ otzim ẹfa chẹ ọbaabh-m,
\q2 obiro osi ọbaabha eden chaam.
\q1 
\v 34 Kẹ osi mmo saam ngaama ẹfa macha s'ochimi,
\q2 osi-m mbe k'obe f'ogor-ogori.
\q1 
\v 35 Kẹ okpebhi mbọhk saam erima,
\q2 mbọhk saam mfha mmena oyuk kwa brons.
\q1 
\v 36 Ẹkkaana chọ ch'anang-m ede ọkhọhnkpa kwaam,
\q2 ẹkkaana chọ ẹkk'aam ẹsa mbar.
\q1 
\v 37 Kọ asi-m nnenga k'ọkkadeden kw'owoni-owoni,
\q2 mmo-dọhngi kaam kindebh.
\b
\q1 
\v 38 “Kaam ngwubhi attattaanga-nọng paam, mbiri ndimi bẹ,
\q2 nnam kimkpa maa, ndimi bẹ.
\q1 
\v 39 Ndimi bẹ biphyir-phyir, bẹ dọk kafha abina,
\q2 bẹ an-atto ayim-m ka mmokpatzọkhi.
\q1 
\v 40 Kọ anang-m ẹfa ch'egbong oririma,
\q2 asi attattaanga-nọng paam, ahakha nho anang-m.
\q1 
\v 41 Kọ asi attattaanga-nọng paam arọbh-m,
\q2 kaam mbiri ndimi anọng p'attaang-m.
\q1 
\v 42 Bẹ abhom aror ẹkkaana, ọnọng kw'ọkkaan bẹ kode.
\q2 Bẹ abhom ayeri Ọvaar Ibinọkpaabyi, bẹ ebhina kobiro ọnang.
\q1 
\v 43 Kaam ngokhi bẹ ayọhri mach'ọkpọhm kw'irerek,
\q2 nduk bẹ, mbiri mbari bẹ mmo mach'ẹdọdọhbhi cha mkpaanga-den.
\b
\q1 
\v 44 “Kọ akk'aam akkaana ka mbọhk s'idibhon s'irim-m abẹ,
\q2 ahokh-m mach'oho kw'idibhon.
\q1 Anọng p'iwa nninong an-awobha k'irekh-irek kwaam.
\q2 
\v 45 Akhekhennọng awobh k'ojora k'itzitzikha saam;
\q2 ogbe kwa bẹ abhaang odik okhuri kaam \it bi kpaar\it*, bẹ ahakha eho anang-m.
\q1 
\v 46 Ẹfa ẹha akhekhennọng mba biphyir,
\q2 bẹ afona k'ochubhabe fabẹ, akwu k'opoma.
\b
\q1 
\v 47 “Ọvaar Ibinọkpaabyi orukhi akpen! Ẹtzọhnga ewobha ẹnang Ẹtzakpa chaam!
\q2 Tte abarada awobha anang Ibinọkpaabyi, kw'ode Ẹtzakpa chaam, obiro ode Ọkkaan kwaam!
\q1 
\v 48 Kẹ wọ ode Ibinọkpaabyi kw'om-otzukha idik k'eho chaam,
\q2 kẹ ohokhi idibhon bi, iwobha k'irekh-irek kwaam,
\q2 
\v 49 kẹ wọ ọkkaan-m ka mbọhk s'attattaanga-nọng paam.
\q1 Kọ atzin-m k'ebe ch'ẹyọhng ch'attattaanga-nọng paam,
\q2 akkaan-m ka mbọhk s'ọgbagbaana.
\q1 
\v 50 Kẹ wọ osi, kaam ńdọhnga kọ Ọvaar Ibinọkpaabyi, k'ottem kw'idibhon;
\q2 kaam ńkkọhn amọng ndima ndọhnga che chọ.
\b
\q1 
\v 51 “Kẹ ọnangi ọvaarnọng kwẹ ngema sa ndeden,
\q2 osi ejibha-barada ọnang nwuma kw'obyengi ana k'eho,
\q2 kw'ode Devid ọmaana va pa va pẹ maa, ogbe ode.”
\c 23
\s1 Akponga-nnam-dim pa Devid
\p 
\v 1 Ma wọ ode akponga-nnam-dim pa Devid:
\q1 “Atzim pa Devid kw'ode nnwa kwa Jẹsẹ ọgbaakhi,
\q2 atzim p'ojinọng kw'Ọvaar Ibinọkpaabyi kw'Ọyọhng okk'otzini k'ẹrọng,
\q1 ojinọng kw'Ibinọkpaabyi kwa Jekọb, okk'ana obyengi k'eho,
\q2 kw'ode okkenggitza kwa bẹ akkọhni k'amọng daman-daam p'Israẹl:
\b
\q1 
\v 2 “Egwugwuma ch'Ọvaar Ibinọkpaabyi ereng ka kaam ẹgbaak atzim,
\q2 atzim pẹ awobh-m k'ẹdaak.
\q1 
\v 3 Ibinọkpaabyi kw'anọng p'Israẹl ọgbaakhi atzim,
\q2 Ẹtzakpa ch'anọng p'Israẹl eben-m bi:
\q1 ‘Ọnọng kw'ọdabhi anọng k'eden ch'etzor-otzor,
\q2 otzim ojora f'Ibinọkpaabyi ọdabh anọng;
\q1 
\v 4 kẹ ode mach'iyaan s'ekpebha s'ewuchen ẹmaani,
\q2 k'ekpebha ch'eboni enede,
\q1 mach'iyaan s'imaani k'ogbe kw'ẹrọng ekk'ebhiri,
\q2 ch'esi araraari amen k'irerek.’
\b
\q1 
\v 5 “Idikha ira ẹhọhmmọr chaam en-etzori ttara Ibinọkpaabyi,
\q2 k'odik-ọkka ira kẹ echekhi ch'ipemanitzor, kosi ttar-m,
\q2 ira echekhi ch'ọphaari obiro ọbọkha otzima k'ọphaangi kpenamkpen, kosi ttar-m;
\q1 k'odik-ọkka kẹ ọkk'ẹnaanga chaam, ọsa eyin k'eden,
\q2 obiro osi idik ọnang-m, otzor k'ochibhi kpenamkpen kwaam.
\q1 
\v 6 Yina, abibyanọng ade mach'afhodima, pa bẹ abhari okhubha wani,
\q2 da ọnọng oni bẹ ka mbọhk ofha otzima.
\q1 
\v 7 Ọnọng kpenamkpen kw'ọn-ọgbọhkhi,
\q2 om-otzima ọtzọhm-ttọhk f'ode okkonga, obiro ọdọhni mach'ẹmma ch'ọkhọhn ọbọkha afhodima;
\q2 bẹ akwọmi bẹ biphyir-phyir, k'ibe sa bẹ awobh.”
\s1 Akkenggitza pa Devid
\p 
\v 8 Ma wọ ode che p'akkenggitza pa Devid:
\p Ocheden-nọng kw'ode oho k'ottem kw'anọng attaan ode Joshẹb-Bashẹbẹt, kw'ofon Takemọn. Wa kẹ otzim ọkhọhn fẹ orima ajinọng nnọhna mfa abẹ, p'ofhu k'ogbe wani.
\p 
\v 9 Ottong afa ode Ẹleyaza kw'ode nnwa kwa Dodo kw'ofon Aho. Mach'ọnọng wani k'ottem kw'akkenggitza attaan, wa kẹ owobh ttara Devid, k'ogbe kwa bẹ alukhi aPhilistiya p'iwa atzobh ka Pas-Damim bi, arima egbong. Wa agbong-nọng p'Israẹl atzọr akpa nnam,
\v 10 yina, Ẹleyaza obe \it bi pyiir\it* ofhu aPhilistiya maa, ọbọhk okwokh-ẹ obiro ọpẹ-ẹ, ọraakhi k'ọkkangkkaang. Wa Ọvaar Ibinọkpaabyi ọnang bẹ ekhema ch'ideden m'ewu nduma. Mando kw'agbong-nọng akpa nnam k'Ẹleyaza. Yina, wa on-okhinggẹ orik bi, bẹ awọra anọng p'akk'apa ekpo.
\p 
\v 11 Ottong attaan ode Shama kw'ode nnwa kw'Agi kw'ofon Harar. K'ogbe kw'anọng p'aPhilistiya atzobh k'ibe rani, s'owoni kw'achi-mọma ahaabh-ọhaabh, agbong-nọng p'Israẹl arọbh aji bẹ.
\v 12 Yina, Shama obe \it bi pyiir\it* k'ottem kw'owoni nwa, ọkpa anọng p'aPhilistiya eden, ofhu bẹ. Wa Ọvaar Ibinọkpaabyi ọnang bẹ ekhema ch'ideden.
\p 
\v 13 M'ọphagbe, ajinọng attaan k'ottem kw'oho p'akkenggitza ẹrọbh obhiri jobh, atza akhebha Devid k'ọmma kw'itzakpa kw'Adulam, k'ogbe kw'ẹkhaan ch'anọng p'aPhilistiya ebhingi k'Ẹttẹri cha Rephayim.
\v 14 K'ogbe nwuma kwa Devid owobh k'ichubhabe, akkeri-ẹbaakhamma cha Philistiya awobh ka Bẹtẹlẹhẹm.
\v 15 Wa asi adaak Devid, on-oben bi, “Kpe o, ira ọnọng ọfha ọkhaabha asi k'esipe ch'ẹbaang ẹbaakhamma cha Bẹtẹlẹhẹm, ọnang-m ngwo e!”
\v 16 Mando kw'akkenggitza mbuma attaan amaami m'ibhingabe sa Philistiya, atza akhaabha asi k'esipe ch'ẹbaang ẹbaakhamma cha Bẹtẹlẹhẹm, atzima achena Devid bi, ogwo. Yina, obhum asi mbuma ogwo-ogwo, on-otzer obyengi bẹ m'itzitzikha s'Ọvaar Ibinọkpaabyi, mach'ẹnanga.
\v 17 Oben bi, “Tzọmi-tzọmi okponga k'idachen, o Ọvaar Ibinọkpaabyi, bi kaam nsi odik-dema nwa! Asi mba abari odik mach'izi s'ajinọng mba p'akhe akpen pabẹ k'obo.” Devid obhum bẹ ogwo-ogwo.
\p Mando kw'iwa akkenggitza mbuma attaan asi odik-barada nwa.
\p 
\v 18 Abishayi kw'ode ọgbaanotte kwa Joab, kw'obiro ode nnwa kwa Zeruya ọmaani, wọ iwa ode oho kwa bẹ anọng attaan. Wa otzim ọkhọhn fẹ orima ajinọng arọbh chi abẹ, ofhu bẹ. Ofona mẹ ọtza che mach'ayok mbonggo attaan.
\v 19 Wa bẹ anang Abishayi ededen ch'ẹbari ọtzam ẹyọhnga ch'ayok mbonggo attaan. Kẹ on-ode odenho kwabẹ, kaambi ode bi iwa ẹkhaan chabẹ kọttar.
\p 
\v 20 Bẹnaya kw'ode nnwa kwa Jẹhoyada, kw'obiro ode ọkkakaama kw'ofon Kabzil, wa osi idik-barada. Wa ofhu akkenggitza p'ideden afa pa Moab. Obiro ọhakha k'ipekhuma ọtza ofhu ekye k'ewu ch'eboni etzebhi.
\v 21 Wa kẹ obiro ofhu ọnọng kw'ofon Ijip, kw'ojibhi ojinọng. Chibhi da iwa ojipnọng nwa otzim ọkhọhn fẹ k'ọbọhk, Bẹnaya ọtza orim-ẹ abẹ ttara ochikhura. Ọbọkha ojipnọng nwa ọkhọhn fẹ ọna, otzima ọfhẹ-ẹ.
\v 22 Idik-barada s'iwa Bẹnaya, kw'ode nnwa kwa Jẹhoyada, osi rọ ma. Wa obiro ọtza che mach-akkenggitza mbonggo attaan.
\v 23 Wa bẹ an-anang-ẹ ikpokpobha s'iyọhng s'ajinọng mbonggo ẹrọbh obhiri jobh. Yina, wa kẹ k'ẹkhaan ch'anọng mba attaan kọttar. Mando kwa Devid ọsẹ-ẹ odenho kw'abaabhi pẹ.
\b
\li2 
\v 24 K'ottem kw'anọng ẹrọbh obhiri jobh ode:
\li3 Asahẹl kw'ode ọgbaanotte kwa Joab,
\li3 ọmaana Ẹlhanan kw'ode nnwa kwa Dodo kw'ofon Bẹtẹlẹhẹm,
\li3 
\v 25 ọmaana Shama kw'ofon Harod,
\li3 ọmaana Ẹlika kw'obiro ofona Harod,
\li3 
\v 26 ọmaana Hẹlẹz kw'ofon Palti,
\li3 ọmaana Ira kw'ode nnwa kw'Ikẹsh kw'ofon Tẹkoa,
\li3 
\v 27 ọmaana Abiyẹza kw'ofon Anatọt,
\li3 ọmaana Sibẹkayi kw'ofon Hushat,
\li3 
\v 28 ọmaana Zalmọn kw'ofon Aho,
\li3 ọmaana Maharayi kw'ofon Nẹtophat,
\li3 
\v 29 ọmaana Hẹlẹb nnwa kwa Baana kw'obiro ofona Nẹtophat,
\li3 Ittayi nnwa kwa Ribayi kw'ofon Gibea k'ẹkhọma cha Bẹnjamin,
\li3 
\v 30 Bẹnaya kw'ofon Piraton,
\li3 ọmaana Hidayi kw'ofon ka nttẹri sa Gaash,
\li3 
\v 31 ọmaana Abi-Albọn kw'ofon Arbat,
\li3 ọmaana Azmavẹt kw'ofon Barhum,
\li3 
\v 32 ọmaana Eliyaba kw'ofon Shalbọn kw'ode nnwa kwa Jashẹn, ọmaana Jonatan
\li3 
\v 33 kw'ode nnwa kwa Shama kw'ofon Harar,
\li3 ọmaana Ahiyam kw'ode nnwa kwa Sharar kw'obiro ofona Harar,
\li3 
\v 34 ọmaana Ẹliphẹlẹt kw'ode nnwa kw'Ahasbayi kw'ofon Maakat,
\li3 ọmaana Eliyam kw'ode nnwa kwa Ahitophẹl kw'ofon Gilọn,
\li3 
\v 35 ọmaana Hẹzro kw'ofon Kaamẹl,
\li3 ọmaana Paarayi kw'ofon Arbit,
\li3 
\v 36 Igal kw'ode nnwa kwa Natan kw'ofon Zoba, Bani kw'ofon Gad,
\li3 
\v 37 ọmaana Zẹlẹk kw'ofon Ammọn,
\li3 ọmaana Nahariya kw'ofon Berot, kw'ode otzim-egbongkpo kwa Joab kw'ode nnwa kwa Zeruya,
\li3 
\v 38 ọmaana Ira kw'ofon Itir,
\li3 ọmaana Garẹb kw'obiro ofona Itir,
\li3 
\v 39 ttara Uriya kw'ofon Het.
\li2 Biphyir-phyir, wa bẹ ade anọng ẹrọbh obhiri chi obhiri afa.
\c 24
\s1 Devid obhikhi agbong-nọng
\p 
\v 1 Iwa ettem ebire epyibh Ọvaar Ibinọkpaabyi etzima etzor anọng p'Israẹl ọmaan pa Juda. Kw'osi iwa ọchọma Devid otzima ẹkhọr otzor bẹ, oben bi, “Rọhng atza atzọkha ọnọng-mik kw'Israẹl ọmaana kwa Juda.”
\p 
\v 2 Mẹ wọ, ọvaarnọng oben Joab ọmaana adenho p'agbong-nọng p'awobh ttar-ẹ bi, “Bọng nọhng makhọra nnọmma s'Israẹl, bọng ttẹwọr ka Dan maa, apyiri ka Beershẹba, abhik ajinọng ifha kaam mfha nnonga obhik kwabẹ.”
\p 
\v 3 Mando kwa Joab obhin ọvaarnọng bi, “Tte Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwọ ọttara ọnọng-mik kw'agbong-nọng igbe arọbh azen ayongi-oyongi. Tte itta ọvaarnọng kwaam otzima chen pẹ ore kwẹ. Osi yan itta ọvaarnọng kwaam oben bi, osi odik-dema nwa o?”
\p 
\v 4 Wa atzim p'ọvaarnọng agaangi ayọhnga pa Joab ọmaana adenho mba pa agbong-nọng. Mando kwa bẹ abin aji ọvaarnọng, atza abhik agbong-nọng p'Israẹl.
\p 
\v 5 Mada bẹ akk'Jọrdan ajekha, bẹ abhing abaanga Aroẹ, k'ẹrakha-ẹrakha kw'obhon kw'owobh k'ẹttẹri. Bẹ arenga ka Gad achina ka Jaza.
\v 6 Bẹ arenga achina ka Gilead ọmaana k'ẹkhọma cha Tatim Hodshi, achina ka Dan Jaan, akhọri achina ka Sidon.
\v 7 Bẹ an-arenga achina k'ichubhabe sa Taya, ọmaana k'ibhon sa abaHiv ttara sa abaKenaan biphyir. Bẹ an-akponga nnam achina ka Beershẹba kw'owobh ka Nẹgẹv k'ẹkhọma cha Juda.
\p 
\v 8 Mada bẹ akk'arenga akpaanga irerek nna biphyir, bẹ akpa nnam ka Jẹrusalẹm k'okpong kw'aphe ọhawani ọmaana iwu ẹrọbh.
\p 
\v 9 Iwa Joab ọgbaak ọvaarnọng ọnọng-mik kw'agbong-nọng: Wa ọnọng-mik kw'afanọng p'Israẹl ode, nnọhna arọbh azen p'afha abọkha ọkkangkkaang. Ọnọng-mik kwa Juda ode nnọhna arọbh attaan obhiri arọbh afa obhiri jobh.
\p 
\v 10 Mada iwa Devid, okk'ẹnọng-mikha ch'agbong-nọng okyera, achibhi ayakh-ẹ atzim maa, on-oben Ọvaar Ibinọkpaabyi bi, “Kaam nkk'ẹkhọhngkwuri ch'ideden nsa k'odik nwa kwa nsi. Tzotzokhaan, Ọvaar Ibinọkpaabyi, bina anang oponga-pyibha kwa kaam ọtzọhmnọng kwọ. Kaam nkk'odidingi-dik nsa e.”
\p 
\v 11 Yina Devid ọphyọbha k'ekpebha, Ọvaar Ibinọkpaabyi okk'Gad kw'ode ọsẹjaakhi, obiro ode ore-ka-chen-anna kwa Devid, atzim ọgbaakha, oben bi:
\v 12 “Rọhng atza agbaak Devid bi, ‘Ma wọ ode odik kw'Ọvaar Ibinọkpaabyi ọgbaakhi: Kaam njọ-ọ achibhi attaan k'itzitzikha bi, atzekha wani kwa kaam ńdima mkpaara aponga pọ.’ ”
\p 
\v 13 Mando kwa Gad ọtza okhebha Devid, oben-ẹ bi, “Ma na ọdaakh-ọ bi okwo f'ideden owobha k'irerek sọ, ka cho attaan o? Na obiro ọdaakh-ọ bi, arọbh abharkpa p'attattaanga-nọng pọ akhubh bọng k'aphe attaan o? Na obiro ọdaakh-ọ bi, ọkhọhmana f'ideden otto okhebha irerek nna k'iwu ittaan o? Kọ nang ochibhi m'idik nna, ifha agbaakh-m ochibhi kwa nda mgbaak ọnọng kw'ọtzọhm-m.”
\p 
\v 14 Iwa Devid oben Gad bi, “Kaam ettem ẹyakh-m atzim. Tte motzer ọkhaama ottotto k'itzitzikha s'Ọvaar Ibinọkpaabyi, kw'inọngkwo sẹ ibar-ọbar, ottu kw'ámotto ka mbọhk s'anọng ọkhaam e.”
\p 
\v 15 Mando kw'Ọvaar Ibinọkpaabyi ọtzọhmi itzama s'ideden k'Israẹl, s'ittẹwọr k'ekpebha maa opyiri k'ogbe kwa bẹ akhe. Wa anọng nnọhna arọbh azenattaan obhiri chi, ape, ttẹwọr ka Dan maa apyiri Beershẹba.
\v 16 Mada orenga-eden kw'Ibinọkpaabyi onemi ọbọhk bi, odimi Jẹrusalẹm, Ọvaar Ibinọkpaabyi obhona ochibhi kwẹ kw'ọmmamma nwa. On-oben orenga-eden kwẹ bi, “Dọk kàsi! Tọr ọbọhk kwọ.” Wa orenga-eden nwa kw'Ọvaar Ibinọkpaabyi on-owobh k'ibe sa bẹ am-awobha agwuma abọkpa-mọma s'Arawuna kw'ofon Jẹbus.
\p 
\v 17 Mada Devid ore orenga-eden nwa kw'om-ofhu anọng, oben Ọvaar Ibinọkpaabyi bi, “Kaam nkk'ẹkhọhngkwuri nsa e; Kaam, okkeri-ayok, nkk'epina nsa e. Bẹ-bẹ ade mach'arukhimaan e. Bẹ ọttọhk kasi. Tte ettuma chọ ewobha ẹnang kaam, ọmaana ẹhọhmmọr chaam.”
\s1 Devid osi ijafọhnibe
\p 
\v 18 M'ewu nduma, Gad ọtza okhebha Devid oben-ẹ bi, “Rọhng avura atza asi ijafọhnibe anang Ọvaar Ibinọkpaabyi, k'ibe sa bẹ am-awobha agwuma abọkpa-mọma s'Arawuna kw'ofon Jẹbus.”
\v 19 Mando kwa Devid ovur mach'Ọvaar Ibinọkpaabyi okk'orenga ka Gad ọtzọhn-ẹ.
\v 20 K'ogbe kw'Arawuna on-okkeri, ore da ọvaarnọng ọmaana akhaan-nọng pẹ am-arenga atzor-ẹ, oyin k'iyaan ọtza ọrakha ottima k'itzitzikha k'irerek, m'itzitzikha s'ọvaarnọng.
\p 
\v 21 Arawuna ọbọbh bi, “Ode yan kw'itta ọvaarnọng kwaam, orori kaam ọtzọhmnọng kwẹ o?”
\p Devid obhina bi, “Kaam nkwu bi nkwu ndebh ibe sọ sa bẹ am-awobha agwuma abọkpa-mọma, ifha nsi ijafọhnibe mẹ nnang Ọvaar Ibinọkpaabyi e, k'odem kw'itzama s'itto ikhebha anọng mba ikwọhbha e.”
\p 
\v 22 Arawuna oben Devid bi, “Tte itta ọvaarnọng kwaam ọtzọkha ọttọhk kpenamkpen f'ọdaakh-ẹ, otzima osi ẹnanga e. Kkeri abhaam p'ẹnanga ẹkwọmichẹ ma, ọmaana atzekpa pa bẹ am-atzima agwuma abọkpa-mọma, ttara ayak p'abhaam p'atzima mach'ommen.
\v 23 K'ẹvaar chọ, kaam Arawuna ndọk ekpo mbya biphyir nnang ọvaarnọng. Tte Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwọ, ọtzọkha ẹjafọhni chọ.”
\p 
\v 24 Yina, ọvaarnọng obhina Arawuna bi, “Mma e, kaam ngaam bi ndebh ekpo mbya k'agbukha e. Kaam ẹjafọhni ẹkwọmichẹ, ch'eni kaam ọttọhk epe, kínsi nnang Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwaam.”
\p Mẹ wọ, Devid odebh ibe nna sa bẹ am-awobha agwuma abọkpa-mọma, ọmaana abhaam k'ashẹkẹl pa silva arọbh afa obhiri jobh.
\v 25 Wa Devid osi ijafọhnibe mẹ ọnang Ọvaar Ibinọkpaabyi. Osi ẹjafọhni ẹkwọmichẹ ọmaana ẹnanga ch'odidiri mẹ. Mẹ wọ e, Ọvaar Ibinọkpaabyi obhina njọhm sẹ s'irerek nnuma. Mando kw'itzama s'itto ikhebha anọng p'Israẹl ibiri ikwọhbha.
