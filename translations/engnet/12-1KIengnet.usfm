\v 12  \w But|strong="H3808"\w* \w when|strong="H1961"\w* \w I|strong="H5921"\w* leave \w you|strong="H5921"\w*, \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd*’s \w spirit|strong="H7307"\w* \w will|strong="H3068"\w* \w carry|strong="H5375"\w* \w you|strong="H5921"\w* \w away|strong="H5375"\w* \w so|strong="H1961"\w* \w I|strong="H5921"\w* \w can|strong="H5650"\w*’t \w find|strong="H4672"\w* \w you|strong="H5921"\w*. \w If|strong="H1961"\w* \w I|strong="H5921"\w* \w go|strong="H3212"\w* \w tell|strong="H5046"\w* Ahab \w I|strong="H5921"\w*’ve seen \w you|strong="H5921"\w*, \w he|strong="H3068"\w* won’t \w be|strong="H1961"\w* able \w to|strong="H3068"\w* \w find|strong="H4672"\w* \w you|strong="H5921"\w* \w and|strong="H3068"\w* \w he|strong="H3068"\w* \w will|strong="H3068"\w* \w kill|strong="H2026"\w* \w me|strong="H5046"\w*. \w That|strong="H3045"\w* \w would|strong="H3068"\w* \w not|strong="H3808"\w* \w be|strong="H1961"\w* fair, \w because|strong="H5921"\w* \w your|strong="H3068"\w* \w servant|strong="H5650"\w* \w has|strong="H3068"\w* \w been|strong="H1961"\w* \w a|strong="H3068"\w* \w loyal|strong="H3068"\w* follower \w of|strong="H3068"\w* \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w from|strong="H5921"\w* \w my|strong="H3068"\w* \w youth|strong="H5271"\w*.  
