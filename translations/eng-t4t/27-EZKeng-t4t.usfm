\p
\v 3 \w As|strong="H3318"\w* \w the|strong="H5674"\w* \w man|strong="H5674"\w* \w continued|strong="H5674"\w* walking \w toward|strong="H3027"\w* \w the|strong="H5674"\w* \w east|strong="H6921"\w*, \w he|strong="H3027"\w* \w had|strong="H3027"\w* \w a|strong="H3068"\w* \w measuring|strong="H6957"\w* \w line|strong="H6957"\w* \w in|strong="H3027"\w* \w his|strong="H3027"\w* \w hand|strong="H3027"\w*. \w He|strong="H3027"\w* \w measured|strong="H4058"\w* \w off|strong="H3318"\w* ◄1,750 feet/530 meters►, \w and|strong="H3027"\w* \w then|strong="H3318"\w* \w led|strong="H3318"\w* \w me|strong="H5674"\w* \w through|strong="H3027"\w* \w water|strong="H4325"\w* \w that|strong="H4325"\w* covered \w my|strong="H3318"\w* ankles.  
