\v 28 \w Their|strong="H3068"\w* \w prophets|strong="H5030"\w*, \w by|strong="H3068"\w* \w falsely|strong="H7723"\w* \w saying|strong="H1696"\w* \w they|strong="H3068"\w* \w have|strong="H3068"\w* received \w visions|strong="H7723"\w*\add from God\add*, \w and|strong="H3068"\w* \w by|strong="H3068"\w* \w giving|strong="H1696"\w* \w false|strong="H7723"\w* messages, try \w to|strong="H1696"\w* ◄cover \w up|strong="H5030"\w* [MET]/\w say|strong="H1696"\w* \w that|strong="H3068"\w* \w it|strong="H1696"\w* \w is|strong="H3068"\w* \w all|strong="H3068"\w* \w right|strong="H3068"\w* \w to|strong="H1696"\w* commit► \w those|strong="H7080"\w* sins. \w They|strong="H3068"\w* \w say|strong="H1696"\w*, ‘\w This|strong="H3541"\w* \w is|strong="H3068"\w* \w what|strong="H3541"\w* \w Yahweh|strong="H3068"\w* \w the|strong="H3069"\w* \w Lord|strong="H3068"\w* \w says|strong="H3541"\w*,’ \w when|strong="H1696"\w* \w I|strong="H3541"\w* \w have|strong="H3068"\w* \w said|strong="H1696"\w* \w nothing|strong="H3808"\w* \w to|strong="H1696"\w* \w them|strong="H3068"\w*.  
