\id EPH - Yagua NT -Peru 2008 (web -2013)
\h Evésu
\toc1 Evesumu Vichavamyuju̱ra Catera
\toc2 Evésu
\toc3 Ev
\mt1 Evesumu Vichavamyuju̱ra Catera
\c 1
\s1 Pávurubay mu̱chuveda
\p 
\v 1 Ray Pávuru, rañi̱cha Jesucrístu nusu̱byi Ju̱denu jtedamuju̱, jiryimuju̱ saju̱ jiintyasavay jiryatiy Evésumu vichavay jirye, jiryatiy jiryevyichasara Jesucrístu va̱ta̱damu day, samiy siityevay saju̱ variy jirye.
\v 2 Jirya̱jmutya̱ra samirya vicha̱da Vu̱jye̱ Ju̱denumusiy, Vu̱yntyityu̱ Jesucrístumusiy jarye, jiryatiy jiryi̱mutya̱ simusirya jiryejyuuchuveda ramityadedaju̱.
\s1 Vuryi̱mutya̱jaya̱sara Crístumusirya rajuura samirya vichasara vuryi̱nu̱yada jiyadaju̱
\p 
\v 3 Ju̱na̱reju̱ jchana̱tyasi̱ sa̱vichasara Vu̱jye̱ Ju̱denu, jiryatiy Vu̱yntyityu̱ Jesucrístu ja̱ñi̱, ni̱day sa̱chara varintyirya rajuura samirya vichasara vuryi̱nu̱yada jiyadaju̱ntiy, Vu̱yntyityu̱ Jesúsmusintyi, jarichuvimu, diyemusidyerya ti̱ta̱ju̱ vu̱jyu̱ darya.
\v 4 Daryamusiñi̱day sajaryeta̱da Crístumuju̱ vu̱y, netimyu̱ ne su̱ndejadara mucadi variy didye, vurya̱tidye vichasara jiintyevye saju̱, ne va̱cha niquesara ra̱chasara sadiya vu̱ñijyu̱ nu̱day.
\p 
\v 5 Sadirya va̱ta̱damusiy yiteda: Ra̱jmutya̱ si̱tenu radyedyeñuju̱ jirye, Jesucrístumusiy sajachipiya̱jada daryá, jidyirya ni̱ru̱yadamuju̱.
\v 6 Ramuni̱day vurya̱jchana̱tyani̱ Ju̱denu samirya sa̱yadiva, jiryatiy sadirya ni̱ru̱yadata jiche̱dyevyu̱y, jiryatiy jaryi sava̱tasavay daryaju̱ Jesucrístumusidyevyu̱y.
\v 7 Jesucrístu jiryi̱nu̱y murichedoda yindaja̱ta vu̱jyuuchuveda jiyadaju̱, saramityaniy Ju̱denu variy vuryivara, jiryatiy jaryi samiryamu sani̱ru̱yadata jiche̱vyu̱y.
\v 8 Sasa̱yada jaryivya̱ju̱ vu̱jyu̱ra jidyetya̱da ti̱ta̱ju̱, samirya jachipiya̱jada jarye ti̱ta̱ju̱ risa̱ju̱.
\v 9 Sadityanunu̱yada vu̱rya jivya̱tara, jiryatiy dutyasara ravichanu̱yada tavajyu̱, jvadicharaday sajachipiya̱jada jvaayadara jijechara jidyirya Crístumu.
\v 10 Sajachipiya̱jada jvaayadara ra̱numatiy ju̱ti̱ sito̱tadeda runda, jasityidye sa̱bay Crístu nusu̱yadaju̱ ti̱ta̱ju̱ra jiryatiy na̱vay jarichumu darya, mucadiva vichara jarye ti̱ta̱ju̱ risa̱ju̱.
\v 11 Simusidye rirya̱jmutya̱ ti̱ta̱ju̱ Crístu siityari̱vantyirya jiyaru̱ryantiy jiryatiy sabayada Ju̱denu rijyu̱ darya. Sadirya jachipiya̱jadata jibeyada daryaju̱ra jidyirya jvaaryu̱yada.
\v 12 Darya sivaay jidyirya darya, ra̱tidye danu̱ya̱ jaryi vanda su̱ro̱, jiryatiy riichana̱tya̱da nijya̱nvay nu̱nchirya, jiryatiy munatya nu̱ñi nutuyada sa̱jiju̱ vuryeyada rá̱ñu Crístu.
\v 13 Jirye jaryentiy, jiryetyuva̱chodanumatirya si̱tenu tu̱choda sanijyu̱, jiryatiy samitu̱choda darya, ramusiñi̱day vu̱dyetyara Ju̱denu jantyutya̱da. Jiryetyuva̱chodanumatiy variy simu, sabayada yintuta jijyu̱ variy jirye, darya ni̱day su̱teda variy: Ra̱jpa̱ni̱ ri̱ntu ri̱bivaju̱ jiryimuju̱ntiy.
\v 14 Jiryatiy sasa̱yada Yintu vu̱y, vu̱dyetya ji̱ta ramusiy vurya̱jmutya̱ra jantyutya̱da Ju̱denumusiy, rirya̱tidye jchana̱tya nijya̱nvay variñi̱ Vuryi̱ndenu, ra̱jasa̱y jaryi vanda su̱ro̱ variy.
\s1 Pávurubay jachiñu̱yada Ju̱denuvara datya̱da Crístu siityari̱vajyu̱
\p 
\v 15-16 Ramuni̱dantyi, ratyuva̱chodanumatiy ranchiy jiryetyuva̱choda simu Vu̱yntyityu̱ Jesús, ti̱ta̱ju̱ jiryevya̱ta̱danchiy jarye riñijyu̱ ti̱ta̱ju̱ Ju̱denu siityari̱vajyuu, ne rapyaru̱y riva jchana̱tya̱dani̱ Ju̱denu jiryeñijyu̱, jasidye rajechipityaja̱ Ju̱denujsa̱ tu̱chodamu jirye.
\v 17 Rajechiñu̱y siva Ju̱denu, Vu̱yntyityu̱ Jesucrístu ja̱y, ni̱tiy vichasara vandamu, sa̱tidye sa̱y Yintu jirye, simusityi jirye̱cha jaryi datyavay, jiryatiy sadityanu jiryeñi̱ Jesús, jirya̱tidye datya si̱tenuni̱.
\v 18 Rajechiñu̱y jiryeyadaju̱, sa̱no̱no̱nu̱rya jiryejechiy datya̱da, jirya̱tidye datyara ta̱rajiju̱ jiryentuchara, jiryatiy sabayada Ju̱denu jiryejyu̱ darya, ta̱ jaryi taratavay jirye̱chate jasiy jiryatiy jiryi̱mutya̱ra jiberya vandamu rusa̱ ti̱ta̱ju̱ sasiityari̱vajyuu.
\v 19 Rajechiñu̱ntyi jirya̱tidye datya ne ti̱ saradoda sa̱ra̱ra sadatyadoda, jiryatiy simu tuva̱chuvamyu darya, ratatiy sivaachara jaryi jivyanu̱yadata darya.
\v 20 Darya savanu̱yadataday jimyi̱sadedani̱ Crístu diibyimusintyi, sama̱sadeda ji̱ta yintyityudamyuju̱ jarichuvimuni̱.
\v 21 Vu̱jye̱ Ju̱denu bayadani̱ Crístu ti̱ta̱ju̱ bayantuvedanchaju̱, jiryatiy ru̱tachara jaryi vanu̱vyeyu, datyavay jarye, ti̱ta̱ju̱ jirya mucadiva vichavay jiryatiy ru̱tay daryaju̱ nutyityu̱miyu, nusu̱yadacanumiy daryaju̱riy. Ti̱ta̱ju̱ jirya jiyadaju̱ sasa̱ñi̱ Crístu jaryi datya̱daju̱, dantyamu̱y ne vinu diye vichavajyu̱, ru̱siy vichavajyu̱ntiy.
\v 22-23 Sabayadama̱ Ju̱denura ti̱ta̱ju̱ Crístu numutu jaridye. Ramuni̱day sabayadani̱ Crístu ja̱mu nutyityu̱ju̱, ti̱ta̱ju̱ sasiityari̱vajyuu nutyityu̱ju̱ jarye, jiryatiy riñi̱cha savu̱ nta variy. Savu̱tanuma ti̱ta̱ju̱ yito̱tadedayu, ni̱tiy datyadarya mityamusiy jto̱tadeda ti̱ta̱ju̱ tara day.
\c 2
\s1 Sa̱ntyutya̱da Crístu jivya̱ta̱damuju̱ vu̱y
\p 
\v 1-2 Jirye jerye vichanu̱yada diibyimiy Ju̱denu diya jiryejyuuchuvediva. Jiryevyichanu̱yada variy juuchatavay jiryatiy jiryechiityari̱nu̱yadara va̱cha vicha̱da ti̱ta̱ju̱ daryaju̱. Jiryevyichanu̱yada variy bayantu nutyityu̱mu tuva̱chuvay, bayantu rapu̱y ni̱tiy vanu̱tya̱da riy rityimyu̱ ne tuva̱churu̱y simu Vu̱jye̱ Ju̱denu.
\v 3 Ti̱ta̱ju̱ nu̱jerye vichanu̱yada ta̱riy ramuntiy. Nu̱dyivaañu̱yadara daryatiy nu̱dyivaaryu̱y, nu̱vyu̱ va̱tara jarye, nu̱jechiy va̱ta̱damu jaryentiy. Ramuni̱day nu̱vyichanu̱yada variy paruti̱savay Ju̱denu jtedamuju̱, nu̱tyu tavay nijya̱nvatyi ti̱ta̱ju̱ darya.
\v 4-5 Ju̱denu ji̱ta ni̱tiy jaryi jantyutyara, jiryatiy sava̱ta̱da jaryi jivya̱ta̱damu vu̱y, dañuma vu̱ñi̱chanu̱yada diibyimiy vu̱jyuuchuvediva, Crístu jsa̱ju̱ sasa̱yada ja̱muca̱ jnu̱yadaju̱ varivyu̱y. Sani̱ru̱yadamu jirye̱yada variy vuryeyadaju̱.
\v 6-7 Sami̱sadeda Ju̱denu Jesucrístu jsa̱ju̱ vu̱y, sama̱sadeda jarichumu sisa̱ju̱ varintyivyu̱y, sa̱tidye dityanujaya̱sara ju̱na̱re sa̱ra̱ju̱ra jaryi yentyutya̱da, jiryatiy jaryi samirya jachityi̱ savichasara daryaju̱ vu̱ñijyu̱ Jesucrístumusiy.
\v 8 Vinu sa̱ntyutya̱damusiy vu̱ryamitya mityara vu̱jyuuchuveda murichirya, jiryatiy vu̱tyuva̱choda simu. Vu̱tyuva̱choda ji̱tantiy ne vu̱dyirya tuva̱choda darya; Ju̱denumusiñuma rani̱cha ti̱ta̱ju̱ day.
\v 9 Ne vu̱cya̱na̱y vuryivaayadatara, vu̱ñuma jchana̱tya ranchivyu̱y.
\v 10 Vu̱vyichasara daryaju̱ su̱ndebimiy jiryatiy su̱ndejada Jesucrístumu vu̱y, vurya̱tidye vichasara samiy jvaavye, darya sabayada ji̱tyaju̱ vurya̱vichajaya̱sara daryá samirya sadiya.
\s1 Vu̱vyichasara samivye Jesucrístumu
\p 
\v 11 Ramuni̱ jirya̱jachipityara nu̱tyu jiryevyichanu̱yada munu̱ñumiy Judíyuveda diya. Jiryatiy ru̱tachara jmutyonusarara jivyu̱ Ju̱denunijyu̱, ru̱nu̱y ji̱ta jiryeñe̱cho̱ nu̱tyu Ju̱denu rrachúvay, jiryatimyu̱ ne jmutyonusavay daryaju̱ jiryedye.
\v 12 Variryundamu jiryevyichanu̱yada tajiñe̱cho̱ju̱ Crístujisiy. Ne jiryevyichanu̱yada variy Ju̱denu siityari̱vay tevamyi, dantyamu̱y ne jiryedyetya̱da didyerya Ju̱denu jteda jiryeyada ra̱yadaju̱ didye. Jiryevyichanu̱yada mitya, ne jiryentuñu̱yada sa̱jiju̱ Ju̱denu jirya vuryi̱nu̱yada rundamu.
\v 13 Diye ji̱ta Jesucrístu batyeda nudaja̱musiy, satuudityaniy Ju̱denu variy jirye, ripya daryaju̱ jiryevyichanu̱yada sa̱jisidye.
\p 
\v 14-15 Sani̱cha ji̱ta Jesucrístu samirya vu̱vyicha̱daju̱ day, varidye santye̱ryadedara davicha̱daju̱y tavicha̱daquiju̱ntiy, daryamusiy sapu̱yadara riñique̱yada jijechivyasiy, ramuni̱day rivyichanu̱yada ripya sa̱jisiy. Sito̱tadeda Jesucrístura Ju̱denu jteda juuchuveda jiyadaju̱ jivyu̱mu, sabatyedamusiy. Su̱teda Ju̱denu daryaju̱ rajuura niquejadamusiy, nu̱tyuramusiy vurya̱vichasara samiy, nu̱tyuramusiy. Sabatyedamusiy ji̱ta yindejada Jesucrístu ni̱ ti̱qui nijya̱mi̱ yimu, jiryatiy sabayadara vurya̱tidye vichajaya̱sara samirya mityiji.
\v 16 Crusitya̱sa batyedata saratyadoda mityijijyu̱ryi davicha̱daju̱y ja̱nvay Ju̱denu diya, rirya̱tidye vichasara ti̱ta̱ju̱ nu̱tyu tevajyuu nta variy. Rata ji̱ta rabaryi̱jada rimyityasiiyadayu.
\v 17 Daryamusiy ji̱ta su̱deda Crístu samirya tu̱choda na̱cho̱, jirya̱tidye tuva̱chu rana̱cho̱ samitu̱choda, samiy vicha̱da jarye, jiryatiy jiryevyichasara ripya daryaju̱ sa̱jisiy. Daryaday satu̱chu ruuva Judíyuvedantiy dañumamu̱y ne riñi̱cha ripya vichavay.
\v 18 Crístumusiy ji̱ta vuryito̱ ti̱ta̱ju̱, dañumamu̱y ne Judíyuveda vu̱ñi̱cha, varimyata si̱tenu Judíyuveda davyu̱y, vuryi̱niy ti̱ta̱ju̱ Vu̱jye̱ Ju̱denumuju̱ vinu ti̱qui si̱tenu Su̱ntumusiy.
\v 19 Ramuni̱mu̱y ne jiryeñi̱cha munu̱ñumiñu̱day, dantyamu̱y ne raruva̱ ja̱nvay. Jiryeñi̱cha ji̱ta Ju̱denu jiintyasavay tevamyidye, Ju̱denu rorijya̱nvay tevamyi jarye risa̱ju̱ ti̱ta̱ju̱.
\v 20 Saroriiy Ju̱denu jiryetya rincha yinsu̱byimiy, saju̱ tu̱chuvabe jarye, nu̱tyu ju̱tuvu̱ nta riñi̱cha variy. Ni̱ni̱ Jesucrístu sani̱cha ravichu̱ nta roriy suru̱tya̱ju̱.
\v 21 Simu ji̱ta jiryentye̱ryaniy nu̱tyu roriche variyu, ra̱sa̱y samiy rorijyu̱ jiryatiy bachara Ju̱denunijyu̱ jachipiya̱joju̱ra.
\v 22 Daryanuma jiryentyidye, nu̱tyunuma taroriqui ti̱ta̱ju̱ jiryevyicha nta variy, samirya vichajo Vu̱jye̱ Ju̱denuju̱, Su̱ntumusintyi.
\c 3
\s1 Su̱pa̱jada Ju̱denu ni̱ Pávurubay ruumu jiryatimyu̱ ne Judíyuveda daryi
\p 
\v 1 Ramuni̱day, Ray Pávuru, ravyicha tanuvu̱nusi̱ Crístu siityari̱sa̱diva, samirya jiryevyicha̱daju̱ jiryatimyu̱ ne Judíyuveda jiryedye.
\v 2 Jiryeñi tuva̱chodama̱ dyetyara nu̱tyu sasa̱yada Ju̱denu jivya̱ta̱damu ray, ra̱tidye tu̱chu jiryivara samitu̱choda.
\v 3 Vu̱jye̱ Ju̱denu dityadoda daryaju̱ra datya̱da dutyasara, darya rañu̱yasiy pasidye ranchiy jiryimuju̱, jirya̱tidye datya varirya.
\v 4 Jiryeñumatiy jnu̱y ramu rañiquejada nu̱chara, jirya̱ma̱ datya variy ramusiy nu̱tyuramusiy radyetya radyerya Ju̱denu niquejada day, jiryatiy dutyasara Crístunchirya.
\v 5 Ne sadityanunu̱yada Ju̱denu ta̱rijye̱myi nijya̱nvavya darya, nu̱tyu diye sadatyanu Yintumusiryi yinsu̱byimiy, saju̱ tu̱chuvay jarye.
\v 6 Ranuma rani̱cha sadatyadoda, jiryatimyu̱ ne jvadichara darya: Nijya̱nvajyuu ji̱ta, jiryatimyu̱ ne Judíyuveda daryi, riñi̱cha Ju̱denu dadyeñuveda rusa̱ Judíyuveda, Crístu vu̱tera jarye, Ju̱denu niquejada jmutya̱vay jarye ti̱ta̱ju̱. Riñi̱day vicha vatajuu Jesucrístumu, jiryatiy rityuva̱chusara samitu̱chodamu.
\v 7 Sani̱ru̱yadata jiche̱yada Ju̱denu ray, ra̱tidye vicha samuchechiy savanu̱yadata, jiryatiy jvaachara rimura.
\v 8 Dañuma rañi̱cha tamityi̱ Ju̱denu jaryeti̱, sasa̱yada Ju̱denu radyerya, ra̱tidye tu̱chu nijya̱nvavyara, jiryatimyu̱ ne Judíyuveda daryi. Ratyu̱chu ruuvara samitu̱choda Crístunchiy, jiryatiy vu̱vyichasara jaryi taratavay Crístumu, jiryatimyu̱ ne vu̱charanumu̱yadasa̱ra̱ra.
\v 9 Su̱teda ti̱ta̱ju̱ riva daryá, ra̱tidye datyanu vijyo̱mujache ti̱ta̱ju̱ra sajachipiya̱jada, jiryatiy ravichanu̱yada dutyasara ta̱riy simu, ni̱tiy ju̱dejada ti̱ta̱ju̱ra.
\v 10 Sa̱dityanu variy jichiityari̱vajyuumusirya ti̱ta̱ju̱ jidyetya̱da. Sa̱dityanu diye riy nutyityu̱veda, nusu̱vyevyeda jarye jiryatiy jarichumu vichavantyiryi.
\v 11 Sito̱tadeda Vu̱jye̱ Ju̱denu, vuryeyada rá̱ñu Jesucrístumusiy daryá, jiryatiy sabayada rajo̱ta̱damusirya.
\v 12 Jiryatiy vu̱tyuva̱chu simu Jesucrístu, vuryito̱sara simu Ju̱denu vu̱chuvu̱yasa̱damu variy.
\v 13 Ramuni̱ rayasanta jirye ne jirya̱paru̱tyajaya̱sara riva jiryatiy paru̱cha̱riy ravyichasara jiryeyadaju̱, tapi jiryi̱chana̱tyasa̱daju̱ daryaju̱ darya.
\s1 Crístu va̱ta̱da
\p 
\v 14 Ramuni̱day ra̱dasiñu Vu̱yntyityu̱ Jesucrístu ja̱y na̱cho̱ju̱ ray.
\v 15 Ju̱denumusiñuma vuryi̱mutya̱ ti̱ta̱ju̱darya vuryi̱tya day, nu̱ñi tevajyuu, mu̱y jarichuvimu, daryatiy jiyu mucadimuntiy.
\v 16 Rajechiñu̱y jiryeyadaju̱ sa̱vanu̱tyaniy Ju̱denu jivyanu̱yadata jirye, jiryatiy sasa̱y Yintumusiy jiryejechiy vanu̱tya̱daju̱ra. Jaryi vanda vijyo̱mu vanu̱yadati̱ daryaju̱ dañi̱ Ju̱denu day.
\v 17 Rajechiñu̱y sa̱tidye vichasara Crístu jiryejechimyu, jiryetyuva̱chodamusiy, jiryatiy jiryevyicha vase jachipiya̱vay sava̱ta̱damuju̱ nu̱tyu nutasara, rajuura jnutijyu̱u̱tara, varimyata nu̱tyu ju̱tuvu̱ surra ju̱sityasará.
\v 18 Rajechiñu̱y siva ramusiñuma jirya̱datya rusa̱ju̱ ti̱ta̱ju̱ Ju̱denuju̱ jiintyasavarya sava̱ta̱da, jiryatiy jaryi vojotara darya, jiryatiy jaryi ja̱muca̱ntirya, jiryatiy jaryi na̱vajyu̱ntirya, jiryatiy jaryi nicha̱richa̱ra̱ju̱ntirya.
\v 19 Rajechiñu̱y jirya̱datyara Crístu va̱ta̱da jiryatimyu̱ ne vu̱dyetyamu̱yadasa̱ra̱ darya, jirya̱tidye vichasara ti̱ta̱ju̱ daryá nu̱tyu Ju̱denu vichasara daryá, jiryatiy savichasara miryani̱ jiryimu.
\p 
\v 20 Diye vanda ra̱chasara ti̱ta̱ju̱ saju̱, ni̱tiy datya jvaayada jaryivya̱ju̱ra rajuura ranchaju̱ vu̱jechiñu̱yada jiyadaju̱, varimyata vu̱jechipiya̱jada jiyadaju̱ntiy. Darya vandanuma ra̱chasara variy saju̱ntidye, ni̱tiy datya jmu̱tya̱da jivyanu̱yadata davyu̱y.
\v 21 Saju̱ ji̱ta ra̱cha vanda, sasiityari̱vajyuumusiy, Jesucrístumusiy jarye, ju̱na̱re sa̱ra̱ju̱ ti̱ta̱ju̱. Dañuma ra̱chajaya̱sara jasiy daryá.
\c 4
\s1 Vurye̱cha vatajuu Ju̱denu Jnutumusiy
\p 
\v 1 Rayasanta ji̱ta jirye, ray jiryatiy ravyichasara tanuvu̱nusi̱ Vu̱yntyityu̱ jiyadaju̱, ri̱tay ti̱ta̱ju̱ jiryivara: Daryanuma jirya̱vichajaya̱sara sanijyu̱ Ju̱denu, daryatiy jiryeñuma rañi̱cha ti̱ta̱ju̱ Ju̱denu jaryetasavamyi.
\v 2 Samiy jachipiya̱jadatavay jirye̱cha, samirya jachityavay jarye, jiryatiy jiryejechi̱niy jivya̱ta̱damu nu̱ñi jiryedyeyu.
\v 3 Paru̱cha̱rimyusiy jiryeryiryi̱ra vatajuu Ju̱denu Jnutumu vicha̱da, jiryatiy jiryevyichasara samirya nu̱ñivajyuu yisa̱.
\v 4 Jirye̱cha nu̱tyu ti̱qui nta Crístumu variy, daryadantyi ti̱qui Jnututavantyi jiryatiy sanatuyada taraqui nutuyadata jirye.
\v 5 Vinu ni̱ni̱ sani̱cha ti̱qui Vu̱yntyityu̱, daryaday taraqui tuva̱choda simuntiy, daryaday varintyirya taraqui ji̱tyu̱yadantiy.
\v 6 Savichasara vinu ti̱qui Vuryi̱ndenu, vinu ni̱ vichasara Vu̱jye̱ vu̱jyu̱. Ni̱ni̱ vichasara rancha ti̱ta̱ju̱, savichasara ranube ti̱ta̱ju̱ntiy, savichasara ramu ti̱ta̱ju̱ risa̱ju̱.
\p 
\v 7 Nu̱ñi ti̱quimusiy vuryi̱mutya̱ra sasa̱ryá jiryatiy vuryeyaru̱rya darya, daryatiy sasa̱ryu̱yada Crístu davyu̱y.
\v 8 Darya su̱teda Davyíbe sanchiy:
\q1 Sa̱subedanumatiy ji̱ta na̱vajyu̱, sayata̱da riy tanuvu̱nusavajyuu yisa̱ju̱, sasa̱yada variy nijya̱nvarya jiyaru̱rya.
\m 
\v 9 Jiryatiy su̱teda Davyíbe: Sa̱subeda, vu̱dyetya ranchiy jiryatiy su̱musa̱da munatya mucadijarijyu̱.
\v 10 Ni̱day Jesús jmusa̱dantiy, ni̱day jasubeda rivasiy varintyi, jaryi na̱vay jarichuvimuju̱ntiy, sa̱tidye mu̱chaniy jidyetya̱data ti̱ta̱ju̱ra tara.
\v 11 Sasa̱yada datya̱da riy tavay, rirya̱tidye vicha variy nusu̱vye, tavay ji̱ta su̱tedamu tu̱chuvay rusa̱ju̱, tavantyi saniquejada tu̱chu̱savajyu̱, tavantyi sasiityari̱vajyuu jnu̱tya̱daju̱, tavantyi datyanuvajyu̱, Ju̱denu niquejada datyadodaju̱.
\v 12-13 Daryamusiñi̱day su̱dutya̱da Ju̱denu riy jijeryetavay ruvaayada jiju̱, rirya̱tidye vanu̱tyanirya Crístuvu̱, ti̱ta̱ju̱ sasiityari̱vajyuumusiy, jasicha̱ra̱ju̱tiy vuryito̱ mityiji jachipiya̱jadaju̱ sisa̱ Crístu, vu̱tyuva̱chodamu, vu̱dyetya̱damu jarye, jasicha̱ra̱ju̱numa vurye̱cha samiy ja̱myi, jiryatiy vu̱cheryeryu̱rya Crístu ja̱vyeda.
\v 14 Ne vurye̱cha variy nu̱tyu deramiy nta nu̱day, jiryatiy rirya̱numitya vani̱ra darya jijechipiya̱jada day, ru̱ntatyanumatiy nijya̱nvarya taji datyadoda. Rijetyaru̱y tajijyu̱ra vu̱jechipiya̱jada nu̱tyu ri̱ye̱rya, varimyata riicho jatyari̱ tajijyu̱ra vu̱cyartye. Jasiy daryaju̱ riy nijya̱nvay rityi quivu̱chuna̱ya̱ va̱cha datyadodamusiy jirye, jiryatiy rirya̱numityaru̱y tajijyu̱ra jiryejechipiya̱jada nupocudi nú̱quiivaju̱ daryaju̱.
\p 
\v 15 Vurya̱nique ji̱tara samiy niquejada vu̱vya̱ta̱damuju̱. Vurya̱ma̱ ja̱vye ti̱ta̱ju̱mu sana̱cho̱ju̱ Crístu, ni̱tiy vichasara vuryi̱no̱.
\v 16 Simusiñi̱ ji̱ta jiryi̱nu̱y vu̱vyichasara nu̱tyu savu̱ nta, ti̱ta̱ju̱ jiryatiy vu̱chiityari̱sarani̱. Vu̱vyichasara mityijijyuu sisa̱, nu̱tyunuma rupanichara nta ravichasara vu̱jyu̱u̱ ti̱ta̱ju̱ saniy Crístu, daryanuma sabayada Ju̱denu darya. Rajo̱tanumatiy jvaayada samirya nu̱ñi Crístu vu̱tera, raja̱vye savu̱ variy, vu̱vyanu̱tyasara variy vu̱vya̱ta̱damusivyu̱y.
\s1 Vadi jnu̱yada Crístumu
\p 
\v 17 Jirya ji̱ta ri̱tay jiryiva; ratyu̱chu Vu̱yntyityu̱ jtedamura: Ne jirya̱vichasara nu̱tyu munu̱ñumiñu̱day, rivyichasara daryaju̱ jidyirya jachipiya̱jadamusiy.
\v 18 Rivyichasara nupocunubesiy jachipiya̱vay, Ju̱denu jnu̱yadamusiy jiintyasavay, jiryatiy datyi̱sa̱miy daryaju̱ daryi, jaryi surra daryaju̱ra rijechiy ra̱jisiy.
\v 19 Jiryatimyu̱ ne ridyetyara jana̱da nu̱ndye, ribemya̱ra jivyicha̱da rirya̱tidye vichasara cadnavedacanumiy, rirya̱tidye jvaarya va̱cha jvaayada jaryi.
\v 20-21 Jirye ji̱ta datya̱dani̱ Crístu darya vicha̱dajisidye, jiryetyi tuva̱chodara si̱tenu niquejada, jiryatiy ridyetyadoda jiryerya, darya ravichasara si̱tenu Jesúsmu day.
\v 22 Jirya̱jatya jiryejechimyusirya ta̱riy jiryevyicha̱da, jiryatiy jiryevyichasara jarapu̱vye ramu, va̱cha ni̱ru̱vye jiryatiy quivu̱chodata riñi̱ru̱tyaniy jiryerya.
\v 23-24 Jirye̱cha̱siy vadivay yintumu, jiryejechimyu jarye, jirya̱ma̱ jachu yiva ni̱ vadi nijya̱mi̱, jiryatiy ju̱desi̱ dañi̱, nu̱tyu Ju̱denu daryá, jiryatiy vase bachi̱ dañi̱, Ju̱denuju̱ jaryetasi̱ daryaju̱ dañi̱.
\s1 Nu̱tyuramusiy vu̱ryi vichasara vadi jnu̱yadamu, nu̱tyuramusiy
\p 
\v 25 Ramuni̱ jirya̱jatya yajisirya quivu̱yada, jirya̱tidye niquera si̱tenu niquejada nu̱ñi jityuunu vichavatya, tapi vu̱vyichanuma nu̱tyu Crístu vu̱tera ti̱ta̱ju̱.
\v 26 Jirya̱tiy nique̱, ne jirya̱juuchuvay variy, dantyamu̱y ne jirya̱suru̱tyanirya jiryeñique̱yada jidye sa̱ra̱ju̱.
\v 27 Ne jirya̱bay vidavijo bayantu nutyityu̱jiju̱ jiryejechimyu.
\p 
\v 28 Ni̱tiy vichanu̱yada paranu̱ni̱, sa̱ma̱ paru̱y riva paradoda, sa̱ma̱ jvaay jijyomututara samirya jvaayada, sa̱tidye sa̱y tara ni̱ jantyuyani̱.
\p 
\v 29 Ne ra̱sipyatachara nicyara̱y niquejada jiryi̱tosiñu̱day, vinu samiy niquejada, vurya̱tidye vanu̱tyaniy riy vu̱tyevamyi ramusiy, rirya̱tidye jmutya̱ ramusirya Ju̱denu jmu̱tya̱da.
\v 30 Ne jirya̱yivatyaniñi̱ Ju̱denu Jnutu, sabayada Ju̱denu daryaju̱ ni̱ Yintu jiryiva, sa̱tidye pu̱chiy tamitya rundamu yisa̱ju̱ variy jirye.
\v 31 Jirya̱numa paru̱y ti̱ta̱ju̱ riva jaryi nique̱yada, japichiy nique̱yada, nique̱yadamusiy sa̱ñe̱ya̱jada, javityiye̱yada, ti̱ta̱ju̱ nicyara̱y jvaayada, nicyara̱y jachipiya̱jada jarye ti̱ta̱ju̱ risa̱ju̱.
\v 32 Jirye̱cha samirya jachityavay jiryisa̱, jantyutyavay jarye, jirya̱ntya ramityanintyidyerya jijyuuchuveda yivantidye, nu̱tyu Ju̱denu ramityadeda jiryivara jijyuuchuveda Crístumusiy.
\c 5
\s1 Nu̱tyuramusiy riryi vichasara Ju̱denu dadyeñumiy
\p 
\v 1 Ramuni̱ jirye̱cha Ju̱denu jantyavay jiryatiy jiryeñi̱cha sadadyeñu jaryi va̱tasavay.
\v 2 Jirya̱ma̱ vichasara jaryi va̱ta̱damu, daryatiy sava̱ta̱da Crístu daryá vu̱y, sasa̱yada variyu, sa̱tidye batye vuryeyadaju̱. Su̱ntatya̱da paru̱cha̱rimyusiy Ju̱denumuju̱yu, jiryatiy su̱mutya̱jada Ju̱denura su̱ntatya̱da, nu̱tyu vu̱rudi jaryi ju̱rura saju̱.
\v 3 Jiryetyi rañi̱cha Ju̱denu vicha̱damu, ne jirya̱nique cadnavedanchiñu̱ndye, dantyamu̱y ne va̱cha jvaayadanchiy, dantyamu̱y ne jaryi tara canuyadacanuminchiy, tapi ratatiy jirya̱jarupanu variñi̱ ti̱.
\v 4 Daryantyamu̱y ne jirya̱niquera nicyara̱y niquejada, datyi̱sa̱damu niquejada, jamiryamu niquejada jarye, mitya. Jirya̱nique ji̱tara niquejada ratatiy jiryi̱chana̱tya̱da ni̱ Ju̱denu.
\v 5 Jirya̱datya samiy daryaju̱ra jirya: Ni̱tiy vichasara cadnavu̱, varimyata vaturu̱y cadnatoda, varimyata va̱cha jvaarya, varimyata tara sa̱chara canuyadacanu, jiryatiy sasiityari̱ Ju̱denu jiyasachirya tara, ne sa̱jmutya̱sara mityara jiyaru̱rya Crístu nusu̱jyomu, jasityi sa̱nsu̱chara Ju̱denu ni̱.
\v 6 Ne jirya̱quivu̱chutaniy mitya niquejadatayu, tapi darya jvaayadaco̱siy ra̱jti̱ Ju̱denu nique̱yada jaryi riyaro̱ju̱ rityimyu̱ ne tuva̱churu̱y simu.
\v 7 Ramuni̱mu̱y ne jirye̱cha rusa̱ rupivye darya vicha̱damu.
\v 8 Ta̱riñuma jirye vichanu̱yada nupocudinube, diye ji̱ta jiryevyichasara Vu̱yntyityu̱musiy vandamu. Jirya̱vichasara samirya nu̱tyu Ju̱denu dadyeñumiy.
\v 9 Vandamu rupiyadamusiy ru̱nday ti̱ta̱ju̱ jiryatiy samiryara, jiryatiy vase jaryera, jiryatiy si̱tenu jarye risa̱ju̱ra.
\v 10 Jirya̱ma̱ jantya jvaayadara jiryatiy samirya Ju̱denu diya darya.
\v 11 Ne jirya̱jvaay mityiji rusa̱ rityi jvaay nupocudinubera jiryatimyu̱ ne samirya Ju̱denu diya darya. Jirya̱sipyata ji̱ta nupocudinubesirya va̱cha jvaayada, no̱no̱muju̱.
\v 12 Jadasara ji̱tara vu̱ñiquejada ranchiy jiryatiy ruvaachara dutya̱damusirya.
\v 13 Ti̱ta̱ju̱ sipyatasaranumatiy vandamuju̱ darya, ra̱ma̱cho̱ ti̱ta̱ju̱ vandamu variy.
\v 14 Ti̱ta̱ju̱ jvadicharanuma no̱no̱damu darya. Ramuni̱tiy ru̱tay variy:
\q1 Ya̱numa jidyo ma̱yadacanu, ya̱numa mi̱sa̱sumiy diibyimiy cabyimusiy, sa̱nó̱no̱nú̱y Crístu variy yiva.
\p 
\v 15 Ramuni̱day, jiryi̱nu̱tyata̱ta samirya jiryevyicha̱da. Ne jirye̱chasara datyi̱sa̱miy, jirye̱cha ji̱ta datyavay.
\v 16 Jiryedyetyata̱ta samiy ramitya̱dara jiryevyicha̱da jiyu, jiryatiy nicyara̱y vicha̱da daryaju̱ diye.
\v 17 Ne jirye̱cha datyi̱sa̱miy nu̱ndye, jirya̱ma̱ datyara Vu̱yntyityu̱ ni̱ru̱yada.
\v 18 Ne jirya̱niyu̱ñu̱day, jiryatiy jarapu̱chara daryaju̱ darya. Jirya̱ma̱ vichasara mu̱chanichavay Ju̱denu jnutumusiy.
\v 19 Jirya̱niqueta nu̱ñi vajyuu murra̱yadatayu, jiryatiy vu̱myurra̱y Ju̱denunijyu̱ Su̱ntumusiy. Jirya̱murra̱chara ti̱ta̱ju̱ jijechitya jirya̱tidye jchana̱tya ratani̱ Vu̱yntyityu̱ variy.
\v 20 Jirya̱jchana̱tyajaya̱ni̱ Vu̱jye̱ Ju̱denu ti̱ta̱ju̱ riva jiryatiy samirya darya, rivantiy jiryatiy ne samirya rani̱chantiy, Vu̱yntyityu̱ Jesucrístu jtyamu jirya̱jchana̱tya variñi̱.
\s1 Nu̱tyura saryi vichasara Ju̱denu siityari̱nu jiryorimyu, nu̱tyura
\p 
\v 21 Jirya̱tuva̱chu nu̱ñi ti̱quimusiy yimu, jiryatiy jiryechuvu̱ñi̱ Crístu.
\v 22-23 Vatuy, jirya̱tuva̱chu jaryi ruumu jivyaduy, nu̱tyu Vu̱yntyityu̱mu vu̱tyuva̱chu daryantiy, tapi sabayada Ju̱denu ni̱ vanu nu̱tyu nutyityu̱ savaturaju̱, daryani̱ savicha Crístu jichiityari̱vajyuu nutyityu̱ntiy, jiryatiy riyada rá̱ñuni̱. Ni̱ni̱ vicha nu̱tyu ru̱no̱, riy ji̱ta nu̱tyu savu̱ nta varidye.
\v 24 Nu̱tyu Crístu siityari̱vay tuva̱chusara yimu, daryani̱ rirya̱tuva̱chusara vatuy ruumu jivyaduntyidye.
\p 
\v 25-26 Vadumyijerye ra̱va̱tasara jaryiñada jivyaturu̱y, nu̱tyu Crístutiy va̱tanu̱yada darya riy jichiityari̱vajyuu, sabatyeda variy riyadaju̱, jiñi̱ru̱yadamu, sa̱tidye jiintya variy jijyu̱ daryi, jiryatiy sapu̱yada daryaju̱ ruuvasirya jijyuuchuveda, jiryatiy riityu̱yada Ju̱denu niquejadamu tuva̱chuvay ja̱a̱mu.
\p 
\v 27 Sivaayada daryá sa̱tidye jnutatya yimuju̱ riy, jaryi vandamu vichavay, ne rirye̱cha vatajo̱ tavay, dantyamu̱y ne tara nicyara̱y baya̱sara riñijyu̱, dantyamu̱y ne nicyara̱tyavay, mitya. Sava̱ta rirye̱cha jiintyevye jijyu̱, ne javatyasavay, mitya.
\v 28 Nu̱tyu vaduy jantyutyara jivyu̱, sani̱ru̱y jaryiyu, daryaday saryi jantyutya nada jivyaturu̱ntyi, saryi ni̱ru̱y jaryi nadantidye. Tapi ni̱tiy va̱ta nada jivyaturu̱y, sava̱ta variy daryantidyeyu.
\v 29 Ne ti̱ javittyurya jivyu̱; sapotyaniy ji̱tayu, daryatiy su̱nu̱tya Crístu riy jichiityari̱vajyuuntiy jiryatiy vuryi̱tay savu̱ daryi.
\v 30 Vu̱y jarye vichasara savu̱tera variy.
\v 31 Darya su̱teda:
\q1 Ramuni̱, sa̱tochiy vanuni̱ jijye̱, su̱no̱da jarye, sa̱tidye ja̱mu̱y jivyaturaju̱ variy, danu̱ju̱myusiy nana̱chasara nu̱tyu ti̱qui variy.
\p 
\v 32 Jirya ji̱ta jaryi ti̱ttasara datyanusara daryaju̱ darya, jiryatiy dutyasara ravichanu̱yada. Rani̱day su̱teda Ju̱denu Crístunijyu̱, sasiityari̱vajyuu nijyu̱ jarye.
\v 33 Darya ri̱tesiy jiryejyu̱ntidyerya jirya niquejadantidye: Nu̱ñi ti̱qui vanu ra̱va̱ta nada jivyaturu̱y nu̱tyu sava̱ta jaryintyidyeyu, daryaday vatujyu̱ntiy, rirya̱bay samirya riy jivyaduy.
\c 6
\s1 Nu̱tyuramusiy rirye̱cha deramiy jijye̱myitya Crístumu, nu̱tyuramusiy
\p 
\v 1 Deramiy, jirya̱ma̱ tuva̱chu ruumu jijye̱myi, Vu̱yntyityu̱mu, jiryatiy vase vichasara daryaju̱ darya.
\v 2 Darya su̱teda Ju̱denu:
\q1 Vurya̱jnu̱y samiy nanuna̱cho̱ vuryi̱no̱da, vu̱jye̱ñe̱cho̱ jarye.
\m Sabayada jirya niquejadatara ru̱ventiy, vurya̱tidye datyasarara nu̱tyu ra̱cha rijyu̱ rityi tuva̱chusara ramu.
\v 3 Su̱teda jadchintyi:
\q1 Vurya̱jnu̱y samiy nanuna̱cho̱ vu̱jye̱jyu̱y, vurya̱tidye jnu̱jeya̱sara samiy ja̱muca̱ jirya mucadimu.
\p 
\v 4 Deramiy ja̱myintyi, ne jirya̱nique̱ttaniryi jidyedyeñu, jirya̱ma̱ ja̱vyechu Vu̱yntyityu̱ vasedodamu riy, sadatyadodamuju̱.
\s1 Nu̱tyuramusiy rirye̱cha muchechimyi jipyatru̱mitya Crístumu, nu̱tyuramusiy
\p 
\v 5 Cumudemintyi, jirya̱ma̱ tuva̱chu simu jipyatru̱. Jirya̱jvaay jichuvu̱yadamu, jiryemyichutyedamu nta jarye risa̱ju̱, darya ntanuma jiryeñi jvaay taraqui jachipiya̱jadata Crístunijyu̱ variy.
\v 6 Ne jirya̱jvaay vinu sa̱tidye jachipiya̱ jiryepyatru̱ samiy jvadichavay variy jirye. Daryatiy Crístu cumudemidye jiryeñi̱chantiy, jirya̱ma̱ jvaay jijechityara Ju̱denu va̱tara.
\v 7 Jirya̱jvaay samiy jachipiya̱jadatara nu̱tyu Vu̱yntyityu̱ju̱, ne nu̱tyu nijya̱mi̱ju̱ day.
\v 8 Jiryedyetyama̱ daryaju̱ darya: Sa̱jmutya̱ nu̱ñi ti̱quira samiy yivaayada murichirya. Daryani̱ sa̱jmutya̱ Ju̱denumusintyirya, dañuma sani̱cha cumude, varimyatamu̱y ne sani̱cha cumude.
\s1 Nu̱tyuramusiy rirye̱cha patru̱miy jimyuchechimyitya Crístumu, nu̱tyuramusiy
\p 
\v 9 Patru̱mintyi, jirya̱ma̱ bachara samiryi jicyumudemiy. Jirya̱ma̱ paru̱y riva ja̱suye̱yada niquejadata riy, jirya̱jachipityaja̱ variñi̱ jiryatiy savichasara ti̱qui Vu̱yntyityu̱ jarichumu, ni̱timyu̱ ne datya javiryu̱tya̱da ti̱.
\s1 Ju̱denu siityari̱vay jvatyá̱ ratatiy ru̱vachara riy bayantuveda
\p 
\v 10 Parichemyusiy ji̱ta, ratyeryi̱veda, vurya̱ma̱ vanu̱tya Vu̱yntyityu̱mu vu̱y, jaryi savanu̱yada jmu̱tya̱data.
\v 11-12 Vurya̱ma̱ jachu vuryivara Ju̱denumusirya bayantu jatyata̱, vurya̱tidye vanu̱tya bayantu nutyityu̱ quivu̱choda jidcho̱ju̱ vu̱y, jiryatimyu̱ ne vu̱ñique̱chara nijya̱nvay savityavay jiyaro̱ju̱, dantyamu̱y ne nudatavay jiyaro̱ju̱. Vu̱ñique̱chara ji̱ta riyaro̱ju̱ nutyityu̱veda day, nusu̱vyevyeda jarye, rityi nusu̱chara jirya mucadimu nupocudinube, rityi vichasara riicho ja̱nvay, jarichumu vichavay bayantuveda nicyara̱myi.
\v 13 Ramuni̱day vurya̱jmutya̱ vuryimuju̱ra Ju̱denumusirya bayantu jatyata̱ ti̱ta̱ju̱, vurya̱tidye vanu̱tya paru̱cha̱riy rundamu vu̱y; vu̱ñumatiy vuunu variryi, vurya̱ma̱cho̱sara ca̱na̱vye variy.
\v 14 Vurya̱ma̱ radesiy nu̱tyu puchusara nta vu̱cyadnumu Ju̱denu niquejadata. Vurya̱jachu vu̱dyutuuvyara vu̱dyutuujyo, jiryatiy Ju̱denumusiy vase vicha̱da darya.
\v 15 Vurya̱jachu vu̱ñumutuvantirya nu̱tyu saapátuntiy ratatiy vurya̱jdutya samitu̱choda tu̱chunumaya̱jadaju̱ vu̱y.
\v 16 Jadchiy ji̱ta vurya̱jmutya̱ntirya vu̱ryamityáta̱ntiy jiryatiy vuryi̱tay Ju̱denumu tuva̱choda darya, ratatiy vurya̱jmutya̱ ti̱ta̱ju̱ra bayantu nutyityu̱ ruve, jiryatiy saduu jiidatya vu̱ñe̱cho̱ju̱ra.
\v 17 Vurya̱jmutya̱ vuryi̱no̱co̱ju̱ra Ju̱denu jmu̱tya̱dantiy, vurya̱jirintyirya Ju̱denu niquejadantiy, jiryatiy Ju̱denu Jnutu jchityitya̱ darya.
\v 18 Ne vurya̱paru̱y riva Ju̱denujsa̱ tu̱choda, vurya̱jiyasantajaya̱ jachiñu̱yada ni̱, Su̱ntumusiy datyadodamuju̱. Vurya̱ntya vichasara vani̱ravay, vurya̱tidye jdutya tara jidcho̱ju̱ vu̱y, ne vurya̱paru̱tya riva vu̱y. Vurya̱tu̱chujaya̱sara sisa̱ Ju̱denu, ti̱ta̱ju̱ sasiityari̱vajyuu jiyadaju̱.
\v 19 Jirya̱tu̱chu sisa̱ Ju̱denu rayadaju̱ntidye, ra̱tidye nique vijyo̱mujache ri̱tosirya samitu̱chodantidye, jiryatiy dutyasara ravichanu̱yada, ra̱tidye tu̱chu rachuvu̱yasa̱damura jiryatiy sanique Ju̱denu rimusidyerya.
\v 20 Ravyicha Ju̱denuju̱ tu̱chu̱ tanuvu̱nujovimu. Ramuni̱ rañiqueru̱y rachuvu̱yasa̱damu, daryatiy sava̱ta ra̱nique jijyu̱.
\s1 Samu̱chuveda Pávurubay tamitya riy
\p 
\v 21 Jirya̱tidye datya raynchiy, nu̱tyura rañi̱cha, Tíquicu ra̱tu̱chu jiryivara ti̱ta̱ju̱ ravyicha̱da, rivaayada jarye. Ni̱ni̱ ji̱ta vu̱tyeryi̱ jaryi va̱tasi̱, samiy jmu̱tyara varidyeñi̱, jiryatiy sivaachara samiy Vu̱yntyityu̱mu dárya.
\v 22 Ri̱pa̱ jiryimuju̱ni̱, sa̱tidye datyatanirya tu̱choda raynchiy, ne jirya̱jachipiya̱ tajijyu̱ jijechimyu variy.
\p 
\v 23 Rirye̱cha samiy vu̱tyeryi̱veda Vu̱jye̱ Ju̱denu va̱ta̱damu, su̱nu̱chodamu jarye jiryatiy su̱nu̱chusara jivya̱ta̱damu Vu̱yntyityu̱ Jesucrístumusidyevyu̱y.
\v 24 Sa̱sa̱chara samiy vichasa̱da riy ti̱ta̱ju̱ jiryatiy vu̱vya̱tajaya̱sarani̱ Vu̱yntyityu̱ Jesucrístu, ne baryi̱jasara va̱ta̱damuju̱.
\cls Sayanuma Pávuru
