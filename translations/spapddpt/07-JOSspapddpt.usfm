\v 7 Así \w que|strong="H5921"\w* \w los|strong="H5921"\w* hombres \w los|strong="H5921"\w* \w persiguieron|strong="H7291"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w hacia|strong="H1870"\w* \w el|strong="H5921"\w* \w Jordán|strong="H3383"\w*, \w hasta|strong="H5921"\w* \w los|strong="H5921"\w* vados. Tan pronto \w como|strong="H5921"\w* \w los|strong="H5921"\w* \w perseguidores|strong="H7291"\w* \w salieron|strong="H3318"\w*, \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* fue \w cerrada|strong="H5462"\w*.   
\p
\v 8 \w Antes|strong="H2962"\w* \w que|strong="H1931"\w* \w se|strong="H1931"\w* acostaran, \w ella|strong="H1931"\w* \w subió|strong="H5927"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* terraza \w y|strong="H5921"\w* \w les|strong="H1992"\w* dijo:  
\v 9 \w Yo|strong="H3588"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w les|strong="H5921"\w* \w dio|strong="H5414"\w* \w esta|strong="H3427"\w* tierra \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w el|strong="H5921"\w* terror \w de|strong="H5921"\w* ustedes \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H3605"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra desfallecen \w ante|strong="H6440"\w* ustedes.  
