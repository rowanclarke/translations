\v 40 \w Car|strong="H3588"\w* \w sur|strong="H3588"\w* \w ma|strong="H3588"\w* \w montagne|strong="H2022"\w* \w sainte|strong="H6944"\w*, \w sur|strong="H3588"\w* \w la|strong="H3478"\w* \w haute|strong="H4791"\w* \w montagne|strong="H2022"\w* d'\w Israël|strong="H3478"\w*, déclare \w le|strong="H5002"\w* \w Seigneur|strong="H3478"\w* \w DIEU|strong="H3588"\w*, \w là|strong="H3478"\w* \w toute|strong="H3605"\w* \w la|strong="H3478"\w* \w maison|strong="H1004"\w* d'\w Israël|strong="H3478"\w*, \w tous|strong="H3605"\w* \w ceux|strong="H3605"\w* \w qui|strong="H3478"\w* \w seront|strong="H1004"\w* \w dans|strong="H3478"\w* \w le|strong="H5002"\w* \w pays|strong="H3478"\w* \w me|strong="H3478"\w* \w serviront|strong="H5647"\w*. \w Là|strong="H3478"\w*, \w je|strong="H3588"\w* \w les|strong="H3605"\w* accepterai, \w et|strong="H3478"\w* \w là|strong="H3478"\w* j'exigerai \w vos|strong="H5647"\w* \w offrandes|strong="H8641"\w*, \w les|strong="H3605"\w* \w prémices|strong="H7225"\w* \w de|strong="H1004"\w* \w vos|strong="H5647"\w* \w dons|strong="H4864"\w*, \w et|strong="H3478"\w* \w toutes|strong="H1004"\w* \w vos|strong="H5647"\w* \w choses|strong="H6944"\w* \w saintes|strong="H6944"\w*.
\v 41 \w Je|strong="H3068"\w* \w vous|strong="H5869"\w* accepterai \w comme|strong="H5869"\w* \w un|strong="H3318"\w* \w parfum|strong="H7381"\w* d'\w une|strong="H3318"\w* \w agréable|strong="H5207"\w* \w odeur|strong="H7381"\w*, quand \w je|strong="H5971"\w* \w vous|strong="H5869"\w* \w ferai|strong="H5971"\w* \w sortir|strong="H3318"\w* \w du|strong="H3318"\w* \w milieu|strong="H5971"\w* \w des|strong="H5869"\w* \w peuples|strong="H5971"\w* \w et|strong="H3318"\w* \w que|strong="H4480"\w* \w je|strong="H5971"\w* \w vous|strong="H5869"\w* \w rassemblerai|strong="H6908"\w* \w des|strong="H5869"\w* \w pays|strong="H5971"\w* \w où|strong="H5869"\w* \w vous|strong="H5869"\w* \w avez|strong="H5869"\w* \w été|strong="H5869"\w* \w dispersés|strong="H6327"\w*. \w Et|strong="H3318"\w* \w je|strong="H5971"\w* \w serai|strong="H5869"\w* \w sanctifié|strong="H6942"\w* \w en|strong="H5971"\w* \w vous|strong="H5869"\w* \w aux|strong="H5971"\w* \w yeux|strong="H5869"\w* \w des|strong="H5869"\w* \w nations|strong="H1471"\w*.
\v 42 \w Vous|strong="H3068"\w* \w saurez|strong="H3045"\w* \w que|strong="H3588"\w* \w je|strong="H3588"\w* \w suis|strong="H3588"\w* \w le|strong="H5414"\w* \w SEIGNEUR|strong="H5414"\w*, \w quand|strong="H3588"\w* \w je|strong="H3588"\w* \w vous|strong="H3068"\w* \w ferai|strong="H5414"\w* \w entrer|strong="H5414"\w* \w dans|strong="H5414"\w* \w le|strong="H5414"\w* \w pays|strong="H5414"\w* d'\w Israël|strong="H3478"\w*, \w dans|strong="H5414"\w* \w le|strong="H5414"\w* \w pays|strong="H5414"\w* \w que|strong="H3588"\w* \w j|strong="H3068"\w*'\w avais|strong="H5414"\w* \w juré|strong="H5375"\w* \w de|strong="H3027"\w* \w donner|strong="H5414"\w* \w à|strong="H3068"\w* \w vos|strong="H5414"\w* \w pères|strong="H5414"\w*.
\v 43 \w Là|strong="H6213"\w*, \w vous|strong="H6440"\w* \w vous|strong="H6440"\w* \w souviendrez|strong="H2142"\w* \w de|strong="H6440"\w* \w votre|strong="H6440"\w* \w conduite|strong="H1870"\w* \w et|strong="H6440"\w* \w de|strong="H6440"\w* \w toutes|strong="H6213"\w* \w vos|strong="H6440"\w* \w actions|strong="H5949"\w* \w par|strong="H6440"\w* \w lesquelles|strong="H6440"\w* \w vous|strong="H6440"\w* \w vous|strong="H6440"\w* \w êtes|strong="H6440"\w* \w souillés|strong="H2930"\w*. \w Vous|strong="H6440"\w* \w vous|strong="H6440"\w* prendrez vous-mêmes \w en|strong="H6213"\w* \w dégoût|strong="H6962"\w* \w pour|strong="H6213"\w* \w tous|strong="H3605"\w* \w les|strong="H6213"\w* \w maux|strong="H7451"\w* \w que|strong="H6440"\w* \w vous|strong="H6440"\w* \w avez|strong="H6440"\w* \w commis|strong="H6213"\w*.
\v 44 \w Vous|strong="H3068"\w* \w saurez|strong="H3045"\w* \w que|strong="H3588"\w* \w je|strong="H3588"\w* \w suis|strong="H3588"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3045"\w*, \w quand|strong="H3808"\w* \w j|strong="H3068"\w*'\w agirai|strong="H6213"\w* \w envers|strong="H6213"\w* \w vous|strong="H3068"\w* \w par|strong="H3068"\w* \w égard|strong="H3045"\w* \w pour|strong="H6213"\w* \w mon|strong="H3068"\w* \w nom|strong="H8034"\w*, \w et|strong="H3068"\w* \w non|strong="H3808"\w* d'\w après|strong="H1004"\w* \w votre|strong="H3808"\w* \w mauvaise|strong="H7451"\w* \w conduite|strong="H1870"\w*, \w ni|strong="H3808"\w* d'\w après|strong="H1004"\w* \w vos|strong="H6213"\w* \w actions|strong="H5949"\w* \w corrompues|strong="H7843"\w*, \w maison|strong="H1004"\w* d'\w Israël|strong="H3478"\w*, déclare \w le|strong="H3068"\w* \w Seigneur|strong="H3045"\w* \w DIEU|strong="H3068"\w*.” »
\p 
\v 45 La parole du SEIGNEUR me fut adressée :
\v 46 « Fils d'homme, tourne ton visage vers le sud, prêche vers le sud, et prophétise contre la forêt de la campagne du sud.
\v 47 Dis à la forêt du sud : “Écoute la parole du SEIGNEUR ! Ainsi parle le Seigneur DIEU : Voici, je vais allumer en toi un feu qui dévorera en toi tout arbre vert et tout arbre sec. La flamme ardente ne s'éteindra pas, et tous les visages en seront brûlés, du sud au nord.
\v 48 Toute chair verra que c'est moi, le SEIGNEUR, qui l'ai allumé. Il ne s'éteindra pas.” »
\p 
\v 49 Alors je dis : « Ah ! Seigneur DIEU ! Ils disent de moi : N'est-il pas un diseur de paraboles ? »
\c 21
\p 
\v 1 \w La|strong="H3068"\w* \w parole|strong="H1697"\w* \w du|strong="H1697"\w* \w SEIGNEUR|strong="H3068"\w* \w me|strong="H3068"\w* \w fut|strong="H3068"\w* \w adressée|strong="H1697"\w* :
\v 2 « \w Fils|strong="H1121"\w* \w d|strong="H6440"\w*'\w homme|strong="H1121"\w*, \w tourne|strong="H7760"\w* \w ton|strong="H6440"\w* \w visage|strong="H6440"\w* \w vers|strong="H6440"\w* \w Jérusalem|strong="H1121"\w*, prêche \w en|strong="H7760"\w* \w direction|strong="H1870"\w* \w des|strong="H1121"\w* sanctuaires, \w et|strong="H1121"\w* \w prophétise|strong="H5012"\w* \w contre|strong="H6440"\w* \w le|strong="H6440"\w* \w pays|strong="H7704"\w* \w d|strong="H6440"\w*'\w Israël|strong="H1121"\w*.
\v 3 \w Dis|strong="H1697"\w* \w au|strong="H3068"\w* \w pays|strong="H6440"\w* \w d|strong="H6440"\w*'\w Israël|strong="H3068"\w* : “\w Ainsi|strong="H3541"\w* \w parle|strong="H3541"\w* \w le|strong="H6440"\w* \w SEIGNEUR|strong="H6440"\w* : \w Voici|strong="H2005"\w*, \w je|strong="H6440"\w* \w suis|strong="H6440"\w* \w contre|strong="H3068"\w* \w toi|strong="H6440"\w*, \w je|strong="H6440"\w* tirerai \w mon|strong="H3068"\w* \w épée|strong="H6440"\w* \w de|strong="H6440"\w* \w son|strong="H6440"\w* fourreau, \w et|strong="H3068"\w* \w je|strong="H6440"\w* retrancherai \w du|strong="H6440"\w* \w milieu|strong="H3068"\w* \w de|strong="H6440"\w* \w toi|strong="H6440"\w* \w le|strong="H6440"\w* juste \w et|strong="H3068"\w* \w le|strong="H6440"\w* méchant.
\v 4 Puisque \w je|strong="H3588"\w* \w veux|strong="H3588"\w* retrancher \w du|strong="H3068"\w* \w milieu|strong="H3068"\w* \w de|strong="H7200"\w* \w toi|strong="H3068"\w* \w le|strong="H3068"\w* juste \w et|strong="H3068"\w* \w le|strong="H3068"\w* méchant, \w mon|strong="H3068"\w* épée sortira \w de|strong="H7200"\w* \w son|strong="H3068"\w* fourreau \w contre|strong="H3068"\w* \w toute|strong="H3605"\w* \w chair|strong="H1320"\w*, \w du|strong="H3068"\w* sud \w au|strong="H3068"\w* nord.
\v 5 Toute chair saura \w que|strong="H3808"\w* \w moi|strong="H3808"\w*, \w le|strong="H1931"\w* SEIGNEUR, j'\w ai|strong="H1931"\w* tiré \w mon|strong="H1931"\w* épée \w de|strong="H3808"\w* \w son|strong="H3808"\w* fourreau. \w Elle|strong="H1931"\w* n'\w y|strong="H1931"\w* retournera \w plus|strong="H3808"\w*.” »
\p 
\v 6 « \w Et|strong="H3068"\w* \w toi|strong="H3068"\w*, \w fils|strong="H1697"\w* d'\w homme|strong="H3068"\w*, gémis ! \w Tu|strong="H3068"\w* gémiras \w sous|strong="H3068"\w* \w leurs|strong="H3068"\w* \w yeux|strong="H3068"\w* \w avec|strong="H3068"\w* \w un|strong="H3068"\w* \w cœur|strong="H3068"\w* brisé\f + \fr 21.6 \ft littéralement, le brisement de tes reins\f* \w et|strong="H3068"\w* \w avec|strong="H3068"\w* amertume.
\v 7 \w S|strong="H3478"\w*'\w ils|strong="H1121"\w* \w te|strong="H6440"\w* \w demandent|strong="H3478"\w* : “\w Pourquoi|strong="H6440"\w* gémis-tu ?”, \w tu|strong="H3478"\w* \w répondras|strong="H3478"\w* : “\w À|strong="H3478"\w* \w cause|strong="H6440"\w* \w d|strong="H6440"\w*'\w une|strong="H1121"\w* nouvelle, \w car|strong="H6440"\w* \w elle|strong="H6440"\w* \w arrive|strong="H3478"\w* ! \w Tout|strong="H6440"\w* \w cœur|strong="H7760"\w* \w se|strong="H3478"\w* fondra, \w toutes|strong="H6440"\w* \w les|strong="H6440"\w* \w mains|strong="H6440"\w* deviendront faibles, \w tout|strong="H6440"\w* esprit défaillira, \w et|strong="H1121"\w* \w tous|strong="H1121"\w* \w les|strong="H6440"\w* genoux \w seront|strong="H1121"\w* faibles \w comme|strong="H1121"\w* \w de|strong="H1121"\w* \w l|strong="H6440"\w*'eau. \w Voici|strong="H1121"\w*, \w elle|strong="H6440"\w* \w arrive|strong="H3478"\w*, \w et|strong="H1121"\w* \w elle|strong="H6440"\w* \w s|strong="H3478"\w*'accomplira, \w dit|strong="H3478"\w* \w le|strong="H6440"\w* \w Seigneur|strong="H6440"\w* \w DIEU|strong="H6440"\w*.” »
\p 
\v 8 \w La|strong="H3068"\w* \w parole|strong="H3068"\w* \w du|strong="H3318"\w* \w SEIGNEUR|strong="H3068"\w* \w me|strong="H3068"\w* \w fut|strong="H3068"\w* adressée :
\v 9 « Fils d'\w homme|strong="H1320"\w*, prophétise, \w et|strong="H3318"\w* \w dis|strong="H3651"\w* : “\w Ainsi|strong="H3651"\w* parle \w le|strong="H3318"\w* \w SEIGNEUR|strong="H3318"\w* :
\q1 \w Une|strong="H3318"\w* \w épée|strong="H2719"\w* ! \w Une|strong="H3318"\w* \w épée|strong="H2719"\w* !
\q2 \w Elle|strong="H1320"\w* \w est|strong="H6662"\w* aiguisée,
\q2 \w elle|strong="H1320"\w* \w est|strong="H6662"\w* \w aussi|strong="H3651"\w* fourbie.
\q1 
