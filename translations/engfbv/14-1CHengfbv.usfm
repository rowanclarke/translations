\v 35 \w the|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Zuph, \w the|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Elkanah, \w the|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Mahath, \w the|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Amasai,
\v 36 \w the|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Elkanah, \w the|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Joel, \w the|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Azariah, \w the|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Zephaniah,
\v 37 \w the|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Tahath, \w the|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Assir, \w the|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Ebiasaph, \w the|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Korah,
\v 38 \w the|strong="H6659"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Izhar, \w the|strong="H6659"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Kohath, \w the|strong="H6659"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Levi, \w the|strong="H6659"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Israel.
\v 39 Asaph, Heman's relative, \w who|strong="H1121"\w* \w served|strong="H1961"\w* beside \w him|strong="H1961"\w* \w on|strong="H1961"\w* \w the|strong="H3588"\w* right: Asaph \w son|strong="H1121"\w* \w of|strong="H1121"\w* Berekiah, \w the|strong="H3588"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Shimea,
\v 40 \w the|strong="H5414"\w* son \w of|strong="H5439"\w* Michael, \w the|strong="H5414"\w* son \w of|strong="H5439"\w* Baaseiah, \w the|strong="H5414"\w* son \w of|strong="H5439"\w* Malkijah,
\v 41 \w the|strong="H5414"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Ethni, \w the|strong="H5414"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Zerah, \w the|strong="H5414"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Adaiah,
\v 42 \w the|strong="H5414"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Ethan, \w the|strong="H5414"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Zimmah, \w the|strong="H5414"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Shimei,
\v 43 the son \w of|strong="H4054"\w* Jahath, the son \w of|strong="H4054"\w* Gershon, the son \w of|strong="H4054"\w* Levi.
\v 44 To Heman's left served sons \w of|strong="H4054"\w* Merari: Ethan son \w of|strong="H4054"\w* Kishi, the son \w of|strong="H4054"\w* Abdi,
\p the son \w of|strong="H4054"\w* Malluch,
\v 45 \w the|strong="H3605"\w* son \w of|strong="H4294"\w* Hashabiah, \w the|strong="H3605"\w* son \w of|strong="H4294"\w* Amaziah, \w the|strong="H3605"\w* son \w of|strong="H4294"\w* Hilkiah,
\v 46 \w the|strong="H2677"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Amzi, \w the|strong="H2677"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Bani, \w the|strong="H2677"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Shemer,
\v 47 \w the|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Mahli, \w the|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Mushi, \w the|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Merari, \w the|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Levi.
\p 
\v 48 \w The|strong="H1121"\w* \w other|strong="H8147"\w* \w Levites|strong="H1121"\w* carried \w out|strong="H8147"\w* all \w the|strong="H1121"\w* \w other|strong="H8147"\w* functions \w in|strong="H5892"\w* \w the|strong="H1121"\w* Tabernacle, \w the|strong="H1121"\w* house \w of|strong="H1121"\w* God.
\p 
\v 49 However, \w it|strong="H5414"\w* \w was|strong="H3478"\w* Aaron \w and|strong="H1121"\w* \w his|strong="H5414"\w* \w descendants|strong="H1121"\w* \w who|strong="H1121"\w* \w were|strong="H3478"\w* \w the|strong="H5414"\w* \w ones|strong="H1121"\w* \w who|strong="H1121"\w* \w gave|strong="H5414"\w* \w offerings|strong="H3478"\w* \w on|strong="H5892"\w* \w the|strong="H5414"\w* altar \w of|strong="H1121"\w* burnt offering \w and|strong="H1121"\w* \w on|strong="H5892"\w* \w the|strong="H5414"\w* altar \w of|strong="H1121"\w* incense \w and|strong="H1121"\w* \w did|strong="H3478"\w* \w all|strong="H5414"\w* \w the|strong="H5414"\w* \w work|strong="H5414"\w* \w in|strong="H3478"\w* \w the|strong="H5414"\w* Most Holy \w Place|strong="H5414"\w*, \w making|strong="H5414"\w* atonement \w for|strong="H1121"\w* \w Israel|strong="H3478"\w* according \w to|strong="H3478"\w* everything \w Moses|strong="H5414"\w* \w the|strong="H5414"\w* servant \w of|strong="H1121"\w* \w God|strong="H5414"\w* \w had|strong="H3478"\w* commanded.
\p 
\v 50 \w The|strong="H5414"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* Aaron \w were|strong="H1121"\w*: Eleazar \w his|strong="H5414"\w* \w son|strong="H1121"\w*, Phinehas \w his|strong="H5414"\w* \w son|strong="H1121"\w*, Abishua \w his|strong="H5414"\w* \w son|strong="H1121"\w*,
\v 51 Bukki \w his|strong="H1961"\w* \w son|strong="H1121"\w*,
\p Uzzi \w his|strong="H1961"\w* \w son|strong="H1121"\w*, Zerahiah \w his|strong="H1961"\w* \w son|strong="H1121"\w*,
\v 52 Meraioth \w his|strong="H5414"\w* son, Amariah \w his|strong="H5414"\w* son, Ahitub \w his|strong="H5414"\w* son,
\v 53 Zadok his son,
\p \w and|strong="H4054"\w* Ahimaaz his son.
\p 
\v 54 These were the places they were given to live as their territory allotted to descendants \w of|strong="H4054"\w* Aaron, beginning with the Kohathite clan, because theirs was the first lot:
\p 
\v 55 They \w received|strong="H3498"\w* Hebron \w in|strong="H1121"\w* Judah together \w with|strong="H3498"\w* its surrounding \w pasturelands|strong="H4054"\w*.
\v 56 But \w the|strong="H2677"\w* fields \w and|strong="H1121"\w* villages near \w the|strong="H2677"\w* town \w were|strong="H1121"\w* given \w to|strong="H1121"\w* Caleb \w son|strong="H1121"\w* \w of|strong="H1121"\w* Jephunneh.
\p 
\v 57 So \w the|strong="H3485"\w* descendants \w of|strong="H4294"\w* Aaron received Hebron, \w a|strong="H3068"\w* town \w of|strong="H4294"\w* refuge, Libnah, Jattir, Eshtemoa,
\v 58 Hilen, Debir,
\v 59 Ashan, Juttah\f + \fr 6:59 \ft This town in missing from the list here, but is included in \xt Joshua 21:16\xt*\ft .\f* \w and|strong="H4054"\w* Beth Shemesh, together \w with|strong="H4294"\w* their \w pasturelands|strong="H4054"\w*.
\v 60 From the tribe \w of|strong="H4054"\w* Benjamin they received Gibeon,\f + \fr 6:60 \ft This town in missing from the list here, but is included in \xt Joshua 21:17\xt*\ft .\f* Geba, Alemeth, \w and|strong="H4054"\w* Anathoth, together with their \w pasturelands|strong="H4054"\w*.
\p They had \w a|strong="H3068"\w* total \w of|strong="H4054"\w* thirteen towns among their families.
\p 
\v 61 \w The|strong="H4294"\w* rest \w of|strong="H4294"\w* Kohath's descendants received by lot ten towns \w from|strong="H4294"\w* \w the|strong="H4294"\w* half \w tribe|strong="H4294"\w* \w of|strong="H4294"\w* Manasseh.
\p 
\v 62 \w The|strong="H1121"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* Gershon, \w by|strong="H4847"\w* family, \w received|strong="H3498"\w* thirteen towns \w from|strong="H1121"\w* \w the|strong="H1121"\w* \w tribes|strong="H4294"\w* \w of|strong="H1121"\w* Issachar, Asher, \w and|strong="H1121"\w* Naphtali, \w and|strong="H1121"\w* \w from|strong="H1121"\w* \w the|strong="H1121"\w* partial \w tribe|strong="H4294"\w* \w of|strong="H1121"\w* Manasseh \w in|strong="H1121"\w* Bashan.
\p 
\v 63 \w The|strong="H5676"\w* descendants \w of|strong="H4294"\w* Merari, \w by|strong="H3383"\w* family, received twelve towns \w from|strong="H4294"\w* \w the|strong="H5676"\w* \w tribes|strong="H4294"\w* \w of|strong="H4294"\w* \w Reuben|strong="H7205"\w*, Gad, \w and|strong="H4054"\w* Zebulun.
\p 
\v 64 So the people \w of|strong="H4054"\w* Israel gave the Levites these towns \w and|strong="H4054"\w* their \w pasturelands|strong="H4054"\w*.
\v 65 They allotted \w the|strong="H1410"\w* towns already mentioned by name \w from|strong="H4294"\w* \w the|strong="H1410"\w* \w tribes|strong="H4294"\w* \w of|strong="H4294"\w* Judah, Simeon, \w and|strong="H4054"\w* Benjamin.
\p 
\v 66 Some \w of|strong="H3270"\w* \w the|strong="H3270"\w* Kohathite families received \w as|strong="H2809"\w* their territory towns from \w the|strong="H3270"\w* tribe \w of|strong="H3270"\w* Ephraim.
\v 67 They were given Shechem, \w a|strong="H3068"\w* town of refuge, in the hill country of Ephraim, Gezer,\f + \fr 6:67 \ft Here Gezer is also included as a town of refuge, but see \xt Joshua 21:21\xt*\ft .\f*
\v 68 Jokmeam, Beth Horon,
\v 69 Aijalon, and Gath Rimmon, together with their pasturelands.
\p 
\v 70 From half the tribe of Manasseh the people of Israel gave Aner and Bileam, together with their pasturelands, to the rest of the Kohathite families.
\p 
\v 71 The descendants of Gershon received the following. From the family of the half-tribe of Manasseh: Golan in Bashan, and Ashtaroth, together with their pasturelands;
\p 
\v 72 from the tribe of Issachar: Kedesh, Daberath,
\v 73 Ramoth, and Anem, together with their pasturelands;
\p 
\v 74 from the tribe of Asher: Mashal, Abdon,
\v 75 Hukok, and Rehob, together with their pasturelands;
\p 
\v 76 and from the tribe of Naphtali: Kedesh in Galilee, Hammon, and Kiriathaim, together with their pasturelands.
\p 
\v 77 The rest of the descendants of Merari received the following. From the tribe of Zebulun: Jokneam, Kartah,\f + \fr 6:77 \ft Jokneah and Kartah are not included in the list here, but see \xt Joshua 21:34\xt*\ft .\f* Rimmono, and Tabor, together with their pasturelands;
\p 
\v 78 from the tribe of Reuben on the east side of the Jordan opposite Jericho: Bezer (in the desert), Jahzah,
\v 79 Kedemoth, and Mephaath, together with their pasturelands;
\p 
\v 80 and from the tribe of Gad: Ramoth in Gilead, Mahanaim,
\v 81 Heshbon, and Jazer, together with their pasturelands.
\b
\c 7
\p 
\v 1 \w The|strong="H1121"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Issachar|strong="H3485"\w*: \w Tola|strong="H8439"\w*, \w Puah|strong="H6312"\w*, \w Jashub|strong="H3437"\w* \w and|strong="H1121"\w* \w Shimron|strong="H8110"\w*—\w a|strong="H3068"\w* total \w of|strong="H1121"\w* four.
\p 
