\s1 The sacrifices during the Harvest Festival
\p 
\v 26 “\w On|strong="H3117"\w* \w the|strong="H3605"\w* \w day|strong="H3117"\w* \w of|strong="H3068"\w* \w the|strong="H3605"\w* Harvest Festival, \w when|strong="H1961"\w* \w you|strong="H3605"\w* \w bring|strong="H7126"\w* \w to|strong="H3068"\w* \w me|strong="H6213"\w* \w the|strong="H3605"\w* \w first|strong="H1061"\w* \w grain|strong="H3605"\w* \w that|strong="H3605"\w* \w you|strong="H3605"\w* \w have|strong="H1961"\w* harvested, \w you|strong="H3605"\w* \w must|strong="H3808"\w* \w gather|strong="H6213"\w* \w together|strong="H7126"\w* \w to|strong="H3068"\w* worship \w me|strong="H6213"\w*. \w Do|strong="H6213"\w* \w not|strong="H3808"\w* \w do|strong="H6213"\w* \w any|strong="H3605"\w* \w work|strong="H4399"\w* \w on|strong="H3117"\w* \w that|strong="H3605"\w* \w day|strong="H3117"\w*.
\v 27 \w Bring|strong="H7126"\w* \w to|strong="H3068"\w* \w me|strong="H1121"\w* \w two|strong="H8147"\w* \w young|strong="H1121"\w* \w bulls|strong="H6499"\w*, \w one|strong="H3532"\w* \w male|strong="H3532"\w* \w sheep|strong="H3532"\w*, \w and|strong="H1121"\w* \w seven|strong="H7651"\w* \w male|strong="H3532"\w* \w lambs|strong="H3532"\w* \w that|strong="H3068"\w* \w are|strong="H1121"\w* one-year-old. \w When|strong="H1121"\w* \w they|strong="H3068"\w* \w are|strong="H1121"\w* completely burned \add on the altar\add*, \w the|strong="H3068"\w* \w smell|strong="H7381"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* very pleasing \w to|strong="H3068"\w* \w me|strong="H1121"\w*.
\v 28 Also bring \w a|strong="H3068"\w* grain \w offering|strong="H4503"\w* \w of|strong="H8147"\w* nice \w flour|strong="H5560"\w* \w mixed|strong="H1101"\w* \w with|strong="H1101"\w* \add olive\add* \w oil|strong="H8081"\w*. \w For|strong="H6241"\w* \w each|strong="H8147"\w* \w bull|strong="H6499"\w*, bring \w six|strong="H7969"\w* quarts/liters, \w and|strong="H6499"\w* \w with|strong="H1101"\w* \w each|strong="H8147"\w* male sheep, bring \w four|strong="H7969"\w* quarts/liters,
\v 29 \w and|strong="H7651"\w* with \w each|strong="H3532"\w* \w of|strong="H6241"\w* the \w lambs|strong="H3532"\w* bring two quarts/liters.
\v 30 Also sacrifice one \w male|strong="H8163"\w* \w goat|strong="H5795"\w* \w to|strong="H5921"\w* cause \w you|strong="H5921"\w* \w to|strong="H5921"\w* be \w forgiven|strong="H3722"\w* \w for|strong="H5921"\w* \w your|strong="H5921"\w* sins.
\v 31 \w Bring|strong="H6213"\w* \w these|strong="H6213"\w* \w offerings|strong="H5930"\w* \w and|strong="H5930"\w* \w the|strong="H6213"\w* \w offering|strong="H4503"\w* \w of|strong="H4503"\w* wine \w in|strong="H6213"\w* addition \w to|strong="H1961"\w* \w the|strong="H6213"\w* \w animals|strong="H1961"\w* \w and|strong="H5930"\w* \w grain|strong="H8548"\w* \w that|strong="H6213"\w* \w you|strong="H6213"\w* burn \add on the altar\add* each day. \add And remember that\add* \w the|strong="H6213"\w* \w animals|strong="H1961"\w* \w that|strong="H6213"\w* \w you|strong="H6213"\w* \w sacrifice|strong="H5930"\w* must \w have|strong="H1961"\w* \w no|strong="H6213"\w* defects.”
\c 29
\s1 The sacrifices for the Festival of Trumpets
\p 
\v 1 “\add Each year\add*, \w gather|strong="H6213"\w* together \w to|strong="H1961"\w* worship \w me|strong="H6213"\w* \w on|strong="H3117"\w* \w the|strong="H3605"\w* \w first|strong="H3117"\w* \w day|strong="H3117"\w* \w of|strong="H3117"\w* \w the|strong="H3605"\w* \w seventh|strong="H7637"\w* \w month|strong="H2320"\w*, \w and|strong="H3117"\w* \w do|strong="H6213"\w* \w not|strong="H3808"\w* \w do|strong="H6213"\w* \w any|strong="H3605"\w* \w work|strong="H4399"\w* \w on|strong="H3117"\w* \w that|strong="H3605"\w* \w day|strong="H3117"\w*. \w On|strong="H3117"\w* \w that|strong="H3605"\w* \w day|strong="H3117"\w* \add the priests\add* \w must|strong="H3808"\w* \w blow|strong="H8643"\w* \w their|strong="H3605"\w* \w trumpets|strong="H8643"\w*.
\p 
\v 2 \w When|strong="H6213"\w* \w the|strong="H6213"\w* \w offerings|strong="H5930"\w* \add on the altar on that day\add* \w are|strong="H1121"\w* \w being|strong="H1121"\w* completely burned, \w the|strong="H6213"\w* \w smell|strong="H7381"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* \w very|strong="H6213"\w* pleasing \w to|strong="H3068"\w* \w me|strong="H6213"\w*. \w The|strong="H6213"\w* animals \w that|strong="H3068"\w* \w you|strong="H6213"\w* \w must|strong="H1121"\w* \w bring|strong="H6213"\w* \w are|strong="H1121"\w* \w one|strong="H3532"\w* \w young|strong="H1121"\w* \w bull|strong="H6499"\w*, \w one|strong="H3532"\w* \w male|strong="H3532"\w* \w sheep|strong="H3532"\w*, \w and|strong="H1121"\w* \w seven|strong="H7651"\w* \w male|strong="H3532"\w* \w lambs|strong="H3532"\w* \w that|strong="H3068"\w* \w are|strong="H1121"\w* one-year-old. \w They|strong="H3068"\w* \w must|strong="H1121"\w* \w have|strong="H3068"\w* \w no|strong="H6213"\w* defects.
\v 3 \w With|strong="H1101"\w* \w these|strong="H8147"\w* animals bring \w an|strong="H4503"\w* \w offering|strong="H4503"\w* \w of|strong="H8147"\w* grain consisting \w of|strong="H8147"\w* finely-ground \w flour|strong="H5560"\w* \w mixed|strong="H1101"\w* \w with|strong="H1101"\w* \add olive\add* \w oil|strong="H8081"\w*. \w With|strong="H1101"\w* \w the|strong="H8147"\w* \w bull|strong="H6499"\w*, bring \w six|strong="H7969"\w* quarts/liters. \w With|strong="H1101"\w* \w the|strong="H8147"\w* male sheep, bring \w four|strong="H7969"\w* quarts/liters,
\v 4 \w and|strong="H7651"\w* with \w each|strong="H3532"\w* \w of|strong="H6241"\w* the \w seven|strong="H7651"\w* \w lambs|strong="H3532"\w* bring two quarts/liters.
\v 5 Also offer one \w male|strong="H8163"\w* \w goat|strong="H5795"\w* \w in|strong="H5921"\w* order \w that|strong="H5795"\w* \w you|strong="H5921"\w* \w will|strong="H2403"\w* \w be|strong="H2403"\w* \w forgiven|strong="H3722"\w* \w for|strong="H5921"\w* \w your|strong="H5921"\w* \w sins|strong="H2403"\w*.
\v 6 \w All|strong="H8548"\w* \w of|strong="H3068"\w* those animals \w are|strong="H3068"\w* \w in|strong="H3068"\w* addition \w to|strong="H3068"\w* \w the|strong="H3068"\w* animals \w that|strong="H3068"\w* \w are|strong="H3068"\w* completely burned \add on the altar\add* each morning \w and|strong="H3068"\w* \w on|strong="H3068"\w* \w the|strong="H3068"\w* first \w day|strong="H2320"\w* \w of|strong="H3068"\w* each \w month|strong="H2320"\w*. \w The|strong="H3068"\w* \w offerings|strong="H5930"\w* \w of|strong="H3068"\w* \w grain|strong="H8548"\w* \w and|strong="H3068"\w* wine must \w be|strong="H3068"\w* \w made|strong="H3068"\w* exactly \w as|strong="H3068"\w* \w I|strong="H3068"\w* \w have|strong="H3068"\w* told you \w to|strong="H3068"\w* \w do|strong="H3068"\w*. \w When|strong="H3068"\w* these \w offerings|strong="H5930"\w* \w are|strong="H3068"\w* burned, \w the|strong="H3068"\w* \w smell|strong="H7381"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* very pleasing \w to|strong="H3068"\w* \w me|strong="H4941"\w*.”
\s1 The day of Atonement
\p 
\v 7 “\add Each year\add*, \w on|strong="H1961"\w* \w the|strong="H3605"\w* \w tenth|strong="H6218"\w* \w day|strong="H2320"\w* \w of|strong="H3605"\w* \w the|strong="H3605"\w* \w seventh|strong="H7637"\w* \w month|strong="H2320"\w*, \w you|strong="H3605"\w* \w must|strong="H5315"\w* \w gather|strong="H6213"\w* together \w to|strong="H1961"\w* worship \w me|strong="H5315"\w*. \w Do|strong="H6213"\w* \w not|strong="H3808"\w* eat \w any|strong="H3605"\w* food \w or|strong="H3808"\w* \w do|strong="H6213"\w* \w any|strong="H3605"\w* \w work|strong="H4399"\w* \w on|strong="H1961"\w* \w that|strong="H3605"\w* \w day|strong="H2320"\w*.
\v 8 \w When|strong="H1961"\w* \w you|strong="H7126"\w* burn \w offerings|strong="H5930"\w* \add on the altar\add* \w on|strong="H3068"\w* \w that|strong="H3068"\w* day, \w the|strong="H3068"\w* \w smell|strong="H7381"\w* \w will|strong="H3068"\w* \w be|strong="H1961"\w* very pleasing \w to|strong="H3068"\w* \w me|strong="H1961"\w*. \w The|strong="H3068"\w* \w animals|strong="H1961"\w* \w that|strong="H3068"\w* \w you|strong="H7126"\w* \w must|strong="H1121"\w* \w bring|strong="H7126"\w* \w are|strong="H1121"\w* \w one|strong="H3532"\w* \w young|strong="H1121"\w* \w bull|strong="H6499"\w*, \w one|strong="H3532"\w* \w male|strong="H3532"\w* \w sheep|strong="H3532"\w*, \w and|strong="H1121"\w* \w seven|strong="H7651"\w* \w male|strong="H3532"\w* \w lambs|strong="H3532"\w* \w that|strong="H3068"\w* \w are|strong="H1121"\w* one-year-old. \w They|strong="H3068"\w* \w must|strong="H1121"\w* \w have|strong="H1961"\w* \w no|strong="H1961"\w* defects.
\v 9 \w With|strong="H1101"\w* \w the|strong="H8147"\w* \w bull|strong="H6499"\w*, bring \w an|strong="H4503"\w* \w offering|strong="H4503"\w* \w of|strong="H8147"\w* grain consisting \w of|strong="H8147"\w* \w six|strong="H7969"\w* quarts/liters \w of|strong="H8147"\w* nice \w flour|strong="H5560"\w* \w mixed|strong="H1101"\w* \w with|strong="H1101"\w* \add olive\add* \w oil|strong="H8081"\w*. \w With|strong="H1101"\w* \w the|strong="H8147"\w* male sheep, bring \w four|strong="H7969"\w* quarts/liters.
\v 10 With \w each|strong="H3532"\w* \w of|strong="H6241"\w* the \w lambs|strong="H3532"\w*, bring two quarts/liters.
\v 11 Also bring one \w male|strong="H8163"\w* \w goat|strong="H5795"\w* \w to|strong="H4503"\w* \add enable me to forgive\add* you \w for|strong="H4503"\w* the \w sins|strong="H2403"\w* you \w have|strong="H2403"\w* committed, \w and|strong="H5930"\w* the animals \w and|strong="H5930"\w* \w grain|strong="H8548"\w* \w and|strong="H5930"\w* wine \w that|strong="H4503"\w* you burn \add on the altar\add* each day \w to|strong="H4503"\w* enable me \w to|strong="H4503"\w* forgive you \w for|strong="H4503"\w* the \w sins|strong="H2403"\w* you \w have|strong="H2403"\w* committed. Those \w offerings|strong="H5930"\w* \w will|strong="H2403"\w* \w be|strong="H2403"\w* \w in|strong="H4503"\w* addition \w to|strong="H4503"\w* the animals \w and|strong="H5930"\w* \w grain|strong="H8548"\w* \w and|strong="H5930"\w* wine \w that|strong="H4503"\w* \w are|strong="H2403"\w* completely burned \add on the altar\add* each day.”
\s1 The Festival of Shelters
\p 
\v 12 “\w On|strong="H3117"\w* \w the|strong="H3605"\w* \w fifteenth|strong="H2568"\w* \w day|strong="H3117"\w* \w of|strong="H3068"\w* \w the|strong="H3605"\w* \w seventh|strong="H7637"\w* \w month|strong="H2320"\w* \add of each year\add*, \w you|strong="H3605"\w* \w must|strong="H2282"\w* \w all|strong="H3605"\w* \w gather|strong="H6213"\w* together \w to|strong="H3068"\w* worship \w me|strong="H6213"\w*. \w You|strong="H3605"\w* \w must|strong="H2282"\w* \w not|strong="H3808"\w* \w do|strong="H6213"\w* \w any|strong="H3605"\w* \w work|strong="H4399"\w* \w on|strong="H3117"\w* \w that|strong="H3605"\w* \w day|strong="H3117"\w*. \w You|strong="H3605"\w* \w must|strong="H2282"\w* \w continue|strong="H1961"\w* \w to|strong="H3068"\w* \w celebrate|strong="H6213"\w* \w for|strong="H6213"\w* \w seven|strong="H7651"\w* \w days|strong="H3117"\w*.
\v 13 \w When|strong="H1961"\w* \w the|strong="H3068"\w* \w offerings|strong="H5930"\w* \w are|strong="H1121"\w* burned \add on the altar\add*, \w the|strong="H3068"\w* \w smell|strong="H7381"\w* \w will|strong="H3068"\w* \w be|strong="H1961"\w* very pleasing \w to|strong="H3068"\w* \w me|strong="H1961"\w*. \w The|strong="H3068"\w* \w animals|strong="H1961"\w* \w that|strong="H3068"\w* \w you|strong="H7126"\w* \w must|strong="H1121"\w* \w bring|strong="H7126"\w* \w are|strong="H1121"\w* 13 \w young|strong="H1121"\w* \w bulls|strong="H6499"\w*, \w two|strong="H8147"\w* \w male|strong="H3532"\w* \w sheep|strong="H3532"\w*, \w and|strong="H1121"\w* 14 \w male|strong="H3532"\w* \w lambs|strong="H3532"\w* \w that|strong="H3068"\w* \w are|strong="H1121"\w* one-year-old. \w These|strong="H8147"\w* \w animals|strong="H1961"\w* \w must|strong="H1121"\w* \w have|strong="H1961"\w* \w no|strong="H1961"\w* defects.
\v 14 \w With|strong="H1101"\w* \w each|strong="H8147"\w* \w of|strong="H8147"\w* \w the|strong="H8147"\w* 13 \w bulls|strong="H6499"\w*, bring \w a|strong="H3068"\w* grain \w offering|strong="H4503"\w* \w of|strong="H8147"\w* \w six|strong="H7969"\w* quarts/liters \w of|strong="H8147"\w* finely-ground \w flour|strong="H5560"\w* \w mixed|strong="H1101"\w* \w with|strong="H1101"\w* \add olive\add* \w oil|strong="H8081"\w*. \w With|strong="H1101"\w* \w each|strong="H8147"\w* \w of|strong="H8147"\w* \w the|strong="H8147"\w* male sheep, bring \w four|strong="H7969"\w* quarts/liters.
\v 15 With \w each|strong="H3532"\w* \w of|strong="H6241"\w* \w the|strong="H6240"\w* 14 \w lambs|strong="H3532"\w*, bring two quarts/liters.
\v 16 Also bring one \w male|strong="H8163"\w* \w goat|strong="H5795"\w* \w to|strong="H4503"\w* \w be|strong="H2403"\w* sacrificed \add to enable me to forgive you\add* \w for|strong="H4503"\w* your \w sins|strong="H2403"\w*, \w in|strong="H4503"\w* addition \w to|strong="H4503"\w* the \w offerings|strong="H5930"\w* \w of|strong="H2403"\w* animals \w and|strong="H5930"\w* \w grain|strong="H8548"\w* \w and|strong="H5930"\w* wine \w that|strong="H4503"\w* \w are|strong="H2403"\w* completely burned \add on the altar\add* each day.
\p 
\v 17-34 “For the next six days of the festival, you must also bring animals to sacrifice. On the second day, bring twelve bulls. On the third/next day, bring eleven bulls. One the fourth/next day, bring ten bulls. On the fifth/next day, bring nine bulls. On the sixth/next day, bring eight bulls. On the seventh/last day, bring seven bulls. But on each of those days, all the other sacrifices and offerings that you bring will remain the same.
\p 
\v 35 “\w On|strong="H3117"\w* \w the|strong="H3605"\w* \w eighth|strong="H8066"\w* \w day|strong="H3117"\w* \w of|strong="H3117"\w* \w the|strong="H3605"\w* festival, \w you|strong="H3605"\w* \w must|strong="H3808"\w* \add again\add* \w gather|strong="H6213"\w* together \w to|strong="H1961"\w* worship \w me|strong="H6213"\w*, \w and|strong="H3117"\w* \w do|strong="H6213"\w* \w not|strong="H3808"\w* \w do|strong="H6213"\w* \w any|strong="H3605"\w* \w work|strong="H4399"\w* \w on|strong="H3117"\w* \w that|strong="H3605"\w* \w day|strong="H3117"\w*.
\v 36 \w On|strong="H3068"\w* \w that|strong="H3068"\w* day, \w you|strong="H7126"\w* \w must|strong="H1121"\w* \w bring|strong="H7126"\w* \w to|strong="H3068"\w* \w the|strong="H3068"\w* altar \w one|strong="H3532"\w* \w bull|strong="H6499"\w*, \w one|strong="H3532"\w* full-grown ram, \w and|strong="H1121"\w* \w seven|strong="H7651"\w* \w lambs|strong="H3532"\w* \w that|strong="H3068"\w* \w are|strong="H1121"\w* one-year-old. These animals \w must|strong="H1121"\w* \w have|strong="H3068"\w* no defects. \w They|strong="H3068"\w* \w must|strong="H1121"\w* \w all|strong="H3068"\w* \w be|strong="H3068"\w* burned \w on|strong="H3068"\w* \w the|strong="H3068"\w* altar, \w and|strong="H1121"\w* \w their|strong="H3068"\w* \w smell|strong="H7381"\w* \w will|strong="H3068"\w* please \w me|strong="H1121"\w*.
\v 37 Bring also \w with|strong="H4941"\w* \w the|strong="H4557"\w* \w bull|strong="H6499"\w* \w and|strong="H4941"\w* \w the|strong="H4557"\w* \w male|strong="H3532"\w* \w sheep|strong="H3532"\w* \w and|strong="H4941"\w* \w each|strong="H3532"\w* \w of|strong="H4557"\w* \w the|strong="H4557"\w* \w lambs|strong="H3532"\w* \w the|strong="H4557"\w* \w offerings|strong="H4503"\w* \w of|strong="H4557"\w* grain \w and|strong="H4941"\w* wine \w that|strong="H4557"\w* ◄\w are|strong="H5262"\w* required/\w I|strong="H4503"\w* told you \w to|strong="H4941"\w* bring►.
\v 38 Also offer one \w male|strong="H8163"\w* \w goat|strong="H8163"\w* \w to|strong="H4503"\w* \w be|strong="H2403"\w* sacrificed \add to enable me to forgive you\add* \w for|strong="H4503"\w* your \w sins|strong="H2403"\w*. These animals \w will|strong="H2403"\w* \w be|strong="H2403"\w* \w in|strong="H4503"\w* addition \w to|strong="H4503"\w* the \w offerings|strong="H5930"\w* \w of|strong="H2403"\w* animals \w and|strong="H5930"\w* \w grain|strong="H8548"\w* \w and|strong="H5930"\w* wine \w that|strong="H4503"\w* \w are|strong="H2403"\w* completely burned \add on the altar\add* each day.
\p 
\v 39 “\w At|strong="H3068"\w* \w your|strong="H3068"\w* \w festivals|strong="H4150"\w*, \w these|strong="H6213"\w* \w are|strong="H3068"\w* \w the|strong="H6213"\w* \w offerings|strong="H8002"\w* \w that|strong="H3068"\w* \w you|strong="H6213"\w* must \w bring|strong="H6213"\w* \w to|strong="H3068"\w* \w me|strong="H6213"\w*: \w The|strong="H6213"\w* \w offerings|strong="H8002"\w* \w that|strong="H3068"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* completely burned \add on the altar\add*, \w the|strong="H6213"\w* \w offerings|strong="H8002"\w* \w of|strong="H3068"\w* grain \w and|strong="H3068"\w* wine, \w and|strong="H3068"\w* \w the|strong="H6213"\w* \w offerings|strong="H8002"\w* \w to|strong="H3068"\w* \w maintain|strong="H6213"\w* fellowship \w with|strong="H3068"\w* \w me|strong="H6213"\w*. \w Those|strong="H6213"\w* \w are|strong="H3068"\w* \w in|strong="H3068"\w* addition \w to|strong="H3068"\w* \w the|strong="H6213"\w* \w offerings|strong="H8002"\w* \w that|strong="H3068"\w* \w you|strong="H6213"\w* \w give|strong="H6213"\w* \w to|strong="H3068"\w* \w me|strong="H6213"\w* \w because|strong="H3068"\w* \w you|strong="H6213"\w* \w promised|strong="H3068"\w* \w to|strong="H3068"\w* \w do|strong="H6213"\w* something, \w and|strong="H3068"\w* other special \w offerings|strong="H8002"\w* \w that|strong="H3068"\w* \w you|strong="H6213"\w* want \w to|strong="H3068"\w* \w give|strong="H6213"\w* \w to|strong="H3068"\w* \w me|strong="H6213"\w*.”
\p 
\v 40 Then Moses/I told to the Israeli people all the things that \w Yahweh|strong="H3068"\w* had commanded him/me.
\c 30
\s1 Rules about special promises to Yahweh
\p 
\v 1 \w Moses|strong="H4872"\w*/\w I|strong="H6680"\w* spoke \w with|strong="H3068"\w* \w the|strong="H3605"\w* leaders \w of|strong="H1121"\w* \w the|strong="H3605"\w* Israeli tribes. \w He|strong="H3068"\w*/\w I|strong="H6680"\w* \w told|strong="H6680"\w* \w them|strong="H6680"\w* \w these|strong="H3605"\w* \w commands|strong="H6680"\w* \w that|strong="H3605"\w* \w Yahweh|strong="H3068"\w* \w had|strong="H3068"\w* \w given|strong="H6680"\w* \w to|strong="H3478"\w* \w him|strong="H6680"\w*/\w me|strong="H6680"\w*:
\p 
