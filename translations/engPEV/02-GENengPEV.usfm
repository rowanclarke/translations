\p
\v 26 Then Joseph told Pharaoh \w what|strong="H2896"\w* \w those|strong="H2007"\w* \w dreams|strong="H2472"\w* meant. First Joseph said, “\w Those|strong="H2007"\w* 7 \w good-looking|strong="H2896"\w*, fat \w cows|strong="H6510"\w* \w that|strong="H1931"\w* \w you|strong="H2007"\w* saw \w in|strong="H8141"\w* your \w dream|strong="H2472"\w*, \w they|strong="H2007"\w* \w are|strong="H8141"\w* \w like|strong="H2896"\w* \w a|strong="H3068"\w* picture \w of|strong="H8141"\w* 7 \w good|strong="H2896"\w* \w years|strong="H8141"\w*. \w And|strong="H8141"\w* \w those|strong="H2007"\w* 7 groups \w of|strong="H8141"\w* \w good|strong="H2896"\w* big seeds \w on|strong="H6510"\w* \w the|strong="H8141"\w* wheat plant, \w they|strong="H2007"\w* \w are|strong="H8141"\w* \w like|strong="H2896"\w* \w a|strong="H3068"\w* picture \w of|strong="H8141"\w* 7 \w good|strong="H2896"\w* \w years|strong="H8141"\w* too. Both \w those|strong="H2007"\w* \w dreams|strong="H2472"\w* mean \w the|strong="H8141"\w* \w same|strong="H1931"\w* \w thing|strong="H2896"\w*.”   
\p
\v 27 \w Then|strong="H1961"\w* Joseph said, “\w And|strong="H8141"\w* \w you|strong="H8141"\w* know \w those|strong="H2007"\w* 7 \w ugly|strong="H7451"\w*, skinny \w cows|strong="H6510"\w*, \w those|strong="H2007"\w* \w ones|strong="H7451"\w* \w that|strong="H8141"\w* \w came|strong="H1961"\w* \w up|strong="H5927"\w* \w from|strong="H5927"\w* \w the|strong="H5927"\w* river \w later|strong="H1961"\w* \w on|strong="H1961"\w*, \w they|strong="H2007"\w* \w are|strong="H8141"\w* \w like|strong="H1961"\w* \w a|strong="H3068"\w* picture \w of|strong="H8141"\w* 7 dry \w years|strong="H8141"\w* \w with|strong="H5927"\w* \w no|strong="H5927"\w* rain \w and|strong="H8141"\w* \w no|strong="H5927"\w* food plants \w growing|strong="H5927"\w*. \w And|strong="H8141"\w* \w you|strong="H8141"\w* know \w those|strong="H2007"\w* 7 small groups \w of|strong="H8141"\w* seeds \w on|strong="H1961"\w* \w the|strong="H5927"\w* wheat plant. \w They|strong="H2007"\w* \w were|strong="H1961"\w* dry, because \w a|strong="H3068"\w* hot dry \w wind|strong="H6921"\w* blew \w on|strong="H1961"\w* \w them|strong="H2007"\w*. Well, \w they|strong="H2007"\w* \w are|strong="H8141"\w* \w like|strong="H1961"\w* \w a|strong="H3068"\w* picture \w of|strong="H8141"\w* \w those|strong="H2007"\w* 7 dry \w years|strong="H8141"\w* \w too|strong="H1961"\w*.”   
\p
\v 28 \w Then|strong="H1696"\w* Joseph \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w Pharaoh|strong="H6547"\w*, “Sir, God \w gave|strong="H6213"\w* \w you|strong="H6213"\w* \w those|strong="H1931"\w* dreams \w to|strong="H1696"\w* \w show|strong="H7200"\w* \w you|strong="H6213"\w* \w what|strong="H1697"\w* \w he|strong="H1931"\w* \w is|strong="H1931"\w* going \w to|strong="H1696"\w* \w do|strong="H6213"\w* \w next|strong="H7200"\w*, \w just|strong="H1697"\w* \w like|strong="H1697"\w* \w I|strong="H1697"\w* \w said|strong="H1696"\w*.  
