\c 37
\s1 Joseph had two dreams about himself and his brothers
\p 
\v 1 \w Jacob|strong="H3290"\w* \w continued|strong="H3427"\w* \w to|strong="H3427"\w* \w live|strong="H3427"\w* \w in|strong="H3427"\w* \w the|strong="H3427"\w* \w Canaan|strong="H3667"\w* region \w where|strong="H4033"\w* \w his|strong="H3290"\w* father \w had|strong="H3290"\w* \w lived|strong="H3427"\w* previously.
\v 2 ◄\w This|strong="H1931"\w* \w is|strong="H1931"\w*/\w I|strong="H5288"\w* \w will|strong="H1961"\w* \w now|strong="H1961"\w* tell \w you|strong="H8141"\w*► \w what|strong="H7451"\w* \w happened|strong="H1961"\w* \w to|strong="H1961"\w* \w Jacob|strong="H3290"\w*’s family.
\p \w When|strong="H1961"\w* \w his|strong="H1961"\w* \w son|strong="H1121"\w* \w Joseph|strong="H3130"\w* \w was|strong="H1961"\w* 17 \w years|strong="H8141"\w* \w old|strong="H1121"\w*, \w he|strong="H1931"\w* \w was|strong="H1961"\w* taking care \w of|strong="H1121"\w* \w the|strong="H1961"\w* \w flocks|strong="H6629"\w* \w of|strong="H1121"\w* \w sheep|strong="H6629"\w* \w and|strong="H1121"\w* \w goats|strong="H1121"\w* \w with|strong="H6629"\w* some \w of|strong="H1121"\w* \w his|strong="H1961"\w* older \w brothers|strong="H1121"\w*. \w They|strong="H8141"\w* \w were|strong="H1961"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w his|strong="H1961"\w* \w father|strong="H1121"\w*’s ◄concubines/female \w slaves|strong="H1121"\w* \w that|strong="H1931"\w* \w he|strong="H1931"\w* \w had|strong="H1961"\w* \w taken|strong="H1961"\w* \w to|strong="H1961"\w* \w be|strong="H1961"\w* \w his|strong="H1961"\w* secondary wives►. \w Joseph|strong="H3130"\w* sometimes told \w his|strong="H1961"\w* \w father|strong="H1121"\w* \w about|strong="H1961"\w* \w bad|strong="H7451"\w* \w things|strong="H7451"\w* \w that|strong="H1931"\w* \w his|strong="H1961"\w* \w brothers|strong="H1121"\w* \w were|strong="H1961"\w* \w doing|strong="H7451"\w*.
\p 
\v 3 Jacob loved \w Joseph|strong="H3130"\w* \w more|strong="H3588"\w* \w than|strong="H3588"\w* \w he|strong="H1931"\w* loved \w any|strong="H3605"\w* \w of|strong="H1121"\w* \w his|strong="H3605"\w* \w other|strong="H3605"\w* \w children|strong="H1121"\w*, \w because|strong="H3588"\w* \w Joseph|strong="H3130"\w* \w had|strong="H3478"\w* \w been|strong="H3605"\w* \w born|strong="H1121"\w* \w when|strong="H3588"\w* Jacob \w was|strong="H3478"\w* \w an|strong="H6213"\w* \w old|strong="H1121"\w* \w man|strong="H1121"\w*. Jacob \w made|strong="H6213"\w* \w for|strong="H3588"\w* \w Joseph|strong="H3130"\w* \w a|strong="H3068"\w* \w long|strong="H3605"\w* pretty \w robe|strong="H3801"\w* \w that|strong="H3588"\w* \w had|strong="H3478"\w* \w long|strong="H3605"\w* sleeves.
\v 4 \w When|strong="H3588"\w* \w Joseph|strong="H3808"\w*’s older brothers \w realized|strong="H7200"\w* \w that|strong="H3588"\w* \w their|strong="H3605"\w* father loved \w him|strong="H7200"\w* \w more|strong="H3808"\w* \w than|strong="H3808"\w* \w he|strong="H3588"\w* loved \w any|strong="H3605"\w* \w of|strong="H3605"\w* \w them|strong="H7200"\w*, \w they|strong="H3588"\w* \w hated|strong="H8130"\w* \w him|strong="H7200"\w*. \w They|strong="H3588"\w* \w never|strong="H3808"\w* \w spoke|strong="H1696"\w* kindly \w to|strong="H1696"\w* \w him|strong="H7200"\w*.
\p 
\v 5 One night \w Joseph|strong="H3130"\w* \w had|strong="H2492"\w* \w a|strong="H3068"\w* \w dream|strong="H2472"\w*. \w He|strong="H3130"\w* \w told|strong="H5046"\w* \w his|strong="H5046"\w* brothers \w about|strong="H3130"\w* \w the|strong="H5046"\w* \w dream|strong="H2472"\w*.
\v 6 \w He|strong="H2088"\w* \w said|strong="H8085"\w* \w to|strong="H8085"\w* \w them|strong="H8085"\w*, “\w Listen|strong="H8085"\w* \w to|strong="H8085"\w* \w the|strong="H8085"\w* \w dream|strong="H2492"\w* \w I|strong="H2088"\w* \w had|strong="H2492"\w*!
\v 7 \w In|strong="H8432"\w* \w the|strong="H8432"\w* dream, \w we|strong="H3068"\w* \w were|strong="H1571"\w* tying \w up|strong="H6965"\w* bundles \w of|strong="H7704"\w* wheat \w in|strong="H8432"\w* \w the|strong="H8432"\w* \w field|strong="H7704"\w*. \w Suddenly|strong="H2009"\w* \w my|strong="H6965"\w* bundle \w stood|strong="H5324"\w* \w up|strong="H6965"\w* straight, \w and|strong="H6965"\w* surprisingly, \w your|strong="H6965"\w* bundles \w gathered|strong="H5437"\w* \w around|strong="H5437"\w* \w my|strong="H6965"\w* bundle \w and|strong="H6965"\w* \w bowed|strong="H7812"\w* \w down|strong="H7812"\w* \w to|strong="H6965"\w* \w it|strong="H8432"\w*!”
\v 8 \w His|strong="H5921"\w* brothers \w said|strong="H1697"\w* \w to|strong="H5921"\w* \w him|strong="H5921"\w*, “\w Do|strong="H3254"\w* \w you|strong="H5921"\w* \w think|strong="H8130"\w* \w that|strong="H1697"\w* \w some|strong="H1697"\w* day \w you|strong="H5921"\w* \w will|strong="H1697"\w* \w rule|strong="H4910"\w* \w over|strong="H5921"\w* \w us|strong="H5921"\w*? \w Are|strong="H1697"\w* \w you|strong="H5921"\w* \add saying that some day\add* \w you|strong="H5921"\w* \w are|strong="H1697"\w* going \w to|strong="H5921"\w* \w be|strong="H5750"\w* \w our|strong="H5921"\w* \w king|strong="H4427"\w*?” [RHQ] \w They|strong="H5921"\w* \w hated|strong="H8130"\w* \w him|strong="H5921"\w* \w even|strong="H5750"\w* \w more|strong="H3254"\w* \w than|strong="H5921"\w* \w before|strong="H5921"\w* \w because|strong="H5921"\w* \w of|strong="H1697"\w* \w what|strong="H1697"\w* \w he|strong="H5921"\w* \w had|strong="H4910"\w* \w told|strong="H1697"\w* \w them|strong="H5921"\w* \w about|strong="H5921"\w* \w his|strong="H5921"\w* \w dream|strong="H2472"\w*.
\p 
\v 9 Later \w he|strong="H8121"\w* \w had|strong="H2492"\w* \w another|strong="H5750"\w* \w dream|strong="H2472"\w*, \w and|strong="H5750"\w* \w again|strong="H5750"\w* \w he|strong="H8121"\w* \w told|strong="H5608"\w* \w his|strong="H5608"\w* older brothers \w about|strong="H5608"\w* \w it|strong="H2009"\w*. \w He|strong="H8121"\w* said, “\w Listen|strong="H2009"\w* \w to|strong="H2472"\w* \w this|strong="H2009"\w*! \w I|strong="H2009"\w* \w had|strong="H2492"\w* \w another|strong="H5750"\w* \w dream|strong="H2472"\w*. \w In|strong="H5750"\w* \w this|strong="H2009"\w* \w dream|strong="H2472"\w*, \w the|strong="H7812"\w* \w sun|strong="H8121"\w* \w and|strong="H5750"\w* \w moon|strong="H3394"\w* \w and|strong="H5750"\w* \w eleven|strong="H6240"\w* \w stars|strong="H3556"\w* \w were|strong="H2009"\w* \w bowing|strong="H7812"\w* \w down|strong="H7812"\w* \w to|strong="H2472"\w* \w me|strong="H5608"\w*!”
\v 10 \w He|strong="H2088"\w* \w also|strong="H2088"\w* \w told|strong="H5608"\w* \w his|strong="H5608"\w* father \w about|strong="H5608"\w* \w it|strong="H4100"\w*. \w His|strong="H5608"\w* father \w rebuked|strong="H1605"\w* \w him|strong="H2088"\w*, saying “\w What|strong="H4100"\w* \w are|strong="H4100"\w* \w you|strong="H4100"\w* suggesting \w by|strong="H2472"\w* \w that|strong="H2088"\w* \w dream|strong="H2472"\w* [RHQ]? \w Do|strong="H4100"\w* \w you|strong="H4100"\w* think \w it|strong="H4100"\w* means \w that|strong="H2088"\w* \w your|strong="H2088"\w* mother \w and|strong="H2088"\w* \w I|strong="H2088"\w* \w and|strong="H2088"\w* \w your|strong="H2088"\w* older brothers \w will|strong="H4100"\w* some day \w bow|strong="H7812"\w* \w down|strong="H7812"\w* \w to|strong="H2472"\w* \w the|strong="H7812"\w* ground \w in|strong="H2088"\w* front \w of|strong="H5608"\w* \w you|strong="H4100"\w*?” [RHQ]
\v 11 Joseph’s older brothers \w were|strong="H1697"\w* furious/angry \w with|strong="H1697"\w* \w him|strong="H7065"\w*, but \w his|strong="H8104"\w* father \w just|strong="H1697"\w* \w kept|strong="H8104"\w* thinking \w about|strong="H1697"\w* \w what|strong="H1697"\w* \w the|strong="H8104"\w* dream meant.
\p 
