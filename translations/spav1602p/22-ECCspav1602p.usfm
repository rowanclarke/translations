\m 
\v 1 \w ECHA|strong="H7971"\w* tu \w pan|strong="H3899"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w*; \w que|strong="H3588"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w muchos|strong="H7230"\w* \w días|strong="H3117"\w* \w lo|strong="H5921"\w* \w hallarás|strong="H4672"\w*.
