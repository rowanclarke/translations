\id MIC - Biblica® Open Igbo Contemporary Bible 2020 
\h Maika 
\toc1 Maika 
\toc2 Maika 
\toc3 Mai 
\mt1 Maika 
\c 1  
\p  
\v 1 Nke a bụ okwu \nd Onyenwe anyị\nd* nke bịaara Maịka, onye Moreshet, nʼoge eze Jotam, Ehaz na Hezekaya, bụ ndị eze Juda. Ọhụ nke ọ hụrụ banyere Sameria na Jerusalem. 
\b  
\b  
\q1  
\v 2 Geenụ ntị, unu ndị mmadụ, unu niile, 
\q2 gee ntị, gị ụwa na ndị niile bi nʼime ya 
\q1 ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* gbaa akaebe megide unu, 
\q2 bụ Onyenwe anyị site nʼụlọnsọ ukwu ya. 
\s1 Ikpe ọmụma dịrị Sameria na Izrel 
\q1  
\v 3 Lee! \nd Onyenwe anyị\nd* na-abịa! O si nʼebe obibi ya na-abịa. 
\q2 Ọ na-abịa ma na-azọda ebe niile dị elu nke ụwa. 
\q1  
\v 4 Ugwu ukwu niile na-agbaze nʼokpuru ụkwụ ya, 
\q2 ndagwurugwu niile na-agbawa, 
\q1 dịka abụba dị nso nʼọkụ, 
\q2 dịka mmiri si nʼebe dị elu na-asọdata 
\q1  
\v 5 Ihe ndị a bụ nʼihi njehie Jekọb, 
\q2 nʼihi mmehie niile nke ndị Izrel. 
\q1 Gịnị bụ njehie Jekọb? 
\q2 Ọ bụghị Sameria? 
\q1 Gịnịkwa bụ ebe dị elu nke Juda? 
\q2 Ọ bụghị Jerusalem? 
\b  
\q1  
\v 6 “Nʼihi ya, aga m eme ka Sameria ghọọ mkpọmkpọ ebe, 
\q2 ebe a na-akụ osisi vaịnị.\f + \fr 1:6 \ft Ya bụ, ubi vaịnị\f* 
\q1 Aga m awụnye nkume ya nʼime ndagwurugwu, 
\q2 mekwaa ka ntọala ya pụta ihe. 
\q1  
\v 7 Arụsị ha niile a pịrị apị ka a ga-akụjisi; 
\q2 onyinye niile a na-ewebata nʼụlọ arụsị ha ka a ga-akpọ ọkụ. 
\q2 Aga m ala arụsị niile ya a kpụrụ akpụ nʼiyi. 
\q1 Ebe ọ bụ na e si nʼaka ndị na-agba akwụna na-ewebata onyinye ndị a, 
\q2 a ga-eji ha kwụọ ụgwọ ịgba akwụna.” 
\s1 Ịkwa akwa na iru ụjụ 
\q1  
\v 8 Nʼihi nke a, aga m akwa akwa, tikwaa mkpu akwa. 
\q2 Aga m agbara ọtọ gbarakwa ụkwụ efu jegharịa. 
\q1 Aga m akpọ mkpu dịka nkịta ọhịa, 
\q2 tipụkwa ube akwa dịka ikwighịkwighị. 
\q1  
\v 9 Nʼihi na ọnya ya enweghị ngwọta, 
\q2 o rutela na Juda. 
\q1 O rutelarị ma nʼọnụ ụzọ ama nke ndị m, 
\q2 rukwaarị Jerusalem. 
\q1  
\v 10 Unu ekwutela okwu ya na Gat; 
\q2 unu akwakwala akwa ọbụla. 
\q1 Tụrụọnụ onwe unu nʼuzuzu, 
\q2 unu ndị Bet-Ofra.\f + \fr 1:10 \fq Bet-Ofra \ft Maọbụ, \fqa Bet-Leafra \ft nke pụtara \fqa ụlọ uzuzu\f* 
\q1  
\v 11 Gabiganụ nʼụzọ unu, 
\q2 unu ndị bi na Shafia. 
\q1 Nʼọnọdụ ịgba ọtọ na ihere unu, 
\q2 unu ndị bi na Zaanan abịakwala nso. 
\q1 Ndị Bet-Ezel na-eru ụjụ 
\q2 nʼihi na e wezugala ndị na-eche unu nche. 
\q1  
\v 12 Ndị bi na Marot nọ nʼoke ahụ mgbu 
\q2 na-eche ka ihe ọma bịa, 
\q1 nʼihi na mbibi esitela nʼaka \nd Onyenwe anyị\nd* bịa, 
\q2 ruo nʼọnụ ụzọ ama Jerusalem 
\q1  
\v 13 Unu ndị bi na Lakish 
\q2 kegidenụ ịnyịnya unu na-agba ọsọ nʼụgbọ agha. 
\q1 Ọ bụ nʼebe ahụ ka mmehie nwaada Zayọn malitere, 
\q2 nʼihi na mmehie Izrel na-eme ka a hụrụ nʼetiti unu. 
\q1  
\v 14 Ya mere, unu ga-enye Moreshet dị na Gat onyinye 
\q2 mgbe unu na-agbapụ ọsọ. 
\q1 Ụlọ Akzib ga-emesịa ghọọ ụlọ aghụghọ 
\q2 nye ndị eze Izrel. 
\q1  
\v 15 Aga m akpọbata onye ga-emeri unu 
\q2 ndị bi na Maresha nʼagha. 
\q1 Ndị a na-asọpụrụ nke Izrel 
\q2 ga-agbabanye nʼAdulam. 
\q1  
\v 16 Kpachaanụ isi unu nʼọnọdụ iru ụjụ 
\q2 nʼihi ụmụntakịrị ndị ahụ ihe ha masịrị unu, 
\q1 meenụ ka isi unu kwọchaa dịka isi udele, 
\q2 nʼihi na a ga-achụpụ ha site nʼebe unu nọ gaa mba ọzọ. 
\c 2  
\s1 Nzube mmadụ na nzube Chineke 
\q1  
\v 1 Ahụhụ na-adịrị ndị na-eche ihe ọjọọ nʼobi ha, 
\q2 na ndị niile na-edina nʼakwa ha na-eche ajọ echiche. 
\q1 Mgbe chi bọrọ, ha na-arụzu ihe ha chepụtara, 
\q2 nʼihi na ikike imezu ya dị nʼaka ha. 
\q1  
\v 2 Ha na-enwe anya ukwu nʼebe ubi ndị ọzọ dị, were ha nʼaka ike, 
\q2 na ụlọ dị iche iche, ha ewere ha nʼike. 
\q1 Ha na-ejikwa aka ike nara ndị mmadụ ụlọ ha, 
\q2 ha na-ezunara ha ihe nketa ha. 
\p  
\v 3 Nʼihi nke a, \nd Onyenwe anyị\nd* na-asị, 
\q1 “Lee, ana m akwado ihe ọjọọ megide agbụrụ a, 
\q2 nke unu na-enweghị ike isite na ya wezuga onwe unu. 
\q1 Unu agaghị eji nganga na-ejegharịkwa, 
\q2 nʼihi na ọ ga-abụ oge ọjọọ. 
\q1  
\v 4 Nʼụbọchị ahụ ha ga-akọcha unu, 
\q2 ha ga-abụrụ unu abụ iru ụjụ iji ya kọchaa unu na-asị, 
\q1 ‘Anyị abụrụla ndị lara nʼiyi, 
\q2 e kesaala ihe nnweta nke ndị m, 
\q1 ọ napụla m ha. 
\q2 O werela ubi anyị nyefee ha nʼaka ndị ahụ meriri anyị nʼagha.’ ” 
\b  
\q1  
\v 5 Nʼihi ya, ọ dịkwaghị onye ga-afọdụ nʼetiti ọgbakọ nke \nd Onyenwe anyị\nd*, 
\q2 onye ga-eji ihe ọtụtụ kee ala ahụ site nʼife nza. 
\s1 Ndị amụma ụgha 
\q1  
\v 6 Ndị amụma ha na-asị, “Unu ebukwala amụma.” 
\q2 “Unu ebukwala amụma banyere ihe ndị a, 
\q2 ihere agaghị eme anyị.” 
\q1  
\v 7 Ụdị ihe a o kwesiri okwukwu, gị ụlọ Jekọb? 
\q2 “Ntachiobi \nd Onyenwe anyị\nd* ọ gwụla? 
\q2 Ihe ndị a ọ bụ otu o si eme?” 
\b  
\q1 “Ọ bụ na okwu m adịghị eme 
\q2 onye ụzọ ya ziri ezi mma? 
\q1  
\v 8 Ma ọ bụ unu na-ebili megide ndị m 
\q2 dịka ndị iro. 
\q1 Unu na-eyipụ ndị na-agafe agafe 
\q2 uwe ọma ha yi nʼahụ ha na-enweghị mmetụta, 
\q2 dịka a ga-asị na unu bụ ndị si nʼagha na-alọta. 
\q1  
\v 9 Unu na-achụpụ ndị inyom ndị m 
\q2 site nʼụlọ afọ ojuju ha. 
\q1 Ụmụ ha ka unu na-anapụ ngọzị m 
\q2 ruo mgbe ebighị ebi. 
\q1  
\v 10 Bilienụ, pụọnụ, 
\q2 nʼihi na ebe a abụkwaghị ebe izuike, 
\q1 nʼihi na-emerụọla ya, e bibiela ya, 
\q2 o bibikwaala, ruo na-ịrụzi ya agaghị adị ire. 
\q1  
\v 11 Ọ bụrụ na otu onye abịa buoro unu amụma ụgha na-asị, 
\q2 ‘Aga m eburu unu amụma banyere mmanya na ihe ọṅụṅụ siri ike,’ 
\q2 ọ bụ onye amụma dị otu a ka ndị a chọrọ. 
\s1 Nkwa nzọpụta 
\q1  
\v 12 “Aga m achịkọta unu niile, gị Jekọb, 
\q2 aga m akpọkọta ndị niile fọdụrụ nʼIzrel nʼotu ebe. 
\q1 Aga m akpọkọta ha dịka atụrụ nʼime ọgba anụ, 
\q2 dịka igwe ewu na atụrụ nʼebe ịta nri ya, 
\q2 ndị mmadụ ga-ejupụtakwa nʼebe ahụ. 
\q1  
\v 13 Onye ahụ na-egbuwa ụzọ ga-anọ nʼihu na-edu ha. 
\q2 Ha ga-etipukwa ọnụ ụzọ ama ahụ, ma site na ya gafee. 
\q1 Eze ha ga-agabigakwa nʼihu ha, 
\q2 \nd Onyenwe anyị\nd* ga-anọ nʼisi.” 
\c 3  
\s1 Ịba mba nye ndịisi na ndị amụma 
\p  
\v 1 Mgbe ahụ ekwuru m sị, 
\q1 “Geenụ ntị unu ndịisi ụlọ Jekọb, 
\q2 na unu ndị na-achị ezinaụlọ Izrel. 
\q1 Ọ bụ na unu ekwesighị ịmata ikpe ziri ezi 
\q2  
\v 2 unu bụ ndị kpọrọ ezi ihe asị ma na-ahụ ajọ ọrụ nʼanya. 
\q1 Unu na-agba ndị m akpụkpọ na ndụ 
\q2 na-agbapụkwa anụ ahụ kpuchiri ọkpụkpụ ha. 
\q1  
\v 3 Unu na-erida anụ ahụ ndị nke m, 
\q2 na-agba ha akpụkpọ, 
\q2 na-etijisi ọkpụkpụ ha, 
\q1 na-egburi anụ ahụ ha, 
\q2 dịka anụ a na-esinye nʼite.” 
\b  
\q1  
\v 4 Mgbe ahụ ha ga-akpọku \nd Onyenwe anyị\nd*, 
\q2 ma ọ gaghị aza ha! 
\q1 Mgbe oge ahụ bịaruru, ọ ga-ezo ihu ha site nʼebe ha nọ 
\q2 nʼihi ihe ọjọọ nke ha mere. 
\p  
\v 5 Ihe a ka \nd Onyenwe anyị\nd* kwuru: 
\q1 “Banyere ndị amụma 
\q2 bụ ndị na-eduhie ndị m, 
\q1 mgbe ha nwere ihe ha ga-eri, 
\q2 ha na-ekwusa ‘Udo’ 
\q1 ma ọ bụrụ na mmadụ enyeghị ha nri, 
\q2 ha na-ebili buo agha\f + \fr 3:5 \ft Nʼakwụkwọ ụfọdụ ha na-ede agha nsọ\f* megide onye dị otu a. 
\q1  
\v 6 Ya mere nʼabalị ga-abịakwasị ha, napụ ha ike ịhụ ọhụ; 
\q2 ọchịchịrị ga-ekpuchi ha, ka ha ghara ịjụta ase ọbụla. 
\q1 Anwụ ga-ada nʼebe ndị amụma ahụ nọ, 
\q2 ụbọchị ga-agbakwa ọchịchịrị nye ha. 
\q1  
\v 7 Ndị ọhụ ụzọ ka ihere ga-eme, 
\q2 ndị na-ajụ ase ka a ga-emebọ. 
\q1 Ha ga-ekpuchi ihu ha, 
\q2 nʼihi na ọsịsa ọbụla agaghị esite nʼebe Chineke nọ bịara ha.” 
\q1  
\v 8 Ma mụ onwe m, ejupụtara m nʼike, 
\q2 ejupụtara m na Mmụọ nke \nd Onyenwe anyị\nd*, 
\q2 jupụtakwa na mmụọ nke ikpe ziri ezi, 
\q1 na nke ịdị ike ikwupụta nye Jekọb njehie ya, 
\q2 na nye Izrel mmehie ya. 
\b  
\q1  
\v 9 Geenụ ntị unu ndị na-achị ezinaụlọ Jekọb, 
\q2 na unu ndịisi ezinaụlọ Izrel. 
\q1 Ndị kpọrọ ikpe ziri ezi asị, 
\q2 ma na-ewere ihe niile na-ezighị ezi nʼọnọdụ ihe ziri ezi. 
\q1  
\v 10 Ndị ji ọbara wuo Zayọn, 
\q2 werekwa ajọ omume wuo Jerusalem. 
\q1  
\v 11 Ndịisi ya na-ekpe ikpe nʼihi ngarị, 
\q2 ndị nchụaja ya na-akụzi ihe nʼihi ụgwọ, 
\q2 ebe ndị amụma ya na-ajụta ase nʼihi ego. 
\q1 Ma ha dabere na \nd Onyenwe anyị\nd* na-asị, 
\q2 “\nd Onyenwe anyị\nd* ọ nọnyeereghị anyị? 
\q2 O nweghị ihe ọjọọ ga-abịakwasị anyị.” 
\q1  
\v 12 Ọ bụ nʼihi gị 
\q2 ka a ga-akọgharị Zayọn dịka ala ubi, 
\q1 Jerusalem ga-aghọ ebe e kpokọtara nkume na ngwongwo ụlọ dakpọrọ adakpọ, 
\q2 ugwu nke ụlọnsọ ukwu ahụ ga-aghọ ebe dị elu nke oke ọhịa tochiri. 
\c 4  
\s1 Ugwu \nd Onyenwe anyị\nd* 
\p  
\v 1 Nʼụbọchị ikpeazụ, 
\q1 ugwu nke ụlọnsọ ukwu \nd Onyenwe anyị\nd*, ga-abụ nke eguzobere 
\q2 dịka ugwu dị elu karịa ugwu niile, 
\q1 a ga-ebuli ya elu karịa ugwu nta niile, 
\q2 ndị dị iche iche ga-eruba nʼime ya dịka iyi. 
\p  
\v 2 Ọtụtụ mba ga-abịa ma sịkwa, 
\q1 “Bịanụ, ka anyị rigoruo ugwu \nd Onyenwe anyị\nd*, 
\q2 ka anyị gaa nʼụlọnsọ ukwu Chineke nke Jekọb. 
\q1 Ọ ga-akụziri anyị ụzọ\f + \fr 4:2 \ft Maọbụ, \fqa ụkpụrụ\f* ya niile, 
\q2 ka anyị nwe ike jee ije nʼokporoụzọ ya niile.” 
\q1 Iwu ga-esi na Zayọn pụta, 
\q2 okwu \nd Onyenwe anyị\nd* ga-esitekwa na Jerusalem pụta. 
\q1  
\v 3 Ọ ga-ekpe ikpe dị nʼetiti ndị dị iche iche, 
\q2 doziekwa esemokwu dị nʼetiti mba na mba ibe ya ruo ebe dị anya. 
\q1 Ha ga-akpụgharịkwa mma agha ha niile, mee ka ha bụrụ mma oge, 
\q2 kpụgharịkwa ùbe ha ka ha ghọọ mma ịkwacha osisi. 
\q1 Mba ọbụla agakwaghị ebuli mma agha megide mba ọzọ, 
\q2 maọbụ zụọ onwe ha nʼịlụ agha ọzọ. 
\q1  
\v 4 Onye ọbụla ga-anọdụrụ onwe ya nʼokpuru vaịnị 
\q2 na nʼokpuru osisi fiig ya, 
\q1 nʼihi na o nweghị onye ga-eme ka ha tụọ egwu ọzọ. 
\q2 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile ekwuola ya. 
\q1  
\v 5 Mba dị iche iche ga-agagharị 
\q2 nke ọbụla nʼaha chi ya, 
\q1 ma anyị onwe anyị ga na-aga nʼaha \nd Onyenwe anyị\nd*, 
\q2 bụ Chineke anyị ruo mgbe niile ebighị ebi. 
\s1 Nzube \nd Onyenwe anyị\nd* 
\q1  
\v 6 “Nʼụbọchị ahụ,” otu a ka \nd Onyenwe anyị\nd* kwupụtara, 
\q2 “aga m achịkọta ndị ngwụrọ, 
\q1 chịkọtaa ndị ahụ niile e mere ka ha biri na mba ọzọ, 
\q2 na ndị ahụ niile m mere ka ha ruo ụjụ. 
\q1  
\v 7 Aga m eme ka ndị ngwụrọ ahụ ghọọ ndị fọdụrụ ndụ, 
\q2 meekwaa ka ndị ahụ a chụpụrụ achụpụ ghọọ mba dị ike. 
\q1 \nd Onyenwe anyị\nd* ga-esi nʼugwu Zayọn chịa ha 
\q2 site nʼoge ahụ ruo mgbe ebighị ebi. 
\q1  
\v 8 Ma gị, ebe nche e wuliri elu maka igwe atụrụ, 
\q2 ugwu nke nwaada Zayọn, 
\q1 ọchịchị a na-achị na mbụ ga-adịghachikwara gị; 
\q2 bụ ọchịchị nke dịrị nwaada Jerusalem.” 
\b  
\q1  
\v 9 Gịnị mere i ji na-akwasị akwa ike? 
\q2 Ọ bụ na i nweghị eze? 
\q1 Onye ndụmọdụ gị ọ nwụọla 
\q2 nke mere na ihe ụfụ jidere gị dịka nwanyị ime na-eme? 
\q1  
\v 10 Susie ude ike, gị nwaada Zayọn, 
\q2 dịka ịsụ ude nke nwanyị ime na-eme, 
\q1 nʼihi na unu aghaghị ịhapụ obodo a 
\q2 jee biri nʼọhịa. 
\q1 Unu aghaghị ịga Babilọn, 
\q2 nʼihi na ọ bụ nʼebe ahụ ka a ga-esi napụta unu. 
\q1 Ebe ahụ ka \nd Onyenwe anyị\nd* ga-agbapụta unu 
\q2 site nʼaka ndị iro unu. 
\b  
\q1  
\v 11 Ugbu a, ọtụtụ mba ezukọọla 
\q2 imegide gị; 
\q1 na-asị, “Ka e merụọ ya 
\q2 ka anya anyị ṅụọ Zayọn.” 
\q1  
\v 12 Ma ha amaghị 
\q2 ihe bụ uche \nd Onyenwe anyị\nd*, 
\q1 ha aghọtakwaghị nzube ya, 
\q2 na ọ chịkọtala ha dịka ukwu ọka, na-ebuga ha nʼebe ịzọcha ọka. 
\q1  
\v 13 “Bilie, zọchaa, gị nwaada Zayọn, 
\q2 nʼihi na aga m enye gị mpi igwe. 
\q1 Aga m enyekwa gị ụkwụ ọla bronz, 
\q2 ị ga-etijisikwa ọtụtụ mba. 
\q1 Uru ha niile, nke ha nwetara nʼụzọ na-ezighị ezi, ka ị ga-enye \nd Onyenwe anyị\nd*. 
\q2 Akụnụba ha ka ị ga-enyekwa Chineke nwe ụwa niile.” 
\c 5  
\s1 Onyendu si Betlehem 
\q1  
\v 1 Ugbu a doo ndị agha gị nʼusoro, gị obodo nke usuu ndị agha, 
\q2 nʼihi na e jirila mgbidi gbaa gị gburugburu ibuso gị agha. 
\q1 Ha ga-eji mkpara 
\q2 tie onyendu Izrel na nti. 
\b  
\q1  
\v 2 “Ma gị onwe gị, Betlehem Efrata, 
\q2 ọ bụ ezie na ị bụ obodo dị nta nʼetiti ndị ikwu Juda niile, 
\q1 ma onye ahụ ga-achị Izrel 
\q2 ga-esi na gị pụta, 
\q1 bụ onye ahụ mmalite ya sitere na mgbe ochie, 
\q2 sitekwa na mgbe ebighị ebi gara aga.” 
\b  
\q1  
\v 3 Ya mere, a ga-arara ha nye 
\q2 tutu ruo mgbe onye ahụ ime na-eme mụpụtara nwa ya. 
\q1 Mgbe ahụ, ụmụnna ya niile ahụ fọdụrụ 
\q2 ga-alọghachikwuru ndị Izrel. 
\b  
\q1  
\v 4 Ọ ga-eguzo zụọ igwe ewu na atụrụ ya, 
\q2 site nʼike nke \nd Onyenwe anyị\nd*, 
\q2 na site nʼịdị ukwuu nke aha \nd Onyenwe anyị\nd* Chineke ya. 
\q1 Ndị ya ga-anọkwa na-enweghị nsogbu, 
\q2 nʼihi na ịdị ukwuu ya ga-eru na nsọtụ niile nke ụwa. 
\b  
\s1 Mgbapụta na Mbibi 
\q1  
\v 5 Ọ ga-abụkwa udo anyị. 
\q2 Mgbe ndị Asịrịa ga-abata nʼala anyị nʼike, 
\q2 sikwa nʼebe niile e wusiri ike nke anyị na-agafe, 
\q1 anyị ga-ahọpụta ndị ọzụzụ atụrụ asaa, 
\q2 ọ bụladị ndịisi asatọ. 
\q1  
\v 6 Onye ga-eji mma agha chịa ala Asịrịa, 
\q2 jirikwa mma agha a mịpụtara amịpụta chịa ala Nimrọd. 
\q1 Ọ ga-anapụta anyị site nʼaka ndị Asịrịa ahụ, 
\q2 mgbe ha ga-eji ike bata nʼala anyị, 
\q2 ma zọrọkwa ije gafee oke ala anyị. 
\b  
\q1  
\v 7 Mgbe ahụ, ndị fọdụrụ afọdụ nke Jekọb 
\q2 ga-adị nʼetiti ọtụtụ ndị mmadụ, 
\q1 dịka igirigi si nʼebe Onyenwe anyị nọ abịa, 
\q2 maọbụ dịka mmiri ozuzo ntakịrị na-ezokwasị ahịhịa, 
\q1 nke na-adịghị ele anya mmadụ 
\q2 maọbụ chere ụmụ mmadụ. 
\q1  
\v 8 Ndị fọdụrụ afọdụ nke Jekọb 
\q2 ga-adịkwa nʼetiti ọtụtụ ndị mmadụ 
\q1 dị ka ọdụm nʼetiti anụ ọhịa niile dị iche iche, 
\q2 e, dịka nwa ọdụm nʼetiti igwe atụrụ, 
\q1 nke na-azọda na-adọkasị mgbe ọ na-agabiga, 
\q2 ma o nweghị onye ga-anapụta ya. 
\q1  
\v 9 Aka gị ga-adị elu na mmeri nke ndị iro ya, 
\q2 a ghakwaghị ịla ndị iro gị niile nʼiyi. 
\p  
\v 10 “Nʼụbọchị ahụ kwa,” otu a ka \nd Onyenwe anyị\nd* kwubiri, 
\q1 “Aga m ala ịnyịnya unu nʼiyi site nʼetiti unu, 
\q2 kụjisiekwa ụgbọala unu niile. 
\q1  
\v 11 Aga m ala obodo niile dị nʼala unu nʼiyi, 
\q2 dọdasịakwa ebe unu niile e wusiri ike. 
\q1  
\v 12 Aga m ala mgbaasị unu nʼiyi, 
\q2 unu agaghị enwekwa ndị na-ajụ mmụọ ọjọọ ase. 
\q1  
\v 13 Aga m ala arụsị a pịrị apị unu niile nʼiyi, 
\q2 ya na nkume nsọ ahụ niile dị nʼetiti unu. 
\q1 Unu agakwaghị akpọ isiala nye 
\q2 ihe unu ji aka unu kpụọ. 
\q1  
\v 14 Aga m ehopu ogidi arụsị niile\f + \fr 5:14 \ft Ogidi ndị a bụ nke arụsị Ashera\f* nke dị nʼetiti unu, 
\q2 mgbe m ga-akụdasị obodo unu niile 
\q1  
\v 15 Aga m esite nʼoke iwe m na ọnụma m bọọrọ onwe m ọbọ 
\q2 nʼahụ mba niile ndị ahụ jụrụ irubere m isi.” 
\c 6  
\s1 Ikpe \nd Onyenwe anyị\nd* megide Izrel 
\p  
\v 1 Geenụ ntị nʼihe Onyenwe anyị na-ekwu, 
\q1 “Bilienụ ọtọ, ma kwuonụ nʼihu ugwu niile ụzọ m siri mejọọ unu. 
\q2 Ka ugwu nta niile nụkwa ihe i nwere ikwu. 
\b  
\q1  
\v 2 “Ma ugbu a geenụ ntị, unu ugwu niile, 
\q2 geenụ ntị, unu ntọala ebighị ebi niile nke ụwa, 
\q1 nʼihi na \nd Onyenwe anyị\nd* nwere ikpe megide ndị nke ya. 
\q2 Ọ bụkwa Izrel ka ọ ga-arụso ụka. 
\b  
\q1  
\v 3 “Unu bụ ndị m, gịnị ka m mere unu? 
\q2 Gwanụ m ụzọ m si boo unu ibu arọ? Zaanụ m. 
\q1  
\v 4 Nʼihi na e si m nʼala Ijipt kpọpụta unu. 
\q2 Agbapụtara m unu site na ịbụ ohu, 
\q1 nye unu Mosis 
\q2 na Erọn na Miriam ka ha nyere unu aka. 
\q1  
\v 5 Ndị m, chetanụ 
\q2 ihe Balak eze Moab zubere 
\q2 na ihe Belam nwa Beoa zara ya. 
\q1 Chetanụ njem unu site nʼobodo Shitim ruo obodo Gilgal, 
\q2 ka unu hụ nzọpụta nke Onyenwe anyị.” 
\b  
\q1  
\v 6 Gịnị ka m ga-eji bịa nʼihu \nd Onyenwe anyị\nd*, 
\q2 ịkpọ isiala nʼihu Chineke onye dị oke elu? 
\q1 M ga-eji onyinye aja nsure ọkụ bịa nʼihu ya 
\q2 nke e ji ụmụ ehi gbara otu afọ chụọ? 
\q1  
\v 7 Ọ ga-atọ \nd Onyenwe anyị\nd* ụtọ, bụ ọtụtụ puku ebule, 
\q2 ya na iri puku mmanụ na-asọ dịka iyi? 
\q1 Aga m eji nwa mbụ m chụọ aja njehie m, 
\q2 maọbụ mkpụrụ nke ahụ m chụọ aja maka mmehie nke mkpụrụobi m? 
\q1  
\v 8 Nʼihi na o gosila gị, gị mmadụ, ihe dị mma. 
\q2 Gịnịkwa bụ ihe ahụ \nd Onyenwe anyị\nd* na-achọ nʼaka gị, 
\q1 Ọ bụ na ọ bụghị ikpe ziri ezi, na ịhụ ime ebere nʼanya, 
\q2 na iji obi dị umeala soro Chineke gị na-eje ije? 
\s1 Ahụhụ Izrel na ikpe ọmụma ya 
\q1  
\v 9 Gee ntị! Olu \nd Onyenwe anyị\nd* na-ada na-akpọku ndị obodo ahụ, 
\q2 nʼezie, ịtụ egwu gị bụ inwe amamihe. 
\q2 “Nụrụnụ olu mkpanaka na Onye hiwere ya. 
\q1  
\v 10 Ọ ga-abụ na m ga-echezọ akụ ị kpara nʼụzọ na-ezighị ezi, gị ụlọ ajọ omume, 
\q2 ya na ihe ọtụtụ nke na-erughị eru unu ji ere ahịa, bụ nke abụrụ ọnụ? 
\q1  
\v 11 M ga-asị onye na-eji ihe ọtụtụ aghụghọ azụ ahịa, 
\q2 na onye bu akpa nke ihe ọtụtụ aghụghọ dị iche iche juru nʼime ya na aka ya dị ọcha? 
\q1  
\v 12 Ndị ọgaranya unu bụ ndị na-eme ihe ike, 
\q2 ndị mmadụ nọ nʼime gị na-agha ụgha, 
\q2 ire ha na-ekwu naanị okwu aghụghọ. 
\q1  
\v 13 Nʼihi ya, ebidola m ịla unu nʼiyi, 
\q2 na ime ka unu bụrụ ndị e bibiri nʼihi mmehie unu 
\q1  
\v 14 Unu ga-eri nri ma afọ agaghị eju unu; 
\q2 afọ agaghị ejukwa unu eju. 
\q1 Unu ga-ewezuga ihe, ma unu agaghị echekwa ha, 
\q2 nʼihi na ihe ọbụla unu nwere ike chekwaa, ka m ga-ewere nyefee nʼaka mma agha. 
\q1  
\v 15 Unu ga-akụ mkpụrụ, ma unu agaghị ewe ihe ubi, 
\q2 unu ga-azọchapụta mmanụ oliv, ma unu agaghị ete ya nʼahụ unu; 
\q2 unu ga-azọchapụtakwa mmanya site na mkpụrụ vaịnị, ma unu agaghị aṅụ mmanya ya. 
\q1  
\v 16 Unu edebela ụkpụrụ niile bụ nke Omri, 
\q2 na omenaala niile nke ụlọ Ehab, 
\q2 unu gbasokwara ndụmọdụ ha niile. 
\q1 Nʼihi ya, aga m enyefe unu nʼaka mbibi 
\q2 mee ka ndị gị ghọọkwa ihe ọchị, 
\q2 unu ga-aghọkwara mba niile ihe nkọcha.” 
\c 7  
\s1 Nhụju anya nke Izrel 
\q1  
\v 1 Ahụhụ dịrị m! 
\q1 Adị m ka onye na-achịkọta mkpụrụ osisi vaịnị nʼọkọchị, 
\q2 mgbe a ghọkọtachara mkpụrụ dị nʼubi vaịnị. 
\q1 O nweghị ụyọkọ mkpụrụ vaịnị ọbụla fọdụrụ nke e nwere ike ịta, 
\q2 o nwekwaghị mkpụrụ fiig buru ụzọ chaa nke agụ ya na-agụsị m ike 
\q1  
\v 2 Ndị ezi omume agwụla nʼụwa, 
\q2 ọ dịkwaghị otu onye na-eme ihe ziri ezi fọdụrụ. 
\q1 Ha niile na-echere oghere ịkwafu ọbara, 
\q2 ha ji ụgbụ na-achụta nta, onye ọbụla na-achụ ụmụnne ya. 
\q1  
\v 3 Ọrụ nke aka ha abụọ na-arụpụta nke ọma bụ ajọ omume. 
\q2 Onyeisi na-ana onyinye, 
\q1 onye ọkaikpe na-eri ngarị, 
\q2 ndị dị ike na-atụpụta ihe masịrị ha, 
\q2 si otu a na-akpagbu eziokwu.\f + \fr 7:3 \ft Maọbụ, \fqa ikpe ziri ezi\f* 
\q1  
\v 4 Onye nke kachasị ibe ya ịdị mma nʼime ha dịka uke. 
\q2 Onye nke na-eme ihe ziri ezi nʼime ha jọrọ njọ karịa ogige ogwu. 
\q1 Ma ugbu a, ụbọchị Chineke na-eleta gị abịala, 
\q2 ụbọchị ahụ ndị nche gị na-akụ ekwe ịdọ aka na ntị. 
\q2 Ugbu a bụ oge ihe ịgba gharịị nye ha. 
\q1  
\v 5 Ekwenyerela onye agbataobi gị, 
\q2 atụkwasịla onye bụ ezi enyi gị obi. 
\q1 Kpachara anya gị, nʼihe gbasara okwu ọnụ gị, 
\q2 ọbụla dị nʼebe nwunye gị nọ. 
\q1  
\v 6 Nʼihi na nwa na-elelị nna ya anya. 
\q2 Nwa nwanyị na-ebili megide nne ya. 
\q1 Nwunye nwa megidekwa nne di ya, 
\q2 ndị iro mmadụ bụ ndị ezinaụlọ ya. 
\b  
\q1  
\v 7 Ma mụ onwe m, ana m ele \nd Onyenwe anyị\nd* anya nʼihi inyeaka ya. 
\q2 Eji m olileanya na-echere Chineke Onye nzọpụta m. 
\q2 Chineke m ga-anụ olu m. 
\s1 Izrel ga-ebili 
\q1  
\v 8 Achịkwala m ọchị gị onye iro m. 
\q2 Mgbe m dara, aga m ebilitekwa. 
\q1 Mgbe m nọ nʼime ọchịchịrị, 
\q2 \nd Onyenwe anyị\nd* nʼonwe ya ga-abụ ihe m. 
\q1  
\v 9 Nʼihi na m emehiela megide ya, 
\q2 aga m anabatara onwe m ahụhụ nke ọnụma \nd Onyenwe anyị\nd*, 
\q1 tutu ruo mgbe ọ ga-ekpe ikpe m, 
\q2 mee ka m guzosie ike. 
\q1 Ọ ga-akpọpụta m nʼìhè; 
\q2 aga m elekwasịkwa ezi omume ya anya. 
\q1  
\v 10 Mgbe ahụ, ndị iro m ga-ahụ, 
\q2 ihere ga-ekpuchi 
\q1 onye ahụ sịrị m, 
\q2 “Olee ebe \nd Onyenwe anyị\nd* Chineke gị ahụ nọ.” 
\q1 Aga m eji anya m hụ mgbe ọ ga-ada, 
\q2 ọ bụladị dịka e si na-azọ ya ụkwụ, 
\q2 dịka apịtị dị nʼokporoụzọ. 
\b  
\q1  
\v 11 Ụbọchị a ga-ewugharị mgbidi gị niile na-abịa; 
\q2 ụbọchị a ga-eme ka oke ala gị saa mbara. 
\q1  
\v 12 Nʼụbọchị ahụ, ha ga-abịakwute gị, 
\q2 site na Asịrịa ruo na obodo niile nke Ijipt, 
\q1 sitekwa nʼIjipt ruo Yufretis, 
\q2 site nʼosimiri ruo osimiri, 
\q2 sitekwa nʼugwu ruo nʼugwu. 
\q1  
\v 13 Ma ụwa ga-aghọ ebe tọgbọrọ nʼefu nʼihi ndị bi nʼime ya, 
\q2 iji kwụọ ha ụgwọ ihe ọjọọ niile ha mere. 
\s1 Ekpere na otuto 
\q1  
\v 14 Were mkpanaka gị zụọ ndị gị, 
\q2 bụ igwe ewu na atụrụ nke ihe nketa gị, 
\q1 ndị bi naanị ha nʼoke ọhịa, 
\q2 nʼebe ịta nri nke ahịhịa ndụ jupụtara. 
\q1 Kwere ka ha taa ahịhịa ndụ nke Bashan, na nke Gilead, 
\q2 dịka na mgbe ochie. 
\b  
\q1  
\v 15 “Dịka nʼụbọchị ahụ unu sitere nʼIjipt pụta, 
\q2 aga m egosi ha ọrụ ịtụnanya m niile.” 
\b  
\q1  
\v 16 Mba dị iche iche ga-ahụ ya, ihere ga-emekwa ha, 
\q2 nʼime ịdị ike ha niile. 
\q1 Ha ga-ekpuchi aka nʼọnụ ha, 
\q2 ntị ga-echikwa ha. 
\q1  
\v 17 Ha ga-aracha aja dịka agwọ, 
\q2 na dịka anụ dị iche iche, nke na-akpụ akpụ nʼala. 
\q1 Ha ga-eji ịma jijiji si nʼebe ha e wusiri ike pụta. 
\q2 Nʼihi egwu ha, ha ga-abịakwute \nd Onyenwe anyị\nd* bụ Chineke anyị. 
\q2 Ha ga-atụkwa egwu gị. 
\q1  
\v 18 Onye bụ chi ahụ dịka gị, 
\q2 nke na-agbaghara ma na-ehichapụ mmehie na njehie 
\q2 nke ndị fọdụrụ afọdụ nʼetiti ihe nketa gị? 
\q1 Ị naghị anọgide na-ewe iwe ruo mgbe ebighị ebi, 
\q2 kama ị bụ onye ọ na-atọ ụtọ inwe obi ebere. 
\q1  
\v 19 Ọ ga-emekwara anyị ebere ọzọ. 
\q2 Ọ ga-azọdakwa mmehie anyị nʼokpuru ukwu ya, 
\q2 Ị ga-atụbakwa mmehie anyị niile nʼebe dịkarịsịrị omimi nke oke osimiri. 
\q1  
\v 20 Ị ga-egosi Jekọb ntụkwasị obi, 
\q2 gosikwa Ebraham ịhụnanya gị, 
\q1 dịka ị ṅụọrọ nna nna anyị ha nʼiyi, 
\q2 site na mgbe ochie.