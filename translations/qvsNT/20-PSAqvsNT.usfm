\id PSA Quechua San Martín
\h SALMO
\toc1 SALMOS
\toc2 SALMO
\toc3 Sal
\mt1 SALMOS
\c 1
\s1 Tata Diosta kasushpanchikuna kushikushpa kawsanchisapa.
\q1 
\v 1 Ñukanchikuna mana sakra runakuna willawananchikunata kasushpanchikuna
\q1 kushikushpa kawsanchisapa.
\q1 Mana uchallikuk runakunashina kawsashpa
\q1 mana uchata rurashpa kawsashpanchikuna
\q1 kushikushpa kawsanchisapa.
\q1 Mana Tata Diosta asichik runakunapa yuyanankunata rurashpanchikuna
\q1 kushikushpa kawsanchisapa.
\q1 
\v 2 Tata Diospa rimananta kuyashpanchikuna tutapi diyapi chay rimananpi yuyaykushpa
\q1 kushikushpa kawsanchisapa.
\q1 
\v 3 Chashna Tata Diospa rimananta kuyashpanchikuna
\q1 yaku mañanpi tarpudu kaspishina allimata wiñanchisapa.
\q1 Wayuchakunan tiempu aypata wayuchakuk kaspishina kanchisapa.
\q1 Aypa allima pankayuk kaspishina kanchisapa.
\q1 Chayrayku tukuy ima rurananchikunata allita ruranchisapa.
\q1 
\v 4 Chay mana alli rurak runakuna mana chashnachu kawsansapa.
\q1 Paykunaka wayra pushanan kutadu murupa karapanshina kunanlla anchunsapa.
\q1 
\v 5 Chayrayku chay mana alli rurak runakuna
\q1 Tata Diospa kastigunmanta mana kishpinkasapachu.
\q1 Paykunaka Tata Diosta kasushpa kawsak runakunawan
\q1 mana tantanakunkasapachu.
\q1 
\v 6 Tata Dios alli rurak runakunata kuydansapa
\q1 alli ñanta purikshina allita rurashpa kawsanankunapa.
\q1 Tukuy uchallikushpa kawsak runakunata
\q1 Tata Dios sukaman kastigankasapa.
\c 2
\s1 Tata Dios akllashkan wambran kamachikun.
\q1 
\v 1 Sukaman yuyani: ¿Imapatí Tata Diosta mana kasuk runakuna turbakunsapa?
\q1 ¿Imapatí mana valekkunata yuyaykunsapa rurayta?
\q1 
\v 2 Tukuy allpapi sinchi kamachikukkuna awtoridarkuna
\q1 Tata Diosta mana kasunayansapachu.
\q1 Chashna mana kasunayashpankuna
\q1 Tata Dios akllashkan sinchi kamachikukwan makanakuk tantanakunsapa.
\q1 
\v 3 Tantanakushpa kaparishpa rimansapa:
\q1 “Akuychi Tata Dios akllashkan kamachikuk runawan makanakuk.
\q1 Akuychi paymanta kishpichinakuk amana kamachiwananchikunapana.”
\b
\q1 
\v 4 Chashna rimaptinkuna
\q1 sielupi kawsak Tata Dios
\q1 paykunata asichinsapa.
\q1 
\v 5 Chaymanta Tata Dios rabyakushpa manchachinsapa.
\q1 Sinchita piñakushpa willansapa:
\q1 
\v 6 “Ñukami akllashkayni Sion urkupi sinchi kamachikukta churashkani tukuy layata kamachinanpa.”
\b
\q1 
\v 7 Kunanka ñuka willaykichi Tata Dios munananta.
\q1 Payka willawashka:
\q1 “Kanka wambraynimi kanki.
\q1 Kantami churashkayki sinchi kamachikuk kanaykipa.
\q1 
\v 8 Chayrayku tukuy llaktakunata mañaway.
\q1 Ñukami allpa kuchun mañanta kushkayki chaypi kamachikunaykipa.
\q1 
\v 9 Sinchi kamachikuk kashpayki suk runakuna mana kasushunayaptinkuna kastigankisapa.
\q1 Yerumanta ruradu varawan
\q1 metomanta ruradu ollata pakikshina paykunata kastigankisapa.”
\b
\q1 
\v 10 Chashna Tata Dios wambranta willaptin
\q1 Kankuna sinchi kamachikukkuna, awtoridarkuna,
\q1 willanaynita allita entiendiychi.
\q1 Yachachinaynita yachakuychi.
\q1 
\v 11 Tata Diosta manchashpa sirviychi.
\q1 Kushikushpa payta kuyaychi.
\q1 
\v 12 Tata Dios kunanllami sinchita rabyakun.
\q1 Chayrayku chukchukushpa ñawpakninpi kumurayaychi
\q1 ama Tata Dios rabyashpa mana allita rurashkaykichirayku wañuchishunaykichipa.
\b
\q1 Tata Dios amachawananchikunata yachashpanchikuna
\q1 kushikushpa kawsanchisapa.
\c 3
\s1 Tata Dioska kuyak runakunata yanapansapa.
\q1 
\v 1 A, Tata Dios,
\q1 aypa chikniwak runakunami tiyan.
\q1 
\v 2 Chikniwashpa ñukawan makanakunayansapa.
\q1 Chay runakuna ñukapa rimansapa:
\q1 “Tata Dios manami yanapankachu.”
\q1 
\v 3 Chashna rimaptinkunapish,
\q1 Tata Dios, kanmi arkanashina arkawanki.
\q1 Kanmi kuyawashpa yanapawashpa animuchiwanki.
\b
\q1 
\v 4 Ñuka Tata Diosta sinchita roygaptini
\q1 payka sielupi kawsananmanta yanapawan.
\q1 
\v 5 Sirishpayni kunanlla puñuni.
\q1 Puñushkaynimanta kashkan rikchamuni
\q1 Tata Dios yanapawaptin.
\q1 
\v 6 Aypa chikniwak runakuna tukuy maypi wañuchiwanayaptinkunapish
\q1 Tata Dios yanapawaptin mana manchakunichu.
\b
\q1 
\v 7 A, Tata Dios,
\q1 yanapawashpayki favorninipi atarimuy.
\q1 Chikniwak runakunamanta salvaway.
\q1 Kanmi chikniwak runakunata makashkankisapa.
\q1 Tukuy mana alli rurak runakunapa armankunata wakllichishkanki.
\q1 
\v 8 Kanmi, Tata Dios, ñukaykunata salvawankisapa.
\q1 Chayrayku kanta kuyaptinikuna yanapawaysapa.
\c 4
\s1 Tata Diosta kreyiptinchikuna allita yanapawanchisapa.
\q1 
\v 1 A, Tata Dios,
\q1 kanmi allita amachawanki.
\q1 Chayrayku kanta roygaptini yanapaway.
\q1 Sukaman llakiptini kanmi kushichiwanki.
\q1 Chayrayku roygaptini llakichiwashpa uyariway.
\b
\q1 
\v 2 Kankuna, chikniwak runakuna,
\q1 ¿aykapikamantí llullakushpa chatawankichi?
\q1 ¿Aykapikamantí mana kuskata yuyashpa llullakuyllata munankichi?
\q1 
\v 3 Allita yachaychi
\q1 Tata Dios payllata kasushpa kawsak runakunallata yanapananta.
\q1 Allita yuyaychi ñuka Tata Diosta roygaptini yanapawananta.
\q1 
\v 4 Chayta yachashpa manchakushpa chukchukuychi
\q1 amana ashwanta uchallikunaykichipa.
\q1 Sirishpaykichi kasillayashpa mana alli rurashkaykichita yuyaychi.
\q1 
\v 5 Chayta yuyashpa
\q1 tukuy shunku Tata Diosta kuyashpa
\q1 animalkunata altarpi wañuchiychi.
\q1 Allita yachaychi amachashunaykichita.
\b
\q1 
\v 6 Aypa runakuna rimansapa:
\q1 Manami ni pi ñukanchikunata kushichiwanayanchisapachu.
\q1 Chashna rimaptinkunapish
\q1 kan, Tata Dios, ñukaykunata llakichiwaysapa.
\q1 
\v 7 Aypa mikunayuk aypa upyanayuk runakuna sukaman kushikunsapa.
\q1 Kan, Tata Dios, paykunamanta ashwanta kushichiwashkanki.
\q1 
\v 8 Kan kuydawaptiki mana manchakushpa sirishpayni kunanlla gustu puñuni.
\c 5
\s1 Roygaypachi Tata Dios yanapawananchikunapa.
\q1 
\v 1-2 Kamachiwak Tatayni Dios,
\q1 parlachiptini uyariway.
\q1 Llakishpa roygaptini yanapaway.
\q1 A, Tata Dios,
\q1 kantami tukuy ima yuyanaynita parlachiyki.
\q1 
\v 3 A, Tata Dios,
\q1 unay unay parlachiptini uyariwanki.
\q1 Pakarinanta ima munanaynita willayki.
\q1 Chaymanta yanapawanaykipa shuyani.
\q1 
\v 4 A, Tata Dios,
\q1 runakuna mana allita ruraptinkuna
\q1 sukaman piñakunki.
\q1 Chayrayku mana alli rurak runakuna
\q1 mana ñawpaknikipi kawsankasapachu.
\q1 
\v 5 Kikinkunalla kreyinakuk runakuna mana ñawpaknikipi kawsankasapachu.
\q1 Mana alli rurak runakunata
\q1 sukaman chikninkisapa.
\q1 
\v 6 Llullakuk runakunata kulluchinkisapa.
\q1 Allipi tukushpa chiknikuk runakunata
\q1 wañuchikunayak runakunata chikninkisapa.
\q1 
\v 7 A, Tata Dios,
\q1 kuyawashpa llakichiwaptiki ñuka atipani wasikipi yaykushpa
\q1 tukuy shunku kuyaynikita.
\q1 Akllashkayki wasikita yuyashpayni kuyayki.
\b
\q1 
\v 8 A, Tata Dios,
\q1 alli rurak kashpayki
\q1 yachachiway allita rurashpa kawsanaynipa
\q1 ama chikniwak runakuna chatawanankunapa.
\q1 Yanapaway allita rurashpa
\q1 alli ñanta purikshina kawsanaynipa.
\q1 
\v 9 Chay chikniwak runakuna
\q1 tukuy tiempu llullata rimansapa.
\q1 Tukuy shunku mana allita yuyashpalla kawsansapa.
\q1 Chashna sukaman uchasapa kashpankuna
\q1 kicharidu asnak sepulturashinami.
\b
\q1 
\v 10 A, Tata Dios,
\q1 chay runakunata kastigaysapa
\q1 tukuy mana alli yuyanankuna nimapi tukunankunapa.
\q1 Uchasapa kashpankuna
\q1 mana kasushunayashkankunarayku
\q1 ñawpaknikimanta paykunata karkuysapa.
\q1 
\v 11 Ñukaykuna amachawanaykipasapa munashpaynikuna kushikunisapa.
\q1 Kushikushpa kantanisapa
\q1 kan, Tata Dios, amachawaptikisapa.
\q1 Kanta kuyashpaynikuna kushikunisapa
\q1 kan yanapawaptikisapa.
\q1 
\v 12 Allita rurashpa kawsaptinikuna
\q1 kan, Tata Dios, yanapawankisapa.
\q1 Yanapawashpaykisapa suk arkanashina amachawankisapa.
\c 6
\s1 Llakishpanchikuna Tata Dioswan parlanchisapa.
\q1 
\v 1 A, Tata Dios,
\q1 ama rabyakushpa piñayawaychu.
\q1 Ama rabyakushpa kastigawaychu.
\q1 
\v 2 A, Tata Dios,
\q1 mana fersasyukmi mallinakuni.
\q1 Chayrayku llakichiway.
\q1 Tukuy kuerpuynimi chukchukun.
\q1 Chayrayku alliyachiway.
\q1 
\v 3 Manchakushpayni chukchukuni.
\q1 A, Tata Dios,
\q1 sukaman munani yanapawanaykipa.
\q1 
\v 4 A, Tata Dios,
\q1 shamuy yanapawak.
\q1 Kuyawashpayki wañuymanta salvaway.
\q1 
\v 5 Wañushpayni manana kay allpapi yuyashkaykinachu.
\q1 Pampadu kashpayni manana atipashanachu alabaynikita.
\q1 
\v 6 Chayta yuyashpa sukaman wakakushpa shaykuni.
\q1 Tukuy tuta sukaman wakakuptini
\q1 almadayni ñawini illiwan ñuyun.
\q1 
\v 7 Chikniwak runakuna sufrichiwaptinkuna
\q1 wakakuptini ñawini shaykushpa puyuyashka.
\b
\q1 
\v 8 Kankuna, mana alli rurak runakuna,
\q1 ñukamanta anchuychi.
\q1 Sukaman llakiptini ñami Tata Dios uyariwashkana.
\q1 
\v 9 Oraptini Tata Dios uyariwashkana.
\q1 Tukuy mañashkaynita
\q1 ñami Tata Dios almitiwashkana.
\q1 
\v 10 Chayrayku chikniwak runakuna
\q1 pinkakushpa turbakunkasapa.
\q1 Tata Dios yanapawaptin
\q1 pinkakuywan raslla kallpankasapa.
\c 7
\s1 Tata Dios kuskanpi kastigakun.
\q1 
\v 1-2 A, Señor Tatayni Dios,
\q1 kantami maskayki amachawanaykipa.
\q1 Sufrichiwak runakunamanta salvaway.
\q1 Paykunamanta kishpichichiway.
\q1 Mana amachawaptikika llullakushpa chatawashpa
\q1 pumashina wakllichiwanmansapa.
\q1 
\v 3 A, Tata Dios,
\q1 ¿ima mana allita rurashpatí uchallikushkani?
\q1 
\v 4 Purikmasini allita rurawaptin manami chiknishkanichu.
\q1 Chikniwak runata mana nimanachiwaykaptin
\q1 manami payta sufrichishkanichu.
\q1 
\v 5 Payta sufrichishka kaptinika ñukatapish sufrichiwachun.
\q1 Payta chiknishka kaptinika ñukatapish mana nimatashina kawawachun.
\q1 
\v 6 A, Tata Dios,
\q1 piñakushpa atariy.
\q1 Favorninipi chikniwak runakunata tinkuysapa.
\q1 Kanmi rimashkanki mana alli rurak runakunata kastiganaykipa.
\q1 Chayrayku favorninipi llukshiy.
\q1 
\v 7 Tukuy llaktakunata tantanachishpayki
\q1 paykunata kamachiysapa.
\q1 
\v 8 A, Tata Dios,
\q1 kanmi tukuy llaktakunapi kawsak runakunata
\q1 willanki allitachu mana allitachu rurashkasapa nishpa.
\q1 Chayrayku allita rurashpa kawsashkaynirayku
\q1 willaway allita rurashkaynita.
\q1 
\v 9 A, Tata Dios,
\q1 kanmi allillata rurak kanki.
\q1 Tukuy runakunapa yuyayninta riksinki.
\q1 Chayrayku tukuy mana alli rurak runakunata kulluchiy.
\q1 Ñukaykuna alli rurak runakuna kaptinikuna
\q1 sinchichiwashpa yanapawaysapa
\q1 ama uchallikunaynikunapa.
\b
\q1 
\v 10 Altu sielupi kawsak Tata Dios
\q1 tukuy alli shunkuyuk runakunata amachan.
\q1 Chayrayku ñukata amachawan.
\q1 
\v 11 Tata Dios kuskanpi kastigakun.
\q1 Tukuy tiempu tukuy mana alli rurak runakunata kastigansapa.
\b
\q1 
\v 17 Tata Dios alli rurak kaptin
\q1 payta alabasha.
\q1 Altu sielupi kamachikuk Tata Diosta yuyashpa
\q1 payta kuyashpa himnokunata kantasha.
\c 8
\s1 Tata Dios runakunata rurarkan kamachikunankunapa.
\q1 
\v 1 A, Tata Dios,
\q1 ashwan sinchi kamachiwakninikunami kanki.
\q1 Kanmi tukuy allpapi kamachikunki.
\q1 Sieluta kawashpaynikuna yachanisapa
\q1 sukaman tukuy laya atipak kanaykita.
\q1 
\v 2 Taksha wambrakuna ñuñukuk wambrakuna alabashuptinkuna
\q1 riksichinakunki tukuy laya atipak kanaykita.
\q1 Chaymanta chiknishuk runakunata
\q1 mana kasushunayak runakunata upallayachinki.
\b
\q1 
\v 3 Rurashkayki sieluta kawashpayni
\q1 chaypi churashkayki killata luserukunata kawashpayni
\q1 
\v 4 yuyani rurashkayki runakuna mana nima kanankunata.
\q1 Chashna mana nima kaptinikuna
\q1 ¿imapatí yuyawashpa llakichiwankisapa?
\q1 
\v 5 Ñukaykunata rurawashkankisapa yaka angelkunashina yachakta.
\q1 Angelkunamanta ashwanta kuyawankisapa kushichiwankisapa.
\q1 
\v 6 Alli yachakta rurawashpaykisapa
\q1 willawashkankisapa rurashkaykikunata kamachinaynikunapa.
\q1 
\v 7 Ovejakunata torokunata sachapi mana wiwa animalkunata
\q1 kuwashkankisapa ñukaykunapa kanankunapa.
\q1 
\v 8 Sielupi pawak animalkunata
\q1 yakupi kawsak challwakunata
\q1 tukuy ima yakupi tiyakta
\q1 churashkankisapa kamachinaynikunapa.
\q1 
\v 9 A, Tata Dios,
\q1 ashwan sinchi kamachikukninikunami kanki.
\q1 Tukuy allpapi kamachikunki.
\c 10
\s1 Roygaptinchikuna Tata Dios yanapawanchisapa.
\q1 
\v 1 A, Tata Dios,
\q1 mallinakuni karuyawashkaykita.
\q1 Llakiptini mallinakuni mana yanapawanaykita.
\q1 
\v 2 Mana alli rurak runakuna sukaman kikinkunalla kreyinakushpankuna
\q1 rabyakushpa alli rurak runakunata sufrichinsapa.
\q1 Chashna kreyinakushpankunapish
\q1 kikinkuna churashkankuna trampallapi urmankasapa.
\q1 
\v 3 Mana alli rurak runakuna
\q1 kikinkunapa munanankunallata rurashpa kawsansapa.
\q1 Tukuy layata kikinkunallapa munashpa
\q1 Tata Diosta maldisishpa washanchansapa.
\q1 
\v 4 Chashna washanchashpa kikinkunalla kreyinakushpa rimansapa:
\q1 “Manami Tata Dios tiyanchu.
\q1 Manami ni pi ruranaynikunata tapuwankasapachu.”
\q1 
\v 5 A, Tata Dios,
\q1 chay runakuna sukaman mana allita rurashpa
\q1 chashnalla tukuy tiempu kawsansapa.
\q1 Kanpa, Tata Dios, kamachikunaykita
\q1 mana nimatashina kawansapa.
\q1 Chikninakukmasinkunata
\q1 mana kreyishpankuna rabyachinsapa.
\q1 
\v 6 Yuyansapa mana ni pi atipananta
\q1 chashna kawsanankunamanta michayta.
\q1 Rimansapa mana nimapi sufrinankunata.
\q1 
\v 7 Chaykunata rimashpa sukaman maldisikunsapa
\q1 llullakunsapa llullachikunsapa.
\q1 Runamasinkunata rabyachishpa sufrichinsapa.
\q1 
\v 8 Llaktankuna washapi mana nimanachik runata chapashpa
\q1 pakallalla wañuchinsapa.
\q1 Mana amachanakuy atipak runakunata kawashpa
\q1 shuyansapa wañuchinankunapa.
\q1 
\v 9 Chay mana alli rurak runakuna
\q1 pumakunashina machayninpi pakakudunkunamanta
\q1 mana amachanakuy atipak runakunata chapansapa.
\q1 Chapashpa shuyansapa imay orami apinkasapa nishpa.
\q1 Chashna apishpa munashkankuna layata paykunata ruransapa.
\q1 
\v 10 Pumakunashina pakchanakushpa takshayansapa
\q1 mana amachanakuy atipak runakunata apinankunapa.
\b
\q1 
\v 11 A, Tata Dios,
\q1 chay runakuna yuyansapa
\q1 kan mana alli ruranankunata kunkanaykita.
\q1 Yuyansapa uyaykita wichkashpa mana kawanaykita.
\q1 
\v 12 A, Tata Dios, atarimuy. Yanapawaysapa.
\q1 Ama sufrik runakunata kunkaychu.
\q1 
\v 13 A, Tatayni Dios
\q1 ¿imapatí mana alli rurak runakuna
\q1 burlata rurashunkisapa?
\q1 Paykunaka yuyansapa kan mana kastigakunaykita.
\q1 
\v 14 A, Tata Dios,
\q1 kikiki kawashkanki
\q1 sakra mana allikunata ruraptinkuna.
\q1 Chayrayku paykunata kastiganayki tiyan.
\q1 Chashna kastigakuk kaptiki
\q1 mana amachanakuy atipak runakuna
\q1 kanta maskashunkisapa amachakunaykipa.
\q1 Kanmi tukuy wakcha runakunata yanapankisapa.
\q1 
\v 15 A, Tata Dios,
\q1 chay mana alli rurak runakunata kastigaysapa
\q1 amana sufrichikushpa kawsanankunapa.
\q1 Tukuy paykunata kastigaysapa kullunankunakaman.
\q1 
\v 16 Kanmi, Tata Dios, mana tukuyniyukta kamachikunki.
\q1 Mana kreyishuk runakunata llaktankunamanta wishchunkisapa.
\q1 
\v 17 A, Tata Dios,
\q1 mana kikinlla kreyinakushpa kuyashuk runakuna
\q1 roygashuptinkuna uyarinkisapa.
\q1 Paykunata animuchishpa yanapankisapa.
\q1 
\v 18 A, Tata Dios,
\q1 tukuy wakchakunata sufrik runakunata yanapaysapa
\q1 wañuy yachak runakuna
\q1 amana runamasinkunata sufrichinankunapa.
\c 11
\s1 Tata Dios tukuy alli rurak runakunata amachansapa.
\q1 
\v 1 Ñukaka Tata Diostami shuyani amachawananpa.
\q1 Yankamantami chikniwak runakuna willawansapa:
\q1 “Pawak animalkuna urkukunaman manchakushpa nitikukshina nitikuy.”
\q1 
\v 2 Paykunaka willawansapa:
\q1 “Mana alli rurak runakunata kawaychi.
\q1 Paykunaka wachinkunata balista waskapi churashpa
\q1 balistankunata pataransapa.
\q1 Pakakudunkunamanta alli rurak runakunata shitansapa.”
\q1 
\v 3 Willawansapa: “Mana awtoridarkuna tiyaptin
\q1 ¿imatatí alli rurak runakuna rurankasapa?”
\b
\q1 
\v 4 Chashna willawaptinkunapish ñuka yachani
\q1 Tata Dios wasinpi kawsananta.
\q1 Sielupi tiyananmanta tukuy runakunata allita kawaykan.
\q1 
\v 5 Tata Dios alli mana alli rurak runakunata kawan.
\q1 Wañuchikunayashpalla kawsak runakunata
\q1 Tata Dios tukuy shunkunmanta sukaman chikninsapa.
\q1 
\v 6 Tata Dios mana alli rurak runakunapa sawanpi
\q1 asufriwan rawraykak ninata tamyachinka.
\q1 Wayrawan chay ninata rawrachinka
\q1 chay sakra runakunata rupachinankunapa.
\q1 Chashna rupachishpa kastigankasapa.
\q1 
\v 7 Tata Dios alli rurakmi.
\q1 Ñukanchikuna allita rurashpa kawsaptinchikuna kuyawanchisapa.
\q1 Tata Diosta tukuy shunku kuyashpanchikuna
\q1 payta uya uya kawashunchisapa.
\c 19
\s1 Sieluta kawashpa yachanchisapa Tata Dios tukuy laya atipak kananta.
\q1 
\v 1 Kawananchi sielu yachachiwanchisapa
\q1 Tata Dios tukuy laya atipak kananta.
\q1 Sieluta kawashpanchikuna yachanchisapa
\q1 Tata Dios tukuy layata rurashkanta.
\q1 
\v 2 Diyan diyan sieluka yachachiwanchisapa
\q1 Tata Dioslla tukuy layata rurashkanta.
\q1 Tutapipish sieluka yachachiwanchisapa
\q1 Tata Dios alli yachak kananta.
\q1 
\v 3 Sielu mana rimakuptin uyarishpanchikunapish
\q1 allita yachanchisapa
\q1 Tata Dios tukuy layata rurashkanta.
\q1 
\v 4 Tukuy allpa kuchun mañanpi kawsak runakuna
\q1 sieluta kawashpa yachanchisapa
\q1 Tata Dios tukuy layata rurashkanta.
\q1 Payka intita sielupi wasinpishina churashka.
\q1 
\v 5 Intika suk novioshina
\q1 kasaranan diya kushikushpa
\q1 wasinmanta kallpan.
\q1 Premyunta chaskinanpa kallpak runashina
\q1 kushikushpa llukshin.
\q1 
\v 6 Intika llukshimunan ladumanta
\q1 yaykunan ladukaman purin.
\q1 Mana ni pi rupayninmanta kishpinchu.
\b
\q1 
\v 7 Tata Diospa kamachikunankuna sukaman allimami.
\q1 Sampayaptinchi animuchiwanchi.
\q1 Paypa rimananka mana llullachiwanchisapachu.
\q1 Mana yachaptinchikuna
\q1 yachachiwanchisapa alli yachak kananchikunapa.
\q1 
\v 8 Tata Diospa rimanan allima kashpa
\q1 kushichiwanchisapa.
\q1 Paypa kamachikunankuna sukaman allima kashpa
\q1 lampara llipyakshina lusichiwanchi
\q1 yachananchikunapa allita rurashpa kawsayta.
\q1 
\v 9 Tata Diosta kuyashpanchikuna
\q1 mana tukuyniyukta
\q1 allita rurashpa kawsanchisapa.
\q1 Tata Dios kuskanpi mana llullakushpa kamachiwanchisapa.
\q1 
\v 10 Paypa rimananka
\q1 kurimanta ashwan allimami.
\q1 Amu mishkinta munananchikunamanta
\q1 Tata Diospa rimananta ashwanta munanchisapa.
\q1 
\v 11 A, Tata Dios,
\q1 kamachikunaykikuna yachachiwan
\q1 ama uchallikushpa kawsanaynipa.
\q1 Chaykunata kasuptini sukaman yanapawanki.
\q1 
\v 12 Mana ni pi kikinmanta yachanchu uchallikushkanta.
\q1 A, Tata Dios,
\q1 mana yuyashpa uchallikuptini
\q1 perdonaway.
\q1 
\v 13 Yanapaway ama kikinilla kreyinakunaynipa.
\q1 Ama munaychu kreyinakushpa kawsanaynipa.
\q1 Yanapawaptiki mana uchayuk runa kasha
\q1 amana uchallikunaynipa.
\q1 
\v 14 A, Tata Dios,
\q1 kanmi amachawashpa uchaynimanta salvawanki.
\q1 Chayrayku munani
\q1 tukuy rimanayni tukuy yuyanayni kushichishunaykipa.
\c 23
\s1 Tata Dios ovejakuna kuydakshina kuydawanchisapa.
\q1 
\v 1 Tata Dios ovejakuna kuydakshina kuydawan.
\q1 Chayrayku mana nima illawanchu.
\q1 
\v 2 Chashna kuydawashpa
\q1 allima pastukunapi samachiwan.
\q1 Chuya likidu ñukñuk yakukunaman pushawan.
\q1 
\v 3 Chashna kuydawashpa animuchiwan.
\q1 Kuska ñankunata pushawan riksinaynipa alli kuydakuk kananta.
\q1 
\v 4 Kan, Tata Dios, kuydawaptiki
\q1 tuta likidu urku sikinkunata puriptinipish
\q1 mana wañuyta manchakunichu.
\q1 Kan, Tata Dios, ñukawan kaptiki
\q1 varaykiwan bastonnikiwan kuydawaptiki
\q1 kushikushpalla kawsasha.
\q1 
\v 5 Chikniwak runakuna tiyaptinpish
\q1 aypa allima mikunata rurapashkanki.
\q1 Kuyawashpa mishkilla asnak wirata
\q1 umaynipi tallishkanki sukaman kushichiwanaykipa.
\q1 Chaymanta upyakunayni kopata untachikshina sukaman yanapawanki.
\q1 
\v 6 A, Tata Dios,
\q1 wañunayni diyakaman sukaman kuyawashpa llakichiwanki.
\q1 Chayrayku wasikipi mana tukuyniyukta kawsasha.
\c 27
\s1 Tata Dios yanapawaptinchikuna mana nimata manchanchisapachu.
\q1 
\v 1 Tata Dios lusninishina kashpa
\q1 chikniwak runakunamanta salvawan.
\q1 Chashna salvawaptin mana ni pita manchanichu.
\q1 Tata Dios amachawaptin
\q1 mana ni pita manchashachu.
\q1 
\v 2 Chay chikniwak mana alli rurak runakuna tantanakunsapa
\q1 makawashpa wañuchiwanankunapa.
\q1 Chashna wañuchiwayta yuyashpankunapish
\q1 mana atipansapachu.
\q1 
\v 3 Chay aypa chikniwak runakuna wañuchiwanayashpa chawpichawaptinkunapish
\q1 mana paykunata manchanichu.
\q1 Sukaman makawanayaptinkunapish mana turbakunichu.
\b
\q1 
\v 4 Ñuka Tata Diosta suk imallata mañashkani.
\q1 Sukaman munani tukuy diya paypa wasinpi yaykuyta payta kuyanaynipa.
\q1 Chaypi sukaman munani kuyawananta yuyayta.
\q1 
\v 5 Sukaman sufrishpa kawsaptini
\q1 Tata Dios amachawashpa yanapawanka.
\q1 Chikniwak runakunamanta wasinpi pakawanka.
\q1 Manllayba rumi sawanpishina churawanka
\q1 ama ni pi wakllichiwananpa.
\q1 
\v 6 Chashna Tata Dios salvawaptin
\q1 atipani chikniwak runakunata kallpachiyta.
\q1 Chaypina payta agradesishpayni paypa wasinpi
\q1 ofrendakunata kusha kuyanaynipa.
\q1 Kushikushpa himnokunata Tata Diosta kantasha.
\b
\q1 
\v 7 A, Tata Dios,
\q1 kanta roygaptini uyariway.
\q1 Llakichiwashpa yanapaway.
\q1 
\v 8 Kikini yuyanakushpa rimani:
\q1 “Tata Diosta roygasha yanapawananpa.”
\q1 Chayrayku, Tata Dios, roygayki yanapawanaykipa.
\q1 
\v 9 A, Tata Dios, yanapaway.
\q1 Ama piñakushpa karkuwaychu.
\q1 Kanlla atipanki salvawayta.
\q1 Ama sapallaynita sakiwaychu.
\q1 Kanmi kanki salvawak Tatayni Dios.
\q1 
\v 10 Tatayni mamayni sakiwaptinkunapish
\q1 kan, Tata Dios, mana sakiwashpa yanapawanki.
\q1 
\v 11 A, Tata Dios,
\q1 chikniwak runakuna makawanayaptinkuna
\q1 yanapaway allita rurashpa alli ñanpi purikshina kawsanaynipa.
\q1 
\v 12 Chay sakra runakuna llullakushpa chatawansapa
\q1 mana alli rurak kanaynita.
\q1 Chayrayku ama munaychu munashkankunata rurawanankunapa.
\q1 
\v 13 Chashna chatawaptinkunapish
\q1 ñuka allita yachani tukuy diya
\q1 kan, Tata Dios, kuyawashpayki yanapawanaykita.
\b
\q1 
\v 14 Chayrayku akuychi Tata Dios yanapawananchikunata shuyaypachi.
\q1 Valorchinakushpa ama sampayaypachichu.
\q1 Ariya, Tata Dios yanapawananchikunata shuyaypachi.
\c 34
\s1 Tata Diosta roygaptinchikuna payka yanapawanchisapa.
\q1 
\v 1 Tukuy oras ñuka Tata Diosta willasha alli rurak kananta.
\q1 Mana shaykushpa Tata Diosta alabasha.
\q1 
\v 2 Tata Dios yanapawaptin sukaman kushikuni.
\q1 Kankuna, alli modoyuk runakuna,
\q1 chayta yachashpa kushikuychi.
\q1 
\v 3 Tata Dios sukaman tukuy laya atipak kaptin
\q1 akuychi tantalla payllata alabaypachi.
\b
\q1 
\v 4 Tata Diosta yanapawananpa mañaptini
\q1 payka uyariwashka.
\q1 Uyariwashpa yanapawashka
\q1 amana manchakunaynipa.
\q1 
\v 5 Tata Diosta shuyashpanchikuna yanapawananchikunapa
\q1 sukaman kushikunchisapa.
\q1 Tata Dios yanapawaptinchikuna
\q1 mana pinkakunchisapachu.
\b
\q1 
\v 6 Ñuka sukaman sufrishpayni
\q1 Tata Dios yanapawananpa
\q1 roygaptini uyariwashka.
\q1 Yanapawashpa llakidu kashkaynimanta kushichiwashka.
\q1 
\v 7 Tata Diospa angelninkuna
\q1 tukuy Tata Diosta kasuk runakunata amachansapa.
\q1 
\v 8 Kankuna mishkik mikunata mallikshina
\q1 Tata Diosta kuyaychi yachanaykichipa alli rurak kananta.
\q1 Tata Dios yanapashunaykichita yachashpaykichi
\q1 sukaman kushikunkichi.
\q1 
\v 9 Kankuna, Tata Diosta kasuk runakuna,
\q1 payta kuyaychi.
\q1 Chashna kuyaptikichi manami nima illapushunkichichu.
\q1 
\v 10 Pumakuna sinchi kashpankunapish yarkansapa.
\q1 Chashnapish kaptin ñukanchikuna Tata Diosta kasuptinchikuna
\q1 aypa allikunata kuwanchisapa.
\b
\q1 
\v 11 Wambraynikuna, shamuychi uyariwak.
\q1 Kunanka yachachiykichi
\q1 imashnami Tata Diosta kuyankichi nishpa.
\q1 
\v 12 Kunanka tapuykichi:
\q1 ¿Munankichichu unayta kawsayta?
\q1 ¿Munankichichu kushikushpalla kawsayta?
\q1 
\v 13 Chashna kawsanayashpaykichika
\q1 ama munaychichu mana allikunata rimayta nima llullakuyta.
\q1 
\v 14 Mana alli ruranaykichita sakishpa
\q1 allikunallata ruraychi.
\q1 Tukuy piwan allillapi kushikushpa kawsaychi.
\q1 
\v 15 Allita rurashpa kawsaptikichi
\q1 Tata Dios kuydashunkichi.
\q1 Roygaptikichi yanapashunkichi.
\b
\q1 
\v 16 Chaymanta Tata Dios
\q1 tukuy mana alli rurak runakunata chikninsapa.
\q1 Paykunata kulluchinkasapa
\q1 amana ni pi paykunata yuyanankunapa.
\q1 
\v 17 Allita rurashpa kawsaptinchikuna
\q1 Tata Diosta roygaptinchikuna payka yanapawanchisapa.
\q1 Llakishpa sufrishpa kawsaptinchikuna
\q1 payka yanapawashpanchikuna kushichiwanchisapa.
\q1 
\v 18 Tukuy uchanchikunata wananayashpa llakiptinchikuna
\q1 Tata Dios llakichiwashpanchikuna perdonawashpanchikuna kushichiwanchisapa.
\b
\q1 
\v 19 Allita rurashpa kawsashpanchikunapish
\q1 sukaman padesinchisapa.
\q1 Chashna padesiptinchikunapish
\q1 Tata Dios yanapawanchisapa
\q1 kushikushpalla kawsananchikunapa.
\q1 
\v 20 Tata Dios yanapawashpanchikuna
\q1 amachawanchisapa ama chikniwakninchi runakuna
\q1 tullunchikunata polvonankunapa.
\b
\q1 
\v 21 Chaymanta sakra runakuna runamasinkunata wañuchinayashpa
\q1 kikinkunalla wañuyta
\q1 maskaykansapa.
\q1 Tata Dios tukuy alli rurakta chiknik runakunata kastigankasapa.
\q1 
\v 22 Chaymanta Tata Diosta kasushpa kawsaptinchikuna
\q1 payka llakichiwashpanchikuna salvawanchisapa.
\q1 Tata Dios amachawananchikunata munaptinchikuna
\q1 payka mana kastigawanchisapachu.
\c 37
\s1 Runakuna mana allita ruraptinkunapish ama turbakuychu.
\q1 
\v 1 Runakuna mana allita ruraptinkunapish
\q1 ama turbakuychu.
\q1 Chay mana alli rurak runakunata kawashpa
\q1 ama paykunashina kawsanayaychu.
\q1 
\v 2 Chay runakunata Tata Dioska
\q1 utka kastigankasapa.
\q1 Kastigaptinkuna tipidu kiwashina tukunkasapa.
\b
\q1 
\v 3 Tata Dios yanapashunaykita yachashpa
\q1 allita rurashpalla kawsay.
\q1 Kay allpapi kawsashpaykira
\q1 Tata Diosllata allita kasushpa kawsay.
\q1 
\v 4 Payta tukuy shunku kuyashpa kawsay.
\q1 Chashna payta kuyaptiki
\q1 alli munanaykita almitishunki.
\q1 
\v 5 Tata Diosta kuyashpa
\q1 payta willay munananta ruranayanaykita.
\q1 Chashna payta willaptiki yanapashunki.
\q1 
\v 6 Tata Dios yanapashuptiki
\q1 tukuy runakuna alli ruranaykita
\q1 lustashina kawankasapa.
\q1 Alli ruranaykita ruraptiki
\q1 inti llipyanantashina kawankasapa
\q1 paykunapish yachanankunapa
\q1 allita rurashpa kawsayta.
\q1 
\v 7 Allita rurashpa mana turbakushpa
\q1 Tata Dios yanapashunanta shuyay.
\q1 Suk runakuna tukuy imayuk kaptinkuna
\q1 ama llakishpa rabyakuychu.
\q1 Mana allita yuyaykuptinkuna
\q1 ama rabyakuychu.
\b
\q1 
\v 8 Ama rabyakushpa piñakuychu.
\q1 Ama munaychu turbakushpa
\q1 mana allita rurayta.
\q1 
\v 9 Tata Dios tukuy mana allita rurak runakunata kastigankasapa.
\q1 Chaymanta Tata Dios yanapashunanta
\q1 shuyaptiki payka yanapashunki.
\b
\q1 
\v 23 Tata Dios tukuy runakunata yachachiwanchisapa.
\q1 Yanapawanchisapa paypa munananta rurananchikunapa.
\q1 
\v 24 Mana allita ruraptinchikuna
\q1 Tata Dios makinchikunamanta apiwakninchishina yanapawanchisapa
\q1 ama uchallikushpa kawsananchikunapa.
\q1 
\v 25 Wayna kashkaynimanta
\q1 ñami viejuyashkanina.
\q1 Manami kawashkanichu
\q1 Tata Dios alli rurak runakunata sakiptin.
\q1 Paykunapa wambrankunapish
\q1 mana nimata mañakushpachu kawsansapa.
\q1 
\v 26 Alli rurak runakuna kashpanchikuna
\q1 tukuy oras llakichikushpa
\q1 runamasinchikunata yanapanchisapa.
\q1 Chay runakunapa wambrankunaka
\q1 tukuy pita sukaman kushichinsapa.
\q1 
\v 27 Chayrayku mana alli rurashkaykimanta wanashpa
\q1 allikunallata rurashpa kawsay.
\q1 Chashnarami Tata Dios mana tukuyniyukta yanapashunki
\q1 allita rurashpa kawsanaykipa.
\q1 
\v 28 Tata Dios alli rurak runakunata kuyansapa.
\q1 Payta kasushpa kawsaptinchikuna
\q1 mana sakiwanchisapachu.
\q1 Chaymanta mana alli rurak runakunata kulluchin.
\q1 Tukuy wambrankunatapish kulluchin.
\c 46
\s1 Tukuy laya atipak Tata Dios ñukanchikunawan kawsan.
\q1 
\v 1 Tata Dios animuchiwanchisapa.
\q1 Chikniwakninchi runakunamanta amachawanchisapa.
\q1 Llakishpa sufriptinchikuna yanapawanchisapa.
\q1 
\v 2 Chashna Tata Dios amachawaptinchikuna
\q1 allpa chukchukushpa waklliptinpish
\q1 mana manchakushunchisapachu.
\q1 Urkukuna manllayba kochapi sumiptinkunapish
\q1 mana manchakushunchisapachu.
\q1 
\v 3 Yakukuna olasyashpa kaparikuptinpish
\q1 urkukuna chukchukuptinkunapish
\q1 mana manchakushunchisapachu.
\b
\q1 
\v 4 Suk yaku kallpashpa kushichiwanchisapa
\q1 Tata Dios chay yakushina yanapawashpanchikuna kushichiwanchisapa.
\q1 Kamachiwakninchikuna Tata Dios ñukanchikunapi kawsan.
\q1 
\v 5 Chashna Tata Dios ñukanchikunapi kawsashpa
\q1 sufriptinchikunapish tukuy diya yanapawanchisapa.
\q1 
\v 6 Chayta kawashpa mana Tata Diosta kasuk runakuna
\q1 manchakushpa kaparinkasapa.
\q1 Sinchi kamachikukkuna sukwan sukwan makanakushpa kawsansapa.
\q1 Tata Dios rimakuptin
\q1 tukuy llaktakuna wakllichinakunsapa.
\b
\q1 
\v 7 Tukuy laya atipak Tata Dios
\q1 ñukanchikunawanmi kawsan.
\q1 Jakobopa Tata Diosninmi amachawanchisapa.
\q1 
\v 8 Payka almirana milagrukunatami rurashka.
\q1 Shamuychi kawak kay allpapi rurashkanta.
\q1 
\v 9 Kuchun mañan allpapi kamachikushka
\q1 amana makanakunankunapa.
\q1 Ñami balistankunata pakishkana.
\q1 Makanakunankuna lansankunata
\q1 ñami paki pakina rurashka.
\q1 Makanakunankuna karrunkunata
\q1 ñami rupachishkana.
\q1 
\v 10 Chayrayku Tata Dios willawanchisapa:
\q1 “Kasillayaychi.
\q1 Riksiwaychi sinchi kamachikuk Tata Dios kanaynita.
\q1 Yachaychi tukuy allpapi tukuy llaktakunata sinchita kamachinaynita.”
\b
\q1 
\v 11 Tukuy laya atipak Tata Dios
\q1 ñukanchikunawanmi kawsan.
\q1 Jakobopa Tata Diosninmi amachawanchisapa.
\c 51
\s1 Tata Diosta roygaypachi perdonawananchikunapa.
\q1 
\v 1 A, Tata Dios,
\q1 kuyawashpayki llakichiway.
\q1 Llakichiwashpayki uchallikushkaynimanta perdonaway.
\q1 
\v 2 Kuyawashpayki mana alli rurashkaynimanta perdonawashpa mayllaway.
\q1 Tukuy uchaynikunamanta pichaway.
\q1 
\v 3 Allita yachani kanta mana kasunayashpayni uchallikushkaynita.
\q1 Uchallikushkaynita mana atipanichu kunkayta.
\q1 
\v 4 A, Tata Dios,
\q1 uchallikushpayni mana allikunata rurashpayni
\q1 kanta mana kasunayashkaykichu.
\q1 Chashna mana kasunayashpayni rabyachishkayki.
\q1 Uchallikushkaynirayku kastigawanayki tiyan.
\q1 Kan kastigawashpayki
\q1 allininpi kastigawanki.
\q1 
\v 5 Nasishkaynimantapacha
\q1 mana alli rurakmi kani.
\q1 Mamaynipa wiksan ukumantapacha uchasapami kani.
\q1 
\v 6 A, Tata Dios, kanka alli shunkuyuk runata kuyanki.
\q1 Shunkuynipi allita yachachiwashkanki.
\q1 
\v 7 Uchaynikunamanta pichaway
\q1 ñawpaknikipi chuya chuya rikurinaynipa.
\q1 Mana alli rurashkaynimanta mayllaway.
\q1 Chashna mayllawaptiki yurak puyushina kiparisha
\q1 allita rurashpa kawsanaynipa.
\q1 
\v 8 A, Tata Dios, kushichiway.
\q1 Kastigawashkaykimanta kashkan kushichiway.
\q1 
\v 9 Amana uchaynita yuyaynachu.
\q1 Mana alli rurashkaynita kunkay.
\q1 
\v 10 A, Tata Dios,
\q1 uchasapa yuyayninita pichay.
\q1 Yanapaway kanta kuyashpa
\q1 allita rurashpa kawsanaynipa.
\q1 
\v 11 A, Tata Dios,
\q1 ama ñawpaknikimanta karkuwaychu.
\q1 Ama Espirituykita kichuwaychu.
\q1 
\v 12 Perdonawashpa kashkan kushichiway.
\q1 Chashna kushichiwashpayki yanapaway allita rurashpa kawsanaynipa.
\q1 
\v 13 Chashna yanapawaptiki
\q1 mana kasushunayak runakunata rimanaykita yachachisha
\q1 munanaykita rurashpa kawsanankunapa.
\q1 Chashna yachachikuptini
\q1 uchasapa runakuna uchankunata wanashpa kasushushpa kawsankasapa.
\c 53
\s1 Tukuy runakuna uchallikunchisapa.
\q1 
\v 1 Mana alli yuyayuk runakuna
\q1 yuyansapa Tata Dios mana tiyananta.
\q1 Chashna yuyashpa uchallikushpa
\q1 wakllichinakushkasapa.
\q1 Uchallikushpa kawsashpankuna
\q1 manana allikunata rurayta atipansapanachu.
\q1 
\v 2 Anak sielumantapacha
\q1 Tata Dios tukuy runakunata kawamunsapa
\q1 ichará maykan alli yuyayuk
\q1 payta kasunayan nishpa.
\q1 
\v 3 Chashna Tata Dios alli rurak runakunata maskashpapish
\q1 mana niman suk alli rurak runata tarinchu.
\q1 Tukuy runakuna uchallikushpa wakllichinakushkasapa.
\q1 Mana ni pi alli rurak tiyanchu.
\q1 Manami niman suk tiyanchu.
\q1 
\v 4 Chay mana alli rurak runakuna
\q1 mana allikunata yuyaykunsapa.
\q1 Tata Diosta mana kasunayashpankuna
\q1 payta kuyakmasinikunata
\q1 chiknishpa sufrichinsapa.
\q1 
\v 5 Chayrayku mana manchakuna oras kaptinpish
\q1 chay mana alli rurak runakuna
\q1 manchakushpa chukchukunkasapa.
\q1 Tata Dios kastigashpa karkuptinkuna
\q1 sukaman pinkakunkasapa.
\q1 
\v 6 Sukaman munani Tata Dios tukuy israel runakunata kuyawashpanchikuna
\q1 chikniwakninchi runakunamanta salvawananchikunapa.
\q1 Tata Dios llakichiwaptinchikuna
\q1 tukuy Jakobopa mirakninkuna
\q1 israel runakuna kushikushunchisapa.
\c 55
\s1 Tata Diosta roygaypachi chikniwakninchi runakunamanta amachawananchikunapa.
\q1 
\v 1 A, Tatayni Dios,
\q1 roygaptini uyariway.
\q1 Ama nimatashina royganaynita uyariychu.
\q1 
\v 2-3 A, Tata Dios,
\q1 uyariwashpa yanapaway.
\q1 Llakishpayni roygayki.
\q1 Chikniwak runakuna rimakuptinkuna
\q1 mana alli rurak runakuna kaparikuptinkuna
\q1 uyarishpa sukaman manchakuni.
\q1 Paykunaka chikniwashpa sufrichiwansapa.
\q1 Sukaman piñakushpa makawanayansapa.
\q1 
\v 4 Chayta kawashpa manchakuptini
\q1 shunkuyni sinchita waktanakun.
\q1 Wañuchiwanankunata yuyashpa
\q1 sukaman manchakuni.
\q1 
\v 5 Chashna sukaman manchakushpayni chukchukuykani.
\q1 
\v 6 Chayta yuyashpa rimani:
\q1 ¿Imapatí mana urpayshina rikrayuk kani?
\q1 Rikrayuk kashpaynika
\q1 nitikushpa pawayman samak rinaynipa.
\q1 
\v 7 Pawashpayni karuta riyman.
\q1 Chakidu pampapi kipariyman
\q1 chaypi kawsanaynipa.
\q1 
\v 8 Chikniwak runakuna sinchita sufrichiwaptinkuna
\q1 Tata Diosta sukaman mañasha
\q1 sinchi wayramantashina amachawananpa.
\b
\q1 
\v 12 Manami chikniwak runachu sufrichiwashka.
\q1 Chikniwak runa sufrichiwaptinka
\q1 mana nimachu kanman.
\q1 Sufrichiwak runamanta ñukaka pakakuyman.
\q1 
\v 13 Chay sufrichiwak runaka
\q1 kuyanakushpa purikmasinimi kashka.
\q1 
\v 14 Paywanmi Tata Diospa wasinpi yaykushpaynikuna parlak kanisapa.
\q1 Paywanmi kushikushpa aypa runakunapa chawpinkunapi purik kanisapa.
\q1 
\v 15 Tukuy chikniwak runakuna
\q1 mana yuyashkankuna oras wañuchunsapa.
\q1 Mana alli rurak kashpankuna
\q1 raslla wañuchunsapa.
\b
\q1 
\v 16 Ñuka sufrishpayni
\q1 Tata Diostami roygasha.
\q1 Roygaptini yanapawanka.
\q1 
\v 17 Pakarinanta chishita tutata wakaptini
\q1 Tata Dios llakichiwashpa yanapawanka.
\q1 
\v 18 Chikniwak runakunawan makanakuptini
\q1 ama wañuchiwanankunapa
\q1 Tata Dios yanapawanka.
\q1 Paykuna aypa kaptinkunapish yanapawanka.
\q1 
\v 19 Paykuna mana Tata Diosta manchashpa
\q1 mana allikunallata rurashpa kawsansapa.
\q1 Chayrayku mana tukuyniyukta
\q1 sinchi kamachikuk Tata Dios
\q1 chikniwak runakunata kastigashpa upallayachinka.
\q1 
\v 20 Paykunaka kuyanakukmasinkunawan makanakunsapa.
\q1 Allimata kawsanankunapa parlashkankunawasha kunkashpa chikninakunsapa.
\q1 
\v 21 Mishki shimi tukushpa parlansapa.
\q1 Chashna parlashpankunapish
\q1 makanakuyllata yuyansapa.
\q1 Mishki shimi tukushpa parlashpankunapish
\q1 chikninakushpalla kawsansapa.
\b
\q1 
\v 22 Akuychi tukuy yuyananchikunata
\q1 Tata Diosta willaypachi.
\q1 Chashna willaptinchikuna payka yanapawashunchisapa
\q1 allillata rurashpa kawsananchikunapa.
\q1 Tata Diosta kasuptinchikuna
\q1 payka yanapawanchisapa ama uchallikunanchikunapa.
\b
\q1 
\v 23 A, Tata Diosnini,
\q1 wañuchikuk llullakuk runakuna
\q1 mana unaytachu kawsankasapa.
\q1 Paykunata kulluchinkisapa.
\q1 Chashnapish kaptin
\q1 ñukaka yachani yanapawanaykita.
\c 61
\s1 Tata Dios amachawanchisapa.
\q1 
\v 1 A, Tata Dios,
\q1 sukaman llakishpayni kaparikuptini
\q1 uyariway.
\q1 Roygaptini uyariwashpa yanapaway.
\q1 
\v 2 Kay allpapi kuchun mañanpi kashpaynipish
\q1 manana yachashpa imatami rurasha nishpa kanta roygayki.
\q1 Roygaptini manllayba rumi sawanpishina churawashpayki
\q1 chikniwak runakunamanta salvaway.
\q1 
\v 3 A, Tata Dios,
\q1 kanmi amachawanki.
\q1 Amachawashpayki allima pirkashina
\q1 chay chikniwak runakunamanta arkawanki.
\b
\q1 
\v 4 Tukuy tiempu wasikipi kawsanayani
\q1 wallpa wawankunata rikran sikipi amachakshina kuydawanaykipa.
\q1 
\v 5 A, Tata Dios,
\q1 kanmi tukuy promesakushkaynita uyarishkanki.
\q1 Chayrayku yanapawashkanki.
\q1 Kanka tukuy kuyashushpa kawsak runakunata yanapankisapa.
\q1 
\v 6 A, Tata Dios,
\q1 kamachikuk kaptini yanapaway
\q1 sukaman unayta kawsanaynipa.
\q1 
\v 7 Yanapaway allita kamachikunaynipa.
\q1 Kuyawashpayki ama shaykushpa kuydaway.
\q1 
\v 8 Chashna yanapawaptiki
\q1 tukuy tiempu kanllata alabashpayni kawsasha.
\q1 Tukuy diya promesakushkaynita rurasha.
\c 73
\s1 Tata Dios sukaman kuyawanchisapa.
\q1 
\v 1 Tata Dios tukuy israel runakunata kuyashpa yanapansapa.
\q1 Tukuy shunku allita yuyashpa kawsak runakunata yanapansapa.
\q1 
\v 2 Chashna Tata Dios yanapakuk kaptinpish
\q1 yaka yaka mana allita rurashpa mitkakukshina urmanayarkani.
\q1 
\v 3 Kikinkunalla kreyinakuk tukuy imayuk
\q1 mana allita rurashpa kawsak runakunata kawarkani.
\q1 Ñukapish paykunashina kanayashpayni yakallapa uchallikurkani.
\q1 
\v 4 Paykunaka wañuyta mana manchansapachu.
\q1 Mana ni unkushpa shaykunsapachu.
\q1 
\v 5 Mana yachansapachu imami llakina nishpa.
\q1 Mana runamasinkunashinachu
\q1 sufrishpa kawsansapa.
\q1 
\v 6 Sukaman kikinkunalla kreyinakushpankuna
\q1 sufrichikushpalla kawsansapa.
\q1 
\v 7 Tukuy layayuk kashpankuna
\q1 tukuy mana alli munanankunallata ruransapa.
\q1 
\v 8 Tukuy pita mana nimatashina kawansapa.
\q1 Mana pinkakushpa kikinkunalla alabanakunsapa.
\q1 Tukuy pita jorachinsapa
\q1 mana allita ruranankunapa sufrichinankunapa.
\q1 
\v 9 Sukaman mana allita rurashpankuna
\q1 willansapa Tata Diosta mana kasunayanankunata.
\q1 Runakunatapish washanchansapa.
\q1 
\v 10 Chayrayku runamasinkuna
\q1 paykunata alabansapa.
\q1 Paykunata sukaman kreyinsapa.
\q1 
\v 11 Rimansapa: “Tata Dios mana alli rurananchikunata
\q1 mana yachankachu.
\q1 Sielupi kawsak Tata Dios mana nimata yachanchu.”
\q1 
\v 12 Chay mana alli rurak runakuna
\q1 mana nimapi sufrishpankuna kullkiyansapa.
\q1 
\v 13 Chayta kawashpa yuyarkani:
\q1 “Llullakushpa alli shunkuyuk runa kawsaykani.
\q1 Llullakushpa allillata rurashpa kawsaykani.
\q1 
\v 14 Tukuy oras sufrini.
\q1 Tukuy diya Tata Dios kastigawan.”
\b
\q1 
\v 15 A, Tata Dios,
\q1 chay mana alli rurak runakunashina chayta rimashpaynika
\q1 kreyishukmasinikunata llullachiymansapa karkan.
\q1 
\v 16 Chayta yuyashpayni
\q1 mana atiparkanichu entiendiyta imapami Tata Dios mana uchankunarayku kastigansapa nishpa.
\q1 
\v 17 Tata Diospa wasinpi yaykushpaynira
\q1 allita yacharkani Tata Dios chay mana alli rurak runakunata kastiganankunata.
\b
\q1 
\v 18 A, Tata Dios,
\q1 kanmi chay mana alli rurak runakunata
\q1 churashkanki llukchak ñanpishina
\q1 uchallikuptinkuna kulluchinaykipasapa.
\q1 
\v 19 Raslla paykunata kastigankisapa.
\q1 Paykunaka manchakuywan wañunkasapa.
\q1 
\v 20 Paykuna llullachinakuptinkunapish
\q1 kan, Tata Dios, kastigakunayki diya chayamuptin
\q1 tukuy mana alli rurashkankunata
\q1 tukuy runakunata kawachinkisapa.
\b
\q1 
\v 21 Chay mana alli rurak runakunata kawashpa
\q1 sukaman turbakurkani.
\q1 Turbakushpa sukaman llakirkani.
\b
\q1 
\v 22 A, Tata Dios,
\q1 mana nima yachak kashpayni
\q1 ñawpaknikipi suk animalshina karkani.
\q1 
\v 23 Chashna mana entiendiptinipish
\q1 kanka kuyawashpa mana sakiwashkankichu.
\q1 Makinimanta apiwashpa purichiwakshina yanapawashkanki.
\q1 
\v 24 Yachachiwashpa yanapawashkanki
\q1 allita rurashpa kawsanaynipa.
\q1 Chaymanta kawsanaykipi
\q1 kushikushpa chaskiwanki.
\q1 
\v 25 Kanlla sielumanta yanapawanki.
\q1 Kanwan kawsashpayni
\q1 mana nima ashwanta munanichu.
\q1 
\v 26 Sukaman sampayaptinipish, kan tata Dios,
\q1 mana tukuyniyukta kuyawashpa yanapawanki.
\q1 
\v 27 A, Tata Dios,
\q1 mana kasushunayak runakuna wañunkasapa.
\q1 Kanmi mana kreyishuk runakunata kulluchinkisapa.
\q1 
\v 28 Paykuna mana kreyishuptinkunapish
\q1 ñukaka kanwan tantalla kawsanayani.
\q1 Kanmi, Tata Dios, amachawanki.
\q1 Chayrayku runamasinikunata willashasapa
\q1 alli rurak kanaykita.
\c 100
\s1 Tata Dios rurawashkanchikunarayku paypa wambrankuna kanchisapa.
\q1 
\v 1 Tukuy allpapi kawsak runakuna,
\q1 Tata Diosta kushichishpa kantaypachi.
\q1 
\v 2 Kushikushpa Tata Diosta kuyaypachi.
\q1 Kushikuywan kaparikushpa ñawpakninman shamuypachi.
\q1 
\v 3 Tata Diosta riksiypachi sinchi kamachikuk kananta.
\q1 Pay rurawashkanchikunarayku
\q1 paypa wambrankunami kanchisapa.
\q1 Paypa pastunpi ovejankunashina kanchisapa.
\q1 
\v 4 Chayrayku Tata Diospa wasinman shamuypachi.
\q1 Kushikushpa payta alabashpa kantukunata kantashpa
\q1 punkunta yaykuypachi.
\q1 Tata Dios sukaman yanapawaptinchikuna
\q1 kushichishpa kuyaypachi.
\q1 
\v 5 Tata Dios alli rurak kaptin
\q1 mana tukuyniyukta kuyakuk kaptin
\q1 kushikushpa payta kuyaypachi.
\c 104
\s1 Tukuy layata rurak Tata Diosta alabaypachi.
\q1 
\v 1 Tata Diosta tukuy shunku kushichishpa alabasha.
\q1 A, Tatayni Dios,
\q1 ashwan sinchi kamachikukmi kanki.
\q1 Tukuy laya atipak kashpayki
\q1 sukaman allimami kanki.
\q1 
\v 2 Luswan sawa llachapawanshina wankunakushkanki.
\q1 Sieluta warkudu llachapatashina churashkanki.
\q1 
\v 3 Kan tukuy layata kamachishpa
\q1 sielupi wasikipa orkonninkunatashina
\q1 manllayba kochapi sinchichishkanki.
\q1 Puyukunata rurashkanki purinayki karrukunashina kanankunapa.
\q1 Wayrashina maytapish rinayashpa rinki.
\q1 
\v 4 Sinchi wayra yachachiwanchisapa sukaman atipak kanaykita.
\q1 Rawraykak ninakunapish kanllapami.
\q1 
\v 5 A, Tata Dios,
\q1 allpata allimata sinchichirkanki.
\q1 ama churashkaykimanta kuyunanpa.
\q1 
\v 6 Yakukuna suk llachapashina allpata kirparkan.
\q1 Yakukuna tukuy urkukunata kirparkan.
\q1 
\v 7 Kan, Tata Dios, yakukunata willaptiki kallparkansapa.
\q1 Troynoshina rimakuptiki
\q1 yakukuna uyarishpa nitikurkansapa.
\q1 
\v 8 Urkukunata llukashpa bajadakunata urayashpa
\q1 rirkansapa maypicha willashkaykipi kanankunapa.
\q1 
\v 9 Willarkankisapa amana chaymanta llukshinankunapa
\q1 ama kashkan allpata kirpanankunapa.
\b
\q1 
\v 10 Chaymanta yaku pachyamunankunamanta
\q1 urkukunata pasashpa yakuta kallpachishkanki
\q1 atun yakukunaman rinankunapa.
\q1 
\v 11 Chay yakukunamanta tukuy sachakunapi kawsak animalkuna yakukunsapa.
\q1 Chayta upyashpa sachapi kawsak burrukuna yakunayayninta samachinsapa.
\q1 
\v 12 Pawak animalkuna yaku mañankunapi wasichakunsapa.
\q1 Kaspikuna ramanpi kantansapa.
\b
\q1 
\v 13 A, Tata Dios,
\q1 kanmi anak sielupi wasikimantapacha
\q1 yakuta tamyachishpa sachakunata ñuyuchinki.
\q1 Altumanta urmamuk yakuwan allpata saksachinki.
\q1 
\v 14 Chay yakuwan pastukunata wiñachinki
\q1 animalkuna mikunankunapa.
\q1 Runakuna tarpunan murukunata wiñachinki
\q1 wayuchakuptin mikunankunapa.
\q1 
\v 15 Chay wayukunata mikunsapa fersasyuk kanankunapa.
\q1 Vinuta upyansapa kushikunankunapa.
\q1 
\v 16 Kan, Tata Dios, chay yakullawan kaspikunata saksachinki.
\q1 Libano partipi tarpushkayki sedrukunatapish saksachinkisapa.
\q1 
\v 17 Chay kaspikunapi taksha pishkillukuna wasichakunsapa.
\q1 Pino kaspikunapi garsakuna kawsansapa.
\q1 
\v 18 Altu urkukunata kabrakunapa rurashkanki.
\q1 Rumikuna sikinpi achunikuna pakakunsapa.
\b
\q1 
\v 19 Killata rurashkanki yachanaynikunapa
\q1 ima laya tiempumi nishpa.
\q1 Intipish yachan
\q1 imay orasmi urkukunapi chinkanka nishpa.
\q1 
\v 20 Chaymanta yana llachapatashina mantanki tutayananpa.
\q1 Tutayaptin sachapi animalkuna llukshinsapa.
\q1 
\v 21 Pumakuna mana mikunankunata tarishpa kaparinsapa.
\q1 Tata Diosta mañansapa mikunankunata kunankunapa.
\q1 
\v 22 Inti kashkan llukshimuptin
\q1 machayninkunapi sirik kutinsapa.
\q1 
\v 23 Chashna diyayaptin ullkukuna trabajunkunaman rinsapa.
\q1 Tutayanankaman trabajansapa.
\b
\q1 
\v 24 A, Tata Dios,
\q1 rikchak layata rurashkanki.
\q1 Kay allpaka tukuy rurashkaykiwan untami.
\q1 
\v 25 Allpapi tiyan manllayba kocha.
\q1 Chay kochapi mana yupaypa atun animalkuna taksha animalkuna tiyan.
\q1 
\v 26 Chay manllayba kochapi barkukuna purinsapa.
\q1 Yaku ukupi manllayba manchanapa animal kawsan
\q1 chaypi pukllananpa.
\q1 
\v 27 A, Tata Dios,
\q1 tukuy chay animalkuna
\q1 kanta shuyashunkisapa mikunankunata
\q1 munashkankuna oras kunaykipasapa.
\q1 
\v 28 Kan, Tata Dios, mikunankunata kunkisapa.
\q1 Chashna kuptiki chay animalkuna apinsapa.
\q1 Paykunata kuptiki
\q1 munashkankunawan saksansapa.
\q1 
\v 29 Chay animalkunata manana yanapaptiki manchakunsapa.
\q1 Manana kawsanankunapa samayta kuptiki wañunsapa.
\q1 Usushpa polvo tukunsapa.
\q1 
\v 30 Munashpayki kashkan kawsachinkisapa.
\q1 Chashna kawsachikushpa allichanki
\q1 allpa kashkan allima rikurinanpa.
\q1 
\v 31 Mash uyariwaychi.
\q1 Tata Dios mana tukuyniyukta kamachikun.
\q1 Tukuy rurashkanta kawashpa sukaman kushikun.
\q1 
\v 32 Tata Dios munaptin allpa chukchukun.
\q1 Tata Dios urkukunata llankaptin kusninsapa.
\b
\q1 
\v 33 Ñuka chaykunata kawashpa wañunayni diyakaman
\q1 kantukunata kantashpa Tata Diosta kushichisha.
\q1 
\v 34 Allita yuyashpayni munani Tata Diosta kushichiyta.
\q1 Paymi ñukata kushichiwan.
\q1 
\v 35 Kushikushpa rimani:
\q1 Allpamanta tukuy ucha rurak runakuna chinkachunsapa.
\q1 Mana alli rurak runakuna amana kawsachunsapanachu.
\q1 Ñukaka Tata Diosta tukuy shunku kuyashpa alabani.
\q1 Munani tukuy runakuna Tata Diosta alabanankunapa.
\c 119
\s1 Tata Diospa rimanan sukaman allima.
\q1 
\v 9 A, Tata Dios
\q1 ¿imashnatí wayna runa atipanman
\q1 mana uchallikushpa kawsayta?
\q1 Waynaka rimanaykita kasushpa
\q1 mana uchallikushpa kawsanka.
\q1 
\v 10 Ñuka tukuy shunku yanapawanaykipa munani.
\q1 Yanapaway kamachikunaykikunata kasushpa kawsanaynipa.
\q1 
\v 11 Tukuy rimanaykitami tukuy shunku allita kasushkani
\q1 ama uchallikushpa kanta rabyachinaynipa.
\q1 
\v 12 A, Tata Dios,
\q1 kanta sukaman alabayki.
\q1 Kamachikunaykikunata yachachiway.
\q1 
\v 13 Tukuy yachachiwanaykita
\q1 ñukapish runamasinikunata parlachisha.
\q1 
\v 14 Aypa imakuna tiyapaptin kushikunaynimanta
\q1 rimanaykita kasushpayni ashwanta kushikusha.
\q1 
\v 15 Tukuy rimanaykita yuyashpa kawsasha.
\q1 Chayta yuyashpa allita rurashpa kawsashpayni
\q1 ñannikipi purisha.
\q1 
\v 16 Rimanaykita yachashpayni sukaman kushikusha.
\q1 Mana kutin kunkashachu.
\q1 
\v 97 A, Tata Dios,
\q1 sukaman yachachiwashkaykita kuyani.
\q1 Tukuy diya chayta yuyashpa chishyani.
\q1 
\v 98 Tukuy kamachikunaykikunata ñami yachanina.
\q1 Rimanaykika chikniwak runakunamanta
\q1 ashwan alli yachaktami rurawashka.
\q1 
\v 99 Kamachikunaykikunata yuyashpa kawsashpayni
\q1 rimanaykita yachachiwak runakunamanta ashwan allita entiendini.
\q1 
\v 100 Rimanaykita kasushpa kawsashpayni
\q1 kamachikuk ansianukunamanta ashwan allita entiendini.
\q1 
\v 101 Tukuy mana alli ruranakunatami sakishkani
\q1 rimanaykita kasushpa kawsanaynipa.
\q1 
\v 102 Rimanaykita kan yachachiwaptiki
\q1 mana chaykunata sakishkanichu.
\q1 
\v 103 Rimanaykipi willawanki yanapawanaykipa.
\q1 Rimanayki ñukñushina allimami.
\q1 Chayrayku ñukñumanta ashwanta rimanaykita munani.
\q1 
\v 104 Rimanaykimi tukuy alli ruranakunata yachachiwashka.
\q1 Chayrayku chay mana alli ruranakunata
\q1 manana munaninachu rurayta.
\q1 
\v 105 Rimanaykika allima lamparashinami
\q1 purinayni ñanpi allima lusshina.
\c 121
\s1 Tata Dios amachawanchisapa.
\q1 
\v 1 Urkukunata kawashpayni tapunakuni:
\q1 ¿Pití ñukata yanapawanman?
\q1 
\v 2 Tukuy kay allpata sieluta rurak Tata Diosmi yanapawanka.
\q1 
\v 3 Tata Diosmi kantapish yanapashunki
\q1 ama uchata rurashpa urmanaykipa.
\q1 Kuydashuk Tata Dios manami puñunchu.
\q1 
\v 4 Israel runakunata kuydak Tata Dios
\q1 manami shaykunchu nima puñunchu.
\q1 
\v 5 Tata Diosmi allita kuydashunki.
\q1 Tata Diosmi amachashunki.
\q1 Laduykillapi kashpa yanapashunka.
\q1 
\v 6 Chashna Tata Dios amachashuptin
\q1 mana diyapi rupay
\q1 nima tutapi killa wakllichishunkachu.
\q1 
\v 7 Tata Dios yanapashunka
\q1 ama nima wakllichishunanpa.
\q1 Payka sukaman allita amachashunki.
\q1 
\v 8 Maymanpish riptiki
\q1 tukuy tiempu Tata Dios yanapashunki.
\c 133
\s1 Kuyanakushpa kawsananchikuna tiyan.
\q1 
\v 1 Mash allita yuyaychi.
\q1 Sukaman allimami wawkinchikunawan paninchikunawan
\q1 kushikushpa kuyanakushpa kawsananchikunapa.
\q1 
\v 2 Tata Dios Aronta akllaptin saserdote kananpa
\q1 wawkin Moiseska umanpi mishkilla wirata tallirkan.
\q1 Chashna talliptin Aronka runamasinkunata yachachirkansapa
\q1 sukwan sukwan kuyanakushpa kawsanankunapa.
\q1 Chay wira tukuy saserdotekunapa barbankunata surushpa
\q1 tukuy llachapankunata ñuyuchin.
\q1 Chashnashina Tata Dios ñukanchikunatapish yachachiwanchisapa
\q1 sukwan sukwan kuyanakushpa kawsananchikunapa.
\q1 
\v 3 Chashna kuyanakushpa kawsashpanchikuna
\q1 Hermon urkupi serenushina kanchisapa.
\q1 Sion urkuta ñuyuchik serenushina kanchisapa.
\q1 Chashna kuyanakushpa kawsaptinchikuna
\q1 Tata Dios kushikushpa sukaman yanapawanchisapa
\q1 mana tukuyniyukta paywan tantalla kawsananchikunapa.
\c 139
\s1 Tata Dios allita riksiwanchisapa.
\q1 
\v 1 A, Tata Dios,
\q1 sukaman allita kawawashkanki
\q1 yachanaykipa allitachu manachu ruraykani nishpa.
\q1 Sukaman allita riksiwanki.
\q1 
\v 2 Kan yachanki tukuy ima ruranaynita.
\q1 Kanmanta karupi kaptinipish
\q1 tukuy yuyanaynita yachanki.
\q1 
\v 3 Maymanpish riptini
\q1 maypipish samaptini
\q1 tukuy ruranaynita yachanki.
\b
\q1 
\v 4 Manara nimata rimaptinira
\q1 kan yachanki imatami rimanayani nishpa.
\q1 
\v 5 Allita chawpichawashpa kuydawanki.
\q1 Makikita ñukapi churanki yanapawanaykipa.
\q1 
\v 6 Chaykunata yachashpayni
\q1 sukaman almirani.
\q1 Mana atipanichu entiendiyta
\q1 imashnami chashna kuydawanki nishpa.
\b
\q1 
\v 7 Chashna sukaman kuydawaptiki
\q1 mana atipanichu Espirituykimanta pakakuyta.
\q1 Ñawpaknikimanta mana atipanichu pakakuyta.
\q1 
\v 8 Sieluman riptinipish
\q1 chaypimi kawawanki.
\q1 Wañudukuna rinankunaman riptinipish
\q1 chaypimi kawawanki.
\q1 
\v 9 Inti llukshimunan partiman riptinipish
\q1 inti yaykunan partipi
\q1 manllayba kochaman riptinipish
\q1 chaypipish kawawanki.
\q1 
\v 10 Tukuy maymanpish riptini tariwanki.
\q1 Alli ladu makikiwan apiwashpa purichiwanki.
\q1 
\v 11 Yuyaptini tutami pakawanka nishpa
\q1 chaypipish tariwanki.
\q1 Diya tutayaptinpish chaypimi tariwanki.
\q1 
\v 12 Sukaman tutayaptinpish
\q1 mana kanmanta atipanichu pakakuyta.
\q1 Tuta kaptinpish diyapishina kawakunki.
\q1 Tutapi diyapi chashnallami kawakunki.
\b
\q1 
\v 13 Kanmi mamaynipa wiksanpi rurawashkanki.
\q1 Tukuy kuerpuynita rurashkanki.
\q1 
\v 14 Chaykunata yachashpa almirashpa alabayki.
\q1 Sukaman almirana layakunata rurashkanki.
\q1 Allita yachani tukuy layata rurashkaykita.
\q1 
\v 15 Mamaynipa wiksanpi kuerpuyni wiñaptin
\q1 mana ni pi kawawaptinpish
\q1 kanmi kawawashkanki.
\q1 
\v 16 Kuerpuyni wiñaykaptin kawawashkanki.
\q1 Libruykipi tukuy chaykunata killkashkanki.
\q1 Manara kawsaptinira yachashkanki
\q1 mashna diyakunatami kawsasha nishpa.
\b
\q1 
\v 17 A, Tata Dios,
\q1 favorninipa allimata yuyaykanki.
\q1 Yuyanaykikunaka sukaman mana yupaypa layami.
\q1 
\v 18 Rurashkaykita yupanayashpayni
\q1 playatashina mana atipanichu yupayta.
\q1 Puñushkaynimanta atarishpayni kanllawan kani.
\b
\q1 
\v 19 A, Tata Dios,
\q1 tukuy sakra mana alli rurak runakunata kastigaysapa.
\q1 Chay wañuchiwanayak runakunata
\q1 ñukamanta anchuchiysapa.
\q1 
\v 20 Washanchashuk runakunata
\q1 yankamanta chiknishuk runakunata kastigaysapa.
\b
\q1 
\v 21 A, Tata Dios,
\q1 chiknishuk runakunata chiknini.
\q1 Mana kasushunayak runakunata mana nimatashina kawanisapa.
\q1 
\v 22 Tukuy shunku paykunata chikninisapa.
\q1 Chay chiknishuk runakunata yuyani
\q1 chikniwak runakuna kanankunata.
\b
\q1 
\v 23 A, Tata Dios,
\q1 allita kawaway yachanaykipa
\q1 allitachu manachu kuyayki nishpa.
\q1 Riksiway allitachu manachu yuyaykuni nishpa.
\q1 
\v 24 Kawaway ichará mana allikunata ruraykani nishpa.
\q1 Chashna mana allita ruraptini
\q1 yanapaway allita rurashpa
\q1 alli ñannikita katinaynipa.
