\id REV
\h أَسَارْڭبْ
\toc1 أَسَارْڭبْ
\toc2 أَسَارْڭبْ
\toc3 أَسَا.
\mt1 أَسَارْڭبْ
\c 1
\s1 ثَامزْوَارُوثْ
\m 
\v 1 أَسَارْڭَابْ ن يَاسُوع لْمَاسِيحْ إِ ذ أَسْ إِوْشَا أَربِّي، حِيمَا أَذْ إِسّْشنْ إِ إِمْسخَّارنْ نّسْ مِينْ إِتّْخصَّا أَذْ إِمْسَارْ ذغْيَا، ؤُشَا إِسَّارْڭبْ إِ-ث أَمْ ث إِسّكّْ س \add ؤُفُوسْ ن\add* لْمَالَاكْ نّسْ إِ ؤُمْسخَّارْ نّسْ يُوحَانَّا.
\v 2 وَانِيثَا إِشْهذْ خْ وَاوَاڒْ ن أَربِّي ؤُ زِي شّْهَاذثْ ن يَاسُوع لْمَاسِيحْ ؤُ زِي مَارَّا مِينْ إِژْرَا،
\v 3 \bd سّعْذْ\bd* ن ونِّي إِقَّارنْ ذ يِينِّي إِتّسْڒَانْ أَوَاڒنْ ن نُّوبُووَا-يَا ؤُ قِّيمنْ تّطّْفنْ ذِي مِينْ ذَايْسنْ يُورَانْ، مَاغَارْ أَقَا ڒْوقْثْ ثِيوضْ-د. \x ◘ \xo 1:‏3 \xt أَسَا. 22‏:‏7، 10. \x*
\b
\m 
\v 4 يُوحَانَّا، إِ سبْعَا ن ثْمسْمُونِينْ ذِي أَسِييَا: أَذْ كِيذْومْ يِيڒِي أَرْضَا ذ ڒهْنَا زڭْ ونِّي إِدْجَانْ ذ ونِّي ثُوغَا ذ ونِّي د غَا يَاسنْ، ؤُڒَا زِي سبْعَا ن أَرُّوحَاثْ نِّي إِدْجَانْ زَّاثْ إِ ڒْعَارْشْ نّسْ، \x ◘ \xo 1:‏4 \xt ؤُف. 3‏:‏14؛ أَسَا. 1‏:‏8؛ 4‏:‏8؛ 11‏:‏17؛ 16‏:‏5. \x*
\v 5 ؤُ زِي يَاسُوع لْمَاسِيحْ، أَشهَّاذْ أَمْثِيقِّي، أَمنْزُو ن إِمتِّيننْ ذ أَمقّْرَانْ ن إِجدْجِيذنْ ن ثمُّورْثْ. \add إِ\add* ونِّي ذ أَنغْ إِتّخْسنْ ؤُ ذ أَنغْ إِفكّنْ زِي دّْنُوبْ نّغْ س إِذَامّنْ نّسْ، \x ◘ \xo 1:‏5 \xt إِشا. 55‏:‏4؛ ڒخ. 20‏:‏28؛ 1 كُور. 15‏:‏20؛ كُول. 1‏:‏18؛ عبر. 9‏:‏12، 14؛ 1 بُط. 1‏:‏19؛ 1 يُوح. 1‏:‏7؛ أَسَا. 3‏:‏14؛ 5‏:‏9. \x*
\v 6 ذ ونِّي يَارّْ أَنغْ ذ إِشْثْ ن ثَاڭلْذَا ن إِكهَّاننْ غَارْ أَربِّي ذ بَابَاسْ، إِ نتَّا أَذْ غَارسْ يِيڒِي ؤُعُودْجِي ذ صُّولْطَا إِ ڒبْذَا قَاعْ. أَمِينْ! \x ◘ \xo 1:‏6 \xt رُوم. 12‏:‏1؛ 1 بُط. 2‏:‏5، 9؛ أَسَا. 5‏:‏10. \x*
\b
\m 
\v 7 خْزَارْ، نتَّا أَذْ د-يَاسْ أَكْ-ذ إِسيْنُوثنْ، كُوڒْ ثِيطّْ أَذْ ث ثْژَارْ، ؤُڒَا ذ إِنِّي ث إِسّْنُوقّْبنْ. مَارَّا ثِيقبَّاڒْ ن ثمُّورْثْ أَذْ خَاسْ وْثنْثْ أَڭجْذُورْ. وَاهْ، أَمِينْ! \x ◘ \xo 1:‏7 \xt دَان. 7‏:‏13؛ زَاك. 12‏:‏10؛ مت. 24‏:‏30؛ 25‏:‏31؛ يُوح. 19‏:‏37؛ ڒخ. 1‏:‏11؛ 1 تس. 1‏:‏10؛ 2 تس. 1‏:‏10؛ يَاه. 14. \x*
\b
\m 
\v 8 نشّْ ذ أَلِيفْ ذ ثَاوْ، \add أَمزْوَارُو ذ ؤُنڭَّارُو\add*، إِقَّارْ سِيذِي أَربِّي، ذ ونِّي إِدْجَانْ ذ ونِّي ثُوغَا ذ ونِّي د غَا يَاسنْ، أَمْزمَّارْ خْ كُوڒْشِي. \x ◘ \xo 1:‏8 \xt إِشا. 41‏:‏4؛ 44‏:‏6؛ أَسَا. 21‏:‏6؛ 22‏:‏13. \x*
\b
\s1 أَضْهَارْ ن يَاسُوع لْمَاسِيحْ
\m 
\v 9 نشّْ، يُوحَانَّا، ؤُمَاثْومْ ذ ؤُمْعَاشَارْ نْومْ ذِي ڒْمحْنثْ ؤُ ذِي صّْبَارْ نِّي إِدْجَانْ ذِي يَاسُوع، ثُوغَا أَيِي ذِي ثڭْزِيرْثْ قَّارنْ أَسْ بَاثْمُوسْ ذِي طّْوعْ ن وَاوَاڒْ ن أَربِّي ذ شّْهَاذثْ ن يَاسُوع لْمَاسِيحْ.
\v 10 ؤُسِيغْ-د ذِي أَرُّوحْ ذڭْ وَاسّْ أَمزْوَارُو ن سِّيمَانَا ؤُشَا سْڒِيغْ أَوَارْنِي أَيِي إِشْثْ ن ثْمِيجَّا ثجْهذْ أَمْ \bd ؤُسُوضِي ذڭْ ؤُيِيشّْ ن ؤُشَارِّي\bd*، \f ◼ \fr 1:‏10 \ft \bd ’ذڭْ وَاسّْ أَمزْوَارُو ن سِّيمَانَا‘\bd* - أَقَا-ث ذڭْ وَاسّْ ن ؤُمنْسِي إِقدّْسنْ ن أَربِّي ؤُمِي تِّيذَارنْ ڒْمُومِينِينْ (ذِي مْكُوڒْ سِّيمَانَا) ڒْموْثْ ن يَاسُوع لْمَاسِيحْ ذِي ثْمسْمُونِينْ.\f*  \x ◘ \xo 1:‏10 \xt أَسَا. 4‏:‏2. \x*
\v 11 ثقَّارْ: ”مِينْ ثتّْوَاڒِيذْ، أَرِي ث ذڭْ إِجّْ ن وذْلِيسْ \add إِتّْوَانْضنْ\add*، سّكّْ إِ-ت-إِ-د إِ سبْعَا ن ثْمسْمُونِينْ: غَارْ أَفَاسُوسْ، غَارْ سْمِيرْنَا، غَارْ بِيرْغَامُوسْ، غَارْ ثِييَاثِيرَا، غَارْ سَارْذِيسْ، غَارْ فِيلَاذِيلْفِييَا ؤُشَا غَارْ لَايُوذِيكِييَا.“
\m 
\v 12 خنِّي نّْقڒْبغْ، حِيمَا أَذْ سّْنغْ وِي كِيذِي إِسَّاوَاڒنْ. أَڒَامِي نّْقڒْبغْ، ژْرِيغْ سبْعَا ن ڒقْنَاذڒْ ن وُورغْ.
\v 13 ذِي ڒْوسْطْ ن ڒقْنَاذڒْ إِجّنْ أَمْ مِّيسْ ن بْنَاذمْ، ثُوغَا يَارْضْ أَپَالْطُو \add ن ؤُكهَّانْ\add* ؤُ غَارسْ إِجّْ ن وبْيَاسْ ن وُورغْ خْ إِذْمَارنْ. \x ◘ \xo 1:‏13 \xt حِز. 1‏:‏26؛ دَان. 7‏:‏13؛ أَسَا. 14‏:‏14. \x*
\v 14 أَزدْجِيفْ نّسْ ذ ؤُشُووَّافْ نّسْ ثُوغَا أَثنْ ذ إِشمْڒَاڒنْ أَمْ ثَاضُوفْثْ، أَمْ وذْفڒْ، ؤُشَا ثِيطَّاوِينْ نّسْ أَمْ يِيحُوذَاقْ ن ثْمسِّي، \x ◘ \xo 1:‏14 \xt دَان. 7‏:‏9؛ أَسَا. 19‏:‏12. \x*
\v 15 إِضَارنْ نّسْ أَمْ نّْحَاسْ زِي لُوبْنَانْ، إِحْمَانْ ذڭْ ؤُفَارَّانْ، ؤُ ڒْحسّْ نّسْ أَمْ ڒْحسّْ ن وَاطَّاسْ ن وَامَانْ. \x ◘ \xo 1:‏15 \xt أَسَا. 14‏:‏2. \x*
\v 16 ثُوغَا غَارسْ ذڭْ ؤُفُوسْ نّسْ أَفُوسِي سبْعَا ن يثْرَانْ ؤُشَا زڭْ ؤُقمُّومْ نّسْ إِتّفّغْ-د زَّايسْ لَانْسَا إِقْضعْ ؤُشَا أَغمْبُوبْ نّسْ أَمْ ثْفُوشْثْ س جّهْذْ نّسْ. \x ◘ \xo 1:‏16 \xt إِشا. 49‏:‏2؛ أَفا. 6‏:‏17؛ عبر. 4‏:‏12؛ أَسَا. 2‏:‏16؛ 19‏:‏15. \x*
\m 
\v 17 أَڒَامِي ث ژْرِيغْ، وْضِيغْ أَسْ غَارْ إِضَارنْ نّسْ أَخْمِي مُّوثغْ ؤُشَا نتَّا إِسَّارْسْ خَافِي أَفُوسْ نّسْ أَفُوسِي، إِنَّا: ”وَارْ تّڭّْوذْ شَا! أَقَا نشّْ ذ أَمزْوَارُو ذ ؤُنڭَّارُو، \x ◘ \xo 1:‏17 \xt إِشا. 41‏:‏4؛ 44‏:‏6؛ 48‏:‏12. \x*
\v 18 نشّْ ذ ونِّي إِدَّارنْ، ؤُ نشّْ ثُوغَا مُّوثغْ، ؤُ خْزَارْ، أَقَا نشّْ ذ ونِّي إِدَّارنْ إِ ڒبْذَا قَاعْ! أَقَا غَارِي ثْسَارُوثْ ن ڒْموْثْ ذ ڒَاخَارْثْ. \x ◘ \xo 1:‏18 \xt أَيُوبْ 12‏:‏14؛ إِشا. 22‏:‏22؛ رُوم. 6‏:‏9؛ أَسَا. 3‏:‏7؛ 20‏:‏1. \x*
\v 19 س ؤُينِّي أَرِي مِينْ ثژْرِيذْ ؤُڒَا ذ ثِيمسْڒَايِينْ نِّي إِدْجَانْ ذ ثِيمسْڒَايِينْ نِّي إِ غَا إِمْسَارنْ أَوَارْنِي مَانْ أَيَا.
\v 20 أَقَا سِّيرّْ ن سبْعَا ن إِثْرَانْ إِ ثژْرِيذْ ذڭْ ؤُفُوسْ إِنُو أَفُوسِي ؤُ \add سِّيرّْ\add* ن سبْعَا ن ڒقْنَاذڒْ ن وُورغْ ذ وَا: سبْعَا ن إِثْرَانْ أَقَا أَثنْ ذ لْمَالَاكَاثْ ن سبْعَا ن ثْمسْمُونِينْ ؤُشَا سبْعَا ن ڒقْنَاذڒْ، أَقَا أَثنْ ذ سبْعَا ن ثْمسْمُونِينْ.“
\b
\b
\c 2
\s1 ثِيبْرَاثِينْ إِ سبْعَا ن ثْمسْمُونِينْ
\m 
\v 1 \bd أَرِي إِ لْمَالَاكْ ذِي ثْمسْمُونْثْ ن أَفَاسُوسْ!\bd*
\m ”أَمُّو إِ إِقَّارْ ونِّي غَارْ إِدْجَا سبْعَا ن إِثْرَانْ ذڭْ ؤُفُوسْ نّسْ، ونِّي إِڭُّورنْ ذِي ڒْوسْطْ ن سبْعَا ن ڒقْنَاذڒْ ن وُورغْ:
\v 2 ’نشّْ سّْنغْ ڒخْذَايمْ نّشْ ذ وَارْبَارْ نّشْ ذ صّْبَارْ نّشْ، بلِّي وَارْ ثْزمَّارذْ أَذْ ثْحمْڒذْ إِنِّي إِعفّْننْ ؤُشَا ثْقدْجْبذْ إِنِّي إِتّڭّنْ إِخفْ نْسنْ ذ رُّوسُولْ، مَاشَا وَارْ دْجِينْ شَا، ؤُشَا ثُوفِيذْ ثنْ ذ أَيْثْ ن بُو-إِخَارِّيقنْ. \f ◼ \fr 2:‏2 \ft \bd ’رُّوسُولْ‘\bd* - نِيغْ ’إِمَازَاننْ‘.\f*
\v 3 شكْ ثْصبَّارذْ ؤُ ثكْسِيذْ أَرْمحْ خْ سِّيبّثْ ن يِيسمْ إِنُو ؤُ وَارْ ثُوحِيڒذْ شَا.
\v 4 مَاشَا غَارِي خَاكْ شَا، بلِّي ثجِّيذْ ثَايْرِي نّشْ ثَامزْوَارُوثْ.
\v 5 عْقڒْ مَانِيسْ-د ثوْضِيذْ ؤُشَا ثُوبْ، خنِّي أڭّْ ڒخْذَايمْ ثِيمزْوُورَا! مَاڒَا وَارْ إِدْجِي أَمنِّي، أَذْ غَاركْ د-أَسغْ ذغْيَا، أَذْ كسّغْ ڒْقنْذِيڒْ نّشْ، مَاڒَا وَارْ ثتُّوبذْ شَا.
\v 6 مَاشَا مَانْ أَيَا ثِيوْضذْ، أَقَا ثْشَارّْهذْ ڒخْذَايمْ ن أَيْثْ ن إِنِيكُولَايِيثنْ، ثِينِّي شَارّْهغْ ؤُڒَا ذ نشّْ. \f ◼ \fr 2:‏6 \ft \bd ’إِنِيكُولَايِيثنْ‘\bd* - نِيثْنِي ذ إِوْذَانْ إِنِّي إِفّْغنْ زڭْ وبْرِيذْ ن لْ-إِيمَانْ ذِي لْمَاسِيحْ (خْژَارْ أَسَا. 2:6؛ 2:15)\f*  \x ◘ \xo 2:‏6 \xt أَسَا. 2‏:‏6. \x*
\m 
\v 7 ونِّي غَارْ دْجَانْ إِمزُّوغنْ، أجّْ إِ-ث أَذْ إِسڒْ مِينْ إِقَّارْ أَرُّوحْ إِ ثْمسْمُونِينْ.
\m ونِّي إِ غَا إِغلّْبنْ أَذْ ث سّشّغْ زِي ثْشجَّارْثْ ن ثُوذَارْثْ إِ يدْجَانْ ذِي جّنّثْ ن أَربِّي.‘ “ \f ◼ \fr 2:‏7 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  \x ◘ \xo 2:‏7 \xt أَمز. 2‏:‏9؛ أَسَا. 22‏:‏2. \x*
\b
\m 
\v 8 \bd أَرِي إِ لْمَالَاكْ ن ثْمسْمُونْثْ ن سْمِيرْنَا!\bd*
\m ”أَمُّو إِ إِقَّارْ ونِّي ذ أَمزْوَارُو ذ ؤُنڭَّارُو، ونِّي إِمُّوثنْ ؤُشَا إِدَّارْ: \x ◘ \xo 2:‏8 \xt إِشا. 41‏:‏4؛ 44‏:‏6؛ أَسَا. 1‏:‏17. \x*
\v 9 ’أَقَا سّْنغْ ڒْمحْنثْ نّشْ ذ وزْڒَاضْ نّشْ، قَاعْ أَمنِّي شكْ ثتّجَّارذْ، ؤُ \add أَقَا-يِي سّْنغْ\add* ؤُڒَا ذ أَشقّفْ ن يِينِّي إِقَّارنْ أَقَا أَثنْ ذ ؤُذَاينْ س ثِيذتّْ، مَاشَا نِيثْنِي وَارْ دْجِينْ شَا \add ذ ؤُذَاينْ\add*، مَاشَا ذ ثَامْزِيذَا ن شِّيطَانْ.
\v 10 وَارْ تّڭّْوذْ شَا زِي مِينْ غَا ثتّْوَاعدّْبذْ. أَقَا إِبْڒِيسْ أَذْ إِنْضَارْ \add شَا\add* زَّايْومْ ذِي ڒحْبسْ، حِيمَا أَذْ ثتّْوَاجَارّْبمْ. أَذْ غَارْومْ ثِيڒِي ڒْمحْنثْ نعشْرَا ن وُوسَّانْ. إِڒِيمْ ذ إِمْثِيقَّانْ أَڒْ ڒْموْثْ، ڒخْذنِّي أَذْ أَومْ وْشغْ تَّاجْ ن ثُوذَارْثْ.
\m 
\v 11 ونِّي غَارْ دْجَانْ إِمزُّوغنْ، أجّْ إِ-ث أَذْ إِسڒْ مِينْ إِقَّارْ أَرُّوحْ إِ ثْمسْمُونِينْ.
\m ونِّي إِ غَا إِغلّْبنْ وَارْ ذ أَسْ د-ثتِّيوِي شَا ثْخسَّارْثْ زِي ڒْموْثْ وِيسّْ ثْنَاينْ.‘ “ \x ◘ \xo 2:‏11 \xt مت. 13‏:‏9. \x*
\b
\m 
\v 12 \bd أَرِي إِ لْمَالَاكْ ذِي ثْمسْمُونْثْ ن بِيرْغَامُوسْ!\bd*
\m ”أَمُّو إِ إِقَّارْ ونِّي غَارْ إِدْجَا سِّيفْ إِقْضعْ خْ ثْنَاينْ ن وُوذْمَاونْ: \x ◘ \xo 2:‏12 \xt أَسَا. 1‏:‏16؛ 2‏:‏16. \x*
\v 13 ’نشّْ سّْنغْ مَانِي ثْزدّْغذْ، \add ذِيهَا مَانِي إِتّْبدَّا\add* ڒْعَارْشْ ن شِّيطَانْ. أَقَا ثقِّيمذْ ثطّْفذْ ذڭْ يِيسمْ إِنُو ؤُشَا وَارْ ثنْكَارذْ شَا لْ-إِيمَانْ ذَايِي، ؤُشَا ذڭْ وُوسَّانْ ؤُمِي ثُوغَا شكْ ثتّْمنْغذْ \add جْمِيعْ\add* أَكْ-ذ ؤُشهَّاذْ أَمْثِيقِّي إِنُو ذِي طّْوعْ ن مَارَّا إِشهَّاذنْ إِنُو إِمْثِيقَّانْ، أَقَا إِتّْوَانغْ نتَّا جَارْ أَومْ.
\v 14 مَاشَا غَارِي خَاكْ شَا، مِينْزِي غَاركْ ذِينِّي \add شَا\add* إِنِّي إِتّطّْفنْ ذڭْ ؤُسڒْمذْ ن بَالْعَامْ، ونِّي ثُوغَا إِسّْڒمْذنْ إِ بَالَاكْ مَامّشْ غَا إِنْضَارْ ثَاعنْكْرِيفْثْ إِ أَيْثْ ن إِسْرَائِيل، حِيمَا أَذْ شّنْ زِي مِينْ غَارْصنْ إِ لْ-أَصْنَامْ ؤُشَا أَذْ سفْسَّاذنْ إِخفْ نْسنْ. \x ◘ \xo 2:‏14 \xt ڒخْڒ. 22‏:‏23؛ 24‏:‏14؛ 25‏:‏1؛ 31‏:‏16. \x*
\v 15 غَاركْ ذِينْ عَاوذْ \add شَا\add* إِنِّي إِتّطّْفنْ ذِي ثْغُورِي ن إِنِيكُولَايِيثنْ. \f ◼ \fr 2:‏15 \ft \bd ’إِنِيكُولَايِيثنْ‘\bd* - نِيثْنِي ذ إِوْذَانْ إِنِّي إِفّْغنْ زڭْ وبْرِيذْ ن لْ-إِيمَانْ ذِي لْمَاسِيحْ (خْژَارْ أَسَا. 2:6؛ 2:15)\f*
\v 16 س ؤُينِّي ثُوبْ! مَاڒَا وَارْ إِدْجِي أَمنِّي، أَذْ غَارْومْ د-أَسغْ ذغْيَا، أَذْ كِيسنْ مّنْغغْ س سِّيفْ ن ؤُقمُّومْ إِنُو. \x ◘ \xo 2:‏16 \xt إِشا. 49‏:‏2؛ أَفا. 6‏:‏17؛ عبر. 4‏:‏12؛ أَسَا. 1‏:‏16. \x*
\m 
\v 17 ونِّي غَارْ دْجَانْ إِمزُّوغنْ، أجّْ إِ-ث أَذْ إِسڒْ مِينْ إِقَّارْ أَرُّوحْ إِ ثْمسْمُونِينْ.
\m ونِّي إِ غَا إِغلّْبنْ أَذْ أَسْ سّشّغْ ’مَانَّا‘ إِنُّوفَارنْ ؤُشَا أَذْ أَسْ وْشغْ إِجّْ ن ؤُقَايَاسْ ذ أَشمْڒَاڒْ، ؤُشَا خْ ؤُقَايَاسْ نِّي إِتّْوَارِي خَاسْ إِجّْ ن إِسمْ ن جْذِيذْ، وَارْ ث إِسِّينْ حذْ مْغِيرْ ونِّي ث إِطّْفنْ.‘ “ \x ◘ \xo 2:‏17 \xt ؤُف. 16‏:‏4‏-‏36. \x*
\b
\m 
\v 18 أَرِي إِ لْمَالَاكْ \bd ذِي ثْمسْمُونْثْ ن ثِييَاثِيرَا!\bd*
\m ”أَمُّو إِ إِقَّارْ مِّيسْ ن أَربِّي ونِّي غَارْ إِدْجَا ثِيطَّاوِينْ أَمْ يِيحُوذَاقْ ن ثْمسِّي ذ إِضَارنْ نّسْ أَمْ نّْحَاسْ زِي لُوبْنَانْ: \x ◘ \xo 2:‏18 \xt أَسَا. 1‏:‏14، 15. \x*
\v 19 ’نشّْ سّْنغْ ڒخْذَايمْ نّشْ ؤُڒَا ذ ثَايْرِي نّشْ ذ لْ-إِيمَانْ نّشْ ذ ثْسخَّارْثْ نّشْ ذ صّْبَارْ نّشْ، أَقَا ڒخْذَايمْ نّشْ ثِينڭُّورَا إِمْغَارنْ خْ ثْمزْوُورَا.
\v 20 مَاشَا غَارِي خَاكْ أَطَّاسْ، مِينْزِي ثجِّيذْ ثَامطُّوثْ نّشْ إِزَابِيلْ، ثنِّي إِقَّارنْ بلِّي نتَّاثْ ذ ثَانَابِيثْ، ثسّڒْمَاذْ ؤُشَا ثسّْغكّْوَا إِمْسخَّارنْ إِنُو، حِيمَا أَذْ سّْفسْذنْ إِخفْ نْسنْ ؤُشَا أَذْ شّنْ مِينْ إِتّْوَاغَارْصنْ إِ لْ-أَصْنَامْ. \x ◘ \xo 2:‏20 \xt 1 إِج. 16‏:‏31؛ 2 إِج. 9‏:‏7. \x*
\v 21 أَقَا وْشِيغْ أَسْ شَا ن ڒْوقْثْ حِيمَا أَذْ ثثُوبْ، \add مَاشَا\add* نتَّاثْ وَارْ ثتّخْسْ شَا أَذْ ثثُوبْ زِي فَارْقْ-شّْغڒْ نّسْ.
\v 22 خْزَارْ، أَذْ تغضْڒغْ ذِي ثَاسُّوثْ، \add أَذْ ثِيڒِي ثحْڒشْ أَڒْ ڒْموْثْ\add*، ؤُشَا إِنِّي أَكِيذسْ إِزنَّانْ، \add أَذْ ثنْ نذْهغْ\add* ذِي ڒْمحْنثْ ثَامقّْرَانْثْ مَاڒَا وَارْ ثُوبنْ شَا زِي مِينْ ڭِّينْ.
\v 23 ثَارْوَا نّسْ أَذْ ثنْ وْثغْ س ڒْموْثْ ؤُشَا مَارَّا ثِيمسْمُونِينْ أَذْ فهْمنْثْ أَقَا نشّْ ذ ونِّي إِقدْجْبنْ ثِيژَّاڒْ ذ وُوڒَاونْ ؤُشَا أَذْ وْشغْ إِ كُوڒْ إِجّنْ زَّايْومْ أَنشْثْ ن ڒخْذَايمْ نْومْ. \x ◘ \xo 2:‏23 \xt 1 صم. 16‏:‏7؛ 1 إِم. 28‏:‏9؛ 29‏:‏17؛ إِزهد.7‏:‏10؛ 62‏:‏13؛ إِرْم. 11‏:‏20؛ 17‏:‏10؛ 32‏:‏19؛ مت. 16‏:‏27؛ ڒخ. 1‏:‏24؛ رُوم. 2‏:‏6؛ 14‏:‏12؛ 2 كُور. 5‏:‏10؛ ڭال. 6‏:‏5؛ أَسَا. 20‏:‏12. \x*
\v 24 مَاشَا إِ كنِّيوْ ؤُ إِ إِنّغْنِي ذِي ثِييَاثِيرَا - \add إِخْسْ أَذْ يِينِي\add* إِ مَارَّا إِنِّي وَارْ غَارْ ثدْجِي شَا ثَاغُورِي-يَا، وَارْ سِّيننْ ؤُمِي قَّارنْ نِيثْنِي ’ڒَْادْجَاغْ ن شِّيطَانْ‘ - أَذْ أَومْ إِنِيغْ: نشّْ وَارْ خَاومْ تّْذَارَّاشغْ شَا ثَاغْرَارْثْ نّغْنِيثْ.
\v 25 \add مَاشَا\add* مِينْ غَارْومْ، طّْفمْ ذَايسْ أَڒْ د غَا يَاسغْ. \x ◘ \xo 2:‏25 \xt أَسَا. 3‏:‏11. \x*
\m 
\v 26 ونِّي إِ غَا إِغلّْبنْ ؤُ ونِّي إِ غَا إِطّْفنْ ذِي ڒخْذَايمْ إِنُو، أَذْ أَسْ وْشغْ صُّولْطَا خْ ڒڭْنُوسْ
\v 27 مَاحنْذْ أَذْ ثنْ يَارْوسْ س ؤُزدْجَاضْ ن وُوزَّاڒْ، أَذْ ثنْ ثَارْژِيمْ أَمْ إِغَارَّافنْ ن بُو-ثْڒَاخْثْ، أَمْ مَامّشْ إِ ثطّْفغْ ؤُڒَا ذ نشّْ زِي بَابَا، \x ◘ \xo 2:‏27 \xt إِزهد. 2‏:‏8‏-‏9. \x*
\v 28 ؤُشَا نشّْ أَذْ أَسْ وْشغْ إِثْرِي ن ڒفْجَارْ.
\m 
\v 29 ونِّي غَارْ دْجَانْ إِمزُّوغنْ، أجّْ إِ-ث أَذْ إِسڒْ مِينْ إِقَّارْ أَرُّوحْ إِ ثْمسْمُونِينْ.‘ “
\b
\b
\c 3
\m 
\v 1 \bd أَرِي إِ لْمَالَاكْ ذِي ثْمسْمُونْثْ ن سَارْذِيسْ!\bd*
\m ”أَمُّو إِ إِقَّارْ ونِّي غَارْ إِدْجَا سبْعَا ن أَرُّوحَاثْ ن أَربِّي ذ سبْعَا ن يثْرَانْ:
\m ’نشّْ سّْنغْ ڒخْذَايمْ نّشْ، أَقَا غَاركْ إِسمْ، بلِّي أَقَا ثدَّارذْ، \add مَاشَا\add* شكْ أَقَا ثتّْمتِّيذْ. \x ◘ \xo 3:‏1 \xt أَسَا. 1‏:‏14، 16. \x*
\v 2 حْضَا، سجْهذْ مِينْ إِقِّيمنْ، إِنِّي ثنْوِيذْ شكْ أَذْ ثنْ ثتّجِّيذْ أَذْ ثمّْثمْ، مَاغَارْ ؤُفِيغْ أَقَا ڒخْذَايمْ نّشْ وَارْ كمّْڒنْثْ شَا غَارْ أَربِّي.
\v 3 عْقڒْ مْلِيحْ، مَامّشْ \add خَاسْ\add* ثسْڒِيذْ ؤُ مَامّشْ ثطّْفذْ، حْضَا ؤُشَا ثُوبْ! مَاشَا مَاڒَا وَارْ ثتّْفِيقذْ، أَذْ غَاركْ د-أَسغْ أَمْ ؤُشفَّارْ، وَارْ ثسِّينذْ شَا ذِي مَانْ ثَاسَاعّثْ إِ خَاكْ د غَا بدّغْ. \x ◘ \xo 3:‏3 \xt مت. 24‏:‏43؛ 1 تس. 5‏:‏2؛ 2 بُط. 3‏:‏10؛ أَسَا. 3‏:‏19؛ 16‏:‏15. \x*
\v 4 مَاشَا غَارِي شَا ن إِسْمَاونْ ذِي سَارْذِيسْ، إِنِّي وَارْ إِسّْخمْجنْ شَا أَرُّوضْ نْسنْ ؤُشَا نِيثْنِي ڭُّورنْ زَّاثِي س \add وَارُّوضْ\add* ذ أَشمْڒَاڒْ، مِينْزِي نِيثْنِي سْذَاهدْجنْ ث.
\m 
\v 5 ونِّي إِ غَا إِغلّْبنْ أَمُّو، أَذْ أَسْ يَارْضنْ أَرُّوضْ ذ أَشمْڒَاڒْ.عمَّارْصْ أَذْ كّْسغْ إِسمْ نّسْ زڭْ وذْلِيسْ إِتّْوَانْضنْ ن ثُوذَارْثْ، مَاشَا أَذْ شهْذغْ خْ يِيسمْ نّسْ زَّاثْ إِ بَابَا ذ لْمَالَاكَاثْ نّسْ. \x ◘ \xo 3:‏5 \xt ؤُف. 32‏:‏32؛ إِزهد. 69‏:‏29؛ مت. 10‏:‏32؛ لك. 12‏:‏8؛ فِيل. 4‏:‏3؛ أَسَا. 20‏:‏12؛ 21‏:‏27. \x*
\m 
\v 6 ونِّي غَارْ دْجَانْ إِمزُّوغنْ، أجّْ إِ-ث أَذْ إِسڒْ مِينْ إِقَّارْ أَرُّوحْ إِ ثْمسْمُونِينْ.‘ “
\b
\m 
\v 7 \bd أَرِي إِ لْمَالَاكْ ن ثْمسْمُونْثْ ن فِيلَاذِيلْفِييَا!\bd*
\m ”أَمُّو إِ إِقَّارْ ؤُمْقدَّاسْ ونِّي ذ ثِيذتّْ ذ ونِّي غَارْ إِدْجَا ثْسَارُوثْ ن ذَاوُوذْ ذ ونِّي إِ غَا يَارزْمنْ، \add خنِّي\add* ؤُڒَا ذ إِجّنْ أَذْ إِبلّعْ، ذ ونِّي إِ غَا إِبلّْعنْ، \add خنِّي\add* ؤُڒَا ذ إِجّنْ أَذْ يَارْزمْ: \x ◘ \xo 3:‏7 \xt أَيُوبْ 12‏:‏14؛ إِشا. 22‏:‏22؛ أَسَا. 1‏:‏18؛ 3‏:‏14. \x*
\m 
\v 8 ’نشّْ سّْنغْ ڒخْذَايمْ نّشْ. خْزَارْ، نشّْ ڭِّيغْ زَّاثشْ إِشْثْ ن ثوَّارْثْ ثَارْزمْ، ثنِّي ؤُڒَا ذ إِجّْ وَارْ إِزمَّارْ أَذْ ت إِبلّعْ، مِينْزِي وَاخَّا جّهْذْ نّشْ ذ أَمژْيَانْ، قَاعْ أَمنِّي ثحْضِيذْ أَوَاڒْ إِنُو ؤُشَا وَارْ ثنْكَارذْ شَا إِسمْ إِنُو.
\v 9 خْزَارْ، أَذْ وْشغْ شَا زِي ثمْزِيذَا ن شِّيطَانْ، إِنِّي إِقَّارنْ أَقَا نِيثْنِي ذ ؤُذَاينْ، \add مَاشَا\add* نِيثْنِي وَارْ دْجِينْ شَا أَمنِّي، مَاشَا نِيثْنِي سّْخَارِّيقنْ. خْزَارْ، أَذْ ثنْ أَرّغْ أَذْ أَشْ وْضَانْ غَارْ إِضَارنْ نّشْ. نِيثْنِي أَذْ نعْمنْ بلِّي نشّْ سّْعِيزّغْ شكْ. \x ◘ \xo 3:‏9 \xt أَسَا. 2‏:‏9. \x*
\m 
\v 10 مِينْزِي أَقَا شكْ ثحْضِيذْ أَوَاڒْ إِنُو ن صّْبَارْ، أَذْ خَاكْ حْضِيغْ عَاوذْ زِي \add ثْسَاعّثْ ن\add* ؤُجَارّبْ ثنِّي إِ ذ غَا يَاسنْ خْ ثمُّورْثْ مَارَّا إِ ؤُجَارّبْ ن يِينِّي إِزدّْغنْ خْ ثمُّورْثْ.
\v 11 نشّْ أَذْ د-أَسغْ ذغْيَا. طّفْ ذِي مِينْ غَاركْ، حِيمَا ؤُڒَا ذ إِجّْ وَارْ ذ أَشْ إِتّكّسْ شَا تَّاجْ نّشْ. \x ◘ \xo 3:‏11 \xt أَسَا. 2‏:‏25. \x*
\m 
\v 12 ونِّي إِ غَا إِغلّْبنْ أَذْ ث ڭّغْ ذ أَپِيلَارْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ ن أَربِّي ؤُشَا وَارْ زَّايسْ إِتّْوَامّكْسِيعمَّارْصْ. نشّْ أَذْ خَاسْ أَرِيغْ إِسمْ ن أَربِّي إِنُو ذ يِيسمْ ن ثنْذِينْثْ ن جْذِيذْ، ؤُرْشَالِيمْ إِ د غَا إِهْوَانْ زڭْ ؤُجنَّا زِي أَربِّي إِنُو، ؤُڒَا ذ إِسمْ إِنُو ن جْذِيذْ. \x ◘ \xo 3:‏12 \xt 1 إِج. 7‏:‏21؛ أَسَا. 21‏:‏2، 10؛ 22‏:‏4. \x*
\m 
\v 13 ونِّي غَارْ دْجَانْ إِمزُّوغنْ، أجّْ إِ-ث أَذْ إِسڒْ مِينْ إِقَّارْ أَرُّوحْ إِ ثْمسْمُونِينْ.‘ “
\b
\m 
\v 14 \bd أَرِي إِ لْمَالَاكْ ن ثْمسْمُونْثْ ن لَايُوذِيكِييَا\bd*
\m ”أَمُّو إِ إِقَّارْ ونِّي ذ أَمِينْ، أَشهَّاذْ أَمْثِيقِّي ذ ثِيذتّْ، ونِّي ذ بدُّو ن مَارَّا مِينْ د-إِخْڒقْ أَربِّي: \x ◘ \xo 3:‏14 \xt كُول. 1‏:‏15؛ أَسَا. 1‏:‏5، 6. \x*
\m 
\v 15 ’نشّْ سّْنغْ ڒخْذَايمْ نّشْ، أَقَا شكْ وَارْ ثسْمِيضذْ وَارْ ثحْمِيذْ. معْلِيكْ بعْذَا ثْسمْضذْ نِيغْ ثحْمِيذْ!
\v 16 س ؤُينِّي، ؤُمِي شكْ ثمْڒُوذذْ، وَارْ ثحْمِيذْ، وَارْ ثسْمِيضذْ، أَذْ شكْ عُوقّغْ زڭْ ؤُقمُّومْ إِنُو.
\v 17 مِينْزِي شكْ ثقَّارذْ: نشّْ غَارِي أَڭْڒَا ؤُشَا إِمَّارْنِي-د غَارِي وَاڭْڒَا، وَارْ ذ أَيِي إِتّْخصِّي وَالُو، \add أَمْ\add* وَارْ ثسِّينذْ شَا بلِّي أَقَا شكْ ثْحڒْشذْ ؤُ ذَايكْ ڒغْبنْ ذ زّڒْضْ ؤُ أَقَا شكْ ذ أَذَارْغَاڒْ ذ أَعَارْيَانْ،
\v 18 أَذْ شكْ نصْحغْ مَاحنْذْ أَذْ خَافِي ثسْغذْ وُورغْ إِقُّورنْ، إِكِّينْ ثِيمسِّي، حِيمَا أَذْ ثْذوْڒذْ ذ بُو-وَاڭْڒَا، ؤُڒَا ذ أَرُّوضْ ذ أَشمْڒَاڒْ، حِيمَا أَذْ ث ثْيَارْضذْ ؤُ وَارْ ثقِّيمْ ثْضهَّارْ عَاذْ ڒفْضِيحثْ ن ثُوعَّارْينْثْ نّشْ. ؤُ ذْهنْ \add عَاوذْ\add* دّْهنْ خْ ثِيطَّاوِينْ نّشْ مَاحنْذْ أَذْ ثَافْ ثتّْوَاڒِيذْ. \x ◘ \xo 3:‏18 \xt 2 كُور. 5‏:‏3؛ أَسَا. 7‏:‏13؛ 16‏:‏15؛ 19‏:‏8. \x*
\v 19 مَارَّا ونِّي سّْعِيزّغْ، تّْوبّْخغْ ث ؤُ أَربِّيغْ ث. خنِّي شْضَارْ، ثُوبْ! \x ◘ \xo 3:‏19 \xt أَيُوبْ 5‏:‏17؛ أَوڒن. 3‏:‏12؛ عبر. 12‏:‏5. \x*
\v 20 أَقَا ذَا، نشّْ بدّغْ غَارْ ثوَّارْثْ، سّْقَارْقُوبغْ-د. مَاڒَا إِسْڒَا حذْ إِ ثْمِيجَّا إِنُو، أَذْ يَارْزمْ ثَاوَّارْثْ، نشّْ أَذْ غَارسْ أَذْفغْ ؤُشَا أَذْ كِيسْ مُّونسْوغْ ذ نتَّا أَكِيذِي.
\m 
\v 21 ونِّي إِ غَا إِغلّْبنْ أَذْ أَسْ وْشغْ، حِيمَا أَذْ إِقِّيمْ أَكِيذِي خْ ڒْعَارْشْ إِنُو، أَمْ نشّْغلّْبغْ ؤُشَا قِّيمغْ أَكْ-ذ بَابَا خْ ڒْعَارْشْ نّسْ. \x ◘ \xo 3:‏21 \xt مت. 19‏:‏28؛ 1 كُور. 6‏:‏2. \x*
\m 
\v 22 ونِّي غَارْ دْجَانْ إِمزُّوغنْ، أجّْ إِ-ث أَذْ إِسڒْ مِينْ إِقَّارْ أَرُّوحْ إِ ثْمسْمُونِينْ.‘ “ *
\b
\b
\c 4
\s1 ڒْعَارْشْ ذڭْ ؤُجنَّا
\m 
\v 1 أَوَارْنِي مَانْ أَيَا، خْزَارْ، إِشْثْ ن ثوَّارْثْ ثنُّورْزمْ ذڭْ ؤُجنَّا. ؤُشَا ثْمِيجَّا إِ سْڒِيغْ أَكِيذِي د-إِسَّاوَاڒنْ أَمْ يِيجّْ ن \bd ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي\bd*، ثنَّا: ”ڭعّذْ ذَا، \add خنِّي\add* نشّْ أَذْ أَشْ سّشْنغْ مِينْ ڭُّورْ أَذْ إِمْسَارْ أَوَارْنِي مَانْ أَيَا.“
\m 
\v 2 ڒخْذنِّي إِرحّفْ أَيِي-د أَرُّوحْ، ؤُ خْزَارْ، إِجّْ ن ڒْعَارْشْ إِبدّْ ذڭْ ؤُجنَّا، ثُوغَا نتَّا إِقِّيمْ خَاسْ.
\v 3 ؤُ ثِيفْرَاسْ ن ونِّي \add خَاسْ\add* إِقِّيمنْ أَمْ \add وژْرُو ن\add* يَاسْبِيسْ ذ سَارْذِييُوسْ، ؤُشَا ثَاسْڒِيثْ ن ونْژَارْ ن إِسيْنُوثنْ إِ-د-إِتّنّْضنْ إِ ڒْعَارْشْ إِضْهَارْ أَمْ \add وژْرُو ن\add* سْمَارَاخْثْ.
\m 
\v 4 قُووَّارنْ أَسْ إِ ڒْعَارْشْ أَربْعَا ؤُ عِيشْرِينْ ن ڒكْرَاسِي إِڭلّْذنْ ؤُشَا أَربْعَا ؤُ-عِيشْرِينْ ن إِمْغَارنْ ثُوغَا قِّيمنْ خْ ڒكْرَاسِي إِڭلّْذنْ، أَرْضنْ أَرُّوضْ ذ أَشمْڒَاڒْ، غَارْسنْ خْ ؤُزدْجِيفْ تِّيجَانْ ن وُورغْ.
\m 
\v 5 ؤُشَا زِي ڒْعَارْشْ نِّي تّفّْغنْ-د زَّايسْ وَاجَّاجنْ ذ أَسَّامنْ ذ ثْمِيجَّاوِينْ. زَّاثْ إِ ڒْعَارْشْ أَرقّنْ سبْعَا ن إِصفْضَاونْ، ثِينَا ذ سبْعَا ن أَرُّوحَاثْ ن أَربِّي.
\m 
\v 6 غَارْ زَّاثْ ن ڒْعَارْشْ ثُوغَا ذِينْ إِجّْ ن ڒبْحَارْ ن زَّاجْ، إِڭَّا أَمْ أَكْرِيسْثَالْ. ذِي ڒْوسْطْ ن ڒْعَارْشْ ذ مِينْ ذ أَسْ د-إِنّْضنْ ثُوغَا ذِينْ أَربْعَا ن إِمُودَّارنْ،عمَّارنْ س ثِيطَّاوِينْ مَارَّا غَارْ زَّاثْ ذ ضفَّارْ. \x ◘ \xo 4:‏6 \xt ؤُف. 24‏:‏10؛ أَسَا. 15‏:‏2. \x*
\v 7 أَمُودَّارْ أَمزْوَارُو يَارْوسْ ذڭْ وَايْرَاذْ، أَمدَّارْ وِيسّْ ثْنَاينْ يَارْوسْ ذڭْ ؤُعجْمِي، أَمدَّارْ وِيسّْ ثْڒَاثَا ثُوغَا أَغمْبُوبْ نّسْ أَخْمِي ن بْنَاذمْ ؤُشَا أَمُودَّارْ وِيسّْ أَربْعَا يَارْوسْ ذڭْ ؤُڭِيذرْ إِطَّاونْ.
\v 8 كُوڒْ إِجّنْ زِي أَربْعَا ن إِمُودَّارنْ ثُوغَا إِبدّْ، تّفّْغنْ-د زڭْ وَاشَّارنْ نّسْ ذ سنّجْ ستَّا ن وَافْرِيونْ إِ د أَسْ د-إِنّْضنْ،عمَّارنْ س ثِيطَّاوِينْ غَارْ ذَاخڒْ. نِيثْنِي وَارْ ژْرِينْ أَرَّاحثْ أَسّْ ذ دْجِيڒثْ، نَّانْ:
\b
\m \qt ”أَمْقدَّاسْ، أَمْقدَّاسْ،\qt*
\m \qt أَمْقدَّاسْ ذ سِيذِي أَربِّي،\qt*
\m \qt أَمْزمَّارْ خْ كُوڒْشِي\qt*
\m \qt ذ ونِّي ثُوغَا، ذ ونِّي إِدْجَانْ،\qt*
\m \qt ذ ونِّي د غَا يَاسنْ.“\qt* \x ◘ \xo 4:‏8 \xt إِشا. 6‏:‏3؛ أَسَا. 1‏:‏4، 8؛ 11‏:‏17؛ 16‏:‏5. \x*
\b
\m 
\v 9 ؤُشَا خْمِي غَا وْشنْ أَربْعَا ن إِمُودَّارنْ أَعُودْجِي ذ شَّانْ ذ ؤُقَاذِي إِ ونِّي إِقِّيمنْ خْ ڒْعَارْشْ، ذ ونِّي إِدَّارنْ إِ ڒبْذَا قَاعْ - ”أَمِينْ!“ -
\v 10 \add خنِّي\add* أَربْعَا ؤُ عِيشْرِينْ ن إِمْغَارنْ وْضَانْ غَارْ ثمُّورْثْ غَارْ زَّاثْ ن ونِّي إِقِّيمنْ خْ ڒْعَارْشْ، سجْذنْ إِ ونِّي إِدَّارنْ إِ ڒبْذَا قَاعْ - ”أَمِينْ!“ - ؤُشَا سَّارْسنْ تِّيجَانْ نْسنْ غَارْ زَّاثْ إِ ڒْعَارْشْ، نَّانْ:
\b
\m 
\v 11 \qt ”شكْ، أَ سِيذِيثْنغْ ذ أَربِّي نّغْ،\qt*
\m \qt ثسْذَاهدْجذْ أَذْ ثكْسِيذْ\qt*
\m \qt أَعُودْجِي ذ شَّانْ ذ جّهْذْ،\qt*
\m \qt مَاغَارْ شكْ ذ ونِّي إِڭِّينْ مَارَّا ثِيمسْڒَايِينْ-أَ،\qt*
\m \qt ؤُ أَقَا أَثنْثْ ذِينْ\qt*
\m \qt ؤُ تّْوَاخڒْقنْثْ س ڒْخَاضَارْ نّشْ!“\qt* \x ◘ \xo 4:‏11 \xt أَسَا. 5‏:‏12. \x*
\b
\b
\c 5
\s1 أَذْلِيسْ إِتّْوَانّْضنْ ذ يزْمَارْ
\m 
\v 1 ؤُشَا ژْرِيغْ غَارْ ؤُفُوسْ أَفُوسِي ن ونِّي إِقِّيمنْ خْ ڒْعَارْشْ إِجّْ ن وذْلِيسْ \add إِتّْوَانْضنْ\add*، ثُوغَا خَاسْ ثِيرَا غَارْ ذَاخڒْ ذ بَارَّا، ؤُشَا \add أَذْلِيسْ\add* ثُوغَا إِتّْوَاشمّعْ س سبْعَا ن إِشمِّيعنْ. \x ◘ \xo 5:‏1 \xt حِز. 2‏:‏10. \x*
\v 2 ؤُشَا ژْرِيغْ إِجّْ ن لْمَالَاكْ إِجْهذْ نّغْنِي، إِتّْڒَاغَا س جّهْذْ:
\b
\m \qt ”مَانْ ونْ إِسْذَاهدْجنْ أَذْ يَارْزمْ\qt*
\m \qt أَذْلِيسْ-أَ \tl إِتّْوَانّْضنْ\tl*\qt*،
\m \qt ؤُشَا أَذْ إِكّسْ إِشمِّيعنْ نّسْ؟“\qt*
\b
\m 
\v 3 ؤُشَا ؤُڒَا ذ إِجّْ ذڭْ ؤُجنَّا نِيغْ ذِي ثمُّورْثْ نِيغْ سَاذُو ثمُّورْثْ إِزمَّارْ أَذْ يَارْزمْ أَذْلِيسْ-أَ \add إِتّْوَانّْضنْ\add* ؤُ أَذْ إِكّسْ إِشمِّيعنْ نّسْ، أَذْ ذَايسْ إِخْزَارْ. \x ◘ \xo 5:‏3 \xt فِيل. 2‏:‏10؛ أَسَا. 5‏:‏13. \x*
\v 4 نشّْ رُوغْ أَطَّاسْ ؤُمِي وَارْ ؤُفِينْ وِي إِسْذَاهدْجنْ أَذْ يَارْزمْ أَذْلِيسْ-أَ \add إِتّْوَانّْضنْ\add* ؤُ أَذْ يَارْزمْ إِشمِّيعنْ نّسْ.
\v 5 إِجّنْ زڭْ إِمْغَارنْ إِنَّا أَيِي: ”وَارْ تّْرُو شَا! خْزَارْ، أَيْرَاذْ زِي ثقْبِيتْشْ ن يَاهُوذَا، أَژْوَارْ ن ذَاوُوذْ، أَقَا إِغلّبْ، حِيمَا أَذْ يَارْزمْ أَذْلِيسْ-أَ \add إِتّْوَانّْضنْ\add* ذ إِشمِّيعنْ نّسْ.“ \x ◘ \xo 5:‏5 \xt أَمز. 49‏:‏9، 10؛ إِشا. 11‏:‏10؛ رُوم. 15‏:‏12؛ أَسَا. 22‏:‏16. \x*
\m 
\v 6 ؤُشَا ژْرِيغْ ذِي ڒْوسْطْ ن ڒْعَارْشْ ذ أَربْعَا ن إِمُودَّارنْ ؤُشَا ذِي ڒْوسْطْ ن إِمْغَارنْ، إِجّْ ن إِزْمَارْ إِبدّْ، إِڭَّا أَخْمِي ذ ثَاغَارْصْثْ. نتَّا غَارسْ سبْعَا ن وَاشَّاونْ ذ سبْعَا ن ثِيطَّاوِينْ، نِيثْنِي ذ سبْعَا ن أَرُّوحَاثْ ن أَربِّي إِنِّي د-إِتّْوَاسّكّنْ غَارْ دُّونشْثْ ثْمُونْ. \f ◼ \fr 5:‏6 \ft \bd ’دُّونشْثْ‘\bd* - س ثْعِيبْرَانِيثْ ’ثمُّورْثْ‘.\f*  \x ◘ \xo 5:‏6 \xt زَاك. 3‏:‏9؛ 4‏:‏10؛ أَسَا. 4‏:‏5. \x*
\v 7 أَقَا نتَّا يُوسَا-د ؤُشَا إِكْسِي أَذْلِيسْ \add إِتّْوَانّْضنْ\add* زڭْ ؤُفُوسْ ن ونِّي إِقِّيمنْ خْ ڒْعَارْشْ.
\m 
\v 8 أَڒَامِي إِطّفْ أَذْلِيسْ \add إِتّْوَانّْضنْ\add*، وْضَانْ-د أَربْعَا ن إِمُودَّارنْ ذ أَربْعَا ؤُ-عِيشْرِينْ ن إِمْغَارنْ غَارْ ثمُّورْثْ زَّاثْ إِ يزْمَارْ. نِيثْنِي مَارَّا إِذْسنْ غَارْسنْ إِشْثْ ن لهَارْپَا ذ إِجّْ ن طّبْصِي ن وُورغْ إِشُّورْ س ڒبْخُورْ: مَانْ أَيَا ذ ثِيژَادْجِيثِينْ ن إِمْقدَّاسنْ. \x ◘ \xo 5:‏8 \xt إِزهد. 141‏:‏2؛ أَسَا. 14‏:‏2. \x*
\v 9 ؤُشَا تّْغنَّاجنْ إِجّْ ن إِزْڒِي ن جْذِيذْ، قَّارنْ:
\b
\m \qt ”شكْ ثسْذَاهدْجذْ\qt*
\m \qt أَذْ ثكْسِيذْ أَذْلِيسْ \tl إِتّْوَانّْضنْ\tl*،\qt*
\m \qt أَذْ ثكّْسذْ إِشمِّيعنْ نّسْ،\qt*
\m \qt مِينْزِي شكْ ثتّْوَاغَارْصذْ\qt*
\m \qt ؤُشَا س إِذَامّنْ نّشْ\qt*
\m \qt ثسْغِيذْ أَنغْ إِ أَربِّي،\qt*
\m \qt زِي كُوڒْ ثَاقْبِيتْشْ ذ ڒْڭنْسْ ذ شّعْبْ.“\qt* \x ◘ \xo 5:‏9 \xt ڒخ. 20‏:‏28؛ أَفا. 1‏:‏7؛ كُول. 1‏:‏14؛ عبر. 9‏:‏12؛ 10‏:‏10؛ 1 بُط. 1‏:‏19؛ 1 يُوح. 1‏:‏7؛ أَسَا. 4‏:‏11. \x*
\m 
\v 10 \qt “شكْ ثَارِّيذْ ثنْ ذ إِشْثْ ن ثْڭلْذَا\qt*
\m \qt ن إِكهَّاننْ ذ إِجدْجِيذنْ\qt*
\m \qt إِ أَربِّي نّغْ،\qt*
\m \qt ؤُ نِيثْنِي أَذْ حكْمنْ\qt*
\m \qt \tl أَمْ إِجدْجِيذنْ\tl* خْ ثمُّورْثْ.“\qt* \x ◘ \xo 5:‏10 \xt ؤُف. 19‏:‏6؛ 1 بُط. 2‏:‏5، 9؛ أَسَا. 1‏:‏6. \x*
\b
\m 
\v 11 خنِّي ژْرِيغْ، ؤُشَا سْڒِيغْ ثْمِيجَّا ن وَاطَّاسْ ن لْمَالَاكَاثْ نّْضنْثْ إِ ڒْعَارْشْ ؤُڒَا ن إِمُودَّارنْ ذ إِمْغَارنْ، ؤُشَا ثُوغَا أَثنْثْعشْرَا-أَڒَافْ ذِيعشْرَا ن ڒُوڒُوفْ ؤُ أَڒَافْ ذِي ڒُوڒُوفْ، \x ◘ \xo 5:‏11 \xt دَان. 7‏:‏10؛ عبر. 12‏:‏22. \x*
\v 12 قَّارنْ س ثْمِيجَّا إِجهْذنْ:
\b
\m \qt ”إِزْمَارْ نِّي إِتّْوَاغَارْصنْ\qt*
\m \qt إِسْذَاهدْجْ أَذْ إِطّفْ\qt*
\m \qt صُّولْطَا ذ وَاڭْڒَا ذ ثِيغِيثْ،\qt*
\m \qt ذ جّهْذْ ذ شَّانْ ذ ؤُعُودْجِي،\qt*
\m \qt ذ لْبَارَاكَا!“\qt* \x ◘ \xo 5:‏12 \xt أَسَا. 4‏:‏11. \x*
\b
\m 
\v 13 ؤُشَا كُوڒْ إِجّْ إِ د-إِخڒْقنْ ذڭْ ؤُجنَّا ؤُ خْ ثمُّورْثْ ذ سَاذُو ثمُّورْثْ ؤُ خْ ڒبْحَارْ، \add وَاهْ،\add* قَاعْ مِينْ إِدْجَانْ ذَايْسنْ، سْڒِيغْ أَسنْ، قَّارنْ:
\b
\m \qt ”لْبَارَاكَا ذ شَّانْ ذ ؤُعُودْجِي ذ صُّولْطَا\qt*
\m \qt أَذْ إِڒِينْ إِ ونِّي إِقِّيمنْ خْ ڒْعَارْشْ\qt*
\m \qt ؤُ إِ يزْمَارْ إِ ڒبْذَا قَاعْ!“\qt*
\b
\m 
\v 14 ؤُشَا ؤُمِي أَربْعَا ن إِمُودَّارنْ نَّانْ: ”أَمِينْ!“، وْضَانْ إِمْغَارنْ غَارْ ثمُّورْثْ، سجْذنْ.
\b
\b
\c 6
\s1 سبْعَا ن إِشمِّيعنْ
\m 
\v 1 ؤُشَا ژْرِيغْ ؤُمِي إِزْمَارْ إِفْسِي \bd إِجّنْ زِي سبْعَا ن إِشمِّيعنْ\bd*، ؤُشَا سْڒِيغْ إِ يِيجّنْ زِي أَربْعَا ن إِمُودَّارنْ إِقَّارْ س ثْمِيجَّا أَمْ وَاجَّاجْ: ”أَسْ-د، خْزَارْ!“
\v 2 خنِّي سْڒِيغْ ؤُ ژْرِيغْ، ؤُ خْزَارْ إِجّْ ن \bd ؤُيِيسْ ذ أَشمْڒَاڒْ\bd*، ذ ونِّي خَاسْ إِنْيِينْ غَارسْ إِجّْ ن ڒْقوْصْ \add ن فْڒِيثْشَا\add* ؤُشَا إِمّوْشْ أَسْ إِجّْ ن تَّاجْ ؤُشَا إِفّغْ-د، إِغْڒبْ، إِتّْغلَّابْ، ؤُ مَاحنْذْ أَذْ إِغْڒبْ. \x ◘ \xo 6:‏2 \xt أَسَا. 19‏:‏11. \x*
\m 
\v 3 أَڒَامِي يَارْزمْ \bd أَشمِّيعْ وِيسّْ ثْنَاينْ\bd*، سْڒِيغْ إِ ؤُمُودَّارْ وِيسّْ ثْنَاينْ، إِقَّارْ: ”أَسْ-د!“
\v 4 ؤُشَا إِفّغْ-د إِجّْ ن \bd ؤُيِيسْ ذ أَزڭّْوَاغْ\bd*، ؤُشَا ونِّي خَاسْ إِنْيِينْ، ڭِّينْ ث حِيمَا أَذْ إِكّسْ ڒهْنَا خْ ثمُّورْثْ، حِيمَا أَذْ كَّارنْ إِوْذَانْ أَذْ غَارْصنْ إِ وَايَاوْيَا ؤُشَا إِمّوْشْ أَسْ إِجّْ ن سِّيفْ إِمْغَارْ.
\m 
\v 5 أَڒَامِي يَارْزمْ \bd أَشمِّيعْ وِيسّْ ثْڒَاثَا\bd*، سْڒِيغْ إِ ؤُمُودَّارْ وِيسّْ ثْڒَاثَا إِقَّارْ: ”أَسْ-د!“ خْزَارْ، إِجّْ ن \bd ؤُيِيسْ ذ أَبَارْشَانْ\bd*، ذ ونِّي خَاسْ إِنْيِينْ غَارسْ إِجّْ ن ڒْمِيزَانْ ذڭْ إِفَاسّنْ نّسْ.
\v 6 زِي ڒْوسْطْ ن إِمُودَّارنْ سْڒِيغْ إِ يِيشْثْ ن ثْمِيجَّا ثقَّارْ: ”إِجّْ ن ڒْمُوذْ ن يِيرْذنْ س يِيجّْ ن ذِينَارْ ؤُ ثْڒَاثَا ن ڒمْذُوذْ ن إِمنْذِي س يِيجّْ ن ذِينَارْ، ؤُ زّشْثْ ذ بِينُو وَارْ ثنْ تّْضِييِّيعمْ شَا!“ \x ◘ \xo 6:‏6 \xt أَسَا. 9‏:‏4. \x*
\m 
\v 7 أَڒَامِي يَارْزمْ \bd أَشمِّيعْ وِيسّْ أَربْعَا\bd*، سْڒِيغْ إِ ثْمِيجَّا ن ؤُمُودَّارْ \add وِيسّْ أَربْعَا\add* ثقَّارْ: ”أَسْ-د!“
\v 8 ؤُشَا ژْرِيغْ إِجّْ ن \bd ؤُيِيسْ ذ أَسْنَابِي\bd*، ذ ونِّي خَاسْ إِنْيِينْ، قَّارنْ أَسْ ’ڒْموْثْ‘، ؤُشَا ثضْفَارْ إِ-ث ڒَاخَارْثْ. ثمّوْشْ أَسْ صُّولْطَا خْ إِجّْ ن أَرْبعْ ن ثمُّورْثْ حِيمَا أَذْ نْغنْ س سِّيفْ، س ڒَاژْ، س ڒْموْثْ ؤُ س ڒوْحُوشْ ن ثمُّورْثْ. \f ◼ \fr 6:‏8 \ft \bd ’أَسْنَابِي‘\bd* - إِخْسْ أَذْ يِينِي ’أَوْرَاغْ أَشحْشَاحْ‘ نِيغْ ’أَوْرَاغْ أَذَارْذَاسْ‘.\f*
\m 
\v 9 أَڒَامِي يَارْزمْ \bd أَشمِّيعْ وِيسّْ خمْسَا\bd*، ژْرِيغْ سَاذُو ؤُعَالْطَارْ ڒعْمُورْ ن يِينِّي إِتّْوَانْغنْ ذِي طّْوعْ ن وَاوَاڒْ ن أَربِّي ؤُ ذِي طّْوعْ ن شّْهَاذثْ ن يَاسُوع إِ ثُوغَا غَارْسنْ. \x ◘ \xo 6:‏9 \xt أَسَا. 19‏:‏10؛ 20‏:‏4. \x*
\v 10 نِيثْنِي ڒَاغَانْ س جّهْذْ، نَّانْ: ”\add أَ\add* سِيذِي، \add أَ\add* أَمْقدَّاسْ ذ بَابْ ن ثِيذتّْ، مشْحَاڒْ إِ غَا ثقِّيمذْ وَارْ ثْحكّْمذْ، وَارْ ثتّْنقْمذْ شَا إِ إِذَامّنْ نّغْ زڭْ إِنِّي إِزدّْغنْ ذِي ثمُّورْثْ؟“
\v 11 ؤُشَا وْشِينْ إِ كُوڒْ إِجّنْ زَّايْسنْ ڒعْبَايَاثْ ذ ثِيشمْڒَاڒِينْ، ؤُ إِتّْوَانَّا أَسنْ بلِّي أَذْ أَريّْحنْ ذْرُوسْ ن ڒْوقْثْ أَڒْ غَا إِكمّڒْ لْعَاذَاذْ ن إِمْسخَّارنْ إِمْعَاشَارنْ نْسنْ ذ وَاوْمَاثنْ نْسنْ، إِنِّي إِ غَا إِتّْوَانْغنْ عَاوذْ أَمْ نِيثْنِي.
\m 
\v 12 ؤُشَا ژْرِيغْ أَڒَامِي يَارْزمْ \bd أَشمِّيعْ وِيسّْ ستَّا\bd*، أَقَا إِمْسَارْ إِجّْ ن ونْهزِّي ن ثمُّورْثْ ذ أَمقّْرَانْ ؤُ ثَافُوشْثْ ثذْوڒْ ذ ثَابَارْشَانْثْ أَمشْنَاوْ إِشْثْ ن ثْخَانْشثْ ن وشْضَانْ ؤُشَا ثَازِيرِي ثْمُونْ ثڭَّا أَمشْنَاوْ إِذَامّنْ، \x ◘ \xo 6:‏12 \xt ڒخ. 2‏:‏20. \x*
\v 13 ؤُشَا إِثْرَانْ ن ؤُجنَّا وْضَانْ-د غَارْ ثمُّورْثْ أَمْ وَارْثُو إِمّنْضَارْ إِقُورَّاعْ نّسْ خْمِي ث-إِ-د-إِغطّڒْ إِجّْ ن ؤُسمِّيضْ ذ أَمقّْرَانْ. \f ◼ \fr 6:‏13 \ft \bd ’إِثْرَانْ ن ؤُجنَّا‘\bd* - إِخْسْ أَذْ يِينِي لْمَالَاكَاثْ إِنِّي إِوْضَانْ أَكْ-ذ شِّيطَانْ. خْزَارْ أَسَا. 12:4، 9.\f*
\v 14 إِتّْوَافدْجْقنْ إِجنْوَانْ ؤُشَا تّْوَانْضنْ نِيثْنِي أَمْ مَامّشْ \add نّضنْ\add* إِذْلِيسنْ. ؤُشَا كُوڒْ أَذْرَارْ ذ مَارَّا ثِيڭْزِيرِينْ تّْوَاكّْسنْ زڭْ إِمُوشَانْ نْسنْ.
\v 15 إِجدْجِيذنْ ن ثمُّورْثْ ذ إِمقّْرَاننْ ذ يِينِّي ذ إِزدْجِيفنْ خْ وَاڒفْ ذ أَيْثْبَابْ ن وَاڭْڒَا ذ يِينِّي غَارْ ثدْجَا صُّولْطَا ذ كُوڒْ إِسْمغْ ذ أَحُورِّي، أَقَا نِيثْنِي \add مَارَّا\add* سّْنُوفَّارنْ إِخفْ نْسنْ ذڭْ إِفْرَانْ ؤُ جَارْ ڒجْرُوفْ ن إِذُورَارْ، \x ◘ \xo 6:‏15 \xt إِشا. 2‏:‏20\x*
\v 16 نَّانْ إِ إِذُورَارْ ذ ڒجْرُوفْ: ”وْضَامْ-د خَانغْ، فَّارمْ أَنغْ زڭْ وُوذمْ ن إِزْمَارْ، \x ◘ \xo 6:‏16 \xt إِشا. 2‏:‏17‏-‏21؛ حُوش. 10‏:‏8؛ لك. 23‏:‏30؛ أَسَا. 9‏:‏6. \x*
\v 17 مِينْزِي أَسّْ أَمقّْرَانْ ن وغْضَابْ نّسْ أَقَا يُوسَا-د، مَانْ ونْ إِزمَّارنْ أَذْ إِقِّيمْ إِبدّْ!“ \x ◘ \xo 6:‏17 \xt يُووِ. 2‏:‏10، 31؛ 3‏:‏15؛ إِشا. 13‏:‏6‏-‏13؛ 24‏:‏23؛ Am. 8‏:‏9؛ مت. 24‏:‏29؛ ڒخ. 2‏:‏20؛ أَسَا. 6‏:‏12‏-‏13\x*
\b
\b
\c 7
\s1 أَشمِّيعْ ن أَربِّي إِدَّارنْ
\m 
\v 1 أَوَارْنِي مَانْ أَيَا ژْرِيغْ أَربْعَا ن لْمَالَاكَاثْ بدّنْثْ غَارْ أَربْعَا ن ثْغمُّورَا ن ثمُّورْثْ، طّْفنْثْ أَربْعَا ن إِسمِّيضنْ ن ثمُّورْثْ، حِيمَا وَارْ إِتّْسُوضِي ؤُسمِّيضْ ڒَا خْ ڒْبَارّْ ڒَا خْ وَامَانْ ؤُڒَا خْ شَا ن ثْشجَّارْثْ. \f ◼ \fr 7:‏1 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*
\v 2 ؤُشَا ژْرِيغْ إِجّْ ن لْمَالَاكْ نّغْنِي يُوڒِي-د مَانِيسْ ذ ثْنقَّارْ ثْفُوشْثْ، أَقَا غَارسْ أَشمِّيعْ ن أَربِّي إِدَّارنْ ؤُشَا إِڒَاغَا س جّهْذْ إِ أَربْعَا ن لْمَالَاكَاثْ نِّي ؤُمِي ثمّوْشْ ثْزمَّارْ حِيمَا أَذْ سّخْسَارنْثْ ثَامُّورْثْ ذ ڒبْحَارْ، \x ◘ \xo 7:‏2 \xt يُوح. 6‏:‏26؛ أَسَا. 9‏:‏4.\x*
\v 3 إِقَّارْ: ”وَارْ تّْسخْسَارمْ ثَامُّورْثْ ؤُڒَا ذ ڒبْحَارْ ؤُڒَا ذ ثِيشجُّورَا أَڒْ غَا نڭّْ أَشمِّيعْ خْ ثنْيَارِينْ ن إِمْسخَّارنْ ن أَربِّي نّغْ.“
\m 
\v 4 ؤُشَا سْڒِيغْ ڒْقدّْ ن يِينِّي إِتّْوَاشمّْعنْ، مْيَا ؤُ-أَربْعَا ؤُ-ربْعِينْ-أَڒفْ أَقَا تّْوَاشمّْعنْ زِي مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل: \x ◘ \xo 7:‏4 \xt أَسَا. 14‏:‏1. \x*
\b
\m 
\v 5 ثنْعَاشْ-أَڒفْ زِي ثقْبِيتْشْ ن يَاهُوذَا،
\m ثنْعَاشْ-أَڒفْ زِي ثقْبِيتْشْ ن رُوبِينْ،
\m ثنْعَاشْ-أَڒفْ زِي ثقْبِيتْشْ ن جَاذْ،
\m 
\v 6 ثنْعَاشْ-أَڒفْ زِي ثقْبِيتْشْ ن أَشِيرْ،
\m ثنْعَاشْ-أَڒفْ زِي ثقْبِيتْشْ ن نَافْثَالِي،
\m ثنْعَاشْ-أَڒفْ زِي ثقْبِيتْشْ ن مَانَاسَّا،
\m 
\v 7 ثنْعَاشْ-أَڒفْ زِي ثقْبِيتْشْ ن شِيمْعُونْ،
\m ثنْعَاشْ-أَڒفْ زِي ثقْبِيتْشْ ن إِسَّاكَارْ،
\m ثنْعَاشْ-أَڒفْ زِي ثقْبِيتْشْ ن لَاوِي،
\m 
\v 8 ثنْعَاشْ-أَڒفْ زِي ثقْبِيتْشْ ن زِيبُولُونْ،
\m ثنْعَاشْ-أَڒفْ زِي ثقْبِيتْشْ ن يُوسُوفْ،
\m ثنْعَاشْ-أَڒفْ زِي ثقْبِيتْشْ ن بِينْيَامِينْ.
\b
\s1 ڒْغَاشِي أَمقّْرَانْ زِي ڒڭْنُوسْ
\m 
\v 9 أَوَارْنِي مَانْ أَيَا أَقَا ژْرِيغْ إِجّْ ن ؤُبَارُّو ن ڒْغَاشِي أَمقّْرَانْ إِ وَارْ إِزمَّارْ ؤُڒَا ذ إِجّْ أَذْ ث إِحْسبْ، زِي كُوڒْ ڒْڭنْسْ ذ ثقْبِيتْشْ ؤُ \add زِي مَارَّا\add* شُّوعُوبْ ذ إِڒْسَاونْ. نِيثْنِي بدّنْ زَّاثْ إِ ڒْعَارْشْ ذ يزْمَارْ، أَرْضنْ ڒعْبَايَاثْ ثِيزِيرَارِينْ ذ ثِيشمْڒَاڒِينْ، ؤُشَا غَارْسنْ ثِيسضْوِينْ ن ثِينِي ذڭْ إِفَاسّنْ نْسنْ،
\v 10 تّْڒَاغَانْ س جّهْذْ:
\b
\m \qt ”أَسنْجمْ أَقَا س أَربِّي نّغْ،\qt*
\m \qt ونِّي إِقِّيمنْ خْ ڒْعَارْشْ\qt*
\m \qt ؤُ س يزْمَارْ.“\qt*
\b
\m 
\v 11 ؤُشَا مَارَّا لْمَالَاكَاثْ ثُوغَا بدّنْثْ نّْضنْثْ إِ ڒْعَارْشْ أَكْ-ذ إِمْغَارنْ ذ أَربْعَا ن إِمُودَّارنْ، وْضَانْ غَارْ ثمُّورْثْ س وُوذْمَاونْ نْسنْ قِيبَاتْشْ إِ ڒْعَارْشْ،
\v 12 قَّارنْ
\b
\m \qt ”أَمِينْ!\qt*
\m \qt أَعُودْجِي ذ لْبَارَاكَا\qt*
\m \qt ذ ثِيغِيثْ ذ ؤُقَاذِي\qt*
\m \qt ذ شَّانْ ذ صُّولْطَا ذ جّهْذْ\qt*
\m \qt أَقَا-ثنْ إِ أَربِّي نّغْ\qt*
\m \qt إِ ڒبْذَا قَاعْ.\qt*
\m \qt أَمِينْ!“\qt*
\b
\m 
\v 13 إِطّفْ إِجّنْ زڭْ إِمْغَارنْ نِّي ذڭْ وَاوَاڒْ، إِنَّا أَيِي: ”مِينْ عْنَانْ إِنَا، إِنِّي يَارْضنْ ڒعْبَايَاثْ ثِيشمْڒَاڒِينْ، مِينْ عْنَانْ ؤُ مَانِيسْ د-ؤُسِينْ؟“
\v 14 نشّْ نِّيغْ أَسْ: ”أَ سِيذِي، شكْ إِ إِسّْننْ.“ إِنَّا أَيِي: ”إِنَا أَقَا ؤُسِينْ-د زِي ڒْمحْنثْ ثَامقّْرَانْثْ. أَقَا نِيثْنِي سِيزْذِيڭنْ ڒعْبَايَاثْ نْسنْ ؤُشَا أَرِّينْ ثنْثْ ذ ثِيشمْڒَاڒِينْ ذڭْ إِذَامّنْ ن إِزْمَارْ.
\v 15 س ؤُينِّي بدّنْ نِيثْنِي زَّاثْ إِ ڒْعَارْشْ ن أَربِّي ؤُشَا سخَّارنْ أَسْ أَسّْ ذ دْجِيڒثْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ، ؤُشَا ونِّي إِقِّيمنْ خْ ڒْعَارْشْ أَذْ خَاسنْ إِوّثْ \add أَقِيضُونْ نّسْ\add*.
\v 16 وَارْ إِقِّيمْ عَاذْ أَذْ دْجَاژنْ نِيغْ أَذْ فَّاذنْ، وَارْ ثنْ ثتّْقذِّي ؤُڒَا ذ ثَافُوشْثْ ؤُڒَا ذ إِشْثْ ن جُّورّثْ ن ڒحْمُو، \x ◘ \xo 7:‏16 \xt إِشا. 49‏:‏10. \x*
\v 17 مِينْزِي إِزْمَارْ نِّي إِدْجَانْ ذِي ڒْوسْطْ ن ڒْعَارْشْ أَذْ ثنْ يَارْوسْ، أَذْ ثنْ إِنْذهْ غَارْ ثُوذَارْثْ ؤُ غَارْ ثَاڒَاوِينْ ن وَامَانْ، ؤُشَا نتَّا أَذْ أَسنْ إِمْسحْ كُوڒْ أَمطَّا زِي ثِيطَّاوِينْ نْسنْ.“ \x ◘ \xo 7:‏17 \xt إِشا. 25‏:‏8؛ إِزهد. 23‏:‏1؛ أَسَا. 21‏:‏4. \x*
\b
\b
\c 8
\s1 أَشمِّيعْ وِيسّْ سبْعَا
\m 
\v 1 أَڒَامِي يَارْزمْ نتَّا \bd أَشمِّيعْ وِيسّْ سبْعَا\bd*، ثُوغَا أَجنَّا يَارْسَا عْڒَاحَاڒْ أَزْينْ ن ثْسَاعّثْ.
\b
\m 
\v 2 ؤُشَا ژْرِيغْ \bd سبْعَا ن لْمَالَاكَاثْ\bd* نِّي إِبدّنْ زَّاثْ إِ أَربِّي ؤُشَا إِمّوْشْ أَسنْثْ \bd سبْعَا ن وَاشَّاونْ ن ؤُيِيشّْ ن إِشَارِّي\bd*.
\b
\m 
\v 3 أَقَا إِجّْ ن لْمَالَاكْ نّغْنِي يُوسَا-د، يُويُورْ أَذْ إِبدّْ غَارْ ؤُعَالْطَارْ س إِشْثْ ن ثقْذُوحْثْ ن وُورغْ إِ ڒبْخُورْ. إِمّوْشْ أَسْ وَاطَّاسْ ن ڒبْخُورْ حِيمَا أَذْ ث إِوهّبْ أَكْ-ذ ثْژَادْجِيثِينْ ن مَارَّا إِمْقدَّاسنْ خْ ؤُعَالْطَارْ قِيبَاتْشْ إِ ڒْعَارْشْ.
\v 4 ؤُشَا أَرِّيحثْ ن ڒبْخُورْ أَكْ-ذ ثْژَادْجِيثِينْ ن إِمْقدَّاسنْ ثُوغَا ثتّْڭعَّاذْ زڭْ ؤُفُوسْ ن لْمَالَاكْ غَارْ زَّاثْ ن أَربِّي. \x ◘ \xo 8:‏4 \xt إِزهد. 141‏:‏2. \x*
\v 5 لْمَالَاكْ إِكْسِي ثَاقْذُوحْثْ ن ڒبْخُورْ، إِشُّورْ إِ-ت س ثْمسِّي زڭْ ؤُعَالْطَارْ ؤُشَا إِنْضَارْ إِ-ث غَارْ ثمُّورْثْ ؤُشَا ؤُسِينْ-د وَاجَّاجنْ ذ ثْمِيجَّاوِينْ ذ وَاسَّامنْ ذ إِجّْ ن ونْهزِّي ن ثمُّورْثْ.
\b
\m 
\v 6 ؤُشَا حزّْمنْثْ سبْعَا ن لْمَالَاكَاثْ ثِينِّي غَارْ إِدْجَا \bd سبْعَا ن وَاشَّاونْ ن ؤُيِيشّْ ن إِشَارِّي\bd* حِيمَا أَذْ \add ذَايْسنْ\add* سُوضنْثْ.
\m 
\v 7 \bd ؤُشَا إِسُوضْ ؤُمزْوَارُو\bd* \add ذِي ڒْبُوقْ نّسْ\add* ؤُشَا ثوْضَا-د ثبْرُورِي ذ ثْمسِّي خدْجْضنْثْ أَكْ-ذ وَامَانْ، تّْوَامنْضَارنْثْ خْ ثمُّورْثْ، ؤُشَا ثشْمضْ إِشْثْ ن تُّوڒُوثْ ن ثمُّورْثْ ذ إِشْثْ ن تُّوڒُوثْ ن ثْشجُّورَا ؤُڒَا ذ مَارَّا أَرْبِيعْ ن ثمُّورْثْ إِشْمضْ.
\m 
\v 8 \bd خنِّي إِسُوضْ ونِّي ذ وِيسّْ ثْنَاينْ\bd* \add ذِي ڒْبُوقْ نّسْ\add* ؤُشَا شَا ن ثْمسْڒَاشْثْ أَمْ وذْرَارْ أَمقّْرَانْ إِشمّْضنْ، إِمّنْضَارْ ذِي ڒبْحَارْ ؤُشَا إِشْثْ ن تُّوڒُوثْ ن ڒبْحَارْ إِذْوڒْ ذ إِذَامّنْ، \x ◘ \xo 8:‏8 \xt إِشا. 13‏:‏13، 19؛ إِرْم. 51‏:‏25\x*
\v 9 ؤُ إِشْثْ ن تُّوڒُوثْ ن إِمُودَّارنْ ذِي ڒبْحَارْ إِنِّي غَارْسنْ ڒعْمَارْ، مُّوثنْ، ؤُشَا إِشْثْ ن تُّوڒُوثْ ن إِغَارُّوبَا ثَاردّدْجْ. \f ◼ \fr 8:‏9 \ft \bd ’إِمُودَّارنْ‘\bd* - نِيغْ ’لْحَايَاوَانَاثْ‘.\f*
\m 
\v 10 \bd خنِّي إِسُوضْ ونِّي ذ وِيسّْ ثْڒَاثَا\bd* \add ذِي ڒْبُوقْ نّسْ\add* ؤُشَا إِوْضَا-د إِجّْ ن إِثْرِي أَمقّْرَانْ زڭْ ؤُجنَّا، يُورْغَا أَمْ يِيجّْ ن ؤُعشَّاڒْ ن ثْمسِّي، إِوْضَا-د خْ إِشْثْ ن تُّوڒُوثْ ن إِغزْرَانْ ؤُ خْ ثَاڒَاوِينْ ن وَامَانْ.
\v 11 إِثْرِي-يَا قَّارنْ-أَسْ ’أَبْسِينْثَا‘، \add نِيغْ ’شِّيحْ‘\add*. ؤُشَا إِشْثْ ن تُّوڒُوثْ ن وَامَانْ ثذْوڒْ ثَارْزڭْ أَمْ ’أَبْسِينْثْ‘، ؤُشَا مُّوثنْ أَطَّاسْ ن يوْذَانْ س وَامَانْ ؤُمِي ذوْڒنْ ذ إِمرْزَاڭنْ. \f ◼ \fr 8:‏11 \ft \bd ’أَبْسِينْثَا‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’شِّيحْ‘.\f*
\m 
\v 12 \bd خنِّي إِسُوضْ ونِّي ذ وِيسّْ أَربْعَا\bd* \add ذِي ڒْبُوقْ نّسْ\add* ؤُشَا ثتّْوَاطّفْ إِشْثْ ن تُّوڒُوثْ ن ثْفُوشْثْ ذ إِشْثْ ن تُّوڒُوثْ ن ثْزِيرِي ذ إِشْثْ ن تُّوڒُوثْ ن إِثْرَانْ، \add أَڒَامِي\add* ثْبَّارْشنْ إِشْثْ ن تُّوڒُوثْ زَّايْسنْ، وَارْ ثتِّيڒِي عَاذْ ثْفَاوْثْ إِ يِيشْثْ ن تُّوڒُوثْ ن ؤُزِيڒْ ؤُشَا أَمُّو ؤُڒَا ذِي دْجِيڒثْ.
\m 
\v 13 ؤُشَا سْڒِيغْ إِجّْ ن ؤُڭِيذرْ إِطَّاوْ-د ذِي ڒْوسْطْ ن ؤُجنَّا، إِقَّارْ: ”\bd ؤُشْثْ، ؤُشْثْ، ؤُشْثْ\bd* خْ يِينِّي إِزدّْغنْ خْ ثمُّورْثْ خْ سِّيبّثْ ن ثْمِيجَّاوِينْ إِنّغْنِي ن \bd وَاشَّاونْ ن إِشَارِّي\bd* ن ثْڒَاثَا ن لْمَالَاكَاثْ إِ غَا إِسُوضنْ عَاذْ \add ذِي ڒْبُوقْ\add*!“
\b
\b
\c 9
\m 
\v 1 \bd خنِّي إِسُوضْ ونِّي ذ وِيسّْ خمْسَا\bd* \add ذِي ڒْبُوقْ نّسْ\add* ؤُشَا ژْرِيغْ إِجّْ ن يثْرِي إِوْضَا-د زڭْ ؤُجنَّا خْ ثمُّورْثْ، ثمّوْشْ أَسْ ثَاسَارُوثْ ن ؤُقمُّومْ ن ثسْرَافْثْ يُودْجْغنْ. \x ◘ \xo 9:‏1 \xt لك. 8‏:‏31؛ أَسَا. 17‏:‏8. \x*
\v 2 ؤُشَا إِڭعّذْ-د دّخَّانْ زڭْ ؤُقمُّومْ ن ثسْرَافْثْ، أَمْ دّخَّانْ ن ثفْقُونْثْ ثَامقّْرَانْثْ إِحْمَانْ، ؤُشَا ثْفُوشْثْ ذ ڒعْوِينْ بَّارْشْننْ س دّخَّانْ ن ثسْرَافْثْ.
\v 3 زِي دّخَّانْ فّْغنْ-د زَّايسْ إِبُورخْسنْ غَارْ ثمُّورْثْ، ثمّوْشْ أَسنْ صُّولْطَا أَمْ ثنِّي إِدْجَانْ غَارْ ثْغَارْضْمِيوِينْ ن ثمُّورْثْ.
\v 4 إِتّْوَانَّا أَسنْ، مَاحنْذْ وَارْ جيّْحنْ أَرْبِيعْ ن ثمُّورْثْ ؤُڒَا ذ قَاعْ أَغمُّويْ أَزِيزَا ؤُڒَا ذ ثِيشجُّورَا، مْغِيرْ إِوْذَانْ وَاهَا إِنِّي وَارْ غَارْ إِدْجِي ؤُشمِّيعْ ن أَربِّي خْ ثنْيَارْثْ نْسنْ. \f ◼ \fr 9:‏4 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  \x ◘ \xo 9:‏4 \xt حِز. 9‏:‏4؛ يُوح. 6‏:‏26؛ أَسَا. 6‏:‏6؛ 7‏:‏2، 3. \x*
\v 5 ثمّوْشْ أَسنْ \add ثْزمَّارْ\add* مَاحنْذْ وَارْ ثنْ نقّنْ، مَاشَا أَذْ ثنْعدّْبنْ ڒْقدّْ ن خمْسَا ن إِيُورنْ، ؤُشَا أَعدّبْ نْسنْ أَمْ ؤُعدّبْ ن ثْغَارْضنْثْ خْمِي ثتّقّسْ إِ بْنَاذمْ.
\m 
\v 6 ذڭْ وُوسَّانْ نِّي أَذْ أَرْزُونْ إِوْذَانْ خْ ڒْموْثْ، \add مَاشَا\add* وَارْ ت تّطِّيفنْ، ؤُشَا أَذْ تَّارنْ أَذْ مّْثنْ، \add مَاشَا\add* ڒْموْثْ أَذْ زَّايْسنْ ثَارْوڒْ. \x ◘ \xo 9:‏6 \xt إِشا. 2‏:‏19؛ إِرْم. 8‏:‏3؛ حُوش. 10‏:‏8؛ لك. 23‏:‏30؛ أَسَا. 6‏:‏16. \x*
\v 7 إِبُورخْسنْ ڭِّينْ أَمْ يِييْسَانْ إِوجْذنْ إِ ؤُمنْغِي، ؤُ غَارْسنْ خْ إِزدْجِيفنْ نْسنْ \add شَا\add* أَمْ تِّيجَانْ أَخْمِي ثنْثْ ڭِّينْ س وُورغْ، ؤُ إِغمْبَابْ نْسنْ أَمْ إِغمْبَابْ ن إِوْذَانْ، \x ◘ \xo 9:‏7 \xt ؤُف. 10‏:‏4؛ يُووِ. 2‏:‏4\x*
\v 8 ؤُ أَشُووَّافْ نْسنْ أَمْ ؤُشُووَّافْ ن ثمْغَارِينْ ؤُ ثِيغْمَاسْ نْسنْ أَمْ ثِينِّي ن وَايْرَاذنْ، \x ◘ \xo 9:‏8 \xt يُووِ. 1‏:‏6\x*
\v 9 ؤُ ثُوغَا غَارْسنْ ثْشَابَّاثْ خْ إِذْمَارنْ نْسنْ أَمْ ثْشَابَّاثْ ن وُوزَّاڒْ \add إِ ؤُسڒْقِي\add*، ؤُ دّْرِيزْ ن وَافْرِيونْ نْسنْ أَمْ دّْرِيزْ ن إِكَارُّوثنْ أَكْ-ذ وَاطَّاسْ ن إِيْسَانْ إِتّقْنُونُّوينْ غَارْ ؤُمنْغِي،
\v 10 ؤُ غَارْسنْ إِكنَّاسنْ أَمْ يِينِّي ن ثْغَارْضْمِيوِينْ ؤُ ثُوغَا ذِينْ إِسنَّاننْ ذڭْ إِكنَّاسنْ نْسنْ. نِيثْنِي غَارْسنْ صُّولْطَا حِيمَا أَذْ سّهْوَانْ ذْرُوشْثْ خْ إِوْذَانْ، ڒْمِيجَاڒْ ن خمْسَا ن إِيُورنْ.
\v 11 نِيثْنِي غَارْسنْ لْمَالَاكْ ن ثسْرَافْثْ ذ أَجدْجِيذْ خَاسنْ، قَّارنْ أَسْ س ثْعِيبْرَانِيثْ ’أَبَادُّو‘ ؤُ س ثْرَامِيثْ قَّارنْ أَسْ ’شَارَا‘. \f ◼ \fr 9:‏11 \ft \bd ’أَبَادُّو‘\bd* - إِسمْ-أَ يُوسَا-ذ زِي ثُوثْلَايْثْ ن ثْعِيبْرَانِيثْ ؤُشَا إِخْسْ أَذْ يِينِي 'أَريّبْ' نِيغْ 'أَردّدْجْ' (أَسَا. 9:11).\f*
\b
\m 
\v 12 \bd ؤُشْثْ ثَامزْوَارُوثْ ثعْذُو\bd*، أَوَارْنِي مَانْ أَيَا أَذْ د-أَسنْثْ عَاذْ ثْنَاينْ ن وُوشْثَاثْ. \x ◘ \xo 9:‏12 \xt أَسَا. 8‏:‏13. \x*
\b
\m 
\v 13 أَوَارْنِي مَانْ أَيَا \bd إِسُوضْ لْمَالَاكْ وِيسّْ ستَّا\bd* \add ذِي ڒْبُوقْ نّسْ\add* ؤُشَا سْڒِيغْ ثْمِيجَّا إِ د-يُوسِينْ زِي أَربْعَا ن وَاشَّاونْ ن ؤُعَالْطَارْ ن وُورغْ إِ إِبدّنْ قِيبَاتْشْ إِ أَربِّي،
\v 14 ثنَّا إِ لْمَالَاكْ وِيسّْ ستَّا إِ غَارْ إِدْجَا \bd ؤُيِيشّْ ن إِشَارِّي\bd*: ”فْسِييْ إِ أَربْعَا ن لْمَالَاكَاثْ نِّي إِشَارْفنْ طَّارْفْ ن إِغْزَارْ أَمقّْرَانْ، لْفُورَاطْ.“
\v 15 ؤُشَا أَرْخُونْ أَسنْ إِ أَربْعَا ن لْمَالَاكَاثْ نِّي ثُوغَا إِوجْذنْ ذِينِّي غَارْ وَاسّْ ذ ؤُيُورْ ذ ؤُسڭّْوَاسْ، حِيمَا أَذْ نْغنْثْ إِشْثْ ن تُّوڒُوثْ ن إِوْذَانْ.
\v 16 ثُوغَا ڒْقدّْ ن ڒْعسْكَارَاثْ ن يِينِّي إِندّْهنْ إِيْسَانْ ثْيُويَا نعشْرَا-أَڒَافْ س عشْرَا ن ڒُوڒُوفْ، ؤُشَا سْڒِيغْ مشْحَاڒْ ذِي دْجَانْ. \f ◼ \fr 9:‏16 \ft \bd ’ثْيُويَا نعشْرَا-أَڒَافْ سعشْرَا ن ڒُوڒُوفْ‘\bd* - ڒْقدّْ نْسنْ أَمُّو 2 خْ 10.000 خْ 10.000 إِخْسْ أَذْ يِينِي 200 مِيلْيُونْ، إِخْسْ أَذْ يِينِي إِجّْ ن ڒْعسْكَارْ ذ أَمقّْرَانْ أَطَّاسْ س وَاطَّاسْ.\f*
\v 17 أَمُّو إِ ژْرِيغْ إِيْسَانْ ذِي ڒوْحِييْ، أَقَا إِنِّي خَاسنْ إِنْيِينْ ثُوغَا سّْذُورُّوينْ إِذْمَارنْ نْسنْ س ثْشَابَّاثْ ن وُوزَّاڒْ \add إِ ؤُسڒْقِي ذ ثِيزڭّْوَاغِينْ\add* أَمْ ثْمسِّي، شَابنْثْ، ذ ثِيوْرَاغِينْ أَمْ ڒشْبَاريّثْ. إِزدْجِيفنْ ن إِيْسَانْ نِّي أَمْ يِيزدْجِيفنْ ن وَايْرَاذنْ ؤُشَا زڭْ إِقمُّومنْ نْسنْ ثفّغْ-د زَّايْسنْ ثْمسِّي ذ دّخَّانْ ذ ڒشْبَاريّثْ.
\v 18 أَقَا إِشْثْ ن تُّوڒُوثْ ن إِوْذَانْ ثتّْوَانغْ س ثْڒَاثَا-يَا ن جّْرَايحْ: س ثْمسِّي ذ ڒشْبَاريّثْ ذ دّخَّانْ إِ د-إِتّفّْغنْ زڭْ إِقمُّومنْ نْسنْ.
\v 19 مِينْزِي صُّولْطَا نْسنْ أَقَا-ت ذڭْ إِقمُّومنْ ذ إِكنَّاسنْ نْسنْ، \add مِينْزِي إِكنَّاسنْ نْسنْ ڭِّينْ أَمْ إِفِيغْرَانْ نِّي غَارْ إِدْجَا إِزدْجِيفنْ، ؤُشَا تّْجيّْحنْ زَّايْسنْ إِوْذَانْ\add*.
\m 
\v 20 إِوْذَانْ إِقِّيمنْ، إِنِّي وَارْ إِتّْوَانْغنْ شَا س جّْرَايحْ-أَ، وَارْ ثُوبنْ شَا زِي ڒْخذْمثْ ن إِفَاسّنْ نْسنْ أَڒَامِي وَارْعبّْذنْ عَاذْ شّْوَاطنْ ذ لْ-أَصْنَامْ ن وُورغْ ذ نُّوقَارْثْ ذ نّْحَاسْ ذ وژْرُو ذ ؤُكشُّوضْ، إِنِّي وَارْ إِتّْوِيڒِينْ، وَارْ إِتّسْڒِينْ، وَارْ إِڭُّورنْ، \x ◘ \xo 9:‏20 \xt إِزهد. 115‏:‏4، 5، 6، 7؛ 135‏:‏15. \x*
\v 21 ؤُشَا نِيثْنِي وَارْ ثُوبنْ شَا زڭْ ونْغَايْ نْسنْ، ڒَا زِي ثْسحَّارْثْ نْسنْ ؤُڒَا زِي فَارْقْ-شّْغڒْ نْسنْ.
\b
\b
\c 10
\s1 لْمَالَاكْ غَارسْ وذْلِيسْ أَمژْيَانْ
\m 
\v 1 ؤُشَا ژْرِيغْ إِجّْ ن لْمَالَاكْ نّغْنِي إِهْوَا-د زڭْ ؤُجنَّا، ثُوغَا يَارْضْ أَسيْنُو ؤُشَا ثَاسْڒِيثْ ن ونْژَارْ ن ؤُجنَّا ثْبدّْ أَسْ خْ ؤُزدْجِيفْ. أَغمْبُوبْ نّسْ إِڭَّا أَمْ ثْفُوشْثْ، إِضَارنْ نّسْ أَمْ إِپِيلَارنْ ن ثْمسِّي. \x ◘ \xo 10:‏1 \xt مت. 17‏:‏2؛ أَسَا. 1‏:‏15. \x*
\v 2 إِطّفْ ذڭْ ؤُفُوسْ نّسْ إِجّْ ن وذْلِيسْ \add إِتّْوَانّْضنْ\add* أَمژْيَانْ يَارْزمْ. إِسَّارْسْ أَضَارْ نّسْ أَفُوسِي خْ ڒبْحَارْ، أَضَارْ نّسْ أَزڒْمَاضْ خْ ثمُّورْثْ،
\v 3 ؤُشَا إِڒَاغَا س ثْمِيجَّا ثجْهذْ، أَمْ وَايْرَاذْ إِتّْزهَّارنْ، ؤُشَا أَوَارْنِي ڒَامِي د-إِڒَاغَا، جِّينْ سبْعَا ن وَاجَّاجنْ أَذْ سْڒنْ ثْمِيجَّاوِينْ نْسنْ.
\v 4 ڒَامِي كمّْڒنْ سبْعَا ن وَاجَّاجنْ نِّي أَوَاڒْ نْسنْ، ثُوغَا خْسغْ أَذْ ث أَرِيغْ، \add مَاشَا\add* سْڒِيغْ إِ يِيشْثْ ن \bd ثْمِيجَّا ثْڒَاغَا-د زڭْ ؤُجنَّا وِيسّْ سبْعَا\bd*: ”أڭّْ أَشمِّيعْ خْ مِينْ نَّانْ سبْعَا ن وَاجَّاجنْ، وَارْ ث تَّارِي شَا.“ \x ◘ \xo 10:‏4 \xt دَان. 8‏:‏26؛ 12‏:‏4؛ 2 كُور. 12‏:‏2\x*
\m 
\v 5 لْمَالَاكْ نِّي ثُوغَا ژْرِيغْ إِبدّْ خْ ڒبْحَارْ ذ ثمُّورْثْ، إِكْسِي أَفُوسْ نّسْ غَارْ ؤُجنَّا \x ◘ \xo 10:‏5 \xt دَان. 12‏:‏7. \x*
\v 6 ؤُشَا إِجُّودْجْ غَارْ ونِّي إِدَّارنْ إِ ڒبْذَا قَاعْ، ونِّي إِڭِّينْ أَجنَّا ذ مِينْ ذَايسْ ؤُ ثَامُّورْثْ ذ مِينْ ذَايسْ ؤُڒَا ذ ڒبْحَارْ ذ مِينْ ذَايسْ:
\b
\m \bd ”وَارْ ثقِّيمْ بُو ڒْوقْثْ \bdit عَاذْ\bdit*!“\bd* \x ◘ \xo 10:‏6 \xt أَسَا. 11‏:‏15. \x*
\b
\m 
\v 7 مَاغَارْ ذڭْ وُوسَّانْ ن لْمَالَاكْ وِيسّْ سبْعَا، خْمِي غَا إِسُوضْ نتَّا \add ذِي ڒْبُوقْ نّسْ\add*، ڭُّورْ أَذْ إِكْمڒْ سِّيرّْ ن أَربِّي نِّي ثُوغَا إِتّْبَارّحْ إِ إِمْسخَّارنْ نّسْ، إِنَابِييّنْ.
\v 8 ؤُشَا ثْمِيجَّا زڭْ ؤُجنَّا إِ سْڒِيغْ ثسِّيوڒْ غَارِي إِشْثْ ن ثْوَاڒَا نّغْنِيثْ، ثنَّا: ”ؤُيُورْ، كْسِي أَذْلِيسْ \add إِتّْوَانّْضنْ\add* أَمژْيَانْ يَارزْمنْ إِ إِدْجَانْ ذڭْ ؤُفُوسْ ن لْمَالَاكْ نِّي إِبدّنْ خْ ڒبْحَارْ ذ ثمُّورْثْ.“
\v 9 ؤُشَا ؤُيُورغْ غَارْ لْمَالَاكْ، تَّارغْ أَسْ أَذْ أَيِي إِوْشْ أَذْلِيسْ \add إِتّْوَانّْضنْ\add* أَمژْيَانْ. إِنَّا أَيِي: ”كْسِي \add أَذْلِيسْ-أَ أَمژْيَانْ\add*، ثشِّيذْ ث ؤُشَا أَذْ إِسَّارْزڭْ أَعذِّيسْ نّشْ، مَاشَا ذڭْ ؤُقمُّومْ نّشْ أَذْ يِيڒِي \add ذ أَمِيژِيذْ\add* أَمْ ثَامّنْثْ.“ \x ◘ \xo 10:‏9 \xt حِز. 2‏:‏9‏-‏3‏:‏1‏-‏4\x*
\v 10 نشّْ كْسِيغْ أَذْلِيسْ أَمژْيَانْ \add إِتّْوَانّْضنْ\add* زڭْ ؤُفُوسْ ن لْمَالَاكْ ؤُشَا شِّيغْ ث. ثُوغَا-ث ذ أَمِيژِيذْ ذڭْ ؤُقمُّومْ إِنُو، \add مَاشَا\add* ڒَامِي ث شِّيغْ، يَارْزڭْ ذڭْ ؤُعذِّيسْ إِنُو.
\v 11 \add خنِّي\add* إِنَّا أَيِي: ”ثمّوْشْ أَسْ عَاوذْ ڒْوقْثْ مَاحنْذْ أَذْ ثْنبِّيذْ إِ وَاطَّاسْ ن ڒڭْنُوسْ ذ ثمُّورَا ذ إِڒْسَاونْ ذ إِجدْجِيذنْ.“
\b
\b
\c 11
\s1 ثْنَاينْ ن ڒشْهُوذْ
\m 
\v 1 ؤُشَا إِمّوْشْ أَيِي إِجّْ ن ؤُغَانِيمْ، إِڭَّا أَمْ يِيجّْ ن ؤُقطَّابْ \add ن ڒعْبَارْ\add*، ؤُشَا إِبدّْ \add ذِينْ\add* لْمَالَاكْ، إِنَّا: ”كَّارْ ؤُشَا عْبَارْ زَّاوشْثْ ثَامقّْرَانْثْ ن أَربِّي ذ ؤُعَالْطَارْ ذ يِينِّي ذَايسْ إِعبّْذنْ، \f ◼ \fr 11:‏1 \ft \bd ’ذَايسْ‘\bd* - إِخْسْ أَذْ يِينِي ’ذِي زَّاوشْثْ ثَامقّْرَانْثْ‘.\f*  \x ◘ \xo 11:‏1 \xt حِز. 40‏:‏3‏-‏49؛ 41؛ 42؛ 43. \x*
\v 2 \add مَاشَا\add* ڒمْرَاحْ نِّي غَارْ ذَاخڒْ ن زَّاوشْثْ ثَامقّْرَانْثْ، أجّْ إِ-ث، وَارْ ث تّْعبَّارْ، مِينْزِي أَقَا إِمّوْشْ إِ ڒڭْنُوسْ ؤُشَا نِيثْنِي أَذْعفْسنْ خْ ثنْذِينْثْ إِقدّْسنْ \bd ثْنَاينْ ؤُ أَربْعِينْ ن إِيُورنْ\bd*. \f ◼ \fr 11:‏2 \ft \bd ’أَذْعفْسنْ‘\bd* - نِيغْ: ’أَذْعجْننْ‘.\f*  \x ◘ \xo 11:‏2 \xt أَسَا. 13‏:‏5. \x*
\v 3 نشّْ أَذْ وْشغْ صُّولْطَا إِ ثْنَاينْ ن ڒشْهُوذْ إِنُو، مَاحنْذْ أَذْ نبَّانْ \add س وَاوَاڒْ ن أَربِّي\add* \bd أَڒفْ ؤُ مِيثَاينْ ؤُ-ستِّينْ ن وُوسَّانْ\bd*، أَمْ يَارْضنْ ثْخَانْشثْ ن وشْضَانْ.“
\m 
\v 4 نِيثْنِي ذ ثْنَاينْ ن ثْزِيثُونِينْ ذ ثْنَاينْ ن ڒقْنَاذڒْ إِ إِبدّنْ زَّاثْ إِ وُوذمْ ن سِيذِي ن مَارَّا ثَامُّورْثْ. \x ◘ \xo 11:‏4 \xt زَاك. 4‏:‏3، 14. \x*
\v 5 مَاڒَا ذِينْ شَا ن يِيجّنْ إِخْسْ أَذْ ثنْ إِهْوڒْ، أَذْ ثفّغْ ثْمسِّي زڭْ ؤُقمُّومْ نْسنْ ؤُشَا أَذْ ثشّْ ڒْعذْيَانْ نْسنْ. أَمُّو إِ غَا تّْوَانْغنْ إِنِّي إِخْسنْ أَذْ ثنْ ضَارّنْ.
\v 6 نِيثْنِي غَارْسنْ صُّولْطَا مَاحنْذْ أَذْ قّْننْ أَجنَّا، حِيمَا وَارْ د-إِوطِّي ونْژَارْ ذڭْ وُوسَّانْ نِّي ذِي غَا نبَّانْ نِيثْنِي، ؤُ غَارْسنْ صُّولْطَا حِيمَا أَذْ أَرّنْ أَمَانْ ذ إِذَامّنْ ؤُ حِيمَا أَذْ سيّْحنْ ثَامُّورْثْ س مَارَّا جّْرِيحشْثْ مڒْمِي مَا خْسنْ. \x ◘ \xo 11:‏6 \xt ؤُف. 7؛ 8؛ 9؛ 10؛ 12؛ 1 إِج. 17‏:‏1. \x*
\m 
\v 7 خْمِي غَا كمّْڒنْ شّْهَاذَاثْ نْسنْ، أَذْ د-إِڭعّذْ ڒْوحْشْ زِي ڒَادْجَاغْ، أَذْ كِيسنْ إِمّْنغْ، أَذْ خَاسنْ إِغلّبْ ؤُشَا أَذْ ثنْ إِنغْ. \x ◘ \xo 11:‏7 \xt دَان. 7‏:‏21؛ أَسَا. 13‏:‏7، 11. \x*
\v 8 ڒْخشْبَاثْ نْسنْ \add أَذْ إِڒِينْثْ\add* ذڭْ وَازَّايْ ن ثنْذِينْثْ ثَامقّْرَانْثْ ؤُمِي قَّارنْ س ڒْمعْنَا أَرُّوحِي نّسْ ’سَاذُومْ‘ ذ ’مِيصْرَا‘، مَانِي نْغِينْ سِيذِيثْسنْ خْ صَّالِيبْ. \x ◘ \xo 11:‏8 \xt إِرْم. 23‏:‏14؛ أَسَا. 7‏:‏2، 5؛ 18‏:‏10. \x*
\v 9 ؤُشَا زِي شُّوعُوبْ ذ ثْقبَّاڒْ ذ إِڒْسَاونْ ذ ڒڭْنُوسْ أَذْ ژَترنْ \add إِوْذَانْ\add* ڒْخشْبَاثْ نْسنْ، \add ڒْقدّْ ن\add* ثْڒَاثَا ن وُوسَّانْ ذ وزْينْ، وَارْ تّجِّينْ ڒْخشْبَاثْ نْسنْ أَذْ تّْوَامَّارْسنْثْ ذڭْ إِمضْڒَانْ.
\v 10 إِمزْذَاغْ ن ثمُّورْثْ أَذْ زَّايْسنْ فَارْحنْ، أَذْعيّْذنْ، أَذْ أَرزْفنْ إِجّنْ غَارْ ونّغْنِي، أَذْ سّكّنْ إِكَاذُوثنْ إِ وَايَاوْيَا، مِينْزِي ثْنَاينْ ن إِنَابِييّنْ-أَ ثُوغَاغزَّانْ ذڭْ إِمزْذَاغْ ن ثمُّورْثْ.
\m 
\v 11 \add مَاشَا\add* أَوَارْنِي ثْڒَاثَا ن وُوسَّانْ ذ وزْينْ يُوذفْ ذَايْسنْ أَرُّوحْ إِدَّارنْ زِي أَربِّي ؤُشَا كَّارنْ، بدّنْ خْ إِضَارنْ نْسنْ ؤُ ثوْضَا-د خَاسنْ أَرُّوحْ ن ثُوذَارْثْ ؤُشَا ثِيڭّْوُوذِي ثمْغَارْ ثوْضَا-د خْ \add مَارَّا\add* إِنِّي ثنْ إِژْرِينْ. \x ◘ \xo 11:‏11 \xt حِز. 37‏:‏5، 10\x*
\v 12 نِيثْنِي سْڒِينْ إِشْثْ ن ثْمِيجَّا ثجْهذْ \add ثتّْڒَاغَا\add* زڭْ ؤُجنَّا، ثقَّارْ أَسنْ: ”ڭعّْذمْ-د ذَا!“ ؤُشَا نِيثْنِي ڭعّْذنْ غَارْ ؤُجنَّا ذڭْ ؤُسيْنُو ؤُشَا ڒْعذْيَانْ نْسنْ ژْرِينْ ثنْ.
\m 
\v 13 ذِي ثْسَاعّثْ نِّي إِمْسَارْ إِجّْ ن ونْهزِّي ن ثمُّورْثْ ذ أَمقّْرَانْ. إِشْثْ ن ثْعشَّارْثْ ن ثنْذِينْثْ ثهْذمْ ؤُشَا سبْعَا-أَڒَافْ ن يرْيَازنْ غَارْسنْ إِسمْ \add إِشنّْعنْ\add* مُّوثنْ س ونْهزِّي-يَا ن ثمُّورْثْ. وِي إِقِّيمنْ، ذوْڒنْ ڭّْوذنْ أَطَّاسْ ؤُشَا سُّوعْڒَانْ زِي أَربِّي ن ؤُجنَّا.
\m 
\v 14 \bd ’خْزَارْ، ثْنَاينْ ن وُوشْثَاثْ عْذُونْثْ، ؤُشَا خْزَارْ ’ؤُشْثْ!‘ وِيسّْ ثْڒَاثَا أَذْ د-ثَاسْ ذغْيَا.\bd* \x ◘ \xo 11:‏14 \xt أَسَا. 8‏:‏13؛ 9‏:‏12؛ 15‏:‏1. \x*
\b
\m 
\v 15 \bd لْمَالَاكْ وِيسّْ سبْعَا إِسُوضْ\bd* \add ذِي ڒْبُوقْ نّسْ\add* ؤُشَا كَّارنْثْ-إِ-د ثْمِيجَّاوِينْ ثِيمقّْرَانِينْ ذڭْ ؤُجنَّا، تّْڒَاغَانْثْ:
\b
\m \qt ”ثَاڭلْذَا ن دُّونشْثْ أَقَا-ت ن أَربِّي نّغْ ؤُ ن لْمَاسِيحْ نّسْ، ؤُشَا نتَّا أَذْ إِحْكمْ أَمْ ؤُجدْجِيذْ إِ ڒبْذَا قَاعْ.“\qt*
\b
\m 
\v 16 أَربْعَا ؤُ عِيشْرِينْ ن إِمْغَارنْ، إِنِّي إِقِّيمنْ زَّاثْ إِ أَربِّي خْ ڒكْرَاسِي نْسنْ إِڭلّْذنْ، وْضَانْ س ؤُغمْبُوبْ نْسنْ \add غَارْ ثمُّورْثْ\add* ؤُشَا سجْذنْ إِ أَربِّي،
\v 17 نَّانْ:
\b
\m \qt ”نشِّينْ نتّْقَاذَا شكْ، أَ سِيذِي أَربِّي،\qt*
\m \qt أَمْزمَّارْ خْ كُوڒْشِي،\qt*
\m \qt شكْ ذ ونِّي إِدْجَانْ ذ ونِّي ثُوغَا،\qt*
\m \qt أَقَا ثكْسِيذْ جّهْذْ نّشْ أَمقّْرَانْ\qt*
\m \qt \tl ذڭْ ؤُفُوسْ نّشْ،\tl*\qt*
\m \qt ؤُشَا ثبْذِيذْ أَذْ ثْحكْمذْ أَمْ ؤُجدْجِيذْ.\qt* \x ◘ \xo 11:‏17 \xt أَسَا. 1‏:‏4، 8؛ 4‏:‏18؛ 16‏:‏5. \x*
\m 
\v 18 \qt ڒڭْنُوسْ ثُوغَا خيّْقنْ \tl خَاكْ،\tl*\qt*
\m \qt \tl مَاشَا\tl* يُوسَا-د وغْضَابْ نّشْ،\qt*
\m \qt ؤُشَا ثِيوضْ-د ڒْوقْثْ ن إِمتِّيننْ\qt*
\m \qt حِيمَا أَذْ تّْوَاحَاسْبنْ\qt*
\m \qt ؤُ حِيمَا أَذْ ثمّوْشْ ڒْمُونثْ\qt*
\m \qt إِ إِمْسخَّارنْ نّشْ،\qt*
\m \qt إِنَابِييّنْ، ؤُ إِ إِمْقدَّاسنْ\qt*
\m \qt ؤُ إِ يِينِّي إِتّڭّْوذنْ إِسمْ نّشْ،\qt*
\m \qt أَمْ إِمژْيَاننْ أَمْ يِيمقّْرَاننْ،\qt*
\m \qt ؤُ شكْ أَذْ ثَاريّْبذْ\qt*
\m \qt إِنِّي إِتَّارذْدْجنْ ثَامُّورْثْ.“\qt*
\b
\m 
\v 19 ثنُّورْزمْ زَّاوشْثْ ثَامقّْرَانْثْ ذڭْ ؤُجنَّا أَڒَامِي ثتّْوَاژَارْ تَّابُوثْ ن ڒْعَاهْذْ نّسْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ، ؤُشَا كَّارنْ وَاسَّامنْ ذ وَاجَّاجنْ ذ ثْمِيجَّاوِينْ ؤُشَا إِمْسَارْ إِجّْ ن ونْهزِّي ن ثمُّورْثْ ؤُ \add وْضَانْ\add* \add إِبْقُوقنْ\add* إِمقّْرَاننْ \add ن\add* ثبْرُورِي. \f ◼ \fr 11:‏19 \ft \bd ’تَّاپُوثْ‘\bd* - نتَّا ذ إِجّْ ن سّنْذُوقْ ن ؤُكشُّوضْ ن ؤُكَاسِييَا إِغدْجْفنْ س وُورغْ. ثُوغَا ذَايسْ ثْنَاينْ ن ثڒْوِيحِينْ ن وژْرُو ن شَّارِيعَا ذ ثَاغَّارْشْثْ ن هَارُونْ نِّي إِتّْوَانُّووْشنْ ذ إِجْ ن ؤُزنْبِيڒْ ذَايسْ ’مَانَّا‘. خْزَارْ عِيبْ. 9:4.\f*  \x ◘ \xo 11:‏19 \xt أَسَا. 15‏:‏5. \x*
\b
\b
\c 12
\s1 ثَامْغَارْثْ ذ ڒْهَايْشثْ
\m 
\v 1 خنِّي ثتّْوَاژَارْ \bd إِشْثْ ن ڒعْڒَامثْ ثَامقّْرَانْثْ ذڭْ ؤُجنَّا\bd*: \bd إِشْثْ ن ثْمطُّوثْ\bd* ثْيَارْضْ ثَافُوشْثْ، ؤُ ثَازِيرِي سَاذُو إِضَارنْ نّسْ ؤُشَا غَارسْ خْ ؤُزدْجِيفْ نّسْ إِجّْ ن تَّاجْ س ثنْعَاشْ ن إِثْرَانْ.
\v 2 ثُوغَا ثكْسِي دّيْسثْ، ثسْغُويُّو س ڒوْجعْ، ثتّْوَاحْصَارْ س ؤُنزْبَارْ ن ثَارُوثْ.
\m 
\v 3 خنِّي ثتّْوَاژَارْ \bd إِشْثْ ن ڒعْڒَامثْ نّغْنِي ذڭْ ؤُجنَّا\bd*، أَقَا ذِينْ \bd إِشْثْ ن ڒْهَايْشثْ ثَامقّْرَانْثْ ثَازڭّْوَاغْثْ أَمْ ثْمسِّي\bd*، غَارسْ سبْعَا ن إِزدْجِيفنْ ذعشْرَا ن وَاشَّاونْ، ؤُشَا خْ إِزدْجِيفنْ نّسْ سبْعَا ن تِّيجَانْ. \f ◼ \fr 12:‏3 \ft \bd ’أَشَّاونْ‘\bd* - نِيثْنِي ذ إِقَاشَّاونْ ن لْحَايَاوَانْ.\f*
\v 4 ؤُشَا أَكنَّاسْ نّسْ إِفَارْضْ إِشْثْ ن تُّوڒُوثْ ن إِثْرَانْ زڭْ ؤُجنَّا، ثسّْژَاريّضْ إِ-ثنْ غَارْ ثمُّورْثْ. ؤُشَا ڒْهَايْشثْ ثُوغَا ثْبدّْ زَّاثْ إِ ثْمطُّوثْ إِ غَا يَارْونْ، حِيمَا أَذْ ثْصَارْضْ مِّيسْ خْمِي ث-إِ-د إِ غَا ثَارُووْ.
\v 5 ؤُشَا ثُورُووْ-د مِّيسْ، أَرْيَازْ نِّي إِ غَا إِحكْمنْ خْ مَارَّا ڒڭْنُوسْ س ؤُزدْجَاضْ ن وُوزَّاڒْ، ؤُشَا مِّيسْ إِمّكْسِي ذغْيَا غَارْ أَربِّي ؤُ غَارْ ڒْعَارْشْ نّسْ. \x ◘ \xo 12:‏5 \xt إِزهد. 2‏:‏9؛ أَسَا. 2‏:‏27. \x*
\v 6 مَاشَا ثَامطُّوثْ ثَارْوڒْ غَارْ ڒخْڒَا، غَارْ مَانِي ثُوغَا ذ أَسْ إِڭَّا أَربِّي أَمْشَانْ حِيمَا أَذْ أَسْ سّشّنْ، \bd ڒْْقدّْ ن وَاڒفْ ؤُ-مِيثَايْنْ ؤُ-ستِّينْ ن وُوسَّانْ\bd*. \x ◘ \xo 12:‏6 \xt إِزهد. 55‏:‏7‏-‏19؛ أَسَا. 11‏:‏3. \x*
\m 
\v 7 ؤُشَا إِكَّارْ \bd ؤُمنْغِي ذڭْ ؤُجنَّا\bd*. مِيخَايِيلْ ذ لْمَالَاكَاثْ نّسْ مّنْغنْثْ أَكْ-ذ ڒْهَايْشثْ، ؤُشَا ؤُڒَا ذ ڒْهَايْشثْ ذ لْمَالَاكَاثْ نّسْ مّنْغنْثْ،
\v 8 مَاشَا نِيثْنِي وَارْ جْهِيذنْ شَا ؤُشَا وَارْ إِتّْوِيفْ عَاذْ ومْشَانْ ذڭْ ؤُجنَّا إِ نِيثْنِي. \x ◘ \xo 12:‏8 \xt دَان. 2‏:‏35. \x*
\v 9 \bd ثمّنْضَارْ-د ڒْهَايْشثْ ثَامقّْرَانْثْ\bd*، نتَّاثْ ذ ؤُفِيغَارْ نِّي ثُوغَا زِيشْ، قَّارنْ أَسْ ’إِبْڒِيسْ‘ نِيغْ ’شِّيطَانْ‘، ونِّي إِغكّْوَانْ مَارَّا ثَامُّورْثْ، \add وَاهْ\add*، أَقَا إِمّنْضَارْ-د خْ ثمُّورْثْ ؤُشَا لْمَالَاكَاثْ نّسْ مّنْضَارنْثْ-إِ-د \add عَاوذْ\add* أَكِيذسْ. \x ◘ \xo 12:‏9 \xt لك. 10‏:‏18؛ أَسَا. 20‏:‏2. \x*
\v 10 ؤُشَا سْڒِيغْ إِشْثْ ن ثْمِيجَّا ثَامقّْرَانْثْ زڭْ ؤُجنَّا ثقَّارْ س جّهْذْ:
\b
\m \qt ”أَقَا \tl يُوسَا-د\tl* ؤُفكِّي ذ صُّولْطَا\qt*
\m \qt ذ ثْڭلْذِيثْ ن أَربِّي نّغْ،\qt*
\m \qt مِينْزِي ونِّي إِضڒْمنْ أَيْثْمَاثْنغْ، أَقَا إِمّنْضَارْ،\qt*
\m \qt ونِّي إِ ثنْ إِضڒْمنْ أَسّْ ذ دْجِيڒثْ.\qt*
\m 
\v 11 \qt غلّْبنْ \tl خَاسْ\tl* س إِذَامّنْ ن إِزْمَارْ،\qt*
\m \qt ذ وَاوَاڒْ ن شّْهَاذثْ نّسْ،\qt*
\m \qt ؤُشَا نِيثْنِي وَارْ سّْعِيزّنْ شَا ثُوذَارْثْ نْسنْ\qt*
\m \qt أَڒْ ڒْموْثْ.\qt*
\m 
\v 12 \qt خْ ؤُينِّي، فَارْحمْ، \tl أَ\tl* إِجنْوَانْ\qt*
\m \qt ذ يِينِّي ذَايْسنْ إِزدّْغنْ!\qt*
\m \bdit ؤُشْثْ\bdit* \qt خْ ثمُّورْثْ ذ ڒبْحَارْ،\qt*
\m \qt إِبْڒِيسْ أَقَا إِهْوَا-د غَارْومْ \qt*
\m \qt س ثفْقحْثْ نّسْ إِمْغَارنْ أَطَّاسْ،\qt*
\m \qt إِسّنْ أَذْ غَارسْ إِقِّيمْ\qt*
\m \qt ذْرُوسْثْ ن ڒْوقْثْ وَاهَا.“\qt* \x ◘ \xo 12:‏12 \xt إِزهد. 96‏:‏11؛ إِشا. 49‏:‏13؛ أَسَا. 8‏:‏13. \x*
\b
\m 
\v 13 أَڒَامِي ڒْهَايْشثْ ثُوفَا إِخفْ نّسْ ثمّنْضَارْ غَارْ ثمُّورْثْ، ثضْفَارْ ثَامطُّوثْ إِ د-يُورْونْ \add مِّيسْ\add* ذ أَوْثمْ.
\v 14 مّوْشنْ أَسْ إِ ثْمطُّوثْ ثْنَاينْ ن وفْرِيونْ ن ؤُڭِيذرْ أَمقّْرَانْ، حِيمَا أَذْ ثضْوُو غَارْ ومْشَانْ نّسْ ذِي ڒخْڒَا، مَاحنْذْ أَذْ ثتّْوَاسّشّْ ذِينِّي، \bd إِجّْ ن ڒْمِيجَاڒْ ن ڒْوقْثْ ذ ڒوْقَاثْ ذ إِجّْ ن وزْينْ \bdit ن يِيجّْ ن ڒْمِيجَاڒْ ن ڒْوقْثْ\bdit*\bd*، مَانِي وَارْ ت إِژَارّْ ؤُفِيغَارْ. \f ◼ \fr 12:‏14 \ft \bd ’إِجّْ ن ڒْمِيجَاڒْ ن ڒْوقْثْ ذ ڒوْقَاثْ ذ إِجّْ ن وزْينْ \bdit ن يِيجّْ ن ڒْمِيجَاڒْ ن ڒْوقْثْ\bdit*‘\bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي ’إِجّْ ن ؤُسڭّْوَاسْ ذ ثْنَاينْ ن إِسڭّْوُوسَا ذ وزْينْ ن ؤُسڭّْوَاسْ‘. خْزَارْ أَسَا. 12:6.\f*  \x ◘ \xo 12:‏14 \xt أَسَا. 2‏:‏6. \x*
\v 15 أَفِيغَارْ إِسُّوسفْ زڭْ ؤُقمُّومْ نّسْ أَوَارْنِي إِ ثْمطُّوثْ، إِڭَّا إِشْثْ ن ڒْحمْڒثْ ن وَامَانْ أَمْ يغْزَارْ، حِيمَا أَذْ ت أَوْينْ وَامَانْ.
\v 16 ثَامُّورْثْ ثْعَاونْ ثَامطُّوثْ ؤُشَا ثَارْزمْ ثمُّورْثْ أَقمُّومْ نّسْ، ثحْرُووْ إِغْزَارْ ونِّي د-إِسُّوسْفنْ ڒْهَايْشثْ زڭْ ؤُقمُّومْ نّسْ.
\v 17 ؤُشَا ڒْهَايْشثْ ثْخيّقْ أَطَّاسْ خْ ثْمطُّوثْ ؤُشَا ثُويُورْ حِيمَا أَذْ ثمّْنغْ أَكْ-ذ يِينِّي إِقِّيمنْ زِي زَّارِيعثْ نّسْ ؤُشَا أَكْ-ذ إِنِّي إِتّطّْفنْ ذِي ثْوصَّا ن أَربِّي ؤُ ذِي شّْهَاذثْ ن يَاسُوع. \f ◼ \fr 12:‏17 \ft \bd ’زَّارِيعثْ نّسْ‘\bd* - إِخْسْ أَذْ يِينِي لْمَاسِيحْ (خْزَارْ أَمز. 3:15) ؤُ ينِّي إِقِّيمنْ أَقَا-ثنْ ذ ڒْمُومِينِينْ إِنِّي يُومْننْ ذِي لْمَاسِيحْ.\f*
\b
\b
\c 13
\s1 ڒْوحْشْ زِي ڒبْحَارْ ؤُ ڒْوحْشْ زِي ثمُّورْثْ
\m 
\v 1 ؤُشَا ذوْڒغْ بدّغْ خْ إِجْذِي \add غَارْ ثْمَا\add* ن ڒبْحَارْ، ؤُشَا ژْرِيغْ \bd إِجّْ ن ڒْوحْشْ إِڭعّذْ-د زِي ڒبْحَارْ\bd*، غَارسْعشْرَا ن وَاشَّاونْ ذ سبْعَا ن إِزدْجِيفنْ. خْ وَاشَّاونْ نّسْعشْرَا ن تِّيجَانْ ؤُشَا خْ إِزدْجِيفنْ نّسْ إِتّْوَارِي خَاسنْ إِجّْ ن يِيسمْ ن تّكْفِيرْ. \x ◘ \xo 13:‏1 \xt دَان. 7‏:‏20؛ أَسَا. 17‏:‏3. \x*
\v 2 ڒْوحْشْ إِ ژْرِيغْ، يَارْوسْ ذڭْ ؤُغِيڒَاسْ، إِضَارنْ نّسْ أَمْ يِيضَارنْ ن دُّوبْ، أَخنْفُوشْ نّسْ أَمْ ؤُخنْفُوشْ ن وَايْرَاذْ. ڒْهَايْشثْ ثوْشَا أَسْ جّهْذْ نّسْ ذ ڒْعَارْشْ نّسْ ؤُڒَا ذ صُّولْطَا إِمْغَارنْ.
\v 3 إِجّنْ زڭْ إِزدْجِيفنْ نّسْ إِڭَّا أَخْمِي ث وْثِينْ أَڒْ ڒْموْثْ، خنِّي إِتّْوَاسّْڭنْفَا ؤُيزِّيمْ نّسْ إِ إِڭِّينْ أَخْمِي إِيْزمْ أَڒْ ڒْموْثْ، ؤُشَا مَارَّا ثَامُّورْثْ ثضْفَارْ ڒْوحْشْ س ؤُثبْهثْ أَمقّْرَانْ.
\v 4 أَقَا نِيثْنِيعبْذنْ ڒْهَايْشثْ، مِينْزِي نتَّاثْ ثوْشَا صُّولْطَا إِ ڒْوحْشْ، ؤُشَا نِيثْنِيعبْذنْ ڒْوحْشْ، نَّانْ: ”وِي يَارْوسنْ ذِي ڒْوحْشْ؟“ ؤُ: ”وِي إِزمَّارنْ أَذْ كِيذسْ إِمّْعَاڒَانْ؟“ \x ◘ \xo 13:‏4 \xt أَسَا. 18‏:‏18. \x*
\v 5 إِمّوْشْ أَسْ \add إِ ڒْوحْشْ\add* أَقمُّومْ نِّي إِسَّاوَاڒنْ س ؤُكبَّارْ ؤُ س ؤُشقّفْ \add ذِي أَربِّي\add*، ؤُشَا ثمّوْشْ أَسْ صُّولْطَا حِيمَا أَذْ إِخْذمْ \bd \bdit إِ يِيجّْ ن ڒْقدّْ ن\bdit* ثْنَاينْ ؤُ-ربْعِينْ ن إِيُورنْ\bd*. \f ◼ \fr 13:‏5 \ft \bd ’ثْنَاينْ ؤُ-ربْعِينْ ن إِيُورنْ‘\bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي 1260 ن وُوسَّانْ نِيغْ 3½ ن إِسڭّْوُوسَا (خْزَارْ أَسَا. 12:6، 14).\f*  \x ◘ \xo 13:‏5 \xt أَيُوبْ 15‏:‏25؛ أَسَا. 11‏:‏2. \x*
\v 6 ؤُشَا نتَّا يَارْزمْ أَقمُّومْ نّسْ حِيمَا أَذْ إِشقّفْ ذِي أَربِّي، ؤُ حِيمَا أَذْ إِشقّفْ ذڭْ يِيسمْ نّسْ ؤُ ذِي ثْزذِّيغْثْ ن يِينِّي إِزدّْغنْ ذڭْ ؤُجنَّا.
\v 7 إِمّوْشْ أَسْ صُّولْطَا مَاحنْذْ أَذْ إِمّْنغْ أَكْ-ذ إِمْقدَّاسنْ ؤُ مَاحنْذْ أَذْ خَاسنْ إِغلّبْ. ثمّوْشْ أَسْ صُّولْطَا خْ مَارَّا ثِيقبَّاڒْ ذ شُّوعُوبْ ذ يِيڒْسَاونْ ذ ڒڭْنُوسْ. \x ◘ \xo 13:‏7 \xt دَان. 7‏:‏21؛ أَسَا. 11‏:‏7. \x*
\v 8 مَارَّا إِنِّي ثُوغَا إِزدّْغنْ ذِي ثمُّورْثْ أَذْ ثعبْذنْ، إِنِّي ؤُمِي وَارْ إِتّْوَازمّمنْ \add إِسْمَاونْ نْسنْ\add* ذڭْ وذْلِيسْ إِتّْوَانْضنْ ن ثُوذَارْثْ ن يزْمَارْ ونِّي ؤُمِي إِتّْوَاغَارْصْ قْبڒْ ثَامَارْسِيوْثْ ن دُّونشْثْ. \x ◘ \xo 13:‏8 \xt ؤُف. 32‏:‏33؛ فِيل. 4‏:‏3؛ أَسَا. 3‏:‏5؛ 17‏:‏8؛ 20‏:‏12؛ 21‏:‏27؛ أَسَا. 21‏:‏27. \x*
\v 9 ونِّي غَارْ دْجَانْ إِمزُّوغنْ، أجّْ إِ-ث أَذْ إِسڒْ.
\m 
\v 10 مَاڒَا \add ذِينْ\add* إِجّنْ ونِّي إِسِّيذْفنْ غَارْ ثْمحْبَاسْثْ، أَذْ إِتّْوَانْذهْ نتَّا \add س يِيخفْ نّسْ\add* غَارْ ثْمحْبَاسْثْ. إِنِّي إِنْغِينْ س سِّيفْ، أَذْ تّْوَانْغنْ س سِّيفْ: أَقَا ذَا \add إِتّْبَانْ-د\add* لْ-إِيمَانْ ذ صّْبَارْ ن إِمْقدَّاسنْ. \x ◘ \xo 13:‏10 \xt أَمز. 9‏:‏6؛ إِرْم. 43‏:‏11؛ مت. 26‏:‏52؛ أَسَا. 14‏:‏12. \x*
\b
\m 
\v 11 \add خنِّي\add* ژْرِيغْ \bd إِجّْ ن ڒْوحْشْ نّغْنِي إِتّْڭعَّاذْ-د زِي ثمُّورْثْ.\bd* ثُوغَا غَارسْ ثْنَاينْ ن وَاشَّاونْ ؤُشَا يَارْوسْ ذڭْ إِزْمَارْ، \add مَاشَا\add* إِسِّيوڒْ أَمْ ڒْهَايْشثْ. \x ◘ \xo 13:‏11 \xt أَسَا. 11‏:‏7. \x*
\v 12 ثُوغَا إِحكّمْ س مَارَّا صُّولْطَا ن ڒْوحْشْ أَمزْوَارُو زَّاثسْ، يَارَّا-د ثَامُّورْثْ ذ إِمزْذَاغْ نّسْ مَارَّا أَذْعبْذنْ ڒْوحْشْ أَمزْوَارُو، ونِّي إِڭّنْفَانْ زڭْ ؤُيزِّيمْ إِ إِڭِّينْ أَخْمِي إِيْزمْ أَڒْ ڒْموْثْ. \x ◘ \xo 13:‏12 \xt أَسَا. 19‏:‏20. \x*
\v 13 نتَّا أَذْ إِڭّْ ڒعْڒَامَاثْ ثِيمقّْرَانِينْ أَڒَامِي إِ غَا يَارّْ ثِيمسِّي أَذْ د-ثهْوَا زڭْ ؤُجنَّا خْ ثمُّورْثْ قِيبَاتْشْ إِ \add ثِيطَّاوِينْ ن\add* إِوْذَانْ. \x ◘ \xo 13:‏13 \xt 2 تس. 2‏:‏9؛ أَسَا. 16‏:‏14. \x*
\v 14 أَذْ إِغْوَا إِنِّي إِزدّْغنْ ذِي ثمُّورْثْ س ڒعْڒَامَاثْ إِ ذ أَسْ إِمّوْشنْ حِيمَا أَذْ ثنْثْ إِڭّْ قِيبَاتْشْ إِ \add ثِيطَّاوِينْ ن\add* ڒْوحْشْ \add أَمزْوَارُو\add*، مَاحنْذْ أَذْ يِينِي إِ يِينِّي إِزدّْغنْ ذِي ثمُّورْثْ أَذْ كَّارنْ أَذْ سّْبدّنْ إِجّْ ن ڒخْيَاڒْ إِ ڒْوحْشْ، ونِّي ثُوغَا إِيْزمْ س سِّيفْ، \add مَاشَا\add* إِدَّارْ \add عَاذْ\add*. \x ◘ \xo 13:‏14 \xt أَعَوذ. 13‏:‏2؛ مت. 24‏:‏24؛ أَسَا. 16‏:‏14؛ 19‏:‏20. \x*
\v 15 ؤُشَا إِمّوْشْ أَسْ أَذْ إِڭّْ إِجّْ ن أَرُّوحْ إِ ڒخْيَاڒْ ن ڒْوحْشْ ؤُ حِيمَا أَذْ إِڭّْ بلِّي مَارَّا إِنِّي وَارْ إِعبّْذنْ ڒْوحْشْ، أَذْ تّْوَانْغنْ. \x ◘ \xo 13:‏15 \xt أَسَا. 19‏:‏20. \x*
\v 16 ؤُشَا أَذْ إِڭّْ مَاحنْذْ أَذْ ثمّوْشْ إِ مَارَّا، إِ إِمژْيَاننْ ذ إِمقّْرَاننْ، إِ أَيْثْبَابْ ن وَاڭْڒَا ذ إِمزْڒَاضْ، إِ أَيْثْ ن شَّانْ ذ إِسمْغَانْ، إِشْثْ ن ڒْمَارْكَا خْ ؤُفُوسْ نْسنْ أَفُوسِي نِيغْ خْ ثنْيَارْثْ نْسنْ، \f ◼ \fr 13:‏16 \ft \bd ’ثَانْيَارْثْ‘\bd* - نِيغْ: ’ثَاوَارْنَا‘.\f*
\v 17 مَاحنْذْ ؤُڒَا ذ إِجّْ وَارْ إِزمَّارْ أَذْ إِسغْ نِيغْ أَذْ إِزّنْزْ مْغِيرْ ونِّي خْ ثدْجَا ڒْمَارْكَا ن يِيسمْ ن ڒْوحْشْ نِيغْ نُّومْرُو ن يِيسمْ نّسْ. \x ◘ \xo 13:‏17 \xt أَسَا. 14‏:‏11. \x*
\m 
\v 18 ذَانِيثَا ثدْجَا ثِيغِيثْ: ونِّي غَارْ إِدْجَا ڒعْقڒْ، أجّْ إِ-ث أَذْ إِحْسبْ نُّومْرُو ن ڒْوحْشْ، مِينْزِي نتَّا ذ نُّومْرُو ن إِجّْ ن بْنَاذمْ ؤُشَا نُّومْرُو نّسْ ذ ستَّا-مْيَا ؤُ-ستَّا ؤُ-ستِّينْ. \x ◘ \xo 13:‏18 \xt 1 إِج. 10‏:‏14؛ 2 إِم. 9‏:‏13؛ عِز. 2‏:‏13؛ أَسَا. 17‏:‏9. \x*
\b
\b
\c 14
\s1 إِزْمَارْ خْ وذْرَارْ ن صِيهْيُونْ
\m 
\v 1 ؤُشَا ژْرِيغْ، أَقَا إِزْمَارْ إِبدّْ-د خْ وذْرَارْ ن صِيهْيُونْ، ؤُشَا أَكِيذسْ مْيَا ؤُ-أَربْعَا ؤُ-ربْعِينْ-أَڒفْ، إِنِّي خْ ثنْيَارْثْ نْسنْ يُورَا إِسمْ نّسْ ذ يِيسمْ ن بَابَاسْ. \x ◘ \xo 14:‏1 \xt 2 إِم. 23‏:‏7؛ إِشا. 31‏:‏4؛ إِزهد. 2‏:‏6؛ أَسَا. 7‏:‏4\x*
\m 
\v 2 سْڒِيغْ إِشْثْ ن ثْمِيجَّا ثُوسَا-د زڭْ ؤُجنَّا، أَمْ ڒْحسّْ ن وَاطَّاسْ ن وَامَانْ ؤُ أَمْ ڒْحسّْ ن وَاجَّاجْ أَمقّْرَانْ، ؤُشَا ڒْحسّْ إِ سْڒِيغْ ثُوغَا أَمْ يِيجّْ ن بُو-لهَارْپَا إِتِّيرَارنْ ذِي لهَارْپَا نّسْ. \x ◘ \xo 14:‏2 \xt يُووِ. 4‏:‏8؛ أَسَا. 1‏:‏15؛ 5‏:‏8؛ 10‏:‏3\x*
\v 3 أَقَا نِيثْنِيغنّْجنْ \add مِينْ إِدْجَانْ\add* أَمْ يِيجّْ ن يزْڒِي ن ؤُصبّحْ ذ جْذِيذْ \add قَاعْ\add* زَّاثْ إِ ڒْعَارْشْ ؤُ زَّاثْ إِ أَربْعَا ن إِمُودَّارنْ ذ إِمْغَارنْ، ؤُشَا ؤُڒَا ذ إِجّْ وَارْ إِزمَّارْ أَذْ إِڒْمذْ إِزْڒِي \add أَيَا\add* ن ؤُصبّحْ مْغِيرْ مْيَا ؤُ-أَربْعَا ؤُ-ربْعِينْ-أَڒفْ، إِنِّي إِتّْوَافْذِينْ زِي ثمُّورْثْ. \x ◘ \xo 14:‏3 \xt أَسَا. 5‏:‏9. \x*
\v 4 إِنَا ذ إِنِّي وَارْ إِسّفْسذنْ إِخفْ نْسنْ أَكْ-ذ ثمْغَارِينْ، مِينْزِي نِيثْنِي ذ إِعزْرِييّنْ إِمزْذَاڭنْ. نِيثْنِي ضفَّارنْ إِزْمَارْ مَانِي مَا إِكَّا. أَقَا إِنَا إِتّْوَافْذِينْ زڭْ إِوْذَانْ \add أَمْ\add* \add صَّابثْ\add* ثَامزْوَارُوثْ إِ أَربِّي ؤُ إِ يزْمَارْ. \x ◘ \xo 14:‏4 \xt 2 كُور. 11‏:‏2. \x*
\v 5 أَقَا وَارْ إِتّْوِيفِّي شَا ڒْغشّْ ذڭْ ؤُقمُّومْ نْسنْ، أَقَا وَارْ ذَايْسنْ بُو ڒْعِيبْ. \x ◘ \xo 14:‏5 \xt صَاف. 3‏:‏13؛ أَفا. 5‏:‏27. \x*
\b
\s1 ثْڒَاثَا ن لْمَالَاكَاثْ
\m 
\v 6 ؤُشَا ژْرِيغْ \bd إِجّْ ن لْمَالَاكْ نّغْنِي\bd* ثُوغَا إِطَّاوْ ذِي ڒْوسْطْ ن ؤُجنَّا، غَارسْ ڒخْبَارْ أَصبْحَانْ إِ ڒبْذَا حِيمَا أَذْ زَّايسْ إِبَارّحْ إِ يِينِّي إِزدّْغنْ ذِي ثمُّورْثْ، إِ كُوڒْ ڒْڭنْسْ ذ شّعْبْ ذ ثقْبِيتْشْ ذ يِيڒسْ،
\v 7 ؤُشَا إِنَّا س جّهْذْ:
\b
\m \qt ”ڭّْوذمْ أَربِّي، وْشمْ أَسْ-د أَعُودْجِي،\qt*
\m \qt أَقَا ثَاسَاعّثْ ن لْحِيسَابْ نّسْ ثِيوضْ-د.\qt*
\m \qt سجْذمْ إِ ونِّي إِڭِّينْ أَجنَّا ذ ثمُّورْثْ\qt*
\m \qt ذ ڒبْحَارْ ذ ثَاڒَاوِينْ ن وَامَانْ.“\qt* \x ◘ \xo 14:‏7 \xt أَمز. 1‏:‏1؛ إِزهد. 33‏:‏6؛ 124‏:‏8؛ 146‏:‏6؛ ڒخ. 14‏:‏15؛ 17‏:‏24. \x*
\b
\m 
\v 8 ؤُشَا \bd ونّغْنِي، ونِّي ذ وِيسّْ ثْنَاينْ\bd*، إِضْفَارْ إِ-ث، إِنَّا:
\b
\m \qt ”أَقَا ثوْضَا، أَقَا ثوْضَا \tl ثنْذِينْثْ\tl* ثَامقّْرَانْثْ بَابِيلْ،\qt*
\m \qt إِ يجِّينْ أَذْ سْونْ مَارَّا ڒڭْنُوسْ \tl زِي بِينُو\tl*\qt*
\m \qt ن ثفْقحْثْ ن فَارْقْ-شّْغڒْ نّسْ.“\qt* \x ◘ \xo 14:‏8 \xt إِشا. 21‏:‏9؛ إِرْم. 51‏:‏8؛ أَسَا. 16‏:‏19؛ 17‏:‏5؛ 18‏:‏2، 10، 21. \x*
\b
\m 
\v 9 ؤُشَا \bd ونّغْنِي، إِجّْ ن لْمَالَاكْ وِيسّْ ثْڒَاثَا\bd*، إِضْفَارْ إِ-ثنْ ؤُشَا إِڒَاغَا س جّهْذْ:
\b
\m \qt ”ونِّي إِعبْذنْ ڒْوحْشْ ذ ڒخْيَاڒْ نّسْ\qt*
\m \qt ذ ونِّي إِكْسِينْ ڒْمَارْكَا خْ ثنْيَارْثْ نّسْ\qt*
\m \qt نِيغْ ذڭْ ؤُفُوسْ نّسْ،\qt*
\m 
\v 10 \qt ذ نتَّا أَذْ إِسُو عَاوذْ\qt*
\m \qt زِي بِينُو ن ثفْقحْثْ ن سِيذِي،\qt*
\m \qt ونِّي إِسّْوجْذنْ بْڒَا أَخدْجضْ\qt*
\m \qt ذِي ڒْكَاسْ ن وغْضَابْ نّسْ،\qt*
\m \qt ؤُشَا أَذْ إِتّْوَاعدّبْ\qt*
\m \qt س ثْمسِّي ذ ڒشْبَاريّثْ\qt*
\m \qt قِيبَاتْشْ إِ \tl ثِيطَّاوِينْ ن\tl* لْمَالَاكَاثْ إِقدّْسنْ\qt*
\m \qt ؤُ قِيبَاتْشْ إِ \tl ثِيطَّاوِينْ ن\tl* يزْمَارْ.\qt* \x ◘ \xo 14:‏10 \xt أَسَا. 16‏:‏19؛ 18؛6؛ 19‏:‏20. \x*
\m 
\v 11 \qt ؤُشَا دّخَّانْ ن ؤُعدّبْ نْسنْ\qt*
\m \qt أَذْ إِقِّيمْ إِڭعّذْ إِ ڒبْذَا قَاعْ.\qt*
\m \qt وَارْ ذِينْ بُو أَرَّاحثْ أَسّْ ذ دْجِيڒثْ\qt*
\m \qt إِ ونِّي إِسجّْذنْ إِ ڒْوحْشْ ذ ڒخْيَاڒْ نّسْ\qt*
\m \qt ؤُ إِ ونِّي إِكْسِينْ ڒْمَارْكَا ن يِيسمْ نّسْ.\qt* \x ◘ \xo 14:‏11 \xt أَسَا. 19‏:‏3. \x*
\m 
\v 12 \qt أَقَا ذَا \tl إِتّْبَانْ-د\tl* صّْبَارْ ن إِمْقدَّاسنْ،\qt*
\m \qt إِنِّي إِتّطّْفنْ ذِي ثْوصَّا ن أَربِّي\qt*
\m \qt ؤُ حطَّانْ لْ-إِيمَانْ ن يَاسُوع.“\qt* \x ◘ \xo 14:‏12 \xt أَسَا. 13‏:‏10. \x*
\b
\m 
\v 13 ؤُشَا سْڒِيغْ إِشْثْ ن ثْمِيجَّا ثتّْڒَاغَا-د زڭْ ؤُجنَّا، ثقَّارْ:
\b
\m \qt ”أَرِي:\qt* \bdit سّعْذْ\bdit* \qt ن إِمتِّيننْ\qt*
\m \qt إِنِّي إِ غَا مّْثنْ ذِي سِيذِيثْنغْ،\qt*
\m \qt زِي ڒخُّو ثْسَاونْثْ!“\qt*
\b
\m \qt ”وَاهْ، إِنَّا أَرُّوحْ، مَاغَارْ أَذْ أَريّْحنْ\qt*
\m \qt زِي ڒخْذَايمْ نْسنْ!“،\qt*
\m \qt \tl أَقَا ڒخْذَايمْ نْسنْ أَذْ ثنْ ضْفَارنْثْ.\tl*\qt*
\b
\s1 ثَاميْرَا ن ثمُّورْثْ
\m 
\v 14 ؤُشَا ژْرِيغْ، أَقَا \bd إِجّْ ن ؤُسيْنُو ذ أَشمْڒَاڒْ\bd*، ؤُشَا خْ ؤُسيْنُو إِقِّيمْ خَاسْ ونِّي يَارْوسنْ ذڭْ إِجّْ ن \bd مِّيسْ ن بْنَاذمْ\bd*، غَارسْ تَّاجْ ن وُورغْ خْ ؤُزدْجِيفْ نّسْ ؤُ أَمْجَارْ إِقْضعْ ذڭْ ؤُفُوسْ نّسْ. \x ◘ \xo 14:‏14 \xt حِز. 1‏:‏26؛ دَان. 7‏:‏13؛ أَسَا. 1‏:‏13. \x*
\b
\m 
\v 15 ؤُشَا \bd إِجّْ ن لْمَالَاكْ نّغْنِي\bd* إِفّغْ-د زِي زَّاوشْثْ ثَامقّْرَانْثْ ؤُشَا إِڒَاغَا س جّهْذْ خْ ونِّي إِقِّيمنْ خْ ؤُسيْنُو:
\b
\m \qt ”سكّْ-د أَمْجَارْ نّشْ، مْجَارْ!\qt*
\m \qt أَقَا ثَاسَاعّثْ ن ثْميْرَا ثِيوضْ-د!“\qt* \x ◘ \xo 14:‏15 \xt يُووِ. 4‏:‏13؛ مت. 13‏:‏39. \x*
\b
\m 
\v 16 ؤُشَا ونِّي إِقِّيمنْ خْ ؤُسيْنُو، إِسّكّْ-د أَمْجَارْ نّسْ غَارْ ثمُّورْثْ ؤُشَا ثتّْوَامْجَارْ ثمُّورْثْ.
\m 
\v 17 ؤُشَا \bd إِجّْ ن لْمَالَاكْ نّغْنِي\bd* إِفّغْ-د زِي زَّاوشْثْ ثَامقّْرَانْثْ إِ إِدْجَانْ ذڭْ ؤُجنَّا، \add ؤُشَا ؤُڒَا ذ\add* نتَّا غَارسْ إِجّْ ن ومْجَارْ إِقْضعْ.
\v 18 ؤُشَا \bd إِجّْ ن لْمَالَاكْ نّغْنِي\bd* ونِّي غَارْ ثدْجَا صُّولْطَا خْ ثْمسِّي، إِفّغْ-د زڭْ ؤُعَالْطَارْ، ؤُشَا إِڒَاغَا-د س جّهْذْ خْ ونِّي غَارْ إِدْجَا ومْجَارْ إِقْضعْ، إِنَّا:
\b
\m \qt ”سكّْ-د أَمْجَارْ نّشْ إِقضْعنْ،\qt*
\m \qt ڒْْقضْ إِزكُّوننْ ن ثْزَايَارِينْ ن ثمُّورْثْ،\qt*
\m \qt مِينْزِي أَضِيڒْ نّسْ أَقَا يِيوضْ.“\qt*
\b
\m 
\v 19 ؤُشَا لْمَالَاكْ إِسّكّْ-د أَمْجَارْ نّسْ غَارْ ثمُّورْثْ، إِڒْقضْ أَضِيڒْ نْ ثْزَايَارْثْ ن ثمُّورْثْ، إِنْضَارْ إِ-ث ذِي ثْسِيرْثْ ثَامقّْرَانْثْ ن وغْضَابْ ن أَربِّي. \x ◘ \xo 14:‏19 \xt أَسَا. 19‏:‏15. \x*
\v 20 حَارْينْ ذِي ثْسِيرْثْ ن ؤُضِيڒْ أَڒْ بَارَّا ن ثنْذِينْثْ ؤُشَا رُوشّنْ-د إِذَامّنْ زِي ثْسِيرْثْ أَڒَامِي إِوْضنْ غَارْ سْڒِيمَاثْ ن ييْسَانْ، ڒْقدّْ ن أَڒفْ ؤُ-مِيثَاينْ ن ’إِسْثَاذِييّنْ‘، \add إِخْسْ أَذْ يِينِي عْڒَاحَاڒْ مِيثَاينْ ؤُ-عِيشْرِينْ كِيلُومِيثْرْ\add*. \f ◼ \fr 14:‏20 \ft \bd ’إِسْثَاذِييّنْ‘\bd*\fp إِجّْ ن ڒْمڒْعبْ ذِي ڒْوقْثْ ن إِيُونَانِييّنْ ثُوغَا غَارسْ إِشْثْ ثُوزُّوڭَارْثْ ن 185 مِيثْرْ، إِخْسْ أَذْ يِينِي ’إِنّْ ن ؤُسْثَاذِييْ‘.\f*  \x ◘ \xo 14:‏20 \xt إِشا. 63‏:‏3. \x*
\b
\b
\c 15
\s1 إِژْڒِي ن إِنِّي إِغلّْبنْ
\m 
\v 1 ؤُشَا \bd ژْرِيغْ\bd* ذڭْ ؤُجنَّا إِشْثْ ن ڒعْڒَامثْ نّغْنِي، ذ ثَامقّْرَانْثْ ذ ثَانبْهثْ: \bd سبْعَا ن لْمَالَاكَاثْ نِّي د-إِوْينْ سبْعَا ن جّْرَايحْ ثِينڭُّورَا\bd*، مِينْزِي إِكْمڒْ زَّايْسنْثْ وغْضَابْ ن أَربِّي. \x ◘ \xo 15:‏1 \xt إِزهد. 7‏:‏12؛ أَسَا. 11‏:‏14. \x*
\b
\m 
\v 2 ؤُشَا ژْرِيغْ شَا إِتّمْشَابهْ ذِي ڒبْحَارْ ن زَّاجْ، ونِّي إِخدْجْضنْ أَكْ-ذ ثْمسِّي، ؤُشَا إِنِّي إِغلّْبنْ خْ ڒْوحْشْ ذ ڒخْيَاڒْ نّسْ ذ نُّومْرُو ن يِيسمْ نّسْ، بدّنْ خْ ڒبْحَارْ ن زَّاجْ، غَارْسنْ لهَارْپَاثْ ن أَربِّي.\x ◘ \xo 15:‏2 \xt أَسَا. 4‏:‏6؛ مِيخَا 7‏:‏18. \x*
\v 3 نِيثْنِيغنّْجنْ إِزْڒِي ن ؤُصبّحْ ن مُوسَا، أَمْسخَّارْ ن أَربِّي، ذ يزْڒِي ن ؤُصبّحْ ن يزْمَارْ، قَّارنْ:
\b
\m \qt ”ذ ثِيمقّْرَانِينْ ذ ثْصبْحَانِينْ ڒخْذَايمْ نّشْ،\qt*
\m \qt \tl أَ،\tl* سِيذِي أَربِّي، أَمْزمَّارْ خْ كُوڒْشِي،\qt*
\m \qt ڒخْذَايمْ نّشْ ذ ثَاسڭْذَا ذ ثِيذتّْ،\qt*
\m \qt \tl أَ\tl* أَجدْجِيذْ ن نْ زّْمَانَاثْ!\qt* \x ◘ \xo 15:‏3 \xt ؤُف. 15‏:‏1‏-‏21؛ أَعَوذ. 32‏:‏1‏-‏44؛ إِزهد. 111‏:‏2؛ 139‏:‏14؛ 145‏:‏17. \x*
\m 
\v 4 \qt مَانْ ونْ وَارْ شكْ إِتّڭّْوذنْ، \tl أَ\tl* سِيذِي،\qt*
\m \qt مَانْ ونْ وَارْ إِسّمْغَارَانْ إِسمْ نّشْ؟\qt*
\m \qt شكْ وحّْذكْ إِ إِدْجَانْ ذ أَمزْذَاڭْ قَاعْ،\qt*
\m \qt مَاغَارْ مَارَّا ڒڭْنُوسْ أَذْ د-أَسنْ،\qt*
\m \qt أَذْ سجْذنْ زَّاثكْ،\qt*
\m \qt مِينْزِي شكْ ثْبَانذْ ذ أَمْسڭّذْ\qt*
\m \qt ذِي ڒحْكَامَاثْ نّشْ.“\qt* \x ◘ \xo 15:‏4 \xt إِرْم. 10‏:‏6، 7؛ زَاك. 14‏:‏16‏-‏20 \x*
\b
\m 
\v 5 أَوَارْنِي أَسْ ژْرِيغْ، أَقَا ثنُّورْزمْ زَّاوشْثْ ثَامقّْرَانْثْ ن ثْزذِّيغْثْ ن شّْهَاذثْ ذڭْ ؤُجنَّا \x ◘ \xo 15:‏5 \xt أَسَا. 11‏:‏19. \x*
\v 6 ؤُشَا سبْعَا ن لْمَالَاكَاثْ نِّي غَارْ دْجَانْثْ سبْعَا ن جّْرَايحْ فّْغنْثْ-إِ-د زِي زَّاوشْثْ ثَامقّْرَانْثْ، يَارْضنْثْ ڒقْطنْ أَزْذَاذْ إِزْذِيڭنْ إِتِّيسِّيقنْ، ؤُشَا غَارْسنْ خْ إِذْمَارنْ إِجّْ ن وبْيَاسْ ن وُورغْ. \x ◘ \xo 15:‏6 \xt أَسَا. 1‏:‏13. \x*
\v 7 ؤُشَا إِجّنْ زِي أَربْعَا ن إِمُودَّارنْ إِوْشَا أَسنْ إِ سبْعَا ن لْمَالَاكَاثْ \bd سبْعَا ن طَّاوْيَاثْ\bd*، شُّورنْثْ س وغْضَابْ ن أَربِّي، ونِّي ذ ثُوذَارْثْ إِ ڒبْذَا قَاعْ. ”أَمِينْ!“
\v 8 ؤُشَا ثتّْوَاعمَّارْ زَّاوشْثْ ثَامقّْرَانْثْ س دّخَّانْ \add إِ د-إِتّفّْغنْ\add* زڭْ ؤُعُودْجِي ن أَربِّي ؤُ زِي جّهْذْ نّسْ. ؤُڒَا ذ إِجّنْ وَارْ إِزمَّارْ أَذْ د-يَاذفْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ أَڒْ غَا كّنْثْ قَاعْ سبْعَا ن جّْرَايحْ ثِينِّي د-إِوْينْ سبْعَا ن لْمَالَاكَاثْ. \x ◘ \xo 15:‏8 \xt ؤُف. 40‏:‏34؛ 1 إِج. 8‏:‏10؛ 2 إِم. 5‏:‏14؛ إِشا. 6‏:‏4. \x*
\b
\b
\c 16
\s1 سبْعَا ن لْمَالَاكَاثْ س سبْعَا ن طَّاوْيَاثْ
\m 
\v 1 ؤُشَا \bd سْڒِيغْ\bd* إِشْثْ ن ثْمِيجَّا زِي زَّاوشْثْ ثَامقّْرَانْثْ ثتّْڒَاغَا خْ سبْعَا ن لْمَالَاكَاثْ نِّي، ثنَّا:
\b
\m \qt ”ؤُيُورنْثْ، تّْفَارّْغنْثْ سبْعَا ن طَّاوْيَاثْ ن وغْضَابْ ن أَربِّي خْ ثمُّورْثْ!“\qt* \x ◘ \xo 16:‏1 \xt إِشا. 66‏:‏6\x*
\b
\m 
\v 2 ونِّي ذ \bd أَمزْوَارُو\bd* يُويُورْ، إِفَارّغْ طَّاوْيَا نّسْ خْ ثمُّورْثْ. ؤُشَا إِذْوڒْ إِجّْ ن ؤُبُوعْرُوسْ ذ أَعفَّانْ إِقْبحْ غَارْ إِوْذَانْ إِ غَارْ ثدْجَا ڒْمَارْكَا ن ڒْوحْشْ، إِنِّي إِسجْذنْ إِ ڒخْيَاڒْ نّسْ. \f ◼ \fr 16:‏2 \ft \bd ’ڒخْيَاڒْ‘\bd* - نِيغْ ’ثِيمْثَالْ‘.\f*  \x ◘ \xo 16:‏2 \xt ؤُف. 9‏:‏9، 10، 11؛ 1 صم. 5‏:‏9؛ أَسَا. 13‏:‏14، 16، 17. \x*
\m 
\v 3 خنِّي إِفَارّغْ \bd لْمَالَاكْ وِيسّْ ثْنَاينْ\bd* طَّاوْيَا نّسْ ذِي ڒبْحَارْ ؤُشَا إِذْوڒْ ڒبْحَارْ أَمْ \add إِذَامّنْ ن إِجّْ ن\add* ؤُمتِّينْ، ؤُشَا كُوڒْ ڒعْمَارْ إِدَّارنْ ذِي ڒبْحَارْ إِمُّوثْ. \x ◘ \xo 16:‏3 \xt ؤُف. 7‏:‏17، 18، 20\x*
\m 
\v 4 خنِّي إِفَارّغْ \bd لْمَالَاكْ وِيسّْ ثْڒَاثَا\bd* طَّاوْيَا نّسْ خْ إِغزْرَانْ ذ ثَاڒَاوِينْ، ؤُشَا أَمَانْ نْسنْ ذوْڒنْ ذ إِذَامّنْ.
\b
\m 
\v 5 ؤُشَا سْڒِيغْ إِ لْمَالَاكْ ن وَامَانْ إِقَّارْ:
\b
\m \qt ”شكْ ذ أَمْسڭَّاذْ،\qt*
\m \qt شكْ ذ ونِّي إِدْجَانْ ذ ونِّي ثُوغَا،\qt*
\m \qt ذ ونِّي ذ أَمزْذَاڭْ قَاعْ،\qt*
\m \qt ؤُمِي ثْكمّْڒذْ ڒحْكَامَاثْ-أَ أَمُّو.\qt* \x ◘ \xo 16:‏5 \xt أَسَا. 1‏:‏4، 8؛ 4‏:‏8؛ 11‏:‏17. \x*
\m 
\v 6 \qt مِينْزِي نِيثْنِي سِّيزّْڒنْ إِذَامّنْ\qt*
\m \qt ن إِنَابِييّنْ ذ إِمْقدَّاسنْ،\qt*
\m \qt ثوْشِيذْ أَسنْ \add عَاوذْ\add* أَذْ سْونْ إِذَامّنْ،\qt*
\m \qt مَاغَارْ أَمُّو إِ ذ أَسنْ د-إِفّغْ.“\qt* \x ◘ \xo 16:‏6 \xt مت. 23‏:‏34. \x*
\b
\m 
\v 7 ؤُشَا سْڒِيغْ أَقَا أَعَالْطَارْ إِقَّارْ:
\b
\m \qt ”وَاهْ، أَ سِيذِي أَربِّي، أَمْزمَّارْ خْ كُوڒْشِي،\qt*
\m \qt ڒحْكَامَاثْ نّشْ ذ ثِيذتّْ ذ ثَاسڭْذَا.“\qt* \x ◘ \xo 16:‏7 \xt أَسَا. 15‏:‏3. \x*
\b
\m 
\v 8 خنِّي إِفَارّغْ \bd لْمَالَاكْ وِيسّْ أَربْعَا\bd* طَّاوْيَا نّسْ خْ ثْفُوشْثْ ؤُشَا ثمّوْشْ أَسْ \add إِ ثْفُوشْثْ\add*، حِيمَا أَذْ ثشْنفْ إِوْذَانْ س ثْمسِّي.
\v 9 ؤُشَا شمْضنْ إِوْذَانْ س ڒْعابُوقْ إِمْغَارنْ ن ثْمسِّي ؤُشَا شقّْفنْ ذڭْ يِيسمْ ن أَربِّي ونِّي غَارْ ثدْجَا صُّولْطَا خْ جّْرَايحْ-أَ ؤُشَا وَارْ ثُوبنْ شَا مَاحنْذْ أَذْ أَسْ وْشِينْ أَعُودْجِي. \x ◘ \xo 16:‏9 \xt أَسَا. 16‏:‏11، 21. \x*
\m 
\v 10 خنِّي إِفَارّغْ \bd لْمَالَاكْ وِيسّْ خمْسَا\bd* طَاوْيَا نّسْ خْ ڒْعَارْشْ ن ڒْوحْشْ ؤُشَا ثوْضَا-د ثَادْجسْثْ خْ ثْڭلْذِيثْ ن ڒْوحْشْ. ؤُشَا زعْفنْ ذڭْ إِڒسْ نْسنْ س سِّيبّثْ ن ڒحْرِيقْ
\v 11 ؤُشَا شقّْفنْ ذڭْ يِيسمْ ن أَربِّي ن إِجنْوَانْ س سِّيبّثْ ن ڒحْرِيقْ ذ إِبُوعْرُوسنْ نْسنْ، \add مَاشَا\add* وَارْ ثُوبنْ شَا زِي ڒخْذَايمْ نْسنْ.
\m 
\v 12 خنِّي إِفَارّغْ \bd لْمَالَاكْ وِيسّْ ستَّا\bd* طَّاوْيَا نّسْ ذڭْ إِغْزَارْ أَمقّْرَانْ، \add إِغْزَارْ ن\add* لْفُورَاطْ ؤُشَا ؤُژْغنْ وَامَانْ نّسْ، أَڒَامِي إِسّوْجذْ أَبْرِيذْ إِ إِجدْجِيذنْ إِنِّي د غَا يَاسنْ زِي مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ. \x ◘ \xo 16:‏12 \xt إِشا. 11‏:‏15\x*
\b
\m 
\v 13 خنِّي ژْرِيغْ، أَقَا ثْڒَاثَا ن ڒَارْيَاحْ إِمنْڭَاسْ أَمْ إِقَارْقْرِيونْ \add فّْغنْ-د\add* زڭْ ؤُخنْفُوشْ ن ڒْهَايْشثْ ؤُ زڭْ ؤُقمُّومْ ن ڒْوحْشْ ؤُ زڭْ ؤُقمُّومْ ن ؤُنَابِي إِسّْخَارِّيقنْ،
\v 14 مَاغَارْ نِيثْنِي ذ ڒَارْيَاحْ ن شّْوَاطنْ إِنِّي إِتّڭّنْ ڒعْڒَامَاثْ إِ ذ إِڭُّورنْ غَارْ إِجدْجِيذنْ ن دُّونشْثْ، مَاحنْذْ أَذْ ثنْ سّْمُوننْ إِ ؤُمنْغِي ذڭْ وَاسّْ أَمقّْرَانْ ن أَربِّي، أَمْزمَّارْ خْ كُوڒْشِي. \x ◘ \xo 16:‏14 \xt 2 تس. 2‏:‏9؛ أَسَا. 13‏:‏13؛ 17‏:‏14؛ 19‏:‏19، 20؛ 20‏:‏8. \x*
\b
\m 
\v 15 \qt ”خْزَارْ، نشّْ أَذْ د-أَسغْ\qt*
\m \qt أَمْ يِيجّْ ن ؤُشفَّارْ!\qt*
\m \bdit سّعْذْ\bdit* \qt ن ونِّي إِ غَا إِقِّيمنْ إِفَاقْ،\qt*
\m \qt ونِّي إِ غَا إِحْضَانْ أَرُّوضْ نّسْ\qt*
\m \qt حِيمَا وَارْ إِڭُّورْ ذ أَعَارْيَانْ،\qt*
\m \qt وَارْ إِتّْوَاژَارْ ؤُسضْحِي نّسْ.“\qt* \x ◘ \xo 16:‏15 \xt مت. 24‏:‏43؛ لك. 12‏:‏39؛ 1 تس. 5‏:‏2؛ 2 بُط. 3‏:‏10؛ أَسَا. 3‏:‏3، 18. \x*
\b
\m 
\v 16 ؤُشَا إِسّْمُونْ إِ-ثنْ غَارْ ومْشَانْ ؤُمِي تّْڒَاغَانْ س ثْعِيبْرَانِيثْ ’مڭِيدُّو‘.
\b
\m 
\v 17 خنِّي إِفَارّغْ \bd لْمَالَاكْ وِيسّْ سبْعَا\bd* طَّاوْيَا نّسْ خْ ڒعْوِينْ ؤُشَا ثُوسَا-د إِشْثْ ن ثْمِيجَّا ثجْهذْ زِي زَّاوشْثْ ثَامقّْرَانْثْ، زِي زَّاثْ ن ڒْعَارْشْ، ثقَّارْ:
\b
\m \qt ”أَقَا إِتّْوَاكمّڒْ!“\qt* \x ◘ \xo 16:‏17 \xt إِشا. 66‏:‏6؛ أَسَا. 21‏:‏6. \x*
\b
\m 
\v 18 ؤُشَا ؤُسِينْ-د وَاسَّامنْ ذ وَاجَّاجنْ، ؤُشَا إِمْسَارْ إِجّْ ن ونْهزِّي ن ثمُّورْثْ ذ أَمقّْرَانْ، وَارْ ثمْسَارْ أَمُّو زڭْ وَامِي إِدْج بْنَاذمْ ذِي ثمُّورْثْ، أَمُّو إِ إِمْغَارْ. \x ◘ \xo 16:‏18 \xt أَسَا. 4‏:‏5؛ 8‏:‏5. \x*
\v 19 ثَانْذِينْثْ ثَامقّْرَانْثْ ثوْضَا ثبْضَا خْ ثْڒَاثَا ن ثْسقَّارْ ؤُشَا مَارَّا ثِيندَّامْ ن ڒڭْنُوسْ هذْمنْثْ ؤُشَا أَربِّي إِعْقڒْ خْ \add ثنْذِينْثْ\add* ثَامقّْرَانْثْ بَابِيلْ، حِيمَا أَذْ أَسْ إِوْشْ ڒْكَاسْ ن بِينُو ن ثفْقحْثْ ن وغْضَابْ نّسْ. \x ◘ \xo 16:‏19 \xt إِزهد. 75‏:‏9؛ إِرْم. 25‏:‏15؛ أَسَا. 14‏:‏8، 10؛ 18‏:‏5. \x*
\v 20 ؤُشَا كُوڒْ ثَاڭْزِيرْثْ ثَارْوڒْ، وَارْ تّْوِيفِينْ شَا إِذُورَارْ \add عَاذْ\add*،
\v 21 وْضَانْ-د إِبْقُوقنْ إِمقّْرَاننْ ن ثبْرُورِي زڭْ ؤُجنَّا خْ إِوْذَانْ، ثُوغَا دّْقڒْ نْسنْ أَنشْثْ ن إِشْثْ ن ’ثَالِينْثْ‘، ؤُشَا إِوْذَانْ شقّْفنْ ذِي أَربِّي زِي سِّيبّثْ ن جّْرِيحشْثْ ن ثبْرُورِي، مِينْزِي جّْرِيحشْثْ نّسْ ثُوغَا ثمْغَارْ أَطَّاسْ. \x ◘ \xo 16:‏21 \xt أَسَا. 11‏:‏19؛ 16‏:‏9، 11. \x*
\b
\b
\c 17
\s1 ثَامْغَارْثْ إِ إِقِّيمنْ خْ ڒْوحْشْ
\m 
\v 1 \bd ؤُشَا يُوسَا-د إِجّنْ زِي سبْعَا ن لْمَالَاكَاثْ\bd*، ثِينِّي غَارْ إِدْجَا سبْعَا ن طَّاوْيَاثْ، إِسِّيوڒْ أَكِيذِي، إِنَّا:
\b
\m \qt ”أَسْ-د، أَذْ أَشْ سّشْنغْ ڒْحُوكْمْ\qt*
\m \qt خْ ثمْغَارْثْ ن فَارْقْ-شّْغڒْ\qt*
\m \qt إِ إِقِّيمنْ خْ وَاطَّاسْ ن وَامَانْ،\qt*
\m 
\v 2 \qt ثنِّي زِي سّْفسْذنْ إِجدْجِيذنْ ن ثمُّورْثْ\qt*
\m \qt إِخفْ نْسنْ،\qt*
\m \qt ؤُشَا مَارَّا إِمزْذَاغْ ن ثمُّورْثْ\qt*
\m \qt سْشَارنْ س بِينُو ن فَارْقْ-شّْغڒْ نّسْ.“\qt*
\b
\m 
\v 3 إِنْذهْ أَيِي ذِي أَرُّوحْ غَارْ ڒخْڒَا ؤُشَا ژْرِيغْ إِشْثْ ن ثْمطُّوثْ ثنْيَا خْ إِجّْ ن ڒْوحْشْ أَزڭّْوَاغْ إِحذْقنْ، إِشُّورنْ س إِسْمَاونْ ن تّكْفِيرْ، ثُوغَا غَارسْ سبْعَا ن إِزدْجِيفنْ ذعشْرَا ن وَاشَّاونْ. \x ◘ \xo 17:‏3 \xt أَسَا. 13‏:‏1؛ 17‏:‏8. \x*
\v 4 ثُوغَا ثَامطُّوثْ ثْيَارْضْ ثَاقنْذُورْثْ ثُورْجُووَانِيثْ ذ ثَازڭّْوَاغْثْ إِحذْقنْ ثقّنْ س وُورغْ ذ يژْرَا إِغْڒَانْ ذ ثْيَاقُوثِينْ. ثُوغَا غَارسْ ذڭْ ؤُفُوسْ نّسْ إِجّْ ن ؤُغَارَّافْ ن وُورغْ إِشُّورْ س ڒخْمجْ ؤُ س نّْعِي ن فَارْقْ-شّْغڒْ نّسْ. \x ◘ \xo 17:‏4 \xt أَسَا. 18‏:‏16. \x*
\v 5 إِتّْوَارِي خْ ثنْيَارْثْ نّسْ إِجّْ ن إِسمْ: ’سِّيرّْ ن بَابِيلْ ثَامقّْرَانْثْ، يمَّاثْسنْثْ ن ثمْغَارِينْ ن فَارْقْ-شّْغڒْ ذ مَارَّا نّْعَاوَاثْ ن ثمُّورْثْ‘. \x ◘ \xo 17:‏5 \xt 2 تس. 2‏:‏7. \x*
\v 6 ؤُشَا ژْرِيغْ ثَامطُّوثْ ثسْشَارْ س إِذَامّنْ ن إِمْقدَّاسنْ ؤُ س إِذَامّنْ ن يِينِّي إِشهّْذنْ خْ يَاسُوع. أَڒَامِي ت ژْرِيغْ، تّْبهْثغْ أَطَّاسْ. \x ◘ \xo 17:‏6 \xt أَسَا. 18‏:‏24. \x*
\m 
\v 7 إِنَّا أَيِي لْمَالَاكْ: ”مَايمِّي ثتّْبهْثذْ؟ نشّْ أَذْ شكْ سَّارْڭْبغْ خْ سِّيرّْ ن ثْمطُّوثْ ذ ڒْوحْشْ س سبْعَا ن إِزدْجِيفنْ ذعشْرَا ن وَاشَّاونْ، ونِّي ت يَاربُّونْ.
\m 
\v 8 ڒْوحْشْ إِ ثژْرِيذْ، ذ ونِّي ثُوغَا ذ ونِّي وَارْ إِدْجِينْ، أَذْ إِڭعّذْ زِي ڒبْحَارْ، أَذْ إِودَّارْ. ؤُشَا أَذْ ثْبهْثنْ إِمزْذَاغْ ن ثمُّورْثْ، إِنِّي إِسمْ نْسنْ وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ إِتّْوَانْضنْ ن ثُوذَارْثْ زڭْ وَامِي إِتّْوَاڭّْ ذْسَاسْ ن دُّونشْثْ، \add أَذْ ثْبهْثنْ\add* خْمِي غَا ژَترنْ ڒْوحْشْ ونِّي ثُوغَا، ذ ونِّي وَارْ إِدْجِينْ، \add عَاذْ\add* أَذْ د-إِقَارّبْ. \x ◘ \xo 17:‏8 \xt ؤُف. 32‏:‏32؛ إِشا. 23‏:‏13؛ فِيل. 4‏:‏3؛ أَسَا. 13‏:‏8. \x*
\v 9 أَقَا ذَا ڒْمعْنَا \add نّسْ\add* إِ ونِّي غَارْ ثدْجَا ڒفْهَامثْ: سبْعَا ن إِزدْجِيفنْ أَقَا ذ سبْعَا ن إِذُورَارْ مِينْ خفْ ثقِّيمْ ثْمطُّوثْ. \x ◘ \xo 17:‏9 \xt أَسَا. 13‏:‏1، 18. \x*
\v 10 أَقَا-ثنْ ؤُڒَا ذ سبْعَا ن إِجدْجِيذنْ، خمْسَا زَّايْسنْ وْضَانْ، إِجّنْ أَقَا إِدْجَا \add عَاذْ\add*، ذ ونّغْنِي أَقَا-ث عَاذْ وَارْ د-يُوسِي. مَاڒَا نتَّا أَذْ د-يَاسْ، أَذْ أَسْ إِمّوْشْ ذْرُوسْ \add ن ڒْوقْثْ\add* إِ إِقِّيمنْ \add عَاذْ\add*.
\v 11 ؤُشَا ڒْهَايْشثْ ذ ڒْوحْشْ نِّي د-يِيوِي ؤُ وَارْ إِدْجِي ذ ونِّي، \add ڒْهَايْشثْ نِّي\add* أَقَا-ت ذ \add أَجدْجِيذْ\add* وِيسّْ ثْمنْيَا، \add مَاشَا\add* أَذْ ثفّغْ زِي سبْعَا نِّي ؤُشَا أَذْ ثْهلّكْ.
\m 
\v 12 عشْرَا ن وَاشَّاونْ إِ ثژْرِيذْ، أَقَا ذعشْرَا ن إِجدْجِيذنْ، وَارْ طِّيفنْ ثَاڭلْذَا عَاذْ، مَاشَا أَذْ طّْفنْ صُّولْطَا ن إِجدْجِيذنْ ڒْقدّْ ن إِشْثْ ن ثْسَاعّثْ أَكْ-ذ ڒْوحْشْ. \x ◘ \xo 17:‏12 \xt دَان. 7‏:‏20؛ أَسَا. 13‏:‏1. \x*
\v 13 نِيثْنِي غَارْسنْ أَرَّايْ ذ إِجّنْ، أَذْ وْشنْ جّهْذْ نْسنْ ذ صُّولْطَا نْسنْ إِ ڒْوحْشْ.
\v 14 إِنَا أَذْ مّنْغنْ أَكْ-ذ إِزْمَارْ ؤُشَا إِزْمَارْ أَذْ خَاسنْ إِغْڒبْ مِينْزِي نتَّا ذ سِيذِي خْ \add مَارَّا\add* إِسِيذِيثنْ ذ ؤُجدْجِيذْ خْ \add مَارَّا\add* إِجدْجِيذنْ، ؤُ إِنِّي أَكِيذسْ \add إِدْجَانْ\add* أَقَا-ثنْ ذ إِنِّي إِتّْوَاڒَاغَانْ ذ يِينِّي إِتّْوَافَارْزنْ ذ إِمْثِيقَّانْ.“ \x ◘ \xo 17:‏14 \xt 1 تِيم. 6‏:‏15؛ أَسَا. 16‏:‏14؛ 19‏:‏16. \x*
\m 
\v 15 إِنَّا أَيِي \add عَاوذْ\add*: ”أَمَانْ إِ ثژْرِيذْ إِ خْ ثقِّيمْ ثمْغَارْثْ ن فَارْقْ-شّْغڒْ، أَقَا أَثنْ ذ ڒڭْنُوسْ، ذ إِبَارُّوثنْ ن ڒْغَاشِي، ذ شُّوعُوبْ، ذ إِڒْسَاونْ. \x ◘ \xo 17:‏15 \xt إِشا. 8‏:‏7. \x*
\m 
\v 16 ؤُشَاعشْرَا ن وَاشَّاونْ إِ ثژْرِيذْ خْ ڒْوحْشْ، نِيثْنِي أَذْ شَارْهنْ ثَامْغَارْثْ ن فَارْقْ-شّْغڒْ أَذْ ت أَردّْدْجنْ، أَذْ ت أَرّنْ ذ ثَاعرْيَانْثْ، أَذْ شّنْ أَيْسُومْ نّسْ، أَذْ ت سّْشمْضنْ س ثْمسِّي. \x ◘ \xo 17:‏16 \xt أَسَا. 18‏:‏8. \x*
\v 17 مَاغَارْ أَربِّي إِوْشَا أَسنْ ذڭْ وُوڒَاونْ نْسنْ حِيمَا أَذْ ڭّنْ نّيّثْ \add ن ڒْوحْشْ\add*، ؤُ مَاحنْذْ أَذْ ت ڭّنْ س أَرَّايْ ذ إِجّنْ، ؤُشَا أَذْ وْشنْ ثَاڭلْذَا نْسنْ إِ ڒْوحْشْ أَڒْ غَا تّْوَاكمّْڒنْ أَوَاڒنْ ن أَربِّي.
\m 
\v 18 ؤُشَا ثَامطُّوثْ إِ ثژْرِيذْ، نتَّاثْ ذ ثَانْذِينْثْ ثَامقّْرَانْثْ، ثنِّي غَارْ ثدْجَا ثْڭلْذَا خْ إِجدْجِيذنْ ن ثمُّورْثْ.“ \x ◘ \xo 17:‏18 \xt أَسَا. 16‏:‏19. \x*
\b
\b
\c 18
\s1 أَوطُّو ن بَابِيلْ
\m 
\v 1 أَوَارْنِي أَسْ ژْرِيغْ \bd إِجّْ ن لْمَالَاكْ نّغْنِي إِهكّْوَا-د زڭْ ؤُجنَّا\bd*، غَارسْ صُّولْطَا ثَامقّْرَانْثْ، ؤُشَا طّْيَا ن ؤُعُودْجِي نّسْ ثڭَّا ثَافَاوْثْ كُوڒْشِي إِ ثمُّورْثْ.
\v 2 نتَّا إِڒَاغَا س ثْمِيجَّا ثجْهذْ، إِقَّارْ:
\b
\m \qt ”أَقَا ثوْضَا، ثوْضَا \tl ثنْذِينْثْ\tl* ثَامقّْرَانْثْ بَابِيلْ،\qt*
\m \qt ثذْوڒْ ذ ثَازذِّيغْثْ إِ شّْوَاطنْ\qt*
\m \qt ذ ڒحْبسْ إِ كُوڒْ ڒَارْيَاحْ أَمنْڭُوسْ أَمنْعِي،\qt* \x ◘ \xo 18:‏2 \xt إِشا. 13‏:‏21؛ 21‏:‏9؛ 34‏:‏11، 14؛ إِرْم. 50‏:‏39؛ 51‏:‏8؛ أَسَا. 14‏:‏8. \x*
\m 
\v 3 \qt مِينْزِي ثسّْخدْجضْ بِينُو ن فَارْقْ-شّْغڒْ نّسْ\qt*
\m \qt إِ مَارَّا ڒڭْنُوسْ،\qt*
\m \qt ؤُ مِينْزِي إِجدْجِيذنْ ن ثمُّورْثْ\qt*
\m \qt أَقَا سّْفسْذنْ إِخفْ نْسنْ زَّايسْ،\qt*
\m \qt ؤُ مِينْزِي إِسبَّابنْ ن ثمُّورْثْ\qt*
\m \qt ذوْڒنْ ذ ثْوَاجَّارْ\qt*
\m \qt س جّهْذْ ن ؤُطمّسْ نّسْ ن وَاڭْرَا.“\qt* \x ◘ \xo 18:‏3 \xt أَسَا. 14‏:‏8؛ 17‏:‏2. \x*
\b
\m 
\v 4 ؤُشَا سْڒِيغْ إِ ثْمِيجَّا نّغْنِي ثْڒَاغَا-د زڭْ ؤُجنَّا:
\b
\m \qt ”فّغْ زَّايسْ، \tl أَ\tl* ڒْڭنْسْ إِنُو،\qt*
\m \qt حِيمَا وَارْ تِّيڒِينْ دّْنُوبْ نّسْ خْ يِيرِي نّشْ\qt*
\m \qt ؤُشَا وَارْ ثْكسِّيذْ زِي جّْرَايحْ نّسْ،\qt* \x ◘ \xo 18:‏4 \xt أَمز. 19‏:‏12؛ إِشا. 48‏:‏20؛ 52‏:‏11؛ إِرْم. 51‏:‏6، 45؛ 2 كُور. 6‏:‏17. \x*
\m 
\v 5 \qt مِينْزِي دّْنُوبْ نّسْ أَقَا إِوْضنْ غَارْ ؤُجنَّا،\qt*
\m \qt ؤُشَا أَربِّي أَقَا إِعْقڒْ خْ ڒْمُوعْصِييّثْ نّسْ.\qt* \x ◘ \xo 18:‏5 \xt أَسَا. 16‏:‏19. \x*
\m 
\v 6 \qt أَرّمْ-د خَاسْ\qt*
\m \qt أَمْ مَامّشْ د-ثَارَّا نتَّاثْ،\qt*
\m \qt أَرّمْ-د خَاسْ س ؤُضفُّوسْ\qt*
\m \qt عْلَاحْسَابْ ڒخْذَايمْ نّسْ،\qt*
\m \qt خدْجضْ أَسْ س ؤُضفُّوسْ ذڭْ ؤُغَارَّافْ\qt*
\m \qt نِّي ثُوغَا ثْخدْجضْ نتَّاثْ.\qt* \x ◘ \xo 18:‏6 \xt أَسَا. 14‏:‏10. \x*
\m 
\v 7 \qt خڒْفمْ أَسْ-د أَعدّبْ ذ وشْضَانْ\qt*
\m \qt أَنشْثْ ثُوغَا نتَّاثْ ثسّْعُودْجِي\qt*
\m \qt ؤُ ثسّْڭعّذْ إِخفْ نّسْ\qt*
\m \qt مِينْزِي ثنَّا ذڭْ وُوڒْ نّسْ:\qt*
\m \qt ’أَقَا قِّيمغْ أَمْ ثْجدْجِيذْثْ،\qt*
\m \qt وَارْ دْجِيغْ ذ ثَاجَّاتْشْ،\qt*
\m \qt ؤُشَا أَشْضَانْ وَارْ ث ژَترّغْ شَا!‘\qt* \x ◘ \xo 18:‏7 \xt إِشا. 47‏:‏8. \x*
\b
\m 
\v 8 س ؤُينِّي ذڭْ إِجّْ ن وَاسّْ أَذْ خَاسْ وْضَانْثْ مَارَّا جّْرَايحْ نّسْ: ڒْموْثْ، أَشْضَانْ ذ ڒَاژْ، ؤُشَا أَذْ ثتّْوَاشْمضْ ذِي ثْمسِّي، مِينْزِي سِيذِي، ذ ونِّي خَاسْ إِ غَا إِحكْمنْ، أَقَا إِجْهذْ. \x ◘ \xo 18:‏8 \xt 2 تس. 2‏:‏8؛ أَسَا. 17‏:‏16. \x*
\m 
\v 9 \bd إِجدْجِيذنْ ن ثمُّورْثْ\bd*، إِنِّي كِيذسْ إِڭِّينْ فَارْقْ-شّْغڒْ ؤُ سّْڭعّْذنْ إِخفْ نْسنْ، أَذْ خَاسْ رُونْ، أَذْ خَاسْ وْثنْ أَڭجْذُورْ خْمِي غَا ژَترنْ دّخَّانْ ن ثْمسِّي نّسْ. \x ◘ \xo 18:‏9 \xt أَسَا. 17‏:‏2؛ 18‏:‏3، 18. \x*
\v 10 نِيثْنِي أَذْ قِّيمنْ بدّنْ غَارْ ڒَاڭّْوَاجْ زِي ثڭّْوُوذِي ن ؤُعدّبْ نّسْ، قَّارنْ:
\b
\m \bdit ’ؤُشْثْ، ؤُشْثْ، ؤُشْثْ، خَامْ، أَ ثَانْذِينْثْ ثَامقّْرَانْثْ\bdit*،
\m \qt بَابِيلْ، ثَانْذِينْثْ إِجهْذنْ،\qt*
\m \qt مِينْزِي أَقَا يُوسَا-د ڒْحُوكْمْ نّمْ\qt*
\m \bdit ذڭْ إِشْثْ ن ثْسَاعّثْ\bdit*!‘ “ \x ◘ \xo 18:‏10 \xt إِشا. 21‏:‏9؛ إِرْم. 51‏:‏1؛ أَسَا. 14‏:‏8. \x*
\b
\m 
\v 11 \bd إِسبَّابنْ ن ثمُّورْثْ\bd* أَذْ خَاسْ رُونْ، أَذْ شضْننْ، مِينْزِي ؤُڒَا ذ إِجّْ وَارْ إِسِّيغْ عَاذْ سّڒْعثْ نْسنْ:
\v 12 سّڒْعثْ ن وُورغْ ذ نُّوقَارْثْ ذ يژْرَا يِيغْڒَانْ ذ ثْيَاقُوثِينْ ذ ڒقْطنْ ذ أَرْجُووَانِي ذ ڒحْرِيرْ أَزڭّْوَاغْ إِحذْقنْ ذ عْڒَامْ كُوڒْ أَكشُّوضْ إِتّْفُوحنْ ذ عْڒَامْ كُوڒْ ڒقْشُوعْ زِي ڒْعَاجْ ذ عْڒَامْ كُوڒْ ڒقْشُوعْ زڭْ ؤُكشُّوضْ إِغْڒَانْ ذ نّْحَاسْ ذ وُوزَّاڒْ ذ ڒْمَارْمُورْ \f ◼ \fr 18:‏12 \ft \bd ’ڒْعَاجْ‘\bd* - إِخْسْ أَذْ يِينِي ’أَشِّيونْ ن ڒْفِيڒْ‘.\f*
\v 13 ذ ڒْقَارْفَا ذ ڒبْخُورْ ذ مِيرُّو ذ جَّاوِي ذ بِينُو ذ زّشْثْ ن زِّيثُونْ ذ أَرنْ ن سّْمِيذْ ذ وُودْجِي ذ ييْسَانْ ذ إِكَارُّوثنْ ؤُڒَا ذ أَرِّيمَاثْ ذ ڒعْمُورْ ن إِوْذَانْ. \x ◘ \xo 18:‏13 \xt حِز. 27‏:‏13. \x*
\v 14 أَقَا ڒْغِيدْجثْ إِ ذِي ثُوغَا إِتّْمژْرِي ڒعْمَارْ نّمْ، أَقَا ثِيڭّْوجْ خَامْ، ؤُڒَا ذ مَارَّا مِينْ ثُوغَا غَارمْ ذ أَڭْڒَا ذ مِينْ إِتِّيسِّيقنْ، أَقَا إِودَّارْ، وَارْ ث ثْژَارّذْعمَّارْصْ \add عَاذْ\add*.
\v 15 إِسبَّابنْ ن ڒحْوَايجْ-أَ، إِنِّي إِذوْڒنْ زَّايْسنْثْ ذ ثْوَاجَّارْ، وَارْ ثنْثْ تِّيفنْ عَاذْ، ؤُشَا أَذْ قِّيمنْ غَارْ ڒَاڭّْوَاجْ زِي ثڭّْوُوذِي ن ؤُعدّبْ نّسْ، أَمْ تّْرُونْ ؤُ أَمْ شطّْننْ،
\v 16 أَذْ إِنِينْ:
\b
\m \bdit ”ؤُشْثْ، ؤُشْثْ\bdit* \bdit خَامْ\bdit*، \bdit أَ شمْ،\bdit* \bdit ثَانْذِينْثْ ثَامقّْرَانْثْ\bdit*
\m \qt إِ يَارْضنْ ڒقْطنْ ذ أَرْجُووَانِي\qt*
\m \qt ذ أَزڭّْوَاغْ إِحذْقنْ إِقّنْ س وُورغْ\qt*
\m \qt ذ يژْرَا إِغْڒَانْ ذ ثْيَاقُوثِينْ،\qt* \x ◘ \xo 18:‏16 \xt أَسَا. 17‏:‏4. \x*
\m 
\v 17 \qt س مِينْزِي\qt* \bdit ذڭْ إِشْثْ ن ثْسَاعّثْ\bdit*
\m \qt أَقَا إِودَّارْ وَاڭْڒَا أَمقّْرَانْ نِّي!“\qt*
\b
\m مَارَّا إِنِّي إِندّْهنْ إِغَارُّوبَا ذ مَارَّا إِنِّي إِتّكّنْ \add خْ ڒبْحَارْ\add* ذڭْ إِغَارُّوبَا ذ مَارَّا إِبحْرِييّنْ ذ مَارَّا إِنِّي إِتّْسبَّابنْ ذِي ڒبْحَارْ قِّيمنْ بدّنْ غَارْ ڒَاڭّْوَاجْ.
\v 18 نِيثْنِي سْغُويّنْ ؤُمِي ژْرِينْ دّخَّانْ ن ثْمسِّي نّسْ، نَّانْ:
\b
\m \qt ”وِي إِزمَّارنْ أَذْ إِمْقُودَّا أَكْ-ذ ثنْذِينْثْ-أَ ثَامقّْرَانْثْ؟“\qt* \x ◘ \xo 18:‏18 \xt إِشا. 34‏:‏10؛ أَسَا. 13‏:‏4؛ 18‏:‏9. \x*
\b
\m 
\v 19 سُّويُوسنْ ؤُشَاڒْ خْ إِزدْجِيفنْ نْسنْ ؤُشَا سْغُوينْ، أَمْ تّْرُونْ ؤُ أَمْ تّشْضِيننْ، نَّانْ:
\b
\m \bdit ”ؤُشْثْ، ؤُشْثْ خَامْ، أَ شمْ، ثَانْذِينْثْ ثَامقّْرَانْثْ\bdit*
\m \qt نِّي ذِي ذوْڒنْ ذ ثْوَاجَّارْ\qt*
\m \qt مَارَّا إِنِّي غَارْ إِدْجَا إِغَارُّوبَا ذِي ڒبْحَارْ،\qt*
\m \qt س ؤُبَارُّو ن وَاڭْڒَا نّسْ،\qt*
\m \qt مِينْزِي\qt* \bdit ذڭْ إِشْثْ ن ثْسَاعّثْ\bdit* \qt ثْودَّارْ!“\qt*
\b
\m 
\v 20 \qt ”فَارْحثْ زَّايسْ، \tl أَ\tl* أَجنَّا،\qt*
\m \qt ؤُ \tl كنِّيوْ، أَ\tl* إِمْقدَّاسنْ ذ رُّوسُولْ ذ إِنَابِييّنْ،\qt*
\m \qt مِينْزِي أَربِّي أَقَا إِسُّوفّغْ-د ڒحْكَامثْ نّسْ خَاسْ!“\qt* \x ◘ \xo 18:‏20 \xt أَسَا. 19‏:‏2. \x*
\b
\m 
\v 21 ؤُشَا إِجّْ زِي لْمَالَاكَاثْ نِّي إِسّْڭعّذْ إِجّْ ن وژْرُو أَمقّْرَانْ أَنشْثْ ن ثصْضَارْثْ ن ثْسِيرْثْ، إِنْضَارْ إِ-ث ذِي ڒبْحَارْ، إِقَّارْ:
\b
\m \qt ”أَمُّو س جّهْذْ أَذْ ثمّنْضَارْ\qt*
\m \qt ثَانْذِينْثْ ثَامقّْرَانْثْ بَابِيلْ\qt*
\m \qt ؤُشَا وَارْ ثتّْوِيفِي عَاذْعمَّارْصْ!\qt* \x ◘ \xo 18:‏21 \xt إِرْم. 51‏:‏64. \x*
\m 
\v 22 \qt ڒْحسّْ ن لهَارْپَا ذ ؤُسُوضِي ذڭْ\qt*
\m \bdit ؤُيِيشّْ ن إِشَارِّي،\bdit*
\m \qt ذ ڒْحسّْ ن عْڒَامْ كُوڒْ أَغنّجْ\qt*
\m \qt ؤُ ن يِينِّي إِتّْسُوضنْ ذِي ڒْبُوقْ،\qt*
\m \qt وَارْ إِتّْوَاسڒْ عَاذْ ذَايمْ.\qt* \x ◘ \xo 18:‏22 \xt إِرْم. 25‏:‏10؛ حِز. 26‏:‏13. \x*
\m 
\v 23 \qt عمَّارْصْ أَذْ ذَايمْ ثتّْوَاژَارْ عَاذْ\qt*
\m \qt طّْيَا ن ڒفْنَارْ،\qt*
\m \qt ؤُشَا ؤُڒَا ذ ڒْحسّْ ن وسْڒِي\qt*
\m \qt ذ ڒْحسّْ ن ثسْڒِيثْ\qt*
\m \qt وَارْ إِتّْوَاسڒْ عَاذْ ذَايمْ.\qt*
\m \qt إِسبَّابنْ نّمْ ثُوغَا أَثنْ\qt*
\m \qt ذ إِمقّْرَاننْ ن ثمُّورْثْ،\qt*
\m \qt مِينْزِي س ثْسحَّارْثْ نّمْ،\qt*
\m \qt أَقَا ثْخذْعذْ ڒڭْنُوسْ مَارَّا.\qt* \x ◘ \xo 18:‏23 \xt إِرْم. 7‏:‏34؛ 16‏:‏9؛ 25‏:‏10. \x*
\m 
\v 24 \qt أَقَا إِتّْوَافْ ذَايمْ إِذَامّنْ\qt*
\m \qt ن إِنَابِييّنْ ذ إِمْقدَّاسنْ،\qt*
\m \qt إِنِّي إِتّْوَانْغنْ ذِي ثمُّورْثْ.“\qt* \x ◘ \xo 18:‏24 \xt أَمز. 4‏:‏10؛ أَسَا. 17‏:‏6. \x*
\b
\b
\c 19
\s1 إِژْڒِي خْ ؤُوطُّو ن بَابِيلْ
\m 
\v 1 أَوَارْنِي أَسْ سْڒِيغْ إِجّْ ن ڒْحسّْ أَمقّْرَانْ ن وَاطَّاسْ ن ڒْغَاشِي ذڭْ ؤُجنَّا، نَّانْ:
\b
\m \qt ”هَالِّيلُو-يَاهْ!\qt*
\m \qt أَسنْجمْ ذ ؤُعُودْجِي ذ جّهْذْ\qt*
\m \qt أَقَا أَثنْ غَارْ أَربِّي نّغْ،\qt*
\m 
\v 2 \qt مِينْزِي ڒحْكَامَاثْ نّسْ \tl مْغِيرْ\tl* ذ ثِيذتّْ ذ ڒْحقّْ،\qt*
\m \qt ؤُمِي إِحَاسبْ خْ ثمْغَارْثْ ن فَارْقْ-شّْغڒْ،\qt*
\m \qt ثنِّي يَاردّْدْجنْ دُّونشْثْ س فَارْقْ-شّْغڒْ نّسْ،\qt*
\m \qt ؤُشَا نتَّا يُوغَا ثَاسْغَارْثْ\qt*
\m \qt خْ إِذَامّنْ ن إِمْسخَّارنْ نّسْ\qt*
\m \qt إِ يُومْسنْ غَارْ إِفَاسّنْ نّسْ.“\qt* \x ◘ \xo 19:‏2 \xt أَعَوذ. 32‏:‏43؛ أَسَا. 15‏:‏3؛ 16‏:‏7؛ 18‏:‏20. \x*
\b
\m 
\v 3 نَّانْ إِ \add ؤُمُورْ\add* وِيسّْ ثْنَاينْ:
\b
\m \qt ”هَالِّيلُو-يَاهْ!“\qt*
\b
\m ؤُشَا أَذْ يَاڒِي دّخَّانْ نّسْ غَارْ ؤُجنَّا إِ ڒبْذَا قَاعْ.\x ◘ \xo 19:‏3 \xt إِشا. 34‏:‏10؛ أَسَا. 14‏:‏11؛ 18‏:‏18. \x*
\b
\m 
\v 4 ؤُشَا أَربْعَا ؤُ-عِيشْرِينْ ن إِمْغَارنْ ذ أَربْعَا ن إِمُودَّارنْ وْضَانْ غَارْ ثمُّورْثْ، سجْذنْ إِ أَربِّي نّغْ ونِّي إِقِّيمنْ خْ ڒْعَارْشْ، نَّانْ:
\b
\m \qt ”أَمِينْ، هَالِّيلُو-يَاهْ!“\qt*
\b
\m 
\v 5 ؤُشَا ثُوسَا-د إِشْثْ ن ثْمِيجَّا زِي ڒْعَارْشْ، ثنَّا:
\b
\m \qt ”سمْغَارمْ أَربِّي نّغْ، \tl أَ\tl* \tl كنِّيوْ\tl* مَارَّا إِمْسخَّارنْ نّسْ،\qt*
\m \qt ؤُ مَارَّا إِنِّي إِتّڭّْوذنْ إِسمْ نّسْ،\qt*
\m \qt أَمْ ؤُمژْيَانْ أَمْ ؤُمقّْرَانْ!“\qt*
\b
\s1 ڒمْڒَاشْ ن يزْمَارْ
\m 
\v 6 ؤُشَا سْڒِيغْ أَقَا نَّانْ أَمْ س ثْمِيجَّا ن ؤُبَارُّو ن ڒْغَاشِي، أَمْ س ڒْحسّْ ن وَاطَّاسْ ن وَامَانْ، أَمْ س زّْهِيرْ ن وَاجَّاجنْ إِمقّْرَاننْ:
\b
\m \qt ”هَالِّيلُو-يَاهْ، مِينْزِي سِيذِي أَربِّي،\qt*
\m \qt أَمْزمَّارْ خْ كُوڒْشِي، أَقَا إِحكّمْ.\qt* \x ◘ \xo 19:‏6 \xt أَسَا. 11‏:‏17؛ أَسَا. 14‏:‏2\x*
\m 
\v 7 \qt أجّْ أَذْ نْفَارْحْ، أَذْ نسْڒِيوْڒِيوْ،\qt*
\m \qt أَذْ أَسْ نڭّْ أَعُودْجِي،\qt*
\m \qt مَاغَارْ ؤُرَارْ ن يزْمَارْ يِيوضْ-د،\qt*
\m \qt ؤُشَا ثَامْغَارْثْ نّسْ أَقَا ثْحزّمْ،\qt* \x ◘ \xo 19:‏7 \xt مت. 22‏:‏2؛ لك. 14‏:‏16. \x*
\m 
\v 8 \qt ؤُشَا ثمّوْشْ أَسْ أَذْ ثْيَارْضْ أَرُّوضْ\qt*
\m \qt زِي ڒْقطَّانْ إِفْسُوسنْ إِزْذِيڭنْ إِتِّيسِّيقنْ،\qt*
\m \qt مِينْزِي ڒْقطَّانْ نِّي\qt*
\m \qt ذ ڒخْذَايمْ إِسڭّْذنْ ن إِمْقدَّاسنْ.“\qt*
\b
\m 
\v 9 نِيثْنِي نَّانْ أَيِي:
\b
\m \qt ”أَرِي:\qt* \bdit سّعْذْ\bdit* \qt ن يِينِّي إِتّْوَاعَارْضنْ\qt*
\m \qt غَارْ ؤُمنْسِي ن وُورَارْ ن إِزْمَارْ.‘\qt*
\b
\m \add خَاسْ ؤُشَا\add* إِنَّا أَيِي شَا ن يِيجّنْ:
\b
\m \qt ”إِنَا ذ أَوَاڒنْ ن ثِيذتّْ ن أَربِّي.“\qt* \x ◘ \xo 19:‏9 \xt أَسَا. 21‏:‏5. \x*
\b
\m 
\v 10 ؤُشَا وْضِيغْ أَسْ غَارْ إِضَارنْ نّسْ حِيمَا أَذْ ثعبْذغْ، \add مَاشَا\add* نتَّا إِنَّا أَيِي:
\b
\m \qt ”لَّ، \tl وَارْ تّڭّْ شَا مَانْ أَيَا!\tl* أَقَا نشّْ ذ أَمْسخَّارْ أَمْعَاشَارْ أَمْ شكْ ذ أَيْثْمَاشْ إِنِّي غَارْ ثدْجَا شّْهَاذثْ ن يَاسُوع.عبْذثْ أَربِّي، مِينْزِي شّْهَاذثْ ن يَاسُوع نتَّاثْ ذ أَرُّوحْ ن مِينْ إِتّْوَانَابّنْ.“\qt* \x ◘ \xo 19:‏10 \xt ڒخ. 10‏:‏26؛ 14‏:‏14؛ أَسَا. 22‏:‏9. \x*
\b
\s1 أَمْنَايْ س ؤُيِيسْ ذ أَشمْڒَاڒْ
\m 
\v 11 \add أَوَارْنِي أَيَا\add* ژْرِيغْ أَجنَّا إِنُّورْزمْ، ؤُ خْزَارْ، أَقَا ذِينْ إِجّْ ن ؤُيِيسْ ذ أَشمْڒَاڒْ ذ ونِّي خَاسْ إِنْيِينْ، قَّارنْ أَسْ ’ذَايسْ ڒَامَانْ!‘، ’ذَايسْ ثِيذتّْ!‘، ؤُشَا نتَّا أَذْ إِحَاسبْ ؤُ أَذْ إِمّْنغْ س ثْسڭْذَا. \x ◘ \xo 19:‏11 \xt أَسَا. 6‏:‏2. \x*
\v 12 ثُوغَا ثِيطَّاوِينْ نّسْ أَمشْنَاوْ إِحُوذَاقْ ن ثْمسِّي، ؤُشَا غَارسْ خْ ؤُزدْجِيفْ نّسْ أَطَّاسْ ن تِّيجَانْ، ؤُشَا يُورَا خَاسْ إِسمْ إِ وَارْ ث إِسِّينْ حذْ مْغِيرْ نتَّا وَاهَا. \x ◘ \xo 19:‏12 \xt أَسَا. 1‏:‏14. \x*
\v 13 ثُوغَا يَارْضْ إِجّْ ن ؤُسڒْهَامْ إِتّْوَارُوشّنْ س إِذَامّنْ، ؤُشَا وَا ذ إِسمْ نّسْ: \bd ’أَوَاڒْ ن أَربِّي‘\bd*. \x ◘ \xo 19:‏13 \xt إِشا. 63‏:‏1؛ يُوح. 1‏:‏1. \x*
\v 14 ڒْعسْكَارَاثْ ن ؤُجنَّا ضْفَارنْ ث-إِ-د خْ ييْسَانْ إِشمْڒَاڒنْ، أَرْضنْ ڒْقطَّانْ ذ أَشمْڒَاڒْ إِزْذِيڭْ. \x ◘ \xo 19:‏14 \xt مت. 28‏:‏3؛ أَسَا. 4‏:‏4؛ 7‏:‏9. \x*
\v 15 فّْغنْ-د ڒسْيُوفْ إِقضْعنْ زڭْ إِقمُّومنْ نْسنْ مَاحنْذْ أَذْ زَّايْسنْ نْغنْ ڒڭْنُوسْ، ؤُ نتَّا أَذْ ثنْ إِحْضَا س ؤُزدْجَاضْ ن وُوزَّاڒْ، ؤُ نتَّا \add سِيمَانْثْ نّسْ\add* أَذْ إِعْفسْ ذِي ثْسِيرْثْ ن وغْضَابْ ن أَربِّي، أَمْزمَّارْ خْ كُوڒْشِي. \x ◘ \xo 19:‏15 \xt إِزهد. 2‏:‏9؛ إِشا. 63‏:‏3؛ أَسَا. 2‏:‏16، 27؛ 14‏:‏19، 20؛ 19‏:‏21. \x*
\v 16 خْ وَارُّوضْ نّسْ ؤُ خْ ثْمصَّاضِينْ نّسْ يُورَا خَاسنْ إِسمْ-أَ: \bd ’أَجدْجِيذْ خْ \bdit مَارَّا\bdit* إِجدْجِيذنْ‘، ’سِيذِي خْ \bdit مَارَّا\bdit* ڒْحُوكَّامْ‘.\bd* \x ◘ \xo 19:‏16 \xt 1 تِيم. 6‏:‏15؛ أَسَا. 17‏:‏14. \x*
\b
\m 
\v 17 ؤُشَا ژْرِيغْ إِجّْ ن لْمَالَاكْ نّغْنِي إِبدّْ ذِي ثْفُوشْثْ. نتَّا إِڒَاغَا س جّهْذْ، إِنَّا إِ مَارَّا إِجْضَاضْ إِطَّاونْ ذِي ڒْوسْطْ ن ؤُجنَّا:
\b
\m \qt ”أَستِّيوْ-ذ، مُونتِّيوْ-د\qt*
\m \qt غَارْ ؤُمنْسِي أَمقّْرَانْ ن أَربِّي،\qt* \x ◘ \xo 19:‏17 \xt إِرْم. 12‏:‏9؛ حِز. 39‏:‏17. \x*
\m 
\v 18 \qt حِيمَا أَذْ ثشّمْ أَيْسُومْ ن إِجدْجِيذنْ\qt*
\m \qt ذ ويْسُومْ ن إِمقّْرَاننْ خْ وَاڒفْ\qt*
\m \qt ذ ويْسُومْ ن يِينِّي إِجهْذنْ\qt*
\m \qt ذ ويْسُومْ ن إِيْسَانْ ذ يِينِّي خَاسنْ إِنْيِينْ،\qt*
\m \qt ذ ويْسُومْ ن إِحُورِّييّنْ ذ إِسمْغَانْ،\qt*
\m \qt أَمْ ن إِمژْيَاننْ أَمْ ن إِمقّْرَاننْ.“\qt*
\b
\m 
\v 19 ؤُشَا ژْرِيغْ ڒْوحْشْ أَكْ-ذ ڒْعسْكَارَاثْ نّسْ ذ إِجدْجِيذنْ ن ثمُّورْثْ ذ إِعسْكَارِّييّنْ نْسنْ، إِنِّي إِمُوننْ حِيمَا أَذْ مّنْغنْ أَكْ-ذ ونِّي إِنْيِينْ خْ ؤُيِيسْ، ؤُ أَكْ-ذ إِعسْكَارِييّنْ نّسْ.
\v 20 أَقَا إِتّْوَاطّفْ ڒْوحْشْ أَكْ-ذ ؤُنَابِي إِسّْخَارِّيقنْ، ونِّي إِڭِّينْ زَّاثسْ ڒعْڒَامَاثْ نِّي زِي ثُوغَا إِغشّْ إِنِّي إِكْسِينْ ڒْمَارْكَا ن ڒْوحْشْ ؤُشَا سجْذنْ إِ ڒخْيَاڒْ نّسْ. نِيثْنِي س ثْنَاينْ إِذْسنْ تّْوَامّنْضَارنْ ذِي ڒبْحَارْ ن ثْمسِّي إِتّْشفْشُوفنْ عَاوذْ س ڒشْبَاريّثْ. \x ◘ \xo 19:‏20 \xt أَعَوذ. 13‏:‏2؛ دَان. 7‏:‏11؛ مت. 24‏:‏24؛ أَسَا. 13‏:‏12، 13، 15، 16؛ 16‏:‏14؛ 20‏:‏10. \x*
\v 21 مَاشَا وِي إِقِّيمنْ تّْوَانْغنْ س وُوزَّاڒْ إِ د-إِكِّينْ زڭْ ؤُقمُّومْ ن ونِّي إِنْيِينْ خْ ؤُيِيسْ. ؤُشَا مَارَّا إِجْضَاضْ إِتّْكشَّاضنْ جِّيوْننْ س ويْسُومْ نْسنْ.
\b
\b
\c 20
\s1 ثَاڭلْذِيثْ ن أَڒفْ ن إِسڭّْوُوسَا
\m 
\v 1 ؤُشَا ژْرِيغْ إِجّْ ن لْمَالَاكْ نّغْنِي إِهْوَا-د زڭْ ؤُجنَّا، غَارسْ ثَاسَارُوثْ ن ثسْرَافْثْ إِ إِدْجَانْ سَاذُو إِ ثمُّورْثْ ذ إِشْثْ ن سّْنسْڒثْ ثَامقّْرَانْثْ ذڭْ ؤُفُوسْ نّسْ. \x ◘ \xo 20:‏1 \xt أَسَا. 1‏:‏18. \x*
\v 2 نتَّا إِطّفْ ڒْهَايْشثْ، أَفِيغَارْ أَوسَّارْ، ونِّي ذ إِبْڒِيسْ ذ شِّيطَانْ ؤُشَا إِشَارْفْ إِ-ث إِ يِيجّْ ن ڒْقدّْ ن وَاڒفْ ن إِسڭّْوُوسَا، \x ◘ \xo 20:‏2 \xt 2 بُط. 2‏:‏4؛ أَسَا. 12‏:‏9. \x*
\v 3 ؤُشَا إِنْضَارْ إِ-ث ذِي ثسْرَافْثْ سَاذُو ثمُّورْثْ، إِبلّعْ خَاسْ ؤُشَا إِڭَّا خَاسْ أَشمِّيعْ، حِيمَا وَارْ إِتّْغشِّي عَاذْ ڒڭْنُوسْ. أَوَارْنِي مَانْ أَيَا أَذْ إِتّْوَاضْڒقْ غَارْ شْوَايْثْ ن ڒْوقْثْ. \x ◘ \xo 20:‏3 \xt أَسَا. 16‏:‏14، 16؛ 20‏:‏8. \x*
\m 
\v 4 نشّْ ژْرِيغْ ڒكْرَاسِي ن إِجدْجِيذنْ ؤُشَا نِيثْنِي سّْغِيمِينْ إِخفْ نْسنْ خَاسنْ، ؤُشَا إِمّوْشْ أَسنْ ڒْحُوكْمْ. أَقَا ڒعْمُورْ-أَ - ن يِينِّي ؤُمِي كّْسنْ إِزدْجِيفنْ نْسنْ ذِي طّْوعْ ن شّْهَاذثْ ن يَاسُوع ذ وَاوَاڒْ ن أَربِّي، وَارْ سجْذنْ إِ ڒْوحْشْ ؤُڒَا إِ ڒخْيَاڒْ، وَارْ طِّيفنْ شَا ڒْمَارْكَا خْ ثنْيَارْثْ نْسنْ ؤُڒَا ذڭْ ؤُفُوسْ نْسنْ - \add أَقَا ڒعْمُورْ-أَ\add* دَّارنْ ؤُ حكْمنْ أَكْ-ذ لْمَاسِيحْ أَڒفْ إِسڭّْوُوسَا. \x ◘ \xo 20:‏4 \xt أَسَا. 6‏:‏9، 11؛ 13‏:‏12، 15، 16. \x*
\m 
\v 5 ثَا ذ ثَانُوكْرَا ثَامزْوَارُوثْ.
\v 6 \bd سّعْذْ\bd* ذ ؤُمْقدَّاسْ ن ونِّي إِ غَا إِطّْفنْ ثَاسْغَارْثْ ذِي ثْنُوكْرَا ثَامزْوَارُوثْ. ڒْموْثْ وِيسّْ ثْنَاينْ وَارْ غَارسْ ثِيڒِي بُو صُّولْطَا خَاسنْ، مَاشَا نِيثْنِي أَذْ إِڒِينْ ذ إِكهَّاننْ ن أَربِّي ؤُ ن لْمَاسِيحْ ؤُشَا أَذْ كِيسْ حكْمنْ أَڒفْ ن إِسڭّْوُوسَا. \x ◘ \xo 20:‏6 \xt إِشا. 61‏:‏6؛ 1 بُط. 2‏:‏9؛ أَسَا. 1‏:‏6؛ 5‏:‏10. \x*
\b
\s1 ڒْحُوكْمْ خْ شِّيطَانْ أَمقّْرَانْ
\m 
\v 7 خْمِي غَا إِقْفڒْ أَڒفْ ن إِسڭّْوُوسَا، أَذْ إِتّْوَاضْڒقْ شِّيطَانْ زِي ڒحْبسْ نّسْ،
\v 8 ؤُشَا أَذْ د-إِفّغْ حِيمَا أَذْ إِغشّْ مَارَّا ڒڭْنُوسْ إِنِّي إِدْجَانْ غَارْ أَربْعَا ن ثْغمُّورَا ن ثمُّورْثْ، \add هَا\add*جُوجْ ذ مَاجُوجْ، أَذْ ثنْ إِسّْمُونْ إِ ؤُمنْغِي، ؤُ ڒْقدّْ نْسنْ أَمْ يجْذِي ن ڒبْحَارْ. \f ◼ \fr 20:‏8 \ft \bd ’هَاجُوجْ‘\bd* - نِيغْ ’جُوجْ‘، نِيغْ ’خُوخْ‘، نِيغْ ’ڭُوڭْ‘. \bd ’مَاجُوجْ‘\bd* - نِيغْ ’مَاخُوخْ‘، نِيغْ ’مَاڭُوڭْ‘.\f*  \x ◘ \xo 20:‏8 \xt حِز. 38‏:‏2؛ 39‏:‏1؛ أَسَا. 16‏:‏14. \x*
\v 9 حَارّْشنْ-د زِي طَّارْفْ ن ثمُّورْثْ ؤُشَا نّْضنْ أَسْ إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ ن إِمْقدَّاسنْ ذ ثنْذِينْثْ إِعِيزّنْ، ؤُشَا ثوْضَا-د ثْمسِّي زڭْ ؤُجنَّا، زِي \add زَّاثْ\add* أَربِّي، ؤُشَا ثشَّا إِ-ثنْ.
\v 10 ؤُشَا إِبْڒِيسْ، ونِّي ثُوغَا ثنْ إِغْوَانْ، أَقَا إِمّنْضَارْ ذِي ڒبْحَارْ ن ثْمسِّي إِتّْشفْشُوفنْ س ڒشْبَاريّثْ مَانِي إِدْجَا ڒْوحْشْ ذ ؤُنَابِي إِسّْخَارِّيقنْ ؤُشَا أَذْ تّْوَاعدّْبنْ أَسّْ ذ دْجِيڒثْ إِ ڒبْذَا قَاعْ. \x ◘ \xo 20:‏10 \xt دَان. 7‏:‏11؛ أَسَا. 14‏:‏10؛ 19‏:‏20. \x*
\b
\s1 ڒْحُوكْمْ خْ إِمتِّيننْ
\m 
\v 11 ؤُشَا ژْرِيغْ إِجّْ ن ڒْعَارْشْ ذ أَمقّْرَانْ ذ أَشمْڒَاڒْ ذ ونِّي خَاسْ إِقِّيمنْ، أَقَا زِي أَرنْذَاذْ ن ؤُغمْبُوبْ نّسْ ثَارْوڒْ ثمُّورْثْ ذ ؤُجنَّا، \add مَاشَا\add* وَارْ ذ أَسنْ إِقِّيمْ بُو ومْشَانْ.
\v 12 نشّْ ژْرِيغْ إِمتِّيننْ بدّنْ زَّاثْ إِ ڒْعَارْشْ، إِمقّْرَاننْ ذ إِمژْيَاننْ. أَقَا نُّورْزْمنْ إِذْلِيسنْ \add إِتّْوَانْضنْ\add* ؤُشَا إِنُّورْزمْ وذْلِيسْ \add إِتّْوَانْضنْ\add* نّغْنِي، \add أَذْلِيسْ إِتّْوَانْضنْ\add* ن ڒْحُوكْمْ. ؤُشَا إِتّْوَاحْكمْ خْ إِمتِّيننْ زِي مِينْ يُورَانْ ذڭْ وذْلِيسْ \add إِتّْوَانْضنْ\add* خْ ڒحْسَابْ ن ڒخْذَايمْ نْسنْ. \x ◘ \xo 20:‏12 \xt ؤُف. 32‏:‏32؛ إِزهد. 62‏:‏13؛ 69‏:‏29؛ إِرْم. 17‏:‏10؛ 32‏:‏19؛ دَان. 7‏:‏9‏-‏12؛ مت. 16‏:‏27؛ رُوم. 2‏:‏6؛ 14‏:‏12؛ 2 كُور. 5‏:‏10؛ ڭال. 6‏:‏5؛ فِيل. 4‏:‏3؛ أَسَا. 2‏:‏23؛ 3‏:‏5. \x*
\v 13 ؤُشَا ڒبْحَارْ إِوْشَا إِمتِّيننْ إِنِّي ثُوغَا أَثنْ ذَايسْ، ؤُشَا ڒْموْثْ ذ ڒَاخَارْثْ وْشِينْثْ إِمتِّيننْ إِنِّي ثُوغَا أَثنْ ذَايْسنْثْ، ؤُشَا إِتّْوَاحْكمْ خَاسنْ، كُوڒْ إِجّنْ أَنشْثْ ن ڒخْذَايمْ نّسْ.
\v 14 ڒْموْثْ ذ ڒَاخَارْثْ مّنْضَارنْثْ ذِي ڒبْحَارْ ن ثْمسِّي. ثَا ذ ڒْموْثْ وِيسّْ ثْنَاينْ.
\v 15 مَاڒَا إِتّْوَافْ حذْ وَارْ إِتّْوَازمّمْ ذڭْ وذْلِيسْ \add إِتّْوَانْضنْ\add* ن ثُوذَارْثْ، إِمّنْضَارْ ذِي ڒبْحَارْ ن ثْمسِّي. \x ◘ \xo 20:‏15 \xt أَسَا. 13‏:‏8\x*
\b
\b
\c 21
\s1 أَجنَّا ن جْذِيذْ ذ ثمُّورْثْ ن جْذِيذْ
\m 
\v 1 ؤُشَا ژْرِيغْ أَجنَّا ن جْذِيذْ ذ إِشْثْ ن ثمُّورْثْ ن جْذِيذْ، مَاغَارْ أَجنَّا أَمزْوَارُو ذ ثمُّورْثْ ثَامزْوَارُوثْ ثُوغَا عْذُونْ، ڒبْحَارْ وَارْ إِقِّيمْ عَاذْ. \x ◘ \xo 21:‏1 \xt إِشا. 65‏:‏17؛ 66‏:‏22؛ 2 بُط. 3‏:‏13. \x*
\v 2 نشّْ ژْرِيغْ ثَانْذِينْثْ إِقدّْسنْ، ؤُرْشَالِيمْ ن جْذِيذْ، ثهْوَا-د زڭْ ؤُجنَّا زِي زَّاثْ أَربِّي، ثڭَّا أَمْ ثسْڒِيثْ إِزهّْجنْ إِ وسْڒِي. \x ◘ \xo 21:‏2 \xt أَسَا. 3‏:‏12؛ 21‏:‏10. \x*
\v 3 ؤُشَا سْڒِيغْ إِشْثْ ن ثْمِيجَّا ثتّْڒَاغَا-د زڭْ ؤُجنَّا س جّهْذْ:
\b
\m \qt ”خْژَارْ، أَقِيضُونْ ن أَربِّي\qt*
\m \qt أَقَا-ت جَارْ إِوْذَانْ،\qt*
\m \qt ؤُشَا نتَّا أَذْ غَارْسنْ إِزْذغْ.\qt*
\m \qt نِيثْنِي أَذْ إِڒِينْ ذ ڒْڭنْسْ نّسْ،\qt*
\m \qt ؤُشَا أَربِّي سِيمَانْثْ نّسْ \tl أَذْ\tl* غَارْسنْ \tl يِيڒِي\tl*،\qt*
\m \qt ؤُشَا أَذْ يِيڒِي ذ أَربِّي نْسنْ.\qt* \x ◘ \xo 21:‏3 \xt حِز. 43‏:‏7. \x*
\m 
\v 4 \qt أَذْ أَسنْ إِسِّيژغْ كُوڒْ إِمطَّانْ\qt*
\m \qt زِي ثِيطَّاوِينْ نْسنْ،\qt*
\m \qt ؤُشَا وَارْ ثتِّيڒِي عَاذْ ڒْموْثْ\qt*
\m \qt ذ وشْضَانْ ذ ؤُشثْشِي ذ ڒحْرِيقْ.“\qt* \x ◘ \xo 21:‏4 \xt إِشا. 25‏:‏8؛ أَسَا. 7‏:‏17. \x*
\b
\m 
\v 5 ؤُ خْمِي ڭُّورغْ، إِنَّا أَيِي ونِّي إِقِّيمنْ خْ ڒْعَارْشْ:
\b
\m \qt ”خْژَارْ، أَذْ ڭّغْ مَارَّا ذ جْذِيذْ!“\qt*
\b
\m \add خَاسْ ؤُشَا\add* إِنَّا أَيِي:
\b
\m \qt ”أَرِي: أَوَاڒنْ-أَ أَقَا ذَايْسنْ ڒَامَانْ ذ ثِيذتّْ.“\qt* \x ◘ \xo 21:‏5 \xt إِشا. 43‏:‏19؛ 2 كُور. 5‏:‏17؛ أَسَا. 4‏:‏2؛ 19‏:‏9؛ 20‏:‏11. \x*
\b
\m 
\v 6 نتَّا إِنَّا أَيِي:
\b
\m \qt ”أَقَا إِتّْوَاكمّڒْ.\qt*
\m \qt نشّْ ذ أَلِيفْ ؤُ نشّْ ذ ثَاوْ،\qt*
\m \qt نشّْ ذ بدُّو ذ أَكمّڒْ.\qt*
\m \qt ونِّي إِفُّوذنْ أَذْ أَسْ وْشغْ\qt*
\m \qt \tl أَذْ إِسُو\tl* بَاطڒْ\qt*
\m \qt زِي ڒْعُونْصَارْ ن وَامَانْ ن ثُوذَارْثْ.\qt* \x ◘ \xo 21:‏6 \xt إِشا. 41‏:‏4؛ 44‏:‏6؛ 55‏:‏1؛ أَسَا. 1‏:‏8؛ 16‏:‏17؛ 22‏:‏13. \x*
\m 
\v 7 \qt وِي غَا إِغلّْبنْ أَذْ إِوَارْثْ مَانْ أَيَا،\qt*
\m \qt ؤُشَا نشّْ أَذْ إِڒِيغْ ذ أَربِّي نّسْ،\qt*
\m \qt ؤُ نتَّا أَذْ يِيڒِي ذ مِّي.\qt* \x ◘ \xo 21:‏7 \xt زَاك. 8‏:‏8؛ عبر. 8‏:‏10. \x*
\m 
\v 8 \qt مَاشَا إِنِّي إِتّْشكَّانْ، ذ لْكُوفَّارْ،\qt*
\m \qt ذ إِعفَّاننْ، ذ إِمخْمَاجْ،\qt*
\m \qt ذ يِينِّي إِنقّنْ، ذ يِينِّي إِڭِّينْ ثَاسحَّارْثْ،\qt*
\m \qt ذ أَيْثْ ن فَارْقْ-شّْغڒْ\qt*
\m \qt ذ يِينِّي إِعبّْذنْ لْ-أَصْنَامْ\qt*
\m \qt ذ مَارَّا أَيْثْ ن بُو-إِخَارِّيقنْ،\qt*
\m \qt أَذْ ثِيڒِي ثسْغَارْثْ نْسنْ\qt*
\m \qt ذِي ڒبْحَارْ إِتّْشفْشُوفنْ\qt*
\m \qt س ثْمسِّي ذ ڒشْبَاريّثْ،\qt*
\m \qt ثَا ذ ڒْموْثْ وِيسّْ ثْنَاينْ.“\qt* \x ◘ \xo 21:‏8 \xt أَسَا. 20‏:‏14، 15؛ 22‏:‏15. \x*
\b
\s1 ؤُرْشَالِيمْ ن جْذِيذْ
\m 
\v 9 ؤُشَا يُوسَا-د إِجّنْ زِي سبْعَا ن لْمَالَاكَاثْ، ثِينِّي غَارْسنْثْ سبْعَا ن طَّاوْيَاثْ شُّورنْثْ س سبْعَا ن جّْرَايحْ ثِينڭُّورَا، إِسِّيوڒْ أَكِيذِي، إِنَّا:
\b
\m \qt ”أَسْ-د، أَذْ أَشْ سّشْنغْ ثَاسْڒِيثْ، ثَامْغَارْثْ ن يزْمَارْ.“\qt* \x ◘ \xo 21:‏9 \xt أَسَا. 15‏:‏6، 7. \x*
\b
\m 
\v 10 إِنْذهْ أَيِي ذِي أَرُّوحْ غَارْ إِجّْ ن وذْرَارْ ذ أَمقّْرَانْ يُوعْڒَانْ أَطَّاسْ ؤُشَا إِسّْشنْ أَيِي ثَانْذِينْثْ إِقدّْسنْ، ؤُرْشَالِيمْ، أَمْ د-ثهْوَا زڭْ ؤُجنَّا، زِي زَّاثْ ن أَربِّي. \x ◘ \xo 21:‏10 \xt عبر. 12‏:‏22؛ أَسَا. 1‏:‏10؛ 21‏:‏2. \x*
\v 11 أَعُودْجِي ن أَربِّي ثُوغَا غَارسْ، ؤُشَا طّْيَا نّسْ ثتِّيسِّيقْ أَمْ يِيژْرَا إِغْڒَانْ أَطَّاسْ، أَمْ وژْرُو ن يَاسْبِيسْ نِّي د-إِضْهَارنْ أَمْ ؤُكْرِيسْثَالْ.
\v 12 إِقُووَّارْ أَسْ د إِجّْ ن وغْبَارْ ذ أَمقّْرَانْ يُوعْڒَا، غَارسْ ثنْعَاشْ ن ثوُّورَا ؤُ ثنْعَاشْ ن لْمَالَاكَاثْ \add ثُوغَا تّْبدَّانْثْ\add* غَارْ ثِيوُّورَا. ؤُ تّْوَارِينْ إِسْمَاونْ \add خْ ثِيوُّورَا نِّي\add*، أَقَا إِسْمَاونْ ن ثنْعَاشْ ن ثْقبَّاڒْ ن إِسْرَائِيل.
\v 13 \add أَقَا ذِينْ\add* ثْڒَاثَا ن ثوُّورَا غَارْ مَانِيسْ ذ ثْنقَّارْ ثْفُوشْثْ ؤُ غَارْ شَّامَالْ ثْڒَاثَا ن ثوُّورَا ؤُ غَارْ لْجَانُوبْ ثْڒَاثَا ن ثوُّورَا ؤُ \add أَقَا ذِينْ\add* ثْڒَاثَا ن ثوُّورَا غَارْ مَانِي ثْغدْجِي ثْفُوشْثْ.
\v 14 أَغْبَارْ ن ثنْذِينْثْ إِبدّْ خْ ثنْعَاشْ ن ذْسُوسَا تّْوَارِينْ خَاسنْ ثنْعَاشْ ن إِسْمَاونْ ن رُّوسُولْ ن مِّيسْ \add ن أَربِّي\add*. \x ◘ \xo 21:‏14 \xt أَفا. 2‏:‏20. \x*
\m 
\v 15 ونِّي ثُوغَا أَكِيذِي إِسَّاوَاڒنْ، غَارسْ إِجّْ ن ؤُغَانِيمْ ن ڒعْبَارْ حِيمَا أَذْ \add زَّايسْ\add* إِعْبَارْ ثَانْذِينْثْ ذ وغْبَارْ نّسْ. \x ◘ \xo 21:‏15 \xt حِز. 40‏:‏3؛ زَاك. 1‏:‏18. \x*
\v 16 ثَانْذِينْثْ ثُوغَا ثمَّارْسْ \add ذِينْ أَمْ\add* إِجّْ ن ؤُكْوَاذْرُونْ، ثَازُوڭَّارْثْ نّسْ أَمْ ثِيرُو نّسْ. نتَّا إِعْبَارْ ثَانْذِينْثْ س \add ؤُغَانِيمْ نّسْ\add* ن ڒعْبَارْ: ثنْعَاشْ-أَڒفْ ن ’إِسْثَاذِييّنْ‘، \add عْڒَاحَاڒْ أَڒْفَاينْ ؤُ مِيثَاينْ كِيلُومِيثْرْ\add*. ثَازُوڭَّارْثْ نّسْ ذ ثِيرُو نّسْ ذ ڒُوعْڒَا نّسْ ذ إِشْثنْ.
\v 17 إِعْبَارْ أَغْبَارْ نّسْ: مْيَا ؤُ-أَربْعَا ؤُ-ربْعِينْ ن إِغَادْجنْ، أَقَا-ث ذ ڒْقدّْ ن إِجّْ ن بْنَاذمْ، أَقَا-ث ن لْمَالَاكْ.
\v 18 أَغْبَارْ نّسْ ڭِّينْ ث س يَاسْبِيسْ، ؤُ ثَانْذِينْثْ ڭِّينْثْ س وُورغْ إِصْفَانْ، إِتّْبَانْ أَمْ زَّاجْ إِصْفَانْ.
\v 19 ذْسُوسَا ن وغْبَارْ ن ثنْذِينْثْ ثُوغَا تّْوَازوّْقنْ كُوڒْشِي س إِژْرَا إِغْڒَانْ. ثُوغَا ذْسَاسْ أَمزْوَارُو ن \add وژْرُو ن\add* يَاسْبِيسْ، ونِّي وِيسّْ ثْنَاينْ ن صَافِّيرْ، ونِّي وِيسّْ ثْڒَاثَا ن خَالْشِيذُونْ، ونِّي وِيسّْ أَربْعَا ن سْمِيرَالْذَا،
\v 20 ونِّي ذ وِيسّْ خمْسَا ن سَارْذُونِيكْسْ، ونِّي وِيسّْ ستَّا ن سَارْذِييُوسْ، ونِّي وِيسّْ سبْعَا ن وژْرُو ن وُورغْ، ونِّي وِيسّْ ثْمنْيَا ن بِيرِيلْ، ونِّي وِيسّْ ثسْعَا ن ثُوبَاسْ، ونِّي وِيسّْعشْرَا ن كْرِيسُوپْرَاسْ، ونِّي وِيسّْ حِيطَاشْ ن يَازِينْثْ ؤُشَا ونِّي وِيسّْ ثنْعَاشْ ن ؤُمثِيسْثْ.
\v 21 ثنْعَاشْ ن ثوُّورَا ذ ثنْعَاشْ ن ثْيَاقُوثِينْ، إِشْثْ إِشْثْ. كُوڒْ إِشْثنْ \add زِي ثوُّورَا\add* نِّي ثُوغَا زڭْ إِشْثْ ن ثْيَاقُوثْ. مَاشَا أَبْرِيذْ يِيرِيونْ ن ثنْذِينْثْ ثُوغَا-ث ن وُورغْ إِصْفَانْ، أَمْ زَّاجْ إِصْفَانْ.
\m 
\v 22 وَارْ ژْرِيغْ شَا زَّاوشْثْ ذَايسْ مِينْزِي سِيذِي أَربِّي، أَمْزمَّارْ خْ كُوڒْشِي، نتَّا سِيمَانْثْ نّسْ ذ زَّاوشْثْ نّسْ.
\v 23 إِزْمَارْ ذ ثنْذِينْثْ وَارْ حْذَاجنْ شَا ثَافُوشْثْ ؤُڒَا ذ ثَازِيرِي، حِيمَا أَذْ خَاسْ سَّارْغنْثْ، مِينْزِي أَعُودْجِي ن أَربِّي يَارقّْ ذَايسْ ؤُشَا إِزْمَارْ ذ ڒفْنَارْ نّسْ. \x ◘ \xo 21:‏23 \xt إِشا. 60‏:‏19؛ زَاك. 14‏:‏7. \x*
\v 24 ڒڭْنُوسْ أَذْ ؤُيُورنْ س ثْفَاوْثْ نّسْ ؤُشَا إِجدْجِيذنْ ن ثمُّورْثْ أَذْ غَارسْ سِّيذْفنْ أَعُودْجِي \add نْسنْ\add*. \x ◘ \xo 21:‏24 \xt إِشا. 60‏:‏3. \x*
\v 25 ثِيوُّورَا نّسْ وَارْ تّْوَاقّْننْثْعمَّارْصْ س ؤُزِيڒْ، مِينْزِي دْجِيڒثْ وَارْ ثتّْغِيمِي شَا ذِينْ. \x ◘ \xo 21:‏25 \xt إِشا. 60‏:‏11؛ أَسَا. 22‏:‏5. \x*
\v 26 نِيثْنِي أَذْ أَوْينْ غَارسْ أَعُودْجِي ذ شَّانْ ن ڒڭْنُوسْ.
\v 27 عمَّارْصْ أَذْ ذَايسْ ثَاذفْ شَا ن ڒْحَاجّثْ ثَامنْڭُوسْثْ نِيغْ ونِّي إِڭِّينْ نّْعَاوَاثْ نِيغْ ونِّي إِسّْخَارِّيقنْ، مْغِيرْ إِنِّي إِتّْوَازمّمنْ ذڭْ وذْلِيسْ \add إِتّْوَانْضنْ\add* ن يزْمَارْ وَاهَا. \x ◘ \xo 21:‏27 \xt ؤُف. 32‏:‏32؛ إِزهد. 69‏:‏29؛ فِيل. 4‏:‏3؛ أَسَا. 3‏:‏5؛ 13‏:‏8؛ 20‏:‏12. \x*
\b
\b
\c 22
\s1 إِغْزَارْ ن وَامَانْ إِدَّارنْ
\m 
\v 1 ؤُشَا نتَّا إِسّْشنْ أَيِي إِجّْ ن إِغْزَارْ إِزْذِيڭْ ن وَامَانْ إِدَّارنْ، ذ أَمزْذَاڭْ، إِصْفَا أَمْ ؤُكْرِيسْثَالْ، إِ د-إِتّفّْغنْ زِي ڒْعَارْشْ ن أَربِّي ؤُ ن يزْمَارْ. \x ◘ \xo 22:‏1 \xt حِز. 47‏:‏1؛ زَاك. 14‏:‏8. \x*
\v 2 ذِي ڒْوسْطْ ن وَازَّايْ نّسْ، خْ ثْمَا-يَا ؤُ خْ ثْمَا نِّي ن إِغْزَارْ، ثُوغَا ثَاشجَّارْثْ ن ثُوذَارْثْ ثنِّي ثسّنْضَايْ ڒْغِيدْجثْ ثنْعَاشْ \add ن ثْوَاڒَاوِينْ\add*. ذِي مْكُوڒْ أَيُورْ ثتِّيشْ ڒْغِيدْجثْ نّسْ ذ ثِيفْرَايْ نّسْ إِ ؤُسْڭنْفُو ن ڒڭْنُوسْ. \x ◘ \xo 22:‏2 \xt حِز. 47‏:‏1‏-‏12؛ أَسَا. 2‏:‏7. \x*
\v 3 وَارْ ذَايسْ ثتِّيڒِي عَاذْ نّعْڒثْ. أَذْ ذَايسْ يِيڒِي ڒْعَارْشْ ن أَربِّي ؤُ ن يزْمَارْ ؤُشَا إِمْسخَّارنْ نّسْ أَذْ خَاسْ سخَّارنْ.
\v 4 نِيثْنِي أَذْ ژَترنْ ؤُذمْ نّسْ، إِسمْ نّسْ أَذْ يِيڒِي خْ ثنْيَارِينْ نْسنْ. \x ◘ \xo 22:‏4 \xt أَسَا. 3‏:‏12. \x*
\v 5 وَارْ ذِينْ ثتِّيڒِي دْجِيڒثْ ؤُشَا نِيثْنِي وَارْ تّحْذِيجنْ عَاذْ طّْيَا ن ڒفْنَارَاثْ نِيغْ ن ثْفَاوِينْ نِيغْ ن ثْفَاوْثْ ن ثْفُوشْثْ، مِينْزِي سِيذِي أَربِّي أَذْ أَسنْ إِڭّْ ثَافَاوْثْ ؤُشَا أَذْ يِيڒِي ذ أَجدْجِيذْ نْسنْ إِ ڒبْذَا قَاعْ. \x ◘ \xo 22:‏5 \xt إِشا. 60‏:‏19؛ زَاك. 14‏:‏7؛ أَسَا. 21‏:‏23. \x*
\b
\m 
\v 6 \add خَاسْ ؤُشَا\add* إِنَّا أَيِي:
\b
\m \qt ”أَوَاڒنْ-أَ ذَايْسنْ ڒَامَانْ ذ ثِيذتّْ!\qt*
\m \qt سِيذِي، أَربِّي ن أَرُّوحْ ن إِنَابِييّنْ إِقدّْسنْ،\qt*
\m \qt أَقَا إِسّكّْ لْمَالَاكْ نّسْ،\qt*
\m \qt حِيمَا أَذْ إِسّْشنْ إِ إِمْسخَّارنْ نّسْ\qt*
\m \qt مِينْ إِ غَا يِيڒِينْ ذغْيَا.“\qt* \x ◘ \xo 22:‏6 \xt أَسَا. 1‏:‏1؛ 19‏:‏9؛ 21‏:‏5. \x*
\b
\m 
\v 7 \bdit ”خْزَارْ نشّْ أَذْ د-أَسغْ ذغْيَا!\bdit*
\m \bdit سّعْذْ\bdit* \qt ن ونِّي إِتّطّْفنْ\qt*
\m \qt ذڭْ وَاوَاڒنْ ن نُّوبُووَاثْ\qt*
\m \qt ن وذْلِيسْ-أَ \tl إِتّْوَانْضنْ\tl*.“\qt* \x ◘ \xo 22:‏7 \xt أَسَا. 1‏:‏3. \x*
\b
\m 
\v 8 نشّْ، يُوحَانَّا، أَقَا ژْرِيغْ ؤُ سْڒِيغْ ثِيمسْڒَايِينْ-أَ. ؤُشَا ڒَامِي ثنْثْ ژْرِيغْ ؤُ سْڒِيغْ، وْضِيغْ غَارْ إِضَارنْ ن لْمَالَاكْ ونِّي ذ أَيِي إِسّشْننْ ثِيمسْڒَايِينْ-أَ، حِيمَا أَذْ \add أَسْ\add*عبْذغْ.
\v 9 \add مَاشَا\add* نتَّا إِنَّا أَيِي:
\b
\m \qt ”حْضَا، لَّا، وَارْ تّڭّْ مَانْ أَيَا،\qt*
\m \qt \tl مَاغَارْ\tl* نشّْ ذ أَمْسخَّارْ أَمْعَاشَارْ نّشْ،\qt*
\m \qt ؤُ ن أَيْثْمَاشْ، إِنَابِييّنْ، ؤُڒَا ن يِينِّي إِتّطّْفنْ\qt*
\m \qt ذڭْ وَاوَاڒنْ ن وذْلِيسْ-أَ \tl إِتّْوَانْضنْ\tl*.\qt*
\m \qt عبْذثْ أَربِّي!“\qt* \x ◘ \xo 22:‏9 \xt ڒخ. 10‏:‏26؛ 14‏:‏14؛ أَسَا. 19‏:‏10. \x*
\b
\m 
\v 10 \add خَاسْ ؤُشَا\add* إِنَّا أَيِي:
\b
\m \qt ”وَارْ تّڭّْ أَشمِّيعْ خْ وَاوَاڒنْ إِ إِتّْوَانَابّن\qt*
\m \qt ذڭْ وذْلِيسْ-أَ \tl إِتّْوَانْضنْ\tl*،\qt*
\m \qt مِينْزِي ڒْوقْثْ أَقَا ثِيوضْ-د.“\qt* \x ◘ \xo 22:‏10 \xt دَان. 8‏:‏26؛ 12‏:‏4؛ أَسَا. 1‏:‏3. \x*
\b
\m 
\v 11 \qt ”ونِّي إِتّڭّنْ مِينْ وَارْ إِسڭّْذنْ،\qt*
\m \qt أَذْ إِڭّْ مِينْ وَارْ إِسڭّْذنْ كْثَارْ،\qt*
\m \qt أَمنْڭُوسْ أَذْ إِذْوڒْ ذ أَمنْڭُوسْ كْثَارْ،\qt*
\m \qt أَمْسڭَّاذْ أَذْ إِڭّْ ثَاسڭْذَا كْثَارْ\qt*
\m \qt ؤُشَا أَمْقدَّاسْ أَذْ إِذْوڒْ ذ أَمْقدَّاسْ كْثَارْ.“\qt*
\b
\m 
\v 12 \bdit ”خْزَارْ، نشّْ أَذْ د-أَسغْ ذغْيَا\bdit*
\m \qt ؤُشَا ڒْمُونثْ إِنُو أَقَا-ت أَكِيذِي،\qt*
\m \qt حِيمَا أَذْ خدْجْصغْ كُوڒْ إِجّنْ\qt*
\m \qt أَنشْثْ ن ڒْخذْمثْ نّسْ.\qt* \x ◘ \xo 22:‏12 \xt إِزهد. 62‏:‏13؛ إِرْم. 17‏:‏10؛ 32‏:‏19؛ مت. 16‏:‏27؛ رُوم. 2‏:‏6؛ 14‏:‏12؛ 1 كُور. 3‏:‏8؛ 2 كُور. 5‏:‏10؛ ڭال. 6‏:‏5؛ أَسَا. 2‏:‏23. \x*
\m 
\v 13 \qt نشّْ ذ أَلِيفْ ؤُ نشّْ ذ ثَاوْ،\qt*
\m \qt ذ أَمزْوَارُو ذ أَنڭَّارُو،\qt*
\m \qt ذ بدُّو ذ أَكمّڒْ.“\qt* \x ◘ \xo 22:‏13 \xt إِشا. 41‏:‏4؛ 44‏:‏6؛ 48‏:‏12؛ أَسَا. 1‏:‏8؛ 21‏:‏6. \x*
\b
\m 
\v 14 ”\bdit سّعْذْ\bdit* \qt نْسنْ إِ يِينِّي إِتّڭّنْ ثِيوصَّا نّسْ.\qt*
\m \qt أَذْ غَارْسنْ ثِيڒِي صُّولْطَا خْ ثْشجَّارْثْ ن ثُوذَارْثْ\qt*
\m \qt ؤُشَا أَذْ د-أَذْفنْ غَارْ ثنْذِينْثْ\qt*
\m \qt زِي ثوُّورَا نّسْ.\qt*
\m 
\v 15 \qt بَارَّا إِدْجَانْ إِنِّي إِتّڭّنْ فَارْقْ-شّْغڒْ\qt*
\m \qt ذ يِينِّي إِنقّنْ\qt*
\m \qt ذ يِينِّي إِعبّْذنْ لْ-أَصْنَامْ\qt*
\m \qt ذ يِينِّي ذَايْسنْ ڒخْمجْ\qt*
\m \qt ذ يِينِّي إِتّْسحَّارنْ ذ مَارَّا إِمْوَاڒَاونْ\qt*
\m \qt ذ إِنِّي إِتّڭّنْ مِينْ إِ د-إِتّفّْغنْ\qt*
\m \qt زڭْ ؤُخَارِّيقْ.“\qt* \x ◘ \xo 22:‏15 \xt 1 كُور. 6‏:‏10؛ أَفا. 5‏:‏5؛ كُول. 3‏:‏5، 6. \x*
\b
\m 
\v 16 \qt ”نشّْ، يَاسُوع، أَقَا سّكّغْ لْمَالَاكْ إِنُو\qt*
\m \qt مَاحنْذْ أَذْ خَاومْ إِشْهذْ مَانْ أَيَا\qt*
\m \qt زَّاثْ إِ ثْمسْمُونِينْ.\qt*
\m \qt أَقَا ذ نشّْ، ذ أَژْوَارْ ذ زَّارِيعثْ ن ذَاوُوذْ،\qt*
\m \qt ذ ونِّي أَكِيذسْ،\qt*
\m \qt ذ إِثْرِي ن ڒفْجَارْ يَارقّنْ.“\qt* \x ◘ \xo 22:‏16 \xt إِشا. 11‏:‏10؛ رُوم. 15‏:‏12؛ 2 بُط. 1‏:‏19؛ أَسَا. 1‏:‏1؛ 5‏:‏5. \x*
\b
\m 
\v 17 أَرُّوحْ ذ ثسْڒِيثْ قَّارنْ:
\b
\m \bdit ”أَسْ-د!“\bdit*
\b
\m ؤُشَا أجّْ ونِّي ث إِسْڒِينْ، أَذْ يِينِي:
\b
\m \bdit ”أَسْ-د!“\bdit*
\b
\m \qt ”ذ ونِّي إِفُوذنْ، أجّْ إِ-ث أَذْ د-يَاسْ،\qt*
\m \qt أَذْ إِسُو أَمَانْ إِدَّارنْ بَاطڒْ.“\qt* \x ◘ \xo 22:‏17 \xt إِشا. 55‏:‏1؛ يُوح. 7‏:‏37\x*
\b
\m 
\v 18 \qt ”نشّْ شهّْذغْ إِ مَارَّا إِنِّي إِتّسْڒَانْ\qt*
\m \qt إِ وَاوَاڒنْ ن نُّوبُووَا ن وذْلِيسْ-أَ \tl إِتّْوَانْضنْ\tl*:\qt*
\m \qt مَاڒَا ذِينْ حذْ ونِّي خَاسنْ إِ غَا يَارْنِينْ،\qt*
\m \qt أَربِّي أَذْ خَاسْ يَارْنِي جّْرَايحْ،\qt*
\m \qt ثِينِّي إِتّْوَازمّمنْ ذڭْ وذْلِيسْ-أَ.\qt*
\m 
\v 19 \qt مَاڒَا شَا ن إِجّنْ إِكّسْ زڭْ وَاوَاڒنْ\qt*
\m \qt ن وذْلِيسْ \tl إِتّْوَانْضنْ\tl* ن نُّوبُووَا-يَا،\qt*
\m \qt أَذْ أَسْ إِكّسْ أَربِّي ثَاسْغَارْثْ نّسْ\qt*
\m \qt زِي ثْشجَّارْثْ ن ثُوذَارْثْ ؤُ زِي ثنْذِينْثْ إِقدّْسنْ.“\qt* \x ◘ \xo 22:‏19 \xt أَعَوذ. 4‏:‏2؛ 12‏:‏32؛ أَوڒن. 30‏:‏6؛ أَسَا. 13‏:‏8؛ 17‏:‏8. \x*
\b
\m 
\v 20 خْمِي نتَّا إِشْهذْ خْ مَانْ أَيَا، إِنَّا:
\b
\m \bdit ”وَاهْ، نشّْ أَذْ د-أَسغْ ذغْيَا!“\bdit*
\b
\m \bdit ”أَسْ-د،\bdit* \qt \tl أَ\tl* سِيذِي يَاسُوع!“\qt*
\b
\m 
\v 21 أَرْضَا ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ \add أَقَا-ث\add* أَكْ-ذ مَارَّا إِمْقدَّاسنْ نّسْ. ”أَمِينْ!“
\b
\m أَنڭَّارْ ن ڒْعَاهْذْ ن جْذِيذْ.
\b
\m أَعُودْجِي إِ يِيسمْ ن أَربِّي،
\m بَابَاثْنغْ ذ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ
\m ذ أَرُّوحْ إِقدّْسنْ. 
