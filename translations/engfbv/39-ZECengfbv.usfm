\p 
\v 4 \w The|strong="H6440"\w* angel \w said|strong="H6030"\w* \w to|strong="H5921"\w* \w those|strong="H5921"\w*\f + \fr 3:4 \ft Presumably other angels.\f* \w standing|strong="H5975"\w* \w there|strong="H5975"\w*, “\w Take|strong="H5493"\w* \w off|strong="H5493"\w* \w his|strong="H6440"\w* \w filthy|strong="H6674"\w* \w clothes|strong="H3847"\w*.” \w Then|strong="H6030"\w* \w he|strong="H5921"\w* \w said|strong="H6030"\w* \w to|strong="H5921"\w* Joshua, “\w See|strong="H7200"\w* \w how|strong="H6030"\w* \w I|strong="H5921"\w* \w have|strong="H5771"\w* \w taken|strong="H5493"\w* \w away|strong="H5493"\w* \w your|strong="H5921"\w* \w sins|strong="H5771"\w* \w from|strong="H5493"\w* \w you|strong="H6440"\w*, \w and|strong="H6030"\w* \w now|strong="H5921"\w* \w I|strong="H5921"\w* am dressing \w you|strong="H6440"\w* \w with|strong="H3847"\w* fine \w clothes|strong="H3847"\w*.”
\p 
\v 5 \w Then|strong="H5975"\w* \w I|strong="H7760"\w* said, “Wrap \w a|strong="H3068"\w* \w clean|strong="H2889"\w* \w turban|strong="H6797"\w* \w around|strong="H5921"\w* \w his|strong="H3068"\w* \w head|strong="H7218"\w*.” \w So|strong="H7760"\w* \w they|strong="H3068"\w* wrapped \w a|strong="H3068"\w* \w clean|strong="H2889"\w* \w turban|strong="H6797"\w* \w around|strong="H5921"\w* \w his|strong="H3068"\w* \w head|strong="H7218"\w* \w and|strong="H3068"\w* \w put|strong="H7760"\w* \w the|strong="H5921"\w* \w clothes|strong="H3847"\w* \w on|strong="H5921"\w* \w him|strong="H5921"\w* \w while|strong="H5921"\w* \w the|strong="H5921"\w* \w angel|strong="H4397"\w* \w of|strong="H3068"\w* \w the|strong="H5921"\w* \w Lord|strong="H3068"\w* \w stood|strong="H5975"\w* \w there|strong="H5975"\w*.
\p 
\v 6 \w Then|strong="H3068"\w* \w the|strong="H3068"\w* \w angel|strong="H4397"\w* \w of|strong="H3068"\w* \w the|strong="H3068"\w* \w Lord|strong="H3068"\w* \w solemnly|strong="H5749"\w* advised \w Joshua|strong="H3091"\w*, saying,
\v 7 “\w This|strong="H3541"\w* \w is|strong="H3068"\w* \w what|strong="H3541"\w* \w the|strong="H5414"\w* \w Lord|strong="H3068"\w* \w Almighty|strong="H6635"\w* \w says|strong="H3541"\w*: If \w you|strong="H5414"\w* \w follow|strong="H3212"\w* \w my|strong="H8104"\w* \w ways|strong="H1870"\w* \w and|strong="H3068"\w* \w observe|strong="H8104"\w* \w my|strong="H8104"\w* \w commands|strong="H1870"\w*, \w then|strong="H5414"\w* \w you|strong="H5414"\w* \w will|strong="H3068"\w* \w govern|strong="H1777"\w* \w my|strong="H8104"\w* \w Temple|strong="H1004"\w* \w and|strong="H3068"\w* \w its|strong="H5414"\w* \w courtyards|strong="H2691"\w*. \w I|strong="H5414"\w* \w will|strong="H3068"\w* \w allow|strong="H5414"\w* \w you|strong="H5414"\w* \w to|strong="H3212"\w* \w walk|strong="H3212"\w* among those \w standing|strong="H5975"\w* \w here|strong="H3541"\w*.
\v 8 \w Pay|strong="H8085"\w* \w attention|strong="H8085"\w*, \w high|strong="H1419"\w* \w priest|strong="H3548"\w* \w Joshua|strong="H3091"\w* \w and|strong="H1419"\w* \w all|strong="H1419"\w* \w your|strong="H6440"\w* fellow-priests \w that|strong="H3588"\w* \w you|strong="H3588"\w* teach!\f + \fr 3:8 \ft Literally, “friends who sit before you.”\f* \w You|strong="H3588"\w* \w are|strong="H1992"\w* \w a|strong="H3068"\w* \w sign|strong="H4159"\w* \w of|strong="H3427"\w* \w good|strong="H2005"\w* \w things|strong="H1419"\w* \w to|strong="H6440"\w* \w come|strong="H4994"\w*. \w Look|strong="H2005"\w*! \w I|strong="H3588"\w* \w am|strong="H2005"\w* \w going|strong="H2005"\w* \w to|strong="H6440"\w* bring \w my|strong="H8085"\w* \w servant|strong="H5650"\w*, \w the|strong="H6440"\w* \w Branch|strong="H6780"\w*.\f + \fr 3:8 \ft Both “my servant” and “the branch” are titles applied to the Messiah.\f*
\v 9 \w See|strong="H2009"\w* \w that|strong="H3588"\w* \w I|strong="H3588"\w* \w have|strong="H3068"\w* \w placed|strong="H5414"\w* \w a|strong="H3068"\w* precious stone \w in|strong="H5921"\w* \w front|strong="H6440"\w* \w of|strong="H3068"\w* \w Joshua|strong="H3091"\w*, \w a|strong="H3068"\w* single stone \w with|strong="H3068"\w* \w seven|strong="H7651"\w* \w faces|strong="H6440"\w*. \w Watch|strong="H2009"\w*, \w for|strong="H3588"\w* \w I|strong="H3588"\w* myself \w am|strong="H3068"\w* \w going|strong="H2005"\w* \w to|strong="H3068"\w* \w engrave|strong="H6605"\w* \w seven|strong="H7651"\w* \w eyes|strong="H5869"\w* \w on|strong="H5921"\w* \w it|strong="H5414"\w*, \w declares|strong="H5002"\w* \w the|strong="H6440"\w* \w Lord|strong="H3068"\w* \w Almighty|strong="H6635"\w*, \w and|strong="H3068"\w* \w I|strong="H3588"\w* \w will|strong="H3068"\w* wipe \w away|strong="H4185"\w* \w the|strong="H6440"\w* \w sins|strong="H5771"\w* \w of|strong="H3068"\w* \w this|strong="H1931"\w* \w land|strong="H6440"\w* \w in|strong="H5921"\w* \w a|strong="H3068"\w* single \w day|strong="H3117"\w*.
\v 10 \w On|strong="H3117"\w* \w that|strong="H3117"\w* \w day|strong="H3117"\w* everyone \w will|strong="H3068"\w* \w invite|strong="H7121"\w* \w their|strong="H3068"\w* \w friends|strong="H7453"\w* \w to|strong="H3068"\w* sit \w in|strong="H3068"\w* peace\f + \fr 3:10 \ft “In peace” implied. \f* \w under|strong="H8478"\w* \w their|strong="H3068"\w* \w vines|strong="H1612"\w* \w and|strong="H3068"\w* \w fig|strong="H8384"\w* \w trees|strong="H8384"\w*, \w says|strong="H5002"\w* \w the|strong="H5002"\w* \w Lord|strong="H3068"\w* \w Almighty|strong="H6635"\w*.”
\b
\c 4
\p 
\v 1 \w Then|strong="H1696"\w* \w the|strong="H7725"\w* \w angel|strong="H4397"\w* \w I|strong="H5782"\w* had been \w talking|strong="H1696"\w* \w to|strong="H1696"\w* \w returned|strong="H7725"\w* \w and|strong="H7725"\w* got \w my|strong="H7725"\w* attention, \w like|strong="H7725"\w* waking someone \w from|strong="H7725"\w* \w sleep|strong="H8142"\w*.\f + \fr 4:1 \ft Clearly Zechariah was not actually asleep, only deep in thought. \f*
\p 
\v 2 “\w What|strong="H4100"\w* \w do|strong="H4100"\w* \w you|strong="H3605"\w* \w see|strong="H7200"\w*?” \w he|strong="H3605"\w* \w asked|strong="H4100"\w* \w me|strong="H7200"\w*.
\p “\w I|strong="H2009"\w* \w see|strong="H7200"\w* \w a|strong="H3068"\w* \w lampstand|strong="H4501"\w* \w made|strong="H3605"\w* \w of|strong="H7218"\w* solid \w gold|strong="H2091"\w* \w with|strong="H5921"\w* \w a|strong="H3068"\w* \w bowl|strong="H1543"\w* \w at|strong="H5921"\w* \w its|strong="H3605"\w* \w top|strong="H7218"\w* having \w seven|strong="H7651"\w* \w lamps|strong="H5216"\w* \w on|strong="H5921"\w* \w it|strong="H5921"\w*, \w each|strong="H3605"\w* \w with|strong="H5921"\w* \w seven|strong="H7651"\w* lips.\f + \fr 4:2 \ft The lips are small channels holding the wicks.\f*
