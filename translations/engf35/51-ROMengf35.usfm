\s2 Before circumcision  
\p
\v 9 \w Is|strong="G3588"\w* \w this|strong="G3778"\w* \w blessing|strong="G3108"\w* \w then|strong="G3767"\w* \w only|strong="G2532"\w* \w for|strong="G1063"\w* \w the|strong="G2532"\w* \w circumcised|strong="G4061"\w*, \w or|strong="G2228"\w* \w also|strong="G2532"\w* \w for|strong="G1063"\w* \w the|strong="G2532"\w* uncircumcised? \w Since|strong="G1063"\w* \w we|strong="G1063"\w* \w say|strong="G3004"\w* \w that|strong="G3588"\w* \w faith|strong="G4102"\w* \w was|strong="G3588"\w* \w credited|strong="G3049"\w* \w to|strong="G1519"\w* Abraham \w as|strong="G1519"\w* \w righteousness|strong="G1343"\w*,  
