\v 24 \w Micaiah|strong="H4321"\w* replied, “\w You|strong="H3117"\w* \w will|strong="H1931"\w* \w find|strong="H7200"\w* \w out|strong="H7200"\w* \w for|strong="H3117"\w* yourself \add to which of us Yahweh’s Spirit has truly spoken\add* \w on|strong="H3117"\w* \w the|strong="H7200"\w* \w day|strong="H3117"\w* \w when|strong="H3117"\w* \w you|strong="H3117"\w* go \w into|strong="H7200"\w* \w a|strong="H3068"\w* \w room|strong="H2315"\w* \w of|strong="H3117"\w* \w some|strong="H3117"\w* house \w to|strong="H3117"\w* \w hide|strong="H2244"\w* \add from the Syrian soldiers\add*!”   
\p
\v 25 \w King|strong="H4428"\w* Ahab commanded \add his soldiers\add*, “\w Seize|strong="H3947"\w* \w Micaiah|strong="H4321"\w* \w and|strong="H1121"\w* \w take|strong="H3947"\w* \w him|strong="H7725"\w* \w to|strong="H7725"\w* Amon, \w the|strong="H3947"\w* \w governor|strong="H8269"\w* \w of|strong="H1121"\w* \w this|strong="H7725"\w* \w city|strong="H5892"\w*, \w and|strong="H1121"\w* \w to|strong="H7725"\w* \w my|strong="H3947"\w* \w son|strong="H1121"\w* \w Joash|strong="H3101"\w*.  
\v 26 Tell \w them|strong="H7725"\w* \w that|strong="H4428"\w* \w I|strong="H5704"\w* \w have|strong="H7965"\w* commanded \w that|strong="H4428"\w* \w they|strong="H5704"\w* \w should|strong="H4428"\w* \w put|strong="H7760"\w* \w this|strong="H2088"\w* \w man|strong="H2088"\w* \w in|strong="H1004"\w* \w prison|strong="H1004"\w* \w and|strong="H7725"\w* \w give|strong="H7760"\w* \w him|strong="H7725"\w* \w only|strong="H5704"\w* \w bread|strong="H3899"\w* \w and|strong="H7725"\w* \w water|strong="H4325"\w*. \w Do|strong="H2088"\w* \w not|strong="H2088"\w* \w give|strong="H7760"\w* \w him|strong="H7725"\w* \w anything|strong="H3899"\w* else \w to|strong="H5704"\w* \w eat|strong="H3899"\w* \w until|strong="H5704"\w* \w I|strong="H5704"\w* \w return|strong="H7725"\w* \w safely|strong="H7965"\w* \add from the battle\add*!”   
\p
\v 27 \w Micaiah|strong="H4321"\w* \w replied|strong="H1696"\w*, “If \w you|strong="H3605"\w* \w return|strong="H7725"\w* \w safely|strong="H7965"\w*, \add it will be clear that\add* \w it|strong="H7725"\w* \w was|strong="H3068"\w* \w not|strong="H3808"\w* \w Yahweh|strong="H3068"\w* \w who|strong="H3605"\w* \w told|strong="H1696"\w* \w me|strong="H7725"\w* \w what|strong="H8085"\w* \w to|strong="H1696"\w* \w say|strong="H1696"\w* \w to|strong="H1696"\w* \w you|strong="H3605"\w*!” \w Then|strong="H1696"\w* \w he|strong="H3068"\w* \w said|strong="H1696"\w* \add to all those who were standing there\add*, “\w Do|strong="H3068"\w* \w not|strong="H3808"\w* forget \w what|strong="H8085"\w* \w I|strong="H3808"\w* \w have|strong="H3068"\w* \w said|strong="H1696"\w* \add to King Ahab\add*!”   
\s1 Ahab died in the battle at Ramoth-Gilead  
\p
\v 28 \w So|strong="H5927"\w* \w the|strong="H5927"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* \w Israel|strong="H3478"\w* \w and|strong="H3063"\w* \w the|strong="H5927"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* \w Judah|strong="H3063"\w* \add led their armies\add* \w to|strong="H3478"\w* \w Ramoth|strong="H7433"\w*, \w in|strong="H3478"\w* \add the\add* \w Gilead|strong="H1568"\w* \add region\add*.  
