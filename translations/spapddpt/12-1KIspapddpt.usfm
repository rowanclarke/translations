\v 30 Entonces Elías dijo \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*: ¡Acérquense \w a|strong="H3068"\w* mí! \w Y|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* \w acercó|strong="H5066"\w* \w a|strong="H3068"\w* \w él|strong="H3605"\w* y reparó \w el|strong="H3605"\w* \w altar|strong="H4196"\w* \w de|strong="H5971"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w que|strong="H5971"\w* fue derribado.
\v 31 Elías \w tomó|strong="H3947"\w* 12 piedras, conforme al \w número|strong="H4557"\w* \w de|strong="H1121"\w* las \w tribus|strong="H7626"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w*, al cual le \w fue|strong="H1961"\w* dada \w Palabra|strong="H1697"\w* \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*,\nd* Quien dijo, \wj \w Israel|strong="H3478"\w* \w será|strong="H1961"\w* tu \w nombre|strong="H8034"\w*.\wj*
\v 32 Con las piedras construyó un \w altar|strong="H4196"\w* en \w el|strong="H6213"\w* \w Nombre|strong="H8034"\w* de \nd \w Yavé|strong="H3068"\w*\nd*, \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* una zanja \w alrededor|strong="H5439"\w* \w del|strong="H4196"\w* \w altar|strong="H4196"\w*, en la cual cupieran dos \w medidas|strong="H5429"\w* de grano.
\p 
\v 33 Preparó luego \w la|strong="H5921"\w* \w leña|strong="H6086"\w*, cortó \w el|strong="H5921"\w* \w buey|strong="H6499"\w* \w en|strong="H5921"\w* trozos, \w los|strong="H5921"\w* colocó \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w leña|strong="H6086"\w*
\v 34 \w y|strong="H5921"\w* ordenó: Llenen cuatro \w cántaros|strong="H3537"\w* \w con|strong="H5921"\w* \w agua|strong="H4325"\w* \w y|strong="H5921"\w* derrámenla \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w holocausto|strong="H5930"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w leña|strong="H6086"\w*. \w Y|strong="H3068"\w* agregó: Háganlo \w por|strong="H5921"\w* segunda vez, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* hicieron. Dijo aún: Háganlo \w por|strong="H5921"\w* tercera vez, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* hicieron.
\v 35 Corrió \w el|strong="H1571"\w* \w agua|strong="H4325"\w* \w alrededor|strong="H5439"\w* \w del|strong="H4196"\w* \w altar|strong="H4196"\w*, \w y|strong="H1571"\w* \w la|strong="H1571"\w* zanja se \w llenó|strong="H4390"\w* \w de|strong="H4325"\w* \w agua|strong="H4325"\w*.
\p 
\v 36 \w Cuando|strong="H3588"\w* \w llegó|strong="H5066"\w* \w la|strong="H3588"\w* hora \w de|strong="H3588"\w* presentar \w el|strong="H3588"\w* holocausto, \w sucedió|strong="H1961"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w profeta|strong="H5030"\w* Elías \w se|strong="H3045"\w* \w acercó|strong="H5066"\w* \w y|strong="H3588"\w* dijo: ¡Oh \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* \w de|strong="H3588"\w* Abraham, \w Isaac|strong="H3327"\w* \w e|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w sea|strong="H1961"\w* \w hoy|strong="H3117"\w* \w manifiesto|strong="H3045"\w* \w que|strong="H3588"\w* \w Tú|strong="H6213"\w* \w eres|strong="H1961"\w* \nd ʼElohim\nd* \w en|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* \w tu|strong="H6213"\w* esclavo \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w hice|strong="H6213"\w* \w todas|strong="H3605"\w* \w estas|strong="H6213"\w* \w cosas|strong="H1697"\w* \w por|strong="H3588"\w* \w tu|strong="H6213"\w* \w Palabra|strong="H1697"\w*!
\v 37 ¡\w Respóndeme|strong="H6030"\w*, oh \nd \w Yavé|strong="H3068"\w*\nd*, \w respóndeme|strong="H6030"\w*! \w Y|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w sabrá|strong="H3045"\w* \w que|strong="H3588"\w* Tú, oh \nd \w Yavé|strong="H3068"\w*\nd*, eres \nd ʼElohim\nd* \w y|strong="H3588"\w* \w que|strong="H3588"\w* Tú devuelves sus corazones.
\p 
\v 38 Entonces \w cayó|strong="H5307"\w* fuego \w de|strong="H4325"\w* \nd \w Yavé|strong="H3068"\w*\nd* y consumió \w el|strong="H5307"\w* \w holocausto|strong="H5930"\w*, la \w leña|strong="H6086"\w*, las piedras, \w el|strong="H5307"\w* \w polvo|strong="H6083"\w* y lamió \w el|strong="H5307"\w* \w agua|strong="H4325"\w* \w que|strong="H4325"\w* había en la zanja.
\p 
\v 39 \w Al|strong="H5921"\w* verlo, \w toda|strong="H3605"\w* \w la|strong="H1931"\w* \w gente|strong="H5971"\w* \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w su|strong="H1931"\w* \w rostro|strong="H6440"\w* \w y|strong="H5921"\w* dijo: ¡\nd \w Yavé|strong="H3068"\w*\nd* \w es|strong="H1931"\w* \nd ʼElohim\nd*! ¡\nd \w Yavé|strong="H3068"\w*\nd* \w es|strong="H1931"\w* \nd ʼElohim\nd*!
\p 
\v 40 \w Y|strong="H3068"\w* Elías \w les|strong="H1992"\w* dijo: ¡Agarren \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w profetas|strong="H5030"\w* de \w baal|strong="H1168"\w*! ¡\w Que|strong="H1992"\w* ninguno \w escape|strong="H4422"\w*! \w Y|strong="H3068"\w* Elías bajó con \w ellos|strong="H1992"\w* al \w arroyo|strong="H5158"\w* de Cisón y \w allí|strong="H8033"\w* \w los|strong="H1992"\w* \w degolló|strong="H7819"\w*.
\p 
\v 41 \w Y|strong="H3068"\w* Elías dijo \w a|strong="H3068"\w* Acab: ¡Levántate, come \w y|strong="H3588"\w* \w bebe|strong="H8354"\w*, \w porque|strong="H3588"\w* hay \w sonido|strong="H6963"\w* \w de|strong="H3588"\w* abundancia \w de|strong="H3588"\w* \w lluvia|strong="H1653"\w*!
\p 
\v 42 Acab \w subió|strong="H5927"\w* \w a|strong="H3068"\w* comer y \w beber|strong="H8354"\w* y Elías \w subió|strong="H5927"\w* \w a|strong="H3068"\w* la \w cumbre|strong="H7218"\w* \w de|strong="H6440"\w* la montaña Carmelo. Al postrarse en tierra, \w puso|strong="H7760"\w* su \w rostro|strong="H6440"\w* entre sus \w rodillas|strong="H1290"\w*
\v 43 y dijo \w a|strong="H3068"\w* su esclavo: \w Sube|strong="H5927"\w* \w ahora|strong="H4994"\w*, y \w mira|strong="H5027"\w* atentamente \w hacia|strong="H1870"\w* el \w mar|strong="H3220"\w*.
\p Él \w subió|strong="H5927"\w* y \w miró|strong="H5027"\w* atentamente, y dijo: \w Nada|strong="H3972"\w* hallo. \w Y|strong="H3068"\w* él \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* decir \w siete|strong="H7651"\w* \w veces|strong="H6471"\w*: \w Vuelve|strong="H7725"\w*.
\p 
\v 44 \w Aconteció|strong="H1961"\w* \w que|strong="H3808"\w* \w a|strong="H3068"\w* la séptima vez dijo: En verdad \w sube|strong="H5927"\w* una \w nube|strong="H6996"\w* del \w mar|strong="H3220"\w*, tan \w pequeña|strong="H6996"\w* \w como|strong="H1961"\w* la \w mano|strong="H3709"\w* de un hombre.
\p \w Y|strong="H3068"\w* él dijo: \w Vé|strong="H5927"\w* y dí \w a|strong="H3068"\w* Acab: Ata las bestias \w a|strong="H3068"\w* tu carroza y \w baja|strong="H3381"\w*, \w para|strong="H1961"\w* \w que|strong="H3808"\w* la \w lluvia|strong="H1653"\w* \w no|strong="H3808"\w* \w te|strong="H3220"\w* detenga.
\p 
\v 45 \w Mientras|strong="H5704"\w* tanto, ocurrió \w que|strong="H5704"\w* \w los|strong="H1961"\w* \w cielos|strong="H8064"\w* \w se|strong="H1961"\w* oscurecieron \w con|strong="H5704"\w* \w nubes|strong="H5645"\w* \w y|strong="H5704"\w* \w viento|strong="H7307"\w*, \w y|strong="H5704"\w* \w hubo|strong="H1961"\w* una \w gran|strong="H1419"\w* \w lluvia|strong="H1653"\w*. Acab \w subió|strong="H7392"\w* \w a|strong="H3068"\w* la carroza \w y|strong="H5704"\w* \w fue|strong="H1961"\w* \w a|strong="H3068"\w* \w Jezreel|strong="H3157"\w*.
\v 46 Pero la \w mano|strong="H3027"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w estuvo|strong="H1961"\w* \w sobre|strong="H1961"\w* Elías, \w de|strong="H6440"\w* modo \w que|strong="H5704"\w* ató su cintura \w y|strong="H5704"\w* \w corrió|strong="H7323"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Acab \w hasta|strong="H5704"\w* la entrada \w de|strong="H6440"\w* \w Jezreel|strong="H3157"\w*.
\c 19
\s1 La huida de Elías a Horeb
\p 
\v 1 Acab informó \w a|strong="H3068"\w* Jezabel \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* Elías \w hizo|strong="H6213"\w* y cómo \w mató|strong="H2026"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w profetas|strong="H5030"\w*.
\v 2 \w Entonces|strong="H3588"\w* Jezabel \w envió|strong="H7971"\w* un \w mensajero|strong="H4397"\w* \w a|strong="H3068"\w* Elías, \w quien|strong="H6213"\w* dijo: ¡\w Así|strong="H3541"\w* \w me|strong="H3588"\w* \w hagan|strong="H6213"\w* \w los|strong="H1992"\w* \tl ʼelohim\tl*, \w y|strong="H3588"\w* \w aun|strong="H3254"\w* \w me|strong="H3588"\w* \w añadan|strong="H3254"\w*, \w si|strong="H3588"\w* \w mañana|strong="H4279"\w* \w a|strong="H3068"\w* \w esta|strong="H1992"\w* \w hora|strong="H6256"\w* \w no|strong="H6213"\w* \w hago|strong="H6213"\w* \w con|strong="H3588"\w* \w tu|strong="H6213"\w* \w vida|strong="H5315"\w* \w como|strong="H3588"\w* \w hiciste|strong="H6213"\w* \w con|strong="H3588"\w* \w la|strong="H3588"\w* \w vida|strong="H5315"\w* \w de|strong="H3588"\w* uno \w de|strong="H3588"\w* \w ellos|strong="H1992"\w*!
\p 
\v 3 \w Y|strong="H3068"\w* él tuvo temor, se \w levantó|strong="H6965"\w* y huyó para salvar su \w vida|strong="H5315"\w*. \w Llegó|strong="H3212"\w* \w a|strong="H3068"\w* Beerseba, que es de \w Judá|strong="H3063"\w*, y dejó \w allí|strong="H8033"\w* \w a|strong="H3068"\w* su esclavo.
\v 4 \w Él|strong="H1931"\w* salió \w solo|strong="H1931"\w* \w al|strong="H8478"\w* \w desierto|strong="H4057"\w* \w donde|strong="H8478"\w* \w anduvo|strong="H1980"\w* todo un \w día|strong="H3117"\w*. Llegó, \w se|strong="H1931"\w* sentó \w debajo|strong="H8478"\w* \w de|strong="H3588"\w* un enebro.\f + \fr 19:4 \ft Enebro: arbusto que crece en el desierto y da buena sombra.\f* Ansiaba \w morir|strong="H4191"\w* \w y|strong="H3588"\w* dijo: ¡\w Basta|strong="H7227"\w* \w ya|strong="H6258"\w*, oh \nd \w Yavé|strong="H3068"\w*\nd*! ¡Quítame \w ahora|strong="H6258"\w* \w la|strong="H1931"\w* \w vida|strong="H5315"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w soy|strong="H1931"\w* \w mejor|strong="H2896"\w* \w que|strong="H3588"\w* mis antepasados!
\v 5 Se recostó \w debajo|strong="H8478"\w* del enebro y se quedó dormido.
\p \w Y|strong="H3068"\w* \w ciertamente|strong="H2009"\w* un \w ángel|strong="H4397"\w* \w lo|strong="H2088"\w* \w tocó|strong="H5060"\w* y le dijo: ¡\w Levántate|strong="H6965"\w*, come!
\v 6 \w Miró|strong="H5027"\w* atentamente, y en verdad había \w a|strong="H3068"\w* su \w cabecera|strong="H4763"\w* una \w torta|strong="H5692"\w* cocida sobre las brasas y una vasija con \w agua|strong="H4325"\w*. Comió y \w bebió|strong="H8354"\w*, y \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* recostarse.
\p 
\v 7 \w El|strong="H3588"\w* \w Ángel|strong="H4397"\w* \w de|strong="H4480"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w llegó|strong="H5060"\w* \w por|strong="H3588"\w* \w segunda|strong="H8145"\w* vez, lo \w tocó|strong="H5060"\w* \w y|strong="H3588"\w* le dijo: \wj ¡\w Levántate|strong="H6965"\w* \w y|strong="H3588"\w* come, \w porque|strong="H3588"\w* largo \w camino|strong="H1870"\w* \w te|strong="H4480"\w* resta!\wj*
\v 8 \w Él|strong="H1931"\w* \w se|strong="H1931"\w* \w levantó|strong="H6965"\w*, comió \w y|strong="H5704"\w* \w bebió|strong="H8354"\w*. \w Con|strong="H5704"\w* \w la|strong="H1931"\w* \w fuerza|strong="H3581"\w* \w de|strong="H5704"\w* \w esa|strong="H1931"\w* comida \w anduvo|strong="H3212"\w* 40 \w días|strong="H3117"\w* \w y|strong="H5704"\w* 40 \w noches|strong="H3915"\w* \w hasta|strong="H5704"\w* \w Horeb|strong="H2722"\w*, \w la|strong="H1931"\w* Montaña \w de|strong="H5704"\w* \nd ʼElohim\nd*.
\v 9 \w Allí|strong="H8033"\w* entró en una \w cueva|strong="H4631"\w* \w donde|strong="H8033"\w* pasó la noche.
\p \w Y|strong="H3068"\w* en verdad \w vino|strong="H4100"\w* \w a|strong="H3068"\w* \w él|strong="H3885"\w* la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w que|strong="H4100"\w* preguntaba: \wj ¿\w Qué|strong="H4100"\w* haces \w aquí|strong="H6311"\w*, Elías?\wj*
\p 
\v 10 \w Y|strong="H3068"\w* \w él|strong="H3588"\w* respondió: Sentí un vivo \w celo|strong="H7065"\w* \w por|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* \w de|strong="H3588"\w* las huestes, \w porque|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* abandonaron tu \w Pacto|strong="H1285"\w*, derribaron tus \w altares|strong="H4196"\w* \w y|strong="H3588"\w* \w mataron|strong="H2026"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* tus \w profetas|strong="H5030"\w*. Quedé \w yo|strong="H3588"\w* solo \w y|strong="H3588"\w* \w me|strong="H3588"\w* \w buscan|strong="H1245"\w* \w para|strong="H3588"\w* \w quitarme|strong="H3947"\w* \w la|strong="H3588"\w* \w vida|strong="H5315"\w*.
\p 
\v 11 \w Y|strong="H3068"\w* \w Él|strong="H5674"\w* dijo: \wj \w Sal|strong="H3318"\w* afuera y \w ponte|strong="H5975"\w* \w en|strong="H3318"\w* \w pie|strong="H5975"\w* \w en|strong="H3318"\w* la Montaña, \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*.\nd* \wj*
\p \w Y|strong="H3068"\w* \w en|strong="H3318"\w* verdad \nd \w Yavé|strong="H3068"\w*\nd* \w pasaba|strong="H5674"\w*. Un \w grande|strong="H1419"\w* y poderoso \w viento|strong="H7307"\w* destrozaba las montañas y rompía las peñas \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*, pero \nd \w Yavé|strong="H3068"\w*\nd* \w no|strong="H3808"\w* \w estaba|strong="H5975"\w* \w en|strong="H3318"\w* \w el|strong="H5674"\w* \w viento|strong="H7307"\w*. Después del \w viento|strong="H7307"\w* \w hubo|strong="H2009"\w* un terremoto, pero \nd \w Yavé|strong="H3068"\w*\nd* \w no|strong="H3808"\w* \w estaba|strong="H5975"\w* \w en|strong="H3318"\w* \w el|strong="H5674"\w* terremoto.
\v 12 Después del terremoto hubo un fuego, pero \nd \w Yavé|strong="H3068"\w*\nd* \w no|strong="H3808"\w* estaba en el fuego. \w Y|strong="H3068"\w* después del fuego, un \w sonido|strong="H6963"\w* \w apacible|strong="H1827"\w* y delicado.
\p 
\v 13 \w Sucedió|strong="H1961"\w* \w que|strong="H4100"\w* al Elías oírlo, cubrió su \w rostro|strong="H6440"\w* con su manto. \w Salió|strong="H3318"\w* y \w estuvo|strong="H1961"\w* \w en|strong="H3318"\w* \w pie|strong="H5975"\w* \w en|strong="H3318"\w* la entrada \w de|strong="H6440"\w* la \w cueva|strong="H4631"\w*. \w Y|strong="H3068"\w* \w en|strong="H3318"\w* verdad, una \w voz|strong="H6963"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* él y le preguntó: \wj ¿\w Qué|strong="H4100"\w* haces \w aquí|strong="H6311"\w*, Elías?\wj*
\p 
\v 14 \w Y|strong="H3068"\w* \w él|strong="H3588"\w* respondió: Sentí un vivo \w celo|strong="H7065"\w* \w por|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w* ʼElohim\nd* \w de|strong="H3588"\w* las huestes, \w porque|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* abandonaron tu \w Pacto|strong="H1285"\w*, derribaron tus \w altares|strong="H4196"\w* \w y|strong="H3588"\w* \w mataron|strong="H2026"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* tus \w profetas|strong="H5030"\w*. Solo \w yo|strong="H3588"\w* quedé, \w y|strong="H3588"\w* \w me|strong="H3588"\w* \w buscan|strong="H1245"\w* \w para|strong="H3588"\w* \w quitarme|strong="H3947"\w* \w la|strong="H3588"\w* \w vida|strong="H5315"\w*.
\p 
\v 15 \nd \w Yavé|strong="H3068"\w*\nd* \w le|strong="H5921"\w* dijo: \wj \w Vé|strong="H3212"\w*, regresa \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w del|strong="H5921"\w* \w desierto|strong="H4057"\w* \w a|strong="H3068"\w* \w Damasco|strong="H1834"\w*. Cuando llegues, \w ungirás|strong="H4886"\w* \w a|strong="H3068"\w* \w Hazael|strong="H2371"\w* \w como|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Siria. \wj*
\v 16 \wj También \w ungirás|strong="H4886"\w* \w como|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* \w Jehú|strong="H3058"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Nimsi, \w y|strong="H5921"\w* \w ungirás|strong="H4886"\w* \w a|strong="H3068"\w* Eliseo, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Safat, \w de|strong="H5921"\w* Abel-mehola, \w como|strong="H5921"\w* \w profeta|strong="H5030"\w* \w en|strong="H5921"\w* tu \w lugar|strong="H8478"\w*. \wj*
\v 17 \wj \w Sucederá|strong="H1961"\w* \w que|strong="H1961"\w* el \w que|strong="H1961"\w* \w escape|strong="H4422"\w* de la \w espada|strong="H2719"\w* de \w Hazael|strong="H2371"\w*, lo \w matará|strong="H4191"\w* \w Jehú|strong="H3058"\w*, y el \w que|strong="H1961"\w* \w escape|strong="H4422"\w* de la \w espada|strong="H2719"\w* de \w Jehú|strong="H3058"\w*, lo \w matará|strong="H4191"\w* Eliseo. \wj*
\v 18 \wj Yo haré \w que|strong="H3808"\w* queden en \w Israel|strong="H3478"\w* 7.000. Sus \w rodillas|strong="H1290"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* doblaron ante \w baal|strong="H1168"\w* y sus \w bocas|strong="H6310"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* besaron. \wj*
\s1 Llamamiento al profeta Eliseo
\p 
\v 19 Al salir \w de|strong="H6440"\w* \w allí|strong="H8033"\w*, \w halló|strong="H4672"\w* \w a|strong="H3068"\w* Eliseo, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Safat, \w que|strong="H1931"\w* araba con 12 \w yuntas|strong="H6776"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H1931"\w*, y \w él|strong="H1931"\w* \w tenía|strong="H1931"\w* \w la|strong="H1931"\w* duodécima. Al \w pasar|strong="H5674"\w* Elías \w hacia|strong="H6440"\w* \w él|strong="H1931"\w*, \w echó|strong="H7993"\w* \w su|strong="H1931"\w* manto \w sobre|strong="H5674"\w* \w él|strong="H1931"\w*.
\p 
\v 20 \w Entonces|strong="H3588"\w* \w él|strong="H3588"\w* \w dejó|strong="H5800"\w* \w los|strong="H3588"\w* \w bueyes|strong="H1241"\w*, \w fue|strong="H3212"\w* \w corriendo|strong="H7323"\w* tras Elías \w y|strong="H3588"\w* dijo: Besaré \w ahora|strong="H4994"\w* \w a|strong="H3068"\w* \w mi|strong="H4994"\w* padre \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w mi|strong="H4994"\w* madre, \w y|strong="H3588"\w* \w luego|strong="H4994"\w* \w te|strong="H3588"\w* seguiré. \w Él|strong="H3588"\w* le dijo: \w Vé|strong="H3212"\w*, regresa. \w Pues|strong="H3588"\w*, ¿\w qué|strong="H3588"\w* \w te|strong="H3588"\w* \w hice|strong="H6213"\w* \w yo|strong="H3588"\w*?
\p 
\v 21 \w Dejó|strong="H5414"\w* \w de|strong="H5971"\w* \w ir|strong="H3212"\w* tras \w él|strong="H1310"\w*. \w Luego|strong="H7725"\w* \w tomó|strong="H3947"\w* la yunta \w de|strong="H5971"\w* \w bueyes|strong="H1241"\w* \w y|strong="H1241"\w* los \w mató|strong="H2076"\w*. Con \w el|strong="H1310"\w* arado \w de|strong="H5971"\w* los \w bueyes|strong="H1241"\w* cocinó su \w carne|strong="H1320"\w* \w y|strong="H1241"\w* la \w dio|strong="H5414"\w* \w a|strong="H3068"\w* la \w gente|strong="H5971"\w* \w para|strong="H5414"\w* \w que|strong="H5971"\w* comiera. Después \w se|strong="H5971"\w* \w levantó|strong="H6965"\w*, \w fue|strong="H3212"\w* tras Elías \w y|strong="H1241"\w* le \w servía|strong="H8334"\w*.
\c 20
\s1 El rey Acab y la invasión de los sirios
\p 
\v 1 Ben-hadad, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Siria, reunió \w todo|strong="H3605"\w* su \w ejército|strong="H2426"\w*, \w y|strong="H5921"\w* acompañado \w por|strong="H5921"\w* 32 \w reyes|strong="H4428"\w* \w que|strong="H5921"\w* dependían \w de|strong="H5921"\w* \w él|strong="H5921"\w*, marchó \w contra|strong="H5921"\w* \w Samaria|strong="H8111"\w* \w con|strong="H5921"\w* caballería \w y|strong="H5921"\w* carruajes. \w La|strong="H5921"\w* sitió \w y|strong="H5921"\w* \w la|strong="H5921"\w* atacó.
\v 2 \w Envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w*, \w a|strong="H3068"\w* Acab, \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w*, para decirle:
\v 3 \w Así|strong="H3541"\w* dijo Ben-hadad: Tu \w plata|strong="H3701"\w* \w y|strong="H3541"\w* \w oro|strong="H2091"\w* son \w míos|strong="H1992"\w*. Tus mujeres \w y|strong="H3541"\w* \w los|strong="H1992"\w* \w mejores|strong="H2896"\w* \w de|strong="H1121"\w* tus \w hijos|strong="H1121"\w* son \w míos|strong="H1992"\w*.
\p 
\v 4 \w Y|strong="H3068"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Israel|strong="H3478"\w* \w respondió|strong="H6030"\w*: Como tú \w dices|strong="H1697"\w*, oh \w mi|strong="H6030"\w* \tl ʼadón\tl* \w el|strong="H3605"\w* \w rey|strong="H4428"\w*, yo soy tuyo con \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* tengo.
\p 
\v 5 \w Los|strong="H1121"\w* \w mensajeros|strong="H4397"\w* \w volvieron|strong="H7725"\w* otra vez \w y|strong="H3588"\w* dijeron: Ben-hadad habló \w esto|strong="H3541"\w*: \w Por|strong="H3588"\w* \w cierto|strong="H3588"\w*, \w envié|strong="H7971"\w* \w a|strong="H3068"\w* decirte: Tu \w plata|strong="H3701"\w* \w y|strong="H3588"\w* tu \w oro|strong="H2091"\w*, también tus mujeres \w y|strong="H3588"\w* tus \w hijos|strong="H1121"\w* \w me|strong="H3588"\w* \w los|strong="H1121"\w* \w darás|strong="H5414"\w*.
\v 6 \w Además|strong="H3588"\w*, \w mañana|strong="H4279"\w* \w a|strong="H3068"\w* \w esta|strong="H1961"\w* \w hora|strong="H6256"\w* \w te|strong="H5869"\w* \w enviaré|strong="H7971"\w* mis esclavos, \w los|strong="H3605"\w* cuales registrarán tu \w casa|strong="H1004"\w* \w y|strong="H3588"\w* las \w casas|strong="H1004"\w* \w de|strong="H3588"\w* tus esclavos. \w Tomarán|strong="H3947"\w* \w y|strong="H3588"\w* \w se|strong="H1961"\w* llevarán \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* agradable \w a|strong="H3068"\w* tus \w ojos|strong="H5869"\w*.
\p 
\v 7 \w El|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w ancianos|strong="H2205"\w* \w del|strong="H4480"\w* país \w y|strong="H3588"\w* les dijo: \w Reconozcan|strong="H3045"\w* \w ahora|strong="H4994"\w* \w y|strong="H3588"\w* \w vean|strong="H7200"\w* \w cómo|strong="H3588"\w* \w éste|strong="H2088"\w* \w no|strong="H3808"\w* \w busca|strong="H1245"\w* \w sino|strong="H3588"\w* hacer daño, \w porque|strong="H3588"\w* exige mis mujeres \w e|strong="H3068"\w* \w hijos|strong="H1121"\w*, \w y|strong="H3588"\w* \w mi|strong="H4994"\w* \w plata|strong="H3701"\w* \w y|strong="H3588"\w* \w oro|strong="H2091"\w*, \w aunque|strong="H3588"\w* \w yo|strong="H4480"\w* \w no|strong="H3808"\w* \w se|strong="H3045"\w* \w los|strong="H1121"\w* negué.
\p 
\v 8 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* respondieron: \w No|strong="H3808"\w* \w lo|strong="H3808"\w* escuches \w ni|strong="H3808"\w* accedas.
\p 
\v 9 \w Entonces|strong="H7725"\w* \w él|strong="H3605"\w* \w respondió|strong="H7725"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w mensajeros|strong="H4397"\w* \w de|strong="H1697"\w* Ben-hadad: Digan \w a|strong="H3068"\w* mi \tl ʼadón\tl* \w el|strong="H3605"\w* \w rey|strong="H4428"\w*: \w Haré|strong="H6213"\w* \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H3808"\w* \w mandaste|strong="H7971"\w* \w a|strong="H3068"\w* \w tu|strong="H6213"\w* esclavo \w al|strong="H4428"\w* principio, pero \w esto|strong="H2088"\w* \w no|strong="H3808"\w* \w lo|strong="H1697"\w* \w puedo|strong="H3201"\w* \w hacer|strong="H6213"\w*. \w Los|strong="H3605"\w* \w mensajeros|strong="H4397"\w* \w fueron|strong="H3212"\w* y le dieron \w la|strong="H3605"\w* \w respuesta|strong="H1697"\w*.
\p 
\v 10 \w Y|strong="H3068"\w* Ben-hadad \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decirle: ¡\w Así|strong="H3541"\w* \w me|strong="H3541"\w* \w hagan|strong="H6213"\w* \w los|strong="H3605"\w* \tl ʼelohim\tl* \w y|strong="H3541"\w* \w aun|strong="H3254"\w* \w me|strong="H3541"\w* \w añadan|strong="H3254"\w*, \w que|strong="H5971"\w* \w el|strong="H3605"\w* \w polvo|strong="H6083"\w* \w de|strong="H5971"\w* \w Samaria|strong="H8111"\w* \w no|strong="H6213"\w* bastará \w para|strong="H5971"\w* llenar las manos \w de|strong="H5971"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w me|strong="H3541"\w* sigue!
\p 
\v 11 Pero el \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w* \w respondió|strong="H6030"\w*: Díganle: No se jacte tanto el que se ata las armas como el que se las desata.
\p 
\v 12 \w Sucedió|strong="H1961"\w* \w que|strong="H1931"\w* \w él|strong="H1931"\w* \w oyó|strong="H8085"\w* \w estas|strong="H2088"\w* \w palabras|strong="H1697"\w* mientras bebía \w con|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w en|strong="H5921"\w* \w el|strong="H1931"\w* puesto \w de|strong="H5921"\w* comando, \w y|strong="H5921"\w* dijo \w a|strong="H3068"\w* \w sus|strong="H1931"\w* esclavos: ¡Alístense! \w Y|strong="H3068"\w* \w ellos|strong="H1931"\w* \w se|strong="H1961"\w* alistaron \w para|strong="H5921"\w* atacar \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w*.
\p 
\v 13 \w Ciertamente|strong="H3588"\w* un \w profeta|strong="H5030"\w* \w se|strong="H3045"\w* \w acercó|strong="H5066"\w* \w a|strong="H3068"\w* Acab, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w y|strong="H3588"\w* le dijo: \nd \w Yavé|strong="H3068"\w*\nd* dice: \wj ¿\w Ves|strong="H7200"\w* \w todo|strong="H3605"\w* \w ese|strong="H2088"\w* inmenso \w ejército|strong="H1995"\w*? \w Mira|strong="H7200"\w*, \w Yo|strong="H3588"\w* \w lo|strong="H2088"\w* \w entrego|strong="H5414"\w* \w hoy|strong="H3117"\w* \w en|strong="H3588"\w* tu \w mano|strong="H3027"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* reconozcas \w que|strong="H3588"\w* \w Yo|strong="H3588"\w* soy \nd \w Yavé|strong="H3068"\w*\nd*.\wj*
\p 
\v 14 Acab preguntó: ¿Por medio \w de|strong="H8269"\w* \w quién|strong="H4310"\w*?
\p \w Y|strong="H3068"\w* \w él|strong="H4310"\w* dijo: \nd \w Yavé|strong="H3068"\w*\nd* dice: \wj Por medio \w de|strong="H8269"\w* los esclavos \w de|strong="H8269"\w* los \w jefes|strong="H8269"\w* \w de|strong="H8269"\w* las \w provincias|strong="H4082"\w*.\wj* \w Y|strong="H3068"\w* Acab preguntó: ¿\w Quién|strong="H4310"\w* comenzará la \w batalla|strong="H4421"\w*? \w Y|strong="H3068"\w* \w él|strong="H4310"\w* respondió: Tú.
\p 
\v 15 Entonces pasó revista \w a|strong="H3068"\w* \w los|strong="H1121"\w* esclavos \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w jefes|strong="H8269"\w* \w de|strong="H1121"\w* las \w provincias|strong="H4082"\w*, y \w eran|strong="H1961"\w* 232. \w Después|strong="H1961"\w* \w de|strong="H1121"\w* \w ellos|strong="H3605"\w* pasó revista \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, y \w eran|strong="H1961"\w* 7.000.
\v 16 \w Éstos|strong="H1931"\w* \w salieron|strong="H3318"\w* \w al|strong="H4428"\w* mediodía, mientras Ben-hadad estaba \w bebiendo|strong="H8354"\w* \w hasta|strong="H1931"\w* embriagarse \w en|strong="H3318"\w* las \w cabañas|strong="H5521"\w* con \w los|strong="H1931"\w* \w reyes|strong="H4428"\w*, \w los|strong="H1931"\w* 32 \w reyes|strong="H4428"\w* \w que|strong="H1931"\w* fueron \w a|strong="H3068"\w* ayudarlo.
\p 
\v 17 Los esclavos \w de|strong="H8269"\w* los \w jefes|strong="H8269"\w* \w de|strong="H8269"\w* las \w provincias|strong="H4082"\w* \w salieron|strong="H3318"\w* \w primero|strong="H7223"\w*. Ben-hadad \w envió|strong="H7971"\w* \w a|strong="H3068"\w* algunos, quienes le informaron y dijeron: Unos hombres \w salieron|strong="H3318"\w* \w de|strong="H8269"\w* \w Samaria|strong="H8111"\w*.
\p 
\v 18 \w Y|strong="H3068"\w* él ordenó: Si \w salieron|strong="H3318"\w* \w en|strong="H3318"\w* son de \w paz|strong="H7965"\w*, agárrenlos \w vivos|strong="H2416"\w*, y si \w salieron|strong="H3318"\w* \w a|strong="H3068"\w* \w combatir|strong="H4421"\w*, \w también|strong="H3318"\w* agárrenlos \w vivos|strong="H2416"\w*.
