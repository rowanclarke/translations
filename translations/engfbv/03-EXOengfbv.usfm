\v 33 \w If|strong="H3588"\w* \w someone|strong="H5307"\w* removes \w the|strong="H3588"\w* \w cover|strong="H3680"\w* \w of|strong="H5307"\w* \w a|strong="H3068"\w* cistern \w or|strong="H3808"\w* \w digs|strong="H3738"\w* \w one|strong="H3808"\w* \w and|strong="H8033"\w* doesn't \w cover|strong="H3680"\w* \w it|strong="H3588"\w*, \w and|strong="H8033"\w* \w an|strong="H8033"\w* \w ox|strong="H7794"\w* \w or|strong="H3808"\w* \w a|strong="H3068"\w* \w donkey|strong="H2543"\w* \w falls|strong="H5307"\w* \w into|strong="H5307"\w* \w it|strong="H3588"\w*,
