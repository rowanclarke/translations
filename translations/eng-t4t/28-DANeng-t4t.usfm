\v 44 \w But|strong="H7227"\w* \w he|strong="H3318"\w* \w will|strong="H7227"\w* \w become|strong="H3318"\w* \w very|strong="H1419"\w* frightened/alarmed \w when|strong="H3318"\w* \w he|strong="H3318"\w* hears reports \w about|strong="H3318"\w* \w what|strong="H8052"\w* \w is|strong="H2534"\w* happening \w in|strong="H7227"\w* \w the|strong="H3318"\w* \w east|strong="H4217"\w* \w and|strong="H1419"\w* \w in|strong="H7227"\w* \w the|strong="H3318"\w* \w north|strong="H6828"\w*. \w So|strong="H3318"\w* \w he|strong="H3318"\w* \w will|strong="H7227"\w* \w become|strong="H3318"\w* \w very|strong="H1419"\w* \w angry|strong="H2534"\w*, \w and|strong="H1419"\w* \w send|strong="H3318"\w* \w his|strong="H3318"\w* army \w to|strong="H3318"\w* fight \w furiously|strong="H2534"\w* \w and|strong="H1419"\w* kill \w many|strong="H7227"\w* \add of their enemies\add*.  
\v 45 \w The|strong="H5704"\w* \add King of Syria\add* \w will|strong="H2022"\w* \w set|strong="H6944"\w* \w up|strong="H5704"\w* \w his|strong="H5704"\w* \w royal|strong="H6944"\w* tents \w in|strong="H3220"\w* \w the|strong="H5704"\w* \w area|strong="H2022"\w* \w between|strong="H5704"\w* \w the|strong="H5704"\w* \add Mediterranean\add* \w Sea|strong="H3220"\w* \w and|strong="H2022"\w* \w the|strong="H5704"\w* \w hill|strong="H2022"\w* \add in Jerusalem\add* \w on|strong="H3220"\w* \w which|strong="H2022"\w* \w the|strong="H5704"\w* temple ◄exists/\w was|strong="H2022"\w* built►. \w But|strong="H5826"\w* \w he|strong="H5704"\w* \w will|strong="H2022"\w* \w be|strong="H2022"\w* killed \w there|strong="H2022"\w*, because \w there|strong="H2022"\w* \w will|strong="H2022"\w* \w be|strong="H2022"\w* no one \w to|strong="H5704"\w* \w help|strong="H5826"\w* \w him|strong="H5826"\w*.”   
\c 12  
\s1 When this world will end  
\p
\v 1  \add The angel also said to me,\add* “\w After|strong="H5921"\w* \w those|strong="H3605"\w* \w things|strong="H1419"\w* \w happen|strong="H1961"\w*, \w the|strong="H3605"\w* \w great|strong="H1419"\w* angel \w Michael|strong="H4317"\w*, \w who|strong="H3605"\w* protects \w the|strong="H3605"\w* \add Israeli\add* \w people|strong="H5971"\w*, \w will|strong="H1961"\w* appear. \w Then|strong="H1961"\w* \w there|strong="H1961"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w a|strong="H3068"\w* \w time|strong="H6256"\w* \w when|strong="H1961"\w* \w there|strong="H1961"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w great|strong="H1419"\w* \w troubles|strong="H6869"\w*/suffering. \w The|strong="H3605"\w* \w troubles|strong="H6869"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w greater|strong="H1419"\w* \w than|strong="H3808"\w* \w any|strong="H3605"\w* \w troubles|strong="H6869"\w*/suffering \w since|strong="H5704"\w* \w the|strong="H3605"\w* \w nations|strong="H1471"\w* \w began|strong="H1961"\w*. \w At|strong="H5921"\w* \w that|strong="H5971"\w* \w time|strong="H6256"\w*, \w all|strong="H3605"\w* \w of|strong="H1121"\w* \w your|strong="H3605"\w* \w people|strong="H5971"\w* \w whose|strong="H1471"\w* names \w have|strong="H1961"\w* \w been|strong="H1961"\w* \w written|strong="H3789"\w* \w in|strong="H5921"\w* \w the|strong="H3605"\w* \w book|strong="H5612"\w* \add containing the names of those who have eternal life\add* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w saved|strong="H4422"\w*.  
\v 2 \w Many|strong="H7227"\w* \w of|strong="H2781"\w* those \w who|strong="H7227"\w* have died [EUP] \w will|strong="H7227"\w* become \w alive|strong="H2416"\w* again. \w Some|strong="H7227"\w* \w of|strong="H2781"\w* them \w will|strong="H7227"\w* \w live|strong="H2416"\w* eternally \add with God\add*, \w and|strong="H5769"\w* \w some|strong="H7227"\w* \w will|strong="H7227"\w* \w be|strong="H5769"\w* eternally shamed/disgraced \add in hell\add*.  
\v 3 Those \w who|strong="H7227"\w* \w were|strong="H7227"\w* \w wise|strong="H7919"\w* \w will|strong="H7227"\w* \w shine|strong="H2094"\w* \w as|strong="H7919"\w* \w brightly|strong="H2094"\w* \w as|strong="H7919"\w* \w the|strong="H6663"\w* sky \add is bright when the sun is shining\add*. \w And|strong="H5769"\w* those \w who|strong="H7227"\w* \w have|strong="H7919"\w* shown \w to|strong="H5769"\w* \w others|strong="H7227"\w* \w the|strong="H6663"\w* way \w to|strong="H5769"\w* live righteously \w will|strong="H7227"\w* \w shine|strong="H2094"\w* \w forever|strong="H5769"\w*, \w like|strong="H7227"\w* \w the|strong="H6663"\w* \w stars|strong="H3556"\w* [SIM].  
\v 4 \w But|strong="H7227"\w* \w as|strong="H5704"\w* \w for|strong="H5704"\w* \w you|strong="H5704"\w*, \w Daniel|strong="H1840"\w*, \w close|strong="H5640"\w* \w up|strong="H2856"\w* \w the|strong="H5704"\w* \w scroll|strong="H5612"\w* \add on which you are writing\add*, \w and|strong="H1697"\w* \w seal|strong="H2856"\w* \w it|strong="H5704"\w* \add in order that no one can open it\add* \w until|strong="H5704"\w* \w the|strong="H5704"\w* \w end|strong="H7093"\w* \add of the world\add* \w is|strong="H1697"\w* \w near|strong="H5704"\w*. \add Before that happens,\add* \w many|strong="H7227"\w* people \w will|strong="H1697"\w* travel rapidly \w here|strong="H5704"\w* \w and|strong="H1697"\w* \w there|strong="H1697"\w*, \w learning|strong="H5612"\w* \w more|strong="H7235"\w* \w and|strong="H1697"\w* \w more|strong="H7235"\w* \add about many things\add*.”   
\p
\v 5 \w When|strong="H7200"\w* \add that angel finished speaking\add*, \w I|strong="H2009"\w*, \w Daniel|strong="H1840"\w*, \w looked|strong="H7200"\w* \w up|strong="H5975"\w*, \w and|strong="H7200"\w* \w suddenly|strong="H2009"\w* \w I|strong="H2009"\w* \w saw|strong="H7200"\w* \w two|strong="H8147"\w* \w other|strong="H8147"\w* \add angels\add*. \w One|strong="H7200"\w* \w was|strong="H8193"\w* \w standing|strong="H5975"\w* \w on|strong="H7200"\w* \w the|strong="H7200"\w* \w side|strong="H8147"\w* \w of|strong="H8147"\w* \w the|strong="H7200"\w* \w river|strong="H2975"\w* \add where I was\add*, \w and|strong="H7200"\w* \w one|strong="H7200"\w* \w was|strong="H8193"\w* \w standing|strong="H5975"\w* \w on|strong="H7200"\w* \w the|strong="H7200"\w* \w other|strong="H8147"\w* \w side|strong="H8147"\w*.  
\v 6 One \w of|strong="H4325"\w* \w them|strong="H3847"\w* \add called to\add* \w the|strong="H5704"\w* other one, \w who|strong="H4605"\w* \w was|strong="H4325"\w* wearing linen/white \w clothes|strong="H3847"\w*, \w who|strong="H4605"\w* \w was|strong="H4325"\w* \w now|strong="H3847"\w* standing further \w up|strong="H5704"\w* (\w OR|strong="H3068"\w*, \w above|strong="H4605"\w*) \w the|strong="H5704"\w* \w river|strong="H2975"\w*, “\w How|strong="H4970"\w* \w long|strong="H5704"\w* \w will|strong="H4325"\w* \w it|strong="H5704"\w* \w be|strong="H4325"\w* \w until|strong="H5704"\w* \w these|strong="H4605"\w* \w amazing|strong="H6382"\w*/frightening events \w end|strong="H7093"\w*?”   
\p
\v 7 \w The|strong="H3605"\w* angel \w who|strong="H3605"\w* \w was|strong="H4325"\w* \w on|strong="H3847"\w* \w the|strong="H3605"\w* \w other|strong="H3605"\w* \w side|strong="H3225"\w* \w of|strong="H3027"\w* (\w OR|strong="H3068"\w*, \w above|strong="H4605"\w*) \w the|strong="H3605"\w* \w river|strong="H2975"\w* \w raised|strong="H7311"\w* \w his|strong="H3605"\w* \w hands|strong="H3027"\w* \w toward|strong="H3027"\w* \w the|strong="H3605"\w* \w sky|strong="H8064"\w*, \w and|strong="H8064"\w* \w solemnly|strong="H7650"\w* \w promised|strong="H7650"\w*, \w with|strong="H3847"\w* \w the|strong="H3605"\w* \w authority|strong="H3027"\w* [MTY] \w of|strong="H3027"\w* \w God|strong="H3027"\w*, \w who|strong="H3605"\w* \w lives|strong="H2416"\w* \w forever|strong="H5769"\w*, “\w It|strong="H3588"\w* \w will|strong="H5971"\w* \w be|strong="H3027"\w* three \w and|strong="H8064"\w* \w a|strong="H3068"\w* \w half|strong="H2677"\w* years. \w All|strong="H3605"\w* \w these|strong="H8085"\w* \w things|strong="H6944"\w* \w will|strong="H5971"\w* \w end|strong="H3615"\w* \w after|strong="H3588"\w* \w God|strong="H3027"\w*’s \w people|strong="H5971"\w* \w stop|strong="H7311"\w* fighting \w against|strong="H3027"\w* \w those|strong="H3605"\w* \w who|strong="H3605"\w* ◄persecute/\w cause|strong="H5971"\w* trouble \w for|strong="H3588"\w*/\w cause|strong="H5971"\w* suffering \w for|strong="H3588"\w*► \w them|strong="H3027"\w*.”   
\p
\v 8 \w I|strong="H8085"\w* \w heard|strong="H8085"\w* \add what he said\add*, \w but|strong="H3808"\w* \w I|strong="H8085"\w* \w did|strong="H4100"\w* \w not|strong="H3808"\w* \w understand|strong="H8085"\w* \w it|strong="H3808"\w*. \w So|strong="H3808"\w* \w I|strong="H8085"\w* \w asked|strong="H4100"\w*, “Sir, \w what|strong="H4100"\w* \w will|strong="H3808"\w* \w be|strong="H3808"\w* \w the|strong="H8085"\w* result \w when|strong="H8085"\w* \w these|strong="H8085"\w* \w things|strong="H3808"\w* \w end|strong="H4100"\w*?”   
\p
\v 9 \w He|strong="H3588"\w* replied, “\w Daniel|strong="H1840"\w*, \w you|strong="H3588"\w* must leave \w now|strong="H3588"\w*. \add I cannot answer your question\add* \w because|strong="H3588"\w* \w what|strong="H1697"\w* \w it|strong="H3588"\w* means must ◄\w be|strong="H1697"\w* kept \w secret|strong="H5640"\w*/\w not|strong="H3588"\w* \w be|strong="H1697"\w* revealed► [DOU] \w until|strong="H5704"\w* \w the|strong="H3588"\w* \w time|strong="H6256"\w* \w when|strong="H3588"\w* everything \w ends|strong="H5704"\w*.  
\v 10 \w Many|strong="H7227"\w* \w people|strong="H3808"\w* \w will|strong="H7563"\w* thoroughly \w purify|strong="H1305"\w* \w their|strong="H3605"\w* inner beings [DOU]. \w But|strong="H3808"\w* \w wicked|strong="H7563"\w* \w people|strong="H3808"\w* \w will|strong="H7563"\w* \w not|strong="H3808"\w* \w understand|strong="H7919"\w* \w these|strong="H3605"\w* \w things|strong="H3605"\w*. \w They|strong="H3808"\w* \w will|strong="H7563"\w* continue \w to|strong="H3808"\w* \w be|strong="H3808"\w* \w wicked|strong="H7563"\w*. \w Only|strong="H3605"\w* \w those|strong="H3605"\w* \w who|strong="H3605"\w* \w are|strong="H7563"\w* \w wise|strong="H7919"\w* \w will|strong="H7563"\w* \w understand|strong="H7919"\w* \add these things\add*.  
\v 11  \add But I can tell you that before everything ends,\add* \w there|strong="H3117"\w* \w will|strong="H5414"\w* \w be|strong="H3117"\w* 1,290 \w days|strong="H3117"\w*, \w from|strong="H5493"\w* \w the|strong="H5414"\w* \w time|strong="H6256"\w* \w that|strong="H3117"\w* people \w are|strong="H3117"\w* \w prevented|strong="H5493"\w* \w from|strong="H5493"\w* offering sacrifices \w each|strong="H3117"\w* \w day|strong="H3117"\w*, \w that|strong="H3117"\w* \w is|strong="H3117"\w*, \w from|strong="H5493"\w* \w the|strong="H5414"\w* \w time|strong="H6256"\w* \w that|strong="H3117"\w* \w the|strong="H5414"\w* \w abominable|strong="H8251"\w*/disgusting thing \w is|strong="H3117"\w* \w put|strong="H5414"\w* \w in|strong="H3117"\w* \w the|strong="H5414"\w* temple.  
\v 12 God \w will|strong="H3117"\w* \w be|strong="H3117"\w* pleased \w with|strong="H3117"\w* those who remain faithful \w until|strong="H3117"\w* 1,335 \w days|strong="H3117"\w* \w are|strong="H3117"\w* ended.   
\p
\v 13 \w So|strong="H5975"\w* \add now I say\add* \w to|strong="H3212"\w* \w you|strong="H3117"\w*, \w continue|strong="H5975"\w* \w to|strong="H3212"\w* faithfully \add trust God\add* \w until|strong="H3117"\w* \add your life on earth\add* ends. \w You|strong="H3117"\w* \w will|strong="H3117"\w* die [EUP], \w but|strong="H3117"\w* \w when|strong="H3117"\w* everything ends, \w you|strong="H3117"\w* \w will|strong="H3117"\w* receive \w your|strong="H5117"\w* reward \add from God\add*.”   