\id PRO
\h Priče Solomunove
\toc1 Priče Solomunove
\toc2 Priče Solomunove
\toc3 Pri
\mt1 Priče Solomunove
\c 1
\s1 Da se pozna mudrost! Treba se čuvati mamca grešnika. Kazna za neposlušnost.
\p 
\v 1 Priče Solomuna sina Davidovog, cara Izrailjevog.
\b
\q1 
\v 2 Da se poznaje mudrost i nastava,
\q2 da se razumeju reči razumne,
\q1 
\v 3 Da se prima nastava
\q2 u razumu, u pravdi, u sudu i u svemu što je pravo,
\q1 
\v 4 Da se daje ludima razboritost,
\q2 mladićima znanje i pomnjivost.
\q1 
\v 5 Mudar će slušati i više će znati,
\q2 i razuman će steći mudrost,
\q1 
\v 6 Da razume priče i značenje,
\q2 reči mudrih ljudi i zagonetke njihove.
\b
\q1 
\v 7 Početak je mudrosti strah Gospodnji;
\q2 ludi preziru mudrost i nastavu.
\b
\q1 
\v 8 Slušaj, sine, nastavu oca svog,
\q2 i ne ostavljaj nauke matere svoje.
\q1 
\v 9 Jer će biti venac od milina oko glave tvoje,
\q2 i grivna na grlu tvom.
\q1 
\v 10 Sine moj, ako bi te mamili grešnici, ne pristaj;
\q1 
\v 11 Ako bi rekli: Hodi s nama
\q2 da vrebamo krv,
\q2 da zasedamo pravome nizašta;
\q1 
\v 12 Proždrećemo ih kao grob žive,
\q2 i svekolike kao one koji silaze u jamu;
\q1 
\v 13 Svakojakog blaga dobićemo,
\q2 napunićemo kuće svoje plena;
\q1 
\v 14 Bacaćeš žreb svoj s nama;
\q2 jedan će nam tobolac biti svima;
\q1 
\v 15 Sine moj, ne idi na put s njima,
\q2 čuvaj nogu svoju od staze njihove.
\q1 
\v 16 Jer nogama svojim trče na zlo
\q2 i hite da prolivaju krv.
\q1 
\v 17 Jer se uzalud razapinje mreža na oči svakoj ptici;
\q1 
\v 18 A oni vrebaju svoju krv
\q2 i zasedaju svojoj duši.
\q1 
\v 19 Takvi su putevi svih lakomih na dobitak,
\q2 koji uzima dušu svojim gospodarima.
\b
\q1 
\v 20 Premudrost viče na polju,
\q2 na ulicama pušta glas svoj;
\q1 
\v 21 U najvećoj vrevi viče,
\q2 na vratima, u gradu govori svoje besede;
\q1 
\v 22 Ludi, dokle ćete ljubiti ludost?
\q2 I podsmevačima dokle će biti mio podsmeh?
\q2 I bezumni, dokle će mrzeti na znanje?
\q1 
\v 23 Obratite se na karanje moje;
\q2 evo, izasuću vam duh svoj,
\q2 kazaću vam reči svoje.
\q1 
\v 24 Što zvah, ali ne hteste,
\q2 pružah ruku svoju, ali niko ne mari,
\q1 
\v 25 Nego odbaciste svaki savet moj,
\q2 i karanje moje ne hteste primiti;
\q1 
\v 26 Zato ću se i ja smejati vašoj nevolji,
\q2 rugaću se kad dođe čega se bojite;
\q1 
\v 27 Kad kao pustoš dođe čega se bojite,
\q2 i pogibao vaša kao oluja kad dođe,
\q2 kad navali na vas nevolja i muka.
\q1 
\v 28 Tada će me zvati, ali se neću odazvati;
\q2 rano će tražiti, ali me neće naći.
\q1 
\v 29 Jer mrziše na znanje,
\q2 i strah Gospodnji ne izabraše;
\q1 
\v 30 Ne pristaše na moj savet,
\q2 i preziraše sva karanja moja.
\q1 
\v 31 Zato će jesti plod od puteva svojih,
\q2 i nasitiće se saveta svojih.
\q1 
\v 32 Jer će lude ubiti mir njihov,
\q2 i bezumne će pogubiti sreća njihova.
\q1 
\v 33 Ali ko me sluša boraviće bezbrižno,
\q2 i biće na miru ne bojeći se zla.
\c 2
\s1 Opomena da ozbiljno tražimo mudrost da bismo se sačuvali od iskušenja.
\q1 
\v 1 Sine moj, ako primiš reči moje,
\q2 i zapovesti moje sahraniš kod sebe,
\q1 
\v 2 Da pazi uho tvoje na mudrost,
\q2 i prigneš srce svoje k razumu,
\q1 
\v 3 Ako prizoveš mudrost,
\q2 i k razumu podigneš glas svoj,
\q1 
\v 4 Ako ga ustražiš kao srebro,
\q2 i kao sakriveno blago ako dobro ustražiš;
\q1 
\v 5 Tada ćeš razumeti strah Gospodnji,
\q2 i poznanje Božije naći ćeš.
\q1 
\v 6 Jer Gospod daje mudrost,
\q2 iz Njegovih usta dolazi znanje i razum.
\q1 
\v 7 Čuva pravima šta doista jeste,
\q2 štit je onima koji hode u bezazlenosti,
\q1 
\v 8 Da bi se držali staza pravih,
\q2 a On čuva put svetaca svojih.
\q1 
\v 9 Tada ćeš razumeti
\q2 pravdu i sud i šta je pravo, i svaki dobri put.
\q1 
\v 10 Kad dođe mudrost u srce tvoje,
\q2 i znanje omili duši tvojoj,
\q1 
\v 11 Pomnjivost će paziti na te,
\q2 razum će te čuvati,
\q1 
\v 12 Izbavljajući te od zla puta,
\q2 od ljudi koji govore opake stvari,
\q1 
\v 13 Koji ostavljaju prave pute
\q2 da idu putevima mračnim,
\q1 
\v 14 Koji se raduju zlo čineći,
\q2 i igraju u zlim opačinama;
\q1 
\v 15 Kojih su putevi krivi,
\q2 i sami su opaki na stazama svojim;
\b
\q1 
\v 16 Izbavljajući te od žene tuđe,
\q2 od tuđinke, koja laska svojim rečima,
\q1 
\v 17 Koja ostavlja vođu mladosti svoje,
\q2 i zaboravlja zavet Boga svog.
\q1 
\v 18 Jer k smrti vodi dom njen,
\q2 i k mrtvima staze njene.
\q1 
\v 19 Ko god uđe k njoj ne vraća se,
\q2 niti izlazi na put životni.
\b
\q1 
\v 20 Zato hodi putem dobrih,
\q2 i drži se staza pravedničkih.
\q1 
\v 21 Jer će pravednici nastavati na zemlji,
\q2 i bezazleni će ostati na njoj.
\q1 
\v 22 A bezbožni će se istrebiti sa zemlje,
\q2 i bezakonici će se iščupati iz nje.
\c 3
\s1 Blagosloven je strah Gospodnji i mudrost.
\q1 
\v 1 Sine moj, ne zaboravljaj nauke moje,
\q2 i zapovesti moje neka hrane srce tvoje.
\q1 
\v 2 Jer će ti doneti dug život,
\q2 dobre godine i mir.
\b
\q1 
\v 3 Milost i istina neka te ne ostavlja;
\q2 priveži ih sebi na grlo,
\q2 upiši ih na ploči srca svog.
\q1 
\v 4 Te ćeš naći milost i dobru misao
\q2 pred Bogom i pred ljudima.
\b
\q1 
\v 5 Uzdaj se u Gospoda svim srcem svojim,
\q2 a na svoj razum ne oslanjaj se.
\q1 
\v 6 Na svim putevima svojim imaj Ga na umu,
\q2 i On će upravljati staze tvoje.
\q1 
\v 7 Ne misli sam o sebi da si mudar;
\q2 boj se Gospoda i uklanjaj se oda zla.
\q1 
\v 8 To će biti zdravlje pupku tvom
\q2 i zalivanje kostima tvojim.
\b
\q1 
\v 9 Poštuj Gospoda imanjem svojim
\q2 i prvinama od svega dohotka svog;
\q1 
\v 10 I biće pune žitnice tvoje obilja,
\q2 i presipaće se vino iz kaca tvojih.
\b
\q1 
\v 11 Sine moj, ne odbacuj nastave Gospodnje,
\q2 i nemoj da ti dosadi karanje Njegovo.
\q1 
\v 12 Jer koga ljubi Gospod onog kara,
\q2 i kao otac sina koji mu je mio.
\b
\q1 
\v 13 Blago čoveku koji nađe mudrost,
\q2 i čoveku koji dobije razum.
\q1 
\v 14 Jer je bolje njom trgovati nego trgovati srebrom,
\q2 i dobitak na njoj bolji je od zlata.
\q1 
\v 15 Skuplja je od dragog kamenja,
\q2 i šta je god najmilijih stvari tvojih ne mogu se izjednačiti s njom.
\q1 
\v 16 Dug život u desnici joj je,
\q2 a u levici bogatstvo i slava.
\q1 
\v 17 Putevi su njeni mili putevi
\q2 i sve staze njene mirne.
\q1 
\v 18 Drvo je životno onima koji se hvataju za nju,
\q2 i ko je god drži srećan je.
\b
\q1 
\v 19 Gospod je mudrošću osnovao zemlju,
\q2 utvrdio nebesa razumom.
\q1 
\v 20 Njegovom mudrošću razvališe se bezdane
\q2 i oblaci kaplju rosom.
\b
\q1 
\v 21 Sine moj, da ti to ne odlazi iz očiju;
\q2 čuvaj pravu mudrost i razboritost;
\q1 
\v 22 I biće život duši tvojoj
\q2 i nakit grlu tvom.
\q1 
\v 23 Tada ćeš ići bez brige putem svojim,
\q2 i noga tvoja neće se spotaći.
\q1 
\v 24 Kad ležeš, nećeš se plašiti,
\q2 i kad počivaš, sladak će ti biti san.
\q1 
\v 25 Nećeš se plašiti od nagle strahote
\q2 ni od pogibli bezbožničke kad dođe.
\q1 
\v 26 Jer će ti Gospod biti uzdanica
\q2 i čuvaće ti nogu da se ne uhvati.
\q1 
\v 27 Ne odreci dobra onima kojima treba,
\q2 kad možeš učiniti.
\b
\q1 
\v 28 Ne govori bližnjemu svom:
\q2 Idi, i dođi drugi put, i sutra ću ti dati,
\q2 kad imaš.
\q1 
\v 29 Ne kuj zlo bližnjemu svom
\q2 koji živi s tobom bez brige.
\q1 
\v 30 Ne svađaj se ni s kim bez uzroka,
\q2 ako ti nije učinio zlo.
\q1 
\v 31 Nemoj zavideti nasilniku,
\q2 ni izabrati koji put njegov.
\q1 
\v 32 Jer je mrzak Gospodu zlikovac,
\q2 a u pravednih je tajna njegova.
\q1 
\v 33 Prokletstvo je Gospodnje u kući bezbožnikovoj,
\q2 a stan pravednički blagosilja.
\q1 
\v 34 Jer podsmevačima On se podsmeva,
\q2 a krotkima daje milost.
\q1 
\v 35 Mudri će naslediti slavu,
\q2 a bezumnike će odneti sramota.
\c 4
\s1 Nastava očina kako da se ide putem mudrosti.
\q1 
\v 1 Slušajte, deco, nastavu očevu,
\q2 i pazite da biste poznali mudrost.
\q1 
\v 2 Jer vam dobru nauku dajem,
\q2 ne ostavljajte zakon moj.
\q1 
\v 3 Kad bejah sin u oca svog mlad,
\q2 i jedinac u matere svoje,
\q1 
\v 4 On me učaše i govoraše mi:
\q2 Neka primi srce tvoje reči moje,
\q2 drži zapovesti moje i bićeš živ.
\q1 
\v 5 Pribavi mudrost, pribavi razum;
\q2 ne zaboravljaj i ne odstupaj od reči usta mojih.
\q1 
\v 6 Nemoj je ostaviti, i čuvaće te,
\q2 ljubi je, i hraniće te.
\q1 
\v 7 Mudrost je glavno; pribavi mudrost,
\q2 i za sve imanje svoje pribavi razum.
\q1 
\v 8 Podiži je i ona će te uzvisiti,
\q2 proslaviće te kad je zagrliš.
\q1 
\v 9 Metnuće ti na glavu venac od milina,
\q2 krasnu krunu daće ti.
\b
\q1 
\v 10 Slušaj, sine moj, i primi reči moje,
\q2 i umnožiće ti se godine životu.
\q1 
\v 11 Učim te putu mudrosti,
\q2 vodim te stazama pravim.
\q1 
\v 12 Kad ushodiš, neće se stezati koraci tvoji,
\q2 i ako potrčiš nećeš se spotaknuti.
\q1 
\v 13 Drži se nastave i ne puštaj,
\q2 čuvaj je, jer ti je život.
\q1 
\v 14 Ne idi na stazu bezbožničku
\q2 i putem nevaljalih ljudi ne stupaj.
\q1 
\v 15 Ostavi ga, ne hodi po njemu,
\q2 ukloni se od njega i mini ga.
\q1 
\v 16 Jer ne spavaju ako ne učine zla,
\q2 i ne dolazi im san ako koga ne obore.
\q1 
\v 17 Jer jedu hleb bezbožnosti
\q2 i piju vino nasilja.
\q1 
\v 18 A put je pravednički kao svetlo videlo,
\q2 koje sve većma svetli dok ne bude pravi dan.
\q1 
\v 19 A put je bezbožnički kao mrak,
\q2 ne znaju na šta će se spotaknuti.
\b
\q1 
\v 20 Sine moj, slušaj reči moje,
\q2 prigni uho svoje besedi mojoj.
\q1 
\v 21 Da ti ne odlaze iz očiju;
\q2 čuvaj ih usred srca svog.
\q1 
\v 22 Jer su život onima koji ih nalaze
\q2 i zdravlje svemu telu njihovom.
\q1 
\v 23 Svrh svega što se čuva čuvaj srce svoje,
\q2 jer iz njega izlazi život.
\q1 
\v 24 Ukloni od usta svojih opačinu
\q2 i od usana svojih nevaljalstvo udalji.
\q1 
\v 25 Oči tvoje neka gledaju upravo
\q2 i veđe tvoje neka se upravljaju pravo pred tobom.
\q1 
\v 26 Meri stazu nogama svojim,
\q2 i svi putevi tvoji neka su poravnjeni.
\q1 
\v 27 Ne svrći ni nadesno ni nalevo,
\q2 odvraćaj nogu svoju oda zla.
\c 5
\s1 Treba se čuvati razvrata.
\q1 
\v 1 Sine moj, slušaj mudrost moju,
\q2 k razumu mom prigni uho svoje,
\q1 
\v 2 Da se držiš razboritosti,
\q2 i usne tvoje da hrane znanje.
\q1 
\v 3 Jer s usana tuđe žene kaplje med,
\q2 i grlo joj je mekše od ulja;
\q1 
\v 4 Ali joj je posledak gorak kao pelen,
\q2 oštar kao mač s obe strane oštar.
\q1 
\v 5 Noge joj silaze k smrti,
\q2 do pakla dopiru koraci njeni.
\q1 
\v 6 Da ne bi merio put životni,
\q2 savijaju se staze njene da ne znaš.
\b
\q1 
\v 7 Zato, deco, poslušajte mene,
\q2 i ne odstupajte od reči usta mojih.
\q1 
\v 8 Neka je daleko od nje put tvoj,
\q2 i ne približuj se k vratima kuće njene,
\q1 
\v 9 Da ne bi dao drugima slave svoje
\q2 i godina svojih nemilostivome,
\q1 
\v 10 Da se ne bi tuđinci nasitili tvog blaga
\q2 i trud tvoj da ne bi bio u tuđoj kući,
\q1 
\v 11 I da ne ridaš na posletku,
\q2 kad se stroši meso tvoje i telo tvoje,
\q1 
\v 12 I kažeš: Kako mrzih na nastavu,
\q2 i kako srce moje prezira karanje!
\q1 
\v 13 I ne poslušah glas učitelja svojih,
\q2 i ne prignuh uha svog k onima koji me učahu!
\q1 
\v 14 Umalo ne zapadoh u svako zlo
\q2 usred zbora i skupštine.
\b
\q1 
\v 15 Pij vodu iz svog studenca
\q2 i što teče iz tvog izvora.
\q1 
\v 16 Neka se razlivaju tvoji izvori na polje,
\q2 i potoci po ulicama.
\q1 
\v 17 Imaj ih sam za se,
\q2 a ne tuđin s tobom.
\q1 
\v 18 Blagosloven da je izvor tvoj,
\q2 i veseli se ženom mladosti svoje;
\q1 
\v 19 Neka ti je kao košuta mila i kao srna ljupka;
\q2 dojke njene neka te opijaju u svako doba,
\q2 u ljubavi njenoj posrći jednako.
\q1 
\v 20 A zašto bi, sine, posrtao za tuđinkom
\q2 i golio nedra tuđoj,
\q1 
\v 21 Kad su pred očima Gospodu putevi svačiji,
\q2 i meri sve staze njegove?
\q1 
\v 22 Bezbožnika će uhvatiti njegova bezakonja,
\q2 i u uža greha svojih zaplešće se;
\q1 
\v 23 Umreće bez nastave,
\q2 i od mnoštva ludosti svoje lutaće.
\c 6
\s1 Treba se čuvati jemstva, lenjosti, zlobe i preljube.
\q1 
\v 1 Sine moj, kad se podjemčiš za prijatelja svog,
\q2 i daš ruku svoju tuđincu,
\q1 
\v 2 Vezao si se rečima usta svojih,
\q2 uhvatio si se rečima usta svojih.
\q1 
\v 3 Zato učini tako, sine moj, i oprosti se,
\q2 jer si dopao u ruke bližnjemu svom;
\q2 idi, pripadni, i navali na bližnjeg svog.
\q1 
\v 4 Ne daj sna očima svojim,
\q2 ni veđama svojim drema.
\q1 
\v 5 Otmi se kao srna iz ruke lovcu,
\q2 i kao ptica iz ruke ptičaru.
\b
\q1 
\v 6 Idi k mravu, lenjivče,
\q2 gledaj puteve njegove, i omudraj.
\q1 
\v 7 Nema vođu ni upravitelja ni gospodara;
\q1 
\v 8 I opet pripravlja leti sebi hranu,
\q2 zbira uz žetvu piću svoju.
\q1 
\v 9 Dokle ćeš, lenjivče, ležati?
\q2 Kad ćeš ustati od sna svog?
\q1 
\v 10 Dok malo prospavaš, dok malo prodremlješ,
\q2 dok malo sklopiš ruke da prilegneš,
\q1 
\v 11 U tom će doći siromaštvo tvoje kao putnik
\q2 i oskudica tvoja kao oružan čovek.
\b
\q1 
\v 12 Čovek nevaljao i nitkov
\q2 hodi sa zlim ustima;
\q1 
\v 13 Namiguje očima, govori nogama, pokazuje prstima;
\q1 
\v 14 Svaka mu je opačina u srcu,
\q2 kuje zlo svagda, zameće svađu.
\q1 
\v 15 Zato će ujedanput doći pogibao njegova,
\q2 časom će se satrti i neće biti leka.
\b
\q1 
\v 16 Na ovo šestoro mrzi Gospod,
\q2 i sedmo je gad duši njegovoj:
\q1 
\v 17 Oči ponosite,
\q1 jezik lažljiv
\q1 i ruke koje prolivaju krv pravu,
\q1 
\v 18 Srce koje kuje zle misli,
\q1 noge koje brzo trče na zlo,
\q1 
\v 19 Lažan svedok koji govori laž,
\q1 i ko zameće svađu među braćom.
\b
\q1 
\v 20 Čuvaj, sine moj, zapovest oca svog,
\q2 i ne ostavljaj nauke matere svoje.
\q1 
\v 21 Priveži ih sebi na srce zasvagda,
\q2 i sveži ih sebi oko grla.
\q1 
\v 22 Kuda god pođeš, vodiće te;
\q2 kad zaspiš, čuvaće te;
\q2 kad se probudiš, razgovaraće te;
\q1 
\v 23 Jer je zapovest žižak, i nauka je videlo,
\q2 i put je životni karanje koje poučava;
\q1 
\v 24 Da te čuvaju od zle žene,
\q2 od jezika kojim laska žena tuđa.
\q1 
\v 25 Ne zaželi u srcu svom lepotu njenu,
\q2 i nemoj da te uhvati veđama svojim.
\q1 
\v 26 Jer sa žene kurve spada čovek na komad hleba,
\q2 i žena pusta lovi dragocenu dušu.
\q1 
\v 27 Hoće li ko uzeti ognja u nedra,
\q2 a haljine da mu se ne upale?
\q1 
\v 28 Hoće li ko hoditi po živom ugljevlju,
\q2 a nogu da ne ožeže?
\q1 
\v 29 Tako biva onome koji ide k ženi bližnjeg svog;
\q2 neće biti bez krivice ko je se god dotakne.
\q1 
\v 30 Ne sramote lupeža koji ukrade da nasiti dušu svoju,
\q2 budući gladan;
\q1 
\v 31 Nego kad ga uhvate plati samosedmo,
\q2 da sve imanje doma svog.
\q1 
\v 32 Ali ko učini preljubu sa ženom, bezuman je,
\q2 dušu svoju gubi ko tako čini;
\q1 
\v 33 Muke i ruga dopada,
\q2 i sramota se njegova ne može izbrisati.
\q1 
\v 34 Jer je ljubavna sumnja žestoka u muža
\q2 i ne štedi na dan osvete;
\q1 
\v 35 Ne mari ni za kakav otkup,
\q2 i ne prima ako ćeš i mnogo darova davati.
\c 7
\s1 Opisivanje zavođenja na razvrat. Žalosne posledice tog zavođenja.
\q1 
\v 1 Sine, čuvaj reči moje,
\q2 i zapovesti moje sahrani kod sebe.
\q1 
\v 2 Čuvaj zapovesti moje i bićeš živ,
\q2 i nauku moju kao zenicu očiju svojih.
\q1 
\v 3 Priveži ih sebi na prste,
\q2 napiši ih na ploči srca svog.
\q1 
\v 4 Reci mudrosti: Sestra si mi;
\q2 i prijateljicom zovi razboritost,
\q1 
\v 5 Da bi te čuvala od žene tuđe,
\q2 od tuđinke, koja laska rečima.
\b
\q1 
\v 6 Jer s prozora doma svog kroz rešetku gledah,
\q1 
\v 7 I videh među ludima,
\q2 opazih među decom bezumnog mladića,
\q1 
\v 8 Koji iđaše ulicom pokraj ugla njenog,
\q2 i koračaše putem ka kući njenoj,
\q1 
\v 9 U sumrak, uveče, kad se unoća i smrče;
\b
\q1 
\v 10 A gle, srete ga žena
\q2 u odelu kurvinskom i lukavog srca,
\q1 
\v 11 Plaha i pusta,
\q2 kojoj noge ne mogu stajati kod kuće,
\q1 
\v 12 Sad na polju, sad na ulici,
\q2 kod svakog ugla vrebaše.
\q1 
\v 13 I uhvati ga, i poljubi ga,
\q2 i bezobrazno reče mu:
\q1 
\v 14 Imam žrtve zahvalne,
\q2 danas izvrših zavete svoje;
\q1 
\v 15 Zato ti iziđoh na susret da te tražim,
\q2 i nađoh te.
\q1 
\v 16 Nastrla sam odar svoj pokrivačem vezenim
\q2 i prostirkama misirskim.
\q1 
\v 17 Okadila sam postelju svoju smirnom, alojom i cimetom.
\q1 
\v 18 Hajde da se opijamo ljubavlju do zore,
\q2 da se veselimo milovanjem.
\q1 
\v 19 Jer mi muž nije kod kuće,
\q2 otišao je na put daleki,
\q1 
\v 20 Uzeo je sa sobom tobolac novčani,
\q2 vratiće se kući u određeni dan.
\b
\q1 
\v 21 Navrati ga mnogim rečima,
\q2 glatkim usnama odvuče ga.
\q1 
\v 22 Otide za njom odmah
\q2 kao što vo ide na klanje
\q2 i kao bezumnik u puto da bude karan,
\q1 
\v 23 Dokle mu strela ne probije jetru,
\q2 kao što ptica leti u zamku
\q2 ne znajući da joj je o život.
\b
\q1 
\v 24 Zato dakle, deco, poslušajte me,
\q2 i pazite na reči usta mojih.
\q1 
\v 25 Nemoj da zastranjuje srce tvoje ne puteve njene,
\q2 nemoj lutati po stazama njenim.
\q1 
\v 26 Jer je mnoge ranila i oborila,
\q2 i mnogo je onih koje je sve pobila.
\q1 
\v 27 Kuća je njena put pakleni
\q2 koji vodi u kleti smrtne.
\c 8
\s1 Poziv i obricanje mudrosti koja je večno u Boga.
\q1 
\v 1 Ne viče li mudrost?
\q2 I razum ne pušta li glas svoj?
\q1 
\v 2 Navrh visina, na putu, na rasputicama stoji,
\q1 
\v 3 Kod vrata, na ulasku u grad, gde se otvaraju vrata, viče:
\q1 
\v 4 Vas vičem, o ljudi,
\q2 i glas svoj obraćam k sinovima ljudskim.
\q1 
\v 5 Naučite se ludi mudrosti,
\q2 i bezumni orazumite se.
\q1 
\v 6 Slušajte, jer ću govoriti velike stvari,
\q2 i usne moje otvarajući se kazivaće šta je pravo.
\q1 
\v 7 Jer usta moja govore istinu,
\q2 i mrska je usnama mojim bezbožnost.
\q1 
\v 8 Prave su sve reči usta mojih,
\q2 ništa nema u njima krivo ni izopačeno.
\q1 
\v 9 Sve su obične razumnom
\q2 i prave su onima koji nalaze znanje.
\q1 
\v 10 Primite nastavu moju, a ne srebro,
\q2 i znanje radije nego najbolje zlato.
\q1 
\v 11 Jer je bolja mudrost od dragog kamenja,
\q2 i šta je god najmilijih stvari ne mogu se izjednačiti s njom.
\b
\q1 
\v 12 Ja mudrost boravim s razboritošću,
\q2 i razumno znanje nalazim.
\q1 
\v 13 Strah je Gospodnji mržnja na zlo;
\q2 ja mrzim na ponositost i na oholost
\q2 i na zli put i na usta opaka.
\q1 
\v 14 Moj je savet i šta god jeste;
\q2 ja sam razum i moja je sila.
\q1 
\v 15 Mnom carevi caruju,
\q2 i vladaoci postavljaju pravdu.
\q1 
\v 16 Mnom vladaju knezovi i poglavari i sve sudije zemaljske.
\q1 
\v 17 Ja ljubim one koji mene ljube,
\q2 i koji me dobro traže nalaze me.
\q1 
\v 18 U mene je bogatstvo i slava,
\q2 postojano dobro i pravda.
\q1 
\v 19 Plod je moj bolji od zlata i od najboljeg zlata,
\q2 i dobitak je moj bolji i od najboljeg srebra.
\q1 
\v 20 Putem pravednim hodim,
\q2 posred staza pravice,
\q1 
\v 21 Da onima koji me ljube dam ono što jeste,
\q2 i riznice njihove da napunim.
\b
\q1 
\v 22 Gospod me je imao u početku puta svog,
\q2 pre dela svojih, pre svakog vremena.
\q1 
\v 23 Pre vekova postavljena sam,
\q2 pre početka, pre postanja zemlje.
\q1 
\v 24 Kad još ne beše bezdana, rodila sam se,
\q2 kad još ne beše izvora obilatih vodom.
\q1 
\v 25 Pre nego se gore osnovaše,
\q2 pre humova ja sam se rodila;
\q1 
\v 26 Još ne beše načinio zemlje ni polja
\q2 ni početka prahu vasiljenskom;
\q1 
\v 27 Kad je uređivao nebesa, onde bejah;
\q2 kad je razmeravao krug nad bezdanom.
\q1 
\v 28 Kad je utvrđivao oblake gore
\q2 i krepio izvore bezdanu;
\q1 
\v 29 Kad je postavljao moru među
\q2 i vodama da ne prestupaju zapovesti Njegove,
\q2 kad je postavljao temelje zemlji;
\q1 
\v 30 Tada bejah kod Njega hranjenica,
\q2 bejah Mu milina svaki dan,
\q2 i veseljah se pred Njim svagda;
\q1 
\v 31 Veseljah se na vasiljeni Njegovoj,
\q2 i milina mi je sa sinovima ljudskim.
\b
\q1 
\v 32 Tako, dakle, sinovi, poslušajte me,
\q2 jer blago onima koji se drže puteva mojih.
\q1 
\v 33 Slušajte nastavu, i budite mudri,
\q2 i nemojte je odbaciti.
\q1 
\v 34 Blago čoveku koji me sluša
\q2 stražeći na vratima mojim svaki dan
\q2 i čuvajući pragove vrata mojih.
\q1 
\v 35 Jer ko mene nalazi, nalazi život
\q2 i dobija ljubav od Gospoda.
\q1 
\v 36 A ko o mene greši, čini krivo duši svojoj;
\q2 svi koji mrze na me, ljube smrt.
\c 9
\s1 Prijateljski poziv mudrosti.
\q1 
\v 1 Premudrost sazida sebi kuću,
\q2 i otesa sedam stupova;
\q1 
\v 2 Pokla stoku svoju,
\q2 rastvori vino svoje,
\q2 i postavi sto svoj.
\q1 
\v 3 Posla devojke svoje,
\q2 te zove svrh visina gradskih:
\q1 
\v 4 Ko je lud, neka se uvrati ovamo.
\q2 I bezumnima veli:
\q1 
\v 5 Hodite, jedite hleba mog,
\q2 i pijte vino koje sam rastvorila.
\q1 
\v 6 Ostavite ludost i bićete živi,
\q2 i idite putem razuma.
\b
\q1 
\v 7 Ko uči podsmevača, prima sramotu;
\q2 i ko kori bezbožnika, prima rug.
\q1 
\v 8 Ne karaj podsmevača da ne omrzne na te;
\q2 karaj mudra, i ljubiće te.
\q1 
\v 9 Kaži mudrome, i biće još mudriji;
\q2 pouči pravednog, i znaće više.
\q1 
\v 10 Početak je mudrosti strah Gospodnji,
\q2 i znanje je svetih stvari razum.
\q1 
\v 11 Jer će se mnom umnožiti dani tvoji
\q2 i dodaće ti se godine životu.
\q1 
\v 12 Ako budeš mudar, sebi ćeš biti mudar;
\q2 ako li budeš podsmevač, sam ćeš tegliti.
\b
\q1 
\v 13 Žena bezumna plaha je,
\q2 luda i ništa ne zna;
\q1 
\v 14 I sedi na vratima od kuće svoje
\q2 na stolici, na visinama gradskim,
\q1 
\v 15 Te viče one koji prolaze,
\q2 koji idu pravo svojim putem:
\q1 
\v 16 Ko je lud? Neka se uvrati ovamo.
\q2 I bezumnom govori:
\q1 
\v 17 Voda je kradena slatka,
\q2 i hleb je sakriven ugodan.
\q1 
\v 18 A on ne zna da su onde mrtvaci
\q2 i u dubokom grobu da su zvanice njene.
\c 10
\s1 Pravičnost se blagosilja, greh se proklinje.
\d Priče Solomunove.
\q1 
\v 1 Mudar je sin radost ocu svom,
\q2 a lud je sin žalost materi svojoj.
\q1 
\v 2 Ne pomaže nepravedno blago,
\q2 nego pravda izbavlja od smrti.
\q1 
\v 3 Ne da Gospod da gladuje duša pravednikova,
\q2 a imanje bezbožničko razmeće.
\q1 
\v 4 Nemarna ruka osiromašava,
\q2 a vredna ruka obogaćava.
\q1 
\v 5 Ko zbira u leto, sin je razuman;
\q2 ko spava o žetvi, sin je sramotan.
\q1 
\v 6 Blagoslovi su nad glavom pravedniku,
\q2 a usta bezbožnička pokriva nasilje.
\q1 
\v 7 Spomen pravednikov ostaje blagosloven,
\q2 a ime bezbožničko trune.
\q1 
\v 8 Ko je mudra srca, prima zapovesti;
\q2 a ko je ludih usana, pašće.
\q1 
\v 9 Ko hodi bezazleno, hodi pouzdano;
\q2 a ko je opak na putevima svojim, poznaće se.
\q1 
\v 10 Ko namiguje okom, daje muku;
\q2 i ko je ludih usana, pašće.
\q1 
\v 11 Usta su pravednikova izvor životu,
\q2 a usta bezbožnička pokriva nasilje.
\q1 
\v 12 Mrzost zameće svađe,
\q2 a ljubav prikriva sve prestupe.
\q1 
\v 13 Na usnama razumnog nalazi se mudrost,
\q2 a za leđa je bezumnog batina.
\q1 
\v 14 Mudri sklanjaju znanje,
\q2 a usta ludoga blizu su pogibli.
\q1 
\v 15 Bogatstvo je bogatima tvrd grad,
\q2 siromaštvo je siromasima pogibao.
\q1 
\v 16 Rad je pravednikov na život,
\q2 dobitak bezbožnikov na greh.
\q1 
\v 17 Ko prima nastavu, na putu je k životu;
\q2 a ko odbacuje kar, luta.
\q1 
\v 18 Ko pokriva mržnju, lažljivih je usana;
\q2 i ko iznosi sramotu bezuman je.
\q1 
\v 19 U mnogim rečima ne biva bez greha;
\q2 ali ko zadržava usne svoje, razuman je.
\q1 
\v 20 Jezik je pravednikov srebro odabrano;
\q2 srce bezbožničko ne vredi ništa.
\q1 
\v 21 Usne pravednikove pasu mnoge,
\q2 a bezumni umiru s bezumlja.
\q1 
\v 22 Blagoslov Gospodnji obogaćava a bez muke.
\q1 
\v 23 Bezumniku je šala činiti zlo,
\q2 a razuman čovek drži se mudrosti.
\q1 
\v 24 Čega se boji bezbožnik, ono će ga snaći;
\q2 a šta pravednici žele Bog će im dati.
\q1 
\v 25 Kao što prolazi oluja, tako bezbožnika nestaje;
\q2 a pravednik je na večitom temelju.
\q1 
\v 26 Kakav je ocat zubima i dim očima,
\q2 takav je lenjivac onima koji ga šalju.
\q1 
\v 27 Strah Gospodnji dodaje dane,
\q2 a bezbožnicima se godine prekraćuju.
\q1 
\v 28 Čekanje pravednih radost je,
\q2 a nadanje bezbožnih propada.
\q1 
\v 29 Put je Gospodnji krepost bezazlenom,
\q2 a strah onima koji čine bezakonje.
\q1 
\v 30 Pravednik se neće nikada pokolebati,
\q2 a bezbožnici neće nastavati na zemlji.
\q1 
\v 31 Usta pravednikova iznose mudrost,
\q2 a jezik opaki istrebiće se.
\q1 
\v 32 Usne pravednikove znaju šta je milo,
\q2 a bezbožnička su usta opačina.
\c 11
\s1 Sreća pobožnih, nesreća bezakonika.
\q1 
\v 1 Lažna su merila mrska Gospodu,
\q2 a prava mera ugodna Mu je.
\q1 
\v 2 Kad dođe oholost, dođe i sramota;
\q2 a u smernih je mudrost
\q1 
\v 3 Pravedne vodi bezazlenost njihova,
\q2 a bezakonike satire zloća njihova.
\q1 
\v 4 Neće pomoći bogatstvo u dan gneva,
\q2 a pravda izbavlja od smrti.
\q1 
\v 5 Pravda bezazlenoga upravlja put njegov,
\q2 a bezbožnik pada od svoje bezbožnosti.
\q1 
\v 6 Pravedne izbavlja pravda njihova,
\q2 a bezakonici hvataju se u svojoj zloći.
\q1 
\v 7 Kad umire bezbožnik, propada nadanje,
\q2 i najjače uzdanje propada.
\q1 
\v 8 Pravednik se izbavlja iz nevolje,
\q2 a bezbožnik dolazi na njegovo mesto.
\q1 
\v 9 Licemer kvari ustima bližnjeg svog;
\q2 ali se pravednici izbavljaju znanjem.
\q1 
\v 10 Dobru pravednih raduje se grad;
\q2 a kad propadaju bezbožnici, biva pevanje.
\q1 
\v 11 Blagoslovima pravednih ljudi podiže se grad,
\q2 a s usta bezbožničkih raskopava se.
\q1 
\v 12 Bezumnik se ruga bližnjemu svom,
\q2 a razuman čovek ćuti.
\q1 
\v 13 Opadač tumarajući izdaje tajnu;
\q2 a ko je verna srca, taji stvar.
\q1 
\v 14 Gde nema saveta, propada narod,
\q2 a pomoć je u mnoštvu savetnika.
\q1 
\v 15 Zlo prolazi ko se jamči za tuđina;
\q2 a ko mrzi na jamstvo, bez brige je.
\q1 
\v 16 Žena mila dobija čast,
\q2 a silni dobijaju bogatstvo.
\q1 
\v 17 Milostiv čovek čini dobro duši svojoj,
\q2 a nemilostiv udi svom telu.
\q1 
\v 18 Bezbožni radi posao prevaran;
\q2 a ko seje pravdu, pouzdana mu je plata.
\q1 
\v 19 Ko se drži pravde, na život mu je;
\q2 a ko ide za zlom, na smrt mu je.
\q1 
\v 20 Mrski su Gospodu koji su opakog srca;
\q2 a mili su Mu koji su bezazleni na svom putu.
\q1 
\v 21 Zao čovek neće ostati bez kara ako i druge uzme u pomoć;
\q2 a seme pravednih izbaviće se.
\q1 
\v 22 Žena lepa a bez razuma
\q2 zlatna je brnjica u gubici svinji.
\q1 
\v 23 Želja je pravednih samo dobro,
\q2 a očekivanje bezbožnih gnev.
\q1 
\v 24 Jedan prosipa, i sve više ima;
\q2 a drugi tvrduje suviše, i sve je siromašniji.
\q1 
\v 25 Podašna ruka biva bogatija,
\q2 i ko napaja, sam će biti napojen.
\q1 
\v 26 Ko ne da žita, proklinje ga narod,
\q2 a ko prodaje, blagoslov mu je nad glavom.
\q1 
\v 27 Ko traži dobro, dobija ljubav;
\q2 a ko traži zlo, zadesiće ga.
\q1 
\v 28 Ko se uzda u bogatstvo svoje, propašće;
\q2 a pravednici će se kao grana zeleneti.
\q1 
\v 29 Ko zatire kuću svoju, naslediće vetar;
\q2 i bezumnik će služiti mudrom.
\q1 
\v 30 Plod je pravednikov drvo životno,
\q2 i mudri obučava duše.
\q1 
\v 31 Gle, pravedniku se na zemlji plaća,
\q2 a kamoli bezbožniku i grešniku?
\c 12
\s1 Vladanje mudrih i bezumnih.
\q1 
\v 1 Ko ljubi nastavu, ljubi znanje;
\q2 a ko mrzi na ukor, ostaje lud.
\q1 
\v 2 Dobar čovek dobija ljubav od Gospoda,
\q2 a čoveka zlikovca osuđuje.
\q1 
\v 3 Neće se čovek utvrditi bezbožnošću,
\q2 a koren pravednih neće se pomaći.
\q1 
\v 4 Vredna je žena venac mužu svom;
\q2 a koja ga sramoti, ona mu je kao trulež u kostima.
\q1 
\v 5 Misli su pravednih prave,
\q2 a saveti bezbožnih prevara.
\q1 
\v 6 Reči bezbožnih vrebaju krv,
\q2 a pravedne izbavljaju usta njihova.
\q1 
\v 7 Obaraju se bezbožni da ih nema,
\q2 a dom pravednih ostaje.
\q1 
\v 8 Prema razumu svom hvali se čovek;
\q2 a ko je opaka srca, prezreće se.
\q1 
\v 9 Ko se snebiva, a ima slugu, bolji je
\q2 od onog koji se veliča a hleba nema.
\q1 
\v 10 Pravednik se brine za život svog živinčeta,
\q2 a u bezbožnika je srce nemilostivo.
\q1 
\v 11 Ko radi svoju zemlju, biće sit hleba;
\q2 a ko ide za besposlicama, bezuman je.
\q1 
\v 12 Bezbožnik želi obranu oda zla,
\q2 ali koren pravednih daje je.
\q1 
\v 13 Zlome je zamka u grehu usana njegovih,
\q2 a pravednik izlazi iz teskobe.
\q1 
\v 14 Od ploda usta svojih siti se čovek dobra,
\q2 i platu za dela svoja prima čovek.
\q1 
\v 15 Bezumniku se čini prav put njegov;
\q2 ali ko sluša savet, mudar je.
\q1 
\v 16 Gnev bezumnikov odmah se pozna,
\q2 ali pametni pokriva sramotu.
\q1 
\v 17 Ko govori istinu, javlja šta je pravo,
\q2 a lažni svedok prevaru.
\q1 
\v 18 Ima ko govori kao da mač probada,
\q2 a jezik je mudrih lek.
\q1 
\v 19 Istinita usta stoje tvrdo doveka,
\q2 a jezik lažljivi za čas.
\q1 
\v 20 Koji zlo misle, prevara im je u srcu,
\q2 a radost je onima koji savetuju na mir.
\q1 
\v 21 Nikakva nesreća neće zadesiti pravednika,
\q2 a bezbožnici će se napuniti zla.
\q1 
\v 22 Mrske su Gospodu lažljive usne;
\q2 a koji rade verno, mili su Mu.
\q1 
\v 23 Pametan čovek pokriva znanje,
\q2 a srce bezumnih razglašuje bezumlje.
\q1 
\v 24 Ruka radljiva gospodariće,
\q2 a lena će davati danak.
\q1 
\v 25 Briga u srcu čovečijem obara;
\q2 a dobra reč razveseljava.
\q1 
\v 26 Pravedniku je bolje nego bližnjemu njegovom;
\q2 a bezbožnike zavodi put njihov.
\q1 
\v 27 Lenjivac neće peći lov svoj,
\q2 a u vrednog je čoveka dobro dragoceno.
\q1 
\v 28 Na putu pravde život je,
\q2 i kuda ide staza njena nema smrti.
\c 13
\s1 Nastavak opisivanja mudrog i bezumnog života.
\q1 
\v 1 Mudar sin sluša nastavu oca svog;
\q2 a podsmevač ne sluša ukore.
\q1 
\v 2 Od ploda usta svojih svaki će jesti dobro,
\q2 a duša nevaljalih ljudi nasilje.
\q1 
\v 3 Ko čuva usta svoja, čuva svoju dušu;
\q2 ko razvaljuje usne, propada.
\q1 
\v 4 Željna je duša lenjivčeva, ali nema ništa;
\q2 a duša vrednih ljudi obogatiće se.
\q1 
\v 5 Na lažnu reč mrzi pravednik;
\q2 a bezbožnik se mrazi i sramoti.
\q1 
\v 6 Pravda čuva onog koji hodi bezazleno;
\q2 a bezbožnost obara grešnika.
\q1 
\v 7 Ima ko se gradi bogat a nema ništa,
\q2 i ko se gradi siromah a ima veliko blago.
\q1 
\v 8 Otkup je za život čoveku bogatstvo njegovo,
\q2 a siromah ne sluša pretnje.
\q1 
\v 9 Videlo pravedničko svetli se,
\q2 a žižak bezbožnički ugasiće se.
\q1 
\v 10 Od oholosti biva samo svađa,
\q2 a koji primaju savet, u njih je mudrost.
\q1 
\v 11 Blago koje se taštinom teče umanjuje se,
\q2 a ko sabira rukom, umnožava.
\q1 
\v 12 Dugo nadanje mori srce,
\q2 i želja je ispunjena drvo životno.
\q1 
\v 13 Ko prezire reč sam sebi udi;
\q2 a ko se boji zapovesti, platiće mu se.
\q1 
\v 14 Nauka je mudroga izvor životni
\q2 da se sačuva prugala smrtnih.
\q1 
\v 15 Dobar razum daje ljubav,
\q2 a put je bezakonički hrapav.
\q1 
\v 16 Svaki pametan čovek radi s razumom,
\q2 a bezuman raznosi bezumlje.
\q1 
\v 17 Glasnik bezbožan pada u zlo,
\q2 a veran je poslanik lek.
\q1 
\v 18 Siromaštvo i sramota doći će na onog koji odbacuje nastavu;
\q2 a ko čuva karanje, proslaviće se.
\q1 
\v 19 Ispunjena je želja slast duši,
\q2 a bezumnima je mrsko odstupiti oda zla.
\q1 
\v 20 Ko hodi s mudrima postaje mudar,
\q2 a ko se drži s bezumnicima postaje gori.
\q1 
\v 21 Grešnike goni zlo,
\q2 a pravednicima se vraća dobro.
\q1 
\v 22 Dobar čovek ostavlja nasledstvo sinovima sinova svojih,
\q2 a grešnikovo imanje čuva se pravedniku.
\q1 
\v 23 Izobila hrane ima na njivi siromaškoj,
\q2 a ima ko propada sa zle uprave.
\q1 
\v 24 Ko žali prut, mrzi na sina svog;
\q2 a ko ga ljubi, kara ga za vremena.
\q1 
\v 25 Pravednik jede, i sita mu je duša;
\q2 a trbuh bezbožnicima nema dosta.
\c 14
\s1 Pohvala pravoj mudrosti u čovečijem životu.
\q1 
\v 1 Mudra žena zida kuću svoju,
\q2 a luda svojim rukama raskopava.
\q1 
\v 2 Ko hodi pravo, boji se Gospoda;
\q2 a ko je opak na svojim putevima, prezire Ga.
\q1 
\v 3 U ustima je bezbožnikovim prut oholosti,
\q2 a mudre čuvaju usta njihova.
\q1 
\v 4 Gde nema volova, čiste su jasle;
\q2 a obilata je letina od sile volovske.
\q1 
\v 5 Istinit svedok ne laže,
\q2 a lažan svedok govori laž.
\q1 
\v 6 Podsmevač traži mudrost, i ne nahodi je;
\q2 a razumnom je znanje lako naći.
\q1 
\v 7 Idi od čoveka bezumnog,
\q2 jer nećeš čuti pametne reči.
\q1 
\v 8 Mudrost je pametnog da pazi na put svoj,
\q2 a bezumlje je bezumnih prevara.
\q1 
\v 9 Bezumnima je šala greh,
\q2 a među pravednima je dobra volja.
\q1 
\v 10 Srce svačije zna jad duše svoje;
\q2 i u veselje njegovo ne meša se drugi.
\q1 
\v 11 Dom bezbožnički raskopaće se,
\q2 a koliba pravednih cvetaće.
\q1 
\v 12 Neki se put čini čoveku prav,
\q2 a kraj mu je put k smrti.
\q1 
\v 13 I od smeha boli srce,
\q2 i veselju kraj biva žalost.
\q1 
\v 14 Puteva svojih nasitiće se ko je izopačenog srca,
\q2 ali ga se kloni čovek dobar.
\q1 
\v 15 Lud veruje svašta,
\q2 a pametan pazi na svoje korake.
\q1 
\v 16 Mudar se boji i uklanja se od zla,
\q2 a bezuman navire i slobodan je.
\q1 
\v 17 Nagao čovek čini bezumlje,
\q2 a pakostan je čovek mrzak.
\q1 
\v 18 Ludi nasleđuje bezumlje,
\q2 a razboriti venčava se znanjem.
\q1 
\v 19 Klanjaju se zli pred dobrima
\q2 i bezbožni na vratima pravednog.
\q1 
\v 20 Ubogi je mrzak i prijatelju svom,
\q2 a bogati imaju mnogo prijatelja.
\q1 
\v 21 Ko prezire bližnjeg svog greši;
\q2 a ko je milostiv ubogima, blago njemu.
\q1 
\v 22 Koji smišljaju zlo, ne lutaju li?
\q2 A milost i vera biće onima koji smišljaju dobro.
\q1 
\v 23 U svakom trudu ima dobitka,
\q2 a govor usnama samo je siromaštvo.
\q1 
\v 24 Mudrima je venac bogatstvo njihovo,
\q2 a bezumlje bezumnih ostaje bezumlje.
\q1 
\v 25 Istinit svedok izbavlja duše,
\q2 a lažan govori prevaru.
\q1 
\v 26 U strahu je Gospodnjem jako pouzdanje,
\q2 i sinovima je utočište.
\q1 
\v 27 Strah je Gospodnji izvor životu
\q2 da se čovek sačuva od prugala smrtnih.
\q1 
\v 28 U mnoštvu je naroda slava caru;
\q2 a kad nestaje naroda, propast je vladaocu.
\q1 
\v 29 Ko je spor na gnev, velika je razuma;
\q2 a ko je nagao pokazuje ludost.
\q1 
\v 30 Život je telu srce zdravo,
\q2 a zavist je trulež u kostima.
\q1 
\v 31 Ko čini krivo ubogome, sramoti Stvoritelja njegovog;
\q2 a poštuje Ga ko je milostiv siromahu.
\q1 
\v 32 Za zlo svoje povrgnuće se bezbožnik,
\q2 a pravednik nada se i na samrti.
\q1 
\v 33 Mudrost počiva u srcu razumnog čoveka,
\q2 a šta je u bezumnima poznaje se.
\q1 
\v 34 Pravda podiže narod,
\q2 a greh je sramota narodima.
\q1 
\v 35 Mio je caru razuman sluga,
\q2 ali na sramotnog gnevi se.
\c 15
\s1 Mudrost donosi spasenje, a bezumlje i grehovi propast.
\q1 
\v 1 Odgovor blag utišava gnev,
\q2 a reč preka podiže srdnju.
\q1 
\v 2 Jezik mudrih ljudi ukrašava znanje,
\q2 a usta bezumnih prosipaju bezumlje.
\q1 
\v 3 Oči su Gospodnje na svakom mestu
\q2 gledajući zle i dobre.
\q1 
\v 4 Zdrav je jezik drvo životno,
\q2 a opačina s njega kršenje od vetra.
\q1 
\v 5 Lud se ruga nastavom oca svog;
\q2 a ko prima ukor biva pametan.
\q1 
\v 6 U kući pravednikovoj ima mnogo blaga;
\q2 a u dohotku je bezbožnikovom rasap.
\q1 
\v 7 Usne mudrih ljudi seju znanje,
\q2 a srce bezumničko ne čini tako.
\q1 
\v 8 Žrtva je bezbožnička gad Gospodu,
\q2 a molitva pravednih ugodna Mu je.
\q1 
\v 9 Gad je Gospodu put bezbožnikov;
\q2 a ko ide za pravdom, njega ljubi.
\q1 
\v 10 Karanje je zlo onome ko ostavlja put;
\q2 koji mrzi na ukor, umreće.
\q1 
\v 11 Pakao je i pogibao pred Gospodom,
\q2 a kamoli srca sinova čovečijih.
\q1 
\v 12 Podsmevač ne ljubi onog ko ga kori,
\q2 niti ide k mudrima.
\q1 
\v 13 Veselo srce veseli lice,
\q2 a žalost u srcu obara duh.
\q1 
\v 14 Srce razumno traži znanje,
\q2 a usta bezumnih ljudi naslađuju se bezumljem.
\q1 
\v 15 Svi su dani nevoljnikovi zli;
\q2 a ko je veselog srca, na gozbi je jednako.
\q1 
\v 16 Bolje je malo sa strahom Gospodnjim
\q2 nego veliko blago s nemirom.
\q1 
\v 17 Bolje je jelo od zelja gde je ljubav
\q2 nego od vola ugojena gde je mržnja.
\q1 
\v 18 Čovek gnevljiv zameće raspru;
\q2 a ko je spor na gnev, utišava svađu.
\q1 
\v 19 Put je lenjoga kao ograda od trnja,
\q2 a staza je pravednih nasuta.
\q1 
\v 20 Mudar je sin radost ocu,
\q2 a čovek bezuman prezire mater svoju.
\q1 
\v 21 Bezumlje je radost bezumniku,
\q2 a razuman čovek hodi pravo.
\q1 
\v 22 Namere se rasipaju kad nema saveta,
\q2 a tvrdo stoje gde je mnogo savetnika.
\q1 
\v 23 Raduje se čovek odgovorom usta svojih,
\q2 i reč u vreme kako je dobra!
\q1 
\v 24 Put k životu ide gore razumnome
\q2 da se sačuva od pakla odozdo.
\q1 
\v 25 Gospod raskopava kuću ponositima,
\q2 a među udovici utvrđuje.
\q1 
\v 26 Mrske su Gospodu misli zle,
\q2 a besede čistih mile su.
\q1 
\v 27 Lakomac zatire svoju kuću,
\q2 a ko mrzi na poklone živ će biti.
\q1 
\v 28 Srce pravednikovo premišlja šta će govoriti,
\q2 a usta bezbožnička rigaju zlo.
\q1 
\v 29 Daleko je Gospod od bezbožnih,
\q2 a molitvu pravednih čuje.
\q1 
\v 30 Vid očni veseli srce,
\q2 dobar glas goji kosti.
\q1 
\v 31 Uho koje sluša karanje životno
\q2 nastavaće među mudrima.
\q1 
\v 32 Ko odbacuje nastavu, ne mari za dušu svoju;
\q2 a ko sluša karanje, biva razuman.
\q1 
\v 33 Strah je Gospodnji nastava k mudrosti,
\q2 i pre slave ide smernost.
\c 16
\s1 Bog vidi čovečija dela.
\q1 
\v 1 Čovek sprema srce,
\q2 ali je od Gospoda šta će jezik govoriti.
\q1 
\v 2 Čoveku se svi putevi njegovi čine čisti,
\q2 ali Gospod ispituje duhove.
\q1 
\v 3 Ostavi na Gospoda dela svoja,
\q2 i biće tvrde namere tvoje.
\q1 
\v 4 Gospod je stvorio sve sam za se,
\q2 i bezbožnika za zli dan.
\q1 
\v 5 Mrzak je Gospodu ko je god ponositog srca,
\q2 i neće ostati bez kara ako će i druge uzeti u pomoć.
\q1 
\v 6 Milošću i istinom očišća se bezakonje,
\q2 i strahom Gospodnjim uklanja se čovek oda zla.
\q1 
\v 7 Kad su čiji putevi mili Gospodu,
\q2 miri s njim i neprijatelje njegove.
\q1 
\v 8 Bolje je malo s pravdom
\q2 nego mnogo dohodaka s nepravdom.
\q1 
\v 9 Srce čovečije izmišlja sebi put,
\q2 ali Gospod upravlja korake njegove.
\q1 
\v 10 Proroštvo je na usnama carevim,
\q2 u sudu neće pogrešiti usta njegova.
\q1 
\v 11 Merila i potezi pravi od Gospoda su,
\q2 i sve kamenje u tobocu njegovo je delo.
\q1 
\v 12 Gadno je carevima činiti nepravdu,
\q2 jer se pravdom utvrđuje presto.
\q1 
\v 13 Mile su carevima usne pravedne,
\q2 i oni ljube onog koji govori pravo.
\q1 
\v 14 Gnev je carev glasnik,
\q2 ali mudar čovek ublažiće ga.
\q1 
\v 15 U veselu je licu carevom život,
\q2 i ljubav je njegova kao oblak s poznim daždem.
\q1 
\v 16 Koliko je bolje teći mudrost nego zlato!
\q2 I teći razum koliko je lepše nego srebro!
\q1 
\v 17 Put je pravednih uklanjanje oda zla;
\q2 čuva dušu svoju ko pazi na put svoj.
\q1 
\v 18 Oholost dolazi pred pogibao,
\q2 i ponosit duh pred propast.
\q1 
\v 19 Bolje je biti poniznog duha s krotkima
\q2 nego deliti plen s oholima.
\q1 
\v 20 Ko pazi na reč, nalazi dobro,
\q2 i ko se uzda u Gospoda, blago njemu.
\q1 
\v 21 Ko je mudrog srca, zove se razuman,
\q2 a slast na usnama umnožava nauku.
\q1 
\v 22 Izvor je životu razum onima koji ga imaju,
\q2 a nauka bezumnih bezumlje je.
\q1 
\v 23 Srce mudroga razumno upravlja ustima njegovim,
\q2 i dodaje nauku usnama njegovim.
\q1 
\v 24 Ljubazne su reči saće meda,
\q2 slast duši i zdravlje kostima.
\q1 
\v 25 Neki se put čini čoveku prav,
\q2 a kraj mu je put k smrti.
\q1 
\v 26 Ko se trudi sebi se trudi,
\q2 jer ga nagone usta njegova.
\q1 
\v 27 Čovek nevaljao kopa zlo,
\q2 i na usnama mu je kao oganj koji pali.
\q1 
\v 28 Opak čovek zameće svađu,
\q2 i opadač rastavlja glavne prijatelje.
\q1 
\v 29 Nasilnik mami druga svog
\q2 i zavodi ga na put koji nije dobar;
\q1 
\v 30 Namiguje očima, kad misli naopako;
\q2 kad miče usnama, čini zlo.
\q1 
\v 31 Seda je kosa slavna kruna,
\q2 nalazi se na putu pravednom.
\q1 
\v 32 Bolji je spor na gnev nego junak,
\q2 i gospodar od svog srca bolji je nego onaj koji uzme grad.
\q1 
\v 33 Ždreb se baca u krilo,
\q2 ali je od Gospoda sve što izlazi.
\c 17
\s1 Mudrost i bezumlje osobito u govoru.
\q1 
\v 1 Bolji je zalogaj suvog hleba s mirom
\q2 nego kuća puna poklane stoke sa svađom.
\q1 
\v 2 Razuman sluga biće gospodar nad sinom sramotnim
\q2 i s braćom će deliti nasledstvo.
\q1 
\v 3 Topionica je za srebro i peć za zlato,
\q2 a srca iskušava Gospod.
\q1 
\v 4 Zao čovek pazi na usne zle,
\q2 a lažljivac sluša jezik pakostan.
\q1 
\v 5 Ko se ruga siromahu, sramoti Stvoritelja njegovog;
\q2 ko se raduje nesreći, neće ostati bez kara.
\q1 
\v 6 Venac su starcima unuci,
\q2 a slava sinovima oci njihovi.
\q1 
\v 7 Ne priliči bezumnom visoka beseda,
\q2 a kamoli knezu lažljiva beseda.
\q1 
\v 8 Poklon je dragi kamen onome koji ga prima,
\q2 kuda se god okrene napreduje.
\q1 
\v 9 Ko pokriva prestup, traži ljubav;
\q2 a ko ponavlja stvar, rastavlja glavne prijatelje.
\q1 
\v 10 Ukor tišti razumnog
\q2 većma nego ludog sto udaraca.
\q1 
\v 11 Zao čovek traži samo odmet,
\q2 ali će se ljut glasnik poslati na nj.
\q1 
\v 12 Bolje je da čoveka srete medvedica kojoj su oteti medvedići,
\q2 nego bezumnik u svom bezumlju.
\q1 
\v 13 Ko vraća zlo za dobro,
\q2 neće se zlo odmaći od kuće njegove.
\q1 
\v 14 Ko počne svađu, otvori ustavu vodi;
\q2 zato pre nego se zametne, prođi se raspre.
\q1 
\v 15 Ko opravda krivoga i ko osudi pravoga,
\q2 obojica su gad Gospodu.
\q1 
\v 16 Na šta je blago bezumnom u ruci
\q2 kad nema razuma da pribavi mudrost?
\q1 
\v 17 U svako doba ljubi prijatelj,
\q2 i brat postaje u nevolji.
\q1 
\v 18 Čovek bezuman daje ruku
\q2 i jamči se za prijatelja svog.
\q1 
\v 19 Ko miluje svađu, miluje greh;
\q2 ko podiže uvis vrata svoja, traži pogibao.
\q1 
\v 20 Ko je opakog srca, neće naći dobra;
\q2 i ko dvoliči jezikom, pašće u zlo.
\q1 
\v 21 Ko rodi bezumna, na žalost mu je,
\q2 niti će se radovati otac ludoga.
\q1 
\v 22 Srce veselo pomaže kao lek,
\q2 a duh žalostan suši kosti.
\q1 
\v 23 Bezbožnik prima poklon iz nedara
\q2 da prevrati puteve pravdi.
\q1 
\v 24 Razumnom je na licu mudrost,
\q2 a oči bezumniku vrljaju nakraj zemlje.
\q1 
\v 25 Žalost je ocu svom sin bezuman,
\q2 i jad roditeljci svojoj.
\q1 
\v 26 Nije dobro globiti pravednika,
\q2 ni da knezovi biju koga što je radio pravo.
\q1 
\v 27 Usteže reči svoje čovek koji zna,
\q2 i tiha je duha čovek razuman.
\q1 
\v 28 I bezuman kad ćuti, misli se da je mudar,
\q2 i razuman, kad stiskuje usne svoje.
\c 18
\s1 Prijateljstvo i miroljubivost.
\q1 
\v 1 Čovek samovoljan traži šta je njemu milo
\q2 i meša se u svašta.
\q1 
\v 2 Bezumniku nije mio razum
\q2 nego da se javlja srce njegovo.
\q1 
\v 3 Kad dođe bezbožnik, dođe i rug,
\q2 i prekor sa sramotom.
\q1 
\v 4 Reči su iz usta čovečijih duboka voda,
\q2 izvor je mudrosti potok koji se razliva.
\q1 
\v 5 Nije dobro gledati bezbožniku ko je,
\q2 da se učini krivo pravom na sudu.
\q1 
\v 6 Usne bezumnikove pristaju u svađu,
\q2 i usta njegova dozivaju boj.
\q1 
\v 7 Bezumniku su usta njegova pogibao,
\q2 i usne njegove pruglo duši njegovoj.
\q1 
\v 8 Reči su opadačeve kao izbijenih,
\q2 ali silaze unutra u trbuh.
\q1 
\v 9 I ko je nemaran u poslu svom
\q2 brat je raspikući.
\q1 
\v 10 Tvrda je kula ime Gospodnje.
\q2 K Njemu će pobeći pravednik, i biće u visokom zaklonu.
\q1 
\v 11 Bogatstvo je bogatom jak grad
\q2 i kao visok zid u njegovoj misli.
\q1 
\v 12 Pred propast podiže se srce čoveka,
\q2 a pre slave ide smernost.
\q1 
\v 13 Ko odgovara pre nego čuje,
\q2 tome je ludost i sramota.
\q1 
\v 14 Duh čovečiji snosi bol svoj;
\q2 a duh oboren ko će podignuti?
\q1 
\v 15 Srce razumnog čoveka dobavlja znanje,
\q2 i uho mudrih traži znanje.
\q1 
\v 16 Dar čoveku širi mesto
\q2 i vodi ga pred vlastelje.
\q1 
\v 17 Pravedan se čini ko je prvi u svojoj raspri,
\q2 ali kad dođe bližnji njegov, ispituje se.
\q1 
\v 18 Raspre prekida žreb,
\q2 i između silnih rasuđuje.
\q1 
\v 19 Uvređen je brat kao tvrd grad,
\q2 i svađa je kao prevornica na dvoru.
\q1 
\v 20 Svakom se trbuh siti plodom usta njegovih,
\q2 dohotkom od usna svojih siti se.
\q1 
\v 21 Smrt je i život u vlasti jeziku,
\q2 i ko ga miluje, ješće plod njegov.
\q1 
\v 22 Ko je našao ženu, našao je dobro
\q2 i dobio ljubav od Gospoda.
\q1 
\v 23 Siromah govori moleći,
\q2 a bogat odgovara oštro.
\q1 
\v 24 Ko ima prijatelja, valja da postupa prijateljski,
\q2 jer ima prijatelja vernijih od brata.
\c 19
\s1 Pobožno siromaštvo, šteta od bezumlja, od lenjosti i od potsmevanja.
\q1 
\v 1 Siromah koji hodi u bezazlenosti svojoj bolji je
\q2 nego opaki usnama svojim, koji je bezuman.
\q1 
\v 2 Kad je duša bez znanja, nije dobro;
\q2 i ko je brzih nogu, spotiče se.
\q1 
\v 3 Ludost čovečija prevraća put njegov,
\q2 a srce se njegovo gnevi na Gospoda.
\q1 
\v 4 Bogatstvo pribavlja mnogo prijatelja,
\q2 a siromaha ostavlja prijatelj njegov.
\q1 
\v 5 Lažan svedok neće ostati bez kara,
\q2 i ko govori laž, neće pobeći.
\q1 
\v 6 Mnogi ugađaju knezu,
\q2 i svak je prijatelj čoveku podatljivom.
\q1 
\v 7 Na siromaha mrze sva braća njegova,
\q2 još više se prijatelji njegovi udaljuju od njega;
\q2 viče za njima, ali ih nema.
\q1 
\v 8 Ko pribavlja razum, ljubi dušu svoju;
\q2 i ko pazi na mudrost, naći će dobro.
\q1 
\v 9 Svedok lažan neće ostati bez kara,
\q2 i ko govori laž, poginuće.
\q1 
\v 10 Ne dolikuju bezumnom miline,
\q2 ni sluzi da vlada knezovima.
\q1 
\v 11 Razum zadržava čoveka od gneva,
\q2 i čast mu je mimoići krivicu.
\q1 
\v 12 Careva je srdnja kao rika mladog lava,
\q2 i ljubav je njegova kao rosa travi.
\q1 
\v 13 Bezuman je sin muka ocu svom,
\q2 i svadljivost ženina neprestano prokisivanje.
\q1 
\v 14 Kuća i imanje nasleđuje se od otaca;
\q2 a od Gospoda je razumna žena.
\q1 
\v 15 Lenost navodi tvrd san,
\q2 i nemarljiva duša gladovaće.
\q1 
\v 16 Ko drži zapovesti, čuva dušu svoju;
\q2 a ko ne mari za puteve svoje, poginuće.
\q1 
\v 17 Gospodu pozaima ko poklanja siromahu,
\q2 i platiće mu za dobro njegovo.
\q1 
\v 18 Karaj sina svog dokle ima nadanja
\q2 i na pogibao njegovu da ne prašta duša tvoja.
\q1 
\v 19 Velik gnev pokazuj kad praštaš kar,
\q2 i kad oprostiš, posle većma pokaraj.
\q1 
\v 20 Slušaj savet i primaj nastavu,
\q2 da posle budeš mudar.
\q1 
\v 21 Mnogo ima misli u srcu čovečijem,
\q2 ali šta Gospod naumi ono će ostati.
\q1 
\v 22 Želja čoveku treba da je da čini milost,
\q2 a bolji je siromah nego laža.
\q1 
\v 23 Strah je Gospodnji na život;
\q2 u koga je on, boravi sit, niti ga pohodi zlo.
\q1 
\v 24 Lenjivac krije ruku svoju u nedra,
\q2 ni k ustima svojim ne prinosi je.
\q1 
\v 25 Udri podsmevača da ludi omudra,
\q2 i razumnog nakaraj da razume nauku.
\q1 
\v 26 Sin sramotan i prekoran
\q2 upropašćuje oca i odgoni mater.
\q1 
\v 27 Nemoj, sine, slušati nauke koja odvodi od reči razumnih.
\q1 
\v 28 Nevaljao svedok podsmeva se pravdi,
\q2 i usta bezbožnika proždiru na nepravdu.
\q1 
\v 29 Gotovi su podsmevačima sudovi
\q2 i bezumnicima boj na leđa.
\c 20
\s1 Opomena zbog neumernosti u jelu i piću, i zbog neobuzdanosti.
\q1 
\v 1 Vino je podsmevač i silovito piće nemirnik,
\q2 i ko god za njim luta neće biti mudar.
\q1 
\v 2 Strah je carev kao rika mladog lava;
\q2 ko ga draži, greši svojoj duši.
\q1 
\v 3 Slava je čoveku da se okani svađe;
\q2 a ko je god bezuman, upleće se.
\q1 
\v 4 Radi zime lenivac ne ore;
\q2 prosi o žetvi, i ništa ne dobija.
\q1 
\v 5 Savet je u srcu čovečijem duboka voda,
\q2 ali čovek razuman crpe ga.
\q1 
\v 6 Najviše ljudi hvali se svojom dobrotom;
\q2 ali ko će naći čoveka istinitog?
\q1 
\v 7 Pravednik jednako hodi u bezazlenosti svojoj;
\q2 blago sinovima njegovim posle njega!
\q1 
\v 8 Car sedeći na prestolu sudskom
\q2 rasipa očima svojim svako zlo.
\q1 
\v 9 Ko može reći:
\q2 Očistio sam srce svoje, čist sam od greha svog?
\q1 
\v 10 Dvojak poteg i dvojaka mera,
\q2 oboje je mrsko Gospodu.
\q1 
\v 11 Po delima svojim poznaje se i dete
\q2 hoće li biti čisto i hoće li biti pravo delo njegovo.
\q1 
\v 12 Uho koje čuje, i oko koje vidi,
\q2 oboje je Gospod načinio.
\q1 
\v 13 Ne ljubi sna, da ne osiromašiš;
\q2 otvaraj oči svoje, i bićeš sit hleba.
\q1 
\v 14 Ne valja, ne valja, govori ko kupuje,
\q2 a kad otide onda se hvali.
\q1 
\v 15 Ima zlata i mnogo bisera,
\q2 ali su mudre usne najdragoceniji nakit.
\q1 
\v 16 Uzmi haljinu onome koji se podjemči za tuđina,
\q2 uzmi zalog od njega za tuđinku.
\q1 
\v 17 Sladak je čoveku hleb od prevare,
\q2 ali mu se posle napune usta peska.
\q1 
\v 18 Misli se utvrđuju savetom;
\q2 zato razumno ratuj.
\q1 
\v 19 Ko otkriva tajnu, postupa neverno;
\q2 zato se ne mešaj s onim koji razvaljuje usta.
\q1 
\v 20 Ko psuje oca svog ili mater svoju,
\q2 njegov će se žižak ugasiti u crnom mraku.
\q1 
\v 21 Nasledstvo koje se iz početka brzo dobija,
\q2 ne biva na posletku blagosloveno.
\q1 
\v 22 Ne govori: Vratiću zlo.
\q2 Čekaj Gospoda, i sačuvaće te.
\q1 
\v 23 Mrzak je Gospodu dvojak poteg,
\q2 merila lažna nisu dobra.
\q1 
\v 24 Od Gospoda su koraci čovečji,
\q2 a čovek kako će razumeti put njegov?
\q1 
\v 25 Zamka je čoveku da proždre svetinju,
\q2 i posle zaveta opet da traži.
\q1 
\v 26 Mudar car rasipa bezbožnike
\q2 i pušta na njih kolo.
\q1 
\v 27 Videlo je Gospodnje duša čovečija,
\q2 istražuje sve što je u srcu.
\q1 
\v 28 Milost i istina čuvaju cara,
\q2 i milošću podupire svoj presto.
\q1 
\v 29 Slava je mladićima sila njihova,
\q2 a starcima čast seda kosa.
\q1 
\v 30 Modrice od boja i udarci koji prodiru do srca jesu lek zlome.
\c 21
\s1 Božiji promisao upravlja srcima i putevima ljudskim.
\q1 
\v 1 Srce je carevo u ruci Gospodu kao potoci vodeni;
\q2 kuda god hoće, savija ga.
\q1 
\v 2 Svaki se put čoveku čini prav,
\q2 ali Gospod ispituje srca.
\q1 
\v 3 Da se čini pravda i sud,
\q2 milije je Gospodu nego žrtva.
\q1 
\v 4 Ponosite oči i naduto srce i oranje bezbožničko greh je.
\q1 
\v 5 Misli vrednog čoveka donose obilje,
\q2 a svakog nagla siromaštvo.
\q1 
\v 6 Blago sabrano jezikom lažljivim taština je
\q2 koja prolazi među one koji traže smrt.
\q1 
\v 7 Grabež bezbožnih odneće ih,
\q2 jer ne hteše činiti što je pravo.
\q1 
\v 8 Čiji je put kriv, on je tuđ;
\q2 a ko je čist, njegovo je delo pravo.
\q1 
\v 9 Bolje je sedeti u uglu od krova
\q2 nego sa ženom svadljivom u kući zajedničkoj.
\q1 
\v 10 Duša bezbožnikova želi zlo,
\q2 ni prijatelj njegov ne nalazi milosti u njega.
\q1 
\v 11 Kad podsmevač biva karan, ludi mudra;
\q2 i kad se mudri poučava, prima znanje.
\q1 
\v 12 Uči se pravednik od kuće bezbožnikove,
\q2 kad se bezbožnici obaraju u zlo.
\q1 
\v 13 Ko zatiskuje uho svoje od vike ubogog, vikaće i sam,
\q2 ali neće biti uslišen.
\q1 
\v 14 Dar u tajnosti utišava gnev
\q2 i poklon u nedrima žestoku srdnju.
\q1 
\v 15 Radost je pravedniku činiti što je pravo,
\q2 a strah onima koji čine bezakonje.
\q1 
\v 16 Čovek koji zađe s puta mudrosti
\q2 počinuće u zboru mrtvih.
\q1 
\v 17 Ko ljubi veselje, biće siromah;
\q2 ko ljubi vino i ulje, neće se obogatiti.
\q1 
\v 18 Otkup za pravednike biće bezbožnik
\q2 i za dobre bezakonik.
\q1 
\v 19 Bolje je živeti u zemlji pustoj
\q2 nego sa ženom svadljivom i gnevljivom.
\q1 
\v 20 Dragoceno je blago i ulje u stanu mudroga,
\q2 a čovek bezuman proždire ga.
\q1 
\v 21 Ko ide za pravdom i milošću,
\q2 naći će život, pravdu i slavu.
\q1 
\v 22 U grad jakih ulazi mudri,
\q2 i obara silu u koju se uzdaju.
\q1 
\v 23 Ko čuva usta svoja i jezik svoj,
\q2 čuva dušu svoju od nevolja.
\q1 
\v 24 Ponositom i obesnom ime je podsmevač,
\q2 koji sve radi besno i oholo.
\q1 
\v 25 Lenjivca ubija želja,
\q2 jer ruke njegove neće da rade;
\q1 
\v 26 Svaki dan želi;
\q2 a pravednik daje i ne štedi.
\q1 
\v 27 Žrtva je bezbožnička gad,
\q2 a kamoli kad je prinose u grehu?
\q1 
\v 28 Lažni svedok poginuće,
\q2 a čovek koji sluša govoriće svagda.
\q1 
\v 29 Bezbožnik je bezobrazan,
\q2 a pravednik udešava svoje pute.
\q1 
\v 30 Nema mudrosti ni razuma ni saveta nasuprot Bogu.
\q1 
\v 31 Konj se oprema za dan boja,
\q2 ali je u Gospoda spasenje.
\c 22
\s1 O dobrom imenu – kako se stiče i gubi.
\q1 
\v 1 Bolje je ime nego veliko bogatstvo,
\q2 i milost je bolja nego srebro i zlato.
\q1 
\v 2 Bogat i siromah sretaju se;
\q2 obojicu je Gospod stvorio.
\q1 
\v 3 Pametan čovek vidi zlo i skloni se,
\q2 a ludi idu dalje i plaćaju.
\q1 
\v 4 Smernosti i strahu Gospodnjem
\q2 plata je bogatstvo i slava i život.
\q1 
\v 5 Trnje i zamke su na putu opakoga;
\q2 ko čuva dušu svoju, biće daleko od toga.
\q1 
\v 6 Uči dete prema putu kojim će ići,
\q2 pa neće odstupiti od njega ni kad ostari.
\q1 
\v 7 Bogat gospodari nad siromasima,
\q2 i ko uzima u zajam biva sluga onome koji daje.
\q1 
\v 8 Ko seje bezakonje žeće muku,
\q2 i prut gneva njegovog nestaće.
\q1 
\v 9 Blago oko biće blagosloveno,
\q2 jer daje hleba svog ubogom.
\q1 
\v 10 Oteraj podsmevača, i otići će raspra
\q2 i prestaće svađa i sramota.
\q1 
\v 11 Ko ljubi čisto srce, i čije su usne ljubazne,
\q2 njemu je car prijatelj.
\q1 
\v 12 Oči Gospodnje čuvaju znanje,
\q2 a poslove bezakonikove obara.
\q1 
\v 13 Lenivac govori:
\q2 Lav je napolju; nasred ulice poginuo bih.
\q1 
\v 14 Usta su tuđih žena jama duboka;
\q2 na koga se gnevi Gospod onamo će pasti.
\q1 
\v 15 Bezumlje je privezano detetu na srce;
\q2 prut kojim se kara ukloniće ga od njega.
\q1 
\v 16 Ko čini krivo siromahu da umnoži svoje, i ko daje bogatome,
\q2 zacelo će osiromašiti.
\b
\q1 
\v 17 Prigni uho svoje i slušaj reči mudrih ljudi,
\q2 i srce svoje privij k nauci mojoj.
\q1 
\v 18 Jer će ti biti milina ako ih složiš u srce svoje,
\q2 ako sve budu poređane na usnama tvojim.
\q1 
\v 19 Da bi ti uzdanje bilo u Gospoda, kazujem ti ovo danas,
\q2 a ti tako čini.
\q1 
\v 20 Nisam li ti napisao znamenite stvari za savete i znanje,
\q1 
\v 21 Da bih ti pokazao tvrđu istinitih reči
\q2 da bi mogao istinitim rečima odgovarati onima koji pošalju k tebi?
\b
\q1 
\v 22 Ne otimaj siromahu zato što je siromah,
\q2 i ne zatiri nevoljnoga na vratima.
\q1 
\v 23 Jer će Gospod braniti njihovu stvar,
\q2 i oteće dušu onima koji njima otimaju.
\q1 
\v 24 Ne druži se s čovekom gnevljivim
\q2 i ne idi sa žestokim,
\q1 
\v 25 Da se ne bi navikao na puteve njegove
\q2 i metnuo zamke na dušu svoju.
\q1 
\v 26 Ne budi od onih koji ruku daju,
\q2 koji se jamče za dugove.
\q1 
\v 27 Ako nemaš čim platiti,
\q2 zašto da se odnese postelja ispod tebe?
\q1 
\v 28 Ne pomiči stare međe,
\q2 koju su postavili oci tvoji.
\q1 
\v 29 Jesi li video čoveka ustaoca na poslu?
\q2 Takvi će pred carevima stajati,
\q2 a neće stajati pred prostacima.
\c 23
\s1 Pouke o mudrosti u životu i o pobožnosti.
\q1 
\v 1 Kad sedneš da jedeš s gospodinom,
\q2 pazi dobro šta je pred tobom.
\q1 
\v 2 Inače bi saterao sebi nož u grlo,
\q2 ako bi bio lakom.
\q1 
\v 3 Ne želi preslačke njegove,
\q2 jer su lažna hrana.
\q1 
\v 4 Ne muči se da se obogatiš,
\q2 i prođi se svoje mudrosti.
\q1 
\v 5 Hoćeš li baciti oči svoje na ono čega brzo nestaje?
\q2 Jer načini sebi krila i kao orao odleti u nebo.
\q1 
\v 6 Ne jedi hleba u zavidljivca,
\q2 i ne želi preslačaka njegovih.
\q1 
\v 7 Jer kako on tebe ceni u duši svojoj tako ti jelo njegovo.
\q2 Govoriće ti: Jedi i pij; ali srce njegovo nije s tobom.
\q1 
\v 8 Zalogaj što pojedeš izbljuvaćeš,
\q2 i izgubićeš ljubazne reči svoje.
\q1 
\v 9 Pred bezumnim ne govori,
\q2 jer neće mariti za mudrost besede tvoje.
\q1 
\v 10 Ne pomiči stare međe,
\q2 i ne stupaj na njivu siročadi.
\q1 
\v 11 Jer je jak osvetnik njihov;
\q2 braniće stvar njihovu od tebe.
\q1 
\v 12 Obrati k nauci srce svoje
\q2 i uši svoje k rečima mudrim.
\q1 
\v 13 Ne uskraćuj kar detetu;
\q2 kad ga biješ prutom, neće umreti.
\q1 
\v 14 Ti ga bij prutom,
\q2 i dušu ćeš mu izbaviti iz pakla.
\q1 
\v 15 Sine moj, ako bude mudro srce tvoje,
\q2 veseliće se srce moje u meni;
\q1 
\v 16 I igraće bubrezi moji
\q2 kad usne tvoje stanu govoriti što je pravo.
\q1 
\v 17 Srce tvoje neka ne zavidi grešnicima,
\q2 nego budi u strahu Gospodnjem uvek.
\q1 
\v 18 Jer ima plata,
\q2 i nadanje tvoje neće se zatrti.
\b
\q1 
\v 19 Slušaj, sine moj, i budi mudar
\q2 i upravi putem srce svoje.
\q1 
\v 20 Ne budi među pijanicama ni među izjelicama.
\q1 
\v 21 Jer pijanica i izjelica osiromašiće,
\q2 i spavač hodiće u ritama.
\b
\q1 
\v 22 Slušaj oca svog koji te je rodio,
\q2 i ne preziri matere svoje kad ostari.
\q1 
\v 23 Kupuj istinu i ne prodaji je;
\q2 kupuj mudrost, znanje i razum.
\q1 
\v 24 Veoma se raduje otac pravednikov,
\q2 i roditelj mudroga veseli se s njega.
\q1 
\v 25 Neka se, dakle, veseli otac tvoj i mati tvoja,
\q2 i neka se raduje roditeljka tvoja.
\b
\q1 
\v 26 Sine moj, daj mi srce svoje,
\q2 i oči tvoje neka paze na moje pute.
\q1 
\v 27 Jer je kurva duboka jama,
\q2 a tesan studenac tuđa žena.
\q1 
\v 28 Ona i zaseda kao lupež
\q2 i umnožava zločince među ljudima.
\b
\q1 
\v 29 Kome: Jaoh? Kome: Kuku?
\q2 Kome svađa? Kome vika?
\q1 Kome rane nizašta?
\q2 Kome crven u očima?
\q1 
\v 30 Koji sede kod vina,
\q2 koji idu te traže rastvoreno vino.
\q1 
\v 31 Ne gledaj na vino kad se rumeni,
\q2 kad u čaši pokazuje lice svoje i upravo iskače.
\q1 
\v 32 Na posledak će kao zmija ujesti
\q2 i kao aspida upeći.
\q1 
\v 33 Oči će tvoje gledati na tuđe žene,
\q2 i srce će tvoje govoriti opačine.
\q1 
\v 34 I bićeš kao onaj koji leži usred mora
\q2 i kao onaj koji spava povrh jedra.
\q1 
\v 35 Reći ćeš: Izbiše me, ali me ne zabole;
\q2 tukoše me, ali ne osetih;
\q1 kad se probudim, ići ću opet da tražim to.
\c 24
\s1 Opomene da budemo strpljivi i pomirljivi.
\q1 
\v 1 Ne zavidi zlim ljudima
\q2 niti želi da si s njima.
\q1 
\v 2 Jer o pogibli misli srce njihovo
\q2 i usne njihove govore o muci.
\b
\q1 
\v 3 Mudrošću se zida kuća
\q2 i razumom utvrđuje se.
\q1 
\v 4 I znanjem se pune kleti svakog blaga i dragocena i mila.
\q1 
\v 5 Mudar je čovek jak,
\q2 i razuman je čovek silan snagom.
\q1 
\v 6 Jer mudrim savetom ratovaćeš,
\q2 i izbavljenje je u mnoštvu savetnika.
\q1 
\v 7 Visoke su bezumnome mudrosti;
\q2 neće otvoriti usta svojih na vratima.
\b
\q1 
\v 8 Ko misli zlo činiti
\q2 zvaće se zlikovac.
\q1 
\v 9 Misao bezumnikova greh je,
\q2 i podsmevač je gad ljudski.
\b
\q1 
\v 10 Ako kloneš u nevolji,
\q2 skratiće ti se sila.
\q1 
\v 11 Izbavljaj pohvatane na smrt;
\q2 i koje hoće da pogube,
\q2 nemoj se ustegnuti od njih.
\q1 
\v 12 Ako li kažeš: Gle, nismo znali za to;
\q2 neće li razumeti Onaj koji ispituje srca,
\q1 i koji čuva dušu tvoju neće li doznati
\q2 i platiti svakome po delima njegovim?
\b
\q1 
\v 13 Sine moj, jedi med, jer je dobar,
\q2 i saće, jer je slatko grlu tvom.
\q1 
\v 14 Tako će biti poznanje mudrosti duši tvojoj, kad je nađeš;
\q2 i biće plata, i nadanje tvoje neće se zatrti.
\b
\q1 
\v 15 Bezbožniče, ne vrebaj oko stana pravednikovog,
\q2 i ne kvari mu počivanje.
\q1 
\v 16 Jer ako i sedam puta padne pravednik, opet ustane,
\q2 a bezbožnici propadaju u zlu.
\b
\q1 
\v 17 Kad padne neprijatelj tvoj, nemoj se radovati,
\q2 i kad propadne, neka ne igra srce tvoje.
\q1 
\v 18 Jer bi video Gospod i ne bi Mu bilo milo,
\q2 i obratio bi gnev svoj od njega na tebe.
\b
\q1 
\v 19 Nemoj se žestiti radi nevaljalaca,
\q2 nemoj zavideti bezbožnicima.
\q1 
\v 20 Jer nema plate nevaljalcu,
\q2 žižak će se bezbožnicima ugasiti.
\b
\q1 
\v 21 Boj se Gospoda, sine moj, i cara,
\q2 i ne mešaj se s nemirnicima.
\q1 
\v 22 Jer će se ujedanput podignuti pogibao njihova,
\q2 a ko zna propast koja ide od obojice?
\b
\p 
\v 23 I ovo je za mudrace:
\b
\q1 Gledati ko je ko na sudu nije dobro.
\q1 
\v 24 Ko govori bezbožniku: Pravedan si,
\q2 njega će proklinjati ljudi i mrziće na nj narodi.
\q1 
\v 25 A koji ga karaju, oni će biti mili,
\q2 i doći će na njih blagoslov dobrih.
\q1 
\v 26 Ko govori reči istinite,
\q2 u usta ljubi.
\b
\q1 
\v 27 Uredi svoj posao na polju,
\q2 i svrši svoje na njivi,
\q2 potom i kuću svoju zidaj.
\b
\q1 
\v 28 Ne budi svedok na bližnjeg svog bez razloga,
\q2 i ne varaj usnama svojim.
\q1 
\v 29 Ne govori: Kako je on meni učinio tako ću ja njemu učiniti;
\q2 platiću ovom čoveku po delu njegovom.
\b
\q1 
\v 30 Iđah mimo njive čoveka lenjog
\q2 i mimo vinograda čoveka bezumnog;
\q1 
\v 31 I gle, beše sve zaraslo u trnje i sve pokrio čkalj,
\q2 i ograda im kamena razvaljena.
\q1 
\v 32 I videvši uzeh na um,
\q2 i gledah i poučih se.
\q1 
\v 33 Dok malo prospavaš, dok malo prodremlješ,
\q2 dok malo sklopiš ruke da počineš,
\q1 
\v 34 U tom će doći siromaštvo tvoje kao putnik,
\q2 i oskudica tvoja kao oružan čovek.
\c 25
\s1 Prava je slava biti nagrađen mudrošću.
\p 
\v 1 I ovo su priče Solomunove koje sabraše ljudi Jezekije cara Judinog.
\b
\q1 
\v 2 Slava je Božija skrivati stvar,
\q2 a slava je carska istraživati stvar.
\q1 
\v 3 Visina nebu i dubina zemlji i srce carevima
\q2 ne može se dosegnuti.
\q1 
\v 4 Uzmi od srebra trosku,
\q2 i izaći će livcu zaklad.
\q1 
\v 5 Uzmi bezbožnika ispred cara,
\q2 i utvrdiće se pravdom presto njegov.
\q1 
\v 6 Ne veličaj se pred carem
\q2 i ne staj na mesto gde stoje vlastelji.
\q1 
\v 7 Jer je bolje da ti se kaže: Hodi gore,
\q2 nego da te ponize pred knezom da vidiš svojim očima.
\b
\q1 
\v 8 Ne idi odmah da se preš,
\q2 gledaj šta bi činio naposletku ako bi te osramotio bližnji tvoj.
\q1 
\v 9 Raspravi stvar svoju s bližnjim svojim,
\q2 ali tuđe tajne ne otkrivaj,
\q1 
\v 10 Da te ne bi psovao ko čuje,
\q2 i sramota tvoja da ne bi ostala na tebi.
\b
\q1 
\v 11 Zlatne jabuke u srebrnim sudima
\q2 jesu zgodne reči.
\q1 
\v 12 Zlatna je grivna i nakit od najboljeg zlata
\q2 mudri karač onome koji sluša.
\q1 
\v 13 Veran je poslanik kao studen snežna o žetvi onima koji ga pošalju,
\q2 i rashlađuje dušu svojim gospodarima.
\q1 
\v 14 Ko se hvali darom lažnim,
\q2 on je kao oblaci i vetar bez dažda.
\b
\q1 
\v 15 Strpljenjem se ublažava knez,
\q2 i mek jezik lomi kosti.
\q1 
\v 16 Kad nađeš med, jedi koliko ti je dosta,
\q2 da ne bi najedavši ga se izbljuvao ga.
\q1 
\v 17 Retko neka ti noga stupa u kuću bližnjeg tvog,
\q2 da ne bi nasitivši se tebe omrzao na te.
\q1 
\v 18 Ko god govori lažno svedočanstvo na bližnjeg svog,
\q2 on je kao malj i mač i oštra strela.
\q1 
\v 19 Uzdanje je u nevernika u nevolji
\q2 zub slomljen i noga uganuta.
\q1 
\v 20 Ko peva pesme žalosnom srcu,
\q2 on je kao onaj koji svlači haljinu na zimi,
\q2 i kao ocat na salitru.
\q1 
\v 21 Ako je gladan nenavidnik tvoj, nahrani ga hleba,
\q2 i ako je žedan napoj ga vode.
\q1 
\v 22 Jer ćeš živo ugljevlje zgrnuti na glavu njegovu,
\q2 i Gospod će ti platiti.
\q1 
\v 23 Severni vetar nosi dažd,
\q2 a potajni jezik lice srdito.
\q1 
\v 24 Bolje je sedeti u uglu od krova
\q2 nego sa ženom svadljivom u kući zajedničkoj.
\q1 
\v 25 Dobar je glas iz daleke zemlje
\q2 kao studena voda žednoj duši.
\q1 
\v 26 Pravednik koji pada pred bezbožnikom
\q2 jeste kao izvor nogama zamućen
\q2 i kao studenac pokvaren.
\q1 
\v 27 Jesti mnogo meda nije dobro,
\q2 i istraživati slavu nije slavno.
\q1 
\v 28 Ko nema vlasti nad duhom svojim,
\q2 on je grad razvaljen bez zidova.
\c 26
\s1 Bezumni, lenji i lažljivi ljudi nisu vredni nikakve časti.
\q1 
\v 1 Kao sneg u leto i dažd o žetvi,
\q2 tako ne dolikuje bezumnome čast.
\q1 
\v 2 Kao vrabac kad prhne i lasta kad odleti,
\q2 tako kletva nezaslužena neće doći.
\q1 
\v 3 Bič konju, uzda magarcu,
\q2 a batina bezumnicima na leđa.
\q1 
\v 4 Ne odgovaraj bezumniku po bezumlju njegovom,
\q2 da ne budeš i ti kao on.
\q1 
\v 5 Odgovori bezumniku prema bezumlju njegovom,
\q2 da ne misli da je mudar.
\q1 
\v 6 Ko šalje bezumnika da mu šta svrši,
\q2 on odseca sebi noge i pije nepravdu.
\q1 
\v 7 Kako hromi hramlje nogama svojim,
\q2 takva je beseda u ustima bezumnih.
\q1 
\v 8 Kao da baca dragi kamen u gomilu kamenja,
\q2 tako radi ko čini čast bezumnome.
\q1 
\v 9 Kao trn kad dođe u ruku pijanome,
\q2 takva je beseda u ustima bezumnih.
\q1 
\v 10 Mnogo muke zadaje svima
\q2 ko plaća bezumniku
\q2 i ko plaća prestupnicima.
\q1 
\v 11 Kao što se pas povraća na svoju bljuvotinu,
\q2 tako bezumnik ponavlja svoje bezumlje.
\q1 
\v 12 Jesi li video čoveka koji misli da je mudar?
\q2 Više ima nadanja od bezumnoga nego od njega.
\q1 
\v 13 Lenjivac govori:
\q2 Ljuti je lav na putu, lav je na ulicama.
\q1 
\v 14 Kao što se vrata obrću na čepovima svojim,
\q2 tako lenivac na postelji svojoj.
\q1 
\v 15 Lenivac krije ruku svoju u nedra,
\q2 teško mu je prineti je k ustima.
\q1 
\v 16 Lenivac misli da je mudriji od sedmorice koji odgovaraju razumno.
\q1 
\v 17 Psa za uši hvata
\q2 ko se prolazeći žesti za tuđu raspru.
\q1 
\v 18 Kakav je bezumnik koji baca iskre i strele smrtne,
\q1 
\v 19 Takav je svaki koji prevari bližnjeg svog
\q2 pa onda veli: Šalio sam se.
\q1 
\v 20 Kad nestane drva, ugasi se oganj;
\q2 tako kad nema opadača, prestaje raspra.
\q1 
\v 21 Ugalj je za žeravicu, drva za oganj,
\q2 a čovek svadljivac da raspaljuje svađu.
\q1 
\v 22 Reči su opadačeve kao reči izbijenih,
\q2 ali silaze unutra u trbuh.
\q1 
\v 23 Kao srebrna pena kojom se obloži crep,
\q2 takve su usne neprijateljske i zlo srce.
\q1 
\v 24 Nenavidnik se pretvara ustima svojim,
\q2 a u srcu slaže prevaru.
\q1 
\v 25 Kad govori umiljatim glasom, ne veruj mu,
\q2 jer mu je u srcu sedam gadova.
\q1 
\v 26 Mržnja se pokriva lukavstvom,
\q2 ali se zloća njena otkriva na zboru.
\q1 
\v 27 Ko jamu kopa, u nju će pasti;
\q2 i ko kamen valja, na njega će se prevaliti.
\q1 
\v 28 Jezik lažan mrzi na one koje satire,
\q2 i usta koja laskaju grade pogibao.
\c 27
\s1 Ne treba se hvaliti i biti osion.
\q1 
\v 1 Ne hvali se sutrašnjim danom,
\q2 jer ne znaš šta će dan doneti.
\q1 
\v 2 Neka te hvali drugi, a ne tvoja usta,
\q2 tuđin, a ne tvoje usne.
\q1 
\v 3 Težak je kamen, i pesak je težak;
\q2 ali je gnev bezumnikov teži od oboga.
\q1 
\v 4 Jarost je nemilostiva, i gnev je plah;
\q2 ali ko će odoleti zavisti?
\q1 
\v 5 Bolji je javni ukor nego tajna ljubav.
\q1 
\v 6 Udarci od prijatelja istiniti su,
\q2 a celivi nenavidnikovi lažni.
\q1 
\v 7 Duša sita gazi saće,
\q2 a gladnoj duši slatko je sve što je gorko.
\q1 
\v 8 Kakva je ptica koja odleti iz svog gnezda,
\q2 takav je čovek koji otide iz svog mesta.
\q1 
\v 9 Ulje i kad veseli srce,
\q2 tako je prijatelj sladak savetom srdačnim.
\q1 
\v 10 Ne ostavljaj prijatelja svog ni prijatelja oca svog,
\q2 i u kuću brata svog ne ulazi u nesreći svojoj:
\q2 bolji je sused blizu nego brat daleko.
\q1 
\v 11 Sine moj, budi mudar i obraduj srce moje,
\q2 da imam šta odgovoriti onome ko me ruži.
\q1 
\v 12 Pametan čovek vidi zlo i skloni se,
\q2 a ludi idu dalje i plaćaju.
\q1 
\v 13 Uzmi haljinu onome koji se podjemči za tuđina,
\q2 i uzmi zalog od njega za tuđinku.
\q1 
\v 14 Ko blagosilja prijatelja svog na glas rano ustajući,
\q2 primiće mu se za kletvu.
\q1 
\v 15 Neprestano kapanje kad je velik dažd,
\q2 i žena svadljiva,
\q2 jedno su;
\q1 
\v 16 Ko je ustavlja, ustavlja vetar,
\q2 i ona se odaje kao mirisavo ulje u desnici.
\q1 
\v 17 Gvožđe se gvožđem oštri,
\q2 tako čovek oštri lice prijatelja svog.
\q1 
\v 18 Ko čuva smokvu, ješće rod njen;
\q2 tako ko čuva gospodara svog, biće poštovan.
\q1 
\v 19 Kako je u vodi lice prema licu,
\q2 tako je srce čovečije prema čoveku.
\q1 
\v 20 Grob i propast nikada se ne mogu zasititi,
\q2 tako oči čovečije nikada nisu site.
\q1 
\v 21 Srebro u topionici i zlato u peći
\q2 a čovek u ustima onog koji ga hvali
\q2 poznaje se.
\q1 
\v 22 Da bezumnoga tucaš u stupi s tučkom s prekrupom,
\q2 ne bi otišlo od njega bezumlje njegovo.
\b
\q1 
\v 23 Dobro gledaj stoku svoju
\q2 i staraj se za stada svoja.
\q1 
\v 24 Jer bogatstvo ne traje doveka
\q2 niti kruna od kolena do kolena.
\q1 
\v 25 Kad trava naraste i pokaže se zelen,
\q2 kupi se trava po planinama.
\q1 
\v 26 Jaganjci su ti za odelo,
\q2 i jarići cena za njivu.
\q1 
\v 27 I dosta ima mleka kozjeg tebi za jelo,
\q2 i za jelo tvom domu
\q2 i za hranu tvojim devojkama.
\c 28
\s1 Blagoslovena je pobožnost i poštenje, prokleta bezbožnost.
\q1 
\v 1 Beže bezbožnici kad ih niko ne goni,
\q2 a pravednici su kao lavići bez straha.
\q1 
\v 2 Kad se u zemlji zla čine, nastaju joj mnogi knezovi;
\q2 ali kad se nađe čovek razuman i vešt, ostaje dugo.
\q1 
\v 3 Čovek siromah koji čini krivo ubogima
\q2 jeste kao silan dažd iza kog nestaje hleba.
\q1 
\v 4 Koji ostavljaju zakon, hvale bezbožnike;
\q2 a koji drže zakon, protive im se.
\q1 
\v 5 Zli ljudi ne razumeju šta je pravo;
\q2 a koji traže Gospoda, razumeju sve.
\q1 
\v 6 Bolji je siromah koji hodi u bezazlenosti svojoj
\q2 nego ko ide krivim putevima ako je i bogat.
\q1 
\v 7 Ko čuva zakon, sin je razuman;
\q2 a ko se druži s izjelicama, sramoti oca svog.
\q1 
\v 8 Ko umnožava dobro svoje ujmom i pridavkom,
\q2 sabira onome koji će razdavati siromasima.
\q1 
\v 9 Ko odvraća uho svoje da ne čuje zakon,
\q2 i molitva je njegova mrska.
\q1 
\v 10 Ko zavodi prave na zao put, pašće u jamu svoju,
\q2 a bezazleni naslediće dobro.
\q1 
\v 11 Bogat čovek misli da je mudar,
\q2 ali razuman siromah ispituje ga.
\q1 
\v 12 Kad se raduju pravedni, velika je slava;
\q2 a kad se podižu bezbožnici, traži se čovek.
\q1 
\v 13 Ko krije prestupe svoje, neće biti srećan;
\q2 a ko priznaje i ostavlja, dobiće milost.
\q1 
\v 14 Blago čoveku koji se svagda boji;
\q2 a ko je tvrdoglav, upada u zlo.
\q1 
\v 15 Bezbožnik koji vlada narodom siromašnim,
\q2 lav je koji riče i medved gladan.
\q1 
\v 16 Knez bez razuma čini mnogo nepravde,
\q2 a koji mrzi na lakomstvo, živeće dugo.
\q1 
\v 17 Čovek koji čini nasilje krvi ljudskoj,
\q2 bežaće do groba, a niko ga neće zadržati.
\q1 
\v 18 Ko hodi u bezazlenosti, spašće se;
\q2 a ko je opak na putevima, pašće u jedan mah.
\q1 
\v 19 Ko radi svoju zemlju, biće sit hleba;
\q2 a ko ide za besposlicama, nasitiće se sirotinje.
\q1 
\v 20 Čovek veran obiluje blagoslovima;
\q2 a ko nagli da se obogati, neće biti bez krivice.
\q1 
\v 21 Nije dobro gledati ko je ko,
\q2 jer za zalogaj hleba čovek će učiniti zlo.
\q1 
\v 22 Nagli da se obogati čovek zavidljiv,
\q2 a ne zna da će mu doći siromaštvo.
\q1 
\v 23 Ko ukorava čoveka naći će posle veću milost
\q2 nego koji laska jezikom.
\q1 
\v 24 Ko krade oca svog i mater svoju,
\q2 i govori: Nije greh,
\q2 on je drug krvniku.
\q1 
\v 25 Oholi zameće svađu;
\q2 a ko se uzda u Gospoda, izobilovaće.
\q1 
\v 26 Ko se uzda u svoje srce, bezuman je;
\q2 a ko hodi mudro, izbaviće se.
\q1 
\v 27 Ko daje siromahu, neće mu nedostajati;
\q2 a ko odvraća oči svoje, biće mu mnogo kletava.
\q1 
\v 28 Kad se podižu bezbožnici, sakriva se čovek;
\q2 a kad ginu, umnožavaju se pravedni.
\c 29
\s1 Mudrost donosi blagoslov, a bezumlje i grehovi propast.
\q1 
\v 1 Čovek koji po karanju ostaje tvrdoglav,
\q2 ujedanput će propasti, da neće biti leka.
\q1 
\v 2 Kad se umnožavaju pravednici, veseli se narod;
\q2 a kad vlada bezbožnik, uzdiše narod.
\q1 
\v 3 Ko ljubi mudrost, veseli oca svog;
\q2 a ko se druži s kurvama, rasipa svoje dobro.
\q1 
\v 4 Car pravdom podiže zemlju;
\q2 a ko uzima mito, satire je.
\q1 
\v 5 Ko laska prijatelju svom,
\q2 razapinje mrežu nogama njegovim.
\q1 
\v 6 U grehu je zlog čoveka zamka,
\q2 a pravednik peva i veseli se.
\q1 
\v 7 Pravednik razume parbu nevoljnih,
\q2 a bezbožnik ne mari da zna.
\q1 
\v 8 Podsmevači raspaljuju grad,
\q2 a mudri utišavaju gnev.
\q1 
\v 9 Mudar čovek kad se pre s ludim,
\q2 ili se srdio ili smejao,
\q2 nema mira.
\q1 
\v 10 Krvopije mrze na bezazlenoga,
\q2 a pravi se brinu za dušu njegovu.
\q1 
\v 11 Sav gnev svoj izliva bezumnik,
\q2 a mudri ustavlja ga natrag.
\q1 
\v 12 Koji knez sluša lažne reči,
\q2 sve su mu sluge bezbožne.
\q1 
\v 13 Siromah i koji daje na dobit sretaju se;
\q2 obojici Gospod prosvetljuje oči.
\q1 
\v 14 Koji car pravo sudi siromasima,
\q2 njegov će presto stajati doveka.
\q1 
\v 15 Prut i kar daju mudrost,
\q2 a dete pusto sramoti mater svoju.
\q1 
\v 16 Kad se umnožavaju bezbožnici, umnožavaju se gresi,
\q2 a pravednici će videti propast njihovu.
\q1 
\v 17 Karaj sina svog, i smiriće te,
\q2 i učiniće milinu duši tvojoj.
\q1 
\v 18 Kad nema utvare, rasipa se narod;
\q2 a ko drži zakon, blago njemu!
\q1 
\v 19 Rečima se ne popravlja sluga,
\q2 jer ako i razume, opet ne sluša.
\q1 
\v 20 Jesi li video čoveka naglog u besedi svojoj?
\q2 Više ima nadanja od bezumnog nego od njega.
\q1 
\v 21 Ako ko mazi slugu od malena,
\q2 on će najposle biti sin.
\q1 
\v 22 Gnevljiv čovek zameće svađu,
\q2 i ko je naprasit, mnogo greši.
\q1 
\v 23 Oholost ponižuje čoveka,
\q2 a ko je smeran duhom, dobija slavu.
\q1 
\v 24 Ko deli s lupežem, mrzi na svoju dušu,
\q2 čuje prokletstvo i ne prokazuje.
\q1 
\v 25 Strašljiv čovek meće sebi zamku;
\q2 a ko se u Gospoda uzda, biće u visokom zaklonu.
\q1 
\v 26 Mnogi traže lice vladaočevo,
\q2 ali je od Gospoda sud svakome.
\q1 
\v 27 Pravednima je mrzak nepravednik,
\q2 a bezbožniku je mrzak ko pravo hodi.
\c 30
\s1 Agurova ispovest.
\p 
\v 1 Reči Agura sina Jakejevog; sabrane reči tog čoveka Itilu, Itilu i Ukalu.
\b
\q1 
\v 2 Ja sam luđi od svakog,
\q2 i razuma čovečijeg nema u mene.
\q1 
\v 3 Niti sam učio mudrost
\q2 niti znam svete stvari.
\q1 
\v 4 Ko je izašao na nebo i opet sišao?
\q2 Ko je skupio vetar u pregršti svoje?
\q1 Ko je svezao vode u plašt svoj?
\q2 Ko je utvrdio sve krajeve zemlji?
\q1 Kako Mu je ime? I kako je ime Sinu Njegovom?
\q2 Znaš li?
\b
\q1 
\v 5 Sve su reči Božije čiste;
\q2 On je štit onima koji se uzdaju u Nj.
\q1 
\v 6 Ništa ne dodaj k rečima Njegovim,
\q2 da te ne ukori i ne nađeš se laža.
\b
\q1 
\v 7 Za dvoje molim Te;
\q2 nemoj me se oglušiti dok sam živ:
\q1 
\v 8 Taštinu i reč lažnu udalji od mene;
\q2 siromaštva ni bogatstva ne daj mi,
\q2 hrani me hlebom po obroku mom,
\q1 
\v 9 Da ne bih najedavši se odrekao se Tebe
\q2 i rekao: Ko je Gospod?
\q1 Ili osiromašivši da ne bih krao
\q2 i uzalud uzimao ime Boga svog.
\b
\q1 
\v 10 Ne opadaj sluge gospodaru njegovom,
\q2 da te ne bi kleo i ti bio kriv.
\b
\q1 
\v 11 Ima rod koji psuje oca svog
\q2 i ne blagosilja matere svoje.
\q1 
\v 12 Ima rod koji misli da je čist,
\q2 a od svog kala nije opran.
\q1 
\v 13 Ima rod koji drži visoko oči svoje,
\q2 i veđe mu se dižu uvis.
\q1 
\v 14 Ima rod kome su zubi mačevi
\q2 i kutnjaci noževi,
\q1 da proždire siromahe sa zemlje
\q2 i uboge između ljudi.
\b
\q1 
\v 15 Pijavica ima dve kćeri, koje govore: Daj, daj.
\q2 Ima troje nesito, i četvrto nikad ne kaže: Dosta:
\q1 
\v 16 Grob,
\q1 materica jalova,
\q1 zemlja koja ne biva sita vode,
\q1 i oganj, koji ne govori: Dosta.
\b
\q1 
\v 17 Oko koje se ruga ocu i neće da sluša matere,
\q2 kljuvaće ga gavrani s potoka i jesti orlići.
\b
\q1 
\v 18 Troje mi je čudesno, i četvrtog ne razumem:
\q1 
\v 19 Put orlov u nebo,
\q1 put zmijin po steni,
\q1 put lađin posred mora,
\q1 i put čovečiji k devojci.
\b
\q1 
\v 20 Takav je put kurvin: jede, i ubriše usta,
\q2 pa veli: Nisam učinila zla.
\b
\q1 
\v 21 Od troga se potresa zemlja,
\q2 i četvrtog ne može podneti:
\q1 
\v 22 Od sluge, kad postane car,
\q1 od bezumnika, kad se najede hleba.
\q1 
\v 23 Od puštenice, kad se uda,
\q1 od sluškinje kad nasledi gospođu svoju.
\b
\q1 
\v 24 Četvoro ima maleno na zemlji,
\q2 ali mudrije od mudraca:
\q1 
\v 25 Mravi, koji su slab narod,
\q2 ali opet pripravljaju u leto sebi hranu;
\q1 
\v 26 Pitomi zečevi, koji su nejak narod,
\q2 ali opet u kamenu grade sebi kuću;
\q1 
\v 27 Skakavci, koji nemaju cara,
\q2 ali opet idu svi jatom;
\q1 
\v 28 Pauk, koji rukama radi
\q2 i u carskim je dvorima.
\b
\q1 
\v 29 Troje lepo korača,
\q2 i četvrto lepo hodi:
\q1 
\v 30 Lav, najjači između zverova,
\q2 koji ne uzmiče ni pred kim,
\q1 
\v 31 Konj opasan po bedrima
\q1 ili jarac,
\q1 i car na koga niko ne ustaje.
\b
\q1 
\v 32 Ako si ludovao ponesavši se ili si zlo mislio,
\q2 metni ruku na usta.
\q1 
\v 33 Kad se razbija mleko, izlazi maslo;
\q2 i ko jako nos utire, izgoni krv;
\q2 tako ko draži na gnev, zameće svađu.
\c 31
\s1 Materine pouke jednome caru. Pohvala vrsnoj ženi.
\p 
\v 1 Reči cara Lemuila; sabrane reči, kojima ga je učila mati njegova.
\b
\q1 
\v 2 Šta, sine moj,
\q2 šta, sine utrobe moje,
\q2 i šta, sine zaveta mojih?
\q1 
\v 3 Ne daj krepost svoju ženama,
\q2 ni puteve svoje onima što satiru careve.
\q1 
\v 4 Nije za careve, Lemuilo, nije za careve da piju vino,
\q2 ni za knezove da piju silovito piće,
\q1 
\v 5 Da ne bi pijući zaboravio uredbe,
\q2 i izmenio pravicu kome nevoljniku.
\q1 
\v 6 Podajte silovito piće onome koji hoće da propadne,
\q2 i vino onima koji su tužnog srca;
\q1 
\v 7 Neka se napije i zaboravi svoje siromaštvo,
\q2 i da se više ne seća svoje muke.
\q1 
\v 8 Otvaraj usta svoja za nemoga,
\q2 za stvar svih namenjenih smrti.
\q1 
\v 9 Otvaraj usta svoja, sudi pravo,
\q2 daj pravicu nevoljnome i ubogome.
\b
\q1 
\v 10 Ko će naći vrsnu ženu?
\q2 Jer vredi više nego biser.
\q1 
\v 11 Oslanja se na nju srce muža njenog,
\q2 i dobitka neće nedostajati.
\q1 
\v 12 Čini mu dobro, a ne zlo,
\q2 svega veka svog.
\q1 
\v 13 Traži vune i lana,
\q2 i radi po volji rukama svojim.
\q1 
\v 14 Ona je kao lađa trgovačka,
\q2 iz daleka donosi hranu svoju.
\q1 
\v 15 Ustaje dok je još noć,
\q2 daje hranu čeljadi svojoj
\q2 i posao devojkama svojim.
\q1 
\v 16 Misli o njivi, i uzme je,
\q2 od rada ruku svojih sadi vinograd.
\q1 
\v 17 Opasuje snagom bedra svoja
\q2 i krepi mišice svoje.
\q1 
\v 18 Vidi kako joj je dobra radnja,
\q2 ne gasi joj se noću žižak.
\q1 
\v 19 Rukama svojim maša se preslice,
\q2 i prstima svojim drži vreteno.
\q1 
\v 20 Ruku svoju otvara siromahu,
\q2 i pruža ruke ubogome.
\q1 
\v 21 Ne boji se snega za svoju čeljad,
\q2 jer sva čeljad njena ima po dvoje haljine.
\q1 
\v 22 Pokrivače sama sebi gradi,
\q2 tanko platno i skerlet odelo joj je
\q1 
\v 23 Zna se muž njen na vratima
\q2 kad sedi sa starešinama zemaljskim.
\q1 
\v 24 Košulje gradi i prodaje,
\q2 i pojase daje trgovcu.
\q1 
\v 25 Odelo joj je krepost i lepota,
\q2 i osmeva se na vreme koje ide.
\q1 
\v 26 Usta svoja otvara mudro
\q2 i na jeziku joj je nauka blaga.
\q1 
\v 27 Pazi na vladanje čeljadi svoje,
\q2 i hleba u lenjosti ne jede.
\q1 
\v 28 Sinovi njeni podižu se i blagosiljaju je;
\q2 muž njen takođe hvali je;
\q1 
\v 29 Mnoge su žene bile vrsne,
\q2 ali ti ih nadvišuješ sve.
\q1 
\v 30 Ljupkost je prevarna i lepota tašta;
\q2 žena koja se boji Gospoda, ona zaslužuje pohvalu.
\q1 
\v 31 Podajte joj od ploda ruku njenih,
\q2 i neka je hvale na vratima dela njena. 
