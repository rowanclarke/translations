\id 1PE NT0021 Tsishingini (tsw) (Salka Kambari) KLP Feb. 2011 
\h 1 Bituru 
\toc1 Mepepelime mo Ufaru ma̱ Bituru 
\toc2 1 Bituru 
\toc3 1 Bit. 
\mt2 Mepepelime mo Ufaru ma̱ 
\mt1 Bituru 
\is1 Ucuɗuwu wa aatagada a nda 
\ip Bituru, vuma na ɗanai aatagada a nda, aajiya a ɗa a̱ da̱na̱i. U da̱na̱ ta̱ zuzu na̱ Yesu. We ene ta̱ cine Yesu sowoi a̱tsuma̱lima̱ ne esu a̱ yi. A̱tsuma̱ e mepepelime ma nda u yuwaan ta̱ a̱za̱ e Itoni a na a̱ ri ba̱ta̱ kokoꞌo adanshi adama a̱ a̱tsuma̱lima̱. 
\ip Bituru damma ta̱ a̱za̱ e Itoni a mantsa mo ndolo a na a yuwan ma̱za̱nga̱ adama a̱ a̱tsuma̱lima̱ a na oo sowuso. Ana wo oꞌwoi Yesu sowo ta̱ a̱tsuma̱lima̱ a̱tsuma̱ o uvaɗi u nda, ne ɗa fo a̱za̱ e Itoni a̱ yi na a ꞌyuwan a ciga o sowo cuꞌun va̱ a̱tsuma̱lima̱ o ndolo. A̱tsuma̱lima̱ a tsu zuwa ta̱ ucawu wo okolo a vuma a̱ da̱shi gbama. U damma le ta̱ isaꞌani ya̱ A̱sula̱ u to oɓolo ne ele a mantsa ma na oo sowuso a̱tsuma̱lima̱ o ndolo. 
\ip Anaꞌan a̱za̱ e Itoni o to sowuso fo a̱tsuma̱lima̱, waru ne ɗa, A̱sula̱ a̱ ta̱ na̱ a̱ɓula̱ hali anaꞌan n nda. Aatagada a nda a ca tsu ta̱ urevu adama a amayun a akiza a na aa kamba tsu na̱ tsoo sowuso a̱tsuma̱lima̱. Waru u damma tsu ta̱ ili i saꞌani ya̱ a̱bunda̱ i na tsaa yuwan a mantsa ma na tsu ri oo sowuso a̱tsuma̱lima̱ ko na̱ tsu ri a asuvu nden. 
\is1 Ili i na i ri pe a̱tsuma̱ a aatagada a nda 
\io1 1. Ica̱su na avasa (1:1-2) 
\io1 2. Adanshi a amayun adama o uzuwu wo okolo (1:3-12) 
\io1 3. Nden tsa ama a̱ A̱sula̱ a na a̱ ri na akiza (1:13–2:17) 
\io1 4. Iroci ya̱ a̱tsuma̱lima̱ e Yesu (2:18-25) 
\io1 5. Za vi Itoni na̱ a̱tsuma̱lima̱ (3:1–4:19) 
\io1 6. A̱sa̱la̱ adama a azagbain a̱za̱ a̱ a̱a̱ꞌisa̱ a̱za̱ e Itoni (5:1-11) 
\io1 7. Ica̱su yu ukosu (5:12-14) 
\c 1  
\p  
\v 1 A̱mu Bituru, aajiya e Yesu Kristi Zamawawa, a̱mu ɗa ma̱a̱ lyungusa̱a̱ ɗu mepepelime ma nda. N ta ɗanasaa ama a na A̱sula̱ a ɗangwai. Ele ɗa aza a na a̱ ri a̱ nden ana omocin a̱tsuma̱ e iɗa ya Pontu, na̱ Galatiya, na̱ Kafadokiya, na Asiya ni iɗa ya Bitiniya. 
\p  
\v 2 A̱sula̱ Dada u ɗangwa ɗu ta̱ ɗe nu ujimu waru Ruhu ka̱mbuwa̱ ɗu ta̱ aza a akiza. Adama o ndolo a ɗa i yuwain tsutoni na̱ Yesu Zamawawa, reve mpasa ma̱ yi mo oꞌwoto ɗu cece. N ta avasa i tsura̱ isaꞌani ya̱ A̱sula̱ na asuvu nden a̱ yi a wuma u ɗu na̱ a̱bunda̱ lon. 
\s1 A̱za̱ e Itoni a̱ da̱na̱ nu uzuwu wo okolo 
\p  
\v 3 Ica a̱ tyo uba̱ta̱ wa̱ A̱sula̱, Dada vu Zagbain tsu Yesu Zamawawa. A̱tsuma̱ e isaꞌani ya̱ a̱bunda̱ ya̱ yi i ɗa a matsisan ntsu. Adama o umatsun u saꞌavu u nda u ɗa tsu ri nu uzuwu wo okolo a na a̱ ri wuma, waru tsu tsura̱ yi ta̱ adama a na a̱ ꞌya̱sa̱in Yesu Zamawawa a̱tsuma̱ a̱ a̱kwa̱kwa̱.  
\v 4 Waru umatsun u saꞌavu u nda u ta̱wa̱a̱ tsu ta̱ na agadu a na a̱a̱ la̱nga̱ shi, waru za na ri cece agba woo kporo shi. A̱sula̱ a̱ tu uguzu na agadu a̱ ɗu ɗe zuva, agba waa lyawa ili i ro i juꞌwa̱n yi shi.  
\v 5 Adama o ndolo ni i ca A̱sula̱ okolo a̱ ɗu, ucira wa̱ yi waa lyawa ili i vama i juꞌwa̱n ɗu shi, hali she nu u roco iwawi a mantsa mo ukosu. Waru ama suru e te ene iwawi i nda. 
\p  
\v 6 Ili i nda amayun a ɗa, adama o ndolo i yuwan ma̱za̱nga̱ adama e le. Amma gogo i to sowo a̱tsuma̱lima̱ icuꞌun icuꞌun mantsa waꞌa.  
\v 7 A̱tsuma̱lima̱ꞌa̱ a̱ ta̱wa̱ ta̱ adama u roco ucawu wo okolo a̱ ɗu amayun a ɗa. Ucawu wo okolo a̱ ɗu ili ya̱ a̱ɓula̱ i ɗa u laꞌa ta̱ zinariya. Akina a ɗa o tsu lobonoto zinariya agba suru na̱ ne u tsu la̱nga̱ ta̱. A mantsa ma na koyan ɗa ee ene Yesu Zamawawa, i ta̱ tsura̱ ica, na̱ tsugbain, ni isaꞌani adama o ucawu wo okolo wa amayun a̱ ɗu.  
\v 8 I ciga ta̱ Zamawawa ko ana koto ye ene niyi shi. Ko na yee inda yi gogo shi, a̱vu gba i ca yi okolo. Waru ko gogo i ta̱ ma̱za̱nga̱ na̱ ma̱za̱nga̱ ma gbain ma na yaa gura cuɗuwa shi.  
\v 9 Adama a na i ca niyi okolo a̱ ɗu, i ta̱ ushi uneꞌe wi iwawi i wuma i ɗu. 
\p  
\v 10 Ama̱sula̱ a yuwan ta̱ adanshi cine A̱sula̱ oo roco ɗu isaꞌani ya̱ yi, reve a̱ bunga̱ ulobonu adama a̱ tsura̱ urevu wi iwawi i na A̱sula̱ aa ca ɗu.  
\v 11 Ruhu vu Zamawawa shi ta̱ a̱tsuma̱ e le, reve u yuwan adanshi a̱ a̱tsuma̱lima̱ a na Zamawawa oo sowo waru na̱ tsugbain tsa na wa̱a̱ tsura̱ na̱ a̱tsuma̱lima̱ o koto. Ama̱sula̱ꞌa̱ a̱ shi ta̱ a ciga e reve mantsa na̱ cine ili i nda yaa fara.  
\v 12 Reve A̱sula̱ o roco le aa yuwusan adanshi e ili i na yaa fara a mantsa me le shi, ili ya amayun i na a dammai adama a̱ ɗu a ɗa. Gogo nda A̱sula̱ a̱ lyungu ta̱ Ruhu va Akiza u kamba ama a mantsa ma na aa yuwusaan ɗu alajiya a Alabari a Saꞌani. Hali na̱ nlingata ma̱ A̱sula̱ fo n ciga ta̱ n reve ili i ndaꞌa. 
\s1 Nden ma akiza 
\p  
\v 13 Adama e ili i nda suru, i yuwan majiyan ma saꞌani, reve i guza̱ okolo a̱ ɗu. I yuwan majiyan ununa A̱sula̱ oo roco ɗu isaꞌani ya̱ yi a mantsa ma na Yesu Zamawawa a̱a̱ ka̱mba̱. Mantsa ma na i cuwain ni ili i ndolo suru, u ta ca ɗu uzuwu wo okolo.  
\v 14 I yuwaan A̱sula̱ tsutoni adama a na a̱ɗu muwun ma̱ yi n ɗa. She i ka̱mba̱ a̱ca̱pa̱ a yuwusan ili i wuya ununa i yuwain a wuma u ɗu ɗe a̱ca̱pa̱ wan. A mantsa mo ndolo i shi i reve ununa u lobonoi i yuwan shi.  
\v 15 A̱sula̱ a ɗangwa ɗu ta̱ adama yoo oꞌwo muwun ma̱ yi, adama o ndolo gogo ni i ciga i ꞌyuwan i da̱na̱ na akiza† a̱tsuma̱ e ili i na yaa yuwusan biti, ununa A̱sula̱ a̱ ri na akiza.  
\v 16 A̱sula̱ na aciya̱yi u damma ta̱, “Ni i ciga i ꞌyuwan yoo oꞌwo na akiza adama a na a̱mu za va akiza a ɗa.” \x ◊ \xo 1:16 \xt N.Gn. 11:44-45; N.Gn. 19:2; N.Gn. 20:7.\x* 
\p  
\v 17 I cuwan i ta yuwusan avasa e ekere a Dada za na ri zuva. A̱yi ɗa za vu ugeꞌetosu, agba u tsu laꞌa ciga za ro e ekere a za ro shi. U ta ca ɗu a̱tsuma̱lima̱ ko iliyinkapa adama e ili i na i yuwain. Adama o ndolo i ciga i ꞌyuwan i ca A̱sula̱ tsugbain a̱tsuma̱ a̱ nden n na yaa yuwusan pa o uvaɗi ana omocin.  
\v 18 I reve ta̱ A̱sula̱ a tsupa† ta̱ ili i gbain i ro adama u wawa ɗu diga o ure u vama u na nkaya n ɗu n lyawaa nɗu. Agba atsupu a na u tsupai ili i ɗa tsa zinariya ko azurufa, ili i na i tsu jima shi.  
\v 19 U tsupaa ɗu ta̱ na̱ mpasa ma̱ a̱ɓula̱ ma̱ Yesu Zamawawa. A̱yi ɗa Ma̱giriꞌi ma̱ A̱sula̱ ma na ma yuwain unusu shi suru suru, waru u ri na abasa shi, ko keꞌen.  
\v 20 A̱sula̱ a ɗangwa yi ta̱ adama o ndolo ɗe nu ujimu kafu a yuwan uvaɗi, gogo gba a rana vu ukosu u nda A̱sula̱ a̱ lyungu yi ta̱ o uvaɗi adama koyan ɗa ee ene yi. Waru A̱sula̱ a yuwan ta̱ ne adama a̱ ɗu.  
\v 21 Gogo nda, i ca A̱sula̱ okolo a̱ ɗu adama a Zamawawa. Waru adama a na A̱sula̱ a̱ ꞌya̱sa̱in Zamawawa a̱tsuma̱ a̱ a̱kwa̱kwa̱, a̱vu u ca yi tsugbain tsa gbain. I ta gura usu reve i zuwa okolo a̱ ɗu uba̱ta̱ wa̱ A̱sula̱ na amayun. 
\p  
\v 22 Gogo nda, i ta gura cigalai na̱ a̱za̱ a̱ ɗu na amayun ana ama o uꞌwa u ta̱. Adama a na a̱ za̱ꞌwa̱i okolo a̱ ɗu cece a mantsa ma na i usuyi Alabari a Saꞌani ili ya amayun i ɗa. Adama a nda ni i ciga i ꞌyuwan i cigalai lon, nu ucira u na u ri o okolo a̱ ɗu suru.  
\v 23 A̱sula̱ a zuwa ta̱ a matsisan ɗu. Wuma u saꞌavu u ɗu wu uta̱ uba̱ta̱ wa aza a na a matsan nɗu o uvaɗi shi. Adama a na wuma u na a ca nɗu u to koto o ukwa̱. A̱yi gba wuma u saꞌavu u nda u ri nu ukotu shi, adama a na wu uta̱ ta̱ a̱tsuma̱ a adanshi a wuma wa̱ A̱sula̱, agba adanshiꞌi u ri nu ukotu shi.  
\v 24 Ishaya vumava̱sula̱ ɗana ta̱: 
\q1 “Ama suru a̱ ta̱ tsa anlya tsa na tsa̱ tsu kuwushi, 
\q1 ulobonu u le waru u tsu kotushi ta̱ 
\q1 ununa vu revei ulobonu u yipa̱lu wo ogozo. 
\q1 Anlya a̱ tsu ꞌyewe ta̱ 
\q1 reve yipa̱lu yo oco e iɗa. \fig Anlya|src="1 Peter_1_24.tif" size="span" loc="1 Peter 1:24" ref="1 Bit. 1:24" \fig* 
\q1  
\v 25 Amma adanshi a Zagbain a̱ ri nu ukotu shi.” \x ◊ \xo 1:25 \xt Isha. 40:6-8.\x* 
\p Waru adanshi a Zagbaiꞌin a̱yi ɗa Alabari a Saꞌani a na tsu yuwain alajiya a̱ yi a̱ tyo ya̱ꞌa̱ ɗu. 
\c 2  
\p  
\v 1 Adama o ndolo ni i ciga i ꞌyuwan i lyawa unusu u na yaa yuwusan. I lyawa a̱ lulumusa̱ ama. I lyawa a dansa i ta̱ na̱ a̱ɓula̱ agba ne ɗa shi. She i tonoo tsushuꞌun wan, agba i lyawa adanshi e ili i na ya̱a̱ ɓa̱li ama o ro.  
\v 2-3 I ciga i ꞌyuwan i da̱na̱ a maluwa ma na yoo sowo maani ma akiza ma na ma̱ ri diga uba̱ta̱ wa̱ Ruhu, adama i kungwa nu ucira a̱tsuma̱ e iwawi i ɗu. I saala e izami ya adanshi a̱ A̱sula̱ ununa ba̱ba̱ tsu da̱na̱ e mesun ma maani, adama a na i peɗei isaꞌani yi Zagbain. 
\s1 Aatali a wuma 
\p  
\v 4 Yesu Zagbain a̱yi ɗa Aatali a wuma. Ama a ꞌyuwan yi ta̱, reve gba A̱sula̱ a ɗangwa yi reve u ciga yi lon.  
\v 5 Ne ɗa a̱ɗu waru i ri. A̱ɗu atali a wuma a ɗa aza a na A̱sula̱ aa yuwusaan ulinga u suwa uꞌwa a̱tsuma̱ o tsugono tsa̱ yi. Waru a̱ɗu oɓolo a nan ganu va akiza a ɗa, waru i ta ca kucci a̱tsuma̱ a̱ Ruhu, za na oo yoꞌonoto A̱sula̱ okolo a̱tsuma̱ e Yesu Zamawawa.  
\v 6 Adanshi a̱ A̱sula̱ a damma tsu ta̱: 
\q1 “Ka̱lyuwa̱i! N ta zuwusa aatali e ikyun yu ucira yu usaa a̱tsuma̱ a Sihiyona,† 
\q1 za na n ɗangwai, 
\q1 a̱yi ɗa macigata ma̱ va̱. 
\q1 Za na cayi vuma ndolo okolo, u te ene u nusan vuma na waa ca okolo shi.” \x ◊ \xo 2:6 \xt Isha. 28:16.\x* 
\q1  
\v 7 A̱yi macigata ma̱ ɗu ma ɗa, a̱ɗu aza a na i ushi niyi. Amma aza a na a ꞌyuwan niyi, 
\q1 “Aatali a na asuwi a ꞌyuwain 
\q1 a̱yi ɗa gba wo oꞌwoi aatali e ikyun yu ucira yu usaa.” \x ◊ \xo 2:7 \xt Ica 118:22.\x* 
\q1  
\v 8 Waru Adanshi a̱ A̱sula̱ a damma ta̱, 
\q1 “A̱yi ɗa aatali a na aa zuwusa ama uta̱ɗa̱tsa̱sa̱, 
\q1 aatali a na aa zuwa le a̱ riya̱.” \x ◊ \xo 2:8 \xt Isha. 8:14.\x* 
\p A̱ ta̱ ta̱ɗa̱tsa̱sa̱ adama a na o poloi atsuvu reve a̱ kuru Adanshi a̱ A̱sula̱ shi. Adama o ndolo reve a cina ili i na o foɓoo nle. 
\p  
\v 9 Amma a̱ɗu i ri tsa ama o ndolo shi, adama a na a̱ɗu elentsu a na A̱sula̱ a ɗangwai a ɗa. A̱ɗu oɓolo a nan ganu a ɗa aza a na aa yuwusaan A̱sula̱ tsugbashi ana Mogono, a̱ɗu ama a akiza a ɗa, waru a̱ɗu ama a̱ A̱sula̱ a ɗa. A̱sula̱ o uta̱a̱ ɗu ta̱ a̱tsuma̱ e irumbu a̱ tyo a̱tsuma̱ e ekan a gbain a saꞌani a̱ yi. Gogo nda ni i ciga i ꞌyuwan i damma linga va asalama na u yuwain suru. Adanshi a̱ A̱sula̱ a damma ta̱, 
\q1  
\v 10 “Ɗe a̱ca̱pa̱ i da̱na̱ ta̱ ama a na a̱ ri ne elentsu shi; 
\q1 gogo gba shi a̱ɗu ama a̱ A̱sula̱ ɗa. 
\q1 Ɗe a̱ca̱pa̱, i shi i tsura̱ iliyali ya̱ A̱sula̱ shi, 
\q1 gogo gba shi, i tsura̱ ta̱ iliyali ya̱ yi.” \x ◊ \xo 2:10 \xt Hos. 1:6; Hos. 1:9; Hos. 2:23.\x* 
\p  
\v 11 Ama a̱ va̱, a̱ɗu omocin a ɗa na aza a mabura o uvaɗi. Adama o ndolo n to ronuso ɗu atsuvu i suma icigi yi iwuya adama a na a̱ ta̱ nla̱ngi no okolo a amayun a̱ ɗu.  
\v 12 I yuwan ugbozu cine ya̱a̱ da̱nusu oɓolo na ama a̱ ɗu aza a na a̱ ri e itoni shi. Ko na aa dansa ne epen, a na i ta yuwusan ili i na i lobonoi shi, e te ene wuma u saꞌani u ɗu, reve a ca okolo e le a̱vu a ca A̱sula̱ tsugbain a mantsa ma na wa̱a̱ ta̱wa̱ adama o ugeꞌetosu wu uvaɗi. 
\s1 Tsutoni na azagbain 
\p  
\v 13 Zagbain ciga ɗu ta̱ i kuru azagbain a ama. I yuwan tsutoni na aza a na laꞌai tsugbain a̱tsuma̱ a ama,  
\v 14 waru oɓolo na azagbain a na u lyunguyi suru. I yuwan ne adama a na mogono ma̱ tsu lyungu le ta̱ adama a ca aza a na aa nususan a̱tsuma̱lima̱, waru reve a cuwa aza a na aa yuwusan ili i mejege. 
\p  
\v 15 A̱sula̱ a ciga ɗu ta̱ i yuwan ili i mejege. Ni i yuwan ne, i ta̱ ɓa̱ru na̱ va ama a na a yuwain adanshi e epen a aci a̱ ɗu pere m pere.  
\v 16 A̱ɗu agbashi a ɗa shi i ta̱ fa̱a̱n. Agba nden m babu tsugbashi tsa̱ ɗu u zuwa ɗu i yuwan iwuya shi. Ufa̱lu u na ya̱a̱ da̱nu ana agbashi a̱ A̱sula̱ a ɗa.  
\v 17 I ca koyan ɗa tsugbain, reve i roco icigi la̱nga̱ a̱ tyo e ekere a̱ a̱za̱ e Itoni. Yu uwwa wovon wa̱ A̱sula̱, a̱vu i ca mogono tsugbain. 
\p  
\v 18 Agbashi, ni i ciga i ꞌyuwan i yuwaan azagbain a̱ ɗu tsutoni, a̱vu i ca le tsugbain. I yuwaan ne aza a na a̱ ri na̱ a̱ɓula̱ waru a̱ ri na̱ majiyan me isaꞌani, waru agba ni i ciga i ꞌyuwan i yuwaan aza a na a̱ ri usuɗuwu.  
\v 19 A̱sula̱ a tsu yuwan ta̱ ma̱za̱nga̱ na̱ vuma kaɓa asuvu a̱ a̱tsuma̱lima̱ e iwuya i na wu ntsayi i sowo shi adama a na u revei A̱sula̱.  
\v 20 Agba na a faba ɗu adama o unusu, ya̱a̱ tsura̱ ili i ro pe shi. Amma A̱sula̱ a ta zuwaa ɗu abaꞌun na̱ wo oꞌwo i to sowo a̱tsuma̱lima̱ adama a na i yuwain ili i saꞌani.  
\v 21 Zamawawa a̱yi ɗa iroci i ɗu, waru u sowo ta̱ a̱tsuma̱lima̱ adama a̱ ɗu. I kuru ili i na u yuwain. A̱sula̱ e ɗe ɗu ta̱ adama i sowo a̱tsuma̱lima̱. Adanshi a̱ A̱sula̱ a damma ta̱: 
\q1  
\v 22 “Zamawawa nusan shi, 
\q1 waru wu luma̱ za shi.” \x ◊ \xo 2:22 \xt Isha. 53:9.\x* 
\p  
\v 23 Ana ama a uwai e isulusa yi, u tsupa le shi. Ana ama a ca niyi a̱tsuma̱lima̱ u damma she ne ele fo o sowo a̱tsuma̱lima̱ shi. A̱yi de u zuwa aciya̱yi e ekere a̱ A̱sula̱ za na tsu yuwan ugeꞌetosu mejege.  
\v 24 A̱yi na aciya̱yi u tanuyi unusu u tsu a̱ lipu va̱ yi ana u kuwa̱i a akpata,† adama a̱tsu tsu kakasai nu unusu u tsu, reve tso oꞌwo wuma adama tsu yuwain ili ya̱ a̱ɓula̱. Yo oꞌwo ta̱ gbaga adama a antsu a̱ yi!  
\v 25 I shi ta̱ e igaru tsi ikyon i na i puwa̱in. Agba gogo i ka̱mba̱ ta̱ uba̱ta̱ wu Za va Aguɓa ɗu, za na a̱a̱ ka̱lyuwusa̱ wuma u ɗu. 
\c 3  
\s1 Cine aa yuwan nden n lolo 
\p  
\v 1 A̱ɗu waru a̱ma̱ci, i kuru ali a̱ ɗu, ununa ya̱a̱ kuru Za va Aguɓa ɗu. Na ali o ro a ꞌyuwan a̱ ushi ikakaꞌa, nden n saꞌani ma̱ a̱ma̱ci n le n ta zuwa le a̱ usu upasu na adanshi a na aa yuwan.  
\v 2 A ta yuwan ne, ne e ene nden n saꞌani n na n lobonoi na yaa yuwusan. 
\p  
\v 3 She i yuwan mpolo n na yoo oꞌwo ulobonu e esu a ama wan. I damaton aciya̱ɗu adama a̱ a̱bunda̱ a maɗava ma̱ a̱nji ko ili i na a yuwain na̱ zinariya ko adama e itana yi ikebe lo wan.  
\v 4 Ana yaa yuwan ne, i lyawa e reve ɗu adama o ulobonu u na u ri o okolo a̱ ɗu. Ulobonu u nda a̱ tsu tsura̱ yi ta̱ o okolo a na a tarai aciya̱yi ili i ro shi. A̱sula̱ a tara yi ta̱ ili i saꞌani yu usokowu yo okolo a na u ri n koto shi.  
\v 5 Ne ɗa a̱ma̱ci a akiza ɗe a̱ca̱pa̱ o oꞌwotoi aciyele ulobonu. A ca ta̱ A̱sula̱ okolo e le, reve waru a ca ali e le tsugbain.  
\v 6 Iroci, Saratu† yuwan ta̱ tsutoni na̱ vali va̱ yi Ibrahim, ana u ɗe niyi zagbain va̱ yi. A̱ɗu esheli a̱ yi a ɗa ni i yuwan ili i na i ri mejege babu wovon wi ili i na yaa cina ɗu. 
\p  
\v 7 Ne ɗa waru, a̱ɗu ali ni i ciga i ꞌyuwan i kuru ben na̱ a̱ma̱ci a̱ ɗu. I guza̱ le nu urevu a̱tsuma̱ a̱ nden n ɗu oɓolo. I cuwan i laꞌa le ta̱ ucira. I cuwan ele fo a̱ ushi ta̱ uneꞌe u saꞌani wa̱ A̱sula̱ za na a̱yi ɗa wuma. I yuwan ne adama ko ili i ta̱ i geshe avasa a̱ ɗu wan. 
\s1 I yuwan nden n saꞌani va̱ni ɗu 
\p  
\v 8 Gogo gba, i yuwan nden n na n lobonoi va̱ni ɗu, reve ili i na i farai na̱ za ro a̱tsuma̱ a̱ ɗu i tara yi gashi ya̱ꞌa̱ ɗu ɗa, a̱vu i cigalai ana muwun ma̱ a̱na̱wu. I roco ama isaꞌani agba i tara aciya̱ɗu ili i ro wan.  
\v 9 Na̱ vuma ro yuwaan ɗu iwuya, she i ka̱mbuwa̱ yi ni iwuya wan. Waru na̱ za ro isula ɗu, she i tsupa wan. Amma i zuwaa le abaꞌun. I yuwan ne adama a na A̱sula̱ e ɗe ɗu ta̱ tsa̱ra̱ i zuwaa ozo o ro abaꞌun. Ne ɗa A̱sula̱ aa zuwaa ɗu abaꞌun fo.  
\v 10 Adanshi a̱ A̱sula̱ a damma ta̱: 
\q1 “Na̱ vuma ciga wuma u ma̱za̱nga̱ na̱ rana saꞌani, 
\q1 nu u ciga u ꞌyuwan u geshe eelentsu a̱ yi a adanshi a vama, 
\q1 waru nu u ciga u ꞌyuwan u geshe una̱ wa̱ yi a adanshi e epen. 
\q1  
\v 11 Nu u ciga u ꞌyuwan u lyawa mayan me iwuya, 
\q1 waru nu u ciga u ꞌyuwan u yuwan isaꞌani. 
\q1 Nu u ciga u ꞌyuwan u yuwan a̱tyo a na waa yuwan adama u yuwan nden n saꞌani na ama. 
\q1  
\v 12 Esu a̱ A̱sulazuva a̱ ta̱ ka̱lyuwusa̱ aza a na aa yuwusan isaꞌani, waru atsuvu a̱ yi a̱ tu ukpa̱tuꞌu na aa yuwusan avasa. Amma A̱sulazuva a tsu tawa ta̱ aza a na aa yuwusan iwuya esu.” \x ◊ \xo 3:12 \xt Ica 34:12-16.\x* 
\p  
\v 13-14 Zane ɗa ri lo aa yuwaan ɗu iwuya, ni i ri ufoɓu na yaa yuwaan le isaꞌani? Agba ko na aa ca ɗu a̱tsuma̱lima̱ adama o uyuwusan wi isaꞌani, she yu uwwa wovon wan, waru she u damaton ɗu wan. A̱sula̱ a ta ca ɗu iliyinkapa adama e isaꞌani i na yaa yuwusan.  
\v 15 Ana yaa damaton aciya̱ɗu, i yuwaan Zamawawa a̱ga̱nda̱ ana Zagbain. I ciga i ꞌyuwan i da̱na̱ ufoɓu u na yaa cuɗuwa za na ece nɗu, i damma ili i na i zuwai i ri nu uzuwu wo okolo.  
\v 16 Agba ni i ciga i ꞌyuwan i yuwan ne ben na̱ tsutoni. I lyawa asuvu a̱ ɗu a̱ da̱na̱ cece. Reve na ama a yuwan adanshi a vama a aci a̱ ɗu, a ta uwwa wono, ne e ene nden n saꞌani n na yaa yuwusan adama a na yoo tono Zamawawa. 
\p  
\v 17 Lyawa i yuwan isaꞌani reve i sowo a̱tsuma̱lima̱, na̱ A̱sula̱ a ciga ɗu i yuwan ne. Ni i sowo awuya adama e isaꞌani, u ta laꞌaa ɗu a na yoo sowo awuya adama e iwuya.  
\v 18 Zamawawa sowo ta̱ a̱tsuma̱lima̱ a mantsa ma na u kuwa̱i adama a̱ nusu tsu, agba u buwa a̱ da̱shi shi. U nusan shi ko keꞌen, amma u kuwa̱ ta̱ adama a̱ a̱za̱ o unusu adama u ta̱wa̱to tsu uba̱ta̱ wa̱ A̱sula̱. Lipu va̱ yi kuwa̱ ta̱, agba a̱ ka̱mba̱to yi ta̱ wuma a̱tsuma̱ a̱ Ruhu. 
\p  
\v 19 Reve u ꞌya̱wa̱ nu ucira u Ruhuꞌu u yuwaan a̱kwa̱kwa̱ a na a̱ ri wunlu o uꞌwa wa ali alajiya.  
\v 20 A̱kwa̱kwa̱ a ama a nda a ꞌyuwan ta̱ a yuwaan A̱sula̱ tsutoni diga a mantsa ma na Nuhu† yuwain wantsun. Agba A̱sula̱ a̱ shi ta̱ a yuwan ankuri ne ele. Ama kunla̱ ɗa a uwai a wantsuꞌun reve A̱sula̱ a wawa le a̱ mini ma gbain. 
\p  
\v 21 Mini ma gbaiꞌin iroci yu urumbusu u na waa wawusa ɗu ɗa gogo. Agba urumbusu adama a̱ wuza̱ꞌu wa̱ a̱shinda̱ a ɗa shi. U to rocosu uvadalasa uba̱ta̱ wa̱ A̱sula̱ na asuvu e cece, adama a na a̱ ꞌya̱sa̱in Yesu Zamawawa a̱tsuma̱ a̱ a̱kwa̱kwa̱.  
\v 22 Gogo Zamawawa ta̱ zuva, uba̱ta̱ u na u ri nden o ukere usaꞌani wa̱ A̱sula̱. Nlingata ma̱ A̱sula̱ suru oɓolo na̱ cuꞌun vo otoni a̱ lima̱ suru na a ciga a ꞌyuwan a yuwaan yi tsutoni. 
\c 4  
\s1 I yuwan ununa Zamawawa yuwain 
\p  
\v 1 Gogo nda, adama a na Zamawawa sowoi a̱tsuma̱lima̱ a̱ lipu va̱ yi, a̱ɗu fo i da̱na̱ ufoɓu u na yoo sowo a̱tsuma̱lima̱. Adama a na ni i usu i sowo a̱tsuma̱lima̱ adama a Zamawawa i ꞌyuwan ta̱ a yuwan unusu.  
\v 2 Adama o ndolo ne ɗa ya̱a̱ kuru ili i na lipu ɗu cigai shi, amma reve i yuwan ulinga na̱ wuma u ɗu i yuwan ili i na A̱sula̱ a cigai.  
\v 3 I tara ta̱ ɗe mantsa lon nu ujimu a yuwusan ili i na aza a na e revei A̱sula̱ shi aa yuwusan. I yuwusan ta̱ tsipere icuꞌun icuꞌun, i shi ta̱ i yuwan ili i wuya i na lipu cigai, i yuwan ta̱ ɗe oso na̱ a̱buki† a vanvama na̱ yisowishi ni itoni ya̱ a̱ma̱li i na A̱sula̱ a ꞌyuwain. 
\p  
\v 4 Akuci a̱ nꞌutsa̱ n ɗu a ta yuwan asalama a na i da̱shi ɓoloi aci ne ele a̱tsuma̱ a mayan me ili i vama shi. Hali gba a uwa a yuwusan adanshi a vama a aci a̱ ɗu adama o ndolo.  
\v 5 Agba na a ciga a ꞌyuwan a̱ usu za na ee geꞌeto koyan ɗa, aza a wuma na aza a na a̱ kuwa̱i ɗe.  
\v 6 Adama o ndolo a ɗa u yuwayin a̱kwa̱kwa̱ alajiya a Alabari a Saꞌani. Adama ko ne e geꞌeto le tsa akapi a ama a̱ lipu, u yuwaan le ta̱ ne tsa̱ra̱ a̱ tsura̱ mantsa ma na a vadala a yuwan wuma a̱tsuma̱ a̱ ruhu cuꞌun na A̱sula̱ a̱ ri na̱ a̱yi. 
\p  
\v 7 Aa jima shi ili biti i to koto. Adama o ndolo i voton ugbozu a̱vu i guza̱ aciya̱ɗu adama i gura yuwan avasa.  
\v 8 Ili i na i laꞌai a̱yi ɗa, i cigalai ni icigi ya amayun, adama a na icigi i tsu zuwa ta̱ i yuwan gafura vu nusu va̱ a̱bunda̱ a na a yuwaan nɗu.  
\v 9 Ni i ciga i ꞌyuwan i ka̱lyuwula̱i ulobonu babu adanshawuya. 
\p  
\v 10 A̱sula̱ a ca ta̱ koyan ɗa a̱tsuma̱ a̱ ɗu uneꞌe kokoꞌo. I yuwan ulinga ni ili i na A̱sula̱ a ca nɗu adama i roco isaꞌani† ya̱ A̱sula̱ a̱ tyo a ama.  
\v 11 Na̱ a̱vu za na tsu yuwan adanshi a ɗa, vu yuwan adanshi gashi A̱sula̱ na aciya̱yi a ɗa aa yuwusan adanshi na̱ a̱vu. Ne e ɗe wu ta̱ adama vu kamba ama, vu yuwan yi na̱ a̱tyo o ucira u na A̱sula̱ a ca nuwu. Adama e ili biti A̱sula̱ a̱ tsura̱ ica a̱tsuma̱ e Yesu Zamawawa. Tsugbain tsa̱ yi nu ucira wa̱ yi a̱ ri nu utyo shi. Ami. 
\s1 A̱tsuma̱lima̱ adama e itoni 
\p  
\v 12 Ama a̱ va̱, she i yuwan asalama wan na a ca ɗu a̱tsuma̱lima̱ gashi akina. She i yuwan majiyan gashi ili i ro i ɗa koꞌo wan.  
\v 13 Amma i yuwan ma̱za̱nga̱ adama a na i uwai a̱ a̱tsuma̱lima̱ a Zamawawa. Adama yo oꞌwo na̱ ma̱za̱nga̱ ma̱ a̱bunda̱ a mantsa ma na o rocoi tsugbain tsu Zamawawa.  
\v 14 Ne e isula ɗu adama a ala a Zamawawa, i ushi ta̱ abaꞌun, adama a na u roco ta̱ tsugbain tsa̱ Ruhu va̱ A̱sula̱ u to oɓolo na̱ a̱ɗu.  
\v 15 U lobono ta̱ i sowo awuya na̱ yu una vuma, ko i yuwan wivu, ko ili i vama i ro. Ne ɗa waru ni i damaton aciya̱ɗu ugondoru a̱tsuma̱ e ili ya ama o ro, u lobono ta̱ i sowo awuya.  
\v 16 Amma ni i sowo a̱tsuma̱lima̱ adama a na yo oꞌwoi a̱za̱ e Itoni, she yu uwwa wono wan. Amma i cuwa A̱sula̱ a na i ri na ala o ndolo. 
\p  
\v 17 Gogo nda mantsa ma ɗa a na A̱sula̱ aa fara ugeꞌetosu na ama o uꞌwa wa̱ yi neꞌen. Waru nu ugeꞌetosu u fara na̱ a̱tsu a̱za̱ e Itoni, cuꞌun vu ugeꞌetosu wu usuɗuwu u na waa yuwaan aza a na a ꞌyuwain a yuwan tsutoni na Alabari a Saꞌani a̱ yi?  
\v 18 Adanshi a̱ A̱sula̱ a damma ta̱, 
\q1 “Nu u ri usa̱n za va̱ a̱ɓula̱† tsura̱ iwawi, 
\q1 cine tsa ɗa woo oꞌwo e ekere a aza a na e revei A̱sula̱ shi, na̱ a̱za̱ o unusu?” \x ◊ \xo 4:18 \xt Udm. 11:31.\x* 
\p  
\v 19 Adanshi a nda suru a̱yi ɗa na̱ yoo sowuso a̱tsuma̱lima̱ ununa A̱sula̱ a zuwai, i lyuwa elime na̱ mayan me mejege, i ca okolo, A̱sula̱ za na yuwan nɗu u ta kamba ɗu. Amayun a ɗa wa̱a̱ kuɗa̱ a kamba ɗu shi. 
\c 5  
\s1 Uritosu adama a azagbain 
\p  
\v 1 Gogo gba, n ta yuwusan adanshi a̱ tyo a azagbain† a̱ a̱za̱ e Itoni. N ta patishi ɗu ana zagbain fo. A̱mu me ene ta̱ a̱tsuma̱lima̱ a na Zamawawa sowoi. Waru n ta̱ tsura̱ n uwa a̱tsuma̱ a tsugbain nu ucira wa̱ yi a mantsa ma na u ka̱mba̱i.  
\v 2 I ka̱lyuwa̱ ama a na A̱sula̱ a zuwai e ekere a̱ ɗu, ununa aza a aguɓa a̱ tsu ka̱lyuwusa̱ ikyon i le. I yuwan ne adama a na i cigai, agba she i yuwan adanshawuya wan. I yuwan ne adama a na yaa uwwusa uyoꞌo i yuwaan A̱sula̱ a̱ga̱nda̱. She i yuwan adama e ili yu uvaɗi i na ya̱a̱ tsura̱ wan.  
\v 3 She yo oꞌwoto aciya̱ɗu ana zagbain, a zuwusa ama mayan me ili wan, amma yo oꞌwoto aciya̱ɗu iroci yi ili i na i ri ulobonu.  
\v 4 Ne ɗa, na̱ Mogono ma Aguɓa ma̱a̱ ta̱wa̱, u ta ca ɗu iliyinkapa adama a na i ta uwa oɓolo na̱ a̱yi a̱tsuma̱ a tsugbain nu ucira wa̱ yi u na u ri nu ukotu shi. 
\s1 Muwun n yuwan tsutoni na̱ mbara 
\p  
\v 5 A̱ɗu olobo, i kuru mbara. Reve suru nɗu, i kambulai gashi agbashi a̱ A̱sula̱ a na a tarai aciyele ili i ro shi, adama a na, 
\q1 “A̱sula̱ a̱ ta̱ a̱ nla̱ngi na̱ za na tarai aciya̱yi ili i ro, 
\q1 agba u tsu ca ta̱ ama a na a tarai aciyele ili i ro shi isaꞌani ya̱ yi.” \x ◊ \xo 5:5 \xt Udm. 3:34.\x* 
\p  
\v 6 Adama o ndolo, i ka̱mbuwa̱ aciya̱ɗu za̱la̱ e ekere o ucira wa̱ A̱sula̱, reve na̱ mantsa ma na ma ntsayi ma̱ ta̱wa̱, a̱yi na aciya̱yi u ta̱ ꞌya̱sa̱n ɗu zuva.  
\v 7 I lyawaa A̱sula̱ ili i na yaa damatosun ɗu suru, adama a na u ta adama a̱ ɗu. 
\p  
\v 8 I da̱na̱ nu ugbozu kuci, waru i da̱na̱ ufoɓu. Mekerenkesu,† maꞌyuwatan ma̱ ɗu ma ɗa, waru u te igaru a yisaali ana kamu a zama za na wee reme a̱vu u tama. \fig Mekerenkesu e izami yi za na wa̱a̱ pusa̱n ana|src="1 Peter_5_8.tif" size="span" loc="1 Peter 5:8" ref="1 Bit. 5:8" \fig* 
\v 9 I da̱na̱ nu ucira a̱tsuma̱ e ili i na yoo tono, ne ɗa yaa ꞌyuwan yi nu ucira wa̱ A̱sula̱. I cuwan a̱za̱ e Itoni yi Zagbain uba̱ta̱ suru a̱tsuma̱ o uvaɗi a ta uwwusa cuꞌun va̱ a̱tsuma̱lima̱ꞌa̱. 
\p  
\v 10 Ni i sowo a̱tsuma̱lima̱ mantsa waꞌa, A̱sula̱ na aciya̱yi u ta lapula ili, reve u gbamato ɗu asuvu, a̱vu u shuwa̱ ɗu yi isawan nu ucira. U ta yuwan ne adama a na a̱yi za vi isaꞌani i ɗa kuci. U zuwa ɗu ta̱ fo i tsura̱ tsugbain tsa̱ yi babu ukotu adama a na u ɓolo nɗu na̱ Zamawawa.  
\v 11 A̱yi ɗa za tsugbain nu ucira u babu ukotu. Ami. 
\s1 Ica̱su 
\p  
\v 12 N tara ta̱ Sila ana mawun ma̱ a̱na̱wu, waru a̱yi ɗa za na maa ca asuvu. A̱yi ɗa u kamba numu ɗana mokoɗi me mepepelime ma nda. N ɗana ta̱ adama m gbamato ɗu asuvu, reve waru n damma ɗu isaꞌani i na A̱sula̱ a̱ ri na amayun, adama i lyuwa elime nu ucawu wo okolo a̱ ɗu ya̱ꞌa̱ yi.  
\v 13 A̱za̱ e Itoni a na a̱ ri Babila\f + \fr 5:13 \ft A̱yi “Babila”, a̱za̱ o urevu wa adanshi a̱ A̱sula̱ a ta dansa a na adanshi a̱ Roma ɗa a yuwusan.\f*† a̱ ta̱ ca̱sa̱sa̱ ɗu. A̱sula̱ a ɗangwa le ta̱ fo cine u ɗangwa nɗu. Mawun ma̱ va̱ Marku ta̱ ca̱sa̱sa̱ ɗu.  
\v 14 I ca̱sa̱la̱i ulobonu a̱tsuma̱ e icigi ya̱ a̱za̱ e Itoni. N ta avasa A̱sula̱ a ca za vi Itoni va̱ Yesu Zamawawa suru asuvu nden.