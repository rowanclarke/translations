\v 1 \w Samuel|strong="H8050"\w* \w tomó|strong="H3947"\w* \w la|strong="H5921"\w* vasija \w de|strong="H5921"\w* \w aceite|strong="H8081"\w* \w y|strong="H3588"\w* \w la|strong="H5921"\w* \w derramó|strong="H3332"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \add Saúl\add*. \w Lo|strong="H3808"\w* \w besó|strong="H5401"\w* \w y|strong="H3588"\w* \w le|strong="H5921"\w* dijo: ¿\w No|strong="H3808"\w* \w te|strong="H5921"\w* \w ungió|strong="H4886"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w para|strong="H5921"\w* \w que|strong="H3588"\w* seas \w jefe|strong="H7218"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w heredad|strong="H5159"\w*?
