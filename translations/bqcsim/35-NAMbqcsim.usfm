\id NAM Nahum in Boko, Ross Jones 2/08 
\h Nauũ 
\toc1 Nauũ 
\toc2 Nauũ 
\toc3 Nau 
\mt1 NAUŨ 
\imt1 Yã́ pↄ́ kú láɛ bee guuↄ 
\ip Láɛ́ bee dↄ̀aa à lɛ́lɛa Asili pↄ́ Isailiↄ lɛ́ falubↄnɛ́ↄ bùsu mɛɛwia Ninivawa yã'ò. Nauũ lápi kɛ̃̀ e Babiloniↄ aaↄ gɛ́ Niniva dúuzↄ̃i e wàↄ gɛ́ Yesu Kilisi ii wɛ̃̀ 612. 
\ip Lápi daalɛa (1.2-8) lɛ́ ↄlↄwɛ̃ɛ kɛ́ Lua mɛ́ iko vĩ dṹnia pↄ́piiwa mɛ́ ↄ̃mɛ a yã́kpalɛkɛ ń dṹniao. A gbɛa (1.9-2.3) lá Lua gbãapi a zĩkɛ bùsuↄ yã́ musu Nauũ gↄↄ. Niniva a kaalɛ, Yudaↄ i gↄ̃ ńzĩa vĩ. A gbɛa lↄ (2.4-3.19) Nauũ Niniva gbãa pↄ́ a vĩ midɛa dàu à sìuwɛ̃ɛ, àlɛ pↄnakɛò. 
\ip Ãnabipi yã́ pↄ́ àlɛ yá gbãa dɛ Niniva kaalɛa yã́a. Ninivaá mɛɛwia pↄ́ ĩ́andãa kↄ̃̀uɛ. A gbɛ̃́ↄá dàakɛn lalasideↄnɛ. Gbɛ̃́ bee taaↄ kaalɛ píiɛ. 
\c 1  
\s1 Dii pↄpaa Ninivadeↄzi 
\p  
\v 1 Niniva\f + \fr 1.1 \ft Sof 2.13-15\f* yã́ pↄ́ Ɛlekosi gbɛ̃́ Nauũ è taalan kɛ: 
\q1  
\v 2 Dii nↄ̀sɛ ì fɛlɛ à tↄsimá, 
\q1 Dii ì tↄsimá, pↄfɛ̃den aà ũ, 
\q1 Dii ì tↄsi a ibɛɛↄwa, 
\q1 ìↄ fɛ̃a a wɛ̀lɛↄzi. 
\q1  
\v 3 Dii pↄ lí pa kpaao, 
\q1 a gbãa vĩ zↄ̃ↄ, 
\q1 ìli tó tàaede bↄ̀ pão. 
\q1 Dii ku zàa'ĩana ń zàao guu, 
\q1 luabɛpuana dɛ aà kɛ̀sɛ luutɛ̃ ũ. 
\q1  
\v 4 Ì ísia lele, gugii i bↄ, 
\q1 ì to swa píi í ba, 
\q1 Basana ń Kaamɛlio i gↄ̃ wɛ̃nannↄ, 
\q1 Libã bùsu sɛdɛ lá bↄlↄↄ i giigaga. 
\q1  
\v 5 Gbɛ̀sĩsĩↄ ì deedee Dii aɛ, 
\q1 sĩ̀sĩↄ ì yↄ́, 
\q1 dṹnia ì lualua aà yã́i, 
\q1 tↄↄlɛ ń pↄ́ pↄ́ kuwàↄ píi. 
\q1  
\v 6 Démɛ a fↄ̃ gí aà kpɛ̃nɛmuuii? 
\q1 Démɛ a fↄ̃ àↄ zɛa 
\q1 aà pↄkũma pãsĩ bↄbↄmagↄↄi? 
\q1 Aà pↄfɛ̃ ì bↄ lán tɛ́waɛ, 
\q1 gbɛsiↄ i wi aà aɛ. 
\q1  
\v 7 Dii maa, 
\q1 a dɛ mikpakĩi ũ wɛ́tɛ̃agↄↄ, 
\q1 gbɛ̃́ pↄ́ nàaàziↄ ↄ̃ a ń yã́ dↄ̃. 
\q1  
\v 8 A a wɛ̀lɛↄ midɛ ń idaaguao, 
\q1 a a ibɛɛpiↄ ya ń kpá gusiau. 
\q1  
\v 9 Lɛ́ kpele aalɛ kpaaĩ Diizii? 
\q1 A a midɛ, 
\q1 aa wɛ́tɛ̃amↄɛ́ gɛ̃n plao. 
\q1  
\v 10 Aa igbɛ̃ aa kã́, aai gↄ̃ ye lɛu, 
\q1 tɛ́ i kṹmá míↄmiↄ lán sɛ̃̀ giiwa. 
\q1  
\v 11 Niniva gbɛ̃e lɛ́ lɛ́ gia da gbɛ̃́ↄwa, 
\q1 àlɛ lɛkpaaĩ ń gbɛ̃́ↄ Diizi. 
\q1  
\v 12 Ma Dii ma mɛ̀: 
\q1 Baa tó an zĩgↄ̃ↄ mↄ̀ ń dasilɛu, 
\q1 wa ń kwɛ́ɛ, aai sãalɛ. 
\q1 Baa kɛ́ ma á swãgàga yãa, 
\q1 má gága lↄo. 
\q1  
\v 13 Má zuu pↄ́ aa dàɛ́ gboo, 
\q1 má mↄ pↄ́ aa kàwá kɛ̃́kɛ̃. 
\m  
\v 14 Yã́ pↄ́ ma Dii má ò Niniva yã́ musun kɛ: 
\q1 N gbɛ̃e a gↄ̃ n tↄ́ aↄ kuwà lↄo. 
\q1 Má pↄ́ ãaↄ ń pↄ́ kásaa pↄ́ kú n tã́akpɛuↄ wíwi, 
\q1 mí mia'ɛ yↄ̃nɛ, asa wɛ̃́lɛ gian n ũ. 
\c 2  
\s1 Zĩblea Ninivawa 
\q1  
\v 1 Baonakpana gwa bɛ sĩ̀sĩ musu, 
\q1 àlɛ aafia kpàwakɛ.\f + \fr 2.1 \ft Isa 52.7\f* 
\q1 Yudaↄ, àli á dikpɛↄ kɛ, 
\q1 àli lɛ́ pↄ́ á kɛ̀ Diiwaↄ fĩaboɛ̀. 
\q1 Gbɛ̃kaalɛnapiↄ ɛa lɛ́lɛwá lↄo, 
\q1 wà ń mìdɛ ḿpii. 
\q1  
\v 2 Ninivadeↄ, wàlɛ mↄ́ lɛ́lɛiwá. 
\q1 À á bĩ́i dↄ̃́a, íↄ zɛ́ gwa! 
\q1 À tepɛ, í zɛ gíũgiũ! 
\q1  
\v 3 Dii a ɛa Yakↄbu buiↄ gawi kpámá, 
\q1 lá Isailipiↄ vĩ yãawaɛ. 
\q1 Asa gbɛ̃waanaↄ mↄ̀ ń bùsu wàaɛ, 
\q1 aa ń vɛ̃ɛbuↄ dɛ̀. 
\q1  
\v 4 An zĩgↄ̃ gbãaↄ sɛ̀ngbaoↄ tã̀, 
\q1 nɛgↄ̃napiↄ ula tɛ̃a zóizoiↄ daa, 
\q1 an sↄ̃́go mↄↄ lɛ́ pípi, 
\q1 aa ku sↄu guu, 
\q1 aalɛ ń sↄ̃naↄ gbãɛgbãɛ. 
\q1  
\v 5 Aa sì wɛ̃́lɛpi zɛau ń ń sↄ̃́goↄ bàzaao, 
\q1 aalɛ kɛ gãaɛ kìlikili. 
\q1 Aalɛ gɛ̃ bìoobioo lán sɛ̃tɛwa, 
\q1 aa wãa lán loupilɛawa. 
\q1  
\v 6 Wà zĩgↄ̃ sĩanaↄ sìsi, 
\q1 aalɛ wã, aalɛ kpakpagua, 
\q1 aa mipɛ̀ bĩ́iwa ń wãao, 
\q1 aalɛ ń sɛ̀ngbaoↄ pɛ́lɛpɛlɛ. 
\q1  
\v 7 Aa bĩ́ibↄlɛↄ wɛ̃̀wɛ̃, 
\q1 gu pↄ́ swa pã̀u wɛ̃́lɛpia, 
\q1 aa kibɛ kwɛ̀. 
\q1  
\v 8 Wà tà ń Niniva kí nao zĩ̀zↄ ũ, 
\q1 aà zↄnↄɛnaↄ lɛ́ ↄ́ↄlↄ lán felenguuluↄwa, 
\q1 aalɛ ńzĩa gbɛ̃gbɛ̃. 
\q1  
\v 9 Ninivapi gↄ̃̀ lán íkalɛkĩiwa. 
\q1 A gbɛ̃́ↄ lɛ́ gɛ̃zɛa lán íwa. 
\q1 Wàlɛ onɛ́: À zɛ! À zɛ! 
\q1 Ãma gbɛ̃e i ɛao. 
\q1  
\v 10 À ã́nusu sɛ́lɛ! À vua naaa! 
\q1 Àizɛɛ diuɛ ń pↄ́ bɛɛɛdeↄ píi. 
\q1  
\v 11 Wà pↄ́ↄ nàaa, wà pↄ́ↄ sɛ̀lɛ, 
\q1 wɛ̃́lɛ gↄ̃̀ da gii. 
\q1 Sↄ̃ kɛ̃̀ gbɛ̃́ↄgu, 
\q1 an gbázĩna lɛ́ lua, 
\q1 an mɛ zɛa lↄo, 
\q1 an baade oosìsi. 
\q1  
\v 12 Nↄ̀ↄmusupiↄ tòo gɛ̀ máɛ? 
\q1 Nↄ̀ↄmusu nɛ́ↄ pↄblekĩipi ku má ni? 
\q1 Nↄ̀ↄmusu sa ń dao ìↄ bɛbɛ we yãa, 
\q1 gbɛ̃e yã́ lí ń nɛ́ↄ vĩakũo. 
\q1  
\v 13 Nↄ̀ↄmusu sapi nↄ̀ↄ kũ̀ a nɛ́ↄnɛ yãa, 
\q1 à nↄ̀ↄ ɛ̀ a naↄnɛ, à mↄ̀má. 
\q1 Nↄ̀ↄ pↄ́ a tàitaiↄ ka aà tòo pai. 
\q1  
\v 14 Ma Dii Zĩgↄ̃de ma mɛ̀: 
\q1 Má fɛlɛnnↄ, 
\q1 má n sↄ̃́goↄ kpasa, a súɛlɛ iↄ dↄ, 
\q1 wi n nɛ́piↄ dɛdɛ ń fɛ̃ndao. 
\q1 Má pↄ́ pↄ́ ń sìmáↄ kaalɛ, 
\q1 wa n zĩnaↄ yã'o ma lↄo. 
\c 3  
\s1 Waiyoo Niniva 
\q1  
\v 1 Waiyoo gbɛ̃dɛnaↄ wɛ̃́lɛ! 
\q1 Ìliↄ ku gbɛ̃taitaisaio. 
\q1 Mↄafili pàɛwà ń pↄ́ pↄ́ wa sìmáↄ. 
\q1  
\v 2 Flã̀ kↄ̃fĩ ń sↄ̃́go gbá kↄ̃fĩo ma dↄ! 
\q1 Sↄ̃́ↄ lɛ́ bàalɛ, an góↄ lɛ́ vĩvĩ. 
\q1  
\v 3 Zĩgↄ̃ sↄ̃deↄ lɛ́ suwà, 
\q1 an fɛ̃nda wɛ́tɛ̃ lɛ́ pipi, 
\q1 an sↄ̃naↄ lɛ́ tɛkɛ. 
\q1 Gbɛ̃́ pↄ́ wà ń paɛpaɛↄ dasi, 
\q1 gɛↄ gↄ̃̀ kpálɛ, wa fↄ̃ dↄdↄo. 
\q1 Wàlɛ kpakpa gɛↄla. 
\q1  
\v 4 Káaluapi lɛnakasaanɛ́ yã́iɛ. 
\q1 Aà kákaa maa, ì kpáńzi, 
\q1 à buiↄ kà zↄbleu ń lɛnakasaanɛ́o, 
\q1 à ń ↄ̃̀ↄkpà a gbɛ̃kↄↄlɛkɛa guu. 
\q1  
\v 5 Ma Dii Zĩgↄ̃de ma mɛ̀, 
\q1 má fɛlɛnnↄ, 
\q1 má n zwãa sɛ kanɛ n mia, 
\q1 mí tó buiↄ n puizi e, 
\q1 mí n asii ↄlↄ an kíaↄnɛ. 
\q1  
\v 6 Má n pápa ń pↄ́ gĩ vãio, 
\q1 mí n kɛ pↄ́ↄpↄↄ, 
\q1 mí tó gbɛ̃́pii wɛfĩma. 
\q1  
\v 7 Gbɛ̃́ pↄ́ wɛsìnlɛↄ bàalɛnɛ 
\q1 aai mɛ: Niniva gↄ̃̀ da fↄ̃̀ii. 
\q1 Démɛ a wɛ̃nakɛ a yã́ musui? 
\q1 Má wá nↄ̀sɛnininaↄ euɛ̀i? 
\q1  
\v 8 N maa dɛ Tɛbɛsi pↄ́ kálɛa Niili saɛa yã̀? 
\q1 Swapi í mɛ́ kàedài a bĩ́i ũ. 
\q1  
\v 9 Etiopiↄ ń Egipiↄ mɛ́ wɛ̃́lɛpi wá ũ, 
\q1 a gbãa lɛ́ vĩo, 
\q1 Putiↄ ń Libiiↄ ku a zɛnnↄdeↄ guuɛ. 
\q1  
\v 10 Kási wà tà ń Tɛbɛsideↄ zĩ̀zↄↄ ũ, 
\q1 wà ń nɛ́ↄ wìwi zɛ́kpaaↄ guu píiɛ. 
\q1 Wà likpà an bɛɛɛdeↄ sɛa yã́ musu, 
\q1 wà mↄkà an gbɛ̃zↄ̃ↄↄwa. 
\q1  
\v 11 Á Ninivadeↄ sↄ̃, 
\q1 ma pↄkũmabↄbↄma í a zↄ̃lɛwáɛ, 
\q1 í gↄ̃ sãalɛa, 
\q1 íↄ mikpakĩi wɛɛlɛ á ibɛɛↄ yã́i. 
\q1  
\v 12 Á zɛgikĩiↄ gↄ̃ lán libɛ pↄ́ màwaɛ. 
\q1 Tó wa zĩ̀a, aa kwɛ a blenaↄnɛ. 
\q1  
\v 13 Gwa! Á zĩgↄ̃ↄ dɛ lán nↄɛↄwaɛ, 
\q1 á wɛ̃́lɛↄ bĩ́ibↄlɛↄ wɛ̃a á wɛ̀lɛↄnɛ dàii. 
\q1 Tɛ́ lɛ́ kṹ bↄlɛpiↄ gbã́aↄwa. 
\q1  
\v 14 À ítↄtↄ kálɛ, asa wa á kákaɛ. 
\q1 À gɛ̃ bɛ̀lɛu, í ↄ̃zↄ̃wà! 
\q1 À bilikibↄò, í á bĩ́i gbãa kã́fĩ! 
\q1  
\v 15 Tɛ́ a gi kṹwá weɛ, 
\q1 wi á dɛdɛ ń fɛ̃ndao. 
\q1 Wa á kaalɛ kwasutɛ̃ↄ pↄblea ũɛ. 
\q1 À kↄ̃ lán kwaↄwa! 
\q1 À gusisi lán kwasutɛ̃ↄwa! 
\q1  
\v 16 Á laatanaↄ dasikũ̀ lán saanaↄwa, 
\q1 aaì gbɛ̃ble, aaì gɛ̃zɛa. 
\q1  
\v 17 Á gudↄ̃anaↄ dɛ lán kwasutɛ̃ↄwa, 
\q1 á zĩ̀kan dↄaanaↄ dasi lán kwaↄwa, 
\q1 aa kpa bĩ́iwa niɛniɛ. 
\q1 Tó ĩatɛ̃ bìlɛ, aaì gɛ̃zɛa, 
\q1 wìliↄ ń tákĩi dↄ̃o. 
\q1  
\v 18 Asiliↄ kía, 
\q1 n gbɛ̃́ↄ dↄaanaↄ i'ò, 
\q1 n zĩgↄ̃ↄ gbɛ̃zↄ̃ↄↄ gàga. 
\q1 N gbɛ̃́ↄ fãaaa sĩ̀sĩↄ musu, 
\q1 gbɛ̃e ku à ń kãaao. 
\q1  
\v 19 Wíwia pↄ wà n wiwi ɛsɛ vĩo, 
\q1 n bↄpi láaa vĩo. 
\q1 Gbɛ̃́ pↄ́ n bao mà 
\q1 ali ↄtaalɛ n yã́ musuɛ, 
\q1 asa gbɛ̃e i gí n pãsĩ kpálɛsai mai a mɛwao.