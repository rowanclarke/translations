\v 1 \w Después|strong="H1961"\w* \w de|strong="H1121"\w* la \w muerte|strong="H4194"\w* \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w*, esclavo \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w aconteció|strong="H1961"\w* \w que|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* habló \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nun|strong="H5126"\w*, \w ministro|strong="H8334"\w* \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w*:  
\v 2 \wj Mi esclavo \+w Moisés|strong="H4872"\+w* \+w murió|strong="H4191"\+w*. \+w Levántate|strong="H6965"\+w*, \+w pues|strong="H6258"\+w*, \+w ahora|strong="H6258"\+w*. Cruza \+w este|strong="H2088"\+w* \+w Jordán|strong="H3383"\+w*, tú y \+w todo|strong="H3605"\+w* \+w este|strong="H2088"\+w* \+w pueblo|strong="H5971"\+w*, \+w a|strong="H3068"\+w* \+w la|strong="H3605"\+w* tierra \+w que|strong="H6258"\+w* \+w doy|strong="H5414"\+w* \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w*.\wj*   
