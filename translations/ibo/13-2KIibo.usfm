\id 2KI - Biblica® Open Igbo Contemporary Bible 2020 
\h 2 Ndị Eze 
\toc1 2 Ndị Eze 
\toc2 2 Ndị Eze 
\toc3 2Ez 
\mt1 2 Ndị Eze 
\c 1  
\s1 Ikpe ọmụma dịrị Ahazaya 
\p  
\v 1 Moab nupuru isi megide Izrel mgbe Ehab nwụrụ.  
\v 2 Nʼoge a, Ahazaya sitere na mgbe ụlọ elu ya dị na Sameria daa, merụọ ahụ nke ukwuu. Nʼihi ọrịa a, o zigara ndị ozi, sị ha, “Gaa jụta ase nʼaka Baal-Zebub,\f + \fr 1:2 \fq Baal-Zebub \ft bụ aha ndị Kenan, nke pụtara \fqa eze mmụọ ọjọọ, \ft maọbụ \fqa ekwensu. Beel-Zebub \ft nke pụtara, \fqa eze ụmụ ijiji \ft bụ aha ịkwa emo nye chi ndị Kenan a na-akpọ Baal-Zebub. \xt Mat 10:25; 12:27\f* bụ chi Ekrọn, ma m ga-adịrị site nʼihe mmerụ ahụ a.” 
\p  
\v 3 Ma mmụọ ozi \nd Onyenwe anyị\nd* gwara Ịlaịja onye Tishbe okwu sị ya, “Gaa zute ndị ozi eze Sameria zipụrụ, jụọ ha sị, ‘Gịnị mere unu ji aga Ekrọn ịjụ ase? Ọ bụ na Chineke anọghị nʼIzrel mere unu ji aga ịjụ Baal-Zebub ase ịmata ma eze ọ ga-adị ndụ?’  
\v 4 Nʼihi nke a, otu a ka \nd Onyenwe anyị\nd* kwuru, ‘Ị gaghị esite nʼelu ihe ndina ahụ bilie. Ị ghaghị ịnwụ!’ ” Ya mere Ịlaịja pụrụ gaa zie ndị ozi eze ozi ahụ. 
\p  
\v 5 Ndị ozi ahụ laghachiri azụ. Ma mgbe eze hụrụ ha, ọ jụrụ ha sị, “Gịnị mere unu ji lọghachi?” 
\p  
\v 6 Ha zara ya, “Otu nwoke zutere anyị nʼụzọ sị anyị, ‘Laghachi ga zie eze ahụ zitere unu sị ya: “Ihe ndị a, ka \nd Onyenwe anyị\nd* kwuru, Ọ bụ nʼihi na Chineke anọghị nʼIzrel ka i ji zipụ ndị mmadụ ka ha gaa jụta ase site nʼaka Baal-Zebub, chi ndị Ekrọn? Nʼihi nke a, ị gaghị esite nʼihe ndina gị bilie. Ya doo gị anya na ị ghaghị ịnwụ!” ’ ” 
\p  
\v 7 Eze jụrụ ha sị, “Onye bụ nwoke a zutere unu nʼụzọ gwa unu okwu ndị a? Olee ụdị mmadụ ọ bụ?” 
\p  
\v 8 Ha zaghachiri ya, “Ọ bụ nwoke yi uwe e ji ajị anụ kpaa; o kere ihe okike akpụkpọ anụ nʼukwu ya.” 
\p Eze sịrị, “Ọ bụ Ịlaịja, onye amụma si Tishbe!” 
\p  
\v 9 Mgbe ahụ, eze zigara otu onyeisi agha ya, na iri ndị agha ise ka ha gaa jide Ịlaịja. Mgbe ndị agha ahụ bịarutere hụ Ịlaịja ka ọ nọ ala nʼelu ugwu, onyeisi agha ahụ kpọrọ Ịlaịja sị ya, “Onye nke Chineke, eze sị gị, ‘rituo!’ ” 
\p  
\v 10 Ịlaịja zara sị ha, “Ọ bụrụ na m bụ onye nke Chineke dịka i kwuru, ka ọkụ si nʼeluigwe daa rechapụ gị na iri ndị a agha ise so gị.” Otu mgbe ahụ, ọkụ sitere nʼeluigwe daa rechapụ iri ndị agha ise ahụ na onyeisi ha. 
\p  
\v 11 Ọzọkwa, eze zigara otu onyeisi agha na iri ndị agha ise ọzọ ka ha gaa jide Ịlaịja. Mgbe ha bịarutere hụ Ịlaịja, onyeisi agha ahụ kpọkuru ya sị ya, “Onye nke Chineke, eze sị gị, ‘rituo, bịa ngwangwa!’ ” 
\p  
\v 12 Ịlaịja zara sị ya, “Ọ bụrụ na m bụ onye nke Chineke dịka i kwuru, ka ọkụ si nʼeluigwe daa rechapụ gị na iri ndị agha ise gị na ha so.” Ngwangwa, ọkụ Chineke si nʼeluigwe daa rechapụ ha. 
\p  
\v 13 Ọzọkwa, eze zigara otu onyeisi agha na iri ndị agha ise ọzọ ka ha gaa jide Ịlaịja. Mgbe ndị agha a bịara hụ Ịlaịja, onyeisi agha ahụ rigoro nʼelu ugwu gbuo ikpere nʼala nʼihu Ịlaịja rịọọ ya amara sị ya, “Onye nke Chineke, biko, meere ohu gị na iri ndị agha ise mụ na ha so ebere.  
\v 14 Lee, ọkụ esitela nʼeluigwe rechapụ ndịisi agha abụọ ahụ buru ụzọ, ha na ndị agha ha. Ugbu a, biko, arịọ m gị, chebe ndụ anyị.” 
\p  
\v 15 Mgbe ahụ, mmụọ ozi \nd Onyenwe anyị\nd* gwara Ịlaịja okwu sị ya, “Atụla egwu! Soro ya gaa!” Ya mere, Ịlaịja sooro onyeisi agha ahụ gaa nʼihu eze. 
\p  
\v 16 Mgbe Ịlaịja ruru nʼihu eze, ọ gwara eze okwu sị ya, “Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, ọ bụ nʼihi na Chineke anọghị nʼIzrel ka i ji zipụ ndị ozi ka ha gaa jụta ase site nʼaka Baal-Zebub, chi ndị Ekrọn? Ebe ọ bụ na i mere ihe dị otu a, ị gaghị esite nʼihe ndina gị bilie. Ị ga-anwụrịrị!”  
\v 17 Ọ nwụrụ dịka okwu \nd Onyenwe anyị\nd* nke Ịlaịja kwuru si dị. 
\p Nʼihi na Ahazaya enweghị nwa nwoke ọbụla, Jehoram\f + \fr 1:17 \ft Maọbụ, \fqa Joram dịka a na-akpọ ya mgbe ụfọdụ\f* nọchiri anya ya dịka eze, nʼafọ nke abụọ nke ịbụ eze Jehoram nwa Jehoshafat, bụ eze Juda.  
\v 18 Akụkọ banyere ịbụ eze nke Ahazaya, na ihe niile o mere, e deghị ha nʼakwụkwọ akụkọ ndị eze Izrel? 
\c 2  
\s1 Ịlaịja alaa eluigwe 
\p  
\v 1 O ruo mgbe \nd Onyenwe anyị\nd* chọrọ ị kpọrọ Ịlaịja laa nʼeluigwe site nʼoke ifufe, Ịlaịja na Ịlaisha nọ nʼụzọ sitere Gilgal.  
\v 2 Ịlaịja sịrị Ịlaisha, “Nọdụ nʼebe a, nʼihi na \nd Onyenwe anyị\nd* ziri m ozi ka m gaa Betel.”\f + \fr 2:2 \ft Betel bụ obodo dị mkpa site nʼoge nna nna ochie ndị Izrel. Rehoboam bụ eze wuru ebe ịchụ aja na Betel nʼụzọ ịma aka nye nke e wuru na Jerusalem. \xt Jen 12:8; 22:10-22; 35:1-5; 1Ez 12:28-33\f* 
\p Ma Ịlaisha zara sị ya, “Dịka \nd Onyenwe anyị\nd* na-adị ndụ, na dịka gị onwe gị nọkwa na-adị ndụ, agaghị m ahapụ gị.” Ya mere, ha abụọ sooro gaa Betel. 
\p  
\v 3 Nʼebe ahụ, ụmụ okorobịa ndị amụma nọ na Betel pụtara zute ha abụọ. Ndị amụma ahụ bịakwutere Ịlaisha sị ya, “Ị maara na \nd Onyenwe anyị\nd* ga-esi nʼebe ị nọ wepụ onyenwe gị Ịlaịja taa?” 
\p Ịlaisha sịrị, “Mụ onwe m maara, ma unu nọrọ nwayọọ.” 
\p  
\v 4 Mgbe ahụ, Ịlaịja sịrị ya, “Ịlaisha, nọdụ nʼebe a, nʼihi na \nd Onyenwe anyị\nd* ziri m ozi ka m gaa Jeriko.” 
\p Ma ọ zara, “Dịka \nd Onyenwe anyị\nd* na-adị ndụ, na dịka gị onwe gị nọkwa na-adị ndụ, agaghị m ahapụ gị.” Ya mere ha abụọ sokwaara ruo Jeriko. 
\p  
\v 5 Ndị otu ndị amụma nọ na Jeriko bịakwutere Ịlaisha nso jụọ ya, “Ị maara na \nd Onyenwe anyị\nd* ga-ewepụ onyenwe gị taa?” 
\p Ọ zara, “E, amaara m, ya mere nọọnụ nwayọọ.” 
\p  
\v 6 Mgbe ahụ, Ịlaịja sịrị ya, “Nọdụ nʼebe a, nʼihi na \nd Onyenwe anyị\nd* ziri m ka m jee Jọdan.” 
\p Ma ọ zara, “Dịka \nd Onyenwe anyị\nd* na-adị ndụ, na dịka gị onwe gị nọkwa na-adị ndụ, agaghị m ahapụ gị.” Ya mere, ha abụọ sooro na-eje. 
\p  
\v 7 Iri ndị amụma ise sitere nʼetiti ndị amụma sooro ha guzoro nʼebe dị anya na ncherita ihu ebe Ịlaịja na Ịlaisha kwụsịrị nʼakụkụ Jọdan.  
\v 8 Mgbe ahụ, Ịlaịja chịịrị uwe mwụda ya, pịakọtaa ya, tie ya nʼelu osimiri ahụ. Mmiri ahụ kewara ụzọ abụọ, ala akọrọ pụtakwara. Nʼebe ahụ ka Ịlaịja na Ịlaisha si gafee nʼofe ọzọ nke osimiri ahụ. 
\p  
\v 9 Mgbe ha abụọ gafesịrị, Ịlaịja jụrụ Ịlaisha ajụjụ sị ya, “Gịnị ka ị chọrọ ka m meere gị tupu e site nʼebe ị nọ wepụ m?” 
\p Ịlaisha rịọrọ sị ya, “Biko, mee ka m nweta ụdị mmụọ i nwere okpukpu abụọ.” 
\p  
\v 10 Ịlaịja zara sị ya, “Ihe ị rịọrọ bụ ihe sịrị ike omume. Ọ bụrụ na ị hụ m mgbe a na-ewepụ m site nʼebe ị nọ, ị ga-enweta ihe ị rịọrọ. Ma ọ bụrụ na ị hụghị m, ị gaghị enweta ihe ị rịọrọ.” 
\p  
\v 11 Mgbe ha na-aga nʼihu nʼije ha na-akparịta ụka, na mberede, ụgbọ ọkụ nke ịnyịnya ọkụ na-adọkpụ pụtara ihe kewaa ha abụọ. Mgbe ahụ kwa oke ifufe buuru Ịlaịja rigoro nʼeluigwe.  
\v 12 Ịlaisha hụrụ ya, lelie anya elu tie mkpu akwa sị, “Nna m! Nna m! Usuu ụgbọ agha na usuu ndị na-agba ịnyịnya Izrel!” Ọ hụkwaghị Ịlaịja anya ọzọ. O jidere uwe o yi nʼahụ dọwaa ya ibe abụọ. 
\p  
\v 13 Emesịa, ọ chịlịri uwe mwụda Ịlaịja nke dapụrụ mgbe e weliri ya elu, laghachi bịa guzo nʼakụkụ osimiri Jọdan.  
\v 14 O tiri akwa ahụ\f + \fr 2:14 \fq Akwa ahụ \ft Maọbụ, \fqa uwe mwụda Ịlaịja \xt 2Ez 2:8.\f* nʼelu mmiri ahụ jụọ sị, “Olee ebe \nd Onyenwe anyị\nd*, Chineke Ịlaịja nọ?” Mgbe o tiri mmiri ahụ ihe, o kewakwara otu ụzọ nʼaka nri nke ọzọ nʼaka ekpe, Ịlaisha gafere nʼofe nke ọzọ. 
\p  
\v 15 Mgbe ndị amụma ahụ si Jeriko nʼele anya, hụrụ ihe mere, ha sịrị, “Mmụọ Ịlaịja adakwasịla Ịlaisha.” Ha gara zute ya, kpọọ isiala nʼihu ya.  
\v 16 Ha sịrị ya “Lee, anyị bụ ndị ohu gị nwere iri ndị ikom ise ahụ siri ike. Kwere ka ha ga chọgharịa nna gị ukwu. Ma eleghị anya mmụọ \nd Onyenwe anyị\nd* eburula ya tụdakwa ya nʼotu ugwu, maọbụ nʼotu ndagwurugwu.” 
\p Ịlaisha zaghachiri, “Unu ezigala ha.” 
\p  
\v 17 Ma mgbe ha nọgidere rịọsie ya arịrịọ ike, ruo mgbe o nwekwaghị ike igbochi ha. Ọ gwara ha sị, “Ọ dị mma, ziganụ mmadụ ka ha gaa chọọ ya.” Ha zigara iri ndị ikom ise, ndị gara chọgharịa Ịlaịja ụbọchị atọ, ma ha achọtaghị ya.  
\v 18 Ịlaisha nọ na Jeriko mgbe ndị a lọghachiri bịa kọọrọ ya otu ha si gaa. Mgbe ahụ, ọ gwara ha sị, “Ọ bụ na m agwaghị unu sị unu ejela?” 
\s1 Ezi mmiri ọṅụṅụ 
\p  
\v 19 Ndị obodo ahụ sịrị Ịlaisha, “Lee, onyenwe anyị, obodo anyị dị nʼebe dị mma, dịka gị onwe gị na-ahụ, ma mmiri dị nʼime ya jọrọ njọ, ala ya adịghị amịpụta mkpụrụ dịka o kwesiri.” 
\p  
\v 20 Ịlaisha zara sị ha, “Ọ dị mma, gaanụ tinye nnu nʼime efere ọhụrụ wetara m ya.” Ha gara weta efere ọhụrụ nke nnu juru nʼime ya. 
\p  
\v 21 Ịlaisha buuru nnu ahụ gaa nʼebe mmiri ahụ si asọpụta, wụnye nnu ahụ nʼime ya. Mgbe ọ na-eme nke a, o kwuru okwu sị, “Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, ‘Agwọọla m mmiri a. Ọnwụ maọbụ amịghị mkpụrụ nke ala agaghị adịkwa.’ ”  
\v 22 Site nʼụbọchị ahụ gaa nʼihu, mmiri ahụ dịịrị ọcha ruo taa, dịka Ịlaisha kwuru. 
\s1 Nkọcha a kọchara Ịlaisha 
\p  
\v 23 Emesịa, Ịlaisha sitere na Jeriko pụọ ịlaghachi Betel. Mgbe ọ na-aga nʼụzọ, ụfọdụ ụmụ okorobịa nta sitere nʼime obodo pụta, bidoro jiri ya na-eme ihe ọchị, sị ya, “Onyeisi nkwọcha, site nʼebe a pụọ! Onyeisi nkwọcha, site nʼebe a pụọ!”  
\v 24 Ịlaisha tụgharịrị lee ha anya, bụọ ha ọnụ nʼaha \nd Onyenwe anyị\nd*. Otu mgbe ahụ, nne anụ ọhịa abụọ, a na-akpọ bịa, sitere nʼọhịa pụta, dọgbuo iri ụmụ okorobịa anọ na abụọ nʼime ha.  
\v 25 Emesịa, Ịlaisha sitere nʼebe ahụ pụọ jeruo nʼugwu Kamel. Emesịakwa, o sitere nʼebe ahụ laghachi na Sameria.\f + \fr 2:25 \ft Ọ bụ nʼobodo Sameria ka Ịlaisha biri.\f* 
\c 3  
\s1 Nnupu isi Moab 
\p  
\v 1 Jehoram nwa Ehab, malitere ịbụ eze ndị Izrel na Sameria nʼafọ nke iri na asatọ nke ọchịchị Jehoshafat na Juda. Afọ iri na abụọ ka ọ chịrị dịka eze.  
\v 2 O mere ihe ọjọọ nʼanya \nd Onyenwe anyị\nd*, ma ọ bụghị dịka nna ya na nne ya mere. O wezugara nkume ahụ e doro nsọ nye Baal nke nna ya kpụrụ.  
\v 3 Otu ọ dị, ọ nọgidere na mmehie Jeroboam nwa Nebat, onye mere ka Izrel baa nʼime mmehie ife arụsị. Joram esiteghị na ha wezuga onwe ya. 
\p  
\v 4 Eze ndị Moab, bụ Misha, na ndị ya, bụ ndị na-azụ atụrụ. Nʼafọ niile, ọ na-atụrụ eze Izrel otu narị puku ajị ebule, na otu narị puku atụrụ.  
\v 5 Ma mgbe Ehab eze Izrel nwụrụ, eze Moab nupuru isi megide eze Izrel, jụkwa ịnọ nʼokpuru ya ọzọ.  
\v 6 Ya mere, eze Joram sitere na Sameria pụọ ga kpọkọta ndị Izrel niile.  
\v 7 O zigara Jehoshafat eze Juda ozi sị ya, “Eze Moab enupula isi megide m. Ị ga-abịa soro m ịga buso ndị Moab agha?” 
\p Ọ zaghachiri, “Aga m eso gị gaa. Mụ na gị bụ otu, ndị m bụ ndị gị, ịnyịnya m bụkwa ịnyịnya gị.” 
\p  
\v 8 “Ma olee ụzọ anyị ga-esi gaa ibu agha ahụ?” 
\p Joram zara, “Anyị ga-esi ụzọ ọzara Edọm.\f + \fr 3:8 \ft Ihe nke a pụtara, bụ na ha ga-esi nʼakụkụ ọdịda anyanwụ Osimiri Nwụrụ anwụ gbaa gburugburu, pụta nʼakụkụ ndịda obodo Moab ma buso ha agha. Ma tupu ha e nwee ike mee otu a, ha ga-esite nʼoke ala ndị Edọm, bụ obodo ndị Juda na-achị gafee.\f*” 
\p  
\v 9 Ya mere, eze Izrel na eze Juda, na eze Edọm,\f + \fr 3:9 \ft Eze Edọm bụ onyeisi alaeze Jehoshafat họpụtara. Ị ga-ahụ nke a nʼakwụkwọ \xt 1Ez 22:47; 2Ez 8:20\f* na ndị agha ha niile, zukọtara site ụzọ ọzara Edọm ịga ibuso Moab agha. Ha gara ije abalị asaa nʼọzara. Ma mmiri ọṅụṅụ ha nwere gwụsịrị. Ọ dịkwaghị mmiri dịrị anụ ụlọ ha, na ndị agha ha. 
\p  
\v 10 Mgbe ahụ, eze Izrel tiri mkpu sị, “Gịnị ka anyị ga-eme? Ọ ga-abụ na \nd Onyenwe anyị\nd* kpọpụtara anyị bụ eze atọ ndị a, nʼebe a, inyefe anyị nʼaka ndị Moab, ka ha merie anyị?” 
\p  
\v 11 Ma Jehoshafat, eze Juda, jụrụ ajụjụ sị, “Ọ bụ na o nweghị onye amụma \nd Onyenwe anyị\nd* nọ nʼebe a, onye anyị ga-esi nʼaka ya jụta \nd Onyenwe anyị\nd* ase, site na ya?” 
\p Otu onyeisi agha ndị Izrel sị ha, “Ịlaisha, nwa Shafat, onye jeere Ịlaịja ozi, nọ nʼebe a.” 
\p  
\v 12 Jehoshafat zara sị, “Okwu \nd Onyenwe anyị\nd* dị nʼọnụ ya.” Ya mere, eze Izrel na Jehoshafat, na eze Edọm, gakwuru ya. 
\p  
\v 13 Ịlaisha zara eze Izrel sị, “Gịnị ka mụ na gị nwekọrọ? Jekwuru ndị amụma nne gị na nna gị, jụta ha ase.” 
\p Eze Izrel zara sị ya, “Mba, nʼihi na ọ bụ \nd Onyenwe anyị\nd* kpọpụtara anyị bụ eze atọ nʼebe a, ka o were anyị nyefee nʼaka ndị Moab.” 
\p  
\v 14 Ịlaisha sịrị, “Ebe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-adị ndụ, bụ onye m na-efe, a si na ọ bụghị nsọpụrụ m nwere nʼebe Jehoshafat eze Juda nọ, agaraghị m atụpụrụ gị ọnụ maọbụ lee gị anya nʼihu.  
\v 15 Ma ugbu a, kpọtaranụ m onye na-akpọ ụbọ.” 
\p Mgbe ọkpọ ụbọ ahụ malitere ịkpọ ụbọ ya, aka \nd Onyenwe anyị\nd* bịakwasịrị Ịlaisha.  
\v 16 Ọ sịrị, “Ihe a ka \nd Onyenwe anyị\nd* kwuru, aga m eme ka ndagwurugwu a jupụta nʼolulu mmiri.  
\v 17 Nʼihi na otu a ka \nd Onyenwe anyị\nd* kwuru, Unu agaghị ahụ ifufe maọbụ mmiri ozuzo, ma ndagwurugwu a ga-ejupụta na mmiri, unu onwe unu ga-aṅụ, na ehi unu, na anụmanụ ndị ọzọ unu ga-aṅụkwa mmiri.  
\v 18 Ma nke a bụ ihe dị nta nʼebe \nd Onyenwe anyị\nd* nọ, nʼihi na ọ ga-enyefekwa ndị Moab nʼaka unu.  
\v 19 Unu ga-etigbu obodo ọbụla e wusiri ike, na obodo ukwu niile. Unu ga-egbudakwa ezi osisi ha na-amị mkpụrụ, kpọchie isi mmiri ha niile, werekwa nkume mebikwaa ezi ala ubi ha niile.” 
\p  
\v 20 O ruo, nʼụtụtụ, nʼoge e ji achụ aja nsure ọkụ ụtụtụ, lee na mmiri sitere ụzọ Edọm sọọrọ bịa nʼebe ahụ ha gwuru olulu na ndagwurugwu ala ahụ sọjuo ala ahụ niile. 
\p  
\v 21 Mgbe ndị Moab nụrụ na ndị eze ahụ na-abịa imegide ha, ha kpọkọtara ndị ikom ọbụla nwere ike ịlụ agha, ma okenye ma okorobịa, pụta bịa guzo nʼoke ala ha.  
\v 22 Mgbe chi bọrọ nʼisi ụtụtụ, anyanwụ wara mụkwasị mmiri ahụ. Site nʼebe ha nọ, ndị Moab lepụrụ anya hụ mmiri ahụ ka ọ na-acha ọbara ọbara.  
\v 23 Mgbe ahụ, ha sịrịtara onwe ha, “Leenụ ọbara! Ọ ga-abụ na ndị agha eze atọ ndị a etigbuola onwe ha. Pụtanụ, unu ndị Moab, ka anyị gaa kwakọrọ ihe nkwata na-agha!” 
\p  
\v 24 Mgbe ha gbaara ọsọ bịaruo nʼụlọ agha ndị Izrel, ndị agha Izrel biliri malite itigbu ha. Ya mere, ndị agha Moab sitere nʼihu ha gbalaga. Ma ndị agha Izrel banyere nʼime obodo ndị Moab, gbuo ihe niile ha hụrụ nʼụzọ.  
\v 25 Ha tidara obodo ndị Moab niile, tinye nkume nʼala ubi ọma ndị Moab niile. Ha kpọchiri isi mmiri niile, gbudasịakwa ezi osisi niile na-amị mkpụrụ nʼala ahụ. Nʼikpeazụ, ọ bụ naanị otu obodo ndị Moab fọdụrụ, isi obodo a na-akpọ Kia Hareset. Ndị ji ụdọ na-ama nkume gbara obodo a gburugburu, bido ibuso ya agha. 
\p  
\v 26 Mgbe eze Moab hụrụ na agha ahụ anaghị agaziri ya nke ọma, ọ chịịrị narị ndị agha asaa, ndị ji mma agha ebu agha, gbalịa isi nʼetiti ndị agha Izrel tikapụta, na ncherita ihu ebe eze Edọm nọ, ma ha enweghị ike.  
\v 27 Ya mere, o weere ọkpara ya, onye gaara abụ eze nʼọnọdụ ya, gbuo ya, dịka aja nʼelu mgbidi gbara obodo ahụ gburugburu nye chi Moab. Iwe dị ukwuu dị nʼụbọchị ahụ megide Izrel. Ha kwụsịrị ibu agha, laghachi nʼobodo nke aka ha. 
\c 4  
\s1 Mmanụ oliv nwanyị di ya nwụrụ 
\p  
\v 1 Otu ụbọchị, otu nwanyị nʼime ndị inyom ndị amụma bịakwutere Ịlaisha rịọ ya sị, “Ohu gị, bụ di m anwụọla. Ị matara na ọ na-atụ egwu\f + \fr 4:1 \ft Ọ sọpụụrụ Onyenwe anyị\f*\nd Onyenwe anyị\nd*. Ma ugbu a, onye o ji ụgwọ na-abịa ịkpọrọ ụmụ m ndị ikom abụọ ime ka ha bụrụ ndị ohu ya.” 
\p  
\v 2 Ịlaisha jụrụ ya ajụjụ sị, “Gịnị ka m ga-emere gị? Gwa m, gịnị ka i nwere nʼụlọ?” 
\p Nwanyị ahụ zara sị, “O nweghị ihe ọbụla ohu gị nwanyị nwere nʼụlọ karịa naanị ntakịrị mmanụ.”\f + \fr 4:2 \ft Mmanụ bụ otu ngwa nri dị mkpa na nri niile ndị si na mpaghara ọwụwa anyanwụ na-eri. Mkpa ọ dị bụ na ọ na-edozi ahụ mmadụ.\f* 
\p  
\v 3 Ịlaisha sịrị, “Jegharịa na-ezi, gaa nata ndị agbataobi gị niile ite nke ihe ọbụla na-adịghị nʼime ya. Ha abụkwala ole na ole.  
\v 4 Mgbe ahụ, baa nʼime ụlọ, gị na ụmụ gị, mechibido onwe unu ụzọ. Malite ịgbanye mmanụ ahụ nʼime ite ahụ niile, mgbe nke ọbụla juru, bupụ ya nʼotu akụkụ.” 
\p  
\v 5 Nwanyị ahụ hapụrụ ya, ga mechibido onwe ya na ụmụ ya ndị ikom ụzọ. Ha na-ebutere ya ite niile ahụ nso, ebe ya onwe ya na-agbanye agbanye nʼime ha.  
\v 6 Mgbe ọ gbajuru ite ndị ahụ niile, ọ sịrị nwa ya, “Butere m ite ọzọ.” 
\p Ma ọ zara, “O nweghị ite ọzọ fọdụrụ.” Mgbe ahụ, mmanụ ahụ kwụsịrị ịgbapụta. 
\p  
\v 7 Ọ gara gwa onye nke Chineke ahụ, onye sịrị, “Gaa, ree mmanụ ahụ, kwụkwaa ụgwọ unu ji. Gị na ụmụ gị ndị ikom were nke fọdụrụ mee mkpa dịrị unu.” 
\s1 Nwanyị Shunem na nwa ya 
\p  
\v 8 Otu ụbọchị, Ịlaisha gara nʼobodo Shunem. Otu nwanyị nwere ugwu bi nʼebe ahụ. Nwanyị ahụ rịọsiri ya ike ka o rie nri. Nʼihi ya, mgbe ọbụla Ịlaisha si nʼebe ahụ gafee, ọ na-akwụsị nʼebe ahụ rie ihe.  
\v 9 Ma nwanyị ahụ gwara di ya okwu sị, “O doro m anya nke ọma na nwoke a na-akwụsị nʼụlọ anyị mgbe niile bụ onye nsọ nke Chineke.  
\v 10 Biko, ka anyị doziere ya otu ọnụụlọ nta nʼime ụlọ elu anyị, ka anyị tinyere ya ihe ndina na tebul, na oche, na oriọna, ka o nwee ebe ọ ga na-anọ mgbe ọbụla ọ bịakwutere anyị.” 
\p  
\v 11 Otu ụbọchị, mgbe Ịlaisha bịakwara nʼebe ahụ, ọ bara nʼọnụụlọ ahụ, dinaa nʼebe ahụ.  
\v 12 Ọ sịrị Gehazi onye na-ejere ya ozi, “Gaa kpọọ onye Shunem a,” Ya mere, ọ kpọrọ ya, ọ bịara guzo nʼihu ya,  
\v 13 Ịlaisha gwara Gehazi, “Gwa nwanyị ahụ, sị, ‘Lee, otu i si enye onwe gị nsogbu niile ndị a maka anyị. Ugbu a, gịnị ka a ga-emere gị? Ọ bụ ka anyị gwa eze okwu banyere gị, ka ọ bụ ịgwa onyeisi ndị agha?’ ” 
\p Ọ zara, “Ebi m nʼetiti ndị m.” 
\p  
\v 14 Ịlaisha jụrụ, “Gịnịkwa ka anyị ga-emere nwanyị a?” 
\p Gehazi sịrị, “Nʼezie, o nweghị nwa nwoke, di ya emeekwala agadi.” 
\p  
\v 15 Ịlaisha sịrị, “Kpọọ ya.” Ya mere, Gehazi kpọrọ ya, ọ bịara guzo nʼọnụ ụzọ.  
\v 16 Ịlaisha sịrị, “Na mgbe dị otu a nʼafọ ọzọ, ị ga-eku nwa nwoke nʼaka gị abụọ.” 
\p Ọ sịrị, “Mba, onyenwe m, biko, gị onye nke Chineke, agwala ohu gị nwanyị okwu ụgha.” 
\p  
\v 17 Ma dịka Ịlaisha si kwuo, nwanyị ahụ tụụrụ ime, na mgbe ahụ nʼafọ ọzọ ya, ọ mụrụ nwa nwoke. 
\p  
\v 18 Nwata ahụ toputara, otu ụbọchị ọ pụrụ jekwuru nna ya nʼubi, ebe ha nọ na-aghọ ọka.  
\v 19 O tikuru nna ya sị ya, “Isi m o, isi m o!” 
\p Nna ya sịrị otu nʼime ndị ohu ya, “Kuru ya kulaara nne ya.”  
\v 20 O kuuru ya, kulaara ya nne ya, nwantakịrị nwoke ahụ nọdụrụ nʼapata nne ya ruo etiti ehihie, mgbe ọ nwụrụ.  
\v 21 Nne ya kuuru ya rigoo nʼelu ụlọ ahụ, tọgbọ ya nʼelu ihe ndina ahụ onye nke Chineke ahụ na-edina, mechie ụzọ pụọ. 
\p  
\v 22 O ziri ozi kpọọ di ya sị ya, “Biko, zitere m otu okorobịa na otu ịnyịnya ibu, ka m jekwuru onye Chineke ahụ. Aga m alọtakwa ọsịịsọ.” 
\p  
\v 23 Ọ sịrị, “Gịnị mere i ji ejekwuru ya taa? Ọ bụghị Ọnwa ọhụrụ, ọ bụghịkwa ụbọchị izuike.” 
\p Ọ zara sị, “Udo dị.” 
\p  
\v 24 Mgbe ahụ, ọ nọkwasịrị nʼelu ịnyịnya ibu ahụ, nye nwokorobịa ahụ iwu sị ya, “Gbasie ọsọ ike. Akwụsịkwala ịgba ọsọ ma ọ bụghị mgbe m gwara gị kwụsị.”  
\v 25 Ya mere, o buliri ije,\f + \fr 4:25 \ft Njem a, ga-abụ ihe dị ka kilomita iri atọ site nʼobodo Shunem ruo nʼugwu a.\f* gakwuru onye nke Chineke nʼugwu Kamel. 
\p Mgbe o lepụrụ anya hụ ya ka ọ na-abịa, onye nke Chineke sịrị odibo ya bụ Gehazi, “Lee nwanyị Shunem ahụ.  
\v 26 Gbara ọsọ gaa zute ya jụọ ya sị ya, ‘Ọ dịkwa mma? Dị gị ọ nọkwa nʼudo? Nwa gị ọ nọkwa nʼudo?’ ” Mgbe Gehazi zutere ya jụọ ajụjụ ndị a, nwanyị ahụ zara Gehazi sị ya, 
\p “E, anyị niile nọ nʼudo, ihe niile na-aga nke ọma.” 
\p  
\v 27 Ma mgbe ọ bịakwutere onye nke Chineke, ọ dara nʼala nʼihu ya, jide ya nʼụkwụ ya abụọ. Gehazi bịaruru nso inupu ya, ma onyeozi Chineke sịrị ya, “Hapụ ya aka, nʼihi na ọ dị ihe na-enye ya nsogbu nʼime mmụọ ya, ma \nd Onyenwe anyị\nd* zonarịrị m ya, ọ gwaghịkwa m ihe mere.” 
\p  
\v 28 Nwanyị ahụ sịrị, “Onyenwe m, arịọrọ m gị nye m nwa nwoke? Ọ bụ na m asịghị gị, ‘emeela m ka m nwee olileanya’?” 
\p  
\v 29 Ịlaisha sịrị Gehazi, “Ngwa, were ihe ike nʼukwu jikọta uwe mwụda gị, werekwa mkpanaka m nʼaka gị, bilie gaa Shunem. Mgbe ị na-aga ekelekwala onye ọbụla ekele. Ọ bụrụkwa na onye ọbụla ekelee gị, azala ekele ya. Gaa nʼụlọ ahụ. I ruo, tụkwasị mkpanaka m nʼihu nwantakịrị nwoke ahụ.” 
\p  
\v 30 Ma nne nwantakịrị ahụ zara sị, “Dịka \nd Onyenwe anyị\nd* na-adị ndụ, na dịka gị onwe gị nọkwa na-adị ndụ, agaghị m ahapụ gị laa.” Ịlaisha biliri soro ya bido ịla nʼụlọ ya. 
\p  
\v 31 Ma Gehazi butere ụzọ rute nʼụlọ ahụ, were mkpanaka ahụ tụkwasị nʼihu nwantakịrị nwoke ahụ, ma nke a emeghị ka nwantakịrị ahụ teta ma ọ bụkwanụ kuo ume. Ya mere, Gehazi laghachiri izute Ịlaisha, gwa ya sị, “Nwata ahụ etetaghị.” 
\p  
\v 32 Mgbe Ịlaisha rutere nʼụlọ ahụ, ọ hụrụ ka nwantakịrị ahụ nwụrụ anwụ dina nʼelu ihe ndina ya.  
\v 33 Ọ banyere nʼime ọnụụlọ ahụ, mechibido ha abụọ ụzọ, kpee ekpere, kpọkuo \nd Onyenwe anyị\nd*.  
\v 34 Emesịa, ọ makpuuru nʼelu nwantakịrị ahụ, tụkwasị ọnụ ya nʼọnụ nwantakịrị ahụ, na anya ya abụọ na nke nwantakịrị ahụ, na aka ya abụọ na nke ya. Mgbe o si otu a dinara nʼelu nwantakịrị ahụ, ahụ nwantakịrị ahụ malitere ikpo ọkụ ọzọ.  
\v 35 Ịlaisha biliri jegharịa nʼime ụlọ ahụ ugboro ole na ole, laghachikwa makpuru nʼelu nwantakịrị ahụ ọzọ. Emesịa, nwantakịrị ahụ zere uzere ugboro asaa, meghe anya ya abụọ. 
\p  
\v 36 Ịlaisha kpọrọ Gehazi sị ya, “Kpọọ nwanyị Shunem.” Ya mere, ọ kpọrọ ya. Mgbe ọ bịakwutere ya, ọ sịrị, “Kuru nwa gị.”  
\v 37 Ọ batara, daa nʼala nʼụkwụ ya, kpọọ isiala. Emesịa, o kuuru nwa ya nwoke pụọ. 
\s1 Ọnwụ dị nʼite nri 
\p  
\v 38 Ịlaisha lọghachiri na Gilgal, mgbe ụnwụ dị nʼala ahụ. Otu ụbọchị, mgbe ya na ụfọdụ ndị amụma nọ na-enwe nzukọ, ọ gwara onye na-ejere ya ozi okwu sị ya: “Sikwasị ite ukwu ahụ nʼọkụ, siere ndị a mụ na ha nọ ihe oriri.” 
\p  
\v 39 Otu onye nʼime ha pụrụ banye nʼọhịa ịchịkọta akwụkwọ nri. Ọ hụrụ osisi vaịnị toro nʼọhịa, chịkọtaa ụfọdụ afụfa ọhịa,\f + \fr 4:39 \ft Mkpụrụ afụfa ọhịa yiri kukumba nʼọdịdị, buo ibu dịka oroma ma ọ na-elu ilu nʼọnụ.\f* nke o kpojuru nʼuwe mwụda ya dịka ọ ga-ejideli. Mgbe ọ lọghachiri, o gbupịasịrị afụfa ọhịa ndị a, wụnye ha nʼime ite ahụ si nʼọkụ, ọ bụ ezie na o nweghị onye maara ihe ha bụ.  
\v 40 Mgbe o ghere, a wụpụtara ya nye ndị ikom ndị ahụ. Ma mgbe ha bidoro iri ya, ha tiri mkpu akwa sị, “Onye nke Chineke, lee, ọnwụ dị nʼite nri a.” Ha enwekwaghị ike iri ya. 
\p  
\v 41 Ịlaisha kwuru okwu sị, “Kpotanụ ụtụ ọka.” Ọ ghanyere ya nʼime ite ahụ sị, “Kunyerenụ ha nri ka ha rie.” Ha riri ya. O nwekwaghị ihe na-egbu egbu dị nʼite ahụ. 
\s1 Ịlaisha enye narị ndị amụma nri 
\p  
\v 42 Otu nwoke si Baal-Shalisha bịa, butere onye nke Chineke ogbe achịcha iri abụọ nke e ji ọka balị mbụ a ghọtara nʼubi mee. O butekwaara ya isi ọka ole na ole nʼakpa. Ịlaisha sịrị, “Were ihe ndị a nye ndị anyị ka ha rie.” 
\p  
\v 43 Onye na-ejere ya ozi jụrụ, “Olee otu m ga-esi chee ihe a nʼihu narị mmadụ?” 
\p Ma Ịlaisha zara, “Chịrị ya nye ndị mmadụ a ka ha rie, nʼihi na otu a ka \nd Onyenwe anyị\nd* kwuru, ‘Ha ga-eriju afọ ha, nwekwa ndị ga-afọdụkwa.’ ”  
\v 44 Ya mere, o chere ya nʼihu ha, ha rikwara, nri ahụ fọdụkwara dịka okwu \nd Onyenwe anyị\nd* si dị. 
\c 5  
\s1 Neeman onye ekpenta 
\p  
\v 1 Nʼoge a, Neeman bụ ọchịagha ndị agha eze Aram,\f + \fr 5:1 \ft Aha eze a, bụ Ben-Hadad nke abụọ \xt 2Ez 8:7\f* Ọ bụ onye dị ukwuu nʼanya nna ya ukwu, bụrụkwa onye a na-enye nsọpụrụ nʼihi na \nd Onyenwe anyị\nd* sitere nʼaka ya nye ndị agha Aram mmeri nʼọgbọ agha dị iche iche. Ọ bụ dike na dimkpa nʼagha, maọbụ onye ekpenta. 
\p  
\v 2 Otu mgbe, ụfọdụ nʼime ndị agha Aram na-apụnara ndị mmadụ ihe pụrụ ga dọta otu nwaagbọghọ nta site nʼIzrel, onye na-ejere nwunye Neeman ozi.  
\v 3 Ọ sịrị nne ya ukwu, “Ọ gaara atọ m ụtọ ma a sị na nna m ukwu ga-aga hụ onye amụma nọ na Sameria. Ọ ga-agwọ ya ọrịa ekpenta a.” 
\p  
\v 4 Neeman nụrụ nke a, bilie gaa kọọrọ eze Aram ihe niile nwaagbọghọ a si Izrel kwuru.  
\v 5 Eze Aram sịrị, “Bilie, gaa, aga m ezigakwara eze Izrel\f + \fr 5:5 \ft Aha eze a, bụ Joram. \xt 2Ez 8:28\f* akwụkwọ ozi.” Ya mere Neeman gara, ọ chịịrị talenti ọlaọcha iri, na puku shekel ọlaedo isii, na uwe ọma dị iche iche, nke dị iri nʼọnụọgụgụ.  
\v 6 Nke a bụkwa ihe dị nʼime akwụkwọ ahụ eze Aram degaara eze Izrel: “Nwoke a ji akwụkwọ a bịakwute gị bụ Neeman, onyeisi ndị agha m. Biko, achọrọ m ka ị gwọọ ya ọrịa ekpenta dị ya nʼahụ.” 
\p  
\v 7 Ngwangwa eze Izrel gụrụ akwụkwọ ahụ, ọ dọwara uwe ya sị, “Abụ m Chineke? A pụrụ m ime ka mmadụ nwụọ na ime ka mmadụ dị ndụ? Gịnị mere nwoke a ji ezitere m onye m ga-agwọ ọrịa ekpenta? Lee ka o si na-achọ ụzọ anyị ga-eji nwee esemokwu.” 
\p  
\v 8 Mgbe Ịlaisha onye Chineke nụrụ na eze Izrel dọwara uwe ya, o ziri ozi a zigara ya sị, “Gịnị mere i ji dọwaa uwe gị? Zitere m Neeman. Ọ ga-amatakwa na e nwere onye amụma nʼIzrel.”  
\v 9 Ya mere, Neeman bịarutere guzo nʼọnụ ụzọ ụlọ Ịlaisha, ya na ịnyịnya ya, na ụgbọ agha ya.  
\v 10 Ịlaisha zigara onyeozi ya nke bịara zie sị ya, “Jee saa ahụ gị ugboro asaa nʼosimiri Jọdan. I mee nke a, ekpenta ahụ ga-esi nʼakụkụ ahụ gị niile pụọ. Ị ga-adịkwa ọcha.” 
\p  
\v 11 Ma Neeman were iwe nke ukwuu tụgharịa bido ịlaghachi ebe o si bịa. Mgbe ọ na-ala, ọ na-ekwu na-asị, “Echere m na ọ ga-apụkwute m, guzo, kpọkuo aha \nd Onyenwe anyị\nd* Chineke ya, fufee aka ya nʼebe ahụ ọrịa m dị, gwọọ m ọrịa ekpenta m.  
\v 12 Abana\f + \fr 5:12 \ft A na-akpọkwa ya Amana\f* na Fapa, bụ osimiri dị na Damaskọs, ha adịghị mma karịa mmiri Izrel niile? Ọ bụ na m enweghị ike ịsa ahụ nʼime ha ma dị ọcha.” Ọ tụgharịrị jiri ọnụma pụọ. 
\p  
\v 13 Ma ndị ozi Neeman jekwuru ya sị ya, “Nna anyị, a sị na ọ bụ ihe sịrị ike nke ukwuu ka onye amụma ahụ gwara gị sị gị mee, ị garaghị eme ya? Ma ihe ọ sị gị mee bụ naanị ‘Gaa saa ahụ gị ka ị dị ọcha.’ ”  
\v 14 Ya mere, ọ gara sụnye onwe ya nʼime osimiri Jọdan ugboro asaa, dịka onye nke Chineke gwara ya. Anụ ahụ ya lọghachiri dị ọcha ka anụ ahụ nwantakịrị. 
\p  
\v 15 Mgbe ahụ, Neeman na ndị niile ya na ha so laghachikwutere onye nke Chineke. O guzoro nʼihu ya sị, “Ugbu a amatala m na ọ dịghị Chineke ọzọ dị nʼụwa niile ma ọ bụghị naanị nʼIzrel. Ya mere, biko, nara onyinye a site nʼaka ohu gị.” 
\p  
\v 16 Ma Ịlaisha zara sị ya, “Dịka \nd Onyenwe anyị\nd* na-adị ndụ, bụ onye m na-ejere ozi, agaghị m ana gị ihe ọbụla.” Ma Neeman rịọrọ ya arịrịọ ka ọ nara ya, ma ọ jụrụ ajụ. 
\p  
\v 17 Mgbe ahụ Neeman sịrị, “Ọ bụrụ na ị gaghị anara, biko, kwerenụ ka m kporo aja nke ịnyịnya abụọ nwere ike ibu. Nʼihi na site ugbu a gaa nʼihu, agaghị m achụrụ chi ọzọ aja nsure ọkụ, ma ọ bụghị naanị \nd Onyenwe anyị\nd*.  
\v 18 Ma ka \nd Onyenwe anyị\nd* gbaghara ohu gị naanị otu ihe a. Mgbe nna m ukwu banyere nʼụlọ arụsị Rimọn ịkpọ isiala, mgbe ọ na-adabere nʼaka m, nke ga-eme ka mụ onwe m kpọọkwa isiala. Mgbe m si otu a kpọọ isiala nʼụlọ arụsị Rimọn, ka \nd Onyenwe anyị\nd* gbaghara ohu gị nʼihi nke a.” 
\p  
\v 19 Ịlaisha zara sị ya, “Ọ dị mma, laa nʼudo.” 
\p Mgbe Neeman lawara, o jerubeghị ebe dị anya,  
\v 20 Gehazi, bụ onyeozi Ịlaisha onye nke Chineke, sịrị nʼobi ya, “Nna m ukwu emezighị ikwere ka Neeman onye Aram laa na-anataghị ya ihe o ji bịa. Dịka \nd Onyenwe anyị\nd* na-adị ndụ, aga m eji ọsọ gbakwuru ya napụta ya ụfọdụ ihe ahụ.” 
\p  
\v 21 Ya mere, Gehazi gbara ọsọ gbakwuru Neeman. Mgbe Neeman hụrụ ya ka ọ gba ọsọ na-abịa, o si nʼelu ụgbọ agha ya wudata gaa zute ya, jụọ ya sị: “Udo ọ dịkwa?” 
\p  
\v 22 “E, udo dị,” ka Gehazi zara, “Onyenwe m zitere m ka m gwa gị, ‘Lee, ụmụ okorobịa abụọ nʼetiti ndị amụma si nʼugwu Ifrem bịakwute m. Biko nye ha otu talenti ọlaọcha na uwe mgbanwe abụọ.’ ” 
\p  
\v 23 Ma Neeman zara sị ya, “Biko, were talenti abụọ.” Ọ kwagidere Gehazi ka ọ nara ha. O kechiri talenti ọlaọcha abụọ ahụ nʼakpa abụọ, tinyere uwe mgbanwe abụọ. O bunyere ndị ohu ya ka ha buru ya na-aga nʼihu Gehazi.  
\v 24 Ma mgbe ha rutere nʼugwu, Gehazi naara ndị ohu Neeman ihe ndị ahụ, sị ha laghachikwa. O zoro ihe ndị ahụ nʼime ụlọ. 
\p  
\v 25 Mgbe ọ batara nʼụlọ guzo nʼihu nna ya ukwu, Ịlaisha jụrụ ya sị, “Ebee ka i si na-abịa Gehazi?” 
\p Ọ zara, “Ohu gị ejeghị ebe ọbụla.” 
\p  
\v 26 Mgbe ahụ Ịlaisha zara ya, “Ọ bụ na mmụọ m esoghị gị mgbe nwoke ahụ si nʼụgbọ ya rịdata izute gị? Oge a ọ bụ oge ịnara ego, na ịnara uwe, na ịnara ubi oliv, na ubi vaịnị, na igwe ehi, na igwe atụrụ, na ndị ohu ndị ikom, na ndị ohu ndị inyom na-eje ozi?  
\v 27 Nʼihi nke a, ekpenta ahụ dị Neeman ga-abịakwasị gị, na ụmụ ụmụ gị, ruo mgbe ebighị ebi.” Ya mere, Gehazi ghọrọ onye ekpenta si nʼihu ya pụọ. Anụ ahụ ya bidokwara ịcha ọcha dịka ogho ọcha. 
\c 6  
\s1 Isi anyụike esee nʼelu mmiri 
\p  
\v 1 Ụmụ ndị amụma gwara Ịlaisha okwu sị, “Lee, ebe a anyị bi nʼihu gị dị oke nta karịa.  
\v 2 Ya mere, ka anyị gaa nʼakụkụ Jọdan gbute osisi anyị ga-eji wuo ụlọ ebe anyị ga-ebi.” 
\p Ọ sịrị ha, “Meenụ ka unu kwuru.” 
\p  
\v 3 Ma otu onye nʼime ha rịọrọ ya sị, “Biko, nna anyị ukwu, soronụ anyị.” 
\p O kwenyere na ọ ga-eso ha.  
\v 4 O sonyekwara ha. 
\p Mgbe ha bịaruru nʼakụkụ Jọdan, ha malitere igbutu osisi.  
\v 5 Ma mgbe otu nʼime ha nọ na-egbutu otu osisi, anyụike ya dabara nʼime mmiri. O tiri mkpu sị, “Ewoo, onyenwe m. Ọ bụkwanụ ihe a rịọtara arịọta.” 
\p  
\v 6 Mgbe ahụ, onye nke Chineke jụrụ ya sị, “Ebee ka ọ dabara?” Mgbe o ziri ya ebe ọ dabara, Ịlaisha gbutere osisi tụba ya nʼebe ahụ, mee ka anyụike ahụ segolite na-erugharị nʼelu mmiri.  
\v 7 Ọ sịrị, “Tụtụlite ya.” O setịrị aka ya wepụta ya. 
\s1 Ìsì ekpuo ndị agha Siria 
\p  
\v 8 Nʼoge a, eze ndị Aram\f + \fr 6:8 \ft Nke bụ Ben-Hadad nke abụọ\f* na ndị Izrel nọ nʼagha. Mgbe ya na ndịisi agha ya kparịtachara, ọ sịrị, “Aga m eguzobe ọmụma ụlọ ikwu m nʼebe dị otu a na nʼebe dị otu a.” 
\p  
\v 9 Ngwangwa, onye nke Chineke zigaara eze Izrel\f + \fr 6:9 \ft Onye a na-akpọ Joram\f* ozi sị, “Lezie anya, unu ejekwala nso nʼebe ahụ, nʼihi na eze Aram na ndị agha ya nọ nʼebe ahụ.”  
\v 10 Nʼihi nke a, eze Izrel mere nchọpụta banyere ebe ahụ onye nke Chineke gwara ya. Ọtụtụ mgbe Ịlaisha dọrọ eze aka na ntị, nʼihi ya, ha nọrọ na nche nʼebe ahụ niile. 
\p  
\v 11 Ihe ndị a mere ka iwe wee eze ndị Aram. Ọ kpọkọtara ndịisi ọrụ ya nye ha iwu sị, “Gwanụ m, onye nʼime anyị dịnyere eze Izrel?” 
\p  
\v 12 Otu onye nʼime ndị ọchịagha ya sịrị, “O nweghị onye ọbụla nʼime anyị, onyenwe m bụ eze. Ọ bụ Ịlaisha, onye amụma Izrel, bụ onye na-agwa eze Izrel okwu niile i na-ekwu nʼime ebe ndina gị.” 
\p  
\v 13 Ya mere, eze Aram nyere ha iwu sị ha, “Gaanụ, chọpụta ebe ọ nọ, ka m ziga ndị agha ga-aga jide ya.” Ha gara lọta, kọọrọ ya na Ịlaisha nọ na Dọtan.  
\v 14 Nʼihi ya, nʼotu anyasị eze Aram zigara ọtụtụ ndị agha ya, ndị ji ịnyịnya na ụgbọ agha gbaa obodo ahụ gburugburu. 
\p  
\v 15 Mgbe onye na-ejere onye nke Chineke ozi biliri ọtọ nʼisi ụtụtụ pụọ, ọ hụrụ ọtụtụ ndị agha na ịnyịnya na ụgbọala, ka ha gbara obodo ha nọ gburugburu. O tiri mkpu sị, “Ewoo, onyenwe m, gịnị ka anyị ga-eme ugbu a?” 
\p  
\v 16 Ma Ịlaisha zara sị ya, “Atụla egwu, nʼihi na ndị nọnyere anyị dị ọtụtụ karịa ndị nọnyeere ha.” 
\p  
\v 17 Mgbe ahụ, Ịlaisha kpere ekpere sị, “\nd Onyenwe anyị\nd*, biko, saghee anya ya abụọ ka ọ hụ.” \nd Onyenwe anyị\nd* meghere anya ohu Ịlaisha, mee ka ọ hụ ịnyịnya ọkụ, na ụgbọala ọkụ jupụtara nʼugwu dị gburugburu ebe ahụ niile. 
\p  
\v 18 Mgbe ndị iro ahụ na-abịaru ya nso, Ịlaisha kpọkuru \nd Onyenwe anyị\nd* nʼekpere sị, “Mee ka ìsì kpuo ndị agha niile.” O mekwara ka ìsì kpuo ha, dịka Ịlaisha rịọọrọ. 
\p  
\v 19 Ịlaisha pụtara sị ha, “Nke a abụghị ụzọ, nke a abụkwaghị obodo unu na-achọ. Soronụ m, ka m gosi unu nwoke unu na-achọ.” O duuru ha jee Sameria. 
\p  
\v 20 Mgbe ha bịaruru Sameria, Ịlaisha kpere ekpere sị, “Biko, \nd Onyenwe anyị\nd*, ugbu a meghee anya ha, ka ha hụ ụzọ.” \nd Onyenwe anyị\nd* meghere anya ha dịka Ịlaisha kpere nʼekpere; ha matakwara na ha nọ na Sameria. 
\p  
\v 21 Mgbe eze Izrel hụrụ ha, ọ jụrụ Ịlaisha ajụjụ sị, “Nna m, ị chọrọ ka m gbuo ha?” 
\p  
\v 22 Ịlaisha zara sị ya, “Egbula ha. Ị ga-egbu ndị i ji mma agha na ụta gị dọta nʼagha? Nye ha nri na mmiri, zilaga ha ka ha lakwuru onyenwe ha.”  
\v 23 Ya mere, ọ kwadooro ha oke oriri dị ukwuu, mgbe ha riri, ṅụkwaa, o zilagara ha, ha lakwuuru nna ha ukwu. Site nʼoge ahụ gaa nʼihu, ndị otu Aram na-apụnara mmadụ ihe kwusịrị inye nsogbu nʼoke ala ndị Izrel. 
\s1 Ụnwụ nʼobodo Sameria 
\p  
\v 24 Ma mgbe ụfọdụ oge gasịrị, Ben-Hadad, eze Aram, chịkọtara ndị agha ya niile pụta bịa gbaa Sameria gburugburu.  
\v 25 Nʼihi nke a, oke ụnwụ dara nʼobodo Sameria. Nri kọrọ nʼala ahụ ruo na e bidoro ire otu isi ịnyịnya ibu\f + \fr 6:25 \ft Ịnyịnya ibu so nʼanụ ụmụ Izrel na-ekwesighị iri nʼihi na ọ dịghị ọcha. \xt Lev 11:4\f* iri shekel ọlaọcha asatọ. E rekwara nsị nduru shekel ise. 
\p  
\v 26 Mgbe eze Izrel na-agafe nʼelu mgbidi gbara obodo ahụ gburugburu, otu nwanyị kpọkuru ya sị ya, “Nyere m aka, onyenwe m eze.” 
\p  
\v 27 Ma eze zara sị ya, “Ọ bụrụ na \nd Onyenwe anyị\nd* ekweghị inyere gị aka, ebee ka m ga-esi nwetara gị inyeaka? Ọ bụ site nʼebe ịzọcha ọka? Ka ọ bụ nʼebe ịzọcha mmanya vaịnị?”  
\v 28 Mgbe ahụ, eze jụrụ ya sị, “Gịnị na-eme?” 
\p Ọ zara, “Nwanyị a sịrị, ‘Nye nwa gị nwoke ka anyị rie ya taa, echi anyị ga-eri nwa m nwoke.’  
\v 29 Ya mere, na anyị siri nwa m rie ya. Nʼụbọchị nke so ya asịrị m ya, ‘Wepụta nwa gị nwoke ka anyị rie ya,’ ma o zoola ya.” 
\p  
\v 30 Mgbe eze nụrụ okwu nwanyị a, ọ dọwara uwe ya. Ma dịka ọ na-agabiga nʼelu mgbidi ahụ, ndị mmadụ lere anya hụ nʼokpuru uwe, akwa mkpe dị nʼime ahụ ya.  
\v 31 Ọ sịrị, “Ka Chineke mesoo m mmeso, otu ọbụla mmeso ahụ si dị njọ, ma ọ bụrụ na isi Ịlaisha nwa Shafat anọgide nʼahụ ya taa.” 
\p  
\v 32 Nʼoge a, Ịlaisha nọdụrụ ala nʼụlọ ya, ndị okenye sokwa ya nọdụ. Eze zipụrụ onyeozi, ma tupu o rute, Ịlaisha gwara ndị okenye ahụ okwu sị ha, “Unu ahụla na ogbu mmadụ a ezitela mmadụ ka ọ bịa gbupụ m isi. Mgbe onyeozi ya bịaruru, mechienụ ụzọ hapụ ya nʼezi, nʼihi na eze nʼonwe ya ga-eso ya nʼazụ bịa.”  
\v 33 Mgbe Ịlaisha nọ na-agwa ha okwu, lee onyeozi ahụ ka ọ na-abịakwute ya. 
\p Eze sokwa ya nʼazụ na-ekwu okwu na-asị, “\nd Onyenwe anyị\nd* emeela ka ihe ọjọọ dị otu a dakwasị anyị. Gịnị mere m ga-eji lee anya inyeaka site nʼaka \nd Onyenwe anyị\nd* ọzọ?” 
\c 7  
\p  
\v 1 Ịlaisha zara sị ya,\f + \fr 7:1 \ft \xt 2Ez 6:24-29\f* “Nụrụ okwu \nd Onyenwe anyị\nd*. Nʼihi na otu a ka \nd Onyenwe anyị\nd* na-ekwu,\f + \fr 7:1 \ft \xt 2Ez 7:18-19\f* Nʼoge dịka mgbe a echi, a ga-ere otu akpa nta ụtụ ọka otu shekel, rekwaa akpa nta ọka balị abụọ otu shekel nʼọnụ ụzọ ama obodo Sameria.” 
\p  
\v 2 Ọchịagha ahụ, nke eze na-adabere nʼaka ya, sịrị onye nke Chineke, “Lee, a sịkwarị na \nd Onyenwe anyị\nd* emeghee oghere idee nke eluigwe, nke a ọ pụrụ ime?” 
\p Ma Ịlaisha zara ya, “Ị ga-eji anya gị abụọ hụ ya, ma ị gaghị eri site nʼime ya.” 
\s1 Ọgbaaghara nʼogige agha ndị Sameria 
\p  
\v 3 Nʼoge a, e nwere ndị ekpenta\f + \fr 7:3 \ft Onye ọbụla na-arịa ọrịa ekpenta a gaghị ebi nʼime obodo nʼetiti ụmụ mmadụ. \xt Lev 13:45-46; Ọnụ 5:2-4; 12:10.\f* anọ nọ nʼezi mgbidi gbara Sameria gburugburu, nʼakụkụ ọnụ ụzọ e si abata obodo ahụ. Ha sịrịtara onwe ha, “Gịnị ka anyị nọ nʼebe a na-eme? Ọ bụ ka anyị nọrọ nʼebe a tutu anyị anwụọ?  
\v 4 Ọ bụrụ na anyị asị, ‘Anyị ga-abanye nʼime obodo,’ ụnwụ dị nʼebe ahụ, anyị ga-anwụkwa. Ọ bụrụkwanụ na anyị anọgide nʼebe a anyị ga-anwụ. Ya mere ka anyị gafeenụ banye nʼọmụma ụlọ ikwu ndị agha Aram, were onwe anyị nyefee ha nʼaka. Ọ bụrụ na ha edebe anyị ndụ, anyị ga-adị ndụ, ọ bụrụ na ha egbuo anyị, anyị ga-anwụkwa.” 
\p  
\v 5 Nʼoge uhuruchi, ha biliri gaa nʼọmụma ụlọ ikwu ndị agha Aram. Mgbe ha bịarutere nʼọnụ ụlọ ikwu ahụ, o nwekwaghị onye nọ nʼebe ahụ,  
\v 6 nʼihi na Onyenwe anyị mere ka ndị Aram nụ ụzụ ụgbọ agha na nke ịnyịnya, na nke usuu ndị agha. Nke a mere ka onye ọbụla gwa ibe ya sị, “Lee, eze ndị Izrel egoola ndị agha ndị Het, na ndị eze Ijipt ibuso anyị agha.”  
\v 7 Ha biliri gbapụ ọsọ nʼabalị ahụ, hapụ ụlọ ikwu ha niile, na ịnyịnya ha niile, na ịnyịnya ibu ha niile, na ihe niile otu o si dịrị, ma gbapụ ọsọ ndụ. 
\p  
\v 8 Mgbe ndị ekpenta ahụ rutere ogige ndị agha ndị Siria, ha banyere nʼime otu ụlọ rie ihe, ṅụkwaa ihe ọṅụṅụ dị nʼime ya. Ha chịịrị ọlaọcha na ọlaedo na uwe ọma niile dị nʼime ya gaa zoo ha. Ọzọkwa, ha lọghachiri banye nʼụlọ ọzọ kwakọrọ ụfọdụ ihe dị nʼime ya gaa zoo. 
\p  
\v 9 Ma mgbe ahụ ha sịrịtara onwe ha, “Ihe anyị na-eme ezighị ezi. Taa bụ ụbọchị oziọma, ma lee ka anyị na-agba nkịtị. Ọ bụrụ na anyị echere ruo ìhè ụtụtụ, a ga-achọpụta ajọọ omume anyị. Ugbu a bịanụ, ka anyị gaa gwa ndị nọ nʼụlọeze, ihe anyị hụrụ.” 
\p  
\v 10 Ya mere, ha gara kpọkuo ndị nche ọnụ ụzọ obodo ahụ, gwa ha sị, “Anyị banyere nʼogige ndị agha Aram, o nweghị mmadụ ọbụla nọ nʼebe ahụ, ọ dịghị olu mmadụ anyị nụrụ nʼebe ahụ, naanị ịnyịnya na ịnyịnya ibu elibere nʼosisi, na ụlọ ikwu ha a hapụrụ dịka ha dị.”  
\v 11 Ndị na-eche nche tiri mkpu kọọrọ ndị nọ nʼụlọeze ihe mere. 
\p  
\v 12 Eze biliri nʼabalị ahụ gwa ndịisi ọrụ ya sị, “Ka m gwa unu ihe ndị Aram mere anyị. Ha maara na anyị nọ nʼoke agụụ, nʼihi ya, ha akpacharala anya hapụ ọmụma ụlọ ikwu ha gaa zoo onwe ha nʼime ọhịa. Echiche ha bụ, ‘Ndị a ga-apụtarịrị, mgbe ahụ, anyị ga-ejide ha na ndụ, banyekwa nʼime obodo ha.’ ” 
\p  
\v 13 Ma otu onye nʼime ndịisi agha ya zara sị ya, “Ka ụfọdụ mmadụ duru ịnyịnya ise ndị ahụ fọdụrụ nʼobodo. Ọ bụrụ na ndị a alọtaghị ọnọdụ ha ga-adị ka nke ndị Izrel niile fọdụrụ nʼebe, e, ha ga-adị ka ndị Izrel niile a gụrụ dịka ndị nwụrụ anwụ. Ya mere, ka anyị zipụ ha ka ha gaa chọpụta ihe mere.” 
\p  
\v 14 Ya mere, ha họpụtara ụgbọ agha abụọ na ịnyịnya ndị na-adọkpụ ha. Eze zipụrụ ha ịchụso ndị agha Aram, O nyere ndị na-agba ha iwu sị, “Gaanụ chọpụta ihe mere.”  
\v 15 Ha sogidere ha ruo nʼosimiri Jọdan. Nʼakụkụ ụzọ niile jupụtara nʼuwe na ngwa agha ndị agha Aram tufuru mgbe ha na-eme ngwangwa. Ndị ahụ e zipụrụ lọghachiri bịa kọọrọ eze ihe ha hụrụ.  
\v 16 Ndị Izrel niile pụrụ gaa kwakọrọ ihe dị nʼọmụma ụlọ ikwu ndị Aram. Nke bụ na e rere otu akpa nta ụtụ ọka a kwọrọ nke ọma otu shekel, rekwaa akpa ọka balị abụọ otu shekel dịka \nd Onyenwe anyị\nd* si kwuo. 
\p  
\v 17 Eze họpụtara ọchịagha ahụ, nke ọ na-adabere nʼaka ya, nye ya ọrụ ilekọta ọnụ ụzọ obodo ahụ. Ma ndị si nʼobodo na-enupụta nuturu ya, zọọ ya ụkwụ, zọgbuo ya mgbe ha na-agbapụta.\f + \fr 7:17 \ft Amụma ahụ mezuru nʼisi ọchịagha eze dịka e kwuru ya. \xt 2Ez 7:2\f* Ọ nwụrụ dịka Ịlaisha onye nke Chineke kwuru mgbe eze bịakwutere ya ụnyaahụ, ijide ya.  
\v 18 Ihe niile mezuru dịka onye nke Chineke gwara eze okwu sị ya, “A ga-ere akpa nta ọka balị abụọ otu shekel na otu akpa nta ụtụ ọka otu shekel, nʼọnụ ụzọ ama Sameria.” 
\p  
\v 19 Nʼoge ahụ, ọchịagha ahụ na-ejere eze ozi zara sị ya, “Ihe dị otu a agaghị eme, ọ bụladị na \nd Onyenwe anyị\nd* emeghee eluigwe mee ka nri zoo, nke a ọ ga-eme?” Ma onye nke Chineke zara ya, “Ị ga-eji anya gị hụ ya, ma ị gaghị eso rie ya.”  
\v 20 Ọ bụkwa otu a ka o si mee, nʼihi na ndị mmadụ zọgburu ya nʼụkwụ nʼọnụ ụzọ ama, ebe ọ nọ nwụọ. 
\c 8  
\s1 Nlọghachi nwanyị Shunem 
\p  
\v 1 Ịlaisha gwara nwanyị ahụ o mere ka nwa ya si nʼọnwụ bilie okwu sị ya, “Bilie, gị na ezinaụlọ gị, gaa nʼobodo ọzọ ebe unu ga-anọ dịka ọbịa nʼihi na \nd Onyenwe anyị\nd* ekwuola na oke ụnwụ ga-adakwasị ala Izrel afọ asaa.”  
\v 2 Nwanyị ahụ mere dịka onye nke Chineke gwara ya, o biliri, ya na ezinaụlọ ya gaa biri nʼala ndị Filistia\f + \fr 8:2 \ft Ọ bụghị naanị nʼala Filistia na-emepụta nri karịa ala ugwu ugwu Izrel, kama ndị agha Siria adịghị e buso ha agha mgbe mgbe, dịka ha na-eme ndị Izrel.\f* afọ asaa. 
\p  
\v 3 Mgbe ụnwụ ahụ gwụsịrị nʼafọ nke asaa, o si nʼala ndị Filistia lọta nʼIzrel. Mgbe ọ lọtara, o jekwuuru eze ka o nyere ya aka inwetaghachi ụlọ ya na ala ya.  
\v 4 Mgbe nwanyị ahụ bịakwutere eze, eze nọ na-agwa Gehazi bụ onye na-ejere onye nke Chineke ozi okwu sị ya, “Biko, kọọrọ m akụkọ ihe ukwu niile Ịlaisha mere.”  
\v 5 Mgbe Gehazi na-akọrọ eze otu Ịlaisha si mee ka nwantakịrị nwụrụ anwụ dị ndụ ọzọ, nwanyị ahụ, onye bụ nne nwantakịrị ahụ, batara nʼime ụlọeze. 
\p Mgbe ahụ, Gehazi kwuru sị, “Onyenwe m eze, onye a bụ nwanyị ahụ, leekwa nwa ya nwoke, onye Ịlaisha mere ka ọ dị ndụ ọzọ.”  
\v 6 Eze jụrụ nwanyị ahụ ajụjụ sị ya, “Ọ bụ eziokwu?” Nwanyị ahụ kọọrọ eze akụkọ ihe niile mere. 
\p Mgbe ahụ, eze dunyere ya otu onyeisi nʼime ndị ozi ya ka o nyere ya aka inwetaghachi ihe ya niile, ya na ụgwọ ruru ya nʼihi mkpụrụ ubi ya niile ha ghọrọ mgbe ahụ o bi nʼala ndị Filistia. 
\s1 Hazael egbuo Ben-Hadad 
\p  
\v 7 Mgbe ihe ndị a gasịrị Ịlaisha gara Damaskọs, isi obodo ndị Siria. Nʼoge a, Ben-Hadad eze Aram, na-arịa ọrịa. “A gara gwa eze na onye nke Chineke abịala nʼebe ahụ.”  
\v 8 Mgbe eze nụrụ ya, ọ kpọrọ Hazael sị ya, “Were onyinye ịnata ihuọma nʼaka gị wegara onye nke Chineke, site nʼaka ya jụta \nd Onyenwe anyị\nd* ase. Jụọ ya, ‘M ga-esi nʼọrịa a bilie?’ ” 
\p  
\v 9 Hazael weere iri ịnyịnya kamel anọ buru ezi ihe niile si nʼala Damaskọs,\f + \fr 8:9 \ft Damaskọs, bụ isi obodo dị mkpa ebe a na-azụ ahịa, nke dị nʼetiti mba Ijipt, na Eshịa nke mpaghara Tọki na Mesopotamịa.\f* wetara Ịlaisha onyinye ndị a sị ya, “Nwa gị Ben-Hadad, eze Aram, zitere ka m jụọ gị sị, ‘M ga-esi nʼọrịa a bilie?’ ” 
\p  
\v 10 Ịlaisha zara sị ya, “Laa, gaa gwa ya sị ya, ‘Ị ga-esi nʼọrịa bilie.’ Ma \nd Onyenwe anyị\nd* egosila m na, nʼezie, ọ ga-anwụ.”  
\v 11 Mgbe Ịlaisha nọ na-ekwu okwu a, o legidere Hazael anya nʼihu tutu ruo mgbe ihere mere ya. Mgbe ahụ, onye nke Chineke kwara akwa. 
\p  
\v 12 Mgbe ahụ, Hazael jụrụ Ịlaisha ajụjụ sị, “Ọ bụ gịnị mere onyenwe m ji akwa akwa?” 
\p Ịlaisha zara sị ya, “Nʼihi na amaara m ihe ọjọọ ị ga-eme ụmụ Izrel nʼoge dị nʼihu. Ị ga-akpọ obodo niile ha e wusiri ike ọkụ, jiri mma agha gbuo ụmụ okorobịa ha. Ị ga-atụpịa ụmụntakịrị na-aṅụ ara, bọwakwaa afọ ndị inyom dị ime.” 
\p  
\v 13 Hazael sịrị, “Olee otu ọrụ gị, bụ nkịta efu, ga-esi nwee ike imezu ihe ukwuu a?” 
\p Ịlaisha zara, “\nd Onyenwe anyị\nd* egosila m na ị ga-abụ eze Aram.” 
\p  
\v 14 Mgbe Hazael, si nʼebe Ịlaisha nọ laa, ọ bịakwutere nna ya ukwu. Mgbe Ben-Hadad jụrụ ya sị, “Gịnị ka Ịlaisha gwara gị?” Hazael zara sị, “Ọ gwara m na ị ga-esi nʼọrịa bilie.”  
\v 15 Ma nʼechi ya, Hazael chịịrị akwa na-egbo oyi, banye ya na mmiri jiri ya baa nʼebe eze dina, gbasaa ya nʼihu eze, tutu ruo mgbe ọ nwụrụ. Emesịa, Hazael ghọrọ eze nʼọnọdụ ya. 
\s1 Jehoram eze Juda 
\p  
\v 16 Nʼafọ nke ise nke ọchịchị Joram nwa Ehab eze Izrel, mgbe Jehoshafat bụ eze Juda, ka Jehoram nwa Jehoshafat malitere ọchịchị ya dịka eze Juda.  
\v 17 Ọ dị iri afọ atọ na abụọ mgbe ọ malitere ịbụ eze, ọ chịrị afọ asatọ na Jerusalem.  
\v 18 O soro ụzọ ndị eze Izrel dịka ụlọ Ehab mere, nʼihi na ọ lụrụ ada Ehab. O mere ihe dị njọ nʼanya \nd Onyenwe anyị\nd*.  
\v 19 Ma nʼagbanyeghị nke a, nʼihi ohu ya bụ Devid \nd Onyenwe anyị\nd* achọghị ibibi Juda. Nʼihi na o kwere nkwa ime ka oriọna dịịrị Devid na ụmụ ụmụ ruo mgbe ebighị ebi. 
\p  
\v 20 Nʼoge Jehoram bụ eze, ka Edọm si nʼokpuru Juda nupu isi, họpụtara onwe ha eze.  
\v 21 Ya mere, Jehoram\f + \fr 8:21 \ft Joram, nke a bụ ịkpọbiri aha a na nkenke\f* duuru ụgbọ agha ya niile gaa nʼobodo Zaịa. O biliri nʼabalị tigbuo ndị Edọm ahụ gbara ya na ndị ọchịagha ụgbọ agha ya gburugburu; ma ndị agha ya gbaghachiri azụ, laa nʼụlọ ha.  
\v 22 Ya mere, Edọm ka na-enupu isi megide Juda, ruo taa. 
\p Obodo Libna nupukwara isi nʼotu oge ahụ. 
\p  
\v 23 Akụkọ ihe niile Jehoram mere, e deghị ha nʼakwụkwọ akụkọ ihe ndị eze Juda mere nʼụbọchị ndụ ha?  
\v 24 Joram sooro ndị nna nna ya ha dina nʼọnwụ, e lie ya nʼebe e liri nna ya ha nʼobodo Devid. Ahazaya nwa ya ghọrọ eze nʼọnọdụ ya. 
\s1 Ahazaya eze Juda 
\p  
\v 25 Nʼafọ nke iri na abụọ nke ọchịchị Joram nwa Ehab, bụ eze Izrel, ka Ahazaya nwa Jehoram, bụ eze Juda malitere ịchị.  
\v 26 Ahazaya gbara iri afọ abụọ na abụọ mgbe ọ malitere ịbụ eze, ọ chịrị otu afọ na Jerusalem. Aha nne ya bụ Atalaya,\f + \fr 8:26 \ft Atalaya, bụ nwunye Joram, bụrụkwa nwa eze Ehab, onye Jezebel mụrụ ya. \xt 2Ih 21:6\f* nwa nwa Omri, eze Izrel  
\v 27 O soro ụzọ niile nke ndị ezinaụlọ Ehab, mee ihe dị njọ nʼanya \nd Onyenwe anyị\nd* dịka ezinaụlọ Ehab mere, nʼihi na ọ lụrụ nwanyị si nʼezinaụlọ Ehab. 
\p  
\v 28 Ahazaya sooro Joram nwa Ehab, gaa ibuso Hazael eze Aram\f + \fr 8:28 \ft Maọbụ, \fqa Siria\f* agha na Ramọt Gilead. Ndị Aram merụrụ Joram ahụ.  
\v 29 Ya mere, eze Joram lọghachitere na Jezril, ka a gwọọ ya mmerụ ahụ ndị Aram merụrụ ya na Ramọt, nʼagha nke ya na Hazael eze Aram lụrụ. 
\p Mgbe ahụ, Ahazaya nwa Jehoram eze Juda, gara Jezril ileta Joram nwa Ehab, nʼihi na e merụrụ ya ahụ. 
\c 9  
\s1 Jehu na ọnwụ Jezebel 
\p  
\v 1 Emesịa, Ịlaisha onye amụma, kpọrọ otu onye nʼime ụmụ ndị amụma sị ya, “Jikere, fanye ọnụ uwe mwụda gị nʼeriri ikere nʼukwu gị,\f + \fr 9:1 \ft Lit. \fqa belịt\f* werekwa karama mmanụ oliv a nʼaka gị, bịa ka ị gaa Ramọt Gilead.  
\v 2 I jeruo ebe ahụ, jee hụ Jehu nwa Jehoshafat, nwa Nimshi anya. Mee ka o bilie site nʼetiti ndị ha na ya nọ. Mekwaa ka gị na ya naanị baa nʼime ụlọ.  
\v 3 Were karama mmanụ wụkwasị ya nʼisi gwa ya okwu sị, ‘Otu a ka \nd Onyenwe anyị\nd* kwuru, eteela m gị mmanụ ịbụ eze Izrel.’ I mesịa, meghe ụzọ ọsịịsọ, sitekwa nʼebe ahụ gbapụ ọsọ.” 
\p  
\v 4 Nwokorobịa onye amụma ahụ gara Ramọt Gilead.  
\v 5 Mgbe o jeruru, ọ hụrụ ebe ọchịagha ahụ nọdụrụ nʼala nʼetiti ndịisi agha ibe ya. O kwuru sị, “Enwere m ozi m ga-ezi gị, ọchịagha.” 
\p Jehu jụrụ, “Ọ bụ onye nʼime anyị ka ị chọrọ izi ozi?” 
\p Ọ zara, “Ọ bụ gị ọchịagha.” 
\p  
\v 6 Jehu biliri baa nʼime ụlọ. Nwokorobịa onye amụma ahụ wụkwasịrị ya mmanụ nʼisi, sị ya, “Otu a ka \nd Onyenwe anyị\nd*, Chineke Izrel sịrị, ‘Eteela m gị mmanụ ịbụ eze ndị nke \nd Onyenwe anyị\nd*, bụ Izrel.  
\v 7 Ị ga-ekpochapụ ezinaụlọ Ehab, nna gị ukwu, aga m esi otu a bọtara onwe m ọbọ, nʼihi ọbara ndị ohu m, bụ ndị amụma na ọbara ndị ozi \nd Onyenwe anyị\nd* niile Jezebel wufuru.  
\v 8 Ezinaụlọ Ehab ga-abụ ihe lara nʼiyi. Nʼala Izrel, m ga-esite nʼezinaụlọ Ehab bipụ ndị ikom niile, maọbụ ohu maọbụ onye nwe onwe ya.  
\v 9 M ga-ala ụlọ Ehab nʼiyi, ka m si laa ezinaụlọ Jeroboam nwa Nebat nʼiyi, na dịka m si lakwaa ezinaụlọ Baasha, nwa Ahija nʼiyi.  
\v 10 Nkịta ga-erikwa anụ Jezebel nwunye Ehab na Jezril. Ọ dịkwaghị onye ga-eli ya.’ ” Mgbe o kwuchara okwu ndị a, onye amụma ahụ meghere ụzọ gbapụ ọsọ. 
\p  
\v 11 Jehu jekwuuru ndịisi agha ibe ya. Otu onye nʼime ha jụrụ ya sị, “Gịnị ka onye ara ahụ chọrọ bịa? Udo ọ dịkwa?” 
\p Jehu zara, “Unu maara onye ọ bụ, marakwa ụdị okwu ga-esi ya nʼọnụ pụta.” 
\p  
\v 12 Ha sịrị, “Ihe i kwuru abụghị eziokwu, gwa anyị ihe o kwuru.” 
\p Jehu sịrị, “Ihe ndị a ka ọ gwara m, ‘Otu a ka a \nd Onyenwe anyị\nd* kwuru, Eteela m gị mmanụ ịbụ eze Izrel.’ ” 
\p  
\v 13 Ngwangwa ha chịịrị uwe mgbokwasị ha niile doo ha nʼusoro nʼala ebe ahụ ka Jehu zọkwasị ha ụkwụ. Ha fụrụ opi ike tie mkpu sị, “Jehu bụ eze!” 
\s1 Jehu egbuo Joram na Ahazaya 
\p  
\v 14 Otu a ka Jehu nwa Jehoshafat, nwa Nimshi, si gbaa izu megide Joram. (Nʼoge a, Joram na ndị Izrel niile na-eche Ramọt Gilead nche, nʼihi Hazael eze Aram.)  
\v 15 Ma Joram bụ eze, laghachitere na Jezril ebe ọ nọ ka ahụ dị ya mma maka ahụ ndị Aram merụrụ ya mgbe ya na Hazael, eze Aram lụrụ agha. Ya mere, Jehu sịrị, “Ọ bụrụ na nke a bụ uche unu, ime m eze unu, unu ekwela ka onye ọbụla si nʼobodo a gbapụ, gaa Jezril kọọ akụkọ a.”  
\v 16 Mgbe ahụ, Jehu wụkwasịrị nʼelu ụgbọ agha ya gbaga Jezril, nʼihi na Joram nọ nʼebe ahụ na-ezu ike. Ma Ahazaya, bụ eze Juda gakwara ileta ya. 
\p  
\v 17 Mgbe onye nche nọ nʼụlọ elu Jezril hụrụ Jehu na ndị agha ya ka ha na-abịa, o tiri mkpu sị, “Lee, o nwere ndị agha na-abịa.” 
\p Joram eze Izrel nyere iwu sị, “Zipụ otu onye na-agba ịnyịnya ka ọ gaa zute ha jụọ ha sị, ‘Udo ọ dịkwa?’ ” 
\p  
\v 18 Onye ọgbaịnyịnya ahụ nọkwasịrị nʼelu ya gbapụ izute Jehu, sị, “Otu a ka eze sịrị, ‘Udo ọ dịkwa?’ ” 
\p Jehu zara, “Gịnị ka gị na udo nwekọrọ? Tụgharịa gaa soro m nʼazụ.” 
\p Onye nche ahụ ziri ozi sị, “Onyeozi ahụ ezutela ha, kama ọ naghị alọta.” 
\p  
\v 19 Eze zipụrụ onye ọgbaịnyịnya nke abụọ. Mgbe ọ bịakwutere ha ọ sịrị, “Otu a ka eze sịrị, ‘Udo ọ dịkwa?’ ” 
\p Jehu zara, “Gịnị ka gị na udo nwekọrọ? Chigharịa soro m nʼazụ.” 
\p  
\v 20 Onye ahụ nọ na-eche nche sịrị, “Ọ garuola ha nso, ma ọ dịghị alọghachitekwa azụ. Ma ọgbụgba ịnyịnya dịka ọ bụ Jehu nwa Nimshi, nʼihi na ọ na-agba ịnyịnya ya dịka onye na-ayị ara.” 
\p  
\v 21 Joram nyere iwu sị, “Kwadooro m ụgbọ agha m.” Mgbe a kwadooro ya, Joram eze Izrel, na Ahazaya, eze Juda, pụtara nọkwasị nʼụgbọ agha, onye ọbụla na nke ya, pụọ ịga izute Jehu. Ha zutere ya nʼoke ala ubi Nebọt, onye Jezril.  
\v 22 Mgbe Joram hụrụ Jehu, ọ jụrụ, “Ị bịara nʼudo? Udo ọ dịkwa, Jehu?” 
\p Jehu zara, “Olee otu udo ga-esi dịrị, ebe ọ bụ na ihe ọjọọ niile nke ikpere arụsị na mgbaasị nke Jezebel nne gị, jupụtara nʼebe niile.” 
\p  
\v 23 Joram chigharịrị ụgbọ agha ya bido ịgba ọsọ. Mgbe ọ na-agba ọsọ, o tiri mkpu kpọkuo Ahazaya sị ya, “Ahazaya, Aghụghọ dị, ọgbaaghara dị!” 
\p  
\v 24 Jehu jiri ike ya niile dọtịa ụta o ji nʼaka ya gba ya Joram. Ọ gbatara Joram àkụ ahụ nʼazụ. Àkụ ahụ sikwa ya nʼobi pụta. Nke a mere ka Joram daa nʼime ụgbọala ya nwụọ.  
\v 25 Mgbe ahụ, Jehu sịrị Bidka, bụ onyeisi agha ya, “Bulie ya, tụba ya nʼubi Nebọt onye Jezril. Chetakwa na mụ na gị nọkwasịrị nʼelu ịnyịnya, anyị abụọ, na-eso nna ya Ehab, mgbe \nd Onyenwe anyị\nd* kwuru okwu amụma a megide ya.  
\v 26 ‘Nʼezie, ahụrụ m ọbara Nebọt na ọbara ụmụ ya ndị ikom ụnyaahụ, otu a ka \nd Onyenwe anyị\nd* kwupụtara, nʼihi ya, aghaghị m ime ka ị kwụghachi ụgwọ ọbara ha nʼala ubi a.’ Ugbu a, bulie ya tụba ya nʼala ubi a dị ka okwu \nd Onyenwe anyị\nd* si dị.” 
\p  
\v 27 Mgbe Ahazaya eze Juda, hụrụ ihe mere, ọ gbaara ọsọ na-agbago nʼụzọ Bet Hagan. Ma Jehu chụsoro ya, na-eti mkpu sị, “Gbukwuonụ ya.” Ha merụrụ ya ahụ ka ọ nọ nʼụgbọ agha ya, nʼụzọ ịga Gua, nso Ibleam, ọ gbara ọsọ ga Megido ebe ọ nọ nwụọ.  
\v 28 Ndị ohu ya ji ụgbọ agha bịa buru ozu ya bubata ya na Jerusalem, lie ya nʼebe e liri nna nna ya ha, nʼobodo Devid.  
\v 29 Nʼafọ iri na otu nke ọchịchị Joram nwa Ehab, ka Ahazaya malitere ịbụ eze Juda. 
\s1 Ọnwụ Jezebel 
\p  
\v 30 Mgbe Jezebel nụrụ na Jehu abịaruola Jezril, ọ banyere nʼụlọ ya, tee uri nʼanya abụọ, dozie agịrị isi ya, pụta bịa nọdụ ala nʼakụkụ oghereikuku, site nʼebe ahụ na-elepụ anya nʼezi.  
\v 31 Mgbe Jehu batara nʼọnụ ụzọ e si abata ụlọeze, Jezebel kpọkuru ya sị, “Ị bịara nʼudo, gị Zimri, gị onye gburu nna gị ukwu.” 
\p  
\v 32 Jehu leliri anya elu lee anya na oghereikuku tie mkpu sị, “Onye dịnyeere m?” Onozi abụọ maọbụ atọ na-eje ozi nʼụlọeze lepụtara anya lee ya anya.  
\v 33 Jehu nyere ha iwu sị ha, “Tụdanụ ya nʼala.” Ya mere, ha si nʼelu ebe ahụ tụda ya nʼala. Mgbe ọ daruru ala, ọbara ya fesasịrị nʼahụ mgbidi ụlọ na nʼahụ ịnyịnya ndị ji ụkwụ ha zọjaa ya. 
\p  
\v 34 Jehu banyere nọ nʼime ụlọeze rie ihe, ṅụkwaa ihe ọṅụṅụ. Emesịa, o nyere iwu sị, “Leenụ nwanyị a a bụrụ ọnụ; burunu ya gaa lie ya, nʼihi na ọ bụ ada eze.”\f + \fr 9:34 \ft Jezebel bụ ada Etbaal, eze ndị Saịdọn \xt 1Ez 16:31\f* 
\v 35 Mgbe ha pụtara ili ya, ọ bụ naanị okpokoro isi ya na ọkpụkpụ ụkwụ ya abụọ, na aka ya abụọ ka ha hụrụ. Ha ahụkwaghị anụ ahụ ya.  
\v 36 Ha laghachiri gwa Jehu ihe ha hụrụ. Ọ zara sị ha, “Nke a bụ okwu \nd Onyenwe anyị\nd*, nke o kwuru site nʼọnụ ohu ya Ịlaịja onye Tishbe sị: ‘Nʼala ubi dị na Jezril ka nkịta ga-anọ rie anụ ahụ Jezebel.  
\v 37 Ozu Jezebel ga-adị ka unyi nʼala ubi dị na Jezril, ruo na mmadụ enweghị ike ikwupụta sị, Nke a bụ Jezebel.’ ” 
\c 10  
\s1 Ọgwụgwụ ezinaụlọ Ehab 
\p  
\v 1 Ugbu a, e nwere ụmụ Ehab ndị ikom ọnụọgụgụ ha dị iri asaa ndị nọ na Sameria,\f + \fr 10:1 \ft Sameria, bụ isi obodo alaeze Ugwu, site nʼoge eze Omri chịrị Izrel. \xt 1Ez 16:24\f* Jehu dere akwụkwọ ozi ziga Sameria, zigara ndịisi obodo Jezril, zigakwara ndị okenye na ndị na-elekọta ụmụ Ehab ndị ahụ. Ọ sịrị,  
\v 2 “Ugbu a, mgbe akwụkwọ a rutere unu aka, ebe unu na ụmụ ndị ikom nna unu ukwu nọ, ebe unu nwekwara ụgbọ agha na ịnyịnya, na obodo e wusiri ike na ngwa agha,  
\v 3 họpụtanụ onye kachasị inwe ugwu ma kwesikwa nʼime ụmụ ndị ikom nna unu ukwu, mee ka ọ nọkwasị nʼocheeze nna ya. Mgbe ahụ, buo agha chebe ụlọ nna unu ukwu.” 
\p  
\v 4 Ma ha tụrụ egwu nʼebe ọ dị ukwuu, sị, “Lee, eze abụọ\f + \fr 10:4 \ft Eze abụọ a na-ekwu banyere ha nʼebe a, bụ Joram na Ahazaya. \xt 2Ez 9:23-28\f* enweghị ike iguzogide ya, anyị onwe anyị ga-esi aṅaa guzogide ya?” 
\p  
\v 5 Ya mere, onye ọ dị nʼaka ilekọta ezinaụlọ eze, onyeisi obodo, ndị okenye na ndị niile na-elekọta ụmụ Ehab, dere akwụkwọ a zigara Jehu, sị ya, “Jehu, anyị niile bụ ndị ohu gị. Anyị jikeere ime ihe niile i gwara anyị. Anyị agaghị ahọpụta onye ọbụla dịka eze; gị onwe gị mee ihe ọbụla ị chere na ọ bụ ya kachasị mma.” 
\p  
\v 6 Mgbe ahụ, Jehu degaara ha akwụkwọ nke ugboro abụọ sị ha, “Ọ bụrụ na unu dịnyeere m, ọ bụrụkwa na unu ga-erube isi nye m, chịrịnụ isi ụmụ ndị ikom nna unu ukwu, bịakwute m nʼotu oge a echi na Jezril.” 
\p Nʼoge ahụ, ụmụ eze iri ndị ikom asaa nọ nʼaka ndịisi obodo ahụ, ndị na-azụlite ha.  
\v 7 Mgbe akwụkwọ ozi ahụ rutere ha, ndị ikom ahụ kpọrọ ụmụ ndị ikom eze dị iri asaa nʼọnụọgụgụ gbuo ha niile, chịrị isi ha tinye na nkata zigara ya Jehu na Jezril.  
\v 8 Mgbe onyeozi bịarutere, ọ gwara Jehu sị, “Ha ebutala isi ụmụ ndị ikom eze.” 
\p Mgbe ahụ, Jehu nyere iwu sị, “Tụkọbanụ ha ọnụ nʼoke abụọ, nʼọnụ ụzọ e si abata obodo, tutu ruo ụtụtụ.” 
\p  
\v 9 Nʼụtụtụ ya, Jehu pụrụ, guzoro nʼihu ndị niile gbakọrọ nʼebe ahụ gwa ha okwu sị, “Ndị Izrel, unu bụ ndị ezi omume. Ọ bụ mụ onwe m gbara izu ọjọọ megide nna m ukwu, gbuo ya, ma onye gburu ndị a niile?  
\v 10 Matanụ nke ọma na o nweghị okwu ọbụla \nd Onyenwe anyị\nd* kwuru megide ezinaụlọ Ehab nke na-agaghị emezu. \nd Onyenwe anyị\nd* emeela ihe o kwere nkwa na ọ ga-eme site nʼọnụ ohu ya Ịlaịja.”  
\v 11 Emesịa, Jehu gburu ndị ikwu Ehab fọdụrụ nʼobodo Jezril, ha na ndịisi niile, na ndị enyi ya niile, na ndị nchụaja ya niile. Ọ dịkwaghị otu onye ikwu Ehab ọ hapụrụ ndụ. 
\p  
\v 12 Emesịakwa, Jehu hapụrụ Jezril gaa Sameria. Mgbe ọ na-aga nʼụzọ, ọ bịaruru ebe a na-akpọ Ebe Izuike Ndị ọzụzụ atụrụ.  
\v 13 Nʼebe ahụ, o zutere ndị ụmụnna Ahazaya, eze Juda, jụọ sị, “Olee ndị ka unu bụ?” 
\p Ha zara, “Anyị bụ ndị ikwu Ahazaya, eze Juda, anyị bịara ka anyị jụọ maka ọdịmma ndị ezinaụlọ eze na nne eze.” 
\p  
\v 14 O nyere iwu sị, “Jidenụ ha na ndụ.” Ha jidere ha na ndụ, gbukwaa ha niile nʼakụkụ olulu miri nke Bet-Eked. Ọnụọgụgụ ha dị iri anọ na abụọ. O nweghị onye ọbụla ọ hapụrụ ndụ. 
\p  
\v 15 Mgbe o si nʼebe ahụ pụọ, o zutere Jehonadab nwa Rekab,\f + \fr 10:15 \ft Ndị Rekab, bụ ndị sitere nʼagbụrụ Rekab, onye sitere nʼagbụrụ ndị Kena. Ha bụ agbụrụ na-ebi ndụ ogologo nʼihi na anyị nụrụ ihe banyere ha nʼakwụkwọ onye amụma \xt Jer 35:5-10\ft  Ha nʼebi nʼụlọ ikwu, bụrụkwa ndị nwere ezi ịnụ ọkụ nʼobi banyere ihe Chineke. Jetro, ọgọ nwoke Mosis si nʼagbụrụ a. \xt Ọpụ 3:1; 4:18; 18:5; Ọnụ 10:29\f* ka ọ na-abịa izute ya. Jehu kelere ya, sị, “Obi gị, o ziri ezi nwee nkwekọrịta, dịka obi m dị nʼebe ị nọ?” 
\p Jehonadab zara sị ya, “E.” 
\p Jehu sịrị, “Ọ bụrụ na o si otu a dịrị, kwe m nʼaka.” Jehonadab kwere ya nʼaka. Jehu nʼonwe ya nyeere ya aka ka ọ rigota nʼụgbọ agha ya.  
\v 16 Mgbe ahụ, Jehu sịrị ya, “Ugbu a, soro m bịa lee ụdị ịnụ ọkụ nʼobi m nwere maka ọrụ \nd Onyenwe anyị\nd*.” Ha abụọ sooro nʼụgbọ agha Jehu. 
\p  
\v 17 Mgbe ha bịaruru Sameria, Jehu gburu ndị enyi na ndị ikwu Ehab niile, ndị fọdụrụ site nʼikwu Ehab, o bibiri ha dịka okwu \nd Onyenwe anyị\nd* kwuru site nʼọnụ onye amụma Ịlaịja. 
\s1 Ogbugbu ndị nchụaja Baal 
\p  
\v 18 Emesịa, Jehu kpọkọtara ndị obodo ahụ niile sị ha, “Ehab fere Baal ofufe nke nta, Jehu ga-efe ya ebe ọ dị ukwuu.  
\v 19 Ugbu a, kpọkọtaanụ ndị amụma Baal niile, ndị niile na-efe ya, na ndị nchụaja ya niile. Hụnụ na onye ọbụla nʼime ha bịara, nʼihi na a ga-eme oke mmemme ịchụ aja nye Baal. Onye ọbụla e lere anya ya nʼebe ahụ, ma a hụghị ya, agaghị adị ndụ.” Ma Jehu ji aghụghọ nʼihi ka ọ laa ndị a na-efe Baal nʼiyi. 
\p  
\v 20 Jehu sịrị, “Kpọsaanụ na a ga-enwe oke mkpọkọta dị nsọ nye Baal.” Ya mere, ha kwusara ya.  
\v 21 O zipụrụ ozi nye ndị bi nʼakụkụ Izrel niile. Ndị niile na-efe Baal bịazuru. Ọ dịghị onye fọdụrụ nke na-abịaghị. Ha jupụtara nʼụlọnsọ ukwu Baal\f + \fr 10:21 \ft Ehab bụ onye wuru ebe a, nke a na-anọ achụrụ arụsị Baal aja na Sameria. \xt 1Ez 16:32\f* site nʼotu isi ya ruo nʼisi nke ọzọ.  
\v 22 Jehu sịrị onye na-elekọta ụlọ ebe a na-edebe uwe ndị na-efe ofufe na-eyi, “Chịpụta uwe nye ndị niile na-efe Baal.” Ya mere, ọ chịpụtaara ha uwe. 
\p  
\v 23 Mgbe ahụ, Jehu na Jehonadab nwa Rekab, banyere nʼebe nzukọ Baal. Jehu sịrị ndị nʼefe Baal, “Chọzienụ nke ọma ka unu hụ na o nweghị onye ọbụla na-efe \nd Onyenwe anyị\nd* nọ nʼebe a, karịakwa naanị ndị na-efe Baal.”  
\v 24 Mgbe ha malitere ịchụ aja na isure ihe nsure ọkụ, Jehu emeelarị ka iri ndị agha asatọ gbaa ụlọ ahụ niile gburugburu. O nyelarị iwu sị, “Ọ bụrụ na unu ekwere ka otu onye si nʼime ụlọ a gbapụ, unu ga-eji ndụ unu kwụghachi ụgwọ onye dị otu ahụ.” 
\p  
\v 25 Ngwangwa Jehu chụchasịrị aja nsure ọkụ, ọ pụrụ gwa ndị agha ya, na ndịisi ha okwu sị, “Baanụ nʼime ụlọ gbuo ndị niile nọ nʼebe ahụ. Unu ekwela ka otu onye nʼime ha gbapụ.” Ha jiri mma agha gbuo ndị ahụ nọ nʼime ụlọ Baal, tụpụta ozu ha nʼezi. Emesịa, ndị agha Jehu banyere nʼime ime ụlọ ebe ịchụ aja Baal,  
\v 26 ha bupụtara ogidi nsọ e ji efe Baal, kpọọ ha ọkụ.  
\v 27 Ha kwaturu ogidi nsọ Baal, kwatukwaa ụlọ ịchụ aja ya. Ya mere e megharịrị ya ka ọ bụrụ ebe ọha mmadụ na-aga ogwe ruo taa. 
\p  
\v 28 Jehu kpochapụrụ ofufe Baal nʼala Izrel niile.  
\v 29 Ma otu ọ dị, o siteghị na mmehie Jeroboam nwa Nebat wezuga onwe ya. Mmehie nke Jeroboam mere ka Izrel mehie, ya bụ, mmehie nke ife arụsị ụmụ ehi e ji ọlaedo kpụọ, dị na Betel na Dan. 
\p  
\v 30 \nd Onyenwe anyị\nd* gwara Jehu sị, “Nʼihi na i mere nke ọma mezuo ihe niile ziri ezi nʼanya m, nʼebe ezinaụlọ Ehab nọ, nʼusoro ihe niile dị nʼuche m ime, ụmụ ụmụ gị ga-anọkwasị nʼocheeze Izrel, ruo nʼọgbọ nke anọ ha.”  
\v 31 Ma Jehu akpachapụghị anya iji obi ya niile debe iwu \nd Onyenwe anyị\nd*, Chineke Izrel. O siteghị na mmehie Jeroboam wezuga onwe ya, bụ mmehie ahụ o mere ka Izrel mee. 
\p  
\v 32 Nʼoge ahụ, \nd Onyenwe anyị\nd* malitere ime ka ndị Izrel bido ịdị nta. Hazael eze Aram, buru agha merie ọtụtụ akụkụ Izrel,  
\v 33 nke dị nʼọwụwa anyanwụ osimiri Jọdan, na ala niile nke Gilead (nʼoke ala ndị Gad, na nke ndị Ruben, na Manase), site nʼAroea nke dị nʼakụkụ ndagwurugwu Anọn, ruo Gilead na Bashan. 
\p  
\v 34 Akụkọ gbasara ọchịchị eze Jehu, na ihe niile o mere, na ịkpa ike ya niile, e deghị ha nʼakwụkwọ akụkọ ndị eze Izrel? 
\p  
\v 35 Jehu sooro ndị nna nna ya ha dina nʼọnwụ, e lie ya na Sameria. Nwa ya bụ Jehoahaz nọchiri anya ya dịka eze.  
\v 36 Ma ụbọchị niile Jehu bụ eze Izrel nʼime Sameria dị iri afọ abụọ na asatọ. 
\c 11  
\s1 Atalaya na Joash 
\p  
\v 1 Mgbe Atalaya nne Ahazaya hụrụ na nwa ya nwoke anwụọla, ọ gara nʼihu bido igbu ndị niile a mụrụ nʼụlọ eze.  
\v 2 Ma Jehosheba,\f + \fr 11:2 \ft Eleghị anya, nne Jehosheba dị iche na nne Atalaya, ma nʼihi na Jehosheba bụ nwunye Jehoiada onye nchụaja, o zoro Joash nʼotu ọnụụlọ nʼime ụlọnsọ ukwu \xt 2Ih 22:11\f* bụ nwa nwanyị eze Jehoram,\f + \fr 11:2 \ft Mgbe ụfọdụ a na-akpọkwa ya Jehoram\f* ma bụrụkwa nwanne nwanyị Ahazaya, kuuru Joash\f + \fr 11:2 \ft Joash bụ nwa eku nʼaka nke ka na-anụ ara, o rubeghị otu afọ mgbe ihe ndị a mere.\f* nwa Ahazaya, zopu ya site nʼetiti ụmụ ndị ikom eze, bụ ndị a chọrọ igbu egbu. O zoro ya na nwanyị na-elekọta ya anya nʼime ụlọ ndina, ka Atalaya hapụ ịhụ ya, nke a mere na-egbughị ya.  
\v 3 Ya na nwanyị na-elekọta ya anya nọgidere na nzuzo nʼime ụlọnsọ \nd Onyenwe anyị\nd*, afọ isii, oge ahụ niile Atalaya na-achị nʼala ahụ. 
\p  
\v 4 Nʼafọ nke asaa, Jehoiada, ziri ozi kpọọ ndị ọchịagha na-achị narị ndị agha, ndị Karị\f + \fr 11:4 \ft Ndị Karị bụ ndị agha e goro ego si Eshịa na mpaghara Tọki. Ha bụ ndị nọchiri anya ndị agha Keret, ndị jere ozi nʼoge eze Devid. \xt 2Sa 8:18\f* na ndị nche oku, mee ka ha bịakwute ya nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*. Ya na ha gbara ndụ, o mekwara ka ha ṅụọ iyi nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*. Mgbe ahụ, o gosiri ha nwa eze.\f + \fr 11:4 \ft Nʼakwụkwọ \xt 2Ih 23:2\ft  nʼebe ahụ e mere ka anyị mara na akpọrọ ndị Livayị, na ndịisi Juda niile nʼoku nzuzo a.\f* 
\v 5 O nyere ha iwu, sị, “Nke a bụ ihe unu ga-eme, unu bụ ndị nọ nʼotu atọ ga-abịa ọrụ nʼụbọchị izuike, nke otu ụzọ nʼime unu na-eche ụlọeze nche,  
\v 6 otu ụzọ nʼime ụzọ atọ ga-anọ nʼọnụ ụzọ Sua, ebe otu ụzọ ga-anọ nʼọnụ ụzọ ama, nʼazụ ndị na-eche nche nʼụlọnsọ ukwu Chineke.  
\v 7 Ma unu bụ otu abụọ ndị kwesiri ịga ezumike site nʼọrụ unu nʼụbọchị izuike, ga-eguzo na nche nʼụlọnsọ ukwu nʼihi eze.  
\v 8 Doonụ onwe unu gburugburu eze, onye ọbụla nʼime unu jide ihe agha nʼaka ya. Onye ọbụla nke na-abịa nso ahịrị unu, ka e gbuo ya. Nọrọnụ eze nso ebe ọbụla ọ gara, mgbe ọ na-apụ nʼezi na mgbe ọ na-aba nʼime.” 
\p  
\v 9 Ndị ọchịagha ndị a na-achị narị ndị agha mere dịka Jehoiada, onye nchụaja nyere nʼiwu. Onye ọbụla kpọrọ ndị ikom ya, ma ndị na-emechi ọrụ, ma ndị na-abata ịrụ ọrụ nʼụbọchị izuike, bịakwute Jehoiada, bụ onye nchụaja.  
\v 10 O nyere ndị ọchịagha ahụ ùbe na ọta niile, ndị bụrịị nke eze Devid, ndị dị nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*.  
\v 11 Onye ọbụla na ndị nche ahụ ji ngwa agha nʼaka ya, ha guzoro onwe ha, nọdụ eze gburugburu, na nso ebe ịchụ aja na ụlọnsọ ukwu, site nʼakụkụ ndịda ruo nʼakụkụ ugwu nke ụlọnsọ ukwu ahụ. 
\p  
\v 12 Jehoiada kpọpụtara nwa eze, kpube ya okpueze nʼisi, o nyere ya otu akwụkwọ nke ihe ọgbụgba ndụ ahụ, chie ya eze. Ha tekwara ya mmanụ ịbụ eze. Ndị niile nọ nʼebe ahụ kụrụ aka, tie mkpu, sị, “Ka eze dịrị ndụ ruo mgbe ebighị ebi!” 
\p  
\v 13 Mgbe Atalaya nụrụ mkpọtụ nke ndị nche na ndị mmadụ na-eme, ọ gakwuru ndị ahụ nọ nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*.  
\v 14 O lepụrụ anya, ma lee eze, ka o guzo nʼakụkụ ogidi,\f + \fr 11:14 \ft \xt 2Ez 23:3; 2Ih 34:31\f* dịka omenaala mmemme ịchị eze si dị. Ndịisi na ndị na-afụ opi nọ nʼakụkụ eze. Ndị niile nke ala ahụ nọkwa na-aṅụrị ọṅụ na-afụ opi. Atalaya dọwara uwe ya, sị, “Nnupu isi megide eze! Nke a bụ nnupu isi megide ọchịchị!” 
\p  
\v 15 Jehoiada, bụ onye nchụaja nyere ndịisi ọchịagha na-achị narị ndị agha, bụ ndị na-elekọta usuu ndị agha, iwu sị ha, “Sitenụ nʼebe ahụ kpọpụta ya nʼetiti ahịrị unu, onye ọbụla nke gbasoro ya, werenụ mma agha gbuo onye ahụ.” Nʼihi na onye nchụaja sịrị, “Agaghị egbu ya nʼime ụlọnsọ \nd Onyenwe anyị\nd*.”  
\v 16 Ya mere, ha jidere ya, mgbe o rutere nʼụzọ ebe ịnyịnya si abata nʼogige ụlọeze, ebe ahụ ka ha nọ gbuo ya. 
\p  
\v 17 Jehoiada mere ka ọgbụgba ndụ dị nʼetiti \nd Onyenwe anyị\nd* na eze, na ndị mmadụ, na ha ga-abụ ndị nke \nd Onyenwe anyị\nd*. O mekwara ka ọgbụgba ndụ dịrị nʼetiti eze na ndị ahụ.  
\v 18 Ndị niile nke ala ahụ gara nʼụlọ nchụaja Baal kwatuo ya. Ha tidasịrị ebe nchụaja na arụsị niile dị nʼebe ahụ mee ka ọ darisịa, gbukwaa Matan onye nchụaja Baal nʼihu ebe ịchụ aja ahụ. 
\p Mgbe ahụ, Jehoiada onye nchụaja, debekwara ndị nche ka ha lekọta ụlọnsọ ukwu \nd Onyenwe anyị\nd*.  
\v 19 Ọ kpọọrọ ndị ọchịagha na-achị narị ndị agha, ha na ndị Karị, na ndị nche, ha na ndị ala ahụ niile, ha niile dupụtara eze site nʼụlọnsọ \nd Onyenwe anyị\nd* site nʼọnụ ụzọ ndị nche banye nʼụlọeze. Eze were ọnọdụ ya nʼelu ocheeze.  
\v 20 Ndị ala ahụ niile ṅụrịrị ọṅụ nke ukwuu, obodo ahụ dakwara jụụ, nʼihi na e ji mma agha gbuo Atalaya nʼụlọeze. 
\p  
\v 21 Joash\f + \fr 11:21 \ft Maọbụ, \fqa Jehoash\f* gbara afọ asaa mgbe ọ malitere ịbụ eze. 
\c 12  
\s1 Joash emezie ụlọnsọ ukwu 
\p  
\v 1 Nʼafọ nke asaa, nke ọchịchị Jehu nʼIzrel, ka Joash malitere ịbụ eze na Juda. Iri afọ anọ ka ọ chịrị dịka eze na Jerusalem. Aha nne ya bụ Zibịa onye Bịasheba.  
\v 2 Joash mere ihe ziri ezi nʼanya \nd Onyenwe anyị\nd* ụbọchị niile nke Jehoiada onye nchụaja ziri ya ihe.  
\v 3 Ma naanị na o wezugaghị ebe ịchụ aja niile dị nʼugwu. Ndị Juda nọgidere na-achụ aja dị iche iche nʼebe ahụ, na-esurekwa ihe nsure ọkụ na-esi isi ụtọ. 
\p  
\v 4 Joash sịrị ndị nchụaja, “Nakọtaanụ ego niile a na-ewebata dịka onyinye dị nsọ nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*, ya bụ, ego a na-anakọta nʼoge ịgụ mmadụ ọnụ, na ego e webatara maka imezu nkwa ndị mmadụ kwere, na ego e webatara nʼụlọnsọ ukwu dịka onyinye afọ ofufe.  
\v 5 Ka onye nchụaja ọbụla site nʼaka otu nʼime ndị na-eche ego nara ego, a ga-eji mezie ihe ọbụla a chọpụtara na o mebiri nʼụlọnsọ ukwu ahụ.” 
\p  
\v 6 Ma nʼafọ nke iri abụọ na atọ nke ọchịchị eze Joash, ọ chọpụtara na ndị nchụaja ahụ emezibeghị ihe mebiri nʼụlọnsọ.  
\v 7 Ya mere, eze Joash\f + \fr 12:7 \ft Nʼoge a, eze Joash a gbaa afọ iri atọ.\f* kpọrọ Jehoiada, onye nchụaja, kpọkwaa ndị nchụaja ndị ọzọ jụọ ha, “Gịnị mere unu emezibeghị ụlọnsọ a? Site ugbu a gaa nʼihu, unu esitekwala nʼaka ndị na-eche ego anara ego ọzọ, kama, nyefeenụ ya maka iji dozie ụlọnsọ ukwu ahụ.”  
\v 8 Ndị nchụaja ahụ kwenyere sị, “Anyị agaghị esitekwa nʼaka ndị mmadụ nara ego ọbụla. Otu a kwa, anyị agaghị emezikwa ụlọnsọ ukwu a nʼonwe anyị.” 
\p  
\v 9 Mgbe ahụ, Jehoiada wetara otu igbe mepuo oghere nʼelu ya, debe ya nʼakụkụ ebe ịchụ aja, nʼaka nri dịka mmadụ na-abata nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*. Ndị nchụaja niile na-eche nche nʼọnụ ụzọ ụlọnsọ ahụ na-etinye ego niile e webatara nʼụlọnsọ \nd Onyenwe anyị\nd* nʼime igbe ahụ.  
\v 10 Mgbe ọbụla ha hụrụ na igbe ego ahụ ejupụtala nʼego, onye ode akwụkwọ ụlọeze na onyeisi nchụaja na-abịa, gụọ ego ahụ e webatara nʼụlọnsọ \nd Onyenwe anyị\nd*, tinye ha nʼakpa.  
\v 11 Ha na-ewere ego ahụ a gụrụ ọnụ, nyefee nʼaka ndị ikom ahọpụtara maka ilekọta ndị ọrụ na-emezi ụlọ \nd Onyenwe anyị\nd*. Ndị ahụ na-eji ya kwụọ ndị ọkwa ǹka osisi na ndị na-ewu ụlọ,  
\v 12 na ndị na-edo nkume, na ndị na-awa nkume ụgwọ. Ọ bụ sitekwa nʼego ahụ ka a na-azụta osisi na nkume a wara awa iji dozie ụlọnsọ \nd Onyenwe anyị\nd*, na ịkwụ ụgwọ ihe ndị ọzọ e ji emezi ihe niile ekwesiri imezi nʼụlọnsọ ukwu ahụ. 
\p  
\v 13 E jikwaghị ego ahụ e webatara nʼụlọnsọ kpụta efere ọlaọcha, ihe e ji akpakepụ ọkụ, efere ịkwọsa mmiri, opi maọbụ ihe ndị ọzọ nke e ji ọlaedo maọbụ ọlaọcha kpụọ maka ụlọnsọ ukwu nke \nd Onyenwe anyị\nd*.  
\v 14 Ọ bụ ndị na-eje ozi, ndị ji ya rụzie ụlọnsọ ukwu \nd Onyenwe anyị\nd* ka e nyere ya.  
\v 15 O nweghị onye a sịrị ka ọ gụzie otu e si jiri ego ahụ rụọ ọrụ, bụ ndị e nyere ego ahụ maka ịkwụ ndị ọrụ ụgwọ, nʼihi na ha bụ ndị kwesiri ntụkwasị obi.  
\v 16 E webataghị ego niile sitere nʼaja ikpe ọmụma nakwa aja mmehie nʼime ụlọnsọ ukwuu \nd Onyenwe anyị\nd*. Ọ bụ ndị nchụaja nwe nke ahụ. 
\p  
\v 17 Nʼoge ahụ, Hazael eze Aram, gara buso Gat agha, lụgbuo ya, dọta ya nʼagha. Emesịa, o chere ihu nʼụzọ Jerusalem imegide ya.  
\v 18 Ma Joash, bụ eze Juda, chịkọtara ihe niile ahụ bụ nke Jehoshafat, Jehoram na Ahazaya nna ya, ndị bụ eze Juda doro nsọ nye Chineke, chịrịkwa onyinye nke ya onwe ya dokwara nsọ, na ọlaedo niile, na akụ niile e nwere ike ịchọta nʼụlọnsọ \nd Onyenwe anyị\nd*, na nke dị nʼụlọeze, zigara Hazael, bụ eze Aram. Nʼihi ihe ndị a, ọ lara, hapụ ibuso Jerusalem agha. 
\p  
\v 19 Akụkọ gbasara ọchịchị eze Joash, na ihe niile o mere, e deghị ha nʼakwụkwọ akụkọ ihe ndị eze Juda niile mere nʼoge ha.  
\v 20 Ndị ozi ya gbara izu ọjọọ megide Joash, gbukwaa ya na Bet Milo, nʼụzọ e si aga Sila.  
\v 21 Ndịisi ozi ahụ gburu ya bụ Jozabad nwa Shimeat, na Jehozabad nwa Shomea. Ọ nwụrụ, e lie ya na ndị nna nna ya ha nʼobodo Devid. Amazaya nwa ya, ghọrọ eze nʼọnọdụ ya. 
\c 13  
\s1 Jehoahaz eze Izrel 
\p  
\v 1 Nʼafọ nke iri abụọ na atọ nke ọchịchị eze Joash nwa Ahazaya na Juda, ka Jehoahaz nwa Jehu malitere ịbụ eze nʼIzrel nʼobodo Sameria. Ọ chịkwara na Sameria afọ iri na asaa.  
\v 2 Kama Jehoahaz bụ eze ọjọọ. O mere ihe jọrọ njọ nʼanya \nd Onyenwe anyị\nd*. O soro ụzọ ọjọọ niile nke Jeroboam nwa Nebat, onye dubara ndị Izrel na mmehie.  
\v 3 Nʼihi nke a, iwe were \nd Onyenwe anyị\nd* nke ukwuu megide Izrel. O mere ka ha nọrọ nʼokpuru ọchịchị Hazael eze Aram na Ben-Hadad nwa ya ogologo oge. 
\p  
\v 4 Ma Jehoahaz kpere ekpere rịọọ \nd Onyenwe anyị\nd* nʼoge a ka o nyere ya aka, \nd Onyenwe anyị\nd* gere ya ntị, nʼihi na Chineke hụrụ mmegbu\f + \fr 13:4 \ft \xt Ọpụ 3:7,9; Nkp 2:18; 2Ez 14:28.\f* nke eze Aram na-emegbu ndị Izrel.  
\v 5 \nd Onyenwe anyị\nd* họpụtaara Izrel onye nzọpụta, ha sitere nʼaka ike ndị Aram nwere onwe ha.\f + \fr 13:5 \ft \xt Neh 9:27; 2Ez 13:25; 14:25,27\f* Izrel biri nʼụlọ nke aka ha dịka ha biiri nʼoge gara aga.  
\v 6 Ma ha esighị na mmehie niile nke ụlọ Jeroboam wezuga onwe ha, bụ nke o jiri mee ka Izrel mehie, kama ha nọ na-ejegharị nʼime ha. Ọzọkwa, ogidi Ashera ka guzoro na Sameria. 
\p  
\v 7 Ọ dịghị ihe fọdụrụ na ndị agha Jehoahaz ma ọ bụghị naanị iri ndị agha ise na-agba ịnyịnya, na ụgbọ agha iri, na puku ndị agha iri. Nʼihi na eze Aram alaala ndị nke fọdụrụ nʼiyi, meekwa ka ha dịrị ka uzuzu mgbe a na-azọcha mkpụrụ. 
\p  
\v 8 Akụkọ gbasara ọchịchị Jehoahaz, na ihe niile o mere, na ihe ọ rụpụtara, e deghị ha nʼakwụkwọ akụkọ ihe ndị eze Izrel mere nʼoge ha?  
\v 9 Jehoahaz sooro ndị nna nna ya ha dina nʼọnwụ, e lie ya na Sameria. Nwa ya Jehoash nọchiri anya ya. 
\s1 Jehoash eze Izrel 
\p  
\v 10 Nʼafọ iri atọ na asaa nke ịbụ eze Joash na Juda, ka Jehoash nwa Jehoahaz malitere ị bụ eze Izrel na Sameria. Ọ chịrị afọ iri na isii.  
\v 11 O mere ihe jọrọ njọ nʼanya \nd Onyenwe anyị\nd*. O siteghị na mmehie Jeroboam nwa Nebat wezuga onwe ya, mmehie nke Jeroboam dubara Izrel ime. Jehoash nọgidere nʼime ha. 
\p  
\v 12 Akụkọ gbasara ọchịchị Jehoash, na ihe niile o mere, na ihe ọ rụpụtara, tinyere agha o buru megide Amazaya eze Juda, e deghị ha nʼakwụkwọ akụkọ ihe ndị eze Izrel mere nʼoge ha?  
\v 13 Jehoash soro nna nna ya ha dina nʼọnwụ, Jeroboam anọchie nʼocheeze ya. E liri Jehoash na Sameria, nʼebe e liri ndị eze Izrel ndị ibe ya. 
\p  
\v 14 Nʼoge a, Ịlaisha nọ nʼọrịa nke ọ ga-esite na ya anwụ. Jehoash, bụ eze Izrel gara ịhụ ya, ọ kwara akwa mgbe ọ hụrụ ya sị, “Nna m, nna m, usuu ụgbọ agha na usuu ndị na-agba ịnyịnya Izrel!” 
\p  
\v 15 Ịlaisha gwara ya okwu sị, “Wepụta ụta na àkụ ụfọdụ.” O mere dịka Ịlaisha gwara ya.  
\v 16 Ịlaisha gwakwara eze Izrel okwu sị ya, “Jide ụta ahụ nʼaka gị abụọ.” Mgbe o jidere ụta ahụ Ịlaisha tụkwasịrị aka nke ya nʼaka eze. 
\p  
\v 17 Ịlaisha gwara ya sị, “Meghee oghereikuku ahụ chere ihu nʼọwụwa anyanwụ.” O meghere ya. Mgbe ahụ Ịlaisha gwara ya sị, “Gbapụ àkụ.” Eze gbapụrụ àkụ. Ịlaisha kwuru sị, “Àkụ mmeri \nd Onyenwe anyị\nd*, àkụ mmeri megide Aram. Ị ga-ebibi ndị Aram kpamkpam nʼAfek.” 
\p  
\v 18 Ọ sịrị, “Chilite àkụ ndị ahụ,” ọ chilitere ha. Ịlaisha gwara eze Izrel, “Gbaa ha nʼala.” Ọ gbara ha nʼala ugboro atọ, ma kwụsị.  
\v 19 Ma onye nke Chineke ahụ were iwe sị ya, “Ị gaara apịa ya nʼala ugboro ise maọbụ isii. Mgbe ahụ, ị gaara enwe ike merie ndị Aram bibie ha kpamkpam. Ma ugbu a, ọ bụ naanị ugbo atọ ka ị ga-emeri ha.” 
\p  
\v 20 Ya mere, Ịlaisha nwụrụ. E likwara ya. 
\p Nʼoge ahụ, ọtụtụ ndị na-apụnara mmadụ ihe nʼike na-esi nʼala ndị Moab na-abịa nʼala Izrel izu ohi site nʼọnwa nke atọ nʼafọ ọhụrụ ọbụla.  
\v 21 Otu ụbọchị, mgbe ụfọdụ ndị ikom na-eli otu nwoke nwụrụ anwụ, ha hụrụ ndị a na-apụnara mmadụ ihe nʼike. Nʼihi nke a, ha mere ngwangwa site nʼụjọ tụbanye nwoke ahụ nʼili Ịlaisha. Mgbe ozu nwoke ahụ dara metụ ọkpụkpụ Ịlaisha ahụ, nwoke ahụ nwụrụ anwụ megharịrị ahụ bilie, guzo nʼụkwụ ya abụọ. 
\p  
\v 22 Hazael, eze Aram, busoro Izrel agha ụbọchị niile nke ndụ Jehoahaz eze Izrel.  
\v 23 Ma \nd Onyenwe anyị\nd* meere ha amara, nwee ọmịiko nʼebe ha nọ, ma gosikwa ha na ihe banyere ha na-emetụ ya nʼobi nʼihi ọgbụgba ndụ ya na Ebraham na Aịzik na Jekọb. Ruo taa, o kweghị ka e bibie ha, maọbụ ka e site nʼihu ya chụpụ ha. 
\p  
\v 24 Emesịa, Hazael eze Aram nwụrụ, Ben-Hadad nwa ya nọchikwara nʼọnọdụ ya.  
\v 25 Jehoash nwa Jehoahaz, weghachitere obodo niile nke ọ naara nʼaka nna ya Jehoahaz site nʼaka Ben-Hadad nwa Hazael. Ugboro atọ ka Jehoash meriri ya, site otu a weghachi obodo niile nke Izrel. 
\c 14  
\s1 Amazaya eze Juda 
\p  
\v 1 Nʼafọ nke abụọ nke ịbụ eze Jehoash nwa Jehoahaz nʼIzrel, ka Amazaya nwa Joash eze Juda malitere ọchịchị ya.  
\v 2 Amazaya gbara iri afọ abụọ na ise mgbe ọ malitere ịbụ eze. Ọ bụ eze na Jerusalem iri afọ abụọ na itoolu. Aha nne ya bụ Jehoadin, onye Jerusalem.  
\v 3 O mere ihe ziri ezi nʼanya \nd Onyenwe anyị\nd*, ma o meghị dịka nna nna ya bụ Devid mere. Nʼihe niile, ọ gbasoro nzọ ụkwụ nna ya Joash.  
\v 4 Ọ wezugaghị ebe ịchụ aja niile dị nʼugwu. Ndị Juda gara nʼihu na-achụ aja na-esurekwa ihe nsure ọkụ na-esi isi ụtọ nʼelu ugwu ahụ niile. 
\p  
\v 5 Mgbe alaeze ahụ siri ike nʼọchịchị ya, o gburu ndị ozi ahụ gburu eze, bụ nna ya.  
\v 6 Ma o meghị ka ụmụ ndị ogbu mmadụ ahụ nwụọ, nʼusoro ihe e dere nʼakwụkwọ iwu Mosis, ebe \nd Onyenwe anyị\nd* nyere iwu sị: “Agaghị eme ka ndị mụrụ ụmụ nwụọ nʼihi ihe ụmụ ha metara, maọbụ mee ka ụmụ nwụọ nʼihi ihe ndị mụrụ ha metara, onye ọbụla ga-anwụ nʼihi mmehie nke aka ya.” 
\p  
\v 7 Amazaya bụ onye gburu puku ndị agha Edọm iri na Ndagwurugwu Nnu, dọtakwa obodo Sela\f + \fr 14:7 \ft Aha a na-akpọ Sela nʼasụsụ Griik bụ Petra. Petra bụ isi obodo Idumia.\f* nʼagha, gụgharịa ya Jekteel,\f + \fr 14:7 \ft \xt Jos 15:38\f* nke bụ aha a na-akpọ ya ruo ụbọchị taa. 
\p  
\v 8 Mgbe ahụ, Amazaya zigara ndị ozi ka ha jekwuru Jehoash nwa Jehoahaz nwa Jehu, eze Izrel, zie ya ozi ịma aka, sị, “Bịa, ka dimkpa na ibe ya zute ihu na ihu nʼagha.” 
\p  
\v 9 Ma Jehoash eze Izrel zighachiri ozi nye Amazaya eze Juda sị ya, “Uke dị na Lebanọn zigaara osisi sida nke dị na Lebanọn ozi, sị ya, ‘Nye nwa m nwoke nwa gị nwanyị ka ọ bụrụ nwunye ya.’ Mgbe ahụ, anụ ọhịa nke dị na Lebanọn gafetere ebe ahụ, zọpịa uke ahụ.  
\v 10 I meriela Edọm, nʼezie. Ugbu a, mpako abatala. Ṅụrịa ọṅụ nʼihi mmeri nke i nwetara, ma nọdụ nʼụlọ gị. Nʼihi gịnị ka ị ga-eji kpaliere onwe gị nsogbu, si otu a wetara onwe gị na Juda ọdịda?” 
\p  
\v 11 Ma otu ọ dị, Amazaya egeghị ntị. Ya mere, Jehoash bụ eze Izrel buliri agha, ya na Amazaya eze Juda zutere ihu na ihu nʼagha na Bet-Shemesh, dị nʼala Juda.  
\v 12 Ndị Izrel meriri ndị Juda, mee ka ha gbalaga, nwoke ọbụla nʼụlọ ya.  
\v 13 Jehoash bụ eze Izrel nwudere Amazaya bụ eze Juda, nwa Joash, nwa Ahazaya na Bet-Shemesh. Mgbe ahụ, Jehoash gara Jerusalem kwada mgbidi Jerusalem, site nʼỌnụ ụzọ ama Ifrem\f + \fr 14:13 \ft \xt Neh 8:16; 12:39\f* ruo nʼọnụ ụzọ ama Nkuku, nke ogologo ya ruru narị nzọ ụkwụ isii.  
\v 14 Ọ chịkọrọ ọlaedo na ọlaọcha niile na ngwongwo niile ahụtara nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*, na nke dị nʼụlọakụ nke ụlọeze. Ọ dọtara ọtụtụ ndị mmadụ nʼagha, kpọrọ laghachi na Sameria. 
\p  
\v 15 Ihe banyere akụkọ ndị ọzọ gbasara ọchịchị Jehoash, na ihe o mere, na ihe ọ rụpụtara, tinyere agha ọ lụrụ megide Amazaya eze Juda, ọ bụ na-edeghị ha nʼakwụkwọ akụkọ ihe ndị eze Izrel mere nʼoge ha?  
\v 16 Jehoash sooro nna nna ya ha dinaa nʼọnwụ, e lie ya na Sameria, ebe e liri eze ndị Izrel ndị ọzọ. Jeroboam nwa ya ghọrọ eze nʼọnọdụ ya. 
\p  
\v 17 Amazaya nwa Joash, eze Juda nọrọ ndụ afọ iri na ise, mgbe Jehoash nwa Jehoahaz, eze Izrel nwụsịrị.  
\v 18 Ma banyere ihe ndị ọzọ niile mere nʼoge ọchịchị Amazaya, ọ bụ na e deghị ha nʼakwụkwọ akụkọ ihe mere nʼoge ndị eze Juda? 
\p  
\v 19 Ha gbara izuzu imegide ya nʼime Jerusalem, ọ gbapụrụ gbalaga Lakish. Ma ha zipụrụ ndị ikom chụụrụ ya gaa Lakish, gbuo ya nʼebe ahụ.  
\v 20 Ha bulatara ozu ya nʼelu ịnyịnya, e lie ya na Jerusalem nʼebe e liri ndị nna nna ya ha, nʼobodo Devid. 
\p  
\v 21 Mgbe ahụ, ndị Juda niile duuru Azaraya onye aha ya bụkwa Uzaya, onye gbara afọ iri na isii, mee ya eze nʼọnọdụ nna ya Amazaya.  
\v 22 Ọ bụ ya wugharịrị obodo Elat, nyeghachi ya Juda, mgbe Amazaya eze sooro ndị nna nna ya ha dina nʼọnwụ. 
\s1 Jeroboam nke abụọ eze Izrel 
\p  
\v 23 Nʼafọ nke iri na ise nke Amazaya nwa Joash, eze Juda, Jeroboam nwa Jehoash eze Izrel ghọrọ eze na Sameria. Ọ chịrị iri afọ anọ na otu dịka eze.  
\v 24 Ma o mere ihe ọjọọ nʼanya \nd Onyenwe anyị\nd* nʼihi na o wezugaghị onwe ya site na mmehie Jeroboam nwa Nebat, onye ahụ dubara ndị Izrel na mmehie.  
\v 25 Ọ bụ ya weghachitara oke ala Izrel site na Lebo Hamat ruo nʼosimiri Araba, dịka okwu \nd Onyenwe anyị\nd*, Chineke nke Izrel si dị, nke o kwuru site nʼọnụ Jona nwa Amitai, onye amụma si Gat Hefa. 
\p  
\v 26 \nd Onyenwe anyị\nd* hụrụ ọnọdụ ọjọọ nke ndị Izrel nọ nʼime ya; onye ọbụla nʼime ha, ohu na onye nwe onwe ya, nọ nʼoke ahụhụ. Ọ dịkwaghị onye inyeaka ọbụla ha nwere.  
\v 27 Ma ọ bụghị uche \nd Onyenwe anyị\nd* ịla Izrel nʼiyi kpamkpam nʼokpuru eluigwe, nʼihi ya ka o mere ka Jeroboam nwa Jehoash napụta ha site nʼaka ndị iro ha. 
\p  
\v 28 Akụkọ niile gbasara ihe niile Jeroboam mere, na ike ya niile, na agha niile o buru, na otu o si nwetaghachiri ndị Izrel obodo Damaskọs na Hamat, bụ obodo ndị Juda, ọ bụ na e deghị ha nʼakwụkwọ akụkọ ihe ndị eze Izrel mere nʼụbọchị ndụ ha?  
\v 29 Jeroboam sooro ndị nna nna ya ha dina nʼọnwụ, e lie ya nʼebe e liri ndị eze Izrel nwụrụ anwụ. Ma Zekaraya nwa ya ghọrọ eze Izrel nʼọnọdụ ya. 
\c 15  
\s1 Azaraya eze Juda 
\p  
\v 1 Nʼafọ nke iri abụọ na asaa nke ọchịchị Jeroboam nʼIzrel ka Azaraya nwa Amazaya bidoro ịchị dịka eze na Juda.\f + \fr 15:1 \ft Ọ bụ nʼime senchuri nke asatọ (Tupu a mụọ Kraịst)\f* 
\v 2 Ọ gbara afọ iri na isii mgbe ọ malitere ị bụ eze. Ọ chịkwara na Jerusalem iri afọ ise na abụọ. Aha nne ya bụ Jekolaya, onye Jerusalem.  
\v 3 O soro nzọ ụkwụ nna ya bụ Amazaya, mee ihe ziri ezi nʼanya \nd Onyenwe anyị\nd*.  
\v 4 Kama dịka eze ndị ọzọ, o wezugaghị ebe ịchụ aja dị nʼelu ugwu; ndị mmadụ gara nʼihu na-achụ aja nsure ọkụ na aja na-esi isi ụtọ nʼebe ahụ. 
\p  
\v 5 \nd Onyenwe anyị\nd* tiri eze ihe otiti ọrịa ekpenta ruo ụbọchị ọnwụ ya.\f + \fr 15:5 \ft A kọrọ akụkọ a nʼakwụkwọ \xt 2Ih 26:16-21\ft  ebe ọ pụtara ìhè. Chineke mere ka eze ghọọ onye ekpenta nʼihi nleda anya o ledara ndị nchụaja, mgbe ọ gara chụọ aja, bụ ihe ọ na-ekwesighị ime dịka eze ọ bụ. \xt Ọnụ 3:10; 16:39-40; 18:6-7\f* O biri nʼụlọ ewupụrụ iche. Jotam\f + \fr 15:5 \ft Ọ bụ Jotam nọ na-achị ala ahụ nʼọnọdụ eze Azaraya ruo mgbe ọ nwụrụ.\f* nwa nwoke eze ghọrọ onye nlekọta ụlọeze na-achịkwa ndị ala ahụ. 
\p  
\v 6 Ma banyere ihe ndị ọzọ niile mere nʼoge ọchịchị Azaraya, na ihe niile o mere, ọ bụ na e deghị ha nʼakwụkwọ akụkọ ihe mere nʼoge ndị eze Juda?  
\v 7 Azaraya soro ndị nna nna ya dina nʼọnwụ, e lie ya nso nʼebe e liri ha, nʼime obodo Devid. Jotam nwa ya ghọrọ eze nʼọnọdụ ya. 
\s1 Zekaraya eze Izrel 
\p  
\v 8 Nʼafọ nke iri atọ na asatọ nke ọchịchị eze Azaraya bụ eze Juda, ka Zekaraya, nwa Jeroboam ghọrọ eze Izrel na Sameria. Ọ chịrị ọnwa isii.  
\v 9 Dịka ndị nna ya bu ya ụzọ si mee, Zekaraya mere ihe jọrọ njọ nʼanya \nd Onyenwe anyị\nd*. O mekwara dịka Jeroboam nwa Nebat, onye dubara ndị Izrel na mmehie ịkpọ isiala nye chi ọzọ. 
\p  
\v 10 Shalum nwa Jebesh, na ndị ọzọ, gbara izu ọjọọ megide ya, tigbuo ya nʼihu ndị Izrel niile. Ọ ghọkwara eze mgbe Zekaraya nwụrụ.  
\v 11 Akụkọ metụtara ihe ndị ọzọ mere mgbe Zekaraya bụ eze, e deghị ha nʼakwụkwọ akụkọ ihe ndị eze Izrel mere nʼụbọchị ndụ ha.  
\v 12 Ya mere, okwu ahụ \nd Onyenwe anyị\nd* gwara Jehu mezuru, nke bụ: “Ụmụ ụmụ gị ga-anọkwasị nʼocheeze Izrel ruo nʼọgbọ nke anọ ha.” 
\s1 Shalum eze Izrel 
\p  
\v 13 Shalum nwa Jebesh malitere ịbụ eze nʼafọ nke iri atọ na itoolu nke ọchịchị Uzaya eze Juda. Ọ chịrị otu ọnwa na Sameria.  
\v 14 Menahem nwa Gadi sitere nʼobodo Tịaza bịaruo Sameria gbuo Shalum nwa Jebesh ghọọ eze nʼọnọdụ ya. 
\p  
\v 15 Akụkọ ndị ọzọ gbasara Shalum na izu ọjọọ ya, e deghị ha nʼakwụkwọ ihe mere nʼoge ndị eze Izrel na-achị. 
\p  
\v 16 Nʼoge ahụ, Menahem sitere na Tịaza buso obodo Tipsa agha, na onye ọbụla bi nʼobodo ahụ na gburugburu ya nʼihi na ha ekweghị emeghe ọnụ ụzọ ama ha. O tigburu Tifsa kwakọrọ ihe niile, bọwakwaa afọ ndị inyom niile dị ime. 
\s1 Menahem eze Izrel 
\p  
\v 17 Nʼafọ iri atọ na itoolu nke Azaraya, eze Juda, Menahem nwa Gadi ghọrọ eze ọhụrụ ndị Izrel. Ọ chịrị afọ iri dịka eze na Sameria.  
\v 18 O mere ihe jọrọ njọ nʼanya \nd Onyenwe anyị\nd*. Nʼoge ọchịchị ya, o sighị na mmehie Jeroboam nwa Nebat wezuga onwe ya, bụ nke o mere ka Izrel mehie. 
\p  
\v 19 Mgbe ahụ, Pul\f + \fr 15:19 \ft Pul bụkwa onye a na-akpọ \fqa Tiglat-Pilesa, \ft nʼasụsụ ndị Babilọn, gụọ \xt 1Ih 5:26\f* eze Asịrịa busoro ala ahụ agha. Menahem nyere ya otu puku talenti ọlaọcha, ime ka Pul kwagide ọchịchị ya, na ime ka aka ya siekwa ike nʼalaeze Izrel.  
\v 20 Menahem si nʼaka ndị Izrel nweta ego a. Onye ọgaranya ọbụla tụrụ iri shekel ọlaọcha ise nke e nyere eze Asịrịa. Mgbe eze Asịrịa natachara ọlaọcha ndị a, o si nʼala ahụ pụọ, ọ nọgidekwaghị nʼala ahụ. 
\p  
\v 21 Akụkọ banyere Menahem na ihe niile o mere, e deghị ha nʼakwụkwọ akụkọ ihe ndị eze Izrel mere nʼụbọchị ndụ ha?  
\v 22 Menahem sooro ndị nna nna ya ha dina nʼọnwụ, Pekahaya nwa ya ghọrọ eze nʼọnọdụ ya. 
\s1 Pekahaya eze Izrel 
\p  
\v 23 Nʼafọ nke iri ise, nke ọchịchị eze Azaraya na Juda, ka Pekahaya nwa Menahem bidoro ịchị dịka eze nʼIzrel. Afọ abụọ ka ọ chịrị nʼime Sameria.  
\v 24 Ma Pekahaya mere ihe ọjọọ nʼanya \nd Onyenwe anyị\nd*. O sighị na mmehie niile nke Jeroboam nwa Nebat wezuga onwe ya, bụ nke o jiri mee ka Izrel mehie.  
\v 25 Ma Peka nwa Remalaya, otu nʼime ndịisi agha eze na iri ndị ikom ise ọzọ si Gilead gbara izu megide ya, gbuo ya nʼụlọeze dị nʼime Sameria. Ha gbukwara Agob na Arie nʼoge a ha gburu Pekahaya. Emesịa, Peka ghọrọ eze nʼọnọdụ ya. 
\p  
\v 26 Akụkọ banyere Pekahaya na ihe niile o mere ka e dere nʼakwụkwọ akụkọ ihe ndị eze Izrel mere nʼụbọchị ndụ ha. 
\s1 Peka eze Izrel 
\p  
\v 27 Nʼafọ nke iri ise na abụọ nke ọchịchị Azaraya eze Juda ka Peka nwa Remalaya ghọrọ eze Izrel nʼobodo Sameria. Ọ chịrị dịka eze iri afọ abụọ.  
\v 28 O mere ihe jọrọ njọ nʼanya \nd Onyenwe anyị\nd*. O fere chi ọzọ ofufe, o sighị na mmehie Jeroboam nwa Nebat wezuga onwe ya, bụ mmehie nke o dubara ndị Izrel nʼime ya. 
\p  
\v 29 Nʼoge Peka bụ eze Izrel, ka Tiglat-Pilesa, eze Asịrịa bịara were Ijon, Ebel-Bet-Maaka, Janoa, Kedesh, Hazọ, Gilead, Galili na ala ndị Naftalị niile. Ọ chụpụrụ ndị mmadụ niile mee ka ha gaa biri nʼAsịrịa.  
\v 30 Nʼoge ahụ, Hoshea nwa Elaa gbara izu ọjọọ megide Peka nwa Remalaya gbuo ya, bụrụ eze nʼọnọdụ ya. Ọ malitere ịbụ eze nʼafọ nke iri abụọ nke ọchịchị eze Jotam nwa Uzaya. 
\p  
\v 31 Akụkọ banyere Peka na ihe niile o mere, e deghị ha nʼakwụkwọ akụkọ ihe ndị eze Izrel niile mere nʼụbọchị ndụ ha? 
\s1 Jotam eze Juda 
\p  
\v 32 Nʼafọ nke abụọ nke ọchịchị Peka nwa Remalaya eze Izrel ka Jotam nwa Ụzaya eze Juda malitere ọchịchị ya.  
\v 33 Ọ gbara iri afọ abụọ na ise mgbe ọ ghọrọ eze. Ọ chịrị afọ iri na isii na Jerusalem. Aha nne ya bụ Jerusha, nwa Zadọk.  
\v 34 O mere ihe ziri ezi nʼanya \nd Onyenwe anyị\nd* dịka nna ya Ụzaya mere.  
\v 35 Kama, o wezugaghị ebe ịchụ aja dị nʼelu ugwu, ndị mmadụ gara nʼihu na-achụ aja nsure ọkụ dị iche iche na aja na-esi isi ụtọ nʼebe ahụ. Jotam wugharịrị Ọnụ Ụzọ ama nke dị Elu nke ụlọnsọ ukwu \nd Onyenwe anyị\nd*. 
\p  
\v 36 Ma banyere ihe ndị ọzọ niile nke oge ọchịchị Jotam na ihe o mere, ọ bụ na e deghị ha nʼakwụkwọ akụkọ ihe mere nʼoge ndị eze Juda?  
\v 37 (Nʼụbọchị ndị ahụ, \nd Onyenwe anyị\nd* malitere izite Rezin eze ndị Aram na Peka nwa Remalaya, imegide ndị Juda.)  
\v 38 Jotam sooro ndị nna nna ya ha dina nʼọnwụ, e lie ya nʼebe e liri ha, nʼobodo Devid, bụ obodo nna ya. Ehaz nwa ya nwoke ghọrọ eze nʼọnọdụ ya. 
\c 16  
\s1 Ehaz eze Juda 
\p  
\v 1 Ehaz\f + \fr 16:1 \ft Ehaz na nna ya Jotam, chịkọrọ dịka eze na Juda nʼime senchuri nke asatọ (Tupu a mụọ Kraịst).\f* nwa Jotam, malitere ịbụ eze Juda nʼafọ nke iri na asaa nke ọchịchị eze Peka nwa Remalaya eze Izrel.  
\v 2 Ehaz gbara iri afọ abụọ mgbe ọ malitere ịbụ eze. Afọ iri na isii ka ọ chịkwara nʼime Jerusalem, ma o meghị ihe ziri ezi nʼanya \nd Onyenwe anyị\nd* bụ Chineke ya, dịka nna ya Devid mere.  
\v 3 Ọ gbasoro ụzọ niile nke ndị eze Izrel, ọbụladị i ji nwa ya nwoke chụọ aja nʼọkụ. Ọ gbasoro omenaala niile rụrụ arụ nke ndị mba ọzọ, ndị ahụ \nd Onyenwe anyị\nd* chụpụrụ site nʼihu ndị Izrel.  
\v 4 Ọ chụrụ aja surekwaa ihe nsure ọkụ aja na-esi isi ụtọ nʼebe niile dị elu, nʼelu ugwu niile, na nʼokpuru osisi ndụ ọbụla. 
\p  
\v 5 Mgbe ahụ, Rezin eze Aram na Peka nwa Remalaya, eze Izrel rigooro ịga buso Jerusalem agha, gbakwaa Ehaz gburugburu. Ma ha emerighị ya nʼagha.  
\v 6 Nʼoge ahụ, Rezin eze Aram dọtaghachiri obodo Elat nye onwe ya, site na ị chụpụ ndị Juda bi nʼElat. Ndị Edọm bara nʼobodo Elat, ha bikwa nʼebe ahụ ruo taa. 
\p  
\v 7 Ehaz zigara ndị ozi ka ha gaa zie Tiglat-Pilesa, eze ndị Asịrịa ozi, sị ya, “Abụ m ohu gị, onyenwe m ka ị bụ. Bịa napụta m site nʼaka eze ndị Aram na eze ndị Izrel, ndị na-ebuso m agha.”\f + \fr 16:7 \ft Arịrịọ enyemaka a site nʼebe eze Pul nọ, mere ka ndị Izrel tufuo ọnọdụ i nwere onwe ha. \xt 2Ih 28:20; Dit 28:36\f* 
\v 8 Ehaz weere ọlaedo na ọlaọcha ahụtara nʼime ụlọnsọ ukwu \nd Onyenwe anyị\nd*, na nke dị nʼakụ niile dị nʼụlọeze zigara eze Asịrịa dịka onyinye.  
\v 9 Eze ndị Asịrịa ṅara ya ntị site nʼibuso obodo Damaskọs agha na imeri ya. O gburu Rezin, bulaa mmadụ niile bi nʼime ya nʼike ka ha gaa biri nʼobodo Kia. 
\p  
\v 10 Mgbe eze Ehaz gara Damaskọs izute Tiglat-Pilesa bụ eze Asịrịa. Ọ hụrụ otu ebe nchụaja nke dị na Damaskọs. O zigaara Ụraya onye nchụaja oyiyi ebe ịchụ aja ahụ. O dekwara ihe gbasara ya nʼakwụkwọ, nke ga-akọwa otu e si ewu ya.  
\v 11 Ya mere, Ụraya onye nchụaja, wuru ebe ịchụ aja nke dị ka nke ahụ Ehaz hụrụ na Damaskọs. O wuchara ya tupu eze alọta.  
\v 12 Mgbe eze si Damaskọs lọta na Juda, ọ hụrụ ebe ịchụ aja ahụ, bịaruo ya nso, doo onyinye ịchụ aja ya nʼelu ya.  
\v 13 Ọ chụrụ aja nsure ọkụ, na aja ihe nsure ọkụ na-esi isi ụtọ, na aja onyinye mkpụrụ ọka. Ọ wụkwasịrị onyinye ihe ọṅụṅụ nʼelu ebe ịchụ aja ahụ, fesakwa ọbara aja udo ya niile nʼelu ebe ịchụ aja ahụ.  
\v 14 O wepụrụ ebe ịchụ aja bronz nke dị nʼihu \nd Onyenwe anyị\nd*, o sitere nʼebe ọ dị nʼihu ụlọnsọ ahụ, nʼetiti ebe ịchụ aja ọhụrụ na ụlọnsọ ukwu \nd Onyenwe anyị\nd*, bute ya nʼakụkụ ugwu nke ebe ịchụ aja ọhụrụ ya. 
\p  
\v 15 Eze Ehaz nyere Ụraya, bụ onyeisi nchụaja iwu, sị, “Ọ bụ nʼelu ebe ịchụ aja ọhụrụ a ka ị ga na-esure aja nsure ọkụ ụtụtụ niile, na onyinye mkpụrụ ọka nke uhuruchi niile, na aja nsure ọkụ eze, na onyinye mkpụrụ ọka nke eze, na aja na onyinye nke ndị niile nʼala a, ya na onyinye mkpụrụ ọka ha niile na onyinye ihe ọṅụṅụ ha niile. Fekwasị ọbara niile e ji chụọ aja nsure ọkụ na aja ndị ọzọ nʼelu ebe ịchụ aja ahụ. Ma ebe ịchụ aja ọla ahụ ga-adịrị m iji jụta ase.”  
\v 16 Ụraya onye nchụaja mere ihe niile dịka eze Ehaz nyere ya nʼiwu. 
\p  
\v 17 Eze bụ Ehaz wepụrụ ihe njikọ niile jikọrọ ihe ndọkwasị ahụ niile a na-ebugharị ebugharị. O wepụrụ efere ukwu ịdọba mmiri a dọkwasịrị nʼelu ehi ọla ahụ dị nʼokpuru ya, ma dọkwasị ya nʼelu nkume.  
\v 18 Nʼihi imekwa ka obi tọọ eze Asịrịa ụtọ, o wepụrụ ụzọ a na-esite maka ụbọchị izuike nke e wuru nʼime ụlọnsọ, na ụzọ mbata eze si abanye nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*. 
\p  
\v 19 Ma banyere ihe ndị ọzọ niile mere nʼoge ọchịchị Ehaz, na ihe ndị o mere, ọ bụ na e deghị ha nʼakwụkwọ akụkọ ihe mere nʼoge ndị eze Juda?  
\v 20 Ehaz soro nna nna ya ha dina nʼọnwụ, e lie ya nʼebe e liri ha nʼobodo Devid. Hezekaya nwa ya ghọrọ eze nʼọnọdụ ya. 
\c 17  
\s1 Hoshea eze Izrel nke ikpeazụ 
\p  
\v 1 Nʼafọ nke iri na abụọ nke ọchịchị Ehaz, bụ eze Juda, ka Hoshea nwa Elaa ghọrọ eze Izrel nʼobodo Sameria. Ọ chịrị dịka eze afọ itoolu.  
\v 2 O mere ihe ọjọọ nʼanya \nd Onyenwe anyị\nd* mgbe ọ bụ eze. Ma ọ bụghị dịka ndị eze Izrel ndị ọzọ bu ya ụzọ. 
\p  
\v 3 Shalmanesa eze Asịrịa bịara buso Hoshea agha, nʼihi na Hoshea nọ nʼokpuru ọchịchị eze Asịrịa, bụrụkwa onye na-atụ ụtụ nye ya kwa afọ.  
\v 4 Ma eze Asịrịa chọpụtara na Hoshea abụghị onye kwesiri ntụkwasị obi nʼihi na Hoshea eze Izrel zipụrụ ndị ozi ya ka ha jekwuru So, eze Ijipt, maka enyemaka. Ọzọkwa, Hoshea kwụsịrị ịtụ ụtụ nye eze Asịrịa dịka ọ na-eme kwa afọ. Nʼihi ya Shalmanesa nwụchiri ya, tinye ya nʼụlọ mkpọrọ.  
\v 5 Eze Asịrịa wakporo ala ahụ niile nʼagha, gbagoo imegide Sameria, nọchibido ya gburugburu, afọ atọ.  
\v 6 Nʼafọ itoolu nke ọchịchị Hoshea, eze Asịrịa dọtara Sameria nʼagha,\f + \fr 17:6 \ft Ndọta a dọtara ndị Izrel nʼagha nʼoge a, bụ nke ugboro abụọ. Nke mbụ, bụ nʼoge Peka bụ eze. \xt 2Ez 15:29\f* dọkpụrụ ndị Izrel niile buga ha nʼala Asịrịa. O mere ka ha biri nʼobodo Hala, nʼime Gozan nke dị nʼosimiri Hoboa, na nʼime obodo ndị Midia. 
\s1 Ndọta a dọtara Izrel nʼagha nʼihi mmehie 
\p  
\v 7 Ihe ndị a niile mere nʼihi na ndị Izrel mehiere megide \nd Onyenwe anyị\nd*, bụ Chineke ha, onye ahụ mere ka ha site nʼokpuru ike Fero, eze Ijipt pụta. Ha kpọrọ isiala nye\f + \fr 17:7 \ft Fere chi ndị ọzọ ofufe\f* chi ndị ọzọ  
\v 8 gbasoro omenaala niile nke ndị mba ahụ \nd Onyenwe anyị\nd* chụpụrụ site nʼala ha. Ha gbasokwara omenaala ọjọọ ndị ahụ niile ndị eze ha webatara.  
\v 9 Ndị Izrel mere ihe ndị ahụ niile \nd Onyenwe anyị\nd* Chineke ha na-adịghị anabata na nzuzo. Ha wuru ebe ịchụ aja nye chi dị iche iche nʼobodo ha niile, e, nʼobodo ukwu ma nʼobodo nta ọbụla.  
\v 10 Ha manyeere onwe ha ogidi nkume, na ogidi chi Ashera nʼelu ugwu ọbụla, na nʼokpuru osisi ọbụla nwere ndo.  
\v 11 Ha chụrụ aja nsure ọkụ na-esi isi ụtọ nʼelu ugwu ọbụla dịka mba ndị naara ebi nʼala ahụ si eme, bụ ndị \nd Onyenwe anyị\nd* chụpụrụ site nʼala ha, mgbe Izrel bịara biri nʼebe ahụ. Ha mere ihe ọjọọ dị iche iche, nke mere ka iwe wee \nd Onyenwe anyị\nd* nke ukwuu.  
\v 12 E, ha fere arụsị dị iche iche ofufe, lefuo anya na \nd Onyenwe anyị\nd* dọrọ ha aka na ntị sị ha, “Unu emela ihe dị otu a.”  
\v 13 Mgbe niile ka \nd Onyenwe anyị\nd* na-eziga ndị amụma ya, na ndị ọhụ ụzọ, ịdọ Izrel na Juda aka na ntị, sị ha, “Sitenụ nʼajọ ihe unu na-eme chegharịa. Debenụ iwu na ụkpụrụ m, dịka iwu ahụ niile m nyere nna unu ha ka ha debe si dị, nke m sikwa nʼọnụ ndị ozi m bụ ndị amụma nye unu.” 
\p  
\v 14 Ma ndị Izrel jụrụ ige ntị. Kama ha kpachara anya kwesie olu ha ike dịka nna nna ha mere, bụ ndị na-ekwenyeghị na \nd Onyenwe anyị\nd* Chineke ha.  
\v 15 Ha jụrụ ụkpụrụ ya niile na ọgbụgba ndụ ya, nke ya na ndị bụ nna nna ha gbara na iwu nke ọ dọrọ ha aka na ntị ka ha debe. Ha gbasooro chi arụsị bụ ihe efu, ha onwe ha ghọkwara ihe efu. Ha ṅomiri mba dị iche iche ndị ahụ bi ha gburugburu, nʼagbanyeghị na \nd Onyenwe anyị\nd* nyere ha iwu sị, “Unu emela dịka ha.” 
\p  
\v 16 Ha jụrụ idebe iwu niile \nd Onyenwe anyị\nd* Chineke ha nyere ha. Ha meere onwe ha ogidi arụsị Ashera, kpụọrọ onwe ha oyiyi ụmụ ehi abụọ. Ha kpọrọ isiala nye Baal, na anyanwụ, na ọnwa, na kpakpando.  
\v 17 Ha jiri ụmụ ha ndị ikom na ụmụ ha ndị inyom chụọ aja nsure ọkụ nye chi ndị mba ọzọ. Ha gakwara nʼaja ịjụ ase, na ịgba aja, si otu a nyefee onwe ha nʼaka ime ihe jọrọ njọ nʼanya \nd Onyenwe anyị\nd*, si otu a kpasuo ya iwe. 
\p  
\v 18 Ya mere, \nd Onyenwe anyị\nd* wesoro Izrel iwe nke ukwuu, wezuga ha site nʼihu ya. Ọ dịkwaghị onye o kwere ka ọ fọdụ, karịakwa naanị ebo Juda.\f + \fr 17:18 \ft Ndị alaeze ndịda si nʼagbụrụ Simiọn na Benjamin, maọbụ naanị ebo Juda gosiri onwe ha ndị kwesiri ntụkwasị obi, gụọ akwụkwọ \xt 1Ez 11:13,32\f* 
\v 19 Ma ndị Juda jụkwara idebe ihe niile \nd Onyenwe anyị\nd* bụ Chineke ha nyere ha nʼiwu. Ha sooro omume ọjọọ ndị Izrel webatara.  
\v 20 Nʼihi nke a, \nd Onyenwe anyị\nd* jụrụ ndị Izrel niile. Ọ tara ha ahụhụ site nʼinyefe ha nʼaka ndị na-apụnara mmadụ ihe nʼike tutu ruo mgbe o mere ka e site nʼihu ya wezuga ha. 
\p  
\v 21 Mgbe \nd Onyenwe anyị\nd* mere ka ndị Izrel dọwapụ onwe ha site nʼalaeze Devid, ha mere Jeroboam nwa Nebat, eze ha. Ma Jeroboam mere ka Izrel site nʼiso \nd Onyenwe anyị\nd* wezuga onwe ha. O mere ka ha mee mmehie dị ukwuu.  
\v 22 Ọ dịkwaghị mgbe ụmụ Izrel sitere nʼime mmehie ahụ Jeroboam dubara ha pụta,  
\v 23 tutu ruo mgbe \nd Onyenwe anyị\nd* kpochapụrụ Izrel niile site nʼihu ya, dịka o kwuru na ọ ga-eme, site nʼọnụ ndị amụma na-ejere ya ozi. Ọ bụ nke a mere ndị Izrel ji gaa biri nʼAsịrịa dịka ndị a dọtara nʼagha ruo taa. 
\s1 Ndị ọhụrụ bịara biri na Sameria 
\p  
\v 24 Eze Asịrịa sitere nʼala Babilọn, Kuta, Ava, Hamat na Sefavaim kpọta ndị mmadụ bịara biri nʼobodo Sameria ịnọchi anya ndị Izrel niile e sitere nʼebe ahụ bupụ. Nʼụzọ dị otu a, ha nwetara Sameria birikwa nʼobodo ya niile.  
\v 25 Ma mgbe ndị Asịrịa malitere ibi nʼebe ahụ, ha atụghị egwu \nd Onyenwe anyị\nd*, maọbụ fee ya ofufe. Nʼihi ya, \nd Onyenwe anyị\nd* zitere ọdụm\f + \fr 17:25 \ft Nʼihi nʼala ahụ tọgbọrọ nʼefu nwa oge nta, nke mere ka ọdụm bi nʼọhịa ndị Palestia mụbaa. \xt Lev 26:21-22\f* ndị batara nʼetiti ha gbuo ụfọdụ mmadụ nʼime ha.  
\v 26 Ya mere, e zigara eze Asịrịa ozi sị ya, “Ndị ahụ i dọtara nʼagha mee ka ha bịa biri nʼobodo Sameria amaghị ihe chi nwe ala ahụ chọrọ. O zitere ọdụm nʼetiti ha, nke na-egbu ha, nʼihi na ndị ahụ amaghị ihe ọ chọrọ.” 
\p  
\v 27 Eze Asịrịa nyere iwu sị: “Ka otu onye nʼime ndị nchụaja\f + \fr 17:27 \ft Onye nʼotu nʼime ndị nchụaja ahụ Jeroboam họpụtara, bụ ndị na-achụ aja nye chi nwa ehi ahụ ọ kpụrụ na Betel. \xt 1Ez 12:31\f* e si na Sameria dọta nʼagha laghachi gaa biri nʼebe ahụ, izi ndị bi nʼobodo ahụ ihe chi ala ahụ chọrọ.”  
\v 28 Ya mere, otu nʼime ndị nchụaja ebuuru site na Sameria gaa ala ọzọ, bịara biri na Betel, kuziere ha otu ha ga-esi na-atụ egwu \nd Onyenwe anyị\nd*. 
\p  
\v 29 Nʼagbanyeghị nke a, ndị mba ọbụla meere onwe ha chi nke aka ha nʼobodo ahụ niile ebe ha bi nʼime ya. Ha guzobere chi ndị a nʼụlọ arụsị nke ndị Sameria wuru nʼebe niile dị elu.  
\v 30 Ndị si Babilọn mere chi ha a na-akpọ Sukọt Benot; ndị si Kut emee Neagal, ebe ndị si Hamat mekwara Ashima.  
\v 31 Ndị si Ava mekwara Nibaz, na Tatak, ma ndị si Sefavaim na-esure ụmụ ha nʼọkụ dịka aja nye Adramelek na Anamelek, bụ chi ndị Sefavaim.  
\v 32 Ha tụrụ egwu\f + \fr 17:32 \ft Kpọkwara isiala nye\f*\nd Onyenwe anyị\nd*, ma ha họpụtara ụdị mmadụ dị iche iche site nʼetiti onwe ha, ndị na-ejere ha ozi dịka ndị nchụaja nʼụlọ chi ha dị nʼebe niile dị elu.  
\v 33 Ha na-atụ egwu \nd Onyenwe anyị\nd* ma ha gara nʼihu na-efe chi nke aka ha dịka omenaala mba ebe ndị e si dọta ha nʼagha si dị. 
\p  
\v 34 Ruo taa, ha na-anọgidesi ike nʼife ofufe dịka ụzọ ochie ha si dị. Ha adịghị atụ egwu \nd Onyenwe anyị\nd*, maọbụ mee dịka ụkpụrụ na iwu niile, maọbụ dịka ntụziaka na ihe niile enyere nʼiwu si dị, bụ nke \nd Onyenwe anyị\nd* nyere ụmụ Jekọb, onye ọ kpọrọ Izrel.  
\v 35 Mgbe \nd Onyenwe anyị\nd* na ndị Izrel gbara ndụ, o nyere ha iwu sị, “Unu atụkwala chi ọzọ ọbụla egwu, maọbụ kpọọ isiala nye ha. Unu efela ha ofufe maọbụ chụọ aja nye ha.  
\v 36 Ma \nd Onyenwe anyị\nd*, onye ji ike dị ukwuu, na aka dị ike e setịpụrụ esetipụ kpọpụta unu site nʼala Ijipt, bụ naanị onye unu ga-atụ egwu. Ya ka unu ga-akpọ isiala nye, ya ka unu ga-achụrụ aja.  
\v 37 Unu ga-elezi anya hụ na unu debere ụkpụrụ na iwu niile, ntụziaka na ihe niile enyere nʼiwu ndị a e depụtara nʼakwụkwọ nye unu. Unu atụkwala egwu\f + \fr 17:37 \ft Maọbụ, \fqa efekwala\f* chi ndị ọzọ.  
\v 38 Unu echefula ọgbụgba ndụ ahụ mụ na unu gbara. Unu akpọkwala isiala nye chi ndị ọzọ nʼihi egwu.  
\v 39 Kama, tụọnụ egwu ma fee \nd Onyenwe anyị\nd* Chineke unu. Ọ bụ ya ga-anapụta unu site nʼaka ndị iro unu niile.” 
\p  
\v 40 Ma ndị Izrel egeghị ntị, kama, dịka ụzọ ọjọọ ha si dị, ha fere chi ọzọ ofufe.  
\v 41 Ọ bụ ezie na ndị a na-efe \nd Onyenwe anyị\nd* ofufe, ma ha nọgidekwara na-ejere arụsị niile ha ozi. Ruo taa, ụmụ ha, na ụmụ ụmụ ha, gara nʼihu na-emekwa ihe nna nna ha mere. 
\c 18  
\s1 Hezekaya eze Juda 
\p  
\v 1 Nʼafọ nke atọ nke ọchịchị Hoshea nwa Elaa eze Izrel ka Hezekaya nwa Ehaz eze Juda malitere ọchịchị nke ya.  
\v 2 Ọ gbara iri afọ abụọ na ise mgbe ọ malitere ị bụ eze. Ọ chịrị iri afọ abụọ na itoolu na Jerusalem. Aha nne ya bụ Abija,\f + \fr 18:2 \ft Maọbụ, \fqa Abi\f* ada Zekaraya.  
\v 3 O mere ihe ziri ezi nʼanya \nd Onyenwe anyị\nd*, dịka nna nna ya Devid.  
\v 4 O wepụrụ ebe niile dị elu, kurisie ogidi nsọ niile, gbutukwa ogidi Ashera niile. O tipịakwara agwọ bronz ahụ Mosis mere, nʼihi na ruo nʼoge ahụ, ụmụ Izrel na-esure aja nsure ọkụ na-esi isi ụtọ nye ya. (A kpọrọ ya Nehushtan.) 
\p  
\v 5 Hezekaya tụkwasịrị \nd Onyenwe anyị\nd*, Chineke Izrel obi ya. Nʼezie, o nwekwaghị onye ọzọ dị ka ya nʼetiti ndị eze Juda niile, ndị bu ya ụzọ chịa, na ndị so ya.  
\v 6 Ọ gbasoro \nd Onyenwe anyị\nd* nʼụzọ niile. O sitekwaghị nʼụzọ \nd Onyenwe anyị\nd* wezuga onwe ya. O debere ihe niile \nd Onyenwe anyị\nd* nyere Mosis nʼiwu.  
\v 7 \nd Onyenwe anyị\nd* nọnyeere ya nʼebe ọbụla ọ gara, ihe niile o mere gaara ya nke ọma. O nupuru isi jụ ịnọkwa nʼokpuru eze ndị Asịrịa, o fekwaghị ya ofufe.  
\v 8 O tigburu ndị Filistia nʼala ha niile ruo na Gaza, na obodo dị ya gburugburu. Ọ lara obodo ahụ niile nʼiyi, obodo ukwu niile e wusiri ike na obodo nta niile a na-ewusighị ike. 
\p  
\v 9 Nʼafọ nke anọ nke ọchịchị Hezekaya, nke bụkwa afọ nke asaa nke ọchịchị Hoshea nwa Elaa, bụ eze Izrel, Shalmanesa, eze Asịrịa gbagoro imegide Sameria, nọchibido ya gburugburu.  
\v 10 Mgbe afọ atọ gasịrị, nʼafọ nke isii nke ọchịchị Hezekaya, na afọ nke itoolu nke ọchịchị Hoshea, bụ eze Izrel, ndị agha Asịrịa dọtara Sameria nʼagha.  
\v 11 Ọ bụ nʼoge ahụ ka eze Asịrịa bupụrụ ndị Izrel niile bulaa ha Asịrịa nʼime obodo Hala, na Gozan nʼakụkụ iyi ukwu Hoboa, na nʼobodo ndị Midia.  
\v 12 Nke a mere nʼihi na ha jụrụ ige ntị nʼolu \nd Onyenwe anyị\nd* bụ Chineke ha, jụkwa ime ihe ọ chọrọ ka ha mee. Ha edebeghị ọgbụgba ndụ ya na iwu niile Mosis onyeozi \nd Onyenwe anyị\nd* nyere ha. Ha jụrụ ige ntị nʼiwu ndị a, maọbụ debe ha. 
\p  
\v 13 Nʼafọ nke iri na anọ nke ọchịchị eze Hezekaya, Senakerib bụ eze Asịrịa, busoro obodo Juda niile e wusiri ike agha, merikwaa ha.  
\v 14 Mgbe ahụ, Hezekaya chọrọ ụzọ ọ ga-esi mee udo, zie ozi zigara eze Asịrịa nʼobodo Lakish sị ya, “Emehiela m, biko, site nʼala m pụọ. Aga m akwụ gị ihe ọbụla ị chọrọ nʼaka m.” Eze Asịrịa sitere nʼaka Hezekaya eze Juda nara narị talenti ọlaọcha atọ, na iri talenti ọlaedo atọ.  
\v 15 Hezekaya chịịrị ọlaọcha niile ọ chọtara nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*, na akụ niile dị nʼụlọeze, nye ya eze Asịrịa. 
\p  
\v 16 Nʼoge ahụ, Hezekaya bụ eze Juda, nyakapụtachara ọlaedo niile o ji techie ibo na ibo ọnụ ụzọ ụlọnsọ ukwu \nd Onyenwe anyị\nd*, chịrị ihe ndị a niile nye eze Asịrịa. 
\s1 Senakerib ebuo agha megide Jerusalem 
\p  
\v 17 Eze Asịrịa sitere na Lakish zipụ ọchịagha\f + \fr 18:17 \ft A na-akpọ Tatan\f* onye ọkwa ya kasị ukwuu, onyeisi ndị na-eje ozi na ọchịagha ya na usuu ndị agha ka ha jekwuru Hezekaya na Jerusalem. Ndị agha a bịaruru Jerusalem kwụsị nʼakụkụ olulu warawara\f + \fr 18:17 \ft Olulu warawara mmiri nke eze Hezekaya gwuru, bụ maka i ji webata mmiri nʼime obodo site nʼiyi Gaihọn.\f* e gwuru ebe Ọdọ mmiri dị elu si nʼasọfe, nʼụzọ e si aga obosara ala ndị na-asụ akwa.  
\v 18 Mgbe ha kpọrọ eze oku ka ọ bịa, Eliakịm nwa Hilkaya, onye nlekọta ụlọeze, na Shebna, ode akwụkwọ eze, na Joa nwa Asaf, onye ndekọ akụkọ ihe mere, pụrụ jekwuru ha. 
\p  
\v 19 Ọchịagha ahụ sịrị ha, “Gwanụ Hezekaya: 
\pm “ ‘Otu a ka eze ukwu ahụ, bụ eze Asịrịa na-ekwu, Ọ bụ na gịnị ka ntụkwasị obi gị dabere?  
\v 20 Ị na-ekwu na i nwere ndụmọdụ na ike ibu agha, maọbụ naanị egbe ọnụ\f + \fr 18:20 \ft Ọ bụ sọsọ okwu egbugbere ọnụ\f* ka ị na-agba. Ọ bụ onye ka ị na-atụkwasị obi mere i ji enupu isi nʼokpuru m?  
\v 21 Lee, amatara m na ị na-atụkwasị obi nʼIjipt, mkpanaka achara ahụ gbajiri agbaji, nke na-adụwa aka onye ọbụla na-adabere na ya. Otu a ka Fero, eze Ijipt dị nye ndị niile na-atụkwasị ya obi.  
\v 22 Ma ọ bụrụ na unu asị m, “Anyị na-atụkwasị \nd Onyenwe anyị\nd* bụ Chineke anyị obi.” Ọ bụghị ya ka Hezekaya wezugara ebe ya niile dị elu na ebe ịchụ aja ya niile, na-asị Juda na Jerusalem, “Unu aghaghị ịkpọ isiala nʼebe ịchụ aja dị nʼime Jerusalem?” 
\pm  
\v 23 “ ‘Ma ugbu a, bịa kwee nna m ukwu, bụ eze Asịrịa nkwa. Aga m enye gị puku ịnyịnya abụọ ma ọ bụrụ na i nwere ike ịchọta ndị ga-agba ha.  
\v 24 Ị ga-esi aṅaa jụ otu onyeisi nke dịkarịsịrị nta nʼime ndịisi ọrụ onyenwe m, na-agbanyeghịkwa na i na-atụkwasị obi nʼIjipt maka inweta ụgbọ agha na ndị na-agba ịnyịnya?  
\v 25 Tinyere nke a, abịara m ibuso ala a agha na ibibi ya ma enweghị okwu sitere na Chineke bịa? Ọ bụ \nd Onyenwe anyị\nd* ya onwe ya gwara m ka m bilie megide obodo a, lakwaa ya nʼiyi.’ ” 
\p  
\v 26 Mgbe ahụ, Eliakịm nwa Hilkaya, Shebna na Joa sịrị ọchịagha ahụ, “Biko, gwa ndị ohu gị okwu nʼasụsụ Aramaik,\f + \fr 18:26 \ft Asụsụ Aramaik (ndị Siria) bụ asụsụ mba na mba ji emekọrịta ihe nʼoge ahụ, ma ọ mesịrị ghọọ asụsụ ndị Juu, site na senchuri nke ise tupu a mụọ Kraịst.\f* ebe ọ bụ na anyị na-aghọta ya. Agwala anyị okwu nʼasụsụ Hibru, ebe ndị nọ nʼelu mgbidi ga-anụ.” 
\p  
\v 27 Ma ọchịagha ahụ zaghachiri, “Ọ bụ nʼihi naanị nna unu ukwu na nye unu onwe unu ka nna m ukwu ji zite m, ka m kwuo ihe ndị a? Ọ bụghị nʼihi ndị mmadụ ahụ na-anọdụ nʼelu mgbidi, ndị, dịka unu, ha ga-eso rie nsị ha nyụrụ, ṅụọkwa mamịrị ha nyụrụ?” 
\p  
\v 28 Mgbe ahụ, ọchịagha ahụ guzoro were oke olu kwuo nʼasụsụ Hibru, sị, “Nụrụnụ okwu eze ukwu ahụ, bụ eze Asịrịa.  
\v 29 Nke a bụ ihe eze sịrị, unu ekwela ka Hezekaya duhie unu. Ọ pụghị ịzọpụta unu site nʼaka m.  
\v 30 Unu ekwela ka Hezekaya mee ka unu tụkwasị \nd Onyenwe anyị\nd* obi. Mgbe ọ na-asị, ‘Nʼezie, \nd Onyenwe anyị\nd* aghaghị ịnapụta anyị, a gaghị enyefe obodo a nʼaka eze Asịrịa.’ 
\p  
\v 31 “Unu aṅakwala Hezekaya ntị. Ihe a ka eze Asịrịa kwuru: Pụkwutenụ m, bịanụ ka mụ na unu mee udo.\f + \fr 18:31 \ft Na mgbe ochie a na-eme udo site nʼịgba ndụ\f* Mgbe ahụ, onye ọbụla nʼime unu ga-eri mkpụrụ si nʼubi vaịnị ya na nke si nʼosisi fiig ya, ṅụọkwa mmiri\f + \fr 18:31 \ft Nke a na-egosi ọnọdụ udo na ọganihu.\f* nke si nʼihe icheta mmiri ya:  
\v 32 ruo mgbe m ga-abịa duru unu gaa nʼala dịka nke unu, bụ ala mkpụrụ ọka na nke mmanya ọhụrụ, ala achịcha na ubi vaịnị, ala mmanụ aṅụ na osisi oliv jupụtara nʼime ya. Họrọnụ ndụ ka unu ghara ịnwụ. 
\p “Unu egela Hezekaya ntị, nʼihi na ọ bụ nrafu ka ọ na-arafu unu mgbe ọ na-asị, ‘\nd Onyenwe anyị\nd* ga-anapụta anyị.’  
\v 33 O nwere chi mba ọbụla nke napụtara ha site nʼaka eze Asịrịa?  
\v 34 Olee ebe ka chi ndị Hamat na Apad nọ? Olee ebe ka chi ndị Sefavaim, Hena na Iva nọkwa? Ha anapụtala Sameria site nʼaka m?  
\v 35 Olee chi nʼime chi mba ndị a niile bụ nke zọpụtarala ala ya site nʼaka m? Unu si aṅaa chee na \nd Onyenwe anyị\nd* pụrụ ịzọpụta Jerusalem site nʼaka m?” 
\p  
\v 36 Ma ndị ahụ niile gbara nkịtị, ha ekwughị ihe ọbụla, nʼihi na eze nyere ha iwu sị, “Unu azaghachila ya.” 
\p  
\v 37 Mgbe ahụ, Eliakịm nwa Hilkaya, onye na-elekọta ụlọeze, na Shebna ode akwụkwọ eze, na Joa nwa Asaf ode akwụkwọ, ha yi uwe ha dọwara adọwa, bịakwute Hezekaya gwa ya ihe niile onyeisi agha ahụ kwuru. 
\c 19  
\s1 A ga-agbapụta Jerusalem 
\p  
\v 1 Mgbe eze Hezekaya, nụrụ nke a, ọ dọwara uwe ya, yikwasị akwa mkpe, baa nʼime ụlọnsọ ukwu \nd Onyenwe anyị\nd*.  
\v 2 O zipụrụ Eliakịm onye nlekọta ụlọeze, Shebna ode akwụkwọ eze na ndị okenye nʼetiti ndị nchụaja, bụ ndị yikwa akwa mkpe, ka ha jekwuru Aịzaya onye amụma, nwa Emọz.  
\v 3 Ha sịrị ya, “Otu a ka Hezekaya sịrị, Ụbọchị taa bụ ụbọchị ahụhụ, na ịba mba na nke ihe ihere. Ụbọchị jọgburu onwe ya dịka ụbọchị nwanyị nọ nʼoke ihe mgbu nke ịmụ nwa ma ike adịkwaghị o ji amụpụta nwa ya.  
\v 4 Ma eleghị anya \nd Onyenwe anyị\nd* Chineke gị, ga-anụ okwu ahụ niile nke Rabashaka bụ ọchịagha, onye nna ya ukwu bụ eze Asịrịa, zitere ịkwa Chineke dị ndụ emo. Eleghị anya \nd Onyenwe anyị\nd* Chineke gị ga-abara ya mba nʼihi okwu ndị a niile o kwuru, bụ ndị ọ nụrụ. Ya mere, kpeere anyị ekpere, anyị bụ ndị fọdụrụ ndụ.” 
\p  
\v 5 Mgbe ndị ozi eze Hezekaya bịakwutere Aịzaya,  
\v 6 ọ sịrị ha, “Otu a ka unu ga-asị nna unu ukwu, ‘Otu a ka \nd Onyenwe anyị\nd* kwuru, Atụla egwu nʼihi okwu niile nke ị nụrụ, bụ nke ndị na-ejere eze Asịrịa ozi ji kwuluo m.  
\v 7 Gee ntị, mgbe ọ nụrụ akụkọ dị aṅaa, aga m eme ka ọ chọọ ịlaghachi nʼobodo nke aka ya. Nʼebe ahụ ka m ga-emekwa ka e jiri mma agha gbuo ya.’ ” 
\p  
\v 8 Mgbe ọchịagha ahụ nụrụ na eze Asịrịa e sitela nʼobodo Lakish pụa, ọ laghachiri hụ na eze Asịrịa na-ebuso obodo Libna agha. 
\p  
\v 9 Nʼoge ahụ, Senakerib natara ozi na Tiahaka, eze Kush,\f + \fr 19:9 \ft Nke a bụ Itiopia ugbu a\f* na-apụta ịbịa ibuso ya agha. Ya mere, o zipụrụ ndị ozi ka ha ga zie Hezekaya ozi, sị,  
\v 10 “Gwanụ Hezekaya, eze Juda, Ekwela ka Chineke onye ị na-atụkwasị obi duhie gị, mgbe ọ na-asị, ‘Agaghị enyefe Jerusalem nʼaka eze Asịrịa.’  
\v 11 Nʼezie a, ị nụla ihe ndị eze Asịrịa mere obodo niile ha busoro agha, otu ha si bibie ha kpamkpam. Ma a ga-anapụtakwa gị onwe gị?  
\v 12 Chi niile nke mba niile ndị ahụ nna nna m ha lara nʼiyi, ha napụtara ha, bụ chi ndị Gozan, Haran, Rezef na nke ndị Eden, ndị nọ na Tel Asa?  
\v 13 Olee ebe eze ndị Hamat maọbụ eze Apad nọ? Olee ebe eze obodo Lair, Sefavaim, Hena na Iva nọkwa?” 
\s1 Ekpere Hezekaya 
\p  
\v 14 Mgbe Hezekaya natara akwụkwọ ozi a site nʼaka ndị ozi ahụ, gụọ ya, o weere ya gaa nʼime ụlọnsọ \nd Onyenwe anyị\nd*, gbasaa ya nʼihu \nd Onyenwe anyị\nd*.  
\v 15 Hezekaya kpere ekpere nye \nd Onyenwe anyị\nd*, sị, “O, \nd Onyenwe anyị\nd*, Chineke nke Izrel, onye ocheeze ya dị nʼetiti ndị cherubim, naanị gị bụ Chineke na-achị alaeze niile nke ụwa. Ọ bụkwa naanị gị kere eluigwe na ụwa.  
\v 16 Tọọ ntị gị nʼala, o \nd Onyenwe anyị\nd* ma nụrụ; meghee anya gị abụọ \nd Onyenwe anyị\nd*, ka ịhụ; gee ntị nụkwa okwu ndị ahụ Senakerib zitere, nke o ji ekwulu Chineke dị ndụ. 
\p  
\v 17 “Nʼeziokwu, \nd Onyenwe anyị\nd*, ndị eze Asịrịa alala mba niile a dị iche iche na ala ha nʼiyi, mee ka ha tọgbọrọ nʼefu.  
\v 18 Ha atụnyekwala chi ha niile nʼime ọkụ, repịakwa ha, nʼihi na ọ bụghị chi ka ha bụ, kama ha bụ naanị ihe a kpụrụ akpụ, nke mmadụ ji osisi na nkume pịa.  
\v 19 Ugbu a, \nd Onyenwe anyị\nd* Chineke anyị, biko, zọpụta anyị site nʼaka ya, ka alaeze niile nke ụwa mata na naanị gị \nd Onyenwe anyị\nd*, naanị, bụ Chineke.” 
\s1 Aịzaya ebuo amụma ọdịda Senakerib 
\p  
\v 20 Mgbe ahụ Aịzaya nwa Emọz zigaara Hezekaya ozi sị, “Otu a ka \nd Onyenwe anyị\nd*, Chineke Izrel sịrị, Anụla m ekpere i kpere banyere Senakerib, eze Asịrịa.  
\v 21 Nke a bụ okwu nke \nd Onyenwe anyị\nd* kwuru megide ya: 
\q1 “ ‘Nwaagbọghọ na-amaghị nwoke, bụ Ada Zayọn 
\q2 na-elelị gị anya, ma jirikwa gị na-eme ihe ọchị. 
\q1 Nwaada Jerusalem 
\q2 na-efufekwa isi ya mgbe ị na-agbapụ ọsọ 
\q1  
\v 22 Onye ka ị kparịrị ma kwulukwaa? 
\q2 Ọ bụ onye ka i sitere na nganga gị 
\q1 welie olu okwu gị na anya gị elu megide? 
\q2 Ọ bụ megide Onye Nsọ nke Izrel? 
\q1  
\v 23 I sitere nʼaka ndị ozi gị 
\q2 kparịa Onyenwe anyị, kwuluo ya, 
\q1 ị sịkwara, 
\q2 “Eji m ọtụtụ ụgbọala m 
\q1 rigoruo ebe dị elu nke nʼelu ugwu niile, 
\q2 nʼebe kachasị elu nke ugwu Lebanọn. 
\q1 Egbudasịala m osisi sida ya niile toro ogologo, 
\q2 na osisi junipa ya niile kachasị mma. 
\q1 Ejeruola m na nsọtụ niile ya, 
\q2 bụ ebe kachasị maa mma nʼoke ọhịa ya niile. 
\q1  
\v 24 Egwuola m ọtụtụ olulu mmiri nʼala ndị mba ọzọ, 
\q2 ṅụkwa mmiri dị nʼebe ahụ. 
\q1 Ọ bụ ọbụ ụkwụ m ka m ji mee 
\q2 ka isi iyi niile dị nʼIjipt takpọọ.” 
\b  
\q1  
\v 25 “ ‘Ọ bụ na ị nụbeghị? 
\q2 Na mgbe ochie ka m kpebiri ya. 
\q1 Nʼụbọchị ndị ahụ gara aga ka m nọ pịa ọpịpịa ya; 
\q2 ugbu a, emeela m ka ọ bịa na mmezu, 
\q1 na ị meela ka obodo nke mgbidi gbara gburugburu, 
\q2 ghọọ mkpokọta nkume. 
\q1  
\v 26 Ndị bi nʼime ha, ndị a napụrụ ike ha nwere 
\q2 bụ ndị dara mba, ndị e tinyekwara nʼọnọdụ ihere. 
\q1 Ha dịka ahịhịa ndụ puru nʼala ubi 
\q2 na ome na-epupụta epupụta 
\q1 nakwa ahịhịa na-etopụta nʼelu ụlọ 
\q2 nke anwụ na-achakpọ tupu o tolite. 
\b  
\q1  
\v 27 “ ‘Ma amaara m ebe ị nọ ọnọdụ 
\q2 marakwa ọpụpụ gị na mbata gị 
\q2 marakwa oke iwe gị megide m. 
\q1  
\v 28 Nʼihi ọnụma dị gị nʼobi megide m, 
\q2 nʼihi na mkparị gị eruola m ntị, 
\q1 aga m etinye nko m nʼimi gị 
\q2 werekwa mkpụmkpụ igwe m kpachie egbugbere ọnụ gị 
\q1 mee ka ị laghachi 
\q2 site nʼụzọ ahụ nke i siri bịa.’ 
\p  
\v 29 “Ma nke a ga-abụ ihe ịrịbama, nye gị, Hezekaya: 
\q1 “Nʼafọ a unu ga-eri ihe na-epu nʼonwe ya, 
\q2 nʼafọ nke abụọ unu ga-eri ihe ubi si na nke ahụ pupụta. 
\q1 Ma nʼafọ nke atọ ghaanụ mkpụrụ ubi, weenụ ihe ubi; 
\q2 kụọ vaịnị nʼubi vaịnị, riekwanụ mkpụrụ ha. 
\q1  
\v 30 Ọzọkwa, ndị fọdụrụ nʼalaeze Juda 
\q2 ga-agba mgbọrọgwụ nʼokpuru ala, mịkwaa mkpụrụ nʼelu. 
\q1  
\v 31 Nʼihi na ọ bụ site na Jerusalem ka ndị fọdụrụ ga-esi pụta; 
\q2 otu ndị fọdụrụ ndụ ga-esitekwa nʼugwu Zayọn pụta. 
\b  
\m “Ọ bụ site nʼịnụ ọkụ nʼobi nke \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile ga-emezu nke a. 
\b  
\p  
\v 32 “Ya mere, nke a bụ ihe \nd Onyenwe anyị\nd* kwuru banyere eze Asịrịa, sị, 
\q1 “ ‘Ọ gaghị azọbata ụkwụ ya nʼime obodo a 
\q2 maọbụ gbaa ọ bụladị otu àkụ nʼebe a. 
\q1 Ọ gaghị eji ọta jegharịa nʼọnụ ụzọ ama ya, 
\q2 maọbụ wuo mgbidi nnọchibido megide ya. 
\q1  
\v 33 Ụzọ o si bịa ka ọ ga-esi laghachi; 
\q2 ọ gaghị abanye nʼobodo a. 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\q1  
\v 34 Aga m echebe obodo a, zọpụtakwa ya 
\q2 nʼihi aha m, na nʼihi Devid, bụ ohu m.’ ” 
\p  
\v 35 Nʼabalị ahụ, mmụọ ozi \nd Onyenwe anyị\nd* pụrụ gaa tigbuo otu puku narị na puku iri asatọ na ise nʼụlọ ikwu ndị Asịrịa. Mgbe ndị mmadụ tetara nʼisi ụtụtụ, lee, ozu ka ha jupụtara ebe niile.  
\v 36 Ya mere, Senakerib, eze Asịrịa biliri ije, laghachi nʼala ya. Ọ laghachiri biri nʼobodo Ninive. 
\p  
\v 37 Otu ụbọchị, mgbe ọ nọ na-akpọ isiala nʼụlọ chi ya a na-akpọ Nisrọk, ụmụ ya ndị ikom aha ha bụ Adramelek na Shareza were mma agha gbuo ya. Ha gbapụrụ ọsọ gbaga nʼala Ararat. Isahadon, bụ nwa ya nwoke, ghọrọ eze nʼọnọdụ ya. 
\c 20  
\s1 Ọrịa Hezekaya 
\p  
\v 1 Nʼoge ahụ, Hezekaya rịara ọrịa ruo na ọ gaara anwụ. Aịzaya onye amụma nwa Emọz bịakwutere ya sị ya, “Otu a ka \nd Onyenwe anyị\nd* sịrị, Dozie ezinaụlọ gị, nʼihi na ị ga-anwụ. Ị gaghị esite nʼute ọrịa a bilie.” 
\p  
\v 2 Hezekaya tụgharịrị chee ihu ya nʼaja ụlọ, kpee ekpere nye \nd Onyenwe anyị\nd*, sị,  
\v 3 “Chetakwa, \nd Onyenwe anyị\nd*, otu m si jegharịa nʼihu gị nʼikwesị ntụkwasị obi, jiri obi m niile fee gị ofufe, ma meekwa ihe dị mma nʼanya gị.” Hezekaya bekwara akwa nke ukwuu. 
\p  
\v 4 Tupu Aịzaya esite nʼetiti ogige ụlọeze pụọ, okwu nke \nd Onyenwe anyị\nd* rutere ya ntị, sị ya:  
\v 5 “Gaghachi azụ, gaa gwa Hezekaya, onye na-achị ndị m, ‘Otu a ka \nd Onyenwe anyị\nd* bụ Chineke nna gị Devid, kwuru: Anụla m ekpere gị, ahụkwala m anya mmiri akwa gị, aga m agwọ gị. Aga m eme ka ahụ dị gị ike nʼụbọchị nke atọ site taa, mgbe ahụ ị ga-aga nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*.  
\v 6 Aga m atụkwasị afọ iri na ise nʼụbọchị ndụ gị. Aga m anapụtakwa gị na obodo a site nʼaka eze Asịrịa. Aga m echebe obodo a nʼihi mụ onwe m, na nʼihi Devid, bụ ohu m.’ ” 
\p  
\v 7 Mgbe ahụ, Aịzaya sịrị, “Kwadoonụ mmanụ fiig dị ọkụ.” Ha mere nke a, teekwasị ya nʼelu etuto ahụ, ahụ dịkwara ya mma. 
\p  
\v 8 Mgbe ahụ, Hezekaya jụrụ Aịzaya sị, “Gịnị ga-abụ ihe ịrịbama na \nd Onyenwe anyị\nd* ga-agwọ m, na m ga-aga nʼụlọnsọ ukwu \nd Onyenwe anyị\nd* nʼụbọchị nke atọ na-abịa nʼihu?” 
\p  
\v 9 Aịzaya zara, “Nke a bụ ihe ama \nd Onyenwe anyị\nd* nye gị na \nd Onyenwe anyị\nd* ga-emezu ihe o kwere na nkwa. Ị chọrọ ka onyinyo a gaa nʼihu ihe nrigo iri, ka ọ bụ ka ọ laa azụ ihe nrigo iri?” 
\p  
\v 10 Hezekaya zara sị, “Ọ dị mfe ka onyinyo gaa nʼihu nzọ ụkwụ iri. Ma mee ka onyinyo a laa azụ ihe nrigo iri.” 
\p  
\v 11 Mgbe ahụ, Aịzaya, onye amụma rịọrọ \nd Onyenwe anyị\nd* ka o meere Hezekaya nke a. \nd Onyenwe anyị\nd* mekwara ka onyinyo laghachi azụ ihe nrigo iri dịka o si gbada nʼihe nrigo ụlọ Ehaz. 
\s1 Ndị ozi si Babilọn 
\p  
\v 12 Nʼoge ahụ, Merodak-Baladan,\f + \fr 20:12 \fq Merodak, \ft bụ aha chi ndị Babilọn a na-akpọ \fqa Maadọk, \ft Ọ bụ ya ka a gụrụ nwa Baladan.\f* nwa Baladan, bụ eze Babilọn zigaara Hezekaya akwụkwọ ozi ekele na onyinye, nʼihi na ọ nụrụ na Hezekaya rịara ọrịa.  
\v 13 Hezekaya nabatara ndị ozi ahụ gosi ha ihe niile dị nʼụlọakụ ya, ọlaọcha, na ọlaedo, ụda dị iche iche na-esi isi ụtọ na ezigbo mmanụ oliv, ụlọ ebe ngwa agha ya niile dị, na ihe niile bụ akụ o nwere. Ọ dịghị ihe dị nʼụlọeze ya maọbụ nʼalaeze ya niile nke ọ na-egosighị ha. 
\p  
\v 14 Mgbe ahụ, Aịzaya onye amụma jekwuru eze Hezekaya jụọ ya sị, “Gịnị ka ndị ikom ndị ahụ kwuru? Ebeekwa ka ha si bịakwute gị?” 
\p Hezekaya zara sị, “Ọ bụ nʼala dị anya ka ha si, ha si Babilọn.” 
\p  
\v 15 Onye amụma jụrụ, “Gịnị ka ha hụrụ nʼụlọ gị?” 
\p Hezekaya zara sị, “Ihe niile nke dị nʼụlọ m ka ha hụrụ. Ọ dịghị ihe niile dị nʼụlọakụ m nke m na-egosighị ha.” 
\p  
\v 16 Mgbe ahụ, Aịzaya sịrị Hezekaya, “Gee ntị nụrụ okwu \nd Onyenwe anyị\nd*.  
\v 17 Lee, oge na-abịa mgbe a ga-eburu ihe niile dị nʼụlọeze gị, na ihe niile nke nna nna gị ha debere nʼụlọakụ ruo taa, buru ha bulaa Babilọn. Ọ dịkwaghị ihe ga-afọdụ, otu a ka \nd Onyenwe anyị\nd* kwuru.  
\v 18 A ga-ebupụ ụfọdụ nʼime ụmụ gị, ndị bụ ahụ na ọbara gị,\f + \fr 20:18 \ft Ụmụ sị nʼahụ gị pụta\f* ndị a ga-amụtara gị, buru ha pụọ nʼebe dị anya, ha ga-abụ ndị onozi nʼụlọeze nke eze Babilọn.” 
\p  
\v 19 Hezekaya zaghachiri, “Okwu \nd Onyenwe anyị\nd* nke i kwuru dị mma.” Nʼihi na o chere nʼobi ya sị, “Ọ bụ na udo na nchekwa agaghị adị nʼoge ndụ m?” 
\p  
\v 20 Ma banyere ihe ndị ọzọ niile mere nʼoge ọchịchị Hezekaya, ọrụ niile ọ rụrụ, tinyere ọdọ mmiri o gwuru, na olulu ọwa mmiri\f + \fr 20:20 \ft Hezekaya gbobichiri mmiri iyi Gaihọn, gwuo olulu ebe mmiri a si aga, ka ọ dịrị ha mfe i nweta mmiri ma ndị iro gbaa Jerusalem gburugburu nʼoge agha. \xt 2Ih 32:30\f* na-aga o gwuru, nke o ji webata mmiri nʼime obodo, ọ bụ na e deghị ha nʼakwụkwọ akụkọ ihe mere nʼoge ndị eze Juda?  
\v 21 Hezekaya sooro ndị nna nna ya dinaa nʼọnwụ. Manase nwa ya ghọrọ eze nʼọnọdụ ya. 
\c 21  
\s1 Manase eze Juda 
\p  
\v 1 Manase gbara afọ iri na abụọ mgbe ọ malitere ịbụ eze. Ọ chịrị iri afọ ise na ise na Jerusalem. Aha nne ya bụ Hefziba.  
\v 2 O mere ihe dị njọ nʼanya \nd Onyenwe anyị\nd*, site nʼịgbaso ihe arụ niile nke ndị mba ọzọ bi nʼala ahụ na mbụ mere, bụ ndị \nd Onyenwe anyị\nd* chụpụrụ nʼihu ndị Izrel.  
\v 3 O wugharịrị ebe dị elu niile nke nna ya Hezekaya lara nʼiyi. O wukwara ebe ịchụ aja dị iche iche nye Baal, pịakwa ogidi Ashera, dịka Ehab eze Izrel mere. Ọ kpọrọ isiala nye usuu ihe niile nke dị na mbara eluigwe,\f + \fr 21:3 \ft Nke a bụ anyanwụ, ọnwa na kpakpando\f* feekwa ha ofufe.  
\v 4 O wuru ebe ịchụ aja dị iche iche, nʼime ụlọnsọ \nd Onyenwe anyị\nd*, nke \nd Onyenwe anyị\nd*, kwuru okwu banyere ya sị, “Ọ bụ na Jerusalem ka m ga-etinye Aha m.”  
\v 5 O wuru ebe ịchụ aja nye usuu ihe niile dị na mbara eluigwe,\f + \fr 21:5 \ft Nke a bụ anyanwụ, ọnwa na kpakpando\f* nʼogige abụọ nke nʼụlọnsọ \nd Onyenwe anyị\nd*.  
\v 6 O jikwa nwa ya nwoke chụọ aja nʼime ọkụ, ọ gbara aja, chọọ ọsịsa nʼaka ndị mgbaasị, jụta ase nʼaka ndị na-ajụ mmụọ ọjọọ ase, ya na ndị dibịa afa mekọkwara ihe. O mere ihe dị njọ nʼebe ọ dị ukwuu nʼanya \nd Onyenwe anyị\nd*, si otu a kpasuo ya iwe. 
\p  
\v 7 O were chi Ashera a pịrị apị, bụ nke o mere, debe nʼime ụlọnsọ ahụ, nke \nd Onyenwe anyị\nd* gwara Devid na nwa ya Solomọn okwu, sị, “Nʼụlọnsọ a na nʼime Jerusalem, nke mụ onwe m họpụtara site nʼebo niile nke Izrel, ka m ga-akpọkwasị Aha m ruo mgbe ebighị ebi.  
\v 8 Ma agaghị emekwa ka ụkwụ ndị Izrel wagharịa ọzọ site nʼala ahụ nke m nyere ndị nna nna ha, naanị ma ọ bụrụ na ha elezie anya debe ihe niile m nyere ha nʼiwu ma debekwa iwu niile nke ohu m bụ Mosis nyere ha.”  
\v 9 Ma ha egeghị ntị, Manase duhiere ha, mee ka ha mee ihe dị njọ karịa nke ndị mba niile ndị \nd Onyenwe anyị\nd* lara nʼiyi site nʼihu ndị Izrel. 
\p  
\v 10 Mgbe ahụ, \nd Onyenwe anyị\nd* kwuru okwu site nʼọnụ ndị amụma ya, sị,  
\v 11 “Nʼihi na Manase, eze Juda emeela ihe arụ ndị a, o meela ihe dị njọ karịa nke ndị Amọrait,\f + \fr 21:11 \ft Nke a bụ aha ozuzu e ji mara ndị niile bi nʼala Kenan tupu ndị Izrel abịa buso ha agha ma merie ha.\f* bụ ndị bụ ya ụzọ, o werela arụsị ya duba Juda nʼime mmehie.  
\v 12 Ya mere, nke a bụ ihe \nd Onyenwe anyị\nd*, bụ Chineke nke Izrel, sịrị: Lee, ana m aga iweta mbibi dị ukwuu nke ga-adakwasị Jerusalem na Juda, nke ntị ọbụla nụrụ ya ga-azụ wuruwuru.  
\v 13 Aga m esetipụ eriri ịtụ ọtụtụ nke m ji megide Sameria na ihe ịtụ mgbidi nke m ji megide ụlọ Ehab, nʼelu Jerusalem. Aga m ehichapụ Jerusalem dịka mmadụ si ehichapụ efere, hichaa ya ihu na azụ ma kpuo ya ihu nʼala.  
\v 14 Aga m agbakụtakwa ndị fọdụrụ nʼihe nketa m azụ, were ha nyefee nʼaka ndị iro ha. Ha ga-aghọ ihe anaara nʼike, ghọọkwa ihe nkwata nʼagha nye ndị iro ha niile,  
\v 15 nʼihi na ha emeela ihe dị njọ nʼanya m, kpasukwaa m iwe, site nʼụbọchị nna nna ha si Ijipt pụta ọbụladị ruo taa.” 
\p  
\v 16 Nke ka nke, Manase gbukwara ọtụtụ ndị aka ha dị ọcha, ruo na ọ wụsaara ọbara ha site nʼotu akụkụ Jerusalem ruo nʼakụkụ nke ọzọ ya, nke a agụnyeghị mmehie ahụ nke o dubara ndị Juda ime, nke mere ka ha mee ihe dị njọ nʼanya \nd Onyenwe anyị\nd*. 
\p  
\v 17 Ma banyere ihe ndị ọzọ niile mere nʼoge ọchịchị Manase na ihe niile o mere, tinyere mmehie niile nke o mere, ọ bụ na e deghị ha nʼakwụkwọ akụkọ ihe mere nʼoge ndị eze Juda?  
\v 18 Manase soro ndị nna nna ya ha dina nʼọnwụ, e lie ya nʼime ubi a gbara ogige nʼụlọeze ya, bụ ubi Ụza a gbara ogige. Amọn nwa ya ghọrọ eze nʼọnọdụ ya. 
\s1 Amọn eze Juda 
\p  
\v 19 Amọn gbara iri afọ abụọ na abụọ mgbe ọ malitere ịbụ eze. Ọ chịrị afọ abụọ na Jerusalem. Aha nne ya bụ Meshulemet, ada Haruz onye Jotba.  
\v 20 O mere ihe dị njọ nʼanya \nd Onyenwe anyị\nd* dịka nna ya Manase mere.  
\v 21 Ọ gbasoro ụzọ ahụ niile dị iche nke nna ya gbasoro. O fere arụsị niile nke nna ya fere, kpọọkwa isiala nye ha.\f + \fr 21:21 \ft \xt Nkp 2:12-13; 1Ez 11:33\f* 
\v 22 Ọ jụrụ iso \nd Onyenwe anyị\nd*, bụ Chineke nna nna ya ha, jụkwa ibi ndụ irube isi nye ya. 
\p  
\v 23 Ndị na-ejere Amọn ozi gbara izu megide ya, ha gburu eze nʼime ụlọeze ya.  
\v 24 Mgbe ahụ, ndị ala ahụ gburu ndị niile ahụ gbara izu megide eze Amọn. Ha mere Josaya nwa ya nwoke eze nʼọnọdụ ya. 
\p  
\v 25 Ma banyere ihe ndị ọzọ niile mere nʼoge ọchịchị Amọn na ihe ndị o mere, ọ bụ na e deghị ha nʼakwụkwọ akụkọ ihe mere nʼoge ndị eze Juda?  
\v 26 E liri ya nʼili nke aka ya, dị nʼogige Ụza. Josaya nwa ya ghọrọ eze nʼọnọdụ ya. 
\c 22  
\s1 Akwụkwọ iwu a chọtara 
\p  
\v 1 Afọ asatọ ka Josaya gbara mgbe ọ malitere ịbụ eze Juda. Iri afọ atọ na otu ka ọ chịrị na Jerusalem. Aha nne ya bụ Jedida, nwa Adaya onye Bozkat.  
\v 2 O mere ihe ziri ezi nʼanya \nd Onyenwe anyị\nd*, gbasookwa ụzọ niile nke nna nna ya Devid kpamkpam, o sighị nʼụzọ a wezuga onwe ya gaa nʼaka nri maọbụ nʼaka ekpe. 
\p  
\v 3 Nʼafọ nke iri na asatọ nke ọchịchị ya, eze Josaya, zigara ode akwụkwọ bụ Shefan nwa Azalaya, onye bụkwa nwa nwa Meshulam, ka ọ gaa nʼụlọnsọ \nd Onyenwe anyị\nd*. Ọ sịrị ya,  
\v 4 “Gakwuru Hilkaya onyeisi nchụaja, sị ya, gụkọta ego nke e webatara nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*, bụ nke ndị na-eche ọnụ ụzọ nakọtara site nʼaka ndị mmadụ.  
\v 5 Gwa ha ka ha nyefee ya nʼaka ndị ikom ahọpụtara maka ilekọta ọrụ nʼụlọnsọ ahụ. Ka ndị ikom a kwụọ ndị ọrụ na-arụzi ụlọnsọ \nd Onyenwe anyị\nd* ụgwọ ọrụ,  
\v 6 ya bụ, inye ya ndị ọkpọ ǹtu, ndị na-ewu ụlọ, na ndị na-edo nkume ụlọ. Ha jirikwa ego ahụ zụta osisi na nkume a wara awa, maka i ji dozie ụlọnsọ ahụ.  
\v 7 Ọ dịghị mkpa ka ha gụzie otu ha si mefuo ego nke e nyefere ha nʼaka, nʼihi na ọrụ ha egosila na ha kwesiri ntụkwasị obi.” 
\p  
\v 8 Hilkaya onyeisi nchụaja, sịrị Shefan ode akwụkwọ, “Achọtala m Akwụkwọ Iwu\f + \fr 22:8 \ft Akwụkwọ Iwu a, nke a chọtara bụ akwụkwọ Diuteronomi, \xt Dit 31:24-26; 2Ih 34:14\ft  Nchọpụta akwụkwọ a, gosiri nʼụzọ pụtara ìhè oke nnupu isi dị nʼala Izrel megide iwu Chineke nʼoge eze Manase na-achị.\f* nʼime ụlọnsọ \nd Onyenwe anyị\nd*.” O nyere ya Shefan, onye nke gụkwara ya.  
\v 9 Mgbe ahụ, Shefan, bụ ode akwụkwọ, bịakwutere eze, gwa ya sị, “Ndị ozi gị enyefela ego niile nke dị nʼụlọnsọ \nd Onyenwe anyị\nd* nʼaka ndị ọrụ na nʼaka ndị nlekọta nọ nʼụlọnsọ Onyenwe anyị.”  
\v 10 Mgbe ahụ, Shefan bụ ode akwụkwọ, gwara eze sị, “O nwere akwụkwọ Hilkaya, onye nchụaja nyere m.” Shefan gụpụtara ihe dị nʼakwụkwọ a nʼihu eze. 
\p  
\v 11 Mgbe eze nụrụ okwu niile dị nʼime Akwụkwọ Iwu ahụ, ọ dọwara uwe ya.\f + \fr 22:11 \ft Nʼoge ochie, ndị mmadụ na-adọwa uwe nʼihi obi mwute\f* 
\v 12 O nyere Hilkaya bụ onyeisi nchụaja, Ahikam nwa Shefan, Akboa nwa Mikaya, Shefan ode akwụkwọ na Asaya, bụ onye ọrụ eze, iwu, sị ha,  
\v 13 “Gaanụ jụta \nd Onyenwe anyị\nd* ase, nʼisi m na nʼisi ndị m, na Juda niile, banyere ihe niile e dere nʼakwụkwọ a nke a chọtara. Nʼihi na ọnụma \nd Onyenwe anyị\nd* dị ukwuu bụ nke na-ere ọkụ megide anyị, nʼihi na ndị bu anyị ụzọ erubeghị isi nʼokwu nke akwụkwọ iwu a, ha agbasoghị ihe niile e dere nʼime ya banyere anyị.” 
\p  
\v 14 Hilkaya onye nchụaja, Ahikam, Akboa, Shefan na Asaya, jekwuuru Hulda, bụ onye amụma nwanyị. Onye bụ nwunye Shalum, nwa Tikva, nwa Hahas, ọ bụ onye na-elekọta uwe. Hulda na-ebi na mpaghara Jerusalem e wuru ọhụrụ. 
\p  
\v 15 Ọ sịrị ha, “Otu a ka \nd Onyenwe anyị\nd* bụ Chineke nke Izrel kwuru: Gwanụ nwoke ahụ ziri unu ka unu bịakwutem, sị,  
\v 16 ‘Otu a ka \nd Onyenwe anyị\nd* na-ekwu: Ana m aga iweta mbibi ga-adakwasị ebe a na ndị niile bi nʼime ya, dịka ihe niile e dere nʼime akwụkwọ nke eze Juda gụrụ, si dị.  
\v 17 Nʼihi na ha ajụla m, gbakụta m azụ, chụọ aja nsure ọkụ na-esi isi ụtọ nye chi ndị ọzọ, kpasuo m iwe site na arụsị niile nke aka ha mepụtara. Iwe m ga-adị ọkụ megide ebe a, ọ gaghị akwụsịkwa.’  
\v 18 Gwanụ eze Juda, onye ahụ zitere unu ịjụta ase site nʼọnụ \nd Onyenwe anyị\nd* sị ya, ‘Ihe ndị a ka \nd Onyenwe anyị\nd*, Chineke Izrel na-ekwu banyere okwu ndị ahụ ị nụrụ.  
\v 19 Nʼihi na o wutere gị nʼobi, na i wedakwara onwe gị nʼala nʼihu Chineke, mgbe ị nụrụ ihe m kwuru megide ebe a na ndị bi nʼime ya, na ha ga-abụ ihe a bụrụ ọnụ, na ihe tọgbọrọ nʼefu, nʼihi na i dọwara uwe gị, bekwaa akwa nʼihu m, mụ onwe m anụkwala, otu a ka \nd Onyenwe anyị\nd* kwupụtara.  
\v 20 Ya mere, aga m achịkọta gị nye nna nna gị ha, a ga-eli gị nʼudo. Anya gị agaghị ahụ mbibi nke m ga-eme ka ọ bịakwasị ebe a.’ ” 
\p Ha laghachiri inye eze ọsịsa ya. 
\c 23  
\s1 Ọgbụgba ndụ eze na ndị Juda 
\p  
\v 1 Mgbe ahụ, eze zigara ozi kpọkọta ndị okenye Juda na Jerusalem.  
\v 2 Ọ gara nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*, ya na ndị ikom Juda niile, ndị niile bi na Jerusalem, na ndị nchụaja, na ndị amụma niile, na ndị mmadụ niile, site nʼonye nta ruo na onye ukwu. Ọ gụpụtara na ntị onye ọbụla okwu niile si nʼakwụkwọ ọgbụgba ndụ ahụ, bụ nke achọtara nʼime ụlọnsọ \nd Onyenwe anyị\nd*.  
\v 3 Eze guzoro nʼakụkụ ogidi, kwee nkwa nʼihu \nd Onyenwe anyị\nd*, ịgbaso \nd Onyenwe anyị\nd*, na iji obi ya niile, na mkpụrụobi ya niile, debe ihe niile o nyere nʼiwu, nʼihe ama ya niile na ụkpụrụ ya niile. O si otu a mee ka okwu niile nke ọgbụgba ndụ ahụ e dere nʼakwụkwọ guzosie ike. Mgbe ahụ, ndị mmadụ niile kwekwara nkwa idebe ọgbụgba ndụ ahụ. 
\p  
\v 4 Eze nyere Hilkaya onyeisi nchụaja na ndị nchụaja na-esote nʼọkwa, na ndị na-eche ọnụ ụzọ mbata, iwu ka ha site nʼụlọnsọ \nd Onyenwe anyị\nd* kwapụtasịa ngwongwo niile e mere nye Baal, na Ashera, na usuu ihe niile nke mbara eluigwe.\f + \fr 23:4 \ft Nke a bụ anyanwụ, ọnwa na kpakpando\f* O sunyere ha niile ọkụ nʼazụ Jerusalem, nʼọhịa dị na Ndagwurugwu Kidrọn, buru ntụ ha bulaa Betel.\f + \fr 23:4 \ft Betel bụ ebe Ụlọ Chineke dị nʼoge ochie, ma ọtụtụ ndị eze Izrel jiri ya mere ebe ha na-efe arụsị ha. \xt Jen 28:19; 1Ez 12:25-29\f* 
\v 5 Ọ chụdara ndị nchụaja arụsị ndị ahụ niile, bụ ndị eze Juda họpụtara isure ihe na-esi isi ụtọ nʼelu ebe dị elu nke obodo Juda nakwa ebe dị ọkụ. Nʼihi na ndị nchụaja ndị a achụọla aja, surekwaa ihe nsure ọkụ na-esi isi ụtọ nʼebe ịchụ aja dị nʼelu ugwu niile dị nʼobodo dị iche iche na Juda, nakwa ndị dị gburugburu Jerusalem. Ha bụ ndị surere ihe nsure ọkụ na-esi isi ụtọ nye Baal, na anyanwụ, ọnwa na kpakpando, nyekwa usuu niile nke mbara eluigwe.  
\v 6 O sikwa nʼụlọnsọ \nd Onyenwe anyị\nd* bupụ ogidi chi Ashera,\f + \fr 23:6 \ft Ashera bụ chi ndị Kenan. Nʼoge Hezekaya na-achị Juda, o gbuturu ogidi a, ma Manase wughachiri ya nʼoge nke ya dị ka eze. \xt 2Ez 18:4; 2Ez 21:3-5\f* wezuga ya nʼazụ Jerusalem, na Ndagwurugwu Kidrọn. Ebe ahụ ka ọ nọ suo ya ọkụ, supịa ya ka ọ ghọọ ntụ, fesaa ya nʼebe a na-eli ndị mmadụ efu.  
\v 7 Ọ kwadakwara ụlọ obibi ụmụ ndị ikom na-agba akwụna dị nọ nʼụlọnsọ \nd Onyenwe anyị\nd*. Nʼebe ndị inyom na-anọ na-akpara Ashera akwa. 
\p  
\v 8 O mere ka ndị nchụaja niile site nʼobodo Juda niile bịa, o merụkwara ebe ịchụ aja niile nke dị elu, site na Geba ruo Bịasheba, ebe ndị nchụaja ndị a nọrọ suree ihe nsure ọkụ na-esi isi ụtọ. Ọ kwatụrụ ọnụ ụzọ ama nke dị nʼebe ọnụ ụzọ ama Joshua, onye bụ gọvanọ obodo, nke dị nʼakụkụ aka ekpe nke ọnụ ụzọ ama obodo.  
\v 9 Ma e kweghị ka ndị nchụaja ahụ jee ozi nʼụlọnsọ \nd Onyenwe anyị\nd* dị na Jerusalem, ma o nyere ha ike iso ndị nchụaja ndị ọzọ rie achịcha a na-ejighị ihe na-eko achịcha mee. 
\p  
\v 10 Josaya merụrụ Tofet, laa ya nʼiyi. Tofet bụ ebe ịchụ aja dị na Ndagwurugwu nke Ben Hinom. O mere nke a igbochi mmadụ ọbụla iji nwa ya nwoke, maọbụ nwa ya nwanyị chụọrọ chi Molek aja nsure ọkụ.  
\v 11 O sitere nʼọnụ ụzọ ụlọnsọ ukwu \nd Onyenwe anyị\nd* wepụ ịnyịnya ndị ahụ ndị eze Juda doro nsọ nye anyanwụ. Ịnyịnya ndị a dị nʼogige ụlọnsọ \nd Onyenwe anyị\nd* nʼebe dị nso nʼụlọ onyeozi aha ya bụ Netan-Melek. Josaya kpọrọ ụgbọ agha ndị a niile e doro nsọ nye anyanwụ ọkụ. 
\p  
\v 12 Josaya kwadara ebe ịchụ aja niile nke ndị eze Juda wukwasịrị nʼelu ụlọeze, nʼelu elu ụlọ Ehaz. Ọ kwadakwara ebe ịchụ aja niile nke Manase wuru nʼime ogige abụọ nke ụlọnsọ ukwu \nd Onyenwe anyị\nd*, kporo ha kpofuo nʼime Ndagwurugwu Kidrọn.  
\v 13 Eze merụkwara ebe ịchụ aja niile dị nʼakụkụ ọwụwa anyanwụ obodo Jerusalem nʼakụkụ ndịda nke Ugwu Mbibi, nke Solomọn eze Izrel wuru nye chi Ashtọret, ihe arụ ndị Saịdọn, na chi Kemosh, ihe arụ ndị Moab, na chi Molek, ihe arụ ụmụ Amọn.  
\v 14 Josaya kwadakwara ogidi nkume niile, gbutuo ihe arụsị Ashera niile, werekwa ọkpụkpụ ndị mmadụ wụsa nʼelu ala ahụ niile. 
\p  
\v 15 Josaya kwadakwara ogidi niile dị na Betel, nke Jeroboam nwa Nebat wuru mgbe o dubara ndị Izrel na mmehie. Ọ kwadara ebe ịchụ aja dị nʼebe ahụ, kụjisie nkume e doro nʼebe ahụ, gwerie ha dịka ntụ. Ọ kpọkwara arụsị Ashera ọkụ.  
\v 16 Josaya legharịkwara anya gburugburu hụ ọtụtụ ili dị nʼelu ugwu. O ziri ndị ohu ya ka ha gaa chịpụtasịa ọkpụkpụ dị nʼili ahụ niile, kpọọ ha ọkụ nʼelu ebe ịchụ aja imerụ ya, dịka okwu \nd Onyenwe anyị\nd* si dị, nke onye nke Chineke kwupụtara mgbe o buru amụma banyere ihe ndị a. 
\p  
\v 17 Josaya jụrụ ndị guzo nʼebe ahụ ajụjụ sị, “Ọ bụ ili onye bụ nke a?” 
\p Ndị ikom obodo ahụ zara sị, “Ọ bụ ili onye nke Chineke ahụ si Juda bịa buo amụma megide ebe ịchụ aja Betel. O buru amụma na ihe ndị a ị na-eme ebe ịchụ aja a ga-emezu.” 
\p  
\v 18 Mgbe ahụ, Josaya zara sị ha, “Hapụnụ ya ka o guzoro onwe ya. Ka nwoke ọbụla gharakwa ịchịpụta ọkpụkpụ ya.” Ha hapụrụ ọkpụkpụ ya, hapụkwa ọkpụkpụ onye amụma ahụ si Sameria bịa. 
\p  
\v 19 Dịka o mere na Betel, otu a ka Josaya wepụrụ ma merụkwaa ebe ịchụ aja niile dị nʼebe niile dị elu nke ndị eze Izrel wuru nʼobodo niile nke Sameria, bụ ebe ịchụ aja kpasuru \nd Onyenwe anyị\nd* iwe.  
\v 20 O gburu ndị nchụaja chi ndị a niile nʼelu ebe ịchụ aja ha, suo ọkpụkpụ ha ọkụ nʼelu ebe ịchụ aja ha. Mgbe o mesịrị ihe ndị a, ọ laghachiri na Jerusalem. 
\p  
\v 21 Eze nyere ndị Juda niile iwu sị ha, “Meerenụ \nd Onyenwe anyị\nd* Chineke unu Mmemme Ngabiga, dịka e dere ya nʼakwụkwọ ọgbụgba ndụ a.”  
\v 22 O nwebeghị mgbe e mere ụdị Mmemme Ngabiga dịka nke a nʼoge ọbụla, site nʼụbọchị ndị ikpe bụ ndị duru Izrel maọbụ nʼụbọchị ndị eze Izrel na eze niile chịrị Juda, ọ dịghị nke yiri Mmemme Ngabiga a.  
\v 23 Ma ọ bụ nʼafọ nke iri na asatọ nke ọchịchị eze Josaya, nʼime Jerusalem ka a nọ mee Mmemme Ngabiga a nye \nd Onyenwe anyị\nd*. 
\p  
\v 24 Ọzọkwa, Josaya gara nʼihu kpochapụ ndị niile na-ajụta mmụọ ọjọọ ase, na ndị dibịa afa, na arụsị\f + \fr 23:24 \ft Ya bụ, chi\f* ezinaụlọ dị iche iche, na arụsị a pịrị apị, na ihe arụ niile nke a hụrụ nʼime Juda na Jerusalem niile. O mere nke a ka e mezuo ihe niile e dere nʼime akwụkwọ ahụ Hilkaya onye nchụaja chọtara nʼụlọ \nd Onyenwe anyị\nd*.  
\v 25 Ọ dịghị eze ọzọ nʼime ndị niile buru ya ụzọ chịa nke dịka Josaya, onye chigharịkwutere \nd Onyenwe anyị\nd*. Onye ji obi ya niile, na mmụọ ya niile na ike ya niile debe iwu niile e nyere Mosis.\f + \fr 23:25 \ft \xt 2Ez 18:5\f* Ọ dịkwaghị eze ọzọ dịka ya, onye biliri mgbe ọ nwụsịrị. 
\p  
\v 26 Ma ihe ndị a emeghị ka iwe ọkụ \nd Onyenwe anyị\nd* na-ewe megide Juda dajụọ, bụ iwe a kpasuru ya nʼihi ihe ọjọọ niile nke Manase mere.  
\v 27 Ya mere, \nd Onyenwe anyị\nd* sịrị, “Aga m ekpochapụ Juda niile site nʼihu m, dịka m si kpochapụ Izrel niile. Aga m ajụkwa obodo ahụ m họpụtara, bụ Jerusalem, jụkwa ụlọnsọ ukwu a nke m kwuru banyere ya sị, ‘Nʼime ya ka Aha m ga-adị.’ ” 
\p  
\v 28 Ma banyere ihe ndị ọzọ niile mere nʼoge ọchịchị Josaya na ihe niile o mere, ọ bụ na e deghị ha nʼakwụkwọ akụkọ ihe mere nʼoge ndị eze Juda? 
\p  
\v 29 Nʼoge Josaya bụ eze, Fero Neko, eze Ijipt, gbagoro gaa nʼakụkụ osimiri Yufretis inyere eze Asịrịa aka. Eze Josaya pụkwara izute ya nʼagha, ma Neko zutere ya nʼagha, gbuo ya na Megido.  
\v 30 Ndị na-ejere Josaya ozi sị na Megido buru ozu ya nʼime ụgbọ agha bulata ya na Jerusalem, lie ya nʼili nke aka ya. Ndị ala ahụ kpọọrọ Jehoahaz nwa nwoke Josaya, tee ya mmanụ, mee ya eze nʼọnọdụ nna ya. 
\s1 Jehoahaz eze Juda 
\p  
\v 31 Jehoahaz gbara iri afọ abụọ na atọ mgbe o bidoro ịchị, ma ọ chịrị na Jerusalem ọnwa atọ. Aha nne ya bụ Hamutal, nwa Jeremaya onye Libna.  
\v 32 O mere ihe dị njọ nʼanya \nd Onyenwe anyị\nd* dịka ndị eze buru ya ụzọ.  
\v 33 Ma Fero Neko keere ya agbụ na Ribla nʼala Hamat, ime ka ọ ghara ịchịkwa na Jerusalem. Neko kwagidere ndị Juda ka ha tụọrọ ya ụtụ narị talenti ọlaọcha, na otu talenti ọlaedo.  
\v 34 Fero Neko mere Eliakịm nwa nwoke Josaya, eze, nʼọnọdụ Josaya bụ nna ya. Ọ gụgharịrị aha Eliakịm ka ọ bụrụ Jehoiakim. Ma o duuru Jehoahaz gaa Ijipt, ebe ọ nọ nwụọ.  
\v 35 Jehoiakim kwụrụ Fero Neko ọlaọcha na ọlaedo ahụ ọ nara nʼaka ya. Ka o nwee ike mee nke a, o kere ụtụ nʼala ahụ, werekwa ike nara ndị ala ahụ ọlaọcha na ọlaedo, dịka mkpebi ha si dị banyere ihe onye ahụ ga-akwụ. 
\s1 Jehoiakim eze Juda 
\p  
\v 36 Jehoiakim gbara iri afọ abụọ na ise mgbe ọ malitere ịbụ eze. Ọ chịrị afọ iri na otu na Jerusalem. Aha nne ya bụ Zebida nwa Pedaya, onye Ruma.  
\v 37 O mere ihe dị njọ nʼanya \nd Onyenwe anyị\nd*, dịka ihe niile nna ya ha ndị bu ya ụzọ mere. 
\c 24  
\p  
\v 1 Nʼoge Jehoiakim na-achị, Nebukadneza eze Babilọn ji ike bata nʼala ya, mee ka Jehoiakim ghọọ ohu ya afọ atọ. Ma o mesịrị tụgharịa megide Nebukadneza, nupukwa isi nʼokpuru ya.  
\v 2 \nd Onyenwe anyị\nd* zigara ndị na-apụnara mmadụ ihe site na Kaldịa, Aram, Moab na ndị Amọn, ka ha ga bibie Juda. Ọ bụ nʼusoro okwu \nd Onyenwe anyị\nd* kpọsara site nʼọnụ ndị amụma ya.  
\v 3 Nʼezie, ihe ndị a bịakwasịrị Juda dịka \nd Onyenwe anyị\nd* si nye ya nʼiwu, ka o si otu a kpochapụ ha site nʼihu ya nʼihi mmehie niile Manase mere, na dịka ihe niile o mere si dị,  
\v 4 tinyere ọbara ndị aka ha dị ọcha nke ọ wusiri. Nʼihi na o mere ka ọbara ndị aka ha dị ọcha jupụta na Jerusalem. \nd Onyenwe anyị\nd* ekwekwaghị agbaghara ajọ omume dị otu a. 
\p  
\v 5 Akụkọ ọzọ niile gbasara ọchịchị Jehoiakim na ihe niile o mere, e deghị ha nʼakwụkwọ akụkọ ihe e mere nʼụbọchị ndụ ndị eze Juda?  
\v 6 Jehoiakim sooro ndị nna nna ya ha dina nʼọnwụ. Jehoiakin nwa ya ghọrọ eze ọhụrụ nʼọnọdụ ya. 
\p  
\v 7 Ma eze Ijipt esiteghị nʼala ya pụta ọzọ, nʼihi na eze Babilọn nọchiri oke ala ya niile, site na mmiri iyi Ijipt ruo nʼoke Osimiri Yufretis. 
\s1 Jehoiakin eze Juda 
\p  
\v 8 Jehoiakin gbara afọ iri na asatọ mgbe ọ malitere ịbụ eze. Ọ chịrị naanị ọnwa atọ na Jerusalem. Aha nne ya bụ Nehushta, nwa Elnatan, onye Jerusalem.  
\v 9 O mere ihe jọrọ njọ nʼanya \nd Onyenwe anyị\nd*, dịka nna ya ha mere. 
\p  
\v 10 Nʼoge ọ bụ eze, ndịisi Nebukadneza, eze Babilọn bịara, gbaa Jerusalem gburugburu ma nọchibido obodo ahụ nʼagha.  
\v 11 Nebukadneza, eze Babilọn nʼonwe ya, bịara nʼobodo ahụ mgbe ndị agha ya gbara ya gburugburu.  
\v 12 Jehoiakin, bụ eze Juda, na nne ya na ndị ọrụ ya niile na ndịisi niile na ndịisi ozi ya niile were onwe ha nyefee Nebukadneza nʼaka. 
\p Nʼafọ asatọ nke ọchịchị eze Babilọn ka ọ kpụụrụ Jehoiakin dịka onye mkpọrọ.  
\v 13 Ọ kwakọọrọ akụ niile dị nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*, na ndị nke dị nʼụlọeze, o gbukakwara ihe ọlaedo niile Solomọn eze Izrel tinyere nʼụlọnsọ ukwu \nd Onyenwe anyị\nd* buru ha bulaa Babilọn, ihe a niile mere dịka \nd Onyenwe anyị\nd* kwururịị.  
\v 14 O bupụkwara puku ndị ikom iri site na Jerusalem bulaa ha Babilọn dịka ndị a dọtara nʼagha. Ndị so nʼime ndị a bụ ndịisi niile na ndị agha niile. O bupụkwara ndị na-akwa ǹka niile na ndị ọkpụ ụzụ. Naanị ndị na-enweghị ike, na ndị ogbenye ka ọ hapụrụ nʼala ahụ. 
\p  
\v 15 Nebukadneza kpụụrụ Jehoiakin ka ọ ga biri na Babilọn. O sikwa na Jerusalem kpọrọ nne eze, na ndị nwunye eze, ndị ozi ya, na ndị niile a ma ama nʼala ahụ gaa Babilọn.  
\v 16 Eze Babilọn bupụkwara ndị ikom niile dị ike ma tozukwaa ibu agha, ndị ọnụọgụgụ ha dị puku asaa, tinyere otu puku ndị ọrụ aka, na ndị ọrụ ǹka, bulaa ha Babilọn.  
\v 17 O mere nwanne nna Jehoiakin, bụ Matanaya, eze nʼọnọdụ ya. Ọ gụgharịrị ya aha, kpọọ ya Zedekaya. 
\s1 Zedekaya eze Juda 
\p  
\v 18 Iri afọ abụọ na otu ka Zedekaya gbara mgbe ọ malitere ịbụ eze nʼime Jerusalem. Aha nne ya bụ Hamutal, nwa Jeremaya onye Libna. Ọ chịrị dịka eze na Jerusalem afọ iri na otu.  
\v 19 Ma o mere ihe jọrọ njọ nʼanya \nd Onyenwe anyị\nd* dịka Jehoiakim mere.\f + \fr 24:19 \ft \xt 2Ih 36:12\f* 
\v 20 Ọ bụ nʼihi iwe \nd Onyenwe anyị\nd* ka ihe ndị a niile ji bịakwasị Jerusalem na Juda. Nʼikpeazụ, o sitere nʼihu ya chụpụ ha. 
\s1 Ọdịda Jerusalem 
\p Nʼoge a, Zedekaya nupuru isi nʼokpuru eze Babilọn.\f + \fr 24:20 \ft \xt 2Ih 36:13; Izk 17:15.\f* 
\c 25  
\p  
\v 1 Nʼafọ nke itoolu nke ọchịchị ya, nʼọnwa nke iri, nʼụbọchị nke iri, Nebukadneza, eze Babilọn duuru ndị agha ya niile bịa ibuso Jerusalem agha. Ọ mara ụlọ ikwu nʼazụ obodo ahụ, wukwaa mgbidi nnọchibido gburugburu obodo ahụ.  
\v 2 Anọchibidoro obodo a nʼagha ruo nʼafọ nke iri na otu nke ọchịchị eze Zedekaya. 
\p  
\v 3 Nʼụbọchị nke itoolu nke ọnwa anọ nʼafọ ahụ, oke ụnwụ siri ike dị nʼobodo ahụ ruo na ọ dịkwaghị nri dị nke ndị mmadụ ga-eri.  
\v 4 Mgbe ahụ, e tipuru oghere nʼaja mgbidi obodo ahụ, ndị agha niile ji abalị gbapụ site nʼọnụ ụzọ ama nke dị nʼetiti mgbidi abụọ nʼakụkụ ubi eze a gbara ogige, nʼagbanyeghị na ndị Kaldịa\f + \fr 25:4 \ft Maọbụ, \fqa Babilọn\f* nọ obodo ahụ gburugburu. Ha gbapụrụ chee ihu nʼụzọ Araba.\f + \fr 25:4 \ft Ya bụ ndagwurugwu Jọdan\f* 
\v 5 Ma ndị agha Kaldịa chụsoro eze nʼazụ, chụkwute ya na mbara ala Jeriko. Ndị agha ya niile sitere nʼebe ọ nọ gbasasịa, hapụ ya,  
\v 6 e jide ya. 
\p Ha kpụgara ya eze Babilọn, nʼobodo Ribla, ebe a nọ maa ya ikpe.  
\v 7 Ha gburu ụmụ ndị ikom Zedekaya nʼihu ya. Ha ghụpụrụ anya ya abụọ, jiri ụdọ bronz kee ya agbụ, kpọrọ ya gaa Babilọn. 
\p  
\v 8 Nʼụbọchị nke asaa, nʼọnwa nke ise nke afọ iri na itoolu nke ọchịchị eze Nebukadneza na Babilọn, Nebuzaradan, ọchịagha ndị nche, onyeisi nʼọrụ eze Babilọn, bịarutere Jerusalem.  
\v 9 O sunyere ụlọnsọ \nd Onyenwe anyị\nd* ọkụ, ụlọeze na ụlọ niile dị na Jerusalem, ụlọ ọbụla bụ nke dị mkpa ka o surere ọkụ  
\v 10 Ndị agha Kaldịa niile bụ ndị nọ nʼokpuru onyeisi ndị nche eze kwaturu mgbidi niile gbara Jerusalem gburugburu.  
\v 11 Nebuzaradan, ọchịagha ndị nche eze, buuru ụfọdụ mmadụ ndị fọdụrụ nʼobodo, na ndị niile fọdụkwara, ha na ndị ọzọ ahụ ji aka ha gbakwuru eze bulaa ha Babilọn, ka ha ga biri nʼala ọzọ.  
\v 12 Ma ọchịagha ahụ, hapụrụ ụfọdụ na ndị ahụ bụ nnọọ ndị ogbenye ọnụ ntụ, ka ha na-elekọta ubi vaịnị niile a gbara ogige na ala ubi niile. 
\p  
\v 13 Ma ndị Babilọn tipịara ogidi bronz niile, ha na ihe ndọkwasị niile na oke osimiri bronz ndị ahụ dị nʼụlọnsọ \nd Onyenwe anyị\nd*, buru bronz ndị ahụ bulaa Babilọn.  
\v 14 Ha chịkọọrọ ite niile, na shọvel niile, na ihe ịkpakepụ ọkụ, na ngaji ukwu niile na ngwa bronz niile nke e ji eje ozi nʼime ụlọnsọ ahụ.  
\v 15 Ọchịagha ndị nche eze, chịrị ihe ịgụnye ọkụ niile, efere ịkwọsa mmiri niile, ya bụ ihe ndị ahụ niile e ji ọlaedo a nụchara anụcha maọbụ ọlaọcha kpụọ. 
\p  
\v 16 O bukwara bronz sitere nʼogidi abụọ ahụ, oke Osimiri ahụ na ihe ndọkwasị ya niile, nke eze bụ Solomọn mere nʼihi ụlọnsọ \nd Onyenwe anyị\nd*. Ha karịrị ihe a ga-eji ihe ọtụtụ tụọ.  
\v 17 Ị dị elu nke otu nʼime ogidi abụọ ndị a bụ mita asatọ na ụma\f + \fr 25:17 \ft Nzọ ụkwụ iri abụọ na asaa\f* nʼọtụtụ. Isi bronz nke e kpukwasịrị nʼotu ogidi dị otu mita na ọkara\f + \fr 25:17 \ft Nzọ ụkwụ anọ na ọkara\f* nʼịdị elu. Ọ bụkwa ihe yiri mkpụrụ pomegranet e ji bronz kpaa, ka e ji chọọ ya mma gburugburu ya niile. Ogidi nke abụọ nwekwara pomegranet, yiri ibe ya. 
\p  
\v 18 Ọchịagha ndị nche eze ahụ, kpụụrụ Seraya, onyeisi nchụaja, na Zefanaya, bụ onye nchụaja na-esote ya nʼọkwa, na ndị nche atọ na-eche ọnụ ụzọ mbata.  
\v 19 O sitere nʼetiti ndị ahụ fọdụrụ nʼobodo kpụụrụ otu onyeisi na-ahụ maka ndị agha, na ndị ikom ise na-enye eze ndụmọdụ. O kpukwaara ode akwụkwọ, onye isi ọrụ na-ahụ maka ịmanye ndị ga-aga agha, jidekwa iri ndị ikom isii ndị ọrụ mmanye, ndị a hụrụ nʼime obodo ahụ.  
\v 20 Nebuzaradan, bụ ọchịagha kpụụrụ ha niile dute ha nʼihu eze Babilọn na Ribla.  
\v 21 Nʼebe ahụ, na Ribla dị nʼobodo Hamat, ka eze nọ nye iwu ka e gbuo ha niile. 
\p Ya mere, a dọọrọ Juda nʼagha, mee ka ọ ga biri nʼala ọzọ. 
\p  
\v 22 Emesịa, Nebukadneza eze Babilọn họpụtara Gedaliya nwa Ahikam, nwa nwa Shefan, ka ọ bụrụ onye na-elekọta ndị fọdụrụ na Juda,  
\v 23 Mgbe ndịisi agha na ndị ikom ha nụrụ na eze Babilọn emeela Gedaliya onye na-achị ala ahụ, ha bịakwutere Gedaliya na Mizpa. Ndị bịakwutere ya bụ, Ishmel nwa Netanaya, Johanan nwa Kariya, Seraya nwa Tanhumet, onye Netofa, na Jaazanaya nwa onye Maaka, na ndị ikom ha.  
\v 24 Gedaliya ṅụọrọ ha iyi, ṅụkwaara ndị ikom ha, sị, “Unu atụla egwu nʼihi ndịisi ọrụ Babilọn. Birinụ nʼala a, feekwa eze Babilọn, ihe ga-agara unu nke ọma.” 
\p  
\v 25 Ma nʼọnwa nke asaa, Ishmel nwa Netanaya, nwa Elishama, onye ya onwe ya si nʼagbụrụ eze, duuru mmadụ iri bịa Mizpa, tigbuo Gedaliya, na ndị ikom Juda na ndị Kaldịa niile, bụ ndị ya na ha nọ.  
\v 26 Nke a mere ka ndị Juda niile, site nʼonye nta ruo nʼonye ukwu, ha na ndịisi agha ndị ahụ biliri gaa Ijipt, nʼihi na ha tụrụ ndị Kaldịa egwu. 
\s1 Jehoiakin enwere onwe ya 
\p  
\v 27 Nʼafọ nke iri atọ na asaa, site na mgbe e mere ka Jehoiakin eze Juda gaa biri nʼala ọzọ, nʼafọ Awel-Maduk\f + \fr 25:27 \ft Ọ bụ ya bụkwa Evil-Merodak.\f* ghọrọ eze Babilọn, o mere ka Jehoiakin si nʼụlọ mkpọrọ pụta nwere onwe ya. Ọ bụ nʼụbọchị nke iri abụọ na asaa nke ọnwa iri na abụọ ka o mere nke a.  
\v 28 Ọ gwara ya okwu ọma, nye ya oche ọnọdụ ya dị elu karịa nke ndị eze ndị ọzọ ya na ha nọ na Babilọn.  
\v 29 Nʼihi nke a, Jehoiakin gbanwere uwe mkpọrọ ya, wezuga ya. Sitekwa nʼoge ahụ, tutu ruo mgbe ọ nwụrụ, ya na eze na-erikọ nri.  
\v 30 Site nʼụbọchị ruo nʼụbọchị, eze Babilọn na-enye Jehoiakin oke ihe ruru ya kwa ụbọchị niile nke ọ dị ndụ.