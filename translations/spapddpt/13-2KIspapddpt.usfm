\p \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w* estableció \w la|strong="H5921"\w* vigilancia \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 19 \w Después|strong="H5921"\w* \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* centuria, \w los|strong="H3427"\w* cereteos, \w los|strong="H3427"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* escolta \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w bajaron|strong="H3381"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p Entraron \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w real|strong="H4428"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* entrada \w de|strong="H5921"\w* \w la|strong="H5921"\w* escolta, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w se|strong="H5921"\w* sentó \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w reyes|strong="H4428"\w*.
\v 20 \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* \w la|strong="H3605"\w* tierra \w se|strong="H5971"\w* regocijó, y \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* \w reposó|strong="H8252"\w*, pues \w mataron|strong="H4191"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w Atalía|strong="H6271"\w* en \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w real|strong="H4428"\w*.
\s1 Reinado de Joás, rey de Judá
\p 
\v 21 Joás tenía siete años cuando comenzó \w a|strong="H3068"\w* reinar.
\c 12
\p 
\v 1 \w Joás|strong="H3060"\w* comenzó \w a|strong="H3068"\w* reinar en \w el|strong="H1121"\w* \w año|strong="H8141"\w* \w séptimo|strong="H7651"\w* \w de|strong="H1121"\w* Jehú, y \w reinó|strong="H4427"\w* 40 \w años|strong="H8141"\w* en Jerusalén. \w El|strong="H1121"\w* nombre \w de|strong="H1121"\w* su madre fue Sibia, \w de|strong="H1121"\w* Beerseba.
\v 2 \w Joás|strong="H3060"\w* hizo lo recto ante \nd \w Yavé|strong="H3068"\w*\nd* \w todos|strong="H8141"\w* los días en los cuales el sacerdote Joiada lo instruía.
\v 3 Pero \w no|strong="H6213"\w* se quitaron \w los|strong="H3605"\w* lugares altos, porque \w el|strong="H3605"\w* pueblo aún sacrificaba y quemaba incienso en \w los|strong="H3605"\w* lugares altos.
\p 
\v 4 \w Y|strong="H3068"\w* Joás dijo \w a|strong="H3068"\w* los sacerdotes: Todo el dinero \w de|strong="H5750"\w* las cosas sagradas \w que|strong="H3808"\w* es traído \w a|strong="H3068"\w* la Casa \w de|strong="H5750"\w* \nd \w Yavé|strong="H3068"\w*\nd*, tanto el dinero del rescate \w de|strong="H5750"\w* cada persona, según está previsto, \w como|strong="H5750"\w* el dinero \w que|strong="H3808"\w* cada uno trae \w de|strong="H5750"\w* su voluntad \w a|strong="H3068"\w* la Casa \w de|strong="H5750"\w* \nd \w Yavé|strong="H3068"\w*\nd*,
\v 5 \w que|strong="H5921"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w lo|strong="H5921"\w* reciban, \w cada|strong="H3605"\w* uno \w de|strong="H5921"\w* su administrador, \w y|strong="H5921"\w* reparen \w ellos|strong="H5921"\w* \w los|strong="H5921"\w* daños \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* dondequiera \w que|strong="H5921"\w* \w se|strong="H5921"\w* halle \w cualquier|strong="H3605"\w* daño.
\p 
\v 6 Pero sucedió \w que|strong="H1992"\w* \w el|strong="H3605"\w* año 23 del rey Joás, \w los|strong="H1992"\w* \w sacerdotes|strong="H3548"\w* aún no habían reparado \w los|strong="H1992"\w* daños del \w Templo|strong="H1004"\w*.
\v 7 Entonces el \w rey|strong="H4428"\w* \w Joás|strong="H3060"\w* llamó \w al|strong="H4428"\w* \w sacerdote|strong="H3548"\w* Joiada y \w a|strong="H3068"\w* \w los|strong="H1961"\w* demás \w sacerdotes|strong="H3548"\w* y les preguntó: ¿\w Por|strong="H4428"\w* \w qué|strong="H3808"\w* \w aún|strong="H3808"\w* \w no|strong="H3808"\w* \w repararon|strong="H2388"\w* \w los|strong="H1961"\w* daños del \w Templo|strong="H1004"\w*? Ahora, \w pues|strong="H1961"\w*, \w no|strong="H3808"\w* tomen el dinero de sus administradores, \w sino|strong="H3808"\w* entréguenlo \w para|strong="H1961"\w* reparar \w los|strong="H1961"\w* daños del \w Templo|strong="H1004"\w*.
\v 8 \w Los|strong="H3588"\w* \w sacerdotes|strong="H3548"\w* consintieron \w en|strong="H3588"\w* \w no|strong="H3588"\w* \w tomar|strong="H3947"\w* \w más|strong="H3588"\w* \w dinero|strong="H3701"\w* del pueblo, \w ni|strong="H6258"\w* reparar \w los|strong="H3588"\w* \w daños|strong="H5414"\w* del \w Templo|strong="H1004"\w*.
\p 
\v 9 Pero el sumo \w sacerdote|strong="H3548"\w* Joiada \w tomó|strong="H3947"\w* un cofre, le hizo una abertura en su tapa y lo puso \w junto|strong="H5971"\w* al altar, \w a|strong="H3068"\w* la derecha, según \w se|strong="H5971"\w* entra en la \w Casa|strong="H1004"\w* \w de|strong="H5971"\w* \nd \w Yavé|strong="H3068"\w*\nd*. Los \w sacerdotes|strong="H3548"\w* \w que|strong="H5971"\w* cuidaban la puerta depositaban allí todo el \w dinero|strong="H3701"\w* \w que|strong="H5971"\w* era llevado \w a|strong="H3068"\w* la \w Casa|strong="H1004"\w* \w de|strong="H5971"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 10 Sucedió \w que|strong="H3605"\w* cuando veían \w que|strong="H3605"\w* había mucho \w dinero|strong="H3701"\w* en \w el|strong="H3605"\w* cofre, \w el|strong="H3605"\w* escriba \w del|strong="H4196"\w* rey y \w el|strong="H3605"\w* sumo \w sacerdote|strong="H3548"\w* iban y \w lo|strong="H3605"\w* contaban. \w Lo|strong="H3605"\w* colocaban en las bolsas \w para|strong="H5414"\w* \w dinero|strong="H3701"\w* \w que|strong="H3605"\w* había en \w el|strong="H3605"\w* \w Templo|strong="H1004"\w* \w de|strong="H5414"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 11 Entregaban \w el|strong="H3588"\w* \w dinero|strong="H3701"\w* \w que|strong="H3588"\w* \w contaban|strong="H1961"\w* \w en|strong="H3588"\w* las manos \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w que|strong="H3588"\w* hacían \w la|strong="H3588"\w* obra \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w Templo|strong="H1004"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w los|strong="H1961"\w* cuales pagaban \w a|strong="H3068"\w* \w los|strong="H1961"\w* carpinteros \w y|strong="H3588"\w* constructores \w que|strong="H3588"\w* reparaban \w la|strong="H3588"\w* \w Casa|strong="H1004"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*,
\v 12 \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w albañiles|strong="H2796"\w* \w y|strong="H5921"\w* canteros \w para|strong="H5921"\w* comprar \w madera|strong="H6086"\w* \w y|strong="H5921"\w* piedra tallada \w para|strong="H5921"\w* reparar \w las|strong="H5921"\w* averías \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w y|strong="H5921"\w* \w para|strong="H5921"\w* todo \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* \w hacía|strong="H6213"\w* \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* reparar \w la|strong="H5921"\w* \w Casa|strong="H1004"\w*.
\p 
\v 13 Pero \w con|strong="H5921"\w* \w el|strong="H5921"\w* dinero \w que|strong="H5921"\w* \w se|strong="H5921"\w* llevaba \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w no|strong="H5921"\w* hacían tazas \w de|strong="H5921"\w* plata, ni despabiladeras, ni tazones, ni trompetas, ni algún utensilio \w de|strong="H5921"\w* oro, ni \w de|strong="H5921"\w* plata,
\v 14 \w porque|strong="H3808"\w* \w lo|strong="H3808"\w* entregaban \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w que|strong="H4480"\w* \w hacían|strong="H6213"\w* \w la|strong="H3605"\w* \w obra|strong="H6213"\w*, y reparaban \w con|strong="H4480"\w* \w él|strong="H3605"\w* \w el|strong="H3605"\w* \w Templo|strong="H1004"\w* \w de|strong="H4480"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 15 \w Además|strong="H3588"\w*, \w no|strong="H6213"\w* exigían cuentas \w a|strong="H3068"\w* \w los|strong="H3588"\w* hombres \w en|strong="H3588"\w* cuyas manos se entregaba \w el|strong="H3588"\w* dinero \w para|strong="H3588"\w* \w hacer|strong="H6213"\w* \w los|strong="H3588"\w* trabajos, \w pues|strong="H3588"\w* actuaban \w con|strong="H3588"\w* honradez.
\v 16 \w El|strong="H5921"\w* \w dinero|strong="H3701"\w* \w de|strong="H5921"\w* \w las|strong="H1992"\w* ofrendas \w por|strong="H5921"\w* \w la|strong="H5921"\w* culpa \w y|strong="H3588"\w* \w el|strong="H5921"\w* \w dinero|strong="H3701"\w* \w de|strong="H5921"\w* \w las|strong="H1992"\w* ofrendas \w por|strong="H5921"\w* \w el|strong="H5921"\w* pecado \w no|strong="H3808"\w* ingresaba \w en|strong="H5921"\w* \w la|strong="H5921"\w* Casa \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w porque|strong="H3588"\w* era \w para|strong="H5921"\w* \w los|strong="H1992"\w* sacerdotes.
\p 
\v 17 En aquel tiempo Hazael, rey de Siria, subió y luchó \w contra|strong="H1961"\w* Gat, y la conquistó. \w Y|strong="H3068"\w* Hazael dispuso subir \w contra|strong="H1961"\w* Jerusalén.
\p 
\v 18 Pero Joás, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Judá, \w tomó|strong="H3920"\w* todos \w los|strong="H5921"\w* objetos consagrados \w que|strong="H5921"\w* ofrecieron sus antepasados: Josafat, Joram \w y|strong="H5921"\w* Ocozías, \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* Judá, \w y|strong="H5921"\w* sus propios objetos consagrados, \w y|strong="H5921"\w* todo \w el|strong="H5921"\w* oro \w que|strong="H5921"\w* había \w en|strong="H5921"\w* \w los|strong="H5921"\w* tesoros \w de|strong="H5921"\w* \w la|strong="H5921"\w* Casa \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* casa \w real|strong="H4428"\w*. \w Y|strong="H3068"\w* \w los|strong="H5921"\w* envió \w a|strong="H3068"\w* \w Hazael|strong="H2371"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Siria, quien \w se|strong="H5921"\w* retiró \w de|strong="H5921"\w* Jerusalén.
\p 
\v 19 \w Todos|strong="H3605"\w* \w los|strong="H5921"\w* hechos \w de|strong="H5921"\w* \w Joás|strong="H3060"\w*, ¿\w no|strong="H5921"\w* están escritos \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w las|strong="H5921"\w* Crónicas \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*?
\p 
\v 20 \w Se|strong="H5921"\w* levantaron \w sus|strong="H1992"\w* esclavos \w y|strong="H5921"\w* tramaron una conspiración, \w y|strong="H5921"\w* mataron \w a|strong="H3068"\w* \w Joás|strong="H3101"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* casa \w de|strong="H5921"\w* Milo, \w en|strong="H5921"\w* \w el|strong="H5921"\w* camino \w que|strong="H3808"\w* baja \w a|strong="H3068"\w* Silo,
\v 21 \w pues|strong="H3381"\w* sus esclavos Josacar, hijo de Simeat, y Jozabad, hijo de Somer, lo \w hirieron|strong="H5221"\w* y murió. Lo sepultaron con sus antepasados \w en|strong="H5221"\w* la Ciudad de David, y reinó \w en|strong="H5221"\w* su lugar su hijo Amasías.
\c 13
\s1 Reinado de Joacaz en Israel
\p 
\v 1 \w El|strong="H5921"\w* \w año|strong="H8141"\w* 23 \w de|strong="H5921"\w* \w Joás|strong="H3101"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Ocozías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, comenzó \w a|strong="H3068"\w* reinar Joacaz, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Jehú|strong="H3058"\w*, \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* \w Samaria|strong="H8111"\w*, \w y|strong="H5921"\w* \w reinó|strong="H4427"\w* 17 \w años|strong="H8141"\w*.
\v 2 \w Hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w* ante \nd \w Yavé|strong="H3068"\w*\nd*, \w porque|strong="H3808"\w* \w siguió|strong="H3212"\w* tras \w los|strong="H1121"\w* \w pecados|strong="H2403"\w* \w de|strong="H4480"\w* \w Jeroboam|strong="H3379"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Nabat|strong="H5028"\w*, \w con|strong="H4480"\w* \w los|strong="H1121"\w* cuales estimuló \w a|strong="H3068"\w* \w pecar|strong="H2398"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, y \w no|strong="H3808"\w* \w se|strong="H4480"\w* apartó \w de|strong="H4480"\w* \w ellos|strong="H4480"\w*.
\p 
\v 3 \w La|strong="H3605"\w* ira \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd* se encendió \w contra|strong="H3478"\w* \w Israel|strong="H3478"\w*, y \w los|strong="H1121"\w* \w entregó|strong="H5414"\w* en repetidas ocasiones en \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w Hazael|strong="H2371"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Siria, y en \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w Ben-adad|strong="H1130"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Hazael|strong="H2371"\w*.
\p 
\v 4 \w Pero|strong="H3588"\w* Joacaz \w oró|strong="H2470"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w y|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* lo \w escuchó|strong="H8085"\w*, \w porque|strong="H3588"\w* \w Él|strong="H3588"\w* \w veía|strong="H7200"\w* \w la|strong="H3588"\w* aflicción \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w cómo|strong="H3588"\w* \w los|strong="H3588"\w* oprimía \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Siria.
\v 5 \nd \w Yavé|strong="H3068"\w*\nd* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* un libertador, y se libraron \w de|strong="H8478"\w* la \w mano|strong="H3027"\w* \w de|strong="H8478"\w* Siria.
\p \w Los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H8478"\w* \w Israel|strong="H3478"\w* vivieron \w en|strong="H3318"\w* sus tiendas \w como|strong="H8478"\w* \w antes|strong="H8543"\w*.
\v 6 Pero \w no|strong="H3808"\w* \w se|strong="H3808"\w* apartaron de los \w pecados|strong="H2403"\w* de \w la|strong="H1571"\w* \w casa|strong="H1004"\w* de \w Jeroboam|strong="H3379"\w*, \w con|strong="H1571"\w* los cuales estimuló \w a|strong="H3068"\w* \w pecar|strong="H2398"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w sino|strong="H3808"\w* \w anduvieron|strong="H1980"\w* \w en|strong="H5493"\w* \w ellos|strong="H1571"\w*. \w También|strong="H1571"\w* \w la|strong="H1571"\w* Asera seguía \w en|strong="H5493"\w* \w pie|strong="H5975"\w* \w en|strong="H5493"\w* \w Samaria|strong="H8111"\w*.
\p 
\v 7 \w A|strong="H3068"\w* Joacaz \w no|strong="H3808"\w* le quedaban \w sino|strong="H3588"\w* 50 \w jinetes|strong="H6571"\w*, \w diez|strong="H6235"\w* carruajes \w y|strong="H3588"\w* 10.000 \w hombres|strong="H6571"\w* \w de|strong="H3588"\w* infantería, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Siria \w los|strong="H3588"\w* \w había|strong="H3588"\w* destruido \w y|strong="H3588"\w* \w los|strong="H3588"\w* \w había|strong="H3588"\w* dejado \w como|strong="H3588"\w* \w el|strong="H3588"\w* \w polvo|strong="H6083"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* trilla.
\p 
\v 8 \w Todos|strong="H3605"\w* \w los|strong="H1992"\w* \w hechos|strong="H1697"\w* \w de|strong="H5921"\w* Joacaz \w y|strong="H5921"\w* \w su|strong="H1992"\w* valor, ¿\w no|strong="H3808"\w* están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w las|strong="H1992"\w* Crónicas \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*?
\v 9 Joacaz descansó \w con|strong="H5973"\w* sus antepasados y lo \w sepultaron|strong="H6912"\w* \w en|strong="H5973"\w* \w Samaria|strong="H8111"\w*. \w Reinó|strong="H4427"\w* \w en|strong="H5973"\w* su \w lugar|strong="H8478"\w* su \w hijo|strong="H1121"\w* Jeoás.
\s1 Reinado de Jeoás en Israel
\p 
\v 10 \w El|strong="H5921"\w* \w año|strong="H8141"\w* 37 \w de|strong="H5921"\w* \w Joás|strong="H3101"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, comenzó \w a|strong="H3068"\w* reinar Jeoás, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Joacaz, \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* \w Samaria|strong="H8111"\w*, \w y|strong="H5921"\w* \w reinó|strong="H4427"\w* 16 \w años|strong="H8141"\w*.
\v 11 \w Hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w* ante \nd \w Yavé|strong="H3068"\w*\nd*, y \w no|strong="H3808"\w* \w se|strong="H3808"\w* apartó \w de|strong="H1121"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w pecados|strong="H2403"\w* \w de|strong="H1121"\w* \w Jeroboam|strong="H3379"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nabat|strong="H5028"\w*, con \w los|strong="H1121"\w* cuales estimuló \w a|strong="H3068"\w* \w pecar|strong="H2398"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w sino|strong="H3808"\w* \w anduvo|strong="H1980"\w* \w en|strong="H5493"\w* \w ellos|strong="H3605"\w*.
\p 
\v 12 \w Todos|strong="H3605"\w* \w los|strong="H1992"\w* \w hechos|strong="H1697"\w* \w de|strong="H5921"\w* Jeoás \w y|strong="H5921"\w* \w su|strong="H1992"\w* valor \w al|strong="H5921"\w* luchar \w contra|strong="H5921"\w* Amasías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, ¿\w no|strong="H3808"\w* están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w las|strong="H1992"\w* Crónicas \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*?
\v 13 Jeoás descansó \w con|strong="H5973"\w* sus antepasados, \w y|strong="H5921"\w* \w Jeroboam|strong="H3379"\w* \w se|strong="H5921"\w* sentó \w en|strong="H5921"\w* su \w trono|strong="H3678"\w*. Jeoás fue \w sepultado|strong="H6912"\w* \w en|strong="H5921"\w* \w Samaria|strong="H8111"\w* \w con|strong="H5973"\w* \w los|strong="H3427"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.
\s1 Fallecimiento del profeta Eliseo
\p 
\v 14 Eliseo cayó \w enfermo|strong="H2470"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w enfermedad|strong="H2483"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* cual iba \w a|strong="H3068"\w* \w morir|strong="H4191"\w*. \w Y|strong="H3068"\w* Jeoás, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, bajó \w y|strong="H5921"\w* \w lloró|strong="H1058"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* dijo: ¡Padre \w mío|strong="H5921"\w*, padre \w mío|strong="H5921"\w*! ¡Carroza \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* su jinete!
\p 
\v 15 Eliseo le dijo: \w Toma|strong="H3947"\w* un \w arco|strong="H7198"\w* y unas flechas. Así que él \w tomó|strong="H3947"\w* un \w arco|strong="H7198"\w* y unas flechas.
\v 16 \w Y|strong="H3068"\w* dijo \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: \w Pon|strong="H7760"\w* tu \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w arco|strong="H7198"\w*. \w Y|strong="H3068"\w* \w él|strong="H5921"\w* \w puso|strong="H7760"\w* su \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w arco|strong="H7198"\w*.
\p Entonces Eliseo apoyó sus \w manos|strong="H3027"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*
\v 17 \w y|strong="H5704"\w* dijo: \w Abre|strong="H6605"\w* la ventana hacia el \w oriente|strong="H6924"\w*, \w y|strong="H5704"\w* él la \w abrió|strong="H6605"\w*. Entonces Eliseo dijo: ¡\w Tira|strong="H3384"\w*! \w Y|strong="H3068"\w* \w al|strong="H5704"\w* tirar él, Eliseo dijo: ¡Flecha \w de|strong="H5704"\w* victoria \w de|strong="H5704"\w* \nd \w Yavé|strong="H3068"\w*\nd*! ¡Sí, flecha \w de|strong="H5704"\w* victoria contra Siria, pues matarás \w a|strong="H3068"\w* los sirios \w en|strong="H5704"\w* Afec \w hasta|strong="H5704"\w* \w acabarlos|strong="H3615"\w*!
\p 
\v 18 \w Y|strong="H3068"\w* agregó: \w Toma|strong="H3947"\w* las flechas. \w Y|strong="H3068"\w* las \w tomó|strong="H3947"\w*. Entonces dijo \w al|strong="H4428"\w* \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w*: ¡Golpea la tierra! Él la golpeó \w tres|strong="H7969"\w* \w veces|strong="H6471"\w* y se detuvo.
\v 19 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* varón \w de|strong="H5921"\w* \nd ʼElohim\nd* \w se|strong="H5921"\w* airó \w contra|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* dijo: ¡\w Si|strong="H5921"\w* hubieras golpeado \w cinco|strong="H2568"\w* \w o|strong="H3068"\w* \w seis|strong="H8337"\w* \w veces|strong="H6471"\w*, entonces \w herirías|strong="H5221"\w* \w a|strong="H3068"\w* Siria \w hasta|strong="H5704"\w* acabarla! Pero \w ahora|strong="H6258"\w* vencerás \w a|strong="H3068"\w* Siria solo \w tres|strong="H7969"\w* \w veces|strong="H6471"\w*.
\p 
\v 20 Eliseo \w murió|strong="H4191"\w* y lo \w sepultaron|strong="H6912"\w*.
\p El \w año|strong="H8141"\w* siguiente llegaron bandas armadas de moabitas \w a|strong="H3068"\w* la tierra.
\v 21 \w Aconteció|strong="H1961"\w* \w que|strong="H5921"\w* \w al|strong="H5921"\w* sepultar \w a|strong="H3068"\w* un hombre, \w de|strong="H5921"\w* repente \w vieron|strong="H7200"\w* una banda armada, \w y|strong="H5921"\w* lanzaron \w el|strong="H5921"\w* muerto \w al|strong="H5921"\w* \w sepulcro|strong="H6913"\w* \w de|strong="H5921"\w* Eliseo. \w Cuando|strong="H1961"\w* \w el|strong="H5921"\w* cadáver \w tocó|strong="H5060"\w* \w los|strong="H1992"\w* \w huesos|strong="H6106"\w* \w de|strong="H5921"\w* Eliseo, \w revivió|strong="H2421"\w* \w y|strong="H5921"\w* \w se|strong="H1961"\w* \w levantó|strong="H6965"\w* \w sobre|strong="H5921"\w* \w sus|strong="H1992"\w* \w pies|strong="H7272"\w*.
\p 
\v 22 \w Hazael|strong="H2371"\w*, \w rey|strong="H4428"\w* de Siria, \w afligió|strong="H3905"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* de Joacaz.
\v 23 Pero \nd \w Yavé|strong="H3068"\w*\nd* tuvo \w misericordia|strong="H7355"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* compadeció \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*. \w Se|strong="H5921"\w* \w volvió|strong="H6437"\w* \w hacia|strong="H5921"\w* \w ellos|strong="H5921"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* su \w Pacto|strong="H1285"\w* \w con|strong="H5921"\w* Abraham, \w Isaac|strong="H3327"\w* \w y|strong="H5921"\w* \w Jacob|strong="H3290"\w*. \w No|strong="H3808"\w* \w los|strong="H5921"\w* \w destruyó|strong="H7843"\w*, \w ni|strong="H3808"\w* \w los|strong="H5921"\w* \w echó|strong="H7993"\w* \w de|strong="H5921"\w* su \w Presencia|strong="H6440"\w* \w hasta|strong="H5704"\w* \w ahora|strong="H6258"\w*.
\p 
\v 24 \w Murió|strong="H4191"\w* \w Hazael|strong="H2371"\w*, \w rey|strong="H4428"\w* \w de|strong="H8478"\w* Siria, y su \w hijo|strong="H1121"\w* \w Ben-adad|strong="H1130"\w* \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w*.
\v 25 Jeoás, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Joacaz, \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* quitar \w de|strong="H1121"\w* \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w Ben-adad|strong="H1130"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Hazael|strong="H2371"\w*, las \w ciudades|strong="H5892"\w* \w que|strong="H1121"\w* éste \w tomó|strong="H3947"\w* \w en|strong="H5221"\w* \w guerra|strong="H4421"\w* \w de|strong="H1121"\w* \w mano|strong="H3027"\w* \w de|strong="H1121"\w* su padre Joacaz. \w Tres|strong="H7969"\w* \w veces|strong="H6471"\w* Jeoás lo \w venció|strong="H5221"\w*, y \w recuperó|strong="H7725"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.
\c 14
\s1 Reinado de Amasías en Judá
\p 
\v 1 \w El|strong="H1121"\w* \w año|strong="H8141"\w* \w segundo|strong="H8147"\w* \w de|strong="H1121"\w* Jeoás, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Joacaz, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, comenzó \w a|strong="H3068"\w* reinar Amasías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joás|strong="H3101"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.
\v 2 \w Tenía|strong="H1961"\w* 25 \w años|strong="H8141"\w* \w cuando|strong="H1961"\w* comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* 29 \w años|strong="H8141"\w* \w en|strong="H4480"\w* Jerusalén. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H4480"\w* su madre \w fue|strong="H1961"\w* Joadán, \w de|strong="H4480"\w* Jerusalén.
\v 3 \w Hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w recto|strong="H3477"\w* ante \nd \w Yavé|strong="H3068"\w*\nd*, \w aunque|strong="H7535"\w* \w no|strong="H3808"\w* como \w David|strong="H1732"\w*, su antepasado. \w Hizo|strong="H6213"\w* conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w hizo|strong="H6213"\w* \w Joás|strong="H3101"\w* su padre.
\v 4 \w Sin|strong="H3808"\w* embargo, los lugares \w altos|strong="H1116"\w* \w no|strong="H3808"\w* fueron quitados, \w porque|strong="H3808"\w* el \w pueblo|strong="H5971"\w* \w aún|strong="H5750"\w* \w sacrificaba|strong="H2076"\w* y quemaba incienso \w en|strong="H5493"\w* los lugares \w altos|strong="H1116"\w*.
\p 
\v 5 \w Sucedió|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* el \w reino|strong="H4467"\w* \w se|strong="H1961"\w* afirmó \w en|strong="H5221"\w* sus \w manos|strong="H3027"\w*, \w mató|strong="H5221"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* esclavos \w que|strong="H1961"\w* asesinaron \w a|strong="H3068"\w* su padre el \w rey|strong="H4428"\w*.
\v 6 \w Pero|strong="H3588"\w* \w no|strong="H3808"\w* \w mató|strong="H5221"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* asesinos, \w según|strong="H5921"\w* \w lo|strong="H3808"\w* \w escrito|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* Rollo \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Ley|strong="H8451"\w* \w de|strong="H5921"\w* \w Moisés|strong="H4872"\w*, \w donde|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w mandó|strong="H6680"\w*: \w No|strong="H3808"\w* \w morirán|strong="H4191"\w* \w los|strong="H1121"\w* padres \w por|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w*, \w ni|strong="H3808"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w morirán|strong="H4191"\w* \w por|strong="H5921"\w* \w los|strong="H1121"\w* padres, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* cada \w cual|strong="H3588"\w* \w morirá|strong="H4191"\w* \w por|strong="H5921"\w* \w su|strong="H3588"\w* \w pecado|strong="H2399"\w*.
\p 
\v 7 \w Él|strong="H1931"\w* \w mató|strong="H5221"\w* \w a|strong="H3068"\w* 10.000 \w de|strong="H5704"\w* Edom \w en|strong="H5704"\w* \w el|strong="H1931"\w* \w valle|strong="H1516"\w* \w de|strong="H5704"\w* \w la|strong="H1931"\w* \w Sal|strong="H4417"\w*. Durante \w la|strong="H1931"\w* \w guerra|strong="H4421"\w* conquistó Sela \w y|strong="H5704"\w* \w la|strong="H1931"\w* \w llamó|strong="H7121"\w* \w Jocteel|strong="H3371"\w*, \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.
\p 
\v 8 Amasías \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* Jeoás, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Joacaz, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Jehú|strong="H3058"\w*, \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, y le dijo: ¡\w Ven|strong="H3212"\w*, veámonos las caras!
\p 
\v 9 Jeoás, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* Amasías, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*: \w El|strong="H1121"\w* cardo del \w Líbano|strong="H3844"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decir \w al|strong="H4428"\w* cedro del \w Líbano|strong="H3844"\w*: \w Da|strong="H5414"\w* tu \w hija|strong="H1323"\w* como esposa \w a|strong="H3068"\w* mi \w hijo|strong="H1121"\w*. \w Pasó|strong="H5674"\w* una fiera salvaje del \w Líbano|strong="H3844"\w* y pisoteó \w el|strong="H1121"\w* cardo.
\v 10 \w Ciertamente|strong="H5221"\w* derrotaste \w a|strong="H3068"\w* Edom, y tu \w corazón|strong="H3820"\w* \w se|strong="H4100"\w* enalteció. ¡Ufánate \w de|strong="H5973"\w* eso y \w quédate|strong="H3427"\w* \w en|strong="H5973"\w* tu \w casa|strong="H1004"\w*! ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* provocas una calamidad \w en|strong="H5973"\w* la \w que|strong="H4100"\w* puedes \w caer|strong="H5307"\w* tú y \w Judá|strong="H3063"\w* \w contigo|strong="H5973"\w*?
\p 
\v 11 Pero Amasías \w no|strong="H3808"\w* \w escuchó|strong="H8085"\w*, \w por|strong="H6440"\w* \w lo|strong="H1931"\w* \w cual|strong="H1931"\w* Jeoás, \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w salió|strong="H5927"\w* y \w se|strong="H1931"\w* \w vieron|strong="H7200"\w* las caras, \w él|strong="H1931"\w* y Amasías, \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Judá|strong="H3063"\w*, en Bet-semes, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w de|strong="H6440"\w* \w Judá|strong="H3063"\w*.
\v 12 \w Judá|strong="H3063"\w* \w fue|strong="H3063"\w* derrotado \w por|strong="H6440"\w* \w Israel|strong="H3478"\w*, y \w huyeron|strong="H5127"\w* cada uno \w a|strong="H3068"\w* su tienda.
\v 13 Jeoás, \w rey|strong="H4428"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w*, capturó \w a|strong="H3068"\w* Amasías, \w rey|strong="H4428"\w* \w de|strong="H5704"\w* \w Judá|strong="H3063"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* \w Joás|strong="H3060"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* Ocozías, \w en|strong="H5704"\w* Bet-semes. Entró \w en|strong="H5704"\w* Jerusalén \w y|strong="H5704"\w* rompió \w el|strong="H1121"\w* \w muro|strong="H2346"\w* \w de|strong="H5704"\w* Jerusalén \w desde|strong="H5704"\w* la \w puerta|strong="H8179"\w* \w de|strong="H5704"\w* Efraín \w hasta|strong="H5704"\w* la \w puerta|strong="H8179"\w* \w de|strong="H5704"\w* la esquina, 180 metros \w en|strong="H5704"\w* total.
\v 14 Después \w tomó|strong="H3947"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w oro|strong="H2091"\w*, \w la|strong="H3605"\w* \w plata|strong="H3701"\w* y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* utensilios \w que|strong="H1121"\w* estaban en \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd* y en \w los|strong="H1121"\w* tesoros \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w real|strong="H4428"\w*. \w Tomó|strong="H3947"\w* rehenes y \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w*.
\p 
\v 15 \w El|strong="H5921"\w* \w resto|strong="H3499"\w* \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w hechos|strong="H1697"\w* \w que|strong="H3808"\w* realizó Jeoás, \w su|strong="H1992"\w* valor \w y|strong="H5921"\w* \w cómo|strong="H5973"\w* luchó \w contra|strong="H5921"\w* Amasías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, ¿\w no|strong="H3808"\w* están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w las|strong="H1992"\w* Crónicas \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*?
\v 16 Jeoás descansó \w con|strong="H5973"\w* sus antepasados, y fue \w sepultado|strong="H6912"\w* \w en|strong="H5973"\w* \w Samaria|strong="H8111"\w* \w con|strong="H5973"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w de|strong="H8478"\w* \w Israel|strong="H3478"\w*. \w Reinó|strong="H4427"\w* \w en|strong="H5973"\w* su \w lugar|strong="H8478"\w* su \w hijo|strong="H1121"\w* \w Jeroboam|strong="H3379"\w*.
\p 
\v 17 Amasías, \w hijo|strong="H1121"\w* \w de|strong="H2568"\w* \w Joás|strong="H3101"\w*, \w rey|strong="H4428"\w* \w de|strong="H2568"\w* \w Judá|strong="H3063"\w*, \w vivió|strong="H2421"\w* 15 \w años|strong="H8141"\w* después \w de|strong="H2568"\w* la \w muerte|strong="H4194"\w* \w de|strong="H2568"\w* Jeoás, \w hijo|strong="H1121"\w* \w de|strong="H2568"\w* Joacaz, \w rey|strong="H4428"\w* \w de|strong="H2568"\w* \w Israel|strong="H3478"\w*.
