\p 
\v 1 Lorsque Doëg, \w l|strong="H1732"\w*'Iduméen, \w vint|strong="H1732"\w* avertir Saül, \w et|strong="H1732"\w* \w lui|strong="H1732"\w* \w dit|strong="H1732"\w* que \w David|strong="H1732"\w* s'\w était|strong="H1732"\w* rendu \w dans|strong="H1732"\w* \w la|strong="H1732"\w* maison d'Achimélec.
\v 2 Pourquoi \w te|strong="H1732"\w* glorifies-tu \w de|strong="H1004"\w* \w la|strong="H5046"\w* malice, \w homme|strong="H1004"\w* puissant? \w La|strong="H5046"\w* bonté \w de|strong="H1004"\w* \w Dieu|strong="H1004"\w* dure toujours.
\v 3 Pareille \w au|strong="H3117"\w* rasoir affilé, \w ta|strong="H3117"\w* langue médite \w la|strong="H3117"\w* \w ruine|strong="H3117"\w*, artisan \w de|strong="H3117"\w* fraudes!
\v 4 \w Tu|strong="H6213"\w* aimes \w le|strong="H6213"\w* \w mal|strong="H6213"\w* \w plus|strong="H6213"\w* \w que|strong="H2803"\w* \w le|strong="H6213"\w* \w bien|strong="H6213"\w*, \w le|strong="H6213"\w* mensonge \w plus|strong="H6213"\w* \w que|strong="H2803"\w* \w les|strong="H6213"\w* \w paroles|strong="H3956"\w* justes. Sélah (pause).
\v 5 \w Tu|strong="H1696"\w* n'aimes \w que|strong="H2896"\w* \w les|strong="H1696"\w* \w paroles|strong="H1696"\w* \w de|strong="H2896"\w* destruction, langue perfide!
\v 6 \w Aussi|strong="H1697"\w* \w Dieu|strong="H1697"\w* \w te|strong="H1697"\w* détruira \w pour|strong="H1697"\w* toujours; \w il|strong="H1697"\w* \w te|strong="H1697"\w* saisira \w et|strong="H1697"\w* t'arrachera \w de|strong="H1697"\w* \w ta|strong="H3605"\w* tente; \w il|strong="H1697"\w* \w te|strong="H1697"\w* déracinera \w de|strong="H1697"\w* \w la|strong="H1697"\w* \w terre|strong="H1697"\w* \w des|strong="H1697"\w* vivants. (Sélah.)
