\v 9 Aide-nous, ô \w Dieu|strong="H1697"\w* \w de|strong="H1697"\w* \w notre|strong="H8034"\w* \w salut|strong="H3468"\w*, \w pour|strong="H5921"\w* \w la|strong="H5921"\w* \w gloire|strong="H3519"\w* \w de|strong="H1697"\w* \w ton|strong="H5921"\w* \w nom|strong="H8034"\w*, \w et|strong="H5921"\w* \w nous|strong="H8034"\w* \w délivre|strong="H5337"\w*! Pardonne-nous \w nos|strong="H3722"\w* \w péchés|strong="H2403"\w* \w pour|strong="H5921"\w* l'\w amour|strong="H5921"\w* \w de|strong="H1697"\w* \w ton|strong="H5921"\w* \w nom|strong="H8034"\w*!
\v 10 \w Pourquoi|strong="H4100"\w* \w les|strong="H3045"\w* \w nations|strong="H1471"\w* diraient-elles: \w Où|strong="H5650"\w* \w est|strong="H5869"\w* \w leur|strong="H3045"\w* \w Dieu|strong="H3045"\w*? \w Qu|strong="H4100"\w*'\w elle|strong="H5869"\w* \w se|strong="H5869"\w* \w montre|strong="H3045"\w* \w à|strong="H5869"\w* \w nos|strong="H5650"\w* \w yeux|strong="H5869"\w*, \w parmi|strong="H3045"\w* \w les|strong="H3045"\w* \w nations|strong="H1471"\w*, \w la|strong="H3045"\w* \w vengeance|strong="H5360"\w* \w du|strong="H5650"\w* \w sang|strong="H1818"\w* \w de|strong="H5650"\w* \w tes|strong="H3045"\w* \w serviteurs|strong="H5650"\w*, \w qui|strong="H5869"\w* \w a|strong="H3068"\w* \w été|strong="H5869"\w* \w répandu|strong="H8210"\w*!
\v 11 \w Que|strong="H1121"\w* \w le|strong="H6440"\w* gémissement \w du|strong="H1121"\w* captif parvienne \w en|strong="H6440"\w* \w ta|strong="H1121"\w* \w présence|strong="H6440"\w*! \w conserve|strong="H3498"\w*, \w selon|strong="H1121"\w* \w la|strong="H6440"\w* \w grandeur|strong="H1433"\w* \w de|strong="H1121"\w* \w ta|strong="H1121"\w* \w force|strong="H2220"\w*, \w ceux|strong="H1121"\w* \w qui|strong="H1121"\w* \w sont|strong="H1121"\w* voués \w à|strong="H1121"\w* \w la|strong="H6440"\w* \w mort|strong="H1121"\w*!
\v 12 \w Et|strong="H7725"\w* \w rends|strong="H7725"\w* \w à|strong="H7725"\w* \w nos|strong="H7725"\w* \w voisins|strong="H7934"\w*, \w par|strong="H7725"\w* \w sept|strong="H7659"\w* \w fois|strong="H7659"\w*, \w dans|strong="H7725"\w* \w leur|strong="H7725"\w* \w sein|strong="H2436"\w*, l'\w outrage|strong="H2778"\w* qu'\w ils|strong="H7725"\w* t'\w ont|strong="H7725"\w* \w fait|strong="H7725"\w*, \w Seigneur|strong="H7725"\w*!
\v 13 Mais \w nous|strong="H5971"\w*, \w ton|strong="H3034"\w* \w peuple|strong="H5971"\w*, \w le|strong="H5971"\w* \w troupeau|strong="H6629"\w* \w que|strong="H5971"\w* \w tu|strong="H5971"\w* conduis, \w nous|strong="H5971"\w* \w te|strong="H5971"\w* \w célébrerons|strong="H3034"\w* \w à|strong="H5971"\w* \w jamais|strong="H5769"\w*. \w D|strong="H3068"\w*'\w âge|strong="H1755"\w* \w en|strong="H5971"\w* \w âge|strong="H1755"\w* \w nous|strong="H5971"\w* redirons \w ta|strong="H5769"\w* \w louange|strong="H8416"\w*.
\c 80
\p 
\v 1 Pasteur d'Israël, prête l'oreille; toi qui mènes Joseph comme un troupeau, toi qui sièges entre \w les|strong="H5329"\w* chérubins, fais briller ta splendeur!
\v 2 Devant \w Éphraïm|strong="H3478"\w*, Benjamin \w et|strong="H3478"\w* Manassé, réveille \w ta|strong="H3427"\w* puissance \w et|strong="H3478"\w* viens \w nous|strong="H3427"\w* sauver.
\v 3 \w O|strong="H3068"\w* \w Dieu|strong="H6440"\w*! rétablis-nous; \w fais|strong="H6440"\w* \w luire|strong="H6440"\w* \w ta|strong="H6440"\w* \w face|strong="H6440"\w*, \w et|strong="H3212"\w* \w nous|strong="H6440"\w* \w serons|strong="H6440"\w* sauvés!
\v 4 Éternel, \w Dieu|strong="H6440"\w* \w des|strong="H6440"\w* armées, jusques \w à|strong="H6440"\w* \w quand|strong="H7725"\w* \w ta|strong="H7725"\w* \w colère|strong="H6440"\w* fumera-t-elle \w contre|strong="H6440"\w* \w la|strong="H6440"\w* prière \w de|strong="H6440"\w* \w ton|strong="H6440"\w* \w peuple|strong="H6440"\w*?
\v 5 \w Tu|strong="H3068"\w* \w leur|strong="H3068"\w* \w fais|strong="H3068"\w* manger \w un|strong="H3068"\w* \w pain|strong="H3068"\w* \w de|strong="H5971"\w* larmes, \w et|strong="H3068"\w* \w tu|strong="H3068"\w* \w leur|strong="H3068"\w* \w fais|strong="H3068"\w* boire \w des|strong="H3068"\w* larmes \w à|strong="H3068"\w* pleine mesure.
\v 6 Tu fais \w de|strong="H3899"\w* nous \w un|strong="H3899"\w* sujet \w de|strong="H3899"\w* contestations \w pour|strong="H3899"\w* nos voisins, \w et|strong="H3899"\w* nos ennemis \w se|strong="H3899"\w* raillent \w de|strong="H3899"\w* nous entre eux.
\v 7 \w Dieu|strong="H7760"\w* \w des|strong="H7760"\w* armées! rétablis-nous; \w fais|strong="H7760"\w* luire \w ta|strong="H7760"\w* face, \w et|strong="H7760"\w* \w nous|strong="H7760"\w* serons sauvés!
\v 8 \w Tu|strong="H7725"\w* enlevas \w de|strong="H6440"\w* \w l|strong="H6440"\w*'Égypte \w une|strong="H6440"\w* vigne; \w tu|strong="H7725"\w* chassas \w des|strong="H6440"\w* nations \w et|strong="H7725"\w* \w tu|strong="H7725"\w* \w la|strong="H6440"\w* plantas.
\v 9 \w Tu|strong="H1471"\w* préparas \w le|strong="H4714"\w* sol \w devant|strong="H1612"\w* elle; elle poussa \w ses|strong="H4714"\w* racines \w et|strong="H5265"\w* remplit \w la|strong="H5265"\w* terre.
\v 10 \w Les|strong="H6440"\w* montagnes \w se|strong="H6440"\w* couvraient \w de|strong="H6440"\w* \w son|strong="H6440"\w* ombre, \w et|strong="H6440"\w* \w les|strong="H6440"\w* cèdres \w de|strong="H6440"\w* \w Dieu|strong="H6440"\w* \w de|strong="H6440"\w* \w ses|strong="H6440"\w* sarments.
\v 11 \w Elle|strong="H6738"\w* étendait \w ses|strong="H3680"\w* pampres jusqu'à \w la|strong="H3680"\w* mer, \w et|strong="H2022"\w* \w ses|strong="H3680"\w* rejetons jusqu'\w au|strong="H2022"\w* fleuve.
\v 12 Pourquoi as-tu rompu \w ses|strong="H7971"\w* clôtures, \w en|strong="H7971"\w* sorte \w que|strong="H5704"\w* \w tous|strong="H3220"\w* \w les|strong="H7971"\w* passants \w la|strong="H7971"\w* pillent?
\v 13 \w Que|strong="H1870"\w* \w le|strong="H5674"\w* sanglier \w des|strong="H1870"\w* forêts \w la|strong="H5674"\w* dévaste, \w et|strong="H5674"\w* \w que|strong="H1870"\w* \w les|strong="H3605"\w* \w bêtes|strong="H5674"\w* \w des|strong="H1870"\w* champs \w la|strong="H5674"\w* broutent?
\v 14 Dieu \w des|strong="H7704"\w* armées, reviens! Regarde \w des|strong="H7704"\w* cieux, \w et|strong="H7462"\w* vois, \w et|strong="H7462"\w* visite cette vigne.
\v 15 \w Protège|strong="H7725"\w* \w ce|strong="H2063"\w* \w que|strong="H7200"\w* \w ta|strong="H7200"\w* droite \w a|strong="H3068"\w* planté, \w et|strong="H7725"\w* \w le|strong="H7200"\w* fils \w que|strong="H7200"\w* \w tu|strong="H7200"\w* t'\w es|strong="H7725"\w* \w choisi|strong="H7200"\w*.
\v 16 \w Elle|strong="H1121"\w* \w est|strong="H1121"\w* brûlée, \w elle|strong="H1121"\w* \w est|strong="H1121"\w* coupée. \w Ils|strong="H1121"\w* périssent devant \w le|strong="H1121"\w* courroux \w de|strong="H1121"\w* \w ta|strong="H5921"\w* \w face|strong="H5921"\w*.
\v 17 \w Que|strong="H6440"\w* \w ta|strong="H6440"\w* \w main|strong="H6440"\w* soit \w sur|strong="H6440"\w* \w l|strong="H6440"\w*'\w homme|strong="H6440"\w* \w de|strong="H6440"\w* \w ta|strong="H6440"\w* droite, \w sur|strong="H6440"\w* \w le|strong="H6440"\w* \w fils|strong="H6440"\w* \w de|strong="H6440"\w* \w l|strong="H6440"\w*'\w homme|strong="H6440"\w* \w que|strong="H6440"\w* \w tu|strong="H6440"\w* \w t|strong="H6440"\w*'\w es|strong="H6440"\w* \w choisi|strong="H6440"\w*;
\v 18 \w Et|strong="H1121"\w* \w nous|strong="H3027"\w* \w ne|strong="H1121"\w* \w nous|strong="H3027"\w* détournerons \w plus|strong="H5921"\w* \w de|strong="H1121"\w* \w toi|strong="H3027"\w*; rends-nous \w la|strong="H5921"\w* vie, \w et|strong="H1121"\w* \w nous|strong="H3027"\w* invoquerons \w ton|strong="H5921"\w* \w nom|strong="H3027"\w*.
\v 19 Éternel, \w Dieu|strong="H3808"\w* \w des|strong="H8034"\w* armées, rétablis-nous; \w fais|strong="H7121"\w* luire \w ta|strong="H4480"\w* face, \w et|strong="H3808"\w* \w nous|strong="H8034"\w* \w serons|strong="H3808"\w* sauvés!
\c 81
\p 
\v 1 Chantez avec allégresse \w à|strong="H5921"\w* \w Dieu|strong="H5921"\w*, \w notre|strong="H5921"\w* force; jetez \w des|strong="H5921"\w* \w cris|strong="H5921"\w* \w de|strong="H5921"\w* réjouissance au \w Dieu|strong="H5921"\w* \w de|strong="H5921"\w* Jacob!
\v 2 Entonnez \w le|strong="H7442"\w* chant; faites \w résonner|strong="H7321"\w* \w le|strong="H7442"\w* tambourin, \w la|strong="H3290"\w* harpe agréable avec \w la|strong="H3290"\w* lyre.
\v 3 Sonnez \w de|strong="H5414"\w* \w la|strong="H5414"\w* trompette \w à|strong="H5414"\w* \w la|strong="H5414"\w* nouvelle lune, \w à|strong="H5414"\w* \w la|strong="H5414"\w* pleine lune, \w au|strong="H5414"\w* \w jour|strong="H5414"\w* \w de|strong="H5414"\w* \w notre|strong="H5414"\w* fête.
\v 4 Car c'\w est|strong="H3117"\w* \w une|strong="H3117"\w* loi \w pour|strong="H3117"\w* Israël, \w une|strong="H3117"\w* ordonnance \w du|strong="H3117"\w* \w Dieu|strong="H3117"\w* \w de|strong="H3117"\w* Jacob.
\v 5 \w Il|strong="H1931"\w* \w en|strong="H3478"\w* \w fit|strong="H3478"\w* \w un|strong="H3478"\w* statut \w pour|strong="H3588"\w* \w Joseph|strong="H3478"\w*, \w quand|strong="H3588"\w* \w il|strong="H1931"\w* sortit contre \w le|strong="H3478"\w* \w pays|strong="H3478"\w* d'Égypte; \w là|strong="H3478"\w* j'entendis \w un|strong="H3478"\w* langage \w que|strong="H3588"\w* \w je|strong="H3588"\w* \w ne|strong="H3478"\w* connaissais \w pas|strong="H1931"\w*.
\v 6 \w J|strong="H3068"\w*'\w ai|strong="H8085"\w* déchargé, dit-il, \w son|strong="H7760"\w* épaule \w du|strong="H3318"\w* fardeau; \w ses|strong="H5921"\w* \w mains|strong="H5921"\w* \w ont|strong="H3045"\w* lâché \w la|strong="H8085"\w* corbeille.
\v 7 \w Tu|strong="H5674"\w* as crié \w dans|strong="H5674"\w* \w la|strong="H5674"\w* détresse, \w et|strong="H5674"\w* \w je|strong="H5674"\w* t'ai délivré; \w je|strong="H5674"\w* t'ai répondu, caché \w dans|strong="H5674"\w* \w le|strong="H5674"\w* tonnerre; \w je|strong="H5674"\w* t'ai éprouvé \w aux|strong="H5493"\w* eaux \w de|strong="H5493"\w* Mériba. (Sélah.)
\v 8 Écoute, \w mon|strong="H7121"\w* \w peuple|strong="H7121"\w*, \w et|strong="H6030"\w* \w je|strong="H7121"\w* t'exhorterai; Israël, si \w tu|strong="H5921"\w* m'écoutais!
\v 9 Qu'\w il|strong="H5971"\w* n'\w y|strong="H5971"\w* \w ait|strong="H3478"\w* \w point|strong="H8085"\w* \w chez|strong="H5971"\w* \w toi|strong="H5971"\w* \w de|strong="H5971"\w* \w dieu|strong="H8085"\w* étranger; \w ne|strong="H3478"\w* \w te|strong="H5971"\w* prosterne \w pas|strong="H8085"\w* devant \w les|strong="H8085"\w* \w dieux|strong="H8085"\w* \w des|strong="H5971"\w* nations!
\v 10 \w Je|strong="H3068"\w* \w suis|strong="H1961"\w* l'Éternel, \w ton|strong="H3808"\w* \w Dieu|strong="H3808"\w*, \w qui|strong="H2114"\w* t'ai \w fait|strong="H3808"\w* remonter \w du|strong="H5236"\w* \w pays|strong="H1961"\w* d'Égypte. Ouvre \w ta|strong="H3808"\w* bouche, \w et|strong="H3808"\w* \w je|strong="H3808"\w* \w la|strong="H1961"\w* remplirai.
\v 11 Mais \w mon|strong="H3068"\w* \w peuple|strong="H3068"\w* n'\w a|strong="H3068"\w* \w pas|strong="H5927"\w* écouté \w ma|strong="H4390"\w* \w voix|strong="H4390"\w*; \w Israël|strong="H3068"\w* n'\w a|strong="H3068"\w* \w pas|strong="H5927"\w* \w voulu|strong="H3068"\w* m'obéir.
\v 12 \w Et|strong="H3478"\w* \w je|strong="H6963"\w* \w les|strong="H8085"\w* \w ai|strong="H8085"\w* \w abandonnés|strong="H3808"\w* \w à|strong="H3478"\w* \w la|strong="H8085"\w* dureté \w de|strong="H5971"\w* \w leur|strong="H8085"\w* \w cœur|strong="H5971"\w*, \w pour|strong="H5971"\w* marcher \w selon|strong="H5971"\w* \w leurs|strong="H8085"\w* conseils.
\v 13 Oh! \w si|strong="H3212"\w* \w mon|strong="H7971"\w* peuple voulait m'écouter, qu'Israël marchât \w dans|strong="H3212"\w* \w mes|strong="H3212"\w* voies!
\v 14 \w J|strong="H3068"\w*'\w eusse|strong="H3478"\w* \w en|strong="H5971"\w* \w un|strong="H3478"\w* instant \w fait|strong="H1870"\w* ployer \w leurs|strong="H8085"\w* ennemis, j'\w aurais|strong="H5971"\w* \w tourné|strong="H1980"\w* \w ma|strong="H8085"\w* \w main|strong="H8085"\w* \w contre|strong="H5971"\w* \w leurs|strong="H8085"\w* adversaires.
\v 15 \w Ceux|strong="H3027"\w* \w qui|strong="H3027"\w* haïssent l'Éternel eussent flatté \w Israël|strong="H7725"\w*, \w et|strong="H7725"\w* \w son|strong="H3027"\w* \w temps|strong="H4592"\w* heureux \w eût|strong="H7725"\w* toujours duré.
\v 16 \w Dieu|strong="H3068"\w* \w les|strong="H3068"\w* \w eût|strong="H3068"\w* nourris \w de|strong="H1961"\w* \w la|strong="H3068"\w* mœlle \w du|strong="H3068"\w* froment. \w Je|strong="H3068"\w* t'eusse rassasié \w du|strong="H3068"\w* miel \w du|strong="H3068"\w* rocher.
\c 82
\p 
\v 1 \w Psaume|strong="H4210"\w* d'Asaph. \w Dieu|strong="H8199"\w* \w se|strong="H5712"\w* \w tient|strong="H5324"\w* \w dans|strong="H7130"\w* l'\w assemblée|strong="H5712"\w* \w de|strong="H4210"\w* \w Dieu|strong="H8199"\w*; \w il|strong="H8199"\w* \w juge|strong="H8199"\w* \w au|strong="H8199"\w* \w milieu|strong="H7130"\w* \w des|strong="H5712"\w* dieux.
\v 2 Jusques \w à|strong="H5704"\w* \w quand|strong="H5704"\w* \w serez-vous|strong="H4970"\w* \w des|strong="H6440"\w* \w juges|strong="H8199"\w* pervers, \w et|strong="H6440"\w* \w aurez-vous|strong="H6440"\w* \w égard|strong="H5375"\w* \w à|strong="H5704"\w* \w la|strong="H6440"\w* \w personne|strong="H6440"\w* \w des|strong="H6440"\w* \w méchants|strong="H7563"\w*?
\v 3 Faites \w droit|strong="H8199"\w* \w au|strong="H8199"\w* \w faible|strong="H1800"\w* \w et|strong="H6041"\w* à l'\w orphelin|strong="H3490"\w*; \w rendez|strong="H8199"\w* \w justice|strong="H8199"\w* \w au|strong="H8199"\w* \w misérable|strong="H1800"\w* \w et|strong="H6041"\w* \w au|strong="H8199"\w* \w pauvre|strong="H1800"\w*.
\v 4 \w Délivrez|strong="H5337"\w* \w le|strong="H3027"\w* \w faible|strong="H1800"\w* \w et|strong="H3027"\w* l'indigent; sauvez-le \w de|strong="H3027"\w* \w la|strong="H3027"\w* \w main|strong="H3027"\w* \w des|strong="H3027"\w* \w méchants|strong="H7563"\w*.
\v 5 \w Ils|strong="H3045"\w* \w ne|strong="H3808"\w* \w connaissent|strong="H3045"\w* \w ni|strong="H3808"\w* n'\w entendent|strong="H3045"\w* \w rien|strong="H3808"\w*; \w ils|strong="H3045"\w* \w marchent|strong="H1980"\w* \w dans|strong="H1980"\w* \w les|strong="H3605"\w* \w ténèbres|strong="H2825"\w*; \w tous|strong="H3605"\w* \w les|strong="H3605"\w* \w fondements|strong="H4144"\w* \w de|strong="H3808"\w* \w la|strong="H3045"\w* \w terre|strong="H3045"\w* \w sont|strong="H3808"\w* \w ébranlés|strong="H4131"\w*.
\v 6 \w J|strong="H3068"\w*'\w ai|strong="H3605"\w* \w dit|strong="H1121"\w*: \w Vous|strong="H1121"\w* \w êtes|strong="H1121"\w* \w des|strong="H1121"\w* \w dieux|strong="H1121"\w*, \w vous|strong="H1121"\w* \w êtes|strong="H1121"\w* \w tous|strong="H3605"\w* \w des|strong="H1121"\w* \w fils|strong="H1121"\w* \w du|strong="H1121"\w* Très-Haut;
\v 7 Toutefois \w vous|strong="H4191"\w* \w mourrez|strong="H4191"\w* \w comme|strong="H4191"\w* \w des|strong="H8269"\w* \w hommes|strong="H8269"\w*, \w et|strong="H5307"\w* \w vous|strong="H4191"\w* \w tomberez|strong="H5307"\w* \w comme|strong="H4191"\w* l'\w un|strong="H4191"\w* \w des|strong="H8269"\w* \w princes|strong="H8269"\w*.
\v 8 \w Lève-toi|strong="H6965"\w*, ô \w Dieu|strong="H3588"\w*, \w juge|strong="H8199"\w* \w la|strong="H3588"\w* \w terre|strong="H8199"\w*! \w Car|strong="H3588"\w* \w tu|strong="H3588"\w* \w posséderas|strong="H5157"\w* \w en|strong="H8199"\w* \w héritage|strong="H5157"\w* \w toutes|strong="H3588"\w* \w les|strong="H3605"\w* \w nations|strong="H1471"\w*.
\c 83
\p 
\v 1 \w O|strong="H3068"\w* Dieu, ne garde pas le silence! Ne sois pas sourd et ne reste pas dans le repos, ô Dieu!
\v 2 Car voici, tes ennemis s'agitent, \w et|strong="H8252"\w* ceux qui \w te|strong="H2790"\w* haïssent \w ont|strong="H2790"\w* levé la tête.
\v 3 \w Ils|strong="H3588"\w* font contre \w ton|strong="H5375"\w* peuple d'astucieux complots, \w et|strong="H5375"\w* \w se|strong="H3588"\w* concertent contre \w ceux|strong="H3588"\w* \w que|strong="H3588"\w* \w tu|strong="H3588"\w* protèges.
\v 4 Venez, disent-ils, faisons-les disparaître d'\w entre|strong="H5971"\w* \w les|strong="H5921"\w* nations, \w et|strong="H5921"\w* qu'\w on|strong="H5971"\w* \w ne|strong="H5971"\w* parle \w plus|strong="H5971"\w* \w du|strong="H5971"\w* nom d'Israël.
