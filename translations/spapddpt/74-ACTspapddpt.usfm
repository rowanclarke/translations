\c 1  
\s1 La promesa del Padre  
\p
\v 1 \w En|strong="G4012"\w* \w el|strong="G3588"\w* \w primer|strong="G4413"\w* relato, \w oh|strong="G5599"\w* \w Teófilo|strong="G2321"\w*, escribí \w con|strong="G2532"\w* \w respecto|strong="G4012"\w* a \w las|strong="G3588"\w* \w cosas|strong="G3739"\w* \w que|strong="G3588"\w* \w Jesús|strong="G2424"\w* \w hizo|strong="G4160"\w* \w y|strong="G2532"\w* \w enseñó|strong="G1321"\w* desde \w el|strong="G3588"\w* comienzo  
\v 2 hasta \w el|strong="G3588"\w* \w día|strong="G2250"\w* cuando dio órdenes \w por|strong="G1223"\w* \w el|strong="G3588"\w* \w Espíritu|strong="G4151"\w* Santo \w a|strong="G1223"\w* \w los|strong="G3588"\w* apóstoles \w que|strong="G3588"\w* \w escogió|strong="G1586"\w*, y ascendió.  
\v 3 \w Después|strong="G3326"\w* \w de|strong="G4012"\w* \w padecer|strong="G3958"\w* \w Él|strong="G3588"\w*, \w se|strong="G1438"\w* les \w apareció|strong="G3700"\w* \w vivo|strong="G2198"\w* \w con|strong="G3326"\w* \w muchas|strong="G4183"\w* \w pruebas|strong="G5039"\w* durante 40 \w días|strong="G2250"\w* \w y|strong="G2532"\w* les \w hablaba|strong="G3004"\w* \w sobre|strong="G4012"\w* \w el|strong="G3588"\w* reino \w de|strong="G4012"\w* \w Dios|strong="G2316"\w*.   
\p
\v 4 \w Se|strong="G2532"\w* reunieron \w y|strong="G2532"\w* les \w mandó|strong="G3853"\w* \w que|strong="G3588"\w* \w no|strong="G3361"\w* salieran \w de|strong="G3588"\w* Jerusalén, \w sino|strong="G3361"\w* \w que|strong="G3588"\w* esperaran \w la|strong="G3588"\w* \w promesa|strong="G1860"\w* \w del|strong="G3588"\w* \w Padre|strong="G3962"\w* \w que|strong="G3588"\w* \w Él|strong="G3588"\w* les anunció:  
\v 5 \wj \+w Porque|strong="G3754"\+w* \+w Juan|strong="G2491"\+w* \+w ciertamente|strong="G3303"\+w* bautizó \+w con|strong="G3326"\+w* \+w agua|strong="G5204"\+w*, \+w pero|strong="G1161"\+w* ustedes serán bautizados \+w con|strong="G3326"\+w* \+w el|strong="G3748"\+w* \+w Espíritu|strong="G4151"\+w* Santo \+w dentro|strong="G1722"\+w* \+w de|strong="G1722"\+w* \+w unos|strong="G3303"\+w* \+w días|strong="G2250"\+w*. \wj*   
\s1 Ascensión del Señor Jesús  
\p
\v 6 \w Los|strong="G3588"\w* reunidos \w le|strong="G1722"\w* preguntaban: \w Señor|strong="G2962"\w*, ¿restauras \w el|strong="G3588"\w* reino \w a|strong="G1722"\w* \w Israel|strong="G2474"\w* \w en|strong="G1722"\w* \w este|strong="G3778"\w* \w tiempo|strong="G5550"\w*?   
