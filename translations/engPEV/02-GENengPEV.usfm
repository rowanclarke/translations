\p
\v 24 \w The|strong="H3605"\w* \w men|strong="H1121"\w* \w that|strong="H3605"\w* lived \w in|strong="H8085"\w* \w that|strong="H3605"\w* \w town|strong="H5892"\w*, \w they|strong="H3605"\w* \w listened|strong="H8085"\w* \w to|strong="H3318"\w* \w Hamor|strong="H2544"\w* \w and|strong="H1121"\w* \w his|strong="H3605"\w* \w son|strong="H1121"\w* Shekem, \w and|strong="H1121"\w* \w they|strong="H3605"\w* \w agreed|strong="H8085"\w* \w to|strong="H3318"\w* \w do|strong="H3318"\w* \w what|strong="H8085"\w* \w Hamor|strong="H2544"\w* \w and|strong="H1121"\w* Shekem \w said|strong="H8085"\w*. \w So|strong="H3318"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* boys \w and|strong="H1121"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w men|strong="H1121"\w* \w that|strong="H3605"\w* lived \w in|strong="H8085"\w* \w that|strong="H3605"\w* \w town|strong="H5892"\w*, \w they|strong="H3605"\w* \w had|strong="H1121"\w* \w a|strong="H3068"\w* \w young|strong="H1121"\w* \w man|strong="H1121"\w* operation.   
\s1 Jacob’s sons finished up Shekem’s mob  
\p
\v 25 \w That|strong="H3605"\w* \w young|strong="H1121"\w* \w man|strong="H2145"\w* operation hurt \w a|strong="H3068"\w* lot. \w And|strong="H1121"\w* 3 \w days|strong="H3117"\w* \w later|strong="H1961"\w*, \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w men|strong="H1121"\w* \w in|strong="H5921"\w* Shekem’s mob still felt really \w weak|strong="H3605"\w*. \w Then|strong="H1961"\w* 2 \w of|strong="H1121"\w* \w Jacob|strong="H3290"\w*’s \w sons|strong="H1121"\w*, \w they|strong="H3117"\w* \w got|strong="H3947"\w* \w some|strong="H3117"\w* \w long|strong="H3117"\w* \w knives|strong="H2719"\w*, \w and|strong="H1121"\w* \w they|strong="H3117"\w* \w went|strong="H3290"\w* \w to|strong="H1961"\w* attack Shekem’s mob. \w Those|strong="H3605"\w* 2 \w sons|strong="H1121"\w* \w were|strong="H1961"\w* \w Simeon|strong="H8095"\w* \w and|strong="H1121"\w* \w Levi|strong="H3878"\w*, \w and|strong="H1121"\w* \w they|strong="H3117"\w* \w were|strong="H1961"\w* \w Dinah|strong="H1783"\w*’s \w brothers|strong="H1121"\w*. Nobody \w in|strong="H5921"\w* Shekem’s mob knew \w that|strong="H3605"\w* \w Dinah|strong="H1783"\w*’s \w brothers|strong="H1121"\w* wanted \w to|strong="H1961"\w* attack \w them|strong="H5921"\w*, \w so|strong="H3947"\w* \w they|strong="H3117"\w* \w were|strong="H1961"\w* \w not|strong="H1961"\w* ready \w to|strong="H1961"\w* fight. \w Simeon|strong="H8095"\w* \w and|strong="H1121"\w* \w Levi|strong="H3878"\w* \w went|strong="H3290"\w* \w into|strong="H5921"\w* \w the|strong="H3605"\w* \w town|strong="H5892"\w*, \w and|strong="H1121"\w* \w they|strong="H3117"\w* \w killed|strong="H2026"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* boys \w and|strong="H1121"\w* \w men|strong="H1121"\w* \w there|strong="H1961"\w*.  
\v 26 \w They|strong="H6310"\w* \w also|strong="H1121"\w* \w killed|strong="H2026"\w* \w Hamor|strong="H2544"\w* \w and|strong="H1121"\w* \w his|strong="H3947"\w* \w son|strong="H1121"\w* Shekem \w with|strong="H1004"\w* \w those|strong="H1121"\w* long \w knives|strong="H2719"\w*.  
\p \w At|strong="H1004"\w* \w that|strong="H1121"\w* \w time|strong="H3318"\w*, \w Dinah|strong="H1783"\w* \w was|strong="H1004"\w* \w in|strong="H1004"\w* Shekem’s \w house|strong="H1004"\w*. \w So|strong="H3947"\w* Simeon \w and|strong="H1121"\w* Levi \w got|strong="H3947"\w* \w Dinah|strong="H1783"\w* \w from|strong="H3318"\w* Shekem’s \w house|strong="H1004"\w*, \w and|strong="H1121"\w* \w they|strong="H6310"\w* \w left|strong="H3318"\w* \w the|strong="H3947"\w* town.   
\p
\v 27 \w Then|strong="H1121"\w* \w Jacob|strong="H3290"\w*’s other \w sons|strong="H1121"\w* \w went|strong="H3290"\w* \w into|strong="H5921"\w* \w the|strong="H5921"\w* \w town|strong="H5892"\w*, \w and|strong="H1121"\w* \w they|strong="H5921"\w* \w saw|strong="H3290"\w* \w all|strong="H5921"\w* \w the|strong="H5921"\w* \w dead|strong="H2491"\w* bodies \w of|strong="H1121"\w* Shekem’s mob. \w So|strong="H5921"\w* \w Jacob|strong="H3290"\w*’s \w sons|strong="H1121"\w* took everything \w that|strong="H5892"\w* \w they|strong="H5921"\w* wanted \w in|strong="H5921"\w* \w that|strong="H5892"\w* \w town|strong="H5892"\w*. \w They|strong="H5921"\w* thought, “Shekem \w did|strong="H3290"\w* \w that|strong="H5892"\w* bad thing \w to|strong="H5921"\w* \w our|strong="H5921"\w* sister, \w so|strong="H5921"\w* \w we|strong="H3068"\w* \w will|strong="H1121"\w* \w take|strong="H1121"\w* everything \w that|strong="H5892"\w* belonged \w to|strong="H5921"\w* \w his|strong="H5921"\w* mob.”  
