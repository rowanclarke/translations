\s1 Huida a Egipto  
\p
\v 13 Cuando \w ellos|strong="G3588"\w* regresaron, \w un|strong="G3588"\w* ángel \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* \w apareció|strong="G5316"\w* súbitamente \w en|strong="G1519"\w* \w un|strong="G3588"\w* sueño \w a|strong="G1519"\w* \w José|strong="G2501"\w* \w y|strong="G2532"\w* \w le|strong="G2596"\w* \w dijo|strong="G3004"\w*: \w Levántate|strong="G1453"\w*, \w toma|strong="G3880"\w* \w al|strong="G3588"\w* \w Niño|strong="G3813"\w* \w y|strong="G2532"\w* \w a|strong="G1519"\w* \w su|strong="G3588"\w* \w madre|strong="G3384"\w* \w y|strong="G2532"\w* \w huye|strong="G5343"\w* \w a|strong="G1519"\w* Egipto. Permanece \w allá|strong="G1563"\w* \w hasta|strong="G2193"\w* \w que|strong="G3588"\w* yo \w te|strong="G4771"\w* diga, \w porque|strong="G1063"\w* \w Herodes|strong="G2264"\w* \w buscará|strong="G2212"\w* \w al|strong="G3588"\w* \w Niño|strong="G3813"\w* \w para|strong="G1519"\w* matarlo.   
\p
\v 14 \w Y|strong="G2532"\w* \w él|strong="G3588"\w* \w se|strong="G2532"\w* \w levantó|strong="G1453"\w* \w de|strong="G1519"\w* \w noche|strong="G3571"\w*, \w tomó|strong="G3880"\w* \w al|strong="G3588"\w* \w Niño|strong="G3813"\w* \w y|strong="G2532"\w* \w a|strong="G1519"\w* \w su|strong="G3588"\w* \w madre|strong="G3384"\w* \w y|strong="G2532"\w* \w se|strong="G2532"\w* fue \w a|strong="G1519"\w* Egipto.  
\v 15 Permaneció \w allá|strong="G1563"\w* \w hasta|strong="G2193"\w* \w la|strong="G3588"\w* \w muerte|strong="G5054"\w* \w de|strong="G1537"\w* \w Herodes|strong="G2264"\w*, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w se|strong="G2532"\w* cumpliera \w lo|strong="G3588"\w* \w dicho|strong="G2046"\w* \w por|strong="G1223"\w* \w el|strong="G3588"\w* \w Señor|strong="G2962"\w*, \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w del|strong="G3588"\w* \w profeta|strong="G4396"\w*:  
