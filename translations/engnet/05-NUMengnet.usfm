\v 13  \w Anyone|strong="H3605"\w* \w who|strong="H3605"\w* \w touches|strong="H5060"\w* \w the|strong="H3605"\w* \w corpse|strong="H5315"\w* \w of|strong="H3068"\w* \w any|strong="H3605"\w* \w dead|strong="H4191"\w* \w person|strong="H5315"\w* \w and|strong="H3478"\w* \w does|strong="H3808"\w* \w not|strong="H3808"\w* \w purify|strong="H2398"\w* \w himself|strong="H5315"\w* \w defiles|strong="H2930"\w* \w the|strong="H3605"\w* \w tabernacle|strong="H4908"\w* \w of|strong="H3068"\w* \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd*. \w And|strong="H3478"\w* \w that|strong="H3588"\w* \w person|strong="H5315"\w* \w must|strong="H4191"\w* \w be|strong="H1961"\w* \w cut|strong="H3772"\w* \w off|strong="H3772"\w* \w from|strong="H3772"\w* \w Israel|strong="H3478"\w*, \w because|strong="H3588"\w* \w the|strong="H3605"\w* \w water|strong="H4325"\w* \w of|strong="H3068"\w* purification \w was|strong="H3068"\w* \w not|strong="H3808"\w* \w sprinkled|strong="H2236"\w* \w on|strong="H5921"\w* \w him|strong="H5921"\w*. \w He|strong="H1931"\w* \w will|strong="H3068"\w* \w be|strong="H1961"\w* \w unclean|strong="H2931"\w*; \w his|strong="H3605"\w* \w uncleanness|strong="H2932"\w* \w remains|strong="H5750"\w* \w on|strong="H5921"\w* \w him|strong="H5921"\w*.   
\p
\v 14 “‘\w This|strong="H2063"\w* \w is|strong="H3117"\w* \w the|strong="H3605"\w* \w law|strong="H8451"\w*: \w When|strong="H3588"\w* \w a|strong="H3068"\w* \w man|strong="H4191"\w* \w dies|strong="H4191"\w* \w in|strong="H4191"\w* \w a|strong="H3068"\w* tent, \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* \w comes|strong="H3117"\w* into \w the|strong="H3605"\w* tent \w and|strong="H3117"\w* \w all|strong="H3605"\w* \w who|strong="H3605"\w* \w are|strong="H3117"\w* \w in|strong="H4191"\w* \w the|strong="H3605"\w* tent \w will|strong="H3117"\w* \w be|strong="H4191"\w* ceremonially \w unclean|strong="H2930"\w* \w seven|strong="H7651"\w* \w days|strong="H3117"\w*.  
