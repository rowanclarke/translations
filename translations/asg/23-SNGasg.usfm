\id SNG - Cishingini Agwara Kambari [asg]
\h Ishipa i Sulemanu
\toc1 Vishipa vu Sulemanu
\toc2 Vishipa vu Sulemanu
\toc3 Vsul
\mt1 Vishipa vu Sulemanu
\imt1 Kuɓa̱yuwa̱
\ip Ilina u kula ku katagarda ka nampa \bk Vishipa vu Sulemanu, ki a kadanshi \bk* Ɗa ɗa vishipa vu na vu laꞋi nu uyoꞋo a̱ ka̱tsuma̱ ki ishipa. Katagarda ka nampa kita̱ uɗiki n ishipa i na mekere n kolobo a tsu yaꞋankpanai kadanshi ku ucigi u le. Makyan ma yoku a yaꞋan kadanshi adama a̱ ka̱ci ke le. Makyan ma yoku kpamu a yaꞋanka ka̱ci ke le ko a̱ja̱Ꞌa̱ e le.
\ip Ishipa i nampa ya, utuka̱ ta̱ i ɗa e keteshe n uye kakau. A ubuta̱ u yoku i ta̱ a kufuɗa kudana kolobo ka a̱yi ɗa mogono Sulemanu n ka̱ci ka̱ ni. I ta̱ kpamu a kufuɗa kukece katagarda ka tsu kuyongo, tsu na a ɗikai mekere ma a bankai a kpaꞋa ku mogono Sulemanu, ama mekere ma mi ta̱ a kuciga vuza yoku na ɗe a̱ likuci i le, a ukocishi de mavuka ma ma doku ta̱ ma gasa n kolobo ku ucigi ka likuci i le. I ta̱ kpamu a kufuɗa ku utuka̱ n arabali a nampa e keteshe tsu urotu u kuyongo u Ka̱shile n uma a̱ ni, ko Vuzavaguɗu n aza o kutoni a̱ ni.
\ip Kpamu i ta̱ a kufuɗa e kece katagarda ka nampa ci ishipa i na yi a kadanshi ku ukuna wu ucigi ugbayin u na ugain a̱ ciya̱ a ubuta̱ u vuka n vali. Nannai bi ba, i ta̱ a kadanshi i ta̱ a kufuɗa kuyaꞋan ishipa i nampa a ubuta̱ u yolo a iɗika yi Isaraila i cau.
\ip Nnama n a̱pa̱lu a na ulai a katagarda ka nampa iyoci i ɗa yu ucanuku wi ikebe nu tsuloboi kpamu, u na u zuwai uma a ciɓa nu ngono n ugain wa a̱ma̱li n ucigi.
\iot Ili i na yi punu udari a katagarda ka nampa.
\io1 Vishipa vu ugiti 1:1; 2.7
\io1 Vishipa vu i re 2:8; 3:5
\io1 Vishipa vu tatsu 3:6; 5:1
\io1 Vishipa vu na̱shi 5:2; 6:3
\io1 Vishipa vu tawun 6:4; 8:14
\ib
\c 1
\p 
\v 1 Ishipa i Sulemanu i na i laꞋi n uyoꞋo.
\s1 Vishipa vu ugiti
\sp Mekere maꞋa ma cananai
\q1 
\v 2 YaꞋan u como mu n una̱ u ni
\q2 adama a na ucigi u nu u laꞋa ta̱ ma̱kya̱n uyoꞋo.
\q1 
\v 3 Ma̱gula̱ni ma maniꞋin ma̱ nu, mi ta̱ n ugaꞋin u kutsumgba,
\q2 kula ku nu tana ki ta̱ ci ili i ma̱gula̱ni i na a vishangi.
\q2 ɗaɗa i zuwai ɗa a̱ma̱ci i a kuciga wu.
\q1 
\v 4 YaꞋan gogoꞋo vu ɗika mu tsu suma,
\q2 yaꞋan mogono ma banka mu a̱ kunu ku ni,
\q1 Ci yaꞋan ma̱za̱nga̱ koɓolo,
\q2 mi ta̱ a kucikpa ucigi u nu u laꞋa ma̱kya̱n,
\q1 ɗaɗa i zuwai nkere mi a kuciga wu.
\q1 
\v 5 Mpa vuza lima̱ ɗa, ama mi ta̱ n tsuloboi.
\q2 a̱ɗa̱ nkere n Urushelima,
\q2 mpa vuza lima̱ ɗa tsu a a̱pa̱m e Kedaru,
\q2 tsu kakashi ku utsutsu ka̱ ka̱pa̱m ka Sulemanu.
\q1 
\v 6 Ka̱ta̱ yi inda mu bi-bi-bi ba
\q2 adama a na mpa vuza lima̱ ɗa,
\q2 adama a na kanna kaꞋa ko songu mu ta̱ ɗa n lima̱na̱i.
\q1 Ataku a̱ va̱ a yaꞋan ta̱ wupa nu mpa
\q2 a zuwai mu n yaꞋan ulinga a kashina ki itacishi,
\q2 n ciya̱ makyan ma na n kula̱na̱ ikyamba i va̱ ba.
\q1 
\v 7 Dana mu, avu macigi ma̱ va̱, teɗai vi a kaguɓa ka ushiga u nu?
\q2 Kpamu teɗai vu tsu banka n ushiga u nu wu uvuka kanna ka suɗukpa baci?
\q1 Yiɗa̱i i zuwai mo kokpo tsu vuka vu na a palai
\q2 a̱ ka̱ka̱ra̱sa̱ a ushiga wa̱ a̱ja̱Ꞌa̱ a̱ nu?
\q1 
\v 8 Avu na vu laꞋi n tsuloboi a̱ ka̱tsuma̱ ka̱ a̱ma̱ci, vu yeve baci ubuta̱ ba,
\q2 tono ura̱Ꞌa̱ wu nlala n na o tsu tono
\q1 vu guɓa nraɗika n nu
\q2 ɗevu n a̱pa̱m a nguɓi.
\q1 
\v 9 Avu macigi ma̱ va̱,
\q2 tsuloboi tsu nu u pura̱ ta̱ ugboji u va̱,
\q1 tsu kodoku ka na ki o kurono ucanuku
\q2 we ekeke odoku o kuvon a FiriꞋauna.
\q1 
\v 10 Ili ya atsuvu i doku ta̱ nguji n nu ugaꞋin,
\q2 kuɗeku ku nu ki ta̱ ucindali n idolu i singai.
\q1 
\v 11 Ci ta̱ a kuyaꞋanka wu ili ya atsuvu ya azanariya,
\q2 n ukali wa azurufa.
\q1 
\v 12 A makyan ma na mogono mi a̱ ubuta̱ u kirukpa ku ni,
\q2 ili ma̱gula̱ ni i va̱ i ka̱na̱ ta̱ ubuta̱ dem m ma̱gula̱ni.
\q1 
\v 13 Macigi ma̱ va̱ mi ta̱ tsu kazuwatsu ma Muru wa̱ va̱,
\q2 a ivaꞋin a̱ ma̱ka̱nga̱ ma̱ va̱.
\q1 
\v 14 Macigi ma̱ va̱ mi ta̱ tsu ka̱kutsu ka̱ a̱pa̱lu a kakamba wa̱ va̱
\q2 ashina itacishi i Enu-gedi.
\q1 
\v 15 Avu vi ta̱ n tsuloboi macigi ma̱ va̱.
\q2 Mayun, avu vi ta̱ n tsuloboi.
\q2 A̱shi a̱ nu i ta̱ kure-kure tsu moɗoi.
\q1 
\v 16 Avu vi ta̱ n tsuloboi, Macigi ma̱ va̱.
\q2 Avu vi ta̱ a kuɗika ugboji u va̱.
\q2 ivaꞋamkpatsu i tsu yi ta̱ leku an mita̱ ma̱ ta̱ku.
\q1 
\v 17 Aburakpatsu a kpaꞋa a̱ tsu nɗanga n sida n ɗa,
\q2 nɗanga n Firi n ɗa ashamkpatsu a kpaꞋa a tsu.
\c 2
\sp Mekere maꞋa ma laꞋi kelime n kadanshi
\q1 
\v 1 Mpa a̱pa̱lu a ɗa akamba a Sharon,
\q2 apulufa a ɗa a̱ ka̱ra̱Ꞌa̱.
\q1 
\v 2 Tsu apulufa a̱ ka̱tsuma̱ ka awana
\q2 ta macigi ma̱ va̱ mi nannai a̱ ka̱tsuma̱ ka n kere.
\q1 
\v 3 Tsu maɗanga ma ruman a̱ ka̱tsuma̱ ka nɗanga n kutsun
\q2 ta macigi ma̱ va̱ mi nannai a̱ ka̱tsuma̱ ko olobo.
\q1 Mi ta̱ a̱ ma̱za̱nga̱ n da̱sa̱ngu a̱ kulu ku ni,
\q2 umaci u ni wi ta̱ n uyoꞋo u kulyaꞋa tsu na n cigai.
\q1 
\v 4 U bankai mu e kefeku ka na i a̱ ka̱ɗiva̱,
\q2 Ucigi u ni urotu u ɗa wa̱ va̱.
\q1 
\v 5 LyaꞋatangu mu n akala a umaci u ma̱biri e uɗekpu,
\q2 Neke mu ma̱kya̱n n soꞋo ka̱ta̱ wuma u va̱ bono,
\q2 adama a na mi ta̱ a̱ kukuwa̱ adama a ucigi.
\q1 
\v 6 Kukiye ku ugula̱ ku ni ki ta̱ ɗaka vu kaci ka̱ va̱,
\q2 kukiye ku usingai ku ni kpamu ku oɓongi mu.
\q1 
\v 7 Nkere n Urushelima,
\q2 yaꞋankai mu uzuwakpani
\q2 n ula a nreꞋe nu nsheun\f + \fr 2:7 \fq n ula a nreꞋe nu nsheun \ft Akucina a̱ ɗa a na a ci yaꞋan a na a ci ciga e ɗeke kula̱ ku Ka̱shile e keteshe ba.\f* n keteshe
\q1 a na ya ku gbandarasa tsu ba
\q2 makyan ma na ci a kupana uyoꞋo.
\q1 
\v 8 Pana, macigi ma̱ va̱
\q2 la̱na̱, a̱yi ɗa na u yawai,
\q1 a kaɗikpangusu a gaɗi va atali,
\q2 e kujeꞋe a gaɗi vu aginda.
\q1 
\v 9 Macigi ma̱ va̱ mi ta̱ tsu mesheun ko maku me mereꞋe.
\q2 La̱na̱, a̱yi ɗa na ɗe kashani uka̱ra̱Ꞌi u mashilya ma̱ tsu,
\q1 a̱ kula̱nuku su n katusu ka̱ kunu,
\q2 a ku inda mu a kakashi ku utsutsu.
\q1 
\v 10 Macigi ma̱ va̱ ma yaꞋan ta̱ kadanshi nu mpa, u danai,
\q2 <<Ɗa̱nga̱, macigi ma̱ va̱ tsu wala,
\q2 vuza vu ugaꞋin vu va̱, tono mu.
\q1 
\v 11 La̱na̱, lyushi i laza ta̱,
\q2 mini ma̱ Ka̱shile ma laza ɗe,
\q2 kpamu ma laza ɗe.
\q1 
\v 12 A̱pa̱lu uta̱ ta̱ aduniya,
\q2 makyan mi ishipa ma yawa ta̱,
\q1 a kupana ma̱shi mo moɗoi
\q2 a̱ ubuta̱ ra̱ka̱ a iɗika i tsu.
\q1 
\v 13 Nɗanga m ma̱biri m matsa ta̱,
\q2 a̱pa̱lu a nɗanga mi itacishi n neke ta̱ ma̱gula̱ni me le.
\q1 ɗa̱nga̱, tsu wala, macigi ma̱ va̱,
\q2 vuza vu ugain vu va̱.>>
\q1 
\v 14 Avu moɗoi ma̱ va̱ a kungu ku kaɓatsu,
\q2 a̱ ubuta̱ u kusheɗeku a kakambu ka katali,
\q1 yotsongu mu a̱shi a̱ nu,
\q2 yaꞋan m pana ka̱la̱ka̱tsu ka̱ nu,
\q1 adama a na ka̱la̱ka̱tsu ka̱ nu ki ta̱ uyoꞋo u kupana,
\q2 a̱shi a̱ nu kpamu i ta̱ n ugaꞋin u ku inda.
\q1 
\v 15 Ka̱na̱ka̱i tsu nsheꞋe n kakamba,
\q2 m muku mu nsheꞋe n kakamba.
\q1 Aza a na i a̱ kula̱nga̱sa̱ ashina a itacishi,
\q2 ashina a itacishi a̱ tsu a na i a̱pa̱lu.
\q1 
\v 16 Macigi ma̱ va̱ vuza vu va̱ ɗa, mpa feu vuza ni ɗa,
\q2 u tsu guɓa ta̱ ushiga u ni a̱ ka̱tsuma̱ ka apulufa.
\q1 
\v 17 Ali kayin a ka asa,
\q2 makyan ma na ubuta̱ wu akanai,
\q1 macigi ma̱ va̱, kpatala,
\q2 vu okpo tsu mesheun,
\q2 ko tsu maku me mereꞋe
\q2 a gaɗi va aginda.
\c 3
\s1 Alatani a vuka vu savu
\q1 
\v 1 N kayin mpa alavu a kajiba ka̱ va̱,
\q2 n la̱nsa̱i vuza na n cigai,
\q2 n la̱nsa̱i ni ama me ene yi ba.
\q1 
\v 2 Mi ta̱ a̱ kuɗa̱nga̱ n ka̱ra̱Ꞌa̱ likuci,
\q2 n tono uye-uye u likuci n asuvu a̱ likuci a,
\q1 mi ta̱ a̱ kula̱nsa̱ vuza na ka̱ɗu ka̱ va̱ ka cigai,
\q2 n la̱nsa̱ yi ta̱ ama me ene yi ba.
\q1 
\v 3 Aza a ku inda likuci a gasai nu mpa
\q2 ele na i a̱ kuka̱ra̱Ꞌa̱ likuci ya.
\q2 <<Me ecei le, yi eneke mu ta̱ vuza na ka̱ɗu ka̱ va̱ ka cigai?>>
\q1 
\v 4 U geshe ba ana n lazai le,
\q2 ɗa me enei vuza na ka̱ɗu ka̱ va̱ ka cigai.
\q1 n ka̱na̱i ni n ka̱sukpa̱ yi u laza ba
\q2 ali n tuka̱i ni a kpaꞋa ka̱ a̱na̱ku a̱ va̱,
\q2 a̱ kunu ku na a̱na̱ku a̱ va̱ a matsai mu.
\q1 
\v 5 A̱ɗa̱ nkere n Urushelima,
\q2 yaꞋankai mu uzuwakpani
\q2 n kula ku nreꞋe nu nsheun,
\q2 aza a ugaꞋin u kinda a aginda.
\q2 Tsu na a tsu kucina n Ka̱shile MalaꞋimili,
\q2 i kucina a na ya ku gbandarasa tsu ba
\q2 makyan ma na ci a kupana uyoꞋo.
\q1 
\v 6 Yayi na lo a̱ ku uta̱ a kakamba ka
\q2 an kogbodolu ka̱ ka̱nga̱,
\q2 n ili i ma̱gula̱ni ma̱ Muru,
\q2 ili i ma̱gula̱ni i na aza a tsulaga a yaꞋin?
\q1 
\v 7 La̱na̱, kakuba ka kuɗika Sulemanu mogono kaꞋa,
\q2 uka̱ra̱Ꞌi n a̱yi osoji amangatatsu a ɗa o kusoku yi,
\q2 osoji a Isaraila a ɗa aza a na a fuɗai kuvon.
\q1 
\v 8 Ra̱ka̱ vu le i ta̱ n otokobi,
\q2 eyevi a̱ vishili a ɗa ka̱u,
\q1 yaba dem n kotokobi ka̱ ni a̱ ma̱kuta̱,
\q2 i ta̱ ufoɓushi adama a uma
\q2 a gbani-gbani a na a̱ tsu ɗa̱nga̱ n kayin.
\q1 
\v 9 Mogono Sulemanu u yaꞋankai ka̱ci ka̱ ni,
\q2 kakuba ka kuɗika mogono,
\q2 ka na u yaꞋin nu nɗanga n Lebano.
\q1 
\v 10 U yaꞋin aburakpatsu a kuɗika kakuba ka n azurufa,
\q2 a palai kucina̱ ku ni n
\q2 kakashi ka azanariya,
\q2 nkere n Urushelima n kalai ni n ucigi.
\q1 
\v 11 Uta̱i a̱ɗa̱ nkere n Sihiyona,
\q2 yi ene mogono Sulemanu u ukai okolokolo,
\q2 a na a̱na̱ku a̱ ni a ukai ni
\q1 a kanna ko yolo ka̱ ni,
\q2 kanna ka na ka̱ɗu ka̱ ni ka yaꞋain ma̱za̱nga̱.
\c 4
\sp Kolobo ka dansai
\q1 
\v 1 Macigi ma̱ va̱ vi ta̱ n tsuloboi,
\q2 a̱shi a̱ nu i ta̱ tsu a̱shi o moɗoi punu upali.
\q2 ka̱nji ka̱ nu ki ta̱ tsu ushiga wu nraɗika
\q1 u na wi a̱ kugida̱la̱ a kusan ku Giliyadu.
\q1 
\v 2 Anga a̱ nu i ta̱ wa̱ri buga̱-buga̱
\q2 tsu ushiga wu nkyon n na a̱ sumba̱i,
\q2 a takpai sararai ra̱ka̱ vu le i ta̱ ugeri,
\q1 yaba dem m gbaɓi vi ni,
\q2 ko vuza wi endeꞋin ba.
\q1 
\v 3 Nla̱ba̱ mu una̱ u nu ushili pa̱za̱za̱
\q2 adanshi vu sura ta̱ ili i shili,
\q2 una̱ u nu ili i maluwa i ɗa,
\q1 o yotsongi nla̱ba̱ mu una̱ u nu,
\q2 nguji n nu a kutasa
\q2 tsu kucina̱ ku umaci u ruman.
\q1 
\v 4 Kuɗeku ku nu ki ta̱ an kumaꞋa
\q2 ku ugaɗi ku Dawuda,
\q2 ku na a maꞋi n tsuloboi,
\q1 idolu yi ta̱ ugeri uka̱ra̱Ꞌi
\q2 e kuɗeku ku nu,
\q2 tsu n nra̱ga̱ ka̱kpa̱n,
\q2 ra̱ka̱ vi le nra̱ga̱ mo ovonshi a ɗa.
\q1 
\v 5 Mani ma̱ nu mi ta̱ a na nreꞋe n re
\q2 a na mpeshe mu nreꞋe,
\q2 a kalina punu apulufa.
\q1 
\v 6 Ali kayin ka asa
\q2 ubuta̱ dem wu akana,
\q1 mi ta a kubana a kusan ka̱ Muru
\q2 n kaginda ki ili i ma̱gula̱ni.
\q1 
\v 7 Vu gaꞋan ta̱ macigi ma̱ va̱,
\q2 ili i gusa̱ wu a ikyamba i nu ba.
\b
\q1 
\v 8 Ta̱wa̱ nu mpa a Lebano, vuka vu savu vu va̱,
\q2 tsu waluka koɓolo a Lebano.
\q1 Gida̱la̱ a̱ kuta̱wa̱ ɗe a kaginda ka Amana,
\q2 ɗe a gaɗi vu Seru, n gaɗi vu Hamonu,
\q1 ɗe e kpenle ki ikawu
\q2 n kaginda ka na a̱kunzu o ci yongo.
\q1 
\v 9 Vu uwa ta̱ a̱ ka̱ɗu ka̱ va̱,
\q2 vutaku vu va̱, vuka vu savu vu va̱,
\q2 n kindi ku a̱shi a̱ nu
\q1 vu uwa ta̱ a̱ ka̱ɗu ka̱ va̱,
\q2 n vudolu vu te vu kuɗeku ku nu.
\q1 
\v 10 N yiɗa̱i n kugisanku n ucigi u nu,
\q2 macigi ma̱ va̱ vuka vu savu vu va̱,
\q1 n yiɗa̱i a kugisanku uyoꞋo wu ucigi u nu
\q2 u na u laꞋi ma̱kya̱n uyoꞋo,
\q2 n yiɗa̱i a kugisanku ili ma̱gula̱ni i nu
\q2 i na i laꞋi ili i ma̱gula̱ni ra̱ka̱ ma̱gula̱ni.
\q1 
\v 11 Nla̱ba̱ mu una̱ u nu n uyoꞋo ci ishigi,
\q2 vuka vu savu vu va̱,
\q1 mani n ishigi yi ta̱ e kelentsu ka̱ nu.
\q2 ma̱gula̱ni mo ntogu n nu
\q2 a na ili ma̱gula̱ni i Lebano.
\q1 
\v 12 Avu kashina kaꞋa ka na a kanzai adama a̱ va̱,
\q2 macigi ma̱ va̱ vuka vu savu vu va̱,
\q2 a̱shi a̱ mini a na a kanzai,
\q2 a̱shi a̱ mini a na a̱ sa̱nka̱i yaba dem.
\q1 
\v 13 Mere ma̱ nkuta̱ n nu kashina ki ta̱ punu,
\q2 tsu kashina ka Adini
\q2 n umaci wu nɗanga u singai,
\q2 ka umaci u ruman mu uyoꞋo
\q2 n ili i ma̱gula̱ni mu uyoꞋo tsa ma̱jigi n nardi,
\q2 
\v 14 Nardi n safaron,
\q2 kalamusu n sinamon,
\q2 n icuꞋu yi nɗanga i na i ci neke ma̱gula̱ni dem,
\q2 m Muru n alosu,
\q2 n ili i ma̱gula̱ni i na i laꞋi m ma̱gula̱ni.
\q1 
\v 15 Avu a̱shi a̱ mini a ɗa a na i e kuneke mini a kashina ka,
\q2 kuɗolu ku na ku ci neke mini ma wuma,
\q2 mana mi e kuyene a Lebano.
\sp Mekere ma yaꞋin kadanshi
\p 
\v 16 Ɗa̱nga̱, wunla̱i wu uɓongaɗi,
\q2 ta̱wa̱ wunla̱i wu uɓonɗakai
\q1 vu uvula̱ kashina ka̱ va̱,
\q2 tsu na ma̱gula̱ni ma̱ kimba̱i a̱ ubuta̱ dem.
\q2 yaꞋan macigi ma̱ va̱ ma̱ ta̱wa̱ a kashina ka̱ ni,
\q2 u lyaꞋa umaci wu nɗanga u na u laꞋi n uyoꞋo.
\c 5
\sp Kolobo ka dansai
\q1 
\v 1 N ta̱wa̱ ta̱ a kashina ka̱ va̱,
\q2 macigi ma̱ va̱ vuka vu savu vu va̱,
\q2 n ɓolongu ta̱ Muru vu va̱ n ili i wali i va̱.
\q1 N lyaꞋa ta̱ kabashi ki ishigi n ishigi i va̱,
\q2 ɗa n soꞋi ma̱kya̱n koɓolo n mani.
\sp A̱ja̱Ꞌa̱ e mekere a dansai
\q1 a̱ɗa̱ na yi a maciganai
\q2 lyaꞋi i soꞋo ali ma maka ɗa̱ n ucigi u ɗa̱.
\s1 Vishipa vu na̱shi
\sp Mekere ma dansai
\q1 
\v 2 N lata ta̱ ama ka̱ɗu ka̱ va̱ ki ta̱ wuma.
\q2 Zuwa atsuvu, macigi ma̱ va̱ mi ta̱ a̱ kuka̱la̱ utsutsu.
\sp Kolobo ka dansai
\q1 <<Ɓa̱yuwa̱ ka̱ mu kamana ka̱ va̱,
\q2 macigi ma̱ va̱, moɗoi ma̱ va̱,
\q2 vuza babu unushi u va̱.
\q1 Kaci ka̱ va̱ ka̱ ta̱na̱ ta̱ n ciza,
\q2 ka̱nji ka̱ va̱ ka̱ ta̱na̱ m mele.>>
\sp Mekere ma dansai
\q1 
\v 3 N foɗo ta̱ ɗe akashi a̱ va̱,
\q2 ka̱ta̱ n doku n uka a ɗa?
\q1 N saꞋa ta̱ ene a̱ va̱,
\q2 ka̱ta̱ n doku n la̱nga̱sa̱ a ɗa?
\q1 
\v 4 Macigi ma̱ va̱ ma uwaka ta̱
\q2 n ekiye a̱ ni a̱ katusu ku utsutsu,
\q2 ɗa ka̱ɗu ka̱ va̱ ka̱ ka̱na̱i mali ma̱ ni.
\q1 
\v 5 Ɗa n ɗa̱nga̱i adama a na m ɓa̱yuwa̱ka̱ macigi ma̱ va̱,
\q2 ekiye a̱ va̱ cepepe m maniꞋin ma Muru,
\q1 a̱jivu a̱ va̱ a̱ kuɗa̱kpa̱ m maniꞋin ma,
\q2 a na n ka̱na̱i a̱ka̱na̱tsu a utsutsu a.
\q1 
\v 6 M ɓa̱yuwa̱ka̱i macigi ma̱ va̱ utsutsu,
\q2 ama macigi ma̱ va̱ ma laza ɗe.
\q1 Ɗa ka̱ɗu ka̱ va̱ ka̱ na̱mgba̱i
\q2 adama a na u laza ta̱.
\q1 n la̱nsa̱i ni ama me ene yi ba.
\q2 n ka̱na̱i kuɗekushe yi ama wu ushuku ba.
\q1 
\v 7 Aza a kindi a gasai nu mpa,
\q2 a makyan mana i a̱ kubana n obonoi a̱ likuci,
\q1 ɗa a lapai mu, a yaꞋankai mu usa̱n,
\q2 ɗa a isai mu kalaba,
\q2 aza a na i a kinda a mashilya ma nanlo.
\q1 
\v 8 A̱ɗa̱ n kere n Urushelima, kucinakai mu,
\q2 ɗa baci yenei macigi ma̱ va̱,
\q1 yiɗa̱i ya ku dana yi?
\q2 Danai ni n lima̱ ta̱ adama ucigi u ni.
\sp A̱ja̱Ꞌa̱ e mekere a dansai
\q1 
\v 9 Avu na vu laꞋi n tsuloboi a̱ ka̱tsuma̱ ka̱ a̱ma̱ci,
\q2 Yiɗa̱i i zuwai ɗa macigi ma̱ nu ma laꞋi yaba dem?
\q1 Adama a̱ n yiɗa̱i vu danai tsu,
\q2 tsu dana yi uteku tsu na vi a kupana?
\sp Mekere ma dansai
\q1 
\v 10 Macigi ma̱ va̱ mi ta̱ n tsuloboi
\q2 m ma̱ta̱na̱ n katsura kpamu,
\q2 n atakaci a ɗa a̱ kuciya̱ vicuꞋu vu ni vu te
\q2 a̱ ka̱tsuma̱ ka uma a̱kpa̱n kupa (10,000).
\q1 
\v 11 Ka̱nji ka kaci ka̱ ni a kutasa tsu azanariya,
\q2 ka̱nji ka̱ ni ulima̱ a kutasa tsu kagawun.
\q1 
\v 12 A̱shi a̱ ni wa̱ri pu tsu mani
\q1 tsu moɗoi ma̱ a̱ri,
\q2 a̱ ka̱kina̱ ko kuɗolu.
\q1 
\v 13 Aguji a̱ ni a na kashina ki ili wali,
\q2 a ku utuka̱ n ma̱gula̱ni.
\q1 Nla̱ba̱ mu una̱ n ni, mi ta̱ tsu a̱pa̱lu
\q2 a̱ kuɗa̱kpa̱ maniꞋin ma̱ Muru.
\q1 
\v 14 Ekiye a̱ ni i ta̱ tsa alangu azanariya
\q2 a na a ukai atali a singai.
\q1 ikyamba i ni yi ta̱ ugbori an kanga ka kagiwa,
\q2 ka na a kalai n atali a Safaya.
\q1 
\v 15 Ene a̱ ni ita̱ a na ashamkpatsu,
\q2 atali a alabasata,
\q2 a na a̱ shikpa̱i e enle azanari.
\q1 Iyoci i ni yi ta̱ an Lebano,
\q2 vu na vu laꞋi n tsuloboi,
\q2 tsu maɗanga ma Sida.
\q1 
\v 16 Una̱ uni wi ta̱ n uyoꞋo,
\q2 ili i ni dem yi ta̱ n ugaꞋin.
\q1 ta macigi ma̱ va̱, ka̱ja̱Ꞌa̱ ka̱ va̱ ki nannai
\q2 a̱ɗa̱ nkere n Urishelima.
\c 6
\sp A̱ja̱Ꞌa̱ e mekere a dansai
\q1 
\v 1 Te ɗai Macigi ma̱ nu ma banai,
\q2 avu mekere ma na ma laꞋi n
\q2 tsuloboi a̱ ka̱tsuma̱ ka̱ a̱ma̱ci?
\q1 Uye wene u ɗai macigi ma̱ nu mo tonoi,
\q2 ciya̱ tsu ɓa̱nka̱ wu kula̱nsa̱ yi.
\sp Mekere ma dansai
\q1 
\v 2 Macigi ma̱ va̱ ma gida̱la̱ ta̱ a kubana a kashina ka̱ ni,
\q2 a̱ ubuta̱ u na ili i wali yi,
\q1 a kaguɓa punu a kashina ka
\q2 kpamu o kuɓolongu a̱pa̱lu.
\q1 
\v 3 Mpa macigi maꞋa u macigi ma̱ va̱,
\q2 macigi ma̱ va̱ kpamu ma̱ va̱ maꞋa,
\q2 wi ta̱ a kaguɓa ka ushiga u ni punu apulufa.
\s1 Vishipa vu tawun
\sp Kolobo ka dansai
\q1 
\v 4 Avu vu gaꞋan ta̱ tsu likuci i Tiriza, macigi ma̱ va̱,
\q2 vu gaꞋan ta̱ tsu Urushelima,
\q2 n tsuloboi tsu ka̱tsura̱ ko osoji
\q2 a na i uɓa̱ni n urotu u kakashi.
\q1 
\v 5 Takpa a̱shi a̱ nu wa̱ va̱,
\q2 i ta̱ a̱ ku ripula̱sa̱ mu.
\q1 Ka̱nji ka̱ nu ki ta̱ an ushiga wu nraɗika
\q2 n na mi a̱ kugida̱la̱ aginda a Giliyadu.
\q1 
\v 6 Anga a̱ nu i ta̱ tsu ushiga wu nlala
\q2 n na mu uta̱i a̱ ubuta̱ u na
\q2 a̱ sumba̱i le a kugaɗukpa.
\q1 Yaba dem n gbaɓi vi ni,
\q2 babu vu vuza te vu le na wi endeꞋin.
\q1 
\v 7 Nguji n nu mi ta̱ a kutasa
\q2 tsu kucina̱ ku umaci u Ruman.
\q1 
\v 8 Ko ɗa baci Egbere amangatatsu i ɗe,
\q2 n a̱ma̱ci a pulai amanga̱na̱shi,
\q2 nu nkere n na n yeve ali ba,
\q2 aza a na a laꞋi kukece,
\q1 
\v 9 a̱yi ɗa koci mi a kuciga
\q1 wi ta̱ n ugaꞋin tsu moɗoi,
\q2 a̱yi endeꞋin a̱ ubuta̱ wa̱ a̱na̱ku a̱ ni,
\q2 maku mu uleshi maꞋa wa̱ a̱na̱ku a̱ ni.
\q1 Nkere mene yi baci ka̱ta̱ a dana, a̱yi vuza vu una̱singai ɗa,
\q2 anan Sangina n a̱ma̱ci a pulai a tsu cikpa yi ta̱.
\sp A̱ja̱Ꞌa̱ e mekere a dansai
\q1 
\v 10 Yayi a̱ kuɓa̱tsa̱ na ɗe an kanna,
\q2 ugaꞋin an wotoi, a kutasa an kanna,
\q2 n tsuloboi tsa azangata a na i ugeri?
\sp Mekere ma dansai
\p 
\v 11 N gida̱la̱ ta̱ a kubana a kashina ka nɗanga n alumo
\q2 adama a na me ene nɗanga n na
\q2 m ɓatsai a̱ ka̱ɗa̱ka̱i ka,
\q1 adama a na me ene
\q2 ko nɗanga mi itacishi n matsa ta̱,
\q2 ko ruman u yaꞋan ta̱ a̱pa̱lu.
\q1 
\v 12 Kafu n zuwaka,
\q2 a̱shi a wuya a zuwai mu,
\q2 me enei ka̱ci ka̱ va̱ a̱ ida̱shi,
\q2 koɓolo m mogono ekeke vu odoku vi ni.
\sp A̱ja̱Ꞌa̱ e mekere ma dansai
\p 
\v 13 Bono, bono, avu mekere ma aza a Shulamiya,
\q2 bono, bono adama a na ci inda wu.
\sp Mekere ma dansai
\q1 Adama a̱ n yiɗa̱i yi a kinda vuza vu Shulamiya,
\q2 a na wi e kujeꞋe tsu Mahanayim?
\c 7
\sp Kolobo ka dansai
\q1 
\v 1 Yiɗa̱i a ku gisanku n ugaꞋin
\q2 u ene a̱ nu punu a ataka,
\q2 avu mekere mo mogono,
\q1 tsu na a yaꞋin nkuta̱ n nu
\q2 tsa atali a singai
\q2 ulinga we ekiye u vuza na u fuɗai ɗa.
\q1 
\v 2 Koyoɗi ka̱ nu tsu mokokoꞋo,
\q2 ma na ma tsu namba ma̱kya̱n
\q2 mu usatari n icita ba.
\q1 kukyun ku nu ki ta̱ tsu ma̱ta̱ka̱ ma alkama
\q2 ma na apulufa a̱ ka̱ra̱Ꞌi.
\q1 
\v 3 Mani ma̱ nu mi ta̱ tsu muku mu nreꞋe n re,
\q2 mpeshe mu nreꞋe.
\q1 
\v 4 Kuɗeku ku nu ki ta̱ tsu kumaꞋa
\q2 ku na a yaꞋin n kanga ka kagiwa.
\q1 A̱shi a̱ nu tsu nɗolu a Heshibon,
\q2 ɗevu n utsutsu u Batu-rabimu.
\q1 Vunu vu nu tsu kumaꞋa ku ugaɗi ku Lebano,
\q2 ku na ki a ku inda Dimaska.
\q1 
\v 5 Kaci ka̱ nu ka yaꞋanka wu ta̱
\q2 okolokolo tsu katali ka Kamelu.
\q1 Ka̱nji ka̱ nu ki ta̱ a kutasa ulima̱,
\q2 ka tsu ɗika ta̱ asuvu a̱ va̱ mogono.
\q1 
\v 6 Macigi ma̱ va̱ vi ta̱ n tsuloboi,
\q2 kpamu vu tsu zuwa mu ta̱ n pana uyoꞋo.
\q1 
\v 7 Kashani ka̱ nu ki ta̱ tsu mashuwa,
\q2 kpamu mani ma̱ nu ma yaꞋan ta̱
\q2 tsu umaci wu nɗanga.
\q1 
\v 8 N danai, <<YaꞋan n kumba maɗanga,
\q2 ka̱ta̱ n ka̱na̱ umaci u ni.>>
\q1 ka̱sukpa̱ mani ma̱ nu mo okpo tsu umaci wi itacishi ,
\q2 ma̱gula̱ni ma ayinviki a̱ nu tsu umaci u ruman,
\q2 
\v 9 kpamu una̱ u nu wi ta̱ tsu ma̱kya̱n
\q2 ma na ma laꞋi nu ugain.
\sp Mekere ma dansai
\q1 yaꞋan ma̱kya̱n ma laza ba̱ri,
\q2 a kubana ubuta̱ u macigi ma̱ va̱,
\q2 ma laza sawu a ka̱tsuma̱ ka nla̱ba̱ n anga.
\q1 
\v 10 Mpa vuza̱ macigi va̱ ɗa,
\q2 kpamu mali ma̱ ni adama a̱ va̱ a ɗa.
\q1 
\v 11 Ta̱wa̱, macigi ma̱ va̱, yaꞋan tsu bana a kakamba,
\q2 yaꞋan tsu asa a̱ likuci i waꞋa.
\q1 
\v 12 YaꞋan tsu bana a kashina ki itacishi nu usana,
\q2 adama a na ce ene ko
\q2 nɗanga mi itacishi m matsa ta̱ ɗe,
\q1 ko a̱pa̱lu ele o ɓoso ta̱ ɗe,
\q2 ko nɗanga n ruman m pa̱lukpa̱ ta̱ ɗe,
\q2 ta ɗe n kuyotsongu wu ucigi u va̱.
\q1 
\v 13 Vi ta̱ a ku tsumgba ma̱gula̱ni mi ica̱Ꞌa̱shi
\q2 m ma̱gula̱ni ma umaci wu nɗanga wu uyoꞋo.
\q1 cau n ku gogo na macigi ma̱ va̱.
\c 8
\sp mekere ma dansai
\q1 
\v 1 Ishi baci avu taku vu va̱ ɗa,
\q2 vuza na wu apai mani ma̱ a̱na̱ku a̱va̱
\q1 ɗa baci n cinai nu pulai,
\q2 ɗa mo oɓongi nu,
\q2 ko vuza wi a kugoyo mu ba.
\q1 
\v 2 Mi ishi a kuɗika wu,
\q2 n tuka̱ a kpaꞋa ka̱ a̱na̱ku a̱ va̱
\q2 a̱ yi na ugbari mu.
\q1 Mi shi e kuneke wu ma̱kya̱n
\q2 usatari n ili wali vu soꞋo,
\q2 ma̱kya̱n mu umaci u ruman u va̱.
\q1 
\v 3 Kukiye ku ugula̱ ku ni ki ta̱
\q2 ɗaka vu kaci ka̱ va̱,
\q2 kukiye ku usingai ku ni
\q2 tamkpamu, wo oɓongi nu mpa.
\q1 
\v 4 A̱ɗa̱ n kere n Urushelima
\q2 yaꞋankai mu uzuwakpani.
\q2 yi a kugbandarasa tsu a makyan
\q2 ma na ci a kupana uyoꞋo ba.
\sp A̱ja̱Ꞌa̱ a̱ e mekere a dansai
\q1 
\v 5 Yayi na ɗe, a̱ ku uta̱ a kakamba,
\q2 u tsubaki a kavangatsu ka Macigi ma̱ ni?
\sp Mekere ma dansai
\q1 A ɗaka vu maɗanga ma ruman
\q2 ɗa n jimgbasai nu,
\q2 a̱ ubuta̱ u na a matsai nu,
\q2 a ubuta̱ u na a̱na̱ku a̱ nu a matsai nu.
\q1 
\v 6 Zuwa mu mo okpo ka̱ta̱mba̱ri a̱ ka̱ɗu ka̱ nu,
\q2 mokpo tsu makawani
\q2 ma ka̱ta̱mba̱ri e kukiye ku nu,
\q1 adama a na utsura u va̱,
\q2 wi ta̱ tsu ucigi wu ukpa̱,
\q2 utsura u cisheꞋe tsu ucigi
\q2 kowanai ɗa tsu kasaun.
\q1 KayaꞋa ku ucigi ki ta̱ tsu kayaꞋa ka akina,
\q2 tsa akina a na i a̱ kukula̱ n usuɗukpi.
\q1 
\v 7 Mini ma na ma ayai,
\q2 mi a kufuɗa ku una akina a ucigi a ba,
\q1 nɗolu tukpa m mini
\q2 n kufuɗa kupura̱ngu ucigi wa ba.
\q1 Ɗa baci vuza u nekei udukuyan u ni ra̱ka̱,
\q2 adama a na u tsula ucigi wa,
\q2 i ta̱ o ku zoꞋoso yi o goyo yi.
\sp A̱ja̱Ꞌa̱ a̱ e mekere a dansai
\q1 
\v 8 Ci ta̱ n vangu vu tsu,
\q2 a̱yi na ka̱ta̱ u muɗa̱i mani ba.
\q1 Yiɗa̱i tsu kuyaꞋan adama a vangu vu tsu,
\q2 ɗa baci a̱ ta̱wa̱i kuyaꞋan
\q2 ukuna u mazama ma̱ ni?
\q1 
\v 9 Ishi baci a dana a̱yi mashilya maꞋa,
\q2 ci ishi a kumaꞋaka yi mashilya mu ugaɗi ma azurufa.
\q1 Ishi baci a dana a̱yi utsutsu u ɗa,
\q2 ci ishi a kukanza yi nu nɗanga n Sida.
\sp Mekere ma dansai
\q1 
\v 10 Mpa mashilya maꞋa,
\q2 mani ma̱ va̱ maꞋa imaꞋashi yu ugaɗi ya.
\q1 A̱ ubuta̱ u Macigi ma̱ va̱,
\q2 mo okpo yi ta̱ ili i kutuka̱ m ma̱ta̱na̱.
\sp Kolobo kadansai
\q1 
\v 11 Sulemanu wi ta̱ n kashina ki itacishi,
\q2 a iɗika i Balu-hamonu.
\q1 U nekei kaꞋa ekiye aza a na a kucimba kaꞋa,
\q1 yaba dem wi ta̱ a̱ kutuka̱ n azurufa ka̱kpa̱n (1,000),
\q2 a̱ ka̱tsuma̱ ki ikebe yu uciyi i kashina i ni.
\q1 
\v 12 Ama mpa mi ta̱ n kashina ki itacishi ka̱ va̱,
\q2 avu Sulemanu mi ta̱ e kuneke wu ikebe azurufa ka̱kpa̱n (1,000).
\q1 mi ta̱ a kuneke,
\q2 aza a ulinga azurufa amangatawenre e re (200).
\sp Kolobo kadansai
\q1 
\v 13 Avu Macigi ma̱ va̱,
\q2 avu na vi a ida̱shi punu a kashina ka,
\q2 avu na a̱ja̱Ꞌa̱ a̱ va̱ i a̱ kula̱na̱ wu,
\q2 yaꞋan m pana ka̱la̱ka̱tsu ka̱ nu.
\sp Mekere ma dansai
\q1 
\v 14 Macigi ma̱ va̱,
\q2 ta̱wa̱ wa̱ va̱ gogoꞋo tsu mesheun,
\q1 tsu maku me mereꞋe
\q2 a kubana ubuta̱ wa aginda a ili ma̱gula̱ni.
