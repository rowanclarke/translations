\p 
\v 13 \nd \w Yavé|strong="H3068"\w*\nd* amonestaba \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* y \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w por|strong="H1870"\w* \w medio|strong="H3027"\w* \w de|strong="H7451"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w profetas|strong="H5030"\w* y \w de|strong="H7451"\w* \w todo|strong="H3605"\w* \w vidente|strong="H2374"\w*: \wj Regresen \w de|strong="H7451"\w* sus \w malos|strong="H7451"\w* \w caminos|strong="H1870"\w* y \w guarden|strong="H8104"\w* mis \w Mandamientos|strong="H4687"\w* y mis Preceptos, según \w toda|strong="H3605"\w* \w la|strong="H8104"\w* \w Ley|strong="H8451"\w* \w que|strong="H3605"\w* \w Yo|strong="H6680"\w* prescribí \w a|strong="H3068"\w* sus antepasados y \w les|strong="H6680"\w* \w envié|strong="H7971"\w* \w por|strong="H1870"\w* \w medio|strong="H3027"\w* \w de|strong="H7451"\w* mis esclavos \w profetas|strong="H5030"\w*.\wj*
