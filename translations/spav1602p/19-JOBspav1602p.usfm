\v 23 He \w aquí|strong="H2005"\w* \w que|strong="H3588"\w* \w él|strong="H3588"\w* tomará \w el|strong="H3588"\w* \w río|strong="H5104"\w* \w sin|strong="H3808"\w* \w inmutarse|strong="H2648"\w*: \w y|strong="H3588"\w* confíase \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w Jordán|strong="H3383"\w* \w pasará|strong="H1518"\w* \w por|strong="H3588"\w* \w su|strong="H3588"\w* \w boca|strong="H6310"\w*.
