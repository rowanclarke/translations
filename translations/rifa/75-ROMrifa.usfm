\id ROM
\h إِرُومَانِييّنْ
\toc1 إِرُومَانِييّنْ
\toc2 إِرُومَانِييّنْ
\toc3 رُوم.
\mt1 إِرُومَانِييّنْ
\c 1
\s1 ثَامزْوَارُوثْ
\m 
\v 1 بُولُوسْ، أَمْسخَّارْ ن يَاسُوع لْمَاسِيحْ، \add رَّاسُولْ\add* إِتّْوَاڒَاغَانْ ذ إِتّْوَاسكّنْ، إِتّْوَاحُوزنْ إِ لْ-إِنْجِيلْ ن أَربِّي \x ◘ \xo 1:‏1 \xt ڒخ. 9‏:‏15؛ 13‏:‏2؛ ڭال. 1‏:‏15. \x*
\v 2 - \add لْ-إِنْجِيلْ\add* نِّي إِزَّارْ إِوَاعْذْ زَّايسْ زڭْ ؤُموَارُو س إِنَابِييّنْ نّسْ ذِي ثِيرَا إِقدّْسنْ - \x ◘ \xo 1:‏2 \xt أَمز. 3‏:‏15؛ 22‏:‏18؛ 26‏:‏4؛ 49‏:‏10؛ أَعَوذ. 18‏:‏15؛ 2 صم. 7‏:‏12؛ إِزهد. 132‏:‏11؛ إِشا. 4‏:‏2؛ 7‏:‏14؛ 9‏:‏5؛ 40‏:‏10؛ إِرْم. 23‏:‏5؛ 33‏:‏14؛ حِز. 34‏:‏23؛ 37‏:‏24؛ دَان. 9‏:‏24؛ مِيخَا 7‏:‏20. \x*
\v 3 خْ مِّيسْ، ونِّي د-إِتّْوَاخڒْقنْ زِي جِّيهثْ ن ويْسُومْ زِي زَّارِيعثْ ن ثَادَّارْثْ ن ذَاوُوذْ، \x ◘ \xo 1:‏3 \xt مت. 1‏:‏1؛ لك. 1‏:‏32؛ ڒخ. 2‏:‏30؛ 13‏:‏23؛ 2 تِيم. 2‏:‏8. \x*
\v 4 \add مَاشَا\add* زِي جِّيهثْ ن جّهْذْ ذ أَرُّوحْ إِقدّْسنْ إِ د-إِسّْنكَّارنْ يَاسُوع لْمَاسِيحْ، سِيذِيثْنغْ، زِي ثَادَّارْثْ ن إِمتِّيننْ، أَقَا إِتّْوَاسَّارْڭبْ ذ مِّيسْ ن أَربِّي. \x ◘ \xo 1:‏4 \xt إِشا. 9‏:‏5؛ 44‏:‏6؛ 54‏:‏5؛ يُوح. 2‏:‏19؛ رُوم. 9‏:‏5؛ 1 يُوح. 5‏:‏20. \x*
\v 5 مَاغَارْ زَّايسْ إِ نطّفْ أَرْضَا ؤُ زَّايسْ إِ نتّْوَاڒَاغَا ذ رُّوسُولْ جَارْ مَارَّا ڒڭْنُوسْ حِيمَا أَذْ طَّاعنْ \add ڒڭْنُوسْ\add* إِ لْ-إِيمَانْ ذڭْ يِيسمْ نّسْ،
\v 6 مَاغَارْ ؤُڒَا ذ كنِّيوْ ثتّْوَاڒَاغَامْ \add زِي ڒڭْنُوسْ\add* س يَاسُوع لْمَاسِيحْ.
\v 7 غَارْ مَارَّا إِنِّي إِدْجَانْ ذِي رُومَا، \add أَ\add* إِمْعِيزّنْ ن أَربِّي، إِنِّي إِتّْوَاڒَاغَانْ ذ إِنِّي ذ إِمْقدَّاسنْ: أَرْضَا ذ ڒهْنَا أَذْ كِيذْومْ إِڒِينْ زِي أَربِّي بَابَاثْنغْ ؤُ زِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 1:‏7 \xt 1 كُور. 1‏:‏2؛ أَفا. 1‏:‏1. \x*
\b
\m 
\v 8 أَمزْوَارْ تّْشكَّارغْ أَربِّي إِنُو س يَاسُوع لْمَاسِيحْ زِي جِّيهثْ نْومْ مَارَّا، مِينْزِي لْ-إِيمَانْ نْومْ أَقَا سْڒِينْ خَاسْ ذِي دُّونشْثْ مَارَّا.
\v 9 مَاغَارْ أَربِّي، ونِّيعبّْذغْ ذِي أَرُّوحْ ذِي لْ-إِنْجِيلْ ن مِّيسْ، إِشْهذْ خَافِي أَقَا نشّْ تِّيذَارغْ كنِّيوْ ڒبْذَا ذِي ثْژَادْجِيثِينْ إِنُو. \x ◘ \xo 1:‏9 \xt رُوم. 9‏:‏1؛ 2 كُور. 1‏:‏23؛ 11‏:‏31؛ ڭال. 1‏:‏20؛ فِيل. 1‏:‏8؛ 1 تس. 2‏:‏5؛ 2 تِيم. 1‏:‏3. \x*
\v 10 تّْژَادْجِيغْ أَذْ أَيِي ثتّْوَارْزمْ زِي ڒخُّو ذ ثْسَاونْثْ إِشْثْ ن ثوَّارْثْ س أَرَّايْ ن أَربِّي، مَاحنْذْ أَذْ غَارْومْ د-أَسغْ. \x ◘ \xo 1:‏10 \xt رُوم. 15‏:‏23، 32. \x*
\v 11 مِينْزِي وحّْشغْ أَذْ كنِّيوْ ژَترغْ ؤُ أَذْ أَومْ وْشغْ شَا ن ثْموْشَا ن أَرُّوحْ، حِيمَا أَذْ ذَايسْ ثتّْوَاسّْمثْنمْ. \x ◘ \xo 1:‏11 \xt رُوم. 15‏:‏29؛ 1 تس. 3‏:‏10. \x*
\v 12 أَذْ نتّْوَاسّْفوّجْ جْمِيعْ س لْ-إِيمَانْ نْومْ ذ ونِّي إِنُو.
\v 13 مَاشَا خْسغْ، \add أَ\add* أَيْثْمَا، أَذْ ثسّْنمْ بلِّي أَطَّاسْ ن إِمُورنْ ڭِّيغْ أَذْ غَارْومْ د-أَسغْ، \add مَاشَا\add* أَڒْ أَسّْ-أَ تّْوَامنْعغْ، حِيمَا أَذْ غَارِي ثِيڒِي ڒْغِيدْجثْ ذَايْومْ عَاوذْ، أَمْ مَامّشْ ذِي ڒڭْنُوسْ نّغْنِي، \x ◘ \xo 1:‏13 \xt 1 تس. 2‏:‏18. \x*
\v 14 \add مَاغَارْ\add* نشّْ ذ بُو-ؤُمَارْوَاسْ مَاحنْذْ أَذْ بَارّْحغْ \add س لْ-إِنْجِيلْ\add* إِ إِيُونَانِييّنْ ؤُ إِ إِبَارْبَارِييّنْ، إِ أَيْثْ ن ثِيغِيثْ ؤُ إِ إِبُوهَاڒِييّنْ، إِ مَارَّا إِوْذَانْ. \x ◘ \xo 1:‏14 \xt 1 كُور. 9‏:‏16. \x*
\v 15 أَمُّو إِ تّْوَاجبْذغْ مَاحنْذْ أَذْ بَارّْحغْ س ڒخْبَارْ أَصبْحَانْ ؤُڒَا إِ كنِّيوْ إِ يدْجَانْ ذِي رُومَا.
\v 16 مِينْزِي وَارْ تّْسضْحِيغْ شَا س لْ-إِنْجِيلْ، مِينْزِي نتَّا ذ جّهْذْ ن أَربِّي إِ ثُوذَارْثْ إِ مَارَّا وِي يُومْننْ، \add إِ يِينِّي يُومْننْ\add* زڭْ وُوذَاينْ غَارْ ؤُمزْوَارْ، ؤُشَا \add خنِّي عَاوذْ إِ يِينِّي\add* زڭْ إِرَامِييّنْ. \x ◘ \xo 1:‏16 \xt إِزهد. 40‏:‏10؛ 1 كُور. 1‏:‏18؛ 15‏:‏2؛ 2 تِيم. 1‏:‏8. \x*
\v 17 مِينْزِي ثَاسڭْذَا ن أَربِّي أَقَا ثْبَانْ ذَايسْ \add ذِي لْ-إِنْجِيلْ\add* زِي لْ-إِيمَانْ غَارْ لْ-إِيمَانْ، أَمْ مَامّشْ ثُورَا:
\b
\m \qt ’أَمْسڭَّاذْ س لْ-إِيمَانْ أَذْ إِدَّارْ.‘\qt* \x ◘ \xo 1:‏17 \xt حَاب. 2‏:‏4؛ يُوح. 3‏:‏36؛ رُوم. 3‏:‏21؛ ڭال. 3‏:‏11؛ فِيل. 3‏:‏9؛ عبر. 10‏:‏38. \x*
\b
\s1 لْغَاضَابْ ن أَربِّي
\m 
\v 18 مِينْزِي أَغْضَابْ ن أَربِّي إِتّْبَانْ-د زڭْ ؤُجنَّا خْ مَارَّا ڒْمُوعْصِييّثْ ذ ثُوعفّْنَا ن إِوْذَانْ إِنِّي إِسّْذُورُّوينْ ثِيذتّْ س ڒْمُوعْصِييّثْ،
\v 19 مِينْزِي ثُوسّْنَا ن أَربِّي إِتّْبَانْ ذَايْسنْ، مِينْزِي أَربِّي أَقَا إِسّْشنْ أَسنْ ث-إِ-د. \x ◘ \xo 1:‏19 \xt ڒخ. 14‏:‏17. \x*
\v 20 مِينْزِي مِينْ إِنُّوفَّارنْ ن أَربِّي، أَقَا إِتّْوَاژَارْ س ڒعْقڒْ س يِينِّي زَّايسْ د-إِتّْوَاخڒْقنْ زڭْ وَامِي ثتّْوَاڭّْ دُّونشْثْ، أَمْ جّهْذْ نّسْ ن ڒبْذَا، أَمْ ثِيفْرَاسْ نّسْ ن أَربِّي، أَڒَامِي نِيثْنِي وَارْ غَارْسنْ بُو سْمَاحثْ. \x ◘ \xo 1:‏20 \xt إِزهد. 19‏:‏2. \x*
\v 21 مِينْزِي، ؤُمِي سّْننْ أَربِّي، وَارْ ث سّْعُودْجنْ نِيغْ وَارْ ث شكَّارنْ أَمْ أَربِّي، مَاشَا ذوْڒنْ بطّْڒنْ ذڭْ إِخَارِيصّنْ نْسنْ ؤُشَا ؤُڒْ نْسنْ إِبَارْشنْ، أَڒَامِي إِذْوڒْ بْڒَاعقْڒْ. \x ◘ \xo 1:‏21 \xt أَعَوذ. 28‏:‏28 \x*
\v 22 ؤُمِي حسّْبنْ إِخفْ نْسنْ ذ إِمِيغِيسنْ، ذوْڒنْ ذ إِفْغَاڒْ،
\v 23 بدّْڒنْ أَعُودْجِي ن أَربِّي إِ وَارْ إِفنِّينْ س شَا ذڭْ وَارْوَاسْ ن صِّيفثْ ن بْنَاذمْ إِفنَّانْ، ذڭْ وَارْوَاسْ ن إِجْضَاضْ، ن \add إِمُودَّارنْ\add* س أَربْعَا ن إِضَارنْ ؤُ ن \add إِمُودَّارنْ\add* نِّي إِتّْبُوعنْ خْ ثمُّورْثْ. \f ◼ \fr 1:‏23 \ft \bd ’إِمُودَّارنْ‘\bd* - نِيغْ ’لْحَايَاوَانَاثْ‘.\f*  \x ◘ \xo 1:‏23 \xt 2 إِج. 17‏:‏29. \x*
\m 
\v 24 \bd س ؤُينِّي\bd* إِسلّمْ إِ-ثنْ أَربِّي غَارْ نّشْوَاثْ إِخمْجنْ ن وُوڒَاونْ نْسنْ حِيمَا أَذْ سّْفضْحنْ أَرِّيمَاثْ نْسنْ جَارْ أَسنْ.
\v 25 أَقَا نِيثْنِي بدّْڒنْ ثِيذتّْ ن أَربِّي س ؤُخَارِّيقْ،عبْذنْ ؤُ سخَّارنْ إِ مِينْ د-إِتّْوَاخڒْقنْ سنّجْ إِ ونِّي د-إِخڒْقنْ كُوڒْشِي، ونِّي ؤُمِي غَارْ إِدْجَا \add مَارَّا\add* أَسمْغَارْ ذ \add مَارَّا\add* لْبَارَاكَاثْ إِ ڒبْذَا قَاعْ. أَمِينْ.
\b
\m 
\v 26 \bd س ؤُينِّي\bd* إِسلّمْ إِ-ثنْ أَربِّي غَارْ شّهْوَاثْ إِنْفضْحنْ، مِينْزِي ؤُڒَا ذ ثِيمْغَارِينْ نْسنْ بدّْڒنْثْ أَبْرِيذْ ن طّْبِيعثْ، تّْنُومَانْثْ إِ مِينْ وَارْ إِدْجِينْ ذ طّْبِيعثْ. \x ◘ \xo 1:‏26 \xt لَاوِي 18‏:‏22، 23. \x*
\v 27 أَمنِّي إِرْيَازنْ عَاوذْ جِّينْ ثَامُونْثْ عْلَاحْسَابْ طّْبِيعثْ أَكْ-ذ ثمْغَارِينْ، ذعْقنْ س نّشْوَاثْ أَكْ-ذ وَايَاوْيَا: إِرْيَازنْ إِ إِتّڭّنْ ڒفْضِيحثْ أَكْ-ذ يرْيَازنْ ؤُشَا قبّْڒنْ ذڭْ إِخفْ نْسنْ ڒْمُونثْ إِ إِسْذَاهدْجنْ إِ ؤُودَّارْ نْسنْ.
\v 28 مِينْزِي وَارْ خْسنْ أَذْ كّْسنْ أَوَاڒْ مَاحنْذْ أَذْ سّْننْ أَربِّي، إِسلّمْ إِ-ثنْ أَربِّي غَارْ ڒعْقڒْ وَارْ إِسكّْوِينْ حِيمَا أَذْ ڭّنْ مِينْ وَارْ إِعدّْڒنْ.
\v 29 نِيثْنِيعمَّارنْ س عْڒَامْ كُوڒْ ڒْمُوعْصِييّثْ، س فَارْقْ-شّْغڒْ ذ ثَارْزُوڭِي ذ ثُوعفّْنَا ذ طّْمعْ، س ڒحْسذْ ذ ونْغَايْ ذ ؤُمنْغِي ذ ثحْرَايْمشْثْ ذ إِنْوَاينْ إِعفّْننْ.
\v 30 \add نِيثْنِي\add* سَّاوَاڒنْ س ڒْغَارْ، تّْشقَّافنْ، شَارّْهنْ أَربِّي، \add نِيثْنِي\add* ذ إِمغْصَابنْ ذ إِمْعفَّارنْ ذ أَيْثْ ن بُو-ؤُقمُّومْ ذ إِمسُوفّْغنْ ن ثُوعفّْنَا، وَارْ غَارْسنْ بُو ڒْعْقڒْ، \add نِيثْنِي\add* وَارْ طِّيعنْ إِ لْوَالِيذِينْ نْسنْ،
\v 31 وَارْ ذَايْسنْ \add ؤُڒْ\add* إِمْثنْ، وَارْ ذَايْسنْ ثَايْرِي ذ وصْڒَاحْ ؤُڒَا ذ أَرّحْمثْ.
\v 32 وَاخَّا نِيثْنِي سّْننْ ڒْحُوكْمْ ن أَربِّي - أَقَا إِنِّي إِتّڭّنْ أَيَا سْذَاهدْجنْ ڒْموْثْ - نِيثْنِي وَارْ تّڭّنْ \add مَارَّا\add* مَانْ أَيَا وَاهَا، مَاشَا أَرطَّانْ عَاوذْ خْ يِينِّي إِتّڭّنْ ثِيمسْڒَايِينْ-أَ. \x ◘ \xo 1:‏32 \xt حُوش. 7‏:‏3. \x*
\b
\b
\c 2
\s1 ڒْحُوكْمْ إِسڭّْذنْ ن أَربِّي
\m 
\v 1 \bd س ؤُينِّي\bd* أَقَا شكْ بْڒَا سْمَاحثْ، أَ بْنَاذمْ، شكْ ذ ونِّي إِحكّْمنْ خْ ونِّي ذ أَشْ يُوذْسنْ، مِينْزِي ذِي مِينْ ثْحكّْمذْ خْ ؤُمدُّوكّڒْ نّشْ، أَقَا ؤُڒَا ذ شكْ ذ بُو-ؤُمَارْوَاسْ ذِي مَانْ أَيَا، مَاغَارْ شكْ، ونِّي إِتّْحَاسَابنْ \add إِنّغْنِي\add*، ڒسْقنْثْ غَاركْ ؤُڒَا ذ سِيمَانْثْ ن ثْمسْڒَايِينْ. \x ◘ \xo 2:‏1 \xt 2 صم. 12‏:‏5؛ مت. 7‏:‏1؛ 1 كُور. 4‏:‏5. \x*
\v 2 نشِّينْ نسّنْ بلِّي ڒْحُوكْمْ ن أَربِّي ذ ثِيذتّْ خْ يِينِّي غَارْ ثدْجَا ثسْغَارْثْ ذِي ثْمسْڒَايِينْ أَمْ ثِينَا.
\v 3 مَاشَا مَايمِّي ذ أَشْ إِتّْغِيڒْ، \add أَ\add* بْنَاذمْ، ونِّي إِحكّْمنْ خْ يِينِّي إِتّڭّنْ ثِيمسْڒَايِينْ-أَ أَمْ ؤُڒَا ذ شكْ ثتّڭّذْ ثنْثْ سِيمَانْثْ نّشْ، أَقَا ثْزمَّارذْ أَذْ ثَاروْڒذْ زِي ڒْحُوكْمْ ن أَربِّي؟
\v 4 نِيغْ ثسّحْقَارَاذْ أَڭْڒَا ن ثْشُونِي نّسْ ذ تَّاسِيعْ ن ؤُرَاجِي نّسْ ذ تَّاسِيعْ إِ ذ أَشْ إِوْشِينْ، ؤُشَا وَارْ ثسِّينذْ شَا بلِّي ثْشُونِي ن أَربِّي أَقَا إِندّهْ إِ شكْ غَارْ تُّوبثْ؟ \x ◘ \xo 2:‏4 \xt 2 بُط. 3‏:‏15. \x*
\v 5 مَاشَا ذِي سِّيبّثْ ن ڒقْسَاحثْ ذ نُّوقْصَانْ ن تُّوبثْ ن وُوڒْ نّشْ، ثْيَارْوذْ إِ يِيخفْ نّشْ إِجّْ ن ڒقْذَارْ ن وغْضَابْ إِ وَاسّْ ن وغْضَابْ ؤُ إِ ؤُسَارْڭبْ ن ڒْحُوكْمْ إِسڭّْذنْ ن أَربِّي، \x ◘ \xo 2:‏5 \xt رُوم. 9‏:‏22. \x*
\v 6 ونِّي إِ غَا إِخدْجْصنْ كُوڒْ إِجّنْ عْلَاحْسَابْ ڒخْذَايمْ نّسْ: \x ◘ \xo 2:‏6 \xt إِزهد. 62‏:‏13؛ إِرْم. 17‏:‏10؛ 32‏:‏19؛ مت. 16‏:‏27؛ رُوم. 14‏:‏12؛ 1 كُور. 3‏:‏8؛ 2 كُور. 5‏:‏10؛ ڭال. 6‏:‏5؛ أَسَا. 2‏:‏23؛ 22‏:‏12. \x*
\m 
\v 7 ... إِ يِينِّي يَارزُّونْ أَعُودْجِي ذ شَّانْ ذ مِينْ وَارْ إِفنِّينْ أَمْ تّْصبَّارنْ نِيثْنِي ذِي ڒخْذَايمْ إِصبْحنْ، \add أَقَا أَذْ أَسنْ إِخدْجصْ س\add* ثُوذَارْثْ إِتّْذُومَانْ،
\m 
\v 8 ... مَاشَا إِ يِينِّي إِتّْغوّْغنْ، إِنِّي وَارْ إِتّْنُومنْ تّطَّاعنْ إِ ثِيذتّْ، مَاشَا تّْنُومنْ تّطَّاعنْ إِ مِينْ وَارْ إِسڭّْذنْ، أَقَا أَذْ أَسنْ إِخدْجصْ س وغْضَابْ ذ ثفْقحْثْ، \x ◘ \xo 2:‏8 \xt 2 تس. 1‏:‏8. \x*
\m 
\v 9 ... ؤُ س ڒْمحْنثْ ذ ڒحْسَارثْ أَذْ إِخدْجصْ كُوڒْ ڒعْمَارْ ن بْنَاذمْ إِ إِتّڭّنْ ڒْغَارْ، ؤُذَاينْ ذ أَمزْوَارْ، \add خنِّي\add* إِرَامِييّنْ،
\m 
\v 10 ... مَاشَا أَعُودْجِي ذ شَّانْ ذ ڒهْنَا \add أَذْ إِڒِينْ\add* إِ مَارَّا وِي إِتّڭّنْ ثْشُونِي، إِ وُوذَاينْ ذ أَمزْوَارْ ؤُشَا \add خنِّي\add* إِ إِرَامِييّنْ،
\v 11 مِينْزِي أَربِّي وَارْ إِتّڭّْ شَا س وُوذْمَاونْ. \x ◘ \xo 2:‏11 \xt أَعَوذ. 10‏:‏17؛ 2 إِم. 19‏:‏7؛ أَيُوبْ 34‏:‏19؛ ڒخ. 10‏:‏34؛ ڭال. 2‏:‏6؛ أَفا. 6‏:‏9؛ كُول. 3‏:‏25؛ 1 بُط. 1‏:‏17. \x*
\b
\m 
\v 12 مِينْزِي مَارَّا إِنِّي غَا إِخْضَانْ بْڒَا شَّارِيعَا، بْڒَا شَّارِيعَا أَذْ تّْوَاهلّْكنْ ؤُشَا مَارَّا إِنِّي غَا إِخْضَانْ سَاذُو شَّارِيعَا، أَقَا س شَّارِيعَا أَذْ تّْوَاحَاسْبنْ
\v 13 مَاغَارْ وَارْ إِدْجِي إِنِّي إِتّسْڒَانْ إِ شَّارِيعَا نِيثْنِي ذ إِمْسڭَّاذنْ غَارْ أَربِّي، مَاشَا إِنِّي إِتّڭّنْ شَّارِيعَا أَقَا نِيثْنِي أَذْ تّْوَاسڭّْذنْ. \x ◘ \xo 2:‏13 \xt مت. 7‏:‏21؛ يَاع. 1‏:‏22؛ 1 يُوح. 3‏:‏7. \x*
\v 14 مِينْزِي مَاڒَا ڒڭْنُوسْ نِّي وَارْ غَارْ إِدْجِي بُو شَّارِيعَا، تّڭّنْ س طّْبِيعثْ مِينْ ذَايسْ ذِي شَّارِيعَا، أَقَا يِينَا ذ شَّارِيعَا إِ يِيخفْ نْسنْ، وَاخَّا نِيثْنِي وَارْ غَارْسنْ بُو شَّارِيعَا،
\v 15 ؤُشَا سّْشَاننْ بلِّي ڒْخذْمثْ ن شَّارِيعَا ثُورَا ذڭْ وُوڒَاونْ نْسنْ، أَمْ ثشْهذْ عَاوذْ ثْنفْسشْثْ نْسنْ، أَمْ إِخَارِّيصنْ نْسنْ ذدْجنْ ؤُڒَا تّْذَافَاعنْ خْ يِيخفْ نْسنْ جَارْ أَسنْ \x ◘ \xo 2:‏15 \xt إِرْم. 31‏:‏33\x*
\v 16 ذڭْ وَاسّْ مِينْ ذِي إِ غَا إِحَاسبْ أَربِّي خْ مِينْ إِنُّوفَارنْ ذڭْ إِوْذَانْ س يَاسُوع لْمَاسِيحْ عْلَاحْسَابْ لْ-إِنْجِيلْ إِنُو. \x ◘ \xo 2:‏16 \xt مت. 25‏:‏31. \x*
\b
\s1 ؤُذَايْ ذ شَّارِيعَا
\m 
\v 17 مَاشَا مَاڒَا شكْ، ؤُمِي ڒَاغَانْ ؤُذَايْ، ثْسنَّاذذْ خْ شَّارِيعَا ؤُ ثسّمْغَارذْ ذِي أَربِّي، \x ◘ \xo 2:‏17 \xt رُوم. 9‏:‏4. \x*
\v 18 أَقَا ثسّْنذْ مِينْ إِخْسْ نتَّا، ثْفَارّْزذْ مِينْ إِصبْحنْ، مِينْزِي ثتّْوَاسّْڒمْذذْ زِي شَّارِيعَا،
\v 19 ؤُ ثْحَاسْبذْ إِخفْ نّشْ ذ أَمْڭوّذْ ن إِذَارْغَاڒنْ ذ ثْفَاوْثْ إِ يِينِّي إِدْجَانْ ذِي ثَادْجسْثْ،
\v 20 ذ أَمْسڭّمْ يَاربَّانْ إِبُوهَاڒِييّنْ ذ أَمْسڒْمَاذْ ن إِحنْجِيرنْ، ؤُ أَقَا غَاركْ صِّيفثْ ن ثُوسّْنَا ذ ثِيذتّْ ذِي شَّارِيعَا،
\v 21 \add إِوَا\add* شكْ ونِّي إِسّڒْمَاذنْ إِنّغْنِي، مَا وَارْ ثسّڒْمِيذذْ شَا إِخفْ نّشْ؟ شكْ ونِّي إِتّْبَارّْحنْ ’وَارْ تِّيشَارْ!‘، مَا ثتَّاشَارذْ؟
\v 22 شكْ ونِّي إِقَّارنْ ’وَارْ زنِّي!‘، مَا ثْزنِّيذْ؟ شكْ ذ ونِّي إِشَارّْهنْ لْ-أَصْنَامْ، مَا ثَاشَارذْ زَّاوشْثْ \add نْسنْ\add* إِقدّْسنْ؟ \x ◘ \xo 2:‏22 \xt ڒخ. 19‏:‏37\x*
\v 23 شكْ ونِّي إِسّمْغَارَانْ ذِي شَّارِيعَا، مَا ثْفضْحذْ أَربِّي ؤُمِي ثخْضِيذْ ذِي شَّارِيعَا؟
\v 24 مِينْزِي خْ سِّيبّثْ نْومْ تّْشقَّافنْ ذڭْ يِيسمْ ن أَربِّي جَارْ ڒڭْنُوسْ أَمْ مَامّشْ ثُورَا. \x ◘ \xo 2:‏24 \xt إِشا. 52‏:‏5؛ حِز. 36‏:‏2. \x*
\m 
\v 25 أَقَا أَخْثَانْ إِنفّعْ مَاڒَا ثْضفَّارذْ شَّارِيعَا نِيشَانْ، مَاشَا مَاڒَا ثتّْعذِّيذْ خْ شَّارِيعَا، أَقَا أَخْثَانْ نّشْ إِتّْوَاحْسبْ بْڒَا أَخْثَانْ.
\v 26 مَاڒَا ونِّي بْڒَا أَخْثَانْ إِتّطّفْ ذِي ڒُومَارْ إِسڭّْذنْ ن شَّارِيعَا، مَا \add خنِّي\add* وَارْ إِحسّبْ بْڒَا أَخْثَانْ نّسْ ذ أَخْثَانْ؟
\v 27 ونِّي إِضفَّارنْ شَّارِيعَا س طّْبِيعثْ أَمْ إِدْجَا بْڒَا أَخْثَانْ، أَذْ شكْ إِحَاسبْ، شكْ ونِّي إِتّْعدَّانْ خْ شَّارِيعَا س ثِيرَا ذ وخْثَانْ!
\v 28 مِينْزِي ؤُذَايْ وَارْ إِدْجِي ذ ؤُذَايْ س وُوذمْ، ؤُ أَخْثَانْ \add س ثِيذتّْ\add* وَارْ إِدْجِي مِينْ إِتّْبَاننْ ذڭْ ويْسُومْ، \x ◘ \xo 2:‏28 \xt يُوح. 8‏:‏39؛ رُوم. 9‏:‏7. \x*
\v 29 مَاشَا نتَّا ذ ؤُذَايْ ونِّي إِتِّيڒِينْ ذ ؤُذَايْ ذِي ثْنُوفّْرَا، ؤُ أَخْثَانْ أَقَا نتَّا ذ ونِّي ذڭْ وُوڒْ، س أَرُّوحْ، وَارْ إِدْجِي \add ذ ونِّي إِتّْوَاڭّنْ\add* عْلَاحْسَابْ ثِيرَّا \add ن شَّارِيعَا\add*، أَڒَامِي أَسمْغَارْ نّسْ وَارْ د-إِتِّيسْ شَا زڭْ إِوْذَانْ مَاشَا زِي أَربِّي. \x ◘ \xo 2:‏29 \xt أَعَوذ. 10‏:‏16؛ إِرْم. 4‏:‏4؛ فِيل. 3‏:‏2، 3؛ كُول. 2‏:‏11. \x*
\b
\b
\c 3
\s1 أَربِّي ذ ثِيذتّْ ؤُ كُوڒْ بْنَاذمْ ذَايسْ ڒْغشّْ
\m 
\v 1 إِ خنِّي، مَانْ ڒفْضڒْ غَارْ وُوذَاينْ، نِيغْ مَانْ ثِيزِي ن وخْثَانْ؟
\v 2 أَطَّاسْ خْ كُوڒْ إِغزْذِيسنْ! خنِّي غَارْ ؤُمزْوَارْ مّوْشنْ أَسنْ ‬وَاوَاڒنْ نْ‮ ‬أَربِّي. \x ◘ \xo 3:‏2 \xt إِزهد. 147‏:‏19؛ رُوم. 9‏:‏4. \x*
\v 3 مَاغَارْ مَاڒَا ثُوغَا شَا زَّايْسنْ وَارْ ؤُمِيننْ شَا، مَا خنِّي بضْڒنْ نِيثْنِي ڒَامَانْ ن أَربِّي زِي سِّيبّثْ ن بْڒَا لْ-إِيمَانْ نْسنْ؟ \x ◘ \xo 3:‏3 \xt ڒخْڒ. 23‏:‏19؛ رُوم. 9‏:‏6؛ 2 تِيم. 2‏:‏13. \x*
\v 4 عمَّارْصْ! مَاغَارْ أَربِّي ذ ثِيذتّْ ؤُشَا كُوڒْ بْنَاذمْ ذ بُو-إِخَارِّيقنْ، أَمْ مَامّشْ ثُورَا:
\b
\m \qt ”شكْ أَذْ ثْبَانذْ ذ أَمْسڭّذْ س وَاوَاڒنْ نّشْ،\qt*
\m \qt أَذْ ثِيڒِيذْ ثْكمّْڒذْ ذِي ڒصْفَايثْ\qt*
\m \qt خْمِي شكْ إِ غَا حَاسْبنْ.“\qt* \x ◘ \xo 3:‏4 \xt إِزهد. 51‏:‏6؛ 116‏:‏11؛ يُوح. 3‏:‏33. \x*
\b
\m 
\v 5 مَاشَا مَاڒَا مِينْ وَارْ إِسّڭّْذنْ ذَايْنغْ أَقَا إِسّْبيّنْ ثَاسڭْذَا ن أَربِّي، مِينْ غَا نِينِي عَاذْ خنِّي؟ مَا أَربِّي وَارْ غَارسْ بُو ڒْحقّْ ؤُمِي خَانغْ إِڭَّا أَغْضَابْ نّسْ؟ نشّْ سَّاوَاڒغْ أَمْ يِيجّْ ن بْنَاذمْ \add ذ أَمذْنُوبْ\add*.
\v 6 وَارْ خَاسْ نسِّيوِيڒْ! مَامّشْ إِ غَا إِحَاسبْ أَربِّي دُّونشْثْ ڒخْذنِّي؟
\v 7 مَامّشْ مَاڒَا ثْفيّضْ ثِيذتّْ ن أَربِّي غَارْ ؤُعُودْجِي نّسْ س ؤُخَارِّيقْ إِنُو، مَايمِّي عَاذْ إِ غَا تّْوَاحَاسْبغْ أَمْ ؤُمذْنُوبْ؟
\v 8 وَارْ إِعدّڒْ أَقَا ثَامسْڒَاشْثْ ثدْجَا أَمْ مَامّشْ قَّارنْ إِنِّي ذَايْنغْ إِشقّْفنْ بلِّي نشِّينْ نقَّارْ: ”أجّْ أَنغْ أَذْ نڭّْ ثُوعفّْنَا، حِيمَا أَذْ زَّايسْ د-يكّْ مِينْ إِشْنَانْ!“؟، إِنِّي أَقَا ڒْحُوكْمْ خَاسنْ أَذْ إِتّْوَاخمّڒْ أَڒْ شّْرعْ إِسڭّْذنْ.
\b
\m 
\v 9 إِ خنِّي مَامّشْ؟ مَا نشِّينْ حْسنْ؟ قْبڒْ أَقَا نُوفَا أَقَا ؤُذَاينْ ذ إِرَامِييّنْ مَارَّا سَاذُو دّنْبْ، \x ◘ \xo 3:‏9 \xt ڭال. 3‏:‏22. \x*
\v 10 أَمْ مَامّشْ ثُورَا:
\b
\m \qt ”ؤُڒَا ذ إِجّْ وَارْ إِدْجِي ذ أَمْسڭّذْ،\qt* \x ◘ \xo 3:‏10 \xt إِزهد. 14‏:‏3؛ 53‏:‏4. \x*
\m 
\v 11 \qt ؤُڒَا ذ إِجّْ وَارْ إِفهّمْ،\qt*
\m \qt ؤُڒَا ذ إِجّْ وَارْ يَارزُّو خْ أَربِّي.\qt*
\m 
\v 12 \qt مَارَّا فّْغنْ زڭْ وبْرِيذْ، مّنْضَارنْ،\qt*
\m \qt ؤُڒَا ذ إِجّْ وَارْ إِتّڭّْ ثْشُونِي، ؤُڒَا ذ إِجّْ.\qt* \x ◘ \xo 3:‏12 \xt إِزهد. 14‏:‏1‏-‏3؛ 53‏:‏2‏-‏4؛ أَمب. 7‏:‏20\x*
\m 
\v 13 \qt ثْمِيجَّاوِينْ نْسنْ ذ إِمضْڒَانْ يَارزْمنْ،\qt*
\m \qt س إِڒْسَاونْ نْسنْ شمّْثنْ،\qt*
\m \qt سّمْ ن إِفِيغْرَانْ سَاذُو إِينْشِيشنْ نْسنْ،\qt* \x ◘ \xo 3:‏13 \xt إِزهد. 5‏:‏10؛ 140‏:‏4. \x*
\m 
\v 14 \qt أَقمُّومْ نْسنْ إِشُّورْ س نّعْڒثْ ذ ثَارْزُوڭِي،\qt* \x ◘ \xo 3:‏14 \xt إِزهد. 10‏:‏7. \x*
\m 
\v 15 \qt س إِضَارنْ نْسنْ تّْقدْجِيقنْ\qt*
\m \qt غَارْ ؤُسِيزّڒْ ن إِذَامّنْ،\qt* \x ◘ \xo 3:‏15 \xt أَوڒن. 1‏:‏16؛ إِشا. 59‏:‏7. \x*
\m 
\v 16 \qt أَريّبْ ذ ثَامَارَا ذڭْ إِبْرِيذنْ نْسنْ،\qt*
\m 
\v 17 \qt أَبْرِيذْ ن ڒهْنَا وَارْ ث سِّيننْ شَا،\qt* \x ◘ \xo 3:‏17 \xt إِشا. 59‏:‏7، 8\x*
\m 
\v 18 \qt ثِيڭّْوُوذِي ن أَربِّي\qt*
\m \qt وَارْ ثدْجِي قِيبَاتْشْ إِ ثِيطَّاوِينْ نْسنْ.“\qt*\x ◘ \xo 3:‏18 \xt إِزهد. 36‏:‏2. \x*
\b
\m 
\v 19 نشِّينْ نسّنْ بلِّي مَارَّا مِينْ ثقَّارْ شَّارِيعَا، أَقَا ثقَّارْ إِ-ث إِ يِينِّي إِدْجَانْ سَاذُو شَّارِيعَا، حِيمَا أَذْ إِتّْوَاقّنْ كُوڒْ أَقمُّومْ ؤُشَا أَذْ ثذْوڒْ مَارَّا دُّونشْثْ ذَايسْ ڒْعِيبْ زَّاثْ إِ أَربِّي،
\v 20 مَاغَارْ زِي ڒخْذَايمْ ن شَّارِيعَا وَارْ إِتّْوَاسڭّذْ ؤُڒَا ذ إِجّْ ن بْنَاذمْ قِيبَاتْشْ نّسْ، مِينْزِي س شَّارِيعَا أَقَا تّْوَاسّْننْ دّْنُوبْ. \x ◘ \xo 3:‏20 \xt رُوم. 7‏:‏7؛ ڭال. 2‏:‏16؛ عبر. 7‏:‏18. \x*
\b
\s1 ثَاسڭْذَا س لْ-إِيمَانْ وحّْذسْ
\m 
\v 21 مَاشَا ڒخُّو أَقَا ثضْهَارْ-د ثْسڭْذَا ن أَربِّي بْڒَا شَّارِيعَا، ثْشهّذْ خَاسْ شَّارِيعَا ذ إِنَابِييّنْ، \x ◘ \xo 3:‏21 \xt رُوم. 1‏:‏17؛ فِيل. 3‏:‏9. \x*
\v 22 أَقَا ثَاسڭْذَا ن أَربِّي زِي لْ-إِيمَانْ ن يَاسُوع لْمَاسِيحْ غَارْ مَارَّا ؤُ خْ مَارَّا إِنِّي زَّايسْ يُومْننْ، مِينْزِي وَارْ ذِينْ بُو ڒْفَارْزْ.
\v 23 مِينْزِي مَارَّا خْضَانْ ؤُشَا إِنقْصْ إِ-ثنْ ؤُعُودْجِي ن أَربِّي،
\v 24 ؤُشَا تّْوَاسڭّْذنْ بَاطڒْ س أَرْضَا نّسْ س ؤُفكِّي إِ إِدْجَانْ ذِي يَاسُوع لْمَاسِيحْ. \x ◘ \xo 3:‏24 \xt إِشا. 53‏:‏5. \x*
\v 25 أَربِّي إِڭَّا إِ-ث ذ أَصْڒَاحْ قْبڒْ سْ لْ-إِيمَانْ ذڭْ إِذَامّنْ نّسْ، ذِي سِّيبّثْ ن دّْنُوبْ نّغْ نِّي ثُوغَا نڭَّا زِيشْ ذِي ڒْمِيجَاڒْ ن ڒْوقْثْ إِ ذ أَنغْ إِوْشَا أَربِّي س تَّاسِيعْ ن ڒْخَاضَارْ نّسْ، حِيمَا أَذْ إِسّْشنْ ثَاسڭْذَا نّسْ ذِي ڒْوقْثْ-أَ، \x ◘ \xo 3:‏25 \xt ؤُف. 25‏:‏17؛ 2 كُور. 5‏:‏19؛ كُول. 1‏:‏20؛ عبر. 4‏:‏16؛ 1 يُوح. 4‏:‏10. \x*
\v 26 مَاحنْذْ ذِي ثْسڭْذَا أَذْ يَارّْ ذ أَمْسڭَّاذْ وِي إِدْجَانْ ذِي لْ-إِيمَانْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ.
\m 
\v 27 مَانِي إِدْجَا خنِّي ؤُسمْغَارْ؟ وَارْ خَاسْ نسِّيوِيڒْ. س مَانْ شَّارِيعَا؟ س مَانْ ڒخْذَايمْ؟عمَّارْصْ، مَاشَا س شَّارِيعَا ن لْ-إِيمَانْ.
\v 28 س ؤُيَا نحْسبْ بلِّي بْنَاذمْ أَذْ إِتّْوَاسڭّذْ س لْ-إِيمَانْ، وَارْ إِدْجِي س ڒخْذَايمْ ن شَّارِيعَا. \x ◘ \xo 3:‏28 \xt ڒخ. 13‏:‏38؛ رُوم. 8‏:‏3؛ ڭال. 2‏:‏16؛ عبر. 7‏:‏25. \x*
\v 29 نِيغْ أَربِّي ن وُوذَاينْ وَاهَا، وَارْ إِدْجِي ن ڒڭْنُوسْ عَاوذْ؟ وَاهْ، ؤُڒَا ن ڒڭْنُوسْ!
\v 30 مِينْزِي أَربِّي ذ إِجّنْ ونِّي إِ غَا إِسڭّْذنْ إِنِّي إِتّْوَاخثْننْ س لْ-إِيمَانْ، ؤُ عَاوذْ إِنِّي وَارْ إِتّْوَاخْثِيننْ س لْ-إِيمَانْ.
\v 31 مَا نْبطّڒْ شَّارِيعَا س لْ-إِيمَانْ؟ وَايَّاوْ، س ڒمْقْڒُوبْ، نشِّينْ أَذْ نضْمنْ شَّارِيعَا.
\b
\b
\c 4
\s1 لْ‘إِمَانْ ن إِبْرَاهِيمْ
\m 
\v 1 مِينْ إِ غَا نِينِي خنِّي خْ إِبْرَاهِيمْ، أَزدْجِيفْ ن ڒجْذُوذْ نّغْ، أَقَا يُوفَا ذِي \add أَرِّيمثْ نّسْ ن\add* ويْسُومْ؟ \x ◘ \xo 4:‏1 \xt إِشا. 51‏:‏2. \x*
\v 2 مِينْزِي مَاڒَا إِبْرَاهِيمْ ثُوغَا إِتّْوَاسڭّذْ س ڒخْذَايمْ، أَقَا غَارسْ شَّانْ، مَاشَا وَارْ إِدْجِي شَا غَارْ أَربِّي.
\v 3 مِينْزِي مِينْ قَّارنْثْ ثِيرَا \add إِقدّْسنْ\add*؟ ”يُومنْ إِبْرَاهِيمْ ذِي أَربِّي ؤُشَا إِتّْوَاحْسبْ أَسْ-د مَانْ أَيَا ذ ثَاسڭْذَا.“ \x ◘ \xo 4:‏3 \xt أَمز. 15‏:‏6؛ ڭال. 3‏:‏6؛ يَاع. 2‏:‏23. \x*
\v 4 ونِّي إِخدّْمنْ وَارْ ذ أَسْ ثتّْوَاحسّبْ شَا ڒْمُونثْ خْ ڒحْسَابْ ن أَرْضَا، مَاشَا خْ ڒحْسَابْ ن ؤُمَارْوَاسْ، \add مِينْزِي تُّورْسنْ أَسْ-د\add*.
\v 5 مَاشَا ونِّي وَارْ إِخدّْمنْ، مَاشَا يُومنْ ذڭْ ونِّي إِتّْسڭَّاذنْ إِمذْنَابْ، أَقَا لْ-إِيمَانْ نّسْ أَذْ أَسْ د-إِتّْوَاحْسبْ ذ ثَاسڭْذَا.
\v 6 أَمْ مَامّشْ إِنَّا ذَاوُوذْ عَاوذْ خْ سّعْذْ ن بْنَاذمْ ونِّي ؤُمِي د أَسْ إِحْسبْ أَربِّي ثَاسڭْذَا بْڒَا ڒخْذَايمْ، ؤُمِي إِنَّا:
\b
\m 
\v 7 \qt ”سّعْذْ ن يِينِّي ؤُمِي إِتّْوَاغْفَارْ إِخطَّانْ نْسنْ،\qt*
\m \qt إِنِّي ؤُمِي إِسّْذُورِييْ \tl نتَّا\tl* دّْنُوبْ نْسنْ.\qt* \x ◘ \xo 4:‏7 \xt إِزهد. 32‏:‏1. \x*
\m 
\v 8 \qt سّعْذْ ن بْنَاذمْ\qt*
\m \qt ؤُمِي وَارْ د أَسْ إِحسّبْ شَا\qt*
\m \qt أَربِّي دّْنُوبْ نّسْ.“\qt* \x ◘ \xo 4:‏8 \xt إِزهد. 32‏:‏1، 2\x*
\b
\m 
\v 9 مَا سّعْذْ-أَ خْ يِينِّي إِتّْوَاخثْننْ وَاهَا نِيغْ عَاوذْ خْ يِينِّي وَارْ إِتّْوَاخثْننْ؟ س مِينْزِي نقَّارْ: ”لْ‘إِمَانْ ن إِبْرَاهِيمْ إِتّْوَاحْسبْ أَسْ-د ذ ثَاسڭْذَا!“ \x ◘ \xo 4:‏9 \xt أَمز. 15‏:‏6\x*
\v 10 مَامّشْ ذ أَسْ ث-إِ-د إِتّْوَاحْسبْ؟ مَا ڒَامِي ثُوغَا س وخْثَانْ نِيغْ مَاڒَا ثُوغَا بْڒَا أَخْثَانْ؟ وَارْ ثُوغِي س وخْثَانْ، مَاشَا ثُوغَا بْڒَا أَخْثَانْ.
\v 11 مِينْزِي إِكْسِي أَخْثَانْ ذ ڒعْڒَامثْ ذ ؤُشمِّيعْ ن ثْسڭْذَا ن لْ-إِيمَانْ نِّي غَارسْ ؤُمِي ث ثُوغَا بْڒَا أَخْثَانْ، حِيمَا أَذْ يِيڒِي ذ جذِّيثْسنْ ن مَارَّا إِنِّي يُومْننْ وَاخَّا نِيثْنِي بْڒَا أَخْثَانْ، حِيمَا أَذْ أَسنْ د-إِتّْوَاحْسبْ \add لْ-إِيمَانْ\add* ذ ثَاسڭْذَا عَاوذْ. \x ◘ \xo 4:‏11 \xt أَمز. 17‏:‏11. \x*
\v 12 نتَّا ذ جذِّيثْسنْ إِ يِينِّي س وخْثَانْ، \add مَاشَا\add* وَارْ إِدْجِي إِ يِينِّي \add إِذوْڒنْ يُومْننْ\add* زڭْ وخْثَانْ وَاهَا، \add مَاشَا\add* عَاوذْ إِ يِينِّي إِڭُّورنْ ذڭْ إِصُورَافْ ن لْ-إِيمَانْ ن جذِّيثْنغْ إِبْرَاهِيمْ ؤُمِي ثُوغَا بْڒَا أَخْثَانْ.
\m 
\v 13 مِينْزِي لْوَاعْذْ إِ إِبْرَاهِيمْ ؤُ إِ زَّارِيعثْ نّسْ بلِّي أَذْ يِيڒِي ذ أَوْرِيثْ ن دُّونشْثْ، وَارْ د-إِتِّيسْ شَا س شَّارِيعَا، مَاشَا س ثْسڭْذَا ن لْ-إِيمَانْ نّسْ.
\v 14 مِينْزِي مَاڒَا إِنِّي زِي شَّارِيعَا ذ إِوْرِيثنْ، أَقَا لْ-إِيمَانْ إِخسَّارنْ ؤُڒَا ذ لْوَاعْذْ إِبضْڒنْ. \x ◘ \xo 4:‏14 \xt ڭال. 3‏:‏18. \x*
\v 15 مَاغَارْ شَّارِيعَا ثتَّارُو أَغْضَابْ. مَانِي وَارْ ثدْجِي شَّارِيعَا، وَارْ ذِينْ إِدْجِي ؤُڒَا ذ أَعذِّي ن شَّارِيعَا. \x ◘ \xo 4:‏15 \xt يُوح. 15‏:‏22؛ رُوم. 5‏:‏20؛ 7‏:‏8؛ ڭال. 3‏:‏19. \x*
\m 
\v 16 س ؤُينِّي نتّْوَاسڭّذْ س لْ-إِيمَانْ، إِخْسْ أَذْ يِينِي س أَرْضَا، مَاحنْذْ أَذْ يِيڒِي لْوَاعْذْ نِيشَانْ إِ قَاعْ زَّارِيعثْ نّسْ، وَارْ إِدْجِي إِ يِينِّي إِدْجَانْ زِي شَّارِيعَا وَاهَا، مَاشَا عَاوذْ إِ يِينِّي إِدْجَانْ زِي لْ-إِيمَانْ ن إِبْرَاهِيمْ، ونِّي ذ جذِّيثْنغْ ن مَارَّا إِذْنغْ، \x ◘ \xo 4:‏16 \xt إِشا. 51‏:‏2. \x*
\v 17 أَمْ مَامّشْ ثُورَا: ”أَقَا ڭِّيغْ شكْ ذ جذِّيثْسنْ إِ وَاطَّاسْ ن ڒڭْنُوسْ!“، زَّاثْ إِ أَربِّي ونِّي زِي ثُوغَا ثُومْنذْ، ونِّي إِتِّيشنْ ثُوذَارْثْ إِ إِمتِّيننْ ذ ونِّي إِتّْڒَاغَانْ ثِيمسْڒَايِينْ إِ وَارْ إِدْجِينْ أَخْمِي دْجَانْ. \x ◘ \xo 4:‏17 \xt أَمز. 17‏:‏5. \x*
\v 18 وَاخَّا إِقْضعْ أَسْ ڒَايَاسْ، أَقَا يُومنْ س ؤُسِيثمْ أَذْ إِذْوڒْ ذ جذِّيثْسنْ إِ وَاطَّاسْ ن ڒڭْنُوسْ أَمْ مَامّشْ ثُورَا: ”أَمُّو إِ غَا ثِيڒِي زَّارِيعثْ نّشْ!“ \x ◘ \xo 4:‏18 \xt أَمز. 15‏:‏5؛ عبر. 11‏:‏12. \x*
\v 19 لْ-إِمَانْ نّسْ وَارْ ثُوغِي إِضْعفْ، ؤُمِي إِحْسبْ أَرِّيمثْ نّسْ ثمُّوثْ أَمْ ثُوغَا غَارسْ مْيَا ن إِسڭّْوُوسَا، ؤُ ؤُمِي إِمُّوثْ ؤُعذِّيسْ ن سَارَا.
\v 20 نتَّا وَارْ إِشكّْ شَا ذِي لْوَاعْذْ ن أَربِّي أَخْمِي س نّقْصْ ن لْ-إِيمَانْ، مَاشَا إِمْحضْ ذِي لْ-إِيمَانْ نّسْ، إِوْشَا أَعُودْجِي إِ أَربِّي. \x ◘ \xo 4:‏20 \xt يُوح. 8‏:‏56؛ عبر. 11‏:‏11، 18. \x*
\v 21 ثُوغَا إِسّنْ نِيشَانْ بلِّي مِينْ زَّايسْ ثُوغَا إِوَاعْذْ أَربِّي، إِزمَّارْ أَذْ ث إِڭّْ عَاوذْ. \x ◘ \xo 4:‏21 \xt إِزهد. 115‏:‏3. \x*
\v 22 س ؤُينِّي إِتّْوَاحْسبْ أَسْ-د \add لْ-إِيمَانْ\add* ذ ثَاسڭْذَا. \x ◘ \xo 4:‏22 \xt أَمز. 15‏:‏6. \x*
\m 
\v 23 مَاشَا وَارْ ثُورِي ذِي سِّيبّثْ نّسْ وَاهَا، أَقَا إِتّْوَاحْسبْ أَسْ-د لْ-إِيمَانْ نّسْ ذ ثَاسڭْذَا، \x ◘ \xo 4:‏23 \xt رُوم. 15‏:‏4. \x*
\v 24 مَاشَا عَاوذْ ذِي سِّيبّثْ نّغْ، حِيمَا نتَّا أَذْ أَنغْ ث-إِ-د-إِحْسبْ \add ذ ثَاسڭْذَا\add*، إِ نشِّينْ إِنِّي إِتَّامْننْ ذڭْ ونِّي إِ د-إِسّْنكَّارنْ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ زِي ثَادَّارْثْ ن إِمتِّيننْ،
\v 25 \add يشُّو لْمَاسِيحْ\add* ونِّي إِتّْوَاسلّْمنْ ذِي سِّيبّثْ ن دّْنُوبْ نّغْ ؤُشَا إِكَّارْ-د حِيمَا أَذْ أَنغْ إِسڭّذْ.
\b
\b
\c 5
\s1 ثَايْرِي ن أَربِّي س لْمَاسِيحْ ذڭْ وُوڒَاونْ نّغْ
\m 
\v 1 خنِّي نشِّينْ، أَمْ نتّْوَاسڭّذْ س لْ-إِيمَانْ، أَقَا أَذْ غَارْنغْ يِيڒِي ڒهْنَا أَكْ-ذ أَربِّي س سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 5:‏1 \xt إِشا. 32‏:‏17؛ يُوح. 16‏:‏33؛ أَفا. 2‏:‏13. \x*
\v 2 مَاغَارْ زَّايسْ إِذْوڒْ أَنغْ-د أَذَافْ س لْ-إِيمَانْ غَارْ أَرْضَا-يَا مِينْ ذِي نْبدّْ، ؤُ نسّمْغَارْ ذڭْ ؤُسِيثمْ ن ؤُعُودْجِي ن أَربِّي. \x ◘ \xo 5:‏2 \xt يُوح. 10‏:‏9؛ 14‏:‏6؛ 1 كُور. 15‏:‏1؛ أَفا. 2‏:‏18؛ 3‏:‏12؛ عبر. 3‏:‏6؛ 10‏:‏19. \x*
\v 3 \add مَاشَا\add* وَارْ إِدْجِي ذِي مَانْ أَيَا وَاهَا، مَاشَا نسّمْغَارْ عَاوذْ ذِي ڒمْحَايمْ، نسّنْ بلِّي ڒْمحْنثْ ثتَّارُو-د ذَايْنغْ صّْبَارْ، \x ◘ \xo 5:‏3 \xt يَاع. 1‏:‏3. \x*
\v 4 ذ صّْبَارْ \add أَذْ يَاوِي\add* ثَاقدْجبْثْ، ؤُشَا ثَاقدْجبْثْ \add أَذْ ثَاوِي\add* أَسِيثمْ،
\v 5 ؤُشَا أَسِيثمْ وَارْ إِتّْسحْشِيمْ شَا، مِينْزِي ثَايْرِي ن أَربِّي أَقَا ثتّْوَافَارّغْ ذڭْ وُوڒَاونْ نّغْ س أَرُّوحْ إِقدّْسنْ إِ ذ أَنغْ إِمّوْشنْ.
\m 
\v 6 ذِي سِّيبّثْ ن ثُوضْعفْثْ نّغْ، أَقَا إِمُّوثْ لْمَاسِيحْ ذِي ڒْوقْثْ-أَ ذِي طّْوعْ ن إِعفَّاننْ. \x ◘ \xo 5:‏6 \xt أَفا. 2‏:‏1؛ كُول. 2‏:‏13؛ عبر. 9‏:‏15؛ 1 بُط. 3‏:‏18. \x*
\v 7 س ڒْوحْڒَانْ أَذْ إِمّثْ حذْ ذِي طّْوعْ ن إِجّْ ن ؤُعفَّانْ، مَاشَا ذِي طّْوعْ ن إِصبْحَاننْ أَذْ ثَاغْ إِزمَّارْ أَذْ إِزْعمْ حذْ أَذْ إِمّثْ.
\v 8 ذِي مَانْ أَيَا إِمْڒَا أَنغْ أَربِّي ثَايْرِي نّسْ، أَقَا لْمَاسِيحْ إِمُّوثْ ذِي طّْوعْ نّغْ ؤُمِي ثُوغَا أَنغْ عَاذْ ذ إِمذْنَابْ. \x ◘ \xo 5:‏8 \xt عبر. 9‏:‏15؛ 1 بُط. 3‏:‏18. \x*
\v 9 مشْحَاڒْ كْثَارْ أَقَا نتّْوَاسڭّذْ ڒخُّو س إِذَامّنْ نّسْ ؤُشَا نتّْوَافكّْ زَّايسْ زڭْ وغْضَابْ!
\v 10 مِينْزِي ڒَامِي ذ أَنغْ ثُوغَا ذ ڒْعذْيَانْ، إِجَّا أَربِّي أَذْ إِسّصْڒحْ إِخفْ نّسْ أَكِيذْنغْ س ڒْموْثْ ن مِّيسْ، مشْحَاڒْ قَاعْ ڒخُّو أَذْ ندَّارْ س ثُوذَارْثْ نّسْ، أَوَارْنِي ڒَامِي زَّايسْ نُوفَا أَصْڒَاحْ.
\v 11 ؤُ وَارْ إِدْجِي مَانْ أَيَا وَاهَا، مَاشَا أَذْ نسّمْغَارْ ذِي أَربِّي عَاوذْ س سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، ونِّي زِي نكْسِي ڒخُّو أَصْڒَاحْ.
\b
\s1 أَذَامْ ذ لْمَاسِيحْ
\m 
\v 12 مَاغَارْ أَمْ مَامّشْ س يِيجّْ ن بْنَاذمْ يُوذفْ-د دّنْبْ غَارْ دُّونشْثْ ؤُشَا س دّنْبْ ثُوذفْ-د ڒْموْثْ، أَمُّو د-ثُوذفْ ڒْموْثْ غَارْ إِوْذَانْ مَارَّا، مِينْزِي خْضَانْ مَارَّا. \x ◘ \xo 5:‏12 \xt أَمز. 2‏:‏17؛ 3‏:‏6؛ 1 كُور. 15‏:‏21. \x*
\v 13 مِينْزِي قْبڒْ مَا ثُوغَا ثدْجَا شَّارِيعَا، ثُوغَا دّنْبْ ذِي دُّونشْثْ، مَاشَا دّنْبْ وَارْ إِتّْوَاحْسِيبْ شَا مِينْزِي وَارْ ذِينْ ثدْجِي شَّارِيعَا.
\v 14 مَاشَا ڒْموْثْ ثُوغَا ثحْكمْ زِي أَذَامْ أَڒْ مُوسَا ؤُڒَا خْ يِينِّي وَارْ إِخْضِينْ ذِي صِّيفثْ ن ؤُخطُّو إِ زِي إِخْضَا أَذَامْ أَكْ-ذ شَّارِيعَا. \add أَذَامْ\add* ونِّي ذ صِّيفثْ ن ونِّي د غَا يَاسنْ.
\m 
\v 15 مَاشَا أَمْ مَامّشْ ثدْجِي \add ثْمسْڒَاشْثْ\add* س ؤُوطُّو، أَمُّو وَارْ ثدْجِي س ثوْهِيبْثْ ن أَرْضَا. مِينْزِي مَاڒَا مُّوثنْ أَطَّاسْ خْ سِّيبّثْ ن إِجّْ ن ؤُخطُّو، مشْحَاڒْ قَاعْ إِ غَا إِفيّضْ أَرْضَا ن أَربِّي ذ ثوْهِيبْثْ نّسْ إِ وَاطَّاسْ س ؤُينِّي ن بْنَاذمْ \add نِّي\add*، يَاسُوع لْمَاسِيحْ.
\v 16 ثَاوْهِيبْثْ س أَرْضَا وَارْ ثتِّيڒِي أَمْ ؤُخطُّو ن يِيجّنْ. س مِينْزِي ڒْحُوكْمْ يِيوِي-د لْحِيسَابْ زڭْ إِجّْ ن ؤُخطُّو، مَاشَا ثَاوْهِيبْثْ ن أَرْضَا ثِيوِي-د زڭْ وَاطَّاسْ ن دّْنُوبْ غَارْ ثْسڭْذَا.
\v 17 مِينْزِي مَاڒَا س ؤُخطُّو ن إِجّنْ أَقَا ثحْكمْ ڒْموْثْ، مشْحَاڒْ قَاعْ إِ غَا حكْمنْ ذِي ثُوذَارْثْ إِنِّي إِكْسِينْ أَفيّضْ ن أَرْضَا ذ ثوْهِيبْثْ ن ثْسڭْذَا س ؤُينِّي \add ن بْنَاذمْ نِّي\add*، أَقَا-ث ذ يَاسُوع لْمَاسِيحْ.
\m 
\v 18 أَمْ مَامّشْ خنِّي س ؤُخطُّو ن إِجّنْ، أَقَا إِذْوڒْ ڒْحُوكْمْ إِ مَارَّا إِوْذَانْ، أَمُّو إِ غَا ثِيڒِي ڒصْفَايثْ إِكمّْڒنْ إِ ثُوذَارْثْ إِ مَارَّا إِوْذَانْ س ثْسڭْذَا ن يِيجّنْ.
\v 19 مِينْزِي أَمْ س ڒْمُوعْصِييّثْ ن إِجّْ ن بْنَاذمْ ذوْڒنْ أَطَّاسْ ذ إِمذْنَابْ، أَمُّو عَاوذْ س طَّاعثْ ن إِجّنْ أَذْ ذوْڒنْ أَطَّاسْ ذ إِمْسڭَّاذنْ.
\v 20 مَاشَا ؤُمِي د-ثُوسَا شَّارِيعَا، إِمَّارْنِي دّنْبْ، ؤُ مَانِي إِمَّارْنِي دّنْبْ، إِمَّارْنِي أَرْضَا أَطَّاسْ س وَاطَّاسْ، \x ◘ \xo 5:‏20 \xt Luik. 7‏:‏47؛ يُوح. 15‏:‏22؛ رُوم. 4‏:‏15؛ 7‏:‏8؛ ڭال. 3‏:‏19\x*
\v 21 حِيمَا، أَمْ مَامّشْ إِحْكمْ دّنْبْ أَڒْ ڒْموْثْ، أَذْ إِحْكمْ أَرْضَا عَاوذْ س ثْسڭْذَا أَڒْ ثُوذَارْثْ إِتّْذُومَانْ س سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ.
\b
\b
\c 6
\s1 أَسغْضصْ ذِي لْمَاسِيحْ
\m 
\v 1 مِينْ غَا نِينِي خنِّي؟ مَا أَذْ نقِّيمْ ذِي دّنْبْ حِيمَا أَذْ إِمَّارْنِي أَرْضَا؟
\v 2 عمَّارْصْ! نشِّينْ إِنِّي إِمُّوثنْ إِ دّنْبْ، مَامّشْ عَاذْ ذَايسْ إِ غَا ندَّارْ؟
\v 3 مَا وَارْ ثسِّينمْ شَا بلِّي إِنِّي زَّايْنغْ إِتّْوَاسّْغضْصنْ ذِي يَاسُوع لْمَاسِيحْ، تّْوَاسّْغضْصنْ ذِي ڒْموْثْ نّسْ؟ \x ◘ \xo 6:‏3 \xt ڭال. 3‏:‏27. \x*
\v 4 أَقَا نتّْوَانْضڒْ أَكِيذسْ س ؤُسغْضصْ ذِي ڒْموْثْ، حِيمَا، أَمْ مَامّشْ د-إِتّْوَاسّْنكَّارْ لْمَاسِيحْ زِي ثَادَّارْثْ ن إِمتِّيننْ غَارْ ؤُعُودْجِي ن بَابَاسْ، أَمُّو إِ غَا نُويُورْ ؤُڒَا ذ نشِّينْ ذِي ثُوذَارْثْ ن جْذِيذْ. \x ◘ \xo 6:‏4 \xt رُوم. 8‏:‏11؛ أَفا. 4‏:‏23؛ فِيل. 3‏:‏10، 11؛ كُول. 2‏:‏12؛ 3‏:‏10؛ عبر. 12‏:‏1؛ 1 بُط. 2‏:‏2. \x*
\v 5 مِينْزِي مَاڒَا نتّْوَاژُّو \add ذِي ثمُّورْثْ\add* ذ إِجّنْ أَكِيذسْ س \add ثفْرَاسْ ن\add* ڒْموْثْ نّسْ، خنِّي أَمُّو إِ غَا نِيڒِي عَاوذْ \add ذ إِجّنْ أَكِيذسْ\add* س ثفْرَاسْ ن ثْنُوكْرَا نّسْ. \x ◘ \xo 6:‏5 \xt رُوم. 8‏:‏11؛ كُول. 3‏:‏1. \x*
\v 6 أَقَا نسّنْ بلِّي بْنَاذمْ نّغْ أَقْذِيمْ إِتّْوَاصلّبْ أَكِيذسْ، حِيمَا أَذْ ثبْضڒْ أَرِّيمثْ ن دّنْبْ، وَارْ نْذِيكّْوِيڒْ عَاوذْ ذ إِمْسخَّارنْ إِ دّنْبْ. \x ◘ \xo 6:‏6 \xt ڭال. 2‏:‏20؛ 5‏:‏24؛ فِيل. 3‏:‏10؛ 1 بُط. 4‏:‏1، 2. \x*
\v 7 مِينْزِي ونِّي إِمُّوثنْ، أَقَا إِتّْوَافكّْ زِي دّْنُوبْ. \x ◘ \xo 6:‏7 \xt 1 بُط. 4‏:‏1. \x*
\m 
\v 8 مَاڒَا خنِّي نمُّوثْ أَكْ-ذ لْمَاسِيحْ، أَقَا نُومنْ بلِّي ندَّارْ \add عَاوذْ\add* أَكِيذسْ، أَكْ-ذ لْمَاسِيحْ. \x ◘ \xo 6:‏8 \xt 2 تِيم. 2‏:‏11. \x*
\v 9 مِينْزِي نسّنْ بلِّي لْمَاسِيحْ إِتّْوَاسّْنكَّارْ-د زِي ثَادَّارْثْ ن إِمتِّيننْ، وَارْ إِتّْمتِّي عَاوذْ. أَقَا ڒْموْثْ وَارْ خَاسْ ثْحكّمْ شَا. \x ◘ \xo 6:‏9 \xt أَسَا. 1‏:‏18. \x*
\v 10 مِينْزِي زڭْ ؤُغزْذِيسْ ن ڒْموْثْ إِ إِمُّوثْ، أَقَا إِمُّوثْ إِ دّْنُوبْ إِجّْ ن ؤُمُورْ، مَاشَا زڭْ ؤُغزْذِيسْ ن ثُوذَارْثْ نّسْ، نتَّا إِدَّارْ إِ أَربِّي. \x ◘ \xo 6:‏10 \xt 1 بُط. 2‏:‏24. \x*
\v 11 أَمُّو كنِّيوْ عَاوذْ: حسْبمْ إِخفْ نْومْ ذ إِمتِّيننْ إِ دّنْبْ، \add مَاشَا\add* ذ إِمُودَّارنْ إِ أَربِّي ذِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ.
\m 
\v 12 خنِّي وَارْ تّجِّيمْ دّنْبْ أَذْ إِحْكمْ ذِي أَرِّيمثْ نْومْ إِفنَّانْ، أَڒَامِي أَذْ أَسْ ثطَّاعمْ ذِي نّشْوَاثْ نّسْ،
\v 13 ؤُشَا وَارْ تّوْشِيمْ إِغزْذِيسنْ \add ن أَرِّيمثْ\add* نْومْ أَمْ دُّوزَانْ إِ ڒْمُوعْصِييّثْ، مَاشَا وْشمْ إِخفْ نْومْ إِ أَربِّي، أَمْ إِوْذَانْ إِنِّي إِذوْڒنْ غَارْ ثُوذَارْثْ زڭْ إِمتِّيننْ، ؤُشَا \add وْشمْ\add* إِغزْذِيسنْ \add ن أَرِّيمثْ\add* نْومْ أَمْ دُّوزَانْ إِ ثْسڭْذَا ن أَربِّي. \x ◘ \xo 6:‏13 \xt لك. 1‏:‏74؛ رُوم. 12‏:‏1؛ ڭال. 2‏:‏20؛ عبر. 9‏:‏14؛ 1 بُط. 4‏:‏2. \x*
\v 14 دّنْبْ وَارْ خَاومْ إِحكّمْ شَا، مِينْزِي وَارْ ثدْجِيمْ سَاذُو شَّارِيعَا مَاشَا سَاذُو أَرْضَا.
\b
\s1 إِمْسخَّارنْ ن ثْسڭْذَا
\m 
\v 15 مَامّشْ خنِّي؟ مَا أَذْ نخْضَا مِينْزِي وَارْ ندْجِي شَا سَاذُو شَّارِيعَا، مَاشَا سَاذُو أَرْضَا؟عمَّارْصْ!
\v 16 مَا وَارْ ثسِّينمْ شَا أَقَا كنِّيوْ ذ إِمْسخَّارنْ ن ونِّي ؤُمِي ثوْشِيمْ إِخفْ نْومْ مَاحنْذْ أَذْ أَسْ ثْسخَّارمْ س طَّاعثْ، ن ونِّي ؤُمِي ثتّطَّاعمْ، مَا إِ دّنْبْ إِ ثتّطَّاعمْ نِيغْ إِ ثْسڭْذَا؟ \x ◘ \xo 6:‏16 \xt يُوح. 8‏:‏34؛ 2 بُط. 2‏:‏19. \x*
\m 
\v 17 ثْقَاذْ أَسْ إِ أَربِّي، أَقَا كنِّيوْ إِنِّي ثُوغَا ذ إِمْسخَّارنْ إِ دّنْبْ، أَقَا ثْذوْڒمْ ثتّطَّاعمْ س وُوڒْ إِ دَّابْ \add إِصْفَانْ\add* ن ؤُسڒْمذْ إِ ذ أَومْ إِتّْوَاسلّْمنْ.
\v 18 ڒَامِي ثتّْوَافكّمْ زِي دّنْبْ، ثْذوْڒمْ ذ إِمْسخَّارنْ ن ثْسڭْذَا. \x ◘ \xo 6:‏18 \xt يُوح. 8‏:‏32؛ ڭال. 5‏:‏1؛ 1 بُط. 2‏:‏16. \x*
\v 19 سَّاوَاڒغْ خْ ڒحْسَابْ ڒعْقڒْ ن بْنَاذمْ خْ سِّيبّثْ ن ثُوضْعفْثْ ن ويْسُومْ نْومْ، مِينْزِي أَمْ مَامّشْ ثوْشِيمْ إِغزْذِيسنْ نْومْ ذ إِمْسخَّارنْ إِ ڒخْمجْ ذ مِينْ وَارْ إِسڭّْذنْ، أَمنِّي ڒخُّو وْشمْ إِغزْذِيسنْ نْومْ ذ إِمْسخَّارنْ إِ ثْسڭْذَا ذ ثْقدَّاسْثْ.
\v 20 مِينْزِي ڒَامِي ثُوغَا كنِّيوْ ذ إِمْسخَّارنْ ن دّنْبْ، ثُوغَا كنِّيوْ ذ إِحُورِّييّنْ زِي جِّيهثْ ن ثْسڭْذَا. \x ◘ \xo 6:‏20 \xt يُوح. 8‏:‏34. \x*
\v 21 مَانْ ڒْغِيدْجثْ إِ ثُوغَا غَارْومْ ڒخْذنِّي؟ ثِيمسْڒَايِينْ إِ زِي ثتّْسضْحَامْ ڒخُّو؟ س مِينْزِي أَنڭَّارْ نْسنْثْ ذ ڒْموْثْ.
\v 22 \add مَاشَا\add* ڒخُّو، ؤُمِي ثتّْوَافكّمْ زِي دّنْبْ ؤُشَا ثْذوْڒمْ ذ إِمْسخَّارنْ ن أَربِّي، أَقَا ڒْغِيدْجثْ نْومْ ثتّْوَاقدّسْ ؤُشَا ؤُنڭَّارْ نّسْ ذ ثُوذَارْثْ إِتّْذُومَانْ.
\v 23 مِينْزِي ڒخْڒَاصْ ن دّنْبْ ذ ڒْموْثْ، مَاشَا ثَاوْهِيبْثْ ن أَربِّي ذ ثُوذَارْثْ إِتّْذُومَانْ س سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 6:‏23 \xt أَمز. 2‏:‏17؛ رُوم. 5‏:‏12؛ 1 كُور. 15‏:‏21؛ يَاع. 1‏:‏15. \x*
\b
\b
\c 7
\s1 أَمتِّيڒْ ن ڒمْڒَاشْ
\m 
\v 1 مَا وَارْ ثسِّينمْ شَا، \add أَ\add* أَيْثْمَا، سَّاوَاڒغْ أَكْ-ذ يِينِّي إِسّْننْ شَّارِيعَا، أَقَا شَّارِيعَا ثْصدْجضْ خْ بْنَاذمْ مِينْ غَا يكّْ إِدَّارْ؟
\v 2 ثَامْغَارْثْ ثقّنْ غَارْ ورْيَازْ نّسْ س شَّارِيعَا مِينْ غَا يكّْ إِدَّارْ، مَاشَا مَاڒَا إِمُّوثْ ورْيَازْ نّسْ، أَقَا ثتّْوَافكّْ زِي شَّارِيعَا زِي جِّيهثْ ن ورْيَازْ نّسْ. \x ◘ \xo 7:‏2 \xt 1 كُور. 7‏:‏2، 10، 39. \x*
\v 3 مَاشَا مَاڒَا أَذْ ثقّنْ غَارْ ورْيَازْ نّغْنِي مِينْ غَا يكّْ ورْيَازْ إِدَّارْ، ثتّْوَاحْسبْ زَّايسْ أَقَا نتَّاثْ ثزْنَا. مَاشَا مَاڒَا إِمُّوثْ ورْيَازْ نّسْ، أَذْ ثَافْ أَذْ ثتّْوَافكّْ زِي شَّارِيعَا، أَقَا وَارْ ثزْنِي مَاڒَا ثمْڒشْ أَكْ-ذ ورْيَازْ نّغْنِي. \x ◘ \xo 7:‏3 \xt مت. 5‏:‏32. \x*
\v 4 خنِّي، \add أَ\add* أَيْثْمَا، كنِّيوْ عَاوذْ أَقَا ثمُّوثمْ إِ شَّارِيعَا س أَرِّيمثْ ن لْمَاسِيحْ، حِيمَا أَذْ ثْذوْڒمْ إِ ونّغْنِي إِ ونِّي د-إِكَّارنْ زِي ثَادَّارْثْ ن إِمتِّيننْ، حِيمَا أَذْ ثوْشمْ ڒْغِيدْجثْ إِ أَربِّي. \x ◘ \xo 7:‏4 \xt ڭال. 2‏:‏19؛ 1 بُط. 4‏:‏1. \x*
\v 5 مِينْزِي ؤُمِي ذ أَنغْ ثُوغَا ذڭْ ويْسُومْ، ثُوغَا شّهْوَاثْ ن دّْنُوبْ خدّْمنْثْ ذڭْ إِغزْذِيسنْ \add ن أَرِّيمثْ\add* نّغْ أَمْ تّْوَاعَارْننْثْ زِي شَّارِيعَا أَڒَامِي غَا أَوْينْثْ ڒْغِيدْجثْ إِ ڒْموْثْ.
\v 6 مَاشَا ڒخُّو أَقَا نتّْوَافكّْ زِي شَّارِيعَا، أَقَا نمُّوثْ خْ مِينْ ذِي ثُوغَا نتّْوَاحْبسْ، حِيمَا أَذْ نعْبذْ \add أَربِّي\add* س ثجْذِيذثْ ن أَرُّوحْ، وَارْ إِدْجِي ذِي صِّيفثْ ثَاقْذِيمْثْ ن ثِيرَا \add إِقدّْسنْ\add*. \f ◼ \fr 7:‏6 \ft \bd 'وَارْ إِدْجِي ذِي صِّيفثْ ثَاقْذِيمْثْ ن ثِيرَا \bdit إِقدّْسنْ\bdit*'\bd* - ثِيرَا إِقدّْسنْ سَّاوَاڒنْثْ خْ يَاسُوع لْمَاسِيحْ. نتَّا ذ أَثَارَّاسْ أَمزْوَارُو ن وذْلِيسْ إِقدّْسنْ زڭْ وذْلِيسْ ؤُمزْوَارُو أَڒْ أَذْلِيسْ ن ؤُسَارْڭبْ غَارْ ؤُنڭَّارْ نّسْ. ونِّي إِقَّارنْ أَذْلِيسْ إِقدّْسنْ (إِخْسْ أَذْ يِينَا ثِيرَا إِقدّْسنْ) نحْڒَا مَا إِسّنْ ؤُثَارَّاسْ أَمزْوَارُو ن وذْلِيسْ، إِدْجْ ذِي ثقْذِيمْثْ ن ثِيرَا إِقدّْسنْ، إِخْسْ أَذْ يِينِي، نتَّا إِقَّارْ بْڒَا مَا إِتّْوَاڒِي أَثَارَّاسْ نِّي أَمزْوَارُو، نتَّا أَمْ إِجّْ ن بْنَاذمْ ذ أَذَارْغَاڒْ. أَذْلِيسْ إِ إِقَّارْ، وَارْ إِدَّارْ إِ نتَّا، مَاشَا إِ نتَّا ذ أَذْلِيسْ نِّي أَمْ إِجّْ ن ؤُمتَّا. س ؤُينِّي ونِّي إِقَّارنْ أَمُّو، أَقَا نتَّا ذِي ثقْذِيمْثْ ن ثِيرَا إِقدّْسنْ، وَارْ إِدْجِي ذِي ثْمَايْنُوثْ ن أَرُّوحْ. مَاغَارْ مْغِيرْ مَاڒَا إِجّْ ن بْنَاذمْ إِسّنْ يَاسُوع لْمَاسِيحْ س وُوڒْ ؤُ س لِيمَانْ، أَذْ إِقْبڒْ أَرُّوحْ إِقدّْسنْ ؤُڒَا ذ ثَامَايْنُوثْ ن أَرُّوحْ ذِي ذَاخڒْ نّسْ ؤُشَا أَذْ إِغَارْ أَذْلِيسْ إِقدّْسنْ س يِيجّْ ن شّكْلْ ذ جْذِيذْ، مِينْزِي يَاسُوع لْمَاسِيحْ نتَّا ذ أَثَارَّاسْ أَمزْوَارُو ن وذْلِيسْ إِقدّْسنْ.\f*  \x ◘ \xo 7:‏6 \xt رُوم. 2‏:‏29؛ 2 كُور. 3‏:‏6. \x*
\b
\s1 أَمنْغِي أَكْ-ذ دّْنُوبْ
\m 
\v 7 مِينْ غَا نِينِي خنِّي؟ مَا شَّارِيعَا ذ دّنْبْ؟عمَّارْصْ! مَاشَا وَارْ سِّينغْ دّنْبْ مْغِيرْ س شَّارِيعَا وَاهَا، مَاغَارْ وَارْ سِّينغْ نّشْوثْ مَاڒَا وَارْ ثنِّي شَّارِيعَا: ”وَارْ تَّاسمْ!“ \x ◘ \xo 7:‏7 \xt ؤُف. 20‏:‏17؛ أَعَوذ. 5‏:‏21؛ رُوم. 3‏:‏20؛ عبر. 7‏:‏18. \x*
\v 8 مَاشَا دّنْبْ يُوفَا لْفُورْصَا س ثوْصيّثْ ؤُشَا ثڭْمَا ذَايِي كُوڒْ نّشْوثْ، مِينْزِي بْڒَا شَّارِيعَا دّنْبْ إِمُّوثْ. \x ◘ \xo 7:‏8 \xt يُوح. 15‏:‏22؛ رُوم. 4‏:‏15؛ 5‏:‏20؛ ڭال. 3‏:‏19. \x*
\v 9 زِيشْ ثُوغَا دَّارغْ بْڒَا شَّارِيعَا، مَاشَا ؤُمِي د-ثُوسَا ثوْصيّثْ، إِبْذَا دّنْبْ أَذْ إِدَّارْ، ؤُشَا مُّوثغْ.
\v 10 ؤُفِيغْ بلِّي ثَاوْصيّثْ إِ إِدْجَانْ إِ ثُوذَارْثْ ثْندّهْ غَارْ ڒْموْثْ.
\v 11 مِينْزِي دّنْبْ أَمْ يُوفَا لْفُورْصَا س ثوْصيّثْ، إِشْمثْ أَيِي ؤُشَا إِنْغَا أَيِي زَّايسْ.
\v 12 خنِّي شَّارِيعَا إِقدّْسنْ إِ ثدْجَا ؤُ ثَاوْصيّثْ إِقدّْسنْ إِ ثدْجَا، ثْسڭّذْ ؤُ ثصْبحْ. \x ◘ \xo 7:‏12 \xt 1 تِيم. 1‏:‏8. \x*
\m 
\v 13 مَا إِذْوڒْ أَيِي مِينْ إِدْجَانْ ذ أَصبْحَانْ ذ ڒْموْثْ إِنُو؟عمَّارْصْ! مَاشَا دّنْبْ، حِيمَا أَذْ إِبَانْ ذ دّنْبْ، إِسّڭْمَا ذَايِي ڒْموْثْ س مِينْ إِدْجَانْ ذ أَصبْحَانْ، حِيمَا أَذْ إِذْوڒْ دّنْبْ ذ دّنْبْ كْثَارْ س ثوْصِييّثْ.
\v 14 أَقَا نسّنْ بلِّي شَّارِيعَا ن أَرُّوحْ إِ ثدْجَا، مَاشَا نشّْ ذ أَيْسُومْ، مّنْزغْ إِ دّنْبْ، \x ◘ \xo 7:‏14 \xt إِشا. 52‏:‏3. \x*
\v 15 مِينْزِي وَارْ سِّينغْ مِينْ غَا ڭّغْ، ؤُشَا مِينْ خْسغْ، وَارْ ث تّڭّغْ، مَاشَا مِينْ شَارّْهغْ ذ مَانَاونِّي إِ تّڭّغْ. \x ◘ \xo 7:‏15 \xt ڭال. 5‏:‏17. \x*
\v 16 مَاڒَا تّڭّغْ مِينْ وَارْ تّخْسغْ، أَذْ وَافْقغْ أَكْ-ذ شَّارِيعَا، بلِّي أَقَا نتَّاثْ ثصْبحْ.
\v 17 مَاشَا ڒخُّو نشّْ وَارْ تّڭّغْ مَانْ أَيَا \add عَاذْ\add*، مَاشَا دّنْبْ إِ ذ أَيِي إِزدّْغنْ \add إِتّڭّْ إِ-ث\add*.
\v 18 مِينْزِي سّْنغْ وَارْ ذَايِي إِزدّغْ مِينْ إِشْنَانْ، إِخْسْ أَذْ يِينِي ذڭْ ويْسُومْ إِنُو. مِينْزِي إِهْونْ خَافِي مَاحنْذْ أَذْ خْسغْ ثْشُونِي، مَاشَا وَارْ زمَّارغْ أَذْ ت ڭّغْ. \x ◘ \xo 7:‏18 \xt أَمز. 6‏:‏5؛ 8‏:‏21. \x*
\v 19 مِينْزِي وَارْ تّڭّغْ ثْشُونِي إِ خْسغْ، مَاشَا ڒْغَارْ إِ وَارْ تّخْسغْ شَا، ذ مَانَاونِّي إِ تّڭّغْ.
\v 20 مَاڒَا تّڭّغْ مِينْ وَارْ تّخْسغْ، وَارْ إِدْجِي عَاذْ ذ نشّْ إِ إِتّڭّنْ مَانْ أَيَا، مَاشَا دّنْبْ ونِّي ذ أَيِي إِزدّْغنْ.
\m 
\v 21 خنِّي تَّافغْ إِشْثْ ن شَّارِيعَا ثنِّي ثُوسَا-د أَكْ-ذ ثْنفْسشْثْ إِنُو، ثنِّي إِخْسنْ أَذْ إِڭّْ ثْشُونِي، أَمْ يُوذسْ أَيِي-د ڒْغَارْ.
\v 22 مِينْزِي فَارْحغْ س شَّارِيعَا ن أَربِّي زِي جِّيهثْ ن بْنَاذمْ نِّي إِدْجَانْ ذِي ذَاخڒْ إِنُو، \x ◘ \xo 7:‏22 \xt أَفا. 3‏:‏16. \x*
\v 23 مَاشَا تّْوَاڒِيغْ ذِينْ شَّارِيعَا نّغْنِي ذڭْ إِغزْذِيسنْ \add ن أَرِّيمثْ\add* إِنُو، ثتّْمنْغَا أَكْ-ذ شَّارِيعَا ن ڒعْقڒْ إِنُو ؤُشَا ثْحبّسْ أَيِي س شَّارِيعَا ن دّنْبْ ثنِّي إِدْجَانْ ذڭْ إِغزْذِيسنْ \add ن أَرِّيمثْ\add* إِنُو. \x ◘ \xo 7:‏23 \xt ڭال. 5‏:‏17. \x*
\b
\m 
\v 24 أَيحَّاثْ مَانَا ومْشُومْ-أَ ن بْنَاذمْ إِ دْجِيغْ! وِي ذ أَيِي غَا إِسّْنجْمنْ زِي أَرِّيمثْ-أَ ن ڒْموْثْ؟
\m 
\v 25 تّْقَاذِيغْ أَربِّي، \add ونِّي إِ ذ أَيِي إِسّنْجْمنْ\add* س ؤُفُوسْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ!
\b
\m أَمُّو أَقَا نشّْ سِيمَانْثْ إِنُو س ڒعْقڒْ إِ خدّْمغْ إِ شَّارِيعَا ن أَربِّي، مَاشَا ذڭْ ويْسُومْ إِنُو إِ شَّارِيعَا ن دّنْبْ.
\b
\b
\c 8
\s1 ثُوذَارْثْ س أَرُّوحْ إِقدّْسنْ
\m 
\v 1 خنِّي وَارْ ذِينِّي بُو ڒْحُوكْمْ خْ يِينِّي إِڭُّورنْ وَارْ إِدْجِي \add عَاذْ\add* ذڭْ ويْسُومْ س يَاسُوع لْمَاسِيحْ.
\v 2 مِينْزِي شَّارِيعَا ن أَرُّوحْ ن ثُوذَارْثْ ذِي يَاسُوع لْمَاسِيحْ، أَقَا ثْفكّْ أَشْ زِي شَّارِيعَا ن دّنْبْ ذ ڒْموْثْ. \x ◘ \xo 8:‏2 \xt يُوح. 8‏:‏36؛ رُوم. 6‏:‏18، 22؛ ڭال. 5‏:‏1. \x*
\v 3 مِينْزِي مَاغَارْ ثُوغَا شَّارِيعَا ثضْعفْ س ثُوضْعفْثْ ن ويْسُومْ، إِسّكّْ-د أَربِّي مِّيسْ ذِي صِّيفثْ ن ويْسُومْ ن دّنْبْ خْ سِّيبّثْ ن دّنْبْ، مَاحنْذْ أَذْ إِحَاسبْ دّنْبْ ذڭْ ويْسُومْ، \x ◘ \xo 8:‏3 \xt ڒخ. 13‏:‏39؛ رُوم. 3‏:‏28؛ ڭال. 2‏:‏16؛ عبر. 7‏:‏18. \x*
\v 4 حِيمَا أَذْ ذَايْنغْ ثتّْوَاكمّڒْ ثَاسڭْذَا ن شَّارِيعَا، مَاحنْذْ وَارْ نڭُّورْ ذڭْ ويْسُومْ، مَاشَا ذِي أَرُّوحْ.
\v 5 مِينْزِي إِنِّي إِدْجَانْ ذڭْ ويْسُومْ تّڭّنْ نّيّثْ نْسنْ ذڭْ ويْسُومْ، مَاشَا إِنِّي ن أَرُّوحْ تّڭّنْ نّيّثْ نْسنْ ذِي أَرُّوحْ. \x ◘ \xo 8:‏5 \xt 1 كُور. 2‏:‏14. \x*
\v 6 مِينْزِي نّيّثْ ن ويْسُومْ ذ ڒْموْثْ، مَاشَا نّيّثْ ن أَرُّوحْ ذ ثُوذَارْثْ ذ ڒهْنَا.
\v 7 مِينْزِي نّيّثْ ن ويْسُومْ، أَقَا-ت ذ ڒعْذَاوَاثْ إِ أَربِّي، مِينْزِي وَارْ ثتّڭّْ شَا أَرَّايْ إِ شَّارِيعَا ن أَربِّي، مَاغَارْ وَارْ ذ أَسْ ثْزمَّارْ.
\v 8 إِنِّي إِدْجَانْ ذڭْ ويْسُومْ وَارْ إِزمَّارنْ أَذْ أَرْضَانْ أَربِّي.
\m 
\v 9 مَاشَا كنِّيوْ وَارْ ثدْجِيمْ شَا ذڭْ ويْسُومْ، مَاشَا ذِي أَرُّوحْ مَاڒَا إِزْذغْ ذَايْومْ أَرُّوحْ ن أَربِّي. مَاشَا مَاڒَا حذْ وَارْ غَارسْ بُو أَرُّوحْ ن لْمَاسِيحْ، ذ ونِّي وَارْ إِتِّيڒِي نّسْ. \x ◘ \xo 8:‏9 \xt 1 كُور. 3‏:‏16. \x*
\v 10 مَاڒَا ذَايْومْ لْمَاسِيحْ، أَقَا أَرِّيمثْ ثمُّوثْ زِي سِّيبّثْ ن دّْنُوبْ، مَاشَا أَرُّوحْ إِدَّارْ زِي سِّيبّثْ ن ثْسڭْذَا.
\v 11 مَاڒَا إِزْذغْ ذَايْومْ أَرُّوحْ ن ونِّي د-إِسّْنكَّارنْ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ زِي ثَادَّارْثْ ن إِمتِّيننْ، أَقَا ونِّي د-إِسّْنكَّارنْ يَاسُوع لْمَاسِيحْ زِي ثَادَّارْثْ ن إِمتِّيننْ أَذْ إِسّدَّارْ عَاوذْ أَرِّيمَاثْ نْومْ إِفنَّانْ س أَرُّوحْ نّسْ إِ إِزدّْغنْ ذَايْومْ. \x ◘ \xo 8:‏11 \xt رُوم. 6‏:‏4، 5؛ 1 كُور. 6‏:‏14؛ 2 كُور. 4‏:‏14؛ أَفا. 2‏:‏5؛ كُول. 2‏:‏13. \x*
\m 
\v 12 خنِّي، \add أَ\add* أَيْثْمَا، أَقَا أَنغْ س ؤُمَارْوَاسْ، \add مَاشَا\add* وَارْ إِدْجِي إِ ويْسُومْ، حِيمَا أَذْ ندَّارْ خْ ڒحْسَابْ ن ويْسُومْ،
\v 13 مِينْزِي مَاڒَا ثدَّارمْ خْ ڒحْسَابْ ن ويْسُومْ، أَذْ ثمْثمْ. مَاشَا مَاڒَا ثتَّارِّيمْ أَذْ مّْثنْثْ ڒخْذَايمْ ن أَرِّيمثْ س أَرُّوحْ، أَذْ ثدَّارمْ.
\v 14 مِينْزِي مَارَّا إِنِّي إِتّْوَانذْهنْ س أَرُّوحْ ن أَربِّي، نِيثْنِي ذ أَرَّاونْ ن أَربِّي. \x ◘ \xo 8:‏14 \xt ڭال. 5‏:‏18. \x*
\v 15 مِينْزِي كنِّيوْ وَارْ ثكْسِيمْ شَا أَرُّوحْ ن ثسْمُوغِي \add ونِّي كنِّيوْ إِ غَا يَارّنْ ذ إِسمْغَانْ\add*، حِيمَا أَذْ ثڭّْوذمْ عَاوذْ، مَاشَا أَقَا ثكْسِيمْ أَرُّوحْ إِ زِي نتّْوَاقْبڒْ ذ أَرَّاونْ، إِ زِي نتّْڒَاغَا: ’ثَابَابَاثْ، بَابَاثْنغْ!‘ \x ◘ \xo 8:‏15 \xt إِشا. 56‏:‏5؛ 1 كُور. 2‏:‏12؛ ڭال. 3‏:‏26؛ 4‏:‏5، 6؛ 2 تِيم. 1‏:‏7. \x*
\v 16 أَرُّوحْ نِّي سِيمَانْثْ نّسْ إِشهّذْ أَكْ-ذ أَرُّوحْ نّغْ، بلِّي نشِّينْ ذ أَرَّاونْ ن أَربِّي. \x ◘ \xo 8:‏16 \xt 2 كُور. 1‏:‏22؛ 5‏:‏5؛ أَفا. 1‏:‏13؛ 4‏:‏30. \x*
\v 17 مَاڒَا نشِّينْ ذ أَرَّاونْ، أَقَا أَنغْ عَاوذْ ذ إِوْرِيثنْ، إِوْرِيثنْ ن أَربِّي ذ إِوْرِيثنْ أَكْ-ذ يَاسُوع لْمَاسِيحْ، مَاغَارْ مَاڒَا نْودّبْ أَكِيذسْ، أَذْ نتّْوَاعُودْجِي أَكِيذسْ عَاوذْ. \x ◘ \xo 8:‏17 \xt 2 تِيم. 2‏:‏11، 12. \x*
\m 
\v 18 نشّْ تّْوَاسّْقنْعغْ بلِّي أَودّبْ إِ خَانغْ إِتّكّنْ إِضَا، وَارْ إِسْذِيهدْجْ شَا أَذْ إِتّْوَاعْبَارْ س ؤُعُودْجِي إِ د غَا إِتّْوَاسّضْهَارنْ ذَايْنغْ. \x ◘ \xo 8:‏18 \xt مت. 5‏:‏12؛ 2 كُور. 4‏:‏10، 17؛ فِيل. 3‏:‏20؛ 1 بُط. 4‏:‏13؛ 1 يُوح. 3‏:‏1، 2. \x*
\v 19 مِينْزِي مَارَّا مِينْ د-إِتّْوَاخڒْقنْ إِخزَّارْ س ؤُسِيثمْ ذ ؤُرَاجِي غَارْ ؤُسَارْڭبْ ن وَارَّاونْ ن أَربِّي.
\v 20 مِينْزِي مَارَّا مِينْ د-إِتّْوَاخڒْقنْ أَقَا إِتّْوَاڭّْ ذِي ڒْبَاطڒْ، وَارْ إِدْجِي س ڒْخَاضَارْ، مَاشَا س ونِّي ث إِڭِّينْ ذِي ڒْبَاطڒْ
\v 21 س ؤُسِيثمْ بلِّي مَارَّا مِينْ د-إِتّْوَاخڒْقنْ أَذْ إِتّْوَافكّْ عَاوذْ زِي ثسْمُوغِي إِ ڒْغشّْ غَارْ ثِيڒلِّي ن ؤُعُودْجِي ن وَارَّاونْ ن أَربِّي.
\v 22 أَقَا نسّنْ بلِّي مَارَّا مِينْ د-إِتّْوَاخڒْقنْ إِزهَّارْ جْمِيعْ س ؤُنزْبَارْ ن ثَارْوَا أَڒْ أَسّْ-أَ. \x ◘ \xo 8:‏22 \xt أَسَا. 5‏:‏13\x*
\m 
\v 23 وَارْ إِدْجِي نِيثْنِي وَاهَا، مَاشَا ؤُڒَا ذ نشِّينْ، إِنِّي غَارْ ثدْجَا ذَايْنغْ \add ڒْْغِيدْجثْ\add* ثَامزْوَارُوثْ ن أَرُّوحْ، نْزهَّارْ ذڭْ إِخفْ نّغْ، نتّْرَاجَا أَذْ نتّْوَاقْبڒْ ذ مِّيسْ، ؤُڒَا ذ أَفكِّي ن أَرِّيمَاثْ نّغْ. \x ◘ \xo 8:‏23 \xt لك. 21‏:‏28. \x*
\v 24 س ؤُينِّي ندَّارْ ذڭْ ؤُسِيثمْ نِّي. مَاشَا أَسِيثمْ إِتّْبَاننْ وَارْ إِدْجِي ذ أَسِيثمْ، مِينْزِي مِينْ إِتّْبَاننْ إِ حذْ، مَامّشْ غَا يڭّْ أَذْ ذَايسْ إِسِّيثمْ عَاذْ؟
\v 25 مَاشَا مَاڒَا نسِّيتِّيمْ ذِي مِينْ وَارْ نتّْوِيڒِي، أَقَا نتّْرَاجَا ث س صّْبَارْ.
\v 26 ذِي مَانْ أَيَا إِتّْعَاوَانْ أَنغْ أَرُّوحْ عَاوذْ ذِي ثضْعفْثْ نّغْ، مِينْزِي وَارْ نسِّينْ شَا مَامّشْ ذ أَنغْ إِ غَا إِشُووَّارْ أَذْ نژَّادْجْ، مَاشَا أَرُّوحْ سِيمَانْثْ نّسْ إِتّْژَادْجْ ذِي طّْوعْ نّغْ س زّْهِيرْ وَارْ إِنطْقنْ. \x ◘ \xo 8:‏26 \xt مت. 20‏:‏22؛ يَاع. 4‏:‏3. \x*
\m 
\v 27 مَاشَا ونِّي إِتّْبقّْشنْ ذڭْ وُوڒَاونْ إِسّنْ مِينْ إِدْجَانْ ذ نّيّثْ ن أَرُّوحْ، أَقَا إِتّْژَادْجْ ذِي طّْوعْ ن إِمْقدَّاسنْ أَمْ مَامّشْ ث إِخْسْ أَربِّي.
\v 28 نشِّينْ نسّنْ أَقَا نتَّا إِعَاونْ ذِي كُوڒْشِي إِ ڒْخَارْ إِ يِينِّي إِتّخْسنْ أَربِّي، إِنِّي إِعدْجمْ إِ-ثنْ قْبڒْ مَاحنْذْ أَذْ تّْوَاڒَاغَانْ.
\v 29 مِينْزِي إِنِّي إِزْوَارْ إِسّنْ إِ-ثنْ، أَقَا إِزْوَارْ إِعدْجمْ إِ-ثنْ حِيمَا أَذْ أَرْوسنْ ذِي صِّيفثْ ن مِّيسْ، حِيمَا أَذْ يِيڒِي نتَّا ذ أَمنْزُو جَارْ وَاطَّاسْ ن وَاوْمَاثنْ. \x ◘ \xo 8:‏29 \xt كُول. 1‏:‏18. \x*
\v 30 ؤُشَا إِنِّي نتَّا إِزَّارْ إِعدْجمْ إِ-ثنْ، أَقَا ذ إِنِّي خْ ذ إِڒَاغَا عَاوذْ، ؤُ إِنِّي خْ ذ إِڒَاغَا، أَقَا ذ إِنِّي إِسڭّذْ عَاوذْ، ؤُ إِنِّي إِسڭّذْ أَقَا ذ إِنِّي إِسّْعُودْجْ عَاوذْ.
\b
\m 
\v 31 مِينْ غَا نِينِي خنِّي ذِي مَانْ أَيَا؟ مَاڒَا أَربِّي أَكِيذْنغْ وِي ذ أَنغْ إِ غَا إِضَادّنْ؟ \x ◘ \xo 8:‏31 \xt ڒخْڒ. 14‏:‏8. \x*
\v 32 ونِّي وَارْ إِشطَّارنْ شَا خْ مِّيسْ، مَاشَا إِوْشَا إِ-ث ذِي طّْوعْ نّغْ مَارَّا، مَامّشْ وَارْ ذ أَنغْ إِتِّيشْ كُوڒْشِي أَكْ-ذ مِّيسْ عَاوذْ؟ \x ◘ \xo 8:‏32 \xt أَمز. 22‏:‏12؛ إِشا. 53‏:‏5؛ يُوح. 3‏:‏16. \x*
\v 33 وِي غَا إِكْسِينْ ثَانْفُوتْشْ إِ يِينِّي إِتّْوَافَارْزنْ زِي أَربِّي؟ أَربِّي ذ ونِّي إِتّْسڭَّاذنْ. \x ◘ \xo 8:‏33 \xt إِشا. 50‏:‏8. \x*
\v 34 وِي غَا إِقْضَانْ ڒْحُوكْمْ؟ لْمَاسِيحْ إِمُّوثْ ؤُ إِكَّارْ-د ؤُ نتَّا \add إِقِّيمْ\add* غَارْ ؤُفُوسِي ن أَربِّي، إِتّْژَادْجْ إِ نشِّينْ. \x ◘ \xo 8:‏34 \xt عبر. 7‏:‏25. \x*
\v 35 مِينْ ذ أَيِي غَا إِبْضَانْ خْ ثَايْرِي ن لْمَاسِيحْ؟ مَا ڒْمحْنثْ، نِيغْ ڒْحبْسْ، نِيغْ أَذَارّشْ، نِيغْ ڒَاژْ، نِيغْ ثُوعَارْينْثْ، نِيغْ لْخَاطَارْ، نِيغْ سِّيفْ؟
\v 36 أَمْ مَامّشْ ثُورَا:
\b
\m \qt ”أَقَا خْ سِّيبّثْ نّشْ نتّْمتَّا كُوڒْ أَسّْ،\qt*
\m \qt نتّْوَاحْسبْ أَمْ إِحُوڒِييّنْ إِ ثْغَارْصْثْ.“\qt* \x ◘ \xo 8:‏36 \xt إِزهد. 44‏:‏23؛ 1 كُور. 4‏:‏9؛ 2 كُور. 4‏:‏11. \x*
\b
\m 
\v 37 مَاشَا ذِي مَانْ أَيَا مَارَّا نذْوڒْ زڭْ إِنِّي إِغلَّابنْ س ونِّي ذ أَنغْ إِخْسنْ.
\v 38 أَقَا نشّْ تّْوَاسّْقنْعغْ بلِّي نِيغْ ڒْموْثْ، نِيغْ ثُوذَارْثْ، نِيغْ لْمَالَاكَاثْ، نِيغْ ڒْحُوكَّامْ، نِيغْ صُّولَاطَاثْ، نِيغْ مِينْ ن يِيضَا، نِيغْ مِينْ إِ د غَا يَاسنْ،
\v 39 نِيغْ ڒُوعْڒَا، نِيغْ رَادْجَاغْ، نِيغْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ نّغْنِي زِي مِينْ د-إِتّْوَاخڒْقنْ، ثْزمَّارْ أَذْ أَنغْ ثبْضَا خْ ثَايْرِي ن أَربِّي، ثنِّي ذِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ.
\b
\b
\c 9
\s1 أَربِّي ذ ڒْڭنْسْ نّسْ إِسْرَائِيل
\m 
\v 1 قَّارغْ ثِيذتّْ ذِي لْمَاسِيحْ، وَارْ سّْخَارِّيقغْ شَا، ؤُشَا ثَانفْسشْثْ إِنُو ثْشهّذْ ذَايِي س أَرُّوحْ إِقدّْسنْ، \x ◘ \xo 9:‏1 \xt رُوم. 1‏:‏9؛ 2 كُور. 1‏:‏23؛ 11‏:‏31؛ ڭال. 1‏:‏20؛ فِيل. 1‏:‏8؛ 1 تس. 2‏:‏5؛ 5‏:‏27. \x*
\v 2 بلِّي غَارِي أَشْضَانْ إِمْغَارْ ذ ڒحْرِيقْ وَارْ إِتّْبذِّي ذڭْ وُوڒْ إِنُو.
\v 3 ثُوغَا تّْژَادْجِيغْ معْلِيكْ ؤُفِيغْ تّْوَاحَارّْمغْ \add ذِي مُومُّو إِنُو\add* خْ لْمَاسِيحْ \add س إِشْثْ نّعْڒثْ\add* ذِي طّْوعْ ن وَاوْمَاثنْ إِنُو، ڒَادْجْ إِنُو زِي جِّيهثْ ن ويْسُومْ \add ن أَرِّيمثْ\add*. \x ◘ \xo 9:‏3 \xt ؤُف. 32‏:‏32؛ رُوم. 10‏:‏1. \x*
\v 4 أَرَّاونْ ن إِسْرَائِيل، إِنِّي إِتّْوَاقبْڒنْ ذ مِّيسْ. غَارْسنْ إِ يدْجَا ؤُعُودْجِي، ڒْعُوهُوذْ، شَّارِيعَا، ثَاسخَّارْثْ \add إِ إِدْجَانْ ذِي زَّاوشْثْ إِقدّْسنْ\add* إِ غَارسْ د-إِقّْننْ، لْوُوعُوذْ ذ ڒجْذُوذْ. \x ◘ \xo 9:‏4 \xt ؤُف. 4‏:‏22؛ أَعَوذ. 7‏:‏6؛ رُوم. 2‏:‏17؛ 3‏:‏2؛ أَفا. 2‏:‏12. \x*
\v 5 زَّايْسنْ إِ د-إِبَانْ لْمَاسِيحْ خْ وبْرِيذْ ن ويْسُومْ \add ن أَرِّيمثْ\add* ونِّي ذ أَربِّي خْ مَارَّا. إِ نتَّا إِ غَا يِيڒِي \add مَارَّا\add* أَسمْغَارْ ذ \add مَارَّا\add* لْبَارَاكَا إِ ڒبْذَا قَاعْ. أَمِينْ! \x ◘ \xo 9:‏5 \xt إِرْم. 23‏:‏6؛ يُوح. 1‏:‏1؛ ڒخ. 20‏:‏28؛ رُوم. 1‏:‏4؛ عبر. 1‏:‏8، 9، 10. \x*
\m 
\v 6 مَاشَا وَارْ إِدْجِي أَڒَامِي أَوَاڒْ ن أَربِّي وَارْ يِيوِيضْ، مِينْزِي مَارَّا إِنِّي زِي إِسْرَائِيل وَارْ دْجِينْ شَا ذ إِسْرَائِيل. \x ◘ \xo 9:‏6 \xt ڒخْڒ. 23‏:‏19؛ يُوح. 8‏:‏39؛ رُوم. 2‏:‏28؛ 3‏:‏3؛ 2 تِيم. 2‏:‏13. \x*
\v 7 ؤُشَا ؤُڒَا ذ مَارَّا نِيثْنِي وَارْ دْجِينْ شَا ذ ثَارْوَا ن إِبْرَاهِيمْ، مِينْزِي نِيثْنِي زِي زَّارِيعثْ ن إِبْرَاهِيمْ، مِينْزِي إِتّْوَانَّا: ”ذِي إِسْحَاقْ أَذْ أَشْ ڒَاغَانْ زَّارِيعثْ.“ \x ◘ \xo 9:‏7 \xt أَمز. 21‏:‏12؛ ڭال. 3‏:‏29؛ 4‏:‏23؛ عبر. 11‏:‏18. \x*
\v 8 مَانْ أَيَا وَارْ إِخْسْ أَذْ يِينِي أَقَا ثَارْوَا عْلَاحْصَابْ جَّاذِيرَا ن أَرِّيمثْ أَقَا-ثنْ ذ ثَارْوَا ن أَربِّي، مَاشَا ثَارْوَا ن لْوَاعْذْ أَذْ تّْوَاحسْبنْ ذ زَّارِيعثْ. \x ◘ \xo 9:‏8 \xt ڭال. 4‏:‏28. \x*
\v 9 مِينْزِي أَوَاڒْ ن لْوَاعْذْ ذ وَا:
\b
\m \qt ”غَارْ ڒْوقْثْ-أَ أَذْ د-أَسغْ\qt*
\m \qt ؤُشَا أَذْ غَارسْ يِيڒِي غَارْ سَارَا مِّيسْ!“\qt* \x ◘ \xo 9:‏9 \xt أَمز. 18‏:‏10. \x*
\b
\m 
\v 10 مَانْ أَيَا وَارْ إِدْجِي وَاهَا ذِي ثْمسْڒَاشْثْ ن سَارَا، مَاشَا ؤُڒَا \add ذِي ثْمسْڒَاشْثْ ن\add* رِيفْقَا، ؤُمِي ثْمُونْ أَكْ-ذ ؤُينِّي ن بْنَاذمْ نِّي، جذِّيثغْ إِسْحَاقْ، \x ◘ \xo 9:‏10 \xt أَمز. 25‏:‏21. \x*
\v 11 ثُوغَا ثِيزَّارْ ثتّْوَاسّنْ ڒِيخْضَارثْ ن أَربِّي ؤُمِي ثُوغَا عَاذْ وَارْ د-خْڒِيقنْ إِحنْجِيرنْ نّسْ، وَارْ زمَّارنْ أَذْ ڭّنْ \add عَاذْ\add* ڒْخَارْ نِيغْ ڒْغَارْ، حِيمَا وَارْ ثتِّيڒِي ثْمسْڒَاشْثْ ذڭْ وبْرِيذْ ن ڒخْذَايمْ، مَاشَا ذڭْ وبْرِيذْ ن ونِّي إِتّْڒَاغَانْ.
\v 12 مَاغَارْ إِتّْوَانَّا \add إِ رِيفْقَا\add*:
\b
\m \qt ”أَقَا أَمقّْرَانْ أَذْ إِسخَّارْ إِ ؤُمژْيَانْ!“،\qt* \x ◘ \xo 9:‏12 \xt أَمز. 25‏:‏23. \x*
\b
\m 
\v 13 أَمْ مَامّشْ ثُورَا:
\b
\m \qt ”يَاعْقُوبْ إِ خْسغْ، مَاشَا شَارْهغْ إِسُو.“\qt* \x ◘ \xo 9:‏13 \xt مـَال. 1‏:‏2‏-‏3. \x*
\b
\m 
\v 14 مِينْ غَا نِينِي خنِّي؟ مَا إِقدّْ أَذْ يِيڒِي غَارْ أَربِّي مِينْ وَارْ إِسڭّْذنْ؟عمَّارْصْ! \x ◘ \xo 9:‏14 \xt أَعَوذ. 32‏:‏4؛ 2 إِم. 19‏:‏7؛ أَيُوبْ 34‏:‏10. \x*
\v 15 خْزَارْ، نتَّا إِنَّا عَاوذْ إِ مُوسَا:
\b
\m \qt ”أَذْ أَرحْمغْ وِي خْسغْ أَذْ أَرحْمغْ،\qt*
\m \qt ؤُشَا أَذْ حِينّغْ خْ وِي خْسغْ أَذْ حِينّغْ.“\qt* \x ◘ \xo 9:‏15 \xt ؤُف. 33‏:‏19. \x*
\b
\m 
\v 16 خنِّي ثَامسْڒَاشْثْ وَارْ ثقِّيمْ شَا غَارْ وِي إِتّخْسنْ ؤُڒَا غَارْ وِي إِتَّازّْڒنْ، مَاشَا غَارْ أَربِّي ونِّي يَارحّْمنْ.
\v 17 مِينْزِي عْلَاحْسَابْ ثِيرَا \add إِقدّْسنْ\add* إِنَّا نتَّا إِ فِيرْعُونْ:
\b
\m \qt ”أَقَا إِ مَانْ أَيَا سّْنكَّارغْ-د شكْ،\qt*
\m \qt حِيمَا أَذْ زَّايكْ سّشْنغْ جّهْذْ إِنُو،\qt*
\m \qt ؤُشَا أَذْ إِتّْوَابَارّحْ إِسمْ إِنُو\qt*
\m \qt ذِي مَارَّا دُّونشْثْ.“\qt* \x ◘ \xo 9:‏17 \xt ؤُف. 9‏:‏16. \x*
\b
\m 
\v 18 خنِّي نتَّا أَذْ يَارْحمْ وِي إِخْسْ، ؤُشَا أَذْ إِسّقْسحْ وِي إِخْسْ.
\b
\m 
\v 19 إِوَا، أَذْ ثَاغْ أَذْ ثِينِيذْ: مَايمِّي إِتّْشثْشَا عَاذْ، مِينْزِي وِي غَا إِمّْعَاڒَانْ أَكْ-ذ مِينْ إِخْسْ نتَّا؟
\v 20 مَاشَا مِينْ ثعْنِيذْ شكْ، أَ بْنَاذمْ، ونِّي إِتّْقَاشَاحنْ أَربِّي؟ مَا مِينْ إِتّْوَاڭّنْ إِزمَّارْ أَذْ إِنِي إِ ونِّي ث إِڭِّينْ: ”مَايمِّي ذ أَيِي ثڭِّيذْ أَمُّو؟“ \x ◘ \xo 9:‏20 \xt إِشا. 29‏:‏16، 45‏:‏9؛ إِرْم. 18‏:‏6. \x*
\v 21 مَا وَارْ إِدْجِي غَارْ بُو-ثْڒَاخْثْ صُّولْطَا خْ ثْڒَاخْثْ حِيمَا أَذْ إِڭّْ \add زڭْ إِشْثْ ن ڒْعجْنثْ\add* إِشْثْ ن ڒْقشْعثْ إِ لْكَارَامَا ؤُ ونّغْنِي إِ ؤُبهْذڒْ؟ \x ◘ \xo 9:‏21 \xt إِرْم. 18‏:‏4‏-‏6؛ 2 تِيم. 2‏:‏20. \x*
\v 22 مَاغَارْ أَربِّي، \add ونِّي\add* ثُوغَا إِخْسْ أَذْ إِسّْشنْ أَغْضَابْ نّسْ ذ جّهْذْ نّسْ، إِسِّيوضْ لْغَاضَابْ نّسْ س وَاطَّاسْ ن تَّاسِيعْ ن ڒْخَاضَارْ خْ ڒقْشُوعْ ن وغْضَابْ إِنِّي إِتّْوَاسّْوجْذنْ مَارَّا إِ ؤُهلّكْ،
\v 23 ؤُشَا إِفَارْغْ ثَايْرِي نّسْ خْ ڒقْشُوعْ ن أَرّحْمثْ إِنِّي إِزْوَارْ إِسّوْجذْ إِ-ثنْ إِ ؤُعُودْجِي إِ أَربِّي!
\v 24 مَاغَارْ نشِّينْ ذ إِنِّي إِتّْوَاڒَاغَانْ، وَارْ إِدْجِي زڭْ وُوذَاينْ وَاهَا، مَاشَا عَاوذْ زِي ڒڭْنُوسْ.
\v 25 أَمْ مَامّشْ إِتّْوَانَّا عَاوذْ ذِي حُوشِيعَا:
\b
\m \qt ”أَذْ سمِّيغْ إِ يِينِّي وَارْ إِدْجِينْ ذ ڒْڭنْسْ إِنُو\qt*
\m \qt ’ڒْڭنْسْ إِنُو!‘،\qt*
\m \qt ؤُشَا إِ يِينِّي وَارْ إِدْجِينْ ذ أَمْعِيزّْ ذ ’أَمْعِيزّْ!‘ “\qt* \x ◘ \xo 9:‏25 \xt حُوش. 2‏:‏25 \x*
\b
\m 
\v 26 أَذْ يِيڒِي ذڭْ ومْشَانْ مَانِي ذ أَسنْ إِتّْوَاڒَاغَا:
\b
\m \qt ’وَارْ إِدْجِي ذ ڒْڭنْسْ إِنُو!‘،\qt*
\b
\m بلِّي ذِينِّي أَذْ أَسنْ ڒَاغَانْ:
\b
\m \qt ’أَرَّاونْ ن أَربِّي إِدَّارنْ!‘\qt* \x ◘ \xo 9:‏26 \xt حُوش. 2‏:‏1؛ 1 بُط. 2‏:‏10. \x*
\b
\m 
\v 27 مَاشَا إِشَاعْيَا إِبَارّحْ زِي جِّيهثْ ن أَيْثْ ن إِسْرَائِيل:
\b
\m \qt ”مَاڒَا ثُوغَا ڒْقدّْ ن أَيْثْ ن إِسْرَائِيل\qt*
\m \qt أَنشْثْ ن إِجْذِي ن ڒبْحَارْ،\qt*
\m \qt \tl مْغِيرْ\tl* مِينْ إِ غَا إِقِّيمنْ أَذْ إِنْجمْ.“\qt* \x ◘ \xo 9:‏27 \xt إِشا. 10‏:‏22. \x*
\b
\m 
\v 28 \qt ”ثَامسْڒَاشْثْ ثْبدّْ نِيشَانْ ؤُ أَذْ ثتّْوَاقْفڒْ،\qt*
\m \qt سِيذِي أَذْ ت إِڭّْ خْ ثمُّورْثْ.“\qt* \x ◘ \xo 9:‏28 \xt إِشا. 10‏:‏22، 23. \x*
\b
\m 
\v 29 أَمْ مَامّشْ إِزْوَارْ إِشَاعْيَا إِنَّا:
\b
\m \qt ”مَاعْلِيكْ سِيذِي ن ڒْعسْكَارَاثْ وَارْ ذ أَنغْ إِجِّي\qt*
\m \qt إِنِّي إِقِّيمنْ دَّارنْ،\qt*
\m \qt إِڒِي نذْوڒْ أَمْ سَاذُومْ ؤُ نَارْوسْ ذِي عَامُورَّا.“\qt* \x ◘ \xo 9:‏29 \xt أَمز. 19‏:‏24؛ إِشا. 1‏:‏9؛ 13‏:‏19؛ إِرْم. 50‏:‏40؛ حِز. 16‏:‏46. \x*
\b
\m 
\v 30 مِينْ غَا نِينِي خنِّي؟ مَا خنِّي ڒڭْنُوسْ إِنِّي وَارْ يَارزُّونْ ثَاسڭْذَا، أَقَا كْسِينْ ثَاسڭْذَا؟ إِوَا، مَاشَا ثَاسڭْذَا ثنِّي س لْ-إِيمَانْ.
\v 31 مَاشَا إِسْرَائِيل نِّي إِضفَّارنْ شَّارِيعَا ن ثْسڭْذَا، وَارْ يِيوِيضْ شَا غَارْ شَّارِيعَا ن ثْسڭْذَا. \x ◘ \xo 9:‏31 \xt رُوم. 10‏:‏2؛ 11‏:‏7. \x*
\v 32 مَايمِّي؟ مِينْزِي \add ثَاسڭْذَا\add* نِّي وَارْ ثدْجِي شَا زِي لْ-إِيمَانْ مَاشَا زِي ڒخْذَايمْ ن شَّارِيعَا، مِينْزِي نِيثْنِي نْذرْفنْ ذڭْ وژْرُو ن ؤُنذْرفْ، \x ◘ \xo 9:‏32 \xt إِشا. 8‏:‏14؛ 1 بُط. 2‏:‏7\x*
\v 33 أَمْ مَامّشْ ثُورَا:
\b
\m \qt ”أَقَا أَذْ ڭّغْ ذِي صِيهْيُونْ أَژْرُو إِ ؤُنذْرفْ\qt*
\m \qt ذ وژْرُو إِ ؤُنقْرَاذْ.\qt*
\m \qt مَارَّا وِي زَّايسْ إِ غَا يَامْننْ،\qt*
\m \qt وَارْ إِتّْسضْحَا.“\qt* \x ◘ \xo 9:‏33 \xt إِزهد. 2‏:‏12؛ 118‏:‏22؛ أَوڒن. 16‏:‏20؛ إِشا. 8‏:‏14؛ 28‏:‏16؛ إِرْم. 17‏:‏7؛ مت. 21‏:‏42؛ 1 بُط. 2‏:‏6. \x*
\b
\b
\c 10
\m 
\v 1 \add أَ\add* أَيْثْمَا، أَمژْرِي ن وُوڒْ إِنُو ؤُ ثَاژَادْجِيثْ ثنِّي ژُودْجغْ غَارْ أَربِّي ذِي طّْوعْ ن \add إِسْرَائِيل\add*، أَقَا-ت حِيمَا أَذْ غَارْسنْ ثِيڒِي ثُوذَارْثْ.
\v 2 أَقَا شهّْذغْ خَاسنْ أَقَا نِيثْنِي غَارْسنْ شْضَارثْ إِ أَربِّي، مَاشَا بْڒَا ثُوسّْنَا. \x ◘ \xo 10:‏2 \xt ڒخ. 22‏:‏3؛ رُوم. 9‏:‏31؛ ڭال. 4‏:‏17. \x*
\v 3 مَاغَارْ وَارْ سِّيننْ ثَاسڭْذَا ن أَربِّي، مَاشَا أَرزُّونْ أَذْ طّْفنْ ذِي ثْسڭْذَا ن إِخفْ نْسنْ. س ؤُيَا وَارْ سّْوَاضْعنْ إِخفْ نْسنْ إِ ثْسڭْذَا ن أَربِّي.
\v 4 مِينْزِي أَكمّڒْ ن شَّارِيعَا نتَّا ذ لْمَاسِيحْ إِ ثْسڭْذَا إِ كُوڒْ إِجّنْ إِ إِتَّامْننْ. \x ◘ \xo 10:‏4 \xt مت. 5‏:‏17؛ ڒخ. 13‏:‏38؛ 2 كُور. 3‏:‏13؛ ڭال. 3‏:‏24. \x*
\v 5 مِينْزِي مُوسَا يُورَا زِي جِّيهثْ ن ثْسڭْذَا ذِي شَّارِيعَا:
\b
\m \qt ”ونِّي إِتّڭّنْ مَانْ أَيَا،\qt*
\m \qt أَذْ زَّايسْ إِدَّارْ.“\qt* \x ◘ \xo 10:‏5 \xt لَاوِي 18‏:‏5؛ حِز. 20‏:‏11؛ ڭال. 3‏:‏12. \x*
\b
\m 
\v 6 مَاشَا ثَاسڭْذَا ثنِّي زِي لْ-إِيمَانْ ثقَّارْ أَمُّو:
\b
\m \qt ”وَارْ ثقَّارْ ذڭْ وُوڒْ نّشْ:\qt*
\m \qt ’وِي غَا إِڭَاعّْذنْ غَارْ ؤُجنَّا\qt*
\m \qt ؤُشَا أَذْ إِسّهْوَا لْمَاسِيحْ؟“\qt*
\b
\m 
\v 7 نِيغْ:
\b
\m \qt ”وِي د-إِهْوَانْ ذڭْ وحْفُورْ ن ڒَاخَارْثْ،\qt*
\m \qt ؤُشَا إِسّْڭعّذْ لْمَاسِيحْ\qt*
\m \qt زِي ثَادَّارْثْ ن إِمتِّيننْ؟“\qt*
\b
\m 
\v 8 مَاشَا مِينْ إِخْسْ أَذْ يِينِي مَانْ أَيَا \add خنِّي\add*؟
\b
\m \qt ”ثَامْوَارِّيثْ ثُوذسْ إِ شكْ،\qt*
\m \qt أَقَا-ث ذڭْ ؤُقمُّومْ نّشْ ؤُڒَا ذڭْ وُوڒْ نّشْ.\qt*
\m \qt وَا ذ أَوَاڒْ ن لْ-إِيمَانْ إِ زِي نتّْبَارّحْ.“\qt* \x ◘ \xo 10:‏8 \xt أَعَوذ. 30‏:‏12‏-‏14. \x*
\b
\m 
\v 9 مَاڒَا ثْشهْذذْ إِ سِيذِيثْنغْ يَاسُوع س ؤُقمُّومْ نّشْ ؤُشَا أَذْ ثَامْنذْ س وُوڒْ نّشْ بلِّي أَربِّي إِسّْنكَّارْ إِ-ث زِي ثَادَّارْثْ ن إِمتِّيننْ، أَذْ ثدَّارذْ.
\v 10 مِينْزِي ؤُڒْ إِ ذَايسْ إِتَّامنْ أَذْ إِتّْوَاسڭّذْ، ؤُشَا أَقمُّومْ إِ زَّايسْ إِشهّْذنْ، أَذْ إِدَّارْ.
\v 11 مِينْزِي ثِيرَا \add إِقدّْسنْ\add* قَّارنْثْ:
\b
\m \qt ”مَارَّا وِي زَّايسْ إِ غَا يَامْننْ،\qt*
\m \qt وَارْ إِتّْسضْحِي شَا.“\qt* \x ◘ \xo 10:‏11 \xt إِشا. 28‏:‏16؛ رُوم. 9‏:‏33. \x*
\b
\m 
\v 12 مِينْزِي نتَّا وَارْ إِتّڭّْ بُو ڒْفَارْزْ جَارْ وُوذَاينْ ذ إِرَامِييّنْ، مِينْزِي نتَّا ذ إِجّنْ، سِيذِي نْسنْ مَارَّا نِّي إِتّنْفيَّاضْ ڒْخَارْ خْ مَارَّا إِنِّي خَاسْ د-إِتّْڒَاغَانْ. \x ◘ \xo 10:‏12 \xt ڒخ. 15‏:‏9؛ رُوم. 3‏:‏22. \x*
\b
\m 
\v 13 \qt ”مِينْزِي كُوڒْ إِجّن\qt*
\m \qt ونِّي إِ غَا إِڒَاغَانْ س يِيسمْ ن سِيذِي،\qt*
\m \qt أَذْ إِدَّارْ.“\qt* \x ◘ \xo 10:‏13 \xt يُووِ. 3‏:‏5؛ ڒخ. 2‏:‏21. \x*
\b
\m 
\v 14 مَامّشْ إِ غَا ڒَاغَانْ خْ ونِّي ذِي وَارْ ؤُمِيننْ شَا؟ نِيغْ مَامّشْ غَا يَامْننْ ذڭْ ونِّي مِيخفْ وَارْ سْڒِينْ، نِيغْ مَامّشْ غَا سْڒنْ، مَاڒَا ؤُڒَا ذ إِجّْ وَارْ زَّايسْ إِبَارّحْ شَا؟
\v 15 مَامّشْ إِ غَا بَارّْحنْ مَاڒَا وَارْ د-تّْوَاسّكّنْ؟ أَمْ مَامّشْ ثُورَا:
\b
\m \qt ”مشْحَاڒْ ضَارْفنْ إِضَارنْ\qt*
\m \qt ن يِينِّي إِتّْبَارّْحنْ س ڒهْنَا،\qt*
\m \qt ن يِينِّي إِتّْبَارّْحنْ س ثبْرَاثِينْ ثِيصبْحَانِينْ.“\qt* \x ◘ \xo 10:‏15 \xt إِشا. 52‏:‏7؛ نَحُم. 2‏:‏1. \x*
\b
\m 
\v 16 مَاشَا وَارْ إِدْجِي مَارَّا طَّاعنْ إِ ؤُبَارّحْ ن ڒخْبَارْ أَصبْحَانْ ن لْ-إِنْجِيلْ، مِينْزِي إِشَاعْيَا إِقَّارْ:
\b
\m \qt ”\tl أَ\tl* سِيذِي إِنُو، وِي غَا يَامْننْ ذِي ثبْرَاثْ نّغْ؟“\qt* \x ◘ \xo 10:‏16 \xt إِشا. 53‏:‏1؛ يُوح. 12‏:‏38. \x*
\b
\m 
\v 17 أَقَا لْ-إِيمَانْ زڭْ ؤُسْحسِّي ؤُشَا أَسْحسِّي زڭْ وَاوَاڒْ ن أَربِّي.
\v 18 مَاشَا أَذْ إِنِيغْ:
\b
\m \qt ”مَا زعْمَا نِيثْنِي وَارْ سْڒِينْ؟“\qt*،
\b
\m \qt ”خْزَارْ، ڒْحسّْ نْسنْ إِفّغْ-د\qt*
\m \qt غَارْ مَارَّا ثَامُّورْثْ،\qt*
\m \qt ؤُشَا أَوَاڒنْ نْسنْ غَارْ ثْنڭُّورَا ن دُّونشْثْ.“\qt* \x ◘ \xo 10:‏18 \xt إِزهد. 19‏:‏5. \x*
\b
\m 
\v 19 مَاشَا أَذْ إِنِيغْ:
\b
\m \qt ”مَا إِسْرَائِيل وَارْ ثفْهِيمْ شَا مَانْ أَيَا؟“\qt*
\b
\m غَارْ ؤُمزْوَارْ مُوسَا إِنَّا:
\b
\m \qt ”أَذْ ذَايْومْ ڭّغْ ثُوسْمِي\qt*
\m \qt زڭْ إِجّْ ن ڒْڭنْسْ إِ وَارْ إِدْجِينْ شَا ذ ڒْڭنْسْ،\qt*
\m \qt ؤُشَا س يِيجّْ ن ڒْڭنْسْ إِ وَارْ إِتّطِّيعنْ\qt*
\m \qt أَذْ ذَايْومْ ڭّغْ أَخيّقْ.“\qt* \x ◘ \xo 10:‏19 \xt أَعَوذ. 32‏:‏21. \x*
\b
\m 
\v 20 ؤُشَا إِشَاعْيَا إِزْعمْ أَذْ يِينِي:
\b
\m \qt ”أَقَا بَانغْ-د إِ يِينِّي وَارْ خَافِي يَارزُّونْ،\qt*
\m \qt أَقَا ؤُفِينْ أَيِي إِنِّي وَارْ خَافِي إِسّقْسَانْ.“\qt* \x ◘ \xo 10:‏20 \xt إِشا. 65‏:‏1. \x*
\b
\m 
\v 21 مَاشَا زِي جِّيهثْ ن إِسْرَائِيل إِقَّارْ:
\b
\m \qt ”أَسّْ إِكْمڒْ سّْوِيژّْضغْ إِفَاسّنْ إِنُو\qt*
\m \qt إِ إِجّْ ن ڒْڭنْسْ إِتّْعكّْسنْ، إِعصَّانْ.“\qt*\x ◘ \xo 10:‏21 \xt إِشا. 65‏:‏2. \x*
\b
\b
\c 11
\s1 مِينْ إِقِّيمنْ ن إِسْرَائِيل ذ ڒفْرُوعْ إِڒقّْمنْ
\m 
\v 1 مَاشَا نشّْ أَذْ إِنِيغْ: مَا يُوڭِي أَربِّي خنِّي ڒْڭنْسْ نّسْ؟عمَّارْصْ! أَقَا نشّْ سِيمَانْثْ إِنُو عَاوذْ ذ إِجّْ ن ورْيَازْ زِي إِسْرَائِيل، زِي زَّارِيعثْ ن إِبْرَاهِيمْ، زِي ثقْبِيتْشْ ن بِينْيَامِينْ. \x ◘ \xo 11:‏1 \xt إِرْم. 31‏:‏37؛ 2 كُور. 11‏:‏22؛ فِيل. 3‏:‏5. \x*
\v 2 أَربِّي وَارْ إِنطَّارْ شَا ڒْڭنْسْ نّسْ إِ ثُوغَا إِسّنْ زڭْ ؤُمزْوَارُو. نِيغْ وَارْ ثسِّينمْ شَا مِينْ إِقَّارْ وذْلِيسْ \add إِقدّْسنْ\add* خْ إِلِييَا، أَمْ مَامّشْ ثُوغَا إِكْسِي ثَانْفُوتْشْ خْ إِسْرَائِيل غَارْ أَربِّي، إِنَّا:
\b
\m 
\v 3 \qt ”أَ سِيذِي، نْغِينْ إِنَابِييّنْ نّشْ،\qt*
\m \qt أَردّْدْجنْ إِعَالْطَارنْ نّشْ.\qt*
\m \qt قِّيمغْ نشّْ وَاهَا،\qt*
\m \qt ؤُشَا نِيثْنِي أَرزُّونْ ڒعْمَارْ إِنُو.“\qt* \x ◘ \xo 11:‏3 \xt 1 إِج. 19‏:‏10، 14. \x*
\b
\m 
\v 4 إِتّْوَانَّا أَسْ س إِجّْ ن ڒوْحِييْ:
\b
\m \qt ”أَقَا جِّيغْ إِ يِيخفْ إِنُو سبْعَا-أَڒَافْ ن يرْيَازنْ،\qt*
\m \qt إِنِّي وَارْ ضْرِينْ شَا غَارْ إِضَارنْ زَّاثْ إِ بَاعَالْ،\qt*
\m \qt وَارْعبْذنْ إِ بَاعَالْ.“\qt* \x ◘ \xo 11:‏4 \xt 1 إِج. 19‏:‏18. \x*
\b
\m 
\v 5 أَمُّو ذِي ڒْوقْثْ ن يِيضَا عَاوذْ، أَقَا إِقِّيمْ يِيجّْ ن ڒْبَاقِي أَمْ ث إِخْضَارْ نتَّا خْ ڒحْسَابْ ن أَرْضَا. \x ◘ \xo 11:‏5 \xt رُوم. 9‏:‏27. \x*
\v 6 مَاڒَا ثدْجَا س أَرْضَا، أَقَا وَارْ ثتِّيڒِي عَاذْ س ڒخْذَايمْ، نِيغْ خنِّي أَرْضَا وَارْ إِدْجِي عَاذْ ذ أَرْضَا. مَاشَا مَاڒَا س ڒخْذَايمْ، وَارْ ثدْجِي عَاذْ ذ أَرْضَا. مَاڒَا لَّا، أَقَا ڒْخذْمثْ وَارْ ثدْجِي عَاذْ ذ ڒْخذْمثْ. \x ◘ \xo 11:‏6 \xt أَعَوذ. 9‏:‏4. \x*
\m 
\v 7 مِينْ غَا نِينِي خنِّي؟ مِينْ ثُوغَا ثَارزُّو إِسْرَائِيل وَارْ ث ثطِّيفْ، مَاشَا إِنِّي إِتّْوَافَارْزنْ طّْفنْ ث ؤُشَا إِنّغْنِي ذوْڒنْ ذ إِذَارْغَاڒنْ ذڭْ وُوڒَاونْ نْسنْ، \x ◘ \xo 11:‏7 \xt رُوم. 9‏:‏31. \x*
\v 8 أَمْ مَامّشْ ثُورَا:
\b
\m \qt ”أَقَا أَربِّي إِوْشَا أَسنْ أَرُّوحْ إِضْبَارنْ\qt*
\m \qt ذ ثِيطَّاوِينْ إِ وَارْ إِتّْوِيڒِينْ،\qt*
\m \qt ذ إِمزُّوغنْ إِ وَارْ إِتّسْڒِينْ،\qt*
\m \qt أَڒْ أَسّْ ن يِيضَا.“\qt* \x ◘ \xo 11:‏8 \xt أَعَوذ. 29‏:‏2؛ إِشا. 6‏:‏9‏-‏10؛ 29‏:‏10؛ حِز. 12‏:‏2؛ مت. 13‏:‏14؛ مك. 4‏:‏12؛ لك. 8‏:‏10؛ يُوح. 12‏:‏40؛ ڒخ. 28‏:‏26. \x*
\b
\m 
\v 9 ذَاوُوذْ إِنَّا عَاوذْ:
\b
\m \qt ”أَذْ ثذْوڒْ ثَازوْضَا \tl ن ثِيغَارْصِينْ\tl* نْسنْ\qt*
\m \qt ذ ڒْفخْ إِ نِيثْنِي،\qt*
\m \qt ؤُشَا أَذْ ثذْوڒْ ڒْمُونثْ نْسنْ ذ ثْعنْكْرِيفْثْ.\qt* \x ◘ \xo 11:‏9 \xt إِزهد. 69‏:‏23. \x*
\m 
\v 10 \qt أجّْ أَذْ ذَارْغْڒنْثْ ثِيطَّاوِينْ نْسنْ\qt*
\m \qt حِيمَا وَارْ تّْوِيڒِينْ نِيثْنِي،\qt*
\m \qt ؤُشَا أجّْ أَذْ قوْسنْ إِعُورَارْ نْسنْ إِ ڒبْذَا.“\qt* \x ◘ \xo 11:‏10 \xt إِزهد. 69‏:‏23‏-‏24. \x*
\b
\m 
\v 11 مَاشَا نشّْ أَذْ إِنِيغْ \add خنِّي\add*: مَا نْذرْفنْ، مَاغَارْ إِتّْخصَّا أَذْ وْضَانْ؟عمَّارْصْ! مَاشَا س ؤُوطُّو نْسنْ ثِيوضْ-د ثُوذَارْثْ إِ ڒڭْنُوسْ، حِيمَا أَذْ ذوْڒنْ تَّاسْمنْ.
\v 12 مَاڒَا إِذْوڒْ ؤُنذْرفْ نْسنْ ذ أَڭْڒَا ذ أَمقّْرَانْ إِ دُّونشْثْ ؤُشَا ڒْحُوكْمْ خَاسنْ ذ أَڭْڒَا إِ ڒڭْنُوسْ، مشْحَاڒْ قَاعْ إِ غَا يِيوضْ ؤُعمَّارْ نْسنْ ذ أَفيّضْ.
\v 13 أَقَا سَّاوَاڒغْ أَكِيذْومْ، \add أَ\add* ڒڭْنُوسْ، نشّْ ذ ونِّي ذ رَّاسُولْ إِ ڒڭْنُوسْ، أَقَا تّْسّمْغَارغْ ذِي ڒْخذْمثْ ن ثْسخَّارْثْ إِنُو: \f ◼ \fr 11:‏13 \ft \bd ’رَّاسُولْ‘\bd* - نِيغْ ’أَمَازَانْ‘.\f*  \x ◘ \xo 11:‏13 \xt ڒخ. 9‏:‏15؛ 13‏:‏2؛ 22‏:‏21؛ ڭال. 1‏:‏16؛ 2‏:‏8؛ أَفا. 3‏:‏8؛ 1 تِيم. 2‏:‏7؛ 2 تِيم. 1‏:‏11. \x*
\v 14 أَذْ ثَاغْ أَذْ زمَّارغْ أَذْ سّكَّارغْ ثُوسْمِي ذڭْ أَيْثْ ن ڒْڭنْسْ إِنُو ؤُشَا أَذْ سّْنجْمغْ شَا زَّايْسنْ.
\v 15 إِوَا، مَاڒَا أَمنْضَارْ نْسنْ أَقَا-ث ذ أَصْڒَاحْ إِ دُّونشْثْ، مَامّشْ غَا يِيڒِي وذْوَاڒْ نْسنْ مْغِيرْ ذ ثُوذَارْثْ زِي ثَادَّارْثْ ن إِمتِّيننْ!
\v 16 مَاڒَا ثُوغَا ثَامزْوَارُوثْ \add ن صَّابثْ\add* ثْقدّسْ، أَمنِّي ؤُڒَا ذ ڒْعجْنثْ \add ن أَرشْثِي\add* ثْقدّسْ! مَاڒَا ثُوغَا أَژْوَارْ إِقدّسْ، أَمنِّي ؤُڒَا ذ ڒفْرُوعْ. \x ◘ \xo 11:‏16 \xt ڒخْڒ. 15‏:‏20\x*
\v 17 ؤُشَا مَاڒَا تّْوَاقسّنْ شَا ن ڒفْرُوعْ ؤُ \add خنِّي\add* شكْ، أَمْ يِيجّْ ن ؤُزمُّورْ ن ڒخْڒَا، ثتّْوَاڒقّْمذْ ذڭْ ومْشَانْ نْسنْ، ثْذوْڒذْ ثْنفْعذْ زڭْ إِژوْرَانْ ذ زّشْثْ ن ثْزِيثُونْثْ،
\v 18 وَارْ ثُوفّْ شَا خْ ڒفْرُوعْ. مَاڒَا ثُوفّذْ، \add سّنْ\add*، أَقَا شكْ وَارْ ثكْسِيذْ شَا أَژْوَارْ، مَاشَا أَژْوَارْ إِكْسِي شكْ.
\m 
\v 19 أَذْ ثَاغْ أَذْ ثِينِيذْ: ”أَقَا تّْوَاقسّنْ ڒفْرُوعْ، حِيمَا نشّْ أَذْ تّْوَاڒقّْمغْ.“
\v 20 إِوَا، نِيثْنِي تّْوَاقسّنْ زِي سِّيبّثْ ن بْڒَا لْ-إِيمَانْ نْسنْ، ؤُشَا شكْ س لْ-إِيمَانْ \add ثتّْوَاڒقّْمذْ ؤُشَا\add* ثكْسِيذْ \add أَمْشَانْ نْسنْ\add*. وَارْ ثُوفّْ شَا، مَاشَا ڭّْوذْ.
\v 21 مِينْزِي مَاڒَا ثُوغَا أَربِّي وَارْ إِتّْشطَّارْ شَا خْ ڒفْرُوعْ ن طّْبِيعثْ، وَارْ خَاكْ إِتّْشطَّارْ شَا عَاوذْ.
\v 22 أَقَا ذَا ذ ڒضْرَافثْ ن أَربِّي ذ ڒوْعَارثْ نّسْ: ڒوْعَارثْ خْ يِينِّي إِوْضَانْ، مَاشَا ڒضْرَافثْ خَاكْ مَاڒَا ثطّْفذْ ذِي ڒضْرَافثْ نّسْ، نِيغْ ؤُڒَا ذ شكْ أَذْ ثتّْوَاقسّذْ.
\v 23 ؤُڒَا ذ نِيثْنِي أَذْ تّْوَاڒقّْمنْ، مَاڒَا وَارْ قِّيمنْ ذِي ثِيكّسْثْ ن لْ-إِيمَانْ نْسنْ، مِينْزِي غَارْ أَربِّي ثِيزمَّارْ، حِيمَا أَذْ ثنْ إِڒقّمْ عَاوذْ. \x ◘ \xo 11:‏23 \xt 2 كُور. 3‏:‏16. \x*
\v 24 مِينْزِي مَاڒَا شكْ، ونِّي إِدْجَانْ س طّْبِيعثْ ذ إِجّْ ن ؤُزمُّورْ ن ڒخْڒَا، ثتّْوَاقسّذْ ؤُشَا ثتّْوَاڒقّْمذْ ذِي ثْزِيثُونْثْ ثَاصبْحَانْثْ، مشْحَاڒْ إِهوْننْ كْثَارْ أَذْ تّْوَاڒقّْمنْ نِيثْنِي ذِي ثْزِيثُونْثْ نِّي د-إِتَّاسنْ أَكْ-ذ طّْبِيعثْ نْسنْ!
\b
\m 
\v 25 مِينْزِي تّخْسغْ أَذْ ثسّْنمْ سِّيرّْ-أَ، \add أَ\add* أَيْثْمَا، حِيمَا وَارْ تِّيڒِيمْ ذ إِمِيغِيسنْ أَكْ-ذ يِيخفْ نْومْ، أَقَا ثمْسَارْ إِشْثْ ن ؤُسْذَاغڒْ ن وُوڒْ خْ إِسْرَائِيل إِ ذْرُوسْ ن ڒْوقْثْ أَڒْ د غَا يَاذفْ ؤُعمَّارْ ن ڒڭْنُوسْ، \x ◘ \xo 11:‏25 \xt لك. 21‏:‏24. \x*
\v 26 ؤُشَا خنِّي مَارَّا إِسْرَائِيل أَذْ ثذْوڒْ غَارْ ثُوذَارْثْ أَمْ مَامّشْ ثُورَا:
\b
\m \qt ”أَمْسنْجمْ أَذْ د-إِفّغْ زِي صِيهْيُونْ\qt*
\m \qt ؤُشَا أَذْ إِسّْبعّذْ ڒْمُوعْصِييّثْ خْ يَاعْقُوبْ.“\qt* \x ◘ \xo 11:‏26 \xt إِزهد. 14‏:‏7؛ إِشا. 27‏:‏9؛ 59‏:‏20؛ إِرْم. 31‏:‏31، 32، 33، 34؛ 2 كُور. 3‏:‏16؛ عبر. 8‏:‏8؛ 10‏:‏16. \x*
\m 
\v 27 \qt “خنِّي أَذْ طّْفنْ ذِي ڒْعَاهْذْ\qt*
\m \qt إِ د-يُوسِينْ زَّايِي،\qt*
\m \qt خْ مِينِّي إِ غَا غْفَارغْ إِ دّْنُوبْ نْسنْ.“\qt* \x ◘ \xo 11:‏27 \xt إِشا. 59‏:‏20، 21؛ دَان. 9‏:‏24\x*
\b
\m 
\v 28 زِي جِّيهثْ ن لْ-إِنْجِيلْ نِيثْنِي أَقَا ذ ڒْعذْيَانْ ذِي طّْوعْ نْومْ، مَاشَا زِي جِّيهثْ ن ڒِيخْضَارثْ \add إِ زِي تّْوَاخْضَارنْ نِيثْنِي\add*، أَقَا نِيثْنِي ذ إِمْعِيزّنْ خْ سِّيبّثْ ن ڒجْذُوذْ.
\v 29 مِينْزِي أَربِّي وَارْ إِتّْبدَّاڒْ ثَاوْهِيبْثْ نّسْ \add ن أَرْضَا\add* ؤُڒَا ذ ثْڒَاغِيثْ نّسْ.
\v 30 مِينْزِي أَمْ مَامّشْ ثُوغَا كنِّيوْ زِيشْ وَارْ ثطِّيعمْ شَا أَربِّي، مَاشَا ڒخُّو أَقَا ثكْسِيمْ أَرّحْمثْ س ڒْمُوعْصِييّثْ نْسنْ،
\v 31 أَمُّو نِيثْنِي عَاوذْ وَارْ طِّيعنْ شَا ڒخُّو إِ أَرّحْمثْ ثنِّي خَاومْ \add د-يُوسِينْ\add*، حِيمَا أَذْ خَاسنْ د-ثَاسْ أَرّحْمثْ.
\v 32 مِينْزِي أَربِّي إِحبّسْ إِ-ثنْ مَارَّا سَاذُو ڒْمُوعْصِييّثْ، حِيمَا أَذْ ثنْ يَارْحمْ مَارَّا. \x ◘ \xo 11:‏32 \xt ڭال. 3‏:‏22. \x*
\m 
\v 33 أَ، رَادْجَاغْ ن وَاڭْڒَا ذ ثِيغِيثْ ذ ثُوسّْنَا ن أَربِّي، مَامّشْ غَا يڭّْ بْنَاذمْ أَذْ إِقدْجبْ ڒحْكَامَاثْ نّسْ، مَامّشْ غَا يڭّْ أَذْ يَافْ إِبْرِيذنْ نّسْ.
\b
\m 
\v 34 \qt ”مِينْزِي وِي غَا إِسّْننْ نّيّثْ ن سِيذِي؟“\qt*
\m نِيغْ:
\m \qt ”وِي ذ أَسْ إِدْجَانْ ذ أَمْشَاوَارْ؟“\qt* \x ◘ \xo 11:‏34 \xt إِشا. 40‏:‏13؛ 1 كُور. 2‏:‏16. \x*
\m 
\v 35 نِيغْ:
\m \qt ”وِي ذ أَسْ إِزَّارنْ إِوْشَا أَسْ \tl شَا\tl*،\qt*
\m \qt ؤُمِي ذ أَسْ إِتّْخصَّا أَذْ إِتّْوَاخدْجصْ زَّايسْ؟“\qt* \x ◘ \xo 11:‏35 \xt أَيُوبْ 41‏:‏3. \x*
\b
\m 
\v 36 مِينْزِي مَارَّا زَّايسْ إِ إِدْجَا، ؤُ مَارَّا ذَايسْ، ؤُ مَارَّا أَقَا-ث س ؤُفُوسْ نّسْ. إِ نتَّا إِ غَا يِيڒِي \add مَارَّا\add* أَسمْغَارْ ذ \add مَارَّا\add* لْبَارَاكَا إِ ڒبْذَا قَاعْ. أَمِينْ! \x ◘ \xo 11:‏36 \xt أَوڒن. 16‏:‏4؛ 1 كُور. 8‏:‏6. \x*
\b
\b
\c 12
\s1 ثِيغَارْصَا إِدَّارنْ
\m 
\v 1 خْ ؤُينِّي تّْڒَاغِيغْ كنِّيوْ، \add أَ\add* أَيْثْمَا، س أَرّحْمثْ ثَامقّْرَانْثْ ن أَربِّي، أَذْ ثْقدّْممْ أَرِّيمَاثْ نْومْ ذ ثَاغَارْصْثْ إِدَّارنْ، إِقدّْسنْ، يَارْضَانْ إِ أَربِّي، وَا ذ أَعْبَاذْ نْومْ إِشُووَّارنْ. \x ◘ \xo 12:‏1 \xt رُوم. 6‏:‏13، 16؛ 1 بُط. 2‏:‏5. \x*
\v 2 وَارْ ثمْقُودَّامْ أَكْ-ذ دُّونشْثْ-أَ، مَاشَا بدّْڒمْ س ؤُڒقّمْ ن ڒعْقڒْ نْومْ زِي جْذِيذْ، حِيمَا أَذْ ثْقدْجْبمْ مِينْ إِخْسْ أَربِّي: مِينْ إِشْنَانْ ذ مِينْ يَارْضَانْ ذ مِينْ إِكمّْڒنْ. \x ◘ \xo 12:‏2 \xt أَفا. 5‏:‏17؛ 1 تس. 4‏:‏3؛ 1 يُوح. 2‏:‏15. \x*
\m 
\v 3 أَقَا س أَرْضَا ثنِّي ذ أَيِي إِمّوْشنْ، قَّارغْ أَومْ مَارَّا: وَارْ تّْخَارِّيصمْ سنّجْ إِ مِينْ إِتّْڒِيقْ ؤُخَارَّاصْ نّسْ، مَاشَا خَارّْصمْ نِيشَانْ عْلَاحْسَابْ ڒْقدّْ ن لْ-إِيمَانْ إِ إِوْشَا أَربِّي إِ كُوڒْ إِجّنْ \add زَّايْومْ\add*. \x ◘ \xo 12:‏3 \xt رُوم. 1‏:‏5؛ 1 كُور. 12‏:‏11؛ أَفا. 4‏:‏7. \x*
\v 4 أَمْ مَامّشْ غَارْنغْ أَطَّاسْ ن إِغزْذِيسنْ ذڭْ إِشْثْ ن أَرِّيمثْ ؤُشَا مَارَّا إِغزْذِيسنْ \add ن أَرِّيمثْ\add* وَارْ غَارْسنْ بُو ڒْخذْمثْ ذ إِشْثنْ، \x ◘ \xo 12:‏4 \xt 1 كُور. 12‏:‏27؛ أَفا. 1‏:‏23؛ 4‏:‏16؛ 5‏:‏23؛ كُول. 1‏:‏24. \x*
\v 5 أَمُّو نشِّينْ، وَاخَّا ذ أَطَّاسْ، أَقَا أَنغْ ذ إِشْثْ ن أَرِّيمثْ ذِي لْمَاسِيحْ ذ إِغزْذِيسنْ إِجّنْ إِ ونّغْنِي. \x ◘ \xo 12:‏5 \xt 1 كُور. 12‏:‏4؛ 2 كُور. 10‏:‏13؛ 1 بُط. 4‏:‏10. \x*
\v 6 مَاشَا غَارْنغْ ثِيوْهِيبِينْ إِمّْسبْضَانْ عْلَاحْسَابْ أَرْضَا إِ ذ أَنغْ إِمّوْشنْ: \add إِجّنْ غَارسْ ثَاوْهِيبْثْ\add* مَاحنْذْ أَذْ إِنبّْ عْلَاحْسَابْ ڒْقدّْ ن لْ-إِيمَانْ، \x ◘ \xo 12:‏6 \xt 1 كُور. 12‏:‏4. \x*
\v 7 ونّغْنِي غَارسْ نّيّثْ ن ثْسخَّارْثْ مَاحنْذْ أَذْ إِسخَّارْ، نِيغْ \add ثَاوْهِيبْثْ\add* ن ؤُمْسغَّارْ مَاحنْذْ أَذْ إِسّْغَارْ، \x ◘ \xo 12:‏7 \xt 1 كُور. 12‏:‏10؛ 1 بُط. 4‏:‏10، 11. \x*
\v 8 \add نِيغْ ثَاوْهِيبْثْ ن\add* ؤُسْفوّجْ مَاحنْذْ أَذْ إِسّْفوّجْ، \add نِيغْ ثَاوْهِيبْثْ\add* مَاحنْذْ أَذْ إِوْشْ س ثشْرِيمثْ، \add نِيغْ ثَاوْهِيبْثْ ن\add* ؤُضبَّارْ س ومْحَاضْ، \add نِيغْ ثَاوْهِيبْثْ ن\add* أَرّحْمثْ س ڒفْرَاحثْ. \x ◘ \xo 12:‏8 \xt أَعَوذ. 15‏:‏7؛ مت. 6‏:‏1، 2، 3؛ 2 كُور. 9‏:‏7. \x*
\b
\m 
\v 9 أَذْ ثِيڒِي ثَايْرِي نْومْ بْڒَا نِّيفَاقْ. شَارْهمْ ڒْغَارْ، ثْشبَّارمْ ذِي مِينْ إِشْنَانْ.
\v 10 إِڒِيمْ مْلِيحْ إِجّنْ أَكْ-ذ ثَاوْمَاثْ نْومْ، خْسمْ إِجّْ إِ ونّغْنِي، إِزَّارمْ أَذْ ثْشنّْعمْ إِجّنْ ونّغْنِي. \x ◘ \xo 12:‏10 \xt أَفا. 4‏:‏2؛ فِيل. 2‏:‏3؛ 1 بُط. 5‏:‏5؛ عبر. 13‏:‏1؛ 1 بُط. 1‏:‏22؛ 2‏:‏17. \x*
\v 11 إِڒِيمْ ذ إِمْحَاضنْ، وَارْ تِّيڒِيمْ ذ إِفِينْيَاننْ. إِڒِيمْ ذ ثِيمسِّي ذِي أَرُّوحْ،عبْذمْ سِيذِيثْومْ،
\v 12 فَارْحمْ ذِي مِينْ إِدْجَانْ أَسِيثمْ نْومْ، ذِي ڒْمحْنثْ نْومْ صْبَارمْ ؤُشَا طّْفمْ ڒبْذَا ذِي ثْژَادْجِيثْ. \x ◘ \xo 12:‏12 \xt لك. 18‏:‏1؛ رُوم. 15‏:‏13؛ أَفا. 6‏:‏18؛ كُول. 4‏:‏2؛ 1 تس. 5‏:‏16، 17؛ عبر. 10‏:‏36؛ 12‏:‏1؛ يَاع. 5‏:‏7\x*
\v 13 وْشمْ أَفُوسْ ذِي مِينْ إِحْذَاجنْ إِمْقدَّاسنْ. ڭّمْ س ڒضْرَافثْ أَكْ-ذ إِبَارَّانِييّنْ. \x ◘ \xo 12:‏13 \xt 1 كُور. 16‏:‏1؛ عبر. 13‏:‏2؛ 1 بُط. 4‏:‏9. \x*
\v 14 بَارْكمْ إِنِّي كنِّيوْ إِمَارّْثنْ، بَارْكمْ وَارْ نعّْڒمْ شَا. \x ◘ \xo 12:‏14 \xt مت. 5‏:‏44؛ 1 كُور. 4‏:‏12. \x*
\v 15 فَارْحمْ أَكْ-ذ إِنِّي إِفَارْحنْ، رُومْ أَكْ-ذ يِينِّي إِتّْرُونْ.
\v 16 حسْبمْ أَيْثْمَاثْومْ أَمْ مَامّشْ ثْحسّْبمْ إِخفْ نْومْ، وَارْ تِّيڒِيمْ ذ إِمْعفَّارنْ، مَاشَا رُوحمْ أَكْ-ذ إِمْوَاضْعنْ. وَارْ تِّيڒِيمْ شَا ذ إِمِيغِيسنْ أَكْ-ذ يِيخفْ نْومْ. \x ◘ \xo 12:‏16 \xt أَوڒن. 3‏:‏7؛ إِشا. 5‏:‏21؛ رُوم. 15‏:‏5؛ 1 كُور. 1‏:‏10؛ فِيل. 2‏:‏2؛ 3‏:‏16؛ 1 بُط. 3‏:‏8. \x*
\v 17 وَارْ تَّارِّيمْ شَا حذْ خْ ڒْغَارْ س ڒْغَارْ، مَاشَا ڭّمْ مِينْ إِشْنَانْ إِ مَارَّا إِوْذَانْ. \x ◘ \xo 12:‏17 \xt أَوڒن. 20‏:‏22؛ مت. 5‏:‏39؛ 1 كُور. 6‏:‏7؛ 2 كُور. 8‏:‏21؛ 1 تس. 5‏:‏15؛ 1 بُط. 2‏:‏12. \x*
\v 18 مَاڒَا ثْزمَّارمْ، مشْحَاڒْ مَا إِ د-إِتَّاسنْ زَّايْومْ، صڒْحمْ أَكْ-ذ مَارَّا إِوْذَانْ. \x ◘ \xo 12:‏18 \xt مك. 9‏:‏50؛ عبر. 12‏:‏14. \x*
\v 19 وَارْ تّنْثِيقِيممْ شَا إِ يِيخفْ نْومْ، \add أَ\add* إِمْعِيزّنْ، مَاشَا وْشمْ أَمْشَانْ إِ وغْضَابْ، مِينْزِي ثُورَا: ”مَاڒَا كنِّيوْ وَارْ ثَارِّيمْ ثَاسْغَارْثْ س يِيخفْ نْومْ، نشّْ أَذْ أَرّغْ ثَاسْغَارْثْ نومْ، إِقَّارْ أَربِّي.“ \x ◘ \xo 12:‏19 \xt أَعَوذ. 32‏:‏35؛ مت. 5‏:‏39؛ لك. 6‏:‏29؛ عبر. 10‏:‏30. \x*
\m 
\v 20 مَاڒَا إِدْجُوژْ ڒعْذُو نْومْ، سشّمْ ث، مَاڒَا إِفُوذْ، وْشمْ أَسْ أَذْ إِسُو، مِينْزِي مَاڒَا ثڭِّيذْ أَيَا، أَذْ ثْيَارْوذْ ڒفْحمْ إِتّحْذُوذُوقنْ خْ ؤُزدْجِيفْ نّسْ. \x ◘ \xo 12:‏20 \xt أَوڒن. 25‏:‏21‏-‏22؛ مت. 5‏:‏44. \x*
\v 21 وَارْ تّجِّيمْ شَا ڒْغَارْ أَذْ كنِّيوْ إِغْڒبْ، مَاشَاغڒْبمْ خْ ڒْغَارْ س ڒْخَارْ.
\b
\b
\c 13
\s1 أَوَاضعْ إِ صُّولْطَا
\m 
\v 1 أجّْ كُوڒْ إِجّْ أَذْ إِوَاضعْ إِ صُّولَاطَاثْ إِنِّي إِدْجَانْ س لْعَاضَامَا، مِينْزِي وَارْ ذِينْ صُّولْطَا مْغِيرْ س أَربِّي، ؤُشَا صُّولَاطَاثْ ثِينِّي إِدْجَانْ، أَقَا إِسّْبدّْ إِ-ثنْثْ أَربِّي. \x ◘ \xo 13:‏1 \xt أَوڒن. 8‏:‏15؛ دَان. 4‏:‏29؛ ثِيث. 3‏:‏1؛ 1 بُط. 2‏:‏13. \x*
\v 2 س ؤُيَا ونِّي إِ غَا إِمّْعَاڒَانْ أَكْ-ذ صُّولْطَا، إِتّمْعَاڒَا أَكْ-ذ مِينْ إِسّْبدّْ أَربِّي، ذ يِينِّي إِتّمْعَاڒَانْ أَذْ كْسِينْ ڒْحُوكْمْ نْسنْ.
\v 3 مِينْزِي ڒْقُوضَاثْ وَارْ دْجِينْ إِ ثِيڭّْوُوذِي ن يِينِّي إِتّڭّنْ ڒْخَارْ، مَاشَا ن يِينِّي إِتّڭّنْ ڒْغَارْ. مَا ثخْسذْ أَذْ ثِيڒِيذْ بْڒَا ثِيڭّْوُوذِي زِي صُّولْطَا \add ن ڒْقُوضَاثْ\add*؟ أڭّْ مِينْ إِشْنَانْ، أَذْ أَشْ يِيڒِي شَّانْ زَّايسْ،
\v 4 مِينْزِي \add صُّولْطَا\add* ذ ثَامْسخَّارْثْ ن أَربِّي إِ ڒفْضڒْ نّشْ. مَاشَا مَاڒَا ثڭِّيذْ ڒْغَارْ، ڭّْوذْ، مِينْزِي \add صُّولْطَا\add* وَارْ ثْبكّسْ شَا سِّيفْ بَاطڒْ ؤُمِي نتَّاثْ ذ ثَامْسخَّارْثْ ن أَربِّي، أَقَا ثْنقّمْ س وغْضَابْ إِقسْحنْ خْ يِينِّي إِتّڭّنْ ڒْغَارْ.
\v 5 س ؤُيَا إِتّْخصَّا أَنغْ أَذْ نطَّاعْ، وَارْ إِدْجِي خْ سِّيبّثْ ن وغْضَابْ وَاهَا، مَاشَا عَاوذْ خْ سِّيبّثْ ن ثْنفْسشْثْ.
\v 6 خْ سِّيبّثْ-أَ ثتّْخدْجْصمْ ضَّارِيبَا إِ كُوڒْ أَزدْجِيفْ ؤُمِي نِيثْنِي ذ إِمْسخَّارنْ ن أَربِّي إِ إِتّْوَاڭّنْ إِ مَانْ أَيَا سِيمَانْثْ نّسْ. \x ◘ \xo 13:‏6 \xt 1 بُط. 2‏:‏\x*
\v 7 خْ ؤُيَا، وْشمْ إِ مَارَّا مِينْ ذ أَسنْ إِتّْخصَّانْ: ضَّارِيبَا إِ ونِّي ؤُمِي د-ثُوسَا ضَّارِيبَا إِ كُوڒْ أَزدْجِيفْ، ڒخْڒَاصْ إِ ونِّي ؤُمِي د-يُوسَا ڒخْڒَاصْ، أَوقَّارْ إِ ونِّي ؤُمِي د-يُوسَا ؤُوقَّارْ، شَّانْ إِ ونِّي إِسْذَاهدْجنْ شَّانْ.
\b
\s1 ثَايْرِي ذ أَكمّڒْ ن شَّارِيعَا
\m 
\v 8 وَارْ تّڭّمْ أَمَارْوَاسْ غَارْ حذْ مْغِيرْ ونِّي ن ثَايْرِي أَكْ-ذ وَايَاوْيَا، مِينْزِي ونِّي إِتّخْسنْ ونِّي ذ أَسْ يُوذْسنْ، أَقَا إِكمّڒْ شَّارِيعَا. \x ◘ \xo 13:‏8 \xt ڭال. 5‏:‏14؛ 1 تِيم. 1‏:‏5. \x*
\v 9 مِينْزِي \add شَّارِيعَا\add* ثقَّارْ عَاوذْ: ”وَارْ زنِّي، وَارْ نقّْ، وَارْ تِّيشَارْ، وَارْ تَّاسمْ!“، ؤُشَا مَاڒَا ذِينْ شَا ن ثوْصيّثْ نّغْنِي، أَقَا أَثنْثْ مُوننْثْ ذڭْ وَاوَاڒْ-أَ: ”أَذْ ثخْسذْ جَّارْ نّشْ أَمْ إِخفْ نّشْ!“ \x ◘ \xo 13:‏9 \xt ؤُف. 20‏:‏13‏-‏17؛ لَاوِي 19‏:‏18؛ أَعَوذ. 5‏:‏17‏-‏19؛ مت. 19‏:‏18؛ 22‏:‏39؛ مك. 12‏:‏31؛ ڭال. 5‏:‏14؛ يَاع. 2‏:‏8. \x*
\v 10 ثَايْرِي وَارْ تّْضَارِّي شَا جَّارْ. س ؤُينِّي ثَايْرِي نتَّاثْ ذ ڒكْمَاڒْ ن شَّارِيعَا.
\m 
\v 11 أَقَا سّْنغْ أَقَا ثَا ذ ڒْوقْثْ ذ ثْسَاعّثْ حِيمَا أَذْ نْفَاقْ زڭْ إِضصْ، مِينْزِي ڒخُّو ثُوذَارْثْ نّغْ ثُوذسْ-د كْثَارْ زڭْ وَامِي نذْوڒْ نُومنْ. \x ◘ \xo 13:‏11 \xt أَفا. 5‏:‏14؛ 1 تس. 5‏:‏6. \x*
\v 12 ڒخُّو ثعْذُو دْجِيڒثْ، يِيوضْ-د ؤُزِيڒْ. أجّْ أَنغْ أَذْ نسَّارْسْ ڒخْذَايمْ ن ثَادْجسْثْ، أَذْ نكْسِي ڒسْنَاحْ ن ثْفَاوْثْ. \x ◘ \xo 13:‏12 \xt كُول. 3‏:‏8؛ 1 تس. 5‏:‏5. \x*
\v 13 أجّْ أَنغْ أَذْ نُويُورْ س ؤُشُووَّارْ أَخْمِي ذ أَزِيڒْ، وَارْ إِدْجِي ذِي زّْهُو أَبَارْشَانْ، ڒَا ذڭْ ؤُغلِّي، ڒَا ذِي ثخْمُوجِي ن فَارْقْ-شّْغڒْ ذِي قَامَا ؤُڒَا ذڭْ ؤُمنْغِي ذ ڒحْسذْ، \x ◘ \xo 13:‏13 \xt لك. 21‏:‏34؛ 1 كُور. 6‏:‏10؛ أَفا. 5‏:‏5؛ فِيل. 4‏:‏8؛ 1 تس. 4‏:‏12؛ 5‏:‏6؛ يَاع. 3‏:‏14. \x*
\v 14 مَاشَا أَرْضمْ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، وَارْ تِّيشمْ ثَايْنِيثْ إِ نّشْوَاثْ ن ويْسُومْ نْومْ. \x ◘ \xo 13:‏14 \xt ڭال. 3‏:‏27؛ 1 بُط. 2‏:‏11. \x*
\b
\b
\c 14
\s1 أَقْبَاڒْ ن وَايَاوْيَا
\m 
\v 1 وِي إِضعْفنْ ذِي لْ-إِيمَانْ، وْشمْ أَسْ أَفُوسْ، وَارْ تّمْسبْضَامْ ذڭْ إِخَارِّيصنْ نْومْ جَارْ أَومْ.
\v 2 أَقَا ذِينْ حذْ يُومنْ إِزمَّارْ أَذْ إِشّْ كُوڒْشِي، مَاشَا ونِّي إِضعْفنْ أَذْ إِشّْ ثِيبِّي وَاهَا. \x ◘ \xo 14:‏2 \xt أَوڒن. 15‏:‏7 \x*
\v 3 ونِّي إِتّتّنْ، وَارْ إِسّحْقَارِي ونِّي وَارْ إِتّتّنْ، ذ ونِّي وَارْ إِتّتّنْ، وَارْ إِحكّمْ خْ ونِّي إِتّتّنْ، مِينْزِي أَربِّي إِقْبڒْ إِ-ث.
\v 4 مِينْ ثعْنِيذْ شكْ ونِّي إِحكّْمنْ خْ ؤُمْسخَّارْ ن ونّغْنِي؟ مِينْزِي مَاڒَا إِبدّْ، ذ مَانْ أَيَا إِ بَابْ نّسْ، ؤُ مَاڒَا إِوْضَا، ذ مَانْ أَيَا إِ بَابْ نّسْ. سِيذسْ إِزمَّارْ أَذْ ث إِسّْبدّْ ذ أَبذِّي. \x ◘ \xo 14:‏4 \xt يَاع. 4‏:‏12. \x*
\m 
\v 5 أَقَا ذِينْ حذْ إِتّْغِيڒْ أَسْ أَقَا ذِينْ أَسّْ سنّجْ إِ وَاسّْ نّغْنِي، ؤُ ونّغْنِي إِتّْغِيڒْ أَسْ أَقَا كُوڒْ أَسّْ كِيفْكِيفْ. أجّْ كُوڒْ إِجّنْ أَذْ إِقْنعْ ذِي ڒْبَاڒْ نّسْ نِيشَانْ. \x ◘ \xo 14:‏5 \xt ڭال. 4‏:‏10؛ كُول. 2‏:‏16. \x*
\v 6 ونِّي إِوقَّارنْ إِجّْ ن وَاسّْ، إِ سِيذسْ إِ ث غَا إِوقَّارْ. ونِّي وَارْ إِوقَّارنْ أَسّْ، إِ سِيذسْ إِ وَارْ ث إِوقَّارْ. ونِّي إِتّتّنْ، إِتّتّْ إِ سِيذسْ، مِينْزِي أَذْ إِشكَّارْ أَربِّي. ونِّي وَارْ إِتّتّنْ شَا، إِ سِيذسْ وَارْ إِتّتّْ شَا ؤُشَا نتَّا أَذْ إِشكَّارْ أَربِّي \add عَاوذْ\add*. \x ◘ \xo 14:‏6 \xt 1 كُور. 10‏:‏31؛ 1 تِيم. 4‏:‏3. \x*
\v 7 مِينْزِي ؤُڒَا ذ إِجّْ زَّايْنغْ أَقَا إِدَّارْ إِ يِيخفْ نّسْ، ؤُشَا ؤُڒَا ذ إِجّنْ إِمُّوثْ إِ يِيخفْ نّسْ. \x ◘ \xo 14:‏7 \xt 2 كُور. 5‏:‏15؛ ڭال. 2‏:‏20؛ 1 تس. 5‏:‏10؛ 1 بُط. 4‏:‏2. \x*
\v 8 مِينْزِي مَاڒَا ندَّارْ، أَذْ ندَّارْ إِ سِيذِيثْنغْ، نِيغْ مَاڒَا نمُّوثْ أَذْ نمّثْ إِ سِيذِيثْنغْ. س ؤُيَا، مَا ندَّارْ نِيغْ نمُّوثْ، أَقَا نشِّينْ إِ سِيذِيثْنغْ.
\v 9 مِينْزِي إِ ؤُيَا إِ إِمُّوثْ لْمَاسِيحْ، ؤُشَا إِذْوڒْ إِدَّارْ \add عَاوذْ\add* ؤُشَا إِكَّارْ-د، حِيمَا أَذْ يِيڒِي ذ سِيذِي إِ يِينِّي إِمُّوثنْ ؤُڒَا إِ يِينِّي إِدَّارنْ.
\v 10 مَاشَا شكْ، مَايمِّي غَا ثْحكْمذْ خْ ؤُمَاشْ؟ نِيغْ مَايمِّي عَاوذْ شكْ ثسّحْقَارَاذْ ؤُمَاشْ؟ مِينْزِي نشِّينْ مَارَّا أَذْ نْبدّْ قِيبَاتْشْ إِ ڒْكُورْسِي ن شّْرعْ ن لْمَاسِيحْ. \x ◘ \xo 14:‏10 \xt مت. 25‏:‏31؛ 2 كُور. 5‏:‏10. \x*
\b
\m 
\v 11 أَمْ مَامّشْ ثُورَا:
\b
\m \qt ”س ثِيذتّْ، أَمْ دَّارغْ نشّْ، إِقَّارْ سِيذِي،\qt*
\m \qt أَذْ أَيِي أَضَارنْ مَارَّا إِفَادّنْ\qt*
\m \qt ؤُ كُوڒْ إِڒسْ أَذْ خَافِي إِشْهذْ.“\qt* \x ◘ \xo 14:‏11 \xt إِشا. 45‏:‏23؛ 49‏:‏18 فِيل. 2‏:‏10. \x*
\b
\m 
\v 12 خنِّي أجّْ كُوڒْ إِجّنْ زَّايْنغْ أَذْ إِڭّْ ڒحْسَابْ خْ يِيخفْ نّسْ قِيبَاتْشْ إِ أَربِّي. \x ◘ \xo 14:‏12 \xt إِزهد. 62‏:‏13؛ إِرْم. 17‏:‏10؛ 32‏:‏19؛ مت. 16‏:‏27؛ رُوم. 2‏:‏6؛ 1 كُور. 3‏:‏8؛ 2 كُور. 5‏:‏10؛ ڭال. 6‏:‏5؛ أَسَا. 2‏:‏23؛ 22‏:‏12. \x*
\v 13 زِي ڒخُّو ذ ثْسَاونْثْ وَارْ حكّْممْ إِجّنْ خْ ونّغْنِي، مَاشَا حْسنْ أَذْ ثكْسذْ أَوَاڒْ مَاحنْذْ وَارْ ثسَّارْسذْ شَا إِجّْ ن وژْرُو مَاحنْذْ أَذْ ذَايسْ إِنْقَارْضْ ؤُمَاشْ. \x ◘ \xo 14:‏13 \xt 1 كُور. 10‏:‏32؛ 2 كُور. 6‏:‏3. \x*
\v 14 مِينْزِي نشّْ سّْنغْ، أَقَا تّْوَاسّْقنْعغْ ذِي سِيذِي يَاسُوع، بلِّي ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ ثخْمجْ إِ نتَّا، مْغِيرْ إِ ونِّي ت إِحسْبنْ ذ ڒخْمجْ، أَقَا إِ نتَّا وَاهَا ؤُمِي ثخْمجْ. \x ◘ \xo 14:‏14 \xt مت. 15‏:‏11؛ مك. 17‏:‏17‏-‏23؛ ڒخ. 10‏:‏15؛ 1 كُور. 8‏:‏4؛ 1 تِيم. 4‏:‏4. \x*
\v 15 مَاڒَا إِخيّقْ ؤُمَاشْ خْ سِّيبّثْ ن مَاشَّا إِ ثشِّيذْ، أَقَا شكْ وَارْ ثُويُورذْ ذِي ثَايْرِي. وَارْ تّحِّي شَا س مَاشَّا نّشْ ونِّي إِ خفْ إِمُّوثْ لْمَاسِيحْ. \x ◘ \xo 14:‏15 \xt 1 كُور. 8‏:‏11. \x*
\v 16 مِينْ نْحسّبْ ذ ڒْخَارْ إِ نشِّينْ، وَارْ تّجِّي حذْ أَذْ خَاسْ إِسِّيوڒْ س ڒْغَارْ.
\v 17 مِينْزِي ثَاڭلْذِيثْ ن أَربِّي وَارْ ثدْجِي ذِي مَاشَّا ذ ثِيسِّيثْ، مَاشَا ذِي ثْسڭْذَا ذ ڒهْنَا ذ ڒفْرَاحثْ س أَرُّوحْ إِقدّْسنْ. \x ◘ \xo 14:‏17 \xt 1 كُور. 8‏:‏8. \x*
\v 18 مِينْزِي ونِّي إِسخَّارنْ إِ لْمَاسِيحْ ذِي مَانْ أَيَا، أَقَا يَارْضَا أَربِّي ؤُشَا نتَّا ذ أَمقْبُوڒْ غَارْ إِوْذَانْ.
\m 
\v 19 أَذْ نضْفَارْ خنِّي مِينْ إِدْجَانْ إِ ڒهْنَا ذ ڒبْنِي ن إِجّنْ إِ ونّغْنِي.
\v 20 وَارْ تَّاردّدْجْ شَا ڒْخذْمثْ ن أَربِّي خْ سِّيبّثْ ن مَاشَّا. مَارَّا ثِيمسْڒَايِينْ أَقَا أَثنْثْ ذ ثِيمزْذَاڭْ، مَاشَا ؤُشْثْ خْ بْنَاذمْ ونِّي إِ غَا إِڭّْ أَژْرُو إِ ؤُنذْرفْ س مَاشَّا نّسْ. \x ◘ \xo 14:‏20 \xt ثِيث. 1‏:‏15. \x*
\v 21 مْلِيحْ ؤُمِي وَارْ نتّتّْ شَا أَيْسُومْ ؤُ وَارْ نْسسّْ شَا بِينُو نِيغْ وَارْ نتّڭّْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ إِ ذِي إِ غَا إِنْذرْفْ ؤُمَاشْ. \x ◘ \xo 14:‏21 \xt 1 كُور. 8‏:‏13. \x*
\v 22 مَا ثتّْوَاسّْقنْعذْ إِ يِيخفْ نّشْ؟ أَذْ أَشْ يِيڒِي مَانْ أَيَا إِ يِيخفْ نّشْ زَّاثْ إِ أَربِّي. سّعْذْ ن ونِّي وَارْ إِتِّيكّْوِيضْ شّْرعْ خْ يِيخفْ نّسْ ذِي مِينْ ذ أَسْ إِتّْغِيڒْ مْلِيحْ.
\v 23 مَاشَا ونِّي إِتّْشكَّانْ خْمِي إِتّتّْ، إِتّْوَاحَاسبْ، مِينْزِي مَانْ أَيَا وَارْ إِدْجِي زِي لْ-إِيمَانْ. قَاعْ مِينْ وَارْ إِدْجِينْ زِي لْ-إِيمَانْ، أَقَا-ث ذ دّنْبْ. \x ◘ \xo 14:‏23 \xt ثِيث. 1‏:‏15. \x*
\b
\b
\c 15
\s1 إِنِّي إِضعْفنْ ذ إِنِّي إِجهْذنْ
\m 
\v 1 مَاشَا نشِّينْ إِنِّي إِجهْذنْ، إِتّْخصَّا أَنغْ أَذْ نَارْبُو ثُوضْعفْثْ ن يِينِّي إِضعْفنْ، وَارْ نتِّيوِي شَا أَرْضَا إِ يِيخفْ نّغْ. \x ◘ \xo 15:‏1 \xt 1 كُور. 9‏:‏22؛ ڭال. 6‏:‏1 \x*
\v 2 كُوڒْ إِجّنْ أَذْ إِسَّارْضَا جَّارْ نّسْ إِ ثْشُونِي ذ ڒبْنِي.
\v 3 مِينْزِي لْمَاسِيحْ عَاوذْ وَارْ إِسَّارْضِي شَا إِخفْ نّسْ، مَاشَا أَمْ مَامّشْ ثُورَا:
\b
\m \qt ”ثِيكّْوُورَا ن يِينِّي إِ شكْ إِكّْوَارنْ،\qt*
\m \qt وْضَانْثْ-إِ-د خَافِي.“\qt* \x ◘ \xo 15:‏3 \xt إِزهد. 69‏:‏10؛ إِشا. 53‏:‏4، 5. \x*
\b
\m 
\v 4 مِينْزِي مَارَّا مِينْ ثُورَا زِيشْ، ثُورَا إِ ؤُسڒْمذْ نّغْ، حِيمَا س صّْبَارْ ذ ؤُشجّعْ س مِينْ إِدْجَانْ ذِي ثِيرَا \add إِقدّْسنْ\add* أَذْ غَارْنغْ يِيڒِي ؤُسِيثمْ. \x ◘ \xo 15:‏4 \xt رُوم. 4‏:‏23، 24. \x*
\v 5 أَربِّي ن صّْبَارْ ذ ؤُفوّجْ أَذْ أَومْ إِوْشْ مَاحنْذْ أَذْ ثْحسْبمْ إِجّْ ونّغْنِي غَارسْ ڒْقِيمثْ ذ إِشْثْ ذِي يَاسُوع لْمَاسِيحْ، \x ◘ \xo 15:‏5 \xt رُوم. 12‏:‏16؛ 1 كُور. 1‏:‏10؛ فِيل. 2‏:‏2؛ 3‏:‏16؛ 1 بُط. 3‏:‏8. \x*
\v 6 حِيمَا س إِجّْ ن أَرَّايْ ذ إِشْثْ ن ثْمِيجَّا أَذْ ثسّْعُودْجَامْ أَربِّي، بَابَاسْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ.
\m 
\v 7 س ؤُينِّي قبْڒمْ إِجّنْ ونّغْنِي ؤُ صبْرمْ إِجّنْ أَكْ-ذ ونّغْنِي، أَمْ مَامّشْ ذ أَنغْ إِقْبڒْ لْمَاسِيحْ عَاوذْ إِ ؤُعُودْجِي ن أَربِّي.
\v 8 مَاغَارْ أَذْ أَومْ إِنِيغْ، أَقَا يَاسُوع لْمَاسِيحْ إِذْوڒْ ذ أَمْسخَّارْ ن وخْثَانْ ذِي طّْوعْ ن ثِيذتّْ ن أَربِّي، حِيمَا أَذْ إِضْمنْ لْوُوعُوذْ \add إِ إِوَاعْذْ أَربِّي\add* إِ ڒجْذُوذْ،
\v 9 ؤُ حِيمَا ڒڭْنُوسْ أَذْ سّمْغَارنْ ذِي أَربِّي خْ سِّيبّثْ ن أَرّحْمثْ إِ خَاسنْ د-ثُوسَا أَمْ مَامّشْ ثُورَا:
\b
\m \qt ”س ؤُينِّي أَذْ شكْ شكَّارغْ جَارْ ڒڭْنُوسْ،\qt*
\m \qt ؤُشَا أَذْ صبّْحغْ إِسمْ نّشْ.“\qt* \x ◘ \xo 15:‏9 \xt 2 صم. 22‏:‏50؛ إِزهد. 18‏:‏50. \x*
\b
\m 
\v 10 ؤُشَا إِقَّارْ عَاوذْ:
\b
\m \qt ”فَارْحمْ، \tl أَ\tl* كنِّيوْ ڒڭْنُوسْ،\qt*
\m \qt \tl جْمِيعْ\tl* أَكْ-ذ ڒْڭنْسْ نّسْ.“\qt* \x ◘ \xo 15:‏10 \xt أَعَوذ. 32‏:‏43. \x*
\b
\m 
\v 11 ؤُشَا إِنَّا عَاوذْ:
\b
\m \qt ”حمْذمْ سِيذِي، \tl أَ\tl* مَارَّا ڒڭْنُوسْ،\qt*
\m \qt صبّْحمْ ث، \tl أَ\tl* مَارَّا شُّوعُوبْ!“\qt* \x ◘ \xo 15:‏11 \xt إِزهد. 117‏:‏1. \x*
\b
\m 
\v 12 عَاوذْ إِشَاعْيَا إِقَّارْ:
\b
\m \qt ”أَذْ يِيڒِي وژْوَارْ ن يَاسَّا،\qt*
\m \qt ؤُ ونِّي د-إِكَّارنْ\qt*
\m \qt أَذْ يِيڒِي ذ أَزدْجِيفْ خْ ڒڭْنُوسْ،\qt*
\m \qt أَذْ ذَايسْ يِيڒِي ؤُسِيثمْ ن ڒڭْنُوسْ.“\qt* \x ◘ \xo 15:‏12 \xt إِشا. 11‏:‏10؛ أَسَا. 5‏:‏5؛ 22‏:‏16. \x*
\b
\m 
\v 13 أَربِّي ن ؤُسِيثمْ أَذْ كنِّيوْ إِشُّورْ س ڒفْرَاحثْ ذ ڒهْنَا ذِي لْ-إِيمَانْ، حِيمَا أَذْ ثْفيّْضمْ س ؤُسِيثمْ نّسْ زِي جّهْذْ ن أَرُّوحْ إِقدّْسنْ.
\b
\s1 پُولُوسْ ذ أَمْسخَّارْ ن لْمَاسِيحْ إِ مَارَّا ڒڭْنُوسْ
\m 
\v 14 نشّْ سِيمَانْثْ إِنُو تّْوَاسْقنْعغْ زِي جِّيهثْ نْومْ، \add أَ\add* أَيْثْمَا، أَقَا كنِّيوْ ثْعمَّارمْ س ثْشُونِي، ثشُّورمْ س مَارَّا ثُوسّْنَا، حِيمَا أَذْ ثسّْڒمْذمْ عَاوذْ إِنّغْنِي.
\v 15 مَاشَا زڭْ ؤُغزْذِيسْ أَقَا ؤُرِيغْ أَومْ س ثرْيَاسْثْ، \add أَ\add* أَيْثْمَا، مَاحنْذْ أَذْ كنِّيوْ سّْعقْڒغْ، س أَرْضَا إِ ذ أَيِي إِمّوْشنْ زِي أَربِّي،
\v 16 حِيمَا أَذْ إِڒِيغْ ذ أَمْسخَّارْ ن يَاسُوع لْمَاسِيحْ إِ ڒڭْنُوسْ، ؤُمِي تّْسخَّارغْ إِ لْ-إِنْجِيلْ ن أَربِّي، حِيمَا أَذْ ثِيڒِي ثْغَارْصْثْ ن ڒڭْنُوسْ ذ ثَامقْبُوتْشْ، ثتّْوَاقدّسْ س أَرُّوحْ إِقدّْسنْ.
\v 17 س ؤُينِّي سّمْغَارغْ ذِي يَاسُوع لْمَاسِيحْ زَّاثْ إِ أَربِّي.
\v 18 مِينْزِي وَارْ زعْمغْ أَذْ سِّيوْڒغْ ذڭْ إِمزُّوغنْ ن ڒڭْنُوسْ خْ شَا وَارْ زَّايِي ث إِڭِّي لْمَاسِيحْ س وَاوَاڒْ ذ ڒْخذْمثْ.
\v 19 س جّهْذْ ن ڒعْڒَامَاثْ ذ ڒعْجَايبْ ؤُشَا س جّهْذْ ن أَرُّوحْ ن أَربِّي، أَقَا ثُوغَا ڭُّورغْ تّنْضغْ زِي ؤُرْشَالِيمْ أَڒْ إِلِّيرِيكُونْ ؤُشَا كمّْڒغْ \add أَبَارّحْ ن\add* ڒخْبَارْ أَصبْحَانْ ن لْمَاسِيحْ.
\v 20 ذِي \add مَارَّا\add* مَانْ أَيَا ثُوغَا أَرزُّوغْ أَذْ بَارّْحغْ س ڒخْبَارْ أَصبْحَانْ، وَارْ إِدْجِي مَانِي إِتّْوَاڒَاغَا خْ يِيسمْ ن لْمَاسِيحْ \add قْبڒْ\add*، حِيمَا وَارْ بنِّيغْ خْ ذْسَاسْ ن ونّغْنِي،
\v 21 مَاشَا أَمْ مَامّشْ ثُورَا:
\b
\m \qt ”إِنِّي وَارْ زَّايسْ إِتّْوَابَارّْحنْ أَذْ ث ژَترنْ،\qt*
\m \qt ؤُ يِينِّي وَارْ \tl خَاسْ\tl* إِسْڒِينْ، أَذْ أَمْننْ.“\qt* \x ◘ \xo 15:‏21 \xt إِشا. 52‏:‏15. \x*
\b
\m 
\v 22 س ؤُينِّي ثُوغَا وَارْ إِوِيضغْ أَطَّاسْ ن إِمُورنْ، مَاحنْذْ أَذْ غَارْومْ د-أَسغْ. \x ◘ \xo 15:‏22 \xt رُوم. 1‏:‏13؛ 1 تس. 2‏:‏18. \x*
\v 23 مَاشَا ڒخُّو وَارْ غَارِي بُو تَّاسِيعْ حِيمَا أَذْ بشَّارغْ عَاذْ ذِي جّْوَايهْ-أَ ؤُ ثُوغَا عَاوذْ خْسغْ أَذْ غَارْومْ د-أَسغْ أَطَّاسْ ن إِسڭّْوُوسَا زڭْ وَامِي. \x ◘ \xo 15:‏23 \xt رُوم. 1‏:‏10؛ 15‏:‏32؛ 1 تس. 3‏:‏10؛ 2 تِيم. 1‏:‏4. \x*
\v 24 خْمِي غَا رَاحغْ غَارْ سبَّانْيَا، سِّيثِيمغْ أَذْ غَارْومْ د-أَسغْ، أَذْ كنِّيوْ ژَترغْ، ؤُ أَذْ زَّايْومْ تّْوَاسّْقبّْضغْ غَارْ ذِينِّي، أَوَارْنِي ڒَامِي إِ غَا أَرّغْ مژْرِي شْوَايْثْ ؤُمِي إِ غَا ژْرِيغْ كنِّيوْ.
\m 
\v 25 مَاشَا ڒخُّو أَقَا رُوحغْ غَارْ ؤُرْشَالِيمْ، حِيمَا أَذْ سخَّارغْ إِ إِمْقدَّاسنْ. \x ◘ \xo 15:‏25 \xt ڒخ. 19‏:‏21؛ 24‏:‏17. \x*
\v 26 مِينْزِي ثُوغَا يَارْضَا إِ يِينِّي إِدْجَانْ ذِي مَاكِيذُونِييَا ذ أَخَايَا أَذْ ڭّنْ شَا ن ثْوِيزَا إِ إِمْقدَّاسنْ إِمزْڒَاضْ نِّي إِدْجَانْ ذِي ؤُرْشَالِيمْ.
\v 27 ثُوغَا أَرْضَانْ خْ مَانْ أَيَا، مَاشَا ثُوغَا ث عَاوذْ ذَايْسنْ ذ أَمَارْوَاسْ. مِينْزِي مَاڒَا ثُوغَا \add ڒڭْنُوسْ\add* شَارْشنْ ذِي مِينْ غَارْسنْ ذ أَڭْڒَا خْ ڒحْسَابْ ن أَرُّوحْ، أَقَا-ث عَاوذْ ذ أَمَارْوَاسْ ذِي ڒڭْنُوسْ مَاحنْذْ أَذْ ثنْ سخَّارنْ س مِينْ غَارْسنْ ذ أَڭْڒَا خْ ڒحْسَابْ دَّاثْ.
\v 28 خْمِي غَا كمّْڒغْ \add ثَاسخَّارْثْ-أَ\add* ؤُشَا أَذْ أَسنْ سِّيوْضغْ ڒْغِيدْجثْ \add ن ثْوِيزَا-يَا\add* س ڒَامَانْ، أَذْ د خَاومْ كّغْ ذ أَبْرِيذْ خْمِي غَا رَاحغْ غَارْ سبَّانْيَا.
\v 29 مَاشَا سّْنغْ بلِّي، مَاڒَا ؤُسِيغْ-د غَارْومْ، أَذْ د-أَسغْ س ڒْمُوذْ إِشُّورنْ س لْبَارَاكَا ن لْ-إِنْجِيلْ ن لْمَاسِيحْ. \x ◘ \xo 15:‏29 \xt رُوم. 1‏:‏11. \x*
\m 
\v 30 تَّارغْ زَّايْومْ، \add أَ\add* أَيْثْمَا، س سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ ؤُشَا س ثَايْرِي ن أَرُّوحْ، أَذْ ثْبدّمْ نِيشَانْ أَكِيذِي ذِي ثْژَادْجِيثْ غَارْ أَربِّي خْ سِّيبّثْ إِنُو، \x ◘ \xo 15:‏30 \xt 2 كُور. 1‏:‏11. \x*
\v 31 حِيمَا أَذْ تّْوَافكّغْ زڭْ إِنِّي وَارْ يُومِيننْ شَا ذِي يَاهُوذِييَّا، حِيمَا أَذْ ثِيڒِي ثْسخَّارْثْ إِنُو إِ إِمْقدَّاسنْ ذِي ؤُرْشَالِيمْ ذ ثَامقْبُوتْشْ، \x ◘ \xo 15:‏31 \xt 2 تس. 3‏:‏2. \x*
\v 32 حِيمَا أَذْ غَارْومْ د-أَسغْ \add شُّورغْ\add* س ڒفْرَاحثْ س أَرَّايْ ن أَربِّي ؤُشَا أَذْ غَارْومْ أَريّْحغْ. \x ◘ \xo 15:‏32 \xt رُوم. 1‏:‏10؛ 15‏:‏23. \x*
\v 33 أَربِّي ن ڒهْنَا أَذْ كِيومْ يِيڒِي مَارَّا إِذْومْ. أَمِينْ.
\b
\b
\c 16
\s1 أَسدْجمْ غَارْ ؤُنڭَّارُو
\m 
\v 1 وكّْڒغْ أَومْ ؤُتْشْمَاثْنغْ فُوبِي، ثنِّي ذ ثَامْسخَّارْثْ ن ثْمسْمُونْثْ ذِي كِينْخْرِييُوسْ،
\v 2 حِيمَا أَذْ زَّايسْ ثَارحّْبمْ ذِي سِيذِيثْنغْ، أَمْ مَامّشْ إِتّْڒِيقْ إِ إِمْقدَّاسنْ، ؤُشَا أَذْ ت ثْعَاوْنمْ ذِي مَارَّا مِينْ زَّايْومْ ثتَّارْ نتَّاثْ، مِينْزِي أَقَا ثْعَاونْ أَطَّاسْ، ؤُڒَا ڒَا ذ نشّْ.
\m 
\v 3 سدْجْممْ س ڒهْنَا خْ بْرِيسْكِيلَّا ذ أَكْوِيلَا، إِنِّي ذ إِمْسخَّارنْ أَكِيذِي ذِي يَاسُوع لْمَاسِيحْ، \x ◘ \xo 16:‏3 \xt ڒخ. 18‏:‏2، 26. \x*
\v 4 نِيثْنِي سبّْڒنْ ثُوذَارْثْ نْسنْ خْ سِّيبّثْ إِنُو. وَارْ دْجِيغْ ذ نشّْ وَاهَا ونِّي ثنْ إِتّْقَاذَانْ، مَاشَا عَاوذْ مَارَّا ثِيمسْمُونِينْ ن ڒڭْنُوسْ.
\m 
\v 5 سدْجْممْ عَاوذْ س ڒهْنَا خْ ثْمسْمُونْثْ ثنِّي ذِي ثَادَّارْثْ نْسنْ.
\m سدْجْممْ خْ إِبَانِيثُوسْ، أَمْعِيزّْ إِنُو، س ڒهْنَا. نتَّا ذ \add صَّابثْ\add* ثَامزْوَارُوثْ ن أَخَايَا ذِي لْمَاسِيحْ.
\m 
\v 6 سدْجْممْ خْ مَارِييَا س ڒهْنَا. نتَّا ثُوغَا ثتَّامَارْ أَطَّاسْ خَاومْ.
\m 
\v 7 سدْجْممْ س ڒهْنَا خْ أَنْذْرُونِيكُوسْ ذ يُونِييَاسْ إِنِّي ذ رَادْجْ إِنُو ذ إِمحْبَاسْ أَكِيذِي، أَقَا أَثنْ ذ إِرْيَازنْ إِتّْوَاسّْننْ غَارْ رُّوسُولْ، ثُوغَا أَثنْ ذِي لْمَاسِيحْ قْبڒْ خَافِي.
\m 
\v 8 سدْجْممْ س ڒهْنَا خْ أَمْبْلِييَاسْ، أَمْعِيزّْ إِنُو ذِي سِيذِيثْنغْ.
\m 
\v 9 سدْجْممْ س ڒهْنَا خْ ؤُرْبَانُوسْ، ونِّي ذ أَمْسخَّارْ أَكِيذْنغْ ذِي لْمَاسِيحْ،
\m ؤُ خْ أَسْثَاخِيسْ أَمْعِيزّْ إِنُو.
\m 
\v 10 سدْجْممْ س ڒهْنَا خْ أَپِيلِّيسْ ونِّي إِتّْوَافَارْزنْ ذِي سِيذِيثْنغْ.
\m سدْجْممْ س ڒهْنَا خْ أَيْثْبَابْ ن ثَادَّارْثْ ن أَرِيسْثُوبُولُوسْ.
\m 
\v 11 سدْجْممْ س ڒهْنَا خْ هِيرُوذِييُونْ ونِّي ذ ڒَادْجْ إِنُو.
\m سدْجْممْ س ڒهْنَا خْ أَيْثْبَابْ ن ثَادَّارْثْ ن نَارْكِيسُّوسْ إِنِّي إِدْجَانْ ذِي سِيذِيثْنغْ.
\v 12 سدْجْممْ س ڒهْنَا خْ ثَارِيفِينَا ذ ثَارِيفُوسَا، ثِينِّي إِتَّامَارنْ ذِي سِيذِيثْنغْ.
\m سدْجْممْ س ڒهْنَا خْ بَارْسِيسْ، أَمْعِيزّْ إِنُو، ونِّي إِتَّامَارنْ أَطَّاسْ ذِي سِيذِيثْنغْ.
\m 
\v 13 سدْجْممْ س ڒهْنَا خْ رُوفُوسْ ونِّي إِتّْوَافَارْزنْ ذِي سِيذِيثْنغْ، ؤُڒَا خْ يمَّاسْ ثنِّي \add عَاوذْ أَمْ يِيشْثْ ن يمَّا\add* إِ نشّْ.
\m 
\v 14 سدْجْممْ س ڒهْنَا خْ أَسِينْكْرِيثُوسْ، فْلِيڭُونْ، هِيرْمَاسْ، بَاثْرُوبَاسْ، هِيرْمِيسْ ؤُشَا خْ وَاوْمَاثنْ إِنِّي أَكِيذْسنْ.
\m 
\v 15 سدْجْممْ س ڒهْنَا خْ فِيلُولُوغُوسْ ذ جُولِييَا ذ نِيرِييُوسْ ذ ؤُتْشْمَاسْ، ذ ؤُلِيمْبَاسْ ذ مَارَّا إِمْقدَّاسنْ إِنِّي أَكِيذْسنْ.
\m 
\v 16 سدْجْممْ خْ وَايَاوْيَا س ؤُسُوذمْ إِقدّْسنْ.
\m مَارَّا ثِيمسْمُونِينْ ن لْمَاسِيحْ مَارَّا تّْسدْجَامنْثْ خَاومْ. \x ◘ \xo 16:‏16 \xt 1 كُور. 16‏:‏20؛ 2 كُور. 13‏:‏12؛ 1 تس. 5‏:‏26؛ 1 بُط. 5‏:‏14. \x*
\b
\m 
\v 17 مَاشَا تّْزَاوَاڭغْ \add كنِّيوْ، أَ\add* أَيْثْمَا، مَاحنْذْ أَذْ ثحْضَامْ زِي وِي إِتّڭّنْ أَمْسبْضِي ذ ثْعِينْكْرِيفِينْ، بَارَّا إِ ثْغُورِي إِ ثغْرِيمْ. بعّْذمْ خَاسنْ. \x ◘ \xo 16:‏17 \xt مت. 18‏:‏17؛ كُول. 2‏:‏8؛ 2 تس. 3‏:‏6؛ 2 تِيم. 3‏:‏5؛ ثِيث. 3‏:‏10؛ 2 يُوح. 10. \x*
\v 18 مِينْزِي أَمْ يِينَا وَارْ سخَّارنْ شَا إِ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، مَاشَا إِ ؤُعذِّيسْ نْسنْ. س ڒهْرُوذْ إِصبْحنْ ذ وَاوَاڒنْ إِزوّْقنْ خدّْعنْ ؤُڒَاونْ ن إِحَافِييّنْ. \x ◘ \xo 16:‏18 \xt حِز. 13‏:‏18؛ فِيل. 3‏:‏19. \x*
\v 19 مِينْزِي طَّاعثْ نْومْ ثتّْوَاسّنْ غَارْ مَارَّا \add إِوْذَانْ\add*. س ؤُينِّي فَارْحغْ زَّايْومْ، مَاشَا خْسغْ أَذْ ثِيڒِيمْ ذ إِمِيغِيسنْ ذِي ثْشُونِي ؤُڒَا ذ إِمزْذَاڭنْ زِي ڒْغَارْ. \x ◘ \xo 16:‏19 \xt مت. 10‏:‏16؛ 1 كُور. 14‏:‏20. \x*
\v 20 أَربِّي ن ڒهْنَا أَذْ إِثحَّا شِّيطَانْ سَاذُو إِضَارنْ نْومْ ذغْيَا. أَرْضَا ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ أَذْ كِيومْ يِيڒِي. أَمِينْ.
\b
\m 
\v 21 ثِيمُوثِييُو، ونِّي ذ أَمْسخَّارْ أَكِيذِي، إِتّْسدْجَامْ-د خَاومْ س ڒهْنَا،
\m ؤُڒَا ذ إِنِّي زِي ڒَادْجْ إِنُو: لُوكِييُوسْ ذ يَاسُونْ ذ سُوسِيبَاثْرُوسْ. \x ◘ \xo 16:‏21 \xt ڒخ. 13؛1؛ 16‏:‏1؛ 17‏:‏5؛ 20‏:‏4؛ فِيل. 2‏:‏19؛ كُول. 1‏:‏1؛ 1 تس. 3‏:‏2؛ 1 تِيم. 1‏:‏2. \x*
\m 
\v 22 نشّْ، ثَارْثِييُوسْ، ونِّي يُورَانْ ثَابْرَاثْ-أَ، تّْسدْجَامغْ خَاومْ ذِي سِيذِيثْنغْ س ڒهْنَا.
\m 
\v 23 إِتّْسدْجَامْ-د خَاومْ خَايُوسْ س ڒهْنَا. نتَّا يَارحّبْ زَّايِي ؤُڒَا زِي ثْمسْمُونْثْ مَارَّا.
\m تّْسدْجَامنْ-د خَاومْ إِرَاسْثُوسْ، ونِّي خْ سّنْذُوقْ ن ثنْذِينْثْ، ذ كْوَارْثُوسْ، ثَاوْمَاثْ. \x ◘ \xo 16:‏23 \xt ڒخ. 19‏:‏22؛ 2 تِيم. 4‏:‏20. \x*
\b
\m 
\v 24 إِ ونِّي غَارْ ثدْجَا صُّولْطَا مَاحنْذْ أَذْ كنِّيوْ إِضْمنْ عْلَاحْسَابْ لْ-إِنْجِيلْ إِنُو - \add لْ-إِنْجِيلْ\add* إِ إِتّْوَابَارّْحنْ زِي جِّيهثْ ن يَاسُوع لْمَاسِيحْ عْلَاحْسَابْ أَسَارْڭَابْ ن سِّيرّْ نِّي ثُوغَا إِنُّوفَارنْ ذِي زّْمَانَاثْ \add ن زِيشْ\add*،
\v 25 مَاشَا أَقَا إِتّْوَاسّضْهَارْ-د ڒخُّو س ثِيرَا \add إِقدّْسنْ\add* \add س ؤُفُوسْ\add* ن إِنَابِييّنْ، ؤُشَا إِتّْوَاسّْشنْ إِ مَارَّا ڒڭْنُوسْ عْلَاحْسَابْ ڒُومُورْ ن أَربِّي، ونِّي إِدْجَانْ إِ ڒبْذَا، أَڒَامِي \add ذ أَسْ\add* غَا طَّاعنْ \add ڒڭْنُوسْ\add* س لْ-إِيمَانْ - \x ◘ \xo 16:‏25 \xt أَفا. 1‏:‏9؛ 3‏:‏9، 20؛ كُول. 1‏:‏26؛ 2 تِيم. 1‏:‏10؛ ثِيث. 1‏:‏2؛ 1 بُط. 1‏:‏20. \x*
\v 26 أَقَا إِ نتَّا ونِّي ذ بَابْ ن ثِيغِيثْ وحّْذسْ، إِ نتَّا ؤُمِي غَا يِيڒِي ؤُعُودْجِي س يَاسُوع لْمَاسِيحْ إِ ڒبْذَا قَاعْ. أَمِينْ.
\b
\m 
\v 27 أَرْضَا ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ أَذْ كِيومْ يِيڒِي مَارَّا. أَمِينْ. 
