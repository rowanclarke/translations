\id NAM - Biblica® Open Igbo Contemporary Bible 2020 
\h Nehum 
\toc1 Nehum 
\toc2 Nehum 
\toc3 Nhu 
\mt1 Nehum 
\c 1  
\p  
\v 1 Amụma banyere obodo Ninive. Akwụkwọ ọhụ Nehum, onye obodo Elkosh. 
\b  
\s1 Iwe \nd Onyenwe anyị\nd* megide Ninive 
\q1  
\v 2 \nd Onyenwe anyị\nd* bụ onye ekworo, bụrụkwa Chineke na-abọ ọbọ. 
\q2 \nd Onyenwe anyị\nd* na-aga ịbọ ọbọ, ọnụma jukwara ya obi. 
\q1 \nd Onyenwe anyị\nd* na-abọ ọbọ nʼahụ ndị iro ya, 
\q2 oke ọnụma ya na-adịgidekwa megide ndị iro ya. 
\q1  
\v 3 \nd Onyenwe anyị\nd* adịghị ewe iwe ọsịịsọ; ma ọ bụ onye ike ya dị ukwuu, 
\q2 \nd Onyenwe anyị\nd* agaghị ahapụ onye ikpe mara ka ọ laa na-enweghị ntaramahụhụ. 
\q1 Ụzọ ya dị nʼoke ikuku, na nʼoke ifufe, 
\q2 igwe ojii bụ uzuzu nke ụkwụ ya. 
\q1  
\v 4 Ọ na-abasiri oke osimiri mba ike, mee ka ọ taa, 
\q2 o mekwaala ka osimiri niile takọrọ. 
\q1 Bashan na Kamel na-akpọnwụ, 
\q2 otu a kwa, nʼosisi ndụ jupụtara Lebanọn na-achanwụsị. 
\q1  
\v 5 Nʼihu ya, ugwu niile na-eme mkpọtụ, 
\q2 ugwu nta niile na-agbazekwa, 
\q1 elu ụwa niile na-amakwa jijiji nʼihu ya, 
\q2 ọ bụladị ụwa dum, na ndị niile bi nʼime ya. 
\q1  
\v 6 Onye ga-eguzogide oke iwe ya? 
\q2 Ọ bụkwa onye ga-eguzosi ike nʼiwe ya dị ọkụ? 
\q1 A wụpụla ọnụma ya dịka ọkụ, 
\q2 e tipịasịala nkume niile ndị ahụ nʼihu ya. 
\b  
\q1  
\v 7 \nd Onyenwe anyị\nd* dị mma. 
\q2 Ọ bụ ebe mgbaba nʼụbọchị nsogbu. 
\q1 Ọ na-elekọta ndị niile na-atụkwasị ya obi, 
\q2  
\v 8 ma ọ ga-eji idee mmiri dị ukwuu 
\q1 gbuo ndị iro ya\f + \fr 1:8 \ft Ọ bụ Ninive ka a na-ekwu ihe banyere ya nʼebe\f* niile, 
\q2 ọ ga-achụba ndị iro ya nʼọchịchịrị. 
\b  
\q1  
\v 9 Kedụ izu ọjọọ unu na-agba megide \nd Onyenwe anyị\nd* 
\q2 ọ ga-eweta ihe niile nʼisi njedebe; 
\q2 nsogbu agaghị abịakwa nke ugboro abụọ. 
\q1  
\v 10 Ha ga-abụ ndị a tụhịkọtara nʼetiti ogwu, 
\q2 ndị mmanya ha ṅụbigara oke na-egbu, 
\q2 ha ga-ala nʼiyi dịka ahịhịa kpọrọ nkụ. 
\q1  
\v 11 Ọ bụ nʼime gị, Ninive, ka otu onye si pụta, 
\q2 bụ onye ahụ gbara izu ọjọọ megide Onyenwe anyị, 
\q2 na-echepụtakwa ajọ atụmatụ. 
\p  
\v 12 Ihe a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “Ọ bụ ezie na ha siri ike, ma bakwaa ụba nʼọnụọgụgụ, 
\q2 ha ga-abụ ndị a ga-egbutu na ndị ga-agabiga. 
\q1 Ọ bụ ezie na m ataala gị bụ Juda ahụhụ, 
\q2 ma agaghị m atakwa gị ahụhụ ọzọ. 
\q1  
\v 13 Ugbu a, aga m agbajipụ agbụ yoku ọ nyanyere unu nʼolu, 
\q2 tibikwaa ụdọ igwe e jiri kegide unu.” 
\b  
\q1  
\v 14 \nd Onyenwe anyị\nd* enyela iwu ya banyere gị, Ninive: 
\q2 “Ị gaghị enwekwa ụmụ ụmụ ndị ga-aza aha gị. 
\q1 Aga m ala arụsị unu niile a pịrị apị na ndị a kpụrụ akpụ nʼiyi, 
\q2 bụ arụsị ndị ahụ dị nʼụlọnsọ nke chi unu niile. 
\q1 Aga m akwadokwa ili gị, 
\q2 nʼihi na ị bụrụla onye jọgburu onwe ya na njọ.” 
\b  
\q1  
\v 15 Lee, nʼelu ugwu niile 
\q2 ka ụkwụ onye ahụ na-eweta oziọma dị, 
\q2 bụ onye ahụ na-ekwusa na udo ga-adị! 
\q1 Mee mmemme gị niile gị Juda, 
\q2 mezukwaa nkwa niile i kwere. 
\q1 Nʼihi na ndị ajọ omume agakwaghị ebuso gị agha, 
\q2 nʼihi na a ga-ala ha nʼiyi kpamkpam. 
\c 2  
\s1 Ninive ga-ada 
\q1  
\v 1 Onye na-ebuso gị agha na-abịakwasị gị. 
\q2 Chee ebe gị niile e wusiri ike nche. 
\q2 Chee ụzọ niile nche, 
\q2 mee ka ụkwụ gị sie ike nʼala. 
\q2 Chịkọtakwa ike gị niile. 
\b  
\q1  
\v 2 \nd Onyenwe anyị\nd* ga-eme ka ịma mma Jekọb laghachi, 
\q2 dịka ịma mma nke Izrel 
\q1 ọ bụ ezie na ndị mbibi ebibiela ha, 
\q2 lakwaa alaka osisi vaịnị ha niile nʼiyi. 
\b  
\q1  
\v 3 Ọta ndị agha ya na-acha ọbara ọbara, 
\q2 ndị bụ dike nʼagha yikwa uwe na-acha uhie uhie. 
\q1 Igwe e ji wuo ụgbọ agha na-egbu amụma 
\q2 nʼụbọchị ahụ ha na-ejikere agha, 
\q2 otu a kwa, ha na-efegharịkwa ùbe ha eji osisi fịa mee. 
\q1  
\v 4 Ụgbọ agha na-eme mkpọtụ dị ukwuu nʼezi, 
\q2 ha na-agbagharị ihu na azụ nʼama niile. 
\q1 Ha na-enwu dịka ire ọkụ, 
\q2 na-agbagharịkwa dịka amụma. 
\b  
\q1  
\v 5 Ọ na-akpọkọta ndị agha ya a zụziri azụzi, 
\q2 ma ha na-asọ ngọngọ nʼije ha. 
\q1 Ha ji ọsọ gbaga ruo nʼelu mgbidi ha, 
\q2 dozie ọta nche ha niile nʼusoro. 
\q1  
\v 6 Ma e megheela ọnụ ụzọ ama nke osimiri, 
\q2 ụlọeze na-amakwa jijiji. 
\q1  
\v 7 E nyela ya ka ọ bụrụ iwu na obodo a 
\q2 aghaghị ịbụ obodo a dọtara nʼagha. 
\q1 Ndị ohu ha ndị inyom so ha nʼazụ na-akwa akwa dịka nduru, 
\q2 na-etikwa aka nʼobi. 
\q1  
\v 8 Ninive dịka ọdọ mmiri 
\q2 nke mmiri ya na-ehifusị. 
\q1 “Kwụsị! Kwụsị!” ka ha na-ebe, 
\q2 ma ọ dịghị onye ga-ele anya nʼazụ. 
\q1  
\v 9 Kwakọrọnụ ọlaọcha, 
\q2 kwakọrọnụ ọlaedo dịka ihe a kwatara nʼagha. 
\q1 Akụnụba dị nʼụlọakụ ya na ihe ndị ọzọ bara uru nʼobodo ahụ, 
\q2 enweghị ọgwụgwụ. 
\q1  
\v 10 E bibiela ya. A gbahapụla ya, hapụ ya ka ọ tọgbọrọ nʼefu. 
\q2 Obi ndị nọ nʼime ya na-alọ mmiri, ikpere ha niile na-ama jijiji, 
\q2 anụ ahụ ha niile na-amakwa jijiji, ihu niile achagharịakwala. 
\b  
\q1  
\v 11 Ebeekwa ka ọgba ọdụm ahụ dị ugbu a, 
\q2 bụ ebe ahụ ha na-anọ enye ụmụ ha nri, 
\q1 ebe oke ọdụm na nne ọdụm na-ejegharị, 
\q2 na ebe ụmụ ọdụm na-anọ na-atụghị egwu ihe ọbụla? 
\q1  
\v 12 Ọdụm ahụ na-adọgbu anụ na-ezuru ụmụ ya, 
\q2 nke na-anyagburu nne ọdụm anụ, 
\q1 na-ekpoju anụ ọ dọgbutara nʼụlọ ya niile. 
\q2 Ebe obibi ya jupụtara nʼanụ ọ dọgburu. 
\b  
\q1  
\v 13 “Edoola m onwe m imegide gị,” 
\q2 otu a ka Onyenwe anyị, Onye pụrụ ime ihe niile kwubiri, 
\q1 “Aga m esure ụgbọala gị niile nʼanwụrụ ọkụ, 
\q2 mma agha ga-ala ụmụ ọdụm gị niile nʼiyi. 
\q2 Agaghị m ahapụkwara gị anụ ọbụla ị ga-adọgbu nʼụwa. 
\q1 A gaghị anụkwa 
\q2 olu ndị ozi gị ọzọ.” 
\c 3  
\s1 Ahụhụ dịrị Ninive 
\q1  
\v 1 Ahụhụ dịrị obodo ọbara, 
\q2 nke jupụtara nʼụgha, 
\q1 na ihe e zutere nʼohi. 
\q2 Ọ dịghị mgbe ị na-adịghị adọgbu. 
\q1  
\v 2 Ụda ụtarị, 
\q2 ụda ụkwụ ụgbọ ịnyịnya, 
\q1 ikiri ụkwụ ịnyịnya na-agba ọsọ, 
\q2 na mkpọtụ nke ụgbọ ịnyịnya agha! 
\q1  
\v 3 Ndị agha ịnyịnya, 
\q2 na-agbagharị na-efegharị mma agha na-egbu amụma, 
\q2 na ùbe ha na-egbuke egbuke. 
\q1 Ndị e gburu egbu dị ọtụtụ, 
\q2 ntụkọta ozu tọgbọrọ ebe niile, 
\q1 ozu a na-enweghị ike ịgụta ọnụ, 
\q2 ndị mmadụ na-asọ ngọngọ mgbe ha na-azọkwasị ozu ụkwụ na-agafe. 
\q1  
\v 4 Ihe ndị a mere nʼihi enweghị afọ ojuju nke agụụ nke onye na-akwa iko, 
\q2 onye ji mma ile anya, nwanyị nwe mgbaasị dị iche iche, 
\q1 onye ji mba dị iche iche nʼagbụ site nʼịgba akwụna ya, 
\q2 na ọtụtụ mmadụ dị iche iche site na mgbaasị ya. 
\b  
\q1  
\v 5 “Edoola m onwe m imegide gị,” otu a ka Onyenwe anyị, Onye pụrụ ime ihe niile kwubiri. 
\q2 “Aga m ekpughepụ uwe gị, jiri ya kpuchie gị ihu, 
\q1 si otu a gosi mba niile nke ụwa ọtọ gị. 
\q2 Ihere ga-emekwa gị nʼihu alaeze niile. 
\q1  
\v 6 Aga m awụkwasị gị ihe arụ dị iche iche, 
\q2 meso gị mmeso onye e ledara anya, 
\q2 mekwaa ka ị bụrụ ihe ilere anya nye mmadụ niile. 
\q1  
\v 7 Ndị niile hụrụ gị ga-agbara gị ọsọ na-asị, 
\q2 ‘Ninive aghọọla ihe lara nʼiyi, onye ga-eru ụjụ nʼihi ya?’ 
\q2 Ebee ka m ga-achọta onye ga-akasị gị obi?” 
\b  
\q1  
\v 8 Ị dị mma karịa Tibs, 
\q2 bụ obodo dị nʼọnụ mmiri Naịl, 
\q2 nke mmiri gbara gburugburu? 
\q1 Osimiri ahụ bụ ihe o ji echebe onwe ya, 
\q2 mmiri ahụ bụkwa mgbidi gbara ya gburugburu. 
\q1  
\v 9 Kush\f + \fr 3:9 \ft Ya bụ, Itiopia\f* na Ijipt bụ agbamume ya nke na-enweghị ọgwụgwụ, 
\q2 Put na Libịa sokwa bụrụ ndị enyemaka ya. 
\q1  
\v 10 Ma otu ọ dị, ebugara ya nʼala ndị ọzọ 
\q2 dịka ohu a dọtara nʼagha. 
\q1 A tụpịasịrị ụmụ ya a mụrụ ọhụrụ nʼelu nkume, 
\q2 nke dị nʼisi okporoụzọ ya niile. 
\q1 E fekwara nza iji kesaa ndị ya niile a na-asọpụrụ, 
\q2 e kekwara ndị ukwu ya niile mkpọrọ igwe. 
\q1  
\v 11 Gị onwe gị ga-aṅụbigakwa mmanya oke,\f + \fr 3:11 \ft Ga-adagbugharị dịka onye mmanya na-egbu\f* 
\q2 ị ga-abụ onye zoro onwe ya ezo, 
\q2 ma chọkwa ebe mgbaba nʼihi ịgbanarị ndị iro gị. 
\b  
\q1  
\v 12 Ebe gị niile e wusiri ike dịka osisi fiig 
\q2 nke mkpụrụ mbụ ya chara nʼelu ya. 
\q1 Ma mgbe a kwagharịrị ya 
\q2 mkpụrụ ndị ahụ na-adaba nʼọnụ onye na-eri ya. 
\q1  
\v 13 Lee ndị agha gị, 
\q2 ha niile bụ ụmụ nwanyị nʼetiti gị. 
\q1 E megheela ọnụ ụzọ ama nke ala gị niile 
\q2 nye ndị iro gị. 
\q2 Ọkụ erepịakwala na mkpọrọ e ji akpọchi ọnụ ụzọ unu niile. 
\b  
\q1  
\v 14 Seta mmiri maka oge nnọchibido, 
\q2 mee ka ebe gị niile nke ewusiri ike siekwa ike karịa. 
\q1 Gwupụta ụrọ, 
\q2 zọta aja, jiri ụrọ ndị ahụ 
\q2 kpụtakwa aja,\f + \fr 3:14 \ft Lit. \fqa Blọk brik\f* rụzikwaa ụlọ ahụ. 
\q1  
\v 15 Nʼebe ahụ ka ọkụ ga-erechapụ gị, 
\q2 mma agha ga-egbutu gị. 
\q2 Ọ ga-eripịa gị dịka igurube si erichapụ ihe niile dị ya nʼihu. 
\q1 Ọ bụladị ma i mee onwe gị ka i hie nne dịka ụkpana, 
\q2 maọbụ mụbaa dịka igurube. 
\q1  
\v 16 Ị meela ka ndị ahịa gị mụbaa nʼọnụọgụgụ, 
\q2 baa ụba karịa kpakpando dị nʼeluigwe, 
\q1 dịka igurube ha na-eripịa ala ahụ, 
\q2 gbasaa nku ha efelaga 
\q1  
\v 17 Ndị nche gị bara ụba igurube, 
\q2 ndị ode akwụkwọ gị dịkwa ukwuu nʼọnụọgụgụ dịka igwe igurube 
\q2 na-ebekwasị nʼelu mgbidi nʼụbọchị oyi. 
\q1 Ma mgbe anyanwụ wara, ha na-efelaga; 
\q2 ọ dịkwaghị onye maara ebe ha feere gaa. 
\b  
\q1  
\v 18 Eze ndị Asịrịa, ndị ọzụzụ atụrụ\f + \fr 3:18 \ft Maọbụ, \fqa ndị ndu\f* gị na-ero ụra, 
\q2 ndị unu a na-asọpụrụ adaala nʼụra ọnwụ. 
\q1 Ndị gị niile agbasasịala nʼelu ugwu niile, 
\q2 ọ dịkwaghị onye ha nwere nke ga-achịkọta ha. 
\q1  
\v 19 Ọ dịghị ihe nwere ike ime ka i si nʼọnọdụ ị nọ ugbu a biliekwa. 
\q2 Nʼihi na ọnya dị gị nʼahụ ga-egbu gị. 
\q1 Ndị niile nụrụ ihe dakwasịrị gị 
\q2 ga-eji ọṅụ kụọ aka ha, 
\q1 nʼihi na onye ka mmadụ ahụ bụ 
\q2 nke na-anụrụghị ụfụ nke enweghị obi ebere gị?