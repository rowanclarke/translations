\p
\v 30 \w Entonces|strong="H3588"\w* \w Israel|strong="H3478"\w* dijo \w a|strong="H3068"\w* \w José|strong="H3130"\w*: \w Ahora|strong="H6471"\w*, \w que|strong="H3588"\w* \w muera|strong="H4191"\w* \w yo|strong="H3588"\w*, después \w de|strong="H3588"\w* \w ver|strong="H7200"\w* tu \w rostro|strong="H6440"\w*, \w porque|strong="H3588"\w* tú \w aún|strong="H5750"\w* \w vives|strong="H2416"\w*.   
\p
\v 31 \w José|strong="H3130"\w* \w dijo|strong="H5046"\w* \w a|strong="H3068"\w* sus hermanos y \w a|strong="H3068"\w* la \w familia|strong="H1004"\w* de su padre: \w Subiré|strong="H5927"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* y le diré: Mis hermanos y la \w familia|strong="H1004"\w* de mi padre que estaban en la tierra de \w Canaán|strong="H3667"\w* \w vinieron|strong="H5927"\w* \w a|strong="H3068"\w* mí.  
\v 32 \w Son|strong="H1961"\w* \w pastores|strong="H7462"\w* \w de|strong="H3588"\w* \w ovejas|strong="H6629"\w* \w que|strong="H3588"\w* cuidan \w el|strong="H3588"\w* \w ganado|strong="H4735"\w*. Trajeron sus rebaños, sus manadas \w de|strong="H3588"\w* \w ganado|strong="H4735"\w* \w vacuno|strong="H1241"\w* \w y|strong="H3588"\w* \w todas|strong="H3605"\w* sus pertenencias.   
\p
\v 33 \w Cuando|strong="H3588"\w* \w Faraón|strong="H6547"\w* \w los|strong="H1961"\w* \w llame|strong="H7121"\w* \w y|strong="H3588"\w* les pregunte: ¿\w Cuál|strong="H4100"\w* \w es|strong="H1961"\w* \w su|strong="H3588"\w* oficio?  
\v 34 Ustedes responderán: Tus esclavos \w somos|strong="H1961"\w* \w pastores|strong="H7462"\w* \w desde|strong="H5704"\w* nuestra \w juventud|strong="H5271"\w* \w hasta|strong="H5704"\w* \w ahora|strong="H6258"\w*, tanto \w nosotros|strong="H3605"\w* \w como|strong="H3588"\w* nuestros antepasados. \add Digan\add* esto \w a|strong="H3068"\w* fin \w de|strong="H3588"\w* \w que|strong="H3588"\w* vivan \w en|strong="H5704"\w* \w la|strong="H1571"\w* tierra \w de|strong="H3588"\w* Gosén, \w porque|strong="H3588"\w* \w todo|strong="H3605"\w* \w pastor|strong="H7462"\w* \w de|strong="H3588"\w* \w ovejas|strong="H6629"\w* \w es|strong="H1961"\w* repugnancia \w para|strong="H5704"\w* \w los|strong="H3427"\w* \w egipcios|strong="H4713"\w*.   
\c 47  
\s1 Los israelitas en Gosén  
\p
\v 1 \w José|strong="H3130"\w* informó \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*: Mi padre \w y|strong="H1241"\w* mis hermanos, sus rebaños \w y|strong="H1241"\w* manadas de \w ganado|strong="H6629"\w* \w vacuno|strong="H1241"\w*, con \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* tienen, llegaron de \w la|strong="H3605"\w* tierra de \w Canaán|strong="H3667"\w*, \w y|strong="H1241"\w* \w aquí|strong="H2005"\w* están en \w la|strong="H3605"\w* tierra de Gosén.  
\v 2 \w Tomó|strong="H3947"\w* \w de|strong="H6440"\w* entre sus hermanos \w a|strong="H3068"\w* \w cinco|strong="H2568"\w* \w de|strong="H6440"\w* ellos y los presentó \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*.   
\p
\v 3 \w Entonces|strong="H1571"\w* \w Faraón|strong="H6547"\w* preguntó \w a|strong="H3068"\w* sus hermanos: ¿\w Cuál|strong="H4100"\w* es su oficio?  
\p \w Y|strong="H3068"\w* respondieron: Tus esclavos somos \w pastores|strong="H7462"\w* de \w ovejas|strong="H6629"\w*, tanto nosotros \w como|strong="H4100"\w* nuestros antepasados.  
\v 4 También dijeron \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*: Vinimos \w para|strong="H3588"\w* vivir \w en|strong="H3588"\w* \w esta|strong="H3427"\w* tierra, \w pues|strong="H3588"\w* \w la|strong="H3588"\w* hambruna aprieta \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Canaán|strong="H3667"\w* \w y|strong="H3588"\w* \w no|strong="H3588"\w* hay \w pasto|strong="H4829"\w* \w para|strong="H3588"\w* las \w ovejas|strong="H6629"\w* \w de|strong="H3588"\w* tus esclavos. \w Por|strong="H3588"\w* tanto, \w te|strong="H3588"\w* rogamos \w que|strong="H3588"\w* permitas \w que|strong="H3588"\w* tus esclavos vivan \w en|strong="H3588"\w* tierra \w de|strong="H3588"\w* Gosén.   
\p
\v 5 Entonces \w Faraón|strong="H6547"\w* habló \w a|strong="H3068"\w* \w José|strong="H3130"\w*: Tu padre y tus hermanos vinieron \w a|strong="H3068"\w* ti.  
\v 6 \w La|strong="H1931"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w está|strong="H1931"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*. Haz \w que|strong="H1931"\w* \w tu|strong="H3426"\w* padre \w y|strong="H5921"\w* tus hermanos vivan \w en|strong="H5921"\w* \w lo|strong="H1931"\w* mejor \w de|strong="H5921"\w* \w esta|strong="H1931"\w* tierra. \w Que|strong="H1931"\w* vivan \w en|strong="H5921"\w* \w la|strong="H1931"\w* tierra \w de|strong="H5921"\w* Gosén, \w y|strong="H5921"\w* \w si|strong="H1931"\w* juzgas \w que|strong="H1931"\w* \w hay|strong="H3426"\w* \w entre|strong="H5921"\w* \w ellos|strong="H1931"\w* hombres aptos, colócalos \w como|strong="H5921"\w* pastores \w principales|strong="H8269"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w ganado|strong="H4735"\w*.   
\p
\v 7 Luego \w José|strong="H3130"\w* llevó \w a|strong="H3068"\w* su padre \w Jacob|strong="H3290"\w* y lo presentó \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*. \w Jacob|strong="H3290"\w* \w bendijo|strong="H1288"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*.  
\v 8 \w Entonces|strong="H3117"\w* \w Faraón|strong="H6547"\w* preguntó \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*: ¿\w Cuántos|strong="H4100"\w* \w años|strong="H8141"\w* tienes?   
\p
\v 9 \w Jacob|strong="H3290"\w* le respondió: \w Los|strong="H1961"\w* \w años|strong="H8141"\w* \w de|strong="H7451"\w* \w mi|strong="H1961"\w* peregrinación \w son|strong="H1961"\w* 130. \w Pocos|strong="H4592"\w* y \w malos|strong="H7451"\w* \w son|strong="H1961"\w* \w los|strong="H1961"\w* \w años|strong="H8141"\w* \w de|strong="H7451"\w* \w mi|strong="H1961"\w* \w vida|strong="H2416"\w*, y \w no|strong="H3808"\w* llegaron \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w años|strong="H8141"\w* \w de|strong="H7451"\w* la \w vida|strong="H2416"\w* \w de|strong="H7451"\w* mis antepasados.  
\v 10 \w Jacob|strong="H3290"\w* \w bendijo|strong="H1288"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* y \w salió|strong="H3318"\w* \w de|strong="H6440"\w* su \w presencia|strong="H6440"\w*.   
\p
\v 11 \w José|strong="H3130"\w* logró que su padre y sus hermanos vivieran y \w les|strong="H6680"\w* \w dio|strong="H5414"\w* posesión en lo mejor \w de|strong="H5414"\w* la tierra \w de|strong="H5414"\w* \w Egipto|strong="H4714"\w*, en la tierra \w de|strong="H5414"\w* Rameses, como \w Faraón|strong="H6547"\w* \w ordenó|strong="H6680"\w*.  
\v 12 \w José|strong="H3130"\w* abastecía \w a|strong="H3068"\w* su padre, \w a|strong="H3068"\w* sus hermanos y \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w familia|strong="H1004"\w* de su padre, incluso \w a|strong="H3068"\w* \w los|strong="H3605"\w* pequeños,  
\v 13 \w aunque|strong="H3588"\w* \w no|strong="H3588"\w* \w había|strong="H3588"\w* alimento \w en|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* país.  
\p \w La|strong="H3605"\w* hambruna era \w muy|strong="H3966"\w* \w grave|strong="H3515"\w*, \w y|strong="H3588"\w* \w la|strong="H3605"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w* \w y|strong="H3588"\w* \w la|strong="H3605"\w* \w de|strong="H3588"\w* \w Canaán|strong="H3667"\w* desfallecían \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H3588"\w* \w la|strong="H3605"\w* hambruna.   
\s1 Últimos años de la hambruna  
\p
\v 14 \w José|strong="H3130"\w* \w recogió|strong="H3950"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w dinero|strong="H3701"\w* \w que|strong="H1992"\w* \w se|strong="H1992"\w* \w halló|strong="H4672"\w* en \w la|strong="H3605"\w* tierra de \w Egipto|strong="H4714"\w* y en \w Canaán|strong="H3667"\w* por \w el|strong="H3605"\w* grano \w que|strong="H1992"\w* le compraban, \w e|strong="H3068"\w* ingresó \w el|strong="H3605"\w* \w dinero|strong="H3701"\w* en \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de \w Faraón|strong="H6547"\w*.  
\v 15 \w Cuando|strong="H3588"\w* \w se|strong="H4100"\w* \w acabó|strong="H8552"\w* \w el|strong="H3588"\w* \w dinero|strong="H3701"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Canaán|strong="H3667"\w*, \w todo|strong="H3605"\w* \w Egipto|strong="H4714"\w* acudió \w a|strong="H3068"\w* \w José|strong="H3130"\w* \w y|strong="H3588"\w* dijo: \w Danos|strong="H3051"\w* \w pan|strong="H3899"\w*. ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* tenemos \w que|strong="H3588"\w* \w morir|strong="H4191"\w* \w delante|strong="H5048"\w* \w de|strong="H3588"\w* ti \w por|strong="H3588"\w* haberse acabado \w el|strong="H3588"\w* \w dinero|strong="H3701"\w*?   
\p
\v 16 Entonces contestó: Si se acabó la \w plata|strong="H3701"\w*, entreguen su \w ganado|strong="H4735"\w*, y yo les \w daré|strong="H5414"\w* alimento \w por|strong="H5414"\w* su \w ganado|strong="H4735"\w*.  
\v 17 \w Y|strong="H3068"\w* \w le|strong="H1931"\w* llevaron \w sus|strong="H1931"\w* \w ganados|strong="H4735"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w*. Entonces \w José|strong="H3130"\w* les \w dio|strong="H5414"\w* alimento \w por|strong="H5414"\w* \w los|strong="H3605"\w* \w caballos|strong="H5483"\w*, \w por|strong="H5414"\w* \w el|strong="H1931"\w* \w ganado|strong="H4735"\w* del \w rebaño|strong="H6629"\w*, \w por|strong="H5414"\w* las reces \w de|strong="H5414"\w* \w la|strong="H1931"\w* manada \w de|strong="H5414"\w* \w ganado|strong="H4735"\w* \w vacuno|strong="H1241"\w* \w y|strong="H1241"\w* \w por|strong="H5414"\w* \w los|strong="H3605"\w* \w asnos|strong="H2543"\w*. Durante \w aquel|strong="H1931"\w* \w año|strong="H8141"\w* les suministró alimento \w a|strong="H3068"\w* cambio \w de|strong="H5414"\w* \w todos|strong="H3605"\w* \w sus|strong="H1931"\w* \w ganados|strong="H4735"\w*.   
\p
\v 18 \w Cuando|strong="H3588"\w* finalizó \w aquel|strong="H1931"\w* \w año|strong="H8141"\w*, acudieron \w a|strong="H3068"\w* \w él|strong="H1931"\w* \w el|strong="H1931"\w* \w segundo|strong="H8145"\w* \w año|strong="H8141"\w* \w y|strong="H3588"\w* \w le|strong="H1931"\w* dijeron: \w No|strong="H3808"\w* ocultamos \w a|strong="H3068"\w* nuestro \tl ʼadón\tl* \w que|strong="H3588"\w*, \w puesto|strong="H3588"\w* \w que|strong="H3588"\w* \w la|strong="H1931"\w* \w plata|strong="H3701"\w* \w se|strong="H1931"\w* \w acabó|strong="H8552"\w* \w y|strong="H3588"\w* también \w el|strong="H1931"\w* \w ganado|strong="H4735"\w* \w es|strong="H1931"\w* \w de|strong="H3588"\w* nuestro \tl ʼadón\tl*, \w nada|strong="H3808"\w* \w queda|strong="H7604"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* nuestro \tl ʼadón\tl* \w sino|strong="H3588"\w* nuestros \w cuerpos|strong="H1472"\w* \w y|strong="H3588"\w* nuestra tierra.  
\v 19 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* tenemos \w que|strong="H4100"\w* perecer \w delante|strong="H5869"\w* \w de|strong="H5414"\w* ti, tanto nosotros \w como|strong="H4100"\w* nuestras tierras? \w Cómpranos|strong="H7069"\w* \w a|strong="H3068"\w* nosotros \w y|strong="H1571"\w* \w a|strong="H3068"\w* nuestra tierra \w por|strong="H4100"\w* alimento, \w y|strong="H1571"\w* nosotros \w y|strong="H1571"\w* nuestras tierras \w seremos|strong="H1961"\w* esclavos \w de|strong="H5414"\w* \w Faraón|strong="H6547"\w*. Pero \w danos|strong="H5414"\w* semilla \w para|strong="H5414"\w* \w que|strong="H4100"\w* vivamos \w y|strong="H1571"\w* \w no|strong="H3808"\w* \w muramos|strong="H4191"\w*, \w y|strong="H1571"\w* \w la|strong="H1571"\w* tierra \w no|strong="H3808"\w* \w sea|strong="H1961"\w* asolada.   
\p
\v 20 \w Entonces|strong="H3588"\w* \w José|strong="H3130"\w* \w compró|strong="H7069"\w* \w para|strong="H5921"\w* \w Faraón|strong="H6547"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w porque|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w egipcios|strong="H4713"\w* vendían sus \w campos|strong="H7704"\w*, \w pues|strong="H3588"\w* \w la|strong="H5921"\w* hambruna arreciaba \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*. \w Así|strong="H3588"\w* \w la|strong="H5921"\w* tierra llegó \w a|strong="H3068"\w* ser \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w*.  
\v 21 Mandó trasladar \w al|strong="H5704"\w* \w pueblo|strong="H5971"\w* \w a|strong="H3068"\w* las \w ciudades|strong="H5892"\w*, \w desde|strong="H5704"\w* un \w extremo|strong="H7097"\w* \w al|strong="H5704"\w* \w otro|strong="H7097"\w* \w de|strong="H5704"\w* \w Egipto|strong="H4714"\w*.  
\v 22 \w Solamente|strong="H7535"\w* \w no|strong="H3808"\w* \w compró|strong="H7069"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w*, \w porque|strong="H3588"\w* \w había|strong="H3588"\w* un \w estatuto|strong="H2706"\w* \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w* \w para|strong="H5921"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w*, \w y|strong="H3588"\w* \w ellos|strong="H5921"\w* comían \w la|strong="H5921"\w* ración \w que|strong="H3588"\w* \w Faraón|strong="H6547"\w* \w les|strong="H5921"\w* \w daba|strong="H5414"\w*. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w no|strong="H3808"\w* tuvieron \w que|strong="H3588"\w* vender sus tierras.   
\p
\v 23 \w José|strong="H3130"\w* dijo al \w pueblo|strong="H5971"\w*: Miren, \w hoy|strong="H3117"\w* los compré \w a|strong="H3068"\w* ustedes con sus tierras \w para|strong="H5971"\w* \w Faraón|strong="H6547"\w*. \w Aquí|strong="H2005"\w* tienen semilla \w para|strong="H5971"\w* sembrar la tierra.  
\v 24 \w Cuando|strong="H1961"\w* llegue la cosecha \w darán|strong="H5414"\w* la quinta parte \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*, y las cuatro \w partes|strong="H3027"\w* \w serán|strong="H1961"\w* \w de|strong="H5414"\w* ustedes \w para|strong="H5414"\w* sembrar el \w campo|strong="H7704"\w*. Ustedes \w tendrán|strong="H1961"\w* alimento, también \w los|strong="H1961"\w* \w que|strong="H1961"\w* \w están|strong="H1961"\w* en sus \w casas|strong="H1004"\w* y sus pequeños.   
\p
\v 25 Respondieron: ¡Nos salvaste la \w vida|strong="H2421"\w*! \w Hallemos|strong="H4672"\w* \w gracia|strong="H2580"\w* ante nuestro \tl ʼadón\tl* y \w seamos|strong="H1961"\w* esclavos \w de|strong="H5869"\w* \w Faraón|strong="H6547"\w*.   
\p
\v 26 \w José|strong="H3130"\w* \w lo|strong="H2088"\w* estableció \w por|strong="H5921"\w* \w estatuto|strong="H2706"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*: \w Faraón|strong="H6547"\w* recibe \w la|strong="H5921"\w* quinta parte. \w Solo|strong="H7535"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w no|strong="H3808"\w* \w fue|strong="H1961"\w* \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w*.   
\p
\v 27 \w Israel|strong="H3478"\w* \w estuvo|strong="H3427"\w* en tierra de Gosén en \w Egipto|strong="H4714"\w*. Tomaron posesión en ella, y fructificaron y se \w multiplicaron|strong="H7235"\w* muchísimo.   
\p
\v 28 \w Jacob|strong="H3290"\w* \w vivió|strong="H2421"\w* en la tierra de \w Egipto|strong="H4714"\w* 17 \w años|strong="H8141"\w*, \w pues|strong="H1961"\w* \w los|strong="H1961"\w* \w días|strong="H3117"\w* de \w Jacob|strong="H3290"\w* \w fueron|strong="H1961"\w* 147 \w años|strong="H8141"\w*.  
