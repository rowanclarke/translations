\id COL - Biblica® Open Igbo Contemporary Bible 2020 
\h Ndị Kọlọsị 
\toc1 Ndị Kọlọsị 
\toc2 Ndị Kọlọsị 
\toc3 Kọl 
\mt1 Ndị Kọlọsị 
\c 1  
\p  
\v 1 Pọl, onye e mere onyeozi Kraịst Jisọs, site nʼọchịchọ Chineke, ya na nwanna anyị Timoti, 
\b  
\p  
\v 2 Na-edegara ndị Kraịst nọ na Kọlọsị, bụ ụmụnna ndị dị nsọ na ndị kwesiri ntụkwasị obi. 
\b  
\p Ka amara na udo nke sitere na Chineke Nna anyị dịrị unu. 
\b  
\s1 Ekele na ekpere 
\p  
\v 3 Mgbe ọbụla anyị na-ekpere unu ekpere anyị na-ekele Chineke onye bụ Nna Onyenwe anyị Jisọs Kraịst ekele.  
\v 4 Nʼihi na anyị anụla ihe banyere okwukwe unu nʼime Kraịst Jisọs, na otu unu si hụ ndị nsọ niile nʼanya.  
\v 5 Okwukwe na ịhụnanya nke na-esite nʼolileanya nke a kwadobere unu nʼeluigwe, nke unu nụrụla nʼokwu nke eziokwu ahụ, bụ oziọma,  
\v 6 nke bịaruterela unu. Nʼezie, dị ka o si dị nʼụwa niile, ọ na-amị mkpụrụ na-etokwa, dị ka o si eme nʼetiti unu, site nʼụbọchị unu nụrụ ma ghọtakwa amara nke Chineke nʼeziokwu.  
\v 7 Dị ka unu siri mụta nʼaka Epafras, onye anyị hụrụ nʼanya na onye anyị na ya na-ejekọ ozi. Ọ bụ onye kwesiri ntụkwasị obi nʼijere Kraịst ozi nʼaha unu.  
\v 8 O meela ka anyị mara ụdị ịhụnanya unu nwere nʼime Mmụọ. 
\p  
\v 9 Nʼihi nke a, site nʼụbọchị anyị nụrụ ihe banyere ya, anyị esepụghị aka ikpere unu ekpere. Anyị na-arịọ ka unu jupụta nʼamamihe nke uche ya, nʼime nghọta ma amamihe nke mmụọ niile.  
\v 10 Ka unu si otu a bie ndụ dị ka Onyenwe anyị chọrọ. Ka unu bụrụkwa ndị na-eme ihe ọma mgbe niile, ndị na-eme ihe na-atọ ya ụtọ nʼụzọ ọbụla, na ndị na-eto eto nʼihe banyere ịma Chineke mgbe niile.  
\v 11 Ebe a na-eme ka unu dị ike nʼime ike niile, dị ka ike nke ebube ya si dị. Ka unu nwee ndidi na ogologo ntachiobi,  
\v 12 na-enyenụ Nna ekele site nʼọṅụ, onye mere ka anyị kwesi iketa oke nʼihe nketa nke ndị nsọ nʼime alaeze nke ìhè.  
\v 13 Nʼihi na ọ napụtara anyị site nʼike nke ọchịchịrị, bịa kpọfee anyị nʼalaeze nke Ọkpara ya ọ hụrụ nʼanya.  
\v 14 Onye anyị si nʼime ya nwee nzọpụta, nke bụ mgbaghara mmehie niile. 
\s1 Onye Kraịst bụ, na ihe o mere 
\p  
\v 15 Ọ bụ nnọọ onyinyo Chineke onye anyị na-apụghị ịhụ anya, bụrụkwa onye mbụ a mụrụ nʼihe niile e kere eke.  
\v 16 Nʼihi na nʼime ya ka e ji kee ihe niile dị nʼụwa na nke dị nʼeluigwe, na ndị anyị pụrụ ịhụ anya na ndị anyị na-apụghị ịhụ anya, ma ocheeze niile, ike niile, ịchị isi niile na ike ọchịchị niile. E kere ihe niile site nʼaka ya nakwa nʼihi ya.  
\v 17 Ya onwe ya nọ tupu ekee ihe niile, ọ bụkwa nʼime ya ka ejikọtara ihe niile nʼotu.  
\v 18 Ọ bụ ya bụ isi nke anụ ahụ ahụ bụ chọọchị. Ọ bụ ya bụ mmalite, onye mbụ a mụrụ nʼetiti ndị niile ga-esi nʼọnwụ bilie. Nke a mere ka ọ bụrụ onyeisi mbụ nʼime ihe niile.  
\v 19 Nʼihi na ọ bụ nʼime ya ka ọ masịrị ozuzu oke ya ibi.  
\v 20 Ọ bụ site na ya ka o ji mee ka ihe niile bịaghachikwute ya. E mere ka udo dịrị nʼetiti ya na ihe niile, maọbụ ihe dị nʼụwa, maọbụ nke dị na nʼeluigwe site na ọbara ọ wụsiri nʼelu obe. 
\p  
\v 21 Unu onwe unu bụ ndị e mere ndị mba ọzọ site nʼebe Chineke nọ, na ndị iro nʼuche unu nʼihi ajọ omume niile unu.  
\v 22 Ma ugbu a, o kpezierela unu site na-anụ ahụ Kraịst, sitekwa nʼọnwụ ya, iji chee unu nʼihu ya dịka ndị dị nsọ, na ndị na-enweghị ịta ụta, na ihe ebubo ọbụla megide ha.  
\v 23 Ma ọ bụrụ na unu anọgide nʼokwukwe unu, bụrụ ndị gbara mgbọrọgwụ, ndị guzosiri ike, ndị na-ewezugaghị onwe ha site nʼolileanya ahụ dịrị unu nʼoziọma ahụ. Nke a bụ oziọma ahụ unu nụrụ, nke ekwusakwara nye ihe niile e kere eke nʼokpuru eluigwe, nke e mere mụ onwe m bụ Pọl, onyeozi ya. 
\s1 Ọrụ Pọl na-arụ nʼime chọọchị 
\p  
\v 24 Ugbu a, ana m aṅụrị ọṅụ nʼihi ahụhụ ndị a nke m na-ahụ nʼihi unu, ana m emezu ihe fọdụrụ nʼahụhụ ahụ Kraịst tara nʼihi anụ ahụ ya bụ chọọchị.  
\v 25 Emeela ka m bụrụ onyeozi chọọchị ya site nʼikike Chineke nyere m, ikwusara unu okwu Chineke nʼozuzu oke ya.  
\v 26 Nke bụ ihe omimi ahụ, nke e zoro ezo site nʼoge ahụ nakwa ọgbọ niile ndị a gara aga, ma ugbu a e mekwara ka ọ pụta ìhè nye ndị nsọ Chineke.  
\v 27 Ọ bụ ha ka Chineke họpụtara ime ka amata akụ nke ebube nke ihe omimi a nʼetiti ndị mba ọzọ, nke bụ Kraịst nʼime unu, onye bụ olileanya nke ebube ahụ. 
\p  
\v 28 Ọ bụ ya ka anyị na-ekwusa, na-adụ onye ọbụla ọdụ, na-akụzikwara onye ọbụla ihe site nʼamamihe niile. Nʼihi na anyị chọrọ iche mmadụ niile ọbụla nʼihu ya dị ka ndị zuruoke nʼime Kraịst.  
\v 29 Nʼihi nke a ka m na-adọgbu onwe m nʼọrụ, dị ka ike ya dị ukwuu nke na-arụ ọrụ si dị m nʼime. 
\c 2  
\p  
\v 1 Ọ bụ ọchịchọ m ka unu ghọta otu m si na-agbasi mgba ike nke ukwuu nʼihi unu, na nʼihi ndị nọ nʼobodo Laodisia, na ndị niile na-enwebeghị ike ịhụ m ihu na ihu.  
\v 2 Ebumnobi m bụ ka a gbaa ha ume, jikọọkwa ha nʼotu nʼịhụnanya, ka ha nweta ụba niile nke nghọta zuruoke na amamihe nke ihe omimi Chineke ahụ bụ Kraịst nʼonwe ya.  
\v 3 Ọ bụkwa nʼime ya ka ụlọakụ ihe zoro ezo niile nke amamihe na ihe ọmụma dị.  
\v 4 Ana m ekwu nke a ka onye ọbụla ghara iji ire ụtọ duhie unu ụzọ.  
\v 5 Ọ bụ ezie na anọghị m nʼetiti unu nʼanụ ahụ, ma anọ m nʼetiti unu nʼime mmụọ. Ana m aṅụrị ọṅụ ịhụ mkpebi unu na iguzosi ike nʼokwukwe unu nʼime Kraịst. 
\s1 Ndụ juru afọ dị nʼime Kraịst 
\p  
\v 6 Ya mere, dị ka unu si nabata Kraịst Jisọs Onyenwe anyị, na-ebinụ ndụ unu nʼime ya.  
\v 7 Bụrụnụ ndị mgbọrọgwụ ha mibanyere nʼime ya, ndị a na-ewuli elu nʼime ya, ndị dị ike nʼime okwukwe, dị ka e si kuziere unu, ndị jupụtara na-inye ekele. 
\p  
\v 8 Lezienụ anya ka onye ọbụla ghara iji ozizi na amamihe efu niile nke na-achị ụwa, na aghụghọ duhie unu nʼokwukwe. Okwu amamihe ahụ nke ihe ozizi ya na ọsịsa ya niile dabeere na mmụọ nke ụwa na ntụpụta mmadụ kama ịdabere nʼihe Kraịst kwuru. 
\p  
\v 9 Nʼihi na nʼime Kraịst ka izuoke niile nke Chineke bi nʼụdịdị mmadụ.  
\v 10 Ya mere, unu nwere ihe niile nʼime ya, onye bụ isi ndị niile na-achị achị, onye bụkwa isi nʼebe ike na ịchị isi niile dị.  
\v 11 Nʼime ya, e biri unu ugwu nke ejighị aka bie, site nʼiwepụ ọdịdị anụ ahụ nʼobibi ugwu nke Kraịst biri.  
\v 12 Mgbe e likọtara unu na ya na baptizim, e sitere nʼọnwụ kpọlite unu na ya site nʼokwukwe ahụ dị nʼike Chineke onye sitere nʼọnwụ kpọlite ya. 
\p  
\v 13 Mgbe unu bụ ndị nwụrụ anwụ nʼime mmehie unu, na nʼime ebighị ugwu nke anụ ahụ mmehie unu, Chineke mere ka unu soro Kraịst dịrị ndụ ọzọ. Ọ gbaghara anyị mmehie anyị niile,  
\v 14 kagbuo iwu niile e dere ede, ya na usoro ya niile nke guzoro imegide anyị. O wezugara ha, kpọgide ha nʼobe.  
\v 15 Mgbe ọ napụrụ ike niile, na ịchị isi niile, ngwa agha ha niile, ọ gbara ha ọtọ nʼihu ọha, igosi mmeri o meriri ha nʼobe. 
\s1 Inwere onwe pụọ nʼiwu mmadụ 
\p  
\v 16 Nʼihi ya, unu ekwela ka onye ọbụla kpee unu ikpe banyere ihe ọbụla unu na-eri, maọbụ ihe unu na-aṅụ, maọbụ ihe banyere ido ụbọchị nsọ, maọbụ ime mmemme ọnwa ọhụrụ maọbụ mmemme ụbọchị izuike.  
\v 17 Ihe ndị a niile bụ onyinyo nke ihe ga-abịa nʼọdịnihu ma nke pụtara ihe dị nʼime Kraịst.  
\v 18 Unu ekwela ka onye ọbụla nke ọ na-amasị ife ndị mmụọ ozi maọbụ ibi ndụ umeala nke aghụghọ dị nʼime ya, onye na-ekwu ọtụtụ okwu banyere ọhụ ọ hụrụ, si otu a na-afụli onwe ya elu nʼefu nʼihi echiche nke onwe ya, maa unu ikpe ma napụ unu ihe nrite unu.  
\v 19 Onye na-adịghị ejidesikwa onye bụ isi aka ike, onye a na-esite nʼaka ya na-eme ka ahụ niile, nke nkwonkwo ha na akwara ha niile na-ejikọta nʼotu, too eto dị ka Chineke si chọọ ka ha too. 
\s1 Iso Kraịst nwụọ na iso ya dị ndụ 
\p  
\v 20 Ebe ọ bụ na unu esorola Kraịst nwụọ nʼebe ozizi na amamihe niile nke na-achị ụwa nọ, gịnị mekwaranụ unu ji ka na-ebi ndụ dị ka a ga-asị na unu bụ nke ụwa, gịnị mere unu ji na-edo onwe unu nʼokpuru iwu ya dị iche?  
\v 21 “Ejidela nke a aka, edetụla nke a ire, ebitụkwala nke a aka”?  
\v 22 Iwu ndị a niile na-ekwu banyere ihe ndị ga-ala nʼiyi mgbe a na-etinye ha nʼọrụ, ha sitere nʼiwu na ozizi nke mmadụ.  
\v 23 Nʼezie, iwu ndị a yiri ihe e ji amamihe guzobe, nʼihi ụzọ o si akwali mmụọ mmadụ nʼife ofufe dị ka ọ chọrọ, na iweda onwe nʼala, na ịta anụ ahụ ahụhụ. Ma ha abaghị uru o bụla iji ha gbochie agụụ ọjọọ nke anụ ahụ. 
\c 3  
\s1 Ibi ndụ ọhụ site nʼike Kraịst 
\p  
\v 1 Ya mere, ebe e mere ka unu bụrụ ndị so Kraịst bilie nʼọnwụ, tụkwasịnụ obi unu nʼihe dị nʼeluigwe ebe Kraịst nọ nʼakụkụ aka nri Chineke.  
\v 2 Ka echiche gbasara eluigwe ju unu obi. Unu atụfukwala oge ichegbu onwe unu banyere ihe dị nʼụwa.  
\v 3 Nʼihi na unu anwụọla. E zokwara ndụ unu nʼime Chineke site na Kraịst.  
\v 4 Mgbe Kraịst onye bụ ndụ unu ga-apụta ihe, unu ga-esokwa ya pụta ìhè nʼebube ya. 
\p  
\v 5 Meenụ ka ọchịchọ ọjọọ niile nke ụwa dị nʼime unu bụrụ ihe nwụrụ anwụ. Unu etinyekwala aka nʼịkwa iko, adịghị ọcha, ọchịchọ ọjọọ, agụụ ime ihe ọjọọ, na anya ukwu (nke bụkwa ikpere arụsị).  
\v 6 Ọ bụkwa nʼihi ihe ndị a ka ọnụma Chineke na-abịakwasị ndị ahụ na-enupu isi.  
\v 7 Ihe ndị a bụ ihe unu na-eme nʼoge gara aga mgbe unu na-adị ndụ nʼime ha.  
\v 8 Ma ugbu a bụ oge iwezuga ihe ndị a niile na ndụ unu: iwe, na ọnụma, na obi ọjọọ, na nkwulu niile, ya na okwu ihere niile na-esi unu nʼọnụ na-apụta.  
\v 9 Unu agwala ibe unu okwu ụgha, nʼihi na unu eyipụla mmadụ ochie ahụ na-eme ụdị omume a.  
\v 10 Ugbu a, unu eyikwasịla ndụ ọhụrụ ahụ, nke e ji amamihe na-eme ka ọ dị ọhụrụ nʼoyiyi nke onye kere ya.  
\v 11 Nkewa ọbụla adịghị nʼime ndụ a. Ọ dịghị mkpa maọbụ onye Juu maọbụ onye mba ọzọ, maọbụ onye e biri ugwu, maọbụ onye a na-ebighị ugwu. Ọ dịkwaghị mkpa maọbụ onye na-asụ asụsụ ọzọ, ma ọ bu onye ime ọhịa, maọbụ onye Sitia, maọbụ ohu, ma ọ bụkwanụ onye nwe onwe ya. Ihe dị mkpa bụ na Kraịst bụ ihe niile, nọrọkwa nʼime ihe niile. 
\s1 Ịpụta ihe nke ndụ ọhụrụ ahụ 
\p  
\v 12 Ya mere, dị ka ndị Chineke họpụtara, ndị dị nsọ na ndị ọ hụrụ nʼanya, yikwasịnụ onwe unu obi ọmịiko, na obi ebere, na obi dị umeala, na ịdị nwayọọ, na ntachiobi.  
\v 13 Na-anagidenụ ibe unu, gbagharakwa mmejọ ọbụla ibe unu na-emejọ unu. Gbagharanụ dị ka Onyenwe anyị sị gbaghara unu.  
\v 14 Nke kachasị nke, kwerenụ ka ịhụnanya na-achị achị na ndụ unu, nʼihi na ọ bụ nke a na-ejikọta ihe niile nʼotu. 
\p  
\v 15 Ka udo Kraịst na-achị achị nʼime obi unu, ebe unu bụ akụkụ nke otu anụ ahụ ahụ, a kpọrọ unu ka unu nọdụ nʼudo. Mgbe niile, nọọnụ na-ekele.  
\v 16 Ka okwu nke Kraịst biri nʼime unu nʼuju ya. Werenụ amamihe niile na-akụzirịta ibe unu ihe, ma na-adụrịtakwa ibe unu ọdụ. Werekwanụ abụ ọma na abụ nke ime mmụọ bụọrọ Chineke abụ ekele nʼobi unu.  
\v 17 Ka ihe niile unu na-eme, nʼokwu maọbụ nʼomume bụrụ nke e mere na nke e kwuru site nʼaha Onyenwe anyị Jisọs, na-enyekwanụ Chineke Nna ekele site na ya. 
\s1 Okwu dịrị ezinaụlọ ndị nke Kraịst 
\p  
\v 18 Ndị bụ nwunye, doonụ onwe unu nʼokpuru di unu, dị ka ọ kwesiri ime nʼime Onyenwe anyị. 
\p  
\v 19 Unu ndị bụ di, hụnụ nwunye unu nʼanya, unu ejikwala obi ilu na-emeso ha omume. 
\p  
\v 20 Ụmụntakịrị, ruberenụ nne na nna unu isi nʼihe niile, nʼihi na nke a na-amasị Onyenwe anyị. 
\p  
\v 21 Unu bụ nna, unu emela ihe ga-akpasu ụmụ unu iwe, ka ha ghara ịda mba nʼobi. 
\p  
\v 22 Ndị bụ ohu, na-eruberenụ ndị bụ nna unu ukwu nʼanụ ahụ isi nʼihe niile, na-emenụ nke a, ọ bụghị naanị mgbe ha nọ na-ele unu anya, maọbụ mgbe unu chọrọ ịnata ihuọma, kama werenụ obi unu niile, na ịtụ egwu Onyenwe anyị rubere ha isi.  
\v 23 Ihe ọbụla unu na-eme, werenụ obi unu niile mee ya. Ka ọ dị ka ọ bụ Onyenwe anyị ka unu na-arụrụ ya, ọ bụghị dị ka unu na-arụrụ ya mmadụ.  
\v 24 Chetanụ nke ọma na unu nwere ụgwọ ọrụ nke Onyenwe anyị kwadobere inye unu, ndị ya. Nʼihi na ọ bụ Onyenwe anyị Kraịst ka unu na-ejere ozi.  
\v 25 Onye ọbụla na-eme ihe ọjọọ ga-anata ụgwọ ọrụ nʼihi ihe ọjọọ niile o mere. Nʼihi na ile mmadụ anya nʼihu adịghị ya. 
\c 4  
\p  
\v 1 Unu ndị nwe odibo, jirinụ ịkwụba aka ọtọ na ikpe ziri ezi na-emeso ndị ohu unu omume, ebe unu maara na unu onwe unu nwere onyenwe unu nʼeluigwe. 
\s1 Ndụmọdụ ndị fọdụrụ 
\p  
\v 2 Na-anọgidenụ nʼekpere, nọọkwanụ na nche na-enyekwanụ ekele.  
\v 3 Na-echetakwanụ anyị nʼekpere, ka Chineke meghere anyị ụzọ ikwusa oziọma, ka anyị nwee ike kwusaa ihe omimi Kraịst, nke m ji maka ya nọrọ nʼụlọ mkpọrọ,  
\v 4 ka m nwee ike kwuo ya ka o doo anya otu m kwesiri.  
\v 5 Unu were amamihe na-achịkọta onwe unu nʼebe ndị nọ nʼezi nọ, jizienụ ohere ọbụla unu nwere nke ọma.  
\v 6 Ka okwu unu na-ekwu bụrụ nke jupụtara nʼamara na-atọ ụtọ, ka unu mụtakwa otu e si enye mmadụ ọsịsa dị mma. 
\b  
\s1 Ekele ikpeazụ 
\p  
\v 7 Taịkikọs, ezi nwanna anyị, onye kwesikwara ntụkwasị obi, onye anyị na ya na-ejekọ ozi nʼọrụ Onyenwe anyị, ga-akọrọ unu ihe niile banyere m.  
\v 8 Ana m ezitere unu ya, ka unu mara ihe banyere ọnọdụ anyị nakwa ka ọ gbaa obi unu ume.  
\v 9 Ezi nwanna anyị nwoke bụ Onisimọs, onye kwesiri ntụkwasị obi, onye bụkwa otu nʼime unu, so ya na-abịa. Ha ga-agwa unu ihe niile na-eme nʼebe a. 
\b  
\p  
\v 10 Arịstakọs, onye mụ na ya nọ nʼụlọ mkpọrọ, na-ekele unu. Mak nwanne Banabas na-ekelekwa unu. (Onye unu natara ihe ntụziaka banyere ya, ọ bụrụ na ọ bịarute nʼebe unu nọ, unu nabata ya nke ọma.) 
\p  
\v 11 Jisọs, onye a na-akpọkwa Jọstus, na-ekelekwa unu. Ọ bụ naanị ndị a bụ ndị Juu\f + \fr 4:11 \ft Ha bụ ndị Juu site nʼobibi ugwu.\f* mụ na ha na-arụkọ ọrụ alaeze Chineke nʼebe a. Ha na-eme nnọọ nke ọma, na-enye m obi ụtọ. 
\p  
\v 12 Epafras, odibo Kraịst Jisọs na onye bụkwa otu onye nʼime ọgbakọ unu na-ekele unu. Oge niile ka ọ na-ekpe ekpere nʼihi unu, na-arịọ ka unu guzosie ike bụrụ ndị tozuru etozu na ndị kwesiri ike nʼọchịchọ niile nke Chineke.  
\v 13 Ana m agbara ya akaebe na ọ rụsịrị ọrụ ike nʼihi unu na nʼihi ndị Laodisia na ndị Hierapolis. 
\p  
\v 14 Ezi enyi anyị Luk, onye dibịa ukwu anyị na Dimas na-ekele unu. 
\p  
\v 15 Keleerenụ m ụmụnna anyị bi na Laodisia na nwanna anyị Nimfas na chọọchị na-ezukọ nʼụlọ ya. 
\b  
\p  
\v 16 Mgbe unu gụchara akwụkwọ a, hụnụ na a gụkwara ya na nzukọ dị na Laodisia. Gụọkwanụ nʼotu mgbe ahụ akwụkwọ nke si na Laodisia bịa. 
\b  
\p  
\v 17 Gwanụ Akipos ka ọ kpachapụ anya rụchaa ọrụ Onyenwe anyị nyere ya ịrụ. 
\b  
\p  
\v 18 Eji m aka m dee ekele nke a mụ onwe m bụ Pọl. Unu echefula na m nọ nʼagbụ. Ka amara dịnyere unu.