\id 1KI
\h 1 إِجدْجِيذنْ
\toc1 1 إِجدْجِيذنْ
\toc2 1 إِجدْجِيذنْ
\toc3 1 إِج.
\mt1 1 إِجدْجِيذنْ
\c 1
\s1 سُولِيمَانْ إِذْوڒْ ذ أَجدْجِيذْ
\m 
\v 1 ثُوغَا أَجدْجِيذْ ذَاوُوذْ إِوْسَارْ ؤُ إِمْغَارْ ذڭْ وُوسَّانْ. سّْذُورْينْ ث س وَارُّوضْ \add مَاشَا\add* وَارْ ث إِڒْقِيفْ \add عَاذْ\add* ڒحْمُو.
\v 2 نَّانْ أَسْ إِمْسخَّارنْ نّسْ: ”أجّْ أَذْ أَرْزُونْ إِ سِيذِي إِنُو أَجدْجِيذْ إِشْثْ ن ثبْڒِيغْثْ ذ ثَاعْزَارشْثْ ؤُ أجّْ إِ-ت أَذْ ثْبدّْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ، أَذْ ذَايسْ ثثْهِيلَّا. أجّْ إِ-ت أَذْ ثطّصْ غَارْ إِذْمَارنْ نّسْ، حِيمَا سِيذِي إِنُو أَجدْجِيذْ، أَذْ إِذْوڒْ إِحمَّا.“
\v 3 أَرْزُونْ نِيثْنِي ذِي مَارَّا ثَامُّورْثْ ن إِسْرَائِيل خْ إِشْثْ ن ثبْڒِيغْثْ ذَايسْ أَژْرِي. ؤُفِينْ أَبِيشَاجْ، ثَاشُونَامِيثْ، ؤُشَا إِوْينْ ت غَارْ ؤُجدْجِيذْ. \f ◼ \fr 1:‏3 \ft \bd ’ثَاشُونَامِيثْ‘\bd* - إِشْثْ ن ثمْغَارْثْ زِي سُونَامْ نِيغْ زِي شُونَامْ، إِشْثْ ن ثنْذِينْثْ ذِي ثمُّورْثْ ن إِسَّاكَارْ، غَارْ لْجَانُوبْ ن وذْرَارْ ن ثَاپُورْ، ذِي شَّامَالْ ن إِسْرَائِيل. قَّارنْ أَسْ إِ ثنْذِينْثْ-أَ عَاوذْ ’شُولَامْ‘ ؤُ زِي ثنْذِينْثْ-أَ إِ د-ثفّغْ ثسْڒِيثْ إِ خْ نقَّارْ ذڭْ وذْلِيسْ ’إِزْڒِي خْ إِزْڒَانْ‘.\f*
\v 4 ثَابْڒِيغْثْ ثُوغَا ذَايسْ أَژْرِي أَطَّاسْ ؤُ نتَّاثْ ثثْهِيلَّا ذَايسْ ؤُ ثْسخَّارْ خَاسْ. أَجدْجِيذْ وَارْ ت إِسِّينْ شَا. \f ◼ \fr 1:‏4 \ft \bd ’وَارْ ت إِسِّينْ شَا‘\bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي ’وَارْ خَاسْ د-يُوذفْ شَا‘.\f*
\m 
\v 5 أَذُونِييَا، مِّيسْ ن هَاجِّيثْ، إِخْسْ أَذْ إِسُّوعْڒَا إِخفْ نّسْ، إِنَّا: ”نشّْ أَذْ ذوْڒغْ ذ أَجدْجِيذْ.“ نتَّا إِضبَّارْ إِكَارُّوثنْ ذ إِمْنَاينْ ؤُشَا إِزْوَارنْ خمْسِينْ ن يرْيَازنْ س ثَازْڒَا زَّاثْ إِ وُوذمْ نّسْ. \x ◘ \xo 1:‏5 \xt 2 صم. 15‏:‏1\x*
\v 6 بَابَاسْ ثُوغَاعمَّارْصْ وَارْ خَاسْ إِسّقْسحْ \add خْ مَانْ أَيَا\add* ڒَامِي \add ذ أَسْ\add* إِنَّا: ”مَايمِّي إِ ثڭِّيذْ أَيَا؟“ عَاوذْ أَذُونِييَا ثُوغَا غَارسْ إِجّْ ن وَادُّوذْ إِشْنَا. يمَّاسْ ثُورُووْ ث-إِ-د أَوَارْنِي إِ أَبْشَالُومْ. \f ◼ \fr 1:‏6 \ft \bd ’يمَّاسْ‘\bd* - إِخْسْ أَذْ يِينِي ’هَاجِّيثْ‘.\f*  \x ◘ \xo 1:‏6 \xt 1 إِم. 3‏:‏2\x*
\v 7 إِسِّيوڒْ أَكْ-ذ يُووَابْ، مِّيسْ ن صَارُويَا، ؤُ أَكْ-ذ أَبْيَاثَارْ، أَكهَّانْ، ؤُشَا نِيثْنِي وْشِينْ أَفُوسْ إِ أَذُونِييَا. \x ◘ \xo 1:‏7 \xt 1 إِج. 2‏:‏22، 28\x*
\v 8 \add مَاشَا\add* أَكهَّانْ صَاذُوقْ ذ بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ، ذ ؤُنَابِي نَاثَانْ ذ شِيمْعِي ذ رِيعِي ؤُڒَا ذ أَيْثْ ن بُو-ثغْرُوضْثْ نِّي \add إِدْجَانْ\add* غَارْ ذَاوُوذْ، وَارْ قِّيننْ شَا إِخفْ نْسنْ غَارْ أَذُونِييَا.
\m 
\v 9 أَذُونِييَا إِغَارْصْ إِ وُودْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ ذ ڒْمَاڒْ إِصحّنْ غَارْ وژْرُو ن زَاحِيفَا ونِّي غَارْ ثَاڒَا ن رُوجِيلْ. نتَّا إِعَارْضْ مَارَّا أَيْثْمَاسْ، إِحنْجِيرنْ ن ؤُجدْجِيذْ، ؤُ مَارَّا إِرْيَازنْ ن يَاهُوذَا، إِمْسخَّارنْ ن ؤُجدْجِيذْ. \x ◘ \xo 1:‏9 \xt ياش. 15‏:‏7؛ 18‏:‏16\x*
\v 10 \add مَاشَا\add* أَنَابِي نَاثَانْ ذ بَانَايَا ذ أَيْثْ ن بُو-ثغْرُوضْثْ \add ن ذَاوُوذْ\add* ذ ؤُمَاسْ سُولِيمَانْ، وَارْ ثنْ إِعْرِيضْ شَا.
\m 
\v 11 \add خنِّي\add* إِنَّا نَاثَانْ إِ بَاثْ-شَابَاعْ، يمَّاسْ ن سُولِيمَانْ، إِنَّا: ”مَا وَارْ ثسْڒِيذْ شمْ، أَقَا أَذُونِييَا، مِّيسْ ن هَاجِّيثْ، إِذْوڒْ ذ أَجدْجِيذْ؟ أَقَا ذَاوُوذْ، سِيذِيثْنغْ، وَارْ خَاسْ يَارْڭِيبْ؟
\v 12 خنِّي ڒخُّو، أَسْ-د، أجّْ أَيِي أَذْ أَمْ وْشغْ شّْوَارْ، حِيمَا أَذْ ثسّْنجْمذْ ثُوذَارْثْ نّمْ ذ ثُوذَارْثْ ن مِّيمْ سُولِيمَانْ.
\v 13 ؤُيُورْ، أَذفْ غَارْ ؤُجدْجِيذْ ذَاوُوذْ، إِنِي أَسْ: ’\add أَ\add* سِيذِي إِنُو أَجدْجِيذْ، مَا وَارْ ثجُّودْجذْ إِ ثَايَّا نّشْ، ثنِّيذْ: س ثِيذتّْ، مِّيمْ سُولِيمَانْ أَذْ يِيڒِي ذ أَجدْجِيذْ أَوَارْنِي أَيِي ؤُ نتَّا أَذْ إِقِّيمْ خْ ڒْعَارْشْ إِنُو؟ مَايمِّي \add إِذْوڒْ خنِّي\add* أَذُونِييَا ذ أَجدْجِيذْ؟‘
\v 14 خْزَارْ، ؤُمِي شمْ ذِينِّي ثسَّاوَاڒذْ \add عَاذْ\add* أَكْ-ذ ؤُجدْجِيذْ، أَذْ أَذْفغْ ؤُڒَا ذ نشّْ أَذْ كمّْڒغْ أَوَاڒنْ نّمْ.“
\m 
\v 15 بَاثْ-شَابَاعْ ثُوذفْ غَارْ ؤُجدْجِيذْ ذڭْ وخَّامْ ن ذَاخڒْ. أَجدْجِيذْ ثُوغَا إِوْسَارْ أَطَّاسْ ؤُ أَبِيشَاجْ، ثَاسُونَامِيثْ، ثْسخَّارْ خَاسْ.
\v 16 بَاثْ-شَابَاعْ ثُوضَارْ، ثْبنْذقْ إِ ؤُجدْجِيذْ ؤُشَا أَجدْجِيذْ إِنَّا: ”مِينْ شمْ يُوغِينْ؟“
\v 17 نتَّاثْ ثنَّا أَسْ: ”\add أَ\add* سِيذِي إِنُو، شكْ ثجُّودْجذْ إِ ثَايَّا نّشْ غَارْ سِيذِي، أَربِّي نّشْ: ’س ثِيذتّْ، سُولِيمَانْ، مِّيمْ، أَذْ يِيڒِي ذ أَجدْجِيذْ أَوَارْنِي أَيِي ؤُ نتَّا أَذْ إِقِّيمْ خْ ڒْعَارْشْ إِنُو!
\v 18 ؤُشَا ڒخُّو، خْزَارْ، أَذُونِييَا إِذْوڒْ ذ أَجدْجِيذْ، ؤُ ڒخُّو، سِيذِي إِنُو أَجدْجِيذْ، شكْ وَارْ \add خَاسْ\add* ثسَّارْڭِيبذْ شَا.
\v 19 نتَّا إِغَارْصْ إِ وَاطَّاسْ ن إِفُونَاسنْ ذ ڒْمَاڒْ إِصحّنْ ذ وُودْجِي ؤُ نتَّا إِعَارْضْ خْ مَارَّا إِحنْجِيرنْ ن ؤُجدْجِيذْ ؤُ خْ أَبْيَاثَارْ، أَكهَّانْ، ؤُ خْ يُووَابْ، أَكُومَانْذَارْ ن ڒْعسْكَارْ، \add مَاشَا\add* أَمْسخَّارْ نّشْ سُولِيمَانْ، وَارْ ث إِعْرِيضْ شَا.
\v 20 غَاركْ شكْ، \add أَ\add* سِيذِي إِنُو أَجدْجِيذْ، غَاركْ شكْ خزَّارنْثْ مَارَّا ثِيطَّاوِينْ ن إِسْرَائِيل، حِيمَا شكْ أَذْ أَسنْ ثسّشْنذْ مَانْ ونْ إِ غَا إِقِّيمنْ خْ ڒْعَارْشْ ن سِيذِي إِنُو أَجدْجِيذْ أَوَارْنِي أَسْ نتَّا.
\v 21 نِيغْ أَذْ إِمْسَارْ، مَاڒَا سِيذِي إِنُو أَجدْجِيذْ أَذْ إِڭّْ أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ، أَقَا نشّْ ذ مِّي سُولِيمَانْ \add أَذْ تّْوَاحسْبنْ\add* ذ أَيْثْ ن ڒْمُوعْصِييّثْ.‘ “ \f ◼ \fr 1:‏21 \ft \bd ’مُوذْنِيبِينْ‘\bd* - نِيغْ ’إِمذْنَابْ‘.\f*
\m 
\v 22 ؤُ خْزَارْ، أَمْ ثسَّاوَاڒْ نتَّاثْ عَاذْ أَكْ-ذ ؤُجدْجِيذْ، يُوذفْ-د أَنَابِي نَاثَانْ.
\v 23 خبَّارنْ \add أَيَا\add* إِ ؤُجدْجِيذْ، نَّانْ: ”خْزَارْ، أَقَا ذَا أَنَابِي نَاثَانْ.“ نتَّا يُوسَا-د زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ، إِبنْذقْ زَّاثْ إِ ؤُجدْجِيذْ س ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ.
\v 24 إِنَّا نَاثَانْ: ”سِيذِي إِنُو أَجدْجِيذْ، مَا ثنِّيذْ شكْ: ’أَذُونِييَا أَذْ يِيڒِي ذ أَجدْجِيذْ أَوَارْنِي أَيِي ؤُ نتَّا أَذْ إِقِّيمْ خْ ڒْعَارْشْ إِنُو‘؟
\v 25 مَاغَارْ نتَّا إِهْوَا أَسّْ-أَ ؤُ نتَّا إِغَارْصْ إِ وَاطَّاسْ ن إِفُونَاسنْ ذ ڒْمَاڒْ إِصحّنْ ذ وُودْجِي ؤُ إِعَارْضْ خْ مَارَّا إِحنْجِيرنْ ن ؤُجدْجِيذْ ؤُ خْ إِكُومَانْذَارنْ ن ڒْعسْكَارْ ؤُ خْ ؤُكهَّانْ أَبْيَاثَارْ. خْزَارْ نِيثْنِي تّتّنْ، سسّنْ زَّاثْ إِ وُوذمْ نّسْ، قَّارنْ: ’أَذْ إِدَّارْ ؤُجدْجِيذْ أَذُونِييَا!‘
\v 26 \add مَاشَا\add* نشّْ، نشّْ ونِّي ذ أَمْسخَّارْ نّشْ، ذ ؤُكهَّانْ صَاذُوقْ ذ بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ، ذ سُولِيمَانْ، أَمْسخَّارْ نّشْ، وَارْ ذ أَنغْ إِعْرِيضْ شَا.
\v 27 مَا إِفّغْ-د وَاوَاڒْ-أَ زِي سِيذِي إِنُو أَجدْجِيذْ؟ مَا \add خنِّي\add* وَارْ ثسَّارْڭِيبذْ شَا أَمْسخَّارْ نّشْ، مَانْ ونْ إِ غَا إِقِّيمنْ خْ ڒْعَارْشْ ن سِيذِي إِنُو أَجدْجِيذْ أَوَارْنِي أَسْ؟“
\b
\m 
\v 28 أَجدْجِيذْ ذَاوُوذْ إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا: ”ڒَْاغَاثْ أَيِي-د خْ بَاثْ-شَابَاعْ!“ نتَّاثْ ثُوسَا-د غَارْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ، ثْبدّْ \add ذِينْ\add* زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ.
\v 29 \add خنِّي\add* إِجُّودْجْ ؤُجدْجِيذْ، إِنَّا: ”\add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي، ونِّي إِفكّنْ ڒعْمَارْ إِنُو زِي مَارَّا ڒحْصَارثْ،
\v 30 وَاهْ نِيشَانْ، أَمْ مَامّشْ ذ أَمْ جُّودْجغْ غَارْ سِيذِي، أَربِّي ن إِسْرَائِيل، نِّيغْ: ’أَقَا مِّيمْ سُولِيمَانْ أَذْ يِيڒِي ذ أَجدْجِيذْ أَوَارْنِي أَيِي ؤُ نتَّا أَذْ إِقِّيمْ خْ ڒْعَارْشْ إِنُو ذڭْ ومْشَانْ إِنُو!‘، وَاهْ، أَمُّو \add إِ-ث\add* غَا ڭّغْ س ثِيذتّْ أَسّْ-أَ.“
\v 31 \add خَاسْ ؤُشَا\add* ثُوضَارْ بَاثْ-شَابَاعْ س ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ، ثْبنْذقْ إِ ؤُجدْجِيذْ، ثنَّا: ”أَذْ إِدَّارْ سِيذِي إِنُو، أَجدْجِيذْ ذَاوُوذْ، إِ ڒبْذَا!“
\m 
\v 32 خَاسْ ؤُشَا إِنَّا ؤُجدْجِيذْ ذَاوُوذْ: ”ڒَْاغَاثْ أَيِي-د إِ ؤُكهَّانْ صَاذُوقْ ذ ؤُنَابِي نَاثَانْ ذ بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ!“ ؤُشَا نِيثْنِي ؤُسِينْ-د زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ.
\v 33 إِنَّا أَسنْ ؤُجدْجِيذْ: ”كْسِيمْ إِمْسخَّارنْ ن سِيذِيثْومْ أَكِيذْومْ ؤُ أجّْ مِّي سُولِيمَانْ أَذْ إِنِييْ خْ ؤُسَارْذُونْ إِ غَارِي \add إِدْجَانْ\add* ؤُ سهْوَا ث غَارْ جِيحُونْ.
\v 34 أجّْ أَكهَّانْ صَاذُوقْ أَكْ-ذ ؤُنَابِي نَاثَانْ أَذْ ث إِذْهنْ ذِينِّي ذ أَجدْجِيذْ خْ إِسْرَائِيل. \add خنِّي\add* أَذْ ثْسُوضمْ ذڭْ ؤُيِيشّْ ن إِشَارِّي، أَذْ ثِينِيمْ: ’ثُوذَارْثْ إِ سُولِيمَانْ!‘
\v 35 إِتّْخصَّا أَذْ ثْڭعّْذمْ أَوَارْنِي أَسْ ؤُ نتَّا أَذْ د-يَاسْ أَذْ إِقِّيمْ خْ ڒْعَارْشْ إِنُو. نتَّا أَذْ يِيڒِي ذ أَجدْجِيذْ ذڭْ ومْشَانْ إِنُو، \add مَاغَارْ\add* نشّْ ؤُمُورغْ أَسْ حِيمَا أَذْ يِيڒِي ذ ڒْحَاكمْ خْ إِسْرَائِيل ؤُ خْ يَاهُوذَا.“
\v 36 بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ، يَارَّا-د خْ ؤُجدْجِيذْ، إِنَّا: ”أَمِينْ، أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن سِيذِي إِنُو أَجدْجِيذْ!
\v 37 أَمْ مَامّشْ ثُوغَا إِدْجَا سِيذِي أَكْ-ذ سِيذِي إِنُو أَجدْجِيذْ، أَمُّو إِ غَا يِيڒِي نتَّا ؤُڒَا أَكْ-ذ سُولِيمَانْ. إِڒِي نتَّا أَذْ إِسّمْغَارْ \add عَاذْ\add* ڒْعَارْشْ نّسْ خْ ڒْعَارْشْ ن سِيذِي إِنُو، أَجدْجِيذْ ذَاوُوذْ!“
\m 
\v 38 \add خنِّي\add* إِهْوَا ؤُكهَّانْ صَاذُوقْ أَكْ-ذ ؤُنَابِي نَاثَانْ ذ بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ، ؤُ أَكْ-ذ إِعسَّاسنْ ن أَرِّيمثْ ذ إِرقَّاسنْ ن ثَازْڒَا. نِيثْنِي سّنْينْ سُولِيمَانْ خْ ؤُسَارْذُونْ ن ؤُجدْجِيذْ ذَاوُوذْ ؤُ نذْهنْ ث غَارْ جِيحُونْ.
\v 39 أَكهَّانْ صَاذُوقْ، إِكْسِي إِشّْ س زّشْثْ زڭْ ؤُقِيضُونْ ؤُشَا إِذْهنْ سُولِيمَانْ. نِيثْنِي سُوضنْ ذڭْ ؤُيِيشّْ ن إِشَارِّي ؤُ مَارَّا ڒْڭنْسْ إِنَّا: ”ثُوذَارْثْ إِ ؤُجدْجِيذْ سُولِيمَانْ!“ \x ◘ \xo 1:‏39 \xt 1 صم. 20‏:‏24\x*
\v 40 مَارَّا ڒْڭنْسْ إِڭعّذْ أَوَارْنِي أَسْ. إِوْذَانْ صفَّارنْ ذِي ثْزَامَارِينْ ؤُ فَارْحنْ س إِشْثْ ن ڒفْرَاحثْ ثمْغَارْ \add أَڒَامِي\add* ثْفدْجقْ ثمُّورْثْ س ڒْحسّْ نْسنْ. \f ◼ \fr 1:‏40 \ft \bd ’إِوْذَانْ‘\bd* - س ثْعِيبْرَانِيثْ ’ڒْڭنْسْ‘.\f*
\m 
\v 41 إِسْڒَا أَيَا أَذُونِييَا أَكْ-ذ مَارَّا إِنوْجِيونْ نِّي غَارسْ \add إِدْجَانْ\add*. نِيثْنِي ثُوغَا بْحْڒَا مُّونْسْونْ. ؤُڒَا ذ يُووَابْ إِسْڒَا إِ ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي، إِنَّا: ”مَانَا ڒْحسّْ زِي ثنْذِينْثْ أَمُّو س زّْهِيرْ أَطَّاسْ؟“
\v 42 \add أَمْ\add* إِسَّاوَاڒْ نتَّا عَاذْ، يُوسَا-د يُونَاثَانْ، مِّيسْ ن ؤُكهَّانْ أَبْيَاثَارْ. أَذُونِييَا إِنَّا: ”أَذفْ-د غَارْ ذَاخڒْ، مِينْزِي شكْ ذ إِجّْ ن ورْيَازْ إِمحْضنْ. شكْ أَذْ ثَاوْيضْ \add نِيشَانْ\add* إِجّْ ن ڒخْبَارْ أَصبْحَانْ.“
\v 43 يُونَاثَانْ يَارَّا-د، إِنَّا إِ أَذُونِييَا: ”س ڒمْقْڒُوبْ، سِيذِيثْنغْ، أَجدْجِيذْ ذَاوُوذْ، إِڭَّا سُولِيمَانْ ذ أَجدْجِيذْ.
\v 44 أَجدْجِيذْ إِسّكّْ أَكِيذسْ أَكهَّانْ صَاذُوقْ ذ ؤُنَابِي نَاثَانْ ذ بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ، ذ إِعسَّاسنْ ن أَرِّيمثْ ذ إِرقَّاسنْ ن ثَازْڒَا ؤُ إِنَا ڭِّينْ ث أَذْ إِنِييْ خْ ؤُسَارْذُونْ ن ؤُجدْجِيذْ.
\v 45 أَكهَّانْ صَاذُوقْ ذ ؤُنَابِي نَاثَانْ ذهْننْ ث ذ أَجدْجِيذْ ذِي جِيحُونْ ؤُ سّنِّي ڭعّْذنْ س ڒفْرَاحثْ أَڒَامِي ثهْوڒْ ثنْذِينْثْ. أَيَا ذ ڒْحسّْ إِ ثسْڒِيمْ.
\v 46 ؤُڒَا ذ سُولِيمَانْ إِتّْغِيمَا خْ ڒْعَارْشْ ن ثْڭلْذِيثْ.
\v 47 ؤُڒَا ذ إِمْسخَّارنْ ن ؤُجدْجِيذْ ؤُسِينْ-د، حِيمَا أَذْ بَارْكنْ سِيذِيثْنغْ، أَجدْجِيذْ ذَاوُوذْ، نَّانْ: ’إِڒِي أَذْ يَارّْ أَربِّي نّشْ إِسمْ ن سُولِيمَانْ \add عَاذْ\add* إِشْنَا خْ يِيسمْ نّشْ ؤُ أَذْ يَارّْ ڒْعَارْشْ نّسْ \add عَاذْ\add* إِمْغَارْ خْ ڒْعَارْشْ نّشْ.‘ \add خَاسْ ؤُشَا\add* إِبنْذقْ ؤُجدْجِيذْ خْ ثَاسُّوثْ نّسْ.
\v 48 عَاوذْ إِنَّا ؤُجدْجِيذْ: ’أَذْ إِتّْوَابَاركْ سِيذِي، أَربِّي ن إِسْرَائِيل، ونِّي إِوْشِينْ أَسّْ-أَ أَذْ إِقِّيمْ \add إِجّنْ\add* خْ ڒْعَارْشْ إِنُو، \add ؤُمِي\add* ثِيطَّاوِينْ إِنُو \add عَاذْ\add* زمَّارنْثْ أَذْ ثْوَاڒَانْثْ \add أَيَا\add*.‘ “
\m 
\v 49 مَارَّا إِنوْجِيونْ إِنِّي \add ثُوغَا إِدْجَانْ\add* غَارْ أَذُونِييَا نّْخڒْعنْ، كَّارنْ ؤُشَا فّْغنْ، \add كُوڒْ\add* أَرْيَازْ يُويُورْ أَبْرِيذْ نّسْ.
\v 50 أَذُونِييَا إِڭّْوذْ زِي سُولِيمَانْ. نتَّا إِكَّارْ، يُويُورْ ؤُشَا إِشبَّارْ ذڭْ وَاشَّاونْ ن ؤُعَالْطَارْ.
\v 51 خبَّارنْ مَانْ أَيَا غَارْ سُولِيمَانْ، نَّانْ: ”خْزَارْ، أَذُونِييَا، إِڭّْوذْ زڭْ ؤُجدْجِيذْ سُولِيمَانْ، \add مَاغَارْ\add* أَقَا نتَّا إِشبَّارْ ذڭْ وَاشَّاونْ ن ؤُعَالْطَارْ، إِقَّارْ: ’أجّْ أَجدْجِيذْ سُولِيمَانْ أَذْ أَيِي إِجَّادْجْ أَسّْ-أَ، أَقَا نتَّا وَارْ إِنقّْ أَمْسخَّارْ نّسْ س سِّيفْ!‘ “
\v 52 إِنَّا سُولِيمَانْ: ”مَاڒَا نتَّا إِبَانْ-د ذ إِجّْ ن ورْيَازْ ذ أَمْثِيقِّي، وَارْ خَاسْ إِوطِّي ؤُڒَا ذ إِجّْ ن ؤُزطُّو ن ؤُشُوَّافْ نّسْ، مَاشَا مَاڒَا إِتّْوَافْ ذَايسْ ثُوعفّْنَا، إِتّْخصَّا أَذْ إِمّثْ.“
\v 53 أَجدْجِيذْ سُولِيمَانْ إِسّكّْ \add شَا ن إِرقَّاسنْ\add* ؤُ نِيثْنِي كسِّينْ ث زڭْ ؤُعَالْطَارْ ؤُ نتَّا يُوسَا-د، إِبنْذقْ زَّاثْ إِ ؤُجدْجِيذْ سُولِيمَانْ. إِنَّا أَسْ سُولِيمَانْ: ”رُوحْ غَارْ ثَادَّارْثْ نّشْ!“
\b
\b
\c 2
\s1 أَوَاڒنْ إِنڭُّورَا ن ذَاوُوذْ إِ سُولِيمَانْ
\m 
\v 1 \add ؤُمِي\add* د-ؤُذْسنْ وُوسَّانْ ن ذَاوُوذْ أَذْ إِمّثْ، إِعْڒمْ نتَّا إِ مِّيسْ سُولِيمَانْ، إِنَّا:
\v 2 ”نشّْ أَذْ ؤُيُورغْ أَبْرِيذْ ن مَارَّا ثَامُّورْثْ. إِڒِي ثْمحْضذْ ؤُ إِڒِي ذ أَرْيَازْ!
\v 3 حْضَا أَوكّڒْ ن سِيذِي، أَربِّي نّشْ، حِيمَا أَذْ ثُويُورذْ ذِي ثبْرِيذِينْ نّسْ، مَاحنْذْ أَذْ ثطّْفذْ ذِي ثْوصَّا نّسْ ذ ڒُومُورَاثْ نّسْ ذ لْفَارَايِيضْ نّسْ ذ شّْهَاذَاثْ نّسْ أَمْ مَامّشْ ث يُورَا ذِي شَّارِيعَا ن مُوسَا، حِيمَا أَذْ ثڭّذْ س ڒعْقڒْ ذِي مَارَّا مِينْ غَا ثڭّذْ ذ مَانِي مَا إِ غَا ثْرَاحذْ، \x ◘ \xo 2:‏3 \xt أَعَوذ. 17‏:‏18؛ 29‏:‏9؛ ياش. 1‏:‏7\x*
\v 4 حِيمَا أَذْ إِكمّڒْ سِيذِي أَوَاڒْ نّسْ إِ خَافِي إِسِّيوڒْ، \add ؤُمِي\add* إِنَّا: ’مَاڒَا إِحنْجِيرنْ نّشْ أَذْ حْضَانْ أَبْرِيذْ نْسنْ س وُوڒْ نْسنْ مَارَّا ؤُ س ڒعْمَارْ نْسنْ مَارَّا، حِيمَا أَذْ ؤُيُورنْ س ڒَامَانْ زَّاثْ إِ وُوذمْ إِنُو، \add خنِّي\add* وَارْ شكْ إِتّْخصِّي ورْيَازْ خْ ڒْعَارْشْ ن إِسْرَائِيل. \x ◘ \xo 2:‏4 \xt 2 صم. 7‏:‏12؛ إِزهد. 132‏:‏12\x*
\m 
\v 5 شكْ ثسّْنذْ عَاوذْ مِينْ إِ ذ أَيِي إِڭَّا يُووَابْ، مِّيسْ ن صَارُويَا، مِينْ إِڭَّا نتَّا إِ ثْنَاينْ ن إِكُومَانْذَارنْ ن ڒْعسْكَارَاثْ ن إِسْرَائِيل، إِ أَبْنِيرْ، مِّيسْ ن نِيرْ، ؤُ إِ عَامَاسَا، مِّيسْ ن يَاثِيرْ. نتَّا إِنْغَا إِ-ثنْ. ذِي \add ڒْوقْثْ ن\add* ڒهْنَا إِسِّيزّڒْ إِذَامّنْ \add أَمْ ذِي ڒْوقْثْ\add* ن ؤُمنْغِي ؤُشَا \add أَمْ ذِي ڒْوقْثْ\add* ن ؤُمنْغِي إِڭَّا إِذَامّنْ غَارْ وبْيَاسْ نّسْ إِ غَارسْ غَارْ ثجْعِينَّا نّسْ ؤُڒَا غَارْ سَانْذَالِييَاثْ نّسْ نِّي خْ إِضَارنْ نّسْ. \x ◘ \xo 2:‏5 \xt 2 صم. 3‏:‏27؛ 20‏:‏10\x*
\v 6 أڭّْ عْلَاحْسَابْ ثِيغِيثْ نّشْ ؤُ وَارْ تّجِّي أَشُوَّافْ نّسْ إِشَابنْ أَذْ إِهْوَا غَارْ ڒَاخَارْثْ ذِي ڒهْنَا.
\m 
\v 7 سْشنْ ثَامخْسِيوْثْ إِشوَّارنْ إِ أَيْثْ ن بَارْزِيلَّايْ زِي جِيلْعَاذْ. نِيثْنِي أَذْ إِڒِينْ جَارْ إِنِّي إِ غَا إِشّنْ زِي طَّابْڒَا نّشْ، مَاغَارْ أَمُّو إِ د-يُوسِينْ غَارِي ؤُمِي أَروْڒغْ زَّاثْ إِ وُوذمْ ن ؤُمَاشْ أَبْشَالُومْ. \x ◘ \xo 2:‏7 \xt 2 صم. 17‏:‏27؛ 19‏:‏31\x*
\m 
\v 8 خْزَارْ شِيمْعِي، مِّيسْ ن جِيرَا، زڭْ أَيْثْ نّْ بِينْيَامِينْ، زِي بَاخُورِيمْ. ؤُڒَا ذ نتَّا أَكِيذكْ. نتَّا إِنْعڒْ أَيِي س إِشْثْ ن نّعْڒثْ إِقسْحنْ ذڭْ وَاسّْ ؤُمِي نشّْ أَروْڒغْ غَارْ مَاحَانَايِيمْ، مَاشَا إِمّْسڒْقَا أَكِيذِي غَارْ لْ-ؤُرْذُونْ ؤُ نشّْ جُّودْجغْ أَسْ غَارْ سِيذِي، نِّيغْ: ’\add غَارِي\add* مَاڒَا أَذْ شكْ نْغغْ س سِّيفْ!‘ \x ◘ \xo 2:‏8 \xt 2 صم. 16‏:‏5؛ 19‏:‏19\x*
\v 9 \add خنِّي\add* ڒخُّو، وَارْ ث حصّبْ ذ أَمزْذَاڭْ، مَاغَارْ شكْ ذ إِجّْ ن ورْيَازْ ذ أَمِيغِيسْ ؤُ ثسّْنذْ مِينْ ذ أَسْ غَا ثڭّذْ، حِيمَا أَشُوَّافْ نّسْ إِشَابنْ أَذْ إِهْوَا غَارْ ڒَاخَارْثْ س إِذَامّنْ.“
\m 
\v 10 ذَاوُوذْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نتَّا إِتّْوَانْضڒْ ذِي ثنْذِينْثْ ن ذَاوُوذْ. \x ◘ \xo 2:‏10 \xt ڒخ. 2‏:‏29؛ 13‏:‏36\x*
\v 11 ؤُسَّانْ إِ ذِي ثُوغَا إِحكّمْ ذَاوُوذْ خْ إِسْرَائِيل، \add ثُوغَا أَثنْ\add* أَربْعِينْ ن إِسڭّْوُوسَا. سبْعَا ن إِسڭّْوُوسَا إِحْكمْ ذِي حَابْرُونْ ؤُ ذِي ؤُرْشَالِيمْ إِحْكمْ ثْڒَاثَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا. \x ◘ \xo 2:‏11 \xt 1 إِم. 29‏:‏27\x*
\b
\s1 ثِيمڭَّا ثِيمزْوُورَا ن ؤُجدْجِيذْ سُولِيمَانْ
\m 
\v 12 سُولِيمَانْ إِقِّيمْ خْ ڒْعَارْشْ ن بَابَاسْ ذَاوُوذْ ؤُ ثَاڭلْذَا نّسْ ثذْوڒْ ثَارنِّي ذِي ڒمْثنْ أَطَّاسْ. \x ◘ \xo 2:‏12 \xt 1 إِم. 29‏:‏23؛ 2 إِم. 1‏:‏1\x*
\v 13 \add خنِّي\add* أَذُونِييَا، مِّيسْ ن هَاجِّيثْ، يُوسَا-د غَارْ بَاثْ-شَابَاعْ، يمَّاسْ ن سُولِيمَانْ. نتَّاثْ ثنَّا: ”مَا ثَاوَاسِيثْ نّشْ س ڒهْنَا؟“ نتَّا إِنَّا: ”ڒهْنَا!“
\v 14 نتَّا إِنَّا: ”نشّْ غَارِي كِيمْ إِجّْ ن وَاوَاڒْ.“ نتَّاثْ ثنَّا \add أَسْ\add*: ”سِيوڒْ!“
\v 15 إِنَّا نتَّا: ”شمْ ثسّْنذْ، أَقَا ثَاڭلْذِيثْ ثُوسَا أَيِي-د ؤُ مَارَّا إِسْرَائِيل إِڭَّا ذَايِي ثِيطَّاوِينْ، حِيمَا أَذْ ذوْڒغْ ذ أَجدْجِيذْ. \add مَاشَا\add* ثَاڭلْذَا ثنّقْڒبْ ؤُشَا ثذْوڒْ إِ ؤُمَا، مِينْزِي ثُوسَا أَسْ-د زِي سِيذِي. \x ◘ \xo 2:‏15 \xt 1 إِم. 22‏:‏9؛ 28‏:‏5\x*
\v 16 ڒخُّو \add مَاشَا\add* خْسغْ أَذْ غَارمْ تَّارغْ إِشْثْ ن ڒْحَاجّثْ \add وَاهَا\add*. وَارْ ذ أَيِي ثَاڭِي!“ نتَّاثْ ثنَّا: أَسْ: ”سِيوڒْ!“
\v 17 نتَّا إِنَّا: ”سِيوڒْ أَكْ-ذ ؤُجدْجِيذْ سُولِيمَانْ - مَاغَارْ نتَّا وَارْ شمْ إِتَّارِّي - \add حِيمَا\add* نتَّا أَذْ أَيِي إِوْشْ أَبِيشَاجْ، ثَاسُونَامِيثْ، ذ ثَامْغَارْثْ.“
\v 18 بَاثْ-شَابَاعْ ثنَّا: ”مْلِيحْ، نشّْ أَذْ سِّيوْڒغْ أَكْ-ذ ؤُجدْجِيذْ ذِي طّْوعْ نّشْ.“
\m 
\v 19 \add خنِّي\add* ثُوسَا-د بَاثْ-شَابَاعْ غَارْ ؤُجدْجِيذْ سُولِيمَانْ، حِيمَا أَكِيذسْ ثسِّيوڒْ خْ أَذُونِييَا. أَجدْجِيذْ إِكَّارْ إِ ؤُمْسَاڭَارْ أَكِيذسْ، يُوضَارْ زَّاثسْ. \add أَوَارْنِي مَانْ أَيَا\add* إِقِّيمْ خْ ڒْعَارْشْ، إِجَّا أَذْ \add ذِينْ\add* سَّارْسنْ إِجّْ ن ڒْكُورْسِي إِ يمَّاسْ ن ؤُجدْجِيذْ ؤُ نتَّاثْ ثقِّيمْ غَارْ ؤُفُوسْ أَفُوسِي نّسْ.
\v 20 \add خنِّي\add* ثنَّا \add أَسْ\add* نتَّاثْ: ”نشّْ خْسغْ أَذْ أَشْ تَّارغْ إِشْثْ ن ڒْحَاجّثْ \add وَاهَا\add*. وَارْ ذ أَيِي ثَاڭِي!“ إِنَّا أَسْ ؤُجدْجِيذْ: ”سقْسَا، يمَّا، نشّْ وَارْ شمْ تَّارِّيغْ شَا.“
\v 21 نتَّاثْ ثنَّا \add أَسْ\add*: ”\add تّْزَاوْڭغْ شكْ\add* حِيمَا أَذْ ثمّوْشْ أَبِيشَاجْ، ثَاسُونَامِيثْ، إِ ؤُمَاشْ أَذُونِييَا ذ ثَامْغَارْثْ.“
\v 22 أَجدْجِيذْ سُولِيمَانْ يَارَّا-د \add خَاسْ\add*، إِنَّا إِ يمَّاسْ: ”مَايمِّي ثتَّارذْ شمْ إِ أَذُونِييَا أَبِيشَاجْ، ثَاسُونَامِيثْ؟ تَّارْ \add خنِّي ؤُڒَا ذ\add* ثَاڭلْذَا، مَاغَارْ نتَّا ذ ؤُمَا ونِّي ذ أَمقّْرَانْ خَافِي، \add وَاهْ تَّارْ إِ-ت\add* إِ نتَّا ؤُ إِ ؤُكهَّانْ أَبْيَاثَارْ ذ يُووَابْ، مِّيسْ ن صَارُويَا.“
\m 
\v 23 أَجدْجِيذْ سُولِيمَانْ إِجُّودْجْ غَارْ سِيذِي، إِنَّا: ”أَذْ أَيِي إِڭّْ أَربِّي ثَا ذ ثَا ؤُ \add عَاذْ\add* كْثَارْ زِي مَانْ أَيَا، مَاغَارْ أَذُونِييَا إِسِّيوڒْ أَوَاڒْ-أَ ضِيدّْ إِ ثُوذَارْثْ نّسْ!
\v 24 \add خنِّي\add* ڒخُّو، \add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي، ونِّي ذ أَيِي إِسّمْثْننْ ؤُ ونِّي ذ أَيِي إِسّْغِيمَانْ خْ ڒْعَارْشْ ن ثْڭلْذِيثْ ن بَابَا ذَاوُوذْ ؤُ ونِّي ذ أَيِي إِڭِّينْ إِشْثْ ن ثَادَّارْثْ أَمْ مَامّشْ ثُوغَا إِنَّا \add قْبڒْ إِ بَابَا ذَاوُوذْ\add*، س ثِيذتّْ، أَذُونِييَا أَذْ إِتّْوَانغْ أَسّْ-أَ!“ \x ◘ \xo 2:‏24 \xt 2 صم. 7‏:‏12، 13\x*
\v 25 خَاسْ ؤُشَا إِسّكّْ ؤُجدْجِيذْ سُولِيمَانْ \add ڒُْومُورْ-أَ\add* س ؤُفُوسْ ن بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ. وَانِيثَا إِوْثَا إِ-ث ؤُشَا إِمُّوثْ أَذُونِييَا.
\m 
\v 26 إِنَّا ؤُجدْجِيذْ إِ ؤُكهَّانْ أَبْيَاثَارْ: ”ؤُيُورْ غَارْ عَانَاثُوثْ، غَارْ ثمُّورْثْ نّشْ، مَاغَارْ شكْ ذ إِجّْ ن ورْيَازْ \add إِسْذَاحدْجْ\add* ڒْموْثْ. أَسّْ-أَ مَاشَا وَارْ شكْ نقّغْ شَا، مِينْزِي شكْ ثَارْبُوذْ تَّابُوثْ ن سِيذِي إِنُو، سِيذِي، زَّاثْ إِ وُوذمْ ن بَابَا ذَاوُوذْ، ؤُ مِينْزِي شكْ ثْودّْبذْ ؤُڒَا س مَارَّا إِ زِي إِودّبْ بَابَا.“ \x ◘ \xo 2:‏26 \xt 1 صم. 22‏:‏20‏-‏23؛ 2 صم. 15‏:‏24\x*
\v 27 سُولِيمَانْ يُوژّڒْ خْ أَبْيَاثَارْ أَڒَامِي نتَّا وَارْ ثُوغِي عَاذْ ذ أَكهَّانْ إِ سِيذِي، حِيمَا أَذْ إِتّْوَاكمّڒْ وَاوَاڒْ ن سِيذِي إِ ثُوغَا إِسِّيوڒْ زِي جِّيهثْ ن ثَادَّارْثْ ن عَالِي ذِي شِيلُو. \x ◘ \xo 2:‏27 \xt 1 صم. 2‏:‏31‏-‏36\x*
\m 
\v 28 \add ؤُمِي\add* يِيوضْ ڒخْبَارْ غَارْ يُووَابْ - أَقَا يُووَابْ إِفّغْ، إِضْفَارْ أَذُونِييَا، وَاخَّا نتَّا وَارْ د-إِفِّيغْ شَا، حِيمَا أَذْ إِضْفَارْ أَبْشَالُومْ - يَارْوڒْ يُووَابْ غَارْ ؤُقِيضُونْ ن سِيذِي ؤُشَا إِطّفْ أَشَّاونْ ن ؤُعَالْطَارْ. \x ◘ \xo 2:‏28 \xt 1 إِج. 1‏:‏50\x*
\v 29 خبَّارنْ أَجدْجِيذْ سُولِيمَانْ أَقَا يُووَابْ يَارْوڒْ غَارْ ؤُقِيضُونْ ن سِيذِي. ؤُ خْزَارْ، إِبدّْ \add ذِينْ\add* غَارْ ؤُعَالْطَارْ. سُولِيمَانْ إِسّكّْ \add غَارسْ\add* بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ، إِنَّا: ”رُوحْ \add ذِينْ\add*، نغْ إِ-ث!“
\v 30 بَانَايَا يُوسَا-د غَارْ ؤُقِيضُونْ ن سِيذِي ؤُشَا إِنَّا أَسْ: ”أَمُّو إِ إِقَّارْ ؤُجدْجِيذْ: ’فّغْ-د غَارْ بَارَّا!‘ “ نتَّا إِنَّا: ”لَّ، نشّْ خْسغْ أَذْ مّْثغْ ذَا!“ بَانَايَا إِسِّيوضْ ثَامْوَارِّيثْ غَارْ ؤُجدْجِيذْ، إِنَّا: ”أَمُّو إِ إِسِّيوڒْ يُووَابْ ؤُ أَمُّو خَافِي د-يَارَّا.“
\v 31 إِنَّا أَسْ ؤُجدْجِيذْ: ”أڭّْ مِينْ إِ ذ أَشْ إِنَّا نتَّا،غضْڒْ إِ-ث ؤُشَا نضْڒْ إِ-ث، حِيمَا أَذْ ثَاڭّْوجذْ خَافِي ؤُ خْ ثَادَّارْثْ ن بَابَا إِذَامّنْ إِ إِسِّيزّڒْ يُووَابْ بَاطڒْ.
\v 32 \add أَمُّو\add* إِ غَا يَارّْ سِيذِي إِذَامّنْ إِ إِسِّيزّڒْ نتَّا خْ ؤُزدْجِيفْ نّسْ، مِينْزِي نتَّا إِسّْحيّذْ ثْنَاينْ ن يرْيَازنْ، إِنِّي إِسڭّْذنْ ؤُ إِحْڒَانْ خَاسْ، ؤُشَا إِنْغَا إِ-ثنْ س سِّيفْ ؤُمِي بَابَا ذَاوُوذْ وَارْ ث إِسِّينْ: أَبْنِيرْ، مِّيسْ ن نِيرْ، أَكُومَانْذَارْ ن ڒْعسْكَارْ ن إِسْرَائِيل، ؤُ عَامَاسَا، مِّيسْ ن يَاثِيرْ، أَكُومَانْذَارْ ن ڒْعسْكَارْ ن يَاهُوذَا.
\v 33 \add أَمُّو\add* إِ غَاعقْبنْ إِذَامّنْ نْسنْ خْ ؤُزدْجِيفْ ن يُووَابْ ؤُ خْ ؤُزدْجِيفْ ن ثَارْوَا نّسْ إِ ڒبْذَا. \add مَاشَا\add* ذَاوُوذْ ذ ثَارْوَا نّسْ ذ ثَادَّارْثْ نّسْ ذ ڒْعَارْشْ نّسْ، أَذْ غَارْسنْ يِيڒِي ڒهْنَا زِي سِيذِي إِ ڒبْذَا.“
\v 34 بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ، إِڭعّذْ غَارْ ؤُعَالْطَارْ، إِوْثَا إِ-ث ؤُشَا إِنْغَا إِ-ث. نتَّا إِتّْوَانْضڒْ ذِي ثَادَّارْثْ نّسْ ذِي ڒخْڒَا.
\v 35 أَجدْجِيذْ إِڭَّا \add خنِّي\add* بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ، ذڭْ ومْشَانْ نّسْ خْ ڒْعسْكَارْ ؤُشَا أَجدْجِيذْ إِڭَّا صَاذُوقْ، أَكهَّانْ، ذڭْ ومْشَانْ ن أَبْيَاثَارْ. \x ◘ \xo 2:‏35 \xt 1 صم. 2‏:‏35\x*
\m 
\v 36 \add خنِّي\add* إِجَّا ؤُجدْجِيذْ أَذْ ڒَاغَانْ إِ شِيمْعِي، إِنَّا أَسْ: ”بْنَا إِ يِيخفْ نّشْ إِشْثْ ن ثَادَّارْثْ ذِي ؤُرْشَالِيمْ ؤُشَا زْذغْ ذِينْ، وَارْ تّفّغْ غَارْ ذَا ؤُڒَا غَارْ ذِيهَا!
\v 37 أَذْ إِمْسَارْ ذڭْ وَاسّْ إِ ذِي إِ غَا ثفّْغذْ، أَذْ ثژْوِيذْ ثِيغْزَارْثْ ن قِيذْرُونْ، أَقَا أَذْ ثسّْنذْ نِيشَانْ أَذْ ثمّْثذْ نْهْڒَا مَّا. إِذَامّنْ نّشْ أَذْ إِڒِينْ خْ ؤُزدْجِيفْ نّشْ.“
\v 38 شِيمْعِي يَارَّا-د خْ ؤُجدْجِيذْ: ”أَوَاڒْ-أَ ذ لمْلِيحْ. أَمْ مَامّشْ إِسِّيوڒْ سِيذِي إِنُو أَجدْجِيذْ، أَمُّو إِ غَا إِڭّْ ؤُڒَا ذ ؤُمْسخَّارْ نّشْ.“ ؤُ شِيمْعِي ثُوغَا إِزدّغْ أَطَّاسْ ن وُوسَّانْ ذِي ؤُرْشَالِيمْ.
\m 
\v 39 \add مَاشَا\add* أَوَارْنِي إِ ثْڒَاثَا ن إِسڭّْوُوسَا، إِمْسَارْ، أَقَا ثْنَاينْ ن إِمْسخَّارنْ ن شِيمْعِي أَروْڒنْ غَارْ أَخِيشْ، مِّيسْ ن مَاعْكَا، أَجدْجِيذْ ن جَاثْ. خبَّارنْ أَيَا إِ شِيمْعِي، نَّانْ: ”خْزَارْ، إِمْسخَّارنْ نّشْ أَقَا أَثنْ ذِي جَاثْ.“
\v 40 \add خنِّي\add* إِكَّارْ شِيمْعِي، إِبَارْذعْ إِ وغْيُوڒْ نّسْ ؤُشَا يُويُورْ غَارْ أَخِيشْ غَارْ جَاثْ، حِيمَا أَذْ يَارْزُو خْ إِمْسخَّارنْ نّسْ. شِيمْعِي يُويُورْ \add ذِينْ\add* ؤُ يَارَّا إِ-ثنْ-د زِي جَاثْ.
\v 41 خبَّارنْ أَيَا إِ سُولِيمَانْ أَقَا شِيمْعِي إِفّغْ زِي ؤُرْشَالِيمْ غَارْ جَاثْ ؤُشَا إِعْقبْ-د \add عَاوذْ\add*.
\v 42 أَجدْجِيذْ إِسّكّْ أَذْ ڒَاغَانْ إِ شِيمْعِي ؤُشَا إِنَّا أَسْ: ”مَا وَارْ شكْ جِّيغْ أَذْ ثجَّادْجذْ غَارْ سِيذِي ؤُعڒْمغْ أَشْ، نِّيغْ: ’ذڭْ وَاسّْ إِ ذِي إِ غَا ثفّْغذْ غَارْ ذَا نِيغْ غَارْ ذِيهَا أَذْ ثسّْنذْ نِيشَانْ، أَذْ ثمّْثذْ نْحْڒَا مَّا‘؟ ؤُ شكْ ثنِّيذْ أَيِي: ’أَوَاڒْ-أَ إِ سْڒِيغْ، أَقَا-ث مْلِيحْ.‘
\v 43 مَايمِّي \add خنِّي\add* وَارْ ثحْضِيذْ شَا ثَاجَادْجِيثْ ن سِيذِي ذ ڒُومُورْ إِ ذ أَشْ ڭِّيغْ؟“
\v 44 إِنَّا ؤُجدْجِيذْ عَاوذْ إِ شِيمْعِي: ”شكْ ثسّْنذْ ذڭْ وُوڒْ نّشْ مَارَّا ثُوعفّْنَا إِ ثڭِّيذْ إِ بَابَا ذَاوُوذْ. \add س ؤُينِّي\add* سِيذِي أَذْ د-يَارّْ ثُوعفّْنَا نّشْ خْ ؤُزدْجِيفْ نّشْ. \x ◘ \xo 2:‏44 \xt 2 صم. 16‏:‏5، 6، 7\x*
\v 45 \add مَاشَا\add* أَذْ إِتّْوَابَاركْ ؤُجدْجِيذْ سُولِيمَانْ ؤُ ڒْعَارْشْ ن ذَاوُوذْ أَذْ إِتّْوَاسّمْثنْ إِ ڒبْذَا زَّاثْ إِ وُوذمْ ن سِيذِي.“
\v 46 \add خَاسْ\add* ؤُشَا إِضبَّارْ ؤُجدْجِيذْ خْ بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ، ؤُ وَانِيثَا يُويُورْ غَارْ بَارَّا، إِوْثَا شِيمْعِي أَڒَامِي إِمُّوثْ وَانِيثَا. \add أَمُّو\add* إِ ثتّْوَاشدّْ ثْڭلْذِيثْ ذڭْ ؤُفُوسْ ن سُولِيمَانْ. \x ◘ \xo 2:‏46 \xt 2 إِم. 1‏:‏1\x*
\b
\b
\c 3
\s1 أَضْهَارْ أَمزْوَارُو ن سِيذِي إِ سُولِيمَانْ ذ ثُوثْرَا نّسْ
\m 
\v 1 سُولِيمَانْ إِذْوڒْ ذ أَضڭّْوَاڒْ ن فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا. نتَّا يِيوِي يدْجِيسْ ن فِيرْعُونْ ؤُشَا إِسِّيذِيفْ إِ-ت غَارْ ثنْذِينْثْ ن ذَاوُوذْ، أَڒَامِي ثُوغَا إِسّقْفڒْ ڒبْنِي ن ثَادَّارْثْ نّسْ ذ ثَادَّارْثْ ن سِيذِي ذ ڒْحِيضْ إِ ذ أَسْ د-إِنّْضنْ إِ ؤُرْشَالِيمْ. \x ◘ \xo 3:‏1 \xt [2 إِم. 1‏:‏1‏-‏12] — 1 إِج. 7‏:‏8\x*
\v 2 مْغِيرْ ڒْڭنْسْ يَارْنِي إِتّْقدَّامْ ثِيغَارْصَا خْ ڒڭْعُوذِي وَاهَا، مِينْزِي أَڒْ ؤُسَّانْ نِّي وَارْ ثتّْوَابنِّي عَاذْ ثَادَّارْثْ إِ يِيسمْ ن سِيذِي. \x ◘ \xo 3:‏2 \xt أَعَوذ. 12‏:‏5\x*
\v 3 سُولِيمَانْ ثُوغَا إِتّخْسْ سِيذِي ؤُمِي يُويُورْ عْلَاحْسَابْ ثِيوصَّا ن بَابَاسْ ذَاوُوذْ. إِقدّمْ مْغِيرْ ثِيغَارْصَا ذ ڒبْخُورْ خْ ڒڭْعُوذِي وَاهَا.
\m 
\v 4 \add أَمُّو إِ\add* يُويُورْ ؤُجدْجِيذْ \add إِشْثْ ن ثْوَاڒَا\add* غَارْ جِيبْعُونْ، حِيمَا أَذْ ذِينِّي إِغَارْصْ، مَاغَارْ ڒْڭعّْذثْ نِّي ثُوغَا-ت ذ ثَامقّْرَانْثْ قَاعْ. إِسّْڭعّذْ سُولِيمَانْ خْ ؤُعَالْطَارْ نِّي أَڒفْ ثِيغَارْصَا ن وشْمَاضْ. \x ◘ \xo 3:‏4 \xt 2 إِم. 1‏:‏3\x*
\v 5 إِبَانْ-د سِيذِي ذِي جِيبْعُونْ س دْجِيڒثْ إِ سُولِيمَانْ ذڭْ إِشْثْ ن ثرْجِيثْ، ؤُشَا إِنَّا أَربِّي: ”تَّارْ! مِينْ إِ ذ أَشْ غَا وْشغْ؟“ \x ◘ \xo 3:‏5 \xt 1 إِج. 9‏:‏2\x*
\v 6 إِنَّا سُولِيمَانْ:
\b
\m ”شكْ ثسّشْنذْ ثَامخْسِيوْثْ إِشوَّارنْ ثَامقّْرَانْثْ إِ ؤُمْسخَّارْ نّشْ، بَابَا ذَاوُوذْ، أَمْ مَامّشْ يُويُورْ نتَّا زَّاثْ إِ وُوذمْ نّشْ س ڒَامَانْ ذ ثْسڭْذَا ذ ڒصْفَايثْ ن وُوڒْ غَاركْ، ؤُ شكْ ثْخمّْڒذْ أَسْ ثَامخْسِيوْثْ-أَ إِشوَّارنْ ثَامقّْرَانْثْ ؤُ ثوْشِيذْ أَسْ إِجّْ ن مِّيسْ، حِيمَا أَذْ إِقِّيمْ خْ ڒْعَارْشْ نّسْ، أَمْ \add ثدْجَا\add* أَسّْ-أَ. \f ◼ \fr 3:‏6 \ft \bd ’ڒْكُورْسِي نسْ إِڭلّْذنْ‘\bd* - نِيغْ ’لْعَارْشْ‘ نسْ (إِجّْ ن وَاوَاڒْ إِتّْوَاكْسِينْ زِي ثعْرَابْثْ).\f*
\v 7 \add خنِّي\add* ڒخُّو، \add أَ\add* سِيذِي، أَربِّي إِنُو، شكْ ثڭِّيذْ أَمْسخَّارْ نّشْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ ن بَابَا ذَاوُوذْ. \add مَاشَا\add* نشّْ \add دْجِيغْ عَاذْ\add* ذ أَحنْجِيرْ أَمژْيَانْ. نشّْ وَارْ سِّينغْ مَامّشْ غَا فّْغغْ ؤُ مَامّشْ غَاعقْبغْ. \x ◘ \xo 3:‏7 \xt 2 إِم. 2‏:‏7\x*
\v 8 أَمْسخَّارْ نّشْ أَقَا-ث ذِي ڒْوسْطْ ن ڒْڭنْسْ نّشْ نِّي ثِيخْضَارذْ شكْ، إِجّْ ن ڒْڭنْسْ إِمْغَارْ أَڒَامِي وَارْ إِزمَّارْ أَذْ إِتّْوَاقدّْ نِيغْ أَذْ إِتّْوَاحسّبْ زڭْ ؤُبَارُّو \add نّسْ أَمقّْرَانْ\add*. \x ◘ \xo 3:‏8 \xt 2 إِم. 1‏:‏9\x*
\v 9 أوْشْ \add خنِّي\add* إِ ؤُمْسخَّارْ نّشْ إِجّْ ن وُوڒْ إِفْثنْ حِيمَا أَذْ ثَافْ إِزمَّارْ أَذْ إِحْكمْ ذِي ڒْڭنْسْ ؤُ حِيمَا أَذْ إِفَارْزْ س ڒعْقڒْ جَارْ مِينْ إِدْجَانْ إِشْنَا ذ مِينْ إِدْجَانْ ذ أَعفَّانْ، مِينْزِي مَانْ ونْ إِزمَّارنْ أَذْ إِحْكمْ خْ ڒْڭنْسْ-أَ أَمقّْرَانْ نّشْ؟“
\b
\m 
\v 10 أَوَاڒْ-أَ ثُوغَا ذ لمْلِيحْ ذِي ثِيطَّاوِينْ ن سِيذِي، ڒَامِي زعْمَا سُولِيمَانْ إِتَّارْ مَانْ أَيَا. \f ◼ \fr 3:‏10 \ft \bd ’سِيذِي‘\bd* - س ثْعِيبْرَانِيثْ ’سِيذِي إِنُو‘.\f*
\b
\m 
\v 11 إِنَّا أَسْ أَربِّي:
\m ”مِينْزِي شكْ ثتَّارذْ أَيَا ؤُ وَارْ ثتَّارذْ شَا ثُوذَارْثْ ثَازِيرَارْثْ إِ يِيخفْ نّشْ، ؤُ وَارْ ثتَّارذْ أَڭْڒَا إِ يِيخفْ نّشْ ؤُ وَارْ ثتَّارذْ شَا ثُوذَارْثْ ن ڒْعذْيَانْ نّشْ، \add مَاشَا\add* ثتَّارذْ إِ يِيخفْ نّشْ ڒعْقڒْ، حِيمَا أَذْ ثسْڒذْ \add مْلِيحْ\add* دّعْوَاثْ \add ذِي ڒْمحْكَامَا\add*، \x ◘ \xo 3:‏11 \xt 2 إِم. 1‏:‏11\x*
\v 12 أَقَا \add س ؤُيَا\add* نشّْ ڭِّيغْ عْلَاحْصَابْ أَوَاڒنْ نّشْ. خْزَارْ، نشّْ وْشِيغْ أَشْ إِجّْ ن وُوڒْ ذ أَمِيغِيسْ ذ أَفهَّامْ، أَمْ مَامّشْ وَارْ ثُوغِي قْبڒْ إِ شكْ ؤُ وَارْ إِتِّيڒِي أَوَارْنِي أَشْ. \x ◘ \xo 3:‏12 \xt أَمب. 1‏:‏16\x*
\v 13 ؤُڒَا ذ مِينْ وَارْ ثتَّارذْ، أَذْ أَشْ ث وْشغْ، أَمْ وَاڭْڒَا أَمْ ؤُعُودْجِي، أَڒَامِي مَارَّا ؤُسَّانْ \add ن ثُوذَارْثْ\add* نّشْ وَارْ \add ذِينْ\add* إِتِّيڒِي ورْيَازْ أَمْ شكْ جَارْ إِجدْجِيذنْ. \x ◘ \xo 3:‏13 \xt مت. 6‏:‏33؛ أَفا. 3‏:‏20\x*
\v 14 مَاڒَا شكْ ثُويُورذْ خْ ثبْرِيذِينْ إِنُو أَڒَامِي غَا ثحْضِيذْ ثِيوصَّا إِنُو ذ ڒُومُورَاثْ إِنُو، أَمْ مَامّشْ يُويُورْ بَابَاشْ ذَاوُوذْ، \add خنِّي\add* نشّْ أَذْ سّْزُوڭَّارغْ \add ڒْْقدّْ ن\add* وُوسَّانْ \add ن ثُوذَارْثْ\add* نّشْ.“
\b
\m 
\v 15 إِفَاقْ-د سُولِيمَانْ، ؤُ خْزَارْ، \add ثُوغَا-ت ذ\add* إِشْثْ ن ثرْجِيثْ. نتَّا يُوسَا-د غَارْ ؤُرْشَالِيمْ ؤُشَا إِبدّْ زَّاثْ إِ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي ؤُ إِسّْڭعّذْ ثِيغَارْصَا ن وشْمَاضْ ؤُ إِڭَّا ثِيوْهِيبِينْ ن ڒهْنَا ؤُ إِسّوْجذْ \add عَاوذْ\add* إِشْثْ ن زَّارْذثْ إِ مَارَّا إِمْسخَّارنْ نّسْ.
\b
\s1 ڒحْكَامْ أَمِيغِيسْ ن سُولِيمَانْ
\m 
\v 16 خنِّي ؤُسِينْثْ-إِ-د ثْنَاينْ ن ثمْغَارِينْ غَارْ ؤُجدْجِيذْ. ثُوغَا-ثنْثْ ذ ثِيمْغَارِينْ ن فَارْقْ-شّْغڒْ، بدّنْثْ زَّاثْ إِ وُوذمْ نّسْ.
\v 17 إِشْثْ ن ثمْغَارْثْ ثنَّا: ”مَاڒَا ثخْسذْ، \add أَ\add* سِيذِي إِنُو، نشّْ زدّْغغْ أَكْ-ذ ثمْغَارْثْ-أَ ذِي ثَادَّارْثْ ذ إِشْثْ، ؤُ نشّْ ؤُرْوغْ \add ؤُمِي ذ أَيِي ثُوغَا\add* غَارسْ ذِي ثَادَّارْثْ.
\v 18 ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا أَوَارْنِي ڒَامِي د-ؤُرْوغْ، إِمْسَارْ، أَقَا ؤُڒَا ذ ثَامْغَارْثْ-أَ ثُورُووْ-د \add إِجّْ ن ؤُحنْجِيرْ\add*. نشِّينْ ثُوغَا نْمُونْ، وَارْ ثُوغِي غَارْنغْ ؤُڒَا ذ إِجّْ ن ؤُبَارَّانِي ذِي ثَادَّارْثْ، مْغِيرْ نشِّينْ س ثْنَاينْ ذِي ثَادَّارْثْ.
\v 19 أَحنْجِيرْ ن ثمْغَارْثْ-أَ إِمُّوثْ ذِي دْجِيڒثْ ؤُمِي ثزّڒْ خَاسْ ذڭْ إِضصْ.
\v 20 نتَّاثْ ثكَّارْ غَارْ وزْينْ ن دْجِيڒثْ، ثكّسْ أَيِي أَحنْجِيرْ إِنُو، ؤُمِي ثَايَّا نّشْ ثطّصْ، ؤُ ثسَّارْسْ إِ-ث ذڭْ وحْسِينْ نّسْ ؤُشَا مِّيسْ إِمُّوثنْ ثسَّارْسْ إِ-ث ذڭْ وحْسِينْ إِنُو.
\v 21 \add ؤُمِي\add* كَّارغْ غَارْ ثُوفُّوثْ، حِيمَا أَذْ سُّوطُّوضغْ أَحنْجِيرْ إِنُو، خْزَارْ، نتَّا إِمُّوثْ. ذِي صّْبحْ ثُوغَا أَيِي خزَّارغْ مْلِيحْ، ژْرِيغْ ثُوغَا-ث وَارْ إِدْجِي شَا ذ أَحنْجِيرْ إِنُو نِّي د-ؤُرْوغْ.“
\v 22 \add خَاسْ\add* ؤُشَا ثنَّا ثمْغَارْثْ نّغْنِيثْ: ”لَّ، ونِّي إِدَّارنْ ذ أَحنْجِيرْ إِنُو ؤُ ونِّي إِمُّوثنْ ذ أَحنْجِيرْ نّمْ!“ ثنّغْنِيثْ ثنَّا: ”لَّ، ونِّي إِمُّوثنْ ذ أَحنْجِيرْ نّمْ ؤُ ونِّي إِدَّارنْ ذ أَحنْجِيرْ إِنُو!“ أَمُّو إِ سِّيوْڒنْثْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ.
\m 
\v 23 إِنَّا ؤُجدْجِيذْ: ”ثَانِيثَا ثقَّارْ: ’ونِّي إِدَّارنْ ذ أَحنْجِيرْ إِنُو ؤُ ونِّي إِمُّوثنْ ذ أَحنْجِيرْ نّمْ!‘، ؤُشَا ونّغْنِي ثقَّارْ: ’لَّ، ونِّي إِمُّوثنْ ذ أَحنْجِيرْ نّمْ ؤُ ونِّي إِدَّارنْ ذ أَحنْجِيرْ إِنُو.‘ “
\v 24 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ: ”أَوْيمْ أَيِي-د إِجّْ ن سِّيفْ!“ نِيثْنِي إِوْينْ إِجّْ ن سِّيفْ غَارْ ؤُجدْجِيذْ. \f ◼ \fr 3:‏24 \ft \bd ’غَارْ ؤُجدْجِيذْ‘\bd* - س ثْعِيبْرَانِيثْ ’زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ‘.\f*
\v 25 أَجدْجِيذْ إِنَّا: ”قسّمْ أَحنْجِيرْ إِدَّارنْ خْ ثْنَاينْ ؤُشَا وْشمْ إِجّْ ن وزْينْ إِ يِيشْثنْ \add زَّايْسنْثْ\add* ؤُ وْشمْ إِ \add ثنّغْنِيثْ\add* إِجّْ ن وزْينْ \add نّغْنِي\add*.“
\v 26 \add مَاشَا\add* ڒَامِي ثُوغَا ثَاشِيثْ نّسْ إِ ؤُحنْجِيرْ نّسْ إِمْغَارْ، ثسِّيوڒْ ثمْغَارْثْ ثنِّي غَارْ إِدْجَا ؤُحنْجِيرْ إِدَّارْ، أَكْ-ذ ؤُجدْجِيذْ، ثنَّا: ”أَ، سِيذِي إِنُو، وْشثْ أَسْ أَحنْجِيرْ نِّي إِدَّارنْ مَاڒَا ثخْسذْ، وَارْ ث نقّثْ!“ ثَانِيثَا مَاشَا ثنَّا: ”وَارْ إِتِّيڒِي إِنُو ؤُڒَا نّمْ. قسّثْ ث ذِي ڒْوسْطْ!“
\v 27 \add خنِّي\add* يَارَّا-د ؤُجدْجِيذْ، إِنَّا: ”وْشمْ أَسْ أَحنْجِيرْ إِدَّارنْ! وَارْ ث نقّمْ. نتَّاثْ ذ يمَّاسْ.“
\v 28 مَارَّا إِسْرَائِيل إِسْڒَا خْ ڒحْكَامْ إِ زِي إِحْكمْ ؤُجدْجِيذْ ؤُ نِيثْنِي ڭّْوذنْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ، مِينْزِي نِيثْنِي ژْرِينْ بلِّي ثِيغِيثْ ن أَربِّي ذَايسْ حِيمَا أَذْ يَاغْ ثَاسْغَارْثْ.
\b
\b
\c 4
\s1 ڒْحُوكَّامْ إِمقّْرَاننْ ن سُولِيمَانْ ذ ڒْوُولَاثْ نّسْ
\m 
\v 1 ثُوغَا أَجدْجِيذْ سُولِيمَانْ ذ أَجدْجِيذْ خْ مَارَّا إِسْرَائِيل.
\m 
\v 2 إِنَا ثُوغَا ذ ڒْحُوكَّامْ نّسْ إِمقّْرَاننْ:
\m عَازَارْيَا، مِّيسْ ن صَاذُوقْ، \add ثُوغَا-ث ذ\add* أَكهَّانْ.
\m 
\v 3 إِلِيحُورَافْ ذ أَخِييَا، إِحنْجِيرنْ ن شِيشَا، \add ثُوغَا أَثنْ ذ\add* إِمَارِيرنْ.
\m يَاحُوشَافَاطْ، مِّيسْ ن أَخِيلُوذْ، ثُوغَا-ث ذ أَمَارِيرْ أَمزْوَارُو. \f ◼ \fr 4:‏3 \ft \bd ’أَمَارِيرْ - إِمَارِيرنْ‘\bd* - إِنِّي زمَّارنْ خْ ثِيرَا ن ڒشْثُوبْ ذ ؤُمزْرُويْ.\f*
\m 
\v 4 بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ، \add ثُوغَا-ث\add* خْ ڒْعسْكَارْ.
\m صَاذُوقْ ذ أَبْيَاثَارْ \add ثُوغَا أَثنْ ذ\add* إِكهَّاننْ.
\m 
\v 5 عَازَارْيَا، مِّيسْ ن نَاثَانْ، \add ثُوغَا-ث\add* خْ ڒْوُولَاثْ.
\m زابُوذْ، مِّيسْ ن نَاثَانْ، \add ثُوغَا-ث ذ\add* أَوْكِيڒْ ذ أَمدُّوكّڒْ ن ؤُجدْجِيذْ.
\m 
\v 6 أَخِيشَارْ \add ثُوغَا-ث\add* خْ ثْزذِّيغْثْ ن ؤُجدْجِيذْ.
\m أَذُونِيرَامْ، مِّيسْ ن أَبْذَا \add ثُوغَا-ث\add* خْ لْجِيزْيَا. \x ◘ \xo 4:‏6 \xt 1 إِج. 12‏:‏18\x*
\b
\m 
\v 7 سُولِيمَانْ غَارسْ ثنْعَاشْ ن ڒْوُولَاثْ خْ مَارَّا إِسْرَائِيل، إِنِّي إِبدّنْ خْ ڒعْوتْشْ ن ؤُجدْجِيذْ ذ ثَادَّارْثْ نّسْ. خْ \add كُوڒْ\add* إِجّْ س ؤُيُورْ نّسْ ذڭْ ؤُسڭّْوَاسْ، ثُوغَا خَاسْ أَذْ ث إِكْسِي.
\v 8 إِنَا ذ إِسْمَاونْ نْسنْ:
\b
\m مِّيسْ ن حُورْ خْ إِذُورَارْ ن إِفْرَايِيمْ.
\m 
\v 9 مِّيسْ ن ذَاقَارْ ذِي مَاقَاسْ ؤُ ذِي شَاعَالُوبِّيمْ، بَايْثْ-شَامْسْ ذ إِلُونْ-بَايْثْ-حَانَانْ.
\m 
\v 10 مِّيسْ ن حَاسَاذْ ذِي أَرُوبُوثْ. نتَّا \add ثُوغَا\add* غَارسْ سُوكُو ذ مَارَّا ثَامُّورْثْ ن حَافِيرْ.
\m 
\v 11 مِّيسْ ن أَبِينَاذَابْ \add غَارسْ\add* مَارَّا ثِيوْرِيرِينْ ن ذُورْ. ثَافَاثْ، يدْجِيسْ ن سُولِيمَانْ، \add ثُوغَا-ت\add* غَارسْ ذ ثَامْغَارْثْ.
\m 
\v 12 بَاعْنَا، مِّيسْ ن أَخِيلُوذْ، \add غَارسْ\add* ثَاعْنَاكْ، مَاجِيدُّو ذ مَارَّا بَايْثْ-شَانْ إِ إِدْجَانْ غَارْ صُورْثَانْ، سْوَادَّايْ ن يَازْرَاعِيلْ، زِي بَايْثْ-شَانْ أَڒْ أَبَالْ-مَاحُولَا، أَڒْ ؤُغزْذِيسْ نّغْنِي ن يُوقْمَاعَامْ.
\m 
\v 13 مِّيسْ ن جَابَارْ \add ثُوغَا\add* ذِي رَامُوثْ-جِيلْعَاذْ. نتَّا غَارسْ ذْشُورَاثْ ن يَا‘إِرْ، مِّيسْ ن مَانَاسَّا، ثِينِّي \add إِدْجَانْ\add* ذِي جِيلْعَاذْ. \add ثُوغَا\add* غَارسْ ؤُڒَا ذ جِّيهثْ ن أَرْجُوبْ، ثنِّي ذِي بَاشَانْ، ستِّينْ ن ثِيندَّامْ مْغَارنْثْ س ڒْحِيضْ ؤُ س زّكْرُونْ ن نّْحَاسْ.
\m 
\v 14 أَخِينَاذَابْ، مِّيسْ ن عِيدُّو، \add غَارسْ\add* مَاحَانَايِيمْ.
\m 
\v 15 أَخِيمَاعَاصْ \add ثُوغَا-ث ذ لْوَالِي\add* ذِي نَافْثَالِي. نتَّا يِيوِي ؤُڒَا بَاسِيمَاثْ، يدْجِيسْ ن سُولِيمَانْ، ذ ثَامْغَارْثْ \add نّسْ\add*.
\m 
\v 16 بَاعْنَا، مِّيسْ ن هُوشَا إِ، \add ثُوغَا-ث ذ لْوَالِي\add* ذِي أَشِيرْ ؤُ ذِي بَاعَالُوثْ.
\m 
\v 17 يَاهُوشَافَاطْ، مِّيسْ ن فَارُوحْ، \add ثُوغَا-ث ذ لْوَالِي\add* ذِي إِسَّاكَارْ.
\m 
\v 18 شِيمْعِي، مِّيسْ ن إِيْلَا، \add ثُوغَا-ث ذ لْوَالِي\add* ذِي بِينْيَامِينْ.
\m 
\v 19 جَابَارْ، مِّيسْ ن ؤُرِي، \add ثُوغَا-ث ذ لْوَالِي\add* ذِي ثمُّورْثْ ن جِيلْعَاذْ، ثَامُّورْثْ ن سِيحُونْ، أَجدْجِيذْ ن إِمُورِييّنْ، ؤُ ن عُوجْ، أَجدْجِيذْ ن بَاشَانْ. نتَّا \add ثُوغَا\add* ذ أَينِّي ن لْوَالِي ذِي ثمُّورْثْ نِّي.
\b
\m 
\v 20 \add ثُوغَا ڒْڭنْسْ ن\add* يَاهُوذَا ذ إِسْرَائِيل س وَاطَّاسْ أَمْ يِيجْذِي غَارْ \add ثْمَا ن\add* ڒبْحَارْ، أَمُّو أَطَّاسْ. نِيثْنِي شِّينْ، سْوِينْ ؤُ فَارْحنْ.
\b
\b
\c 5
\s1 ڒمْغَارثْ ن سُولِيمَانْ
\m 
\v 1 سُولِيمَانْ إِحْكمْ خْ مَارَّا ثِيڭلْذِيوِينْ زڭْ إِغْزَارْ \add ن لْفُورَاطْ\add* أَڒْ ثَامُّورْثْ ن إِفِيلِيسْطِينِييّنْ ؤُ أَڒْ أَيْمِيرْ ن مِيصْرَا. نِيثْنِي ثُوغَا تَّاوْينْ ثَارْزِيفِينْ ؤُ سخَّارنْ إِ سُولِيمَانْ، مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّسْ.
\v 2 أَسُونِييْ ن سُولِيمَانْ إِ يِيجّْ ن وَاسّْ ثُوغَا-ث ثْڒَاثِينْ إِكُورُوثنْ ن وَارنْ أَزْذَاذْ ؤُ ستِّينْ إِكُورُوثنْ ن وَارنْ،
\v 3 عشْرَا ن إِفُونَاسنْ إِصحّنْ، عِيشْرِينْ ن إِفُونَاسنْ ن هدُّو ذ مْيَا ن وُودْجِي، أَهْثَا إِ ؤُذَاذنْ، إِغَايْضنْ ن وزْغَارْ، وَاشَّاونْ إِمقّْرَاننْ ذ إِوژِّيونْ ن ڒخْڒَا. \f ◼ \fr 5:‏3 \ft \bd ’إِوژِّيونْ ن ڒخْڒَا‘\bd* - إِشْثْ ن مَارْكَا ن إِجْضَاضْ أَمْ ’إِيَاژِيذنْ‘.\f*
\v 4 أَمُّو إِ ثُوغَا إِحكّمْ خْ مَارَّا \add ثَامُّورْثْ\add* خْ ثْمَا-يَا ن إِغْزَارْ \add ن لْفُورَاطْ\add*، زِي ثِيفْسَاخْ أَڒْ غَازَّا، خْ مَارَّا إِجدْجِيذنْ خْ ثْمَا-يَا ن إِغْزَارْ ؤُشَا إِذْوڒْ أَسْ ڒهْنَا غَارْ مَارَّا جّْوَايهْ إِ ذ أَسْ د-إِنّْضنْ.
\v 5 يَاهُوذَا ذ إِسْرَائِيل ثُوغَا زدّْغنْ ذِي ڒَامَانْ، كُوڒْ  إِجّْ سَاذُو ثْزَايَارْثْ نّسْ ؤُ سَاذُو وَارْثُو نّسْ، زِي ذَانْ أَڒْ بِئرْ-سبْعَا، مَارَّا ؤُسَّانْ ن سُولِيمَانْ. \x ◘ \xo 5:‏5 \xt لَاوِي 26‏:‏5؛ مِيخَا 4‏:‏4؛ زَاك. 3‏:‏10\x*
\m 
\v 6 سُولِيمَانْ ثُوغَا غَارسْ أَربْعِينْ-أَڒفْ ن ڒْكُورِيثْ ن ييْسَانْ إِ إِكَارُّوثنْ نّسْ \add ن ؤُمنْغِي\add* ؤُ ثنْعَاشْ-أَڒفْ ن إِمْنَاينْ. \f ◼ \fr 5:‏6 \ft \bd ’أَمْنَايْ - إِمْنَاينْ‘\bd* - أَرْيَازْ ونِّي إِنْيِينْ خْ إِجّْ ن ؤُيِيسْ.\f*  \x ◘ \xo 5:‏6 \xt 1 إِج. 10‏:‏26؛ 2 إِم. 1‏:‏14؛ 9‏:‏25\x*
\v 7 لْوُولَاثْ-أَ، كُوڒْ إِجّْ ذڭْ ؤُيُورْ نّسْ، تّْهِيلَّانْ ذڭْ ؤُجدْجِيذْ سُولِيمَانْ ؤُ ذِي مَارَّا إِنِّي ثُوغَا د-إِتَّاسنْ غَارْ طَّابْڒَا ن ؤُجدْجِيذْ سُولِيمَانْ. نِيثْنِي وَارْ جِّينْ أَذْ إِخصّْ وَالُو.
\v 8 إِمنْذِي ذ ؤُڒُومْ إِ إِيْسَانْ ؤُ إِ إِيْسَانْ ن ثَازْڒَا تَّاوْينْ ثنْ غَارْ ومْشَانْ مَانِي مَا إِدْجَا، كُوڒْ  إِجّْ أَمْ مَامّشْ أَوكّڒْ نّسْ.
\m 
\v 9 سِيذِي إِوْشَا إِ سُولِيمَانْ ثِيغِيثْ ذ ڒعْقڒْ س وَاطَّاسْ ؤُڒَا ذ تَّاسِيعْ \add ن ثُوسّْنَا\add* ذڭْ وُوڒْ أَمْ يِيجْذِي غَارْ ثْمَا نْ ڒبْحَارْ.
\v 10 ثِيغِيثْ ن سُولِيمَانْ ثُوغَا ذ ثَامقّْرَانْثْ خْ ثِيغِيثْ ن مَارَّا ثَارْوَا ن مَانِيسْ إِ د-ثْنقَّارْ ثْفُوشْثْ ؤُ خْ مَارَّا ثِيغِيثْ ن إِمِيصْرِييّنْ.
\v 11 نتَّا ثُوغَا ذ أَمِيغِيسْ خْ مَارَّا إِوْذَانْ، خْ إِثَانْ، أَزْرَاحِي، خْ هَايْمَانْ، كَالْكُولْ ذ ذَارْذَاعْ، إِحنْجِيرنْ ن مَاحُولْ. إِسمْ نّسْ إِذْوڒْ \add إِتّْوَاسّْننْ\add* غَارْ مَارَّا ڒڭْنُوسْ إِ ذ أَسْ د-إِنّْضنْ.
\v 12 نتَّا إِسِّيوڒْ ثڒْثْ-أَڒَافْ ن وَاوَاڒنْ إِوزْننْ. أَڒفْ ؤُ-خمْسَا ن إِزْڒَانْ ثُوغَا أَثنْ زَّايسْ.
\v 13 نتَّا إِسِّيوڒْ \add عَاوذْ\add* خْ ثْشجُّورَا، زِي \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ خْ \add إِذُورَارْ ن\add* لُوبْنَانْ أَڒْ ثْعلْدْجثْ إِ د-إِغمّْينْ زِي ڒْحِيضْ. نتَّا إِسِّيوڒْ \add عَاوذْ\add* خْ ڒْمَاڒْ، خْ إِجْضَاضْ، خْ مَارَّا إِمُودَّارنْ إِنِّي إِتّْبُوعنْ ؤُ خْ إِسڒْمَانْ. \f ◼ \fr 5:‏13 \ft \bd ’ثْعلْدْجثْ‘\bd* - نِيغْ ’هِيسُوبْ‘.\f*
\v 14 زِي مَارَّا ڒڭْنُوسْ ؤُسِينْ-د \add إِوْذَانْ\add*، حِيمَا أَذْ سْڒنْ ثِيغِيثْ ن سُولِيمَانْ، زِي مَارَّا إِجدْجِيذنْ ن ثمُّورْثْ إِنِّي ثُوغَا إِسْڒَانْ خْ ثِيغِيثْ نّسْ.
\b
\s1 أَسوْجذْ ن سُولِيمَانْ إِ ڒبْنِي ن زَّاوشْثْ ثَامقّْرَانْثْ
\m 
\v 15 حِيرَامْ، أَجدْجِيذْ ن صُورْ، إِسّكّْ إِمْسخَّارنْ نّسْ غَارْ سُولِيمَانْ، مَاغَارْ نتَّا ثُوغَا إِسْڒَا، أَقَا ذهْننْ سُولِيمَانْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ ن بَابَاسْ. إِوَا حِيرَامْ ثُوغَا ڒبْذَا إِتّخْسْ ذَاوُوذْ. \x ◘ \xo 5:‏15 \xt [2 إِم. 2‏:‏1‏-‏17] — 2 صم. 5‏:‏11؛ 1 إِم. 14‏:‏1\x*
\v 16 سُولِيمَانْ إِجَّا أَذْ إِنِينْ إِ حِيرَامْ:
\v 17 ”شكْ ثسّْنذْ أَقَا بَابَا ذَاوُوذْ ثُوغَا وَارْ إِزمَّارْ أَذْ إِبْنَا إِشْثْ ن ثَادَّارْثْ إِ يِيسمْ ن سِيذِي، أَربِّي نّسْ، زِي سِّيبّثْ ن إِمنْغَانْ إِ زِي إِ ذ أَسْ د-إِنّْضنْ نِيثْنِي، أَڒَامِي ثنْ إِڭَّا سِيذِي سَاذُو إِضَارنْ نّسْ. \f ◼ \fr 5:‏17 \ft \bd ’سَاذُو إِضَارنْ‘\bd* - س ثْعِيبْرَانِيثْ ’سَاذُو أَضَارْ نّسْ‘.\f*  \x ◘ \xo 5:‏17 \xt 1 إِم. 28‏:‏3\x*
\v 18 \add مَاشَا\add* ڒخُّو إِوْشَا أَيِي سِيذِي، أَربِّي إِنُو، ڒهْنَا زِي مَارَّا إِغزْذِيسنْ. وَارْ \add ذِينْ\add* إِدْجِي \add عَاذْ\add* بُو وغْرِيمْ ؤُ وَارْ \add ذِينْ عَاذْ\add* أَسِيڭّْوذْ ن ثُوعفّْنَا.
\v 19 خْزَارْ، نشّْ نْوِيغْ أَذْ بْنِيغْ إِشْثْ ن ثَادَّارْثْ إِ يِيسمْ ن سِيذِي، أَربِّي إِنُو، أَمْ مَامّشْ إِسِّيوڒْ سِيذِي إِ بَابَا ذَاوُوذْ، إِنَّا: ’مِّيشْ، ونِّي إِ غَا سّْغِيمغْ خْ ڒْعَارْشْ نّشْ، أَذْ إِبْنَا إِشْثْ ن ثَادَّارْثْ إِ يِيسمْ إِنُو.‘ \x ◘ \xo 5:‏19 \xt 2 صم. 7‏:‏13؛ 1 إِم. 22‏:‏10؛ 2 إِم. 1‏:‏18\x*
\v 20 ؤُمُورْ \add خنِّي\add* ڒخُّو، أَقَا أَذْ أَيِي زذْمنْ ثِيشجُّورَا ن ثنْڭلْثْ زڭْ \add إِذُورَارْ\add* ن لُوبْنَانْ. إِمْسخَّارنْ إِنُو أَذْ إِڒِينْ أَكْ-ذ إِمْسخَّارنْ نّشْ ؤُ نشّْ أَذْ أَشْ وْشغْ ڒْمُونثْ إِ إِمْسخَّارنْ نّشْ عْلَاحْسَابْ مَارَّا مِينْ ذ أَيِي غَا ثِينِيذْ، مِينْزِي شكْ ثسّْنذْ أَقَا نشِّينْ وَارْ غَارْنغْ ؤُڒَا ذ إِجّْ ونِّي إِزمَّارنْ أَذْ إِزْذمْ أَكشُّوضْ أَمْ \add أَيْثْ ن\add* صِيذُونْ.“
\m 
\v 21 ؤُمِي إِسْڒَا حِيرَامْ أَوَاڒنْ ن سُولِيمَانْ، إِمْسَارْ، أَقَا إِفَارْحْ أَطَّاسْ س وَاطَّاسْ، إِنَّا: ”أَذْ إِتّْوَابَاركْ سِيذِي أَسّْ-أَ، مَاغَارْ نتَّا إِوْشَا إِ ذَاوُوذْ إِجّْ ن مِّيسْ ذ أَمِيغِيسْ خْ ڒْڭنْسْ-أَ ذ أَمقّْرَانْ!“
\v 22 حِيرَامْ إِسّكّْ \add إِجّْ ن ؤُرقَّاسْ\add* غَارْ سُولِيمَانْ، إِنَّا: ”نشّْ سْڒِيغْ إِ ؤُمِي إِ ثسّكّذْ \add إِجّْ ن ؤُرقَّاسْ\add* غَارِي. نشّْ أَذْ سّْقفْڒغْ مَارَّا مژْرِي نّشْ زِي جِّيهثْ ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ ذ ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُمرْزِي. \f ◼ \fr 5:‏22 \ft \bd ’أَمرْزِي‘\bd* - نِيغْ ’أَمضْزِي‘.\f*
\v 23 إِمْسخَّارنْ إِنُو أَذْ ث-إِ-د-أَوْينْ زڭْ \add إِذُورَارْ ن\add* لُوبْنَانْ غَارْ ڒبْحَارْ ؤُ نشّْ أَذْ ث سِّيوْضغْ خْ ثْغَارُّوبَا ن ثْحنْيَا خْ ڒبْحَارْ غَارْ ومْشَانْ إِ ذ أَيِي غَا ثِينِيذْ. ذِينِّي أَذْ ث سَّارْخُوغْ ؤُ شكْ أَذْ ث ثكْسِيذْ، ؤُ شكْ أَذْ ثسّْقفْڒذْ مَارَّا مژْرِي إِنُو، مَاحنْذْ أَذْ ثوْشذْ مَاشَّا إِ ثَادَّارْثْ إِنُو.“
\m 
\v 24 ؤُشَا حِيرَامْ إِوْشَا أَكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ ذ ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُمرْزِي إِ سُولِيمَانْ، مَارَّا أَنشْثْ مژْرِي نّسْ.
\v 25 إِوْشَا سُولِيمَانْ عِيشْرِينْ-أَڒفْ إِكُورُوثنْ ن إِرْذنْ إِ حِيرَامْ ذ مَاشَّا إِ ثَادَّارْثْ نّسْ ؤُ عِيشْرِينْ إِكُورُوثنْ ن زّشْثْ \add ن زِّيثُونْ\add* ثَاحُورّشْثْ. ذ مَانْ أَيَا إِ إِوْشَا سُولِيمَانْ أَسڭّْوَاسْ خْ ؤُسڭّْوَاسْ إِ حِيرَامْ.
\v 26 سِيذِي إِوْشَا إِ سُولِيمَانْ ثِيغِيثْ أَمْ مَامّشْ ثُوغَا إِ ذ أَسْ إِنَّا نتَّا. ثُوغَا \add ذِينْ\add* ڒهْنَا جَارْ حِيرَامْ ذ سُولِيمَانْ، ؤُشَا نِيثْنِي س ثْنَاينْ إِذْسنْ ڭِّينْ إِجّْ ن ڒْعَاهْذْ. \x ◘ \xo 5:‏26 \xt 1 إِج. 3‏:‏12\x*
\m 
\v 27 أَجدْجِيذْ سُولِيمَانْ إِسّْڭعّذْ-د زِي مَارَّا إِسْرَائِيل \add إِرْيَازنْ\add* إِ ثْسخَّارْثْ إِ إِتّْخصَّانْ. أَسْڭعّذْ-أَ يِيوِي-د ثْڒَاثِينْ-أَڒفْ ن يرْيَازنْ إِ ڒْخذْمثْ.
\v 28 إِسّكّْ إِ-ثنْ غَارْ \add إِذُورَارْ ن لُوبْنَانْ\add*،عشْرَا-أَڒَافْ \add ن يرْيَازنْ\add* ذڭْ ؤُيُورْ، س نُّوبثْ: إِجّْ ن ؤُيُورْ ثُوغَا أَثنْ خْ \add إِذُورَارْ ن\add* لُوبْنَانْ ؤُ ثْنَاينْ ن إِيُورنْ ثُوغَا أَثنْ ذِي ثَادَّارْثْ نْسنْ. أَذُونِيرَامْ \add ثُوغَا\add* خْ يرْيَازنْ إِ إِڭِّينْ ڒْخذْمثْ.
\v 29 ثُوغَا سُولِيمَانْ غَارسْ \add عَاوذْ\add* سبْعِينْ-أَڒفْ ن إِمْسخَّارنْ إِ ثْربُّوثْ ن ڒهْمڒْ ذ ثْمنْيِينْ-أَڒفْ ن إِسُويْذَاينْ خْ إِذُورَارْ.
\v 30 أَهْثَا عَاذْ إِ إِمحْضَاينْ إِمقّْرَاننْ ن سُولِيمَانْ نِّي \add إِدْجَانْ\add* خْ ڒْخذْمثْ، ثُوغَا ذِينْ ثْڒَاثَا ؤُ-ثْڒَاثِينْ-مْيَا \add ن يرْيَازنْ\add* نِّي إِدْجَانْ خْ ڒْڭنْسْ إِ إِڭِّينْ ڒْخذْمثْ.
\v 31 يُومُورْ ؤُجدْجِيذْ مَاحنْذْ أَذْ نقْشنْ ثِيصُوضَارْ ثِيمقّْرَانِينْ، ثِيصُوضَارْ إِغْڒَانْ، حِيمَا أَذْ سَّارْسنْ ذْسَاسْ ن ثَادَّارْثْ \add س\add* ثِيصُوضَارْ-أَ إِتّْوَاسُّويْذَانْ.
\v 32 إِبنَّاينْ ن سُولِيمَانْ ذ إِبنَّاينْ ن حِيرَامْ ؤُڒَا ذ إِجِيبَايْلِييّنْ نقْشنْ ثنْثْ. نِيثْنِي سّْوجْذنْ أَكشُّوضْ ذ يژْرَا، حِيمَا أَذْ بْنَانْ ثَادَّارْثْ.
\b
\b
\c 6
\s1 ڒبْنِي ن زَّاوشْثْ ثَامقّْرَانْثْ
\m 
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعَا-مْيَا ؤُ-ثْمَانْيِينْ أَوَارْنِي إِ ؤُفُّوغْ ن أَيْثْ ن إِسْرَائِيل زِي ثمُّورْثْ ن مِيصْرَا، ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعَا ن ثْڭلْذَا ن سُولِيمَانْ خْ إِسْرَائِيل، ذڭْ ؤُيُورْ ن زِيوْ، أَيُورْ وِيسّْ ثْنَاينْ، إِمْسَارْ، أَقَا نتَّا إِبْذَا أَذْ إِبْنَا ثَادَّارْثْ ن سِيذِي. \x ◘ \xo 6:‏1 \xt [2 إِم. 3‏:‏1‏-‏14] — 1 إِج. 8‏:‏65‏-‏66؛ 2 إِم. 3‏:‏2؛ ڒخ. 7‏:‏47\x*  \fig 1‭ ‬إِج‭. ‬6|src="‬solomontempleinsideview-rifara-01.jpg" size="span" ref="زَّاوشْث‭ ‬ئِي‭ ‬ئِبْنَان‭ ‬ؤُجدْجِيذ‭ ‬سُولِيمَان"\fig*
\b
\m 
\v 2 ثَادَّارْثْ إِ إِبْنَا ؤُجدْجِيذْ سُولِيمَانْ إِ سِيذِي ثُوغَا-ت ستِّينْ ن إِغَادْجنْ ن ثُوزّڭَّارْثْ ؤُ عِيشْرِينْ \add ن إِغَادْجنْ ن\add* ثِيرُو ؤُ ثْڒَاثِينْ ن إِغَادْجنْ ن ڒُوعْڒَا.
\v 3 أَسْقِيفْ ن وَاذَافْ غَارْ زَّاثْ ن \add وخَّامْ ن\add* زَّاوشْثْ ثَامقّْرَانْثْ ن ثَادَّارْثْ، ثُوغَا-ث عِيشْرِينْ ن إِغَادْجنْ ن ثزُّوڭَّارْثْ غَارْ وُوذمْ ن ثِيرُو ن ثَادَّارْثْ، ؤُ ثِيرُو نّسْ ثُوغَا-ثعشْرَا ن إِغَادْجنْ غَارْ وُوذمْ ن ثَادَّارْثْ. \x ◘ \xo 6:‏3 \xt يُوح. 10‏:‏23؛ ڒخ. 3‏:‏11؛ 5‏:‏12\x*
\v 4 نتَّا إِڭَّا إِ ثَادَّارْثْ ثِيبُورْجَاثِينْ، بلّْعنْ ثنْثْ س ثوُّورَا أَكْ-ذ إِعُومَاذْ إِ ؤُبلّعْ.
\v 5 غَارْ ڒْحِيضْ، غَارْ مَارَّا إِغزْذِيسنْ نّسْ ن ثَادَّارْثْ، إِبْنَا إِجّْ ن ڒبْنِي ن زِّييَاذَا، غَارْ ڒحْيُوضْ إِ ذ أَسْ د-إِنّْضنْ إِ ثَادَّارْثْ، \add ڒحْيُوضْ\add* ن \add وخَّامْ ن\add* زَّاوشْثْ ثَامقّْرَانْثْ ؤُ ن \add وخَّامْ ن\add* ذَاخڒْ \add ن زَّاوشْثْ\add*. إِڭَّا ڒبْنِييَّاثْ ن ڒضْرُوفْ \add أَمْ وَافْرِيونْ\add* غَارْ إِغزْذِيسنْ \add ن ثَادَّارْثْ\add* ذڭْ ونّضْ.
\v 6 ثِيسفْڒِي ن وَادَّايْ \add ثُوغَا-ت\add* ذِي خمْسَا ن إِغَادْجنْ ن ثِيرُو ؤُ ثنِّي ذِي ڒْوسْطْ \add ثُوغَا-ت ذِي\add* ستَّا ن إِغَادْجنْ ؤُ ثنِّي وِيسّْ ثْڒَاثَا \add ثُوغَا-ت ذِي\add* سبْعَا ن إِغَادْجنْ، مَاغَارْ إِڭَّا ثِينبْذَاثِينْ غَارْ بَارَّا ن ثَادَّارْثْ غَارْ إِغزْذِيسنْ نّسْ، حِيمَا \add ثِيسفْڒِينْ\add* وَارْ تِّيذْفنْثْ شَا ذِي ڒحْيُوضْ ن ثَادَّارْثْ.
\v 7 \add ؤُمِي\add* ثتّْوَابْنَا ثَادَّارْثْ، \add أَقَا\add* ثتّْوَابْنَا س ثْصُوضَارْ إِتّْوَاقسّنْ زِي مَانِي ثنْثْ نقْشنْ، أَڒَامِي وَارْ تّْوِيسْڒنْ إِفْضِيسنْ، نِيغْ شَّاقُورْ نِيغْ شَا زِي ڒقْشُوعْ ن وُوزَّاڒْ ذِي ثَادَّارْثْ ڒَامِي ثتّْوَابْنَا.
\v 8 ثَاوَّارْثْ إِ ڒبْنِي ن ڒضْرُوفْ غَارْ ؤُمرْوَاسُو \add ثُوغَا-ت\add* غَارْ ؤُغزْذِيسْ أَفُوسِي أَڒْ زَّاثْ ن ثَادَّارْثْ. خْ دّْرُوجَاثْ ينّْضنْ تّْڭعَّاذنْ غَارْ ونِّي ذڭْ ؤُمرْوَاسُو ؤُ زڭْ ؤُمرْوَاسُو غَارْ ونِّي وِيسّْ ثْڒَاثَا.
\v 9 \add أَمُّو\add* إِ إِبْنَا ثَادَّارْثْ، إِكمّڒْ إِ-ت. إِسّْذُورِييْ ثَادَّارْثْ س ثْحنْيَا ؤُ س ثڒْوِيحِينْ ن \add ؤُكشُّوضْ ن\add* ثْنڭْلِينْ.
\v 10 إِبْنَا \add عَاوذْ\add* ڒبْنِي ن زِّييَاذَا غَارْ مَارَّا ثَادَّارْثْ، خمْسَا ن إِغَادْجنْ ن ڒُوعْڒَا \add إِ كُوڒْ طّبْقثْ\add* وَانِيثَا يَارْسَا س \add ثْحنْيَا ن\add* ؤُكشُّوضْ نْ \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ خْ ثَادَّارْثْ.
\m 
\v 11 \add خنِّي\add* يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ سُولِيمَانْ، إِنَّا:
\v 12 ”خْ ثَادَّارْثْ-أَ إِ ثْبنِّيذْ: مَاڒَا شكْ ثُويُورذْ عْلَاحْصَابْ ثِيوصَّا إِنُو ؤُ أَذْ ثڭّذْ لْفَارَايِيضْ  إِنُو ؤُ أَذْ ثحْضِيذْ ڒُومُورَاثْ إِنُو ؤُمِي ذَايْسنْثْ ثُويُورذْ، خنِّي نشّْ أَذْ أَشْ سّْقفْڒغْ أَوَاڒْ إِ سِّيوْڒغْ غَارْ بَابَاشْ ذَاوُوذْ. \x ◘ \xo 6:‏12 \xt 2 صم. 7‏:‏13؛ 1 إِج. 2‏:‏4؛ 9‏:‏4؛ 1 إِم. 22‏:‏10، 19\x*
\v 13 نشّْ أَذْ زذْغغْ ذِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل ؤُ نشّْ وَارْ سمّْحغْ شَا ذِي ڒْڭنْسْ إِنُو إِسْرَائِيل.“
\m 
\v 14 سُولِيمَانْ إِبْنَا ثَادَّارْثْ ؤُ إِكمّڒْ إِ-ت.
\v 15 نتَّا إِبْنَا \add ؤُڒَا ذ\add* أَذْمَاونْ ن ڒحْيُوضْ ن ثَادَّارْثْ نِّي إِدْجَانْ غَارْ ذَاخڒْ س ثْفڒْوِينْ ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ. زِي ثِيسِي ن ثَادَّارْثْ أَڒْ ڒحْيُوضْ ن ثْزقَّا إِڒحّفْ إِ-ثنْ س ؤُكشُّوضْ ؤُ إِڒحّفْ إِ ثِيسِي ن ثَادَّارْثْ س ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُمرْزِي. \f ◼ \fr 6:‏15 \ft \bd ’أَمرْزِي‘\bd* - نِيغْ ’أَمضْزِي‘.\f*
\v 16 ثُوغَا إِبْنَا \add عَاذْ\add* عِيشْرِينْ ن إِغَادْجنْ \add كْثَارْ\add* زڭْ إِغزْذِيسنْ نْ ضفَّارْ ن ثَادَّارْثْ س ثْفڒْوِينْ ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ، زِي ثِيسِي أَڒْ \add ثَازقَّا ن\add* ڒحْيُوضْ، ؤُشَا إِڭَّا \add تَّاسِيعْ\add* ذِي ذَاخڒْ نّسْ ذ \add أَخَّامْ ن\add* ذَاخڒْ \add ن زَّاوشْثْ\add* إِ نتَّا، ذ أَقْذَاسْ خْ ؤُقدَّاسْ.
\v 17 ثَادَّارْثْ \add ثُوغَا-ت\add* أَربْعِينْ إِغَادْجنْ ن ثُوزّڭَّارْثْ، \add إِخْسْ أَذْ يِينِي\add* \add أَخَّامْ ن\add* زَّاوشْثْ ثَامقّْرَانْثْ نِّي غَارْ زَّاثْ.
\v 18 ثُوغَا أَكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ \add إِ إِدْجَانْ\add* غَارْ ذَاخڒْ ن ثَادَّارْثْ إِتّْوَانقّشْ س ثْعبُّوزِينْ ذ نُّووَّارَاثْ ڭُّورْ أَذْ أَرزْمنْثْ. مَارَّا ثُوغَا أَكشُّوضْ ن ثنْڭلْثْ، وَارْ د-إِتّْبِينْ ؤُڒَا ذ إِجّْ وژْرُو.
\v 19 إِڭَّا \add أَخَّامْ ن\add* ذَاخڒْ \add ن زَّاوشْثْ\add* غَارْ ذَاخڒْ قَاعْ ن ثَادَّارْثْ، حِيمَا أَذْ ذِينْ إِسَّارْسْ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي.
\m 
\v 20 \add أَخَّامْ ن\add* ذَاخڒْ \add ن زَّاوشْثْ\add* \add ثُوغَا-ث\add* عِيشْرِينْ ن إِغَادْجنْ ن ثُوزّڭَّارْثْ غَارْ ؤُغزْذِيسْ ن زَّاثْ ؤُ عِيشْرِينْ ن إِغَادْجنْ ن ثِيرُو ذ عِيشْرِينْ ن إِغَادْجنْ ن ڒُوعْڒَا. إِڒحّفْ إِ-ث س وُورغْ إِزذْڭنْ. إِڒحّفْ \add عَاوذْ\add* أَعَالْطَارْ س ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ.
\v 21 سُولِيمَانْ إِغدْجفْ ذَاخڒْ ن ثَادَّارْثْ س وُورغْ إِزذْڭنْ. غَارْ زَّاثْ ن \add وخَّامْ ن\add* ذَاخڒْ \add ن زَّاوشْثْ\add* إِسّعْذُو سّْنَاسڒْ ن وُورغْ. إِغدْجفْ \add وخَّامْ ن ذَاخڒْ\add* س وُورغْ.
\v 22 إِغدْجفْ مَارَّا ثَادَّارْثْ س وُورغْ، أَڒَامِي ثْكمّڒْ مَارَّا ثَادَّارْثْ. إِغدْجفْ مَارَّا أَعَالْطَارْ نِّي إِدْجَانْ غَارْ \add وخَّامْ ن\add* ذَاخڒْ \add ن زَّاوشْثْ\add* س وُورغْ.
\m 
\v 23 ذڭْ \add وخَّامْ ن\add* ذَاخڒْ \add ن زَّاوشْثْ\add* إِڭَّا ثْنَاينْ ن إِكِيرُوبنْ \add ن ؤُكشُّوضْ\add* ن ؤُزمُّورْ. ثِيذِّي نْسنْ ثُوغَا-ت ذِيعشْرَا ن إِغَادْجنْ. \f ◼ \fr 6:‏23 \ft \bd ’إِكِيرُوبنْ‘\bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*  \x ◘ \xo 6:‏23 \xt ؤُف. 25‏:‏18\x*
\v 24 إِجّْ ن وَافْرِيوْ ن ؤُكِيرُوبْ \add ثُوغَا ذَايسْ\add* خمْسَا ن إِغَادْجنْ ؤُ ذڭْ وَافْرِيوْ نّغْنِي ن ؤُكِيرُوبْ \add ثُوغَا ذَايسْ عَاوذْ\add* خمْسَا ن إِغَادْجنْ. زڭْ إِخفْ ن \add يِيجّْ ن\add* وَافْرِيوْ نّسْ أَڒْ إِخفْ ن وَافْرِيوْ نّسْ \add نّغْنِي\add* \add أَقَا\add*عشْرَا ن إِغَادْجنْ.
\v 25 أَكِيرُوبْ نّغْنِي \add ثُوغَا غَارسْ عَاوذْ ڒعْبَارْ ن\add*عشْرَا ن إِغَادْجنْ. إِكِيرُوبنْ ثُوغَا غَارْسنْ س ثْنَاينْ إِذْسنْ إِجّْ ن ڒعْبَارْ ذ إِجّْ ن وَادُّوذْ.
\v 26 إِجّْ ن ؤُكِيرُوبْ ثُوغَا ڒُوعْڒَا نّسْعشْرَا ن إِغَادْجنْ ؤُ أَمُّو ؤُڒَا ذ \add ڒُوعْڒَا ن\add* ؤُكِيرُوبْ نّغْنِي.
\v 27 نتَّا إِسّْبدّْ إِكِيرُوبنْ ذِي ڒْوسْطْ ن ثَادَّارْثْ ن ذَاخڒْ. إِفْرِيونْ ن إِكِيرُوبنْ ثُوغَا بزّْعنْ \add أَڒَامِي\add* أَفْرِيوْ ن إِجّْ إِتَّاكّْوَاضْ إِجّْ ن ڒْحِيضْ ؤُ أَفْرِيوْ ن ؤُكِيرُوبْ نّغْنِي إِتَّاكّْوَاضْ ڒْحِيضْ نّغْنِي. غَارْ ڒْوسْطْ ن ثَادَّارْثْ مّْحَاذَانْ إِفْرِيونْ نْسنْ أَيَاوْيَا، أَفْرِيوْ غَارْ وفْرِيوْ. \x ◘ \xo 6:‏27 \xt ؤُف. 25‏:‏20\x*
\v 28 نتَّا إِغدْجفْ إِكِيرُوبنْ س وُورغْ.
\m 
\v 29 مَارَّا ڒحْيُوضْ ن ثَادَّارْثْ غَارْ مَارَّا إِغزْذِيسنْ نّسْ إِنْقشْ إِ-ثنْ س ؤُقسِّي ن إِنقِّيشنْ ن إِكِيرُوبنْ ذ ثْشجُّورَا ن ثِينِي ذ نُّووَّارَاثْ يَارزْمنْ، زِي ذَاخڒْ ؤُ غَارْ بَارَّا.
\v 30 إِغدْجفْ ثِيسِي ن ثَادَّارْثْ س وُورغْ أَمْ \add ذڭْ وخَّامْ\add* ن ضَاخڒْ أَمْ \add ذڭْ وخَّامْ\add* ن زَّاثْ.
\v 31 غَارْ وَاذَافْ ن \add وخَّامْ ن\add* ذَاخڒْ \add ن زَّاوشْثْ\add* إِڭَّا نتَّا ثِيوُّورَا \add ن ؤُكشُّوضْ\add* ن ؤُزمُّورْ. أَكْوَاذْرُونْ س ڒضْرُوفْ \add غَارْ ؤُغزْذِيسْ ن ثوَّارْثْ\add* \add إِتَّاوِي\add* إِجّْ ن ڒخْمُوسْ \add ن ڒْحِيضْ\add*.
\v 32 ثْنَاينْ ن ثوُّورَا \add ثُوغَا أَثنْثْ\add* زڭْ \add ؤُكشُّوضْ ن\add* ؤُزمُّورْ. نتَّا إِنْقشْ \add ذَايْسنْ\add* إِنقِّيشنْ ن إِكِيرُوبنْ ذ ثْشجُّورَا ن ثِينِي ذ نُّووَّارَاثْ يَارزْمنْ، ؤُشَا إِغدْجفْ \add ثِيوُّورَا\add* س وُورغْ. \add ؤُڒَا ذ\add* إِكِيرُوبنْ ذ ثْشجُّورَا ن ثِينِي إِبزّعْ إِ-ثنْ س وُورغْ.
\v 33 إِڭَّا عَاوذْ ڒضْرُوفْ \add إِ ثْنَاينْ ن إِغزْذِيسنْ\add* ن وَاذَافْ \add ن وخَّامْ\add* ن زَّاوشْثْ ثَامقّْرَانْثْ زڭْ \add ؤُكشُّوضْ ن\add* ؤُزمُّورْ، زڭْ إِشْثْ ن ثرْبَاعْثْ \add ن ڒْحِيضْ\add*.
\v 34 ثْنَاينْ ن ثوُّورَا \add ثُوغَا أَثنْثْ\add* زڭْ ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُمرْزِي. ثْنَاينْ ن ثْغمُّورَا \add غَارْ طَّارْفْ\add* ن إِشْثْ ن ثوَّارْثْ ثُوغَا تّْقُووَّارنْثْ ذِي \add بَارَّا\add* ؤُ ثْنَاينْ ن ثْغمُّورَا تّْوَانقْشنْثْ \add غَارْ طَّارْفْ\add* ن ثنّغْنِيثْ ثُوغَا تّْقُووَّارنْثْ ذِي \add ذَاخڒْ\add*.
\v 35 نتَّا إِنْقشْ \add ذَايْسنْثْ\add* إِكِيرُوبنْ ذ ثْشجُّورَا ن ثِينِي ذ نُّووَّارَاثْ يَارزْمنْ ؤُشَا إِشلّلْ إِ-ثنْثْ س وُورغْ، س إِجّْ ن وُوذمْ ن ثقْشُورْثْ إِڒغّنْ خْ ونْقَاشْ.
\m 
\v 36 نتَّا إِبْنَا ڒمْرَاحْ غَارْ ذَاخڒْ س ثْڒَاثَا ن إِسذِّييّنْ ن ثْصُوضَارْ إِتّْوَاسُّويْذَانْ ؤُ س يِيجّْ ن ؤُسذِّي ن \add ثْحنْيَا ن ثْشجَّارْثْ ن\add* ثنْڭلْثْ.
\m 
\v 37 ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعَا إِتّْوَاسَّارْسْ ذْسَاسْ ن ثَادَّارْثْ ن سِيذِي، ذڭْ ؤُيُورْ زِيوْ.
\v 38 ذڭْ ؤُسڭّْوَاسْ وِيسّْ حِيطَاشْ ن ؤُيُورْ بُولْ، أَقَا-ث ذ أَيُورْ وِيسّْ ثْمنْيَا، ثتّْوَاكمّڒْ ثَادَّارْثْ س مَارَّا ثِيسقَّارْ نّسْ ؤُ عْلَاحْسَابْ مَارَّا لْفَارَايِيضْ نّسْ. نتَّا إِبْنَا إِ-ت \add ذڭْ إِجّْ ن ڒْمِيجَاڒْ ن\add* سبْعَا ن إِسڭّْوُوسَا.
\b
\b
\c 7
\s1 ڒقْصَارْ ن سُولِيمَانْ
\m 
\v 1 ذِي ثَادَّارْثْ نّسْ إِبْنَا سُولِيمَانْ ثْڒطَّاشْ ن إِسڭّْوُوسَا، ؤُشَا إِكمّڒْ مَارَّا ثَادَّارْثْ نّسْ. \x ◘ \xo 7:‏1 \xt 1 إِج. 9‏:‏10\x*
\v 2 نتَّا إِبْنَا ثَادَّارْثْ ن وزْغَارْ ن لُوبْنَانْ. \add ثُوغَا-ت\add* ذِي مْيَا ن إِغَادْجنْ ن ثُوزّڭَّارْثْ ؤُ خمْسِينْ ن إِغَادْجنْ ن ثِيرُو ؤُ ثْڒَاثِينْ ن إِغَادْجنْ ن ڒُوعْڒَا، \add ثتّْوَاڭّْ\add* خْ أَربْعَا ن إِسذِّييّنْ ن إِپِيلَارنْ ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ ؤُ \add تّْوَاسَّارْسنْثْ\add* ثْحنْيَا ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ ثِيوَا إِ إِپِيلَارنْ. \f ◼ \fr 7:‏2 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘. \bd ’ڒُوعْڒَا‘\bd* - نِيغْ ’ثِيذِّي‘.\f*
\v 3 ثُوغَا س إِشْثْ ن ثْزقَّا زڭْ ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ ثِيوَا إِ ثْحنْيَا ن ؤُعَارّضْ نِّي \add إِدْجَانْ\add* خْ خمْسَا ؤُ-ربْعِينْ ن إِپِيلَارنْ \add نِّي\add*، أَقَا خمّسْطَاشْ \add ن ثْحنْيَا\add* خْ إِجّْ ن ؤُسذِّي \add ن إِپِيلَارنْ\add*.
\v 4 ثُوغَا ثِيوُّورَا \add ن ڒكْوَازِي\add* ذِي ثْڒَاثَا ن إِسذِّييّنْ، \add إِشْثْ ن\add* ثْبُورْجثْ أَجمَّاضْ إِ ثْبُورْجثْ \add نّغْنِي\add*، ثْڒَاثَا ن ثْوَاڒَاوِينْ.
\v 5 مَارَّا ثِيوُّورَا ذ ڒضْرُوفْ \add نْسنْثْ غَارْ إِغزْذِيسنْ\add* \add ثُوغَا أَثنْ ذ\add* أَكْوَاذْرُونْ، ؤُشَا أَرْزَامْ \add ن إِشْثْ ن ثوَّارْثْ\add* \add ثُوغَا-ت\add* أَجمَّاضْ ن وَارْزَامْ \add ن إِشْثْ ن ثوَّارْثْ نّغْنِي\add*، ثْڒَاثَا ن ثْوَاڒَاوِينْ.
\v 6 أَسْقِيفْ إِڭَّا إِ-ث س إِپِيلَارنْ \add غَارْ زَّاثْ ن ثَادَّارْثْ\add*، خمْسِينْ ن إِغَادْجنْ ن ثُوزّڭَّارْثْ ؤُ ثْڒَاثِينْ ن إِغَادْجنْ ن ثِيرُو. غَارْ وُوذمْ ن \add إِپِيلَارنْ نِّي\add* ثُوغَا إِشْثْ ن ثسْقِيفْثْ \add نّغْنِي\add* أَكْ-ذ إِپِيلَارنْ، ؤُشَا عَاوذْ ؤُڒَا ذ إِجّْ ن ؤُسقّفْ غَارْ وُوذمْ ن \add إِپِيلَارنْ نِّي\add*.
\v 7 نتَّا إِڭَّا \add عَاوذْ\add* أَخَّامْ إِ ڒْعَارْشْ مَانِي ثُوغَا إِشَارّعْ، أَخَّامْ ن ثَادَّارْثْ ن شّْرَاعْ، ؤُشَا إِسّْذُورِييْ إِ-ث زِي ثِيسِي \add سْوَادَّايْ\add* أَڒْ ثِيسِي \add نّغْنِي سنّجْ\add* س ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ.
\v 8 ثَادَّارْثْ نّسْ، مَانِي ثُوغَا إِزدّغْ، ذِي ڒمْرَاحْ نّغْنِي نِّي إِدْجَانْ \add كْثَارْ\add* غَارْ ذَاخڒْ زڭْ وخَّامْ \add ن ثَادَّارْثْ ن شّْرَاعْ\add*، أَقَا ثتّْوَاڭّْ أَمنِّي. نتَّا إِڭَّا \add عَاوذْ\add* إِشْثْ ن ثَادَّارْثْ إِ يدْجِيسْ ن فِيرْعُونْ، ثنِّي يِيوِي سُولِيمَانْ \add ذ ثَامْغَارْثْ\add*، أَمْ وخَّامْ-أَ وَانِيثَا. \x ◘ \xo 7:‏8 \xt 1 إِج. 3‏:‏1\x*  *
\b
\m 
\v 9 مَانْ أَيَا مَارَّا \add ثُوغَا-ث زِي\add* ثْصُوضَارْ إِغْڒَانْ، تّْوَاسُّويْذَانْثْ عْلَاحْسَابْ ڒقْيَاسْ، زِي ذَاخڒْ ؤُ زِي بَارَّا تّْوَانْشَارنْ س ڒْمنْشَارْ، ؤُ مَانْ أَيَا زِي ذْسَاسْ أَڒْ إِژْرَا ن سنّجْ قَاعْ ؤُ زِي بَارَّا أَڒْ ڒمْرَاحْ أَمقّْرَانْ.
\v 10 ذْسَاسْ إِتّْوَاڭّْ س ثْصُوضَارْ إِغْڒَانْ، إِژْرَا إِمقّْرَاننْ، إِژْرَا نعشْرَا ن إِغَادْجنْ ؤُ إِژْرَا ن ثْمنْيَا ن إِغَادْجنْ،
\v 11 ؤُ ثِيوَا نْسنْ ثِيصُوضَارْ إِغْڒَانْ، تّْوَاسُّويْذَانْثْ عْلَاحْسَابْ ڒقْيَاسْ، ؤُڒَا ذ أَكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ.
\v 12 ڒمْرَاحْ أَمقّْرَانْ إِ ذ أَسْ د-إِنّْضنْ \add ثُوغَا-ث عَاوذْ\add* زِي ثْڒَاثَا ن إِسذِّييّنْ ن ثْصُوضَارْ إِتّْوَاسُّويْذَانْ ذ إِجّْ ن ؤُسذِّي ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ، \add أَمْ مَامّشْ\add* إِ ڒمْرَاحْ ن ذَاخڒْ إِ ثَادَّارْثْ ن سِيذِي أَمْ إِ وسْقِيفْ ن وَاذَافْ ن ثَادَّارْثْ.
\b
\s1 ڒْخذْمثْ ن حِيرَامْ إِ زَّاوشْثْ ثَامقّْرَانْثْ
\m 
\v 13 أَجدْجِيذْ سُولِيمَانْ إِسّكّْ غَارْ حِيرَامْ زِي صُورْ، حِيمَا أَذْ د-يَاسْ. \x ◘ \xo 7:‏13 \xt [2 إِم. 3‏:‏15‏-‏17؛ 2 إِم. 4؛ 2 إِم. 5‏:‏1] — 2 إِم. 2‏:‏12\x*
\v 14 وَانِيثَا ثُوغَا ذ مِّيسْ ن إِشْثْ ن ثَاجَّاتْشْ زِي ثقْبِيتْشْ ن نَافْثَالِي ؤُ بَابَاسْ ثُوغَا-ث ذ إِجّْ ن ورْيَازْ زِي صُورْ، إِجّْ ن ومْزِيڒْ ن نّْحَاسْ. نتَّا ثُوغَا إِشُّورْ س ڒفْهَامثْ ذ ڒعْقڒْ ذ ثُوسّْنَا حِيمَا أَذْ إِسُّوفّغْ قَاعْ ڒْخذْمثْ ن نّْحَاسْ. نتَّا يُوسَا-د غَارْ ؤُجدْجِيذْ سُولِيمَانْ ؤُ مَارَّا مِينْ إِڭَّا، إِڭَّا إِ-ث \add ن نّْحَاسْ\add*. \x ◘ \xo 7:‏14 \xt ؤُف. 31‏:‏3\x*
\m 
\v 15 نتَّا إِڭَّا \bd ثْنَاينْ ن إِپِيلَارنْ ن نّْحَاسْ\bd*. ڒُْوعْڒَا ن إِجّْ ن ؤُپِيلَارْ ثُوغَا-ت ثْمنْطَاشْ ن إِغَادْجنْ ؤُشَا س يِيجّْ ن ؤُفِيڒُو ن ثنْعَاشْ ن إِغَادْجنْ \add إِزمَّارْ\add* أَذْ إِنّضْ إِ ؤُپِيلَارْ نّغْنِي. \x ◘ \xo 7:‏15 \xt 2 إِج. 25‏:‏16، 17؛ إِرْم. 52‏:‏21\x*
\v 16 نتَّا إِڭَّا ثْنَاينْ ن تِّيجَانْ ن نّْحَاسْ إِفسْينْ حِيمَا أَذْ ثنْ سَّارْسنْ خْ إِزدْجِيفنْ ن إِپِيلَارنْ. ڒُوعْڒَا ن إِجّْ ن تَّاجْ ثُوغَا-ث خمْسَا ن إِغَادْجنْ ؤُ ڒُوعْڒَا ن تَّاجْ نّغْنِي ثُوغَا-ث ؤُڒَا ذ خمْسَا ن إِغَادْجنْ.
\v 17 \add ؤُڒَا ذ\add* ثِيجطَّايِينْ تّْوَاڭّنْثْ س إِشْثْ ن ڒْخذْمثْ ن ؤُمُوذِي، \add أَمْ\add* إِفِيڒَانْ ڭِّينْ ثنْثْ س سّْنَاسڒْ إِ تِّيجَانْ \add إِ إِدْجَانْ\add* خْ إِزدْجِيفنْ ن إِپِيلَارنْ. سبْعَا إِ يِيجّْ ن تَّاجْ ؤُ سبْعَا إِ تَّاجْ نّغْنِي.
\v 18 إِڭَّا إِپِيلَارنْ ذ ثْنَاينْ ن إِسذِّييّنْ \add ن إِرمَّامنْ\add* إِ ذ أَسْ د-إِنّْضنْ إِ د-يُوسِينْ أَكْ-ذ ڒْخذْمثْ ن ؤُمُوذِي إِ إِتّْوَاڭّنْ مَاحنْذْ أَذْ \add زَّايسْ\add* إِسّْذُورِييْ تِّيجَانْ \add إِ إِدْجَانْ\add* ثِيوَا إِ \add إِسذِّييّنْ ن\add* إِرمَّامنْ. أَمُّو إِ إِڭَّا ؤُڒَا إِ تَّاجْ نّغْنِي.
\v 19 تِّيجَانْ خْ ؤُزدْجِيفْ ن إِپِيلَارنْ نِّي \add إِدْجَانْ\add* غَارْ وسْقِيفْ ن وَاذَافْ تّْوَاڭّنْ \add أَمْ\add* ثْلِيلِّيشِينْ، \add س إِجّْ ن ڒُوعْڒَا ن\add* أَربْعَا ن إِغَادْجنْ. \f ◼ \fr 7:‏19 \ft \bd ’ثِيلِيلِّيشِينْ‘\bd* - إِشْثْ ن مَارْكَا ن إِنُّووَّارنْ ذَايْسنْ أَژْرِي أَطَّاسْ.\f*
\v 20 تِّيجَانْ \add إِ إِدْجَانْ\add* خْ ثْنَاينْ ن إِپِيلَارنْ \add ذوْڒنْ\add* سنّجْ أَكْ-ذ وُوذمْ ن ؤُقُورَارْ نِّي ثُوغَا إِ-د-إِتَّاسنْ أَكْ-ذ ڒْخذْمثْ إِمُوذنْ. ؤُشَا مِيثَاينْ ن إِرمَّامنْ قُووَّارنْ أَسنْ-د س ثْنَاينْ ن إِسذِّييّنْ، ؤُڒَا خْ تَّاجْ نّغْنِي.
\v 21 \add خنِّي\add* إِسّْبدّْ نتَّا إِپِيلَارنْ غَارْ وسْقِيفْ ن وَاذَافْ ن زَّاوشْثْ ثَامقّْرَانْثْ. إِسّْبدّْ أَپِيلَارْ أَفُوسِي، إِڭَّا أَسْ يَاخِينْ، ؤُشَا إِسّْبدّْ ؤُڒَا ذ أَپِيلَارْ أَزڒْمَاضْ، إِڭَّا أَسْ بُوعَازْ.
\v 22 خْ ؤُزدْجِيفْ ن إِپِيلَارنْ ثُوغَا \add ذِينْ\add* إِشْثْ ن ڒْخذْمثْ \add إِزوّْقنْ\add* ذِي فُورْمَا ن \add إِجّْ ن ڒْكَاسْ أَمْ\add* إِشْثْ ن ثْلِيلّشْثْ. \add أَمُّو\add* ثتّْوَاكمّڒْ ڒْخذْمثْ ن إِپِيلَارنْ.
\m 
\v 23 نتَّا إِڭَّا \bd ثَارِيمَانْثْ إِفسْينْ إِ وَامَانْ\bd*. \add ثُوغَا-ث\add* ڒعْبَارْ نّسْ زِي طَّارْفْ أَڒْ طَّارْفْ نّسْ \add نّغْنِي\add*عشْرَا ن إِغَادْجنْ، ذ أَقُورَارْ قَاعْ، ؤُشَا ثِيذِّي نّسْ \add ثُوغَا-ث\add* ذِي خمْسَا ن إِغَادْجنْ ؤُ ثْزمَّارذْ أَذْ أَسْ ثنّْضذْ س إِشْثْ ن ؤُفِيڒُو ن ڒعْبَارْ ن ثْڒَاثِينْ ن إِغَادْجنْ. \f ◼ \fr 7:‏23 \ft \bd ’ثَارِيمَانْثْ‘\bd* - س ثْعِيبْرَانِيثْ ’ڒبْحَارْ‘ نِيغْ ’إِلْ‘.\f*  \x ◘ \xo 7:‏23 \xt 2 إِم. 4‏:‏2؛ إِرْم. 52‏:‏20\x*
\v 24 سْوَادَّايْ إِ ثْمَا نّسْ إِ ذ أَسْ د-إِنّْضنْ قَاعْ، ثُوغَا \add ذِينْ\add* ثِيعبُّوزِينْ \add أَكْ-ذ نُّووَّارَاثْ يَارزْمنْ\add*.عشْرَا ذِي كُوڒْ إِجّْ ن ؤُغِيڒْ نّْضنْثْ إِ ثْرِيمَانْثْ. ثْنَاينْ ن إِسذِّييّنْ نِّي ن ثْعبُّوزِينْ \add أَكْ-ذ نُّووَّارَاثْ يَارزْمنْ\add* ثُوغَا تّْوَافسْينْ أَكِيذسْ. \x ◘ \xo 7:‏24 \xt 2 إِم. 4‏:‏3\x*
\v 25 ثَارِيمَانْثْ ثْبدّْ خْ ثنْعَاشْ ن إِفُونَاسنْ. ثْڒَاثَا زَّايْسنْ أَرِّينْ س وُوذمْ نْسنْ غَارْ شَّامَالْ، ثْڒَاثَا زَّايْسنْ أَرِّينْ س وُوذمْ نْسنْ غَارْ ڒْغَارْبْ، ثْڒَاثَا زَّايْسنْ أَرِّينْ س وُوذمْ نْسنْ غَارْ لْجَانُوبْ ؤُ ثْڒَاثَا زَّايْسنْ أَرِّينْ س وُوذمْ نْسنْ غَارْ شَّارْقْ. ثَارِيمَانْثْ \add ثَارْسَا\add* خَاسنْ ؤُ مَارَّا زّْعنْقُوقَاثْ نْسنْ ثُوغَا ذوْڒنْثْ خزَّارنْثْ غَارْ ذَاخڒْ.
\v 26 ثڭْذَارْ \add ن ثْرِيمَانْثْ\add* ذ إِجّْ ن ڒعْبَارْ ن ؤُفُوسْ ؤُ ثْمَا نّسْ ثُوغَا أَمْ ڒْخذْمثْ إِزوّْقنْ ن ثْمَا ن إِجّْ ن ؤُفنْجَاڒْ، أَمْ ثْنوَّاشْثْ ن ثْلِيلّشْثْ. ثْوَاوِيثْ نّسْ ثُوغَا أَڒْفَاينْ إِبَاثُوثنْ. \f ◼ \fr 7:‏26 \ft \bd ’أَبَاثُو‘\bd* - إِجّْ ن ’ؤُبَاثُو‘ عْرَاحَاڒْ 20 نِيغْ 40 لِيثْرُو.\f*
\m 
\v 27 نتَّا إِڭَّا \bd عشْرَا ن ثْكَارُّوثِينْ ن نّْحَاسْ\bd*. ثُوغَا ثُوزّڭَّارْثْ ن إِشْثْ ن ثْكَارُّوثْ أَربْعَا ن إِغَادْجنْ ؤُ ثِيرُو نّسْ أَربْعَا ن إِغَادْجنْ ؤُ ڒُوعْڒَا نّسْ ثْڒَاثَا ن إِغَادْجنْ.
\v 28 أَمُّو إِ تّْوَاڭّنْثْ ثْكَارُّوثِينْ. نِيثنْثِي ثُوغَا غَارْسنْثْ ثِيڒْوِيحِينْ عَارّْضنْثْ ؤُ ثڒْوِيحِينْ عَارّْضنْثْ \add ثُوغَا أَثنْثْ\add* جَارْ شَّافُوذْ.
\v 29 خْ ثڒْوِيحِينْ عَارّْضنْثْ جَارْ شَّافُوذْ، \add ثُوغَا ذِينْ\add* \add أَرْشَامنْ ن\add* ويْرَاذنْ، إِفُونَاسنْ ذ إِكِيرُوبنْ. غَارْ سنّجْ خْ شَّافُوذْ ثُوغَا \add ذِينْ\add* إِجّْ ن ؤُسنَّاذْ. سَاذُو ويْرَاذنْ ذ إِفُونَاسنْ تّْوَاڭّنْثْ ثِيسذِّييِينْ ن ثفْرَايْ نِّي يُويْڒنْ غَارْ وَادَّايْ .
\v 30 إِشْثْ ن ثْكَارُّوثْ ثُوغَا غَارسْ أَربْعَا ن ثْجَارَّارِينْ ن نّْحَاسْ ذ ڒحْزَامَاثْ ن نّْحَاسْ. أَربْعَا ن إِضَارنْ ثُوغَا غَارْسنْ ثِيغَارْضِينْ. ثِيغَارْضِينْ إِفسْينْ نِّي \add ثُوغَا أَثنْثْ\add* سَاذُو إِ ثْبَانْيُوثْ إِ ؤُسِيرْذْ، زَّاثْ إِ كُوڒْ ثَاغَارْضْثْ \add ثُوغَا ذِينْ\add* ثِيسذِّييِينْ ن ثفْرَايْ.
\v 31 أَقمُّومْ نّسْ \add ثُوغَا-ث\add* غَارْ ذَاخڒْ ن تَّاجْ ن ثْكَارُّوثْ، إِجّْ ن ؤُغِيڒْ غَارْ سنّجْ. أَقمُّومْ نّسْ ثُوغَا-ث ذ أَقُورَارْ، إِجّْ ن ؤُغِيڒْ ذ وزْينْ، أَمُّو إِ إِتّْوَاڭّْ. خْ ؤُقمُّومْ \add ثُوغَا ذِينْ\add* عَاوذْ ثِينْقَاشِينْ، ؤُ ثِيڒْوِيحِينْ نْسنْ عَارّْضنْثْ ثُوغَا أَثنْثْ س أَربْعَا ن ثْغمُّورَا، وَارْ دْجِينْثْ ذ ثِيقُورَارِينْ.
\v 32 أَربْعَا ن ثْجَارَّارِينْ \add ثُوغَا أَثنْثْ\add* سَاذُو ثڒْوِيحِينْ عَارّْضنْثْ ؤُ ڒحْزَامَاثْ ن ثْجَارَّارِينْ \add ثُوغَا أَثنْثْ شدّْننْثْ\add* غَارْ ثْكَارُّوثْ. ڒُْوعْڒَا ن إِشْثْ ن ثْجَارَّارْثْ \add ثُوغَا-ث\add* إِجّْ ن ؤُغِيڒْ ذ وزْينْ.
\v 33 ثِيجَارَّارِينْ تّْوَاڭّنْثْ أَمْ تّْوَاڭّنْثْ ثْجَارَّارِينْ ن إِجّْ ن ؤُكَارُّو. ڒحْزَامَاثْ نْسنْثْ، يَانْثَاثْ نْسنْثْ، أَرَّاذْيَاوَاثْ نْسنْثْ ذ إِغُوڒَافْ \add ن ڒحْزَامَاثْ\add* نْسنْثْ تّْوَافسْينْثْ مَارَّا.
\v 34 \add ثُوغَا ذِينْ\add* أَربْعَا ن ثْغَارْضِينْ غَارْ أَربْعَا ن ثْغمُّورَا ن إِشْثْ ن ثْكَارُّوثْ. ثِيغَارْضِينْ نّسْ فّْغنْثْ زِي ثْكَارُّوثْ.
\v 35 سنّجْ إِ ثْكَارُّوثْ \add ثُوغَا ذِينْ\add* إِجّْ ن طَّارْفْ ن وزْينْ ن ؤُغِيڒْ إِبدّْ إِقُووَّارْ أَسْ-د زِي مَارَّا إِغزْذِيسنْ نّسْ. سنّجْ إِ ثْكَارُّوثْ \add ثُوغَا ذِينْ\add* عَاوذْ إِفَاسّنْ غَارْ ثڒْوِيحِينْ نّسْ.
\v 36 خْ ثڒْوِيحِينْ أَكْ-ذ إِفَاسّنْ نْسنْثْ ؤُ خْ ثڒْوِيحِينْ ثِيقبَّارِينْ نْسنْثْ إِنْقشْ إِكِيرُوبنْ، إِيْرَاذنْ ذ ثْشجُّورَا ن ثِينِي، خْ كُوڒْ إِجّْ ن ومْشَانْ إِخْڒَا، ؤُڒَا ذ ثِيسذِّييِينْ ن ثفْرَايْ غَارْ مَارَّا إِغزْذِيسنْ.
\v 37 أَمُّو إِ إِڭَّا نتَّاعشْرَا ن ثْكَارُّوثِينْ، مَارَّا س يِيجّْ ن وبْرِيذْ ن ؤُفسْيِي، س يِيجّْ ن ڒقْيَاسْ، س يِيجّْ ن وَادُّوذْ.
\m 
\v 38 إِڭَّا \add عَاوذْ\add* \bd عشْرَا ن ثْبَانْيُوثِينْ ن نّْحَاسْ\bd*. إِشْثْ ن ثْبَانْيُوثْ إِكْسِي أَربْعِينْ إِبَاثُوثنْ. إِشْثْ ن ثْبَانْيُوثْ \add ثُوغَا-ت\add* ذَايسْ أَربْعَا ن إِغَادْجنْ. خْ قَاعْ إِشْثْ زِيعشْرَا ن ثْكَارُّوثِينْ \add نِّي\add* \add ثُوغَا ثكَّارْ أَسْ-د\add* إِشْثْ ن ثْبَانْيُوثْ. \f ◼ \fr 7:‏38 \ft \bd ’أَبَاثُو‘\bd* - إِجّْ ن ’ؤُبَاثُو‘ عْرَاحَاڒْ 20 نِيغْ 40 لِيثْرُو.\f*  \x ◘ \xo 7:‏38 \xt 2 إِم. 4‏:‏6\x*
\v 39 إِڭَّا خمْسَا ن ثْكَارُّوثِينْ غَارْ ؤُغزْذِيسْ ن زَّاثْ أَفُوسِي ن ثَادَّارْثْ ؤُ خمْسَا غَارْ ؤُغزْذِيسْ ن زَّاثْ أَزڒْمَاضْ ن ثَادَّارْثْ، مَاشَا ثَارِيمَانْثْ \add ثَامقّْرَانْثْ\add* إِ وَامَانْ إِڭَّا إِ-ث غَارْ ؤُغزْذِيسْ ن زَّاثْ أَفُوسِي ن ثَادَّارْثْ، غَارْ ؤُغزْذِيسْ ن شَّارْقْ، غَارْ لْجَانُوبْ \add نّسْ\add*.
\v 40 إِڭَّا حِيرَامْ \add عَاوذْ\add* ثِيبَانْيُوثِينْ \add إِ ؤُسِيرْذْ\add*، إِغنْجَاينْ ذ طَّاوْيَاثْ إِ ؤُرُوشِّي. إِكمّڒْ حِيرَامْ مَارَّا ڒْخذْمثْ نِّي إِڭَّا إِ ؤُجدْجِيذْ سُولِيمَانْ \add إِ\add* ثَادَّارْثْ ن سِيذِي:
\m 
\v 41 ثْنَاينْ ن إِپِيلَارنْ ذ ثْنَاينْ ن إِقُورَارنْ ن تِّيجَانْ نِّي \add إِدْجَانْ\add* خْ إِزدْجِيفنْ ن ثْنَاينْ ن إِپِيلَارنْ \add نِّي\add*، ؤُڒَا ذ ثْنَاينْ ن ڒخْذَايمْ ن ؤُمُوذِّي إِ ذ أَسنْثْ-إِ-د-إِنّْضنْ إِ ثْنَاينْ ن إِقُورَارنْ ن تِّيجَانْ إِنِّي \add إِدْجَانْ\add* خْ إِزدْجِيفنْ ن ثْنَاينْ ن إِپِيلَارنْ،
\v 42 أَربْعَا-مْيَا ن إِرمَّامنْ إِ ثْنَاينْ ن ڒخْذَايمْ ن ؤُمُوذِّي \add تّْوَامّْسبْضَانْ\add* خْ ثْنَاينْ ن إِسذِّييّنْ ن إِرمَّامنْ إِ كُوڒْ ڒْخذْمثْ ن ؤُمُوذِّي إِ زِي ذْڒِينْ نِيثْنِي ثْنَاينْ ن إِقُورَارنْ ن تِّيجَانْ إِنِّي خْ وُوذمْ سنّجْ ن إِپِيلَارنْ،
\v 43 ذعشْرَا ن ثْكَارُّوثِينْ ذعشْرَا ن ثْبَانْيُوثِينْ \add نِّي إِدْجَانْ\add* خْ ثْكَارُّوثِينْ \add نِّي\add*،
\v 44 ذ ثَارِيمَانْثْ ذ ثنْعَاشْ ن إِفُونَاسنْ سَاذُو إِ ثْرِيمَانْثْ،
\v 45 ذ ثيْذُورِينْ ذ إِغنْجَاجنْ ذ طَّاوْيَاثْ إِ ؤُرُوشِّي.
\b
\m مَارَّا ڒقْشُوعْ-أَ إِ إِڭَّا حِيرَامْ إِ ؤُجدْجِيذْ سُولِيمَانْ \add إِ\add* ثَادَّارْثْ ن سِيذِي، \add ثُوغَا أَثنْ\add* زِي نّْحَاسْ إِتّْوَاسُّويْذَانْ.
\v 46 أَجدْجِيذْ إِكبّْ إِ-ثنْ ذڭْ ؤُذوَّارْ ن لْ-ؤُرْذُونْ ذِي ثْڒَاخْثْ إِڭْذَارنْ جَارْ سُوكُّوثْ ذ صَارْثَانْ. \x ◘ \xo 7:‏46 \xt ياش. 3‏:‏16\x*
\v 47 سُولِيمَانْ إِسّْعِيزّْ خْ \add ووْزَانْ ن\add* مَارَّا ڒقْشُوعْ-أَ ذِي سِّيبّثْ ن ڒْقدّْ نْسنْ ذ أَمقّْرَانْ أَطَّاسْ. وَارْ بقّْشنْ ذِي ڒوْزنْ ن نّْحَاسْ.
\b
\m 
\v 48 سُولِيمَانْ إِڭَّا مَارَّا ڒقْشُوعْ إِ ثَادَّارْثْ ن سِيذِي:
\m أَعَالْطَارْ ن وُورغْ، ثَازوْضَا ن وُورغْ مِينْ خفْ \add إِتّْوَاسَّارْسْ\add* وغْرُومْ ن وسْشَانْ، \x ◘ \xo 7:‏48 \xt ؤُف. 25‏:‏23؛ 30‏:‏1\x*
\v 49 ڒَا ذ ڒقْنَاذڒْ، خمْسَا غَارْ يفُوسْ ذ خمْسَا غَارْ ؤُزڒْمَاضْ، زَّاثْ إِ \add وخَّامْ ن\add* ذَاخڒْ \add ن زَّاوشْثْ\add* زڭْ وُورغْ إِزذْڭنْ، ڒَا ذ \add نُّووَارَاثْ\add* يَارزْمنْ ذ ڒفْنَارَاثْ ذ ثْجقَّاضِينْ \add ن ثفْثِيتْشْ\add* ن وُورغْ،
\v 50 ؤُڒَا ذ طَّاوْيَاثْ ذ ثْجقَّاضِينْ ذ طَّاوْيَاثْ إِ ؤُرُوشِّي ذ ثْغنْجَايِينْ ذ ثْمجْمَارِينْ ن وُورغْ إِزذْڭنْ. \add خنِّي إِڭَّا عَاوذْ\add* ڒمْفَاسڒْ إِ ثوُّورَا ن ثَادَّارْثْ ن ذَاخڒْ، إِ وقْذَاسْ خْ ؤُقدَّاسْ، ؤُڒَا \add ڒمْفَاسڒْ\add* إِ ثوُّورَا ن \add وخَّامْ ن\add* زَّاوشْثْ ثَامقّْرَانْثْ ن ثَادَّارْثْ زڭْ وُورغْ.
\b
\m 
\v 51 أَمُّو إِ ثتّْوَاكمّڒْ مَارَّا ڒْخذْمثْ إِ إِڭَّا ؤُجدْجِيذْ سُولِيمَانْ إِ ثَادَّارْثْ ن سِيذِي. ؤُشَا سُولِيمَانْ إِسِّيذفْ ثِيوْهِيبِينْ إِقدّْسنْ ن بَابَاسْ. إِسَّارْسْ نُّوقَارْثْ ذ وُورغْ ذ ڒقْشُوعْ ذڭْ إِخَّامنْ ن ثْخُوبَايْ ن ثَادَّارْثْ ن سِيذِي. \f ◼ \fr 7:‏51 \ft \bd ’ثِيوْهِيبِينْ إِقدّْسنْ‘\bd* - س ثْعِيبْرَانِيثْ ’ثِيمسْڒَايِينْ إِقدّْسنْ‘.\f*  \x ◘ \xo 7:‏51 \xt 2 صم. 8‏:‏7، 11؛ 2 إِم. 5‏:‏1\x*
\b
\b
\c 8
\s1 أَذشّنْ ن زَّاوشْثْ ثَامقّْرَانْثْ
\m 
\v 1 خنِّي إِسّْمُونْ سُولِيمَانْ إِمْغَارنْ ن إِسْرَائِيل، مَارَّا إِزدْجِيفنْ ن ثْقبَّاڒْ، ڒْحُوكَّامْ \add ن ثُوذْرِينْ\add* ن ڒجْذُوذْ ن أَيْثْ ن إِسْرَائِيل غَارْ ؤُجدْجِيذْ سُولِيمَانْ ذِي ؤُرْشَالِيمْ، حِيمَا أَذْ سّْڭعّْذنْ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي زِي ثنْذِينْثْ ن ذَاوُوذْ، ثنِّي ذ صِيهْيُونْ. \x ◘ \xo 8:‏1 \xt [2 إِم. 5‏:‏2‏-‏14؛ 2 إِم. 6؛ 2 إِم. 7‏:‏1‏-‏10] — 2 صم. 5‏:‏9؛ 6‏:‏12، 17؛ 2 إِم. 5‏:‏2\x*
\v 2 مَارَّا إِرْيَازنْ ن إِسْرَائِيل مُوننْ-د غَارْ ؤُجدْجِيذْ سُولِيمَانْ غَارْ ڒْعِيذْ ذڭْ ؤُيُورْ ن إِثَانِيمْ، أَقَا-ث ذ أَيُورْ وِيسّْ سبْعَا.
\v 3 مَارَّا إِمْغَارنْ ن إِسْرَائِيل ؤُسِينْ-د ؤُ إِكهَّاننْ سّْڭعّْذنْ تَّابُوثْ.
\v 4 نِيثْنِي سّْڭعّْذنْ تَّابُوثْ ن سِيذِي أَكْ-ذ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُڒَا ذ مَارَّا ڒقْشُوعْ إِقدّْسنْ إِ ثُوغَا إِدْجَانْ ذڭْ ؤُقِيضُونْ. سّْڭعّْذنْ ت إِكهَّاننْ ذ إِلَاوِييّنْ.
\v 5 أَجدْجِيذْ سُولِيمَانْ أَكْ-ذ مَارَّا ثَامسْمُونْثْ ن إِسْرَائِيل إِ ثُوغَا غَارسْ د-ثْمُونْ ؤُ ثُوغَا-ت أَكِيذسْ زَّاثْ إِ تَّابُوثْ، \add مَارَّا نِيثْنِي\add* وهّْبنْ ؤُدْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ، إِنِّي وَارْ زمَّارنْ أَذْ تّْوَاحسْبنْ زِي سِّيبّثْ ن ڒْقدّْ أَمقّْرَانْ نْسنْ.
\m 
\v 6 إِكهَّاننْ إِوْينْ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي غَارْ ومْشَانْ نّسْ، غَارْ \add وخَّامْ ن\add* ذَاخڒْ ن ثَادَّارْثْ، ذڭْ وقْذَاسْ خْ ؤُقدَّاسْ، أَڒْ سَاذُو وَافْرِيونْ ن إِكِيرُوبنْ. \f ◼ \fr 8:‏6 \ft \bd ’إِكِيرُوبنْ‘\bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*
\v 7 مَاغَارْ إِكِيرُوبنْ بزّْعنْ ثْنَاينْ ن وَافْرِيونْ نْسنْ ثِيوَا ن ومْشَانْ ن تَّابُوثْ، ؤُشَا إِكِيرُوبنْ ذْڒِينْ تَّابُوثْ ذ إِعُومَاذْ نّسْ \add إِ ثَاربُّوثْ\add* زِي سنّجْ.
\v 8 إِعُومَاذْ نّسْ \add ن ثَاربُّوثْ\add* ثُوغَا فّْغنْ-د أَڒَامِي تّْوَاژَارّنْ إِخْفَاونْ ن إِعُومَاذْ نّسْ زڭْ ؤُقدَّاسْ زَّاثْ إِ وُوذمْ ن \add وخَّامْ ن\add* ذَاخڒْ \add ن زَّاوشْثْ\add*، \add مَاشَا\add* زِي بَارَّا وَارْ زمَّارنْ أَذْ ثنْ ژَترنْ. \add إِعُومَاذْ\add* قِّيمنْ ذِينِّي أَڒْ أَسّْ-أَ.
\v 9 وَارْ إِدْجِي ؤُڒَا ذ شَا ذِي تَّابُوثْ مْغِيرْ ثْنَاينْ ن ثڒْوِيحِينْ إِ ثُوغَا ذَايسْ إِسَّارْسْ مُوسَا غَارْ هُورِيبْ، ڒَامِي إِڭَّا سِيذِي \add ڒْْعَاهْذْ\add* أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُمِي د-فّْغنْ زِي مِيصْرَا. \x ◘ \xo 8:‏9 \xt ؤُف. 34‏:‏27\x*
\m 
\v 10 ڒَامِي د-فّْغنْ إِكهَّاننْ زڭْ ؤُقدَّاسْ \add غَارْ بَارَّا\add*، إِمْسَارْ، أَقَا إِجّْ ن ؤُسيْنُو إِشُّورْ ثَادَّارْثْ ن سِيذِي.
\v 11 وَارْ زمَّارنْ إِكهَّاننْ أَذْ قِّيمنْ بدّنْ حِيمَا أَذْ سخَّارنْ زِي سِّيبّثْ ن ؤُسيْنُو، مِينْزِي أَعُودْجِي ن سِيذِي ثُوغَا إِشُّورْ ثَادَّارْثْ ن سِيذِي. \x ◘ \xo 8:‏11 \xt ؤُف. 40‏:‏34، 35؛ 2 إِم. 7‏:‏2\x*
\v 12 خنِّي إِنَّا سُولِيمَانْ: ”سِيذِي إِنَّا أَقَا نتَّا أَذْ إِزْذغْ ذڭْ إِجّْ ن ؤُسيْنُو إِبُّومْبسْ. \x ◘ \xo 8:‏12 \xt ؤُف. 20‏:‏21؛ لَاوِي 16‏:‏2؛ أَعَوذ. 4‏:‏11؛ 5‏:‏22؛ 2 إِم. 6‏:‏1\x*
\v 13 \add س ثِيذتّْ\add*، نشّْ بْنِيغْ إِشْثْ ن ثَادَّارْثْ، إِشْثْ ن ثْزذِّيغْثْ إِ شكْ، إِجّْ ن ومْشَانْ إِمْثنْ إِ شكْ، حِيمَا أَذْ \add ذِينْ\add* ثْزذْغذْ إِ ڒبْذَا.“
\m 
\v 14 إِنّقْڒبْ ؤُجدْجِيذْ س ؤُغمْبُوبْ نّسْ ؤُشَا إِبَاركْ مَارَّا أَڭْرَاوْ-أَ \add ن ڒْڭنْسْ\add* ن إِسْرَائِيل ؤُ مَارَّا أَڭْرَاوْ ن إِسْرَائِيل ثُوغَا إِبدّْ.
\v 15 نتَّا إِنَّا: ”أَذْ إِتّْوَابَاركْ سِيذِي، أَربِّي ن إِسْرَائِيل، ونِّي إِسِّيوْڒنْ س ؤُقمُّومْ نّسْ إِ بَابَا ذَاوُوذْ ذ \add ونِّي\add* \add ث\add* إِكمّْڒنْ س ؤُفُوسْ نّسْ ؤُمِي إِنَّا:
\v 16 ’زڭْ وَاسّْ إِ ذِي نذْهغْ ڒْڭنْسْ إِنُو إِسْرَائِيل زِي مِيصْرَا، وَارْ إِخْضَارغْ ؤُڒَا ذ إِشْثْ ن ثنْذِينْثْ زِي مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل، حِيمَا أَذْ \add ذِينِّي\add* بْنِيغْ إِشْثْ ن ثَادَّارْثْ، حِيمَا أَذْ \add ذِينْ\add* يِيڒِي إِسمْ إِنُو، \add مَاشَا\add* نشّْ إِخْضَارغْ ذَاوُوذْ، حِيمَا أَذْ يِيڒِي ذ ڒْحَاكمْ خْ ڒْڭنْسْ إِنُو إِسْرَائِيل.‘ \x ◘ \xo 8:‏16 \xt 2 صم. 7‏:‏8؛ 2 إِم. 6‏:‏5\x*
\v 17 ثُوغَا ذڭْ وُوڒْ ن بَابَا ذَاوُوذْ، حِيمَا أَذْ إِبْنَا إِشْثْ ن ثَادَّارْثْ إِ يِيسمْ ن سِيذِي، أَربِّي ن إِسْرَائِيل. \x ◘ \xo 8:‏17 \xt 2 صم. 7‏:‏2؛ 1 إِم. 17‏:‏1؛ 2 إِم. 6‏:‏7\x*
\v 18 إِنَّا سِيذِي إِ بَابَا ذَاوُوذْ: ’ؤُمِي ثڭِّيذْ ذڭْ وُوڒْ نّشْ حِيمَا أَذْ ثبْنِيذْ إِشْثْ ن ثَادَّارْثْ إِ يِيسمْ إِنُو، ذِي مَانْ أَيَا إِ ثڭِّيذْ مْلِيحْ ؤُمِي ت ثُوغَا ذڭْ وُوڒْ نّشْ.
\v 19 مَاشَا وَارْ إِدْجِي شكْ إِ غَا إِبْنَانْ ثَادَّارْثْ نِّي، مَاشَا مِّيشْ إِ د-إِفّْغنْ زِي ثجْعِينَّا نّشْ. ذ نتَّا أَذْ إِبْنَا ثَادَّارْثْ إِ يِيسمْ إِنُو.‘
\v 20 سِيذِي إِسّمْثنْ أَوَاڒْ نّسْ نِّي إِسِّيوڒْ، مَاغَارْ نشّْ ذوْڒغْ بدّغْ ذڭْ ومْشَانْ ن بَابَا ذَاوُوذْ ؤُ قِّيمغْ خْ ڒْعَارْشْ ن إِسْرَائِيل، أَمْ مَامّشْ ثُوغَا إِسِّيوڒْ سِيذِي، ؤُ نشّْ بْنِيغْ ثَادَّارْثْ إِ يِيسمْ ن سِيذِي، أَربِّي ن إِسْرَائِيل.
\v 21 نشّْ ڭِّيغْ ذِينْ إِجّْ ن ومْشَانْ إِ تَّابُوثْ ثنِّي ذِي إِدْجَا ڒْعَاهْذْ ن سِيذِي إِ إِڭَّا نتَّا أَكْ-ذ ڒجْذُوذْ نّغْ ؤُمِي ثنْ د-إِنْذهْ زِي مِيصْرَا.“
\m 
\v 22 سُولِيمَانْ إِبدّْ زَّاثْ إِ ؤُعَالْطَارْ ن سِيذِي أَرنْذَاذْ ن مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* ن إِسْرَائِيل، ؤُشَا نتَّا إِكْسِي إِفَاسّنْ نّسْ غَارْ ؤُجنَّا، \x ◘ \xo 8:‏22 \xt 2 إِم. 6‏:‏12\x*
\v 23 إِنَّا:
\b
\m ”\add أَ\add* سِيذِي، أَربِّي ن إِسْرَائِيل، وَارْ إِدْجِي ؤُڒَا ذ إِجّْ ن أَربِّي أَمْ شكْ ذڭْ ؤُجنَّا سنّجْ ؤُ خْ ثمُّورْثْ سْوَادَّايْ، ونِّي إِحْضَانْ ڒْعَاهْذْ ذ ثْمخْسِيوْثْ إِشوَّاڒنْ إِ إِمْسخَّارنْ نّشْ نِّي إِڭُّورنْ زَّاثْ إِ وُوذمْ نّشْ س مَارَّا ؤُڒْ نْسنْ،
\v 24 ونِّي إِحْضَانْ ذِي طّْوعْ ن ؤُمْسخَّارْ نّشْ، بَابَا ذَاوُوذْ، خْ مِينْ خفْ أَكِيذسْ ثسِّيوْڒذْ، مِينْزِي س ؤُقمُّومْ نّشْ إِ ثسِّيوْڒذْ ؤُ س ؤُفُوسْ نّشْ إِ د-ثَارِّيذْ أَذْ إِتّْوَاكمّڒْ، أَمْ \add ثدْجَا\add* أَسّْ-أَ.
\v 25 \add خنِّي\add* ڒخُّو، سِيذِي، أَربِّي ن إِسْرَائِيل، حْضَاثْ ذِي طّْوعْ ن ؤُمْسخَّارْ نّشْ، بَابَا ذَاوُوذْ، خْ مِينْ كِيذسْ ثسِّيوْڒذْ ؤُمِي ثنِّيذْ: ’وَارْ إِتّْوَاقسّْ زَّايكْ ؤُڒَا ذ إِجّْ ن ورْيَازْ زِي زَّاثْ إِ وُوذمْ إِنُو ونِّي إِقِّيمنْ خْ ڒْعَارْشْ ن إِسْرَائِيل، مِينْ غَا كّنْ إِحنْجِيرنْ نّشْ أَذْ حْضَانْ أَذْ ؤُيُورنْ أَبْرِيذْ نْسنْ زَّاثْ إِ وُوذمْ إِنُو أَمْ مَامّشْ ثُويُورذْ شكْ زَّاثْ إِ وُوذمْ إِنُو!‘ \x ◘ \xo 8:‏25 \xt 2 صم. 7‏:‏12، 16؛ 1 إِج. 2‏:‏4؛ إِزهد. 132‏:‏12\x*
\v 26 \add خنِّي\add* ڒخُّو، \add أَ\add* أَربِّي ن إِسْرَائِيل، أڭّثْ أَذْ ذوْڒنْ ذ ثِيذتّْ أَوَاڒنْ نِّي ثسِّيوْڒذْ أَكْ-ذ ؤُمْسخَّارْ نّشْ، بَابَا ذَاوُوذْ.
\m 
\v 27 مَاغَارْ مَا س ثِيذتّْ أَذْ إِزْذغْ أَربِّي خْ ثمُّورْثْ؟ خْزَارْ، أَجنَّا، \add وَاهْ،\add* أَجنَّا ن إِجنْوَانْ وَارْ إِزمَّارْ أَذْ شكْ إِكْسِي، مشْحَاڒْ س ذْرُوسْ ثَادَّارْثْ-أَ نِّي سّْبدّغْ نشّْ! \x ◘ \xo 8:‏27 \xt 2 إِم. 2‏:‏5؛ إِشا. 66‏:‏1؛ إِرْم. 23‏:‏24؛ ڒخ. 7‏:‏49\x*
\v 28 ميّڒْ غَارْ ثْژَادْجِيثْ ن ؤُمْسخَّارْ نّشْ ؤُ غَارْ ؤُزَاوڭْ نّسْ، \add أَ\add* سِيذِي، أَربِّي إِنُو، حِيمَا أَذْ ثسْڒذْ غَارْ ؤُڒَاغِي ؤُ غَارْ ثْژَادْجِيثْ نِّي إِژُّودْجْ ؤُمْسخَّارْ نّشْ أَسّْ-أَ زَّاثْ إِ وُوذمْ نّشْ.
\v 29 أجّْ ثِيطَّاوِينْ نّشْ أَذْ تّْوَارزْمنْثْ دْجِيڒثْ ذ وَاسّْ ثِيوَا إِ ثَادَّارْثْ-أَ، ثِيوَا إِ ومْشَانْ إِ خْ ثنِّيذْ: ’أَقَا إِسمْ إِنُو أَذْ ذِينْ يِيڒِي إِ ؤُسدْجِي غَارْ ثْژَادْجِيثْ إِ إِژُّودْجْ ؤُمْسخَّارْ نّشْ ذڭْ ومْشَانْ-أَ.‘ \x ◘ \xo 8:‏29 \xt أَعَوذ. 12‏:‏11\x*
\v 30 سڒْ \add خنِّي\add* إِ ؤُزَاوڭْ ن ؤُمْسخَّارْ نّشْ ؤُ ن ڒْڭنْسْ نّشْ إِسْرَائِيل، \add إِ ؤُزَاوڭْ\add* نِّي تَّارنْ نِيثْنِي ذڭْ ومْشَانْ-أَ، ؤُ سڒْ شكْ \add خنِّي\add* ذڭْ ومْشَانْ ن ثْزذِّيغْثْ نّشْ، ذڭْ ؤُجنَّا، \add وَاهْ،\add* سڒْ ؤُشَا غْفَارْ.
\m 
\v 31 مَاڒَا إِخْضَا إِجّْ أَكْ-ذ جَّارْ نّسْ ؤُ ثتّْوَاڭّْ خَاسْ إِشْثْ ن ثْجَادْجِيثْ، حِيمَا أَذْ ت إِجُّودْجْ ؤُ وَانِيثَا يُوسَا-د ؤُشَا إِجُّودْجْ زَّاثْ إِ ؤُعَالْطَارْ نّشْ ذِي ثَادَّارْثْ-أَ،
\v 32 سڒْ شكْ \add خنِّي\add* ذڭْ ؤُجنَّا، كَّارْ، حْكمْ خْ إِمْسخَّارنْ نّشْ، \add حِيمَا\add* أَذْ إِتّْوَاحْكمْ خْ ؤُعفَّانْ أَڒَامِي أَبْرِيذْ نّسْ أَذْ د-إِهْوَا خْ ؤُزدْجِيفْ نّسْ، ؤُ \add حِيمَا\add* أَذْ ثتّْوَاڭّْ ثْسڭْذَا إِ ؤُمْسڭّذْ أَڒَامِي أَذْ أَسْ ثتّْوَاغْ ثسْغَارْثْ عْلَاحْسَابْ ثَاسڭْذَا نّسْ.
\v 33 مَاڒَا إِتّْوَاغْڒبْ ڒْڭنْسْ نّشْ إِسْرَائِيل زَّاثْ إِ وُوذمْ ن ڒعْذُو، مِينْزِي نِيثْنِي خْضَانْ أَكِيذكْ، \add مَاشَا\add* نِيثْنِي أَذْ غَاركْ د-ذوْڒنْ ؤُشَا أَذْ قَاذَانْ إِسمْ نّشْ ؤُ أَذْ ژَتدْجنْ أَذْ كْسِينْ س ڒْمعْرُوفْ إِ شكْ ذِي ثَادَّارْثْ-أَ،
\v 34 سڒْ شكْ \add خنِّي\add* ذڭْ ؤُجنَّا ؤُ غْفَارْ دّْنُوبْ ن ڒْڭنْسْ نّشْ إِسْرَائِيل ؤُ نْذهْ إِ-ثنْ أَذْ د-ذوْڒنْ غَارْ ثمُّورْثْ نِّي ثوْشِيذْ إِ ڒجْذُوذْ نْسنْ.
\m 
\v 35 مَاڒَا إِبلّعْ ؤُجنَّا، خْمِي وَارْ ذِينْ إِتِّيڒِي ونْژَارْ، مِينْزِي نِيثْنِي خْضَانْ أَكِيذكْ ؤُ نِيثْنِي أَذْ ژَّادْجنْ أَمْ نّْقڒْبنْ غَارْ ومْشَانْ-أَ، أَذْ قَاذَانْ إِسمْ نّشْ ؤُ أَذْ د-ذوْڒنْ خْ دّْنُوبْ نْسنْ ؤُمِي شكْ ثنْ ثحْصَارذْ،
\v 36 سڒْ شكْ \add خنِّي\add* ذڭْ ؤُجنَّا ؤُ غْفَارْ أَسنْ دّنْبْ ن إِمْسخَّارنْ نّشْ ؤُ ن ڒْڭنْسْ نّشْ إِسْرَائِيل، مِينْزِي شكْ ثسّڒْمَاذذْ إِ-ثنْ أَبْرِيذْ أَصبْحَانْ نِّي إِتّْخصَّا أَذْ ؤُيُورنْ، ؤُ أوْشْ شكْ \add خنِّي\add* أَنْژَارْ خْ ثمُّورْثْ نِّي ثوْشِيذْ ذ ڒْوَارْثْ إِ ڒْڭنْسْ نّشْ.
\m 
\v 37 مَاڒَا ذِينْ ڒَاژْ ذِي ثمُّورْثْ، \add نِيغْ\add* طَّاعُونْ، \add نِيغْ\add* إِتّْوَاسّشْمضْ \add إِمنْذِي زڭْ ؤُسمِّيضْ\add*، \add نِيغْ\add* جّْرِيحشْثْ ن وفْسُو \add نِيغْ\add* ثَامُوغْرِي \add ثنِّي\add* إِصَارّْضنْ، \add نِيغْ\add* مَاڒَا إِحْصَارْ إِ-ث ڒعْذُو \add غَارْ\add* ثوُّورَا نّسْ، \add نِيغْ\add* ثڒْقفْ إِ-ث مَامّشْ مَا ثڭَّا شَا ن جّْرِيحشْثْ \add نِيغْ\add* شَا ن ڒحْڒَاشْ،
\v 38 \add خنِّي\add* مَانْ مَا إِ غَا إِژُّودْجْ نِيغْ غَا إِتَّارْ إِجّْ ن بْنَاذمْ \add نِيغْ\add* مَارَّا ڒْڭنْسْ نّشْ إِسْرَائِيل، \add أَمْ\add* نِيثْنِي، كُوڒْ إِجّْ \add زَّايْسنْ\add*، سّْننْ جّْرِيحشْثْ ن وُوڒْ نْسنْ، ؤُ نتَّا إِكْسِي \add خنِّي\add* إِفَاسّنْ نّسْ غَارْ ثَادَّارْثْ-أَ،
\v 39 سڒْ شكْ \add غَارسْ\add* زڭْ ؤُجنَّا، أَمْشَانْ إِمْثنْ ن ثْزذِّيغْثْ نّشْ، غْفَارْ، كَّارْ ؤُ أوْشْ كُوڒْ إِجّْ عْلَاحْسَابْ ثِيبْرِيذِينْ نّسْ - أَمْ مَامّشْ ثسّْنذْ شكْ ؤُڒْ نّسْ، مَاغَارْ شكْ وَاهَا إِ إِسّْننْ ؤُڒْ ن كُوڒْ بْنَاذمْ -
\v 40 حِيمَا نِيثْنِي أَذْ شكْ ڭّْوذنْ مَارَّا ؤُسَّانْ إِ غَا كّنْ دَّارنْ خْ وُوذمْ ن ثمُّورْثْ نِّي ثوْشِيذْ إِ ڒجْذُوذْ نّغْ،
\v 41 \add ؤُشَا سڒْ شكْ\add* ؤُڒَا غَارْ ؤُبَارَّانِي نِّي وَارْ \add إِدْجَانْ\add* زِي ڒْڭنْسْ نّشْ إِسْرَائِيل، \add مَاشَا\add* أَذْ د-يَاسْ ذِي طّْوعْ ن يِيسمْ نّشْ زڭْ إِشْثْ ن ثمُّورْثْ إِڭّْوجنْ.
\v 42 مَاغَارْ نِيثْنِي أَذْ سْڒنْ خْ يِيسمْ نّشْ أَمقّْرَانْ، خْ ؤُفُوسْ نّشْ إِجهْذنْ ؤُ خْ ؤُغِيڒْ نّشْ إِسّْوِيژّْضنْ! مَاڒَا نتَّا د-يُوسَا ؤُ أَذْ إِژَّادْجْ ذِي ثَادَّارْثْ-أَ،
\v 43 سڒْ شكْ \add خنِّي\add* زڭْ ؤُجنَّا، أَمْشَانْ إِمْثنْ ن ثْزذِّيغْثْ نّشْ، ؤُ أڭّْ عْلَاحْسَابْ مَارَّا مِينْ خفْ ذ غَاركْ غَا إِڒَاغَا ؤُبَارَّانِي، حِيمَا مَارَّا ڒڭْنُوسْ ن دُّونشْثْ أَذْ سّْننْ إِسمْ نّشْ، حِيمَا نِيثْنِي أَذْ شكْ ڭّْوذنْ، أَمْ ڒْڭنْسْ نّشْ إِسْرَائِيل، ؤُ أَذْ ؤُشِينْ، أَقَا إِسمْ نّشْ إِتّْوَابَارّحْ ثِيوَا إِ ثَادَّارْثْ-أَ إِ بْنِيغْ.
\m 
\v 44 مَاڒَا ڒْڭنْسْ إِفّغْ غَارْ ؤُمنْغِي أَكْ-ذ ڒعْذُو نّسْ ذڭْ وبْرِيذْ مِينْ خفْ ثنْ ثسّكّذْ ؤُ نِيثْنِي أَذْ ژَّادْجنْ إِ سِيذِي \add أَمْ\add* نّْقڒْبنْ غَارْ ثنْذِينْثْ-أَ إِ ثِيخْضَارذْ شكْ ؤُ غَارْ ثَادَّارْثْ إِ بْنِيغْ نشّْ إِ يِيسمْ نّشْ،
\v 45 سڒْ شكْ \add خنِّي\add* ذڭْ ؤُجنَّا إِ ثْژَادْجِيثْ نْسنْ ؤُ إِ ؤُزَاوڭْ نْسنْ ؤُشَا ثَاغذْ أَسنْ ثَاسْغَارْثْ.
\m 
\v 46 مَاڒَا نِيثْنِي خْضَانْ أَكِيذكْ - مَاغَارْ وَارْ إِدْجِي ؤُڒَا ذ إِجّْ بْنَاذمْ إِ وَارْ إِخْضَانْ - ؤُ شكْ ثسْعَارذْ خَاسنْ، أَذْ ثنْ ثْسلّْمذْ زَّاثْ إِ وُوذمْ ن ڒعْذُو ؤُشَا نِيثْنِي أَذْ ثنْ نذْهنْ ذ إِمحْبَاسْ غَارْ ثمُّورْثْ ن ڒعْذُو، مَا ثڭّْوجْ نِيغْ ثُوذسْ \add إِ ثدْجَا\add*، \x ◘ \xo 8:‏46 \xt 2 إِم. 6‏:‏36؛ أَوڒن. 20‏:‏9؛ أَمب. 7‏:‏20؛ 1 يُوح. 1‏:‏8، 10\x*
\v 47 ؤُ نِيثْنِي أَذْ ثُوبنْ ذڭْ وُوڒْ نْسنْ ذِي ثمُّورْثْ مَانِي تّْوَاحبّْسنْ، \add وَاهْ\add*، أَذْ ثُوبنْ ؤُ أَذْ خَاكْ د-ڒَْاغَانْ ذِي ثمُّورْثْ ن يِينِّي ثنْ إِحبّْسنْ، أَذْ إِنِينْ: ’نشِّينْ نخْضَا ؤُ نڭَّا مِينْ وَارْ إِسڭّْذنْ، أَقَا نڭَّا ثُوعفّْنَا!‘،
\v 48 ؤُ نِيثْنِي أَذْ غَاركْ د-ذوْڒنْ س مَارَّا ؤُڒْ نْسنْ ؤُ س مَارَّا ڒعْمَارْ نْسنْ ذِي ثمُّورْثْ ن ڒْعذْيَانْ نْسنْ إِنِّي ثنْ إِحبّْسنْ ؤُشَا أَذْ غَاركْ ژَّادْجنْ \add أَمْ\add* نّْقڒْبنْ غَارْ ثمُّورْثْ نِّي ثوْشِيذْ إِ ڒجْذُوذْ نْسنْ، غَارْ ثنْذِينْثْ-أَ إِ ثِيخْضَارذْ شكْ ؤُ غَارْ ثَادَّارْثْ-أَ إِ بْنِيغْ نشّْ إِ يِيسمْ نّشْ،
\v 49 سڒْ شكْ \add خنِّي\add* ذڭْ ؤُجنَّا، أَمْشَانْ إِمْثنْ ن ثْزذِّيغْثْ نّشْ، إِ ثْژَادْجِيثْ نْسنْ ؤُ إِ ؤُزَاوڭْ نْسنْ ؤُشَا أَغْ أَسنْ ثَاسْغَارْثْ.
\v 50 غْفَارْ إِ ڒْڭنْسْ نّشْ مِينْ زِي خْضَانْ أَكِيذكْ ؤُ \add غْفَارْ أَسنْ\add* مَارَّا إِخطَّانْ نْسنْ إِ كِيذكْ إِخْضَانْ، ؤُ أوْشْ أَسنْ أَرّحْمثْ زَّاثْ إِ وُوذمْ ن يِينِّي إِ ثنْ إِحبّْسنْ، حِيمَا نِيثْنِي أَذْ خَاسنْ أَرحْمنْ.
\v 51 نِيثْنِي مَاغَارْ ذ ڒْڭنْسْ نّشْ ذ ثَاسْغَارْثْ نّشْ نِّي د-ثسُّوفّْغذْ زِي مِيصْرَا، زِي ڒْوسْطْ ن ؤُفرَّانْ ن وُوزَّاڒْ.
\m 
\v 52 أجّْ ثِيطَّاوِينْ نّشْ أَذْ تّْوَارْزْمنْثْ إِ ؤُحشّمْ ن ؤُمْسخَّارْ نّشْ ؤُ إِ ؤُحشّمْ ن ڒْڭنْسْ نّشْ إِسْرَائِيل، مَاحنْذْ أَذْ غَارْسنْ ثسْڒذْ أَكْ-ذ مَارَّا مِينْ غَاركْ إِ غَا ڒَاغَانْ،
\v 53 مَاغَارْ شكْ ثْفَارْزذْ إِ-ثنْ إِ يِيخفْ نّشْ ذ ڒْوَارْثْ زِي مَارَّا ڒڭْنُوسْ ن ثمُّورْثْ، أَمْ مَامّشْ ثسِّيوْڒذْ شكْ س ثْسخَّارْثْ ن مُوسَا، ؤُمْسخَّارْ نّشْ، ؤُمِي ثسُّوفّْغذْ ڒجْذُوذْ نّغْ زِي مِيصْرَا، \add أَ\add* سِيذِي إِنُو، سِيذِي!“ \x ◘ \xo 8:‏53 \xt ؤُف. 19‏:‏5؛ أَعَوذ. 4‏:‏20؛ 7‏:‏6؛ 9‏:‏26، 29؛ 14‏:‏2\x*
\b
\m 
\v 54 ڒَامِي ثُوغَا سُولِيمَانْ إِكمّڒْ مَارَّا ثْژَادْجِيثْ-أَ ؤُ \add مَارَّا\add* أَحشّمْ-أَ غَارْ سِيذِي، إِمْسَارْ، أَقَا نتَّا إِكَّارْ زِي زَّاثْ ن ؤُعَالْطَارْ ن سِيذِي، أَمْ ث ثُوغَا خْ إِفَادّنْ نّسْ س وعْرُورْ إِقْوسْ أَمْ تّْوَاسّْوِيژَّاضنْ إِفَاسّنْ نّسْ غَارْ ؤُجنَّا.
\v 55 نتَّا ثُوغَا إِبدّْ \add ذِينْ\add* ؤُشَا إِبَاركْ مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* ن إِسْرَائِيل، إِنَّا س ثْمِيجَّا إِجهْذنْ:
\b
\m 
\v 56 ”أَذْ إِتّْوَابَاركْ سِيذِي، ونِّي إِسَّاريّْحنْ ڒْڭنْسْ نّسْ إِسْرَائِيل عْلَاحْسَابْ مَارَّا مِينْ ثُوغَا إِقَّارْ! زِي مَارَّا أَوَاڒْ\add أنْ\add* إِصبْحَاننْ إِ زِي إِسِّيوڒْ س ثْسخَّارْثْ ن ؤُمْسخَّارْ نّسْ مُوسَا، وَارْ د-إِوْضِي ؤُڒَا ذ إِجّْ. \x ◘ \xo 8:‏56 \xt ياش. 21‏:‏45\x*
\v 57 أَذْ يِيڒِي سِيذِي، أَربِّي نّغْ، أَكِيذْنغْ أَمْ ثُوغَا إِدْجَا أَكْ-ذ ڒجْذُوذْ نّغْ، مَاحنْذْ نتَّا وَارْ ذ أَنغْ إِتّجِّي ؤُ وَارْ ذ أَنغْ إِنطَّارْ،
\v 58 \add مَاشَا\add* أَذْ إِنْذهْ ؤُڒَاونْ نّغْ غَارسْ، مَاحنْذْ نشِّينْ أَذْ نُويُورْ خْ ثبْرِيذِينْ نّسْ ؤُ أَذْ نحْضَا ڒُومُورَاثْ نّسْ ذ ثْوصَّا نّسْ ذ لْفَارَايِيضْ نّسْ نِّي يُومُورْ إِ ڒجْذُوذْ نّغْ.
\v 59 أجّْ أَوَاڒنْ-أَ إِ سِّيوْڒغْ س ؤُحشّمْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَسّْ ذ دْجِيڒثْ، أَذْ إِڒِينْ ؤُذْسنْ غَارْ سِيذِي، أَربِّي نّغْ، حِيمَا نتَّا أَذْ يَاغْ ثَاسْغَارْثْ إِ ؤُمْسخَّارْ نّسْ ذ ڒْڭنْسْ نّسْ إِسْرَائِيل، كُوڒْ أَسّْ \add س\add* مِينْ \add إِ إِتّْڒِيقنْ\add* إِ وَاسّْ نِّي،
\v 60 مَاحنْذْ مَارَّا ڒڭْنُوسْ ن ثمُّورْثْ أَذْ سّْننْ أَقَا سِيذِي ذ أَربِّي، وَارْ ذِينْ نّغْنِي، \x ◘ \xo 8:‏60 \xt أَعَوذ. 4‏:‏35، 39\x*
\v 61 مَاحنْذْ ؤُڒْ نْومْ أَذْ يِيڒِي إِمُونْ أَكْ-سِيذِي، أَربِّي نّغْ، حِيمَا أَذْ ثُويُورمْ عْلَاحْسَابْ ثِيوصَّا نّسْ، أَذْ ثحْضَامْ ڒُومُورَاثْ نّسْ، أَمْ \add ثدْجَا\add* أَسّْ-أَ.“
\b
\m 
\v 62 إِغَارْصْ ؤُجدْجِيذْ ذ مَارَّا إِسْرَائِيل أَكِيذسْ ثِيغَارْصَا زَّاثْ إِ وُوذمْ ن سِيذِي.
\v 63 سُولِيمَانْ إِغَارْصْ ثِيغَارْصَا ن ڒهْنَا نِّي إِغَارْصْ إِ سِيذِي: ثْنَاينْ ؤُ-عِيشْرِينْ-أَڒَافْ ن إِفُونَاسنْ ذ ثْفُونَاسِينْ ذ مْيَا ؤُ-عِيشْرِينْ-أَڒَافْ ن وُودْجِي ذ ثَاغَارْصْثْ ن ڒهْنَا. أَمُّو إِ إِذشّنْ ؤُجدْجِيذْ ثَادَّارْثْ ن سِيذِي \add جْمِيعْ\add* أَكْ-ذ مَارَّا أَيْثْ ن إِسْرَائِيل. \x ◘ \xo 8:‏63 \xt 2 إِم. 7‏:‏5‏-‏10\x*
\m 
\v 64 ذڭْ وَاسّْ ذ إِجّنْ إِسّْقدّسْ ؤُجدْجِيذْ ڒْوسْطْ ن ڒمْرَاحْ ن زَّاثْ ونِّي \add إِدْجَانْ\add* زَّاثْ إِ ثَادَّارْثْ ن سِيذِي، مِينْزِي إِسّوْجذْ ذِينْ ثَاغَارْصْثْ ن وشْمَاضْ ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ؤُڒَا ذ ثَاذُونْثْ ن ثْغَارْصَا ن ڒهْنَا. مَاغَارْ أَعَالْطَارْ ن نّْحَاسْ ونِّي \add إِدْجَانْ\add* زَّاثْ إِ وُوذمْ ن سِيذِي، ثُوغَا ذ أَمژْيَانْ حِيمَا أَذْ إِكْسِي ثِيغَارْصَا ن وشْمَاضْ ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذ ثَاذُونْثْ ن ثْغَارْصَا ن ڒهْنَا. \x ◘ \xo 8:‏64 \xt 2 إِم. 7‏:‏7\x*
\m 
\v 65 ذِي ڒْوقْثْ نِّي إِڭَّا سُولِيمَانْ ڒْعِيذْ \add عَاوذْ\add* ذ مَارَّا إِسْرَائِيل أَكِيذسْ، زِي مَانِي غَا ثِيوْضذْ غَارْ حَامَاثْ أَڒْ ثَاغْزَارْثْ ن مِيصْرَا: إِجّْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add* أَمقّْرَانْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّغْ، سبْعَا ن وُوسَّانْ ؤُڒَا ذ سبْعَا ن وُوسَّانْ كْثَارْ، أَرْبعْطَاشْ ن وُوسَّانْ. \x ◘ \xo 8:‏65 \xt 1 إِج. 8‏:‏65‏-‏66\x*
\v 66 ذڭْ وَاسّْ وِيسّْ ثْمنْيَا يَارْخُو نتَّا إِ ڒْڭنْسْ، ؤُشَا نِيثْنِي بَارْكنْ أَجدْجِيذْ. \add أَوَارْنِي ؤُيَا\add* ؤُيُورنْ غَارْ إِقِيضَانْ نْسنْ س وُوڒْ إِفَارْحْ ؤُ س ڒْخَاضَارْ خْ مَارَّا ڒْخَارْ إِ ثُوغَا إِڭَّا سِيذِي إِ ؤُمْسخَّارْ نّسْ ذَاوُوذْ ؤُ إِ ڒْڭنْسْ نّسْ إِسْرَائِيل.
\b
\b
\c 9
\s1 أَضْهَارْ وِيسّْ ثْنَاينْ ن سِيذِي إِ سُولِيمَانْ
\m 
\v 1 أَوَارْنِي ڒَامِي إِكمّڒْ سُولِيمَانْ ڒبْنِي ن ثَادَّارْثْ ن سِيذِي ؤُ \add ڒبْنِي ن\add* ثَادَّارْثْ ن ؤُجدْجِيذْ، \add وَاهْ،\add* مَارَّا مِينْ ثُوغَا إِمّژْرِي ؤُ ثُوغَا إِخْسْ أَذْ ث إِڭّْ، \x ◘ \xo 9:‏1 \xt [2 إِم. 7‏:‏11‏-‏22] — 2 إِم. 7‏:‏11\x*
\v 2 إِبَانْ-د سِيذِي إِ سُولِيمَانْ إِ ثْوَاڒَا وِيسّْ ثْنَاينْ، أَمْ مَامّشْ إِ ذ أَسْ د-إِبَانْ ذِي جِيبْعُونْ. \x ◘ \xo 9:‏2 \xt 1 إِج. 3‏:‏5\x*
\v 3 إِنَّا أَسْ سِيذِي: ”نشّْ سْڒِيغْ إِ ثْژَادْجِيثْ نّشْ ؤُ إِ ؤُحشّمْ نّشْ إِ زِي ثْحشّْمذْ زَّاثْ إِ وُوذمْ إِنُو. ثَادَّارْثْ إِ ثبْنِيذْ، سّْقدّْسغْ ت، حِيمَا أَذْ سّْمثْنغْ ذِينْ إِسمْ إِنُو إِ ڒبْذَا ؤُشَا ثِيطَّاوِينْ إِنُو ذ وُوڒْ إِنُو أَذْ ذِينْ إِڒِينْ إِ ڒبْذَا! \x ◘ \xo 9:‏3 \xt أَعَوذ. 12‏:‏11؛ 1 إِج. 8‏:‏29\x*
\v 4 مَاڒَا شكْ ثُويُورذْ زَّاثْ إِ وُوذمْ إِنُو أَمْ مَامّشْ ثُوغَا إِڭُّورْ بَابَاشْ ذَاوُوذْ س وُوڒْ إِمُونْ ؤُ س ڒصْفَايثْ، أَذْ ثڭّذْ أَمْ مَامّشْ مَارَّا إِ ذ أَشْ ؤُمُورغْ ؤُ أَذْ ثحْضِيذْ ثِيوصَّا إِنُو ذ لْفَارَايِيضْ  إِنُو،
\v 5 \add خنِّي\add* أَذْ سّْمثْنغْ ڒْعَارْشْ ن ثْڭلْذَا نّشْ خْ إِسْرَائِيل إِ ڒبْذَا، أَمْ مَامّشْ سِّيوْڒغْ غَارْ بَابَاشْ ذَاوُوذْ، نِّيغْ: ’وَارْ زَّايكْ إِتّْوَاقسِّي شَا ن ورْيَازْ زِي ڒْعَارْشْ ن إِسْرَائِيل!‘ \x ◘ \xo 9:‏5 \xt 2 صم. 7‏:‏12، 16؛ 1 إِج. 6‏:‏12؛ 2‏:‏4؛ 1 إِم. 22‏:‏10؛ إِزهد. 132‏:‏12\x*
\m 
\v 6 مَاشَا مَاڒَا كنِّيوْ، شكْ ذ إِحنْجِيرنْ نْومْ، أَذْ ثْحيّْذمْ زِي ضفَّارْ إِنُو ؤُ كنِّيوْ وَارْ ثْحطَّامْ عَاذْ ڒُومُورَاثْ إِنُو ذ ثْوصَّا إِنُو نِّي وْشِيغْ زَّاثْ إِ وُوذمْ نْومْ، ؤُ كنِّيوْ أَذْ ثُويُورمْ أَذْ ثْسخَّارمْ إِ إِربِّيثنْ نّغْنِي، أَذْ أَسنْ ثْبنْذْقمْ، \x ◘ \xo 9:‏6 \xt 2 صم. 7‏:‏14؛ إِزهد. 89‏:‏30، 31\x*
\v 7 خنِّي أَذْ قْضِيغْ إِسْرَائِيل زِي ثمُّورْثْ نِّي ذ أَسنْ وْشِيغْ ؤُشَا ثَادَّارْثْ-أَ إِ سّْقدّْسغْ إِ يِيسمْ إِنُو أَذْ ت مّنْضَارغْ زڭْ وُوذمْ إِنُو ؤُ إِسْرَائِيل أَذْ إِذْوڒْ ذ إِجّْ ن ؤُمذْيَا ذ \add إِشْثْ ن ڒْقشْعثْ\add* ن ؤُسْثهْزِي جَارْ مَارَّا ڒڭْنُوسْ. \x ◘ \xo 9:‏7 \xt أَعَوذ. 28‏:‏37؛ إِرْم. 7‏:‏15\x*
\v 8 ؤُ خْ ثَادَّارْثْ-أَ ثنِّي يُوعْڒَانْ قَاعْ، مَارَّا وِي خَاسْ إِ غَا إِكّنْ، أَذْ إِثبْهثْ أَذْ إِصفَّارْ. نِيثْنِي أَذْ إِنِينْ: ’مَايمِّي إِڭَّا سِيذِي أَمُّو ذِي ثمُّورْثْ-أَ ؤُ ذِي ثَادَّارْثْ-أَ؟‘ \x ◘ \xo 9:‏8 \xt أَعَوذ. 26‏:‏19؛ 28‏:‏1؛ 29‏:‏23؛ 2 إِم. 7‏:‏21؛ إِرْم. 22‏:‏8\x*
\v 9 أَذْ إِنِينْ: ’مِينْزِي نِيثْنِي سمْحنْ ذِي سِيذِي، أَربِّي نْسنْ، ونِّي د-إِسُّوفّْغنْ ڒجْذُوذْ نْسنْ زِي ثمُّورْثْ ن مِيصْرَا، ؤُ مِينْزِي نِيثْنِي شبَّارنْ ذِي إِربِّيثنْ نّغْنِي، ؤُيُورنْ أَذْ أَسنْ بنْذْقنْ ؤُ أَذْ أَسنْعبْذنْ، خْ ؤُيَا إِسِّيوضْ سِيذِي مَارَّا ڒْغَارْ-أَ خَاسنْ.‘ “
\b
\s1 ڒبْنِييَاثْ ن سُولِيمَانْ
\m 
\v 10 أَوَارْنِي عِيشْرِينْ ن إِسڭّْوُوسَا إِ ذِي إِبْنَا سُولِيمَانْ ثْنَاينْ ن ثُوذْرِينْ، ثَادَّارْثْ ن سِيذِي ؤُ ثَادَّارْثْ ن ؤُجدْجِيذْ، إِمْسَارْ \x ◘ \xo 9:‏10 \xt [2 إِم. 8‏:‏1‏-‏18] — 2 إِم. 8‏:‏1\x*
\v 11 - \add أَمْ\add* إِوْشَا حِيرَامْ، أَجدْجِيذْ ن صُورْ، إِ سُولِيمَانْ عْلَاحْسَابْ مژْرِي نّسْ أَكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ ذ ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُمرْزِي ذ وُورغْ - أَقَا سُولِيمَانْ إِوْشَا إِ حِيرَامْ عِيشْرِينْ ن ثْندَّامْ ذِي ثمُّورْثْ ن لْجَالِيلْ. \f ◼ \fr 9:‏11 \ft \bd ’أَمرْزِي‘\bd* - نِيغْ ’أَمضْزِي‘.\f*
\v 12 حِيرَامْ إِفّغْ-د زِي صُورْ، حِيمَا أَذْ إِخْزَارْ ثِيندَّامْ نِّي ذ أَسْ إِوْشَا سُولِيمَانْ، مَاشَا ثُوغَا أَثنْثْ وَارْ شْنَانْثْ ذِي ثِيطَّاوِينْ نّسْ.
\v 13 نتَّا إِنَّا: ”مَانَا ثِيندَّامْ-أَ إِ ذ أَيِي ثوْشِيذْ، أَوْمَا؟“ ؤُ نتَّا إِڒَاغَا أَسنْثْ: ’ثَامُّورْثْ ن كابُولْ‘. \add نِيثنْثِي تّْوَاڒَاغَانْثْ أَمُّو\add* أَڒْ أَسّْ-أَ.
\v 14 حِيرَامْ ثُوغَا إِسّكّْ إِ ؤُجدْجِيذْ مْيَا ؤُ-عِيشْرِينْ ثَالِينْثْ ن وُورغْ.
\m 
\v 15 ذ وَا ذ أَوَاڒْ خْ لْجِيزْيَا إِ ثُوغَا إِسّْڭعّذْ ؤُجدْجِيذْ سُولِيمَانْ، مَاحنْذْ أَذْ إِبْنَا ثَادَّارْثْ ن سِيذِي ذ ثَادَّارْثْ نّسْ ذ لْقلْعَا ذ ڒْحِيضْ ن ؤُرْشَالِيمْ ذ حَاصُورْ ذ مَاجِيدُّو ذ جَازَارْ.
\v 16 فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا، ثُوغَا إِڭعّذْ، إِطّفْ جَازَارْ، إِقدّْ أَسْ ثِيمسِّي. إِنْغَا أَيْثْ ن كنْعَانْ إِ ثُوغَا إِزدّْغنْ ذِي ثنْذِينْثْ ؤُشَا إِوْشَا إِ-ت ذ ثَارْزفْثْ ن ثسْڒِيثْ إِ يدْجِيسْ، ثَامْغَارْثْ ن سُولِيمَانْ.
\v 17 سُولِيمَانْ إِبْنَا \add خنِّي\add* جَازَارْ ذ بَايْثْ-حُورُونْ ن وَادَّايْ
\v 18 ذ بَاعْلَاثْ ذِي ثمُّورْثْ \add نِّي\add* ذ ثَاذْمَارْ ذِي ڒخْڒَا \x ◘ \xo 9:‏18 \xt 2 إِم. 8‏:‏4‏-‏6\x*
\v 19 ذ مَارَّا ثِيندَّامْ ن ڒخْزنْ نِّي غَارسْ غَارْ سُولِيمَانْ ؤُڒَا ذ ثِيندَّامْ ن إِكَارُّوثنْ ذ ثِيندَّامْ ن إِمْنَاينْ، ؤُ مَارَّا مِينْ ثُوغَا إِمّژْرِي سُولِيمَانْ أَذْ \add ث\add* إِبْنَا ذِي ؤُرْشَالِيمْ، خْ \add إِذُورَارْ ن\add* لُوبْنَانْ ؤُ ذِي مَارَّا ثَامُّورْثْ إِ خْ إِحْكمْ.
\m 
\v 20 مَارَّا ڒْڭنْسْ إِ إِقِّيمنْ ن إِمُورِييّنْ، إِحِيتِّييّنْ، إِفِيرِيزِييّنْ، إِحِيوِييّنْ ذ إِيابُوسِييّنْ، إِنِّي وَارْ \add إِدْجِينْ\add* شَا زڭْ أَيْثْ ن إِسْرَائِيل،
\v 21 ثَارْوَا نْسنْ نِّي إِقِّيمنْ أَوَارْنِي أَسنْ ذِي ثمُّورْثْ، إِنِّي وَارْ زمَّارنْ أَيْثْ ن إِسْرَائِيل أَذْ ثنْ حَارّْمنْ \add إِ ؤُثحِّي\add*، إِڭَّا خَاسنْ سُولِيمَانْ لْجِيزْيَا ن ثسْمُوغِي أَڒْ أَسّْ-أَ.
\v 22 زڭْ أَيْثْ ن إِسْرَائِيل وَارْ إِڭِّي سُولِيمَانْ ؤُڒَا ذ إِجّْ ذ إِسْمغْ، مِينْزِي نِيثْنِي ثُوغَا أَثنْ ذ إِعسْكَارِييّنْ ذ إِمْسخَّارنْ نّسْ ذ ڒْحُوكَّامْ نّسْ ذ إِنغْرَافنْ نّسْ \add ن ڒْعسْكَارْ\add* ذ إِمقّْرَاننْ ن إِكَارُّوثنْ نّسْ ذ إِمْنَاينْ نّسْ. \x ◘ \xo 9:‏22 \xt لَاوِي 25‏:‏39\x*
\v 23 إِنَا ذ إِمحْضَاينْ إِمقّْرَاننْ نِّي ثُوغَا إِتّْوَاڒقّْمنْ خْ ڒْخذْمثْ ذِي طّْوعْ ن سُولِيمَانْ، خمْسَا-مْيَا ؤُ-خمْسِينْ \add ن يرْيَازنْ\add* نِّي ثُوغَا إِضبَّارنْ خْ ڒْڭنْسْ نِّي ثُوغَا إِتّطّْفنْ ذِي ڒْخذْمثْ.
\m 
\v 24 مَاشَا يدْجِيسْ ن فِيرْعُونْ ثْڭعّذْ زِي ثنْذِينْثْ ن ذَاوُوذْ غَارْ ثَادَّارْثْ إِ ثُوغَا إِ ذ أَسْ إِبْنَا. ڒخْذنِّي إِبْنَا لْقلْعَا. \x ◘ \xo 9:‏24 \xt 2 إِم. 8‏:‏11\x*
\m 
\v 25 ثْڒَاثَا ن ثْوَاڒَاوِينْ ذڭْ ؤُسڭّْوَاسْ إِسّْڭعّذْ سُولِيمَانْ ثِيغَارْصَا ن وشْمَاضْ ذ ثوْهِيبِينْ ن ڒهْنَا خْ ؤُعَالْطَارْ إِ ثُوغَا إِبْنَا إِ سِيذِي. \add عَاوذْ\add* إِسّْبخَّارْ خْ \add ؤُعَالْطَارْ ن ڒبْخُورْ\add* نِّي إِدْجَانْ زَّاثْ إِ وُوذمْ ن سِيذِي، ؤُشَا \add أَمُّو\add* إِ إِسلّمْ نتَّا ثَادَّارْثْ أَمْ ثكْمڒْ \add إِ سِيذِي\add*.
\m 
\v 26 أَجدْجِيذْ سُولِيمَانْ إِبْنَا ؤُڒَا ذ إِجّْ ن وَاڭْرَاوْ ن إِغَارُّوبَا ذِي عِيصْيُونْ-جَابَارْ إِ إِدْجَانْ غَارْ إِلَاثْ، غَارْ ثْمَا ن ڒبْحَارْ ن ثلْڭَا، ذِي ثمُّورْثْ إِذُومْ.
\v 27 حِيرَامْ إِسّكّْ إِمْسخَّارنْ نّسْ س وَاڭْرَاوْ ن إِغَارُّوبَا نِّي، إِبحْرِييّنْ إِنِّي إِسّْننْ ڒبْحَارْ، \add جْمِيعْ\add* أَكْ-ذ إِمْسخَّارنْ ن سُولِيمَانْ.
\v 28 نِيثْنِي إِوْضنْ غَارْ ؤُفِيرْ ؤُ كْسِينْ سّنِّي أَربْعَا-مْيَا ؤُ-عِيشْرِينْ ثَالِينْثْ ن وُورغْ ؤُ إِوْينْ ث غَارْ ؤُجدْجِيذْ سُولِيمَانْ.
\b
\b
\c 10
\s1 أَنوْجوْ ن ثْجدْجِيذْثْ ن سَابَا
\m 
\v 1 ثَاجدْجِيذْثْ ن شَابَا ثسْڒَا خْ شّنّْعثْ ن سُولِيمَانْ ثنِّي إِ د-يُوسِينْ أَكْ-ذ يِيسمْ ن سِيذِي ؤُ نتَّاثْ ثُوسَا-د، حِيمَا أَذْ ث ثْقدْجبْ س ثْحُوجَا ن ثْوَافِيثْ. \x ◘ \xo 10:‏1 \xt [2 إِم. 9‏:‏1‏-‏12]\x*
\v 2 نتَّاثْ ثُوسَا-د غَارْ ؤُرْشَالِيمْ س إِجّْ ن ؤُكَارَابَانْ إِ ذ أَسْ د-إِضْفَارنْ س دّْقڒْ \add ن وَاڭْڒَا\add* أَطَّاسْ، س إِڒغْمَانْ نِّي يَاربُّونْ ڒعْطُورْ ذ وَاطَّاسْ ن وُورغْ ذ إِژْرَا إِغْڒَانْ، ؤُ نتَّاثْ ثُوسَا-د غَارْ سُولِيمَانْ ؤُ ثسِّيوڒْ أَكِيذسْ خْ مَارَّا مِينْ غَارسْ ذڭْ وُوڒْ. \x ◘ \xo 10:‏2 \xt 2 إِم. 9‏:‏1؛ مت. 12‏:‏42؛ لك. 11‏:‏31\x*
\v 3 سُولِيمَانْ إِشَارْحْ مَارَّا أَوَاڒنْ إِ ثْحَاجَا \add نتَّاثْ\add*. وَارْ ذِينْ ؤُڒَا ذ إِجّْ ن وَاوَاڒْ \add س ڒمْعَانِي\add* إِنُّوفَّارنْ إِ وَارْ إِزمَّارْ ؤُجدْجِيذْ أَذْ أَسْ ث إِشَارّحْ.
\m 
\v 4 ثَاجدْجِيذْثْ ن شَابَا ثژْرَا مَارَّا ثِيغِيثْ ن سُولِيمَانْ ذ ثَادَّارْثْ إِ إِبْنَا،
\v 5 ذ مَاشَّا خْ طَّابْڒَا نّسْ، ذ مَامّشْ قِّيمنْ إِمْسخَّارنْ نّسْ، ذ مَامّشْ بدّنْ إِخدَّامنْ نّسْ ذ وَارُّوضْ نْسنْ، ذ إِوَارَّاذنْ نّسْ، ذ دّْرُوجْ نّسْ \add إِزوّْقنْ\add* إِ خفْ د-إِڭعّذْ غَارْ ثَادَّارْثْ ن سِيذِي، ؤُشَا وَارْ إِقِّيمْ ذَايسْ \add عْڒَاحَاڒْ\add* بُوحْبڒْ \add عَاذْ\add*. \x ◘ \xo 10:‏5 \xt 2 إِج. 16‏:‏18؛ 1 إِم. 9‏:‏18\x*
\v 6 نتَّاثْ ثنَّا إِ ؤُجدْجِيذْ: ”أَوَاڒْ نِّي سْڒِيغْ ذِي ثمُّورْثْ إِنُو خْ وَاوَاڒنْ نّشْ ؤُ خْ ثِيغِيثْ نّشْ، نِيشَانْ ذ ثِيذتّْ.
\v 7 نشّْ وَارْ ؤُمِينغْ شَا س وَاوَاڒنْ نِّي، أَڒَامِي د-ؤُسِيغْ ذَانِيثَا ؤُ \add خنِّي\add* ثِيطَّاوِينْ إِنُو ژْرِينْثْ أَيَا. خْزَارْ أَزْينْ \add زِي كُوڒْ مَانْ أَيَا\add* وَارْ ذ أَيِي إِتّْوَانَّا. ثِيغِيثْ ذ ثْشُونِي عْلَاحْسَابْ شّنّْعثْ إِ خْ سْڒِيغْ، أَقَا شكْ سنّجْ نْسنْثْ.
\v 8 سّعْذْ ن يرْيَازنْ نّشْ، سّعْذْ ن إِمْسخَّارنْ نّشْ، إِنِّي إِبدّنْ زَّاثْ إِ وُوذمْ نّشْ ڒبْذَا، إِنِّي زمَّارنْ أَذْ سْڒنْ ثِيغِيثْ نّشْ.
\v 9 أَذْ إِتّْوَابَاركْ سِيذِي، أَربِّي نّشْ، ونِّي ؤُمِي د-ثُوسِيذْ خْ ڒْخَاضَارْ، حِيمَا أَذْ شكْ يڭّْ خْ ڒْعَارْشْ ن إِسْرَائِيل. مِينْزِي سِيذِي إِتّخْسْ إِسْرَائِيل إِ ڒبْذَا، \add س ؤُيَا\add* إِڭَّا شكْ ذ أَجدْجِيذْ، مَاحنْذْ أَذْ ثڭّذْ ڒْحقّْ ذ ثْسڭْذَا.“
\v 10 نتَّاثْ ثوْشَا إِ ؤُجدْجِيذْ مْيَا ؤُ-عِيشْرِينْ ثَالِينْثْ ن وُورغْ ذ وَاطَّاسْ ن ڒعْطُورْ ذ يژْرَا إِغْڒَانْ. إِجّْ ن ؤُفيّضْ ن ڒعْطُورْ أَمْ وَانِيثَا إِ إِوْشِينْ ثَاجدْجِيذْثْ ن شَابَا إِ ؤُجدْجِيذْ سُولِيمَانْ،عمَّارْصْ عَاذْ وَارْ د-يُوسِي شَا.
\m 
\v 11 أَڭْرَاوْ ن إِغَارُّوبَا ن حِيرَامْ إِ-د يِيوْينْ ؤُرغْ زڭْ ؤُفِيرْ، يِيوْيِي-د عَاوذْ أَطَّاسْ ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* صَانْذَالْ ذ يژْرَا إِغْڒَانْ زِي ؤُفِيرْ.
\v 12 أَجدْجِيذْ إِڭَّا زڭْ ؤُكشُّوضْ ن صَانْذَالْ وَانِيثَا أَفْرَاينْ إِزوّْقنْ إِ ثَادَّارْثْ ن سِيذِي ؤُ إِ ثَادَّارْثْ ن ؤُجدْجِيذْ ؤُڒَا ذ ڒْڭَامْبْرِييَاثْ ذ لهَارْپَاثْ إِ إِمذْيَازنْ. أَكشُّوضْ ن سَانْذَالْ أَمْ وَانِيثَاعمَّارْصْ وَارْ د-يُوسِي نِيغْ إِتّْوَاژَارْ عَاذْ أَڒْ أَسّْ-أَ. \x ◘ \xo 10:‏12 \xt 2 إِم. 9‏:‏11\x*
\m 
\v 13 أَجدْجِيذْ سُولِيمَانْ إِوْشَا إِ ثْجدْجِيذْثْ ن شَابَا مَارَّا ذِي مِينْ ثُوغَا ثمّژْرِي، مِينْ مَا ثُوغَا ثتَّارْ سنّجْ إِ مِينْ ذ أَسْ إِوْشَا \add عَاذْ\add*، عْلَاحْصَابْ \add ثَاشْرِيمْثْ ن\add* ؤُفُوسْ ن ؤُجدْجِيذْ سُولِيمَانْ. \add خنِّي\add* ثنّقْڒبْ، ثذْوڒْ غَارْ ثمُّورْثْ نّسْ، نتَّاثْ ذ إِمْسخَّارنْ نّسْ.
\b
\s1 أَڭْڒَا أَطَّاسْ ن سُولِيمَانْ
\m 
\v 14 ڒْقدّْ ن وُورغْ إِ إِتَّاذْفنْ غَارْ سُولِيمَانْ ذڭْ إِجّْ ن ؤُسڭّْوَاسْ ثُوغَا ستَّا-مْيَا ؤُ-ستَّا ؤُ-ستِّينْ ثَالِينْثْ ن وُورغْ، \x ◘ \xo 10:‏14 \xt [2 إِم.9‏:‏13‏-‏28]] — 2 إِم. 9‏:‏13؛ عِز. 2‏:‏13؛ أَسَا. 17‏:‏9. \x*
\v 15 بْڒَا \add مِينْ إِكْسِي\add* زڭْ إِتِّيجَارِييّنْ ؤُ زِي ثْسبَّابْثْ ن إِسبَّابنْ ؤُ زِي مَارَّا إِجدْجِيذنْ ن عَارَابِييَّا ؤُ زِي لْوُولَاثْ ن ثمُّورْثْ.
\m 
\v 16 أَجدْجِيذْ سُولِيمَانْ إِڭَّا \add عَاوذْ\add* مِيثَاينْ ن ثْسدَّارِييِينْ \add ن ؤُعسْكَارِي\add* ثِيمقّْرَانِينْ س وُورغْ إِتّْوَادّْزنْ. خْ إِشْثْ ن ثْسدَّارْثْ تّْوَاڭّنْ ستَّا-مْيَا \add شِيقْلُو\add* ن وُورغْ. \x ◘ \xo 10:‏16 \xt 1 إِج. 14‏:‏26\x*
\v 17 \add يَارْنِي إِڭَّا نتَّا\add* ثڒْثْ-مْيَا ن ثْسدَّارِييِينْ ن ؤُعسْكَارِي س وُورغْ إِتّْوَادّْزنْ. تّْوَاڭّنْثْ ثڒْثْ مِينَايَاثْ ن وُورغْ خْ إِشْثْ ن ثْسدَّارْثْ. أَجدْجِيذْ إِسَّارْسْ إِ-ثنْثْ ذِي ثَادَّارْثْ ن وزْغَارْ ن لُوبْنَانْ. \f ◼ \fr 10:‏17 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  \x ◘ \xo 10:‏17 \xt 1 إِج. 7‏:‏2\x*
\m 
\v 18 أَجدْجِيذْ سُولِيمَانْ إِڭَّا \add عَاوذْ\add* إِجّْ ن ڒْعَارْشْ أَمقّْرَانْ زِي ڒْعَاجْ ؤُشَا إِغدْجفْ إِ-ث س وُورغْ إِتّْوَاصفَّانْ. \f ◼ \fr 10:‏18 \ft \bd ’ڒْعَاجْ‘\bd* - إِخْسْ أَذْ يِينِي ’أَشَّاونْ ن لْفِيلْ‘.\f*  \x ◘ \xo 10:‏18 \xt 2 إِم. 9‏:‏17\x*
\v 19 ڒْعَارْشْ وَانِيثَا غَارسْ ستَّا ن ثَارفِّيذِينْ ؤُ أَزدْجِيفْ ن ڒْعَارْشْ ثُوغَا-ث إِقُووَّارْ غَارْ ضفَّارْ نّسْ ؤُ غَارْ ثْنَاينْ ن إِغزْذِيسنْ ن ڒْكُورْسِي ثُوغَا دْجَانْ إِغَادْجنْ، ؤُ ثْنَاينْ ن وَايْرَاذنْ ثُوغَا بدّنْ زَّاثْ إِ إِغَادْجنْ.
\v 20 ثنْعَاشْ ن وَايْرَاذنْ بدّنْ غَارْ ثْنَاينْ ن إِغزْذِيسنْ خْ ستَّا ن ثَارفِّيذِينْ. أَمْ نتَّا وَارْ إِتّْوَاڭّْ عَاذْ ؤُڒَا ذڭْ إِشْثْ ن ثْڭلْذِيثْ.
\m 
\v 21 مَارَّا إِغَارَّافنْ ن ثِيسِّيثْ ن سُولِيمَانْ \add ثُوغَا أَثنْ\add* ن وُورغْ ؤُ مَارَّا ڒقْشُوعْ ن ثَادَّارْثْ ن وزْغَارْ ن لُوبْنَانْ \add ثُوغَا أَثنْ\add* س وُورغْ إِزذْڭنْ، وَارْ ذِينْ نُّوقَارْثْ \add ذَايسْ\add*، \add مَاغَارْ\add* ذڭْ وُوسَّانْ ن سُولِيمَانْ ثُوغَا حسّْبنْ ت ذ وَالُو. \f ◼ \fr 10:‏21 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*
\v 22 مَاغَارْ أَجدْجِيذْ ثُوغَا غَارسْ إِجّْ ن وَاڭْرَاوْ ن إِغَارُّوبَا ن ثَارْشِيشْ خْ ڒبْحَارْ \add جْمِيعْ\add* أَكْ-ذ وڭْرَاوْ ن إِغَارُّوبَا ن حِيرَامْ. إِشْثْ ن ثْوَاڒَا ذِي ثْڒَاثَا ن إِسڭّْوُوسَا يُوذفْ وڭْرَاوْ ن إِغَارُّوبَا ن ثَارْشِيشْ، يِيوِي ؤُرغْ ذ نُّوقَارْثْ، ڒْعَاجْ ذ إِبَاغُوسنْ ذ إِطَاوْسنْ.
\v 23 أَجدْجِيذْ سُولِيمَانْ إِعْذُو مَارَّا إِجدْجِيذنْ ن دُّونشْثْ ذڭْ وَاڭْڒَا ذ ثِيغِيثْ. \x ◘ \xo 10:‏23 \xt 1 إِج. 3‏:‏12، 13\x*
\v 24 مَارَّا دُّونشْثْ يَارْزُو \add أَذْ ژَترنْ\add* ؤُذمْ ن سُولِيمَانْ، مَاحنْذْ أَذْ سْڒنْ ثِيغِيثْ نّسْ إِ ثُوغَا إِسَّارْسْ أَربِّي ذڭْ وُوڒْ نّسْ.
\v 25 \add س ؤُينِّي\add* ؤُسِينْ-د نِيثْنِي أَسڭّْوَاسْ أَوَارْنِي إِ ؤُمَاسْ، كُوڒْ إِجّْ س ثَارْزفْثْ نّسْ، \add س\add* ڒقْشُوعْ ن نُّوقَارْثْ، ڒقْشُوعْ ن وُورغْ، أَرُّوضْ، ڒسْنَاحْ، ڒعْطُورْ، إِيْسَانْ ذ إِسَارْذَانْ. أَقَا ذ مَانْ أَيَا إِمْسَارْ أَسڭّْوَاسْ أَوَارْنِي إِ ؤُمَاسْ.
\v 26 سُولِيمَانْ إِسّْمُونْ إِكَارُّوثنْ ذ إِمْنَاينْ. نتَّا ثُوغَا غَارسْ أَڒفْ ؤُ-أَربْعَا-مْيَا ن إِكَارُّوثنْ ذ ثنْعَاشْ-أَڒفْ ن إِمْنَاينْ، ؤُشَا يِيوْيِي ثنْ غَارْ ثْندَّامْ ن إِكَارُّوثنْ ؤُ غَارْ ؤُجدْجِيذْ ذِي ؤُرْشَالِيمْ. \x ◘ \xo 10:‏26 \xt 1 إِج. 5‏:‏20؛ 2 إِم. 1‏:‏14؛ 9‏:‏25\x*
\m 
\v 27 أَجدْجِيذْ إِڭَّا نُّوقَارْثْ \add أَطَّاسْ\add* ذِي ؤُرْشَالِيمْ، أَمشْنَاوْ إِژْرَا، ؤُ \add ثِيشجُّورَا ن\add* ثنْڭلْثْ إِڭَّا \add إِ-ثنْثْ\add* أَطَّاسْ أَمشْنَاوْ إِزمُّورنْ نِّي \add إِدْجَانْ\add* ذِي ثمُّورْثْ إِوَاطَانْ. \x ◘ \xo 10:‏27 \xt 2 إِم. 1‏:‏15؛ 9‏:‏27\x*
\m 
\v 28 إِيْسَانْ إِ سُولِيمَانْ تّْوَاسُّوفّْغنْ زِي مِيصْرَا، زِي قِيوِي. إِسبَّابنْ ن ؤُجدْجِيذْ إِوْينْ \add ثنْ\add* س يِيجّْ ن تَّامَانْ \add إِمثْننْ\add* زِي قِيوِي. \x ◘ \xo 10:‏28 \xt 2 إِم. 1‏:‏16؛ 9‏:‏28\x*
\v 29 إِجّْ ن ؤُكَارُّو إِڭعّذْ-د ؤُ إِتّْوَاسُّوفّغْ-د زِي مِيصْرَا س \add إِجّْ ن تَّامَانْ ن\add* ستَّا-مْيَا \add شِيقْلُو\add* ن نُّوقَارْثْ ؤُ إِجّْ ن ؤُيِيسْ س مْيَا ؤُ-خمْسِينْ \add شِيقْلُو\add*. نِيثْنِي سُّوفّْغنْ ثنْ س ؤُفُوسْ نْسنْ \add عَاوذْ\add* إِ مَارَّا إِجدْجِيذنْ ن إِحِيتِّييّنْ ؤُ إِ إِجدْجِيذنْ ن أَرَامْ. \x ◘ \xo 10:‏29 \xt 2 إِم. 1‏:‏17\x*
\b
\b
\c 11
\s1 أَعْبذْ ن لْ-أَصْنَامْ زِي سُولِيمَانْ
\m 
\v 1 أَجدْجِيذْ سُولِيمَانْ ثُوغَا إِتّخْسْ أَطَّاسْ ن ثمْغَارِينْ ثِيبَارَّانِييِّينْ، \add أَمْ مَامّشْ ثُوغَا إِتّخْسْ\add* ؤُڒَا ذ يدْجِيسْ ن فِيرْعُونْ: \add ثِيمْغَارِينْ\add* زِي مُوآبَ، زِي عَامُّونْ، زِي إِذُومْ، زِي صِيذُونْ ؤُ زڭْ إِحِيتِّييِّينْ، \x ◘ \xo 11:‏1 \xt أَعَوذ. 17‏:‏17\x*
\v 2 \add ثِيمْغَارِينْ\add* زِي ڒڭْنُوسْ إِ خْ ثُوغَا إِنَّا سِيذِي إِ أَيْثْ ن إِسْرَائِيل: ”كنِّيوْ وَارْ غَارْسنْ تَّاذْفمْ ؤُشَا ؤُڒَا ذ نِيثْنِي وَارْ غَارْومْ تَّاذْفنْ. س ثِيذتّْ أَذْ غْوَانْ نِيثْنِي ؤُڒْ نْومْ، حِيمَا أَذْ ثُويُورمْ أَوَارْنِي إِ إِربِّيثنْ نْسنْ!“ \add مَاشَا\add* سُولِيمَانْ إِقّنْ غَارْسنْ س ثَايْرِي. \x ◘ \xo 11:‏2 \xt ؤُف. 34‏:‏16؛ أَعَوذ. 7‏:‏3\x*
\v 3 نتَّا ثُوغَا غَارسْ سبْعَا-مْيَا ن ثمْغَارِينْ، ثِيجدْجِيذِينْ، ؤُ ثڒْثْ-مْيَا ن ثِييَّا. ثِيمْغَارِينْ نّسْ غْوَانْثْ ؤُڒْ نّسْ.
\v 4 ڒَامِي د-ثِيوضْ ثوْسَارْ غَارْ سُولِيمَانْ غْوَانْثْ ثمْغَارِينْ نّسْ ؤُڒْ نّسْ، \add أَڒَامِي يُويُورْ\add* أَوَارْنِي إِ إِربِّيثنْ نّغْنِي. ؤُڒْ نّسْ وَارْ إِقِّيمْ إِمُونْ إِ سِيذِي، أَربِّي نّسْ، أَمْ وُوڒْ نْ بَابَاسْ ذَاوُوذْ.
\v 5 سُولِيمَانْ يُويُورْ أَوَارْنِي إِ أَشْثُورِيثْ، ثَاربِّيثْ ن إِصِيذُونِييّنْ، ؤُ أَوَارْنِي إِ مِيلْكُومْ، نّْعِي ن لْ-أَصْنَامْ ن أَيْثْ ن عَامُّونْ. \x ◘ \xo 11:‏5 \xt ڒقض. 2‏:‏13؛ 2 إِج. 23‏:‏13\x*
\v 6 سُولِيمَانْ إِڭَّا \add مِينْ إِدْجَانْ ذ\add* أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي. نتَّا وَارْ ثُوغِي إِشْضَارْ أَطَّاسْ إِ سِيذِي أَمْ بَابَاسْ ذَاوُوذْ.
\v 7 خنِّي إِبْنَا سُولِيمَانْ إِشْثْ ن ڒْڭعّْذثْ إِ كَامُوشْ، نّْعِي ن صَّانَامْ ن أَيْثْ ن مُوآبَ، ذڭْ وذْرَارْ ونِّي \add إِدْجَانْ\add* زَّاثْ إِ ؤُرْشَالِيمْ، ؤُشَا \add ؤُڒَا ذ إِشْثْ ن ڒْڭعّْذثْ\add* إِ مُولِيكْ، نّْعِي ن صَّانَامْ ن أَيْثْ ن عَامُّونْ. \x ◘ \xo 11:‏7 \xt 2 إِج. 23‏:‏13\x*
\v 8 أَمُّو إِ إِڭَّا إِ مَارَّا ثِيمْغَارِينْ نّسْ ثِيبَارَّانِييِّينْ، ثِينِّي إِوْينْ ڒبْخُورْ ذ ثْغَارْصَا ن وشْمَاضْ إِ إِربِّيثنْ نْسنْثْ.
\m 
\v 9 \add س ؤُينِّي\add* إِسْعَارْ سِيذِي خْ سُولِيمَانْ، مِينْزِي ؤُڒْ نّسْ ثُوغَا إِحيّذْ خْ سِيذِي، أَربِّي ن إِسْرَائِيل، إِ ثُوغَا غَارسْ-د إِبَانْ ثْنَاينْ ن ثْوَاڒَاوِينْ، \x ◘ \xo 11:‏9 \xt 1 إِج. 3‏:‏5؛ 9‏:‏2\x*
\v 10 \add وَاخَّا\add* ثُوغَا غَارسْ د-يُوسَا ڒُومُورْ \add نِيشَانْ\add*، مَاحنْذْ وَارْ إِڭُّورْ أَوَارْنِي إِ إِربِّيثنْ نّغْنِي ؤُ نتَّا \add خنِّي\add* وَارْ إِحْضَا مِينْ ذ أَسْ يُومُورْ سِيذِي. \x ◘ \xo 11:‏10 \xt 1 إِج. 6‏:‏12\x*
\v 11 \add س ؤُينِّي\add* إِنَّا سِيذِي إِ سُولِيمَانْ: ”مِينْزِي إِمْسَارْ أَشْ أَمُّو أَڒَامِي وَارْ ثحْضِيذْ شَا ڒْعَاهْذْ إِنُو ذ ثْوصَّا إِنُو نِّي شكْ ؤُمُورغْ، س ثِيذتّْ أَذْ زَّايكْ قڒْعغْ ثَاڭلْذِيثْ-أَ ؤُشَا أَذْ ت وْشغْ إِ ؤُمْسخَّارْ نّشْ. \x ◘ \xo 11:‏11 \xt 1 إِج. 12‏:‏15\x*
\v 12 ذڭْ وُوسَّانْ نّشْ وَارْ ث ڭّغْ \add عَاذْ\add* ذِي طّْوعْ ن بَابَاشْ ذَاوُوذْ، \add مَاشَا\add* أَذْ ت قڒْعغْ زڭْ ؤُفُوسْ ن مِّيشْ.
\v 13 مَاشَا نشّْ وَارْ خَاكْ قڒْعغْ ثَاڭلْذِيثْ مَارَّا. أَذْ وْشغْ إِشْثْ ن ثقْبِيتْشْ إِ مِّيشْ ذِي طّْوعْ ن ؤُمْسخَّارْ إِنُو ذَاوُوذْ ؤُ ذِي طّْوعْ ن ؤُرْشَالِيمْ نِّي فَارْزغْ نشّْ.“
\b
\s1 ڒْعذْيَانْ ن سُولِيمَانْ
\m 
\v 14 سِيذِي إِسّكَّارْ-د إِ سُولِيمَانْ إِجّْ ن ڒعْذُو هَاذَاذْ، زِي إِذُومْ. ثُوغَا هَاذَاذْ زِي ثَارْوَا ن ؤُجدْجِيذْ ن إِذُومْ. \f ◼ \fr 11:‏14 \ft \bd ’ثَارْوَا‘\bd* - س ثْعِيبْرَانِيثْ ’زَّارِيعثْ‘.\f*
\v 15 ؤُمِي ثُوغَا ذَاوُوذْ ذِي إِذُومْ ؤُ يُووَابْ، أَكُومَانْذَارْ نّسْ ن ڒْعسْكَارْ، إِڭعّذْ مَاحنْذْ أَذْ إِنْضڒْ إِنِّي إِتّْوَاسّْنُوقّْبنْ، إِمْسَارْ، أَقَا يُووَابْ إِنْغَا مَارَّا \add مِينْ إِدْجَانْ ذ\add* أَوْثمْ ذِي إِذُومْ. \x ◘ \xo 11:‏15 \xt 2 صم. 8‏:‏14؛ 1 إِم. 18‏:‏12، 13\x*
\v 16 مَاغَارْ يُووَابْ إِقِّيمْ ذِينِّي ستَّا ن إِيُورنْ أَكْ-ذ مَارَّا إِسْرَائِيل، أَڒَامِي إِثحَّا مَارَّا \add مِينْ إِدْجَانْ ذ\add* أَوْثمْ ذِي إِذُومْ. \f ◼ \fr 11:‏16 \ft \bd ’إِثحَّا‘\bd*- س ثْعِيبْرَانِيثْ ’إِقْضعْ‘.\f*
\v 17 مَاشَا هَاذَاذْ إِزمَّارْ أَذْ يَارْوڒْ، نتَّا ذ شَا ن يرْيَازنْ إِذُومِييّنْ زڭْ إِمْسخَّارنْ ن بَابَاسْ أَكِيذسْ، أَڒَامِي د-ؤُسِينْ غَارْ مِيصْرَا. ثُوغَا هَاذَاذْ \add عَاذْ\add* ذ إِجّْ ن ؤُحنْجِيرْ ذ أَمژْيَانْ.
\v 18 نِيثْنِي ثُوغَا كَّارنْ زِي مِيذْيَانْ ؤُشَا إِوْضنْ غَارْ فَارَانْ. ذِينِّي كْسِينْ نِيثْنِي إِرْيَازنْ ن فَارَانْ أَكِيذْسنْ ؤُشَا ؤُسِينْ-د غَارْ مِيصْرَا غَارْ فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا. وَانِيثَا إِوْشَا أَسْ إِشْثْ ن ثَادَّارْثْ، إِوْشَا أَسْ أَوَاڒْ \add أَذْ أَسْ إِوْشْ\add* مَاشَّا ؤُ إِوْشَا أَسْ إِشْثْ ن ثمُّورْثْ.
\v 19 هَاذَاذْ يُوفَا أَرْضَا أَمقّْرَانْ ذِي ثِيطَّاوِينْ ن فِيرْعُونْ، أَڒَامِي وَانِيثَا إِوْشَا أَسْ ؤُتْشْمَاسْ ن ثمْغَارْثْ نّسْ ذ ثَامْغَارْثْ، ؤُتْشْمَاسْ ن ثْجدْجِيذْثْ ثَاحْفَانِيسْ.
\v 20 ؤُتْشْمَاسْ ن ثَاحْفَانِيسْ ثُورُووْ أَسْ-د مِّيسْ جَانُوبَاثْ، ونِّي ثسُّوطُّوضْ ثَاحْفَانِيسْ ذِي ثَادَّارْثْ ن فِيرْعُونْ، أَڒَامِي \add خنِّي\add* جَانُوبَاثْ \add إِيْمَا\add* ذِي ڒْوسْطْ ن أَيْثْ ن فِيرْعُونْ.
\m 
\v 21 إِسْڒَا هَاذَاذْ ذِي مِيصْرَا بلِّي ذَاوُوذْ ثُوغَا إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ ؤُشَا يُووَابْ، أَكُومَانْذَارْ ن ڒْعسْكَارْ، إِمُّوثْ. \add خنِّي\add* إِنَّا هَاذَاذْ إِ فِيرْعُونْ: ”سكّْ أَيِي-د، أَذْ رَاحغْ غَارْ ثمُّورْثْ إِنُو!“
\v 22 \add مَاشَا\add* فِيرْعُونْ إِنَّا: ”مِينْ شكْ إِخصّنْ غَارِي، ڒَامِي ذَايكْ ژْرِيغْ، شكْ ثخْسذْ أَذْ ثْعقْبذْ غَارْ ثمُّورْثْ نّشْ؟“ نتَّا إِنَّا: ”وَالُو، مَاشَا \add وَاخَّا أَمنِّي\add* سكّْ أَيِي-د ذِينْ!“
\m 
\v 23 أَربِّي إِسّكَّارْ خَاسْ \add عَاوذْ\add* إِجّْ ن ڒعْذُو نّغْنِي، رَازُونْ، مِّيسْ ن إِلِيذَاعْ، ونِّي ثُوغَا يَاروْڒنْ زِي سِيذِي نّسْ هَاذَاذْ-عَازَارْ، أَجدْجِيذْ ن صُوبَا. \x ◘ \xo 11:‏23 \xt 2 صم. 8‏:‏3؛ 10‏:‏18\x*
\v 24 ثُوغَا إِسّْمُونْ إِرْيَازنْ، إِذْوڒْ ذ ڒْقبْطَانْ ن بَانْذِييَّا \add نْسنْ\add* ڒَامِي ثُوغَا إِخْسْ ذَاوُوذْ أَذْ ثنْ إِنغْ. \add مَاشَا\add* نِيثْنِي رُوحنْ غَارْ ذِيمَاشْقْ، زدّْغنْ ذِينْ ؤُ أَريّْسنْ ذِي ذِيمَاشْقْ. \x ◘ \xo 11:‏24 \xt 2 صم. 8‏:‏3\x*
\v 25 نتَّا ثُوغَا-ث ذ إِجّْ ن ڒعْذُو ن إِسْرَائِيل مَارَّا ؤُسَّانْ ن سُولِيمَانْ ذ مَانْ أَيَا سنّجْ إِ ڒْغَارْ \add إِ إِڭَّا\add* هَاذَاذْ. نتَّا إِعِيفّْ إِسْرَائِيل ؤُ يَاريّسْ أَمْ ؤُجدْجِيذْ خْ أَرَامْ.
\m 
\v 26 يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، إِجّْ ن إِفْرَاثِي زِي صَارَاذَاثَا، إِجّْ ن ؤُمْسخَّارْ ن سُولِيمَانْ إِسّْڭعّذْ أَفُوسْ نّسْ خْ ؤُجدْجِيذْ. يمَّاسْ قَّارنْ أَسْ صَارُوعَا، ثُوغَا-ت ذ ثَاجَّاتْشْ. \f ◼ \fr 11:‏26 \ft \bd ’يَارُوبْعَامْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ڒْڭنْسْ ذ أَطَّاسْ‘ نِيغْ ’ڒْڭنْسْ إِمْشُوبّشْ‘.\f*  \x ◘ \xo 11:‏26 \xt 2 إِم. 13‏:‏6\x*
\v 27 ذ مَانْ أَيَا ذ سِّيبّثْ إِ زِي ثُوغَا د-إِسّْڭعّذْ أَفُوسْ نّسْ خْ ؤُجدْجِيذْ، \add ڒَْامِي\add* ثُوغَا سُولِيمَانْ إِبنَّا لْقلْعَا، إِقّنْ ثَازِّيثْ ذِي ثنْذِينْثْ ن بَابَاسْ ذَاوُوذْ. \f ◼ \fr 11:‏27 \ft \bd ’ثَازِّيثْ‘\bd* - نِيغْ ’ڒْخَاوِي‘.\f*
\v 28 ثُوغَا يَارُوبْعَامْ ذ إِجّْ ن بُو-ثغْرُوضْثْ إِمحْضنْ. إِژْرَا سُولِيمَانْ أَقَا أَحُوذْرِي إِمْحضْ ذِي ڒْخذْمثْ ؤُشَا نتَّا إِڭَّا إِ-ث خْ مَارَّا ڒْخذْمثْ ن ثَاربُّوثْ ن ثَادَّارْثْ ن يُوسُوفْ.
\v 29 ذِي ڒْوقْثْ نِّي إِمْسَارْ أَقَا يَارُوبْعَامْ إِفّغْ زِي ؤُرْشَالِيمْ ؤُشَا يُوفَا إِ-ث ؤُنَابِي أَخِييَا ذڭْ وبْرِيذْ. وَانِيثَا ثُوغَا يَارْضْ إِجّْ ن وَارُّوضْ ن جْذِيذْ ؤُ نِيثْنِي س ثْنَاينْ إِذْسنْ ثُوغَا أَثنْ وحّذْسنْ ذڭْ إِيَّارْ.
\v 30 أَخِييَا إِطّفْ أَرُّوضْ ن جْذِيذْ نّسْ ونِّي يَارْضنْ ؤُ إِشَارّڭْ إِ-ث ذِي ثنْعَاشْ ن إِزِييْنَاثْ.
\v 31 إِنَّا إِ يَارُوبْعَامْ: ”كْسِيعشْرَا ن إِزِييْنَاثْ إِ شكْ، مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’خْژَارْ، نشّْ أَذْ شَارّْڭغْ ثَاڭلْذِيثْ زڭْ ؤُفُوسْ ن سُولِيمَانْ ؤُشَا أَذْ أَشْ وْشغْعشْرَا ن ثْقبَّاڒْ، \x ◘ \xo 11:‏31 \xt 1 صم. 15‏:‏28\x*
\v 32 \add مَاشَا\add* إِشْثْ ن ثقْبِيتْشْ أَذْ ثِيڒِي إِ نتَّا ذِي طّْوعْ ن ؤُمْسخَّارْ إِنُو ذَاوُوذْ ؤُ ذِي طّْوعْ ن ؤُرْشَالِيمْ، ثَانْذِينْثْ نِّي فَارْزغْ نشّْ زِي مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل.
\v 33 مَاغَارْ نِيثْنِي سمْحنْ ذَايِي ؤُ سجْذنْ إِ أَشْثُورِيثْ، ثَاربِّيثْ ن إِصِيذُونِييّنْ، إِ كَامُوشْ، أَربِّي ن أَيْثْ ن مُوآبَ، ؤُ إِ مَالْكَامْ، أَربِّي ن أَيْثْ ن عَامُّونْ. وَارْ ؤُيُورنْ نِيثْنِي ذِي ثبْرِيذِينْ إِنُو مَاحنْذْ أَذْ ڭّنْ مِينْ \add إِدْجَانْ\add* نِيشَانْ ذِي ثِيطَّاوِينْ إِنُو ؤُ \add وَارْ حْضِينْ\add* ثِيوصَّا إِنُو ذ لْفَارَايِيضْ إِنُو أَمْ \add ث إِڭَّا\add* بَابَاسْ ذَاوُوذْ.
\v 34 مَاشَا وَارْ ذ أَسْ تّكّْسغْ شَا مَارَّا ثَاڭلْذِيثْ زڭْ ؤُفُوسْ نّسْ، مَاشَا أَذْ ث سّْمثْنغْ ذ ڒْحَاكمْ مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّسْ ذِي طّْوعْ ن ؤُمْسخَّارْ إِنُو ذَاوُوذْ، ونِّي فَارْزغْ ذ ونِّي إِحْضَانْ ڒُومُورَاثْ إِنُو ذ ثْوصَّا إِنُو،
\v 35 \add مَاشَا\add* أَذْ كّْسغْ ثَاڭلْذَا زڭْ ؤُفُوسْ ن مِّيسْ ؤُ أَذْ شكْ وْشغْعشْرَا ن ثْقبَّاڒْ زَّايسْ،
\v 36 ؤُ إِ مِّيسْ أَذْ أَسْ وْشغْ إِشْثْ ن ثقْبِيتْشْ، مَاحنْذْ أَذْ ثقِّيمْ إِ ؤُمْسخَّارْ إِنُو ذَاوُوذْ ڒبْذَا إِشْثْ ن ثْفَاوْثْ زَّاثْ إِ وُوذمْ إِنُو ذِي ؤُرْشَالِيمْ، ثَانْذِينْثْ نِّي فَارْزغْ نشّْ إِ يِيخفْ إِنُو، حِيمَا أَذْ ذِينْ سّْمثْنغْ إِسمْ إِنُو. \x ◘ \xo 11:‏36 \xt 1 إِج. 15‏:‏4؛ إِزهد. 132‏:‏17\x*
\v 37 نشّْ أَذْ شكْ كْسِيغْ ؤُ شكْ أَذْ ثْحكْمذْ خْ مَارَّا مِينْ إِمّژْرِي ڒعْمَارْ نّشْ ؤُ أَذْ ثِيڒِيذْ ذ أَجدْجِيذْ خْ إِسْرَائِيل.
\v 38 مَاڒَا شكْ ثسْڒِيذْ غَارْ مَارَّا مِينْ زِي شكْ ؤُمُورغْ، أَذْ ثُويُورذْ خْ ثبْرِيذِينْ إِنُو ؤُ أَذْ ثڭّذْ مِينْ \add إِدْجَانْ\add* نِيشَانْ ذِي ثِيطَّاوِينْ إِنُو ؤُمِي إِ غَا ثحْضِيذْ ثِيوصَّا إِنُو ذ ڒُومُورَاثْ إِنُو أَمْ ث إِڭَّا ؤُمْسخَّارْ إِنُو ذَاوُوذْ، \add خنِّي\add* أَذْ إِمْسَارْ أَقَا نشّْ أَذْ إِڒِيغْ أَكِيذكْ ؤُ أَذْ أَشْ بْنِيغْ إِشْثْ ن ثَادَّارْثْ إِ غَا ثقِّيمْ أَمْ مَامّشْ ت بْنِيغْ إِ ذَاوُوذْ ؤُ نشّْ أَذْ أَشْ وْشغْ إِسْرَائِيل،
\v 39 نشّْ أَذْ سّهْوِيغْ ثَارْوَا ن ذَاوُوذْ إِ مَانْ أَيَا، مَاشَا وَارْ إِدْجِي إِ ڒبْذَا.“ \f ◼ \fr 11:‏39 \ft \bd ’ثَارْوَا‘\bd* - س ثْعِيبْرَانِيثْ ’زَّارِيعثْ‘.\f*
\m 
\v 40 سُولِيمَانْ ثُوغَا يَارزُّو أَذْ إِنغْ يَارُوبْعَامْ، مَاشَا يَارُوبْعَامْ إِكَّارْ، يَارْوڒْ غَارْ مِيصْرَا، غَارْ شِيشَاكْ، أَجدْجِيذْ ن مِيصْرَا. نتَّا إِقِّيمْ ذِي مِيسْرَا أَڒْ ڒْموْثْ ن سُولِيمَانْ.
\b
\m 
\v 41 مِينْ إِقِّيمنْ ن إِمزْرُوينْ ن سُولِيمَانْ ذ مَارَّا مِينْ إِڭَّا ذ ثِيغِيثْ إِ غَارسْ، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن سُولِيمَانْ؟ \x ◘ \xo 11:‏41 \xt 2 إِم. 9‏:‏29‏-‏31\x*
\v 42 ڒْوقْثْ نِّي إِحْكمْ سُولِيمَانْ خْ مَارَّا إِسْرَائِيل ذِي ؤُرْشَالِيمْ، ثُوغَا أَربْعِينْ ن إِسڭّْوُوسَا. \x ◘ \xo 11:‏42 \xt 2 إِم. 9‏:‏30\x*
\v 43 سُولِيمَانْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نتَّا إِتّْوَانْضڒْ ذِي ثنْذِينْثْ ن بَابَاسْ ذَاوُوذْ ؤُ مِّيسْ رَاحَابْعَامْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\b
\b
\c 12
\s1 أَبطُّو ن ثْڭلْذِيثْ
\m 
\v 1 رَاحَابْعَامْ يُويُورْ غَارْ شَاكِيمْ، مَاغَارْ مَارَّا إِسْرَائِيل يُوسَا-د غَارْ شَاكِيمْ، حِيمَا أَذْ ث ڭّنْ ذ أَجدْجِيذْ. \x ◘ \xo 12:‏1 \xt [2 إِم. 10‏:‏1‏-‏19؛ 11‏:‏1‏-‏4] — 2 إِم. 10‏:‏1؛ \x*
\v 2 ؤُمِي إِسْڒَا يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، خْ مَانْ أَيَا، ؤُمِي ثُوغَا عَاذْ ذِي مِيصْرَا - أَقَا نتَّا ثُوغَا يَارْوڒْ زِي زَّاثْ ن وُوذمْ ن ؤُجدْجِيذْ سُولِيمَانْ ؤُ يَارُوبْعَامْ ثُوغَا إِزْذغْ ذِي مِيصْرَا - إِمْسَارْ \x ◘ \xo 12:‏2 \xt 1 إِج. 11‏:‏40\x*
\v 3 أَقَا سّكّنْ-د غَارسْ إِرقَّاسنْ، جِّينْ أَذْ خَاسْ ڒَاغَانْ. يَارُوبْعَامْ ذ مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* ن إِسْرَائِيل ؤُسِينْ-د، سِّيوْڒنْ أَكْ-ذ رَاحَابْعَامْ، نَّانْ:
\v 4 ”بَابَاشْ إِڭَّا خَانغْ إِجّْ ن ؤُزَايْڒُو إِقْسحْ. \add خنِّي\add* ڒخُّو، سَارْخُو شكْ ڒْخذْمثْ إِقسْحنْ ن بَابَاشْ ؤُڒَا ذ أَزَايْڒُو إِضقْڒنْ إِ خَانغْ إِڭَّا، \add خنِّي\add* أَذْ شكْ نخْذمْ.“ \x ◘ \xo 12:‏4 \xt 2 إِم. 10‏:‏4\x*
\v 5 نتَّا إِنَّا أَسنْ: ”ؤُيُورمْ ؤُعقْبمْ أَوَارْنِي إِ ثْڒَاثَا ن وُوسَّانْ.“ ؤُشَا يُويُورْ ڒْڭنْسْ.
\m 
\v 6 إِمْشَاوَارْ ؤُجدْجِيذْ رَاحَابْعَامْ أَكْ-ذ إِمقّْرَاننْ، إِنِّي ثُوغَا إِبدّنْ زَّاثْ إِ وُوذمْ ن بَابَاسْ سُولِيمَانْ ؤُمِي ثُوغَا عَاذْ إِدَّارْ، إِنَّا: ”س مِينْ زِي ذ أَيِي ثْوصَّامْ أَذْ د-أَرّغْ خْ ڒْڭنْسْ-أَ؟“
\v 7 نِيثْنِي سِّيوْڒنْ أَكِيذسْ، نَّانْ: ”مَاڒَا شكْ ثڭِّيذْ إِخفْ نّشْ أَسّْ-أَ ذ أَمْسخَّارْ إِ ڒْڭنْسْ-أَ، أَذْ خَاسنْ ثْسخَّارذْ، أَذْ خَاسنْ د-ثَارّذْ ؤُ أَذْ كِيذْسنْ ثسِّيوْڒذْ س وَاوَاڒنْ إِشْنَانْ، خنِّي أَذْ ذوْڒنْ نِيثْنِي ذ إِمْسخَّارنْ نّشْ إِ ڒبْذَا.“
\v 8 \add مَاشَا\add* نتَّا إِنْضَارْ شّْوَارْ إِ ذ أَسْ ثُوغَا وْشِينْ إِمقّْرَاننْ ؤُشَا إِمْشَاوَارْ أَكْ-ذ إِحُوذْرِييّنْ نِّي ثُوغَا أَكِيذسْ إِمْغَارنْ ؤُ بدّنْ ڒخُّو زَّاثْ إِ وُوذمْ نّسْ.
\v 9 نتَّا إِسّقْسَا ثنْ: ”مَانْ ثتّْشَاوَارمْ أَذْ ث د-نَارّْ خْ وَاوَاڒْ ن ڒْڭنْسْ، مِينْزِي سِّيوْڒنْ أَكِيذِي، نَّانْ \add أَيِي\add*: ’سَارْخُو أَزَايْڒُو إِ خَانغْ إِڭَّا بَابَاشْ.‘ “
\v 10 إِحُوذْرِييّنْ نِّي أَكِيذسْ ثُوغَا إِمْغَارنْ سِّيوْڒنْ أَكِيذسْ، نَّانْ: ”أَمُّو إِ د غَا ثَارّذْ خْ ڒْڭنْسْ إِ كِيذكْ إِسِّيوْڒنْ، إِنَّانْ: ’بَابَاشْ إِسّضْقڒْ أَزَايْڒُو نّغْ، مَاشَا \add ڒخُّو\add* شكْ سَارْخُو ث خَانغْ!‘ ؤُ أَمُّو إِ كِيذْسنْ إِ غَا ثسِّيوْڒذْ: ’\add أَضَاضْ\add* أَمژْيَانْ إِنُو أَذْ يِيڒِي ذ أَمقّْرَانْ خْ ثجْعِينَّا ن بَابَا.
\v 11 \add خنِّي\add* ڒخُّو، أَقَا بَابَا إِقّنْ أَومْ إِجّْ ن ؤُزَايْڒُو إِقسْحنْ، \add خنِّي\add* نشّْ أَذْ ث سّْضقْڒغْ عَاذْ. بَابَا يَاربَّا كنِّيوْ س ؤُركُّوضْ، نشّْ أَذْ كنِّيوْ أَربِّيغْ س إِغَارْضْمِيونْ.‘ “
\m 
\v 12 ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا ؤُسِينْ-د يَارُوبْعَامْ ذ مَارَّا ڒْڭنْسْ غَارْ رَاحَابْعَامْ، أَمْ مَامّشْ ثُوغَا إِسِّيوڒْ ؤُجدْجِيذْ، إِنَّا: ”عقْبمْ-د غَارِي أَوَارْنِي إِ ثْڒَاثَا ن وُوسَّانْ!“
\v 13 أَجدْجِيذْ يَارَّا-د ڒْڭنْسْ س إِشْثْ ن ثمْوَارِّيثْ إِقسْحنْ، \add مَاغَارْ\add* نتَّا إِنْضَارْ شّْوَارْ إِ ذ أَسْ وْشِينْ إِمقّْرَاننْ.
\v 14 إِسِّيوڒْ أَكِيذْسنْ عْلَاحْسَابْ شّْوَارْ ن إِحُوذْرِييّنْ، إِنَّا: ”بَابَا إِسّضْقڒْ أَزَايْڒُو نْومْ، مَاشَا نشّْ أَذْ سّْضقْڒغْ عَاذْ أَزَايْڒُو نْومْ. بَابَا يَاربِّي كنِّيوْ س ؤُركُّوضْ، نشّْ أَذْ كنِّيوْ أَربِّيغْ س إِغَارْضْمِيونْ.“
\m 
\v 15 أَجدْجِيذْ وَارْ إِسْڒِي شَا غَارْ ڒْڭنْسْ، مَاغَارْ أَنقْڒبْ-أَ ثُوغَا إِ د-يُوسَا زِي سِيذِي، حِيمَا أَذْ إِسّمْثنْ أَوَاڒْ إِ ثُوغَا إِسِّيوڒْ سِيذِي س ؤُفُوسْ ن أَخِييَا، أَشِيلُونِي، إِ يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ. \x ◘ \xo 12:‏15 \xt 1 إِج. 11‏:‏11، 31\x*
\m 
\v 16 \add ؤُمِي\add* مَارَّا إِسْرَائِيل إِژْرَا أَقَا أَجدْجِيذْ وَارْ غَارْسنْ إِسْڒِي شَا، يَارَّا-د ڒْڭنْسْ خْ ؤُجدْجِيذْ، نَّانْ: ”مَانْ ثَاسْغَارْثْ إِ غَارْنغْ ذِي ذَاوُوذْ؟ نشِّينْ وَارْ غَارْنغْ بُو ثسْغَارْثْ غَارْ مِّيسْ ن يَاسَّا. غَارْ إِقِيضَانْ نّشْ، \add أَ\add* إِسْرَائِيل! ڒْهَا ڒخُّو أَكْ-ذ ثَادَّارْثْ نّشْ، \add أَ أَيْثْ ن\add* ذَاوُوذْ!“ ؤُشَا يُويُورْ إِسْرَائِيل غَارْ إِقِيضَانْ نْسنْ. \x ◘ \xo 12:‏16 \xt 2 صم. 20‏:‏1\x*
\v 17 \add مَاشَا\add* خْ أَيْثْ ن إِسْرَائِيل إِنِّي ثُوغَا إِزدّْغنْ ذِي ثْندَّامْ ن يَاهُوذَا، أَقَا رَاحَابْعَامْ ثُوغَا خَاسنْ ذ أَجدْجِيذْ.
\v 18 أَجدْجِيذْ رَاحَابْعَامْ إِسّكّْ \add غَارْسنْ\add* أَذُورَامْ، ونِّي \add إِدْجَانْ\add* خْ لْجِيزْيَا ن ثسْمُوغِي، ؤُ مَارَّا إِسْرَائِيل يَارْجمْ إِ-ث س يژْرَا أَڒَامِي إِمُّوثْ. أَجدْجِيذْ رَاحَابْعَامْ إِقدْجبْ، مَاحنْذْ أَذْ ينْيَا ذغْيَا خْ إِجّْ ن ؤُكَارُّو حِيمَا أَذْ يَارْوڒْ غَارْ ؤُرْشَالِيمْ. \x ◘ \xo 12:‏18 \xt 1 إِج. 4‏:‏6؛ 5‏:‏14\x*
\v 19 أَمُّو إِ إِغوّغْ إِسْرَائِيل خْ ثَادَّارْثْ ن ذَاوُوذْ، أَڒْ أَسّْ-أَ. \x ◘ \xo 12:‏19 \xt 2 إِج. 17‏:‏21\x*
\v 20 \add ؤُمِي\add* مَارَّا إِسْرَائِيل إِسْڒَا أَقَا يَارُوبْعَامْ إِعْقبْ-د، إِمْسَارْ، أَقَا سّكّنْ غَارسْ مَاحنْذْ أَذْ أَسْ د-ڒَْاغَانْ، حِيمَا أَذْ د-يَاسْ غَارْ ثْمسْمُونْثْ ؤُشَا ڭِّينْ ث ذ أَجدْجِيذْ خْ مَارَّا إِسْرَائِيل. ؤُڒَا ذ إِجّْ وَارْ إِقِّيمْ إِضفَّارْ عَاذْ ثَادَّارْثْ ن ذَاوُوذْ مْغِيرْ ثَاقْبِيتْشْ ن يَاهُوذَا.
\m 
\v 21 \add ؤُمِي\add* د-يُوسَا رَاحَابْعَامْ غَارْ ؤُرْشَالِيمْ، إِسّْمُونْ مَارَّا ثَادَّارْثْ ن يَاهُوذَا ذ ثقْبِيتْشْ ن بِينْيَامِينْ، مْيَا ؤُ-ثْمنْيِينْ-أَڒفْ \add ن إِرْيَازنْ\add* إِتّْوَافَارْزنْ، تّْوَاذَارّْبنْ إِ ؤُمنْغِي، حِيمَا أَذْ مّنْغنْ أَكْ-ذ ثَادَّارْثْ ن إِسْرَائِيل، حِيمَا أَذْ د-أَرّنْ ثَاڭلْذِيثْ غَارْ رَاحُوبْعَامْ، مِّيسْ ن سُولِيمَانْ. \x ◘ \xo 12:‏21 \xt 2 إِم. 11‏:‏1\x*
\v 22 \add خنِّي\add* يُوسَا-د وَاوَاڒْ ن أَربِّي غَارْ شَامْعِييَا أَرْيَازْ ن أَربِّي، إِنَّا: \x ◘ \xo 12:‏22 \xt 2 إِم. 11‏:‏2\x*
\v 23 ”سِيوڒْ أَكْ-ذ رَاحَابْعَامْ، مِّيسْ ن سُولِيمَانْ، أَجدْجِيذْ ن يَاهُوذَا، ؤُ أَكْ-ذ مَارَّا ثَادَّارْثْ ن يَاهُوذَا ؤُ ثنِّي ن بِينْيَامِينْ ؤُ إِ \add مَارَّا\add* مِينْ إِقِّيمنْ ن ڒْڭنْسْ، إِنِي:
\v 24 ’أَمُّو إِ إِقَّارْ سِيذِي: وَارْ تّْڭعّْذمْ ؤُ وَارْ تّْمنْغَامْ أَكْ-ذ أَيْثْمَاثْومْ، أَيْثْ ن إِسْرَائِيل. إِتّْخصَّا أَذْ إِعْقبْ \add كُوڒْ إِجّْ ن\add* ورْيَازْ غَارْ ثَادَّارْثْ نّسْ، مَاغَارْ ذ مَانْ أَيَا إِ إِمْسَارنْ زَّايِي.‘ “ نِيثْنِي سْڒِينْ غَارْ وَاوَاڒْ ن سِيذِي ؤُشَاعقْبنْ ؤُشَا ؤُيُورنْ \add غَارْ ومْشَانْ نْسنْ\add* عْلَاحْسَابْ أَوَاڒْ ن سِيذِي. *
\b
\m 
\v 25 يَارُوبْعَامْ إِبْنَا شَاكِيمْ خْ إِذُورَارْ ن إِفْرَايِيمْ ؤُشَا إِزْذغْ ذِينِّي. سّنِّي إِفّغْ ؤُشَا إِبْنَا فَانُووِيلْ. \x ◘ \xo 12:‏25 \xt ؤُف. 32‏:‏30\x*
\v 26 إِنَّا يَارُوبْعَامْ ذڭْ وُوڒْ نّسْ: ”ڒخُّو أَذْ د-ثعْقبْ ثْڭلْذِيثْ غَارْ ثَادَّارْثْ ن ذَاوُوذْ.
\v 27 \add مَاغَارْ\add* مَاڒَا ڒْڭنْسْ-أَ أَذْ د-إِڭعّذْ، حِيمَا أَذْ يَاوِي ثِيوْهِيبِينْ ذِي ثَادَّارْثْ ن سِيذِي ذِي ؤُرْشَالِيمْ، \add خنِّي\add* أَذْ د-إِذْوڒْ وُوڒْ ن ڒْڭنْسْ-أَ غَارْ سِيذِيثْسنْ، غَارْ رَاحَابْعَامْ، أَجدْجِيذْ ن يَاهُوذَا. أَذْ أَيِي نْغنْ ؤُ أَذْ د -عقْبنْ غَارْ رَاحَابْعَامْ، أَجدْجِيذْ ن يَاهُوذَا.“
\v 28 إِمْشَاوَارْ ؤُجدْجِيذْ، \add خنِّي\add* إِڭَّا \bd ثْنَاينْ ن إِعجْمِييّنْ ن وُورغْ\bd*، إِنَّا أَسنْ \add إِ ڒْڭنْسْ\add*: ”ذ أَطَّاسْ إِ كنِّيوْ مَاحنْذْ أَذْ ثْڭعّْذمْ غَارْ ؤُرْشَالِيمْ. خْزَارْ، إِربِّيثنْ نّشْ، \add أَ\add* إِسْرَائِيل، إِنِّي شكْ إِ د-إِسُّوفّْغنْ زِي مِيصْرَا.“ \f ◼ \fr 12:‏28 \ft \bd ’أَمْوَا‘\bd* - نِيغْ ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘.\f*  \x ◘ \xo 12:‏28 \xt ؤُف. 32‏:‏8؛ 2 إِج. 17‏:‏16\x*
\v 29 نتَّا إِسّْبدّْ إِجّْ \add ن صَّانَامْ\add* ن ؤُفُونَاسْ ذِي \bd بَايْثْ-إِلْ\bd* ؤُ ونّغْنِي إِسّْبدّْ إِ-ث ذِي \bd ذَانْ\bd*.
\v 30 أَيَا إِذْوڒْ ذ أَعْرَاضْ غَارْ دّْنُوبْ. ڒْڭنْسْ إِزْوَارْ يُويُورْ زَّاثْ إِ وُوذمْ ن إِجّْ \add ن ؤُفُونَاسْ\add* أَڒْ دَان.
\m 
\v 31 نتَّا إِسّْبدّْ إِشْثْ ن زَّاوشْثْ خْ ڒڭْعُوذِي. إِڭَّا إِكهَّاننْ \add إِ د-إِقَّارْصنْ\add* زِي مَارَّا طّْرُوفَا ن ڒْڭنْسْ إِنِّي وَارْ \add إِدْجِينْ\add* زڭْ أَيْثْ ن لَاوِي. \x ◘ \xo 12:‏31 \xt ڒخْڒ. 3‏:‏10؛ 1 إِج. 13‏:‏33؛ 2 إِج. 17‏:‏32؛ 2 إِم. 11‏:‏15\x*
\m 
\v 32 ذڭْ ؤُيُورْ وِيسّْ ثْمنْيَا، ذڭْ وَاسّْ وِيسّْ خمّسْطَاشْ ن ؤُيُورْ، إِڭَّا يَارُوبْعَامْ إِجّْ ن ڒْعِيذْ، أَمْ ڒْعِيذْ إِ تّڭّنْ ذِي يَاهُوذَا، ؤُ نتَّا إِسّْڭعّذْ ثِيغَارْصَا خْ ؤُعَالْطَارْ. إِڭَّا أَمُّو ذِي بَايْثْ-إِلْ حِيمَا أَذْ إِقدّمْ ثِيغَارْصَا إِ إِعجْمِييّمْ إِ يڭَّا. إِڭَّا عَاوذْ إِكهَّاننْ ذِي بِيثْ-إِلْ خْ ڒڭْعُوذِي نِّي إِڭَّا.
\m 
\v 33 ذڭْ وَاسّْ وِيسّْ خمّسْطَاشْ ذڭْ ؤُيُورْ وِيسّْ ثْمنْيَا ن ؤُيُورْ إِ ثُوغَا إِخَارّصْ نتَّا ذڭْ وُوڒْ نّسْ، إِسّْڭعّذْ ثِيغَارْصَا خْ ؤُعَالْطَارْ نِّي إِڭَّا ذِي بَايْثْ-إِلْ. أَمُّو إِ إِسّْبدّْ إِجّْ ن ڒْعِيذْ إِ أَيْثْ ن إِسْرَائِيل ؤُشَا إِسّْبخَّارْ ڒبْخُورْ خْ ؤُعَالْطَارْ.
\b
\b
\c 13
\s1 أَرْيَازْ ن أَربِّي زِي ثمُّورْثْ ن يَاهُوذَا
\m 
\v 1 خْزَارْ، س وَاوَاڒْ ن سِيذِي يُوسَا-د إِجّْ ن ورْيَازْ ن أَربِّي زِي يَاهُوذَا غَارْ بَايْثْ-إِلْ. يَارُوبْعَامْ ثُوغَا إِبدّْ زَّاثْ إِ ؤُعَالْطَارْ، حِيمَا أَذْ إِوهّبْ ڒبْخُورْ.
\v 2 نتَّا إِڒَاغَا خْ ؤُعَالْطَارْ س وَاوَاڒْ ن أَربِّي، إِنَّا: ”\add أَ\add* أَعَالْطَارْ، أَعَالْطَارْ، أَمُّو إِ إِقَّارْ سِيذِي، أَذْ د-إِتّْوَاخْڒقْ إِجّْ ن مِّيسْ ذِي ثَادَّارْثْ ن ذَاوُوذْ، أَذْ أَسْ قَّارنْ يُوشِييَا. نتَّا أَذْ خَاكْ إِڭّْ ذ ثَاغَارْصْثْ إِكهَّاننْ ن ڒڭْعُوذِي نِّي خَاكْ إِوهّْبنْ ڒبْخُورْ، ؤُ أَذْ خَاكْ شمْضنْ إِغْسَانْ ن إِوْذَانْ.“ \x ◘ \xo 13:‏2 \xt 2 إِج. 23‏:‏15‏-‏20\x*
\v 3 ذڭْ وَاسّْ نِّي ذ إِجّنْ إِوْشَا إِشْثْ نْ ڒعْڒَامثْ، إِنَّا: ”ثَا ذ ڒعْڒَامثْ إِ خْ إِسِّيوڒْ سِيذِي. خْزَارْ، أَعَالْطَارْ أَذْ إِشَارّڭْ ؤُ إِغّضْ ن مِينْ إِقِّيمنْ ن ثَاذُونْثْ إِ خَاسْ \add إِدْجَانْ\add* أَذْ زَّايسْ د-إِحْرُودْجضْ.“
\m 
\v 4 ؤُمِي إِسْڒَا ؤُجدْجِيذْ أَوَاڒْ ن ورْيَازْ ن أَربِّي ونِّي إِڒَاغَانْ خْ ؤُعَالْطَارْ ذِي بَايْثْ-إِلْ، إِمْسَارْ، أَقَا إِسّْوِيژّضْ يَارُوبْعَامْ أَفُوسْ نّسْ خْ ؤُعَالْطَارْ، إِنَّا: ”طّفْ إِ-ث!“ \add مَاشَا\add* أَفُوسْ نّسْ نِّي ثُوغَا غَارسْ إِسّْوِيژّْضنْ، يُوژغْ، أَڒَامِي وَارْ إِزمَّارْ عَاذْ أَذْ ث-إِ-د-يَارّْ غَارسْ.
\v 5 إِشَارّڭْ ؤُعَالْطَارْ ؤُشَا إِحْڒُودْجذْ زَّايسْ \add يِيغّذْ ن\add* ثَاذُونْثْ عْلَاحْسَابْ ڒعْڒَامثْ إِ إِوْشَا ورْيَازْ ن أَربِّي س وَاوَاڒْ ن سِيذِي.
\v 6 خنِّي يَارَّا-د ؤُجدْجِيذْ، إِنَّا إِ ورْيَازْ ن أَربِّي: ”زَاوْڭْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّشْ، ؤُشَا ژَتدْجْ خَافِي \add حِيمَا\add* أَفُوسْ إِنُو أَذْ غَارِي د-إِذْوڒْ!“ ؤُشَا إِزَاوْڭْ ورْيَازْ ن أَربِّي إِ وُوذمْ ن سِيذِي ؤُشَا أَفُوسْ ن ؤُجدْجِيذْ إِذْوڒْ-د غَارسْ ؤُشَا إِذْوڒْ أَمْ مَامّشْ ث ثُوغَا قْبڒْ. \x ◘ \xo 13:‏6 \xt ؤُف. 8‏:‏4؛ 9‏:‏28؛ 10‏:‏17؛ ڒخْڒ. 21‏:‏7؛ ڒخ. 8‏:‏24\x*
\v 7 \add خَاسْ ؤُشَا\add* إِسِّيوڒْ ؤُجدْجِيذْ أَكْ-ذ ورْيَازْ ن أَربِّي: ”أَسْ-د غَارْ ثَادَّارْثْ إِنُو ؤُشَا أَريّحْ! ؤُڒَا ذ نشّْ أَذْ أَشْ وْشغْ إِشْثْ ن ثرْزفْثْ.“
\v 8 \add مَاشَا\add* يَارَّا-د ورْيَازْ ن أَربِّي خْ ؤُجدْجِيذْ: ”وَاخَّا شكْ ثوْشِيذْ أَيِي أَزْينْ ن ثَادَّارْثْ نّشْ، نشّْ وَارْ \add أَ\add*كِيذكْ ڭُّورغْ ؤُ وَارْ تِّيشغْ أَغْرُومْ ذڭْ ومْشَانْ-أَ ؤُڒَا وَارْ \add ذَا\add* سسّغْ. \x ◘ \xo 13:‏8 \xt ڒخْڒ. 22‏:‏18\x*
\v 9 مَاغَارْ أَمُّو إِ ذ أَيِي إِوصَّا س وَاوَاڒْ ن سِيذِي، إِنَّا: ’شكْ وَارْ \add ذِينِّي\add* ثتّتّذْ ؤُ وَارْ \add ذِينِّي\add* ثْسسّذْ ؤُ وَارْ ثْعِيقِّيبذْ خْ وبْرِيذْ إِ خْ د-ثُوسِيذْ.‘ “
\v 10 ؤُشَا نتَّا إِرُوحْ خْ إِجّْ ن وبْرِيذْ نّغْنِي ؤُ وَارْ د-إِعْقِيبْ شَا خْ وبْرِيذْ إِ خْ د-يُوسَا غَارْ بَايْثْ-إِلْ.
\m 
\v 11 ذِي بَايْثْ-إِلْ ثُوغَا إِزدّغْ \add عَاذْ\add* إِجّْ ن ؤُنَابِي إِوْسَارْ. مِّيسْ نّسْ يُوسَا-د، إِحَاجَا أَسْ مِينْ ثُوغَا إِڭَّا ورْيَازْ ن أَربِّي ذڭْ وَاسّْ نِّي ذِي بَايْثْ-إِلْ، ؤُڒَا ذ أَوَاڒنْ إِ إِنَّا إِ ؤُجدْجِيذْ. إِحنْجِيرنْ نّسْ حَاجَانْ أَسْ ثنْ إِ بَابَاثْسنْ.
\v 12 إِنَّا أَسنْ بَابَاثْسنْ: ”خْ مَانْ أَبْرِيذْ إِ يُويُورْ نتَّا؟“ إِحنْجِيرنْ نّسْ ثُوغَا ژْرِينْ مَانْ أَبْرِيذْ ثُوغَا إِطّفْ ورْيَازْ ن سِيذِي ونِّي ثُوغَا إِ د-يُوسِينْ زِي يَاهُوذَا.
\v 13 نتَّا إِنَّا إِ إِحنْجِيرنْ نّسْ: ”بَارْذْعمْ أَيِي إِ وغْيُوڒْ!“ نِيثْنِي بَارْذْعنْ أَسْ إِ وغْيُوڒْ  ؤُشَا نتَّا إِنْيَا خَاسْ إِرُوحْ.
\v 14 نتَّا يَاردّفْ أَرْيَازْ ن أَربِّي ؤُشَا يُوفَا إِ-ث أَمْ إِقِّيمْ سَاذُو إِشْثْ ن ثْشجَّارْثْ ن يِيڭّْ. نتَّا إِنَّا أَسْ: ”مَا شكْ ذ أَرْيَازْ ن أَربِّي ونِّي د-إِفّْغنْ زِي يَاهُوذَا؟“ نتَّا إِنَّا: ”ذ نشّْ!“
\v 15 \add خنِّي\add* إِنَّا أَسْ: ”أَسْ-د أَكِيذِي غَارْ ثَادَّارْثْ إِنُو ؤُ أشّْ أَغْرُومْ.“
\v 16 \add مَاشَا\add* نتَّا إِنَّا: ”نشّْ وَارْ زمَّارغْ أَكِيذكْعقْبغْ ؤُ نشّْ وَارْ أَكِيذكْ د-تَّاسغْ. ؤُڒَا ذ نشّْ وَارْ تّتّغْ، وَارْ سسّغْ ذڭْ ومْشَانْ-أَ.
\v 17 مَاغَارْ يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، \add إِنَّا\add*: ’شكْ وَارْ ثْزمَّارذْ أَذْ \add ذِينِّي\add* ثشّذْ أَغْرُومْ ؤُ وَارْ ثْسسّذْ أَمَانْ. شكْ وَارْ ثْزمَّارذْ أَذْ د-ثْعقْبذْ خْ وبْرِيذْ إِ خْ د-ثُوسِيذْ.‘ “
\v 18 نتَّا إِنَّا أَسْ: ”ؤُڒَا ذ نشّْ ذ إِجّْ ن ؤُنَابِي أَمْ شكْ، ؤُ إِجّْ ن لْمَالَاكْ إِسِّيوڒْ أَكِيذِي س وَاوَاڒْ ن سِيذِي، إِنَّا: ’أَوْيِي ث غَاركْ ذِي ثَادَّارْثْ نّشْ، حِيمَا أَذْ يشّْ أَغْرُومْ، أَذْ إِسسّْ أَمَانْ.‘ “ \add أَمُّو\add* إِ إِسّْخَارّقْ خَاسْ.\x ◘ \xo 13:‏18 \xt ڭال. 1‏:‏8\x*
\v 19 ؤُشَا نتَّا إِعْقبْ أَكِيذسْ، إِشَّا أَغْرُومْ ذِي ثَادَّارْثْ نّسْ ؤُ إِسْوَا أَمَانْ.
\m 
\v 20 ؤُمِي قِّيمنْ نِيثْنِي غَارْ طَّابْڒَا، أَقَا يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ ؤُنَابِي ونِّي ثُوغَا ث-إِ-د-يَارِّينْ،
\v 21 ؤُ نتَّا إِڒَاغَا إِ ورْيَازْ ن أَربِّي إِ د-يُوسِينْ زِي يَاهُوذَا، إِنَّا: ”أَمُّو إِ إِقَّارْ سِيذِي: ’مَاغَارْ شكْ ثْغوّْغذْ خْ وَاوَاڒْ ن سِيذِي ؤُ وَارْ ثحْضِيذْ ڒُومُورْ إِ ذ أَشْ يُومُورْ سِيذِي، أَربِّي نّشْ،
\v 22 \add مَاشَا\add* ثْعقْبذْ ؤُ ثشِّيذْ أَغْرُومْ ؤُ ثسْوِيذْ أَمَانْ ذڭْ ومْشَانْ إِ خْ إِ ذ أَشْ إِنَّا: ’وَارْ ثْزمَّارذْ أَذْ \add ذِينْ\add* ثشّذْ أَغْرُومْ ؤُ وَارْ \add ذِينْ\add* ثْسّسذْ أَمَانْ، خْ ؤُيَا ڒْخشْبثْ نّشْ وَارْ د-ثُوسَا ذڭْ ونْضڒْ ن ڒجْذُوذْ نّشْ.‘ “
\m 
\v 23 أَوَارْنِي ؤُمِي ثُوغَا إِشَّا ذ إِسْوَا، إِبَارْذعْ أَسْ إِ وغْيُوڒْ إِ ؤُنَابِي إِ ذ إِڭَّا أَذْ د-إِذْوڒْ.
\v 24 أَمُّو د-إِفّغْ ؤُشَا إِمْسَاڭَارْ أَكِيذسْ إِجّْ ن ويْرَاذْ، إِنْغَا إِ-ث. ڒْخشْبثْ نّسْ ثُوغَا ثمّنْضَارْ \add ذِينْ\add* خْ وبْرِيذْ ؤُ أَغْيُوڒْ إِبدّْ زَّاثسْ ؤُشَا ؤُڒَا ذ أَيْرَاذْ إِبدّْ زَّاثْ إِ ڒْخشْبثْ. \x ◘ \xo 13:‏24 \xt 1 إِج. 20‏:‏36\x*
\v 25 ؤُ خْزَارْ، عْذُونْ \add شَا ن\add* يرْيَازنْ، ژْرِينْ ڒْخشْبثْ ثمّنْضَارْ خْ وبْرِيذْ ؤُڒَا ذ أَيْرَاذْ إِبدّْ زَّاثْ إِ ڒْخشْبثْ. نِيثْنِي إِوْضنْ غَارْ ثنْذِينْثْ ن ؤُنَابِي إِوْسَارنْ ؤُشَا سِّيوْڒنْ خْ مَانْ أَيَا.
\v 26 \add ؤُمِي\add* أَنَابِي ونِّي إِ-ث-إِ-د-يَارِّينْ زڭْ وبْرِيذْ، إِسْڒَا مَانْ أَيَا، إِنَّا نتَّا: ”وَا ذ أَرْيَازْ ن أَربِّي، ونِّي ثُوغَا إِغوّْغنْ خْ وَاوَاڒْ ن سِيذِي. \add خْ ؤُينِّي\add* إِوْشَا إِ-ث سِيذِي إِ ويْرَاذْ ؤُ وَانِيثَا إِمزّقْ إِ-ث ؤُشَا إِنْغَا إِ-ث عْلَاحْسَابْ أَوَاڒْ ن سِيذِي ونِّي ثُوغَا كِيذسْ إِسِّيوْڒنْ.“
\v 27 ؤُشَا نتَّا إِسِّيوڒْ أَكْ-ذ إِحنْجِيرنْ نّسْ، إِنَّا: ”بَارْذْعمْ أَيِي إِ وغْيُوڒْ!“ نِيثْنِي بَارْذْعنْ أَسْ،
\v 28 ؤُشَا نتَّا إِفّغْ، يُوفَا ڒْخشْبثْ ثمّنْضَارْ خْ وبْرِيذْ ؤُڒَا ذ أَغْيُوڒْ ذ وَايْرَاذْ إِ إِبدّنْ زَّاثْ إِ ڒْخشْبثْ. أَيْرَاذْ وَارْ يشِّي ڒْخشْبثْ ؤُ وَارْ إِمزّقْ أَغْيُوڒْ.
\v 29 خنِّي إِسّْڭعّذْ ؤُنَابِي ڒْخشْبثْ، إِسَّارْسْ إِ-ت خْ وغْيُوڒْ ؤُشَا يِيوْيِي ت أَكِيذسْ. أَمُّو إِ د-يُوسَا ؤُنَابِي إِوْسَارنْ ذِي ثنْذِينْثْ، حِيمَا أَذْ خَاسْ إِوّثْ أَڭجْذُورْ ؤُ أَذْ ث إِنْضڒْ.
\v 30 نتَّا إِنْضڒْ ڒْخشْبثْ ذڭْ ونْضڒْ نّسْ ؤُ نِيثْنِي وْثِينْ خَاسْ أَڭجْذُورْ: ”ؤُهْ، ؤُمَا إِنُو!“
\v 31 أَوَارْنِي ؤُمِي ثُوغَا ث إِنْضڒْ، إِمْسَارْ، أَقَا إِسِّيوڒْ أَكْ-ذ إِحنْجِيرنْ نّسْ، إِنَّا: ”خْمِي غَا مّْثغْ، نضْڒمْ أَيِي ذڭْ ونْضڒْ إِ ذِي إِمّنْضَارْ ورْيَازْ ن أَربِّي ؤُ سَّارْسمْ إِغْسَانْ إِنُو خْ ؤُغزْذِيسْ ن إِغْسَانْ نّسْ!
\v 32 مَاغَارْ أَوَاڒْ إِ إِبَارّحْ س وَاوَاڒْ ن سِيذِي خْ ؤُعَالْطَارْ-أَ نِّي \add إِدْجَانْ\add* ذِي بَايْثْ-إِلْ ؤُ خْ مَارَّا ثِيزَاوِييِّينْ ن ڒڭْعُوذِي نِّي \add إِدْجَانْ\add* ذِي ثْندَّامْ ن سَامَارْيَا، أَذْ د-إِفّغْ نِيشَانْ.“ \x ◘ \xo 13:‏32 \xt 2 إِج. 23‏:‏16\x*
\m 
\v 33 أَوَارْنِي إِ وَاوَاڒْ-أَ وَارْ د-إِدّكّْوِيڒْ شَا يَارُوبْعَامْ زڭْ وبْرِيذْ أَعفَّانْ نّسْ، \add مَاشَا\add* يَاڒقّمْ عَاوذْ إِكهَّاننْ زِي \add مَارَّا\add* طّْرُوفَا ن ڒْڭنْسْ خْ ڒڭْعُوذِي. ونِّي ث إِخْسنْ، يَاڒقّمْ إِ-ث ؤُ وَانِيثَا إِذْوڒْ ذ أَكهَّانْ نْ ڒڭْعُوذِي. \x ◘ \xo 13:‏33 \xt 1 إِج. 12‏:‏31، 32\x*
\v 34 زِي ثْمسْڒَاشْثْ-أَ ثوْضَا ثَادَّارْثْ ن يَارُوبْعَامْ ذِي دّْنُوبْ، أَڒَامِي د-ثْقَارّبْ غَارْ ؤُثحِّي ذ وَاردّدْجْ زِي ثمُّورْثْ.
\b
\b
\c 14
\s1 يَارُوبْعَامْ ذ ؤُنَابِي أَهِييَا
\m 
\v 1 ذِي ڒْوقْثْ نِّي إِذْوڒْ أَبِييَا، مِّيسْ ن يَارُوبْعَامْ، إِهْڒشْ.
\v 2 إِنَّا يَارُوبْعَامْ إِ ثمْغَارْثْ نّسْ: ”كَّارْ، بدّڒْ أَرُّوضْ نّمْ، مَاحنْذْ وَارْ إِعقّڒْ ؤُڒَا ذ إِجّْ أَقَا شمْ ذ ثَامْغَارْثْ ن يَارُوبْعَامْ، أَذْ ثُويُورذْ غَارْ شِيلُو. أَقَا ذِينِّي أَنَابِي أَخِييَا ونِّي خَافِي إِنَّانْ أَقَا نشّْ أَذْ ذوْڒغْ ذ أَجدْجِيذْ خْ ڒْڭنْسْ-أَ. \x ◘ \xo 14:‏2 \xt 1 إِج. 11‏:‏31\x*
\v 3 كْسِي أَكِيذمْعشْرَا ن إِغْرُومنْ ذ ثفْضِيڒِينْ ذ إِجّْ ن ؤُقْذِيحْ ن ثَامّنْثْ ؤُشَا ؤُيُورْ غَارسْ! نتَّا أَذْ أَمْ إِنِي مِينْ غَا إِمْسَارنْ أَكْ-ذ ؤُحنْجِيرْ.“
\v 4 ؤُشَا أَمُّو إِ ثڭَّا ثمْغَارْثْ ن يَارُوبْعَامْ. نتَّاثْ ثكَّارْ، ثُويُورْ غَارْ شِيلُو، ثِيوضْ غَارْ ثَادَّارْثْ ن أَخِييَا. أَخِييَا ثُوغَا وَارْ إِثْوِيڒِي مَاغَارْ ثِيطَّاوِينْ نّسْ ثُوغَا ذوْڒنْثْ طّمّْسنْثْ ذِي ثوْسَارْ نّسْ.
\v 5 \add مَاشَا\add* سِيذِي إِنَّا إِ أَخِييَا: ”خْزَارْ، أَذْ د-ثَاسْ ثمْغَارْثْ ن يَارُوبْعَامْ، حِيمَا أَذْ شكْ ثسّقْسَا خْ مِّيسْ، مِينْزِي وَانِيثَا إِهْڒشْ. ثَا ذ ثَا إِ ذ أَسْ غَا ثِينِيذْ. خْمِي إِ د غَا ثَاسْ، أَذْ إِمْسَارْ، نتَّاثْ أَذْ ثسّْنِيعْمِيڒْ إِخفْ نّسْ ذ إِشْثنْ نّغْنِيثْ.“
\m 
\v 6 ؤُمِي إِسْڒَا أَخِييَا ڒْحسّْ ن إِصُورَافْ نّسْ غَارْ ثوَّارْثْ، إِمْسَارْ، أَقَا نتَّا إِنَّا: ”أَذفْ-د غَارْ ذَاخڒْ، أَ ثَامْغَارْثْ ن يَارُوبْعَامْ! مَايمِّي ثسّْنِيعْمِيڒذْ إِخفْ نّمْ أَمشْنَاوْ شمْ ذ إِشْثنْ نّغْنِيثْ؟ نشّْ تّْوَاسّكّغْ-د غَارمْ س \add إِشْثْ ن ثبْرَاثْ\add* إِقسْحنْ.
\v 7 ؤُيُورْ، إِنِي إِ يَارُوبْعَامْ: ’أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: مِينْزِي نشّْ سّْڭعّْذغْ شكْ زِي جَارْ ڒْوسْطْ ن ڒْڭنْسْ ؤُ ڭِّيغْ شكْ ذ ڒْحَاكمْ خْ ڒْڭنْسْ إِنُو إِسْرَائِيل، \x ◘ \xo 14:‏7 \xt 1 إِج. 12‏:‏15\x*
\v 8 ؤُشَا شَارّْڭغْ ثَاڭلْذِيثْ زِي ثَادَّارْثْ ن ذَاوُوذْ ؤُشَا وْشِيغْ أَشْ ت، \add مَاشَا\add* شكْ وَارْ ثدْجِيذْ شَا أَمْ ؤُمْسخَّارْ إِنُو ذَاوُوذْ، ونِّي إِحْضَانْ ڒُومُورَاثْ إِنُو ذ ونِّي د أَيِي إِضْفَارنْ، حِيمَا أَذْ يڭّْ مْغِيرْ مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ إِنُو،
\v 9 ؤُ مِينْزِي ثڭِّيذْ ت ذ ثَاعفَّانْثْ مَاهُو خْ \add مِينْ ڭِّينْ\add* مَارَّا \add إِنِّي إِدْجَانْ\add* قْبڒْ إِ شكْ، ؤُشَا شكْ ثُويُورذْ ثڭِّيذْ إِربِّيثنْ نّغْنِي ذ ڒخْيَاڒَاثْ نّغْنِي إِفسْينْ، حِيمَا أَذْ أَيِي ثسْعَارذْ، ؤُشَا ثنْضَارذْ أَيِي أَوَارْنِي إِ وعْرُورْ نّشْ،
\v 10 س ؤُيَا، خْزَارْ، أَذْ أَوْيغْ ثُوعفّْنَا خْ ثَادَّارْثْ ن يَارُوبْعَامْ ؤُ أَذْ ثحِّيغْ زِي يَارُوبْعَامْ مَارَّا وِي \add ث\add* إِتّڭّنْ خْ ڒْحِيضْ، \add أَمْ\add* ونِّي إِتّْوَاطّْفنْ، \add أَمْ\add* ونِّي ؤُمِي جِّينْ ذِي إِسْرَائِيل، ؤُ نشّْ أَذْ مْحِيغْ مِينْ إِقِّيمنْ ن ثَادَّارْثْ ن يَارُوبْعَامْ، أَمْ مَامّشْ فَارْضنْ ڒغْبَارْ أَڒْ غَا إِقْضَا. \x ◘ \xo 14:‏10 \xt 1 صم. 25‏:‏22، 34؛ 1 إِج. 16‏:‏11؛ 21‏:‏21؛ 15‏:‏29؛ 2 إِج. 9‏:‏8\x*
\v 11 مَانْ ونْ زِي ثَادَّارْثْ ن يَارُوبْعَامْ إِ غَا إِمّْثنْ ذِي ثنْذِينْثْ، أَذْ ث شّنْ يِيطَانْ ؤُ وِي غَا إِمّْثنْ ذڭْ إِيَّارْ، أَذْ ث شّنْ إِجْضَاضْ ن ؤُجنَّا، مَاغَارْ سِيذِي ذ ونِّي ت إِنَّانْ.“
\m 
\v 12 ”ؤُ شمْ، كَّارْ، ؤُيُورْ غَارْ ثَادَّارْثْ نّمْ! مَاڒَا إِضَارنْ نّمْ أَذْ أَوْينْ غَارْ ثنْذِينْثْ، أَذْ إِمّثْ ؤُحنْجِيرْ.
\v 13 مَارَّا إِسْرَائِيل أَذْ خَاسْ وْثنْ أَڭجْذُورْ ؤُ نِيثْنِي أَذْ ث نضْڒنْ، مَاغَارْ نتَّا وَاهَا زِي ثَادَّارْثْ ن يَارُوبْعَامْ أَذْ إِطّفْ أَنْضڒْ، مَاغَارْ ذِي ثَادَّارْثْ ن يَارُوبْعَامْ إِتّْوَافْ ذَايسْ نتَّا \add وَاهَا\add* مِينْ إِشْنَانْ إِ سِيذِي، أَربِّي ن إِسْرَائِيل.
\v 14 سِيذِي أَذْ د-إِسّكَّارْ إِ يِيخفْ نّسْ إِجّْ ن ؤُجدْجِيذْ خْ إِسْرَائِيل نِّي إِ غَا إِثحَّانْ ثَادَّارْثْ ن يَارُوبْعَامْ، أَسّْ أَقَا ذ وَا. مِينْ ذِينْ؟ \add وَاهْ\add*، عَاذْ ڒخُّو! \x ◘ \xo 14:‏14 \xt 1 إِج. 15‏:‏28، 29\x*
\v 15 سِيذِي أَذْ إِوّثْ إِسْرَائِيل، أَذْ ث إِسّنْهزّْ سَّا ذ سَّا أَمْ ؤُغَانِيمْ ذڭْ وَامَانْ، ؤُ نتَّا أَذْ إِقْڒعْ إِسْرَائِيل زِي ثمُّورْثْ-أَ إِصبْحنْ إِ إِوْشَا إِ ڒجْذُوذْ نْسنْ ؤُ نتَّا أَذْ ثنْ يَاريّشْ خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add*، مِينْزِي نِيثْنِي ڭِّينْ إِ يِيخفْ نْسنْ ثِيربِّينْ ن شْوَارْثِي ؤُ سْعَارنْ \add زَّايْسنْثْ\add* سِيذِي. \x ◘ \xo 14:‏15 \xt 2 إِج. 17‏:‏18\x*
\v 16 نتَّا أَذْ إِسلّمْ إِسْرَائِيل ذِي سِّيبّثْ ن دّْنُوبْ إِ إِڭَّا يَارُوبْعَامْ، إِ زِي يَارَّا إِسْرَائِيل أَذْ إِخْضَا.“
\m 
\v 17 ؤُشَا ثكَّارْ ثمْغَارْثْ ن يَارُوبْعَامْ، ثطّفْ أَبْرِيذْ ؤُشَا ثِيوضْ غَارْ ثِيرْصَا. ؤُمِي د-ثُوسَا غَارْ ثْنبْذَاثْ ن ثَادَّارْثْ، إِمُّوثْ ؤُحنْجِيرْ.
\v 18 نِيثْنِي نضْڒنْ ث ؤُ مَارَّا إِسْرَائِيل إِوْثَا خَاسْ أَڭجْذُورْ، عْلَاحْسَابْ أَوَاڒْ ن سِيذِي إِ إِسِّيوڒْ س ؤُفُوسْ ن ؤُمْسخَّارْ نّسْ، أَنَابِي أَخِييَا.
\m 
\v 19 إِمزْرُوينْ إِقِّيمنْ ن يَارُوبْعَامْ، مَامّشْ إِمّْنغْ ذ مَامّشْ إِحْكمْ، خْزَارْ، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل.
\v 20 ؤُسَّانْ إِ إِحْكمْ يَارُوبْعَامْ ثُوغَا ثْنَاينْ ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا. نتَّا إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ ؤُ مِّيسْ نَاذَابْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\b
\s1 ڒْموْثْ ن رَاحُوبْعَامْ، مِّيسْ ن سُولِيمَانْ
\m 
\v 21 رَاحَابْعَامْ، مِّيسْ ن سُولِيمَانْ، ثُوغَا ذ أَجدْجِيذْ ذِي يَاهُوذَا. ثُوغَا غَارسْ وَاحِيثْ ؤُ-ربْعِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ نتَّا ذ أَجدْجِيذْ. نتَّا إِحْكمْ سْبعْطَاشْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ، ذِي ثنْذِينْثْ إِ إِخْضَارْ سِيذِي زِي جَارْ مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل، حِيمَا أَذْ ذِينْ إِسّمْثنْ إِسمْ نّسْ. يمَّاسْ قَّارنْ أَسْ نِيعْمَا، نتَّاثْ زِي \add ثمُّورْثْ\add* ن عَامُّونْ. \x ◘ \xo 14:‏21 \xt [2 إِم. 12‏:‏1‏-‏16] — 2 إِم. 12‏:‏13\x*
\v 22 يَاهُوذَا إِڭَّا \add مِينْ إِدْجَانْ\add* ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي ؤُ نِيثْنِي سْعَارنْ ث مَاهُو خْ مَارَّا مِينْ ثُوغَا ڭِّينْ ڒجْذُوذْ نْسنْ س دّْنُوبْ نْسنْ إِ زِي خْضَانْ.
\v 23 \add مَاغَارْ\add* ؤُڒَا ذ نِيثْنِي بْنَانْ ڒڭْعُوذِي إِ يِيخفْ نْسنْ ذ إِمَايْضُوثنْ \add إِقدّْسنْ\add* ذ ثِيربِّينْ ن شْوَارْثِي، ذِي مَارَّا ثِيوْرِيرِينْ يُوعْڒَانْ ؤُ سَاذُو كُوڒْ ثَاشجَّارْثْ ثَازِيزِيثْ. \f ◼ \fr 14:‏23 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*
\v 24 ثُوغَا ذِينْ ؤُڒَا ذ إِمثْليّنْ ذِي ثمُّورْثْ. نِيثْنِي ڭِّينْ مَارَّا جّْعَايفْ ن ڒڭْنُوسْ إِ ثُوغَا إِسُّوفّغْ سِيذِي زِي ڒْوَارْثْ زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل.
\m 
\v 25 ذڭْ ؤُسڭّْوَاسْ وِيسّْ خمْسَا ن ؤُجدْجِيذْ رَاحَابْعَامْ، إِمْسَارْ، أَقَا إِڭعّذْ شِيشَاكْ، أَجدْجِيذْ ن مِيصْرَا، ضِيدّْ إِ ؤُرْشَالِيمْ. \x ◘ \xo 14:‏25 \xt 2 إِم. 12‏:‏2\x*
\v 26 نتَّا إِكّسْ ڒكْنُوزْ زِي ثَادَّارْثْ ن سِيذِي ؤُ ڒكْنُوزْ زِي ثَادَّارْثْ ن ؤُجدْجِيذْ، \add إِوَا\add*، نتَّا يِيوِي مَارَّا. يِيوِي ؤُڒَا ذ مَارَّا ثِيسدَّارِييِينْ ن ؤُعسْكَارِي ن وُورغْ نِّي إِڭَّا سُولِيمَانْ. \x ◘ \xo 14:‏26 \xt 1 إِج. 10‏:‏16، 17؛ 2 إِم. 9‏:‏15\x*
\v 27 ذڭْ ومْشَانْ نْسنْثْ إِڭَّا ؤُجدْجِيذْ رَاحَابْعَامْ ثِيسدَّارِييِينْ ن ؤُعسْكَارِي إِتّْوَاڭّنْ زِي نّْحَاسْ. إِڭَّا إِ-ثنْثْ ذڭْ إِفَاسّنْ ن إِمقّْرَاننْ خْ إِرقَّاسنْ ن ثَازْڒَا نِّي ثُوغَا تّْعسَّانْ غَارْ وَاذَافْ ن ثَادَّارْثْ ن ؤُجدْجِيذْ.
\v 28 مڒْمِي مَا إِ غَا يَاذفْ ؤُجدْجِيذْ غَارْ ثَادَّارْثْ ن سِيذِي، إِمْسَارْ، أَقَا إِرقَّاسنْ ن ثَازْڒَا أَربُّونْ ثنْثْ ؤُ إِوْينْ ثنْثْ خنِّي عَاوذْ غَارْ وخَّامْ ن إِرقَّاسنْ ن ثَازْڒَا.
\v 29 إِمزْرُوينْ إِقِّيمنْ ن رَاحَابْعَامْ ذ مَارَّا مِينْ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن يَاهُوذَا؟
\v 30 ثُوغَا إِدْجَا ؤُمنْغِي جَارْ رَاحَابْعَامْ ذ يَارُوبْعَامْ مَارَّا ؤُسَّانْ نْسنْ.
\v 31 رَاحَابْعَامْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نتَّا إِتّْوَانْضڒْ جَارْ ڒجْذُوذْ نّسْ ذِي ثنْذِينْثْ ن ذَاوُوذْ. يمَّاسْ قَّارنْ أَسْ نِيعْمَا، إِشْثْ ن \add ثمْغَارْثْ\add* ثَاعَامُّونِيثْ. مِّيسْ أَبِييَامْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\b
\b
\c 15
\s1 أَبِييَامْ، أَجدْجِيذْ خْ ثمُّورْثْ ن يَاهُوذَا
\m 
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْمنْطَاشْ ن ؤُجدْجِيذْ يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، إِذْوڒْ أَبِييَامْ ذ أَجدْجِيذْ خْ يَاهُوذَا. \x ◘ \xo 15:‏1 \xt [2 إِم. 13‏:‏1‏-‏23] — 2 إِم. 13‏:‏1\x*
\v 2 نتَّا إِحْكمْ ثْڒَاثَا ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ مَاعْكَا، يدْجِيسْ ن أَبِيشَالُومْ. \x ◘ \xo 15:‏2 \xt 2 إِم. 13‏:‏2\x*
\v 3 نتَّا يُويُورْ ذِي مَارَّا دّْنُوبْ ن بَابَاسْ نِّي ثُوغَا إِڭَّا قْبڒْ نّسْ ؤُشَا ؤُڒْ نّسْ وَارْ ثُوغِي شَا إِشْضَارْ غَارْ سِيذِي، أَربِّي نّسْ، أَمْ وُوڒْ ن بَابَاسْ ذَاوُوذْ.
\v 4 مَاشَا ذِي طّْوعْ ن ذَاوُوذْ إِوْشَا أَسْ سِيذِي، أَربِّي نّسْ، إِجّْ ن ڒفْنَارْ ذِي ؤُرْشَالِيمْ ؤُمِي إِڭَّا أَذْ إِسّكَّارْ مِّيسْ أَوَارْنِي أَسْ، ؤُ ؤُمِي إِڭَّا أَذْ ثقِّيمْ ثْبدّْ ؤُرْشَالِيمْ، \x ◘ \xo 15:‏4 \xt 1 إِج. 11‏:‏36\x*
\v 5 مَاغَارْ ذَاوُوذْ ثُوغَا إِڭَّا \add مِينْ إِدْجَانْ\add* نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي ؤُ نتَّا ثُوغَا وَارْ إِحيّذْ ذِي مَارَّا ثُوذَارْثْ نّسْ خْ مَارَّا مِينْ إِ ذ أَسْ يُومُورْ نتَّا، مْغِيرْ ذِي ثْمسْڒَاشْثْ ن ؤُرِييَا، أَحِيتِّي. \x ◘ \xo 15:‏5 \xt 2 صم. 11‏:‏4، 15؛ 12‏:‏9\x*
\v 6 ثُوغَا \add ذِينْ\add* أَمنْغِي جَارْ رَاحَابْعَامْ ذ يَارُوبْعَامْ، مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّسْ.
\m 
\v 7 إِمزْرُوينْ إِقِّيمنْ ن أَبِييَامْ ذ مَارَّا مِينْ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن يَاهُوذَا؟ ثُوغَا ذِينْ عَاوذْ أَمنْغِي جَارْ أَبِييَامْ ذ يَارُوبْعَامْ.
\v 8 أَبِييَامْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نضْڒنْ ث ذِي ثنْذِينْثْ ن ذَاوُوذْ. مِّيسْ أَسَا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.\x ◘ \xo 15:‏8 \xt 2 إِم. 13‏:‏23\x*
\b
\s1 أَسَا، أَجدْجِيذْ خْ ثمُّورْثْ ن يَاهُوذَا
\m 
\v 9 ذڭْ ؤُسڭّْوَاسْ وِيسّْ عِيشْرِينْ ن يَارُوبْعَامْ، أَجدْجِيذْ ن إِسْرَائِيل، إِذْوڒْ أَسَا ذ أَجدْجِيذْ خْ يَاهُوذَا. \x ◘ \xo 15:‏9 \xt [2 إِم. 14‏:‏1‏-‏2؛ 15‏:‏16؛ 16‏:‏6، 11‏-‏14]\x*
\v 10 نتَّا إِحْكمْ وَاحِيثْ ؤُ-ربْعِينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. حنَّاسْ قَّارنْ أَسْ مَاعْكَا، يدْجِيسْ ن أَبِيشَالُومْ.
\v 11 أَسَا إِڭَّا \add مِينْ إِدْجَانْ\add* نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي، أَمْ إِڭَّا بَابَاسْ ذَاوُوذْ.
\v 12 نتَّا إِسُّوفّغْ إِمثْليّنْ زِي ثمُّورْثْ ؤُشَا إِحيّذْ مَارَّا إِميْضَا \add ن لْ-أَصْنَامْ نْسنْ\add* إِ ثُوغَا ڭِّينْ ڒجْذُوذْ نّسْ. \x ◘ \xo 15:‏12 \xt 1 إِج. 22‏:‏47\x*
\v 13 نتَّا إِسّْحيّذْ ؤُڒَا ذ حنَّاسْ مَاعْكَا زِي جّهْذْ نّسْ، مَاغَارْ نتَّاثْ ثُوغَا ثڭَّا إِجّْ ن ڒخْيَاڒْ ذ جّْعِيفشْثْ إِ ثْربِّيثْ ن شْوَارْثِي. أَسَا إِقسّْ جّْعِيفشْثْ نّسْ ؤُشَا إِسّْشمْضْ \add إِ-ت\add* غَارْ ثغْزَارْثْ ن قِيذْرُونْ. \x ◘ \xo 15:‏13 \xt 2 إِم. 15‏:‏16\x*
\v 14 وَارْ تّْوَاحيّْذنْثْ ڒڭْعُوذِي، مَاشَا ؤُڒْ ن أَسَا ثُوغَا إِشْضَارْ نِيشَانْ إِ سِيذِي، مَارَّا ؤُسَّانْ \add ن ثُوذَارْثْ\add* نّسْ.
\v 15 نتَّا يِيوِي ثِيوْهِيبِينْ إِقدّْسنْ ن بَابَاسْ ؤُڒَا ذ ثِيوْهِيبِينْ نِّي إِسّْقدّسْ نتَّا س يِيخفْ نّسْ ذِي ثَادَّارْثْ ن سِيذِي: نُّوقَارْثْ ذ وُورغْ ذ ڒقْشُوعْ \add نّغْنِي\add*. \x ◘ \xo 15:‏15 \xt لَاوِي 5‏:‏15\x*
\m 
\v 16 ثُوغَا \add ذِينْ\add* أَمنْغِي جَارْ أَسَا ذ بَاعْشَا، أَجدْجِيذْ ن إِسْرَائِيل، مَارَّا ؤُسَّانْ نْسنْ.
\v 17 بَاعْشَا، أَجدْجِيذْ ن إِسْرَائِيل، إِڭعّذْ \add غَارْ ؤُمنْغِي\add* ضِيدّْ إِ يَاهُوذَا ؤُشَا إِبْنَا رَامَا، حِيمَا وَارْ إِتّجِّي ؤُڒَا ذ إِجّْ أَذْ يُويُورْ غَارْ أَسَا، حِيمَا أَذْ \add غَارسْ\add* د-يَاسْ. \x ◘ \xo 15:‏17 \xt 2 إِم. 16‏:‏1\x*
\v 18 \add خنِّي\add* إِكْسِي أَسَا مَارَّا نُّوقَارْثْ ذ وُورغْ إِ ثُوغَا إِقِّيمنْ ذڭْ إِخَّامنْ ن ثْخُوبَايْ ن ثَادَّارْثْ ن سِيذِي ؤُڒَا ذ ثْخُوبَايْ ن ثَادَّارْثْ ن ؤُجدْجِيذْ، ؤُشَا إِسلّمْ \add مَارَّا\add* أَيَا إِ إِمْسخَّارنْ نّسْ. ؤُشَا أَجدْجِيذْ أَسَا إِسّكّْ إِ-ثنْ غَارْ بِينْهَاذَاذْ، مِّيسْ ن ثَابْرِيمُونْ، مِّيسْ ن حَازْيُونْ، أَجدْجِيذْ ن أَرَامْ، ونِّي ثُوغَا إِزدّْغنْ ذِي ذِيمَاشْقْ، حِيمَا أَذْ يِينِي: \x ◘ \xo 15:‏18 \xt 1 إِج. 20‏:‏1؛ 2 إِم. 16‏:‏2‏-‏14\x*
\v 19 ”\add أَقَا ذِينْ\add* إِجّْ ن ڒْعَاهْذْ جَارْ أَيِي ذ شكْ، جَارْ بَابَا ذ بَابَاشْ. خْزَارْ نشّْ أَذْ أَشْ د-سّكّغْ إِشْثْ ن ثرْزفْثْ ن نُّوقَارْثْ ذ وُورغْ. رُوحْ، فْسِي ڒْعَاهْذْ نّشْ أَكْ-ذ بَاعْشَا، أَجدْجِيذْ ن إِسْرَائِيل، مَاحنْذْ أَذْ إِكَّارْ أَذْ خَافِي إِڭّْوجْ.“
\v 20 بِينْهَاذَاذْ إِسْڒَا غَارْ ؤُجدْجِيذْ أَسَا ؤُشَا إِسّكّْ إِكُومَانْذَارنْ ن ڒْعسْكَارْ نّسْ غَارْ ثْندَّامْ ن إِسْرَائِيل. نتَّا إِغْڒبْ خْ عِييُونْ ذ ذَانْ ذ أَبَالْ-بَايْثْ-مَاعْكَا ذ مَارَّا كِينَّارُوثْ. \add أَقَا إِسّكّْ إِ-ثنْ\add* غَارْ مَارَّا ثَامُّورْثْ ن نَافْثَالِي.
\v 21 ؤُمِي بَاعْشَا إِسْڒَا خْ ؤُيَا، إِمْسَارْ، أَقَا نتَّا إِسّْبدّْ ذِي ڒبْنِي ن رَامَا ؤُشَا إِقِّيمْ إِزدّغْ ذِي ثِيرْصَا.
\v 22 أَجدْجِيذْ أَسَا إِجَّا أَذْ بَارّْحنْ ذِي مَارَّا يَاهُوذَا، وَارْ إِتّْغِيمِي حذْ، حِيمَا نِيثْنِي أَذْ كّْسنْ إِژْرَا زِي رَامَا ذ ؤُكشُّوضْ إِ زِي ثُوغَا إِبنَّا بَاعْشَا. ؤُ س مَانْ أَيَا إِبْنَا ؤُجدْجِيذْ أَسَا \add ثَانْذِينْثْ ن\add* جِيبْعَا ذِي بِينْيَامِينْ ذ مِيصْفَا.
\m 
\v 23 إِمزْرُوينْ إِقِّيمنْ ن أَسَا، مَارَّا ثِيمڭَّا نّسْ إِمحْضنْ ذ مَارَّا مِينْ إِڭَّا ؤُڒَا ذ ثِيندَّامْ نِّي إِبْنَا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن يَاهُوذَا؟ مَاشَا ؤُمِي إِوْسَارْ، إِهْڒشْ نتَّا زڭْ إِضَارنْ نّسْ س ثْنَاينْ.
\v 24 أَسَا إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نتَّا إِتّْوَانْضڒْ جَارْ ڒجْذُوذْ نّسْ ذِي ثنْذِينْثْ ن بَابَاسْ ذَاوُوذْ. مِّيسْ يَاهُوشَافَاطْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. \x ◘ \xo 15:‏24 \xt 2 إِم. 16‏:‏13؛ 17‏:‏1\x*
\b
\s1 نَاذَابْ، أَجدْجِيذْ خْ ثمُّورْثْ ن إِسْرَائِيل
\m 
\v 25 نَاذَابْ، مِّيسْ ن يَارُوبْعَامْ، إِذْوڒْ ذ أَجدْجِيذْ خْ إِسْرَائِيل ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ ن أَسَا، أَجدْجِيذْ ن يَاهُوذَا. نتَّا إِحْكمْ ثْنَاينْ ن إِسڭّْوُوسَا خْ إِسْرَائِيل.
\v 26 نتَّا إِڭَّا \add مِينْ إِدْجَانْ\add* ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي ؤُشَا يُويُورْ ذڭْ وبْرِيذْ ن بَابَاسْ ؤُ ذِي دّْنُوبْ نّسْ إِ زِي يَارَّا إِسْرَائِيل أَذْ إِخْضَا.
\m 
\v 27 بَاعْشَا، مِّيسْ ن أَبِييَا، زِي ثَادَّارْثْ ن إِسَّاكَارْ، إِڭَّا خَاسْ إِشْثْ ن ثْمعْمُوتْشْ ؤُ بَاعْشَا إِغْڒبْ خَاسْ ذِي جِيبَّاثُونْ نِّي \add إِدْجَانْ\add* ن إِفِيلِيسْطِينِييّنْ، ؤُمِي نَاذَابْ ذ مَارَّا إِسْرَائِيل ثُوغَا إِنّْضنْ إِ جِيبَّاثُونْ.
\v 28 إِنْغَا إِ-ث بَاعْشَا ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثَا ن أَسَا، أَجدْجِيذْ ن يَاهُوذَا، ؤُ نتَّا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\v 29 ؤُمِي إِذْوڒْ نتَّا ذ أَجدْجِيذْ، إِمْسَارْ، أَقَا إِقْضَا خْ مَارَّا ثَادَّارْثْ ن يَارُوبْعَامْ. ؤُڒَا ذ شَا ن يَارُوبْعَامْ نِّي \add يَارِّينْ\add* نّفْسْ، وَارْ ث إِجِّي أَذْ إِقِّيمْ إِدَّارْ، أَڒَامِي ث إِثحَّا عْلَاحْسَابْ أَوَاڒْ ن سِيذِي نِّي ثُوغَا إِسِّيوڒْ س ؤُقمُّومْ ن ؤُمْسخَّارْ نّسْ أَخِييَا، أَشِيلُونِي، \x ◘ \xo 15:‏29 \xt 1 إِج. 14‏:‏10، 14\x*
\v 30 ذِي سِّيبّثْ ن دّْنُوبْ ن يَارُوبْعَامْ إِ زِي إِخْضَا نتَّا ؤُ إِ زِي يَارَّا إِسْرَائِيل أَذْ إِخْضَا س ثْمڭَّا نّسْ إِخوّْجنْ إِ زِي إِسْعَارْ سِيذِي، أَربِّي ن إِسْرَائِيل.
\m 
\v 31 إِمزْرُوينْ إِقِّيمنْ ن نَاذَابْ، ذ مَارَّا مِينْ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل؟
\v 32 ثُوغَا \add ذِينْ\add* أَمنْغِي جَارْ أَسَا ذ بَاعْشَا، أَجدْجِيذْ ن إِسْرَائِيل، مَارَّا ؤُسَّانْ نْسنْ.
\b
\s1 بَاعْسَا، أَجدْجِيذْ ن إِسْرَائِيل
\m 
\v 33 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثَا ن ؤُجدْجِيذْ أَسَا، أَجدْجِيذْ ن يَاهُوذَا، إِذْوڒْ بَاعْشَا، مِّيسْ ن أَخِييَا، ذ أَجدْجِيذْ خْ مَارَّا إِسْرَائِيل ذِي ثِيرْصَا، \add ؤُ نتَّا إِحْكمْ\add* أَربْعَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا.
\v 34 نتَّا إِڭَّا \add مِينْ إِدْجَانْ\add* ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي ؤُ يُويُورْ ذڭْ وبْرِيذْ ن يَارُوبْعَامْ ؤُ ذِي دّْنُوبْ نّسْ إِ زِي يَارَّا إِسْرَائِيل أَذْ إِخْضَا.
\b
\b
\c 16
\s1 أَعْڒمْ ن ؤُجدْجِيذْ بَاعْسَا س ؤُنَابِي يَاهُو
\m 
\v 1 يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ يَاهُو، مِّيسْ ن حَانَانِي. أَوَاڒْ ثُوغَا ضِيدّْ إِ بَاعْشَا، إِنَّا:
\v 2 ”مِينْزِي نشّْ سّْڭعّْذغْ-د شكْ زِي ثْعجَّاجْثْ ؤُ ڭِّيغْ شكْ ذ ڒْحَاكمْ خْ ڒْڭنْسْ إِنُو إِسْرَائِيل، ؤُشَا شكْ ثُويُورذْ خْ وبْرِيذْ ن يَارُوبْعَامْ ؤُ ثَارِّيذْ ڒْڭنْسْ إِنُو إِسْرَائِيل أَذْ إِخْضَا ؤُمِي إِ ذ أَيِي ثسْعَارذْ س دّْنُوبْ نْسنْ، \x ◘ \xo 16:‏2 \xt 1 إِج. 14‏:‏7\x*
\v 3 خْزَارْ، \add س ؤُيَا\add* أَذْ مْحِيغْ مِينْ إِقِّيمنْ ن بَاعْشَا ذ مِينْ إِقِّيمنْ ن ثَادَّارْثْ نّسْ، ؤُ نشّْ أَذْ ڭّغْ ثَادَّارْثْ نّشْ أَمْ ثَادَّارْثْ ن يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ. \x ◘ \xo 16:‏3 \xt 1 إِج. 15‏:‏29\x*
\v 4 مَانْ ونْ زِي ثَادَّارْثْ ن بَاعْشَا إِ غَا إِمّْثنْ ذِي ثنْذِينْثْ، أَذْ ث شّنْ يِيطَانْ ؤُ مَانْ ونْ زَّايسْ إِ غَا إِمُّوثنْ ذڭْ إِيَّارْ، أَذْ ث شّنْ يِيجْضَاضْ ن ؤُجنَّا.“ \x ◘ \xo 16:‏4 \xt 1 إِج. 14‏:‏11؛ 15‏:‏29؛ 16‏:‏12\x*
\m 
\v 5 إِمزْرُوينْ إِقِّيمنْ ن بَاعْشَا، ذ مَارَّا مِينْ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل؟
\v 6 بَاعْشَا إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ ؤُ نتَّا إِتّْوَانْضڒْ ذِي ثِيرْصَا. مِّيسْ إِلَا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\v 7 أَمُّو د-يُوسَا وَاوَاڒْ ن سِيذِي س ؤُفُوسْ ن ؤُنَابِي يَاهُو، مِّيسْ ن حَانَانِي، ؤُڒَا خْ بَاعْشَا ذ ثَادَّارْثْ نّسْ زِي سِّيبّثْ ن مَارَّا ثَاعفَّانْثْ إِ إِڭَّا ذِي ثِيطَّاوِينْ ن سِيذِي، ؤُمِي ث إِسْعَارْ س ڒخْذَايمْ ن إِفَاسّنْ نّسْ ؤُ ؤُمِي إِذْوڒْ أَمْ ثَادَّارْثْ ن يَارُوبْعَامْ، ؤُشَا ؤُڒَا مِينْزِي نتَّا ثُوغَا إِقْضَا وَانِيثَا.
\b
\s1 إِيْلَا، أَجدْجِيذْ ن إِسْرَائِيل
\m 
\v 8 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ستَّا ؤُ-عِيشْرِينْ ن أَسَا، أَجدْجِيذْ ن يَاهُوذَا، إِذْوڒْ إِلَا، مِّيسْ ن بَاعْشَا، ذ أَجدْجِيذْ خْ إِسْرَائِيل ذِي ثِيرْصَا، \add إِ إِجّْ ن ڒْمِيجَاڒْ ن\add* ثْنَاينْ ن إِسڭّْوُوسَا.
\v 9 زِيمْرِي، أَمْسخَّارْ نّسْ، ونِّي ذ أَكُومَانْذَارْ خْ إِجّْ ن وزْينْ ن إِكَارُّوثنْ \add ن ؤُمنْغِي\add*، إِڭَّا خَاسْ إِشْثْ ن ثْمعْمُوتْشْ ؤُمِي ث ثُوغَا ذِي ثِيرْصَا، ثُوغَا إِسْشَارْ ذِي ثَادَّارْثْ ن أَرْصَا، ونِّي ثُوغَا ذ أَمحْضَايْ خْ ثَادَّارْثْ ذِي ثِيرْصَا.
\v 10 زِيمْرِي يُوذفْ، إِوْثَا إِ-ث ؤُشَا إِنْغَا إِ-ث ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا ؤُ-عِيشْرِينْ ن أَسَا، أَجدْجِيذْ ن يَاهُوذَا. نتَّا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. \x ◘ \xo 16:‏10 \xt 2 إِج. 9‏:‏31\x*
\v 11 ڒَامِي إِذْوڒْ ذ أَجدْجِيذْ ؤُشَا إِنْيَا خْ ڒْعَارْشْ نّسْ، إِمْسَارْ، أَقَا إِقْضَا خْ مَارَّا ثَادَّارْثْ ن بَاعْشَا. نتَّا وَارْ إِجِّي ؤُڒَا ذ إِجّْ ونِّي ث إِڭِّينْ خْ ڒْحِيضْ \add أَذْ إِدَّارْ\add*، ؤُ \add وَارْ إِجِّي ؤُڒَا ذ إِجّْ\add* ونِّي \add إِزمَّارنْ\add* أَذْ أَسْ إِنْثَاقمْ ؤُ \add ؤُڒَا ذ إِجّْ\add* زڭْ إِمدُّوكَّاڒْ نّسْ.
\v 12 \add أَمُّو\add* إِ إِثحَّا زِيمْرِي مَارَّا ثَادَّارْثْ ن بَاعْشَا عْلَاحْسَابْ أَوَاڒْ ن سِيذِي نِّي إِسِّيوڒْ بَاعْشَا س ؤُفُوسْ ن ؤُنَابِي يَاهُو،
\v 13 ذِي سِّيبّثْ ن مَارَّا دّْنُوبْ ن بَاعْشَا ذ دّْنُوبْ ن مِّيسْ إِلَا إِ زِي خْضَانْ نِيثْنِي ؤُ إِ زِي أَرِّينْ إِسْرَائِيل أَذْ إِخْضَا أَمْ سْعَارنْ سِيذِي، أَربِّي ن إِسْرَائِيل، س \add لْ-أَصْنَامْ\add* نْسنْ إِبطّْڒنْ.
\m 
\v 14 إِمزْرُوينْ إِقِّيمنْ ن إِلَا، ذ مَارَّا مِينْ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل؟
\b
\s1 زِيمْرِي، أَجدْجِيذْ ن إِسْرَائِيل
\m 
\v 15 ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا ؤُ-عِيشْرِينْ ن أَسَا، أَجدْجِيذْ ن يَاهُوذَا، ثُوغَا زِيمْرِي سبْعَا ن وُوسَّانْ ذ أَجدْجِيذْ ذِي ثِيرْصَا. ڒْڭنْسْ ثُوغَا إِحصَّارْ إِ جِيبَّاثُونْ نِّي \add إِدْجَانْ\add* ن إِفِيلِيسْطِينِييّنْ.
\v 16 ڒْڭنْسْ إِ ثُوغَا إِوْثِينْ إِقِيضَانْ نّسْ \add ذِينْ\add*، إِسْڒَا أَقَا قَّارنْ: ”زِيمْرِي ثُوغَا إِڭَّا ذ إِشْثْ ن ثْمعْمُوتْشْ ؤُشَا إِنْغَا أَجدْجِيذْ.“ ذڭْ وَاسّْ نِّي مَارَّا ڒْڭنْسْ يَارَّا عُومْرِي، ونِّي ذ أَكُومَانْذَارْ خْ ڒْعسْكَارْ، ذ أَجدْجِيذْ خْ إِسْرَائِيل ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ.
\v 17 عُومْرِي إِڭعّذْ-د زِي جِيبَّاثُونْ ذ مَارَّا إِسْرَائِيل أَكِيذسْ ؤُشَا نّْضنْ أَسْ-د إِ ثِيرْصَا.
\v 18 ؤُمِي إِژْرَا زِيمْرِي أَقَا ثَانْذِينْثْ ثُوغَا ثتّْوَاطّفْ، يُوذفْ غَارْ لْقلْعَا ن ثَادَّارْثْ ن ؤُجدْجِيذْ، إِقدّْ ثِيوَا نّسْ ثِيمسِّي إِ ثَادَّارْثْ ن ؤُجدْجِيذْ، أَڒَامِي إِمُّوثْ
\v 19 ذِي سِّيبّثْ ن دّْنُوبْ نّسْ إِ ثُوغَا إِڭَّا، ؤُمِي إِڭَّا \add مِينْ إِدْجَانْ\add* ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، ؤُمِي يُويُورْ ذڭْ وبْرِيذْ ن يَارُوبْعَامْ ؤُڒَا ذِي سِّيبّثْ ن دّْنُوبْ إِ إِڭَّا أَمْ ذ يَارَّا إِسْرَائِيل أَذْ إِخْضَا.
\m 
\v 20 إِمزْرُوينْ إِقِّيمنْ ن زِيمْرِي، ذ ثَامعْمُوتْشْ إِ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل؟
\b
\s1 عُومْرِي، أَجدْجِيذْ ن إِسْرَائِيل
\m 
\v 21 خنِّي إِتّْوَامّْسبْضَا ڒْڭنْسْ ن إِسْرَائِيل خْ ثْنَاينْ ن إِزِييْنَاثْ. إِجّْ ن وزْينْ ن ڒْڭنْسْ \add إِبدّْ\add* أَوَارْنِي إِ ثِيبْنِي، مِّيسْ ن جِينَاثْ، مَاحنْذْ أَذْ ث ڭّنْ ذ أَجدْجِيذْ، ؤُ إِجّْ ن وزْينْ \add نّغْنِي\add* \add إِبدّْ\add* أَوَارْنِي إِ عُومْرِي.
\v 22 ڒْڭنْسْ نِّي \add إِبدّنْ\add* أَوَارْنِي إِ عُومْرِي، ثُوغَا إِجْهذْ خْ ڒْڭنْسْ نِّي \add إِبدّنْ\add* أَوَارْنِي إِ ثِيبْنِي، مِّيسْ ن جِينَاثْ. \add خنِّي\add* إِمُّوثْ ثِيبْنِي ؤُ عُومْرِي إِذْوڒْ ذ أَجدْجِيذْ.
\m 
\v 23 ذڭْ ؤُسڭّْوَاسْ وِيسّْ وَاحِيثْ ؤُ-ثْڒَاثِينْ ن أَسَا، أَجدْجِيذْ ن يَاهُوذَا، إِذْوڒْ عُومْرِي ذ أَجدْجِيذْ خْ إِسْرَائِيل. \add نتَّا إِحْكمْ\add* ثنْعَاشْ ن إِسڭّْوُوسَا. ذِي ثِيرْصَا إِحْكمْ ستَّا ن إِسڭّْوُوسَا.
\v 24 إِسْغَا أَذْرَارْ ن سَامَارْيَا زِي شَامِيرْ س ثْنَاينْ ثَالِينْثْ ن نُّوقَارْثْ، ؤُ نتَّا \add إِبْذَا\add* أَذْ إِبْنَا \add خْ\add* وذْرَارْ ن سَامَارْيَا. إِڒَاغَا أَسْ إِ ثنْذِينْثْ إِ إِبْنَا ’سَامَارْيَا‘، عْلَاحْسَابْ إِسمْ ن شَامِيرْ، بَابْ ن وذْرَارْ.
\v 25 عُومْرِي إِڭَّا \add مِينْ إِدْجَانْ\add* ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي. نتَّا ثُوغَا إِڭَّا \add مِينْ إِدْجَانْ ذ أَعفَّانْ\add* مَاهُو خْ مَارَّا إِنِّي ثُوغَا ذ أَسْ إِزْوَارنْ.
\v 26 نتَّا يُويُورْ ذِي كُوڒْ ثَابْرِيذْثْ ن يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، ؤُ ذِي دّْنُوبْ نّسْ إِ زِي يَارَّا إِسْرَائِيل أَذْ إِخْضَا، ؤُمِي سْعَارنْ نِيثْنِي سِيذِي، أَربِّي ن إِسْرَائِيل، س \add لْ-أَصْنَامْ\add* نْسنْ إِبطّْڒنْ.
\m 
\v 27 إِمزْرُوينْ إِقِّيمنْ ن عُومْرِي ذ مِينْ إِڭَّا ذ صُّولْطَا نّسْ إِ زِي إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل؟
\v 28 عُومْرِي إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نتَّا إِتّْوَانْضڒْ ذِي سَامَارْيَا. مِّيسْ أَخَابْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\b
\s1 أَخَابْ، أَجدْجِيذْ ن إِسْرَائِيل، أَكْ-ذ ثمْغَارْثْ نّسْ إِزَابِيلْ
\m 
\v 29 أَخَابْ، مِّيسْ ن عُومْرِي، إِذْوڒْ ذ أَجدْجِيذْ خْ إِسْرَائِيل ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْمنْيَا ؤُ-ثْڒَاثِينْ ن أَسَا، أَجدْجِيذْ ن يَاهُوذَا. أَخَابْ مِّيسْ ن عُومْرِي، إِحْكمْ ثْنَاينْ ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا خْ إِسْرَائِيل ذِي سَامَارْيَا.
\v 30 أَخَابْ، مِّيسْ ن عُومْرِي، إِڭَّا \add مِينْ إِدْجَانْ\add* ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، مَاهُو خْ مَارَّا إِنِّي ثُوغَا زَّايسْ إِزْوَارنْ.
\v 31 ثُوغَا ثُويُورْثْ نّسْ ذِي دّْنُوبْ ن يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، ذْرُوسْ وَاهَا، \add مَاغَارْ\add* نتَّا يِيوِي إِزَابَالْ، يدْجِيسْ ن إِثْ-بَاعَالْ، أَجدْجِيذْ ن إِصِيذُونِييّنْ، ذ ثَامْغَارْثْ، ؤُشَا يُويُورْ أَذْ إِعْبذْ إِ بَاعْلْ، إِسْجذْ أَسْ.
\v 32 نتَّا إِسّْبدّْ إِجّْ ن ؤُعَالْطَارْ إِ بَاعْلْ ذِي زَّاوشْثْ ن بَاعْلْ نِّي إِبْنَا نتَّا ذِي سَامَارْيَا.
\v 33 نتَّا إِڭَّا عَاوذْ إِشْثْ ن ثْربِّيثْ ن شْوَارْثِي. أَخَابْ إِعْذُو س وسْعَارْ نّسْ إِ سِيذِي، أَربِّي ن إِسْرَائِيل، خْ مَارَّا إِجدْجِيذنْ نِّي ثُوغَا إِ ذ أَسْ إِزْوَارنْ.
\m 
\v 34 ذڭْ وُوسَّانْ نّسْ إِبْنَا حِييِيلْ، زِي بَايْثْ-إِلْ، \add ثَانْذِينْثْ ن\add* أَرِيحَا. إِسَّارْسْ ذْسَاسْ نّسْ ذِي سُّومْ ن مِّيسْ أَمنْزُو أَبِيرَامْ ؤُ ذِي سُّومْ ن مِّيسْ أَمَاژُوژْ سَاجُوبْ يَاركّبْ ثِيوُّورَا نّسْ عْلَاحْسَابْ أَوَاڒْ ن سِيذِي إِ إِسِّيوڒْ س \add ؤُقمُّومْ\add* ن يَاشُووَا، مِّيسْ ن نُونْ. \x ◘ \xo 16:‏34 \xt ياش. 6‏:‏26\x*
\b
\b
\c 17
\s1 أَنَابِي إِلِييَا غَارْ يغْزَارْ ن كْرِيثْ
\m 
\v 1 إِلِييَا، زِي ثِيشْبِي، زڭْ إِمعْزَابْ ن جِيلْعَاذْ، إِنَّا إِ أَخَابْ: ”س ثِيذتّْ أَمْ إِدَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل، ونِّي ؤُمِي بدّغْ زَّاثْ إِ وُوذمْ نّسْ، مَاڒَا أَذْ د-يَاسْ نّْذَا نِيغْ أَنْژَارْ ذڭْ إِسڭّْوُوسَا-يَا، \add أَذْ يِيڒِي\add* أَيَا مْغِيرْ س وَاوَاڒْ إِنُو!“ \f ◼ \fr 17:‏1 \ft \bd ’أَثِيشْبِي‘\bd* - إِجّْ ن ورْيَازْ زِي ثِيشْبِي زِي جّْوَايهْ ن جِيلْعَاذْ.\f*  \x ◘ \xo 17:‏1 \xt يَاع. 5‏:‏17\x*
\v 2 يُوسَا-د غَارسْ وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 3 ”ؤُيُورْ سّنِّي، أَرّْ \add س ؤُزدْجِيفْ\add* غَارْ شَّارْقْ ؤُشَا سْنُوفَّارْ إِخفْ نّشْ غَارْ ثِيغْزَارْثْ ن كْرِيثْ ونِّي \add إِدْجَانْ\add* غَارْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ. \f ◼ \fr 17:‏3 \ft \bd ’زَّاثْ ن ...‘\bd* - س ثْعِيبْرَانِيثْ ’زَّاثْ إِ وُوذمْ ن ...‘ ؤُڒَا ذِي أَيثْ 5.\f*
\v 4 أَذْ إِمْسَارْ أَذْ ثسْوذْ زِي ثغْزَارْثْ ؤُ نشّْ ؤُمُورغْ إِ إِبَاغْڒِيونْ، أَقَا أَذْ شكْ ذِينِّي سّشّنْ.“
\v 5 نتَّا يُويُورْ \add ذڭْ وبْرِيذْ\add* ؤُشَا إِڭَّا عْلَاحْسَابْ أَوَاڒْ ن سِيذِي. نتَّا يُويُورْ أَذْ إِزْذغْ غَارْ ثغْزَارْثْ ن كْرِيثْ نِّي \add إِدْجَانْ\add* غَارْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ.
\v 6 إِبَاغْڒِيونْ إِوْينْ أَسْ-د أَغْرُومْ ذ ويْسُومْ غَارْ ثُوفُّوثْ ؤُڒَا ذ أَغْرُومْ ذ ويْسُومْ غَارْ ثَامذِّيثْ ؤُ نتَّا إِسْوَا زِي ثغْزَارْثْ.
\b
\s1 إِلِييَا ذ ثَاجَّاتْشْ ن صَارْفَاثْ
\m 
\v 7 أَوَارْنِي وَاطَّاسْ ن وُوسَّانْ، إِمْسَارْ، أَقَا يُوژغْ ثِيغْزَارْثْ، مَاغَارْ وَارْ إِوْثِي شَا ونْژَارْ ذِي ثمُّورْثْ.
\v 8 يُوسَا أَسْ-د وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 9 ”كَّارْ، ؤُيُورْ غَارْ صَارْفَاثْ نِّي \add إِدْجَانْ\add* غَارْ صِيذُونْ، زْذغْ ذِينِّي. خْزَارْ، نشّْ ؤُمُورغْ ذِينِّي إِ يِيشْثْ ن ثَاجَّاتْشْ، مَاحنْذْ أَذْ شكْ ثسّشّْ.“ \x ◘ \xo 17:‏9 \xt لك. 4‏:‏25، 26\x*
\v 10 نتَّا إِكَّارْ، يُويُورْ غَارْ صَارْفَاثْ. \add ؤُمِي\add* د-يُوسَا غَارْ ثوَّارْثْ ن ثنْذِينْثْ، خْزَارْ، إِشْثْ ن ثَاجَّاتْشْ ثتّْحَارْوَاشْ أَكشُّوضْ. نتَّا إِڒَاغَا خَاسْ، إِنَّا: ”أَوِي أَيِي-د شَا ن وَامَانْ ذڭْ ؤُغَارَّافْ-أَ، \add حِيمَا\add* أَذْ سْوغْ.“
\v 11 \add ؤُمِي\add* ثُويُورْ نتَّاثْ حِيمَا أَذْ د-ثَاوِي أَيَا، إِڒَاغَا-د نتَّا خَاسْ: ”أَوِي أَيِي-د ؤُڒَا ذ إِجّْ ن ؤُڒقِّيمْ ن وغْرُومْ ذڭْ ؤُفُوسْ نّمْ.
\v 12 \add مَاشَا\add* نتَّاثْ ثنَّا: ”س ثِيذتّْ أَمْ إِدَّارْ سِيذِي، أَربِّي نّشْ، مِينْ غَارِي ذ ثَافْذِيڒْثْ، أَقَا مْغِيرْ إِشْثْ ن وُورُو ن وَارنْ ذڭْ ؤُبُوقَاڒْ ذ شَا ن زّشْثْ ذڭْ ؤُغَارَّافْ! خْزَارْ نشّْ حَارْوْشغْ ثْنَاينْ ن إِكشُّوضنْ ؤُ أَذْ ث سّْوجْذغْ إِ نشّْ ذ مِّي، خنِّي أَذْ ث نشّْ أَذْ نمّثْ.“
\v 13 إِنَّا أَسْ إِلِييَا: ”وَارْ تّڭّْوذْ شَا. ؤُيُورْ، أڭّْ مِينْ ثُوغَا ثنِّيذْ، مَاشَا أڭّْ أَيِي-د ذ أَمزْوَارُو إِشْثْ ن ثفْضِيڒْثْ ؤُ أَوِي ت-إِ-د ذَا غَارِي. أَوَارْنِي ؤُيَا أَذْ ثسّوْجذْ \add شَا\add* إِ شمْ ؤُ إِ إِخفْ نّمْ ذ مِّيمْ.
\v 14 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’أَرنْ ذڭْ ؤُبُوقَاڒْ وَارْ إِخكّْوِي ؤُ زّشْثْ ذڭْ ؤُغَارَّافْ وَارْ ثْنقِّيصْ أَڒْ أَسّْ إِ ذِي إِ غَا إِوْشْ سِيذِي أَنْژَارْ خْ وُوذمْ ن ثمُّورْثْ.‘ “
\v 15 نتَّاثْ ثُويُورْ ؤُشَا ثڭَّا عْلَاحْصَابْ أَوَاڒْ ن إِلِييَا. \add أَمُّو\add* إِ إِشَّا نتَّاثْ، ؤُشَا \add ؤُڒَا\add* ذ نتَّاثْ ذ ثَادَّارْثْ نّسْ، أَطَّاسْ ن وُوسَّانْ.
\v 16 أَرنْ ذڭْ ؤُبُوقَاڒْ وَارْ إِخكّْوِي ذ زّشْثْ ذڭْ ؤُغَارَّافْ وَارْ ثْنقِّيصْ عْلَاحْسَابْ أَوَاڒْ ن سِيذِي إِ إِسِّيوڒْ س ؤُقمُّومْ ن إِلِييَا.
\m 
\v 17 أَوَارْنِي مَانْ أَيَا، إِمْسَارْ، أَقَا إِهْڒشْ مِّيسْ ن ثمْغَارْثْ-أَ، مِّيسْ ن لَّالَا ن ثَادَّارْثْ. ڒهْڒَاشْ نّسْ يَارْنِي أَطَّاسْ أَڒَامِي وَارْ إِتَّارِي عَاذْ نّفْسْ.
\v 18 نتَّاثْ ثنَّا إِ إِلِييَا: ”مِينْ ذِينْ جَارْ أَيِي ذ شكْ، \add أَ\add* شكْ، أَرْيَازْ ن أَربِّي؟ مَا ثُوسِيذْ-د غَارِي حِيمَا أَذْ أَيِي ثسّْعقْڒذْ خْ دّْنُوبْ إِنُو ؤُ حِيمَا أَذْ ثنْغذْ مِّي؟“
\v 19 نتَّا يَارَّا-د خَاسْ: ”أوْشْ أَيِي-د مِّيمْ!“ ؤُ نتَّا إِكْسِي ث زڭْ وحْسِينْ نّسْ، يَارْبُو ث غَارْ سنّجْ غَارْ وخَّامْ ن نّجْ مَانِي ثُوغَا إِزْذغْ نتَّا سِيمَانْثْ نّسْ، ؤُشَا إِسَّارْسْ إِ-ث خْ قَامَا نّسْ.
\v 20 \add خنِّي\add* إِڒَاغَا غَارْ سِيذِي، إِنَّا: ”سِيذِي، أَربِّي إِنُو، مَا ثڭِّيذْ خنِّي عَاذْ ثُوعفّْنَا ذِي ثَاجَّاتْشْ-أَ إِ غَارْ زدّْغغْ نشّْ \add أَمْ ؤُبَارَّانِي\add*، أَڒَامِي ثنْغِيذْ مِّيسْ؟“
\v 21 نتَّا إِسَارّحْ إِخفْ نّسْ ثْڒَاثَا ن ثْوَاڒَاوِينْ ثِيوَا إِ ؤُحنْجِيرْ ؤُ إِڒَاغَا غَارْ سِيذِي، إِنَّا: ”سِيذِي، أَربِّي إِنُو، أجّْ أَذْ غَارسْ د-يعْقبْ ڒعْمَارْ ن ؤُحنْجِيرْ-أَ!“
\v 22 سِيذِي إِسْڒَا إِ ثْمِيجَّا ن إِلِييَا ؤُشَا إِعْقبْ-د ڒعْمَارْ ن ؤُحنْجِيرْ عَاوذْ غَارسْ \add أَڒَامِي\add* د-إِذْوڒْ إِدَّارْ.
\v 23 إِلِييَا إِكْسِي أَحنْجِيرْ ؤُشَا إِسّهْوَا ث زڭْ وخَّامْ ن نّجْ ذِي ثَادَّارْثْ ؤُشَا إِوْشَا أَسْ ث إِ يمَّاسْ. إِنَّا إِلِييَا: ”خْزَارْ، مِّيمْ إِدَّارْ!“
\v 24 ثنَّا ثمْغَارْثْ إِ إِلِييَا: ”ڒخُّو سّْنغْ أَقَا شكْ ذ إِجّْ ن ورْيَازْ ن أَربِّي ؤُ أَقَا أَوَاڒْ ن سِيذِي ذڭْ ؤُقمُّومْ نّشْ ذ ثِيذتّْ.“
\b
\b
\c 18
\s1 إِلِييَا ذ إِنَابِييّنْ ن بَاعَالْ خْ وذْرَارْ ن كَارْمِيلْ
\m 
\v 1 أَوَارْنِي وَاطَّاسْ ن وُوسَّانْ، إِمْسَارْ، أَقَا يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ إِلِييَا ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثَا، إِنَّا: ”ؤُيُورْ، سْشنْ إِخفْ نّشْ إِ أَخَابْ، \add مَاغَارْ\add* نشّْ أَذْ وْشغْ أَنْژَارْ ذِي ثمُّورْثْ.“
\v 2 ؤُشَا يُويُورْ إِلِييَا حِيمَا أَذْ إِسّْشنْ إِخفْ نّسْ إِ أَخَابْ. ثُوغَا ڒَاژْ إِمْغَارْ ذِي سَامَارْيَا.
\v 3 أَخَابْ ثُوغَا إِڒَاغَا إِ عُوبَاذْيَا ونِّي \add إِدْجَانْ\add* خْ ثَادَّارْثْ \add ن ؤُجدْجِيذْ\add*. عُوبَاذْيَا ثُوغَا إِتّڭّْوذْ سِيذِي أَطَّاسْ.
\v 4 ؤُمِي إِزَابَالْ إِقْضَا إِنَابِييّنْ ن سِيذِي، إِمْسَارْ، أَقَا عُوبَاذْيَا يِيوِي مْيَا ن إِنَابِييّنْ، إِسّْنُوفَّارْ إِ-ثنْ، خمْسِينْ خمْسِينْ ذڭْ إِجّْ ن يفْرِي، ؤُ إِعْثقْ إِ-ثنْ س وغْرُومْ ذ وَامَانْ.
\v 5 أَخَابْ إِنَّا إِ عُوبَاذْيَا: ”ؤُيُورْ ذِي ثمُّورْثْ غَارْ مَارَّا ثَاڒَاوِينْ ن وَامَانْ ؤُ غَارْ مَارَّا ثِيغزْرَاثِينْ. أَذْ ثَاغْ أَذْ نَافْ أَهدُّو ؤُ \add زمَّارنْ\add* إِيْسَانْ ذ إِسَارْذَانْ أَذْ قِّيمنْ دَّارنْ ؤُ أَذْ ثَافْ نْهْڒَا مَا ننْغَا ڒْمَاڒْ.“
\v 6 نِيثْنِي بْضَانْ ثَامُّورْثْ جَارْ أَسنْ حِيمَا أَذْ ت شُوقنْ. أَخَابْ يُويُورْ خْ إِجّْ ن وبْرِيذْ، نتَّا وحّْذسْ، ؤُ عُوبَاذْيَا يُويُورْ خْ إِجّْ وبْرِيذْ نّغْنِي، \add ؤُڒَا ذ نتَّا\add* وحّْذسْ.
\m 
\v 7 \add ؤُمِي\add* ثُوغَا عُوبَاذْيَا ذڭْ وبْرِيذْ، خْزَارْ، أَقَا إِمّڒْقَا أَكِيذسْ إِلِييَا. عُوبَاذْيَا إِعْقڒْ إِ-ث، إِوْضَا زَّاثسْ س ؤُغمْبُوبْ نّسْ \add غَارْ ثمُّورْثْ\add*، إِنَّا: ”مَا ذ شكْ، سِيذِي إِنُو إِلِييَا؟“
\v 8 إِنَّا أَسْ وَانِيثَا: ”ذ نشّْ. ؤُيُورْ، إِنَّا إِ سِيذِي نّشْ: ’خْژَارْ، إِلِييَا \add أَقَا-ث ذَانِيثَا\add*!‘ “
\v 9 \add مَاشَا\add* نتَّا إِنَّا: ”مَانْ دّنْبْ إِ \add ڭِّيغْ\add*، أَقَا شكْ أَذْ أَيِي ثْسلّْمذْ ذڭْ إِفَاسّنْ ن أَخَابْ، حِيمَا أَذْ أَيِي إِنغْ؟
\v 10 س ثِيذتّْ أَمْ إِدَّارْ سِيذِي، أَربِّي نّشْ، وَارْ ذِينْ ؤُڒَا ذ إِجّْ ن ڒْڭنْسْ نِيغْ إِشْثْ ن ثْڭلْذِيثْ مَانِي سِيذِي إِنُو وَارْ إِجِّي أَذْ خَاكْ يَارْزُو! \add مَاڒَا\add* نَّانْ نِيثْنِي: ’نتَّا وَارْ ذَا إِدْجِي!‘، \add خنِّي\add* إِجَّا ڒْڭنْسْ نِّي أَذْ إِجَّادْجْ بلِّي وَارْ زمَّارنْ أَذْ شكْ أَفنْ.
\v 11 ؤُ ڒخُّو شكْ ثنِّيذْ: ’ؤُيُورْ، إِنِي إِ سِيذِي نّشْ: خْزَارْ إِلِييَا \add أَقَا-ث ذَانِيثَا\add*!‘
\v 12 \add أَذْ ثَاغْ\add* أَذْ إِمْسَارْ، \add خْمِي\add* إِ خَاكْ غَا ؤُيُورغْ، أَقَا أَرُّوحْ ن سِيذِي أَذْ شكْ إِكْسِي، وَارْ سِّينغْ مَانِي. مَاڒَا خنِّي نشّْ أَذْ د-أَسغْ، حِيمَا أَذْ \add ث\add* إِنِيغْ إِ أَخَابْ ؤُ نتَّا وَارْ شكْ إِتِّيفْ، نتَّا أَذْ أَيِي إِنغْ، وَاخَّا أَمْسخَّارْ نّشْ إِتّڭّْوذْ سِيذِي زِي ثمْژِي إِنُو.
\v 13 مَا وَارْ ذ أَشْ عِيوْذنْ شَا إِ سِيذِي إِنُو، مِينْ ڭِّيغْ نشّْ، ؤُمِي إِزَابَالْ إِنْغَا إِنَابِييّنْ ن سِيذِي؟ أَقَا نشّْ سّْنُوفَّارغْ مْيَا ن يرْيَازنْ زڭْ إِنَابِييّنْ، كُوڒْ خمْسِينْ ذڭْ إِجّْ ن يفْرِي؟ ؤُڒَا أَقَا نشّْعثْقغْ ثنْ س وغْرُومْ ذ وَامَانْ؟
\v 14 ؤُ ڒخُّو ثقَّارذْ ’ؤُيُورْ، إِنِي إِ سِيذِي نّشْ: خْزَارْ، إِلِييَا \add أَقَا-ث ذَا\add*!‘ نتَّا أَذْ أَيِي إِنغْ.“
\v 15 إِنَّا إِلِييَا: ”س ثِيذتّْ أَمْ إِدَّارْ سِيذِي ن ڒْعسْكَارَاثْ زَّاثْ إِ وُوذمْ نّسْ ؤُمِي بدّغْ، أَقَا نِيشَانْ نشّْ أَذْ سشّْنغْ إِخفْ إِنُو أَسّْ-أَ!“
\m 
\v 16 \add خنِّي\add* يُويُورْ عُوبَاذْيَا غَارْ ؤُمْسَاڭَارْ أَكْ-ذ أَخَابْ، إِخبَّارْ أَسْ \add ث\add*. ؤُشَا أَخَابْ يُويُورْ، مَاحنْذْ أَذْ إِمْسَاڭَارْ أَكْ-ذ إِلِييَا.
\v 17 ؤُمِي إِژْرَا أَخَابْ إِلِييَا، إِمْسَارْ، أَقَا أَخَابْ إِنَّا أَسْ: ”مَا شكْ ذ أَضيّعْ ن إِسْرَائِيل؟“ \x ◘ \xo 18:‏17 \xt عَام. 7‏:‏10\x*
\v 18 نتَّا إِنَّا: ”نشّْ وَارْ ضِييّْعغْ شَا إِسْرَائِيل، مَاشَا شكْ ذ ثَادَّارْثْ ن بَابَاشْ ؤُمِي كنِّيوْ ثجِّيمْ ڒُومُورَاثْ ن سِيذِي \add غَارْ ؤُغزْذِيسْ\add* ؤُ شكْ ثُويُورذْ أَوَارْنِي إِ ’إِبَاعْلنْ‘.
\v 19 خنِّي ڒخُّو، سْمُونْ مَارَّا إِسْرَائِيل غَارِي غَارْ وذْرَارْ ن كَارْمِيلْ ؤُڒَا ذ أَربْعَا-مْيَا ؤُ-خمْسِينْ ن إِنَابِييّنْ ن بَاعْلْ ذ أَربْعَا-مْيَا ن إِنَابِييّنْ ن ثْربِّيثْ ن شْوَارْثِي نِّي إِتّتّنْ زِي طَّابْڒَا ن إِزَابَالْ.“
\m 
\v 20 أَخَابْ إِسّكّْ \add إِجّْ ن ؤُرقَّاسْ\add* غَارْ مَارَّا أَيْثْ ن إِسْرَائِيل ؤُ إِسّْمُونْ إِنَابِييّنْ غَارْ وذْرَارْ ن كَارْمِيلْ.
\v 21 إِلِييَا إِقَارّبْ-د غَارْ مَارَّا ڒْڭنْسْ، إِنَّا: ”مشْحَاڒْ عَاذْ إِ غَا ثكّمْ عَاذْ تّْنقْڒَابمْ كنِّيوْ غَارْ ثْنَاينْ ن إِغزْذِيسنْ؟ مَاڒَا سِيذِي ذ أَربِّي، ضْفَارمْ أَسْ-د، ؤُ مَاڒَا ذ بَاعْلْ، \add خنِّي\add* ضْفَارمْ وَانِيثَا!“ مَاشَا ڒْڭنْسْ وَارْ خَاسْ د-يَارِّي ؤُڒَا س يِيجّْ ن وَاوَاڒْ. \x ◘ \xo 18:‏21 \xt ياش. 24‏:‏15\x*
\v 22 \add خنِّي\add* إِنَّا إِلِييَا إِ ڒْڭنْسْ: ”نشّْ وَاهَا إِ إِقِّيمنْ ذ أَنَابِي ن سِيذِي ؤُشَا إِنَابِييّنْ ن بَاعْلْ أَقَا أَثنْ س أَربْعَا-مْيَا ؤُ خمْسِينْ ن يرْيَازنْ.
\v 23 أجّْ أَذْ أَنغْ وْشنْ ثْنَاينْ ن إِفُونَاسنْ. أجّْ إِ-ثنْ \add خنِّي\add* أَذْ فَارْزنْ أَفُونَاسْ أَمژْيَانْ أَمزْوَارُو إِ يِيخفْ نْسنْ، أَذْ ث بْضَانْ ؤُ أَذْ ث سَّارْسنْ خْ ؤُكشُّوضْ، \add مَاشَا\add* وَارْ تّڭّنْ ثِيمسِّي \add سَاذُو\add* نّسْ. نشّْ أَذْ سّْوجْذغْ أَفُونَاسْ أَمژْيَانْ نّغْنِي، أَذْ ث سَّارْسغْ خْ ؤُكشُّوضْ ؤُ وَارْ تّڭّغْ ثِيمسِّي \add سَاذُو\add* نّسْ.
\v 24 \add خنِّي\add* أَذْ ثْڒَاغَامْ إِسمْ ن أَربِّي نْومْ ؤُ نشّْ أَذْ ڒَاغِيغْ إِسمْ ن سِيذِي، ؤُشَا أَربِّي ونِّي إِ د غَا يَارّنْ س ثْمسِّي، ذ نتَّا أَذْ يِيڒِي ذ أَربِّي.“ ؤُشَا إِڒَاغَا مَارَّا ڒْڭنْسْ، نَّانْ: ”أَوَاڒْ\add -أَ\add* ذ لمْلِيحْ!“
\m 
\v 25 إِنَّا إِلِييَا إِ إِنَابِييّنْ ن بَاعْلْ: ”خْضَارمْ إِ يِيخفْ نْومْ أَفُونَاسْ أَمژْيَانْ أَمزْوَارُو ؤُ سّْوجْذمْ أَسْ ث ذ أَمزْوَارُو، مَاغَارْ كنِّيوْ س وَاطَّاسْ. ڒَاغَامْ \add خنِّي\add* إِسمْ ن أَربِّي نْومْ، \add مَاشَا\add* وَارْ سْرُوسَامْ شَا ثِيمسِّي سَاذُو نّسْ.“
\v 26 نِيثْنِي كْسِينْ أَفُونَاسْ أَمژْيَانْ إِ ذ أَسنْ إِوْشَا نتَّا ؤُ سّْوجْذنْ ث. خنِّي ڒَاغَانْ إِ يِيسمْ ن بَاعْلْ، زِي ثُوفُّوثْ أَڒْ أَزَالْ، نَّانْ: ”\add أَ\add* بَاعْلْ، أَرّْ أَنغْ-د!“ \add مَاشَا\add* وَالُو ن ڒْحسّْ ؤُشَا ؤُڒَا ذ إِجّْ وَارْ د-يَارِّي شَا. نِيثْنِي نڭْزنْ خْ ؤُعَالْطَارْ إِ \add ذِينْ\add* إِتّْوَاڭّنْ.
\v 27 غَارْ وَازَالْ إِبْذَا إِلِييَا إِتّْقسَّارْ خَاسنْ، إِنَّا: ”ڒَْاغَامْ س ثْمِيجَّا إِجهْذنْ، أَقَا-ث ذ أَربِّي. \add نِيشَانْ\add* نتَّا إِتّْخمَّامْ، نِيغْ إِعزّڒْ \add شْوَايْثْ\add*، نِيغْ نتَّا \add عَاذْ\add* ذڭْ وبْرِيذْ. أَذْ ثَاغْ إِتّطّصْ ؤُشَا إِتّْخصَّا أَسْ أَذْ إِفَاقْ \add عَاذْ\add*.“
\v 28 نِيثْنِي سْغُوينْ س ثْمِيجَّا إِجهْذنْ ؤُ قسّنْ إِخفْ نْسنْ س ڒسْيُوفْ ذ إِحْرِيشنْ أَمْ ثْنَامِيثْ نْسنْ، أَڒَامِي ؤُزّْڒنْ إِذَامّنْ نْسنْ خَاسنْ.
\v 29 ؤُمِي إِعْذُو أَزَالْ، إِمْسَارْ، أَقَا نِيثْنِي تّْنبَّانْ أَڒْ د غَا يَاوْينْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*. \add مَاشَا\add* وَارْ ذِينْ ؤُڒَا ذ إِشْثْ ن ثْمِيجَّا ؤُشَا ؤُڒَا ذ إِجّْ وَارْ د-يَارِّي ؤُ وَارْ \add ذِينْ\add* بُو لِيسْثِيجَابَا وَالُو.
\m 
\v 30 \add خنِّي\add* إِنَّا إِلِييَا إِ ڒْڭنْسْ: ”قَارّْبمْ-د غَارِي!“ مَارَّا ڒْڭنْسْ إِقَارّبْ-د غَارسْ ؤُ نتَّا إِعْذڒْ أَعَالْطَارْ ن سِيذِي إِ ثُوغَا إِتّْوَاهْذمْ.
\v 31 إِلِييَا إِكْسِي ثنْعَاشْ ن يژْرَا، خْ ڒْقدّْ ن ثْقبَّاڒْ ن إِحنْجِيرنْ ن يَاعْقُوبْ إِ ؤُمِي د-يُوسَا وَاوَاڒْ ن سِيذِي إِ ثُوغَا إِنَّا: ”إِسْرَائِيل أَذْ يِيڒِي ذ إِسمْ نّشْ.“ \x ◘ \xo 18:‏31 \xt أَمز. 32‏:‏27؛ ياش. 4‏:‏5، 20؛ 2 إِج. 17‏:‏34\x*
\v 32 س يژْرَا نِّي إِبْنَا نتَّا أَعَالْطَارْ ذڭْ يِيسمْ ن سِيذِي. إِقوَّارْ إِ ؤُعَالْطَارْ إِشْثْ ن ثَارْيَا س ڒْقدّْ ن ثْنَاينْ ن ڒقْيَاسْ ن زَّارِيعثْ. \f ◼ \fr 18:‏32 \ft \bd ’ڒقْيَاسْ‘\bd* - عْڒَاينْ 7-8 لِيثْرُو.\f*
\v 33 إِستّفْ أَكشُّوضْ ؤُشَا إِبْضَا أَفُونَاسْ أَمژْيَانْ ذ إِشدْجِيقنْ، إِسَّارْسْ \add إِ-ث\add* خْ ؤُكشُّوضْ.
\v 34 إِنَّا: ”عمَّارمْ أَربْعَا ن إِبُوقَاڒنْ س وَامَانْ ؤُشَا زدْجْعمْ ثنْ ثِيوَا إِ ثْغَارْصْثْ ن وشْمَاضْ ؤُ خْ ؤُكشُّوضْ!“ ؤُشَا يَارْنِي إِنَّا: ”ڭّمْ ث ثْوَاڒَا نّغْنِيثْ!“ ؤُ نِيثْنِي ڭِّينْ ث ثْوَاڒَا نّغْنِيثْ. \add خنِّي\add* إِنَّا: ”ڭّمْ ث وِيسّْ ثْڒَاثَا ن ثْوَاڒَاوِينْ!“ ؤُ نِيثْنِي ڭِّينْ ث وِيسّْ ثْڒَاثَا ن ثْوَاڒَاوِينْ.
\v 35 تَّازّْڒنْ وَامَانْ، نّْضنْ إِ ؤُعَالْطَارْ. ؤُ نتَّا إِعمَّارْ ؤُڒَا ذ ثَارْيَا س وَامَانْ.
\m 
\v 36 ؤُمِي قدّْمنْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*، إِمْسَارْ، أَقَا أَنَابِي إِلِييَا إِقَارّبْ-د، إِنَّا: ”سِيذِي، أَربِّي ن إِبْرَاهِيمْ ذ إِسْحَاقْ ذ إِسْرَائِيل، أجّْ أَذْ إِتّْوَاسّنْ أَسّْ-أَ أَقَا شكْ ذ أَربِّي ذِي إِسْرَائِيل ؤُ أَقَا نشّْ ذ أَمْسخَّارْ نّشْ \add إِ دْجِيغْ\add* ؤُ بلِّي نشّْ ڭِّيغْ مَارَّا مَانْ أَيَا عْلَاحْسَابْ أَوَاڒْ نّشْ. \x ◘ \xo 18:‏36 \xt ؤُف. 3‏:‏6؛ مت. 22‏:‏32؛ مك. 12‏:‏26؛ لك. 20‏:‏37؛ ڒخ. 7‏:‏32\x*
\v 37 أَرّْ أَيِي-د، \add أَ\add* سِيذِي، أَرّْ أَيِي-د، حِيمَا ڒْڭنْسْ-أَ أَذْ إِسّنْ، أَقَا شكْ، \add أَ\add* سِيذِي، ذ أَربِّي \add إِ ثدْجِيذْ\add* ؤُ أَقَا شكْ ثَارِّيذْ-د ؤُڒْ نْسنْ \add غَاركْ\add*.“
\v 38 ؤُشَا ثهْوَا-د ثْمسِّي ن سِيذِي \add زڭْ ؤُجنَّا\add*، ثشَّا ثَاغَارْصْثْ ن وشْمَاضْ ذ ؤُكشُّوضْ ذ يژْرَا ذ ثْعجَّاجْثْ، ؤُشَا ثڒْسحْ ؤُڒَا ذ أَمَانْ \add إِ إِدْجَانْ\add* ذِي ثَارْيَا.
\v 39 مَارَّا ڒْڭنْسْ إِژْرَا إِ-ث. نِيثْنِي وْضَانْ س ؤُغمْبُوبْ نْسنْ \add غَارْ ثمُّورْثْ\add*، نَّانْ: ”سِيذِي أَقَا-ث ذ أَربِّي، سِيذِي أَقَا-ث ذ أَربِّي!“
\v 40 إِلِييَا إِنَّا أَسنْ: ”طّْفمْ إِنَابِييّنْ ن بَاعْلْ، وَارْ تّجِّيمْ ؤُڒَا ذ إِجّْ زَّايْسنْ أَذْ يَارْوڒْ.“ طّْفنْ ثنْ، ؤُشَا إِلِييَا إِجَّا إِ-ثنْ أَذْ سّهْوَانْ غَارْ ثغْزَارْثْ ن قِيشُونْ، إِنْغَا إِ-ثنْ ذِينِّي.
\m 
\v 41 \add خنِّي\add* إِنَّا إِلِييَا إِ أَخَابْ: ”ڭعّذْ، أشّْ، ثسْوذْ، مَاغَارْ \add نشّْ أَقَا تّسْڒِيغْ\add* ڒْحسّْ ن إِجّْ ن ؤُشَارْشَارْ ن ونْژَارْ أَطَّاسْ.“
\v 42 أَخَابْ إِڭعّذْ، حِيمَا أَذْ إِشّْ أَذْ إِسُو ؤُشَا إِڭعّذْ إِلِييَا غَارْ ثْقِيشَّاثْ ن كَارْمِيلْ. إِقُّونْجڒْ خْ ثمُّورْثْ ؤُشَا إِڭَّا ؤُذمْ نّسْ جَارْ إِفَادّنْ نّسْ.
\v 43 \add خنِّي\add* إِنَّا إِ ؤُمْسخَّارْ نّسْ: ”ڭعّذْ ؤُشَا خْزَارْ غَارْ ڒبْحَارْ!“ وَانِيثَا إِڭعّذْ، إِخْزَارْ غَارْ ڒَاڭّْوَاجْ، إِنَّا: ”وَارْ \add تّْوِيڒِيغْ\add* وَالُو!“ إِلِييَا إِنَّا: ”ذْوڒْ-د ثْوَاڒَا نّغْنِيثْ!“، \add ؤُشَا أَمُّو\add* سبْعَا ن ثْوَاڒَاوِينْ!
\v 44 غَارْ ثْوَاڒَا وِيسّْ سبْعَا، إِمْسَارْ، أَقَا إِنَّا: ”خْزَارْ، إِشْثْ ن ثْسيْنُوثْ ثَامژْيَانْثْ، أَمْ ؤُفُوسْ ن إِجّْ ن ورْيَازْ، إِڭعّذْ-د زِي ڒبْحَارْ.“ \add خنِّي\add* إِنَّا: ”ؤُيُورْ، إِنِي إِ أَخَابْ: ’حزّمْ \add إِيْسَانْ\add*، هْوَا-د، مَاحنْذْ أَنْژَارْ وَارْ شكْ إِتّطّفْ.“
\v 45 جَارْ ؤُ جَارْ إِبَّارْشنْ ؤُجنَّا س إِسيْنُوثنْ ؤُ س ؤُسمِّيضْ ؤُشَا إِبْذَا ونْژَارْ أَذْ إِوّثْ أَطَّاسْ. \add خنِّي\add* إِنْيَا أَخَابْ \add ذڭْ ؤُكَارُّو\add*، إِفّغْ، يُويُورْ غَارْ يَازْرَاعِيلْ.
\v 46 ثُوغَا أَفُوسْ ن سِيذِي خْ إِلِييَا. نتَّا إِبْيسْ ثَاعْجِينَّا نّسْ ؤُشَا إِزْوَارْ إِتَّازّڒْ زَّاثْ إِ وُوذمْ ن أَخَابْ أَڒَامِي د-يِيوضْ غَارْ يَازْرَاعِيلْ.
\b
\b
\c 19
\s1 إِلِييَا خْ وذْرَارْ ن هُورِيبْ
\m 
\v 1 أَخَابْ إِحَاجَا إِ إِزَابَالْ مَارَّا مِينْ إِڭَّا إِلِييَا ؤُڒَا ذ مَارَّا خْ مَامّشْ إِنْغَا \add إِلِييَا\add* مَارَّا إِنَابِييّنْ س سِّيفْ.
\v 2 إِزَابَالْ ثسّكّْ إِجّْ ن ؤُرقَّاسْ غَارْ إِلِييَا، مَاحنْذْ أَذْ أَسْ يِينِي: ”أَذْ أَيِي ڭّنْ إِربِّيثنْ ثَا ذ ثَا ؤُڒَا ذ كْثَارْ زِي مَانْ أَيَا، مَاڒَا وَارْ ڭِّيغْ ثِيوشَّا ذِي ڒْوقْثْ-أَ ڒعْمَارْ نّشْ أَمْ ڒعْمَارْ ن إِجّْ زَّايْسنْ.“
\v 3 نتَّا إِخْزَارْ، إِكَّارْ ؤُشَا إِرُوحْ، حِيمَا أَذْ إِنْجمْ ڒعْمَارْ نّسْ. يُوسَا-د غَارْ بِئرْ-سبْعَا نِّي \add إِدْجَانْ\add* ذِي يَاهُوذَا، ؤُشَا إِجَّا أَحُوذْرِي أَمْسخَّارْ نّسْ ذِينِّي.
\v 4 نتَّا سِيمَانْثْ نّسْ يُويُورْ ثِيشْڒِي ن وبْرِيذْ ن إِجّْ ن وَاسّْ ذِي ڒخْڒَا، إِقِّيمْ إِزّڒْ سَاذُو ثَازڭّْوَارْثْ ن وَازُّو ؤُشَا إِتَّارْ، حِيمَا أَذْ إِمّثْ ڒعْمَارْ نّسْ، إِنَّا: ”كْفَا، \add أَ\add* سِيذِي، كْسِي ڒخُّو ڒعْمَارْ إِنُو، مَاغَارْ وَارْ دْجِيغْ حْسنْ خْ ڒجْذُوذْ إِنُو.“
\v 5 \add خنِّي\add* إِزّڒْ، إِطّصْ سَاذُو إِشْثْ ن ثْزڭّْوَارْثْ ن وَازُّو. ؤُ خْزَارْ، لْمَالَاكْ إِحَاذَا ث، إِنَّا أَسْ: ”كَّارْ، أشّْ!“
\v 6 ؤُمِي نتَّا إِسّْڭعّذْ ثَامُوغْڒِي نّسْ، خْزَارْ، زَّاثْ إِ ؤُزدْجِيفْ نّسْ أَقَا ذِينْ إِشْثْ ن ثفْضِيڒْثْ إِ ثُوغَا سّنْڭْونْ ت س ڒفْحمْ ؤُڒَا ذ إِشْثْ ن ثبْرِيقْثْ ذَايسْ أَمَانْ. \add خنِّي\add* إِشَّا، إِسْوَا ؤُشَا إِذْوڒْ عَاوذْ إِزّڒْ \add ذِينْ\add*.
\v 7 لْمَالَاكْ ن سِيذِي يُوسَا-د ثْوَاڒَا وِيسّْ ثْنَاينْ، إِحَاذَا ث، إِنَّا: ”كَّارْ، أشّْ، نِيغْ أَبْرِيذْ \add أَذْ يِيڒِي\add* ذ أَزِيرَارْ خَاكْ.“
\v 8 نتَّا إِكَّارْ، إِشَّا، إِسْوَا. س جّهْذْ ن مَاشَّا يُويُورْ \add ثِيشْثِي ن\add* أَربْعِينْ ن وُوسَّانْ ذ أَربْعِينْ ن دْجِييَاڒِي أَڒْ أَذْرَارْ ن أَربِّي، هُورِيبْ. \x ◘ \xo 19:‏8 \xt ؤُف. 34‏:‏28؛ مت. 4‏:‏2\x*
\m 
\v 9 ذِينِّي يِيوضْ غَارْ إِجّْ ن يفْرِي ؤُشَا إِسّنْسْ ذِينِّي. ؤُ خْزَارْ، \add يُوسَا\add* أَسْ-د أَوَاڒْ ن سِيذِي، إِنَّا أَسْ: ”مِينْ ذَا إِ غَا ثڭّذْ، إِلِييَا؟“
\v 10 نتَّا إِنَّا: ”نشّْ شْضَارغْ أَڒْ طَّارْفْ ذِي طّْوعْ ن سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ، مَاغَارْ أَيْثْ ن إِسْرَائِيل سمْحنْ ذِي ڒْعَاهْذْ نّشْ، هذْمنْ إِعَالْطَارنْ نّشْ ؤُ إِنَابِييّنْ نّشْ تّْوَانْغنْ س سِّيفْ، مْغِيرْ نشّْ ذ ونِّي إِقِّيمنْ ؤُ نِيثْنِي أَرزُّونْ أَذْ أَيِي كّْسنْ ؤُڒَا ذ ثُوذَارْثْ إِنُو.“ \f ◼ \fr 19:‏10 \ft \bd ’ثُوذَارْثْ‘\bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ‘.\f*  \x ◘ \xo 19:‏10 \xt رُوم. 11‏:‏3\x*
\m 
\v 11 نتَّا إِنَّا: ”فّغْ، بدّْ خْ وذْرَارْ زَّاثْ إِ وُوذمْ ن سِيذِي.“ ؤُ خْزَارْ، إِعْذُو-د سِيذِي. إِشْثْ ن ثْحَارْيَاضْثْ ثمْغَارْ ؤُ ثجْهذْ أَقَا ثوْثَا إِذُورَارْ ؤُ ثڒْبزْ ڒجْرُوفْ زَّاثْ إِ وُوذمْ ن سِيذِي. \add مَاشَا\add* سِيذِي ثُوغَا وَارْ إِدْجِي شَا ذِي ثْحَارْيَاضْثْ. أَوَارْنِي إِ ثْحَارْيَاضْثْ \add يُوسَا-د\add* إِجّْ ن ونْهزِّي ن ثمُّورْثْ. \add مَاشَا\add* سِيذِي \add ثُوغَا\add* وَارْ إِدْجِي شَا ذڭْ ونْهزِّي ن ثمُّورْثْ.
\v 12 أَوَارْنِي إِ ونْهزِّي ن ثمُّورْثْ \add ثُوسَا-د\add* ثْمسِّي. \add مَاشَا\add* سِيذِي \add ثُوغَا\add* وَارْ إِدْجِي شَا ذِي ثْمسِّي. أَوَارْنِي ثْمسِّي \add ثُوغَا ذِينْ\add* إِشْثْ ن ثْمِيجَّا ثفْسُوسْ، ثَارْسَا.
\m 
\v 13 ؤُمِي إِسْڒَا إِلِييَا، إِمْسَارْ أَقَا إِڒحّفْ أَغمْبُوبْ نّسْ ذڭْ ؤُپَارْثسُّو نّسْ، إِفّغْ غَارْ بَارَّا ؤُشَا إِبدّْ غَارْ ؤُقمُّومْ ن يفْرِي. ؤُ خْزَارْ، إِشْثْ ن ثْمِيجَّا \add إِسِّيوڒْ\add* أَكِيذسْ، ثنَّا: ”مِينْ ذَا ثڭّذْ إِلِييَا؟“
\v 14 نتَّا إِنَّا: ”نشّْ شْضَارغْ أَڒْ طَّارْفْ ذِي طّْوعْ ن سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ، مَاغَارْ أَيْثْ ن إِسْرَائِيل سمْحنْ ذِي ڒْعَاهْذْ نّشْ، هذْمنْ إِعَالْطَارنْ نّشْ، ؤُ إِنَابِييّنْ نّشْ تّْوَانْغنْ س سِّيفْ، مْغِيرْ نشّْ ذ ونِّي إِقِّيمنْ، ؤُ نِيثْنِي أَرزُّونْ أَذْ كّْسنْ ؤُڒَا ذ ثُوذَارْثْ إِنُو.“
\m 
\v 15 إِنَّا أَسْ سِيذِي: ”ؤُيُورْ، عْقبْ أَبْرِيذْ نّشْ غَارْ ڒخْڒَا ن ذِيمَاشْقْ ؤُ خْمِي غَا ثَاوْضذْ غَارْ ذِينْ، ذْهنْ حَازَايِيلْ ذ أَجدْجِيذْ خْ أَرَامْ!
\v 16 \add ؤُڒَا ذ\add* يَاهُو، مِّيسْ ن نِيمْشِي، أَذْ ث ثْذهْنذْ ذ أَجدْجِيذْ خْ إِسْرَائِيل ؤُشَا إِلِيشَاعْ، مِّيسْ ن شَافَاثْ زِي أَبَالْ-مَاحُولَا، ذْهنْ إِ-ث ذ أَنَابِي ذڭْ ومْشَانْ نّشْ.
\v 17 أَذْ إِمْسَارْ، أَقَا يَاهُو أَذْ إِنغْ وِي غَا إِنجْمنْ إِ سِّيفْ ن حَازَايِيلْ، ؤُ إِلِيشَاعْ أَذْ إِنغْ وِي غَا إِنجْمنْ إِ سِّيفْ ن يَاهُو. \x ◘ \xo 19:‏17 \xt 2 إِج. 9‏:‏14‏-‏37\x*
\v 18 \add خنِّي\add* جِّيغْ نشّْ ذِي إِسْرَائِيل سبْعَا-أَڒَافْ \add ن ڒعْمُورْ\add*، مَارَّا إِنِّي إِفَادّنْ نْسنْ وَارْ قُّونْجڒنْ زَّاثْ إِ بَاعْلْ ؤُ مَارَّا إِنِّي وَارْ ث إِسُّوذْمنْ س ؤُقمُّومْ نْسنْ.“ \x ◘ \xo 19:‏18 \xt رُوم. 11‏:‏4\x*
\b
\m 
\v 19 إِفّغْ إِلِييَا سّنِّي، يُوفَا \bd إِلِيشَاعْ، مِّيسْ ن شَافَاثْ\bd*. نتَّا ثُوغَا إِشَارّزْ س ثنْعَاشْ ن إِزَايْڒُوثنْ ن \add إِينْذُوزنْ\add* ؤُ نتَّا \add سِيمَانْثْ نّسْ\add* \add إِشَارْزْ\add* خْ وِيسّْ ثنْعَاشْ. إِلِييَا إِعْذُو غَارسْ، إِنْضَارْ خَاسْ أَپَارْثسُّو نّسْ.
\v 20 \add ڒخْذنِّي\add* إِسْمحْ ذڭْ إِفُونَاسنْ، إِعْڒفْ أَوَارْنِي إِ إِلِييَا، إِنَّا: ”تّْزَاوْڭغْ، أجّْ أَيِي أَذْ سُّوذْمغْ بَابَا ذ يمَّا \add إِ ؤُقبّضْ\add*، خنِّي أَذْ شكْ ضْفَارغْ.“ نتَّا إِنَّا أَسْ: ”ؤُيُورْ، ذْوڒْ، مِينْزِي مِينْ ذَايكْ ڭِّيغْ نشّْ؟“
\v 21 إِعْقبْ نتَّا \add خنِّي\add* أَوَارْنِي أَسْ، إِكْسِي إِجّْ ن ؤُزَايْڒُو ن إِفُونَاسنْ ؤُشَا إِغَارْصْ أَسنْ. س ؤُكشُّوضْ ن ؤُزَايْڒُو إِسّْننَّا أَيْسُومْ نْسنْ، إِوْشَا إِ-ث إِ ڒْڭنْسْ مَاحنْذْ أَذْ إِشّْ. \add أَوَارْنِي ؤُيَا\add* إِكَّارْ، ؤُشَا إِضْفَارْ إِلِييَا، إِسخَّارْ أَسْ.
\b
\b
\c 20
\s1 ڒحْصَارثْ ن سَامَارْيَا ذ ؤُمنْغِي غَارْ أَفِيقْ
\m 
\v 1 بِينْهَاذَاذْ، أَجدْجِيذْ ن أَرَامْ، إِسّْمُونْ مَارَّا ڒْعسْكَارْ نّسْ. ثُوغَا أَكِيذسْ ثْنَاينْ ؤُ-ثْڒَاثِينْ ن إِجدْجِيذنْ س إِيْسَانْ ذ إِكَارُّوثنْ. نتَّا إِڭعّذْ، إِنّضْ إِ سَامَارْيَا ؤُ إِمّْنغْ أَكِيذسْ.
\v 2 خنِّي إِسّكّْ نتَّا إِرقَّاسنْ غَارْ أَخَابْ، أَجدْجِيذْ ن إِسْرَائِيل، ذَاخڒْ ذِي ثنْذِينْثْ.
\v 3 إِنَّا أَسْ: ”أَمُّو إِ إِقَّارْ بِينْ-هَاذَاذْ: ’نُّوقَارْثْ نّشْ ذ وُورغْ نّشْ إِنُو. ؤُڒَا ذ ثِيمْغَارِينْ نّشْ ذ إِحنْجِيرنْ نّشْ إِشوَّارنْ، أَقَا أَثنْ إِنُو.‘ “
\v 4 أَجدْجِيذْ ن إِسْرَائِيل يَارَّا-د خَاسْ، إِنَّا: ”أَمْ مَامّشْ ثنِّيذْ، أَ سِيذِي إِنُو أَجدْجِيذْ. نشّْ نّشْ س مَارَّا مِينْ غَارِي.“
\v 5 إِرقَّاسنْ ؤُسِينْ-د إِشْثْ ن ثْوَاڒَا نّغْنِيثْ، نَّانْ: ”أَمُّو إِسِّيوڒْ بِينْهَاذَاذْ، إِنَّا: ’نشّْ جِّيغْ أَذْ أَشْ إِنِينْ: إِتّْخصَّا أَذْ أَيِي ثوْشذْ نُّوقَارْثْ ذ وُورغْ نّشْ ذ ثمْغَارِينْ نّشْ ذ إِحنْجِيرنْ نّشْ!،
\v 6 مَاشَا ثِيوشَّا غَارْ ڒْوقْثْ-أَ أَذْ سّكّغْ إِمْسخَّارنْ إِنُو غَاركْ، مَاحنْذْ أَذْ أَرْزُونْ ذِي ثَادَّارْثْ نّشْ ؤُ ذِي ثُوذْرِينْ ن إِمْسخَّارنْ نّشْ. أَذْ إِمْسَارْ بلِّي نِيثْنِي أَذْ طّْفنْ مَارَّا مِينْ خَاكْ إِعِيزّنْ ذِي ثِيطَّاوِينْ نّشْ س إِفَاسّنْ نْسنْ، أَذْ \add ث\add* أَوْينْ.‘ “
\m 
\v 7 \add خنِّي\add* إِڒَاغَا ؤُجدْجِيذْ ن إِسْرَائِيل خْ مَارَّا إِمْغَارنْ ن ثمُّورْثْ، إِنَّا: ”سْنمْ \add خنِّي\add* ؤُ خْزَارمْ أَقَا وَانِيثَا إِنْوَا ڒْغَارْ، مَاغَارْ ثُوغَا إِسّكّْ-د غَارِي \add قْبڒْ\add*، مَاحنْذْ \add أَذْ إِكْسِي\add* ثِيمْغَارِينْ إِنُو ذ إِحنْجِيرنْ إِنُو ذ نُّوقَارْثْ إِنُو ذ وُورغْ إِنُو ؤُ نشّْ وَارْ ذ أَسْ ث قْضِيعغْ.“
\v 8 مَارَّا إِمْغَارنْ ذ مَارَّا ڒْڭنْسْ نَّانْ أَسْ: ”وَارْ \add غَارسْ\add* تّسْڒِي ؤُ وَارْ ذ أَسْ تِّيشْ تّسْرِيحْ!“
\v 9 \add خنِّي\add* إِنَّا إِ إِرقَّاسنْ ن بِينْهَاذَاذْ: ”إِنِيمْ إِ سِيذِي إِنُو أَجدْجِيذْ: ’مَارَّا ؤُمِي إِ ثسّكّذْ أَمْسخَّارْ نّشْ غَارْ ؤُمزْوَارُو أَذْ ث ڭّغْ، \add مَاشَا\add* ثَامسْڒَاشْثْ-أَ وَارْ زمَّارغْ أَذْ ث ڭّغْ.‘ “ فّْغنْ إِرقَّاسنْ ؤُشَا إِوْينْ أَسْ-د أَوَاڒْ-أَ.
\v 10 \add خَاسْ ؤُشَا\add* إِسّكّْ بِينْهَاذَاذْ غَارسْ، إِنَّا: ”أَذْ أَيِي ڭّنْ إِربِّيثنْ أَمُّو ؤُ أَذْ أَرْنِينْ عَاذْ كْثَارْ، مَاڒَا ثَاعجَّاجْثْ ن سَامَارْيَا ثْقدّْ، حِيمَا أَذْ ثشُّورْ ؤُرُو ن إِفَاسّنْ ن مَارَّا ڒْڭنْسْ إِ يُويُورنْ ذڭْ إِصُورَافْ إِنُو!“
\v 11 يَارَّا-د ؤُجدْجِيذْ ن إِسْرَائِيل، إِنَّا: ”إِنِيمْ أَسْ: ’ونِّي إِبيْسنْ أَبْيَاسْ، وَارْ إِتّْشنّعْ إِخفْ نّسْ أَمْ ونِّي ث إِسَّارْسنْ.‘ “
\v 12 ؤُمِي إِسْڒَا إِ وَاوَاڒْ-أَ، \add أَمْ\add* ثُوغَا إِسسّْ أَكْ-ذ إِجدْجِيذنْ ذڭْ إِقِيضَانْ، أَقَا إِنَّا إِ إِمْسخَّارنْ نّسْ: ”سْبدّمْ إِخفْ نْومْ!“ ؤُ نِيثْنِي سّْوجْذنْ إِخفْ نْسنْ \add إِ ؤُمنْغِي\add* ضِيدّْ إِ ثنْذِينْثْ.
\m 
\v 13 ؤُ خْزَارْ إِجّْ ن ؤُنَابِي يُوسَا-د غَارْ أَخَابْ، أَجدْجِيذْ ن إِسْرَائِيل، إِنَّا: ”أَمُّو إِ إِسِّيوڒْ سِيذِي: ’مَا ثتّْوَاڒِيذْ شكْ ڒْغَاشِي-يَا أَمقّْرَانْ؟ خْزَارْ أَسّْ-أَ نشّْ أَذْ ث وْشغْ ذڭْ ؤُفُوسْ نّشْ، حِيمَا أَذْ ثسّْنذْ أَقَا نشّْ ذ سِيذِي.‘ “
\v 14 ؤُشَا أَخَابْ إِنَّا: ”زِي مَانْ ونْ؟“ نتَّا إِنَّا: ”أَمُّو إِ إِقَّارْ سِيذِي: ’س إِمْسخَّارنْ ن ڒْحُوكَّامْ ن لْعَامَالَاثْ.‘ “ ؤُ نتَّا إِنَّا: ”مَانْ ونْ إِ غَا إِبْذَانْ أَمنْغِي؟“ إِنَّا نتَّا: ”ذ شكْ!“
\v 15 \add خَاسْ ؤُشَا\add* إِسدّْ نتَّا إِمْسخَّارنْ ن ڒْحُوكَّامْ ن لْعَامَالَاثْ. ثُوغَا أَثنْ ذِي مِيثَاينْ ؤُ-ثْنَاينْ ؤُ-ثْڒَاثِينْ. إِسدّْ أَوَارْنِي أَسنْ مَارَّا ڒْڭنْسْ. مَارَّا أَيْثْ ن إِسْرَائِيل، ثُوغَا أَثنْ ذِي سبْعَا-أَڒَافْ \add ن يرْيَازنْ\add*.
\v 16 فّْغنْ نِيثْنِي غَارْ وَازَالْ. بِينْهَاذَاذْ ثُوغَا إِسْشَارْ ذڭْ إِقِيضَانْ، نتَّا ذ إِجدْجِيذنْ، ثْنَاينْ ؤُ-ثْڒَاثِينْ ن إِجدْجِيذنْ إِ ذ أَسْ إِوْشِينْ أَفُوسْ.
\v 17 إِمْسخَّارنْ ن ڒْحُوكَّامْ ن لْعَامَالَاثْ فّْغنْ-د ذ إِمزْوُورَا \add زِي سَامَارْيَا\add*. بِينْهَاذَاذْ ثُوغَا إِسّكّْ شَا \add ن إِبرْڭَاڭنْ\add* ؤُ نِيثْنِي خبَّارنْ أَسْ، نَّانْ: ”أَقَا إِرْيَازنْ فّْغنْ-د زِي سَامَارْيَا.“
\v 18 نتَّا إِنَّا: ”مَاڒَا نِيثْنِي فّْغنْ-د إِ ڒهْنَا، طّْفمْ ثنْ دَّارنْ ؤُ مَاڒَا نِيثْنِي فّْغنْ-د إِ ؤُمنْغِي، طّْفمْ ثنْ \add عَاوذْ\add* دَّارنْ!“
\v 19 فّْغنْ-د إِمْسخَّارنْ ن ڒْحُوكَّامْ ن لْعَامَالَاثْ زِي ثنْذِينْثْ أَكْ-ذ ڒْعسْكَارْ \add إِ د-يُوسِينْ\add* أَوَارْنِي أَسنْ.
\v 20 \add كُوڒْ\add* أَرْيَازْ إِغْڒبْ خْ وغْرِيمْ نّسْ أَڒَامِي أَروْڒنْ أَيْثْ ن أَرَامْ ؤُ إِسْرَائِيل إِضْفَارْ إِ-ثنْ، \add مَاشَا\add* بِينْهَاذَاذْ، أَجدْجِيذْ ن أَرَامْ، إِنْجمْ خْ ؤُيِيسْ أَكْ-ذ شَا ن إِمْنَاينْ. \f ◼ \fr 20:‏20 \ft \bd ’أَغْرِيمْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَرْيَازْ‘. \bd ’أَمْنَايْ‘\bd* - ونِّي إِندّْهنْ أَيِيسْ.\f*
\m 
\v 21 \add خنِّي\add* إِفّغْ ؤُڒَا ذ أَجدْجِيذْ ن إِسْرَائِيل ؤُ نتَّا إِغْڒبْ خْ ييْسَانْ ذ إِكَارُّوثنْ \add ن ؤُمنْغِي\add* أَڒَامِي إِڭَّا أَسْ إِشْثْ ن ثشْثِي ذ ثَامقّْرَانْثْ إِ أَرَامْ.
\v 22 \add خنِّي\add* يُوسَا-د ؤُنَابِي غَارْ ؤُجدْجِيذْ ن إِسْرَائِيل، إِنَّا أَسْ: ”ؤُيُورْ، مْحضْ إِخفْ نّشْ. سّنْ ؤُ خْزَارْ مِينْ غَاركْ أَذْ ث ثڭّذْ، مَاغَارْ غَارْ ؤُبدُّو ن ؤُسڭّْوَاسْ ن جْذِيذْ أَذْ خَاكْ إِفّغْ ؤُجدْجِيذْ ن أَرَامْ \add ثْوَاڒَا نّغْنِي\add*.
\b
\m 
\v 23 إِمْسخَّارنْ ن ؤُجدْجِيذْ ن أَرَامْ نَّانْ أَسْ: ”أَربِّي نْسنْ ذ إِجّْ ن أَربِّي ن إِذُورَارْ، خْ ؤُيَا ثُوغَا جهْذنْ خَانغْ. مَاڒَا نشِّينْ نمّْنغْ أَكِيذْسنْ ذِي ڒْوَاطَا، \add خنِّي\add* أَذْ خَاسنْ نجْهذْ نِيشَانْ!
\v 24 أڭّْ مِينْ إِقَّارْ وَاوَاڒْ-أَ: كّسْ كُوڒْ إِجّْ زڭْ إِجدْجِيذنْ زڭْ ومْشَانْ نّسْ ؤُ ڭّمْ لْوُولَاثْ ذڭْ ومْشَانْ نْسنْ.
\v 25 سْمُونْ أَمُّو إِجّْ ن ڒْعسْكَارْ أَمْ ڒْعسْكَارْ نِّي ثْودَّارذْ، س ييْسَانْ أَمْ ييْسَانْ نِّي ؤُ س إِكَارُّوثنْ أَمْ إِكَارُّوثنْ نِّي، ؤُشَا أجّْ أَنغْ أَكِيذْسنْ نمّْنغْ ذِي ڒْوَاطَا. \add ؤُشْثْ\add* مَاڒَا \add خنِّي\add* نشِّينْ وَارْ خَاسنْ نجْهِيذْ!“ ؤُ نتَّا إِسْڒَا غَارْسنْ ؤُشَا أَمنِّي إِ إِڭَّا. \f ◼ \fr 20:‏25 \ft \bd ’إِسْڒَا غَارْسنْ‘\bd* - س ثْعِيبْرَانِيثْ ’إِسْڒَا غَارْ ثْمِيجَّا نْسنْ‘.\f*
\v 26 غَارْ ؤُبدُّو ن ؤُسڭّْوَاسْ ن جْذِيذْ، إِمْسَارْ، أَقَا بِينْهَاذَاذْ إِسدّْ أَرَامْ. إِفّغْ غَارْ أَفِيقْ إِ ؤُمنْغِي أَكْ-ذ إِسْرَائِيل.
\v 27 ؤُڒَا ذ أَيْثْ ن إِسْرَائِيل تّْوَاسدّنْ. وْشِينْ أَسنْ ڒعْوتْشْ ؤُ نِيثْنِي فّْغنْ إِ ؤُمْسَاڭَارْ أَكِيذْسنْ. أَيْثْ ن إِسْرَائِيل وْثِينْ إِقِيضَانْ نْسنْ أَجمَّاضْ نْسنْ أَمْ ثْنَاينْ ن ثْحِيمْرِيوِينْ ثِيمژْيَانِينْ ن إِغَايْضنْ. \add إِنِّي ن\add* أَرَامْ \add مَاشَا\add*عمَّارنْ ثَامُّورْثْ.
\v 28 يُوسَا-د غَارْسنْ ورْيَازْ ن سِيذِي، إِسِّيوڒْ أَكْ-ذ ؤُجدْجِيذْ ن إِسْرَائِيل، إِنَّا: ”أَمُّو إِ إِسِّيوڒْ سِيذِي: ’مِينْزِي إِنِّي ن أَرَامْ إِنَّانْ: سِيذِي ذ إِجّْ ن أَربِّي ن إِذُورَارْ، وَارْ إِدْجِي ذ إِجّْ ن أَربِّي ن ثْسدْجْيِينْ!‘، خْ ؤُيَا إِ غَا وْشغْ ڒْغَاشِي-يَا أَمقّْرَانْ ذڭْ ؤُفُوسْ نّشْ، حِيمَا كنِّيوْ أَذْ ثْعقْڒمْ، أَقَا نشّْ ذ سِيذِي.“
\v 29 ثُوغَا وْثِينْ إِقِيضَانْ نْسنْ سبْعَا ن وُوسَّانْ أَرنْذَاذْ ن وَايَاوْيَا. ذڭْ وَاسّْ وِيسّْ سبْعَا، إِمْسَارْ، أَقَا إِكَّارْ ؤُمنْغِي. ذڭْ إِجّْ ن وَاسّْ نْغِينْ أَيْثْ ن إِسْرَائِيل مْيَاثْ-أَڒفْ \add ن يرْيَازنْ\add* خْ إِضَارنْ زِي أَرَامْ.
\m 
\v 30 إِنِّي إِقِّيمنْ أَروْڒنْ غَارْ ثنْذِينْثْ ن أَفِيقْ ؤُشَا ڒْحِيضْ إِوْضَا خْ سبْعَا ؤُ-عِيشْرِينْ-أَڒفْ ن يرْيَازنْ، نِّي ثُوغَا إِقِّيمنْ. ؤُڒَا بِينْهَاذَاذْ ثُوغَا يَارْوڒْ ؤُشَا يُوذفْ غَارْ ثنْذِينْثْ، \add يُويُورْ\add* زڭْ \add إِجّْ ن\add* وخَّامْ غَارْ إِجّْ ن وخَّامْ \add نّغْنِي\add*. \x ◘ \xo 20:‏30 \xt 1 إِج. 22‏:‏25؛ 2 إِم. 18‏:‏24\x*
\v 31 \add خنِّي\add* نَّانْ أَسْ إِمْسخَّارنْ نّسْ: ”خْزَارْ، نشِّينْ نسْڒَا، أَقَا إِجدْجِيذنْ ن ثَادَّارْثْ ن إِسْرَائِيل ذ إِجدْجِيذنْ ذَايْسنْ ثَامخْسِيوْثْ إِشوَّارنْ. أجّْ أَنغْ أَذْ نبْيسْ س ثْخُونْشَايْ \add ن وشْضَانْ\add* غَارْ وبْيَاسْ ؤُ س إِسغْوَانْ غَارْ إِزدْجِيفنْ نّغْ ؤُشَا أَذْ نفّغْ غَارْ ؤُجدْجِيذْ ن إِسْرَائِيل. أَذْ ثَاغْ أَذْ شكْ يجّْ أَذْ ثدَّارذْ.“ \f ◼ \fr 20:‏31 \ft \bd ’أَذْ شكْ يجّْ أَذْ ثدَّارذْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَذْ يجّْ ڒعْمَارْ نّكْ أَذْ إِدَّارْ‘.\f*
\v 32 نِيثْنِي بيْسنْ س ثْخُونْشَايْ \add ن وشْضَانْ\add* ؤُ \add ڭِّينْ\add* إِسغْوَانْ غَارْ إِزدْجِيفنْ نْسنْ ؤُشَا \add أَمُّو\add* د-ؤُسِينْ نِيثْنِي غَارْ ؤُجدْجِيذْ ن إِسْرَائِيل، نَّانْ: ”أَمْسخَّارْ نّشْ بِينْهَاذَاذْ إِنَّا: ’أجّْ أَذْ إِدَّارْ ڒعْمَارْ إِنُو!‘ “ ؤُ نتَّا يَارَّا-د: ”مَا نتَّا إِدَّارْ عَاذْ؟ نتَّا ذ ؤُمَا!“
\v 33 إِرْيَازنْ فهْمنْ أَقَا مَانْ أَيَا ذ إِشْثْ ن ڒعْڒَامثْ ثصْبحْ، ؤُشَا أَرْزُونْ ذغْيَا خْ شَا، مَا أَقَا مَانْ أَيَا نِيشَانْ، ؤُشَا نَّانْ: ”ؤُمَاشْ بِينْهَاذَاذْ ...“ ؤُشَا نتَّا إِنَّا: ”أَسمْ-د، أَوْيمْ ث-إِ-د \add ذَانِيثَا\add*.“ \add خنِّي\add* إِفّغْ بِينْهَاذَاذْ غَارسْ ؤُ نتَّا إِسّنْيَا ث ذڭْ ؤُكَارُّو.
\v 34 إِنَّا أَسْ \add بِينْهَاذَاذْ\add*: ”ثِيندَّامْ نِّي ثُوغَا إِطّفْ بَابَا زِي بَابَاشْ، أَذْ ثنْثْ أَرّغْ. \add إِوَا،\add* أڭّْ إِ يِيخفْ نّشْ ذْشُورَاثْ \add إِ ثْسبَّابْثْ\add* ذِي ذِيمَاشْقْ أَمْ مَامّشْ إِڭَّا بَابَا ذْشُورَاثْ ذِي سَامَارْيَا.“ ؤُشَا \add أَخَابْ إِنَّا\add*: ”نشّْ أَذْ أَشْ أَرْخُوغْ خْ إِجّْ ن ڒْعَاهْذْ.“ ؤُ نتَّا إِقّنْ أَكِيذسْ إِجّْ ن ڒْعَاهْذْ ؤُشَا يَارْخُو أَسْ.
\b
\s1 أَنَابِي إِوبّخْ أَخَابْ
\m 
\v 35 إِجّْ ن ورْيَازْ زڭْ أَيْثْ ن إِنَابِييّنْ إِنَّا إِ جَّارْ نّسْ س وَاوَاڒْ ن سِيذِي: ”وّثْ أَيِي!“ أَرْيَازْ يُوڭِي \add مَاشَا\add* أَذْ ث إِوّثْ.
\v 36 إِنَّا أَسْ نتَّا: ”مِينْزِي شكْ وَارْ ثسْڒِيذْ غَارْ ثْمِيجَّا ن سِيذِي، خْزَارْ، مْغِيرْ شكْ أَذْ خَافِي ثفّْغذْ، أَذْ شكْ إِنغْ إِجّْ ن ويْرَاذْ.“ ؤُمِي خَاسْ يُويُورْ، إِڒْقفْ إِ-ث إِجّْ ن ويْرَاذْ ؤُ وَانِيثَا إِنْغَا إِ-ث.
\v 37 \add خنِّي\add* يُوفَا إِجّْ ن ورْيَازْ نّغْنِي، إِنَّا: ”وّثْ أَيِي!“ أَرْيَازْ نِّي إِوْثَا إِ-ث أَمُّو، أَڒَامِي ث إِيْزمْ.
\m 
\v 38 يُويُورْ ؤُنَابِي، إِبدّْ غَارْ وبْرِيذْ إِ \add ؤُمڒْقِي أَكْ-ذ\add* ؤُجدْجِيذْ. إِسّْنُوفَّارْ إِخفْ نّسْ س إِجّْ ن ڒشْفنْ خْ ثِيطَّاوِينْ نّسْ.
\v 39 ؤُمِي د-إِعْذُو ؤُجدْجِيذْ، إِمْسَارْ، أَقَا إِڒَاغَا إِ ؤُجدْجِيذْ، إِنَّا: ”أَمْسخَّارْ نّشْ ثُوغَا إِفّغْ غَارْ ڒْوسْطْ ن ؤُمنْغِي. ؤُشَا خْزَارْ، أَقَا ذِينْ إِجّْ ورْيَازْ يُوسَا-د غَارْ ؤُغزْذِيسْ، يِيوِي أَيِي-د إِجّْ ن ورْيَازْ، إِنَّا: ’حْضَا أَرْيَازْ-أَ، مَاشَا مَاڒَا إِودَّارْ غَارْ ؤُسذِّي \add ن ڒْعسْكَارْ\add*، أَذْ يِيڒِي ڒعْمَارْ نّشْ ذڭْ ومْشَانْ نّسْ نِيغْ أَذْ ثْخدْجْصذْ إِشْثْ ن ثَالِينْثْ ن نُّوقَارْثْ.‘
\v 40 ڒَامِي ثُوغَا إِتّْشغڒْ ؤُمْسخَّارْ نّشْ ذَا ذ ذِيهَا، إِمْسَارْ، أَقَا وَارْ \add ذِينْ\add* إِقِّيمْ \add عَاذْ\add*.“ إِنَّا أَسْ ؤُجدْجِيذْ ن إِسْرَائِيل: ”وَا ذ ڒْحُوكْمْ نّشْ، ثوْثِيذْ \add ث\add* س يِيخفْ نّشْ!“
\m 
\v 41 نتَّا إِكّسْ ذغْيَا ڒشْفنْ خْ ثِيطَّاوِينْ نّسْ، ؤُشَا إِعْقڒْ إِ-ث ؤُجدْجِيذْ ن إِسْرَائِيل، أَقَا-ث \add ذ إِجّْ\add* زڭْ إِنَابِييّنْ.
\v 42 نتَّا إِنَّا أَسْ: ”أَمُّو إِ إِسِّيوڒْ سِيذِي: ’مِينْزِي شكْ ثجِّيذْ أَرْيَازْ نِّي حَارّْمغْ نشّْ \add إِ ؤُثحِّي\add* أَذْ إِنْجمْ زڭْ ؤُفُوسْ نّشْ، أَذْ يِيڒِي ڒعْمَارْ نّشْ ذڭْ ومْشَانْ ن ڒعْمَارْ نّسْ ؤُ ڒْڭنْسْ نّشْ ذڭْ ومْشَانْ ن ڒْڭنْسْ نّسْ.“ \x ◘ \xo 20:‏42 \xt 1 إِج. 22‏:‏37، 38\x*
\v 43 أَجدْجِيذْ ن إِسْرَائِيل يُويُورْ س ڒْخَاضَارْ إِخْسَارنْ ذ إِخيِّيقنْ غَارْ ثَادَّارْثْ ؤُشَا يُوسَا-د غَارْ سَامَارْيَا.
\b
\b
\c 21
\s1 ڒحْوِيشْ ن ثْزَايَارْثْ ن نَاپُوثْ
\m 
\v 1 أَوَارْنِي ثْمسْڒَايِينْ-أَ أَقَا ذِينْ مِينْ إِمْسَارنْ أَكْ-ذ نابُوثْ، أَيَازْرَاعِيلِي، ونِّي غَارْ إِدْجَا إِجّْ ن ؤُمَارْجعْ ن ؤُضِيڒْ ذِي يَازْرَاعِيلْ زَّاثْ إِ ڒقْصَارْ ن أَخَابْ، أَجدْجِيذْ ن سَامَارْيَا.
\v 2 أَخَابْ إِسِّيوڒْ أَكْ-ذ نابُوثْ، إِنَّا: ”أوْشْ أَيِي أَمَارْجعْ نّشْ ن ؤُضِيڒْ، حِيمَا أَذْ غَارِي يِيڒِي ذ ثَاحْوِيشْ ثَازِيزَاوْثْ، مَاغَارْ أَقَا ثُوذسْ إِ ثَادَّارْثْ إِنُو. نشّْ أَذْ أَشْ وْشغْ ذڭْ ومْشَانْ نّسْ إِجّْ ن ؤُمَارْجعْ \add نّغْنِي\add* ن ؤُضِيڒْ إِصْبحْ خَاسْ، نِيغْ مَاڒَا مَانْ أَيَا ذ لمْلِيحْ ذِي ثِيطَّاوِينْ نّشْ، أَذْ شكْ خدْجْصغْ تّْمَانْ نّسْ س \add تّْمنْيَاثْ ن\add* نُّوقَارْثْ.“ \f ◼ \fr 21:‏2 \ft \bd ’ضِّيڒشْثْ‘\bd* - نِيغْ ’أَحْوِيشْ ن ثْزَايَارْثْ‘.\f*
\v 3 \add مَاشَا\add* نابُوثْ إِنَّا إِ أَخَابْ: ”سِيذِي أَذْ أَيِي إِحْضَا، أَقَا أَذْ أَشْ وْشغْ ثَاسْغَارْثْ ن ڒجْذُوذْ إِنُو!“
\v 4 ؤُشَا إِعْقبْ أَخَابْ غَارْ ثَادَّارْثْ نّسْ س ڒْخَاضَارْ إِخْسَارنْ ذ إِخيِّيقنْ زِي سِّيبّثْ ن وَاوَاڒْ إِ كِيذسْ إِسِّيوڒْ نابُوثْ، أَيَازْرَاعِيلِي، ؤُمِي إِنَّا: ”نشّْ وَارْ ذ أَشْ تِّيشغْ ثَاسْغَارْثْ ن ڒجْذُوذْ إِنُو.“ ؤُ نتَّا إِزّڒْ خْ قَامَا نّسْ، يَارَّا أَغمْبُوبْ نّسْ \add غَارْ ڒْحِيضْ\add*، وَارْ إِشِّي أَغْرُومْ.
\m 
\v 5 ثَامْغَارْثْ نّسْ إِزَابَالْ ثُوسَا-د غَارسْ، ثسِّيوڒْ أَكِيذسْ: ”مِينْ ذِينْ أَڒَامِي ڒْخَاضَارْ نّشْ إِخْسَارْ أَمُّو ؤُ وَارْ ثتّتّذْ أَغْرُومْ؟“
\v 6 نتَّا إِسِّيوڒْ أَكِيذسْ: ”مَاغَارْ نشّْ سِّيوْڒغْ أَكْ-ذ نابُوثْ، أَيَازْرَاعِيلِي، نِّيغْ أَسْ: ’أوْشْ أَيِي أَمَارْجعْ نّشْ ن ؤُضِيڒْ إِ \add تّْمنْيَاثْ ن\add* نُّوقَارْثْ، نِيغْ، مَاڒَا ثخْسذْ أَذْ أَشْ وْشغْ إِجّْ ن ؤُمَارْجعْ ن ؤُضِيڒْ \add نّغْنِي\add* ذڭْ ومْشَانْ نّسْ!‘، \add مَاشَا\add* نتَّا إِنَّا: ’نشّْ وَارْ ذ أَشْ تِّيشغْ أَمَارْجعْ إِنُو ن ؤُضِيڒْ!‘ “
\v 7 ثنَّا أَسْ ثمْغَارْثْ نّسْ إِزَابَالْ: ”مَا \add خنِّي\add* شكْ تّڭّذْ إِخفْ نّشْ ذ أَجدْجِيذْ خْ إِسْرَائِيل؟ كَّارْ، أشّْ أَغْرُومْ ؤُ أجّْ ؤُڒْ نّشْ أَذْ يِيڒِي مْلِيحْ! نشّْ أَذْ أَشْ وْشغْ أَمَارْجعْ ن ؤُضِيڒْ ن نابُوثْ، أَيَازْرَاعِيلِي.“
\v 8 نتَّاثْ ثُورَا ثِيبْرَاثِينْ خْ يِيسمْ ن أَخَابْ ؤُشَا ثْشمّعْ إِ-ثنْثْ س \add ثْخَاضنْثْ نّسْ ن\add* ؤُشمِّيعْ ؤُ ثسّكّْ ثِيبْرَاثِينْ نِّي إِ إِمقّْرَاننْ ؤُ إِ ثَارْوَا ن ثَاصِيڒثْ نِّي ثُوغَا إِزدّْغنْ غَارْ نابُوثْ ذِي ثنْذِينْثْ نّسْ.
\v 9 ذِي ثبْرَاثِينْ ثُورَا، ثنَّا: ”بَارّْحمْ س يِيجّْ ن ؤُژُومِّي ؤُ سْغِيممْ نابُوثْ غَارْ زَّاثْ ن مَارَّا ڒْڭنْسْ
\v 10 ؤُشَا سْبدّمْ ثْنَاينْ ن إِرْيَازنْ، أَيْثْ إِ وَارْ إِسكّْوِينْ، قِيبَاتْشْ نّسْ، حِيمَا أَذْ خَاسْ شهْذنْ، أَذْ إِنِينْ: ’شكْ ثْشقّْفذْ ذِي أَربِّي ؤُ ذڭْ ؤُجدْجِيذْ!‘ سُوفْغمْ ث خنِّي غَارْ بَارَّا ؤُ أَرجْممْ ث أَڒْ ذ إِمّثْ.“
\m 
\v 11 إِرْيَازنْ ن ثنْذِينْثْ، إِمقّْرَاننْ ذ ثَارْوَا ن ثَاصِيڒثْ نِّي ثُوغَا إِزدّْغنْ ذِي ثنْذِينْثْ نّسْ، ڭِّينْ عْلَاحْسَابْ مِينْ ذ أَسنْ ثُومُورْ إِزَابَالْ، أَمْ مَامّشْ يُورِينْ ذِي ثبْرَاثِينْ نِّي ثُوغَا ذ أَسنْ د-ثسّكّْ.
\v 12 نِيثْنِي بَارّْحنْ س يِيجّْ ن ؤُژُومِّي ؤُ سّْغِيمنْ نابُوثْ غَارْ زَّاثْ ن مَارَّا ڒْڭنْسْ.
\v 13 \add خنِّي\add* ؤُسِينْ-د ثْنَاينْ ن يرْيَازنْ، أَيْثْ إِ وَارْ إِسكّْوِينْ، ؤُشَا قِّيمنْ قِيبَاتْشْ نّسْ. إِرْيَازنْ إِ وَارْ إِسكّْوِينْ شهْذنْ خَاسْ، خْ نابُوثْ، زَّاثْ إِ ڒْڭنْسْ، نَّانْ: ”نابُوثْ إِشقّفْ ذِي سِيذِي ؤُ ذڭْ ؤُجدْجِيذْ.“ \add خنِّي\add* سُّوفّْغنْ ث بَارَّا إِ ثنْذِينْثْ ؤُشَا أَرجْمنْ ث أَڒَامِي إِمُّوثْ.
\v 14 \add أَوَارْنِي أَسْ\add* جِّينْ أَذْ إِنِينْ إِ إِزَابَالْ: ”نابُوثْ إِتّْوَارْجمْ ؤُ إِمُّوثْ.“
\v 15 ؤُمِي ثسْڒَا إِزَابَالْ أَقَا نابُوثْ إِتّْوَارْجمْ، إِمُّوثْ، إِمْسَارْ، أَقَا إِزَابَالْ ثنَّا إِ أَخَابْ: ”كَّارْ، كْسِي أَمَارْجعْ ن ؤُضِيڒْ ن نابُوثْ، أَيَازْرَاعِيلِي، ذ ڒْوَارْثْ، \add أَحْوِيشْ\add* إِ يُوڭِينْ نتَّا أَذْ أَشْ ث إِوْشْ س \add تّْمنْيَاثْ ن\add* نُّوقَّارْثْ، مَاغَارْ نابُوثْ وَارْ إِدَّارْ شَا \add عَاذْ\add*، مَاشَا إِمُّوثْ.“
\v 16 ؤُمِي إِسْڒَا أَخَابْ، بلِّي نابُوثْ إِمُّوثْ، إِمْسَارْ، أَقَا أَخَابْ إِكَّارْ، مَاحنْذْ أَذْ إِهْوَا غَارْ ؤُمَارْجعْ ن ؤُضِيڒْ ن نابُوثْ، أَيَازْرَاعِيلِي، حِيمَا أَذْ ث إِكْسِي ذ ڒْوَارْثْ.
\m 
\v 17 \add خنِّي\add* يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ إِلِييَا، أَثِيشْبِي، إِنَّا:
\v 18 ”كَّارْ، هْوَا، حِيمَا أَذْ ثمّڒْقِيذْ أَكْ-ذ أَخَابْ، أَجدْجِيذْ ن إِسْرَائِيل، ونِّي \add إِدْجَانْ\add* ذِي سَامَارْيَا. خْزَارْ، نتَّا ذڭْ ؤُمَارْجعْ ن ؤُضِيڒْ ن نابُوثْ مَانِي غَارْ د-إِهْوَا، حِيمَا أَذْ ث إِكْسِي ذ ڒْوَارْثْ.
\v 19 إِتّْخصَّا أَذْ كِيذسْ ثسِّيوْڒذْ، أَذْ ثِينِيذْ: ’أَمُّو إِ إِقَّارْ سِيذِي: مَا ثنْغِيذْ ؤُ \add خنِّي\add* ثكّْسذْ ؤُڒَا ذ ثَاسْغَارْثْ؟‘ \add عَاوذْ\add* إِتّْخصَّا أَذْ كِيذسْ ثسِّيوْڒذْ، أَذْ ثِينِيذْ: ’أَمُّو إِ إِقَّارْ سِيذِي: ذڭْ ومْشَانْ مَانِي ڒسْحنْ إِطَانْ إِذَامّنْ ن نابُوثْ، أَذْ ڒسْحنْ إِطَانْ ؤُڒَا ذ إِذَامّنْ نّشْ، \add وَاهْ،\add* ذ إِنِّي نّشْ!‘ “
\m 
\v 20 إِنَّا أَخَابْ إِ إِلِييَا: ”مَا ثُوفِيذْ أَيِي، شكْ، ڒعْذُو إِنُو؟“ نتَّا إِنَّا: ”نشّْ ؤُفِيغْ شكْ مِينْزِي شكْ ثزّنْزذْ إِخفْ نّشْ، مَاحنْذْ أَذْ ثڭّذْ مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي.
\v 21 خْزَارْ نشّْ أَذْ خَاكْ سِّيوْضغْ ڒْغَارْ ؤُ أَذْ مْحِيغْ مِينْ إِقِّيمنْ نّشْ. أَذْ ثحِّيغْ مَارَّا وِي ث إِتّڭّنْ خْ ڒْحِيضْ، \add أَمْ\add* ونِّي إِتّْوَاطّْفنْ، \add أَمْ\add* ونِّي ؤُمِي جِّينْ ذِي إِسْرَائِيل. \x ◘ \xo 21:‏21 \xt 2 إِج. 9‏:‏7، 8، 9\x*
\v 22 نشّْ أَذْ أَرّغْ ثَادَّارْثْ نّشْ أَمْ ثَادَّارْثْ ن يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، ؤُ أَمْ ثَادَّارْثْ ن بَاعْشَا، مِّيسْ ن أَخِييَا، زِي سِّيبّثْ ن وسْعَارْ إِ زِي \add ذ أَيِي\add* ثسْعَارذْ، ؤُ ؤُمِي ثَارِّيذْ إِسْرَائِيل أَذْ إِخْضَا.“ \x ◘ \xo 21:‏22 \xt 1 إِج. 15‏:‏29؛ 16‏:‏3، 11\x*
\v 23 إِسِّيوڒْ سِيذِي ؤُڒَا خْ إِزَابَالْ، إِنَّا: ”إِطَانْ أَذْ شّنْ إِزَابَالْ غَارْ ڒْحِيضْ ن زَّاثْ ن يَازْرَاعِيلْ. \x ◘ \xo 21:‏23 \xt 2 إِج. 9‏:‏35، 36، 37\x*
\v 24 مَانْ ونْ زِي أَخَابْ إِ غَا إِمُّوثنْ ذِي ثنْذِينْثْ، أَذْ ث شّنْ إِطَانْ ؤُ مَانْ ونْ إِ غَا إِمُّوثنْ ذڭْ إِيَّارْ أَذْ ث شّنْ إِجْضَاضْ ن ؤُجنَّا.“
\m 
\v 25 ؤُڒَا ذ إِجّْ وَارْ إِدْجِي \add عمَّارْصْ\add* أَمْ أَخَابْ إِ إِزّنْزنْ إِخفْ نّسْ، حِيمَا أَذْ يڭّْ \add مِينْ إِدْجَانْ ذ\add* أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، أَمْ ث ثْعَارّنْ ثمْغَارْثْ نّسْ إِزَابَالْ. \x ◘ \xo 21:‏25 \xt 1 إِج. 16‏:‏33\x*
\v 26 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ جّْعِيفشْثْ أَڒْ طَّارْفْ ؤُمِي يَاردّفْ إِميْضَا \add ن لْ-أَصْنَامْ نْسنْ\add* ؤُ \add ؤُمِي إِڭَّا\add* عْلَاحْسَابْ مَارَّا مِينْ إِڭِّينْ إِمُورِييّنْ نِّي ثُوغَا إِسُّوفّغْ سِيذِي زِي ڒْوَارْثْ زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل.
\m 
\v 27 ؤُمِي إِسْڒَا أَخَابْ أَوَاڒنْ-أَ، إِبْذَا أَذْ إِشَارّڭْ أَرُّوضْ نّسْ، يَارْضْ إِشْثْ ثْخَانْشثْ \add ن وشْضَانْ\add* خْ أَرِّيمثْ نّسْ، إِژُومّْ. عَاوذْ إِطّصْ ذڭْ إِشْثْ ن ثْخَانْشثْ ؤُ يُويُورْ س أَرخْوَانْ.
\v 28 \add خنِّي\add* يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ إِلِييَا، أَثِيشْبِي، إِنَّا:
\v 29 ”مَا ثژْرِيذْ مَامّشْ إِسّهْوَا أَخَابْ إِخفْ نّسْ زَّاثْ إِ وُوذمْ إِنُو؟ مِينْزِي إِسّهْوَا إِخفْ نّسْ زَّاثْ إِ وُوذمْ إِنُو، نشّْ وَارْ سِّيكّْوِيضغْ ڒْغَارْ ذڭْ وُوسَّانْ نّسْ، مَاشَا ذڭْ وُوسَّانْ ن مِّيسْ أَذْ سِّيوْضغْ ڒْغَارْ خْ ثَادَّارْثْ نّسْ.“
\b
\b
\c 22
\s1 أَمنْغِي أَكْ-ذ أَرَامْ خْ رَامُوثْ ذِي جِيلْعَاذْ
\m 
\v 1 ثْڒَاثَا ن إِسڭّْوُوسَا حْضَانْ نِيثْنِي ڒْهُوذْنثْ، وَارْ ذِينْ ثُوغِي أَمنْغِي جَارْ أَرَامْ ذ إِسْرَائِيل. \x ◘ \xo 22:‏1 \xt [2 إِم. 18‏:‏2‏-‏34]\x*
\v 2 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثَا، ڒَامِي د-إِهْوَا يَاهُوشَافَاطْ، أَجدْجِيذْ ن يَاهُوذَا، غَارْ ؤُجدْجِيذْ ن إِسْرَائِيل، إِمْسَارْ،
\v 3 أَقَا أَجدْجِيذْ ن إِسْرَائِيل إِنَّا إِ إِمْسخَّارنْ نّسْ: ”مَا ثسّْنمْ أَقَا رَامُوثْ ذِي جِيلْعَاذْ نّغْ؟ مَا إِتّْخصَّا أَنغْ أَذْ نحْضَا ڒْهُوذْنثْ، وَارْ ثنْ نتّكّسْ زڭْ ؤُفُوسْ ن ؤُجدْجِيذْ ن أَرَامْ؟“
\v 4 \add خَاسْ ؤُشَا\add* إِنَّا إِ يَاهُوشَافَاطْ ”زعْمَا أَذْ كِيذِي ثفّْغذْ غَارْ ؤُمنْغِي أَكْ-ذ رَامُوثْ ذِي جِيلْعَاذْ؟“ إِنَّا يَاهُوشَافَاطْ إِ ؤُجدْجِيذْ ن إِسْرَائِيل: ”نشّْ \add أَذْ إِڒِيغْ\add* أَمْ شكْ، ڒْڭنْسْ إِنُو أَمْ ڒْڭنْسْ نّشْ، إِيْسَانْ إِنُو أَمْ ييْسَانْ نّشْ.“
\m 
\v 5 إِنَّا يَاهُوشَافَاطْ \add عَاوذْ\add* إِ ؤُجدْجِيذْ ن إِسْرَائِيل: ”سقْسَا عَافَاكْ أَسّْ-أَ خْ وَاوَاڒْ ن سِيذِي.“
\v 6 \add خنِّي\add* إِسّْمُونْ ؤُجدْجِيذْ ن إِسْرَائِيل إِنَابِييّنْ، عْڒَاحَاڒْ أَربْعَا-مْيَا ن يرْيَازنْ، إِنَّا أَسنْ: ”مَا أَذْ فّْغغْ غَارْ ؤُمنْغِي غَارْ رَامُوثْ ذِي جِيلْعَاذْ نِيغْ أَذْ ث جّغْ؟“ نِيثْنِي نَّانْ: ”ڭعّذْ، مَاغَارْ سِيذِي إِنُو أَذْ ثنْ إِوْشْ ذڭْ ؤُفُوسْ ن ؤُجدْجِيذْ.“
\v 7 \add مَاشَا\add* يَاهُوشَافَاطْ إِنَّا: ”مَا وَارْ ذَا شَا إِجّْ ن ؤُنَابِي ن سِيذِي، \add مَاحنْذْ أَذْ نْزمَّارْ\add* أَذْ ث نسّقْسَا نشِّينْ؟“
\v 8 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ ن إِسْرَائِيل إِ يَاهُوشَافَاطْ: ”أَقَا عَاذْ ذَا إِجّْ ن ورْيَازْ إِ زَّايسْ نْزمَّارْ أَذْ نسّقْسَا سِيذِي. مَاشَا نشّْ شَارْهغْ ث، مَاغَارْ نتَّا وَارْ ذ أَيِي إِتّْنبَّاعمَّارْصْ س مِينْ إِصبْحنْ، مَاشَا مْغِيرْ س \add مِينْ إِدْجَانْ\add* ذ أَعفَّانْ. أَقَا-ث ذ مِيخَا-يَاهُو، مِّيسْ ن يِيمْلَا.“ إِنَّا يَاهُوشَافَاطْ: ”وَارْ إِدْجِي أَمُّو إِ غَا إِسِّيوڒْ أَجدْجِيذْ!“
\v 9 \add خنِّي\add* إِڒَاغَا-د ؤُجدْجِيذْ ن إِسْرَائِيل إِ يِيجّْ ن ؤُمْسخَّارْ أَمْشنّعْ، إِنَّا: ”ذغْيَا، أَوِي-د مِيخَا-يَاهُو، مِّيسْ ن يِيمْلَا!“
\v 10 أَجدْجِيذْ ن إِسْرَائِيل ذ يَاهُوشَافَاطْ، أَجدْجِيذْ ن يَاهُوذَا، قِّيمنْ \add ذِينْ\add*، كُوڒْ إِجّْ خْ ڒْعَارْشْ نّسْ، يَارْضنْ س وَارُّوضْ ن إِجدْجِيذنْ خْ وَازَّايْ ن ؤُنذْرَارْ غَارْ ؤُقمُّومْ ن ثوَّارْثْ \add ن ثنْذِينْثْ\add* ن سَامَارْيَا ؤُ مَارَّا إِنَابِييّنْ ثُوغَا تّْنبَّانْ زَّاثْ إِ وُوذمْ نْسنْ. \f ◼ \fr 22:‏10 \ft \bd ’أَزَّايْ‘\bd* - نِيغْ ’أَنذْرَارْ‘\f*  \x ◘ \xo 22:‏10 \xt 2 إِم. 18‏:‏9\x*
\v 11 صِيذْقِييَا، مِّيسْ ن كَانْعَانَا، ثُوغَا إِڭَّا إِ إِخفْ نّسْ أَشَّاونْ ن وُوزَّاڒْ، إِنَّا: ”أَمُّو إِ إِنَّا سِيذِي: ’س يِينَا إِ غَا ثسّْنُوقّْبذْ أَيْثْ ن أَرَامْ أَڒْ ثنْ غَا ثقْضِيضْ.‘ “
\v 12 مَارَّا إِنَابِييّنْ ثُوغَا تّْنبَّانْ كِيفْكِيفْ، نَّانْ: ”ڭعّذْ غَارْ رَامُوثْ ذِي جِيلْعَاذْ، أَذْ ثِيڒِيذْ ثْفڒْحذْ، \add مِينْزِي\add* سِيذِي أَذْ ثنْ إِوْشْ ذڭْ ؤُفُوسْ ن ؤُجدْجِيذْ.“
\m 
\v 13 أَرقَّاسْ نِّي ثُوغَا إِطّْفنْ \add أَبْرِيذْ\add*، حِيمَا أَذْ إِڒَاغَا إِ مِيخَا-يَاهُو، إِسِّيوڒْ، إِنَّا:”خْزَارْ خنِّي، أَوَاڒنْ ن إِنَابِييّنْ \add أَخْمِي د-فّْغنْ\add* زڭْ إِجّْ ن ؤُقمُّومْ س ڒْخِيرْ غَارْ ؤُجدْجِيذْ. تّْزَاوْڭغْ أَذْ إِڒِينْ وَاوَاڒنْ نّشْ أَمْ وَاوَاڒنْ نْسنْ، سِيوڒْ مِينْ إِصبْحنْ.“
\v 14 \add مَاشَا\add* مِيخَا-يَاهُو إِنَّا: ”\add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي، مِينْ ذ أَيِي غَا يِينِي سِيذِي، أَذْ ث إِنِيغْ.“
\v 15 \add ؤُمِي\add* د-يُوسَا غَارْ ؤُجدْجِيذْ، إِنَّا أَسْ ؤُجدْجِيذْ: ”مِيخَا-يَاهُو، مَا أَذْ نفّغْ نشِّينْ غَارْ رَامُوثْ ذِي جِيلْعَاذْ نِيغْ أَذْ ث نجّْ؟“ إِنَّا أَسْ نتَّا: ”ڭعّذْ، أَذْ ثِيڒِيذْ ثْفڒْحذْ، مِينْزِي سِيذِي أَذْ ثنْ إِوْشْ ذڭْ ؤُفُوسْ ن ؤُجدْجِيذْ.“
\v 16 إِنَّا أَسْ ؤُجدْجِيذْ: ”مشْحَاڒْ ن ثْوَاڒَاوِينْ إِتّْخصَّا أَيِي أَذْ شكْ سّْجَادْجغْ، وَارْ ذ أَيِي ثنِّيذْ مْغِيرْ ثِيذتّْ ذڭْ يِيسمْ ن سِيذِي؟“
\v 17 ؤُشَا نتَّا إِنَّا: ”نشّْ ژْرِيغْ مَارَّا إِسْرَائِيل تّْوَابزّْعنْ خْ إِذُورَارْ أَمْ وُودْجِي وَارْ غَارْسنْ بُو ؤُمكْسَاوْ. إِنَّا سِيذِي: ’إِنَا وَارْ غَارْسنْ بُو إِسِيذِيثنْ، أجّْ \add كُوڒْ\add* أَرْيَازْ أَذْ د-إِذْوڒْ غَارْ ثَادَّارْثْ نّسْ ذِي ڒهْنَا.‘ “
\v 18 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ ن إِسْرَائِيل إِ يَاهُوشَافَاطْ: ”مَا وَارْ ذ أَشْ نِّيغْ: ’نتَّا إِتّْنبَّا خَافِي وَالُو ن مِينْ إِصبْحنْ، مْغِيرْ \add مِينْ إِدْجَانْ\add* ذ أَعفَّانْ؟‘ “
\m 
\v 19 \add خَاسْ ؤُشَا\add* إِنَّا وَانِيثَا: ”س ؤُيَا سڒْ إِ وَاوَاڒْ ن سِيذِي. نشّْ ژْرِيغْ سِيذِي إِقِّيمْ خْ ڒْعَارْشْ ذ مَارَّا ڒْعسْكَارْ ن ؤُجنَّا إِبدّْ غَارسْ، غَارْ يفُوسْ نّسْ ؤُ غَارْ ؤُزڒْمَاضْ نّسْ. \x ◘ \xo 22:‏19 \xt 2 إِم. 18‏:‏18؛ أَيُوبْ 1‏:‏6‏-‏12؛ 2‏:‏1\x*
\v 20 سِيذِي إِنَّا: ’مَانْ ونْ إِ غَا إِغْوَانْ أَخَابْ أَڒْ غَا إِڭعّذْ، أَذْ إِوْضَا ذِي رَامُوثْ ذِي جِيلْعَاذْ؟‘ وَا إِنَّا أَمُّو ؤُ وِينْ إِنَّا أَمُّو.
\v 21 \add خنِّي\add* إِفّغْ-د إِجّْ ن بُوحْبڒْ، إِبدّْ زَّاثْ إِ وُوذمْ ن سِيذِي، إِنَّا: ’نشّْ أَذْ ث غْوِيغْ.‘ سِيذِي إِسّقْسَا ث: ’س مِينْزِي؟‘
\v 22 نتَّا إِنَّا: ’نشّْ أَذْ فّْغغْ ؤُ أَذْ ذوْڒغْ ذ إِجّْ ن بُوحْبڒْ إِسّْخَارِّيقنْ ذڭْ ؤُقمُّومْ ن مَارَّا إِنَابِييّنْ نّسْ.‘ ؤُ نتَّا إِنَّا: ’أَذْ ثْفڒْحذْ مَاحنْذْ أَذْ ث ثغْوِيذْ. فّغْ، أڭّْ أَمنِّي!‘
\v 23 \add خنِّي\add* ڒخُّو، سِيذِي إِوْشَا إِجّْ ن بُوحْبڒْ إِسّْخَارِّيقنْ ذڭْ ؤُفُوسْ ن مَارَّا إِنَابِييّنْ نْومْ ؤُشَا سِيذِي إِبَارّحْ خَاكْ س ڒْغَارْ.“
\v 24 \add خنِّي\add* إِقَارّبْ-د صِيذْقِييَا، مِّيسْ ن كَانْعَانَا، غَارْ مِيخَا-يَاهُو، إِوْثِي ث غَارْ ؤُغسْمِيرْ، إِنَّا: ”مَانِي \add خنِّي\add* ثُوغَا زَّايِي إِعْذُو أَرُّوحْ ن سِيذِي حِيمَا أَذْ كِيذكْ إِسِّيوڒْ؟“
\v 25 إِنَّا مِيخَا-يَاهُو: ”خْزَارْ، أَذْ ث ثْژَارذْ ذڭْ وَاسّْ نِّي ذِي غَا ثمْهَافذْ زڭْ \add إِجّْ ن\add* وخَّامْ غَارْ وخَّامْ \add نّغْنِي\add*، حِيمَا أَذْ ثسّْنُوفَّارذْ إِخفْ نّشْ.“ \x ◘ \xo 22:‏25 \xt 1 إِج. 20‏:‏30؛ 2 إِم. 18‏:‏24\x*
\v 26 أَجدْجِيذْ ن إِسْرَائِيل إِنَّا: ”طّْفمْ مِيخَا-يَاهُو، نذْهمْ ث غَارْ أَمُونْ، ڒْحَاكمْ ن ثنْذِينْثْ، ؤُ غَارْ يُووَاشْ، مِّيسْ ن ؤُجدْجِيذْ.
\v 27 أَذْ ثِينِيذْ: ’أَمُّو إِ إِقَّارْ ؤُجدْجِيذْ: نْضَارمْ وَا ذِي ڒحْبسْ ؤُ سشّمْ ث س وغْرُومْ ن ڒحْصَارثْ ؤُ س وَامَانْ ن ڒحْصَارثْ أَڒْ د غَاعقْبغْ ذِي ڒهْنَا.‘ “
\v 28 مِيخَا-يَاهُو إِنَّا: ”مَاڒَا شكْ ثْعقْبذْ-د \add س ثِيذتّْ\add* ذِي ڒهْنَا، أَقَا سِيذِي وَارْ زَّايِي إِسِّيوڒْ!“ نتَّا إِنَّا \add عَاوذْ\add*: ”سْڒمْ، ڒڭْنُوسْ، مَارَّا \add كنِّيوْ\add*!“ \x ◘ \xo 22:‏28 \xt مِيخَا 1‏:‏2\x*
\m 
\v 29 \add خنِّي\add* إِڭعّذْ ؤُجدْجِيذْ ن إِسْرَائِيل أَكْ-ذ يَاهُوشَافَاطْ، أَجدْجِيذْ ن يَاهُوذَا، غَارْ رَامُوثْ ذِي جِيلْعَاذْ.
\v 30 إِنَّا ؤُجدْجِيذْ ن إِسْرَائِيل إِ يَاهُوشَافَاطْ: ”نشّْ أَذْ بدّْڒغْ أَرُّوضْ، \add خنِّي\add* أَذْ د-فّْغغْ غَارْ ؤُمنْغِي. شكْ \add مَاشَا\add* \add ثْزمَّارذْ\add* أَذْ ثْيَارْضذْ أَرُّوضْ نّشْ!“ أَجدْجِيذْ ن إِسْرَائِيل إِڭَّا أَرُّوضْ وَارْ إِدْجِي نّسْ، إِفّغْ-د غَارْ ؤُمنْغِي.
\v 31 أَجدْجِيذْ ن أَرَامْ ثُوغَا يُومُورْ إِ ڒْقبْطَانَاثْ ن إِكَارُّوثنْ \add ن ؤُمنْغِي\add*، إِنِّي زَّايْسنْ غَارسْ ثْنَاينْ ؤُ-ثْڒَاثِينْ، إِنَّا: ”إِتّْخصَّا أَومْ وَارْ تّْمنْغِيمْ أَكْ-ذ ؤُمقّْرَانْ نِيغْ أَكْ-ذ ؤُمژْيَانْ، مْغِيرْ أَكْ-ذ ؤُجدْجِيذْ ن إِسْرَائِيل!“
\v 32 ؤُمِي ڒْقبْطَانَاثْ ن إِكَارُّوثنْ \add ن ؤُمنْغِي\add* ژْرِينْ يَاهُوشَافَاطْ، إِمْسَارْ، أَقَا نِيثْنِي نَّانْ: ”أَقَا ذ وَا، أَجدْجِيذْ ن إِسْرَائِيل!“ نِيثْنِي ميّْڒنْ خَاسْ حِيمَا أَكِيذسْ مّنْغنْ، مَاشَا يَاهُوشَافَاطْ إِسْغُويْ.
\v 33 ؤُمِي ژْرِينْ ڒْقبْطَانَاثْ ن إِكَارُّوثنْ \add ن ؤُمنْغِي\add*، أَقَا نتَّا ثُوغَا وَارْ إِدْجِي ذ أَجدْجِيذْ ن إِسْرَائِيل، إِمْسَارْ، أَقَا ذوْڒنْ-د، \add وَارْ ث أَردّْفنْ عَاذْ\add*.
\m 
\v 34 \add خنِّي\add* إِعيّنْ إِجّْ ن ورْيَازْ س ڒْقوْسْ س ڒْبَاڒْ نّسْ ذ أَشمْڒَاڒْ ؤُشَا إِڒْقفْ أَجدْجِيذْ ن إِسْرَائِيل جَارْ وَاوَاضنْ ن وَارُّوضْ ن وُوزَّاڒْ. \add ڒخْذنِّي\add* إِنَّا وَانِيثَا إِ ونِّي إِندّْهنْ أَكَارُّو: ”قْڒبْ أَفُوسْ نّشْ، سُوفّغْ أَيِي زِي ڒْعسْكَارْ، مَاغَارْ إِيْزْمغْ أَطَّاسْ.“
\v 35 ذڭْ وَاسّْ نِّي إِذْوڒْ ؤُمنْغِي يوْعَارْ أَطَّاسْ. إِقِّيمْ ؤُجدْجِيذْ إِبدّْ ذڭْ ؤُكَارُّو \add ذڭْ ؤُمنْغِي\add* أَكْ-ذ أَيْثْ ن أَرَامْ، مَاشَا غَارْ ثْمذِّيثْ إِمُّوثْ. إِذَامّنْ ن ؤُيزِّيمْ ثُوغَا ؤُزّْڒنْ ذڭْ ؤُعذِّيسْ ن ؤُكَارُّو.
\v 36 غَارْ ؤُغدْجَايْ ن ثْفُوشْثْ جِّينْ أَذْ بَارّْحنْ س جّهْذْ ذِي مَارَّا ڒْعسْكَارْ، نَّانْ: ”\add كُوڒْ\add* أَرْيَازْ \add أَذْ د-إِعْقبْ\add* غَارْ ثنْذِينْثْ نّسْ ؤُ \add كُوڒْ\add* أَرْيَازْ غَارْ ثمُّورْثْ نّسْ!“
\v 37 إِمُّوثْ ؤُجدْجِيذْ، إِوْينْ ث غَارْ سَامَارْيَا. نِيثْنِي نضْڒنْ أَجدْجِيذْ ذِي سَامَارْيَا.
\v 38 سِّيرْذنْ أَكَارُّو ذڭْ ؤُيڒْمَامْ ن سَامَارْيَا ؤُشَا ڒسْحنْ إِطَانْ إِذَامّنْ نّسْ، مَانِي ثِيمْغَارِينْ ن فَارْقْ-شّْغڒْ سِّيرْذنْثْ ذَايسْ، عْلَاحْسَابْ أَوَاڒْ ن سِيذِي إِ ثُوغَا إِنَّا.
\m 
\v 39 إِمزْرُوينْ إِقِّيمنْ ن أَخَابْ، ذ مَارَّا مِينْ إِڭَّا ذ ثَادَّارْثْ ن ڒْعَاجْ إِ إِبْنَا ذ مَارَّا ثِيندَّامْ إِ إِبْنَا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل؟
\v 40 أَخَابْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. مِّيسْ أَخَازْيَا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\b
\s1 يَاهُوشَافَاطْ، أَجدْجِيذْ ن يَاهُوذَا
\m 
\v 41 يَاهُوشَافَاطْ، مِّيسْ ن أَسَا، إِذْوڒْ ذ أَجدْجِيذْ خْ إِسْرَائِيل، ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعَا ن أَخَابْ، أَجدْجِيذْ ن إِسْرَائِيل. \x ◘ \xo 22:‏41 \xt [2 إِم. 20‏:‏30‏-‏37؛ 21‏:‏1] — 2 إِم. 20‏:‏31\x*
\v 42 يَاهُوشَافَاطْ \add ثُوغَا\add* غَارسْ خمْسَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا، ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ خمْسَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ أَزُوبَا، يدْجِيسْ ن شَالْخِي.
\v 43 نتَّا يُويُورْ ذِي مَارَّا ثِيبْرِيذِينْ ن بَابَاسْ أَسَا، وَارْ خَاسنْثْ إِحيّذْ شَا. نتَّا إِڭَّا \add مِينْ إِدْجَانْ\add* نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي.
\v 44 ڒڭْعُوذِي وَارْ تّْوَاكّْسنْثْ. ڒْڭنْسْ يِيوِي عَاذْ ثِيغَارْصَا ذ ثوْهِيبِينْ ن ڒبْخُورْ خْ ڒڭْعُوذِي.
\v 45 يَاهُوشَافَاطْ إِحْضَا خْ ڒهْنَا أَكْ-ذ ؤُجدْجِيذْ ن إِسْرَائِيل.
\m 
\v 46 إِمزْرُوينْ إِقِّيمنْ ن يَاهُوشَافَاطْ، ذ ثْمڭَّا نّسْ إِمحْضنْ إِ إِڭَّا ذ مَامّشْ إِمّْنغْ، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن يَاهُوذَا؟
\m 
\v 47 نتَّا إِمْحَا إِمثْليّنْ إِقِّيمنْ زِي ثمُّورْثْ، إِنِّي ثُوغَا إِقِّيمنْ زڭْ وُوسَّانْ ن بَابَاسْ أَسَا.
\v 48 ذِي إِذُومْ وَارْ ثُوغِي \add ذِينْ\add* شَا ن ؤُجدْجِيذْ، \add مَاشَا\add* إِجّْ ن لْوَالِي ن ؤُجدْجِيذْ.
\v 49 يَاهُوشَافَاطْ إِڭَّا إِغَارُّوبَا ن ثَارْشِيشْ، حِيمَا أَذْ نذْهنْ غَارْ ؤُفِيرْ أَذْ أَوْينْ ؤُرغْ. \add مَاشَا\add* وَارْ د-فِّيغنْ شَا، مَاغَارْ إِغَارُّوبَا أَرْژِينْ غَارْ عِيصْيُونْ-جَابَارْ.
\v 50 خنِّي إِنَّا أَخَازْيَا، مِّيسْ ن أَخَابْ، إِ يَاهُوشَافَاطْ: ”أجّْ إِمْسخَّارنْ إِنُو أَذْ نذْهنْ أَكْ-ذ إِمْسخَّارنْ نّشْ خْ إِغَارُّوبَا!“، \add مَاشَا\add* يَاهُوشَافَاطْ يُوڭِي.
\v 51 يَاهُوشَافَاطْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نتَّا إِتّْوَانْضڒْ جَارْ ڒجْذُوذْ نّسْ ذِي ثنْذِينْثْ ن بَابَاسْ ذَاوُوذْ. مِّيسْ يَاهُورَامْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\b
\s1 أَخَازْيَا، أَجدْجِيذْ ن إِسْرَائِيل
\m 
\v 52 أَخَازْيَا، مِّيسْ ن أَخَابْ، إِذْوڒْ ذ أَجدْجِيذْ خْ إِسْرَائِيل ذِي سَامَارْيَا، ذڭْ ؤُسڭّْوَاسْ وِيسّْ سْبعْطَاشْ ن يَاهُوشَافَاطْ، أَجدْجِيذْ ن يَاهُوذَا. نتَّا إِحْكمْ ثْنَاينْ ن إِسڭّْوُوسَا خْ إِسْرَائِيل.
\v 53 نتَّا إِڭَّا \add مِينْ إِدْجَانْ ذ\add* أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي. نتَّا يُويُورْ خْ وبْرِيذْ ن بَابَاسْ ؤُ خْ وبْرِيذْ ن يمَّاسْ ؤُ خْ وبْرِيذْ ن يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، ونِّي يَارِّينْ إِسْرَائِيل أَذْ إِخْضَا.
\v 54 نتَّا إِعْبذْ بَاعْلْ، إِبنْذقْ أَسْ. نتَّا إِسْعَارْ سِيذِي، أَربِّي ن إِسْرَائِيل، س مَارَّا مِينْ ثُوغَا إِڭَّا بَابَاسْ. 
