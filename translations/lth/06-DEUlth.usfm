\pmr CĂ« jĂ¶ kĂŻbĂ«c bino gamĂ¶ nĂŻ, âAmĂ«n!â
\pm 
\v 17 âCen myero Ă¶mak dhanĂ¶ mĂ¶rĂ¶ na bino cwarĂ¶ kidi mĂ« wang ngĂ¶m k'awodhe.â
\pmr CĂ« jĂ¶ kĂŻbĂ«c bino gamĂ¶ nĂŻ, âAmĂ«n!â
\pm 
\v 18 âCen myero Ă¶mak dhanĂ¶ mĂ¶rĂ¶ na bino mĂŻĂ¶ athĂ¶Ă¶ wang lĂŒbĂ¶ yoo na path.â
\pmr CĂ« jĂ¶ kĂŻbĂ«c bino gamĂ¶ nĂŻ, âAmĂ«n!â
\pm 
\v 19 âCen myero Ă¶mak dhanĂ¶ mĂ¶rĂ¶ na bino balĂ¶ pido k'arok, athĂŻn kic onyo dha thĂ¶Ă¶ Ă«ka mĂŻĂ¶ kĂ¶p lĂ¶Ă¶.â
