\id JHN - Teribe NT (Gen, Ruth, Jonah and other portions) -Panama 2008 (DBL -2013)
\h Juan
\toc1 Jesucristo roy pjl̈ú ëre, e jyã tara Juandë
\toc2 Juan
\toc3 Jn
\mt1 Evangelio según Juan
\mt2 Jesucristo roy pjl̈ú ëre, e jyã tara Juandë
\imt1 Kjibokwo ëre sorë
\ip Domer shäng kjl̈ara ko Juan. E judío. Dënashko ga e ma shaga ba kjl̈ara Santiago tjok. Pjl̈ara ga l̈öng parkë di bäng buk kësbang, shkung, so dl̈ung kjoyo ko Galilea l̈i sor goshko ga epga rokara Jesúsdë opping ba tjok. Kuya l̈ok ga to jek ba tjok, beno l̈öng ba oppingga shara. E irgo ga öötong beno l̈öng ba oppinggaga dogl̈o sak kjwara kjingsho pjök (12) l̈i pjeyoga bakoe. Ba oppingga woyde Jesúsdë ara ba kjl̈ara wl̈eni tak pjang kjibokwo ëre go l̈i, e Juan om go.
\ip Jesús wol̈ono, ga woshrara Sbörë iröng obi irgo ga judíoga ara l̈öng ba kjok baĩya l̈ishko l̇l̇ëm, öötong beno l̈öng kjok shto obl̈ë obl̈ë shara. Woyotjl̈ĩkoba ga kjibokwo ëre tara Juandë judíoga l̈öng kjok shto obl̈ë obl̈ë l̈i kong. Kjibokwo ëre tara ba kong l̇l̇ëno, e tara beno pjang Juan 20.31 go. Tjl̈ẽ ga «Ëre toror, miydëmi e go wl̈o ga no pjl̈uyo ichara Sbörë l̈i, e Jesús, e Sbö Wa bakoe. Ga pjãy mär ba go wl̈eni ga pjãy ber l̈öng së ĩyado Sbö tjok.»
\c 1
\s1 Tjl̈õkwo l̈i weno beno no
\q1 
\v 1 Shäng kjl̈ara ko Tjl̈õkwo.\f + \fr 1:1 \fk Tjl̈õkwo \ft l̈e l̈i, e \fk Jesucristo \ft l̈okl̈o.\f*
\q1 Kjok ëre dämär, l̇l̇ëye l̇l̇ëm obishko ga
\q2 e sök tjän.
\q1 E sök Sbö tjok,
\q2 ga e Sbö.
\q1 
\v 2 L̇l̇ëye l̇l̇ëm obishko ga
\q2 e sök Sbö tjok.
\q1 
\v 3 Ba go ga
\q2 l̇l̇ëbo tjeng kës ëre shäryara Sbörë
\q1 L̇l̇ëbo tjeng kës ĩy l̈öng ëre,
\q2 e shäryara ba go.
\q1 
\v 4 L̇l̇ëbo tjeng së kës ëre, e l̈aga erë.
\q2 Shji uunkong ber l̈öng së tjagl̈ën wl̈eni, e l̈aga erë bakoe.
\q1 Shji kong kjok miydë twaga l̈i e,
\q2 e bi kong ga iök jong shjiy wl̈eni.
\q1 
\v 5 Kjok ro sĩ l̈ishko ga
\q2 iök l̈i jong shjiy ĩyado,
\q2 e sjëya kjok ro sĩ l̈irë ga äe.
\p 
\v 6 Eebor ga domer weno shäng kjl̈ara ko Juan, e ichaga Sbörë.
\v 7 Ichara Iök Shjiy l̈i\f + \fr 1:7 \fk Iök Shjiy \ft l̈e l̈i, e \fk Jesucristo \ft l̈okl̈o.\f* roy l̈ë oba kong, nopga uunkong mär ber l̈öng ba go wl̈o.
\v 8 Juan, e Iök Shjiy l̈i l̇l̇ëme. E shrono shäng Iök Shjiy l̈i roy l̈aga eröe.
\v 9 Iök Shjiy jl̈õkoyo l̈i, shji uunkong ber l̈öng kjok miydë ara l̈i l̈aga erë, ga eshko ga tjwe döröe.
\p 
\v 10 Eshkoshko ga sök kjok ëre kjing go, ga kjok ëre shäryara kës ëmdë ga e ë miydaraba l̇l̇ëme.
\v 11 Öör shäng kjok baĩya l̈ishko, gueniyo wl̈okjrara ba tjëyogarë l̇l̇ëme.
\v 12 Gueniyo no kjong kjongda omwl̈okjrono, ga beno l̈öng mär ba go. Epga iara beno l̈öng Sbö wapga.
\v 13 E weno beno Sbö wapga, shji nopga wen kjok ëre kjing go dik l̇l̇ëme. E l̈aga domerdë l̇l̇ëm, e l̈aga Sbörë.
\p 
\v 14 Ga Tjl̈õkwo l̈i, e weno beno no, ga beno sök shji nopga tjok. E Data Sbö Wa kjl̈araso, e Sbö bakoe. E kjĩshko ga e dbo ara, ga ba dbo kãl̈ã ĩnoy wẽl̈ëe. E go ga Sbö wopjl̈ú l̈i, Sbö tjl̈õkwo bek l̈i, e shrono beno sök bi tjok, ĩy, kuy wl̈o.
\p 
\v 15 Juan tjl̈ẽno ba kjĩshko, tjl̈ẽ ga «Kjupäshko ga tja tjl̈ẽno bomi kong ga “No tjwe bor irgo kjl̈ara. Gueniyo tja l̇l̇ëm obishko ga sök tjän. E kjĩshko ga tjwl̈õ ara bor kjinmo” l̈oror eni. Ga l̈oror l̈i shäng kjwe» l̈e.
\p 
\v 16 Ba wopjl̈ú ara l̈i kjĩshko ga shji uunkong kjimte ĩyado.
\v 17 Dënashko ga kjok l̇l̇gwekkl̈o twara Sbörë Moisés kong, l̈e bi kong wl̈o. E goshko ga e l̇l̇ë miydoroye. Ga Sbö wopjl̈ú l̈i sorë, Sbö tjl̈õkwo bek l̈i l̇l̇ë, era miydoroy Jesucristo go.
\v 18 Sbö, e ĩga ërë l̇l̇ëme. Gueniyo ba Wa kjl̈araso l̈i, e Sbö bakoe. Data Sbö miyde sök owa l̇l̇ëm, ga e sorë l̈aga erë bi kong.
\s1 Juan No Waga tjl̈ẽno Jesús kjĩshko
\p 
\v 19-20 Pjl̈ara ga syõshtagaga Sbö kong, ba kjimtagaga Leví tjëyoga, e ichara judío tjl̈apgaga kjok l̇l̇gwega wl̈eniyo l̈öng Jerusalén kjokyo l̈irë tjl̈ẽ Juan kong ga «¿No pjl̈uyo ichara Sbörë shrono shäng l̈i, e pjare?»
\p «Tja l̇l̇ëme» l̈e ba kong wẽl̈ëe.
\p 
\v 21 Ga kjakrokara l̈ok jek obi ga «¿Eni ga pja ë? ¿Pja Elías tjwaydere?»
\p «L̇l̇ëme» l̈e ba kong.
\p Ga kjakrokara l̈ok jek obi ga «¿Sbö tjl̈õkwo l̈aga tjwe l̈ëba l̈i pjare?»
\p «L̇l̇ëme» l̈e ba kong.
\p 
\v 22 Eni ga tjl̈ẽ l̈ok ba kong ga «Eni ga pja ë l̈os borwa kong om go, roy sörwa borwa ichagaga kong wl̈o» l̈e.
\p 
\v 23 Kuya ga tjl̈ẽ ba kong l̈ok ga «Kjibokwo tara Sbö tjl̈õkwo l̈aga tek dënashko so Isaíasdë. Tjl̈ẽno beno eni:
\q1 »“Kjok dogro no l̇l̇ëmshko ga ëbo tjl̈ẽ shäng dbo go ga
\q2 ‘Irbo shäryozĩ ber bek Tjl̈apga tjwe l̈i kong’ l̈e.”\f + \fr 1:23 \ft Isaías 40.3.\f*
\m Ëbo tjl̈ẽ shäng dbo go l̈ara l̈i, e tja l̈ayde» l̈e.
\p 
\v 24 Fariseoga l̈öng eshko kjl̈öbö.
\v 25 Kuya l̈ok ga tjl̈ẽ ba kong ga «Pja no pjl̈uyo ichara Sbörë shrono shäng l̈i l̇l̇ëm, pja Elías l̇l̇ëm, pja Sbö tjl̈õkwo l̈aga tjwe l̈ëba l̈i l̇l̇ëm bakoe l̈ëp shäng eni. ¿Eni ga pja no wë ega?»
\p 
\v 26 «Nopga wër shäng di goshko. Gueniyo bomi tjrëko shäng kjl̈ara, era ë miydëmi l̈öng l̇l̇ëme.
\v 27 No tjwe bor irgo kjl̈ara l̈i e. Bek wl̈o ga tja ba drepkwota dök wl̈o l̇l̇ëm, e tjwl̈õ ara bor kjinmo anmoyõ kjĩshko»\f + \fr 1:27 \fk Drepkwota döga \ft l̈anyo, e tak pjang Mateo 3.11 go.\f* l̈e ba kong.
\p 
\v 28 L̇l̇ëbo shäryono kës eni l̈i, e shäryono Betania kjokyo, Jordán diyo kjwo kal̈ëkong, no we jer shäng di roshko l̈ishko.
\s1 Öng Wl̈ẽp Ushko So L̇l̇gwokl̈ë ichara Sbörë l̈i, e Jesús
\p 
\v 29 Wẽshko ga Jesús ĩya Juandë tek shäng tjwayde ba shwoy ga tjl̈ẽ ga «¡Ĩzĩa! Öng Wl̈ẽp Ushko So L̇l̇gwokl̈ë ichara Sbörë l̈i shäng kjwe. Shji öng ushko so zrök, owa pjang bi go l̈i l̈ö̃ya Sbörë ber dret wl̈o. Domer kjwe öng ushko so eniyo wl̈eni, owa pjang bi go l̈i l̈ö̃ya Sbörë ber dret wl̈o, shji nopga l̈öng kjok ëre kjing go kës l̈i kong.
\v 30 Kjupäshko ga tja tjl̈ẽno bomi kong ga “No tjwe bor irgo kjl̈ara. Gueniyo tja l̇l̇ëm obishko ga e sök tjän. E kjĩshko ga tjwl̈õ ara bor kjinmo” l̈oror eni. Ga l̈oror l̈i shäng kjwe.
\v 31 Tja shrono shäng no wë di goshko, e ë miyde Israel tjëyogarë wl̈o, gueniyo tja ëmdë ga ommiydono l̇l̇ëme» l̈e.
\p 
\v 32-33 Ga Juan tjl̈ẽ jek obi ga «E ë miydër shäng l̇l̇ëm obishko ga bor ichaga no wë di goshko l̈i tjl̈ẽno bor kong ga “Sbö Sëya to ter kjok dogo dwayo so dunggwo kjoyo, ga opyë ber sök ë kjing go l̈i, era nopga go Sbö Sëya iche tjwe ber kësbang ba tjok” l̈ara bor kong eni. E irgo ga tja omĩno ga Sbö Sëya to ter kjok dogo dwayo so dunggwo kjoyo, ga opyono beno sök ba go.
\v 34 Tjara omĩno eni, ga l̈ër bomi kong ga e Sbö Wa jl̈õe» l̈e.
\s1 Jesús oppinggaga bäm ĩyo
\p 
\v 35 Wẽshko ga Juan shäng eshko obi, ba oppinggaga do pjök tjok.
\v 36 Jesús ĩya shäng ga tjl̈ẽ ga «¡Ĩzĩa! Öng Wl̈ẽp Usho So L̇l̇gwokl̈ë ichara Sbörë l̈i shäng kjwe» l̈e.
\p 
\v 37 Kuya Juan oppinggaga l̈irë ga to jek l̈ok Jesús irgo.
\p 
\v 38 Ĩya Jesúsdë iröng ga tjl̈ẽ ba kong l̈ok ga «¿L̇l̇ëye woydëmiro?»
\p «Tjl̈apga no pingga, ¿pja pë buk kjone?» l̈e ba kong.
\p 
\v 39 Kuya ga tjl̈ẽ ba kong ga «Pjãy tek bor tjok, ĩmi wl̈o» l̈e. Ga to jek l̈ok ba tjok, öötong l̈öng u jong kjone sök l̈ishko. Dl̈o töy kuzong ga beno l̈öng ba tjok eshko äär jong shkë go.
\p 
\v 40 Kjl̈ara jũni ko Andrés, e Simón Pedro l̈ëng.
\v 41 Andrés opshino eshko dwayoshko ga jek öötong shäng ba shjiy l̈i shwoy ga tjl̈ẽ ba kong ga «¡Mesías\f + \fr 1:41 \fk Mesías\ft , e Hebreo tjl̈õkwo.\f* l̈i, e wl̈ẽnorwae!» l̈e ba kong. (Mesías, e no pjl̈uyo iche l̈e Sbörë l̈i l̈okl̈o).
\p 
\v 42 Eshko ga ba shjiy l̈i söra jek Jesús shwoy. Ĩya Jesúsdë ga tjl̈ẽ ba kong ga «Pja ko Simón. Pja data ko Juan. Gueniyo pja kowëba ber Cefas shara» l̈e. (Cefas, e Pedro l̈okl̈o.)\f + \fr 1:42 \ft Arameo tjl̈õkwo \fk Cefas\ft , e \fk ak \ft l̈okl̈o. Grecia so tjl̈õkwo \fk Pedro\ft , e \fk ak \ft l̈okl̈o bakoe.\f*
\s1 Felipe, Natanael, e rokara Jesúsdë
\p 
\v 43-44 Wẽshko ga Jesús jek jongya Galilea kjokyo l̈e. Jek jëk shängshko ga domer wl̈ẽna shäng kjl̈ara ko Felipe, e Betsaida so, Pedro, Andrés, e kjokyo. Felipe ĩya ga tjl̈ẽ ba kong ga «Pja tek bor tjok, pja pin wl̈o» l̈e.
\p 
\v 45 Kuya ga jek öötong shäng domer obl̈ë ko Natanael shwoy ga tjl̈ẽ ba kong ga «Tjl̈õkwo tara Moisésdë kjok l̇l̇gwekkl̈o go, ëbo tjwe kjl̈ara l̇l̇ono l̈i kjĩshko. Sbö tjl̈õkwo l̈agaga l̈öng l̈i omtono ba kjĩshko bakoe. Domer l̈ara l̈ok l̈i ĩnorwa. E ko Jesús, e Nazaret so, José wa»\f + \fr 1:45 \ft Eshko dbaryo ga Jesús, e José wa l̈ëba, miga eni l̇l̇ëme.\f* l̈e.
\p 
\v 46 Kuya ga tjl̈ẽ ba kong ga «¿Nazaret kjokyo l̈ëpdo? ¿L̇l̇ëbo pjl̈ú wen eshko l̈aga ëro?»
\p «Kjweri shji to ĩk» l̈e ba kong.
\p 
\v 47 Eshko ga jek öötong l̈öng Jesús shäng l̈ishko. Natanael ĩya Jesúsdë ga tjl̈ẽ ba kong ga «Domer tek shäng kjwe, e Israel tjëyo jl̈õkoyo, tjl̈õkwo l̈e ga jl̈õkoyo, jyõrkë l̇l̇ëm wl̈eniyo» l̈e.
\p 
\v 48 Kuya ga tjl̈ẽ ba kong ga «¿Tja no eniyo miydëp sorë?»
\p «Pja rokayde Feliperë l̇l̇ëm obishko ga pja ĩnor sök kjor jong kjl̈ara ko \tl higuera\tl* l̈i dirko» l̈e ba kong.
\p 
\v 49 Kuya ga tjl̈ẽ ba kong ga «Tjl̈apga no pingga, Sbö Wa l̈i pja, Israel tjëyo pjl̈uyo l̈i pja bakoe» l̈e.
\p 
\v 50 Kuya ga tjl̈ẽ ba kong ga «Tja tjl̈ẽno bop kong ga “Pja ĩnor sök kjor jong kjl̈ara ko \tl higuera\tl* l̈i dirko” l̈oror eni. Tja tjl̈õkwo kjrorop e kjĩshko. Ga l̇l̇ëbo ĩp kësbang, ĩnop kjwe kjinmo» l̈e.
\v 51 Ga tjl̈ẽ ba kong obi ga «L̈ër bop kong jl̈õkoyo ga l̇l̇ono ga ĩp ga kjok dogo roshwing, ga Sbö parkagaga kjok dogo so jem l̈öng, ter l̈öng no to ter kjok dogo dwayo ëre go» l̈e.
\c 2
\s1 Di kworkwara Jesúsdë beno kjil̇l̇gwo bo dyo dbo ara
\p 
\v 1-2 Dbargwo mya irgo ga oba orkwosmok l̈öng Caná kjokyo, e Galilea kjokyo obi. Ga Jesús öötong shäng eshko ba oppinggaga tjok, mana orkwosmoga l̈irë kjĩy. Jesús mekë sök eshko bakoe.
\p 
\v 3 Oba l̈öng orkwosmozl̈ong dbaryo l̈i shrëk wopro ga kjil̇l̇gwo bo dyo dbo ara yẽ pjitonge. Eni ga Jesús mekë tjl̈ẽ ba kong ga «Kjil̇l̇gwo bo dyo dbo ara yẽ pjitonge» l̈e.
\p 
\v 4 Kuya ga tjl̈ẽ ba kong ga «Mekë, ¿l̈ëp shäng bor kong eni ega? Tja dbaryo äätë l̇l̇ëm obi» l̈e.
\p 
\v 5 Eshko ga ba mekë tjl̈ẽ parkagaga l̈öng l̈i kong ga «L̇l̇ëye l̈e bomi kong l̈i shäryozĩ eni» l̈e.
\p 
\v 6 Judíoga sgara l̈öng orkwo shkwë yõtso enido, ba pjeyoga tek dënashko so sdëkwo sorë ga eni. E kjĩshko ga di bapkwo tjeng eshko kjwo tjer (6), shäryak ak go, kjwara kjwara di shak bayo bonkö kësbang tjung wl̈eni\f + \fr 2:6 \fk Bonkö kësbang tjung wl̈eni\ft , e \fk bayo litro pkëng (4) dik.\f* kjwo sak pjök (20) dik, l̇l̇ëm ga sak mya (30) dik.
\v 7 Eshko ga Jesús tjl̈ẽ parkagaga l̈öng l̈i kong ga «Di bapkwo kjwe dl̈ĩzĩ di go» l̈e ba kong, ga uunkong l̈i dl̈ina l̈ok beno tjeng tjung di go.
\v 8 Eshko ga tjl̈ẽ ba kong l̈ok jek obi ga «Shizĩ sira, ga sözĩ jek këm bomi kägäyo shäng wl̈e kong» l̈e.
\p Kuya l̈ok ga shäryara eni.
\v 9 Twara l̈ok ba kägäyo kongshko ga miydara l̈ok ga di l̈i kworkwara Jesúsdë beno kjil̇l̇gwo bo dyo dbo ara, gueniyo l̇l̇ë miydara ba kägäyorë shäng l̇l̇ëme. Eni ga iarashko ga domer orkwosmono l̈i rokara tek ba shwoy,
\v 10 ga tjl̈ẽ ba kong ga «Nopga uunkong orkwosmozl̈ong dbaryo shrëkshko ga kjil̇l̇gwo bo dyo dbo ara iako owa l̇l̇ëm wl̈eniyo twe nopga mak pjir l̈öng l̈i kong bäm go, ie l̈ok wl̈o. Iara l̈ok ara irgo ga kjil̇l̇gwo bo dyo dbo ara tjwl̈õ chira wl̈eniyo twe ba kong l̈ok shara. Gueniyo pjara omshäryono eni l̇l̇ëme. ¿Iako owa l̇l̇ëm wl̈eniyo l̈ira ship shäng kjwl̈ë jã egaro?» l̈e.
\p 
\v 11 L̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryara Jesúsdë bäm l̈i e, shäryara eshko Caná kjokyo, e Galilea kjokyo obi. E go ga ba dbo kãl̈ã pina ba oppinggaga kong, ga beno l̈öng mär ba go.
\v 12 E irgo ga to jek öötong shäng Capernaúm kjokyo ba mekë, ba l̈ëmga, ba oppinggaga tjok, ga beno l̈öng eshko dbar kjwöbö.
\s1 L̇l̇ëbo soynegaga l̈öng Sbö u zl̈ong bäng l̈i ichara Jesúsdë drete
\p 
\v 13 Israel tjëyoga döktong tek Egipto kjokyo dwayo dbaryo shrëkkl̈o judíoga kong l̈i dörö kjĩshko ga Jesús jek öötong shäng Jerusalén kjokyo.
\v 14 Eshko ga opzrëno jek shäng Sbö u zl̈ong bäng ga nopga wl̈ẽna l̈öng l̇l̇ëbo soynek, sögl̈a, öng wl̈ẽp ushko so, dunggwo bakoe. Nopga obl̈ë wl̈ẽna wl̈oktong l̈öng dbur kjl̈opswë.
\v 15 Ĩya Jesúsdë eni ga no shpokkl̈o shäryara pjl̈ara kjil̇l̇gwo go, ga l̈öng l̈i ichara jek eshko dwayo dret, ba öng l̇l̇ë tjok. Dbur kjl̈opswaga dburyo l̈i dbura ba shjiryo, ga ba dbur bapkwo kjl̈opswozl̈ong l̈i poskara beno tjeng töshko.
\v 16 Ga tjl̈ẽ dunggwo soynegaga l̈öng l̈i kong ga «¡Bomi dunggwo kjwe shizĩ ëre dwayo! ¡Bor Data u ëre iëmi ber jong l̇l̇ëbo soynezl̈ong uyo l̇l̇ëme!» l̈e. \fig Jesús nopga ichono opshik jek Sbö u zl̈ong bäng dwayo (Juan 2.13-16)|src="LB00316B.TIF" size="span" ref="John 2.15 "\fig*
\p 
\v 17 Eshko ga tjl̈õkwo tak pjang Sbö kjibokwoyo go l̈i woyoshrara ba oppinggagarë l̈ok kjrina. Tak pjang l̈i tjl̈ẽ ga «Tja wo pjang bop u l̈i go ĩyado. Tja ymo ara ba kjĩshko.»\f + \fr 2:17 \ft Salmo 69.9.\f*
\p 
\v 18 Eshko ga judíoga tjeng l̈i tjl̈ẽ l̈ok ba kong ga «¿L̇l̇ëye shäryëp shäng l̈i shäryëp ega? ¿Pja ichaga ërë? Pja ichaga Sbörë wl̈eni ga l̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryos borwa kong, e miydërwa e go wl̈o» l̈e.
\p 
\v 19 Kuya ga tjl̈ẽ ba kong l̈ok ga «Sbö u ëre shdözĩ ber dret, ga äär dbargwo mya ga shäryër ber jong ba shtoshko iröng obi» l̈e.
\p 
\v 20 Kuya l̈ok ga tjl̈ẽ ba kong ga «Sbö u ëre shäryëba wl̈o ga woydara l̈u pjl̈ogl̈o sak pkëng kjingsho tjer (46). ¿Ga pja omshäryë dbargwo mya l̈ëp sorëro?» l̈e.
\p 
\v 21 Gueniyo Sbö u l̈e shäng l̈i, e ba doyo om go l̈i l̈ayde.
\v 22 E irgo ga wol̈ono, ga woshrara Sbörë iröng obishko ga l̇l̇ëye l̈ara l̈i woyoshrara ba oppinggagarë l̈ok. Eshko ga Sbö tjl̈õkwo tak pjang l̈i, e kjrara l̈ok, ga Jesús tjl̈õkwo kjrara l̈ok eni bakoe.
\s1 No wotjl̈ĩk sorë, e miydara Jesúsdë pjire
\p 
\v 23 Ga nopga l̈öng Israel tjëyoga döktong tek Egipto kjokyo dwayo dbaryo l̈i shrëkshko ga Jesús shäng l̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryë Jerusalén kjokyo. Ĩya nopga l̈öng eshko l̈irë ga kjone kjone beno l̈öng mär ba go.
\v 24 Gueniyo nopga wotjl̈ĩk sorë l̈i miyde Jesúsdë shäng pjire. E kjĩshko ga tjl̈õkwo l̈ëba l̈i kjre uunkong l̇l̇ëme.
\v 25 Nopga wotjl̈ĩk l̇l̇ë, e miyde shäng pjir ĩyado. E kjĩshko ga wotjl̈ĩk sorë l̈i l̈ëba ba kong guing l̇l̇ëme.
\c 3
\s1 Jesús, Nicodemo
\p 
\v 1 Domer shäng kjl̈ara ko Nicodemo, e fariseo, judío tjl̈apga kjok l̇l̇gwega wl̈eniyo bakoe.
\v 2 Shkër kjwara ga jek öötong shäng Jesús shwoy ga tjl̈ẽ ba kong ga «Tjl̈apga no pingga, miydërwa ga pja ichaga Sbörë no ping. Sbö shäng bop tjok l̇l̇ëm kjwe ga l̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryëp shäng l̈i shäryëp ga äe» l̈e.
\p 
\v 3 Kuya ga tjl̈ẽ ba kong ga «L̈ër bop kong jl̈õkoyo ga shji uunkong weno pjl̈ara. Gueniyo ëye wen jek pjl̈ara obi l̇l̇ëm ga äär ber Sbö nopga ga äe» l̈e.
\p 
\v 4 Kuya ga tjl̈ẽ ba kong ga «¿Shji öötong këguë tjän ga shji wen obi sorë? Shji äär ber buk bi mekë bö roshko, shji wẽya jek obi wl̈o ga äe» l̈e.
\p 
\v 5 Kuya ga tjl̈ẽ ba kong ga «L̈ër bop kong jl̈õkoyo ga ëye we Sbö Sëyarë, ga wẽya ber tjagl̈ën wl̈eni l̇l̇ëm ga äär ber Sbö nopga ga äe.
\v 6 Ëye wengga norë ga ber no eröe. Ëye äär ber Sbö ĩ wl̈o ga woyde ga wengga Sbö Sëyarë.
\v 7 “Nopga uunkong wen jek obi kjl̈uwe” l̈ër bop kongshko ga pja ber sök pol̇l̇äk l̇l̇ëme.
\v 8 Pjl̈uk, e shrono ga kup ga wẽl̈ë, gueniyo tjwe jong kjone dwayo, jongya jek kjone, e miydëp l̇l̇ëme. To woydë jek kjone ga eshko. Nopga wẽya Sbö Sëyarë l̈i, e so e kjoyo bakoe» l̈e.
\p 
\v 9 Kuya ga tjl̈ẽ ba kong ga «¿L̇l̇ëye l̈ëp shäng l̈i, e sorëro?»
\p 
\v 10 «Pja Israel tjëyoga pingga. ¿Eni ga e miydëp l̇l̇ëm sorëro?
\v 11 L̈ër bop kong jl̈õkoyo ga tjl̈õkwo l̈ërwa bomi kong, e miydërwa kjĩy, l̇l̇ëbo ĩnorwa om go l̈i, e l̈orwarë, gueniyo tjl̈õkwo l̈ërwa l̈öng l̈i, e kjrëmi l̇l̇ëme.
\v 12 L̇l̇ëbo tjeng kjok ëre kjing go l̈i l̈ër shäng bomi kong, ga tjl̈õkwo kjrëmi l̇l̇ëme. ¿Eni ga l̇l̇ëbo tjeng kjok dogo l̈i l̈otë bomi kong kjwe ga tjl̈õkwo kjrëmi sorëro?
\p 
\v 13 »Ëye öör jem kjok dogo l̇l̇ëme. Gueniyo no to ter kjok dogo dwayo ëre ter shrono ey dwayo.
\v 14 Dgur jyãgl̈o poyona Moisésdë dënashko sorë ga l̇l̇ono ga tja poyongoba pjang kjomo eni bako,
\v 15 ëye mär bor go ga ber l̈öng së ĩyado Sbö tjok wl̈o.
\p 
\v 16 »Nopga l̈öng kjok ëre kjing go woyde Sbörë ara. E kjĩshko ga ba Wa kjl̈araso ëre ichara zrökoba nopga kjĩshko wl̈o, ëye mär bor go ga jer l̇l̇ëm wl̈o, ber l̈öng së ĩyado Sbö tjok wl̈o.
\v 17 Tja ichara kjok ëre kjing go no dök wl̈o, no shdung wl̈o l̇l̇ëme.
\v 18 Ëye mär bor go ga ber shdungko l̇l̇ëme. Gueniyo ëye mär bor go l̇l̇ëm ga era beno shdungko tjän, mär Sbö Wa kjl̈araso ëre go l̇l̇ëm kjĩshko.
\p 
\v 19-20 »Ëye l̇l̇ëbo owa shäryë ga woyde ga ĩga ërë l̇l̇ëme. Ga tja shrono shäng kjok ëre kjing go, iök jong shjiy wl̈eni. E kjĩshko ga tja woydara l̇l̇ëbo owa shäryagagarë l̇l̇ëm, ga beno l̈öng pjola, l̇l̇ëbo shärye l̈öng owa l̈i ber wẽl̈ë l̇l̇ëm wl̈o l̈e. Epga beno shdungko e kjĩshko.
\v 21 Gueniyo ëye jëk tjl̈õkwo bek l̈i go ga woyde l̈ok ga ber l̈öng iök jong shjiy l̈ishko, l̇l̇ëbo pjl̈ú shärye l̈öng Sbö kjĩshko l̈i ber wẽl̈ë wl̈o» l̈e ba kong.
\s1 Juan Jesús l̈ãywono
\p 
\v 22 E irgo ga Jesús jek öötong shäng Judea kjokyo ba oppinggaga tjok, ga beno l̈öng eshko dbar kjwöbö no wë jer di roshko.
\v 23-24 Kjok buk kjrina ko Enón, Salim kjokyo ber buk soshko. Enón kjokyo l̈ishko ga di ara. E kjĩshko ga Juan bängzaydëba no shdũzl̈ong uyo roshko l̇l̇ëm obishko ga shäng eshko no wë, ga nopga jek äär l̈öng ara ba shwoy, we Juandë wl̈o.
\p 
\v 25 Eshko ga Juan oppinggaga opyono l̈öng ëngl̈ë kar kar judío shäng kjl̈ara eshko l̈i tjok, shji wë di go sorë l̈i l̈ãywe l̈öng.
\v 26 Pjir ga jek öötong l̈öng Juan shwoy ga tjl̈ẽ ba kong ga «Tjl̈apga no pingga, kjupä ga domer shäng bop tjok Jordán diyo kjwo kal̈ëkong l̈i, l̈ãyworop l̈i, e shäng no wë, ga nopga l̈öng kës l̈i jek l̈öng ba shwo l̈ëkong shara» l̈e.
\p 
\v 27 Kuya ga tjl̈ẽ ba kong l̈ok ga «Ëye l̇l̇ëbo tjok ga e twaga Sbörë ba kong kjĩshko.
\v 28 “No pjl̈uyo ichara Sbörë shrono shäng l̈i, e tja l̇l̇ëme. Tja ichara jek ba bäm go erä” l̈oror bomi kong tjän, ga kuromi wẽl̈ëe.
\p 
\v 29 »Kjogl̈o shäng kjl̈ara orkwosmok wl̈o wl̈eni ga e sogo domer orkwosmok ba tjok wl̈o l̈i eröe. Domer orkwosmok wl̈o l̈i yorkaga shäng l̈i, e ber shäng wopjl̈ú, ba kjl̈ara tjl̈ẽno shäng l̈i kura kjĩshko. Tjara so domer yorkaga l̈i kjoyoe. Tja wopjl̈ú ara anmoyõ e kjĩshko.
\v 30 Bek wl̈o ga era ber tjwl̈õ ara jek këgong këgong, ga tjara ber tjwl̈õ chira.
\p 
\v 31 »Ter shrono shäng kjok dogo dwayo l̈ira tjwl̈õ ara, obl̈ë kjinmo. Ëye kjok ëre so ga e jũshko so erä, ga l̇l̇ëbo jũshko so l̈i l̈ãywayde. Ter shrono shäng kjok dogo dwayo l̈ira tjwl̈õ ara, obl̈ë kjinmo.
\v 32 L̇l̇ëbo ĩna, kura eshko l̈i, e l̈ãywayde, gueniyo ba tjl̈õkwo kjrëba l̇l̇ëme.
\v 33 Gueniyo tjl̈õkwo kjraga ë l̈i kong ga tjl̈õkwo l̈ara Sbörë ba kjĩshko l̈i, e beke l̈e.
\v 34 Jesús ichara Sbörë ba tjl̈õkwo roy l̈ë oba kong, ga e go ba Sëya twara beno ba kong kësbang anmoyõ.
\v 35 Ba Wa woyde Data Sbörë ara, ga l̇l̇ëbo tjeng kës l̈i iara beno tjeng ba wl̈oshko.
\v 36 Ëye mär ba Wa go ga beno l̈öng së Sbö tjok tjän, ga ber l̈öng eni ĩyado. Gueniyo ëye omwl̈okjrë l̇l̇ëm ga äär ber l̈öng Sbö tjok eni l̇l̇ëm, ga shdũya Sbörë ber ĩyado wl̈o bakoe» l̈e.
\c 4
\s1 Jesús l̈ano wal̈ë Samaria so tjok
\p 
\v 1-3 Jesús roy kura fariseogarë l̈ok ga nopga pĩya shäng, we shäng jer di roshko ara, Juan kjinmo, miga shäng no wë om go l̇l̇ëm, waga ba oppinggagarë l̈ok. E miydara Jesúsdë, ga to Judea kjokyo dwayo, jek jongya Galilea kjokyo iröng obi.
\v 4 Irbo l̈i jek jong Samaria kjokyo go kuzong ga
\v 5 jek öötong shäng kjok buk kjrina ko Sicar, e Samaria kjokyo obi, kjok twara Jacobdë beno ba wa José kong dënashko l̈i buk soshko.
\v 6 Eshko ga di bäng jong kjwara, shiga Jacobdë dënashko. Dl̈o dl̈uw dik ga Jesús sjeno jërbo kuzong ga sirkeno sök di bäng jong l̈i zl̈ong.
\v 7-8 Ba oppinggaga jek l̈ok u l̈ok arashko dl̈i tjwl̈ẽk, Jesúsda beno sök eshko.
\p Eshko ga wal̈ë Samaria so tek tjwe shäng kjl̈ara di shik. Wal̈ë l̈i ĩya sök ga tjl̈ẽ ba kong ga «Tja së̃s di sira» l̈e.
\p 
\v 9 Kuya ga tjl̈ẽ ba kong ga «Pja judío, ga tja wal̈ë Samaria so. ¿Eni ga tja kong di rokëp sorëro?» l̈e. (L̈ara ba kong eni, judíoga pjë Samaria sopga tjok l̇l̇ëm kjĩshko.)
\p 
\v 10 Kuya ga tjl̈ẽ ba kong ga «L̇l̇ëbo twe woydë Sbörë bop kong, gueniyo e l̇l̇ë miydëp shäng l̇l̇ëme. Ga di rokaga sök ëre, tja ë miydëp shäng l̇l̇ëm bakoe. Miydëp kjwe ga tja kong di rokorop, di shji ie ber l̈öng së jl̈õkoyo wl̈eniyo» l̈e.
\p 
\v 11 Eshko ga wal̈ë l̈i tjl̈ẽ ba kong ga «Tjl̈apga, di bäng ëre jong rong, ga pja di shikkl̈o drete. ¿Eni ga di shji ie ber l̈öng së l̈ëp sök l̈i ship sorëro?
\v 12 Bi tjl̈apga tek dënashko so Jacob di shino di bäng ëre dwayo, ga iara beno ba wapga kong, ba öng kong bakoe. Pjir ga iara beno jong bi kong. ¿Pja tjwl̈õ ara ba kjinmore?»
\p 
\v 13 «Ëye di ëre iono ga pjesit ga jek wodogro obi.
\v 14 Gueniyo di twak tjarë l̈i, ëye omiono ga ber wodogro ame. E ber pjang di shl̈äl̈ä wl̈eni, ga ie ber l̈öng së ĩyado Sbö tjok bakoe» l̈e ba kong.
\p 
\v 15 Kuya ga tjl̈ẽ ba kong ga «Tjl̈apga, di l̈ëp sök l̈i twos bor kong sira, tja wodogro ame wl̈o, tja tek shäng di shik kjër jũshko ame wl̈o bakoe» l̈e.
\p 
\v 16 Kuya ga tjl̈ẽ ba kong ga «Pja nom bop l̈anma wl̈okjrë. Wl̈ẽnop ga tek söba» l̈e.
\p 
\v 17 Kuya wal̈ë l̈irë ga tjl̈ẽ ba kong ga «Tja l̈anma drete» l̈e.
\p Kuya ga tjl̈ẽ ba kong ga «“Tja l̈anma drete” l̈ëp shäng l̈i, e l̈orop beke.
\v 18 Jl̈õkoyo ga pja l̈anmaga rayono öötong dogl̈o shkëng (5) tjän, ga eerishko ga domer sök bop tjok l̈i, e bop l̈anma l̇l̇ëme. L̈ëp shäng l̈i, e l̈orop beke» l̈e.
\p 
\v 19 Kuya wal̈ë l̈irë ga tjl̈ẽ ba kong ga «Tjl̈apga, miydër ga pja Sbö tjl̈õkwo l̈aga.
\v 20 Borwa tjl̈apgaga Samaria so tek dënashko so l̈i Sbö poshrëno dl̈up ëreshko. Gueniyo pjãy judíogara tjl̈ẽ ga “Sbö, e poshrëy wl̈o ga woyde ga shäryëy eshko Jerusalén kjokyo dey” l̈ëmi eni» l̈e.
\p 
\v 21 Kuya ga tjl̈ẽ ba kong ga «Tja tjl̈õkwo kjrozong. Dbar tjwe kjwara ga Data Sbö poshrëmi wl̈o ga pjãy tek dl̈up ëre go ame, pjãy jek Jerusalén kjokyoshko ame bakoe.
\v 22 Samaria sopga, Sbö poshrëmi l̈öng l̈i miydëmi l̈öng l̇l̇ëme. Gueniyo tjawa judíoga tjrëko no shäng kjl̈ara, kjrara Sbörë ber no döga wl̈o. E kjĩshko ga Sbö poshrërwa l̈öng l̈i, e miydërwa l̈öng pjl̈úe.
\v 23 Gueniyo dbar tjwe kjwara ga ëye Data Sbö poshrëk woydë jl̈õkoyo ga e poshrëya jl̈õkoyo ba pjl̈úshko, Sbö Sëya go, woyde Sbörë sorë l̈i eni. Ga dbar tjwe l̈ër shäng l̈i, e shrono tjän.
\v 24 Sbö, e sëya. E kjĩshko ga woyde ga e poshrëy jl̈õkoyo bi pjl̈úshko, ba Sëya go» l̈e.
\p 
\v 25 Kuya ga tjl̈ẽ ba kong ga «Miydër ga no pjl̈uyo iche l̈e Sbörë l̈i tjwe.\f + \fr 4:25 \fk No pjl̈uyo iche l̈e Sbörë \ft l̈i, e kowëba \fk Cristo \ft bakoe.\f* Shrono ga l̇l̇ëbo tjeng kës l̈i pjl̈ol̇l̇gweya borwa kong drete» l̈e.
\p 
\v 26 Kuya ga tjl̈ẽ ba kong ga «Tjwe l̈ëp shäng l̈i, e tja» l̈e.
\p 
\v 27 E irgo ga Jesús oppinggaga shrono l̈ok iröng obi. Ĩya l̈ok ga sök l̈an wal̈ë tjok ga yëy l̈e erä, ga wotjl̈ĩk l̈ok ga «¿L̇l̇ëye woyde? ¿Sök l̈an wal̈ë kjwe tjok l̇l̇ëno?» l̈e, gueniyo kjakrokara l̈ok ba kong l̇l̇ëme.
\p 
\v 28 Eshko ga ba di bapkwo iara wal̈ë l̈irë beno jong eshko, ga to jongya u l̈ok arashko. Öötong shäng eshko ga tjl̈ẽ nopga kong ga
\v 29 «Domer sök këm kjl̈ara, tja, l̇l̇ëye shäryoror dö l̈i, e miyde sök pjir, ga l̈ara bor kong pjire. ¿No pjl̈uyo ichara Sbörë shrono shäng l̈i ero l̇l̇ëm? Pjãy tegö. Shji to ĩk» l̈e.
\v 30 Kuya l̈ok ga opshino to jek l̈ok ba tjok, jongya Jesús sök l̈ishko.
\p 
\v 31 E wopro ga Jesús oppinggaga tjl̈ẽ ba kong ga «Tjl̈apga no pingga, pja ios sira» l̈e l̈öng eni.
\p 
\v 32 Kuya ga tjl̈ẽ ba kong ga «Tja l̇l̇ëbo uako tjok, gueniyo l̇l̇ë miydëmi l̈öng l̇l̇ëme» l̈e.
\p 
\v 33 Kuya l̈ok ga tjl̈ẽ l̈ok ëng kong ga «¿Ëbo dl̈i söno ba kongdo?» l̈e.
\p 
\v 34 Gueniyo tjl̈ẽ ba kong l̈ok ga «L̇l̇ëye woyde bor ichagarë ga shäryër l̈e l̈i, e shäryër woydë äär jong shäryoror pjir guing. Bor kong ga pak ëre, e bor dl̈i wl̈eni.
\v 35 Pjãy tjl̈ẽ ga “Kjwe mogl̈o pkëng (4) obi ga dwl̈a bo shjiye” l̈ëmi. Gueniyo l̈ër bomi kong ga nopga tek tjeng kjwe ĩzĩa. Nopga koshëy Sbö tjl̈õkwo kjrë ame, tek l̈öng Sbö tjl̈õkwo kjrë eniwa tjok wl̈o.
\p 
\v 36 »Ëye dwl̈a skok ga dburyo shaya. Ga dwl̈a skozl̈ong dbaryo ga dwl̈a skogaga l̈i l̈öng wopjl̈ú, dwl̈a dgagaga tek dënashko l̈i l̈öng wopjl̈ú bakoe. Sbö tjl̈õkwo, e eni wl̈eni bakoe. Ëye tjl̈õkwo kjrono ga ber l̈öng së ĩyado Sbö tjok. Gueniyo eshko ga tjl̈õkwo pjl̈ol̇l̇gwegaga ba kong, kjre wl̈o l̈i, e l̈öng wopjl̈ú, tjl̈õkwo l̈agaga ba kong tek dënashko l̈i l̈öng wopjl̈ú bakoe.
\v 37 Oba tjl̈ẽ ga “Kjl̈ara dwl̈a dguë, kjl̈ara obi ba bo töng” l̈ëba eni. Eni jl̈õe.
\v 38 Pjãy ichër tjl̈õkwo pjl̈ol̇l̇gwek oba kong, kjrëba wl̈o. Gueniyo tek dënashko ga nopga obl̈ë öör l̈öng tjl̈õkwo l̈ë oba kong. Ba pak l̈i kjange. Ga l̇l̇ëbo weno pak shäryara l̈ok kjĩshko l̈i, e beno bomi kong» l̈e.
\p 
\v 39 Eshko ga Samaria sopga l̈öng kjok eshko l̈i mär beno l̈öng Jesús go ara, l̇l̇ëye l̈ara wal̈ë l̈irë ba kong l̈i kjĩshko. Tjl̈ẽno ga «L̇l̇ëye shäryoror dö l̈i, e miyde shäng pjir, ga l̈ara bor kong pjire» l̈ara ba kong l̈ok eni.
\v 40 Eni ga öötong l̈öng Jesús shwoy ga rokara ber sök ba tjok, ga beno sök eshko ba tjok dbar pjök.
\v 41 Eshko ga nopga mär beno l̈öng ba go ara obi, tjl̈õkwo l̈ara om go ba kong l̈i kjĩshko.
\v 42 Eni ga tjl̈ẽ l̈ok wal̈ë l̈i kong ga «Bäm go ga tjawa mär Jesús go, l̇l̇ëye l̈orop borwa kong l̈i kjĩshko. Gueniyo kurorwa tjawarë om go shara. E kjĩshko ga miydërwa pjl̈ú ga nopga kjok ëre so döga l̈i e» l̈e.
\s1 Domer parkaga pjl̈u kong l̈i wa poptara Jesúsdë
\p 
\v 43 Dbar pjök irgo ga Jesús opshino to eshko dwayo jongya jong Galilea kjokyo.
\v 44 (Pjl̈ara ga Jesús tjl̈ẽ ga «Kjok kjone pogo ga Sbö tjl̈õkwo l̈aga, e iëba tjwl̈õ ara. Gueniyo ba kjok om go l̈ishko ga iëba tjwl̈õ l̇l̇ëme» l̈e eni.)
\v 45 Gueniyo kjupäbä ga Jesús sök Jerusalén kjokyo, Israel tjëyoga döktong tek Egipto kjokyo dwayo dbaryo shrëzl̈ong dbaryoshko. Eshko ga l̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryara ara. Galilea sopga kjone kjone öör l̈öng eshko bako, ga l̇l̇ëye shäryara kës l̈i ĩna l̈ok. E kjĩshko ga Jesús öötong shäng Galilea kjokyoshko ga e wl̈okjrara l̈ok wopjl̈úe.
\p 
\v 46 Dbar kjwara ga Jesús jek öötong shäng Caná kjokyo jek obi. Caná kjokyo, e Galilea kjokyo obi, di kjl̈opswara beno kjil̇l̇gwo bo dyo dbo ara kjupäbäshko l̈ishko. Domer shäng kjl̈ara Capernaúm kjokyo, parkaga pjl̈u kong wl̈eniyo. Wa buk kjl̈ara swl̈o ara.
\v 47 Kuya domer l̈irë ga Jesús shrono shäng Judea kjokyo dwayo ga jek öötong shäng ba shwoy ga tjl̈ẽ ba kong ga «Bor wa swl̈o ara, buk wol̈ontoe. Rokër bop kong sira ga pja jek bor tjok bor ushko, poptëp wl̈o» l̈e.
\p 
\v 48 Kuya ga tjl̈ẽ ba kong ga «L̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryër bomi kong l̇l̇ëm ga pjãy mär bor go l̇l̇ëme» l̈e.
\p 
\v 49 Kuya domer l̈irë ga tjl̈ẽ ba kong ga «Tjl̈apga, shji to jekdo, bor wa wol̈ontë l̇l̇ëm obi tjok» l̈e.
\p 
\v 50 Kuya ga tjl̈ẽ ba kong ga «Pja nom bop ushko. Bop wa poptono tjän» l̈e.
\p Kuya ga tjl̈õkwo kjrara, ga toe.
\v 51 Wẽshko ga jëk shäng ääto ba ushko ga ba parkagaga tek l̈öng ba wl̈okjrë irbo, ga tjl̈ẽ l̈ok ba kong ga «¡Tjl̈apga, bop wa, e poptono beno pjl̈úe!» l̈e.
\p 
\v 52 Kuya ga tjl̈ẽ ba kong l̈ok ga «¿Kayo yonkë kjok orë?»
\p «Kjl̈ik l̈i zeno kjupke dl̈o jõya kjwl̈ëshko» l̈e l̈ok ba kong.
\p 
\v 53 Eshko ga miydara domer l̈irë ga Jesús tjl̈ẽno ga «Bop wa poptono tjän» l̈ara ba kong l̈i, e dl̈oyo e go. Eni ga beno shäng mär Jesús go, ba pjeyoga l̈öng ba ushko uunkong tjok.
\p 
\v 54 Jesús tek Judea kjokyo dwayo shrono shäng Galilea kjokyo irgo ga l̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryara e tjok ga öötong pjl̈ogl̈o pjök tjän.
\c 5
\s1 Woshtozl̈ong dbaryo ga domer jëk l̇l̇ëm wl̈eniyo poptara Jesúsdë kjl̈ara
\p 
\v 1 Öötong dbar shrëzl̈ong dbaryo judíoga kong obl̈ëshko ga Jesús jek öötong shäng Jerusalén kjokyo obi.
\v 2 Shji opzrëk jek Jerusalén kjokyo roshko u bäng bängyo ko Öng Wl̈ẽp Ushko So l̈i goshko ga shji jek jëk sira wl̈eni ga di bapkwo shäryak buk eshko kjwara kësbang, roshko di, arameo tjl̈õkwo go ko Betzata. Ba kopshko ga u tjeng kjwo shkëng (5), di bapkwo l̈i sor go pjribrie.
\v 3-4 Swl̈opga obl̈ë obl̈ë tjeng töshko eshko ara, nopga kjok ĩgö l̇l̇ëm wl̈eniyo, nopga jëk l̇l̇ëm wl̈eniyo, nopga dre kuga l̇l̇ëm wl̈eniyo bakoe.\f + \fr 5:3-4 \ft Tek dënashko ga kjibokwo ëre jyã shiraba obl̈ë obl̈ë ara. Ga kjone kjone tjl̈ẽ ga «Swl̈opga obl̈ë obl̈ë tjeng töshko eshko ara, no kjok ĩgö l̇l̇ëm wl̈eniyo, no jëk l̇l̇ëm wl̈eniyo, no dre kuga l̇l̇ëm wl̈eniyo bakoe. Ga l̈öng di buk l̈i dgön koshë. Ol̈ö ga Sbö parkaga kjok dogo so ter tjwe kjl̈ara, ga di buk l̈i rorwe, dgön wl̈o. Eshko ga ëye opzrëk jer di l̈i roshko bäm go ga poptë jekdo.»\f*
\v 5 Buk kjl̈ara eshko jëk l̇l̇ëm wl̈eniyo. E öötong l̈u pjl̈ogl̈o sak mya kjingsho kjwong (38).
\v 6 Eni ga Jesús jek öötong shäng eshko ga buk l̈i ĩna, ga buk eshko öötong l̈u kop ara l̈i miydara, ga tjl̈ẽ ba kong ga «¿Pja poptë woydëre?»
\p 
\v 7 «Tjl̈apga, di kjwe l̈uywëshko ga tja opl̈ong woydë ba roy, gueniyo tja kjimtaga ërë l̇l̇ëme. Tja drön ara, opl̈ong om go wl̈o l̈ërshko ga obl̈ë opl̈ono bor bäm go tjän» l̈e.
\p 
\v 8 Kuya ga tjl̈ẽ ba kong ga «Pja kojõzong. Bop bukkl̈o buk kjwe kjros, ga pja jëkzong» l̈e ba kong.
\v 9 Jekdo eshko ga poptono, ba bukkl̈o buk l̈i kjrara, ga jëktonge.
\p Eshko ga woshtozl̈ong dbaryo.
\v 10 Eni ga domer l̈i ĩya judío tjl̈apgagarë l̈ok ga tjl̈ẽ l̈ok ba kong ga «Eeri ga woshtozl̈ong dbaryo. Bi bukkl̈o, e söy wl̈o ga äe» l̈e.
\p 
\v 11 Kuya ga tjl̈ẽ ba kong l̈ok ga «Bor poptaga tjl̈ẽno bor kong ga “Bop bukkl̈o kjwe kjros, ga pja jëkzong” l̈ara bor kong eni» l̈e.
\p 
\v 12 Eni ga tjl̈ẽ l̈ok ba kong ga «¿L̈aga ërë bop kong eni?» l̈e.
\v 13 Gueniyo e ë miydara l̇l̇ëm, poptono pjirshko ga Jesús opjneno jek nopga tjeng ara l̈i tjrëko kjĩshko.
\p 
\v 14 E irgo ga domer l̈i wl̈ẽna Jesúsdë öötong sök Sbö u zl̈ong bäng, ga tjl̈ẽ ba kong ga «Tja kuzong. Pja poptono beno shäng pjl̈úe. Gueniyo l̇l̇ëbo owa shäryëp ame, l̇l̇ëm ga l̇l̇ëbo wen bop kong owa e kjinmo kjwe» l̈e.
\v 15 Eshko ga domer l̈i to ey dwayo, jek öötong shäng judío tjl̈apgaga shwoy, ga tjl̈ẽ ba kong l̈ok ga «Bor poptaga, e Jesús» l̈e.
\v 16 Eni ga l̇l̇ëbo shärye Jesúsdë eni woshtozl̈ong dbaryo kjĩshko ga opyono beno l̈öng ba wl̈oyo.
\p 
\v 17 Gueniyo Jesús tjl̈ẽ ba kong l̈ok ga «Woshtozl̈ong dbaryo ëmdë ga bor Data, e shäng parkë obi, ga tjara omshäryë eni bakoe» l̈e.
\v 18 Kuya l̈ok ga iirkono ara ba kong. Woshtozl̈ong dbaryo ga pak shärye enido dö l̇l̇ëm, Sbö, e kowara ba Data l̈ara l̈ishko ga miydara l̈ok ga e opyono tjwl̈õ Sbö dik l̈ayde shäng. E kjĩshko ga zröya l̈ok woydë ara anmoyõ.
\s1 Sbö Wa, e ichaga ba Datarë
\p 
\v 19 Eshko ga Jesús tjl̈ẽ ba kong l̈ok ga «L̈ër bomi kong jl̈õkoyo ga l̇l̇ëye shärye Data Sbörë l̈i, e shäryotë tja ba Wa ërerë döe. L̇l̇ëbo shäryër bor woshko l̇l̇ëme.
\v 20 Tja woyde bor Datarë ara, ga l̇l̇ëbo tjeng kës shärye shäng l̈i, e pĩya bor kong drete. Ga l̇l̇ëbo pĩya bor kong kësbang, ëre kjinmo anmoyõ.
\v 21 Ëye wol̈ono ga woshre Data Sbörë ber shäng së iröng obi. Eni wl̈eni ga ëye iër woydë ber shäng së ga iër ber eni ga pjl̈ú bakoe.
\v 22 Ga ëye l̇l̇gweya Data Sbörë ber shdungko wl̈o l̇l̇ëme. No l̇l̇gwega iara beno shäng l̈i, e tja.
\v 23 Shäryara eni, tja bangkjrëba wl̈o, e bangkjrëba sorë ga eni. Ëye, tja bangkjre l̇l̇ëm ga bor ichaga bangkjre l̇l̇ëm bakoe.
\p 
\v 24 »L̈ër bomi kong jl̈õkoyo ga ëye, bor tjl̈õkwo kjrara, ga mär bor ichaga go ga beno l̈öng së ĩyado ba tjok, epga shdungko ame. Bäm go ga beno l̈öng no wol̈ono wl̈eni, gueniyo iara beno l̈öng së jl̈õkoyo shara.
\v 25 L̈ër bomi kong jl̈õkoyo ga dbar tjwe kjwara ga Sbö Wa ëre ybö kuya nopga wol̈ono l̈öng wl̈eni l̈irë, ga ëye omtjl̈õkwo kjrë ga ie Sbörë ber l̈öng së jl̈õkoyo shara. Ga dbar tjwe l̈ër shäng l̈i, e shrono tjän.
\v 26 Nopga ber tjeng së, e l̈aga Data Sbörë eröe. Gueniyo ba Wa ëre iara beno ba l̈aga eni bakoe.
\v 27 Ga dbo twara bor kong no l̇l̇gwek ber shdungko wl̈o, tja shrono kjok dogo dwayo beno no kjĩshko.
\p 
\v 28 »Pjãy kong l̇l̇ëbo l̈oror l̈i, pjãy opshgawë e kjĩshko l̇l̇ëme. Dbar tjwe kjwara ga Sbö Wa ëre ybö kuya nopga wol̈ono iak öötong tjeng sakshko l̈irë,
\v 29 ga woshrë, ga opshik l̈ok tjeng l̈ishko dwayo. Eshko ga ëye wol̈ono l̈öng l̇l̇ëbo pjl̈ú shäryë wl̈eniyo ga woshrë ber tjeng së ĩyado Sbö tjok wl̈o, ga ëye wol̈ono l̈öng l̇l̇ëbo owa shäryë wl̈eniyo ga woshrë ber tjeng shdũya Sbörë wl̈o.
\v 30 L̇l̇ëbo shäryër bor woshko l̇l̇ëme. No l̇l̇gwer, tja ichara ba l̇l̇gwek sorë l̈i eni. L̇l̇gwershko ga woydër ga bor ichaga ber wopjl̈ú bor tjok. E kjĩshko ga l̇l̇ëye l̈ër shäng l̈i, e bek l̈otë.
\s1 Tjl̈õkwo l̈agaga Jesús kjĩshko
\p 
\v 31 »Tja tjl̈ẽ bor kjĩshko om go kjwe ga e tjwl̈õ l̇l̇ëme.
\v 32 Gueniyo shäng kjl̈ara obi tjl̈ẽ bor kjĩshko, ga miydër ga l̇l̇ëye l̈e l̈i, e jl̈õe.
\p 
\v 33 »Pjãy nopga ichono l̇l̇ëbo kjakrokë Juan kong, ga l̇l̇ëye l̈ara bomi kong l̈i, e jl̈õe.
\v 34 Bor kong ga tjl̈õkwo l̈ara norë l̈i, e tjwl̈õ l̇l̇ëme. Gueniyo l̈ër shäng bomi kong, ba tjl̈õkwo kjrëmi wl̈o, pjãy där e go wl̈o.
\v 35 Juan Sbö tjl̈õkwo l̈ono shäng bomi kong, iök jong shjiy wl̈eni, ga pjãy beno l̈öng wopjl̈ú ba kãl̈ã l̈i goshko dbar kjwöbö.
\p 
\v 36 »Gueniyo l̇l̇ëbo shäryër kësbange. Shäryër eni, tja ichara Data Sbörë ba shäryë kjĩshko. Miydëmi e go ga tja ichaga erë. Eni ga bor tjl̈õkwo tjwl̈õ ara, tjl̈õkwo l̈ara Juandë bor kjĩshko l̈i kjinmo.
\p 
\v 37 »Tja ichara Data Sbörë, ga tjl̈ẽno bor kjĩshko bakoe. Gueniyo e ĩmirë l̇l̇ëm, ba tjl̈ẽ l̈i kumirë l̇l̇ëm bakoe.
\v 38 Ba tjl̈õkwo kumi woydë l̇l̇ëme. Tja ichara ba l̈ë bomi kong, gueniyo pjãy mär woydë bor go l̇l̇ëme.
\p 
\v 39 »Pjãy opping Sbö kjibokwoyo go ara, pjãy opping äär ber l̈öng së ĩyado Sbö tjok wl̈o. Ga l̇l̇ëbo tak l̈ok ara eshko bor kjĩshko.
\v 40 Eni ëmdë ga pjãy ber l̈öng së ĩyado Sbö tjok wl̈o ga pjãy mär woydë bor go l̇l̇ëme.
\p 
\v 41 »Tja poshrëkoba l̈i, e bor kong ga tjwl̈õ l̇l̇ëme.
\v 42 Miydër pjl̈ú ga Sbö woydëmi l̇l̇ëme.
\v 43 Tja ichaga bor Datarë, ga tja shrono shäng na, gueniyo tja tjl̈õkwo kjrëmi woydë l̇l̇ëme. Gueniyo obl̈ë tjwayde shäng ba woshko kjwe ga era tjl̈õkwo kjrëmi owa l̇l̇ëme.
\v 44 Woydëmi ga oba ber l̈öng wopjl̈ú bomi tjok, gueniyo Sbö sök kjl̈araso l̈i ber wopjl̈ú bomi tjok l̈i, e bomi kong ga l̇l̇ëno l̇l̇ëme. ¿Eni ga tja tjl̈õkwo kjrëmi sorëro?
\p 
\v 45 »Gueniyo pjãy rotaga Data Sbö kong l̈i, e tja l̇l̇ëme. Bomi rotaga, e Moisés. Pjãy mär l̈öng tjl̈õkwo tara l̈i go l̈ëmi.
\v 46 Ga tjl̈õkwo l̈i tara bor kjĩshko. Eni ga ba tjl̈õkwo l̈i kjroromi jl̈õkoyo kjwe ga bor tjl̈õkwo kjroromi bakoe.
\v 47 ¿Gueniyo ba tjl̈õkwo tara pjang l̈i kjroromi l̇l̇ëm kuzong ga bor tjl̈õkwo kjrëmi sorëro?» l̈e.
\c 6
\s1 Jesús nopga sëno dogl̈o sak dbäw dbäw pjl̈ogl̈o shkëng (5,000)
\p 
\v 1 E irgo ga Jesús jek dipzono öötong shäng di bäng buk kësbang, shkung, so dl̈ung kjoyo ko Galilea kjwo kal̈ëkong. Di bäng l̈i ko Tiberias bakoe.
\v 2 Eshko ga nopga jëk l̈öng ara ba tjok, l̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shärye shäng ara l̈i ĩna l̈ok kjĩshko.
\v 3 Ga Jesús jem öötong wl̈oktong sök dl̈up jong kjwara eshko l̈i go ba oppinggaga tjok.
\v 4 Eshko dbaryo ga Israel tjëyoga döktong tek Egipto kjokyo dwayo dbaryo shrëkkl̈o judíoga kong l̈i döröe.
\p 
\v 5 Eshko ga nopga tëm l̈öng träk l̇l̇ëm ba shwoy l̈i kop ĩya ga tjl̈ẽ Felipe kong ga «¿Shji dl̈i tjwl̈ẽk oba l̈öng kës tëm tjeng kjwe kong kjone?» l̈e.
\v 6 L̇l̇ëye shärye eshko l̈i miydara shäng pjir tjän, gueniyo l̈ara ba kong eni, ba tjl̈ĩkkl̈o, dborye sorë kuya wl̈o.
\p 
\v 7 Eni ga Felipe tjl̈ẽ ba kong ga «Kjwepga kjwe së̃y uunkong wl̈o ga woyde ga dbur bayo domer parkono dbargwo sak dbäw pjl̈ogl̈o pjök (200) ãska wl̈eni. Shäryoroy eni ëmdë ga dl̈iyo shdöy sira sira ga pjitënge» l̈e.
\p 
\v 8 Eshko ga ba oppingga kjl̈ara obi ko Andrés, Simón Pedro l̈ëng l̈i tjl̈ẽ ba kong ga
\v 9 «Kjwozirwa shäng jũshko kjl̈ara, pjl̈ung shosho suk pjir tjeng kjwo shkëng (5), mã tjeng do pjök bakoe. ¿Gueniyo kjwe l̇l̇ëno oba l̈öng kës kjwe kong?» l̈e.
\p 
\v 10 Kuya Jesúsdë ga tjl̈ẽ ba oppinggaga kong ga «Nopga kjwe ichozĩ wl̈ar tjeng töshko» l̈e. Eni ga ichara l̈ok wl̈oktong tjeng shkwamsho ara eshko l̈i kjing go. Domerga tjeng eshko dogl̈o sak dbäw dbäw pjl̈ogl̈o shkëng (5,000) dik.
\p 
\v 11 Pjir ga pjl̈ung shosho suk pjir kjwo shkëng (5) l̈i kjrara Jesúsdë, ga tjl̈ẽ Sbö kong ga «Tjawa kong dl̈i tworop ëre. Tjawa ber wopjl̈ú bop tjok e kjĩshko» l̈e. E irgo ga pjl̈ung shosho l̈i shdöra nopga sirkeno tjeng kës l̈i kong, woydara l̈ok bayo kjöm ga eni. Ga shäryara eni mã l̈i tjok bakoe.
\p 
\v 12 Nopga uunkong iono beno l̈öng bö tjung, wopjl̈ú irgo ga Jesús tjl̈ẽ ba oppinggaga kong ga «Worbo tömi, opzang l̇l̇ëm wl̈o» l̈e ba kong.
\v 13 Eni ga pjl̈ung shosho l̈i worbo töna l̈ok shing roshko, beno tjeng shing kjwo sak kjwara kjingsho pjök (12), tjung tjunge.
\p 
\v 14 L̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryara Jesúsdë l̈i ĩya nopga tjeng l̈irë ga tjl̈ẽ l̈ok ëng kong ga «Jl̈õkoyo ga Sbö tjl̈õkwo l̈aga tjwe wl̈o l̈i kjwe» l̈e.
\v 15 Ga wotjl̈ĩk l̈ok ga shaya, iche ber sök ba pjl̈uyo dbo go wl̈o l̈e. E miydara Jesúsdë pjir kuzong ga opshino jem l̇l̇ögong sit, ber sök tjoksa wl̈o.
\s1 Jesús jëktong di kjing go
\p 
\v 16-17 Kjok ro zoktong irgo ga ba oppinggaga jer dl̈up l̈i go dwayo öötong di bäng buk kësbang l̈i sor go. Eshko ga Jesús tjwayde l̇l̇ëm obishko ga opyono jem l̈ok kjyong roshko, jek dipzë l̈öng Capernaúm kjokyo wl̈o l̈e, di bäng buk kësbang l̈i kjwo kal̈ëkong.
\v 18 Jek l̈öng kjyong roshkoshko ga pjl̈uk shrono dbo ara, di iõya ara bakoe.
\p 
\v 19 Jek l̈öng kjyong roshguë wop ara, öötong l̈öng di bäng roworbëshko\f + \fr 6:19 \ft Di bäng l̈i sor go äär ba roworbëshko wl̈o ga e wop kilómetro shkëng (5) dik.\f* ga Jesús ĩya l̈ok ga tek jëk shäng di l̈i kjing go, ba kjyong jek pjang l̈i shwo l̈ëkong, ga bangkjrara l̈ok ara.
\v 20 Eshko ga tjl̈ẽ ba kong l̈ok ga «¡Tja l̈i jekdo shäng! L̇l̇ëye bangkjrëmi l̇l̇ëme» l̈e.
\v 21 Kuya l̈ok ga wl̈okjrara l̈ok kjyong l̈i roshko. Jekdo eshko ga ba kjyong öötong pjang di bäng l̈i kjako, äär woydë l̈ok kjone l̈ishko.
\p 
\v 22 Nopga beno tjeng di bäng kjwo kal̈ëkong l̈i ommiydono ga Jesús oppinggaga briktong l̈ok kjyong kjl̈ara roshko, ga Jesús to jek ba tjok l̇l̇ëme. Ga kjyong obl̈ëra drete. Wẽshko ga
\v 23 kjyong tek l̈ok kjl̈öbö Tiberias kjokyo dwayo, shrono tjeng nopga iono kjupkeshko l̈i shtoyoshko.
\v 24 Ga miydara l̈ok ga Jesús sök l̇l̇ëm, ba oppinggaga l̈öng l̇l̇ëmshko ga opyono l̈ok kjyong roshko, ga to dipzono jek Capernaúm kjokyo, Jesús wl̈ẽk.
\s1 Dl̈i, shji ie ber l̈öng së ĩyado Sbö tjok l̈i, e Jesús
\p 
\v 25 Öötong l̈öng di kjwo kal̈ëkong ga wl̈ẽna l̈ok, ga tjl̈ẽ l̈ok ba kong ga «Tjl̈apga no pingga, ¿pja tjwe shäng na l̇l̇onoshko?»
\p 
\v 26 «L̈ër bomi kong jl̈õkoyo ga tja wl̈ẽmi l̈öng, pjãy iono bö tjung, wopjl̈ú kjĩshko erä. Gueniyo l̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryoror l̈i, e l̇l̇ë l̈okl̈o miydëmi l̈öng l̇l̇ëme.
\v 27 Pjãy parkë dl̈i srer wl̈eniyo kjĩshko l̇l̇ëme. Pjãy parkë dl̈i srer l̇l̇ëm wl̈eniyo kjĩshko dey, uoromi ga pjãy ie ber l̈öng së ĩyado Sbö tjok wl̈eniyo. No to ter kjok dogo dwayo ëre, tja ichaga Data Sbörë, ga dl̈i ëre twaga bomi kong l̈i, e tja» l̈e.
\p 
\v 28 Eni ga tjl̈ẽ l̈ok ba kong ga «¿Pak woyde Sbörë ga shäryërwa l̈e l̈i l̇l̇ë? ¿L̇l̇ëye shäryërwa ga pjl̈ú, Sbö ber wopjl̈ú borwa tjok wl̈o?»
\p 
\v 29 «Tja ichaga erë, ga pak woyde ga shäryëmi l̈e l̈i, e ëre: Pjãy mär ber l̈öng bor go» l̈e.
\p 
\v 30 Kuya l̈ok ga tjl̈ẽ ba kong ga «Tjawa mär ber l̈öng bop go wl̈o ga woydërwa ga l̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryëp borwa kong, ĩnwa wl̈o. ¿L̇l̇ëye shäryëp ga pjl̈ú?
\v 31 Borwa tjl̈apgaga tek dënashko so l̈öng kjok dogro no l̇l̇ëmshko ga \tl maná\tl* uara l̈ok eshko, tak pjang Sbö tjl̈õkwo go sorë l̈i eni. Tjl̈ẽ ga “Dl̈i twara ba kong kjok dogo dwayo”»\f + \fr 6:31 \ft Éxodo 16.4; Nehemías 9.15; Salmo 78.24-25.\f* l̈e.
\p 
\v 32 Kuya ga tjl̈ẽ ba kong l̈ok ga «Pjãy wotjl̈ĩk ga dl̈i l̈ëmi l̈öng l̈i twaga Moisésdë bomi kong kjok dogo dwayo l̈ëmi. Gueniyo l̈ër bomi kong jl̈õkoyo ga e eni l̇l̇ëme. E twaga bor Datarë bomi kong. Dl̈i jl̈õkoyo ter tjwe kjok dogo dwayo twaga l̈i e.
\v 33 Dl̈i twe l̈i, kjl̈ara ichak Sbörë ter shrono shäng kjok dogo dwayo, nopga l̈öng kjok ëre kjing go ie ber l̈öng së ĩyado ba tjok wl̈o l̈i e» l̈e.
\p 
\v 34 Eni ga tjl̈ẽ l̈ok ba kong ga «Tjl̈apga, dl̈i l̈ëp shäng l̈i twos borwa kong ĩyado» l̈e.
\p 
\v 35 Kuya ga tjl̈ẽ ba kong l̈ok ga «Dl̈i, e uoromi ga pjãy ie ber l̈öng së ĩyado Sbö tjok wl̈eniyo l̈i, e tja. Ëye tjwe ber bor tjok wl̈o, ga mär bor go ga ber pjl̈irö ame, e ber wodogro ame bakoe.
\v 36 Gueniyo tja ĩnomi ëmdë ga pjãy mär bor go l̇l̇ëm, l̈oror bomi kong sorë l̈i eni.
\v 37 Nopga twara Data Sbörë beno bor kong kës l̈i, e tjwe ber tjeng bor tjok wl̈o. Ga ëye tjwe ber bor tjok wl̈o ga wl̈okjrër uunkong, “L̇l̇ëme” l̈ër ë kong l̇l̇ëme.
\p 
\v 38 »Tja ter shrono shäng kjok dogo dwayo, l̇l̇ëbo shäryër bor woshko wl̈o l̇l̇ëme. Tja ichara bor Datarë shrono shäng l̇l̇ëye woyde ga shäryër l̈e l̈i, e shäryotë.
\v 39 Ga l̇l̇ëye woyde bor ichagarë l̈i, e ëre: Kjok pjir dbaryoshko ga nopga twara beno tjeng bor kong kës l̈i woshrër iröng obi, jer kjl̈ara l̇l̇ëm wl̈o.
\v 40 Woyde bor Datarë ga ëye ba Wa ëre tjl̈õkwo kjrë, ga mär bor go ga ber l̈öng së ĩyado ba tjok. Eni ga epga woshrër uunkong iröng obi kjok pjir dbaryo l̈ishko» l̈e.
\p 
\v 41 Kuya judíoga l̈öng l̈irë ga Jesús l̈ãywara l̈ok owa, «Dl̈i ter shrono kjok dogo dwayo l̈i tja» l̈ara l̈i kjĩshko.
\v 42 Tjl̈ẽ l̈ok ëng kong ga «¿Domer kjwe Jesús l̇l̇ëmdo? ¿Data José l̇l̇ëmdo? Ba data, mekë, e miydërwa pjl̈úe. ¿“Tja ter shrono shäng kjok dogo dwayo” l̈e sorëro?» l̈e.
\p 
\v 43 Kuya Jesúsdë ga tjl̈ẽ ba kong l̈ok ga «Tja l̈ãywëmi ëng kong eni kjër l̇l̇ëme.
\v 44 Tja ichaga Data Sbörë. Ga ëye ichara ber bor tjok wl̈o l̇l̇ëm ga tjwe ber bor tjok wl̈o ga äe. Gueniyo ëye tjwe ber bor tjok wl̈o ga woshrër iröng obi kjok pjir dbaryo l̈ishko.
\v 45 Tjl̈õkwo tara Sbö tjl̈õkwo l̈aga tek dënashko so kjl̈ararë beno pjang eni: “L̇l̇ono ga nopga uunkong pĩya Sbörë om go.”\f + \fr 6:45 \ft Isaías 54.13.\f* Eni ga ëye Data Sbö tjl̈õkwo kuno, ga l̇l̇ë l̈okl̈o miydara ga tjwe ber tjeng bor tjok uunkong.
\p 
\v 46 »Data Sbö, e ĩga ërë l̇l̇ëme. Gueniyo to ter ba shwoy dwayo ërera omĩno eröe.
\v 47 L̈ër bomi kong jl̈õkoyo ga ëye mär bor go ga ber l̈öng së ĩyado Sbö tjok uunkong.
\p 
\v 48 »Dl̈i, e uoromi ga pjãy ie ber l̈öng së ĩyado Sbö tjok wl̈eniyo l̈i, e tja.
\v 49 Bomi tjl̈apgaga tek dënashko so l̈öng kjok dogro no l̇l̇ëmshko ga \tl maná\tl* uara l̈ok eshko. Eni ëmdë ga wol̈ono uunkong.
\v 50 Gueniyo dl̈i ter shrono kjok dogo dwayo wl̈eniyo l̈ira, ëye omuono ga wol̈on l̇l̇ëme.
\v 51 Dl̈i ter shrono kjok dogo dwayo l̈i, e tja. Ëye omuono ga ber l̈öng së ĩyado Sbö tjok. Dl̈i l̈ër shäng l̈i, e bor sho l̈otë. E twër nopga l̈öng kjok ëre kjing go kës l̈i kong, äär ber l̈öng së ĩyado Sbö tjok wl̈o» l̈e.
\p 
\v 52 Kuya judíoga l̈öng l̈irë ga ëng l̈ono l̈ok kar kar ëng tjok. Tjl̈ẽ l̈ok ga «¿Domer kjwe, l̇l̇ë l̈aydero? ¿Shji iche ba sho uë l̈e, e sorëro?» l̈e l̈ok eni.
\p 
\v 53 Kuya Jesúsdë ga tjl̈ẽ ba kong l̈ok ga «L̈ër bomi kong jl̈õkoyo ga pjãy ber l̈öng së jl̈õkoyo wl̈o ga no to ter kjok dogo dwayo ëre sho uëmi, srëng iëmi kjl̈uwe.
\v 54 Ga ëye omshäryono eni ga woshrër iröng obi kjok pjir dbaryo l̈ishko, ga ber sök së ĩyado Sbö tjok.
\v 55 Dl̈i jl̈õkoyo l̈ër shäng l̈i, e bor sho. L̇l̇ëbo iëy wl̈o jl̈õkoyo l̈i, e bor srëng.
\v 56 Ëye bor sho uono, bor srëng iono ga beno sök bor tjok, ga tja beno sök ba tjok, no kjl̈araso wl̈eni.
\p 
\v 57 »Data Sbö sök së, ga tja sök së ba kjĩshko. Tja ichara shrono shäng na, ga ëye mär bor sho go ga ber l̈öng së jl̈õkoyo bor kjĩshko.
\v 58 Bomi tjl̈apgaga tek dënashko so \tl maná\tl* uono l̈ok, ga wol̈onoe. Dl̈i ter shrono kjok dogo dwayo l̈i, e so e kjoyo l̇l̇ëme. Ëye dl̈i l̈ër shäng l̈i uono ga ber l̈öng së ĩyado Sbö tjok» l̈e.
\p 
\v 59 L̇l̇ëbo tjeng kës ëre l̈ara Jesúsdë shäng oba kong Capernaúm kjokyo, judíoga syõ uyo jong eshko l̈i roshko.
\s1 Jesús oppinggaga ba rayono l̈ok ara
\p 
\v 60 Kuya ba oppinggaga tjeng eshko l̈irë ga epga ara tjl̈ẽ l̈ok ëng kong ga «Tjl̈õkwo l̈e shäng l̈i, e kjrëy wl̈o ga kjange. ¿Ëye omkjrë ga pjl̈úro?» l̈e.
\p 
\v 61 L̇l̇ëye l̈e l̈öng l̈i miyde Jesúsdë shäng pjir, ga tjl̈ẽ ba kong l̈ok ga «¿Tjl̈õkwo l̈ër shäng l̈i, e bomi barwokl̈ore?
\v 62 ¿No to ter kjok dogo dwayo ëre jem eshko iröng obi l̈i ĩnomi wl̈eni ga l̇l̇ëye l̈ëmi eshko?
\v 63 Nopga ber l̈öng së l̈aga Sbö Sëyarë, l̇l̇ëye shärye norë om go ga äe. Ga tjl̈õkwo l̈ër shäng bomi kong l̈i, e Sbö Sëya ĩ. E kjĩshko ga tjl̈õkwo kjroromi wl̈eni ga pjãy beno l̈öng së ĩyado Sbö tjok.
\v 64 Gueniyo pjãy kjong kjong mär woydë bor go l̇l̇ëme» l̈e. Ëye mär ber l̈öng ba go l̇l̇ëm l̈i ë, ba soynega shäng l̈i ë, e miyde shäng pjir tek dämärshko. L̈ara eni e kjĩshko.
\v 65 E irgo ga tjl̈ẽ ba kong l̈ok ga «Tja tjl̈ẽno bomi kong ga “Ëye ichara Data Sbörë ber bor tjok wl̈o l̇l̇ëm ga tjwe ber bor tjok wl̈o ga äe” l̈oror eni e kjĩshko» l̈e.
\p 
\v 66 Kuya ba tjl̈õkwo kjragaga tjeng eshko l̈irë ga epga ara shdöktong to l̈ok, jëktong l̈ok Jesús tjok ame.
\p 
\v 67 Eshko ga Jesús tjl̈ẽ ba oppinggaga dogl̈o sak kjwara kjingsho pjök (12) l̈i kong ga «¿Pjãy ëmdë ga toe woydë bakore?» l̈e.
\p 
\v 68 Kuya Pedrorë ga tjl̈ẽ ba kong ga «Tjl̈apga, tjawa ber l̈öng së ĩyado Sbö tjok wl̈o ga bop tjl̈õkwo kjrorwarë. ¿Eni ga pja rayororwa kjwe ga tjawa mär ber l̈öng ë go?
\v 69 Bop tjl̈õkwo kjrorwarë. Ga miydërwa ga pja iak beno shäng dboy Sbö kong» l̈e.
\p 
\v 70 Kuya ga tjl̈ẽ ba kong ga «¿Pjãy dogl̈o sak kjwara kjingsho pjök (12) kjraga tjarë l̇l̇ëmdo? Eni ëmdë ga pjãy kjl̈ara wotjl̈ĩk Ä wl̈eni» l̈e.
\v 71 L̈ara eni l̈i, e Judas l̈ayde shäng. E Simón Iscariote wa. Judas, e Jesús oppinggaga dogl̈o sak kjwara kjingsho pjök (12) l̈i kjl̈arayo, gueniyo Jesús soynena, iara beno tjeng ba wl̈oyoga wl̈oshko.
\c 7
\s1 Jesús to jek judíoga l̈öng u shäryak öng kwota go dbaryo l̈i shrëk
\p 
\v 1 E irgo ga Jesús to jek shäng kjok shto obl̈ë obl̈ë Galilea kjokyo. Gueniyo Judea kjokyo ga judíoga l̈öng ba wl̈ẽk, zröya l̈ok wl̈o l̈e. E kjĩshko ga jek woydë eshko l̇l̇ëme.
\v 2 Eshko dbaryo ga judíoga l̈öng u shäryak öng kwota go dbaryo l̈i döröe.
\v 3 Eni ga Jesús l̈ëmga tjl̈ẽ ba kong ga «Pja nom jek Judea kjokyo, l̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryëp shäng l̈i ĩya bop oppinggaga tjeng eshko l̈irë bako wl̈o.
\v 4 Woydëy ga l̇l̇ëbo shäryëy l̈i miydëba wl̈o ga shäryëy l̈ũtshko wl̈o ga äe. Eni ga l̇l̇ëbo shäryëp shäng l̈i, e shäryos oba uunkong bokshto, pja ë miydëba wl̈o» l̈e.
\v 5 L̈ara l̈ok eni, epga ba l̈ëmga ëmdë ga mätë ba go l̇l̇ëm obi kjĩshko.
\p 
\v 6 Kuya ga tjl̈ẽ ba kong l̈ok ga «Pjãy jek eshko woydëmi l̇l̇ono ga eni. Gueniyo tja dbaryo äätë l̇l̇ëm obi.
\v 7 Nopga Sbö miydë l̇l̇ëm wl̈eniyo, pjãy ĩywa l̈ok shjiktëng l̇l̇ëme. Gueniyo tjara ĩywa l̈ok shjiktëng, l̇l̇ëbo shärye l̈öng l̈i, e owa l̈ër shäng ba kong kjĩshko.
\v 8 Pjãy to dbar l̈i shrëk. Tjara jek l̇l̇ëm obi, tja dbaryo äätë l̇l̇ëm obi kjĩshko» l̈e,
\v 9 ga beno sök eshko Galilea kjokyo.
\p 
\v 10 Gueniyo ba l̈ëmga briktong pjir irgo ga jek öötong shäng eshko, l̈ũtshko wl̈eni, miydëba l̇l̇ëm wl̈o.
\p 
\v 11 Eshko ga wl̈ẽya judío tjl̈apgagarë l̈öng, ga tjl̈ẽ ga «¿Domer, e kwonl̇l̇o?» l̈e l̈öng ëng kong eni.
\p 
\v 12 Nopga l̈öng eshko l̈i Jesús l̈anyotkë l̈öng ara. Kjong kjong tjl̈ẽ ga «Domer, e pjl̈úe» l̈e. Kjong kjong obi tjl̈ẽ ga «Eni l̇l̇ëme. Shäng oba jyãpgwë eröe» l̈e.
\v 13 Eni ëmdë ga judío tjl̈apgaga bangkjre l̈ok ara. E kjĩshko ga Jesús l̈anyotke l̈ok l̈ũtshko erö, kuya l̈ok l̇l̇ëm wl̈o.
\s1 Jesús oba pino
\p 
\v 14 Dbar l̈i shrëkoba äär jong sondë kjwara, ga öötong dbar bëy wl̈eni ga Jesús opzrëno jek öötong shäng oba ping Sbö u zl̈ong bäng kjwl̈ëe.
\v 15 Kuya judío tjl̈apgagarë ga beno l̈öng sëya l̇l̇ëm, ga tjl̈ẽ l̈ok ëng kong ga «Domer kjwe oppino l̇l̇ëme. ¿Eni ga kjok miydë ara kjweni sorëro?» l̈e l̈ok eni.
\p 
\v 16 L̇l̇ëye l̈e l̈öng l̈i miyde Jesúsdë shäng pjir, ga tjl̈ẽ ba kong l̈ok ga «Tjl̈õkwo l̈ër shäng bomi kong ëre, e l̈aga tjarë l̇l̇ëm, e l̈aga bor ichagarë.
\v 17 Tjl̈õkwo l̈i l̈aga tjarëre, de l̈aga Sbörë, e miydaga Sbö kol̈agaga l̈öng l̈irë.
\v 18 Ëye tjl̈õkwo l̈ë ba woshko ga opyë woydë ber pjl̈ú oba bokso eröe. Gueniyo ëye opyë woydë ber pjl̈ú ba ichaga bokso ga tjl̈õkwo bek l̈i l̈ayde, jyõ l̈e l̇l̇ëme.
\v 19 ¿Kjok l̇l̇gwekkl̈o twara Moisésdë beno bomi kong dënashko l̇l̇ëmdo? Eni ëmdë ga pjãy omkol̈ë l̇l̇ëme. ¿Eni ga tja zrömi woydë egaro?»
\p 
\v 20 «¿Pja skwẽro? Pja goshko Ä sëya kjl̈ara. ¿Pja zröga ërë l̈ëpdo?» l̈e ba kong.
\p 
\v 21 Kuya ga tjl̈ẽ ba kong ga «Woshtozl̈ong dbaryo ga l̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryoror bomi kong kjrina, ga pjãy beno l̈öng sëya l̇l̇ëme.
\v 22 Dënashko ga pjãy ichara Moisésdë bomi wapga domerga doyo jyã të. (Ichaga Moisésdë jl̈õkoyo, gueniyo soyara bomi tjl̈apgaga tek dënashko so tjwl̈õ ara l̈irë bäm go.) Pjãy ichara eni kuzong ga bomi wapga äär dbargwo kjwong (8) ga doyo jyã tëmi, woshtozl̈ong dbaryo ëmdë ga shäryëmi eni.
\v 23 ¿Eni ga shäryëmi eshko dbaryo, kjok l̇l̇gwekkl̈o tara Moisésdë pjang l̈i shäryëmi wl̈o ga no poptoror ey dbaryoshko ga pjãy iirkono ara bor kong ega?
\v 24 No l̇l̇gwemishko ga l̇l̇gwemi l̇l̇ëbo ĩmi l̈i go ame, l̇l̇gwemi bek shara» l̈e.
\p 
\v 25 Kuya Jerusalén sopga l̈öng l̈irë ga kjong kjong tjl̈ẽ ëng kong ga «¿Domer wl̈ẽkoba l̈öng, zrökoba wl̈o l̈i shäng kjwe l̇l̇ëmdo?
\v 26 Shäng tjl̈õkwo l̈ë oba uunkong bokshto, ga kong l̇l̇ëye l̈e bi ichagagarë ba kong l̇l̇ëme. ¿Miydara l̈ok ga no pjl̈uyo iche l̈e Sbörë l̈i kjwe jl̈õe l̈e l̈ëpde?
\v 27 Gueniyo no pjl̈uyo iche l̈e Sbörë l̈i tjweshko ga e kjone so miydaga ërë l̇l̇ëme. Domer kjwera kjone so miydërwa pjl̈úe» l̈e l̈öng eni.
\p 
\v 28 E wopro ga Jesús shäng oba ping Sbö u zl̈ong bäng. L̇l̇ëye l̈e l̈öng l̈i kuya ga tjl̈ẽ ba kong l̈ok dbo go ga «Tja ë miydëmi l̈ëmi l̈öng eni. Tja kjone so miydëmi l̈ëmi l̈öng eni bakoe. Gueniyo tja ëre shrono shäng bor woshko l̇l̇ëme. Tja ichaga tjok. Tjl̈õkwo bek l̈aga l̈i e. Era miydëmi l̈öng l̇l̇ëme.
\v 29 Gueniyo tjara tek ba shwoy dwayo, ga tja ichaga erë. E kjĩshko ga e miydër pjl̈úe» l̈e.
\p 
\v 30 Eshko ga shaya l̈ok woydë, gueniyo ba dbaryo äätë l̇l̇ëm obi kjĩshko ga to porwara l̈ok l̇l̇ëme.
\v 31 Eni ëmdë ga nopga tjeng eshko l̈i tjrëko ga nopga ara beno l̈öng mär ba go. Tjl̈ẽ l̈öng ga «¿No pjl̈uyo iche l̈e Sbörë l̈i shronoshko ga l̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shärye domer kjwe kjinmo sorëro?» l̈e l̈öng eni.
\s1 Nopga ichara fariseogarë Jesús shak l̈e
\p 
\v 32 Jesús l̈anyotkëba sorë l̈i roy kura fariseogarë, ga töno l̈ok syõshtaga kägäyoga tjok. E irgo ga Sbö u dagaga ichara l̈ok kjl̈öbö ba shak.
\v 33 Öötong jek l̈öng ba shwoy ga Jesús tjl̈ẽ l̈öng l̈i kong ga «Tja ber sök bomi tjok dbar kjwöbö döe. E irgo ga tja to iröng bor ichaga sök l̈ishko.
\v 34 Eshko ga tja wl̈ẽmi l̈öng kjër ga tja wl̈ẽmi l̇l̇ëm, tja öötong sök l̈ishko ga pjãy äär eshko ga ä kjĩshko» l̈e.
\p 
\v 35 Kuya judíoga l̈öng l̈irë ga tjl̈ẽ l̈ok ëng kong ga «¿Wl̈ẽy ga äe l̈e l̈i, e sorëro? ¿Jongya kjok shto obl̈ë obl̈ë, judíoga shdöktong öötong l̈öng tjëyoga obl̈ë obl̈ë tjrëko l̈ishko, nopga judío l̇l̇ëm wl̈eniyo ping wl̈o l̈ëpde?
\v 36 ¿Tjl̈ẽ ga “Tja wl̈ẽmi l̈öng kjër ga tja wl̈ẽmi l̇l̇ëm, tja öötong sök l̈ishko ga pjãy äär eshko ga ä kjĩshko” l̈e shäng l̈i l̇l̇ë l̈ayde?» l̈e.
\s1 Di tur ri ri bi roy dwayo
\p 
\v 37 E irgo ga dbar shrëzl̈ong dbaryo pjirzl̈ong dbaryo l̈i öötonge. Dbar eshko l̈i tjwl̈õ ara anmoyõ l̈ëba. Eshko dbaryo ga Jesús kojono shäng kojong, ga tjl̈ẽ dbo go ga «Ëye wodogro ga tek bor shwoy, di twër ba kong l̈i ie wl̈o.
\v 38 Ëye mär bor go ga ber shäng di jong tur ri ri ba roy dwayo wl̈eni, e iaga ërë ga ber l̈öng së ĩyado Sbö tjok, tak pjang Sbö tjl̈õkwo go sorë l̈i eni» l̈e.
\v 39 (Di l̈i, e Sbö Sëya l̈okl̈o. Ëye mär ba go ga kong Sbö Sëya twe ber ba go wl̈o l̈ayde. Eshko dbaryo ga Jesús äätë ber sök kësbang, tjwl̈õ ara kjok dogo l̇l̇ëm obi. E kjĩshko ga Sbö Sëya twayde l̇l̇ëm obi.)
\s1 Nopga shdöktong beno wotjl̈ĩk obl̈ë obl̈ë
\p 
\v 40 Kuya l̈öng l̈irë ga kjong kjong tjl̈ẽ ga «Jl̈õkoyo ga Sbö tjl̈õkwo l̈aga tjwe l̈ëba l̈i kjwe» l̈e.
\v 41 Kjong kjong tjl̈ẽ ga «No pjl̈uyo iche l̈e Sbörë l̈i kjwe» l̈e. Kjong kjong obi tjl̈ẽ ga «Eni l̇l̇ëme. No pjl̈uyo iche l̈e Sbörë l̈i wen tjwe Galilea kjokyo dwayo l̇l̇ëme.
\v 42 Sbö tjl̈õkwo tak pjang l̈i tjl̈ẽ ga e David tjëyo, e ber Belén so, David weno buk l̈ishko» l̈e.
\v 43 Eni ga nopga shdöktong beno wotjl̈ĩk obl̈ë obl̈ë Jesús kjĩshko.
\v 44 Kjong kjong omshak woydë, gueniyo porwara l̈ok l̇l̇ëme.
\s1 Judío tjl̈apgaga Jesús tjl̈õkwo kjrono l̇l̇ëme
\p 
\v 45 E irgo ga Sbö u dagaga ichara l̈öng l̈i to jek l̈ok ba ichagaga l̈öng l̈ishko iröng obi. Ĩya ba ichagagarë l̈ok ga tjl̈ẽ ba kong l̈ok ga «¿Söromi l̇l̇ëm ega?» l̈e syõshtaga kägäyoga, fariseoga l̈irë eni.
\p 
\v 46 Kuya l̈ok ga tjl̈ẽ ba kong ga «Ëye tjl̈ẽ wol̈ëso eni l̈i kurwarë l̇l̇ëme» l̈e.
\p 
\v 47 Eni ga fariseoga tjl̈ẽ ba kong l̈ok ga «¿Pjãy ëmdë ga jyãpgwara bakore?
\v 48 Shji judío ichagaga, fariseoga, shji mär ba go kjl̈ara l̇l̇ëme.
\v 49 Ba tjl̈õkwo kjragaga l̈öng l̈i, kjok l̇l̇gwekkl̈o tara Moisésdë l̈i miyde l̈öng l̇l̇ëme. Epga shdungko» l̈e.
\p 
\v 50 Eshko ga fariseo shäng kjl̈ara ko Nicodemo. Pjl̈ara ga öör l̈an Jesús tjok. Eshko ga tjl̈ẽ l̈öng l̈i kong ga
\v 51 «Tjl̈õkwo tak pjang bi kjok l̇l̇gwekkl̈o go tjl̈ẽ ga ëye rotaraba ga kjakrokëy ba kong, l̇l̇ëye shäryara l̈i, e l̇l̇ë miydëy yõtso wl̈o, ga shdũydë eshko kjwl̈ë jã» l̈e.
\p 
\v 52 Kuya l̈ok ga tjl̈ẽ ba kong ga «¿Pja ëmdë ga Galilea soro? Sbö tjl̈õkwo tak pjang kjibokwo go l̈i ĩs yõtso. Miydëp e go ga Sbö tjl̈õkwo l̈aga wen tjwe Galilea kjokyo dwayo l̇l̇ëme» l̈e.
\v 53 E irgo ga töno l̈öng eshko l̈i to jongya l̈ok ba ushko.
\c 8
\s1 Wal̈ë l̇l̇ëbo owa shäryaga wl̈eniyo söraba öötong shäng Jesús bokshto kjl̈ara\f + \fr 8:0 \ft Tek dënashko ga kjibokwo ëre jyã shiraba obl̈ë obl̈ë ara. Ga Juan 7.53-8.11 wen pjang kjibokwo këguë anmoyõ l̈i go l̇l̇ëme.\f*
\p 
\v 1 E irgo ga Jesús jem Olivos dl̈upyo.
\v 2 Wẽshko kjok shröngto ga jer öötong shäng Sbö u zl̈ong bäng obi. Eshko ga nopga shrono l̈öng ara ba shwoy, ga Jesús wl̈oktong sök ba ping eshko.
\p 
\v 3 E wopro ga no pinggaga kjok l̇l̇gwekkl̈o tara Moisésdë l̈i go, fariseoga, e tek l̈öng kjl̈öbö eshko. Wal̈ë tek söra l̈ok kjl̈ara. Wal̈ë l̈i wl̈ẽnaba buk domer tjok, gueniyo domer, e ba l̈anma l̇l̇ëme. Öötong l̈öng eshko ga wal̈ë l̈i iara l̈ok beno shäng nopga l̈öng l̈i bokshto,
\v 4 ga tjl̈ẽ l̈ok Jesús kong ga «Tjl̈apga no pingga, wal̈ë kjwe wl̈ẽnaba buk domer tjok, gueniyo domer, e ba l̈anma l̇l̇ëme.
\v 5 Kjok l̇l̇gwekkl̈o go ga shji ichara Moisésdë wal̈ë kjweniyo l̈ök ak go, zröy wl̈o. ¿L̇l̇ëye l̈ëp eshko?» l̈e.
\v 6 L̈ara l̈ok eni, Jesús tjl̈ĩya wl̈o, rote l̈ok l̇l̇ëye l̈e l̈i go wl̈o.
\p Kuya Jesúsdë ga dboryara l̇l̇ëme. Kjujono shäng l̇l̇ëbo të kl̈ung kjing go ba sakkwo go.
\v 7 Ga kjakroke l̈ok ba kong kjër kuzong ga kojono iröng, ga tjl̈ẽ ba kong l̈ok ga «Pjãy kjone dey ga kumi ga pjl̈o bek, l̇l̇ëbo owa shäryaga l̇l̇ëm wl̈eniyo ga akkwo kjrëmi kjwara ga wal̈ë kjwe l̈özĩ e go bäm go» l̈e,
\v 8 ga kjujono shäng l̇l̇ëbo të kl̈ung kjing go ba sakkwo go jek obi.
\p 
\v 9 Kuya nopga tjeng l̈irë ga brik l̈ok kjl̈ara kjl̈ara, këkboga äär jong dwl̈asga go. To pjir ga wal̈ë l̈i beno shäng Jesús tjok eröe.
\v 10 Eshko ga Jesús kojongö shäng, ga tjl̈ẽ ba kong ga «¿Bop rotaga tjwe l̈öng yẽ kwonl̇l̇o? ¿Pja shduna l̈ok l̇l̇ëmde?»
\p 
\v 11 «L̇l̇ëme, Tjl̈apga. Tja shduna l̈ok l̇l̇ëme» l̈e ba kong.
\p Kuya ga tjl̈ẽ ba kong ga «Tja ëmdë ga pja shdun l̇l̇ëm bakoe. Eni ga pja nomo. Gueniyo ga l̇l̇ëbo owa shäryëp ame» l̈e.
\s1 Jesús tjl̈ẽno ba kjĩshko om go
\p 
\v 12 E irgo ga Jesús tjl̈ẽno nopga kong obi. Tjl̈ẽ ga «Tja so iök jong shjiy nopga kjok ëre so kong kjoyo, kjok miyde l̈ok ara wl̈o. Ëye jëk shäng bor tjok ga jëk kjok ro sĩ roy wl̈eni ame. Era jëk iök shjiy l̈i tjok wl̈eni, kjok ĩgö wẽl̈ë wl̈o, ga beno shäng së ĩyado Sbö tjok» l̈e.
\p 
\v 13 Kuya fariseogarë l̈ok ga tjl̈ẽ ba kong ga «Pja tjl̈ẽ shäng bop kjĩshko om go erä. E kjĩshko ga bop tjl̈õkwo tjwl̈õ l̇l̇ëme. Woyde ga l̈aga obl̈ërë bop kjĩshko dey» l̈e.
\p 
\v 14 Kuya ga tjl̈ẽ ba kong ga «Tja tjl̈ẽ shäng bor kjĩshko ëmdë ga tjl̈õkwo l̈ër shäng l̈i, e jl̈õ, tja tjwe kjone dwayo, tja jek kjone, e miydër shäng pjl̈ú kjĩshko. Gueniyo pjãyda ommiydë l̇l̇ëme.
\v 15 Pjãy no l̇l̇gwek, nopga kjok ëre so ĩ dik. Gueniyo tjara no l̇l̇gwek l̇l̇ëme.
\v 16 L̇l̇gweror kjwe ga shäryoror bor woshko l̇l̇ëm, shäryoror Data Sbö, bor ichaga l̈i tjok. E kjĩshko ga l̇l̇gweror kjwe ga kjwe beno beke.
\v 17 Bomi kjok l̇l̇gwekkl̈o tak pjang l̈i tjl̈ẽ ga ëye l̇l̇gwey wl̈o ga woyde ga nopga wl̈ẽy do pjök omĩno, oml̈ë jong eni wl̈eniyo. Enira l̇l̇gwey ga pjl̈úe.
\v 18 Tjl̈õkwo l̈agaga bor kjĩshko l̈i tjeng do pjök eni bakoe. Kjl̈ara l̈i tja, kjl̈ara l̈i Data Sbö, bor ichaga. Tjawa pjöyĩkong tjl̈ẽno bor kjĩshko beke» l̈e.
\p 
\v 19 Kuya l̈ok ga tjl̈ẽ ba kong ga «¿Bop data l̈ëp l̈i sök kjone?»
\p «Tja ë miydëmi l̈öng l̇l̇ëme. Miydoromi kjwe ga bor Data l̈i ë miydëmi bakoe» l̈e ba kong.
\v 20 L̈ara shäng eni Sbö u zl̈ong bäng, dbur twozl̈ong shtoyo l̈ishko. Gueniyo eshko ga ba dbaryo äätë l̇l̇ëm obi kjĩshko ga to sharaba l̇l̇ëme.
\p 
\v 21 Eshko ga tjl̈ẽno nopga kong jek pjl̈ara obi. Tjl̈ẽ ga «Tja toe. E irgo ga tja wl̈ẽmi, gueniyo pjãy wol̈on ber l̈öng owa pjang bomi go l̈öna Sbörë l̇l̇ëm l̈i tjok. Ga tja öötong sök l̈ishko ga pjãy äär eshko ga äe» l̈e.
\p 
\v 22 Kuya judío tjl̈apgaga tjeng l̈irë ga tjl̈ẽ l̈ok ëng kong ga «¿Tjl̈ẽ shäng ga “Tja öötong sök l̈ishko ga pjãy äär eshko ga äe” l̈e shäng l̈i l̇l̇ë l̈ayde? ¿Domer kjwe opzrök woydë l̈ayde shängde?» l̈e l̈ok eni.
\p 
\v 23 Gueniyo tjl̈ẽ ba kong l̈ok obi ga «Pjãy kjok töshko ëre so, gueniyo tjara kjok dogo so. Pjãy wotjl̈ĩk nopga kjok ëre so dik, gueniyo tjara wotjl̈ĩk eni l̇l̇ëme.
\v 24 “Pjãy wol̈on ber l̈öng owa pjang bomi go l̈öna Sbörë l̇l̇ëm l̈i tjok” l̈oror bomi kong e kjĩshko. Tjl̈õkwo l̈ër shäng bor kjĩshko l̈i kjrëmi l̇l̇ëm ga pjãy wol̈on ber l̈öng owa pjang bomi go l̈öna Sbörë l̇l̇ëm l̈i tjok jl̈õkoyo» l̈e.
\p 
\v 25 Kuya l̈ok ga tjl̈ẽ ba kong ga «¿Eni ga pja ëro?»
\p «Tja ë l̈oror bomi kong tek dämärshko l̈i tja.
\v 26 Tja tjl̈ẽ woydë bomi kong ara, l̇l̇ëbo owa shäryëmi l̈öng l̈i kjĩshko. Gueniyo l̈ër bor woshko l̇l̇ëme. Bor ichaga tjl̈ẽ bek ĩyado, ga tjl̈õkwo l̈ara bor kong l̈i, e l̈otë nopga kjok ëre so kong» l̈e.
\p 
\v 27 Tjl̈ẽno shäng ba ichaga kjĩshkoshko ga ba Data sök kjok dogo l̈i l̈ayde shäng, gueniyo miydara l̈ok l̇l̇ëme.
\v 28 Eni ga tjl̈ẽ ba kong l̈ok jek obi ga «No to ter kjok dogo dwayo ëre poyonomi pjang kjomoshko ga tja ë miydëmi eshko, ga l̇l̇ëbo shäryër bor woshko l̇l̇ëm, tja pina bor Datarë sorë l̈i l̈otë shäng, e miydëmi eshko bakoe.
\v 29 Bor ichaga, e shäng bor tjok, tja raye l̇l̇ëm, l̇l̇ëbo woyde l̈i shäryër ĩyado kjĩshko» l̈e.
\v 30 Kuya nopga tjeng eshko l̈irë ga nopga ara beno l̈öng mär ba go.
\s1 Abraham tjëyoga
\p 
\v 31 Eshko ga Jesús tjl̈ẽno judíoga mär beno l̈öng ba go l̈öng l̈i kong. Tjl̈ẽ ga «Tjl̈õkwo kjroromi l̈i rayëmi l̇l̇ëm ga pjãy ber l̈öng bor oppinggaga jl̈õkoyo.
\v 32 Enira tjl̈õkwo bek l̈i miydëmi l̈öng pjl̈ú, ga pjãy där e go» l̈e.
\p 
\v 33 Kuya l̈ok ga tjl̈ẽ ba kong ga «Tjawa Abraham tjëyoga, ga tjawa äätë parkagaga tjwl̈ẽk l̈öng pjir wl̈eniyo ë tjok l̇l̇ëme. ¿Eni ga tjawa ber l̈öng där wl̈o l̈ëp ega?»
\p 
\v 34 «L̈ër bomi kong jl̈õkoyo ga ëye l̇l̇ëbo owa shäryë ga ber l̈öng parkagaga tjwl̈ẽk l̈öng pjir wl̈eniyo dik. Ichaga beno ba wotjl̈ĩk owa l̈irë.
\v 35 Ga parkagaga tjwl̈ẽk l̈öng pjir wl̈eniyo, e shtoyo ber ba sogo l̈i pjeyoga tjok ĩyado wl̈o l̇l̇ëme. Woyde ameshko ga iche toe. Gueniyo ga ba wa l̇l̇ë, era ber sök ba pjeyoga tjok ĩyado wl̈o.
\v 36 Eni ga pjãy döga Sbö Wa ërerë ga pjãy döktong jl̈õkoyo.
\v 37 Miydër ga pjãy Abraham tjëyoga, l̈ëmi l̈öng sorë l̈i eni. Gueniyo ga tja zrömi woydë, bor tjl̈õkwo kjrëmi woydë l̇l̇ëm kjĩshko.
\v 38 L̇l̇ëbo ĩnor Data Sbö bokshto l̈i l̈otë shäng bomi kong, gueniyo pjãy jëk l̈öng tjl̈õkwo l̈aga bomi datarë bomi kong l̈i go» l̈e ba kong.
\p 
\v 39 Kuya l̈ok ga tjl̈ẽ ba kong ga «Tjawa Abraham tjëyoga» l̈e.
\p Kuya ga tjl̈ẽ ba kong l̈ok ga «Pjãy Abraham tjëyoga jl̈õkoyo kjwe ga pjãy opshäryë baĩya dik.
\v 40 Gueniyo tjl̈õkwo bek l̈ara Sbörë bor kong l̈i l̈ër shäng bomi kong, ga tja zrömi woydë e kjĩshko. ¡Abraham opshäryono eni l̇l̇ëme!
\v 41 Pjãy opshäryë l̈öng bomi data jl̈õkoyo l̈i ĩ dik» l̈e.
\p Kuya l̈ok ga tjl̈ẽ ba kong ga «Tjawa data obl̈ë l̇l̇ëme. Borwa data, e kjl̈araso, Sbö eröe» l̈e.
\p 
\v 42 Kuya ga tjl̈ẽ ba kong l̈ok ga «Tja tek Sbö shwoy dwayo, ga tja shrono shäng na. Eni ga Sbö, e bomi data jl̈õkoyo kjwe ga tja woydëmi ara. Tja shrono shäng bor woshko l̇l̇ëm, tja ichaga erë.
\v 43 ¿Tjl̈õkwo l̈ër shäng bomi kong l̈i l̇l̇ë l̈okl̈o miydëmi l̇l̇ëm ega? Tjl̈õkwo l̈i kjrëmi woydë l̇l̇ëm kjĩshko.
\v 44 Bomi data jl̈õkoyo l̈ër shäng bomi kong l̈i, e Ä. Pjãy wotjl̈ĩk baĩya dik, ga l̇l̇ëye woyde l̈i, e shäryëmi woydë eni. Wenoshko tek l̈ëkong ga e shäng no zröga ĩyado. Tjl̈õkwo bek l̈i rayara, e jyõrkë ä kjĩshko. Tjl̈ẽshko ga jyõrkë erä. Wotjl̈ĩk jyõ erä. Jyõrkagaga l̈öng kës data wl̈eni l̈i e.
\v 45 Gueniyo tjl̈õkwo l̈ër shäng bomi kong l̈i, e beke. Tjl̈õkwo l̈i kjrëmi l̇l̇ëm e kjĩshko.
\v 46 ¿Pjãy kjone dey ga tja ĩnomi l̇l̇ëbo owa shäryë? Ëye l̇l̇ëme. Tjl̈õkwo l̈ër shäng bomi kong l̈i, e beke. ¿Eni ga tjl̈õkwo l̈i kjrëmi l̇l̇ëm ega?
\v 47 Sbö tjl̈õkwo l̈i, e kuya ba nopga l̈öng kës l̈irë. Gueniyo pjãyda omkuk l̇l̇ëm, pjãy ba nopga l̇l̇ëm kjĩshko» l̈e.
\s1 Jesús tjl̈ẽno ba kjĩshko om go
\p 
\v 48 Kuya judío tjl̈apgaga l̈öng l̈irë ga tjl̈ẽ l̈ok ba kong ga «Pja Samaria so erä, pja goshko Ä sëya kjl̈ara bakoe. L̈ërwa eni, ga miydërwa ga e jl̈õe» l̈e.
\p 
\v 49 Kuya ga tjl̈ẽ ba kong l̈ok ga «Tja go Ä sëya l̇l̇ëme. L̇l̇ëye shäryër shäng l̈i, e shäryër bor Data bangkjrër kjĩshko. Gueniyo tja bangkjrëmi l̇l̇ëme.
\v 50 Tja ber tjwl̈õ ara l̈i wl̈ẽga tjarë l̇l̇ëme. E wl̈ẽga obl̈ërë. No l̇l̇gwega l̈i e.
\v 51 L̈ër bomi kong jl̈õkoyo ga bor tjl̈õkwo kol̈agaga l̈öng kës l̈i, e wol̈on l̇l̇ëme» l̈e.
\p 
\v 52 Kuya l̈ok ga tjl̈ẽ ba kong ga «Miydërwa bop tjl̈ẽ l̈i go ga pja goshko Ä sëya kjl̈ara jl̈õkoyo. Abraham, e wol̈onoe. Sbö tjl̈õkwo l̈agaga l̈öng kës l̈i, e wol̈ono bakoe. ¿Eni ga “Bor tjl̈õkwo kol̈agaga l̈öng kës l̈i, e wol̈on l̇l̇ëme” l̈ëp shäng eni sorëro?
\v 53 ¿Pja tjwl̈õ ara borwa kjokë Abraham kjinmo l̈ëpdo? Era wol̈ono, Sbö tjl̈õkwo l̈agaga l̈öng kës l̈i wol̈ono bakoe. ¿Eni ga pja ë l̈ëpdo?»
\p 
\v 54 «L̇l̇ëbo shäryër tjarë om go, tja ber kësbang, tjwl̈õ ara wl̈o kjwe ga e l̇l̇ëno l̇l̇ëme. Gueniyo bor iaga ber kësbang, tjwl̈õ ara l̈i, e bor Data, bomi Sbö l̈ëmi l̈i e.
\v 55 Gueniyo era miydëmi l̈öng l̇l̇ëme. Tjara ommiydë. Tja ommiydë l̇l̇ëme l̈oror bomi kong kjwe ga tja ber shäng jyõ l̈aga pjãy dik. Gueniyo tja ommiydë, ga ba tjl̈õkwo kol̈ër ĩyado.
\v 56 Bomi kjokë Abraham, tja wen tjwe kjok ëre kjing go dbaryo ëre ĩya woydë ara, koshara shäng woowa l̇l̇ëme. Ga pina Sbörë ba kongshko ga beno wopjl̈úe» l̈e.
\p 
\v 57 Kuya l̈ok ga tjl̈ẽ ba kong ga «Borwa kjokë Abraham, e wol̈ono tek dëna tjän, ga pja mite jã, pja l̈u pjl̈ogl̈o sak shkëng (50) l̇l̇ëm obi. ¿Eni ga Abraham ĩnop sorëro?»
\p 
\v 58 «L̈ër bomi kong jl̈õkoyo ga Abraham l̇l̇ëm obishko ga tja sök tjän» l̈e.
\p 
\v 59 Kuya l̈ok ga iirkono ara ba kong, ga akkwo kjrara l̈ok, l̈öya wl̈o l̈e, gueniyo Jesús opjneno, opshino to Sbö u jong l̈ishko dwayo.
\c 9
\s1 Domer kjok ĩgö l̇l̇ëm tek wenoshko dwayo poptara Jesúsdë kjl̈ara
\p 
\v 1 Jesús jek jëk shäng wopro ga domer ĩna sök kjl̈ara kjok ĩgö l̇l̇ëm, weno buk eni.
\v 2 Eshko ga ba oppinggaga tjl̈ẽ l̈ok ba kong ga «Tjl̈apga no pingga, ¿domer kjwe weno buk kjok ĩgö l̇l̇ëm kjweni ega? ¿L̇l̇ëbo owa shäryaga erëre, de ba datagarë?»
\p 
\v 3 «Eni l̇l̇ëme. Beno kjweni, opshäryono owa kjĩshko l̇l̇ëm, ba dataga opshäryono owa kjĩshko l̇l̇ëm bakoe. Domer kjwe kjok ĩgö l̇l̇ëm, Sbö dbo ara l̈i pin oba kong wl̈o.
\v 4 Pak twara bor ichagarë bi kong, shäryëy wl̈o. Ga dbar tjok obi wopro ga pak l̈i shäryëy kjl̈uwe. Dbar pjitong ga l̇l̇ëye shäryëy wl̈o ame.
\v 5 Tja sök kjok ëre kjing go obishko ga tja so iök jong shjiy nopga kjok ëre so kong kjoyo, kjok miyde l̈ok ara wl̈o» l̈e ba kong.
\p 
\v 6 Tjl̈ẽno pjir ga tröng tjwono kl̈ung kjing go, ga ba tröng l̈i rorwara kl̈ung sho tjok beno dishäng. Eshko ga kjrara sira, ga shtira domer sök l̈i bokkwo kjing go kar kar,
\v 7 ga tjl̈ẽ ba kong ga «Pja nom bokkwo shkwë di buk di bapkwo ko Siloé roshko l̈i go» l̈e. (Siloé, e ichara l̈okl̈o.)
\p Kuya ga to jek eshko, bokkwo shkwono di l̈ara l̈i go. E irgo ga tjwe shäng iröng obi, ga bokkwo poptono beno pjl̈úe.
\p 
\v 8 Ĩya ba pjeyoga l̈öng soshko l̈irë ga tjl̈ẽ l̈ok ëng kong ga «¿Domer kjwe, ĩy sök dbur rokë oba kong kjupargue kjwe l̇l̇ëmdo?» l̈e l̈ok eni. Nopga dämär ga omĩno dbur rokë oba kong wl̈eniyo oml̈ono eni bakoe.
\p 
\v 9 Eshko ga kjone kjone tjl̈ẽ ga «Kjwe jl̈õe» l̈e.
\p Kjone kjone obi tjl̈ẽ ga «L̇l̇ëme. Domer kjwe so e kjoyo erä» l̈e.
\p Tjl̈ẽ l̈öng l̇l̇ë l̈i kuya domer l̈irë ga tjl̈ẽ ba kong ga «Domer l̈ëmi l̈öng l̈i, e tja» l̈e.
\p 
\v 10 Kuya l̈ok ga tjl̈ẽ ba kong ga «¿Eni ga pja kjok ĩk pjl̈ú sorë?»
\p 
\v 11 «No shäng kjl̈ara kowëba Jesús. E dishäng shäryono sira, ga shtira bor bokkwo kjing go. E irgo ga tja ichara bokkwo shkwë di buk di bapkwo ko Siloé roshko l̈i go. E irgo ga tja öör bokkwo shkwë eshko, ga tja beno shäng kjok ĩk pjl̈úe» l̈e.
\p 
\v 12 Kuya l̈ok ga tjl̈ẽ ba kong ga «¿Domer l̈ëp shäng l̈i kwonl̇l̇o?»
\p «Miydër l̇l̇ëme» l̈e ba kong.
\s1 Fariseoga l̈ano domer poptono l̈i kjĩshko
\p 
\v 13-14 Eshko ga woshtozl̈ong dbaryo. E kjĩshko ga domer l̈i söra l̈ok, jek öötong shäng fariseoga l̈öng l̈i shwoy.
\v 15 Eshko ga fariseoga tjl̈ẽ l̈ok ba kong ga «¿Pja poptono sorë?»
\p «Dishäng shtira Jesúsdë bor bokkwo kjing go. E irgo ga tja bokkwo shkwono, ga tja beno shäng kjok ĩk pjl̈úe» l̈e ba kong.
\p 
\v 16 Kuya l̈ok ga kjone kjone tjl̈ẽ ga «Domer l̈e l̈i, woshtozl̈ong dbaryo jneya l̇l̇ëme. Miydëy e go ga e ichaga Sbörë l̇l̇ëme» l̈e.
\p Kjone kjone obi tjl̈ẽ ga «¿Gueniyo e l̇l̇ëbo owa shäryaga wl̈eniyo kjwe ga l̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shärye sorë?» l̈e. Eni ga beno l̈öng wotjl̈ĩk obl̈ë obl̈ë.
\p 
\v 17 E irgo ga tjl̈ẽno l̈ok domer poptono shäng l̈i kong obi. Tjl̈ẽ ga «Bokkwo poptono l̈i pja. ¿Eni ga bop kong ga domer l̈ëp shäng l̈i ë?»
\p «Bor kong ga domer l̈i, e Sbö tjl̈õkwo l̈aga» l̈e ba kong.
\p 
\v 18 Kuya judío tjl̈apgaga l̈öng l̈irë ga tjl̈õkwo kjre l̇l̇ëme. E kjĩshko ga no ichara l̈ok ba dataga wl̈okjrë.
\v 19 Söra l̈ok, öötong l̈öng eshko ga judío ichagaga l̈i tjl̈ẽ l̈ok ba kong ga «¿Weno kjok ĩgö l̇l̇ëm l̈ëmi l̈öng l̈i kjwe jl̈õre? ¿Eni ga shäng kjok ĩk pjl̈ú sorë?»
\p 
\v 20 «Miydërwa ga kjwe borwa wa jl̈õe. Ga weno kjok ĩgö l̇l̇ëme.
\v 21 Gueniyo eeri ga kjok ĩgö pjl̈ú sorë, poptaga ë, e miydërwa l̈öng l̇l̇ëme. Kjwe këguë tjän. Kjakrokozĩ ba kong om go dey, pjãy dborye om go wl̈o» l̈e ba kong.
\v 22-23 L̈ara l̈ok eni, judío tjl̈apgaga l̈i bangkjre l̈ok ara kjĩshko. Tjwayde l̈ok l̇l̇ëm obishko ga judío tjl̈apgaga l̈i tjl̈ẽno l̈ok ëng kong ga «Ëye tjl̈ẽno ga “No pjl̈uyo iche l̈e Sbörë l̈i, e Jesús” l̈ara ga ichërwa opzrëk bi syõ uyo roshko ame» l̈ara l̈ok eni pjir tjän, ga beno eni. E miydara domer l̈i data, mekërë pjire. Tjl̈ẽno ga «Kjwe këguë tjän. Kjakrokozĩ ba kong om go dey» l̈ara l̈ok eni e kjĩshko.
\p 
\v 24 E irgo ga domer bokkwo poptono l̈i rokara judío ichagaga l̈irë jek obi, ga tjl̈ẽ l̈ok ba kong ga «Miydërwa ga domer l̈ëp shäng l̈i, e l̇l̇ëbo owa shäryaga eröe. E kjĩshko ga tjl̈õkwo l̈os bëy, Sbö ber kësbang, tjwl̈õ ara wl̈o» l̈e.
\p 
\v 25 Kuya ga tjl̈ẽ ba kong l̈ok ga «Domer l̈i l̇l̇ëbo owa shäryagare, de l̇l̇ëm, e miydër shäng l̇l̇ëme. Gueniyo ga dämär ga tja kjok ĩgö l̇l̇ëm, ga eeri ga tja kjok ĩgö pjl̈úe. Era miydër pjl̈úe» l̈e.
\p 
\v 26 Eshko ga tjl̈ẽno l̈ok ba kong obi. Tjl̈ẽ ga «¿Bop bokkwo kjwe popteshko ga l̇l̇ëye shäryara bop kong?»
\p 
\v 27 «L̈oror bomi kong tjän, gueniyo tja tjl̈õkwo kjrëmi woydë l̇l̇ëme. ¿Kjakrokëmi bor kong kjër l̇l̇ëno? ¿Pjãy kjl̈opswë woydë ber l̈öng opping ba tjokde?» l̈e ba kong.
\p 
\v 28 Kuya l̈ok ga domer l̈i äyoshtakza l̈ok tjã tjã, tjl̈ẽ l̈ok ga «¡Ba oppingga l̈i pja eröe! ¡Tjawa opping Moisés tjl̈õkwo go!
\v 29 Miydërwa ga tjl̈õkwo l̈aga Moisés kong l̈i, e Sbö. Gueniyo domer l̈ëp shäng l̈i wen tjwe kjone dwayo miydërwa ëmdë l̇l̇ëme» l̈e.
\p 
\v 30 Kuya ga tjl̈ẽ ba kong l̈ok ga «¿E sorëro? E wen tjwe kjone dwayo miydëmi l̈öng l̇l̇ëm, gueniyo bor bokkwo poptara beno pjl̈úe.
\v 31 Miydëy pjl̈ú ga l̇l̇ëbo owa shäryaga syõshtë Sbö kongshko ga tjl̈õkwo kuya l̇l̇ëme. Gueniyo ëye Sbö poshrëk, l̇l̇ëye woyde l̈i shäryë ĩyado ga era syõshtë ba kong ga tjl̈õkwo kuya.
\v 32 ¿Kuy l̇l̇onoshko ga ëye weno kjok ĩgö l̇l̇ëm l̈i bokkwo poptaraba eni l̈ëba? Ëye l̇l̇ëme.
\v 33 Domer l̈i ichaga Sbörë l̇l̇ëm kjwe ga l̇l̇ëbo shärye kjweni ga äe» l̈e.
\p 
\v 34 Kuya l̈ok ga tjl̈ẽ ba kong ga «Pja wenoshko tek l̈ëkong ga pja l̇l̇ëbo owa shäryaga eröe. ¿Eni ga tjawa pim woydë ega?» l̈e l̈ok ba kong, ga ichara l̈ok judíoga syõ uyo dwayo, ga ichara l̈ok opzrëk e roshko ame.
\s1 Nopga kjok ĩgö l̇l̇ëm wl̈eniyo
\p 
\v 35 Roy kura Jesúsdë. Eni ga domer l̈i wl̈ẽna, ga tjl̈ẽ ba kong ga «¿Pja mär no to ter kjok dogo dwayo l̈i gore?»
\p 
\v 36 «Tjl̈apga, l̈ëp shäng l̈i ë l̈os bor kong, tja mär ber shäng ba go wl̈o» l̈e ba kong.
\p 
\v 37 Kuya ga tjl̈ẽ ba kong ga «E ĩnop tjän. Shäng l̈an bop tjok l̈i e» l̈e.
\p 
\v 38 Kuya ga tjl̈ẽ ba kong ga «Tjl̈apga, tja mär bop go» l̈e, ga kjök tono sök ba zl̈ong bäng, ga poshrëra.
\p 
\v 39 Eshko ga tjl̈ẽ domer l̈i kong ga «Tja shrono shäng kjok ëre kjing go no l̇l̇gwega, nopga kjok ĩgö l̇l̇ëm wl̈eni ber l̈öng kjok ĩk pjl̈ú wl̈o, nopga kjok ĩk pjl̈ú wl̈eni l̈i ber l̈öng kjok ĩgö ame wl̈o bakoe» l̈e.
\p 
\v 40 Fariseoga l̈öng eshko kjl̈öbö. Tjl̈ẽno eni l̈i kuya l̈ok ga tjl̈ẽ ba kong ga «¿E sorë? ¿Enira bop kong ga tjawa l̈öng kjok ĩgö l̇l̇ëm wl̈enire?»
\p 
\v 41 «Pjãy l̈öng kjok ĩgö l̇l̇ëm kjwe ga pjãy ber shdungko, l̇l̇ëbo owa shäryoromi l̈i kjĩshko l̇l̇ëme. Gueniyo pjãy kjok ĩk pjl̈ú l̈ëmi kuzong ga pjãy shdungko» l̈e.
\c 10
\s1 Öng wl̈ẽp ushko so daga pjl̈ú anmoyõ l̈i, e Jesús
\p 
\v 1 Eshko ga Jesús tjl̈ẽ obi ga «L̈ër bomi kong jl̈õkoyo ga ëye jek opzrëk öng wl̈ẽp ushko so kjëryo jong l̈i u bäng go l̇l̇ëm, gueniyo jek opzrëk ba pogl̈o go ga e öng l̈ũyotkaga.
\v 2 E ga ëye jek opzrëk u bäng l̈i go ga öng daga jl̈õkoyo l̈i e.
\v 3 Ga kong u bäng l̈i döya u bäng daga shäng l̈irë, opzrëk jek e go wl̈o. Eshko ga ba öng l̈i roke kjl̈arashko kjl̈arashko ba ko go, ga kuya ba öng tjeng l̈irë ga tjwe ba zl̈ong bäng, bapshiya to wl̈o.
\v 4 E irgo ga öng baĩya l̈i shira pjir ey dwayoshko ga jek shäng ba bäm go, ga öng l̈i jek tjeng ba irgo, ba daga ybö miyde l̈ok pjl̈ú kjĩshko.
\v 5 Gueniyo obl̈ë kjwe ga irpjãya l̈ok l̇l̇ëm, tök l̈ok l̇l̇et erä, ba ybö miyde l̈ok l̇l̇ëm kjĩshko» l̈e.
\v 6 Tjl̈ẽno öng wl̈ẽp ushko so jyãgl̈o go eni, gueniyo l̇l̇ë l̈okl̈o miydaraba l̇l̇ëme. \fig Öng shtoyo (Juan 10.1-10)|src="LB00014B.TIF" size="span" ref="John 10.1 "\fig*
\p 
\v 7 E kjĩshko ga tjl̈ẽ obi ga «L̈ër bomi kong jl̈õkoyo ga öng kjëryo u bäng l̈ër shäng l̈i, e tja om go l̈okl̈o.
\v 8 Nopga öör l̈öng bor bäm go kës l̈i, e öng l̈ũyotkaga wl̈eni, gueniyo öng l̈i rokara l̈okshko ga ba ybö kura l̈ok l̇l̇ëme.
\v 9 U bäng l̈ër shäng l̈i, e tja l̈okl̈o bakoe. Ëye jek opzrëk tja shäng l̈i go ga era döktonge. E opzrëk jek, opshik tek, ga kjl̈o sho ue wl̈ẽpe.
\p 
\v 10 »L̈ũgwanggaga tjwe l̈öng öng l̈i l̈ũyotkaga, zröga, pjiga bakoe. Tjara shrono shäng na, öng l̈i ber l̈öng së ĩyado Sbö tjok wl̈o, ber l̈öng wopjl̈ú wl̈o.
\v 11 Tja öng daga pjl̈ú anmoyõ wl̈eni. Öng daga pjl̈ú l̈i optwë wol̈on öng l̈i kjĩshko.
\v 12 Ëye parkë öng l̈i dë dbur kjĩy dö ga opshäryë eni l̇l̇ëm, öng l̈i baĩya l̇l̇ëm kjĩshko. Ĩya ga shjiti kjl̈oshko so iir ä wl̈eniyo tjwe sök kjl̈ara ga öng daga potjwl̈ẽk ĩ l̈i tök, ga öng l̈i raye beno tjeng tjoksa eshko. Eshko ga shjiti l̈i shrono ga öng l̈i shaya kjl̈ara, ga l̇l̇amo shdär ber kjl̈oroe.
\v 13 Öng daga potjwl̈ẽk ĩ l̈i töktong, ba kong ga öng l̈i tjwl̈õ ara l̇l̇ëm kjĩshko, dbur woydayde shäng eröe.
\p 
\v 14 »Tjara öng daga pjl̈ú anmoyõ wl̈eni. Bor öng l̈i miydër shäng pjl̈u, ga tja miyde l̈ok pjl̈ú bakoe.
\v 15 Tjawa ëng miydë l̈öng eni l̈i, e so Data Sbö miydër shäng pjl̈ú, ga tja miyde shäng pjl̈ú l̈i kjoyoe. Ga tja optwë wol̈on bor öng l̈i kjĩshko.
\v 16 Tja öng tjeng kjrina obi, gueniyo epga so öng kjëryo l̈ër shäng l̈i kjoyo l̇l̇ëme. Eni ëmdë ga bor ybö kuya l̈ok bakoe. Epga tön tjwe uunkong kjl̈uwe, bor öng l̈i ber tjeng kjrinaso wl̈o, öng daga ber kjl̈araso wl̈o bakoe.
\v 17 Tja optwë wol̈on ba kjĩshko, e irgo ga tja woshrë iröng obi. Tja woyde bor Datarë ara e kjĩshko.
\v 18 Woydoror eni l̇l̇ëm kjwe ga tja zröga ërë l̇l̇ëme. Tja optwë wol̈on wl̈o l̈aga tjarë. Tja kong dbo twara bor Datarë ara, tja optwë wol̈on wl̈o, tja woshrë iröng obi wl̈o bakoe» l̈e.
\p 
\v 19 Kuya judíoga l̈öng l̈irë ga beno l̈öng wotjl̈ĩk kjring pjök obi.
\v 20 Epga ara tjl̈ẽ ga «¡Domer kjwe goshko Ä sëya kjl̈ara! ¡Kjwe skwẽ! ¿Kuy ega?» l̈e.
\v 21 Gueniyo kjone kjone tjl̈ẽ ga «No goshko Ä sëyaga tjl̈ẽ eni l̇l̇ëme. ¿No kjok ĩgö l̇l̇ëm wl̈eniyo popte Ä sëyagarë sorëro?» l̈e l̈ok eni.
\s1 Judíoga mär woydë Jesús go l̇l̇ëme
\p 
\v 22 E irgo ga öötong kjok owa dbaryo, ga Sbö u iak beno jong dboy ba kong dbaryo l̈i shrëkoba wopro ga
\v 23 Jesús jek jëk shäng Salomón Shto buk l̈ishko. E ber buk Sbö u jong l̈ishko.
\v 24 Eshko ga kopjringa judío tjl̈apgagarë l̈ok pjribri, ga tjl̈ẽ l̈ok ba kong ga «¿Tjawa iëp ber tjeng wotjl̈ĩk pja ëro l̈ërwa äär jong l̇l̇onoro? No pjl̈uyo ichara Sbörë shrono shäng l̈i, e pja jl̈õkoyo wl̈eni ga l̈os borwa kong wẽl̈ë, miydërwa wl̈o» l̈e.
\p 
\v 25 Kuya ga tjl̈ẽ ba kong l̈ok ga «L̈oror bomi kong tjän, gueniyo tja tjl̈õkwo kjroromi l̇l̇ëme. L̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryër shäng bor Data ko goshko ara. Woyde ga e go ga tja ë miydëmi wẽl̈ëe.
\v 26 Gueniyo tja tjl̈õkwo kjrëmi l̈öng l̇l̇ëm, pjãy öng wl̈ẽp ushko so botoya l̇l̇ëm kjĩshko.
\v 27 Botoya l̈ira, bor ybö kuya l̈ok. Epga miydër pjl̈ú, ga jëk l̈ok bor irgo.
\v 28 Epga iër ber tjeng së ĩyado Sbö tjok, wol̈on ame. Tjeng bor wl̈oshko, ga döga ërë bor shjiryo l̇l̇ëme.
\v 29 Twaga bor Datarë beno tjeng bor kong. Era kësbang, uunkong kjinmo. Tjeng ba wl̈oshko, ga döga ërë ba shjiryo l̇l̇ëm bakoe.
\v 30 Tja, Data Sbö, tjawa kjl̈araso» l̈e.
\p 
\v 31 Kuya l̈ok ga iirkono ara ba tjok, ga akkwo kjrara l̈ok, l̈öya wl̈o l̈e,
\v 32 gueniyo Jesús tjl̈ẽ ba kong l̈ok ga «L̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryoror Data Sbö ko goshko ara. ¿Tja l̈ömi, zrömi woydë akkwo kjwe go l̇l̇ëbo shäryoror kjone dey l̈i kjĩshko?»
\p 
\v 33 «Pja l̈örwa e kjĩshko l̇l̇ëme. Pja no eröe. Gueniyo pja opyë woydë ber Sbö wl̈eni. Pja shäng Sbö l̈ãywë owa, iëp ber tjwl̈õ l̇l̇ëm wl̈o l̈ëp. Pja l̈örwa e kjĩshko» l̈e.
\p 
\v 34 Kuya ga tjl̈ẽ ba kong ga «Tak pjang bomi kjok l̇l̇gwekkl̈o go eni: “‘L̈ër bomi kong ga pjãy sböpga’ l̈e Sbörë eni.”\f + \fr 10:34 \ft Salmo 82.6.\f*
\v 35 Miydëy ga l̇l̇ëye tak pjang Sbö tjl̈õkwo go l̈i, e kjëy ga äe. Ga Sbö tjl̈ẽno nopga kong, ga kowara sböpga.
\v 36 Tja kjrara Data Sbörë, ga tja ichara ter shrono shäng kjok ëre kjing go. Eni ga ¿“Tja Sbö Wa” l̈oror bomi kongshko ga pjãy wotjl̈ĩk ga tja shäng Sbö l̈ãywë owa, tja ber tjwl̈õ ara wl̈o l̈ër l̈ëmi eni ega?
\v 37 Tja opshäryë bor Data dik l̇l̇ëm kjwe ga tja tjl̈õkwo kjrëmi l̇l̇ëm ga pjl̈úe.
\v 38 Gueniyo tja opshäryë Data Sbö dik kuzong ga tja tjl̈õkwo kjrëmi woydë l̇l̇ëm ëmdë ga woyde ga miydëmi l̇l̇ëbo shäryër shäng l̈i go ga Data Sbö shäng bor tjok, pjãy mär woydë bor go l̇l̇ëm gueniyo» l̈e.
\p 
\v 39 Kuya l̈ok ga shaywa l̈ok erä, gueniyo töktonge.
\p 
\v 40 E irgo ga Jesús jek öötong shäng Jordán diyo kjwo kal̈ëkong iröng obi, ga beno sök eshko, nopga wara Juandë dënashko, e kjokyo.
\v 41 Eshko ga nopga öötong l̈öng ara ba shwoy, ga tjl̈ẽ l̈ok ëng kong ga «L̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryara Juandë l̇l̇ëme. Gueniyo l̇l̇ëye l̈ara domer kjwe kjĩshko kës l̈i, e beno jl̈õe» l̈e l̈ok eni.
\v 42 Ga kjok eshko ga nopga ara beno l̈öng mär ba go.
\c 11
\s1 Lázaro wol̈onoe
\p 
\v 1-2 Domer shäng kjl̈ara ko Lázaro. E Betania so, ba dorga María, Marta, e kjokyo. María, poshtikkl̈o l̈õ pjl̈ëbl̈ë kwongga Tjl̈apga Jesús dre kjing go, ga dongga ba käkzong go l̈i e. Pjl̈ara ga Lázaro buk swl̈o ara.
\v 3 E kjĩshko ga ba dorga no ichono ba roy sök Jesús kong, tjl̈ẽ ba kong ga «Tjl̈apga, Lázaro woydëp ara l̈i, e buk swl̈o ara» l̈e.
\p 
\v 4 Kuya ga tjl̈ẽ ga «E shara swl̈orë, ba wol̈on dbaryo wl̈o l̈i öötong kjĩy l̇l̇ëme. E shäryono eni, Sbö ber kësbang, tjwl̈õ ara oba bokshto wl̈o, Sbö Wa ëre ber kësbang, tjwl̈õ ara oba bokshto wl̈o bakoe» l̈e.
\v 5 Lázaro woyde Jesúsdë ara, ba dorga woyde ara bakoe.
\v 6 Roy kura eni ëmdë ga beno shäng dbar pjök obi shäng l̈ishko.
\p 
\v 7 Eshko ga tjl̈ẽ ba oppinggaga kong ga «Shji to Judea kjokyo iröng obi» l̈e.
\p 
\v 8 Kuya l̈ok ga tjl̈ẽ ba kong ga «Tjl̈apga no pingga, kjupäshko ga kjok eshko ga pja l̈öya, zröya judíogarë l̈ara. ¿Eni ga pja jek woydë eshko iröng obi ega?» l̈e.
\p 
\v 9 Kuya ga tjl̈ẽno ba kong l̈ok l̇l̇ëbo jyãgl̈o go. Tjl̈ẽ ga «¿Dbar kjwobi go ga dl̈o të kjok shröngto äär jong kjok sëng ĩyado l̇l̇ëmdo? Ëye jëk shäng dba ga sabyë l̇l̇ëm, kjok shjiy kjĩy.
\v 10 Gueniyo ëye jëk shäng shkë ga era sabyë, kjok shjiy l̇l̇ëm kjĩshko» l̈e.
\v 11 E irgo ga tjl̈ẽ ba kong l̈ok obi ga «Bi kjl̈ara Lázaro, e buk pëe. Gueniyo tja to ba wol̇l̇eng» l̈e.
\p 
\v 12-13 Kuya l̈ok ga wotjl̈ĩk ga buk pë jl̈õkoyo l̈e. E kjĩshko ga tjl̈ẽ l̈ok ba kong ga «Tjl̈apga, ¿pono ga kayo yonkë l̇l̇ëmdo?» l̈e, miga «E buk pëe» l̈e Jesúsdë l̈i, e Lázaro wol̈onoe l̈ayde.
\p 
\v 14 Eni ga tjl̈ẽno ba kong l̈ok wẽl̈ëe. Tjl̈ẽ ga «¡Lázaro, e wol̈onoe!
\v 15 Gueniyo miydër ga tja shäng ey l̇l̇ëm l̈i, e ber bomi kong pjl̈úe. L̇l̇ëbo shäryër wl̈o l̈i ĩnomi ga pjãy mär ber l̈öng bor go jek këgong. E kjĩshko ga tja wopjl̈úe. Kjweri shji to ĩk» l̈e.
\p 
\v 16 Ba oppinggaga tjeng l̈i tjrëko shäng kjl̈ara ko Tomás, e kowëba Kjl̈ö bakoe. Eshko ga tjl̈ẽ ba pjeyoga oppinggaga tjeng l̈i kong ga «Shji to jek ba tjok, shji wol̈on ba tjok wl̈o» l̈e.
\s1 Lázaro woshrara Jesúsdë iröng obi
\p 
\v 17 Eni ga Jesús jek Betania kjokyo ba oppinggaga tjok. Gueniyo öötong l̈öng eshko ga Lázaro iaraba buk sakshko öötong dbargwo pkëng (4) tjän.
\v 18 Kjok eshko ga Jerusalén kjokyo ber buk soshko. Shji opshik jek jëk Jerusalén kjokyo dwayo kjok shröngto ga shji äär kjok eshko dl̈o kjókshko wl̈eni.\f + \fr 11:18 \ft Jerusalén kjokyo äär Betania kjokyo wl̈o ga e wop kilómetro mya dik.\f*
\v 19 Eni kuzong ga judíoga öötong l̈öng ara Jerusalén kjokyo dwayo, Marta, María, e yorkë wl̈o.
\p 
\v 20 Jesús jem shäng ääto eshko l̈i kuya Martarë ga jer ba wl̈okjrë irbo. Maríara beno sök ushko.
\v 21 Marta öötong shäng Jesús zl̈ong bäng ga tjl̈ẽ ba kong ga «Tjl̈apga, pja kjwe shäng ëreshko ga bor sing, e shinmotkono l̇l̇ëme.
\v 22 Gueniyo miydër ga öötong dbar kop ara tjän ëmdë ga l̇l̇ëye rokëp Sbö kong l̈i twe ber bop kong» l̈e.
\p 
\v 23 Kuya ga tjl̈ẽ ba kong ga «Bop sing, e woshrë iröng obi» l̈e.
\p 
\v 24 Kuya ga tjl̈ẽ ba kong ga «Miydër ga woshrë iröng obi kjok pjir dbaryo l̈ishko jã» l̈e.
\p 
\v 25 Kuya ga tjl̈ẽ ba kong ga «Nopga woshraga ber l̈öng së iröng obi l̈i, e tja. Nopga iaga ber l̈öng së ĩyado Sbö tjok l̈i, e tja bakoe. Ëye mär bor go ga wol̈ono ëmdë ga ber l̈öng së ĩyado.
\v 26 Ga ëye mär l̈öng bor go, ga beno l̈öng së ĩyado Sbö tjok ga era wol̈on ame. ¿L̇l̇ëye l̈ër shäng l̈i tjl̈õkwo kjrëpde?»
\p 
\v 27 «Ëng, Tjl̈apga. Miydër ga no pjl̈uyo, Sbö Wa iche l̈e Sbörë ter tjwe kjok ëre kjing go l̈i, e pja» l̈e ba kong.
\p 
\v 28 E irgo ga jem iröng ba ushko ba l̈ëng rokë. Öötong shäng eshko ga rokara dboshko, ga tjl̈ẽno ba kong tjoksa. Tjl̈ẽ ga «No pingga l̈i shrono shäng jũshko, ga pja roke shäng» l̈e.
\p 
\v 29 Kuya Maríarë ga kojono jekdo, ga jek Jesús ĩk.
\v 30 Eshko ga Jesús wl̈ẽna Martarë shäng kjone ga shäng eshko obi, tjwayde Betania kjokyo l̇l̇ëme.
\v 31 Eshko ga María kojono mal̈ing, ga opshino jek eshko dwayo l̈i ĩya judíoga tjeng ba yorkë eshko l̈irë ga wotjl̈ĩk l̈ok ga to sl̈ar sakshkoro l̈e, ga jek l̈ok ba irgo.
\p 
\v 32 Jesús ĩya Maríarë pjola dwayo ga jer öötong shäng ba zl̈ong bäng ga kjök tono, tjl̈ẽ ba kong ga «Tjl̈apga, pja kjwe shäng ëreshko ga bor sing, e shinmotkono l̇l̇ëme» l̈e.
\p 
\v 33 Eshko ga kjök tono sök sl̈ar ëë l̈i, judíoga l̈öng ba yorkaga l̈i sl̈ar l̈ok ara l̈i ĩya Jesúsdë ga jek wosong erä, beno woydë ara,
\v 34 ga tjl̈ẽ l̈öng l̈i kong ga «¿Shinmo l̈i ioromi beno buk kjone?»
\p «Ĩp woydë ga shji to ĩk» l̈e ba kong.
\p 
\v 35 Eshko ga Jesús sl̈ar ëëe.
\v 36 Ĩya judíoga l̈öng l̈irë ga tjl̈ẽ l̈ok ëng kong ga «Shinmo l̈i woydara ara, ĩzĩa» l̈e.
\p 
\v 37 Gueniyo kjone kjone tjl̈ẽ ga «Kjupä ga no kjok ĩgö l̇l̇ëm wl̈eniyo poptara domer kjwerë kjl̈ara. ¿Eni ga shinmo l̈i kjimtara wol̈on l̇l̇ëm wl̈o l̇l̇ëm ega?» l̈e.
\p 
\v 38 Eshko ga Jesús woydë ara obi. Sak l̈i jong guëng jong ööng kjwara l̈i roshko, ak kësbang iak jong kjwara ba bängzakkl̈o. Öötong shäng eshko ga
\v 39 tjl̈ẽ nopga tjeng l̈i kong ga «Ak kjwe kjozĩa» l̈e.
\p Kuya shinmo dor Marta l̈irë ga tjl̈ẽ ba kong ga «Gueniyo Tjl̈apga, e shinmotkono eeri ga öötong dbargwo pkëng (4). Eni ga l̈õ ong tjän» l̈e.
\p 
\v 40 Kuya ga tjl̈ẽ ba kong ga «Tja tjl̈ẽno bop kong tjän ga tja tjl̈õkwo kjrëp ga Sbö dbo kãl̈ã ĩp jl̈õkoyo l̈orop bop kong eni» l̈e.
\p 
\v 41 Eshko ga ak l̈i kjara l̈ok jong l̈ishko dwayo. E irgo ga kjok dogo ĩya Jesúsdë, tjl̈ẽ ga «Data, l̇l̇ëye l̈oror bop kong l̈i kurop. Tja wopjl̈ú bop tjok e kjĩshko.
\v 42 Miydër ga tja kup ĩyado, gueniyo l̈ër shäng ëre, nopga tjeng ëre kjĩshko, tja ichaga pjarë miyde l̈ok wl̈o» l̈e.
\p 
\v 43 Syõshtono eni pjir ga tjl̈ẽno dbo go. Tjl̈ẽ ga «¡Lázaro, pja opshis tek kjwey dwayo!» l̈e.
\v 44 Eshko ga shinmo iak buk sakshko l̈i opshino tek ey dwayo, gueniyo woshrono tek shäng së tjän. Eshko ga ba orkwo, ba dre, e poyrik shwomzrëng go, ga kä potaywak tuk shwong go bakoe. Eni ga Jesús tjl̈ẽ nopga tjeng l̈i kong ga «Ba poyrikkl̈o, ba kä potaywokl̈o kjwe dözĩa. Ga to wẽyẽ» l̈e.
\s1 Jesús zröya woydë judío ichagagarë l̈e
\p 
\v 45 Eni ga l̇l̇ëbo shäryara Jesúsdë l̈i ĩya judíoga öör l̈öng María yorkë l̈irë ga epga ara beno l̈öng mär ba go.
\v 46 Gueniyo kjone kjone obi jek l̈öng ba l̈anyotkë fariseoga kong.
\v 47 Kuya l̈ok ga Judío Kjok L̇l̇gwegaga Këskësyo rokara fariseoga, syõshtaga kägäyogarë l̈ok, ëng töng wl̈o. Eshko ga tjl̈ẽ l̈ok töno l̈öng l̈i kong ga «L̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shärye domer l̈irë ara. ¿Kjwëy l̇l̇ong?
\v 48 Rayëy ber kjweni ga nopga l̈öng kës l̈i kjl̈opswë mär ber l̈öng ba go eröe. Eni wl̈eni ga miydëy ga ëngkjwagaga iche bi ichagaga Roma so l̈irë bi Sbö u ëre pjik, ga bi tjëyoga ëre zröya l̈ok pjir bakoe» l̈e.
\p 
\v 49 Domer sök kjl̈ara eshko ko Caifás. L̈u eshko ga parkë sök syõshtaga kësbangyo. Eshko ga tjl̈ẽ töno l̈öng l̈i kong ga «Pjãy kjok miydë sira l̇l̇ëme.
\v 50 Pjl̈ú wl̈o ga no wol̈on kjl̈ara oba uunkong ãska, uunkong l̈i wol̈on l̇l̇ëm wl̈o. ¿E ëmdë ga miydëmi l̇l̇ëmdo?» l̈e.
\v 51 Caifás tjl̈ẽno sök eni, gueniyo l̈e sök ba woshko l̇l̇ëme. L̈u eshko ga parkë sök syõshtaga kësbangyo kuzong ga e iara Sbörë ba tjl̈õkwo l̈ë oba kong eni, ga tjl̈õkwo l̈ara l̈i, e Jesús wol̈on judíoga l̈öng kës ãska l̈i l̈okl̈o.
\v 52 Ga Jesús wol̈on ba ãska dö l̇l̇ëme. E wol̈on Sbö nopga shdöktong tjeng kjok kjwang jĩkong l̈i ãska, tö̃ya wl̈o, ber tjeng tjëyo kjrinaso wl̈o.
\v 53 Eni ga l̇l̇gwera l̈ok ëng tjok ga Jesús zröya l̈e. Ga eshko jek l̈ëkong ga beno l̈öng wotjl̈ĩk eni.
\p 
\v 54 E kjĩshko ga Jesús jëktong shäng judíoga bokshto ame. Opshino to jek eshko dwayo ba oppinggaga tjok, ga öötong beno l̈öng kjok buk kjrina ko Efraín, kjok dogro no l̇l̇ëmshko l̈i ber buk soshko.
\p 
\v 55 Eshko ga Israel tjëyoga döktong tek Egipto kjokyo dwayo dbaryo shrëkkl̈o judíoga kong l̈i döröe. Eni ga nopga to jem Jerusalén kjokyo ara ba kjokshko dwayo, dbaryo l̈i äätë l̇l̇ëm obishko ga ba sdëkwo l̈i shäryë, opyë äär Sbö poshrëk ba ushko ga pjl̈ú wl̈o.
\v 56 Eshko ga to l̈öng Jesús wl̈ẽk, ga kjakroke l̈ok ëng kong ga «¿Jesús tjwe dbar l̈i shrëk l̈ëpde?» l̈e l̈ok eni Sbö u zl̈ong bäng.
\p 
\v 57 Bäm go ga fariseoga, syõshtaga kägäyoga, e tjl̈ẽno nopga uunkong kong. Tjl̈ẽ ga «Jesús, e shäng kjone l̈i miydaga ë ga woydërwa ga l̈e borwa kong, sharwa wl̈o» l̈e l̈ok eni.
\c 12
\s1 Poshtikkl̈o l̈õ pjl̈ëbl̈ë tjwl̈õ ara wl̈eniyo tyara Maríarë Jesús dre kjing go
\p 
\v 1 Israel tjëyoga döktong tek Egipto kjokyo dwayo dbaryo shrëkkl̈o l̈i, kjwe dbargwo tjer (6) obishko ga Jesús jek öötong shäng Betania kjokyo, Lázaro sök l̈ishko. Dëna ga Lázaro wol̈ono, ga woshrara Jesúsdë iröng obi.
\v 2 Öötong shäng eshko ga dl̈i shäryaraba ba shrëkkl̈o. Ga dl̈i l̈i pjl̈orgara Martarë nopga uunkong tjeng eshko l̈i kong, ga tjrëko Lázaro sök bebi.
\v 3 Eshko ga María poshtikkl̈o l̈õ pjl̈ëbl̈ë tjwl̈õ ara wl̈eniyo söno bayo eeje\f + \fr 12:3 \fk Poshtikkl̈o l̈õ pjl̈ëbl̈ë tjwl̈õ ara \ft l̈i söra bayo litro bëy dik.\f* bapkwo kjwara kësbang tjung, ga tyara Jesús dre kjing go, ga dona ba käkzong go. Eshko ga u l̈i roshko beno l̈õ poshtikkl̈o l̈õ pjl̈ëbl̈ë l̈i eröe.
\p 
\v 4 Jesús oppinggaga tjeng l̈i tjrëko sök kjl̈ara ko Judas Iscariote, Jesús soynega l̈i e. L̇l̇ëye shäryë eshko l̈i ĩya ga tjl̈ẽ ga
\v 5 «¿Kjwe zãya kjweni ega? Soynena kjwe dburyo shaya bayo domer parkë dbargwo sak dbäw pjl̈ogl̈o mya (300) ãska wl̈eni, oba song wl̈eniyo kjimtokl̈o wl̈o dey» l̈e.
\v 6 L̈ara eni, oba song wl̈eniyo kjimte woydë kjĩy l̇l̇ëme. E iak beno shäng dbur bapkwo daga ba pjeyoga kong. Ol̈ö ga dbur iak tjeng ba bapkwo roshko l̈i l̈ũyotke, e l̈ũgwang kjĩshko. L̈ara eni e kjĩshko.
\p 
\v 7 Kuya Jesúsdë ga tjl̈ẽ ba kong ga «¡Wẽyẽ! Poshtikkl̈o kjwe beno bor kong, tja iëba sakshkoshko ga bor doyo ëre beno poshtik pjir tjän wl̈o.
\v 8 Oba song wl̈eniyo, e l̈öng bomi tjok ĩyado, gueniyo tjara shäng bomi tjok ĩyado l̇l̇ëme» l̈e.
\s1 Lázaro zröya woydë syõshtaga kägäyogarë
\p 
\v 9 Eshko ga Jesús öötong shäng Betania kjokyo l̈i roy miydara judíoga ararë, ga shrono l̈öng ba ĩk. Shrono l̈öng Lázaro ĩk bakoe. Wol̈ono, ga woshrara Jesúsdë iröng obi l̈i e.
\v 10-11 Lázaro kjĩshko ga judíoga ara mär beno l̈öng Jesús go. E kjĩshko ga syõshtaga kägäyoga wotjl̈ĩk l̈ok ga «Lázaro ëmdë ga zröy bakoe» l̈e l̈ok ëng kong eni.
\s1 Jesús öötong opzrëno Jerusalén kjokyo, pjl̈u wl̈eni
\p 
\v 12 Wẽshko ga Jesús opshino jek Betania kjokyo dwayo jongya Jerusalén kjokyo. Roy miydara nopga öötong l̈öng eshko dbar shrëk l̈irë.
\v 13 Eni ga mek korga kjrara, söra l̈ok jek ba tjok, ga to jongya ba wl̈okjrë. Ga tjl̈ẽ l̈ok dbo go ga
\q1 «Kjwe pjl̈ú jl̈õe.
\q1 Ichara Tjl̈apgarë shrono kjok ëreshko.
\q2 Kjwe kjimte Sbörë.
\q1 Kjwe Israel tjëyo pjl̈uyo.
\q2 Kjwe kjimte Sbörë» l̈e.
\p 
\v 14 E bäm go ga öng so kwomgl̈a kjoyo dre töshko l̇l̇gwokl̈ë wl̈eniyo wl̈ẽna Jesúsdë kjl̈ara, ga opyono sök ba kjing go, tak pjang Sbö tjl̈õkwo go sorë l̈i eni. Tjl̈ẽno beno eni:
\q1 
\v 15 «Sión\f + \fr 12:15 \fk Sión \ft kjokyo, e kowëba \fk Jerusalén \ft bakoe.\f* sopga, l̇l̇ëye bangkjrëmi l̇l̇ëme.
\q2 ¡Ĩzĩa! Bomi pjl̈uyo, e tek sök döröe.
\q2 Tjwe sirkeno sök öng so kwomgl̈a kjoyo dre töshko l̇l̇gwokl̈ë wl̈eniyo kjing go.»\f + \fr 12:15 \ft Zacarías 9.9.\f*
\p 
\v 16 Eshko dbaryo ga l̇l̇ëbo shäryono l̈i, e l̇l̇ë l̈okl̈o miyde Jesús oppinggaga tjeng l̈irë l̈öng l̇l̇ëme. Gueniyo Jesús briktong to jem kjok dogo irgo ga l̇l̇ëbo shäryono Jesús kong ëre, e tak beno pjang Sbö tjl̈õkwo go ba kjĩshko tek dëna tjän l̈i miyde l̈ok kjwl̈ë jã.
\p 
\v 17 Shinmo Lázaro buk sakshko obishko ga Jesús öör shäng eshko, rokara tek ey dwayo, ga woshrara iröng obi. Ga Jesús opzrëk jek Jerusalén kjokyo roshkoshko ga nopga öör l̈öng ba tjok sakshko kjupäbäshko l̈i, e jek l̈öng ba irgo eshko, roy l̈e l̈öng oba kong.
\v 18 Roy kura nopga l̈öng eshko l̈irë, ga opshino tek l̈ok ara ba wl̈okjrë.
\v 19 Eshko ga ĩya fariseogarë l̈ok ga tjl̈ẽ l̈ok ëng kong ga «¿Ĩmi ga sorë? Shji zanae. Nopga tjeng kës kjwe to jek ba shwo l̈ëkong drete» l̈e.
\s1 Jesús l̈ano ba wol̈on dbaryo kjĩshko
\p 
\v 20 Nopga öötong l̈öng eshko dbar shrëk l̈i tjrëko, Grecia sopga l̈öng kjl̈öbö bakoe.
\v 21 Domer shäng kjl̈ara eshko obi ko Felipe, e Betsaida so. Grecia sopga l̈i tjl̈ẽ l̈ok ba kong ga «Tjl̈apga, tjawa l̈an woydë Jesús tjok» l̈e.
\p 
\v 22 Kuya ga jek shäng Andrés shwoy, ga l̈ara ba kong. E irgo ga jek öötong l̈öng ba l̈ë Jesús kong.
\p 
\v 23 Kuya Jesúsdë ga tjl̈ẽ ba kong l̈ok ga «No to ter kjok dogo dwayo ëre ber kësbang, tjwl̈õ ara nopga uunkong bokshto l̈i, e dbaryo öötonge.
\v 24 L̈ër bomi kong jl̈õkoyo ga dwl̈a l̇l̇ë botjyë ber ara wl̈o ga l̈on jer kl̈ung kjing go, ga kjer guing. Enira dwl̈a wen ara obi, l̇l̇ëm ga l̇l̇ëye wen l̇l̇ëme.
\v 25 Ëye wotjl̈ĩk opdë om go, zrökoba bor kjĩshko l̇l̇ëm wl̈o l̈e ga äär kjok dogo l̇l̇ëme. Gueniyo ëye wotjl̈ĩk ara ber sök së kjok ëre kjing go wl̈o l̇l̇ëm ga era ber sök së ĩyado Sbö tjok.
\v 26 Ëye parkë woydë bor kong l̈e ga woydër ga jëk l̈öng bor tjok ĩyado, tja äär sök kjone ga e äär l̈öng eshko bakoe. Ga ëye parkë bor kong ga ie bor Datarë ber l̈öng tjwl̈õ ara.
\p 
\v 27 »Eeri ga tja ëre wosonge. L̇l̇ëye shäryër miydër l̇l̇ëme. Tja shrono shäng na, l̇l̇ëye wen tjwe bor kong l̈i wen bor kong wl̈o. E kjĩshko ga “Data, tja kjimtos, tja dös l̇l̇ëye wen tjwe bor kong l̈ishko dwayo” l̈ër ga äe» l̈e.
\p 
\v 28 E irgo ga tjl̈ẽ obi ga «Data, pja ko ios ber kësbang, tjwl̈õ ara» l̈e.
\p Eshko ga ybö kuraba ter kjok dogo dwayo. Tjl̈ẽ ga «Bor ko ioror beno kësbang, tjwl̈õ ara tjän. Ga shäryër jek obi» l̈e.
\v 29 Kuya nopga l̈öng l̈irë ga kjone kjone tjl̈ẽ ga «E kjrik» l̈e, kjone kjone obi tjl̈ẽ ga «E Sbö parkaga kjok dogo so l̈i tjl̈ẽkdo ba kong» l̈e.
\p 
\v 30 Eni ga Jesús tjl̈ẽ ba kong l̈ok ga «Ybö kuroy l̈i tjl̈ẽno beno bor kong l̇l̇ëm, beno bomi kong.
\v 31 Nopga Sbö miydë l̇l̇ëm wl̈eniyo l̇l̇gwezl̈ong dbaryo l̈i öötonge. Kjok ëre ichaga l̈i,\f + \fr 12:31 \fk Kjok ëre ichaga \ft l̈e l̈i, e \fk Ä \ft l̈okl̈o.\f* e kjozl̈ong kjok ëre kjing go dbaryo l̈i öötong bakoe.
\v 32 Tjara poyonaba kjok ëre kjing go dwayo jem pjang kjomoshko ga nopga uunkong iër tek l̈öng bor shwoy» l̈e.
\v 33 L̈ara eni, e wol̈on sorë l̈i l̈okl̈o.
\p 
\v 34 Eshko ga nopga l̈öng l̈i tjl̈ẽ ba kong ga «No pjl̈uyo iche l̈e Sbörë l̈i ber sök së ĩyado, tak pjang kjok l̇l̇gwekkl̈o tara Moisésdë l̈i go eni. Ga pja tjl̈ẽ ga no to ter kjok dogo dwayo l̈i pja. ¿Eni ga pja poyongoba pjang kjomo kjl̈uwe l̈ëp sorë? ¿No to ter kjok dogo dwayo l̈i pja l̈ëp shäng l̈i l̇l̇ë l̈okl̈o?»
\p 
\v 35 «Iök shjiy ëre ber shäng bomi tjrëko dbar kjwöbö obi döe. E wopro ga pjãy jëk l̈öng bor go, pjãy wl̈ẽna shkërëshko ga pjãy sabyë l̇l̇ëm wl̈o. Ëye jëk shäng kjok ro sĩ roy ga jongya kjone miyde l̇l̇ëme.
\v 36 Eni ga iök shjiy ëre shäng obishko ga pjãy mär ber l̈öng bor go, pjãy opyë ber l̈öng so tja kjoyo wl̈o» l̈e ba kong. Tjl̈ẽno ba kong pjirshko ga opshino to eshko dwayo, ga opjnenoe.
\s1 Judíoga mär woydë Jesús go l̇l̇ëm obi
\p 
\v 37 L̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryara Jesúsdë kës ëre nopga l̈i bokshto. Eni ëmdë ga mär woydë ba go l̇l̇ëm obi.
\v 38-41 Shäryono eni, tjl̈õkwo tara Sbö tjl̈õkwo l̈aga tek dënashko so Isaíasdë l̈i ber jl̈õkoyo wl̈o. Jesús dbo kãl̈ã ĩna, ga tjl̈ẽno ba kjĩshko. Tjl̈ẽno beno eni:
\q1 «Tjl̈apga, ¿borwa tjl̈õkwo kjraga ëro?
\q2 ¿Bop dbo ara l̈i ĩga ëro?»\f + \fr 12:38-41 \ft Isaías 53.1.\f*
\m Tjl̈ẽno beno obi eni:
\q1 «Epga iara Tjl̈apgarë beno l̈öng kjok ĩgö l̇l̇ëm wl̈eni,
\q2 iara beno l̈öng l̇l̇ëye kuya woydë l̇l̇ëm bakoe.
\q1 Shäryara eni,
\q2 l̇l̇ëye ĩya l̈ok ba bokkwo go l̇l̇ëm wl̈o,
\q2 l̇l̇ëye kuya l̈ok l̇l̇ëm wl̈o,
\q2 optwë ber l̈öng bor kong l̇l̇ëm wl̈o,
\q2 epga dör l̇l̇ëm wl̈o.»\f + \fr 12:38-41 \ft Isaías 6.10.\f*
\m Epga mär ber l̈öng ba go ga ä e kjĩshko.
\p 
\v 42 Eni ëmdë ga judíoga ara mär l̈öng ba go, ba ichagaga kjone kjone bakoe. Gueniyo bangkjre l̈ok ga iche fariseogarë opzrëk judíoga syõ uyo roshko ame. E kjĩshko ga l̇l̇ëye l̈ara l̈ok ë kong l̇l̇ëme.
\v 43 Woydara l̈ok ga ber l̈öng pjl̈ú oba bokso. Ba kong ga e tjwl̈õ ara, ber l̈öng pjl̈o bek Sbö bokso l̈i kjinmo.
\s1 Jesús shrono shäng kjok ëre kjing go no döga
\p 
\v 44 Eshko ga Jesús tjl̈ẽno nopga kong dbo go. Tjl̈ẽ ga «Ëye mär bor go ga mär bor go dö l̇l̇ëme. E mär bor ichaga go bakoe.
\v 45 Ga tja ĩyashko ga bor ichaga ĩya bakoe.
\v 46 Tja shrono shäng kjok ëre kjing go iök shjiy wl̈eni, nopga mär bor go l̈i ber l̈öng kjok ro sĩ roy wl̈eni ame wl̈o.
\p 
\v 47 »Tja shrono shäng nopga kjok ëre so l̈i l̇l̇gwega l̇l̇ëm, tja shrono shäng ba döga. E kjĩshko ga ëye bor tjl̈õkwo kuno, gueniyo kjrara l̇l̇ëm ga e l̇l̇gwega tjarë l̇l̇ëm,
\v 48 e l̇l̇gwega obl̈ërë. Kjok pjir dbaryo l̈ishko ga e l̇l̇gwega Sbörë, ga shdũya, bor tjl̈õkwo kjrara l̇l̇ëm kjĩshko, tja wl̈okjrara l̇l̇ëm kjĩshko bakoe.
\v 49 Tjl̈õkwo l̈i l̈oror bor woshko l̇l̇ëme. L̇l̇ëye l̈oror l̈i, l̈oror sorë l̈i, e l̈aga Data Sbö, bor ichaga l̈irë bor kong,
\v 50 ga l̈oror eni. Miydër ga ba tjl̈õkwo kjragaga l̈i ie ber l̈öng së ĩyado ba tjok. L̈oror eni e kjĩshko» l̈e.
\c 13
\s1 Ba oppinggaga dre shkwara Jesúsdë
\p 
\v 1 Eshko ga Israel tjëyoga döktong tek Egipto kjokyo dwayo dbaryo shrëkkl̈o l̈i döröe. Ga miyde Jesúsdë ga kjok ëre raye ber, ga jongya iröng Data Sbö sök l̈ishko dbaryo l̈i öötonge. Ba nopga l̈öng kjok ëre kjing go l̈i woydara ara ĩyado, ga pina ba kong, äär jong pjirshko.
\p 
\v 2 Judas Iscariote, e Simón wa. Jesús ië ba oppinggaga tjok kjok sëng l̈i dl̈oyo äätë l̇l̇ëm obishko ga Judas go Ä shrono beno ba tjok, ga ichara wotjl̈ĩk Jesús soynek, ga twe ba wl̈oyoga kong tjän.
\v 3 Miyde Jesúsdë pjir ga l̇l̇ëbo tjeng kës l̈i iara Data Sbörë beno tjeng ba wl̈oshko. Miyde ga ter Sbö shwoy dwayo, ga jongya ba shwoy iröng obi.
\v 4 Eni ga sök ië ba oppinggaga tjokshko ga kojono shäng, ba shwong kop l̈ëkong l̈i skwara, ga ãska shwong podonggl̈o wl̈eniyo pjrira pjang pjribri ba dop go.
\v 5 Eshko ga di kjrara, tjyara ba bapkwo roy, ga opyono sök ba oppinggaga tjeng eshko l̈i dre shkwë, ga ba dre dõya sök shwong podonggl̈o l̈i go.
\p 
\v 6 Öötong sök Simón Pedro dre shkwë ga Pedro tjl̈ẽ ba kong ga «Tjl̈apga, ¿tja dre shkwëp l̈ëpdo?»
\p 
\v 7 «L̇l̇ëye shäryër bop kong l̈i, e l̇l̇ë l̈okl̈o miydëp sök l̇l̇ëme. Gueniyo l̇l̇ono ga l̇l̇ëbo ëre l̇l̇ë l̈okl̈o miydëp pjire» l̈e ba kong.
\p 
\v 8 Kuya ga tjl̈ẽ ba kong ga «L̇l̇ëme. Pja ichër bor dre shkwë l̇l̇ëme» l̈e.
\p Kuya ga tjl̈ẽ ba kong ga «Bop dre kjwe shkwër l̇l̇ëm ga pja ber no botoya l̇l̇ëme» l̈e.
\p 
\v 9 Kuya ga tjl̈ẽ ba kong ga «Tjl̈apga, enira woydër ga tja dre shkwëp dö l̇l̇ëme. Bor orkwo, bor kägä, e shkwos bor kong bakoe» l̈e.
\p 
\v 10 Kuya ga tjl̈ẽ ba kong ga «Ëye wono pjir tjän ga doyo uunkong beno drëpdrëe. Eshko ga woyde ga ba dre shkwoydë eröe. Ga pjãy l̈öng drëpdrë wl̈eni tjän, gueniyo pjãy uunkong l̇l̇ëme» l̈e.
\v 11 Miyde ga ba soynega ba wl̈oyoga kong l̈i sök kjone dey, l̈öng drëpdrë wl̈eni uunkong l̇l̇ëme l̈ara eni e kjĩshko.
\p 
\v 12 Ba oppinggaga dre shkwara pjir ga shwong kop l̈ëkong skwara dämär l̈i pjuna jek obi, ga öötong sirkeno sök ba iozl̈ong shtoyo iröng obi. Eshko ga tjl̈ẽ ba oppinggaga kong ga «¿L̇l̇ëbo shäryoror bomi kong kjwe l̇l̇ë l̈okl̈o miydëmire?
\v 13 Tja kowëmi no pingga, l̇l̇ëm ga Tjl̈apga l̈ëmi, ga l̈ëmi eni l̈i beke.
\v 14 Tja bomi Tjl̈apga, bomi pingga. Eni ga pjãy dre shkworor kuzong ga woyde ga pjãy ëng dre shkwë kar kar eni bakoe.
\v 15 Shäryoror bomi kong kjweni, ĩmi wl̈o, pjãy omshäryë ëng kong kjweni ĩyado wl̈o.
\v 16 L̈ër bomi kong jl̈õkoyo ga parkagaga tjwl̈ẽk l̈öng pjir wl̈eniyo tjwl̈õ ara, ba sogo kjinmo l̇l̇ëme. Ëye roy söga wl̈eniyo ga e tjwl̈õ ara, ba ichaga kjinmo l̇l̇ëm bakoe.
\v 17 Tjl̈õkwo l̈ër shäng bomi kong l̈i, e l̇l̇ë l̈okl̈o miydëmi l̈öng pjl̈úe. Ga shäryëmi eni wl̈eni ga pjãy ie Sbörë ber wopjl̈úe.
\p 
\v 18 »Gueniyo l̈ër shäng pjãy uunkong kong l̇l̇ëme. Kjroror tjeng botoya l̈i ë, e miydër sök pjire. Gueniyo ëre shäryë jũni, Sbö tjl̈õkwo tak pjang l̈i ber jl̈õkoyo wl̈o. Tjl̈ẽno beno eni: “Ëye ië sök bor tjok ga kworkwono beno sök bor wl̈oyo.”\f + \fr 13:18 \ft Salmo 41.9.\f*
\v 19 L̇l̇ëbo ëre l̈ër shäng bomi kong, e shäryoydë l̇l̇ëm obishko. Eni ga shäryonoshko ga miydëmi e go ga Sök Ĩyado l̈i, e tja.
\v 20 L̈ër bomi kong jl̈õkoyo ga ëye, no ichoror l̈i wl̈okjrara ga tja wl̈okjrara wl̈eni. Ëye, tja wl̈okjrara ga bor ichaga wl̈okjrara wl̈eni bakoe» l̈e.
\s1 «Pjãy kjl̈ara, tja soyneya, twe bor wl̈oyoga kong» l̈ara Jesúsdë
\p 
\v 21 Tjl̈ẽno eni pjir ga wosonkono ara, ga tjl̈ẽ ga «L̈ër bomi kong jl̈õkoyo ga pjãy kjl̈ara, tja soyneya, twe bor wl̈oyoga kong» l̈e.
\p 
\v 22 Kuya l̈ok ga beno l̈öng ëng bokkwo ĩk drëng kjl̈arashko kjl̈arashko, gueniyo ë l̈ayde miyde l̈ok l̇l̇ëme.
\v 23 Kjl̈ara sök Jesús zl̈ong bäng, woyde Jesúsdë ara ba kjl̈ara wl̈eni l̈i\f + \fr 13:23 \fk Ba oppingga woyde ara ba kjl̈ara wl̈eni \ft l̈e l̈i, e \fk Juan \ft l̈ayde.\f* e.
\v 24 Eshko ga Simón Pedro kä wikzong sök eshko l̈i kong, ë l̈ayde kjakroke Jesús kong wl̈o.
\p 
\v 25 Ĩya ga tjl̈ẽ Jesús kong ga «Tjl̈apga, ¿ë l̈opdë?» l̈e ba kwomsoshko.
\p 
\v 26 Kuya ga tjl̈ẽ ba kong ga «Pjl̈ung shosho suk pjir ëre pör, ga twër ë kong ga e e» l̈e. Eshko ga pjl̈ung shosho suk pjir l̈i pöra, ga twara Judas Iscariote, Simón wa l̈i kong.
\v 27 Ga pjl̈ung shosho suk pjir l̈i kjrarashko ga go Ä shrono beno ba tjok.
\p Eshko ga Jesús tjl̈ẽ Judas kong ga «L̇l̇ëye shäryëp wl̈o l̈i shäryos mal̈inge» l̈e.
\v 28 Kura ba oppinggaga l̇l̇amo tjeng l̈irë, gueniyo l̇l̇ë l̈ayde sök l̈i miyde l̈ok l̇l̇ëme.
\v 29 Judas iak beno shäng dbur daga ba pjeyoga kong. E kjĩshko ga kjone kjone wotjl̈ĩno ga ichara Jesúsdë l̇l̇ëbo tjwl̈ẽk ba dbar shrëya wl̈o l̈i kong, l̇l̇ëm ga ichara dbur twë oba song wl̈eniyo kong l̈ara.
\v 30 Eni ga pjl̈ung shosho suk pjir l̈i kjrara Judasdë pjir ga opshino to ey dwayo. Eshko ga kjok shkë tjän.
\s1 Tjl̈õkwo tjagl̈ën
\p 
\v 31 Judas opshino to irgo ga Jesús tjl̈ẽ ba oppinggaga beno tjeng l̈i kong ga «No to ter kjok dogo dwayo ëre ber kësbang, tjwl̈õ ara oba bokso, ga Sbö ber kësbang, tjwl̈õ ara bor kjĩshko eni bakoe.
\v 32 Eni ga Sbö iër ber kësbang, tjwl̈õ ara eni ga Sbö Wa ëre ie ber kësbang, tjwl̈õ ara eni bakoe. Ga shärye eni mal̈inge.
\p 
\v 33 »Pjãy bor wapga wl̈eni. Tja ber sök bomi tjok sira obi eröe. L̇l̇ëbo l̈oror judíoga kong l̈i, e l̈ër bomi kong eni bakoe. Tja to irgo ga tja wl̈ẽmi, gueniyo tja öötong sök l̈ishko ga pjãy äär eshko ga äe.
\v 34 Tjl̈õkwo l̈ër bomi kong, shäryëmi wl̈o l̈i, e tjagl̈ën. Pjãy ëng woydos ara kar kare. Pjãy woydoror sorë ga pjãy ëng woydos kar kar eni bakoe.
\v 35 Shäryoromi eni wl̈eni ga miydëba e go ga pjãy bor oppinggaga jl̈õkoyo» l̈e.
\s1 «“Jesús, e ë miydër l̇l̇ëme” l̈ëp oba kong» l̈ara Jesúsdë Pedro kong
\p 
\v 36 Eshko ga Simón Pedro tjl̈ẽ ba kong ga «Tjl̈apga, ¿pja to kjone?»
\p «Tja to äär kjone l̈ishko ga pja äär eshko ga äe. Gueniyo l̇l̇ono ga pja jek äär bor irgo» l̈e ba kong.
\p 
\v 37 Kuya ga tjl̈ẽ ba kong ga «Tjl̈apga, ¿tja jek bop tjok eni tjok ga ä ega? Tja optwë wol̈on bop kjĩshko ga pjl̈úe» l̈e.
\p 
\v 38 Kuya ga tjl̈ẽ ba kong ga «¿Pja optwë wol̈on bor kjĩshko jl̈õkoyore? L̈ër bop kong jl̈õkoyo ga pjesit kjok shränto ga kjörkö kjl̈untë l̇l̇ëm obishko ga “Jesús, e ë miydër l̇l̇ëme” l̈orop oba kong pjl̈ogl̈o mya tjän» l̈e.
\c 14
\s1 Shji äär Data sök l̈ishko sorë
\p 
\v 1 Eshko ga Jesús tjl̈ẽ ba oppinggaga kong ga «Pjãy wosonkë l̇l̇ëme. Pjãy mär ber l̈öng Sbö go, pjãy mär ber l̈öng bor go bakoe.
\v 2 Bor Data ushko ga nopga ber l̈öng wl̈o l̈i shtoyo ara. Eni l̇l̇ëm kjwe ga l̈oror bomi kong tjän. Tja to shto poshäryë bomi kong eshko.
\v 3 Ga shto poshäryër bomi kong kuzong ga tja tjwe iröng obi bomi wl̈okjrë, ga pjãy sör bor tjok, pjãy äär ber l̈öng bor tjok eshko wl̈o.
\v 4 Irbo jek äär tja to kjone l̈ishko l̈i miydëmi l̈öng pjir tjän» l̈e.
\p 
\v 5 Kuya l̈ok ga Tomás tjl̈ẽ ba kong ga «Tjl̈apga, pja to kjone miydërwa l̈öng l̇l̇ëme. ¿Eni ga irbo l̈i miydërwa sorë?»
\p 
\v 6 «Pjãy äär ber l̈öng Data Sbö sök l̈ishko bor kjĩshko. Tjl̈õkwo bek l̈i miydëmi bor kjĩshko. Pjãy äär ber l̈öng së jl̈õkoyo bor kjĩshko bakoe. Ëye mär bor go l̇l̇ëm ga äär Data Sbö sök l̈ishko l̇l̇ëme.
\v 7 Bäm goshko ga tja ë miydoromi l̇l̇ëme. E kjĩshko ga bor Data miydoromi l̇l̇ëm bakoe. Gueniyo eeri jek l̈ëkong ga e miydëmi l̈öng pjl̈ú, e ĩnomi shäng wl̈eni kjĩshko» l̈e.
\p 
\v 8 Eshko ga Felipe tjl̈ẽ ba kong ga «Tjl̈apga, Data Sbö pĩs borwa kong. Woydërwa l̈i e eröe» l̈e.
\p 
\v 9 Kuya ga tjl̈ẽ ba kong ga «Felipe, tja shäng bomi tjok dbar kop ara tjän. ¿Eni ga tja miydëp shäng l̇l̇ëm obire? Ëye, tja ĩna ga Data Sbö ĩna bakoe. ¿Eni ga “Data Sbö pĩs borwa kong” l̈ëp bor kong sorëro?
\v 10 Tja shäng ba tjok, ga e shäng bor tjok bakoe. Tjawa kjl̈araso. ¿E jl̈õe l̈ëmi l̇l̇ëmde?» l̈e.
\p Eshko ga tjl̈ẽ ba oppinggaga uunkong l̈öng l̈i kong ga «Tjl̈õkwo l̈ër shäng bomi kong l̈i, e botoya l̇l̇ëme. Jl̈õkoyo ga pak shäryër shäng l̈i, e shäryaga Data Sbö shäng bor tjok l̈irë.
\p 
\v 11 »Tja shäng ba tjok, ga e shäng bor tjok bakoe. Tjawa kjl̈araso. E jl̈õe l̈ozĩa. L̇l̇ëm ga pjãy mär bor go, l̇l̇ëbo shäryoror ĩnomi l̈i kjĩshko.
\v 12 L̈ër bomi kong jl̈õkoyo ga ëye mär bor go ga pak shäryër shäng l̈i shärye eni. Ga tja to Data Sbö shwoy irgo ga pak shärye kësbang e kjinmo bakoe.
\v 13 Ga l̇l̇ëye rokëmi bor kong bor ko go kës l̈i shäryër bomi kong, Data Sbö iër ber kësbang, tjwl̈õ ara oba bokso wl̈o.
\v 14 L̇l̇ëye rokëmi bor kong bor ko go kës l̈i shäryër bomi kong eni jl̈õkoyo.
\s1 «Sbö Sëya ichër jek bomi kjimtë» l̈ara Jesúsdë
\p 
\v 15 »Tja woydëmi wl̈eni ga bor tjl̈õkwo kol̈ozĩa.
\v 16 Enira l̇l̇ëbo rokër Data Sbö kong, ga pjãy kong bomi poshdungga twe obl̈ë, ber shäng bomi tjok ĩyado wl̈o.
\v 17 Sbö Sëya l̈i e. Tjl̈õkwo bek l̈i pĩya bomi kong, miydëmi wl̈o. Nopga Sbö miydë l̇l̇ëm wl̈eniyo omwl̈okjrë l̇l̇ëm, ĩya l̈ok l̇l̇ëm kjĩshko, miyde l̈ok l̇l̇ëm kjĩshko bakoe. Pjãyda ommiydë, shäng bomi tjok kjĩshko, ber shäng bomi yorkaga ĩyado wl̈o kjĩshko bakoe.
\p 
\v 18 »Tja toshko ga pjãy rayër ber l̈öng l̇l̇upsëng wl̈eni l̇l̇ëme. Tja tjwe iröng bomi shwoy obi.
\v 19 Dbar sira obi ga tja ĩya nopga Sbö miydë l̇l̇ëm wl̈eniyorë ame. Gueniyo pjãyda, tja ĩmi obi. Eshko ga tja sök së kjĩshko ga pjãy ber l̈öng së jl̈õkoyo.
\v 20 Eshko dbaryo ga pjãy ommiydono ga tja shäng bor Data tjok, pjãy l̈öng bor tjok, ga tja shäng bomi tjok bakoe.
\v 21 Ëye bor tjl̈õkwo kjrë, ga kol̈e ga bor woydaga jl̈õkoyo l̈i e. Bor woydagaga l̈öng kës l̈i, e woyde bor Datarë ara. Epga woydër, ga tja opping ba kong l̈ok bakoe» l̈e.
\p 
\v 22 Kjl̈ara shäng eshko ko Judas, gueniyo e Judas Iscariote l̇l̇ëme. Judas l̈i tjl̈ẽ Jesús kong ga «Tjl̈apga, ¿pja opping borwa kong erö ega? ¿Pja opping oba uunkong kong l̇l̇ëm ega?»
\p 
\v 23 «Ëye, tja woyde ga bor tjl̈õkwo kol̈e. Eni ga e woyde bor Datarë, ga tjawa jek ba shwoy, ga tjawa ber l̈öng ba tjok.
\v 24 Ëye, tja woyde l̇l̇ëm ga bor tjl̈õkwo kol̈e l̇l̇ëme. Tjl̈õkwo l̈ër shäng kumi l̈öng l̈i, e l̈aga tjarë l̇l̇ëm, e l̈aga Data Sbö, bor ichaga l̈irë.
\p 
\v 25 »Tjl̈õkwo ëre l̈oror bomi kong, tja shäng bomi tjok obishko.
\v 26 Gueniyo Sbö Sëya, bomi poshdungga l̈i iche Data Sbörë bomi kong bor ko go, ga pjãy pĩya jek këgong, tjl̈õkwo l̈oror bomi kong kës l̈i woyoshre bomi kong bakoe.
\p 
\v 27 »Tja toe. Gueniyo ga pjãy iër ber l̈öng wl̈ẽpe. Pjãy l̈öng wl̈ẽp l̈aga l̈i, e tja. Pjãy ie nopga Sbö miydë l̇l̇ëm wl̈eniyorë ber eni l̇l̇ëme. Pjãy wosonkë l̇l̇ëm, l̇l̇ëye bangkjrëmi l̇l̇ëm bakoe.
\p 
\v 28 »Tja tjl̈ẽno bomi kong ga “Tja toe. Ga tja tjwe iröng bomi shwoy obi” l̈oror l̈i kuromi tjän. Tja to iröng Data Sbö shwoy. Eni ga tja woydëmi jl̈õkoyo wl̈eni ga pjãy ber l̈öng wopjl̈ú eshko, Data Sbö kësbang, tjwl̈õ ara bor kjinmo kjĩshko.
\v 29 L̇l̇ëbo ëre shäryoydë l̇l̇ëm obishko ga l̈ër shäng bomi kong. Eni ga shäryonoshko ga pjãy mär ber l̈öng bor go jek këgong ba kjĩshko.
\v 30 Kjok ëre ichaga l̈i\f + \fr 14:30 \fk Kjok ëre ichaga \ft l̈e l̈i, e \fk Ä \ft l̈okl̈o.\f* tek tjwe shäng. E kjĩshko ga tja tjl̈ẽ bomi kong ara obi l̇l̇ëme. E dbo ara, bor ichë wl̈o l̇l̇ëme.
\v 31 Gueniyo Data Sbö woydër ara. E kjĩshko ga e miyde nopga l̈öng kës l̈irë wl̈o ga tja ichara l̇l̇ëbo shäryër wl̈o l̈i, e shäryër eni.
\p »Ëësë, shji toe» l̈e.
\c 15
\s1 Kjil̇l̇gwo sokö, ba kowo
\p 
\v 1 Eshko ga Jesús tjl̈ẽ ba oppinggaga kong ga «Tja so kjil̇l̇gwo sokö bo pjl̈ëbl̈ë tjok wl̈eniyo kjoyoe. Obl̈ëyo tja dik drete. Bor Data, e so kjil̇l̇gwo l̈i daga kjoyo bakoe.
\v 2 Kjil̇l̇gwo kowo l̇l̇ë botjyë l̇l̇ëm ga ze tas tas. Kowo kjong kjong botjyë ga dbo toya pjäs pjäs, kowo l̈i botjyë pjl̈ú anmoyõ wl̈o.
\v 3 Pjãy so kowo dbo tok pjir l̈i kjoyo, tjl̈õkwo l̈oror bomi kong l̈i kjroromi kjĩshko.
\v 4 Eni ga pjãy ber l̈öng bor tjok, ga tja ber shäng bomi tjok bakoe. Kowo l̇l̇ë botjyë om go ga ä, jong tuktëng ba sokö go guing. Pjãy so e kjoyo bakoe. Pjãy ber l̈öng bor tjok l̇l̇ëm wl̈eni ga pjãy l̇l̇ëbo pjl̈ú shäryë ga äe. \fig Kjil̇l̇gwo kowo (Juan 15.1-8)|src="HK00110B.TIF" size="col" ref="John 15.1 "\fig*
\p 
\v 5 »Tja so kjil̇l̇gwo sokö l̈i kjoyoe. Pjãy so ba kowo l̈i kjoyo bakoe. Ëye l̈öng bor tjok, ga tja shäng ba tjok ga l̇l̇ëbo pjl̈ú shärye ara, so kowo botjyë pjl̈ú l̈i kjoyoe. Gueniyo ëye l̈öng bor tjok l̇l̇ëm ga l̇l̇ëbo pjl̈ú shärye ga äe.
\v 6 Ga ëye l̈öng bor tjok l̇l̇ëm ga ber so kowo dbukko, iak beno tjeng dan dogro wl̈o l̈i kjoyoe. Kowo eni l̈i, e tö̃y, suy wl̈o erä.
\v 7 Gueniyo pjãy ber l̈öng bor tjok, ga pjãy mär ber l̈öng bor tjl̈õkwo go ga l̇l̇ëye rokëmi woydë l̈i rokozĩ, ga twër bomi kong.
\v 8 Pjãy ĩkoba ga l̇l̇ëbo pjl̈ú shäryë ara, so kowo botjyë pjl̈ú l̈i kjoyo ga miydëba e go ga pjãy bor oppingga, ga bor Data iëba ber kësbang, tjwl̈õ ara bomi kjĩshko.
\p 
\v 9-10 »Pjãy woydër, tja woyde Data Sbörë sorë ga eni. E kol̈ër shäng ĩyado, ga tja woyde ber shäng eni ĩyado bakoe. Eni ga tja kol̈ozĩ ber l̈öng ĩyado, pjãy woydër ber l̈öng eni ĩyado bako wl̈o.
\v 11 L̈ër shäng bomi kong eni, pjãy ber l̈öng wopjl̈ú, botoya dik wl̈o. Eni ga pjãy wopjl̈ú jl̈õkoyo.
\v 12 Tjl̈õkwo l̈ër shäng bomi kong shäryëmi wl̈o l̈i eni: Pjãy ëng woydos ara kar kar, pjãy woydoror sorë ga eni.
\v 13 Shji bi kjl̈ara woydë ara ga l̇l̇ëbo shäryëy ba kong tjwl̈õ ara anmoyõ l̈i, shji optwë wol̈on ba kjĩshko l̈i e.
\v 14 Ga tja kol̈ëmi wl̈eni ga pjãy kowër bor pjeyoga.
\v 15 Parkagaga tjeng l̈i, l̇l̇ëye shärye ba kägäyorë l̈i, e miyde l̈öng l̇l̇ëme. Gueniyo l̇l̇ëbo l̈ara bor Datarë bor kong l̈i, e l̈oror bomi kong pjir tjän. E kjĩshko ga pjãy kowër bor parkaga ame, pjãy kowër bor pjeyoga shara.
\p 
\v 16 »Tja kjraga pjãydë l̇l̇ëm, pjãy kjraga tjarë. Ga pjãy ioror beno to l̈öng l̇l̇ëbo pjl̈ú ber ĩyado l̈i shäryë. Shäryëmi eni ga l̇l̇ëye rokëmi Data Sbö kong bor ko go l̈i, e twe bomi kong.
\v 17 Tjl̈õkwo l̈ër shäng bomi kong shäryëmi wl̈o l̈i eni: Pjãy ëng woydos ara kar kare.
\s1 Shji ĩywa nopga Sbö miydë l̇l̇ëm wl̈eniyorë shjiktëng
\p 
\v 18 »Nopga Sbö miydë l̇l̇ëm wl̈eniyo, pjãy ĩywa l̈ok shjiktëng wl̈eni ga woyoshrëmi eshko ga tja ĩywa l̈ok shjiktëng bomi bäm go bakoe.
\v 19 Pjãy so epga kjoyo kjwe ga pjãy woyde l̈ok pjl̈ú, ba pjeyoga wl̈eni. Gueniyo pjãy kjroror ba tjrëko dwayo kuzong ga pjãy so epga kjoyo ame. Pjãy ĩywa l̈ok shjiktëng e kjĩshko.
\v 20 Tjl̈õkwo l̈oror bomi kong l̈i woyoshrozĩa. Tja tjl̈ẽno bomi kong ga “Parkagaga tjwl̈ẽk l̈öng pjir wl̈eniyo tjwl̈õ ara, ba sogo kjinmo l̇l̇ëme” l̈oror eni. Eni ga tja shduna l̈ok kuzong ga pjãy shdũya l̈ok eni bakoe. Tjl̈õkwo l̈oror ba kong l̈i kjrara l̈ok kjwe ga tjl̈õkwo l̈ëmi ba kong l̈i kjre l̈ok eni bakoe.
\v 21 L̇l̇ëbo uunkong ëre shärye l̈ok bomi kong, pjãy bor nopga kjĩshko, bor ichaga miyde l̈ok l̇l̇ëm kjĩshko bakoe.
\p 
\v 22 »Tja kjwe shrono tjl̈ẽno ba kong l̇l̇ëm ga l̇l̇ëbo owa shäryara l̈ok l̈i ber pjang ba go l̇l̇ëme. Gueniyo epga iak beno shdungko tjän, bor tjl̈õkwo kura l̈ok l̈i kjrara l̈ok l̇l̇ëm kjĩshko.
\v 23 Ëye, tja ĩywa shjiktëng ga bor Data, e ĩywa shjiktëng bakoe.
\v 24 L̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryoror ba kong ara. Eni l̇l̇ëm kjwe ga l̇l̇ëbo owa shäryara l̈ok l̈i ber pjang ba go l̇l̇ëme. Gueniyo l̇l̇ëbo shäryoror l̈i ĩna l̈ok wẽl̈ë ëmdë ga tja, bor Data, tjawa ĩywa l̈ok shjiktëng.
\v 25 Ëre shäryë jũni, kjok l̇l̇gwekkl̈o baĩya tak pjang l̈i ber jl̈õkoyo wl̈o. Tjl̈ẽno beno eni: “Tja goshko l̇l̇ëye owa wl̈ẽna l̈ok l̇l̇ëm ëmdë ga tja ĩywa l̈ok shjiktëng.”\f + \fr 15:25 \ft Salmo 35.19; 69.4.\f*
\p 
\v 26 »Rokër Data Sbö kong ga ba Sëya, bomi poshdungga l̈i iche tjwe ber bomi tjok. Ga ichara shronoshko ga pjãy kjimte, tjl̈õkwo bek l̈i pĩya bomi kong bakoe. Ga tjl̈ẽ bomi kong bor kjĩshko ara.
\v 27 Ga pjãy l̈öng bor tjok tek dämärshko dwayo kuzong ga pjãy tjl̈ẽ bor kjĩshko eni bakoe.
\c 16
\p 
\v 1 »L̈ër shäng bomi kong eni, pjãy mär ber l̈öng bor go wl̈o, tja rayëmi l̇l̇ëm wl̈o.
\v 2 Pjãy ichëba opzrëk jek judíoga syõ uyo roshko ame. Ga dbar tjwe kjwara ga pjãy zröya nopgarëshko ga wotjl̈ĩk l̈ok ga l̇l̇ëbo shärye l̈öng Sbö kong pjl̈úe l̈e.
\v 3 Shärye l̈ok eni, tja, Data Sbö, tjawa miyde l̈ok l̇l̇ëm kjĩshko.
\v 4 L̈ër shäng bomi kong eni, äär ba dbaryoshko ga tjl̈õkwo ëre woyoshrëmi eshko wl̈o.
\s1 Pak shärye Sbö Sëyarë bi kong
\p »Tjl̈õkwo ëre l̈oror bomi kong tek dämärshko l̇l̇ëm, eshko ga tja shäng bomi tjok obi kjĩshko.
\v 5 Gueniyo eerishko ga tja to bor ichaga sök l̈ishko. Eni ëmdë ga “¿Pja to kjone?” l̈ëmi bor kong l̇l̇ëme.
\v 6 L̇l̇ëbo l̈ër shäng l̈i kuromi kjĩshko ga pjãy beno l̈öng woydë ara.
\v 7 Gueniyo l̈ër bomi kong jl̈õkoyo ga tja briktong l̈i, e ber bomi kong pjl̈ú anmoyõ. Tja brik l̇l̇ëm kjwe ga Sbö Sëya, bomi poshdungga l̈i tjwe ber bomi tjok l̇l̇ëme. Gueniyo tja briktong pjir ga e ichër tjwe ber bomi tjok.
\v 8-10 Ga shronoshko ga nopga Sbö miydë l̇l̇ëm wl̈eniyo, epga diktong ara l̈i pĩya ba kong, miyde l̈ok wẽl̈ë wl̈o. Mär l̈öng bor go l̇l̇ëm kjĩshko ga pĩya ba kong ga wotjl̈ĩk bëy l̇l̇ëbo owa l̈i kjĩshko l̇l̇ëme. Tja to Data Sbö sök l̈ishko kjĩshko ga pĩya ba kong ga irbo bek l̈i miyde l̈ok l̇l̇ëme.
\v 11 Kjok ëre ichaga l̈i\f + \fr 16:11 \fk Kjok ëre ichaga \ft l̈e l̈i, e \fk Ä \ft l̈okl̈o.\f* iak beno shdungko tjän kjĩshko ga nopga l̇l̇gweya Sbörë sorë l̈i miyde l̈ok l̇l̇ëm bakoe.
\p 
\v 12 »Tja l̇l̇ëbo l̈ë woydë bomi kong ara obi, gueniyo eni tjok ga woyotjl̈ĩmi ga pjãy äär ba dbo go l̇l̇ëme.
\v 13 Gueniyo Sbö Sëya shronoshko ga tjl̈õkwo bek kës l̈i pĩya bomi kong. Eshko ga tjl̈õkwo l̈e bomi kong ba woshko l̇l̇ëm, tjl̈õkwo kura l̈i l̈ayde bomi kong eröe. Ga l̇l̇ëye wen wl̈o l̈i l̈e bomi kong, wentë l̇l̇ëm obishko.
\v 14 Tjl̈õkwo botoya l̈i l̈e bomi kong, miydëmi wl̈o. Eni ga tja ie ber kësbang, tjwl̈õ ara.
\v 15 Data Sbö l̇l̇ëbo tjeng kës l̈i, e botoya. Tjl̈õkwo botoya l̈i l̈e Sbö Sëyarë bomi kong, miydëmi wl̈o l̈oror bomi kong e kjĩshko.
\p 
\v 16 »Wop ä ga tja ĩmi shäng bomi tjok ame. Gueniyo wop ä obi ga tja ĩmi shäng bomi tjok jek obi» l̈e.
\s1 Jesús oppinggaga woydono ara pjir ga ber l̈öng wopjl̈ú shara
\p 
\v 17 Kuya ba oppinggagarë l̈ok ga tjl̈ẽ l̈ok ëng kong ga «¿“Wop ä ga tja ĩmi shäng bomi tjok ame. Gueniyo wop ä obi ga tja ĩmi shäng bomi tjok jek obi” l̈e shäng l̈i l̇l̇ë l̈ayde? ¿“Tja to Data Sbö sök l̈ishko” l̈e shäng l̈i l̇l̇ë l̈ayde?» l̈e l̈ok eni.
\v 18 Ga kjakroke l̈ok ëng kong jek obi ga «¿“Wop ä” l̈e shäng l̈i l̇l̇ë l̈ayde? L̇l̇ë l̈ayde miydëy l̈öng l̇l̇ëme» l̈e l̈ok ëng kong eni.
\p 
\v 19 L̇l̇ëye kjakroke woyde ba kong l̈i miydara Jesúsdë pjire. E kjĩshko ga tjl̈ẽ ba kong l̈ok ga «¿“‘Wop ä ga tja ĩmi shäng bomi tjok ame. Gueniyo wop ä obi ga tja ĩmi shäng bomi tjok jek obi’ l̈e shäng l̈i l̇l̇ë l̈ayde?” l̈ëmi l̈öng ëng kong eni.
\v 20 L̈ër bomi kong jl̈õkoyo ga nopga Sbö miydë l̇l̇ëm wl̈eniyo l̈öng wopjl̈ú wopro ga pjãy l̈öng woydë, sl̈ar ara eshko. Gueniyo e irgo ga pjãy ber l̈öng eni ame, pjãy kjl̈opswë ber l̈öng wopjl̈ú shara.
\p 
\v 21 »Wal̈ë wl̈oshko buk döröshko ga shaya swl̈orë, dbaryo öötong kjĩshko. Gueniyo wl̈oshko tjeng irgo ga bang ara l̈i woyo ba kong ame, wopjl̈ú ba chida tjeng l̈i kjĩshko.
\v 22 Eni wl̈eni ga eeri ga pjãy l̈öng woydë ara. Gueniyo e irgo ga pjãy ĩn jek obishko ga pjãy ber l̈öng wopjl̈úe. Eshko ga wopjl̈ú l̈i döga ërë bomi shjiryo l̇l̇ëme.
\v 23 Eshko dbaryo ga l̇l̇ëye kjakrokëmi bor kong wl̈o drete. L̈ër bomi kong jl̈õkoyo ga l̇l̇ëye rokëmi bor Data kong bor ko go l̈i, e twe bomi kong.
\v 24 L̇l̇ëbo rokomirë Sbö kong bor ko l̈i go l̇l̇ëm obi. Gueniyo eeri ga l̇l̇ëbo rokozĩ ba kong, ga kjrëmi, ga pjãy ber l̈öng wopjl̈ú jl̈õkoyo.
\p 
\v 25 »Tja tjl̈ẽ shäng bomi kong l̇l̇ëbo jyãgl̈o go, gueniyo l̇l̇ono ga tja tjl̈ẽ bomi kong eni ame. Eshko ga bor Data l̈ãywër bomi kong wẽl̈ëe.
\v 26 Eshko dbaryo ga l̇l̇ëbo rokëmi ba kong om go bor ko go. Tjara l̇l̇ëbo rokë ba kong bomi kjĩshko guing ame.
\v 27 Tja woydëmi, ga miydëmi ga tja ter shrono Sbö shwoy dwayo. E kjĩshko ga pjãy woyde Data Sbörë om go.
\v 28 Tja ter shrono kjok ëre kjing go ba shwoy dwayo, ga tja to kjok ëre kjing go dwayo jem ba shwoy iröng obi» l̈e.
\p 
\v 29 Kuya ba oppinggagarë l̈ok ga tjl̈ẽ l̈ok ba kong ga «Eeri ga pja tjl̈ẽ shäng borwa kong wẽl̈ë. Pja tjl̈ẽ shäng l̇l̇ëbo jyãgl̈o go l̇l̇ëme.
\v 30 Ëre go ga miydërwa ga l̇l̇ëbo tjeng kës l̈i miydëp shäng pjir, l̇l̇ëbo kjakrokëba bop kong guing l̇l̇ëme. E kjĩshko ga miydërwa ga pja ter shrono Sbö shwoy dwayo» l̈e.
\p 
\v 31 Kuya ga tjl̈ẽ ba kong l̈ok ga «¿Bor tjl̈õkwo kjrëmi tjände?
\v 32 Dbar tjwe kjwara ga pjãy shdär ber l̈öng l̇l̇aw pogo, pjãy kjl̈ara kjl̈ara ber l̈öng bomi ushko om go. Eshko ga tja rayëmi ber sök tjoksa. Gueniyo eshko ga tja sök tjoksa l̇l̇ëm, bor Data sök bor tjok kjĩshko. Ga dbar tjwe l̈ër l̈i, e shrono tjän.
\v 33 L̈ër shäng bomi kong eni, pjãy ber l̈öng wl̈ẽp bor kjĩshko. Pjãy l̈öng kjok ëre kjing go obishko ga l̇l̇ëbo wen tjwe bomi kong owa ara. Gueniyo nopga Sbö miydë l̇l̇ëm wl̈eniyo l̈i dbo zanor pjir tjän. E kjĩshko ga pjãy dbokjrozong» l̈e.
\c 17
\s1 Jesús syõshtono Sbö kong ba kjĩshko om go
\p 
\v 1 E irgo ga kjok dogo ĩya Jesúsdë drëng, ga syõshtono Sbö kong. Tjl̈ẽ ga «Data, dbar l̈i öötonge. Bop Wa ëre ios ber kësbang, tjwl̈õ ara, pja iër ber kësbang, tjwl̈õ ara bako wl̈o.
\v 2 Tja kong dbo tworop kësbang, nopga l̈öng kës l̈i ber tjeng bor wl̈oshko wl̈o, tjrëko nopga tworop beno bor kong kës l̈i iër ber l̈öng së ĩyado bop tjok wl̈o.
\v 3 Sbö kjl̈araso l̈i pja, ga tja Jesucristo, tja ichaga pjarë. Nopga l̈i ber l̈öng së ĩyado bop tjok wl̈o ga woyde ga shji miyde l̈ok guing.
\v 4 Pak tworop bor kong shäryër wl̈o l̈i shäryoror pjire. Eni ga pja ioror beno kësbang, tjwl̈õ ara kjok ëre kjing go.
\v 5 Kjok ëre wentë l̇l̇ëm obishko ga tja kësbang, tjwl̈õ ara bop bokso. Eeri ga Data, tja ios ber kësbang, tjwl̈õ ara eni obi.
\s1 Jesús syõshtono Sbö kong ba oppinggaga kjĩshko
\p 
\v 6 »Nopga kjok ëre so kjrorop, tworop bor kong. Ga pja ë l̈oror ba kong l̈ok. Epga bopoya twopdë bor kong, ga bop tjl̈õkwo kol̈ara l̈ok pjl̈úe.
\v 7 Miydara l̈ok ga l̇l̇ëbo tjeng kës tworop bor kong l̈i, e twaga pjarë.
\v 8 Tjl̈õkwo l̈orop bor kong l̈i, e l̈oror ba kong l̈ok pjir, ga kjrara l̈ok. Miydara l̈ok pjl̈ú ga tja ter shrono bop shwoy dwayo. Tja ichaga pjarë l̈i, e jl̈õe miydara l̈ok bakoe.
\v 9 Tja syõshtë nopga tworop bor kong l̈i kjĩshko, epga bopoya kjĩshko. Gueniyo tja syõshtë nopga pja miydë l̇l̇ëm wl̈eniyo kjĩshko l̇l̇ëme.
\v 10 Nopga botoya l̈öng kës l̈i, e bopoya. Nopga bopoya l̈öng kës l̈i, e botoya bakoe. Ba kjĩshko ga tja beno kësbang, tjwl̈õ ara.
\p 
\v 11 »Data, pja eröe. Tja shäng kjok ëre kjing go wl̈o ame. Tja to bop shwoy. Nopga tworop bor kong bop dbo go l̈ira ber l̈öng kjok ëre kjing go. Eni ga epga dos yõtso bop dbo go, ber l̈öng kjl̈araso wl̈eni wl̈o, shji kjl̈araso sorë ga eni.
\v 12 Tja shäng ba tjok l̈ok obishko ga epga wl̈ikoror, doror dbo tworop bor kong l̈i go. Eni ga jeno kjl̈ara döe. Weno shäng jer wl̈o l̈i e. Shäryono eni, tjl̈õkwo tak pjang bop tjl̈õkwo go ba kjĩshko l̈i ber jl̈õkoyo wl̈o.
\p 
\v 13 »Eni tjok ga tja to bop shwoy iröng obi. Gueniyo tja shäng kjok ëre kjing go obishko ga l̇l̇ëbo ëre l̈ër shäng bop kong eni, epga ber l̈öng wopjl̈ú jl̈õkoyo, botoya dik wl̈o.
\v 14 Bop tjl̈õkwo l̈oror ba kong l̈ok. Epga, e nopga pja miydë l̇l̇ëm wl̈eniyo dik l̇l̇ëme. Tja eni l̇l̇ëm bakoe. E kjĩshko ga bor nopga ĩywa nopga pja miydë l̇l̇ëm wl̈eniyorë l̈ok shjiktëng.
\p 
\v 15 »Rokër bop kong ga bor nopga kjëp kjok ëre kjing go dwayo l̇l̇ëme. Woydër ga wl̈ikëp, l̇l̇ëbo owa shärye Ärë ba kong l̇l̇ëm wl̈o.
\v 16 Epga, e nopga pja miydë l̇l̇ëm wl̈eniyo dik l̇l̇ëme. Tja eni l̇l̇ëm bakoe.
\v 17 Bop tjl̈õkwo, e beke. Eni ga bor nopga ios ber tjeng dboy bop kong, jëk ber l̈öng pjl̈o bek bop tjl̈õkwo bek l̈i go wl̈o.
\v 18 Epga ichër jek kjok ëre kjing go, tja ichorop ter shrono shäng kjok ëre kjing go sorë ga eni.
\v 19 Ba kjĩshko ga tja opyono beno shäng dboy bop kong jl̈õkoyo, epga ber tjeng dboy bop kong jl̈õkoyo tjl̈õkwo bek l̈i go wl̈o.
\s1 Jesús syõshtono Sbö kong tjl̈õkwo kjragaga l̈öng kës l̈i kong
\p 
\v 20 »Tja syõshtë ba kjĩshko dö l̇l̇ëme. L̇l̇ono ga tjl̈õkwo l̈e l̈ok obl̈ë kong, ga kjong kjong mär ber l̈öng bor go eshko. Tja syõshtë ba kjĩshko l̈ok bakoe.
\v 21 Data, pja shäng bor tjok, ga tja shäng bop tjok bakoe. E kjĩshko ga shji kjl̈araso. Woydër ga epga ber l̈öng kjl̈araso eni bakoe. Woydër ga l̈öng bi tjok, tja ichaga pjarë l̈i miyde nopga pja miydë l̇l̇ëm wl̈eniyorë wl̈o.
\v 22 Epga ioror beno tjwl̈õ ara, tja iorop beno tjwl̈õ ara sorë ga eni, epga ber l̈öng kjl̈araso wl̈o, shji kjl̈araso sorë ga eni.
\v 23 Tja shäng ba tjok, ga pja shäng bor tjok. Woydër ga ber l̈öng kjl̈araso jl̈õkoyo, tja ichaga pjarë l̈i miyde nopga pja miydë l̇l̇ëm wl̈eniyorë wl̈o, bor nopga woydorop ara, tja woydorop sorë ga eni l̈i miyde l̈ok eni bako wl̈o.
\p 
\v 24 »Data, kjok ëre shäryopdë l̇l̇ëm obishko ga tja woydorop ara. E kjĩshko ga tja iorop beno kësbang, tjwl̈õ ara. Woydër ga nopga tworop bor kong tjeng l̈i jem bor tjok, ber tjeng tja äär sök l̈ishko wl̈o, tja iorop beno kësbang, tjwl̈õ ara l̈i ĩya l̈ok wẽl̈ë wl̈o.
\p 
\v 25 »Data, pja pjl̈o beke. Pja miyde nopga kjok ëre so l̈irë l̈öng l̇l̇ëm, gueniyo tjara ommiydë, ga tja ichaga pjarë l̈i miyde bor nopgarë pjl̈úe.
\v 26 Pja sorë, e l̈oror ba kong, miyde l̈ok wl̈o, ga l̈ër shäng ba kong l̈ok obi. Shäryër eni, epga ëng woydë ara kar kar wl̈o, tja woydëp sorë ga eni, tja ber shäng ba tjok l̈ok wl̈o bakoe» l̈e.
\c 18
\s1 Jesús shara ba wl̈oyogarë
\p 
\v 1 Jesús syõshtono pjir ga opshino jek eshko dwayo ba oppinggaga tjok, ga jek dipzono Cedrón diwa kjwo kal̈ëkong. Eshko ga kjok dgak buk kjrina, kjor ko \tl olivo\tl* l̈ok ara, ga opzrëno jek l̈ok eshko.
\v 2 Jesús tön shäng enido eshko ba oppinggaga tjok. E kjĩshko ga kjok l̈i miydara Judas, ba soynega l̈irë pjl̈úe.
\v 3 Eni kuzong ga Judas jek äär shäng eshko. Ëngkjwagaga, Sbö u dagaga, e jek l̈öng ba irgo, ichak syõshtaga kägäyoga, fariseogarë. Ëngkjwokl̈o söya tjeng ba wl̈oshko, iök bakoe.
\p 
\v 4 L̇l̇ëye shärye ba tjok l̈i miyde Jesúsdë shäng. Eni ga ëng wl̈ẽno ba tjok, ga tjl̈ẽ ba kong l̈ok ga «¿Ë wl̈ẽmirë?»
\p 
\v 5 «Jesús, Nazaret so l̈i wl̈ẽnwarë» l̈e l̈ok ba kong.
\p Eni ga tjl̈ẽ ba kong l̈ok ga «E tja» l̈e. (Judas, ba soynega l̈i shäng eshko ba tjok bebi.)
\v 6 L̈ara eni l̈i kuya l̈ok ga opshino jek l̈ok iröng sira, ga dgono jek rish rish tjeng töshko.
\p 
\v 7 Eshko ga Jesús tjl̈ẽ ba kong l̈ok jek obi ga «¿Ë wl̈ẽmirë?»
\p «Jesús, Nazaret so l̈i wl̈ẽnwarë» l̈e l̈ok ba kong.
\p 
\v 8 Eni ga tjl̈ẽ ba kong l̈ok jek obi ga «E tja l̈oror bomi kong tjän. Tja wl̈ẽmirë dö ga l̇l̇amo l̈öng ëre ichozĩ toe» l̈e.
\v 9 Shäryono eni, tjl̈õkwo l̈ara l̈unashko l̈i ber jl̈õkoyo wl̈o. Tjl̈ẽno ga «Nopga tworop bor kong l̈i jeror kjl̈ara l̇l̇ëme» l̈ara eni.
\p 
\v 10 Eshko ga Simón Pedro dröng shino kjwangna ba bapkwo roy dwayo, ga syõshtaga kësbangyo parkaga kwomgwo zakza tas jer l̈on pjik buk töshko erä. (Parkaga l̈i ko Malco.)
\p 
\v 11 Eshko ga Jesús tjl̈ẽ ba kong ga «Bop dröng kjwe jnes ba shtoy iröng obi. Tja ichara Data Sbörë, tja shdungoba, bokrotkëba, zrökoba wl̈o, ga shäryër eni kjl̈uwe» l̈e.
\s1 Jesús söraba Anás bokshto
\p 
\v 12 Eshko ga ëngkjwagaga, ba kägäyo, Sbö u dagaga, Jesús shara l̈ok, ga kjrochara.
\v 13 E irgo ga söra l̈ok jek Anás bokshto. Anás, e Caifás kegue. L̈u eshko ga Caifás parkë sök syõshtaga kësbangyo.
\v 14 Kjupäshko ga tjl̈ẽno ga «Pjl̈ú wl̈o ga no wol̈on kjl̈ara oba uunkong ãska» l̈ara eni.
\s1 «Jesús, e ë miydër l̇l̇ëme» l̈ara Pedrorë
\p 
\v 15 E wopro ga Simón Pedro, Jesús oppingga kjl̈ara obi, e jek l̈öng Jesús sökoba jek shäng l̈i irgo. Jesús oppingga obl̈ë l̈i miyde syõshtaga kësbangyo l̈irë kuzong ga pjöyĩkong jek opzrëno shäng Jesús tjok u l̈i worbo go.
\v 16 Pedrora beno sök kjoko, u bäng zl̈ong. Eshko ga Jesús oppingga obl̈ë l̈i opshino tek iröng, ga l̈ano kjogl̈o parkë shäng u bäng daga l̈i tjok, ga Pedro söra jek ba tjok kjër roshko.
\p 
\v 17 Eshko ga kjogl̈o l̈i tjl̈ẽ Pedro kong ga «¿Pja ëmdë ga domer l̈i oppingga bebi l̇l̇ëmdo?»
\p «L̇l̇ëme» l̈e ba kong.
\p 
\v 18 Eshko ga smo ara kuzong ga parkagaga, Sbö u dagaga l̈öng l̈i, e iök boktöno kjwara, ga beno l̈öng iökkok. Pedro ëmdë ga shäng iökkok ba tjok bakoe.
\s1 L̇l̇ëbo kjakrokara Anásdë Jesús kong
\p 
\v 19 E wopro ga syõshtaga kësbangyo l̈i l̇l̇ëbo kjakrokono Jesús kong, ba oppinggaga kjĩshko, l̇l̇ë pĩyde oba kong l̈i kjĩshko bakoe.
\v 20 Kuya ga tjl̈ẽ ba kong ga «Tja tjl̈ẽno oba uunkong bokshto. Dbar kjwobi go ga oba pinor shäng judíoga syõ uyo l̈ok l̈i roshko, l̇l̇ëm ga Sbö u zl̈ong bäng, judíoga l̈öng kës l̈i tön l̈öng enido l̈i shtoshko. L̇l̇ëbo l̈oror l̈ũtshko l̇l̇ëme.
\v 21 ¿Eni ga l̇l̇ëbo kjakrokëp bor kong ega? Kjakrokos bor tjl̈õkwo kugaga kong. L̇l̇ëye l̈oror l̈i miyde l̈ok pjire» l̈e.
\p 
\v 22 L̈ara eni l̈i kura Sbö u daga kjl̈ara shäng l̈irë, ga Jesús kwomso shpokza pjök, ga tjl̈ẽ ba kong ga «¿Tjl̈apga syõshtaga kësbangyo kjwe dboryëp eniro?»
\p 
\v 23 «L̇l̇ëbo l̈oror owa kjwe ga l̇l̇ë l̈os bor kong. ¿Gueniyo l̈oror pjl̈ú ga tja shpop ega?» l̈e ba kong.
\p 
\v 24 E irgo ga ichara Anásdë jek jëk shäng kjro go Caifás, syõshtaga kësbangyo l̈i shwoy.
\s1 «Jesús, e ë miydër l̇l̇ëme» l̈ara Pedrorë jek obi
\p 
\v 25 E wopro ga Simón Pedro shäng iökkok kjoko, ga l̈öng l̈i tjl̈ẽ ba kong ga «¿Pja ëmdë ga domer l̈i oppingga bebi l̇l̇ëmdo?»
\p «L̇l̇ëme» l̈e ba kong.
\p 
\v 26 Syõshtaga kësbangyo parkaga kjl̈ara shäng eshko, e domer kwomgwo zara Pedrorë l̈i pjeyo. E tjl̈ẽ Pedro kong ga «¿Pja ĩnor shäng kjok dgak buk, kjor ko \tl olivo\tl* l̈ok ara l̈ishko ba tjok bebi l̇l̇ëmdo?»
\p 
\v 27 «L̇l̇ëme» l̈e ba kong. Jekdo eshko ga kjörkö kjl̈unoe.
\s1 Jesús söraba Pilato bokshto
\p 
\v 28 Kjok shröngto ga Jesús söraba to Caifás shwoy dwayo, jek öötong l̈öng kjok eshko so ichaga ko Pilato, e ushko, gueniyo judío tjl̈apgaga l̈ira opzrëno jek l̈ok u l̈i roshko l̇l̇ëme. (Dbar shrëkkl̈o l̇l̇ë döröshko ga judíoga sgara l̈öng opkjë l̈öng dboshko. Opzrëno l̈ok nopga judío l̇l̇ëm wl̈eniyo u roshko wl̈eni ga Israel tjëyoga döktong tek Egipto kjokyo dwayo dbaryo l̈i shrëya ga äe l̈e. Opzrëno jek l̈ok u l̈i roshko l̇l̇ëm e kjĩshko.)
\v 29 Eni kuzong ga Pilato opshino tek kjoko, ga tjl̈ẽ ba kong l̈ok ga «¿Domer kjwe rotëmi l̇l̇ë kjĩshko?»
\p 
\v 30 «L̇l̇ëbo owa shäryara l̇l̇ëm kjwe ga sörorwa tek bop kong l̇l̇ëme» l̈e ba kong.
\p 
\v 31 Eni ga Pilato tjl̈ẽ ba kong l̈ok ga «Eni ga sözĩ, l̇l̇gwezĩ pjãydë om go bomi kjok l̇l̇gwekkl̈o l̈i go» l̈e.
\p Kuya l̈ok ga tjl̈ẽ ba kong ga «Gueniyo no zrörwa tjawarë om go ga äe. No zrökko l̈aga l̈i pja eröe» l̈e.
\v 32 Shäryono eni, tjl̈õkwo l̈ara Jesúsdë, e wol̈on sorë l̈i ber jl̈õkoyo wl̈o.
\p 
\v 33 Eshko ga Pilato jek opzrëno ba u roshko iröng obi, ga Jesús rokara tek ba shwoy, ga tjl̈ẽ ba kong ga «¿Judío pjl̈uyo l̈i pjare?»
\p 
\v 34 «¿E kjakrokëp shäng, tja ë miydëp woydë kjĩshkore, de l̈aga obl̈ërë bop kong?» l̈e ba kong.
\p 
\v 35 Kuya ga tjl̈ẽ ba kong ga «¿Tja judío l̈ëpdo? Pja söga, twaga bor kong l̈i, e bop pjeyoga om go, syõshtaga kägäyoga bakoe. ¿Pja l̇l̇ëye owa shäryono?»
\p 
\v 36 «Tja ber pjl̈u kjok ëre kjing go wl̈o l̇l̇ëme. Eni kjwe ga bor nopga ëngkjwë judíoga tjok, tja wl̈ike l̈ok wl̈o. Gueniyo bor pjl̈u shtoyo l̈i kjokyo obl̈ë» l̈e ba kong.
\p 
\v 37 Kuya ga tjl̈ẽ ba kong ga «¿Enira pja pjl̈ure?»
\p «Tja pjl̈u l̈aga pjarë, ga l̈orop beke. Tja weno to ter shäng kjok ëre kjing go, tjl̈õkwo bek l̈i l̈aga. Ëye tjl̈õkwo bek l̈i kuk woydë ga tja kuya» l̈e.
\p 
\v 38 Kuya ga tjl̈ẽ ba kong ga «¿Tjl̈õkwo bek l̈i l̇l̇ë?» l̈e. L̈ara eni pjir ga opshino jek l̈an judío tjl̈apgaga tjok obi. Tjl̈ẽ ga «Domer ëre bor kong ga l̇l̇ëye owa shäryara ber shdungko wl̈o drete.
\v 39 Äär l̈u pjl̈obi go ga Israel tjëyoga döktong tek Egipto kjokyo dwayo dbaryo shrëkkl̈oshko ga nopga bängzak tjeng no shdũzl̈ong uyo roshko l̈i, enido ga rayër kjl̈ara. ¿Eni ga woydëmi ga judío pjl̈uyo l̈ëmi l̈i dötë bomi kongde?»
\p 
\v 40 «L̇l̇ëme. ¡Barrabás, e döpdë dey!» l̈e ba kong. Barrabás, e dënashko ga ëngkjwono Roma sopga tjok.
\c 19
\s1 Jesús ichara Pilatorë zrökoba pjang kjl̈ös go wl̈o
\p 
\v 1 Eni ga Jesús twara Pilatorë ba ëngkjwagaga kong, shpoya l̈ok no shpokkl̈o go wl̈o.
\v 2 Eshko ga shkö sho ywara l̈ok kjrina, beno pjl̈u dl̈u iokl̈o wl̈eni, ga iara l̈ok ba dl̈u kjing go, ga kong shwong wl̈ẽna l̈ok kara pjl̈upga shwong wl̈eniyo ko dingding shwëshwë, ga pjuna l̈ok ba do go.
\v 3 E irgo ga jek l̈ok ba zl̈ong bäng, ga tjl̈ẽ ba kong ga «¡Judío pjl̈uyo, pja pjl̈ú, pja tjwl̈õ arae!» l̈e l̈ok eni, ga shpokza l̈ok pjök pjök ba kwomsoshko erä.
\p 
\v 4 Eshko ga Pilato opshino tek kjoko iröng obi, ga tjl̈ẽ l̈öng l̈i kong ga «Domer tek sör shäng ëre ĩzĩa. Woydër ga miydëmi ga bor kong ga l̇l̇ëye owa shäryara ber shdungko wl̈o drete» l̈e.
\v 5 Jesús opshino tek shäng ba bokshto pjl̈u dl̈u iokl̈o ywak shkö sho go l̈i jong ba dl̈u kjing go, doyak shäng pjl̈upga shwong wl̈eniyo l̈i go bakoe. Eshko ga Pilato tjl̈ẽ l̈öng l̈i kong ga «Domer shäng ëre ĩzĩa» l̈e.
\p 
\v 6 Ĩya syõshtaga kägäyoga, Sbö u dagagarë ga tjl̈ẽ l̈ok dbo go ga «¡Zrös pjang kjl̈ös go! ¡Zrös pjang kjl̈ös go!» l̈e l̈ok eni.
\p Kuya Pilatorë ga tjl̈ẽ ba kong l̈ok ga «Sözĩ, ga zrözĩ pjãydë. Bor kong ga l̇l̇ëye wl̈ẽnor ber shdungko wl̈o drete» l̈e.
\p 
\v 7 Kuya judío tjl̈apgaga l̈öng l̈irë ga tjl̈ẽ ba kong ga «Domer kjwe tjl̈ẽno ga “Tja Sbö Wa” l̈ara eni. E kjĩshko ga borwa kjok l̇l̇gwekkl̈o tak pjang l̈i tjl̈ẽ ga e zrökko» l̈e.
\p 
\v 8 Kuya ga bangkjrara ara jek këgong.\f + \fr 19:8 \ft Eshko ga Pilato wotjl̈ĩk ga Jesús, e Sbö Wa jl̈õkoyo kjwe l̈e. Bangkjrara ara e kjĩshko.\f*
\v 9 Eni ga jek opzrëno ba u roshko iröng obi, ga tjl̈ẽ Jesús kong ga «¿Pja kjone so?» l̈e, gueniyo dboryara l̇l̇ëme.
\v 10 Eni kuzong ga tjl̈ẽ ba kong obi ga «¿Tja dboryëp woydë l̇l̇ëmde? Pja shäng bor wl̈oshko. Pja därde, de pja zrökoba pjang kjl̈ös gore, e l̈aga tjarë. ¿E miydëp l̇l̇ëmdo?»
\p 
\v 11 «Dbo twara Sbörë bop kong l̇l̇ëm kjwe ga tja shäng bop wl̈oshko l̇l̇ëme. E kjĩshko ga bor twagaga bop kong l̈öng kjwe, e l̇l̇ëbo owa shäryono kësbang, bop kjinmo» l̈e ba kong.
\p 
\v 12 Eshko jek l̈ëkong ga Pilato beno shäng l̇l̇ëbo shäryë ara, Jesús döya wl̈o l̈e. Gueniyo ga judío tjl̈apgaga öö l̈e l̈ok jek tjë jĩkong, tjl̈ẽ ga «Ë pogo opyë sök pjl̈u ga e pjl̈u kësbangyo sök Roma kjokyo l̈i wl̈oyo. Eni ga domer kjwe rayëp jek to wl̈eni ga pja ba wl̈oyo bakoe» l̈e.
\p 
\v 13 Kuya Pilatorë ga sirkeno sök no l̇l̇gwezl̈ong sökkl̈o jong l̈i kjing go, ga nopga ichara Jesús shik eshko. Shto eshko l̈i kowëba Töshko Shto Shäryak Buk Akkwo Go, arameo tjl̈õkwo go kowëba Gabatá.
\v 14 Eshko ga öötong dl̈o dl̈uw, ga Israel tjëyoga döktong tek Egipto kjokyo dwayo dbaryo shrëkkl̈o l̈i bong. Eshko dbaryo ga judíoga poshäryë, ba dbar l̈i shrëya l̈ok wl̈o. Ga Pilato tjl̈ẽ judío tjl̈apgaga kong ga «Bomi pjl̈uyo shäng kjwe ĩzĩa» l̈e.
\p 
\v 15 Kuya l̈ok ga tjl̈ẽ ba kong dbo go ga «¡Ichos jũy dwayo! ¡Ichos jũy dwayo! ¡Zrös pjang kjl̈ös go!» l̈e.
\p Eshko ga Pilato tjl̈ẽ ba kong l̈ok ga «¿Woydëmi ga bomi pjl̈uyo kjwe zrör pjang kjl̈ös gore?»
\p «Tjawa pjl̈uyo sök kjl̈araso, pjl̈u kësbangyo sök Roma kjokyo l̈i e» l̈e.
\p 
\v 16 Era eni ga Jesús twara Pilatorë ba ëngkjwagaga kong, l̈öya l̈ok pjang kjl̈ös go wl̈o, ga söra l̈ok to ey dwayo.
\s1 Jesús zröraba pjang kjl̈ös go
\p 
\v 17 Ga Jesús jek shäng ba tjok, ba kjl̈ös l̈i söya pjang om go, ga öötong l̈öng kjokyo ko No Kä Dbogl̈o dl̈upyo, arameo tjl̈õkwo go ko Gólgota.
\v 18 Eshko ga l̈öra l̈ok pjang kjl̈ös go. Nopga l̈öra l̈ok kjl̈ös go do pjök obi bakoe. Kjl̈ara pjang or kël̈ë, kjl̈ara pjang or mil̈ë, kjl̈ösyo dboy dboye.
\p 
\v 19 Pilato kjibokwo tono kjwara, ga iara l̈ok Jesús l̈ök pjangshko l̈i kopshko, e zröya l̈ok l̇l̇ë kjĩy miydëba wl̈o. Kjibokwo tak pjang l̈i tjl̈ẽ ga «Domer ëre ko Jesús, Nazaret so. E judío pjl̈uyo.»
\v 20 Ga jyãgl̈o tak pjang kjibokwo go l̈i, e tak pjang arameo tjl̈õkwo go, latín tjl̈õkwo go, Grecia so tjl̈õkwo go bakoe. Ga kjibokwo l̈i l̈ara judíoga ararë, kjok eshko l̈i buk Jerusalén kjokyo soshko kjĩshko.
\v 21 Eni ga judío syõshtaga kägäyoga tjl̈ẽ l̈ok Pilato kong ga «Tëy kjweni l̇l̇ëme. Tos “Domer ëre tjl̈ẽ ga ‘Judío pjl̈uyo l̈i tja’ l̈e.” Tos eni dey» l̈e.
\p 
\v 22 Kuya ga tjl̈ẽ ba kong l̈ok ga «L̇l̇ëbo toror pjang pjir tjän. Ber pjang eni» l̈e.
\p 
\v 23 Jesús l̈öra ëngkjwagagarë l̈ok pjirshko ga ba shwong töna, ga pjl̈orgara kjringgwo pkëng (4) kjl̈ara ĩ ĩe. Ba shwong ro l̈ëkong l̈i, e shäryak shwong karaso, sera ter jong l̇l̇öm l̈ëkong dwayo äär jong dre l̈ëkong.
\v 24 E kjĩshko ga tjl̈ẽ l̈ok ëng kong ga «Dwl̈ëy l̇l̇ëme. Shwong kjwe ber ë kong ĩy wl̈o ga jyã shiy dey» l̈e, ga shäryara l̈ok eni. Shäryono eni, Sbö tjl̈õkwo tak pjang l̈i ber jl̈õkoyo wl̈o. Tjl̈ẽno beno eni:
\q1 «Bor shwong shdöra l̈ok ëng kong,
\q2 ga jyã shira l̈ok, shwong l̈i ber ë kong ĩya wl̈o.»\f + \fr 19:24 \ft Salmo 22.18.\f*
\p 
\v 25 Jesús kjl̈ös jong l̈ishko ga ba mekë shäng soshko, ba mewa shäng eshko bakoe. Cleofas boy ko María, María Magdala so, e l̈öng eshko ba tjok l̈ok bakoe.
\v 26 Ga ba mekë ĩya shäng ba oppingga woyde ara ba kjl̈ara wl̈eni l̈i\f + \fr 19:26 \fk Ba oppingga woyde ara ba kjl̈ara wl̈eni \ft l̈e l̈i, e \fk Juan \ft l̈ayde.\f* zl̈ong bäng, ga tjl̈ẽ ba mekë kong ga «Wal̈ë, bop wa shäng kjwey» l̈e ba kong,
\v 27 ga tjl̈ẽ ba oppingga l̈i kong ga «Bop mekë shäng kjwey» l̈e. Eni ga eshko jek l̈ëkong ga Jesús mekë wl̈okjrara, ga söra beno sök ba ushko.
\s1 Jesús wol̈ono pjang kjl̈ös go
\p 
\v 28 E irgo ga miyde Jesúsdë ga ba pak l̈i shäryara pjire. Eni ga Sbö tjl̈õkwo tak pjang l̈i ber jl̈õkoyo wl̈o ga tjl̈ẽ ga «Tja wodogroe» l̈e.
\v 29 Eshko ga di bapkwo jong kjwara, roshko kjil̇l̇gwo bo dyo shpoä. Ga l̇l̇ëbo l̇l̇ukl̇l̇uk di shak ara wl̈eniyo kjrara no shäng eshko l̈irë kjwara, pöra kjil̇l̇gwo bo dyo shpoä l̈i go, kjrochara pjang kjor dbo go, ga poyona jem, shuya Jesúsdë wl̈o l̈ara.
\v 30 Shura sira, ga tjl̈ẽ ga «L̇l̇ëbo uunkong l̈i shäryono pjire» l̈e. E irgo ga kä kjujono, ga wol̈onoe.
\p 
\v 31 Eshko ga poshäryozl̈ong dbaryo l̈i ey, ga woshtozl̈ong dbaryo tjwl̈õ ara wl̈eniyo l̈i bong. E kjĩshko ga woyde judío tjl̈apgagarë ga shinmo doyo ber l̈ok kjl̈ös go äär jong bong jã l̇l̇ëme. E kjĩshko ga rokara l̈ok Pilato kong ga nopga iche ba kworbo tok, wol̈on mal̈ing wl̈o. E irgo ga woyde l̈ok ga ba doyo l̈õya ter ba kjl̈ös go dwayo jekdo.
\v 32 Eni ga ëngkjwagaga jek l̈ok domer l̈öra pjang bäm go Jesús zl̈ong l̈i kworbo tok. E irgo ga ba kjl̈arayo l̈i kworbo tora bakoe.
\v 33 Gueniyo jek äär Jesús pjang l̈ishko ga ĩya l̈ok ga wol̈ono pjang tjän, ga kworbo tora l̇l̇ëme.
\p 
\v 34 Eshko ga ëngkjwaga kjl̈ara, Jesús shorkekza l̈ö kowo go ba pjl̈oksoshko. Wop eni l̇l̇ëm ga srëng tek tur jong di tjok.
\v 35 Tjl̈õkwo ëre taga l̈i tja, ga l̇l̇ëbo tër shäng ëre, e ĩnor om go. Miydër ga tja tjl̈ẽ beke. Ga l̇l̇ëbo ĩnor l̈i totë shäng bomi kong, jl̈õe l̈ëmi wl̈o.
\v 36 Shäryono eni, Sbö tjl̈õkwo tak pjang l̈i ber jl̈õkoyo wl̈o. Tjl̈ẽno beno eni: «Ba dbogl̈o tar kjl̈ara l̇l̇ëme.»\f + \fr 19:36 \ft Éxodo 12.46; Números 9.12; Salmo 34.20.\f*
\v 37 Sbö tjl̈õkwo tak pjang kjrina obi. Tjl̈ẽno beno eni: «Shorkera pjus l̈i ĩnaba l̈ok.»\f + \fr 19:37 \ft Zacarías 12.10.\f*
\s1 Jesús doyo jnena Josérë
\p 
\v 38 Domer shäng kjl̈ara ko José, e Arimatea so. E oppino ara Jesús tjok, gueniyo shäryara l̈ũtshko, judío tjl̈apgaga bangkjrara ara kjĩshko. Ga Jesús wol̈ono irgo ga ba doyo rokara Pilato kong, ga «Jöl̈ö» l̈e ba kong.
\p Eni ga José öör ba dök, ga söra to ey dwayo.
\p 
\v 39 Domer jëk shäng ba tjok kjl̈ara obi ko Nicodemo. Pjl̈ara ga öör l̈an Jesús tjok shkë. Jek shäng José tjokshko ga dwl̈o poshtikkl̈o shtiya l̈ok shinmo doyo go an mal̈ing l̇l̇ëm wl̈eniyo söra jek ba tjok kjring pjök kwing dunggwo kjwo sak kjäk kjingsho shkëng (75) dik.\f + \fr 19:39 \fk Dunggwo kjwo sak kjäk kjingsho shkëng (75)\ft , e \fk kwing libra sak kjäk kjingsho shkëng (75) dik.\f*
\v 40 E irgo ga José, Nicodemo, Jesús doyo söra l̈ok, dwl̈o poshtikkl̈o l̈i shtira shwong go, ga doyo l̈i popgara e go, judíoga sgara shinmo doyo jnek sorë ga eni.
\v 41 Jesús zröraba pjang kjl̈ös go l̈ishko ga kjok dgak buk kjrina soshko, roshko sak buk kjrina, shinmo doyo iaydëba eshko l̇l̇ëm obi.
\v 42 Ga judíoga poshäryozl̈ong dbaryo l̈i ey kuzong ga doyo l̈i iara beno buk sak l̈i roshko, buk soy kjĩshko.
\c 20
\s1 Sak beno buk rorëe
\p 
\v 1 Öötong sondë kjok shränto ga María Magdala so jek öötong shäng sak l̈ishko, ga ĩna ga ak iak beno jong ba bängzakkl̈o l̈i, e kjak beno jong ba sor go.
\v 2 Eni ga jek zron jong Simón Pedro sök oppingga woyde Jesúsdë ara ba kjl̈ara wl̈eni l̈i\f + \fr 20:2 \fk Ba oppingga woyde ara ba kjl̈ara wl̈eni \ft l̈e l̈i, e \fk Juan \ft l̈ayde.\f* tjok l̈ishko, ga tjl̈ẽ ba kong l̈ok ga «¡Tjl̈apga doyo l̈i söraba to sakshko dwayo! ¡Öötong iaraba kjone l̈i miydëy l̇l̇ëme!» l̈e.
\p 
\v 3 Kuya l̈ok ga opshino jek l̈ok jongya sakshko.
\v 4 Pjöyĩkong l̈i jek zron jong ëng tjok, gueniyo kjl̈ara zrono Pedro kjinmo, ga öötong shäng bäm go sakshko.
\v 5 Eshko ga roĩna doktëng shäng töshko. Ga ĩna ga ba popgokl̈o beno tjeng erä, gueniyo opzrëno jek ba roy l̇l̇ëme.
\v 6 E irgo ga Simón Pedro öötong shäng eshko, ga opzrëno jek ba roy. Ba popgokl̈o l̈i ĩna tjeng eshko.
\v 7 Ba kä potaywokl̈o ĩna shpuk, iak beno buk dboshko.
\v 8 Eshko ga oppingga shrono shäng bäm go l̈i opzrëno jek ba roy bakoe. Ĩna pjir, ga woshrono jl̈õe l̈e.
\v 9 Gueniyo eshko ga Sbö tjl̈õkwo tak pjang l̈i tjl̈ẽ ga Jesús woshrë iröng obi kjl̈uwe l̈e l̈i l̇l̇ë l̈okl̈o miydayde l̈ok l̇l̇ëm obi.
\s1 Jesús weno María Magdala so kong
\p 
\v 10 E irgo ga to jek l̈ok ba ushko iröng obi.
\v 11 Gueniyo María Magdala so l̈ira beno shäng sak l̈i zl̈ong bäng kjoko, sl̈ar ëë, ga sak l̈i roĩna doktëng shäng töshko.
\v 12 Eshko ga ĩna ga Sbö parkagaga kjok dogo so l̈öng do pjök, doyono l̈ok shwong ko pjl̈ubl̈ún go, sirkeno l̈öng Jesús doyo iak beno buk l̈ishko, kjl̈ara sök kä l̈ëkong, kjl̈ara sök dre l̈ëkong.
\p 
\v 13 Eshko ga tjl̈ẽ l̈ok ba kong ga «Wal̈ë, ¿pja sl̈ar ega?»
\p «¡Bor Tjl̈apga doyo l̈i sörabae! ¡Öötong iaraba buk kjone miydër l̇l̇ëme!» l̈e ba kong.
\v 14 L̈ara eni pjir ga bojongö kal̈ëkong, ga ĩya ga Jesús bë shäng, gueniyo e Jesús miydara l̇l̇ëme.
\p 
\v 15 Eshko ga Jesús tjl̈ẽ ba kong ga «Wal̈ë, ¿pja sl̈ar ega? ¿Ë wl̈ẽpdë?» l̈e.
\p Woyotjl̈ĩya beno shäng wotjl̈ĩk ga kjok eshko daga l̈i shängdo l̈e. Eni ga tjl̈ẽ ba kong ga «Tjl̈apga, shinmo doyo l̈i söga pjarë wl̈eni ga iorop beno buk kjone l̈os bor kong, tja to kjrë wl̈o» l̈e.
\p 
\v 16 Eshko ga tjl̈ẽ ba kong ga «María» l̈e.
\p Kuya ga bojongö iröng, tjl̈ẽno ba kong arameo tjl̈õkwo go, tjl̈ẽ ga «¡Rabuni!» l̈e. (Rabuni, e no pingga l̈okl̈o.)
\p 
\v 17 Kuya ga tjl̈ẽ ba kong ga «Tja rayozong. Tja äätë iröng Data Sbö shwoy l̇l̇ëm obi. Gueniyo pja nom bor pjeyoga shwoy. Pja tjl̈ẽ ba kong ga tja jek jongya iröng bor Data shwoy, e bomi Data bakoe. E bor Sbö, e bomi Sbö bakoe l̈ëp ba kong eni» l̈e.
\p 
\v 18 Kuya ga jek ba oppinggaga l̈öng l̈ishko, ga tjl̈ẽ ba kong ga «¡Tjl̈apga ĩnor!» l̈e, ga l̇l̇ëye l̈ara ba kong l̈i l̈ara ba kong l̈ok pjire.
\s1 Jesús weno ba oppinggaga dogl̈o sak kjwara (10) l̈i kong
\p 
\v 19 Öötong sondë kjok sëng ga ba oppinggaga töno l̈öng ëng tjok. Eshko ga judío tjl̈apgaga bangkjre l̈ok ara kjĩshko ga u bäng bäng l̈i bängzara l̈ok jong tuk tjän. Eni ga Jesús weno shäng ba tjrëko, ga tjl̈ẽ ba kong l̈ok ga «Miga. Pjãy ber l̈öng wl̈ẽpe» l̈e.
\v 20 L̈ara eni ga ba orkwo bäng, ba pjl̈okso bäng, e pina ba kong l̈ok. Ga ĩya l̈ok ga beno l̈öng wopjl̈ú, woowa l̇l̇ëme.
\v 21 E irgo ga Jesús tjl̈ẽ ba kong l̈ok obi ga «Pjãy ber l̈öng wl̈ẽpe. Tja ichara Data Sbörë sorë ga pjãy ichër eni bakoe» l̈e.
\v 22 Eshko ga pjl̈uk bakwara ba kopshko, tjl̈ẽ ga «Pjãy go Sbö Sëya tjwe ber bomi tjok.
\v 23 Ë pogo, owa pjang ba go l̈i l̈ömi ba kong ga l̈ö̃ya Sbörë ba kong eni bakoe. Gueniyo owa pjang ba go l̈i l̈ömi ba kong l̇l̇ëm ga l̈ö̃ya Sbörë ba kong l̇l̇ëm bako, beno l̈öng ba owa l̈i tjok ĩyado» l̈e.
\s1 Jesús weno Tomás kong
\p 
\v 24 Jesús oppinggaga dogl̈o sak kjwara kjingsho pjök (12) kjl̈ara ko Tomás, e kowëba Kjl̈ö bakoe. Jesús weno shäng ba oppinggaga l̈i kongshko ga Tomás shäng eshko l̇l̇ëme.
\v 25 E kjĩshko ga e irgo ga ba pjeyoga tjl̈ẽ ba kong ga «¡Tjl̈apga ĩnorwa!» l̈e ba kong.
\p Kuya ga tjl̈ẽ ba kong l̈ok ga «L̈öraba orkwo bäng l̈i ĩn woydë, ga bor sakkwo zrër woydë ba roshko. Bor orkwo zrër woydë ba pjl̈okso bäng roshko bakoe. Eni l̇l̇ëm ga jl̈õe l̈ër l̇l̇ëme» l̈e.
\p 
\v 26 Öötong sondë kjwara obi ga Jesús oppinggaga l̈i töno uunkong l̈öng u l̈i roshko jek obi. Eshko dbaryo ga Tomás sök eshko bakoe. Eshko ga u bäng bäng jong tuke. Eni ga Jesús weno shäng ba tjrëko obi, ga tjl̈ẽ ba kong l̈ok ga «Miga. Pjãy ber l̈öng wl̈ẽpe» l̈e.
\v 27 E irgo ga tjl̈ẽ Tomás kong ga «Bor orkwo ëre ĩzong. Bop sakkwo kjwe zrës jũshko. Bop orkwo kjwe kjëmö, zrës bor pjl̈okso bäng ëre roshko. Tja woshrono iröng obire, de l̇l̇ëm, e woyotjl̈ĩp ame. E jl̈õe l̈ozong» l̈e.
\p 
\v 28 Eshko ga Tomás tjl̈ẽ ba kong ga «Pja bor Tjl̈apga, bor Sbö bakoe» l̈e.
\p 
\v 29 Kuya ga tjl̈ẽ ba kong ga «Tja woshrono iröng obi jl̈õe l̈ëp, tja ĩnop kjĩshko. Ëye, l̇l̇ëye ĩna l̇l̇ëm ëmdë ga jl̈õe l̈e ga ber wopjl̈úe» l̈e.
\p 
\v 30 L̇l̇ëbo ĩydëba l̇l̇ëm wl̈eniyo shäryara Jesúsdë ba oppinggaga bokshto ara obi, gueniyo tak pjang kjibokwo ëre go l̇l̇ëme.
\v 31 Gueniyo ëre toror, miydëmi e go wl̈o ga no pjl̈uyo ichara Sbörë l̈i, e Jesús, e Sbö Wa bakoe, ga pjãy mär ba go wl̈eni ga pjãy ber l̈öng së ĩyado Sbö tjok.
\c 21
\s1 Jesús weno ba oppinggaga dogl̈o kjäk (7) kong
\p 
\v 1 E irgo ga Jesús weno shäng ba oppinggaga kong obi, di bäng buk kësbang, shkung, so dl̈ung kjoyo ko Tiberias\f + \fr 21:1 \fk Tiberias di bäng\ft , e kowëba \fk Galilea \ft bakoe.\f* l̈i sor go. Shäryono eni.
\v 2 Eshko ga l̈öng Simón Pedro, Tomás (e kowëba Kjl̈ö), Natanael (e Caná so, Caná kjokyo, e Galilea kjokyo obi), Zebedeo wapga do pjök, ba oppinggaga do pjök obi.
\v 3 Ga Simón Pedro tjl̈ẽ l̇l̇amo l̈öng l̈i kong ga «Tja to mã shak» l̈e.
\p Kuya l̈ok ga tjl̈ẽ ba kong ga «Tjawa ëmdë ga jek bop tjok bebi» l̈e.
\p Eni ga uunkong l̈i opyono l̈ok jek kjyong roshko, gueniyo e shkëyo ga mã shano l̇l̇ëme.
\p 
\v 4 Wẽshko kjok shröngto ga ĩya l̈ok ga Jesús weno shäng di bäng l̈i sor go, gueniyo e ë miyde l̈öng l̇l̇ëme.
\v 5 Eni ga Jesús tjl̈ẽ ba kong l̈ok dbo go ga «Pjeyoga, ¿mã sharomire?»
\p «L̇l̇ëme» l̈e l̈ok ba kong.
\p 
\v 6 Kuya ga tjl̈ẽ ba kong l̈ok ga «Bomi mã shakkl̈o kjwe dbuzĩ jer orkwo kël̈ëkong, ga mã shami dani» l̈e.
\p Kuya l̈ok ga shäryara eni, ga ba shakkl̈o l̈i poyõya ga ä, roshko mã ara kjĩshko.
\p 
\v 7 Eshko ga Jesús oppingga woyde ara ba kjl̈ara wl̈eni l̈i\f + \fr 21:7 \fk Ba oppingga woyde ara ba kjl̈ara wl̈eni \ft l̈e l̈i, e \fk Juan \ft l̈ayde.\f* tjl̈ẽ ga «¡Tjl̈apga l̈i shängdo!» l̈e. Kuya Simón Pedrorë ga ba shwong kop l̈ëkong skwara l̈unashko l̈i pjuna jekdo, ga optono jer dishko chuw erä.
\v 8-9 Eshko ga kjyong l̈i buk këm di rong wop tjok. Eni ga l̇l̇amo l̈öng l̈i jek ba irgo kjyong l̈i go, mã shakkl̈o roy mã tjung l̈i dopshiya jek öötong l̈öng pjöshko l̈ëkong. Opshino l̈ok kjyong l̈i roy dwayoshko ga ĩya l̈ok ga iök jong kjrina ri ri, ga iökgwo l̈i kjing go mã buk kjl̈ara, pjl̈ung shosho suk pjir buk kjwara bakoe.
\p 
\v 10 Eshko ga Jesús tjl̈ẽ ba kong l̈ok ga «Mã sharomi yẽ tek sözĩ kjl̈öbö» l̈e.
\p 
\v 11 Kuya Simón Pedrorë ga opyono kjyong l̈i roy, ga mã shakkl̈o beno pjang di roshko l̈i dopshira jek öötong buk pjöshko. Roshko tjeng mã këskës dogl̈o sak dbäw kjingsho sak shkëng kjingsho mya (153), eni ëmdë ga dwl̈ëtong l̇l̇ëme.
\p 
\v 12 Eshko ga Jesús tjl̈ẽ ba kong l̈ok ga «Pjãy tek ië» l̈e.
\p Miyde l̈ok pjl̈ú ga e Tjl̈apga Jesús. E kjĩshko ga «¿Pja ë?» l̈e l̈ok ba kong l̇l̇ëme.
\v 13 E irgo ga Jesús jek ba zl̈ong bäng, ga pjl̈ung shosho suk pjir l̈i kjrara, ga shdöra ba kong. Mã suk pjir l̈i kjrara, ga shdöra eni bakoe.
\v 14 Jesús woshrara Sbörë iröng obi irgo ga weno ba oppinggaga kong e tjok ga öötong pjl̈ogl̈o mya.
\s1 Jesús tjl̈ẽno Pedro kong
\p 
\v 15 Iono l̈ok pjir ga Jesús tjl̈ẽ Simón Pedro kong ga «Simón, Juan wa, ¿tja woydaga ara l̈i ë? ¿E pjare?»
\p «Ëng, Tjl̈apga. Miydëp ga pja woydër» l̈e ba kong.
\p Kuya ga tjl̈ẽ ba kong ga «Eni ga bor tjl̈õkwo kjragaga dëp yõtso, öng wl̈ẽp ushko so de ba dagarë sorë ga eni» l̈e.
\p 
\v 16 Eshko ga Jesús tjl̈ẽ ba kong obi ga «Simón, Juan wa, ¿tja woydëp ara jl̈õkoyore?»
\p «Ëng, Tjl̈apga. Miydëp ga pja woydër» l̈e ba kong.
\p Kuya ga tjl̈ẽ ba kong ga «Eni ga bor tjl̈õkwo kjragaga dëp, öng wl̈ẽp ushko so de ba dagarë sorë ga eni» l̈e.
\p 
\v 17 Era eni ga Jesús tjl̈ẽno ba kong obi, öötong pjl̈ogl̈o mya. Tjl̈ẽ ga «Simón, Juan wa, ¿tja woydëp jl̈õkoyore?» l̈e.
\p Kuya ga woydë ara, kjakrokara ba kong pjl̈ogl̈o mya kjĩshko. Eni ga tjl̈ẽ ba kong ga «Tjl̈apga, l̇l̇ëbo tjeng kës l̈i miydëp shäng pjl̈úe. Miydëp ga pja woydër» l̈e.
\p Kuya ga tjl̈ẽ ba kong ga «Eni ga bor tjl̈õkwo kjragaga dëp, öng wl̈ẽp ushko so de ba dagarë sorë ga eni.
\v 18 L̈ër bop kong jl̈õkoyo ga dënashko ga pja mite obishko ga pja opdoyë tjoksa, pja jek äär woydëp kjone l̈ishko. Gueniyo l̇l̇ono ga pja öötong këguë ga pja orkwo ië ber l̈ok bek, pja doyëba wl̈o, ga pja sökoba jek äär woydëp kjone l̇l̇ëm l̈ishko» l̈e.
\v 19 L̈ara eni l̈i, e Pedro wol̈on sorë l̈i l̈okl̈o, ga Sbö ber kësbang, tjwl̈õ ara e kjĩshko. Eshko ga Jesús tjl̈ẽ ba kong ga «Tja rayëp l̇l̇ëme. Tja opshäryono sorë ga pja opshäryë eni bakoe» l̈e.
\p 
\v 20 Eshko ga Pedro bojono iröng, ga ĩya ga Jesús oppingga woyde Jesúsdë ara ba kjl̈ara wl̈eni l̈i tek shäng ba irgo. (Dënashko ga l̈öng iëshko ga «Tjl̈apga, ¿pja soynega l̈i ë?» l̈aga Jesús kong ba kwomsoshko l̈i e.)
\v 21 Ĩya Pedrorë ga tjl̈ẽ Jesús kong ga «Tjl̈apga, ¿e ga kjwe, l̇l̇ëye shäryëba ba tjok?»
\p 
\v 22 «Woydër ga kjwe ber shäng, tja tjwe iröng obi guing wl̈eni ga wẽyẽ, e miydaga ber tjarë. Tja rayëp l̇l̇ëme. Tja opshäryono sorë ga pja opshäryë eni bakoe» l̈e.
\v 23 E kjĩshko ga roy shdöktong Jesús tjl̈õkwo kjragaga uunkong kong ga domer l̈ara l̈i beno wol̈on l̇l̇ëm wl̈o l̈e. Gueniyo l̈ara Jesúsdë eni l̇l̇ëme. Tjl̈ẽno ga «Woydër ga kjwe ber shäng, tja tjwe iröng obi guing wl̈eni ga wẽyẽ, e miydaga ber tjarë» l̈ara eni eröe.
\p 
\v 24 Ba oppingga l̈ër shäng l̈i, e tja. Ëre ĩnor om go, ga tër shäng om go bakoe. Miydëba ga tja tjl̈ẽ beke.
\p 
\v 25 L̇l̇ëbo shäryara Jesúsdë ara obi obl̈ë obl̈ëe. Toroy uunkong wl̈eni ga kjok kjwang jĩkong dl̈ino jong kjibokwo sho eröe.
