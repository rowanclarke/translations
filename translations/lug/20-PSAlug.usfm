\b
\q1 
\v 3 Onooweebwa ki,
\q2 era onookolebwa otya, ggwe olulimi olukuusa?
\q1 
\v 4 Onoofumitibwa n’obusaale obwogi obw’omulwanyi omuzira,
\q2 n’oyokerwa ku manda ag’omuti entaseesa.
\b
\q1 
\v 5 Ndabye ennaku, kubanga mbeera mu Meseki;
\q2 nsula mu weema za Kedali!
\q1 
\v 6 Ndudde nnyo
\q2 mu bantu abakyawa eddembe.
\q1 
\v 7 Nze njagala mirembe,
\q2 naye bwe njogera bo baagala ntalo.
\c 121
\cl Zabbuli 121
\d Oluyimba nga balinnya amadaala.
\q1 
\v 1 Nnyimusa amaaso gange eri ensozi,
\q2 okubeerwa kwange kuva wa?
\q1 
\v 2 Okubeerwa kwange kuva eri \nd Mukama\nd*,
\q2 eyakola eggulu n’ensi.
\b
\q1 
\v 3 Taliganya kigere kyo kusagaasagana;
\q2 oyo akukuuma taabongootenga.
\q1 
\v 4 Laba, oyo akuuma Isirayiri
\q2 taabongootenga so teyeebakenga.
\b
\q1 
\v 5 \nd Mukama\nd* ye mukuumi wo;
\q2 \nd Mukama\nd* y’akusiikiriza ku mukono gwo ogwa ddyo;
\q1 
\v 6 emisana enjuba teekwokyenga,
\q2 wadde omwezi ekiro.
\b
\q1 
\v 7 \nd Mukama\nd* anaakukuumanga mu buli kabi;
\q2 anaalabiriranga obulamu bwo.
\q1 
\v 8 \nd Mukama\nd* anaakukumanga amagenda go n’amadda,
\q2 okuva leero n’okutuusa emirembe gyonna.
\c 122
\cl Zabbuli 122
\d Oluyimba nga balinnya amadaala. Lwa Dawudi.
\q1 
\v 1 Nasanyuka bwe baŋŋamba nti,
\q2 “Tugende mu nnyumba ya \nd Mukama\nd*!”
\q1 
\v 2 Ebigere byaffe biyimiridde
\q2 mu miryango gyo, Ayi Yerusaalemi.
\b
\q1 
\v 3 Yerusaalemi yazimbibwa okuba
\q2 ekibuga ekinywevu ekiyimiridde awamu.
\q1 
\v 4 Eyo ebika byonna gye biraga,
\q2 ebika bya \nd Mukama\nd*,
\q1 okutendereza erinnya lya \nd Mukama\nd*
\q2 ng’ebiragiro ebyaweebwa Isirayiri bwe biri.
\q1 
\v 5 Eyo entebe ez’okusalirako emisango gye zaateekebwa;
\q2 z’entebe ez’obwakabaka ez’ennyumba ya Dawudi.
\b
\q1 
\v 6 Musabirenga Yerusaalemi emirembe:
\q2 “Abo abakwagala bafune ebirungi.
\q1 
\v 7 Emirembe gibeerenga munda w’ebisenge byo;
\q2 n’amayumba go amanene gabeerenga n’omukisa era nga manywevu.”
\q1 
\v 8 Olwa baganda bange ne mikwano gyange
\q2 nnaayogeranga nti, “Emirembe gibeerenga mu ggwe.”
\q1 
\v 9 Olw’obulungi bw’ennyumba ya \nd Mukama\nd* Katonda waffe, nnaanoonyanga okukulaakulana kwa Yerusaalemi.
\c 123
\cl Zabbuli 123
\d Oluyimba nga balinnya amadaala.
\q1 
\v 1 Nnyimusa amaaso gange gy’oli,
\q2 Ayi ggwe atuula ku ntebe ey’obwakabaka mu ggulu.
\q1 
\v 2 Amaaso g’abaddu nga bwe gatunuulira omukono gwa mukama waabwe;
\q2 n’amaaso g’omuweereza omukazi nga bwe gatunuulira omukono gwa mugole we\f + \fr 123:2 \ft \nd Mukama\nd* w’omuddu ne mugole w’omuddu omukazi baakozesanga bubonero okubaako kye bategeeza abaddu baabwe\f*,
\q1 n’amaaso gaffe bwe gatyo bwe gatunuulira \nd Mukama\nd* Katonda waffe,
\q2 okutuusa lw’alitusaasira.
\b
\q1 
\v 3 Tusaasire, Ayi \nd Mukama\nd*, tusaasire,
\q2 kubanga tunyoomeddwa nnyo ddala.
\q1 
\v 4 Emitima gyaffe gijjudde ennaku olw’okuduulirwa abo abeeyagala,
\q2 n’okunyoomebwa ab’amalala.
\c 124
\cl Zabbuli 124
\d Oluyimba nga balinnya amadaala. Lwa Dawudi.
\q1 
\v 1 Isirayiri agamba nti,
\q2 singa Katonda teyali ku ludda lwaffe,
\q1 
\v 2 singa Katonda teyali ku ludda lwaffe
\q2 abalabe baffe bwe baatulumba,
\q1 
\v 3 banditusaanyizzaawo mu kaseera buseera,
\q2 obusungu bwabwe bwe bwatubuubuukirako.
\q1 
\v 4 Amataba g’obusungu bwabwe ganditusaanyizzaawo,
\q2 ne mukoka n’atukulukutirako;
\q1 
\v 5 amazzi ag’obusungu bwabwe agayira
\q2 ganditukuluggusizza.
\b
\q1 
\v 6 \nd Mukama\nd* atenderezebwe
\q2 atatugabuddeeyo ne tutaagulwataagulwa amannyo gaabwe.
\q1 
\v 7 Tuwonye ng’ekinyonyi bwe kiva
\q2 ku mutego gw’abatezi;
\q1 omutego gukutuse,
\q2 naffe tuwonye!
\q1 
\v 8 Okubeerwa kwaffe kuli mu linnya lya \nd Mukama\nd*,
\q2 eyakola eggulu n’ensi.
\c 125
\cl Zabbuli 125
\d Oluyimba nga balinnya amadaala.
\q1 
\v 1 Abeesiga \nd Mukama\nd* bali ng’olusozi Sayuuni
\q2 olutayinza kusiguukululwa, naye olubeerawo emirembe gyonna.
\q1 
\v 2 Ensozi nga bwe zeetooloola Yerusaalemi,
\q2 ne \nd Mukama\nd* bw’atyo bwe yeetooloola abantu be,
\q2 okuva kaakano n’okutuusa emirembe gyonna.
\b
\q1 
\v 3 Kubanga abafuzi abakola ebibi tebalifugira
\q2 mu nsi y’abatuukirivu,
\q1 baleme okuwaliriza abatuukirivu
\q2 okukola ebibi.
\b
\q1 
\v 4 Ayi \nd Mukama\nd*, abalungi n’abo abalina omutima omulongoofu
\q2 bakolere ebirungi.
\q1 
\v 5 Naye abo abalaga mu makubo gaabwe amakyamu,
\q2 \nd Mukama\nd* alibawaŋŋangusa wamu n’abakola ebitali bya butuukirivu.
\b
\q1 Emirembe gibe ku Isirayiri.
\c 126
\cl Zabbuli 126
\d Oluyimba nga balinnya amadaala.
\q1 
\v 1 \nd Mukama\nd* bwe yakomyawo abawaŋŋanguse ba Sayuuni,
\q2 twafaanana ng’abaloota.
\q1 
\v 2 Olwo akamwa kaffe ne kajjula enseko,
\q2 ne nnimi zaffe ne ziyimba ennyimba ez’essanyu.
\q1 Amawanga ne gagamba nti,
\q2 “\nd Mukama\nd* abakoledde ebikulu.”
\q1 
\v 3 \nd Mukama\nd* atukoledde ebikulu,
\q2 kyetuvudde tusanyuka.
\b
\q1 
\v 4 Otuzze obuggya, Ayi \nd Mukama\nd*,
\q2 tufaanane ng’emigga egikulukutira mu lusenyi.
\q1 
\v 5 Abo abasiga nga bakaaba amaziga,
\q2 baliyimba ennyimba ez’essanyu nga bakungula.
\q1 
\v 6 Oyo agenda ng’akaaba
\q2 ng’atwala ensigo okusiga;
\q1 alikomawo ng’ayimba ennyimba ez’essanyu
\q2 ng’aleeta ebinywa bye.
\c 127
\cl Zabbuli 127
\d Oluyimba nga balinnya amadaala. Lwa Sulemaani.
\q1 
\v 1 \nd Mukama\nd* bw’atazimba nnyumba,
\q2 abo abagizimba bazimbira bwereere.
\q1 \nd Mukama\nd* bw’atakuuma kibuga,
\q2 abakuumi bateganira bwereere.
\q1 
\v 2 Oteganira bwereere bw’okeera mu makya n’okola,
\q2 ate n’olwawo n’okwebaka
\q1 ng’okolerera ekyokulya;
\q2 kubanga \nd Mukama\nd* abaagalwa be abawa otulo.
\b
\q1 
\v 3 Abaana aboobulenzi kya bugagga okuva eri \nd Mukama\nd*;
\q2 era abaana mpeera gy’agaba okuva gy’ali.
\q1 
\v 4 Ng’obusaale bwe bubeera mu mukono gw’omulwanyi,
\q2 n’abaana abazaalibwa mu buvubuka bw’omuntu bwe bali bwe batyo.
\q1 
\v 5 Alina omukisa omuntu oyo
\q2 ajjuzza ensawo ye n’obusaale,
\q1 kubanga tebaliswazibwa;
\q2 balyolekera abalabe baabwe mu mulyango omunene.
\c 128
\cl Zabbuli 128
\d Oluyimba nga balinnya amadaala.
\q1 
\v 1 Balina omukisa abatya Katonda;
\q2 era abatambulira mu makubo ge.
\q1 
\v 2 Olirya ebibala ebiriva mu kutegana kwo;
\q2 oliweebwa emikisa era olifuna ebirungi.
\q1 
\v 3 Mu nnyumba yo,
\q2 mukyala wo aliba ng’omuzabbibu ogubala ennyo;
\q1 abaana bo aboobulenzi baliba ng’amatabi g’emizeeyituuni
\q2 nga beetoolodde emmeeza yo.
\q1 
\v 4 Bw’atyo bw’aweebwa emikisa
\q2 omuntu atya \nd Mukama\nd*.
\b
\q1 
\v 5 \nd Mukama\nd* akuwenga omukisa ng’asinziira mu Sayuuni,
\q2 era olabe Yerusaalemi nga kijjudde ebirungi
\q1 ennaku zonna ez’obulamu bwo.
\q2 
\v 6 Owangaale olabe abaana b’abaana bo!
\b
\q1 Emirembe gibeere mu Isirayiri.
\c 129
\cl Zabbuli 129
\d Oluyimba nga balinnya amadaala.
\q1 
\v 1 Isirayiri ayogere nti,
\q2 “Bambonyaabonyezza nnyo okuva mu buvubuka bwange.”
\q1 
\v 2 Ddala bambonyaabonyezza nnyo okuva mu buvubuka bwange;
\q2 naye tebampangudde.
\q1 
\v 3 Newaakubadde ng’omugongo gwange gujjudde enkovu olw’embooko ze bankubye
\q2 era ne gulabika nga kwe bayisizza ekyuma ekirima,
\q1 
\v 4 kyokka \nd Mukama\nd* mutuukirivu;
\q2 amenyeemenye enjegere z’abakola ebibi.
\b
\q1 
\v 5 Abo bonna abakyawa Sayuuni bagobebwe
\q2 era bazzibweyo emabega nga baswadde.
\q1 
\v 6 Babeere ng’omuddo ogumera waggulu ku nnyumba\f + \fr 129:6 \ft Obusolya bw’ennyumba z’omu Isirayiri zaalina ettaka waggulu ku zo eryali litabuddwamu evvu n’omusenyu. Enkuba bwe yatonnyanga, mwamerangamu omuddo, kyokka omuddo ogwo gwakalanga mangu ddala olw’omusana okugwakako kubanga emirandira gyagwo tegyagendanga wala wansi mu kasolya\f*,
\q2 oguwotoka nga tegunnakula.
\q1 
\v 7 Omukunguzi tagufaako, n’oyo asiba ebinywa agunyooma.
\q1 
\v 8 Wadde abayitawo baleme kwogera nti,
\q2 “Omukisa gwa \nd Mukama\nd* gube ku mmwe.
\q2 Tubasabidde omukisa mu linnya lya \nd Mukama\nd*.”
\c 130
\cl Zabbuli 130
\d Oluyimba nga balinnya amadaala.
\q1 
\v 1 Ayi \nd Mukama\nd*, nkukaabira nga nsobeddwa nnyo.
\q2 
\v 2 Ayi Mukama, wulira eddoboozi lyange;
\q1 otege amatu go
\q2 eri eddoboozi ly’okwegayirira kwange.
\b
\q1 
\v 3 Ayi \nd Mukama\nd*, singa otubalira obutali butuukirivu bwaffe,
\q2 ani eyandiyimiridde mu maaso go?
\q1 
\v 4 Naye osonyiwa;
\q2 noolwekyo ossibwamu ekitiibwa.
\b
\q1 
\v 5 Nnindirira \nd Mukama\nd*, emmeeme yange erindirira
\q2 era essuubi lyange liri mu kigambo kye.
\q1 
\v 6 Emmeeme yange erindirira Mukama;
\q2 mmulindirira okusinga ng’abakuumi bwe balindirira obudde okukya;
\q2 okusingira ddala ng’abakuumi bwe balindirira obudde okukya.
\b
\q1 
\v 7 Ayi Isirayiri, weesigenga \nd Mukama\nd*,
\q2 kubanga \nd Mukama\nd* y’alina okwagala okutaggwaawo;
\q2 era y’alina okununula okutuukiridde.
\q1 
\v 8 \nd Mukama\nd* y’alinunula Isirayiri n’amuggya
\q2 mu byonoono bye byonna.
\c 131
\cl Zabbuli 131
\d Oluyimba nga balinnya amadaala. Lwa Dawudi.
\q1 
\v 1 Ayi \nd Mukama\nd* siri wa malala,
\q2 so n’amaaso gange tegeegulumiza.
\q1 Siruubirira bintu binsukiridde
\q2 newaakubadde ebintu eby’ekitalo ebinsinga.
\q1 
\v 2 Naye ŋŋonzezza emmeeme yange era ngisiriikirizza
\q2 ng’omwana bw’asiriikirira nga nnyina amuggye ku mabeere.
\q2 Omwana avudde ku mabeere nga bw’asiriikirira, n’emmeeme yange bw’eri bw’etyo.
\b
\q1 
\v 3 Ayi Isirayiri, weesigenga \nd Mukama\nd*
\q2 okuva leero n’okutuusa emirembe gyonna.
\c 132
\cl Zabbuli 132
\d Oluyimba nga balinnya amadaala.
\q1 
\v 1 Ayi \nd Mukama\nd* jjukira Dawudi
\q2 n’okubonaabona kwe yagumiikiriza kwonna.
\b
\q1 
\v 2 Nga bwe yalayirira \nd Mukama\nd*,
\q2 ne yeeyama eri Katonda Ayinzabyonna, Katonda wa Yakobo,
\q1 
\v 3 ng’agamba nti, “Siriyingira mu nnyumba yange,
\q2 wadde okulinnya ku kitanda kyange.
\q1 
\v 4 Sirikkiriza tulo kunkwata
\q2 newaakubadde okuzibiriza amaaso gange,
\q1 
\v 5 okutuusa lwe ndimala okufunira \nd Mukama\nd* ekifo;
\q2 ekifo eky’okubeeramu ekya Katonda Ayinzabyonna, Katonda wa Yakobo.”
\b
\q1 
\v 6 Laba, twakiwulirako mu Efulasa,
\q2 ne tukizuula mu nnimiro ya Jaali.
\q1 
\v 7 Kale tugende mu kifo kye mw’abeera,
\q2 tumusinzirize awali entebe y’ebigere bye.
\q1 
\v 8 Golokoka, Ayi \nd Mukama\nd*, ogende mu kifo kyo mw’owummulira;
\q2 ggwe n’Essanduuko yo ey’Endagaano, eraga obuyinza bwo.
\q1 
\v 9 Bakabona bo bambazibwe obutuukirivu,
\q2 n’abatukuvu bo bayimbe n’essanyu.
\b
\q1 
\v 10 Ku lulwe Dawudi omuddu wo,
\q2 tomugaana oyo gwe wafukako amafuta.
\b
\q1 
\v 11 \nd Mukama\nd* Katonda yalayirira Dawudi
\q2 ekirayiro ekitaliggwaawo, era talikivaako.
\q1 Kubanga yamugamba nti, “Omu ku batabani bo
\q2 gwe ndituuza ku ntebe yo ey’obwakabaka.
\q1 
\v 12 Batabani bo bwe banaakuumanga Endagaano yange
\q2 n’ebiragiro byange bye nnaabayigirizanga,
\q1 ne batabani baabwe nabo banaatuulanga
\q2 ku ntebe yo ey’obwakabaka emirembe gyonna.”
\b
\q1 
\v 13 Kubanga \nd Mukama\nd* yalonda Sayuuni,
\q2 nga kye yasiima okutuulangamu, n’agamba nti:
\q1 
\v 14 “Kino kye kifo mwe nnaawummuliranga emirembe gyonna;
\q2 omwo mwe nnaatuulanga nga ndi ku ntebe ey’obwakabaka kubanga nkisiimye.
\q1 
\v 15 Nnaakiwanga omukisa ne nkiwa n’ebirungi,
\q2 era n’abaavu baamu nnaabakkusanga ebyokulya.
\q1 
\v 16 Bakabona baakyo, obulokozi bunaabanga kyambalo kyabwe;
\q2 n’abatukuvu baakyo banaayimbanga ennyimba ez’essanyu n’essanyu.
\b
\q1 
\v 17 “Eyo gye ndyaliza batabani ba Dawudi obuyinza;
\q2 ne muteekerawo ettabaaza olw’oyo gwe nayiwako amafuta.
\q1 
\v 18 Abalabe be ndibajjuza ensonyi,
\q2 naye ye ndimwambaza engule ey’ekitiibwa ekingi.”
\c 133
\cl Zabbuli 133
\d Oluyimba nga balinnya amadaala. Lwa Dawudi.
\q1 
\v 1 Laba bwe kiri ekirungi era nga kisanyusa,
\q2 abooluganda okubeera awamu nga batabaganye.
\b
\q1 
\v 2 Kiri ng’amafuta ag’omuwendo omungi agafukibwa ku mutwe gwa Alooni
\q2 ne gakulukutira mu kirevu;
\q1 gakulukutira mu kirevu kya Alooni,
\q2 ne gakka ku kitogi ky’ebyambalo bye.
\q1 
\v 3 Kiri ng’omusulo gw’oku lusozi Kerumooni,
\q2 ogugwa ne ku nsozi za Sayuuni;
\q1 kubanga eyo \nd Mukama\nd* gy’agabira omukisa
\q2 n’obulamu emirembe gyonna.
\c 134
\cl Zabbuli 134
\d Oluyimba nga balinnya amadaala.
\q1 
\v 1 Mulabe, mutendereze \nd Mukama\nd*, mmwe mwenna abaddu ba \nd Mukama\nd*,
\q2 abaweereza ekiro mu nnyumba ya \nd Mukama\nd*.
\q1 
\v 2 Mugolole emikono gyammwe mu kifo ekitukuvu,
\q2 mutendereze \nd Mukama\nd*.
\b
\q1 
\v 3 \nd Mukama\nd* eyakola eggulu n’ensi
\q2 akuwe omukisa ng’asinziira mu Sayuuni.
\c 135
\cl Zabbuli 135
\q1 
\v 1 Mutendereze \nd Mukama\nd*.
\b
\q1 Mutendereze erinnya lya \nd Mukama\nd*.
\q2 Mumutendereze mmwe abaddu ba \nd Mukama\nd*;
\q1 
\v 2 mmwe abaweereza mu nnyumba ya \nd Mukama\nd*,
\q2 mu mpya z’ennyumba ya Katonda waffe.
\b
\q1 
\v 3 Mutendereze \nd Mukama\nd*, kubanga \nd Mukama\nd* mulungi;
\q2 mutendereze erinnya lye kubanga ekyo kisanyusa.
\q1 
\v 4 Kubanga \nd Mukama\nd* yeerondera Yakobo okuba owuwe;
\q2 ye Isirayiri gwe yeeroboza okuba eky’omuwendo.
\b
\q1 
\v 5 Mmanyi nga \nd Mukama\nd* mukulu wa kitiibwa,
\q2 era nga Mukama oyo y’asinga bakatonda bonna.
\q1 
\v 6 \nd Mukama\nd* kyonna ky’asiima ky’akola,
\q2 mu ggulu ne ku nsi;
\q2 mu nnyanja ne mu buziba bwayo.
\q1 
\v 7 Alagira ebire ne byekuluumulula okuva ku nkomerero y’ensi;
\q2 atonnyesa enkuba erimu okumyansa,
\q2 n’asumulula empewo okuva mu mawanika ge.
\b
\q1 
\v 8 Ye yakuba ababereberye ab’e Misiri;
\q2 ababereberye b’abantu n’ebibereberye by’ebisolo.
\q1 
\v 9 Ye yaweereza obubonero n’ebyewuunyo wakati wo, ggwe Misiri,
\q2 eri Falaawo n’abaweereza be bonna.
\q1 
\v 10 Ye yakuba amawanga amangi,
\q2 n’atta bakabaka ab’amaanyi era be bano,
\q1 
\v 11 Sikoni kabaka w’Abamoli,
\q2 ne Ogi kabaka w’e Basani
\q2 ne bakabaka bonna ab’e Kanani.
\q1 
\v 12 Ensi yaabwe n’agiwaayo ng’obusika,
\q2 okuba obusika bw’abantu be Isirayiri.
\b
\q1 
\v 13 Ayi \nd Mukama\nd*, erinnya lyo lya lubeerera,
\q2 era n’obukulu bwo bumanyibwa emirembe gyonna.
\q1 
\v 14 Kubanga Katonda aliggyako abantu be omusango,
\q2 era alisaasira abaweereza be.
\q1 
\v 15 Abamawanga ebifaananyi byonna ebyole bye basinza,
\q2 ebyakolebwa n’emikono gy’abantu mu ffeeza ne zaabu,
\q1 
\v 16 birina emimwa, naye tebyogera;
\q2 birina amaaso, naye tebiraba;
\q1 
\v 17 birina amatu naye tebiwulira;
\q2 so ne mu kamwa kaabyo temuyitamu mukka.
\q1 
\v 18 Ababikola balibifaanana;
\q2 na buli abyesiga alibifaanana.
\b
\q1 
\v 19 Ayi ennyumba ya Isirayiri mutendereze \nd Mukama\nd*;
\q2 mmwe ennyumba ya Alooni mutendereze \nd Mukama\nd*.
\q1 
\v 20 Mmwe ennyumba ya Leevi mutendereze \nd Mukama\nd*;
\q2 mmwe abatya \nd Mukama\nd* mutendereze \nd Mukama\nd*.
\q1 
\v 21 \nd Mukama\nd* ali mu Sayuuni yeebazibwe;
\q2 yeebazibwe oyo abeera mu Yerusaalemi.
\b
\q1 Mutendereze \nd Mukama\nd*.
\c 136
\cl Zabbuli 136
\q1 
\v 1 Mwebaze \nd Mukama\nd* kubanga mulungi,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 2 Mwebaze Katonda wa bakatonda bonna,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 3 Mwebaze Mukama w’abafuzi,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\b
\q1 
\v 4 Oyo yekka akola ebyamagero ebikulu,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 5 Oyo eyakola eggulu mu kutegeera kwe,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 6 Oyo eyabamba ensi ku mazzi,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 7 Oyo eyakola ebyaka ebinene,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 8 Enjuba yagikola okufuganga emisana,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 9 Omwezi n’emmunyeenye yabikola okufuganga ekiro,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\b
\q1 
\v 10 Oyo eyatta ababereberye b’Abamisiri,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 11 N’aggya Isirayiri mu Misiri,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 12 Yabaggyamu n’omukono gwe ogw’amaanyi gwe yagolola;
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\b
\q1 
\v 13 Oyo eyayawulamu amazzi g’Ennyanja Emyufu,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 14 N’ayisa abaana ba Isirayiri wakati waayo,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 15 Naye n’asaanyaawo Falaawo n’eggye lye mu Nnyanja Emyufu;
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\b
\q1 
\v 16 Oyo eyakulembera abantu be mu ddungu,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\b
\q1 
\v 17 Ye yafufuggaza bakabaka abaatiikirivu,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 18 N’atta bakabaka ab’amaanyi,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 19 Ye yatta ne Sikoni, kabaka w’Abamoli,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 20 Era ye yatta ne Ogi kabaka wa Basani,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 21 N’awaayo ensi yaabwe okuba obutaka,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 22 Okuba obutaka bwa Isirayiri omuddu we,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\b
\q1 
\v 23 Oyo eyatujjukira nga tuweddemu ensa,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 24 N’atuwonya abalabe baffe,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\q1 
\v 25 Oyo awa abantu n’ebiramu byonna ekyokulya,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\b
\q1 
\v 26 Kale mwebaze Katonda w’eggulu,
\qr kubanga okwagala kwe kubeerera emirembe gyonna.
\c 137
\cl Zabbuli 137
\q1 
\v 1 Twatuula ku mabbali g’emigga gy’e Babulooni,
\q2 ne tukaaba amaziga bwe twajjukira Sayuuni.
\q1 
\v 2 Ne tuwanika ennanga zaffe
\q2 ku miti egyali awo.
\q1 
\v 3 Abaatunyaga ne batulagira okuyimba,
\q2 abaatubonyaabonya ne batulagira okusanyuka;
\q2 nga bagamba nti, “Mutuyimbireyo lumu ku nnyimba za Sayuuni.”
\b
\q1 
\v 4 Tunaayimba tutya oluyimba lwa \nd Mukama\nd*
\q2 mu nsi eteri yaffe?
\q1 
\v 5 Bwe nnaakwerabiranga, ggwe Yerusaalemi,
\q2 omukono gwange ogwa ddyo gukale!
\q1 
\v 6 Olulimi lwange lwesibire waggulu w’ekibuno kyange
\q2 singa nkwerabira,
\q1 ggwe Yerusaalemi, ne sikulowoozaako
\q2 okusinga ebintu ebirala byonna.
\b
\q1 
\v 7 Jjukira, Ayi \nd Mukama\nd*, batabani ba Edomu kye baakola,\f + \fr 137:7 \ft Nebukadduneeza bwe yazikiriza Yerusaalemi, bazzukulu ba Edomu baasanyuka okulaba ng’abalabe baabwe Abayisirayiri bazikiridde. Kino kyali kibi nnyo kubanga Abayisirayiri ne bazzukulu ba Edomu baaluganda. Bazzukulu ba Edomu bava mu Esawu\f*
\q2 ku lunaku Yerusaalemi lwe kyawambibwa;
\q1 ne baleekaana nti, “Kisuule,
\q2 kimalirewo ddala n’emisingi gyakyo.”
\q1 
\v 8 Ggwe omuwala wa Babulooni, agenda okuzikirizibwa,
\q2 yeesiimye oyo alikusasula ebyo
\q2 nga naawe bye watukola.
\q1 
\v 9 Yeesiimye oyo aliddira abaana bo
\q2 n’ababetentera\f + \fr 137:9 \ft Okukakasa nga tewaba n’omu ku b’omu kibuga ekiwambiddwa asigalawo, abaakiwambanga baabetentanga emitwe gy’abaana abato ab’omu kibuga ekyo ku lwazi\f* ku lwazi.
\c 138
\cl Zabbuli 138
\d Zabbuli Ya Dawudi.
\q1 
\v 1 Nnaakutenderezanga Ayi \nd Mukama\nd*, n’omutima gwange gwonna;
\q2 ne mu maaso ga bakatonda abalala nnaayimbanga okukutendereza.
\q1 
\v 2 Nvuunama nga njolekedde Yeekaalu yo Entukuvu,
\q2 ne ntendereza erinnya lyo
\q2 olw’okwagala kwo n’olw’obwesigwa bwo;
\q1 kubanga wagulumiza ekigambo kyo
\q2 n’erinnya lyo okusinga ebintu byonna.
\q1 
\v 3 Olunaku lwe nakukoowoolerako wannyanukula;
\q2 n’onnyongeramu amaanyi mu mwoyo gwange.
\b
\q1 
\v 4 Bakabaka bonna ab’omu nsi banaakutenderezanga, Ayi \nd Mukama\nd*,
\q2 nga bawulidde ebigambo ebiva mu kamwa ko.
\q1 
\v 5 Banaatenderezanga ebikolwa byo Ayi \nd Mukama\nd*;
\q2 kubanga ekitiibwa kya \nd Mukama\nd* kinene.
\b
\q1 
\v 6 Newaakubadde nga \nd Mukama\nd* asukkulumye,
\q2 naye afaayo eri abo abeetoowaza; naye abeegulumiza ababeera wala.
\q1 
\v 7 Newaakubadde nga neetooloddwa ebizibu,
\q2 naye ggwe okuuma obulamu bwange;
\q1 ogolola omukono gwo eri abalabe bange abakambwe,
\q2 era omukono gwo ogwa ddyo ne gumponya.
\q1 
\v 8 \nd Mukama\nd* alituukiriza ebyo by’anteekeddeteekedde;
\q2 kubanga okwagala kwo, Ayi \nd Mukama\nd*, kubeerera emirembe gyonna.
\q2 Tolekulira ebyo bye watonda.
\c 139
\cl Zabbuli 139
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 Ayi \nd Mukama\nd*, okebedde omutima gwange,
\q2 n’otegeera byonna ebiri munda yange.
\q1 
\v 2 Bwe ntuula omanya, ne bwe ngolokoka omanya;
\q2 era otegeera byonna bye ndowooza, ne bwe mbeera ewala ennyo.
\q1 
\v 3 Otegeera okutambula kwange kwonna n’okuwummula kwange.
\q2 Omanyi amakubo gange gonna.
\q1 
\v 4 Ekigambo kye nnaayogera, Ayi \nd Mukama\nd*,
\q2 okimanya nga sinnaba na kukyogera.
\q1 
\v 5 Ondi mu maaso n’emabega,
\q2 era ontaddeko omukono gwo.
\q1 
\v 6 Okumanya okw’engeri eyo kunsukkiridde,
\q2 era nkwewuunya nnyo, kunnema okutegeera.
\b
\q1 
\v 7 Nnaagenda wa Omwoyo wo gy’atali?
\q2 Oba nnaagenda wa ggwe gy’otoli?
\q1 
\v 8 Bwe nnaalinya mu ggulu, nga gy’oli;
\q2 bwe nnakka emagombe, nayo nga gy’oli.
\q1 
\v 9 Bwe nneebagala empewo ez’oku makya ne zintwala
\q2 ne mbeera mu bitundu by’ennyanja ebisinga okuba ewala;
\q1 
\v 10 era n’eyo omukono gwo gunannuŋŋamya,
\q2 omukono gwo ogwa ddyo gunannywezanga.
\q1 
\v 11 Bwe nnaagamba nti, “Ekizikiza kimbuutikire,
\q2 n’obudde obw’emisana bwe ndimu bufuuke ekiro.”
\q1 
\v 12 Naye era ekizikiza gy’oli tekiba kizikiza,
\q2 ekiro kyakaayakana ng’emisana;
\q2 kubanga gy’oli ekizikiza n’omusana bifaanana.
\b
\q1 
\v 13 Ggwe watonda byonna ebiri munda mu nze;
\q2 ggwe wammumbira mu lubuto lwa mmange.
\q1 
\v 14 Nkutendereza, kubanga wankola mu ngeri ey’entiisa era ey’ekitalo;
\q2 emirimu gyo gya kyewuunyo;
\q2 era ekyo nkimanyidde ddala bulungi.
\q1 
\v 15 Wammanya nga ntondebwa,
\q2 bwe nakolerwa mu kyama;
\q1 bwe natondebwa mu buziba bw’ensi n’amagezi go amangi.
\q2 
\v 16 Wandaba nga si natondebwa.
\q1 Ennaku zange zonna ze wanteekerateekera
\q2 zawandiikibwa mu kitabo kyo.
\q1 
\v 17 By’ondowooleza nga bya muwendo munene, Ayi Katonda!
\q2 Omuwendo gwabyo munene!
\q1 
\v 18 Singa ngezaako okubibala
\q2 bisinga omusenyu obungi.
\q1 Ne bwe ngolokoka mu makya
\q2 oba okyandowoozaako.
\b
\q1 
\v 19 Abakola ebibi batte, Ayi Katonda;
\q2 abasajja abassi b’abantu banveeko.
\q1 
\v 20 Abantu abo bakwogerako bibi;
\q2 bakwegulumiririzaako mu butategeera bwabwe.
\q1 
\v 21 Abakukyawa, Ayi \nd Mukama\nd*, nange mbakyawa;
\q2 abo abakwegulumiririzaako bansunguwaza.
\q1 
\v 22 Mbakyayira ddala nnyo,
\q2 era mbayita balabe bange.
\q1 
\v 23 Nkebera, Ayi Katonda, otegeere omutima gwange.
\q2 Ngezesa omanye ebirowoozo byange.
\q1 
\v 24 Olabe obanga mu nze mulimu engeri yonna enkyamu;
\q2 era onkulembere mu kkubo erintuusa mu bulamu obutaggwaawo.
\c 140
\cl Zabbuli 140
\d Ya mukulu w’okuyimba. Zabbuli ya Dawudi.
\q1 
\v 1 Omponye abakola ebibi, Ayi \nd Mukama\nd*,
\q2 omponye abantu abakambwe;
\q1 
\v 2 abateesa mu mitima gyabwe okukola ebibi;
\q2 abanoonya entalo buli kiseera.
\q1 
\v 3 Ebigambo byabwe byogi ng’ennimi z’emisota;
\q2 ebiva mu kamwa kaabwe busagwa ng’obw’essalambwa.
\b
\q1 
\v 4 Onkuume abakola ebibi baleme okunkwatako, Ayi \nd Mukama\nd*;
\q2 omponye abantu abakambwe
\q2 abateesa okunkyamya.
\q1 
\v 5 Abantu ab’amalala banteze omutego;
\q2 banjuluzza ekitimba kyabwe;
\q2 ne batega emitego mu kkubo lyange.
\b
\q1 
\v 6 Nagamba \nd Mukama\nd* nti, “Ggwe oli Katonda wange.”
\q2 Wulira okwegayirira kwange, onsaasire, Ayi \nd Mukama\nd*!
\q1 
\v 7 Ayi \nd Mukama\nd*, \nd Mukama\nd* wange, ggw’omponya n’amaanyi go,
\q2 ggwe engabo yange mu lutalo.
\q1 
\v 8 Ayi \nd Mukama\nd*, abakola ebibi tobawa bye beetaaga,
\q2 era tokkiriza ntekateeka zaabwe kutuukirira;
\q2 baleme kuba na malala wadde okwenyumiriza.
\b
\q1 
\v 9 Abanneetoolodde baleke enkwe zaabwe
\q2 zibeekyusizeeko baboneebone.
\q1 
\v 10 Amanda agaaka omuliro gabagwire;
\q2 basuulibwe mu muliro,
\q2 bakasukibwe mu bunnya obutakoma mwe bataliva emirembe gyonna.
\q1 
\v 11 Tokkiriza balimba kweyongera bungi;
\q2 abakambwe bayigganyizibwe bazikirire.
\b
\q1 
\v 12 Mmanyi nga \nd Mukama\nd* ayamba abo ababonaabona, y’ayamba abanaku okuyisibwa mu bwenkanya.
\q1 
\v 13 Abatuukirivu banaakutenderezanga,
\q2 era w’oli we banaabeeranga.
\c 141
\cl Zabbuli 141
\d Zabbuli Ya Dawudi.
\q1 
\v 1 Ayi \nd Mukama\nd* nkukaabira; oyanguwe okujja gye ndi!
\q2 Owulire eddoboozi lyange, nga nkukoowoola.
\q1 
\v 2 Okusaba kwange kubeere ng’ebyakaloosa mu maaso go,
\q2 n’okugolola emikono gyange gy’oli kubeere nga ssaddaaka ey’akawungeezi.
\b
\q1 
\v 3 Onkuume, Ayi \nd Mukama\nd*, nneme okwasamya akamwa kange,
\q2 era bwe njogera onkomeko.
\q1 
\v 4 Okyuse omutima gwange guleme kugoberera kibi,
\q2 n’okwemalira mu bikolwa ebibi;
\q1 nneme okwetaba n’abantu abakola ebitali bya butuukirivu,
\q2 wadde okulya ku mmere yaabwe.
\b
\q1 
\v 5 Leka omuntu omutuukirivu ankube, kubanga anaaba ankwatiddwa ekisa;
\q2 muleke annenye, ekyo kinaaba ng’amafuta amalungi agafukiddwa ku mutwe gwange;
\q2 sijja kugagaana.
\q1 Naye nnaasabanga bulijjo nga sikkiriziganya na babi wadde n’ebikolwa byabwe.
\q2 
\v 6 Abakola ebibi bwe baliweebwayo eri ab’okubasalira omusango,
\q2 olwo ne balyoka bayiga nti ebigambo byange bya mazima.
\q1 
\v 7 Balyogera nti, “Ng’omuntu bw’akabala n’akuba amavuunike,
\q2 n’amagumba gaffe bwe galisaasaanyizibwa bwe gatyo mu kamwa k’emagombe.”
\b
\q1 
\v 8 Naye nze amaaso ngatadde ku ggwe, Ayi \nd Mukama\nd* Katonda;
\q2 mu ggwe mwe neekwese, tondeka nga sirina anambeera!
\q1 
\v 9 Nkuuma omponye omutego gwe banteze,
\q2 n’ebitimba by’abo abakola ebitali bya butuukirivu.
\q1 
\v 10 Ebitimba bye banteze abakola ebibi abo bonna, baleke babigwemu, kyokka nze mpone.
\c 142
\cl Zabbuli 142
\d Okusaba kwa Dawudi bwe yali mu mpuku.
\q1 
\v 1 Nkaabirira \nd Mukama\nd* n’eddoboozi ery’omwanguka;
\q2 neegayirira \nd Mukama\nd* ansaasire.
\q1 
\v 2 Mmutegeeza byonna ebinneemulugunyisa,
\q2 ne mmwanjulira ebinteganya byonna.
\b
\q1 
\v 3 Omwoyo gwange bwe gunnennyika,
\q2 gw’omanyi eky’okunkolera.
\q1 Banteze omutego mu kkubo lyange mwe mpita.
\q1 
\v 4 Bwe ntunula ku mukono gwange ogwa ddyo, sirabayo anambeera;
\q2 sirina wa kwekweka, era tewali n’omu anfaako.
\b
\q1 
\v 5 Nkaabirira ggwe, Ayi \nd Mukama\nd*,
\q2 nga ŋŋamba nti, “Ggwe kiddukiro kyange,
\q2 ggwe mugabo gwange mu nsi muno.”
\b
\q1 
\v 6 Owulire okukaaba kwange,
\q2 kubanga njeezebwa nnyo!
\q1 Mponya abanjigganya,
\q2 kubanga bansinza nnyo amaanyi.
\q1 
\v 7 Nziggya mu kkomera,
\q2 ndyoke nkwebaze nga ntendereza erinnya lyo.
\q1 Abatuukirivu balinneetooloola,
\q2 ng’onkoledde ebyekisa ekingi ebingi.
\c 143
\cl Zabbuli 143
\d Zabbuli Ya Dawudi.
\q1 
\v 1 Wulira okusaba kwange, Ayi \nd Mukama\nd*,
\q2 wulira okwegayirira kwange!
\q1 Ggwe omwesigwa
\q2 era omutuukirivu jjangu ombeere.
\q1 
\v 2 Tonsalira musango,
\q2 kubanga mu maaso go tewali n’omu atuukiridde.
\q1 
\v 3 Omulabe wange angoba n’ankwata n’ansuula wansi;
\q2 anteeka mu kizikiza ne nfaanana ng’abaafa edda.
\q1 
\v 4 Noolwekyo omwoyo gwange guweddemu endasi,
\q2 n’omutima gwange gwennyise.
\q1 
\v 5 Nzijukira ennaku ez’edda,
\q2 ne nfumiitiriza ku ebyo bye wakola byonna,
\q2 ne ndowooza ku mirimu gy’emikono gyo.
\q1 
\v 6 Ngolola emikono gyange gy’oli,
\q2 ne nkuyaayaanira ng’ettaka ekkalu bwe liyaayaanira enkuba.
\b
\q1 
\v 7 Yanguwa okunziramu, Ayi \nd Mukama\nd*,
\q2 kubanga omwoyo gwange guggwaamu amaanyi.
\q1 Tonkisa maaso go,
\q2 nneme okufaanana ng’abafu.
\q1 
\v 8 Obudde nga bukedde, nsaba ondage okwagala kwo okutaggwaawo;
\q2 kubanga ggwe gwe neesiga.
\q1 Njigiriza ekkubo lye nsaana okutambuliramu,
\q2 kubanga omwoyo gwange gwonna guli gy’oli.
\q1 
\v 9 Mponya, Ayi \nd Mukama\nd*, abalabe bange,
\q2 kubanga ggwe kiddukiro kyange.
\q1 
\v 10 Njigiriza okukola by’oyagala,
\q2 kubanga ggwe Katonda wange!
\q1 Omwoyo wo omulungi ankulembere,
\q2 antambulize mu kkubo eddungi ery’omuseetwe.
\b
\q1 
\v 11 Olw’erinnya lyo, Ayi \nd Mukama\nd*, onkuume,
\q2 mu butuukirivu bwo onzigye mu kabi.
\q1 
\v 12 Omalewo abalabe bange olw’okwagala kwo,
\q2 ozikirize n’abanjigganya bonna,
\q2 kubanga nze ndi muddu wo.
\c 144
\cl Zabbuli 144
\d Zabbuli ya Dawudi.
\q1 
\v 1 Atenderezebwe \nd Mukama\nd*, olwazi lwange,
\q2 atendeka emikono gyange okulwana,
\q2 era ateekerateekera engalo zange olutalo.
\q1 
\v 2 \nd Mukama\nd* anjagala ye Katonda wange era kye kiddukiro kyange,
\q2 ge maanyi gange amangi era ye mulokozi wange.
\q1 Ye ngabo yange mwe neekweka.
\q2 Awangula amawanga n’agassa wansi w’ebigere byange.
\b
\q1 
\v 3 Ayi \nd Mukama\nd*, omuntu kye ki ggwe okumufaako,
\q2 oba omwana w’omuntu, ggwe okumulowoozaako?
\q1 
\v 4 Omuntu ali nga mukka.
\q2 Ennaku ze ziri ng’ekisiikirize ekiyita obuyisi.
\b
\q1 
\v 5 Yawula mu ggulu lyo, Ayi \nd Mukama\nd*, okke!
\q2 Kwata ku nsozi zinyooke omukka!
\q1 
\v 6 Myansa abalabe basaasaane,
\q2 era lasa obusaale bwo obazikirize.
\q1 
\v 7 Ogolole omukono gwo ng’osinziira waggulu ennyo,
\q2 omponye,
\q1 onzigye mu mazzi amangi,
\q2 era onzigye mu mikono gya bannamawanga;
\q1 
\v 8 ab’emimwa egyogera eby’obulimba,
\q2 abalayira nti kya mazima, so nga bulimba bwereere.
\b
\q1 
\v 9 Ayi \nd Mukama\nd*, nnaakuyimbiranga oluyimba oluggya;
\q2 nnaakukubiranga ennanga ey’enkoba ekkumi,
\q1 
\v 10 ggwe awa bakabaka obuwanguzi;
\q2 amponya, nze omuddu wo Dawudi, ekitala ekyogi.
\b
\q1 
\v 11 Ndokola, omponye onzigye
\q2 mu mukono gwa bannamawanga bano
\q1 ab’emimwa egyogera eby’obulimba,
\q2 era omukono gwabwe ogwa ddyo gwa bulimba.
\b
\q1 
\v 12 Batabani baffe mu buvubuka bwabwe, Ayi \nd Mukama\nd*,
\q2 babeere ng’ebisimbe ebikulidde ddala obulungi,
\q1 ne bawala baffe babe ng’empagi ennungi ez’oku nsonda
\q2 okuzimbirwa ennyumba ya kabaka mu lubiri.
\q1 
\v 13 Amawanika gaffe gajjule ebibala
\q2 ebya buli ngeri.
\q1 Endiga zaffe zizaale
\q2 enkumi n’obukumi zijjule amalundiro gaffe.
\q2 
\v 14 Ente zaffe ziwalule ebizito.
\q1 Ebisenge by’ekibuga bireme kumenyebwa.
\q2 Waleme kubaawo kukaaba
\q2 n’okwaziirana kwonna mu nguudo ez’omu bibuga byaffe.
\q1 
\v 15 Abantu abaweereddwa emikisa egyo beesiimye!
\q2 Balina omukisa abantu abo abalina Katonda waabwe nga ye \nd Mukama\nd*.
\c 145
\cl Zabbuli 145
\d Oluyimba lwa Dawudi olw’okutendereza.
\q1 
\v 1 Nnaakugulumizanga ggwe Katonda wange, era Kabaka wange;
\q2 era nnaatenderezanga erinnya lyo buli lunaku emirembe n’emirembe.
\q1 
\v 2 Nnaakutenderezanga buli lunaku;
\q2 era nnaasuutanga erinnya lyo emirembe n’emirembe.
\b
\q1 
\v 3 \nd Mukama\nd* mukulu, wa kitiibwa, era asaanira okutenderezebwanga ennyo,
\q2 n’obukulu bwe tebwogerekeka.
\q1 
\v 4 Buli mulembe gunaatenderanga gunnaagwo ebikolwa byo,
\q2 era gunaatendanga emirimu gyo egy’amaanyi.
\q1 
\v 5 Nnaatendanga obukulu n’obulungi bw’ekitiibwa kyo,
\q2 era nnaafumiitirizanga ku bikolwa byo ebyewuunyisa.
\q1 
\v 6 Abantu banaatendanga amaanyi g’ebikolwa byo eby’ekitalo,
\q2 nange nnaatendanga obukulu bwo obw’ekitiibwa.
\q1 
\v 7 Banaayogeranga ku bulungi bwo obw’ekitalo nga bajaguza;
\q2 era banaayimbanga olw’obutuukirivu bwo.
\b
\q1 
\v 8 \nd Mukama\nd* wa kisa, ajudde okusaasira,
\q2 alwawo okusunguwala era ajudde okwagala okutaggwaawo.
\b
\q1 
\v 9 \nd Mukama\nd* mulungi eri buli muntu,
\q2 era okusaasira kwe kubuna byonna bye yatonda.
\q1 
\v 10 Byonna bye watonda binaakutenderezanga, Ayi \nd Mukama\nd*;
\q2 n’abatukuvu bo banaakugulumizanga.
\q1 
\v 11 Banaayogeranga ku kitiibwa ky’obwakabaka bwo,
\q2 era banaatendanga amaanyi go.
\q1 
\v 12 Balyoke bategeeze abantu bonna ebikolwa byo eby’amaanyi,
\q2 n’ekitiibwa ky’obukulu obw’obwakabaka bwo.
\q1 
\v 13 Obwakabaka bwo, bwakabaka bwa lubeerera,
\q2 n’obufuzi bwo bwa mirembe na mirembe.
\b
\q1 \nd Mukama\nd* by’ayogera byonna bya bwesigwa,
\q2 n’ebikolwa bye bijjudde okusaasira.
\q1 
\v 14 \nd Mukama\nd* awanirira abo bonna abazitoowereddwa,
\q2 era ayimusa bonna abagwa.
\q1 
\v 15 Amaaso g’abantu bonna gatunuulira ggwe, Ayi \nd Mukama\nd*,
\q2 era bonna gw’obawa ebyokulya mu biseera byabyo.
\q1 
\v 16 Oyanjuluza engalo zo,
\q2 ebiramu byonna n’obigabira bye byetaaga ne bikkuta.
\b
\q1 
\v 17 \nd Mukama\nd* mutuukirivu mu bikolwa bye byonna
\q2 era ayagala byonna bye yatonda.
\q1 
\v 18 \nd Mukama\nd* abeera kumpi n’abo bonna abamukoowoola;
\q2 abo bonna abamukoowoola mu mazima.
\q1 
\v 19 Abo bonna abamussaamu ekitiibwa abawa bye baagala,
\q2 era awulira okukaaba kwabwe n’abawonya.
\q1 
\v 20 \nd Mukama\nd* akuuma bonna abamwagala,
\q2 naye abakola ebibi alibazikiriza.
\b
\q1 
\v 21 Akamwa kange kanaatenderezanga \nd Mukama\nd*,
\q2 era na buli kitonde kinaatenderezanga erinnya lye ettukuvu
\q2 emirembe n’emirembe.
\c 146
\cl Zabbuli 146
\q1 
\v 1 Tendereza \nd Mukama\nd*!
\b
\q1 Tendereza \nd Mukama\nd* ggwe emmeeme yange!
\b
\q1 
\v 2 Nnaatenderezanga \nd Mukama\nd* ennaku zonna ez’obulamu bwange;
\q2 nnaayimbanga okutendereza Katonda wange nga nkyali mulamu.
\q1 
\v 3 Teweesiganga bafuzi,
\q2 wadde abantu obuntu omutali buyambi.
\q1 
\v 4 Kubanga bafa ne bakka emagombe;
\q2 ne ku lunaku olwo lwennyini, byonna bye baba bateeseteese ne bifa.
\q1 
\v 5 Yeesiimye oyo ayambibwa Katonda wa Yakobo;
\q2 ng’essuubi lye liri mu \nd Mukama\nd* Katonda we,
\q1 
\v 6 eyakola eggulu n’ensi
\q2 n’ennyanja ne byonna ebirimu,
\q2 era omwesigwa emirembe gyonna.
\q1 
\v 7 Atereeza ensonga z’abajoogebwa mu bwenkanya,
\q2 n’abalumwa enjala abawa ebyokulya.
\q1 \nd Mukama\nd* asumulula abasibe.
\q2 
\v 8 \nd Mukama\nd* azibula amaaso ga bamuzibe,
\q1 era awanirira abazitoowereddwa.
\q2 \nd Mukama\nd* ayagala abatuukirivu.
\q1 
\v 9 \nd Mukama\nd* alabirira bannamawanga,
\q2 era ayamba bamulekwa ne bannamwandu;
\q2 naye ekkubo ly’abakola ebibi alifaafaaganya.
\b
\q1 
\v 10 \nd Mukama\nd* anaafuganga emirembe gyonna,
\q2 Katonda wo, Ayi Sayuuni, anaabanga Katonda wa buli mulembe.
\b
\q1 Mutendereze \nd Mukama\nd*!
\c 147
\cl Zabbuli 147
\q1 
\v 1 Mutendereze \nd Mukama\nd*!
\b
\q1 Kubanga kirungi okutenderezanga Katonda waffe;
\q2 kubanga ajjudde ekisa, n’oluyimba olw’okumutenderezanga lumusaanira.
\b
\q1 
\v 2 \nd Mukama\nd* azimba Yerusaalemi;
\q2 era akuŋŋaanya Abayisirayiri abaali mu buwaŋŋanguse.
\q1 
\v 3 Azzaamu amaanyi abo abalina emitima egimenyese,
\q2 era ajjanjaba ebiwundu byabwe.
\q1 
\v 4 \nd Mukama\nd* ategeka omuwendo gw’emmunyeenye;
\q2 era buli emu n’agituuma erinnya.
\q1 
\v 5 Mukama waffe mukulu era wa kitiibwa; amaanyi g’obuyinza bwe tegatendeka,
\q2 n’okutegeera kwe tekuliiko kkomo.
\q1 
\v 6 \nd Mukama\nd* awanirira abawombeefu,
\q2 naye abakola ebibi abasuulira ddala wansi.
\b
\q1 
\v 7 Muyimbire \nd Mukama\nd* ennyimba ez’okumwebaza;
\q2 mumukubire entongooli ezivuga obulungi.
\b
\q1 
\v 8 \nd Mukama\nd* abikka eggulu n’ebire,
\q2 ensi agitonnyeseza enkuba,
\q2 n’ameza omuddo ne gukula ku nsozi.
\q1 
\v 9 Ente aziwa emmere, ne bannamuŋŋoona abato abakaaba abaliisa.
\b
\q1 
\v 10 Essanyu lya \nd Mukama\nd* teriri mu maanyi ga mbalaasi,
\q2 wadde mu magulu g’omuntu,
\q1 
\v 11 wabula \nd Mukama\nd* asanyukira abo abamussaamu ekitiibwa,
\q2 era abalina essuubi mu kwagala kwe okutaggwaawo.
\b
\q1 
\v 12 Tendereza \nd Mukama\nd* ggwe Yerusaalemi,
\q2 tendereza Katonda wo ggwe Sayuuni,
\q1 
\v 13 kubanga ebisiba enzigi zo, ye abinyweza,
\q2 n’abantu bo abasulamu n’abawa omukisa.
\q1 
\v 14 Aleeta emirembe ku nsalo zo;
\q2 n’akukkusa eŋŋaano esinga obulungi.
\b
\q1 
\v 15 Aweereza ekiragiro kye ku nsi;
\q2 ekigambo kye ne kibuna mangu.
\q1 
\v 16 Ayaliira omuzira ku ttaka ne gutukula ng’ebyoya by’endiga enjeru,
\q2 n’omusulo ogukutte n’agusaasaanya ng’evvu.
\q1 
\v 17 Omuzira agukanyuga ng’obuyinjayinja;
\q2 bw’aleeta obutiti ani ayinza okubusobola?
\q1 
\v 18 \nd Mukama\nd* aweereza ekigambo kye, omuzira ne gusaanuuka;
\q2 n’akunsa empewo, amazzi ne gakulukuta.
\q1 
\v 19 Yategeeza Yakobo ekigambo kye;
\q2 Isirayiri n’amanya amateeka ga \nd Mukama\nd* n’ebiragiro bye.
\q1 
\v 20 Tewali ggwanga na limu lye yali akolaganye nalyo bw’atyo;
\q2 amawanga amalala tegamanyi mateeka ge.
\b
\q1 Mutendereze \nd Mukama\nd*!
\c 148
\cl Zabbuli 148
\q1 
\v 1 Mutendereze \nd Mukama\nd*!
\b
\q1 Mumutendereze nga musinziira mu ggulu,
\q2 mumutenderereze mu bifo ebiri waggulu.
\q1 
\v 2 Mumutendereze mmwe mwenna bamalayika be,
\q2 mumutendereze mmwe mwenna eggye lye ery’omu ggulu.
\q1 
\v 3 Mmwe enjuba n’omwezi mutendereze \nd Mukama\nd*,
\q2 nammwe mwenna emmunyeenye ezaaka mumutendereze.
\q1 
\v 4 Tendereza \nd Mukama\nd* ggwe eggulu eriri waggulu ennyo,
\q2 naawe amazzi agali waggulu w’eggulu.
\b
\q1 
\v 5 Leka byonna bitendereze erinnya lya \nd Mukama\nd*!
\q2 Kubanga ye yalagira, ne bitondebwa.
\q1 
\v 6 Yabinywereza ddala mu bifo byabyo ennaku zonna,
\q2 n’ateekawo etteeka eritaliggwaawo.
\b
\q1 
\v 7 Mumutendereze nga musinziira ku nsi,
\q2 mmwe balukwata n’ebifo byonna eby’omu buziba bw’ennyanja,
\q1 
\v 8 mmwe okumyansa, n’omuzira ogw’amakerenda, n’omuzira ogukutte era n’olufu,
\q2 naawe kikuŋŋunta, mugondere ekiragiro kye,
\q1 
\v 9 mmwe agasozi n’obusozi,
\q2 emiti egy’ebibala n’emivule;
\q1 
\v 10 ensolo ez’omu nsiko era n’ente zonna,
\q2 ebyewalula n’ebinyonyi ebibuuka,
\q1 
\v 11 bakabaka b’ensi n’amawanga gonna,
\q2 abalangira n’abafuzi bonna ab’ensi,
\q1 
\v 12 abavubuka abalenzi n’abawala;
\q2 abantu abakulu n’abaana abato.
\b
\q1 
\v 13 Bitendereze erinnya lya \nd Mukama\nd*,
\q2 kubanga erinnya lye lyokka lye ligulumizibwa;
\q2 ekitiibwa kye kisinga byonna eby’omu nsi n’eby’omu ggulu.
\q1 
\v 14 Abantu be abawadde amaanyi,
\q2 era agulumizizza abatukuvu be,
\q2 be bantu be Isirayiri abakolagana naye.
\b
\q1 Mutendereze \nd Mukama\nd*.
\c 149
\cl Zabbuli 149
\q1 
\v 1 Mutendereze \nd Mukama\nd*!
\b
\q1 Muyimbire \nd Mukama\nd* oluyimba oluggya,
\q2 mumutenderereze wamu n’ekibiina ky’abatukuvu.
\b
\q1 
\v 2 Isirayiri asanyukirenga eyamutonda;
\q2 n’abantu ba Sayuuni bajagulize Kabaka waabwe!
\q1 
\v 3 Batenderezenga erinnya lye nga bwe bazina,
\q2 bamutenderezenga nga bwe bakuba ennanga n’ebitaasa.
\q1 
\v 4 Kubanga \nd Mukama\nd* asanyukira abantu be,
\q2 n’abawombeefu abawa engule ey’obulokozi.
\q1 
\v 5 Abatuukirivu bajagulizenga mu kitiibwa kino;
\q2 bayimbire ku bitanda byabwe olw’essanyu.
\b
\q1 
\v 6 Batenderezenga Katonda waabwe,
\q2 bakwate ekitala eky’obwogi obubiri,
\q1 
\v 7 bawoolere eggwanga,
\q2 babonereze n’amawanga,
\q1 
\v 8 bateeke bakabaka baago mu njegere,
\q2 n’abakungu baago babasibe amagulu n’ebyuma,
\q1 
\v 9 babasalire omusango ogwabawandiikirwa.
\q2 Kino kye kitiibwa ky’abatukuvu be bonna.
\b
\q1 Mutendereze \nd Mukama\nd*.
\c 150
\cl Zabbuli 150
\q1 
\v 1 Mutendereze \nd Mukama\nd*!
\b
\q1 Mutendereze Katonda mu kifo kye ekitukuvu;
\q2 mumutenderereze ne mu ggulu lye ery’amaanyi.
\q1 
\v 2 Mumutendereze olw’ebikolwa bye ebiraga amaanyi ge;
\q2 mumutendereze olw’obukulu bwe obusukkiridde.
\q1 
\v 3 Mumutendereze n’eddoboozi ery’ekkondeere,
\q2 mumutendereze n’ennanga ey’enkoba n’endere.
\q1 
\v 4 Mumutendereze n’ebitaasa n’amazina;
\q2 mumutendereze n’ebivuga eby’enkoba n’endere!
\q1 
\v 5 Mumutendereze nga mukuba ebitaasa;
\q2 mumutendereze n’ebitaasa ebivuga ennyo!
\b
\q1 
\v 6 Buli ekissa omukka kitenderezenga \nd Mukama\nd*!
\b
\q1 Mutendereze \nd Mukama\nd*.
