\v 12 Te \w dongah|strong="H9999"\w* \w amih|strong="H9908"\w* \w te|strong="H0413"\w*, “\w Kamah|strong="H9901"\w* he m'\w pom|strong="H5375"\w* uh \w lamtah|strong="H9999"\w* \w kai|strong="H9901"\w* he \w tuitunli|strong="H3220"\w* \w khuila|strong="H0413"\w* n'\w dong|strong="H2904"\w* uh laeh. Te \w vaengah|strong="H9999"\w* \w tuitunli|strong="H3220"\w* khaw \w nangmih|strong="H9904"\w* \w taeng|strong="H5921"\w* \w lamloh|strong="H4480"\w* \w paa|strong="H8367"\w* bitni. \w Kai|strong="H9901"\w* \w kong|strong="H7578"\w* \w ah|strong="H9996"\w* \w hlipuei|strong="H5591"\w* \w len|strong="H1419"\w* \w he|strong="H2088"\w* \w nangmih|strong="H9904"\w* \w soah|strong="H5921"\w* a tloh \w tila|strong="H3588"\w* \w ka|strong="H0589"\w* \w ming|strong="H3045"\w*,” a \w ti|strong="H0559"\w* nah.   
\p
\v 13 Te \w vaengah|strong="H9999"\w* \w laiphuei|strong="H3004"\w* \w dongla|strong="H0413"\w* \w mael|strong="H7725"\w* \w ham|strong="H9997"\w* \w hlang|strong="H0376"\w* rhoek loh a \w kaih|strong="H2864"\w* uh. \w Tedae|strong="H9999"\w* \w tuitunli|strong="H3220"\w* khaw \w cet|strong="H1980"\w* \w tih|strong="H9999"\w* \w amih|strong="H9908"\w* \w taengah|strong="H5921"\w* a \w thikthuek|strong="H5590"\w* pah \w dongah|strong="H3588"\w* \w noeng|strong="H3201"\w* uh \w pawh|strong="H3808"\w*.  
