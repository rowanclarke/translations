\id EST
\h إِسْثِيرْ
\toc1 إِسْثِيرْ
\toc2 إِسْثِيرْ
\toc3 إِسْت.
\mt1 إِسْثِيرْ
\c 1
\s1 ڒْعِيذْ أَمقّْرَانْ ن ؤُجدْجِيذْ أَحَاشْوِيرُوشْ
\m 
\v 1 إِمْسَارْ ذڭْ وُوسَّانْ ن أَحَاشْوِيرُوشْ - نتَّا ذ أَحَاشْوِيرُوشْ ونِّي ثُوغَا إِحكّْمنْ زِي ثمُّورْثْ ن ڒْهنْذْ أَڒْ ثَامُّورْثْ ن كُوشْ خْ مْيَا ؤُ-سبْعَا ؤُ-عِيشْرِينْ ن لْعَامَالَاثْ -
\v 2 \add وَاهْ،\add* ذڭْ وُوسَّانْ نِّي، ؤُمِي إِقِّيمْ ؤُجدْجِيذْ أَحَاشْوِيرُوشْ خْ ڒْعَارْشْ ن ثْڭلْذِيثْ نّسْ ذِي ڒقْصَارْ ن شُوشَانْ،
\v 3 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثَا ن ڒحْكَامْ نّسْ، \add أَقَا\add* إِڭَّا إِشْثْ ن زَّارْذثْ إِ مَارَّا ڒْحُوكَّامْ ذ إِمْسخَّارنْ نّسْ. ثُوغَا \add إِكُومَانْذَارنْ ن\add* ڒْعسْكَارْ ن \add ثمُّورْثْ ن\add* لْفُورْسْ ذ مَاذَايْ ؤُڒَا ذ ثَارْوَا ن ثَاصِيڒثْ ذ ڒْحُوكَّامْ ن لْعَامَالَاثْ \add تّْمُونَانْ\add* زَّاثْ إِ وُوذمْ نّسْ،
\v 4 ؤُمِي إِسّْشنْ أَڭْڒَا ن ؤُعُودْجِي ن ثْڭلْذِيثْ نّسْ ذ شَّانْ ذ ڒمْڒَاحثْ ن لْعَاضَامَا نّسْ ذڭْ وَاطَّاسْ ن وُوسَّانْ، أَقَا ذِي مْيَا ؤُ-ثْمَانْيِينْ ن وُوسَّانْ.
\v 5 \add ؤُمِي\add* عْذُونْ وُوسَّانْ نِّي، \add خنِّي\add* ثُوغَا إِسّوْجَاذْ ؤُجدْجِيذْ إِشْثْ ن زَّارْذثْ إِ مَارَّا ڒْڭنْسْ نِّي ثُوغَا \add ذِينْ\add* ذِي لْقلْعَا ن شُوشَانْ، زڭْ ؤُمقّْرَانْ أَڒْ أَمژْيَانْ، سبْعَا ن وُوسَّانْ، ذڭْ وَازَّايْ ن وحْوِيشْ ن ڒقْصَارْ ن ؤُجدْجِيذْ.
\v 6 أَقَا ذِينْ \add أَرْوَاقَاثْ\add* ذ إِشمْڒَاڒنْ ذ إِزِيزَاونْ ذ إِذهْمَاننْ مُّوذنْ س إِفِيڒَانْ ن ڒقْطنْ أَزْذَاذْ ذ \add ؤُفِيڒُو\add* أَرْجُووَانِي ڭِّينْ ثنْثْ غَارْ إِقضْبَانْ ن نُّوقَارْثْ ؤُ غَارْ إِپِيلَارنْ ن ڒْمَارْمُورْ. ڒمْطَارْبَاثْ ن وُورغْ ذ نُّوقَارْثْ \add مَّارْسنْثْ\add* خْ ثِيسِي ن زّلِّيجْ ذَايسْ \add أَژْرُو\add* أَزِيزَا أَمْ سْمَارَاخْثْ ذ \add وژْرُو\add* ذ أَشمْڒَاڒْ ذ \add وژْرُو\add* أَمْ ثْيَاقُوثْ ذ \add وژْرُو\add* ذ أَبَارْشَانْ.
\v 7 ثمّوْشْ ثْسسِّي ذِي ڒقْشُوعْ ن وُورغْ ؤُ ثُوغَا مَارَّا ڒقْشُوعْ مّْسبْضَانْ، ثَا وَارْ ثَارْوِيسْ ثَا، ؤُ ثُوغَا \add ذِينْ\add* بِينُو إِڭلّْذنْ س وَاطَّاسْ، أَنشْثْ إِ ثُوغَا إِزمَّارْ ؤُفُوسْ ن ؤُجدْجِيذْ \add أَذْ ث إِوْشْ\add*. \f ◼ \fr 1:‏7 \ft \bd ’ڒقْشُوعْ‘\bd* - إِفنْجَاڒنْ ذ إِغَارَّافنْ.\f*
\v 8 ثُوغَا سْوِينْ عْلَاحْسَابْ ڒُومُورْ، وَارْ إِدْجِي س ؤُغِيڒْ، مِينْزِي أَمُّو إِ إِوصَّا ؤُجدْجِيذْ إِ مَارَّا إِمقّْرَاننْ ن ثَادَّارْثْ نّسْ، مَاحنْذْ أَذْ ڭّنْ ڒْخَاضَارْ إِ مَارَّا.
\v 9 ثڭَّا ثْجدْجِيذْثْ وَاشْثِي ؤُڒَا ذ إِشْثْ ن زَّارْذثْ إِ ثمْغَارِينْ ذِي ثَادَّارْثْ إِڭلّْذنْ ن ؤُجدْجِيذْ أَحَاشْوِيرُوشْ.
\b
\s1 ثَاجدْجِيذْثْ وَاشْثِي ثوْضَا
\m 
\v 10 ذڭْ وَاسّْ وِيسّْ سبْعَا، ؤُمِي إِذْوڒْ وُوڒْ ن ؤُجدْجِيذْ إِفَارْحْ س بِينُو، إِنَّا إِ مَاهُومَانْ، بِيزْثَا، حَارْپُونَا، بِيغْثَا ذ أَبَاغْثَا، زِيثَارْ ذ كَارْكَاسْ، أَقَا نِيثْنِي ذ سبْعَا ن إِمْسخَّارنْ إِشنّْعنْ إِ ثُوغَا إِسخَّارنْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ أَحَاشْوِيرُوشْ،
\v 11 حِيمَا أَذْ أَوْينْ ثَاجدْجِيذْثْ وَاشْثِي زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ س تَّاجْ إِڭلّْذنْ، مَاحنْذْ أَذْ إِسّْشنْ أَژْرِي نّسْ إِ ڒڭْنُوسْ ؤُ إِ ڒْحُوكَّامْ، مِينْزِي نتَّاثْ ثُوغَا ذَايسْ أَژْرِي.
\v 12 \add مَاشَا\add* ثَاجدْجِيذْثْ وَاشْثِي ثُوڭِي أَذْ د-ثَاسْ عْلَاحْسَابْ أَوَاڒْ ن ؤُجدْجِيذْ \add نِّي ذ أَسْ د-يُوسَا\add* س ؤُفُوسْ ن إِمْسخَّارنْ إِشنّْعنْ. إِفُّوڭمْ ؤُجدْجِيذْ أَطَّاسْ ؤُشَا إِكَّارْ ذَايسْ وسْعَارْ نّسْ.
\v 13 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ إِ إِمِيغِيسنْ إِنِّي إِفهّْمنْ ڒْمِيجَاڒَاثْ ن ڒْوقْثْ - مِينْزِي أَمُّو إِ ثُوغَا ثتّْوَاڭّْ ثْمسْڒَاشْثْ ن ؤُجدْجِيذْ زَّاثْ إِ يِينِّي إِسّْننْ أَزرْفْ ؤُ ڒحْكَامْ -
\v 14 \add إِ\add* كَارْشَانَا، شِيثَارْ، أَذْمَاثَا، ثَارْشِيشْ، مَارَاسْ، مَارْسَانَا ذ مَامُوكَانْ، سبْعَا ن ڒْحُوكَّامْ ن لْفُورْسْ ذ مَاذَايْ، \add إِنِّي\add* ذ أَسنْ إِعدّڒْ مَاحنْذْ أَذْ ژَترنْ ؤُذمْ ن ؤُجدْجِيذْ ؤُ كْسِينْ إِمُوشَانْ إِمزْوُورَا ذِي ثْڭلْذِيثْ:
\v 15 ”مِينْ ذ أَنغْ إِتّْخصَّا أَذْ نڭّْ أَكْ-ذ ثْجدْجِيذْثْ وَاشْثِي عْلَاحْسَابْ ڒْقَانُونْ، مِينْزِي نتَّاثْ وَارْ ثڭِّي أَوَاڒْ ن ؤُجدْجِيذْ أَحَاشْوِيرُوشْ إِ د-إِسّكّْ س ؤُفُوسْ ن إِمْسخَّارنْ نّسْ إِشنّْعنْ؟“
\v 16 \add خنِّي\add* إِنَّا مَامُوكَانْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ ذ ڒْحُوكَّامْ: ”ثَاجدْجِيذْثْ وَاشْثِي وَارْ ثڭِّي شَا ڒْعِيبْ ذڭْ ؤُجدْجِيذْ ذ ڒْحُوكَّامْ وَاهَا، مَاشَا ؤُڒَا ذِي مَارَّا ڒْحُوكَّامْ ذ مَارَّا ڒڭْنُوسْ ذِي مَارَّا لْعَامَالَاثْ ن ؤُجدْجِيذْ أَحَاشْوِيرُوشْ.
\v 17 مِينْزِي مِينْ ثڭَّا ثْجدْجِيذْثْ أَذْ إِفّغْ غَارْ مَارَّا ثمْغَارِينْ ؤُشَا أَذْ يَارّْ إِرْيَازنْ نْسنْثْ أَذْ تّْوَاسّحْقَارنْ جَارْ ثِيطَّاوِينْ نْسنْثْ خْمِي قَّارنْثْ: ’أَجدْجِيذْ أَحَاشْوِيرُوشْ إِنَّا أَذْ سّكّنْ غَارْ ثْجدْجِيذْثْ وَاشْثِي مَاحنْذْ أَذْ د-ثَاسْ زَّاثْ إِ وُوذمْ نّسْ، مَاشَا نتَّاثْ وَارْ د-ثُوسِي شَا.‘
\v 18 \add ؤُڒَا\add* ذ ثِيمْغَارِينْ ن ڒْحُوكَّامْ ن لْفُورْسْ ذ مَاذَايْ، ثِينِّي إِسْڒَانْ إِ ثمْوَارِّيثْ ن ثْجدْجِيذْثْ، أَذْ إِنِينْثْ أَيَا أَسّْ-أَ إِ مَارَّا ڒْحُوكَّامْ ن ؤُجدْجِيذْ ؤُشَا أَمُّو إِ ذِينْ غَا يِيڒِي ؤُسحْقَارْ ذ ؤُذُوقّزْ ن وغْضَابْ أَطَّاسْ.
\v 19 مَاڒَا إِعْجبْ أَسْ ڒْحَاڒْ إِ ؤُجدْجِيذْ، أجّْ إِ-ث \add خنِّي\add* أَذْ إِسُّوفّغْ إِجّْ ن ڒُومُورْ، أَذْ ث إِزمّمْ ذِي ڒْقَاوَانِينْ ن أَيْثْ ن لْفُورْسْ ذ مَاذَايْ، مَاحنْذْ وَارْ ث تّْعدَّانْ، ؤُ وَارْ إِتّجِّي أَذْ د-ثَاسْ ثَاجدْجِيذْثْ وَاشْثِي \add عَاذْ\add* زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ أَحَاشْوِيرُوشْ ؤُشَا أجّْ أَجدْجِيذْ أَذْ إِوْشْ ثَاڭلْذَا نّسْ إِ حذْ نّغْنِي، أَذْ ثِيڒِي حْسنْ زَّايسْ.
\v 20 \add خْمِي\add* إِ غَا إِتّْوَاسڒْ ڒُومُورْ ن ؤُجدْجِيذْ نِّي إِ غَا يڭّْ ذِي مَارَّا ثَاڭلْذِيثْ نّسْ، \add ثنِّي\add* ذ ثَامقّْرَانْثْ، \add خنِّي\add* أَذْ ذوْڒنْثْ مَارَّا ثِيمْغَارِينْ أَذْ وقَّارنْثْ إِرْيَازنْ نْسنْثْ، زڭْ ؤُمژْيَانْ أَڒْ أَمقّْرَانْ.“
\v 21 ثُوغَا أَوَاڒْ-أَ ذ لمْلِيحْ ذِي ثِيطَّاوِينْ ن ؤُجدْجِيذْ ذ ڒْحُوكَّامْ ؤُشَا إِڭَّا ؤُجدْجِيذْ عْلَاحْسَابْ أَوَاڒْ ن مَامُوكَانْ.
\v 22 إِسّكّْ ثِيبْرَاثِينْ غَارْ مَارَّا لْعَامَالَاثْ ن ؤُجدْجِيذْ - إِ كُوڒْ لْعَامَالَا س ثِيرَا نّسْ ؤُ إِ كُوڒْ ڒْڭنْسْ س يِيڒسْ نّسْ - حِيمَا كُوڒْ أَرْيَازْ أَذْ يِيڒِي ذ ڒْحَاكمْ خْ ثَادَّارْثْ نّسْ ؤُشَا أَذْ إِسِّيوڒْ س يِيڒسْ ن ڒْڭنْسْ نّسْ.
\b
\b
\c 2
\s1 إِسْثِيرْ ثذْوڒْ ذ ثَاجدْجِيذْثْ ن جْذِيذْ
\m 
\v 1 أَوَارْنِي مَانْ أَيَا، ؤُمِي يَارْسَا وسْعَارْ ن ؤُجدْجِيذْ، إِذْوڒْ إِتّْخمَّامْ ذڭْ وَاشْثِي ذ مِينْ ثڭَّا ؤُ ذِي مِينْ خَاسْ إِتّْوَاڭّنْ ن ڒحْكَامْ.
\v 2 \add خنِّي\add* نَّانْ إِمْسخَّارنْ إِحُوضْرِييّنْ ن ؤُجدْجِيذْ إِ ثُوغَا إِ ذ أَسْ إِتّْسخَّارنْ: ”أجّْ أَذْ أَرْزُونْ ثِيبْڒِيغِينْ إِ ؤُجدْجِيذْ، ثِيعزْرِييِّينْ إِ ذِي إِدْجَا وژْرِي.
\v 3 أجّْ أَجدْجِيذْ أَذْ إِڭّْ إِوقَّافنْ خْ مَارَّا لْعَامَالَاثْ ن ثْڭلْذِيثْ نّسْ، أَذْ سّْمُوننْ مَارَّا ثِيبْڒِيغِينْ ثِيعزْڒِييِينْ نِّي ذِي إِدْجَا وژْرِي، غَارْ لْقلْعَا ن شُوشَانْ، غَارْ ثَادَّارْثْ ن ثمْغَارِينْ، سَاذُو إِ ثْعسَّاسْثْ ن هِيجَايْ، أَمْسخَّارْ أَمْشنّعْ ن ؤُجدْجِيذْ ونِّي ذ أَعسَّاسْ خْ ثمْغَارِينْ ؤُ أَذْ أَسنْثْ وْشنْ ثِيمسْڒَايِينْ إِ ؤُثْهلِّي ن وژْرِي.
\v 4 ثَابْڒِيغْثْ إِ غَا إِعجْبنْ إِ ؤُجدْجِيذْ أَذْ ثِيڒِي ذ ثَاجدْجِيذْثْ ذڭْ ومْشَانْ ن وَاشْثِي.“ ثُوغَا أَوَاڒْ-أَ ذ لمْلِيحْ ذِي ثِيطَّاوِينْ ن ؤُجدْجِيذْ ؤُشَا نتَّا إِڭَّا أَمُّو.
\m 
\v 5 ثُوغَا \add ذِينْ\add* إِجّْ ن ورْيَازْ ذ ؤُذَايْ ذِي لْقلْعَا ن شُوشَانْ، قَّارنْ أَسْ مُورْذَاخَايْ، مِّيسْ ن يَا‘إِرْ، مِّيسْ ن شِيمْعِي، مِّيسْ ن كِيسْ، إِجّْ ن ورْيَازْ زڭْ \add أَيْثْ ن\add* بِينْيَامِينْ.
\v 6 نتَّا إِتّْوَانْذهْ زِي ؤُرْشَالِيمْ أَكْ-ذ أَيْثْ ن لْمنْفَا نِّي د-إِوْينْ أَكْ-ذ يَاكُونْيَا، أَجدْجِيذْ ن يَاهُوذَا، إِنِّي ؤُمِي إِنْذهْ نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، ذِي لْمنْفَا. \x ◘ \xo 2:‏6 \xt 2 إِج. 24‏:‏14\x*
\v 7 ذ نتَّا ونِّي ثُوغَا إِسّيْمنْ هَاذَاسَّا، إِخْسْ أَذْ يِينِي إِسْثِيرْ، يدْجِيسْ نعمِّيسْ، مِينْزِي وَارْ غَارسْ ثُوغِي \add عَاذْ\add* بَابَاسْ نِيغْ يمَّاسْ. نتَّاثْ ثُوغَا ذ إِشْثْ ن ثبْڒِيغْثْ س إِجّْ ن وَادُّوذْ إِشُووَّارْ ؤُ ذَايسْ أَژْرِي. \add أَوَارْنِي ؤُمِي\add* إِمُّوثْ بَابَاسْ ذ يمَّاسْ، إِكْسِي ت مُورْذَاخَايْ، إِڭَّا إِ-ت ذ يدْجِيسْ.
\v 8 أَڒَامِي إِتّْوَاسّنْ وَاوَاڒْ ن ؤُجدْجِيذْ ذ ڒْقَانُونْ نّسْ ؤُشَا تّْوَاسّْمُوننْثْ أَطَّاسْ ن ثبْڒِيغِينْ ذِي لْقلْعَا ن شُوشَانْ سَاذُو إِ ثْعسَّاسْثْ ن هِيجَايْ، إِمْسَارْ بلِّي سّعْذُونْ إِسْثِيرْ عَاوذْ غَارْ ثَادَّارْثْ ن ؤُجدْجِيذْ، \add ثذْوڒْ\add* سَاذُو ثْعسَّاسْثْ ن هِيجَايْ، أَعسَّاسْ ن ثمْغَارِينْ.
\v 9 ثعْجبْ أَسْ ثَابْڒِيغْثْ ؤُ نتَّاثْ ثُوسَا أَسْ-د خْ ڒْخَاضَارْ ذِي ثِيطَّاوِينْ نّسْ. نتَّا إِقدْجقْ حِيمَا أَذْ أَسْ إِوْشْ ثِيمسْڒَايِينْ إِ ؤُثْهلِّي ن وژْرِي ذ مَاشَّا نّسْ، \add ؤُ حِيمَا أَذْ أَسْ إِوْشْ\add* ؤُڒَا ذ سبْعَا ن ثمْسخَّارِينْ ثِيمژْيَانِينْ إِتّْوَاخْضَارنْ زِي ثَادَّارْثْ ن ؤُجدْجِيذْ، ؤُشَا إِسّْمُوطِّييْ إِ-ثنْثْ غَارْ ومْشَانْ إِشْنَانْ قَاعْ ذِي ثَادَّارْثْ ن ثمْغَارِينْ.
\v 10 إِسْثِيرْ وَارْ ثْخبَّارْ شَا ڒْڭنْسْ نّسْ نِيغْ جَّاذِيرَا نّسْ، مِينْزِي مُورْذَاخَايْ إِوصَّا ت مَاحنْذْ وَارْ ث ثقَّارْ شَا.
\m 
\v 11 ثُوغَا مُورْذَاخَايْ إِڭُّورْ كُوڒْ أَسّْ زَّاثْ إِ ڒمْڒَاهْ إِ إِدْجَانْ زَّاثْ إِ ثَادَّارْثْ ن ثمْغَارِينْ مَاحنْذْ أَذْ إِسّنْ مَامّشْ ثدْجَا إِسْثِيرْ ذ مِينْ ذ أَسْ غَا إِمْسَارنْ.
\v 12 ثَابْڒِيغْثْ أَوَارْنِي ثنّغْنِي ثَاسْ أَسْ-د نُّوبثْ حِيمَا أَذْ ثَاذفْ غَارْ ؤُجدْجِيذْ أَحَاشْوِيرُوشْ، أَوَارْنِي ثنْعَاشْ ن ؤُيُورنْ \add ن ؤُزيّنْ\add* أَمْ مَامّشْ ثدْجَا ثوْصيّثْ إِ ثمْغَارِينْ، مِينْزِي أَمُّو إِ تّْوَاكمّْڒنْ وُوسَّانْ ن ؤُثْهلِّي ن وژْرِي: ستَّا ن ؤُيُورنْ س زّشْثْ ن مِيرُّو ذ ستَّا ن إِيُورنْ س ڒعْطُورْ إِتّْفُوحنْ ذ فُومَاذَاثْ إِ ثمْغَارِينْ.
\v 13 \add أَمُّو\add* د-ثُوسَا \add كُوڒْ إِشْثْ ن\add* ثبْڒِيغْثْ غَارْ ؤُجدْجِيذْ: مَارَّا مِينْ ثتَّارْ، إِمّوْشْ أَسْ مَاحنْذْ أَذْ زَّايسْ ثفّغْ زِي ثَادَّارْثْ ن ثمْغَارِينْ غَارْ ثَادَّارْثْ ن ؤُجدْجِيذْ.
\v 14 غَارْ ثْمذِّيثْ ثُوذفْ غَارْ ذَاخڒْ ؤُ غَارْ ثُوفُّوثْ ثعْقبْ-د غَارْ ثَادَّارْثْ وِيسّْ ثْنَاينْ ن ثمْغَارِينْ سَاذُو ؤُحطُّو ن شَاعَاشْغَازْ، أَمْسخَّارْ أَمْشنّعْ ن ؤُجدْجِيذْ، أَعسَّاسْ ن ثِييَّا. وَارْ د-ثعْقبْ غَارْ ؤُجدْجِيذْ، مْغِيرْ مَاڒَا ثعْجبْ أَسْ إِ ؤُجدْجِيذْ ؤُشَا ثتّْوَاڒَاغَا س يِيسمْ نّسْ.
\m 
\v 15 ڒَامِي د-ثِيوضْ نُّوبثْ ن إِسْثِيرْ، يدْجِيسْ ن أَبِيحَايِيلْ،عمِّيسْ ن مُورْذَاخَايْ، ونِّي ت يَارِّينْ ذ يدْجِيسْ، وَارْ ثتَّارْ وَالُو مْغِيرْ مِينْ إِنَّا هِيجَايْ، أَمْسخَّارْ أَمْشنّعْ ن ؤُجدْجِيذْ، أَعسَّاسْ ن ثمْغَارِينْ. ؤُ إِسْثِيرْ ثُوسَا-د خْ ڒْخَاضَارْ إِ مَارَّا وِي ت إِژْرِينْ.
\v 16 أَمُّو إِ إِوْينْ إِسْثِيرْ غَارْ ؤُجدْجِيذْ أَحَاشْوِيرُوشْ، غَارْ ثَادَّارْثْ نّسْ إِڭلّْذنْ، ذڭْ ؤُيُورْ وِيسّْعشْرَا، أَقَا-ث ذ ؤُيُورْ ن طِيبِيثْ، ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا ن ثْڭلْذَا نّسْ.
\v 17 أَجدْجِيذْ ثُوغَا إِتّخْسْ إِسْثِيرْ خْ مَارَّا ثِيمْغَارِينْ \add نّغْنِي\add* ؤُشَا نتَّاثْ ثُوفَا أَرْضَا ذ ڒحْنُونشْثْ زَّاثْ إِ وُوذمْ نّسْ كْثَارْ خْ مَارَّا ثِيعْزُورَايْ نّغْنِي. إِسَّارْسْ تَّاجْ إِڭلّْذنْ خْ ؤُزدْجِيفْ نّسْ ؤُشَا يَارَّا إِ-ت ذ ثَاجدْجِيذْثْ ذڭْ ومْشَانْ ن وَاشْثِي.
\v 18 إِڭَّا ؤُجدْجِيذْ إِشْثْ ن زَّارْذثْ ثَامقّْرَانْثْ إِ مَارَّا ڒْحُوكَّامْ نّسْ ذ إِمْسخَّارنْ نّسْ، زَّارْذثْ ن إِسْثِيرْ. إِڭَّا ڒهْنَا ذِي مَارَّا لْعَامَالَاثْ ؤُ إِوْشَا أَرِّيغَالُوثنْ عْلَاحْسَابْ ثِيزمَّارْ ن ؤُجدْجِيذْ.
\b
\s1 مُورْذَاخَايْ إِبْضڒْ أَنقِّي ن ؤُجدْجِيذْ
\m 
\v 19 خْمِي تّْوَاسّْمُوننْثْ ثِيعْزُورَايْ عَاوذْ، إِقِّيمْ مُورْذَاخَايْ غَارْ ثوَّارْثْ ن ؤُجدْجِيذْ.
\v 20 إِسْثِيرْ وَارْ ثْخبَّارْ شَا إِ جَّاذِيرَا نّسْ نِيغْ إِ ڒْڭنْسْ نّسْ، أَمْ مَامّشْ ذ أَسْ يُومُورْ مُورْذَاخَايْ، مِينْزِي إِسْثِيرْ ثُوغَا ثڭُّورْ عْلَاحْسَابْ ڒُومُورْ ن مُورْذَاخَايْ أَمْ مَامّشْ ثُوغَا ثتّڭّْ ؤُمِي ثُوغَا غَارسْ ثتّْوَاربَّا.
\v 21 ذڭْ وُوسَّانْ نِّي، أَمْ إِقِّيمْ مُورْذَاخَايْ ذِي ثوَّارْثْ ن ؤُجدْجِيذْ، ثُوغَا بِيغْثَانْ ذ ثَارَاشْ، ثْنَاينْ ن إِمْسخَّارنْ إِشنّْعنْ ن ؤُجدْجِيذْ زڭْ إِعسَّاسنْ ن ثوَّارْثْ، تّْفُوڭّْمنْ أَطَّاسْ ؤُ ثُوغَا أَرزُّونْ أَذْ سّْوِيژّْضنْ أَفُوسْ غَارْ ؤُجدْجِيذْ أَحَاشْوِيرُوشْ.
\v 22 ثَامسْڒَاشْثْ-أَ ثذْوڒْ ثتّْوَاسّنْ غَارْ مُورْذَاخَايْ ؤُشَا نتَّا إِخبَّارْ \add إِ-ت\add* إِ ثْجدْجِيذْثْ إِسْثِيرْ، ؤُشَا إِسْثِيرْ ثنَّا مَانْ أَيَا إِ ؤُجدْجِيذْ س يِيسمْ ن مُورْذَاخَايْ.
\v 23 أَرْزُونْ ذِي ثْمسْڒَاشْثْ نِّي ؤُشَا ؤُفِينْ مَانْ أَيَا ذ ثِيذتّْ. ؤُيْڒنْ ثنْ س ثْنَاينْ خْ ثحْنَاشْثْ ؤُشَا ؤُرَانْ ث ذڭْ وذْلِيسْ ن إِمزْرُوينْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ.
\b
\b
\c 3
\s1 ثَامعْمُوتْشْ ن هَامَانْ ضِيدّْ إِ وُوذَاينْ
\m 
\v 1 أَوَارْنِي مَانْ أَيَا إِكَّارْ ؤُجدْجِيذْ أَحَاشْوِيرُوشْ، إِڭَّا شَّانْ ذ أَمقّْرَانْ ذِي هَامَانْ، مِّيسْ ن هَامَّاذَاثَا، أَجَاجِي، ؤُشَا إِسّْڭعّذْ إِ-ث ؤُشَا يَارَّا ڒْكُورْسِي نّسْ سنّجْ إِ مَارَّا ڒْحُوكَّامْ نِّي غَارسْ إِدْجَانْ. \f ◼ \fr 3:‏1 \ft \bd ’أَجَاجِي‘\bd* - إِجّنْ زڭْ أَيْثْ ن أَجَاجْ.\f*
\v 2 مَارَّا إِمْسخَّارنْ ن ؤُجدْجِيذْ نِّي ثُوغَا غَارْ ثوَّارْثْ ن ؤُجدْجِيذْ، ؤُضَارنْ، قوْسنْ زَّاثْ إِ هَامَانْ، مِينْزِي أَمُّو إِ \add ث\add* يُومُورْ ؤُجدْجِيذْ. مَاشَا مُورْذَاخَايْ وَارْ إِوْضِي خْ إِفَادّنْ نّسْ ؤُ وَارْ إِبنْذِيقْ.
\v 3 نَّانْ إِمْسخَّارنْ ن ؤُجدْجِيذْ إِ إِدْجَانْ ذِي ثوَّارْثْ ن ؤُجدْجِيذْ إِ مُورْذَاخَايْ: ”مَايمِّي ثْعذِّيذْ خْ ڒُومُورْ ن ؤُجدْجِيذْ؟“
\v 4 ؤُمِي خَاسْ نَّانْ أَيَا زڭْ وَاسّْ غَارْ وَاسّْ ؤُ نتَّا وَارْ ذ أَسنْ إِسْڒِي شَا، إِمْسَارْ أَقَا نِيثْنِي خبَّارنْ \add أَيَا\add* إِ هَامَانْ حِيمَا أَذْ ژَترنْ مَا أَذْ قِّيمنْ بدّنْ أَوَاڒنْ ن مُورْذَاخَايْ \add إِ زِي إِوّثْ خْ يِيخفْ نّسْ\add*، مِينْزِي إِسَّارْڭبْ إِ-ثنْ بلِّي أَقَا نتَّا ذ ؤُذَايْ.
\m 
\v 5 \add ڒَْامِي\add* إِژْرَا هَامَانْ بلِّي مُورْذَاخَايْ وَارْ يِيوْضِي خْ إِفَادّنْ نّسْ ؤُ وَارْ ذ أَسْ إِبنْذِيقْ، إِسْعَارْ هَامَانْ س وَاطَّاسْ.
\v 6 \add مَاشَا\add* إِتّْغِيڒْ أَسْ أَيَا ذ أَسحْقَارْ مَاحنْذْ أَذْ إِسّْوِيژّضْ أَفُوسْ نّسْ غَارْ مُورْذَاخَايْ وَاهَا، مِينْزِي سِّيوْڒنْ أَكِيذسْ خْ ڒْڭنْسْ ن مُورْذَاخَايْ. س ؤُيَا يَارزُّو هَامَانْ أَذْ إِهلّكْ مَارَّا ؤُذَاينْ نِّي \add إِدْجَانْ\add* ذِي مَارَّا ثَاڭلْذِيثْ ن أَحَاشْوِيرُوشْ، ڒْڭنْسْ ن مُورْذَاخَايْ.
\v 7 ذڭْ ؤُيُورْ أَمزْوَارُو، ونِّي ذ أَيُورْ ن نِيسَانْ، ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثنْعَاشْ ن ؤُجدْجِيذْ أَحَاشْوِيرُوشْ، ڭِّينْ نِيثْنِي ’بُورْ‘، إِخْسْ. أَذْ يِينِي ’ثَاقدُّوحْثْ‘، زَّاثْ إِ وُوذمْ ن هَامَانْ، إِ كُوڒْ أَسّْ ؤُ إِ كُوڒْ أَيُورْ، أَڒْ د-إِوْضَا ثْقدُّوحْثْ خْ ؤُيُورْ وِيسّْ ثنْعَاشْ، ونِّي ذ أَيُورْ ن أَذَارْ. \f ◼ \fr 3:‏7 \ft \bd ’نِيسَانْ‘\bd* - إِخْسْ أَذْ يِينِي ’أَبْرِيلْ‘. \bd ’أَذَارْ‘\bd* - مِينْ إِخْسْ أَذْ يِينِي ’مَارْسْ‘.\f*
\v 8 \add مِينْزِي\add* إِنَّا هَامَانْ إِ ؤُجدْجِيذْ أَحَاشْوِيرُوشْ: ”أَقَا ذِينْ إِجّْ ن ڒْڭنْسْ إِمْطَارّشْ ؤُ إِتّْوَابْضَا جَارْ ڒڭْنُوسْ ذِي مَارَّا لْعَامَالَاثْ ن ثْڭلْذِيثْ نّشْ. إِزرْفَانْ نْسنْ فَارّْقنْ خْ مَارَّا ڒڭْنُوسْ ؤُ نِيثْنِي وَارْ طِّيفنْ شَا ذڭْ إِزرْفَانْ ن ؤُجدْجِيذْ. س ؤُينِّي وَارْ ذ أَسْ إِعدّڒْ إِ ؤُجدْجِيذْ أَذْ ثنْ يجّْ \add أَمُّو\add*. \f ◼ \fr 3:‏8 \ft \bd ’إِزرْفَانْ‘\bd* - نِيغْ ’ڒْقَاوَانِينْ‘.\f*
\v 9 مَاڒَا ثُوسَا أَسْ-د إِ ؤُجدْجِيذْ س ڒْخَاضَارْ، \add خنِّي\add* أَذْ أَرِينْ \add إِجّْ ن ڒُومُورْ،\add* حِيمَا أَذْ ثنْ أَردّْدْجنْ، \add خنِّي\add* نشّْ أَذْ ڭّغْ أَذْ سّْوزْنغْ إِجّْ ن ڒْقدّْ نعشْرَا-أَڒَافْ ثَالِينْثْ ن نُّوقَارْثْ، أَذْ ڭّغْ أَيَا ذڭْ إِفَاسّنْ ن يِينِّي إِ غَا إِحْضَانْ ڒْخذْمثْ، مَاحنْذْ أَذْ ث سِّيذْفنْ ذڭْ إِخَّامنْ ن ثْخُوبَايْ ن ؤُجدْجِيذْ.“
\v 10 إِكّسْ ؤُجدْجِيذْ ثَاخَاذنْثْ ن ؤُشمِّيعْ إِ زِي يَارشّمْ زڭْ \add ؤُضَاضْ ن\add* ؤُفُوسْ نّسْ ؤُشَا إِوْشَا إِ-ت إِ هَامَانْ، مِّيسْ ن هَامَّاذَاثَا، أَجَاجِي، ڒعْذُو ن وُوذَاينْ.
\v 11 إِنَّا ؤُجدْجِيذْ إِ هَامَانْ: ”نُّوقَارْثْ جِّيغْ أَشْ ت، ؤُڒَا ذ ڒْڭنْسْ، حِيمَا أَذْ زَّايسْ ثڭّذْ مِينْ ثْوَارِيذْ ذ لمْلِيحْ ذِي ثِيطَّاوِينْ نّشْ.“
\m 
\v 12 ذڭْ ؤُيُورْ أَمزْوَارُو، ذڭْ وَاسّْ نّسْ وِيسّْ ثْڒطَّاشْ، مْڒَاغَانْ إِمَارِيرنْ ن ؤُجدْجِيذْ، ؤُرَانْ مَارَّا عْلَاحْسَابْ ڒُومُورْ ن هَامَانْ إِ إِجدْجِيذنْ \add إِ إِدْجَانْ\add* سَاذُو ؤُجدْجِيذْ ؤُ إِ لْوُولَاثْ نِّي \add إِدْجَانْ\add* خْ كُوڒْ لْعَامَالَا ؤُ إِ ڒْحُوكَّامْ ن كُوڒْ ڒْڭنْسْ. نِيثْنِي ؤُرَانْ إِ كُوڒْ لْعَامَالَا س ثِيرَا نّسْ ؤُ إِ كُوڒْ ڒْڭنْسْ س إِڒسْ نّسْ. ثُوغَا \add ثَابْرَاثْ\add* ثُورَا س يِيسمْ ن ؤُجدْجِيذْ، ؤُ ثتّْوَاشمّعْ س ثْخَاذنْثْ ن ؤُشمِّيعْ ن ؤُجدْجِيذْ. \f ◼ \fr 3:‏12 \ft \bd ’إِمَارِيرنْ‘\bd* - نِيثْنِي ذ إِنِّي إِتَّارِينْ.\f*
\v 13 سّكّنْ ثِيبْرَاثِينْ أَكْ-ذ إِرقَّاسنْ ن ثَازْڒَا غَارْ مَارَّا لْعَامَالَاثْ ن ؤُجدْجِيذْ، \add حِيمَا\add* أَذْ ثحَّانْ، أَذْ نْغنْ ؤُ أَذْ هلّْكنْ مَارَّا ؤُذَاينْ، أَمْ ؤُمژْيَانْ أَمْ ؤُمقّْرَانْ، إِحنْجِيرنْ إِمژْيَاننْ ذ ثمْغَارِينْ، ذڭْ وَاسّْ ذ إِجّنْ، ذڭْ وَاسّْ وِيسّْ ثْڒطَّاشْ ن ؤُيُورْ وِيسّْ ثنْعَاشْ، ونِّي ذ أَيُورْ ن أَذَارْ، ؤُ \add خنِّي\add* أَذْ كشّْضنْ مَارَّا مِينْ غَارْسنْ ذ ثَاكشَّاضْثْ.
\v 14 ثُوغَا إِتّْخصَّا أَذْ سُّوفّْغنْ مِينْ إِدْجَانْ ذِي ثِيرَا أَمْ يِيجّْ ن ؤُزرْفْ، زڭْ إِشْثْ ن لْعَامَالَا أَڒْ ثنّغْنِي س بْطَايْطَايْ إِ مَارَّا ڒڭْنُوسْ، حِيمَا أَذْ إِڒِينْ حزّْمنْ إِ ؤُيَا ذڭْ وَاسّْ نِّي.
\v 15 فّْغنْ إِرقَّاسنْ ن ثَازْڒَا، تّْوَاشجّْعنْ س ؤُزيَّارْ س وَاوَاڒْ ن ؤُجدْجِيذْ، ؤُشَا إِتّْوَاسُّوفّغْ ؤُزرْفْ \add عَاوذْ\add* ذِي لْقلْعَا ن شُوشَانْ. ثُوغَا أَجدْجِيذْ ذ هَامَامْ قِّيمنْ سسّنْ، مَاشَا ثَانْذِينْثْ ن شُوشَانْ ثُوغَا-ت ثهْوڒْ.
\b
\b
\c 4
\s1 لْقَارَارْ ن إِسْثِيرْ
\m 
\v 1 \add ؤُمِي\add* يَارْڭبْ مُورْذَاخَايْ خْ مَارَّا مِينْ إِتّْوَاڭّنْ، إِشَارّڭْ ثْشَامِيرْ نّسْ، يَارْضْ إِشْثْ ن ثْخَانْشثْ \add إِسُّويسْ\add* إِغّضْ \add خْ ؤُزدْجِيفْ نّسْ\add* ؤُشَا إِژْوَا ذِي ڒْوسْطْ ن ثنْذِينْثْ، ثُوغَا إِسّْغُويُّو إِشْثْ ن ثْغُويِّيثْ ثجْهذْ ثَارْزڭْ.
\v 2 يِيوضْ-د أَڒْ ثَاوَّارْثْ ن ؤُجدْجِيذْ، مِينْزِي وَارْ إِعدّڒْ إِ ؤُڒَا ذ إِجّْ مَاحنْذْ أَذْ يَاذفْ غَارْ ثوَّارْثْ ن ؤُجدْجِيذْ أَمْ يَارْضْ ثْخَانْشثْ \add ن وشْضَانْ\add*.
\v 3 ذِي كُوڒْ لْعَامَالَا ذ كُوڒْ ثَانْذِينْثْ مَانِي يِيوضْ ڒُومُورْ ن ؤُجدْجِيذْ، إِڒْقفْ ؤُذَاينْ إِجّْ ن وشْضَانْ ذ أَمقّْرَانْ ذ ؤُژُومِّي ذ إِمطَّاونْ ذ إِغُويَّانْ، ؤُشَا قِّيمنْ أَطَّاسْ زَّايْسنْ ژّْڒنْ ذِي ثْخَانْشثْ ن وشْضَانْ ذ يِيغّضْ.
\m 
\v 4 ثِيمْسخَّارِينْ ثِيمژْيَانِينْ ن إِسْثِيرْ ذ إِمْسخَّارنْ نّسْ إِشنّْعنْ ؤُسِينْ-د مَاحنْذْ أَذْ ت خبَّارنْ س ؤُيَا ؤُشَا ثحْزنْ ثْجدْجِيذْثْ أَطَّاسْ. ثسّكّْ ثْشَامِيرَاثْ إِ مُورْذَاخَايْ مَاحنْذْ أَذْ ثنْثْ يَارْضْ، أَذْ إِكّسْ ثَاخَانْشثْ نّسْ \add ن وشْضَانْ\add*، مَاشَا نتَّا وَارْ ثنْثْ إِقْبِيڒْ.
\v 5 \add خنِّي\add* ثْڒَاغَا إِسْثِيرْ إِ هَاثَاخْ، إِجّْ زڭْ إِمْسخَّارنْ إِشنّْعنْ ن ؤُجدْجِيذْ، ونِّي ثُوغَا إِ ذ أَسْ إِڭَّا ؤُجدْجِيذْ ذ أَمْسخَّارْ، ؤُشَا ثُومُورْ إِ-ث خْ مُورْذَاخَايْ مَاحنْذْ أَذْ ثسّنْ مِينْ ث يُوغِينْ ذ مَايمِّي إِڭَّا أَمُّو.
\v 6 إِفّغْ هَاتَّاخْ غَارْ مُورْذَاخَايْ، غَارْ وَازَّايْ \add إِ إِدْجَانْ\add* زَّاثْ إِ ثوَّارْثْ ن ؤُجدْجِيذْ،
\v 7 ؤُشَا مُورْذَاخَايْ إِعَاوذْ أَسْ مَارَّا مِينْ ذ أَسْ إِمْسَارنْ ذ شْحَاڒْ ن نُّوقَارْثْ إِ إِوَاعذْ هَامَانْ أَذْ ث إِوْزنْ إِ إِخَّامنْ ن ثْخُوبَايْ ن ؤُجدْجِيذْ ذِي طّْوعْ ن ؤُردّدْجْ ن وُوذَاينْ.
\v 8 نتَّا إِوْشَا أَسْ إِشْثْ ن ثِيڒمْثْ ن ثِيرَا ن ؤُزرْفْ إِ إِتّْوَاسُّوفّْغنْ ذِي شُوشَانْ مَاحنْذْ أَذْ ثنْ أَردّْدْجنْ، حِيمَا أَذْ ت إِسّْشنْ إِ إِسْثِيرْ ؤُ أَذْ أَسْ يِينِي ؤُ أَذْ أَسْ يُومُورْ مَاحنْذْ أَذْ ثْرَاحْ غَارْ ؤُجدْجِيذْ أَذْ أَسْ ثْزَاوْڭْ ؤُ مَاحنْذْ أَذْ أَسْ ثتَّارْ زَّاثْ إِ وُوذمْ نّسْ ذِي طّْوعْ ن ڒْڭنْسْ نّسْ.
\v 9 يُوذفْ هَاثَاخْ ؤُشَا إِعَاوذْ أَوَاڒنْ ن مُورْذَاخَايْ إِ إِسْثِيرْ.
\v 10 ثسِّيوڒْ إِسْثِيرْ إِ هَاثَاخْ ؤُشَا ثُومُورْ إِ-ث \add أَذْ يِينِي\add* إِ مُورْذَاخَايْ:
\v 11 ”مَارَّا إِمْسخَّارنْ ن ؤُجدْجِيذْ ذ مَارَّا ڒْڭنْسْ ذِي لْعَامَالَاثْ ن ؤُجدْجِيذْ سّْننْ مْلِيحْ بلِّي مَارَّا وِي غَا يَاذْفنْ غَارْ ؤُجدْجِيذْ ذڭْ وَازَّايْ ن زَّاثْ، أَمْ وَارْ د-إِتّْوَاڒَاغَا، ذ أَرْيَازْ نِيغْ ذ ثَامْغَارْثْ \add إِ إِدْجَا\add*، أَقَا \add ذِينْ\add* خَاسْ إِجّْ ن ڒحْكَامْ وَاهَا، ذ ڒْموْثْ، مْغِيرْ مَاڒَا أَجدْجِيذْ إِسّْوِيژّضْ أَسْ أَزدْجَاضْ \add نّسْ\add* ن وُورغْ، حِيمَا أَذْ إِقِّيمْ إِدَّارْ. ثْڒَاثِينْ ن وُوسَّانْ-أَ إِ إِعْذُونْ وَارْ خَافِي د-إِڒَاغَا حذْ مَاحنْذْ أَذْ د-أَسغْ غَارْ ؤُجدْجِيذْ.“
\v 12 عَاوْذنْ نِيثْنِي أَوَاڒنْ ن إِسْثِيرْ إِ مُورْذَاخَايْ.
\v 13 \add خنِّي\add* إِنَّا مُورْذَاخَايْ، أَذْ إِنِينْ إِ إِسْثِيرْ عَاوذْ: ”وَارْ ثْخمَّامْ، أَقَا شمْ ثْزمَّارذْ أَذْ ثَاروْڒذْ ذِي ثَادَّارْثْ ن ؤُجدْجِيذْ، كْثَارْ خْ مَارَّا وُوذَاينْ نّغْنِي.
\v 14 مِينْزِي مَاڒَا شمْ ثسّغْذذْ س ثِيذتّْ ذِي ڒْوقْثْ-أَ، أَذْ ذِينْ ثِيڒِي ڒفْسَاسثْ ذ ؤُسلّكْ إِ وُوذَاينْ زڭْ وبْرِيذْ نّغْنِي، مَاشَا شمْ ذ ثَادَّارْثْ ن بَابَامْ أَذْ تّْوَاردّْدْجنْ. وِي إِسّْننْ مَا ثكْسِيذْ أَوقَّارْ إِڭلّْذنْ غَارْ  إِشْثْ ن ڒْوقْثْ أَمْ ثَانِيثَا؟“ \f ◼ \fr 4:‏14 \ft \bd ’أَبْرِيذْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَمْشَانْ‘.\f*
\v 15 \add خنِّي\add* إِنَّا إِسْثِيرْ، إِتّْخصَّا أَذْ د-أَرّنْ خْ مُورْذَاخَايْ:
\v 16 ”ؤُيُورْ، سْمُونْ مَارَّا ؤُذَاينْ إِ إِزدّْغنْ ذِي شُوشَانْ ؤُشَا ژُومّمْ أَيِي إِ نشّْ، وَارْ ثتّمْ، وَارْ ثْسسّمْ ثْڒَاثَا ن وُوسَّانْ، دْجِيڒثْ ذ وَاسّْ. ؤُڒَا ذ نشّْ ذ ثمْسخَّارِينْ إِنُو ثِيمژْيَانِينْ أَذْ ژُومّنْثْ أَمُّو، ؤُشَا خنِّي أَذْ أَذْفغْ غَارْ ؤُجدْجِيذْ مِينْ وَارْ إِشُووَّارْ عْلَاحْسَابْ أَزرْفْ. مَاڒَا فْنِيغْ، \add خنِّي\add* فْنِيغْ!“
\v 17 \add خنِّي\add* إِفّغْ مُورْذَاخَايْ ؤُشَا إِڭَّا أَمْ مَامّشْ مَارَّا مِينْ خْ إِ ذ أَسْ ثُومُورْ إِسْثِيرْ.
\b
\b
\c 5
\s1 إِسْثِيرْ ثتَّارْ أَعَاونْ ن ؤُجدْجِيذْ
\m 
\v 1 ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا، إِمْسَارْ، أَقَا إِسْثِيرْ ثْيَارْضْ أَرُّوضْ إِڭلّْذنْ ؤُشَا ثْرُوحْ ثكَّارْ ذڭْ وَازَّايْ ن ذَاخڒْ ن ثَادَّارْثْ ن ؤُجدْجِيذْ، نِيشَانْ قِيبَاتْشْ إِ ؤُجمَّاضْ ن ثَادَّارْثْ ن ؤُجدْجِيذْ. ثُوغَا أَجدْجِيذْ إِقِّيمْ خْ ڒْعَارْشْ نّسْ ذِي ثَادَّارْثْ إِڭلّْذنْ أَرنْذَاذْ ن ثوَّارْثْ ن ثَادَّارْثْ.
\v 2 \add ؤُمِي\add* إِژْرَا ؤُجدْجِيذْ ثَاجدْجِيذْثْ إِسْثِيرْ ثْبدّْ ذڭْ وَازَّايْ، إِمْسَارْ، أَقَا ثُوفَا أَرْضَا ذِي ثِيطَّاوِينْ نّسْ، أَڒَامِي إِسّڒْقَا ؤُجدْجِيذْ أَزدْجَاضْ \add نّسْ\add* ن وُورغْ إِ ثُوغَا غَارسْ ذڭْ ؤُفُوسْ نّسْ إِ إِسْثِيرْ ؤُشَا ثْقَارّبْ-د إِسْثِيرْ، ثْحَاذَا ثِيخفْثْ ن ؤُزدْجَاضْ.
\v 3 \add خنِّي\add* إِنَّا أَسْ ؤُجدْجِيذْ: ”مِينْ شمْ يُوغِينْ، \add أَ\add* ثَاجدْجِيذْثْ إِسْثِيرْ، نِيغْ مِينْ ثعْنَا ثُوثْرَا نّمْ؟ أَذْ أَمْ ثمّوْشْ، وَاخَّا ثدْجَا ذ أَزْينْ ن ثْڭلْذِيثْ!“
\v 4 ثنَّا إِسْثِيرْ: ”مَاڒَا ثُوسَا أَسْ-د إِ ؤُجدْجِيذْ س ڒْخَاضَارْ، أَقَا نتَّا أَذْ د-يَاسْ أَسّْ-أَ أَكْ-ذ هَامَانْ غَارْ زَّارْذثْ إِ ذ أَسْ سّْوجْذغْ.“
\m 
\v 5 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ: ”أَرّمْ هَامَانْ أَذْ إِقدْجقْ أَذْ إِڭّْ أَمْ مَامّشْ ثنَّا إِسْثِيرْ.“ \add ڒَْامِي\add* د-يُوسَا ؤُجدْجِيذْ أَكْ-ذ هَامَانْ غَارْ زَّارْذثْ نِّي إِ ثسّوْجذْ إِسْثِيرْ،
\v 6 إِنَّا ؤُجدْجِيذْ إِ إِسْثِيرْ ؤُمِي سْوِينْ بِينُو: ”مِينْ ذَايمْ \add إِدْجَانْ\add* ذ مژْرِي؟ أَذْ أَمْ إِمّوْشْ. مِينْ \add إِدْجَانْ\add* ذ ثُوثْرَا نّمْ؟ أَذْ غَارمْ ثِيڒِي وَاخَّا ذ أَزْينْ ن ثْڭلْذِيثْ.“
\v 7 \add خنِّي\add* ثَارَّا-د خَاسْ إِسْثِيرْ، ثنَّا: ”وَا ذ مژْرِي إِنُو ذ ثُوثْرَا إِنُو:
\v 8 مَاڒَا \add خنِّي\add* نشّْ ؤُفِيغْ أَرْضَا ذِي ثِيطَّاوِينْ ن ؤُجدْجِيذْ ؤُ مَاڒَا ثُوسَا أَسْ-د إِ ؤُجدْجِيذْ س ڒْخَاضَارْ حِيمَا أَذْ إِسِّيوضْ مژْرِي إِنُو ذ ثُوثْرَا إِنُو، أَقَا أَذْ د-يَاسْ ؤُجدْجِيذْ أَكْ-ذ هَامَانْ غَارْ زَّارْذثْ إِنُو نِّي ذ أَسْ إِ غَا سّْوجْذغْ، \add خنِّي\add* ثِيوشَّا أَذْ ڭّغْ عْلَاحْسَابْ أَوَاڒْ ن ؤُجدْجِيذْ.“
\m 
\v 9 إِفّغْ هَامَانْ ذڭْ وَاسّْ نِّي، إِفَارْحْ ؤُ ثُوغَا-ث خْ ڒْخَاذَارْ نّسْ أَطَّاسْ، مَاشَا ؤُمِي إِژْرَا هَامَانْ مُورْذَاخَايْ إِقِّيمْ ذِي ثوَّارْثْ ن ؤُجدْجِيذْ، وَارْ إِكَّارْ، وَارْ غَارسْ إِنْهزّْ، \add خنِّي\add* إِسْعَارْ هَامَانْ س وَاطَّاسْ.
\v 10 مَاشَا هَامَانْ إِثبّثْ سِيمَانْثْ نّسْ ؤُ \add ؤُمِي\add* يِيوضْ غَارْ ثَادَّارْثْ، إِجَّا أَذْ د-أَسنْ إِمدُّوكَّاڒْ نّسْ ذ زَارَاشْ، ثَامْغَارْثْ نّسْ.
\v 11 إِسِّيوڒْ هَامَانْ أَكِيذْسنْ خْ ؤُعُودْجِي ن وَاڭْڒَا نّسْ ؤُ خْ إِحْرَامنْ نّسْ إِ غَارسْ إِدْجَانْ س وَاطَّاسْ ؤُ خْ مَارَّا مِينْ زِي إِ ذ أَسْ إِشنّعْ ؤُجدْجِيذْ ؤُ ذ مَامّشْ إِ-ث إِسّْڭعّذْ سنّجْ إِ ڒْحُوكَّامْ ذ إِمْسخَّارنْ ن ؤُجدْجِيذْ.
\v 12 عَاوذْ إِنَّا هَامَانْ: ”ؤُڒَا ذ ثَاجدْجِيذْثْ إِسْثِيرْ وَارْ ثجِّي حذْ أَذْ د-يَاسْ أَكْ-ذ ؤُجدْجِيذْ غَارْ زَّارْذثْ إِ ثسّوْجذْ، مْغِيرْ نشّْ، ؤُشَا أَحقَّا ؤُڒَا ذ ثِيوشَّا تّْوَاعَارْضغْ \add جْمِيعْ\add* أَكْ-ذ ؤُجدْجِيذْ.
\v 13 مَاشَا مَانْ أَيَا مَارَّا وَارْ ذ أَيِي إِشْقِي مِينْ غَا كّغْ تّْوَاڒِيغْ مُورْذَاخَايْ، ؤُذَايْ، إِقِّيمْ ذِي ثوَّارْثْ ن ؤُجدْجِيذْ.“
\v 14 \add خنِّي\add* ثنَّا زَارَاشْ، ثَامْغَارْثْ نّسْ، جْمِيعْ أَكْ-ذ إِمدُّوكَّاڒْ نّسْ: ”أجّْ أَذْ سّْبدّنْ إِشْثْ ن ثْحنَاشْثْ \add مَانِي ث غَا أَيْڒنْ\add*، أَذْ يِيڒِي ڒُوعْڒَا نّسْ خمْسِينْ ن إِغِيڒنْ ؤُشَا غَارْ صّْبحْ أَذْ ثِينِيذْ إِ ؤُجدْجِيذْ، حِيمَا أَذْ غَارسْ أَيْڒنْ مُورْذَاخَايْ ؤُ \add خنِّي\add* أَذْ ثُويُورذْ س ڒفْرَاحثْ غَارْ زَّارْذثْ أَكْ-ذ ؤُجدْجِيذْ.“ إِتّْغِيڒْ أَسْ إِ هَامَانْ أَقَا مَانْ أَيَا ذ إِجّْ ن شّْوَارْ إِشْنَا ؤُشَا سّْبدّنْ ثَاحْنَاشْثْ ن وَايَاڒْ.
\b
\b
\c 6
\s1 شّنْعثْ إِ مُورْذَاخَايْ
\m 
\v 1 ذِي دْجِيڒثْ نِّي سِيمَانْثْ نّسْ ثُوغَا يُوڭِي أَذْ إِكّْ إِضصْ خْ ؤُجدْجِيذْ ؤُشَا إِنَّا أَذْ أَسْ د-أَوْينْ أَذْلِيسْ ن ڒِيذَارثْ ن إِمزْرُوينْ ؤُشَا غْرِينْ زَّايْسنْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ.
\v 2 إِتّْوَافْ ؤُرَانْ \add ذَايسْ\add*، أَقَا مُورْذَاخَايْ إِخبَّارْ خْ بِيغْثَانَا ذ ثَارَاشْ، ثْنَاينْ ن إِمْسخَّارنْ إِشنّْعنْ ن ؤُجدْجِيذْ، زڭْ إِعسَّاسنْ ن ثوَّارْثْ، إِنِّي ثُوغَا يَارزُّونْ أَذْ وْثنْ أَفُوسْ ن ؤُجدْجِيذْ أَحَاشْوِيرُوشْ.
\v 3 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ: ”مَانْ شَّانْ ذ ڒمْغَارثْ إِ إِتّْوَاڭّنْ إِ مُورْذَاخَايْ خْ مَانْ أَيَا؟“ إِمْسخَّارنْ إِحُوضْرِييّنْ ن ؤُجدْجِيذْ نِّي ثُوغَا إِ ذ أَسْ إِتّْسخَّارنْ، نَّانْ: ”وَارْ ذ أَسْ إِتّْوَاڭّْ وَالُو ذِي طّْوعْ نّسْ!“
\v 4 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ: ”وِي \add ذِينْ\add* بَارَّا ذڭْ وَازَّايْ؟“ هَامَانْ ثُوغَا عَاذْ مَامّشْ د-إِتَّاذفْ غَارْ وَازَّايْ ن ثَادَّارْثْ ن ؤُجدْجِيذْ \add إِ إِدْجَانْ\add* غَارْ بَارَّا قَاعْ حِيمَا أَذْ يِينِي إِ ؤُجدْجِيذْ حِيمَا أَذْ يَايڒْ مُورْذَاخَايْ غَارْ ثْحنَاشْثْ ن وَايَاڒْ، ثنِّي إِ ذ أَسْ إِسّوْجذْ.
\v 5 إِمْسخَّارنْ ن ؤُجدْجِيذْ نَّانْ أَسْ: ”أَقَا ذ هَامَانْ إِ ذَا إِبدّنْ ذڭْ وَازَّايْ.“ \add خنِّي\add* إِنَّا ؤُجدْجِيذْ: ”أجّْ إِ-ث أَذْ يَاذفْ!“
\m 
\v 6 \add خْمِي\add* يُوذفْ هَامَانْ، إِنَّا أَسْ ؤُجدْجِيذْ: ”مِينْ غَا إِتّْوَاڭّنْ أَكْ-ذ ورْيَازْ إِ ؤُمِي إِخْسْ ؤُجدْجِيذْ أَذْ ث إِشنّعْ؟“ إِخمّمْ هَامَانْ ذڭْ وُوڒْ نّسْ: ”مَانْ ونْ إِخْسْ ؤُجدْجِيذْ أَذْ إِشنّعْ كْثَارْ زَّايِي؟“
\v 7 س ؤُينِّي يَارَّا-د هَامَانْ خْ ؤُجدْجِيذْ: ”أَرْيَازْ إِ إِخْسْ ؤُجدْجِيذْ أَذْ ث إِشنّعْ،
\v 8 أَذْ أَسْ إِمّوْشْ ثْشَامِيرْ إِڭلّْذنْ إِ زِي إِنُّومْ ؤُجدْجِيذْ أَذْ يَارْضْ ؤُڒَا ذ أَيِيسْ إِ خفْ إِنُّومْ ؤُجدْجِيذْ أَذْ إِنِييْ ؤُشَا أَذْ سَّارْسنْ إِجّْ ن تَّاجْ إِڭلّْذنْ خْ ؤُزدْجِيفْ نّسْ.
\v 9 أَذْ ڭّنْ ثْشَامِيرْ ذ ؤُيِيسْ ذڭْ ؤُفُوسْ ن إِجّْ زِي ڒْحُوكَّامْ ن ؤُجدْجِيذْ، \add إِجّنْ\add* زِي ثَارْوَا ن ثَاصِيڒثْ، ؤُشَا أَذْ زَّايسْ سّْيَارْضنْ أَرْيَازْ نِّي إِ إِخْسْ ؤُجدْجِيذْ أَذْ إِشنّعْ ؤُشَا أَذْ ث سّْنذْهنْ خْ ؤُيِيسْ ذڭْ وَازَّايْ ن ثنْذِينْثْ، ؤُشَا أَذْ بَارّْحنْ: ’أَمُّو إِ غَا إِتّْوَاڭّْ أَكْ-ذ ورْيَازْ، ونِّي إِخْسْ ؤُجدْجِيذْ أَذْ ث إِشنّعْ!‘ “
\v 10 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ إِ هَامَانْ: ”قدْجقْ، كْسِي ثْشَامِيرْ ذ ؤُيِيسْ أَمْ مَامّشْ ثنِّيذْ ؤُشَا أڭّْ أَمنِّي أَكْ-ذ مُورْذَاخَايْ ونِّي إِقِّيمنْ ذِي ثوَّارْثْ ن ؤُجدْجِيذْ ؤُ وَارْ تّجِّي ؤُڒَا ذ إِجّْ ن وَاوَاڒْ أَذْ إِوْضَا زِي مَارَّا مِينْ ثسِّيوْڒذْ.“
\m 
\v 11 إِكْسِي هَامَانْ ثْشَامِيرْ ذ ؤُيِيسْ ؤُشَا إِسّْيَارْضْ مُورْذَاخَايْ س ثْشَامِيرْ ؤُ إِسّْنذْهْ إِ-ث خْ وَازَّايْ ن ثنْذِينْثْ ؤُشَا إِسّكَّارْ أَبَارّحْ قِيبَاتْشْ نّسْ: ”أَمُّو إِ غَا إِتّْوَاڭّْ أَكْ-ذ ورْيَازْ ونِّي ؤُمِي إِخْسْ ؤُجدْجِيذْ أَذْ أَسْ إِشنّعْ!‘“
\v 12 \add أَوَارْنِي أَيَا\add* إِعْقبْ مُورْذَاخَايْ عَاوذْ غَارْ ثوَّارْثْ ن ؤُجدْجِيذْ، مَاشَا هَامَانْ يُويُورْ ذغْيَا غَارْ ثَادَّارْثْ، إِحْزنْ ؤُ ثُوغَا أَزدْجِيفْ نّسْ إِڒحّفْ.
\v 13 إِعَاوذْ هَامَانْ إِ زَارَاشْ، ثَامْغَارْثْ نّسْ، ؤُ إِ مَارَّا إِمدُّوكَّاڒْ نّسْ مَارَّا مِينْ إِ ذ أَسْ إِمْسَارنْ. \add خنِّي\add* نَّانْ أَسْ إِمِيغِيسنْ نّسْ ذ زَارَاشْ، ثَامْغَارْثْ نّسْ: ”مَاڒَا مُورْذَاخَايْ، ونِّي زَّاثْ إِ وُوذمْ نّسْ ثبْذِيذْ أَذْ ثوْضِيذْ، زِي زَّارِيعثْ ن وُوذَاينْ إِ يدْجَا، وَارْ ذ أَسْ ثْزمَّارذْ، مَاشَا س ثِيذتّْ أَذْ ثوْضِيذْ زَّاثْ إِ وُوذمْ نّسْ.“
\v 14 ؤُمِي نِيثْنِي سِّيوْڒنْ عَاذْ أَكِيذسْ، ؤُسِينْ-د إِمْسخَّارنْ إِشنّْعنْ ذ ؤُجدْجِيذْ ؤُشَا قدْجْقنْ أَذْ أَوْينْ هَامَانْ غَارْ زَّارْذثْ نِّي ثسّوْجذْ إِسْثِيرْ.
\b
\b
\c 7
\s1 ڒْحُوكْمْ خْ هَامَانْ
\m 
\v 1 \add ؤُمِي\add* د-يِيوضْ ؤُجدْجِيذْ أَكْ-ذ هَامَانْ حِيمَا أَذْ سْونْ أَكْ-ذ ثْجدْجِيذْثْ إِسْثِيرْ،
\v 2 إِنَّا ؤُجدْجِيذْ، عَاوذْ ذڭْ وَاسّْ وِيسّْ ثْنَاينْ، أَكْ-ذ ثِيسِّيثْ ن بِينُو إِ إِسْثِيرْ: ”مِينْ ذَايمْ إِدْجَانْ ذ مژْرِي، \add أَ\add* ثَاجدْجِيذْثْ إِسْثِيرْ! أَذْ أَمْ إِمّوْشْ. ذ مِينْ \add إِدْجَانْ\add* ذ ثُوثْرَا نّمْ؟ أَذْ غَارمْ ثِيڒِي وَاخَّا ذ أَزْينْ ن ثْڭلْذِيثْ.“
\v 3 \add خنِّي\add* ثَارَّا-د خَاسْ ثْجدْجِيذْثْ إِسْثِيرْ، ثنَّا: ”مَاڒَا \add خنِّي\add* ؤُفِيغْ أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، \add أَ\add* أَجدْجِيذْ، ؤُ مَاڒَا ثُوسَا أَسْ-د إِ ؤُجدْجِيذْ س ڒْخَاضَارْ، أجّْ أَذْ أَيِي وْشنْ ثُوذَارْثْ إِنُو خْ مژْرِي إِنُو ؤُ ڒْڭنْسْ إِنُو خْ ثُوثْرَا إِنُو.
\v 4 مَاغَارْ نشِّينْ نمّنْزْ، نشّْ ذ ڒْڭنْسْ إِنُو، مَاحنْذْ أَذْ نتّْوَاردّدْجْ ؤُ أَذْ نتّْوَاثحَّا. مَاڒَا نمّنْزْ أَمْ يِيسمْغَانْ ذ ثِييَّا، نشّْ أَذْ سُّوسْمغْ، مِينْزِي خْ ؤُيَا ڒحْصَارثْ وَارْ ثتِّيڒِي أَنشْثْ أَڒَامِي إِشُووَّارْ أَذْ صدّْعغْ أَجدْجِيذْ.“
\v 5 \add خنِّي\add* إِسِّيوڒْ ؤُجدْجِيذْ أَحَاشْوِيرُوشْ، إِنَّا إِ ثْجدْجِيذْثْ إِسْثِيرْ: ”مِينْ إِعْنَا نتَّا ؤُ مَانِي إِدْجَا ونِّي غَارْ إِدْجَا وُوڒْ إِشُّورْ مَاحنْذْ أَذْ إِڭّْ أَمُّو؟“
\v 6 ثنَّا أَسْ إِسْثِيرْ: ”أَرْيَازْ \add نِّي\add* إِ ذ أَنغْ إِحْصَارنْ ذ ڒعْذُو \add نّغْ\add*، أَقَا ذ وَا ذ هَامَانْ أَعفَّانْ!“ \add خنِّي\add* إِنّخْڒعْ هَامَانْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ ذ ثْجدْجِيذْثْ.
\m 
\v 7 إِكَّارْ ؤُجدْجِيذْ س وسْعَارْ، إِجَّا ثِيسِّيثْ ن بِينُو ؤُشَا يُويُورْ غَارْ وحْوِيشْ ن ڒقْصَارْ. هَامَانْ إِقِّيمْ إِبدّْ مَاحنْذْ أَذْ إِحشّمْ ثَاجدْجِيذْثْ إِسْثِيرْ ذِي طّْوعْ ن ثُوذَارْثْ نّسْ، مَاغَارْ يُوشَا أَكْ-ذ ؤُجدْجِيذْ أَقَا إِعوّڒْ أَذْ أَسْ إِڭّْ ڒْغَارْ.
\v 8 \add أَڒَامِي\add* د-إِذْوڒْ إِجدْجِيذْ زڭْ وحْوِيشْ ن ڒقْصَارْ غَارْ ثَادَّارْثْ مَانِي ثدْجَا طَّابْڒَا ن بِينُو، يُوفَا هَامَانْ إِوْضَا خْ ڒمْطَارْبَاثْ إِ خْ ثُوغَا ثزّڒْ إِسْثِيرْ. \add خنِّي\add* إِنَّا ؤُجدْجِيذْ: ”ڒخُّو أَقَا إِهكّْوڒْ ؤُڒَا ذ ثَاجدْجِيذْثْ غَارِي ذِي ثَادَّارْثْ!“ قَاعْ وَارْ د-إِفِّيغْ وَاوَاڒْ زڭْ ؤُقمُّونْ ن ؤُجدْجِيذْ، أَڒَامِي ثُوغَا \add إِمْسخَّارنْ\add* ڒحّْفنْ أَسْ إِ هَامَانْ خْ ؤُغمْبُوبْ.
\v 9 حَارْپُونَا، إِجّْ زڭْ إِمْسخَّارنْ إِشنّْعنْ، إِنِّي ثُوغَا إِبدّنْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ، إِنَّا: ”أَقَا ذِينْ ثَاحْنَاشْثْ \add ن وَايَاڒْ\add*، ثنِّي إِ ثُوغَا إِڭَّا هَامَانْ إِ مُورْذَاخَايْ ونِّي ثُوغَا إِسِّيوڒْ مْلِيحْ ذڭْ ؤُجدْجِيذْ، ثْبدّْ غَارْ ثَادَّارْثْ ن هَامَانْ ؤُ ڒُوعْڒَا نّسْ خمْسِينْ ن إِغِيڒنْ.“ \add خنِّي\add* إِنَّا ؤُجدْجِيذْ: ”أَيْڒمْ غَارسْ هَامَانْ!“
\v 10 ؤُيْڒنْ هَامَانْ غَارْ ثحْنَاشْثْ إِ ثُوغَا إِڭَّا نتَّا سِيمَانْثْ نّسْ إِ مُورْذَاخَايْ ؤُشَا يَارْسَا وسْعَارْ ن ؤُجدْجِيذْ.
\b
\b
\c 8
\s1 مِينْ إِڭَّا ؤُجدْجِيذْ ذِي طّْوعْ ن وُوذَاينْ
\m 
\v 1 ذڭْ وَاسّْ نِّي أَجدْجِيذْ إِوْشَا أَسْ إِ ثْجدْجِيذْثْ إِسْثِيرْ ثَادَّارْثْ ن هَامَانْ، ڒعْذُو ن وُوذَاينْ، ؤُشَا يُوسَا-د مُورْذَاخَايْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ، مِينْزِي إِسْثِيرْ ثْخبَّارْ س مِينْزِي \add ذ أَسْ د-إِتَّاسْ\add* إِ نتَّاثْ.
\v 2 إِكّسْ-د ؤُجدْجِيذْ ثَاخَاذنْثْ نّسْ ن ؤُشمِّيعْ، ثنِّي ثُوغَا د-إِكّسْ زِي هَامَانْ ؤُشَا إِوْشَا أَسْ-ت إِ مُورْذَاخَايْ، ؤُ إِسْثِيرْ ثڭَّا مُورْذَاخَايْ خْ ثَادَّارْثْ ن هَامَانْ.
\v 3 ثسِّيوڒْ إِسْثِيرْ ثْوَاڒَا نّغْنِي أَكْ-ذ ؤُجدْجِيذْ، ثوْضَا أَسْ غَارْ إِضَارنْ، ثثْرُو ؤُ ثْحشّمْ إِ-ث مَاحنْذْ أَذْ إِسِّيڭّْوجْ ثَاعفَّانْثْ ن هَامَانْ، أَجَاجِي، ؤُڒَا ذ ثَامعْمُوتْشْ إِ ثُوغَا إِخَارّصْ ضِيدّْ إِ وُوذَاينْ.
\v 4 إِسّْوِيژّضْ ؤُجدْجِيذْ إِ إِسْثِيرْ أَزدْجَاضْ \add نّسْ\add* ن وُورغْ. \add خنِّي\add* إِسْثِيرْ ثكَّارْ، ثْبدّْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ،
\v 5 ثنَّا: ”مَاڒَا مْلِيحْ إِ ؤُجدْجِيذْ ؤُ نشّْ ؤُفِيغْ ڒْخَاضَارْ زَّاثْ إِ وُوذمْ نّسْ ؤُ مَاڒَا ثْسڭّمْ ثْمسْڒَاشْثْ-أَ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ ؤُ نشّْ ؤُذْفغْ أَسْ ذِي ڒْخَاضَارْ ذِي ثِيطَّاوِينْ نّسْ، أجّْ أَذْ أَرِينْ \add شَا\add* حِيمَا أَذْ تّْوَابضْڒنْثْ ثبْرَاثِينْ نِّي ذِي ثدْجَا ثْمعْمُوتْشْ ن هَامَانْ، مِّيسْ ن هَامَّاذَاثَا، أَجَاجِي، ثِينِّي إِ يُورَا إِ ؤُهلّكْ ن وُوذَاينْ ذِي مَارَّا لْعَامَالَاثْ ن ؤُجدْجِيذْ.
\v 6 مَاغَارْ مَامّشْ زمَّاريْ أَذْ خْزَارغْ ڒْغَارْ إِ غَا إِڒقْفنْ ڒْڭنْسْ إِنُو؟ ؤُ مَامّشْ زمَّارغْ أَذْ خْزَارغْ أَهلّكْ ن جَّاذِيرَا إِنُو؟“
\v 7 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ أَحَاشْوِيرُوشْ إِ ثْجدْجِيذْثْ إِسْثِيرْ ؤُ إِ وُوذَايْ مُورْذَاخَايْ: ”خْزَارْ، وْشِيغْ ثَادَّارْثْ ن هَامَانْ إِ إِسْثِيرْ ؤُ نتَّا س يِيخفْ نّسْ ؤُيْڒغْ ث غَارْ ثْحنَاشْثْ، مِينْزِي إِسّْوِيژّذْ أَفُوسْ نّسْ غَارْ وُوذَاينْ.
\v 8 أَذْ ثَارِيمْ كنِّيوْ \add سِيمَانْثْ نْومْ\add* س يِيسمْ ن ؤُجدْجِيذْ مِينْ إِدْجَانْ إِشْنَا ذِي ثِيطَّاوِينْ نْومْ ذِي طّْوعْ ن وُوذَاينْ. شمّْعمْ ث س ثْخَاذنْثْ ن ؤُجدْجِيذْ، مِينْزِي ثِيرَا إِ يُورَانْ س يِيسمْ ن ؤُجدْجِيذْ ؤُ شمّْعمْ ثنْثْ س ثْخَاذنْثْ ن ؤُشمِّيعْ ن ؤُجدْجِيذْ، وَارْ إِزمَّارْ حذْ أَذْ ثنْثْ إِبْضڒْ.“
\m 
\v 9 \add خنِّي\add* تّْوَاڒَاغَانْ إِمَارِيرنْ ن ؤُجدْجِيذْ، ذڭْ وَاسّْ نِّي، ذڭْ ؤُيُورْ وِيسّْ ثْڒَاثَا، ونِّي ؤُمِي \add قَّارنْ أَسْ\add* أَيُورْ ن سِيوَانْ، ذڭْ \add وَاسّْ\add* وِيسّْ ثْڒَاثَا ؤُ-عِيشْرِينْ زَّايسْ، ؤُشَا ؤُرَانْ أَمْ مَامّشْ مَارَّا مِينْ يُومُورْ مُورْذَاخَايْ، \add أَقَا ؤُرَانْ\add* ث إِ وُوذَاينْ، إِ إِجدْجِيذنْ \add إِ إِدْجَانْ\add* سَاذُو إِ ؤُجدْجِيذْ ؤُ إِ لْوُولَاثْ ؤُ إِ ڒْحُوكَّامْ ن لْعَامَالَاثْ، زِي ڒْهنْذْ أَڒْ كُوشْ، مْيَا ؤُ-سبْعَا ؤُ-عِيشْرِينْ ن لْعَامَالَاثْ، \add إِ\add* كُوڒْ لْعَامَالَا س ثِيرَا نّسْ ؤُ \add إِ\add* كُوڒْ ڒْڭنْسْ س يِيڒسْ نّسْ ؤُ \add عَاوذْ\add* إِ وُوذَاينْ س ثِيرَا نْسنْ ؤُ س يِيڒسْ نْسنْ.
\v 10 إِتّْوَارِي س يِيسمْ ن ؤُجدْجِيذْ أَحَاشْوِيرُوشْ ؤُ ثتّْوَاشمّعْ \add ثبْرَاثْ\add* س ثْخَاذنْثْ ن ؤُشمِّيعْ ن ؤُجدْجِيذْ ؤُشَا سّكّنْ ثِيبْرَاثِينْ نِّي أَكْ-ذ إِرقَّاسنْ ن ثَازْڒَا خْ ييْسَانْ، نْيِينْ خْ ييْسَانْ ن ثَازْڒَا إِڭلّْذنْ ن جَّاذِيرَا إِشْنَانْ قَاعْ.
\v 11 \add ذِي ثبْرَاثِينْ نِّي\add* إِوْشَا ؤُجدْجِيذْ \add تّسْرِيحْ\add* إِ وُوذَاينْ مَاحنْذْ أَذْ مُوننْ ذِي كُوڒْ ثَانْذِينْثْ إِ ذِي دْجَانْ، أَذْ كَّارنْ ذِي طّْوعْ ن ثُوذَارْثْ نْسنْ، حِيمَا أَذْ أَردّْدْجنْ، أَذْ نْغنْ ؤُ أَذْ ثحَّانْ كُوڒْ ڒْعسْكَارْ زِي ڒْڭنْسْ ذ لْعَامَالَا نِّي ثنْ إِ غَا إِحْصَارنْ، ؤُڒَا ذ إِحنْجِيرنْ إِمژْيَاننْ ذ ثمْغَارِينْ، ؤُ حِيمَا أَذْ طّْفنْ مِينْ زَّايْسنْ،
\v 12 \add ذ مَانْ أَيَا\add* ذڭْ وَاسّْ ذ إِجّنْ ذِي مَارَّا لْعَامَالَاثْ ن ؤُجدْجِيذْ أَحَاشْوِيرُوشْ، ذڭْ \add وَاسّْ\add* وِيسّْ ثْڒطَّاشْ ن ؤُيُورْ وِيسّْ ثنْعَاشْ، أَقَا-ث ذ أَيُورْ ن أَذَارْ.
\v 13 ثُوغَا إِتّْخصَّا أَذْ ثتّْوَاسُّوفّغْ إِشْثْ ن ثِيڒمْثْ ن ثِيرَا-يَا أَمْ ؤُزرْفْ ذِي مَارَّا لْعَامَالَاثْ مَاحنْذْ أَذْ إِتّْوَاسَّارْڭبْ إِ مَارَّا ڒڭْنُوسْ، أَقَا ؤُذَاينْ أَذْ إِڒِينْ حزّْمنْ ذڭْ وَاسّْ نِّي حِيمَا أَذْ نْثَاقْمنْ زِي ڒْعذْيَانْ نْسنْ.
\v 14 إِرقَّاسنْ ن ثَازْڒَا، إِنِّي ينْيِينْ خْ ييْسَانْ ن ثَازْڒَا إِڭلّْذنْ، فّْغنْ ذغْيَا، تّْوَاشجّْعنْ س ؤُزيَّارْ س وَاوَاڒْ ن ؤُجدْجِيذْ. إِتّْوَاسُّوفّغْ ؤُزرْفْ عَاوذْ ذِي لْقلْعَا ن شُوشَانْ.
\v 15 خَاسْ ؤُشَا إِفّغْ-د مُورْذَاخَايْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ ذڭْ ؤُسڒْهَامْ إِڭلّْذنْ \add ن ؤُفِيڒُو\add* أَذهْمَانِي ذ ؤُشمْڒَاڒْ ؤُ س إِجّْ ن تَّاجْ ذ أَمقّْرَانْ ن وُورغْ ذ ؤُسڒْهَامْ ن ڒقْطنْ أَزْذَاذْ ذ ؤُفِيڒُو أَرْجُووَانِي، ؤُشَا ثَانْذِينْثْ ن شُوشَانْ نڭْزنْ ذَايسْ إِوْذَانْ س ڒفْرَاحثْ.
\v 16 ؤُذَاينْ ثُوغَا غَارْسنْ ثْفَاوْثْ ذ ڒفْرَاحثْ، ذ وَارْشُوقْ ذ شَّانْ.
\v 17 ذِي كُوڒْ لْعَامَالَا ؤُ ذِي كُوڒْ ثَانْذِينْثْ مَانِي مَا د-يِيوضْ وَاوَاڒْ ن ؤُجدْجِيذْ ذ ؤُزرْفْ نّسْ، ثُوغَا ذِينْ ڒفْرَاحثْ ذ وَارْشُوقْ جَارْ وُوذَاينْ ذ زّْرُوذْ ذ وُوسَّانْ إِصبْحنْ ؤُ وَاطَّاسْ زِي ڒڭْنُوسْ ن ثمُّورْثْ ذوْڒنْ ذ ؤُذَاينْ، مِينْزِي ثوْضَا-د خَاسنْ ثِيڭّْوُوذِي زڭْ وُوذَاينْ.
\b
\b
\c 9
\s1 أَنْقَامْ ن وُوذَاينْ خْ ڒْعذْيَانْ نْسنْ
\m 
\v 1 ذڭْ ؤُيُورْ وِيسّْ ثنْعَاشْ، ونِّي ذ أَيُورْ ن أَذَارْ، ذڭْ وَاسّْ وِيسّْ ثْڒطَّاشْ زڭْ ؤُيُورْ نِّي، ؤُمِي د-ثِيوضْ \add ڒْوقْثْ\add* إِ ذِي ثُوغَا أَذْ ڭّنْ أَوَاڒْ ن ؤُجدْجِيذْ ذ ؤُزرْفْ نّسْ، ذڭْ وَاسّْ إِ ذِي ثُوغَا تّْرَاجَانْ ڒْعذْيَانْ ن وُوذَاينْ أَذْ خَاسنْ مّنْضَارنْ، ثُوغَا ڒْحَاڒْ س ڒْعكْسْ، مَاغَارْ ؤُذَاينْ مّنْضَارنْ خْ يِينِّي ثنْ إِشَارْهنْ.
\v 2 سّْمُوننْ ؤُذَاينْ ذِي ثْندَّامْ نْسنْ ذِي مَارَّا لْعَامَالَاثْ ن ؤُجدْجِيذْ أَحَاشْوِيرُوشْ، مَاحنْذْ أَذْ وْثنْ إِنِّي ثُوغَا إِتّخْسنْ أَذْ ذَايْسنْ ڭّنْ ڒْغَارْ، ؤُشَا ؤُڒَا ذ إِجّْ إِزمَّارْ أَذْ إِقِّيمْ إِبدّْ زَّاثْسنْ، مِينْزِي مَارَّا ڒڭْنُوسْ ثُوغَا فشْڒنْ س ثِيڭّْوُوذِي زڭْ وُوذَاينْ.
\v 3 مَارَّا ڒْحُوكَّامْ ن لْعَامَالَاثْ ذ إِجدْجِيذنْ \add إِ إِدْجَانْ\add* سَاذُو ؤُجدْجِيذْ ذ لْوُولَاثْ ذ إِمْسخَّارنْ ن ؤُجدْجِيذْ وْشِينْ أَفُوسْ إِ وُوذَاينْ، مِينْزِي ثِيڭّْوُوذِي ن مُورْذَاخَايْ ثوْضَا خَاسنْ،
\v 4 مِينْزِي مُورْذَاخَايْ ثُوغَا غَارسْ شَّانْ ذِي ثَادَّارْثْ ن ؤُجدْجِيذْ ؤُشَا ڒخْبَارْ نّسْ إِفّغْ غَارْ مَارَّا لْعَامَالَاثْ، مِينْزِي أَرْيَازْ مُورْذَاخَايْ ثُوغَا صُّولْطَا نّسْ ثَارنِّي عَاذْ.
\v 5 غڒْبنْ وُوذَاينْ مَارَّا ڒْعذْيَانْ نْسنْ أَمْ ثنْ شَّاثنْ س سِّيفْ، س ونْغَايْ ذ ؤُهلّكْ. ڭِّينْ أَكْ-ذ يِينِّي ثنْ إِشَارّْهنْ أَمْ مَامّشْ خْسنْ نِيثْنِي.
\v 6 ذِي لْقلْعَا ن شُوشَانْ نْغِينْ ؤُ هلّْكنْ ؤُذَاينْ خمْسَا-مْيَا ن يرْيَازنْ.
\v 7 \add ؤُڒَا ذ\add* فَارْشَانْذَاثَا ذ ذَالْفُونْ ذ أَشْفَاثْ
\v 8 ذ فُورَاثَا ذ أَذَالْيَا ذ أَرِيذَاثَا
\v 9 ذ فَارْمَاشْثَا ذ أَرِيسَايْ ذ أَرِيذَايْ ذ وَايْزَاثَا،
\v 10 عشْرَا ن إِحنْجِيرنْ ن هَامَانْ، مِّيسْ ن هَامَاذَاثْ، ڒعْذُو ن وُوذَاينْ، نْغِينْ ثنْ، مَاشَا وَارْ سّْوِيژّْضنْ شَا إِفَاسّنْ نْسنْ غَارْ ثْكشَّاضْثْ.
\v 11 ذڭْ وَاسّْ نِّي ذ إِجّْ إِوْينْ-د قدَّا ن إِمتَّانْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ ذِي لْقلْعَا ن شُوشَانْ.
\v 12 إِنَّا ؤُجدْجِيذْ إِ ثْجدْجِيذْثْ إِسْثِيرْ: ”ذِي لْقلْعَا ن شُوشَانْ ؤُذَاينْ نْغِينْ ؤُ هلّْكنْ خمْسَا-مْيَا ن يرْيَازنْ ؤُڒَا ذعشْرَا ن إِحنْجِيرنْ ن هَامَانْ. مِينْ غَا يِيڒِي ڭِّينْ \add عَاذْ\add* ذِي لْعَامَالَاثْ نّغْنِي ن ؤُجدْجِيذْ؟ مِينْ ذِينْ \add عَاذْ\add* غَارمْ ذ أَسِيثمْ؟ أَذْ أَمْ إِمّوْشْ! مِينْ ثسِّيثِيمذْ؟ أَذْ غَارمْ يِيڒِي!“
\v 13 \add خنِّي\add* ثنَّا إِسْثِيرْ: ”مَاڒَا مْلِيحْ إِ ؤُجدْجِيذْ، أجّْ أَذْ إِمّوْشْ تّسْرِيحْ إِ وُوذَاينْ \add إِ إِدْجَانْ\add* ذِي شُوشَانْ ؤُڒَا ذ ثِيوشَّا مَاحنْذْ أَذْ ڭّنْ عْلَاحْسَابْ أَزرْفْ ن وَاسّْ-أَ، ؤُشَا أجّْ أَذْ أَيْڒنْعشْرَا ن إِحنْجِيرنْ ن هَامَانْ غَارْ ثحْنَاشْثْ.“
\v 14 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ مَاحنْذْ أَذْ ڭّنْ أَمنِّي. \add ڒخْذنِّي\add* إِتّْوَاسُّوفّغْ-د إِجّْ ن ؤُزرْفْ ذِي شُوشَانْ ؤُشَا ؤُيْڒنْعشْرَا ن إِحنْجِيرنْ ن هَامَانْ.
\v 15 ؤُذَاينْ نِّي \add إِدْجَانْ\add* ذِي شُوشَانْ، مُوننْ عَاوذْ ذڭْ وَاسّْ وِيسّْ أَرْبعْطَاشْ ن ؤُيُورْ ن أَذَارْ ؤُشَا نْغِينْ ثڒْثْ-مْيَاثْ ن يرْيَازنْ، مَاشَا وَارْ سّْوِيژّْضنْ شَا إِفَاسّنْ نْسنْ غَارْ ثْكشَّاضْثْ.
\v 16 مُوننْ عَاوذْ وُوذَاينْ نّغْنِي ذِي لْعَامَالَاثْ ن ؤُجدْجِيذْ حِيمَا أَذْ كَّارنْ ذِي طّْوعْ ن ثُوذَارْثْ نْسنْ ؤُ حِيمَا أَذْ طّْفنْ ڒهْنَا زِي غَارْ ڒْعذْيَانْ نْسنْ. نْغِينْ خمْسَا ؤُ-سبْعِينْ-أَڒفْ ن يرْيَازنْ جَارْ إِنِّي ثنْ إِشَارّْهنْ، مَاشَا وَارْ سّْوِيژّْضنْ شَا إِفَاسّنْ نْسنْ غَارْ ثْكشَّاضْثْ.
\b
\s1 أَڒقّمْ ن ڒْعِيذْ ن ’بُورِيمْ‘
\m 
\v 17 مَانْ أَيَا إِمْسَارْ ذڭْ وَاسّْ وِيسّْ ثْڒطَّاشْ ن ؤُيُورْ ن أَذَارْ ؤُ ذڭْ \add وَاسّْ\add* وِيسّْ أَرْبعْطَاشْ زَّايسْ أَريّْحنْ ؤُشَا ڭِّينْ ث ذ إِجّْ ن وَاسّْ ن زَّارْذثْ ذ ڒفْرَاحثْ.
\v 18 ؤُذَاينْ نِّي \add إِدْجَانْ\add* ذِي شُوشَانْ، مُوننْ ذڭْ \add وَاسّْ\add* وِيسّْ ثْڒطَّاشْ \add ن ؤُيُورْ\add* ؤُڒَا ذڭْ \add وَاسّْ\add* وِيسّْ أَرْبعْطَاشْ ؤُشَا نِيثْنِي أَريّْحنْ ذڭْ وَاسّْ وِيسّْ خمّسْطَاشْ ؤُشَا ڭِّينْ ث ذ إِجّْ ن وَاسّْ ن زَّارْذثْ ذ ڒفْرَاحثْ.
\v 19 خْ ؤُيَا ؤُذَاينْ، إِنِّي \add إِدْجَانْ\add* ذِي ڒْكَامْپُو، إِنِّي إِزدّْغنْ ذڭْ ثْندَّامْ بْڒَا ڒحْيُوضْ، ڭِّينْ أَسّْ وِيسّْ أَرْبعْطَاشْ ن ؤُيُورْ ن أَذَارْ ذ إِجّْ ن وَاسّْ ن ڒفْرَاحثْ ذ زَّارْذثْ ذ ڒْخَارْ، \add أَسّْ\add* إِ ذِي سّكَّانْ أَرِّيغَالُوثْ إِجّْ إِ ونّغْنِي.
\v 20 إِزمّمْ مُورْذَاخَايْ إِمزْرُوينْ-أَ ؤُشَا إِسّكّْ ثِيبْرَاثِينْ إِ مَارَّا ؤُذَاينْ نِّي \add إِدْجَانْ\add* ذِي مَارَّا لْعَامَالَاثْ ن ؤُجدْجِيذْ أَحَاشْوِيرُوشْ، إِ يِينِّي \add إِدْجَانْ\add* يُوذْسنْ ذ إِنِّي \add إِدْجَانْ\add* إِڭّْوجنْ،
\v 21 مَاحنْذْ أَذْ ثنْ أَرّنْ أَذْ حْضَانْ أَسّْ وِيسّْ أَرْبعْطَاشْ ن ؤُيُورْ ن أَذَارْ ؤُڒَا ذ وَاسّْ وِيسّْ خمّسْطَاشْ \add زَّايسْ\add* زڭْ ؤُسڭّْوَاسْ أَڒْ أَسڭّْوَاسْ \add نّغْنِي\add*
\v 22 - عْلَاحْسَابْ ؤُسَّانْ إِ ذِي طّْفنْ ؤُذَاينْ أَرَّاحثْ زِي ڒْعذْيَانْ نْسنْ، ؤُ \add عْلَاحْسَابْ\add* أَيُورْ نِّي ثُوغَا \add إِ ذ أَسنْ\add* إِبدّْڒنْ زِي ڒحْزنْ غَارْ رفْرَاحثْ ؤُ زڭْ وشْضَانْ غَارْ وَاسّْ أَصبْحَانْ - حِيمَا أَذْ ثنْ أَرّنْ ذ ؤُسَّانْ ن زَّارْذثْ ذ ڒفْرَاحثْ ؤُ \add حِيمَا\add* كُوڒْ إِجّْ أَذْ إِسّكّْ أَغِيرَالُوثْ إِ ونّغْنِي ؤُ \add حِيمَا\add* أَذْ وْشنْ إِ إِمزْڒَاضْ.
\v 23 قبْڒنْ وُوذَاينْ مِينْ بْذَانْ أَذْ ضْفَارنْ \add عَاذْ\add* ؤُ مِينْ ذ أَسنْ يُورَانْ \add س ؤُفُوسْ\add* ن مُورْذَاخَايْ،
\v 24 مِينْزِي هَامَانْ، مِّيسْ ن هَامَاذَاثَا، أَجَاجِي، ڒعْذُو ن مَارَّا ؤُذَاينْ، ثُوغَا إِتّْخَارّصْ إِجّْ ن ونْوَايْ ضِيدّْ إِ وُوذَاينْ مَاحنْذْ أَذْ ثنْ إِهلّكْ، ؤُ نتَّا ثُوغَا إِنْضَارْ ’بُورْ‘، أَقَا-ث ذ ثَاقدُّوحْثْ، حِيمَا أَذْ ثنْ يَاردّدْجْ ؤُ أَذْ ثنْ إِهلّكْ.
\v 25 \add مَاشَا\add* ؤُمِي د-ثُوسَا \add إِسْثِيرْ\add* زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ، يُومُورْ نتَّا س ثِيرَا مَاحنْذْ أَذْ يَارّْ خْ ؤُزدْجِيفْ نّسْ أَنْوَايْ-أَ ذ أَعفَّانْ، ثنِّي ثُوغَا إِخَارّصْ ضِيدّْ إِ وُوذَاينْ، ؤُشَا ؤُيْڒنْ ث، نتَّا ذ إِحنْجِيرنْ نّسْ، غَارْ ثحْنَاشْثْ. \x ◘ \xo 9:‏25 \xt إِسْت. 8‏:‏8\x*
\v 26 خْ ؤُيَا ڒَاغَانْ ؤُسَّانْ-أَ ’بُورِيمْ‘، زڭْ إِسمْ ن ’بُورْ‘. خْ ؤُيَا، زِي سِّيبّثْ ن وَاوَاڒنْ ن ثبْرَاثْ-أَ ؤُ \add زِي سِّيبّثْ ن\add* مِينْ ژْرِينْ س يِيخفْ نْسنْ زِي مَانْ أَيَا ؤُ \add زِي سِّيبّثْ ن\add* مِينْ ذ أَسْ إِمْسَارنْ،
\v 27 كَّارنْ أَذْ حْضَانْ ؤُسَّانْ-أَ ؤُشَا قبْڒنْ وُوذَاينْ إِ يِيخفْ نْسنْ ؤُ إِ زَّارِيعثْ نْسنْ ؤُ إِ مَارَّا إِنِّي غَارْسنْ د-إِقّْننْ، مَاحنْذْ وَارْ سّْعدُّونْ شَا أَذْ حْضَانْ ثْنَاينْ ن وُوسَّانْ-أَ أَمْ مَامّشْ يُورَا ؤُ عْلَاحْسَابْ ڒْوقْثْ إِ غَارْسنْ إِتّْوَاڭّنْ إِ كُوڒْ أَسڭّْوَاسْ، \f ◼ \fr 9:‏27 \ft \bd ’ثَارْوَا‘\bd* - س ثْعِيبْرَانِيثْ ’زَّارِيعثْ‘.\f*
\v 28 ؤُشَا أَذْ إِذَارنْ ؤُ أَذْ حْضَانْ ؤُسَّانْ-أَ ذِي كُوڒْ جِّيڒْ، ذِي كُوڒْ ڒَادْجْ، ذِي كُوڒْ لْعَامَالَا ؤُ ذِي كُوڒْ ثَانْذِينْثْ ؤُ وَارْ سّْعدُّونْ شَا ؤُسَّانْ-أَ ن بُورِيمْ جَارْ وُوذَاينْ ؤُ وَارْ إِتّتّْوَاڭّْ ؤُنڭَّارْ غَارْ ڒِيذَارثْ نْسنْ س زَّارِيعثْ نْسنْ.
\v 29 ثُورَا ثْجدْجِيذْثْ إِسْثِيرْ، يدْجِيسْ ن أَبِيحَايِيلْ، \add إِشْثْ ن ثْوَاڒَا نّغْنِي جْمِيعْ\add* أَكْ-ذ وُوذَايْ مُورْذَاخَايْ، س مَارَّا ثِيزمَّارْ \add نْسنْ\add*، حِيمَا أَذْ ڭّنْ أَسشْنِي ذِي ثبْرَاثْ-أَ وِيسّْ ثْنَاينْ خْ \add ثْمسْڒَاشْثْ ن\add* بُورِيمْ.
\v 30 إِسّكّْ ثِيبْرَاثِينْ إِ مَارَّا ؤُذَاينْ ذِي مْيَا ؤُ-سبْعَا ؤُ-عِيشْرِينْ ن لْعَامَالَاثْ ن ثْڭلْذِيثْ ن أَحَاشْوِيرُوشْ، \add جْمِيعْ\add* أَكْ-ذ وَاوَاڒنْ ن ڒهْنَا ذ ڒَامَانْ،
\v 31 حِيمَا أَذْ نيّْشنْ ؤُسَّانْ-أَ ن بُورِيمْ ذِي ڒْوقْثْ نْسنْ إِتّْوَاڭّنْ، أَمْ مَامّشْ ذ أَسنْ يُومُورْ وُوذَايْ مُورْذَاخَايْ، \add جْمِيعْ\add* أَكْ-ذ ثْجدْجِيذْثْ إِسْثِيرْ، ؤُ أَمْ مَامّشْ ڭِّينْ خْ يِيخفْ نْسنْ ؤُ خْ زَّارِيعثْ نْسنْ، \add أَكْ-ذ\add* ڒُومُورَاثْ خْ ؤُژُومِّي ذ ؤُوطُّو نْسنْ ن ؤُڭجْذُورْ.
\v 32 خْ ڒُومُورْ ن إِسْثِيرْ بدّنْ وَاوَاڒنْ-أَ خْ \add ڒْْعِيذْ ن\add* بُورِيمْ ؤُشَا مَانْ أَيَا إِتّْوَارَا ذڭْ إِجّْ ن وذْلِيسْ.
\b
\b
\c 10
\s1 ڒمْغَارثْ ثَامقّْرَانْثْ ن مُورْذَاخَايْ
\m 
\v 1 إِڭَّا ؤُجدْجِيذْ أَحَاشْوِيرُوشْ ضَّارِيبَا خْ \add يِينِّي سَاذُو نّسْ\add* ذِي ثمُّورْثْ ؤُ ذِي ثڭْزِيرِينْ نْ ڒبْحَارْ.
\v 2 مَارَّا مِينْ إِڭَّا \add مُورْذَاخَايْ\add* ن جّهْذْ ذ ثْزمَّارْ ؤُڒَا ذ أَبَارّحْ خْ ڒمْغَارثْ ن مُورْذَاخَايْ، ونِّي ذ أَسْ إِوْشِينْ ؤُجدْجِيذْ إِجّْ ن شَّانْ إِمْغَارْ، مَا وَارْ ثنْ ؤُرِينْ ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن مَاذَايْ ذ لْفُورْسْ؟
\v 3 مِينْزِي ثُوغَا مُورْذَاخَايْ ذ ونِّي وِيسّْ ثْنَاينْ أَوَارْنِي إِ ؤُجدْجِيذْ أَحَاشْوِيرُوشْ، ؤُشَا ثُوغَا-ث ذ أَمقّْرَانْ جَارْ وُوذَاينْ ؤُ أَطَّاسْ زڭْ أَيْثْمَاسْ أَرْضَانْ زَّايْسنْ ؤُ نتَّا ثُوغَا يَارزُّو مِينْ إِدْجَانْ حْسنْ إِ ڒْڭنْسْ نّسْ ؤُ ثُوغَا إِسَّاوَاڒْ س ڒْخَارْ خْ مَارَّا إِنِّي ن ڒْڭنْسْ نّسْ. 
