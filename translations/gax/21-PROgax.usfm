\q2 balchaan ammoo adde'ee hin tacho'u. 
\q1  
\v 4 Niitiin qalbeeffattuun dhirsa ifiitiif akka kallachaa ti; 
\q2 ta isa qaanessitu ammoo 
\q2 akka dhukkuba lafee nyaatuu ti. 
\q1  
\v 5 Yaadi worra balcha'aa yaada haqaa ti; 
\q2 gorsi worra hama'aa ammoo nama soba. 
\q1  
\v 6 Jechi nama hama'aa dhiiga dhangalaasiisa; 
\q2 jechi nama balcha'aa ammoo 
\q2 dhiiga dhangalaasiisa jalaa baasa. 
\q1  
\v 7 Namooti hamaaleyyiin hin badan; 
\q2 deebi'aneelle hin dhaggamanu. 
\q2 Maatiin worra balcha'aa ammoo 
\q2 jabaattee dhaabbatti. 
\q1  
