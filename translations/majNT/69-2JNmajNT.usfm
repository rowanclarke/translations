\id 2JN Mazatec of Jalapa de Díaz 
\h Xu̱ju̱n xi ma joho xi kits'ínntu nda̱ postru̱ Jua 
\toc1 Xu̱ju̱n xi ma joho xi kits'ínntu nda̱ postru̱ Jua 
\toc2 Xu̱ju̱n xi ma joho xi kits'ínntu nda̱ postru̱ Jua 
\toc3 2 Jn. 
\mt1 Xu̱ju̱n xi ma joho xi kits'ínntu nda̱ postru̱ Jua 
\c 1  
\s1 B'i̱ ts'ín kikjaniñaha̱ Jua xu̱ta̱ ni̱nku̱ 
\p  
\v 1 An xi nda̱cháha̱ xu̱ta̱ ni̱nku̱ títs'inkjínu̱u xu̱ju̱i̱n jun xu̱ta̱ ni̱nku̱ xi j'ájinnu̱u Nti̱a̱ná, xi tjona a̱t'aha̱ tintsu̱ba̱jián ni xi na̱xu̱ tjín. Ko̱ najmi tu̱ nku an xi tjoho̱ jun. Ko̱ ní ta̱ tjoho̱ jun ngayjee̱ xu̱ta̱ xi ja mankjihi̱n ni xi na̱xu̱ tjín.  
\v 2 A̱t'aha̱ ni xi na̱xu̱ tjín tíjñajin tehe̱nte ani̱ma̱ná ko̱ tu̱ nku s'e̱jñajihínná tu̱ nkjéhé ni. 
\p  
\v 3 Katsjánu̱u kju̱a̱nda ko̱ kju̱a̱jyu ko̱ katuma ni̱ma̱ha̱ jun Nti̱a̱ Na̱'miná ko̱ Nda̱ Nti̱a̱ná Jesucristo̱ xi Ntíhi̱ Nti̱a̱ Na̱'miná. Kats'ínts'ejíhi̱nnu̱u ni xi na̱xu̱ tjín ko̱ kju̱a̱tjo. 
\s1 B'i̱ ts'ín tsakúya Jua nga n'e̱tjáá xi̱nki̱á 
\p  
\v 4 Tsjo ṉkjún kamana nk'ie nga kikie k'u̱a̱ xu̱ta̱ ts'a̱jun xi tíi̱ncha ts'ín ni xi na̱xu̱ tjín, xi nkú ts'ín y'éjña Nti̱a̱ Na̱'miná.  
\v 5 Ko̱ nd'a̱i̱ já nts'ena̱, tíbankinu̱u nga b'i̱ ngján n'e̱tjáá xinki̱á. Ni xi tíb'et'ánu̱u nd'a̱i̱, najmi a̱s'a̱i tíb'éjñahá Nti̱a̱ná. Xi nkú níhi nga tuts'ihi̱n ni kin'ekjóho̱on ni xu'bi̱.  
\v 6 Kju̱a̱tjo 'mihi̱ nga n'e̱e ni xi y'éjña Nti̱a̱ná. ¿Mí nihi xi y'éjña nga n'e̱é? Nk'ie nga n'e̱tjáá xinki̱á, xi nkú ts'ín kik'inyanu̱u nga tuts'ihi̱n ni. 
\s1 B'i̱ ts'ín tsukúya Jua ni xi i̱ncha ts'ín já maestru̱ tsank'á xi tjín 
\p  
\v 7 A̱t'aha̱ tjíma ṉkjún a̱sunntee̱ já tsank'á xi najmi ts'ínkjáíhi̱n nga yjoninte kik'a Jesucristo̱ nga j'ai a̱sunntei̱. Xi b'a̱ títsu, kui xi tíb'ana̱cha̱ ko̱ kui xi fi kontra̱ha̱ xi kits'ín nibá Nti̱a̱ná.  
\v 8 Chúhu̱un yjonu̱u tu̱ xi najmi n'e̱katsúnyahanu ni xi y'entje̱i̱ a̱jinnu̱u. Tsa chúhu̱un kui nii̱, n'e̱kjóho̱on ngayjee̱ ni xi kanénu̱u. 
\p  
\v 9 Tu̱ yáhani xi k'u̱ésuhu̱n ni xi tsakúya Cristo̱ nga najmi basinjñajin ni xi kisakúya̱ha̱, kui xi najmi be Nti̱a̱ná. Tu̱nga xi síjñajin tehe̱nte ni xi tsakúya Cristo̱, kui xi be Nti̱a̱ Na̱'miu̱ ko̱ Ntíu̱.  
\v 10 Tsa tjín xi ku̱i̱chúsenu̱u ko̱ najmi ku̱a̱kúyanu̱u ni xi tsakúya Cristo̱, najmi tu̱ n'ekjóho̱on ni'yanu̱u ko̱ ta̱ ndaha najmi tu̱ suniñoho̱o.  
\v 11 A̱t'aha̱ xi kjúániñaha̱, kui xi tíbasinko̱ xu̱ta̱ xu'bo̱ nga tífiko̱ndju xá ch'onk'uhu̱n. 
\s1 B'i̱ ts'ín kits'ínkje Jua xu̱ju̱i̱n 
\p  
\v 12 Tjín ṉkjún sana ni xi xínnu̱u, tu̱nga najmi mjehéna xu̱ju̱n k'uet'ánu̱u. Mjena kfíntsubek'únnu̱u ko̱ kuinchjani̱jmíko̱nu̱u nga ku̱i̱chusenu̱u, tu̱ xi b'a̱ ts'ín tu̱ xí tsjohó k'úéhená. 
\p  
\v 13 Títs'ínkjinu̱u kju̱a̱suniña xu̱ta̱ ni̱nku̱ xinki̱u xi tjín e̱i̱ xi Nti̱a̱ná ta̱ j'ájihi̱n.