\id JAS - Yaouré NT [yre] -Côte d'Ivoire 1999 (web version -2013 bd)
\h Zaji
\toc1 'Fluba nɛn Zaji -a crɛn -tɛ
\toc2 Zaji
\toc3 Zaji
\mt2 'Fluba nɛn
\mt1 Zaji
\mt2 -a crɛn -tɛ
\c 1
\p 
\v 1 'An 'bɔ Zaji nɛn an Bali 'lee Minsan Zozi Crizi "sua bɛ, mɛɛn 'fluba 'gʋɛ -a crɛn -tɛ. Maan crɛn -tɛ Bali -le minnun pɛɛnɔn nɛn 'o fuiladɩ "man 'trɛda bɛ, -wlɛ. An 'ka 'tɔ bo.
\s1 E 'ka "le Zozizan 'e 'ci -fɔɔ "dɩ!
\p 
\v 2 'An "bʋɩ Zozinɔn, 'wɩ 'tɔndɔn pɛɛnɔn nɛn o bɔa 'ka man bɛ, 'ka yɩ 'cee ci "nran wɩ -a.
\v 3 Kɔɔ te ka yi -tɛra Bali da bɛ, ka bɔala 'ji, -e 'e -pɔan 'sɔdɩ -nɔn 'cɛɛ.
\v 4 'Ka yiɛ 'trɔa "da, -e -pɔan 'sɔdɩ zɩɛ 'e 'kʋ 'kaa -trilii "le zɩ e cɩ Bali ci 'sɔ 'a bɛ, -yee 'wɩ 'zʋ. -E 'ka 'kɔn tɩglɩ, te 'ka drɛ wɩ a 'e 'sʋdɩ "ji Bali 'lɛ.
\p 
\v 5 'Pian -te min -tʋ a 'ka yei 'nan 'wɩ nɛn kɔ 'e drɛ ya'a tɔa dɩɛ, 'e laabʋ Bali 'lɔ. Bali 'wɩ 'tɔdɩ -nɔan -yrɛ "le zɩ yaa laabʋ -yrɔ "bɛ -yee 'wɩ 'zʋ. Kɔɔ ya'a min bo "va "dɩ, ɛn yaa -nɔan 'e "tun.
\v 6 'Pian min 'bɔ 'e yi -tɛra "da -e 'e laabʋ -yrɔ. Te 'e 'ci -fɔɔ "dɩ! Kɔɔ min nɛn 'e 'ci -fɔɔman bɛ, e ya "le "pɛzannɛn nɛn fulɔ 'ta -tɔa "man "bɛ, -yee 'wɩ 'zʋ.
\v 7 Maan ve 'cɛɛ 'nan, te -a -cin 'e 'kɔn min zɩɛ -a -ji 'nan, 'e fɛ -tʋ ye Minsan 'lɔ "fo "dɩ.
\v 8 Kɔɔ min nɛn 'e 'ci -fɔɔman bɛ, -a -wulo -ji wɩ 'ka -tʋwli "dɩ. Ɛn -yee 'wɩ pɛɛnɔn drɛdɩ -ji bɛ, ya'a 'e yiɛ 'tɔala 'wɩ 'tʋ da tɩglɩ -e 'e drɛ dɩ.
\s1 Seezan 'lee fɛzan -le 'wɩ
\p 
\v 9 Min nɛn e ya seezan -a, ɛn e sɔɔnla Zozi -sru "bɛ, -a san ci 'e "nran 'nan, Bali 'e dra min -dan a.
\v 10 'Pian min nɛn e ya fɛzan -a, ɛn e sɔɔnla Zozi -sru "bɛ, -a -cin 'e 'kɔn -a san ji 'nan, e 'ka min -dan a Bali 'lɛ "fo "dɩ. Kɔɔ e "sia 'e yɩfɛ -sru "le zɩ lu 'e -fui -tɛa, -e 'e 'sran bɛ -yee 'wɩ 'zʋ.
\v 11 -Te yidɛ bii 'plɛblɛ bɛ, -e lu -fui 'e 'sran, te -yee fɛnyian -nyan. Zɩ fɛzan "sia 'e yɩfɛ da zɩɛ.
\s1 'Wɩ 'wlidɩ "drɛdɩ -taala 'kɔ!
\p 
\v 12 Min nɛn 'wɩ 'wlidɩ "cin -trɔa "ji ɛn ya'a drɛlɛ dɩɛ, Bali -le -fɛa -a san man. Kɔɔ -te -a san 'yee 'plɛblɛ 'ci kɔɔn zɩɛ -trilii ɛn e 'bɔla -a -wulo planan "bɛ, 'belidɩ nɛn ya'a 'nyaan dɩɛ e ya -yee vɛ -a. Minnun nɛn o Bali ye "yi "bɛ o -kopa nɛn zɩɛ.
\p 
\v 13 Min nɛn 'wɩ 'wlidɩ "cin -trɔa "ji "bɛ, te 'e 'pa Bali da dɩ! Kɔɔ 'wɩ 'wlidɩ "cin 'ka Bali ji dɩ, ɛn Bali 'ka 'wɩ 'wlidɩ "cin tɔala min ji dɩ.
\v 14 'Pian blamin 'bɔ 'wulo -ji wɩ 'bɛ see "paaman, -e 'e 'wɩ 'wlidɩ "drɛdɩ -cin -tɔ "ji.
\v 15 -Te min sɔɔnla 'e 'wulo -ji "nrɔndɩ 'wlidɩ zɩɛ -a -sru "bɛ, -e 'e 'wɩ 'wlidɩ "drɛ. Ɛn -te min 'wɩ 'wlidɩ drɛ 'trilii bɛ, -a 'le 'srannan "nɛn -kadɩ -a.
\p 
\v 16 'An "bʋɩ Zozinɔn, an 'ka ye "yi 'kpa. Te 'ka 'wɩ 'gʋɛ -a "sia 'ka see "paa wɩ -a dɩ.
\v 17 Maan ve 'cɛɛ 'nan, 'wɩ "yi 'lee 'wɩ tɩglɩ pɛɛnɔn "sia Bali va lou. -Yɛɛ laji fɛnun pɛɛnɔn nɛn o "bia bɛ o drɛ. Fɛnun pɛɛnɔn zɩɛ 'o 'man limlan, 'pian Bali 'ka 'limlan 'li "fo "dɩ.
\v 18 Bali 'bɔ 'ci 'sɔ 'a nɛn, e -kaa drɛ 'yee 'nɛnnun -a. Zozi 'le 'wɩ 'nɔnnɔn nɛn e ya 'wɩ tɩglɩ 'a bɛ, -a 'bɔ 'a nɛn e 'belidɩ 'nɔn -cɛɛ 'nan, -e -kaa kɔn 'e 'pɛ drɛvɛ flin -a.
\s1 'Ka "trɔɛn "tɔ Bali wei lɛ, -e 'ka 'ta wʋla "da!
\p 
\v 19 'An "bʋɩ Zozinɔn, an 'ka ye "yi 'kpa. 'Wɩ 'gʋɛ -a -cin 'e 'fɔla 'ka 'ji. 'Ka "trɔɛn 'e 'wɩ man! Te 'ka 'lɛbo 'e 'fɔ 'e 'flin -e 'e 'wɩ dɩ! Ɛn te 'bli 'e 'fɔ 'ka 'ji tada dɩ!
\v 20 Kɔɔ -te 'bli 'fɔ min ji bɛ, ya'a Bali ci 'sɔ wɩnun dra "fo "dɩ!
\v 21 -Yee "wɛan nɛn 'ka 'wɩ pɛɛnɔn nɛn e min "tri -tɔa Bali 'lɛ bɛ -a 'tʋɩ, 'lee 'wɩ 'wlidɩ pɛɛnɔn, -e 'ka 'wɩ Bali wei nɛn waa 'vɩ 'cɛɛ bɛ -a man, -e 'e -kɔla 'e 'ka 'si 'wɩ 'ji -le "wɛan.
\p 
\v 22 Te 'ka 'fli sɛɛ wʋ 'nan ka ya Bali wei mannan dɩ! 'Pian -te kaa 'man bɛ, 'ka 'ta wʋla "da!
\v 23 -Yɛɛ cɩ 'nan, min nɛn 'e "trɔɛn -tɔa Bali wei lɛ, te ya'a 'ta 'wo "da "dɩɛ, yaa dra "le 'nan min -tʋ 'bɛ 'e 'fli -nanjɛɛn -niannun 'ji, ɛn 'e 'fli -tɔ klɔ 'yɩ.
\v 24 Zɩ e cɛɛn "man ɛn e -kʋ bɛ, 'nun tɔɔn -a -tɔ klɔ 'san 'e 'fli ji.
\v 25 'Pian bii nɛn 'i yiɛ -trɔa Bali wei tɩglɩ nɛn e min "sia 'wɩ 'wlidɩ "le nɔanba -ji bɛ -a da bɛ, Bali -fɛa ve 'i man. Kɔɔ 'i "trɔɛn "tɔ -yrɛ, ɛn i kɔala "man, ɛn -a -cin 'ka 'sanlɛ 'i 'ji dɩ, 'pian i 'ta 'wʋla "da.
\p 
\v 26 Min nɛn e 'nan e ya Bali -sru, te ya'a 'kɔlaman 'e wei 'kundɩ -a dɩɛ, te e ya 'e 'fli sɛɛ wʋnan. Te -yee 'ta wʋdɩ Bali -sru "bɛ -a -ci "ka "dɩ.
\v 27 'Pian -kaa "tɩ Bali bɔdɩ tɩglɩ nɛn 'nan, blamin 'e yiɛ 'tɔ "tɩ 'lee "bʋ "ka "da "nɛnnun 'lee -calenun va 'wee yra yɩdɩ -ji. Ɛn "nyian 'nan blamin 'e 'fli 'kun -e 'e vɩlɛ 'e 'wɩ 'wlidɩ "tʋwli "drɛ dɩ.
\c 2
\s1 Te 'ka min bʋ "va dɩ!
\p 
\v 1 'An "bʋɩ Zozinɔn, kaa nɛn ka yi -tɛra mingɔnnɛn -kaa san Zozi Crizi da bɛ, te 'ka min bʋ "va "dɩ.
\v 2 'Ka 'ci "nrɔn 'wɩ 'gʋɛ -a da. Fɛzan -tʋ wla 'cee cin yɩ 'kuin 'e 'pɛ 'wlɛ man le -siga, ɛn 'e 'ta le sɔ fɛnyian -a. Seezan -tʋ wla "nyian 'cee cin yɩ 'kɔn 'lein zɩɛ -a -ji, te sɔ "cɛɛndɩ a "da.
\v 3 Min nɛn 'e 'ta le sɔ fɛnyian -a bɛ, kaa -nanjɛn, ɛn 'ka 'nyrannan fɛnyian -nɔn -yrɛ. 'Pian kaa 'vɩ seezan "le "lɛ 'nan: «Bii 'gʋ, "i "tɔ wʋ lou, ɛn -te i ya "va "bɛ, 'i 'nyran 'mɛn pɛin "srɔn "tra.»
\v 4 'Wɩ zɩɛ -a drɛdɩ bɛ, e ya min bʋdɩ "va "wlidɩ "a.
\p 
\v 5 'An "bʋɩ Zozinɔn, an 'ka ye "yi 'kpa. 'Ka "trɔɛn "tɔ 'wɩ 'gʋɛ -yrɛ! Maan ve 'cɛɛ 'nan, minnun nɛn o cɩ seenɔn 'a 'trɛ 'gʋɛ -a da bɛ, Bali o 'si "va 'nan, -e 'e o drɛ fɛnɔn 'a 'wee yi -tɛradɩ 'e da man, -e 'o 'kʋ 'yee mingɔnnɛn trɛ nɛn yaa 'pla minnun nɛn waa ye "yi "bɛ, -wlɛ "bɛ -a da.
\v 6 'Pian 'cee vɛ bɛ, ka'a seenɔn 'siala min -a dɩ, fɛnɔn nɛn ka o ye "yi. -Mɛ "le "wɛan nɛn kaa dra zɩ? Fɛnɔn 'bɛ 'tɛ "paa 'ka da, ɛn -wɛɛ -ko 'kaa tin 'banɔn 'cɛin -da.
\v 7 Ɛn -wɛɛ 'tɔ "srɔnman 'tɔ fɛnyian nɛn Zozi Crizi 'tɔ a bɛ -a man.
\p 
\v 8 Bali -le 'fluba 'ji bɛ, -yee -pei -tɔ wɩ -dan tʋ -a. E ya 'e 'crɛn -tɛdɩ 'nan:
\q1 «'I bɔɛzan -tʋ yɩ "yi
\q1 "le 'yie 'wɩ 'zʋ!»
\m -Te 'wɩ zɩɛ -a drɛnan nɛn ka cɩ bɛ, te ka 'wɩ "yi drɛ.
\v 9 'Pian -te ka min 'bʋ "va "bɛ, te ka 'wɩ 'wlidɩ drɛ. Ɛn te Bali -le -pei zɩɛ e tin -tɛa 'ka da Bali 'lɛ.
\v 10 Kɔɔ -te min Bali -le -pei -tʋwli "cɛ srɛ bɛ, te yaa pɛɛnɔn srɛ "fo.
\v 11 Bali -a 'vɩ 'nan:
\q1 «Te blamin 'e min nan -wɛɛ "dɩ,
\q1 ɛn te 'e min -sran -wɛɛ "dɩ!»
\m Ɛn yaa 'vɩ "nyian 'nan:
\q1 «Te blamin 'e drɛ min -tɛzan -a dɩ!»
\m -Te min 'ka min nan -wɛɛlɛ dɩ, 'pian ɛn e drɛ min -tɛzan -a bɛ, te ya'a 'ta wʋlɛa Bali wei da "fo "dɩ.
\p 
\v 12 -Yee "wɛan maan ve 'cɛɛ 'nan, -te 'ka "ta "we, ɛn 'ka "ta 'wɩ dra bɛ, -a -cin 'e 'kɔn 'ka 'ji 'nan, Bali wei nɛn e min "sia 'wɩ 'wlidɩ "le nɔanba -ji bɛ, e 'cee tin "baa.
\v 13 Kɔɔ yi nɛn Bali 'trɛdanɔn 'le tin "baa bɛ, min nɛn ya'a 'e bɔɛnun nyrinda 'silɛ dɩɛ, Bali 'ka -a san nyrinda sia dɩ. 'Pian min nɛn 'e bɔɛnun nyrinda 'si bɛ, te "klan 'e 'kɔn -a san -ji dɩ.
\s1 Yi -tɛradɩ Bali da 'lee min drɛ wɩ
\p 
\v 14 'An "bʋɩ Zozinɔn, -te min -a 'vɩ 'nan, an yi -tɛala Bali da, te ya'a kɔɔnman 'e drɛ wɩ -a dɩɛ, -a -ci nɛn 'nɔn? -Yee yi -tɛradɩ Bali da zɩɛ, ya'a sia 'wɩ 'ji "fo "dɩ.
\v 15 'Ka 'ci "nrɔn 'wɩ 'gʋɛ -a da. 'Ka "bʋɩ Zozizan 'tʋ a 'ka 'va, -te 'bɛ "cɛɛ dɩ, 'ka "blu Zozizan 'tʋ a 'ka 'va, -a ta sɔ "ka "dɩ, ɛn -a -blɩfɛ "ka "dɩ.
\v 16 Ɛn kaa 'vɩ -yrɛ 'nan: «Kʋ ya yi pee nyan. I -fʋ -trɔɔ. Bali 'e fɛ nɛn yia -wɛɛman bɛ -a -nɔn 'yiɛ.» 'Pian fɛ nɛn 'e klɩ "man "bɛ, ka'a -nɔnlɛ -yrɛ "dɩ. 'Wɩ zɩɛ -a drɛdɩ bɛ, -a -ci "ka "fo "dɩ.
\v 17 -A -tʋwli "nɛn "nyian yi -tɛradɩ Bali da -a. Min nɛn e yi -tɛala Bali da, ɛn ya'a kɔɔnman 'e drɛ wɩnun -a dɩɛ, min zɩɛ -yee yi -tɛradɩ Bali da -ci "ka "fo "dɩ.
\p 
\v 18 Ɛn "nyian bɛ, -te min -a 'vɩ 'mɛn 'nan: «Min -tʋ yi -tɛala Bali da, ɛn min pee "e "yi "dra minnun lɛ.»
\p Tɔɔn maan laabo min zɩɛ -yrɔ 'nan, 'i 'yie yi -tɛradɩ Bali da nɛn wa'a kɔɔnman o drɛ wɩ -a dɩɛ, -a -ci -kɔɔn 'mɛn! -E 'an 'mɛn yi -tɛradɩ Bali da -ci -kɔɔn 'yiɛ 'an drɛ wɩ -a.
\v 19 I yi -tɛala "da 'nan Bali a -tʋwli "cɛ. 'Wɩ 'kpa nɛn. 'Pian -a -cin 'e 'kɔn 'i 'ji 'nan, -yʋ -wlidɩnun "o yi -tɛala "nyian "da zɩ, ɛn o "klanman -yrɔ.
\p 
\v 20 -Blʋzan, i ya "vale 'an -ci -kɔɔn 'yiɛ 'nan, yi -tɛradɩ Bali da nɛn wa'a kɔɔnman 'o drɛ wɩ -a dɩɛ, -a -ci "ka "dʋʋ?
\v 21 -Mɛ "le "wɛan nɛn Bali -kaa tra Abraam 'sia min tɩglɩ 'a? -A drɛ wɩ man nɛn. Kɔɔ Abraam wɩɩ "man, ɛn e 'e 'pɩ Izak 'si, yaa -nɔn Bali lɛ 'sraga bʋvɛ -a Bali -pan "davɛ da.
\v 22 Yia 'yɩ? -A drɛ wɩ 'lee -yee yi -tɛradɩ Bali da drɛ 'tʋwli. Ɛn -yee yi -tɛradɩ Bali da 'e 'lɛ sɔɔ -a drɛ wɩ man.
\v 23 'Wɩ 'bɔ zɩɛ -yee "wɛan e ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji 'nan:
\q1 «Abraam yi -tɛra Bali wei da,
\q1 ɛn Bali -a 'sia min tɩglɩ 'a
\q1 'yee yi -tɛradɩ 'e da man.»
\m Bali -a laabʋ 'e bee.
\v 24 -Yee "wɛan maan 'vɩ 'cɛɛ 'nan, Bali min "siala min tɩglɩ 'a 'e drɛ wɩ 'lee 'yee yi -tɛradɩ 'e da man, 'pian ya'a siala min tɩglɩ 'a 'yee yi -tɛradɩ Bali da 'saza "cɛ "man dɩ.
\p 
\v 25 'Wɩ 'tʋwli zɩɛ -yɛɛ drɛ "nyian -kɔnnɛn -wɛɛzan nɛn waa laabo Rab bɛ -yee vɛ -a. Bali -a "sia lɩmɔn tɩglɩ 'a 'e drɛ wɩ man. Kɔɔ minnun nɛn Zozue o 'pa 'sia bɛ, e 'pa 'o 'va, ɛn e -si -tʋ kɔɔn -wlɛ 'nan 'o 'tɛ -ji "da.
\p 
\v 26 Kaa -tɔa 'nan -te 'flindɩ -nyan min lɔ bɛ, te e -ka. -A -tʋwli "nɛn "nyian yi -tɛradɩ Bali da -le vɛ -a. Yi -tɛradɩ Bali da nɛn wa'a kɔɔnman 'o drɛ wɩ -a dɩɛ, te e ya 'e 'kadɩ.
\c 3
\s1 Min nrɛn 'le 'wɩ
\p 
\v 1 'An "bʋɩ Zozinɔn, te 'ka vɩnan 'ka pɛɛnɔn 'e drɛ Bali wei "paanɔn 'a dɩ. Kɔɔ kaa -tɔa 'nan, 'kʋ Bali wei "paanɔn bɛ, Bali 'kʋe 'wɩ tin "baa 'plɛblɛ 'e "mlian min peenun -le vɛ da.
\v 2 -Kaa pɛɛnɔn -pɛ "saanman 'wɩ 'wlidɩ 'va 'wɩ "kaga "ji. -Te min 'lewei 'ka "saanlɛ -tʋwli 'wɩ 'wlidɩ 'va dɩɛ, te min nɛn -a drɛ wɩ a 'e 'lɛ sɔɔdɩ bɛ, -nyrɛn. Te e -kɔlaman 'e 'fli 'kundɩ -a "fo.
\p 
\v 3 'Ka 'ci "nrɔn 'wɩ 'gʋɛ -a da. -Kaa -bulalɛ wlɛ wo -sʋnun 'le, 'nan -e 'o -kaa wei man, -e -kaa -kɔla "o pladɩ -a.
\v 4 Ɛn "nyian bɛ, 'ka 'ci "nrɔn -klʋ -dandannun da. -Te -klʋ a -dan 'kɔ oo, -a -trɔa "vɛ -si yra a "wɛnnɔn. -Te fulɔ 'plɛblɛ a 'ta 'tɔnan "man "bɛ, -a -trɔa "vɛ -si yra "wɛnnɛn zɩɛ -yɛɛ -maan -e -a -fɔzan 'e -trɔa -si yra.
\v 5 -A -tʋwli "nɛn "nyian min nrɛn 'le vɛ -a. E ya min man mɛnnun va "wɛnnɔn, 'pian -yɛɛ -maan -e 'wɩ -dan 'e 'fɔla.
\p Ɛn "nyian bɛ 'ka 'ci "nrɔn plɔ -dan nɛn 'tɛ "wɛnnɛn -fɔala 'ji bɛ -a da.
\v 6 Min nrɛn a "le 'tɛ 'le 'wɩ 'zʋ. -A da nɛn 'wɩ 'wlidɩ 'tɔ -tʋdʋ pɛɛnɔn cɩ. E ya -kaa man mɛnnun va, ɛn -yɛɛ -kaa munmuan "tri -tɔa. Maan ve 'cɛɛ 'nan, -e 'e 'sia yi nɛn o min -yaa "da "trilii, -e -a -ka yi 'e bɔ bɛ, -a nrɛn 'bɛ 'tɛ wo -yee 'trɛda va. 'Tɛ zɩɛ Satan -va nɛn e "sia.
\p 
\v 7 Min -kɔlaman -e 'e luji wi pɛɛnɔn, 'lee "lomannun, 'lee pɔnɛnnun, 'lee fɛ pɛɛnɔn nɛn o 'ta wʋla 'o 'kɔlɛnɛn "bɛ, o 'lɛbʋ.
\v 8 'Pian min -tʋ 'ka 'kɔlaman 'e nrɛn pladɩ -a "fo "dɩ. Fɛ -wlidɩ "nɛn, ya'a 'tɔa 'e "pa 'ji flɩɩ dɩɛ, -nyrɛn. E ya 'e fadɩ min -tɛ 'yile -a.
\p 
\v 9 Nrɛn zɩɛ -a 'bɔ 'a nɛn -kaa Minsan nɛn e cɩ -kaa "tɩ "a bɛ, -a 'tɔ bɔa. Ɛn -a 'bɔ 'a nɛn -kaa wei "paala blamin nɛn Bali -a drɛ "le 'yee 'wɩ 'zʋ bɛ, -a man.
\v 10 Min 'le 'a nɛn min -fɛa ve min man. Ɛn min 'le 'tʋwli zɩɛ -a 'bɔ 'a nɛn min 'e wei "paala min man. 'An beenun, te 'cee vɛ 'e 'kɔn zɩɛ dɩ!
\v 11 Fɛnan nɛn 'yi bɔala bɛ, 'e drɛ 'cee 'wɩ -kɔɔn "manvɛ -a! 'Yi 'nɔnnɔn 'lee 'yi nyrannyran 'ka 'bɔala fɛ -tʋwli zɩɛ -a -nan 'e cin -a dɩ.
\v 12 Ɛn "nyian bɛ, -lomin yiba 'ka 'baa -voga -a dɩ, ɛn -mango yiba 'ka 'baa -lomin -a dɩ. Ɛn 'yi 'wɛwɛa 'lee 'yi 'nɔnnɔn 'ka bɔala 'yi bɔlanan 'tʋwli "nan dɩ.
\s1 Laji 'wɩ 'tɔdɩ
\p 
\v 13 -Te min -tʋ a 'ka yei, te 'wɩ pɛɛnɔn 'cin a "ji, ɛn e 'wɩ -tɔa "bɛ, 'e -kɔɔn 'yee -kɔndɩ "yi 'lee 'e drɛ wɩnun tɩglɩ 'a.
\v 14 'Pian -te man bʋdɩ -nɔnnɔan -cin a 'ka 'ji bɛ, te 'ka 'fli -kɔɔn 'cee 'wɩ 'tɔdɩ -a "fo "dɩ. Ɛn -te bɔɛ "blɩdɩ -cin a 'ka 'ji bɛ, te 'ka 'fli -kɔɔn 'cee 'wɩ 'tɔdɩ -a "fo "dɩ. Kɔɔ -te 'ka 'fli -kɔɔn 'nan ka ya 'wɩ 'tɔnɔn 'a bɛ, te ka 'wlu -sɛan.
\v 15 'Wɩ 'tɔdɩ zɩɛ, Bali "cɛɛ 'bɛ -nɔan "dɩ. E "sia 'trɛda 'gʋ, ɛn min 'bɔ -wulo -ji nɛn e -tɔala. Satan -va nɛn e "sia.
\v 16 Fɛ nɛn maan ve zɩɛ -yɛɛ cɩ 'nan, -te man bʋdɩ a fɛnan, ɛn bɔɛ "blɩdɩ a fɛnan bɛ, fɛ zɩɛ -a -nan 'ka flɩɩ "fo "dɩ. 'Wɩ 'wlidɩ 'tɔ 'tʋdʋ pɛɛnɔn a -nan.
\p 
\v 17 'Pian 'wɩ 'tɔdɩ nɛn e "sia Bali va bɛ, e ya 'wɩ 'tɔdɩ tɩglɩ 'a. E min dra min -trɔɔ -a, ɛn e min dra min ci "yizan 'a. Min zɩɛ e min wei maan, min nyrinda -sɛan "da, ɛn e "yi "dra min lɛ. Ya'a min bo "va "dɩ, ɛn ya'a 'wɩ 'dra -dawli a dɩ.
\v 18 Minnun nɛn waa -wɛɛman -trɔɔ 'nan minnun yei 'e 'fʋ -trɔɔ bɛ, -a 'le 'srannan "bɛ 'wɩ "yi "drɛdɩ nun 'bɛ -taa "bɔlɛa.
\c 4
\s1 'Ka Satan 'tʋɩ -e 'ka -sɔɔnla Bali -sru!
\p 
\v 1 -Kulinun a 'ka yei, ɛn 'wɩ 'blɩdɩnun a 'ka yei. Nyin zia nɛn 'wɩnun zɩɛ -a pou 'si? Maan ve 'cɛɛ 'nan, 'ka 'bɔ 'wulo -ji "nrɔndɩ -wlidɩnun nɛn ka 'ta wʋla "da "bɛ -yɛɛ -maan 'wɩnun a 'ka yei.
\v 2 Ka ya "vale fɛ -tʋ 'e drɛ 'cee vɛ -a, 'pian -te ka'a ye dɩɛ, te ka 'nandɩ 'sia min man "le 'ka -tɛ. Ɛn ka ya "vale 'nan 'ka bɔɛzan -tʋ -lɔ fɛ 'e drɛ 'cee vɛ -a, 'pian -te ka'a 'kɔlaman -a yɩdɩ -a dɩɛ, te -kulinun 'lee 'wɩ 'blɩdɩnun wla 'ka yei. Fɛ nɛn ka cɩ "va "bɛ ka'a ye dɩ, ka'a laabo Bali lɔ dɩ -le "wɛan.
\v 3 Ɛn -te kaa laabʋ Bali lɔ bɛ, ya'a nɔan 'cɛɛ dɩ, kɔɔ -a laabʋ "manwɩ a -wlidɩ. Kaa laabo 'nan, -e 'ka 'fli ci 'sɔ wɩnun drɛ -a.
\p 
\v 4 Ka "we "flivli Bali man "le lɩmɔn nɛn e 'si 'e 'sran wlu, ɛn e -kʋ -kɔnnɛn pee -va bɛ -yee 'wɩ 'zʋ. 'Trɛda fɛnun yɩdɩ "yi "bɛ, e ya Bali 'nan man wɩ -a. Ka'a -ci tɔa dʋʋ? Min oo min nɛn e 'trɛda fɛnun pɛɛnɔn ye "yi "bɛ, 'e 'fli dra Bali 'nanmanzan 'a.
\v 5 E ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji 'nan:
\q1 «Lei nɛn Bali -a -nɔn 'cɛɛ bɛ,
\q1 Bali -a ye "yi, ɛn e man bo "da!»
\m Te -a -cin 'e 'kɔn 'ka 'ji 'nan, 'wɩ zɩɛ e ya 'wɩ "tun "a dɩ!
\v 6 'Pian "yi "nɛn Bali -a dra -cɛɛ bɛ e "mlianla "da. Kɔɔ e ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji 'nan:
\q1 «Minnun nɛn o 'fli dra -dandan bɛ
\q1 Bali 'ka o ye "yi "dɩ.
\q1 'Pian e "yi "dra minnun nɛn
\q1 wa'a 'o 'fli kɔɔnman dɩɛ -wlɛ.»
\p 
\v 7 -Yee "wɛan nɛn 'ka 'wɩ "man 'ka 'ci 'fɩdaa 'a, -e 'ka 'ta wʋla Bali -sru! Te 'ka tɔa Satan lɛ dɩ! 'Ka drɛ zɩɛ -e 'e 'si 'ka man -kɔɔbli!
\v 8 'Ka -pli Bali man, -e 'e -pli 'ka man! 'Wɩ 'wlidɩ "drɛnɔn, 'ka 'pɛ 'e 'si 'wɩ 'wlidɩ -sru! Kaa nɛn 'ka 'ci -fɔɔman Bali -sru 'ta wʋdɩ -ji bɛ, 'ka 'ci 'si 'fɩdaa -e 'ka 'ta wʋla Bali -sru.
\v 9 'Wɩ 'wlidɩnun nɛn kaa dra bɛ, -a 'wɩ 'e 'nan 'ka man! 'O 'ka 'ta drɛ -trɔdrɔ! 'Ka 'wuɔ! 'Ka 'cee 'shɛ 'blɩdɩ lila "da -wuɔdɩ -a! 'Ka 'cee 'ci "nrandɩ lila "da -trundɩ -a!
\v 10 'Ka 'fli drɛ "wɛnnɔn Bali 'lɛ, -e 'e 'ka drɛ -dan!
\s1 Te 'ka min 'tɔ 'tɛ dɩ!
\p 
\v 11 'An "bʋɩ Zozinɔn, te 'ka 'wɩ 'ka cin man -wlidɩ "dɩ! Min nɛn e 'wɩ 'wlidɩ 'vɩ 'e "bʋɩ -tʋ man, -te 'bɛ "cɛɛ dɩ yaa 'tɔ 'tɛ bɛ, te e 'wɩ 'wlidɩ 'vɩ Bali -le -pei man, ɛn e tin -tɛ "da. -Yɛɛ cɩ 'nan, -te i 'wɩ 'wlidɩ 'vɩ Bali -le -pei man bɛ, te yi'a 'ta wʋlɛa "da "dɩ, 'pian te i drɛ -a man tin 'bazan 'a.
\v 12 Bali -tʋwli 'bɛ -pei -tɔ minnun lɛ, ɛn -yɛɛ cɩ -a ta tin 'bazan a. -A -tʋwli 'bɛ -kɔlaman min 'sidɩ -a 'wɩ 'ji, 'lee min -tɛdɩ -a. 'I 'fli "siala 'kɔ, ɛn i "we 'i bɔɛnun man zɩɛ.
\s1 Fɛnɔn, te 'ka 'fli 'sia -dan dɩ!
\p 
\v 13 Kaa nɛn kaa ve 'nan: «Cɛɛgʋ 'lee "trɛ "a kʋ -ko 'fla 'gʋɛ -a da, kʋ lɛ -tʋ -tɛa "nan nun, kʋ 'flɛ -taan -e 'kʋ "lala yɩ» bɛ, 'ka drɛ "yi!
\v 14 Ka'a "trɛ wɩ tɔa dɩ. Ka ya "le "lolu -koei "wɛnnɛn nɛn e -tɔala -voo, -e 'e 'si 'nan bɛ -yee 'wɩ 'zʋ.
\v 15 'Wɩ nɛn kɔ 'ka vɩ bɛ, -nyrɛn 'gʋ. 'Ka vɩ 'nan: «-Te Minsan wɩɩ "man 'nan 'belidɩ 'bɔ 'kʋ man bɛ, kʋ fɛ 'gʋ 'lee fɛ 'gʋɛ -a dra.»
\v 16 'Pian ka'a 'wɩ zɩɛ 'bɛ 've dɩ. 'Ka 'fli "siala -dan, ɛn 'ka 'fli -kɔɔnman. 'Wɩ zɩɛ -a drɛdɩ bɛ, e ya -wlidɩ.
\p 
\v 17 Maan ve 'cɛɛ 'nan, min oo min nɛn e 'wɩ "yi "nɛn kɔ 'e drɛ bɛ -a -tɔa, ɛn ya'a drɛlɛ dɩɛ, te e 'wɩ 'wlidɩ drɛ.
\c 5
\s1 Fɛnɔn, 'ka drɛ "yi, "tɔgɔ 'wɩ 'e bɔ 'ka man!
\p 
\v 1 Fɛnɔn, an 'wɩ "paala 'cɛɛ 'nan, 'ka wu 'sia 'plɛblɛ, 'wɩ 'nɔnnɔan nɛn e -taa "bɔlɛ 'ka man bɛ -yee "wɛan.
\v 2 Tʋ zɩɛ -a man bɛ, 'ka yɩfɛnun srɛman, ɛn fadrʋnɛn 'cee sɔnun -ble.
\v 3 -Jeza -fɔa 'cee -siga 'lee 'cee "lalanun man. -Jeza zɩɛ -yɛɛ 'ka man wɩ -tɔa lou -e 'e 'ka kɔlɛbo "blɩ "le 'tɛ 'zʋ. 'Trɛda -nyan tʋ 'bɔ 'kogo, 'pian te ka -ko 'ka yɩfɛnun tredɩ -a "kaga.
\v 4 Minnun nɛn o 'nyranman 'pa 'cee fei ɛn ka'a o -pan wʋlɛ dɩɛ, 'plɛblɛ pɛɛnɔn 'san Bali -wee -paandɩ man.
\v 5 Ɛn "nyian bɛ fɛ -tʋ 'ka 'klɩlɛ 'ka man dɩ, 'ka 'ci 'sɔ wɩnun pɛɛnɔn drɛ 'trɛda. 'Trɛda -nyan tʋ 'bɔ 'kogo, 'pian te ka -ko fɛnun -blɩdɩ -a, ɛn ka -ko bɔadɩ -a "le -sru nɛn o cɩ -a 'lɛ bʋnan 'nan -e 'o -blɩ bɛ -yee 'wɩ 'zʋ.
\v 6 Ɛn "nyian bɛ minnun nɛn wa'a 'wɩ 'tʋ drɛlɛ dɩɛ, ka 'wɩ 'pa o da, ɛn ka o tɛɛ. Wa'a 'wɩ 'tʋ vɩlɛ dɩ.
\s1 'Ka -pɔan 'e 'sɔ!
\p 
\v 7 'An "bʋɩ Zozinɔn, 'ka -pɔan 'e 'sɔ 'trilii, -e Minsan -ta tʋ 'e bɔ. 'Ka 'ci "nrɔn fei 'pazan nɛn e 'yee fɛ 'wlɛ -fɔa 'trɛ 'ji bɛ -a da. Yaa man -pɛan -pɔan 'sɔdɩ -a -trilii, -e laa 'e 'fɛn "man, -e -a -tɛ tʋ 'e bɔ.
\v 8 'Ka 'bɔ "nyian, "cee -pɔan 'e 'sɔ zɩɛ! 'Ka -pɔan 'kun, kɔɔ Minsan -tadɩ 'bɔ 'kogo.
\p 
\v 9 'An "bʋɩ Zozinɔn, te 'ka cin man wɩ 'pa dɩ, "tɔgɔ Bali 'e tin -tɛ 'ka da! Min nɛn 'e tin -tɛa "min da bɛ, e 'bɔ 'kogo.
\v 10 Minnun nɛn o Bali 'lewei 'vɩ Minsan 'tɔ da bɛ, o -pɔan 'sɔ 'wee yra yɩdɩ -ji. 'Ka 'ci "nrɔn o da, -e 'o drɛ 'cee 'wɩ -kɔɔn "mannɔn 'a.
\v 11 Minnun nɛn o -pɔan 'sɔ yra yɩdɩ -ji bɛ, kʋa ve o man 'nan 'wee 'wɩ a "yi. Ka Zob -le -pɔan 'sɔdɩ 'wɩ 'man. Ɛn fɛ nɛn Bali -a -nɔn -yrɛ -a 'le 'srannan "bɛ, kaa -tɔa. Maan ve 'cɛɛ 'nan, Minsan ci a "yi, ɛn min nyrinda -sɛan "da.
\p 
\v 12 'An "bʋɩ Zozinɔn, te 'ka 'wɩ 'tʋ -ji -pɛ wluan dɩ! Te 'ka 'pɛ wluan labli man dɩ, ɛn te 'ka 'pɛ wluan 'trɛ man dɩ, ɛn te 'ka 'pɛ wluan "nyian fɛ pee man dɩ! 'Pian 'wɩ tɩglɩ nɛn 'ka vɩ! -Te 'wɩ a 'wɩ 'kpa -a bɛ, 'ka vɩ -inyan! Ɛn -te 'wɩ a 'wlu 'a bɛ, 'ka vɩ -cɛjɛ! "Tɔgɔ yi nɛn Bali tin -tɛa 'trɛdanɔn da bɛ, 'e vɩlɛ 'e 'ka 'tʋɩ 'e "tun "dɩ.
\s1 'Ka Bali trʋ 'ba!
\p 
\v 13 -Te min -tʋ a 'ka yei 'nan e ya 'e yra yɩnan bɛ, 'e Bali trʋ 'ba! -Te min -tʋ a 'ka yei 'nan -a ci "nranman bɛ, 'e Bali 'tɔ 'bɔ "dre "fɔ!
\v 14 -Te min -tʋ a 'ka yei 'nan -a man "yaaman bɛ, 'e -leglizinɔn ceje laabʋ, -e 'o Bali trʋ 'ba -yrɛ, te o 'nyrɔn -sɛan -a -win -ji Minsan 'tɔ da.
\v 15 -Wee Bali trʋ 'badɩ nɛn waa dra yi -tɛradɩ Bali da -a bɛ, e man "yaazan zɩɛ -a "belia, ɛn Minsan -a wuanla. -Te 'wɩ 'wlidɩ "nɛn yaa drɛ bɛ, Bali -a fuiman.
\p 
\v 16 -Yee "wɛan nɛn 'ka 'cee 'wɩ 'wlidɩ "vɩ 'ka cin lɛ 'vaa -e 'ka Bali trʋ 'ba 'ka cin lɛ, 'dʋ -e 'ka 'beli. Kɔɔ -te min a tɩglɩ Bali 'lɛ bɛ, -yee Bali trʋ 'badɩ 'e 'bli pɛɛnɔn 'a bɛ, -a 'lɛ a "man.
\p 
\v 17 'Ka 'ci "nrɔn 'wɩ nɛn Bali 'lewei vɩzan -tʋ -a drɛ 'li bɛ -a da. Bali 'lewei vɩzan zɩɛ waa laabo Eli, ɛn e ya blamin -a "le -cee 'wɩ 'zʋ. E Bali trʋ 'ba 'e 'bli pɛɛnɔn 'a 'nan, te laa 'e 'fɛn dɩ. Ɛn 'wɩ 'kpa, laa 'ka 'fɛnlɛ 'trɛda dɩ. Yaa drɛ lɛ yaaga mlɛn 'shɛɛdʋ.
\v 18 "Bɛ -sru ɛn e Bali trʋ 'ba "nyian, tɔɔn laa 'fɛn, ɛn fɛ pɛɛnɔn bɔdɩ 'sia.
\p 
\v 19 'An "bʋɩ Zozinɔn, -te min -tʋ a 'ka yei, ɛn e 'si 'wɩ tɩglɩ man -kɔɔbli bɛ, 'ka drɛ -e 'e sɔɔnla "nyian 'wɩ tɩglɩ zɩɛ -a -sru.
\v 20 'Ka -tɔ 'nan, min oo min nɛn yaa drɛ ɛn e 'wɩ 'wlidɩ "drɛzan 'si 'si 'wlidɩ "da ɛn yaa sɔɔnla 'wɩ tɩglɩ -sru "bɛ, -yɛɛ -maan ɛn Bali 'belidɩ nɛn ya'a 'nyaan dɩɛ -a -nɔn min zɩɛ -yrɛ, kɔɔ Bali -yee 'wɩ 'wlidɩ pɛɛnɔn fui.
