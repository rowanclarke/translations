\id ZEC
\h زَاكَارِييَّا
\toc1 زَاكَارِييَّا
\toc2 زَاكَارِييَّا
\toc3 زَاك.
\mt1 زَاكَارِييَّا
\c 1
\s1 أَڒَاغِي إِ تُّوبثْ
\m 
\v 1 \bd ذڭْ ؤُيُورْ وِيسّْ ثْمنْيَا، ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْمنْيَا ن ذَارِييُوسْ\bd*، يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ زَاكَارِييَّا، مِّيسْ ن بَارَاخْيَا، مِّيسْ ن عِيدُّو، أَنَابِي، إِنَّا:
\b
\m 
\v 2 ”سِيذِي ثُوغَا إِفُّوڭمْ أَطَّاسْ خْ ڒجْذُوذْ نْومْ.
\v 3 إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: ذْوڒْ-د غَارِي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، خنِّي نشّْ أَذْ غَارْومْ-د ذوْڒغْ، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.
\v 4 وَارْ تِّيڒِيمْ أَمْ ڒجْذُوذْ نْومْ إِ يِينِّي ؤُمِي بَارّْحنْ إِنَابِييّنْ ن زِيشْ، نَّانْ: ’أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، ذوْڒمْ-د خنِّي زڭْ إِبْرِيذنْ نْومْ إِعفّْننْ ؤُ زِي ثْمڭَّا نْومْ إِعفّْننْ!‘ مَاشَا نِيثْنِي وَارْ سْڒِينْ شَا ؤُ وَارْ ذ أَيِي وْشِينْ أَمزُّوغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. \x ◘ \xo 1:‏4 \xt إِشا. 31‏:‏6؛ إِرْم. 3‏:‏12؛ 18‏:‏11؛ حِز. 18‏:‏30؛ حُوش. 14‏:‏2\x*
\v 5 ڒجْذُوذْ نْومْ، مَانِي دْجَانْ؟ ؤُ إِنَابِييّنْ، مَا أَذْ دَّارنْ إِ ڒبْذَا؟
\v 6 مَاشَا أَوَاڒنْ إِنُو ذ ثْوصَّا إِنُو نِّي ؤُمُورغْ إِ إِمْسخَّارنْ إِنُو، إِنَابِييّنْ، مَا وَارْ ڒْقِيفنْ ڒجْذُوذْ نْومْ؟ نِيثْنِي ذوْڒنْ-د، نَّانْ: أَمْ مَامّشْ ثُوغَا سِيذِي ن ڒْعسْكَارَاثْ إِنكّْوَا أَذْ يڭّْ أَكِيذْنغْ عْلَاحْسَابْ إِبْرِيذنْ نّغْ ذ ثْمڭَّا نّغْ، أَمُّو إِ إِڭَّا نتَّا أَكِيذْنغْ.‘ “ \x ◘ \xo 1:‏6 \xt إِڭجذ. 1‏:‏18\x*
\b
\s1 ثَامژْرِيوْثْ ثَامزْوَارُوثْ - أَربْعَا ن إِيْسَانْ
\m 
\v 7 \bd ذڭْ وَاسّْ وِيسّْ أَربْعَا ؤُ-عِيشْرِينْ، ذڭْ ؤُيُورْ وِيسّْ حِيطَاشْ، وَا ذ أَيُورْ ن شَابَاطْ، ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ ن ذَارِييُوسْ\bd* يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ زَاكَارِييَّا، مِّيسْ ن بَارَاخْيَا، مِّيسْ ن عِيدُّو، أَنَابِي، حِيمَا أَذْ \add كِيسْ\add* إِسِّيوڒْ.
\b
\m 
\v 8 نشّْ ژْرِيغْ ذِي دْجِيڒثْ، خْزَارْ، أَقَا إِجّْ ن ورْيَازْ خْ إِجّْ ن ؤُيِيسْ ذ أَزڭّْوَاغْ. نتَّا ثُوغَا إِبدّْ جَارْ ثْشجُّورَا ن ثْرِيحَانْثْ ذِي ڒَادْجَاغْ ؤُ أَوَارْنِي أَسْ ذِينْ إِيْسَانْ إِزڭّْوَاغنْ ذ \add ييْسَانْ\add* إِقَارْقَاشنْ ذ \add ييْسَانْ\add* إِشمْڒَاڒنْ.
\v 9 نشّْ نِّيغْ: ”سِيذِي إِنُو، مِينْ عْنَانْ إِنَا؟“ \add ڒخْذنِّي\add* إِنَّا أَيِي لْمَالَاكْ نِّي كِيذِي إِسَّاوَاڒنْ: ”نشّْ أَذْ أَشْ سّشْنغْ مِينْ عْنَانْ إِنَا!“
\v 10 أَرْيَازْ نِّي إِبدّنْ جَارْ ثْشجُّورَا ن ثْرِيحَانْثْ، يَارَّا-د، إِنَّا: ”إِنَا ذ إِنِّي د-إِسّكّْ سِيذِي حِيمَا أَذْ سُوحنْ خْ ثمُّورْثْ.“
\v 11 نِيثْنِي أَرِّينْ-د خْ لْمَالَاكْ ن سِيذِي، ونِّي إِبدّنْ جَارْ ثْشجُّورَا ن ثْرِيحَانْثْ، نَّانْ: ”نشِّينْ نْسُوحْ ذِي ثمُّورْثْ، ؤُ خْزَارْ، مَارَّا ثَامُّورْثْ ثقِّيمْ، ثَارْسَا.“
\b
\m 
\v 12 \add خنِّي\add* يَارَّا-د لْمَالَاكْ ن سِيذِي، إِنَّا: ”\add أَ\add* سِيذِي ن ڒْعسْكَارَاثْ، أَڒْ مڒْمِي \add عَاذْ\add* وَارْ ثتّْحِينِّيذْ خْ ؤُرْشَالِيمْ ؤُ خْ ثْندَّامْ ن يَاهُوذَا نِّي خْ ثُوغَا ثْسخْضذْ سبْعِينْ ن إِسڭّْوُوسَا-يَا؟“
\v 13 سِيذِي يَارَّا-د خْ لْمَالَاكْ نِّي كِيذِي إِسَّاوَاڒنْ \add س\add* وَاوَاڒنْ شْنَانْ، \add س\add* وَاوَاڒنْ ن ؤُفوّجْ.
\v 14 لْمَالَاكْ نِّي كِيذِي إِسَّاوَاڒنْ، إِنَّا أَيِي: ”بَارّحْ، إِنِي:
\b
\m \bd ’أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ:\bd*
\m \qt نشّْ ؤُسْمغْ ذِي طّْوعْ ن ؤُرْشَالِيمْ\qt*
\m \qt ذ صِيهْيُونْ س وَاسَامْ ذ أَمقّْرَانْ.\qt*
\m 
\v 15 \qt س إِجّْ ن ؤُذُوقّزْ أَمقّْرَانْ ن وغْضَابْ إِنُو\qt*
\m \qt فُّوڭْمغْ خْ ڒڭْنُوسْ إِنّفْخنْ.\qt*
\m \qt نشّْ ثُوغَا فُّوڭْمغْ مْغِيرْ شْوَايْثْ ن ڒْوقْثْ،\qt*
\m \qt \tl مَاشَا\tl* نِيثْنِي رُوحنْ أَرْنِينْ ذَايسْ.‘\qt*
\m 
\v 16 \qt س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي:\qt*
\m \qt ’نشّْ ذوْڒغْ-د غَارْ ؤُرْشَالِيمْ س ثحْنُونشْثْ،\qt*
\m \qt ثَادَّارْثْ إِنُو أَذْ ثتّْوَابْنَا ذَايسْ،\qt*
\m \qt \tl أَمُّو\tl* إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ،\qt*
\m \qt ؤُشَا \tl أَ\tl*فِيڒُو نْ ڒعْبَارْ\qt*
\m \qt أَذْ إِتّْوَاڭّْ خْ ؤُرْشَالِيمْ.‘\qt*
\m 
\v 17 أَرْنِي بَارّحْ، إِنِي:
\b
\m \bd ’أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ:\bd*
\m \qt ثِيندَّامْ إِنُو أَذْ فيّْضنْثْ عَاوذْ سْ ڒْخَارْ،\qt*
\m \qt مَاغَارْ سِيذِي أَذْ إِسّْفوّجْ صِيهْيُونْ عَاوذْ\qt*
\m \qt ؤُ نتَّا أَذْ إِخْضَارْ ؤُرْشَالِيمْ عَاوذْ.‘ “\qt*
\b
\b
\c 2
\s1 ثَامژْرِيوْثْ وِيسّْ ثْنَاينْ - أَربْعَا ن إِشَّاونْ ذ أَربْعَا ن إِمْزِيڒنْ
\m 
\v 1 نشّْ سّْڭعّْذغْ ثِيطَّاوِينْ إِنُو ؤُشَا ژْرِيغْ، ؤُ خْزَارْ \add أَقَا ذِينْ\add* \bd أَربْعَا ن وَاشَّاونْ\bd*.
\v 2 نشّْ نِّيغْ إِ لْمَالَاكْ نِّي كِيذِي إِسَّاوَاڒنْ: ”مِينْ عْنَانْ إِنَا؟“ نتَّا يَارَّا-د خَافِي: ”إِنَا ذ أَربْعَا ن وَاشَّاونْ نِّي إِزُّوزَارنْ يَاهُوذَا، إِسْرَائِيل ذ ؤُرْشَالِيمْ.“
\m 
\v 3 \add خنِّي\add* إِسّْشنْ أَيِي سِيذِي \bd أَربْعَا ن إِمْزِيڒنْ\bd*.
\v 4 \add ڒخْذنِّي\add* نشّْ نِّيغْ: ”مِينْ ؤُمِي د-ؤُسِينْ نِيثْنِي، مِينْ غَا ڭّنْ؟“ نتَّا إِسِّيوڒْ، إِنَّا: ”إِنَا ذ أَشَّاونْ نِّي إِزُّوزَارنْ يَاهُوذَا، أَڒَامِي وَارْ د-إِسّْڭعّذْ \add عَاذْ\add* ؤُڒَا ذ إِجّْ أَزدْجِيفْ نّسْ، مَاشَا إِنَا ؤُسِينْ-د حِيمَا أَذْ ثنْ سّْنخْڒْعنْ، حِيمَا أَذْ نْضَارنْ أَشَّاونْ ن ڒڭْنُوسْ نِّي د-إِسّْڭعّْذنْ إِشّْ ضِيدّْ إِ ثمُّورْثْ ن يَاهُوذَا حِيمَا أَذْ ت زُوزَّارنْ.“
\b
\s1 ثَامژْرِيوْثْ وِيسّْ ثْڒَاثَا - أَرْيَازْ س ؤُفِيڒُو ن ڒقْيَاسْ
\m 
\v 5 نشّْ سّْڭعّْذغْ ثِيطَّاوِينْ إِنُو، ژْرِيغْ، ؤُ خْزَارْ، أَقَا \add ذِينْ\add* إِجّْ ن ورْيَازْ س ؤُفِيڒُو ن ڒعْبَارْ ذڭْ ؤُفُوسْ نّسْ.
\v 6 نشّْ نِّيغْ: ”مَانِي غَا ثْرَاحذْ شكْ؟“ نتَّا يَارَّا-د ”\add نشّْ أَذْ رَاحغْ\add* حِيمَا أَذْ عْبَارغْ ؤُرْشَالِيمْ مَاحنْذْ أَذْ ژَترغْ مشْحَاڒْ \add ثدْجَا\add* ثِيرُو نّسْ ؤُ مشْحَاڒْ \add ثدْجَا\add* ثُوزّڭَّارْثْ نّسْ.“
\v 7 ؤُ خْزَارْ، إِفّغْ-د لْمَالَاكْ نِّي كِيذِي إِسَّاوَاڒنْ ؤُشَا إِجّْ ن لْمَالَاكْ نّغْنِي إِفّغْ-د حِيمَا أَذْ كِيذسْ إِمّڒْقَا،
\v 8 إِنَّا أَسْ: ”ذغْيثْ، سِيوڒْ أَكْ-ذ ؤُحُوذْرِي نِّي، إِنِي:
\b
\m \qt ’ؤُرْشَالِيمْ أَذْ ذِينْ ثِيڒِي\qt*
\m \qt ثشُّورْ س ثْندَّامْ نُورّْزْمنْثْ بْڒَا ڒحْيُوضْ\qt*
\m \qt زِي سِّيبّثْ ن وَاطَّاسْ ن إِوْذَانْ ذ ڒْمَاڒْ\qt*
\m \qt \tl إِ إِدْجَانْ\tl* ذِي ڒْوسْطْ نّسْ.\qt*
\m 
\v 9 \qt نشّْ أَذْ أَسْ إِڒِيغْ ذ إِجّْ ن ڒْحِيضْ ن ثْمسِّي\qt*
\m \qt إِ ذ أَسْ-د إِتّنّْضنْ، إِقَّارْ سِيذِي،\qt*
\m \qt ؤُ ذِي ڒْوسْطْ نّسْ أَذْ أَسْ إِڒِيغْ إِ ؤُعُودْجِي.\qt*
\b
\m 
\v 10 \qt ذغْيَامْ، ذغْيَامْ، أَروْڒمْ\qt*
\m \qt زِي ثمُّورْثْ ن شَّامَالْ،\qt*
\m \qt \tl أَمُّو إِ\tl* إِقَّارْ سِيذِي،\qt*
\m \qt مَاغَارْ نشّْ بْضِيغْ كنِّيوْ\qt*
\m \qt أَمْ أَربْعَا ن إِسمِّيضنْ ن ؤُجنَّا،\qt*
\m \qt \tl أَمُّو إِ\tl* إِقَّارْ سِيذِي.\qt*
\m 
\v 11 \qt ذغْيَاثْ، صِيهْيُونْ، فكّثْ،\qt*
\m \qt \tl شمْ\tl* ذ ثنِّي إِزدّْغنْ\qt*
\m \qt غَارْ يدْجِيسْ ن بَابِيلْ!‘ “\qt*
\b
\m 
\v 12 \bd ”مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ:\bd*
\b
\m \qt ’ذِي طّْوعْ ن ؤُعُودْجِي،\qt*
\m \qt إِسّكّْ أَيِي-د نتَّا غَارْ ڒڭْنُوسْ\qt*
\m \qt نِّي زَّايْسنْ تّْوَاكشّْضمْ،\qt*
\m \qt مَاغَارْ ونِّي كنِّيوْ إِ غَا إِحَاذَانْ،\qt*
\m \qt إِحَاذَا مُومُّو ن ثِيطّْ إِنُو.\qt*
\m 
\v 13 \qt مَاغَارْ خْزَارْ، نشّْ سّنْهزّغْ.\qt*
\m \qt أَفُوسْ إِنُو خَاسنْ،\qt*
\m \qt ؤُ نِيثْنِي أَذْ ذوْڒنْ ذ ثَاكشَّاضْثْ\qt*
\m \qt ن إِمْسخَّارنْ نْسنْ.\qt*
\m \qt كنِّيوْ أَذْ ثسّْنمْ\qt*
\m \qt أَقَا إِسّكّْ أَيِي-د سِيذِي ن ڒْعسْكَارَاثْ.\qt*
\m 
\v 14 \qt سْڒِيوْڒوْ ؤُ فَارْحْ، \tl أَ\tl* يدْجِيسْ ن صِيهْيُونْ،\qt*
\m \qt مَاغَارْ خْزَارْ، نشّْ أَذْ د-أَسغْ\qt*
\m \qt ؤُ أَذْ زذْغغْ ذِي ڒْوسْطْ نّمْ،\qt*
\m \qt \tl أَمُّو\tl* إِ إِقَّارْ سِيذِي.‘\qt* \x ◘ \xo 2:‏14 \xt لَاوِي 26‏:‏12؛ حِز. 37‏:‏27؛ 2 كُور. 6‏:‏16\x*
\b
\m 
\v 15 \bdit ’ذڭْ وَاسّْ نِّي،\bdit*
\m \qt أَذْ قّْننْ وَاطَّاسْ ن ڒڭْنُوسْ غَارْ سِيذِي،\qt*
\m \qt ؤُ نِيثْنِي أَذْ إِڒِينْ ذ ڒْڭنْسْ إِنُو.\qt*
\m \qt نشّْ أَذْ زذْغغْ ذِي ڒْوسْثْ نّمْ\qt*
\m \qt ؤُ أَذْ ثسّْنذْ، أَقَا سِيذِي ن ڒْعسْكَارَاثْ\qt*
\m \qt إِسّكّْ أَيِي-د غَارمْ.\qt* \x ◘ \xo 2:‏15 \xt إِزهد. 22‏:‏1 بُط. 2‏:‏9\x*
\m 
\v 16 \qt سِيذِي أَذْ إِطّفْ يَاهُوذَا ذ ثَاسْغَارْثْ نّسْ\qt*
\m \qt خْ ثمُّورْثْ إِقدّْسنْ.\qt*
\m \qt نتَّا أَذْ إِفَارْزْ ؤُرْشَالِيمْ عَاذْ.\qt*
\m 
\v 17 \qt أجّْ مَارَّا دَّاثْ أَذْ إِسّغْذْ\qt*
\m \qt زَّاثْ إِ وُوذمْ ن سِيذِي،\qt*
\m \qt مَاغَارْ نتَّا إِفَاقْ-د\qt*
\m \qt زِي ثْزذِّيغْثْ نّسْ إِقدّْسنْ.‘ “\qt*
\b
\b
\c 3
\s1 ثَامژْرِيوْثْ وِيسّْ أَربْعَا- أَكهَّانْ أَمقّْرَانْ يَاهُوشَاعْ
\m 
\v 1 \add أَوَارْنِي أَسْ\add* إِسّْشنْ أَيِي يَاهُوشَاعْ، أَرَّايْسْ ن إِكهَّاننْ. نتَّا ثُوغَا إِبدّْ زَّاثْ إِ وُوذمْ ن لْمَالَاكْ ن سِيذِي. شِّيطَانْ إِبدّْ-د غَارْ ؤُفُوسْ أَفُوسِي ن يَاشُوعَا حِيمَا أَذْ زَّايسْ إِسّْشثْشَا.
\v 2 سِيذِي إِنَّا إِ شِّيطَانْ: ”أَذْ يِيڒِي أَذْ شكْ إِعَاقبْ سِيذِي، \add أَ\add* شِّيطَانْ! أَذْ شكْ إِعَاقبْ سِيذِي، ونِّي إِفَارْزنْ ؤُرْشَالِيمْ! مَا وَارْ إِدْجِي \add يَاهُوشَاعْ وَانِيثَا\add* ذ إِجّْ ن ؤُكشُّوضْ قڒْعنْ ث-د زِي ثْمسِّي؟“ \x ◘ \xo 3:‏2 \xt يَاه. 9\x*
\v 3 يَاهُوشَاعْ ثُوغَا يَارْضْ أَرُّوضْ إِوسّْخنْ أَمْ إِبدّْ زَّاثْ إِ وُوذمْ ن لْمَالَاكْ.
\m 
\v 4 \add خنِّي\add* إِطّفْ نتَّا ذڭْ وَاوَاڒْ ؤُشَا إِسِّيوڒْ أَكْ-ذ يِينِّي إِبدّنْ زَّاثْ إِ وُوذمْ نّسْ، إِنَّا: ”كّْسمْ أَسْ أَرُّوضْ إِوسّْخنْ إِ وَانِيثَا!“ \add خنِّي\add* إِنَّا أَسْ: ”خْزَارْ، نشّْ كّْسغْ زَّايكْ ڒْمُوعْصِييّثْ نّشْ ؤُ أَذْ شكْ سّْيَارْضغْ س إِجّْ ن وَارُّوضْ إِشُووَّارنْ.“ \x ◘ \xo 3:‏4 \xt مِيخَا 7‏:‏18\x*
\v 5 نشّْ نِّيغْ: ”أَذْ أَسْ قّْننْ إِشْثْ ن أَرژّثْ ثَامزْذَاڭْثْ خْ ؤُزدْجِيفْ نّسْ!“ ؤُ نِيثْنِي قّْننْ أَسْ أَرژّثْ ثَامزْذَاڭْثْ خْ ؤُزدْجِيفْ نّسْ ؤُشَا سّْيَارْضنْ أَسْ أَرُّوضْ \add إِشُووَّارنْ\add*، أَمْ ثُوغَا لْمَالَاكْ ن سِيذِي إِبدّْ ذِينْ
\v 6 \add خَاسْ ؤُشَا\add* إِشْهذْ لْمَالَاكْ ن سِيذِي إِ يَاهُوشَاعْ، إِنَّا:
\b
\m 
\v 7 \bd ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ:\bd*
\b
\m \qt ’مَاڒَا شكْ ثُويُورذْ خْ إِبْرِيذنْ إِنُو،\qt*
\m \qt ؤُ مَاڒَا شكْ أَذْ ثحْضِيذْ ثَاسخَّارْثْ إِنُو،\qt*
\m \qt خنِّي أَذْ ثسُّويُورذْ\qt*
\m \qt ؤُڒَا ذ ثَادَّارْثْ إِنُو س ڒْحقّْ\qt*
\m \qt ؤُ أَذْ ثِيڒِيذْ ذ أَمحْضَايْ ن ڒمْرَاحَاثْ إِنُو،\qt*
\m \qt ؤُ نشّْ أَذْ أَشْ وْشغْ\qt*
\m \qt أَذْ ثْزمَّارذْ أَذْ ثْرَاحذْ أَذْ ثَاذْفذْ\qt*
\m \qt جَارْ إِنِّي ذَا إِبدّنْ.\qt*
\m 
\v 8 \qt خنِّي سڒْ، يَاهُوشَاعْ،\qt*
\m \qt \tl شكْ،\tl* أَرَّايْسْ ن إِكهَّاننْ،\qt*
\m \qt شكْ ذ إِمدُّوكَّاڒْ نّشْ،\qt*
\m \qt إِنِّي إِقِّيمنْ زَّاثكْ،\qt*
\m \qt مَاغَارْ نِيثْنِي ذ إِشْثْ ن ڒعْڒَامثْ ن ؤُثبْهثْ،\qt*
\m \qt مَاغَارْ خْزَارْ، نشّْ أَذْ د-أَوْيغْ\qt*
\m \qt أَمْسخَّارْ إِنُو، ’أَغدُّو‘.\qt* \x ◘ \xo 3:‏8 \xt إِشا. 4‏:‏2؛ 11‏:‏1؛ إِرْم. 23‏:‏5؛ 33‏:‏15؛ زَاك. 6‏:‏12\x*
\m 
\v 9 \qt مَاغَارْ خْزَارْ، أَژْرُو،\qt*
\m \qt ونِّي ذِينْ سَّارْسغْ زَّاثْ إِ يَاهُوشَاعْ،\qt*
\m \qt خْ وژْڒُو نِّي \tl خزَّارنْثْ\tl* سبْعَا ن ثِيطَّاوِينْ.\qt*
\m \qt خْزَارْ، نشّْ أَذْ \tl ذَايسْ\tl* نقْشغْ\qt*
\m \qt ثَانقَّاشْثْ نّسْ،\qt*
\m \qt \tl أَمُّو\tl* إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ،\qt*
\m \qt ؤُ نشّْ أَذْ كّْسغْ\qt*
\m \qt ڒْمُوعْصِييّثْ ن ثمُّورْثْ-أَ\qt*
\m \qt ذڭْ إِجّْ ن وَاسّْ!\qt*
\m 
\v 10 \bdit ذڭْ وَاسّْ نِّي،\bdit* \qt إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ،\qt*
\m \qt أَذْ ثْعَارْضمْ إِجّْ إِ ونّغْنِي\qt*
\m \qt سَاذُو ثْزَايَارْثْ ؤُ سَاذُو وَارْثُو.‘ “\qt*
\b
\b
\c 4
\s1 ثَامژْرِيوْثْ وِيسّْ خمْسَا - ڒْقنْذِيڒْ ذ ثْنَاينْ ن ثْزِيثُونِينْ
\m 
\v 1 لْمَالَاكْ نِّي كِيذِي إِسَّاوَاڒنْ، إِعْقبْ-د ؤُشَا إِسّْفَاقْ أَيِي-د أَمْ مَامّشْ د-سّْفَاقَانْ إِجّْ ن ورْيَازْ زڭْ يِيضصْ نّسْ.
\v 2 نتَّا إِنَّا أَيِي: ”مِينْ ثژْرِيذْ؟“ نشّْ نِّيغْ: ”نشّْ ژْرِيغْ، ؤُ خْزَارْ، إِجّْ نْ ڒْقنْذِيڒْ ن وُورغْ مَارَّا، ؤُ \add أَقَا ذِينْ\add* إِجّْ ن طّبْصِي ن زّشْثْ خْ ؤُزدْجِيفْ نّسْ ؤُ خَاسْ سبْعَا ن ڒفْنَارَاثْ، سبْعَا \add سنّجْ إِ\add* سبْعَا ن إِبُوضنْ إِ ڒفْنَارَاثْ \add إِ إِدْجَانْ\add* خْ ؤُزدْجِيفْ نّسْ
\v 3 ؤُ زَّاثسْ \add أَقَا ذِينْ\add* ثْنَاينْ ن إِزمُّورنْ، إِجّْ غَارْ ؤُغزْذِيسْ أَفُوسِي ن طّبْصِي \add ن زّشْثْ\add* ؤُ إِجّْ غَارْ ؤُزڒْمَاضْ نّسْ.“
\m 
\v 4 نشّْ أَرِّيغْ-د ؤُ سِّيوْڒغْ أَكْ-ذ لْمَالَاكْ نِّي كِيذِي إِسَّاوَاڒنْ، نِّيغْ: ”سِيذِي إِنُو، مِينْ عْنَانْثْ ثْمسْڒَايِينْ-أَ؟“
\v 5 لْمَالَاكْ نِّي كِيذِي إِسَّاوَاڒنْ، يَارَّا-د، إِنَّا أَيِي: ”مَا وَارْ ثسِّينذْ شكْ، مِينْ عْنَانْثْ ثْمسْڒَايِينْ-أَ؟“ نشّْ نِّيغْ: ”لَّ، \add أَ\add* سِيذِي إِنُو!“
\m 
\v 6 \add خنِّي\add* يَارَّا-د ؤُشَا إِسِّيوڒْ-د أَكِيذِي، إِنَّا: ”وَا ذ أَوَاڒْ ن سِيذِي إِ زَارُوبَّابِيلْ، \add أَوَاڒْ\add* نِّي إِقَّارْ: ’وَارْ إِدْجِي س جّهْذْ ؤُڒَا س لْعُونْفْ، مَاشَا أَذْ يِيڒِي س أَرُّوحْ إِنُو!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ. \x ◘ \xo 4:‏6 \xt حُوش. 1‏:‏7\x*
\v 7 مِينْ ثعْنِيذْ شكْ، \add أَ\add* أَذْرَارْ أَمقّْرَانْ؟ أَذْ ثْذوْڒذْ ذ إِشْثْ نْ ڒْوَاطَا زَّاثْ إِ وُوذمْ ن زَارُوبَّابِيلْ، مَاغَارْ نتَّا أَذْ د-إِسُّوفّغْ أَژْرُو ن نّجْ س إِغُويَّانْ إِجهْذنْ: ’أَرْضَا، أَرْضَا أَذْ غَارسْ يِيڒِي!‘ “
\m 
\v 8 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 9 ”إِفَاسّنْ ن زَارُوبَّابِيلْ سَّارْسنْ ذْسَاسْ إِ ثَادَّارْثْ-أَ، إِفَاسّنْ نّسْ أَذْ ت كمّْڒنْ، مَاحنْذْ أَذْ ثسّْنمْ أَقَا سِيذِي ن ڒْعسْكَارَاثْ إِسّكّْ أَيِي-د غَارْومْ.
\v 10 مَاغَارْ مَانْ ونْ إِسّحْقَارَانْ أَسّْ ن ثْمسْڒَايِينْ ثِيمژْيَانِينْ؟ سبْعَا \add ن ثِيطَّاوِينْ\add* نِّي ڭُّورْ أَذْ فَارْحنْ، خْمِي غَا ژَترنْ أَژْرُو ن ثغْمَارْثْ ذڭْ ؤُفُوسْ ن زَارُوبَّابِيلْ، أَقَا أَثنْثْ ثِيطَّاوِينْ ن سِيذِي نِّي إِتّكّنْ مَارَّا ثَامُّورْثْ.“
\m 
\v 11 نشّْ أَرّغْ-د، نِّيغْ أَسْ: ”مَانَا ثْنَاينْ ن إِزمُّورنْ نِّي \add ذِينْ\add* غَارْ ؤُغزْذِيسْ أَفُوسِي ذ ؤُژرْمَاضْ ن ڒْقنْذِيڒْ؟“
\v 12 أَرْنِيغْ طّْفغْ ذڭْ وَاوَاڒْ، نِّيغْ أَسْ: ”مِينْ عْنَانْ ثْنَاينْ ن ڒفْرُوعْ ن ؤُزمُّورْ \add نِّي إِدْجَانْ\add* سنّجْ إِ ثْنَاينْ ن إِقُوذَاسْ ن وُورغْ، ذ يِينِّي إِتّْفَارَّاغنْ \add زّشْثْ س ثِينْثَا نّسْ ن\add* وُورغْ \add س ثْنَاينْ ن إِقُوذَاسْ نِّي\add*؟“
\v 13 نتَّا إِسَّاوَاڒْ-د غَارِي، إِنَّا: ”مَا وَارْ ثسِّينذْ شكْ مِينْ عْنَانْ إِنَا؟“ نشّْ نِّيغْ: ”لَّ، \add أَ\add* سِيذِي إِنُو!“
\v 14 \add خنِّي\add* إِنَّا: ”إِنَا ذ ثْنَاينْ ن إِحنْجِيرنْ إِ إِتّْوَاذهْننْ س زّشْثْ نِّي إِبدّنْ زَّاثْ إِ سِيذِي ن مَارَّا ثَامُّورْثْ.“
\b
\b
\c 5
\s1 ثَامژْرِيوْثْ وِيسّْ ستَّا - أَذْلِيسْ إِتّْوَانّْضنْ إِطَّاونْ
\m 
\v 1 سّْڭعّْذغْ ثِيطَّاوِينْ إِنُو ثْوَاڒَا نّغْنِي ؤُشَا ژْرِيغْ، ؤُ خْزَارْ، أَقَا \add ذِينْ\add* \bd إِجّْ ن وذْلِيسْ إِتّْوَانّْضنْ إِطَّاوْ\bd*.
\v 2 نتَّا إِنَّا أَيِي: ”مِينْ ثتّْوَاڒِيذْ شكْ؟“ نشّْ نِّيغْ: ”نشّْ تّْوَاڒِيغْ إِجّْ ن وذْلِيسْ إِتّْوَانّْضنْ إِطَّاوْ س يِيجّْ ن ثُوزّڭَّارْثْ ن عِيشْرِينْ ن إِغَادْجنْ ذ إِشْثْ ن ثِيرُو نعشْرَا ن إِغَادْجنْ.“
\v 3 \add خنِّي\add* إِنَّا أَيِي: ”ثَا ذ نّعْڒثْ نِّي إِ غَا إِفّْغنْ خْ مَارَّا ثَامُّورْثْ، مَاغَارْ مَارَّا ونِّي إِ غَا يَاشَارنْ، أَذْ إِتّْوَاقْضعْ زِي سِّيبّثْ ن مِينْ يُورَانْ خْ ؤُغزْذِيسْ-أَ ؤُ كُوڒْ إِجّْ ونِّي إِ غَا إِجَّادْجنْ ژُورْ أَذْ إِتّْوَاقْضعْ زِي سِّيبّثْ ن مِينْ يُورَانْ خْ ؤُغزْذِيسْ نّغْنِي.
\v 4 نشّْ أَذْ أَرّغْ نّعْڒثْ أَذْ د-ثفّغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، حِيمَا أَذْ د-ثَاسْ ذِي ثَادَّارْثْ ن ؤُشفَّارْ ؤُ ذِي ثَادَّارْثْ ن يِينِّي إِتّْجَادْجَانْ ژُورْ س يِيسمْ إِنُو. نتَّاثْ أَذْ ثسّنْسْ ذِي ڒْوسْثْ ن ثَادَّارْثْ نّسْ ؤُ نتَّاثْ أَذْ ت يشّْ س ؤُكشُّوضْ نّسْ ذ إِژْرَا نّسْ.“
\b
\s1 ثَامژْرِيوْثْ وِيسّْ سبْعَا - ثَامْغَارْثْ ذِي إِفَا
\m 
\v 5 إِفّغْ-د لْمَالَاكْ نِّي كِيذِي إِسَّاوَاڒنْ، إِنَّا أَيِي: ”سْڭعّذْ ثِيطَّاوِينْ نّشْ ؤُ خْزَارْ مِينْ \add ذِينْ\add* د-إِتّْبَاننْ!“
\v 6 نشّْ نِّيغْ: ”مَانَاوْيَا؟“ نتَّا إِنَّا: ”وَا ذ \bd ڒْْمُوذْ ن إِفَا\bd* نِّي د-إِتّْبَاننْ.“ \add خنِّي\add* إِنَّا: ”ثَا ذ فُورْمَا نْسنْ خْ مَارَّا ثَامُّورْثْ.“
\v 7 ؤُ خْزَارْ، أَقَا ثتّْوَاسّْڭعّذْ ثْقبَّارْثْ ن ڒخْفِيفْ \add ذ ثَاقُورَارِيرْثْ\add* ؤُ ثقِّيمْ إِشْثْ ن ثمْغَارْثْ ذِي ڒْوسْطْ ن إِفَا.
\v 8 نتَّا إِنَّا: ”ثَا ذ ثَاعفَّانْثْ!“ ؤُشَا إِنْضَارْ إِ-ت \add عَاوذْ\add* ذڭْ إِفَا نِّي ؤُشَا إِنْضَارْ أَژْرُو ن ڒخْفِيفْ خْ ؤُقمُّومْ نّسْ.
\v 9 نشّْ سّْڭعّْذغْ ثِيطَّاوِينْ إِنُو ؤُشَا ژْرِيغْ، ؤُ خْزَارْ ثْنَاينْ ن ثمْغَارِينْ ؤُسِينْثْ-إِ-د غَارْ زَّاثْ ؤُ أَسمِّيضْ إِشُّورْ أَفْرِيونْ نْسنْثْ. نِيثنْثِي ثُوغَا غَارْسنْثْ أَفْرِيونْ أَمْ وَافْرِيونْ ن ؤُبلَّارْجْ ؤُ نِيثنْثِي سّْڭعّْذنْثْ إِفَا \add نِّي\add* جَارْ ثمُّورْثْ ذ ؤُجنَّا.
\v 10 \add خنِّي\add* نِّيغْ إِ لْمَالَاكْ نِّي كِيذِي إِسَّاوَاڒنْ: ”مَانِي غَا رَاحنْثْ أَكْ-ذ إِفَا-يَا؟“
\v 11 نتَّا إِنَّا أَيِي: ”مَاحنْذْ أَذْ أَسْ بْنَانْ إِشْثْ ن ثَادَّارْثْ ذِي ثمُّورْثْ ن شِينَارْ. مَاڒَا ثتّْوَاكمّڒْ، أَذْ ثتّْوَاسّْبدّْ ذِينْ ذڭْ ومْشَانْ نّسْ.“
\b
\b
\c 6
\s1 أَنڭَّارْ ن ثْمژْرِيوْثْ وِيسّْ أَمزْوَارُو - أَربْعَا ن إِكَارُّوثنْ
\m 
\v 1 نشّْ سّْڭعّْذغْ ثِيطَّاوِينْ إِنُو ثْوَاڒَا نّغْنِي، ؤُ خْزَارْ، أَقَا أَربْعَا ن إِكَارُّوثنْ فّْغنْ-د زِي جَارْ ثْنَاينْ ن إِذُورَارْ ؤُ إِذُورَارْ \add نِّي\add* ثُوغَا ذ إِذُورَارْ ن نّْحَاسْ.
\v 2 غَارْ ؤُكَارُّو أَمزْوَارُو \add ثُوغَا ذِينْ\add* إِيْسَانْ ذ إِزڭّْوَاغنْ، غَارْ ؤُكَارُّو وِيسّْ ثْنَاينْ إِيْسَانْ ذ إِبَارْشَاننْ،
\v 3 غَارْ ؤُكَارُّو وِيسّْ ثْڒَاثَا إِيْسَانْ ذ إِشمْڒَاڒنْ ؤُ غَارْ ؤُكَارُّو وِيسّْ أَربْعَا إِيْسَانْ ذ إِقَارْقَاشنْ، \add أَقَا أَثنْ ذ إِيْسَانْ\add* جهْذنْ.
\v 4 نشّْ أَرِّيغْ-د، نِّيغْ إِ لْمَالَاكْ نِّي كِيذِي إِسَّاوَاڒنْ: ”مِينْ عْنَانْ إِنَا، \add أَ\add* سِيذِي إِنُو؟“
\m 
\v 5 يَارَّا-د لْمَالَاكْ، إِنَّا أَيِي: ”إِنَا ذ أَربْعَا ن إِسمِّيضنْ ن ؤُجنَّا نِّي د-إِتّفّْغنْ زِي مَانِي بدّنْ زَّاثْ إِ سِيذِي ن مَارَّا ثَامُّورْثْ.
\v 6 إِنِّي س إِيْسَانْ إِبَارْشَاننْ أَذْ فّْغنْ غَارْ ثمُّورْثْ ن شَّامَالْ ؤُ \add إِيْسَانْ\add* إِشمْڒَاڒنْ أَذْ ثنْ ضفَّارنْ، ؤُشَا \add إِيْسَانْ\add* إِقَارْقَاشنْ أَذْ فّْغنْ غَارْ ثمُّورْثْ ن لْجَانُوبْ.“
\v 7 \add إِيْسَانْ\add* إِجهْذنْ فّْغنْ، أَرْزُونْ أَذْ ژْوَانْ ثَامُّورْثْ، \add مَاغَارْ\add* نتَّا إِنَّا: ”فّْغمْ، ژْوَامْ ثَامُّورْثْ!“ ؤُ نِيثْنِي ژْوَانْ ثمُّورْثْ.
\v 8 نتَّا إِڒَاغَا أَيِي-د، إِنَّا: ”خْزَارْ، \add إِيْسَانْ\add* نِّي إِفّْغنْ غَارْ ثمُّورْثْ ن شَّامَالْ، أَقَا سَّاريّْحنْ أَرُّوحْ إِنُو ذِي ثمُّورْثْ ن شَّامَالْ.“ \f ◼ \fr 6:‏8 \ft \bd ’سَّاريّْحنْ أَرُّوحْ إِنُو‘\bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي بلِّي ڒْحُوكْمْ نِّي سِّيوْضنْ إِيْسَانْ إِبَارْشَاننْ خْ ثمُّورْثْ ن شَّامَالْ إِسّْجِّيونْ أَرُّوحْ ن أَربِّي. أَقَا ڒْحَاكَامَاثْ نّسْ إِسڭّْذنْ ؤُمِي نتَّا ذ أَمْسڭّذْ.\f*
\b
\s1 تَّاجْ إِ ؤُكهَّانْ أَمقّْرَانْ
\m 
\v 9 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 10 ”كْسِي ثِيوْهِيبِينْ زڭْ أَيْثْ ن لْمنْفَا، زِي حَالِيمْ، طُوبِييَا ذ يَاذَاعْيَا ؤُ رُوحْ ذِينِّي \add ؤُڒَا ذ\add* شكْ \bd ذڭْ وَاسّْ نِّي\bd* ؤُ أَذفْ غَارْ ثَادَّارْثْ ن يُوشِييَا، مِّيسْ ن صَافَانْيَا، \add غَارْ ثَادَّارْثْ\add* إِ غَارسْ د-يُوسِينْ زِي بَابِيلْ. \f ◼ \fr 6:‏10 \ft \bd ’صَافَانْيَا‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي ث إِسّْنُوفَّارنْ سِيذِي‘.\f*
\v 11 كْسِي نُّوقَارْثْ ذ وُورغْ، أڭّْ \add زَّايْسنْ\add* تِّيجَانْ ؤُ سَارْسْ \add إِ-ثنْ\add* خْ ؤُزدْجِيفْ ن يَاهُوشَاعْ، مِّيسْ ن يَاهُوصَاذَاقْ، أَرَّايْسْ ن إِكهَّاننْ،
\v 12 ؤُ سِيوڒْ أَكِيذسْ، إِنِي أَسْ:
\b
\m ’أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: خْزَارْ، إِجّْ ن ورْيَازْ، ’أَغدُّو‘ ذ إِسمْ نّسْ. نتَّا أَذْ د-إِفّغْ زڭْ ومْشَانْ نّسْ ؤُ نتَّا أَذْ إِبْنَا زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي.
\v 13 نتَّا أَذْ إِبْنَا زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي ؤُ أَذْ يَارْضْ لْعَاضَامَا. نتَّا أَذْ إِقِّيمْ ؤُ أَذْ إِحْكمْ خْ ڒْعَارْشْ نّسْ ؤُ نتَّا أَذْ يِيڒِي ذ أَكهَّانْ خْ ڒْعَارْشْ نّسْ ؤُ أَذْ يِيڒِي جَارْ أَسنْ شّْوَارْ س ڒهْنَا.‘
\b
\m 
\v 14 تِّيجَانْ أَذْ إِڒِينْ إِ حَالِيمْ، طُوبِييَا، يَاذَاعْيَا ذ حَايْنْ، مِّيسْ ن صَافَانْيَا، ذ ڒِيذَارثْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي. \f ◼ \fr 6:‏14 \ft \bd ’حَايْنْ‘\bd* - إِخْسْ أَذْ يِينِي ’ڒْخَاضَارْ‘.\f*
\v 15 زِي ڒَاڭّْوَاجْ أَذْ د-أَسنْ \add إِوْذَانْ\add* ؤُ نِيثْنِي أَذْ بْنَانْ زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي ؤُ كنِّيوْ أَذْ ثسّْنمْ أَقَا سِيذِي ن ڒْعسْكَارَاثْ إِسّكّْ أَيِي-د غَارْومْ. \add أَيَا\add* أَذْ إِمْسَارْ، مَاڒَا كنِّيوْ ثتّسْڒَامْ س ثِيذتّْ غَارْ ثْمِيجَّا ن سِيذِي، أَربِّي نْومْ.“ \x ◘ \xo 6:‏15 \xt Ḥag. 2‏:‏7 \x*
\b
\b
\c 7
\s1 إِسقْسِيثنْ خْ ؤُسَّانْ ن ؤُژُومِّي - أَوَاڒْ أَمزْوَارُو ن سِيذِي
\m 
\v 1 \bd إِمْسَارْ ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعَا ن ؤُجدْجِيذْ ذَارِييُوسْ،\bd* \add ڒَْامِي\add* د-يُوسَا وَاوَاڒْ ن سِيذِي غَارْ زَاكَارِييَّا، \bd ذڭْ \bdit وَاسّْ\bdit* وِيسّْ أَربْعَا ن ؤُيُورْ وِيسّْ ثسْعَا، ذڭْ \bdit ؤُيُورْ\bdit* ن كِيسْلُووْ،\bd*
\v 2 \add أَقَا\add* إِسّكّْ \add ڒْْڭنْسْ ن\add* بَايْثْ-إِلْ شَارَاصِيرْ ذ رَاجَامْ-مَالِيكْ ذ يرْيَازنْ نّسْ مَاحنْذْ أَذْ تَّارنْ أَرْضَا زَّاثْ إِ وُوذمْ ن سِيذِي،
\v 3 ؤُمِي سَّاوَاڒنْ أَكْ-ذ إِكهَّاننْ، إِنِّي \add إِدْجَانْ\add* ذِي ثَادَّارْثْ ن سِيذِي ن ڒْعسْكَارَاثْ، ؤُ أَكْ-ذ إِنَابِييّنْ، قَّارنْ: ”مَا أَذْ أَرْنِيغْ ذڭْ ؤُيُورْ وِيسّْ خمْسَا أَذْ رُوغْ ؤُ أَذْعزْڒغْ إِخفْ إِنُو أَمْ مَامّشْ ث تّڭّغْ ڒخُّو عَاذْ أَطَّاسْ ن إِسڭّْوُوسَا؟“
\b
\m 
\v 4 \bd يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي ن ڒْعسْكَارَاثْ، إِنَّا:\bd*
\b
\m 
\v 5 ”سِيوڒْ أَكْ-ذ مَارَّا ڒْڭنْسْ ؤُ أَكْ-ذ إِكهَّاننْ، إِنِي: ڒَامِي كنِّيوْ ثْژُومّمْ ؤُ ثوْثِيمْ خْ إِذْمَارنْ نْومْ \add زڭْ وشْضَانْ\add*، ذڭْ ؤُيُورْ وِيسّْ خمْسَا ؤُ ذڭْ ؤُيُورْ وِيسّْ سبْعَا، ؤُ مَانْ أَيَا ڒخُّو عَاذْ أَطَّاسْ ن إِسڭّْوُوسَا، مَا ثْژُومّمْ كنِّيوْ \add خنِّي\add* إِ نشّْ، \add س ثِيذتّْ\add* إِ نشّْ؟
\v 6 ڒَامِي ثشِّيمْ ؤُ ڒَامِي ثسْوِيمْ، مَا وَارْ ثِيشِّيمْ \add إِ يِيخفْ نْومْ\add* ؤُ مَا وَارْ ثِيسْوِيمْ \add إِ يِيخفْ نْومْ\add*؟
\v 7 مَا وَارْ ثُوغِي إِڒِيقْ أَذْ يِيڒِي زِي سِّيبّثْ ن وَاوَاڒنْ إِ إِجَّا سِيذِي أَذْ تّْوَابَارّْحنْ س ؤُفُوسْ ن إِنَابِييّنْ ن زِيشْ ؤُمِي ثُوغَا ثقِّيمْ ؤُرْشَالِيمْ \add عَاذْ\add* س إِمزْذَاغْ ذِي ڒْهُوذْنثْ أَكْ-ذ ثْندَّامْ إِ ذ أَسْ د-إِنّْضنْ، ؤُ ڒَامِي ثُوغَا \add عَاذْ\add* إِمزْذَاغْ ذِي \add ثَامُّورْثْ ن\add* لْجَانُوبْ ؤُ ذِي ثمُّورْثْ إِوَاطَانْ؟“
\b
\m 
\v 8 \bd يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ زَاكَارِييَّا، إِنَّا:\bd*
\b
\m 
\v 9 \bd ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ\bd*، إِ إِقَّارنْ: ’حكْممْ س إِجّْ ن ڒْحُوكْمْ إِسڭّْذنْ ؤُ ڭّمْ س ثْمخْسِيوْثْ إِشوَّارنْ ذ أَرّحْمثْ إِجّْ أَكْ-ذ ونّغْنِي.
\v 10 وَارْ حصَّارمْ ثَاجَّاتْشْ ؤُڒَا ذ أَيُوجِيڒْ نِيغْ ڒْبَارَّانِي ؤُڒَا ذ أَمژْڒُوضْ، ؤُ وَارْ تّجِّيمْ ؤُڒَا ذ إِجّْ أَذْ إِخَارّصْ ذِي ڒْغَارْ ضِيدّْ إِ ؤُمَاسْ ذڭْ وُوڒْ نّسْ!‘ \x ◘ \xo 7:‏10 \xt ؤُف. 22‏:‏22\x*
\v 11 \add مَاشَا\add* نِيثْنِي ؤُڭِينْ أَذْ وْشنْ ثَايْنِيثْ ؤُ نِيثْنِي ڭِّينْ مَارَّا س ڒْمقْڒُوبْ ؤُ بلّْعنْ إِمزُّوغنْ نْسنْ، حِيمَا وَارْ تّسْڒِينْ.
\v 12 نِيثْنِي سّْقسْحنْ ؤُڒْ نْسنْ أَمْ يِيجّْ ن ؤُمسْمِيرْ، مَاحنْذْ وَارْ تّسْڒِينْ شَّارِيعَا ذ وَاوَاڒنْ نِّي د-إِسّكّْ سِيذِي ن ڒْعسْكَارَاثْ س أَرُّوحْ نّسْ س ؤُفُوسْ ن إِنَابِييّنْ ن زِيشْ، أَڒَامِي د-يُوسَا إِجّْ ن ؤُذُوقّزْ ذ أَمقّْرَانْ ن وغْضَابْ ن سِيذِي ن ڒْعسْكَارَاثْ.
\v 13 أَقَا إِمْسَارْ أَمْ مَامّشْ إِڒَاغَا نتَّا \add زِيشْ\add*، \add مَاشَا\add* نِيثْنِي وَارْ سْڒِينْ شَا. س ؤُينِّي ڒَاغَانْ \add ڒخُّو\add* نِيثْنِي ؤُ نشّْ وَارْ تّسْڒِيغْ شَا، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ. \x ◘ \xo 7:‏13 \xt أَوڒن. 1‏:‏28؛ إِشا. 1‏:‏15؛ إِرْم. 11‏:‏11؛ 14‏:‏12\x*
\v 14 نشّْ أَذْ ثنْ زُوزَّارغْ خْ مَارَّا ڒڭْنُوسْ نِّي ثُوغَا وَارْ سِّيننْ ؤُ أَوَارْنِي أَسنْ أَذْ ثتّْوَاخَارّبْ ثمُّورْثْ، ؤُڒَا ذ إِجّْ \add عَاذْ\add* وَارْ \add خَاسْ\add* إِژكّْوِي ؤُ ؤُڒَا ذ إِجّْ \add عَاذْ\add* وَارْ د-إِذِّيكّْوِيڒْ. نِيثْنِي أَرِّينْ ثَامُّورْثْ إِعِيزّنْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ.‘ “
\b
\b
\c 8
\s1 أَوَاڒْ وِيسّْ ثْنَاينْ ن سِيذِي - سِيذِي أَذْ إِبَاركْ ؤُرْشَالِيمْ
\m 
\v 1 \bd يُوسَا-د \bdit غَارِي\bdit* وَاوَاڒْ ن سِيذِي ن ڒْعسْكَارَاثْ، إِنَّا:\bd*
\b
\m 
\v 2 \bd ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ:\bd* ’س وَاسَامْ ذ أَمقّْرَانْ ؤُسْمغْ زِي صِيهْيُونْ، س وسْعَارْ ثَامقّْرَانْثْ ؤُسْمغْ ذِي طّْوعْ نّسْ.‘\x ◘ \xo 8:‏2 \xt زَاك. 1‏:‏14\x*
\v 3 \bd أَمُّو إِ إِقَّارْ سِيذِي:\bd* ’نشّْعقْبغْ-د غَارْ صِيهْيُونْ ؤُ أَذْ زذْغغْ ذِي ڒْوسْطْ ن ؤُرْشَالِيمْ ؤُشَا ؤُرْشَالِيمْ أَذْ أَسْ ڒَاغَانْ ’ثَانْذِينْثْ ن ثِيذتّْ!‘، ؤُ أَذْرَارْ ن سِيذِي ن ڒْعسْكَارَاثْ أَذْ أَسْ إِنِينْ ’أَذْرَارْ إِقدّْسنْ!‘ \x ◘ \xo 8:‏3 \xt أَسَا. 14‏:‏1‏-‏5\x*
\m 
\v 4 \bd أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ:\bd* ’أَذْ إِڒِينْ عَاوذْ إِوسُّورَا ذ ثْوسُّورَا ذڭْ وَازَّاينْ ن ؤُرْشَالِيمْ. \add كُوڒْ\add* أَرْيَازْ أَذْ غَارسْ ثِيڒِي ثغَّارْشْثْ نّسْ ذڭْ ؤُفُوسْ نّسْ زِي سِّيبّثْ ن وَاطَّاسْ ن وُوسَّانْ \add إِ غَا إِدَّارْ\add*.
\v 5 أَزَّاينْ ن ثنْذِينْثْ أَذْ ذوْڒنْ شُّورنْ س إِحنْجِيرنْ ذ ثْحنْجِيرِينْ إِ إِتِّيرَارنْ ذڭْ وَازَّاينْ نّسْ.‘
\m 
\v 6 \bd أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ:\bd* ’مَاغَارْ ذ ڒعْجبْ قَاعْ ذِي ثِيطَّاوِينْ ن مِينْ إِقِّيمنْ ن ڒْڭنْسْ-أَ ذڭْ وُوسَّانْ نِّي، مَا أَذْ يِيڒِي أَيَا ؤُڒَا إِ نشّْ ذ ڒعْجبْ قَاعْ؟‘، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.
\m 
\v 7 \bd أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ:\bd* ’خْزَارمْ، نشّْ أَذْ سّْنجْمغْ ڒْڭنْسْ إِنُو زِي ثمُّورْثْ ن ونْقَارْ \add ن ثْفُوشْثْ\add* ؤُ زِي ثمُّورْثْ ن ؤُغدْجِي ن ثْفُوشْثْ،
\v 8 ؤُ نشّْ أَذْ ثنْ أَوْيغْ ذِينْ حِيمَا أَذْ زذْغنْ ذِي ؤُرْشَالِيمْ. نِيثْنِي أَذْ إِڒِينْ ذ ڒْڭنْسْ إِ نشّْ ؤُ نشّْ أَذْ إِڒِيغْ ذ أَربِّي إِ نِيثْنِي، ذِي ثِيذتّْ ؤُ ذِي ثْسڭْذَا.‘
\m 
\v 9 \bd أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ:\bd* ’محْضمْ إِفَاسّنْ نْومْ، كنِّيوْ إِنِّي إِسْڒِينْ ذڭْ وُوسَّانْ-أَ أَوَاڒنْ-أَ زڭْ ؤُقمُّومْ ن إِنَابِييّنْ نِّي \add ذِينْ إِدْجَانْ\add* ذڭْ وَاسّْ نِّي ذِي إِتّْوَاسَّارْسْ ذْسَاسْ ن ثَادَّارْثْ ن سِيذِي ن ڒْعسْكَارَاثْ، مَاحنْذْ أَذْ \add خَاسْ\add* ثتّْوَابْنَا زَّاوشْثْ ثَامقّْرَانْثْ زِي جْذِيذْ.
\v 10 مَاغَارْ قْبڒْ إِ وُوسَّانْ نِّي وَارْ إِقِّيمْ وَالُو زِي ڒْمُونثْ ن بْنَاذمْ ؤُ إِشْثْ نْ ڒبْهِيمثْ وَارْ د-ثتَّاوِي وَالُو ؤُ ونِّي د-إِفّْغنْ ذ ونِّي د-إِذوْڒنْ، وَارْ يِيوِي ڒَامَانْ زِي سِّيبّثْ ن ڒعْذُو، \add مَاغَارْ\add* نشّْ سّكَّارغْ \add كُوڒْ\add* إِجّْ خْ جَّارْ نّسْ. \f ◼ \fr 8:‏10 \ft \bd ’\bdit كُوڒْ\bdit* إِجّْ خْ ؤُمْقَارّبْ نّسْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَرْيَازْ خْ ؤُمْقَارّبْ نّسْ‘.\f*
\v 11 \add ڒخُّو\add* مَاشَا نشّْ وَارْ تِّيڒِيغْ إِ مِينْ إِقِّيمنْ ن ڒْڭنْسْ-أَ أَمْ وُوسَّانْ إِمزْوُورَا، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.
\v 12 مَاغَارْ زَّارِيعثْ ن ڒهْنَا، ثَازَايَارْثْ، أَذْ ثوْشْ ڒْغِيدْجثْ نّسْ ؤُ ثَامُّورْثْ أَذْ ثوْشْ صَّابثْ نّسْ ؤُ أَجنَّا أَذْ إِوْشْ نّْذَا نّسْ ؤُ نشّْ أَذْ وْشغْ مَارَّا أَيَا ذ ثَاسْغَارْثْ إِ مِينْ إِقِّيمنْ ن ڒْڭنْسْ-أَ.
\v 13 أَذْ إِمْسَارْ، أَقَا أَمْ مَامّشْ ثُوغَا كنِّيوْ ذ نّعْڒثْ جَارْ رڭْنُوسْ، \add كنِّيوْ، أَ\add* ثَادَّارْثْ ن يَاهُوذَا ذ ثَادَّارْثْ ن إِسْرَائِيل، أَقَا نشّْ أَذْ كنِّيوْ سّْنجْمغْ ؤُ أَذْ إِڒِيغْ ذ لْبَارَاكَا إِ كنِّيوْ. وَارْ تّڭّْوذمْ، محْضمْ إِفَاسّنْ نْومْ!‘
\m 
\v 14 \bd مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ:\bd* ’أَمْ مَامّشْ نشّْ خَارّْصغْ أَذْ أَومْ ڭّغْ ڒْغَارْ، ڒَامِي ذ أَيِي سّْفُوڭْمنْ ڒجْذُوذْ نْومْ، \bd أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ\bd*، ؤُ نشّْ وَارْ نْذِيمغْ \add زِي مَانْ أَيَا\add*،
\v 15 أَمُّو إِ د-ذوْڒغْ نشّْ \add ڒخُّو\add* أَذْ خَارّْصغْ ذڭْ وُوسَّانْ-أَ مَاحنْذْ أَذْ ڭّغْ ڒْخَارْ ذِي ؤُرْشَالِيمْ ؤُ ذِي ثَادَّارْثْ ن يَاهُوذَا. وَارْ تّڭّْوذمْ شَا!
\v 16 ثِينَا ذ ثِيمسْڒَايِينْ إِ كنِّيوْ إِتّْخصَّانْ أَذْ ثنْثْ ثڭّمْ: سِيوْڒمْ ثِيذتّْ كُوڒْ إِجّْ أَكْ-ذ جَّارْ نّسْ، شَارّْعمْ ذِي ثوُّورَا نْومْ س ثِيذتّْ ؤُ س يِيجّْ نْ ڒْحُوكْمْ إِڒِيقّنْ. \x ◘ \xo 8:‏16 \xt أَفا. 4‏:‏25\x*
\v 17 وَارْ تّجِّيمْ أَذْ إِخَارّصْ إِجّْ ن ورْيَازْ ذِي ڒْغَارْ خْ جَّارْ نّسْ ؤُ وَارْ تّخْسمْ ثَاجَادْجِيثْ ژُورْ، مَاغَارْ نشّْ شَارّْهغْ مَارَّا أَيَا!‘، إِقَّارْ سِيذِي.“ \x ◘ \xo 8:‏17 \xt زَاك. 5‏:‏3، 4؛ 7‏:‏10\x*
\b
\m 
\v 18 \bd يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي ن ڒْعسْكَارَاثْ، إِنَّا:\bd*
\b
\m 
\v 19 \bd ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ:\bd* ’أَژُومِّي ن ؤُيُورْ وِيسّْ أَربْعَا ؤُ أَژُومِّي \add ن ؤُيُورْ\add* وِيسّْ خمْسَا ؤُ أَژُومِّي \add ن ؤُيُورْ\add* وِيسّْ سبْعَا ؤُ أَژُومِّي \add ن ؤُيُورْ\add* وِيسّْعشْرَا أَذْ ذوْڒنْ ذ ڒفْرَاحثْ ؤُ ذ وَارْشقْ إِ ثَادَّارْثْ ن يَاهُوذَا. أَذْ إِڒِينْ ذ ڒعْيُوذَاثْ شْنَانْ. خْسمْ ثِيذتّْ ذ ڒهْنَا!‘
\m 
\v 20 \bd أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ:\bd* ’أَقَا ڒڭْنُوسْ ؤُڒَا ذ إِمزْذَاغْ ن وَاطَّاسْ ن ثْندَّامْ أَذْ د-أَسنْ عَاذْ \add ذَانِيثَا\add*! \x ◘ \xo 8:‏20 \xt إِشا. 2‏:‏2، إِرْم. 16‏:‏19، مِيخَا 4‏:‏1، زَاك. 8‏:‏2\x*
\v 21 إِمزْذَاغْ ن إِشْثْ \add ن ثنْذِينْثْ\add* أَذْ رَاحنْ غَارْ إِمزْذَاغْ ن إِشْثْ \add ن ثنْذِينْثْ نّغْنِيثْ\add*، أَذْ إِنِينْ: جّمْ أَنغْ أَذْ نطّفْ أَبْرِيذْ حِيمَا أَذْ نتَّارْ \add زَّاثْ إِ\add* وُوذمْ ن سِيذِي ؤُ حِيمَا أَذْ نَارْزُو سِيذِي ن ڒْعسْكَارَاثْ. ؤُڒَا ذ نشّْ أَذْ رَاحغْ.
\v 22 أَطَّاسْ ن إِيْذُوذنْ ذ وَاطَّاسْ ن ڒڭْنُوسْ إِجهْذنْ أَذْ د-أَسنْ حِيمَا أَذْ أَرْزُونْ خْ وُوذمْ ن سِيذِي ن ڒْعسْكَارَاثْ ذِي ؤُرْشَالِيمْ ؤُ حِيمَا أَذْ تَّارنْ أَرْضَا زَّاثْ إِ وُوذمْ ن سِيذِي.‘
\m 
\v 23 \bd أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ:\bd* ’ذڭْ وُوسَّانْ نِّي أَذْ إِمْسَارْ، أَقَاعشْرَا ن يرْيَازنْ، زِي مَارَّا ثُوثْلَايِينْ ن ڒڭْنُوسْ أَذْ طّْفنْ، \add وَاهْ،\add* أَذْ طّْفنْ أَبحْڒُوڒْ ن إِجّْ ن ورْيَازْ ذ ؤُذَايْ، أَذْ إِنِينْ: ’نشِّينْ أَذْ نْرَاحْ أَكِيذْومْ، مَاغَارْ نسْڒَا أَقَا أَربِّي أَكِيذْومْ!‘ “
\b
\b
\c 9
\m 
\v 1 \bd ڒْْحُوكْمْ إِسَّاڭّْوَاذنْ ن وَاوَاڒْ ن سِيذِي خْ ثمُّورْثْ ن حَاذْرَاخْ،\bd*
\m \bd \bdit ڒْْحُوكْمْ\bdit* نِّي يَارْسَانْ خْ ذِيمَاشْقْ.\bd*
\b
\m \qt ”مَاغَارْ سِيذِي إِحطَّا خْ بْنَاذمْ\qt*
\m \qt ؤُ خْ مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل،\qt*
\m 
\v 2 \qt ؤُڒَا خْ حَامَاثْ إِ-ت-د-إِڒسْقنْ،\qt*
\m \qt خْ صُورْ ذ صِيذُونْ،\qt*
\m \qt وَاخَّا نِيثنْثِي ذ ثِيمِيغِيسِينْ أَطَّاسْ.\qt*
\m 
\v 3 \qt ثبْنَا صُورْ إِجّْ ن لْبَارَاجْ إِ يِيخفْ نّسْ\qt*
\m \qt ؤُ ثيْرُو نُّوقَارْثْ أَمْ ثْعجَّاجْثْ\qt*
\m \qt ذ وُورغْ إِقُّورنْ أَمْ ؤُبدْجَاعْ ن إِمسْرَاقْ.\qt*
\m 
\v 4 \qt خْزَارْ، سِيذِي إِنُو أَذْ ت إِطّفْ،\qt*
\m \qt أَذْ إِوّثْ لْبَارَاجْ نّسْ غَارْ ڒبْحَارْ،\qt*
\m \qt ؤُشَا أَذْ ت ثشّْ ثْمسِّي.“\qt*
\b
\m 
\v 5 \qt ”أَشْكلُونْ أَذْ ت ثْژَارْ، أَذْ ثذْوڒْ ثڭّْوذْ،\qt*
\m \qt \tl أَمُّو\tl* ؤُڒَا ذ غَازَّا، أَذْ ثَارْجِيجْ أَطَّاسْ،\qt*
\m \qt ؤُڒَا ذ عَاقْرُونْ، مَاغَارْ أَذْ إِفْشڒْ ؤُرَاجِي نّسْ.\qt*
\m \qt أَذْ إِتّْوَاثحَّا ؤُجدْجِيذْ زِي غَازَّا\qt*
\m \qt ؤُ \tl ذِي ثَانْذِينْثْ ن\tl* أَشْقَالُونْ\qt*
\m \qt وَارْ ذَايسْ ثْزدّغْ \tl عَاذْ\tl* ؤُڒَا ذ إِجّنْ.\qt*
\m 
\v 6 \qt مِّيسْ ن ڒحْرَامْ أَذْ إِزْذغْ ذِي أَشْذُوذْ\qt*
\m \qt ؤُ نشّْ أَذْ ثحِّيغْ نّْفَاخثْ ن إِفِيلِيسْطِينِييّنْ.\qt* \f ◼ \fr 9:‏6 \ft \bd ’أَذْ ثحِّيغْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَذْ قضْعغْ‘.\f*
\m 
\v 7 \qt نشّْ أَذْ كْسِيغْ إِذَامّنْ زڭْ ؤُقمُّومْ نّسْ\qt*
\m \qt ؤُڒَا ذ نّْعَاوَاثْ زِي جَارْ ثِيغْمَاسْ نّسْ\qt*
\m \qt ؤُ أَمُّو إِ غَا إِقِّيمْ ؤُڒَا ذ نتَّا\qt*
\m \qt إِ أَربِّي نّغْ.\qt*
\m \qt نتَّا أَذْ يِيڒِي أَمْ يِيجّْ ن ومْغَارْ ذِي يَاهُوذَا\qt*
\m \qt ؤُ عَاقْرُونْ أَمْ يِيجّْ ن ؤُيابُوسِي.\qt*
\m 
\v 8 \qt نشّْ أَذْ ڭّغْ ڒْمَارْڭحْ إِنُو\qt*
\m \qt ذڭْ ونّضْ ن ثَادَّارْثْ إِنُو،\qt*
\m \qt ضِيدّْ ن ونِّي إِ غَا إِژْوَانْ\qt*
\m \qt ؤُ ضِيدّْ ن ونِّي د غَا إِذوْڒنْ،\qt*
\m \qt حِيمَا ونِّي إِحصَّارنْ\qt*
\m \qt وَارْ خَاسْ إِعدُّو شَا عَاذْ،\qt*
\m \qt مَاغَارْ ڒخُّو ژْڒِيغْ \tl ث\tl* س ثِيطَّاوِينْ إِنُو.“\qt*
\b
\s1 أَجدْجِيذْ إِ د غَا يَاسنْ ن سِيحْيُونْ
\m 
\v 9 \qt ”فَارْحْ، \tl أَ\tl* يدْجِيسْ ن صِيهْيُونْ،\qt*
\m \qt سْڒِيوْڒوْ، \tl أَ\tl* يدْجِيسْ ن ؤُرْشَالِيمْ!\qt*
\m \qt خْزَارْ، أَجدْجِيذْ نّمْ يُوسَا-د غَارمْ،\qt*
\m \qt نتَّا ذ أَمْسڭّذْ\qt*
\m \qt ؤُ أَقَا يَارْضْ أَرُّوضْ ن ؤُسنْجمْ،\qt*
\m \qt نتَّا ذ أَمْوَاضعْ،\qt*
\m \qt إِنْيَا خْ إِجّْ ن وغْيُوڒْ،\qt*
\m \qt خْ إِجّْ ن وزْعُوقْ، أَسْنُوسْ ن إِشْثْ ن ثغْيُوتْشْ.\qt*
\m 
\v 10 \qt نشّْ أَذْ قْضِيغْ إِكَارُّوثنْ \tl ن ؤُمنْغِي\tl*\qt*
\m \qt زِي إِفْرَايِيمْ\qt*
\m \qt ؤُڒَا ذ إِيْسَانْ زِي ؤُرْشَالِيمْ.\qt*
\m \qt أَذْ إِتّْوَاقْڒعْ ؤُڒَا ذ ڒْقوْسْ ن ؤُمنْغِي.\qt*
\m \qt نتَّا أَذْ إِبَارّحْ س ڒهْنَا إِ رڭْنُوسْ\qt*
\m \qt ؤُ صُّولْطَا نّسْ أَذْ ثِيڒِي\qt*
\m \qt زِي ڒبْحَارْ أَڒْ ڒبْحَارْ،\qt*
\m \qt زڭْ إِغْزَارْ \tl ن لْفُورَاطْ\tl*\qt*
\m \qt أَڒْ  إِنڭُّورَا ن ثمُّورْثْ.“\qt*
\b
\m 
\v 11 \qt ”\tl وَاهْ\tl* ؤُڒَا ذ شمْ، \tl أَ يدْجِيسْ ن صِيهْيُونْ\tl*،\qt*
\m \qt زِي سِّيبّثْ ن إِذَامّنْ ن ڒْعَاهْذْ نّمْ\qt*
\m \qt فكّغْ-د إِمحْبَاسْ نّمْ\qt*
\m \qt زڭْ وَانُو يُوژْغنْ إِ وَارْ ذِي دْجِينْ وَامَانْ.\qt* \x ◘ \xo 9:‏11 \xt مت. 26‏:‏28؛ لك. 22‏:‏20؛ رُوم. 9‏:‏3، 4؛ رُوم. 11‏:‏25، 26، 27؛ 1 كُور. 11‏:‏25؛ عبر. 9‏:‏19، 20، 21.\x*
\m 
\v 12 \qt عقْبمْ غَارْ لْبُورْجْ نْومْ،\qt*
\m \qt \tl كنِّيوْ\tl* إِمحْبَاسْ إِنِّي غَارْ إِدْجَا ڒَايَاسْ.\qt*
\m \qt ؤُڒَا ذ أَسّْ-أَ نشّْ تّْبَارّْحغْ:\qt*
\m \qt أَقَا نشّْ أَذْ غَارمْ د-أَرّغْ\qt*
\m \qt ثْنَاينْ ن ثْسقَّارْ،\qt*
\m 
\v 13 \qt مَاغَارْ نشّْ أَذْ محْضغْ يَاهُوذَا\qt*
\m \qt \tl أَمْ إِجّْ ن ڒْقوْسْ\tl*\qt*
\m \qt ؤُ أَذْ ڭّغْ إِفْرَايِيمْ خْ ڒْقوْسْ.\qt*
\m \qt نشّْ أَذْ سّكَّارغْ\qt*
\m \qt إِحنْجِيرنْ نّمْ، \tl أَ\tl* صِيهْيُونْ،\qt*
\m \qt ضِيدّْ إِ إِحنْجِيرنْ نّشْ، \tl أَ\tl* يَاوَانْ،\qt*
\m \qt ؤُ نشّْ أَذْ شكْ أَرّغْ\qt*
\m \qt أَمْ سِّيفْ ن إِجّْ ن بُو-ثغْرُوضْثْ.“\qt* \f ◼ \fr 9:‏13 \ft \bd ’يَاوَانْ‘\bd* - إِخْسْ أَذْ يِينِي لْيُونَانْ ن زِيشْ.\f*
\b
\m 
\v 14 \qt ”سِيذِي أَذْ إِبَانْ سنّجْ نْسنْ\qt*
\m \qt ؤُ فْڒِيثْشَاثْ نّسْ أَذْ إِڒِينْثْ\qt*
\m \qt تّْوسّْڭنْثْ أَمْ وَاسَّامْ\qt*
\m \qt ؤُ سِيذِي إِنُو، سِيذِي،ْ\qt*
\m \qt أَذْ إِسُوضْ ذڭْ ؤُيِيشّْ ن إِشَارِّي،\qt*
\m \qt أَذْ يُويُورْ أَكْ-ذ ثْحَارْيَاضِينْ\qt*
\m \qt ن ؤُسمِّيضْ ن لْجَانُوبْ.\qt* \x ◘ \xo 9:‏14 \xt نَحُم. 2‏:‏6\x*
\m 
\v 15 \qt سِيذِي ن ڒْعسْكَارَاثْ أَذْ ثنْ إِسّْذُورِييْ.\qt*
\m \qt نِيثْنِي أَذْ شّنْ،\qt*
\m \qt أَذْ دّْزنْ إِژْرَا ن إِدْجِييْ ؤُشَا أَذْ سْونْ،\qt*
\m \qt أَذْ ڭّنْ دّْرِيزْ أَمْ غَارْ بِينُو\qt*
\m \qt ؤُ أَذْ ذوْڒنْ شُّورنْ\qt*
\m \qt أَمْ طَّاوْيَا ن ؤُرُوشِّي،\qt*
\m \qt أَمْ ثْغمَّارْ ن ؤُعَالْطَارْ.\qt*
\m 
\v 16 \qt سِيذِي، أَربِّي نْومْ\qt*
\m \qt أَذْ ثنْ إِسّنْجمْ\qt* \bdit ذڭْ وَاسّْ نِّي\bdit*
\m \qt أَمْ وُودْجِي ن ڒْڭنْسْ نّسْ،\qt*
\m \qt مَاغَارْ نِيثْنِي \tl أَمشْنَاوْ\tl* إِژْرَا \tl إِغْڒَانْ\tl*\qt*
\m \qt خْ إِجّْ ن تَّاجْ \tl إِڭلّْذنْ\tl*\qt*
\m \qt إِتِّيسِّيقنْ خْ ثمُّورْثْ نّسْ.\qt*
\m 
\v 17 \qt مَاغَارْ مشْهَاڒْ إِمْغَارْ أَذْ يِيڒِي ڒْخَارْ \tl نّسْ\tl*\qt*
\m \qt ؤُ مشْهَاڒْ إِمْغَارْ أَذْ يِيڒِي وَاژْڒِي \tl نّسْ\tl*!\qt*
\m \qt إِمنْذِي أَذْ إِسّغْمِي إِحُوذْرِييّنْ\qt*
\m \qt ؤُڒَا بِينُو ن جْذِيذْ ثِيعْزَارِييِّينْ.“\qt*
\b
\b
\c 10
\s1 أَعْذَاڒْ ن يَاهُوذَا ذ إِسْرَائِيل
\m 
\v 1 \qt ”تَّارمْ أَنْژَارْ زِي سِيذِي،\qt*
\m \qt ذِي ڒْوقْثْ ن ونْژَارْ ن ثفْسُوثْ.\qt*
\m \qt سِيذِي إِتّڭّْ أَسَّامنْ،\qt*
\m \qt \tl وَاهْ،\tl* نتَّا أَذْ أَسنْ إِوْشْ\qt*
\m \qt إِبُوذَا ن ونْژَارْ،\qt*
\m \qt إِ كُوڒْ إِجّْ ن وفْسُو ذڭْ إِيَّارْ.\qt* \f ◼ \fr 10:‏1 \ft \bd ’أَنْژَارْ ن ثَافْسُوثْ‘\bd* - أَنْژَارْ ن ثفْسُوثْ ذِي شَّارْقْ أَمڒْوَاسُو إِشَّاثْ قْبڒْ ڒْوقْثْ ن ثْميْرَا ذڭْ ؤُيُورْ ن مَارْسْ ذ وَابْرِيلْ.\f*
\m 
\v 2 \qt مَاغَارْ ڒخْيَاڒَاثْ ن لْ-أَصْنَامْ سَّاوَاڒنْ ڒْغشّْ،\qt*
\m \qt ؤُ إِڭزَّاننْ تّْوَاڒَانْ إِخَارِّيقنْ\qt*
\m \qt ؤُ نِيثْنِي تّْعَاوَاذنْ ثِيرْجَا إِشمّْثنْ،\qt*
\m \qt نِيثْنِي سّْفوَّاجنْ س ڒعْوِينْ.\qt*
\m \qt خْ ؤُيَا إِ تّْوَاسِّيڭّْوجنْ أَمْ وُودْجِي،\qt*
\m \qt تّْوَاحْصَارنْ، مِينْزِي أَمكْسَاوْ وَارْ ذِينْ إِدْجِي.“\qt* \f ◼ \fr 10:‏2 \ft \bd ’أَمكْسَاوْ‘\bd* - نِيغْ ’أَنِيتْشيِ‘.\f*  \x ◘ \xo 10:‏2 \xt أَمب. 5‏:‏6\x*
\b
\m 
\v 3 \qt ”خْ إِمكْسَاونْ يَارْغَا وغْضَابْ إِنُو\qt*
\m \qt ؤُ نشّْ أَذْ خدْجْصغْ إِغَايْضنْ،\qt*
\m \qt مَاغَارْ سِيذِي ن ڒْعسْكَارَاثْ\qt*
\m \qt أَذْ إِسِّيجّْ خْ ثْحِيمَارْثْ نّسْ،\qt*
\m \qt خْ ثَادَّارْثْ ن يَاهُوذَا،\qt*
\m \qt ؤُ نتَّا أَذْ ثنْ إِسدّْ\qt*
\m \qt أَمْ ؤُيِيسْ نّسْ إِتِّيسِّيقنْ غَارْ ؤُمنْغِي.\qt*
\m 
\v 4 \qt زَّايسْ أَژْرُو ن ثغْمَارْثْ،\qt*
\m \qt زَّايسْ ڒوْثذْ،\qt*
\m \qt زَّايسْ ڒْقوْسْ \tl ن ؤُمنْغِي\tl*،\qt*
\m \qt أَذْ زَّايسْ د-فّْغنْ \tl خنِّي\tl*\qt*
\m \qt مَارَّا إِمْزيَّارنْ جْمِيعْ.\qt* \x ◘ \xo 10:‏4 \xt إِشا. 28‏:‏16؛ إِشا. 22‏:‏23\x*
\m 
\v 5 \qt نِيثْنِي مَارَّا أَذْ ذوْڒنْ\qt*
\m \qt أَمْ أَيْثْ ن بُو-ثغْرُوضْثْ\qt*
\m \qt إِنِّي ذڭْ ؤُمنْغِي أَذْعفْسنْ\qt*
\m \qt خْ ؤُبدْجَاعْ ذِي زّْنَاقِي.\qt*
\m \qt \tl وَاهْ\tl*، نِيثْنِي أَذْ مّنْغنْ،\qt*
\m \qt مَاغَارْ سِيذِي أَذْ يِيڒِي أَكِيذْسنْ،\qt*
\m \qt ؤُ نِيثْنِي أَذْ سضْحَانْ إِنِّي إِنْيِينْ خْ ييْسَانْ.\qt*
\m 
\v 6 \qt نشّْ أَذْ سّْجهْذغْ ثَادَّارْثْ ن يَاهُوذَا\qt*
\m \qt ؤُ أَذْ سّْنجْمغْ ثَادَّارْثْ ن يُوسُوفْ\qt*
\m \qt ؤُ نشّْ أَذْ أَسنْ وْشغْ ثَازذِّيغْثْ،\qt*
\m \qt مَاغَارْ نشّْ أَرّحْمغْ ذَايْسنْ\qt*
\m \qt ؤُ نِيثْنِي أَذْ إِڒِينْ أَخْمِي نشّْ\qt*
\m \qt وَارْ ثنْ نْضَارغْ،\qt*
\m \qt مَاغَارْ نشّْ ذ سِيذِي، أَربِّي نْسنْ،\qt*
\m \qt ؤُ نشّْ أَذْ غَارْسنْ سْڒغْ.“\qt*
\b
\m 
\v 7 \qt ”\tl إِنِّي ن\tl* إِفْرَايِيمْ أَذْ إِڒِينْ\qt*
\m \qt أَمْ يِيجّْ ن بُو-ثغْرُوضْثْ\qt*
\m \qt ؤُ ؤُڒْ نْسنْ أَذْ إِفَارْحْ أَمْ غَارْ بِينُو،\qt*
\m \qt ؤُ إِحنْجِيرنْ نْسنْ\qt*
\m \qt أَذْ ث ژَترنْ ؤُ أَذْ فَارْحنْ،\qt*
\m \qt ؤُڒْ نْسنْ أَذْ إِفَارْحْ ذِي سِيذِي.\qt*
\m 
\v 8 \qt نشّْ أَذْ خَاسنْ صفَّارغْ\qt*
\m \qt ؤُ أَذْ ثنْ سّْمُونغْ،\qt*
\m \qt مَاغَارْ نشّْ فْذِيغْ ثنْ،\qt*
\m \qt ؤُ نِيثْنِي أَذْ د-ذوْڒنْ ذڭْ وَاطَّاسْ،\qt*
\m \qt أَمْ مَامّشْ ثنْ ثُوغَا ذڭْ وَاطَّاسْ.\qt*
\m 
\v 9 \qt نشّْ أَذْ ثنْ زَارْعغْ جَارْ ڒڭْنُوسْ\qt*
\m \qt ؤُ نِيثْنِي أَذْ أَيِي إِذَارنْ\qt*
\m \qt ذِي جّْوَايهْ إِڭّْوجّنْ.\qt*
\m \qt \tl خنِّي\tl* أَذْ دَّارنْ أَكْ-ذ إِحنْجِيرنْ نْسنْ\qt*
\m \qt ؤُشَا أَذْ د-ذوْڒنْ.\qt* \x ◘ \xo 10:‏9 \xt حِز. 37‏:‏13‏-‏14\x*
\m 
\v 10 \qt نشّْ أَذْ ثنْ جّغْ أَذْ د -عقْبنْ زِي مِيسْڒَا،\qt*
\m \qt أَذْ ثنْ د-سّْمُونغْ زِي أَشُّورْ\qt*
\m \qt ؤُ أَذْ ثنْ د-أَوْيغْ غَارْ ثمُّورْثْ ن جِيلْعَاذْ\qt*
\m \qt ؤُ \tl غَارْ\tl* لُوبْنَانْ،\qt*
\m \qt مَاشَا أَيَا وَارْ ثنْ إِتّْقذِّي.\qt* \x ◘ \xo 10:‏10 \xt إِرْم. 22‏:‏6؛ حُوش. 9‏:‏3؛ زَاك. 10‏:‏11\x*
\m 
\v 11 \qt نتَّا أَذْ إِژْوَا ڒبْحَارْ ن ڒحْصَارثْ نْسنْ\qt*
\m \qt ؤُ أَذْ إِوّثْ ڒمْوَاجْ ن ڒبْحَارْ\qt*
\m \qt ؤُ مَارَّا إِمُوشَانْ يُودْجْغنْ\qt*
\m \qt ن إِغْزَارْ \tl ن نِيلْ\tl* أَذْ أَژْغنْ.\qt*
\m \qt نّْفَاخثْ ن أَشُّورْ أَذْ ثتّْوَاسّْوَاضعْ،\qt*
\m \qt ؤُ أَزدْجَاضْ ن مِيسْڒَا أَذْ إِتّْوَاودَّارْ.\qt*
\m 
\v 12 \qt نشّْ أَذْ ثنْ سّْجهْذغْ ذِي سِيذِي\qt*
\m \qt ؤُ نِيثْنِي أَذْ ؤُيُورنْ ذڭْ يِيسمْ نّسْ!“،\qt*
\m \qt \tl أَمُّو إِ\tl* إِقَّارْ سِيذِي.\qt*
\b
\b
\c 11
\s1 أَمكْسَاوْ أَصبْحَانْ ذ يِيمكْسَاونْ إِعفَّاننْ ذ ؤُمكْسَاوْ أَپُوهَاڒِي
\m 
\v 1 \qt ”أَرْزمْ ثِيوُّورَا نّشْ، \tl أَ\tl* لُوبْنَانْ،\qt*
\m \qt \tl مَاحنْذْ\tl* ثِيمسِّي أَذْ ثشّْ ثِينڭْلِينْ نّشْ.\qt*
\m 
\v 2 \qt رُو، \tl أَ ثَاشجَّارْثْ\tl* ن ؤُمرْزِي،\qt*
\m \qt مَاغَارْ ثَانْڭلْثْ ثوْضَا،\qt*
\m \qt مَاغَارْ ثِيشجُّورَا \tl نِّي\tl* إِجهْذنْ\qt*
\m \qt تّْوَاردّْدْجنْثْ!\qt*
\m \qt رُوثْ، \tl أَ\tl* ثِيشجُّورَا ن ڒْبدْجُوضْ ن بَاشَانْ،\qt*
\m \qt مَاغَارْ أَزْغَارْ إِمّْشُوبّْشنْ إِوْضَا.“\qt* \f ◼ \fr 11:‏2 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘. \bd ’أَمرْزِي‘\bd* - نِيغْ ’أَمضْزِي‘.\f*
\b
\m 
\v 3 \qt ”\tl سْڒمْ\tl* إِ ڒْحسّْ ن ثْغُويِّيثْ ن إِمكْسَاونْ،\qt*
\m \qt مَاغَارْ أَعُودْجِي نْسنْ إِتّْوَاردّدْجْ،\qt*
\m \qt \tl سْڒمْ\tl* إِ ڒْحسّْ ن ؤُزهَّارْ\qt*
\m \qt ن ويْرَاذنْ إِمژْيَاننْ،\qt*
\m \qt مَاغَارْ ڒْعزّْ ن لْ-ؤُرْذُونْ إِتّْوَاردّدْجْ.“\qt*
\b
\m 
\v 4 ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي إِنُو: ’أَرْوسْ ؤُدْجِي نِّي ؤُمِي غَا غَارْصنْ،
\v 5 إِنِّي ثنْ إِملّْكنْ نقّنْ ثنْ بْڒَا مَا أَذْ تّْوَاعَاقْبنْ، إِنِّي \add ثنْ إِملّْكنْ\add* زّنْزنْ ثنْ، قَّارنْ: أَذْ إِتّْوَابَاركْ سِيذِي، أَقَا نشّْ ذوْڒغْ غَارِي أَڭْڒَا! إِمكْسَاونْ نْسنْ وَارْ ذ أَسنْ زِّيدْجِيزنْ.‘ “
\b
\m 
\v 6 ”خنِّي نشّْ وَارْ ذ أَيِي زِّيدْجِيزنْ عَاذْ إِمزْذَاغْ ن ثمُّورْثْ، إِقَّارْ سِيذِي. خْزَارْ، نشّْ أَذْ وْشغْ إِ إِوْذَانْ كُوڒْ إِجّْ ذڭْ ؤُفُوسْ ن جَّارْ نّسْ ؤُ ذڭْ ؤُفُوسْ ن ؤُجدْجِيذْ نّسْ، ؤُ نِيثْنِي أَذْعفْسنْ خْ ثمُّورْثْ ؤُ نشّْ وَارْ \add ثنْ\add* تّْفكّغْ شَا زڭْ ؤُفُوسْ نْسنْ.“
\b
\m 
\v 7 ”نشّْ أَروْسغْ ؤُدْجِي ثِينِّي ؤُمِي غَا غَارْصنْ، مَاغَارْ نِيثنْثِي ذ ؤُدْجِي إِتّْوَاحْسَارنْ. نشّْ كْسِيغْ إِ يِيخفْ إِنُو ثْنَاينْ ن ثغَّارْينْ. إِشْثْ ڭِّيغْ أَسْ ’ڒْْخَاضَارْ!‘ ؤُ ثنّغْنِي ڭِّيغْ أَسْ ’ثَاغْرُوضْثْ!‘، ؤُ \add أَمُّو إِ\add* أَرْوْسغْ نشّْ ؤُدْجِي.“
\b
\m 
\v 8 ”ذڭْ إِجّْ ن ؤُيُورْ تّحِّيغْ ثْڒَاثَا زڭْ إِمكْسَاونْ. ڒعْمَارْ إِنُو وَارْ إِزمَّارْ أَذْ ثنْ ثَارْبُو \add عَاذْ\add* ؤُشَا ؤُڒَا ذ ڒعْمَارْ نْسنْ إِشَارْهْ أَيِي عَاوذْ.
\v 9 نشّْ نِّيغْ: نشّْ وَارْ كنِّيوْ أَركّْوْسغْ! مِينْ إِمُّوثنْ، أجّْ \add إِ-ث\add* أَذْ إِمّثْ ؤُ مِينْ إِهلّْكنْ، أجّْ \add إِ-ث\add* أَذْ إِتّْوَاهلّكْ، ؤُ جّمْ إِنِّي إِقِّيمنْ أَذْ شّنْ أَيْسُومْ إِجّْ ن ونّغْنِي.
\v 10 نشّْ كْسِيغْ ثَاغَّارْشْثْ إِنُو ’رْخَاضَارْ‘، ؤُشَا أَرْژِيغْ ت مَاحنْذْ أَذْ أَرْژغْ أَمُّو ڒْعَاهْذْ إِنُو نِّي ڭِّيغْ أَكْ-ذ مَارَّا ڒڭْنُوسْ.
\v 11 \bd ذڭْ وَاسّْ نِّي\bd* إِذْوڒْ \add ڒْْعَاهْذْ\add* يَارّژْ ؤُ أَمُّو إِ سّْننْ وُودْجِي إِتّْوَاحْصَارنْ نِّي ذ أَيِي إِحطَّانْ، أَقَا أَيَا ثُوغَا ذ إِجّْ ن وَاوَاڒْ ن سِيذِي.“
\b
\m 
\v 12 ”نشّْ نِّيغْ أَسنْ: ’مَاڒَا أَيَا مْلِيحْ ذِي ثِيطَّاوِينْ نْومْ، وْشمْ أَيِي ڒْمُونثْ إِنُو، ؤُ مَاڒَا لَّا، جّمْ ث!‘ \add خنِّي\add* وزْننْ ڒْمُونثْ إِنُو: ثْڒَاثِينْ ن \add ڒْوزْنَاثْ ن\add* نُّوقَارْثْ. \x ◘ \xo 11:‏12 \xt ؤُف. 21‏:‏32؛ مت. 26‏:‏15؛ 27‏:‏9\x*
\v 13 \add خنِّي\add* إِنَّا أَيِي سِيذِي: ’نْضَارْ \add ڒْْمُونثْ\add* نِّي غَارْ بُو-ثْڒَاخْثْ، تَّامَانْ \add نِّي\add* ’إِصبْحنْ‘ إِنِّي ذ أَيِي ڭِّينْ تَّامَانْ!‘ ؤُ نشّْ كْسِيغْ ثْڒَاثِينْ نْ ڒْوزْنَاثْ ن نُّوقَارْثْ ؤُشَا نْضَارغْ ثنْثْ غَارْ بُو-ثْڒَاخْثْ ذِي ثَادَّارْثْ ن سِيذِي. \f ◼ \fr 11:‏13 \ft \bd ’أَقدَّارْ‘\bd* - نِيغْ ’بُو-ثْڒَاخْثْ‘.\f*
\v 14 \add ڒخْذنِّي\add* أَرْژِيغْ نشّْ ثَاغَّارْشْثْ إِنُو نّغْنِي \add ثنِّي ڭِّيغْ أَسْ\add* ’ثَاغْرُوضْثْ‘ مَاحنْذْ أَذْ أَرْژغْ \add أَمُّو\add* ثَاوْمَاثْ جَارْ يَاهُوذَا ذ إِسْرَائِيل.“
\b
\m 
\v 15 ”سِيذِي إِنَّا أَيِي: ’كْسِي ثْوَاڒَا نّغْنِيثْ دُّوزَانْ ن إِجّْ ن ؤُمكْسَاوْ أَبُوهَاڒِي،
\v 16 مَاغَارْ نشّْ أَذْ جّغْ أَذْ د-إِكَّارْ إِجّْ ن ؤُمكْسَاوْ ذِي ثمُّورْثْ: مِينْ إِرُوحنْ وَارْ يَارزُّو، مِينْ إِمْطَارّْشنْ وَارْ ث يَارزُّو، مِينْ يَارْژنْ وَارْ ث إِسّْڭنْفِي ؤُ مِينْ إِقِّيمنْ إِبدّْ، وَارْ ث إِحطِّي نتَّا. \add مَاشَا\add* نتَّا أَذْ يشّْ أَيْسُومْ ن \add ڒبْهَايمْ\add* إِصحّنْ ؤُ أَذْ أَسنْثْ إِكّسْ ثِيشضْيِينْ.‘ “
\b
\m 
\v 17 \qt ”ؤُشْثْ خْ ؤُمكْسَاوْ إِ وَارْ إِسكّْوِينْ،\qt*
\m \qt ونِّي إِسمّْحنْ ذڭْ وُودْجِي!\qt*
\m \qt سِّيفْ \tl أَذْ د-إِعْذُو\tl* خْ ؤُغِيڒْ نّسْ\qt*
\m \qt ؤُ خْ ثِيطّْ نّسْ ثَافُوسشْثْ.\qt*
\m \qt أَغِيڒْ نّسْ أَذْ يَاژغْ مَارَّا،\qt*
\m \qt ؤُ ثِيطّْ نّسْ ثَافُوسشْثْ أَذْ ثعْمشْ مَارَّا!“\qt* \x ◘ \xo 11:‏17 \xt إِرْم. 23‏:‏1؛ حِز. 34‏:‏2؛ يُوح. 10‏:‏12\x*
\b
\b
\c 12
\s1 ڒحْصَارثْ ذ ؤُفكِّي ذ ثْغُويِّيثْ ن وشْضَانْ ن ؤُرْشَالِيمْ
\m 
\v 1 \bd ڒْْحُوكْمْ إِسَّاڭّْوَاذنْ ن وَاوَاڒْ ن سِيذِي خْ إِسْرَائِيل.\bd* سِيذِي إِسَّاوَاڒْ، نتَّا ذ ونِّي إِتّْبزَّاعنْ أَجنَّا ؤُ إِسّْرُوسَا ذْسَاسْ ن ثمُّورْثْ ؤُ إِسّْبدَّا أَرُّوحْ ن بْنَاذمْ ذِي ذَاخڒْ نّسْ:
\b
\m 
\v 2 ”خْزَارمْ، نشّْ أَذْ ڭّغْ ؤُرْشَالِيمْ ذ طّبْصِي ن ؤُذوّخْ إِ مَارَّا ڒڭْنُوسْ إِ ذ أَسْ د-إِنّْضنْ ؤُشَا أَذْ د-يَاسْ طّبْصِي نِّي ؤُڒَا خْ يَاهُوذَا غَارْ ڒحْصَارثْ ن ؤُرْشَالِيمْ.
\b
\m 
\v 3 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِمْسَارْ أَقَا نشّْ أَذْ أَرّغْ ؤُرْشَالِيمْ ذ إِجّْ ن وژْرُو إِذقْڒنْ إِ مَارَّا ڒڭْنُوسْ. مَارَّا إِنِّي يَارزُّونْ أَذْ ث سّْڭعّْذنْ، أَذْ سّْيزْمنْ إِخفْ نْسنْ أَطَّاسْ ؤُ مَارَّا ڒڭْنُوسْ ن دُّونشْثْ أَذْ تّْوَاسّْمُوننْ ضِيدّْ نّسْ.
\m 
\v 4 \bd ذڭْ وَاسّْ نِّي\bd*، إِقَّارْ سِيذِي، أَذْ وْثغْ مَارَّا إِيْسَانْ س أَرْجفْ ذ إِمْنَاينْ نّسْ س ثُوبُّوهڒْيَا، \add مَاشَا\add* أَذْ قِّيمغْ أَرزّْمغْ ثِيطَّاوِينْ إِنُو خْ ثَادَّارْثْ ن يَاهُوذَا، \add خْمِي\add* إِ غَا وْثغْ مَارَّا إِيْسَانْ ن ڒڭْنُوسْ س ثُودَّارْغتْشْ.
\v 5 إِمْڭوَّاذنْ ن يَاهُوذَا أَذْ إِنِينْ ذڭْ وُوڒْ نْسنْ: ’إِمزْذَاغْ ن ؤُرْشَالِيمْ أَذْ إِڒِينْ ذ جّهْذْ إِنُو س \add ؤُفُوسْ ن\add* سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي نْسنْ!‘
\m 
\v 6 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ ڭّغْ إِمْڭوَّاذنْ ن يَاهُوذَا أَمْ يِيجّْ ن ڒْمجْمَارْ ن ثْمسِّي ذِي ثَافَّا ن ؤُكشُّوضْ ؤُ أَمْ يِيجّْ ن وصْفضْ جَارْ ثِيقبِّيضِينْ ن إِمنْذِي ؤُ نِيثْنِي أَذْ فّْزنْ مَارَّا ڒڭْنُوسْ إِ ذ أَسنْ د-إِنّْضنْ، غَارْ يفُوسْ ؤُ غَارْ ؤُزڒْمَاضْ، ؤُشَا ؤُرْشَالِيمْ أَذْ ثقِّيمْ عَاذْ ذڭْ ومْشَانْ نّسْ، ذِي ؤُرْشَالِيمْ.
\v 7 سِيذِي أَذْ إِسّنْجمْ أَمزْوَارْ إِقِيضَانْ ن يَاهُوذَا حِيمَا شَّانْ ن ثَادَّارْثْ ن ذَاوُوذْ ذ شَّانْ ن إِمزْذَاغْ ن ؤُرْشَالِيمْ وَارْ إِذِّيكّْوِيڒْ ذ أَمقّْرَانْ أَطَّاسْ قِيبَاتْشْ إِ يَاهُوذَا.
\m 
\v 8 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِسّْذُورِييْ سِيذِي إِمزْذَاغْ ن ؤُرْشَالِيمْ.
\m \bd ذڭْ وَاسّْ\bd* نِّي أَذْ يِيڒِي ونِّي إِ غَا إِنّْقَارْضنْ جَارْ أَسنْ أَمْ ذَاوُوذْ ؤُشَا ثَادَّارْثْ ن ذَاوُوذْ أَذْ ثِيڒِي أَمْ أَربِّي، أَمْ لْمَالَاكْ ن سِيذِي زَّاثْ إِ وُوذمْ نْسنْ.
\m 
\v 9 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِمْسَارْ، أَقَا نشّْ أَذْ ركّْزغْ أَذْ مْحِيغْ مَارَّا ڒڭْنُوسْ إِ د غَا يَاسنْ \add إِ ڒحْصَارثْ\add* غَارْ ؤُرْشَالِيمْ.
\v 10 \add مَاشَا\add* أَذْ فَارّْغغْ أَرُّوحْ ن أَرْضَا ذ ثْژَادْجِيثِينْ خْ ثَادَّارْثْ ن ذَاوُوذْ ؤُ خْ إِمزْذَاغْ ن ؤُرْشَالِيمْ ؤُ نِيثْنِي أَذْ غَارِي د-خْزَارنْ ونِّي ذِي سّْنُوقّْبنْ. نِيثْنِي أَذْ خَاسْ وْثنْ أَيجْذُورْ أَمْ وْثِينْ أَڭجْذُورْ خْ ؤُينِّي ن مِّيسْ ؤُ أَذْ خَاسْ شضْننْ س ثرْزُوڭِي أَمْ ونِّي إِتّشْضِيننْ خْ \add ڒْْموْثْ ن\add* مِّيسْ أَمنْزُو. \x ◘ \xo 12:‏10 \xt حِز. 39‏:‏29؛ يُووِ. 3‏:‏1؛ يُوح. 19‏:‏37؛ أَسَا. 1‏:‏7\x*
\m 
\v 11 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ ثِيڒِي ثْغُويِّيثْ ن وشْضَانْ ثمْغَارْ ذِي ؤُرْشَالِيمْ، أَمْ ثْغُويِّيثْ ن وشْضَانْ ن هَاذَاذْ-رِيمُّونْ ذِي ثغْزُورْثْ ن مَاجِيدُّونْ. \x ◘ \xo 12:‏11 \xt 2 إِج. 23‏:‏29؛ 2 إِم. 35‏:‏22، 24\x*
\m 
\v 12 ثَامُّورْثْ أَذْ ثسْغُويْ زڭْ وشْضَانْ، كُوڒْ ڒَادْجْ وحّْذسْ.
\m ڒَادْجْ ن ثَادَّارْثْ ن ذَاوُوذْ وحّْذسْ
\m ذ ثمْغَارِينْ نْسنْ وحّذْسنْثْ،
\m ڒَادْجْ ن ثَادَّارْثْ ن نَاثَانْ وحّْذسْ
\m ذ ثمْغَارِينْ نْسنْ وحّذْسنْثْ.
\m 
\v 13 ڒَادْجْ ن ثَادَّارْثْ ن لَاوِي وحّْذسْ
\m ذ ثمْغَارِينْ نْسنْ وحّذْسنْثْ،
\m ڒَادْجْ ن شِيمْعِي وحّْذسْ
\m ذ ثمْغَارِينْ نْسنْ وحّذْسنْثْ.
\m 
\v 14 مَارَّا ڒَادْجَاثْ نّغْنِي، كُوڒْ ڒَادْجْ وحّْذسْ ؤُڒَا ذ ثِيمْغَارِينْ وحّذْسنْثْ.“
\b
\b
\c 13
\s1 أَسفْصِي ذ ؤُسِيزْذڭْ ن ؤُرْشَالِيمْ
\m 
\v 1 ”\bd ذڭْ وَاسّْ نِّي\bd* ڭُّورْ أَذْ ثدُّوقّزْ إِشْثْ ن ثَاڒَا إِ ثَادَّارْثْ ن ذَاوُوذْ ؤُڒَا إِ إِمزْذَاغْ ن ؤُرْشَالِيمْ، ضِيدّْ إِ دّنْبْ ؤُ ضِيدّْ إِ ڒخْمجْ.
\m 
\v 2 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِمْسَارْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، نشّْ أَذْ ثحِّيغْ إِسْمَاونْ ن ڒخْيَاڒَاثْ ن لْ-أَصْنَامْ زِي ثمُّورْثْ، \add حِيمَا\add* وَارْ خَاسنْعقّْڒنْ عَاذْ. ؤُڒَا ذ إِنَابِييّنْ ذ بُوحْبڒْ أَمنْڭُوسْ أَذْ ثنْ سُّوفّْغغْ زِي ثمُّورْثْ. \f ◼ \fr 13:‏2 \ft \bd ’أَذْ ثحِّيغْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَذْ قضْعغْ‘.\f*  \x ◘ \xo 13:‏2 \xt أَعَوذ. 13‏:‏6‏-‏11؛ أَعَوذ. 18‏:‏20. \x*
\v 3 أَذْ إِمْسَارْ، مَاڒَا شَا ن إِجّنْ أَذْ إِنبَّا، بلِّي بَابَاسْ ذ يمَّاسْ إِنِّي ث-إِ-د إِجِّينْ، أَذْ أَسْ إِنِينْ: ’شكْ وَارْ تّْغِيمِيذْ ثدَّارذْ، مَاغَارْ شكْ ثسِّيوْڒذْ إِخَارِّيقنْ ذڭْ إِسمْ ن سِيذِي!‘ بَابَاسْ ذ يمَّاسْ إِنِّي ث-إِ-د إِجِّينْ، أَذْ ث سّْنُوقّْبنْ خْمِي غَا إِنبَّا. \x ◘ \xo 13:‏3 \xt أَعَوذ. 13‏:‏6‏-‏11، 18‏:‏20\x*
\m 
\v 4 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِمْسَارْ أَقَا إِنَابِييّنْ أَذْ سضْحَانْ، كُوڒْ إِجّْ خْ ڒوْحِييْ نّسْ \add إِ إِثْوَاڒَا\add* خْمِي ثُوغَا إِنبَّا. نِيثْنِي وَارْ تِّيرِيضنْ شَا أَپَارْثسُّو ن شّْعَارْ \add ن إِنَابِييّنْ\add* مَاحنْذْ أَذْ سّْخَارّْقنْ.
\v 5 نتَّا أَذْ يِينِي ’نشّْ وَارْ دْجِيغْ ذ أَنَابِي، نشّْ ذ إِجّْ ن ورْيَازْ ونِّي إِتّْفدْجْحنْ إِيَّارْ، مِينْزِي إِكْسبْ أَيِي إِجّنْ زِي ثمْژِي إِنُو.‘
\v 6 أَذْ أَسْ إِنِينْ: ’مِينْ عْنَانْ \add خنِّي\add* إِيزِّيمنْ-أَ ذڭْ إِفَاسّنْ نّشْ؟‘، أَذْ يِينِي نتَّا: ’أَمُّو إِ وْثِينْ أَيِي ذِي ثَادَّارْثْ ن إِمْعِيزّنْ إِنُو.‘ “
\b
\m 
\v 7 ”سِّيفْ، كَّارْ خْ ؤُمكْسَاوْ إِنُو ؤُ خْ ورْيَازْ نِّي إِدْجَانْ ذ أَمْعَاشَارْ إِنُو!، \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ. وّثْ أَمكْسَاوْ إِنُو ؤُشَا \add خنِّي\add* أَذْ إِمّْسبْضَا وُودْجِي، \add مَاشَا\add* نشّْ أَذْ أَرّغْ أَفُوسْ إِنُو \add عَاوذْ إِ ؤُسڒْقِي\add* ثِيوَّا إِمُوقْڒِيڒنْ.“ \x ◘ \xo 13:‏7 \xt مت. 26‏:‏31؛ مك. 14‏:‏27\x*
\b
\m 
\v 8 ”أَذْ إِمْسَارْ ذِي ثَامُّورْثْ مَارَّا، إِقَّارْ سِيذِي، أَقَا ثْنَاينْ ن إِزيْنَاثْ أَذْ تّْوَاقضْعنْ ؤُ نِيثْنِي أَذْ سُّوفّْغنْ بُوحْبڒْ، \add مَاشَا\add* أَزْينْ وِيسّْ ثْڒَاثَا أَذْ ذَايسْ إِقِّيمْ.
\v 9 أَزْينْ وِيسّْ ثْڒَاثَا أَذْ ث نْضَارغْ ذِي ثْمسِّي، ؤُشَا نشّْ أَذْ ثنْ سّصْفِيغْ أَمْ مَامّشْ سّصْفَانْ نُّوقَارْثْ ؤُ نشّْ أَذْ ثنْ جَارّْبغْ أَمْ مَامّشْ تّْجَارَّابنْ ؤُرغْ. نِيثْنِي أَذْ ڒَاغَانْ س يِيسمْ إِنُو ؤُ نشّْ أَذْ \add أَسنْ\add* سْڒغْ. أَذْ إِنِيغْ: ’ڒْْڭنْسْ إِنُو!‘ ؤُ نِيثْنِي أَذْ إِنِينْ: ’سِيذِي ذ أَربِّي إِنُو!‘ “ \x ◘ \xo 13:‏9 \xt إِزهد. 50‏:‏15؛ 91‏:‏15؛ 144‏:‏15؛ يُوح. 20‏:‏28؛ 1 بُط. 1‏:‏6\x*
\b
\b
\c 14
\s1 أَهكّْوُو ن سِيذِي خْ وذْرَارْ ن زِّيثُونْ
\m 
\v 1 \bd ”خْزَارثْ، أَذْ د-يَاسْ إِجّْ ن وَاسّْ إِ سِيذِي\bd* إِ ذِي إِ غَا ثتّْوَابْضَا ثْكشَّاضْثْ نّمْ ذِي ڒْوسْطْ نّمْ! \x ◘ \xo 14:‏1 \xt يُووِ. 2‏:‏10، 31؛ 3‏:‏15؛ إِشا. 13‏:‏6‏-‏13؛ 24‏:‏23؛ Am. 8‏:‏9؛ مت. 24‏:‏29؛ ڒخ. 2‏:‏20؛ أَسَا. 6‏:‏12‏-‏13\x*
\v 2 نشّْ أَذْ سّْمُونغْ مَارَّا ڒڭْنُوسْ إِ ؤُمنْغِي أَكْ-ذ ؤُرْشَالِيمْ. ثَانْذِينْثْ أَذْ ثتّْوَاطّفْ، ثُوذْرِينْ أَذْ تّْوَاكشّْضنْثْ، ثِيمْغَارِينْ أَذْ تّْوَاسّْنُوقّْبنْثْ ؤُ أَزْينْ ن ثنْذِينْثْ أَذْ إِتّْوَانْذهْ ذِي لْمنْفَا، \add مَاشَا\add* مِينْ إِقِّيمنْ ن ڒْڭنْسْ وَارْ ڭُّورْ شَا أَذْ إِتّْوَاقْضعْ. \x ◘ \xo 14:‏2 \xt إِشا. 13‏:‏16\x*
\v 3 سِيذِي أَذْ إِفّغْ ؤُ نتَّا أَذْ إِمّْنغْ أَكْ-ذ ڒڭْنُوسْ أَمْ ذڭْ وَاسّْ ن ؤُمنْغِي، ذڭْ وَاسّْ ن إِتّْمنْغَا \add ڒبْذَا\add* ذڭْ وَاسّْ ن وهْجَامْ. \x ◘ \xo 14:‏3 \xt إِشا. 42‏:‏13\x*
\b
\m 
\v 4 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ بدّنْ إِضَارنْ نّسْ خْ وذْرَارْ ن زِّيثُونْ ونِّي قِيبَاتْشْ إِ ؤُرْشَالِيمْ، غَارْ شَّارْقْ. أَذْرَارْ ن زِّيثُونْ أَذْ إِتّْوَافدْجقْ ذِي ثْنَاينْ ن إِزِييْنَاثْ، جِّيهثْ ن شَّارْقْ ؤُ جِّيهثْ ن ڒبْحَارْ، \add مَاحنْذْ أَذْ ذِينْ ثِيڒِي\add* إِشْثْ ن ثغْزُورْثْ ذ ثَامقّْرَانْثْ. أَزْينْ ن وذْرَارْ أَذْ إِميّڒْ غَارْ شَّامَالْ ؤُ أَزْينْ نّغْنِي ن وذْرَارْ أَذْ إِميّڒْ غَارْ لْجَانُوبْ. \x ◘ \xo 14:‏4 \xt ڒخ. 1‏:‏11\x*
\v 5 ؤُشَا كنِّيوْ أَذْ ثَاروْڒمْ زِي هكّْوُو ن إِذُورَارْ إِنُو، مَاغَارْ ثَاغْزُورْثْ ن إِذُورَارْ أَذْ د-ثَاوضْ أَڒْ أَصَالْ ؤُ كنِّيوْ أَذْ ثَاروْڒمْ أَمْ مَامّشْ ثَاروْڒمْ كنِّيوْ زڭْ ونْهزِّي ن ثمُّورْثْ ذڭْ وُوسَّانْ ن عُوزِّييَا، أَجدْجِيذْ ن يَاهُوذَا، ؤُشَا سِيذِي، أَربِّي إِنُو، أَذْ د-يَاسْ ؤُ مَارَّا إِمْقدَّاسنْ أَكِيذكْ. \x ◘ \xo 14:‏5 \xt عَام. 1‏:‏1\x*
\b
\m 
\v 6 \bd ذڭْ وَاسّْ نِّي\bd* ڭُّورْ أَذْ إِمْسَارْ أَقَا وَارْ ثتِّيڒِي ثْفَاوْثْ، إِثْرَانْ إِتِّيسِّيقنْ أَذْ ثتّْوَاكمّْشنْ.
\v 7 أَذْ يِيڒِي ذ إِجّْ ن وَاسّْ إِتّْوَافَارْزْ، أَذْ يِيڒِي إِتّْوَاسّنْ غَارْ سِيذِي. وَارْ إِدْجِي ذ أَسّْ ؤُڒَا ذ دْجِيڒثْ. أَذْ إِمْسَارْ غَارْ ڒْوقْثْ ن ؤُعشِّي أَذْ ثِيڒِي ثْفَاوْثْ.\x ◘ \xo 14:‏7 \xt أَسَا. 21‏:‏25\x*
\b
\m 
\v 8 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِمْسَارْ أَقَا أَمَانْ إِدَّارنْ أَذْ د-فّْغنْ زِي ؤُرْشَالِيمْ، أَزْينْ زَّايْسنْ غَارْ ڒبْحَارْ أَشَارْقِي ؤُ أَزْينْ نّغْنِي غَارْ ڒبْحَارْ ن ڒْغَارْبِي. \add أَمُّو\add* إِ غَا يِيڒِي ذڭْ ؤُنبْذُو ؤُ ذِي ثْڭَارْسْثْ. \f ◼ \fr 14:‏8 \ft \bd ڒبْحَارْ‘\bd* - نِيغْ ’إِلْ‘. \bd ’ثَاڭرْسْثْ‘\bd* - نِيغْ ’ڒْمشْطَا‘.\f*  \x ◘ \xo 14:‏8 \xt حِز. 47‏:‏1‏-‏12؛ يُووِ. 4‏:‏18؛ أَسَا. 22‏:‏1\x*
\v 9 سِيذِي أَذْ يِيڒِي ذ أَجدْجِيذْ خْ مَارَّا ثَامُّورْثْ.
\b
\m \bd ذڭْ وَاسّْ نِّي\bd* أَذْ يِيڒِي نتَّا ذ أَينِّي ن سِيذِي ؤُ إِسمْ نّسْ ذ أَينِّي ن يِيسمْ.
\v 10 مَارَّا ثَامُّورْثْ أَذْ ثذْوڒْ أَمْ ڒوْضَا، زِي جَابْعَا أَڒْ رِيمُّونْ، غَارْ \add جِّيهثْ ن\add* لْجَانُوبْ ن ؤُرْشَالِيمْ. \add ثَانْذِينْثْ\add* أَذْ ثتّْوَاسّْڭعّذْ ؤُ أَذْ ذَايسْ زذْغنْ \add إِوْذَانْ\add* ذڭْ ومْشَانْ نّسْ، زِي ثوَّارْثْ ن بِينْيَامِينْ أَڒْ أَمْشَانْ ن ثوَّارْثْ إِ ذِينْ ثُوغَا زِيشْ، أَڒْ ثَاوَّارْثْ ن ثغْمَارْثْ، ؤُ زِي لْبُورْجْ ن حَانَانِييِيلْ أَڒْ ثِيسَارِينْ ن وحْرَايْ ن دِّيڒشْثْ ن ؤُجدْجِيذْ.
\v 11 نِيثْنِي أَذْ ذَايسْ زذْغنْ ؤُ وَارْ إِتِّيڒِي عَاذْ ؤُڒَا ذ إِجّْ ن ؤُحَارّمْ إِ ؤُثحِّي، مِينْزِي ؤُرْشَالِيمْ أَذْ إِزْذغْ ذِي ڒَامَانْ.
\b
\m 
\v 12 ثَا أَذْ ثِيڒِي ذ ثِيشْثِي إِ زِي غَا إِوّثْ سِيذِي مَارَّا ڒڭْنُوسْ نِّي إِمّنْغنْ أَكْ-ذ ؤُرْشَالِيمْ: نتَّا أَذْ يَارّْ أَرِّيمثْ ن كُوڒْ \add بْنَاذمْ\add* أَذْ إِكِّيشُّو أَمْ نتَّا عَاذْ إِبدّْ خْ إِضَارنْ نّسْ ؤُ ثِيطَّاوِينْ نّسْ أَذْ كِّيشّْونْثْ ذڭْ إِخُوبَاشْ نْسنْ ؤُ إِڒسْ نّسْ أَذْ إِكِّيشُّو ذڭْ ؤُقمُّومْ نّسْ. \f ◼ \fr 14:‏12 \ft \bd ’أَقمُّومْ نّسْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَقمُّومْ نْسنْ‘.\f*
\b
\m 
\v 13 \bd ذڭْ وَاسّْ نِّي\bd* ڭُّورْ أَذْ إِمْسَارْ أَقَا إِجّْ ن ؤُمْخَارْوضْ ذ أَمقّْرَانْ زِي سِيذِي أَذْ إِذْوڒْ جَارْ أَسنْ، أَڒَامِي غَا إِطّفْ كُوڒْ إِجّْ أَفُوسْ ن جَّارْ نّسْ ؤُ \add خنِّي\add* أَفُوسْ ن كُوڒْ إِجّنْ أَذْ إِنّقْڒبْ ضِيدّْ إِ ؤُفُوسْ ن جَّارْ نّسْ.
\v 14 عَاذْ أَذْ إِمّْنغْ يَاهُوذَا ذِي ؤُرْشَالِيمْ ؤُشَا أَذْ تّْوَاسّْمُوننْ وَاڭْڒَا ن مَارَّا ڒڭْنُوسْ إِ ذ أَسْ د-إِنّْضنْ: ؤُرغْ ذ نُّوقَارْثْ ذ وَارُّوضْ أَطَّاسْ س وَاطَّاسْ.
\v 15 أَمُّو إِ غَا ثِيڒِي \add عَاوذْ\add* ثشْثِي ن ؤُيِيسْ ذ ؤُسَارْذُونْ ذ وڒْغمْ ذ يغْيَاڒْ ذ مَارَّا ڒْمَاڒْ نِّي \add إِدْجَانْ\add* ذِي ڒْعسْكَارَاثْ، أَقَا ثِيشْثِي-يَا \add أَذْ ثنْ ثڒْقفْ\add*.
\b
\m 
\v 16 \add خنِّي\add* أَذْ إِمْسَارْ أَقَا مَارَّا إِنِّي إِقِّيمنْ زِي مَارَّا ڒڭْنُوسْ نِّي د-يُوسِينْ غَارْ ؤُرْشَالِيمْ \add إِ ڒحْصَارثْ\add*، أَذْ ڭعّْذنْ زڭْ ؤُسڭّْوَاسْ أَڒْ أَسڭّْوَاسْ، حِيمَا أَذْ بنْذْقنْ زَّاثْ إِ ؤُجدْجِيذْ، إِ سِيذِي ن ڒْعسْكَارَاثْ ؤُ حِيمَا أَذْعيّْذنْ ڒْعِيذْ ن إِعُوشُّوثنْ. \x ◘ \xo 14:‏16 \xt إِشا. 66‏:‏23\x*
\v 17 أَذْ إِمْسَارْ بلِّي مَانْ ونْ زِي ڒَادْجَاثْ ن ثمُّورْثْ وَارْ د-إِتّْڭِيعِّيذْ شَا غَارْ ؤُرْشَالِيمْ حِيمَا أَذْ إِبنْذقْ إِ ؤُجدْجِيذْ، إِ سِيذِي ن ڒْعسْكَارَاثْ، أَقَا وَارْ خَاسْ إِوطِّي شَا ونْژَارْ.
\v 18 مَاڒَا ڒَادْجْ ن مِيصْرَا وَارْ د-إِڭعّذْ ؤُ وَارْ د-ثُوسِي شَا، \add خنِّي\add* وَارْ خَاسنْ \add إِشِّيثْ\add* ونْژَارْ. ثَا أَذْ ثِيڒِي ذ ثِيشْثِي إِ زِي غَا إِڒْقفْ سِيذِي ڒڭْنُوسْ نِّي وَارْ ذِينْ إِتّْڭِيعِّيذنْ شَا حِيمَا أَذْعيّْذنْ فِيشْثَا ن ڒْعِيذْ ن إِعُوشُّوثنْ.
\v 19 ثَا ڭُّورْ أَذْ ثِيڒِي ذ ثِيشْثِي إِ دّْنُوبْ ن مِيصْرَا ؤُڒَا ذ ثِيشْثِي إِ مَارَّا ڒڭْنُوسْ، إِنِّي وَارْ ذِينْ إِتّْڭعّذنْ، حِيمَا أَذْعيّْذنْ ڒْعِيذْ ن إِعُوشُّوثنْ.
\b
\m 
\v 20 \bd ذڭْ وَاسّْ نِّي\bd* ڭُّورْ أَذْ يِيڒِي خْ ثْنَاقُوسِينْ ن ييْسَانْ ’ذ أَمْقدَّاسْ إِ سِيذِي!‘ تّْنَاجَارْ ذِي ثَادَّارْثْ ن سِيذِي أَذْ إِڒِينْ أَمْ طَّاوْيَاثْ إِ ؤُرُوشِّي زَّاثْ إِ ؤُعَالْطَارْ.
\v 21 مَارَّا تّْنَاجَارْ ذِي ؤُرْشَالِيمْ ؤُ ذِي يَاهُوذَا أَذْ إِڒِينْ قدّْسنْ إِ سِيذِي ن ڒْعسْكَارَاثْ ؤُ مَارَّا إِنِّي إِ د غَا يَاسنْ حِيمَا أَذْ قدّْمنْ ثِيوْهِيبِينْ، أَذْ زَّايْسنْثْ كْسِينْ ؤُ أَذْ ذَايْسنْثْ سّْننَّانْ.
\b
\m \bd ذڭْ وَاسّْ نِّي\bd* وَارْ \add ذِينْ\add* إِتِّيڒِي ؤُڒَا ذ إِجّْ ن ؤُكنْعَانِي ذِي ثَادَّارْثْ ن سِيذِي ن ڒْعسْكَارَاثْ.“ \x ◘ \xo 14:‏21 \xt إِشا. 35‏:‏8؛ يُووِ. 4‏:‏17؛ أَسَا. 21‏:‏27؛ 22‏:‏15\x* 
