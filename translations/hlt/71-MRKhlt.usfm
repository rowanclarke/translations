\v 10 Te \w dongah|strong="G2532"\w* amah \w bueng|strong="G3441"\w* a \w om|strong="G1096"\w* \w vaengah|strong="G3753"\w*, \w a|strong="G0846"\w* \w taengvai|strong="G4012"\w* \w rhoek|strong="G3588"\w* \w neh|strong="G4862"\w* \w hlainit|strong="G1427"\w* \w rhoek|strong="G3588"\w* loh \w nuettahnah|strong="G3850"\w* \w te|strong="G3588"\w* a \w dawt|strong="G2065"\w* uh.  
\v 11 Te \w dongah|strong="G2532"\w* \w amih|strong="G0846"\w* te, \wj “ \+w Pathen|strong="G2316"\+w* \+w ram|strong="G0932"\+w* \+w kah|strong="G3588"\+w* \+w olhuep|strong="G3466"\+w* \+w te|strong="G3588"\+w* \+w nangmih|strong="G5213"\+w* \+w m'paek|strong="G1325"\+w* coeng. \+w Tedae|strong="G1161"\+w* \+w poengben|strong="G1854"\+w* kah \+w rhoek|strong="G1565"\+w* ham tah soeprhep \+w boeih|strong="G3956"\+w* \+w te|strong="G3588"\+w* \+w nuettahnah|strong="G3850"\+w* \+w la|strong="G1722"\+w* a \+w om|strong="G1096"\+w* pah\wj*.  
\v 12 \x - \xo 4.12 \xt Isa 6. 9,10.\x*\wj Te \+w daengah|strong="G2443"\+w* ni a \+w hmuh|strong="G0991"\+w* tah a \+w hmuh|strong="G0991"\+w* uh sui \+w dae|strong="G2532"\+w* a \+w hmat|strong="G3708"\+w* uh \+w pawt|strong="G3361"\+w* eh, a \+w yaak|strong="G0191"\+w* tah a \+w yaak|strong="G0191"\+w* uh sui \+w dae|strong="G2532"\+w* a \+w hmuhming|strong="G4920"\+w* uh \+w pawt|strong="G3361"\+w* eh. Ha \+w mael|strong="G1994"\+w* uh \+w vetih|strong="G2532"\+w* \+w amih|strong="G0846"\+w* te vik \+w hlah|strong="G0863"\+w* \+w ve|strong="G3379"\+w*,” \wj* a \w ti|strong="G3004"\w* nah.   
\s1 Thuinuetnah a Thuicaih  
\p
\v 13 Te \w phoeiah|strong="G2532"\w* \w amih|strong="G0846"\w* te, \wj “ \+w Hekah|strong="G5026"\+w* \+w nuettahnah|strong="G3850"\+w* \+w he|strong="G3588"\+w* na \+w ming|strong="G1492"\+w* uh \+w pawt|strong="G3756"\+w* \+w atah|strong="G2532"\+w* \+w nuettahnah|strong="G3850"\+w* \+w boeih|strong="G3956"\+w* \+w te|strong="G3588"\+w* \+w metlam|strong="G4459"\+w* na \+w ming|strong="G1097"\+w* uh eh?\wj*  
