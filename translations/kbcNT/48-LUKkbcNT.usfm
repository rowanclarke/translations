\c 4  
\s1 ĮĪodaxakawa dineetalo Jesus 
\r (Mateus 4.1-11; Marcos 1.12-13) 
\p  
\v 1 AneotedoÉĄĖķoji Liwigo ini miniwataÉĄĖķa Jesus. NaÉĄĖķa dopitedijo Jesus me icoÉĄĖķotedicogi akiidi JordÃĢo, odaa Liwigo AneotedoÉĄĖķoji ja yadeegitedicogi miditaÉĄĖķa nipodigi ane yadilo, ane diÉĄĖķica niÉĄĖķeladimigipi.  
\v 2 NiÉĄĖķicoatigilo cwareenta nokododi, odaa diaabo ja dineetalo Jesus me domeÉĄĖķeo deÉĄĖķeote libeyaceÉĄĖķegi. NiÉĄĖķijoa nokododi aÉĄĖķica ane yeligo, odaa niÉĄĖķidiaaÉĄĖķidi ja nigicile.  
\v 3 Odaa ÉĄĖķodaxakawa jeÉĄĖķeetalo, âNigewi makaami Lionigi AneotedoÉĄĖķoji, awii niÉĄĖķinoa wetiadi me paontedi.â  
\v 4 Odaa Jesus ja igidi, meeteta, âAjakadi, igaataÉĄĖķa lotaÉĄĖķanaÉĄĖķaxi AneotedoÉĄĖķoji diniditeloco me diÉĄĖķinokina paon meo lewiÉĄĖķa oko, pida oko ewi mida lewiÉĄĖķa leeÉĄĖķodi niÉĄĖķina meyiwaÉĄĖķadi inoatawece lotaÉĄĖķa AneotedoÉĄĖķoji.â 
\p  
\v 5 Odaa diaabo ja yadeegitedicogi Jesus digoida maditaÉĄĖķa aca aneneÉĄĖķegi daÉĄĖķaxa me leegitibigimece wetiÉĄĖķa. Odaa aniÉĄĖķica daÉĄĖķa leegi, ja ikeetalo icoatawece niÉĄĖķicoa iiÉĄĖķotedi.  
\v 6 Odaa jeÉĄĖķeetalo Jesus, âJajigotaÉĄĖķawa ÉĄĖķanaÉĄĖķatetigi me iiÉĄĖķeni inoatawece iiÉĄĖķotedi, codaa jajigotedaÉĄĖķawa inoatawece ane libinico aneiteloco. IgaataÉĄĖķa inoatawece onajigotediwa, odaa jakadi maÉĄĖķaÉĄĖķa jajigota okanicodaaÉĄĖķica ane jemaa me jajigota.  
\v 7 Odaa idiwatawece niÉĄĖķidiwa ÉĄĖķanepilidi, nige amakitedini ÉĄĖķadokotidi yodoe moÉĄĖķeetetiwa.â  
\v 8 Odaa Jesus ja igidi, meeteta, âEmii opili SatanÃĄs! IgaataÉĄĖķa diniditeloco AneotedoÉĄĖķoji lotaÉĄĖķanaÉĄĖķaxi, âOÉĄĖķeetetalo ĮĪaniotagodi AneotedoÉĄĖķoji, codaa iniokiniwateda moÉĄĖķeetetalo.ââ 
\p  
\v 9 Odaa diaabo ja yadeegitedicogi Jesus nigotaÉĄĖķa JerusalÃĐm, odaa ideyate miditaÉĄĖķa ica ane daÉĄĖķaxa me leegitibigimece mini liÉĄĖķeladi AneotedoÉĄĖķoji, odaa meetalo, âNigewi makaami Lionigi AneotedoÉĄĖķoji, adinaxokitinece natinedi.  
\v 10 IgaataÉĄĖķa diniditeloco AneotedoÉĄĖķoji lotaÉĄĖķanaÉĄĖķaxi, âAneotedoÉĄĖķoji me niiÉĄĖķe niaanjotedi modoweditaÉĄĖķalocoâ.  
\v 11 Codaa aaÉĄĖķaÉĄĖķa diniditini, âMoilokaditalo ÉĄĖķabaaÉĄĖķatedi modoweditaÉĄĖķaloco me deÉĄĖķetaciloteda ÉĄĖķadoÉĄĖķonaka midiwa wetiadi.ââ 
\p  
\v 12 Odaa Jesus ja igidi, meeteta, âAjakadi, igaataÉĄĖķa madi lotaÉĄĖķanaÉĄĖķaxi AneotedoÉĄĖķoji diniditeloco, âJinaÉĄĖķa adineenitalo ĮĪoniotagodi AneotedoÉĄĖķoji.ââ 
\p  
\v 13 NiÉĄĖķijo diaabo naÉĄĖķa ika me dineetalo Jesus minoatawece niÉĄĖķicoa anigotalo, odaa ja ikanawaanigi micaaniÉĄĖķigotalo. 
\s1 Jesus yojogotedini libakedi digoida nipodigi GalilÃĐia 
\r (Mateus 4.12-17; Marcos 1.14-15) 
\p  
\v 14 Jesus opitacedicogi nipodigi GalilÃĐia, niÉĄĖķica AneotedoÉĄĖķoji Liwigo jeÉĄĖķeliodi me yajigotalo loniciwaÉĄĖķa. Odaa niÉĄĖķicoa nibodicetedi anoditece Jesus joniÉĄĖķilaagiteloco iditawece niÉĄĖķidi nipodigi.  
\v 15 Odaa diiÉĄĖķaxinaÉĄĖķa midiwa liiakanaÉĄĖķaxiidi judeutedi, odaa ijotawece ica oko anowajipatalo oiweniÉĄĖķide. 
\s1 NiÉĄĖķeladimigipitigi nigotaÉĄĖķa NazarÃĐ aÉĄĖķodibatege Jesus 
\r (Mateus 13.53-58; Marcos 6.1-6) 
\p  
\v 16 Jesus niÉĄĖķicotedicogi nigotaÉĄĖķa NazarÃĐ ane liidaÉĄĖķadi. Odaa naÉĄĖķa saabado, jiÉĄĖķigo mani liiakanaÉĄĖķaxi judeutedi ane lakatigitedibece. Odaa ja dabiditedini me dalomeÉĄĖķenataka.  
\v 17 Oyajigotalo notaÉĄĖķanaÉĄĖķaxi ane idÃ­ IsaÃ­as, niÉĄĖķijo ane yeloÉĄĖķoditedibece lowooko AneotedoÉĄĖķoji. Odaa Jesus naÉĄĖķa yowiegi naÉĄĖķadi notaÉĄĖķanaÉĄĖķaxi, yowiegitedeloco midiwa nidiko anee, 
\q1  
\v 18 âLiwigo ĮĪoniotagodi AneotedoÉĄĖķoji etini meetaÉĄĖķa. 
\q1 IgaataÉĄĖķa ee liomaÉĄĖķatagi, 
\q1 codaa me najigotiwa inimaweneÉĄĖķegi me jeloÉĄĖķoditedibece nibodicetedi anele midiwa madewetedi. 
\q1 IdiiÉĄĖķe me jeloÉĄĖķoditiogi niwilogojedi me jikaticoace, 
\q1 codaa jeloÉĄĖķoditiogi ÉĄĖķoladi me jao me yatetacibigiwaji, 
\q1 codaa me jao moiwoko niÉĄĖķijo anoiatetibeci. 
\q1  
\v 19 IdiiÉĄĖķe me jeloÉĄĖķoditiogi niÉĄĖķica nicaaÉĄĖķabi 
\q1 nige ikee ĮĪoniotagodi AneotedoÉĄĖķoji meliodi meletetema niÉĄĖķina oko.â 
\p  
\v 20 Odaa Jesus ja ilipaditacediwage naÉĄĖķajo notaÉĄĖķanaÉĄĖķaxi, odaa ja yopilaÉĄĖķadite niÉĄĖķijo nowienoÉĄĖķodi niiakanaÉĄĖķaxi. Odaa ja nicotacedini. Ijotawece oko mani niiakanaÉĄĖķaxi owatacotece.  
\v 21 Odaa ja dotaÉĄĖķa, meetediogi, âNiÉĄĖķina noko, niÉĄĖķidi ane diniditeloco niÉĄĖķidi liwai lotaÉĄĖķanaÉĄĖķaxi AneotedoÉĄĖķoji anajipaatatiwaji natigide, jiÉĄĖķicota. (LeeÉĄĖķodi jiÉĄĖķidaa idinanatigi me jiba.)â 
\p  
\v 22 Iditawece oko ele modotaÉĄĖķatibige Jesus, codaa oyopo leeÉĄĖķodi lotaÉĄĖķa libinienaÉĄĖķa. Odaa modi, âIca mele me dotaÉĄĖķa, niÉĄĖķidooda lionigi JosÃĐ!â 
\p  
\v 23 (Jesus naÉĄĖķa yowooÉĄĖķodi me doÉĄĖķodibatege.) Odaa meetediogi, âAjawienataka menitiwatiwaji niÉĄĖķijo nigegi anee, âDotowegi, akamaÉĄĖķa adinicilatiti!â Codaa maÉĄĖķaÉĄĖķa enitiwa, âAwii digoina manataÉĄĖķa naÉĄĖķana ÉĄĖķanigotaÉĄĖķa niÉĄĖķijoa ane jibodicaÉĄĖķatalo mawiite manitaÉĄĖķa nigotaÉĄĖķa Cafarnaum.ââ  
\v 24 Odaa mee, âJeloÉĄĖķoditaÉĄĖķawatiwaji niÉĄĖķina anewi, aÉĄĖķica ini ane yeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko anele modibatege miditaÉĄĖķa epaa loiigi.  
\v 25 Diganajipaatiwatiwaji! NiÉĄĖķijo jotigide owidi wajekalodi digoina ÉĄĖķoniiÉĄĖķo Israel malee yewiÉĄĖķa Elias, niÉĄĖķijo ane yeloÉĄĖķoditibece AneotedoÉĄĖķoji lowooko, niÉĄĖķijo me daÉĄĖķa datiode itoatadiÉĄĖķida nicaaÉĄĖķape niÉĄĖķigo meeya. Odaa eliodi niÉĄĖķica nigigi inatawece ÉĄĖķoniiÉĄĖķo.  
\v 26 Pida AneotedoÉĄĖķoji aiiÉĄĖķe Elias me yaxawa anigeteÉĄĖķepidaÉĄĖķaca niÉĄĖķina wajekalodipi judeutedi, digoina Israel. Pida iiÉĄĖķe Elias manitaÉĄĖķa aca wajekalo ane daÉĄĖķa ÉĄĖķodoiigi, ane liÉĄĖķeladi mani nigotaÉĄĖķa Sarepta digoida nipodigi Sidom ane daÉĄĖķa ÉĄĖķonipodigi.  
\v 27 Eledi eliodi dawace-loolatedi judeutedi digoina Israel maleeÉĄĖķijo Eliseu, inaaÉĄĖķina ane yeloÉĄĖķoditedibece lowooko AneotedoÉĄĖķoji. Pida aÉĄĖķica ane icilatidi. Ijokijo NaamÃĢ, ane loiigi siiriotedi, baÉĄĖķa icilatidi.â 
\p  
\v 28 NiÉĄĖķijo noÉĄĖķowajipatalo Jesus lotaÉĄĖķa, ijotawece niÉĄĖķijo ane idei mani liiakanaÉĄĖķaxi judeutedi eliodi me neliÉĄĖķideeÉĄĖķa.  
\v 29 Odaa ja dabiditiniwace oixigitedicogi wetice nigotaÉĄĖķa. NaÉĄĖķani nigotaÉĄĖķa idei ditibigimedi ica lojotaÉĄĖķadi, odaa joÉĄĖķoyadeegitedicogi Jesus ditibigimedi lojotaÉĄĖķadi domaÉĄĖķa oyamaÉĄĖķatedinece wakagi iiÉĄĖķo.  
\v 30 Pida Jesus yakagiditediogi liwigotigi niÉĄĖķijo noiigi, odaa joÉĄĖķopi. 
\s1 Ica ÉĄĖķoneleegiwa ane dakatiogi niwigo abeyaceÉĄĖķegi 
\r (Marcos 1.21-28) 
\p  
\v 31 Jesus one dinikatedinicogi manitaÉĄĖķa aca nigotaÉĄĖķa Cafarnaum nipodigi GalilÃĐia. Odaa niiÉĄĖķaxitediniwace niÉĄĖķidi noiigi me saabado.  
\v 32 Eliodi moyopo leeÉĄĖķodi anodaaÉĄĖķeeteda me diiÉĄĖķaxinaÉĄĖķa, igaataÉĄĖķa dotaÉĄĖķa micataÉĄĖķa anida epaa naÉĄĖķatetigi.  
\v 33 ManitaÉĄĖķa niiakanaÉĄĖķaxi aneite me diiÉĄĖķaxinaÉĄĖķa onini ica ÉĄĖķoneleegiwa anodakatiogi, icoa lowooko one beyagi. Odaa igedi me dotaÉĄĖķa, mee,  
\v 34 âAmiina anemaanitoÉĄĖķodici, Jesus ane ÉĄĖķadiÉĄĖķeladi NazarÃĐ? Domige naÉĄĖķanagi me ÉĄĖķodaaÉĄĖķateÉĄĖķegi? JowooÉĄĖķodi anakaami! JaÉĄĖķakamaÉĄĖķakaami ane niiÉĄĖķe AneotedoÉĄĖķoji, codaa iniokiniwateda mabaatema.â 
\p  
\v 35 Odaa Jesus ja yapeteÉĄĖķe, meeteta, âAnotokiti, codaa anotitice niÉĄĖķida ÉĄĖķoneleegiwa!â NiÉĄĖķijo niwigo abeyaceÉĄĖķegi yokoletinigi iiÉĄĖķo niÉĄĖķijo ÉĄĖķoneleegiwa lodoe ijotawece niÉĄĖķijo noiigi, pida aÉĄĖķica elaciledi niÉĄĖķijo ÉĄĖķoneleegiwa. Odaa ja noditice niwigo abeyaceÉĄĖķegi. 
\p  
\v 36 Iditawece niÉĄĖķica oko nawelatibigiwaji, odaa dinotaÉĄĖķaneÉĄĖķe midiaaÉĄĖķiditiwage, modi, âGanigaaleeÉĄĖķinoa niÉĄĖķinoa lotaÉĄĖķa! IgaataÉĄĖķa ida nimaweneÉĄĖķegi codaa me loniciwaÉĄĖķa me iticoitedice niwicidi abeyacaÉĄĖķaÉĄĖķa. NiÉĄĖķina me iiÉĄĖķe, odaa ja noditicoaci.â  
\v 37 Odaa nibodicetedi anoditece Jesus jiÉĄĖķilaagiteloco iditawece niÉĄĖķidi nipodigi. 
\s1 Jesus nicilatiditediniwace eliodi oko 
\r (Mateus 8.14-17; Marcos 1.29-34) 
\p  
\v 38 Jesus naÉĄĖķa noditedice niiakanaÉĄĖķaxi, odaa jiÉĄĖķigo liÉĄĖķeladi SimÃĢo. Aca loxiiÉĄĖķate SimÃĢo one deelotika, dapicoÉĄĖķo-lolaadi. Odaa joÉĄĖķodipokotalo Jesus me icilatidi.  
\v 39 Odaa Jesus jiÉĄĖķigo. NiÉĄĖķicoteta naÉĄĖķajo iwaalo, odaa ja dakagitedeloco, ja iiÉĄĖķe me noditice dapicoÉĄĖķo-lolaadi. Odaa aÉĄĖķica daÉĄĖķa leegi ja icÃ­, odaa ja dabiditini, ja doolaÉĄĖķatema ĮĪoniotagodi idiaa lokaaÉĄĖķetedipi. 
\p  
\v 40 NiÉĄĖķijo naÉĄĖķa dalimeti aligeÉĄĖķe, niÉĄĖķica oko anini litaagi ane deelotika, oyadeegitalo Jesus. Adinatopiamico leelotika. Jesus dibatedeloco oninitecibeci ane deelotika, odaa ja icilatidi.  
\v 41 Niwicidi abeyacaÉĄĖķaÉĄĖķa noditicoaci mijotaÉĄĖķa eliodi oko. NaÉĄĖķa noditicoaci, dinigetaÉĄĖķateetibigiwaji me notaÉĄĖķanaÉĄĖķa, modi, âJa makamaÉĄĖķakaami Lionigi AneotedoÉĄĖķoji!â OyowooÉĄĖķodi niÉĄĖķidaaÉĄĖķidoa niÉĄĖķicoa Cristo, ane niiÉĄĖķe AneotedoÉĄĖķoji me ÉĄĖķodewikatidi. Pida joaniÉĄĖķidaa leeÉĄĖķodi Jesus me yapeteÉĄĖķe, codaa aika modi niÉĄĖķijaaÉĄĖķijoa icoa Cristo. 
\s1 Jesus yeloÉĄĖķoditedibece nibodicetedi anele 
\r (Marcos 1.35-39) 
\p  
\v 42 NiÉĄĖķijo naÉĄĖķa yeloÉĄĖķotibige, Jesus ja noditedice nigotaÉĄĖķa, igo miditaÉĄĖķa nipodigi ane diÉĄĖķica niÉĄĖķeladimigipi. NiÉĄĖķijo noiigi odoletibige, odaa noÉĄĖķodakapetege, adomaÉĄĖķaleeÉĄĖķoikatedice mopi.  
\v 43 Pida Jesus meetediogi, âLeeditibige mejigo jeloÉĄĖķoditedibece nibodicetedi anele midiwataÉĄĖķa eletidi nigotadi. IgaataÉĄĖķa idiiÉĄĖķe AneotedoÉĄĖķoji me jeloÉĄĖķoditedibece nibodicetedi anele, me icota anigida noko iiÉĄĖķe inatawece niÉĄĖķina noiigitigi niÉĄĖķina iiÉĄĖķo.â  
\v 44 Odaa ja yatematitedibece nibodicetedi anele midiwataÉĄĖķa niiakanaÉĄĖķaxiidi nipodigiteloco GalilÃĐia. 
\c 5  
\s1 Jesus eniditediogi niÉĄĖķica odoejedipi anodiotibece 
\r (Mateus 4.18-22; Marcos 1.16-20) 
\p  
\v 1 Ica noko Jesus ideite liniogotibece niweiigi GenesarÃĐ (eledi liboonaÉĄĖķadi me GalilÃĐia), odaa niÉĄĖķica noiigi joÉĄĖķodiniligicetelogo, leeÉĄĖķodi moyemaa mowajipatalo AneotedoÉĄĖķoji lotaÉĄĖķa.  
\v 2 Odaa naÉĄĖķa nadi icoa itiwataale niwateceli ane ideitedice liniogotibece weiigi. NiÉĄĖķijo nomiigomigipi waxoditicoace liwateceli, oiwilegi leelatiidi anoibake me nomiigomigipi.  
\v 3 Odaa Jesus jona waxoditedinigi aca niwatece ane SimÃĢo nebi. Odaa jona dipokote me yotonawaanigitice liniogotibece. Odaa naÉĄĖķa nicotedini Jesus, ja niiÉĄĖķaxitediniwace niÉĄĖķijo noiigi, ideite catinedi naÉĄĖķajo niwatece. 
\p  
\v 4 NiÉĄĖķijo naÉĄĖķa ika me niiÉĄĖķaxitediniwace niÉĄĖķijo noiigi, odaa meeteta SimÃĢo, âAdeegiticogi ÉĄĖķawatece digoida liwigotinigi, odaa okolenitinitiwaji ÉĄĖķadeelatiidi abaatalo noÉĄĖķojedi.â 
\p  
\v 5 Odaa SimÃĢo ja niniÉĄĖķodi, meetalo, âĮĪoniiÉĄĖķaxinoÉĄĖķodi, ja jomiigaÉĄĖķa ijotawece enoale, aÉĄĖķica ÉĄĖķobakajetege. Pida leeÉĄĖķodi makaami ÉĄĖķodiiÉĄĖķeneÉĄĖķegi, jiÉĄĖķidaa leeÉĄĖķodi nige jokolenaÉĄĖķatacedini ÉĄĖķodeelatiidi.â  
\v 6 Odaa niÉĄĖķijo noÉĄĖķoyokoletedini leelatiidi, owidi niÉĄĖķicoa libakajetedi noÉĄĖķojedi, ja domaÉĄĖķa daa niÉĄĖķijoa leelatiidi.  
\v 7 Odaa joÉĄĖķoyategitiogi icoa eletidi lokaaÉĄĖķetedi maditaÉĄĖķa aca eledi niwatece menagitibeci oyaxawatiogi. NeÉĄĖķenagitibeci odaa joÉĄĖķoyetigilo niÉĄĖķijoa niwateceli noÉĄĖķojedi, jona domaÉĄĖķa domololetedini, leeÉĄĖķodi me daÉĄĖķaxa me iwaaÉĄĖķadi niÉĄĖķijoa noÉĄĖķojedi. \fig |src="CN01875B.TIF" size="span" copy="ÂĐ 1978 David C. Cook Publishing Co." ref="Lucas 5.6-7" \fig* 
\v 8 NiÉĄĖķijo SimÃĢo Pedro naÉĄĖķa nadi loniciwaÉĄĖķa Jesus, odaa ja yamaÉĄĖķatedini lokotidi lodoe Jesus, odaa meetalo, âAdiwikodeni, adotonitice Iniotagodi, igaataÉĄĖķa eemoda ÉĄĖķoneleegiwa aninoa libatico!â 
\p  
\v 9 Eo niÉĄĖķida ligegi leeÉĄĖķodi SimÃĢo ijaaÉĄĖķijoa eletidi ane idei mijotaÉĄĖķa eliodi moyopo loniciwaÉĄĖķa Jesus, igaataÉĄĖķa onowidi niÉĄĖķicoa noÉĄĖķojedi anodibatalo.  
\v 10 Tiago ijaa JoÃĢo lionigipi Zebedeu, lokaaÉĄĖķetedi SimÃĢo, eledi eliodi moyopo. Odaa Jesus jeÉĄĖķeete SimÃĢo, âJinaÉĄĖķadoii! NatigidiwaÉĄĖķa abaatalo noÉĄĖķojedi majicitiogi oko. Pida niÉĄĖķina natigide ja ÉĄĖķabakedi mawii metidadiwaÉĄĖķadi oko, odaa jaÉĄĖķajicitalo AneotedoÉĄĖķoji.â 
\p  
\v 11 Odaa noÉĄĖķoyadeegitedicogi liwateceli daato, odaa joÉĄĖķodiotece Jesus, joÉĄĖķoika ijoatawece ane libaketedi. 
\s1 Jesus icilatidi ica dawace-lolaadi 
\r (Mateus 8.1-4; Marcos 1.40-45) 
\p  
\v 12 Ica noko, Jesus me ideite manitaÉĄĖķa aca nigotaÉĄĖķa, odaa onini ica ÉĄĖķoneleegiwa ane daÉĄĖķaxatece ica dawace-lolaadi. NiÉĄĖķijo naÉĄĖķa naditege Jesus, odaa ja dakagitinigi iiÉĄĖķo neÉĄĖķepaa itinigi iiÉĄĖķo latobi, diniwikodetibece. Odaa ja dipokotalo Jesus, meetalo, âIniotagodi, nigemaani madicilatiti, jowooÉĄĖķodi mida ÉĄĖķadoniciwaÉĄĖķa madicilatiti.â  
\v 13 Odaa Jesus ja dibatedeloco, meete, âEe! Jemaa me ÉĄĖķadicili!â AoniÉĄĖķica daÉĄĖķa leegi jona icÃ­ niÉĄĖķijo ÉĄĖķoneleegiwa ane dawace-lolaadi.  
\v 14 Pida Jesus yajoi me diÉĄĖķica ane yeloÉĄĖķodita me icilatidi, meeteta, âEmii minitaÉĄĖķa ane libakadi AneotedoÉĄĖķoji liÉĄĖķeladi, adinikeenita, codaa aboonitalo AneotedoÉĄĖķoji niÉĄĖķijo eijeeÉĄĖķagi ane diiÉĄĖķenataka MoisÃĐs me dinalegi, amaleeÉĄĖķaÉĄĖķa oyowooÉĄĖķodi niÉĄĖķina oko naÉĄĖķa ÉĄĖķadicili.â 
\p  
\v 15 Pida niÉĄĖķijo okotigi anitawece nigotaÉĄĖķa jeÉĄĖķeliodi moyalaÉĄĖķatalo Jesus, odaa niÉĄĖķica noiigi joÉĄĖķototalo mowajipatalo lotaÉĄĖķa, codaa me nicilatiditediniwace.  
\v 16 Pida idioka limedi me dinoÉĄĖķatedicobece, migo miditaÉĄĖķa nipodigi ane diÉĄĖķica niÉĄĖķeladimigipi, yotaÉĄĖķaneÉĄĖķe AneotedoÉĄĖķoji. 
\s1 Jesus icilatidi ica alejaado ane daÉĄĖķadiaa ditineÉĄĖķe 
\r (Mateus 9.1-8; Marcos 2.1-12) 
\p  
\v 17 Ica noko Jesus niiÉĄĖķaxitediniwace ica noiigi. NiÉĄĖķica aneite, onidi me nicotiniwace icoa fariseutedi icaaÉĄĖķicoa niiÉĄĖķaxinaÉĄĖķanadi anodiiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs. OicoÉĄĖķoticogi inoatawece ane nigotadawaanaÉĄĖķa nipodaÉĄĖķa GalilÃĐia aniaa JudÃĐia, codaa me oicoÉĄĖķoticogi nigotaÉĄĖķa JerusalÃĐm. NiÉĄĖķica loniciwaÉĄĖķa ĮĪoniotagodi AneotedoÉĄĖķoji idei mijoataÉĄĖķa Jesus niÉĄĖķina me nicilatiditediniwace eelotaginadi.  
\v 18 Odaa digawini niciagi, onicoa icoa ÉĄĖķoneleegiwadi anoyadeegi ica alejaado ane daÉĄĖķadiaa ditineÉĄĖķe, one iwoteloco liÉĄĖķelate, odaa joÉĄĖķodoletibige nimaweneÉĄĖķegi me dakatiobece catiwedi diimigi aneite Jesus, domoÉĄĖķoyadeegiticogi niÉĄĖķijo ÉĄĖķoneleegiwa lodoe Jesus.  
\v 19 Pida aÉĄĖķoyakadi me dakatiobece leeÉĄĖķodi niÉĄĖķica noiigi-nelegi. Odaa joÉĄĖķonoÉĄĖķeletibigimece ditibigimedi diimigi lelÃĄÉĄĖķa. Odaa jonoÉĄĖķonoÉĄĖķa deegajoli, owo lawimaÉĄĖķajegi diimigi. NoÉĄĖķoigodi moyomoke niÉĄĖķijo diimigi lelÃĄÉĄĖķa, odaa joÉĄĖķoyexaÉĄĖķatinigi niÉĄĖķijo alejaado catinedi liÉĄĖķelate, odaa joÉĄĖķonikatini lodoe Jesus liwigotigi niÉĄĖķijo noiigi.  
\v 20 NiÉĄĖķijo Jesus naÉĄĖķa nadi mida eliwaÉĄĖķatakaneÉĄĖķegi niÉĄĖķijoa lokaaÉĄĖķetedi alejaado, odaa jeÉĄĖķeete, âYokaaÉĄĖķedi, ÉĄĖķabeyaceÉĄĖķeco ja inapitaÉĄĖķadi.â 
\p  
\v 21 Odaa niÉĄĖķijo anodiiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs, ijaaÉĄĖķijoa fariseutedi dinotaÉĄĖķaneÉĄĖķetiwage, modi, âAmiidoa icoa ÉĄĖķoneleegiwa ane diniciaceeketetege AneotedoÉĄĖķoji? IgaataÉĄĖķa iniokiniwateda AneotedoÉĄĖķoji me yakadi me napitaÉĄĖķadi oko libeyaceÉĄĖķeco.â 
\p  
\v 22 Pida Jesus ja yowooÉĄĖķodi niÉĄĖķica anodinotaÉĄĖķaneÉĄĖķetigi, odaa jeÉĄĖķeetediogi, âIgaamee ina mawii ida ÉĄĖķadowoogotiwaji?  
\v 23 Mige daÉĄĖķaxa me dakake mejita niÉĄĖķidi alejaado, âJa inapitaÉĄĖķadi ÉĄĖķabeyaceÉĄĖķeco,â oÉĄĖķoa, domige daÉĄĖķaxa me dakake me jiiÉĄĖķe me dabiditini, odaa jeÉĄĖķewaligi?  
\v 24 Pida natigide amaleeÉĄĖķaÉĄĖķa owooÉĄĖķotitiwaji, jikeetaÉĄĖķawa me Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, mida iiÉĄĖķenatakaneÉĄĖķegi digoina iiÉĄĖķo me inapitaÉĄĖķadi libeyaceÉĄĖķeco oko.â Odaa jeÉĄĖķeete niÉĄĖķijo alejaado, âAdabititini! Abaata ÉĄĖķadiÉĄĖķelate, odaa opiliticogi ÉĄĖķadiÉĄĖķeladi!â 
\p  
\v 25 AÉĄĖķica daÉĄĖķa leegi niÉĄĖķijo ÉĄĖķoneleegiwa ja dabiditi lodoe ijotawece niÉĄĖķijo noiigi, naÉĄĖķa dibata liÉĄĖķelate, odaa joÉĄĖķopiticogi liÉĄĖķeladi, diniotagodetibigimece AneotedoÉĄĖķoji.  
\v 26 Ijotawece niÉĄĖķijo noiigi eliodi moyopo, codaa odoÉĄĖķetetibigimece AneotedoÉĄĖķoji. Eliodi maÉĄĖķaÉĄĖķa doitibigiwaji, odaa modi, âNiÉĄĖķina noko, jinataÉĄĖķa nibinico ane diÉĄĖķicoa me jinataÉĄĖķa!â 
\s1 Jesus enidite Levi me diotibece 
\r (Mateus 9.9-13; Marcos 2.13-17) 
\p  
\v 27 NiÉĄĖķidiaaÉĄĖķidi Jesus naÉĄĖķa noditedice nigotaÉĄĖķa, odaa ja nadi ica ÉĄĖķoneleegiwa ane liboonaÉĄĖķadi Levi. One libakedi me dibatibigege ninyeelo ninionigi-eliodi romaanotedi. One nicote niÉĄĖķica aneitibige moyedia. Odaa Jesus jiÉĄĖķigo minitaÉĄĖķa, odaa jeÉĄĖķeete, âAnagi, aniwitici!â  
\v 28 Odaa Levi ja dabiditini, ja yaladi ane libakedi, odaa ja diotece Jesus. 
\p  
\v 29 Odaa Levi ja yaloke Jesus eo ica nalokegi nelegi mini liÉĄĖķeladi. Odaa eliodi niÉĄĖķica anodibatibigege ninyeelo ninionigi-eliodi romaanotedi, codaa meledi eliodi oko idi me nicoÉĄĖķowepodi.  
\v 30 Icoa fariseutedi icaaÉĄĖķicoa anodiiÉĄĖķaxinaÉĄĖķatece najoinaÉĄĖķaneÉĄĖķeco anida aneetege niÉĄĖķijo lapo fariseutedi eledi idi, joÉĄĖķoyalomeÉĄĖķe niÉĄĖķijo anodiotibece Jesus, moditiogi, âIgaamee ina me ÉĄĖķagiiwepoditiwaji idi anodibatibigege ninyeelo ninionigi-eliodi romaanotedi, codaa me niÉĄĖķinoa eletidi abeyacaÉĄĖķaÉĄĖķa?â 
\p  
\v 31 Odaa ja igidi Jesus, meetediogi, âNiÉĄĖķina anicileÉĄĖķegipi aÉĄĖķoyopotibige dotowegi, pida niÉĄĖķina ane neelotikanaÉĄĖķa boÉĄĖķoyopotibige dotowegi.  
\v 32 Ajanagi daÉĄĖķa jiniditiogi ane iÉĄĖķenaÉĄĖķatibigiwaji, pida janagi me jiniditiogi aninoa libeyaceÉĄĖķeco amaleeÉĄĖķaÉĄĖķa odinilaatece libeyaceÉĄĖķeco, odaa joÉĄĖķodopitalo AneotedoÉĄĖķoji.â 
\s1 Jesus diiÉĄĖķaxinaÉĄĖķatetece ica anodaaÉĄĖķee me jikanakawaanigi me jiniodaÉĄĖķa me jotaÉĄĖķaneÉĄĖķenaÉĄĖķa AneotedoÉĄĖķoji 
\r (Mateus 9.14-17; Marcos 2.18-22) 
\p  
\v 33 Ica noko moditalo Jesus, âNiÉĄĖķijo anodiotibeci JoÃĢo Batista idatecibece aniodaÉĄĖķa, owotibige meneÉĄĖķegi yoniciwaditibigiwaji moyotaÉĄĖķaneÉĄĖķe AneotedoÉĄĖķoji. AnaÉĄĖķaÉĄĖķa oniotoÉĄĖķodici ane fariseutedi idaaÉĄĖķee. Pida niÉĄĖķidi anodiotibigaÉĄĖķadici baadiÉĄĖķica doÉĄĖķoika me niodaÉĄĖķa.â 
\p  
\v 34 Odaa Jesus jeÉĄĖķeetediogi, âDomigakatitiwaji molii me niodaÉĄĖķa, niÉĄĖķina nodenigipi midi nadoneÉĄĖķegi, ina niÉĄĖķini miditaÉĄĖķa niÉĄĖķini ane wado?  
\v 35 Pida icota noko monoÉĄĖķatice niÉĄĖķini ane wado me ideitice liwigotigi. Odaa niÉĄĖķida noko joÉĄĖķoika me niodaÉĄĖķa.â 
\p  
\v 36 Jesus eledi yatematitediogi ica natematigo anida ane ÉĄĖķodiiÉĄĖķaxitece, meetediogi, âAÉĄĖķica ini ane dapadenaÉĄĖķata niÉĄĖķina lipegeteÉĄĖķe liwai gela daÉĄĖķa napadeteloco nowoodaÉĄĖķagi oxiiÉĄĖķodi. Nigica anidaÉĄĖķaee, ibeyacaÉĄĖķadi naÉĄĖķadi lapadexe, codaa niÉĄĖķina napadenaÉĄĖķanaÉĄĖķadi me gela aÉĄĖķeyotinigi niÉĄĖķina nowoodaÉĄĖķagi oxiiÉĄĖķodi.  
\v 37 Eleditace migini ane yadotinigi viinyo gela naÉĄĖķana laÉĄĖķaaÉĄĖķaxi ewacogo baanoÉĄĖķopake. Nigica anidaaÉĄĖķee, niÉĄĖķidiwa laÉĄĖķaaÉĄĖķaxidi laxokodi datope, odaa jaÉĄĖķanado niÉĄĖķica viinyo, codaa jaÉĄĖķaÉĄĖķa beyagi niÉĄĖķicoa laÉĄĖķaaÉĄĖķaxidi.  
\v 38 Leeditibige moyetigi niÉĄĖķina viinyo gela naÉĄĖķana laÉĄĖķaaÉĄĖķaxi gela.  
\v 39 Codaa aÉĄĖķica ane yemaa viinyo gela, niÉĄĖķina naÉĄĖķa eliodi me wacipeta viinyo oxiiÉĄĖķodi, igaataÉĄĖķa yakadi mee, âNiÉĄĖķina viinyo oxiiÉĄĖķodi daÉĄĖķaxa mele.ââ (Jesus yatemati niÉĄĖķida natematigo me ikee liiÉĄĖķaxinaÉĄĖķaneÉĄĖķeco mepaÉĄĖķa geladi.) 
\c 6  
\s1 Jesus diiÉĄĖķaxinaÉĄĖķatetece anodaaÉĄĖķee saabado 
\r (Mateus 12.1-8; Marcos 2.23-28) 
\p  
\v 1 NeÉĄĖķeledi saabado Jesus jonaÉĄĖķa yakagiditedeloco ica nixoÉĄĖķotagi aninaa leyeema. NiÉĄĖķijo anodiotibece onotegi noÉĄĖķonigakala, odaa joÉĄĖķoyeligo lolacidi leyeema.  
\v 2 Odaa onicoa icoa fariseutedi anodi, âIgaamee ina mawiitiwaji ida aneni, ÉĄĖķonajoinaÉĄĖķaneÉĄĖķeco aÉĄĖķodika me jaoÉĄĖķa niÉĄĖķida aneni niÉĄĖķina me saabado? (IgaataÉĄĖķa ane daÉĄĖķa ÉĄĖķodika me jaoÉĄĖķa okanicodaaÉĄĖķica nibakedi codaa me inigakalaÉĄĖķa leyeema).â  
\v 3 Jesus naÉĄĖķa igidi, meetediogi, âAgodiÉĄĖķica malomeÉĄĖķenitelocotiwaji, niÉĄĖķijo Davi loenatagi, naÉĄĖķa nigicile, ijaaÉĄĖķijoa lokaaÉĄĖķetedi.  
\v 4 Davi geme dakatiwece lopegedi AneotedoÉĄĖķoji. Odaa ja dibatalo niÉĄĖķijoa paontedi anoyajigotalo AneotedoÉĄĖķoji, odaa ja yeligo, ligiiwepodi lokaaÉĄĖķetedi. Pida ÉĄĖķonajoinaÉĄĖķaneÉĄĖķeco modi midiokidi moyakadi moyeligo niÉĄĖķidi ane nibaaÉĄĖķa mini AneotedoÉĄĖķoji lopegedi, niÉĄĖķidiwa paontedi anoibootalo AneotedoÉĄĖķoji.â (Pida aÉĄĖķica daÉĄĖķa nilaagedi Davi.)  
\v 5 Odaa Jesus jeÉĄĖķeetediogi, âEe, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, jeÉĄĖķemaÉĄĖķa jiiÉĄĖķe niÉĄĖķina anoyakadi mowo niÉĄĖķina me saabado.â 
\s1 Jesus icilatidi ica beyagi libaaÉĄĖķadi me saabado 
\r (Mateus 12.9-14; Marcos 3.1-6) 
\p  
\v 6 NeÉĄĖķeledi saabado, Jesus one dakatediwece niiakanaÉĄĖķaxi me diiÉĄĖķaxinaÉĄĖķa. Odaa oninica ÉĄĖķoneleegiwa alejaado, beyagi libaaÉĄĖķadi.  
\v 7 Icoa anodiiÉĄĖķaxinaÉĄĖķatece najoinaÉĄĖķaneÉĄĖķeco icoa fariseutedi, anaÉĄĖķaÉĄĖķa idi oiÉĄĖķoaditalo Jesus, oyemaa moiwi mige dicilatitaÉĄĖķa niÉĄĖķina me saabado. Owotibige moyakadi modotaÉĄĖķatibige Jesus me daÉĄĖķa yoteteteda saabado. (LeeÉĄĖķodi lakatigi judeutedi me daÉĄĖķa nibaaÉĄĖķa niÉĄĖķina me saabado.)  
\v 8 Pida Jesus yowooÉĄĖķoditediwe niÉĄĖķicoa lowooko. Odaa joaniÉĄĖķidaa leeÉĄĖķodi meete niÉĄĖķijo beyagi libaaÉĄĖķadi, âAdabititini lodoe niÉĄĖķina oko!â Odaa niÉĄĖķijo ÉĄĖķoneleegiwa ja dabiditi. 
\p  
\v 9 Odaa Jesus meetediogi, âĮĪadigeetiwaji, amiini ica ane diiÉĄĖķenatakata ÉĄĖķonajoinaÉĄĖķaneÉĄĖķeco me jaoÉĄĖķa ina me saabado? Domige ÉĄĖķodiiÉĄĖķe me jaoÉĄĖķa anele, oÉĄĖķoa, domige ane beyagi? Jakadi me inoÉĄĖķa ane yeloadi oko, oÉĄĖķoa domige jakadi me jeloadi oko?â  
\v 10 Odaa iwitediogi iditawece niÉĄĖķidi anoyawiile. Odaa meete Jesus niÉĄĖķijo ane beyagi libaaÉĄĖķadi, âIxokenitice ÉĄĖķabaaÉĄĖķadi!â NaÉĄĖķa ixoketice libaaÉĄĖķadi, odaa ja icÃ­.  
\v 11 Odaa eliodi me neliÉĄĖķideeÉĄĖķa niÉĄĖķijoa lakapetedipi, codaa odinotaÉĄĖķaneÉĄĖķetigi niÉĄĖķica anodigotalo Jesus. 
\s1 Jesus iomaÉĄĖķaditedice niÉĄĖķicoa dooze ÉĄĖķoneleegiwadi anodiotibece 
\r (Mateus 10.1-4; Marcos 3.13-19) 
\p  
\v 12 NiÉĄĖķijoa nokododi, Jesus igo dalaÉĄĖķatetedibigimece aca wetiÉĄĖķa me yotaÉĄĖķaneÉĄĖķe AneotedoÉĄĖķoji. Odaa idiaa ixomaÉĄĖķateetedice ijotawece enoale me yotaÉĄĖķaneÉĄĖķe AneotedoÉĄĖķoji.  
\v 13 NoÉĄĖķone yeloÉĄĖķotibige, Jesus jeÉĄĖķeniditediogi ÉĄĖķoneleegiwadi anodiotibece. Odaa ja iomaÉĄĖķaditedice dooze, odaa joniÉĄĖķida ica aneyatedigi me âLiiÉĄĖķexedi AneotedoÉĄĖķoji.â Odaa liboonaÉĄĖķatedi niÉĄĖķicoa ÉĄĖķoneleegiwadi:  
\v 14-16 SimÃĢo aneote Jesus me liboonaÉĄĖķadi me Pedro, ijaaÉĄĖķijo nioxoa anodita AndrÃĐ; Tiago, ijaa JoÃĢo, Filipe; ijaa Bartolomeu; Mateus ijaa TomÃĐ; Tiago ane lionigi Alfeu; SimÃĢo analeeÉĄĖķoyatigi me Zelotes; Judas ane lionigi eledi Tiago; ijaa Judas Iscariotes aneyaa Jesus mijotaÉĄĖķa neloÉĄĖķododipi. 
\s1 Jesus niiÉĄĖķaxitediniwace codaa me nicilatiditediniwace oko 
\r (Mateus 4.23-25) 
\p  
\v 17 Odaa noÉĄĖķone dinikatedini Jesus me icoÉĄĖķotedibigimece aca wetiÉĄĖķa, odaa ja dabiditedini miditaÉĄĖķa ica anabotiwage ijaaÉĄĖķijo noiigi anodiotibece. Codaa onidi ica eliodi oko aÉĄĖķicaadaÉĄĖķa icoÉĄĖķoticogi niÉĄĖķicoa nipodaÉĄĖķa JudÃĐia, codaa me nigotaÉĄĖķa JerusalÃĐm, codaa me nipodaÉĄĖķa aca Tiro aniaa Sidom, anodipegitinece ica akiidi-eliodi.  
\v 18 Igotibeci mowajipatalo lotaÉĄĖķa Jesus, codaa me nicilatiditediniwace leelotika. IcaaÉĄĖķica ane diotibece niwicidi abeyacaÉĄĖķaÉĄĖķa anowote niÉĄĖķinoa lowooko ane napioi, eledi igotibeci diniwakateetibigiwaji.  
\v 19 Ijotawece niÉĄĖķijo noiigi odoletibige modibatelogo Jesus, leeÉĄĖķodi noditice ica loniciwaÉĄĖķa ane icilatidi iditawece oko ane neelotikanaÉĄĖķa. 
\s1 Jesus diiÉĄĖķaxinaÉĄĖķatetece anodaaÉĄĖķee ica oko anida linikegi icaaÉĄĖķica ica oko ane agecaÉĄĖķalo 
\r (Mateus 5.1-12) 
\p  
\v 20 Jesus iwitediogi niÉĄĖķijo anodiotibece, odaa meetediogi, 
\q1 âNiÉĄĖķida makaamitiwaji aniniitibeci, 
\q1 anakaami madewetedi, 
\q1 igaataÉĄĖķa AneotedoÉĄĖķoji ja iiÉĄĖķe ÉĄĖķadaaleÉĄĖķena. 
\q1  
\v 21 Aniniitibecitiwaji ane anigicile niÉĄĖķina natigide, 
\q1 igaataÉĄĖķa icota me ÉĄĖķaditiminitiwaji. 
\q1 Aniniitibecitiwaji ane anoenitibece niÉĄĖķinoa nokododi, 
\q1 igaataÉĄĖķa icota malajikanitibece. 
\q1  
\v 22 Aniniitibeci niÉĄĖķina akaamitiwaji ane deÉĄĖķetiÉĄĖķademaani, 
\q1 ane deÉĄĖķele modibataÉĄĖķagi, 
\q1 codaa metiÉĄĖķadienitibige, 
\q1 nige odi makaami abeyacaÉĄĖķaÉĄĖķa, 
\q1 leeÉĄĖķodi maniwitici ane Ee, 
\q1 ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi. 
\p  
\v 23 NiÉĄĖķina nige ixomaÉĄĖķateenitedijo niÉĄĖķinoa nawikodico anejitalo, jemaa meliodi maniniitibecitiwaji. IgaataÉĄĖķa AneotedoÉĄĖķoji ja yotetetedaÉĄĖķadomi ane daÉĄĖķaxa meletaÉĄĖķadomitiwaji digoida ditibigimedi. IgaataÉĄĖķa diganee natigide, jiÉĄĖķidaaÉĄĖķee niÉĄĖķijo jotigide litacepodi niÉĄĖķina oko moyametibigo niÉĄĖķijo anoyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko. 
\q1  
\v 24 Pida akaamitiwaji biÉĄĖķicota meliodi mawikodeetiwaji, 
\q1 anakaami liicotedi, 
\q1 igaataÉĄĖķa jaÉĄĖķabaatege icoatawece niÉĄĖķicoa anakati mabaatege, 
\q1 aÉĄĖķaleeÉĄĖķabaatege eledi aneletaÉĄĖķadomi. 
\q1  
\v 25 Icota meliodi maÉĄĖķaÉĄĖķa awikodeetiwaji, 
\q1 akaami anele manioditiwaji niÉĄĖķinoa nokododi, 
\q1 igaataÉĄĖķa icota me ÉĄĖķadeloati nigigi. 
\q1 Codaa icota meliodi mawikodee, 
\q1 akaami ane alajikanitibece, 
\q1 igaataÉĄĖķa icota manoeni leeÉĄĖķodi ÉĄĖķagecaÉĄĖķaloÉĄĖķo. 
\q1  
\v 26 Eliodi maÉĄĖķaÉĄĖķa awikodee niÉĄĖķina akaami anetiÉĄĖķadiweniÉĄĖķideni niÉĄĖķina oko, 
\q1 igaataÉĄĖķa niÉĄĖķica jotigide ÉĄĖķadaamipi aaÉĄĖķaÉĄĖķa oiweniÉĄĖķide niÉĄĖķijoa awitakaÉĄĖķaÉĄĖķa anodi moyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko. 
\q1 (Pida oinaale niÉĄĖķijo noiigi.) 
\s1 Leeditibige me jemaanaÉĄĖķa ÉĄĖķoneloÉĄĖķododipi 
\r (Mateus 5.38-48) 
\p  
\v 27 Pida ejitaÉĄĖķawatiwaji ane anajipaatiwa, me leeditibige memaani ÉĄĖķoneloÉĄĖķododipi, codaa awii niÉĄĖķica aneletema niÉĄĖķijo anakaami neleÉĄĖķetedipi.  
\v 28 Ipokitalo AneotedoÉĄĖķoji me ibinietediogi niÉĄĖķina anodotaÉĄĖķatibigaÉĄĖķaji, codaa otaÉĄĖķaneÉĄĖķenitetiwaji AneotedoÉĄĖķoji me ibinietediogi niÉĄĖķina anoyametibigaÉĄĖķaji.  
\v 29 Nigica ane yabaketigi ÉĄĖķadajice, ajicita naÉĄĖķani eledi ÉĄĖķadajice maÉĄĖķaÉĄĖķa yabake. (Me ikeeni me diÉĄĖķica ÉĄĖķadelaÉĄĖķatema.) Nigica ane dibata ÉĄĖķanicaapa ajici codaa me ÉĄĖķanoecaÉĄĖķaxi.  
\v 30 Idioka limedi medianitiwaji niÉĄĖķina ane dipokotaÉĄĖķawa ganigica. Codaa niÉĄĖķina ane dibata ganigidi ane ÉĄĖķanebi, jiniÉĄĖķipoki doÉĄĖķoyopilaÉĄĖķaditaÉĄĖķawa.  
\v 31 Ademii oko niÉĄĖķica anemaani modigotaÉĄĖķawa. 
\p  
\v 32 Niginoka emaani niÉĄĖķina anetiÉĄĖķademaani, aÉĄĖķica ÉĄĖķanigaanye miniwataÉĄĖķa AneotedoÉĄĖķoji. IgaataÉĄĖķa niÉĄĖķina oko ane beyagi aaÉĄĖķaÉĄĖķoyemaa niÉĄĖķina nemaanoÉĄĖķodi.  
\v 33 Codaa nigawii aneletema inokina niÉĄĖķina anowotaÉĄĖķadomi anele, odaa aÉĄĖķicatace ÉĄĖķanigaanye. IgaataÉĄĖķa niÉĄĖķina oko abeyacaÉĄĖķaÉĄĖķa jiÉĄĖķidaaÉĄĖķee.  
\v 34 Codaa nigadilaÉĄĖķaneÉĄĖķenitiogi inokina niÉĄĖķina ane eni metiÉĄĖķadediani, nigica anigidi ÉĄĖķadowoodaÉĄĖķagi anonadila, aÉĄĖķicatace ÉĄĖķanigaanyetiwaji. IgaataÉĄĖķa niÉĄĖķina oko ane beyagi eo ladiligi niÉĄĖķina inaaÉĄĖķina abeyaceÉĄĖķegi eotibige me dibatege liikoa.  
\v 35 Pida jemaa memaani ÉĄĖķaneloÉĄĖķododipi, codaa awii niÉĄĖķina aneletema, awii ladiligi, pida niÉĄĖķina me daÉĄĖķa aliitege me yopilaÉĄĖķaditaÉĄĖķawa liikoa. JoaniÉĄĖķidaaÉĄĖķee odaa baÉĄĖķa ÉĄĖķadedianitetiwaji AneotedoÉĄĖķoji, codaa akaami lionigipi AneotedoÉĄĖķoji ane iiÉĄĖķe inoatawece. IgaataÉĄĖķa eletetema codaa me niÉĄĖķina oko ane daÉĄĖķa diniotagodetibigiwaji codaa me abeyacaÉĄĖķaÉĄĖķa.  
\v 36 Iwikodeni eledi oko, diganigotedaÉĄĖķawa AneotedoÉĄĖķoji ĮĪadiodi me ÉĄĖķadiwikodenitetiwaji. 
\s1 JinaÉĄĖķawini eledi oko ane doÉĄĖķowooÉĄĖķoti niÉĄĖķica ane loenatagi 
\r (Mateus 7.1-5) 
\p  
\v 37 JinaÉĄĖķawini anee eledi oko niÉĄĖķina ane daÉĄĖķa iwikodeni, odaa AneotedoÉĄĖķoji aiwi anenitiwaji oteÉĄĖķexaaÉĄĖķaÉĄĖķa ÉĄĖķadiloikatititetiwaji. JineÉĄĖķeni me leeditibige moiloikatidi oko leeÉĄĖķodi meo ane beyagi. Odaa AneotedoÉĄĖķoji aÉĄĖķee me leeditibige metiÉĄĖķadiloikatititetiwaji. Adinaagitititibige okanicodaaÉĄĖķica ane beyagi anowotaÉĄĖķadomi. Odaa AneotedoÉĄĖķoji yaagiditedibige niÉĄĖķijoa ÉĄĖķadoenataka ane beyagi.  
\v 38 Ajicitatiwaji eledi oko niÉĄĖķica ane yopotibige, odaa AneotedoÉĄĖķoji yajigotedaÉĄĖķawatiwaji niÉĄĖķica anopootibige. Digo micataÉĄĖķa niÉĄĖķina oko ane yetigi nelegei leyeema neÉĄĖķepaa niolakati, alee ipiati, joaniÉĄĖķidaaÉĄĖķee eliodi ane yajigotedaÉĄĖķawa AneotedoÉĄĖķoji. IgaataÉĄĖķa AneotedoÉĄĖķoji yajigotedaÉĄĖķawa liciagi niÉĄĖķina anajicita eledi oko.â 
\p  
\v 39 Jesus yeloÉĄĖķoditediogi ica natematigo anida ane ÉĄĖķodiiÉĄĖķaxitece, meetediogi, âNiÉĄĖķina ÉĄĖķolaÉĄĖķa domige yakadi me digilaÉĄĖķatedeta eledi ÉĄĖķolaÉĄĖķa? Nige digilaÉĄĖķatedeta, odaa niÉĄĖķidoa itoata ÉĄĖķoladi yeloÉĄĖķo me daxaboketinece diÉĄĖķica begi.  
\v 40 Codaa niÉĄĖķina ane didiko anaÉĄĖķaxateloco niiÉĄĖķaxinoÉĄĖķodi. Pida niÉĄĖķina nige igodi icoatawece niÉĄĖķicoa lidiko, odaa ja liciagi niÉĄĖķini niiÉĄĖķaxinoÉĄĖķodi. 
\p  
\v 41 JinaÉĄĖķa ÉĄĖķadiÉĄĖķoati laÉĄĖķamicaÉĄĖķajegi ÉĄĖķanioxoa catiwedi ligecooÉĄĖķe, leeÉĄĖķodi akamaÉĄĖķakaami oteÉĄĖķexaaÉĄĖķaÉĄĖķa emaani mowooÉĄĖķoti niÉĄĖķidi iwoÉĄĖķo liwai ane idei catiwedi ÉĄĖķagecooÉĄĖķe.  
\v 42 Pida menita ÉĄĖķanioxoa, âInioxoa, anagi! InoÉĄĖķa ÉĄĖķadaÉĄĖķamicaÉĄĖķajegi catiwedi ÉĄĖķagecooÉĄĖķe.â Igaamee ina mawii ida ÉĄĖķagegi, akamaÉĄĖķakaami aÉĄĖķemaani mowooÉĄĖķoti niÉĄĖķidi iwoÉĄĖķo liwai catiwedi ÉĄĖķagecooÉĄĖķe? ĮĪademaanigi mokawii makaami ele. Pida ele majela manoÉĄĖķaa niÉĄĖķidi iwoÉĄĖķo liwai catiwedi ÉĄĖķagecooÉĄĖķe, odaa jeÉĄĖķele manatiteloco laÉĄĖķamicaÉĄĖķajegi ÉĄĖķanioxoa manoÉĄĖķaatema. 
\s1 JowooÉĄĖķotaÉĄĖķa niale leeÉĄĖķodi elali 
\r (Mateus 7.16-20; 12.33-35) 
\p  
\v 43 NaÉĄĖķana niale anele, abeyagi elali. Odaa naÉĄĖķana niale ane beyagi, aÉĄĖķele elali.  
\v 44 Codaa jowooÉĄĖķotaÉĄĖķa anada naÉĄĖķana niale leeÉĄĖķodi niÉĄĖķinoa elali. IgaataÉĄĖķa ainotecaÉĄĖķa ilipeÉĄĖķe madataÉĄĖķa lalepiÉĄĖķigo, codaa ainoÉĄĖķaaÉĄĖķa âuuvaâ maditaÉĄĖķa omiigonaÉĄĖķa.  
\v 45 IgaataÉĄĖķa niÉĄĖķina anele icoÉĄĖķotiwece laaleÉĄĖķena niÉĄĖķina oko anele, leeÉĄĖķodi laaleÉĄĖķena nolee niÉĄĖķica anele. Pida niÉĄĖķina ane beyagi icoÉĄĖķotiwece laaleÉĄĖķena niÉĄĖķina oko ane beyagi, leeÉĄĖķodi laaleÉĄĖķena nolee ane beyagi. IgaataÉĄĖķa niÉĄĖķina oko eetece inokina niÉĄĖķina ane idei catiwedi laaleÉĄĖķena. 
\s1 Icoa itoa latopaco lipodaÉĄĖķalatedi diimigi 
\r (Mateus 7.24-27) 
\p  
\v 46 Igaamee ina menitiwatiwaji, âĮĪoniotagodi, ĮĪoniotagodi,â pida aÉĄĖķawii niÉĄĖķina ane jiiÉĄĖķetaÉĄĖķawatiwaji?  
\v 47 Natigide jeloÉĄĖķoditaÉĄĖķawatiwaji anodaaÉĄĖķee niÉĄĖķina oko anenagi meetaÉĄĖķa, odaa wajipatalo yotaÉĄĖķa, codaa idadiwaÉĄĖķadi.  
\v 48 Jiciaceeketege niÉĄĖķina ÉĄĖķoneleegiwa ane dabiteÉĄĖķetini liÉĄĖķeladi. Odaa ilecatiditinece me naligitedini lawonadi ditibigimedi wetiÉĄĖķa. Odaa naÉĄĖķa abooÉĄĖķo-akiidi, icota ninyoÉĄĖķodi minitaÉĄĖķa liÉĄĖķeladi. Pida ninyoÉĄĖķodi ayakadi me igike niÉĄĖķini diimigi, leeÉĄĖķodi datiteta moyojogotini.  
\v 49 Pida niÉĄĖķina oko ane wajipatalo yotaÉĄĖķa, pida aÉĄĖķeyiwaÉĄĖķadi, baÉĄĖķa liciagi eledi ÉĄĖķoneleegiwa ane dabiteÉĄĖķetini liÉĄĖķeladi. DabiteÉĄĖķetini miditaÉĄĖķa dotiwadi, pida boÉĄĖķodaa ayatitaÉĄĖķaditedini lawonadi. NaÉĄĖķa abooÉĄĖķo-akiidi, niÉĄĖķicota ninyoÉĄĖķodi liÉĄĖķeladi. Odaa jeÉĄĖķenitini, aÉĄĖķica nenyakigi.â 
\c 7  
\s1 Jesus icilatidi liotagi ica lacilo icoa niodaÉĄĖķawadi romaanotedi 
\r (Mateus 8.5-13) 
\p  
\v 1 NiÉĄĖķijo naÉĄĖķa nigotedini Jesus me yotaÉĄĖķaneÉĄĖķe niÉĄĖķidi noiigi, odaa jiÉĄĖķigo manitaÉĄĖķa nigotaÉĄĖķa Cafarnaum.  
\v 2 Odaa oninica ÉĄĖķoneleegiwa ane iiÉĄĖķe onaniteci taalia iodaÉĄĖķawadi. Ica liotagi ane daÉĄĖķaxa me yemaa, one deelotika, jona doletibige me yeleo.  
\v 3 NiÉĄĖķini ane iiÉĄĖķe niodaÉĄĖķawadi romaanotedi naÉĄĖķa dibodicetalo Jesus, jona iiÉĄĖķe icoa lacilodi judeutedi migotibeci odipokotalo Jesus migo icilatidi niÉĄĖķijo liotagi.  
\v 4 NoÉĄĖķototalo Jesus, odaa icaanoÉĄĖķodigotalo mowotibige migo, moditalo, âJanagaÉĄĖķa makaamitaÉĄĖķa, jemaanaÉĄĖķa micilatiti liotagi lacilo iodaÉĄĖķawadi, igaataÉĄĖķa niÉĄĖķini ane iiÉĄĖķe niodaÉĄĖķawadi romaanotedi, ÉĄĖķoneleegiwa libinienigi.  
\v 5 Codaa eliodi me yemaa ÉĄĖķodoiigi, jeÉĄĖķepaa diiÉĄĖķenatakata modabiteÉĄĖķetini ÉĄĖķodiiakanaÉĄĖķaxi.â 
\p  
\v 6 Odaa Jesus jiÉĄĖķigo lixigaÉĄĖķawepodi. Pida niÉĄĖķijo niÉĄĖķipegitedio liÉĄĖķeladi niÉĄĖķijo lacilo romaanotedi, odaa ja iiÉĄĖķetege icoa lokaaÉĄĖķetedi migotibeci odakapetege Jesus. Odaa joÉĄĖķoyeloÉĄĖķoditalo Jesus niÉĄĖķicoa lotaÉĄĖķa niÉĄĖķijo lacilo romaanotedi, monee, âĮĪoniotagodi, ajemaa daÉĄĖķalee ÉĄĖķadigiwoci. Eliodi ÉĄĖķaniwalÃģ, aÉĄĖķakaami iciagi managi anakaatiwece iÉĄĖķeladi.  
\v 7 Codaa joaniÉĄĖķidaa leeÉĄĖķodi me daÉĄĖķa ejigo jipokotaÉĄĖķawa managi deÉĄĖķepaa digoina. Pida okexaa eni me icÃ­ idida iotagi, odaa ja icÃ­ inioneeÉĄĖķa.  
\v 8 IgaataÉĄĖķa akaami iciagi, ee aaÉĄĖķaÉĄĖķa idi anetidiiÉĄĖķe, codaa idiwa iniodaÉĄĖķawadi maÉĄĖķaÉĄĖķa jiiÉĄĖķe. Idatecibece ini anejita, âEmiiâ, odaaÉĄĖķigo. IniaaÉĄĖķeledi mejita, âAnagiâ, odaa jeÉĄĖķenagi. Idatecibece mejita iotagi, âEtidi anawii.â Odaa jeÉĄĖķeo.â 
\p  
\v 9 NiÉĄĖķijo Jesus naÉĄĖķa wajipate niÉĄĖķijoa lotaÉĄĖķa, eliodi me yopo. Odaa naÉĄĖķa nawiilitetedijo, meetediogi niÉĄĖķijo noiigi anodiotece, âEjitaÉĄĖķawatiwaji, aniÉĄĖķica oko jakapetege midi ÉĄĖķodoiigi Israel ane eliodi eliwaÉĄĖķatakaneÉĄĖķegi digo minitaÉĄĖķa niÉĄĖķini ÉĄĖķoneleegiwa (ane daÉĄĖķa ÉĄĖķodoiigi).â  
\v 10 NiÉĄĖķijoa liiÉĄĖķexedi niÉĄĖķijo ane iiÉĄĖķe niodaÉĄĖķawadi romaanotedi, noÉĄĖķopitiobeci ane icoÉĄĖķoticogi. NoÉĄĖķotota, niÉĄĖķijo niotagi ja icÃ­. 
\s1 Jesus eote me yewiÉĄĖķatace lionigi aca wajekalo 
\p  
\v 11 Ica noko Jesus onigo manitaÉĄĖķa nigotaÉĄĖķa Naim. IjaaÉĄĖķijo anodiotibece icaaÉĄĖķica eledi noiigi-nelegi lixigaÉĄĖķawepodi.  
\v 12 Odaa noÉĄĖķone odipegita niÉĄĖķica lapoagi niÉĄĖķica niwilanigi ane niotaa naÉĄĖķani nigotaÉĄĖķa, odaa joÉĄĖķodakapetetege ica lapo-nelegi, anoyadeegi ica lioneeÉĄĖķa ane yeleo, oyadeegi monaligitini. NiÉĄĖķica ÃĐmeÉĄĖķegi onokijoteci me lionigi acoda wajekalo. NiÉĄĖķica noiigi-nelegi oigaalatibece naÉĄĖķajo eliodo.  
\v 13 NiÉĄĖķijo naÉĄĖķa nadi ĮĪoniotagodi naÉĄĖķajoda wajekalo, eliodi me iwikode. Odaa jeÉĄĖķeeteta, âJinaÉĄĖķa anoeni!â  
\v 14 Odaa joneÉĄĖķepaanaÉĄĖķa ipegiteta, odaa ja dibatedeloco aca iwokodaÉĄĖķaxi. Odaa niÉĄĖķijo anoyadeegi ja dabiditiniwace. Odaa jeÉĄĖķee Jesus, âLioneeÉĄĖķa, Ee ÉĄĖķadiiÉĄĖķeni, anicootini!â  
\v 15 Odaa niÉĄĖķijo ÃĐmeÉĄĖķegi jona nicotini, odaa ja dotaÉĄĖķa. Jesus ja yopilaÉĄĖķadite naÉĄĖķajo eliodo. 
\p  
\v 16 Ijotawece niÉĄĖķijo oko eliodi me doitibigiwaji, odaa odoÉĄĖķetetalo AneotedoÉĄĖķoji, modi, âDinikeetoÉĄĖķowa ane yeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko, codaa niÉĄĖķida eliodi nimaweneÉĄĖķegi. AneotedoÉĄĖķoji ja dalitediogi loiigi, odaa yaxawatediogi!â  
\v 17 Nibodicetedi anoditece Jesus jiÉĄĖķilaagiteloco iditawece nipodigi JudÃĐia, codaa me niÉĄĖķicoa nipodaÉĄĖķa anipegitege. 
\s1 JoÃĢo iiÉĄĖķe niÉĄĖķijo anodiotibeci migotibeci midoataÉĄĖķa Jesus 
\r (Mateus 11.2-19) 
\p  
\v 18 NiÉĄĖķijo anodiotibeci JoÃĢo Batista oyeloÉĄĖķodita icoatawece niÉĄĖķicoa baaneÉĄĖķeote Jesus.  
\v 19 Odaa JoÃĢo eniditiogi icoa itoataale anodiotibeci, odaa ja iiÉĄĖķe moige ĮĪoniotagodi, meetiogi, âNigicootalo, enitalo, âManigakamaÉĄĖķakaami icoa ane inibeoonaÉĄĖķatege menagi me ÉĄĖķodewikatidi, oÉĄĖķoa, domigalee inibeoonaÉĄĖķatege eledi oko?ââ 
\p  
\v 20 NoÉĄĖķototalo Jesus, odaa joÉĄĖķoige, moditalo, âĮĪoniotagodi, JoÃĢo Batista ÉĄĖķodiiÉĄĖķe me ÉĄĖķadigeeÉĄĖķegi manigakamaÉĄĖķakaami icoa ane inibeoonaÉĄĖķatege menagi ÉĄĖķodewikatidi, oÉĄĖķoa, domigalee inibeoonaÉĄĖķatege eledi oko?â 
\p  
\v 21 AjaaÉĄĖķajo naÉĄĖķajo lakata niÉĄĖķicotibeci niÉĄĖķijoa liiÉĄĖķexedi JoÃĢo, Jesus ja icilatidi eliodi oko ane neelotikanaÉĄĖķa, ina anodakatiogi, codaa eote me yatetacibigiwaji ÉĄĖķoladi.  
\v 22 Odaa Jesus ja igiditediogi niÉĄĖķijo ane iiÉĄĖķe JoÃĢo, meetediogi, âOpilitacicogi minitaÉĄĖķa JoÃĢo, odaa eloÉĄĖķoti niÉĄĖķinoa ananati, codaa anajipaatalotiwaji. EloÉĄĖķoti me yatetacibigiwaji ÉĄĖķoladi, mewaligi ane beyagi laxace, codaa me icÃ­ dawace-loolatedi, aticilonadi ja wajipatacibigiwaji, ÃĐmaÉĄĖķaÉĄĖķa newiÉĄĖķatace, codaa me jatemati nibodicetedi anele miditaÉĄĖķa madewetedi.  
\v 23 NiÉĄĖķina oko ninitibece niÉĄĖķina me daÉĄĖķa dinibolikatiditici.â 
\p  
\v 24 NiÉĄĖķijo noÉĄĖķopitibeci niÉĄĖķijoa liiÉĄĖķexedi JoÃĢo, odaa Jesus ja yalaÉĄĖķate JoÃĢo Batista, meetediogi niÉĄĖķidi noiigi, âIjo me emiitiwaji midi nipodigi ane yadilo ane diÉĄĖķica niÉĄĖķeladimigipi, amiijo anemii awinitiwaji? Domigemii mawini ÉĄĖķoneleegiwa ane diÉĄĖķica baÉĄĖķa niiticogi ane liciagi niÉĄĖķina naanyogo ane igike niocodi?  
\v 25 Amiina anemii awinitiwaji? Domigemii awini ÉĄĖķoneleegiwa anele me dinixo? De jeloÉĄĖķoditaÉĄĖķawatiwaji! NiÉĄĖķijo anele me dinixotibigiwaji, ane diÉĄĖķica ananiaditema, ane diÉĄĖķeladetigi diimaÉĄĖķa libinienaÉĄĖķa, liÉĄĖķeladi niÉĄĖķinoa inionaÉĄĖķa-eloodoli.  
\v 26 Enice, amiijo ica anemii awinitiwaji? Domige emii awinitiwaji niÉĄĖķijo ane yeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko? BeÉĄĖķewi! JeloÉĄĖķoditaÉĄĖķawatiwaji mepeÉĄĖķewi me emii awinitiwaji niÉĄĖķijo ane naÉĄĖķaxatelogo niÉĄĖķijo anoyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko niÉĄĖķijo jotigide.  
\v 27 IgaataÉĄĖķa joaniÉĄĖķijaa JoÃĢo niÉĄĖķijo aneeta AneotedoÉĄĖķoji lotaÉĄĖķanaÉĄĖķaxi, neÉĄĖķee AneotedoÉĄĖķoji, âJiwakatee iiÉĄĖķexegi ÉĄĖķadodoe, yoetece ÉĄĖķaligiâ.  
\v 28 JeloÉĄĖķoditaÉĄĖķawa, JoÃĢo me daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi caticedi ijotawece niÉĄĖķijo eledi anoyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko. Pida niÉĄĖķina oko iwikodaÉĄĖķa ane iiÉĄĖķe AneotedoÉĄĖķoji laaleÉĄĖķena, baÉĄĖķa daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi caticeditace JoÃĢo.â 
\p  
\v 29 NiÉĄĖķina anodibatibigege ninyeelo ninionigi-eliodi romaanotedi, codaa me iditawece niÉĄĖķidi noiigi owajipatalo lotaÉĄĖķa ĮĪoniotagodi, joaniÉĄĖķidiaaÉĄĖķidi niÉĄĖķica ane nilegetiniwace JoÃĢo, noÉĄĖķowajipatalo lotaÉĄĖķa Jesus, odaa modi AneotedoÉĄĖķoji iÉĄĖķenaÉĄĖķa.  
\v 30 Pida niÉĄĖķijoa fariseutedi ijaaÉĄĖķijo anodiiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs baadoÉĄĖķoyemaa me nilegetiniwace JoÃĢo. JoaniÉĄĖķidaa modowocetege niÉĄĖķica ane domaÉĄĖķa yemaa AneotedoÉĄĖķoji mowo. 
\p  
\v 31 Odaa ĮĪoniotagodi mee, âNiÉĄĖķina noiigi, amiini ica ane jakadi me jiboÉĄĖķoditege? Natigide jeloÉĄĖķoditaÉĄĖķawatiwaji ane jiboÉĄĖķoditege.  
\v 32 Liciagi nigaanigipawaanigi ane nicotiniwace me nalooÉĄĖķo midi lalokaditibece. Ini lapo meeta, me dapaaweta niÉĄĖķini eledi lapo, âJa jatenaÉĄĖķatigi nateneÉĄĖķegi nadoneÉĄĖķegi, pida aÉĄĖķanibailetiwaji. Codaa ja domaÉĄĖķa jigaanaÉĄĖķa ica nanaagi monaligitini ÃĐmeÉĄĖķegi, pida aÉĄĖķanoenitiwajiâ. (Odaa niÉĄĖķidi nigaanigipawaanigi idioka limedi me dinotigimade.)  
\v 33 IgaataÉĄĖķa JoÃĢo Batista enagi, odaa ayeligo paon, oteÉĄĖķexaaÉĄĖķaÉĄĖķa wacipeta viinyo. Odaa menitiwaji me dakatiogi niwigo abeyaceÉĄĖķegi.  
\v 34 Odaa Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, naÉĄĖķaÉĄĖķa janagi, odaa baÉĄĖķa jeligo paon, codaa me jacipe viinyo. Odaa menitiwaji, âDigawini! NiÉĄĖķidoa ÉĄĖķoneleegiwa olade, codaa me acipeÉĄĖķegi. LokaaÉĄĖķetedipi niÉĄĖķidi anodibatibigege ninyeelo ninionigi-eliodi romaanotedi, codaa lokaaÉĄĖķetedipi inatawece niÉĄĖķina oko anowidi libeyaceÉĄĖķeco!â (Odaa ÉĄĖķadiciagitiwaji niÉĄĖķijo nigaanigipawaanigi leeÉĄĖķodi midioka limedi madinotigimadenitiwaji.)  
\v 35 Pida niÉĄĖķina oko anida liwaxinigi, baanaÉĄĖķa yowooÉĄĖķodi AneotedoÉĄĖķoji me diwaxinaÉĄĖķa, codaa midioka limedi meo ane iÉĄĖķenaÉĄĖķa.â 
\s1 Jesus igo liÉĄĖķeladi ica fariseu anodita SimÃĢo 
\p  
\v 36 Ica fariseu one node Jesus migo aniodi liÉĄĖķeladi. Odaa Jesus jiÉĄĖķigo. NaÉĄĖķa dakatediwece liÉĄĖķeladi, odaa ja nicotedi maditaÉĄĖķa aca nameeja maniodi.  
\v 37 ManitaÉĄĖķa naÉĄĖķani nigotaÉĄĖķa onani aca iwaalo agopeloa. NaÉĄĖķa dibodicetalo miniwatedigi Jesus liÉĄĖķeladi niÉĄĖķijo fariseu maniodi, odaa jiÉĄĖķigo, yadeegi aca bootawaana wetiÉĄĖķa, anodita âalabastroâ. NaÉĄĖķaca bootawaana one nolee ladokojegi.  
\v 38 NaÉĄĖķajo iwaalo dabiditi lowidi Jesus micoataÉĄĖķa loÉĄĖķonaka, anoetibece. Odaa latiidi datikoletelogo loÉĄĖķonaka Jesus. Odaa ja yatita lamodi me iwilegi Jesus loÉĄĖķonaka, codaa eliodi me napicoÉĄĖķotedice loÉĄĖķonaka, ikee me diniotagodetalo. Codaa yadotelogo loÉĄĖķonaka niÉĄĖķica ladokojegi.  
\v 39 NiÉĄĖķijo fariseu ane node Jesus naÉĄĖķa nadi anee naÉĄĖķajo iwaalo, odaa meetibige le, âNiÉĄĖķina deÉĄĖķewi niÉĄĖķiniaaÉĄĖķiniwa NiÉĄĖķicoa ane neloÉĄĖķoditedoÉĄĖķowa AneotedoÉĄĖķoji lowooko, daÉĄĖķanagawini yowooÉĄĖķodi anani naÉĄĖķani iwaalo ane dibatelogo, codaa taÉĄĖķaÉĄĖķa yowooÉĄĖķodi niÉĄĖķicoa ligopeloaÉĄĖķeco, codaa ane libeyaceÉĄĖķeco.â 
\p  
\v 40 Odaa Jesus meeteta niÉĄĖķijo fariseu, âSimÃĢo, domiÉĄĖķida igegi.â Odaa ja igidi, meetalo, âDigageni, niiÉĄĖķaxinaÉĄĖķanaÉĄĖķa.â  
\v 41 Odaa Jesus jeÉĄĖķeete, âIdiwa iniwataale ÉĄĖķoneleegiwadi onaalewe ica anidioka limedi me yajigo monadila ninyeelo. Onica ica ane dinaalewe ciinco taalia beexotedi, odaa ica eledi baÉĄĖķa dinaalewe meya-taalia beexotedi.  
\v 42 NiÉĄĖķidi iniwataale aÉĄĖķoyakadi moyedia niÉĄĖķijoa naaleweta niÉĄĖķijo ÉĄĖķoneleegiwa. Odaa joaniÉĄĖķidaa meetiogi me daÉĄĖķadiaa leeditibige moyedia. Natigide ÉĄĖķadige, amepidiÉĄĖķica ijoa itoa ane daÉĄĖķaxa me yemaa ijo ÉĄĖķoneleegiwa anonaalewe?â 
\p  
\v 43 SimÃĢo ja niniÉĄĖķodi, meetalo, âEjime niÉĄĖķijo ane daÉĄĖķaxa me dinaalewe jiÉĄĖķijaa daÉĄĖķaxa me demaanaÉĄĖķa.â Odaa Jesus meete, âEle motaÉĄĖķani!â 
\p  
\v 44 Odaa Jesus naÉĄĖķa niwiteta naÉĄĖķajo iwaalo, odaa meete SimÃĢo, âJaÉĄĖķanati naÉĄĖķani iwaalo. NiÉĄĖķijo naÉĄĖķa inakatiwece ÉĄĖķadiÉĄĖķeladi, aÉĄĖķanajicitiwa ninyoÉĄĖķodi me jiwilegi iÉĄĖķonaka. Pida baÉĄĖķa iwilegi iÉĄĖķonaka yatitalo latiidi, odaa yatita lamodi me yadilonatidi iÉĄĖķonaka.  
\v 45 Codaa niÉĄĖķijo naÉĄĖķa janotio, aÉĄĖķadapiciÉĄĖķi me ÉĄĖķadecoatitici. Pida niÉĄĖķijo naÉĄĖķa nakatio, naÉĄĖķani iwaalo naÉĄĖķani me napicoÉĄĖķotedice iÉĄĖķonaka.  
\v 46 Codaa oteÉĄĖķexaaÉĄĖķaÉĄĖķa adootigi najidi yacilo mikeeni moÉĄĖķeetetiwa, pida aniaaÉĄĖķani baÉĄĖķa yadotelogo iÉĄĖķonaka ladokojegi.  
\v 47 Odaa jemaa mejitaÉĄĖķawa AneotedoÉĄĖķoji ja iwilegi libeyaceÉĄĖķeco naÉĄĖķani iwaalo anowidi. Odaa joaniÉĄĖķidaa leeÉĄĖķodi meliodi me idemaa. Pida niÉĄĖķina oko ane daÉĄĖķa deemitetece me leeditibige me doletibige AneotedoÉĄĖķoji me iwilegi libeyaceÉĄĖķeco, aÉĄĖķewi me idemaa.â 
\p  
\v 48 Odaa Jesus jeÉĄĖķeeteta naÉĄĖķajo iwaalo, âAneotedoÉĄĖķoji ja napitaÉĄĖķadi ÉĄĖķabeyaceÉĄĖķeco.â 
\p  
\v 49 NiÉĄĖķijo eledi oko anidiaaÉĄĖķi madi nameeja, dinotaÉĄĖķaneÉĄĖķetiwage, modi, âAmiiniwa icoa ÉĄĖķoneleegiwa anee me yakadi me napitaÉĄĖķadi ÉĄĖķobeyaceÉĄĖķeco?â 
\p  
\v 50 Odaa Jesus jeÉĄĖķeeteta naÉĄĖķajo iwaalo, âAneotedoÉĄĖķoji ja ÉĄĖķadewikatiti leeÉĄĖķodi madinakatoni. Odaa emii opili, mele ÉĄĖķadaaleÉĄĖķena!â 
\c 8  
\s1 Iwaalepodi anodiotibece Jesus 
\p  
\v 1 NiÉĄĖķidiaaÉĄĖķidi Jesus ja diniwiajetedicogi midiwataÉĄĖķa icoa nigotadi icaaÉĄĖķicoa nigotadawaanaÉĄĖķa niÉĄĖķidi nipodigi, yeloÉĄĖķoditedibece icoa nibodicetedi anele, anoneloÉĄĖķoditoÉĄĖķowa anodaaÉĄĖķeeteda AneotedoÉĄĖķoji me iiÉĄĖķe oko laaleÉĄĖķena. NiÉĄĖķijo dooze anodiotibece eledi ijo me lixigaÉĄĖķawepodi.  
\v 2 Codaa onica ica iwaalepodi anaÉĄĖķaÉĄĖķa igotibeci. Jesus one iticoitedice niwigo abeyaceÉĄĖķegi ane dakatiogi anigepidaÉĄĖķaca niÉĄĖķijo iwaalepodi, codaa one nicilatidi ica ane neelotikanaÉĄĖķa. Aca anodita Maria aneledi oyatigi me Madalena. JoanaÉĄĖķajaa Jesus ane icilatidi modakatiogi seete niwicidi abeyacaÉĄĖķaÉĄĖķa.  
\v 3 AcaaÉĄĖķaca aca Joana lodawa ica Cuza ane dowediteloco liÉĄĖķeladi ica inionigi-eliodi Herodes. Codaa eledi igo aca Susana, icaaÉĄĖķica eledi iwaalepodi, anoyaxawa Jesus ijaaÉĄĖķijo anodiotibece, oyajigo liwai niÉĄĖķicoa ane nepilidi moyaxawatiogi. 
\s1 Jesus yatemati ica natematigigi ica anetanaÉĄĖķa 
\r (Mateus 13.10-23; Marcos 4.10-20) 
\p  
\v 4 Ica oko ane icoÉĄĖķoticogi inoatawece nigotadi ototalo, odaa ja dilapode niÉĄĖķica noiigi-nelegi. NiÉĄĖķijo naÉĄĖķa dilapodetibigiwaji, odaa Jesus ja yatemati ica natematigo ane ÉĄĖķodiiÉĄĖķaxi, meetediogi,  
\v 5 âDigawinitiwaji! Ica ÉĄĖķoneleegiwa onigo etanaÉĄĖķa. NiÉĄĖķijo naÉĄĖķa yokoletedibece niÉĄĖķijoa nolacidi, onicoa icoa ane enitedini midi naigi. Analee onipodi oko, codaa me ilaaÉĄĖķaxodi aaÉĄĖķaÉĄĖķa oyeligo.  
\v 6 Icoa eletidi nolacidi one enitedini midiwa icoa wetiadawaanaÉĄĖķa. Odaa ja domaÉĄĖķa ili, pida yadilo, leeÉĄĖķodi ibeyacaÉĄĖķadi me yadilo niÉĄĖķijo anei.  
\v 7 Pida icoa eletidi boÉĄĖķonenite midi ica ipelakijadi. NaÉĄĖķa domaÉĄĖķa ili, pida jonaÉĄĖķaÉĄĖķa ili niÉĄĖķijo ipelaÉĄĖķa, odaa ja yapoÉĄĖķoditedini.  
\v 8 Pida onicoa icoa eletidi anenitedinigi miditaÉĄĖķa ica iiÉĄĖķo anele. Odaa boÉĄĖķone ili, codaa onele. One onidateci libatadi yajigo onaniteci taalia ligecidi.â NiÉĄĖķidiaaÉĄĖķidi Jesus joneÉĄĖķeetediogi, âAne yemaa me wajipatalo niÉĄĖķinoa ane jiiÉĄĖķaxinaÉĄĖķatece, enice atacolitece!â 
\s1 Jesus yeloÉĄĖķodi niÉĄĖķica ane diitigi niÉĄĖķida natematigo 
\p  
\v 9 NiÉĄĖķijo anodiotibece joÉĄĖķoigetece Jesus niÉĄĖķica ane diitigi niÉĄĖķijo natematigo ane yatemati.  
\v 10 Jesus igidi, meetediogi, âAneotedoÉĄĖķoji baÉĄĖķa ikeetedaÉĄĖķawatiwaji anodaaÉĄĖķee me iiÉĄĖķe oko laaleÉĄĖķena, igaataÉĄĖķa aÉĄĖķica ane yowooÉĄĖķodi. Odaa niÉĄĖķina me jiiÉĄĖķaxi eledi oko, baÉĄĖķa jatemati natematiko anida ane jiciaceeketege. Jaotibige moiwi pida aÉĄĖķonadi niÉĄĖķica anewi, owajipata pida aÉĄĖķoyowooÉĄĖķodi ane diitigi. 
\p  
\v 11 NiÉĄĖķijo natematigo ane jatemati, digawini ane diitigi. NiÉĄĖķijoa lolacidi liciagi niÉĄĖķinoa lotaÉĄĖķa AneotedoÉĄĖķoji.  
\v 12 NiÉĄĖķijoa lolacidi anenite miditaÉĄĖķa naigi, liciagi niÉĄĖķina oko anowajipatalo lotaÉĄĖķa AneotedoÉĄĖķoji. Pida neÉĄĖķenagi ÉĄĖķodaxakawa, odaa ja noÉĄĖķa niÉĄĖķijoa notaÉĄĖķa anowajipatalo ane ideite laaleÉĄĖķena. Eotibige me daÉĄĖķadiaa oyiwaÉĄĖķadi NiÉĄĖķijoa ane ÉĄĖķodewikatidi, odaa AneotedoÉĄĖķoji aÉĄĖķaleeÉĄĖķaÉĄĖķa eote lewiÉĄĖķa.  
\v 13 NiÉĄĖķijoa lolacidi anenite midiwa wetiadawaanaÉĄĖķa, liciagi niÉĄĖķina oko anowajipatalo AneotedoÉĄĖķoji lotaÉĄĖķa, odaa joÉĄĖķodibatege codaa eliodi me ninitibigiwaji. Pida niÉĄĖķidi oko aÉĄĖķewi niÉĄĖķica eliwaÉĄĖķatakaneÉĄĖķegi. Liciagi niÉĄĖķinoa enanigijedi ane daÉĄĖķa leegitinece litodi. Odaa aleegi metiwaÉĄĖķataka, neÉĄĖķenagi ÉĄĖķodaxakawa dineeta, odaa jeÉĄĖķeyamaÉĄĖķaticoace leeÉĄĖķodi lawikodico.  
\v 14 NiÉĄĖķijoa lolacidi anenite miditaÉĄĖķa ipelakijadi, liciagi niÉĄĖķina oko anowajipatalo AneotedoÉĄĖķoji lotaÉĄĖķa, pida idokee mowo niÉĄĖķinoa lakataÉĄĖķa niÉĄĖķina iiÉĄĖķo, codaa noÉĄĖķowikomataaÉĄĖķa, odoletibige me liicotedi, codaa odoletibige mowo niÉĄĖķica anepaaÉĄĖķoyemaa. JoaniÉĄĖķidaaÉĄĖķee niÉĄĖķijo ipelakijadi ane doÉĄĖķoika me ili niÉĄĖķijoa enanigijedi, metaye, liciagi eliwaÉĄĖķatakaneÉĄĖķegi niÉĄĖķijo oko aili pida dinelio.  
\v 15 Odaa niÉĄĖķijoa aneniteloco iiÉĄĖķo anele baÉĄĖķa liciagi niÉĄĖķina oko anowajipatalo lotaÉĄĖķa AneotedoÉĄĖķoji, odaa oyotete catiwedi laaleÉĄĖķena. Odaa baadaÉĄĖķa inaale laaleÉĄĖķena, pida ele. Codaa me lewiÉĄĖķa niÉĄĖķidi oko diniigi, owo niÉĄĖķina ane yemaa AneotedoÉĄĖķoji codaa odinatitalo lawikodico. 
\s1 Aca lokokena 
\r (Marcos 4.21-25) 
\p  
\v 16 AÉĄĖķica ini ane yalegi loledaÉĄĖķaxi oditaÉĄĖķa yamaÉĄĖķateloco ÉĄĖķinogo ane leegitinece le, migetaÉĄĖķa ixotiwece lipe le loledaÉĄĖķaxi, pida ipeke loledaÉĄĖķaxi ditibigimedi, odaa inatawece oko anodakatiwece diimigi onadi liwitiigi. 
\p  
\v 17 IgaataÉĄĖķa inoatawece niÉĄĖķinoa ane dinaÉĄĖķaditedini, icota me jowooÉĄĖķotaÉĄĖķa, codaa inoatawece ane daÉĄĖķa jowooÉĄĖķotaÉĄĖķateda, icota me jinataÉĄĖķa, codaa enagi manitaÉĄĖķa aca nilokokena AneotedoÉĄĖķoji.  
\v 18 Enice anidakitatiwaji anodaaÉĄĖķeni majipaatalo AneotedoÉĄĖķoji lotaÉĄĖķa. IgaataÉĄĖķa niÉĄĖķina baanaÉĄĖķa dibatege ganigidi, dibatacege caticeditace niÉĄĖķijo baanaÉĄĖķa dibatege. Pida niÉĄĖķina ane diÉĄĖķica, niÉĄĖķijo ane diletibige diÉĄĖķidi me nebi, onoÉĄĖķaticogi minitaÉĄĖķa.â 
\s1 Ica loiigiwepodi Jesus 
\r (Mateus 12.46-50; Marcos 3.31-35) 
\p  
\v 19 NaÉĄĖķajo eliodo ijaa nioxoadipi Jesus igotibeci midoataÉĄĖķa. Pida aÉĄĖķoyakadi modipegitalo, leeÉĄĖķodi niÉĄĖķidi noiigi-nelegi.  
\v 20 Odaa joniÉĄĖķica ica aneo libodigi, meetalo, âĮĪadiodo, idiaa ÉĄĖķanioxoadipi etidi digoida wetice niÉĄĖķina diimigi. Oyemaa metiÉĄĖķadotaÉĄĖķaneÉĄĖķeni.â  
\v 21 Pida Jesus ja niniÉĄĖķodi, meeteta, âEiodo, inioxoadipi, niÉĄĖķina anowajipatalo AneotedoÉĄĖķoji lotaÉĄĖķa, anowo ane yemaa AneotedoÉĄĖķoji.â 
\s1 Jesus eote me notokoti niwocotaÉĄĖķa 
\r (Mateus 8.23-27; Marcos 4.35-41) 
\p  
\v 22 Ica noko Jesus ijaaÉĄĖķijo anodiotibece owaxoditinigi aca niwatece, odaa mee Jesus, âIniÉĄĖķa daato niÉĄĖķina weiigi.â Odaa jiÉĄĖķigotibeci.  
\v 23 EÉĄĖķidaa diiticogi migotibeci, Jesus jona diote. CodaaÉĄĖķida joneÉĄĖķenagi ica niwocotaÉĄĖķa, odaa jona nolee ninyoÉĄĖķodi aca niwatece. Eliodi modiitege niÉĄĖķica ane doide.  
\v 24 Odaa niÉĄĖķijo anodiotibece Jesus jonoÉĄĖķodipegitalo moyojietelogo, moditalo, âĮĪoniiÉĄĖķaxinoÉĄĖķodi! ĮĪoniiÉĄĖķaxinoÉĄĖķodi! Aiwoko moko ma!â Odaa jona niwodi Jesus. Odaa ja yapeteÉĄĖķe niÉĄĖķijo niocodi, ijaaÉĄĖķijoa ebekadi, codaa iiÉĄĖķe me notokotiniwace. Odaa niÉĄĖķijo niwocotaÉĄĖķa, ijaaÉĄĖķijoa ebekadi ja notokotiniwace, jona watacoti.  
\v 25 Odaa Jesus jeÉĄĖķeetediogi niÉĄĖķijo anodiotibece, âIgaamee ina me daÉĄĖķadadiwaÉĄĖķatitatiwaji?â Pida eliodi moyopo, codaa doitibigiwaji, dinotaÉĄĖķaneÉĄĖķetiwage modi, âAmiidoa icoa ÉĄĖķoneleegiwa? IgaataÉĄĖķa iiÉĄĖķe niocodi, ebekadi me notokotiniwace, odaa jiÉĄĖķidaaÉĄĖķee!â 
\s1 Jesus icilatidi ica ane dakatiogi niwicidi abeyacaÉĄĖķaÉĄĖķa 
\r (Mateus 8.28-34; Marcos 5.1-20) 
\p  
\v 26 NoÉĄĖķotota nipodigi ica noiigi gadareenotedi, daato niÉĄĖķidi weiigi ane dilokotege GalilÃĐia.  
\v 27 NaÉĄĖķa waxoditedice Jesus naÉĄĖķajo niwatece, odaa jona dakapetege ica ÉĄĖķoneleegiwa anelatibige naÉĄĖķani nigotaÉĄĖķa. Jona jotigide modakatiogi niÉĄĖķicoa niwicidi abeyacaÉĄĖķaÉĄĖķa. AonaÉĄĖķaleeÉĄĖķicoa lowoodi, oteÉĄĖķexaaÉĄĖķaÉĄĖķaleeÉĄĖķica liÉĄĖķeladi, pida one lotokaÉĄĖķadi midiwataÉĄĖķa icoa lawimaÉĄĖķajetedi-wetiadi minitaÉĄĖķa ica apiiÉĄĖķo. \fig |src="CN01709B.TIF" size="span" copy="ÂĐ 1978 David C. Cook Publishing Co." ref="Lucas 8.27" \fig* 
\v 28-29 IgaataÉĄĖķa niÉĄĖķica niwigo abeyaceÉĄĖķegi elioditibece me dibata. Codaa onidatecibeci niÉĄĖķica oko one oigoetece galeena libaaÉĄĖķatedi, loÉĄĖķonaka, pida idioka limedi me nakagidi. Codaa niÉĄĖķijo niwigo abeyaceÉĄĖķegi yadeegiticobige miditaÉĄĖķa ica nipodigi ane yadilo ane diÉĄĖķica niÉĄĖķeladimigipi. NiÉĄĖķijo naÉĄĖķa naditege Jesus, odaa jona dapaawe, odaaÉĄĖķenitini loÉĄĖķonaka Jesus, odaa mee me dinigetaÉĄĖķatee, âJesus, Lionigi AneotedoÉĄĖķoji ane iiÉĄĖķe inoatawece! Amiina ica anemaanitici? JipokotaÉĄĖķawa me daÉĄĖķadiloikatiti.â Eo niÉĄĖķida ligegi, leeÉĄĖķodi Jesus ja iiÉĄĖķe me noditicoaci niÉĄĖķijoa niwicidi abeyacaÉĄĖķaÉĄĖķa. 
\p  
\v 30 Odaa Jesus jona ige, oneete, âIgame ÉĄĖķaboonaÉĄĖķadi?â NaÉĄĖķa igidi, mee, âIboonaÉĄĖķadi me ee, âNoiigi-nelegiâ.â Eo niÉĄĖķida ligegi leeÉĄĖķodi owidi niÉĄĖķicoa niwicidi abeyacaÉĄĖķaÉĄĖķa anodakatiogi.  
\v 31 Odaa niÉĄĖķicoa niwicidi abeyacaÉĄĖķaÉĄĖķa eliodi modipokotalo Jesus me daÉĄĖķa iiÉĄĖķetedicogi midataÉĄĖķa libegi ane leegitinece, meote me nawikodeeÉĄĖķa. 
\p  
\v 32 Onini ica lapo-nelegi nigidagiwadi noxicoÉĄĖķonaÉĄĖķa odipegitege aca wetiÉĄĖķa. Odaa niÉĄĖķijoa niwicidi abeyacaÉĄĖķaÉĄĖķa odipokotalo Jesus me ika modakatiogilo niÉĄĖķijoa nigidagiwadi. Odaa ja ika.  
\v 33 Odaa niÉĄĖķijoa niwicidi abeyacaÉĄĖķaÉĄĖķa joÉĄĖķoika niÉĄĖķijo ÉĄĖķoneleegiwa, odaa joÉĄĖķodakatiogilo nigidagiwadi. Odaa niÉĄĖķidiwa nigidagiwadi waleditiniwace ica elagigi, odaa joÉĄĖķodaxaboketinece ica weiigi, joÉĄĖķoceÉĄĖķaÉĄĖķa. 
\p  
\v 34 NiÉĄĖķijo anoyowie niÉĄĖķijoa nigidagiwadi noÉĄĖķonadi niÉĄĖķida niciagi, odaa joÉĄĖķodeleta naÉĄĖķani nigotaÉĄĖķa, codaa me bajeendatedi, oyatemati niÉĄĖķida niciagi.  
\v 35 Eliodi oko igotibeci oiwi niÉĄĖķica niciagi. NoÉĄĖķodipegitalo Jesus, odaa joÉĄĖķonadi niÉĄĖķijo ane icilatidi modakatiogi niwicidi abeyacaÉĄĖķaÉĄĖķa, odaa eliodi me doitibigiwaji, leeÉĄĖķodi niÉĄĖķijo ÉĄĖķoneleegiwa ini me nicoti micoataÉĄĖķa Jesus loÉĄĖķonaka, joniÉĄĖķidoa lowoodi, codaa aÉĄĖķaleeÉĄĖķicoa niÉĄĖķijoa lowooko yetoledi.  
\v 36 NiÉĄĖķica anonadi niÉĄĖķida niciagi, oyatematitiogi niÉĄĖķidi noiigi ica anodaaÉĄĖķee noÉĄĖķoicilatidi niÉĄĖķijo ÉĄĖķoneleegiwa.  
\v 37 Odaa iditawece noiigi ane niÉĄĖķeladimigipitigi nipodigi icoa gadareenotedi odipokotalo Jesus me noditedice nipodigi, igaataÉĄĖķa one eliodi me doitibigiwaji. Odaa jonoÉĄĖķowaxoditacinigi aca niwatece, odaa joÉĄĖķopitacicogi daato weiigi. 
\p  
\v 38 NiÉĄĖķijo Jesus naÉĄĖķa nipegi me dawace liwatece, odaa niÉĄĖķijo ÉĄĖķoneleegiwa ane icilatidi eliodi me dipokotibigalo migo diotece. Pida Jesus naÉĄĖķa ibode, meeteta,  
\v 39 âEmii opiliticogi ÉĄĖķadiÉĄĖķeladi, odaaÉĄĖķatematii niÉĄĖķica anigotedaÉĄĖķawa AneotedoÉĄĖķoji.â NiÉĄĖķidiaaÉĄĖķidi niÉĄĖķijo ÉĄĖķoneleegiwa jiÉĄĖķigoteloco anitawece nigotaÉĄĖķa, yatematitibece niÉĄĖķica anigote Jesus lewiÉĄĖķa. 
\s1 Jesus icilatidi aca iwaalo, acaaÉĄĖķaca nigaanawaana 
\r (Mateus 9.18-26; Marcos 5.21-43) 
\p  
\v 40 NiÉĄĖķijo Jesus niÉĄĖķicotacedicogi daato weiigi, ica noiigi ele modibatege, codaa ninitibigiwaji leeÉĄĖķodi ijotawece akaaÉĄĖķonibeotibigege.  
\v 41 JoniÉĄĖķigo dakapetege Jesus ica ÉĄĖķoneleegiwa anodita Jairo. JoniÉĄĖķijaa dowediteloco liiakanaÉĄĖķaxi judeutedi manitaÉĄĖķa naÉĄĖķani nigotaÉĄĖķa. NaÉĄĖķa yamaÉĄĖķatedini lokotidi lodoe Jesus, odaa ja dipokotalo migo liÉĄĖķeladi.  
\v 42 LeeÉĄĖķodi Jairo onajoteci me liona, onaleekeote dooze nicaaÉĄĖķape, pida eliodi me deelotika, jona doletibige me yeleo. 
\p Odaa Jesus jiÉĄĖķigo, pida niÉĄĖķica noiigi joÉĄĖķodiniligicetelogo.  
\v 43 Odaa ja dakapetetege aca iwaalo awodina. JoneÉĄĖķeote dooze nicaaÉĄĖķape me deelotika, codaa jona yaaÉĄĖķadi icoatawece niÉĄĖķicoa ane nepilidi me yedia dotowexedi. Pida aÉĄĖķica ane yakadi me icilatidi.  
\v 44 Odaa naÉĄĖķajo iwaalo jona nowidila Jesus, odaa dibatigi laxabi nijayogo, odaa jona wakagitege lawodi.  
\v 45 Odaa Jesus ja digika, onee, âAmiijo ane dibatiloco?â Pida niÉĄĖķijo noiigi modi me diÉĄĖķica ane dibatelogo. Odaa Pedro meetalo, âĮĪoniiÉĄĖķaxinoÉĄĖķodi, inatawece niÉĄĖķina noiigi etiÉĄĖķadawiileni, codaa metiÉĄĖķadiligiceni.â  
\v 46 Pida Jesus mee, âOÉĄĖķoa ijo ica ane dibatiloco, igaataÉĄĖķa jeemitetece me noditice yoniciwaÉĄĖķa ane ÉĄĖķodicilatidi.â  
\v 47 NaÉĄĖķajo iwaalo naÉĄĖķa nadi me daÉĄĖķadiaa yakadi me yaÉĄĖķaditi niÉĄĖķijo loenatagi, odaa joniÉĄĖķigo dawigicetijo, yamaÉĄĖķatedini lokotidi lodoe Jesus. Codaa yatemati lodoe ijotawece niÉĄĖķijo noiigi ane leeÉĄĖķodi me dibatelogo Jesus, codaa yatemati niÉĄĖķica me daÉĄĖķa leegi odaa ja icÃ­ me awodina.  
\v 48 Odaa Jesus meeteta, âIona, ja ÉĄĖķadicili leeÉĄĖķodi madadiwaÉĄĖķati. Emiita opili, mele ÉĄĖķadaaleÉĄĖķena!â 
\p  
\v 49 EÉĄĖķidaaÉĄĖķeeteda Jesus me dotaÉĄĖķatedibece, joniÉĄĖķica ica ane icoÉĄĖķoticogi liÉĄĖķeladi Jairo, niÉĄĖķijo ane dowediteloco niiakanaÉĄĖķaxi, odaa jeÉĄĖķeeta, âĮĪadiona ja yeleo. JinaÉĄĖķaleeÉĄĖķanigiwoci ĮĪoniiÉĄĖķaxinoÉĄĖķodi.â  
\v 50 NaÉĄĖķa wajipate Jesus niÉĄĖķijoa lotaÉĄĖķa, odaa jeÉĄĖķeeteta Jairo, âJinaÉĄĖķadoii! BiÉĄĖķida adinakatoni, odaa jeÉĄĖķeletace ÉĄĖķadiona.â 
\p  
\v 51 NiÉĄĖķicotediwece diimigi, aÉĄĖķica ane ikatedio me dakatio, pida ijokijo Pedro, Tiago, ijaa JoÃĢo, ijaaÉĄĖķijo eliododipi naÉĄĖķajo nigaanawaana baÉĄĖķa ikatediobece me dakatiobece.  
\v 52 Ijotawece niÉĄĖķijo oko nacaagaÉĄĖķateloco, codaa me notaÉĄĖķanaÉĄĖķateloco leeÉĄĖķodi naÉĄĖķajo nigaanawaana. Odaa Jesus meetediogi, âJinaÉĄĖķacaagetibecetiwaji! NaÉĄĖķadi nigaanawaana ayeleo, pida diote.â 
\p  
\v 53 Odaa jonoÉĄĖķoyame, igaataÉĄĖķa oyowooÉĄĖķodi neÉĄĖķewi me yeleo naÉĄĖķajo nigaanawaana.  
\v 54 Odaa ja imonyatedicoace me noditicoaci, odaa naÉĄĖķa dibatedigi libaaÉĄĖķadi naÉĄĖķajo nigaanawaana, odaa jeÉĄĖķee niÉĄĖķina me dinigetaÉĄĖķatee, âNigaanawaana, anicootini!â  
\v 55 Odaa niÉĄĖķica liwigo jonaÉĄĖķa dopiteloco, aoniÉĄĖķica ica daÉĄĖķa leegi jona nicoti. Odaa Jesus ja diiÉĄĖķenatakate mowo liweenigi.  
\v 56 NiÉĄĖķijo eliododipi eliodi moyopo. Odaa Jesus ja yajoi me doÉĄĖķoyatematitibece niÉĄĖķida niciagi. 
\c 9  
\s1 Jesus iiÉĄĖķe niÉĄĖķijo dooze anodiotibece moyeloÉĄĖķoditedibece nibodicetedi anele 
\r (Mateus 10.5-15; Marcos 6.7-13) 
\p  
\v 1 Jesus eniditediogi niÉĄĖķijo dooze anodiotibece me dinatecoÉĄĖķotee, odaa yajigotediogi ica loniciwaÉĄĖķa codaa me naÉĄĖķatetigi moiticoitedice inoatawece ane niwicidi abeyacaÉĄĖķaÉĄĖķa, codaa moicilatidi eelotaginadi.  
\v 2 Odaa ja iiÉĄĖķetediogi moyeloÉĄĖķodi anodaaÉĄĖķee AneotedoÉĄĖķoji me iiÉĄĖķe laaleÉĄĖķenali oko, codaa moicilatidi eelotaginadi.  
\v 3 Odaa jeÉĄĖķeetediogi, âJiniÉĄĖķica ananibaatinetiwaji maniwiaje. JinaÉĄĖķadeegi ÉĄĖķagiilaÉĄĖķadi, oteÉĄĖķexaaÉĄĖķaÉĄĖķa ÉĄĖķadowoodaÉĄĖķaxi, niweenigi, dinyeelo, oteÉĄĖķexaaÉĄĖķaÉĄĖķa eledi ÉĄĖķanoecaÉĄĖķaxi.  
\v 4 Adeoni minitaÉĄĖķa diimigi anele modibataÉĄĖķagitiwaji, nigepaa limedi manotitice naÉĄĖķani nigotaÉĄĖķa.  
\v 5 Odaa nigaca nigotaÉĄĖķa anicootatiwaji ane deÉĄĖķele modibataÉĄĖķagitiwaji niÉĄĖķeladimigipi, odaa niganotiticetiwaji naÉĄĖķani nigotaÉĄĖķa, iticiÉĄĖķi lamoÉĄĖķo ÉĄĖķadoÉĄĖķonaka, amaleeÉĄĖķaÉĄĖķa ikeeni AneotedoÉĄĖķoji me yelatetema niÉĄĖķidi niÉĄĖķeladimigipi.â 
\p  
\v 6 Odaa jiÉĄĖķigotibeci niÉĄĖķijo anodiotibece odigotece icoatawece niÉĄĖķicoa nigotadawaanaÉĄĖķa, oyeloÉĄĖķoditedibece nibodicetedi anele, codaa oicilatidi eelotaginadi niÉĄĖķica anodigotece. 
\s1 Herodes doÉĄĖķowikomata 
\r (Mateus 14.1-12; Marcos 6.14-29) 
\p  
\v 7 Herodes ane ninionigi-eliodi niÉĄĖķica nipodigi dibodicetalo icoatawece niÉĄĖķicoa Jesus loenataka. Odaa eliodi me doÉĄĖķowikomata, aÉĄĖķaleeÉĄĖķica baÉĄĖķa lowoogo, leeÉĄĖķodi onica ica anodi Jesus me JoÃĢo Batista naÉĄĖķa yewiÉĄĖķatace.  
\v 8 Ica eledi modi mone Elias, naÉĄĖķa dinikeetaci, odaa ica eledi onodi Jesus minaaÉĄĖķina niÉĄĖķina ane yeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko, baanaÉĄĖķa yeleo anokaanaÉĄĖķa yewiÉĄĖķatace.  
\v 9 Odaa Herodes mee, âJeÉĄĖķemaÉĄĖķa jiiÉĄĖķenatakata moyakagidi lacilo JoÃĢo. Enice, amiida ica ÉĄĖķoneleegiwa? IgaataÉĄĖķa jibodicetalo niÉĄĖķicoa loenataka.â Odaa Herodes ja doletibige nimaweneÉĄĖķegi me nadi Jesus. 
\s1 Jesus niodeÉĄĖķetedini noiigi-nelegi 
\r (Mateus 14.13-21; Marcos 6.30-44; JoÃĢo 6.1-14) 
\p  
\v 10 NaÉĄĖķa dopitijo niÉĄĖķijo liiÉĄĖķexedipi, odaa joÉĄĖķoyeloÉĄĖķoditalo Jesus icoatawece niÉĄĖķicoa ane loenataka. Odaa ja yadeegi igotibeci manitaÉĄĖķa aca nigotakawaana ane liboonaÉĄĖķadi Betsaida, ijokijo niÉĄĖķijo anodiotibece me yadeegi.  
\v 11 Pida niÉĄĖķijo noiigi noÉĄĖķoyowooÉĄĖķodi ane diitedicogi Jesus, odaa joÉĄĖķoigaalatece. Odaa ja dibatetege Jesus, yatematitediogi anodaaÉĄĖķee AneotedoÉĄĖķoji me iiÉĄĖķe oko laaleÉĄĖķenali, codaa icilatidi niÉĄĖķijo ane neelotikanaÉĄĖķa. 
\p  
\v 12 NiÉĄĖķijo naÉĄĖķa ÉĄĖķocidi, niÉĄĖķijo dooze anodiotibece Jesus jiÉĄĖķigotibeci midoataÉĄĖķa, odaa moditalo, âJeÉĄĖķele me iiÉĄĖķeni mopitibeci niÉĄĖķina noiigi, amaleeÉĄĖķaÉĄĖķa igotibeci minoataÉĄĖķa niÉĄĖķinoa nigotadawaanaÉĄĖķa, bajeendatedi, odoletibige niÉĄĖķica aniwote, codaa amaleeÉĄĖķaÉĄĖķa oyakadi anoyeligo. IgaataÉĄĖķa niÉĄĖķina anejonaÉĄĖķa yadilo, aÉĄĖķica niÉĄĖķeladimigipi.â  
\v 13 Pida Jesus naÉĄĖķa igidi, meetediogi, âAkamaÉĄĖķakaamitiwaji, ajicitiogi ane yeligo!â Odaa modi, âAÉĄĖķicoda ÉĄĖķoweenigi, idiwa mina ciinco paontedi, idiaaÉĄĖķidioda itiwataale noÉĄĖķojedi. AjakataÉĄĖķa daÉĄĖķa jajicaÉĄĖķatiogi anoyeligo, ajiboÉĄĖķotege me jinoojeteeÉĄĖķatibige niweenigi.â  
\v 14 Owo niÉĄĖķida ligegi, leeÉĄĖķodi jona domaÉĄĖķa iwida ciinco miili ÉĄĖķoneleegiwadi (we nigaanigipawaanigi codaa me iwaalepodi). Odaa Jesus oneetediogi niÉĄĖķijo anodiotibece, âIiÉĄĖķeni me nicotiniwace niÉĄĖķidi noiigi, mowo lapotibece meya-taaliatibece oko.â 
\p  
\v 15 NiÉĄĖķijo anodiotibece jiÉĄĖķidaaÉĄĖķee, joÉĄĖķoiiÉĄĖķe niÉĄĖķijo noiigi me nicotiniwace.  
\v 16 Odaa Jesus ja dibate niÉĄĖķijoa ciinco paontedi ijaaÉĄĖķijoa itiwataale noÉĄĖķojedi. NaÉĄĖķa iwitedibigimece ditibigimedi, odaa ja diniotagodete AneotedoÉĄĖķoji leeÉĄĖķodi niweenigi. NiÉĄĖķidiaaÉĄĖķidi ja ninoketedini niÉĄĖķijoa paontedi, ijaaÉĄĖķijoa noÉĄĖķojedi. Odaa ja yajigotediogi niÉĄĖķijo anodiotibece monediatiniwace niÉĄĖķidi noiigi.  
\v 17 Ijotawece niodaÉĄĖķa, codaa nitiminaÉĄĖķa. Odaa niÉĄĖķijo anodiotibece joÉĄĖķoyetigilo dooze etacanitedi niÉĄĖķicoa liwailidi ane iiÉĄĖķotedice. 
\s1 Pedro yeloÉĄĖķodi anijoa Jesus 
\r (Mateus 16.13-19; Marcos 8.27-29) 
\p  
\v 18 Ica noko one oniniwatece Jesus, yotaÉĄĖķaneÉĄĖķe AneotedoÉĄĖķoji. Odaa jonoÉĄĖķototalo niÉĄĖķijo anodiotibece. Odaa jonaÉĄĖķa nigetediniwace, meetediogi, âAmiijo anodi me Ee, ina noiigi?â  
\v 19 Odaa joÉĄĖķoigidi, moditalo, âInitecibece oko modi makaami JoÃĢo Batista. Pida ina eledi modi makaami Elias. Codaa ina eledi modi makaami anigepidiÉĄĖķica niÉĄĖķijo anoyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko jotigide, anokaanaÉĄĖķa yewiÉĄĖķatace.â  
\v 20 Odaa ja nigetediniwace, meetediogi, âBiÉĄĖķida makaamitiwaji, ame Ee me enitiwaji?â Odaa Pedro ja igidi, meetalo, âOko baÉĄĖķa jowooÉĄĖķotaÉĄĖķa naÉĄĖķakamaÉĄĖķakaami ane niiÉĄĖķe AneotedoÉĄĖķoji me ÉĄĖķodewikatidi.â 
\s1 Jesus eetetece lemeÉĄĖķegi, codaa yalaÉĄĖķate me yewiÉĄĖķatace 
\r (Mateus 16.20-28; Marcos 8.30â9.1) 
\p  
\v 21 Odaa Jesus ja yajoi me doÉĄĖķoyatematitibece niÉĄĖķiniaaÉĄĖķiniwa NiÉĄĖķicoa ane niiÉĄĖķe AneotedoÉĄĖķoji.  
\v 22 Odaa meetediogi, âEe, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, leeditibige meliodi me jawikode. Odibatigi, niÉĄĖķina anoiiÉĄĖķe ÉĄĖķodoiigi, codaa me niÉĄĖķidi anoiiÉĄĖķe sacerdotitedi, idiaaÉĄĖķidi niÉĄĖķidi anodiiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs. Codaa etideloadi, pida nigicotalo itoatadiÉĄĖķida nokododi, odaa ja idewiÉĄĖķatace.â 
\p  
\v 23 Odaa Jesus jeÉĄĖķeetediogi ijotawece, âNigica ane yemaa me niotici, leeditibige me daÉĄĖķa doletibige niÉĄĖķica anepaa yemaa, codaa leeditibige me igotema me dawikode codaa me yeleo, inoatawece nokododi. Odaa ja yakadi me niotici.  
\v 24 IgaataÉĄĖķa niÉĄĖķina ane yemaa lakataÉĄĖķa niÉĄĖķina oko digoina iiÉĄĖķo, yeleo nigidiaaÉĄĖķidi. Pida niÉĄĖķina ane yeleo Ee leeÉĄĖķodi, biÉĄĖķicota noko me yewiÉĄĖķatace.  
\v 25 Codaa niÉĄĖķina oko daÉĄĖķa dinigaanyetece niÉĄĖķinoa aninoa digoina iiÉĄĖķo, nige yeleo, AneotedoÉĄĖķoji iloikatidi, codaa aÉĄĖķaleeÉĄĖķica niwalÃģ, jaÉĄĖķaniatagigi.  
\v 26 IgaataÉĄĖķa niÉĄĖķina oko nige dinibolikatiditici, codaa me yotaÉĄĖķa, odaa Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, aaÉĄĖķaÉĄĖķa idinibolikatiditece nige janagi inadeegi yoniciwaÉĄĖķa, codaa nige jatale iciagi miniwataÉĄĖķa Eiodi me datale, codaa iciaco me datale aanjotedi ane idioka limedi modibatema.  
\v 27 EjitaÉĄĖķawatiwaji mewi mina oko digoina anaÉĄĖķa nigo, nigonadi AneotedoÉĄĖķoji nige iiÉĄĖķe laaleÉĄĖķenali oko.â 
\s1 Jesus dakapetetege MoisÃĐs ijaa Elias 
\r (Mateus 17.1-13; Marcos 9.2-8) 
\p  
\v 28 NiÉĄĖķidiaaÉĄĖķidi ejinaÉĄĖķa ixomaÉĄĖķatedice oito nokododi me yeloÉĄĖķodi Jesus niÉĄĖķijoa lotaÉĄĖķa, odaa ja yadeegi me lixigaÉĄĖķawepodi Pedro, JoÃĢo, ijaa Tiago. Odaa ja dalaÉĄĖķatetedibigimece aca wetiÉĄĖķa ane leegitibigimece, igo me yotaÉĄĖķaneÉĄĖķe AneotedoÉĄĖķoji.  
\v 29 EÉĄĖķidaa diitigi me yotaÉĄĖķaneÉĄĖķe AneotedoÉĄĖķoji jona diniigi anodaaÉĄĖķee latobi, lowoodi jonaÉĄĖķaÉĄĖķa yapacaÉĄĖķa, codaa me datale.  
\v 30 CodaaÉĄĖķida icoa itoa ÉĄĖķoneleegiwadi naÉĄĖķa dinikeetibigiwaji, odaa joÉĄĖķoyotaÉĄĖķaneÉĄĖķe Jesus. NiÉĄĖķidoa itoa ÉĄĖķoneleegiwadi one MoisÃĐs, ijaa Elias. \fig |src="CN01728B.TIF" size="span" copy="ÂĐ 1978 David C. Cook Publishing Co." ref="Lucas 9.30" \fig* 
\v 31 NiÉĄĖķidoa itoa aaÉĄĖķaÉĄĖķa dataletibigiwaji. Odaa joÉĄĖķoyotaÉĄĖķaneÉĄĖķetibigo Jesus, oyalaÉĄĖķata ica lemeÉĄĖķegi ane nibikota AneotedoÉĄĖķoji micota digoida JerusalÃĐm.  
\v 32 Pedro ijaaÉĄĖķijoa niÉĄĖķijoa lokaaÉĄĖķetedi jonaÉĄĖķa nibaciÉĄĖķa, odaa ja niotaÉĄĖķa. Pida naÉĄĖķa niwoditibigiwaji, odaa joÉĄĖķonadi Jesus me datale, ijaaÉĄĖķijoa itoataale ÉĄĖķoneleegiwadi midoataÉĄĖķa.  
\v 33 NiÉĄĖķijo naÉĄĖķa nipegi mopitibeci niÉĄĖķidiwa itoataale ÉĄĖķoneleegiwadi, Pedro meetalo Jesus, âĮĪoniiÉĄĖķaxinoÉĄĖķodi, niÉĄĖķica mele minaaÉĄĖķejonaÉĄĖķa! JaoÉĄĖķate iniwatadiÉĄĖķini ÉĄĖķadopecetiiditiwaji, oniniteci ÉĄĖķanebi, ini eledi MoisÃĐs, iniaaÉĄĖķeledi Elias.â Eo niÉĄĖķida ligegi, pida ayowooÉĄĖķodi niÉĄĖķica ane diitigi. 
\p  
\v 34 Pedro eÉĄĖķidaaÉĄĖķee me dotaÉĄĖķa, naÉĄĖķa dinikatiogi ica lolaadi, odaa ja yapoÉĄĖķoditiniwace. NiÉĄĖķijo anodiotibece Jesus doitibigiwaji niÉĄĖķijo naÉĄĖķa nowicetiogi niÉĄĖķijo lolaadi.  
\v 35 Odaa joÉĄĖķowajipata ica ane dotaÉĄĖķa catiwedi niÉĄĖķijo lolaadi, onee, âNiÉĄĖķidoa, jiÉĄĖķidaaÉĄĖķidoa Ionigi aneliodi me jemaa. Ajipaata ane ligegi!â 
\p  
\v 36 NiÉĄĖķijo naÉĄĖķa nigotini ica ane dotaÉĄĖķa, niÉĄĖķijo anodiotibece Jesus joÉĄĖķonadi mokaaniÉĄĖķidoatece. Odaa ja notokotiniwace, odaa niÉĄĖķijoa nokododi aÉĄĖķica anoyeloÉĄĖķodi niÉĄĖķijo anonadi. 
\s1 Jesus icilatidi nigaanigawaanigi ane dakatiogi niwigo abeyaceÉĄĖķegi 
\r (Mateus 17.14-21; Marcos 9.14-29) 
\p  
\v 37 NeÉĄĖķeledi noko ja daxoditiniwace me idei ditibigimedi wetiÉĄĖķa. Odaa ica noiigi-nelegi jiÉĄĖķigotibeci odakapetege Jesus.  
\v 38 Odaa onica ica ÉĄĖķoneleegiwa ane idei liwigotigi niÉĄĖķidi noiigi, onee me dinigetaÉĄĖķatee, âĮĪoniiÉĄĖķaxinoÉĄĖķodi, jipokotaÉĄĖķawa managi icilatiti ionigi, igaataÉĄĖķa onididateci me ionigi.  
\v 39 Niwigo abeyaceÉĄĖķegi ane dakatiogi, niÉĄĖķina me dibata, odaa eo me codaaÉĄĖķidata naÉĄĖķa dapaawe, dinawigice niÉĄĖķica niwigo, natiamaÉĄĖķaditigi nioladi niÉĄĖķidi nigaanigi. NiÉĄĖķica niwigo abeyaceÉĄĖķegi idioka limedi me yawigice, ayemaa me noditice.  
\v 40 Ja domaÉĄĖķa jipokotiogi niÉĄĖķidi anodiotibigaÉĄĖķadici moiticoitice niwigo abeyaceÉĄĖķegi, pida aÉĄĖķoyakadi moiticoitice.â 
\p  
\v 41 Jesus naÉĄĖķa dotaÉĄĖķa, mee, âAkaami oko ane daÉĄĖķa adinakatonitiwaji, akaami abeyacaÉĄĖķaÉĄĖķa. AÉĄĖķaleeÉĄĖķowidi nokododi minaaÉĄĖķejo makaamitaÉĄĖķatiwaji. Amigida ica noko nige daÉĄĖķadiaa jakadi me idinatitaÉĄĖķawatiwaji?â Odaa joneÉĄĖķeete niÉĄĖķijo ÉĄĖķoneleegiwa, âAnadeegi ÉĄĖķadionigi digoina meetaÉĄĖķa!â  
\v 42 NiÉĄĖķica naÉĄĖķa yadeegi niÉĄĖķijo nigaanigawaanigi, niwigo abeyaceÉĄĖķegi jona yokoletinigi iiÉĄĖķo, codaa me yawigice. Pida Jesus ja iiÉĄĖķe me noditice niÉĄĖķijo niwigo abeyaceÉĄĖķegi, odaa ja icilatidi niÉĄĖķijo nigaanigawaanigi. Odaa ja yopilaÉĄĖķadite niÉĄĖķijo eliodi.  
\v 43 Ijotawece niÉĄĖķijo oko eliodi moyopo, leeÉĄĖķodi me nelegi niÉĄĖķica notoetiigi AneotedoÉĄĖķoji. 
\s1 Jesus yalaÉĄĖķatace ica lemeÉĄĖķegi 
\r (Mateus 17.22-23; Marcos 9.30-32) 
\p EÉĄĖķidaaÉĄĖķee modoxicetema niÉĄĖķijoa loenataka Jesus, neÉĄĖķeetediogi niÉĄĖķijo anodiotibece,  
\v 44 âDigatacolitece yotaÉĄĖķataÉĄĖķawatiwaji. Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, etidajigota loniciwaÉĄĖķa ÉĄĖķoneleegiwadi.â  
\v 45 Pida niÉĄĖķijo anodiotibece aÉĄĖķoyowooÉĄĖķoditece niÉĄĖķijoa lotaÉĄĖķa, leeÉĄĖķodi AneotedoÉĄĖķoji aneÉĄĖķeote moyowooÉĄĖķodi. Odaa joaniÉĄĖķidaa leeÉĄĖķodi me doÉĄĖķoyowooÉĄĖķodi niÉĄĖķica ane diitigi niÉĄĖķijoa Jesus lotaÉĄĖķa. Pida odoitalo doÉĄĖķoigetece niÉĄĖķica ane diitigilo niÉĄĖķijoa lotaÉĄĖķa. 
\s1 NiÉĄĖķica ane daÉĄĖķaxa me diniwaloe 
\r (Mateus 18.1-5; Marcos 9.33-37) 
\p  
\v 46 NiÉĄĖķijo anodiotibece Jesus jonoÉĄĖķodinotigimadetigi niÉĄĖķica ane daÉĄĖķaxa me diniwaloe.  
\v 47 Pida Jesus yowooÉĄĖķodi niÉĄĖķica anoyowo catiwedi laaleÉĄĖķenali. Odaa jona dibate ica nigaanigawaanigi. NaÉĄĖķa nicooÉĄĖķete liwai,  
\v 48 Odaa jeÉĄĖķeetediogi, âNiÉĄĖķina ane dibatege niÉĄĖķini nigaanigawaanigi, leeÉĄĖķodi naÉĄĖķatetigi IboonaÉĄĖķadi, niÉĄĖķini dibatigi. Odaa niÉĄĖķini ane dibatigi, aaÉĄĖķaÉĄĖķa dibatege ane idiiÉĄĖķe. IgaataÉĄĖķa niÉĄĖķina ane daÉĄĖķaxa me iwikodaÉĄĖķa ÉĄĖķadiwigotigitiwaji, joaniÉĄĖķiniaa daÉĄĖķaxa mida niwalÃģ.â 
\s1 NiÉĄĖķica ane daÉĄĖķa ÉĄĖķodakapetegi, ÉĄĖķodicaajo 
\r (Marcos 9.38-40) 
\p  
\v 49 Odaa JoÃĢo oneetalo, âĮĪoniiÉĄĖķaxinoÉĄĖķodi, jinataÉĄĖķa ijo ÉĄĖķoneleegiwa ane iticoitedice niwicidi abeyacaÉĄĖķaÉĄĖķa datika ĮĪaboonaÉĄĖķadi. Odaa ja joxokojoÉĄĖķo me iticoitedice niwicidi abeyacaÉĄĖķaÉĄĖķa, igaataÉĄĖķa adiotibigaÉĄĖķadici digo anejinaÉĄĖķa me jiwaÉĄĖķataÉĄĖķadici.â  
\v 50 Pida Jesus meeteta, âIgaamee ina moxoki? IgaataÉĄĖķa niÉĄĖķina ane daÉĄĖķa ÉĄĖķodakapetegi, ÉĄĖķodicaajo.â 
\s1 Samaritaanotedi aÉĄĖķodibatege Jesus 
\p  
\v 51 NaÉĄĖķa nipegi niÉĄĖķica noko Jesus mopitedibigimece ditibigimedi, odaa ja lowoogo mewi migo JerusalÃĐm.  
\v 52 JoneÉĄĖķeote lienigipi migotibeci odoe. Odaa niÉĄĖķigotibeci joÉĄĖķodakatiwece aca nigotakawaana samaritaanotedi, domoÉĄĖķodoletibige ane lotokaÉĄĖķadi Jesus.  
\v 53 Pida niÉĄĖķijo niÉĄĖķeladimigipi aÉĄĖķodibatege Jesus, leeÉĄĖķodi moyowooÉĄĖķodi me lowoogo migo JerusalÃĐm.  
\v 54 NiÉĄĖķijo anodiotibece Jesus, Tiago ijaa JoÃĢo noÉĄĖķonadi me doÉĄĖķodibatege, odaa modi, âĮĪoniotagodi, emaani me jiiÉĄĖķenaÉĄĖķa me dinikatini noledi icoÉĄĖķotibigimece ditibigimedi me yaaÉĄĖķadi niÉĄĖķidi noiigi, anee Elias niÉĄĖķijo jotigide?â 
\p  
\v 55 Pida Jesus naÉĄĖķa nawiilitetege, odaa ja napeteÉĄĖķetediniwace, meetediogi, âNiÉĄĖķida makaamitiwaji aÉĄĖķowooÉĄĖķoti anodaaÉĄĖķeni.  
\v 56 IgaataÉĄĖķa Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, ajanagi me jaaÉĄĖķadi oko, pida janagi me jao lewiÉĄĖķa.â Odaa joniÉĄĖķigotibeci manitaÉĄĖķa aca eledi nigotakawaana. 
\s1 Ica oko onodi moyemaa modiotibece Jesus 
\r (Mateus 8.18-22) 
\p  
\v 57 NiÉĄĖķijo Jesus naÉĄĖķa ideite naigitinece ijaaÉĄĖķijo anodiotibece, ica ÉĄĖķoneleegiwa oneetalo Jesus, âIniotagodi, jemaa me jiotaÉĄĖķadici okanicodaaÉĄĖķica anemaani me aaticogi.â  
\v 58 Odaa Jesus jeÉĄĖķeeteta, âNaÉĄĖķana eti ida epaa libegi, codaa me ilaaÉĄĖķaxodi ani epaa libato. Pida Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, baadiÉĄĖķicanejo me inipetini.â 
\p  
\v 59 Odaa Jesus oneete ica eledi ÉĄĖķoneleegiwa, âAnagi aniwitibici!â Pida onee, âIniotagodi, ecoÉĄĖķotace ejigo iÉĄĖķeladi, inaligitini eiodi.â  
\v 60 Odaa Jesus jeÉĄĖķeete, âIkani niÉĄĖķina ane liciagi ÃĐmeÉĄĖķegi me naligitini nÃĐmeÉĄĖķegi. Pida akaami baanaÉĄĖķa akamaÉĄĖķa emii, eloÉĄĖķoti anodaaÉĄĖķee AneotedoÉĄĖķoji me iiÉĄĖķe oko laaleÉĄĖķenali.â 
\p  
\v 61 Odaa ica eledi ÉĄĖķoneleegiwa oneetalo Jesus, âIniotagodi, ee ejigo jiotaÉĄĖķadici, pida ecoÉĄĖķotace ejigo jibodenaÉĄĖķa digoida iÉĄĖķeladi.â  
\v 62 Pida Jesus naÉĄĖķa igidi meeteta, âNiÉĄĖķina ane gela me yabooÉĄĖķodi iiÉĄĖķo, odaa niwiticogi lowidi, AneotedoÉĄĖķoji ayakadi daÉĄĖķa yajigote me libakedi me yeloÉĄĖķoditibece anodaaÉĄĖķee me iiÉĄĖķe laaleÉĄĖķenali oko.â 
\c 10  
\s1 Jesus imonya seteenta ÉĄĖķoneleegiwadi moyeloÉĄĖķodi nibodicetedi anele 
\p  
\v 1 NiÉĄĖķidiaaÉĄĖķidi ĮĪoniotagodi Jesus naÉĄĖķa igiditediogi niÉĄĖķijoa ÉĄĖķoneleegiwadi anodi moyemaa modiotibece, odaa ja iomaÉĄĖķaditedice eletidi seteenta ÉĄĖķoneleegiwadi. Odaa ja imonya itoataaletibece migotibeci dinewadetibigiwaji, midiwataÉĄĖķa nigotadi, codaa me midiwataÉĄĖķa icoa nigotadawaanaÉĄĖķa ane lowoogo Jesus migotetece.  
\v 2 Odaa meetediogi, âEliodi oko anonibeotege mowajipatalo nibodicetedi anele, micataÉĄĖķa niÉĄĖķina nixoÉĄĖķotagi nelegi baanaÉĄĖķa limedi monopilaÉĄĖķaditedio nawodigijedi, pida aÉĄĖķeliodi ane nibaaÉĄĖķa. JoaniÉĄĖķidaa leeÉĄĖķodi ipokitalo AneotedoÉĄĖķoji me niwakatee eletidi liotaka. MicataÉĄĖķa niÉĄĖķina ane nebi nixoÉĄĖķotagi me iiÉĄĖķe niÉĄĖķinoa eletidi liotaka me naxawanatakanaÉĄĖķa monopilaÉĄĖķaditedio lawodigijedi.  
\v 3 Emiitiwaji! ĮĪadiiÉĄĖķeni micoataÉĄĖķa niÉĄĖķinoa waxacocoli miditaÉĄĖķa noiigi ane liciagi diwilecoÉĄĖķoni.  
\v 4 JinaÉĄĖķadeegi ÉĄĖķaninyeelaÉĄĖķaxi, oteÉĄĖķexaaÉĄĖķaÉĄĖķa ÉĄĖķaniboco ane nolee niweenigi, migetaÉĄĖķa eletidi ÉĄĖķawelatedi. Codaa jiniÉĄĖķica ananicenitiwaji oko ÉĄĖķadakapetegitinece naigi. 
\p  
\v 5 Nigakaatiwece diimigi, odoejegi ane alitigi ÉĄĖķagegi, eni, âJemaanaÉĄĖķa AneotedoÉĄĖķoji meote mele ÉĄĖķadaaleÉĄĖķenali akaamitawecetiwaji ane ÉĄĖķadiÉĄĖķeladi niÉĄĖķina diimigi.â  
\v 6 Nigica oko anoyemaa AneotedoÉĄĖķoji meote mele laaleÉĄĖķena, odaa AneotedoÉĄĖķoji ibinie ane ÉĄĖķadipoketegi. Pida nige diÉĄĖķica ane yemaa AneotedoÉĄĖķoji meote mele laaleÉĄĖķena, odaa AneotedoÉĄĖķoji aibinie niÉĄĖķica niÉĄĖķeladimigipi, ane domaÉĄĖķa ÉĄĖķadipoketegiteloco.  
\v 7 IdiaaÉĄĖķonitetiwaji minitaÉĄĖķa niÉĄĖķini diimigi, odaa elici anoyajigotaÉĄĖķawatiwaji. IgaataÉĄĖķa iÉĄĖķenaÉĄĖķa niÉĄĖķina nibakecajo me dibatege nigaanyeÉĄĖķegi. 
\p  
\v 8 Codaa niÉĄĖķina nigakaatiwecetiwaji nigotaÉĄĖķa, odaa nigele modibataÉĄĖķagi, elici niÉĄĖķica anoyajigotaÉĄĖķawa.  
\v 9 Icilatititiwaji eelotaginaditigi naÉĄĖķani nigotaÉĄĖķa, codaa enitiogi niÉĄĖķidi niÉĄĖķeladimigipitigi naÉĄĖķani nigotaÉĄĖķa, âAneotedoÉĄĖķoji ja igo me iiÉĄĖķe laaleÉĄĖķenali noiigitigi naÉĄĖķana nigotaÉĄĖķaâ.  
\v 10 Pida nigakaatiwece nigotaÉĄĖķa ane deÉĄĖķele modibataÉĄĖķagi, emiitelogo ladicotiidi, odaa enitiwaji,  
\v 11 âNiÉĄĖķina amoÉĄĖķotigi naÉĄĖķana nigotaÉĄĖķa ane yexogotece ÉĄĖķodoÉĄĖķonaka, jiticoÉĄĖķojoÉĄĖķo amaleeÉĄĖķaÉĄĖķa jikeenaÉĄĖķataÉĄĖķawatiwaji me yelatedaÉĄĖķadomi AneotedoÉĄĖķoji. DomaÉĄĖķa jemaanaÉĄĖķa mowooÉĄĖķotitiwaji naÉĄĖķa igo AneotedoÉĄĖķoji me iiÉĄĖķe ÉĄĖķadaaleÉĄĖķenalitiwaji, pida aÉĄĖķemaanitiwaji.ââ Odaa Jesus meetediogi niÉĄĖķijoa seteenta liiÉĄĖķexedi,  
\v 12 âEjitaÉĄĖķawatiwaji, AneotedoÉĄĖķoji daÉĄĖķaxa meote me nawikodeeÉĄĖķa niÉĄĖķijo niÉĄĖķeladimigipitigi naÉĄĖķani nigotaÉĄĖķa ane deÉĄĖķele modibataÉĄĖķagi, caticedi niÉĄĖķijo oko niÉĄĖķeladimigipitigi nigotaÉĄĖķa Sodoma, ane yaaÉĄĖķadi AneotedoÉĄĖķoji niÉĄĖķijo jotigide. Eliodi me nawikodeeÉĄĖķa niÉĄĖķidi oko ane deÉĄĖķele modibataÉĄĖķagi niÉĄĖķica noko nige limedi me iloikatidi AneotedoÉĄĖķoji niÉĄĖķina noiigi leeÉĄĖķodi libeyaceÉĄĖķeco.â 
\s1 Icoa nigotadi anei me doÉĄĖķoyiwaÉĄĖķaditeda Jesus 
\r (Mateus 11.20-24) 
\p  
\v 13 Jesus idokee me niiÉĄĖķaxitediniwace niÉĄĖķidi oko, odaa meetediogi, âAkaamitiwaji ane ÉĄĖķadiÉĄĖķeladi Corazim, icota meliodi mawikodeetiwaji. Codaa akaamitiwaji ane ÉĄĖķadiÉĄĖķeladi Betsaida aaÉĄĖķaÉĄĖķa icota meliodi mawikodeetiwaji, leeÉĄĖķodi me daÉĄĖķa adadiwaÉĄĖķati. IgaataÉĄĖķa niÉĄĖķijoa ÉĄĖķodoxiceÉĄĖķetedi aneote AneotedoÉĄĖķoji mani ÉĄĖķanigotaÉĄĖķatiwaji, deÉĄĖķeote mijoataÉĄĖķa nigotadi Tiro aniaa Sidom, noiigitigi niÉĄĖķijoa nigotadi toÉĄĖķoika mowo ane beyagi niÉĄĖķijo jotigide. TaÉĄĖķa nicotiniwace, odinixotinigilo lowoodi jaacogoli, codaa toÉĄĖķoyatita lojienigi lacilodi, moikee modinilaatece libeyaceÉĄĖķeco.  
\v 14 Pida niÉĄĖķica noko nige iloikatidi AneotedoÉĄĖķoji niÉĄĖķina oko leeÉĄĖķodi libeyaceÉĄĖķeco, ÉĄĖķadiloikatititetiwaji caticedi niÉĄĖķidi niÉĄĖķeladimigipitigi Tiro aniaa Sidom.  
\v 15 Odaa akaami noiigitigi Cafarnaum, domige ÉĄĖķadiweniÉĄĖķideni AneotedoÉĄĖķoji digoida ditibigimedi? OteÉĄĖķexaaÉĄĖķaÉĄĖķa onateciÉĄĖķini! Pida baÉĄĖķa ÉĄĖķadokolenitediogi minitaÉĄĖķa noledi ane daÉĄĖķa ipe, mawikodeetiwaji.â 
\p  
\v 16 Odaa Jesus jeÉĄĖķeetediogi niÉĄĖķijo anodiotibece, âNiÉĄĖķina ane wajipataÉĄĖķawatiwaji, aaÉĄĖķaÉĄĖķa najipatiwa. Codaa niÉĄĖķina ane daÉĄĖķa dibataÉĄĖķagitiwaji, Ee idaaÉĄĖķigotiwa. Odaa niÉĄĖķina ane daÉĄĖķa dibatigi, adibatege AneotedoÉĄĖķoji ane idiiÉĄĖķe.â 
\s1 NiÉĄĖķijoa seteenta liiÉĄĖķexedi Jesus ja dopitijo 
\p  
\v 17 NiÉĄĖķijoa seteenta liiÉĄĖķexedi naÉĄĖķa dopitijo, odaa eliodi me ninitibigiwaji. Odaa moditalo Jesus, âĮĪoniotagodi, codaa me niÉĄĖķinoa niwicidi abeyacaÉĄĖķaÉĄĖķa etiÉĄĖķodadiwaÉĄĖķadi niÉĄĖķina me jiticodaÉĄĖķaticoace, jibakenaÉĄĖķa ĮĪaboonaÉĄĖķadi me jiticodaÉĄĖķaticoace modakatiogi oko.â 
\p  
\v 18 Pida Jesus naÉĄĖķa igidi, meetediogi, âJinadi ÉĄĖķodaxakawa SatanÃĄs yediiÉĄĖķa menitini icoÉĄĖķotibigimece ditibigimedi, micataÉĄĖķa niÉĄĖķina nalebepaÉĄĖķa ane yediiÉĄĖķa.  
\v 19 Diganajipaatiwatiwaji! Ja jajigotaÉĄĖķawa ÉĄĖķanimaweneÉĄĖķegi me ipoditeloco lakeedi, codaa me nelÃĄ. (Odaa aÉĄĖķica anigotaÉĄĖķawa.) Codaa aÉĄĖķekeni icatawece niÉĄĖķica domaÉĄĖķa loniciwaÉĄĖķa ÉĄĖķodaxakawa, odaa aÉĄĖķica anigotaÉĄĖķawatiwaji niÉĄĖķina ane beyagi.  
\v 20 Pida jinaÉĄĖķa aniniitibecitiwaji leeÉĄĖķodi metiÉĄĖķadadiwaÉĄĖķati niwicidi abeyacaÉĄĖķaÉĄĖķa. Pida jemaa maniniitibeci leeÉĄĖķodi naÉĄĖķa iditedini AneotedoÉĄĖķoji ÉĄĖķaboonaÉĄĖķatedi digoida ditibigimedi madi lotaÉĄĖķanaÉĄĖķaxi aneite liboonaÉĄĖķatedi loiigi.â 
\s1 Jesus ninitedibece 
\r (Mateus 11.25-27; 13.16-17) 
\p  
\v 21 NaÉĄĖķajo lakata Liwigo AneotedoÉĄĖķoji eo niÉĄĖķica meliodi me ninitedibece Jesus. Odaa mee, âEiodi, jaÉĄĖķakamaÉĄĖķakaami ane iiÉĄĖķeni ditibigimedi, codaa me iiÉĄĖķo, joÉĄĖķetetibigimaÉĄĖķadici, leeÉĄĖķodi jiÉĄĖķikeenitiogi niÉĄĖķina oko iwikodadi niÉĄĖķica anaÉĄĖķatitema niÉĄĖķina oko aninoa lixaketedi, codaa me niÉĄĖķina aneliodi me nidikonaÉĄĖķa. JoaniÉĄĖķidaa anakamaÉĄĖķa emaani mawii, odaa ica mele. JoaniÉĄĖķidaa leeÉĄĖķodi me iniotagodetaÉĄĖķawa.â 
\p  
\v 22 Odaa Jesus meetediogi niÉĄĖķijo oko anidi miniwataÉĄĖķa, âEiodi najigotediwa inoatawece. AÉĄĖķica ane yowooÉĄĖķodi AneotedoÉĄĖķoji Lionigi, iniokiniwateda Eliodi. AÉĄĖķica ane yowooÉĄĖķodi niÉĄĖķicoa Eliodi, iniokiniwateda Lionigi me yowooÉĄĖķodi, codaa niÉĄĖķina ane yemaa Lionigi me ikeete anodaaÉĄĖķeeteda Eliodi.â 
\p  
\v 23 Odaa Jesus ja nawiilitetetege niÉĄĖķijo anodiotibece. Odaa meetediogi niÉĄĖķica midiokiditiwage, âNinitibigiwaji niÉĄĖķina oko anonadi niÉĄĖķinoa ananatitiwaji!  
\v 24 IgaataÉĄĖķa ejitaÉĄĖķawatiwaji, niÉĄĖķijo jotigide eliodi niÉĄĖķijo anoyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko, codaa owidi inionaÉĄĖķa-eloodoli niÉĄĖķijo jotigide, domoÉĄĖķoyemaa monadi niÉĄĖķina analeeÉĄĖķanatitetiwaji, pida aÉĄĖķonadi. Codaa domoÉĄĖķoyemaa mowajipatalo niÉĄĖķinoa analeeÉĄĖķajipaatalo, pida aÉĄĖķica doÉĄĖķowajipatalo.â 
\s1 Ica samaritaano anele 
\p  
\v 25 Digawinitiwaji! Ica niiÉĄĖķaxinaÉĄĖķanaÉĄĖķa lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs, niÉĄĖķini dabiditi, odaa igeteda Jesus mina dineetalo, mee, âĮĪoniiÉĄĖķaxinoÉĄĖķodi, amiina ane leeditibige me jao, odaa ja jakadi midioka limedi me idewiÉĄĖķa miniwataÉĄĖķa AneotedoÉĄĖķoji?â  
\v 26 Jesus naÉĄĖķa igidi, meeteta, âAmiidi ica ane diniditeloco midiwa lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs? Amiidi ica baanaÉĄĖķa alomeÉĄĖķeniteloco?â 
\p  
\v 27 Odaa mee niÉĄĖķijo ÉĄĖķoneleegiwa, me igidi, âEmaani ĮĪaniotagodi AneotedoÉĄĖķoji manitawece ÉĄĖķadaaleÉĄĖķena, codaa minoatawece niÉĄĖķicoa ane eemiteetece, codaa minitawece ÉĄĖķadoniciwaÉĄĖķa, codaa minoatawece ÉĄĖķadowooko. Codaa leeditibige memaani ÉĄĖķadipecaÉĄĖķawa digo aneni madinemaani.â  
\v 28 Odaa Jesus meete, âJaÉĄĖķadigititece niÉĄĖķina anewi. Awii niÉĄĖķida anenita, odaa idioka limedi me ÉĄĖķadewiki miniwataÉĄĖķa AneotedoÉĄĖķoji.â 
\p  
\v 29 Pida niÉĄĖķijo ÉĄĖķoneleegiwa domaÉĄĖķa dinikeenaÉĄĖķaneÉĄĖķe me iÉĄĖķenaÉĄĖķa. Odaa ja digikataci, mee, âPida, amiijo ica ipecaÉĄĖķawa?â 
\p  
\v 30 Jesus naÉĄĖķa igidi, meete, âIca ÉĄĖķoneleegiwa one dinikatini manitaÉĄĖķa nigotaÉĄĖķa JerusalÃĐm, one igo JericÃģ. Naigitinece jona dakapetege icoa olicaÉĄĖķaÉĄĖķa, odaa jonoÉĄĖķonoÉĄĖķa lowoodi, codaa eliodi monalaketibige, pida noÉĄĖķoika, jona doletibige me yeleo, odaa joÉĄĖķopitibeci.  
\v 31 Pida ganigepidiÉĄĖķica niÉĄĖķijoa sacerdotitedi ane libakadi AneotedoÉĄĖķoji liÉĄĖķeladi, jonaÉĄĖķaÉĄĖķa dinikatini mijotaÉĄĖķa niÉĄĖķijo naigi. Odaa naÉĄĖķa nadi niÉĄĖķijo ÉĄĖķoneleegiwa, odaa ja nawiile, inigotinece eledi liwai niÉĄĖķijo naigi.  
\v 32 Ica leviita eledi jonaÉĄĖķaÉĄĖķa inaaÉĄĖķigotinece. NaÉĄĖķa nadi niÉĄĖķijo ÉĄĖķoneleegiwa, odaa onexaa iwiteloco, odaa jaÉĄĖķaÉĄĖķa ixomaÉĄĖķatijo.  
\v 33 Pida ica samaritaano onaÉĄĖķaÉĄĖķa diniwiaje, odaa niÉĄĖķicoteloco. NaÉĄĖķa nadi niÉĄĖķijo ÉĄĖķoneleegiwa eliodi me iwikode.  
\v 34 Odaa jona diiteloco niÉĄĖķipegi, odaa jeÉĄĖķeo liwetadi, one yatita najidi inaa viinyo niÉĄĖķicoa elaciletedi. NiÉĄĖķidiaaÉĄĖķidi ja yexaÉĄĖķateloco niÉĄĖķijo ÉĄĖķoneleegiwa nemadica, odaa jona yadeegiticogi manitaÉĄĖķa aca ÉĄĖķodiotaÉĄĖķaxi, odaa jiÉĄĖķidiaaÉĄĖķi me dowediteloco. \fig |src="CN01749B.TIF" size="span" copy="ÂĐ 1978 David C. Cook Publishing Co." ref="Lucas 10.33-34" \fig* 
\v 35 NeÉĄĖķeledi noko jona yajigota niÉĄĖķijo ane nebi naÉĄĖķaca ÉĄĖķodiotaÉĄĖķaxi iniwataale beexotedi ane loojedi modowediteloco. Odaa meeta, âAdowetiteloco, codaa nigicoa eletidi laakataka, nige idopitijo, odaa jediateda.ââ 
\p  
\v 36 Odaa Jesus jeÉĄĖķeeteta niÉĄĖķijo ÉĄĖķoneleegiwa ane ige, âAmiida ica anakati? AmepidiÉĄĖķica idi itoatadiÉĄĖķida anewi me lipecaÉĄĖķawa niÉĄĖķijo anonaxacoÉĄĖķotibige?â  
\v 37 Odaa niÉĄĖķijo ane diiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs ja igidi Jesus, mee, âNiÉĄĖķijo aneneÉĄĖķegi iwikode niÉĄĖķijo ÉĄĖķoneleegiwa, codaa me yaxawa.â Odaa Jesus jeÉĄĖķeete, âDice awii liciagi.â 
\s1 Jesus dalite Marta ajaa Maria 
\p  
\v 38 Jesus ijaaÉĄĖķijo niÉĄĖķijo anodiotibece odioteci naigi, odaa joÉĄĖķotota manitaÉĄĖķa aca nigotakawaana. Odaa aca iwaalo anodita Marta ja nodetedicogi Jesus minitaÉĄĖķa liÉĄĖķeladi.  
\v 39 Aca nioxoa anodita Maria, odaa jona dilokotege ĮĪoniotagodi Jesus, odaa ja wajipatalo niÉĄĖķicoa liiÉĄĖķaxinaÉĄĖķaneÉĄĖķeco.  
\v 40 Pida Marta baÉĄĖķa yajolitaÉĄĖķatelogo niÉĄĖķicoa libaketedi mini liÉĄĖķeladi. Odaa niÉĄĖķigo miniwataÉĄĖķa Jesus, odaa oneetalo, âIniwa-aagodi, agodaÉĄĖķana-aati, naÉĄĖķani ininyooxoa naÉĄĖķa idika moka eeyotece me jaote digawi-iinitelogo iba-aaketedi? IiÉĄĖķeni menagi idaxawanawaanigi!â 
\p  
\v 41 Pida ĮĪoniotagodi ja igidi meeteta, âNiÉĄĖķida makaami ÉĄĖķadajolitakitibece, codaa me aÉĄĖķowikomataatibece, leeÉĄĖķodi niÉĄĖķinoa anicinoa.  
\v 42 Pida leeditibige mokidatece niÉĄĖķica ÉĄĖķadoenatagi, odaa Maria baanaÉĄĖķa iomaÉĄĖķaditice niÉĄĖķica ane daÉĄĖķaxa mele, codaa aÉĄĖķica ane ibanootece.â 
\c 11  
\s1 Jesus diiÉĄĖķaxinaÉĄĖķatetece ica anodaaÉĄĖķee me jotaÉĄĖķaneÉĄĖķenaÉĄĖķa AneotedoÉĄĖķoji 
\r (Mateus 6.9-15; 7.7-11) 
\p  
\v 1 Ica noko Jesus ganigidi ica aneite me yotaÉĄĖķaneÉĄĖķe AneotedoÉĄĖķoji. Odaa naÉĄĖķa nigotedini me yotaÉĄĖķaneÉĄĖķe AneotedoÉĄĖķoji, ganigepidiÉĄĖķica niÉĄĖķijo anodiotibece dipokotalo Jesus, mee, âĮĪoniotagodi, ÉĄĖķodiiÉĄĖķaxineÉĄĖķegi me jotaÉĄĖķaneÉĄĖķenaÉĄĖķa AneotedoÉĄĖķoji, digo anee JoÃĢo Batista me iiÉĄĖķaxitiogi anodiotibeci.â 
\p  
\v 2 Odaa meetediogi, âNiÉĄĖķina motaÉĄĖķaneÉĄĖķeni AneotedoÉĄĖķoji, enitiwaji, 
\q1 âĮĪodiodi anadeoni ditibigimedi, 
\q1 jemaanaÉĄĖķa minatawece oko odoÉĄĖķeteta ĮĪaboonaÉĄĖķadi. 
\q1 JemaanaÉĄĖķa me iiÉĄĖķeni laaleÉĄĖķenali inatawece oko. 
\q1 Awii niÉĄĖķica anemaani mawii digoina iiÉĄĖķo, 
\q1 liciagi mowo anemaani digoida ditibigimedi. 
\q1  
\v 3 AnajicitoÉĄĖķowa ÉĄĖķoweenigi ane jopooÉĄĖķatibige inoatawece nokododi. 
\q1  
\v 4 IxomaÉĄĖķateenitedice ÉĄĖķobeyaceÉĄĖķeco, 
\q1 igaataÉĄĖķa niÉĄĖķida moko jixomaÉĄĖķateenaÉĄĖķatice 
\q1 niÉĄĖķina anowotoÉĄĖķodomi ane beyagi. 
\q1 Codaa jiniÉĄĖķikani daÉĄĖķa dineetoÉĄĖķowa ÉĄĖķodaxakawa. 
\q1 Pida ÉĄĖķodoÉĄĖķaaÉĄĖķegiticogi miditaÉĄĖķa loniciwaÉĄĖķa nibeyacaÉĄĖķa.ââ 
\p  
\v 5 Odaa Jesus meetediogi, âDiÉĄĖķica niÉĄĖķina akaamitiwaji anigo liÉĄĖķeladi lokaaÉĄĖķedi niÉĄĖķina me liwigo-enoale me doletibige ladiligi, oditaÉĄĖķa eeta, âYokaaÉĄĖķedi, awiitate yadilaÉĄĖķa itiwatadiÉĄĖķidi paontedi.  
\v 6 IgaataÉĄĖķa ini yokaaÉĄĖķedi gela meno me diniwiaje, pida aÉĄĖķica anigetiÉĄĖķidi ane jajigota me yeligo.â  
\v 7 Pida idei catiwedi liÉĄĖķeladi me igidi, onee, âJinaÉĄĖķawii igecaÉĄĖķaloÉĄĖķo! Ja jinoxoco yapoagi, codaa ionigipi ja niotaÉĄĖķa, aÉĄĖķalee jakadi daÉĄĖķa idicoti oditaÉĄĖķa jajigotedaÉĄĖķawa paontedi.â  
\v 8 Odaa ejitaÉĄĖķawatiwaji anicotini daÉĄĖķa leeÉĄĖķodi me lokaaÉĄĖķedi, pida yajigota ane dipokotibige, leeÉĄĖķodi jeÉĄĖķeo ligecaÉĄĖķaloÉĄĖķo me daÉĄĖķa yakamaÉĄĖķadi. 
\p  
\v 9 JoaniÉĄĖķidaa leeÉĄĖķodi mejitaÉĄĖķawatiwaji, ipokitalo AneotedoÉĄĖķoji, odaa jaÉĄĖķabaatege ane ÉĄĖķadipoketegi. Oleetibige AneotedoÉĄĖķoji niÉĄĖķina midi ananiaditibige makaamitaÉĄĖķatiwaji, odaa akatitiwaji. Atokeni epoagi, odaa domoketaÉĄĖķadomi.  
\v 10 JiÉĄĖķidaaÉĄĖķee inatawece niÉĄĖķina anodipokotalo AneotedoÉĄĖķoji, yajigotediogi anodipokotibige, codaa inatawece niÉĄĖķina anodoletibige, oyakadi. Codaa epoagi domoketema niÉĄĖķina ane yatoke.  
\v 11 Domigica ina akaamitiwaji anakaami eniododipi ane yajigota lionigi lakeedi, ina me dipokotigi noÉĄĖķojegi?  
\v 12 OÉĄĖķoa, domige ajicita nelÃĄ ina me dipokotigi okoÉĄĖķokoodi ligetegi?  
\v 13 Odaa niÉĄĖķida makaamitiwaji, anakaami abeyacaÉĄĖķaÉĄĖķa, owooÉĄĖķoti majici ÉĄĖķadionigi anele. Odaa ĮĪadiodi ane itiniwa digoida ditibigimedi daÉĄĖķaxatace me yajigotediogi Liwigo niÉĄĖķina anodipokotalo!â 
\s1 Onica ica anodi mini niwigo ane beyagi midoataÉĄĖķa Jesus 
\r (Mateus 12.22-30; Marcos 3.20-27) 
\p  
\v 14 Jesus one iticoitedice ica niwigo abeyaceÉĄĖķegi ane dakatiogi ica ÉĄĖķoneleegiwa, aneo mewaloÉĄĖķonaÉĄĖķa. NiÉĄĖķijo naÉĄĖķa noditice niÉĄĖķijo niwigo abeyaceÉĄĖķegi, odaa niÉĄĖķijo ÉĄĖķoneleegiwa jonaÉĄĖķa yakaditace me dotaÉĄĖķa. Odaa niÉĄĖķidi noiigi eliodi moyopo.  
\v 15 Pida onidi ica oko anodi, âNaÉĄĖķanati! Belzebu ane iiÉĄĖķe niwicidi abeyacaÉĄĖķaÉĄĖķa eo notoetiigi niÉĄĖķidoa ÉĄĖķoneleegiwa me iticoitedice niwicidi ane beyagi. (Belzebu aneledi liboonaÉĄĖķadi SatanÃĄs).â 
\p  
\v 16 Odaa ica eledi oko odineetalo odipokotalo meote loenatagi anodoxicetema, me ikee me icoÉĄĖķoticogi nimaweneÉĄĖķegi miniwataÉĄĖķa AneotedoÉĄĖķoji.  
\v 17 Pida Jesus yowooÉĄĖķodi lowooko, odaa meetediogi, âNiÉĄĖķijo noiigi anowotibece lapoawaanigi me dakapetibigiwage, niÉĄĖķidi noiigi icota me ma. Codaa niÉĄĖķina dinoiigiwepodi ane daÉĄĖķa ilaÉĄĖķatiwage aaÉĄĖķaÉĄĖķa icota me ma.  
\v 18 Codaa niÉĄĖķijo ane iiÉĄĖķe SatanÃĄs, nige diniomaÉĄĖķadi me dinideleÉĄĖķe, baadaÉĄĖķa yeyaÉĄĖķaticoace. Igaamee ina meni me Belzebu najigotiwa inotoetiigi me jiticoitedice niwicidi abeyacaÉĄĖķaÉĄĖķa?  
\v 19 Pida daantiÉĄĖķidaaÉĄĖķee, amiijo ane yajigotiogi notoetiigi niÉĄĖķijo anodiotibigaÉĄĖķadici moiticoitedice niwicidi abeyacaÉĄĖķaÉĄĖķa? JoaniÉĄĖķidaa leeÉĄĖķodi niÉĄĖķijo anodiotibigaÉĄĖķadici ijaaÉĄĖķoikeetaÉĄĖķawa meliodi mabataa.  
\v 20 Pida jatika loniciwaÉĄĖķa AneotedoÉĄĖķoji me jiticoitedice niwicidi abeyacaÉĄĖķaÉĄĖķa. Odaa niÉĄĖķida ikee naÉĄĖķa diiÉĄĖķenataka AneotedoÉĄĖķoji digoina ÉĄĖķadiwigotigitiwaji. 
\p  
\v 21 NiÉĄĖķina ÉĄĖķoneleegiwa loniciweÉĄĖķenigi anele manigoe, dowediteloco epaa liÉĄĖķeladi, codaa icoatawece niÉĄĖķicoa ane nepilidi dotete.  
\v 22 Pida nigicota niÉĄĖķina ane daÉĄĖķaxa me loniciweÉĄĖķenigi, odaa ja dinigaanyetece niÉĄĖķijo loniciweÉĄĖķenigi, odaa ja yadeegi icoatawece niÉĄĖķicoa likanaÉĄĖķanaÉĄĖķatedi, niÉĄĖķijoa ane nakato niÉĄĖķijo ÉĄĖķoneleegiwa loniciweÉĄĖķenigi. Odaa ja yawalace niÉĄĖķicoa latekatece niÉĄĖķijo loniciweÉĄĖķenigi. 
\p  
\v 23 NiÉĄĖķina ane daÉĄĖķa icaajo, dice yakapetegi, codaa niÉĄĖķina ane daÉĄĖķa idaxawatece me jatecoÉĄĖķotee iniwaxacocoli anilaagitedibece, odaa ja miniaa ilaagaÉĄĖķaditedibece. 
\s1 AnodaaÉĄĖķee niwigo abeyaceÉĄĖķegi mopitacicogi ane icoÉĄĖķoticogi 
\r (Mateus 12.43-45) 
\p  
\v 24 NiÉĄĖķina niwigo abeyaceÉĄĖķegi naÉĄĖķa noditicogi oko, onigotelogo nipodaÉĄĖķa ane yadilo, ane diÉĄĖķica niÉĄĖķeladimigipi, doletibige ane lotokaÉĄĖķadi. NiÉĄĖķina naÉĄĖķa diÉĄĖķica yakadi, odaa meetibige le, âJopitacicogi iÉĄĖķeladi ane idoditicogi.â  
\v 25 Odaa joÉĄĖķopitaceloco niÉĄĖķijo oko, anakaaÉĄĖķijo me dakatiogi, odaa yakadi me micataÉĄĖķa niÉĄĖķina diimigi ane dinoladitice, codaa anoyoetibigo.  
\v 26 Odaa ja noditice, odaa igotiogi eletidi seete niwicidi abeyacaÉĄĖķaÉĄĖķa, niÉĄĖķidiwa daÉĄĖķaxa me beyagi caticedi niÉĄĖķijo odoejegi. NoÉĄĖķodakatiogi niÉĄĖķini ÉĄĖķoneleegiwa, odaa jiÉĄĖķidiaaÉĄĖķiticoace. Odaa niÉĄĖķica anee niÉĄĖķijo ÉĄĖķoneleegiwa ja daÉĄĖķaxa me beyagi caticedi niÉĄĖķijo anee maleekoka dakatiogi niÉĄĖķijo niwigo abeyaceÉĄĖķegi.â 
\s1 NiÉĄĖķica anepeÉĄĖķewi me ninitibece 
\p  
\v 27 EÉĄĖķidaaÉĄĖķeeteda me dotaÉĄĖķa Jesus, aca iwaalo ane idei liwigotigi niÉĄĖķidi noiigi mee, niÉĄĖķina me dinigetaÉĄĖķatee me yotaÉĄĖķaneÉĄĖķe Jesus, âNinitibece naÉĄĖķaca iwaalo ane dinigajetaÉĄĖķadici, codaa ane ÉĄĖķadilipeÉĄĖķeni!â  
\v 28 Pida Jesus naÉĄĖķa igidi, meete, âDaÉĄĖķaxa me ninitibigiwaji niÉĄĖķijo anowajipatalo AneotedoÉĄĖķoji lotaÉĄĖķa, codaa moyiwaÉĄĖķadi.â 
\s1 Odipokotalo Jesus meote loenataka ÉĄĖķodoxiceÉĄĖķetedi me ikee anijoa 
\r (Mateus 12.38-42; 16.1-4) 
\p  
\v 29 NiÉĄĖķijo noiigi naÉĄĖķa diniligice, moyawiile Jesus, odaa jona dotaÉĄĖķa onee, âNiÉĄĖķina noiigi niÉĄĖķinoa nokododi daÉĄĖķaxa me abeyacaÉĄĖķaÉĄĖķa. Odipokotalo AneotedoÉĄĖķoji meote ÉĄĖķodoxiceÉĄĖķedi me ikee me niÉĄĖķiniaa idiiÉĄĖķe. Pida AneotedoÉĄĖķoji aÉĄĖķeote eledi loenatagi, igaataÉĄĖķa jeÉĄĖķeote niÉĄĖķijo anigote Jonas niÉĄĖķijo jotigide, niÉĄĖķijo ane yeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko.  
\v 30 IgaataÉĄĖķa Jonas ikeetiogi niÉĄĖķeladimigipitigi NÃ­nive miniaaÉĄĖķiniwa AneotedoÉĄĖķoji iiÉĄĖķe migo naÉĄĖķani nigotaÉĄĖķa, odaa joÉĄĖķoyowooÉĄĖķodi niÉĄĖķicoa ane ninyaco Jonas. JiÉĄĖķidaaÉĄĖķeji Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, idinikeetiogi niÉĄĖķina noiigi me idiiÉĄĖķe AneotedoÉĄĖķoji.  
\v 31 NaÉĄĖķajo iniona-eloodo ane icoÉĄĖķoticogi micataÉĄĖķa niocodi niwetaÉĄĖķa, icoÉĄĖķoticogi ditigedi enagi me wajipatalo lotaÉĄĖķa SalomÃĢo, niÉĄĖķijo aninoa owidi lixaketedi. Odaa niÉĄĖķica noko nige limedi AneotedoÉĄĖķoji me iloikatidi oko leeÉĄĖķotedi libeyaceÉĄĖķeco, ajaaÉĄĖķajo naÉĄĖķajo iwaalo dabiditini, ikee me abataatiwaji, igaataÉĄĖķa ite Ee ÉĄĖķadiwigotigitiwaji ane daÉĄĖķaxa me inoa ixaketedi caticedi SalomÃĢo. Pida aÉĄĖķemaani mabaategetiwaji inoa yotaÉĄĖķa, oteÉĄĖķexaaÉĄĖķaÉĄĖķa adinilaanitibece.  
\v 32 NiÉĄĖķijo noÉĄĖķowajipatalo Jonas lotaÉĄĖķa niÉĄĖķijo niÉĄĖķeladimigipitigi NÃ­nive, odaa joÉĄĖķodinilaatece libeyaceÉĄĖķeco. Odaa niÉĄĖķica noko nige limedi AneotedoÉĄĖķoji me iloikatidi oko leeÉĄĖķotedi libeyaceÉĄĖķeco, odaa niÉĄĖķeladimigipitigi NÃ­nive dabiditiniwace, oikee makaami nilaagetedipi, igaataÉĄĖķa ite Ee ÉĄĖķadiwigotigitiwaji, codaa yotaÉĄĖķa daÉĄĖķaxa me ÉĄĖķoneÉĄĖķaÉĄĖķa aliciaco lotaÉĄĖķa Jonas. Pida akaamitiwaji aÉĄĖķabaatege inoa yotaÉĄĖķa, codaa aÉĄĖķadinilaanitibecetiwaji. 
\s1 NiÉĄĖķica ane nalo catiwedi ÉĄĖķodaaleÉĄĖķena 
\r (Mateus 5.15; 6.22-23) 
\p  
\v 33 AÉĄĖķica ini oko ane yalegi loledaÉĄĖķaxi oditaÉĄĖķa yapoÉĄĖķoditini, domigetaÉĄĖķa yapoÉĄĖķoditeloco baxia. Pida ideyate loledaÉĄĖķaxi ditibigimedi, eotibige minatawece oko anodakatiwece diimigi onadi liwitiigi.  
\v 34 NiÉĄĖķinoa ligecooÉĄĖķe niÉĄĖķina oko micataÉĄĖķa daÉĄĖķa lokokenatema laaleÉĄĖķena. NiÉĄĖķinoa ligecooÉĄĖķe nigele, odaa anitawece laaleÉĄĖķena nalo. Pida nige deÉĄĖķeleteda ligecooÉĄĖķe, laaleÉĄĖķena idaaÉĄĖķee, idei nexocaÉĄĖķa.  
\v 35 Pida anidakitiwaji, amaleeÉĄĖķaÉĄĖķa naÉĄĖķani lokokena anani makaamitaÉĄĖķatiwaji adinanatigi me nexocaÉĄĖķa.  
\v 36 Niganitawece ÉĄĖķadaaleÉĄĖķena nolee lokokena, oteÉĄĖķexaaÉĄĖķaÉĄĖķa idei nexocaÉĄĖķa, odaa atale macataÉĄĖķa naÉĄĖķana lokokena me nalo catiwedi ÉĄĖķadaaleÉĄĖķena.â 
\s1 Jesus eetedeloco icoa fariseutedi icaaÉĄĖķicoa anodiiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs 
\r (Mateus 23.1-36; Marcos 12.38-40) 
\p  
\v 37 NaÉĄĖķa nigotedini Jesus me dotaÉĄĖķa, odaa ica fariseu jonaÉĄĖķa node migo aniodi liÉĄĖķeladi. Odaa Jesus joniÉĄĖķigo, odaa jona nicotedi maditaÉĄĖķa aca nameeja.  
\v 38 NiÉĄĖķijo naÉĄĖķa nadi niÉĄĖķijo fariseu Jesus me diÉĄĖķica daÉĄĖķa aniwilegi ane lakatigi codaaÉĄĖķanioditeda, eliodi me yopo.  
\v 39 Odaa ĮĪoniotagodi oneete, âNiÉĄĖķida makaamitiwaji anakaami fariseutedi, inoka iwileci ÉĄĖķanigoopa, ÉĄĖķaniÉĄĖķinogo wetice. (Odaa idaÉĄĖķaÉĄĖķa enitiwaji aniwileci me wetice.) Pida catiwedi ÉĄĖķadaaleÉĄĖķena, inokemaani molice, codaa mawii ane beyagi.  
\v 40 Akaami yetoledi! IgaataÉĄĖķa AneotedoÉĄĖķoji jiÉĄĖķijaa eote wetice, codaa me yoe catiwedi.  
\v 41 Pida daÉĄĖķajicitiogi madewetedi ÉĄĖķaweenigi ane nolee ÉĄĖķaniÉĄĖķinogo, ÉĄĖķanigoopatiwaji. Odaa inoatawece yapiditedaÉĄĖķadomitiwaji. 
\p  
\v 42 AneotedoÉĄĖķoji ÉĄĖķadiloikatititetiwaji anakaami fariseutedi! IgaataÉĄĖķa ajicitalo liwai ÉĄĖķadawodigijedi ane ÉĄĖķanidiizimo, âhortelÃĢâ, âarrudaâ, codaa meletidi niale-laamotiidi ane jelicaÉĄĖķa. Pida niÉĄĖķida makaamitiwaji aÉĄĖķoleetibige makaami eletema eledi oko, codaa aÉĄĖķemaanitiwaji AneotedoÉĄĖķoji. Leeditibige makaami eletema eledi oko, codaa memaani AneotedoÉĄĖķoji, codaa niÉĄĖķinoa anicinoa eletidi ajicitalo AneotedoÉĄĖķoji. 
\p  
\v 43 AneotedoÉĄĖķoji ÉĄĖķadiloikatititetiwaji anakaami fariseutedi! LeeÉĄĖķodi daÉĄĖķaxa me ÉĄĖķademaanigitiwaji manicooteloco nibaanco niÉĄĖķina oko anida naÉĄĖķatetigi midiwa niiakanaÉĄĖķaxiidi, codaa ÉĄĖķademaanigi modeemitetibigaÉĄĖķaji metiÉĄĖķadiceni miditaÉĄĖķa ane licooÉĄĖķaditibece oko me dakapetibigiwage.  
\v 44 AneotedoÉĄĖķoji ÉĄĖķadiloikatititetiwaji anakaami fariseutedi, codaa makaamitiwaji ane iiÉĄĖķaxinaÉĄĖķanitece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs, oko ane daÉĄĖķa dinikee niÉĄĖķica anee. ĮĪadiciagitiwaji niÉĄĖķina anonaligite ÃĐmeÉĄĖķegi, pida ayeloÉĄĖķo, odaa niÉĄĖķina oko odaÉĄĖķaxatibigeloco, pida aÉĄĖķoyowooÉĄĖķodi midi.â 
\p  
\v 45 Odaa ica ane diiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs jona igidi Jesus, oneetalo, âĮĪoniiÉĄĖķaxinoÉĄĖķodi, niÉĄĖķina mawii niÉĄĖķida ÉĄĖķagegi, jaÉĄĖķaÉĄĖķa enitoÉĄĖķoloco.â  
\v 46 Jesus oneeteta, âAneotedoÉĄĖķoji aaÉĄĖķaÉĄĖķa ÉĄĖķadiloikatititetiwaji ane iiÉĄĖķaxinaÉĄĖķanitece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs. LeeÉĄĖķodi micataÉĄĖķa daÉĄĖķawii loyaÉĄĖķagi eledi oko, leeÉĄĖķodi maÉĄĖķaxakeni ÉĄĖķadiiÉĄĖķaxinaÉĄĖķaneÉĄĖķeco, niÉĄĖķinoa ane iwaaÉĄĖķadi, ane daÉĄĖķadiaa domiÉĄĖķica anabotege. Pida akamaÉĄĖķakaamitiwaji aÉĄĖķaxawani niÉĄĖķina oko moyotete icoa ÉĄĖķadiiÉĄĖķaxinaÉĄĖķaneÉĄĖķeco daÉĄĖķa micataÉĄĖķa madoti maxawanitiwaji me yadeegi loyaÉĄĖķagi. 
\p  
\v 47 AneotedoÉĄĖķoji ÉĄĖķadiloikatititetiwaji leeÉĄĖķodi miwilaniteloco aniwote niÉĄĖķijo anoyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko naijedi ÉĄĖķaditacepodi niÉĄĖķijo jotigide. AkamaÉĄĖķakaamitiwaji jiÉĄĖķiwilaniteloco niÉĄĖķinoa libecoli manalakitibige.  
\v 48 NiÉĄĖķina miwilaniteloco niÉĄĖķinoa libecoli, jiÉĄĖķikeenitiwaji maniwotitema anee niÉĄĖķijo jotigide, niÉĄĖķijo noÉĄĖķonigodi niÉĄĖķijo anoyeloÉĄĖķoditedibece lowooko AneotedoÉĄĖķoji. Odaa natigide jiÉĄĖķiwilani aniwote, codaa jaÉĄĖķawii me libinienigi.  
\v 49 JoaniÉĄĖķidaa leeÉĄĖķodi AneotedoÉĄĖķoji ane daÉĄĖķaxa niÉĄĖķica lowooÉĄĖķotakaneÉĄĖķegi, meete, âJiwakateetiogi niÉĄĖķidi noiigi anoyeloÉĄĖķoditedibece yowooko, codaa niÉĄĖķina ane jiiÉĄĖķetibigiwaji mowo ibakedi. Odaa niÉĄĖķidi noiigi idi anonigodi, idiaaÉĄĖķeledi oiatetibeci niÉĄĖķidi anoyeloÉĄĖķoditedibece yowooko.â  
\v 50 Odaa leeÉĄĖķodi niÉĄĖķida niciagi, AneotedoÉĄĖķoji icota me iloikatidi niÉĄĖķina noiigi niÉĄĖķinoa nokododi, leeÉĄĖķodi ijotawece niÉĄĖķijo anoyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko ane nigo, niÉĄĖķijo maleekoka yoeteda niÉĄĖķina iiÉĄĖķo.  
\v 51 Abel, jiÉĄĖķijaa odoejegi anoyeloadi, codaa me eletidi anonigodi, odaa owidijegi anoyeloadi Zacarias digoida lagitege nameeja wetiÉĄĖķa minitaÉĄĖķa niÉĄĖķijo eledi diimigi-le aneitedice AneotedoÉĄĖķoji. EjitaÉĄĖķawatiwaji mewi micota me iloikatidi AneotedoÉĄĖķoji niÉĄĖķina noiigi aninaa niÉĄĖķinoa nokododi, leeÉĄĖķodi lemeÉĄĖķegi niÉĄĖķijo liotagipi. 
\p  
\v 52 AneotedoÉĄĖķoji icota me ÉĄĖķadiloikatititetiwaji ane iiÉĄĖķaxinaÉĄĖķanitece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs. IgaataÉĄĖķa ÉĄĖķadiciagitiwaji niÉĄĖķina ane noxoco lapoagi liÉĄĖķeladi, odaa aika oko me dakatiobece. JoaniÉĄĖķidaaÉĄĖķenitiwaji aÉĄĖķikani oko moyowooÉĄĖķodi anodaaÉĄĖķee moyakadi migotibeci lodoe AneotedoÉĄĖķoji, pida oteÉĄĖķexaaÉĄĖķaÉĄĖķa akaamitiwaji aÉĄĖķemaani makaatiobece.â 
\p  
\v 53 NiÉĄĖķijo Jesus naÉĄĖķa noditedice, odaa niÉĄĖķijo anodiiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs ijaaÉĄĖķijoa fariseutedi joÉĄĖķoyalomeÉĄĖķe. Odaa eliodi moyelatema, codaa eliodi monigetedice.  
\v 54 DomoÉĄĖķodoletibige daÉĄĖķa dibatÃĄ niÉĄĖķina me dotaÉĄĖķa, domoÉĄĖķowo moyakadi me nilaagedi. 
\c 12  
\s1 Jesus yalaÉĄĖķate ica oko ane lemaanigi me yeloÉĄĖķo, pida ayeloÉĄĖķo 
\r (Mateus 10.26-27) 
\p  
\v 1 Icoa fariseutedi onigetedice Jesus, odaa eliodi oko yatecoÉĄĖķo codaa joÉĄĖķoipoditibigeloco eledi. Odaa Jesus ja yajoitediogi niÉĄĖķidi anodiotibece, meetediogi, âOnexaa anidakitiogi fariseutedi anoyotete ane beyagi catiwedi laaleÉĄĖķena, ane ibeyacaÉĄĖķadi lewiÉĄĖķa. Liciagi niÉĄĖķina labookojegi leyeema ane idei catiwedi paon, ajinataÉĄĖķa, pida eo me dabo.  
\v 2 Inoatawece ane dinapoÉĄĖķoditedini, icota me dinowiegi, codaa inoatawece anoyowiegitelogo, icota me jowooÉĄĖķotaÉĄĖķa.  
\v 3 JoaniÉĄĖķidaaÉĄĖķee ijoatawece ane ÉĄĖķadotaÉĄĖķa digoida nexocaÉĄĖķa, icota me jajipaaÉĄĖķatalo digoina getaÉĄĖķa. Inoatawece icoa ÉĄĖķadotaÉĄĖķa ane domaÉĄĖķa aÉĄĖķatitedini catiwedi diimigi-le ane dinoxoco, icota nigidiaaÉĄĖķidi oyatemati owotibige minatawece oko owajipatalo. 
\s1 Ica ane leeditibige me idoiiÉĄĖķa 
\r (Mateus 10.28-31) 
\p  
\v 4 EjitaÉĄĖķawa yokaaÉĄĖķetedi, anaÉĄĖķadoiita niÉĄĖķina ane yakadi me yeloadi ÉĄĖķadolaadi, leeÉĄĖķodi aÉĄĖķalee yakadi meo eledi anigotaÉĄĖķawa.  
\v 5 Pida jeloÉĄĖķoditaÉĄĖķawatiwaji anepaÉĄĖķa leeditibige madoiita. Adoiitalo AneotedoÉĄĖķoji anepiÉĄĖķida loniciwaÉĄĖķa me ÉĄĖķadokolenitedicogi minitaÉĄĖķa noledi ane daÉĄĖķa ipe, nigicota me yaaÉĄĖķadi ÉĄĖķadewiÉĄĖķa. JopitacaÉĄĖķalocotiwaji mejitaÉĄĖķawa, adoiitalo niÉĄĖķiniwa anejitedaÉĄĖķawa. 
\p  
\v 6 NiÉĄĖķina moyaa ciinco imikola, aÉĄĖķicoda loojedi, loojedi iniwataale beexotedi. Pida AneotedoÉĄĖķoji idokee ayaagiditedibige otaÉĄĖķanitece imikola.  
\v 7 Eleditace jemaa mejitaÉĄĖķawa AneotedoÉĄĖķoji me yowooÉĄĖķodi ane liwokodi ÉĄĖķadamodi aneitigi ÉĄĖķadacilo. Enice jinaÉĄĖķadoiitiwaji, igaataÉĄĖķa daÉĄĖķaxa meliodi ÉĄĖķaniwalÃģ, aÉĄĖķadiciagitiwaji niÉĄĖķijoa imikola anowidi. 
\s1 NiÉĄĖķica oko anida aneetege Jesus, icaaÉĄĖķica ane diÉĄĖķica aneetege 
\r (Mateus 10.32-33; 12.32; 10.19-20) 
\p  
\v 8 EjitaÉĄĖķawatiwaji niÉĄĖķina oko anee lodoe eledi oko mida anejitege, odaa Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, eji lodoe niaanjotedi AneotedoÉĄĖķoji mewi mida anejitege.  
\v 9 Pida niÉĄĖķina oko ane dinaÉĄĖķaditi lodoe eledi oko mida anejitege, odaa Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, aaÉĄĖķaÉĄĖķa eji lodoe AneotedoÉĄĖķoji codaa me aanjotedi mewi me diÉĄĖķica anejitege.  
\v 10 NiÉĄĖķina ane beyagi me dotaÉĄĖķatibigiji, Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, AneotedoÉĄĖķoji baÉĄĖķa yakadi me ixomaÉĄĖķateetedice loenataka ane beyagi, nige dinilaatece libeyaceÉĄĖķeco. Pida niÉĄĖķina ane beyagi me dotaÉĄĖķatibige AneotedoÉĄĖķoji Liwigo, AneotedoÉĄĖķoji baadaÉĄĖķa ixomaÉĄĖķateetedice loenataka ane beyagi.  
\v 11 NiÉĄĖķina nigetiÉĄĖķadadeegi metiÉĄĖķadalomeÉĄĖķeni midiwataÉĄĖķa liiakanaÉĄĖķaxiidi judeutedi, oÉĄĖķoa, domige lodoe ÉĄĖķoniwinoÉĄĖķododi idiaa lacilodi judeutedi, jinaÉĄĖķa aÉĄĖķowikomataa leeÉĄĖķodi me doÉĄĖķowooÉĄĖķoti me ojetee oteÉĄĖķexaaÉĄĖķaÉĄĖķa owooÉĄĖķoti magitatakani.  
\v 12 IgaataÉĄĖķa naÉĄĖķani lakata, AneotedoÉĄĖķoji Liwigo ikeetaÉĄĖķawa niÉĄĖķica ane leeditibige me ÉĄĖķagegi.â 
\s1 Ica liico ane liciagi niÉĄĖķina yetole ane diÉĄĖķica liwaxinigi 
\p  
\v 13 Ica ÉĄĖķoneleegiwa anidiaaÉĄĖķi liwigotigi niÉĄĖķidi noiigi-nelegi meetalo Jesus, âĮĪoniiÉĄĖķaxinoÉĄĖķodi, adiwikodeni, iiÉĄĖķeni inioxoa me iniwaiÉĄĖķawatece niÉĄĖķidiwa ane nenyaÉĄĖķaditedoÉĄĖķodomi ijoolatibige ÉĄĖķodiodi.â  
\v 14 Pida Jesus meeteta, âYokaaÉĄĖķedi, amiijo ica aneetaÉĄĖķawa me Ee ÉĄĖķaniwinoÉĄĖķodi, oÉĄĖķoa amiijo ica aneo me Ee ÉĄĖķadacilo me jawalace icoa ÉĄĖķanepilidi?â  
\v 15 Odaa Jesus meetediogi iditawece niÉĄĖķijo oko, âAtacolitecetiwaji, codaa adowetitatiwaji ineÉĄĖķewianaÉĄĖķa memaani gaantiÉĄĖķini ane nebi eledi oko. IgaataÉĄĖķa AneotedoÉĄĖķoji ayemaa me yewiÉĄĖķatema niÉĄĖķina oko minokina me dinigaanyetece niliicaÉĄĖķajetegi niÉĄĖķina iiÉĄĖķo.â 
\p  
\v 16 Odaa Jesus ja yatemati ica natematigo ane ÉĄĖķodiiÉĄĖķaxi, meetediogi, âIca ÉĄĖķoneleegiwa liico, onidiwa icoa lixoÉĄĖķotaka anoyajigo owidi nawodigijedi.  
\v 17 Odaa meetibige le, âIgamige ele mejigotalo? IgaataÉĄĖķa aÉĄĖķica anejate niÉĄĖķinoa yawodigijedi.â  
\v 18 Odaa jeÉĄĖķeo lowoogo, mee, âJa jowooÉĄĖķodi anejigotalo, jojiketedi niÉĄĖķinoa idiimaÉĄĖķa nelecoli aneite me jotete yawodigijedi, odaa jaotace geladi diimaÉĄĖķa daÉĄĖķaxatace me nelecoli, odaa ja jotete niÉĄĖķinoa yawodigijedi ela. Odaa catiwedi idiimaÉĄĖķa geladi jotete idiwatawece yawodigijedi codaa me niÉĄĖķinoa eletidi ane inepilidi.â  
\v 19 Odaa meetibige le, âNige jotete idiwatawece ane jopotigi me jixomaÉĄĖķateetedice owidi nicaaÉĄĖķape. Odaa ja inipetini, ele me jiniodi, jacipe, jaote icoa ane inikeco.â  
\v 20 Pida AneotedoÉĄĖķoji meeteta, âNiÉĄĖķida makaami, akaami yetole! IgaataÉĄĖķa inaaÉĄĖķina niÉĄĖķina enoale ja ÉĄĖķadelewi. Odaa amiijo ica aneote nepilidi idiwatawece icoa ÉĄĖķadotetenataka?â  
\v 21 JoaniÉĄĖķidaaÉĄĖķee niÉĄĖķina oko ane nioda niliicaÉĄĖķajetecidi niÉĄĖķina iiÉĄĖķo, lodoe AneotedoÉĄĖķoji baadaÉĄĖķa liico.â 
\s1 Leeditibige me jinakatonaÉĄĖķa AneotedoÉĄĖķoji 
\r (Mateus 6.25-34) 
\p  
\v 22 Odaa Jesus meetediogi anodiotibece, âJoaniÉĄĖķidaa mejitaÉĄĖķawatiwaji jinaÉĄĖķa ÉĄĖķadigecaÉĄĖķaleÉĄĖķeni niweenigi anopootibige me ÉĄĖķadewiki, oteÉĄĖķexaaÉĄĖķaÉĄĖķa ÉĄĖķadowoodaÉĄĖķagi anopootibige madinixomitinigi.  
\v 23 IgaataÉĄĖķa ÉĄĖķadiwigo daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi aliciagi niweenigi. ĮĪadolaadi daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi aliciagi nowoodaÉĄĖķagi.  
\v 24 Digawini ilaaÉĄĖķaxodi! AÉĄĖķenanaÉĄĖķanaÉĄĖķa, oteÉĄĖķexaaÉĄĖķaÉĄĖķa onioda liweenaÉĄĖķa. Codaa aÉĄĖķica lidiimigi anoyate liweenaÉĄĖķa moyotete. Pida AneotedoÉĄĖķoji idokee me yajigotediogi liweenigi. Pida akaamitiwaji daÉĄĖķaxa makaami ÉĄĖķoneÉĄĖķegi caticedi niÉĄĖķinoa ilaaÉĄĖķaxodi.  
\v 25 Amiijo ina akaamitelocotiwaji ane yakadi me iigitedice nokododi me yewiÉĄĖķa, leeÉĄĖķodi ÉĄĖķadoÉĄĖķowikomatiigitiwaji?  
\v 26 Enice nige daÉĄĖķakati mawii ÉĄĖķadoenatagi lionicawaanigi, igame leeÉĄĖķoditiwaji ina me ÉĄĖķadigecaÉĄĖķaleÉĄĖķeni inoa eletidi ane daÉĄĖķaxa me dakake? 
\p  
\v 27 Digawini niÉĄĖķinoa niale lawoÉĄĖķo libinienaÉĄĖķa! AnibaaÉĄĖķa, aÉĄĖķoyoe lipegeteÉĄĖķe. Pida ejitaÉĄĖķawatiwaji ijaaÉĄĖķijo SalomÃĢo midiwatawece ane niliicaÉĄĖķajetecidi, pida aÉĄĖķica daÉĄĖķa dinixotinigilo nowoodi libinienaÉĄĖķa daÉĄĖķa naÉĄĖķaxatelogo niÉĄĖķinoa niale lawoÉĄĖķo.  
\v 28 AneotedoÉĄĖķoji eote nadegogo micataÉĄĖķa diÉĄĖķinoa lowoodi libinienaÉĄĖķa. Nadegogo ane ili niÉĄĖķina noko, natiinigoi joÉĄĖķoyalegi. Odaa ajawienataka me yajigotedaÉĄĖķawa ÉĄĖķadowoodi anele, akaamitiwaji ane deÉĄĖķeliodi ÉĄĖķatiwaÉĄĖķatakaneÉĄĖķegi. 
\p  
\v 29 Enice jinaÉĄĖķa adinigecaÉĄĖķaloÉĄĖķotiti, diÉĄĖķidokee moleetibige me ÉĄĖķadigecaÉĄĖķaleÉĄĖķeni niÉĄĖķica anelici, codaa anacipeta.  
\v 30 IgaataÉĄĖķa noiigi anida aneetege niÉĄĖķina iiÉĄĖķo idokee modoletibige inoatawece niÉĄĖķinoa anicinoa. LeeÉĄĖķodi ĮĪadioditetiwaji AneotedoÉĄĖķoji yowooÉĄĖķodi inoatawece niÉĄĖķicoa anopootibige.  
\v 31 Enice jinaÉĄĖķa ÉĄĖķadigecaÉĄĖķaloÉĄĖķotiti niÉĄĖķinoa ganicinoa, pida odoejegi oleetibige mawii AneotedoÉĄĖķoji me iiÉĄĖķe laaleÉĄĖķenali oko, odaa AneotedoÉĄĖķoji jaÉĄĖķaÉĄĖķa yajigotedaÉĄĖķawa inoatawece anopootibige. 
\s1 NiÉĄĖķicoa niliicaÉĄĖķajetecidi niÉĄĖķica ditibigimedi 
\r (Mateus 6.19-21) 
\p  
\v 32 Akaami yoiigi anakaami onateciÉĄĖķidi, jinaÉĄĖķadoii. IgaataÉĄĖķa ĮĪadiodi AneotedoÉĄĖķoji yakadi mele meote makaami lacilodi niÉĄĖķina loiigi.  
\v 33 Aani niÉĄĖķicoa ane ÉĄĖķanepilidi, odaa anedianitiniwace madewetedipi dinyeelo. Oleetibige ÉĄĖķanaÉĄĖķaaÉĄĖķaxi ane daÉĄĖķa daa, odaa oteteni ÉĄĖķaniliicaÉĄĖķajetecidi digoida ditibigimedi, aneite me daÉĄĖķadiaa daa. IgaataÉĄĖķa digoida ditibigimedi oliceÉĄĖķegi aÉĄĖķicoticogi me dolice, oteÉĄĖķexaaÉĄĖķaÉĄĖķa ipilaÉĄĖķawaana aÉĄĖķaca daÉĄĖķa yaaÉĄĖķadi.  
\v 34 IgaataÉĄĖķa aneite ÉĄĖķaniliicaÉĄĖķajetecidi, jiÉĄĖķidiaa yemaa ÉĄĖķadaaleÉĄĖķenalitiwaji me onite. 
\s1 Icoa niotaka ane nigomaÉĄĖķatema okanicodaaÉĄĖķica 
\p  
\v 35 Leeditibige madinoetitiwaji me ÉĄĖķadigomitema okanicodaaÉĄĖķica gaantiÉĄĖķica anenagi, ipiciati ÉĄĖķanigoenaÉĄĖķadi, codaa aleci ÉĄĖķadoledaÉĄĖķaxiidi.  
\v 36 Awii liciagi niÉĄĖķijoa niotaka anowalitibigege necalailegi me icoÉĄĖķoticogi miditaÉĄĖķa nadoneÉĄĖķegi. Nige yatoke epoagi me doletibige me dakatio, odaa aleegi joÉĄĖķoyomoketege.  
\v 37 NiÉĄĖķijoa niotaka ane icotiogi necalailegi malee niwotaÉĄĖķa, ane nigomaÉĄĖķa modibatema, odaa ninitibigiwaji niÉĄĖķijoa niotaka. EjitaÉĄĖķawatiwaji, niÉĄĖķijo necalailegi diniikoaÉĄĖķe, iikoaÉĄĖķe lowoodi me nediatiniwace, odaa ja iiÉĄĖķe me nicotiniwace madi nameeja, odaa epaa noÉĄĖķatema liweenigi.  
\v 38 Eleditace deÉĄĖķeno me liwigo enoale, migetaÉĄĖķa iniwatadaÉĄĖķani lakata me nigoitijo, idokee micotiogi me niwotaÉĄĖķa, idokee me nigomaÉĄĖķa me nibaaÉĄĖķa, odaa ninitibigiwaji niÉĄĖķijoa niotaka.  
\v 39 Pida leeditibige mowooÉĄĖķotitiwaji niÉĄĖķina niÉĄĖķeladimigi daÉĄĖķa yowooÉĄĖķodi naÉĄĖķaca lakata micotio oliceÉĄĖķegi, odaa agotaÉĄĖķa ika me yawime liÉĄĖķeladi me dolice.  
\v 40 Odaa niÉĄĖķida makaamitiwaji leeditibige me ÉĄĖķadigomi, igaataÉĄĖķa Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, janotaÉĄĖķawatiwaji naÉĄĖķaca lakata maleedaÉĄĖķa anibeoonitege me yanokegi.â 
\s1 Ica niotagi ane yakadi me jinakatonaÉĄĖķa, icaaÉĄĖķica ane daÉĄĖķa yakadi me jinakatonaÉĄĖķa 
\r (Mateus 24.45-51) 
\p  
\v 41 Odaa Pedro ja ige Jesus, meetalo, âĮĪoniotagodi, okomokoko manatematiitoÉĄĖķowa ica natematigo ane ÉĄĖķodiiÉĄĖķaxi, oÉĄĖķoa, aaÉĄĖķaÉĄĖķa atematiitiogi inatawece oko?â 
\p  
\v 42 ĮĪoniotagodi naÉĄĖķa igidi, meeteta, âAmiijo ica liciagi niÉĄĖķijo niotagi ane yakadi me jinakatonaÉĄĖķa, aninoa lixaketedi? Necalailegi nenyaÉĄĖķaditini me yowie niÉĄĖķicoa eletidi niotaka, codaa me yediatece liweenigi me ditibigimedi lakata.  
\v 43 Odaa niÉĄĖķijo niotagi aneo idiwatawece niÉĄĖķicoa necalailegi ane nenyaÉĄĖķaditini me libaketedi, nigeno necalailegi, niÉĄĖķijo niotagi eliodi me ninitibece.  
\v 44 EjitaÉĄĖķawatiwaji mewi mepaanaÉĄĖķa ixotio necalailegi me doweditelogo icoatawece ane nepilidi.  
\v 45 Pida niÉĄĖķijo niotagi daÉĄĖķa eledi lowoogo, oditaÉĄĖķa dotaÉĄĖķatigi le, deÉĄĖķee, âInecalailegi ja leegi aniÉĄĖķica me dopitijoâ, oditaÉĄĖķa ja nalaketiniwace niÉĄĖķijoa eletidi niotaka, daÉĄĖķa daÉĄĖķaxa me aniodi, wacipe, yemaÉĄĖķatibece.  
\v 46 Odaa necalailegi niÉĄĖķijo niotagi dopitijo niÉĄĖķina me daÉĄĖķadiaa nibeotege, naÉĄĖķaca aligeÉĄĖķe me daÉĄĖķadiaa yowooÉĄĖķodi. Odaa necalailegi taÉĄĖķa nakagiditibige eote liwailidawaanaÉĄĖķa. Odaa joaniÉĄĖķidaaÉĄĖķee niÉĄĖķijo niotagi oiloikatidi nigepaa anigicatibige, oyawanaÉĄĖķaditege niÉĄĖķina ane doÉĄĖķoyiwaÉĄĖķaditeda AneotedoÉĄĖķoji. 
\p  
\v 47 NiÉĄĖķina niotagi ane yowooÉĄĖķodi necalailegi ane yemaa, pida adinoe, aÉĄĖķeo necalailegi ane yemaa, icota meliodi monalaketibige.  
\v 48 Pida niÉĄĖķijo eledi niotagi ane daÉĄĖķa yowooÉĄĖķodi ica necalailegi ane yemaa, diba, pida beyagi libaketedi, odaa idokee me leeditibige me dinalake, pida onateciÉĄĖķini me dinaxacoÉĄĖķo. AneotedoÉĄĖķoji idaaÉĄĖķee, eliodi me ipiciadi niÉĄĖķina oko aneliodi ane yajigote. Codaa me walitetege me dibatetege me naÉĄĖķaxataceloco ane liwokodi niÉĄĖķina anowidi me yajigote. 
\s1 Ina oko dawalacetiwage leeÉĄĖķodi Jesus 
\r (Mateus 10.34-36) 
\p  
\v 49 Janagi niÉĄĖķina iiÉĄĖķo micataÉĄĖķa niÉĄĖķina oko ane dÃĄloÉĄĖķo me yalegi nipodigi, codaa eliodi me jemaatibige doÉĄĖķodaa yabidi ane jalegi.  
\v 50 Leeditibige meliodi me jawikode. JoaniÉĄĖķidaa leeÉĄĖķodi eliodi me joÉĄĖķowikomata nigepaa enotiloco niÉĄĖķida niciagi.  
\v 51 Migaleetibigetiwaji daÉĄĖķa janagi niÉĄĖķina iiÉĄĖķo daÉĄĖķa jaotibige niÉĄĖķina oko me daÉĄĖķadiaa nidelaÉĄĖķa? AniÉĄĖķidaa ibakedi me janagi. Pida ejitaÉĄĖķawatiwaji ane leeÉĄĖķodi me janagi, jaotibige oko me dawalacetiwage.  
\v 52 IgaataÉĄĖķa diÉĄĖķidi ciinco oko dinoiigiwepodi icota me dawalacetiwage, iniwatadiÉĄĖķini oko dakapetege iniwata oko, codaa iniwataale dakapetege iniwatadiÉĄĖķini.  
\v 53 Eniodi ja lakapetegi lionigi, nionigi jaÉĄĖķaÉĄĖķa lakapetegi eliodi; eniodo ja lakapete liona, niona ja lakapete eliodo; noxiiÉĄĖķate ja lakapete liiÉĄĖķate, niiÉĄĖķate jaÉĄĖķaÉĄĖķa lakapete loxiiÉĄĖķate.â 
\s1 NiÉĄĖķinoa ane jinataÉĄĖķa niÉĄĖķinoa nokododi ikee AneotedoÉĄĖķoji ane yoe 
\r (Mateus 16.2-3) 
\p  
\v 54 Odaa Jesus meetediogi ica noiigi, âDigoina ÉĄĖķoniiÉĄĖķotedi, niÉĄĖķina nige ica manatitece lolaadi ane icoÉĄĖķoticogi niocodi wajenaÉĄĖķa, odaaÉĄĖķeni, âNatigidawaanigi datiode!â Odaa ewi niÉĄĖķidaaÉĄĖķee.  
\v 55 Odaa niocodi nige icoÉĄĖķoticogi natinedi, odaaÉĄĖķenitiwaji, âNilÃĄÉĄĖķa!â Odaa ewi me nilÃĄÉĄĖķa.  
\v 56 OwooÉĄĖķotitiwaji anodaa diitigi ane ixomaÉĄĖķatice niÉĄĖķina iiÉĄĖķo, codaa me ditibigimedi. Enice, igaamee me doÉĄĖķowooÉĄĖķoti ica AneotedoÉĄĖķoji anigote inoa nokododi? Akaamitiwaji niÉĄĖķina anodi mowo AneotedoÉĄĖķoji ane yemaa, pida aÉĄĖķawii. 
\s1 Adinilakidenitege niÉĄĖķina ane daÉĄĖķa ÉĄĖķadilakiitege 
\r (Mateus 5.25-26) 
\p  
\v 57 Igaamee daÉĄĖķakamaÉĄĖķakaamitatiwaji awii ÉĄĖķadowoogo ane iÉĄĖķenaÉĄĖķa?  
\v 58 Nigica ane beyagi me dotaÉĄĖķatibigaÉĄĖķajitiwaji, codaa ane domaÉĄĖķa ÉĄĖķadadeegiticogi lodoe ÉĄĖķoniwinoÉĄĖķodi, oleetibige ÉĄĖķanimaweneÉĄĖķegi madinilakidenitege digoida naigitece, amaleeÉĄĖķaÉĄĖķa daÉĄĖķadiaa ÉĄĖķadadeegiticogi lodoe ÉĄĖķoniwinoÉĄĖķodi. IgaataÉĄĖķa nige daÉĄĖķadinilakidenitege, ja ÉĄĖķadajicita iodaÉĄĖķawadi libaaÉĄĖķadi, odaa iodaÉĄĖķawadi jeÉĄĖķetiÉĄĖķadiwilo.  
\v 59 EjitaÉĄĖķawatiwaji aÉĄĖķanotiticogi niwiloÉĄĖķonaÉĄĖķaxi nigepaa ediani owidije beexo ÉĄĖķoniwinoÉĄĖķodi ane diiÉĄĖķenatakata mediani.â 
\c 13  
\s1 Nige daÉĄĖķa idinilaanaÉĄĖķatibece, odaa idokee me ÉĄĖķodeleo nigepaa ganigicatibige 
\p  
\v 1 AjaaÉĄĖķajo naÉĄĖķajo lakata ica oko ototalo Jesus, odaa joÉĄĖķoyatematitalo ica anodaaÉĄĖķee Pilatos me diiÉĄĖķenataka monigodi anigepidiÉĄĖķica niÉĄĖķijoa galileutedi, maleeÉĄĖķidaa diitigi monigodi waxacocoli moibootema AneotedoÉĄĖķoji leeÉĄĖķodi libeyaceÉĄĖķeco.  
\v 2 Odaa Jesus ja niniÉĄĖķodi, meetediogi, âMigakati mijo ijo ninyaagi ijoa galileutedi me leeÉĄĖķodi mowote libeyaceÉĄĖķeco caticedi me liciagi niÉĄĖķinoa eletidi galileutedi?  
\v 3 EjitaÉĄĖķawatiwaji aÉĄĖķica libeyaceÉĄĖķegi ane caticedi me liciagi eletidi galileutedi. Codaa niÉĄĖķida makaamitiwaji nige daÉĄĖķadinilaanitece ÉĄĖķabeyaceÉĄĖķeco, akaami eleditetiwaji ÉĄĖķadelewi anee me nigo, odaa idokee me leegitalo AneotedoÉĄĖķoji motonitedice.  
\v 4 NiÉĄĖķijo 18 oko ane nigo aneniteloco aca niwilana ane leegitibigimece niÉĄĖķijo eledi liwai JerusalÃĐm ane liboonaÉĄĖķadi SiloÃĐ. Migakati me nigo leeÉĄĖķodi me daÉĄĖķaxa me nilaagetedipi lodoe AneotedoÉĄĖķoji caticedi niÉĄĖķidiwa eletidi niÉĄĖķeladimigipitigi JerusalÃĐm?  
\v 5 EjitaÉĄĖķawatiwaji niÉĄĖķijo ane nigo adaÉĄĖķaxa me nilaagetedipi lodoe AneotedoÉĄĖķoji daÉĄĖķa liciagi niÉĄĖķina eledi oko. Pida nige daÉĄĖķadinilaanitecetiwaji ÉĄĖķabeyaceÉĄĖķeco, akaami eleditetiwaji ÉĄĖķadelewi digo anee me nigo, odaa idokee me leegitalo motonitedice AneotedoÉĄĖķoji.â 
\s1 Aca fiigoigo ane daÉĄĖķaca ela 
\p  
\v 6 Odaa Jesus ja yatemati ica natematigo anida ane ÉĄĖķodiiÉĄĖķaxitece, odaa meetediogi, âIca ÉĄĖķoneleegiwa ada lawodigije fiigoigo midiwataÉĄĖķa elanigijedi âuuvaâ. Odaa neÉĄĖķenagi domaÉĄĖķa doletibige ela naÉĄĖķada niale, pida aÉĄĖķaca yakadi.  
\v 7 Odaa meeta niÉĄĖķica ane yowie lawodigijedi, âDigawini! JiÉĄĖķijoa itoatadiÉĄĖķida nicaaÉĄĖķape ixomaÉĄĖķatedijo, idokee niÉĄĖķina me janagi joletibige ela naÉĄĖķada niale, pida aÉĄĖķaca jakadi. Natigide akagiti naÉĄĖķada niale! JinaÉĄĖķalee jikanaÉĄĖķa naÉĄĖķada niale daÉĄĖķa iteloco iiÉĄĖķo anele, ane yakadi mejanaÉĄĖķate eletidi nawodigijedi.â  
\v 8 Pida niÉĄĖķijo ane yowie lawodigijedi ja igidi, mee, âInecalailegi, ecoÉĄĖķotace jikanaÉĄĖķa naÉĄĖķada niale jiwinaÉĄĖķa niÉĄĖķina nicaaÉĄĖķabi, jabooÉĄĖķodi libatadi, amaleeÉĄĖķaÉĄĖķa yaxawa me ili.  
\v 9 NaÉĄĖķada niale nigetaye niÉĄĖķina nicaaÉĄĖķabi anenagi, odaa jikanaÉĄĖķa me ili. Pida nige daÉĄĖķacata ela, odaaÉĄĖķepaanaÉĄĖķa adiiÉĄĖķenita me jakagidi.ââ 
\s1 Jesus icilatidi aca iwaalo awenanaÉĄĖķa me saabado 
\p  
\v 10 Ica saabado Jesus diiÉĄĖķaxinaÉĄĖķa manitaÉĄĖķa aca liiakanaÉĄĖķaxi judeutedi.  
\v 11 Digawini! Onani aca iwaalo joneÉĄĖķeote dezoito nicaaÉĄĖķape me awenanaÉĄĖķa leeÉĄĖķodi ica niwigo abeyaceÉĄĖķegi ane dakatiogi. Aona yakadi me dineÉĄĖķenaÉĄĖķadi.  
\v 12 Odaa Jesus ja nadi aca iwaalo, neÉĄĖķenidite, meeteta, âIwaalo, ida makaami ja ÉĄĖķadicilitema ÉĄĖķadeelotagi!â  
\v 13 Odaa ipeketedeloco libaaÉĄĖķatedi, odaa aÉĄĖķica daÉĄĖķa leegi ja icÃ­ me diwena, odaa ja doÉĄĖķetetibigimece AneotedoÉĄĖķoji. 
\p  
\v 14 Pida ica nowienoÉĄĖķodi niiakanaÉĄĖķaxi ja deliÉĄĖķide, leeÉĄĖķodi Jesus me icilatidi naÉĄĖķajo iwaalo me saabado. JoaniÉĄĖķidaa leeÉĄĖķodi meetiogi niÉĄĖķidi noiigi, âIdiwa dibatio ÉĄĖķobaaÉĄĖķadi nokododi me jakataÉĄĖķa me jibaaÉĄĖķa. Odaa anagi niÉĄĖķinoa eletidi nokododi me diniwakateeni, pida jinaÉĄĖķanagi niÉĄĖķina me saabado.â 
\p  
\v 15 Odaa ĮĪoniotagodi ja igidi, meeteta, âAkaamitiwaji niÉĄĖķina anodi moyotete liiÉĄĖķenatakaneÉĄĖķeco AneotedoÉĄĖķoji, pida aÉĄĖķotetenitetiwaji! NiÉĄĖķina me saabado okanicodaaÉĄĖķica niÉĄĖķina akaamitiwaji igo aneite neijedi ane noxocotege, odaa ikatedice noÉĄĖķodinadi, oÉĄĖķoa, domige nemadicali yadeegitinigi ninyoÉĄĖķodi me yacipeÉĄĖķetedi.  
\v 16 Pida naÉĄĖķada iwaalo anida aneetege licoÉĄĖķegi AbraÃĢo, niwilo SatanÃĄs 18 nicaaÉĄĖķape. Igame leeÉĄĖķodi ina me eni me daÉĄĖķa yakadi me jicilatidi ina me saabado?â  
\v 17 Odaa Jesus naÉĄĖķa igiditediogi, ijotawece niÉĄĖķijo neloÉĄĖķododipi niboliÉĄĖķatibigiwaji. Pida ijo eledi noiigi baÉĄĖķa ninitibigiwaji leeÉĄĖķodi niÉĄĖķijoa ÉĄĖķodoxiceÉĄĖķetedi aneote. 
\s1 Lolagi aca mostaada 
\r (Mateus 13.31-32; Marcos 4.30-32) 
\p  
\v 18 Odaa Jesus jeÉĄĖķee, âIgamigodaaÉĄĖķee AneotedoÉĄĖķoji nige iiÉĄĖķe laaleÉĄĖķenali ina oko? Amigini ica ane jiciaceeketege?  
\v 19 Digawini! AneotedoÉĄĖķoji nige iiÉĄĖķe niÉĄĖķina oko laaleÉĄĖķenali, jiciaceeketege lolagi âmostaadaâ ane daÉĄĖķaxa me lionawaana. Ica ÉĄĖķoneleegiwa dibata, odaa jeÉĄĖķeyateloco niogÃģ. Odaa naÉĄĖķajo elanigije ja ili, odaa ja niale nelegi. Odaa ilaaÉĄĖķaxodi joÉĄĖķowote libatoli midoataÉĄĖķa libiweli.â (Odaa jiÉĄĖķidaaÉĄĖķee me ili niÉĄĖķina lapo oko ane nepilidi AneotedoÉĄĖķoji). 
\s1 Natematigigi labookojegi leyeema 
\r (Mateus 13.33) 
\p  
\v 20 Jesus naÉĄĖķa dotaÉĄĖķatace, odaa mee, âAmigetiÉĄĖķini ane jiciaceeketege ica AneotedoÉĄĖķoji nige iiÉĄĖķe ina oko laaleÉĄĖķenali?  
\v 21 NiÉĄĖķina AneotedoÉĄĖķoji nige iiÉĄĖķe niÉĄĖķina oko laaleÉĄĖķenali, liciagi niÉĄĖķina ane yabooÉĄĖķodi leyeema anoibake moyoe paon, odaa joÉĄĖķoyawanaÉĄĖķaditege leyeema oiatigi itoatadiÉĄĖķida baxiatedi, odaa niÉĄĖķidiaaÉĄĖķidi ijoatawece baxiatedi ja nolee leeÉĄĖķodi jiÉĄĖķinaa ane yabooÉĄĖķodi leyeema.â 
\s1 Ica epoacawaanigi 
\r (Mateus 7.13-14, 21-23) 
\p  
\v 22 Jesus yakagiditedeloco nigotadi nelecoli, codaa me nigotadawaanaÉĄĖķa, niiÉĄĖķaxitediniwace oko, eÉĄĖķidaaÉĄĖķee me diniwiajetedicogi nigotaÉĄĖķa JerusalÃĐm.  
\v 23 Odaa joniÉĄĖķica ane ige, oneetalo, âĮĪoniotagodi, migeliodi ica oko AneotedoÉĄĖķoji ane yajigote lewiÉĄĖķa?â 
\p  
\v 24 Odaa Jesus ja igidi, meeteta, âAdinoniciwaÉĄĖķatitiwaji makaatiwece niÉĄĖķida epoacawaanigi amaleeÉĄĖķaÉĄĖķa yajigotedaÉĄĖķawa AneotedoÉĄĖķoji ÉĄĖķadewiÉĄĖķa. LeeÉĄĖķodi ejitaÉĄĖķawatiwaji eliodi oko anodoletibige me dakatiobece, pida aÉĄĖķoyakadi. 
\p  
\v 25 NigidiaaÉĄĖķidi nige dabiditini niÉĄĖķeladimigi, odaa ja noxoco epoagi, odaa akaamitiwaji jiÉĄĖķidiaaÉĄĖķonitice we. Odaa jaÉĄĖķanatokenitice epoagi, manidita, odaa menitiwaji, âĮĪoniotagodi, omokeni epoagi amaleeÉĄĖķaÉĄĖķa jakatio.â Odaa ja ÉĄĖķadigititetiwaji, meetedaÉĄĖķawa, âAjowooÉĄĖķodi ane icoÉĄĖķiticogitiwaji!â  
\v 26 Odaa menitiwaji, âGemakaami ÉĄĖķogiiwa, codaa geme aniiÉĄĖķaxinitiniwace oko niÉĄĖķinoa ÉĄĖķonigotadawaanaÉĄĖķa.â  
\v 27 Pida nige ÉĄĖķadigititetiwaji, meetedaÉĄĖķawa, âGeneÉĄĖķejitaÉĄĖķawa, ajowooÉĄĖķodi ane icoÉĄĖķiticogi. Adotonitice akaamitawece anawii ane beyagi!â  
\v 28 Niganatitiwaji AbraÃĢo, Isaque, JacÃģ, codaa mijotawece niÉĄĖķijo anoyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko digoida AneotedoÉĄĖķoji ninioxadi, pida baÉĄĖķakaamitawece etiÉĄĖķadokoleniticogi we, odaa jaÉĄĖķanoenitibece, acigiceni ÉĄĖķadowe leeÉĄĖķodi me daÉĄĖķaxa me eliÉĄĖķideetiwaji.  
\v 29 Odaa ina oko ane enagitibeci aÉĄĖķicaadaÉĄĖķa icoÉĄĖķoticogi, icoÉĄĖķoticogi nigoi, ÉĄĖķocidi, wajenaÉĄĖķa, codaa me niwetaÉĄĖķa. Odaa ja nicotiniwace madi nameeja me niodaÉĄĖķa minitaÉĄĖķa ninioxadi AneotedoÉĄĖķoji digoida ditibigimedi.  
\v 30 Digawini! NiÉĄĖķina oko iwikodadipi, ane ideitice lowiditice, niÉĄĖķidi jiÉĄĖķidiaa ideitice odoe. Odaa niÉĄĖķina oko ane diniwaloetibigiwaji ane ideitice odoe, niÉĄĖķidi jiÉĄĖķidiaa ideitice owiditice.â 
\s1 Jesus agecaÉĄĖķalo leeÉĄĖķodi niÉĄĖķeladimigipitigi JerusalÃĐm 
\r (Mateus 23.37-39) 
\p  
\v 31 AniaaÉĄĖķani aca lakata jonoÉĄĖķototalo Jesus icoa fariseutedi, odaa moditalo, âAnotitice, emii opili leeÉĄĖķodi Herodes doletibige me ÉĄĖķadeloati!â 
\p  
\v 32 Odaa Jesus ja igidi, meetediogi, âHerodes liciagi niÉĄĖķina eijeeÉĄĖķagi ane diwaxinaÉĄĖķa. Emii, nigicoota, odaa enita, âDigawini! NiÉĄĖķinoa onateciÉĄĖķinoa nokododi, jiticoitedice niwicidi abeyacaÉĄĖķaÉĄĖķa, jicilatidi oko eelotaginadi. Odaa nige ixomaÉĄĖķatedice itoatadiÉĄĖķida nokododi, ja jigodi ibaketedi.  
\v 33 Pida leeditibige me jiotece inaigi niÉĄĖķinoa nokododawaanaÉĄĖķa. IgaataÉĄĖķa ayakadi diÉĄĖķica anigeteÉĄĖķepidiÉĄĖķica niÉĄĖķina anoyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko daÉĄĖķa lemaÉĄĖķadi eledi nipodigi ditigedi nigotaÉĄĖķa JerusalÃĐm.â 
\p  
\v 34 Akaamitiwaji niÉĄĖķeladimigipitigi JerusalÃĐm, jaÉĄĖķakamaÉĄĖķa anigoti niÉĄĖķijo anoyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko, eleditace anigidaatiniwace niÉĄĖķijo AneotedoÉĄĖķoji ane niwakateetedibigaÉĄĖķaji. AnigenaÉĄĖķa liwokodi domaÉĄĖķa jemaa me ÉĄĖķadatecoÉĄĖķoteenitiwaji meetaÉĄĖķa, leeÉĄĖķodi me domaÉĄĖķa jemaa me idoweditaÉĄĖķalocotiwaji, macataÉĄĖķa naÉĄĖķana okoÉĄĖķokoodi me ixomodatediwece lionaÉĄĖķa catiwedi labadi. Pida aÉĄĖķemaanitiwaji.  
\v 35 Natigide, digawini! ĮĪanigotaÉĄĖķatiwaji aÉĄĖķaleeÉĄĖķica ane dowediteloco. Odaa ejitaÉĄĖķawatiwaji, aÉĄĖķaleeÉĄĖķica madatitiwaji nigepaaÉĄĖķicota niÉĄĖķica noko menitiwaji, âNinitedibece NiÉĄĖķinoa anenagi, anida naÉĄĖķatetigi LiboonaÉĄĖķadi ĮĪoniotagodi AneotedoÉĄĖķoji!ââ 
\c 14  
\s1 Jesus icilatidi eelotaginaÉĄĖķa me saabado 
\p  
\v 1 Ica noko me saabado, Jesus dakatediwece liÉĄĖķeladi ica lacilo fariseutedi ane node maniodi. Odaa icoa fariseutedi eledi onidi moiÉĄĖķoaditalo Jesus.  
\v 2 JiÉĄĖķigo Jesus lodoe ica ÉĄĖķoneleegiwa eelotaginaÉĄĖķa, nadedi libaaÉĄĖķatedi, loÉĄĖķonaka.  
\v 3 Odaa Jesus ja igetediogi niÉĄĖķidiwa niiÉĄĖķaxinaÉĄĖķanadi anodiiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs, idiaaÉĄĖķidiwa fariseutedi, meetediogi, âMige oyoli ÉĄĖķonajoinaÉĄĖķaneÉĄĖķeco daÉĄĖķa jicilatidi niÉĄĖķina eelotaginaÉĄĖķa ina noko me saabado, oÉĄĖķoa, aÉĄĖķoyoli?â 
\p  
\v 4 Pida aÉĄĖķoigidi. Odaa Jesus ja dibate niÉĄĖķijo ÉĄĖķoneleegiwa. NaÉĄĖķa icilatidi, odaa ja imonya mopi.  
\v 5 Odaa Jesus ja igetediogi, meetediogi, âIna diÉĄĖķica ÉĄĖķadionigi ane daxaboketinece nalice, migetaÉĄĖķa ÉĄĖķanoÉĄĖķodinaÉĄĖķatiwaji, odaa migetaÉĄĖķa adinopaÉĄĖķatitibece manoÉĄĖķaa leeÉĄĖķodi me saabado? OÉĄĖķoa domige odaa aÉĄĖķanoÉĄĖķaa leeÉĄĖķodi me saabado?â  
\v 6 Odaa aÉĄĖķoyakadi moigidi. 
\s1 Jesus yalaÉĄĖķate ica oko ane diniwikodetibece 
\p  
\v 7 Jesus iwitediogi niÉĄĖķica oko nodenigipi oniwitedi limetiidi odoletibige niÉĄĖķina nimedi ane daÉĄĖķaxa mele. Odaa ja yatemati natematigo anida ane ÉĄĖķodiiÉĄĖķaxi, meetediogi,  
\v 8 âNiÉĄĖķina nigakaami nodenigi midi nadoneÉĄĖķegi, jinaÉĄĖķanicooteloco baancotedi ane daÉĄĖķaxa mele. IgaataÉĄĖķa eji meledi onode eledi oko ane daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi ane daÉĄĖķa ÉĄĖķadiciagi.  
\v 9 Odaa niÉĄĖķijo ane ÉĄĖķadodeni, diÉĄĖķicotaÉĄĖķawa ijaaÉĄĖķijo niÉĄĖķijo eledi nodenigi, odaa meetaÉĄĖķawa, âAjicita ÉĄĖķamedi niÉĄĖķida eledi yodenigi.â Odaa jaÉĄĖķaniboliki, odaa jaÉĄĖķanicooteloco nimedi ane deÉĄĖķele.  
\v 10 Pida niÉĄĖķina nigakaami nodenigi nalooÉĄĖķo, anicooteloco niÉĄĖķidi nimedi ane daÉĄĖķa ÉĄĖķoneÉĄĖķegi. Odaa niÉĄĖķida ane ÉĄĖķadodeni igo makaamita, meetaÉĄĖķawa, âYokaaÉĄĖķedi, anagi, anicooti digoina miditaÉĄĖķa nimedi anele.â JoaniÉĄĖķidaaÉĄĖķee ÉĄĖķadeloÉĄĖķoteeni lodoe iditawece niÉĄĖķidi lodenigipi.  
\v 11 IgaataÉĄĖķa niÉĄĖķina oko anepaa doletibige me yeloÉĄĖķo, nigidiaaÉĄĖķidi icota me diniwikodetibece. Pida niÉĄĖķina ane diniwikodetibece, nigidiaaÉĄĖķidi icota me yeloÉĄĖķo.â 
\p  
\v 12 Jesus meeteta niÉĄĖķijo ane node, âIna nigawiite niweenigi nelegi me yaxoÉĄĖķo-noko, oÉĄĖķoa, mige ÉĄĖķocidi, jinaÉĄĖķanodeni ÉĄĖķadokaaÉĄĖķetedi, ÉĄĖķanioxoadipi, codaa me ÉĄĖķaditacepodi, migetaÉĄĖķa ÉĄĖķadipecaÉĄĖķawepodi ane liicotedi. LeeÉĄĖķodi nigidiaaÉĄĖķidi jaÉĄĖķaÉĄĖķa etiÉĄĖķadodeni, odaa ja micataÉĄĖķa deÉĄĖķetiÉĄĖķadediani.  
\v 13 Pida nigica mawii nalokegi, anodeni madewetedipi, alejaadotedi, inoa ane daÉĄĖķa yakadi mewaligitibigiwaji, etoinadi.  
\v 14 Odaa AneotedoÉĄĖķoji ÉĄĖķadibinieni. IgaataÉĄĖķa aÉĄĖķica nimaweneÉĄĖķegi niÉĄĖķidi deÉĄĖķetiÉĄĖķadediani. Odaa AneotedoÉĄĖķoji yajigotedaÉĄĖķawa anele niÉĄĖķica noko nigeote me newiÉĄĖķatace niÉĄĖķina oko ane iÉĄĖķenaÉĄĖķatibigiwaji.â 
\s1 Natematigigi ica nalokegi nelegi 
\r (Mateus 22.1-10) 
\p  
\v 15 AnigepidiÉĄĖķijo niÉĄĖķijo oko anidiaaÉĄĖķi maditaÉĄĖķa nameeja miniwataÉĄĖķa Jesus wajipatalo niÉĄĖķijoa lotaÉĄĖķa, odaa meetalo, âNiÉĄĖķica ane nicotiniwace maditaÉĄĖķa nameeja me nalooÉĄĖķo digoida ninioxadi AneotedoÉĄĖķoji, niÉĄĖķidi icota me daÉĄĖķaxa me ninitibigiwaji.â 
\p  
\v 16 Pida Jesus meeteta, âIca ÉĄĖķoneleegiwa one dodenaÉĄĖķa node eliodi oko miditaÉĄĖķa lalokegi aneote.  
\v 17 NiÉĄĖķicota aca lakata nalokegi, odaa ja iiÉĄĖķe liotagi me nodetece oko, mee, âAnagitiwaji, inoatawece ja igo.â  
\v 18 Pida iditawece idokida lowoogo, jeÉĄĖķecoÉĄĖķotace owote inoa linetedi. NiÉĄĖķica odoejegi nodenigi meeta niÉĄĖķida niotagi, âIbeyacaÉĄĖķadi jinoojeteta nipodigi, leeditibige mejigo jiwi. Jipokotalo ÉĄĖķaniotagodi me daÉĄĖķa yakaditeda me beyagi.â  
\v 19 Odaa niÉĄĖķini eledi nodenigi meeta, âJinoojeteta dooze lacilodi ewalaile. EcoÉĄĖķotace ejigo jiwi migele me nibaaÉĄĖķa. Jipokotalo ÉĄĖķaniotagodi me daÉĄĖķa yakaditeda me beyagi.â  
\v 20 Odaa niÉĄĖķica eledi mee, âAjakadi mejigo, ibeyacaÉĄĖķadi gela me jado. JoaniÉĄĖķidaa leeÉĄĖķodi daÉĄĖķa jakadi mejigo.â 
\p  
\v 21 Odaa niÉĄĖķijo niotagi ja dopitijo, ja yatematita niÉĄĖķini niotagodi, odaa ja deliÉĄĖķide. Odaa meeta liotagi, âEmii ÉĄĖķadediiki, emiitece ladicotiidi, ina ladicotiidawaanaÉĄĖķa diimaÉĄĖķa, odaa anadeegi niÉĄĖķinoa madewetedi, inoa alejaadotedi, ina ane deÉĄĖķewaligi, etoinadi.â  
\v 22 NiÉĄĖķidiaaÉĄĖķidi ja dopitijo niÉĄĖķijo niotagi, odaa mee, âIniotagodi, ja jaote ijoatawece ane ÉĄĖķadiiÉĄĖķenatakaneÉĄĖķeco, pida eÉĄĖķidiwa nimetiidi iiÉĄĖķotedice.â  
\v 23 Odaa niÉĄĖķijo niotagodi meeta niÉĄĖķijo liotagi, âEmii iwitece naicoli, naicolawaanaÉĄĖķa wetice nigotaÉĄĖķa. Awii me nakatiobece oko digoina iÉĄĖķeladi nigepaa nolee.  
\v 24 IgaataÉĄĖķa ejitaÉĄĖķawatiwaji, otiÉĄĖķinitece niÉĄĖķijo odoejegipi nodenigipi aniodi digoina yalokegi.ââ 
\s1 Ica ane yakadi me diotibece Jesus 
\r (Mateus 10.37-38) 
\p  
\v 25 Eliodi oko anodiotece Jesus me diniwiaje, naÉĄĖķa noletedijo, meetediogi,  
\v 26 âNiÉĄĖķina anenagi meetaÉĄĖķa, ayakadi me niotibici, nige deÉĄĖķewi me idemaa caticedi me liciagi me yemaa eliodi, eliodo, lodawa, lionigipi, nioxoadipi, niwaalepodi, codaa miniaaÉĄĖķini.  
\v 27 NiÉĄĖķina ane daÉĄĖķa igotema me dawikode nigepaa yeleo, codaa aniotici, niÉĄĖķini ayakadi miniÉĄĖķina ane niotibici. 
\p  
\v 28 NiÉĄĖķina akaamiteloco nige ÉĄĖķadowoogo mawii ÉĄĖķadiÉĄĖķeladi nelegi, odoejegi leeditibige manicooti owoo ane liwokodi yajigo odaa awini migabo mediani.  
\v 29 Nige doÉĄĖķowoo ane liwokodi, doidetibige me idioka oeni lipodaÉĄĖķaladi, pida aÉĄĖķinitawece agoti diimigi. Odaa niÉĄĖķina oko anonadi niÉĄĖķida niciagi oyame.  
\v 30 Odaa joÉĄĖķodi, âNiÉĄĖķini ÉĄĖķoneleegiwa domaÉĄĖķa yoe liÉĄĖķeladi, pida aigodi libakedi.â 
\p  
\v 31 NiÉĄĖķina diÉĄĖķini inionigi-eliodi anidiwa deez miili niodaÉĄĖķawadi daÉĄĖķa doletibige me ideleÉĄĖķe niÉĄĖķini eledi inionigi-eliodi ane iwitideÉĄĖķeta, nadeegi onokotece ÉĄĖķodigoti miili iodaÉĄĖķawadi. Odoejegi ecoÉĄĖķotace nicotini, doletibige me yowooÉĄĖķodi migica loniciwaÉĄĖķa me ideleÉĄĖķe niÉĄĖķini eledi inionigi-eliodi.  
\v 32 Nige yakadi ina me daÉĄĖķa abotege, odaa niboloitee malee leegitege niÉĄĖķini eledi, odaa ja imonya liiÉĄĖķexedi igetece niÉĄĖķini eledi inionigi niÉĄĖķica ane yemaa eotibige me daÉĄĖķalee ideleÉĄĖķe.  
\v 33 JoaniÉĄĖķidaaÉĄĖķee aÉĄĖķica niÉĄĖķina akaamiteloco ane yakadi me niotibici nige daÉĄĖķa ika idiwatawece icoa ane nepilidi.â 
\s1 Ica yoci ane deÉĄĖķele 
\r (Mateus 5.13; Marcos 9.50) 
\p  
\v 34 Odaa eÉĄĖķidaa diitigi me dotaÉĄĖķa Jesus, mee, âNiÉĄĖķina yoci eletema inoatawece, pida niganiaditema libayodaÉĄĖķa, aÉĄĖķica ÉĄĖķonimaweneÉĄĖķegi daÉĄĖķa jaoÉĄĖķatace me bayodi.  
\v 35 Odaa aÉĄĖķaleeÉĄĖķeletema iiÉĄĖķo, oteÉĄĖķexaaÉĄĖķaÉĄĖķa eletema me iniboloiteenaÉĄĖķa, pida idoka eletema me jalataÉĄĖķa. Ane yemaa me wajipatalo iiÉĄĖķaxinaÉĄĖķaneÉĄĖķeco, atacolitece!â 
\c 15  
\s1 Natematigigi waxacoco ananiadi 
\r (Mateus 18.12-14) 
\p  
\v 1 Ica noko eliodi niÉĄĖķijo anodibatibigege ninyeelo ninionigi-eliodi romaanotedi, idiaaÉĄĖķidi ica eledi oko anodi me daÉĄĖķaxa me abeyacaÉĄĖķaÉĄĖķa, igotibeci odipegitalo Jesus mowajipatalo latematiko.  
\v 2 Pida idiwa icoa fariseutedi, icaaÉĄĖķicoa niiÉĄĖķaxinaÉĄĖķanadi anodiiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs, eliodi moyalomeÉĄĖķe Jesus, modi, âNiÉĄĖķidoa ÉĄĖķoneleegiwa dibatetege niÉĄĖķinoa ÉĄĖķoneleegiwadi abeyacaÉĄĖķaÉĄĖķa, codaa ligiiwepodi.â  
\v 3 Odaa Jesus ja yatemati ica natematigo ane ÉĄĖķodiiÉĄĖķaxi, meetediogi,  
\v 4 âNiÉĄĖķida makaamitiwaji diÉĄĖķini anidiwa onaniteci taalia niwaxacocoli, odaa daÉĄĖķaca ananiaditibige. AjawienatakanaÉĄĖķa me igo doletibige, ecoÉĄĖķotace yoya niÉĄĖķijoa eletidi ane yeyaÉĄĖķatedice digoida nipodigi. Odaa jiÉĄĖķigo doletibige naÉĄĖķajo waxacoco ananiadi nigepaa yakadi.  
\v 5 NigidiaaÉĄĖķidi nige yakadi naÉĄĖķajo waxacoco, odaa ja yoyaÉĄĖķadi, eliodi me ninitibece.  
\v 6 Nigicota liÉĄĖķeladi, odaa jeÉĄĖķeniditiogi lokaaÉĄĖķetedi, lipecaÉĄĖķawepodi, odaa meetiogi, âJemaa makaami inikaÉĄĖķawepodi, leeÉĄĖķodi idinitibeci me jakadi naÉĄĖķajo iniwaxacoco ananiadi.â  
\v 7 EjitaÉĄĖķawatiwaji jiÉĄĖķidaaÉĄĖķee, iditawece ane idei digoida ditibigimedi ninitibigiwaji niÉĄĖķina mini ane dinilaatece libeyaceÉĄĖķeco niÉĄĖķina oko abeyaceÉĄĖķegipi, pida baadaÉĄĖķa ninitibigiwaji leeÉĄĖķodi niÉĄĖķina eledi oko anodiletibige daÉĄĖķa iÉĄĖķenaÉĄĖķatibigiwaji, codaa anodi me daÉĄĖķalee leeditibige me dinilaatibigiwaji. 
\s1 Natematigigi aca beexo ananiadi 
\p  
\v 8 DaÉĄĖķa aca iwaalo anidiwa deez nibeexotedi daÉĄĖķaniadi onaniteci, ajawienatakanaÉĄĖķa migo doletibige. Yalegi loledaÉĄĖķaxi, yoladitice liÉĄĖķeladi, doletibige nigepaa yakadi naÉĄĖķajo beexo.  
\v 9 NaÉĄĖķa yakadi naÉĄĖķajo beexo, odaa jeÉĄĖķeniditiogi lokaaÉĄĖķetedi, lipecaÉĄĖķawadi, odaa meetiogi, âJemaa makaami inikaÉĄĖķawepodi leeÉĄĖķodi idinitibeci me jakadi inibeexo ananiadi.â  
\v 10 EjitaÉĄĖķawatiwaji, jiÉĄĖķidaaÉĄĖķee AneotedoÉĄĖķoji niaanjotedi me ninitibigiwaji leeÉĄĖķodi me dinilaatece libeyaceÉĄĖķeco niÉĄĖķina oko aniatagigi.â 
\s1 Natematigigi ica nionigi aniatagigi 
\p  
\v 11 Odaa Jesus meetetiogi, âIca ÉĄĖķoneleegiwa onidiwa iniwataale lionaÉĄĖķa.  
\v 12 Ica noko niÉĄĖķica baÉĄĖķalee lioneeÉĄĖķa lionigi meeta eliodi, âEiodi, jemaa manajicitediwa niÉĄĖķicoa ane inepilidi ane domaÉĄĖķa jibatege nige ÉĄĖķadelewi.â Odaa ja yawalace ane nepilidi nediatiniwace niÉĄĖķidoa itoataale lionaÉĄĖķa. 
\p  
\v 13 AÉĄĖķica doÉĄĖķowidi nokododi niÉĄĖķijo baÉĄĖķalee lioneeÉĄĖķa lionigi ja nioda idiwatawece ane noÉĄĖķetedi, odaa ja noditice, jiÉĄĖķigo ica eledi iiÉĄĖķo ane leegita. Odaa oneliodi me dalotibece, wacipetibece, codaa me itineÉĄĖķe awicijipi, yaaÉĄĖķadi ijoatawece niÉĄĖķicoa noÉĄĖķetedita eliodi.  
\v 14 NiÉĄĖķidiaaÉĄĖķidi naÉĄĖķa yaaÉĄĖķadi ijoatawece icoa ane nepilidi, pida jaÉĄĖķaÉĄĖķa icota nigigi niÉĄĖķidi nipodigi. Odaa ja dawikode.  
\v 15 NiÉĄĖķidiaaÉĄĖķidi jiÉĄĖķigo doletibige libakedi miditaÉĄĖķa niÉĄĖķeladimigipitigi niÉĄĖķidi nipodigi, odaa ja yakadi necalailegi iiÉĄĖķe me yowie nigidagiwadi.  
\v 16 Odaa leeÉĄĖķodi me daÉĄĖķaxa me nigicile, ja domaÉĄĖķa yemaa me yeligo nigidagiwadi liweenigi, leeÉĄĖķodi aÉĄĖķoyediatece ane yeligo. 
\p  
\v 17 Pida naÉĄĖķa eliodi me dowooko, meetigi le, âEiodi idiwa owidi liotaka, inoa liweenaÉĄĖķa caticedi me liciagi ane jopotibige, emeÉĄĖķee ite ee digoina ja ideloadi nigigi. \fig |src="cn01759B.tif" size="span" copy="ÂĐ 1978 David C. Cook Publishing Co." ref="Lucas 15-15.17" \fig* 
\v 18 Natigide ja jopita eiodi liÉĄĖķeladi. Nigejota, odaa ejita, âEiodi, jao ane beyagitema AneotedoÉĄĖķoji, codaa makaami.  
\v 19 Natigide aÉĄĖķalee yakadi deÉĄĖķenitiwa me ee ÉĄĖķadionigi, leeÉĄĖķodi aÉĄĖķee oko anele. Pida jemaa mawii ibakedi liciagi niÉĄĖķinoa ÉĄĖķadiimetedi.â â  
\v 20 NaÉĄĖķa ika me dowooko, odaa jiÉĄĖķigo opita eliodi. 
\p Odaa niÉĄĖķijo lioneeÉĄĖķa eleegitege, odaa niÉĄĖķijo eliodi ja naditege. Odaa eliodi me iwikodetege. NaÉĄĖķa walokoditege lionigi, ibedotece, napicoÉĄĖķo.  
\v 21 Odaa niÉĄĖķijo lioneeÉĄĖķa meeta eliodi, âEiodi, jao ane beyagitema AneotedoÉĄĖķoji, codaa makaami. AÉĄĖķalee yakadi deÉĄĖķenitiwa me ee ÉĄĖķadionigi, leeÉĄĖķodi aÉĄĖķee oko anele.â  
\v 22 Pida niÉĄĖķijo eliodi, meetiogi liotaka, âĮĪadediiki manadeegi naÉĄĖķaca ane daÉĄĖķaxa me libiniena jayogo anixomeÉĄĖķenitinigi. Awii libaaÉĄĖķateje ixomitiwece nibedona, codaa awiite liwelatedi.  
\v 23 Codaa awii abaata wacawaanigi ane daÉĄĖķaxa majakalo, eloati, jaoÉĄĖķa nalokegi, ÉĄĖķodinitibece.  
\v 24 IgaataÉĄĖķa niÉĄĖķida ionigi ane dopitijo, micataÉĄĖķa daÉĄĖķa yeleo, odaa ja yewiÉĄĖķatace, codaa aniadi, noÉĄĖķokaanaÉĄĖķa jakataÉĄĖķa.â Odaa joÉĄĖķowo nalokegi. 
\p  
\v 25 NiÉĄĖķijo lionigi boÉĄĖķoxiiÉĄĖķodi ideitice nipodigi, naÉĄĖķa dopitio, niÉĄĖķipegitio liÉĄĖķeladi, ja wajipatalo natenaÉĄĖķaneÉĄĖķeco, ica oko dayaagetiogi me nalooÉĄĖķo.  
\v 26 Odaa jeÉĄĖķenidita anigepidiÉĄĖķijo niÉĄĖķidiwa liotaka, naÉĄĖķa ige, meeta, âAmiidi ica ayaagi?â  
\v 27 Odaa ja igidi, meeta, âĮĪanioxoa ja dopitijo, mele. JoaniÉĄĖķidaa leeÉĄĖķodi ÉĄĖķadiodi diiÉĄĖķenataka moyeloadi wacawaanigi ajakalo.â 
\p  
\v 28 NiÉĄĖķijo boÉĄĖķoxiiÉĄĖķodi lionigi ja deliÉĄĖķide, odaa ayemaa me dakatio. Odaa eliodi ja noditicogi we, domaÉĄĖķa yemaa me yadeegitio, yocaÉĄĖķaneÉĄĖķetibigo.  
\v 29 Pida naÉĄĖķa igidi eliodi, meeta, âDigawini! JoÉĄĖķowidi nicaaÉĄĖķape me jibataÉĄĖķadomi, liciagi niÉĄĖķinoa ÉĄĖķaotaka. AÉĄĖķica daÉĄĖķa ÉĄĖķadotigimadeni. Pida aÉĄĖķica daÉĄĖķanajicitiwa oteÉĄĖķexaaÉĄĖķaÉĄĖķa waxigida me jeloadi daÉĄĖķa jao nalokegi me inode yokaaÉĄĖķetedipi.  
\v 30 NiÉĄĖķini ÉĄĖķadionigi ane yaaÉĄĖķadi ÉĄĖķaninyeelo, yaaÉĄĖķaditeloco iwaalepodi agopeloaÉĄĖķa, odaa neÉĄĖķeno, jeÉĄĖķeloatitema wacawaanigi ajakalo.â  
\v 31 Odaa niÉĄĖķijo eliodi meeta, âIonigi, idioka limedi makaami meetaÉĄĖķa. Odaa inoatawece ane inepilidi, akaami ÉĄĖķanepilidi.  
\v 32 Pida baÉĄĖķa leeditibige me jaoÉĄĖķa nalokegi me ÉĄĖķodinitibece. LeeÉĄĖķodi niÉĄĖķida ÉĄĖķanioxoa micataÉĄĖķa daÉĄĖķa yeleo, odaa niÉĄĖķidiaaÉĄĖķidi ja yewiÉĄĖķatace. MicataÉĄĖķa daÉĄĖķaniadi, niÉĄĖķidiaaÉĄĖķidi noÉĄĖķoyakadi!ââ 
\c 16  
\s1 Natematigigi ica niotagi ane daÉĄĖķa yakadi me jinakatonaÉĄĖķa 
\p  
\v 1 Jesus meetediogi niÉĄĖķijo anodiotibece, âIca ÉĄĖķoneleegiwa liico, oninica liotagi ane iiÉĄĖķe icoa libaketedi. Odaa joniÉĄĖķica anenagitibeci minitaÉĄĖķa niÉĄĖķini ÉĄĖķoneleegiwa liico, odaa joÉĄĖķoyatematita niÉĄĖķijo liotagi me yaaÉĄĖķadi ninyeelo.  
\v 2 Odaa jeÉĄĖķenidita niÉĄĖķijo liotagi, meeta, âEwi ijo anonatematitiwa? Natigide jemaa maneloÉĄĖķotitediwa icoatawece niÉĄĖķicoa ÉĄĖķadaakataka, jilakidenaÉĄĖķatedi ÉĄĖķanaalewe, leeÉĄĖķodi niÉĄĖķina natigide aÉĄĖķalee iiÉĄĖķeni niÉĄĖķinoa ibaketedi.â  
\v 3 Odaa niÉĄĖķijo liotagi meetibige le, âInecalailegi ja idikatice. Amigini ica ane jao? Ajakadi me jiba daÉĄĖķa inaligi iiÉĄĖķo, codaa idiboliÉĄĖķa daÉĄĖķa jipokotibige dinyeelo.  
\v 4 Pida ja jowooÉĄĖķodi ane inimaweneÉĄĖķegi modibatigi niÉĄĖķina niÉĄĖķeladimigipi midiwataÉĄĖķa liÉĄĖķelatedi, nige idiiÉĄĖķe inecalailegi me jopi.â 
\p  
\v 5 Odaa niÉĄĖķijo niotagi jeÉĄĖķeniditiogi niÉĄĖķijo anonaalewe necalailegi. Odaa jeÉĄĖķeeta niÉĄĖķijo odoejegi, âIgame liwokodi manaaleweeni inecalailegi?â  
\v 6 Odaa niÉĄĖķijo ÉĄĖķoneleegiwa mee, âJinaalewe onaniteci taalia bootitedi najidi.â NiÉĄĖķijo niotagi mee, âDigawini analee liwokodi ÉĄĖķanaalewe. Idiitini manaaleweeni meya-taalia bootitedi najidi.â  
\v 7 Odaa jeÉĄĖķeeta niÉĄĖķijo eledi anenotio, âApaÉĄĖķa akaami, igame liwokodi ÉĄĖķanaalewe?â Odaa jeÉĄĖķee, âJinaalewe onaniteci taalia jaacotedi leyeema.â Odaa niÉĄĖķijo niotagi mee, âIdiitedini manaaleweeni onexaa oiteenta jaacotedi leyeema.â 
\p  
\v 8 IgaanaÉĄĖķa yowooÉĄĖķodi niÉĄĖķijo necalailegi niÉĄĖķijo niotagi ane daÉĄĖķa yakadi me jinakatonaÉĄĖķa, odaa ja iweniÉĄĖķide leeÉĄĖķodi niÉĄĖķida anee. LeeÉĄĖķodi niÉĄĖķina oko anida aneetege niÉĄĖķina iiÉĄĖķo, baÉĄĖķa daÉĄĖķaxa me niwaxinaÉĄĖķanaÉĄĖķa, niÉĄĖķina mowote noojetekico caticedi me liciagi niÉĄĖķina oko anida aneetege nilokokena AneotedoÉĄĖķoji. 
\p  
\v 9 EjitaÉĄĖķawatiwaji mabakeni niliicaÉĄĖķajetecidi niÉĄĖķina iiÉĄĖķo bidige ina ÉĄĖķadokaaÉĄĖķetedipi, awiitibige nige daÉĄĖķaleeÉĄĖķicoa niÉĄĖķijoa ÉĄĖķaniliicaÉĄĖķajetecidi, odaa AneotedoÉĄĖķoji ja dibatedaÉĄĖķagi me ÉĄĖķadiÉĄĖķeladi digoida ditibigimedi.  
\v 10 NiÉĄĖķina ane yakadi me jinakatonaÉĄĖķatema niÉĄĖķinoa anicinoa ane diÉĄĖķica jaoÉĄĖķate, odaa yakadi me jinakatonaÉĄĖķatema niÉĄĖķinoa anicinoa anida ane jaoÉĄĖķate. Pida niÉĄĖķina ane daÉĄĖķa yakadi me jinakatonaÉĄĖķatema niÉĄĖķinoa anicinoa ane diÉĄĖķica jaoÉĄĖķate, odaa ayakadi daÉĄĖķa jinakatonaÉĄĖķatema niÉĄĖķinoa anicinoa anida ane jaoÉĄĖķa.  
\v 11 Enice nige daÉĄĖķa yakadi metiÉĄĖķadinakatonitema niÉĄĖķinoa niliicaÉĄĖķajetecidi niÉĄĖķina iiÉĄĖķo, amiijo ica ane ÉĄĖķadinakatonitema niÉĄĖķicoa beÉĄĖķewi me ÉĄĖķoniliicaÉĄĖķajetecidi?  
\v 12 NiÉĄĖķina nige daÉĄĖķawiitetiwaji niÉĄĖķica ane iÉĄĖķenaÉĄĖķatema niÉĄĖķinoa ane nepilidi eledi oko, amiijo ica ane yajigotaÉĄĖķawa ica ane ÉĄĖķanebi? 
\p  
\v 13 AÉĄĖķica ane yakadi me dibatema iniwataale necalaixedi, igaataÉĄĖķa ini ane daÉĄĖķa yemaa, odaa iniaaÉĄĖķeledi baÉĄĖķa lemaanigi, domige ini ane nienaÉĄĖķaneÉĄĖķe, odaa iniaaÉĄĖķeledi aÉĄĖķalee deemitetibige. Odaa joaniÉĄĖķidaaÉĄĖķee aÉĄĖķakati mabaatema AneotedoÉĄĖķoji, nige leedi mawiite inoatawece onidaaÉĄĖķida manigaanyetece dinyeelo.â 
\s1 LiiÉĄĖķenatakaneÉĄĖķeco AneotedoÉĄĖķoji adiniigi 
\r (Mateus 11.12-13; 5.31-32; Marcos 10.11-12) 
\p  
\v 14 Icoa fariseutedi anowajipatalo lotaÉĄĖķa Jesus, jonoÉĄĖķoyame leeÉĄĖķodi daÉĄĖķaxa moyemaa dinyeelo.  
\v 15 Odaa Jesus meetediogi, âNiÉĄĖķina makaamitiwaji oleetibige niÉĄĖķina oko modi ica makaami oko ane iÉĄĖķenaÉĄĖķa, pida AneotedoÉĄĖķoji baÉĄĖķa yowooÉĄĖķoditediwece ÉĄĖķadaaleÉĄĖķenali. IgaataÉĄĖķa niÉĄĖķinoa ganicinoa analeetibige daÉĄĖķa diniwaloe, AneotedoÉĄĖķoji yakadi me diÉĄĖķica ane jaoÉĄĖķa. 
\p  
\v 16 AneotedoÉĄĖķoji domaÉĄĖķa yemaa niÉĄĖķina oko me niiÉĄĖķaxinaÉĄĖķanaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs, codaa modiiÉĄĖķaxinaÉĄĖķatece lotaÉĄĖķa niÉĄĖķijo jotigide AneotedoÉĄĖķoji liiÉĄĖķexedi anoyeloÉĄĖķoditedibece lowooko. AneotedoÉĄĖķoji domaÉĄĖķa yemaa doÉĄĖķodiiÉĄĖķaxinaÉĄĖķatece niÉĄĖķinoa notaÉĄĖķa deÉĄĖķepaaÉĄĖķeno JoÃĢo Batista. Pida niÉĄĖķijo maleeÉĄĖķijo JoÃĢo, idokee me jeloÉĄĖķotaÉĄĖķa ÉĄĖķobodicetedi anele anodaaÉĄĖķeeteda AneotedoÉĄĖķoji me iiÉĄĖķe laaleÉĄĖķenali oko. Odaa natigide digawiniteloco inatawece oko ja dinoniciwaÉĄĖķaditibigiwaji me dinawanaÉĄĖķaditege niÉĄĖķina noiigi ane iiÉĄĖķe AneotedoÉĄĖķoji laaleÉĄĖķenali.  
\v 17 Icota me daa ditibigimedi, codaa me iiÉĄĖķo, pida baÉĄĖķa dakake monidateci ligegi inoÉĄĖķaaÉĄĖķa liiÉĄĖķenatakaneÉĄĖķeco AneotedoÉĄĖķoji. 
\p  
\v 18 DiÉĄĖķica ÉĄĖķoneleegiwa ane iticoitice lodawa, odaa ja lodawa eledi iwaalo. Odaa niÉĄĖķini ÉĄĖķoneleegiwa ja doÉĄĖķolaÉĄĖķataka. Odaa diÉĄĖķica eledi ane lodawa naÉĄĖķani iwaalo ane oiticoitice, odaa jaÉĄĖķaÉĄĖķa doÉĄĖķolaÉĄĖķataka. 
\s1 Natematigigi ica liico iniaa ica madewedi LÃĄzaro 
\p  
\v 19 Ica ÉĄĖķoneleegiwa liico ane dinixotinigilo nowoodi libinienaÉĄĖķa ane dakake loojedi. Eotibiga nalokeco, codaa ele maniodi.  
\v 20 Pida onaÉĄĖķaÉĄĖķini ica ÉĄĖķoneleegiwa madewedi ane liboonaÉĄĖķadi LÃĄzaro, one diwexege lolaadi. IdiaaÉĄĖķitibige lapoagi liÉĄĖķeladi niÉĄĖķini ÉĄĖķoneleegiwa liico.  
\v 21 LÃĄzaro walitibigege latijedi niÉĄĖķini liico maniodi naÉĄĖķaleekoka aaÉĄĖķaÉĄĖķa aniodi. Icoa necexodi one onapitibece liwexegadi LÃĄzaro. 
\p  
\v 22 NiÉĄĖķijo ÉĄĖķoneleegiwa madewedi niÉĄĖķidiaaÉĄĖķidi ja yeleo, odaa aanjotedi joÉĄĖķoyadeegi liwigo me nicote liwai AbraÃĢo miditaÉĄĖķa nalooÉĄĖķo digoida ditibigimedi. NiÉĄĖķidiaaÉĄĖķidi niÉĄĖķijo ÉĄĖķoneleegiwa liico jaÉĄĖķaÉĄĖķa yeleo, odaa joÉĄĖķonaligitini.  
\v 23 Odaa beÉĄĖķeliodi me dawikode digoida lawikodadi ÃĐmaÉĄĖķaÉĄĖķa. IgaanaÉĄĖķa noletibige, odaa ja nadi AbraÃĢo digoida ditigedi, iniaa LÃĄzaro liwai AbraÃĢo.  
\v 24 Odaa ja dapaawe mee, âEiodi AbraÃĢo, adiwikodeni! Anieni LÃĄzaro me itiminatidi nibedona, amaleeÉĄĖķaÉĄĖķa ilege yoceligi, igaataÉĄĖķa ja daÉĄĖķaxa me jawikode minataÉĄĖķa niÉĄĖķina noledi.â 
\p  
\v 25 AbraÃĢo naÉĄĖķa igidi, meeta, âIonigi, analakitibige makati inoatawece anele malee ÉĄĖķadewiki digoida iiÉĄĖķo, iniaa LÃĄzaro inoka dibatege ane beyagi. Pida natigide LÃĄzaro ja ilaÉĄĖķatini, akamaÉĄĖķakaami baanaÉĄĖķa awikodee.  
\v 26 Codaa eleditace ida nelegi wakagi iiÉĄĖķo ane ÉĄĖķodawalacetiwage digoina ÉĄĖķodiwigotigi, aneotibige me daÉĄĖķa yakadi me diÉĄĖķetita ane domaÉĄĖķa yemaa migo digoida daato makaamitaÉĄĖķa, oteÉĄĖķexaaÉĄĖķaÉĄĖķica ane yakadi me niÉĄĖķetita digoina naato mokotaÉĄĖķa.â 
\p  
\v 27 Odaa niÉĄĖķijo liico mee, âEnice, eiodi AbraÃĢo, jipokotaÉĄĖķawa, iiÉĄĖķeni LÃĄzaro digoida liÉĄĖķeladi eiodi.  
\v 28 IgaataÉĄĖķa idiwa nigotini ÉĄĖķobaaÉĄĖķadi inioxoadipi. IiÉĄĖķeni LÃĄzaro me ibodicaxi inioxoadipi me deÉĄĖķenagitibeci niÉĄĖķina anejo me jawikode.â 
\p  
\v 29 AbraÃĢo naÉĄĖķa igidi, meeta, âMiditaÉĄĖķa ÉĄĖķanioxoadipi idiwa notaÉĄĖķanaÉĄĖķaxiidi ane iditedini MoisÃĐs, ijaaÉĄĖķijoa anoidi niÉĄĖķijo anoyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko. Ikani ÉĄĖķanioxoadipi mowajipatalo lotaÉĄĖķa niÉĄĖķijoa notaÉĄĖķanaÉĄĖķaxiidi.â  
\v 30 NiÉĄĖķijo liico mee, âOÉĄĖķoa, eiodi AbraÃĢo, aÉĄĖķowajipatalo. Pida diÉĄĖķica ane yewiÉĄĖķatace, diÉĄĖķigo datematikatema, odaa boÉĄĖķodinilaatece libeyaceÉĄĖķeco.â  
\v 31 Pida AbraÃĢo naÉĄĖķa igidi, meeta, âNige doÉĄĖķowajipatalo niÉĄĖķijoa notaÉĄĖķa ane iditedini MoisÃĐs, ijaaÉĄĖķijoa lidiko niÉĄĖķijo anoyeloÉĄĖķoditedibece lowooko AneotedoÉĄĖķoji, odaa idaaÉĄĖķee diÉĄĖķica ane yewiÉĄĖķatace, idokee doÉĄĖķoyiwaÉĄĖķadi.ââ 
\c 17  
\s1 Jesus diiÉĄĖķaxinaÉĄĖķatetece ica anodaaÉĄĖķee ica ane beyagi 
\r (Mateus 18.6-7, 21-22; Marcos 9.42) 
\p  
\v 1 Jesus meetediogi niÉĄĖķijo anodiotibece, âAjawienatakanaÉĄĖķa midioka limedi menagi aneo niÉĄĖķina oko mowo loenatagi ane beyagi! Pida AneotedoÉĄĖķoji eliodi me iloikatidi niÉĄĖķina aneo eletidi oko mowo ane beyagi.  
\v 2 NiÉĄĖķina aneo anigepidiÉĄĖķica niÉĄĖķina nigaanigipawaanigi mowo ane beyagi, domeÉĄĖķeletema doÉĄĖķoigoetece lotoinaÉĄĖķadi naÉĄĖķana wetiÉĄĖķa ane iwaaÉĄĖķadi, oditaÉĄĖķa oyokoletinigi akiidi-eliodi. Pida daÉĄĖķaxa me beyagitema niÉĄĖķina meo niÉĄĖķina nigaanigipawaanigi moyoe ane beyagi.  
\v 3 Ina baÉĄĖķa adinoetitiwaji! 
\p NiÉĄĖķina ÉĄĖķanioxoa deÉĄĖķeo ane beyagitaÉĄĖķadomi, oxoki. Odaa nige dinilaatibece, ixomaÉĄĖķateenitedice icoatawece niÉĄĖķicoa aneotaÉĄĖķadomi ane beyagi.  
\v 4 DeÉĄĖķeo seete ane beyagitaÉĄĖķadomi noko, odaa seete maÉĄĖķaÉĄĖķa igo makaamitaÉĄĖķa, odaa meetaÉĄĖķawa, âJa idinilaatibeceâ, odaa ixomaÉĄĖķateenitedice icoatawece niÉĄĖķicoa aneo ane beyagitaÉĄĖķadomi.â 
\s1 Jesus diiÉĄĖķaxinaÉĄĖķatetece ica anodaaÉĄĖķee ÉĄĖķotiwaÉĄĖķatakaneÉĄĖķegi 
\p  
\v 5 NiÉĄĖķijoa liiÉĄĖķexedi joÉĄĖķodipokotalo ĮĪoniotagodi, odaa moditalo, âĮĪoniotagodi, ÉĄĖķodaxawaneÉĄĖķegi aleeni ÉĄĖķotiwaÉĄĖķatakaneÉĄĖķegi.â  
\v 6 Odaa ĮĪoniotagodi jeÉĄĖķeetediogi, âNigokateciÉĄĖķini ÉĄĖķatiwaÉĄĖķatakaneÉĄĖķegi, macataÉĄĖķa naÉĄĖķana lolagi âmostaadaâ ane daÉĄĖķaxa me lionawaana, odaa akatitiwaji me iiÉĄĖķeni niale nelegi, me enitatiwaji, âAdinawaceni, odaa emii adinananiti digoida miditaÉĄĖķa akiidi-eliodi!â Odaa naÉĄĖķada niale ÉĄĖķadadiwaÉĄĖķati. 
\s1 Libakedi ica niotagi 
\p  
\v 7 DiÉĄĖķica ganigepidiÉĄĖķijo niÉĄĖķina akaamitiwaji anini ÉĄĖķaotagi ane dibateloco nixoÉĄĖķotagi, oÉĄĖķoa, migetaÉĄĖķa yowie waxacocoli. NiÉĄĖķina naÉĄĖķa dopitio me icoÉĄĖķoticogi nipodigi, migetaÉĄĖķa enita? âAnagi, anicooti madi nameeja, aniodi.â  
\v 8 Pida aÉĄĖķenita! Pida baÉĄĖķa enita, âOenitomi iweenigi, codaa iikoeni ÉĄĖķadowoodi manadeegitiwa iweenigi, aliitiwa nigepaa idiaadi me jiniodi, codaa me jacipe. Odaa nigidiaaÉĄĖķidi baÉĄĖķakamaÉĄĖķa adinediani maniodi, codaa macipe.â  
\v 9 Aleeditibige me iniotagodeeÉĄĖķata niotagi leeÉĄĖķodi niÉĄĖķina meo niÉĄĖķina anoiiÉĄĖķeta me yoe.  
\v 10 Odaa akaamitiwaji idaaÉĄĖķeni. NigidiaaÉĄĖķidi nigagoti mawiite icoatawece niÉĄĖķicoa anetiÉĄĖķadiiÉĄĖķenitalo mawiite, odaa enitiwaji, âAleeditibige doÉĄĖķodiniotagodetoÉĄĖķowa, leeÉĄĖķodi oko niotagipi, codaa jaoÉĄĖķate inokinoa niÉĄĖķinoa anoniiÉĄĖķetedoÉĄĖķowa me jaoÉĄĖķate.ââ 
\s1 Jesus icilatidi deez ÉĄĖķoneleegiwadi dawace-loolatedi 
\p  
\v 11 Jesus eÉĄĖķidaa diitedicogi me diniwiajetedicogi manitaÉĄĖķa nigotaÉĄĖķa JerusalÃĐm. Odaa inaaÉĄĖķigotetece midiwa nipodaÉĄĖķa GalilÃĐia, aniaa Samaria.  
\v 12 NiÉĄĖķijo naÉĄĖķa nipegi me dakatediwece aca nigotakawaana, odaa jiÉĄĖķigotibeci odakapetege icoa deez ÉĄĖķoneleegiwadi dawace-loolatedi. Odaa ja dabiditiniwace, pida leegitiogi moyetecetedice Jesus.  
\v 13 Odaa ja napaawaÉĄĖķa dinigetaÉĄĖķateetibigiwaji, modi, âJesus, ĮĪoniotagodi, ÉĄĖķodiwikodeneÉĄĖķegi!â 
\p  
\v 14 NiÉĄĖķijo Jesus naÉĄĖķa naditediogi, odaa jeÉĄĖķeetediogi, âEmii midiwataÉĄĖķa sacerdotitedi, adinikeenitiogi naÉĄĖķa ÉĄĖķadicilitiwaji.â Odaa eÉĄĖķidaa diiticogi mewaligitibigiwaji, codaaÉĄĖķida naÉĄĖķa nicilaÉĄĖķa. 
\p  
\v 15 Odaa ganigepidiÉĄĖķica niÉĄĖķijoa ÉĄĖķoneleegiwadi naÉĄĖķa nadi me icÃ­, odaa ja dopitege Jesus, igedi me dotaÉĄĖķa, doÉĄĖķetetibigimece AneotedoÉĄĖķoji.  
\v 16 NiÉĄĖķicotalo Jesus, odaa ja yamaÉĄĖķatedini lokotidi lodoe, diniotagodetalo. NiÉĄĖķijo ÉĄĖķoneleegiwa ane diniotagodetalo, samaritaano.  
\v 17 Jesus mee, âIjoa deez ÉĄĖķoneleegiwadi ane nicilaÉĄĖķa. Odaa igame diÉĄĖķetedigi ijoa eletidi noove?  
\v 18 AgodiÉĄĖķica eledi ane dopitijo me doÉĄĖķetetibigimece AneotedoÉĄĖķoji, pida tibiginiokini niÉĄĖķini ane daÉĄĖķa ÉĄĖķodoiigi?â  
\v 19 Odaa Jesus jeÉĄĖķeeteta, âAdabititini, odaaÉĄĖķemii opili! Ja ÉĄĖķadicili, leeÉĄĖķodi me iwaÉĄĖķati AneotedoÉĄĖķoji.â 
\s1 NiÉĄĖķica noko AneotedoÉĄĖķoji nige iolatedicoace oko 
\r (Mateus 24.23-28, 37-41) 
\p  
\v 20 Icoa fariseutedi joÉĄĖķoige Jesus ica AneotedoÉĄĖķoji nige iiÉĄĖķe inatawece niÉĄĖķina oko. NaÉĄĖķa igidi, meetediogi, âAneotedoÉĄĖķoji aÉĄĖķinatawece ikeetediogi nige limedi me iiÉĄĖķe laaleÉĄĖķenali oko.  
\v 21 AÉĄĖķica anee, âDigawini! ĮĪoninionigi-eliodi etiniwa digoina!â OÉĄĖķoa, domigetaÉĄĖķa ee, âĮĪoninionigi-eliodi etiniwa digoidane!â IgaataÉĄĖķa AneotedoÉĄĖķoji iniwa me diiÉĄĖķenataka catiwedi ÉĄĖķadaaleÉĄĖķenali.â 
\p  
\v 22 Odaa jeÉĄĖķeetediogi niÉĄĖķijo anodiotibece, âIcota meliodi memaani madatitace niÉĄĖķica noko Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, nige janagi jiiÉĄĖķe inatawece iiÉĄĖķo, pida aÉĄĖķadatitiwaji.  
\v 23 Odaa niÉĄĖķina eledi oko moditaÉĄĖķawa, âDigawini! Etiniwa digoida!â OÉĄĖķoa, migetoÉĄĖķodi, âEtiniwa digoina!â Pida jineÉĄĖķemiitiwaji, oteÉĄĖķexaaÉĄĖķaÉĄĖķa iwitece.  
\v 24 IgaataÉĄĖķa liciagi nalebepaÉĄĖķa me Ã­di, me naloteloco ditibigimedi onidateci liwai nigepaaÉĄĖķeledi liwai, joaniÉĄĖķidaaÉĄĖķee niÉĄĖķica noko Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, nige janagi me jiiÉĄĖķenataka.  
\v 25 Pida odoejegi, leeditibige me jawikode, codaa niÉĄĖķina oko niÉĄĖķinoa nokododi aÉĄĖķodibatigi. 
\p  
\v 26 NiÉĄĖķica niciagi liciagi niÉĄĖķijoa nokododi NoÃĐ, niÉĄĖķijo jotigide, odaa jiÉĄĖķidaaÉĄĖķee niÉĄĖķicoa nokododi maleedaÉĄĖķa idopitijo Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi.  
\v 27 NiÉĄĖķijo jotigide niÉĄĖķica oko niodaÉĄĖķa, owacipeta viinyo, nadonaÉĄĖķa, codaa moyajigo inoa lionaÉĄĖķa me nadonaÉĄĖķa. Odaa joaniÉĄĖķidaaÉĄĖķee neÉĄĖķepaa niÉĄĖķijo noko NoÃĐ naÉĄĖķa dakatiwece naÉĄĖķajo etogo-nelegi. Odaa neÉĄĖķeno abooÉĄĖķo-ninyoÉĄĖķodi, ja yaaÉĄĖķadi ijotawece niÉĄĖķijo oko.  
\v 28 Eleditace jiÉĄĖķidaaÉĄĖķee niÉĄĖķicoa nokododi LÃģ, niÉĄĖķijo jotigide. Ica oko niodaÉĄĖķa, owacipeta viinyo, oojeteeÉĄĖķa, oyaa elaanaÉĄĖķa, codaa moyoe diimaÉĄĖķa.  
\v 29 Pida niÉĄĖķijo noko LÃģ naÉĄĖķa noditicogi nigotaÉĄĖķa Sodoma, odaa AneotedoÉĄĖķoji jeÉĄĖķeote meniteloco noledi, codaa me wetiadi ane Ã­di, odaa ja nigodi ijotawece niÉĄĖķijo oko.  
\v 30 JoaniÉĄĖķidaaÉĄĖķee niÉĄĖķica noko Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, nige idinikee. 
\p  
\v 31 NiÉĄĖķica noko, niÉĄĖķijo ananipeti ditibigimedi liÉĄĖķeladi, ele me daÉĄĖķa dinikatini me dakatiwece liÉĄĖķeladi daÉĄĖķa dibatalo niÉĄĖķijo ane nepilidi anele, ade dinopaÉĄĖķadi melodi. Odaa niÉĄĖķijo ane ideitice nipodigi aÉĄĖķele daÉĄĖķa dopitio daÉĄĖķa dibatalo ane nepilidi.  
\v 32 Analakitibigetiwaji ane ninyaagi naÉĄĖķajo LÃģ lodawa! (Ane yeleo, leeÉĄĖķodi me dinopaÉĄĖķadi meo ane liiÉĄĖķenatakaneÉĄĖķegi AneotedoÉĄĖķoji).  
\v 33 NiÉĄĖķina oko anidioka limedi me doletibige mepaa iiÉĄĖķe lewiÉĄĖķa, nige yeleo, odaa jaÉĄĖķaniatagigi. Pida niÉĄĖķina oko ane yeleo me Ee leeÉĄĖķodi, odaa baÉĄĖķa yewiÉĄĖķatace nigidiaaÉĄĖķidi.  
\v 34 Natigide jeloÉĄĖķoditedaÉĄĖķawatiwaji niÉĄĖķinoa notaÉĄĖķa anida ane jaoÉĄĖķate. NiÉĄĖķica enoale itiwataale oko dinoomatewamigi, niotaÉĄĖķa. Onijoteci oyadeegitibigi, idiaaÉĄĖķeledi baÉĄĖķa nenyaÉĄĖķati.  
\v 35 Iniwataale iwaalepodi onidi leyeema. Onaniteci oyadeegitibigi, aniaaÉĄĖķeledi baÉĄĖķa nenyaÉĄĖķati.  
\v 36 Itoataale ÉĄĖķoneleegiwadi nibaaÉĄĖķa nipodigi. Odaa onidateci oyadeegitibigi, odaa idaaÉĄĖķeledi baÉĄĖķa nenyaÉĄĖķati.â 
\p  
\v 37 Odaa niÉĄĖķijo anodiotibece joÉĄĖķoige, moditalo, âĮĪoniotagodi, igamei nige jinataÉĄĖķa ida niciagi?â Odaa jeÉĄĖķeetediogi, âAnei anigidi ÃĐmeÉĄĖķegi, odaa jiÉĄĖķidiaaÉĄĖķi me dilapode opoedi.â (Odaa jiÉĄĖķidaa me jowooÉĄĖķotaÉĄĖķa ane diÉĄĖķetigi ganigidi ÃĐmeÉĄĖķegi, leeÉĄĖķodi me jinataÉĄĖķa opoedi). 
\c 18  
\s1 Jesus yatemati ica natematigo ane yalaÉĄĖķata ica ÉĄĖķoniwinoÉĄĖķodi acaaÉĄĖķaca wajekalo 
\p  
\v 1 Jesus yatemati ica natematigo ane ÉĄĖķodiiÉĄĖķaxitece me leeditibige niÉĄĖķina oko midioka limedi me doÉĄĖķoibagitema moyotaÉĄĖķaneÉĄĖķe AneotedoÉĄĖķoji.  
\v 2 Odaa jeÉĄĖķeetediogi, âManitaÉĄĖķa aca nigotaÉĄĖķa onini ica ÉĄĖķoniwinoÉĄĖķodi ane daÉĄĖķa deemitetibige AneotedoÉĄĖķoji, codaa aÉĄĖķica ane deemitetigi.  
\v 3 NaÉĄĖķani nigotaÉĄĖķa onani aca wajekalo. Anidioka limedi me doletibige niÉĄĖķini ÉĄĖķoniwinoÉĄĖķodi, dipokota me yaxawa, codaa idioka limedi meetibiga, âAdaxawani, codaa awii niÉĄĖķica ane ilaÉĄĖķatice me jakapetege yaxakawa.â  
\v 4-5 IgaanoÉĄĖķowidi nokododi ixomaÉĄĖķatedijo me daÉĄĖķa niniÉĄĖķodi ane yemaa. Odaa niÉĄĖķidiaaÉĄĖķidi epaa dinotaÉĄĖķaneÉĄĖķe, mee, âDigo aneji me daÉĄĖķa idoitalo AneotedoÉĄĖķoji, codaa me diÉĄĖķica ane jeemitetibige, jaxawa naÉĄĖķajo wajekalo, leeÉĄĖķodi jeÉĄĖķeliodi me idigiwogotice. DaaditaÉĄĖķa jaxawa, odaa idioka limedi me doletibigiji, pida jeÉĄĖķeliodi me idigiwogotice.ââ 
\p  
\v 6 Odaa ĮĪoniotagodi jeÉĄĖķeetediogi, âDige atacolitece lotaÉĄĖķa niÉĄĖķijo ÉĄĖķoniwinoÉĄĖķodi aiÉĄĖķenaÉĄĖķa.  
\v 7 Ajawienataka AneotedoÉĄĖķoji me yaxawa loiigi, anodipokotibigalo, noko codaa menoale, me yaxawatediogi, odaa eotetema niÉĄĖķica ane iÉĄĖķenaÉĄĖķa modakapetege laxakawepodi. OÉĄĖķoa domige dinopaÉĄĖķadi nige yaxawatediogi idi loiigi?  
\v 8 Pida ejitaÉĄĖķawatiwaji me age me yaxawa, codaa meote ane iÉĄĖķenaÉĄĖķa modakapetege laxakawepodi. Odaa Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, nige janagitace, migica jakadi oko anetidadiwaÉĄĖķadi digoina iiÉĄĖķo?â 
\s1 Jesus yatemati ica natematigo ane yalaÉĄĖķata ica fariseu, icaaÉĄĖķica ica ane dibatibigege ninyeelo ninionigi-eliodi romaanotedi 
\p  
\v 9 Jesus yatematitediogi ica eledi natematigo niÉĄĖķica oko anodiletibige daÉĄĖķa daÉĄĖķaxa meletibigiwaji, pida inaaÉĄĖķina anoiligoiticoace eledi oko.  
\v 10 Odaa jeÉĄĖķee, âIcoa itoataale ÉĄĖķoneleegiwadi igotibeci AneotedoÉĄĖķoji liÉĄĖķeladi moyotaÉĄĖķaneÉĄĖķe. Onijoteci fariseu, ica eledi baÉĄĖķa niÉĄĖķina ane dibatibigege ninyeelo ninionigi-eliodi romaanotedi. 
\p  
\v 11 NiÉĄĖķijo fariseu naÉĄĖķa dabiditi odaa dinigetaÉĄĖķatee mepaa dinotaÉĄĖķaneÉĄĖķe, mee, âAneotedoÉĄĖķoji, iniotagodetaÉĄĖķawa, leeÉĄĖķodi aÉĄĖķee oko adodigomadaÉĄĖķa, oteÉĄĖķexaaÉĄĖķaÉĄĖķa ee oko ane daÉĄĖķa iÉĄĖķenaÉĄĖķa, oteÉĄĖķexaaÉĄĖķaÉĄĖķa ee oko ane itineÉĄĖķe lodawa eledi, digo anee niÉĄĖķinoa eletidi ÉĄĖķoneleegiwadi. Eleditace iniotagodetaÉĄĖķawa aiciagi niÉĄĖķida ÉĄĖķoneleegiwa ane dibatibigege ninyeelo ninionigi-eliodi romaanotedi.  
\v 12 Idinatita nigigi itoataale nokododi inoatawece domiingotedi, codaa me inidiizimo jajigotaÉĄĖķawa.â 
\p  
\v 13 NiÉĄĖķijo ane dibatibigege ninyeelo ninionigi-eliodi romaanotedi, idiaaÉĄĖķaÉĄĖķa itice, pida aÉĄĖķipegitege. Odaa oteÉĄĖķexaaÉĄĖķaÉĄĖķa iwitibigimece ditibigimedi. Pida yabaketibigeloco elipije me ikee magecaÉĄĖķalo, odaa jeÉĄĖķee, âAneotedoÉĄĖķoji, adiwikodeni, leeÉĄĖķodi eemoda abeyaceÉĄĖķegi.â  
\v 14 EjitaÉĄĖķawatiwaji, niÉĄĖķijo ÉĄĖķoneleegiwa noÉĄĖķopiticogi minitaÉĄĖķa liÉĄĖķeladi, AneotedoÉĄĖķoji jeÉĄĖķeote me iÉĄĖķenaÉĄĖķa. Pida niÉĄĖķijo eledi AneotedoÉĄĖķoji aÉĄĖķeote me iÉĄĖķenaÉĄĖķa. LeeÉĄĖķodi niÉĄĖķijo oneo mida ane jaoÉĄĖķa, icota moyame, pida niÉĄĖķijo ane diniwikodetibece, AneotedoÉĄĖķoji icota me iweniÉĄĖķide.â 
\s1 Jesus dibatetege nigaanigipawaanigi 
\r (Mateus 19.13-15; Marcos 10.13-16) 
\p  
\v 15 Ica noko eliodi oko oyadeegi nigaanigipawaanigi midoataÉĄĖķa Jesus, owotibige me dibatedeloco me ibinie. Pida niÉĄĖķijo anodiotibece noÉĄĖķonadi, odaa joÉĄĖķoyolitege niÉĄĖķijo anonadeegi nigaanigipawaanigi.  
\v 16 Pida Jesus eniditediogi niÉĄĖķijo nigaanigipawaanigi mototalo, odaa jeÉĄĖķee, âIkani niÉĄĖķina nigaanigipawaanigi menagitibeci meetaÉĄĖķa, codaa jinoÉĄĖķoliitege, leeÉĄĖķodi AneotedoÉĄĖķoji iiÉĄĖķe laaleÉĄĖķenali niÉĄĖķina ane liciagi niÉĄĖķina nigaanigipawaanigi.  
\v 17 EjitaÉĄĖķawatiwaji niÉĄĖķina anewi, niÉĄĖķina ane ikatece AneotedoÉĄĖķoji me iiÉĄĖķe laaleÉĄĖķena, liciagi niÉĄĖķina nigaanigawaanigi me dibatege niÉĄĖķina anodita, odaa niÉĄĖķini oko baÉĄĖķa yakadi me dakatiwece AneotedoÉĄĖķoji aneitedice digoida ditibigimedi.â 
\s1 Ica ÉĄĖķoneleegiwa liico 
\r (Mateus 19.16-30; Marcos 10.17-31) 
\p  
\v 18 Ica ÉĄĖķoneleegiwa ane lacilo judeutedi, igo ige Jesus, meetalo, âĮĪoniiÉĄĖķaxinoÉĄĖķodi anele, amiida ica ane leeditibige me jao, odaa jiÉĄĖķidaa yewiÉĄĖķa digoida ditibigimedi miniwataÉĄĖķa AneotedoÉĄĖķoji?â  
\v 19 Jesus naÉĄĖķa igidi, meeteta, âIgame leeÉĄĖķodi ina menitiwa me Ee ele? Oniniwatece AneotedoÉĄĖķoji mele, aÉĄĖķica eledi anele.  
\v 20 Codaa noÉĄĖķowooÉĄĖķoti ijoa liiÉĄĖķenatakaneÉĄĖķeco AneotedoÉĄĖķoji, anodi, âJinaÉĄĖķaÉĄĖķolaÉĄĖķatakani, jinaÉĄĖķa aijee, jinoÉĄĖķolice, jiniÉĄĖķinaaleni eledi oko. Codaa eemiteetibige ÉĄĖķadiodi, codaa me ÉĄĖķadiodo.ââ  
\v 21 Odaa niÉĄĖķijo ÉĄĖķoneleegiwa mee, âNiÉĄĖķijo maleeÉĄĖķee nigaanigawaanigi naÉĄĖķa jeemitetibige ijoatawece niÉĄĖķijoa liiÉĄĖķenatakaneÉĄĖķeco AneotedoÉĄĖķoji.â 
\p  
\v 22 NiÉĄĖķijo Jesus naÉĄĖķa wajipateta niÉĄĖķijoa lotaÉĄĖķa, odaa jeÉĄĖķeete, âEÉĄĖķidaa ananiaditibige mawii. Aani idiwatawece niÉĄĖķicoa ane ÉĄĖķanepilidi, odaa edianitiniwace madewetedi ÉĄĖķaninyeelo. Odaa jaÉĄĖķakati ÉĄĖķaniliicaÉĄĖķajetecidi digoida ditibigimedi. Odaa nigidiaaÉĄĖķidi odaaÉĄĖķanagi, aniwitici!â  
\v 23 NiÉĄĖķijo ÉĄĖķoneleegiwa naÉĄĖķa wajipatalo niÉĄĖķijoa lotaÉĄĖķa Jesus, odaa eliodi magecaÉĄĖķalo, leeÉĄĖķodi owidi niÉĄĖķicoa niliicaÉĄĖķajetecidi. 
\p  
\v 24 Jesus nadi meliodi magecaÉĄĖķalo, odaa jeÉĄĖķee, âIca me dakake niÉĄĖķinoa liicotedi moika AneotedoÉĄĖķoji me iiÉĄĖķe laaleÉĄĖķenali.  
\v 25 AÉĄĖķica laÉĄĖķaliigi gameelo me ixomaÉĄĖķatiwece etakado libegi. Pida baÉĄĖķa dakake ÉĄĖķoneleegiwa liico me ikatece AneotedoÉĄĖķoji me iiÉĄĖķe laaleÉĄĖķena.â 
\p  
\v 26 NiÉĄĖķijo anowajipatalo niÉĄĖķijoa lotaÉĄĖķa ja nigikanaÉĄĖķa, modi, âEnice, amiijo ica ane yakadi midioka limedi me yewiÉĄĖķa miniwataÉĄĖķa AneotedoÉĄĖķoji?â  
\v 27 Odaa Jesus meetediogi, âNiÉĄĖķina anoyakadi niÉĄĖķina oko me diÉĄĖķica nimaweneÉĄĖķegi moyoe, pida AneotedoÉĄĖķoji biÉĄĖķida nimaweneÉĄĖķegitetece me yoe.â 
\p  
\v 28 Odaa Pedro mee, âDigawini! Ja jikanaÉĄĖķatedice ijoatawece ane ÉĄĖķonepilidi, odaa ja jiwaÉĄĖķatibigaÉĄĖķadici.â  
\v 29 Odaa Jesus meetediogi, âEjitaÉĄĖķawatiwaji niÉĄĖķina anewi, inatawece oko ane daÉĄĖķadiaaÉĄĖķewianaÉĄĖķa niwita liÉĄĖķeladi, eliododipi, nioxoadipi, lodawa, idiaa lionigipi, meotibige me iiÉĄĖķe AneotedoÉĄĖķoji laaleÉĄĖķenali niÉĄĖķina eledi oko,  
\v 30 NiÉĄĖķidi AneotedoÉĄĖķoji yajigotediogi caticedi niÉĄĖķijoa baanoÉĄĖķoikatedice, niÉĄĖķina malee newiÉĄĖķa digoina, codaa aaÉĄĖķaÉĄĖķeote niÉĄĖķina oko midioka limedi me newiÉĄĖķa miniwataÉĄĖķa digoida ditibigimedi.â 
\s1 Jesus eetacetece lawikodico anicotece nigidiaaÉĄĖķidi 
\r (Mateus 20.17-19; Marcos 10.32-34) 
\p  
\v 31 Jesus yadeegi ijokijo niÉĄĖķijo anodiotibece, odaa meetediogi, âDigawini! JiÉĄĖķiniÉĄĖķa JerusalÃĐm, odaa digoida jiÉĄĖķidiaaÉĄĖķi nige jawikode, Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, icotece niÉĄĖķicoa anoiditedini, niÉĄĖķijo anoyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko niÉĄĖķijo jotigide aneetici.  
\v 32 Etidajigotiogi niÉĄĖķidi ane daÉĄĖķa judeutedi, odaa oyametibigiji, etidiweenigetice, codaa metidawaletice.  
\v 33 Etidalaketigi, odaa nigidiaaÉĄĖķidi jeÉĄĖķetideloadi. Pida nige ixomaÉĄĖķatedice itoatadiÉĄĖķida nokododi, odaa ja idewiÉĄĖķatace.â 
\p  
\v 34 NiÉĄĖķijo anodiotibece aÉĄĖķoyowooÉĄĖķodi niÉĄĖķijoa Jesus lotaÉĄĖķa. OyaÉĄĖķaditema niÉĄĖķica ane diitigilo niÉĄĖķijoa lotaÉĄĖķa, odaa aÉĄĖķoyowooÉĄĖķodi niÉĄĖķica Jesus aneyatedigi ligegi. 
\s1 Jesus icilatidi ica ÉĄĖķolaÉĄĖķa awikotaagi 
\r (Mateus 20.29-34; Marcos 10.46-52) 
\p  
\v 35 Jesus niÉĄĖķipegitedio nigotaÉĄĖķa JericÃģ. Odaa onini ica ÉĄĖķoneleegiwa etoinaÉĄĖķa nicotinece liniogotibece naigi, dipokotibige dinyeelo.  
\v 36 NiÉĄĖķina me wajipatece niÉĄĖķina noiigi me ixomaÉĄĖķatijo, odaa ja digika, digikatece anigina ica ane enagi.  
\v 37 Odaa modita, âJesus niÉĄĖķijoa ane icoÉĄĖķotedicogi NazarÃĐ, inaaÉĄĖķenagitetece digoina!â  
\v 38 Odaa dinigetaÉĄĖķatee me dapaawe, mee, âJesus, anida anenitege licoÉĄĖķegi Davi, adiwikodenita!â  
\v 39 Odaa niÉĄĖķijo noiigi ane dinewadetibigiwaji joÉĄĖķoyoxoÉĄĖķo niÉĄĖķijo ÉĄĖķolaÉĄĖķa, domoÉĄĖķoiiÉĄĖķe me notoko. Pida jeÉĄĖķepaanaÉĄĖķa dapaawe, mee, âAkaami anida anenitege licoÉĄĖķegi Davi, adiwikodenita!â  
\v 40 Odaa Jesus ja dabiditedi, ja diiÉĄĖķenatakate monadeegitalo niÉĄĖķijo ÉĄĖķolaÉĄĖķa. NaÉĄĖķa nipegitalo, odaa Jesus ja ige, meeteta,  
\v 41 âAmiina ica anemaani mejigotaÉĄĖķawa?â Odaa jeÉĄĖķee, âIniotagodi, jemaa me jatetibece.â  
\v 42 Odaa Jesus jeÉĄĖķeete, âAnoleetice, odaa jaÉĄĖķatenitibece! AneotedoÉĄĖķoji ÉĄĖķadicilatiti, leeÉĄĖķodi madinakatoni.â  
\v 43 Odaa aÉĄĖķica daÉĄĖķa leegi, niÉĄĖķijo ÉĄĖķoneleegiwa ja yatetibece, odaa ja diotece Jesus, codaa doÉĄĖķetetibigimece AneotedoÉĄĖķoji. Odaa ijotawece niÉĄĖķijo noiigi-nelegi noÉĄĖķonadi niÉĄĖķijo Jesus loenatagi, odaa joÉĄĖķodoÉĄĖķetetibigimece AneotedoÉĄĖķoji. 
\c 19  
\s1 Jesus igo aniodi Zaqueu liÉĄĖķeladi 
\p  
\v 1 Jesus dakatediwece nigotaÉĄĖķa JericÃģ, yakagiditedeloco naÉĄĖķani nigotaÉĄĖķa.  
\v 2 Onini ica ÉĄĖķoneleegiwa liboonaÉĄĖķadi Zaqueu, lacilo niÉĄĖķijo anodibatibigege ninyeelo ninionigi-eliodi romaanotedi. Zaqueu one liico.  
\v 3 Odaa domaÉĄĖķa yemaa me nadi anidoa icoa Jesus, pida ayakadi me nadi leeÉĄĖķodi niÉĄĖķidi noiigi, ibeyacaÉĄĖķadi me daÉĄĖķaxa moxiiÉĄĖķotawaanigi.  
\v 4 Odaa jona walokoditicogi lodoe niÉĄĖķidi noiigi, odaa ja dalaÉĄĖķatetibigimece aca niale, fiigoigo loidena, eotibige me yakadi me nadi Jesus, leeÉĄĖķodi idiaaÉĄĖķigotetece digoida aneitice me dalaÉĄĖķate. 
\p  
\v 5 NiÉĄĖķijo Jesus niÉĄĖķicotedicogi digoida aneitice, naÉĄĖķa iwitedibigimece ditibigimedi, odaa jeÉĄĖķeeteta, âZaqueu, adinageni madaxotiti, igaataÉĄĖķa leeditibige midiaaÉĄĖķejo ÉĄĖķadiÉĄĖķeladi niÉĄĖķina noko.â \fig |src="CN01776B.TIF" size="span" copy="ÂĐ 1978 David C. Cook Publishing Co." ref="Lucas 19.5" \fig* 
\v 6 Odaa ja yediiÉĄĖķa me waxoditice, odaa ja dibatege Jesus digoida liÉĄĖķeladi, codaa eliodi me ninitibece.  
\v 7 Ijotawece niÉĄĖķijo anonadi Jesus me lixigaÉĄĖķawa Zaqueu, dinoxatiwage, modi, âIgo aniodi digoida liÉĄĖķeladi niÉĄĖķijo ÉĄĖķoneleegiwa anowidi libeyaceÉĄĖķeco.â 
\p  
\v 8 NaÉĄĖķa dabiditi Zaqueu, odaa jeÉĄĖķeetalo ĮĪoniotagodi, âDigawini, Iniotagodi! Natigide jajigotiogi madewetedi liwigotigi inoa ane inepilidi. Pida nigica ane jinaale me inoÉĄĖķa ninyeelo, jopilaÉĄĖķaditace cwaatolo mopitibigeloco niÉĄĖķijoa dinyeelo ane jibanootece.â  
\v 9 Odaa Jesus jeÉĄĖķeeteta, âNiÉĄĖķina noko AneotedoÉĄĖķoji eote niÉĄĖķina oko ane liÉĄĖķeladi niÉĄĖķina diimigi midioka limedi me newiÉĄĖķa miniwataÉĄĖķa. IgaataÉĄĖķa akaami eledi ida anenitege ane licoÉĄĖķegi mijotaÉĄĖķa AbraÃĢo.  
\v 10 IgaataÉĄĖķa Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, janagitiogi me jao lewiÉĄĖķa miniwataÉĄĖķa AneotedoÉĄĖķoji niÉĄĖķijo aniatagigipi, codaa me ane leegitalo moyototedice AneotedoÉĄĖķoji.â 
\s1 Jesus yatemati icoa deez beexotedi oolo 
\r (Mateus 25.14-30) 
\p  
\v 11 Odaa niÉĄĖķijo noiigi noÉĄĖķowajipatalo ijoa lotaÉĄĖķa, odaa Jesus ja yatemati ica natematigo ane ÉĄĖķodiiÉĄĖķaxi. NiÉĄĖķijo noÉĄĖķodipegita JerusalÃĐm, odaa joÉĄĖķodiletibige daantaÉĄĖķa nipegi ica nige iiÉĄĖķe AneotedoÉĄĖķoji inatawece oko. JoaniÉĄĖķidaa leeÉĄĖķodi Jesus naÉĄĖķa yatemati niÉĄĖķida natematigo.  
\v 12 Mee, âOnini ica ÉĄĖķoneleegiwa ica loiigiwepodi one niÉĄĖķinoa ÉĄĖķoneÉĄĖķaÉĄĖķa. One igo miditaÉĄĖķa eledi iiÉĄĖķo digoida ditigedi, eotibige moixotio me ninionigi-eliodi niÉĄĖķidi epaa nipodigi. Odaa ja dopitijo.  
\v 13 AniÉĄĖķicatibige daÉĄĖķa diniwiaje, odaa jeÉĄĖķeniditiogi deez liimetedi. Odaa yajigota oninitecibeci onaniteci beexo oolo, odaa meetiogi, âAbakeni niÉĄĖķinoa dinyeelo bidige owidi nigepaa idopitijo.â  
\v 14 Pida niÉĄĖķidi loiigi ane ideitice miditaÉĄĖķa niiÉĄĖķo aÉĄĖķoyemaa me ninionigi-eliodi. Odaa joÉĄĖķoiomaÉĄĖķaditicoace icoa ÉĄĖķoneleegiwadi, odaa joÉĄĖķoiiÉĄĖķeticogi niÉĄĖķidi oko me igotibeci digoida miditaÉĄĖķa eledi iiÉĄĖķo moyeloÉĄĖķodita niÉĄĖķijo ane domaÉĄĖķa ixotio niÉĄĖķijo ÉĄĖķoneleegiwa me inionigi-eliodi. OyeloÉĄĖķodita me doÉĄĖķoyemaa niÉĄĖķijo ÉĄĖķoneleegiwa ane domaÉĄĖķa ixotio me ninionigi-eliodi niÉĄĖķidi noiigi. 
\p  
\v 15 NiÉĄĖķijo ÉĄĖķoneleegiwa naÉĄĖķa dopitijo, ja ninionigi-eliodi niÉĄĖķijo ane daÉĄĖķa domoÉĄĖķoyemaa. NiÉĄĖķijo naÉĄĖķa dopitijo, odaa jeÉĄĖķeniditiogi niÉĄĖķijoa liimetedipi ane yajigotiogi ninyeelo, leeÉĄĖķodi yemaa me yowooÉĄĖķodi niÉĄĖķica ane liwokodi dinyeelo anowote moibake niÉĄĖķijoa beexotedi oolo.  
\v 16 NiÉĄĖķijo odoejegi limeedi neÉĄĖķenota, meeta, âIniotagodi, jakaditedaÉĄĖķadomi deez beexotedi me jibake naÉĄĖķajo beexo ananajicitiwa.â  
\v 17 Odaa niÉĄĖķijo inionigi-eliodi meeta, âJiÉĄĖķidiaaÉĄĖķi! Akaami nimeedi anele! JaÉĄĖķanikeenitiwa me jakadi me ÉĄĖķadinakatoni, mele mawii niÉĄĖķijo ane jajigotaÉĄĖķawa me ÉĄĖķabaketawaanigi. JoaniÉĄĖķidaa leeÉĄĖķodi ÉĄĖķadixomitio me iiÉĄĖķeni deez nigotadi.â  
\v 18 Odaa niÉĄĖķijo eledi limeedi naÉĄĖķaÉĄĖķa enota, meeta, âIniotagodi, jakaditedaÉĄĖķadomi ciinco beexotedi me jibake naÉĄĖķajo ananajicitiwa beexo.â  
\v 19 Odaa jaÉĄĖķaÉĄĖķa eeta niÉĄĖķijo ninionigi-eliodi, âJiÉĄĖķidiaaÉĄĖķi! JajigotaÉĄĖķawa me iiÉĄĖķeni ciinco nigotadi.â 
\p  
\v 20 Odaa niÉĄĖķijo eledi nimeedi naÉĄĖķaÉĄĖķa enota, meeta, âDigawini, Iniotagodi! Etani naÉĄĖķajo ÉĄĖķanibeexo. Jilipaditigi leenxo, odaa ja jotete.  
\v 21 IgaataÉĄĖķa idoitaÉĄĖķawa, leeÉĄĖķodi makaami ÉĄĖķoneleegiwa ane dakake laaleÉĄĖķena. Akati manoÉĄĖķaa niÉĄĖķina ane daÉĄĖķa ÉĄĖķanebi, codaa anopilaÉĄĖķatitio ane daÉĄĖķa ÉĄĖķatanigijegi.â  
\v 22 Odaa niÉĄĖķijo inionigi-eliodi meeta, âAkaami nimeedi ane beyagi! NiÉĄĖķinoa ÉĄĖķadotaÉĄĖķa ja ikee makaami beyagi. OwooÉĄĖķoti me ee ÉĄĖķoneleegiwa ane dakake laaleÉĄĖķena, me inoÉĄĖķa ane daÉĄĖķa inebi, codaa inopilaÉĄĖķaditio niÉĄĖķina ane daÉĄĖķa eyanigijegi.  
\v 23 Enice, igaamee daÉĄĖķajicitiogi ijoa ininyeelo niÉĄĖķina anonadila dinyeelo modoletibige me gaanyaÉĄĖķa? DaÉĄĖķajicitiogi, odaa naÉĄĖķa idopitijo, otaÉĄĖķaÉĄĖķa jibatacege ininyeelo codaa me niÉĄĖķicoa ane ÉĄĖķanigaanye.â 
\p  
\v 24 Odaa niÉĄĖķijo inionigi-eliodi jeÉĄĖķeetiogi niÉĄĖķijo anowalitibigege niÉĄĖķica ligegi, meetiogi, âAnoÉĄĖķaa naÉĄĖķani nibeexo, odaa ajicitiogi niÉĄĖķijo anidiwa deez nibeexotedi.â  
\v 25 Odaa joÉĄĖķodita, âPida ĮĪoniotagodi, jiÉĄĖķidiwa deez nibeexotedi.â  
\v 26 Odaa jeÉĄĖķee, âDe jeloÉĄĖķoditaÉĄĖķawatiwaji, niÉĄĖķijo anidiwa, odaa alee dibatege eletidi. Pida niÉĄĖķijo ane diÉĄĖķicoa, icaaÉĄĖķica onateciÉĄĖķidi ane nebi pida oibanootece.  
\v 27 Natigide, anadeegitediwa niÉĄĖķicoa idelaÉĄĖķawepodi ane daÉĄĖķa domoÉĄĖķoyemaa me ee ninionigi-eliodi, odaa anigoti digoina yodoe.ââ 
\s1 Jesus dakatediwece nigotaÉĄĖķa JerusalÃĐm 
\r (Mateus 21.1-11; Marcos 11.1-11; JoÃĢo 12.12-19) 
\p  
\v 28 NiÉĄĖķijo Jesus neÉĄĖķee niÉĄĖķijoa lotaÉĄĖķa, odaa ja dinewade, dalaÉĄĖķatetedibigimece nalaÉĄĖķate JerusalÃĐm.  
\v 29 NaÉĄĖķa icotediogi icoa nigotadawaanaÉĄĖķa ane liboonaÉĄĖķadi BetfagÃĐ, aniaa BetÃĒnia, anipegitiwage odipegitege ica lojotaÉĄĖķadi ane liboonaÉĄĖķadi âLojotaÉĄĖķadi Oliveiraâ. NiÉĄĖķijo niÉĄĖķipegitediogi, odaa ja iiÉĄĖķe itoataale niÉĄĖķijo anodiotibece.  
\v 30 Meetediogi, âEmii nigepaa midiwataÉĄĖķa nigotadawaanaÉĄĖķa digoida ÉĄĖķododoe. Nigakaatiotiwaji, odaa jaÉĄĖķakati boliicawaanigi dinigoetini, analeediÉĄĖķica mowaxoditeloco. Owileceni ini boliicawaanigi, odaa anadeegiticogi digoina meetaÉĄĖķa.  
\v 31 Nigica ane ÉĄĖķadigeetiwaji, nigeetaÉĄĖķawa, âIgaamenitiwaji ina mowileceni ini boliicawaanigi?â Odaa enita, âJowilecenaÉĄĖķa ini boliicawaanigi leeÉĄĖķodi ĮĪoniotagodi yopotedibige.ââ 
\p  
\v 32 Odaa jiÉĄĖķigotibeci niÉĄĖķijo ane iiÉĄĖķetedibigiwaji, odaa joÉĄĖķoyakadi niÉĄĖķijo aneyatedigi Jesus ligegi.  
\v 33 NiÉĄĖķijo naÉĄĖķa oikatice niÉĄĖķijo boliicawaanigi, odaa niÉĄĖķica ane nebi ja nigikanaÉĄĖķa, modi, âIgame leeÉĄĖķodi ina mowileceni ini boliicawaanigi?â  
\v 34 Odaa joÉĄĖķoigidi, modita, âJowilecenaÉĄĖķa niÉĄĖķini boliicawaanigi leeÉĄĖķodi ĮĪoniotagodi yopotedibige.â  
\v 35 Odaa joÉĄĖķoyadeegi boliicawaanigi midoataÉĄĖķa Jesus, niÉĄĖķidiaaÉĄĖķidi joÉĄĖķoyexaÉĄĖķateloco nijayogoli lelÃĄÉĄĖķa niÉĄĖķijo boliicawaanigi. Odaa joÉĄĖķoyadodi Jesus me waxoditedibige.  
\v 36 IgaanaÉĄĖķa onaditege Jesus, odaa niÉĄĖķidi noiigi oipecetinigi iiÉĄĖķo nijayogoli naigitinece, owotibige moikee moiweniÉĄĖķide. 
\p  
\v 37 NiÉĄĖķipegitedio nigotaÉĄĖķa JerusalÃĐm, naÉĄĖķa idinikanaÉĄĖķatinece minitaÉĄĖķa lojotaÉĄĖķadi aninoa icoa nialeli âoliveiraâ, anodita âLojotaÉĄĖķadi Oliveiraâ. NiÉĄĖķijo niÉĄĖķico niÉĄĖķica noiigi-nelegi anodiotibece ninitibigiwaji, odigaanaÉĄĖķatibigimece AneotedoÉĄĖķoji me dinigetaÉĄĖķateetibigiwaji leeÉĄĖķodi ijoatawece niÉĄĖķijoa ÉĄĖķodoxiceÉĄĖķetedi libinienaÉĄĖķa baaniÉĄĖķijo monadi.  
\v 38 Odaa modi niÉĄĖķijo noiigi, 
\q1 âJemaanaÉĄĖķa AneotedoÉĄĖķoji meote aneletema niÉĄĖķiniwa inionigi-eliodi anida naÉĄĖķatetigi aneitelogo LiboonaÉĄĖķadi ĮĪoniotagodi AneotedoÉĄĖķoji. 
\q1 Inoatawece aninoa digoida ditibigimedi idioka limedi me ilaÉĄĖķatiwage. 
\q1 JoÉĄĖķeeÉĄĖķatibigimece ane ideitedice ditibigimedi.â 
\p  
\v 39 Odaa onicoa icoa fariseutedi, anidiaaÉĄĖķi liwigotigi niÉĄĖķidi noiigi-nelegi, onoditalo Jesus, âNiiÉĄĖķaxinaÉĄĖķanaÉĄĖķa! Oxoki niÉĄĖķidi anodiotibigaÉĄĖķadici leeÉĄĖķodi niÉĄĖķinoa lotaÉĄĖķa.â (LeeÉĄĖķodi aÉĄĖķoyemaa modi Jesus me inionigi-eliodi.)  
\v 40 Odaa ja igidi, meetediogi, âEjitaÉĄĖķawatiwaji daÉĄĖķa notokotiniwace, odaa niÉĄĖķinoa wetiadi jaÉĄĖķaÉĄĖķa napaawaÉĄĖķateloco modoÉĄĖķetetibigimece AneotedoÉĄĖķoji!â 
\s1 Jesus anoe leeÉĄĖķodi me iwikode niÉĄĖķeladimigipitigi JerusalÃĐm 
\p  
\v 41 NiÉĄĖķijo Jesus niÉĄĖķipegite nigotaÉĄĖķa, naÉĄĖķa naditeta naÉĄĖķani nigotaÉĄĖķa, odaa jaÉĄĖķanoe leeÉĄĖķodi ane ninyaagi nigidiaaÉĄĖķidi niÉĄĖķidi niÉĄĖķeladimigipitigi nigotaÉĄĖķa.  
\v 42 Odaa jeÉĄĖķee, âNiÉĄĖķida me Ee domaÉĄĖķa jemaa mowooÉĄĖķoti niÉĄĖķina noko niÉĄĖķica ane leeditibige mawii makatitiwaji AneotedoÉĄĖķoji me daÉĄĖķalee yelatedaÉĄĖķadomi. Pida niÉĄĖķina natigide aÉĄĖķaleeÉĄĖķakatitiwaji manati niÉĄĖķica ane leeditibige mawii.  
\v 43 LeeÉĄĖķodi icotalo nokododi ÉĄĖķadaxakawepodi onojotaÉĄĖķadi iiÉĄĖķo moyolitaÉĄĖķagitiwaji manotiticogi we nigotaÉĄĖķa. JiÉĄĖķidaaÉĄĖķee nigonoxocotaÉĄĖķagitiwaji, etiÉĄĖķadiligicenitiwaji inoatawece ÉĄĖķawailidi.  
\v 44 Odaa joÉĄĖķoyaaÉĄĖķadi anitawece ÉĄĖķanigotaÉĄĖķatiwaji, codaa makaamitawece anakaami niÉĄĖķeladimigipi. Odaa aÉĄĖķaca nenyaÉĄĖķati otaÉĄĖķanitece wetiÉĄĖķa ane waxoditeloco eledi, leeÉĄĖķodi aÉĄĖķemaani mowooÉĄĖķoti NiÉĄĖķijoa AneotedoÉĄĖķoji ane niiÉĄĖķe me dalitaÉĄĖķawatiwaji LiiÉĄĖķexegi me domeÉĄĖķeotedaÉĄĖķadomi anele.â 
\s1 Ica Jesus aneote digoida AneotedoÉĄĖķoji liÉĄĖķeladi 
\r (Mateus 21.12-17; Marcos 11.15-19; JoÃĢo 2.13-22) 
\p  
\v 45 Jesus naÉĄĖķa dakatediwece AneotedoÉĄĖķoji liÉĄĖķeladi, odaa ja niticoitedicoace icoa anoojetekaÉĄĖķa anidiaaÉĄĖķite.  
\v 46 Odaa jeÉĄĖķeetediogi, âLotaÉĄĖķanaÉĄĖķaxi AneotedoÉĄĖķoji diniditeloco niÉĄĖķica AneotedoÉĄĖķoji ane ligegi, niÉĄĖķijo neÉĄĖķee, âIÉĄĖķeladi jiÉĄĖķidiaa ite niÉĄĖķina oko ane etidotaÉĄĖķaneÉĄĖķe.â Pida jaÉĄĖķademiitiwaji liÉĄĖķeladi micataÉĄĖķa daÉĄĖķa latecaÉĄĖķadi olicaÉĄĖķaÉĄĖķa.â 
\p  
\v 47 Jesus one diiÉĄĖķaxinaÉĄĖķa minitaÉĄĖķa AneotedoÉĄĖķoji liÉĄĖķeladi icoatawece niÉĄĖķicoa nokododi. Odaa niÉĄĖķijoa sacerdotitedi ijaaÉĄĖķijo anodiiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco AneotedoÉĄĖķoji, ijaaÉĄĖķijo niÉĄĖķijo anoiiÉĄĖķe judeutedi, joÉĄĖķodoletibige moyeloadi Jesus.  
\v 48 Pida aÉĄĖķica nimaweneÉĄĖķegi, leeÉĄĖķodi iditawece oko watacotibigiwaji, mowajipatalo lotaÉĄĖķa Jesus. 
\c 20  
\s1 Ica ane icoÉĄĖķoticogi naÉĄĖķatetigi Jesus me iticoitedicoace niÉĄĖķijo anoojetekaÉĄĖķa minitaÉĄĖķa AneotedoÉĄĖķoji liÉĄĖķeladi 
\r (Mateus 21.23-27; Marcos 11.27-33) 
\p  
\v 1 Ica noko Jesus idiaaÉĄĖķite AneotedoÉĄĖķoji liÉĄĖķeladi, odaa niiÉĄĖķaxitediniwace ica noiigi, yeloÉĄĖķoditediogi niÉĄĖķicoa nibodicetedi anele ane icoÉĄĖķotedibigimece miniwataÉĄĖķa AneotedoÉĄĖķoji. Odaa joÉĄĖķototalo niÉĄĖķijo anoiiÉĄĖķe sacerdotitedi, codaa me niÉĄĖķijo anodiiÉĄĖķaxinaÉĄĖķatece icoa lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs, ijaaÉĄĖķijoa icoa laxokodi ÉĄĖķoneleegiwadi, lacilodi noiigi judeutedi.  
\v 2 Odaa joÉĄĖķoige, moditalo, âIgame icoÉĄĖķoticogi ica ÉĄĖķanaÉĄĖķatetigi mawiite inoa ÉĄĖķadoenataka? Codaa amiijo ica ane yajigotaÉĄĖķawa ÉĄĖķanaÉĄĖķatetigi me yakadi mawiite inoa ÉĄĖķadoenataka?â 
\p  
\v 3 Jesus ja igidi, meetediogi, âEe aaÉĄĖķaÉĄĖķa ÉĄĖķadigeetiwaji, odaa jemaa madigiti.  
\v 4 Amiijo ica ane niiÉĄĖķe JoÃĢo me nilegetiniwace oko? AneotedoÉĄĖķoji niiÉĄĖķe? OÉĄĖķoa, ÉĄĖķoneleegiwadi oniiÉĄĖķe?â  
\v 5 Odaa jiÉĄĖķidiaa dinotaÉĄĖķaneÉĄĖķetiwage, modi, âDaÉĄĖķa jigitaÉĄĖķa me AneotedoÉĄĖķoji niwakatee JoÃĢo me dilegenaÉĄĖķa, odaa jeÉĄĖķeetedoÉĄĖķowa, âJoaniÉĄĖķidaaÉĄĖķee igatime leeÉĄĖķodi ina diÉĄĖķiwaÉĄĖķatiteda icoa aneetedaÉĄĖķawa JoÃĢo?â  
\v 6 Pida deÉĄĖķejinaÉĄĖķa me ÉĄĖķoneleegiwadi oniiÉĄĖķe, odaa niÉĄĖķina noiigi-nelegi joÉĄĖķonokoletoÉĄĖķoloco wetiadi, leeÉĄĖķodi oyiwaÉĄĖķadi JoÃĢo minaaÉĄĖķina ina ane yeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko.â  
\v 7 Odaa joÉĄĖķoigidi Jesus, moditalo me doÉĄĖķoyowooÉĄĖķodi niÉĄĖķica ane yajigota JoÃĢo naÉĄĖķatetigi me nilegetiniwace oko.  
\v 8 Odaa Jesus jeÉĄĖķee, âEe eleditiwaji ajeloÉĄĖķoditaÉĄĖķawa niÉĄĖķica ane najigotiwa inaÉĄĖķatetigi me jakadi me jaote niÉĄĖķinoa yoenataka.â 
\s1 Jesus yatemati natematigigi icoa nawodaÉĄĖķanadi abeyacaÉĄĖķaÉĄĖķa 
\r (Mateus 21.33-46; Marcos 12.1-12) 
\p  
\v 9 NiÉĄĖķidiaaÉĄĖķidi Jesus ja yatematitediogi niÉĄĖķidi noiigi niÉĄĖķida natematigo anida ane ÉĄĖķodiiÉĄĖķaxitece, odaa jeÉĄĖķee, âIca ÉĄĖķoneleegiwa eyatedi âuuvaâ libatatiidi miditaÉĄĖķa lixoÉĄĖķotagi. Odaa ja dinilakidetege icoa ÉĄĖķoneleegiwadi modoweditelogo, odaa ja noditice, igo eledi iiÉĄĖķo, ica ditigedi, odaa leegi midiaaÉĄĖķi.  
\v 10 NiÉĄĖķicota ica limedi monopilaÉĄĖķaditedio lawodigijedi, odaa ja iiÉĄĖķe onijoteci liotagi me dibatege liwai niÉĄĖķica baanaÉĄĖķa odinilakidetigi. Pida niÉĄĖķijoa ÉĄĖķoneleegiwadi anodoweditelogo onaxacoÉĄĖķotibige niÉĄĖķijo liotagi, oiiÉĄĖķe mopi, me diÉĄĖķicata ane yadeegi.  
\v 11 NiÉĄĖķijo ane nebi nixoÉĄĖķotagi ja iiÉĄĖķe eledi liotagi. Pida idaaÉĄĖķodigota onaxacoÉĄĖķotibige, onietibige, codaa moiiÉĄĖķe mopi me diÉĄĖķicata ane yadeegi.  
\v 12 Odaa ja niwakatee eledi liotagi. Pida niÉĄĖķijo liotagi oyacilotidi, odaa joÉĄĖķoyokoleticogi wetice niÉĄĖķidiwa nawodigijedi anoniotaa. 
\p  
\v 13 Odaa niÉĄĖķijo ane nepilidi niÉĄĖķijoa nawodigijedi meetigi le, âAmigaleeÉĄĖķini ica inimaweneÉĄĖķegi? Natigide jiiÉĄĖķe niÉĄĖķini ionigi yemaanigi. Ijoatibige doÉĄĖķodeemitetibige.â  
\v 14 Pida niÉĄĖķijo anodoweditelogo niÉĄĖķijoa nawodigijedi noÉĄĖķonaditege lionigi niÉĄĖķijo ane nepilidi nawodigijedi, odaa modi, âNiÉĄĖķina niÉĄĖķijo lionigi niÉĄĖķijo ane nepilidi nawodigijedi, jiÉĄĖķinaa nenyaÉĄĖķatema nawodigijedi, nige yeleo eliodi. Ele me jeloataÉĄĖķa, odaa niÉĄĖķinoa nawodigijedi ja ÉĄĖķonepilidi.â  
\v 15 Odaa joÉĄĖķoyokoleticogi we niÉĄĖķidiwa nawodigijedi, odaa joÉĄĖķoyeloadi. 
\p Natigide, amiini ica anakatitecetiwaji ijo ane nepilidi idiwa nawodigijedi migotiogi idi anoyeloadi lionigi?  
\v 16 Enagi, odaa ja nigodi niÉĄĖķidi anodoweditelogo nawodigijedi. Odaa ja yajigotiogi niÉĄĖķidiwa nawodigijedi eletidi ÉĄĖķoneleegiwadi modoweditelogo.â NiÉĄĖķijo noiigi noÉĄĖķowajipata niÉĄĖķida natematigo, odaa modi, âInibeoonaÉĄĖķatege AneotedoÉĄĖķoji me daÉĄĖķa ikateda micota niÉĄĖķida niciagi.â 
\p  
\v 17 Jesus naÉĄĖķa iwitediogi, odaa jeÉĄĖķee, âEnice, amiini ica aneetece ijo liwai ajo AneotedoÉĄĖķoji lotaÉĄĖķanaÉĄĖķaxi anee, 
\q1 âNaÉĄĖķajo wetiÉĄĖķa ane diÉĄĖķica mowo, 
\q1 niÉĄĖķijo anoyoe diimigi, 
\q1 ajaaÉĄĖķajo naÉĄĖķajo wetiÉĄĖķa dinoe me wetiÉĄĖķa ane daÉĄĖķaxa mida anowo mini diimigi, 
\q1 caticedi niÉĄĖķidiwa eletidi wetiadi anoibakeâ? 
\q1 (LeeÉĄĖķodi jaÉĄĖķaniaa dowediteloco initawece niÉĄĖķini diimigi.) 
\p  
\v 18 NiÉĄĖķina oko ane dixipeteloco naÉĄĖķani wetiÉĄĖķa, oninoateci liwailidi yeyaÉĄĖķatedice. Codaa naÉĄĖķani wetiÉĄĖķa deÉĄĖķeniteloco oko, iopaaÉĄĖķadi.â 
\s1 Oigetece Jesus niÉĄĖķijoa dinyeelo ane leeditibige moyediatece niÉĄĖķijo ninionigi-eliodi romaanotedi 
\r (Mateus 22.15-22; Marcos 12.13-17) 
\p  
\v 19 NiÉĄĖķijo anodiiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs ijaaÉĄĖķijo niÉĄĖķijo anoiiÉĄĖķe sacerdotitedi, oyowooÉĄĖķodi niÉĄĖķidiaaÉĄĖķeetediogi Jesus, niÉĄĖķijo naÉĄĖķa yatemati niÉĄĖķida natematigo. Odaa joÉĄĖķodoletibige moniwilo aniaaÉĄĖķani naÉĄĖķaca lakata, pida aÉĄĖķica loenatagi leeÉĄĖķodi odoitiogi niÉĄĖķidi noiigi.  
\v 20 Odaa joÉĄĖķoiÉĄĖķoaditalo Jesus, niÉĄĖķidiaaÉĄĖķidi joÉĄĖķoiiÉĄĖķe ÉĄĖķoneleegiwadi modinanatigi niÉĄĖķina oko ane iÉĄĖķenaÉĄĖķa moiÉĄĖķoaditalo Jesus, codaa monigetedice, odoletibige modibatalo oyatitalo lotaÉĄĖķa. DomoÉĄĖķoyemaa mica ica anoyatigi ligegi modakapetege Jesus, domoÉĄĖķowotibige moyakadi moyajigo minitaÉĄĖķa ninionigi-eliodi romaanotedi, moiloikatidi Jesus.  
\v 21 NiÉĄĖķijoa ÉĄĖķoneleegiwadi niiÉĄĖķexedi joÉĄĖķoige Jesus, moditalo, âĮĪoniiÉĄĖķaxinoÉĄĖķodi, jowooÉĄĖķotaÉĄĖķa meloÉĄĖķoti anewi, codaa me iiÉĄĖķaxinaÉĄĖķanitece anewi. Codaa jowooÉĄĖķotaÉĄĖķa me daÉĄĖķawii ÉĄĖķademaani oko daÉĄĖķa leeÉĄĖķodi mida ane jaoÉĄĖķa. Pida ewi me iiÉĄĖķaxinaÉĄĖķanitece niÉĄĖķica AneotedoÉĄĖķoji ane yemaa mowo niÉĄĖķina oko.  
\v 22 Natigide digawini, domige ÉĄĖķodiiÉĄĖķe inoa ÉĄĖķonajoinaÉĄĖķaneÉĄĖķeco me jajicaÉĄĖķata CÃĐsar dinyeelo, niÉĄĖķijo ninionigi-eliodi romaanotedi ane ÉĄĖķodiiÉĄĖķeta me jedianaÉĄĖķa? OÉĄĖķoa, domige etiÉĄĖķodoli inoa ÉĄĖķonajoinaÉĄĖķaneÉĄĖķeco me jedianaÉĄĖķa?â 
\p  
\v 23 Pida Jesus yowooÉĄĖķodi modoletigi mowotema ane beyagi modakapetege. Odaa jeÉĄĖķee,  
\v 24 âAwii anikeenitiwa beexo romaanexe. Ame liwigo aniwoteloco ani beexo, codaa ame liboonaÉĄĖķadi ane diniditeloco ani beexo?â Odaa joÉĄĖķodi, âCÃĐsar.â  
\v 25 Odaa Jesus jeÉĄĖķee, âEnice, ediani CÃĐsar niÉĄĖķica ane leeditibige medianitece, codaa ajicitalo AneotedoÉĄĖķoji niÉĄĖķica ane leeditibige medianitece.â 
\p  
\v 26 Odaa aÉĄĖķoyakadi modi mica ligegi Jesus ane beyagi lodoe niÉĄĖķidi noiigi. Codaa eliodi moyopo ane eyatedigi ligegi me igiditediogi. JoaniÉĄĖķidaa leeÉĄĖķodi modaa notokotiniwace. 
\s1 Oigetece Jesus ica anodaaÉĄĖķee niÉĄĖķina oko ica nige newiÉĄĖķatace 
\r (Mateus 22.23-33; Marcos 12.18-27) 
\p  
\v 27 Icoa saduceutedi aonoÉĄĖķoyiwaÉĄĖķadi micota me newiÉĄĖķatace niÉĄĖķijo baanaÉĄĖķa nigo, odaa onica anototalo Jesus, moige,  
\v 28 Moditalo, âĮĪoniiÉĄĖķaxinoÉĄĖķodi, niÉĄĖķijo MoisÃĐs naÉĄĖķa idÃ­ niÉĄĖķijoa ÉĄĖķonajoinaÉĄĖķaneÉĄĖķeco, mee me iditedini, âDiÉĄĖķica ÉĄĖķoneleegiwa ane yeleo nenyaÉĄĖķaditi lodawa me diÉĄĖķica lionigi, odaa leeditibige nioxoa me lodawa naÉĄĖķajo wajekalo amaleeÉĄĖķaÉĄĖķa icoa lionaÉĄĖķa. Odaa niÉĄĖķidi lionigipi ja micataÉĄĖķa daÉĄĖķa lionigipi niÉĄĖķijo baanaÉĄĖķa yeleo.â  
\v 29 Pida onicoa seete dinioxomigi. Odaa niÉĄĖķica liidaÉĄĖķa jona wado. Pida aniÉĄĖķica lionigi naÉĄĖķa yeleo.  
\v 30 Odaa niÉĄĖķijo liiÉĄĖķejetewa ja lodawa naÉĄĖķajo wajekalo. Pida jaÉĄĖķaÉĄĖķa yeleo maleediÉĄĖķica lionigi.  
\v 31 NiÉĄĖķidiaaÉĄĖķidi niÉĄĖķijo aaÉĄĖķaÉĄĖķa liiÉĄĖķejetewa jaÉĄĖķaÉĄĖķa lodawa ajaaÉĄĖķajo naÉĄĖķajo wajekalo. Pida eledi yeleo. Odaa joaniÉĄĖķidaaÉĄĖķee ijotawece niÉĄĖķijo seete dinioxomigi nodawa ajokajo iwaalo, codaa ijotawece nigo maleediÉĄĖķica lionigi.  
\v 32 NiÉĄĖķidiaaÉĄĖķidi naÉĄĖķajo iwaalo jaÉĄĖķaÉĄĖķa yeleo.  
\v 33 Odaa niÉĄĖķica noko nige newiÉĄĖķatace ÃĐmaÉĄĖķaÉĄĖķa, amigepidiÉĄĖķica niÉĄĖķijo seete dinioxomigi baÉĄĖķa lodawa ajo iwaalo? IgaataÉĄĖķa ijotawece nodawa ajokajo iwaalo.â 
\p  
\v 34 Jesus naÉĄĖķa igidi, meetediogi, âNiÉĄĖķina oko anida aneetege niÉĄĖķina iiÉĄĖķo nadonaÉĄĖķa, odaa jiÉĄĖķinoa lionaÉĄĖķa, odaa jaÉĄĖķaÉĄĖķa nadonaÉĄĖķa niÉĄĖķinoa lionaÉĄĖķa.  
\v 35 Pida niÉĄĖķina AneotedoÉĄĖķoji aneote me yewiÉĄĖķatace leeÉĄĖķodi me iÉĄĖķenaÉĄĖķatibigiwaji, nige newiÉĄĖķatace, aÉĄĖķalee nadonaÉĄĖķa.  
\v 36 Pida ja liciaco aanjotedi, aÉĄĖķalee yakadi daÉĄĖķa nigo. Ja lionaÉĄĖķa AneotedoÉĄĖķoji leeÉĄĖķodi jeÉĄĖķepaaÉĄĖķeote naÉĄĖķa newiÉĄĖķatace.  
\v 37 Codaa ijaaÉĄĖķijo MoisÃĐs ikee niÉĄĖķijoa ÃĐmaÉĄĖķaÉĄĖķa me newiÉĄĖķatace. NiÉĄĖķijo naÉĄĖķa iditini me yalaÉĄĖķata naÉĄĖķajo nialawaana ane Ã­di, pida ayabidi. Iditini yalaÉĄĖķatalo ĮĪoniotagodi AneotedoÉĄĖķoji niÉĄĖķiniaa, âNoenoÉĄĖķodi AbraÃĢo, NoenoÉĄĖķodi Isaque, codaa me NoenoÉĄĖķodi JacÃģ.â  
\v 38 Odaa leeÉĄĖķodi niÉĄĖķidiwa notaÉĄĖķa, ja jowooÉĄĖķotaÉĄĖķa me daÉĄĖķa NoenoÉĄĖķoditeda ÃĐmaÉĄĖķaÉĄĖķa, pida NoenoÉĄĖķodi niÉĄĖķina oko anidi me newiÉĄĖķa. LeeÉĄĖķodi lodoe AneotedoÉĄĖķoji iditawece newiÉĄĖķa.â 
\p  
\v 39 NiÉĄĖķidiaaÉĄĖķidi icoa anodiiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs moditalo Jesus, âĮĪoniiÉĄĖķaxinoÉĄĖķodi, ica mele motaÉĄĖķani!â  
\v 40 Owo niÉĄĖķida ligegi leeÉĄĖķodi niÉĄĖķijoa saduceutedi aÉĄĖķaleeÉĄĖķabo laaleÉĄĖķena mowote eletidi ligikaneÉĄĖķeco midoataÉĄĖķa Jesus. 
\s1 Jesus digikatedigi NiÉĄĖķijoa ane niiÉĄĖķe AneotedoÉĄĖķoji me ÉĄĖķodewikatidi 
\r (Mateus 22.41-46; Marcos 12.35-37) 
\p  
\v 41 Jesus digika, meetediogi, âIca AneotedoÉĄĖķoji ane niwakatee me yewikatidi oko, igame leeÉĄĖķodi ina oko modi mida aneetege licoÉĄĖķegi Davi?  
\v 42-43 IgaataÉĄĖķa ijaaÉĄĖķijo Davi mee miditaÉĄĖķa liwai AneotedoÉĄĖķoji lotaÉĄĖķanaÉĄĖķaxi anodita Enaco, mee me iditeloco, 
\q1 âĮĪoniotagodi AneotedoÉĄĖķoji meeteta Iniotagodi, 
\q1 âAnicootini iwai ibaaÉĄĖķadi me jiiÉĄĖķenatakanaÉĄĖķa, 
\q1 nigepaaÉĄĖķicota me jiÉĄĖķeke ÉĄĖķaneloÉĄĖķododipi.â â 
\m  
\v 44 Davi nigeetalo me Niotagodi, odaa igaamee ina me yakadi ica ane niiÉĄĖķe AneotedoÉĄĖķoji mida aneetege licoÉĄĖķegi Davi?â 
\s1 Jesus yalaÉĄĖķate niÉĄĖķijo anodiiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs 
\r (Mateus 23.1-36; Marcos 12.38-40) 
\p  
\v 45 NiÉĄĖķijo noiigi owajipatalo Jesus, neÉĄĖķeetediogi niÉĄĖķijo anodiotibece,  
\v 46 âAnidakitiogi niÉĄĖķina anodiiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs. Lemaanigi niÉĄĖķina mewaligitibigiwaji, modinixotinigilo nijayogoli niÉĄĖķina oko ÉĄĖķoneÉĄĖķegi. Eleditace lemaanigi niÉĄĖķina oko modeemitetibige monice miditaÉĄĖķa ane latecaÉĄĖķaditibece oko. Codaa lemaanigi monicoteloco nibaanco niÉĄĖķina oko ÉĄĖķoneÉĄĖķegi midiwataÉĄĖķa niiakanaÉĄĖķaxiidi, codaa niÉĄĖķina migotibeci nalooÉĄĖķo, odoletibige limedi niÉĄĖķina anele.  
\v 47 Pida oninaaletiniwace wajekalodi, odaa joÉĄĖķodoliceta anigidi lowoodaÉĄĖķagi anele, codaa lemaanigi me dinikeenaÉĄĖķaneÉĄĖķe moyotaÉĄĖķaneÉĄĖķe AneotedoÉĄĖķoji. Pida AneotedoÉĄĖķoji icota meliodi me iloikatidi.â 
\c 21  
\s1 Aca wajekalo madewete ane yajigotalo AneotedoÉĄĖķoji iniodataale beexotedawaanaÉĄĖķa 
\r (Marcos 12.41-44) 
\p  
\v 1 Jesus iwitediogi ica oko minitaÉĄĖķa AneotedoÉĄĖķoji liÉĄĖķeladi. Odaa naditediogi niÉĄĖķijoa liicotedi noÉĄĖķoyokoletinigi ninyeelo naÉĄĖķajo niwokodaÉĄĖķaxi AneotedoÉĄĖķoji.  
\v 2 Odaa aaÉĄĖķaÉĄĖķa nadi naÉĄĖķajo wajekalo madewete maÉĄĖķaÉĄĖķa yokoletinigi madi iwokodaÉĄĖķaxi iniwataale beexotedawaanaÉĄĖķa.  
\v 3 Odaa Jesus jeÉĄĖķee, âEjitaÉĄĖķawatiwaji niÉĄĖķina anewi. NaÉĄĖķani wajekalo madewete yajigotalo AneotedoÉĄĖķoji caticedi anoyajigo niÉĄĖķijo eledi oko.  
\v 4 LeeÉĄĖķodi niÉĄĖķijo eledi oko oyajigo niÉĄĖķinoa ane iiÉĄĖķotedice ninyeelo. Pida naÉĄĖķani wajekalo digo anee me daÉĄĖķaxa me madewete, pida yajigotalo AneotedoÉĄĖķoji ijoatawece niÉĄĖķijoa ane domaÉĄĖķa yopotibige me yewiÉĄĖķa.â 
\s1 Jesus yalaÉĄĖķate micota moyojiketini AneotedoÉĄĖķoji liÉĄĖķeladi 
\r (Mateus 24.1-2; Marcos 13.1-2) 
\p  
\v 5 NiÉĄĖķijo anodiotibece notaÉĄĖķanaÉĄĖķateloco oyalaÉĄĖķata AneotedoÉĄĖķoji liÉĄĖķeladi, oyakadi ica me daÉĄĖķaxa me libinienigi, icoa niwetiadi libinienaÉĄĖķa, codaa owidi niÉĄĖķicoa eletidi elomaÉĄĖķajetecidi libinienaÉĄĖķa niÉĄĖķini diimigi anoibootalo AneotedoÉĄĖķoji niÉĄĖķica noiigi. Odaa Jesus jeÉĄĖķee,  
\v 6 âIcota noko niÉĄĖķini diimigi libinienigi ananatitiwaji icota moyaaÉĄĖķadi. Odaa aÉĄĖķaca nenyaÉĄĖķatini otaÉĄĖķanitece wetiÉĄĖķa ane waxoditeloco eledi wetiÉĄĖķa.â 
\p  
\v 7 Odaa joÉĄĖķoige Jesus, moditalo, âĮĪoniiÉĄĖķaxinoÉĄĖķodi, igaatigi ica nige jinataÉĄĖķa ida niciagi? Amiida ica AneotedoÉĄĖķoji loenatagi me nikeetedoÉĄĖķowa ica nige limedi ida niciagi anenita?â 
\s1 NiÉĄĖķina anodiotece Jesus nigidiaaÉĄĖķidi nawikodeeÉĄĖķa, codaa moiatetibeci 
\r (Mateus 24.3-14; Marcos 13.3-13) 
\p  
\v 8 Odaa Jesus mee, âAdinowetitiwaji! AdiÉĄĖķica ane ÉĄĖķadinaaleni, leeÉĄĖķodi eliodi oko odinanatibigiji, modi, âEe liiÉĄĖķexegi AneotedoÉĄĖķojiâ, oÉĄĖķoa, domigodi, âJiÉĄĖķicota noko ĮĪoniotagodi.â Pida jiniÉĄĖķiwitecetiwaji.  
\v 9 Codaa jinaÉĄĖķadoii nigajipaata moyalaÉĄĖķata nideleÉĄĖķeco digawiniteloco noiigi, codaa me niÉĄĖķina dinoiigiwepodi nidelaÉĄĖķa. IgaataÉĄĖķa jiÉĄĖķinaa odoejedi me jinataÉĄĖķa, pida anaÉĄĖķa nipegi liniogo niÉĄĖķinoa nokododi.â 
\p  
\v 10 Odaa Jesus jeÉĄĖķee, âIcota midi noiigi dinigoditege eledi noiigi, codaa nimaweneÉĄĖķeco iiÉĄĖķo dakapetege nimaweneÉĄĖķeco eledi iiÉĄĖķo.  
\v 11 NiÉĄĖķinoa eletidi nipodaÉĄĖķa jibodicaÉĄĖķata datalale iiÉĄĖķo ane yoniciwadi, oko nigodi nigigi, codaa me neelotika ane yediiÉĄĖķa me waxodita eledi oko. AneotedoÉĄĖķoji eote ane ikee digoida ditibigimedi ane ikee me deliÉĄĖķide, odaa eote niÉĄĖķina oko meliodi me doitibigiwaji. 
\p  
\v 12 Pida maleedaÉĄĖķa icotece inoatawece niÉĄĖķinoa anejitedaÉĄĖķawa, icota modibataÉĄĖķawatiwaji, owo mawikodee. Odaa etiÉĄĖķadajicitiogitiwaji niÉĄĖķinoa lacilodi liiakanaÉĄĖķaxiidi judeutedi, odaa jeÉĄĖķetiÉĄĖķadixomitiwece niwiloÉĄĖķonaÉĄĖķaxi. LeeÉĄĖķodi IboonaÉĄĖķadi etiÉĄĖķadadeegitatiwaji lodoe inionaÉĄĖķa-eloodoli, inaaÉĄĖķinoa eletidi lacilodi metiÉĄĖķadiwini, odaa joÉĄĖķowo anodigotaÉĄĖķawa.  
\v 13 JoaniÉĄĖķidaa nigakatitiwaji menitici miditaÉĄĖķa.  
\v 14 Atiteteloco ÉĄĖķadowoogo, jiniÉĄĖķiigi amanagawini aaÉĄĖķaÉĄĖķowikomataatiwaji maleedaÉĄĖķa icota lakata motaÉĄĖķani.  
\v 15 LeeÉĄĖķodi emeÉĄĖķee jajigotaÉĄĖķawa ÉĄĖķadixakedi, odaa jaxawataÉĄĖķadici ane alitigi ÉĄĖķagegi magiti ÉĄĖķadaxakawepodi, odaa iditawece aÉĄĖķoyakadi modinigaanyetaÉĄĖķadici, codaa aÉĄĖķoyakadi moditaÉĄĖķawa me deÉĄĖķenitece anewi.  
\v 16 Pida etiÉĄĖķadajicita metiÉĄĖķadiwilo niÉĄĖķina ÉĄĖķadiododipi, ÉĄĖķanioxoadipi, ÉĄĖķaditacepodi, inaa ÉĄĖķadokaaÉĄĖķetedipi. Codaa ganigepidiÉĄĖķica anoyeloadi niÉĄĖķina akaamitiwaji.  
\v 17 Odaa inatawece oko aÉĄĖķetiÉĄĖķademaani Ee leeÉĄĖķodi.  
\v 18 Pida niÉĄĖķida makaamitiwaji aÉĄĖķica ananiatitema otaÉĄĖķaÉĄĖķidatece ÉĄĖķadamodi.  
\v 19 Odaa natigide aatege niÉĄĖķinoa ane dakaketedaÉĄĖķadomi, amaleeÉĄĖķaÉĄĖķa idioka limedi me ÉĄĖķadewiki miniwataÉĄĖķa AneotedoÉĄĖķoji. 
\s1 Jesus yalaÉĄĖķate ica me daa nigotaÉĄĖķa JerusalÃĐm 
\r (Mateus 24.15-21; Marcos 13.14-19) 
\p  
\v 20 Niganatitiwaji nigotaÉĄĖķa JerusalÃĐm, monawiile owidi iodaÉĄĖķawadi ÉĄĖķadidelaÉĄĖķawadi, odaa joÉĄĖķowooÉĄĖķotitiwaji niÉĄĖķicotalo nokododi ane nibikota AneotedoÉĄĖķoji me yaaÉĄĖķadi nigotaÉĄĖķa.  
\v 21 Odaa anidiaaÉĄĖķi nipodigi JudÃĐia ele me deletibigimoace midiwataÉĄĖķa wetiadi. Codaa niÉĄĖķina anidiaaÉĄĖķitice nigotaÉĄĖķa leeditibige me yediiÉĄĖķatibigiwaji me noditicoaci. Odaa niÉĄĖķina anidiaaÉĄĖķitice nipodigi aÉĄĖķalee yakadi me dakatiwece nigotaÉĄĖķa.  
\v 22 LeeÉĄĖķodi niÉĄĖķicoa nokododi ja limedi AneotedoÉĄĖķoji me iloikatidi niÉĄĖķidi noiigi, codaa icota midiokidi minoa ninyaco ijoatawece niÉĄĖķijoa aniwoteloco AneotedoÉĄĖķoji lotaÉĄĖķanaÉĄĖķaxi.  
\v 23 NiÉĄĖķina iwaalepodi ipilaÉĄĖķaÉĄĖķa, inaaÉĄĖķina niÉĄĖķina baÉĄĖķalee oilipeÉĄĖķe lionigipi, niÉĄĖķidi eliodi me nawikodeeÉĄĖķa niÉĄĖķicoa nokododi, leeÉĄĖķodi enagi owidi nawikodico digoina iiÉĄĖķo, codaa AneotedoÉĄĖķoji iloikatidi niÉĄĖķina noiigi leeÉĄĖķodi yelatetema me daÉĄĖķaxa mowidi libeyaceÉĄĖķeco.  
\v 24 Odaa niÉĄĖķica laxakawepodi eliodi anonigodi niÉĄĖķidi noiigi oyatitiogi lodaajoli-ocaÉĄĖķatedi, codaa idi eledi oyadeegi micataÉĄĖķa me niwilogojegipi minoataÉĄĖķa eletidi iiÉĄĖķotedi. Odaa idi eledi noiigi oyaaÉĄĖķadi nigotaÉĄĖķa JerusalÃĐm, odaa ida loniciwaÉĄĖķatema moiiÉĄĖķe nigotaÉĄĖķa nigepaa liniogo niÉĄĖķicoa nokododi AneotedoÉĄĖķoji ane nibikota me ika mowo niÉĄĖķida niciagi. 
\s1 Lanokegi ĮĪoneleegiwa ane icoÉĄĖķotibigimece ditibigimedi 
\r (Mateus 24.29-31; Marcos 13.24-27) 
\p  
\v 25 JoaniÉĄĖķidaaÉĄĖķee niÉĄĖķica niciagi, naÉĄĖķani aligeÉĄĖķe, epenai, codaa me yotetitedi, oikeetiogi niÉĄĖķina oko naÉĄĖķa nipegi liniogo iiÉĄĖķo. Odaa digoina iiÉĄĖķo, inatawece noiigi aÉĄĖķaleeÉĄĖķica doÉĄĖķonibeotibigege anele, codaa eliodi me doitibigiwaji, leeÉĄĖķodi layaageÉĄĖķegi akiidi-eliodi, nebekadi.  
\v 26 Codaa niÉĄĖķina oko noÉĄĖķomiwaditiniwace leeÉĄĖķodi daÉĄĖķaxa me doitibigiwaji, niÉĄĖķina moyowo niÉĄĖķida niciagi nigicote. LeeÉĄĖķodi inoatawece ane loniciweÉĄĖķeco ditibigimedi digikee.  
\v 27 Odaa niÉĄĖķina oko jeÉĄĖķetidadi, Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, me idinikatini jiniotinece lolaadi, meliodi yoniciwaÉĄĖķa.  
\v 28 Nige limedi niÉĄĖķinoa ninyacoli, odaa jaÉĄĖķabo ÉĄĖķadaaleÉĄĖķena maliitigi, leeÉĄĖķodi aÉĄĖķalee leegi odaa AneotedoÉĄĖķoji ja ÉĄĖķadoÉĄĖķaatedicogi niÉĄĖķinoa ÉĄĖķadawikodico.â 
\s1 Jesus yatemati ica natematigo anida ane ÉĄĖķodiiÉĄĖķaxitece ane yalaÉĄĖķata niale fiigoigo 
\r (Mateus 24.32-35; Marcos 13.28-31) 
\p  
\v 29 Odaa Jesus ja yatemati niÉĄĖķida natematigo anida ane ÉĄĖķodiiÉĄĖķaxitece, mee, âDigawini niale fiigoigo inaaÉĄĖķinoa eletidi nialeli.  
\v 30 NiÉĄĖķina manatitiwaji niÉĄĖķinoa laamotiidi maleekoka daxoditedice, odaa joÉĄĖķowooÉĄĖķoti jiÉĄĖķicota limedi me daamotiide.  
\v 31 JiÉĄĖķidaaÉĄĖķee nigicota manati niÉĄĖķida niciagi, minoa nawikodico, odaa joÉĄĖķowooÉĄĖķotitiwaji naÉĄĖķa nipegi AneotedoÉĄĖķoji me iiÉĄĖķe laaleÉĄĖķenali oko. 
\p  
\v 32 EjitaÉĄĖķawatiwaji niÉĄĖķina anewi, niÉĄĖķina oko aninaa me newiÉĄĖķa niÉĄĖķica nigicotalo niÉĄĖķicoa nokododi nige limedi nawikodico, aÉĄĖķinatawece nigo nigicota niÉĄĖķida niciagi anejita.  
\v 33 Ditibigimedi, iiÉĄĖķo, baÉĄĖķa ixomaÉĄĖķatedice, pida yotaÉĄĖķa baadaÉĄĖķa ixomaÉĄĖķatedice, idioka limedi midiwa. 
\s1 Leeditibige midioka limedi me idinowetaÉĄĖķatege niÉĄĖķica anenagi 
\p  
\v 34 AkamaÉĄĖķakaamitiwaji adinoweti jiniÉĄĖķidioka limedi moleetibige maloo, daÉĄĖķa ÉĄĖķademakitibece, codaa jinaÉĄĖķaÉĄĖķowikomataatelogo niÉĄĖķinoa aneni digoina iiÉĄĖķo. Ina daÉĄĖķadoiita adaÉĄĖķakaami libakajetegi maleedaÉĄĖķa enitigi deÉĄĖķeno niÉĄĖķica noko AneotedoÉĄĖķoji.  
\v 35 IgaataÉĄĖķa niÉĄĖķica noko enagi, odaa dibatiogi eliodi oko digoina iiÉĄĖķo, niÉĄĖķina analee doÉĄĖķoditibige, macataÉĄĖķa naÉĄĖķana enoona me dibata eijeeÉĄĖķagi me daÉĄĖķa eetibige.  
\v 36 Odaa leeditibige midioka limedi madinoweti, codaa midioka limedi motaÉĄĖķaneÉĄĖķeni AneotedoÉĄĖķoji, amaleeÉĄĖķaÉĄĖķa akatitiwaji metiÉĄĖķadiwokoni nawikodico anenagi, codaa amaleeÉĄĖķaÉĄĖķa akatitiwaji manooticogi yodoe, Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi.â 
\p  
\v 37 Inoatawece nokododi Jesus niiÉĄĖķaxitediniwace niÉĄĖķijo noiigi minitaÉĄĖķa AneotedoÉĄĖķoji liÉĄĖķeladi. Odaa niÉĄĖķina menoale ja noditedicogi nigotaÉĄĖķa, idiaaÉĄĖķitedice maditaÉĄĖķa aca wetikawaana anodita, âLojotaÉĄĖķadi Oliveiraâ.  
\v 38 Odaa niÉĄĖķina naÉĄĖķa yeloÉĄĖķotibige, iditawece niÉĄĖķidi noiigi igotibeci midoataÉĄĖķa Jesus minitaÉĄĖķa AneotedoÉĄĖķoji liÉĄĖķeladi mowajipatalo lotaÉĄĖķa. 
\c 22  
\s1 Lacilodi judeutedi odinilakidetege Judas me ikee Jesus 
\r (Mateus 26.1-5, 14-16; Marcos 14.1-2, 10-11; JoÃĢo 11.45-53) 
\p  
\v 1 NaÉĄĖķa nipegi ica nalokegi anodita âLalokegi paon ane diÉĄĖķica labookojegiâ, aneledi oyatigi me âPÃĄscoaâ.  
\v 2 NiÉĄĖķijo anoiiÉĄĖķe sacerdotitedi ijaaÉĄĖķijoa niiÉĄĖķaxinaÉĄĖķanadi anodiiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs, joÉĄĖķodoletibige nimaweneÉĄĖķegi moyeloadi Jesus. Pida aÉĄĖķoyakadi, leeÉĄĖķodi odoitiogi niÉĄĖķidi noiigi. 
\p  
\v 3 Judas, aneledi oyatigi me Iscariotes, ida aneetege niÉĄĖķijo dooze anodiotibece Jesus. SatanÃĄs ja dakatiwece laaleÉĄĖķena Judas.  
\v 4 Odaa jiÉĄĖķigo yotaÉĄĖķaneÉĄĖķe niÉĄĖķijo anoiiÉĄĖķe sacerdotitedi ijaaÉĄĖķijo anoiiÉĄĖķe niÉĄĖķicoa iodaÉĄĖķawadi anoyowie AneotedoÉĄĖķoji liÉĄĖķeladi. OdinotaÉĄĖķaneÉĄĖķetege ica nimaweneÉĄĖķegi me yajigo Jesus midiwa lacilodi judeutedi.  
\v 5 Odaa eliodi me ninitibigiwaji, codaa odinilakidetege moyediatece dinyeelo.  
\v 6 Judas ja niwoditema, odaa ja doletibige nimaweneÉĄĖķegi me yakadi me yajigo Jesus midiwa neloÉĄĖķododipi me doÉĄĖķoyowooÉĄĖķodi niÉĄĖķidi noiigi. 
\s1 Jesus iiÉĄĖķe itoa anodiotibece moilakideti ane niodaÉĄĖķadi me PÃĄscoa 
\r (Mateus 26.17-25; Marcos 14.12-21; JoÃĢo 13.21-30) 
\p  
\v 7 NiÉĄĖķicota ica noko nalokegi âPaon ane diÉĄĖķica labookojegiâ, niÉĄĖķica noko noÉĄĖķonigodi waxacocoli moninitege ica lalokegi PÃĄscoa.  
\v 8 Odaa Jesus ja iiÉĄĖķe Pedro ijaa JoÃĢo, meetediogi, âEmiitiwaji odaaÉĄĖķoeni ÉĄĖķoweenigi lajo PÃĄscoa.â  
\v 9 Odaa ja nigikanaÉĄĖķa, modi, âIgamei ica anemaani mejonaÉĄĖķatice me joenaÉĄĖķa ica ÉĄĖķoweenigi?â  
\v 10 Odaa Jesus ja igidi, meetediogi, âDigawinitiwaji, nigakaatiwece nigotaÉĄĖķa, akapetege ÉĄĖķoneleegiwa yoyaÉĄĖķadi boote ane nolee ninyoÉĄĖķodi. Odaa iwitece nigepaa minitaÉĄĖķa niÉĄĖķica diimigi ane dakatiwece.  
\v 11 Odaa enita niÉĄĖķini ane nebi diimigi, âĮĪoniiÉĄĖķaxinoÉĄĖķodi ÉĄĖķodiiÉĄĖķe me jigikanaÉĄĖķatigi ica ane diiÉĄĖķetigi ica ÉĄĖķodicooÉĄĖķadi nelegi, anei me niodaÉĄĖķa, ĮĪoniotagodi inaaÉĄĖķinoa anodiotibece moyeligo liweenigi PÃĄscoa.â  
\v 12 Odaa ja ikeetaÉĄĖķawatiwaji ica ÉĄĖķodicooÉĄĖķadi nelegi ditibigimedi diimigi initawece ilaÉĄĖķatini. OdaaÉĄĖķidiaaÉĄĖķonitetiwaji me oeni ÉĄĖķoweenigi.â  
\v 13 NiÉĄĖķijo niÉĄĖķigotibeci, odaa joÉĄĖķodakapetege niÉĄĖķijo Jesus aneyatedigi ligegi. Odaa joÉĄĖķoyoe liweenigi PÃĄscoa. 
\s1 Jesus diiÉĄĖķenatakate moyeligo ica niweenigi moyalaÉĄĖķatibige 
\r (Mateus 26.26-30; Marcos 14.22-26; 1 CorÃ­ntios 11.23-25) 
\p  
\v 14 NiÉĄĖķijo niÉĄĖķicota aca lakata, odaa Jesus ja nicotedi maditaÉĄĖķa aca nameeja awatetege niÉĄĖķijo anodiotibece.  
\v 15 Odaa jeÉĄĖķeetediogi, âJiÉĄĖķijo mejitaÉĄĖķawatiwaji, meliodi me jemaa me jeligo niÉĄĖķida ÉĄĖķoweenigi me PÃĄscoa, mokotawece jatecoÉĄĖķojoÉĄĖķo maleedaÉĄĖķa icota me jawikode.  
\v 16 LeeÉĄĖķodi ejitaÉĄĖķawatiwaji me daÉĄĖķadiaa jeligo liweenigi nalokegi PÃĄscoa nigepaa jiniodaÉĄĖķa nige limedi lalokegi AneotedoÉĄĖķoji ane iomaÉĄĖķaditedice, nigicota me iiÉĄĖķe laaleÉĄĖķenali inatawece oko.â 
\p  
\v 17 Odaa Jesus naÉĄĖķa dibate aca goopa viinyo, odaa diniotagodete AneotedoÉĄĖķoji. NiÉĄĖķidiaaÉĄĖķidi jeÉĄĖķee, âAbaatege naÉĄĖķada goopa, odaa adinajicitigi niÉĄĖķida viinyo.  
\v 18 LeeÉĄĖķodi ejitaÉĄĖķawatiwaji aÉĄĖķalee jacipe viinyo nigepaa limedi AneotedoÉĄĖķoji me iiÉĄĖķe laaleÉĄĖķenali niÉĄĖķina oko.â 
\p  
\v 19 Odaa ja dibate paon, naÉĄĖķa diniotagodete AneotedoÉĄĖķoji. Odaa ja inoke niÉĄĖķijo paon. NaÉĄĖķa yajigotediogi niÉĄĖķijo anodiotibece, odaa jeÉĄĖķeetediogi, âNiÉĄĖķidi paon micataÉĄĖķa yolaadi ane jajigo leeÉĄĖķodi akaamitiwaji. Awiitibiga niÉĄĖķida anejinaÉĄĖķa amaleeÉĄĖķaÉĄĖķa analakitibigiji.â  
\v 20 IgaanaÉĄĖķa oiaaditece moyeligo paon, odaa naÉĄĖķa dibate naÉĄĖķajo goopa, idaaÉĄĖķigote, odaa jeÉĄĖķeetediogi, âNaÉĄĖķada goopa viinyo micataÉĄĖķa AneotedoÉĄĖķoji daÉĄĖķa gelatace me dinilakidetetege oko me noÉĄĖķa libeyaceÉĄĖķeco, odaa ja dibatacetetege leeÉĄĖķodi yawodi ane anado ane akaamitawecetiwaji leeÉĄĖķodi. Odaa niÉĄĖķida viinyo anacipetatiwaji micataÉĄĖķa daÉĄĖķa yawodi. 
\p  
\v 21 Pida digawini! NiÉĄĖķijo ane idajigotiogi yaxakawepodi, etini aniodi digoina meetaÉĄĖķa.  
\v 22 Odaa Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, ideleo, leeÉĄĖķodi mina lowoogo AneotedoÉĄĖķoji. Pida niÉĄĖķini ane idajigotiogi ineloÉĄĖķododipi, nigidiaaÉĄĖķidi eliodi me dawikode.â  
\v 23 Odaa niÉĄĖķijo anodiotibece ja dinigetiwage, modi, âAmigijo ica ane yajigo ĮĪoniotagodi midi neloÉĄĖķododipi?â 
\s1 NiÉĄĖķica ane daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi 
\p  
\v 24 NiÉĄĖķijo anodiotibece Jesus ja dinotigimadetiwage, odoletibige moyowooÉĄĖķodi ganigepidiÉĄĖķijo ica ane daÉĄĖķaxa me diniwaloe.  
\v 25 Odaa Jesus jeÉĄĖķeetediogi, âNiÉĄĖķinoa ninionaÉĄĖķa-eloodoli digoina iiÉĄĖķo lemaanigi moiiÉĄĖķe oko, codaa lacilodi lemaanigi moditiogi, âMiniÉĄĖķina aneo anele mokotaÉĄĖķaâ.  
\v 26 Pida baÉĄĖķaleediÉĄĖķidaaÉĄĖķenitatiwaji. Pida niÉĄĖķina ane idei makaamitaÉĄĖķatiwaji ane daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi, leeditibige miniaaÉĄĖķini micataÉĄĖķa niÉĄĖķina niotagi baÉĄĖķalee lioneeÉĄĖķa. Odaa niÉĄĖķina ane ÉĄĖķadacilo, ele midioka limedi me diniciaceeketege nimeedi.  
\v 27 Amiijo ica ane daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi? ManigijaaÉĄĖķijo ijo ane nicotini madi nameeja maniodi, oÉĄĖķoa, manigijaaÉĄĖķijo ane nadeegita eledi oko liweenigi ane yeligo? Nige yemaa niÉĄĖķijo ane nicotini madi nameeja jiÉĄĖķijaa ÉĄĖķoneÉĄĖķegi! Pida Ee baÉĄĖķa diniciaceeketege niÉĄĖķina niotagi digoina ÉĄĖķadiwigotigitiwaji. 
\p  
\v 28 JaÉĄĖķakamaÉĄĖķakaamitiwaji niÉĄĖķijo anidioka limedi me idinadeegitibigege minoa yawikodico. (Pida aÉĄĖķadikanitiwaji).  
\v 29 Pida joaniÉĄĖķidaa Eiodi me najigotediwa me jiiÉĄĖķe inoatawece, odaa Ee, aaÉĄĖķaÉĄĖķa jajigotaÉĄĖķawatiwaji me iiÉĄĖķeni inoatawece.  
\v 30 Odaa icota maniodi, macipe, codaa makaami ÉĄĖķogiiwepodi miditaÉĄĖķa nalokegi AneotedoÉĄĖķoji aneote nige limedi me jiiÉĄĖķe inoatawece. Codaa niÉĄĖķida makaami jiÉĄĖķida ÉĄĖķanaÉĄĖķatetigitiwaji me iiÉĄĖķenatakani, odaa jaÉĄĖķawinitiwaji anemiitiogi, codaa me iiÉĄĖķeni niÉĄĖķijoa dooze latopaco loiigi Israel.â 
\s1 Jesus eote leemidi SimÃĢo Pedro 
\r (Mateus 26.31-35; Marcos 14.27-31; JoÃĢo 13.36-38) 
\p  
\v 31 Odaa ĮĪoniotagodi jeÉĄĖķee, âSimÃĢo, SimÃĢo, digawini! SatanÃĄs dipokotalo AneotedoÉĄĖķoji me ika me dineetaÉĄĖķawa akaamitawecetiwaji, me ÉĄĖķadigikeni, micataÉĄĖķa nawodaÉĄĖķanaÉĄĖķa me yajigijice leyeema, catinedi beneela.  
\v 32 Pida jaÉĄĖķaÉĄĖķa jipokotaÉĄĖķaloco me ÉĄĖķadaxawani AneotedoÉĄĖķoji, me daÉĄĖķa ikani madadiwaÉĄĖķati, SimÃĢo. Odaa nige adopilitiwa, odaa awii me yoniciwaditace ÉĄĖķanioxoadipi mabo laaleÉĄĖķena.â  
\v 33 Pida Pedro meetalo, âIniotagodi, ja idigo makaami iniwilaÉĄĖķawa, codaa makaami yemaÉĄĖķawa.â  
\v 34 Odaa Jesus meeteta, âPedro, ejitaÉĄĖķawa, niÉĄĖķina enoale aniÉĄĖķicatibige daÉĄĖķa anoe okoÉĄĖķokoodi, odaa itoatadiÉĄĖķida meni me daÉĄĖķadowooÉĄĖķoti.â 
\s1 Jesus jaÉĄĖķaÉĄĖķeote leemidi niÉĄĖķijo anodiotibece 
\p  
\v 35 Odaa Jesus ja ige, meetediogi, âIca ananiaditaÉĄĖķadomitiwaji, ijo me ÉĄĖķadiiÉĄĖķeni memiitiwaji me diÉĄĖķicoa ÉĄĖķanibocoli, me daÉĄĖķaca ÉĄĖķanixacoola, codaa meletidi ÉĄĖķawelatedi?â Odaa joÉĄĖķoigidi, moditalo, âAÉĄĖķica ane aniaditibige.â 
\p  
\v 36 Odaa jeÉĄĖķeetediogi, âPida niÉĄĖķina natigide anidiwa nibocoli, mige nixacoola, ele me yadeegi. Odaa niÉĄĖķini ane diÉĄĖķica lodaajo-ocaÉĄĖķataÉĄĖķa, odaa ele meyaa nicaapa, me yakadi me dinoojeteta lodaajo-ocaÉĄĖķataÉĄĖķa.  
\v 37 LeeÉĄĖķodi ejitaÉĄĖķawatiwaji me leeditibige micota niÉĄĖķida niciagi, aneeta naÉĄĖķadi AneotedoÉĄĖķoji lotaÉĄĖķanaÉĄĖķaxi mee, âAwatetege monilaÉĄĖķadi niÉĄĖķijoa agopeloaÉĄĖķa.â LeeÉĄĖķodi jiÉĄĖķicota niÉĄĖķida niciagi, ijo aneetece AneotedoÉĄĖķoji lotaÉĄĖķanaÉĄĖķaxi.â  
\v 38 Odaa niÉĄĖķijo anodiotibece moditalo, âĮĪoniotagodi, digawini! Digoina idiwa itiwataale ÉĄĖķododaajoli-ocaÉĄĖķatedi.â Odaa jeÉĄĖķeetediogi, âJaÉĄĖķabo!â 
\s1 Jesus igotace minitaÉĄĖķa LojotaÉĄĖķadi Oliveira 
\r (Mateus 26.36-46; Marcos 14.32-42) 
\p  
\v 39 Jesus noditedicogi nigotaÉĄĖķa, igo minitaÉĄĖķa LojotaÉĄĖķadi Oliveira ane ligileÉĄĖķegitedibece. NiÉĄĖķijo anodiotibece eledi igotibeci.  
\v 40 NiÉĄĖķijo niÉĄĖķicotedicogi niÉĄĖķijo lemaanigi meitedibige, odaa jeÉĄĖķeetediogi niÉĄĖķijo anodiotibece, âIpokitalo AneotedoÉĄĖķojitiwaji me daÉĄĖķa ikateda mawii ane beyagi nigetiÉĄĖķadicini.â 
\p  
\v 41 Odaa ja yetecetedicoace, iboÉĄĖķodi mabo me jokolenaÉĄĖķa wetiÉĄĖķa. Odaa ja yamaÉĄĖķatedini lokotidi me yotaÉĄĖķaneÉĄĖķe AneotedoÉĄĖķoji, mee,  
\v 42 âEiodi, nigemaani, madatamaÉĄĖķateenitege niÉĄĖķinoa yawikodico anenagi, ane jiciaceeketege naÉĄĖķana goopa ane nolee niÉĄĖķina nacipaÉĄĖķadi ane bayodi. Pida jemaa me jixomaÉĄĖķateetedice niÉĄĖķica anakamaÉĄĖķa emaani, idiÉĄĖķida aÉĄĖķiniÉĄĖķinoa ane emaÉĄĖķa jemaa me jixomaÉĄĖķateetedice.â  
\v 43 Odaa ja dinikeetalo ica aanjo, ane icoÉĄĖķotibigimece ditibigimedi, enagi me yajigotalo loniciwaÉĄĖķa.  
\v 44 Jesus eÉĄĖķidaaÉĄĖķee me yotaÉĄĖķaneÉĄĖķe AneotedoÉĄĖķoji, odaa eliodi me doÉĄĖķowikomata, neÉĄĖķepaa dinonipetetece lawodi ane datikoletedinigi iiÉĄĖķo. 
\p  
\v 45 NaÉĄĖķa nigotedini me yotaÉĄĖķaneÉĄĖķe AneotedoÉĄĖķoji, odaa ja dabiditedini, opitacedicogi miditaÉĄĖķa niÉĄĖķijo anodiotibece, odaa jiÉĄĖķicotediogi me niotaÉĄĖķa, leeÉĄĖķodi eliodi me agecaÉĄĖķalodipi.  
\v 46 Odaa jeÉĄĖķeetediogi, âIgaamenitiwaji ina me iote? Anicootiniwacetiwaji, odaaÉĄĖķipokitalo AneotedoÉĄĖķoji me daÉĄĖķa ikateda me oeni ane beyagi nigetiÉĄĖķadicini.â 
\s1 Jesus oniwilo 
\r (Mateus 26.47-56; Marcos 14.43-50; JoÃĢo 18.3-11) 
\p  
\v 47 Jesus eÉĄĖķidaaÉĄĖķeeteda me dotaÉĄĖķa, noÉĄĖķototalo ica noiigi-nelegi. Odaa niÉĄĖķijo ane liboonaÉĄĖķadi Judas, anida aneetege niÉĄĖķijo dooze anodiotibece Jesus, jiÉĄĖķijaa odilokoteloco niÉĄĖķijo noiigi. Odaa niÉĄĖķipegitalo Jesus ja domaÉĄĖķa napicoÉĄĖķo.  
\v 48 Pida Jesus meeteta, âJudas, me domaÉĄĖķadapiciÉĄĖķi, oleetibige me adikeenitiogi idi ineloÉĄĖķododipi, Ee ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi?â 
\p  
\v 49 NiÉĄĖķijo noÉĄĖķonadi niÉĄĖķijo anodiotibece Jesus niÉĄĖķida niciagi, odaa ja nigikanaÉĄĖķa, modi, âĮĪoniotagodi, emaani me jiticodaÉĄĖķaticoace jatiiÉĄĖķatiogi ÉĄĖķododaajoli-ocaÉĄĖķatedi?â  
\v 50 Odaa jiÉĄĖķijo ica aneyacilotidi ica limeedi niÉĄĖķijo lacilo-sacerdotitedi, yakagiditice napaaÉĄĖķate ane diÉĄĖķeticogi libaaÉĄĖķadi.  
\v 51 Pida Jesus yoxoÉĄĖķo, meete, âJaÉĄĖķabo, jinaÉĄĖķaleeÉĄĖķawii ÉĄĖķadoenatagi!â Odaa ja dibatedinece napaaÉĄĖķate niÉĄĖķijo nimeedi, odaa ja yexocaÉĄĖķaditacedi. 
\p  
\v 52 Odaa jeÉĄĖķeetediogi niÉĄĖķijo anoiiÉĄĖķe sacerdotitedi ijaaÉĄĖķijoa icoa ninionaÉĄĖķa iodaÉĄĖķawadi anoyowie AneotedoÉĄĖķoji liÉĄĖķeladi, icoa lacilodi judeutedi, anigotibeci moniwilo. Odaa jeÉĄĖķeetediogi, âIgame leeÉĄĖķoditiwaji manadeegi inoa ÉĄĖķadodaajoli-ocaÉĄĖķatedi inaa ÉĄĖķaneboli madiwilotiwaji, micataÉĄĖķa deÉĄĖķee ÉĄĖķonematagodi?  
\v 53 IjiÉĄĖķijo me jawataÉĄĖķagitiwaji minitaÉĄĖķa AneotedoÉĄĖķoji liÉĄĖķeladi inoatawece nokododi, pida aÉĄĖķadiwilotiwaji. Pida niÉĄĖķina natigide, jiÉĄĖķicota lakata AneotedoÉĄĖķoji ane nibikota mabaatiwatiwaji, ja limedi niÉĄĖķina anida aneetege nexocaÉĄĖķa me ini loniciwaÉĄĖķa meo loenatagi me dakapetigi.â 
\s1 Pedro mee ica me daÉĄĖķa yowooÉĄĖķoditeda Jesus 
\r (Mateus 26.57-58, 69-75; Marcos 14.53-54, 66-72; JoÃĢo 18.15-18, 25-27) 
\p  
\v 54 Odaa joÉĄĖķoniwilo Jesus, joÉĄĖķoyadeegitedicogi liÉĄĖķeladi niÉĄĖķijo lacilo-sacerdotitedi. Odaa Pedro ja diotece, pida leegitece me yototedice.  
\v 55 NiÉĄĖķijo noÉĄĖķoyelotigi noledi liwigotigi niogÃģ ica diimigi, odaa ja dinitotibigiwaji. Odaa Pedro jaÉĄĖķaÉĄĖķa nicotini miditaÉĄĖķa.  
\v 56 NaÉĄĖķa nicotini, odaa aca niimete ja nadi liniogotibece noledi. NaÉĄĖķa iwi, odaa jeÉĄĖķee, âNiÉĄĖķini aaginaÉĄĖķa idiaaÉĄĖķi-iitice mijoataÉĄĖķa Jesus!â  
\v 57 Pida Pedro mee, âAwicije, aÉĄĖķicoa daÉĄĖķa yowooÉĄĖķotagi!â  
\v 58 Aona niÉĄĖķica daÉĄĖķa leegi, ica ÉĄĖķoneleegiwa naÉĄĖķaÉĄĖķa nadi, odaa jeÉĄĖķee, âNiÉĄĖķida makaami eji makaami eledi ganigepidiÉĄĖķica niÉĄĖķijo anodiotibece.â Pida Pedro ja igidi, meeta, âĮĪodokaaÉĄĖķedi, aÉĄĖķica daÉĄĖķa jiotibece!â 
\p  
\v 59 NaÉĄĖķa ixomaÉĄĖķatice onaniteci lakata, ica eledi ÉĄĖķoneleegiwa jeÉĄĖķee, âJeloÉĄĖķoditaÉĄĖķawa niÉĄĖķina anewi, niÉĄĖķini ÉĄĖķoneleegiwa idiaaÉĄĖķitice mijoataÉĄĖķa, leeÉĄĖķodi icoÉĄĖķoticogi nipodigi GalilÃĐia!â  
\v 60 Pida Pedro mee, âNagoodi ÉĄĖķodokaaÉĄĖķedi, odaa aÉĄĖķica daÉĄĖķa jowooÉĄĖķodi niÉĄĖķica ane ÉĄĖķadalakita!â Odaa aoniÉĄĖķica daÉĄĖķa leegi, eÉĄĖķidaaÉĄĖķee me dotaÉĄĖķatibece, naÉĄĖķanoe okoÉĄĖķokoodi.  
\v 61 Odaa ĮĪoniotagodi ja nawiilitetetege me iwiteta Pedro. Odaa Pedro ja nalaÉĄĖķatibige niÉĄĖķijoa ĮĪoniotagodi lotaÉĄĖķateta, neÉĄĖķeeteta, âNiÉĄĖķina enoale, aniÉĄĖķicatibige daÉĄĖķa anoe okoÉĄĖķokoodi, odaa itoatadiÉĄĖķida meni me daÉĄĖķadowooÉĄĖķoti.â  
\v 62 Odaa Pedro ja noditicogi anei, odaa eliodi manoetibece. 
\s1 Icoa iodaÉĄĖķawadi onalaketedibige Jesus 
\r (Mateus 26.67-68; Marcos 14.65) 
\p  
\v 63 Icoa ÉĄĖķoneleegiwadi anoyowie Jesus onigiwogotedice, codaa monalaketedibige.  
\v 64 Onoxoco ligecooÉĄĖķeli, odaaÉĄĖķoyalaketigi latobi, odaa joÉĄĖķoige, moditalo, âIwela, amiijo ica ane ÉĄĖķadalakeni?â  
\v 65 Odaa owidi eletidi anodigotalo moyametibigo. 
\s1 Jesus ideite lodoe ica me dilapode lacilodi judeutedi 
\r (Mateus 26.59-66; Marcos 14.55-64; JoÃĢo 18.19-24) 
\p  
\v 66 NaÉĄĖķa yeloÉĄĖķotibige, niÉĄĖķijoa lacilodi judeutedi, ijaaÉĄĖķijo niÉĄĖķijo anoiiÉĄĖķe sacerdotitedi, ijaaÉĄĖķijo anodiiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs, niÉĄĖķidi ja yatecoÉĄĖķo. Odaa joÉĄĖķodipoko monadeegitedicogi Jesus lodoe me dilapode.  
\v 67 Odaa joÉĄĖķoige, moditalo, âManige akamaÉĄĖķakaami NiÉĄĖķicoa ane niwakatee AneotedoÉĄĖķoji me ÉĄĖķodatamaÉĄĖķateetetege ÉĄĖķodaxakawepodi? EnitoÉĄĖķowa nige naÉĄĖķakamaÉĄĖķakaami!â Odaa ja igidi, meetediogi, âDeÉĄĖķejitaÉĄĖķawatiwaji neÉĄĖķemeÉĄĖķee, aÉĄĖķadadiwaÉĄĖķati.  
\v 68 Codaa daÉĄĖķa ÉĄĖķadigeetiwaji, aÉĄĖķadigiti.  
\v 69 Pida Ee, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, aÉĄĖķica daÉĄĖķa leegi odaa ja idicotini liwai libaaÉĄĖķadi AneotedoÉĄĖķoji aninoatawece loniciweÉĄĖķeco.â  
\v 70 Odaa iditawece joÉĄĖķoige, moditalo, âIda makaami, akaami Lionigi AneotedoÉĄĖķoji?â Odaa ja igidi, meetediogi, âEwi niÉĄĖķida alitigi ÉĄĖķagegi ewi neÉĄĖķemeÉĄĖķee Lionigi AneotedoÉĄĖķoji.â  
\v 71 Odaa joÉĄĖķodi, âAÉĄĖķalee jopooÉĄĖķatibige eledi oko daÉĄĖķa neloÉĄĖķoditoÉĄĖķowa aneyatedigi ligegi, leeÉĄĖķodi okomoÉĄĖķoko ja jajipaaÉĄĖķatalo ane lotaÉĄĖķaneÉĄĖķegi!â 
\c 23  
\s1 Jesus oyadeegitalo Pilatos, ica romaano ane iiÉĄĖķe nipodaÉĄĖķa JudÃĐia 
\r (Mateus 27.1-2, 11-14; Marcos 15.1-5; JoÃĢo 18.28-38) 
\p  
\v 1 Odaa ijotawece niÉĄĖķijo lapo-nelegi dabiditiniwace, odaa joÉĄĖķoyadeegi Jesus minitaÉĄĖķa Pilatos.  
\v 2 Odaa ja notaÉĄĖķanaÉĄĖķateloco modakapetege Jesus, modi, âJa jibaÉĄĖķatalo niÉĄĖķidoa ÉĄĖķoneleegiwa ane niiÉĄĖķaxitediniwace ÉĄĖķodoiigi modakapetege romaanotedi, codaa me doÉĄĖķoyedia ane leeditibige me jedianaÉĄĖķa CÃĐsar, ninionigi-eliodi romaanotedi. Codaa IdaaÉĄĖķidoa mee ica minionigi-eliodi, AneotedoÉĄĖķoji ane niiÉĄĖķe.â  
\v 3 Odaa Pilatos ja ige Jesus, meetalo, âEwi naÉĄĖķakamaÉĄĖķakaami ninionigi-eliodi judeutedi?â Jesus ja igidi, meeteta, âIniotagodi, ewi niÉĄĖķida ÉĄĖķagegi.â  
\v 4 Odaa Pilatos jeÉĄĖķeetiogi niÉĄĖķijo anoiiÉĄĖķe sacerdotitedi, ijaaÉĄĖķijo noiigi-nelegi, âAÉĄĖķica ane beyagi ane jinaditece idoa ÉĄĖķoneleegiwa daÉĄĖķa jiiÉĄĖķenatakatalo moyeloadi.â  
\v 5 Pida joÉĄĖķoyopilaÉĄĖķaditacelogo niÉĄĖķijoa lotaÉĄĖķa, notigimadaÉĄĖķa, modi, âPida niiÉĄĖķaxitediniwace ÉĄĖķodoiigi anitawece JudÃĐia modakapetege romaanotedi, anetiÉĄĖķodiiÉĄĖķe. Yajela nipodigi GalilÃĐia, natigide jeÉĄĖķenotedicogi digoina JerusalÃĐm.â 
\s1 Jesus jaÉĄĖķaÉĄĖķoyadeegitedicogi lodoe Herodes, niÉĄĖķijo anoiolatice romaanotedi me iiÉĄĖķe nipodaÉĄĖķa GalilÃĐia 
\p  
\v 6 NiÉĄĖķijo Pilatos naÉĄĖķa wajipatibece Jesus mida aneetetege noiigi galileu, odaa ja ige migewi me galileu.  
\v 7 IgaanaÉĄĖķa yowooÉĄĖķodi Pilatos Jesus me icoÉĄĖķotedicogi nipodigi anei me diiÉĄĖķenataka Herodes, odaa ja iiÉĄĖķetedicogi minitaÉĄĖķa, leeÉĄĖķodi Herodes aaÉĄĖķaÉĄĖķa ini manitaÉĄĖķa nigotaÉĄĖķa JerusalÃĐm niÉĄĖķijoa nokododi. 
\p  
\v 8 NiÉĄĖķijo Herodes naÉĄĖķa nadi Jesus, odaa eliodi me ninitibece, leeÉĄĖķodi ijo me wajipatibece icoa anee, codaa akaa domaÉĄĖķa yemaa me nadi. Odaa ja walitibigege Jesus deÉĄĖķeote okanicodaaÉĄĖķica ÉĄĖķodoxiceÉĄĖķedi.  
\v 9 Codaa eliodi me nigetedice Jesus, pida aigidi.  
\v 10 NiÉĄĖķijo anoiiÉĄĖķe sacerdotitedi ijaaÉĄĖķijo niÉĄĖķijo anodiiÉĄĖķaxinaÉĄĖķatece lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs, idiaaÉĄĖķi dabiditiniwace. Odaa dinoniciwaÉĄĖķaditibigiwaji me notaÉĄĖķanaÉĄĖķa modakapetege Jesus.  
\v 11 Herodes ijaaÉĄĖķijoa niodaÉĄĖķawadi oniweenigitedice Jesus, codaa moyametibigo. OnixomeÉĄĖķetedinigi nijayogo inionigi-eliodi, odaa Herodes ja iiÉĄĖķetacedicogi minitaÉĄĖķa Pilatos.  
\v 12 Odaa Herodes ijaa Pilatos ja dinokaaÉĄĖķetewamigi ijaaÉĄĖķijo niÉĄĖķijo noko, leeÉĄĖķodi niÉĄĖķicoa nokododi dinelatiwage. 
\s1 Pilatos diiÉĄĖķenatakatalo Jesus moyeloadi 
\r (Mateus 27.15-26; Marcos 15.6-15; JoÃĢo 18.39â19.16) 
\p  
\v 13 Odaa Pilatos ja yatecoÉĄĖķotee niÉĄĖķijo anoiiÉĄĖķe sacerdotitedi ijaaÉĄĖķijoa niÉĄĖķijoa lacilodi judeutedi, codaa mijotawece niÉĄĖķijo noiigi.  
\v 14 Odaa jeÉĄĖķeetiogi, âJaÉĄĖķanadeegitediwatiwaji niÉĄĖķidoa ÉĄĖķoneleegiwa menitiwa ica meote lacilo ÉĄĖķadoiigi me nakapetegipi romaanotedi. Pida digawinitiwaji, ja inigetedice ÉĄĖķadodoe, odaa jakadi ina me diÉĄĖķica loenatagi ane beyagi, niÉĄĖķijoa anenitalo meote.  
\v 15 Codaa Herodes idaaÉĄĖķee yakadi me diÉĄĖķica loenatagi ane beyagi, joaniÉĄĖķidaa leeÉĄĖķodi me niiÉĄĖķetacedicogi mokotaÉĄĖķa. Pida digawinitiwaji! AÉĄĖķica loenatagi ane beyagi daÉĄĖķa leeditibige me jiiÉĄĖķenatakatalo moyeloadi.  
\v 16 Pida jiiÉĄĖķenatakatalo moyametibigo, odaa nigidiaaÉĄĖķidi ja jikatedice.â  
\v 17 Inoatawece nicaaÉĄĖķape me nakatio nalokegi PÃĄscoa, leeditibige Pilatos me ikatice onidateci ÉĄĖķoneleegiwa niwilogojegi, leeÉĄĖķodi mina ligileÉĄĖķegitibece. 
\p  
\v 18 Odaa iditawece niÉĄĖķidi noiigi notaÉĄĖķanaÉĄĖķateloco, codaa napaawaÉĄĖķateloco, modi, âAdeegi niÉĄĖķidoa ÉĄĖķoneleegiwa meloati, odaa anikanitoÉĄĖķodomi BarrabÃĄs!â  
\v 19 NiÉĄĖķica BarrabÃĄs one niwilogojegi leeÉĄĖķodi eyatege niÉĄĖķidi noiigi me lakapetegipi ninionigi-eliodi romaanotedi, codaa onica laigo. 
\p  
\v 20 Odaa Pilatos joÉĄĖķopitacege me notaÉĄĖķaneÉĄĖķetiniwace, leeÉĄĖķodi domaÉĄĖķa lipegeÉĄĖķedi me ikatedice Jesus.  
\v 21 Pida jeÉĄĖķepaanaÉĄĖķa napaawaÉĄĖķateloco niÉĄĖķijo noiigi, modi, âOtonitedeloco nicenaÉĄĖķanaÉĄĖķate! Otonitedeloco nicenaÉĄĖķanaÉĄĖķate!â  
\v 22 Odaa jiÉĄĖķicota me itoatadiÉĄĖķida Pilatos me nigetiniwace, meetiogi, âPida amiini ica loenatagi ane beyagi me leeditibige me jiiÉĄĖķenatakatalo moyeloadi? EmeÉĄĖķee aÉĄĖķica jakadi ane leeÉĄĖķodi daÉĄĖķa jiiÉĄĖķenatakatalo moyeloadi. Pida jiiÉĄĖķenatakatalo monalaketedibige. NigidiaaÉĄĖķidi odaa ja jikatedice.â  
\v 23 Pida idokee modoletibige niÉĄĖķica mowo anodigotalo Jesus, codaa jeÉĄĖķepaanaÉĄĖķa dinigetaÉĄĖķateetibigiwaji me napaawaÉĄĖķateloco, modipokotibige moyototedeloco Jesus nicenaÉĄĖķanaÉĄĖķate. NiÉĄĖķijo noiigi ijaaÉĄĖķijo niÉĄĖķijo anoiiÉĄĖķe sacerdotitedi napaawaÉĄĖķa neÉĄĖķepaa oyakadi anodoletibige.  
\v 24 Odaa Pilatos ja yajigo Jesus midiwa iodaÉĄĖķawadi mowo niÉĄĖķica anoyemaa modigotalo niÉĄĖķijo noiigi.  
\v 25 Odaa ja ikatice niÉĄĖķijo anodipoko me ikatice, ane diniwilo leeÉĄĖķodi meyatege loiigi modakapetege ninionigi-eliodi romaanotedi codaa me daije. Pida Jesus baanaÉĄĖķa yajigo midiwa iodaÉĄĖķawadi moyeloadi, anoyemaa niÉĄĖķijo noiigi-nelegi modigotalo. 
\s1 Jesus oyototedeloco nicenaÉĄĖķanaÉĄĖķate 
\r (Mateus 27.32-44; Marcos 15.21-32; JoÃĢo 19.17-27) 
\p  
\v 26 Odaa niÉĄĖķijoa iodaÉĄĖķawadi joÉĄĖķoyadeegi Jesus. EÉĄĖķidaa diiticogi migotibeci, joÉĄĖķodakapetege ica ÉĄĖķoneleegiwa ane liboonaÉĄĖķadi SimÃĢo ane liÉĄĖķeladi nigotaÉĄĖķa Cirene. SimÃĢo icoÉĄĖķoticogi nipodigi. Odaa joÉĄĖķodibata SimÃĢo, oyexaÉĄĖķateloco naÉĄĖķajo nicenaÉĄĖķanaÉĄĖķate digoina lewagi, odaa joÉĄĖķowo me yadeegi dilokotelogo Jesus. 
\p  
\v 27 Eliodi ica noiigi anodiotece Jesus. Liwigotigi niÉĄĖķidi oko ijo iwaalepodi ane noenaÉĄĖķateloco, codaa eliodi me agecaÉĄĖķalodipi leeÉĄĖķodi niÉĄĖķida anodigotalo Jesus.  
\v 28 Pida Jesus naÉĄĖķa nawiilitetetege, odaa jeÉĄĖķeetediogi, âIwaalepodi, anakaami niÉĄĖķeladimigipitigi JerusalÃĐm, jinaÉĄĖķanoeni leeÉĄĖķodi niÉĄĖķida aneji, pida anoeni leeÉĄĖķodi akamaÉĄĖķakaamitiwaji idiaa ÉĄĖķadionigipi!  
\v 29 LeeÉĄĖķodi ewi micota nokododi niÉĄĖķina oko nigodi, âNinitibigiwaji niÉĄĖķina iwaalepodi analee diÉĄĖķica linala!â  
\v 30 Codaa odipokotalo niÉĄĖķinoa wetiadi, modi, âĮĪodapoÉĄĖķoteÉĄĖķegiti!â Codaa oditiogi niÉĄĖķinoa lojotakatedi, âĮĪodaaÉĄĖķateÉĄĖķegitini!â  
\v 31 IgaataÉĄĖķa nigowo niÉĄĖķida anodigotiwa, Ee ane ideÉĄĖķenaÉĄĖķa, ane iciagi niÉĄĖķina iwoÉĄĖķo baÉĄĖķalee dione (ane doÉĄĖķoibake mowo noledi), pida ÉĄĖķadaxakawepodi baÉĄĖķa daÉĄĖķaxa me beyagi anodigotaÉĄĖķawa, ane ÉĄĖķadiciagi niÉĄĖķina iwoÉĄĖķo baanaÉĄĖķa yadilo (ane yabidi, odaa aÉĄĖķica ane yeyaÉĄĖķatice).â 
\p  
\v 32 NiÉĄĖķijoa iodaÉĄĖķawadi eletidi oyadeegi itoataale ÉĄĖķoneleegiwadi ÉĄĖķonematagododi me lemaÉĄĖķawepodi Jesus.  
\v 33 NiÉĄĖķijo noÉĄĖķotota ica lojotaÉĄĖķadi ane liboonaÉĄĖķadi âLibitagi ĮĪodaciloâ, odaa jiÉĄĖķidiaaÉĄĖķi Jesus moyototedeloco nicenaÉĄĖķanaÉĄĖķate. IjaaÉĄĖķijoa itoataale ÉĄĖķoneleegiwadi ÉĄĖķonematagododi eletidi nicenaÉĄĖķanaÉĄĖķatedi anoyototelogo, onidateci diÉĄĖķeticogi liwai libaaÉĄĖķadi Jesus, ijo eledi diÉĄĖķetege nimagijegi.  
\v 34 Jesus mee, âEiodi, jinaÉĄĖķaloikatiti niÉĄĖķidi noiigi leeÉĄĖķodi niÉĄĖķida anodigotiwa. IgaataÉĄĖķa aÉĄĖķoyowooÉĄĖķodi niÉĄĖķida ane loenatagi.â Odaa joÉĄĖķoiwi anepaÉĄĖķa dinetetece noÉĄĖķodinawalacetibige lowoodi. 
\p  
\v 35 Ica noiigi-nelegi idiaaÉĄĖķitice dabiditiniwace oiwitalo Jesus, ijaaÉĄĖķijoa lacilodi eletidi idiaaÉĄĖķiticoaci, odaa modi, âEote eledi oko me newiÉĄĖķatace. DaantiÉĄĖķidaaÉĄĖķidoa NiÉĄĖķicoa ane niiÉĄĖķe AneotedoÉĄĖķoji me ÉĄĖķodewikatidi, ane iomaÉĄĖķaditedice AneotedoÉĄĖķoji, daÉĄĖķanagawini ida nimaweneÉĄĖķegi meote lewiÉĄĖķa.â 
\p  
\v 36 NiÉĄĖķijoa iodaÉĄĖķawadi oyametibigo Jesus. Igotibeci midoataÉĄĖķa domoÉĄĖķoyacipeÉĄĖķetalo viinyo ane daÉĄĖķa dakake loojedi.  
\v 37 Odaa moditalo, âNigewi makaami ninionigi-eliodi judeutedi, dicakamaÉĄĖķa awii ÉĄĖķadewiÉĄĖķa!â 
\p  
\v 38 MadataÉĄĖķa licenaÉĄĖķanaÉĄĖķate Jesus ditibigimedawaanigi lacilo, oyototeloco taaboa-liwai ane diniditeloco, 
\qc \sc âNIĮĪIDOA NINIONIGI-ELIODI JUDEUTEDI.â\sc* 
\m Diniditelogo niÉĄĖķijoa notaÉĄĖķa nioladi greego, nioladi romaano, nioladi hebraico. 
\p  
\v 39 GanigepidiÉĄĖķica niÉĄĖķijoa itoataale ÉĄĖķonematagododi anaÉĄĖķaÉĄĖķa oyototeloco nicenaÉĄĖķanaÉĄĖķate, beyagi lotaÉĄĖķatalo Jesus, meetalo, âNigewi naÉĄĖķakamaÉĄĖķakaami ane niiÉĄĖķe AneotedoÉĄĖķoji, dice awii ÉĄĖķadewiÉĄĖķa, codaa moko awii ÉĄĖķodewiÉĄĖķa!â  
\v 40 Pida niÉĄĖķijo eledi ÉĄĖķonematagodi ja yoxoÉĄĖķo, meeta, âJinaÉĄĖķawii niÉĄĖķida ÉĄĖķagegi, agodaÉĄĖķadoiitalo AneotedoÉĄĖķoji? EtiÉĄĖķodiloikatidi midokida anodigotoÉĄĖķowa.  
\v 41 Codaa niÉĄĖķida ÉĄĖķodawikodigi oko itoataale baÉĄĖķa iÉĄĖķenaÉĄĖķa, leeÉĄĖķodi me jedianaÉĄĖķateloco niÉĄĖķijoa ÉĄĖķodoenataka ane beyagi. Pida niÉĄĖķidoa ÉĄĖķoneleegiwa, aÉĄĖķica loenatagi ane beyagi.â  
\v 42 Odaa jeÉĄĖķeetalo Jesus, âIniotagodi, analakitibigiji, nigadopilitijo, nige limedi managi iiÉĄĖķeni inoatawece.â  
\v 43 Odaa Jesus jeÉĄĖķeeteta, âEjitaÉĄĖķawa niÉĄĖķina anewi, niÉĄĖķina noko adeoni meetaÉĄĖķa digoida ditibigimedi.â 
\s1 LemeÉĄĖķegi Jesus 
\r (Mateus 27.45-56; Marcos 15.33-41; JoÃĢo 19.28-30) 
\p  
\v 44-45 NaÉĄĖķa nipegi me yaxoÉĄĖķo-noko, odaa aligeÉĄĖķe ja ipe, ja nexocaÉĄĖķa inatawece iiÉĄĖķo, neÉĄĖķepaa iniwatadaÉĄĖķani lakata me ÉĄĖķocidi. Codaa naÉĄĖķajo lipegeteÉĄĖķe minitaÉĄĖķa AneotedoÉĄĖķoji liÉĄĖķeladi, ane iomaÉĄĖķaditege oko aneite AneotedoÉĄĖķoji, naÉĄĖķajo lipegeteÉĄĖķe daawidigidicetigi liwigotigi ditibigimedi, icoÉĄĖķotibigimece ditibigimedi neÉĄĖķepaa natinedi.  
\v 46 Odaa Jesus dinigetaÉĄĖķatee me dapaawe, mee, âEiodi, jajigotaÉĄĖķawa iwigo!â NaÉĄĖķa nigotedini me dotaÉĄĖķa, odaa ja yeleo. 
\p  
\v 47 NiÉĄĖķijo nowienoÉĄĖķodi niodaÉĄĖķawadi romaanotedi naÉĄĖķa nadi niÉĄĖķijo niciagi, odaa ja iweniÉĄĖķide AneotedoÉĄĖķoji, mee, âNiÉĄĖķica mewi niÉĄĖķidoa ÉĄĖķoneleegiwa me diÉĄĖķicata loenatagi ane beyagi!â \fig |src="cn01844B.tif" size="col" copy="ÂĐ 1978 David C. Cook Publishing Co." ref="Lucas 23.47" \fig* 
\p  
\v 48 Ijotawece niÉĄĖķijo oko ane dilapode moiwi niÉĄĖķida niciagi, joÉĄĖķoyabaketibigeloco elipije, moikee magecaÉĄĖķalodipi, odaa niÉĄĖķidiaaÉĄĖķidi joÉĄĖķopiticogi inoa liÉĄĖķelatedi.  
\v 49 Odaa ijotawece niÉĄĖķijo lokaaÉĄĖķetedipi Jesus, ijaaÉĄĖķijo iwaalepodi anoniotece, oicoÉĄĖķoticogi nipodigi GalilÃĐia, aÉĄĖķipegitiobece, pida boÉĄĖķonadi ijoatawece anee niÉĄĖķijo niciagi. 
\s1 Oixotiwece lolaadi Jesus midataÉĄĖķa lawimaÉĄĖķajegi-wetiÉĄĖķa 
\r (Mateus 27.57-61; Marcos 15.42-47; JoÃĢo 19.38-42) 
\p  
\v 50-51 Onini ica ÉĄĖķoneleegiwa ane liboonaÉĄĖķadi JosÃĐ, ane liÉĄĖķeladi aca nigotaÉĄĖķa ArimatÃĐia, nipodigi JudÃĐia. InaaÉĄĖķina ÉĄĖķoneleegiwa anele, codaa me iÉĄĖķenaÉĄĖķa, nibeotibigege ica noko AneotedoÉĄĖķoji nige iiÉĄĖķe inatawece iiÉĄĖķo. Codaa ida aneetege icoa seteenta lacilodi judeutedi. Pida aniwoditema niÉĄĖķicoa eletidi lacilodi, niÉĄĖķijo noÉĄĖķodoletibige nimaweneÉĄĖķegi mowo anodigotalo Jesus.  
\v 52 NiÉĄĖķijo ÉĄĖķoneleegiwa igo minitaÉĄĖķa Pilatos dipokota Jesus lolaadi.  
\v 53 Odaa JosÃĐ jiÉĄĖķigo noÉĄĖķa Jesus lolaadi madataÉĄĖķa nicenaÉĄĖķanaÉĄĖķate, odaa ja ilipaditigi aca niÉĄĖķelate. NiÉĄĖķidiaaÉĄĖķidi ja ixotiwece niÉĄĖķijo lolaadi Jesus catiwedi ica lawimaÉĄĖķajegi-wetiÉĄĖķa, baanaÉĄĖķa igo me dinaligi maditaÉĄĖķa aca wetiÉĄĖķa. NiÉĄĖķijo lawimaÉĄĖķajegi aniÉĄĖķica doÉĄĖķoibake diÉĄĖķica ÃĐmeÉĄĖķegi anoixotiwece.  
\v 54 NiÉĄĖķijo noko anaÉĄĖķa nakatio saabado, pida niÉĄĖķijo noko niÉĄĖķidi noiigi joÉĄĖķodinoetege ica saabado. 
\p  
\v 55 NiÉĄĖķijo iwaalepodi anoniotece Jesus anoicoÉĄĖķoticogi GalilÃĐia, joÉĄĖķodioteci JosÃĐ. Odaa boÉĄĖķonadi niÉĄĖķica lawimaÉĄĖķajegi-wetiÉĄĖķa, codaa monadi niÉĄĖķica anodigota lolaadi Jesus.  
\v 56 NiÉĄĖķidiaaÉĄĖķidi joÉĄĖķopiticogi inoa liÉĄĖķelatedi, odaa joÉĄĖķoyoe edokojetedi, ina najidi aneletege lanigi, moyatita Jesus lolaadi. NaÉĄĖķa saabado jaÉĄĖķanipetiniwace, ane liiÉĄĖķenatakaneÉĄĖķegi AneotedoÉĄĖķoji. 
\c 24  
\s1 Jesus naÉĄĖķa yewiÉĄĖķatace 
\r (Mateus 28.1-10; Marcos 16.1-8; JoÃĢo 20.1-10) 
\p  
\v 1 NaÉĄĖķa domiingo me nigoitijo, niÉĄĖķijo iwaalepodi jiÉĄĖķigotibeci midataÉĄĖķa niÉĄĖķijo lawimaÉĄĖķajegi-wetiÉĄĖķa anoyatice lolaadi Jesus, oyadeegi nadokojetedi anoyoe. Codaa ijo eledi iwaalepodi lixigaÉĄĖķawepodi.  
\v 2 NiÉĄĖķicotiobeci, odaa joÉĄĖķonadi naÉĄĖķajo wetiÉĄĖķa nelegi anoyatita monoxoco niÉĄĖķijo lawimaÉĄĖķajegi-wetiÉĄĖķa, joÉĄĖķonoÉĄĖķaticogi niÉĄĖķijo aneitice.  
\v 3 Pida naÉĄĖķa dakatiobece, aÉĄĖķaleeÉĄĖķica moyakadi lolaadi ĮĪoniotagodi Jesus.  
\v 4 AÉĄĖķoyowooÉĄĖķodi ane diitigi niÉĄĖķida niciagi, odaa eÉĄĖķidaaÉĄĖķee me nowookonaÉĄĖķa, codaa noÉĄĖķonida dinikeetiogi lodoe itoataale ÉĄĖķoneleegiwadi, odinixotinigilo nowoodi ane datale. \fig |src="cn01853B.tif" size="span" copy="ÂĐ 1978 David C. Cook Publishing Co." ref="Lucas 24.4" \fig* 
\v 5 Odaa niÉĄĖķijo iwaalepodi eliodi me doitibigiwaji, dakagitiniwace neÉĄĖķepaa iiÉĄĖķo. Odaa niÉĄĖķijoa ÉĄĖķoneleegiwadi ja nigikanaÉĄĖķa, modi, âIgaameni ina moleetibigetiwaji midiwataÉĄĖķa ÃĐmaÉĄĖķaÉĄĖķa ijoa baanaÉĄĖķa yewiÉĄĖķa?  
\v 6 AÉĄĖķicoatedigi digoina, pida ja yewiÉĄĖķatace. EÉĄĖķanalakitibigetiwaji ijoa lotaÉĄĖķatedaÉĄĖķawa maleeÉĄĖķidiaaÉĄĖķitedice nipodigi GalilÃĐia, niÉĄĖķijo neÉĄĖķeetedaÉĄĖķawatiwaji,  
\v 7 âEe, ĮĪoneleegiwa ane jicoÉĄĖķotibigimece ditibigimedi, leeditibige metidajigotiogi ÉĄĖķoneleegiwadi abeyacaÉĄĖķaÉĄĖķa, codaa etidototeloco nicenaÉĄĖķanaÉĄĖķate, igaanige ixomaÉĄĖķatedijo itoatadiÉĄĖķida nokododi, odaa ja idewiÉĄĖķatace.ââ 
\p  
\v 8 Odaa niÉĄĖķijo iwaalepodi joÉĄĖķonalaÉĄĖķatigilo niÉĄĖķijoa lotaÉĄĖķa.  
\v 9 Odaa joÉĄĖķopitibeci, me icoÉĄĖķoticogi midataÉĄĖķa lawimaÉĄĖķajegi-wetiÉĄĖķa, igotibeci oyeloÉĄĖķoditiogi niÉĄĖķijo oonze anodiotibece Jesus, ijaaÉĄĖķijo eletidi.  
\v 10 NiÉĄĖķijo iwaalepodi noÉĄĖķoyatematitiogi niÉĄĖķijoa liiÉĄĖķexedi Jesus, anonadi, niÉĄĖķidi iwaalepodi liboonaÉĄĖķatedi Maria Madalena, Joana, Maria ane eliodo Tiago, ijaaÉĄĖķijo eledi iwaalepodi lixigaÉĄĖķawepodi.  
\v 11 Pida noÉĄĖķowajipata niÉĄĖķijo latematigo niÉĄĖķijo iwaalepodi, oyakadi ina daÉĄĖķa dinetoletibigiwaji, odaa aÉĄĖķoyiwaÉĄĖķadi.  
\v 12 Pida naÉĄĖķa dabiditi Pedro, odaa ja walokoditicogi midataÉĄĖķa niÉĄĖķijo lawimaÉĄĖķajegi-wetiÉĄĖķa. NiÉĄĖķicoticogi, odaa dakagitini iwitiwece catiwedi. Pida ijoka naditeda niÉĄĖķijoa niÉĄĖķelateli. Odaa joÉĄĖķopiticogi liÉĄĖķeladi, eliodi me nawela leeÉĄĖķodi niÉĄĖķijo ane nadi. 
\s1 Jesus iwidatediogi itoataale anodiotibece digoida naigi nigotakawaana EmaÃšs 
\r (Marcos 16.12-13) 
\p  
\v 13 IjaaÉĄĖķijo niÉĄĖķijo noko itoataale anodiotibece igotibeci manitaÉĄĖķa nigotakawaana anodita EmaÃšs, ejime itoa leegoa me yototice JerusalÃĐm.  
\v 14 NiÉĄĖķijoa ÉĄĖķoneleegiwadi odinotaÉĄĖķaneÉĄĖķetigi niÉĄĖķicoa ane loanico Jesus.  
\v 15 EoniÉĄĖķidaaÉĄĖķee me dinotaÉĄĖķaneÉĄĖķe, dinotigimadetiwage, naÉĄĖķa iwidatediogi Jesus, odaa ja lixigaÉĄĖķawepodi.  
\v 16 Odaa noÉĄĖķonadi aÉĄĖķoyowooÉĄĖķodi, AneotedoÉĄĖķoji eote me doÉĄĖķoyowooÉĄĖķoditeda. 
\p  
\v 17 Odaa Jesus ja nigetediniwace, meetediogi, âAmiina ica ane ÉĄĖķadalakitatiwaji ina naigitece? Codaa igame leeÉĄĖķodi ina makaami agecaÉĄĖķalodipi?â  
\v 18 Odaa ica ane liboonaÉĄĖķadi Cleopas ja igidi, meetalo, âManigakamokakaami ane ideoni JerusalÃĐm, ane daÉĄĖķa yowooÉĄĖķodi ijo niciagi, natigidiwaÉĄĖķa niÉĄĖķijoa nokododawaanaÉĄĖķa ane ixomaÉĄĖķatedice?â  
\v 19 Odaa ja digika, meetediogi, âAmiida ica niciagi ane ÉĄĖķadalaki?â Odaa joÉĄĖķoigidi, moditalo, âIdinotaÉĄĖķaneÉĄĖķenaÉĄĖķatigi ninyaagi Jesus, niÉĄĖķijoa anelatedibige NazarÃĐ. InaaÉĄĖķina niÉĄĖķina ane yeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko, eliodi nimaweneÉĄĖķegi niÉĄĖķina me dotaÉĄĖķa, codaa owidi loenataka datikate loniciwaÉĄĖķa lodoe AneotedoÉĄĖķoji, codaa me lodoe eliodi oko.  
\v 20 NiÉĄĖķijo anoiiÉĄĖķe sacerdotitedi ijaaÉĄĖķijoa ÉĄĖķodacilodi oyajigo moyeloadi, odaa joÉĄĖķoyototedeloco nicenaÉĄĖķanaÉĄĖķate.  
\v 21 Pida ja domiÉĄĖķijaa jaliiÉĄĖķatalo me yatamaÉĄĖķateetetege ÉĄĖķodoiigi Israel niÉĄĖķina laxakawepodi. Pida niÉĄĖķina noko jeÉĄĖķeote itoatadiÉĄĖķida nokododi moyeloadi.  
\v 22 Pida ijo iwaalepodi ÉĄĖķodokaaÉĄĖķetedipi mejiwaÉĄĖķatibece ĮĪoniotagodi, owotibige meliodi me ÉĄĖķodawela. Eka yapacaÉĄĖķatege nigoi, niÉĄĖķigotibeci midataÉĄĖķa lawimaÉĄĖķajegi-wetiÉĄĖķa anoyatice lolaadi ĮĪoniotagodi.  
\v 23 Odaa aÉĄĖķaleeÉĄĖķica moyakadi lolaadi. Odaa ja dopitijo modi ica modinikeetiogi icoa aanjotedi, odaa niÉĄĖķicoa aanjotedi onodi ica naÉĄĖķa yewiÉĄĖķatace.  
\v 24 Odaa jiÉĄĖķijo ÉĄĖķodokaaÉĄĖķetedipi anigotibeci midataÉĄĖķa niÉĄĖķijo lawimaÉĄĖķajegi-wetiÉĄĖķa, odaa joÉĄĖķonadi mewi niÉĄĖķijo anodita niÉĄĖķijo iwaalepodi. Pida aÉĄĖķicoa monadi ĮĪoniotagodi Jesus.â 
\p  
\v 25 Odaa Jesus jeÉĄĖķeetediogi, âNiÉĄĖķida makaamitiwaji aÉĄĖķica ÉĄĖķadowoogo, codaa dakake ÉĄĖķadaaleÉĄĖķenali, me daÉĄĖķa iwaÉĄĖķatiteda ijoatawece lotaÉĄĖķa niÉĄĖķijo anoyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko.  
\v 26 NiÉĄĖķijoa AneotedoÉĄĖķoji ane niiÉĄĖķe leeditibige me dawikode, odaa ja dakatediwece miniwataÉĄĖķa Eliodi.â  
\v 27 Odaa ja yeloÉĄĖķoditediogi ijotawece liwai AneotedoÉĄĖķoji lotaÉĄĖķanaÉĄĖķaxi aneetece Jesus. Yajela niÉĄĖķijo liwai MoisÃĐs ligegi, ijaaÉĄĖķijo liwai aneetece Jesus, anoidi niÉĄĖķijo anoyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko. 
\p  
\v 28 NiÉĄĖķijo noÉĄĖķodipegita naÉĄĖķajo nigotakawaana ane diiticogi, Jesus eote micataÉĄĖķa daÉĄĖķa ixomaÉĄĖķatedicogi odoe.  
\v 29 Odaa joÉĄĖķonolitedini, moditalo, âInaaÉĄĖķoni mokotaÉĄĖķa, leeÉĄĖķodi ja ÉĄĖķocidi.â Odaa ja dakatediwece ica diimigi, midiaaÉĄĖķinawaanigite.  
\v 30 Odaa niÉĄĖķica naÉĄĖķa nicotedi maditaÉĄĖķa aca nameeja, ijaaÉĄĖķijoa itoa ÉĄĖķoneleegiwadi, naÉĄĖķa dibate ica paon, odaa ja diniotagodete AneotedoÉĄĖķoji. NaÉĄĖķa inoke niÉĄĖķijo paon, odaa ja yajigotediogi.  
\v 31 Odaa AneotedoÉĄĖķoji jeÉĄĖķeote niÉĄĖķijoa ÉĄĖķoneleegiwadi moyowooÉĄĖķodi me Jesus. Pida jiÉĄĖķidiaa laakadi.  
\v 32 Odaa oninitecibeci mee, âAgodaÉĄĖķaleeÉĄĖķaÉĄĖķa, jowooÉĄĖķotaÉĄĖķa naÉĄĖķa itineÉĄĖķe ÉĄĖķodaaleÉĄĖķena, niÉĄĖķijo naÉĄĖķa ÉĄĖķodotaÉĄĖķaneÉĄĖķetedice digoida naigi me neloÉĄĖķoditedoÉĄĖķowa liwai AneotedoÉĄĖķoji lotaÉĄĖķanaÉĄĖķaxi?â 
\p  
\v 33 AjaaÉĄĖķajo naÉĄĖķajo lakata naÉĄĖķa dabiditiniwace, odaa joÉĄĖķopitacicogi nigotaÉĄĖķa JerusalÃĐm. Odaa joÉĄĖķototiogi niÉĄĖķijo oonze anodiotibece Jesus, ijaaÉĄĖķijo eledi oko anawatege.  
\v 34 Odaa moditiogi niÉĄĖķijo itoataale, âDicewi ĮĪoniotagodi naÉĄĖķa yewiÉĄĖķatace. One dinikeeteta SimÃĢo.â  
\v 35 Odaa niÉĄĖķijo itoataale jaÉĄĖķaÉĄĖķoyatemati anodaaÉĄĖķee monadi digoida naigi, codaa oyatemati moyowooÉĄĖķodi ĮĪoniotagodi niÉĄĖķijo naÉĄĖķa inoke niÉĄĖķijo paon. 
\s1 Jesus dinikeetediogi niÉĄĖķijo anodiotibece 
\r (Mateus 28.16-20; Marcos 16.14-18; JoÃĢo 20.19-23; Atos 1.6-8) 
\p  
\v 36 EoniÉĄĖķidaaÉĄĖķee moyatemati, codaa noÉĄĖķonidoateda Jesus naÉĄĖķa dinikee liwigotigi. Odaa jeÉĄĖķeetediogi, âJemaa AneotedoÉĄĖķoji meote mele ÉĄĖķadaaleÉĄĖķenalitiwaji!â 
\p  
\v 37 Pida nawelatibigiwaji, codaa eliodi me doitibigiwaji, odiletibige doÉĄĖķonadi niwigo.  
\v 38 Pida meetediogi, âIgame leeÉĄĖķodi ina manawelatiwaji? Codaa igame leeÉĄĖķodi me dawienataka ÉĄĖķadaaleÉĄĖķena?  
\v 39 Digawini ibaaÉĄĖķatedi, codaa me iÉĄĖķonaka! Odaa jaÉĄĖķanati mewi neÉĄĖķemeÉĄĖķee. Digabaatiloco, odaa joÉĄĖķowooÉĄĖķoti neÉĄĖķemeÉĄĖķee! LeeÉĄĖķodi niwigo aÉĄĖķicoa liboledi, oteÉĄĖķexaaÉĄĖķaÉĄĖķa libitaka, pida akaamitiwaji madati biÉĄĖķinoa iboledi.â 
\p  
\v 40 NiÉĄĖķijo neÉĄĖķee, odaa ja ikee libaaÉĄĖķatedi, codaa me loÉĄĖķonaka.  
\v 41 Pida aneÉĄĖķeniwaÉĄĖķatakanaÉĄĖķa, leeÉĄĖķodi meliodi me nawelatibigiwaji, codaa me ninitibigiwaji. Odaa Jesus ja digika, meetediogi, âAÉĄĖķica anigetiÉĄĖķida ÉĄĖķaweenigi domaÉĄĖķa jeligo?â  
\v 42 Odaa joÉĄĖķoyajigotalo liwai noÉĄĖķojegi niloogo.  
\v 43 Odaa ja dibatetege, jaÉĄĖķaniodi lodoe niÉĄĖķijo anodiotibece. 
\p  
\v 44 NiÉĄĖķidiaaÉĄĖķidi Jesus meetediogi, âMaleeÉĄĖķinaaÉĄĖķejotice makaamitaÉĄĖķatiwaji neÉĄĖķejitaÉĄĖķawa me leeditibige me jixomaÉĄĖķateetedice ijoatawece niÉĄĖķijoa aneetici maditaÉĄĖķa AneotedoÉĄĖķoji lotaÉĄĖķanaÉĄĖķaxi, miditaÉĄĖķa niÉĄĖķijo ane idÃ­ MoisÃĐs, miditaÉĄĖķa niÉĄĖķijoa anoidi niÉĄĖķijo anoyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko, codaa midiwataÉĄĖķa enaco.â 
\p  
\v 45 Odaa ja yajigotediogi lixakedi moyowooÉĄĖķodi ane diitigi lotaÉĄĖķanaÉĄĖķaxi AneotedoÉĄĖķoji.  
\v 46 Odaa jeÉĄĖķeetediogi, âNiÉĄĖķida diniditeloco AneotedoÉĄĖķoji lotaÉĄĖķanaÉĄĖķaxi, NiÉĄĖķijoa ane niwakatee AneotedoÉĄĖķoji me yewikatidi oko, ane Cristo, leeditibige me dawikode, codaa me yeleo, odaa yewiÉĄĖķatace nige ixomaÉĄĖķatedice itoatadiÉĄĖķida nokododi.  
\v 47 Eledi diniditeloco niÉĄĖķijoa liiÉĄĖķexedi moyeloÉĄĖķoditiogi niÉĄĖķina oko me leeditibige modinilaatece libeyaceÉĄĖķeco, odaa joÉĄĖķodopitalo AneotedoÉĄĖķoji me iwilegi laaleÉĄĖķenali. NiÉĄĖķidi liiÉĄĖķexedi oyeloÉĄĖķodi niÉĄĖķinoa nibodicetedi odatika liboonaÉĄĖķadi Cristo, minataÉĄĖķa inatawece noiigi, oyajela nigotaÉĄĖķa JerusalÃĐm.  
\v 48 Akaami nakataÉĄĖķanadi niÉĄĖķijo ane ininyaagi, odaa eloÉĄĖķotitedibece niÉĄĖķijoa ananati!  
\v 49 Odaa digawini! EmeÉĄĖķee iniwakateetibigaÉĄĖķajitiwaji niÉĄĖķijo Eiodi aneeteta. Pida ecoÉĄĖķotace inaaÉĄĖķoni nigotaÉĄĖķa JerusalÃĐm, nigepaaÉĄĖķabaategetiwaji Liwigo AneotedoÉĄĖķoji ane icoÉĄĖķotibigimece ditibigimedi ane yajigotaÉĄĖķawa ÉĄĖķadoniciwaÉĄĖķa.â 
\s1 Jesus opitedibigimece ditibigimedi 
\r (Marcos 16.19-20; Atos 1.9-11) 
\p  
\v 50 Odaa Jesus ja yadeegitedicogi wetice nigotaÉĄĖķa neÉĄĖķepaa manitaÉĄĖķa nigotakawaana BetÃĒnia. NaÉĄĖķa nawacetedibige libaaÉĄĖķatedi, odaa ja ibinietediogi.  
\v 51 EÉĄĖķidaaÉĄĖķee me ibinietediogi, Jesus jaÉĄĖķanojicetedice, odaa joÉĄĖķoyadeegitedibigimece ditibigimedi.  
\v 52 NiÉĄĖķijo anodiotibece odoÉĄĖķetetibigimece, odaa joÉĄĖķopitacicogi manitaÉĄĖķa nigotaÉĄĖķa JerusalÃĐm, eliodi me ninitibigiwaji.  
\v 53 Odaa idioka limedi me ideiticoace minitaÉĄĖķa AneotedoÉĄĖķoji liÉĄĖķeladi, modigaanaÉĄĖķatibigimece, codaa modiniotagodetalo AneotedoÉĄĖķoji. Odaa jiÉĄĖķidaaÉĄĖķee. (AmÃĐm).