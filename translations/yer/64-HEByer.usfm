\id HEB - Tarok
\h AIbərahim
\toc3 AIbər
\toc2 AIbərahim
\toc1 Nlir nnap-nlà âkum ìjili AIbərahim
\mt2 Nlir nnap-nlà âkum ìjili
\mt1 AIbərahim
\c 1
\s1 UYa Inan uwa ji pa̱ kpaktak
\p 
\v 1 Matmat te, Inan là nnap ka̱ okəka okəka yi ka̱ asa̱l pa̱ ɗongɗong pa̱ kyák ka̱ atak nnap-nlà onəm oga nka̱m nre ka̱tətak.
\v 2 Ǹyangmata̱ ka̱ ashe nra ngga nkur va̱ ta̱ ji wo te, uza̱ là nnap ayi ka̱ atak aYen wò. Uwa uza̱ nak na ta̱l uyen uga ngwur akup ká̱ iya̱m pa̱ kpaktak. Ka̱ atak a wà kpa uza̱ nəm apambin ká̱ apaɓur.
\v 3 UYen uwa ichumchum Inan va ka̱ ngghan mí yiya. Uwa kpa ka̱ nnap nnəm nva pa̱ səlak nji Inan. Uwa ka̱ nnak nkpaktak iya̱m i yà ka̱ atak ichumchum nnap-nlà ngga nfa ka̱ anunung. Ka̱ nva̱ngva̱ uza̱ gba̱l ka̱ nnal nnap-mɓá̱ngɓa̱ng yi ayi chit te, uza̱ le ɓa ga apaɓur təm ka̱wo ari Inan uwa ji pa̱ kpaktak.
\v 4 A nak te, uza̱ ji oma̱leka ji pa̱ makmak ká̱ ichumchum. Wa nva aɗin va̱ uza̱ ka̱ te, a ji ajo oza̱ ji pa̱ makmak a.
\p 
\v 5 Umaleka uro ya uva Inan là apir nnap-nlà va̱ ta̱ á na ka̱t. Nna pa̱,
\q1 <<Mmaɓu na uYen mi.
\q1 Nda n ta̱l uPo ɓu chit.>>
\m Uza̱ là iya̱m va̱ ta̱ ûma̱leka ro ka̱t kpa. Nna pa̱,
\q1 <<Mi ta̱l uPupon.
\q1 Uza̱ nnyi te, i ta̱l uYen mi.>>
\m 
\v 6 Inan won pa̱ o re nre ká̱ uYen wò ugəshi ka̱ ashe apambin va̱ ta̱ te, uza̱ là pa̱,
\q1 <<Re nkpaktak oma̱leka a wop na.>>
\m 
\v 7 Oma̱leka jiwo te, iya̱m va ta̱ uza̱ là ka̱ apal ishi oza̱. Uza̱ là pa̱,
\q1 <<Uza̱ i nak oma̱leka wò i tong wa ayə́r.
\q1 Onəm oga nnəm inunok nnyi te, uza̱ i nak i tong wa apər.>>
\m 
\v 8 Iya̱m va ta̱ Inan là ka̱ apal ishi aYen wò jiwo. Uza̱ là pa̱,
\q1 <<ÁPonzhi-Inan, iponzhi ɓu pak chit təm mbyet mbyet.
\q1 Iponzhi ɓu va u kpán idari dari te, iponzhi iga nva̱n nnandər.
\q1 
\v 9 Iya̱m inəna̱n na u ma̱n.
\q1 Iya̱m ina te, u ma̱n ka̱ ka̱t, u yiyang.
\q1 Ka̱kul nva̱ ta te, Inan va̱ Inan ɓu te,
\q1 Uza̱ nak ɓu chit ishi ka̱ apal ishi nlwàk ɓu pa̱ kpaktak.
\q1 Atak nsat va̱ ta̱ i ɓa ka̱ nchang ìgwak aɓu pa̱ makmak.>>
\m 
\v 10 Uza̱ là kpa pa̱,
\q1 <<ÁPonzhi-Inan, ka̱ mɓəɓan na byet te, mmaɓu na u nəm apambin.
\q1 Apaɓur pa̱ kpaktak iya̱m va mmaɓu na u nəm kpa.
\q1 
\v 11 Oza̱ i kukur. Mmaɓu ji ɓu te, u təm chit mbyet mbyet.
\q1 Nkpaktak oza̱ i gbəgbak wa ilukwán.
\q1 
\v 12 Ɓu chəndər oza̱ wa nkup iya̱m iga ndan izər.
\q1 Mi i ga̱ɓa̱n oza̱ ga̱ɓa̱n wa ntur ìlukwan i le mí pá ikak.
\q1 Mmaɓu ji ɓu te, ɓu təm ntəm ɓu.
\q1 U təm chit mbyet mbyet, ngwal ukak ro yà ka̱ ashe ɓu ka̱t.
\q1 Izun ɓu yà ka̱ nkur ka̱t.>>
\m 
\v 13 Uro yà ka̱ ashe oma̱leka va uza̱ là nnap-nlà va̱ ta̱ á na ka̱t. Nna pa̱,
\q1 <<Təm ka̱wo ari mi na ń nak onəm oga nyang ɓu oza̱ a ta̱l itok iga nnak ashar ɓu a.>>
\m 
\v 14 O nyi ka̱t ɗò? Nna pa̱ nkpaktak oma̱leka pa te, oza̱ oga aruhu aga nnəm inok va ma re nre ka̱ pa̱ a nakshi ka̱ onəm oga ngwur *akup ká̱ irirì iga mbyet mbyet a?
\c 2
\s1 Nnap nka̱mshi mmakmak
\p 
\v 1 Ka̱kul nva̱ ta te, nkpak pa̱ i nakshi pa̱ dakdak ká̱ iya̱m va̱ i fe chit. Ka̱kul le kan won i nəm achen yi i gba̱ng ka̱ ka̱t.
\v 2 Nnap nlà Inan va̱ oma̱leka vang ka̱ te, ma məma̱n ka̱. Unəm va̱ pat iya̱m va̱ ma là, ka̱t te uza̱ yang nkpəkpak te, uza̱ yà nnyám ntan va məmal.
\v 3 Chit te, a yà pa̱ i nakshi ka̱ nnap irirì iga mbyet mbyet imakmak va̱ ta̱ ka̱t te, i yar sang kang mí nyám ntan á yi ka̱t yà? UPonzhi uYesu uwa ká̱ ishi wò ɓan nla nnap irirì va̱ ta. Onəm va̱ ǹnyi fe ka̱ atətak ká̱ achwang oza̱ te, oma là á yi na i nyi pa̱ kpátkpát.
\v 4 Inan nyám nnap nji wò nyám kpa ka̱ apal ishi nnap irirì va̱ ta̱ nzəng ka̱ nji oza̱ va̱ ta. Uza̱ nyám ka̱ atak nnəm iya̱m ichumchum chumchum ká̱ iga nɗaktak, ká̱ iya̱m pa̱ ɗongɗong, ká̱ imwa pa̱ ɗongɗong ija aRuhu-Nəna̱n va uza̱ kap ônəm wa nva uza̱ ɗom a.
\s1 UYesu Kəristi uwa ngwan nnap irirì
\p 
\v 5 Ka̱kul oma̱leka na Inan nak nlok nnəm ichumchum ka̱ apambin va ka̱ mɓa ka̱t. Apal mbin va mmayi ka̱ nla nnənap a.
\v 6 Ma nyám chit pa̱ kpátkpát ka̱ atak ro ka̱ ashe nnap-nlà Inan pa̱,
\q1 <<Unəm won nyan iza̱ kan ɓu ɗak ka̱ nrəng na yà?
\q1 Ka̱t te, unəm pa̱ wat wong nyang iza̱ kang ɓu nyàp ka̱ nənap yà?
\q1 
\v 7 U nak na oma̱leka ji na ka̱kul nra pa̱ ɗa̱p.
\q1 Te u na atak nsat nchumchum á na.
\q1 U rup ka̱ na kpa.
\q1 U nak na uwa ishi ka̱ apal ishi iya̱m pa̱ kpaktak ka̱ ashe apaɓur ka̱ apambin.
\q1 
\v 8 U na ichumchum á na ka̱ apal ishi iya̱m pa̱ kpaktak.>>
\m Nná ichumchum va Inan na á na ka̱ apal ishi iya̱m pa̱ kpaktak ta̱ te, Inan re iya̱m ro ka̱t. Ka̱ nna kpa te, ǹyangmata̱ te, i ya uza̱ ka̱ nnəm ichumchum ka̱ nkpaktak iya̱m ka̱t.
\v 9 Ka̱ nna kpa te, mmayi ka̱ nya uYesu va ma nak oma̱leka ji na ka̱kul nra pa̱ ɗa̱p te, ma na ichumchum á na chit. Ma rup ka̱ na kpa ka̱kul ikú va̱ uza̱ kú. Iya̱m va̱ ta̱ pa̱ kpaktak nnap-nnəna̱n Inan, ná uYesu a kú ka̱kul nza̱ unəm nggo.
\p 
\v 10 Ka̱kul nva̱ ta te, a məma ká̱ Inan pa̱ uYesu va iya̱m pa̱ kpaktak ma nəm ka̱kul a wà, kan iya̱m pa̱ kpaktak ma nəm nzəng ká̱ uwa kpa te, uwa a yà ishi ôza̱ ka̱ atak mɓək anung va kúr anung nnap nya irirì iga mbyet mbyet a. Mɓək anung va̱ ta̱ pa̱ kpaktak te, ka̱kul na Inan a ɓa ka̱ ovan wò pa̱ kyák a ya apir ichumchum chumchum.
\v 11 Unəm va̱ i nal nnap-mɓá̱ngɓa̱ng onəm, ka̱ onəm va̱ uza̱ nal ôza̱ te, oza̱ fa ka̱ akum azəngtəng. Nna nak te, ìwuswa nəm uYesu ka̱ ngwór oza̱ pa̱ ogənan wò ka̱t.
\v 12 Nna uza̱ là pa̱
\q1 <<Mi là nnap aɗin ɓu pa̱ gbá̱ngbá̱ng ôgənang mi.
\q1 Ka̱ ashe onəm oga ngwop ɓu, mi shep ɓu ka̱ nnap-nshì.>>
\m 
\v 13 Uza̱ là kpa pa̱,
\q1 <<Mi təp nkam mi ká̱ izər ɓu na.>>
\m Uza̱ là kà̱ɗi pa̱,
\q1 <<Mmami na ta̱ ka̱ ovan va Inan na á mi.>>
\p 
\v 14 Ka̱kul pa̱ ovan va̱ ta̱ onəm va izər va ìnyam na pa mwang ka̱ nchə̀r te, uYesu nyang unəm wa nji oza̱ na kpa. Na uza̱ a nəm igwan ka̱ apal ishi anəm uga ichumchum ikú ka̱ atak nkú na o wong. Unəm va̱ ta uwa uShetan.
\v 15 Uza̱ nəm pa na uza̱ a fən nkpaktak onəm va̱ ma mar oza̱ na byet te, oma kap chit ká̱ izwal ka̱t, ka̱kul ayər ikú a.
\v 16 A ra ka̱ mban pa̱ jakjai pa̱ uza̱ vang ka̱kul nka̱mshi oma̱leka na ka̱t. Nnap akum ìjili aIbərahim nna rwa na.
\v 17 Ka̱kul iya̱m va ta te, nkpak pa̱ uza̱ a yà wa aɓo ogənan wò na kpa, ka̱ atətak ro a ɓur ka̱t. Na uza̱ a ta̱l uponzhi onəm oga mpyal awop uga nrwa ìgwak, uga nnandər va ka̱ nnəm inok Inan. Na uza̱ a shi iya̱m inana Înan iga nyar nnap-mɓá̱ngɓa̱ng onəm.
\v 18 Ka̱kul pa̱ uza̱ ká̱ ishi wò te, ma mà na mà ka̱ atak mɓək anung te, ya uwa yà ká̱ ichumchum iga nka̱mshi onəm va̱ ma ka̱ mmà oza̱ kpa a.
\c 3
\s1 Ichumchum aYesu ká̱ ija aMusa
\p 
\v 1 Ka̱kul nva̱ ta te, ógənang onəna̱n va nnap awór aga apaɓur yar wo yar te, re ìgwak wo pa̱ kpaktak a ga ká̱ uYesu. Uwa unəm uga nre Inan ka̱kul nnap nna nnandər. Uwa kpa uponzhi onəm oga mpyal awop uchumchum ka̱kul nnap nzəngtəng.
\v 2 Uza̱ nəm nnandər yəl awo yəl ûnəm va̱ nak na ká̱ inok wa nva uMusa ka̱ nəm ka̱ onəm Inan a.
\v 3 Ka̱ nna kpa te, ma ya məma pa̱ uwa a yà ká̱ ichumchum pa̱ makmak a ji uMusa ji, wa nva unəm uga mme nzhi uwa ká̱ ichumchum ji nzhi va̱ uza̱ me a.
\v 4 Nza̱ nzhi nggo te, unəm a me. Unəm uga mme iya̱m pa̱ kpaktak te, uwa Inan a.
\v 5 UMusa pa te, uza̱ nəm inok inandər ka̱ ashe nkpaktak nzhi Inan wa azwal. Na uza̱ a là nnap ka̱ apal ishi iya̱m va nna ma ɓur ka̱ nləla.
\v 6 UKəristi Unəm uyákyàk Inan jiwo te, uza̱ nəm inok inandər ka̱ nzhi Inan wa aYen umarmar. Mmayi na i ta̱l nzhizhi a yà pa̱ i tong i kəkam ka̱ ashe nnak ìgwak va̱ mmayi ka̱ nlan ka̱ a.
\s1 Nna nnandər nna ɓyen
\p 
\v 7 Ka̱kul nva̱ ta̱ te, o nəm wa nva aRuhu-Nəna̱n là. Nna pa̱,
\q1 <<Nda a yà pa̱ o fe ichəchu te,
\q1 
\v 8 kang o twat anung igwák wo ka̱t.
\q1 Kang a ya wa nva̱ ka̱ o nəm ká̱ ilum va̱ ka̱ fa iya̱mkak ka̱ mi ka̱ ashe nra va̱ o ma mi ka̱ ashe anyin va̱ a.
\q1 
\v 9 Ka̱ ta na okəka wo ka̱ ma mi, oza̱ va̱k mi.
\q1 Oza̱ ya iya̱m va̱ ya n nəm, har a kur izun ìsəm neɗing.
\q1 
\v 10 Iya̱m va ta nak te, m mən ìkum ká̱ onəm oga ashe nra va̱ ta.
\q1 A nak te, n là pa̱,
\q1 <Pa̱ ɗəkər te, ìgwak oza̱ ka̱ nnak oza̱ i tan afəp.
\q1 Oma nyi asa̱l mi chit ka̱t.>
\q1 
\v 11 Te n sóng anung ka̱ ashe mmən ikum mi pa̱,
\q1 <Ko pa̱ ɗa̱p oza̱ i tan ka̱ ashe njul va̱ mi na ka̱t.> >>
\m 
\v 12 Ôgənang, o nakshi pa̱ dakdak ka̱kul le kang ìgwak inga iga nyáng ka̱ nna nnandər a tar ka̱ ashe aro ka̱ ashe wó, a nak na uza̱ a chər atak Inan uga Irirì ka̱t.
\v 13 Re o kam owan wó ká̱ izəzər nza̱ ilum nggo. A yà pa̱ nna ma yà, atak i tan mí wór pa̱ nda te, re o kam owan wó. Ka̱kul kang anung ìgwak aro ka̱ ashe wó a twat ka̱kul ntàng atak nnap mɓá̱ngɓa̱ng ka̱t.
\v 14 Í nəm ntəm nzəng ká̱ uKəristi a yà pa̱ na i tong a kəkam ka̱ apal ishi nna nnandər va̱ ká̱ i na ka̱ na ngəshi, har i ga i chu ilum iga nkur a.
\v 15 Nnap nlà Inan ləla kpa pa̱,
\q1 <<Nda a yà pa̱ o fe ichəchu te, kan o twat anung igwák wo ka̱t.
\q1 Kang a ya wa nva̱ ka̱ o nəm ká̱ ilum va̱ ka̱ o fa iya̱mkak ka̱ mi va̱ a.>>
\p 
\v 16 Oda va̱ kap ka̱ nfe ichəchu va̱ oza̱ fe te, oza̱ fa iya̱mkak ka̱ na yà? Onəm va uMusa ka̱ lim mpyal dap oza̱ fa ka̱ ashe mbin aMasar ka̱t ɗò?
\v 17 Ká̱ oda Inan mən ìkum ká̱ izun ìsəm neɗing yà? Ká̱ onəm va ka̱ nəm nnap-mɓá̱ngɓa̱ng oza̱ tak kú ka̱ ashe anyin ka̱t ɗò?
\v 18 Ká̱ oda Inan sóng anung pa̱ oza̱ i tar ka̱ ashe njul va̱ u ga nnəna ka̱t yà? Ká̱ onəm oga nlang nkpak nnap-nnəm va ka̱t ɗò?
\v 19 Te í yá pa̱ oza̱ tan ka̱ ashe njul va̱ ta ka̱t, ka̱kul nlan nna nnandər oza̱.
\c 4
\s1 Njul ka̱kul onəm Inan
\p 
\v 1 Ka̱kul nva̱ ta te, re i nəm dakdak, ka̱kul le kan a wa a yà pa̱ uro ka̱ ashe wo a chu nyiya ka̱t. Ka̱kul nsar nnap-nlà ngga ntar ka̱ ashe njul Inan nna watar chit ka̱t.
\v 2 Ma là nnap-nlà Inan ngga nchang nfe là ayi na kpa wa nji oza̱. Nnap nlà va̱ ta yà ka̱ nka̱mshi oro ka̱ ashe oza̱ jiwo ka̱t. Ka̱kul oza̱ va̱ fe nnap-nlà va̱ ta te, oza̱ ya ka̱ nna nnandər ngga nkəka̱m ka̱t.
\v 3 Mmayi va̱ i na nnandər na ka̱ te, i tan chit ka̱ ashe njul wa nva Inan là a. Nna pa̱,
\q1 <<N sóng anung ka̱ ashe mmən ikum mi pa̱ ka̱ pa̱ ɗa̱p, oza̱ i tan ka̱ ashe njul mi ka̱t.>>
\m Nna kap ka̱ nva̱ pa̱ Inan gba̱l ká̱ inok wò chit matmat ka̱ nfa ka̱ apambin a.
\v 4 Ka̱kul uza̱ là nnap là ka̱ atak ro ka̱ ashe nnap-nlà wò ka̱ apal ishi nnap ilum iga ifangshat pa̱,
\q1 <<Inan jul ka̱ nra ngga nfangshat ká̱ inok wò pa̱ kpaktak.>>
\m 
\v 5 Ka̱ ashe atak azəngtəng va̱ ta te, uza̱ ləla kpa pa̱,
\q1 <<Ko pa̱ ɗa̱p oza̱ i tan ka̱ ashe njul mi ka̱t.>>
\p 
\v 6 Asa̱l na yà bol ka̱kul ntan ka̱ ashe njul va̱ ta. Onəm va̱ matmat ma là nnap-nlà Inan ngga nchang nfe ôza̱ kan oza̱ tan ka̱ ashe njul va̱ ta ka̱t te, nlan nkpak nnap nnəm oza̱ nna nak.
\v 7 A nak te, Inan pak ilum ro kà̱ɗi va mí wór pa̱ nda ta̱. A gba̱ng nva̱ng te, uza̱ là nnap-nlà ka̱ atak nnəm inok ká̱ uDawuda wa nva ma là chit pa̱,
\q1 <<Nda a yà pa̱ o fe ichəchu te, kan o twat anung igwák wo ka̱t.>>
\m 
\v 8 Ka̱ ya pa̱ uJoshuwa tan ka̱ oIsa̱rila ka̱ ashe njul va̱ ta chit na nnandər te, Inan ka̱ là nnap ngga mɓa ro ka̱t.
\v 9 Ka̱kul nva̱ ta te, ilum iga njul ka̱kul onəm Inan i ya ɓur.
\v 10 Unəm va pa̱ kpaktak tar ka̱ ashe njul Inan te, ya uza̱ jul chit ká̱ inok na kpa, wa nva Inan jul ka̱ nva̱n nnəm inok ijiwò a.
\v 11 Ka̱kul nva̱ ta te, re i ɗak na i tan ka̱ ashe njul va̱ ta. Ka̱kul le kan ntar ka̱ ashishe a ma̱t ka̱kul nyar nnap nnəm oza̱ ngga nlan nkpak nnap nnəm ka̱t.
\p 
\v 12 Ka̱kul nnap-nlà Inan ká̱ irirì. Kang i nəm inok pa̱ gənggəng kpa. Á ri ji nza̱ ndokchi nrírí ngga anung pa̱ parəm ji. I pa atak, i va̱n irirì anəm i le ká̱ izər aruhu, ká̱ mɓan izər, ká̱ nvil. Á nyi nrəng nnap anəm ká̱ iya̱m va̱ unəm ɗom pa̱ kpaktak.
\v 13 Iya̱m ro yà ibwambwam ka̱ atak Inan ka̱ ashe nkpaktak iya̱m va̱ uza̱ nəm ka̱t. Nza̱ iya̱m nggo te, a ra pa̱ jakjai ka̱ mpyal Inan. Oza̱ pəl mpəlpəl ka̱ mpyal anəm va nkpak pa̱ i nyám ishi yi ka̱ mpipyal a.
\s1 UYesu unəm uga mpyal awop uchumchum
\p 
\v 14 Ka̱kul pa̱ nna i yà ká̱ uponzhi onəm oga mpyal awop uchumchum va kyen ɓa ga apaɓur uwa uYesu uYa Inan te, re i bur pa̱ gənggəng iya̱m va̱ i là pa̱ i məma̱n ka̱ a.
\v 15 UPonzhi onəm oga mpyal awop yi va̱ ta̱ pa te, uza̱ unəm va nlan ìkàm yi nəm nkun á na ka̱t ɗò ka̱t. Uza̱ pa te, unəm va mmà ka̱ ka̱ nza̱ asa̱l-awu nggo te, a ya na ya wa nva ya yi kpa a. ká̱ nnà te, ka̱ pa̱ ɗa̱p uza̱ nəm nnap mɓá̱ngɓa̱ng jiwo ka̱t.
\v 16 Ka̱kul nva̱ ta te, re i ga mpyal itok aPonzhi Inan iga nnap nnəna̱n ka̱ ashe nləp ikwoksok na i ya nnyám nrwa ìgwak nzəng ka̱ nnap nnəna̱n va i ka̱mshi yi ilum va pa̱ kpaktak ka̱ ashe nlan a.
\c 5
\p 
\v 1 Nza̱ uponzhi onəm oga mpyal awop nggo te, mí yak na ka̱ ashe onəm mí kyer na unəm uga nnəm inok Înan ka̱kul owan wò. Inok va iga ǹyichi imwa oza̱ Înan ká̱ iya̱m ipápà ka̱kul nshi iga nyar nnap-mɓá̱ngɓa̱ng.
\v 2 Onəm oga amwang ká̱ onəm va̱ làr chit re asa̱l te, uza̱ nyi ngga ká̱ oza̱ pa̱ shiriri nyi. Ka̱kul uza̱ ká̱ ishi wò te, uza̱ kam ka̱t na kpa ka̱ nza̱ asa̱l-awu nggo.
\v 3 Ka̱kul nva̱ ta te, nkpak pa̱ uza̱ a shi iya̱m ipápà ka̱kul nyar nnap mɓá̱ngɓa̱ng wò ka̱ nja aɓoshi onəm kpa.
\v 4 Unəm kur nnak ishi wò ká̱ inok ichumchum va̱ ta ka̱t. Inan uwa wór unəm ka̱, wa nva uza̱ wór uHaruna ká̱ inok va̱ ta a.
\v 5 wantana uKəristi uwa nak ishi wò ká̱ inok ichumchum iga iponzhi onəm oga mpyal awop va̱ ta̱ ka̱t. Inan a là á na pa̱,
\q1 <<Mmaɓu uYen mi
\q1 N ta̱l uPo ɓu chit nda.>>
\m 
\v 6 Inan ləla kpa ka̱ atak ro ka̱ ashe nnap-nlà wò pa̱,
\q1 <<Mmaɓu unəm uga nshi iya̱m awop mbyet mbyet mbyet.
\q1 Inok va ipir ija aMekizedek a.>>
\p 
\v 7 Ka̱ ashe nra va̱ uYesu uwa yà ka̱ apambin te, uza̱ nəm aduwa nzəng ka̱ nchal ichal ká̱ ayə́ng pa̱ gbá̱ngbá̱ng ûnəm uga ichumchum uva pa̱ a ka̱m ishi na pa̱ kang uza̱ a kú ka̱t a. Inan fe ayiyə́ng ka̱kul pa̱ uza̱ unəm uga nra ká̱ ishi pa̱ makmak.
\v 8 Kap ka̱ nva̱ pa̱ uza̱ uYa Inan te, uza̱ ɗyang nkpak nnap nnəm ka̱ atak mɓək anung va uza̱ ɓək.
\v 9 Ma nak na uza̱ kur chit pa̱ chak te, uza̱ ta̱l atak va irirì iga mbyet mbyet i ɓəl ka̱ ka̱kul nkpaktak onəm va̱ ka̱ nkpak nnap nnəm á na a.
\v 10 Inan ka̱ ngwór na pa̱ uponzhi onəm oga mpyal awop uva inunok apir ija aMalkisadek.
\s1 Awon ka̱ apal ishi nləp ifang
\p 
\v 11 Nna i yà ká̱ iya̱m pa̱ makmak pa̱ i là ka̱ apal ishishi. ká̱ nnà te, nləla awo ká̱ nvəva̱n a kəkam ká̱ yi ka̱kul o mwan, ìgwak tul awo kà̱ nkpán ipipir ka̱t.
\v 12 A mal pa̱ wa ǹyangmata̱ te, ká̱ o tong onəm oga nɗyang iya̱m ônəm chit. Ká̱ nna kpa te, nna o watar nva̱ chit pa̱ ma ɗyang iya̱m awo ka̱ apal ishi nnandər nnap-nlà Inan kà̱ɗi ka̱t. Mbyal va ka̱kul ovanba̱k te, nna ma ká̱ wo. Iya̱m nri ikamkam a ji nkam wo ji.
\v 13 Unəm va pa̱ kpaktak uwa ka̱ anung mma mbyal wa ayenba̱k te, uza̱ i kur nkpán ipir nɗyang ka̱ apal ishi ntong onəm onəna̱n kà̱ mpyal Inan ka̱t.
\v 14 Iya̱m nri ikamkam pa te, ka̱kul onəmgbak. Oma ka̱ atak iya̱m va̱ oza̱ i nəm pa̱ ɗəkər ɗəkər te, oza̱ ɗyang nva̱n iya̱m inəna̱n ká̱ iɓá̱ngɓa̱ng îshi oza̱ chit nyi oza̱.
\c 6
\p 
\v 1 Ka̱kul nva̱ ta te, i re nnap nɗyang ngga ngəshi ka̱ apal ishi aKəristi na i pa ishi yi ka̱ nnap ntong onəm va kúr chit a. Kang i təm ka̱ mban akum nɗyang ngga apal ishi nnap ngga̱ɓa̱n nre awop alakchi ka̱ nnap nna nnandər ká̱ Inan,
\v 2 ka̱ nnap nɗyang ka̱ apal ishi abaptisima, ka̱ nnap nnak awo ônəm ká̱ ishi, ka̱ nnap ngwon ka̱ onəm kúkú ka̱ atak ikú, ka̱ nnap-akwali aga mbyet mbyet ka̱t.
\v 3 Ka̱ mma̱n Inan te, í nənəm pa.
\p 
\v 4 Onəm va̱ oza̱ ya atak atántàn Inan chit, onəm va oma mà nchang imwa iga apaɓur va̱ chit, oza̱ ka̱m aRuhu-Nəna̱n ka̱m kpa,
\v 5 onəm va oza̱ mà nchang nnap-nlà Inan mà ká̱ ichumchum iga nra ngga mɓa
\v 6 kang a yà pa̱ oza̱ ru te, mí chu nle ká̱ oza̱ ka̱ apal asa̱l kà̱ɗi ka̱t. Ka̱kul oza̱ ka̱ mpak uYa Inan ka̱ apal akun ikú kà̱ɗi nzəng ká̱ nnyi pa̱ oza̱ i ya anunung ya. Oza̱ ka̱ nna ìwuswa á na ka̱ ashe onəm.
\v 7 Mbin va̱ ka̱ ngwa ndəng iva̱r va̱ ka̱ mpəng pa̱ ɗəkər kang iya̱m nsusuk a fa ɓa nəm ishi har onəm oga nwuwap ɓən iya̱m te, Inan i nak nnap-nnəna̱n m̂bin va̱ ta.
\v 8 A ya nnyi pa̱ mbin va̱ ta fa izú ká̱ nkpakshi te, ya a sat atak alakchi chit. Mí là anung mbín va̱ ta i vyap. Nkukur mpwak ka̱ apər na chwat.
\p 
\v 9 Ônəm ma̱nma̱n, kap ka̱ nva pa̱ i là nnap-nlà wanta̱ te, mmawó te, i nyinyi pa̱ kpátkpát pa̱ mmawó ka̱ ntong ka̱ apal nnap va ɓiɓyen jiwo. Nna nnap nka̱mshi ngga irirì iga mbyet mbyet a.
\v 10 Inan lan nnandər ka̱t. Uza̱ i yà ka̱ nkong ká̱ inok wo ka̱ mma̱n va̱ mmawó ka̱ nnyinyam á na ka̱t. Mma̱n va o nyám ka̱ atak nka̱mshi va̱ ka̱ o nəm ônəm Inan. Mmawo ka̱ anung nnənəm na pa̱ har.
\v 11 I ɗom pa̱ nza̱ uzəntəng wo nggo te, uza̱ a zhing ka̱ nnap nya nyə́l nnak ìgwak wò har a ga chu alum aga nkur.
\v 12 Na kan o rusok izər ka̱t. Re o ɗyang nnap nnəm onəm va̱ ka̱ atak nna nnandər oza̱ nzəng ka̱ nka̱r ìgwak ká̱ nnap te, oza̱ ka̱m iya̱m va̱ chit ma sar nnap-nləla.
\s1 Nsar nnap-nlà Inan yə́l awo yə́l
\p 
\v 13 Nva̱ Inan ka̱ sar nnap-nlà ûIbərahim te, unəm ro yà ji na uva uza̱ i sóng aɗiɗin ka̱t. A nak te, uza̱ sóng aɗin wò na.
\v 14 Uza̱ là pa̱, <<Mi nak nnap nnəna̱n aɓu. Mi na nva̱n aɓu. Mi na nva̱n aɓu kpa pa̱ makmak.>>
\v 15 UIbərahim ka̱r ìgwak nzəng ka̱ nlok te, uza̱ ya iya̱m va̱ ma ka̱ sar nnap-nləla á na.
\v 16 Unəm i sóng aɗin va ji na ji. A yà pa̱ anung gwang unəm ka̱ owan wò kang ma sóng chit te, nnap va̱ ta kùr chit.
\v 17 Nna nak te, Inan ka̱ ɗom pa̱ ovan oga ngwur iya̱mkup va̱ uza̱ sar nnənap na oza̱ a nyi pa̱ kpátkpát pa̱ iya̱m va̱ o là te, i ga̱ɓa̱n ka̱ pa̱ ɗa̱p ka̱t te, uza̱ sóng anung ka̱ kpa.
\v 18 Inan nəm pa na ka̱ atak iya̱m iga iparəm va a təm chit i ga̱ɓa̱n ka̱t, kang asa̱l ro yà va Inan i nap akwam ro ka̱ ashishe ka̱t. Ka̱kul nva̱ ta te, mmayi va̱ i chən chit i ɓa i ya atak mbwam ka̱ ashishe te, re ìgwak a kam yi pa̱ makmak ka̱ mbur pa̱ gənggəng iya̱m va̱ ma yichi ayi, mmayi ka̱ nnak ìgwak ka̱ a.
\v 19 Nnak ìgwak va̱ ta̱ wa iya̱m iga nkpán irirì i sat ka̱ va mmayi ka̱ a. Iya̱m ro ya i səng na ka̱t. Ko pa̱ ɗa̱p iya̱m ro i dok na ka̱t. Nnà i tar har nsəm nza̱ni atak yə́ryər ka̱ nzhi Inan.
\v 20 Atak va uYesu va̱ ga chit mpyal ayi te, uza̱ tar chit ka̱ ta ka̱kul yi. Uza̱ ta̱l uponzhi onəm oga mpyal awop Înan uchumchum chit mbyet mbyet. Inok va ipir ija aMalkisadek a.
\c 7
\p 
\v 1 Umelkizedek va̱ ta̱ pa te, ka̱ ya uPonzhi ka̱ aSalem. Uza̱ unəm uga nshi iya̱m awop uja aPonzhi Inan va Ji pa̱ Kpaktak. Uza̱ gwang aIbərahim ka̱ nle ka̱ atak nri oponzhi ká̱ ikum te, uza̱ nak nnap nnəna̱n á na.
\v 2 Ka̱ ashe nkpaktak iya̱m va̱ uIbərahim ri ká̱ ikum te, uza̱ kpa̱k uzəng ka̱ ashe agba̱pchi na á na. Ngəshi te, ipir aɗiɗin pa̱ uponzhi uga nnap nnəm nnəna̱n. Uza̱ uponzhi aSalem kpa. Nna ipipir pa̱ uponzhi uga ntəm ntəm ikangkang.
\v 3 Uza̱ yà ká̱ upon ka̱t. Uza̱ ya ká̱ unang ka̱t. Ma nyi akum ìjili va̱ oza̱ fa ka̱ ka̱t. Ma nyi alum aməmar ka̱t kang a wong a nyang alum ikuku. Uza̱ wa aYa Inan va uwa unəm uga nshi iya̱m awop mbyet mbyet a.
\p 
\v 4 O dər apir ichumchum va̱ uza̱ ka̱. Ka̱kul ukəka yi uIbərahim ká̱ ishi wò te, ka̱ ashe nkpaktak iya̱m va̱ uza̱ ri ká̱ ikum te, uza̱ kpa̱k uzəng ka̱ ashe agba̱pchi uza̱ na á na.
\v 5 Nnap mpakpak là pa̱ onəm oga akum ìjili aLawi va̱ tong onəm oga mpyal awop te, re uza̱ a ka̱m iya̱m pa̱ izən ka̱ ashe agba̱pchi ka̱ ashe iya̱m va ogənan oza̱ oIsa̱rila i na Înan a. Oza̱ i ka̱m kap ka̱ nva̱ pa̱ oza̱ fa ka̱ akum ìjili aIbərahim na kpa a.
\v 6 Umelkizedek va̱ ta unəm va fa akum ìjili aLawi ka̱t te, a ka̱m apir iya̱m inana va̱ ta ka̱ atak aIbərahim. Uza̱ nak nnap nnəna̱n ûIbərahim kpa. Uza̱ va uwa Inan sar nnap-nlà pa̱ ɗongɗong á na a.
\v 7 Nnap ngga ndap atam ro yà ka̱ ka̱t. Nna pa̱ unəm va dar uwan wò te, uwa i nak nnap nnəna̱n ûnəm va̱ ma dar na a.
\v 8 Onəm oga nshi iya̱m awop va̱ ka̱ nka̱m iya̱m inana iga izən ka̱ ashe agba̱pchi te, ikú i yar oza̱ yar. Umelkizedek va̱ ka̱ ka̱m apir iya̱m inana va ta kpa te, ma nyám nnap chit ka̱ apal ishishi pa̱ uza̱ i kú jiwo ka̱t.
\v 9 Ɗom te, mí ləla pa̱ uLawi va̱ ká̱ ishi wò unəm uga nka̱m izaka te, uza̱ na apir iya̱m va̱ ta na aMelkizedek nva̱ uIbərahim ka̱ na a.
\v 10 Ka̱kul nva̱ uIbərahim ka̱ gwang umelkizedek te, uLawi ka̱ ya chit ka̱ ashe nchə̀r akəka wò.
\p 
\v 11 Ma na nnap-mpakpak ônəm ka̱kul pa̱ apir inok onəm oga akum ìjili aLawi nna yà. Ka̱ ya pa̱ mí tong onəm va kukur ka̱ atak inok onəm oga mpyal awop oga akum ìjili aLawi na nna̱n te, ma ka̱ ɗak ka̱ nre nre ka̱ unəm uga nshi iya̱m awop ukak uga nnəm apir inok ija aMalkisadek ka̱ɗor ija aHaruna ka̱kul iza̱ lap yà?
\v 12 A yà pa̱ ma ga̱ɓa̱n iya̱m ro ka̱ ashe inok iga nshi iya̱m awop te, nkpak pa̱ ma ga̱ɓa̱n iya̱m ro ka̱ ashe nnap-mpakpak pakpak kpa.
\v 13 Unəm va̱ ma là nnáp va̱ ta ka̱ apal ishishi te, uza̱ fa ka̱ akum ìjili ikak pa̱ ɗi va unəm ro ka̱ ashe oza̱ uwa nəm inok ka̱ atak nshi iya̱m awop chit ka̱t a.
\v 14 Ma nyinyi pa̱ kpátkpát pa̱ uPonzhi yi uYesu fa ka̱ akum ìjili aYahuda. UMusa là iya̱m ro ka̱ apal ishi akum ìjili va̱ ta pa̱ oza̱ i tong onəm oga mpyal awop kpa ka̱t.
\v 15 Nnap va̱ ta̱ i ra pa̱ jakjai i jujwak a yà pa̱ unəm ukak uga nshi iya̱m awop apir nja aMalkisadek a yìyà a.
\v 16 Unəm va̱ ta ta̱l unəm uga nshi iya̱m awop ka̱kul nnap anəm nro va ma pak ka̱t. Uza̱ ta̱l ka̱ atak ichumchum irirì va ma kur nzhìzhì ka̱t a.
\v 17 Ka̱kul ma nyám nnap nyám ka̱ apal ishishi pa̱,
\q1 <<Mmaɓu unəm uga nshi iya̱m awop mbyet mbyet.
\q1 Inok va ipir ija aMalkisadek a.>>
\m 
\v 18 Ma le ká̱ iya̱m va̱ nnap-mpakpak mmatmat là te, ma re chit. Ka̱kul a chu nnəm iya̱m ro ka̱t. A yà ka̱ nka̱mshi ka̱t kpa.
\v 19 Nnap-mpakpak aMusa kur nnak unəm ro pa̱ a ta̱l unəm va kúkúr ka̱t. Ǹyangmata̱ te, ma ɓa ká̱ iya̱m iga nnak ìgwak ikak chit va ka̱ atətak na kang í səng í ɓa datkulung ká̱ Inan.
\p 
\v 20 Iya̱m va̱ ta̱ yà pa mwan nzəng ka̱ nsóng anung ka̱t ɗò ka̱t. Onəm va̱ ka̱ yà onəm oga mpyal awop matmat te, oza̱ ɓan inok va̱ ta nzəng ka̱ nsóng anung ka̱t.
\v 21 Uza̱ jiwo te, uza̱ ta̱l unəm uga nshi iya̱m awop ka̱ atak nsóng anung nva̱ Inan ka̱ là á na pa̱
\q1 <<UPonzhi Inan sóng anung chit.
\q1 Uza̱ i yà ka̱ nle nva̱n ka̱ nnap-nlà wò ka̱t.
\q1 Nna uza̱ là pa̱,
\q1 <Mmaɓu unəm uga nshi iya̱m awop mbyet mbyet a.> >>
\m 
\v 22 Ka̱kul nna te, uYesu uwa sat unəm va mí kpán, a yà pa̱ mí yə́l nsar nnap-nlà va̱ ta ka̱t a. Nsar nnap-nlà va ɓyen ji mmatmat ji pa̱ gənggəng.
\p 
\v 23 Onəm oga nshi iya̱m awop omatmat te, oza̱ yə́l pa̱ kyák. Ka̱kul ikú i dan oza̱ dan ka̱ nnəm inok mbyet mbyet.
\v 24 UYesu jiwo te, inok nshi iya̱m awop ijini təm á na chit mbyet mbyet, i le atak anəm ro lap ka̱t. Ka̱kul uza̱ təm chit mbyet mbyet.
\v 25 Ka̱kul nva̱ ta te, pa̱ ɗəkər uwa ká̱ ichumchum iga nka̱mshi ngga nna irirì iga mbyet mbyet. Uza̱ i ka̱mshi onəm va pa̱ kpaktak i səng i ɓa dat ká̱ Inan ka̱ ashe aɗiɗin a. Nka̱m ishishi pa̱ makmak ka̱kul uza̱ təm urirì chit mbyet mbyet. Pa̱ ɗəkər te, uza̱ ka̱ nnəm aduwa ôza̱.
\p 
\v 26 Apir aponzhi onəm oga mpyal awop va ta í ram ishi ka̱. Uza̱ unəm unəna̱n, mpat ro yà ka̱ ashishe ka̱t. Uza̱ yà ka̱ adak ro ka̱t. Ma va̱n na chit le ká̱ izər onəm oga nnəm nnap-mɓá̱ngɓa̱ng. Ma na atak nsat nchumchum á na chit ka̱ ashe apaɓur.
\v 27 Iya̱m ro ɗak na ka̱ nshi iya̱m awop nza̱ ilum nggo wa aɓoshi oponzhi onəm oga mpyal awop va̱ ka̱t. Nshi iya̱m va ngəshi te, oza̱ i shi ka̱kul nyar nnap-mɓá̱ngɓa̱ng nji oza̱. I le te, oza̱ i shi ka̱kul nyar nja aɓoshi onəm ɗak. Uza̱ te, uza̱ nəm iya̱m va̱ ta chit nva̱ng pa̱ nzəng na byet. Nna uza̱ ka̱ na ishi wò ká̱ ikú wa iya̱m ipápà ka̱kul nshi a.
\v 28 Nnap mpakpak aMusa re onəm re i tong oponzhi onəm oga mpyal awop kap ka̱ nyen oza̱. Inok va̱ nsóng anung Inan nəm va ɓa kà̱ nva̱n nnap-mpakpak te, uYa Inan uwa ma nak ta̱l uponzhi onəm oga mpyal awop. Uwa kúkúr jiwo mbyet mbyet a.
\c 8
\s1 UYesu uponzhi nnap nshi iya̱m awop Înan mpipye
\p 
\v 1 Iya̱m va̱ pa̱ wat pa̱ mmayi ka̱ nləla te, nna ta̱. Pa̱ nna i ya ká̱ uponzhi onəm oga mpyal awop uva ka̱ ntəm ka̱wo ari itok iponzhi Inan ka̱ ashe apaɓur.
\v 2 Uza̱ ka̱ nnəm inok ka̱ ashe atak yə́ryər aga Nzhi Inan nchumchum. Atak va aghal aga awa aga nnandər va unəm a ka̱ ka̱t. UPonzhi Inan a ka̱.
\v 3 Nza̱ uponzhi onəm oga mpyal awop nggo te, ma kyer na pa̱ uza̱ a yichi imwa ká̱ iya̱m ipápà iga nshi. Ka̱kul nva̱ ta te, nkpak pa̱ uza̱ a yà ká̱ iya̱m va uza̱ i yichi.
\v 4 Ka̱ yà pa̱ uza̱ ka̱ apambin te, uza̱ ka̱ yà unəm uga nshi iya̱m awop ka̱t. Ka̱kul onəm oma yà nyal va i yichi imwa va̱ nnap-mpakpak aMusa là pa̱ ma na a.
\v 5 Oza̱ ka̱ nnəm inok ka̱ ashe atak yə́ryər va fa izər na pa mwan ka̱ aga ashe apaɓur. A sat wa ala̱ka̱n aga apaɓur na pa kùk. Ka̱kul uMusa ɓan nka aghal aga awa va̱ ta te, Inan là á na pa̱, <<Nakshi pa̱ dakdak na u ka̱ a mal izər ka̱ nkpaktak iya̱m va ma nyám aɓu ka̱ apal aɓam a.>>
\v 6 Inok va̱ uYesu Kəristi ya te, a ɓyen ji imatmat ji pa̱ gənggəng. Ka̱kul nsar nnap-nlà va̱ uza̱ pa anung ka̱ sat unəm uga ishimshe te, a dar mmatmat dar. Ka̱kul ma pak ka̱ atak nsar nnap-nlà va ɓyen ji mmatmat ji a.
\v 7 Ka̱ ya pa̱ nsar nnap-nlà mmatmat va̱ ta ga̱n ka̱ atak ro ka̱ pa̱ ɗa̱p ka̱t te, ma ka̱ ɗak ka̱ mpəpar ka̱t.
\v 8 Inan ya mpat oza̱ ya nva̱ uza̱ là pa̱,
\q1 <<Ilum ya ka̱ mɓa mmami uPonzhi Inan n là.
\q1 Ilum va mi sar nnap-nlà mpipye ka̱ onəm oga aIsa̱rila ka̱ akum ìjili aYahuda.
\q1 
\v 9 I yà wa mmatmat nva ka̱ n sar ka̱ okəka oza̱ ka̱t.
\q1 Nna ka̱ ashe nra va̱ n dap oza̱ ndapdap ka̱ awo mi, na ń fa ka̱ oza̱ ka̱ ashe mbin aMasar a.
\q1 Ka̱kul oza̱ tong pa̱ kwák kpak iya̱m va̱ n sar ká̱ ishimshe mi ka̱ oza̱ ka̱t.
\q1 A nak te, n ga̱ɓa̱n asəm n na ôza̱.
\q1 Mmami uPonzhi Inan n là.
\q1 
\v 10 Nsar nnap-nlà va ta̱ mi sar ka̱ oIsa̱rila.
\q1 Mmami uPonzhi Inan ka̱ nla pa̱ nra va̱ ta i ɓa i chu te, mi nak oga nnap-mpakpak mi ka̱ ashe nrəng nnap oza̱.
\q1 Mi lir oza̱ ka̱ anung igwák oza̱.
\q1 Mi ta̱l Inan oza̱.
\q1 Oza̱ nnyi te, i tong onəm mi.
\q1 
\v 11 Oza̱ i təm ka̱ nɗyang iya̱m ówan oza̱ oga atak azəngtəng ka̱ oza̱ lap ka̱t.
\q1 I nak te, unəm ro i təm ka̱ nla ûwan wò pa̱, <Nyi Inan> ka̱t.
\q1 Ka̱kul nkpaktak oza̱ i nyi mi nyi.
\q1 I ɓan ká̱ unəm va yen ji har i ga i chu unəm va ji pa̱ kpaktak.
\q1 
\v 12 Ka̱kul mi nyám nrwa ìgwak ôza̱ ka̱ apal ishi ina oza̱.
\q1 Mi rəng nnap-mɓá̱ngɓa̱ng oza̱ ka̱t.>>
\m 
\v 13 Ka̱ atak ngwór nsar nnap-nlà va̱ ta̱ pa̱ mpipye te, ya uza̱ nak ngga ngəshi ta̱l ngbakgbak chit. Iya̱m va pa̱ kpaktak inunok ka̱ nkùr kan ka̱ ngbak kpa te, i gba̱ng nva̱n ka̱t te, mí ya lap ka̱t. I watar watar.
\c 9
\s1 Awop aga apambin ka̱ aga apaɓur
\p 
\v 1 Nsar nnap-nlà ngga ngəshi va̱ ta te, nna yà ká̱ iya̱m ipakpak ka̱ apal ishi nnap awop nzəng ka̱ atak yə́ryər yə́ryər va onəm a ɗa̱mshi.
\v 2 Ma ka̱ atətak ka̱ awa. Ka̱ ashe afufu aga agbai te, atak ncher apitila nna yà, ka̱ atebəl, ka̱ nzəngkəng awop nggorgor. Ma wór ashe afu va̱ ta pa̱ atak yə́ryər.
\v 3 Ka̱ nsəm nza̱ni ngga nka atak apəpar te, afu na yà va mí wór pa̱ Atak va yər ji pa̱ kpaktak a.
\v 4 Ka̱ ashishe te, atak nshi iya̱m va ma nəm ka̱ azənariya ka̱kul nshi iya̱m inəngnəng ichangchang te, nna yà, ka̱ akwati nsar nnap-nlà va ma ɓəl nza̱ ngba̱k nggo ka̱ ndəng azənariya a. Ka̱ ashe akwati va̱ ta te, asu *amanna va ma nəm ka̱ azənariya te, i yìyà ká̱ idari aHaruna va i tə́tə́p, ká̱ ipáng va̱ ma lir nsar nnap-nlà ká̱ izər oza̱.
\v 5 Ka̱ apal ishi akwati va̱ ta te, iya̱m iga abasəm va ɓyen pa̱ gənggəng nna yà bir ka̱ atak nshan nchə̀r ngga nyar nnap-mɓá̱ngɓa̱ng. Í kan ìjili nnap oga iya̱m va̱ ta̱ i kur ǹyangmata̱ ka̱t.
\p 
\v 6 Ka̱ nva̱ngva̱ ma gba̱l ka̱ nɗa̱mshi ka̱ iza̱ nggo chit wanta̱ te, pa̱ ɗəkər onəm oga mpyal awop i tan ashe afu aga agbai i nəm inok Inan.
\v 7 Afu aga ashe jiwo te, uponzhi onəm oga mpyal awop uwa ka̱ nkukwa i tar. Uza̱ i tar atak va̱ ta nva̱n pa̱ nzəng na byet ka̱ ashe izun. Uza̱ i tar ka̱t, ya uza̱ kpán nchə̀r ngga ǹyichi Înan ka̱kul nyar nnap-mɓá̱ngɓa̱ng ngga ishi wò ka̱ nja aɓoshi onəm va nəm nzəng ka̱ nyi onəm ka̱t a.
\v 8 Ka̱ asa̱l va ta aRuhu-Nəna̱n ka̱ nnyam ipir nnap pa̱ asa̱l aga ntar atak yə́ryər va ji pa̱ kpaktak te, nna bol chit ka̱t. A yà pa̱ aghal aga awa nna yà sat a.
\v 9 Nkpaktak iya̱m va̱ ta nyám iya̱m va ka̱kul nra va mmayi ka̱ ashishe. Iya̱m va̱ ta ka̱ nnyam pa̱ imwa ká̱ iya̱m inana iga nshi va̱ ma pak inok nnəna te, a kur nva̱ pa̱ a nal iɗimɗim igwák onəm oga mɓa awop ka̱t.
\v 10 Nnap iya̱m-nrì, ká̱ iya̱m iwawa ka̱ nnal izər ka̱ asa̱l pa̱ ɗongɗong na pa mwan. Oza̱ oga iya̱m ipakpak iga nnəm ka̱ agbai na pa mwang. Na oza̱ a nəm inok kang mí lok ipipye ká̱.
\p 
\v 11 UKəristi vang chit wa aponzhi onəm oga mpyal awop oga iya̱m inəna̱n va nna ya a. Uza̱ tar inok ka̱ ashe aghal va ɓyen ji amatmat ji. Aghal ajini va̱ ta a kur iya̱m kur. Unəm a ka̱ ka̱t. Ma nəm wa nva ma nəm aɓo iya̱m ka̱t kpa.
\v 12 Uza̱ tar ashe atak yə́ryər va̱ ta nva̱n pa̱ nzəng na byet nva kúkúr. Uza̱ tar te, uza̱ kpán nchə̀r iɓə́l ka̱t te, nchə̀r ivan ina ka̱wo ka̱t. Uza̱ tar ka̱ nchə̀r wò. A nak te, uza̱ ka̱m ishi yi chit mbyet mbyet.
\v 13 Nchə̀r iɓə́l, ká̱ ina inunggwan, ká̱ nchwang ivan ina va̱ ma shi kang mí sháng ônəm va̱ ka̱ adak te, i nal adak aga izər nal i le ôza̱.
\v 14 Chit te, nchə̀r aYesu kəristi i nal oza̱ i fa i yà wa nsang nnyi ɗa? Uza̱ va ka̱ atak aRuhu aga mbyet mbyet te, uza̱ na ishi wò Înan adak ro ya ka̱ na ka̱t. Te uza̱ i nal ìɗimɗim igwák yi iga inok ikuku i yà wa nsang yà? Nnal ìgwak va ka̱kul ngwop Inan uga Irirì a.
\p 
\v 15 Ka̱kul nva̱ ta te, uwa unəm uga ishimshe yi ká̱ Inan uva pá anung ka̱ nnap nsar nnap-nlà mpipye va̱ ta̱. Na onəm va̱ ma wór te, oza̱ a ya iya̱mkup iga mbyet mbyet va ma ka̱ sar nnənap. Ka̱kul uza̱ kú ikú chit iga mmwa amwa va ka̱m ishi oza̱ ka̱ atak mpat nnap va̱ oza̱ ka̱ pat n̂sar nnap-nlà ngga ngəshi a.
\p 
\v 16 Iya̱mkup va̱ ma lir asa̱l nkəkap lir jiwo te, unəm va̱ lir te, uza̱ i kú mi í nyi nnandər nandər kan i ya nnap.
\v 17 Mi i nəm inok ka̱ chit ka̱t, ya unəm va̱ lir te, i kú kan. A yà pa̱ unəm va̱ ta uwa yà ká̱ irirì te, nna i ɓan inok chit ka̱t.
\v 18 Nna nak te, nsar nnap-nlà ngga ngəshi va̱ te, nzəng ká̱ ikú ka̱t te, ka̱ ya pa̱ ma sar chit ka̱t.
\v 19 Ka̱kul nva̱ngva̱ uMusa gba̱l ka̱ nkun nnap-mpakpak wò n̂kpaktak onəm te, uza̱ yar nchə̀r ivan ina, ká̱ iɓə́l, ka̱ ndəng. Uza̱ chip azang *ahisop ka̱ awulu arəzang te, uza̱ shim sháng âtakarda nnap-mpakpak va̱ ta, ká̱ ishi wò kpa, ka̱ nkpaktak onəm.
\v 20 Uza̱ là ka̱ anunung pa̱, <<Nchə̀r va̱ ta̱ nchə̀r va i nyám nnandər nsar nnap-nlà va̱ Inan là pa̱ o kpak a.>>
\v 21 Uza̱ le te, uza̱ shan nchə̀r va̱ ta wanta na kpa aghal ka̱ nkpaktak iya̱m inok ka̱kul awop.
\v 22 Ka̱ ashe nkpak iya̱m va̱ nnap-mpakpak aMusa là pa̱ ma kpak te, mmakmak iya̱m pa̱ wat te, mí nal ka̱ nchə̀r na. A yà pa̱ nzəng ka̱ ntar nchə̀r ka̱t te, ya nyar nnap-mɓá̱ngɓa̱ng i ya ka̱t.
\s1 Ikú aYesu kəristi nna nyar nnap-mɓá̱ngɓa̱ng
\p 
\v 23 A məma nva̱ ma nal iya̱m va̱ ta̱ ka̱ asa̱l va̱ ta. Iya̱m va fa izər ká̱ iga apaɓur a. Iya̱m iga apaɓur ká̱ ishi oza̱ jiwo te, mí nal ká̱ iya̱m va ji iva̱ ta ji.
\v 24 Atak yə́ryər va̱ uYesu Kəristi tar te, unəm a me ka̱t. A fa izər na pa mwan ká̱ inandər ka̱t. Uza̱ tar ashe apaɓur na ká̱ inan wò. Na o ta̱l ka̱ mpyal Inan ka̱kul yi ǹyangmata̱.
\v 25 Uza̱ tar pa̱ na o yichi ishi wò nva̱n pa̱ nkyák wa nva̱ uponzhi onəm oga mpyal awop ka̱ nnənəm ka̱t. Nna uza̱ i tar Atak yə́ryər nza̱ izun nggo ka̱ nchə̀r va njini ka̱t a.
\v 26 Ka̱ ya pa te, ya uYesu ka̱ mɓək anung ìsəm izən ɓan ka̱ nfa ka̱ apambin. Kang wa nnà ta ka̱t. Uza̱ nyám ishi wò chit pa̱ nzəng na byet ka̱ ashe nra ngga nkur va̱ ta̱. Ka̱kul na o dərkən nnap-mɓá̱ngɓa̱ng a le ka̱ cho ka̱ atak ǹyichi ishi wò iya̱m ipápà iga nshi.
\v 27 Ma pak chit təm ûnəm pa̱ uza̱ a kú nva̱n pa̱ nzəng na byet. Ka̱ nva̱n ikú te, nkat akwali nna yà.
\v 28 wantana kpa ká̱ uYesu Kəristi. Ma yichi na Înan chit nva̱n pa̱ nzəng na byet ka̱kul nyar nnap-mɓá̱ngɓa̱ng onəm pa̱ kyák. Uza̱ i ga nnyam ishi wò kà̱ɗi. Uza̱ i fa pa̱ na o nəm ikún nnap-mɓá̱ngɓa̱ng lap ka̱t. Uza̱ i fa na o ka̱mshi onəm va̱ ka̱ ntəm i lok na ka̱ nzhing.
\c 10
\p 
\v 1 Ka̱kul pa̱ nnap-mpakpak aMusa pa te, ala̱ka̱n iya̱m inəna̱n va ka̱ mɓa, inandər nandər va ka̱t te, ya ka̱ pa̱ ɗa̱p iya̱m ipápà ka̱kul nshi i kur nnak onəm oga nsəng mɓa datkulung ká̱ Inan i kur pa̱ chak ka̱t. Iya̱m va ma pak inok nshishi chit izún ka̱ apal asəm izún a.
\v 2 Ka̱ ya pa̱ oza̱ nəm inok nəm na te, ma ka̱ re nnəna chit ka̱t ɗò? Ka̱ ya pa̱ ma nal onəm oga awop va̱ ta chit pa̱ kpaktak te, iya̱m ro ka̱ ɗak oza̱ ka̱ nnap-mɓá̱ngɓa̱ng lap ka̱t.
\v 3 Iya̱m ipápà iga nshi i ɓa ka̱ nrəng nnap-mɓá̱ngɓa̱ng ônəm nza̱ izun nggo.
\v 4 Ka̱kul asa̱l ro ya pa̱ nchə̀r ina inunggwan ká̱ iɓə́l a yar nnap-mɓá̱ngɓa̱ng ka̱t.
\p 
\v 5 Nna nak te, uKəristi won pa̱ o vang ka̱ ashe apambin va̱ ta̱ te, uza̱ là pa̱,
\q1 <<ÁPonzhi Inan, iya̱m ipápà ká̱ iya̱m inana te, a ɗom ɓu ka̱t.
\q1 Ka̱ nna kpa te, u ɗa̱mshi izər á mi chit.
\q1 
\v 6 Iya̱m ipápà ka̱kul nshi pa̱ ɗwot ká̱ iya̱m inana ka̱kul nyar nnap mɓá̱ngɓa̱ng te, u fe nchang oza̱ ka̱t.
\q1 
\v 7 A nak te, n là pa̱, <Mmami na ta̱. ÁPonzhi Inan m ɓa pa̱ ń nəm iya̱m va u ɗom, wa nva ma lir chit ka̱ ashe nnap-nlà ɓu a.> >>
\v 8 Ngəshi te, uza̱ là pa̱, <<Iya̱m ipápà ká̱ iya̱m inana, ká̱ iya̱m ipápà iga nshi pa̱ ɗwot, ká̱ iya̱m inana ka̱kul nyar nnap-mɓá̱ngɓa̱ng te, u ɗom ka̱t. U fe nchang oza̱ ka̱t kpa.>> Nna kap ka̱ nva̱ pa̱ ma yichi dakdak wa nva nnap-mpakpak aMusa là a.
\v 9 A le te, uza̱ là pa̱, <<Mmami na ta̱. M ɓa ka̱kul nnəm iya̱m va u ɗom a.>> Uza̱ nshin iya̱m iga ngəshi le, na uza̱ a pak ipəpar.
\v 10 Ka̱ atak nnəm iya̱m va Inan ɗom te, ma nal yi chit i tong onəna̱n ka̱ atak ǹyichi izər aYesu kəristi wa iya̱m ipápà ka̱kul nshi Înan. Ma yichi nva̱n pa̱ nzəng na byet va kúkúr a.
\p 
\v 11 Nza̱ unəm uga nshi iya̱m awop Inan nggo te, i nəm inok wò iga nza̱ ilum nggo. Pa̱ ɗəkər te, uza̱ i yichi á na apir iya̱m ipápà izəntəng va. Iya̱m va chu nyar nnap-mɓá̱ngɓa̱ng ka̱ pa̱ ɗa̱p ka̱t a.
\v 12 UKəristi jiwo te, nva̱ngva̱ uza̱ gba̱l ka̱ ǹyichi iya̱m ipápà nva̱ng pa̱ nzəng na byet Inan ka̱kul nyar nnap mɓá̱ngɓa̱ng mbyet mbyet te, uza̱ le chit təm ka̱wo ari Inan.
\v 13 Uza̱ təm chit kan i lok pa̱ ma nak onəm oga nyang wò a ta̱l atak nnak ashishar.
\v 14 Ka̱ atak ǹyichi iya̱m ipápà Inan nva̱n pa̱ nzəng na te, uza̱ nak onəm va̱ ma ka̱ nnal i tong onəna̱n te, oza̱ tong onəm va kúr onəm chit mbyet mbyet.
\p 
\v 15 ARuhu nəna̱n nyám nnap nyám ayi kpa ka̱ apal ishi nnap va̱ ta. Ngəshi te, uza̱ là pa̱,
\q1 
\v 16 <<UPonzhi Inan là pa̱,
\q1 Nnap va̱ ta̱ mi sar ka̱ oza̱ ka̱ nva̱n nra va̱ ta.
\q1 Mi nak nnap-mpakpak mi ka̱ ashe igwák oza̱.
\q1 Mi lir ka̱ ashe igwák iga nrəng nnap oza̱.>>
\v 17 Le te, uza̱ là pa̱, <<Mi rəng nnap-mɓá̱ngɓa̱ng oza̱ lap ka̱t, ka̱ nggantal nnap-mpakpak va̱ oza̱ gantal a.>>
\v 18 A yà pa̱ ma yar nnap-mɓá̱ngɓa̱ng ôza̱ chit te, mí ɗak ka̱ nna iya̱m ipápà iga nshi ka̱kul nyar nnap mɓá̱ngɓa̱ng lap ka̱t.
\s1 Re i ɓa dat ká̱ Inan
\p 
\v 19 Ógənang, ka̱kul nva̱ ta te, ìgwak kam yi kam ka̱ ntar ashe atak yə́ryər pa̱ shat ka̱ atak nchə̀r aYesu.
\v 20 I wòl asa̱l apipye aga irirì va ma bol ayi chit va nza̱ni ngga nka atak va uza̱ bol. Nza̱ni va izəzər a.
\v 21 Ka̱kul pa̱ nna i yà ká̱ unəm uga nshi iya̱m awop uchumchum uga nnəm ka̱ onəm Inan te,
\v 22 re i ɓa dat ká̱ Inan ká̱ ìgwak inəna̱n va yə́l pa̱ sur ka̱ nnyi pa̱ nna nnandər yi akwam ka̱t. I ɓa ká̱ ìgwak va ma nal ina iga ashe ìɗimɗim ɗimɗim chit. Izər yi nnyi te, ma nal ayi chit kpa ka̱ ndəng nnəna̱n.
\v 23 Re i sat a kam ka̱ apal ishi nnak ìgwak yi va̱ i məma̱n ka̱. Ka̱kul unəm va̱ sar nnap-nlà ayi te, nnandər nandər yəl awo yəl.
\v 24 I nakshi nak ka̱ owan yi ka̱ apal ishi iya̱m va i nəm kan i nak mí zhing ka̱ nnap mma̱n ka̱ nnəm iya̱m inəna̱n a.
\v 25 Kang i nəm iwali ka̱ nnap mɓa atak mɓut ka̱t. Ka̱kul oro nnəm pa sat iya̱m izər oza̱ chit. Ka̱ɗor nnəm pa te, re i kam owan yi. A dudong nva̱ o ya Ilum nvang aPonzhi uYesu datkulung chit a.
\p 
\v 26 A yà pa̱ i ga mpyal ka̱ nnəm nnap-mɓá̱ngɓa̱ng ka̱ avyal nva̱ngva̱ i nyi nnandər chit pa̱ kpátkpát te, iya̱m ipápà iga nshi Înan ka̱kul nyar nnap mɓá̱ngɓa̱ng ro yà ɓur lap ka̱t.
\v 27 Iya̱m va̱ ɓur te, ya ntəm nlok akwali arwarwa na chwat ka̱ apər asalsal aga nri onəm oga nyang Inan.
\v 28 Unəm va pa̱ kpaktak ka̱ pat iya̱m ro ka̱ ashe nnap-mpakpak aMusa kan onəm pa̱ oparəm, ka̱t te pa̱ oshatɗing là pa̱ nnandər uza̱ nəm iya̱m va̱ ta nəm te, mí gba̱l unəm uga nggantal nnap va̱ ta nzəng ka̱ nnyam nrusok afu ro ka̱t.
\v 29 Unəm va̱ ɓak uYa Inan, uza̱ yar pa̱ nchə̀r ngga nnyam nnandər nsar nnap-nlà Inan pa̱ iya̱m ro ka̱t, nchə̀r va ma nal na ka̱, uza̱ pwat aRuhu aga nnap nnəna̱n te, nza̱ apir akwali va rwa ji pa̱ kpaktak o ya ma pa̱ ma nyám ntan ûnəm va̱ ta ka̱ yà?
\v 30 I nyi unəm va̱ nyi là pa̱, <<Mpyát akat nnap te, mmami na mi nəm. Mmami na mi mwa unəm.>> Ma ləla kpa pa̱, <<UPonzhi Inan i ga nnap-akwali ônəm wò.>>
\v 31 Iya̱m iga nnəm ayər pa̱ makmak pa̱ unəm uga mpat nnap a tar awo aPonzhi Inan uga Iriri a.
\p 
\v 32 O rəng nra va̱ watar chit cho nna ka̱ o ka̱m atak atántàn Inan ka̱ ashe ìgwak wo. Ko o sar ìgwak pa̱ kan ka̱ mɓək anung pa̱ makmak.
\v 33 Nro te, mí pwat wo ka̱ ashe onəm. Mi i na idumdum awo kpa. Nro te, onəm va̱ ma ka̱ nnəm ôza̱ pa te, a ɓyen awo pa̱ ma ka̱ nəm awo nzəng ka̱ oza̱.
\v 34 Onəm va̱ ka̱ nzhi ikan a rwa ìgwak rwa awo. Nvyat iya̱m ká̱ wo te, a ɗak wo ka̱t. Ka̱kul o nyinyi pa̱ na o yà ká̱ iya̱m va ɓyen pa̱ gənggəng. Iya̱m va təm chit mbyet mbyet a.
\p 
\v 35 Ka̱kul nva̱ ta te, kan o nəm nsal ká̱ iya̱m va̱ o ma̱n ka̱ chit ka̱t. Iya̱m va mí mwa wo ka̱kukul pa̱ makmak a.
\v 36 Re o sar ìgwak pa̱ makmak na nva̱ngva̱ o nəm iya̱m va̱ Inan ɗom te, o ya iya̱m va̱ uza̱ sar nnənap.
\v 37 Ma lir chit ka̱ ashe nnap-nlà Inan pa̱,
\q1 <<I gba̱ng lap pe ka̱t te, unəm va̱ ka̱ nvang te, uza̱ i kali ka̱t.
\q1 
\v 38 Unəm mi unəna̱n i lár ka̱ atak nna nnandər wò.
\q1 A ya nnyi pa̱ uza̱ i le nva̱n te, mi fe nchang ka̱ na ka̱t.>>
\m 
\v 39 Mmayi onəm va i ga̱ɓa̱n i le i zhì ka̱t. Ka̱ɗor nva̱ pa̱ i ya pa te, mmayi ka̱ nna nnandər ká̱ Inan. A nak te, ma ka̱mshi yi chit.
\c 11
\s1 Nna nnandər
\p 
\v 1 Nna nnandər pa te, nnyi pa̱ kpátkpát pa̱ iya̱m va̱ unəm ka̱ nnak ìgwak ka̱ va ma ka̱ ǹyiya ká̱ iwu ka̱t te, pa̱ inandər.
\v 2 Ka̱kul apir iya̱m va ta Inan ma̱n ka̱ onəm matmat.
\p 
\v 3 Ka̱kul nna nnandər na te, i kpán ìpir nnàp pa̱ ma nəm nkpaktak apambin ká̱ apaɓur ka̱ atak nnap-nlà va fa ka̱ anung Inan. A nak te, iya̱m va̱ ma ka̱ nyiya ká̱ iwu te, ma nəm ká̱ iya̱m va ma ya ká̱ iwu ka̱t.
\p 
\v 4 Ka̱kul nna nnandər na te, uHabila na iya̱m inana iga mpà Înan va ɓyen ji ija aKayinu a. Ka̱kukul na Inan ma̱n ka̱ na uza̱ nak na pa̱ unəm unəna̱n kà̱ mpyal wò. Inan nyám ka̱ atak nka̱m iya̱m inana ijini. Nna ta nak te, kap ka̱ nva̱ pa̱ uHabila kú uza̱ ya lap ka̱t te, nnap nnənəm va̱ ta nna ka̱ nlà nnap ka̱ yi.
\v 5 Ka̱kul nna nnandər na te, uNuhu ma yar na ká̱ irirì uza̱ ɓa ga apaɓur. A nak te, uza̱ nyi iya̱m va̱ mí wór pa̱ ikú ka̱t. Ma ram na te, ma ya na ka̱t ka̱kul Inan yar na chit ɓa ga atak wò. Kang mí yar na te, ma là nnənap là pa̱ uza̱ unəm va Inan fe nchang fe ka̱ na.
\v 6 Nzəng ka̱ nna nnandər ka̱t te, asa̱l ro yà unəm i nak Inan i fe nchang ka̱ na ka̱t. Ka̱kul unəm va pa̱ kpaktak ɗom nsəng mɓa dat ká̱ Inan te, nkpak pa̱ uza̱ a na nnandər pa̱ Inan uwa yà. Uza̱ i ma̱n kpa pa̱ Inan pa te, i mwa onəm va̱ mwa ka̱ nram na.
\p 
\v 7 Ka̱kul nna nnandər na te, Inan ka̱ won uNuhu ka̱ apal ishi iya̱m va mmá ya ká̱ iwu chit ka̱t te, uza̱ gwong achwang ká̱ Inan, kang uza̱ kpà agirgi ndəng aga nka̱m ishi irirì onəm wò. Ka̱ atak nnap-nnənəm va̱ ta te, uza̱ nak akwali ikú ri nkpaktak apambin. Uza̱ ǹnyi te, uza̱ ta̱l unəm uga ngwur akup nnap-nnəm nnəna̱n va Inan i na ka̱ atak nna nnandər a.
\p 
\v 8 Ka̱kul nna nnandər na te, uIbərahim kpak nnap nnəm Înan ka̱ apal ishi awór va̱ Inan wór na pa̱ a re mbin wò a ga atak ro va i ga nta̱l ajini. Uza̱ re nzhi, uza̱ nyi atak va̱ uza̱ ka̱ ngga ka̱ ka̱t.
\v 9 Ka̱kul nna nnandər na te, uza̱ ga ra nzhi ka̱ mbin va̱ ma ka̱ sar nnap-nləla á na. Uza̱ ra nzhi wa aɗyanəm uga ntəm ka̱ mbin va njini ka̱t a. Nzhí oza̱ aghal na pa kùk. UIshaku nəm pa na kpa ká̱ uYakup. UIshaku ká̱ uYakup oza̱ ovan oga ngwur iya̱mkup ka̱ nsar nnap-nlà nzəngtəng va kpa.
\v 10 Uza̱ təm nak ìgwak ká̱ ìtong ichumchum va ma ban akukum ban jiwo. Ìtong va unəm va̱ cha pa̱ na ma me, ká̱ unəm va̱ me te, uPonzhi Inan uwa ká̱ ishi wò.
\p 
\v 11 Ka̱kul nna nnandər na te, uSaratu kpa ka̱m ichumchum iga nyar anyam, nna kap ka̱ nva̱ pa̱ uza̱ watar mmar amar chit a. Uwa ká̱ nnyinyi pa̱ unəm va̱ yar nsar nnap-nlà va̱ ta pa te, nnandər nandər yəl awo yəl.
\v 12 A nak te, ka̱ atak anəm pa̱ uzəng va ɗongɗong ká̱ unəm ukúkú ka̱t te, akum ìjili a fa yəl wa izhán iga apaɓur. Oza̱ yəl ya ka̱ nkun ka̱t kpa wa ashishiri aga anung iwa.
\p 
\v 13 Nkpaktak onəm va̱ ta kú ka̱ ashe nna nnandər, oza̱ ya iya̱m va̱ ma sar nnap-nləla ôza̱ ka̱t. Oza̱ yiya na pa mwang pa̱ ɗilu ka̱ cho te, oza̱ ka̱m ká̱ nchang ìgwak. Oza̱ məma̱n kpa pa̱ oza̱ onəmchən ká̱ oɗyanəm ka̱ apambin va̱ ta.
\v 14 Onəm va̱ i là nnap wanta̱ te, ya oza̱ ka̱ nram mbin ngga ishi oza̱.
\v 15 Ka̱ ya pa̱ oza̱ ka̱ nrəng nnap mbin va oza̱ fa re te, ya asa̱l na ka̱ ya ôza̱ ka̱ nle mbin va̱ ta.
\v 16 Iya̱m va ta rwa oza̱ ka̱t. Nnap mbin va ɓyen ji nva̱ ta ji te, nna rwa oza̱. Mbin va ngga apaɓur a. A nak te, ìwuswa nəm Inan pa̱ ma wór wò pa̱ mmawò Inan oza̱ ka̱t. Ka̱kul uza̱ ɗa̱mshi ìtong ka̱kul oza̱ ɗa̱mshi.
\p 
\v 17 Ka̱kul nna nnandər na te, nva̱ Inan mà uIbərahim pa̱ uza̱ á na iya̱m ipápà iga nshi á wò ká̱ uIshaku te, uza̱ ma̱n ɓan nna uyen va uwa pa̱ uzəng byet. Uza̱ va ma ka̱ yar nsar nnap-nlà á na a.
\v 18 Uyen va ma là nnənap pa̱, <<Ka̱ atak aIshaku na kan mí kun ishi ka̱ akum ìjili ɓu.>>
\v 19 Uza̱ məma̱n pa̱ ka̱ ya pa̱ ka̱ ashe onəm kúkú te, Inan uwa yà ká̱ ichumchum iga nna nva̱ng á wò. Wa aghan ntar achu te, mí là pa̱ uIshaku pa te, uza̱ le ɓa á na ka̱ atak ikú na.
\p 
\v 20 Ka̱kul nna nnandər na te, uIshaku far nnap nnəna̱n Inan úYakup ká̱ uIshuwa ka̱ apal ishi iya̱m va ka̱ ngga mɓa a.
\p 
\v 21 Ka̱kul nna nnandər na te, uYakup won nkú te, uza̱ far nnap nnəna̱n Inan ka̱ apal ishi ovan aYusufu onunggwan pa̱ oparəm. Uza̱ nəm pa nzəng ka̱ nda̱r nkpánggang nkuchi ngwop Inan.
\p 
\v 22 Ka̱kul nna nnandər na te, uYusufu won nkú te, uza̱ kyer nggol kyer ka̱ apal ishi nnap nfa oIsa̱rila ka̱ mbin aMasar. Uza̱ là iya̱m là kpa ka̱ apal ishi nli akúm wò.
\p 
\v 23 Ka̱kul nna nnandər na te, uMusa ma mar na te, upupon ká̱ unənang bwam na ape pa̱ shatɗing. Ka̱kul oza̱ ya uyen va̱ ta ɓyen ka̱ oza̱ byet. Ayər nnap-mpakpak aponzhi nəm oza̱ ka̱t.
\p 
\v 24 Ka̱kul nna nnandər na te, uMusa uza̱ rup te, uza̱ yang pa̱ kang ma wór wò pa̱ uya aya *aFirauna uchar.
\v 25 Uza̱ yak idumdum nzəng ka̱ onəm Inan ka̱ nva̱ pa̱ uza̱ a fe nchang iya̱m va i watar watar va nnap-mɓá̱ngɓa̱ng a.
\v 26 Uza̱ nak pa̱ mpwat va̱ unəm i fe ka̱ ka̱kul aKəristi te, idur imakmak va ji iga mbin aMasar ji. Ka̱kul uza̱ nak ìgwak ká̱ imwa va Inan i na.
\v 27 Ka̱kul nna nnandər na te, ayər mmən ikum aponzhi nəm na ka̱ nfa nre mbin aMasar ka̱t. Uza̱ sar ìgwak ka̱kul uza̱ pak iwu ûnəm va mí ya na ká̱ iwu ka̱t.
\v 28 Ka̱kul nna nnandər na te, uza̱ kpak nnap Ngantal ká̱ nsháng nchə̀r ka̱ anung nzhi wa nva̱ Inan là. Na uma̱leka uga ngba̱ng ovan ogəshi a dok iji oIsa̱rila ka̱t.
\p 
\v 29 Ka̱kul nna nnandər na te, oIsa̱rila pa̱ng Iwa Irəzang na oza̱ ka̱ nchen ka̱ mbin ngwomwom. Onəm oga aMasar va̱ ka̱ ngwà oza̱ ɗom pa̱ o pa̱ng kpa te, ndəng limchi oza̱. Oza̱ wa ndəng kú.
\v 30 Ka̱kul nna nnandər na te, akamsəlang atwattwat va̱ gang aJarika̱ te, a shin nva̱ngva̱ oIsa̱rila chen gang nza̱ ilum nggo har nra pa̱ nfangshat.
\p 
\v 31 Ka̱kul nna nnandər na te, uRahap uchar uga nram onunggwan zhì nzəng ka̱ aɓo onəm oga aJarika̱ oga nlan nnap nnəm ka̱t. Ka̱kul uza̱ ka̱m onəm oga aIsa̱rila va̱ ɓa nsóng ashe mbin ɓu là pa̱ okpa.
\p 
\v 32 N ga mpyal ka̱ nnap-nlà va̱ ta ɗakɓo? Ka̱kul alum i ga i tar mi pa ka̱ nlà nnap aGidiyon ká̱ uBarak, ká̱ uSamson, ká̱ uJepta, ká̱ uDawuda, ká̱ uSamuwel, ká̱ onəm oga nka̱m nre ka̱ atak Inan.
\v 33 Oza̱ va oro ka̱ ashe oza̱ ri mbin nkak ká̱ ikum. Oro nap akwali aga nnandər. Oro ya nyə́l nsar nnap-nlà Inan ya ká̱ iwu. Oro bur anung ilir ká̱ awo.
\v 34 Oro jəp apər aga nri atak asalsal. Oro ɓur awalang pa̱ zəng oza̱ ka̱ kú ikú ndokchi. Oro ma nak nyà oza̱ ká̱ ìkàm ka̱t nyan ìkàm. Oro tong ovanza̱m oga nkam ka̱ mpyal ikum. Oro nak onəm oga nlung ikum oga mbin nkak chən.
\v 35 Ochar ro ovan oza̱ kú te, ma li ka̱t, ma wong ka̱ oza̱ ka̱ atak ikú. Oro ma na idumdum ôza̱. Ma kùk oza̱ ka̱ nzhi ikan te, oza̱ yak ntəm ka̱ ta, na oza̱ a kú ka̱ ashe idumdum te, ma won ka̱ oza̱ a yà ká̱ irirì va ɓyen ji a.
\v 36 Oro ma nnap avyal ôza̱. Ma nə́m oza̱ pa̱ zhalat zhalat. Har ma pak oza̱ ka̱ nzwar. Ma kùk oza̱ ka̱ nzhí ikán.
\v 37 Ma *kwan oza̱ ká̱ ipang kú. Ma pá ikpal ôro ma ghak ká̱ ishimshe. Ma gba̱ng oro ka̱ ndokchi. Oza̱ i mwak awa itám ká̱ iɓə́l i ranggang ka̱. Oza̱ tong onəm oga nkun. Ma ɓək anung oza̱. Ma nəm ka̱ oza̱ pa̱ vyakshin.
\v 38 Pa̱ oza̱ pa̱ vyakshin nva̱ pa̱ oza̱ a təm ka̱ ashe apambin va̱ ta̱ ka̱t. Oza̱ i ranggang i ga ashe ǹzam ka̱ ashe aɓam. Oza̱ i ra ka̱ ashe agba̱k ka̱ ache.
\p 
\v 39 Onəm va̱ ta pa̱ kpaktak te, ma là nnap nna nnandər oza̱ là. ká̱ nnà te, oza̱ ka̱m iya̱m va̱ ma sar nnap-nləla ôza̱ ka̱t.
\v 40 Inan ɗa̱mshi iya̱m inəna̱n chit ka̱kul yi. Nna nak te, nkpak pa̱ í yà nzəng ka̱ oza̱ kan oza̱ i yà wa nva̱ Inan ɗom pa̱ oza̱ a yà a.
\c 12
\s1 Nnyám ntan Inan
\p 
\v 1 Onəm yà chit pa̱ kpakpa wanta̱ onəm va í ɗyang nnap ka̱ oza̱ te, re i swang ka̱ cho iya̱m iga nɗak yi. I re nnəm nnap mɓá̱ngɓa̱ng va yang a yi ka̱ izər ka̱ nva̱ nyang ka̱t a. Re i chəng nchəng ngga mma nkələk va̱ ra a yi ka̱ mpyal nzəng ka̱ nka̱r ìgwak.
\v 2 I pak iwu ûYesu wa. Uza̱ va ɓan nnap nna nnandər yi kan uwa kpa kúr anung a. Ka̱kul nchang ìgwak va uza̱ nyi pa̱ o ga nyiya te, uza̱ ka̱r ìgwak ka̱ ikú iga apal akun. Apir ikú iga ìwuswa va̱ ta̱ ta̱l iya̱m ro va ɗak na ka̱t. Ǹyangmata̱ te, uza̱ ka̱ ntəm ka̱wo ari itok iponzhi Inan.
\p 
\v 3 O dər apir anəm va̱ ka̱r ìgwak ká̱ nyang va̱ onəm oga nnəm nnap-mɓá̱ngɓa̱ng yang na, ná kan izər a rusok ká̱ wo ka̱t.
\v 4 Ikum va̱ mmawó ka̱ nlung ka̱ nnap-mɓá̱ngɓa̱ng te, nna o yang nnap-mɓá̱ngɓa̱ng chit har nva̱ pa̱ o kú ka̱t.
\v 5 Nnap nlà Inan ngga nkam onəm va̱ pa̱ Inan wór wo pa̱ ovan wò te, a kong ká̱ wo chit ɗò? Nna pa̱,
\q1 <<Ayen mi, kan wa yar nɗyang ntàn aPonzhi Inan nnap iwali ka̱t.
\q1 A yà pa̱ uza̱ a ɗyang ntan aɓu te, kan a rusok izər aɓu ka̱t.
\q1 
\v 6 Ka̱kul uPonzhi Inan i ɗyang ntan ɗyang ûnəm va pa̱ kpaktak uza̱ ka̱ mma̱n na.
\q1 Unəm va pa̱ kpaktak uza̱ ma̱n ka̱ na ma̱n pa̱ uyen wò te, uza̱ i ɗyang ntan á na.>>
\m 
\v 7 O ka̱r ìgwak ka̱ mɓək anung ná ma ka̱ nɗyang ntan awo. Inan ka̱ nnəm ká̱ wo wa ovan wò. Nza̱ uyen pa̱ wat kan upupon i ɗyang ntan á na ka̱t yà?
\v 8 A yà pa̱ ma re wo pa ma tan wo ka̱t, wa nva nkpaktak onəm ka̱ ya te, ya mmawó ovan va ma nyi unəm va̱ mar oza̱ ka̱t. Ó yà ovan oga nzhi ka̱t.
\v 9 Opon oga mmar yi i ɗyang ntan ayi te, í wá oza̱ wá. Chit te, a mal pa̱ i wá uPo yi uga aruhu nna a ji na i lár ka̱t ɗò?
\v 10 OPo yi i ɗyang ntan ayi i ga ngwur ka̱t. Oza̱ i nəm wa nva oza̱ yà mà ka̱ oza̱. UPonzhi Inan te, uza̱ ka̱ nɗyang ntan ayi va mmayi na í yep mməmal. Uza̱ nəm pa ka̱kul na i yà ka̱ nnap-nnənəm va ɗom adak ka̱t.
\v 11 Ǹyangmata̱ te, nɗyang ntàn i nəm wa nɗul, ka̱ i chang ka̱t. I nəm te, i ɓa ka̱ nra ìgwak ka̱ nnap nnəm ngga ntong onəna̱n ka̱ mpyal Inan ônəm va̱ ɗyang ntan va̱ ta ɗyang a.
\p 
\v 12 Ka̱kul nva̱ ta̱ te, o gha̱p awo wo akuku ka̱ apal. O nak irəng wo a kam.
\v 13 O nak asa̱l wo a sat nzwan ka̱kul nchen wo. Nna chit te, unəm va̱ ugurum te, mɓan izəzər a lyanshin a le ka̱t. Ka̱ɗor nva̱ ta te, ma tan na.
\s1 Awon ka̱kul onəm oga nyang nnap Inan
\p 
\v 14 O ɗak ka̱ nzhing na o təm ntəm ikángkáng ka̱ onəm pa̱ kpaktak nzəng ka̱ ngbá̱ng ka̱ adak. Ka̱kul nzəng ka̱ ngbá̱ng ka̱ adak ka̱t te, asa̱l ro yà unəm i ya iponzhi Inan ka̱t.
\v 15 O nəm dakdak kan nya nnap nnəna̱n Inan a ma̱t wo ka̱t. O nəm dakdak kpa kan nɗul afu ro a pa ìjili ka̱ ashe wo ka̱t. I won i myak te, i ɓa ka̱ nɗaktak. I nak onəm pa̱ kyák i nəm nnap-mɓá̱ngɓa̱ng i vyap.
\v 16 O nəm dakdak kan o nəm mmai ka̱t. Kang o yang ngwa Inan wa aIshuwa va yap ká̱ inəmgbak wò ka̱kul iya̱m-nrì ka̱t.
\p 
\v 17 O nyinyi ka̱ nva̱ngva̱ uza̱ ɗom pa̱ o wur akup ka̱ nnap nnəna̱n va̱ ta te, ma yang á na. Ka̱kul uza̱ ya mbagar ngga nle nva̱n ka̱ nnap inəmgbak va̱ ta ka̱t. Uza̱ ram har ka̱ mbəl kan uza̱ ya ka̱t.
\p 
\v 18 O ɓa atak iya̱m va mí dudok ka̱t. Atak va ka̱ nsal ka̱ apər, ka̱t te a kpa̱r ɗin pa̱ bítbít, ka̱t te ǹyər,
\v 19 ka̱t te mɓur agbəshi, ka̱t te nnap achu va har onəm oga nfife sak anung pa̱ kan ma là nnap va̱ ta ôza̱ a fe ka̱t.
\v 20 Ka̱kul ayər ma̱t oza̱ ma̱t kà̱ nnap-mpakpak va̱ pa̱, <<Ko a yà pa̱ izhé a dok aɓam va̱ ta̱ te, mí kwan ká̱ ipáng i kú.>>
\v 21 Iya̱m va̱ ta nəm ayər ka̱ ndər byet har a nak te, uMusa là pa̱, <<Mmami ka̱ ntàn ka̱ ayər.>>
\v 22 O ɓa aƁam aSiyona aga aUrushelima aga apaɓur jiwo. Atak Inan uga Iriri. O ɓa atak oma̱leka va ɓut ka̱ atak nnəm nchang izər oza̱ yə́l yà ka̱ nkun ka̱t.
\v 23 Mɓut ovan gəshi va ka̱ ashe nchang ìgwak. Ma lir aɗin oza̱ chit ka̱ apaɓur. Atak Inan va uwa unəm uga nnap-akwali ônəm pa̱ kpaktak a. O ɓa atak aruhu onəm nəna̱n va ma nak chit tong onəm va yà ka̱ adak ro ka̱t.
\v 24 Atak aYesu unəmsa̱l nsar nnap-nlà mpipye. O ɓa atak nchə̀r nshángsháng va i là nnap-nnəna̱n ji nchə̀r aHabila ji pa̱ makmak a.
\p 
\v 25 O nəm dakdak kang o yang nfe unəm va̱ ka̱ nla nnap ka̱t. Ka̱kul a yà pa̱ matmat te, oza̱ pətər ká̱ unəm va̱ won oza̱ ka̱ apambin ka̱t te, i yar sang kang í pətər ûnəm va̱ ka̱ ngwon yi ka̱ apaɓur kan mmayi ka̱ nyang yà?
\v 26 Kà̱ ya te, achuchu nak apambin yənggət. Ǹyangmata̱ te, uza̱ sar nnap-nlà chit pa̱, <<Mi ga nnak apambin i yənggət kà̱ɗi na chwat ka̱t. Mi yənggət apaɓur kpa.>>
\v 27 Nnap nlà va̱ pa̱, <<kà̱ɗi >> Te, a nyám chit pa̱ iya̱m va̱ pa̱ kpaktak ma fa ka̱ kang mí yənggət yənggət te, mí zəp i le. Iya̱m va̱ i yənggət ka̱t te, i tong ntong oza̱.
\v 28 Ka̱kul nva̱ ta te, i ɗəngchi Inan ka̱kul uza̱ na iponzhi va a yi i yənggət ji wo ka̱t a. Ka̱kul nva̱ ta te, i wop Inan ká̱ apir awop va uza̱ i məma̱n ka̱ ka̱ ashe nra ká̱ ishi nzəng ká̱ ayər.
\v 29 Ka̱kul Inan yi pa te, uza̱ apər aga nri atak.
\c 13
\s1 Asa̱l va Inan i fe nchang onəm
\p 
\v 1 O ga mpyal ka̱ mma̱n ogənan.
\v 2 Kang o nəm nsal ka̱ nnyam nnyi nnap ônəmchən ka̱t. Ka̱ atak nnyi nnap va ta te, oro na ndəng ngwa ôma̱leka oza̱ nyi ka̱t.
\v 3 Kang o kong ka̱ ogənan va̱ ka̱ nzhí ikán ka̱t. O təm na mmawó nzəng ka̱ oza̱ ka̱ ashe ikán va̱ ta. Onəm va̱ ma ka̱ nnyán ka̱ oza̱ nnyi te, re a yà na mmawó ka̱ nfe mɓək anung va̱ ta nzəng. Ka̱kul mmawó izər izəntəng.
\p 
\v 4 Ma yar ntəm ivan iya̱m ichumchum. Kang ma nak adak ívan ka̱ atak nra ka̱ onəm okak ka̱t. Ka̱kul Inan i ga nnap-akwali ônəm oga nnəm mmai ka̱ onəm ngga nra ochar onəm.
\v 5 O fa ka̱ ashe aɗom aga nchang mbwai. Iya̱m va unəm ka̱ te, re nna a kúr na. Ka̱kul Inan là pa̱, <<Ko pa̱ ɗa̱p mi yà ka̱ nre ɓu ka̱ nkukwa ka̱t. Mi ga̱ɓa̱n asəm mi na ɓu ka̱t kpa.>>
\v 6 Ka̱kul nva̱ ta te, i là pa̱ shat pa̱,
\q1 <<UPonzhi Inan uwa unəm uga nna nka̱mshi á mi, mi nəm ayər ka̱t.
\q1 Iza̱ unəm kúr nnənəm á mi yà?>>
\p 
\v 7 Kang o kong ka̱ nnap onəm ochumchum wo ka̱t. Onəm va ka̱ là nnap-nlà Inan awo. O rəng apir ntəm oza̱. O ɗyang nnap nnəm oza̱ ngga nna nnandər.
\v 8 UYesu Kəristi unəm zəngtəng mbyet mbyet. Uwa ka̱ nlam, uwa nda.
\v 9 Kang o ma̱n nɗyang nggafak apir pa̱ ɗongɗong a zwar wo ka̱t. Iya̱m va mà te, re nnap nnəna̱n Inan nna a nak ìgwak wo o kam. Kang a ya nnap nkpak nnap-mpakpak ka̱ apal ishi iya̱m-nrì ka̱t. Iya̱m va ka̱mshi ônəm oga nnəm nnap va̱ ta ka̱t a.
\v 10 Mmayi ka̱ atak nshi iya̱m awop va onəm oga nnəm inok awop oYahudi te, oza̱ yà ká̱ ichumchum iga nri iya̱m va̱ ma ka̱ nshishi ka̱ apəpal jiwo ka̱t.
\p 
\v 11 Iya̱mkang va̱ uponzhi onəm oga mpyal awop i yar nchəchər i tar ka̱ ka̱ ashe atak yə́ryər ka̱kul nyar nnap-mɓá̱ngɓa̱ng te, mí shi izhé oza̱ ka̱ nsəm apa̱k.
\v 12 Nna nak te, uYesu ɓək anung pa na kpa ka̱ nsəm ìtong na o nak onəm wò a tong onəna̱n va ya ka̱ adak ro ka̱t ka̱ atak nchə̀r njini.
\v 13 Ka̱kul nva̱ ta te, re i fa i ga i ya na ka̱ nsəm apa̱k na i fe ká̱ ìwuswa va̱ ma na á na.
\v 14 Ka̱ ta̱ te, i yà ká̱ ìtong ro iga mbyet mbyet ka̱t. Mmayi ka̱ nlok ìtong va i ga nfa.
\v 15 Ka̱ atak aYesu na te, re pa̱ ɗəkər te, i yichi aɗəngchi Înan wa iya̱m inana. Awop va anung yi i ɓa ka̱ ka̱ atak nla pa̱ i nyi aɗiɗin nyi a.
\v 16 Kang o nəm iwali ka̱ nnəm iya̱m inəna̱n ka̱t. Kang o wali ka̱ nnap nkap iya̱m va̱ mmawó ka̱ ká̱ izəzər ka̱t kpa. Apir iya̱m inana va ta na i chang ká̱ Inan.
\p 
\v 17 Re o kpak nnap nnəm ônəm chumchum wo. O ra ká̱ ishi ôza̱ ka̱kul oza̱ ka̱ mmángchi irirì wo wa onəm va i ga nnyam inok va̱ oza̱ nəm. O nak na oza̱ a nəm inok ka̱ ashe nchang ìgwak. Kang a yà ka̱ ashe nlak ìgwak ka̱t. O lak ìgwak ôza̱ te, i yà ka̱ nka̱mshi ro ka̱ atak wo ka̱t.
\p 
\v 18 O nəm aduwa nəm ayi. Ka̱kul i nyinyi ka̱ ashe ìɗimɗim ìgwak yi pa̱ i ɗom nnəm iya̱m ɗom pa̱ kpaktak ka̱ asa̱l va mal.
\v 19 Mmami ka̱ nchal wo ka̱ nzhing pa̱ o nəm aduwa á mi pa̱ gənggəng na Inan a nak mi n le atak wo kà̱ɗi pa̱ kəlak.
\s1 Nfar nnap nnəna̱n ka̱ nre anung
\p 
\v 20 Re Inan uga nna nra ìgwak va ka̱ atak ikú iga nyə́l nsar nnap-nlà va təm chit mbyet mbyet, uwa le ɓa ká̱ uPonzhi yi uYesu ka̱ atak ngwon ka̱ na ka̱ atak ikú, uza̱ va unəm uga nkpak iya̱mkang uchumchum te,
\v 21 uza̱ a nak iya̱m inəna̱n pa̱ kpaktak ka̱ ashe wo ka̱kul nnəm iya̱m va uza̱ ɗom. Uza̱ a nəm inok ka̱ ashe yi va i chang ka̱ na. Uza̱ a nəm ka̱ atak nnəm inok ká̱ uYesu Kəristi uwa ichumchum təm ijini chit mbyet mbyet a. Nna a təm.
\p 
\v 22 Ógənang, mmami ka̱ nchal wo pa̱ o ka̱r ìgwak ka̱ nnap nla mi ngga nkam wo. Ka̱kul n lir iya̱m ro awo mak pe ka̱t.
\p 
\v 23 N ɗom pa̱ o nyi pa̱ ma fa ká̱ ugənang yi uTimoti chit ka̱ nzhi ikan. A yà pa̱ uza̱ i ɓa pa̱ kəlak te, mi ɓa atak wo nzəng ka̱ na.
\p 
\v 24 O re anung re n̂kpaktak onəm ochumchum wo nzəng ka̱ nkpaktak onəm Inan. Onəm Inan va̱ ka̱ mbin aItaliya te, oza̱ ka̱ nre anung awo.
\p 
\v 25 Re nnap-nnəna̱n Inan a təm nzəng ká̱ wo pa̱ kpaktak. Nna a təm.
