\s2 The \nd third\nd* bowl  
\p
\v 4 \w Then|strong="G2532"\w* \w the|strong="G2532"\w* \w third|strong="G5154"\w* \w angel|strong="G1632"\w* \w poured|strong="G1632"\w* \w out|strong="G1632"\w* \w his|strong="G1519"\w* \w bowl|strong="G5357"\w* \w on|strong="G1519"\w* \w the|strong="G2532"\w* \w rivers|strong="G4215"\w* \w and|strong="G2532"\w* \w the|strong="G2532"\w* \w springs|strong="G4077"\w* \w of|strong="G2532"\w* \w water|strong="G5204"\w*, \w and|strong="G2532"\w* \w they|strong="G2532"\w* \w turned|strong="G1096"\w* \w into|strong="G1519"\w* blood.  
\v 5 \w And|strong="G2532"\w* \w I|strong="G2532"\w* heard \w the|strong="G2532"\w* angel \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w waters|strong="G5204"\w* \w saying|strong="G3004"\w*: “\w How|strong="G3754"\w* \w just|strong="G1342"\w* \w You|strong="G3754"\w* \w are|strong="G1510"\w*! \w The|strong="G2532"\w* \w One|strong="G3588"\w* \w who|strong="G3588"\w* \w is|strong="G1510"\w* \w and|strong="G2532"\w* \w who|strong="G3588"\w* \w was|strong="G1510"\w*, \w the|strong="G2532"\w* \w holy|strong="G3741"\w* \w One|strong="G3588"\w*, \w because|strong="G3754"\w* \w You|strong="G3754"\w* \w have|strong="G2532"\w* \w judged|strong="G2919"\w* \w these|strong="G3778"\w* \w things|strong="G3778"\w*.  
\v 6 \w Because|strong="G3754"\w* \w they|strong="G2532"\w* \w shed|strong="G1632"\w* \w the|strong="G2532"\w* blood \w of|strong="G2532"\w* saints \w and|strong="G2532"\w* \w prophets|strong="G4396"\w*, \w and|strong="G2532"\w* \w You|strong="G3754"\w* \w have|strong="G2532"\w* \w given|strong="G1325"\w* \w them|strong="G1325"\w* blood \w to|strong="G2532"\w* \w drink|strong="G4095"\w*.\f + \fr 16:6 \ft That is right. Where are people going to find water to drink, let alone for washing, etc.?\f* \w They|strong="G2532"\w* deserve \w it|strong="G2532"\w*!”  
