\v 12  Perhaps \w the|strong="H7200"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w will|strong="H3068"\w* notice \w my|strong="H3068"\w* affliction \w and|strong="H3068"\w* \w this|strong="H2088"\w* \w day|strong="H3117"\w* grant \w me|strong="H7725"\w* \w good|strong="H2896"\w* \w in|strong="H3068"\w* \w place|strong="H8478"\w* \w of|strong="H3068"\w* \w his|strong="H3068"\w* \w curse|strong="H7045"\w*.”   
\p
\v 13  \w So|strong="H1980"\w* \w David|strong="H1732"\w* \w and|strong="H1980"\w* \w his|strong="H1732"\w* \w men|strong="H1980"\w* \w went|strong="H1980"\w* \w on|strong="H1980"\w* \w their|strong="H5980"\w* \w way|strong="H1870"\w*. \w But|strong="H1870"\w* \w Shimei|strong="H8096"\w* kept \w going|strong="H1980"\w* \w along|strong="H1980"\w* \w the|strong="H1870"\w* \w side|strong="H6763"\w* \w of|strong="H2022"\w* \w the|strong="H1870"\w* \w hill|strong="H2022"\w* opposite \w him|strong="H5619"\w*, yelling \w curses|strong="H7043"\w* \w as|strong="H1980"\w* \w he|strong="H1732"\w* \w threw|strong="H5619"\w* \w stones|strong="H5619"\w* \w and|strong="H1980"\w* \w dirt|strong="H6083"\w* \w at|strong="H1732"\w* \w them|strong="H1870"\w*.  
