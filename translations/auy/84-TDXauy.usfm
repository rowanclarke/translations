\id TDX - Awiyaana NT [auy] -Papua New Guinea 1984 (web version -2012 bd) 
\h Tuwímbai-aaigoni áwáu maarán-iye 
\toc1 Tuwímbai-aaigoni áwáu maarán-iye 
\toc2 Tuwímbai-aaigoni áwáu maarán-iye 
\toc3 T. á. m. 
\mt1 Tuwímbai-aaigoni áwáu maarán-iye  
\c 1  
\s1 Tuwímbai-aaigoni áwáu maarán-iye.  
\p \k Aantá-waasi \k*  
\li1 Mátíyu 10:2  
\li1 Aantá-waasi 14:13  
\pi1 Ísu kesáái simátímaꞌmae nóro séna simátímakain-kwaasisafesa numa-áímpínkémbá aposeliye wésefo kentáásááifimba aantá-waasiyesa wésune. Íumba Ísuni kísau-waasi sísamaifakemba kaeꞌá kumbaimái-waasi aantembanifo tuwímbai-waasi-tuwiꞌa Pórowe Páánápáasiye Sáírásiye fíꞌo-fiꞌon-kwaasisafesawaraꞌa aantá-waasiye wésewe.  
\b  
\p \k Aarakwá tááiye awáꞌ-wáásí tááiye iyámpói tááiye miyán-ááí \k*  
\pi1 maampímbá wéraifo toráumai ísáaro.  
\li1 Mátíyu 5:27-32 .. 19:3-9  
\li1 Mááka 7:10 .. 10:2-12  
\li1 Rómu 7:2-3  
\li1 1 Kórinti 6:9-11 .. 7:1-16 .. 7:25-40  
\li1 2 Kórinti 6:14  
\li1 Éfásási 5:21-33 .. 6:1-4  
\li1 Kórósi 3:18-21  
\li1 1 Tímóti 3:4  
\li1 Ípúru 12:7-11 .. 13:4  
\li1 1 Pítaa 3:1-7  
\b  
\p \k Aare tiꞌnónkáꞌó káátaraan-aai. \k*  
\li1 1 Kórinti 11:2-16  
\pi1 Naaófáꞌá aare táái tiꞌnómbó ímbo ánáan-kwimaimo kámoꞌo wíyún-inintafesa sáwí-imayaawaraꞌ-inine siyáawe.  
\b  
\p \k Ámáán-kawaa-waasi \k*  
\li1 Mátíyu 3:7  
\li1 Aantá-waasi 4:1 .. 5:17  
\pi1 Yúndaa-waasiti óraaꞌ-waasi kaekáꞌ-unkwimaꞌmai mésa moórá-unkwimo ombá Móseseni ámááne miwítí ámááne wésimatimewisafesa numa-áímpínkémbá Ferisi-waasiye wésefo kentáásááifimba ámáán-kawaa-waasiyesa wésune. Moórá-unkwimo ombá sésa púwómpinkemba ímba íyáfasinanaawe sésa púwón-kwaasi timambá ímba wéraiye sésa Maníkóní wíyómpaken-kisau-waasi ímba méraawe sen-kwáásí túwíꞌa Sátúsi-amaan-aaimo sen-kwáásíyé.  
\b  
\p \k Ámáán-kisau-waasi \k*  
\li1 Mátíyu 8:4 .. 12:5  
\pi1 Ámáán-kisau-waasi Maníkóní óraaꞌ-amaan-daumpaꞌa kísau maésa Móseseni ámáámba arááíwaesa waásiti sáwí-imayaa maitiyuwáínana miwífáꞌá sáwí-meyamba ímba tínkwae sésa póí tufúꞌmai óntan-taareraꞌa agaimái Maníkómbá ámaꞌmae iyáawe. Miyámó uráan-kwaasisontafesa numa-áímpínkémbá pris-waasiye wésefo kentáásááifimba ámáán-kisau-waasiyesa wésune.  
\b  
\p \k Ándá-aran-domba \k*  
\pi1 Numa-áímpínkémbá wain-iye wésefo kentáásááifinkemba ándá-aran-done wésewe. Maampímbá wéraifo toráumai ísáaro.  
\li1 Mátíyu 9:14-17 .. 21:33-46 .. 26:26-30  
\li1 Rómu 14:19-23  
\li1 1 Kórinti 10:14-22 .. 11:23-32  
\b  
\p \k Aráá-tonkon-aai \k*  
\pi1 maampímbá wéraifo toráumai ísáaro.  
\li1 Mátíyu 26:26-30  
\li1 Mááka 14:22-26  
\li1 Rúku 22:15-20  
\li1 1 Kórinti 10:14-22 .. 11:17-34  
\b  
\p \k Ísípi-marafaken-kawaago \k*  
\li1 Aantá-waasi 7:10  
\pi1 Ísípi-marafaken-kawaagowemo sembá miwí tááifinkene numa-áímpínkéné Ferowe wésewe.  
\p \k Ísu aúíꞌa úmai maéꞌmaeꞌo íyawini áwáun-iye. Aúíꞌa úmai maéꞌmaeꞌo íyawini áwáu-aai \k*  
\pi1 maampímbá wéraifo toráumai ísáaro.  
\li1 Yóni 3:16 .. 3:36 .. 5:24 .. 5:39-40 .. 6:47  
\li1 Yóni 6:66-69 .. 10:27-30 .. 14:6 .. 17:1-5  
\li1 Rómu 6:22-23  
\li1 1 Yóni 5:11-15  
\b  
\p \k Ísu Káráísitini waásiye \k*  
\pi1 sésa numa-áímpínkémbá Kristeniye wésewe.  
\li1 Aantá-waasi 11:26  
\b  
\p \k Ísu marapáꞌá kumíndasafesa imáyáa ésamo toꞌmayaa on-ááí \k*  
\pi1 maampímbá wéraifo toráumai ísáaro.  
\li1 Mátíyu 16:24-28 .. 24:36-44 .. 25:31-46  
\li1 Mááka 8:34-38 .. 13:32-37  
\li1 Rúku 12:35-40 .. 19:11-27 .. 21:34-36  
\li1 Yóni 14:1-3  
\li1 Aantá-waasi 1:9-11  
\li1 1 Kórinti 1:4-9 .. 3:10-15 .. 4:5  
\li1 Fírípai 1:3-6 .. 3:20-21  
\li1 Kórósi 3:1-4  
\li1 1 Tésárónika 3:11-13 .. 4:13-18 .. 5:23-24  
\li1 2 Tésárónika 1:5-12  
\li1 1 Tímóti 6:11-16  
\li1 2 Tímóti 4:1-8  
\li1 Táítási 2:11-14  
\li1 Ípúru 9:27-28  
\li1 Yémísi 5:7-9  
\li1 1 Pítaa 1:13  
\li1 2 Pítaa 3:1-14  
\li1 1 Yóni 2:28 - 3:3  
\li1 Yúti 14-24  
\li1 Paápé uráin-aai 1:7 .. 16:15 .. 20:11-15 .. 22:20  
\b  
\p \k Ísuni fasiꞌaénkó seyaafá-fásíꞌáénkómbá íyáákarain-aai \k*  
\pi1 maampímbá wéraifo toráumi ísáaro.  
\pi1 Waántáwankomba íyáákaraiye.  
\li1 Mátíyu 4:1-11  
\li1 1 Yóni 3:8  
\pi1 Tíꞌo ún-kwaasi asófatinkena pukómpinkemba íyáfasintinkaraiye.  
\li1 Mátíyu 4:24 .. 8:1-4 .. 9:1-8 .. 9:18-26  
\li1 Mááka 2:1-12 .. 5:24-34 .. 7:31-37  
\li1 Rúku 7:11-17  
\li1 Yóni 9:1-41 .. 11:1-44  
\li1 Aantá-waasi 3:1-16 .. 9:36-42  
\li1 Yémísi 5:14-16  
\pi1 Sáwí-amutamba tirumpinkémbá maitíyukaiye.  
\li1 Mátíyu 8:28-34  
\li1 Mááka 1:21-28 .. 6:7 .. 7:25-30  
\li1 Rúku 9:37:43  
\pi1 Kári-tomban-ifo sáwífa-tomba úkáiye.  
\li1 Mátíyu 14:13-21 .. 15:32-38  
\pi1 Óraa-fiyunda torówana mafaimakáiye.  
\li1 Mátíyu 8:23-27  
\pi1 Non-afóforaꞌa kuráiye.  
\li1 Mátíyu 14:22-33  
\pi1 Waántáwanko waásimo puwíya-fasiꞌaembo tokáimba Ísu taíꞌásuwainiye.  
\li1 Ípúru 2:14-15  
\pi1 Ísu aúíꞌa úmai maéꞌmaeꞌo uwátínkáí-fasiꞌaemba tokáiwain-iye.  
\li1 Yóni 17:1-3  
\pi1 Ísu waásiti sáwí-imayaa wémaitiyuwai-fasiꞌaemba tokáiwain-iye.  
\li1 Mátíyu 9:1-8  
\li1 Rúku 7:47-50  
\b  
\p \k Ísuni kísau-waasi \k*  
\li1 Mátíyu 10:1  
\pi1 Ísu séna Maníkón-aai simátíménaꞌa kembá súwaꞌnai eꞌa keséꞌa níwae séna sísamaifakemba kaeꞌá kumbaimái-waasi íyáfasintinkain-kwaasisafena numa-áímpínkémbá disaipeliye wésefo kentáásááifimba Ísuni kísau-waasiyesa wésune.  
\b  
\p \k Ísuni waásifimba umbai-tántááꞌá tínda-aaiye fasiꞌátínkáín-aaiye \k* maampímbá wéraifo toráumai ísáaro.  
\li1 Mátíyu 5:10-11 .. 6:25-33 .. 10:16-25  
\li1 Mátíyu 11:28-30 .. 26:40-41  
\li1 Rúku 17:1-4 .. 8:13  
\li1 Yóni 14:1-3  
\li1 Aantá-waasi 5:40-42 .. 9:15-16  
\li1 Rómu 5:1-5 .. 8:17-18 .. 8:31-39 .. 12:12-18  
\li1 1 Kórinti 10:6-13  
\li1 2 Kórinti 1:3-7 .. 4:16-18 .. 12:7-10 .. 15:56-58  
\li1 Kárésíya 6:1-2  
\li1 Éfésási 4:25-32  
\li1 Fírípai 4:4-7  
\li1 1 Tésárónika 3:1-5  
\li1 2 Tésárónika 3:1-5  
\li1 1 Tímóti 1:7  
\li1 2 Tímóti 2:14-15  
\li1 Ípúru 2:18 .. 4:14-16 .. 12:7-11 .. 12:14  
\li1 Yémísi 1:2-4 .. 1:12-15  
\li1 1 Pítaa 1:3-9 .. 2:19-21 .. 3:13-18  
\li1 1 Pítaa 4:12-19 .. 5:6-11  
\li1 2 Pitaa 2:9  
\li1 1 Yóni 2:7-11 .. 4:18  
\li1 Yúti 24  
\b  
\p \k Máána-tomba \k*  
\li1 Yóni 6:31  
\pi1 Yúndaa-waasi Ísípi-marafaꞌa ándáfakaamba mérowana Mósese séna Maníkó Émbaramuwara wenaísaafitantambo íyawiwaraꞌa timénaumne siyóm-barafaꞌa kónae séna tíꞌmaena kúmba afufumpim-bárámá máásai-marafaꞌa wéwesa 40 aatai maisukáawe. Maníkó tómbá tuwówasa mi-40-áátáígón-arumpimba námae iyáawe. Mintómbá aifa-kánáá awánésa miwí tááifinkemba sésa maanaawemo sumbá nóin-tantaaraꞌiyo sésa siyáawe.  
\b  
\p \k Maníkó waásimo méraawini áwáusafena tísai índa-kanaa tínda-aai \k* maampímbá wéraifo toráumai ísáaro.  
\li1 Mátíyu 11:20-24 .. 12:36-37 .. 16:27 .. 21:33-44  
\li1 Yóni 3:18-21 .. 8:24 .. 12:47-48  
\li1 Rómu 6:22-23 .. 14:12  
\li1 Ípúru 10:26-31  
\b  
\p \k Maníkó wení waásiyaꞌa wégawaaniye. \k*  
\li1 Mátíyu 3:2  
\pi1 Ísu marapáꞌó méronkaꞌa Yúndaa-waasiti marafáꞌá Rómu-kamani-waasi kawáánurowasa Yúndaa-waasi sésa Rómu-waasi kóíyanamo éna Maníkó kenkátá kawáánuwasinkena kentáásí Fasiꞌaénkó-iꞌa íníye sésa amuꞌmarésa méraawe. Marapáꞌá méraankaꞌa waántáwanko tafisisasá wenááisafesa ewémó sewí waántáwanko miwítí fasiꞌaénkó-iꞌa wéifo Ísun-aaisafesa ewémó sewí Maníkó miwítí Fasiꞌaénkó-iꞌa éna miwíyáꞌá wégawaaniye. Miyámó wéofo ánaaembo éna Maníkó aantemba Fasiꞌaéniꞌa éna waásiyaꞌe mararáꞌé wíyómpaꞌe weyáá kawááníníye. Maníkó wení waásiyaꞌa wégawaaniye sésa numa-áímpínkémbá kingdomuwe wésefo maampímbá wéraifo ísáaro.  
\li1 Mátíyu 3:2 .. 6:10 .. 6:30-33 .. 7:21-23  
\li1 Mátíyu 13:24-52 .. 18:1-4 .. 18:23-35 .. 19:13-15  
\li1 Mátíyu 20:1-16 .. 22:1-14 .. 25:1-13  
\li1 Rúku 13:18-21 .. 17:20-21 .. 18:24-30 .. 23:42-43  
\li1 Yóni 18:36  
\li1 1 Kórinti 6:9-10  
\b  
\p \k Maníkómó íyáfasinankaiwai \k*  
\li1 Mátíyu 11:2 .. 16:16  
\li1 Yóni 6:14-15  
\pi1 Yúndaa-waasi kentáásí óraaꞌ-waasi-iꞌa ínkwáe sésamo ombá masawémba tiꞌnómpímbá atinkéꞌómbaniye. Miyámó éꞌóntafesa Yúndaa-waasi-taaifinkemba Mésiyaawe wésefo Kíríki-waasi-taaifinkemba  
\pi1 Káráísitiyemo sembá minááígóní áwáu Maníkómó íyáfasinankaiwain-iye wésewe. Maníkó kesááninko kesí kísau máínkwae séna íyáfasinankaundawi paápé íníye súwana Yúndaa-waasiti marafáꞌá Ísu paápé uráiye. Yúndaa-waasiti marafáꞌá Rómu-kamani-waasi kawáánuronkaꞌa Yúndaa-waasi sésa Maníkómó íyáfasinankaraiwai paápé éna Rómu-waasi timátuwena wemá kawááníníye sumbá Ísu ímba miyá úntafesa Maníkómó íyáfasinankaraiwaiye ímba siyáawe.  
\b  
\p \k Maníkómpáꞌá inaimó sen-ááí \k* maampímbá wéraifo toráumai ísáaro.  
\li1 Mátíyu 6:5-15 .. 18:19-20 .. 21:21-22 .. 26:36-46  
\li1 Mááka 11:24-26  
\li1 Rúku 6:12 .. 10:2 .. 18:1-8 .. 22:39-46  
\li1 Yóni 11:21-22 .. 14:12-14 .. 15:7 .. 16:24  
\li1 Aantá-waasi 7:60 .. 9:40 .. 16:25-26  
\li1 Rómu 8:26  
\li1 Éfésási 6:18-19  
\li1 1 Tésárónika 5:17-18  
\li1 1 Tímóti 2:1-8  
\li1 Ípúru 7:23-25  
\li1 Yémísi 1:5-8 .. 4:3 .. 5:13-16  
\li1 1 Yóni 3:22-24 .. 5:13-15  
\b  
\p \k Maníkón-aai \k* maampímbá wéraifo toráumai ísáaro.  
\li1 Mátíyu 13:3-25 .. 24:35  
\li1 Rúku 21:33  
\li1 Yóni 8:31-32 .. 15:7-11 .. 17:13-19 .. 20:30-31  
\li1 Aantá-waasi 17:11  
\li1 Rómu 1:16-17 .. 15:4-6  
\li1 Éfésási 6:13-20  
\li1 Kórósi 3:12-17  
\li1 1 Tésárónika 2:13  
\li1 2 Tímóti 3:14-17  
\li1 Ípúru 4:12-13  
\li1 1 Pítaa 1:25  
\li1 1 Yóni 5:13  
\b  
\p \k Maníkón-aai simátímakowi \k*  
\li1 Mátíyu 1:22  
\pi1 Ísu ímba marapáꞌá kunkónkaꞌa Maníkón-aai isésa simátímaꞌmaesa iyáawi mésa Maníkómó íyáfasinankaiwai paápé íníye-aai aúfáífimba agaimakáankaꞌa póna Ísu marapáꞌá kunkáiye. Miyámó uráan-kwaasisontafesa numa-áímpínkémbá profeti-waasiye wésefo kentáásááifimba Maníkón-aai simátímakaawiyesa wésune.  
\b  
\p \k Maníkón-aaisafesa timankúnkúmba wéowe. \k*  
\li1 Mátíyu 9:2  
\pi1 Numa-áímpínkémbó sésamo bilipiyemo sembá kentáásááifimba Ísun-aaisafeꞌa éraiꞌe séꞌa timankúnkúmba oro. Ísu Manínkón-ááninko marapáꞌá kumbéna Maníkón-aai simátimena tíꞌo ún-kwaasi túwaꞌnai ena sáwíꞌo úmaimo méraampinkemba fautinkánae séna aaraa-táíyáꞌá pukáintafeꞌa Ísun-aaisafeꞌa éraiꞌe séꞌa timankúnkúmba oro wésefo maampímbá wéraifo toráumai ísáaro.  
\li1 Mátíyu 9:2 .. 9:22 .. 9:28 .. 15:28  
\li1 Mátíyu 17:20 .. 21:22 .. 27:42  
\li1 Rúku 17:5-6  
\li1 Yóni 3:16 .. 5:24 .. 6:47 .. 6:69 .. 20:31  
\li1 Aantá-waasi 10:43 .. 11:21 .. 13:48  
\li1 Rómu 1:17 .. 4:2-3 .. 5:1 .. 10:9  
\li1 1 Kórinti 1:21 .. 15:2  
\li1 2 Kórinti 13:5  
\li1 Kárésíya 2:16 .. 5:5  
\li1 Éfésási 2:8 .. 3:17  
\li1 Kórósi 1:23  
\li1 Ípúru 11:1 .. 11:6  
\li1 Yémísi 5:15  
\li1 1 Pítaa 1:7  
\li1 1 Yóni 3:23 .. 5:1-5 .. 5:10-13  
\b  
\p \k Maníkóní ámáámba \k*  
\li1 Mátíyu 5:17  
\pi1 Maníkóní ámáámba maarán-iye. Maníkómó Mósesembo simámakain-amaamba siyáánkai-amaamba óntan-kwandaaiyaꞌa agaimakón-amaane Maníkó fíꞌo-fiꞌon-aai siyáin-amaane naaófáꞌó Maníkómó Émbaramuntafena séna túma kárámai araénáémbo úmaraiyan-kwaasi kesí waási-iꞌa oro siyáin-amaane miyán-ámáámbá Maníkóní ámáámban-iye. Yúndaa-waasiti óraaꞌ-waasi Maníkóní ámáámpimba tuwímbai-aai áúwimai ayáátááse úmaresa arááíwakaawe. Ámáán-aai maampímba wéraifo toráumai ísáaro.  
\li1 Mátíyu 5:17 .. 7:12 .. 23:23  
\li1 Aantá-waasi 13:38-39  
\li1 Rómu 3:28 .. 7:21 - 8:8 .. 10:4-5  
\li1 Kárésíya 3:2-5 .. 3:23-29  
\li1 Ípúru 9:18-28  
\b  
\p \k Manínkóní Ufaen-ámútánkó \k*  
\li1 Mátíyu 1:18  
\pi1 Numa-áímpínkémbá Holi Spiritiye wésefo kentáásááifimba Maníkóní Ufaen-ámútánkón-iyesa wésune. Ísuni waási tirumpimbá Maníkóní Ufaen-  
\pi1 ámútánkó méraiye-aai maampímbá wéraifo toráumai ísáaro.  
\li1 Mátíyu 1:18-21 .. 3:11 .. 12:32 .. 28:18-20  
\li1 Mááka 13:11  
\li1 Rúku 4:1  
\li1 Yóni 1:29-34 .. 14:15-19 .. 14:25-26 .. 16:12-15  
\li1 Aantá-waasi 1:8 .. 2:1-42 .. 10:44-48  
\li1 Rómu 5:5 .. 8:12-17 .. 8:26-27 .. 15:13  
\li1 1 Kórinti 3:16-17  
\li1 Kárésíya 5:16-18  
\li1 Éfésási 1:11-14  
\li1 1 Tésárónika 1:5-6  
\li1 2 Tímóti 1:13-14  
\li1 2 Pítaa 1:20-21  
\b  
\p \k Maníkóní waásiyaꞌo káráwiyaawi-taai \k*  
\pi1 maampímbá wéraifo toráumai ísáaro.  
\li1 1 Tímóti 3:1-12  
\li1 Táítási 1:5-9  
\li1 Yémísi 5:14-16  
\li1 1 Pítaa 5:1-5  
\b  
\p \k Maníkóní wíyómpaken-kisau-waasi \k*  
\li1 Mátíyu 1:20  
\pi1 Maníkóní wíyómpaken-kisau-waasisafesa numa-áímpínkémbá enseliman-owe wésewe.  
\b  
\p \k Nombó maitínkáán-aai. \k*  
\li1 Mátíyu 3:11  
\li1 Aantá-waasi 2:38  
\li1 Kórósi 2:12  
\pi1 Waási sáwí-imayaawe aoisaané tuwésa Maníkómpáꞌá tun-kwáásí Yóni nombá maitínkaraiye. Ánaaemba Ísu  
\pi1 ukáimpinkemba íyáfasinena wíyómpaꞌa iyónkaꞌa Ísun-aaisafesa éraiꞌe sésa timankúnkúmbo un-kwáásí sésa suwánésa Ísuni aampaꞌá wégon-kwaasin-owe síwae sésa nombá maiyáawe.  
\b  
\p \k Óntankon-aai \k* maampímbá wéraifo toráumai ísáaro.  
\li1 Mátíyu 6:24 .. 13:22 .. 19:16-30  
\li1 Mááka 8:34-38 .. 14:3-9  
\li1 Rúku 12:13-21 .. 12:32-34 .. 16:10-13  
\li1 Fírípai 4:10-13  
\li1 Kórósi 3:1-2  
\li1 2 Tímóti 3:1-5  
\li1 Ípúru 13:5  
\li1 Yémísi 1:9-11 .. 4:13-14  
\li1 1 Yóni 2:15-17  
\b  
\p \k Póímo wénaan-aai. \k*  
\pi1 Naaófáꞌá Yúndaa-waasi póíma ímbo naráan-aaiye kísaufaken-ton-aantemba nésa póí-amaꞌwaraꞌa naráan-aaiye maampímbá wéraifo toráumai ísáaro.  
\li1 Mááka 7:17-23  
\li1 Aantá-waasi 10:9-16 .. 15:19-29  
\li1 Rómu 14:1-4 .. 14:13-23  
\li1 1 Kórinti 8:1-13 .. 10:14-32  
\li1 1 Tímóti 4:1-5  
\b  
\p \k Puwíyampinkembo íyáfasinaiyan-aai \k*  
\pi1 maampímbá wéraifo toráumai ísáaro.  
\li1 Mátíyu 22:23-33  
\li1 Yóni 5:25-29 .. 6:35-40 .. 11:21-27  
\li1 Aantá-waasi 2:29-33 .. 4:32-33  
\li1 1 Kórinti 15:3-7 .. 15:12-58  
\li1 Fírípai 3:7-11  
\li1 1 Tésárónika 4:13-18  
\b  
\p \k Rómu-kamani-aifa-kawaago \k*  
\li1 Mátíyu 22:21  
\pi1 Rómu-kamani-aifa-kawaagowemo sembá Rómu-waasi-taaifinkene numa-áímpínkéné Sisaawe wésewe.  
\b  
\p \k Sambaatigón-ááí \k*  
\pi1 Yúndaa-waasi saagon-kánáá ámáán-aai ísón-kanaasafesa Yúndaa-waasi-taaifine numa-áímpínkéné sambaatiyé wésefo maampímbá wéraifo toráumai ísáaro.  
\li1 Mátíyu 12:1-14  
\li1 Mááka 2:23-3:6  
\li1 Rúku 4:16-37 .. 6:2-11 .. 13:10-17 .. 14:1-6  
\li1 Yóni 5:2-18 .. 7:14-24 .. 9:1-14  
\b  
\p \k Sáwíꞌo uwátinkaiyaꞌo ímbo anondáámo íyan-aai \k*  
\pi1 maampímbá wéraifo toráumai ísáaro.  
\li1 Mátíyu 6:7-15 .. 18:15-35  
\li1 Mááka 11:25-26  
\li1 Rúku 6:27-38 .. 11:4 .. 17:3-4 .. 23:33-34  
\li1 Aantá-waasi 7:59-60  
\li1 Rómu 12:14-21  
\li1 Éfésási 4:31-32  
\li1 Kórósi 3:31  
\li1 1 Tésárónika 5:15  
\li1 1 Pítaa 2:23  
\b  
\p \k Taakisi-óntánkón-ááí. \k*  
\li1 Mátíyu 5:46  
\pi1 Rómu-kamani-waasi Yúndaa-waasisafesa taakisi-  
\pi1 óntámbá síméro sésa tuwímbai-Yundaa-waasi minkísáú tímúwasa taakisi-óntámbá maimaésa nómba kesáfé-óntánkwáráꞌá maimaésa taakisi-óntámbá Rómu-kamani-waasi mátimesa umén-óntámbá kesáfésa maiyésa minóntánkákémbá óntawaraꞌ-waasi-iꞌa uwasá fíꞌon-Yundaa-waasi tíyámba uwátínkaraawe.  
\b  
\p \k Waántáwanko Ísuntafena sáwíꞌa ínkwae séna maꞌmáímo awánarain-aai \k* maampímbá wéraifo toráumai ísáaro.  
\li1 Mátíyu 4:1-11  
\li1 Mááka 1:12-13  
\li1 Rúku 4:1-13  
\b  
\p \k Wayó-kísáúmó máén-kwaasi\k*  
\li1 1 Kórinti 7:21  
\li1 Kórósi 3:22  
\pi1 Póíye iyánémó kesáfésamo méyánontemba naaófáꞌá waási méyánúmai métínkówasa miwítí wayó-kísáú máúwasa ímba méyámbá tímúwasa ándá-waasiyaamba úwoi-kisau maéꞌómbaniye. Minááí numa-áímpínkémbá sleviye wésewe.  