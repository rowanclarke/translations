\id MAT - Biblica® Open Igbo Contemporary Bible 2020
\h Matiu
\toc1 Oziọma Matiu
\toc2 Matiu
\toc3 Mat
\mt1 Oziọma Matiu
\c 1
\s1 Usoro ọmụmụ Jisọs onye bụ Kraịst ahụ
\li4 
\v 1 Nke a bụ ndekọ usoro ọmụmụ Jisọs onye bụ Kraịst, nwa Devid, nwa Ebraham.
\b
\li1 
\v 2 Ebraham mụrụ Aịzik,
\li1 Aịzik amụọ Jekọb,
\li1 Jekọb amụọ Juda na ụmụnne ya.
\li1 
\v 3 Juda mụtara Perez na Zera site na Tama,
\li1 Perez mụrụ Hezrọn,
\li1 Hezrọn amụọ Aram.
\li1 
\v 4 Aram mụrụ Aminadab,
\li1 Aminadab mụrụ Nashọn,
\li1 Nashọn amụọ Salmọn.
\li1 
\v 5 Salmọn bụ nna Boaz, site na nwunye ya Rehab,
\li1 Boaz mụrụ Obed, site na nwunye ya Rut,
\li1 Obed amụọ Jesi.
\li1 
\v 6 Jesi amụọ Devid, bụ eze.
\b
\li1 Devid mụrụ Solomọn site na nwunye ya Ụraya.
\li1 
\v 7 Solomọn mụrụ Rehoboam,
\li1 Rehoboam amụọ Abija,
\li1 Abija amụọ Esa.
\li1 
\v 8 Esa mụrụ Jehoshafat,
\li1 Jehoshafat amụọ Joram,
\li1 Joram amụọ Ụzaịa.
\li1 
\v 9 Ụzaịa mụrụ Jotam,
\li1 Jọtam amụọ Ehaz,
\li1 Ehaz amụọ Hezekaya.
\li1 
\v 10 Hezekaya mụrụ Manase,
\li1 Manase amụọ Emọn,
\li1 Emọn amụọ Josaya.
\li1 
\v 11 Mgbe e mere ka ha gaa biri nʼala Babilọn ka Josaya mụrụ Jekonaya na ụmụnne ya.
\b
\li4 
\v 12 Mgbe ha si Babilọn lọta
\li1 Jekonaya mụrụ Shealtiel,
\li1 Shealtiel amụọ Zerubabel.
\li1 
\v 13 Zerubabel mụrụ Abiud,
\li1 Abiud amụọ Eliakịm,
\li1 Eliakịm amụọ Azoa.
\li1 
\v 14 Azoa mụrụ Zadọk,
\li1 Zadọk amụọ Akịm,
\li1 Akịm amụọ Eliud.
\li1 
\v 15 Eliud mụrụ Elieza,
\li1 Elieza amụọ Matan,
\li1 Matan amụọ Jekọb.
\li1 
\v 16 Jekọb mụrụ Josef onye bụ di Meri nne Jisọs, onye a na-akpọ Kraịst.
\b
\li4 
\v 17 Ya mere, site nʼEbraham ruo na Devid, e nwere ọgbọ iri na anọ. Ma site nʼoge Devid ruo mgbe a dọọrọ ha nʼagha gaa Babilọn, e nwere ọgbọ iri na anọ. Sitekwanụ nʼoge ahụ ruo mgbe a mụrụ Kraịst bụkwa ọgbọ iri na anọ.
\s1 Josef anabata Jisọs dịka nwa ya nwoke
\p 
\v 18 Otu a ka ọmụmụ Jisọs, onye a na-akpọ Kraịst\f + \fr 1:18 \ft Maọbụ, \fqa Onye nzọpụta\f* siri dị: Nne ya Meri bụ onye e kwenyere na ọ ga-alụ Josef, ma tupu ha ebikọọ ọnụ a chọpụtara na Meri di ime site na Mmụọ Nsọ.
\v 19 Ma Josef di ya bụ onye ezi omume, ọ chọghị imenye ya ihere, nʼihi ya, o zubere ịchụ ya na nzuzo.
\p 
\v 20 Mgbe Josef nwechara mkpebi a, mmụọ ozi Onyenwe anyị bịakwutere ya na nrọ sị ya, “Josef nwa Devid, atụla egwu ịkpọrọ Meri ka ọ bụrụ nwunye gị, nʼihi na nwa ahụ ọ dị ime ya sitere nʼike Mmụọ Nsọ.
\v 21 Ọ ga-amụkwa nwa nwoke, onye ị ga-akpọ aha ya Jisọs,\f + \fr 1:21 \fq Jisọs \ft nke a bụ otu ndị Griik si akpọ \fqa Joshua \ft nke pụtara \nd Onyenwe anyị\nd* na-azọpụta.\f* nʼihi na ọ ga-azọpụta ndị nke ya site na mmehie ha.”
\p 
\v 22 Ihe ndị a mere iji mezuo ihe ahụ Onyenwe anyị kwuru site nʼọnụ onye amụma ya sị,
\v 23 “Lee, nwaagbọghọ ahụ na-amaghị nwoke ga-atụrụ ime, mụọ nwa nwoke. Ha ga-akpọ aha ya Ịmanụel”\f + \fr 1:23 \ft \xt Aịz 7:14\xt*\f* (nke bụ ma asụgharịa ya, “Chineke nọnyeere anyị”).
\p 
\v 24 Mgbe Josef si nʼụra teta, o mere dịka mmụọ ozi Onyenwe anyị nyere ya nʼiwu. Ọ kpọọrọ Meri ka ọ bụrụ nwunye ya.
\v 25 Ma ha abụọ edinakọghị tutu ruo mgbe ọ mụsịrị nwa nwoke, onye ọ kpọrọ aha ya Jisọs.
\c 2
\s1 Ọbịbịa ndị amamihe
\p 
\v 1 Mgbe a mụchara Jisọs na Betlehem nke Judịa nʼoge Herọd bụ eze, ndị amamihe si ọwụwa anyanwụ bịaruru Jerusalem,
\v 2 na-ajụ ajụjụ sị, “Olee ebe ọ nọ, bụ onye a mụrụ ịbụ eze ndị Juu? Anyị hụrụ kpakpando ya\f + \fr 2:2 \fq Kpakpando ya \ft mgbe ọ walitere\f* nʼọwụwa anyanwụ, ma bịa ịkpọ isiala nye ya.”
\p 
\v 3 Mgbe eze Herọd nụrụ nke a, obi lọrọ ya mmiri nke ukwuu, ya na ndị niile bi na Jerusalem.
\v 4 Mgbe ọ kpọkọtara ndịisi nchụaja na ndị ozizi iwu niile, ọ jụrụ ha, olee ebe e kwuru na a ga-amụ Kraịst\f + \fr 2:4 \ft Maọbụ, \fqa Onye nzọpụta\f* ahụ.
\v 5 Ha zara ya sị, “Na Betlehem nke Judịa. Nʼihi na otu a ka onye amụma ahụ dere nʼakwụkwọ sị,
\q1 
\v 6 “ ‘Ma gị onwe gị, Betlehem, dị nʼala Juda,
\q2 ị dịghị nta karịchasịa nʼetiti ndị ọchịchị Juda,
\q1 nʼihi na ọ bụ site na gị ka onye ọchịchị ga-esi pụta,
\q2 onye ga-achị ndị nke m Izrel.’\f + \fr 2:6 \ft \xt Mai 5:2\xt*\f*”
\p 
\v 7 Mgbe ahụ Herọd kpọrọ ndị amamihe ahụ na nzuzo jụpụta ha banyere oge kpakpando ahụ ji pụta ìhè.
\v 8 O zipụrụ ha ije Betlehem sị ha, “Gaanụ lee anya nke ọma chọpụta ebe nwantakịrị ahụ nọ. Mgbe unu chọtara ya, bịanụ mee ka m mara, ka m gaakwa kpọọ isiala nye ya.”
\p 
\v 9 Mgbe ha nụrụ okwu eze, ha pụrụ gawa, ma kpakpando ahụ ha hụrụ nʼọwụwa anyanwụ pụtakwara ọzọ, na-aga nʼihu ha ruo mgbe ọ bịara guzo nʼelu ebe nwantakịrị ahụ nọ.
\v 10 Ha ṅụrịrị ọṅụ nke ukwuu mgbe ha hụrụ kpakpando ahụ.
\v 11 Ka ha banyere nʼụlọ ahụ, ha hụrụ nwantakịrị ahụ na nne ya Meri, ha gburu ikpere nʼala ma kpọọrọ ya isiala. Ha meghere akpa akụ ha nye ya onyinye ọlaedo na ọkpụrụkpụ eso osisi na-esi isi ụtọ a na-akpọ frankisens,\f + \fr 2:11 \ft Maọbụ, \fqa mgbaisiọma\f* ya na máá.\f + \fr 2:11 \ft Maọbụ, \fqa mgba ilu\f*
\v 12 Nʼihi na a dọrọ ha aka na ntị na nrọ ka ha ghara ịlaghachikwuru Herọd, ha sitere nʼụzọ ọzọ laghachi obodo ha.
\s1 Mgbapụ gaa nʼala Ijipt
\p 
\v 13 Mgbe ndị amamihe ahụ lasịrị, mmụọ ozi Onyenwe anyị mere ka Josef hụ ya na nrọ, ọ sịrị ya, “Bilie ọsịịsọ kpọrọ nwantakịrị a na nne ya gbalaa Ijipt. Alọghachikwala tutu ruo mgbe m ga-agwa gị, nʼihi na Herọd na-achọ nwantakịrị a ka o gbuo ya.”
\p 
\v 14 Nʼoge abalị, Josef biliri kpọrọ Meri na nwantakịrị ahụ gbalaa Ijipt.
\v 15 Ebe ahụ ka ha nọgidere tutu ruo mgbe Herọd nwụrụ. Nke a mere ka okwu ahụ Onyenwe anyị kwuru site nʼọnụ onye amụma mezuo. “Ọ bụkwa site nʼIjipt ka m kpọpụtara nwa m.”\f + \fr 2:15 \ft \xt Hos 11:1\xt*\f*
\p 
\v 16 Iwe were Herọd nke ukwuu mgbe ọ chọpụtara na ndị amamihe ahụ aghọọla ya aghụghọ. Nʼihi ya, o nyere iwu banyere Betlehem na obodo nta ndị ọzọ gbara ya gburugburu, ka ha gbuo ụmụntakịrị niile nọ nʼobodo ndị a, bụ ndị gbara site nʼafọ abụọ gbadaa, dị ka ihe ọ nụtara site nʼọnụ ndị amamihe si dị.
\v 17 E sitekwara otu a mezuo amụma ahụ Jeremaya buru sị,
\q1 
\v 18 “A nụrụ otu olu na Rema,
\q2 ịkwa akwa na oke iru ụjụ dị,
\q1 Rechel na-akwa akwa nʼihi ụmụ ya;
\q2 ọ dịghị nkasiobi ọbụla dịrị ya,
\q2 nʼihi na ha adịghịkwa.”\f + \fr 2:18 \ft \xt Jer 31:15\xt*\f*
\s1 Nlọghachi na Nazaret
\p 
\v 19 Mgbe Herọd nwụrụ, mmụọ ozi Onyenwe anyị bịakwutere Josef na nrọ nʼIjipt
\v 20 sị ya, “Bilie, kpọrọ nwantakịrị ahụ na nne ya laghachi nʼala Izrel nʼihi na ndị na-achọ igbu ya anwụọla.”
\p 
\v 21 Ya mere, o biliri, kpọọrọ nwantakịrị ahụ na nne ya, laghachi nʼala Izrel.
\v 22 Mgbe ọ nụrụ na eze ọhụrụ gbanwere Herọd na Judịa bụ nwa ya a na-akpọ Akelus,\f + \fr 2:22 \fq Akelus \ft Onye ketara ịchị otu ụzọ nʼụzọ atọ nʼalaeze Herọd.\f* egwu tụrụ Josef ịlaghachi ebe ahụ. Ma nʼihi na adọwo ya aka na ntị na nrọ, ọ wezugara onwe ya gaa nʼakụkụ Galili.
\v 23 Ọ gara biri nʼobodo a na-akpọ Nazaret. E sitekwara otu a mezuo okwu ọnụ ndị amụma sị na, “A ga-akpọ ya onye Nazaret.”
\c 3
\s1 Nkwusa nke Jọn
\p 
\v 1 Nʼoge ahụ, Jọn omee baptizim bịara na-ezisa ozi nʼọzara Judịa. Isi okwu ya bụ,
\v 2 “Chegharịanụ, nʼihi na alaeze eluigwe dị nso.”
\v 3 Nʼihi na nwoke a bụ onye e kwuru okwu banyere ya site nʼọnụ onye amụma Aịzaya sị,
\q1 “Otu onye na-eti mkpu nʼọzara, na-asị,
\q1 ‘Dozienụ ụzọ maka Onyenwe anyị,
\q2 meenụ ka okporoụzọ ya guzozie.’ ”\f + \fr 3:3 \ft \xt Aịz 40:3\xt*\f*
\p 
\v 4 Jọn yi uwe e ji ajị ịnyịnya kamel mee. O kekwara ihe okike ukwu nke akpụkpọ anụ nʼukwu ya. Nri ya bụ igurube na mmanụ aṅụ.
\v 5 Nʼoge ahụ, ndị mmadụ sitere Jerusalem, na Judịa niile, nʼala niile dị Jọdan gburugburu, na-apụkwuru ya.
\v 6 Mgbe ha na-ekwupụta mmehie ha, o mere ha baptizim nʼosimiri Jọdan.
\p 
\v 7 Ma mgbe ọhụrụ ọtụtụ ndị Farisii na ndị Sadusii ka ha na-abịa ka e mee ha baptizim, ọ sịrị ha, “Unu ụmụ ajụala, onye dọrọ unu aka na ntị sị unu gbanarị ọnụma nke na-abịa?
\v 8 Mịanụ mkpụrụ na-egosipụta nchegharị unu.
\v 9 Unu echekwala na unu pụrụ ị sị nʼime onwe unu, ‘Anyị nwere Ebraham dịka nna,’ nʼihi na Chineke pụrụ isite na nkume ndị a mepụtara Ebraham ụmụ.
\v 10 Ma ugbu a atụkwasịla anyụike na mgbọrọgwụ osisi niile. Osisi ọbụla nke na-adịghị amị ezi mkpụrụ ka a ga-egbutu, tụba ya nʼime ọkụ.
\p 
\v 11 “Mụ onwe m ji mmiri eme unu baptizim nʼihi nchegharị, ma onye dị ike karịa m na-abịa. Onye m na-erughị ịchịta akpụkpọụkwụ ya. Ọ ga-eji Mmụọ Nsọ na ọkụ were mee unu baptizim.
\v 12 Ihe ịfụcha ọka ya dị ya nʼaka, ọ ga-azacha ebe ịzọcha ọka ya nke ọma, chịkọta mkpụrụ ọka wiiti tinye ha nʼọba, ma jiri ọkụ a na-apụghị imenyụ emenyụ rechapụ igbugbo ọka.”
\s1 Jọn emee Jisọs baptizim
\p 
\v 13 Mgbe ahụ, Jisọs sitere na Galili bịa nʼosimiri Jọdan ka Jọn mee ya baptizim.
\v 14 Ma Jọn chọrọ igbochi ya, sị, “Ọ bụ m kwesiri ịbịakwute gị ka ị mee m baptizim. Gịnị mere i ji abịakwute m?”
\p 
\v 15 Ma Jisọs zara ya sị, \wj “Kwere ka ọ dịrị otu a ugbu a, o kwesiri ka anyị mezuo ezi omume niile.”\wj* Mgbe ahụ Jọn kwenyere.
\p 
\v 16 Ngwangwa e mechara Jisọs baptizim, o sitere na mmiri ahụ rịpụta. Nʼotu oge ahụ, eluigwe meghere, Jọn hụrụ Mmụọ nke Chineke ka o si nʼelu fedata dị ka nduru na-ebekwasị Jisọs nʼisi.
\v 17 Otu olu sitere nʼeluigwe kwuo okwu sị, “Onye a bụ Ọkpara m, onye m hụrụ nʼanya. Ihe ya dị m ezi mma.”
\c 4
\s1 Ọnwụnwa a nwara Jisọs nʼọzara
\p 
\v 1 Emesịa, Mmụọ Nsọ duuru Jisọs baa nʼọzara ka ekwensu nwaa ya ọnwụnwa.
\v 2 Mgbe o busiri ọnụ iri ụbọchị anọ ehihie na abalị, agụụ gụrụ ya nke ukwuu.
\v 3 Mgbe ahụ onye ọnwụnwa ahụ bịakwutere ya sị, “Ọ bụrụ na ị bụ Ọkpara Chineke, gwa nkume ndị a ka ha ghọọ achịcha.”
\p 
\v 4 Ma Jisọs zara, \wj “E dere ya nʼakwụkwọ nsọ sị, ‘Ọ bụghị naanị site na achịcha\wj*\f + \fr 4:4 \fq Achịcha \ft nwere ike bụrụ \fqa nri\f*\wj ka mmadụ si adị ndụ, kama site nʼokwu niile si nʼọnụ Chineke pụta.’\wj*\f + \fr 4:4 \ft Okwu a dịkwa nʼakwụkwọ \xt Dit 8:3\xt*\ft .\f*\wj ”\wj*
\p 
\v 5 Mgbe ahụ, ekwensu duuru ya baa nʼobodo nsọ ahụ, mee ka o guzo nʼebe dịkarịsịrị elu nke ụlọnsọ ukwu,
\v 6 sị ya, “Ọ bụrụ na ị bụ Ọkpara Chineke, site nʼebe a tụda onwe gị nʼala. Nʼihi na e dere ya nʼakwụkwọ nsọ sị,
\q1 “ ‘Ọ ga-enye ndị mmụọ ozi ya iwu banyere gị,
\q2 ha ga-ebuli gị elu nʼaka ha
\q2 ka ị ghara ịkpọbi ụkwụ gị na nkume.’\f + \fr 4:6 \ft \xt Abụ 91:11,12\xt*\f*”
\p 
\v 7 Ma Jisọs zara sị ya, \wj “E deela ya nʼakwụkwọ nsọ sị, ‘Ị gaghị anwa Onyenwe gị na Chineke gị ọnwụnwa.’\wj*\f + \fr 4:7 \ft Gụọkwa ya nʼakwụkwọ \xt Dit 6:16\xt*\ft .\f*\wj ”\wj*
\p 
\v 8 Ọzọkwa, ekwensu kpọọrọ ya gaa nʼelu ugwu dị elu, gosi ya alaeze niile nke ụwa na ebube ha.
\v 9 Ọ sịrị ya, “Aga m enye gị ha niile ma ọ bụrụ na ị daa nʼala kpọọ isiala nye m.”
\p 
\v 10 Ma Jisọs sịrị ya, \wj “Si nʼebe m nọ pụọ, ekwensu. Nʼihi na akwụkwọ nsọ kwuru sị, ‘Ọ bụ naanị Onyenwe anyị Chineke gị ka ị ga-akpọ isiala nye, naanị ya ka ị ga-efekwa.’\wj*\f + \fr 4:10 \ft Nke a dịkwa nʼakwụkwọ \xt Dit 6:13\xt*\ft .\f*\wj ”\wj*
\p 
\v 11 Mgbe ahụ ekwensu hapụrụ ya laa. Ndị mmụọ ozi bịakwutere ya, nọnyere ya, na-ejere ya ozi.
\s1 Jisọs ebido ọrụ nkwusa
\p 
\v 12 Mgbe Jisọs nụrụ na e tinyela Jọn nʼụlọ mkpọrọ, ọ pụrụ gaa Galili.
\v 13 Emesịa, ọ hapụrụ Nazaret gaa biri na Kapanọm, bụ obodo dị nʼakụkụ osimiri Galili. Ọ dị nso nʼoke ala Zebụlọn na Naftalị.
\v 14 Nʼụzọ dị otu a, amụma ahụ Aịzaya buru mezuru. Amụma nke sịrị,
\q1 
\v 15 “Ala Zebụlọn na ala Naftalị,
\q2 nke dị nʼakụkụ osimiri, nʼofe Jọdan,
\q2 Galili nke ndị mba ọzọ,
\q1 
\v 16 ndị nọ nʼọchịchịrị
\q2 ahụla ìhè dị ukwuu.
\q1 Ndị bi nʼala onyinyo ọnwụ
\q2 ka ìhè nwukwasịrị.”\f + \fr 4:16 \ft \xt Aịz 9:1,2\xt*\f*
\p 
\v 17 Site nʼoge ahụ gaa nʼihu Jisọs bidoro na-ekwusa na-asị, \wj “Chegharịanụ, nʼihi na alaeze eluigwe dị nso.”\wj*
\s1 Ọkpụkpọ ndị na-eso ụzọ ya
\p 
\v 18 Ma mgbe Jisọs na-agafe nʼakụkụ osimiri Galili, ọ hụrụ ụmụnne abụọ, Saimọn onye a na-akpọ Pita, na Andru nwanne ya, ndị ọrụ ha bụ ịkụ azụ, ebe ha nọ nʼụgbọ mmiri na-akụ azụ.
\v 19 Ọ sịrị ha, \wj “Bịanụ soro m. Aga m eme unu ndị ọkụ na-akụta mmadụ.”\wj*
\v 20 Ha hapụrụ ụgbụ azụ ha otu mgbe ahụ soro ya.
\p 
\v 21 Mgbe ọ gara nʼihu nke nta, ọ hụrụ ụmụnne abụọ ọzọ, Jemis nwa Zebedi na Jọn nwanne ya, ebe ha na nna ha Zebedi nọ nʼime ụgbọ mmiri na-ekezi ụgbụ azụ ha. Ọ kpọkwara ha,
\v 22 ngwangwa ha hapụrụ ụgbọ ha na nna ha soro ya.
\s1 Jisọs agwọọ ndị ọrịa
\p 
\v 23 Jisọs jegharịrị nʼobodo niile nke Galili, na-akụzi ihe nʼụlọ nzukọ niile ha, na-ekwusakwa oziọma nke alaeze ahụ. Ọ na-agwọkwa ọrịa na nrịa nrịa niile dị iche iche nʼetiti ndị ahụ.
\v 24 Akụkọ banyere ya gbasara jezuo akụkụ Siria niile. Mgbe ahụ ọtụtụ ndị mmadụ kpọtaara ya ndị niile ahụ na-esighị ike, ndị na-arịa ụdị ọrịa dị iche iche, ndị nwere ahụ mgbu, na ndị mmụọ ọjọọ na-esogbu, na ndị akwụkwụ, na ndị akụkụ ahụ ha kpọnwụrụ akpọnwụ. Ọ gwọkwara ha niile.
\v 25 Ọtụtụ mmadụ sitere na Galili, Dekapọlịs,\f + \fr 4:25 \ft Dekapọlịs pụtara Obodo iri.\f* Jerusalem, Judịa na nʼofe osimiri Jọdan, soro ya.
\c 5
\s1 Nkwusa banyere alaeze ọhụrụ ahụ
\p 
\v 1 Mgbe Jisọs hụrụ igwe mmadụ ahụ, ọ rigooro nʼelu ugwu. Mgbe ọ nọdụrụ ala, ndị na-eso ụzọ ya bịakwutere ya,
\v 2 o bido ikuziri ha ihe.
\s1 Okwu banyere ndị ngọzị na-adịrị
\m Ọ sịrị:
\q1 
\v 3 \wj “Ngọzị na-adịrị ndị bụ ogbenye nʼime mmụọ,\wj*
\q2 \wj nʼihi na alaeze eluigwe bụ nke ha.\wj*
\q1 
\v 4 \wj Ngọzị na-adịrị ndị na-eru ụjụ,\wj*
\q2 \wj nʼihi na a ga-akasị ha obi.\wj*
\q1 
\v 5 \wj Ngọzị na-adịrị ndị dị nwayọọ nʼobi,\wj*
\q2 \wj nʼihi na ha ga-eketa ụwa.\wj*
\q1 
\v 6 \wj Ngọzị na-adịrị ndị agụụ ezi omume na-agụ,\wj*
\q2 \wj nʼihi na ndị ahụ ka afọ ga-eju.\wj*
\q1 
\v 7 \wj Ngọzị na-adịrị ndị na-eme obi ebere,\wj*
\q2 \wj nʼihi na ha ka a ga-emere ebere.\wj*
\q1 
\v 8 \wj Ngọzị na-adịrị ndị dị ọcha nʼobi,\wj*
\q2 \wj nʼihi na ha ga-ahụ Chineke anya.\wj*
\q1 
\v 9 \wj Ngọzị na-adịrị ndị na-eme ka udo dị nʼetiti mmadụ na ibe ya,\wj*
\q2 \wj nʼihi na a ga-akpọ ha ụmụ Chineke.\wj*
\q1 
\v 10 \wj Ngọzị na-adịrị ndị a na-emegbu nʼihi ezi omume,\wj*
\q2 \wj nʼihi na alaeze eluigwe bụ nke ha.\wj*
\p 
\v 11 \wj “Ngọzị na-adịrị unu mgbe ndị mmadụ na-akọcha unu, na-emegbu unu, ma na-ekwukwa okwu ọjọọ na ụgha niile dị iche iche megide unu nʼihi m.\wj*
\v 12 \wj Ṅụrịanụ ọnụ, nwekwanụ obi ụtọ, nʼihi na ụgwọ ọrụ unu dị ukwuu nʼeluigwe. Nʼihi na nʼụzọ dị otu a ka ha sogburu ndị amụma ndị buru unu ụzọ.\wj*
\s1 Nnu na ìhè
\p 
\v 13 \wj “Unu bụ nnu nke ụwa, ma ọ bụrụ na nnu adịghị atọkwa ụtọ, a ga-eji gịnị mee ka ọ tọọ ụtọ ọzọ? Ọ bakwaghị uru ọbụla, ma ọ bụghị naanị itufu ya, ka ndị mmadụ zọọ ya ụkwụ.\wj*
\p 
\v 14 \wj “Unu bụ ihe nke ụwa. Unu dị ka obodo e wuru nʼelu ugwu nke a na-apụghị izo ezo.\wj*
\v 15 \wj Ndị mmadụ adịghị amụnye oriọna dọnye ya nʼokpuru igbe, kama a na-adọkwasị ya nʼelu ihe ịdọba oriọna, ka o nye ndị niile nọ nʼụlọ ahụ ìhè.\wj*
\v 16 \wj Ya mere, kwerenụ ka ìhè unu nwuo nye mmadụ niile, ka ndị mmadụ hụ ọrụ ọma unu, tookwa Nna unu nke bi nʼeluigwe.\wj*
\s1 Mmezu iwu
\p 
\v 17 \wj “Unu echela na m bịara ịkagbu iwu Mosis, maọbụ ozizi ndị amụma. Abịaghị m ịkagbu akagbu, kama abịara m imezu ha.\wj*
\v 18 \wj Nʼezie, agwa m unu, na tutu eluigwe na ụwa agabiga, ọ dịghị otu mkpụrụ edemede ọbụla dị nta, ọ bụladị nke dịkarịsịrị nta, nke a ga-esi nʼIwu a wepụ ruo mgbe ha niile ga emezu.\wj*
\v 19 \wj Nʼihi ya, onye ọbụla nke ga-emebi otu nʼime iwu ndị a, ọ bụladị nke dịkarịsịrị nta, ma kuziekwara ndị ọzọ ime otu ahụ, a ga-agụ onye ahụ nʼonye dịkarịsịrị nta nʼalaeze eluigwe. Ma onye na-ezi ụmụ mmadụ ka ha debe iwu ahụ, ma na-emekwa okwu ndị ahụ nʼonwe ya, a ga-akpọ ya onye dị ukwuu nʼalaeze eluigwe.\wj*
\v 20 \wj Ka m dọọ unu aka na ntị. Ọ bụrụ na ezi omume unu akarịghị ezi omume ndị Farisii na ndị ozizi iwu, unu apụghị ịba nʼalaeze eluigwe ma ọlị.\wj*
\s1 Ozizi banyere igbu mmadụ
\p 
\v 21 \wj “Unu nụrụ na-agwara ndị mmadụ nʼoge gara aga, sị, ‘Onye egbula mmadụ, onye ọbụla gburu mmadụ a ga-ekpe ya ikpe.’\wj*\f + \fr 5:21 \ft \xt Ọpụ 20:13\xt*\f*
\v 22 \wj Ma asị m unu, na onye ọbụla nke na-ewe iwe megide nwanna ya, na-enyefe onwe ya nʼaka ikpe. Onye ọbụla nke na-akpọ nwanna ya ‘\tl Raka\tl*,’ ya bụ Onye iberiibe,\wj*\f + \fr 5:22 \ft Ọfọ ogori, nʼokwu nlelị anya\f*\wj ga-aza ajụjụ nʼụlọikpe. Ọzọkwa, onye ọbụla nke kpọrọ nwanne ya,\wj*\f + \fr 5:22 \ft Nke a pụtara \fqa nwanna nʼime Kraịst\f*\wj ‘Onye nzuzu,’\wj*\f + \fr 5:22 \ft Maọbụ, \fqa Onye na-enweghị uche\f*\wj na-edo onwe ya ịba nʼọkụ ala mmụọ.\wj*
\p 
\v 23 \wj “Ya mere, ọ bụrụ na ị gaa inye onyinye gị nʼebe ịchụ aja, ma cheta nʼebe ahụ na gị na nwanne gị adịghị nʼudo,\wj*
\v 24 \wj hapụ onyinye gị nʼebe ịchụ aja, laa ka gị na nwanne gị kpezie. Mgbe unu mere udo, laghachi bịa nye onyinye gị.\wj*
\p 
\v 25 \wj “Mee ọsịịsọ ka gị na onye kpọ gị eje ụlọ ikpe kpezie, mgbe ọ na-eburubeghị ikpe gị na ya jee nʼaka ọkaikpe, onye ga-enyefe gị nʼaka ndị nche, ma eleghị anya etinye gị nʼụlọ mkpọrọ.\wj*
\v 26 \wj Nʼezie, agwa m gị, ị gaghị e si nʼebe ahụ pụta ruo mgbe ị kwụghachiri kobo niile i ji.\wj*\f + \fr 5:26 \ft Maọbụ, \fqa ụgwọ niile\f*
\s1 Ịkwa iko
\p 
\v 27 \wj “Unu nụrụ na e kwuru sị, ‘Akwala iko.’\wj*\f + \fr 5:27 \ft \xt Ọpụ 20:14\xt*\f*
\v 28 \wj Ma asị m unu, onye ọbụla lere nwanyị anya site na-agụụ ịkwa iko emeelarị mmehie ịkwa iko nʼime obi ya megide nwanyị ahụ.\wj*
\v 29 \wj Nʼihi nke a, ọ bụrụ na anya aka nri gị na-eme ka i jehie, ghụpụ ya tufuo. Ọ kaara gị mma na i tufuru otu akụkụ ahụ gị baa nʼalaeze karịa na i ji ahụ zuruoke baa nʼọkụ ala mmụọ.\wj*
\v 30 \wj Ọ bụrụ na aka nri gị na-eme ka i jehie, gbupụ ya tufuo. Ọ kaara gị mma na i tufuru otu akụkụ ahụ gị ma baa nʼalaeze eluigwe, karịa na i ji ahụ zuruoke ma baa nʼọkụ ala mmụọ.\wj*
\s1 Ịgba alụkwaghị m
\p 
\v 31 \wj “E kwukwara sị, ‘Onye ọbụla chọrọ ịgbara nwunye ya alụkwaghị m, ga-ebu ụzọ dee akwụkwọ alụkwaghị m nye nwunye ya.’\wj*\f + \fr 5:31 \ft \xt Dit 24:1\xt*\f*
\v 32 \wj Ma asị m unu, onye ọbụla gbara nwunye ya alụkwaghị m, ma ọ bụghị nʼihi ịkwa iko, ọ na-etinye nwanyị ahụ nʼọnọdụ ga-eme ka ọ kwaa iko. Ọ bụrụ na nwanyị ahụ alụọ di ọzọ, nwoke ahụ lụrụ nwanyị ahụ na-emekwa mmehie ịkwa iko.\wj*
\s1 Ịṅụ iyi
\p 
\v 33 \wj “Ọzọkwa, unu nụrụ na a gwara ndị mmadụ nʼoge gara aga sị, ‘Aṅụla iyi ụgha, kama mezuo ihe niile unu ṅụrụ nʼiyi nye Onyenwe anyị.’\wj*
\v 34 \wj Ma asị m unu aṅụla iyi ọbụla. Ejikwala eluigwe aṅụ iyi nʼihi na eluigwe bụ ebe ocheeze Chineke dị.\wj*
\v 35 \wj Ejikwala ụwa aṅụ iyi nʼihi na ụwa bụ ebe mgbakwasị ụkwụ ya. Ejikwala Jerusalem aṅụ iyi nʼihi na ọ bụ obodo Eze ukwu ahụ.\wj*
\v 36 \wj Ejikwala isi gị aṅụ iyi nʼihi na ị pụghị ime ka otu agịrị isi gị dị ọcha maọbụ dị oji.\wj*
\v 37 \wj Aṅụla iyi ọbụla. Kama ka okwu unu bụrụ ‘E’ maọbụ ‘Ee’; ihe ọbụla gafere nke a sitere nʼaka ajọ onye ahụ.\wj*
\s1 Ịbọ ọbọ
\p 
\v 38 \wj “Unu anụla na e kwuru sị, ‘Ọ bụ anya ka a kụkpọrọ, anya nʼọnọdụ anya. Ọ bụrụkwa otu eze ka e tipụrụ, eze nʼọnọdụ eze.’\wj*\f + \fr 5:38 \ft \xt Ọpụ 21:24; Lev 24:20; Dit 19:21\xt*\f*
\v 39 \wj Ma ana m asị unu eguzogidela onye bụ ajọ onye. Kama ọ bụrụ na mmadụ amaa gị ụra na ntị aka nri, tụgharịara ya ntị nke ọzọ.\wj*
\v 40 \wj Ọ bụrụ na mmadụ agbaa gị akwụkwọ nʼụlọikpe, ka ọ nara gị uwe ime gị, nyekwa ya uwe nke elu gị.\wj*
\v 41 \wj Ọ bụrụ na mmadụ esite nʼike chọọ ka i soro ya gaa puku nzọ ụkwụ atọ, soro ya gaa puku nzọ ụkwụ isii.\wj*
\v 42 \wj Nye onye ọbụla rịọrọ gị ihe. Achụghachikwala ndị na-abịa ka i binye ha ego.\wj*
\s1 Ịhụ ndị iro nʼanya
\p 
\v 43 \wj “Unu nụrụ na e kwuru sị, ‘Hụnụ ndị agbataobi unu nʼanya, ma kpọkwanụ ndị iro unu asị.’\wj*\f + \fr 5:43 \ft \xt Lev 19:18\xt*\f*
\v 44 \wj Ma asị m unu, hụnụ ndị iro unu nʼanya, kpekwaaranụ ndị na-esogbu unu ekpere.\wj*
\v 45 \wj Nke a ga-eme ka unu bụrụ ụmụ nke Nna unu bi nʼeluigwe, onye na-eme ka anwụ mụọrọ ndị ọma na ndị ọjọọ, na-emekwa ka mmiri zooro ndị ezi omume na ndị ajọ omume.\wj*
\v 46 \wj Ọ bụrụ naanị ndị hụrụ unu nʼanya ka unu na-ahụ nʼanya, gịnị ga-abụ ụgwọ ọrụ unu? Ọ bụladị ndị ọna ụtụ na-emekwa otu a.\wj*
\v 47 \wj Ọ bụrụkwa na unu na-ekele naanị ndị enyi unu ekele, ọ dịghị ihe ọbụla dị iche nʼebe unu na ndị ọzọ nọ. Nʼihi na ndị na-amaghị Chineke na-emekwa otu ahụ.\wj*
\v 48 \wj Ya mere, unu kwesiri izuoke nʼịrụ ọrụ ọma, dịka Nna unu bi nʼeluigwe si zukwaa oke.\wj*
\c 6
\s1 Ozizi banyere inye onyinye
\p 
\v 1 \wj “Kpacharanụ anya ka unu ghara ime ezi omume unu naanị ka ndị mmadụ hụ unu. Nʼihi na unu mee nke a, unu agaghị enweta ụgwọ ọrụ ọbụla site nʼaka Nna unu bi nʼeluigwe.\wj*
\p 
\v 2 \wj “Unu afụla opi mgbe unu na-enye ndị nọ na mkpa onyinye, nʼihi na otu a ka ndị ihu abụọ na-eme nʼụlọ nzukọ na nʼokporoụzọ, ka ndị mmadụ too ha. Nʼezie, ana m agwa unu, ha anatala ụgwọ ọrụ ha nʼizuoke.\wj*
\v 3 \wj Mgbe unu chọrọ ịrụ ọrụ ebere, meenụ ya na nzuzo. Ekwela ka aka ekpe gị mata ihe aka nri gị na-achọ ime.\wj*
\v 4 \wj Ka onyinye gị bụrụ na nzuzo. Mgbe ahụ, Nna gị, onye na-ahụ ihe dị na nzuzo ga-akwụghachi gị.\wj*
\s1 Ozizi banyere ekpere
\p 
\v 5 \wj “Mgbe ọbụla unu chọrọ ikpe ekpere, unu emela dị ka ndị ihu abụọ, nʼihi na ha hụrụ iguzo nʼime ụlọ ekpere, nakwa nʼakụkụ ụzọ nʼanya na-ekpe ekpere, ebe ndị mmadụ ga-ahụ ha. Nʼezie, agwa m unu, ha anatala ụgwọ ọrụ ha nʼebe o zuruoke.\wj*
\v 6 \wj Kama, mgbe unu chọrọ ikpe ekpere, baanụ nʼime ime ụlọ unu. Mechiekwanụ ụzọ unu, kpọkuonụ Nna unu nʼekpere na nzuzo. Mgbe ahụ Nna unu, onye na-ahụ ihe e mere na nzuzo, ga-enye unu ụgwọ ọrụ unu.\wj*
\v 7 \wj Mgbe unu na-ekpe ekpere, unu ekwula okwu nkwukwasị efu dị ka ndị na-amaghị Chineke na-eme. Ha chere na a ga-anụ ekpere ha nʼihi ọtụtụ okwu ha na-ekwu.\wj*
\v 8 \wj Unu adịla ka ha. Chetanụ na tupu unu arịọ arịrịọ ọbụla, Nna unu bi nʼeluigwe maara ihe na-akpa unu.\wj*
\p 
\v 9 \wj “Sinụ otu a na-ekpe ekpere:\wj*
\q1 \wj “ ‘Nna anyị nke bi nʼeluigwe,\wj*
\q1 \wj ka e doo aha gị nsọ.\wj*
\q1 
\v 10 \wj Ka alaeze gị bịa,\wj*
\q1 \wj ka e mee uche gị nʼụwa,\wj*
\q2 \wj dịka e si eme ya nʼeluigwe.\wj*
\q1 
\v 11 \wj Nye anyị nri nke ụbọchị taa.\wj*
\q1 
\v 12 \wj Gbaghara anyị mmehie anyị,\wj*
\q2 \wj dịka anyị si agbaghara ndị na-emehie megide anyị.\wj*
\q1 
\v 13 \wj Ekwela ka anyị daba nʼime ọnwụnwa,\wj*
\q2 \wj kama, zọpụta anyị nʼaka ajọ onye ahụ.’\wj*\f + \fr 6:13 \ft Akwụkwọ ochie ụfọdụ na-emechi ekpere a nʼụzọ dị otu a, \fqa nʼihi nʼalaeze bụ nke gị, ike na otuto ruo mgbe niile ebighị ebi. Amen.\f*
\m 
\v 14 \wj Ọ bụrụ na unu agbaghara ndị mmadụ mgbe ha mehiere megide unu, Nna unu nke bi nʼeluigwe ga-agbagharakwa unu mmehie unu.\wj*
\v 15 \wj Ọ bụrụkwanụ na unu agbagharaghị ndị ọzọ mmehie niile ha, Nna unu nke bi nʼeluigwe agaghị agbaghara unu mmehie unu.\wj*
\s1 Ibu ọnụ
\p 
\v 16 \wj “Ọzọ, mgbe ọbụla unu na-ebu ọnụ, unu agbarụla ihu unu dịka ndị ihu abụọ na-eme. Nʼihi na ha na-agbarụ ihu ha ka ndị ọzọ hụ na ha na-ebu ọnụ. Nʼezie agwa m unu, ha anatala ụgwọ ọrụ ha.\wj*
\v 17 \wj Mgbe ị na-ebu ọnụ, tee isi gị mmanụ, ma saakwa ihu gị mmiri,\wj*
\v 18 \wj ka ndị ọzọ ghara ịhụta na ị na-ebu ọnụ kama ka ọ bụrụ naanị nye Nna gị, onye anya na-adịghị ahụ. Nna gị, onye na-ahụ ihe niile na-eme na nzuzo, ga-akwụ gị ụgwọ.\wj*
\s1 Ịkpado akụ nʼeluigwe
\p 
\v 19 \wj “Unu akpadola akụ nʼụwa nye onwe unu, ebe ọ ga-agba nchara, akịka atakwa ya, ebe ndị ohi ga-etiwa ma zukwaa ha.\wj*
\v 20 \wj Kama kwadoonụ akụ nʼeluigwe nye onwe unu, ebe ha na-agaghị agba nchara, ebe akịka na-agaghị eri ha, ebe ndị ohi na-adịghị etiwa maọbụ zuo ihe.\wj*
\v 21 \wj Nʼihi na ebe ọbụla akụ unu dị ka obi unu ga-adịkwa.\wj*
\p 
\v 22 \wj “Anya bụ oriọna nke anụ ahụ. Ọ bụrụkwa na anya gị adịrị ọcha, ahụ gị niile ga-ejupụta nʼìhè.\wj*
\v 23 \wj Ọ bụrụ na anya gị ajọọ njọ, akụkụ ahụ gị niile ga-ejupụta nʼọchịchịrị. Ọ bụrụkwa na ìhè ahụ dị nʼime gị aghọọ ọchịchịrị, ọchịchịrị ahụ ga-adị ukwuu.\wj*
\p 
\v 24 \wj “Ọ dịghị onye ọbụla pụrụ ife nna ukwu abụọ, nʼihi na ọ ga-achọ ịhụ otu nʼime ha nʼanya, kpọkwa nke ọzọ asị, maọbụ sọpụrụ otu ma lelịa nke ọzọ anya. Otu a kwa i nweghị ike ife Chineke na akụ otu mgbe ahụ.\wj*
\s1 Echegbula onwe unu
\p 
\v 25 \wj “Nʼihi nke a ka m ji na-asị unu, unu echegbula onwe unu banyere ndụ unu, ihe unu ga-eri, maọbụ ihe unu ga-aṅụ, maọbụ banyere ahụ unu, ihe unu ga-eyi nʼahụ. Ọ bụ ndụ akarịghị nri eji azụ ya, ka ọ bụ ahụ akarịghị ihe e ji ekpuchi ya?\wj*
\v 26 \wj Werenụ ụmụ nnụnụ dị ka ihe ịmaatụ. Ha adịghị akụ mkpụrụ nʼubi maọbụ ewe ihe ubi. Ha adịghị achịkọtakwa ihe debe nʼọba. Ma Nna unu nke bi nʼeluigwe na-azụ ha. Ọ bụ na unu adịghị oke ọnụahịa karịa ha?\wj*
\v 27 \wj Onye nʼetiti unu pụrụ itinye otu nkeji nʼogologo ụbọchị nke ndụ\wj*\f + \fr 6:27 \ft Maọbụ, \fqa otu kubit nʼogologo ya\f*\wj ya site nʼichegbu onwe ya?\wj*
\p 
\v 28 \wj “Gịnị mekwaranụ unu ji na-anọ nʼechiche oge niile maka uwe? Leenụ okoko osisi nke ọhịa. Ha adịghị arụ ọrụ maọbụ dọgbuo onwe ha nʼọrụ.\wj*
\v 29 \wj Ma asị m unu, ọ bụladị Solomọn nʼebube nke ịbụ eze ya niile, eyighị uwe ọbụla mara mma dị ka otu nʼime okoko osisi nke ọhịa ndị a.\wj*
\v 30 \wj Ma ọ bụrụ na Chineke si otu a chọọ ahịhịa efu nke ubi mma, nke pụrụ ịdị ndụ taa ma echi atụba ha nʼite ọkụ, ọ bụ na ọ gaghị a chọọ unu mma karịa. Unu ndị okwukwe nta?\wj*
\v 31 \wj Nʼihi nke a, unu echegbukwala onwe unu na-asị, ‘Gịnị ka anyị ga-eri?’ maọbụ, ‘Gịnị ka anyị ga-aṅụ?’ maọbụ, ‘Gịnịkwa ka anyị ga-eyi?’\wj*
\v 32 \wj Ọ bụ ihe ndị a ka ndị na-amaghị Chineke na-achọsi ike. Ma Nna unu bi nʼeluigwe maara na ọ dị unu mkpa.\wj*
\v 33 \wj Ma burunu ụzọ chọọ alaeze ya na ezi omume ya, a ga-atụkwasịkwara unu ihe ndị a niile.\wj*
\v 34 \wj Ya mere, unu echegbula onwe unu banyere echi, nʼihi na echi ga-echere onwe ya. Nsogbu nke ụbọchị taa ezuorola ụbọchị taa.\wj*
\c 7
\s1 Ikpe ndị ọzọ ikpe
\p 
\v 1 \wj “Unu ekpela ndị ọzọ ikpe, ka a ghara ikpekwa unu ikpe.\wj*
\v 2 \wj Nʼihi na a ga-ekpe unu ikpe dịka unu si kpee ndị ọzọ. Ọ bụkwa ihe unu ji tụọrọ ndị ọzọ ka a ga-eji tụọrọ unu.\wj*
\p 
\v 3 \wj “Gịnị mere i ji elee ntakịrị ahịhịa dị nwanna gị\wj*\f + \fr 7:3 \fq Nwanna gị \ft onye agbataobi gị.\f*\wj nʼanya ma ị dịghị ahụta obodobo osisi dị gị onwe gị nʼanya?\wj*
\v 4 \wj Olee otu ị ga-esi gwa ya si, ‘Nwanna m, kwere ka m tụpụ gị ntakịrị ahịhịa danyere gị nʼanya,’ mgbe obodobo osisi dị gị nʼanya, nke na-adịghị ekwe gị hụzie ụzọ.\wj*
\v 5 \wj Onye ihu abụọ! Buru ụzọ wepụ obodobo osisi dị gị nʼanya ka i nwee ike ịhụzi ụzọ tụpụ ntakịrị ahịhịa nke dị nwanna gị nʼanya.\wj*
\p 
\v 6 \wj “Enyela nkịta ihe dị nsọ. Enyekwala ezi ihe dị oke ọnụahịa. Ha ga-azọtọ ha ma tụgharịakwa dọrie gị.\wj*
\s1 Rịọọnụ, chọọnụ, kụọnụ aka
\p 
\v 7 \wj “Na-arịọnụ, unu ga-arịọta, na-achọnụ, unu ga-achọta, kụọkwanụ aka nʼụzọ, a ga-emeghekwara unu ụzọ.\wj*
\v 8 \wj Nʼihi na onye na-arịọ, na-arịọta. Onye na-achọ, na-achọta. Onye na-akụ aka nʼụzọ ka a ga-emeghekwara ụzọ.\wj*
\p 
\v 9 \wj “Ọ dị onye nʼime unu, ma ọ bụrụ na nwa ya arịọọ ya achịcha, ga-enye ya okwute?\wj*
\v 10 \wj Maọbụ, nwata ahụ arịọọ azụ, o nye ya agwọ?\wj*
\v 11 \wj Ya mere, ebe unu ndị ọjọọ maara otu e si enye ụmụ unu ezi onyinye, Nna unu bi nʼeluigwe ọ gaghị enye unu karịa, ma ọ bụrụ na unu arịọọ ya!\wj*
\v 12 \wj Ya mere, nʼime ihe niile, na-emeso ndị mmadụ dị ka i si chọọ ka ha mesoo gị. Nke a bụ nchịkọta ihe iwu na ndị amụma ziri.\wj*
\s1 Ụzọ dị warawara na ndị dị obosara
\p 
\v 13 \wj “Sitenụ nʼọnụ ụzọ dị warawara banye. Nʼihi na ọnụ ụzọ ahụ dị obosara. Mbara ka ụzọ ahụ dịkwa na-eduba nʼịla nʼiyi. Ọtụtụ na-esoro ya.\wj*
\v 14 \wj Ole na ole na-achọta ụzọ ahụ na-eduba na ndụ, nʼihi na ọ dị warawara, dịkwa nkpagide.\wj*
\s1 Osisi na mkpụrụ ya
\p 
\v 15 \wj “Kpachapụnụ anya! Nʼihi na ndị amụma ụgha dị. Ha na-abịakwute unu nʼụdịdị atụrụ, ma ha bụ agụ.\wj*
\v 16 \wj A ga-esite na mkpụrụ\wj*\f + \fr 7:16 \fq Mkpụrụ \ft Nʼebe a o bụ ihe Igbo na-akpọ omume maọbụ agwa.\f*\wj ha mata ndị ha bụ. Ndị mmadụ ọ na-esite nʼosisi ogwu dị nʼọhịa ghọta mkpụrụ osisi grepu, ka ha na-esite nʼosisi uke gbara nʼọhịa ghọta mkpụrụ fiig?\wj*
\v 17 \wj Nʼụzọ dị otu a, osisi ọbụla dị mma na-amịpụta mkpụrụ ọma, ma osisi dị njọ na-amịpụta mkpụrụ dị njọ.\wj*
\v 18 \wj Osisi na-amị mkpụrụ ọma adịghị amị mkpụrụ ọjọọ. Nke na-amị mkpụrụ ọjọọ adịghịkwa amị mkpụrụ ọma.\wj*
\v 19 \wj Ma osisi ọbụla na-amịghị mkpụrụ ọma ka a ga-egbutu tụnye ya nʼọkụ.\wj*
\v 20 \wj Ụzọ e si amata osisi ọma bụ site na mkpụrụ ya.\wj*
\s1 Ndị ga-abanye nʼalaeze
\p 
\v 21 \wj “Ọ bụghị ndị niile na-asị m ‘Onyenwe anyị, Onyenwe anyị,’ ga-abanye nʼalaeze eluigwe, kama ọ bụ naanị ndị ahụ na-eme ihe Nna m nọ nʼeluigwe na-achọ ka ha mee.\wj*
\v 22 \wj Nʼụbọchị ahụ, ọtụtụ ndị mmadụ ga-asị m, ‘Onyenwe anyị, Onyenwe anyị, ọ bụ na anyị ejighị aha gị buo amụma, jiri aha gị chụpụ mmụọ ọjọọ, ma jirikwa aha gị ruo ọtụtụ ọrụ ebube?’\wj*
\v 23 \wj Mgbe ahụ aga m agwa ha hoohaa sị ha, ‘Amaghị m unu, sitenụ nʼihu m pụọ, unu ndị ajọ omume!’\wj*
\s1 Ihe iso Jisọs Pụtara
\p 
\v 24 \wj “Onye ọbụla ṅara ntị nʼokwu ndị a m kwuru, ma meekwa ha, dị ka nwoke ahụ maara ihe, onye wuru ụlọ ya nʼelu oke nkume.\wj*
\v 25 \wj Mmiri zosikwara ike nʼelu ụlọ ahụ, idee mmiri sọkwara, tie nʼụlọ ahụ. Ifufe siri ike fekwara, ma ụlọ ahụ adaghị. Nʼihi na e wuru ntọala ya nʼelu oke nkume.\wj*
\v 26 \wj Ma ndị niile nụrụ okwu ndị a, ma lefuru ha anya, bụ ndị nzuzu. Ha dị ka nwoke wuru ụlọ ya nʼelu aja.\wj*
\v 27 \wj Ngwangwa mmiri zoro, idee mmiri sọkwara, ifufe fesikwara ike tie nʼụlọ ahụ, ụlọ ahụ dara daruo ala. Ọdịda ya dị ukwuu.”\wj*
\p 
\v 28 Mgbe Jisọs kwuchara okwu ndị a, ozizi ya juru igwe mmadụ ahụ niile anya.
\v 29 Nʼihi na o ziri ihe dịka onye nwere ikike. Ọ bụghị dị ka ndị ozizi iwu ha.
\c 8
\s1 Ọgwụgwọ onye ekpenta
\p 
\v 1 Ọtụtụ mmadụ sooro Jisọs mgbe o si nʼugwu ahụ rịdata.
\v 2 Mgbe ha na-aga nʼụzọ, otu onye ekpenta bịakwutere ya kpọọ isiala nye ya, rịọ ya sị, “Onyenwe m, ọ bụrụ na ị chọrọ, ị pụrụ ime ka m dị ọcha.”
\p 
\v 3 O setịpụrụ aka ya, metụ ya sị, \wj “Achọrọ m ka ị dị ọcha, dịrịkwa ọcha!”\wj* Ngwangwa, ekpenta ahụ lara.
\v 4 Jisọs nyere nwoke ahụ iwu sị ya, \wj “Hụ na ịgwaghị onye ọbụla, kama gaa gosi onye nchụaja onwe gị, chụọkwa aja onyinye dịka Mosis, nyere nʼiwu, ka ọ bụrụ ihe ama nye ya.”\wj*
\s1 Okwukwe nke onye ọchịagha
\p 
\v 5 Mgbe ọ banyere na Kapanọm,\f + \fr 8:5 \ft Obodo dịkarịsịrị nso osimiri Jọdan, nʼakụkụ ndịda ugwu ọnụ mmiri Galili.\f* otu onye ọchịagha\f + \fr 8:5 \ft Onye na-achị narị ndị agha\f* bịakwutere ya rịọọ ka o nyere ya aka.
\v 6 Ọ sịrị, “Onyenwe m, onye na-ejere m ozi dina nʼụlọ nʼoke ihe mgbu, akụkụ ahụ ya kpọnwụkwara akpọnwụ.”
\p 
\v 7 Jisọs sịrị ya, \wj “Ọ bụ m bịa gwọọ ya?”\wj*
\p 
\v 8 Ma onye ọchịagha ahụ zara ya sị, “Onyenwe m, ekwesighị m ka ị bata nʼokpuru ụlọ m. Naanị nọdụ nʼebe a, kwuo okwu, ahụ ga-adịkwa onye na-ejere m ozi ike.
\v 9 Nʼihi na mụ onwe m bụkwa onye nọ nʼokpuru ikike ọchịchị, nwee ndị agha nọ nʼokpuru m. Ana m asị onye nke a, ‘gaa.’ Ọ gaa, sịkwa onye nke ọzọ, ‘bịa.’ Ọ bịa. Ana m asị ohu m, ‘mee nke a.’ Ọ na-emekwa ya.”
\p 
\v 10 Mgbe Jisọs nụrụ okwu a, o juru ya anya nke ukwuu. Ọ gwara igwe mmadụ ahụ so ya okwu sị, \wj “Nʼezie, ahụbeghị m okwukwe dị otu a ebe ọbụla; ọ bụladị nʼIzrel niile.\wj*
\v 11 \wj Nʼezie kwa, ọtụtụ ndị mmadụ ga-esite nʼọwụwa anyanwụ nakwa ọdịda anyanwụ bịa soro Ebraham na Aịzik na Jekọb nọkọọ nʼoriri nʼalaeze eluigwe.\wj*
\v 12 \wj Ma ụmụ alaeze ahụ, ka a ga-atụpụ nʼezi, nʼime ọchịchịrị, ebe ịkwa akwa na ịta ikikere eze ga-adị.”\wj*
\p 
\v 13 Jisọs gwara ọchịagha ahụ okwu sị ya, \wj “Laa! E meerela gị dị ka okwukwe gị sịrị dị.”\wj* Ahụ dịrị onye ahụ na-ejere ya ozi mma nʼotu awa ahụ.
\s1 Jisọs agwọọ ndị ọrịa
\p 
\v 14 Mgbe Jisọs ruru nʼụlọ Pita, ọ chọpụtara na nne nwunye ya nwere ahụ ọkụ.
\v 15 Ọ metụrụ ya aka, ahụ ọkụ ahụ hapụrụ ya, o biliri malite ijere ya ozi.
\p 
\v 16 Nʼoge uhuruchi, ha kpọtaara ya ọtụtụ ndị mmụọ ọjọọ na-esogbu. O ji okwu ọnụ chụpụ mmụọ ọjọọ ahụ niile, gwọọkwa ndị niile ahụ na-adịghị ike.
\v 17 Nke a bụ imezu amụma ahụ Aịzaya buru sị,
\q1 “O bupụrụ nrịa nrịa anyị niile,
\q2 burukwa ọrịa anyị niile.”\f + \fr 8:17 \ft \xt Aịz 53:4\xt*\f*
\s1 Ihe ọ ga-efu iso Jisọs
\p 
\v 18 Mgbe Jisọs hụrụ igwe mmadụ dị ukwuu ndị gbara ya gburugburu, ọ nyere ndị na-eso ụzọ ya iwu ka ha gafee nʼofe nke ọzọ.
\v 19 Nʼoge ahụ, otu onye nʼetiti ndị na-ezi iwu bịakwutere ya sị ya, “Onye nkuzi, aga m eso gị gaa ebe ọbụla ị na-aga.”
\p 
\v 20 Jisọs zara, sị, \wj “Nkịta ọhịa nwere ọnụ ebe ha na-edina. Ụmụ nnụnụ nke igwe nwekwara akwụ; ma Nwa nke Mmadụ enweghị ebe obibi.”\wj*
\p 
\v 21 Otu onye ọzọ nʼime ndị na-eso ụzọ ya sịrị ya, “Onyenwe m, aga m eso gị, kama kwere ka m buru ụzọ gaa lie nna m.”
\p 
\v 22 Ma Jisọs zara sị ya, \wj “Soro m ugbu a. Hapụ ndị nwụrụ anwụ ka ha lie ndị nwụrụ anwụ ibe ha.”\wj*
\s1 Ebili mmiri adajụọ
\p 
\v 23 Mgbe ọ banyere nʼụgbọ, ndị na-eso ụzọ ya sooro ya.
\v 24 Nʼotu ntabi anya, oke ifufe bidoro ife nʼọdọ mmiri ahụ, nke mere na ebili mmiri na-ekpuchi ụgbọ ahụ. Ma ọ nọ na-arahụ ụra mgbe ihe ndị a na-eme.
\v 25 Ndị na-eso ụzọ ya jekwuuru ya, kpọtee ya, sị ya, “Onyenwe anyị, zọpụta anyị! Lee, na anyị nʼala nʼiyi.”
\p 
\v 26 Ma ọ zaghachiri, \wj “Unu ndị okwukwe nta, gịnị mere ụjọ ji na-atụ unu?”\wj* Mgbe ahụ o biliri baara ifufe ahụ na ebili mmiri ahụ mba. Ha niile dajụrụ, deere jii.
\p 
\v 27 O juru ndị na-eso ụzọ ya anya, mee ka ha jụọ ajụjụ sị, “Ọ bụ ụdị mmadụ dị aṅaa ka nwoke a bụ? Ọ bụladị ifufe na ebili mmiri na-eme ihe o kwuru.”
\s1 Ọgwụgwọ ndị mmụọ ọjọọ na-esogbu
\p 
\v 28 Mgbe o rutere nʼofe nke ọzọ nke obodo Gadarin, mmadụ abụọ ndị mmụọ ọjọọ si nʼebe a na-eli ozu zutere ya. Ha na-akpa ike nke ukwuu, na ọ dịkwaghị onye na-esite nʼụzọ ahụ agafe nʼihi ha.
\v 29 Ngwangwa, ha tiri mkpu bido na-ajụ ajụjụ sị, “Gịnị ka anyị na gị nwekọrọ, gị Ọkpara Chineke? Ị gaghị echekwa eche ka oge ruo tupu ibido ịta anyị ahụhụ?”
\p 
\v 30 Igwe ezi\f + \fr 8:30 \ft Ezi \fqa Ezi bụ otu nʼime anụmanụ ndị na-adịghị ọcha nye ndị Juu. \xt Lev 11:7\xt*\f* nọ nʼakụkụ ebe ahụ na-akpa nri.
\v 31 Mmụọ ọjọọ ndị a rịọrọ ya arịrịọ sị, “Ọ bụrụ na ị chụpụ anyị, biko, hapụ anyị ka anyị banye nʼime ezi ndị a.”
\p 
\v 32 Ọ nyere ha iwu sị ha, \wj “Ngwa, gaanụ!”\wj* Ha sitere nʼime mmadụ abụọ ahụ pụta banye nʼime igwe ezi ahụ. Otu mgbe ahụ kwa, ezi ndị ahụ niile gbaara ọsọ site na mkputamkpu ala ọnụ mmiri ahụ dabanyechaa nʼime mmiri ahụ. Ha nwụkwara nʼime ya.
\v 33 Ndị na-elekọta igwe ezi ndị ahụ gbapụrụ gbaga nʼime obodo kọọrọ ha ihe niile mere; tinyere ihe mere ndị ahụ mmụọ ọjọọ na-esogbu.
\v 34 Ya mere ndị niile nọ nʼobodo ahụ pụtara ịhụ Jisọs. Mgbe ha hụrụ ya ha rịọrọ ya sị ya pụọra ha nʼakụkụ obodo ha.
\c 9
\s1 Jisọs agwọọ onye ahụ ya kpọnwụrụ akpọnwụ
\p 
\v 1 Jisọs banyekwara nʼụgbọ mmiri nke kwọọrọ ya bịaruo nʼobodo nke ya.
\v 2 Ndị ikom ụfọdụ butere ya otu nwoke akụkụ ahụ ya kpọnwụrụ akpọnwụ, bụ onye dina nʼute. Mgbe Jisọs hụrụ okwukwe ndị ahụ, ọ gwara onye ọrịa ahụ okwu sị ya, \wj “Nwee obi ike nwa m nwoke nʼihi na a gbagharala gị mmehie gị niile.”\wj*
\p 
\v 3 Nʼoge a, ụfọdụ ndị ozizi iwu nke ndị Juu nọ nʼebe ahụ sịrịtara onwe ha, “Nwoke a na-ekwulu Chineke.”
\p 
\v 4 Ma ebe Jisọs matara ihe ha na-eche nʼobi ha, ọ sịrị, \wj “Gịnị mere unu ji na-eche ajọ echiche nʼobi unu?\wj*
\v 5 \wj Olee nke ka mfe ikwu? Ọ bụ ị sị, ‘A gbagharala gị mmehie gị niile,’ ka ọ bụ ị sị, ‘Bilie jee ije’?\wj*
\v 6 \wj Ma ka unu mata na Nwa nke Mmadụ nwere ikike nʼụwa ịgbaghara mmehie.”\wj* Ọ sịrị onye ahụ akụkụ ahụ ya kpọnwụrụ akpọnwụ, \wj “Bilie, chịrị ute gị laa!”\wj*
\v 7 Nwoke ahụ biliri, chịrị ute ya laa nʼụlọ ya.
\v 8 Mgbe igwe mmadụ a hụrụ ihe ahụ mere, akpata oyi jụrụ ha nʼahụ nʼihi egwu. Ha tokwara Chineke onye na-enye ụmụ mmadụ ikike dị otu a.
\s1 Ọkpụkpọ Matiu
\p 
\v 9 Mgbe Jisọs si nʼebe ahụ na-aga, ọ hụrụ otu nwoke a na-akpọ Matiu ka ọ nọdụrụ ala nʼụlọ ịnakọta ụtụ. Ọ sịrị ya, \wj “Soro m.”\wj* Na-atụfughị oge, ọ hapụrụ ihe niile soro ya.
\p 
\v 10 Dị ka ọ nọdụrụ ala iri nri uhuruchi nʼụlọ Matiu, ọtụtụ ndị ọna ụtụ na ndị mmehie sooro ya na ndị na-eso ụzọ ya nọdụ na-eri nri.
\v 11 Mgbe ndị Farisii hụrụ nke a, ha jụrụ ndị na-eso ụzọ ya ajụjụ sị ha, “Gịnị mere onye ozizi unu ji eso ndị ọna ụtụ na ndị mmehie na-eri nri?”
\p 
\v 12 Mgbe ọ nụrụ nke a, Jisọs sịrị, \wj “Mkpa dibịa adịghị akpa ndị ahụ dị ike, kama ọ bụ ndị ahụ na-esighị ike ka mkpa dibịa na-akpa.\wj*
\v 13 \wj Ma gaanụ mụta ihe okwu a pụtara, ‘Ana m achọ ebere, ọ bụghị aja.’\wj*\f + \fr 9:13 \ft \xt Hos 6:6\xt*\f*\wj Nʼihi na abịaghị m ịkpọ ndị ezi omume, kama abịara m ịkpọ ndị mmehie.”\wj*
\s1 Ajụjụ banyere ibu ọnụ
\p 
\v 14 Emesịa, ndị na-eso ụzọ Jọn bịara jụọ ya ajụjụ sị, “Gịnị mere ndị na-eso ụzọ gị adịghị ebu ọnụ dị ka anyị onwe anyị na ndị Farisii na-eme?”
\p 
\v 15 Jisọs jụrụ ha sị, \wj “O kwesiri ka ndị enyi onye na-alụ nwunye ọhụrụ nọrọ na mwute na-erighị nri, mgbe ha na di nwanyị ọhụrụ nọ? Oge na-abịa mgbe a ga-ewepụ di nwanyị ọhụrụ nʼetiti ha, mgbe ahụ ka ha ga-ebu ọnụ.\wj*
\p 
\v 16 \wj “Ọ dịghị onye na-eji akwa ọhụrụ kwachie ebe akwa ochie siri dọkaa, nʼihi na akwa ahụ ga-esi nʼebe a kwachiri ya dọwaa; mee ka ọ dị njọ karịa ka ọ dị na mbụ.\wj*
\v 17 \wj Ọ dịkwaghị onye ga-etinye mmanya ọhụrụ nʼime karama akpụkpọ ochie, nʼihi na karama ochie ahụ ga-agbawa mee ka mmanya ọhụrụ ahụ wufuo. Kama ọ dị mma itinye mmanya ọhụrụ nʼime karama akpụkpọ ọhụrụ, nke ga-echekwa ha abụọ nke ọma.”\wj*
\s1 Nwata nwanyị na ọtụtụ ndị ọzọ
\p 
\v 18 Mgbe ọ nọ na-ekwu okwu, otu onyeisi ụlọ ekpere bịara kpọọ isiala nye ya, sị, “Ọ dịbeghị anya nwa m nwanyị nwụrụ. Otu ọ dị, bịa ka ị bikwasị ya aka gị. Ọ ga-ebili dịkwa ndụ ọzọ.”
\v 19 Nʼihi nke a, Jisọs soro ya gawa. Ndị na-eso ụzọ ya sokwara ha.
\p 
\v 20 Ma o nwere otu nwanyị onye ahụ na-esighị ike. Nwanyị a anọọla nʼọrịa a afọ iri na abụọ. Ọ bụkwa ọrịa oruru ọbara nke na-adịghị akwụsị akwụsị ka ọ na-arịa. Nwanyị a sitere nʼazụ bịaruo ya nso, metụ ọnụ uwe ya aka.
\v 21 Nʼihi na o kwuolarị nʼime obi ya sị, “Ọ bụrụ nnọọ na m ga-enwe ike metụ ọnụ uwe ya aka, a ga-agwọ m.”
\p 
\v 22 Jisọs chigharịrị lee ya anya sị ya, \wj “Ada m, nwee obi ike, nʼihi na e sitela nʼokwukwe gị mee ka ahụ dị gị mma.”\wj* Ahụ dịkwara nwanyị ahụ mma site nʼoge ahụ.
\p 
\v 23 Mgbe Jisọs batara nʼụlọ onyendu ụlọ ekpere ndị Juu ahụ, hụ igwe mmadụ ka ha na-atụ ụzụ na ndị na-egbu ọja.
\v 24 Ọ sịrị ha, \wj “Sinụ ebe a pụọ, nwata nwanyị a anwụghị anwụ, kama ọ nọ nʼụra.”\wj* Ma ha chịrị ya ọchị.
\v 25 Ma mgbe achụpụsịrị igwe mmadụ ahụ, ọ banyere nʼime ụlọ, jide nwata nwanyị ahụ nʼaka, o bilie ọtọ.
\v 26 Akụkọ ọrụ ebube a gbasara nʼebe niile nʼala ahụ.
\s1 Jisọs agwọọ ndị ìsì na onye ogbi
\p 
\v 27 Mgbe Jisọs si nʼebe ahụ na-apụ, ụmụ nwoke abụọ ndị kpuru ìsì sooro ya. Ha tikuru ya mkpu na-asị, “Nwa Devid, meere anyị ebere!”
\p 
\v 28 Ha sooro ya bata nʼụlọ ebe ọ nọ. Ọ jụrụ ha ajụjụ sị, \wj “Unu kwere na m nwere ike ime ka unu hụ ụzọ?”\wj*
\p Ha zara sị ya, “E, Onyenwe anyị, anyị kweere.”
\p 
\v 29 O metụrụ ha aka nʼanya sị ha, \wj “Ya dịrị unu dị ka okwukwe unu si dị.”\wj*
\v 30 Ngwangwa ndị ìsì ahụ bidoro ịhụ ụzọ. Jisọs maara ha ọkwa sị ha \wj “Unu agwakwala onye ọbụla.”\wj*
\v 31 Ma ha pụrụ gbasaa akụkọ a ebe niile nʼala ahụ.
\p 
\v 32 Mgbe ndị a sitere nʼebe ahụ pụọ, ndị ọzọ buteere ya nwoke dara ogbi, onye mmụọ ọjọọ bikwa nʼime ya.
\v 33 Mgbe ọ chụpụrụ mmụọ ọjọọ ahụ, onye ogbi ahụ bidoro ikwu okwu. Ibubo nwụrụ igwe mmadụ nọ nʼebe ahụ. Ha sịrị, “Anyị ahụtụbeghị ihe dị otu a nʼala Izrel.”
\p 
\v 34 Ma ndị Farisii sịrị, “Ọ bụ ekwensu, eze ndị mmụọ ọjọọ, na-enye ya ike ịchụpụ mmụọ ọjọọ.”
\s1 Ndị ọrụ adịghị ukwuu
\p 
\v 35 Jisọs jegharịrị nʼobodo niile na ogbe niile dị nʼebe ahụ, ma ndị ukwu na ndị nta, na-ezi ihe nʼụlọ ekpere ndị Juu, na-ekwusakwa oziọma nke alaeze ahụ. Ọ na-agwọkwa ọrịa na nrịa nrịa niile dị iche iche.
\v 36 Mgbe ọ hụrụ igwe mmadụ niile na-abịakwute ya, ọmịiko ha mere ya, nʼihi na ha bụ ndị a na-esogbu. Ndị na-enweghị onye inyeaka. Ndị dị ka atụrụ na-enweghị onye na-azụ ha.
\v 37 Mgbe ahụ, ọ sịrị ndị na-eso ụzọ ya, \wj “Owuwe ihe ubi hiri nne nʼezie. Ma ndị ọrụ dị ole na ole.\wj*
\v 38 \wj Ya mere, rịọọnụ Onyenwe owuwe ihe ubi ka o zite ndị ọrụ nʼowuwe ihe ubi ya.”\wj*
\c 10
\s1 Jisọs ezipu ndị ozi iri na abụọ
\p 
\v 1 Jisọs kpọrọ ndị na-eso ụzọ ya iri na abụọ nye ha ikike ịchụpụ mmụọ na-adịghị ọcha, na ịgwọ nrịa nrịa na ọrịa niile dị iche iche.
\b
\li4 
\v 2 Nke a bụ aha ndị ozi iri na abụọ ahụ:
\b
\li1 Saimọn (onye a na-akpọkwa Pita) na Andru nwanne Saimọn;
\li1 Jemis nwa Zebedi, na Jọn nwanne ya.
\li1 
\v 3 Filip na Batalomi;
\li1 Tọmọs na Matiu onye ọna ụtụ;
\li1 Jemis nwa Alfiọs, na Tadiọs.
\li1 
\v 4 Saimọn onye a na-akpọ Zilọt\f + \fr 10:4 \ft Onye so nʼotu ndị Juu chọrọ iji ike kwatuo ọchịchị ndị Rom.\f* na Judas Iskarịọt, onye raara ya nye nʼaka ndị gburu ya.
\b
\p 
\v 5 Ndị ikom iri na abụọ ndị a ka Jisọs nyere ikike zipụ. Maara ha ọkwa sị ha: \wj “Unu agala nʼebe ndị mba ọzọ, maọbụ nʼebe ndị Sameria nọ.\wj*
\v 6 \wj Kama jekwurunụ ụmụ Izrel, ndị bụ atụrụ furu efu.\wj*
\v 7 \wj Mgbe unu na-aga, na-ekwusaaranụ ha sị, ‘alaeze eluigwe a dịla nso.’\wj*
\v 8 \wj Gwọọnụ ndị ọrịa, kpọteenụ ndị nwụrụ anwụ, meenụ ka ahụ ndị ekpenta dị ọcha,\wj*\f + \fr 10:8 \ft Nʼakwụkwọ nsọ, ekpenta bụ aha gụnyere ọtụtụ ọrịa na-emetụta anụ ahụ.\f*\wj chụpụkwanụ mmụọ ọjọọ. Nʼefu ka unu natara. Ya mere, nyenụ nʼefu.\wj*
\p 
\v 9 \wj “Mgbe unu na-aga, unu anatala ọlaọcha maọbụ ọlaedo, maọbụ ọla ọbụla tinye nʼime belịt unu.\wj*
\v 10 \wj Unu ejikwala akpa maka njem unu, maọbụ uwe abụọ, maọbụ akpụkpọụkwụ, maọbụ mkpanaka. Nʼihi na onye ọrụ kwesiri ihe e ji azụ ya.\wj*
\v 11 \wj Ma obodo ọbụla maọbụ ogbe ọbụla unu bara nʼime ya, chọọnụ ụfọdụ ndị kwesiri nsọpụrụ bi nʼobodo ahụ. Nọgidekwanụ nʼụlọ ha ruo mgbe unu ga-ahapụ obodo ahụ.\wj*
\v 12 \wj Mgbe unu na-abanye nʼụlọ ahụ, keleenụ ndị bi na ya sị, udo dịrị unu.\wj*
\v 13 \wj Ọ bụrụ na ndị nọ nʼụlọ ahụ anabata unu, meenụ ka udo unu bịakwasị nʼụlọ ahụ. Ọ bụrụkwanụ na ha anabataghị unu, ka udo unu lọghachikwute unu.\wj*
\v 14 \wj Ọ bụrụ na onye ọbụla anabataghị unu, maọbụ jụ ịnụrụ okwu unu, mgbe unu na-ahapụ ụlọ ahụ maọbụ obodo ahụ kụchapụnụ aja dị nʼụkwụ unu.\wj*
\v 15 \wj Nʼeziokwu, ọ ga-adịrị obodo ahụ njọ nʼụbọchị ikpe karịa obodo Sọdọm na Gọmọra.\wj*
\s2 Mkpagbu nke oge dị nʼihu
\p 
\v 16 \wj “Ana m ezipu unu dị ka atụrụ nʼetiti agụ. Ya mere, nweenụ uche dịka agwọ. Burunu ndị a na-apụghị ịta ụta dịka nduru.\wj*
\v 17 \wj Kpachapụnụ anya. Nʼihi na a ga-enyefe unu nʼaka nzukọ ndị ụlọ ikpe, pịaakwa unu ihe nʼụlọ ekpere ha.\wj*
\v 18 \wj A ga-ekpe unu ikpe nʼihu ndị na-achị achị na nʼihu ndị eze nʼihi m. Ma nke a ga-enye unu ohere ịgwa ha ihe banyere m. E, nke a ga-enye unu ohere ịgba ama banyere m nye ndị mba ọzọ.\wj*
\v 19 \wj Mgbe ha jidere unu na-ekpe unu ikpe, unu echegbula onwe unu banyere ihe unu ga-ekwu, maọbụ otu unu ga-esi kwuo ya. Nʼihi na a ga-eme ka unu mata ihe unu ga-ekwu nʼoge ahụ.\wj*
\v 20 \wj Nʼihi na ọ bụghị unu ga-ekwu nʼonwe unu. Kama Mmụọ nke Nna unu bi nʼeluigwe ga-esite nʼọnụ unu kwuo okwu.\wj*
\p 
\v 21 \wj “Nwanne ga-arara nwanne ya nye ka e gbuo ya, nna ga-ararakwa nwa ya nye. Ụmụ ga-ebili megide ndị mụrụ ha mee ka e gbuo ha.\wj*
\v 22 \wj Mmadụ niile ga-akpọ unu asị nʼihi m. Ma onye ga-eguzosi ike ruo ọgwụgwụ ka a ga-azọpụta.\wj*
\v 23 \wj Mgbe ọbụla ndị mmadụ sogburu unu nʼotu obodo gbalaganụ nʼobodo ọzọ. Nʼezie, asị m unu, unu agaghị agazucha obodo niile nke Izrel tupu Nwa nke Mmadụ alọghachi.\wj*
\p 
\v 24 \wj “Nwata akwụkwọ adịghị akarị onye nkuzi ya. Ohu adịghị akarịkwa nna ya ukwu.\wj*
\v 25 \wj O zuorela onye na-eso ụzọ onye nkuzi ka ọ dị ka onye nkuzi ya, na ohu ahụ ka ọ dị ka onyenwe ya. Ọ bụrụ na a kpọrọ nna nwe ụlọ Belzebub, a ga-esi aṅaa ghara ịkpọ ndị ezinaụlọ ya ihe karịrị nke a?\wj*
\s2 Onye e kwesiri ịtụ egwu
\p 
\v 26 \wj “Ya mere unu atụla ha egwu. O nweghị ihe ọbụla e kpuchiri ekpuchi nke a na-agaghị ekpughe, maọbụ ihe e zoro ezo nke a na-agaghị eme ka ọ pụta ìhè.\wj*
\v 27 \wj Ihe m na-agwa unu ugbu a na nzuzo, kọsaanụ ya mgbe chi bọrọ. Ihe m ji nwayọọ mee ka ọ baa unu na ntị, nọdụnụ nʼelu ụlọ kwusaa ya.\wj*
\v 28 \wj Unu atụla egwu ndị pụrụ igbu naanị anụ ahụ unu, ma ha enweghị ike ịmetụ mkpụrụobi unu aka. Kama onye unu ga-atụ egwu bụ Onye ahụ nwere ike imebi anụ ahụ unu na mkpụrụobi, tụbakwa ha nʼọkụ ala mmụọ.\wj*
\v 29 \wj Ọ bụghị otu kobo ka a na-ere ụmụ nza abụọ? Ma otu nʼime ha agaghị ada nʼala ma ọ bụrụ na Nna unu bi nʼeluigwe amaghị.\wj*
\v 30 \wj Ọ bụladị agịrị isi dị nʼisi unu ka a maara ọnụọgụgụ ha.\wj*
\v 31 \wj Ya mere, unu atụla egwu. Unu dị oke ọnụ karịa ọtụtụ ụmụ nza.\wj*
\p 
\v 32 \wj “Ya mere, onye ọbụla kwupụtara m nʼihu ụmụ mmadụ, ka mụ onwe m ga-ekwupụta nʼihu Nna m bi nʼeluigwe.\wj*
\v 33 \wj Ma onye ọbụla na-agọnarị m nʼihu ndị mmadụ, mụ onwe m ga-agọnarịkwa ya nʼihu Nna m bi nʼeluigwe.\wj*
\p 
\v 34 \wj “Unu echekwala na m bịara iweta udo nʼụwa. Abịaghị m iweta udo, kama ọ bụ iwebata mma agha.\wj*
\v 35 \wj Abịara m ime,\wj*
\q1 \wj “ ‘Ka nwoke megide nna ya,\wj*
\q2 \wj ka nwa nwanyị megide nne ya,\wj*
\q1 \wj ka nwunye nwa megide nne di ya,\wj*
\q2 
\v 36 \wj ndị iro mmadụ ga-abụ ndị ezinaụlọ ya.’\wj*\f + \fr 10:36 \ft \xt Mai 7:6\xt*\f*
\p 
\v 37 \wj “Ọ bụrụ na ị hụrụ nne gị maọbụ nna gị nʼanya karịa m, i kwesighị ịbụ onye nke m. Ọ bụrụ na ị hụrụ nwa gị nwoke, maọbụ nwa gị nwanyị nʼanya karịa m, i kwesighị ịbụ onye nke m.\wj*
\v 38 \wj Onye ọbụla na-eburughị obe ya soro m, ekwesighị ị bụ onye nke m.\wj*
\v 39 \wj Onye ọbụla chọtara ndụ ya ga-etufu ya, ma onye ọbụla tufuru ndụ ya maka m, ga-achọtakwa ya.\wj*
\p 
\v 40 \wj “Ndị niile nabatara unu na-anabata m. Mgbe ha nabatara m, ọ bụkwa Onye ahụ zitere m ka ha na-anabata.\wj*
\v 41 \wj Ọ bụrụ na unu anabata onye amụma nʼihi na ọ bụ onye amụma, unu na onye amụma ahụ ga-enwekọ otu ụgwọ ọrụ. Ọ bụrụkwa na unu anabata onye ezi omume nʼihi ezi omume ya, unu ga-esorokwa ya nata ụgwọ ọrụ nke onye ezi omume.\wj*
\v 42 \wj Ọ bụrụ na onye ọbụla ekunye otu nʼime ndị a na-eso ụzọ m mmiri oyi ka ọ ṅụọ, nʼihi na ọ bụ onye na-eso ụzọ m, nʼezie, asị m unu, ọ ghaghị ịnata ụgwọ ọrụ ya.”\wj*
\c 11
\s1 Ozi Jọn ziri ka e zie Jisọs
\p 
\v 1 Mgbe Jisọs nyesịrị ndị na-eso ụzọ ya ndụmọdụ ndị a, ọ hapụrụ ebe ahụ pụọ. Bido na-ejegharị nʼobodo dị iche iche na-ezisa oziọma.
\p 
\v 2 Jọn omee baptizim nọkwa nʼụlọ mkpọrọ nʼoge ahụ. Mgbe ọ nụrụ akụkọ ọrụ ebube niile nke Kraịst na-arụ, o zipụrụ ndị na-eso ụzọ ya.
\v 3 Ọ gwara ha ka ha jụọ ya ajụjụ sị, “Ọ bụ gị bụ onye ahụ anyị na-ele anya ọbịbịa ya, ka ọ bụ onye ọzọ?”
\p 
\v 4 Jisọs zara ha sị, \wj “Laghachinụ azụ gwa Jọn banyere ihe unu nụrụ na ihe anya unu hụrụ.\wj*
\v 5 \wj Gwanụ ya na a na-eme ka ndị ìsì hụ ụzọ, ka ndị ngwụrọ gaa ije. A na-emekwa ka ahụ ndị ekpenta dị ọcha.\wj*\f + \fr 11:5 \ft Ọrịa a bụ ekpenta, a bụghị ka anyị si mara ya nʼala anyị, kama ọ bụ aha ndị Griik ji mara ọrịa niile dị iche iche nke na-emetụta akpụkpọ ahụ.\f*\wj Ndị ogbi na-anụ ihe, na-ekwu okwu. Ndị nwụrụ anwụ ka a na-akpọte. Gwakwanụ ya ihe banyere oziọma a na-ezisara ndị ogbenye.\wj*
\v 6 \wj Ziekwanụ ya ozi a, na ngọzị na-adịrị onye ahụ na-enweghị ihe mkpasu iwe nʼihi m.”\wj*
\p 
\v 7 Mgbe ndị ahụ Jọn zitere lara, Jisọs bidoro ịgwa igwe mmadụ nọ nʼebe ahụ okwu banyere Jọn. Ọ jụrụ ha ajụjụ sị, \wj “Mgbe unu gara nʼọzara ịhụ Jọn, gịnị ka unu lere anya na unu ga-ahụ? Ọ bụ ahịhịa achara nke ikuku na-ebugharị?\wj*
\v 8 \wj Ma ọ bụghị otu a, gịnị ka unu pụrụ ịga ịhụ? Ọ bụ nwoke yi uwe mara mma? Ma lee ndị na-eyi uwe dị oke ọnụahịa na-anọ nʼụlọ eze.\wj*
\v 9 \wj Ma gịnị ka unu lere anya na unu ga-ahụ? Ọ bụ onye amụma? E, asị m unu, ọ bụ onye karịrị onye amụma.\wj*
\v 10 \wj Onye bụ onye ahụ e dere ihe banyere ya nʼakwụkwọ nsọ sị,\wj*
\q1 \wj “ ‘Lee, aga m ezipu onyeozi m nʼihu gị,\wj*
\q2 \wj onye ga-edozi ụzọ gị nʼihu gị.’\wj*\f + \fr 11:10 \ft \xt Mal 3:1\xt*\f*
\m 
\v 11 \wj Nʼezie, ọ dịghị nwoke ọbụla nʼetiti ndị nwanyị mụrụ dị ukwuu karịa Jọn omee baptizim. Ma onye dịkarịsịrị nta nʼalaeze eluigwe dị ukwuu karịa ya.\wj*
\v 12 \wj Site nʼụbọchị ndị ahụ Jọn omee baptizim malitere ọrụ ya ruo ugbu a, ihe banyere alaeze eluigwe na-agabiga ihe ike. Otu a kwa ndị dị ike na-abagidekwa ya.\wj*
\v 13 \wj Nʼihi na tupu Jọn abịa, iwu na ndị amụma niile buru amụma banyere alaeze a.\wj*
\v 14 \wj Ọ bụrụkwa na unu jikeere ịnabata ya, ọ bụ ya bụ Ịlaịja ahụ, nke na a ga ịbịa.\wj*
\v 15 \wj Onye ọbụla nwere ntị ịnụ ihe, ya nụrụ.\wj*
\p 
\v 16 \wj “Gịnị ka m ga-eji tụnyere ndị bi nʼọgbọ a? Gịnị ka ha yiri? Ha dị ka ụmụntakịrị na-egwuri egwu nʼama, ndị na-asị ibe ha,\wj*
\q1 
\v 17 \wj “ ‘Anyị gburu unu ọja,\wj*
\q2 \wj ma unu ekweghị ete egwu.\wj*
\q1 \wj Anyị bụụrụ unu abụ ịkwa ozu,\wj*
\q2 \wj ma unu akwaghị akwa.’\wj*
\m 
\v 18 \wj Jọn bịara na-erighị achịcha maọbụ ihe ọṅụṅụ. Ha sịrị, ‘Mmụọ ọjọọ bi nʼime ya.’\wj*
\v 19 \wj Ma Nwa nke Mmadụ bịara na-eri ihe oriri, na-aṅụkwa ihe ọṅụṅụ. Ha sị, ‘Lee, onye oke oriri na onye oke aṅụmaṅụ abịala, enyi ndị ọna ụtụ na ndị mmehie.’ Ma amamihe na-esite nʼọrụ ya gosiri na ihe o mere dị mma.”\wj*
\s1 Abụmọnụ nye obodo ndị na-ekwenyeghị
\p 
\v 20 Mgbe ahụ ọ bidoro ịbụ obodo niile ebe ọ rụrụ ọtụtụ ọrụ ebube ọnụ, nʼihi na obodo ndị a echegharịghị.
\v 21 \wj “Ahụhụ ga-adịrị gị Korazin. Ahụhụ ga-adịkwara gị Betsaida. Nʼihi na a sị na ọ bụ nʼime Taịa na Saịdọn ka a rụrụ ọrụ ebube niile a rụrụ nʼime unu, ha gaara echegharị ma gosikwa nchegharị ha site nʼiyi uwe mkpe na ikpokwasị onwe ha ntụ nʼisi.\wj*
\v 22 \wj Nʼezie asị m unu na ọ ga-adịrị unu njọ nʼụbọchị ikpe ahụ karịa obodo Taịa na Saịdọn.\wj*
\v 23 \wj Ma gị Kapanọm bụ obodo a na-asọpụrụ, a ga-ebuli gị elu ruo eluigwe? Mba, ị ga-arịdaru ọkụ ala mmụọ. Nʼihi na a sị na a rụrụ ọrụ ebube m rụrụ nʼime gị nʼobodo Sọdọm, a garaghị ala ya nʼiyi. Ọ gaara adịrị ruo taa.\wj*
\v 24 \wj Nʼezie asị m unu, ọ ga-adịrị unu njọ nʼụbọchị ikpe ahụ karịa obodo Sọdọm.”\wj*
\s1 Izuike nye ndị ike gwụrụ
\p 
\v 25 Nʼoge ahụ, Jisọs kwuru sị, \wj “Nna, Onyenwe eluigwe na ụwa, ana m ekele gị,\wj*\f + \fr 11:25 \ft Maọbụ, \fqa ana m eto gị\f*\wj nʼihi na ị zonarịrị ndị ọkachamara eziokwu ahụ, ma kpughee ya nye ụmụntakịrị.\wj*
\v 26 \wj E, Nna m, ọ tọrọ gị ụtọ ime ya nʼụzọ dị otu a.\wj*
\p 
\v 27 \wj “Nna m enyefeela m ihe niile nʼaka. Ọ dịghị onye maara Ọkpara ahụ ma ọ bụghị Nna ya. Ọ dịkwaghị onye maara Nna karịa Ọkpara ahụ na ndị Ọkpara ahụ kwadoro igosi Nna ya.\wj*
\p 
\v 28 \wj “Bịakwutenụ m unu niile ndị na-adọgbu onwe unu nʼọrụ, ndị e bokwasịrị ibu dị arọ. Aga m enyekwa unu izuike.\wj*
\v 29 \wj Nyaranụ yoku\wj*\f + \fr 11:29 \ft Maọbụ, \fqa ịyagba\f*\wj nke m nʼolu unu, mụtakwanụ ihe site nʼaka m. Nʼihi na adị m nwayọọ, bụrụkwa onye dị umeala nʼobi. Unu ga-achọtakwara mkpụrụobi unu izuike.\wj*
\v 30 \wj Nʼihi na yoku m dị mfe, ibu m adịghịkwa arọ.”\wj*
\c 12
\s1 Jisọs bụ Onyenwe ụbọchị izuike
\p 
\v 1 Nʼoge ahụ, Jisọs sitere nʼubi a kụrụ ọka na-agafe nʼụbọchị izuike. Ma ebe agụụ na-agụ ndị na-eso ụzọ ya, ha malitere ịghọ ogbe ọka, na ịta mkpụrụ ya.
\v 2 Mgbe ndị Farisii hụrụ nke a, ha sịrị ya, “Lee, ndị na-eso ụzọ gị na-eme ihe na-ezighị ezi ime nʼụbọchị izuike!”
\p 
\v 3 Ma ọ zara ha sị, \wj “Ọ bụ na unu agụtaghị ihe Devid na ndị ya na ha soo mere mgbe agụụ na-agụ ha?\wj*
\v 4 \wj Otu o si banye nʼụlọ Chineke, ya na ndị so ya, rie achịcha a na-eche nʼihu Chineke, nke na-ezighị ezi nʼiwu ka ha rie, kama ọ dịịrị naanị ndị nchụaja iri ya.\wj*
\v 5 \wj Ka ọ bụ na unu agụtabeghị ebe e dere ya nʼime akwụkwọ iwu Mosis na ndị nchụaja na-emerụ ụbọchị izuike nʼụlọnsọ ukwu ahụ, ma ọ dịghị onye na-ata ha ụta?\wj*
\v 6 \wj Ma ana m agwa unu na onye dị ukwuu karịa ụlọnsọ ukwu nọ nʼebe a.\wj*
\v 7 \wj Ọ bụrụ na unu ghọtara ihe akwụkwọ nsọ na-ekwu mgbe ọ na-asị, ‘Ana m achọ ebere, ọ bụghị aja.’\wj*\f + \fr 12:7 \ft \xt Hos 6:6\xt*\f*\wj Unu agaraghị ama ndị ikpe na-amaghị ikpe.\wj*
\v 8 \wj Nʼihi na Nwa nke Mmadụ bụ Onyenwe ụbọchị izuike.”\wj*
\p 
\v 9 O sitere nʼebe ahụ pụọ banye nʼụlọ nzukọ ha.
\v 10 Nʼebe a ka ọ hụrụ otu nwoke aka ya kpọnwụrụ akpọnwụ. Ndị nọ nʼebe ahụ jụrụ ya ajụjụ sị, “O ziri ezi nʼiwu ịgwọ mmadụ nʼụbọchị izuike?”\f + \fr 12:10 \ft Maọbụ, \fqa ụbọchị ofufe ndị Juu\f*
\p 
\v 11 Ma ọ zara ha sị, \wj “Ọ bụrụ na otu onye nʼime unu nwere otu atụrụ danyere nʼime olulu nʼụbọchị izuike gịnị ka ọ ga-eme? Ọ ga-ahapụ ya nʼebe ahụ? Ọ gaghị ejide ya dọpụta ya?\wj*
\v 12 \wj Mmadụ ọ dịghị mkpa karịa atụrụ? Ya mere, o ziri ezi nʼiwu bụ ịrụ ọrụ ọma nʼụbọchị izuike.”\wj*
\p 
\v 13 Mgbe ahụ ọ sịrị nwoke ahụ, \wj “Setịpụ aka gị.”\wj* Nwoke ahụ setịpụrụ aka ya. Aka ahụ dịkwara ya mma dị ka aka nke ọzọ.
\v 14 Nʼihi nke a ndị Farisii sitere nʼebe ahụ pụọ, ga gbaa izu otu ha ga-esi gbuo ya.
\s1 Onye Chineke họpụtara
\p 
\v 15 Ma ebe Jisọs maara ihe ha na-ezube ime, o sitere nʼebe ahụ pụọ. Ma ọtụtụ ndị mmadụ sooro ya. Ọ gwọkwara ha nrịa nrịa ha niile.
\v 16 Ma o nyere ha iwu ka ha hapụ ịgwa ndị ọzọ onye ọ bụ.
\v 17 Nke a bụ ka emezuo okwu ahụ Aịzaya onye amụma kwuru,
\q1 
\v 18 “Onye a bụ onye na-ejere m ozi, onye m họpụtara.
\q2 Onye m hụkwara nʼanya. O bụkwa onye ihe ya na-atọ m ụtọ.
\q1 Aga m etinye Mmụọ m nʼime ya.
\q2 Ọ ga-eme ka ikpe ziri ezi rute mba niile aka.
\q1 
\v 19 Ọ gaghị ese okwu, ọ gaghị etisikwa mkpu ike.
\q2 O nweghị onye ga-anụ olu okwu ya nʼezi.
\q1 
\v 20 Ọ gaghị agbaji ahịhịa riidi azọpịara nʼala,
\q2 maọbụ menyụọ ogho oriọna na-enwu ntakịrị ntakịrị,
\q1 tutu ruo mgbe ọ ga-eme ka ikpe ziri ezi merie.
\q2 
\v 21 Ọ bụkwa nʼaha ya ka mba niile dị nʼụwa ga-atụkwasị olileanya ha.”\f + \fr 12:21 \ft \xt Aịz 42:1-4\xt*\f*
\s1 Jisọs na ekwensu
\p 
\v 22 Emesịa, ha kpọtaara ya otu nwoke kpuru ìsì ma daakwa ogbi. Ọ bụkwa onye mmụọ ọjọọ na-esogbu. Ọ gwọrọ ya, mee ka nwoke ahụ hụ ụzọ, bidokwa ikwu okwu.
\v 23 Ihe a juru igwe mmadụ nọ nʼebe ahụ anya. Nʼihi ya, ha kwuru sị, “Nwoke a, ọ ga-abụ Nwa Devid?”\f + \fr 12:23 \ft Onye nzọpụta ahụ.\f*
\p 
\v 24 Mgbe ndị Farisii nụrụ nke a, ha sịrị, “Nwoke a chụpụrụ mmụọ ọjọọ a nʼihi na Belzebub, eze ndị mmụọ ọjọọ, nyere ya ike ịchụpụ ya.”
\p 
\v 25 Ma ebe ọ matara ihe ha na-eche nʼobi ha. Ọ gwara ha okwu sị, \wj “Alaeze ọbụla kewara megide onwe ya ga-ada. Obodo o bụla maọbụ ezinaụlọ ọbụla kewara megide onwe ya agaghị eguzo.\wj*
\v 26 \wj Ọ bụrụ na ekwensu achụpụ ekwensu, o kewala megide onwe ya. Oleekwanụ otu alaeze ya ga-esi guzo.\wj*
\v 27 \wj Dị ka unu kwuru, ọ bụrụ na m na-achụpụ mmụọ ọjọọ site nʼike Belzebub, ọ bụ nʼike onye ka ụmụ unu ndị ikom na-achụpụ ha? Ya mere, ọ bụ ụmụ unu ga-ekpe unu ikpe nʼihi okwu a unu kwuru.\wj*
\v 28 \wj Ma ọ bụrụ na m na-esite nʼike Mmụọ nke Chineke na-achụpụ mmụọ ọjọọ, matakwanụ na alaeze Chineke abịala nʼetiti unu.\wj*
\p 
\v 29 \wj “Ọ dịghị mmadụ ọbụla pụrụ ịbanye nʼụlọ nwoke dị ike kwakọrọ ngwongwo niile dị nʼụlọ ahụ. Ma o nwere ike ime nke a ma ọ bụrụ na ọ ga-eburu ụzọ kee nwoke ahụ agbụ? Mgbe o kesịrị ya agbụ, o nwere ike ịbanye kwakọtaa ngwongwo niile dị nʼụlọ nwoke ahụ.\wj*
\p 
\v 30 \wj “Onye ọbụla na-adịnyeghịrị m na-emegide m. Onye ọ bụlakwa na-adịghị eso m ekpokọta, na-ekposa ekposa.\wj*
\v 31 \wj Ya mere, ana m agwa unu sị, na a ga-agbaghara mmehie na nkwulu niile. Ma agaghị agbaghara nkwulu ekwuluru Mmụọ Nsọ.\wj*
\v 32 \wj Onye ọbụla nke ga-ekwu okwu megide Nwa nke Mmadụ, a ga-agbaghara ya, ma onye ọbụla na-ekwu megide Mmụọ Nsọ, agaghị agbaghara ya, nʼọgbọ a maọbụ nʼọgbọ nke na-abịa.\wj*
\s1 Osisi na mkpụrụ ya
\p 
\v 33 \wj “Ọ bụrụ na e mee ka osisi too nke ọma, ọ ga-amịta mkpụrụ ọma, ma ọ bụrụ na o toghị nke ọma, ọ ga-amịta mkpụrụ ọjọọ. Nʼihi na a na-amata osisi ọbụla site na mkpụrụ ya.\wj*
\v 34 \wj Ụmụ ajụala, olee otu unu ga-esi kwuo okwu dị mma, ebe obi unu dị njọ? Nʼihi na ihe mmadụ kwuru bụ ihe si ya nʼobi pụta.\wj*
\v 35 \wj Ezi mmadụ na-esi nʼezi akụ ya wepụta ihe dị mma, ma ajọ mmadụ na-esitekwa nʼajọ akụ ya wepụta ajọọ ihe.\wj*
\v 36 \wj Ma ana m agwa unu sị, nʼụbọchị ikpe ahụ, onye ọbụla ga-aza ajụjụ, banyere okwu niile na-enweghị isi o kwuru.\wj*
\v 37 \wj Nʼihi na ọ bụ site nʼokwu ọnụ gị ka ị ga-abụ onye ikpe mara, sitekwa nʼokwu ọnụ gị ka ị ga-abụ onye ikpe na-amaghị.”\wj*
\s1 Ihe ịrịbama Jona
\p 
\v 38 Mgbe ahụ, ụfọdụ ndị ozizi iwu na ndị Farisii gwara Jisọs sị ya, “Onye nkuzi, anyị chọrọ ka i gosi anyị ihe ịrịbama.”
\p 
\v 39 Ma ọ zara sị ha, \wj “Ọ bụ naanị ajọ ọgbọ nke na-enweghị okwukwe ga-achọkwa ka e gosi ha ihe ịrịbama. Ma ọ dịkwaghị ihe ịrịbama ọzọ a ga-egosi unu karịa ihe ịrịbama Jona onye amụma.\wj*
\v 40 \wj Nʼihi na dị ka Jona nọrọ ụbọchị atọ, ehihie na abalị nʼafọ azụ dị ukwuu, otu a ka Nwa nke Mmadụ ga-esi nọọkwa ụbọchị atọ, ehihie na abalị nʼobi nke ala.\wj*
\v 41 \wj Ndị ikom Ninive ga-eso ọgbọ a bilie nʼụbọchị ikpe maa ya ikpe. Nʼihi na ha chegharịrị mgbe ha nụrụ nkwusa Jona. Ma lee onye karịrị Jona ukwuu nọ nʼebe a.\wj*
\v 42 \wj Nʼụbọchị ikpe ahụ kwa, eze nwanyị nke Ndịda\wj*\f + \fr 12:42 \ft Maọbụ, \fqa Sheba\f*\wj ga-eso ọgbọ a bilie boo ya ebubo. Ọ ga-amakwa unu ikpe. Nʼihi na o siri nʼebe dị ụwa sọtụrụ bịa nụrụ okwu amamihe Solomọn. Ma ugbu a onye ahụ dị ukwuu karịa Solomọn nọ nʼebe a, ma unu jụrụ i kwere na ya.\wj*
\s1 Nlọghachi nke mmụọ ọjọọ
\p 
\v 43 \wj “Mgbe mmụọ na-adịghị ọcha si nʼime mmadụ pụọ, ọ na-agabiga nʼọzara ebe mmiri na-adịghị ịchọ ebe izuike, ma ọ naghị achọta ya.\wj*
\v 44 \wj Mgbe ahụ, ọ na-asị, ‘Aga m alaghachi nʼụlọ m, ebe m si pụta.’ Mgbe ọ lọghachiri, ọ na-achọpụta na a zachara ụlọ ahụ dozie ya, ọ dịkwaghị onye bichiri nʼime ya.\wj*
\v 45 \wj Mgbe ahụ, ọ na-apụ gaa chọta mmụọ asaa ọzọ, ndị dị njọ karịa ya onwe ya. Ha niile na-abata bịa biri nʼime onye ahụ. Mee ka ọnọdụ ya dị njọ karịa ka ọ dị na mbụ. Otu a ka ọ ga-adịrị ndị bi nʼọgbọ a jọrọ njọ.”\wj*
\s1 Nne Jisọs na ụmụnne ya
\p 
\v 46 Mgbe ọ nọ na-agwa igwe mmadụ ahụ okwu, nne ya na ụmụnne ya bịara guzoro nʼezi na-eche ka ha gwa ya okwu.
\v 47 Otu onye nʼime igwe mmadụ ahụ gwara ya okwu sị, “Lee, nne gị na ụmụnne gị ndị nwoke na-achọ ịhụ gị nʼezi. Ha chọrọ ịgwa gị okwu.”
\p 
\v 48 Ma ọ zara onye ahụ gwara ya okwu sị, \wj “Onye bụ nne m? Olee ndị bụ ụmụnne m ndị nwoke?”\wj*
\v 49 Ọ tụrụ ndị na-eso ụzọ ya aka, sị, \wj “Lee, ndị a bụ nne m na ụmụnne m ndị nwoke.\wj*
\v 50 \wj Nʼihi na onye ọbụla na-eme ihe Nna m bi nʼeluigwe chọrọ, bụ nwanne m nwoke, na nwanne m nwanyị, nakwa nne m.”\wj*
\c 13
\s1 Ilu banyere ọgha mkpụrụ
\p 
\v 1 Nʼotu ụbọchị ahụ, Jisọs hapụrụ ụlọ ahụ gaa nʼọnụ mmiri ebe ọ nọdụrụ ala.
\v 2 Igwe mmadụ dị ukwuu bịakwutere ya, nke mere ka ọ baa nʼime ụgbọ mmiri. Nʼime ya ka ọ nọ na-ezi ndị mmadụ nọ nʼọnụ mmiri ahụ na-ege ya ntị ihe.
\v 3 O ji ilu gwa ha ọtụtụ ihe. Ọ gwara ha sị, \wj “O nwere otu onye ọrụ ubi gara ịkụ mkpụrụ nʼubi ya.\wj*
\v 4 \wj Mgbe ọ na-agha mkpụrụ ndị a, ụfọdụ nʼime ha dara nʼakụkụ ụzọ ebe ụmụ nnụnụ bịara tụrịa ha loo.\wj*
\v 5 \wj Ma ụfọdụ nʼime ha dara nʼala dị nkume nkume. Ọ dịghị anya ha puputara, too, nʼihi na aja dị nʼebe ahụ emighị emi.\wj*
\v 6 \wj Ma mgbe anwụ mụkwasịrị ha, ha chanwụrụ, kpọnwụọ, nʼihi na mgbọrọgwụ ha emikpughị emikpu nʼime ala.\wj*
\v 7 \wj Mkpụrụ ụfọdụ danyere nʼetiti ogwu, ogwu ahụ topụtara kpagbuo ha.\wj*
\v 8 \wj Ma ụfọdụ mkpụrụ dara nʼezi ala, mịakwa ọtụtụ mkpụrụ. Ụfọdụ mịrị mkpụrụ iri atọ, ụfọdụ iri isii, ụfọdụ kwa otu narị.\wj*
\v 9 \wj Onye ọbụla nwere ntị ịnụ ihe, ya nụrụ.”\wj*
\p 
\v 10 Emesịa, ndị na-eso ụzọ ya bịakwutere ya jụọ ya sị, “Gịnị mere i ji na-agwa ndị a okwu nʼilu?”
\p 
\v 11 Ọ zaghachiri, \wj “Nʼihi na ọ bụ unu ka e nyere ịmata ihe omimi niile nke alaeze eluigwe. Emeghị ka ndị ọzọ ghọta ya.\wj*
\v 12 \wj Onye ahụ nwere ihe ka a ga-enyekwa ọzọ, ka o nwee karịa. Ma onye na-enweghị ihe ọbụla ka a ga-anapụ ọ bụladị ihe o nwere.\wj*
\v 13 \wj Nke a bụ ihe mere m ji agwa ha okwu nʼilu:\wj*
\q1 \wj “Nʼihi na ha na-ele anya, ma ha adịghị ahụ ụzọ,\wj*
\q2 \wj ha na-ege ntị, ma ha adịghị anụ ihe maọbụ aghọta ya.\wj*
\m 
\v 14 \wj Nke a bụkwa imezu amụma ahụ Aịzaya buru sị,\wj*
\q1 \wj “ ‘Unu ga na-anụ, nụkwa, ma unu agaghị aghọta ihe ọbụla.\wj*
\q2 \wj Unu ga na-ele anya, hụkwa, ma unu agaghị ahụ ihe ọbụla.\wj*
\q1 
\v 15 \wj Nʼihi na obi ndị nke a a maala abụba, dịkwa arọ,\wj*
\q2 \wj ha adịghị ejikwa ntị ha anụ ihe,\wj*
\q2 \wj ha mechikwara anya ha ka ha ghara ịhụ ụzọ.\wj*
\q1 \wj Ma ọ bụghị otu a ha nwere ike iji anya ha hụ ụzọ,\wj*
\q2 \wj jirikwa ntị ha nụ ihe,\wj*
\q2 \wj sitekwa nʼobi ha nwe nghọta\wj*
\q1 \wj ma chigharịa bịakwute m, ka m gwọọ ha.’\wj*\f + \fr 13:15 \ft \xt Aịz 6:9,10\xt*\f*
\m 
\v 16 \wj Ma ngọzị na-adịrị anya unu, nʼihi na ha na-ahụ ụzọ, na ntị unu nʼihi na ha na-anụkwa ihe.\wj*
\v 17 \wj Nʼezie agwa m unu, ọtụtụ ndị amụma na ndị ezi omume ka ọ gụrụ agụụ ịhụ ihe unu na-ahụ, ma ha ahụghị ya, na ịnụ ihe unu na-anụ, ma ha anụghị ya.\wj*
\s1 Jisọs akọwaa ilu ọgha mkpụrụ
\p 
\v 18 \wj “Ugbu nụrụnụ nkọwa ilu ọgha mkpụrụ ahụ.\wj*
\v 19 \wj Mgbe onye ọbụla nụrụ oziọma nke alaeze ahụ, ma ọ ghọtaghị ya, ajọ onye ahụ na-abịa napụ ya ihe ahụ akụrụ nʼobi ya. Nke a bụ mkpụrụ ahụ nke dara nʼokporoụzọ.\wj*
\v 20 \wj Mkpụrụ nke dara nʼala nkume nọchiri anya obi mmadụ onye nụrụ oziọma ahụ, jirikwa oke ọṅụ nabata ya.\wj*
\v 21 \wj Ma ebe ha na-enweghị mgbọrọgwụ nʼime ha. Ha na-anọ nwa oge nta. Mgbe nsogbu maọbụ mkpagbu bịara nʼihi okwu ahụ, ngwangwa ha na-adachapụ.\wj*
\v 22 \wj Mkpụrụ nke dara nʼala ahụ ogwu ogwu dị nọchiri anya obi mmadụ onye nụrụ oziọma ahụ, ma ọchịchọ nke ụwa a, ya na itinye obi nʼakụ nke ụwa a, kpagidere okwu dị nʼime ya, mee ka ọ ghara ịmị mkpụrụ.\wj*
\v 23 \wj Ma mkpụrụ dara nʼala ọma ahụ nọchiri anya obi mmadụ onye gere ntị nʼoziọma ahụ, ghọtakwa ya. Ọ na-amịta mkpụrụ dị narị, maọbụ iri isii, maọbụ iri atọ karịa ihe akụnyere nʼime ya.”\wj*
\s1 Ilu mkpụrụ na-epu ahịhịa
\p 
\v 24 Ọ tụụrụ ha ilu ọzọ sị, \wj “Alaeze eluigwe dị ka mmadụ ọbụla nke kụrụ ezi mkpụrụ\wj*\f + \fr 13:24 \ft Ezi mkpụrụ bụ Oziọma ahụ.\f*\wj nʼubi ya.\wj*
\v 25 \wj Ma nʼotu abalị, mgbe onye ọbụla nọ nʼụra, onye iro gara nʼubi ahụ kụọ mkpụrụ na-epu ahịhịa nʼetiti ezi mkpụrụ ọka wiiti ahụ ọ kụrụ ma laa.\wj*
\v 26 \wj Mgbe mkpụrụ ọka wiiti ndị ahụ puputara, mepụta isi ọka, ahịhịa ahụ bidokwara ito.\wj*
\p 
\v 27 \wj “Ndị ọrụ onye nwe ubi ahụ bịara sị ya, ‘Nna anyị ukwu, ọ bụghị ezi mkpụrụ ọka ka ị kụrụ nʼubi gị? Ebeekwanụ ka ahịhịa ndị a si bịa?’\wj*
\p 
\v 28 \wj “Onye ọrụ ubi ahụ zara ha sị, ‘Ọ bụ onye iro m kụrụ ahịhịa ndị a.’\wj*
\p \wj “Ndị ọrụ ya jụrụ ya sị, ‘Ị chọrọ ka anyị gaa fopụtasịa ha?’\wj*
\p 
\v 29 \wj “Ma onye ọrụ ubi ahụ sịrị ha, ‘Ọ dịghị, nʼihi na mgbe unu na-achọ ihopu ahịhịa ndị ahụ, unu nwere ike site na-amaghị ama hopu ezi mkpụrụ ọka wiiti.\wj*
\v 30 \wj Hapụnụ ọka ahụ ka ha na ahịhịa ndị ahụ na-etokọta, tutu ruo mgbe a ga-ewe ihe ubi. Nʼoge ahụ aga m enye ndị owuwe ihe ubi iwu sị, burunu ụzọ chịkọtasịa ahịhịa ndị a niile, kee ha nʼukwu nʼukwu, kpọọ ha ọkụ. Ma kpokọtanụ ọka wiiti ndị a tinye ha nʼọba m.’ ”\wj*
\s1 Ilu banyere mkpụrụ mọstaadị
\p 
\v 31 Ọ tụkwara ilu ọzọ sị ha, \wj “Alaeze eluigwe dị ka mkpụrụ mọstaadị nke onye ọrụ ubi kụrụ nʼubi ya.\wj*
\v 32 \wj Ọ bụ ezie na ọ bụ mkpụrụ dịkarịsịrị nta karịa mkpụrụ ubi niile, ma mgbe mkpụrụ a toro, ọ na-adị ukwuu karịa ihe niile a kụrụ nʼubi. Ọ na-aghọ osisi buru ibu, nke ụmụ nnụnụ na-ezukwa ike nʼalaka ya.”\wj*
\s1 Ilu banyere ihe na-eko achịcha
\p 
\v 33 Ọ tụrụ ha ilu ọzọ sị, \wj “Alaeze eluigwe dị ka ihe na-eko achịcha,\wj*\f + \fr 13:33 \ft Maọbụ, \fqa yiist\f*\wj nke nwanyị na-ewere gwakọta nʼụtụ ọka e ji eme achịcha, tutu ruo mgbe ihe iko achịcha ahụ mere ka ụtụ ọka ahụ niile koo.”\wj*
\p 
\v 34 Oge niile ka Jisọs na-eji ilu na-agwa ndị mmadụ ndị a okwu. O nweghị oge ọbụla ọ gwara ha okwu hapụ iji ilu.
\v 35 O mere nke a ka okwu onye amụma kwuru mezuo, sị,
\q1 “Aga m eji ilu kwuo okwu mgbe m na-agwa ha okwu.
\q2 Aga m agwakwa ha ihe mmadụ ọbụla na-amaghị site nʼoge e kere ụwa.”\f + \fr 13:35 \ft \xt Abụ 78:2\xt*\f*
\s1 Nkọwa ilu mkpụrụ na-epu ahịhịa
\p 
\v 36 Emesịa, ọ hapụrụ igwe mmadụ ahụ baa nʼụlọ. Ndị na-eso ụzọ ya bịakwutere ya sị ya, “Kọwaara anyị ihe ilu ahụ ị tụrụ pụtara, ilu banyere ahịhịa puru nʼubi a kụrụ ọka.”
\p 
\v 37 Jisọs zara ha sị, \wj “Nwoke ahụ kụrụ mkpụrụ ahụ bụ Nwa nke Mmadụ.\wj*
\v 38 \wj Ubi ahụ a ghanyere mkpụrụ ndị ahụ bụ ụwa. Mkpụrụ nke a kụrụ nʼubi ahụ nọchiri anya ụmụ nke alaeze ahụ. Ahịhịa ahụ puru nʼubi ahụ nọchikwara anya ụmụ ajọ onye ahụ.\wj*
\v 39 \wj Onye iro ahụ gara kụọ mkpụrụ puru ahịhịa bụ ekwensu. Owuwe ihe ubi nọchiri anya ọgwụgwụ oge. Ndị owuwe ihe ubi bụkwa ndị mmụọ ozi.\wj*
\p 
\v 40 \wj “Dị ka e siri fopụtasịa ahịhịa ahụ kpọọ ha ọkụ, otu a ka ọ ga-adị mgbe ụwa ga-agwụ.\wj*
\v 41 \wj Nwa nke Mmadụ ga-ezipụ ndị mmụọ ozi ya ka ha gaa site nʼalaeze ya fopụtasịa ihe niile na-eme ka e mee mmehie, na ndị niile na-eme ajọ ihe.\wj*
\v 42 \wj Ha ga-atụbakwa ha nʼime oke ọkụ ahụ, ebe ha ga-anọ na-akwa akwa, na-atakwa ikikere eze.\wj*
\v 43 \wj Ma ndị niile bụ ndị ezi omume ga-enwu dị ka anyanwụ nʼime alaeze Nna ha. Onye ọbụla nwere ntị ịnụ ihe, ya nụrụ.\wj*
\s1 Ilu banyere akụ e zoro nʼala
\p 
\v 44 \wj “Alaeze eluigwe dị ka akụ e zoro nʼubi, nke otu nwoke chọpụtara zookwa ya ọzọ. Nwoke a jiri ọṅụ ree ihe niile o nwere, ma gaa zụta ubi ahụ.\wj*
\s1 Ilu banyere nkume dị oke ọnụahịa
\p 
\v 45 \wj “Ọzọ, alaeze eluigwe yiri nkume dị oke ọnụahịa nke onye na-azụ ahịa chọtara.\wj*
\v 46 \wj Mgbe ọ hụrụ nkume a, o ree ihe niile o nwere, were ego ya gaa zụrụ nkume a dị oke ọnụahịa.\wj*
\s1 Ilu banyere ụgbụ e ji egbu azụ
\p 
\v 47 \wj “Ọzọkwa, alaeze eluigwe dị ka ụgbụ e ji egbu azụ, nke a wụnyere nʼime osimiri, jiri ya jide azụ dị iche iche.\wj*
\v 48 \wj Mgbe ụgbụ a juru, ndị ọkụ azụ ahụ na-adọpụta ya. Nọdụ ala họpụtasịa ndị dị mma tinye ha nʼime nkata, ma tufuo ndị na-adịghị mma.\wj*
\v 49 \wj Otu a ka ọ ga-adị nʼọgwụgwụ oge. Ndị mmụọ ozi ga-abịa kewapụ ndị ọjọọ site nʼetiti ndị ezi omume,\wj*
\v 50 \wj ma tụbakwa ha nʼime oke ọkụ ahụ. Ebe ha ga-anọ na-akwa akwa na-atakwa ikikere eze.”\wj*
\p 
\v 51 Ọ jụrụ ha sị, \wj “Unu ghọtara ihe ndị a m na-ekwu?”\wj*
\p Ha zara sị ya, “E.”
\p 
\v 52 Ọ sịrị ha, \wj “Nʼihi nke a, onye nkuzi nke iwu ọbụla nke e mere ka ọ bụrụ onye na-eso ụzọ alaeze eluigwe, dị ka onyenwe ụlọ nke na-esite nʼụlọakụ ya na-ewepụta ihe ọhụrụ na ihe ochie.”\wj*
\s1 A dịghị asọpụrụ onye amụma
\p 
\v 53 Mgbe Jisọs tụsịrị ilu ndị a, o si ebe ahụ pụọ.
\v 54 O rutere nʼobodo ya, malite izi ha ihe nʼụlọ ekpere ha, nke a jukwara ha anya. Ha jụrịtara onwe ha ajụjụ na-asị, “Ebee ka o si nweta amamihe a? Ebee ka o si nweta ike ịrụ ọrụ ebube ndị a niile?
\v 55 Nwoke a, ọ bụghị nwa onye kapinta? Ọ bụ na-adịghị akpọ nne ya Meri? Jemis, Josef, Saimọn na Judas, ha abụghị ụmụnne ya ndị ikom?
\v 56 Ụmụnne ya ndị inyom niile, ha anọghị nʼetiti anyị?\f + \fr 13:56 \ft Ọ bụ na anyị amakwaghị ụmụnne ya ndị inyom, ndị anyị na ha bi nʼebe a.\f* Olee ebekwa ka nwoke a si nweta ihe ndị a?”
\v 57 Iwe were ha nʼebe ọ nọ.
\p Ma Jisọs gwara ha okwu sị ha, \wj “A na-asọpụrụ onye amụma nʼebe niile, ma a dịghị asọpụrụ ya nʼobodo a mụrụ ya, nakwa nʼezinaụlọ nke ya.”\wj*
\p 
\v 58 Ya mere, ọ rụghị ọtụtụ ọrụ ebube nʼebe ahụ, nʼihi na ha enweghị okwukwe nʼime ha.
\c 14
\s1 Ọnwụ Jọn omee baptizim
\p 
\v 1 Nʼoge a Herọd eze na-achị Galili nụrụ ihe banyere Jisọs.
\v 2 Ọ gwara ndị na-ejere ya ozi okwu sị ha, “Onye a bụkwanụ Jọn omee baptizim. O sitela na ndị nwụrụ anwụ bilie dịkwa ndụ ọzọ. Ọ bụ ya mere ike ịrụ ọrụ ebube ndị a ji dị nʼime ya.”
\p 
\v 3 Nʼihi na, Herọd jidere Jọn kee ya agbụ tinye ya nʼụlọ mkpọrọ, nʼihi Herodịas nwunye Filip nwanne ya nwoke.
\v 4 Nʼihi na Jọn gwara ya, “Ọ bụghị ihe ziri ezi nʼiwu ka ị kpọrọ ya.”
\v 5 Herọd chọrọrị igbu ya, ma ọ tụrụ egwu ndị mmadụ, nʼihi na ha weere Jọn dị ka onye amụma.
\p 
\v 6 Ma mgbe a na-eme mmemme icheta ọmụmụ Herọd, ada Herodịas tere egwu nʼihu Herọd, na nʼihu ndị ọbịa bịara nʼụbọchị ahụ. Obi tọrọ Herọd ụtọ nke ukwuu.
\v 7 Nke a mere o ji ṅụọ iyi kwee nkwa inye ya ihe ọbụla ọ rịọrọ.
\v 8 Ma dị ka nne ya si haziere ya, ọ rịọrọ eze Herọd sị, “Nye m isi Jọn omee baptizim nʼefere ugbu a.”
\v 9 Arịrịọ a wutere eze Herọd, ma nʼihi iyi ọ ṅụrụ na nʼihi ndị ọbịa ya niile, ọ chọghị ịla azụ nʼokwu ya. O nyere iwu ka e meere ya ihe ọ chọrọ.
\v 10 O ziri ozi ka e bipụ isi Jọn nʼụlọ mkpọrọ.
\v 11 E tinyere isi ya nʼefere bunye nwaagbọghọ ahụ. Ọ naara ya bulaara nne ya.
\v 12 Ndị na-eso ụzọ ya bịara buru ozu ya gaa lie. Ha gara kọọrọ Jisọs ihe mere.
\s1 Jisọs enye puku mmadụ ise nri
\p 
\v 13 Mgbe Jisọs nụrụ akụkọ a, ọ banyere nʼụgbọ mmiri gaa nʼọzara, ebe ọ ga-anọdụrụ onwe ya. Ma mgbe igwe mmadụ nụrụ ya, ha si obodo dị iche iche sooro ya nʼukwu ala.
\v 14 Mgbe o sitere nʼụgbọ mmiri ahụ rịdata, ọ hụrụ oke igwe mmadụ. O nwere ọmịiko nʼebe ha nọ, gwọọ ndị ọrịa nʼetiti ha.
\p 
\v 15 Nʼoge anyasị ụbọchị ahụ, ndị na-eso ụzọ ya bịakwutere ya sị ya, “Chi na-achọ iji. Ebe a abụkwaghị ebe ndị mmadụ bi. O nweghị nri a ga-azụta nʼọzara a. Zilaga igwe mmadụ ndị a ka ha gaa nʼime obodo zụọra onwe ha nri.”
\p 
\v 16 Ma Jisọs gwara ha sị, \wj “Ọ dịghị mkpa na ha ga-ala. Nyenụ ha nri ka ha rie.”\wj*
\p 
\v 17 Ha zara ya sị, “Ọ bụ naanị ogbe achịcha ise na azụ abụọ ka anyị nwere.”
\p 
\v 18 Ọ sịrị ha, \wj “Wetaranụ m ha nʼebe a.”\wj*
\v 19 Ọ gwara igwe mmadụ ahụ ka ha nọdụ ala nʼahịhịa. O weere ogbe achịcha ise na azụ abụọ ahụ welie anya ya elu nye Chineke ekele. Ọ nyawara achịcha ahụ, nye ha ndị na-eso ụzọ ya, ndị na-eso ụzọ ya nyere ha igwe mmadụ ahụ.
\v 20 Onye ọbụla riri rijuo afọ. Emesịa, ndị na-eso ụzọ Jisọs tụtụkọtara iberibe achịcha dara nʼala tụtụjuo ha nkata iri na abụọ.
\v 21 Ma ndị riri nri ahụ dị puku ụmụ nwoke ise, nʼagụnyeghị ụmụ nwanyị, na ụmụntakịrị.
\s1 Jisọs agaa ije nʼelu mmiri
\p 
\v 22 Mgbe nke a gasịrị, ọ gwara ndị na-eso ụzọ ya ka ha banye nʼụgbọ malite ịgafe ofe ọzọ nke osimiri ahụ. Ma ya onwe ya nọdụrụ maka izilaga ndị mmadụ ahụ.
\v 23 Mgbe ọ zilagasịrị igwe mmadụ ahụ, ọ rigooro nʼelu ugwu ikpe ekpere, naanị ya. Mgbe oge anyasị ruru, naanị ya nọkwa na-ebe ahụ.
\v 24 Ma nʼoge a ụgbọ mmiri ahụ esitela nʼebe ala dị nso gamie nʼelu osimiri, ebili mmiri na-ebugharịkwa ya, nʼihi na ifufe ahụ na-emegide ya.
\p 
\v 25 Ma ihe dị ka site nʼelekere atọ ruo elekere isii nke ụtụtụ, Jisọs bịakwutere ha, na-aga ije nʼelu osimiri.
\v 26 Mgbe ndị na-eso ụzọ ya hụrụ ya ka ọ na-aga ije nʼelu osimiri ahụ, obi lọrọ ha mmiri, ha sị, “Ọ bụkwanụ mmụọ o!” Ha tiri mkpu nʼihi egwu.
\p 
\v 27 Ma ngwangwa Jisọs sịrị ha, \wj “Nweenụ obi ike! O bụ m; unu atụla egwu.”\wj*
\p 
\v 28 Pita zara ya, “Onyenwe anyị, ọ bụrụ na ọ bụ gị, sị m bịakwute gị nʼelu mmiri.”
\p 
\v 29 Ọ sịrị ya, \wj “Bịa!”\wj*
\p Pita sitere nʼụgbọ ahụ pụta, bido ịga ije nʼelu mmiri ijekwuru Jisọs.
\v 30 Ma mgbe ọ hụrụ oke ebili mmiri ahụ ka ọ na-amagharị; egwu tụrụ ya. Ma mgbe ọ malitere imikpu nʼime mmiri ahụ, o tiri mkpu sị, “Onyenwe m! Zọpụta m!”
\p 
\v 31 Na-atụfughị oge, Jisọs setịpụrụ aka ya dọpụta Pita. Ọ sịrị ya, \wj “Gị onye okwukwe nta, nʼihi gịnị ka i ji nwee obi abụọ!”\wj*
\p 
\v 32 Ma mgbe ha rịbanyere nʼime ụgbọ ahụ ifufe ahụ kwụsịkwara.
\v 33 Ndị ahụ nọ nʼụgbọ ahụ kpọrọ isiala nye ya sị, “Nʼezie, ị bụ Ọkpara Chineke.”
\s1 Ọgwụgwọ ndị ọrịa na Genesaret
\p 
\v 34 Mgbe ha gafere nʼofe nke ọzọ, ha bịarutere nʼala Genesaret.
\v 35 Mgbe ndị obodo ahụ matara na ọ bụ ya, ha zisara ozi gburugburu obodo niile ahụ, ma dutere ya ndị niile ahụ na-adịghị ike.
\v 36 Ha rịọrọ ya ka o kwenye ka ha metụ ọ bụladị ọnụ uwe ya aka. Ndị niile metụrụ ya aka ka a gwọrọ.
\c 15
\s1 Omenaala ndị Farisii
\p 
\v 1 Mgbe ahụ, ụfọdụ ndị Farisii na ndị ozizi iwu si Jerusalem bịakwute Jisọs jụrụ ya ajụjụ sị,
\v 2 “Gịnị mere ndị na-eso ụzọ gị adịghị erube isi nʼomenaala ndị okenye? Ha anaghị akwọ aka ha tupu ha erie nri.”
\p 
\v 3 Ọ zara ha sị, \wj “Gịnị mere unu ji na-ada iwu Chineke nʼihi omenaala unu?\wj*
\v 4 \wj Nʼihi na Chineke sịrị, ‘Sọpụrụ nne gị na nna gị,’\wj*\f + \fr 15:4 \ft \xt Ọpụ 20:12; Dit 5:16\xt*\f*\wj na, ‘onye ọbụla kwujọrọ nna maọbụ nne ya ka e gbuo ya.\wj*\f + \fr 15:4 \ft Onye ahụ aghaghị ịnwụ\f*\wj ’\wj*\f + \fr 15:4 \ft \xt Ọpụ 21:17; Lev 20:9\xt*\f*
\v 5 \wj Ma unu na-asị, ọ bụrụ na onye ọbụla ga-asị nna maọbụ nne ya, ihe ọbụla bụ nke ị gara erite nʼaka m bụ ‘onyinye dịrị Chineke.’\wj*
\v 6 \wj Nʼihi ya, ha agaghị eji ya asọpụrụ nna ha maọbụ nne ha. Nʼụzọ dị otu a, unu na-eme ka okwu Chineke bụrụ ihe efu nʼihi omenaala unu.\wj*
\v 7 \wj Ndị ihu abụọ! Amụma ahụ Aịzaya buru banyere unu bụ eziokwu. Mgbe o kwuru sị,\wj*
\q1 
\v 8 \wj “ ‘Ndị a ji egbugbere ọnụ ha na-asọpụrụ m\wj*,
\q2 \wj ma obi ha dị anya nʼebe m nọ.\wj*
\q1 
\v 9 \wj Ofufe ha na-efe m bụ ihe efu,\wj*\f + \fr 15:9 \ft Ịkpọ isiala ha bụ ihe efu.\f*
\q2 \wj ozizi ha bụkwa ihe mmadụ nyere nʼiwu.’\wj*\f + \fr 15:9 \ft \xt Aịz 29:13\xt*\f* \wj ”\wj*
\s1 Ịdị ọcha dị mkpa
\p 
\v 10 Mgbe ahụ, ọ kpọrọ igwe mmadụ ahụ, sị ha, \wj “Geenụ ntị, ghọtakwanụ.\wj*
\v 11 \wj Ọ bụghị ihe banyere mmadụ nʼọnụ na-emerụ ya, kama ọ bụ ihe sị nʼọnụ onye ahụ pụta na-emerụ ya.”\wj*
\p 
\v 12 Ndị na-eso ụzọ ya bịakwutere ya sị, “Ị makwa na obi adịghị ndị Farisii mma nʼihi okwu ahụ i kwuru?”
\p 
\v 13 Ma ọ zara sị ha, \wj “Osisi ọbụla Nna m nke eluigwe na-ejighị aka ya kụọ ka a ga-ehopu.\wj*
\v 14 \wj Ya mere, unu echegbula onwe unu, nʼihi na ha bụ ndị ndu kpuru ìsì. Ma ọ bụrụ na onye ìsì eduo onye ìsì ibe ya ha abụọ adaba nʼime olulu.”\wj*
\p 
\v 15 Pita sịrị ya, “Kọwaara anyị ihe ilu a pụtara.”
\p 
\v 16 Ọ jụrụ ha sị, \wj “Unu ọ ka dị ka ndị na-enweghị nghọta?\wj*
\v 17 \wj Ọ bụ na unu aghọtaghị na ihe ọbụla nke na-aba nʼọnụ na-aga nʼime afọ, sịkwa nʼebe ahụ a nyụpụ ya nʼụlọ nsị?\wj*
\v 18 \wj Ma ihe si mmadụ nʼọnụ pụta na-esi ya nʼobi apụta. Ọ bụ ihe dị otu a na-emerụ mmadụ.\wj*
\v 19 \wj Nʼihi na ọ bụ nʼime obi mmadụ ka echiche ime ihe ọjọọ ndị a si apụta: igbu mmadụ, ịkwa iko niile, ịkwa iko nke ndị ikom nwere nwunye na ndị inyom nwere di, na izu ohi, na ama ụgha, na nkwulu.\wj*
\v 20 \wj Ihe ndị a bụ ihe na-emerụ mmadụ, ọ bụghị ma mmadụ kwọrọ aka tupu o rie nri, maọbụ na ọ kwọghị.”\wj*
\s1 Okwukwe nwanyị Kena
\p 
\v 21 Jisọs hapụrụ obodo ahụ gaa nʼakụkụ obodo Taịa na Saịdọn.
\v 22 Nʼebe ahụ, otu nwanyị onye Kenan bi nʼobodo ahụ bịakwutere ya rịọọ ya sị, “Onyenwe m, nwa Devid, biko meere m ebere. Ada m nwanyị nwere ajọ mmụọ nʼime ya nke na-esogbu ya oge niile.”
\p 
\v 23 Ma ọ gbara ya nkịtị. Emesịa ndị na-eso ụzọ ya bịakwutere ya rịọ ya sị ya, “Chụlaa nwanyị a! Lee ka o si eti mkpu na-esogharị anyị!”
\p 
\v 24 Ọ zara sị, \wj “Ezitere m naanị ijekwuru atụrụ furu efu nke ụlọ Izrel.”\wj*
\p 
\v 25 Ma ọ bịara daa nʼụkwụ ya rịọọ ya sị, “Onyenwe m, nyere m aka!”
\p 
\v 26 Ọ zara sị, \wj “O zighị ezi na a ga-ewere nri ụmụntakịrị tụpụrụ nkịta.”\wj*
\p 
\v 27 Ọ zara sị, “Ọ bụ eziokwu Onyenwe m. Ma a na-ekwekwa ka ụmụ nkịta nọ nʼokpuru tebul rie iberibe nri nke na-esi nʼelu tebul ha daa nʼala.”
\p 
\v 28 Jisọs zara sị ya, \wj “Nwanyị, okwukwe gị dị ukwuu! Laa, e meelara gị ihe ị na-arịọ.”\wj* Nʼotu oge ahụ a gwọrọ ada ya.
\s1 Jisọs agwọọ ọtụtụ ndị ọrịa
\p 
\v 29 Jisọs hapụrụ ebe ahụ lọghachi nʼakụkụ osimiri Galili. Ọ rịgooro nʼelu ugwu nọdụ ala.
\v 30 Igwe mmadụ dị ukwuu bịakwutere ya. Ha duteere ya ndị ngwụrọ, na ndị ìsì, na ndị aka ha na ndị ụkwụ ha kpọnwụrụ akpọnwụ, na ndị ogbi, na ọtụtụ ndị ọzọ. Ha tọgbọrọ ha nʼụkwụ ya, ọ gwọkwara ha niile.
\v 31 Ọ tụrụ mmadụ niile nʼanya mgbe ha hụrụ ndị ogbi ka ha bidoro ikwu okwu. Mgbe ha hụkwara na a gwọrọ ndị aka ha, na ndị ụkwụ ha nwụrụ anwụ, o jukwara ha anya ịhụ na ndị ngwụrọ gara ije, na ndị ìsì hụkwara ụzọ. Ha toro Chineke nke Izrel.
\s1 Jisọs enye puku mmadụ anọ nri
\p 
\v 32 Jisọs kpọrọ ndị na-eso ụzọ ya sị ha, \wj “Ana m emere igwe mmadụ ndị a obi ebere, nʼihi na mụ na ha anọọla ụbọchị atọ nʼebe a, ma ha eribeghị nri ọbụla. Agaghị m ezilaga ha na-erighị nri, nʼihi na ha nwere ike ịda nʼụzọ.”\wj*
\p 
\v 33 Ndị na-eso ụzọ ya sịrị, “Ebee ka anyị ga-enweta nri ga-ezuru igwe mmadụ ndị a nʼọzara a?”
\p 
\v 34 Jisọs jụrụ ha sị, \wj “Ogbe achịcha ole ka unu nwere?”\wj*
\p Ha sịrị ya, “Ogbe achịcha asaa na azụ ole na ole.”
\p 
\v 35 Ọ gwara igwe mmadụ ahụ ka ha nọdụ ala.
\v 36 O weere ogbe achịcha asaa na azụ ole na ole ahụ kelee Chineke ekele. Ọ nyawasịrị ha, nye ndị na-eso ụzọ ya. Ndị na-eso ụzọ ya nyekwara igwe mmadụ ahụ.
\v 37 Onye ọbụla nʼime ha riri, rijuo afọ. Ndị na-eso ụzọ ya tụtụkọtara iberibe ndị fọdụrụ nke juru nkata asaa.
\v 38 Ndị riri nri ahụ dị puku ụmụ nwoke anọ, nʼagụnyeghị ndị nwanyị na ụmụntakịrị.
\v 39 Mgbe o zilagara igwe mmadụ ahụ, ọ banyere nʼụgbọ mmiri gafee osimiri, bịaruo nʼobodo Magadan.
\c 16
\s1 Arịrịọ ka e gosi ihe ịrịbama
\p 
\v 1 Ndị Farisii na ndị Sadusii bịakwutere Jisọs ịnwa ya ọnwụnwa. Ha gwara ya sị, “Gosi anyị ihe ịrịbama si nʼeluigwe.”
\p 
\v 2 Ọ zara ha, \wj “Mgbe o ruru anyasị unu na-asị, ‘Ihu eluigwe ga-adị mma nʼihi na ọ na-acha uhie uhie.’\wj*
\v 3 \wj Nʼụtụtụ unu na-asị, ‘Anyị ga-enwe mmiri ozuzo taa nʼihi na ihu eluigwe na-acha uhie uhie ma na-eji oji.’ Lee na unu pụrụ ịkọwa ihu eluigwe, ma unu apụghị isite nʼihe ịrịbama ndị a unu na-ahụ anya kọwaa ihe oge a anyị nọ nʼime ya pụtara.\wj*
\v 4 \wj Ajọ ọgbọ nke jupụtara nʼịkwa iko, nke na-arịọkwa ihe ịrịbama. Ọ nweghị ihe ịrịbama ọzọ a ga-egosi ya karịa ihe ịrịbama Jona.”\wj* Mgbe ahụ ọ sitere nʼebe ahụ ha nọ pụọ.
\s1 Ihe na-eko achịcha ndị Farisii
\p 
\v 5 Mgbe ha gafesịrị nʼofe ọzọ, ndị na-eso ụzọ ya chetara na ha ejighị achịcha ọbụla.
\v 6 Nʼoge ahụ kwa, Jisọs dụrụ ha ọdụ sị ha, \wj “Lezienụ anya, ma na-ezekwa ihe ndị na-eko achịcha ndị Farisii na ndị Sadusii.”\wj*
\p 
\v 7 Ha malitere na-ekwurịta nʼetiti onwe ha, na-asị, ọ bụ nʼihi na anyị ewetaghị ogbe achịcha ọbụla.
\p 
\v 8 Ebe ọ bụ na Jisọs matara ihe ha na-eche, ọ sịrị, \wj “Unu ndị okwukwe nta! Gịnị mere unu ji na-esogbu onwe unu nʼihi na unu enweghị achịcha?\wj*
\v 9 \wj Olee mgbe unu ga-amata ihe? Ọ bụ na unu echetaghị puku mmadụ ise ahụ m jiri ogbe achịcha ise mee ka ha rijuo afọ? Ọ bụ nkata ole ka unu tụtụjuru?\wj*
\v 10 \wj Unu echetakwaghị na m ji ogbe achịcha asaa zụọ puku mmadụ anọ? Iberibe achịcha juru nkata ole ka unu tụtụkọtara?\wj*
\v 11 \wj Gịnị mere unu aghọtaghị na ọ bụghị ihe banyere achịcha ka m na-ekwu? Cheenụ onwe unu nche nʼebe ihe na-eko achịcha ndị Farisii na ndị Sadusii nọ.”\wj*
\v 12 Mgbe ahụ ka ha ghọtara na ihe ọ na-akọwara ha abụghị ihe banyere ihe na-eko achịcha nke a na-ata ata, kama ọ bụ ihe banyere ozizi ndị Farisii na ndị Sadusii.
\s1 Ọgbụgba ama Pita
\p 
\v 13 Mgbe Jisọs bịaruru obodo a na-akpọ Sizaria Filipai, ọ jụrụ ndị na-eso ụzọ ya ajụjụ sị ha, \wj “Onye ka ndị mmadụ na-asị na Nwa nke Mmadụ bụ?”\wj*
\p 
\v 14 Ha zara ya sị, “Ụfọdụ na-asị na ị bụ Jọn omee baptizim, ụfọdụ na-asị na ị bụ Ịlaịja, ndị ọzọ na-asịkwa na ị bụ Jeremaya, maọbụ otu nʼime ndị amụma.”
\p 
\v 15 Ọ jụrụ ha sị, \wj “Ma unu onwe unu, ọ bụ onye ka unu na-asị na m bụ?”\wj*
\p 
\v 16 Saimọn Pita zara sị ya, “Ị bụ Kraịst\f + \fr 16:16 \ft Maọbụ, \fqa Onye nzọpụta\f* ahụ, Ọkpara Chineke dị ndụ.”
\p 
\v 17 Jisọs gwara ya sị, \wj “Saimọn Pita nwa Jona, ị bụ onye a gọziri agọzi, nʼihi na anụ ahụ na ọbara ekpugheghị ya nye gị. Kama, ọ bụ Nna m bi nʼeluigwe mere ka ị mata ya.\wj*
\v 18 \wj Ma mụ onwe m na-agwa gị, na gị onwe gị bụ Pita.\wj*\f + \fr 16:18 \ft Nʼasụsụ ndị Griik \fq Pita \ft pụtara \fq Nkume\fqa .\f*\wj Ọ bụkwa nʼelu nkume a ka m ga-ewu ụlọ chọọchị m. Ike niile nke ọkụ ala mmụọ apụghịkwa iguzo megide ya.\wj*
\v 19 \wj Aga m enye gị mkpisi igodo alaeze eluigwe. Ihe ọbụla ị ga-eke agbụ nʼelu ụwa, ka a ga-ekekwa agbụ nʼeluigwe. Ihe ọbụla ị ga-atọpụ nʼagbụ nʼụwa, a ga-atọpụkwa ya nʼeluigwe.”\wj*
\v 20 Mgbe ahụ, o nyere ndị na-eso ụzọ ya iwu ka ha ghara ime ka onye ọbụla mata na ya bụ Kraịst ahụ.
\s1 Jisọs ekwuo okwu ọnwụ ya
\p 
\v 21 Site nʼoge ahụ Jisọs malitere ịkọwara ndị na-eso ụzọ ya, na ya aghaghị ịga Jerusalem, ebe ọ ga-ahụ ọtụtụ ahụhụ dị iche iche site nʼaka ndị okenye, na ndịisi nchụaja, na ndị ozizi iwu. O mere ka ha mata na aghaghị igbu ya, ma nʼụbọchị nke atọ, a ga-eme ka o site nʼọnwụ bilie.
\p 
\v 22 Pita duuru ya pụọ nʼotu akụkụ, nọdụ nʼebe ahụ baara ya mba sị ya, “Onyenwe m, Chineke ekwela. Ihe ndị a agaghị adakwasị gị!”
\p 
\v 23 Ma o chigharịrị sị Pita, \wj “Si nʼebe m nọ pụọ, ekwensu! Ị bụ ihe mgbochi nye m. Nʼihi na ihe ị na-eche echiche ya bụ naanị echiche mmadụ, ọ bụghị uche Chineke.”\wj*
\p 
\v 24 Mgbe ahụ Jisọs gwara ndị na-eso ụzọ ya sị, \wj “Ọ bụrụ na onye ọbụla achọọ ịbụ onye na-eso ụzọ m, ya buru ụzọ jụ onwe ya, buru obe ya, soro m nʼazụ.\wj*
\v 25 \wj Nʼihi na onye ọbụla na-eche ndụ ya nche ka ọ hapụ ifunarị ya ga-atụfu ya. Ma onye ọbụla tufuru ndụ ya nʼihi m, ga-achọtakwa ya.\wj*
\v 26 \wj Nʼihi na uru gịnị ka mmadụ nwetara ma ọ bụrụ na o ritechaa ụwa niile nʼuru ma tufuo ndụ ya? Maọbụ gịnị bụ ihe ahụ dị nʼụwa nke mmadụ ga-eji gbanwee ndụ ya?\wj*
\v 27 \wj Nʼihi na Nwa nke Mmadụ ga-abịa nʼebube nke Nna ya, ya na ndị mmụọ ozi ya. Mgbe ahụ ka ọ ga-ekpe onye ọbụla ikpe dị ka ọrụ ya si dị.\wj*
\p 
\v 28 \wj “Nʼezie asị m unu, ụfọdụ nʼime ndị guzo nʼebe, agaghị edetụ ọnwụ ire, tụpụ ha ahụ Nwa nke Mmadụ ka ọ na-abịa nʼalaeze ya.”\wj*
\c 17
\s1 Nnwogha Jisọs nwoghara
\p 
\v 1 Mgbe ụbọchị isii gasịrị, Jisọs kpọọrọ Pita, na Jemis na Jọn nwanne ya, rigoro nʼugwu dị elu ebe naanị ha nọdụrụ.
\v 2 Nʼebe ahụ a gbanwere ọdịdị ya nʼihu ha, ihu ya na-enwupụ dị ka anyanwụ, uwe ya chapụkwara dị ka ìhè.
\v 3 Nʼotu ntabi anya ahụ, ha hụrụ Mosis na Ịlaịja ka ha na ya na-ekwurịta okwu.
\p 
\v 4 Mgbe ahụ Pita sịrị Jisọs, “Onyenwe anyị. Ọ dị mma ka anyị niile nọdụ nʼebe a. Ọ bụrụ na ị ga-enye m ike, aga m ewu ụlọ ikwu atọ nʼebe a. Otu nʼime ụlọ ndị a ga-abụ nke gị, otu nke Mosis, nke ọzọ nke Ịlaịja.”
\p 
\v 5 Mgbe ọ ka kpụ okwu nʼọnụ, igwe ojii nke na-enwu enwu kpuchiri ha, olu sitere nʼigwe ojii ahụ daa sị, “Onye a bụ Ọkpara m, onye m hụrụ nʼanya, onye ihe ya dị m ezi mma. Geenụ ya ntị.”
\p 
\v 6 Mgbe ndị na-eso ụzọ ya nụrụ olu a, ha dara nʼala nʼihi egwu.
\v 7 Ma Jisọs jekwuuru ha metụ ha aka sị ha, \wj “Bilienụ, unu atụla egwu.”\wj*
\v 8 Mgbe ha lelitere anya ha, o nwekwaghị onye ọzọ ha hụrụ ma ọ bụghị naanị Jisọs.
\p 
\v 9 Ma mgbe ha si nʼelu ugwu ahụ na-arịdata, Jisọs nyere ha iwu, sị, \wj “Unu agwala onye ọbụla ihe unu hụrụ tutu ruo mgbe Nwa nke Mmadụ ga-esi nʼọnwụ bilie.”\wj*
\p 
\v 10 Ndị na-eso ụzọ ya jụrụ ya sị, “Gịnị mere ndị ozizi iwu ji na-ekwu na Ịlaịja aghaghị ibu ụzọ bịa?”
\p 
\v 11 Ọ zara sị, \wj “Ọ bụ ezie, Ịlaịja na-abịa, ọ ga-emekwa ka ihe niile dị ka ọ dị na mbụ.\wj*
\v 12 \wj Ma Ịlaịja abịalarị, ma ndị mmadụ amataghị ya. Kama ndị mmadụ emeela ya ihe ọjọọ dị iche iche. Otu a kwa ka mụ onwe m bụ Nwa nke Mmadụ ga-esi ahụ ahụhụ site nʼaka ha.”\wj*
\v 13 Mgbe ahụ ndị na-eso ụzọ ya ghọtara na ọ bụ Jọn omee baptizim ka ọ na-ekwu banyere ya.
\s1 Ọ gwọrọ nwa akwụkwụ
\p 
\v 14 Mgbe ha bịarutere nʼebe igwe mmadụ ahụ nọ, otu nwoke bịakwutere ya gbuo ikpere nʼihu ya,
\v 15 rịọọ ya sị, “Onyenwe m, biko, meere nwa m nwoke ebere, nʼihi na akwụkwụ na-adọ ya. Ọ na-ata oke ahụhụ, ọtụtụ mgbe ọ na-adaba nʼime ọkụ maọbụ nʼime mmiri.
\v 16 Ma ekuteere m ya ndị na-eso ụzọ gị ka ha gwọọ ya, ma ha enweghị ike ime ka ahụ dị ya mma.”
\p 
\v 17 Jisọs zara sị, \wj “Unu ọgbọ a na-enweghị okwukwe, ndị na-adịghị erubekwa isi. Ruo ole mgbe ka mụ na unu ga-anọ? Ruo ole mgbe ka m ga-anọ na-anagide ekweghị ekwe unu? Kpọtaranụ m nwata ahụ nʼebe a.”\wj*
\v 18 Jisọs baara mmụọ ọjọọ ahụ mba, mee ka o si nʼime nwata ahụ pụta. Otu mgbe ahụ, mmụọ ọjọọ ahụ pụtara, nwata ahụ bụ onye agwọkwara nʼotu oge ahụ.
\p 
\v 19 Mgbe e mesịrị, ndị na-eso ụzọ Jisọs bịakwutere ya na nzuzo jụọ ya sị, “Gịnị mere o ji siere anyị ike ịchụpụ mmụọ ọjọọ ahụ?”
\p 
\v 20 Ọ sịrị ha, \wj “Ọ bụ nʼihi na okwukwe unu nwere esighị ike. Nʼezie, agwa m unu, ọ bụrụ na unu e nwee okwukwe nke dị nta ka mkpụrụ mọstaadị, unu nwere ike ị sị ugwu a, ‘Site nʼebe a wezuga onwe gị,’ ọ ga-apụtakwa. Ọ dịghị ihe unu na-agaghị enwe ike ime.\wj*
\v 21 \wj Ma mmụọ ọjọọ dị otu a agaghị apụ, ma ọ bụghị naanị site nʼikpe ekpere na ibu ọnụ.”\wj*\f + \fr 17:21 \ft Ụfọdụ akwụkwọ na-edebanye okwu ndị a dịka ọ dị nʼakwụkwọ \xt Mak 9:29\xt*\ft .\f*
\s1 Jisọs ekwuo okwu ọnwụ ya ọzọ
\p 
\v 22 Mgbe ha gbakọrọ na Galili, Jisọs gwara ha sị, \wj “A ga-arara Nwa nke Mmadụ nye nʼaka ndị mmadụ.\wj*
\v 23 \wj Ha ga-egbukwa ya, ma nʼụbọchị nke atọ a ga-eme ka o si nʼọnwụ bilie.”\wj* Nke a wutere ha nke ukwuu.
\s1 Ịtụ ụtụ ụlọnsọ ukwu
\p 
\v 24 Mgbe ha bịaruru na Kapanọm, ndị na-ana ụtụ nʼihi ụlọnsọ\f + \fr 17:24 \ft Didrakma abụọ bụ ọnụ ego ụtụ ụlọnsọ.\f* bịakwutere Pita jụọ ya sị, “Onye ozizi unu ọ dịghị atụ ụtụ ụlọnsọ?”
\p 
\v 25 Pita zara ha sị, “E, ọ na-atụ ụtụ.”
\p Mgbe ọ batara nʼụlọ, Jisọs buru ụzọ jụọ ya sị, \wj “Gịnị ka i chere banyere nke a Saimọn? Ọ bụ nʼaka ndị ole ka ndị eze ụwa si anakọta ụtụ taks? Ọ bụ nʼaka ụmụ ha, ka ọ bụ nʼaka ndị ọbịa?”\wj*
\p 
\v 26 Ma mgbe Pita zara ya sị, “Ọ bụ site nʼaka ndị ọbịa.”
\p Jisọs sịrị ya, \wj “Ọ dị mma. Iwu ejighị ndị bụ ụmụ.\wj*
\v 27 \wj Ma otu ọ dị, achọghị m ka anyị mee ka iwe wee ha. Gaa nʼosimiri ahụ tụnye nko azụ gị nʼime ya. Meghe ọnụ azụ mbụ ị ga-egbute. Ị ga-ahụ otu mkpụrụ ego nʼime ọnụ ya. Were ya nye ha, ka ọ bụrụ ụtụ nke mụ na gị.”\wj*
\c 18
\s1 Onye dịkarịrị ukwuu
\p 
\v 1 Nʼoge ahụ kwa, ndị na-eso ụzọ Jisọs bịakwutere ya jụọ ajụjụ sị, “Olee onye dị ukwuu karịa ibe ya nʼalaeze eluigwe?”
\p 
\v 2 Ọ kpọrọ otu nwantakịrị, onye o mere ka o guzoro nʼetiti ha,
\v 3 ọ sịrị, \wj “Nʼezie, agwa m unu, ọ bụrụ na unu agbanweghị ma dịrị ka ụmụntakịrị, unu agaghị aba nʼalaeze eluigwe.\wj*
\v 4 \wj Onye ọbụla wedara onwe ya ala dị ka nwantakịrị a bụ onye dịkarịsịrị ukwuu nʼalaeze eluigwe.\wj*
\v 5 \wj Onye ọbụla nabatara nwantakịrị dị otu a nʼihi m, bụ onye nabatara m.\wj*
\s1 Ihe na-eweta ịda mba
\p 
\v 6 \wj “Ma ọ bụrụ na onye ọbụla nʼime unu emee ka otu nʼime ndị a dị nta, bụ ndị tụkwasịrị m obi, jehie nʼokwukwe ya, ọ kaara onye ahụ mma na e kedoro ya nkume igwe nri nʼolu, tụnye ya nʼoke osimiri ka mmiri rie ya.\wj*
\v 7 \wj Ahụhụ ga-adịrị ụwa nʼihi ihe ndị na-eme ka mmadụ jehie. Ihe ndị na-eme ka mmadụ daba nʼọnwụnwa aghaghị ịbịa, ma ahụhụ ga-adịrị onye ahụ nke ọ ga-esite nʼaka ya bịa.\wj*
\v 8 \wj Nʼihi nke a, ọ bụrụ na aka gị maọbụ ụkwụ gị na-eme ka i jehie, gbupụ ya tufukwaa ya. Ọ kaara gị mma inwe ọrụsị maọbụ daa ngwụrọ baa na ndụ, karịa na ị ga-enwe aka abụọ maọbụ ụkwụ abụọ, a tụnye gị nʼọkụ ebighị ebi.\wj*
\v 9 \wj Ọzọ, ọ bụrụ na anya gị na-eme ka i jehie, ghụpụ ya tufuo. Ọ ga-akara gị mma na i nwere otu anya baa na ndụ, karịa inwe anya abụọ, a tụnye gị nʼọkụ ala mmụọ.\wj*
\s1 Atụrụ furu efu
\p 
\v 10 \wj “Lezienụ anya ka unu ghara ileda otu nʼime ụmụntakịrị ndị a anya. Nʼihi na nʼeluigwe, ndị mmụọ ozi ha na-anọ nʼihu Nna m mgbe niile.\wj*
\v 11 \wj Nʼihi na Nwa nke mmadụ bịara ịzọpụta ndị furu efu.\wj*\f + \fr 18:11 \ft Ụfọdụ akwụkwọ mgbe ochie na-edebanye okwu ndị a dịka ọ dị nʼakwụkwọ \xt Luk 19:10\xt*\ft .\f*
\p 
\v 12 \wj “Gịnị ka unu chere? Ọ bụrụ na ọ dị onye nwere narị atụrụ, ma otu nʼime ha akpafuo, gịnị ka ọ ga-eme? Ọ gaghị ahapụ iri atụrụ itoolu na itoolu fọdụrụ pụọ jegharịa nʼugwu na ndịda niile, ịchọ atụrụ ahụ kpafuru akpafu?\wj*
\v 13 \wj Ọ bụrụkwa na ọ chọta ya, gịnị ka ọ ga-eme? Nʼezie, agwa m unu, ọ ga-aṅụrị oke ọnụ nʼihi otu atụrụ a karịa iri atụrụ itoolu na itoolu ndị ọzọ ahụ na-agahieghị ụzọ.\wj*
\v 14 \wj Ya mere, ọ bụghị nzube Nna m nke bi nʼeluigwe ka otu nʼime ụmụnta ndị a ala nʼiyi.\wj*
\s1 Mmehie nke nwanne
\p 
\v 15 \wj “Ọ bụrụ na nwanna gị emehie megide gị, jekwuru ya ebe naanị gị na ya nọ, tụọ ya mmehie nʼanya. Ọ bụrụ na o gee gị ntị, i ritela nwanna gị nʼuru.\wj*
\v 16 \wj Ma ọ bụrụ na o geghị gị ntị, kpọrọ otu onye maọbụ mmadụ abụọ ọzọ laghachi azụ nʼebe ọ nọ, ‘ka okwu ọbụla ekwuru bụrụ nke mmadụ abụọ maọbụ atọ ga-agba akaebe banyere ya.’\wj*\f + \fr 18:16 \ft \xt Dit 19:15\xt*\ft .\f*
\v 17 \wj Ọ bụrụ na o geghị ha ntị, gwa ndị chọọchị, ma ọ bụrụ na o geghịkwa ọ bụladị ndị chọọchị ntị, were ya dị ka onye mba ọzọ maọbụ onye ọna ụtụ.\wj*
\p 
\v 18 \wj “Nʼezie, asị m unu, na ihe ọbụla unu kere agbụ nʼụwa a, e keela ya rịị agbụ nʼeluigwe. Ihe ọbụla kwa unu tọpụrụ nʼụwa, a tọpụkwala ya rịị nʼeluigwe.\wj*
\p 
\v 19 \wj “Ọzọ, ana m agwa unu nʼezie a sị, ọ bụrụ na mmadụ abụọ nʼetiti unu ekwekọrịta nʼụwa banyere ihe ọbụla unu na-arịọ nʼekpere Nna m bi nʼeluigwe ga-emezuru unu ihe ahụ.\wj*
\v 20 \wj Nʼihi na ebe ọbụla mmadụ abụọ maọbụ atọ zukọtara nʼaha m, mụ onwe m nọ nʼetiti ha.”\wj*
\s1 Mkpa ọ dị inwe obi mgbaghara
\p 
\v 21 Mgbe ahụ Pita bịakwutere ya jụọ ya ajụjụ sị, “Onyenwe anyị, ọ bụ ugboro ole ka m ga-agbaghara nwanne m nke mehiere megide m? Ọ bụ ugboro asaa?”
\p 
\v 22 Jisọs zara sị ya, \wj “Ọ bụghị ugboro asaa. Kama ị ga-agbaghara ya ruo iri ugboro asaa ụzọ asaa.\wj*\f + \fr 18:22 \ft Ọnụọgụgụ nke a bụ narị anọ na iri itoolu.\f*
\p 
\v 23 \wj “A ga-eji alaeze eluigwe tụnyere eze ahụ kpebiri ka ya na ndị ọrụ ya gụzie ego ya ha ji.\wj*
\v 24 \wj Mgbe ha malitere na-apịazi, a kpọtaara eze ahụ otu onye nke ji ya ụgwọ ruru puku talenti iri.\wj*\f + \fr 18:24 \ft Ihe ruru nde naịra abụọ maọbụ karịa.\f*
\v 25 \wj Nwoke ahụ enweghị ihe ọ ga-eji kwụọ ụgwọ o ji. Nna ya ukwu nyere iwu ka e refuo ya na nwunye ya na ụmụ ya, na ihe niile o nwere, ka akwụghachi ụgwọ o ji.\wj*
\p 
\v 26 \wj “Ma ohu ahụ dara nʼala, gbukwaa ikpere ya nʼala, rịọ ya arịrịọ sị, ‘Onyenwe m, biko, nwee ntachiobi nʼebe m nọ. Aga m akwụghachikwa gị ụgwọ niile m ji gị.’\wj*
\v 27 \wj Nna ukwu onye ọrụ ahụ nwere ọmịiko nʼebe ọ nọ, meere ya ebere. Ọ sịrị ya akwụghachila ụgwọ o ji ọzọ.\wj*
\p 
\v 28 \wj “Ma mgbe ohu ahụ sitere nʼebe ahụ pụọ, ọ hụrụ otu ohu ibe ya ji ya ụgwọ otu narị denarị.\wj*\f + \fr 18:28 \ft Ihe ruru otu puku naịra maọbụ o jiri ihe ntakịrị karịa.\f*\wj O jidere ya nʼaka ike, machie ya aka nʼakpịrị, sị ya, ‘Kwụghachi m ụgwọ i ji m ugbu a.’\wj*
\p 
\v 29 \wj “Ya mere, ohu ibe ya ahụ dara nʼala nʼihu ya rịọọ ya ka o nye ya nwantịntị oge. Ọ rịọkwara ya sị, ‘Enyi m, biko nwee ntachiobi, aga m akwụghachi gị ụgwọ m ji gị.’\wj*
\p 
\v 30 \wj “Ma o kwenyeghị, kama ọ gara tụba ya nʼụlọ mkpọrọ, ebe ọ ga-anọ ruo mgbe ọ kwụsịrị ụgwọ niile o ji ya.\wj*
\v 31 \wj Mgbe ndị ohu ibe ya hụrụ ihe mere, o wutere ha nke ukwuu. Ha jekwuru Nna ha ukwu kọọrọ ya ihe niile ndị a.\wj*
\p 
\v 32 \wj “Nʼihi nke a Nna ya ukwu kpọrọ ohu ahụ sị ya, ‘Ohu obi ọjọọ! Agbaghara m gị ụgwọ ahụ niile i ji, nʼihi na ị rịọrọ m arịrịọ.\wj*
\v 33 \wj Ọ bụ na ị kwesighị inwe obi ebere nʼebe ohu ibe gị nọ, dị ka m si mere gị ebere?’\wj*
\v 34 \wj Nʼihi iwe, Nna ya ukwuu nyefere ya nʼaka ndị nche na-eche ndị nọ nʼụlọ mkpọrọ ka ha taa ya ahụhụ, ruo mgbe ọ kwụchara ụgwọ niile o ji.\wj*
\p 
\v 35 \wj “Otu a ka Nna m bi nʼeluigwe ga-emekwa unu, ma ọ bụrụ na unu ejighị obi unu niile gbaghara ụmụnna unu.”\wj*
\c 19
\s1 Ozizi banyere ọlụlụ di na nwunye
\p 
\v 1 Mgbe Jisọs kwusiri okwu ndị a, o hapụrụ Galili gaa na mpaghara Judịa, nke dị nʼofe osimiri Jọdan.
\v 2 Igwe mmadụ dị ukwuu sooro ya. Ọ gwọkwara ndị ahụ na-esighị ike nʼetiti ha nʼebe ahụ.
\p 
\v 3 Ụfọdụ ndị Farisii bịakwutere ya i nwalee ya, sị, “O ziri ezi nʼiwu na nwoke ga-agbara nwunye ya alụkwaghị m nʼihi ihe ọbụla?”
\p 
\v 4 Ọ zara ha sị, \wj “Ọ bụ na unu agụtabeghị na akwụkwọ nsọ, na Onye kere ha na mbụ kere ha nwoke na nwanyị.\wj*
\v 5 \wj Nʼihi nke a ka nwoke ga-eji hapụ nne ya na nna ya e jikọta ya na nwunye ya. Ha abụọ ga-abụkwa otu anụ ahụ.\wj*\f + \fr 19:4,5 \ft \xt Jen 1:27; Jen 2:24\xt*\f*
\v 6 \wj Ya mere, ha abụkwaghị mmadụ abụọ ọzọ, kama otu anụ ahụ. Ya mere, ihe Chineke jikọtara, ka mmadụ ọbụla atọsala ya.”\wj*
\p 
\v 7 Ha jụrụ ya sị, “Gịnị mekwaranụ Mosis ji nye iwu si na nwoke ọbụla nwere ohere ide akwụkwọ alụkwaghị m nye nwunye ya?”
\p 
\v 8 Ọ zara ha sị ha, \wj “Ọ bụ nʼihi na unu bụ ndị mkpọchi obi, ya mere Mosis jiri hapụ unu ka unu gbaa nwunye unu alụkwaghị m; ma ọ dịghị otu a site na mbụ.\wj*
\v 9 \wj Ma ana m asị unu, onye ọbụla ga-ahapụ nwunye ya lụrụ onye ọzọ, ma ọ bụghị nʼihi na o jidere nwunye ya na mmehie ịkwa iko, onye ahụ emeela mmehie ịkwa iko ma ọ lụọ nwanyị ọzọ.”\wj*
\p 
\v 10 Ndị na-eso ụzọ ya sịrị ya, “Ọ bụrụ na o si otu a dịrị, ọ ka mma na mmadụ alụghị nwunye ma ọlị.”
\p 
\v 11 Ma ọ zara sị ha, \wj “Ọ bụghị mmadụ niile ga-anagide okwu a. Naanị ndị e nyere ike ime ya ga-anagide ya.\wj*
\v 12 \wj Ma ụfọdụ ndị mmadụ ka a mụrụ ka ha bụrụ onozi, ndị ọzọ bụkwa ndị mmadụ ibe ha mere otu a. Ndị ọzọ dịkwa ndị jiri aka ha họrọ ibu onozi\wj*\f + \fr 19:12 \ft Nke a bụ ọnọdụ alụghị di maọbụ nwunye nke mmadụ kpebiri nʼonwe ya.\f*\wj nʼihi alaeze eluigwe. Onye pụrụ ịnara nke a, ya nara ya.”\wj*
\s1 Jisọs agọzie ụmụntakịrị
\p 
\v 13 Mgbe ahụ e kuteere ya ụmụntakịrị ka o bikwasị ha aka, kpeekwara ha ekpere. Ma ndị na-eso ụzọ ya baara ndị kutere ha mba.
\p 
\v 14 Ma Jisọs sịrị ha, \wj “Kweenụ ka ụmụntakịrị bịakwute m, unu egbochikwala ha. Nʼihi na alaeze eluigwe bụ nke ndị dị otu a.”\wj*
\v 15 O bikwasịrị ha aka nʼisi gọzie ha niile tupu ọ hapụ ha pụọ.
\s1 Onye ọgaranya
\p 
\v 16 Otu onye bịakwutere ya, jụọ ya ajụjụ sị, “Ezi onye ozizi, olee ezi ihe m ga-eme ka m keta ndụ ebighị ebi?”
\p 
\v 17 Jisọs sịrị ya, \wj “Gịnị mere i ji ajụ m ajụjụ banyere ihe bụ ezi ihe? Ọ dị naanị otu onye nke bụ ezi mmadụ. Ọ bụrụ na ị chọrọ ịba nʼime ndụ ahụ, debe iwu niile e nyere.”\wj*
\p 
\v 18 Ọ jụrụ ya ajụjụ sị, “Olee iwu ndị m ga-edebe?”
\p Jisọs zara ya, \wj “ ‘Egbula mmadụ, akwala iko, ezula ohi, ekwula okwu ụgha.\wj*
\v 19 \wj Sọpụrụ nne gị na nna gị.\wj*\f + \fr 19:19 \ft \xt Ọpụ 20:12-16; Dit 5:16-20\xt*\f*\wj Ọzọ, hụkwa onye agbataobi gị nʼanya dị ka onwe gị.’\wj*\f + \fr 19:19 \ft \xt Lev 19:18\xt*\f*\wj ”\wj*
\p 
\v 20 Nwokorobịa ahụ sịrị ya, “Edebezuchaala m iwu ndị a siterịị na mgbe m dị na nwata. Gịnị ọzọ fọdụụrụ m ime?”
\p 
\v 21 Jisọs zara sị ya, \wj “Ọ bụrụ na ị chọrọ ịbụ onye zuruoke nʼezie, laa nʼụlọ gị ree ihe niile i nwere, nyekwa ndị ogbenye ego i retara. Ị ga-enwe akụ nʼeluigwe, mgbe ahụ, bịakwa soro m.”\wj*
\p 
\v 22 Mgbe nwokorobịa ahụ nụrụ okwu a, ọ lara na mwute, nʼihi na ọ bụ ọgaranya.
\p 
\v 23 Mgbe ahụ Jisọs gwara ndị na-eso ụzọ ya sị, \wj “Nʼezie agwa m unu, ọ bụ nnọọ ihe siri ike na onye ọgaranya ga-abanye nʼalaeze eluigwe.\wj*
\v 24 \wj Ọzọkwa, asị m unu, ọ dịịrị ịnyịnya kamel mfe ịgafe nʼanya agịga, karịa ọgaranya ịbanye nʼalaeze Chineke.”\wj*
\p 
\v 25 Okwu a o kwuru tụrụ ndị na-eso ụzọ ya nʼanya. Ha sịrị, “Ọ bụrụ na o si otu a dịrị, onye kwanụ ka a ga-azọpụta?”
\p 
\v 26 Jisọs legidere ha anya sị ha, \wj “Nʼebe mmadụ nọ nke a bụ ihe a na-apụghị ime, ma ọ dịghị ihe rara ahụ ime nʼebe Chineke nọ.”\wj*
\p 
\v 27 Mgbe ahụ Pita jụrụ ya sị, “Lee, anyị ahapụla ihe niile soro gị, gịnị ga-abụ ụgwọ ọrụ anyị?”
\p 
\v 28 Jisọs zara sị ya, \wj “Nʼezie agwa m unu, mgbe a ga-agbanwe ihe niile, mgbe Nwa nke Mmadụ ga-anọkwasị nʼelu ocheeze ebube ya, nʼalaeze ahụ, nʼezie, unu bụ ndị na-eso ụzọ m ga-anọkwasị nʼocheeze iri na abụọ ahụ, na-ekpe ebo iri na abụọ nke Izrel ikpe.\wj*
\v 29 \wj Onye ọbụla hapụrụ ụlọ ya, na ụmụnne ya nwoke, na ụmụnne ya nwanyị, na nne ya na nna ya, na ụmụntakịrị ya, maọbụ ala o nwere, soro m, ga-anata dị ka ụgwọ ọrụ okpukpu narị ihe ọ hapụrụ, natakwa alaeze. Ọ ga-eketakwa ndụ ebighị ebi.\wj*
\v 30 \wj Ma ọtụtụ ndị bu ụzọ ga-abụ ndị ikpeazụ, ma ndị ikpeazụ ga-abụkwa ndị bu ụzọ.”\wj*
\c 20
\s1 Ilu banyere ndị ọrụ ubi
\p 
\v 1 \wj “Ihe ọzọ a ga-eji tụnyere alaeze eluigwe bụ nwoke nwere ala ubi, onye pụrụ nʼisi ụtụtụ ịkpọta ndị ọrụ ga-arụ ọrụ nʼubi vaịnị ya.\wj*
\v 2 \wj Ya na ndị ọrụ ahụ kwekọtara na ọ ga-akwụ ha otu denarị, nʼihi ọrụ ụbọchị ahụ. Emesịa o zigara ha nʼubi vaịnị ya.\wj*
\p 
\v 3 \wj “Mgbe ọ pụrụ nʼihe dị ka elekere itoolu nke ụtụtụ, o sitere nʼebe a na-akpọta ndị ọrụ na-agafe hụ ndị ọzọ ka ha guzoro nʼọma ahịa na-enweghị ọrụ ha na-arụ.\wj*
\v 4 \wj Ọ sịrị ha, ‘Unu onwe unu gaakwanụ rụọ ọrụ nʼubi vaịnị m, ihe ọbụla ziri ezi ka m ga-akwụ unu.’\wj*
\v 5 \wj Ya mere ha gara.\wj*
\p \wj “Ọ pụkwara nʼelekere iri na abụọ na elekere atọ nke ehihie, ma meekwa otu ihe ahụ.\wj*
\v 6 \wj Mgbe o ruru elekere ise nke anyasị, ọ pụrụ hụ ndị ọzọ ka ha guzoro. Ọ jụrụ ha ajụjụ sị, ‘Gịnị mere unu ji guzoro nʼebe a taa niile na-arụghị ọrụ?’\wj*
\p 
\v 7 \wj “Ha zara sị ya, ‘Nʼihi na ọ dịghị onye kpọrọ anyị ọrụ.’\wj*
\p \wj “Ọ gwara ha sị, ‘Unu onwe unu gaakwanụ rụọ ọrụ nʼubi vaịnị m. Aga m akwụkwa unu ihe dị mma.’\wj*
\p 
\v 8 \wj “Mgbe o ruru oge anyasị, onye nwe ubi vaịnị ahụ gwara onye na-elekọtara ya ndị ahụ anya sị, ‘Kpọkọta ndị ọrụ ahụ kwụọ ha ụgwọ, site na ndị ikpeazụ bịara ọrụ ruo na ndị bu ụzọ.’\wj*
\p 
\v 9 \wj “Mgbe ndị a kpọrọ ọrụ nʼelekere ise anyasị naara ego ha, a kwụrụ ha otu denarị, otu denarị.\wj*
\v 10 \wj Ma mgbe ndị a kpọrọ ọrụ nʼisi ụtụtụ bịara ịnara ego ha, ha lere anya na a ga-akwụ ha karịa. Ma a kwụkwara ha niile otu denarị.\wj*
\v 11 \wj Mgbe ha naara ego ahụ, ha tamuru ntamu megide nna nwe ụlọ,\wj*
\v 12 \wj na-asị, ‘Ndị a bịara nʼikpeazụ rụrụ ọrụ naanị otu awa, ma i meela ka anyị na ha hara. Anyị bụ ndị buru ihe mgbu nke ọrụ ma okpomọkụ nke anwụ niile chara nʼụbọchị taa.’\wj*
\p 
\v 13 \wj “Ma ọ zara otu nʼime ha sị, ‘Enyi m, emeghị m gị ihe ọjọọ ọbụla. Ọ bụ na mụ na gị ekwughị na m ga-akwụ gị otu denarị nʼụbọchị?\wj*
\v 14 \wj Nara nke ruru gị laa. A chọrọ m ịkwụ ndị a bịara nʼikpeazụ ụgwọ dị ka m si kwụọ gị.\wj*
\v 15 \wj Ọ bụ na m enweghị ike iji ihe m nwere mee otu ọ masịrị m? Ọ bụ anya ukwu ka ị na-enwe nʼihi afọ ofufu m?’\wj*
\p 
\v 16 \wj “Ya mere, onye ikpeazụ ga-abụ onye bu ụzọ, ma onye bu ụzọ ga-abụkwa onye ikpeazụ.”\wj*
\s1 Jisọs ekwuokwa okwu banyere ọnwụ ya
\p 
\v 17 Mgbe Jisọs na-aga Jerusalem, ọ kpọpụrụ mmadụ iri na abụọ ahụ na-eso ụzọ ya nʼakụkụ sị ha,
\v 18 \wj “Lee, anyị na-aga Jerusalem ebe a ga-arara Nwa nke Mmadụ nyefee nʼaka ndịisi nchụaja na ndị ozizi iwu. Ha ga-ama ya ikpe ọnwụ,\wj*
\v 19 \wj nyefekwa ya nʼaka ndị mba ọzọ, ndị ga-eji ya mee ihe ọchị, pịa ya ihe, ma kpọgide ya nʼobe. Ma nʼụbọchị nke atọ, a ga-eme ka ọ site nʼọnwụ bilie.”\wj*
\s1 Arịrịọ nne Jemis na Jọn
\p 
\v 20 Mgbe ahụ, nne ụmụ Zebedi, duuru ụmụ ya ndị ikom abụọ bịakwute ya, o gburu ikpere nʼala nʼihu ya, rịọ ya ihe ọ chọrọ ka o meere ha.
\p 
\v 21 Ọ sịrị ya, \wj “Gịnị ka ị chọrọ ka m meere gị?”\wj*
\p Ọ zara ya sị, “Kwee m nkwa na ụmụ abụọ ndị a ga-anọdụ otu nʼaka nri gị, nke ọzọ nʼaka ekpe gị nʼalaeze gị.”
\p 
\v 22 Ma Jisọs zara sị, \wj “Unu amaghị ihe unu na-arịọ. Unu pụrụ ịṅụ iko ahụ nke mụ onwe m ga-aṅụ?”\wj*
\p Ha zara ya sị, “Ee, anyị nwere ike ịṅụ ya.”
\p 
\v 23 Jisọs sịrị ha, \wj “Nʼezie unu ga-aṅụ iko m ga-aṅụ, ma ịnọdụ nʼaka nri maọbụ nʼaka ekpe m, abụghị ihe dịrị m inye, kama ọ dịịrị ndị ahụ Nna m kwadooro ya.”\wj*
\p 
\v 24 Mgbe mmadụ iri ndị ọzọ nʼime ndị na-eso ụzọ ya nụrụ nke a, iwe were ha nke ukwuu megide ụmụnne abụọ a.
\v 25 Ma Jisọs kpọkọtara ha niile, sị ha, \wj “Nʼetiti ndị na-ekweghị ekwe,\wj*\f + \fr 20:25 \ft Maọbụ, \fqa ndị mba ọzọ\f*\wj ndịisi ha na-emeso ndị ha na-achị mmeso dị ka o si dị ha mma nʼuche. Ndị ukwu nʼetiti ha na-ejikwa aka ike na-achị ndị nọ nʼokpuru ha.\wj*
\v 26 \wj Ma nʼetiti unu ọ gaghị adị otu a. Kama, onye ọbụla nʼetiti unu chọrọ ịbụ onyeisi, ga-ebu ụzọ bụrụ onye na-ejere unu niile ozi.\wj*
\v 27 \wj Ma onye ọbụla nke chọrọ ịbụ onye mbụ nʼetiti unu ga-abụ ohu unu niile.\wj*
\v 28 \wj Ọ bụladị dị ka Nwa nke Mmadụ na-abịaghị ka e jeere ya ozi, kama ka o jee ozi, ma nyekwa ndụ ya ka ọ bụrụ ihe mgbapụta nke ọtụtụ mmadụ.”\wj*
\s1 Ndị ìsì abụọ Jisọs gwọrọ
\p 
\v 29 Mgbe ha na-ahapụ Jeriko, ọtụtụ igwe mmadụ sooro ya nʼazụ.
\v 30 Ndị ìsì abụọ nọ nʼakụkụ ụzọ ahụ. Mgbe ha nụrụ na ọ bụ Jisọs na-abịa, ha malitere iti mkpu nʼoke olu na-asị, “Onyenwe anyị, Nwa Devid, meere anyị ebere!”
\p 
\v 31 Igwe mmadụ ahụ baara ha mba ka ha mechie ọnụ ha. Ma ndịisi ahụ nọgidesịrị ike na-eti mkpu nʼoke olu na-asị, “Onyenwe anyị, Nwa Devid, meere anyị ebere!”
\p 
\v 32 Mgbe Jisọs bịaruru nʼebe ha nọ, o guzoro kpọọ ha, jụọ ha sị, \wj “Gịnị ka unu chọrọ ka m meere unu?”\wj*
\p 
\v 33 Ha zara sị ya, “Onyenwe anyị, biko, anyị chọrọ ka i mee ka anyị hụ ụzọ.”
\p 
\v 34 Jisọs nwere ọmịiko nʼahụ ha. O metụrụ ha aka nʼanya. Ngwangwa ha bidoro ịhụ ụzọ, ma sorokwa ya.
\c 21
\s1 Mbata ikpeazụ Jisọs batara Jerusalem
\p 
\v 1 Mgbe ha na-abịaru Jerusalem nso, ha rutere Betfeji dị nʼUgwu Oliv. Jisọs zipụrụ mmadụ abụọ nʼime ndị na-eso ụzọ ya.
\v 2 Ọ gwara ha sị, \wj “Baanụ nʼime obodo nta ahụ dị unu nʼihu, ngwangwa unu ga-ahụ otu ịnyịnya ibu elibere nʼosisi nʼebe ahụ, nke ya na nwa ya nọ nʼotu ebe. Tọpụta ha ma kpụtaranụ m ha.\wj*
\v 3 \wj Ọ bụrụkwa na onye ọbụla asị unu ihe ọbụla, unu ga-asị ha, ọ dị Onyenwe anyị mkpa, ọ ga-akpụghachitekwa ha ngwangwa.”\wj*
\p 
\v 4 E mere nke a ka okwu e kwuru site nʼọnụ onye amụma mezuo.
\q1 
\v 5 “Gwanụ ada Zayọn sị,
\q2 ‘lee, eze gị ka ọ na-abịakwute gị.
\q1 Ọ bụ onye dị nwayọọ. Ọ na-anọkwasịkwa nʼelu ịnyịnya ibu,
\q2 ee, nʼelu nwa ịnyịnya, nwa ịnyịnya na-ebu ibu.’ ”\f + \fr 21:5 \ft \xt Zek 9:9\xt*\f*
\p 
\v 6 Ndị na-eso ụzọ ya gara mee ihe Jisọs sịrị ha mee.
\v 7 Ha kpụtara ịnyịnya ibu ahụ na nwa ịnyịnya ahụ, wụkwasịkwa uwe ha nʼelu ha ka Jisọs nọkwasị nʼelu ha.
\v 8 Ọtụtụ nʼime igwe mmadụ ahụ tụsara uwe ha nʼokporoụzọ. Ndị ọzọ gbuturu alaka osisi, tụsaa ha nʼụzọ nʼihu ya.
\v 9 Ụfọdụ nʼime igwe mmadụ ahụ nọ nʼihu, na ndị na-esokwa nʼazụ, nọ na-eti mkpu nʼoke olu na-asị:
\q1 “Hozanna dịrị Nwa Devid!”
\b
\q1 “Onye a gọziri agọzi ka onye ahụ bụ, nke na-abịa nʼaha Onyenwe anyị!”\f + \fr 21:9 \ft \xt Abụ 118:26\xt*\f*
\b
\q1 “Hozanna nʼebe kachasị ihe niile elu!”
\p 
\v 10 Mgbe ọ batara nʼime Jerusalem, ụzụ tụrụ, obodo ahụ niile mere mkpọtụ. Ndị mmadụ bidoro na-ajụ ajụjụ na-asị, “Onye kwa bụ onye a?”
\p 
\v 11 Igwe mmadụ ahụ nọ na-asị, “Nwoke a bụ Jisọs, onye amụma ahụ sị Nazaret, obodo dị nʼime Galili.”
\s1 Jisọs nʼụlọnsọ ukwu
\p 
\v 12 Jisọs banyere nʼụlọnsọ ukwu dị na Jerusalem, malite ịchụpụ ndị niile na-ere ahịa na ndị na-azụ ahịa nʼime ụlọnsọ ahụ. O kpuru tebul ndị na-agbanwe ego ihu nʼala, kwatuokwa oche ndị na-ere nduru.
\v 13 Ọ sịrị ha, \wj “E dere ya nʼakwụkwọ nsọ, ‘Ụlọ m ka a ga-akpọ ụlọ ekpere,’\wj*\f + \fr 21:13 \ft \xt Aịz 56:7\xt*\f*\wj ma unu emeela ya ‘ọgba ndị na-apụnarị mmadụ ihe nʼike.’\wj*\f + \fr 21:13 \ft \xt Jer 7:11\xt*\f*\wj ”\wj*
\p 
\v 14 Ndị ìsì na ndị ngwụrọ bịakwutere ya nʼụlọnsọ ahụ. Ọ gwọkwara ha.
\v 15 Ma mgbe ndịisi nchụaja na ndị ozizi iwu hụrụ ihe ịrịbama ndị a, hụkwa ka ụmụnta na-eti mkpu nʼoke olu nʼogige ụlọnsọ ahụ, na-asị, “Hozanna dịrị Nwa Devid.” Iwe were ha nke ukwuu.
\p 
\v 16 Ha sịrị ya, “Ị na-anụkwa ihe ụmụnta ndị a na-ekwu?”
\p Jisọs zara sị ha, \wj “E, ana m anụ ya. Ọ bụ na unu agụtabeghị ihe akwụkwọ nsọ kwuru sị,\wj*
\q1 \wj “ ‘I sitere nʼọnụ ụmụntakịrị na ụmụ na-aṅụ ara\wj*
\q2 \wj gị, Onyenwe anyị, kwadooro otuto gị’\wj*\f + \fr 21:16 \ft \xt Abụ 8:2\xt*\f*\wj ?”\wj*
\p 
\v 17 Ọ hapụrụ ha, si nʼobodo ahụ pụọ gaa Betani, ebe ọ nọrọ nʼabalị ahụ niile.
\s1 Jisọs abụọ osisi fiig ọnụ
\p 
\v 18 Nʼụtụtụ, mgbe ọ laghachiri nʼobodo ahụ, agụụ gụrụ ya nke ukwuu.
\v 19 Ọ hụrụ otu osisi fiig nke dị nʼakụkụ ụzọ. Mgbe o rutere nʼukwu ya, ọ hụghị ihe ọbụla nʼelu ya karịa naanị akwụkwọ ndụ. Ya mere, ọ sịrị ya, \wj “Malite taa gaa nʼihu, ị gaghị amịkwa mkpụrụ ọzọ!”\wj* Otu mgbe ahụ kwa, osisi ahụ kpọnwụrụ.
\p 
\v 20 Mgbe ndị na-eso ụzọ ya hụrụ nke a, o juru ha anya, ha jụọ sị, “Gịnị mere osisi fiig a ji kpọnwụọ ngwangwa otu a?”
\p 
\v 21 Jisọs zara sị ha, \wj “Nʼezie agwa m unu, ọ bụrụ na unu e nwee okwukwe, gharakwa inwe obi abụọ, ọ bụghị naanị na unu ga-eme ihe e mere osisi fiig ahụ. Unu pụrụ inye ugwu a iwu sị ya, ‘Si nʼebe a wezuga onwe gị, gaa danye nʼoke osimiri.’ Ọ ga-emezukwa.\wj*
\v 22 \wj Ihe ọbụla unu ga-arịọ nʼekpere, ọ bụrụ na unu ekwere unu ga-anatakwa ya.”\wj*
\s1 Ajụjụ banyere ebe Jisọs si nweta ike ya
\p 
\v 23 Mgbe Jisọs batara nʼogige ụlọnsọ ukwu ahụ, ndịisi nchụaja na ndị ozizi iwu bịakwutere ya ka ọ nọ na-akụzi ihe jụọ ya sị, “Olee ikike i ji na-eme ihe ndị a niile? Ọ bụ onye nyekwara gị ikike a?”
\p 
\v 24 Jisọs zara sị ha, \wj “Aga m ajụkwa unu otu ajụjụ. Ọ bụrụ na unu azaa ya, aga m agwakwa unu onye nyere m ikike m ji eme ihe ndị a niile.\wj*
\v 25 \wj Baptizim nke Jọn o sitere nʼeluigwe, ka ọ si nʼaka mmadụ?”\wj*
\p Ha kparịtara ụka nʼetiti onwe ha na-asị, “Ọ bụrụ na anyị asị, ‘Na o si nʼeluigwe,’ ọ ga-asị anyị, ‘Ọ bụ gịnị mere unu na-ejighị kwenye na ya?’
\v 26 Ma ọ bụrụ na anyị asị, ‘Na o sitere nʼaka mmadụ,’ anyị na-atụ igwe mmadụ ndị a egwu, nʼihi na mmadụ niile kwenyere na Jọn bụ onye amụma.”
\p 
\v 27 Ya mere ha zara Jisọs sị ya: “Anyị amaghị.”
\p Jisọs zakwara ha sị, \wj “Mụ onwe m agaghị agwakwa unu ikike m ji na-eme ihe ndị a.\wj*
\s1 Ilu banyere ụmụnne abụọ
\p 
\v 28 \wj “Gịnị ka unu chere banyere ihe a? Otu nwoke nwere ụmụ nwoke abụọ gwara nwa ya nke okenye sị ya, ‘Nwa m nwoke, gaa rụọ ọrụ nʼubi vaịnị m taa.’\wj*
\p 
\v 29 \wj “Ọ zara ya sị, ‘Agaghị m aga.’ Ma o mesịrị gbanwee obi ya gaakwa rụọ ọrụ ahụ.\wj*
\p 
\v 30 \wj “Nna ha bịakwutere nwa ya nke nta gwakwa ya otu ihe ahụ. Nwa ahụ zakwara sị, ‘Aga m aga, onyenwe anyị.’ Ma nʼikpeazụ ọ gaghị.\wj*
\p 
\v 31 \wj “Onye nʼime ha abụọ mere ihe nna ya chọrọ?”\wj*
\p Ha zara sị ya, “Onye nke mbụ.”
\p Jisọs kọwaara ha sị, \wj “Nʼezie agwa m unu, ndị ọna ụtụ na ụmụ nwanyị akwụna ga-ebu unu ụzọ banye nʼalaeze Chineke.\wj*
\v 32 \wj Nʼihi na Jọn bịakwutere unu igosi unu ụzọ ezi omume, ma unu ekweghị. Ndị ọna ụtụ, na ụmụ nwanyị akwụna chegharịrị. Ọ bụladị mgbe unu hụrụ nke a, o mekwaghị ka unu chegharịa kwere na ya.\wj*
\s1 Ilu banyere ndị nlekọta ubi ọjọọ
\p 
\v 33 \wj “Ugbu a geekwanụ ntị nʼilu ọzọ. Otu onye dị nke nwere ala ubi. Ọ kụrụ osisi vaịnị nʼubi a. Ọ gbakwara ubi ya ogige, gwuokwa ebe ịzọcha mkpụrụ vaịnị nʼime ya.\wj*\f + \fr 21:33 \ft Maọbụ, \fqa ebe a na-apịpụta mmanya vaịnị\f*\wj O wukwara ụlọ elu nʼime ya. Mgbe o mesịrị ihe ndị a, o weere ubi ahụ tinye nʼaka ndị ga-elekọtara ya ubi ahụ, pụọ gaa nʼala ọzọ.\wj*
\v 34 \wj Mgbe oge iwe ihe ubi ruru, o zipụrụ ndị odibo ya ka ha jekwuru ndị na-elekọta ubi ahụ, nata mkpụrụ nke ruuru ya site nʼubi ahụ.\wj*
\p 
\v 35 \wj “Ma ndị na-elekọta ubi ahụ jidere ndị odibo ya ahụ tie otu onye nʼime ha ihe, gbukwaa onye ọzọ nʼime ha. Ha tụkwara otu nʼime ha nkume.\wj*
\v 36 \wj Emesịa, o zigakwara ọtụtụ ndị odibo karịrị ndị nke mbụ nʼọnụọgụgụ. Ma ndị na-elekọta ubi ahụ mekwara ndị a ihe ha mere ndị nke mbụ.\wj*
\v 37 \wj Nʼikpeazụ o zigara ọkpara ya, sị, ‘Ha ga-asọpụrụ nwa m.’\wj*
\p 
\v 38 \wj “Ma mgbe ndị na-elekọta ubi ahụ hụrụ ọkpara ya, ha gbara izu nʼetiti onwe ha sị, ‘Lee! Onye a bụ onye nketa ihe niile. Bịanụ ka anyị gbuo ya, ma nwetakwa ihe nketa ya.’\wj*
\v 39 \wj Ya mere, ha jidere ya nʼike, kpụrụ ya gafee nʼazụ ubi vaịnị ahụ, gbuo ya nʼebe ahụ.\wj*
\p 
\v 40 \wj “Mgbe onye nwe ubi vaịnị ahụ lọtara, gịnị ka unu chere na ọ ga-eme ndị ahụ o tinyere ilekọtara ya ubi ya?”\wj*
\p 
\v 41 Ha zara ya sị, “Ọ ga-egbu ndị ajọ omume ahụ, laa ha nʼiyi nʼụzọ dị njọ. Ọ ga-ewerekwa ubi vaịnị ya tinye nʼaka ndị nlekọta ọzọ, ndị ga-enyekwa ya mkpụrụ ubi ruuru ya nʼoge ya.”
\p 
\v 42 Jisọs sịrị ha, \wj “Ọ ga-abụ na unu agụtabeghị ihe e dere nʼakwụkwọ nsọ sị,\wj*
\q1 \wj “ ‘Nkume ahụ ndị na-ewu ụlọ jụrụ,\wj*
\q2 \wj abụrụla nkume isi ntọala ụlọ.\wj*
\q1 \wj Nke a bụ ọrụ nke Onyenwe anyị rụrụ,\wj*
\q2 \wj ọ bụkwa ọrụ ịtụnanya nʼanya anyị.’\wj*\f + \fr 21:42 \ft \xt Abụ 118:22,23\xt*\f*
\p 
\v 43 \wj “Ya mere, ana m eme ka unu ghọta, na a ga-anapụ unu alaeze Chineke, were ya nye ndị mba ọzọ, ndị ga-amịpụta ezi mkpụrụ.\wj*
\v 44 \wj Onye ọbụla nke dakwasịrị nʼelu nkume a ga-etiwasị, ma ọ ga-egwepịa onye ọbụla nke ọ dakwasịrị.”\wj*
\p 
\v 45 Mgbe ndịisi nchụaja na ndị Farisii nụrụ ilu ya ndị a, ha ghọtara na ọ na-ekwu banyere ha.
\v 46 Ha chọrọ ụzọ ha ga-esi jide ya, ma oke egwu igwe mmadụ ahụ tụrụ ha, nʼihi na ha gụrụ ya nʼonye amụma.
\c 22
\s1 Ilu banyere oriri ọlụlụ nwunye
\p 
\v 1 Jisọs gwara ha okwu ọzọ nʼilu sị,
\v 2 \wj “Alaeze eluigwe dị ka otu eze, nke kwadoro oke oriri ọlụlụ di na nwunye, nʼihi nwa ya nwoke.\wj*
\v 3 \wj O zipụrụ ndị ohu ya ka ha gaa chetara ndị ahụ a kpọrọ ka ha bịa. Ma ha niile achọghị ịbịa.\wj*
\p 
\v 4 \wj “O zipụkwara ndị ohu ya ọzọ na-ejere ya ozi ka ha gaa gwa ndị ahụ a kpọrọ oriri sị, ‘E dozichaala ihe oriri ugbu a, egburu m oke ehi, na anụ ọzọ gbara abụba. Edoziela ihe niile. Bịanụ nʼoriri ọlụlụ di na nwunye.’\wj*
\p 
\v 5 \wj “Ma ndị ahụ niile a kpọrọ oriri gawaara mkpa ha nʼihi na ha akpọghị ya ihe ọbụla. Otu onye gara nʼala ubi ya, nke ọzọ nʼụlọ ahịa ya.\wj*
\v 6 \wj Ndị fọdụrụ jidere ndị ohu ya, mee ha ihe ihere ma gbukwaa ha.\wj*
\v 7 \wj Onye eze ahụ were iwe nke ukwuu, zipụ ndị agha ya ka ha gaa laa ndị ogbu mmadụ ahụ nʼiyi, rechapụkwa obodo ha nʼọkụ.\wj*
\p 
\v 8 \wj “Mgbe ahụ ọ gwara ndị ohu ya sị, ‘E doziela m oriri ọlụlụ di na nwunye, ma ndị a kpọrọ oku ekwesighị ekwesi.\wj*
\v 9 \wj Ugbu a, gaanụ nʼakụkụ ụzọ niile, kpọbatanụ ndị niile unu hụrụ, ka ha bịa nʼoriri ọlụlụ di na nwunye a.’\wj*
\v 10 \wj Ndị ohu ahụ pụrụ gaa nʼokporoụzọ niile kpọbata mmadụ niile ha hụrụ. Ha kpọbatara ndị bụ ezi mmadụ na ndị bụ ajọ mmadụ. Ụlọ oriri ahụ jupụtakwara na ndị a kpọrọ.\wj*
\p 
\v 11 \wj “Ma mgbe eze ahụ batara ileta ndị niile nọ na nri, ọ hụrụ otu nwoke nke na-eyighị uwe ọlụlụ nwunye.\wj*
\v 12 \wj Ọ jụrụ ya ajụjụ sị, ‘Enyi m, i si aṅaa bata nʼebe a mgbe ị na-eyighị uwe ọlụlụ di na nwunye?’ O mechiri ọnụ ya nʼihi na o nweghị ihe ọ ga-asa.\wj*
\p 
\v 13 \wj “Eze ahụ nyere ndị ozi ya iwu sị ha, ‘Keenụ ya eriri, aka na ụkwụ, tụpụkwanụ ya nʼezi, nʼime ọchịchịrị, ebe ịkwa akwa na ịta ikikere eze ga-adị.’\wj*
\p 
\v 14 \wj “Nʼihi na akpọrọ ọtụtụ mmadụ oku, maọbụ mmadụ ole na ole ka a họọrọ.”\wj*
\s1 Ịtụ ụtụ nye Siza
\p 
\v 15 Mgbe ahụ ndị Farisii\f + \fr 22:15 \fq Farisii \ft Ndị otu na-akwado maka idebezu mmemme na omenaala niile ndị Juu.\f* zukọtara na-achọ ụzọ ha ga-esi mee ka o kwuhie ọnụ ka ha site na ya jide ya.
\v 16 Ha zigara ndị na-eso ụzọ ha na ndị nʼotu Herọd ka ha jụọ ya sị, “Onye ozizi, anyị maara nke ọma na ị bụ onye eziokwu, na ị na-ezikwa ụzọ Chineke nʼeziokwu. Ị dịghị asọkwa onye ọbụla anya, nʼihi na ị dịghị ele mmadụ anya nʼihu nʼagbanyeghị ndị ha bụ.
\v 17 Ugbu a gwa anyị, gịnị bụ uche gị? O ziri ezi nʼiwu ịtụ ụtụ nye Siza, ka ọ bụ na o zighị ezi?”
\p 
\v 18 Ebe Jisọs maara ihe ọjọọ ha bu nʼobi, ọ zara sị ha, \wj “Ndị ihu abụọ! Gịnị mere unu ji anwa m ọnwụnwa?\wj*
\v 19 \wj Gosinụ m ego e ji akwụ ụgwọ ụtụ.”\wj* Ha wetaara ya otu mkpụrụ ego.
\v 20 Ọ jụrụ ha ajụjụ sị, \wj “Onye ka e sekwasịrị onyinyo ya nʼelu ego a? Aha onye kwa dị nʼokpuru onyinyo a?”\wj*
\p 
\v 21 Ha zara sị ya, “Ọ bụ nke Siza.”
\p Mgbe ahụ ọ gwara ha sị, \wj “Ọ dị mma. Nyenụ Siza ihe ruuru Siza, ma nyekwanụ Chineke ihe niile bụ nke ruuru Chineke.”\wj*
\p 
\v 22 Mgbe ha nụrụ nke a, ọ gbagwojuru ha anya, nʼihi ya, ha hapụrụ ya pụọ.
\s1 Ọlụlụ nwunye na mbilite nʼọnwụ
\p 
\v 23 Nʼụbọchị ahụ kwa, ụfọdụ ndị Sadusii, ndị na-asị na mbilite nʼọnwụ adịghị, bịakwutere ya ịghụ ya ọnụ.
\v 24 Onye ozizi, “Mosis kwuru sị, ọ bụrụ na nwoke ọbụla anwụọ na-amụtaghị nwa, nwanne ya nwoke ga-alụrụ nwanyị ahụ di ya nwụrụ, ka ọ mụtara nwanne ya nwoke ahụ nwụrụ anwụ nwa.
\v 25 Ugbu a, e nwere ụmụnne nwoke asaa nʼetiti anyị. Onye nke mbụ lụrụ nwunye, nwụọ, ma ebe ọ dịghị ụmụ ọ mụtara, ọ hapụrụ nwanne ya nwunye ya.
\v 26 Otu a ka nke abụọ mekwara, ma nke atọ, ruo na nke asaa.
\v 27 Nʼikpeazụ, nwanyị ahụ nʼonwe ya nwụkwara.
\v 28 Ugbu a, nʼoge mbilite nʼọnwụ, nwunye onye ka nwanyị a ga-abụ, ebe ọ bụ na ụmụnne nwoke asaa ndị a lụtụchara ya mgbe ọ nọ nʼụwa?”
\p 
\v 29 Jisọs zara ha sị, \wj “Unu na-ejehie ụzọ nʼihi na unu aghọtaghị ihe akwụkwọ nsọ na-ekwu. Unu aghọtakwaghị ụdị ike Chineke nwere.\wj*
\v 30 \wj Nʼihi na mbilite nʼọnwụ, ịlụ di na nwunye agaghị adịkwa, kama ha ga-adị ka ndị mmụọ ozi nʼeluigwe.\wj*
\v 31 \wj Ma nʼihe banyere mbilite nʼọnwụ nke ndị nwụrụ anwụ, ọ bụ na unu agụtabeghị ihe Chineke gwara unu sị,\wj*
\v 32 \wj Mụ onwe m bụ Chineke nke Ebraham, Chineke nke Aịzik na Chineke nke Jekọb.\wj*\f + \fr 22:32 \ft \xt Ọpụ 3:6\xt*\f*\wj Ọ bụghị Chineke nke ndị nwụrụ anwụ, kama ọ bụ nke ndị dị ndụ.”\wj*
\p 
\v 33 Mgbe igwe mmadụ ahụ nụrụ nke a, ozizi ya juru ha anya.
\s1 Iwu kachasị mkpa
\p 
\v 34 Ma mgbe ndị Farisii nụrụ na ọ emeela ka ndị Sadusii mechie ọnụ ha, ha gbakọtara otu ebe.
\v 35 Otu onye nʼime ha, bụ onye ozizi iwu\f + \fr 22:35 \ft Ndị ozizi iwu bụ ndị ọka nʼiwu, ọ bụ ha na a tapịaa iwu gbasara usoro okpukpe.\f* bịara jụọ ya ajụjụ iji nwaa ya:
\v 36 “Onye ozizi, olee iwu nke kachasị mkpa nʼime iwu niile?”
\p 
\v 37 Ọ zara sị ya, \wj “ ‘Hụ Onyenwe gị bụ Chineke gị nʼanya site nʼobi gị niile na site na mkpụrụobi gị niile, na site nʼuche gị niile.’\wj*\f + \fr 22:37 \ft \xt Dit 6:5\xt*\f*
\v 38 \wj Nke a bụ iwu nke mbụ, bụrụkwa iwu kachasị iwu niile.\wj*
\v 39 \wj Iwu ọzọ na-eso nke a nʼịdị mkpa bụ nke a, ‘Hụ onye agbataobi gị nʼanya dị ka i si hụ onwe gị nʼanya.’\wj*\f + \fr 22:39 \ft \xt Lev 19:18\xt*\f*
\v 40 \wj Iwu ndị ọzọ niile na ihe niile ndị amụma kwuru dabeere nʼebe iwu abụọ ndị a nọ.”\wj*
\s1 Ajụjụ Jisọs jụrụ ndị Farisii
\p 
\v 41 Mgbe ndị Farisii gbakọrọ nʼotu ebe, Jisọs jụrụ ha,
\v 42 \wj “Gịnị ka unu na-eche banyere Kraịst? Nwa onye ka ọ bụ?”\wj*
\p Ha zara sị ya, “Ọ bụ nwa Devid.”
\p 
\v 43 Ọ sịrị ha, \wj “Gịnị mekwaranụ Devid site na ntụziaka nke Mmụọ Nsọ jiri kpọọ ya ‘Onyenwe m’? Nʼihi na ọ sịrị,\wj*
\q1 
\v 44 \wj “ ‘Onyenwe anyị gwara Onyenwe m sị ya,\wj*
\q2 \wj “Nọdụ ala nʼaka nri m\wj*
\q1 \wj ruo mgbe m ga-edebe ndị iro gị\wj*
\q2 \wj nʼokpuru ụkwụ gị abụọ.” ’\wj*\f + \fr 22:44 \ft \xt Abụ 110:1\xt*\f*
\m 
\v 45 \wj Ọ bụrụ na Devid kpọrọ ya ‘Onyenwe anyị,’ oleekwanụ otu o si bụrụkwa nwa ya?”\wj*
\v 46 Ọ dịghị onye pụrụ ịsa ya okwu. Sitekwa nʼụbọchị ahụ, ọ dịghị onye ọbụla nwere anya ike ịjụ ya ajụjụ ọzọ.
\c 23
\s1 Ịdọ aka na ntị banyere ihu abụọ
\p 
\v 1 Mgbe ahụ Jisọs gwara igwe mmadụ ahụ niile na ndị na-eso ụzọ ya sị,
\v 2 \wj “Ndị ozizi iwu na ndị Farisii na-anọ nʼoche Mosis.\wj*
\v 3 \wj Ya mere, meenụ ma na-edebekwanụ ihe niile ha na-agwa unu. Ma unu esokwala omume ha. Nʼihi na ha adịghị eme ihe ha na-ekwusa. Ha na-ekwu otu ihe ma na-eme ihe ọzọ.\wj*
\v 4 \wj Ha na-eke ibu dị arọ dịkwa ike obubu bokwasị ndị ọzọ nʼubu, ma ha onwe ha agaghị eweli ọ bụladị otu mkpịsịaka i buli ha.\wj*
\p 
\v 5 \wj “Ihe niile ha na-eme bụ ka ndị mmadụ hụ ha. Ha na-eme ka igbe nta\wj*\f + \fr 23:5 \ft Maọbụ, \fqa Filaktịrị\f*\wj e tinyere iwu ndị dị mkpa e depụtara nke ha na-ekekwasị nʼegedege ihu na nʼaka dị obosara na-emekwa ka ọnụnụ uwe ha buo ibu.\wj*
\v 6 \wj Ha hụrụ ịnọ nʼisi oche nʼoge mmemme oriri ọbụla na ịnọkwasị nʼoche kachasị elu nʼụlọ ekpere nʼanya.\wj*
\v 7 \wj Ọ na-amasị ha mgbe a na-ekele ha ekele pụrụ iche nʼọma ahịa, ndị ọzọ a na-akpọkwa ha, ‘Onye ozizi.’\wj* 
\p 
\v 8 \wj “Unu ekwela ka onye ọbụla kpọọ unu ‘Onye ozizi,’ nʼihi na unu nwere naanị otu Onye ozizi. Unu niile bụkwa ụmụnne. Ọ dịghị onye ka ibe ya ukwuu.\wj*
\v 9 \wj Unu akpọkwala onye ọbụla nʼụwa a ‘Nna,’ nʼihi na unu nwere otu Nna nke bi nʼeluigwe.\wj*
\v 10 \wj Unu ekwela ka a kpọọ unu ndị ndu, nʼihi na ọ bụ naanị otu onyendu ka unu nwere, ya bụ Kraịst.\wj*
\v 11 \wj Onye dị ukwuu nʼetiti unu ga-abụ onye na-ejere unu ozi.\wj*
\v 12 \wj Nʼihi na onye ọbụla ga-ebuli onwe ya elu ka a ga-eweda nʼala. Ma onye ọbụla wedara onwe ya ala, ka a ga-ebuli elu.”\wj*
\s1 Ahụhụ asaa dịịrị ndị ozizi iwu na ndị Farisii
\p 
\v 13 \wj “Ahụhụ ga-adịrị unu ndị Farisii na ndị ozizi iwu, ndị ihu abụọ! Nʼihi na unu na-emechibido ndị ọzọ ụzọ ha ga-esi bata nʼalaeze eluigwe, ma unu onwe unu adịghị abata. Unu adịghịkwa enye ndị ọzọ ohere ịbata.\wj*
\p 
\v 14 \wj “Ahụhụ ga-adịrị unu ndị ozizi iwu na ndị Farisii, ndị ihu abụọ! Nʼihi na unu na-eripịa ụlọ ndị inyom di ha nwụrụ, ọ bụladị mgbe unu na-ekpe ogologo ekpere ka mmadụ hụ unu. Unu ga-anata ikpe ọmụma dị ukwuu.\wj*\f + \fr 23:14 \ft Ụfọdụ akwụkwọ mgbe ochie na-edebanye okwu ndị a dịka ọ dị nʼakwụkwọ \xt Mak 12:40\xt*\ft na \xt Luk 20:47\xt*\ft .\f*
\p 
\v 15 \wj “Ahụhụ ga-adakwasị unu ndị ozizi iwu na ndị Farisii, ndị ihu abụọ! Nʼihi na unu na-agafe oke osimiri na mba dị iche iche, ime ka otu onye chegharịa, bụrụ onye na-eso ụzọ unu. Ma mgbe unu mesịrị nke a, unu na-alaghachi mee ya okpukpu abụọ ka ọ bụrụ nwa ọkụ ala mmụọ karịa onwe unu.\wj*
\p 
\v 16 \wj “Ahụhụ ga-adịrị unu ndị ndu kpuru ìsì! Nʼihi na unu na-asị, Onye ọbụla jiri ụlọnsọ ṅụọ iyi, iyi ọ ṅụrụ bụ ihe efu. Ma onye ọbụla jiri ọlaedo dị nʼime ụlọnsọ ṅụọ iyi kwesiri imezu iyi ahụ ọ ṅụrụ.\wj*
\v 17 \wj Ndị nzuzu kpuru ìsì! Olee nke karịrị ukwuu? Ọ bụ ọlaedo ahụ, ka ọ bụ ụlọnsọ nke doro ọlaedo ahụ nsọ?\wj*
\v 18 \wj Unu na-ezikwa ndị mmadụ sị, ‘Ọ bụrụ na mmadụ ejiri ebe ịchụ aja ṅụọ iyi, iyi ahụ ọ ṅụrụ bụ ihe efu. Ma onye ọbụla ga-eji onyinye dị nʼelu ebe ịchụ aja ṅụọ iyi ga-emezu iyi ahụ ọ ṅụrụ.’\wj*
\v 19 \wj Leenụ ka unu si bụrụ ndị ìsì! Olee nke karịrị ukwuu? Ọ bụ onyinye dị nʼelu ebe ịchụ aja ka ọ bụ ebe ịchụ aja na-edo onyinye ahụ nsọ?\wj*
\v 20 \wj Ya mere, mgbe onye ọbụla ji ebe ịchụ aja ṅụọ iyi, ọ bụ ebe ịchụ aja ahụ na onyinye dị nʼelu ya ka o ji ṅụọ iyi ahụ.\wj*
\v 21 \wj Otu a kwa, onye ji ụlọnsọ ahụ ṅụọ iyi jikwa ụlọnsọ ahụ na onye bi nʼime ya na-aṅụ iyi.\wj*
\v 22 \wj Mgbe mmadụ jikwa eluigwe ṅụọ iyi, ọ bụ ocheeze Chineke na onye nọdụrụ nʼelu ocheeze ahụ ka o ji ṅụọ iyi.\wj*
\p 
\v 23 \wj “E, ahụhụ ga-adakwasị unu ndị Farisii na ndị ozizi iwu. Ndị ihu abụọ! Nʼihi na unu na-asa anya unu mmiri nye, ọ bụladị onyinye otu ụzọ nʼime ụzọ iri unu ruo nʼakwụkwọ nri dịkarịsịrị nta dị nʼubi unu, dịka mint, diil na kumin, ma unu akpọghị ikpe ziri ezi na ebere, na okwukwe ihe dị mkpa. Ihe ndị a ka unu kwesiri ibu ụzọ mee ma gharakwa ileghara iwu ndị ọzọ anya.\wj*
\v 24 \wj Ndị ndu kpuru ìsì! Unu na-azapụ ijiji site na mmanya unu na-aṅụ, ma unu na-eloda ịnyịnya kamel.\wj*
\p 
\v 25 \wj “Ahụhụ ga-adakwasị unu, ndị Farisii na ndị ozizi iwu, ndị ihu abụọ! Nʼihi na unu na-elezi anya nke ọma mee ka azụ iko mmiri unu, na azụ efere unu dị ọcha, ma ime ha jupụtara na ịpụnarị mmadụ ihe nʼike na ọchịchọ ọjọọ niile.\wj*\f + \fr 23:25 \ft \xt Mak 2:1\xt*\f*
\v 26 \wj Gị onye Farisii kpuru ìsì! Buru ụzọ mee ka ime iko dị ọcha, mgbe ahụ azụ ya ga-adịkwa ọcha.\wj*
\p 
\v 27 \wj “Ahụhụ ga-adịrị unu ndị Farisii na ndị ozizi iwu, ndị ihu abụọ! Nʼihi na unu yiri ili e tere nzu, nke na-egosi onwe ya dị ka ihe mara mma, ma ime ya jupụtara nʼọkpụkpụ ndị nwụrụ anwụ, na ihe niile na-adịghị ọcha.\wj*
\v 28 \wj Nʼụzọ dị otu a, unu na-egosi onwe unu dị ka ndị ezi omume, ma nʼime unu, unu jupụtara nʼihu abụọ na ndị ajọ omume.\wj*
\p 
\v 29 \wj “E, ahụhụ ga-adịrị unu ndị Farisii na ndị ozizi iwu, ndị ihu abụọ! Nʼihi na unu na-ewu ili ndị amụma na-ewerekwa ihe ịchọ mma na-edozi nkume ncheta ndị ezi omume.\wj*
\v 30 \wj Unu na-asịkwa, ọ bụrụ na anyị nọ nʼoge nna anyị ha, anyị agaraghị eso ha wufuo ọbara ndị amụma.\wj*
\v 31 \wj Site nʼụzọ dị otu a, unu na-agba akaebe megide onwe unu na unu bụ ụmụ ndị gburu ndị amụma.\wj*
\v 32 \wj Gaanụ sorokwa nzọ ụkwụ nna unu ha, ka unu rụzuo ọrụ ahụ ha malitere.\wj*
\p 
\v 33 \wj “Ụmụ agwọ! Ụmụ ajụala! Unu si aṅaa chee na unu ga-agbanarị ikpe nke ịba nʼọkụ ala mmụọ?\wj*
\v 34 \wj Ya mere, aga m ezitere unu ndị amụma, ndị amamihe na ndị nkuzi. Ụfọdụ nʼime ha ka unu ga-egbu, ụfọdụ ka unu ga-akpọgide nʼobe, ndị ọzọkwa ka unu ga-apịa ihe nʼụlọ nzukọ unu. Unu ga-achụkwa ha ọsọ site nʼotu obodo gaa nʼobodo ọzọ.\wj*
\v 35 \wj Ka ọgbọ a bụrụ ndị ikpe mara nʼihi ọbara nke ndị ezi omume niile e gburu nʼụwa, site nʼọbara Ebel ruo na nke Zekaraya nwa Berekaya, onye unu gburu nʼetiti ụlọnsọ nʼebe ịchụ aja unu.\wj*
\v 36 \wj Nʼezie agwa m unu, ihe ndị a niile, ga-abịakwasị ọgbọ a.\wj*
\s1 Ịhụnanya Jisọs nʼebe Jerusalem dị
\p 
\v 37 \wj “O Jerusalem, Jerusalem! Gị obodo na-egbu ndị amụma, na nke na-atụ ndị niile e ziteere gị nkume. Ugboro ole ka m chọrọ ịchịkọta ụmụ gị dị ka nne ọkụkụ si achịkọta ụmụ ya nʼokpuru nku ya ichebe ha? Ma ị chọghị ka m mee otu a!\wj*
\v 38 \wj Lee, a hapụrụla unu ụlọ unu ka ọ tọgbọrọ nʼefu.\wj*
\v 39 \wj Nʼihi na asị m unu, unu agaghị ahụ m anya ọzọ tutu ruo mgbe unu ga-asị, Onye a gọziri agọzi ka onye ahụ bụ nke na-abịa nʼaha Onyenwe anyị.\wj*\f + \fr 23:39 \ft \xt Abụ 118:26\xt*\f* \wj ”\wj*
\c 24
\s1 Mbibi ụlọnsọ ukwu na ihe ama ọgwụgwụ oge
\p 
\v 1 Mgbe Jisọs si nʼụlọnsọ ahụ na-apụ, ndị na-eso ụzọ ya bịakwutere ya na-achọ igosi ya akụkụ dị iche iche nke ụlọnsọ ukwu ahụ.
\v 2 Ma ọ zara ha sị, \wj “Unu hụrụ ihe ndị a niile? Nʼezie agwa m unu, oge na-abịa mgbe ọ bụladị otu nkume na-agaghị adịgidekwa nʼelu ibe ya, nke a na-agaghị akwatu nʼala.”\wj*
\p 
\v 3 Mgbe ọ nọdụrụ ala nʼelu Ugwu Oliv, ndị na-eso ụzọ ya bịakwutere ya iche, sị, “Gwa anyị, olee mgbe ihe ndị a ga-emezu? Gịnị ga-abụkwa ihe ịrịbama nke oge i ji alọghachi na nke ọgwụgwụ ụwa a?”
\p 
\v 4 Jisọs zara ha sị, \wj “Lezienụ anya ka onye ọbụla ghara iduhie unu ụzọ.\wj*
\v 5 \wj Nʼihi na ọtụtụ ga-abịa nʼaha m, na-ekwu sị, ‘Abụ m Kraịst ahụ.’ Ha ga-eduhiekwa ọtụtụ ndị ụzọ.\wj*
\v 6 \wj Mgbe unu nụrụ ụzụ agha, na akụkọ agha dị iche iche, unu atụla egwu, nʼihi na ihe ndị a aghaghị ime. Ma ha anaghị egosi na ọgwụgwụ oge eruola.\wj*
\v 7 \wj Mba ga-ebili megide mba ibe ya, alaeze ga-ebilikwa megide alaeze ọzọ; oke ụnwụ,\wj*\f + \fr 24:7 \fq Oke ụnwụ \ft oke ụnwụ na-eweta ụkọ nri na nrịa nrịa dị iche iche.\f*\wj na ala ọma jijiji ga-adịkwa nʼọtụtụ ebe dị iche iche.\wj*
\v 8 \wj Ma ihe ndị a niile bụ naanị mmalite ịta ahụhụ nke ga-abịa.\wj*
\p 
\v 9 \wj “Mgbe ahụ ha ga-arara unu nyefee nʼaka ndị ga-ata unu ahụhụ. Ha ga-egbukwa unu. Mba niile ga-akpọ unu asị nʼihi m.\wj*
\v 10 \wj Ọtụtụ ga-ada site nʼokwukwe ha nʼoge ahụ. Ha ga-emekwa ka ibe ha ma nʼọnya, kpọọkwa ibe ha asị.\wj*
\v 11 \wj Mgbe ahụ ọtụtụ ndị amụma ụgha ga-apụta. Ha ga-eduhiekwa ọtụtụ mmadụ.\wj*
\v 12 \wj Nʼihi na ajọ omume bara ụba nʼebe niile, ịhụnanya ọtụtụ ndị mmadụ nʼebe ibe ha nọ ga-ajụ oyi.\wj*
\v 13 \wj Ma onye ga-eguzosi ike ruo ọgwụgwụ ka a ga-azọpụta.\wj*
\v 14 \wj A ga-ekwusa oziọma nke alaeze ahụ nye ụwa niile ka ọ bụrụ ihe ama nye mba niile. Emesịa ọgwụgwụ oge ahụ ga-abịa.\wj*
\p 
\v 15 \wj “Ya mere, mgbe unu hụrụ ihe arụ nke na-eweta mbibi, nke e kwuru okwu ya site nʼọnụ Daniel onye amụma,\wj*\f + \fr 24:15 \ft \xt Dan 9:27; 11:31; 12:11\xt*\f*\wj ka ọ na-eguzo nʼebe nsọ (onye na-agụ ya nwee nghọta ihe ọ pụtara).\wj*
\v 16 \wj Mgbe ahụ, ka ndị nọ na Judịa were ọsọ gbalaga nʼelu ugwu.\wj*
\v 17 \wj Ka onye nọ nʼelu ụlọ ghara ịrịdata ka ọ banye nʼime ụlọ ya, ịkwapụta ngwongwo dị nʼime ụlọ ya.\wj*
\v 18 \wj Ka onye nọ nʼubi ghara ịlọghachi nʼụlọ ya ịchịrị uwe ya.\wj*
\v 19 \wj Ma ịta ahụhụ ga-adịrị ndị nwanyị di ime, na ndị na-enye ụmụaka ara nʼụbọchị ahụ\wj*
\v 20 \wj Kpesienụ ekpere ike ka unu ghara ịgba ọsọ a nʼoge oke oyi, maọbụ nʼụbọchị izuike.\wj*
\v 21 \wj Nʼihi na oke mkpagbu ga-adị, ụdị nke ụwa na-ahụbeghị mbụ, na nke anya na-agaghị ahụkwa ọzọ site na mmalite ụwa ruo mgbe ahụ.\wj*
\p 
\v 22 \wj “Ọ bụrụ na-emeghị ka ụbọchị ndị ahụ dị mkpụmkpụ, o nweghị onye a ga-azọpụta, ma nʼihi ndị ya ọ họpụtara, ụbọchị ndị ahụ ga-adị mkpụmkpụ.\wj*
\v 23 \wj Mgbe ahụ, ọ bụrụ na onye ọbụla asị unu, ‘Lee, Kraịst nọ nʼebe a,’ maọbụ, ‘Lee ya nʼebe ahụ,’ unu ekwela.\wj*
\v 24 \wj Nʼihi na ndị nzọpụta ụgha na ndị amụma ụgha ga-apụta. Ha ga-eme ihe oke ịrịbama na ọrụ ebube dị iche iche. Ọ bụrụ na ọ ga-ekwe mee, ha ga-esite nʼọrụ ebube ha ga-arụ duhie, ọ bụladị ndị ahụ a họpụtara.\wj*
\v 25 \wj Lee, agwala m unu ihe ndị a, mgbe ha na-emebeghị.\wj*
\p 
\v 26 \wj “Ya mere, ọ bụrụ na ha asị unu, ‘Lee, ọ nọ nʼime ọzara,’ unu agakwala. Ọ bụrụkwa na ha asị unu, ‘Lee, ọ nọ nʼime ime ụlọ,’ unu ekwela.\wj*
\v 27 \wj Nʼihi na ọbịbịa Nwa nke Mmadụ ga-adị ka amụma na-egbu nʼọwụwa anyanwụ nke a na-ahụ anya nʼọdịda anyanwụ.\wj*
\v 28 \wj Matakwanụ na ebe ọbụla ozu dị, nʼebe ahụ ka udele na-ezukọta.\wj*
\p 
\v 29 \wj “Ngwangwa mgbe mkpagbu nke ụbọchị ndị ahụ niile gabigasịrị,\wj*
\q1 \wj “ ‘anyanwụ ga-agba ọchịchịrị.\wj*
\q2 \wj Ọnwa agaghị enyekwa ìhè,\wj*
\q1 \wj kpakpando ga-esi na mbara eluigwe daa,\wj*
\q2 \wj ike niile nke eluigwe ga-ama jijiji.’\wj*\f + \fr 24:29 \ft \xt Aịz 13:10; 34:4\xt*\f*
\p 
\v 30 \wj “Nʼoge ahụ akara ngosi nke Nwa nke Mmadụ ga-apụta ihe na mbara eluigwe. Agbụrụ niile nke ụwa ga-anọkwa na-eru ụjụ. Ha ga-ahụ Nwa nke Mmadụ ka ọ na-abịa nʼigwe ojii, nʼike nakwa oke ebube.\wj*
\v 31 \wj Ọ ga-ewerekwa olu opi ike zipụ ndị mmụọ ozi ka ha gaa kpọkọtaa ndị niile a họpụtara site nʼakụkụ anọ niile nke eluigwe na ụwa.\wj*
\s1 Ihe mmụta site nʼosisi fiig
\p 
\v 32 \wj “Ugbu a mụtanụ ihe site nʼosisi fiig. Mgbe ọbụla alaka ya malitere iwepụta ome dị nro, na-epupụtakwa akwụkwọ ndụ maranụ na ọkọchị na-abịa nso.\wj*
\v 33 \wj Otu a kwa, mgbe unu na-ahụ ihe ndị a niile ka ha na-eme marakwanụ na ọ nọ nso, ọ bụladị nʼọnụ ụzọ unu.\wj*
\v 34 \wj Nʼezie agwa m unu, ihe ndị a niile aghaghị imezu tupu ọgbọ a agabiga.\wj*
\v 35 \wj Eluigwe na ụwa ga-agabiga, ma okwu m enweghị ike ịgabiga.\wj*
\s1 O nweghị onye maara mgbe ọ ga-abụ
\p 
\v 36 \wj “Ma o nweghị onye ọbụla maara ụbọchị ahụ, maọbụ oge awa ahụ ga-abụ. Ọ bụladị ndị mmụọ ozi nọ nʼeluigwe amaghị ya. Ọkpara ahụ amakwaghị. Ọ bụ naanị Nna maara ya.\wj*
\v 37 \wj Ọbịbịa Nwa nke Mmadụ ga-adị ka ọ dị nʼụbọchị Noa.\wj*
\v 38 \wj Nʼoge ahụ tupu iju mmiri ahụ abịa, ndị mmadụ nọ na-eri na aṅụ, na-emekwa mmemme ọlụlụ di na nwunye, ruo ụbọchị Noa banyere nʼime ụgbọ mmiri ya.\wj*
\v 39 \wj Ha amataghị ihe ga-eme tutu oke mmiri ahụ abịa kpochapụ ha niile. Otu ahụ ka ọbịbịa Nwa nke Mmadụ ga-adị.\wj*
\v 40 \wj Mmadụ abụọ ga na-arụkọ ọrụ nʼubi ha, a ga-ewepụ otu hapụkwa onye nke ọzọ.\wj*
\v 41 \wj Ụmụ nwanyị abụọ ga na-akwọ nri na nkume igwe nri, a ga-ewere otu, ma hapụkwa nke ọzọ.\wj*
\p 
\v 42 \wj “Nʼihi nke a, na-echenụ nche, nʼihi na unu amaghị ụbọchị Onyenwe unu ga-abịa.\wj*
\v 43 \wj Ma ghọtanụ nke a: Ọ bụrụ na nna nwe ụlọ mara oge onye ohi ga-abịa nʼụlọ ya nʼabalị, ọ ga-anọ na nche nʼoge ahụ. Ọ gaghị ekwe ka onye ohi kụwaa ụlọ ya.\wj*
\v 44 \wj Otu a ka unu onwe unu pụrụ isi nọgide na nche oge niile, nʼihi na Nwa nke Mmadụ ga-abịa nʼoge awa unu na-atụghị anya ya.\wj*
\s1 Ọ dị mkpa ịnọ na nche
\p 
\v 45 \wj “Onye bụ ohu ahụ nke kwesiri ntụkwasị obi ma nwekwa uche, nke onyenwe ya mere onyeisi ndị ohu nọ nʼezinaụlọ ya, ka ọ na-enye ha nri nʼoge ya?\wj*
\v 46 \wj Ngọzị na-adịrị ohu ahụ, onye, mgbe onyenwe ya ga-alọghachi hụ na ọ na-eme otu a.\wj*
\v 47 \wj Nʼezie asị m unu, ọ ga-eme ya onyeisi nke ihe niile o nwere.\wj*
\v 48 \wj Ma ọ bụrụ na ohu ahụ bụ onye ajọọ omume na-asị onwe ya,\wj*\f + \fr 24:48 \ft Maọbụ, na-asị nʼobi ya\f*\wj ‘Nna m ukwu anọọla ogologo oge,’\wj*
\v 49 \wj ọ bụrụkwa na o bido iti ndị ohu ibe ya ihe, sorokwa ndị ọṅụ oke mmanya na-eri, na-aṅụ.\wj*
\v 50 \wj Nna ukwu ohu ahụ ga-alọta nʼụbọchị ọ na-atụghị anya, nʼoge awa ọ na-amakwaghị.\wj*
\v 51 \wj Ọ ga-egburisikwa ya, nye ya ọnọdụ nʼetiti ebe ndị ihu abụọ nọ. Ebe e nwere ịkwa akwa na ịta ikikere eze.\wj*
\c 25
\s1 Ụmụ agbọghọ iri
\p 
\v 1 \wj “A ga-eji alaeze eluigwe tụnyere akụkọ ụmụ agbọghọ iri ndị weere oriọna ha pụta izute onye na-alụ nwunye ọhụrụ.\wj*
\v 2 \wj Ise nʼime ha maara ihe, ma ise ndị ọzọ bụ ndị nzuzu.\wj*
\v 3 \wj Ise ndị nzuzu ahụ weere oriọna ha, ma ha ejighị mmanụ ọkụ.\wj*
\v 4 \wj Ise ndị maara ihe, wụjuru mmanụ ọkụ na karama, tinyekwa oriọna ha.\wj*
\v 5 \wj Mgbe onye na-alụ nwunye ọhụrụ ahụ nọrọ ọdụ nʼọbịbịa ya, ụra tụwara ha, ha dinara ala rahụ ụra.\wj*
\p 
\v 6 \wj “Nʼetiti abalị e tiri mkpu nʼoke olu sị, ‘Onye na-alụ nwunye ọhụrụ na-abịa, pụtanụ gaa zute ya!’\wj*
\p 
\v 7 \wj “Mgbe ahụ ụmụ agbọghọ niile ahụ\wj*\f + \fr 25:7 \ft E mere ka anyị mara na ndị a bụ ndị ha na nwoke ọbụla e dinabeghị.\f*\wj biliri mụnye oriọna ha.\wj*
\v 8 \wj Ise ndị nzuzu ahụ rịọrọ ise ndị maara ihe sị, ‘Biko, wụnyetụrụnụ anyị ụfọdụ nʼime mmanụ ọkụ unu, lee na oriọna anyị na-anyụ anyụ.’\wj*
\p 
\v 9 \wj “Ndị maara ihe zara ha sị, ‘Mba! Ọ gaghị ezuru anyị na unu. Kama gaanụ zuru nke unu nʼaka ndị na-ere ya.’\wj*
\p 
\v 10 \wj “Ma mgbe ha pụrụ ịzụta mmanụ ọkụ ahụ, onye na-alụ nwunye ọhụrụ bịarutere. Ndị jikeere ejikere soro ya banye nʼoriri ọlụlụ di na nwunye ahụ. E mechikwara ọnụ ụzọ.\wj*
\p 
\v 11 \wj “Emesịa, ise ndị nzuzu ahụ\wj*\f + \fr 25:11 \ft Ụmụ agbọghọ ise ndị nzuzu\f*\wj lọghachiri na-ekwu sị, ‘Onyenwe anyị, Onyenwe anyị, meghere anyị ụzọ!’\wj*
\p 
\v 12 \wj “Ma ọ zaghachiri ha sị, ‘Nʼezie, nʼezie, agwa m unu, amaghị m ndị unu bụ.’\wj*
\p 
\v 13 \wj “Ya mere, na-anọgidenụ na nche, nʼihi na unu amaghị ụbọchị ahụ, maọbụ oge awa ahụ.\wj*
\s1 Ijizi akụ
\p 
\v 14 \wj “Ọzọ, ọ ga-adị ka otu nwoke chọrọ ịga njem. Ọ kpọkọtara ndị ohu ya niile nyefee ha akụnụba ya nʼaka.\wj*
\v 15 \wj O nyere onye nke mbụ talenti ise, nke abụọ ka o nyere talenti abụọ. O nyere onye nke ikpeazụ otu talenti.\wj*\f + \fr 25:15 \fq Talenti \ft Otu talenti bụ ụgwọ ọnwa iri afọ abụọ nke onye Griik na-arụ ọrụ ụbọchị.\f*\wj O nyere ha nʼotu nʼotu dị ka ike ha ha. Mgbe ahụ ọ hapụrụ ha gaa ije ya.\wj*
\v 16 \wj Onye ahụ natara talenti ise weere ego ahụ malite ịzụ ahịa. Ngwangwa o retara talenti ise ọzọ nʼuru.\wj*
\v 17 \wj Otu a kwa, onye nke e nyere talenti abụọ zụpụtakwara talenti abụọ ọzọ nʼuru.\wj*
\v 18 \wj Ma onye ahụ natara otu talenti gara gwuo ala lie ego nna ya ukwu, nʼihi ichezi ya nke ọma.\wj*
\p 
\v 19 \wj “Mgbe ogologo oge gasịrị, nna ukwu ndị ohu ahụ lọtara site nʼije ya. Ọ kpọkọtara ha niile ka ha gụzie akụ ya.\wj*
\v 20 \wj Onye ahụ natara talenti ise batara wetakwa ise ọzọ. Ọ gwara nna ya ukwu sị, ‘Ị nyere m talenti ise, ma ugbu a azụpụtala m talenti ise ọzọ!’\wj*
\p 
\v 21 \wj “Nna ya ukwu sịrị ya, ‘I mere nke ọma ezi ohu kwesiri ntụkwasị obi. I zipụtala na i kwesiri ntụkwasị obi nʼihe dị ntakịrị. Nʼihi ya aga m etinye gị nʼebe ị ga-elekọta ọtụtụ ihe. Bata nʼọṅụ nke nna gị ukwu.’\wj*
\p 
\v 22 \wj “Onye nke e nyere talenti abụọ bịara sị, ‘Nna anyị ukwu, i nyere m talenti abụọ, ma lee, eritala m talenti abụọ ọzọ nʼuru.’\wj*
\p 
\v 23 \wj “Nna ya ukwu sịrị ya, ‘I mere nke ọma. Ị bụ ezi ohu kwesiri ntụkwasị obi. I zipụtala na i kwesiri ntụkwasị obi nʼihe dị ntakịrị. Nʼihi ya aga m etinye gị nʼebe ị ga-elekọta ọtụtụ ihe. Bata nʼọṅụ nke nna gị ukwu.’\wj*
\p 
\v 24 \wj “Onye e nyere otu talenti batara sị, ‘Nna anyị ukwu, amaara m onye ị bụ. Ị bụ onye aka ntagide. Ị na-ewe ihe ubi nʼebe ị na-akụghị mkpụrụ. Ị na-achịkọtakwa nʼebe ị na-agbasaghị.\wj*
\v 25 \wj Nʼihi nke a, atụrụ m egwu, a gara m liere gị ego talenti gị nʼala. Lee ihe gị werekwa.’\wj*
\p 
\v 26 \wj “Nna ya ukwu zara ya sị, ‘Ohu ọjọọ na onye umengwụ. Ị maara na m na-ewe ihe ubi nʼebe m na-akụghị mkpụrụ, na-achịkọtakwa nʼebe m na-agbasaghị.\wj*
\v 27 \wj Ị gaara etinye ego m nʼaka ndị na-echekwa ego, ndị gaara akwụghachi ya na ọmụrụnwa ya, nke m gaara anata mgbe m lọghachiri.\wj*
\p 
\v 28 \wj “ ‘Napụtanụ ya talenti ahụ o ji, were ya nye onye ji talenti iri.\wj*
\v 29 \wj Nʼihi na onye ọbụla nwere ka a ga e tinyekwuru ka o nwebigakwa oke. Ma onye ahụ ọ na-adịghị nke o nwere, a ga-anapụ ya ọ bụladị nke nta o nwere.\wj*
\v 30 \wj Tụpụnụ ohu a na-abaghị uru nʼezi, nʼime ọchịchịrị, ebe ịkwa akwa na ịta ikikere eze ga-adị.’\wj*
\s1 Ikpe nke ikpeazụ
\p 
\v 31 \wj “Mgbe Nwa nke Mmadụ ga-abịa nʼebube ya na ndị mmụọ ozi niile, mgbe ahụ ka ọ ga-anọ nʼelu ocheeze ebube ya.\wj*
\v 32 \wj Mba niile nke ụwa ga-ezukọtakwa nʼihu ya. Ọ ga-ekewapụta ha, otu obodo site nʼibe ya, dị ka onye ọzụzụ atụrụ sị ekewapụta ụmụ atụrụ site nʼụmụ ewu.\wj*
\v 33 \wj Ọ ga-edebe ụmụ atụrụ ahụ nʼakụkụ aka nri ya, ma ụmụ ewu ga-anọ nʼaka ekpe ya.\wj*
\p 
\v 34 \wj “Mgbe ahụ, eze ga-asị ndị nọ nʼaka nri ya, ‘Batanụ nʼime alaeze, unu ndị Nna m gọziri agọzi, batanụ nʼime alaeze nke e doziiri unu site na mgbe e kere ụwa.\wj*
\v 35 \wj Nʼihi na mgbe agụụ gụrụ m unu nyere m nri. Mgbe akpịrị kpọrọ m nkụ unu nyere m ihe ọṅụṅụ. Mgbe m bụ ọbịa unu kpọbatara m.\wj*
\v 36 \wj Mgbe m gba ọtọ, unu zụtara uwe nye m. Mgbe m dara ọrịa unu lekọtara m. Anọkwara m nʼụlọ mkpọrọ unu bịara leta m.’\wj*
\p 
\v 37 \wj “Mgbe ahụ ndị ezi omume ahụ ga-ajụ ya sị, ‘Onyenwe anyị, olee mgbe anyị hụrụ gị ka agụụ na-agụ gị anyị enye gị nri? Olee mgbe anyị hụrụ gị ka akpịrị na-akpọ gị nkụ, anyị ekuru mmiri ọṅụṅụ nye gị?\wj*
\v 38 \wj Olee mgbe kwa ka anyị hụrụ gị dị ka onye ọbịa anyị akpọbata gị? Olee mgbe kwa ka anyị hụrụ gị ka ị gba ọtọ anyị enye gị uwe?\wj*
\v 39 \wj Olee mgbe kwa ka anyị hụrụ gị nʼọrịa, maọbụ nʼụlọ mkpọrọ anyị abịa leta gị?’\wj*
\p 
\v 40 \wj “Eze ahụ ga-azaghachi ha sị, ‘Nʼezie asị m unu, mgbe unu mesoro otu nʼime ndị a dị nta nʼime ụmụnne m omume ọma, ọ bụ m ka unu mesoro omume ahụ.’\wj*
\p 
\v 41 \wj “Mgbe ahụ ọ ga-asịkwa ndị nọ nʼaka ekpe ya, ‘Pụọnụ nʼihu m unu ndị a bụrụ ọnụ. Baanụ nʼime ọdọ ọkụ ebighị ebi ahụ a kwadobeere ekwensu na ndị mmụọ ozi ya.\wj*
\v 42 \wj Nʼihi na mgbe agụụ na-agụ m, unu enyeghị m ihe ọbụla ka m rie. Mgbe akpịrị na-akpọ m nkụ, unu ekunyeghị m mmiri ka m ṅụọ.\wj*
\v 43 \wj Mgbe m nọ dị ka ọbịa, unu akpọbataghị m nʼụlọ unu. Mgbe m gba ọtọ, unu enyeghị m uwe. Mgbe ahụ na-esighị m ike, unu elekọtaghị m. Mgbe m nọ nʼụlọ mkpọrọ, unu abịaghị leta m.’\wj*
\p 
\v 44 \wj “Mgbe ahụ ha ga-azakwa sị, ‘Onyenwe anyị, olee mgbe anyị hụrụ gị ka agụụ na-agụ gị, maọbụ ka akpịrị na-akpọ gị nkụ, maọbụ oge ị bụ onye ọbịa, maọbụ oge ị gba ọtọ, maọbụ oge ị nọ nʼọrịa, maọbụ ị nọ nʼụlọ mkpọrọ, ma anyị elekọtaghị gị?’\wj*
\p 
\v 45 \wj “Ọ ga-aza ha sị, ‘Eziokwu ahụ bụ nke a, mgbe ahụ unu jụrụ inyere otu nʼime ndị a dị nta aka, ọ bụ m ka unu jụrụ i nyere aka.’\wj*
\p 
\v 46 \wj “Ndị a ga-aba nʼịta ahụhụ ebighị ebi. Ma ndị ezi omume ga-aba na ndụ ebighị ebi.”\wj*
\c 26
\s1 Izuzu megide Jisọs
\p 
\v 1 Mgbe Jisọs kwusiri okwu ndị a, ọ gwara ndị na-eso ụzọ ya sị,
\v 2 \wj “Dị ka unu maara nke ọma, Mmemme Ngabiga ga-amalite mgbe ụbọchị abụọ gasịrị. Nʼoge ahụ, a ga-ararakwa Nwa nke Mmadụ nye ka a kpọgide ya nʼobe.”\wj*
\p 
\v 3 Nʼoge ahụ, ndịisi nchụaja, na ndị okenye zukọtara nʼụlọeze otu onyeisi nchụaja a na-akpọ Kaịfas.
\v 4 Ha gbara izu ịchọpụta ụzọ ha ga-esi jide Jisọs na nzuzo gbuo ya.
\v 5 Ha kwekọrịta sị, “Ọ gaghị abụ nʼoge mmemme ka ọgbaaghara hapụ ịdị nʼetiti ndị mmadụ.”
\s1 Otite mmanụ na Betani
\p 
\v 6 Mgbe Jisọs nọ na Betani, nʼụlọ Saimọn onye ekpenta,
\v 7 otu nwanyị bu karama alabasta nke mmanụ otite isi ụtọ dị oke ọnụahịa dị nʼime ya, bịakwutere ya, nke ọ wụsara ya nʼisi dị ka ọ na-anọdụ ala nʼeri nri.
\p 
\v 8 Ma mgbe ndị na-eso ụzọ ya hụrụ nke a, iwe were ha nke ukwuu. Ha sịrị, “Olee ụdị ịla nʼiyi dị nke a!
\v 9 A gaara erepụta mmanụ a ego dị ukwuu were ego e retara ya nyere ndị ogbenye aka.”
\p 
\v 10 Ebe Jisọs matara ihe ha na-atamu nʼobi ha, ọ sịrị ha, \wj “Gịnị mere unu ji esogbu nwanyị a? O merela m ihe dị mma.\wj*
\v 11 \wj Unu na ndị ogbenye ga-anọ oge niile, ma ọ bụghị mụ na unu ga-anọ mgbe niile.\wj*
\v 12 \wj Nʼihi na site nʼịwụ m mmanụ otite a nʼahụ, o doziela m maka olili.\wj*
\v 13 \wj Nʼezie, ana m agwa unu, nʼebe ọbụla ezisara oziọma a nʼụwa niile, a ga na-echeta nwanyị a nʼihi ihe ọma a o meere m.”\wj*
\s1 Juda ekwere ịrara Jisọs nye
\p 
\v 14 Mgbe ahụ otu nʼime mmadụ iri na abụọ na-eso ụzọ ya, onye aha ya bụ Judas Iskarịọt, jekwuuru ndịisi nchụaja.
\v 15 Ọ jụrụ ha sị, “Gịnị ka unu ga-enye m ma m rara ya nye nʼaka unu?” Ha kwụrụ ya iri mkpụrụ ọlaọcha atọ.
\v 16 Site nʼoge ahụ na-aga, ọ chọrọ ohere ịrara ya nye nʼaka ha.
\s1 Oriri Mmemme Ngabiga
\p 
\v 17 Nʼụbọchị mbụ nke mmemme achịcha na-ekoghị eko, ndị na-eso ụzọ Jisọs bịakwutere ya jụọ ya sị, “Ebee ka ị chọrọ ka anyị gaa kwadoro gị ihe gị maka oriri Ngabiga?”
\p 
\v 18 Ọ zara ha sị, \wj “Jekwurunụ otu nwoke nʼime obodo sị ya, Onye ozizi sị, ‘Oge m abịala nso. Mụ na ndị na-eso ụzọ m ga-eri oriri Ngabiga nʼụlọ gị.’ ”\wj*
\v 19 Ndị na-eso ụzọ ya mere dị ka Jisọs gwara ha, doziekwa oriri Ngabiga ahụ nʼebe ahụ.
\p 
\v 20 Nʼuhuruchi ụbọchị ahụ, ya na ndị na-eso ụzọ ya iri na abụọ ahụ nọdụrụ ala nʼoche nri ahụ.
\v 21 Mgbe ha na-eri nri, o kwuru sị, \wj “Nʼezie ana m agwa unu, na otu onye nʼime unu ga-arara m nye.”\wj*
\p 
\v 22 Ha nwere oke mwute, ma malite ịjụ ya nʼotu nʼotu sị, “Onyenwe anyị, ọ bụ m?”
\p 
\v 23 Ma ọ zara ha sị, \wj “Ọ bụ onye ahụ mụ na ya na-amanyekọta aka nʼotu efere ga-arara m nye.\wj*
\v 24 \wj Lee Nwa nke Mmadụ ga-ala dị ka e si buo ya nʼamụma. Ma ahụhụ ga-adịrị nwoke ahụ onye a ga-esite nʼaka ya rara Nwa nke Mmadụ nye. Ọ gaara akara onye ahụ mma ma a sị na a mụghị ya amụ.”\wj*
\p 
\v 25 Judas, onye ahụ raara ya nye jụrụ ya sị, “Onye ozizi ọ bụ m?”
\p Ọ zara sị, \wj “Gị onwe gị ekwuola ya.”\wj*
\s1 Mmalite oriri nsọ
\p 
\v 26 Mgbe ha nọkwa na-eri nri, Jisọs were ogbe achịcha ahụ, mgbe o nyechara ekele, ọ nyawara ya nye ndị na-eso ụzọ ya sị ha, \wj “Naranụ nke a rie, nʼihi na nke a bụ anụ ahụ m.”\wj*
\p 
\v 27 Mgbe ahụ kwa, o burukwara iko mmanya, ma mgbe o nyechara ekele, o bunyere ya ndị na-eso ụzọ ya sị ha, \wj “Unu niile ṅụọnụ site nʼiko a.\wj*
\v 28 \wj Nʼihi na nke a bụ ọbara m nke bụ akara ọgbụgba ndụ ọhụrụ ahụ. A na-awụsa ya maka ọtụtụ mgbaghara mmehie.\wj*
\v 29 \wj Ana m agwa unu, na-agaghị m aṅụ mmanya sitere na mkpụrụ vaịnị ọzọ, tutu ruo ụbọchị ahụ mụ na unu ga-aṅụ ya nʼụzọ dị iche nʼalaeze Nna m.”\wj*
\p 
\v 30 Mgbe ha bụsịrị abụ, ha pụrụ gaa nʼUgwu Oliv.
\s1 Ngọnarị Pita
\p 
\v 31 Mgbe ahụ Jisọs gwara ha sị, \wj “Nʼabalị taa, unu niile ga-agbahapụ naanị m. Nʼihi na e dere ya, sị:\wj*
\q1 \wj “ ‘Aga m etigbu onye ọzụzụ atụrụ,\wj*
\q2 \wj atụrụ nke igwe atụrụ ahụ ga-agbasasịkwa.’\wj*\f + \fr 26:31 \ft \xt Zek 13:7\xt*\f*
\m 
\v 32 \wj Ma mgbe e mere ka m si nʼọnwụ bilite, aga m ebu unu ụzọ gaa Galili.”\wj*
\p 
\v 33 Pita sịrị, “Ọ bụrụ na mmadụ niile agbahapụ gị gbalaga, agaghị m ahapụ gị.”
\p 
\v 34 Jisọs sịrị, \wj “Nʼezie agwa m gị, nʼabalị taa, tupu oke ọkụkụ akwaa akwa, ị ga-agọnarị m ugboro atọ.”\wj*
\p 
\v 35 Ma Pita kwuru sị, “Ọ bụrụ na ọ dị mkpa ka m soro gị nwụọ, agaghị m agọnarị gị.” Ọ bụkwa otu ihe ahụ ka ndị ahụ niile na-eso ụzọ ya kwuru.
\s1 Ekpere Jisọs na Getsameni
\p 
\v 36 Mgbe Jisọs bịara nʼogige ahụ a na-akpọ Getsameni, ọ gwara ndị na-eso ụzọ ya sị ha, \wj “Nọdụnụ nʼebe a ka m gaa nʼihu nke nta kpee ekpere.”\wj*
\v 37 Ọ kpọọrọ Pita tinyere onwe ya, na ụmụ Zebedi abụọ. Ọ malitere inwe obi mwute nʼime onwe ya. Obi malitekwara ịlọ ya mmiri.
\v 38 Mgbe ahụ ọ gwara ha sị, \wj “Ọ na-ewute mkpụrụobi m nke ukwuu ruo nʼọnụ ọnwụ. Nọgidenụ nʼebe a soro m na-eche nche.”\wj*
\p 
\v 39 Ọ gara nʼihu nke nta daa, kpuo ihu ya nʼala, kpee ekpere sị, \wj “Nna m, ọ bụrụ na ọ ga-ekwe mee, napụ m iko a. Ma ọ bụghị ka e mee uche m, kama ka e mee uche gị.”\wj*
\p 
\v 40 Ya mere, ọ bịakwutere ndị na-eso ụzọ ya, hụ ha ka ha na-arahụ ụra. Ọ sịrị Pita, \wj “Ọ bụ na unu enweghị ike i soro m chee nche, ọ bụladị otu awa?\wj*
\v 41 \wj Na-echenụ nche, na-ekpekwa ekpere, ka unu ghara ịba nʼọnwụnwa.\wj*\f + \fr 26:41 \ft Maọbụ, \fqa nwalee\f*\wj Nʼihi na mmụọ dị na njikere ma anụ ahụ adịghị ike.”\wj*
\p 
\v 42 Ọ laghachiri azụ nke ugboro abụọ kpeekwa ekpere sị, \wj “Nna m, ọ bụrụ na iko a agaghị agabiga ma ọ bụghị na m ṅụrụ ya, ka e mee uche gị.”\wj*
\p 
\v 43 Ọ lọghachikwara ọzọ hụkwa ka ha na-arahụ ụra, nʼihi na anya ha dị arọ.
\v 44 Ọ hapụrụ ha ọzọ gaa kpee ekpere nke ugboro atọ, na-ekwukwa otu okwu ahụ.
\p 
\v 45 Mgbe ọ lọghachikwutere ndị na-eso ụzọ ya, ọ sịrị ha, \wj “Unu ka nọ na-arahụ ụra, na-ezukwa ike? Lee, oge awa ahụ abịala, a rarala Nwa nke Mmadụ nye nʼaka ndị mmehie.\wj*
\v 46 \wj Bilienụ ka anyị gawa. Lee, onye ahụ na-arara m nye na-abịa!”\wj*
\s1 Njide e jidere Jisọs
\p 
\v 47 Mgbe ọ nọ na-ekwu okwu a, Judas, otu nʼime ndị ozi iri na abụọ ahụ bịaruru, ya na ọtụtụ igwe mmadụ so. Ụfọdụ ji mma agha ha, ndị ọzọ ji osisi.\f + \fr 26:47 \ft Maọbụ, \fqa mkpọ\f* Ọ bụ ndịisi nchụaja na ndị okenye ndị Juu zitere ha.
\v 48 Ma onye ahụ na-arara ya nye, nyere ha ihe ịrịbama, sị, “Onye ahụ m ga-esutu ọnụ bụ nwoke ahụ, jidesienụ ya aka ike!”
\v 49 Ngwangwa o jekwuuru Jisọs sị ya, “Ekele, Onye ozizi!” ma sutukwa ya ọnụ.
\p 
\v 50 Jisọs gwara ya sị, \wj “Enyi m, mee ihe ị bịara ime ngwangwa.”\wj*
\p Mgbe ahụ, ndị ikom ahụ bịara nso jide Jisọs, sekpụrụ ya nʼike.
\v 51 Otu onye nʼime ndị ha na Jisọs nọ, setịrị aka ya, mịpụta mma agha ya, gbuo ohu onyeisi nchụaja, gbupụ ntị ya.
\p 
\v 52 Ma Jisọs sịrị ya, \wj “Mịghachi mma agha gị nʼọbọ ya, nʼihi na mmadụ ọbụla na-eji mma egbu mmadụ ibe ya ga-anwụ site na mma.\wj*
\v 53 \wj I cheghị na m pụrụ ịrịọ Nna m ka o zitere m ihe karịrị usuu ndị mmụọ ozi iri na abụọ nʼotu ntabi anya?\wj*
\v 54 \wj Ma olee otu ihe e dere nʼakwụkwọ nsọ ga-esi mezuo, nke kwuru na ọ ghaghị ịdị otu a?”\wj*
\p 
\v 55 Nʼoge awa ahụ, Jisọs gwara igwe mmadụ ahụ sị, \wj “Unu pụtara chịrị mma agha na mkpọ bịa ijide m dị ka a ga-asị na m bụ onye ohi? Anọrọla m ziekwa ihe nʼụlọnsọ kwa ụbọchị, ma unu ejideghị m.\wj*
\v 56 \wj Ma ihe ndị a na-eme ka ihe ndị amụma dere nʼakwụkwọ nsọ mezuo.”\wj* Nʼoge ihe ndị a niile na-eme, ndị na-eso ụzọ ya niile hapụrụ ya gbalaga.
\s1 Jisọs nʼụlọikpe
\p 
\v 57 Ndị jidere Jisọs duuru ya gaa nʼụlọ Kaịfas, onyeisi nchụaja. Ndị ozizi iwu na ndị okenye ndị Juu zukọtara nʼebe ahụ.
\v 58 Pita sogidere Jisọs nʼazụ site nʼebe dị anya. O rutere nʼobi onyeisi nchụaja, baa nʼime ụlọ, sorokwa ndị na-eje ozi nọdụ ala, ka o nwe ike ịhụ otu ihe a ga-esi bie.
\p 
\v 59 Ndịisi nchụaja, na ndịisi ikpe nʼụlọikpe ahụ nọ na-achọ ama ụgha megide Jisọs, ka ha hụ ụzọ ha ga-esi gbuo ya.
\v 60 Ma ọ dịghị nke ha chọtara, nʼagbanyeghị nʼọtụtụ ndị akaebe ụgha pụtara.
\p Nʼikpeazụ, mmadụ abụọ pụtara
\v 61 kwuo sị, “Nwoke a sịrị, ‘Enwere m ike ịkwatu ụlọnsọ ukwu nke Chineke, wughachikwa ya nʼụbọchị atọ. ’ ”
\p 
\v 62 Onyeisi nchụaja biliri ọtọ kwuo sị, “Ọ bụ na ị nweghị ihe ọbụla ị ga-aza? Gịnị bụ ama ndị a a na-agba megide gị?”
\v 63 Ma Jisọs ekwughị ihe ọbụla.
\p Onyeisi nchụaja gwara ya sị, Eji m aha Chineke dị ndụ nye gị iwu, sị gị, “gwa anyị, ị bụ Kraịst, Ọkpara Chineke?”
\p 
\v 64 Jisọs gwara ya sị, \wj “Gị onwe gị kwuru ya. Ma ana m agwa unu, site ugbu a na-aga nʼihu, unu ga-ahụ Nwa nke Mmadụ ka ọ na-anọdụ nʼaka nri nke Onye dị ike, na-abịakwa nʼigwe ojii nke eluigwe.”\wj*
\p 
\v 65 Mgbe ahụ onyeisi nchụaja dọwara uwe ya, kwuo sị, “O kwuola arụ! Olee mkpa ọ dị ịchọkwa ndị akaebe? Unu nụkwara nkwulu ya?
\v 66 Gịnị bụ mkpebi unu?”
\p Ha zara sị ya, “O kwesiri ka ọ nwụọ!”
\p 
\v 67 Mgbe ahụ, ha gbụsara ya ọnụ mmiri asọ nʼihu, tiekwa ya aka. Ndị ọzọ maara ya ụra,
\v 68 sị ya, “Buoro anyị amụma, gị, Kraịst. Onye tiri gị ihe?”
\s1 Pita agọnarị Jisọs
\p 
\v 69 Mgbe ahụ Pita nọdụrụ ala na mbara ezi nke obi ahụ. Otu nʼime ụmụ agbọghọ na-eje ozi bịakwutere ya, sị, “Ị bụkwanụ otu nʼime ndị na-eso ụzọ Jisọs onye Galili.”
\p 
\v 70 Ma ọ gọrọ nʼihu ha niile sị, “Amaghị m ihe ị na-ekwu.”
\p 
\v 71 Mgbe ọ pụrụ gaa nọdụ nʼọnụ ụzọ mbata, nwaagbọghọ ọzọ hụrụ ya, gwa ndị nọ nʼebe ahụ sị, “Nwoke a na Jisọs onye Nazaret nọkọrọ.”
\p 
\v 72 Ọzọkwa, o weere ịṅụ iyi gọọ, “Amaghị m onye nwoke ahụ bụ.”
\p 
\v 73 Mgbe oge nta gasịrị, ndị guzo nʼebe ahụ bịakwutere Pita sị ya, “Nʼezie, ịbụ otu nʼime ha, nʼihi na asụsụ gị agbaala gị ama.”
\p 
\v 74 Ọ malitere ịbụ onwe ya ọnụ, na ịṅụ iyi sị, “Amaghị m nwoke a.”
\p Mgbe ahụkwa oke ọkpa kwara akwa.
\v 75 Pita chetara okwu ahụ Jisọs kwuru sị, \wj “Tupu oke ọkpa akwaa akwa, ị ga-agọnarị m ugbo atọ.”\wj* O si nʼebe ahụ pụọ, gaa kwaa akwa nke ukwuu.
\c 27
\s1 Jisọs nʼihu Pailet
\p 
\v 1 Mgbe chi bọrọ, ndịisi nchụaja niile na ndị okenye gbara izu megide Jisọs otu ha ga-esi gbuo ya.
\v 2 Ya mere, ha kere ya agbụ, duru ya pụọ, nyefee ya nʼaka Pailet onye bụ gọvanọ.
\s1 Ọnwụ Judas
\p 
\v 3 Mgbe Judas, onye ahụ rara Jisọs nye, hụrụ na a maala Jisọs ikpe ọnwụ, o chegharịrị weghachikwara ndịisi nchụaja na ndị okenye iri ego ọlaọcha atọ ahụ.
\v 4 Ọ kwuru sị, “Emehiela m, site na ịrara onye aka ya dị ọcha nye ọnwụ.”
\p Ma ha sịrị, “Nke ahụ agbasaghị anyị, ọ bụ mkpa dịrị gị.”
\p 
\v 5 Ọ wụsara ego ọlaọcha ahụ nʼala ụlọnsọ, pụọ gaa kwụọ ụdọ.
\p 
\v 6 Ndịisi nchụaja tụtụkọtara ego ahụ kwuo sị, “O megidere iwu itinye ego a nʼime ụlọakụ, nʼihi na ọ bụ ego ọbara.”
\v 7 Mgbe ha gbasịrị izu, ha kwekọtara ma were ego ahụ zụta ala nʼaka otu ọkpụ ite. Ha mere ala ahụ ka ọ bụrụ ebe a na-eli ndị ọbịa.
\v 8 Nke a mere e ji na-akpọ ala ahụ, “Ala Ọbara,”\f + \fr 27:8 \ft Maọbụ, \fqa Ubi Ọbara\f* ruo taa.
\v 9 Nʼụzọ dị otu a, okwu e kwuru site nʼọnụ Jeremaya onye amụma mezuru. “Ha tụtụkọtara mkpụrụ ego ọlaọcha iri atọ, bụ ọnụahịa onye ahụ, nke ụfọdụ nʼime ụmụ Izrel kpebiri na a ga-akwụ nʼisi ya.
\v 10 Ha ji ego ahụ zụọ ubi onye ọkpụ ite, dị ka Onyenwe anyị nyere m iwu.”\f + \fr 27:10 \ft \xt Zek 11:12,13; Jer 19:1-13; 32:6-9\xt*\f*
\s1 Pailet ajụọ Jisọs ajụjụ
\p 
\v 11 Nʼoge a Jisọs guzo nʼihu gọvanọ. Gọvanọ jụrụ ya sị, “Ị bụ eze ndị Juu?”
\p Jisọs sịrị ya, \wj “Gị onwe gị kwuru ya.”\wj*
\p 
\v 12 Mgbe ndịisi nchụaja na ndị okenye boro ya ebubo ụgha, o kwughị ihe ọbụla.
\v 13 Ya mere, Pailet sịrị ya, “Ị naghị anụ ihe ndị a niile ha na-ebo gị?”
\v 14 Ma ọ zaghị ọ bụladị otu mkpụrụ okwu nʼebubo ndị ahụ. Ihe a gbagwojuru gọvanọ anya nke ukwuu.
\s1 Ikpe ọnwụ a mara Jisọs
\p 
\v 15 Ugbu a, ọ bụ omenaala gọvanọ nʼoge mmemme na ọ ga-ahapụ otu onye mkpọrọ, bụ onye igwe mmadụ họọrọ.
\v 16 Ma nʼoge a e nwere otu onye mkpọrọ nke ọtụtụ mmadụ maara nke ọma. A na-akpọ Jisọs Barabas.
\v 17 Mgbe igwe mmadụ niile zukọrọ, Pailet sịrị ha, “Onye ka unu chọrọ ka m hapụrụ unu, ọ bụ Jisọs Barabas ka ọ bụ Jisọs onye a na-akpọ Kraịst?”
\v 18 Nʼihi na ọ maara nke ọma na ọ bụ site nʼekworo ka ha ji rara Jisọs nye nʼaka ya.
\p 
\v 19 Mgbe ọ nọkwasịrị nʼelu oche ikpe ya, nwunye ya zitere ozi sị ya, “Wepụkwa aka gị nʼihe gbasara nwoke onye ezi omume ahụ. Nʼihi na ahụjuru m anya na nrọ nʼabalị gara aga nʼihi ya.”
\p 
\v 20 Ma ndịisi nchụaja na ndị okenye kwagidere igwe mmadụ ahụ ka ha rịọ ya, ka ọ hapụrụ ha Barabas, ma nye ha Jisọs ka ha gbuo ya.
\p 
\v 21 Ọzọkwa, gọvanọ sịrị ha, “Nʼime mmadụ abụọ ndị a onye ka unu chọrọ ka m hapụrụ unu?”
\p Ha sịrị, “Barabas!”
\p 
\v 22 Pailet sịrị ha, “Gịnị ka m ga-eme Jisọs onye a na-akpọ Kraịst?”
\p Ha niile sịrị, “Kpọgide ya nʼobe!”
\p 
\v 23 Ọ jụrụ ha sị, “Ọ bụ nʼihi gịnị? Olee ihe ọjọọ o mere?”
\p Ma ha tiri mkpu karịa ka ha si eti na mbụ, na-asị, “Kpọgide ya nʼobe! Kpọgide ya nʼobe!”
\p 
\v 24 Mgbe Pailet hụrụ na o nweghị ihe ọ pụrụ ime, kama na ụzụ na ọgbaaghara na-amalite. O weere mmiri kwọọ aka ya nʼihu igwe mmadụ ahụ sị ha, “Aka m dị ọcha nʼebe ọbara nwoke a dị. Jirinụ aka unu hụ maka ya.”
\p 
\v 25 Igwe mmadụ ahụ zaghachiri ya nʼotu olu sị, “Ka ọbara ya dị nʼisi anyị na nʼisi ụmụ anyị!”
\p 
\v 26 Mgbe ahụ ọ hapụụrụ ha Barabas. Mgbe ọ pịachara Jisọs ihe, ọ raara ya nye ka ha kpọgide ya nʼobe.
\s1 Ndị agha ejiri Jisọs mee ihe ọchị
\p 
\v 27 Mgbe ahụ ndị agha gọvanọ duuru Jisọs baa nʼogige ụlọ ndị agha,\f + \fr 27:27 \ft Nke a na-akpọ Pritoriọm nʼasụsụ Griik.\f* mee ka otu ndị agha niile gbaa ya gburugburu.
\v 28 Ha yipụrụ ya uwe ya, yinye ya uwe mwụda na-acha uhie uhie.
\v 29 Ha kpara okpueze nke e ji ogwu mee, kpukwasị ya nʼisi. Ha tinyekwara ya mkpara achara nʼaka nri, gbuo ikpere nʼala nʼihu ya, na-akwa ya emo na-asị, “Ekele, Eze ndị Juu!”
\v 30 Ha gbụrụ ya ọnụ mmiri asọ, werekwa osisi ahụ kụọ ya nʼisi ọtụtụ mgbe.
\v 31 Mgbe ha ji ya mechaa ihe ọchị, ha yipụrụ ya uwe ahụ, yinyekwa ya uwe nke ya, duuru ya pụọ, ịga kpọgide ya nʼobe.
\s1 Ha akpọgide ya nʼobe
\p 
\v 32 Mgbe ha na-apụ, ha zutere otu nwoke onye obodo Sirini a na-akpọ Saimọn. Ha manyere ya ka o buru obe ya.
\v 33 Mgbe ha bịarutere nʼebe a na-akpọ Gọlgọta (nke pụtara, “ebe okpokoro isi”).
\v 34 Ha nyere ya mmanya a gwara ọgwụ ilu ka ọ ṅụọ. Mgbe o detụrụ ya ire, o kweghị ya ọṅụṅụ.
\v 35 Mgbe ha kpọgidechara ya nʼelu obe. Ha fere nza nke ha jiri kee uwe ya nʼetiti onwe ha.\f + \fr 27:35 \ft Imezu ihe e dere nʼAbụ Ọma 22:18.\f*
\v 36 Ha nọdụkwara ala nʼebe ahụ na-eche ya nche.
\v 37 Nʼelu ebe isi ya dị, ka ha debere ihe ha dekwasịrị ebubo ha boro ya. Nke a bụ ihe ha dere:
\pc Onye a bụ Jisọs, Eze ndị Juu.
\p 
\v 38 Ha kpọgidekwara ya na ndị ohi abụọ nʼobe. Otu onye nʼaka nri, onye nke ọzọ nʼaka ekpe ya.
\v 39 Ndị na-agafe nʼụzọ na-ekwutọ ya, na-efufekwa isi ha,
\v 40 na-asịkwa, “Leenụ onye nwere ike ịkwatu ụlọnsọ Chineke wughachi ya na mkpụrụ ụbọchị atọ! Zọpụtanụ onwe gị! Ọ bụrụ na ị bụ Ọkpara Chineke si nʼelu obe ahụ rịdata!”
\v 41 Ndịisi nchụaja, ndị ozizi iwu na ndị okenye sokwa na-eme ya ihe ọchị, na-asị,
\v 42 “Ọ zọpụtara ndị ọzọ, ma o nweghị ike ịzọpụta onwe ya. Ọ bụ eze ndị Izrel; ya si nʼelu obe rịdata ugbu a, anyị ga-ekwerekwa na ya.
\v 43 Ọ tụkwasịrị Chineke obi, ọ bụrụ na ọ masịrị Chineke, ya napụta ya ugbua, nʼihi na o kwuru sị, ‘Abụ m Ọkpara Chineke. ’ ”
\v 44 Ọ bụladị ndị ohi ahụ a kpọgidekọrọ ha na ya nʼobe nọkwa na-akparị ya.
\s1 Ọnwụ Jisọs
\p 
\v 45 Ma site nʼelekere iri na abụọ nke ehihie ruo nʼelekere atọ nke ehihie, ọchịchịrị gbachikọtara nʼala ahụ niile.
\v 46 Nʼoge dị ka elekere atọ nke ehihie, Jisọs tiri mkpu nʼoke olu sị, \tl \wj “Elọi, Elọi, lama sabaktani?”\wj*\tl* (nke pụtara, \wj “Chineke m, Chineke m, gịnị mere i jiri hapụ m?”\wj*).\f + \fr 27:46 \ft \xt Abụ 22:1\xt*\f*
\p 
\v 47 Mgbe ụfọdụ ndị guzo nʼebe ahụ nụrụ nke a, ha sịrị, “Ọ na-akpọ Ịlaịja.”
\p 
\v 48 Nʼotu oge ahụ kwa otu onye nʼime ha gbaara ọsọ were ogbo denye ya na mmanya gbara ụka, fanye ya nʼosisi, welie ya elu, chee ya ka ọ ṅụọ.
\v 49 Ma ndị ọzọ sịrị, “Hapụnụ, ka anyị lee ma Ịlaịja ọ ga-abịa ịzọpụta ya.”
\p 
\v 50 Ọzọkwa, Jisọs jiri oke olu tie mkpu, kubie ume.
\p 
\v 51 Nʼotu ntabi anya ahụ kwa, akwa mgbochi nke ụlọnsọ ahụ gbawara site nʼelu ruo nʼala. Ala makwara jijiji. Nkume tiwasịkwara.
\v 52 Ala ili meghere. A hụrụ ọtụtụ ndị nsọ, ndị nwụrụ anwụ, ka e mere ka ha si nʼọnwụ bilie.
\v 53 Mgbe ha sitere nʼọnwụ bilie, ha hapụrụ ili ha banye nʼime obodo nsọ, gosikwa ọtụtụ mmadụ onwe ha.
\p 
\v 54 Mgbe ọchịagha, na ndị ya ha nọ nʼebe ahụ na-eche Jisọs nche hụrụ ala ọma jijiji a, na ihe niile mere, ha tụrụ oke egwu. Ha kwuru sị, “Nʼezie, nwoke a bụ Ọkpara Chineke!”
\p 
\v 55 Ọtụtụ ụmụ nwanyị nọ nʼebe ahụ, ndị guzo nʼebe dị anya na-ele ihe na-eme. Ha si Galili soro Jisọs, na-ejere ya ozi.\f + \fr 27:55 \ft Nʼihi ịhụ maka mkpa ya\f*
\v 56 Nʼime ha bụ Meri Magdalin, na Meri nne Jemis na Josef, na nne ụmụ Zebedi.
\s1 Olili Jisọs
\p 
\v 57 Mgbe o ruru anyasị, otu onye ọgaranya si Arimatia aha ya bụ Josef. Onye ya onwe ya bụkwa onye na-eso ụzọ Jisọs,
\v 58 jekwuuru Pailet rịọọ ya ka e bunye ya ozu Jisọs. Pailet nyere iwu ka e bunye ya ozu ahụ.
\v 59 Josef buuru ozu ya, were ezi akwa ọcha linin na-enwu enwu fụchie ya,
\v 60 ma gaa lie ya nʼili ọhụrụ nke o gwuuru onwe ya, nʼetiti nkume. O jikwa otu nkume buru ibu kpuchie ọnụ ụzọ ili ahụ, hapụ ya laa.
\v 61 Meri Magdalin na Meri nke ọzọ nọ na-ebe ahụ, ha nọdụrụ ala na ncherita ihu ili ahụ.
\s1 Ndị nche nʼili Jisọs
\p 
\v 62 Nʼechi ya, nke bụ ụbọchị na-eso ụbọchị Nkwadebe, ndịisi nchụaja na ndị Farisii zukọrọ jekwuru Pailet.
\v 63 Ha kwuru sị, “Nna anyị ukwu, anyị na-echeta na mgbe onye ụgha ahụ dị ndụ, ọ sịrị na ya ga-esi nʼọnwụ bilie mgbe ụbọchị atọ gasịrị.
\v 64 Ya mere, nye iwu ka ndị agha gị na-eche ili ya nche, ruo mgbe ụbọchị atọ gasịrị. Nke a ga-egbochi ndị na-eso ụzọ ya ịga zuru ozu ya. Ka ha ghara ị sịkwa ndị mmadụ na o sitela nʼọnwụ bilie. Ọ bụrụ na ha agha ụgha dị otu a, ọ ga-ajọrọ anyị njọ mgbe ahụ karịa na mbụ.”
\p 
\v 65 Pailet gwara ha sị, “Unu nwere otu ndị agha na-eche nche, kpọrọnụ ha gaa mechisie ili ahụ ike dị ka unu si maara eme.”
\v 66 Ya mere, ha kpọrọ ndị agha gaa mechizie ọnụ ili ahụ. Ha kakwara akara nʼelu nkume ahụ.
\c 28
\s1 Mbilite nʼọnwụ Jisọs
\p 
\v 1 Mgbe ụbọchị izuike gasịrị, nʼisi ụtụtụ ụbọchị mbụ nʼime izu ụka, Meri Magdalin na Meri nke ọzọ, gara ka ha lee ili ahụ.
\p 
\v 2 Na mberede, oke ala ọma jijiji malitere. Nʼihi na mmụọ ozi Onyenwe anyị sitere nʼeluigwe rịdata, kpụgharịa nkume ahụ e ji mechie ọnụ ili ahụ, nọkwasịkwa nʼelu ya.
\v 3 Ihu ya na-enwu dị ka amụma. Uwe ya na-achakwa ọcha dị ka akụmmiri igwe.\f + \fr 28:3 \ft Ya bụ, snoo\f*
\v 4 Nʼihi egwu ya, ndị nche makwara jijiji. Daa nʼala nọrọ dị ka ndị nwụrụ anwụ.
\p 
\v 5 Ma mmụọ ozi ahụ gwara ụmụ nwanyị ahụ sị ha, “Unu atụla egwu, nʼihi na amaara m na ọ bụ Jisọs onye a kpọgburu nʼelu obe ka unu na-achọ.
\v 6 Ọ nọkwaghị nʼebe a. O sitela nʼọnwụ bilie, dị ka o si kwuo. Bịanụ lee ebe ọ tọgbọburu.
\v 7 Gaanụ ngwangwa gwa ndị na-eso ụzọ ya na e meela ka o si nʼọnwụ bilie. Lee, o burula unu ụzọ gawa Galili. Ebe ahụ ka unu ga-ahụ ya. Chetakwanụ ihe m gwara unu.”
\p 
\v 8 Ha ji oke egwu na ọṅụ pụọ ọsịịsọ site nʼili ahụ, gbara ọsọ gawa ịkọrọ ndị na-eso ụzọ ya.
\v 9 Na mberede, Jisọs zutere ha sị ha, \wj “Ndeewonụ!”\wj* Ha bịakwutere ya, jide ụkwụ ya abụọ aka, kpọọkwa isiala nye ya.
\v 10 Ya mere Jisọs gwara ha sị, \wj “Unu atụla egwu. Gaanụ, gwanụ ụmụnne m ka ha gaa Galili. Ha ga-ahụ m nʼebe ahụ.”\wj*
\s1 Ama ndị nche gbara
\p 
\v 11 Mgbe ha na-aga, ụfọdụ ndị agha chere ili ahụ nche batara nʼime obodo. Ha gara kọọrọ ndịisi nchụaja ihe niile mere.
\v 12 Emesịa, ndị nchụaja na ndị okenye zukọtara kwekọrịtaa inye ndị agha ahụ ọkpụrụkpụ ego,
\v 13 sị ha, “Ihe a ka unu ga-ekwu, ‘Ndị na-eso ụzọ ya bịara nʼabalị zuru ya nʼohi mgbe anyị nọ na-arahụ ụra.’
\v 14 Ọ bụrụ na nke a eruo gọvanọ ntị, anyị ga-emeta ya mma, ma mee ka unu pụọ na nsogbu.”
\v 15 Ha naara ego ahụ, meekwa dị ka e ziri ha. Akụkọ a ka a gbasara nʼetiti ndị Juu ruo taa.
\s1 Jisọs enye ndị na-eso ụzọ ya ikike
\p 
\v 16 Ma ndị ikom iri na otu ahụ bụ ndị na-eso ụzọ ya gara Galili, nʼelu ugwu ebe Jisọs gwara ha gaa.
\v 17 Mgbe ha hụrụ ya, ha kpọrọ isiala nye ya. Ma ụfọdụ nʼime ha nwere obi abụọ.
\v 18 Jisọs bịara ha nso, gwa ha sị, \wj “E werela ikike niile dị nʼeluigwe na nke dị nʼelu ụwa nye m.\wj*
\v 19 \wj Ya mere, gaanụ mee ka mba niile bụrụ ndị na-eso ụzọ m, na-emenụ ha baptizim nʼaha nke Nna, na nke Ọkpara, na nke Mmụọ Nsọ.\wj*
\v 20 \wj Ziekwanụ ha ka ha na-eme ihe niile m nyere unu nʼiwu. Ma chetanụ na m na-anọnyere unu mgbe niile, ruo ọgwụgwụ oge.”\wj*
