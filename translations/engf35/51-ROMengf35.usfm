\q2
\v 11 \w there|strong="G1510"\w* \w is|strong="G1510"\w* \w no|strong="G3756"\w* \w one|strong="G3588"\w* \w who|strong="G3588"\w* \w understands|strong="G4920"\w*, \w no|strong="G3756"\w* \w one|strong="G3588"\w* \w who|strong="G3588"\w* \w seeks|strong="G1567"\w* \w God|strong="G2316"\w*.   
\q1
\v 12 \w All|strong="G3956"\w* \w have|strong="G1510"\w* \w turned|strong="G1578"\w* \w aside|strong="G1578"\w*, together \w they|strong="G3588"\w* \w have|strong="G1510"\w* \w been|strong="G1510"\w* \w made|strong="G4160"\w* useless;  
\q2 \w there|strong="G1510"\w* \w is|strong="G1510"\w* \w no|strong="G3756"\w* \w one|strong="G1520"\w* \w who|strong="G3588"\w* shows \w kindness|strong="G5544"\w*,  
\q2 \w no|strong="G3756"\w*, \w not|strong="G3756"\w* \w so|strong="G4160"\w* much \w as|strong="G2193"\w* \w one|strong="G1520"\w*.”\f + \fr 3:12 \ft See Psalm 14:1-3, 53:1-3; Ecclesiastes 7:20.\f*   
\q1
\v 13 “\w Their|strong="G3588"\w* \w throat|strong="G2995"\w* \w is|strong="G3588"\w* \w an|strong="G1100"\w* opened \w grave|strong="G5028"\w*;  
\q2 \w they|strong="G3588"\w* habitually deceive \w with|strong="G5259"\w* \w their|strong="G3588"\w* \w tongues|strong="G1100"\w*.”\f + \fr 3:13 \ft See Psalm 5:9.\f*  
