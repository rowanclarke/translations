\id EPH  
\h EFESIOS 
\toc1 IXCARTA SAN PABLO NIMA CATZOKNILH EFESIOS 
\toc2 EFESIOS 
\toc3 Ef. 
\mt1 IXCARTA SAN PABLO NIMA CATZOKNILH EFESIOS 
\c 1  
\s1 Pablo ca̱huaní kalhé̱n cristianos xalac Efeso 
\p  
\v 1 Aquit Pablo tí Dios li̱lhca̱ni̱t nacli̱tanú ixapóstol Jesucristo tí nali̱chihui̱nán. Cca̱ma̱lakacha̱niyá̱n jaé carta huixín tí ca̱lacsacni̱tán Dios nali̱scujá̱tit y li̱pa̱huaná̱tit Cristo Jesús nac ca̱chiquí̱n Efeso.  
\v 2 Quinti̱cucán Dios y Quimpu̱chinacán Jesucristo caca̱cxilhlacachá̱n y caca̱ma̱xquí̱n li̱pa̱xáu latáma̱t. 
\p  
\v 3 Dios Ixti̱cú Quimpu̱chinacán Jesucristo la̱ta nac akapú̱n quinca̱cxilhlacachini̱tán quinca̱lakalhamaná̱n ni̱tú nali̱puhuaná̱u nac quinacujcán tí li̱pa̱huaná̱u Cristo. Capa̱xcatcatzi̱níu tú quinca̱ma̱xqui̱yá̱n  
\v 4 pues antes natlahuá ca̱quilhtamacú Dios quinca̱lacsacni tí ama ta̱talakxtumi̱yá̱u Cristo xlacata namacuaniyá̱u y nacha̱ná̱u ixlacatí̱n Dios ni̱tú quinkasatcán.  
\v 5 La̱ta maka̱sá quilhtamacú xlá quinca̱lakalhamán y quinca̱li̱lhcá̱n ixli̱hua̱k ixnacú naquinca̱li̱ma̱nu̱yá̱n ixcamán tí ama ca̱lakma̱xtú Jesucristo.  
\v 6 Capa̱xcatcatzi̱níu ixli̱tlá̱n la̱ ma̱si̱ni̱t quinca̱lakalhamaná̱n y quinca̱cxilhlacachini̱tán tí ta̱talakxtumi̱ni̱táu Ixkahuasa tí lakalhamán. 
\p  
\v 7 Hasta li̱mákxtakli cani̱lh Ixkahuasa xlacata nataxtuniyá̱u y na̱cxilá̱u la̱ quinca̱lakalhamaná̱n quinca̱ma̱tzanke̱naniyá̱n quintala̱kalhi̱ncán.  
\v 8 ¿Ticu ni̱ acxcatzi̱ni̱t la̱ ma̱si̱ni̱t lanca ixtalakalhamá̱n Dios? Xlá quinca̱ma̱xqui̱ni̱tán li̱skalala y tancs talacapa̱stacni  
\v 9 nama̱kachakxi̱yá̱u tú tze̱k laclhca̱ni̱t quilacatacán xlacata nacatzi̱yá̱u la̱ quinca̱cxilhlacachín la̱ta maká̱n quilhtamacú.  
\v 10 Acxni nachá̱n quilhtamacú Dios hua̱k ama ma̱kantaxtí tú laclhca̱ni̱t y la̱ta tú anán nac akapú̱n y nac ca̱quilhtamacú ama makamaklhti̱nán Cristo xlacata nama̱paksi̱nán. 
\p  
\v 11 La̱ta maká̱n Dios quinca̱lacsacni aquín judíos tí ama tata̱maklhti̱nán Cristo tú natali̱pa̱xahuá, xlá láclhca̱lh quilacatacán tú lacpúhualh ma̱s quinca̱mini̱niyá̱n tí amá̱n li̱pa̱xahuayá̱u tú ma̱lacnu̱ni̱t.  
\v 12 ¡Capa̱xcatcatzi̱níu Dios ixli̱lanca ixtalakalhamá̱n la̱ quinca̱cxilhlacachín aquín tí xla̱huán li̱pa̱huáu Cristo tla̱n quinca̱lakma̱xtuyá̱n! 
\p  
\v 13 Huixín tí ni̱ judíos na̱ chuná acxni kaxpáttit li̱pa̱xáu ixtachihuí̱n Dios la̱ tla̱n taxtuniyá̱tit, li̱pa̱huántit Cristo; xlá ca̱ma̱lakacha̱nín Espíritu Santo la̱ ma̱lácnu̱lh xlacata nakalhi̱yá̱tit la̱ aktum sello y naca̱li̱lakapascaná̱tit li̱tapaksi̱yá̱tit Dios.  
\v 14 Dios quinca̱ma̱xqui̱ni̱tán Espíritu Santo xlacata ni̱ na̱ktzonksuayá̱u amá̱n maklhti̱naná̱u tú ca̱ma̱lacnu̱nini̱t ama ca̱ma̱xquí tí taca̱najlani̱t ama ca̱lakma̱xtú, xlacata chuná tla̱n nalakachixcuhui̱cán cani̱cxnihuá. 
\s1 Pablo ca̱li̱kalhtahuaká cristianos 
\p  
\v 15 Aquit acxni ccátzi̱lh la̱ tancs li̱pa̱huaná̱tit Jesús huixín xalac Efeso y la̱ ca̱lakalhamántit hua̱k ixcamán Dios tí ca̱lacsacni̱t,  
\v 16 ni̱ cli̱makxtakni̱t cca̱li̱kalhtahuakayá̱n ixlacatí̱n Dios y cpa̱xcatcatzi̱ní tú tlahuani̱t milacatacán.  
\v 17 Cmaksquín lanca Quinta̱tajcán Dios Ixpu̱chiná Jesucristo caca̱ma̱xquí̱n li̱skalala nac mintalacapa̱stacnicán xlacata nacatzi̱yá̱tit la̱ta tú laclhca̱ni̱t milacatacán y nama̱kachakxi̱yá̱tit la̱ ca̱lakalhamani̱tán,  
\v 18 y caca̱ma̱lakacha̱nín ixtaxkáket nac minacujcán xlacata na̱cxilhlacachipiná̱tit tú pa̱t maklhti̱naná̱tit a̱stá̱n, la̱ li̱pa̱xáu ama ca̱ma̱xqui̱yá̱n tú ca̱ma̱lacnu̱nini̱t tí ca̱lacsacni̱t ama ca̱lakalhamán.  
\v 19 Xli̱tlihueke Dios ni̱tí ma̱ccha̱ní y quinca̱ma̱si̱niyá̱n aquín tí li̱pa̱huaná̱u y li̱lacahua̱naná̱u tú tla̱n li̱tlahuá ixli̱tlihueke  
\v 20 acxni ma̱lacastacuáni̱lh Jesús nac ca̱li̱ní̱n y li̱mákxtakli catahui nac ixpa̱xtú̱n ní nata̱ma̱paksi̱nán nac akapú̱n  
\v 21 xlacata natalakachixcuhuí hua̱k tí tama̱paksi̱nán ixli̱ti̱lanca akapú̱n, tí tama̱kantaxtí tú ca̱li̱lhca̱ni̱t Dios, tí takalhí li̱tlihueke, tí ta̱cpuxcún tú lama ca̱quilhtamacú, y la̱ta tú lactzú o laclanca huí juú ca̱quilhtamacú y a̱lacatunu ca̱quilhtamacú.  
\v 22 Dios li̱makxtakni̱t Cristo cama̱páksi̱lh la̱ta tú anán y na̱ li̱makxtakni̱t caca̱cpúxculh hua̱k cristianos tí ca̱lacsacni̱t natali̱pa̱huán.  
\v 23 Porque namá tí tali̱pa̱huán Cristo tali̱tanú ixmacni cha̱tum cristiano y Cristo li̱tanú ixakxa̱ka huá tla̱n ca̱li̱ma̱xquí cha̱tum tí tali̱pa̱huán tú tamaclacasquín nac ixlatama̱tcán. 
\c 2  
\s1 Dios ca̱cxilhlacachá̱n cristianos 
\p  
\v 1 Xapu̱lh quilhtamacú huixín Dios ca̱li̱ma̱nu̱ni̱tán la̱ xaní̱n porque ni̱ ixputzayá̱tit nali̱pa̱huaná̱tit ixli̱piná̱tit lhu̱hua tatzaca̱tni y tala̱kalhí̱n nac milatama̱tcán;  
\v 2 ixca̱ma̱tlahui̱ni̱tán tlajaná tí ma̱paksi̱nán ca̱quilhtamacú y huixín ixkaxpatá̱tit tú ixca̱huaniyá̱n namá tí talapu̱lá nac ni̱ tla̱n u̱n, xlacán ta̱ktlakahuacá cristianos catakaxmatmákalh Dios.  
\v 3 Milh quilhtamacú hua̱k aquín na̱ chuná ixlama̱náu, ixtakokeyá̱u tú ixquinca̱ma̱tlahui̱yá̱n ni̱ tla̱n quinkasatcán, ixtlahuayá̱u tú ni̱ tla̱n ixquinca̱ma̱cxcatzi̱ni̱yá̱n y la̱ta tú li̱xcájnit ixmina̱chá quintalacapa̱stacnicán huá xlacata ixli̱mini̱ní naxoko̱naná̱u la̱ xa̱makapitzi. 
\p  
\v 4 Pero ixtalakalhamá̱n Dios quinca̱cxilhlacachín y xlacata nacatzi̱yá̱u la̱ quinca̱pa̱xqui̱yá̱n  
\v 5 ma̱squi caj xlacata quintala̱kalhi̱ncán ixli̱tanu̱ma̱náu la̱ xaní̱n xlá quinca̱ma̱xquí̱n sa̱sti latáma̱t caj xlacata li̱pa̱huaná̱u Cristo. Dios quinca̱lakma̱xtún porque quinca̱lakalhamán  
\v 6 hasta ama quinca̱ma̱lacastacuani̱yá̱n ca̱li̱ní̱n na̱ chuná la̱ ma̱lacastacuáni̱lh Cristo y nac akapú̱n ama quinca̱huili̱yá̱n nac ixpa̱xtú̱n Cristo  
\v 7 xlacata tla̱n nama̱sí cani̱cxnihuá quilhtamacú la̱ tacámajli nac ixnacú quinca̱cxilhlacachín aquín tí quinca̱lakalhamaná̱n caj xlacata li̱pa̱huaná̱u Jesús.  
\v 8 Huixín taxtunítit porque Dios ca̱cxilhlacachín y huixín ca̱najlátit tú ca̱ma̱lacnu̱nín, ni̱tí tipuhuán tla̱n catzí huá li̱lakalhámalh Dios, tó̱, ¡quintapa̱xahua̱ncán Dios quinca̱ma̱squihui̱ni̱tán!  
\v 9 Ni̱tí titalactlancán napuhuán tla̱n cristiano huá̱ li̱lakalhámalh Dios.  
\v 10 Dios quinca̱tlahuán y quinca̱macama̱stán ixmacán Cristo xlacata natlahuayá̱u tú tla̱n lacasquín Dios y chú tiláclhca̱lh la̱ta maká̱n quilhtamacú. 
\s1 Tí ni̱ judíos ixca̱li̱maca̱ncán lacli̱xcájnit cristianos 
\p  
\v 11 Calacapa̱stáctit huixín tí ni̱ judíos xlacata milh quilhtamacú acxni namá judíos tí tacircuncidarlani̱t nac ixmacnicán xlacata natasí ixtali̱pa̱huán Dios, ni̱ ixca̱cxilhputuná̱n ixca̱li̱ma̱nu̱yá̱n lacli̱xcájnit cristianos tí ni̱ ixtali̱pa̱huán Dios.  
\v 12 Ca̱ksántit la̱ amá quilhtamacú ni̱ ixlakapasá̱tit Cristo, ni̱ para ixca̱ta̱talakxtumi̱yá̱tit judíos xalac Israel, ni̱ para ixcatzi̱yá̱tit tú ma̱lacnu̱ni̱t Dios ama ca̱ma̱xquí ixcamán, ni̱ ixacxilhlacachipiná̱tit tunu li̱pa̱xáu latáma̱t. Huixín ni̱ ixkalhi̱yá̱tit xastacnán Dios tí nali̱pa̱huaná̱tit ca̱quilhtamacú.  
\v 13 Pero chí caj xlacata Cristo ni̱lh nac culu̱s tla̱n ma̱lacatzuhui̱yá̱tit Dios huixín tí mákat ixlapu̱layá̱tit. 
\p  
\v 14 Cristo quinca̱ma̱lacatla̱ní̱n ixlacatí̱n Dios pues quinca̱ma̱lakxtumí̱n aquín judíos y huixín tí ni̱ judíos la̱ pu̱tum cristianos, lactláhualh tú ixquinca̱ma̱tunujá̱n xlacata ni̱ nala̱cxilhputuná̱u.  
\v 15 Xlá li̱tamákxtakli naní xlacata judíos tí tama̱kantaxtí ixley Moisés yaj natasi̱tzi̱ní tí ni̱ judíos ni̱ tama̱kantaxtí xlacata acxtum natara̱cxilhlacachá̱n la̱ li̱ta̱camán; Cristo ca̱ma̱lakxtúmi̱lh xlacata yaj tara̱tzonkcatzaní.  
\v 16 Huá tla̱n ca̱li̱xapanini̱t ixtala̱kalhi̱ncán nac culu̱s ni̱ma̱ ixtalí̱n ixlacatí̱n Dios xlacata tla̱n acxtum natama̱lacatzuhuí. ¡Nac culu̱s ma̱lakspútulh ixtasi̱tzicán tí ni̱ ixtara̱cxilhputún!  
\v 17 Cristo milh ca̱huaní la̱ natata̱ra̱lí̱n Dios namá tí ni̱ judíos ma̱kat ixtalapu̱lá y na̱ chuná judíos tí lacatzú ixtalapu̱lá  
\v 18 xlacata la̱ aquín y la̱ huixín nakalhi̱yá̱u li̱camama ma̱lacatzuhui̱yá̱u Quinti̱cucán Dios pues huata cha̱tum Ixespíritu Dios tí quinca̱ma̱xquí̱n li̱tlihueke. 
\p  
\v 19 Chí huixín yaj li̱tanu̱yá̱tit la̱ xala mákat cristianos o la̱ tí caj tamakchá̱n a̱lacatunu pu̱táhui̱lh, tó̱; chí huixín li̱tanu̱yá̱tit la̱ cati̱huá cristiano tí tali̱pa̱huán Dios y na̱ li̱tanu̱yá̱tit ixcamán Dios tí ca̱lacsacni̱t.  
\v 20 Huixín tí li̱pa̱huaná̱tit Jesús camá̱n ca̱li̱ma̱lacastucá̱n la̱ aktum ákxtaka tí tama̱lacatzúqui̱lh apóstoles y profetas y nac ixcha̱stú̱n la̱ xacha̱ya yá Jesucristo  
\v 21 xlacata aná natzinca̱snanko̱yá̱u cha̱tunu aquín tí ma̱lakanu̱yá̱u ixpu̱siculan ní lakachixcuhui̱cán Dios.  
\v 22 Cha̱tunu aquín tí li̱pa̱huaná̱u Cristo quinca̱li̱ma̱nu̱yá̱n ixchic ni̱ma̱ tlahuani̱t xlacata aná nalatamá Ixespíritu Dios. 
\c 3  
\s1 Dios li̱lhca̱ni̱t Pablo naca̱ma̱kalhchihui̱ní cristianos 
\p  
\v 1 Aquit Pablo tí cmacama̱xqui̱ni̱t quilatáma̱t Cristo ctanu̱ma cpu̱la̱chí̱n caj xlacata cca̱lakalhamaná̱n huixín tí ni̱ judíos.  
\v 2 Cpuhuán catzi̱yá̱tit la̱ quiacxilhlacáchilh Dios quilakalhámalh xlacata nacca̱makta̱yayá̱n huixín.  
\v 3 Aquit cca̱huaniyá̱n tziná la̱ quima̱cxcatí̱ni̱lh tú tze̱k ixlaclhca̱ni̱t milacatacán,  
\v 4 para tla̱n li̱kalhtahuakayá̱tit pa̱t catzi̱yá̱tit xlacata tancs cma̱kachakxi̱ni̱t tú xlacata lí̱ni̱lh Cristo nac culu̱s.  
\v 5 Dios ni̱ tancs ca̱ma̱sí̱nilh xalakmaká̱n cristianos jaé tú tze̱k ixlaclhca̱ni̱t, pero chí Ixespíritu ca̱ma̱xqui̱ni̱t ixtaxkáket apóstoles y profetas tí ca̱lacsacni̱t natali̱scuja.  
\v 6 ¡Cakaxpáttit! Dios láclhca̱lh tí ni̱ judíos tla̱n ama tata̱paxahuá judíos para taca̱najlá la̱ ma̱lacnu̱ni̱t ama ca̱lakma̱xtú cristianos xlacata tla̱n natali̱tanú la̱ li̱ta̱camán y quilhpa̱xtum natamaklhti̱nán tú ma̱lacnu̱ni̱t Dios ama ca̱ma̱xquí tí tali̱pa̱huán Dios. 
\p  
\v 7 Ni̱ ccatzí para aquit ixquilakchá̱n, pero Dios quiliacxilhlacáchilh ixli̱tlihueke y quili̱mákxtakli nacma̱kantaxtí jaé tascújut.  
\v 8 Aquit ma̱s xapakstá̱n cli̱tamákxtakli tí ca̱lacsacni̱t Dios, pero xlá quisipaacxilhni̱t y ma̱tlá̱ni̱lh aquit nacca̱huaní cristianos tí ni̱ judíos xlacata ni̱tí ma̱ccha̱ní tú ma̱stá Cristo.  
\v 9 Quili̱mákxtakli nacca̱ma̱xquí taxkáket natama̱kachakxí cristianos tú tze̱k laclhca̱ni̱t maká̱n quilhtamacú Dios tí tláhualh la̱ta tú anán ca̱quilhtamacú,  
\v 10 xlacata tí ca̱lakmá̱xtulh Cristo tla̱n natama̱si̱ní lactali̱pa̱u y lacli̱cuánit ma̱paksi̱naní̱n tí talama̱na ixli̱ti̱lanca akapú̱n, hua̱k laclanca ixtalacapa̱stacni Dios la̱ láclhca̱lh naca̱lakma̱xtú cristianos.  
\v 11 Chú láclhca̱lh maká̱n quilhtamacú y chí ma̱kantaxti̱ni̱t Quimpu̱chinacán Jesús.  
\v 12 Aquín tí ca̱najlayá̱u quinca̱lacati̱ta̱yani̱tán Cristo yaj jicuaná̱u ma̱lacatzuhui̱yá̱u y ta̱chihui̱naná̱u Dios acxni tú liakaxculiyá̱u.  
\v 13 Aquit cca̱huaniyá̱n ni̱ ca̱katuyúntit caj xlacata cakxtakajnama milacatacán, pues chuná cca̱ma̱lacahua̱ni̱má̱n la̱ cca̱lakalhamaná̱n. 
\s1 Pablo ca̱li̱kalhtahuaká cristianos 
\p  
\v 14 Acxni clacapa̱staca tú tlahuani̱t Dios Ixti̱cú Quimpu̱chinacán Jesucristo aquit ctatzokostaní xlacata naclakachixcuhuí  
\v 15 porque huá ma̱lakahuani̱ni̱t la̱ta tú anán nac akapú̱n y nac ca̱quilhtamacú.  
\v 16 Como ccatzí ni̱tí ma̱ccha̱ní ixli̱lanca ixtalakalhamá̱n, aquit cmaksquín caca̱li̱ma̱xquí̱n Ixespíritu li̱tlihueke y li̱camama nac mili̱stacnicán  
\v 17 xlacata tí li̱pa̱huaná̱tit Jesús tla̱n nalatamá nac minacujcán y ni̱cxni cali̱makxtáktit la̱pa̱xqui̱yá̱tit  
\v 18 xlacata hua̱k tí tali̱pa̱huán Dios nala̱cxilá̱tit la̱ li̱ta̱camán. Huata chuná tla̱n nama̱kachakxi̱yá̱tit ixli̱lanca ixtalakalhamá̱n Cristo ni̱ma̱ ma̱lakachá, tu̱tzú, ta̱lhmá̱n y ixli̱ti̱lanca ca̱quilhtamacú.  
\v 19 ¡Makatlajá la̱ta tú lakapasá̱u y li̱lacacha̱ná̱u! Aquit cmaksquín camaklhcatzí̱tit jaé talakalhamá̱n xlacata Dios na̱kchipá mintalacapa̱stacnicán. 
\p  
\v 20 Aquit cpa̱xcatcatzi̱ní ixli̱lanca Dios tí kalhí li̱tlihueke tla̱n tlahuá ma̱s tú aquín ni̱ para maksquiná̱u o ni̱ para lacpuhuaná̱u porque xlá quinca̱ma̱xqui̱ni̱tán li̱tlá̱n namaksquiná̱u ixli̱tlihueke.  
\v 21 ¡Calakachixcuhuí̱u Dios cani̱cxnihuá quilhtamacú y na̱ chuná Jesucristo tí quinca̱lakma̱xtuni̱tán aquín tí li̱pa̱huaná̱u! 
\c 4  
\s1 Pablo ca̱maksquín catara̱lakalhámalh cristianos 
\p  
\v 1 Aquit ctanu̱ma cpu̱la̱chí̱n caj xlacata Quimpu̱chiná Jesús, pero cca̱kastacya̱huayá̱n calatapá̱tit la̱ ca̱mini̱ní natalatamá cristianos tí ca̱lacsacni̱t Dios.  
\v 2 Ni̱ calactlancántit, tla̱n cacatzí̱tit, y cala̱cxilhlacachipítit la̱pa̱ti̱niyá̱tit tú ca̱tlahuaniyá̱tit para xli̱ca̱na la̱lakalhamaná̱tit.  
\v 3 Ni̱cxni tunuj túnu cataxtútit xlacata Espíritu Santo naca̱kskalhli̱ná̱n li̱pa̱xáu ca̱li̱tlá̱n nalatapa̱yá̱tit.  
\v 4 Cha̱tunu aquín li̱tanu̱yá̱u ixmacni cha̱tum chixcú y huata Cristo li̱tanú ixakxa̱ka, huata kalhi̱yá̱u cha̱tum Espíritu tí quinca̱kskalhli̱ná̱n, y huata acxilhlacacha̱ná̱u ti̱pa̱tum tapa̱xahuá̱n ni̱ma̱ quinca̱ma̱lacnu̱nicani̱tán.  
\v 5 Huata kalhi̱yá̱u cha̱tum Quimpu̱chinacán, huata huí ti̱pa̱tum tapa̱xahuá̱n la̱ nali̱pa̱huaná̱u, huata lakapasá̱u ti̱pa̱tum ta̱kmúnut,  
\v 6 huata kalhi̱yá̱u cha̱tum Quinti̱cucán Dios tí ca̱ma̱paksi̱kó hua̱k cristianos y ca̱maclacasquín la̱ta lacasquín y ca̱ta̱lama cha̱tunu cristianos. 
\p  
\v 7 Pero Cristo quinca̱ma̱xqui̱ni̱tán cha̱tunu quintascujutcán ni̱ma̱ lacasquín nama̱kantaxti̱yá̱u.  
\v 8 La̱ huan nac Escrituras: 
\q1 Acxni tá̱cxtulh nac akapú̱n cá̱li̱lh tí la̱ tachí̱n ixca̱li̱kalhi̱cán, 
\q1 y ca̱má̱xqui̱lh ixtascujutcán cristianos. 
\p  
\v 9 Jaé huamputún xlacata namá tí tá̱cxtulh nac akapú̱n pu̱la tá̱ctalh nac ca̱quilhtamacú ní huí tú li̱xcájnit.  
\v 10 Para tla̱n tá̱ctalh nac ca̱quilhtamacú, tla̱n ta̱cxtupá nac ixli̱ta̱lhmá̱n akapú̱n xlacata nama̱kahuani̱kó ixli̱tlihueke ixli̱ti̱lanca ca̱quilhtamacú y akapú̱n.  
\v 11 Xlá ca̱má̱xqui̱lh cha̱tunu ixtascujutcán: makapitzi ca̱má̱xqui̱lh li̱tlá̱n natali̱tanú apóstoles tí natali̱chihui̱nán, tunu ca̱má̱xqui̱lh li̱tlihueke natama̱cxcatzi̱ni̱nán ixtalacapa̱stacni Dios, tunu ca̱má̱xqui̱lh talacapa̱stacni natali̱chihui̱nán la̱ tla̱n tataxtuní cristianos, tunu ca̱lí̱lhca̱lh nata̱cpuxcún cristianos, y tunu ca̱lí̱lhca̱lh natama̱sí ixtachihui̱n Dios.  
\v 12 Xlá ca̱má̱xquilh talacapa̱stacni namá tí ca̱lacsacni̱t xlacata natama̱kantaxtí la̱ laclhca̱ni̱t natalatamá tí tali̱pa̱huán Cristo, y cha̱tunu tí tali̱tanú ixmacni Cristo tla̱n acxtum natara̱makta̱yá,  
\v 13 hasta nachá̱n quilhtamacú acxni hua̱k tí li̱pa̱huaná̱u Cristo nakalhi̱yá̱u ti̱pa̱tum talacapa̱stacni y nacatzi̱yá̱u ticu namá Ixkahuasa Dios, nama̱ccha̱niyá̱u talacapa̱stacni, nama̱kachakxi̱yá̱u ticu namá lanca chixcú y namaklhcatzi̱yá̱u nac quinacujcán tapa̱xahuá̱n la̱ quinca̱cxilhlacachín Cristo.  
\v 14 Entonces yaj amá̱n layá̱u la̱ lactzú camán tí tza̱pu tzá̱pu talakxta̱palí ixtapuhua̱ncán, ni̱ tuhua taca̱najlá tí ca̱ma̱si̱ní tunuj takalhchihuí̱n y ni̱ para ta̱klhu̱hua̱tnán taca̱najlá tú tahuán makapitzi akskahuinaní̱n.  
\v 15 Amá̱n ma̱kachakxi̱yá̱u talacapa̱stacni la̱ nala̱lakalhamaná̱u pues mini̱ní nama̱kachakxi̱yá̱u hua̱k ixtalacapa̱stacni Cristo porque huá akxa̱ka tí li̱tanu̱yá̱u aquín ixmacni.  
\v 16 Y mientras Cristo ca̱ma̱paksi̱ma nahuán lactzu lactzú tú li̱laknú ixmacni ni̱tú kalhta̱xtú porque huá catzí ní tamacuán cha̱tum cha̱túm. Para cha̱tunu ma̱kantaxtí ixtascújut ni̱ma̱ li̱lhca̱cani̱t hua̱k tara̱macuaní pues tara̱makta̱yá xlacata natama̱kachakxí la̱ natara̱lakalhamán. 
\s1 Tí tali̱pa̱huán Cristo talakxta̱palí ixlatama̱tcán 
\p  
\v 17 Aquit cli̱quilhán Quimpu̱chinacán tú cama ca̱huaniyá̱n: yaj calatapá̱tit la̱ namá tí ni̱ talakapasa Dios y tí ni̱ tancs talacpuhua̱nán.  
\v 18 Ixtalacapa̱stacnicán la̱ ca̱paklhtu̱tá takalhí, ni̱ talakapasa li̱pa̱xáu latáma̱t ni̱ma̱ ma̱stá Dios porque ni̱tú tama̱kachakxí y la̱ lakatzí̱n talama̱na.  
\v 19 Namá cristianos yaj talacama̱xanán, ¡talaktzanka̱ni̱t! Talakatí tali̱tlahuá ixmacnicán la̱ta tú li̱xcájnit ca̱ma̱lacpuhua̱ní ixtalacapa̱stacnicán. 
\p  
\v 20 Pero huixín ni̱ lá ca̱makslihuekeyá̱tit porque Cristo ni̱ chú ca̱ma̱si̱nini̱tán.  
\v 21 Para xli̱ca̱na kaxpatni̱tántit tancs ixtachihuí̱n y catzi̱yá̱tit la̱ lacasquín natalatamá tí tali̱pa̱huán,  
\v 22 chí tuncán ca̱ktzonksuátit xapu̱lh milatama̱tcán, catramakántit namá li̱xcájnit minkasatcán ni̱ma̱ ca̱ma̱laktzanke̱ni̱tán y ca̱ma̱tlahui̱ni̱tán tú li̱xcájnit.  
\v 23 Yaj ca̱klhu̱hua̱tnántit calakxta̱palí̱tit milatama̱tcán y mintalacapa̱stacnicán  
\v 24 y cama̱lacatzuquí̱tit sa̱sti latáma̱t la̱ tí apenas lakahuán. Cama̱sí̱tit tlahuayá̱tit tú lacasquín Dios y lapa̱nántit la̱ tí ca̱lacsacni̱t natamacuaní. 
\p  
\v 25 Huá cca̱liakastacya̱huayá̱n yaj cala̱liakskahuinántit, cahuántit tú xli̱ca̱na acxni ca̱ta̱chihui̱naná̱tit minta̱cristianoscán porque para li̱tanu̱yá̱tit ixmacni Cristo tú tlahuá cha̱tum hua̱k xa̱makapitzi tamaklhcatzí.  
\v 26 Acxni si̱tzi̱yá̱tit ni̱tí cali̱si̱tzi̱tapu̱spíttit xlacata ni̱ natlahuayá̱tit tala̱kalhí̱n y catacamájtit aktzonksuayá̱tit mintasi̱tzicán nac aktum chichiní  
\v 27 xlacata tlajaná ni̱ naca̱ma̱nu̱niyá̱n li̱xcájnit ixtalacapa̱stacni.  
\v 28 Tí ixkalha̱nán yaj cakalhá̱nalh y catzúculh cha̱lhca̱tnán la̱ mini̱ní xlacata tla̱n naca̱li̱makta̱yá tú tamaclacasquín xa̱makapitzi.  
\v 29 Ni̱cxni cahuántit lacli̱xcájnit tachihuí̱n chá cahuántit lactlá̱n tachihuí̱n ni̱ma̱ naca̱makta̱yá y natali̱lacapa̱stacnán xa̱makapitzi tí ca̱kaxmatá̱n.  
\v 30 Huixín ni̱ cali̱ma̱lakaputzí̱tit milatama̱tcán Espíritu Santo ni̱ma̱ ca̱ma̱lakacha̱nín Dios xlacata naca̱li̱lakapasá̱n huá li̱tapaksi̱yá̱tit amá quilhtamacú acxni naca̱ma̱xquí cristianos tú ma̱lacnu̱ni̱t.  
\v 31 Aquit ni̱ cakatzanká cca̱huaniyá̱n yaj tú cala̱li̱ma̱puhua̱ní̱tit, yaj cala̱tzonkcatzanítit, yaj cala̱si̱tzi̱nítit, ni̱ cala̱sláktit, ni̱ cala̱li̱kalhkama̱nántit, ni̱ para cala̱tlahuanítit tú ni̱ tla̱n.  
\v 32 Huixín catzaksátit acxtum la̱pa̱xqui̱yá̱tit y la̱sipaacxilá̱tit. Cala̱ma̱tzanke̱nanítit tú la̱tlahuaniyá̱tit cha̱tum cha̱túm na̱ chuná la̱ ca̱ma̱tzanke̱nanín Dios mintala̱kalhi̱ncán tí li̱pa̱huaná̱tit Cristo. 
\c 5  
\s1 Pablo huan la̱ ixli̱latama̱tcán tí tali̱pa̱huán Cristo 
\p  
\v 1 Aquit cca̱huaniyá̱n, para Dios ca̱lakalhamani̱tán camakslihuekétit la̱ camán tí talakalhamán ixti̱cucán.  
\v 2 Quilhpa̱xtum cala̱pa̱xquí̱tit na̱ chuná la̱ Cristo quinca̱pa̱xquí̱n hasta li̱tamákxtakli namakni̱cán xlacata naxoko̱naní Dios quintala̱kalhi̱ncán y Dios lakáti̱lh tú tláhualh la̱ acxni quincalá mu̱csún incienso ni̱ma̱ li̱lakachixcuhui̱cán. 
\p  
\v 3 Huixín tí ca̱lacsacni̱tán Dios ni̱ para calacpuhuántit li̱ma̱huacayá̱tit li̱tzaca̱tnaná̱tit mimacnicán, ni̱ para hua̱k calakcatzántit.  
\v 4 Ni̱ para cali̱chihui̱nántit tú li̱ma̱xaná, ni̱ cala̱li̱kalhkama̱nántit tú kalhi̱yá̱tit nac mimacnicán, ni̱ para huata cali̱kalhkama̱nántit tú li̱tlahuayá̱tit mimacnicán, porque namá ni̱ quinca̱mini̱niyá̱n aquín. Chá ma̱s tla̱n cali̱pa̱xcatcatzi̱níu Quimpu̱chinacán tú tlahuani̱t.  
\v 5 Huixín mili̱catzi̱tcán xlacata nac ixtapáksi̱t Cristo y xla Dios ni̱ lá ama tatanú amá cristianos tí huata tali̱puhuán la̱ nata̱kskahuí ixta̱cha̱tcán o ixta̱ko̱lucán o la̱ natatlahuá tú li̱xcájnit, o la̱ natali̱tzaca̱tnán quimacnicán pues tali̱tamakxtaka la̱ catalakachixcúhui̱lh ixmacnicán.  
\v 6 Ni̱ caca̱kskahuín namá cristianos tí tatalacatla̱ní tahuán ni̱ laclanca tala̱kalhí̱n tatlahuani̱t porque ixtasi̱tzi Dios ama ca̱lakchá̱n namá tí ni̱ ta̱kahua̱nán. 
\p  
\v 7 Huixín ni̱ caca̱makslihuekétit ni̱ para caca̱ta̱ta̱yátit namá cristianos  
\v 8 porque ma̱squi xapu̱lh na̱ chuná ca̱paklhtu̱tá ixlapu̱laya̱nántit, chí li̱tla̱huampa̱nántit ixtaxkáket Quimpu̱chinacán. Huá cca̱li̱huaniyá̱n cama̱sí̱tit namá taxkáket nac milatama̱tcán.  
\v 9 Pues tí takalhí taxkáket nac ixnacujcán tla̱n tacatzí, tancs talama̱na y talakapasa ixtalacapa̱stacni Dios.  
\v 10 Aquit cca̱maksquiná̱n calacputzátit la̱ puhuaná̱tit lakatí Quimpu̱chinacán nalatapa̱yá̱tit.  
\v 11 Huixín ni̱ caca̱makslihuekétit namá tí tatlahuá tú li̱xcájnit ca̱paklhtu̱tá y acxni ni̱ ca̱cxilhma̱ca; huixín chá caca̱ma̱laksí̱tit tú tatlahuá.  
\v 12 Xlacán lhu̱hua tú li̱xcájnit tze̱k tatlahuá hasta li̱ma̱xaná li̱chihui̱nancán.  
\v 13 Pero acxni ca̱li̱ta̱chihui̱nancán taxkáket tama̱sí tú tze̱k tatlahuani̱t porque tí lakchá̱n taxkáket staranca lacahua̱huán.  
\v 14 ¿Ni̱ catzi̱yá̱tit la̱ huan Dios nac Escrituras? Pues chuné huan: 
\q1 Calacastacuánanti huix para lhtatápa̱t; 
\q1 cataxtu para lápa̱t nac ixpu̱latama̱ncán ni̱n 
\q1 xlacata Cristo naliakskalhli̱ná̱n ixtaxkáket. 
\p  
\v 15 Ixli̱maklhu̱hua cca̱huaniyá̱n tla̱n cali̱lacahua̱nántit la̱ lapa̱nántit; ni̱ calatapá̱tit la̱ laktakalhí̱n cristianos, calatapá̱tit la̱ lakskalala cristianos.  
\v 16 Tla̱n camaclacasquíntit minquilhtamacujcán porque tuhua jaé quilhtamacú ni̱ma̱ pu̱lama̱naú.  
\v 17 Huixín ni̱ catlahuátit tú ni̱ ca̱macuaniyá̱n, calacputzátit tlahuayá̱tit nac milatama̱tcán tú lacasquín Dios. 
\p  
\v 18 Huixín ni̱ huata cali̱tapa̱tzamátit cuchu porque acxni ma̱s tlahuacán tatzaca̱tni, huixín chá cama̱sí̱tit tali̱tzamá minacujcán Espíritu Santo.  
\v 19 Y acxni la̱ta̱chihui̱naná̱tit cala̱huanítit salmos, alabanzas y laclá̱n tachihuí̱n ni̱ma̱ ca̱ma̱lacpuhua̱ni̱yá̱n Espíritu Santo. Calakachixcuhuí̱tit y catli̱nítit Quimpu̱chinacán ixli̱hua̱k minacujcán  
\v 20 xlacata napa̱xcatcatzi̱niyá̱u Quinti̱cucán Dios tú tlahuani̱t quilacatacán tí li̱pa̱huaná̱u Quimpu̱chinacán Jesucristo. 
\p  
\v 21 Ni̱cxni cali̱makxtáktit la̱kaxpatniyá̱tit cha̱tum cha̱túm tú mili̱tlahuatcán la̱ lacputzayá̱tit macuaniyá̱tit Quimpu̱chinacán. 
\s1 Tí tatamakaxtokni̱t catara̱lakalhámalh 
\p  
\v 22 Xalacchaján tí tatamakaxtokni̱t catakáxmatli tú ca̱li̱ma̱paksí ixta̱ko̱lucán, na̱ chuná la̱ takaxmata Quimpu̱chinacán.  
\v 23 Porque lacchixcuhuí̱n ta̱cpuxcún ixma̱hui̱nacán na̱ chuná la̱ Cristo ca̱cpuxcún tí tali̱pa̱huán y ca̱ksántit la̱ ca̱lakmá̱xtulh tí tali̱pa̱huán porque ca̱li̱ma̱nú la̱ ixmacni.  
\v 24 Huá cca̱li̱huaniyá̱n lacchaján catakáxmatli tú ca̱li̱ma̱paksí ixta̱ko̱lucán na̱ chuná la̱ cristianos tí tali̱pa̱huán Cristo takaxmata tú ca̱li̱ma̱paksí. 
\p  
\v 25 Xalacchixcuhuí̱n tí tatamakaxtoknit catapá̱xqui̱lh ixta̱cha̱tcán na̱ chuná la̱ Cristo ca̱lakalhamán tí tali̱pa̱huán y ni̱ lakcátzalh macamá̱sta̱lh ixli̱stacni xlacata naca̱lakma̱xtú.  
\v 26 Namá cristianos tí tali̱pa̱huán y tachéke̱lh ixtala̱kalhi̱ncán acxni tata̱kmúnulh y taca̱nájlalh ixtachihuí̱n, xlá ca̱ma̱tunujni̱t la̱ cha̱tum tasquín tzuma̱t  
\v 27 xlacata tla̱n li̱pa̱xáu naca̱maklhti̱nán la̱ ni̱tú catali̱tzacá̱tnalh, la̱ ni̱tú catali̱makatzánka̱lh tú natali̱ma̱xanán, sino que natachá̱n ixlacatí̱n ni̱tú ixkasatcán la̱ mini̱ní xatasquín tzuma̱t.  
\v 28 Huá cca̱li̱huaniyá̱n, lacchixcuhuí̱n catalakalhámalh ixta̱cha̱tcán na̱ chuná la̱ talakcatzán ixmacnicán. Namá chixcú tí lacasquín ni̱tú catzanká̱nilh na̱ tamaclacasquiní calacpútzalh ni̱tú natzanka̱ní ixta̱cha̱t.  
\v 29 Porque ¿ticu yá cristiano ni̱ lakcatzán ixmacni? ¡Ni̱tí! Hua̱k tama̱huí y tacuentaja, y Cristo na̱ chuná ca̱cuentaja tí li̱pa̱huaná̱u  
\v 30 pues cha̱tunu aquín li̱tanu̱yá̱u ixmacni.  
\v 31 Xa̱huá ca̱ksántit la̱ huan Dios nac Escrituras: “Cha̱tum chixcú namakxtaka ixti̱cú ixna̱na y nata̱talakxtumí amá pusca̱t tí ixta̱cha̱t nahuán y entonces ixcha̱tuycán natali̱tanú la̱ cha̱tum cristiano.”  
\v 32 Tuhua ma̱kachakxi̱cán jaé tú cca̱huanín pero ma̱sí xlacata Cristo y aquín tí li̱pa̱huaná̱u li̱tanu̱yá̱u la̱ cha̱tum cristiano.  
\v 33 Pero chí cca̱huaniparayá̱n cha̱tunu lacchixcuhuí̱n catalakalhámalh ixta̱cha̱tcán na̱ chuná la̱ talakcatzán ixmacnicán, y lacchaján catarespetartláhualh ixta̱ko̱lucán. 
\c 6  
\s1 La̱ ixli̱latama̱tcán camaná̱n, xanati̱cún, patrón y tasa̱cua 
\p  
\v 1 Huixín camaná̱n cakaxpáttit tú tali̱ma̱paksi̱nán minati̱cún porque lakatí Dios.  
\v 2 Camá̱n ca̱ma̱lacapa̱stacayá̱n la̱ ma̱paksí̱nalh Dios y tú ca̱ma̱lacnú̱nilh tí natakaxmata: “Caca̱lakalhamántit minta̱ta y mintzé  
\v 3 xlacata li̱pa̱xáu maká̱s quilhtamacú nalatapa̱ya ca̱quilhtamacú.” 
\p  
\v 4 Huixín xanati̱cún ni̱ caca̱makasi̱tzí̱tit mincamancán, chá calacputzátit ca̱makastacá̱tit nata̱kahua̱nán y caca̱ma̱si̱nítit la̱ natali̱pa̱huán Quimpu̱chinacán. 
\p  
\v 5 Huixín tí ca̱ma̱scujucaná̱tit cakaxpáttit tú tali̱ma̱paksi̱nán tí ca̱cpuxcuná̱n, ca̱kahua̱nántit, caca̱respetartlahuátit, cascújtit ixli̱hua̱k minacujcán la̱ cali̱scújtit Cristo.  
\v 6 Ni̱ huata acxni ca̱maktakalhpa̱cántit xlacata ni̱ naca̱kahuanicaná̱tit, tó̱; huixín siempre cascújtit ixli̱hua̱k minacujcán la̱ tali̱cha̱lhca̱tnán Cristo tí talakatí tama̱kantaxtí tú lacasquín Dios.  
\v 7 Huixín ni̱ ca̱ktzonkcatzántit acxni scujá̱tit, capa̱xahuátit la̱ cali̱scújtit Quimpu̱chinacán y ni̱ cristianos tí ca̱ma̱paksi̱yá̱n.  
\v 8 Pues ca̱ksántit xlacata Quimpu̱chinacán ama ca̱ma̱xquí ixtaxoko̱ncán tí tatlahuá tú tla̱n la̱ cha̱tum tastá̱n tasa̱cua y la̱ tí ni̱ kalhí tí ma̱paksí. 
\p  
\v 9 Huixín xapu̱chinaní̱n tascujut, cca̱huaniyá̱n caca̱lakalhamántit mintasa̱cuacán ni̱ huata caca̱maka̱klhátit, ca̱ksántit xlacata huixín y mintasa̱cuacán huata kalhi̱yá̱tit cha̱tum Mimpu̱chinacán nac akapú̱n y xlá acxtum ca̱cxilhlacachá̱n cristianos. 
\s1 Tlajaná ca̱makatlajaputún tí tali̱pa̱huán Jesús 
\p  
\v 10 Li̱ta̱camán, aquit cca̱maksquiná̱n ni̱ cali̱makxtáktit li̱pa̱huaná̱tit Quimpu̱chinacán xlacata nakalhi̱yá̱tit li̱camama y chuná xlá na̱ ni̱ nali̱makxtaka ca̱ma̱xqui̱yá̱n ixli̱tlihueke.  
\v 11 Huixín ni̱ cali̱makxtáktit cucayá̱tit namá li̱tlihueke ni̱ma̱ ca̱ma̱xqui̱ni̱tán Dios xlacata nata̱yaniyá̱tit acxni nata̱ra̱nicá̱tit tlajaná.  
\v 12 Porque ca̱ta̱ra̱niccán cristianos ni̱ snu̱n li̱cuánit la̱ acxni ca̱ta̱ra̱niccán ixli̱tlihuekecán namá tí talapu̱lá ca̱u̱ní̱n ixli̱ti̱lanca ca̱quilhtamacú, la̱ xanapuxcun tlajananí̱n, lacli̱cuánit xakascahuirín tí ta̱kastacya̱huá cristianos catatzacá̱tnalh, y tí ta̱ktlakahuacanán catatláhualh cristianos tú ni̱ tla̱n.  
\v 13 Huá cca̱li̱huaniyá̱n ni̱ cali̱makxtáktit li̱latapu̱li̱yá̱tit ixli̱tlihueke Dios xlacata tla̱n naca̱makatlajayá̱tit namá tlajananí̱n acxni ca̱ta̱ra̱slaká̱n, y para ta̱yaniyá̱tit tla̱n ma̱s tancs nali̱pa̱huaná̱tit Dios. 
\p  
\v 14 Huixín catzi̱yá̱tit soldados acxni tara̱nica, ta̱kxpakatahuacá la̱ cinturón, na̱ chuná huixín ca̱kxpakatahuacátit tancs ixtalacapa̱stacni Dios; xlacán tacuxmu̱tahuacá li̱cá̱n xlacata naca̱maklhti̱nán, huixín na̱ chuná cacuxmu̱tahuacátit tancs milatama̱tcán.  
\v 15 Soldados tatatu̱nú zapatos ni̱ma̱ tla̱n tali̱tanú cani̱huá, huixín na̱ chuná lacapala capítit cani̱huá xlacata tla̱n nali̱chihui̱naná̱tit la̱ Dios ca̱lakma̱xtú cristianos.  
\v 16 Soldados takalhí escudos ni̱ma̱ tali̱chipapa̱xtoka li̱cá̱n, huixín na̱ chuná cakalhí̱tit la̱ escudo tancs li̱pa̱huaná̱tit Dios xlacata nali̱chipapa̱xtoká̱tit ixli̱tlihueke tlajaná.  
\v 17 Xlacán tata̱knú cascos, huixín na̱ chuná cakalhí̱tit nac miakxa̱kacán xli̱ca̱na ca̱lakma̱xtuni̱tán Cristo. 
\p  
\v 18 Aquit cca̱huaniyá̱n skálalh calatapa̱tit ni̱ cali̱makxtáktit kalhtahuakayá̱tit, camaksquíntit Espíritu Santo caca̱ma̱cxcatzi̱ní̱n tú tla̱n ca̱ma̱xqui̱yá̱n Dios. Siempre camaksquíntit Dios caca̱maktakalhni y caca̱maktákalhli xa̱makapitzi tí na̱ tali̱pa̱huán Dios.  
\v 19 Y aquit na̱ caquila̱li̱kalhtahuakáu xlacata caquima̱cxcatzí̱ni̱lh Dios tachihuí̱n ni̱ma̱ nacca̱huaní quilhpa̱xtum cristianos ixli̱hua̱k quintapuhuá̱n la̱ tla̱n tataxtuní tí tali̱pa̱huán Cristo.  
\v 20 Dios quili̱makxtakni̱t nacma̱kahuaní jaé lacsa̱sti tachihuí̱n ma̱squi chí ctanu̱ma cpu̱la̱chí̱n pues camaksquíntit ni̱ cactatláji̱lh xlacata tancs nacli̱chihui̱nán la̱ mini̱ní. 
\p  
\v 21 Namá koxitá quinta̱camcán Tíquico ni̱ akatzanka̱ni̱t li̱scujni̱t Quimpu̱chinacán y huá ama ca̱huaniyá̱n la̱ clama̱náu y tú ctlahuama.  
\v 22 Aquit cca̱ma̱lakacha̱nimá̱n xlacata nacatzi̱yá̱tit tú cpa̱xtokni̱táu y nali̱pa̱xahuayá̱tit tú naca̱li̱ta̱chihui̱naná̱n. 
\p  
\v 23 Li̱ta̱camán, Quinta̱tajcán Dios y Quimpu̱chinacán Jesucristo caca̱ma̱xquí̱n ma̱s li̱pa̱xáu latáma̱t, caca̱ma̱si̱nín la̱ ma̱s nala̱lakalhamaná̱tit huixín li̱ta̱camán tí li̱pa̱huaná̱tit Jesús.  
\v 24 Quinti̱cucán Dios caca̱cxilhlacachá̱n y caca̱ma̱xquí̱n tú makatzanka̱yá̱tit huixín tí xli̱ca̱na pa̱xqui̱yá̱tit y tlahuayá̱tit tú ca̱li̱ma̱paksi̱yá̱n Quimpu̱chincán Jesucristo. Chuná calalh, amén.