\id ECC - Susu Translation 
\h كَوَندِلَ 
\toc1 كَوَندِلَ شَ كِتَابُي 
\toc2 كَوَندِلَ 
\toc3 كَو 
\mt1 كَوَندِلَ شَ كِتَابُي 
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ 
\ip عَننَبِ سُلٍمَنِ يِ كِتَابُي نَن سّبّشِ عَ شَ بَننَيَ، عَ شَ نْي، نُن عَ شَ لْننِ بٍلٍبٍلٍ نَن شَ قٍ رَ. نَ بِرِن قِندِشِ مَسٍنيِ هَفِفّ نَن نَ عَ بّ عَلَتَلَ شَ مَرَفِرِ كُي. عَ نَشَ عَ قَهَامُ نَ بِرِن قِندِشِ «قٍ قُقَقُ» نَن نَ. بِرَقٍ نَ قٍ مْولِ قْشْ رَ، نَ لُشِ عَلْ مِشِ «نَشَن بِرَ مَ قٌيٍ قْشْ رَ.» قٌيٍ نَ نَ، كْنْ عَ سِفَمَ نّ، عَ مُ بُمَ. عَ سُشُقٍ مُ سْونّيَمَ. عَ نَ نَ كِ نّ وٌن مَ دُنِحّءِفِرِ كُي. 
\ip يِ كِتَابُي شَ مَسٍنيِ تِدٍ فبٌ بَرِ مَ تٌ مِشِيٍ مُ تَفَنمَ بِرَدٍ قٍ وُيَشِ قْشْ رَ نَشَن مُ قِندِشِ عَلَتَلَ شَ سّرِيّ رَ. عٍ بِرِن كَتَمَ نّ نَاقُلِ سْتْدٍ. عٍ لْننِ قٍنمَ عَلَكٌ نَ تَن قَن شَ قِندِ كْبِرِ رَ. نَ كِرَ شْن مَ عٍ قٍ مْولِ بِرِن نَبَمَ نَشٍيٍ نْمَ رَقَندٍ عٍ قَتٍ مَ. نَ حّرّ كِ كُي عَدَ مَدِ لُمَ يُنُبِ رَبَ رَ. 
\ip عَلَتَلَ نَشَن مَسٍنمَ وٌن بّ عَننَبِ سُلٍمَنِ سَابُي رَ عَ قِندِشِ يِ نَن نَ؛ عَ لَنمَ عَدَ مَدِ شَ بِرَ عَلَتَلَ شَ سّرِيّ قْشْ رَ يِ دُنِحَ بّندّ قُحِ قَرِ. عَلَ دُنِحَ نَشَن دَاشِ عَ قَن عَدَ مَ بّ، كْنْ عَ مُ لَنمَ عَ شَ قِندِ عَ شَ عَلَ رَ. عَلَتَلَ حّلّشِنيِ قِمَ مِشِ مَ، كْنْ عَ وَ مَ نّ عٍ شَ عَ كٌلٌن عَ تَن نَن قِندِشِ عٍ مَرِفِ رَ. عَ لَنمَ عَدَ مَ شَ دُنِحَ عِفِرِ، عَ يَ تِشِ عَلَ نَن نَ. عَ شَ عَ كٌلٌن دُنِحَ سٍيٍ مُ بُمَ، عٍ لُشِ نّ عَلْ «قٌيٍ» نَشَن لْيمَ يٍن. 
\ip يِ كِتَابُي عَ مَسٍنمَ نّ وٌن بّ عَ لَنمَ وٌن مَرِفِ شَ قِندِ عَلَتَلَ دَالِ مَنفّ نَن نَ، عَ نَشَ قِندِ دَالِ سٍ ندٍ رَ. عَلَ شَ وٌن مَلِ نَ كٌلٌنقٍ رَ وٌن بْحّ كُي. عَمِنَ. 
\mt1 كَوَندِلَ شَ كِتَابُي 
\c 1  
\s1 دُنِحَ قُ نَ عَ رَ! 
\d  
\v 1 دَوُدَ شَ دِ دَرِ سَلَمُ مَنفّ شَ كَوَندِ نَن يَ؛ 
\q1  
\v 2 دُنِحَ قِندِشِ قٍ قُقَقُ نَن نَ. 
\q1 دُنِحَ قٍيٍ تِدٍ يٌ مُ نَ، 
\q1 نَ بِرِن قِندِشِ قُيَن نَن نَ. 
\q1 ﭑ تَن كَوَندِلَ شَ مَسٍنيِ نَن نَن كِ. 
\b  
\q1  
\v 3 عَدَ مَدِ فٍينِ مُندُن سْتْمَ عَ شَ وَلِ مَ سٌفٍ بُن مَ؟ 
\q1  
\v 4 ندٍيٍ قَشَمَ، ندٍيٍ بَرِ مَ، دُنِحَ قَن نَ كّحَ كٍرٍن لْشْي بِرِن. 
\q1  
\v 5 سٌفٍ تٍمَ، عَ فٌرٌ مَ، عَ مَن فبِلٍن عَ تٍشِ دّننَشّ. 
\q1  
\v 6 قٌيٍ قَن مِنِمَ، عَ سِفَمَ يِرٍقَنيِ مَ، عَ عَ مَقِندِ مَ كْولَ مَ. 
\q1 عَ نَ فّ مَقِندِدٍ، عَ مَن فبِلٍن عَ كٍلِدٍ. 
\q1  
\v 7 شُرٍ بِرِن شُن تِشِ بَا نَن نَ، كْنْ بَا مُ رَقٍمَ. 
\q1 شُرٍيٍ كٍلِمَ دّننَشّ، عٍ مَن فبِلٍنمَ مّننِ نّ. 
\q1  
\v 8 قٍ بِرِن حّرّ مَ، عَ مُ تَفَنمَ، عَ مُ مَسَرَ مَ. 
\q1 عَدَ مَ يَ مُ وَ سَمَ قٍ مَتٌدٍ، 
\q1 عَ تُلِ قَن مُ لُفَمَ قٍ رَ مّدٍ. 
\q1  
\v 9 نَشَن بَرَ دَنفِ نُ، 
\q1 نَ نَن مَن فبِلٍنمَ عَ رَ. 
\q1 نَشَن بَرَ رَبَ نُ، نَ نَن مَن نَبَمَ. 
\q1 قٍ نّينّ مُ رَبَمَ دُنِحَ مَ نَشَن حْندْن مُ نُ رَبَ. 
\q1  
\v 10 قٍ نّينّ يٌ مُ نَ نَشَن عَ نِيَمَ مِشِ شَ عَ قَلَ، 
\q1 «يِ مَتٌ، قٍ نّينّ نَ عَ رَ!» 
\q1 ﭑ شَ عَ قَلَ وٌ بّ، نَ قٍ مْولِ حَن نُ نَ بٍينُن وٌن تَن شَ بَرِ. 
\q1  
\v 11 حَمَ مُ رَتُمَ قٍ دَنفِشِ مَ، 
\q1 قٍ نَشَن سَ قَمَ رَبَدٍ، حَمَ نّيمُمَ نّ نَ قَن نَ. 
\p  
\v 12 ﭑ تَن كَوَندِلَ، ﭑ بَرَ قِندِ مَنفّ رَ عِسِرَيِلَ بْشِ مَ دَرِ سَلَمُ.  
\v 13 ﭑ نَتّ تٌنفٌشِ نّ، قٍ نَشٍيٍ بِرِن نَبَقٍ يِ دُنِحَ مَ، ﭑ شَ عٍ مَتٌ عَ قَنيِ رَ. نَ كُي ﭑ عَ تٌ نّ عَ عَلَ كٌتٍ شْرْشْي نَن سَشِ عَدَ مَدِيٍ قَرِ.  
\v 14 ﭑ بَرَ وَلِ بِرِن مَتٌ نَشَن نَبَمَ يِ دُنِحَ مَ. قُقَقُ نَ عَ بِرِن نَ! بِرَقٍ نَ وَلِ قْشْ رَ، عَ لُشِ نّ عَلْ مِشِ نَ بِرَقٍ قٌيٍ نَن قْشْ رَ. 
\q1  
\v 15 نَشَن كُنتِنشِ، نَ مُ نْمَ مَتِنشِندٍ، 
\q1 نَشَن لُشِ، نَ مُ نْمَ كَمَلِدٍ. 
\p  
\v 16 ﭑ نَشَ عَ مَحْشُن ﭑ يّتّ مَ، عَ ﭑ تَن بَرَ لْننِ قٍن دَنفِ دَرِ سَلَمُ مَنفّ بِرِن نَ، نَشٍيٍ سِنفٍ قَ ﭑ تَن يَرَ. ﭑ بَرَ لْننِ نُن قٍ كٌلٌنيِ فبٍفبٍ سْتْ دُنِحَ شَ قٍ مَ.  
\v 17 ﭑ نَشَ نَتّ تٌنفٌ ﭑ شَ شَشِلِمَيَ نُن شَشِلِتَرٍحَ قَن مَتٌ. كْنْ ﭑ بَرَ عَ تٌ نَ قَن لُشِ عَلْ بِرَقٍ قٌيٍ نَن قْشْ رَ. 
\q1  
\v 18 شَشِلِمَيَ نُن كْنتْقِلِ نَن حّرّ مَ كِرَ كٍرٍن شْن مَ. 
\q1 قٍ كٌلٌنيِ فبٌمَ كِ نَشّ، تْورّ قَن فبٌمَ نَ كِ نّ. 
\c 2  
\s1 عَدَ مَدِ وَشْنقٍ 
\p  
\v 1 ﭑ عَ قَلَ نّ ﭑ يّتّ بّ، «ﭑ شَ حّلّشِنيِ مَتٌ، ﭑ شَ عَ كٌلٌن نَشَن قَن.» ﭑ نَشَ عَ تٌ عَ حّلّشِنيِ قَن مُ بُمَ.  
\v 2 ﭑ نَشَ ﭑ يّتّ مَشْرِن، «يٍلٍقٍ تُن مُ قِندِشِ قٍ كَمَلِشِ رَ. حّلّشِنيِ تِدٍ نَ مُنسٍ رَ؟»  
\v 3 ﭑ نَشَ نَتّ تٌنفٌ ﭑ مَ لْننِ قٍنقٍ كُي، ﭑ شَ حّلّشِنيِ قٍن وّنِ رَ. ﭑ نُ وَ مَ عَ كٌلٌنقٍ مُنسٍ مُنَقَنيِ فبٌ عَدَ مَدِيٍ بّ عٍ شَ دُنِحّءِفِرِ كُي. 
\p  
\v 4 ﭑ نَشَ وَلِ شُنفبٍ ندٍيٍ سُشُ عَلْ بَنشِ تِقٍ نُن شّ سَقٍ.  
\v 5 ﭑ نَشَ يِرٍ تٌقَنيِيٍ يَءِلَن نَاقُلِ كَنيِ عٍ مَلَبُمَ دّننَشّ سَنسِ تٌقَنيِيٍ يَ مَ.  
\v 6 ﭑ نَشَ يٍ يِرٍ فٍ نَشٍيٍ عَ نِيَمَ يٍ شَ سَ ﭑ مَ سَنسِيٍ مَ.  
\v 7 ﭑ نَشَ كٌنيِيٍ سَرَ، نَشٍيٍ بَرَ دِيٍ سْتْ نَشٍيٍ قِندِشِ ﭑ فبٍ رَ، عٍ قَ لُ ﭑ شْنيِ. ﭑ نَشَ شُرُ سٍ فبٍفبٍ سْتْ، دَنفِ دَرِ سَلَمُكَيٍ بِرِن نَ نَشٍيٍ نُ نَ بٍينُ ﭑ شَ بَرِ.  
\v 8 ﭑ نَشَ فبٍتِ، شّيمَ، نُن نَاقُلِ مْولِ بِرِن سْتْ. ﭑ نَشَ يٍلِبَيٍ سْتْ، عَ نُن فِنّ فَلِ عَدَ مَ وَشْنقٍ شَ قٍ رَ.  
\v 9 ﭑ نَشَ قِندِ مِشِ شُنفبٍ رَ دَنفِقٍ دَرِ سَلَمُكَيٍ بِرِن نَ نَشٍيٍ نُ نَ بٍينُ ﭑ شَ بَرِ. ﭑ نَشَ نَ بِرِن نَبَ لْننِ قٍنقٍ رَ. 
\q1  
\v 10 ﭑ نَشَ ﭑ وَشْنقٍ مْولِ بِرِن قٍن، 
\q1 ﭑ مُ تٌندِ سٍسٍ رَ نَشَن نُ رَقَنشِ ﭑ مَ. 
\q1 ﭑ مَ وَلِ يَتِ نُ رَقَنشِ ﭑ مَ، 
\q1 نَ نَن قِندِشِ ﭑ مَ فٍينِ رَ. 
\q1  
\v 11 كْنْ ﭑ تٌ ﭑ مَ وَلِ بِرِن مَتٌ، 
\q1 ﭑ نَشَن نَبَشِ تْورّ كُي، 
\q1 ﭑ نَشَ عَ تٌ نَ بِرِن قُقَقُ. 
\q1 عَ نُ لُشِ نّ عَلْ مِشِ نَشَن بِرَ مَ قٌيٍ قْشْ رَ 
\q1 عَ مُ سٍسٍ سُشُ. 
\b  
\q1  
\v 12 نَ تّمُي ﭑ نَشَ ﭑ حْشْ سَ شَشِلِمَيَ نُن شَشِلِتَرٍحَ شْن مَ. 
\q1 نَشَن تِمَ مَنفّ رَ ﭑ حْشْي رَ، 
\q1 نَ قَمَ مُنسٍ رَبَدٍ؟ 
\q1  
\v 13 ﭑ نَشَ عَ تٌ شَشِلِمَيَ قَن دَنفِ شَشِلِتَرٍحَ رَ، 
\q1 عَلْ نَءِيَلَنيِ قَن تٌ قَنشِ دِ مِ بّ. 
\q1  
\v 14 شَشِلِمَ سٍ تٌمَ عَ يَ رَ، 
\q1 شَشِلِتَرٍ تَن عَ حّرّ مَ دِ مِ نَن كُي. 
\q1 كْنْ عٍ قِرِن بِرِن قَشَمَ نّ. 
\q1  
\v 15 نَ نَن عَ رَ ﭑ نَشَ عَ مَحْشُن، 
\q1 شَ ﭑ تَن نُن شَشِلِتَرٍ بِرِن قَشَمَ نّ، 
\q1 ﭑ مَ شَشِلِمَيَ تِدٍ قَ نَ مُنسٍ رَ؟ 
\q1 ﭑ نَشَ عَ قَلَ ﭑ يّتّ بّ، «شَشِلِمَيَ قَن قٍ قُقَقُ نَن عَ رَ.» 
\q1  
\v 16 شَشِلِمَ نُن شَشِلِتَرٍ شَ قٍ مُ رَتُمَ مِشِيٍ رَ، 
\q1 عٍ نّيمُمَ نّ عٍ قِرِن بِرِن مَ، عٍ قِرِن بِرِن قَشَمَ نّ. 
\p  
\v 17 نَ كُي دُنِحّءِفِرِ نَشَ رَحَاشُ ﭑ مَ، بَرِ مَ ﭑ بَرَ عَ كٌلٌن ﭑ مَ وَلِ مُ بُمَ. عَ لُشِ نّ عَلْ مِشِ نَشَن بِرَ مَ قٌيٍ قْشْ رَ، عٍ مُ عَ سُشُ.  
\v 18 ﭑ مَ وَلِ نَشَ رَحَاشُ ﭑ مَ، بَرِ مَ ﭑ بَرَ عَ كٌلٌن قٌ ﭑ شَ نَ بِرِن لُ مِشِ فبّتّ يِ رَ.  
\v 19 نَ مِشِ قِندِ مَ شَشِلِمَ نَن نَ، كَ شَشِلِتَرٍ رَ؟ ندٍ نْمَ نَ كٌلٌندٍ؟ كْنْ عَ تَن يَتِ نْي سْتْمَ نّ ﭑ مَ وَلِ بِرِن شُن مَ! قٍ قُقَقُ نَن نَ كِ.  
\v 20 نَ كُي ﭑ نَشَ نِمِسَ وَلِ بِرِن شَ قٍ رَ ﭑ نَشَن نَبَ يِ دُنِحَ مَ. 
\p  
\v 21 مِشِ نَشَن وَلِشِ لْننِ نُن قَتّ رَ، عَ قَ نَ وَلِ لُ مِشِ ندٍ يِ رَ نَشَن مُ سٍسٍ رَبَ نَ وَلِ كُي، نَ قِندِشِ قٍ قُقَقُ نَن نَ نَشَن شْرْشْ كِ قَنيِ رَ.  
\v 22 مِشِ فٍينِ مُندُن سْتْمَ عَ شَ وَلِ نُن عَ شَ كَتّ كُي عَ نَشَن نَبَشِ يِ دُنِحَ مَ؟  
\v 23 عَ شَ وَلِ قِندِشِ تْورّ شْرْشْي نَن نَ عَ بّ. هَلِ كْي رَ عَ بْحّ مُ مَلَبُمَ. قٍ قُقَقُ نَن نَ كِ. 
\p  
\v 24 عَ لَنمَ مِشِ شَ عَ دّفٍ، عَ شَ عَ مِن، عَ شَ عَ شَ وَلِ رَبَ سّيوّ كُي. ﭑ بَرَ عَ كٌلٌن نَ بِرِن كٍلِشِ عَلَ نَن مَ.  
\v 25 مِشِ مُ نْمَ عَ دّفٍدٍ، عَ قٍ قَنيِ كٌلٌن شَ عَلَ مُ عَ مَلِ؟  
\v 26 مِشِ نَشَن نَقَن عَلَ مَ، عَلَ عَ كِمَ شَشِلِ قَنيِ، قَهَامُي، نُن سّيوّ نَن نَ. كْنْ شَشِلِتَرٍ تَن، عَلَ عَ نِيَمَ نّ عَ شَ عَ هَرِفٍ بِرِن سٌ مِشِ فبّتّ يِ رَ نَشَن نَقَن عَلَ مَ. يِ قَن قِندِشِ قٍ قُقَقُ نَن نَ، عَلْ مِشِ نَشَن بِرَ مَ قٌيٍ قْشْ رَ. 
\c 3  
\s1 تّمُي نَ قٍ بِرِن مَ 
\q1  
\v 1 تّمُي نَ قٍ بِرِن مَ، 
\q1 قٍ بِرِن دُنِحَ مَ، عَ شَ وَشَتِ نَ نَ. 
\q1  
\v 2 وَشَتِ ندٍ نَ دِ بَرِقٍ مَ، 
\q1 وَشَتِ ندٍ نَ قَشَقٍ مَ. 
\q1 وَشَتِ ندٍ نَ سَنسِ سِقٍ مَ، 
\q1 وَشَتِ ندٍ نَ سَنسِ شَبَقٍ مَ. 
\q1  
\v 3 وَشَتِ ندٍ نَ قَشّ تِقٍ مَ، 
\q1 وَشَتِ ندٍ نَ دَندَن تِقٍ مَ. 
\q1 وَشَتِ ندٍ نَ سٍ كَنَقٍ مَ، 
\q1 وَشَتِ ندٍ نَ سٍ يَءِلَنقٍ مَ. 
\q1  
\v 4 وَشَتِ ندٍ نَ وَقٍ مَ، 
\q1 وَشَتِ ندٍ نَ يٍلٍقٍ مَ. 
\q1 وَشَتِ ندٍ نَ يَيٍ رَ مِنِقٍ مَ، 
\q1 وَشَتِ ندٍ نَ قَرٍ بٌرٌنقٍ مَ. 
\q1  
\v 5 وَشَتِ ندٍ نَ فّمّيٍ رَيٍنسٍنقٍ مَ، 
\q1 وَشَتِ ندٍ نَ فّمّيٍ مَلَنقٍ مَ. 
\q1 وَشَتِ ندٍ نَ سُنبُ تِقٍ مَ، 
\q1 وَشَتِ ندٍ نَ عَ تِتَرٍيَ مَ. 
\q1  
\v 6 وَشَتِ ندٍ نَ سٍ قٍنقٍ مَ، 
\q1 وَشَتِ ندٍ نَ عَ لُقٍ مَ. 
\q1 وَشَتِ ندٍ نَ سٍ رَفَتَقٍ مَ، 
\q1 وَشَتِ ندٍ نَ عَ وْلّقٍ مَ. 
\q1  
\v 7 وَشَتِ ندٍ نَ سٍ عِبْوقٍ مَ، 
\q1 وَشَتِ ندٍ نَ عَ دّفّقٍ مَ. 
\q1 وَشَتِ ندٍ نَ وْيّنقٍ مَ، 
\q1 وَشَتِ ندٍ نَ دُندُقٍ مَ. 
\q1  
\v 8 وَشَتِ ندٍ نَ شَنُ تِقٍ مَ، 
\q1 وَشَتِ ندٍ نَ شْن تِقٍ مَ. 
\q1 وَشَتِ ندٍ نَ فٍرٍ سٌقٍ مَ، 
\q1 وَشَتِ ندٍ نَ سَاتَقٍ مَ. 
\p  
\v 9 وَلِكّ فٍينِ مُندُن سْتْمَ عَ شَ كَتّ كُي؟  
\v 10 ﭑ بَرَ كٌتٍ تٌ عَلَ نَشَن دْشْشِ عَدَ مَدِيٍ شُن.  
\v 11 عَ بَرَ سٍ بِرِن نَتٌقَن عَ وَشَتِ مَ. عَ بَرَ عَ نِيَ عَدَ مَدِ شَشِلِ شَ سِفَ عَبَدَن قٍ مَ، هَلِ عَ مُ نْ عَلَ شَ وَلِيٍ كٌلٌندٍ كٍلِ عَ قْلّ مَ هَن عَ رَحْنيِ.  
\v 12 ﭑ عَ كٌلٌن قٍقٍ مُ نَ نَشَن قَن عَدَ مَدِ بّ، قٌ عَ سّيوَ، عَ قٍ قَنيِ رَبَ عَ شَ دُنِحّءِفِرِ كُي.  
\v 13 مِشِ عَ دّفٍقٍ، عَ عَ مِن، عَ سّيوَ عَ شَ وَلِ كُي، نَ نَن قِندِشِ عَلَ شَ كِ رَ عَدَ مَدِ بّ.  
\v 14 ﭑ عَ كٌلٌن عَلَ شَ وَلِ بِرِن بُمَ نّ عَبَدَن. سٍسٍ مُ سَمَ عَ شُن مَ، سٍسٍ مُ بَمَ عَ رَ. عَلَ قٍ رَبَمَ نّ عَلَكٌ عَدَ مَدِ شَ فَاشُ عَ يَ رَ. 
\q1  
\v 15 نَشَن نَ نَ، نَ حَن نُ نَ نُ. 
\q1 نَشَن قَمَ رَبَدٍ، نَ حَن نُ نَ نُ. 
\q1 عَدَ مَدِ نَشَن نَبَشِ، عَلَ قَمَ نّ نَ مَكِيتِدٍ. 
\p  
\v 16 ﭑ بَرَ قٍ فبّتّ قَن تٌ يِ دُنِحَ مَ؛ 
\q1 نْندِ مَقِندِ مَ وُلٍ رَ، 
\q1 تِنشِنيِ مَقِندِ مَ تِنشِنتَرٍيَ رَ. 
\q1  
\v 17 ﭑ نَشَ عَ مَحْشُن ﭑ شَشِلِ كُي، 
\q1 عَلَ تِنشِنتْي نُن تِنشِنتَرٍ مَكِيتِمَ نّ، 
\q1 بَرِ مَ قٍ بِرِن عَ وَشَتِ نَ نَ. 
\p  
\v 18 ﭑ مَن نَشَ عَ مَحْشُن ﭑ شَشِلِ كُي، عَلَ نَ مِشِيٍ مَتٌقٍ نّ، عَلَكٌ عٍ شَ عَ كٌلٌن دَالِسٍ نَن لَنشِ عٍ مَ عَلْ وُلَءِ سُبٍيٍ.  
\v 19 عٍ قِرِن بِرِن قَمَ نّ رَحْندٍ يِرٍ كٍرٍن، عٍ قِرِن بِرِن قَشَمَ نّ. عٍ قِرِن بِرِن حّنفِمَ كِ كٍرٍن، عَدَ مَ يٌ سُبٍ يٌ، عٍ بِرِن لَن. قٍ قُقَقُ نَ نَ بِرِن نَ.  
\v 20 عٍ بِرِن سِفَدٍ كٍرٍن. عٍ كٍلِشِ بّندّ نّ، عٍ مَن فبِلٍنمَ بّندّ نّ.  
\v 21 ندٍ عَ كٌلٌن شَ مِشِ قَشَشِ شَشِلِ تٍمَ كٌورٍ نّ، شَ سُبٍ قَشَشِ شَشِلِ فٌرٌ مَ بْشِ نّ؟ 
\p  
\v 22 ﭑ عَ كٌلٌن قٍقٍ مُ نَ نَشَن قَن عَدَ مَدِ بّ، قٌ عَ سّيوَ عَ شَ وَلِ كُي. نَ نَن قِندِشِ عَلَ شَ مَرَفِرِ رَ عَدَ مَدِ بّ. ندٍ نْمَ عَ مَسٍندٍ عَ بّ نَشَن قَمَ رَبَدٍ عَ دَنفِ شَنبِ؟ 
\c 4  
\s1 قَشَقٍ نُن بَلٌقٍ 
\p  
\v 1 ﭑ مَن بَرَ ﭑ شَشِلِ رَ سِفَ حَشَنكَتّ بِرِن مَ، نَشَن نَ رَبَقٍ يِ دُنِحَ مَ. 
\q1 مِشِ حَشَنكَتَشِ نَ وَقٍ، 
\q1 عٍ مَدُندُ مَ يٌ مُ نَ. 
\q1 نْي نَ مِشِيٍ بّ نَشٍيٍ نَ عٍ حَشَنكَتَقٍ. 
\q1 عٍ مَدُندُ مَ يٌ مُ نَ. 
\q1  
\v 2 ﭑ بَرَ عَ مَحْشُن، مِشِ قَشَشِ نَن سّيوَشِ دَنفِقٍ مِشِ بَلٌشِ رَ. 
\q1  
\v 3 مِشِ نَشَن مُ بَرِشِ سِندٍن، 
\q1 نٍيٍ شَ هّيرِ دَنفِ مِشِ قَشَشِ نُن مِشِ بَلٌشِ رَ، 
\q1 بَرِ مَ عٍ مُ حَشَنكَتّ كٌلٌن نَشَن نَ رَبَقٍ يِ دُنِحَ مَ. 
\p  
\v 4 ﭑ بَرَ عَ تٌ، مِشِ وَلِمَ عٍ شُننَكٍلِ قٍنمَ مِلّ كُي. يِ قَن قِندِشِ قٍ قُقَقُ نَن نَ، عَلْ بِرَقٍ قٌيٍ قْشْ رَ. 
\q1  
\v 5 شَشِلِتَرٍ عَ بّلّشّيٍ قِندِفِلِنشِ عَ مَ، عَ مُ وَلِمَ، 
\q1 هَن عَ شُن نَكَنَ. 
\q1  
\v 6 بْحّسَ دٌندٌرٌنتِ قِسَ كَتّ فبٍفبٍ بّ. 
\q1 نَ كَتّ لُشِ نّ عَلْ مِشِ نَشَن بِرَ مَ قٌيٍ قْشْ رَ. 
\p  
\v 7 ﭑ بَرَ قٍ قُقَقُ فبّتّ قَن تٌ يِ دُنِحَ مَ. 
\q1  
\v 8 شّمّ ندٍ نُ نَ نَشَن نُ نَ عَ كٍرٍنيِ مَ، 
\q1 مِشِ يٌ مُ نُ نَ عَ بّ. 
\q1 عَ نُ وَلِمَ تّمُي بِرِن، كْنْ عَ مُ وَ سَ عَ شَ نَاقُلِ رَ. 
\q1 عَ نَشَ عَ يّتّ مَشْرِن، 
\q1 «ﭑ نَ وَلِقٍ تْورّ كُي ندٍ بّ؟» 
\q1 يِ مْولِ قَن قِندِشِ قٍ قُقَقُ نَن نَ. 
\b  
\q1  
\v 9 مِشِ قِرِن مَلَنشِ سْونّيَ دَنفِقٍ مِشِ رَ نَشَن لُمَ عَ كٍرٍن. 
\q1 نَ قِرِنيِيٍ شَ وَلِ دَنفِ نَ مِشِ كٍرٍنيِ فبٍ رَ. 
\q1  
\v 10 شَ عَ سَ لِ كٍرٍن بِرَ، عَ بٌورٍ عَ رَكٍلِمَ نّ. 
\q1 كْنْ مِشِ نَشَن بِرَ مَ، عَ مَلِمَ مُ نَ، 
\q1 نَ تْورْ مَ نّ عَ حَاشِ رَ. 
\q1  
\v 11 نَ مَنِيَشِ مِشِ قِرِن نَن نَ، 
\q1 نَشٍيٍ سَشِ عٍ بٌورٍ قّ مَ شِنبٍلِ تّمُي، 
\q1 عٍ نُ وُيٍنيِ سْتْ عٍ بٌورٍ سَابُي رَ. 
\q1 كْنْ مِشِ نَشَن نَ عَ كٍرٍنيِ مَ، نَ شِنبٍلِ بَمَ دِ؟ 
\q1  
\v 12 مِشِ حَاشِ نْمَ نّ مِشِ كٍرٍن نَ، 
\q1 كْنْ مِشِ قِرِن تَن تِمَ نّ عَ كَنكٍ. 
\q1 لُوتِ شْرِ سَشَن مَلَنشِ مُ بٌلٌنمَ مَقُرٍن. 
\p  
\v 13 مِسِكِينّ شَ دِ نَشَن شَشِلِ قَن، عَ سّنبّ فبٌ مَنفّ بّ نَشَن مُ قَتَ مَرَ سِ قَنيِ نُن عَ حَاشِ تَفِ رَ سَدٍ.  
\v 14 نَ مِشِ مْولِ نْمَ مِنِدٍ فٍيلِ كُي، عَ قِندِ مَنفّ رَ. عَ بَرِشِ سٍتَرٍحَ نَن كُي، عَ قَ مَنفّيَ سْتْ.  
\v 15 دُنِحَ مِشِ بِرِن سَشَنيِ نَن نَبَمَ، عِ نَ دَنفِ مِشِ فبّتّ قَ تِ عِ حْشْي رَ.  
\v 16 مِشِ وُيَشِ دَنفِشِ نّ بٍينُن نَ كَنيِ شَ بَرِ. مِشِ نَشٍيٍ قَمَ عَ شَنبِ رَ، عَ شَ قٍ مُ قَمَ رَقَندٍ عٍ مَ. نَ قَن قِندِشِ قٍ قُقَقُ نَن نَ، عَلْ مِشِ نَشَن بِرَقٍ قٌيٍ قْشْ رَ. 
\p  
\v 17 عِ نَ سِفَ سَلِدٍ عَلَ شَ بَنشِ، عِ شَ عِ يّتّ مَتٌ عَ قَنيِ رَ. عِ نَ سِفَ، عِ شَ عِ تُلِ مَتِ مَسٍنيِ رَ نَشَن تِمَ نَا. نَ تِدٍ فبٌ دَنفِقٍ سّرّشّ بَقٍ رَ نَشَن نَبَمَ شَشِلِتَرٍحَ كُي، بَرِ مَ شَشِلِتَرٍيٍ مُ عَ كٌلٌن، عَ عٍ نَ قٍ كٌبِ نَن شُن مَ نَ كِ. 
\c 5  
\s1 لَايِدِ تٌنفٌقٍ عَلَ بّ 
\q1  
\v 1 عِ نَشَ فبَتَ عِ دّ رَبِدٍ وْيّنيِ شِلِ مَ، 
\q1 عِ نَشَ فبَتَ لَايِدِ تٌنفٌدٍ عَلَ بّ، 
\q1 بَرِ مَ عَلَ تَن نَ كٌورٍ نّ، كْنْ عِ تَن نَ بْشِ نَن مَ. 
\q1 عَوَ، عِ شَ وْيّنيِ نَشَ وُيَ. 
\q1  
\v 2 عَلْ شِيٍ تٌ كٍلِمَ مَحْشُنيِ فبٍفبٍ مَ، 
\q1 شَشِلِتَرٍحَ قَن كٍلِمَ دّ وُيَ نَن مَ. 
\p  
\v 3 شَ عِ بَرَ لَايِدِ تٌنفٌ عَلَ بّ، عِ نَشَ دُفُندِ عَ رَكَمَلِدٍ. شَشِلِتَرٍحَ مُ رَقَن عَلَ مَ. عَ لَنمَ عِ شَ عِ شَ لَايِدِ رَكَمَلِ.  
\v 4 لَايِدِ تٌنفٌتَرٍحَ قِسَ لَايِدِ رَكَمَلِتَرٍحَ بّ.  
\v 5 عِ نَشَ تِن عِ شَ وْيّنيِ شَ قِندِ يُنُبِ رَ. عِ نَشَ عَ قَلَ عَلَ شَ شّيرَ بّ، «ﭑ مُ نُ وَ مَ لَايِدِ يَتِ تٌنفٌقٍ.» نَ قٍ مْولِ عَلَ رَشْنْمَ نّ، عَ عَ نِيَ عِ شَ وَلِ شُن شَ رَكَنَ.  
\v 6 شِيٍ وُيَشِ سَقٍ نُن وْيّنيِ تِقٍ قِندِشِ قٍ قُقَقُ نَن نَ. نَ كُي عَ لَنمَ عِ شَ فَاشُ عَلَ يَ رَ. 
\p  
\v 7 عِ نَشَ تّرّننَ شَ عَ سَ لِ عِ مِشِيٍ تٌمَ تَا كُي نَشٍيٍ قُمَ مِسِكِينّيٍ مَ، عٍ سّرِيّ كَنَ، عٍ كِيتِ حَاشِ سَ تِنشِنتْييٍ مَ. مَنفّ عَ بٌورٍ مَنفّ نَن مَلِمَ، هَن عَ مَنفّيَ شُنفبٍ سْتْ.  
\v 8 عٍ بِرِن فٍينِمَ شّ سَمَيٍ نَن سَابُي رَ، هَلِ مَنفّ شُنفبٍ. 
\q1  
\v 9 كْبِرِ رَقَن مِشِ نَشَن مَ، عَ مُ وَ سَمَ. 
\q1 بَننَيَ رَقَن نَشَن مَ، عَ نَاقُلِ مُ عَ رَلِمَ. 
\q1 قٍ قُقَقُ نَن نَ كِ. 
\b  
\q1  
\v 10 هَرِفٍ فبٌمَ كِ نَشّ، عَ دٌنمَيٍ قَن فبٌمَ نَ كِ نّ. 
\q1 نَ كُي مُنَقَنيِ مُندُن نَ هَرِفٍ كَنيِ بّ، 
\q1 بَ عَ يَ تِقٍ رَ عَ هَرِفٍ رَ؟ 
\b  
\q1  
\v 11 وَلِكّ لُفَ بَ، عَ مُ لُفَ بَ، عَ شِشْلِ قَنيِ رَبَمَ نّ. 
\q1 كْنْ بَننَ شَ نَاقُلِ عَ نِيَمَ نّ عَ مُ شِشْلِ قَنيِ رَبَ. 
\q1  
\v 12 ﭑ قٍ مَفَاشُشِ ندٍ رَكْرْ سِشِ يِ دُنِحَ مَ؛ 
\q1 كَنكَنقٍ بَننَيَ مَ هَن عَ بَننَ تْورْ، 
\q1  
\v 13 شَ نَ مُ عَ رَ، بَننَيَ لْيقٍ تْورّ ندٍ سَابُي رَ، 
\q1 عَ قَ لِ بَننَ شَ دِ مُ كّ سْتْ. 
\q1  
\v 14 عَدَ مَدِ مِنِ كِ نَشّ عَ نفَ تّفّ، 
\q1 عَ مَن فبِلٍنمَ بّندّ عَ مَفٍلِ رَ نَ كِ نّ. 
\q1 عَ مُ سٍسٍ شَنِنمَ عَ شُن مَ عَ نَشَن سْتْ عَ شَ وَلِ كُي. 
\q1  
\v 15 يِ قٍ شْرْشْ. 
\q1 عَدَ مَدِ قَ كِ نَشّ يِ دُنِحَ مَ، 
\q1 عَ مَن سِفَمَ نَ كِ نّ. 
\q1 عَ شَ كَتّ قِندِشِ قٍ قُقَقُ نَن نَ. 
\q1  
\v 16 عَ دُنِحَ عِفِرِ مَ دِ مِ نَن كُي، 
\q1 كْنتْقِلِ، تْورّ، نُن بْحّ مَحَاشُي كُي. 
\p  
\v 17 نَ كُي ﭑ نَشَ عَ قَهَامُ عَ قَن عَدَ مَ بّ شَ عَ عَ دّفٍ، عَ عَ مِن، عَ سّيوَ عَ شَ وَلِ رَ، عَ نَشَن نَبَمَ دُنِحَ مَ عَ شَ سِمَيَ كُي، عَلَ نَشَن نَفِرِشِ عَ مَ نَ نَن قِندِشِ عَ شَ فٍينِ رَ.  
\v 18 شَ عَلَ عَ رَفِرِ مِشِ مَ عَ شَ هَرِفٍ سْتْ، عَ قَ سّيوَ نَ رَ هَن عَ وَ سَ، نَ بَرَ قِندِ عَلَ شَ كِ نَن نَ.  
\v 19 نَ كُي، عَ مُ كْنتْقِلِمَ عَ شَ سِمَيَ شَ دُنكٍ شَ قٍ رَ، بَرِ مَ عَلَ بَرَ عَ نِيَ عَ بْحّ شَ لُ سّيوّ كُي تُن. 
\c 6  
\s1 بَننَيَ نُن سّيوّ 
\p  
\v 1 ﭑ قٍ شْرْشْي فبّتّ نَن تٌ يِ دُنِحَ مَ؛  
\v 2 عَلَ بَننَيَ نُن بِنيّ رَفِرِشِ مِشِ ندٍ مَ هَن عَ وَ سَ نَ بِرِن نَ، كْنْ عَلَ قَ عَ نِيَ عَ مُ شَن عَ يِ، عَ قَ عَ لُ مِشِ فبّتّ يِ رَ. قٍ قُقَقُ نَن نَ كِ نَشَن شْرْشْ عَ فبٍ رَ. 
\p  
\v 3 هَلِ مِشِ دِ كّمّ سْتْ، عَ نَشَ سِمَيَ شْن كُيٍ سْتْ، شَ عَ مُ نْمَ سّيوَدٍ عَ هَرِفٍ رَ، حَمَ مُ قَ عَ رَفَتَ فَبُرِ كُي عَ رَفَتَ كِ مَ، دِيْرّ نَشَن بَشِ عَ نفَ قُرِ، نَ قِسَ نَ كَنيِ بّ.  
\v 4 نَ دِيْرّ مُ قِندِ مَ عَ رَ، عَ كٍلِمَ دِ مِ نَن كُي، عَ شِلِ يَتِ مُ قَلَمَ.  
\v 5 عَ مُ سٌفٍ شَ نَءِيَلَنيِ تٌشِ، عَ مُ سٍسٍ كٌلٌنشِ، كْنْ عَ شَ قٍ قِسَ نَ نَاقُلِ كَنيِ بّ،  
\v 6 هَلِ نَاقُلِ كَنيِ قَ لُ دُنِحَ مَ حّ وُلُ قِرِن سّيوّتَرٍحَ كُي. عٍ بِرِن مُ سِفَمَ عَلِفِيَمَ شّ؟ 
\q1  
\v 7 مِشِ شَ كَتّ بِرِن نَبَمَ قُرِ قٍ نَن مَ قٍ رَ، 
\q1 كْنْ عَ مُ وَ سَمَ قٍوٌ. 
\q1  
\v 8 مُنسٍ لُمَ شَشِلِمَ يِ رَ نَشَن مُ نَ شَشِلِتَرٍ يِ رَ؟ 
\q1 مُنسٍ لُمَ مِسِكِينّ بّ شَ عَ حّرّ كِ قَن عَ بٌورٍ يَ شْرِ؟ 
\q1  
\v 9 سٍ تٌشِ قِسَ مَحْشُنيِ بّ؟ 
\q1 قٍ قُقَقُ نَن نَ كِ 
\q1 نَشَن لُشِ عَلْ مِشِ نَشَن بِرَقٍ قٌيٍ قْشْ رَ. 
\b  
\q1  
\v 10 دَالِسٍ بِرِن حَن بَرَ شِلِ سْتْ، 
\q1 عَدَ مَ نَشَن نُ نَ، عَ حَن بَرَ كٌلٌن. 
\q1 عَدَ مَ مُ نْمَ مِشِ رَ نَشَن سّنبّ فبٌ عَ بّ. 
\q1  
\v 11 وْيّنيِ نَ فبٌ، قٍ قُقَقُ قَن فبٌمَ نّ. 
\q1 عَ مُ مِشِ يٌ مَلِمَ. 
\p  
\v 12 ندٍ عَ كٌلٌن قٍ نَشَن قَن عَدَ مَدِ بّ عَ شَ دُنِحّءِفِرِ كُي، نَشَن دَنفِمَ مَقُرٍن مَقُرٍن عَلْ نِينِ؟ ندٍ نْمَ عَ قَلَدٍ عَ بّ قٍ نَشَن نَبَمَ عَ قَشَ شَنبِ؟ 
\c 7  
\s1 شَشِلِ قَنيِ 
\q1  
\v 1 شِلِ قَنيِ قَن دَنفِ لَبُندّ قَنيِ رَ. 
\q1 عِ قَشَ لْشْي قَن دَنفِ عِ بَرِ لْشْي رَ. 
\q1  
\v 2 سٌقٍ كَاحّ بَنشِ قِسَ سٌقٍ شُلُن بَنشِ بّ، 
\q1 بَرِ مَ قَشّ رَفِرِشِ عَدَ مَ بِرِن بّ. 
\q1 عَ لَنمَ مِشِ بَلٌشِ شَ رَتُ نَ مَ. 
\q1  
\v 3 سُننُنيِ قِسَ يٍلٍ بّ، 
\q1 بَرِ مَ مِشِ بْحّ قَنيِ سْتْمَ نّ سُننُنيِ كُي. 
\q1  
\v 4 شَشِلِمَ عَ حْشْ رَ سِفَمَ نّ قَشّ مَ، 
\q1 شَشِلِتَرٍ تَن نَ يٍلٍقٍ نَن تُي. 
\q1  
\v 5 شَشِلِمَ شَ شُرُي قِسَ شَشِلِتَرٍ شَ مَتْشْي بّ. 
\q1  
\v 6 شَشِلِتَرٍ شَ يٍلٍ لُشِ نّ 
\q1 عَلْ بٌلٍيٍ نَشٍيٍ مَبُلَمَ تُندٍ بُن مَ. 
\q1 قٍ قُقَقُ نَن نَ كِ. 
\q1  
\v 7 كْبِرِ تِنشِنتَرٍ عَ نِيَمَ نّ شَشِلِمَ شَ قِندِ شَشِلِتَرٍ رَ، 
\q1 يٍ دْشْي عَ بْحّ مَقِندِ مَ نّ. 
\b  
\q1  
\v 8 قٍ رَحْنيِ قِسَ عَ قْلّ بّ. 
\q1 مِشِ سَبَرِشِ قِسَ يّتّ عِفبٌي بّ. 
\q1  
\v 9 عِ بْحّ نَشَ فبَتَ تٍدٍ، 
\q1 بَرِ مَ شَشِلِتَرٍيٍ بْحّ نَن تٍمَ. 
\b  
\q1  
\v 10 عِ نَشَ لُ عَ قَلَ رَ، «سِنفٍ دَنفِ يَكْسِ رَ.» 
\q1 شَشِلِمَيَ وْيّنيِ مُ نَ نَ رَ. 
\b  
\q1  
\v 11 شَشِلِمَيَ لُشِ نّ عَلْ كّ، 
\q1 عَ مُنَقَنيِ نَ دُنِحَ مِشِ بِرِن بّ. 
\q1  
\v 12 شَشِلِمَيَ قِندِشِ مِشِ شَ كَنتَرِ نَن نَ، 
\q1 كْبِرِ قَن قِندِشِ مِشِ شَ كَنتَرِ نَن نَ، 
\q1 كْنْ شَشِلِمَيَ نَن قِسَ، 
\q1 بَرِ مَ عَ شَشِلِمَ رَكِسِمَ. 
\q1  
\v 13 عَلَ شَ وَلِ مَتٌ. 
\q1 عَ نَشَن مَدَلِن، ندٍ نْمَ نَ مَتِنشِندٍ؟ 
\q1  
\v 14 عِ شَ سّيوَ هّيرِ تّمُي. 
\q1 تْورّ تّمُي نَ عَ لِ، عِ شَ رَتُ عَ مَ، 
\q1 عَ عَلَ نَن نَ قِرِنيِ بِرِن دَاشِ. 
\q1 نَ كُي عَدَ مَدِ مُ نْمَ عَ شَ تِنَ كٌلٌندٍ. 
\b  
\q1  
\v 15 ﭑ مَ سِمَيَ قُقَقُ كُي، 
\q1 ﭑ عَ تٌشِ نّ تِنشِنتْي ندٍ قَشَ سِمَيَ دُنكٍ كُي هَلِ عَ تٌ تِنشِنشِ، 
\q1 تِنشِنتَرٍ ندٍ بُ دُنِحَ هَلِ عَ تٌ مُ تِنشِن. 
\q1  
\v 16 عِ نَشَ عِ يّتّ قِندِ تِنشِنتْي رَ، 
\q1 عِ نَشَ عِ يّتّ قِندِ لْننِلَ رَ، 
\q1 شَ نَ مُ عَ رَ عِ عِ يّتّ كَنَمَ نّ. 
\q1  
\v 17 عِ نَشَ قِندِ تِنشِنتَرٍ رَ، 
\q1 شَ نَ مُ عَ رَ عِ قَشَمَ نّ بٍينُ عِ شَ وَشَتِ شَ عَ لِ. 
\q1  
\v 18 عَ لَنمَ عِ شَ عِ حْشْ سَ نَ مَرَ سِ قِرِنيِ شْن مَ. 
\q1 عَلَ شَ يَرَفَاشُي شَ قٍ سْونّيَمَ نّ نَ بِرِن كُي. 
\b  
\q1  
\v 19 شَشِلِمَ شَ شَشِلِمَيَ عَ سّنبّ فبٌمَ نّ دَنفِ تَا مَنفّ قُ رَ. 
\q1  
\v 20 تِنشِنتْي مُ نَ يِ دُنِحَ مَ، 
\q1 نَشَن قٍ قَنيِ تُن نَبَمَ، عَ مُ يُنُبِ يٌ رَبَ. 
\b  
\q1  
\v 21 عِ نَشَ عِ تُلِ مَتِ مِشِ شَ وْيّنيِ بِرِن نَ، 
\q1 شَ نَ مُ عَ رَ عِ قَمَ عِ شَ كٌنيِ شُي مّدٍ عَ عِ دَنكَمَ، 
\q1  
\v 22 عَلْ عِ تَن يَتِ بَرَ عَ رَبَ سَنيَ وُيَشِ مِشِيٍ رَ. 
\q1  
\v 23 ﭑ نَ بِرِن عِفبّشِ نّ شَشِلِمَيَ رَ. 
\q1 ﭑ نَشَ عَ قَلَ، «ﭑ شَ قِندِ شَشِلِمَ رَ،» 
\q1 كْنْ ﭑ مُ نْ. 
\q1  
\v 24 شَشِلِمَيَ تَن تِلِن، عَ مَكُيَ وٌن نَ، 
\q1 ندٍ نْمَ عَ قَهَامُدٍ؟ 
\q1  
\v 25 نَ كُي ﭑ نَشَ كَتَ نَ كٌلٌندٍ، 
\q1 ﭑ شَ سٌ شَشِلِمَيَ كُي، ﭑ شَ قَهَامُي سْتْ، 
\q1 ﭑ شَ عَ كٌلٌن تِنشِنتَرٍيَ قِندِشِ شَشِلِتَرٍحَ نَن نَ، 
\q1 شَشِلِتَرٍحَ قَن قِندِشِ دَشُحَ نَن نَ. 
\b  
\q1  
\v 26 ﭑ بَرَ قٍ ندٍ تٌ نَشَن شْنْ دَنفِ قَشّ رَ. 
\q1 فِنّ نَ عَ رَ نَشَن قِندِشِ يّلّ رَ، 
\q1 نَشَن بْحّ قِندِشِ فَنتَنيِ رَ، 
\q1 نَشَن بّلّشّيٍ لُشِ عَلْ لُوتِ بَلَنشِ. 
\q1 مِشِ نَشَن نَقَن عَلَ مَ، 
\q1 عَ كٍلِمَ نّ نَ فِنّ شُن مَ، 
\q1 كْنْ نَ فِنّ يُنُبِتْي نَن مَسْتْمَ. 
\q1  
\v 27 ﭑ تَن كَوَندِلَ يِ نَن تٌ ﭑ مَ قٍ مَتٌشِ بِرِن كُي؛ 
\q1  
\v 28 ﭑ نَشَ شّمّ تِنشِنشِ كٍرٍن تٌ شّمّ وُلُ يَ مَ، 
\q1 ﭑ نَشَ عَ قٍن هَن، 
\q1 كْنْ ﭑ مُ فِنّ يٌ تٌ حَمَ يَ مَ نَشَن تِنشِن. 
\q1  
\v 29 ﭑ يِ نَن فبَنسَن تٌ كْرّ؛ 
\q1 عَلَ عَدَ مَدِيٍ دَاشِ نّ عٍ تِنشِنشِ، 
\q1 كْنْ عٍ تَن نَشَ عٍ يّتّ مَدَشُ. 
\c 8  
\s1 شَشِلِمَيَ نُن مَنفّيَ 
\q1  
\v 1 شَشِلِمَ مَنِيّ مُ نَ. 
\q1 ندٍ قَتَ قٍ تِلِنشِ قَتَنقَسِدٍ؟ 
\q1 شَشِلِمَ يَتَفِ نْرْ مَ عَ شَ شَشِلِمَيَ سَابُي نَن نَ، 
\q1 عَ لَهَلّ مَسَرَ مَ نّ. 
\p  
\v 2 ﭑ شَ عَ قَلَ وٌ بّ، عَ لَنمَ وٌ شَ مَنفّ شَ يَامَرِ رَبَتُ، بَرِ مَ وٌ بَرَ وٌ رَكَلِ عَلَ يَ شْرِ.  
\v 3 عِ نَشَ فبَتَ كٍلِدٍ مَنفّ يَ شْرِ. عِ نَشَ تِ قٍقٍ شَنبِ رَ نَشَن مُ قَن. مَنفّ عَ وَشْنقٍ نَن نَبَمَ.  
\v 4 عَ لُ كِ يٌ كِ، نْي نَ مَنفّ نَن يِ. ندٍ نْمَ عَ مَتَندِدٍ؟ 
\q1  
\v 5 مِشِ نَشَن مَنفّ شَ يَمَرِ رَبَتُمَ، 
\q1 قٍ حَاشِ يٌ مُ عَ سْتْمَ. 
\q1 شَشِلِمَ عَ حّرّ كِ نُن حّرّ وَشَتِ كٌلٌن. 
\q1  
\v 6 قٍ بِرِن لَنمَ عَ شَ رَبَ عَ وَشَتِ نُن عَ كّحَ مَ، 
\q1 هَلِ نَ قَ قِندِ مَ قٍ شْرْشْي رَ مِشِ بّ. 
\b  
\q1  
\v 7 مِشِ تٌ مُ عَ كٌلٌن قٍ نَشٍيٍ قَمَ رَبَدٍ، 
\q1 ندٍ نْمَ نٍيٍ تَفِ رَبَدٍ عَ بّ؟ 
\q1  
\v 8 مِشِ يٌ مُ نْمَ عَ حّنفِ يَمَرِدٍ، 
\q1 مِشِ يٌ مُ نْمَ عَ قَشَ لْشْي سُفَندِدٍ. 
\q1 مِشِ مُ نْمَ كٍلِدٍ فٍرٍ شُن مَ، 
\q1 تِنشِنتَرٍيَ مُ قٍ كٌبِ رَبَيٍ بّحِنمَ. 
\p  
\v 9 ﭑ بَرَ يِ بِرِن رَكْرْ سِ دُنِحَ مَ. ﭑ نَشَ مِشِ تٌ عَ نَ عَ بٌورٍ يَمَرِقٍ، عَ قَ عَ يّتّ تْورْ نَ كُي.  
\v 10 ﭑ نَشَ مِشِ حَاشِيٍ تٌ نَشٍيٍ رَفَتَمَ بِنيّ كُي، مِشِيٍ نُ نَشٍيٍ مَتْشْمَ هْرْ مْلِنفِرَ يِرٍ تَا كُي. قٍ قُقَقُ نَن نَ كِ. 
\p  
\v 11 شَ قٍ كٌبِ رَبَيٍ مُ حَشَنكَتّ سْتْ عَ تّمُي، حَمَ قَن قَمَ نّ بِرَدٍ عٍ وَشْنقٍ حَاشِيٍ قْشْ رَ.  
\v 12 ﭑ عَ كٌلٌن هَلِ قٍ كٌبِ رَبَيٍ فبِلٍن قٍ حَاشِ رَبَقٍ رَ هَن سَنمَيَ كّمّ، سْونّيَ تَن نَبَمَ نّ مِشِ بّ نَشَن فَاشُمَ عَلَ يَ رَ، نَشَن لُمَ عَ بَتُ رَ.  
\v 13 كْنْ قٍ مُ سْونّيَمَ مِشِ حَاشِيٍ بّ نَشٍيٍ مُ فَاشُمَ عَلَ يَ رَ، عٍ شَ سِمَيَ شْن مُ كُيَمَ عَلْ مِشِ نِينِ. 
\p  
\v 14 قٍ قُقَقُ فبّتّ نَ نَ يِ دُنِحَ مَ؛ قٍ شْرْشْي نَشَن لَن عَ شَ دْشْ مِشِ حَاشِ مَ، نَ نَن دْشْمَ تِنشِنتْي مَ. قٍ قَنيِ نَشَن لَن عَ شَ رَبَ تِنشِنتْي بّ، نَ نَن نَبَمَ مِشِ حَاشِ بّ. ﭑ شَ عَ قَلَ وٌ بّ، نَ قٍ مْولِ قِندِشِ قٍ قُقَقُ نَن نَ.  
\v 15 نَ كُي عَ لَنمَ عَدَ مَ شَ سّيوَ عَ شَ دُنِحّءِفِرِ كُي. قٍ يٌ مُ نَ نَشَن قِسَ يِ بّ؛ مِشِ لَنمَ عٍ شَ عٍ دّفٍ، عٍ شَ عٍ مِن، عٍ شَ سّيوَ. نَ كِ عَ سّيوَ مَ نّ عَ شَ وَلِ رَ عَ شَ دُنِحّءِفِرِ كُي، عَلَ نَشَن قِشِ عَ مَ دُنِحَ بّندّ قُحِ قَرِ. 
\p  
\v 16 ﭑ تٌ نَتّ تٌنفٌ ﭑ شَ قَهَامُي سْتْ عَدَ مَدِ شَ وَلِ شَ قٍ رَ، عَ نَشَن نَبَمَ كْي نُن يَنيِ،  
\v 17 ﭑ نَشَ عَلَ شَ وَلِ مَتٌ. مِشِ يٌ مُ نْمَ سٌدٍ قٍ بِرِن كُي نَشَن نَبَمَ دُنِحَ مَ. هَلِ عَ كَتَ هَن، عَ مُ عَ كٌلٌنمَ قٍوٌ. هَلِ شَشِلِمَ نَشَن عَ قَلَمَ عَ بَرَ فّ نَ كٌلٌندٍ، عَ مُ نْمَ نَ كٌلٌندٍ يَتِ يَتِ. 
\c 9  
\s1 عَدَ مَدِ مُ يَرٍ كٌلٌن 
\p  
\v 1 ﭑ تٌ ﭑ مَحْشُن نَ قٍ بِرِن مَ، ﭑ عَ تٌشِ نّ تِنشِنتْييٍ، شَشِلِمَيٍ، نُن عٍ شَ كَتّ بِرِن كٍلِمَ عَلَ نَن مَ. عَدَ مَدِ مُ عَ كٌلٌن عَ قَمَ نَشَن لِدٍ عَ يَرَ، شَنُنتٍيَ شَ نَ مُ عَ رَ شْننَنتٍيَ. نَ بِرِن نَ عَلَ نَن يِ.  
\v 2 عَدَ مَدِ بِرِن سِفَمَ نّ عَلِفِيَمَ. تِنشِنتْي بَ، تِنشِنتَرٍ بَ، سّنِيّنتْي بَ، سّنِيّنتَرٍ بَ، سّرّشّبَ بَ، سّرّشّبَتَرٍ بَ. 
\q1 مِشِ قَنيِ بَ، مِشِ حَاشِ بَ 
\q1 عٍ بِرِن سِفَمَ نّ عَلِفِيَمَ. 
\q1 مِشِ نَشَن لَايِدِ تٌنفٌمَ بَ، 
\q1 مِشِ نَشَن مُ سُو سَمَ نَ تٌنفٌدٍ بَ، 
\q1 عٍ بِرِن سِفَمَ نّ عَلِفِيَمَ. 
\p  
\v 3 قٍ شْرْشْي نَن يِ كِ قٍ بِرِن يَ مَ دُنِحَ مَ؛ مَرَحْن كِ كٍرٍن نَن نَ نٍيٍ بِرِن بّ. عَدَ مَدِيٍ بْحّ رَقٍشِ قٍ حَاشِ نَن نَ، عٍ وَلِمَ شَشِلِتَرٍحَ نَن نَ عٍ شَ دُنِحّءِفِرِ كُي. نَ دَنفِ شَنبِ، عٍ قَشَمِشِيٍ لِمَ نّ عَلِفِيَمَ.  
\v 4 مِشِ بَلٌشِ فبَنسَن نْمَ عَ شَشِلِ تِدٍ قٍ ندٍ مَ. بَرٍ حِحّ قِسَ يّتّ قَشَشِ بّ. 
\q1  
\v 5 نَشٍيٍ بَلٌشِ، نٍيٍ عَ كٌلٌن عَ عٍ قَشَمَ نّ، 
\q1 كْنْ مِشِ قَشَشِيٍ تَن مُ قٍقٍ كٌلٌن. 
\q1 سَرٍ قِ يٌ مُ نَ عٍ بّ سْنْن، 
\q1 عٍ شَ قٍ يَتِ بَرَ نّيمُ مِشِيٍ رَ. 
\q1  
\v 6 عٍ شَ شَنُنتٍيَ، عٍ شَ شْننَنتٍيَ، عٍ وَشْنقٍ، نٍيٍ بِرِن بَرَ حْن. 
\q1 عٍ تَن فبٍ يٌ مُ نَ يِ دُنِحَ قٍيٍ تَن يَ مَ سْنْن. 
\p  
\v 7 سِفَ، عِ عِ دّفٍ سّيوّ كُي، عِ عِ شَ وّنِ مِن بْحّ قَنيِ كُي. عَلَ وَ مَ نَ نَن شْن عِ بّ.  
\v 8 عِ شَ سٌسٍ قِيشّ رَفٌرٌ عِ مَ، عِ شَ لَبُندّ قَنيِ سَ عِ قَتٍ مَ.  
\v 9 عِ شَ دُنِحَ عِفِرِ سّيوّ كُي وٌ نُن عِ شَنُنتٍنيِ فِنّ. عَلَ بَرَ يِ سِمَيَ نَن قِ عِ مَ. هَلِ عَ تٌ دَنفِمَ عَلْ قٌيٍ، هَلِ عَ شْرْشْ، عَلَ شَ مَرَفِرِ نَ عَ رَ عِ بّ.  
\v 10 عِ نْمَ وَلِ نَشَن نَ، عِ شَ نَ رَبَ عِ سّنبّ بِرِن نَ، بَرِ مَ عِ نَشَن نَبَمَ دُنِحَ مَ، عَلْ وَلِقٍ، قٍ مَتٌقٍ، قٍ قَهَامُقٍ، نُن قٍ كٌلٌنقٍ، نَ سٍسٍ مُ نَ عَلِفِيَمَ عِ سِفَقٍ دّننَشّ. 
\p  
\v 11 ﭑ مَن بَرَ قٍ فبّتّ تٌ يِ دُنِحَ مَ؛ 
\q1 نَشَن شُلُن دَنفِ عَ بٌورٍ رَ، عَ مُ فبَتَ فٍينِمَ تّمُي بِرِن شّ، 
\q1 نَشَن سّنبّ فبٌ دَنفِ عَ بٌورٍ رَ، عَ مُ فٍرٍ فٍينِمَ تّمُي بِرِن شّ، 
\q1 نَشَن شَشِلِ قَن عَ بٌورٍ بّ، عَ مُ دٌنسٍ سْتْمَ تّمُي بِرِن شّ، 
\q1 نَشَن مَ لْننِ دَنفِ عَ بٌورٍ رَ، عَ مُ نَاقُلِ سْتْمَ تّمُي بِرِن شّ، 
\q1 نَشَن شَ قَهَامُي فبٌ عَ بٌورٍ بّ، عَ مُ هِننّ سْتْمَ تّمُي بِرِن شّ. 
\q1 عَلَ شَ مَرَفِرِ تَن قٍ بِرِن نَبَمَ عَ وَشَتِ نّ. 
\p  
\v 12 مِشِ يٌ مُ عَ كٌلٌن قٍ قَمَ عَ لِدٍ تّمُي نَشّ؛ 
\q1 يّشّ سُشُمَ نّ يّلّ شْرْشْي كُي، 
\q1 شْنِ سُشُمَ نّ فَنتَنيِ رَ. 
\q1 نَ كِ قٍ شْرْشْي عَدَ مَدِ تّرّننَمَ نّ كٍرٍنيِ رَ. 
\p  
\v 13 ﭑ مَن بَرَ يِ شَشِلِمَيَ مِسَالِ تٌ دُنِحَ مَ نَشَن تِدٍ فبٌ.  
\v 14 تَا شُرِ ندٍ نُ نَ، مِشِ مُ نُ فبٌ دّننَشّ. مَنفّ سّنبّمَ ندٍ نَشَ نَ تَا فٍرٍ، عَ قَ تٍدٍ يَءِلَن نَ تَا تّتّ بُنيِ.  
\v 15 نَ تَاكَ ندٍ نُ نَ، نَشَن قِندِشِ سٍتَرٍ شَشِلِمَ رَ. عَ نَشَ نَ تَا رَكِسِ عَ شَ شَشِلِمَيَ سَابُي رَ، كْنْ نَ دَنفِ شَنبِ مِشِ يٌ مُ رَتُ عَ شَ قٍ مَ.  
\v 16 نَ كُي ﭑ نَشّ، 
\q1 شَشِلِمَيَ قِسَ حَلَمَيَ بّ، 
\q1 كْنْ سٍتَرٍ شَ شَشِلِمَيَ مَبٍرٍ مَ نّ، 
\q1 مِشِ مُ عَ شَ مَسٍنيِ سُشُمَ. 
\b  
\q1  
\v 17 شَشِلِمَ شَ مَسٍنيِ رَشَرَشِ رَ مّقٍ، 
\q1 نَ قِسَ مَنفّ شَ سْنشْي رَتٍ بّ شَشِلِتَرٍيٍ تَفِ. 
\q1  
\v 18 شَشِلِمَيَ قِسَ فٍرٍ سٌسٍيٍ بّ، 
\q1 كْنْ يُنُبِتْي كٍرٍن فبَنسَن نْمَ قٍ قَنيِ فبٍفبٍ شُن نَكَنَدٍ. 
\c 10  
\s1 تَالِ وْيّنيِ 
\q1  
\v 1 تُفِتُفِ نَ قَشَ لَبُندّ شُن مَ، لَبُندّ شِرِ كَنَمَ نّ. 
\q1 شَشِلِتَرٍحَ نَن شُي مّمَ دَنفِقٍ شَشِلِمَيَ شُي رَ. 
\b  
\q1  
\v 2 شَشِلِمَ بْحّ مَتِنسٍ، 
\q1 شَشِلِتَرٍ بْحّ حَاشُ. 
\q1  
\v 3 شَشِلِتَرٍ عَ شَ شَشِلِتَرٍحَ مَسٍنمَ نّ بِرِن بّ عَ شَ حّرّ كُي. 
\q1  
\v 4 شَ عِ شَ مَنفّ شْنْ عِ مَ، عِ نَشَ كٍلِ عِ شَ وَلِ شُن مَ، 
\q1 عِ شَ سَبَرِ قٍ شْرْشْي رَبْرْشْمَ. 
\b  
\p  
\v 5 ﭑ قٍ شْرْشْي ندٍ قَن تٌشِ يِ دُنِحَ مَ نَشَن كٍلِشِ مَنفّ مَ؛ 
\q1  
\v 6 عَ نْي قِمَ نّ شَشِلِتَرٍ ندٍ مَ، 
\q1 بَننَ ندٍ تَن مُ نْي يٌ سْتْ. 
\q1  
\v 7 ﭑ بَرَ كٌنيِ ندٍ تٌ عَ سٌي رَفِمَ، 
\q1 مَنفّ ندٍ قَ عَ حّرّ عَ سَنيِ رَ. 
\b  
\q1  
\v 8 يِلِ فٍ نْمَ بِرَدٍ عَ شَ يِلِ فٍشِ كُي، 
\q1 مِشِ نَشَن يَلٍ تِمَ تّتّ مَ، بْشِمَسٍ نْمَ نَ قَن شِندٍ. 
\q1  
\v 9 مِشِ نَشَن فّمّ مَسٌلِمَ، عَ نْمَ عَ مَشْنْدٍ فّمّ رَ. 
\q1 مِشِ نَشَن يٍفٍ بْو مَ، عَ نْمَ عَ مَشْنْدٍ يٍفٍ رَ. 
\q1  
\v 10 شَ بٍيرَ كٌلٍ تٌرِشِ، عَ مُ رَلُفَن، نَ عَ نِيَمَ نّ وَلِ شَ شْرْشْ. 
\q1 شَشِلِمَيَ شُننَكٍلِ قِمَ مِشِ مَ نَ كِ نّ. 
\q1  
\v 11 شَ بْشِمَسٍ مِشِ شِن بٍينُن بْشِمَسٍ سُشُمَ شَ عَ سُشُ، 
\q1 مِشِ نَشَن بْشِمَسٍ سُشُمَ، عَ مُ فٍينِمَ. 
\b  
\q1  
\v 12 هِننّ فبٍفبٍ نَ شَشِلِمَ شَ مَسٍنيِ كُي، 
\q1 كْنْ شَشِلِتَرٍ تَن شَ وْيّنيِ عَ يّتّ بْنْمَ نّ. 
\q1  
\v 13 عَ شَ مَسٍنيِ قْلْمَ لْننِتَرٍحَ رَ، 
\q1 عَ رَحْن دَشُحَ رَ. 
\q1  
\v 14 شَشِلِتَرٍ شَ وْيّنيِ وُيَ. 
\b  
\q1 عَدَ مَدِ مُ عَ كٌلٌن قٍ نَشَن قَمَ قَدٍ. 
\q1 ندٍ عَ رَكٌلٌنمَ قٍ رَ نَشَن قَمَ عَ لِدٍ؟ 
\b  
\q1  
\v 15 شَشِلِتَرٍ عَ يّتّ رَتَفَنمَ، 
\q1 هَلِ تَا كِرَ، عَ مُ عَ كٌلٌن. 
\b  
\q1  
\v 16 حَشَنكَتّ نَ تَا بّ نَشَن شَ مَنفّ قِندِشِ قٌنِكٍ يْرّ رَ، 
\q1 نَشَن شَ كُنتِفِيٍ كُرُنمَ شُلُنيِ تِقٍ رَ. 
\q1  
\v 17 حّلّشِنيِ نَ تَا بّ نَشَن شَ مَنفّ قَتَنشِ مَنفّ بْنسْي رَ، 
\q1 نَشَن شَ كُنتِفِيٍ عٍ دّفٍمَ عَ وَشَتِ مَ سّنبّ سْتْقٍ رَ، عٍ مُ سِيسِ. 
\b  
\q1  
\v 18 شَ بَنشِ كَنيِ تُننَشْنْ، بَنشِ شُنيِ بِرَ مَ نّ، 
\q1 شَ عَ مُ عَ قِندِ تُننَبّشِ رَ، عَ شَ بَنشِ قَمَ نّ مِنِدٍ. 
\q1  
\v 19 مِشِ دٌنسٍ رَقَلَمَ نّ عَلَكٌ عَ شَ حّلّشِن، 
\q1 عَ وّنِ مِنمَ نّ عَلَكٌ عَ شَ سّيوَ، 
\q1 عَ كْبِرِ سْتْمَ نّ عَلَكٌ عَ هَيِ بِرِن شَ قَن. 
\b  
\q1  
\v 20 عِ نَشَ مَنفّ دَنكَ هَلِ عِ شَ مَحْشُنيِ كُي، 
\q1 عِ نَشَ بَننَ دَنكَ هَلِ عِ شَ كٌنكٌي كُي، 
\q1 بَرِ مَ شْنِ ندٍ عِ شُي شَنِنمَ نّ، عَ نَ قَلَ مِشِ ندٍ بّ. 
\c 11  
\s1 وَكِلِقٍ 
\p  
\v 1 تَالِ ندٍيٍ نَن يِ كِ؛ 
\q1 شَ عِ تَامِ وٌلِ يٍ مَ، 
\q1 عِ قَمَ نّ عَ مَسْتْدٍ لْشْي ندٍ. 
\q1  
\v 2 عِ شَ عِ شَ سْتْسٍ تَشُ مِشِ سٌلٌقٍرٍ رَ، شَ نَ مُ عَ رَ، مِشِ سٌلٌمَسَشَن، 
\q1 بَرِ مَ عِ مُ عَ كٌلٌن حَشَنكَتّ نَشَن قَمَ دُنِحَ لِدٍ. 
\q1  
\v 3 شَ نُشُي رَقٍشِ يٍ رَ، 
\q1 تُنّ قَمَ نّ بِرَدٍ بْشِ مَ. 
\q1 شَ وُرِ بِرَ يِرٍ قَنيِ مَ، شَ عَ بِرَ كْولَ مَ، 
\q1 عَ لُمَ نَا نّ. 
\q1  
\v 4 مِشِ يٌ بْنبْ قٌيٍ رَبّنقٍ رَ، نَ مُ سَنسِ سِمَ. 
\q1 مِشِ يٌ بْنبْ نُشُي مَتٌقٍ رَ، نَ مُ قَمَ سَنسِ شَبَدٍ. 
\b  
\q1  
\v 5 عِ مُ حّنفِ نُن شْرِيٍ رَقَلَ كِ كٌلٌن قُرِ فِنّ قُرِ كُي، 
\q1 عِ مَن مُ عَلَ دَالِ مَنفّ شَ وَلِ قَن كٌلٌن. 
\b  
\q1  
\v 6 عِ شَ وَكِلِ كٍلِقٍ فّيسّفّ هَن نُنمَرٍ سَنسِ سِقٍ رَ، 
\q1 بَرِ مَ عِ مُ عَ كٌلٌن عِ شَ وَلِ مُندُن قَمَ سْونّيَدٍ. 
\b  
\q1  
\v 7 نَءِيَلَنيِ تٌقٍ حْشُن. 
\q1  
\v 8 عَ لَنمَ مِشِ شَ سّيوَ عَ شَ سِمَيَ رَ، 
\q1 كْنْ عَ نَشَ نّيمُ دِ مِ مَ نَشَن نُ نَ عَ شَ سِمَيَ كُي. 
\q1 قٍ نَشَن بِرِن قَمَ، قٍ قُقَقُ نَ عَ رَ. 
\b  
\q1  
\v 9 قٌنِكٍ، عِ شَ حّلّشِن عِ شَ قٌنِكٍيَ كُي، 
\q1 عِ سٌندٌنيِ شَ سّيوَ عِ شَ قٌنِكٍيَ وَشَتِ كُي. 
\q1 عِ شَ بِرَ عِ بْحّ نُن عِ وَشْنقٍ قْشْ رَ، 
\q1 كْنْ عِ شَ عَ كٌلٌن عَ عَلَ عِ مَكِيتِمَ نّ نَ بِرِن مَ. 
\q1  
\v 10 نَ كُي كْنتْقِلِ مَكُيَ عِ رَ، 
\q1 تْورّ كٍرِ عِ قْشْ رَ. 
\q1 قٌنِكٍيَ قِندِشِ قٍ قُقَقُ نَن نَ. 
\c 12  
\s1 قَشّ مَكْرّ 
\q1  
\v 1 عِ شَ رَتُ عِ دَالِ مَرِفِ مَ عِ شَ قٌنِكٍيَ كُي، 
\q1 بٍينُن عِ نِمِسَ لْشْي شَ قَ، 
\q1 بٍينُن تْورّ وَشَتِ شَ عِ لِ، عِ قَ عَ قَلَ، 
\q1 «سّيوّ يٌ مُ نَ ﭑ بّ سْنْن.» 
\q1  
\v 2 عِ شَ رَتُ عَ مَ بٍينُن سٌفٍ شَ دِ مِ، 
\q1 بٍينُن كِكٍ نُن تُنبُييٍ شَ عِقْورْ، 
\q1 بٍينُن نُشُي شَ سِفَ تُنّ بِرَ شَنبِ. 
\b  
\q1  
\v 3 نَ تّمُي بَنشِ كَنتّيٍ سّرّنمَ نّ، 
\q1 شّمّ حَلَمَيٍ عٍ قٍلٍنمَ نّ، 
\q1 مَالٍ دِنمَيٍ شُرُنمَ نّ، 
\q1 مِشِ نَشٍيٍ سٍ عِفبّمَ عٍ لُمَ نّ دِ مِ كُي، 
\q1  
\v 4 بَنشِ نَادّيٍ بَلَنمَ نّ، 
\q1 مَالٍ دِن شُي دَنمَ نّ، 
\q1 شْنِ شُي دُندُ مَ نّ نَشَن نُ مِشِيٍ رَشُنُمَ، 
\q1  
\v 5 شّمّ قَمَ نّ فَاشُدٍ يِرٍ عِتٍشِ رَ، 
\q1 عٍ قَمَ نّ فَاشُدٍ قٍ شْرْشْي رَ كِرَ شْن مَ، 
\q1 شّمْشِ شُنسّشّ قَمَ نّ قِيشّدٍ، 
\q1 كَتٌي بَمَ نّ كَسَرّ تِقٍ، 
\q1 سٍرِ مُ دَندَنيِ تِمَ سْنْن. 
\b  
\q1 نَ تّمُي مِشِ سِفَمَ نّ عَ شَ لِنفِرَ دْنشْي، 
\q1 وَ شُي مِنِمَ نّ كِرَيٍ شْن مَ. 
\q1  
\v 6 نَ رَبَمَ نّ بٍينُن فبٍتِ شَ بٌلٌن، 
\q1 بٍينُن شّيمَ تْنبِلِ شَ كَنَ، 
\q1 بٍينُن قّحّ شَ عِبْو دُلٌنيِ مَ، 
\q1 بٍينُن يٍ بّندُن سٍ شَ كَنَ كٌلٌنيِ يِرٍ، 
\q1  
\v 7 بٍينُن عَدَ مَدِ شَ فبِلٍن بّندّ عَ دَاشِ نَشّ، 
\q1 عَ نِي قَن شَ فبِلٍن عَلَ مَ نَشَن عَ رَ سٌ عَ قَتٍ عِ. 
\b  
\q1  
\v 8 ﭑ تَن كَوَندِلَ شَ عَ قَلَ وٌ بّ، 
\q1 «قٍ قُقَقُ نَن نَ نَ بِرِن نَ. عَ بِرِن لُشِ نّ عَلْ قٌيٍ!» 
\b  
\p  
\v 9 وٌ شَ عَ كٌلٌن يِ كَوَندِلَ قِندِشِ شَشِلِمَ نَن نَ، نَشَن بَرَ حَمَ شَرَن. عَ بَرَ تَالِيٍ مَتٌ، عَ عٍ يَءِلَن.  
\v 10 يِ كَوَندِلَ كَتَ نّ عَ شَ مَسٍنيِ قَنيِيٍ نُن سّبّلِ تِنشِنشِيٍ سْتْ نَشٍيٍ نْندِ مَسٍنمَ.  
\v 11 شَشِلِمَيٍ شَ مَسٍنيِيٍ لُشِ نّ عَلْ وُرِ رَ مٍلُشِ نَشٍيٍ شُرُ سٍيٍ رَحّرّ مَ. نَ مَسٍنيِيٍ مَلَنشِ لُشِ نّ عَلْ لَنتُمَ نَشٍيٍ مَبَنبَنشِ وُرِ مَ. نَ بِرِن قَتَنشِ شُرُ سٍ دّ مَدٌنيِ كٍرٍن نَن نَ. 
\p  
\v 12 ﭑ مَ دِ، نَشَن دَنفِ نَ مَسٍنيِيٍ رَ، عِ شَ عِ يّتّ رَتَنفَ نَ مَ. دَنيِ مُ نَ سّبّلِ يَءِلَنقٍ مَ. شَرَنيِ فبٍفبٍ مِشِ رَتَفَنمَ نّ. 
\q1  
\v 13 عَ بِرِن شُندُ سُشِ يِ مَسٍنيِ نَن نَ؛ 
\q1 وٌن شَ فَاشُ عَلَ يَ رَ، وٌن شَ عَ شَ يَامَرِيٍ رَبَتُ، 
\q1 بَرِ مَ عَدَ مَدِ شَ وَلِ لَنمَ عَ شَ قِندِ نَ نَن نَ. 
\q1  
\v 14 وٌن شَ فَاشُ عَلَ يَ رَ بَرِ مَ عَ تَن نَن مِشِ شَ وَلِ بِرِن مَكِيتِمَ، 
\q1 هَلِ قٍ نَشَن بِرِن نْشُنشِ، 
\q1 عَ قِندِ عَ قَنيِ رَ بَ، عَ قِندِ عَ حَاشِ رَ بَ.