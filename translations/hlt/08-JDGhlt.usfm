\v 19 \w A|strong="H9907"\w* \w khuklu|strong="H1290"\w* \w dongah|strong="H5921"\w* \w Samson|strong="H9909"\w* a \w soei|strong="H3463"\w* \w tih|strong="H9999"\w* \w hlang|strong="H0376"\w* a \w khue|strong="H7121"\w*. \w Samson|strong="H9909"\w* \w lu|strong="H7218"\w* dongkah \w samtum|strong="H4253"\w* \w parhih|strong="H7651"\w* \w te|strong="H0853"\w* a \w vok|strong="H1548"\w* pah \w tih|strong="H9999"\w* \w Samson|strong="H9909"\w* te \w phaep|strong="H6031"\w* \w ham|strong="H9997"\w* te a \w poeih|strong="H2490"\w*. Te \w dongah|strong="H9999"\w* \w a|strong="H9909"\w* \w thadueng|strong="H3581"\w* khaw \w Samson|strong="H9909"\w* \w dong|strong="H5921"\w* \w lamloh|strong="H4480"\w* viik \w nong|strong="H5493"\w*.  
\v 20 Te \w vaengah|strong="H9999"\w*, “\w Samson|strong="H8123"\w*, \w na|strong="H9905"\w* pum \w dongkah|strong="H5921"\w* \w Philisti|strong="H6430"\w* rhoek te,” a \w ti|strong="H0559"\w* nah \w tih|strong="H9999"\w* \w a|strong="H9909"\w* \w ih|strong="H8142"\w* \w lamkah|strong="H4480"\w* \w haenghang|strong="H3364"\w*. A \w noek|strong="H6471"\w* \w noek|strong="H6471"\w* \w vaengkah|strong="H9996"\w* \w bangla|strong="H9995"\w* ka \w thoo|strong="H3318"\w* \w vetih|strong="H9999"\w* ka \w khoek|strong="H5287"\w* bitni a \w ti|strong="H0559"\w*. \w Tedae|strong="H9999"\w* \w anih|strong="H9909"\w* \w taeng|strong="H5921"\w* \w lamloh|strong="H4480"\w* \w BOEIPA|strong="H3068"\w* a \w nong|strong="H5493"\w* \w te|strong="H3588"\w* \w amah|strong="H1931"\w* loh \w ming|strong="H3045"\w* \w pawh|strong="H3808"\w*.   
\s1 Samson kah a Dueknah  
\p
\v 21 Te \w dongah|strong="H9999"\w* \w Samson|strong="H9909"\w* te \w Philisti|strong="H6430"\w* rhoek loh a \w tuuk|strong="H0270"\w* uh \w tih|strong="H9999"\w* \w a|strong="H9909"\w* \w mik|strong="H5869"\w* a \w koeih|strong="H5365"\w* pa uh. \w Gaza|strong="H5804"\w* \w la|strong="H9911"\w* a \w suntlak|strong="H3381"\w* puei uh \w tih|strong="H9999"\w* \w rhohum|strong="H5178"\w* \w neh|strong="H9996"\w* a \w khih|strong="H0631"\w* uh. Te \w dongah|strong="H9999"\w* Samson tah \w thongtla|strong="H0615"\w* \w im|strong="H1003"\w* \w ah|strong="H9996"\w* sum aka \w kuelh|strong="H2912"\w* la a \w khih|strong="H0631"\w* uh.  
