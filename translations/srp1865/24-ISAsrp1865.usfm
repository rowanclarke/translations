\id ISA
\h Knjiga proroka Isaije
\toc1 Knjiga proroka Isaije
\toc2 Isaija
\toc3 Isa
\mt1 Knjiga proroka Isaije
\c 1
\s1 Izrailjevo otpadništvo i kazna. Pozivanje da se uistini obrati Bogu, a ne samo da prinosi žrtve. Obricanje i pretnja.
\p 
\v 1 Utvara Isaije sina Amosovog, koju vide za Judu i za Jerusalim za vremena Ozije, Joatama, Ahaza i Jezekije, careva Judinih.
\b
\q1 
\v 2 Čujte, nebesa, i slušaj, zemljo;
\q2 jer Gospod govori:
\q1 Sinove odgojih i podigoh,
\q2 a oni se okrenuše od mene.
\q1 
\v 3 Vo poznaje gospodara svog
\q2 i magarac jasle gospodara svog,
\q1 a Izrailj ne poznaje,
\q2 narod moj ne razume.
\b
\q1 
\v 4 Da grešnog naroda!
\q2 Naroda ogrezlog u bezakonju!
\q1 Semena zlikovačkog,
\q2 sinova pokvarenih!
\q1 Ostaviše Gospoda,
\q2 prezreše Sveca Izrailjevog,
\q2 odstupiše natrag.
\b
\q1 
\v 5 Što biste još bili bijeni
\q2 kad se sve više odmećete?
\q2 Sva je glava bolesna i sve srce iznemoglo.
\q1 
\v 6 Od pete do glave nema ništa zdravo,
\q2 nego uboj i modrice i rane gnojave,
\q2 ni isceđene ni zavijene ni uljem zablažene.
\b
\q1 
\v 7 Zemlja je vaša pusta,
\q2 gradovi vaši ognjem popaljeni;
\q1 vaše njive jedu tuđini na vaše oči,
\q2 i pustoš je kao što opustošavaju tuđini.
\q1 
\v 8 I osta kći sionska kao koliba u vinogradu,
\q2 kao senica u gradini od krastavaca,
\q2 kao grad opkoljen.
\b
\q1 
\v 9 Da nam Gospod nad vojskama nije ostavio malo ostatka,
\q2 bili bismo kao Sodom, izjednačili bismo se s Gomorom.
\b
\q1 
\v 10 Čujte reč Gospodnju, knezovi sodomski,
\q2 poslušajte zakon Boga našeg, narode gomorski!
\q1 
\v 11 Šta će mi mnoštvo žrtava vaših?
\q2 Veli Gospod.
\q1 Sit sam žrtava paljenica od ovnova
\q2 i pretiline od gojene stoke,
\q2 i ne marim za krv junčiju i jagnjeću i jareću.
\b
\q1 
\v 12 Kad dolazite da se pokažete preda mnom,
\q2 ko ište to od vas, da gazite po mom tremu?
\q1 
\v 13 Ne prinosite više žrtve zaludne;
\q2 na kad gadim se;
\q1 a o mladinama i subotama i o sazivanju skupštine
\q2 ne mogu podnositi bezakonja i svetkovine.
\q1 
\v 14 Na mladine vaše i na praznike vaše mrzi duša moja,
\q2 dosadiše mi, dodija mi podnositi.
\q1 
\v 15 Zato kad širite ruke svoje,
\q2 zaklanjam oči svoje od vas;
\q1 i kad množite molitve,
\q2 ne slušam;
\q2 ruke su vaše pune krvi.
\q1 
\v 16 Umijte se, očistite se,
\q2 uklonite zloću dela svojih ispred očiju mojih,
\q2 prestanite zlo činiti.
\q1 
\v 17 Učite se dobro činiti,
\q2 tražite pravdu,
\q1 ispravljajte potlačenog,
\q2 dajite pravicu sirotoj,
\q2 branite udovicu.
\b
\q1 
\v 18 Tada dođite, veli Gospod,
\q2 pa ćemo se suditi:
\q1 ako gresi vaši budu kao skerlet,
\q2 postaće beli kao sneg;
\q1 ako budu crveni kao crvac,
\q2 postaće kao vuna.
\q1 
\v 19 Ako hoćete slušati,
\q2 dobro zemaljsko ješćete.
\q1 
\v 20 Ako li nećete, nego budete nepokorni,
\q2 mač će vas pojesti,
\q2 jer usta Gospodnja rekoše.
\b
\q1 
\v 21 Kako posta kurva verni grad?
\q2 Pun beše pravice,
\q1 pravda nastavaše u njemu,
\q2 a sada krvnici.
\q1 
\v 22 Srebro tvoje posta troska,
\q2 vino tvoje pomeša se s vodom.
\q1 
\v 23 Knezovi su tvoji odmetnici
\q2 i drugovi lupežima;
\q2 svaki miluje mito i ide za darovima;
\q1 sirotoj ne daju pravice,
\q2 i parnica udovička ne dolazi pred njih.
\b
\q1 
\v 24 Zato govori Gospod, Gospod nad vojskama,
\q2 silni Izrailjev:
\q1 Aha! Razračunaću se sa protivnicima svojim,
\q2 i osvetiću se neprijateljima svojim.
\q1 
\v 25 I okrenuću ruku svoju na te,
\q2 i sažeći ću troske tvoje da te prečistim,
\q2 i ukloniću sve olovo tvoje.
\q1 
\v 26 I postaviću ti opet sudije kao pre,
\q2 i savetnike kao ispočetka;
\q1 tada ćeš se zvati grad pravedni,
\q2 grad verni.
\b
\q1 
\v 27 Sion će se otkupiti sudom,
\q2 i pravdom oni koji se u nj vrate.
\q1 
\v 28 A odmetnici i grešnici svi će se satrti,
\q2 i koji ostavljaju Gospoda, izginuće.
\q1 
\v 29 Jer ćete se posramiti od gajeva koje želeste,
\q2 i zastideti se od vrtova koje izabraste.
\q1 
\v 30 Jer ćete biti kao hrast kome opada lišće
\q2 i kao vrt u kome nema vode.
\q1 
\v 31 I biće junak kao kučine
\q2 i delo njegovo kao iskra,
\q1 i oboje će se zapaliti,
\q2 i neće biti nikoga da ugasi.
\c 2
\s1 Iz Siona dolazi spas i mir svim narodima; ali će se najpre suditi Izrailju koji se klanja idolima.
\p 
\v 1 Reč koja dođe u utvari Isaiji sinu Amosovom za Judu i za Jerusalim.
\b
\q1 
\v 2 Biće u potonja vremena gora doma Gospodnjeg
\q2 utvrđena uvrh gora i uzvišena iznad humova,
\q2 i sticaće se k njoj svi narodi.
\q1 
\v 3 I ići će mnogi narodi govoreći:
\q2 Hodite da idemo na goru Gospodnju,
\q2 u dom Boga Jakovljevog,
\q1 i učiće nas svojim putevima,
\q2 i hodićemo stazama Njegovim.
\q1 Jer će iz Siona izaći zakon,
\q2 i reč Gospodnja iz Jerusalima.
\q1 
\v 4 I sudiće među narodima,
\q2 i karaće mnoge narode,
\q1 te će raskovati mačeve svoje na raonike,
\q2 i koplja svoja na srpove,
\q1 neće dizati mača narod na narod,
\q2 niti će se više učiti boju.
\b
\q1 
\v 5 Dome Jakovljev,
\q2 hodi da idemo po svetlosti Gospodnjoj.
\b
\q1 
\v 6 Ali si ostavio svoj narod, dom Jakovljev,
\q2 jer su puni zala istočnih
\q1 i gataju kao Filisteji,
\q2 i mili su im sinovi tuđinski.
\q1 
\v 7 I zemlja je njihova puna srebra i zlata,
\q2 i blagu njihovom nema kraja;
\q1 zemlja je njihova puna konja,
\q2 i kolima njihovim nema kraja.
\q1 
\v 8 Puna je zemlja njihova idola;
\q2 delu ruku svojih klanjaju se,
\q2 što načiniše prsti njihovi.
\q1 
\v 9 I klanjaju se prosti ljudi, i savijaju se glavni ljudi;
\q2 nemoj im oprostiti.
\q1 
\v 10 Uđi u stenu, i sakrij se u prah
\q2 od straha Gospodnjeg i od slave veličanstva Njegovog.
\q1 
\v 11 Ponosite oči čovečje poniziće se,
\q2 i visina ljudska ugnuće se,
\q2 a Gospod će sam biti uzvišen u onaj dan.
\b
\q1 
\v 12 Jer će doći dan Gospoda nad vojskama
\q2 na sve ohole i ponosite
\q1 i na svakog koji se podiže,
\q2 te će biti poniženi,
\q1 
\v 13 I na sve kedre livanske
\q2 velike i visoke
\q2 i na sve hrastove vasanske,
\q1 
\v 14 I na sve gore visoke
\q2 i na sve humove izdignute,
\q1 
\v 15 I na svaku kulu visoku
\q2 i na svaki zid tvrdi,
\q1 
\v 16 I na sve lađe tarsiske
\q2 i na sve likove mile.
\q1 
\v 17 Tada će se ponositost ljudska ugnuti
\q2 i visina se ljudska poniziti,
\q2 i Gospod će sam biti uzvišen u onaj dan.
\q1 
\v 18 I idola će nestati sasvim.
\q1 
\v 19 I ljudi će ići u pećine kamene
\q2 i u rupe zemaljske
\q1 od straha Gospodnjeg
\q2 i od slave veličanstva Njegovog,
\q2 kad ustane da potre zemlju.
\b
\q1 
\v 20 Tada će baciti čovek idole svoje srebrne i idole svoje zlatne,
\q1 koje načini sebi da im se klanja,
\q2 krticama i slepim miševima,
\q1 
\v 21 Ulazeći u raseline kamene
\q2 i u pećine kamene
\q1 od straha Gospodnjeg
\q2 i od slave veličanstva Njegovog,
\q2 kad ustane da potre zemlju.
\q1 
\v 22 Prođite se čoveka, kome je dah u nosu;
\q2 jer šta vredi?
\c 3
\s1 Sud zbog greha narodnih i zbog ženske taštine.
\q1 
\v 1 Jer gle, Gospod, Gospod nad vojskama
\q2 uzeće Jerusalimu i Judi potporu i pomoć,
\q2 svaku potporu u hlebu i svaku potporu u vodi,
\q1 
\v 2 Junaka i vojnika,
\q2 sudiju i proroka
\q2 i mudraca i starca,
\q1 
\v 3 Pedesetnika i uglednog čoveka,
\q2 i savetnika i veštog umetnika i čoveka rečitog.
\q1 
\v 4 I daću im knezove mladiće,
\q2 i deca će im biti gospodari.
\q1 
\v 5 I činiće silu u narodu jedan drugom
\q2 i svaki bližnjem svom;
\q1 dete će ustajati na starca
\q2 i nepošten čovek na poštenog.
\b
\q1 
\v 6 I čovek će uhvatiti brata svog iz kuće oca svog govoreći:
\q2 Imaš haljinu, budi nam knez,
\q2 ovaj rasap neka je pod tvojom rukom.
\q1 
\v 7 A on će se zakleti u onaj dan govoreći:
\q2 Neću biti lekar,
\q1 niti imam kod kuće hleba ni haljinu,
\q2 ne postavljajte me knezom narodu.
\q1 
\v 8 Jer se obori Jerusalim i Juda pade,
\q2 jer se jezik njihov i dela njihova protive Gospodu
\q2 da draže oči slave Njegove.
\b
\q1 
\v 9 Šta se vidi na licu njihovom svedoči na njih,
\q2 razglašuju greh svoj kao Sodom, ne taje;
\q1 teško duši njihovoj!
\q2 Jer sami sebi čine zlo.
\q1 
\v 10 Recite pravedniku da će mu dobro biti,
\q2 jer će jesti plod od dela svojih.
\q1 
\v 11 Teško bezbožniku! Zlo će mu biti,
\q2 jer će mu se naplatiti ruke njegove.
\q1 
\v 12 Narodu mom čine silu deca,
\q2 i žene su im gospodari.
\q1 Narode moj!
\q2 Koji te vode, zavode te,
\q2 i kvare put hoda tvog.
\b
\q1 
\v 13 Ustaje Gospod na parbu,
\q2 stoji da sudi narodima.
\q1 
\v 14 Gospod će doći na sud
\q2 sa starešinama naroda svog
\q2 i s knezovima njegovim,
\q1 jer vi potrste vinograd,
\q2 grabež od siromaha u vašim je kućama.
\q1 
\v 15 Zašto gazite narod moj
\q2 i lice siromasima satirete?
\q2 Govori Gospod, Gospod nad vojskama.
\b
\q1 
\v 16 Još govori Gospod:
\q2 Što se poneše kćeri sionske
\q1 i idu opruženog vrata i namigujući očima,
\q2 sitno koračaju i zvekeću nogama,
\q1 
\v 17 Zato će Gospod učiniti da oćelavi teme kćerima sionskim,
\q2 i otkriće Gospod golotinju njihovu.
\b
\p 
\v 18 Tada će Gospod skinuti nakit s obuće i vezove i mesečiće,
\v 19 nizove i lančiće i trepetljike,
\v 20 ukosnike i podveze i pojase i stakalca mirisna i oboce,
\v 21 prstene i počeonike,
\v 22 svečane haljine i ogrtače i privese i toboce,
\v 23 i ogledala i košuljice i oglavlja i pokrivala.
\b
\q1 
\v 24 I mesto mirisa biće smrad,
\q2 i mesto pojasa raspojasina,
\q1 mesto pletenica ćela,
\q2 mesto širokih skuta pripasana vreća,
\q2 i mesto lepote ogorelina.
\q1 
\v 25 Tvoji će ljudi pasti od mača
\q2 i junaci tvoji u ratu.
\q1 
\v 26 I tužiće i plakaće vrata njegova,
\q2 a on će pust ležati na zemlji.
\c 4
\s1 O mesijskom spasenju.
\p 
\v 1 I u ono vreme sedam će žena uhvatiti jednog čoveka govoreći: Svoj ćemo hleb jesti i svoje ćemo odelo nositi, samo da se zovemo tvojim imenom, skini s nas sramotu.
\b
\p 
\v 2 U ono vreme biće klica Gospodnja na slavu i čast, i plod zemaljski na krasotu i diku ostatku Izrailjevom.
\v 3 I ko ostane u Sionu i ko još bude u Jerusalimu, zvaće se svet, svaki ko bude zapisan za život u Jerusalimu,
\v 4 kad Gospod opere nečistoću kćeri sionskih, i iz Jerusalima očisti krv njegovu Duhom koji sudi i sažiže.
\v 5 Gospod će stvoriti nad svakim stanom na gori sionskoj i nad zborovima njenim oblak danju s dimom i svetlost plamena ognjenog noću, jer će nad svom slavom biti zaklon.
\v 6 I biće koliba, da senom zaklanja danju od vrućine i da bude utočište i zaklon od poplave i od dažda.
\c 5
\s1 Priča o nerodnom vinogradu Gospodnjem. Pretnja Božijim sudom, osobito neprijateljskim upadom.
\q1 
\v 1 Zapevaću sada dragom svom
\q2 pesmu dragog svog o vinogradu njegovom.
\q1 Dragi moj ima vinograd na rodnom brdašcetu.
\q1 
\v 2 I ogradi ga, i otrebi iz njega kamenje,
\q2 i nasadi ga plemenitom lozom,
\q1 i sazida kulu usred njega,
\q2 i iskopa pivnicu u njemu,
\q1 i počeka da rodi grožđem,
\q2 a on rodi vinjagom.
\b
\q1 
\v 3 Pa sada, stanovnici jerusalimski
\q2 i ljudi Judejci,
\q1 sudite između mene i vinograda mog.
\q1 
\v 4 Šta je još trebalo činiti vinogradu mom
\q2 šta mu ne učinih?
\q1 Kad čekah da rodi grožđem,
\q2 zašto rodi vinjagom?
\b
\q1 
\v 5 Sada ću vam kazati šta ću učiniti vinogradu svom.
\q2 Oboriću mu ogradu, neka opusti;
\q2 razvaliću mu zid, neka se pogazi;
\q1 
\v 6 Uparložiću ga, neće se rezati ni kopati,
\q2 nego će rasti čkalj i trnje,
\q1 i zapovediću oblacima da ne puštaju više dažd na nj.
\b
\q1 
\v 7 Da, vinograd je Gospoda nad vojskama dom Izrailjev,
\q2 i ljudi su Judejci mili sad Njegov;
\q1 On čeka sud, a gle nasilja,
\q2 čeka pravdu, a gle vike.
\b
\q1 
\v 8 Teško onima koji sastavljaju kuću s kućom,
\q2 i njivu na njivu nastavljaju,
\q1 da već ne bude mesta
\q2 i vi sami ostanete u zemlji.
\q1 
\v 9 Od Gospoda nad vojskama čuh:
\q2 Mnoge kuće opusteće,
\q1 u velikim i lepim neće biti nikoga.
\q1 
\v 10 Jer će deset rala vinograda dati jedan vat,
\q2 i gomer semena daće efu.
\b
\q1 
\v 11 Teško onima koji rane, te idu na silovito piće
\q2 i ostaju do mraka dok ih vino raspali.
\q1 
\v 12 I na gozbama su im gusle i psaltiri
\q2 i bubnji i svirale i vino;
\q1 a ne gledaju na dela Gospodnja
\q2 i ne vide rad ruku Njegovih.
\b
\q1 
\v 13 Zato se narod moj odvede u ropstvo
\q2 što ne znaju,
\q1 i koje poštuje gladuju,
\q2 i ljudstvo njegovo gine od žeđi.
\q1 
\v 14 Zato se raširio grob
\q2 i razvalio ždrelo svoje preveć,
\q1 i sići će u nj slava njegova i mnoštvo njegovo
\q2 i vreva njegova i koji se vesele u njemu.
\q1 
\v 15 I pognuće se prost čovek,
\q2 i visoki će se poniziti,
\q2 i ponosite oči oboriće se;
\q1 
\v 16 Gospod nad vojskama uzvisiće se sudom,
\q2 i Bog Sveti posvetiće se pravdom.
\q1 
\v 17 I jaganjci će pasti po svom običaju,
\q2 i došljaci će jesti s pustih mesta pretilinu.
\b
\q1 
\v 18 Teško onima koji vuku bezakonje uzicama od taštine,
\q2 i greh kao užem kolskim,
\q1 
\v 19 Koji govore: Neka pohita,
\q2 neka brzo dođe delo Njegovo,
\q2 da vidimo,
\q1 i neka se približi
\q2 i dođe šta je naumio Svetac Izrailjev,
\q2 da poznamo.
\q1 
\v 20 Teško onima koji zlo zovu dobro,
\q2 a dobro zlo,
\q1 koji prave od mraka svetlost,
\q2 a od svetlosti mrak,
\q1 koji prave od gorkog slatko
\q2 a od slatkog gorko.
\q1 
\v 21 Teško onima koji misle da su mudri,
\q2 i sami su sebi razumni.
\q1 
\v 22 Teško onima koji su jaki piti vino
\q2 i junaci u mešanju silovitog pića.
\q1 
\v 23 Koji pravdaju bezbožnika za poklon,
\q2 a pravednima uzimaju pravdu.
\b
\q1 
\v 24 Zato kao što oganj proždire strnjiku
\q2 i slama nestaje u plamenu,
\q1 tako će koren njihov biti kao trulež
\q2 i cvet njihov otići će kao prah,
\q1 jer odbaciše zakon Gospoda nad vojskama
\q2 i prezreše reč Sveca Izrailjevog.
\q1 
\v 25 Zato se raspali gnev Gospodnji na narod Njegov,
\q2 i mahnuv rukom svojom na nj udari ga da se gore zadrmaše
\q2 i mrtva telesa njegova biše kao blato po ulicama.
\q1 Kod svega toga gnev se Njegov ne odvrati,
\q2 nego je ruka Njegova još podignuta.
\b
\q1 
\v 26 I podignuće zastavu narodima dalekim,
\q2 i zazviždaće im s kraja zemlje;
\q2 i gle, oni će doći odmah, brzo.
\q1 
\v 27 Neće biti među njima umornog ni sustalog,
\q2 ni dremljivog ni sanjivog,
\q1 nikome se neće raspasati pojas oko njega,
\q2 niti će se kome otkinuti remen na obući.
\q1 
\v 28 Strele će im biti oštre,
\q2 i svi lukovi njihovi zapeti;
\q1 kopita u konja njihovih biće kao kremen
\q2 i točkovi njihovi kao vihor.
\q1 
\v 29 Rika će im biti kao u lava,
\q2 i rikaće kao lavići;
\q1 bučaće i ugrabiće plen i odneti ga,
\q2 i neće biti nikoga da otme.
\q1 
\v 30 Bučaće nad njim u to vreme kao što more buči.
\q1 Tada će pogledati na zemlju,
\q2 a to mrak i strah,
\q2 i svetlost će se pomračiti nad pogiblju njihovom.
\c 6
\s1 Isaijino viđenje slave Gospodnje i pozivanje da prorokuje.
\p 
\v 1 Godine koje umre car Ozija videh Gospoda gde sedi na prestolu visokom i izdignutom, i skut Mu ispunjavaše crkvu.
\v 2 Serafimi stajahu više Njega, svaki ih imaše šest krila: dvema zaklanjaše lice svoje i dvema zaklanjaše noge svoje, a dvema leteše.
\v 3 I vikahu jedan drugom govoreći:
\b
\q1 Svet, svet, svet je Gospod nad vojskama;
\q2 puna je sva zemlja slave Njegove.
\b
\p 
\v 4 I zadrmaše se pragovi na vratima od glasa kojim vikahu, i dom se napuni dima.
\v 5 I rekoh: Jao meni! Pogiboh, jer sam čovek nečistih usana, i živim usred naroda nečistih usana, jer Cara Gospoda nad vojskama videh svojim očima.
\p 
\v 6 A jedan od serafima dolete k meni držeći u ruci živ ugljen, koji uze s oltara kleštima,
\v 7 i dotače se usta mojih, i reče: Evo, ovo se dotače usta tvojih, i bezakonje tvoje uze se, i greh tvoj očisti se.
\b
\p 
\v 8 Potom čuh glas Gospodnji gde reče: Koga ću poslati? I ko će nam ići? A ja rekoh: Evo mene, pošalji mene.
\v 9 A On reče: Idi, i reci tom narodu:
\b
\q1 Slušajte ali nećete razumeti,
\q2 gledajte ali nećete poznati.
\q1 
\v 10 Učini da odeblja srce tom narodu
\q2 i uši da im otežaju,
\q2 i oči im zatvori,
\q1 da ne vide očima svojim
\q2 i ušima svojim da ne čuju
\q2 i srcem svojim da ne razumeju
\q1 i ne obrate se i ne iscele.
\q1 
\v 11 A ja rekoh:
\q2 Dokle, Gospode?
\q1 A On reče:
\q2 Dokle ne opuste gradovi da budu bez stanovnika
\q1 i kuće da budu bez ljudi,
\q2 i zemlja dokle sasvim ne opusti,
\q1 
\v 12 I dokle Gospod opravi daleko ljude
\q2 i bude sama pustoš u zemlji.
\q1 
\v 13 Ali će još biti u njoj desetina,
\q2 pa će se i ona zatrti;
\q1 ali kao hrast ili brest,
\q2 kojima i kad zbace lišće ostaje stablo,
\q1 tako će sveto seme biti njeno stablo.
\c 7
\s1 Jerusalim u nevolji zbog Siraca i Izrailjaca. Utešno obricanje Emanuila. Kazna preko Asiraca.
\p 
\v 1 U vreme Ahaza sina Jotama sina Ozije cara Judinog dođe Resin car sirski i Fakej sin Remalijin car Izrailjev na Jerusalim da ga biju, ali ga ne mogoše uzeti.
\v 2 I dođe glas domu Davidovom i rekoše: Sirija se složi s Jefremom. A srce Ahazovo i srce naroda njegovog ustrepta kao drveće u šumi od vetra.
\p 
\v 3 Tada reče Gospod Isaiji: Izađi na susret Ahazu, ti i Sear-jasuv, sin tvoj, nakraj jaza gornjeg jezera, na put kod polja beljarevog.
\v 4 I reci mu: Čuvaj se i budi miran, ne boj se i srce tvoje neka se ne plaši od dva kraja ovih glavnji što se puše, od raspaljenog gneva Resinovog i sirskog i sina Remalijinog.
\v 5 Što se Sirci i Jefrem i sin Remalijin dogovoriše na tvoje zlo govoreći:
\v 6 Hajdemo na judejsku da joj dosadimo i da je osvojimo i da postavimo u njoj carem sina Taveilovog.
\v 7 Zato ovako veli Gospod Bog:
\b
\q1 Neće se to učiniti,
\q2 neće biti.
\q1 
\v 8 Jer je glava Siriji Damask,
\q2 a Damasku je glava Resin;
\q1 i do šezdeset i pet godina satrće se Jefrem
\q2 tako da više neće biti narod.
\q1 
\v 9 I glava je Jefremu Samarija,
\q2 a Samariji je glava sin Remalijin.
\q1 Ako ne verujete, nećete se održati.
\b
\p 
\v 10 I još reče Gospod Ahazu govoreći:
\v 11 Išti znak od Gospoda Boga svog, išti ozdo iz dubine ili ozgo s visine.
\v 12 A Ahaz reče: Neću iskati, niti ću kušati Gospoda.
\v 13 Tada reče Isaija: Slušajte sada, dome Davidov; malo li vam je što dosađujete ljudima, nego dosađujete i Bogu mom?
\v 14 Zato će vam sam Gospod dati znak; eto devojka će zatrudneti i rodiće Sina, i nadenuće Mu ime Emanuilo.
\v 15 Maslo i med ješće, dok ne nauči odbaciti zlo a izabrati dobro.
\v 16 Jer pre nego nauči dete odbaciti zlo a izabrati dobro, ostaviće zemlju, na koju se gadiš, dva cara njena.
\v 17 Gospod će pustiti na te i na narod tvoj i na dom oca tvog dane, kakvih nije bilo otkad se Jefrem odvoji od Jude, preko cara asirskog.
\p 
\v 18 I tada će Gospod zazviždati muvama koje su nakraj reka misirskih, i pčelama koje su u zemlji asirskoj;
\v 19 i doći će i popadaće sve u puste doline i u kamene raseline i na sve česte i na svako drvce.
\p 
\v 20 Tada će Gospod obrijati britvom zakupljenom ispreko reke, carem asirskim, glavu i dlake po nogama, i bradu svu.
\p 
\v 21 I tada ko sačuva kravicu i dve ovce,
\v 22 od mnoštva mleka što će davati ješće maslo; jer maslo i med ješće ko god ostane u zemlji.
\p 
\v 23 I tada će svako mesto gde ima hiljadu čokota za hiljadu srebrnjaka zarasti u čkalj i trnje.
\v 24 Sa strelama i s lukom ići će se onamo, jer će sva zemlja biti čkalj i trnje.
\v 25 A na sve gore koje su se kopale motikom, na njih neće doći strah od čkalja i trnja, nego će biti ispust volovima i gaziće ih ovce.
\c 8
\s1 Uteha vernih u zlim vremenima. Opomena da se veruje u Boga živoga.
\p 
\v 1 I reče mi Gospod: Uzmi knjigu veliku i napiši u njoj pismom čovečjim: Brz na plen, hitar na grabež.
\v 2 I uzeh verne svedoke, Uriju sveštenika i Zahariju sina Jeverehijinog.
\p 
\v 3 Potom pristupih k proročici, i ona zatrudne i rodi sina. A Gospod mi reče: Nadeni mu ime: Brz na plen, hitar na grabež.
\v 4 Jer pre nego dete nauči vikati: Oče moj i majko moja, odneće se blago damaštansko i plen samarijski pred carem asirskim.
\p 
\v 5 I još mi reče Gospod govoreći:
\v 6 Što ovaj narod ne mari za vodu siloamsku koja teče tiho, i raduje se Resinu i sinu Remalijinom,
\v 7 zato, evo, Gospod će navesti na njih vodu iz reke silnu i veliku, cara asirskog i svu slavu njegovu, te će izaći iz svih potoka svojih, i teći će povrh svih bregova svojih,
\v 8 i navaliće preko Jude, plaviće i razlivaće se i doći do grla, i krila će joj se raširiti preko svekolike zemlje tvoje, Emanuilo!
\b
\q1 
\v 9 Združujte se, narodi, ali ćete se potrti;
\q1 čujte svi koji ste u dalekoj zemlji:
\q2 oružajte se, ali ćete se potrti;
\q2 oružajte se, ali ćete se potrti.
\q1 
\v 10 Dogovarajte se, dogovor će vam se razbiti:
\q1 recite reč, neće biti od nje ništa,
\q2 jer je s nama Bog.
\b
\p 
\v 11 Jer mi ovako reče Gospod uhvativši me za ruku i opomenuvši me da ne idem putem ovog naroda, govoreći:
\v 12 Ne govorite „Buna” kad god ovaj narod kaže „Buna”, i ne bojte se čega se on boji, i ne plašite se.
\v 13 Gospoda nad vojskama svetite; i On neka vam je strah i bojazan.
\v 14 I biće vam svetinja, a kamen za spoticanje i stena za sablazan obema domovima Izrailjevim, zamka i mreža stanovnicima jerusalimskim.
\v 15 I spotaknuće se mnogi i pašće i satrće se, zaplešće se i uhvatiće se.
\p 
\v 16 Sveži svedočanstvo, zapečati zakon mojim učenicima.
\v 17 Čekaću dakle Gospoda, koji je sakrio lice svoje od doma Jakovljevog, i uzdaću se u Nj.
\v 18 Evo ja i deca koju mi je dao Gospod jesmo znak i čudo Izrailju od Gospoda nad vojskama, koji nastava na gori Sionu.
\v 19 I ako vam kažu: Pitajte vrače i gatare, koji šapću i mrmljaju, recite: Ne treba li narod da pita Boga svog? Ili će pitati mrtve mesto živih?
\v 20 Zakon i svedočanstvo tražite. Ako li ko ne govori tako, njemu nema zore.
\v 21 I hodiće po zemlji potucajući se i gladujući; i kad bude gladan, ljutiće se i psovati cara svog i Boga svog gore.
\v 22 A kad pogleda na zemlju, a to nevolja i mrak i teška muka, i on zagnan u tamu.
\c 9
\s1 Mesijino rođenje, ime i carstvo. Sud Izrailju.
\p 
\v 1 Ali neće se onako zamračiti pritešnjena zemlja kao pre kad se dotače zemlje Zavulonove i zemlje Neftalimove, ili kao posle kad dosađivaše na putu k moru s one strane Jordana Galileji neznabožačkoj.
\b
\q1 
\v 2 Narod koji hodi u tami videće videlo veliko,
\q2 i onima koji sede u zemlji gde je smrtni sen zasvetliće videlo.
\q1 
\v 3 Umnožio si narod,
\q2 a nisi mu uveličao radosti;
\q1 ali će se radovati pred Tobom
\q2 kao što se raduju o žetvi,
\q2 kao što se vesele kad dele plen.
\q1 
\v 4 Jer si slomio jaram u kome vucijaše,
\q2 i štap kojim ga bijahu po plećima
\q1 i palicu nasilnika njegovog
\q2 kao u dan madijanski.
\q1 
\v 5 Jer će obuća svakog ratnika koji se bije u graji
\q2 i odelo u krv uvaljano
\q2 izgoreti i biti hrana ognju.
\q1 
\v 6 Jer nam se rodi Dete, Sin nam se dade,
\q2 kome je vlast na ramenu,
\q1 i ime će Mu biti:
\q2 Divni, Savetnik, Bog silni, Otac večni, Knez mirni.
\q1 
\v 7 Bez kraja će rasti vlast i mir
\q2 na prestolu Davidovom i u carstvu njegovom
\q1 da se uredi i utvrdi sudom i pravdom
\q2 od sada doveka.
\q1 To će učiniti revnost Gospoda nad vojskama.
\b
\q1 
\v 8 Gospod posla reč Jakovu,
\q2 i ona pade u Izrailju.
\q1 
\v 9 I znaće sav narod,
\q2 Jefrem i stanovnici samarijski,
\q2 koji oholo i ponositog srca govore:
\q1 
\v 10 Padoše opeke, ali ćemo mi zidati od tesanog kamena;
\q2 dudovi su posečeni, ali ćemo ih zameniti kedrima.
\q1 
\v 11 Ali će Gospod podignuti protivnike Resinove na nj,
\q2 i skupiće neprijatelje njegove,
\q1 
\v 12 Sirce s istoka i Filisteje sa zapada,
\q2 te će ždreti Izrailja na sva usta.
\q1 Kod svega toga neće se odvratiti gnev Njegov,
\q2 nego će ruka Njegova još biti podignuta.
\b
\q1 
\v 13 Jer se narod neće obratiti k onome ko ga bije,
\q2 i neće tražiti Gospoda nad vojskama.
\q1 
\v 14 Zato će odseći Gospod Izrailju glavu i rep,
\q2 granu i situ u jedan dan.
\q1 
\v 15 Starešina i ugledan čovek to je glava,
\q2 a prorok koji uči laž to je rep.
\q1 
\v 16 Jer koji vode taj narod, oni ga zavode,
\q2 a koje vode, oni su propali.
\q1 
\v 17 Zato se Gospod neće radovati mladićima njegovim,
\q2 i na sirote njegove i na udovice njegove neće se smilovati,
\q1 jer su svikoliki licemeri i zlikovci,
\q2 i svaka usta govore nevaljalstvo.
\q1 Kod svega toga neće se odvratiti gnev Njegov,
\q2 nego će ruka Njegova još biti podignuta.
\b
\q1 
\v 18 Jer će se razgoreti bezbožnost kao oganj,
\q2 koji sažeže čkalj i trnje,
\q1 pa upali gustu šumu,
\q2 te otide u dim visoko.
\q1 
\v 19 Od gneva Gospoda nad vojskama zamračiće se zemlja
\q2 i narod će biti kao hrana ognju,
\q2 niko neće požaliti brata svog.
\q1 
\v 20 I zgrabiće s desne strane, pa će opet biti gladan,
\q2 i ješće s leve strane, pa se opet neće nasititi;
\q2 svaki će jesti meso od mišice svoje,
\q1 
\v 21 Manasija Jefrema, i Jefrem Manasiju,
\q2 a obojica će se složiti na Judu.
\q1 Kod svega toga neće se odvratiti gnev Njegov,
\q2 nego će ruka Njegova još biti podignuta.
\c 10
\s1 Kazna nepravednih sudija. Asirova obest i poniženje. Ostatak se u Izrailju obraća Bogu.
\q1 
\v 1 Teško onima koji postavljaju zakone nepravedne
\q2 i koji pišu nepravdu,
\q1 
\v 2 Da odbiju od suda uboge,
\q2 i da otimaju pravicu siromasima naroda mog,
\q1 da bi im plen bile udovice
\q2 i sirote grabež.
\q1 
\v 3 A šta ćete činiti u dan pohođenja i pogibli
\q2 koja će doći izdaleka?
\q1 Kome ćete pribeći za pomoć?
\q2 Gde li ćete ostaviti slavu svoju?
\q1 
\v 4 Da se ne bi unizila među roblje
\q2 i među pobijene pala?
\q1 Kod svega toga neće se odvratiti gnev Njegov,
\q2 nego će ruka Njegova još biti podignuta.
\b
\q1 
\v 5 Teško Asiru, šibi gneva mog,
\q2 ako i jeste palica u ruci njegovoj moja jarost.
\q1 
\v 6 Na narod licemerni poslaću ga,
\q2 i zapovediću mu za narod na koji se gnevim, da pleni i otima,
\q2 i da ga izgazi kao blato na ulicama.
\q1 
\v 7 Ali on neće tako misliti
\q2 i srce njegovo neće tako suditi,
\q1 nego mu je u srcu da zatre
\q2 i istrebi mnoge narode.
\q1 
\v 8 Jer će reći:
\q2 Knezovi moji nisu li svi carevi?
\q1 
\v 9 Nije li Halan kao Harhemis?
\q2 Nije li Emat kao Arfad?
\q2 Nije li Samarija kao Damask?
\q1 
\v 10 Kako je ruka moja našla carstva lažnih bogova,
\q2 kojih likovi behu jači od jerusalimskih i samarijskih,
\q1 
\v 11 Neću li učiniti Jerusalimu
\q2 i njegovim lažnim bogovima
\q1 onako kako sam učinio Samariji
\q2 i njenim lažnim bogovima?
\b
\p 
\v 12 Ali kad svrši Gospod sve delo svoje na gori sionskoj i u Jerusalimu, tada ću obići plod oholog srca cara asirskog i slavu ponositih očiju njegovih.
\v 13 Jer reče:
\b
\q1 Krepošću ruke svoje učinih
\q2 i mudrošću svojom, jer sam razuman;
\q1 i premestih međe narodima
\q2 i blago njihovo zaplenih
\q2 i kao junak oborih stanovnike.
\q1 
\v 14 I ruka moja nađe kao gnezdo bogatstvo u naroda,
\q2 i kako se kupe jaja ostavljena tako pokupih svu zemlju,
\q1 i ne bi nikoga da mahne krilom
\q2 ili da otvori usta i pisne.
\b
\q1 
\v 15 Hoće li se sekira veličati nad onim koji njom seče?
\q2 Hoće li se pila razmetati nad onim koji njom radi?
\q1 Kao da bi prut mahao onim koji ga digne,
\q2 kao da bi se hvalio štap da nije od drveta.
\q1 
\v 16 Zato će Gospod, Gospod nad vojskama, pustiti na pretile njegove mršu,
\q2 i slavu će njegovu potpaliti da gori kao oganj.
\q1 
\v 17 Jer će videlo Izrailjevo biti oganj,
\q2 i Svetac će njegov biti plamen,
\q2 i upaliće i sažeći trnje njegovo i čkalj njegov u jedan dan.
\q1 
\v 18 I krasotu šume njegove i njive njegove, od duše do tela, uništiće,
\q2 i biće kao begunac kad iznemogne.
\q1 
\v 19 I šta ostane drveta šume njegove, biće malo,
\q2 da bi ih dete moglo popisati.
\b
\p 
\v 20 I u to vreme ostatak Izrailjev i koji se izbave u domu Jakovljevom neće se više oslanjati na onog ko ih bije, nego će se oslanjati na Gospoda Sveca Izrailjevog istinom.
\v 21 Ostatak će se obratiti, ostatak Jakovljev, k Bogu silnom.
\v 22 Jer ako bude naroda tvog, Izrailju, kao peska morskog, ostatak će se njegov obratiti. Pogibao je određena, razliće se pravda.
\v 23 Jer će Gospod, Gospod nad vojskama, izvršiti pogibao određenu u svoj zemlji.
\p 
\v 24 Zato ovako veli Gospod, Gospod nad vojskama: Ne boj se Asirca, narode moj, koji nastavaš na gori Sionu; prutom će te udariti i štap svoj podignuće na te kao u Misiru.
\v 25 Jer još malo, i gnev će prestati; tada će se jarost moja obratiti na njihovu pogibao.
\v 26 Jer će podignuti na nj Gospod nad vojskama bič, te će biti kao rasap madijanski kod kamena Oriva i kao štap njegov na moru, i podignuće ga kao u Misiru.
\v 27 I tada će se skinuti breme njegovo s ramena tvog i jaram njegov s vrata tvog, i izlomiće se jaram od pomazanja.
\b
\q1 
\v 28 Dođe u Ajat, prođe u Migron,
\q2 u Mihmasu rasprti prtljag svoj.
\q1 
\v 29 Pođoše klancem, u Gavaji zanoćiše,
\q2 prepade se Rama, Gavaja Saulova pobeže.
\q1 
\v 30 Viči glasno, kćeri Galimova;
\q2 nek se čuje u Lais, jadni Anatote!
\q1 
\v 31 Madmina pobeže,
\q2 stanovnici gevimski utekoše.
\q1 
\v 32 Još jedan dan, pa će stajati u Novu,
\q2 mahnuće rukom svojom na goru kćeri sionske,
\q2 na hum jerusalimski.
\b
\q1 
\v 33 Gle, Gospod, Gospod nad vojskama, okresaće silom grane;
\q2 šta je visoko poseći će, i šta je uzdignuto sniziće.
\q1 
\v 34 I gustu će šumu iseći sekirom,
\q2 i Livan će pasti od Silnoga.
\c 11
\s1 Mesija i njegovo carstvo mira. Spasenje rasutih sinova narodnih.
\q1 
\v 1 Ali će izaći šibljika iz stabla Jesejevog,
\q2 i izdanak iz korena njegovog izniknuće.
\q1 
\v 2 I na Njemu će počivati Duh Gospodnji,
\q2 duh mudrosti i razuma,
\q1 duh saveta i sile,
\q2 duh znanja i straha Gospodnjeg.
\q1 
\v 3 I mirisanje će Mu biti u strahu Gospodnjem,
\q2 a neće suditi po viđenju svojih očiju,
\q2 niti će po čuvenju svojih ušiju karati.
\q1 
\v 4 Nego će po pravdi suditi siromasima
\q2 i po pravici karati krotke u zemlji,
\q1 i udariće zemlju prutom usta svojih,
\q2 i duhom usana svojih ubiće bezbožnika.
\q1 
\v 5 I pravda će Mu biti pojas po bedrima,
\q2 i istina pojas po bocima.
\b
\q1 
\v 6 I vuk će boraviti s jagnjetom,
\q2 i ris će ležati s jaretom,
\q1 tele i lavić i ugojeno živinče biće zajedno,
\q2 i malo dete vodiće ih.
\q1 
\v 7 I krava i medvedica zajedno će pasti,
\q2 mlad njihova ležaće zajedno,
\q2 i lav će jesti slamu kao vo.
\q1 
\v 8 I dete koje sisa igraće se nad rupom aspidinom,
\q2 i dete odbijeno od sise zavlačiće ruku svoju u rupu zmije vasilinske.
\q1 
\v 9 Neće uditi ni potirati na svoj svetoj gori mojoj,
\q2 jer će zemlja biti puna poznanja Gospodnjeg
\q2 kao more vode što je puno.
\b
\p 
\v 10 I u to će vreme za koren Jesejev, koji će biti zastava narodima, raspitivati narodi, i počivalište Njegovo biće slavno.
\p 
\v 11 I tada će Gospod opet podignuti ruku svoju da zadobije ostatak naroda svog, šta ostane od asirske i od Misira i od Patrosa i od etiopske i od Elama i od Senara i od Emata i od ostrva morskih.
\b
\q1 
\v 12 I podignuće zastavu narodima
\q2 i prognane Izrailjeve i rasejane Judine
\q2 sabraće s četiri kraja zemlje,
\q1 
\v 13 I nestaće zavisti Jefremove,
\q2 i neprijatelji Judini istrebiće se;
\q1 Jefrem neće zavideti Judi,
\q2 a Juda neće zlobiti Jefremu.
\q1 
\v 14 Nego će složno leteti na pleća Filistejima k zapadu;
\q2 zajedno će pleniti narode istočne;
\q1 na Edomce i Moavce dignuće ruke svoje,
\q2 i sinovi Amonovi biće im pokorni.
\q1 
\v 15 I Gospod će presušiti zaliv mora misirskog,
\q2 i mahnuće rukom svojom svrh reke
\q2 sa silnim vetrom svojim,
\q1 i udariće je po sedam krakova
\q2 da se može prelaziti u obući.
\q1 
\v 16 I biće put ostatku naroda njegovog,
\q2 što ostane od Asirske,
\q1 kao što je bio Izrailju
\q2 kad izađe iz zemlje misirske.
\c 12
\s1 Zahvalna pesma spasenih.
\q1 
\v 1 I reći ćeš u ono vreme:
\q2 Hvalim Te, Gospode, jer si se bio razgnevio na me,
\q2 pa se odvratio gnev Tvoj, i utešio si me.
\b
\q1 
\v 2 Gle, Bog je spasenje moje,
\q2 uzdaću se i neću se bojati,
\q1 jer mi je sila i pesma Gospod Bog,
\q2 On mi bi Spasitelj.
\b
\p 
\v 3 S radošću ćete crpsti vodu iz izvora ovog spasenja.
\v 4 I tada ćete reći:
\b
\q1 Hvalite Gospoda,
\q2 glasite ime Njegovo,
\q1 javljajte po narodima dela Njegova,
\q2 napominjite da je visoko ime Njegovo.
\b
\q1 
\v 5 Pojte Gospodu,
\q2 jer učini velike stvari,
\q2 neka se zna po svoj zemlji.
\q1 
\v 6 Klikuj i pevaj,
\q2 koja sediš u Sionu,
\q2 jer je Svetac Izrailjev velik posred vas.
\c 13
\s1 Proricanje da će Midi razoriti Vavilon.
\p 
\v 1 Breme Vavilonu, koje vide Isaija sin Amosov.
\b
\q1 
\v 2 Na gori visokoj podignite zastavu,
\q2 vičite im glasno, mašite rukom,
\q2 neka uđu na vrata kneževska.
\q1 
\v 3 Ja sam zapovedio izabranima svojim
\q2 i dozvao sam junake svoje
\q1 da izvrše gnev moj
\q2 koji se raduju s veličine moje.
\b
\q1 
\v 4 Vika stoji ljudstva na gorama kao da je velik narod,
\q2 vika i vreva carstva skupljenih naroda;
\q2 Gospod nad vojskama pregleda vojsku ubojitu.
\q1 
\v 5 Dolaze iz daleke zemlje,
\q2 s kraja nebesa,
\q1 Gospod i oruđa srdnje Njegove,
\q2 da zatre svu zemlju.
\b
\q1 
\v 6 Ridajte, jer je blizu dan Gospodnji;
\q2 doći će kao pustoš od Svemogućeg.
\q1 
\v 7 Zato će svaka ruka klonuti,
\q2 i svako srce čovečje rastopiti se.
\q1 
\v 8 I oni će se smesti,
\q2 muke i bolovi spopašće ih,
\q2 mučiće se kao porodilja,
\q1 prepašće se jedan od drugog,
\q2 lica će im biti kao plamen.
\b
\q1 
\v 9 Evo, ide dan Gospodnji
\q2 ljuti s gnevom i jarošću
\q1 da obrati zemlju u pustoš,
\q2 i grešnike da istrebi iz nje.
\q1 
\v 10 Jer zvezde nebeske i prilike nebeske neće pustiti svetlost svoju,
\q2 sunce će pomrčati o rađanju svom,
\q2 i mesec neće pustiti svetlost svoju.
\q1 
\v 11 I pohodiću vasiljenu za zloću,
\q2 i bezbožnike za bezakonje;
\q1 i ukinuću razmetanje oholih,
\q2 i ponos silnih oboriću.
\q1 
\v 12 Učiniću da će čovek više vredeti nego zlato čisto,
\q2 više nego zlato ofirsko.
\q1 
\v 13 Zato ću zatresti nebo,
\q2 i zemlja će se pokrenuti sa svog mesta
\q1 od jarosti Gospoda nad vojskama
\q2 i u dan kad se raspali gnev Njegov.
\q1 
\v 14 I biće kao srna poplašena
\q2 i kao stado koje niko ne sabira;
\q1 svako će gledati za svojim narodom,
\q2 i svako će bežati u svoju zemlju.
\q1 
\v 15 Ko se god nađe, biće proboden,
\q2 i koji se god skupe, poginuće od mača.
\q1 
\v 16 I decu ću im razmrskati na njihove oči,
\q2 kuće ću im opleniti
\q2 i žene ću im sramotiti.
\b
\q1 
\v 17 Evo, ja ću podignuti na njih Mide,
\q2 koji neće mariti za srebro,
\q2 niti će zlato iskati.
\q1 
\v 18 Nego će iz lukova decu ubijati,
\q2 ni na plod u utrobi neće se smilovati,
\q2 niti će decu žaliti oko njihovo.
\q1 
\v 19 I Vavilon, ures carstvima i dika slavi haldejskoj,
\q2 biće kao Sodom i Gomor kad ih Bog zatre.
\q1 
\v 20 Neće se u njemu živeti
\q2 niti će se ko naseliti od kolena do kolena,
\q1 niti će Arapin razapeti u njemu šator,
\q2 niti će pastiri počivati onuda.
\q1 
\v 21 Nego će počivati onde divlje zveri,
\q2 i kuće će njihove biti pune velikih zmija,
\q1 i onde će nastavati sove,
\q2 i aveti će skakati onuda.
\q1 
\v 22 I dovikivaće se buljine u pustim kućama
\q2 i zmajevi u dvorovima veselim.
\q1 A doći će njegovo vreme, i blizu je,
\q2 i dani njegovi neće se protegnuti.
\c 14
\s1 Oslobođenje Izrailja i pobedna pesma zbog pogibli cara vavilonskog. Propast Asiraca i Filisteja.
\p 
\v 1 Jer će se smilovati Gospod na Jakova, i opet će izabrati Izrailja, i namestiće ih u zemlji njihovoj, i prilepiće se k njima došljaci i pridružiće se domu Jakovljevom.
\v 2 Jer će ih uzeti narodi i odvesti na mesto njihovo, i naslediće ih Izrailjci u zemlji Gospodnjoj da im budu sluge i sluškinje, i zarobiće one koji ih behu zarobili, i biće gospodari svojim nasilnicima.
\b
\p 
\v 3 I kad te smiri Gospod od truda tvog i muke i od ljutog ropstva u kome si robovao,
\v 4 tada ćeš izvoditi ovu priču o caru vavilonskom i reći ćeš:
\b
\q1 Kako nesta nastojnika,
\q2 nesta danka?
\q1 
\v 5 Slomi Gospod štap bezbožnicima,
\q2 palicu vladaocima,
\q1 
\v 6 Koja je ljuto bila narode bez prestanka,
\q2 i gnevno vladala nad narodima,
\q2 i gonila nemilice.
\q1 
\v 7 Sva zemlja počiva i mirna je;
\q2 pevaju glasno.
\q1 
\v 8 Vesele se s tebe i jele i kedri livanski govoreći:
\q2 Otkako si pao, ne dolazi niko da nas seče.
\q1 
\v 9 Pakao dole uskoleba se tebe radi
\q2 da te sretne kad dođeš,
\q1 probudi ti mrtvace i sve knezove zemaljske,
\q2 diže s prestola njihovih sve careve narodne.
\q1 
\v 10 Svi će progovoriti i reći tebi:
\q1 I ti li si iznemogao kao mi?
\q2 Izjednačio se s nama?
\q1 
\v 11 Spusti se u pakao ponos tvoj,
\q2 zveka psaltira tvojih;
\q1 prostrti su poda te moljci,
\q2 a crvi su ti pokrivač.
\b
\q1 
\v 12 Kako pade s neba,
\q2 zvezdo danice, kćeri zorina?
\q1 Kako se obori na zemlju
\q2 koji si gazio narode?
\q1 
\v 13 A govorio si u srcu svom:
\q1 Izaći ću na nebo,
\q2 više zvezda Božjih podignuću presto svoj,
\q2 i sešću na gori zbornoj na strani severnoj;
\q1 
\v 14 Izaći ću u visine nad oblake,
\q2 izjednačiću se s Višnjim.
\q1 
\v 15 A ti se u pakao svrže,
\q2 u dubinu grobnu.
\q1 
\v 16 Koji te vide pogledaće na te,
\q2 i gledaće te govoreći:
\q1 To li je onaj koji je tresao zemlju,
\q2 koji je drmao carstva,
\q1 
\v 17 Koji je vasiljenu obraćao u pustinju,
\q2 i gradove njene raskopavao?
\q1 Roblje svoje nije otpuštao kući?
\q1 
\v 18 Svi carevi narodni,
\q2 svikoliki, leže slavno,
\q2 svaki u svojoj kući.
\q1 
\v 19 A ti se izbaci iz groba svog,
\q2 kao gadna grana,
\q1 kao haljina pobijenih,
\q2 mačem pobodenih,
\q1 koji silaze u jamu kamenu,
\q2 kao pogažen strv.
\q1 
\v 20 Nećeš se združiti s njima pogrebom,
\q2 jer si zemlju svoju zatro,
\q2 narod si svoj ubio;
\q1 neće se spominjati seme zlikovačko dok je veka.
\b
\q1 
\v 21 Pripravite pokolj sinovima njegovim
\q2 za bezakonje otaca njihovih
\q1 da se ne podignu
\q2 i ne naslede zemlju
\q2 i ne napune vasiljenu gradovima.
\b
\p 
\v 22 Jer ću ustati na njih, govori Gospod nad vojskama, i zatrću ime Vavilonu i ostatak, i sina i unuka, govori Gospod.
\v 23 I načiniću od njega stan ćukovima i jezera vodena, i omešću ga metlom pogibli, govori Gospod nad vojskama.
\b
\q1 
\v 24 Zakle se Gospod nad vojskama govoreći:
\q1 Doista, biće kako sam smislio,
\q2 i kako sam naumio izvršiće se.
\q1 
\v 25 Potrću Asirca u zemlji svojoj,
\q2 na gorama svojim izgaziću ga;
\q1 tada će se skinuti s njih jaram njegov,
\q2 i breme njegovo s pleća njihovih skinuće se.
\b
\q1 
\v 26 To je namišljeno svoj zemlji,
\q2 i to je ruka podignuta na sve narode.
\q1 
\v 27 Jer je Gospod nad vojskama naumio,
\q2 ko će razbiti?
\q1 I Njegovu ruku podignutu
\q2 ko će odvratiti?
\b
\p 
\v 28 Godine koje umre car Ahaz bi objavljeno ovo breme:
\b
\q1 
\v 29 Nemoj se radovati, zemljo filistejska svakolika,
\q2 što se slomi prut onog koji te je bio;
\q1 jer će iz korena zmijskog niknuti zmija vasilinska,
\q2 i plod će mu biti zmaj ognjeni krilati.
\q1 
\v 30 I prvenci siromaški nahraniće se,
\q2 i ubogi će počivati bez straha;
\q1 a tvoj ću koren umoriti glađu,
\q2 i ostatak tvoj on će pobiti.
\q1 
\v 31 Ridajte, vrata;
\q2 viči, grade;
\q1 rastopila si se, sva zemljo filistejska,
\q2 jer sa severa ide dim
\q2 i niko se neće osamiti u zborovima njegovim.
\b
\q1 
\v 32 I šta će se odgovoriti poslanicima narodnim?
\q1 Da je Gospod osnovao Sion
\q2 i da će u nj utecati nevoljnici naroda Njegovog.
\c 15
\s1 Proricanje o propasti Moava.
\p 
\v 1 Breme Moavu.
\b
\q1 Da, obnoć se raskopa Ar moavski
\q2 i propade;
\q1 da, obnoć se raskopa Kir moavski
\q2 i propade.
\q1 
\v 2 Otide u dom i u Devon,
\q2 na visine, da plače:
\q1 Moav će ridati za Nevonom i za Medevom,
\q2 sve će mu glave biti ćelave,
\q2 svaka brada oskubena.
\q1 
\v 3 Po ulicama će njegovim pripasivati kostret,
\q2 na krovovima njegovim i na ulicama njegovim
\q2 sve će ridati suze lijući.
\q1 
\v 4 I vikaće Esevon i Eleala,
\q2 do Jase čuće im se glas;
\q1 i vojnici će moavski vikati,
\q2 duša će se u svakom uzmučiti.
\q1 
\v 5 Srce moje vapije za Moavom;
\q2 begunci njegovi pobegoše dori do Sigora
\q2 kao junica trećakinja;
\q1 jer će se ići uz brdo luitsko plačući,
\q2 i putem oronajimskim razlegaće se jauk.
\q1 
\v 6 Jer će nestati voda nimrimskih,
\q2 jer će posahnuti bilje, nestaće trave,
\q2 zeleni neće biti.
\q1 
\v 7 I zato što su ostavljali i što su čuvali
\q2 odneće se na potok arapski.
\q1 
\v 8 Jer će vika ići oko međa moavskih,
\q2 do Eglaima jauk njihov,
\q2 i do Vir-Elima jauk njihov.
\q1 
\v 9 Jer će se voda dimonska napuniti krvi;
\q2 i još ću dometnuti Dimonu,
\q1 na begunce moavske i na ostatak zemaljski poslaću lavove.
\c 16
\s1 Nastavak proricanja o propasti Moava.
\q1 
\v 1 Šaljite jaganjce gospodaru zemaljskom,
\q2 od Sele do pustinje,
\q2 ka gori kćeri sionske.
\q1 
\v 2 Jer će biti kćeri moavske na brodovima arnonskim
\q2 kao ptica koja luta, oterana s gnezda.
\b
\q1 
\v 3 Učini veće, narode,
\q2 načini sen u podne kao noć,
\q1 zakloni izagnane,
\q2 nemoj izdati begunce.
\q1 
\v 4 Neka kod tebe borave izgnani moji, Moave;
\q2 budi im zaklon od pustošnika;
\q1 jer će nestati nasilnika,
\q2 prestaće pustošenje,
\q1 istrebiće se sa zemlje koji gaze druge.
\q1 
\v 5 I utvrdiće se presto milošću,
\q2 i na njemu će sedeti jednako u šatoru Davidovom
\q1 koji će suditi i tražiti što je pravo
\q2 i biti brz da čini pravdu.
\b
\q1 
\v 6 Čusmo za oholost Moava vrlo ponositog,
\q2 za ponos njegov i oholost i obest njegovu;
\q1 laži njegove neće biti tvrde.
\q1 
\v 7 Zato će ridati Moavac nad Moavcem, svi će ridati;
\q2 nad temeljima kir-aresetskim uzdisaćete jer su razvaljeni.
\b
\q1 
\v 8 I polja esevonska posušiše se
\q2 i čokot sivamski;
\q1 gospoda narodna potrše krasne loze njegove,
\q2 koje dosezahu do Jazira
\q2 i vijahu se po pustinji;
\q1 odvode njegove pružahu se
\q2 i prelažahu preko mora.
\q1 
\v 9 Zato ću plakati plačem jazirskim za čokotom sivamskim;
\q2 zalivaću te suzama svojim, Esevone i Elealo,
\q2 jer pesma o letini tvojoj i o žetvi tvojoj pade.
\q1 
\v 10 I nesta radosti i veselja s polja rodnog,
\q2 u vinogradima se ne peva ni podvikuje,
\q2 vina u kacama ne gazi gazilac;
\q1 učinih kraj pesmama.
\q1 
\v 11 Zato utroba moja ječi kao gusle za Moavom,
\q2 i srce moje za Kir-Eresom.
\b
\p 
\v 12 I kad se vidi da se umorio Moav na visini svojoj, ući će u svetinju svoju da se pomoli; ali ništa neće svršiti.
\p 
\v 13 Ovo je reč što reče Gospod za Moava davno.
\v 14 A sada veli Gospod govoreći: Do tri godine, kao što su godine najamničke, ološaće slava Moavova sa svim mnoštvom njegovim, i šta ostane biće vrlo malo i nejako.
\c 17
\s1 Proricanje o propasti Damaska i Izrailja.
\p 
\v 1 Breme Damasku.
\b
\q1 Gle, Damask će se ukinuti da ne bude više grad,
\q2 nego će biti gomila razvalina.
\q1 
\v 2 Gradovi aroirski biće ostavljeni,
\q2 biće za stada, te će u njima počivati,
\q2 i niko ih neće plašiti.
\q1 
\v 3 Nestaće gradova Jefremovih
\q2 i carstva u Damasku i ostatku sirskom,
\q1 biće kao slava sinova Izrailjevih,
\q2 veli Gospod nad vojskama.
\b
\q1 
\v 4 I u taj će dan istančati slava Jakovljeva,
\q2 i debelo telo njegovo omršaće.
\q1 
\v 5 Jer će biti kao kad žetelac sabira žito i rukom žanje klasje,
\q2 i biće kao kad se kupi klasje u dolini rafajskoj.
\q1 
\v 6 Ali će se ostaviti u njoj pabirci
\q2 kao kad se otrese maslina,
\q1 pa dve tri ostanu u vrhu,
\q2 i četiri pet na rodnim granama,
\q1 veli Gospod Bog Izrailjev.
\b
\p 
\v 7 U to će vreme čovek pogledati na Tvorca svog, i oči njegove gledaće na Sveca Izrailjevog;
\v 8 a neće pogledati na oltare, delo ruku svojih, niti će gledati na ono što su načinili prsti njegovi, ni na lugove ni na likove sunčane.
\p 
\v 9 U to će vreme tvrdi gradovi njegovi biti kao ostavljen grm i ogranak, jer će se ostaviti radi sinova Izrailjevih, i biće pustoš.
\b
\q1 
\v 10 Jer si zaboravio Boga spasenja svog,
\q2 i nisi se sećao Stene sile svoje;
\q1 zato sadi krasne sadove
\q2 i lozu stranu presađuj;
\q1 
\v 11 Danju radi da uzraste šta posadiš,
\q2 i jutrom gledaj da ti seme nikne;
\q1 ali kad dođe do branja razgrabiće se,
\q2 i ostaće ti ljuta žalost.
\b
\q1 
\v 12 Teško mnoštvu velikih naroda,
\q2 što buče kao što buče mora,
\q1 i uzavrelim narodima,
\q2 kojih stoji vreva kao silnih voda;
\q1 
\v 13 Vreva stoji naroda kao velikih voda;
\q2 ali će povikati na njih,
\q2 i oni će pobeći daleko,
\q1 i biće gonjeni kao pleva po brdima od vetra
\q2 i kao prah od vihora.
\q1 
\v 14 Uveče eto straha,
\q2 i pre nego svane nema nikoga.
\q1 To je deo onih koji nas gaze,
\q2 i nasledstvo onih koji otimaju od nas.
\c 18
\s1 Etiopska zemlja proslavlja Gospoda.
\q1 
\v 1 Teško zemlji koja sen čini krilima
\q2 s one strane reka etiopskih;
\q1 
\v 2 Koja šalje poslanike preko mora,
\q2 u lađama od site po vodama,
\q2 govoreći: Idite, brzi glasnici,
\q1 k narodu rasejanom i oplenjenom,
\q2 k narodu strašnom otkako je dosad,
\q1 k narodu razmerenom i pogaženom,
\q2 kome zemlju raznose reke.
\b
\q1 
\v 3 Svi koji živite na svetu
\q2 i stanujete na zemlji,
\q1 kad se digne zastava na gorama, gledajte,
\q2 i kad zatrubi truba, slušajte.
\q1 
\v 4 Jer ovako mi reče Gospod:
\q1 Umiriću se i gledaću iz stana svog,
\q2 kao vrućina koja suši posle dažda
\q2 i kao rosan oblak o vrućini žetvenoj.
\q1 
\v 5 Jer pre berbe, kad napupe pupci
\q2 i od cveta postane grozd i stane zreti,
\q1 okresaće odvode srpom,
\q2 i uzeće lozu i odseći.
\q1 
\v 6 Sve će se ostaviti pticama gorskim
\q2 i zverima zemaljskim;
\q1 i ptice će letovati na njima,
\q2 a svakojake zveri zemaljske zimovaće.
\b
\p 
\v 7 Tada će se doneti dar Gospodu nad vojskama
\b
\q1 od naroda rasejanog i oplenjenog,
\q2 od naroda strašnog otkako je dosad,
\q1 od naroda razmerenog i pogaženog,
\q2 kome zemlju raznose reke,
\b
\p k mestu imena Gospoda nad vojskama, ka gori sionskoj.
\c 19
\s1 Proricanje o propasti Misira. Misir se udružuje sa Asirom i Izrailjem da služi Gospodu.
\p 
\v 1 Breme Misiru.
\b
\q1 Gle, Gospod sedeći na oblaku lakom doći će u Misir;
\q2 i zatrešće se od Njega idoli misirski,
\q2 i srce će se rastopiti u Misircima.
\q1 
\v 2 I razdražiću Misirce jedne na druge,
\q2 te će vojevati brat na brata
\q1 i prijatelj na prijatelja,
\q2 grad na grad,
\q2 carstvo na carstvo.
\q1 
\v 3 I nestaće duha Misiru,
\q2 i nameru njegovu razbiću;
\q1 tada će pitati svoje idole
\q2 i opsenare i vrače i gatare.
\q1 
\v 4 I predaću Misirce u ruke žestokim gospodarima,
\q2 i ljut će car vladati njima,
\q1 veli Gospod, Gospod nad vojskama.
\b
\q1 
\v 5 I nestaće vode iz mora,
\q2 i reka će presahnuti i zasušiti se.
\q1 
\v 6 I reke će oteći,
\q2 opašće i presahnuti potoci misirski,
\q2 trska i sita posušiće se.
\q1 
\v 7 Trava kraj potoka, na ušću potoka,
\q2 i svi usevi kraj potoka
\q2 posahnuće i nestaće ih i propašće.
\q1 
\v 8 I tužiće ribari
\q2 i biće setni svi koji bacaju udicu,
\q2 i koji razapinju mrežu po vodama zabrinuće se.
\q1 
\v 9 I stideće se koji rade od tankog lana,
\q2 i koji tkaju tanko belo platno.
\q1 
\v 10 I nasipi će mu se razvaliti,
\q2 i koji zagrađuju ribnjake,
\q2 svi će biti žalosnog srca.
\b
\q1 
\v 11 Doista, knezovi su soanski bezumni,
\q2 i savet mudrih savetnika Faraonovih lud je.
\q1 Kako možete govoriti Faraonu:
\q2 Ja sam sin mudrih, sin starih careva?
\q1 
\v 12 Gde su? Gde su mudraci tvoji?
\q2 Neka ti kažu ako znaju
\q2 šta je naumio za Misir Gospod nad vojskama.
\q1 
\v 13 Poludeše knezovi soanski;
\q2 prevariše se knezovi nofski;
\q2 prelastiše Misir glave plemena njegovih.
\q1 
\v 14 Gospod je izlio među njih duh prevaran,
\q2 te učiniše da posrće Misir u svim poslovima
\q2 kao što posrće pijan čovek bljujući.
\q1 
\v 15 I neće biti dela u Misiru
\q2 što bi učinila glava ili rep,
\q2 grana ili sita.
\b
\p 
\v 16 Tada će biti Misirci kao žene; bojaće se i drhtati od ruke Gospoda nad vojskama kad zamahne na njih.
\v 17 I zemlja će Judina biti strah Misiru; ko je se god opomene, prepašće se radi namere Gospoda nad vojskama što je naumio suprot njemu.
\p 
\v 18 U to će vreme biti pet gradova u zemlji misirskoj koji će govoriti jezikom hananskim i zaklinjati se Gospodom nad vojskama; jedan će se zvati grad Aheres.
\p 
\v 19 U to će vreme biti oltar Gospodnji usred zemlje misirske, i spomenik Gospodnji na međi njenoj;
\v 20 i biće znak i svedočanstvo Gospodu nad vojskama, u zemlji misirskoj. Kad stanu vikati ka Gospodu na nasilnike, On će im poslati spasitelja i kneza i izbaviće ih.
\v 21 I biće poznat Gospod Misircima, i poznaće Misirci Gospoda u to vreme, i služiće Mu žrtvama i darovima, i zavetovaće zavete Gospodu, i izvršavaće.
\v 22 Tako će Gospod udariti Misir, i udarivši isceliće, jer će se obratiti ka Gospodu, umoliće Mu se, i isceliće ih.
\p 
\v 23 U to će vreme biti put iz Misira u Asirsku, i Asirac će ići u Misir i Misirac u Asirsku, i služiće Gospodu Misirci s Asircima.
\p 
\v 24 U to će vreme Izrailj biti treći s Misircima i Asircima, i biće blagoslov posred zemlje.
\v 25 Jer će ih blagosloviti Gospod nad vojskama govoreći: Da je blagosloven moj narod misirski i asirski, delo ruku mojih, i nasledstvo moje, Izrailj.
\c 20
\s1 Proricanje o pobedama Asiraca nad Misirom i Etiopijom.
\p 
\v 1 Godine koje dođe Tartan na Azot, kad ga posla Sargon car asirski, te bi Azot i uze ga,
\v 2 u to vreme reče Gospod preko Isaije sina Amosovog govoreći: Idi, skini kostret sa sebe, i izuj obuću s nogu svojih. I učini tako i iđaše go i bos.
\p 
\v 3 Tada reče Gospod: Kako ide sluga moj Isaija go i bos za znak i čudo šta će biti do tri godine Misiru i etiopskoj,
\v 4 tako će odvesti car asirski u ropstvo Misirce, i Etiopljane u sužanjstvo, decu i starce, gole i bose i golih zadnjica, na sramotu Misircima.
\v 5 I prepašće se i posramiće se od etiopske, uzdanice svoje, i od Misira, ponosa svog.
\v 6 I reći će tada koji žive na ovom ostrvu: Gle, to je uzdanica naša, ka kojoj pritecasmo za pomoć da se sačuvamo od cara asirskog; kako ćemo se izbaviti?
\c 21
\s1 Proricanje o propasti Vavilona, Dume (Edoma) i Arapske.
\p 
\v 1 Breme pustinji na moru.
\b
\q1 Kao vihori koji prolaze na jug,
\q2 tako će doći iz pustinje,
\q2 iz zemlje strašne.
\q1 
\v 2 Ljuta utvara javi mi se.
\q2 Nevernik neveru čini,
\q2 pustošnik pustoši;
\q1 hodi, Elame; opkoli, Midijo!
\q2 Svemu uzdisanju učiniću kraj.
\q1 
\v 3 Zato su bedra moja puna bola;
\q2 muke me obuzeše
\q2 kao kad se muči porodilja;
\q1 zgurih se čujući,
\q2 prepadoh se videći.
\q1 
\v 4 Srce mi se smete,
\q2 groza me poduze;
\q1 noć milina mojih pretvori mi se u strah.
\q1 
\v 5 Postavi sto,
\q2 stražar neka straži;
\q1 jedi, pij;
\q2 ustajte knezovi, mažite štitove.
\q1 
\v 6 Jer ovako mi reče Gospod:
\q2 Idi, postavi stražara da ti javi šta vidi.
\q1 
\v 7 I vide kola, i dva reda konjika;
\q2 kola s magarcima i kola s kamilama;
\q2 i pažaše dobro velikom pažnjom.
\q1 
\v 8 I povika kao lav:
\q2 Gospodaru, ja stojim jednako na straži danju,
\q2 i stojim na straži po svu noć.
\q1 
\v 9 I evo dođoše na kolima ljudi,
\q2 u dva reda konjici.
\q1 Tada povika i reče:
\q2 Pade, pade Vavilon,
\q2 i svi rezani likovi bogova njegovih razbiše se o zemlju.
\q1 
\v 10 Vršaju moj, i pšenice gumna mog!
\q2 Šta čuh od Gospoda nad vojskama, Boga Izrailjevog,
\q2 javih vam.
\b
\p 
\v 11 Breme Dumi.
\b
\q1 Viče k meni neko sa Sira:
\q1 Stražaru! Šta bi noćas?
\q2 Stražaru! Šta bi noćas?
\q1 
\v 12 Stražar reče:
\q2 Doći će jutro, ali i noć;
\q1 ako ćete tražiti, tražite,
\q2 vratite se, dođite.
\b
\p 
\v 13 Breme arapskoj.
\b
\q1 Po šumama u arapskoj noćivaćete,
\q2 putnici dedanski!
\q1 
\v 14 Iznesite vode pred žedne,
\q2 koji živite u zemlji Temi,
\q2 sretnite s hlebom begunca.
\q1 
\v 15 Jer će bežati od mača, od mača golog,
\q2 od luka zapetog
\q2 i od žestokog boja.
\b
\p 
\v 16 Jer ovako mi reče Gospod: Za godinu, kao što je godina najamnička, nestaće sve slave kidarske.
\v 17 I što ostane hrabrih strelaca sinova kidarskih, biće malo; jer Gospod Bog Izrailjev reče.
\c 22
\s1 Jerusalim opkoljen. Somna svrgnut. Elijakim na vlasti.
\p 
\v 1 Breme dolini viđenja.
\b
\q1 Šta ti je te si sva izašla na krovove?
\q1 
\v 2 Grade puni vike i vreve,
\q2 grade veseli!
\q1 Tvoji pobijeni nisu pobijeni mačem
\q2 niti pogiboše u boju.
\q1 
\v 3 Glavari tvoji uzmakoše svikoliki,
\q2 povezaše ih strelci;
\q1 šta se god nađe tvojih, svi su povezani,
\q2 ako i pobegoše daleko.
\q1 
\v 4 Zato rekoh:
\q1 Prođite me se, da plačem gorko;
\q2 ne trudite se da me tešite za pogiblju kćeri naroda mog.
\b
\q1 
\v 5 Jer je ovo dan muke i potiranja i smetnje
\q2 od Gospoda, Gospoda nad vojskama,
\q2 u dolini viđenja;
\q1 obaliće zid,
\q2 i vika će biti do gore.
\q1 
\v 6 I Elam uze Tul,
\q2 s kolima ljudi i s konjicima,
\q2 i Kir istače štit.
\q1 
\v 7 I krasne doline tvoje napuniše se kola,
\q2 i konjici se namestiše pred vratima.
\q1 
\v 8 I odastre se zastirač Judin;
\b
\p i pogledao si u to vreme na oružje u kući šumskoj.
\v 9 I videste da je mnogo proloma na gradu Davidovom, i sabraste vodu u donjem jezeru.
\v 10 I izbrojaste kuće jerusalimske, i razvaliste kuće da utvrdite zid.
\v 11 I načiniste jaz među dva zida za vodu iz starog jezera; ali ne pogledaste na Onog koji je to učinio i ne obazreste se na Onog koji je to odavno spremio.
\b
\q1 
\v 12 I zva vas Gospod nad vojskama u onaj dan
\q2 da plačete i ridate
\q2 i da skubete kose i pripašete kostret;
\q1 
\v 13 A gle, radost i veselje,
\q2 ubijaju goveda, kolju ovce,
\q2 jedu meso i piju vino
\q1 govoreći:
\q2 Jedimo i pijmo,
\q2 jer ćemo sutra umreti.
\q1 
\v 14 Ali Gospod nad vojskama javi mi:
\q1 Neće vam se oprostiti ovo bezakonje do smrti,
\q2 veli Gospod, Gospod nad vojskama.
\b
\p 
\v 15 Ovako veli Gospod, Gospod nad vojskama: Idi k onom rizničaru, k Somni, upravitelju dvorskom,
\v 16 i reci mu: Šta ćeš ti tu? I ko ti je tu, te si tu istesao sebi grob? Istesao si sebi grob na visokom mestu i spremio si sebi stan u kamenu.
\v 17 Evo, čoveče, Gospod će te baciti daleko i zatrpaće te.
\v 18 Zavitlaće te i hititi kao loptu u zemlju prostranu; onde ćeš umreti i onde će biti kola slave tvoje, sramoto domu gospodara svog;
\v 19 i svrći ću te s mesta tvog, i isteraću te iz službe tvoje.
\v 20 I u to vreme pozvaću slugu svog Elijakima sina Helkijinog;
\v 21 i obući ću mu tvoju haljinu, i tvojim ću ga pojasom opasati, i tvoju ću mu vlast dati u ruku, i biće otac Jerusalimljanima i domu Judinom.
\v 22 I metnuću mu ključ od doma Davidovog na rame: kad on otvori, neće niko zatvoriti, i kad on zatvori, neće niko otvoriti.
\v 23 I kao klin uglaviću ga na tvrdom mestu, i biće presto slave domu oca svog;
\v 24 i o njemu će se vešati sva slava doma oca njegovog, sinova i unuka, svakojaki sudovi, i najmanji, i čaše i mehovi.
\v 25 U to vreme, veli Gospod nad vojskama, pomeriće se klin uglavljen na tvrdom mestu, i izvadiće se i pašće, i teža što je na njemu propašće; jer Gospod reče.
\c 23
\s1 Razorenje i obnovljenje Tira u slavu Božiju.
\p 
\v 1 Breme Tiru.
\b
\q1 Ridajte lađe tarsiske,
\q2 jer je raskopan, da nema kuće niti ko dolazi.
\q1 Iz zemlje kitimske javi im se.
\q1 
\v 2 Umuknite koji živite na ostrvu,
\q2 koje trgovci sidonski pomorci puniše.
\q1 
\v 3 I dohodi mu behu po velikim vodama
\q2 seme siorsko, žetva s reke,
\q2 i beše trg narodima.
\q1 
\v 4 Stidi se, Sidone, jer govori more,
\q2 sila morska veli:
\q1 Ne mučim se porođajem, ne rađam,
\q2 ne odgajam momke, ne podižem devojke.
\q1 
\v 5 Kao što se ožalostiše kad čuše za Misir,
\q2 tako će se ožalostiti kad čuju za Tir.
\q1 
\v 6 Idite u Tarsis,
\q2 ridajte ostrvljani!
\q1 
\v 7 Je li to vaš veseli grad,
\q2 čija je starina od davnina?
\q1 Njegove će ga noge zaneti daleko u tuđinstvo.
\q1 
\v 8 Ko je to smislio na Tir,
\q2 koji razdavaše vence,
\q1 čiji trgovci behu knezovi,
\q2 i prekupci slavni na zemlji?
\q1 
\v 9 Gospod je nad vojskama to smislio,
\q2 da osramoti ponos svake slave
\q2 i da poništi sve slavne na zemlji.
\q1 
\v 10 Pređi preko zemlje svoje kao potok, kćeri tarsiska;
\q2 nema više pojasa.
\q1 
\v 11 Ruku svoju podiže na more, zadrma carstva;
\q2 Gospod je zapovedio za Hanan da se raskopaju gradovi njegovi.
\q1 
\v 12 I veli:
\q2 Nećeš se više veseliti, osramoćena devojko, kćeri sidonska.
\q1 Ustani, idi u Kitim, ni onde nećeš imati mira.
\b
\p 
\v 13 Eto zemlje haldejske; tog naroda nije bilo; Asur je osnova za one koji živehu u pustinjama, podigoše kule u njoj, pogradiše dvorove; i obrati se u razvaline.
\b
\q1 
\v 14 Ridajte lađe tarsiske,
\q2 jer je raskopan vaš grad.
\b
\p 
\v 15 I tada će Tir biti zarobljen sedamdeset godina, za vek jednog cara, a posle sedamdeset godina pevaće se Tiru kao kurvi:
\b
\q1 
\v 16 Uzmi gusle, idi po gradu, zaboravljena kurvo;
\q2 dobro udaraj, pevaj i popevaj,
\q2 eda bi te se opet opomenuli.
\b
\p 
\v 17 Jer posle sedamdeset godina Gospod će pohoditi Tir, a on će se vratiti na kurvarsku zaslugu svoju, i kurvaće se sa svim carstvima na zemlji.
\v 18 Ali će trgovina njegova i zasluga njegova biti posvećena Gospodu, neće se ostavljati ni čuvati, nego će trgovina njegova biti onima koji nastavaju pred Gospodom da jedu do sitosti i imaju odelo dobro.
\c 24
\s1 Božiji sud zemlji. Buduće otkrivenje slave Božije na gori Sionu.
\q1 
\v 1 Gle, Gospod će isprazniti zemlju i opusteti je,
\q2 prevrnuće je i rasejaće stanovnike njene.
\q1 
\v 2 I biće sveštenik kao narod,
\q2 gospodar kao sluga,
\q1 gospođa kao sluškinja,
\q2 prodavac kao kupac,
\q1 koji daje u zajam kao koji uzima u zajam,
\q2 koji uzima dobit kao koji daje.
\q1 
\v 3 Sasvim će se isprazniti zemlja,
\q2 i sasvim će se opleniti.
\q1 Jer Gospod reče ovu reč.
\b
\q1 
\v 4 Tužiće zemlja i opasti,
\q2 iznemoći će vasiljena i opasti;
\q1 iznemoći će glavari naroda zemaljskog.
\q1 
\v 5 Jer se zemlja oskvrni pod stanovnicima svojim,
\q2 jer prestupiše zakone,
\q1 izmeniše uredbe,
\q2 raskidoše zavet večni.
\q1 
\v 6 Zato će prokletstvo proždreti zemlju,
\q2 i zatrće se stanovnici njeni;
\q1 zato će izgoreti stanovnici zemaljski,
\q2 i malo će ljudi ostati.
\q1 
\v 7 Tužiće vino, uvenuće loza vinova,
\q2 uzdisaće svi koji su veselog srca.
\q1 
\v 8 Prestaće veselje uz bubnje,
\q2 nestaće graja onih koji se vesele,
\q2 prestaće veselje uz gusle.
\q1 
\v 9 Neće piti vino uz pesme,
\q2 ogorčaće silovito piće onima koji ga piju.
\q1 
\v 10 Razbiće se pusti grad,
\q2 zatvorene će biti sve kuće da niko ne ulazi.
\q1 
\v 11 Tužnjava će biti po ulicama radi vina,
\q2 proći će svako veselje,
\q2 otići će radost zemaljska.
\q1 
\v 12 Pustoš će ostati u gradu,
\q2 i vrata će se razvaliti.
\q1 
\v 13 Jer će biti u zemlji i u narodima kao kad se oberu masline,
\q2 i kao kad se paljetkuje posle berbe.
\b
\q1 
\v 14 Ovi će podignuti glas svoj i pevaće,
\q2 radi veličanstva Gospodnjeg podvikivaće od mora.
\q1 
\v 15 Zato slavite Gospoda u dolinama,
\q2 na ostrvima morskim ime Gospoda Boga Izrailjevog.
\q1 
\v 16 S kraja zemlje čusmo pesme u slavu Pravednom;
\q2 ali rekoh: Ološah! Ološah! Teško meni!
\q1 Nevernici neveru čine,
\q2 baš nevernici neveru čine.
\b
\q1 
\v 17 Strahota i jama i zamka pred tobom je,
\q2 stanovniče zemaljski!
\q1 
\v 18 I ko uteče čuvši za strahotu, pašće u jamu;
\q2 a ko izađe iz jame, uhvatiće se u zamku;
\q1 jer će se ustave na visini otvoriti
\q2 i zatrešće se temelji zemlje.
\q1 
\v 19 Sva će se zemlja razbiti,
\q2 sva će se zemlja raspasti,
\q2 sva će se zemlja uskolebati.
\q1 
\v 20 Sva će se zemlja ljuljati kao pijan čovek,
\q2 i premestiće se kao koliba,
\q1 jer će joj otežati bezakonje njeno,
\q2 te će pasti i neće više ustati.
\b
\q1 
\v 21 I u to će vreme pohoditi Gospod na visini vojsku visoku
\q2 i na zemlji sve careve zemaljske.
\q1 
\v 22 I skupiće se kao što se skupljaju sužnji u jamu,
\q2 i biće zatvoreni u tamnicu,
\q2 i posle mnogo vremena biće pohođeni.
\q1 
\v 23 I posramiće se mesec
\q2 i sunce će se zastideti
\q1 kad Gospod nad vojskama stane carovati na gori Sionu i u Jerusalimu,
\q2 i pred starešinama svojim proslavi se.
\c 25
\s1 Slavljenje Gospoda. Gozba naroda na gori Sionu.
\q1 
\v 1 Gospode, Ti si Bog moj,
\q2 uzvišavaću Te, slaviću ime Tvoje,
\q1 jer si učinio čudesa;
\q2 namere Tvoje od starine vera su i istina.
\q1 
\v 2 Jer si od grada načinio gomilu,
\q2 i od tvrdog grada zidine;
\q1 od grada dvor za strance,
\q2 doveka se neće sagraditi.
\q1 
\v 3 Zato će Te slaviti narod silan,
\q2 grad strašnih naroda bojaće Te se.
\q1 
\v 4 Jer si bio krepost ubogom,
\q2 krepost siromahu u nevolji njegovoj,
\q1 utočište od poplave,
\q2 zaklon od žege,
\q2 jer je gnev nasilnički kao poplava koja obaljuje zid.
\q1 
\v 5 Vrevu inostranaca prekinuo si
\q2 kao pripeku na suvom mestu;
\q1 kao pripeka senom od oblaka,
\q2 tako se pevanje nasilnika prekide.
\b
\q1 
\v 6 I Gospod će nad vojskama učiniti svim narodima na ovoj gori gozbu od pretila mesa,
\q2 gozbu od čistog vina, od pretilog mesa s moždanima, od vina bez taloga.
\q1 
\v 7 I pokvariće na ovoj gori zastirač kojim su zastrti svi narodi,
\q2 i pokrivač kojim su pokriveni svi narodi.
\q1 
\v 8 Uništiće smrt zauvek,
\q2 i utrće Gospod Gospod suze sa svakog lica,
\q1 i sramotu naroda svog ukinuće sa sve zemlje;
\q2 jer Gospod reče.
\q1 
\v 9 I reći će se u ono vreme:
\q2 Gle, ovo je Bog naš, Njega čekasmo, i spašće nas;
\q1 ovo je Gospod, Njega čekasmo;
\q2 radovaćemo se i veselićemo se za spasenje Njegovo.
\q1 
\v 10 Jer će ruka Gospodnja počinuti na ovoj gori,
\q2 a Moav će se izgaziti na svom mestu
\q2 kao što se gazi slama za gnoj.
\q1 
\v 11 I razmahnuće rukama svojim sred njega,
\q2 kao što razmahuje plivač da pliva,
\q2 i oboriće oholost njegovu mišicama ruku svojih.
\q1 
\v 12 I grad i visoke zidove tvoje sniziće,
\q2 oboriće, baciće na zemlju u prah.
\c 26
\s1 Pesma narodna u slavu Boga i uzdanje u Boga.
\p 
\v 1 Tada će se pevati ova pesma u zemlji Judinoj:
\b
\q1 Imamo tvrd grad;
\q2 zidovi su i opkop spasenje.
\q1 
\v 2 Otvorite vrata da uđe narod pravedni,
\q2 koji drži veru.
\q1 
\v 3 Ko se Tebe drži,
\q2 čuvaš ga jednako u miru,
\q2 jer se u Tebe uzda.
\q1 
\v 4 Uzdajte se u Gospoda doveka,
\q2 jer je Gospod Gospod Večna stena.
\q1 
\v 5 Jer ponižuje one koji nastavaju na visini,
\q2 grad visoki obara,
\q1 obara ga na zemlju,
\q2 obraća ga u prah.
\q1 
\v 6 Te ga gazi noga,
\q2 noge ubogih, stopala nevoljnih.
\b
\q1 
\v 7 Put je pravedniku prav,
\q2 Ti ravniš stazu pravednome.
\q1 
\v 8 I na putu sudova Tvojih, Gospode, čekamo Te;
\q2 Tvoje ime i Tvoj spomen žudi duša.
\q1 
\v 9 Dušom svojom žudim Tebe noću,
\q2 i duhom svojim što je u meni tražim Te jutrom;
\q1 jer kad su sudovi Tvoji na zemlji,
\q2 uče se pravdi koji žive u vasiljenoj.
\q1 
\v 10 Ako se i pomiluje bezbožnik,
\q2 ne uči se pravdi,
\q1 u zemlji najpravednijoj čini bezakonje
\q2 i ne gleda na veličanstvo Gospodnje.
\q1 
\v 11 Gospode! Ruka je Tvoja visoko podignuta,
\q2 a oni ne vide;
\q1 videće i posramiće se od revnosti za narod,
\q2 i oganj će proždreti neprijatelje Tvoje.
\q1 
\v 12 Gospode! Nama ćeš dati mir,
\q2 jer sva dela naša Ti si nam učinio.
\q1 
\v 13 Gospode Bože naš, gospodariše nad nama gospodari drugi osim Tebe,
\q2 ali samo Tobom pominjemo ime Tvoje.
\q1 
\v 14 Pomreše, neće oživeti,
\q2 mrtvi budući neće ustati,
\q1 jer si ih Ti pohodio i istrebio,
\q2 zatro svaki spomen njihov.
\q1 
\v 15 Gospode, umnožio si narod,
\q2 umnožio si narod i proslavio si se,
\q2 ali si ih zagnao na sve krajeve zemaljske.
\b
\q1 
\v 16 Gospode, u nevolji tražiše Te,
\q2 i zvaše pokornu molitvu kad si ih karao.
\q1 
\v 17 Kao trudna žena kad hoće da se porodi
\q2 pa se muči i viče od bola,
\q2 takvi bejasmo mi pred Tobom, Gospode!
\q1 
\v 18 Zatrudnesmo, mučismo se da rodimo,
\q2 i kao da rodismo vetar,
\q1 nikako ne pomogosmo zemlji,
\q2 niti padoše koji žive u vasiljenoj.
\q1 
\v 19 Oživeće mrtvi tvoji,
\q2 i moje će mrtvo telo ustati.
\q1 Probudite se, i pevajte koji stanujete u prahu;
\q2 jer je Tvoja rosa rosa na travi,
\q2 i zemlja će izmetnuti mrtvace.
\b
\q1 
\v 20 Hajde narode moj, uđi u kleti svoje,
\q2 i zaključaj vrata svoja za sobom,
\q2 prikrij se začas, dokle prođe gnev.
\q1 
\v 21 Jer, gle, Gospod izlazi iz mesta svog
\q2 da pohodi stanovnike zemaljske za bezakonje njihovo,
\q1 i zemlja će otkriti krv svoju
\q2 niti će više pokrivati pobijene svoje.
\c 27
\s1 Poniženje svetskih sila, sabiranje sinova Izrailjevih.
\p 
\v 1 Tada će Gospod pokarati mačem svojim ljutim i velikim i jakim levijatana, prugu zmiju, i levijatana, krivuljastu zmiju, i ubiće zmaja koji je u moru.
\b
\q1 
\v 2 Tada pevajte o vinogradu koji rađa crveno vino:
\q1 
\v 3 Ja Gospod čuvam ga,
\q2 u svako doba zalivaću ga,
\q2 dan noć čuvaću ga da ga ko ne ošteti.
\q1 
\v 4 Nema gneva u mene;
\q1 ko će staviti u boj nasuprot meni čkalj i trnje?
\q2 Ja ću pogaziti i spaliti sve.
\q1 
\v 5 Ili neka se uhvati za silu moju da učini mir sa mnom;
\q2 učiniće mir sa mnom.
\b
\q1 
\v 6 Jednom će se ukoreniti Jakov,
\q2 procvetaće i uzrasti Izrailj,
\q2 i napuniće vasiljenu plodom.
\b
\q1 
\v 7 Je li ga udario
\q2 onako kako je udario one koji njega udaraše?
\q1 Je li ga ubio
\q2 onako kako su ubijeni oni koje je ubio?
\q1 
\v 8 S merom ga je karao, kad ga je odbacio,
\q2 kad ga je odneo silnim vetrom svojim istočnim.
\q1 
\v 9 Zato će se time očistiti bezakonje Jakovljevo
\q2 i to će biti sva korist što će se uzeti greh njegov
\q1 kad sve kamenje oltarno razmetne
\q2 kao razdrobljeno krečno kamenje
\q1 i ne bude više gajeva ni sunčanih likova,
\q1 
\v 10 Jer će tvrdi grad opusteti
\q2 i biće stan ostavljen i zanemaren kao pustinja;
\q1 onde će pasti tele i onde će legati,
\q2 i poješće mu grane.
\q1 
\v 11 Kad se posuše grane, polomiće se;
\q2 žene će dolaziti i ložiti ih na oganj.
\q1 Jer je narod nerazuman;
\q2 zato ga neće žaliti koji ga je stvorio,
\q2 i koji ga je sazdao neće se smilovati na nj.
\b
\p 
\v 12 U to će vreme Gospod ovijati od obale reke do potoka misirskog, a vi, sinovi Izrailjevi, sabraćete se jedan po jedan.
\v 13 I tada će se zatrubiti u veliku trubu, i koji se behu izgubili u zemlji asirskoj i koji behu zagnani u zemlju misirsku, doći će i klanjaće se Gospodu na svetoj gori u Jerusalimu.
\c 28
\s1 Sud Jefremu i Judi. Skupocen kamen od ugla. Divan Gospodnji savet.
\q1 
\v 1 Teško gizdavom vencu pijanica Jefremovih,
\q2 uvelom cvetu krasnog nakita njihovog,
\q1 koji su uvrh rodnog dola,
\q2 pijani od vina!
\q1 
\v 2 Gle, u Gospoda ima neko jak i silan
\q2 kao pljusak od grada,
\q1 kao oluja koja sve lomi,
\q2 kao poplava silne vode,
\q2 kad navali, oboriće sve na zemlju rukom.
\q1 
\v 3 Nogama će se izgaziti gizdavi venac,
\q2 pijanice Jefremove.
\q1 
\v 4 I uveli cvet krasnog nakita njihovog,
\q2 što je uvrh rodnog dola,
\q1 biće kao voće uzrelo pre leta,
\q2 koje čim ko vidi, uzme u ruku i pojede.
\b
\q1 
\v 5 U ono će vreme Gospod nad vojskama biti slavna kruna
\q2 i dičan venac ostatku naroda svog,
\q1 
\v 6 I duh suda onome koji sedi da sudi,
\q2 i sila onima koji uzbijaju boj do vrata.
\b
\q1 
\v 7 Ali se i oni zanose od vina,
\q2 i posrću od silovitog pića:
\q1 sveštenik i prorok zanose se od silovitog pića,
\q2 osvojilo ih je vino, posrću od silovitog pića,
\q2 zanose se u prorokovanju, spotiču se u suđenju.
\q1 
\v 8 Jer su svi stolovi puni bljuvotine i nečistoće,
\q2 nema mesta čistog.
\b
\q1 
\v 9 Koga će učiti mudrosti,
\q2 i koga će uputiti da razume nauku?
\q1 Decu, kojoj se ne daje više mleko,
\q2 koja su odbijena od sise?
\q1 
\v 10 Jer zapovest po zapovest, zapovest po zapovest,
\q2 pravilo po pravilo, pravilo po pravilo,
\q2 ovde malo, onde malo davaše se.
\b
\q1 
\v 11 Zato će nerazumljivom besedom i tuđim jezikom govoriti tom narodu;
\q2 
\v 12 Jer im reče:
\q1 Ovo je počinak,
\q2 ostavite umornog da počine;
\q1 ovo je odmor;
\q2 ali ne hteše poslušati.
\q1 
\v 13 I biće im reč Gospodnja,
\q2 zapovest po zapovest, zapovest po zapovest,
\q1 pravilo po pravilo, pravilo po pravilo,
\q2 malo ovde, malo onde,
\q1 da idu i padaju nauznako i razbiju se,
\q2 i da se zapletu u zamke i uhvate.
\b
\q1 
\v 14 Zato slušajte reč Gospodnju, ljudi podsmevači,
\q2 koji vladate narodom što je u Jerusalimu.
\q1 
\v 15 Što rekoste:
\q1 Uhvatismo veru sa smrću,
\q2 i ugovorismo s grobom;
\q1 kad zađe bič kao povodanj,
\q2 neće nas dohvatiti,
\q1 jer od laži načinismo sebi utočište,
\q2 i za prevaru zaklonismo se;
\q1 
\v 16 Zato ovako veli Gospod Gospod:
\q1 Evo, ja mećem u Sionu kamen,
\q2 kamen izabran, kamen od ugla, skupocen, temelj tvrd;
\q1 ko veruje neće se plašiti.
\q1 
\v 17 I izvršiću sud po pravilu
\q2 i pravdu po merilima;
\q1 i grad će potrti lažno utočište
\q2 i voda će potopiti zaklon.
\q1 
\v 18 I vera vaša sa smrću uništiće se,
\q2 i ugovor vaš s grobom neće ostati,
\q1 a kad zađe bič kao povodanj, potlačiće vas.
\q1 
\v 19 Čim zađe, odneće vas,
\q2 jer će zalaziti svako jutro, danju i noću,
\q2 i kad se čuje vika, biće sam strah.
\q1 
\v 20 Jer će odar biti kratak da se čovek ne može pružiti,
\q2 i pokrivač uzak da se ne može umotati.
\q1 
\v 21 Jer će Gospod ustati kao na gori Ferasimu,
\q2 razgneviće se kao u dolu gavaonskom,
\q1 da učini delo svoje,
\q2 neobično delo svoje,
\q1 da svrši posao svoj,
\q2 neobičan posao svoj.
\q1 
\v 22 Nemojte se dakle više podsmevati
\q2 da ne postanu jači okovi vaši,
\q1 jer čuh od Gospoda Gospoda nad vojskama pogibao određenu svoj zemlji.
\b
\q1 
\v 23 Slušajte, i čujte glas moj,
\q2 pazite i čujte besedu moju.
\q1 
\v 24 Ore li orač svaki dan da poseje?
\q2 Ili brazdi i povlači njivu svoju?
\q1 
\v 25 Kad poravni odozgo,
\q2 ne seje li grahor i kim?
\q1 I ne meće li pšenicu na najbolje mesto,
\q2 i ječam na zgodno mesto,
\q2 i krupnik na njegovo mesto?
\q1 
\v 26 I Bog ga njegov uči
\q2 i upućuje kako će raditi.
\b
\q1 
\v 27 Jer se grahor ne vrše branom,
\q2 niti se točak kolski obrće po kimu,
\q2 nego se cepom mlati grahor i kim prutom.
\q1 
\v 28 Pšenica se vrše, ali neće jednako vreći
\q2 niti će je satrti točkom kolskim na zupcima razdrobiti.
\q1 
\v 29 I to dolazi od Gospoda nad vojskama,
\q2 koji je divan u savetu, velik u mudrosti.
\c 29
\s1 Jerusalim će se pritesniti i potom će se spasti. Narod će zaslepeti. Čudna promena.
\q1 
\v 1 Teško Arilu,
\q2 Arilu, gradu gde je stajao David.
\q1 Dodajte godinu na godinu,
\q2 neka kolju žrtve praznične.
\q1 
\v 2 Ali ću pritesniti Arila,
\q2 i biće žalost i tuga,
\q2 jer će mi biti kao Aril.
\q1 
\v 3 Jer ću te opkoliti vojskom,
\q2 i stegnuću te opkopima
\q2 i podignuću suprot tebi kule.
\q1 
\v 4 Te ćeš oboren govoriti sa zemlje
\q2 i iz praha ćeš mucati,
\q1 i glas će ti biti sa zemlje kao u bajača
\q2 i iz praha ćeš šapćući govoriti.
\b
\q1 
\v 5 A mnoštvo neprijatelja tvojih biće kao sitan prah
\q2 i mnoštvo nasilnika kao pleva kad se razmeće;
\q1 i to će biti začas, iznenada.
\q2 
\v 6 Gospod nad vojskama pohodiće ga gromom i trusom i hukom velikom,
\q2 vihorom i burom i plamenom ognjenim koji proždire.
\q1 
\v 7 I mnoštvo svih naroda koji vojuju na Aril
\q2 i svi koji udaraju na nj i na zidove njegove
\q1 i koji ga pritešnjuju,
\q2 biće kao utvara noćna u snu.
\q1 
\v 8 Biće kao kad gladan sni da jede,
\q2 pa kad se probudi a duša mu prazna;
\q1 ili kad sni žedan da pije,
\q2 pa kad se probudi, a on iznemogao i duša mu žedna;
\q1 tako će biti mnoštvo svih naroda što vojuju na goru sionsku.
\b
\q1 
\v 9 Stanite i čudite se;
\q2 vapijte i vičite:
\q1 Pijani su, ali ne od vina;
\q2 posrću, ali ne od silovitog pića.
\q1 
\v 10 Jer je Gospod izlio na vas duh tvrdog sna
\q2 i zatvorio vam oči,
\q1 oslepio proroke i videoce,
\q2 glavare vaše.
\b
\p 
\v 11 I svaka utvara biće vam kao reči u zapečaćenoj knjizi, koju daju čoveku koji zna čitati govoreći: Čitaj to; a on reče: Ne mogu, jer je zapečaćeno.
\v 12 Ili da daju knjigu onom koji ne zna čitati govoreći: Čitaj to; a on reče: Ne znam čitati.
\b
\q1 
\v 13 Zato reče Gospod:
\q1 Što se ovaj narod približuje ustima svojim
\q2 i usnama svojim poštuje me,
\q1 a srce im daleko stoji od mene,
\q2 i strah kojim me se boje zapovest je ljudska kojoj su naučeni,
\q1 
\v 14 Zato ću evo još raditi čudesno s tim narodom,
\q2 čudesno i divno,
\q1 i mudrost mudrih njegovih poginuće
\q2 i razum razumnih nestaće.
\b
\q1 
\v 15 Teško onima koji duboko sakrivaju od Gospoda nameru,
\q2 koji rade u mraku i govore:
\q2 Ko nas vidi? I ko nas zna?
\q1 
\v 16 Naopake misli vaše nisu li kao kao lončarski?
\q2 Govori li delo za onog koji ga je načinio: Nije me načinio?
\q2 I lonac govori li za onog koji ga je načinio: Ne razume?
\b
\q1 
\v 17 Neće li se doskora i Livan pretvoriti u polje,
\q2 i polje se uzimati za šumu?
\q1 
\v 18 I u taj će dan gluvi čuti reči u knjizi,
\q2 i iz tame i mraka videće oči slepih.
\q1 
\v 19 I krotki će se veoma radovati u Gospodu,
\q2 i ništi između ljudi veseliće se sa Sveca Izrailjevog.
\q1 
\v 20 Jer nasilnika neće biti,
\q2 i nestaće podsmevača,
\q2 i istrebiće se svi koji gledaju da čine bezakonje,
\q1 
\v 21 Koji okrivljuju čoveka za reč,
\q2 i meću zamku onom koji kara na vratima,
\q2 i obaraju pravednog lažju.
\b
\p 
\v 22 Zato Gospod, koji je otkupio Avrama, ovako govori za dom Jakovljev:
\b
\q1 Neće se više Jakov postideti,
\q2 niti će mu lice pobledeti.
\q1 
\v 23 Jer kad vidi usred sebe decu svoju, delo ruku mojih,
\q2 tada će oni svetiti ime moje,
\q1 svetiće Sveca Jakovljevog
\q2 i bojaće se Boga Izrailjevog.
\q1 
\v 24 I koji lutaju duhom orazumiće se,
\q2 i vikači će primiti nauku.
\c 30
\s1 Teško onim koji pobegnu u Misir! Blago onim koji se uzdaju u Gospoda! Sud Asiru.
\q1 
\v 1 Teško sinovima odmetnicima, govori Gospod,
\q2 koji sastavljaju namere koje nisu od mene,
\q1 zaklanjaju se za zaklon koji nije od mog Duha,
\q2 da domeću greh na greh;
\q1 
\v 2 Koji silaze u Misir ne pitajući šta ću ja reći,
\q2 da se ukrepe silom Faraonovom
\q2 i da se zaklone pod senkom misirskom.
\q1 
\v 3 Jer će vam sila Faraonova biti na sramotu,
\q2 i zaklon pod senkom misirskom na porugu.
\q1 
\v 4 Jer knezovi njegovi biše u Soanu,
\q2 i poslanici njegovi dođoše u Hanes.
\q1 
\v 5 Ali će se svi posramiti s naroda,
\q2 koji im neće pomoći,
\q1 niti će im biti na korist ni na dobit,
\q2 nego na sramotu i na porugu.
\b
\p 
\v 6 Tovar će biti na stoci južnoj:
\b
\q1 u zemlju gde je nevolja i muka,
\q2 gde su lavovi i lavići,
\q2 guje i zmajevi ognjeni krilati,
\q1 odneće blago svoje magarcima na ramenima
\q2 i bogatstvo svoje kamilama na grbama,
\q2 k narodu koji neće pomoći.
\q1 
\v 7 Jer će Misirci uzalud i naprazno pomagati;
\q1 zato vičem o tom:
\q2 jačina im je da sede s mirom.
\b
\q1 
\v 8 Sada idi, napiši ovo pred njima na daščicu,
\q2 napiši u knjigu,
\q1 da ostane za vremena koja će doći,
\q2 doveka;
\q1 
\v 9 Jer su narod nepokoran,
\q2 sinovi lažljivi,
\q2 sinovi koji neće da slušaju zakon Gospodnji;
\q1 
\v 10 Koji govore videocima:
\q2 Nemojte viđati,
\q1 i prorocima:
\q2 Nemojte nam prorokovati šta je pravo,
\q1 govorite nam mile stvari,
\q2 prorokujte prevaru;
\q1 
\v 11 Svrnite s puta, odstupite od staze,
\q2 neka nestane ispred nas Svetac Izrailjev.
\q1 
\v 12 Zato ovako veli Svetac Izrailjev:
\q1 Kad odbacujete ovu reč,
\q2 i uzdate se u prevaru i opačinu
\q2 i na nju se oslanjate,
\q1 
\v 13 Zato će vam to bezakonje biti kao pukotina u zidu koji hoće da padne,
\q2 koja izdigne zid visoko, te se naglo ujedanput obori.
\q1 
\v 14 I razbiće ga kao što se razbija razbijen sud lončarski,
\q2 ne žali se,
\q1 te se ne nađe ni crepa kad se razbije
\q2 da uzmeš oganj s ognjišta ili da zahvatiš vodu iz jame.
\b
\q1 
\v 15 Jer ovako govori Gospod Gospod, Svetac Izrailjev:
\q1 Ako se povratite i budete mirni,
\q2 izbavićete se,
\q1 u miru i uzdanju biće sila vaša;
\q2 ali vi nećete.
\q1 
\v 16 Nego govorite:
\q1 Ne; nego ćemo na konjima pobeći.
\q2 Zato ćete bežati.
\q1 Pojahaćemo brze konje.
\q2 Zato će biti brži koji će vas terati.
\q1 
\v 17 Bežaće vas hiljadu kad jedan poviče;
\q2 kad poviču petorica, bežaćete svi,
\q1 dok ne ostanete kao okresano drvo navrh gore
\q2 i kao zastava na humu.
\b
\q1 
\v 18 A zato čeka Gospod da se smiluje na vas,
\q2 i zato će se uzvisiti da vas pomiluje;
\q1 jer je Gospod pravedan Bog;
\q2 blago svima koji Ga čekaju.
\b
\p 
\v 19 Jer će narod nastavati u Sionu, u Jerusalimu; nećeš više plakati, doista će te pomilovati kad povičeš; čim te čuje, odazvaće ti se.
\v 20 Premda će vam Gospod dati hleb tužni i vodu nevoljničku; ali ti se više neće uzimati učitelji tvoji, nego će oči tvoje gledati učitelje tvoje,
\v 21 i uši će tvoje slušati reč iza tebe gde govori: To je put, idite njim, ako biste svrnuli nadesno ili nalevo.
\v 22 I oprznićete posrebrene likove svoje rezane i zlatno odelo likova livenih, i bacićete ih kao nečistoću, i reći ćeš im: Odlazite.
\p 
\v 23 I daće dažd semenu tvom koje poseješ na njivi, i hleb od roda zemaljskog biće obilat i sit; tada će stoka tvoja pasti na paši prostranoj.
\v 24 Volovi i magarci, što rade zemlju, ješće čistu zob ovejanu lopatom i rešetom.
\v 25 I na svakoj gori visokoj i na svakom humu visokom biće izvori i potoci, kad bude pokolj veliki, kad popadaju kule.
\v 26 I svetlost će mesečeva biti kao svetlost sunčeva, a svetlost će sunčeva biti sedam puta veća, kao svetlost od sedam dana, kad Gospod zavije ulom narodu svom i isceli rane koje mu je zadao.
\b
\q1 
\v 27 Gle, ime Gospodnje ide izdaleka,
\q2 gnev Njegov gori i vrlo je težak;
\q1 usne su Mu pune ljutine
\q2 i jezik Mu je kao oganj koji sažiže.
\q1 
\v 28 A Duh Mu je kao potok koji plavi i dopire do grla,
\q2 da raseje narode da odu u ništa,
\q1 i biće u čeljustima narodima uzda
\q2 koja će ih goniti da lutaju.
\b
\p 
\v 29 Pevaćete kao noću uoči praznika, i veselićete se od srca kao onaj koji ide sa sviralom na goru Gospodnju, k steni Izrailjevoj,
\v 30 i Gospod će pustiti da se čuje slava glasa Njegovog, i pokazaće kako maše rukom svojom s ljutim gnevom i plamenom ognjenim koji proždire, s rasapom i sa silnim daždem i s gradom.
\v 31 Jer će se od glasa Gospodnjeg prepasti Asirac, koji je bio palicom.
\v 32 I kuda god prođe palica pouzdana, kojom će Gospod navaliti na nj, biće bubnji i gusle, i ratovima žestokim ratovaće na njih.
\v 33 Jer je već pripravljen Tofet, i samom caru pripravljen je, načinio je dubok i širok; mesta, ognja i drva ima mnogo; dah Gospodnji kao potok sumporni upaliće ga.
\c 31
\s1 Slaba pomoć od Misira. Božija pomoć u borbi s Asircima.
\q1 
\v 1 Teško onima koji idu u Misir za pomoć,
\q2 koji se oslanjaju na konje,
\q1 i uzdaju se u kola što ih je mnogo,
\q2 i u konjanike što ih je veliko mnoštvo,
\q1 a ne gledaju na Sveca Izrailjevog
\q2 i ne traže Gospoda.
\q1 
\v 2 Ali je i on mudar,
\q2 i navući će zlo,
\q2 i neće poreći svoje reči,
\q1 nego će ustati na dom nevaljalih ljudi
\q2 i na one koji pomažu onima koji čine bezakonje.
\q1 
\v 3 A Misirci su ljudi a ne Bog,
\q2 i konji su njihovi telo a ne Duh;
\q1 i zato će Gospod mahnuti rukom svojom,
\q2 te će pasti pomagač,
\q1 pašće i onaj kome pomaže,
\q2 i svi će zajedno poginuti.
\b
\q1 
\v 4 Jer ovako mi reče Gospod:
\q1 Kao što lav i lavić riče nad lovom svojim,
\q2 i ako se i sviče na nj mnoštvo pastira,
\q1 on se ne plaši od vike njihove
\q2 niti se pokorava na buku njihovu,
\q1 tako će Gospod nad vojskama sići
\q2 da vojuje za goru sionsku i za hum njen.
\q1 
\v 5 Kao ptice krilima
\q2 Gospod će nad vojskama zaklanjati Jerusalim,
\q1 i zaklanjajući izbaviće,
\q2 i obilazeći sačuvaće.
\b
\p 
\v 6 Vratite se k Njemu, od kog se sasvim odvrgoste, sinovi Izrailjevi!
\v 7 Jer će u onaj dan svaki odbaciti idole svoje srebrne, i zlatne svoje idole, koje vam ruke vaše načiniše na greh.
\b
\q1 
\v 8 I Asirac će pasti od mača ne čovečjeg,
\q2 i mač ne čovečji poješće ga,
\q1 i bežaće ispred mača,
\q2 i mladići će njegovi plaćati danak.
\q1 
\v 9 I stena će njegova proći od straha,
\q2 i knezovi će se njegovi prepasti od zastave,
\q1 veli Gospod,
\q2 čiji je oganj na Sionu i peć u Jerusalimu.
\c 32
\s1 Srećne prilike naroda Božijeg pod pravednim carem, ali posle ranije osude.
\q1 
\v 1 Evo, car će carovati pravo
\q2 i knezovi će vladati po pravdi.
\q1 
\v 2 I čovek će biti kao zaklon od vetra,
\q2 i kao utočište od poplave,
\q1 kao potoci na suvom mestu,
\q2 kao sen od velike stene u zemlji sasušenoj.
\q1 
\v 3 I oči onih koji vide neće biti zaslepljene,
\q2 i uši onih koji čuju slušaće.
\q1 
\v 4 I srce nerazumnih razumeće mudrost,
\q2 i jezik mutavih govoriće brzo i razgovetno.
\q1 
\v 5 Nevaljalac se neće više zvati knez,
\q2 niti će se tvrdica nazivati podašnim.
\q1 
\v 6 Jer nevaljalac o nevaljalstvu govori,
\q2 i srce njegovo gradi bezakonje,
\q1 radeći licemerno
\q2 i govoreći na Boga laž,
\q1 da isprazni dušu gladnom
\q2 i napoj žednom da uzme.
\q1 
\v 7 I sprave tvrdičine zle su;
\q1 smišlja lukavštine
\q2 da zatre nište rečima lažnim
\q2 i kad siromah govori pravo.
\q1 
\v 8 Ali knez smišlja kneževski,
\q2 i ustaje da radi kneževski.
\b
\q1 
\v 9 Ustanite, žene mirne,
\q2 slušajte glas moj;
\q1 kćeri bezbrižne,
\q2 čujte reči moje.
\q1 
\v 10 Za mnogo godina bićete u smetnji,
\q2 vi bezbrižne;
\q1 jer neće biti berbe,
\q2 i sabiranje neće doći.
\q1 
\v 11 Strašite se, vi mirne;
\q2 drhtite, vi bezbrižne,
\q1 svucite se, budite gole,
\q2 i pripašite oko sebe kostret,
\q1 
\v 12 Bijući se u prsa za lepim njivama,
\q2 za rodnim čokotima.
\q1 
\v 13 Trnje i čkalj niknuće na zemlji naroda mog,
\q2 i po svim kućama veselim, u gradu veselom.
\q1 
\v 14 Jer će se dvorovi ostaviti,
\q2 vreva gradska nestaće;
\q1 kule i stražare postaće pećine doveka,
\q2 radost divljim magarcima i paša stadima,
\q1 
\v 15 Dokle se ne izlije na nas Duh s visine
\q2 i pustinja postane njiva
\q2 a njiva se stane uzimati za šumu.
\q1 
\v 16 Tada će sud stanovati u pustinji,
\q2 i pravda će stajati na njivi.
\q1 
\v 17 I mir će biti delo pravde,
\q2 šta će pravda učiniti biće pokoj i bezbrižnost doveka.
\q1 
\v 18 I moj će narod sedeti u mirnom stanu
\q2 i u šatorima pouzdanim,
\q2 na počivalištima tihim.
\q1 
\v 19 Ali će grad pasti na šumu,
\q2 i grad će se vrlo sniziti.
\q1 
\v 20 Blago vama koji sejete pokraj svake vode,
\q2 i puštate volove i magarce.
\c 33
\s1 Narodu Božijem, koji jadikuje, obriče se propast neprijatelja, grešnicima na strah, a vernim na radost.
\q1 
\v 1 Teško tebi, koji pustošiš a tebe ne pustoše,
\q2 i koji činiš neveru a tebi se ne čini nevera;
\q1 kad prestaneš pustošiti, bićeš opustošen,
\q2 kad prestaneš činiti neveru, činiće ti se nevera.
\b
\q1 
\v 2 Gospode, smiluj se na nas,
\q2 Tebe čekamo;
\q1 budi im mišica svako jutro,
\q2 i spasenje naše u nevolji.
\q1 
\v 3 Narodi pobegoše od jake vike,
\q2 rasejaše se narodi što se ti podiže.
\q1 
\v 4 I pokupiće se plen vaš kao što se kupe gusenice,
\q2 skočiće na nj kao što skaču skakavci.
\b
\q1 
\v 5 Uzvišen je Gospod, jer nastava na visini;
\q2 napuniće Sion suda i pravde.
\q1 
\v 6 I tvrđa vremena tvog, sila spasenja tvog biće mudrost i znanje;
\q2 strah Gospodnji biće blago tvoje.
\b
\q1 
\v 7 Eto, junaci njihovi viču na polju,
\q2 i poslanici mirni plaču gorko:
\q1 
\v 8 Putevi opusteše,
\q2 putnici ne putuju;
\q1 pokvari ugovor,
\q2 odbaci gradove,
\q2 ne mari za čoveka.
\q1 
\v 9 Zemlja tuži i čezne,
\q2 Livan se stidi i vene,
\q1 Saron je kao pustinja,
\q2 Vasan i Karmil ogoleše.
\b
\q1 
\v 10 Sada ću ustati, veli Gospod,
\q2 sada ću se uzvisiti, sada ću se podignuti.
\q1 
\v 11 Zatrudnećete slamom, rodićete strnjiku;
\q2 gnev vaš proždreće vas kao oganj.
\q1 
\v 12 I narodi će biti kao peći krečne,
\q2 izgoreće ognjem kao trnje posečeno.
\b
\q1 
\v 13 Slušajte koji ste daleko šta sam učinio,
\q2 i koji ste blizu poznajte moć moju.
\q1 
\v 14 Grešnici u Sionu uplašiće se,
\q2 drhat će spopasti licemere,
\q2 i reći će:
\q1 Ko će od nas ostati kod ognja koji proždire?
\q2 Ko će od nas ostati kod večne žege?
\q1 
\v 15 Ko hodi u pravdi
\q2 i govori šta je pravo;
\q1 ko mrzi na dobitak od nasilja;
\q2 ko otresa ruke svoje da ne primi poklon;
\q1 ko zatiskuje uši svoje da ne čuje za krv,
\q2 i zažima oči svoje da ne vidi zlo;
\q1 
\v 16 On će nastavati na visokim mestima;
\q2 gradovi na stenama biće mu utočište,
\q1 hleb će mu se davati,
\q2 voda mu neće nedostajati.
\b
\q1 
\v 17 Oči će ti videti cara u krasoti njegovoj,
\q2 gledaće zemlju daleku.
\q1 
\v 18 Srce će tvoje misliti o strahu govoreći:
\q2 Gde je pisar?
\q1 Gde brojač?
\q2 Gde je onaj što pregleda kule?
\q1 
\v 19 Nećeš videti žestok narod,
\q2 narod koji govori iz dubina da se ne razbira,
\q2 u koga je jezik mutav da se ne razume.
\q1 
\v 20 Pogledaj na Sion,
\q2 grad praznika naših;
\q1 oči tvoje neka vide Jerusalim,
\q2 mirni stan,
\q1 šator, koji se neće odneti,
\q2 kome se kolje neće nikada pomeriti,
\q2 i nijedno mu se uže neće otkinuti.
\q1 
\v 21 Nego će nam onde Gospod veliki biti mesto reka i potoka širokih,
\q2 po kojima neće ići lađa s veslima,
\q2 niti će velika lađa prolaziti onuda.
\q1 
\v 22 Jer je Gospod naš sudija,
\q2 Gospod je koji nam postavlja zakone,
\q1 Gospod je car naš,
\q2 On će nas spasti.
\b
\q1 
\v 23 Oslabiše tvoja uža,
\q2 ne mogu tvrdo držati katarke svoje
\q2 ni razapeti jedra;
\q1 tada će se razdeliti velik plen,
\q2 hromi će razgrabiti plen.
\q1 
\v 24 I niko od stanovnika neće reći:
\q2 Bolestan sam.
\q1 Narodu koji živi u njemu oprostiće se bezakonje.
\c 34
\s1 Božiji sud svim neprijateljima njegovog naroda, osobito Edomu.
\q1 
\v 1 Pristupite, narodi, da čujete;
\q2 pazite, narodi;
\q1 neka čuje zemlja i šta je u njoj,
\q2 vasiljena i šta se god rađa u njoj.
\q1 
\v 2 Jer se Gospod razgnevio na sve narode,
\q2 i razljutio se na svu vojsku njihovu,
\q1 zatrće ih,
\q2 predaće ih na pokolj.
\q1 
\v 3 I pobijeni njihovi baciće se,
\q2 i od mrtvaca njihovih dizaće se smrad
\q2 i gore će se rasplinuti od krvi njihove.
\q1 
\v 4 I sva će se vojska nebeska rastopiti,
\q2 i saviće se nebesa kao knjiga,
\q1 i sva vojska njihova popadaće
\q2 kao što pada list s vinove loze
\q2 i kao što pada sa smokve.
\b
\q1 
\v 5 Jer je opojen na nebu mač moj,
\q1 evo, sići će na sud na Edomce
\q2 i na narod koji sam prokleo da se zatre.
\q1 
\v 6 Mač je Gospodnji pun krvi
\q2 i tovan od pretiline,
\q1 od krvi jagnjeće i jarčije,
\q2 od pretiline bubrega ovnujskih;
\q1 jer Gospod ima žrtvu u Vosoru
\q2 i veliko klanje u zemlji edomskoj.
\q1 
\v 7 I jednorozi će sići s njima
\q2 i junci s bikovima;
\q1 zemlja će se njihova opiti od krvi
\q2 i prah će njihov utiti od pretiline.
\b
\q1 
\v 8 Jer će biti dan osvete Gospodnje,
\q2 godina plaćanja,
\q2 da bi se osvetio Sion.
\q1 
\v 9 I potoci će se njeni pretvoriti u smolu,
\q2 i prah njen u sumpor,
\q2 i zemlja će njihova postati smola razgorela.
\q1 
\v 10 Neće se gasiti ni noću ni danju,
\q2 doveka će se dizati dim njen,
\q1 od kolena do kolena ostaće pusta,
\q2 niko neće prelaziti preko nje doveka.
\q1 
\v 11 Nego će je naslediti gem i ćuk,
\q2 sova i gavran naseliće se u njoj,
\q1 i Gospod će rastegnuti preko nje uže pogibli
\q2 i merila pustoši.
\q1 
\v 12 Plemiće njene zvaće da caruju,
\q2 ali neće biti nijednog,
\q2 i svi će knezovi njeni otići u ništa.
\b
\q1 
\v 13 I trnje će izniknuti u dvorima njihovim,
\q2 kopriva i čkalj u gradovima njihovim,
\q1 i biće stan zmajevima
\q2 i naselje sovama.
\q1 
\v 14 I sretaće se divlje zveri s buljinama,
\q2 aveti će se dovikivati,
\q2 onde će se naseliti veštice i naći počivalište.
\b
\q1 
\v 15 Onde će se gnezditi ćuk i nositi jaja
\q2 i leći ptiće i sabirati ih pod sen svoj;
\q1 onde će se sastajati i jastrebovi jedan s drugim.
\q1 
\v 16 Tražite u knjizi Gospodnjoj i čitajte,
\q2 ništa od ovog neće izostati
\q2 i nijedno neće biti bez drugog;
\q1 jer šta kažem, On je zapovedio,
\q2 i Duh će ih Njegov sabrati.
\q1 
\v 17 Jer im On baci žreb,
\q2 i ruka Njegova razdeli im zemlju užem,
\q1 i njihova će biti doveka,
\q2 od kolena do kolena nastavaće u njoj.
\c 35
\s1 Dobro naroda Božijeg posle podnesenih muka.
\q1 
\v 1 Radovaće se tome pustinja i zemlja sasušena,
\q2 veseliće se pustoš i procvetati kao ruža.
\q1 
\v 2 Procvetaće obilno,
\q2 i veseliće se radujući se i popevajući;
\q1 slava livanska daće joj se
\q2 i krasota karmilska i saronska;
\q1 ta će mesta videti slavu Gospodnju,
\q2 krasotu Boga našeg.
\b
\q1 
\v 3 Ukrepite klonule ruke,
\q2 i kolena iznemogla utvrdite.
\q1 
\v 4 Recite onima kojima se srce uplašilo:
\q1 Ohrabrite se, ne bojte se;
\q2 evo Boga vašeg;
\q1 osveta ide, plata Božja,
\q2 sam ide, i spašće vas.
\b
\q1 
\v 5 Tada će se otvoriti oči slepima,
\q2 i uši gluvima otvoriće se.
\q1 
\v 6 Tada će hromi skakati kao jelen,
\q2 i jezik nemog pevaće,
\q1 jer će u pustinji provreti vode
\q2 i potoci u zemlji sasušenoj.
\q1 
\v 7 I suvo će mesto postati jezero,
\q2 i zemlja sasušena izvori vodeni,
\q1 u stanu zmajevskom, po ložama njihovim,
\q2 biće trava, trska i sita.
\b
\q1 
\v 8 I onde će biti nasap i put,
\q2 koji će se zvati sveti put;
\q1 neće ići po njemu nečisti,
\q2 nego će biti za njih;
\q1 ko uzide njim,
\q2 ni lud neće zaći.
\q1 
\v 9 Neće onde biti lava,
\q2 i ljuta zver neće ići po njemu,
\q2 niti će se onde naći,
\q1 nego će hoditi izbavljeni.
\q1 
\v 10 I koje iskupi Gospod,
\q2 vratiće se i doći će u Sion pevajući,
\q1 i večna će radost biti nad glavom njihovom,
\q2 dobiće radost i veselje,
\q2 a žalost i uzdisanje bežaće.
\c 36
\s1 Senahirim opkoljava Jerusalim.
\p 
\v 1 Četrnaeste godine carovanja Jezekijinog podiže se Senahirim car asirski na sve tvrde gradove Judine, i uze ih.
\v 2 I posla car asirski Ravsaka iz Lahisa u Jerusalim k caru Jezekiji s velikom vojskom; i on stade kod jaza gornjeg jezera na putu kod polja beljarevog.
\v 3 Tada izađe k njemu Elijakim sin Helkijin, koji beše nad dvorom, i Somna pisar i Joah sin Asafov pametar.
\p 
\v 4 I reče im Ravsak: Kažite Jezekiji: Ovako kaže veliki car, car asirski: Kakva je to uzdanica u koju se uzdaš?
\v 5 Da kažem, ali su prazne reči, da imaš saveta i sile za rat. U šta se dakle uzdaš, te si se odmetnuo od mene?
\v 6 Gle, uzdaš se u štap od trske slomljene, u Misir, na koji ako se ko nasloni, ući će mu u ruku i probošće je; takav je Faraon car misirski svima koji se uzdaju u nj.
\v 7 Ako li mi kažeš: Uzdamo se u Gospoda Boga svog; nije li to onaj čije je visine i oltare oborio Jezekija i zapovedio Judi i Jerusalimu: Pred ovim oltarom klanjajte se?
\v 8 Hajde zateci se mom gospodaru, caru asirskom, i daću ti dve hiljade konja, ako možeš dobaviti koji će jahati.
\v 9 Kako ćeš dakle odbiti i jednog vojvodu između najmanjih slugu gospodara mog? Ali se ti uzdaš u Misir za kola i konjike.
\v 10 Svrh toga, eda li sam ja bez Gospoda došao na ovo mesto da ga zatrem? Gospod mi je rekao: Idi na tu zemlju, i zatri je.
\p 
\v 11 Tada Elijakim i Somna i Joah rekoše Ravsaku: Govori slugama svojim sirski, jer razumemo, a nemoj nam govoriti judejski da sluša narod na zidu.
\v 12 A Ravsak reče: Eda li me je gospodar moj poslao ka gospodaru tvom ili k tebi da kažem ove reči? Nije li k tim ljudima, što sede na zidu, da jedu svoju nečist i da piju svoju mokraću s vama?
\p 
\v 13 Tada stade Ravsak i povika glasno judejski i reče: Čujte reči velikog cara asirskog.
\v 14 Ovako kaže car: Nemojte da vas vara Jezekija, jer vas ne može izbaviti.
\v 15 Nemojte da vas nagovori Jezekija da se pouzdate u Gospoda, govoreći: Gospod će nas izbaviti, ovaj se grad neće dati u ruke caru asirskom.
\v 16 Ne slušajte Jezekiju; jer ovako kaže car asirski: Učinite mir sa mnom i hodite k meni, pa jedite svaki sa svog čokota i svaki sa svoje smokve, i pijte svaki iz svog studenca,
\v 17 dokle ne dođem i odnesem vas u zemlju kao što je vaša, u zemlju obilnu žitom i vinom, u zemlju obilnu hlebom i vinogradima.
\v 18 Nemojte da vas vara Jezekija govoreći: Gospod će nas izbaviti. Je li koji između bogova drugih naroda izbavio svoju zemlju iz ruke cara asirskog?
\v 19 Gde su bogovi ematski i arfadski? Gde su bogovi sefarvimski? Jesu li izbavili Samariju iz mojih ruku?
\v 20 Koji su između svih bogova ovih zemalja izbavili zemlju svoju iz moje ruke? A Gospod će izbaviti Jerusalim iz moje ruke?
\p 
\v 21 Ali oni ćutahu, i ne odgovoriše mu ni reči, jer car beše zapovedio i rekao: Ne odgovarajte mu.
\v 22 Tada Elijakim sin Helkijin, koji beše nad dvorom, i Somna pisar i Joah sin Asafov, pametar, dođoše k Jezekiji razdrevši haljine, i kazaše mu reči Ravsakove.
\c 37
\s1 Senahirimova se sila posle molitve Jezekijine za noć razbija.
\p 
\v 1 A kad to ču car Jezekija, razdre haljine svoje i veza oko sebe kostret, pa otide u dom Gospodnji.
\v 2 I posla Elijakima, koji beše nad dvorom, i Somnu pisara i najstarije sveštenike obučene u kostret k Isaiji proroku sinu Amosovom.
\v 3 I rekoše mu: Ovako veli Jezekija: Ovo je dan nevolje i kara i ruga, jer prispeše deca do porođaja, a nema snage da se rode.
\v 4 Da ako je čuo Gospod Bog tvoj što reče Ravsak, koga posla car asirski gospodar njegov da ruži Boga Živog i da Ga vređa rečima koje je čuo Gospod Bog tvoj, pomoli se za ostatak koji se nalazi.
\p 
\v 5 I dođoše k Isaiji sluge cara Jezekije.
\v 6 I reče im Isaija: Ovako recite gospodaru svom: Ovako veli Gospod: Ne plaši se od reči koje si čuo, kojima huliše na me sluge cara asirskog.
\v 7 Evo, ja ću pustiti na nj duh, te će čuti glas i vratiti se u svoju zemlju, i učiniću da pogine od mača u svojoj zemlji.
\p 
\v 8 I tako vrativši se Ravsak nađe cara asirskog gde bije Livnu, jer beše čuo da je otišao od Lahisa.
\v 9 A on ču za Tiraku cara huskog gde kazaše: Ide da se bije s tobom. I čuvši posla poslanike k Jezekiji govoreći:
\v 10 Ovako recite Jezekiji caru Judinom: Nemoj da te vara Bog tvoj, u koga se uzdaš govoreći: Neće se dati Jerusalim u ruke caru asirskom.
\v 11 Eto, čuo si šta su učinili carevi asirski svim zemljama potrvši ih sasvim; a ti li ćeš se izbaviti?
\v 12 Jesu li narode koje satrše oci moji izbavili bogovi njihovi, Gosance, Harance, Resefe i sinove Edenove koji behu u Telasaru?
\v 13 Gde je car ematski i car arfadski i car od grada Sefarvima, od Ene i Ave?
\b
\p 
\v 14 A kad Jezekija primi knjigu iz ruku poslanika i pročita je, otide u dom Gospodnji, i razvi je Jezekija pred Gospodom.
\v 15 I pomoli se Jezekija Gospodu govoreći:
\v 16 Gospode nad vojskama, Bože Izrailjev, koji sediš na heruvimima, Ti si sam Bog svim carstvima na zemlji, Ti si stvorio nebo i zemlju.
\v 17 Prigni, Gospode, uho svoje i čuj; otvori, Gospode, oči svoje i vidi; čuj sve reči Senahirima, koji posla da ruži Boga Živog.
\v 18 Istina je, opustošili su carevi asirski sve one narode i zemlje njihove,
\v 19 i pobacali su bogove njihove u oganj, jer ne behu bogovi, nego delo ruku čovečjih, drvo i kamen, zato ih potrše.
\v 20 I zato, Gospode Bože naš, izbavi nas iz ruku njegovih, da poznaju sva carstva na zemlji da si Ti sam Gospod.
\b
\p 
\v 21 Tada posla Isaija sin Amosov k Jezekiji i poruči mu: Ovako veli Gospod Bog Izrailjev: Uslišio sam za šta si mi se molio radi Senahirima cara asirskog.
\v 22 Ovo je reč koju izreče Gospod za nj:
\b
\q1 Ruga ti se i podsmeva ti se devojka, kći sionska,
\q2 za tobom maše glavom kći jerusalimska.
\q1 
\v 23 Koga si ružio i hulio?
\q2 I na koga si podigao glas?
\q2 I podigao uvis oči svoje?
\q1 Na Sveca Izrailjevog.
\q1 
\v 24 Preko sluga svojih ružio si Gospoda i rekao si:
\q1 S mnoštvom kola svojih izađoh na visoke gore,
\q2 na strane livanske,
\q1 i poseći ću visoke kedre njegove,
\q2 i lepe jele njegove,
\q1 i doći ću na najviši kraj njegov,
\q2 u šumu njegovog Karmila.
\q1 
\v 25 Ja sam kopao, i pio vodu,
\q2 i isušio sam stopama svojim sve potoke gradovima.
\b
\q1 
\v 26 Nisi li čuo da ja to odavna činim
\q2 i od iskona da sam tako uredio?
\q1 Sada puštam to,
\q2 da prevratiš tvrde gradove u puste gomile.
\q1 
\v 27 Zato koji u njima žive iznemogoše,
\q2 uplašiše se i smetoše se,
\q1 postaše kao trava poljska,
\q2 kao zelena travica,
\q1 kao trava na krovovima,
\q2 koja se suši pre nego sazri.
\b
\q1 
\v 28 Znam seđenje tvoje
\q2 i polaženje tvoje i dolaženje tvoje
\q2 i kako besniš na me.
\q1 
\v 29 Jer besniš na me,
\q2 i tvoja obest dođe do mojih ušiju,
\q1 zato ću metnuti brnjicu svoju na nozdrve tvoje,
\q2 i uzdu svoju u gubicu tvoju,
\q2 pa ću te odvesti natrag putem kojim si došao.
\b
\p 
\v 30 A tebi ovo neka bude znak: ješćete ove godine šta samo od sebe rodi, a druge godine šta opet samo od sebe rodi; a treće godine sejte i žanjite i sadite vinograde i jedite rod iz njih.
\v 31 Jer ostatak doma Judinog, što ostane, opet će pustiti žile ozdo i roditi ozgo.
\v 32 Jer će iz Jerusalima izaći ostatak, i iz gore Siona, koji se sačuvaju. Revnost Gospoda nad vojskama učiniće to.
\p 
\v 33 Zato ovako veli Gospod za cara asirskog: Neće ući u ovaj grad, niti će baciti amo strele, neće se primaći k njemu sa štitom, niti će iskopati opkope oko njega.
\v 34 Vratiće se putem kojim je došao, a u grad ovaj neće ući, veli Gospod.
\v 35 Jer ću braniti taj grad i sačuvaću ga sebe radi i radi Davida sluge svog.
\p 
\v 36 Tada izađe anđeo Gospodnji i pobi u logoru asirskom sto i osamdeset i pet hiljada; i kad ustaše ujutru, a to sve sami mrtvaci.
\v 37 Te se podiže Senahirim car asirski, i otide, i vrativši se osta u Nineviji.
\v 38 I kad se klanjaše u domu Nisroka boga svog, Adrameleh i Sarasar sinovi njegovi ubiše ga mačem, a sami pobegoše u zemlju araratsku, i na njegovo se mesto zacari Esaradon, sin njegov.
\c 38
\s1 Jezekija se razboljeva, ozdravlja i hvali Boga.
\p 
\v 1 U to vreme razbole se Jezekija na smrt; i dođe k njemu prorok Isaija sin Amosov i reče mu: Ovako veli Gospod: Naredi za kuću svoju, jer ćeš umreti i nećeš ostati živ.
\v 2 A Jezekija se okrete licem k zidu, i pomoli se Gospodu,
\v 3 i reče: Oh, Gospode, opomeni se da sam jednako hodio pred Tobom verno i s celim srcem, i tvorio šta je Tebi ugodno. I plaka Jezekija veoma.
\p 
\v 4 Tada dođe reč Gospodnja Isaiji govoreći:
\v 5 Idi i reci Jezekiji: Ovako veli Gospod Bog Davida oca tvog: Čuo sam molitvu tvoju, i video sam suze tvoje, evo dodaću ti veku petnaest godina.
\v 6 I izbaviću tebe i ovaj grad iz ruku cara asirskog, i braniću ovaj grad.
\p 
\v 7 I ovo neka ti bude znak od Gospoda da će učiniti Gospod šta je rekao.
\v 8 Evo ja ću vratiti sen po kolencima po kojima je sišao na sunčaniku Ahazovom natrag za deset kolenaca. I vrati se sunce za deset kolenaca po kolencima po kojima beše sišlo.
\b
\p 
\v 9 Ovo napisa Jezekija car Judin kad se razbole, i ozdravi od bolesti svoje:
\b
\q1 
\v 10 Ja rekoh, kad se presekoše dani moji:
\q2 Idem k vratima grobnim,
\q2 uze mi se ostatak godina mojih.
\q1 
\v 11 Rekoh:
\q2 Neću videti Gospoda Gospoda u zemlji živih,
\q2 neću više videti čoveka među onima koji stanuju na svetu.
\q1 
\v 12 Vek moj prođe
\q2 i prenese se od mene kao šator pastirski;
\q1 presekoh život svoj kao tkač,
\q2 odseći će me od osnutka;
\q2 od jutra do večera učinićeš mi kraj.
\q1 
\v 13 Mišljah za jutra da će kao lav potrti sve kosti moje;
\q2 od jutra do večera učinićeš mi kraj.
\b
\q1 
\v 14 Pištah kao ždral i kao lastavica,
\q2 ukah kao golubica,
\q1 oči mi iščileše gledajući gore:
\q2 Gospode, u nevolji sam, olakšaj mi.
\q1 
\v 15 Šta da kažem?
\q1 On mi kaza, i učini.
\q2 Proživeću sve godine svoje po jadu duše svoje.
\b
\q1 
\v 16 Gospode, o tom se živi
\q2 i u tom je svemu život duha mog,
\q2 iscelio si me i sačuvao u životu.
\q1 
\v 17 Evo, na mir dođe mi ljut jad;
\q1 ali Tebi bi milo da izvučeš dušu moju iz jame pogibli,
\q2 jer si bacio za leđa svoja sve grehe moje.
\q1 
\v 18 Jer neće grob Tebe slaviti,
\q2 neće Te smrt hvaliti,
\q2 i koji siđu u grob ne nadaju se Tvojoj istini.
\q1 
\v 19 Živi, živi, oni će Te slaviti kao ja danas:
\q2 otac će sinovima javljati istinu Tvoju.
\b
\q1 
\v 20 Gospod me spase,
\q2 zato ćemo pevati pesme moje
\q2 u domu Gospodnjem dok smo god živi.
\b
\p 
\v 21 A Isaija beše rekao da uzmu grudu suvih smokava i previju na otok, te će ozdraviti.
\v 22 I Jezekija beše rekao: Šta će biti znak da ću otići u dom Gospodnji?
\c 39
\s1 Jezekiji se obećava kazna.
\p 
\v 1 U to vreme Merodah-Valadan, sin Valadanov, car vavilonski, posla knjigu s darom Jezekiji; jer beše čuo da je bio bolestan i ozdravio.
\v 2 I Jezekija se obradova tome, i pokaza im sve riznice svoje, srebro i zlato i mirise, i najbolje ulje, i kuću gde mu beše oružje, i šta se god nalažaše u riznicama njegovim, ne osta ništa da im ne pokaza Jezekija u kući svojoj i u svemu gospodstvu svom.
\v 3 Tada dođe prorok Isaija k caru Jezekiji i reče mu: Šta su govorili ti ljudi i odakle su došli k tebi? A Jezekija reče: Iz daleke zemlje došli su k meni, iz Vavilona.
\v 4 A on reče: Šta su videli u tvom dvoru? A Jezekija reče: Videli su sve što ima u mom dvoru; nije ostalo ništa u riznicama mojim da im nisam pokazao.
\p 
\v 5 Tada reče Isaija Jezekiji: Čuj reč Gospoda nad vojskama.
\v 6 Evo doći će vreme kad će se odneti u Vavilon sve što ima u kući tvojoj, i što su sabirali oci tvoji do danas, neće ostati ništa, veli Gospod.
\v 7 I sinove tvoje, koji će izaći od tebe, koje ćeš roditi, uzeće da budu dvorani u dvoru cara vavilonskog.
\v 8 A Jezekija reče Isaiji: Dobra je reč Gospodnja koju si rekao. Još reče: Je li? Za mog veka biće mir i vera?
\c 40
\s1 Gospod dolazi da spase svoj narod. Gospod je neizmerno moćan i slavan.
\q1 
\v 1 Tešite, tešite narod moj,
\q2 govori Bog vaš.
\q1 
\v 2 Govorite Jerusalimu ljubazno,
\q2 i javljajte mu da se navršio rok njegov,
\q2 da mu se bezakonje oprostilo,
\q1 jer je primio iz ruke Gospodnje dvojinom za sve grehe svoje.
\b
\q1 
\v 3 Glas je nekoga koji viče:
\q2 Pripravite u pustinji put Gospodnji,
\q2 poravnite u pustoši stazu Bogu našem.
\q1 
\v 4 Sve doline neka se povise,
\q2 i sve gore i bregovi neka se slegnu,
\q1 i što je krivo neka bude pravo,
\q2 i neravna mesta neka budu ravna.
\q1 
\v 5 I javiće se slava Gospodnja,
\q2 i svako će telo videti;
\q1 jer usta Gospodnja govoriše.
\b
\q1 
\v 6 Glas govori: Viči.
\q2 I reče: Šta da vičem?
\q1 Da je svako telo trava
\q2 i sve dobro njegovo kao cvet poljski.
\q1 
\v 7 Suši se trava, cvet opada kad duh Gospodnji dune na nj;
\q2 doista je narod trava.
\q1 
\v 8 Suši se trava, cvet opada;
\q2 ali reč Boga našeg ostaje doveka.
\b
\q1 
\v 9 Izađi na visoku goru, Sione,
\q2 koji javljaš dobre glasove;
\q1 podigni silno glas svoj, Jerusalime,
\q2 koji javljaš dobre glasove;
\q2 podigni, ne boj se.
\q1 Kaži gradovima Judinim:
\q2 Evo Boga vašeg.
\q1 
\v 10 Evo, Gospod Bog ide na jakog,
\q2 i mišica će Njegova ovladati njim;
\q1 evo plata je njegova kod Njega
\q2 i delo njegovo pred Njim.
\q1 
\v 11 Kao pastir pašće stado svoje;
\q2 u naručje svoje sabraće jaganjce,
\q1 i u nedrima će ih nositi,
\q2 a dojilice će voditi polako.
\b
\q1 
\v 12 Ko je izmerio vodu grstima svojim
\q2 i nebesa premerio peđu?
\q1 Ko je merom izmerio prah zemaljski,
\q2 i gore izmerio na merila i bregove na poteg?
\q1 
\v 13 Ko je upravljao Duhom Gospodnjim?
\q2 Ili Mu bio savetnik i naučio Ga?
\q1 
\v 14 S kim se dogovarao
\q2 i ko Ga je urazumio i naučio putu suda,
\q2 i naučio Ga znanju i pokazao Mu put razuma?
\q1 
\v 15 Gle, narodi su kao kap iz vedra,
\q2 i kao praška na merilima broje se;
\q1 gle, premešta ostrva kao prašak.
\q1 
\v 16 Ni Livan ne bi bio dosta za oganj,
\q2 i životinje njegove ne bi bile dosta za žrtvu paljenicu.
\q1 
\v 17 Svi su narodi kao ništa pred Njim,
\q2 manje negoli ništa i taština vrede Mu.
\b
\q1 
\v 18 S kim ćete dakle izjednačiti Boga?
\q2 I kakvu ćete Mu priliku naći?
\q1 
\v 19 Umetnik lije lik,
\q2 i zlatar ga pozlaćuje,
\q2 i verižice srebrne lije.
\q1 
\v 20 A ko je siromah, te nema šta prineti,
\q2 bira drvo koje ne trune,
\q1 i traži veštog umetnika da načini rezan lik,
\q2 koji se ne pomiče.
\b
\q1 
\v 21 Ne znate li? Ne čujete li?
\q2 Ne kazuje li vam se od iskona?
\q2 Ne razumete li od temelja zemaljskih?
\q1 
\v 22 On sedi nad krugom zemaljskim,
\q2 i njeni su Mu stanovnici kao skakavci;
\q1 On je razastro nebesa kao platno
\q2 i razapeo ih kao šator za stan.
\q1 
\v 23 On obraća knezove u ništa,
\q2 sudije zemaljske čini da su kao taština.
\b
\q1 
\v 24 Kao da nisu posađeni ni posejani,
\q2 i kao da im se stablo nije ukorenilo u zemlji,
\q1 čim dune na njih, posahnu,
\q2 i vihor kao plevu raznese ih.
\b
\q1 
\v 25 S kim ćete me dakle izjednačiti
\q2 da bih bio kao on?
\q2 veli Sveti.
\q1 
\v 26 Podignite gore oči svoje i vidite;
\q2 ko je to stvorio?
\q1 Ko izvodi vojsku svega toga na broj i zove svako po imenu,
\q2 i velike radi sile Njegove i jake moći ne izostaje nijedno?
\b
\q1 
\v 27 Zašto govoriš, Jakove, i kažeš, Izrailju:
\q2 Sakriven je put moj od Gospoda,
\q2 i stvar moja ne izlazi pred Boga mog?
\q1 
\v 28 Ne znaš li?
\q1 Nisi li čuo da Bog večni Gospod,
\q2 koji je stvorio krajeve zemaljske,
\q2 ne sustaje niti se utruđuje?
\q1 Razumu Njegovom nema mere.
\q1 
\v 29 On daje snagu umornom,
\q2 i nejakom umnožava krepost.
\q1 
\v 30 Deca se more i sustaju,
\q2 i mladići padaju;
\q1 
\v 31 Ali koji se nadaju Gospodu, dobijaju novu snagu,
\q2 podižu se na krilima kao orlovi,
\q2 trče i ne sustaju, hode i ne more se.
\c 41
\s1 Bog poziva svog slugu da teši siromahe i da posrami idolopoklonike.
\q1 
\v 1 Umuknite preda mnom, ostrva;
\q2 i narodi neka se potkrepe,
\q1 neka pristupe, i tada neka kažu:
\q2 Hajdemo da se sudimo.
\b
\q1 
\v 2 Ko je podigao pravdu s istoka?
\q2 Ko je dozvao da ide za njim ustopce?
\q1 Ko joj je pokorio narode
\q2 i dao joj vlast nad carevima
\q1 i učinio te su kao prah maču njenom
\q2 i kao razvejana pleva luku njenom?
\q1 
\v 3 Pogna ih, prođe mirno putem,
\q2 kojim ne beše hodao nogama svojim.
\q1 
\v 4 Ko je uradio i učinio to?
\q2 I zove naraštaje od iskona?
\q1 Ja, Gospod,
\q2 prvi i poslednji, ja isti.
\b
\q1 
\v 5 Videše ostrva i uplašiše se,
\q2 krajevi zemaljski zadrhtaše,
\q2 približiše se i dođoše.
\q1 
\v 6 Jedan drugom pomagaše,
\q2 i bratu svom govoraše: Budi hrabar.
\q1 
\v 7 Drvodelja hrabraše zlatara:
\q2 koji kleplje hrabraše onog koji kuje na nakovnju,
\q1 govoreći: Dobro je za spajanje.
\q2 I pritvrđivaše klincima da se ne pomiče.
\b
\q1 
\v 8 Ali ti, Izrailju, slugo moj;
\q2 Jakove, koga izabrah,
\q2 seme Avrama prijatelja mog;
\q1 
\v 9 Ti, koga uzeh s krajeva zemaljskih,
\q2 i između izabranih njenih dozvah te,
\q1 i rekoh ti: Ti si moj sluga,
\q2 ja te izabrah, i ne odbacih tebe;
\q1 
\v 10 Ne boj se, jer sam ja s tobom;
\q2 ne plaši se, jer sam ja Bog tvoj;
\q1 ukrepiću te i pomoći ću ti,
\q2 i podupreću te desnicom pravde svoje.
\b
\q1 
\v 11 Gle, postideće se i posramiće svi koji se ljute na tebe;
\q2 biće kao ništa i izginuće protivnici tvoji.
\q1 
\v 12 Potražićeš suparnike svoje,
\q2 ali ih nećeš naći, biće kao ništa,
\q2 i koji vojuju na te, nestaće ih.
\q1 
\v 13 Jer ja Gospod Bog tvoj držim te za desnicu,
\q2 i kažem ti: Ne boj se, ja ću ti pomagati.
\b
\q1 
\v 14 Ne boj se, crviću Jakovljev, narodiću Izrailjev,
\q2 ja ću ti pomagati,
\q2 govori Gospod i Izbavitelj tvoj, Svetac Izrailjev.
\q1 
\v 15 Gle, učiniću te da budeš kao sprava za vršenje nova sa zupcima:
\q2 vreći ćeš gore i satrćeš ih,
\q2 i brda ćeš obratiti u plevu.
\q1 
\v 16 Vijaćeš ih, i vetar će ih odneti
\q2 i vihor će ih rasuti,
\q1 a ti ćeš se veseliti u Gospodu
\q2 i hvalićeš se Svecem Izrailjevim.
\b
\q1 
\v 17 Siromahe i uboge,
\q2 koji traže vode a nje nema,
\q2 kojima se jezik osušio od žeđi,
\q1 njih ću uslišiti ja Gospod,
\q2 ja Bog Izrailjev neću ih ostaviti.
\q1 
\v 18 Otvoriću reke na visovima,
\q2 i izvore usred dolina,
\q1 pustinju ću obratiti u jezero vodeno,
\q2 i suvu zemlju u izvore vodene.
\q1 
\v 19 Posadiću u pustinji kedar, sitim, mirtu i maslinu;
\q2 posadiću u pustoj zemlji jelu, brest i šimšir,
\q1 
\v 20 Da vide i poznaju i da promisle i razumeju
\q2 da je to uradila ruka Gospodnja,
\q2 i Svetac Izrailjev da je to stvorio.
\b
\q1 
\v 21 Iznesite parbu svoju, veli Gospod,
\q2 pokažite razloge svoje, veli car Jakovljev.
\q1 
\v 22 Neka dođu i neka nam objave šta će biti;
\q1 objavite nam šta je prvo bilo,
\q2 da promislimo i poznamo šta će biti iza toga;
\q1 ili kažite nam šta će biti unapredak.
\q1 
\v 23 Kažite šta će biti posle,
\q2 i poznaćemo da ste bogovi;
\q1 ili učinite šta dobro ili zlo,
\q2 i divićemo se i gledati svi.
\q1 
\v 24 Gle, vi niste ništa, i delo vaše nije ništa;
\q2 koji vas izbira, gad je.
\b
\q1 
\v 25 Podigoh jednog sa severa, i doći će;
\q2 od istoka sunčanog prizvaće ime moje,
\q1 stupaće po glavarima kao po kalu
\q2 i kao što lončar gazi blato.
\q1 
\v 26 Ko je objavio od iskona, da bismo znali,
\q2 ili od starina, da bismo rekli: Istina je?
\q1 Ali nema nikoga da bi objavio,
\q2 niti ima koga da je napred kazao,
\q2 niti ima koga da bi čuo reči vaše.
\q1 
\v 27 Ja prvi Sionu kažem: Eto, eto toga.
\q2 U Jerusalimu ću dati ko će javljati dobre glasove.
\q1 
\v 28 Jer pogledam, ali nema nikoga,
\q2 nema među njima nijednoga ko bi savetovao;
\q2 pitam ih, ali ne odgovaraju ni reči.
\q1 
\v 29 Gle, svi su taština, ništa su dela njihova;
\q2 liveni su likovi njihovi vetar i ništavilo.
\c 42
\s1 Sluga Božiji (Mesija) u svojoj blagosti videlo idolopoklonicima i vođ zaslepljenog naroda.
\q1 
\v 1 Evo sluge mog, koga podupirem,
\q2 izabranika mog, koji je mio duši mojoj;
\q1 metnuću Duh svoj na Njega,
\q2 sud narodima javljaće.
\q1 
\v 2 Neće vikati ni podizati,
\q2 niti će se čuti glas Njegov po ulicama.
\q1 
\v 3 Trsku stučenu neće prelomiti,
\q2 i sveštilo koje se puši neće ugasiti;
\q2 javljaće sud po istini.
\q1 
\v 4 Neće Mu dosaditi, niti će se umoriti,
\q2 dokle ne postavi sud na zemlji,
\q2 i ostrva će čekati nauku Njegovu.
\b
\q1 
\v 5 Ovako govori Bog Gospod,
\q2 koji je stvorio nebesa i razapeo ih,
\q1 koji je rasprostro zemlju i šta ona rađa,
\q2 koji daje disanje narodu što je na njoj
\q2 i duh onima što hode po njoj:
\q1 
\v 6 Ja Gospod dozvah Te u pravdi,
\q2 i držaću Te za ruku, i čuvaću Te,
\q2 i učiniću Te da budeš zavet narodu, videlo narodima;
\q1 
\v 7 Da otvoriš oči slepima,
\q2 da izvedeš sužnje iz zatvora
\q2 i iz tamnice koji sede u tami.
\q1 
\v 8 Ja sam Gospod, to je ime moje,
\q2 i slavu svoju neću dati drugom
\q2 ni hvalu svoju likovima rezanim.
\q1 
\v 9 Evo, pređašnje dođe,
\q2 i ja javljam novo,
\q2 pre nego nastane kazujem vam.
\b
\q1 
\v 10 Pevajte Gospodu pesmu novu,
\q2 hvalu Njegovu od kraja zemlje,
\q1 koji se plavite po moru i sve što je u njemu,
\q2 ostrva i koji živite na njima.
\q1 
\v 11 Pustinja i gradovi njeni, sela gde stanuje Kidar,
\q2 neka podignu glas,
\q1 neka pevaju koji žive po stenama,
\q2 neka klikuju savrh gora.
\q1 
\v 12 Neka daju slavu Gospodu,
\q2 i hvalu Njegovu neka javljaju po ostrvima.
\q1 
\v 13 Gospod će izaći kao junak,
\q2 podignuće revnost svoju kao vojnik,
\q1 vikaće i klikovati,
\q2 nadvladaće neprijatelje svoje.
\b
\q1 
\v 14 Ćutah dugo, činjah se gluv, ustezah se;
\q2 ali ću sada vikati kao žena kad se porađa,
\q2 i sve ću potrti i istrebiti.
\q1 
\v 15 Opusteću gore i bregove,
\q2 i svaku travu na njima osušiću,
\q1 i od reka ću načiniti ostrva,
\q2 i jezera ću isušiti.
\q1 
\v 16 I vodiću slepe putem koji nisu znali;
\q2 vodiću ih stazama koje nisu znali;
\q1 obratiću pred njima mrak u svetlost
\q2 i šta je neravno u ravno.
\q1 To ću im učiniti,
\q2 i neću ih ostaviti.
\q1 
\v 17 Tada će se vratiti natrag i posramiti se koji se uzdaju u lik rezani,
\q2 koji govore likovima livenim: Vi ste naši bogovi.
\b
\q1 
\v 18 Čujte, gluvi;
\q2 progledajte, slepi, da vidite.
\q1 
\v 19 Ko je slep osim sluge mog?
\q2 I ko je gluv kao poslanik moj koga šaljem?
\q1 Ko je slep kao Savršeni?
\q2 Ko je slep kao sluga Gospodnji?
\q1 
\v 20 Gledaš mnogo, ali ne vidiš;
\q2 otvorene su ti uši, ali ne čuješ.
\q1 
\v 21 Gospodu beše mio radi pravde Njegove,
\q2 učini zakon velikim i slavnim.
\q1 
\v 22 A narod je oplenjen i potlačen,
\q2 svi su koliki povezani u pećinama
\q2 i sakriveni u tamnicama;
\q1 postaše plen,
\q2 a nema nikoga da bi izbavio;
\q1 postaše grabež,
\q2 a nema nikoga da bi rekao: Vrati.
\q1 
\v 23 Ko između vas čuje ovo
\q2 i pazi i sluša za posle?
\q1 
\v 24 Ko je dao Jakova da se potlači
\q2 i Izrailja otimačima?
\q1 Nije li Gospod,
\q2 kome zgrešismo?
\q1 Jer ne hteše hoditi putevima Njegovim
\q2 niti slušaše zakon Njegov.
\q1 
\v 25 Zato izli na njih žestoku jarost svoju i silan rat,
\q2 i zapali ga unaokolo, ali on ne razume;
\q2 zapali ga, ali on ne mari.
\c 43
\s1 Bog izbavlja svoj narod kao što je obećao i oprašta mu greh iz čiste milosti.
\q1 
\v 1 Ali sada ovako veli Gospod,
\q2 koji te je stvorio, Jakove,
\q2 i koji te je sazdao, Izrailju:
\q1 ne boj se, jer te otkupih,
\q2 pozvah te po imenu tvom;
\q2 moj si.
\q1 
\v 2 Kad pođeš preko vode,
\q2 ja ću biti s tobom,
\q1 ili preko reka,
\q2 neće te potopiti;
\q1 kad pođeš kroz oganj,
\q2 nećeš izgoreti
\q2 i neće te plamen opaliti.
\q1 
\v 3 Jer sam ja Gospod, Bog tvoj,
\q2 Svetac Izrailjev,
\q2 Spasitelj tvoj;
\q1 dadoh u otkup za te
\q2 Misir, Etiopsku i Sevu mesto tebe.
\q1 
\v 4 Otkako si mi postao drag,
\q2 proslavio si se i ja te ljubih;
\q1 i dadoh ljude za te
\q2 i narode za dušu tvoju.
\q1 
\v 5 Ne boj se, jer sam ja s tobom;
\q2 od istoka ću dovesti seme tvoje,
\q2 i od zapada sabraću te.
\q1 
\v 6 Kazaću severu: Daj,
\q2 i jugu: Ne brani;
\q1 dovedi sinove moje iz daleka
\q2 i kćeri moje s krajeva zemaljskih,
\q1 
\v 7 Sve, koji se zovu mojim imenom
\q2 i koje stvorih na slavu sebi,
\q2 sazdah i načinih.
\b
\q1 
\v 8 Izvedi narod slepi koji ima oči,
\q2 i gluvi koji ima uši.
\q1 
\v 9 Svi narodi neka se skupe,
\q2 i neka se saberu plemena;
\q1 ko je između njih napred kazao to
\q2 ili nam kazao šta je bilo pre?
\q1 Neka dovedu svedoke svoje i opravdaju se;
\q2 ili neka čuju, i kažu: Istina je.
\q1 
\v 10 Vi ste moji svedoci, veli Gospod,
\q2 i sluga moj koga izabrah,
\q1 da biste znali i verovali mi
\q2 i razumeli da sam ja;
\q1 pre mene nije bilo Boga
\q2 niti će posle mene biti.
\q1 
\v 11 Ja sam, ja sam Gospod,
\q2 i osim mene nema Spasitelja.
\q1 
\v 12 Ja objavih, i spasoh, i napred kazah,
\q2 i nikoji tuđ bog među vama,
\q1 i vi ste mi svedoci, veli Gospod,
\q2 i ja sam Bog.
\q1 
\v 13 Ja sam od pre nego dan posta,
\q2 i niko ne može izbaviti iz moje ruke;
\q1 kad radim, ko će smesti?
\b
\q1 
\v 14 Ovako govori Gospod
\q2 Izbavitelj vaš, Svetac Izrailjev:
\q1 Vas radi poslaću u Vavilon
\q2 i pobacaću sve prevornice,
\q2 i Haldejce s lađama, kojima se hvale.
\q1 
\v 15 Ja sam Gospod Svetac vaš,
\q2 Stvoritelj Izrailjev, car vaš.
\b
\q1 
\v 16 Ovako govori Gospod
\q2 koji je načinio po moru put
\q2 i po silnim vodama stazu,
\q1 
\v 17 Koji izvodi kola i konje,
\q2 vojsku i silu,
\q1 da svi popadaju i ne mogu ustati,
\q2 da se ugase kao što se gasi sveštilo:
\q1 
\v 18 Ne pominjite šta je pre bilo
\q2 i ne mislite o starim stvarima.
\q1 
\v 19 Evo, ja ću učiniti novo, odmah će nastati;
\q2 nećete li ga poznati?
\q1 Još ću načiniti u pustinji put,
\q2 reke u suvoj zemlji.
\q1 
\v 20 Slaviće me zveri poljske, zmajevi i sove,
\q2 što sam izveo u pustinju vode,
\q2 reke u zemlji suvoj,
\q1 da napojim narod svoj,
\q2 izabranika svog.
\q1 
\v 21 Narod koji sazdah sebi,
\q2 pripovedaće hvalu moju.
\b
\q1 
\v 22 A ti, Jakove, ne priziva me,
\q2 i bejah ti dosadan, Izrailju.
\q1 
\v 23 Nisi mi prineo jagnjeta na žrtvu paljenicu,
\q2 i žrtvama svojim nisi me počastio;
\q1 nisam te nagonio da mi služiš prinosima,
\q2 niti sam te trudio da mi kadiš.
\q1 
\v 24 Nisi mi kupio za novce kada,
\q2 niti si me pretilinom žrtava svojih nasitio,
\q1 nego si me mučio svojim gresima,
\q2 i dosadio si mi bezakonjem svojim.
\b
\q1 
\v 25 Ja, ja sam brišem tvoje prestupe sebe radi,
\q2 i grehe tvoje ne pominjem.
\q1 
\v 26 Opomeni me, da se sudimo,
\q2 kazuj, da se opravdaš.
\q1 
\v 27 Otac tvoj prvi sagreši,
\q2 i učitelji tvoji skriviše mi.
\q1 
\v 28 Zato ću izbaciti iz svetinje knezove,
\q2 i daću Jakova u prokletstvo
\q2 i Izrailja u sramotu.
\c 44
\s1 Izlevanje duha milosti. Idolopoklonstvo je bezumlje. Milost Gospodnja i spasenje Izrailja.
\q1 
\v 1 Ali sada čuj, Jakove, slugo moj,
\q2 i Izrailju, koga izabrah.
\q1 
\v 2 Ovako veli Gospod,
\q2 koji te je stvorio
\q1 i sazdao od utrobe materine,
\q2 i koji ti pomaže:
\q1 ne boj se, slugo moj Jakove,
\q2 i mili, koga izabrah.
\q1 
\v 3 Jer ću izliti vodu na žednoga
\q2 i potoke na suvu zemlju,
\q1 izliću Duh svoj na seme tvoje
\q2 i blagoslov svoj na tvoje natražje.
\q1 
\v 4 I procvetaće kao u travi,
\q2 kao vrbe pokraj potoka.
\q1 
\v 5 Ovaj će reći: Ja sam Gospodnji,
\q2 a onaj će se zvati po imenu Jakovljevom,
\q1 a drugi će se pisati svojom rukom Gospodnji,
\q2 i prezivaće se imenom Izrailjevim.
\b
\q1 
\v 6 Ovako govori Gospod
\q2 Car Izrailjev i Izbavitelj njegov,
\q2 Gospod nad vojskama:
\q1 ja sam prvi i ja sam poslednji,
\q2 i osim mene nema Boga.
\q1 
\v 7 I ko kao ja oglašuje i objavljuje ovo,
\q2 ili mi uređuje otkako naselih stari narod?
\q1 Neka im javi šta će biti i šta će doći.
\q1 
\v 8 Ne bojte se i ne plašite se;
\q2 nisam li ti davno kazao i objavio?
\q1 Vi ste mi svedoci;
\q2 ima li Boga osim mene?
\q1 Da, nema stene, ne znam ni jedne.
\b
\p 
\v 9 Koji grade rezane likove, svi su ništa, i mile stvari njihove ne pomažu ništa, i one su im svedoci da ne vide i ne razumeju, da bi se posramili.
\v 10 Ko gradi boga i lije lik, nije ni na kakvu korist.
\v 11 Gle, svi će se drugovi njegovi posramiti, i umetnici više od drugih ljudi; neka se skupe svi i stanu, biće ih strah i posramiće se svi.
\p 
\v 12 Kovač kleštima radi na živom ugljevlju, i kuje čekićem, i radi snagom svoje ruke, gladuje, te iznemogne, i ne pije vode, te sustane.
\v 13 Drvodelja rasteže vrpcu i beleži crvenilom, teše i zaokružuje, i načinja kao lik čovečji, kao lepog čoveka, da stoji u kući.
\v 14 Seče sebi kedre, i uzima česevinu i hrast ili šta je najčvršće među drvećem šumskim; sadi jasen, i od dažda raste.
\v 15 I biva čoveku za oganj, i uzme ga, te se greje; upali ga, te peče hleb; i još gradi od njega boga i klanja mu se; gradi od njega lik rezan, i pada na kolena pred njim.
\v 16 Polovinu loži na oganj, uz polovinu jede meso ispekavši pečenje, i biva sit, i greje se i govori: Aha, ogrejah se, videh oganj.
\v 17 A od ostatka gradi boga, rezan lik svoj, pada pred njim na kolena i klanja se, i moli mu se i govori: Izbavi me, jer si ti bog moj.
\p 
\v 18 Ne znaju, niti razumeju, jer su im oči zaslepljene da ne vide, i srca, da ne razumeju.
\v 19 Niti uzimaju na um, nema znanja ni razuma da bi koji rekao: Polovinu ovog spalih na oganj, i na uglju od njega ispekoh hleb, ispekoh meso i jedoh; i od ostatka eda li ću načiniti gad, i panju drvenom hoću li se klanjati?
\v 20 Takav se hrani pepelom, prevareno srce zavodi ga da ne može izbaviti dušu svoju, niti reći: Nije li laž što mi je u desnici?
\b
\q1 
\v 21 Pamti to, Jakove i Izrailju, jer si moj sluga;
\q2 ja sam te sazdao, sluga si moj,
\q2 Izrailju, neću te zaboraviti.
\q1 
\v 22 Rasuću kao oblak prestupe tvoje,
\q2 i grehe tvoje kao maglu;
\q1 vrati se k meni,
\q2 jer sam te izbavio.
\b
\q1 
\v 23 Pevajte, nebesa, jer Gospod učini,
\q2 podvikujte, nizine zemaljske,
\q2 popevajte, gore, šume i sva drva u njima,
\q1 jer izbavi Gospod Jakova
\q2 i proslavi se u Izrailju.
\b
\q1 
\v 24 Ovako govori Gospod, Izbavitelj tvoj,
\q2 koji te je sazdao od utrobe materine:
\q1 ja Gospod načinih sve:
\q2 razapeh nebo sam, rasprostreh zemlju sam sobom;
\q1 
\v 25 Uništavam znake lažljivcima,
\q2 i vrače obezumljujem,
\q1 vraćam natrag mudrace,
\q2 i pretvaram mudrost njihovu u ludost;
\q1 
\v 26 Potvrđujem reč sluge svog,
\q2 i navršujem savet glasnika svojih;
\q1 govorim Jerusalimu: Naselićeš se,
\q2 i gradovima Judinim: Sazidaćete se;
\q1 i pustoline njihove podignuću;
\q1 
\v 27 Govorim dubini: Presahni
\q2 i isušiću reke tvoje;
\q1 
\v 28 Govorim Kiru: Pastir si moj;
\q2 i izvršiće svu volju moju,
\q1 i kazaće Jerusalimu: Sazidaćeš se,
\q2 i crkvi: Osnovaćeš se.
\c 45
\s1 Kir je oruđe Svemogućeg za poniženje idola i spasenje Izrailja.
\q1 
\v 1 Ovako govori Gospod pomazaniku svom Kiru,
\q2 koga držim za desnicu,
\q1 da oborim pred njim narode i careve raspašem,
\q2 da se otvaraju vrata pred njim
\q2 i da ne budu vrata zatvorena:
\q1 
\v 2 Ja ću ići pred tobom,
\q2 i puteve neravne poravniću,
\q1 vrata bronzana razbiću
\q2 i prevornice gvozdene slomiću.
\q1 
\v 3 I daću ti blago tajno
\q2 i bogatstvo sakriveno,
\q1 da poznaš da sam ja Gospod Bog Izrailjev,
\q2 koji te zovem po imenu.
\q1 
\v 4 Radi sluge svog Jakova
\q2 i Izrailja izabranika svog
\q1 prozvah te imenom tvojim i prezimenom,
\q2 premda me ne znaš.
\q1 
\v 5 Ja sam Gospod, i nema drugog,
\q2 osim mene nema boga;
\q1 opasah te, premda me ne znaš,
\q1 
\v 6 Da bi poznali od istoka sunčanog i od zapada
\q2 da nema drugog osim mene;
\q2 ja sam Gospod i nema drugog,
\q1 
\v 7 Koji pravim svetlost i stvaram mrak,
\q2 gradim mir i stvaram zlo;
\q1 ja Gospod činim sve to.
\b
\q1 
\v 8 Rosite, nebesa, ozgo,
\q2 i oblaci neka kaplju pravdom,
\q1 neka se otvori zemlja
\q2 i neka rodi spasenjem
\q2 i zajedno neka uzraste pravda;
\q1 ja Gospod stvorih to.
\b
\q1 
\v 9 Teško onom ko se svađa s Tvorcem svojim;
\q2 crep s drugim crepovima neka se svađa;
\q1 ali hoće li kao reći lončaru svom: Šta radiš?
\q2 Za tvoj posao nema ruku.
\q1 
\v 10 Teško onom ko govori ocu: Što rađaš?
\q2 I ženi: Što se porađaš?
\b
\q1 
\v 11 Ovako veli Gospod
\q2 Svetac Izrailjev i Tvorac njegov:
\q1 Pitajte me šta će biti;
\q2 za sinove moje i za delo ruku mojih naređujte mi.
\q1 
\v 12 Ja sam načinio zemlju
\q2 i čoveka na njoj stvorio,
\q1 ja sam razapeo nebesa svojim rukama,
\q2 i svoj vojsci njihovoj dao zapovest.
\q1 
\v 13 Ja ga podigoh u pravdi,
\q2 i sve puteve njegove poravniću;
\q1 on će sazidati moj grad
\q2 i roblje moje otpustiće,
\q1 ne za novce ni za darove,
\q2 veli Gospod nad vojskama.
\b
\q1 
\v 14 Ovako veli Gospod:
\q1 Trud misirski i trgovina etiopska i Savaca ljudi visokog rasta
\q2 doći će k tebi i biti tvoja;
\q1 za tobom će pristati, u okovima će ići,
\q2 i tebi će se klanjati, tebi će se moliti govoreći:
\q1 Doista, Bog je u tebi,
\q2 i nema drugog Boga.
\b
\q1 
\v 15 Da, ti si Bog, koji se kriješ,
\q2 Bog Izrailjev, Spasitelj.
\q1 
\v 16 Oni će se svi postideti i posramiti,
\q2 otići će sa sramotom svikoliki koji grade likove.
\q1 
\v 17 A Izrailja će spasti Gospod spasenjem večnim,
\q2 nećete se postideti niti ćete se osramotiti doveka.
\b
\q1 
\v 18 Jer ovako veli Gospod, koji je stvorio nebo,
\q1 Bog, koji je sazdao zemlju i načinio je i utvrdio,
\q2 i nije je stvorio naprazno,
\q2 nego je načinio da se na njoj nastava:
\q1 ja sam Gospod, i nema drugog.
\q1 
\v 19 Nisam govorio tajno
\q2 ni na mračnom mestu na zemlji,
\q1 nisam rekao semenu Jakovljevom:
\q2 Tražite me uzalud.
\q1 Ja Gospod govorim pravdu,
\q2 javljam šta je pravo.
\b
\q1 
\v 20 Skupite se i dođite, pristupite
\q2 svi koji ste se izbavili između naroda.
\q1 Ništa ne znaju koji nose drvo od svog lika
\q2 i mole se bogu koji ne može pomoći.
\q1 
\v 21 Oglasite, i dovedite,
\q2 neka većaju zajedno:
\q1 ko je to od starine kazao?
\q2 Ko je javio još onda?
\q2 Nisam li ja, Gospod?
\q1 Nema osim mene drugog Boga,
\q2 nema Boga pravednog
\q2 i Spasitelja drugog osim mene.
\b
\q1 
\v 22 Pogledajte u mene,
\q2 i spašćete se svi krajevi zemaljski;
\q1 jer sam ja Bog,
\q2 i nema drugog.
\q1 
\v 23 Sobom se zakleh;
\q2 izađe iz usta mojih reč pravedna,
\q2 i neće se poreći,
\q1 da će im se pokloniti svako koleno,
\q2 i zaklinjati se svaki jezik,
\b
\q1 
\v 24 I govoriće:
\q1 U Gospodu je pravda i sila;
\q2 k Njemu će doći;
\q2 ali će se posramiti svi koji se gneve na Nj.
\q1 
\v 25 U Gospodu će se opravdati i proslaviti
\q2 sve seme Izrailjevo.
\c 46
\s1 Pad Vavilonskih idola. Spas je Izrailjev u Bogu koji mu je veran.
\q1 
\v 1 Pade Vil, izvali se Nevo;
\q2 likovi njihovi metnuše se na životinju i na stoku;
\q2 šta nosite, teško je, i umoriće.
\q1 
\v 2 Izvališe se, padoše svi,
\q2 ne mogoše izbaviti tovar,
\q2 nego i sami odoše u ropstvo.
\b
\q1 
\v 3 Slušajte me, dome Jakovljev
\q2 i svi koji ste ostali od doma Izrailjevog,
\q1 koje nosim od utrobe,
\q2 koje držim od rođenja.
\q1 
\v 4 I do starosti vaše ja ću biti isti,
\q2 i ja ću vas nositi do sedog veka;
\q1 ja sam stvorio i ja ću nositi,
\q2 ja ću vas nositi i izbaviću.
\b
\q1 
\v 5 S kim ćete me izjednačiti i uporediti?
\q2 Koga ćete mi uzeti za priliku da bi bio kao ja?
\q1 
\v 6 Prosipaju zlato iz toboca
\q2 i mere srebro na merila,
\q1 plaćaju zlataru da načini od njega boga,
\q2 pred kojim padaju i klanjaju se.
\q1 
\v 7 Meću ga na rame i nose ga,
\q2 i postavljaju ga na mesto njegovo,
\q2 te stoji i ne miče se s mesta svog;
\q1 ako ga ko zove, ne odziva se
\q2 niti ga izbavlja iz nevolje njegove.
\b
\q1 
\v 8 Pamtite to, i pokažite se da ste ljudi,
\q2 uzmite na um, prestupnici!
\q2 
\v 9 Pamtite šta je bilo od starine;
\q1 jer sam ja Bog, i nema drugog Boga,
\q2 i niko nije kao ja,
\q1 
\v 10 Koji od početka javljam kraj
\q2 i izdaleka šta još nije bilo;
\q1 koji kažem: namera moja stoji
\q2 i učiniću sve što mi je volja.
\q1 
\v 11 Zovem s istoka pticu
\q2 i iz daleke zemlje čoveka
\q2 koji će izvršiti šta sam naumio.
\q1 Rekoh i dovešću to,
\q2 naumih i učiniću.
\b
\q1 
\v 12 Slušajte me, koji ste upornog srca,
\q2 koji ste daleko od pravde.
\q1 
\v 13 Približih pravdu svoju, nije daleko,
\q2 i spasenje moje neće odocniti,
\q1 jer ću u Sionu postaviti spasenje,
\q2 u Izrailju slavu svoju.
\c 47
\s1 Propast obesnog i praznovernog Vavilona.
\q1 
\v 1 Siđi i sedi u prah, devojko,
\q2 kćeri vavilonska;
\q1 sedi na zemlju, nema prestola,
\q2 kćeri haldejska;
\q1 jer se nećeš više zvati nežna i ljupka.
\q1 
\v 2 Uzmi žrvnje, i melji brašno,
\q2 otkrij kosu svoju,
\q1 izuj se, zagali noge,
\q2 idi preko reka.
\q1 
\v 3 Otkriće se golotinja tvoja,
\q2 i videće se sramota tvoja;
\q1 osvetiću se,
\q2 i niko mi neće smetati.
\q1 
\v 4 Ime je Izbavitelju našem Gospod nad vojskama,
\q2 Svetac Izrailjev.
\b
\q1 
\v 5 Sedi ćuteći, i uđi u tamu, kćeri haldejska;
\q2 jer se nećeš više zvati gospođa carstvima.
\q1 
\v 6 Razgnevih se na narod svoj,
\q2 oskvrnih nasledstvo svoje
\q2 i predadoh ga tebi u ruke;
\q1 a ti im ne pokaza milost;
\q2 na starce si metala preteški jaram svoj;
\q1 
\v 7 I govorila si:
\q2 Doveka ću biti gospođa;
\q1 ali nikad nisi to uzimala na um,
\q2 niti si pomišljala šta će biti na posletku.
\b
\q1 
\v 8 Sada dakle čuj ovo,
\q2 koja živiš u slastima
\q1 i bez brige sediš
\q2 i govoriš u srcu svom:
\q1 Ja sam, i nema druge osim mene,
\q2 neću biti udovica niti ću osiroteti.
\q1 
\v 9 To će ti oboje doći ujedanput, u isti dan,
\q2 da osirotiš i obudoviš,
\q1 doći će ti potpuno,
\q2 radi mnoštva čini tvojih
\q2 i radi velike sile čaranja tvog.
\b
\q1 
\v 10 Jer si se pouzdala u zloću svoju govoreći:
\q2 Niko me ne vidi.
\q1 Mudrost tvoja i znanje tvoje prevariše te,
\q2 te si govorila u srcu svom:
\q2 Ja sam, i osim mene nema druge.
\q1 
\v 11 Zato će doći na te zlo,
\q2 a nećeš znati odakle izlazi,
\q1 i popašće te nevolja,
\q2 da je nećeš moći odbiti,
\q1 i doći će na te ujedanput pogibao,
\q2 za koju nećeš znati.
\b
\q1 
\v 12 Stani sada s vračanjem svojim
\q2 i s mnoštvom čini svojih,
\q2 oko kojih si se trudila od mladosti svoje,
\q1 ne bi li se pomogla,
\q2 ne bi li se okrepila.
\q1 
\v 13 Umorila si se od mnoštva namera svojih;
\q1 neka stanu sada zvezdari,
\q2 koji gledaju zvezde,
\q2 koji proriču svakog meseca,
\q1 i neka te sačuvaju od onog što će doći na te.
\b
\q1 
\v 14 Gle, oni su kao pleva,
\q2 oganj će ih spaliti,
\q2 ni sami sebe neće izbaviti iz plamena;
\q1 neće ostati uglja da se ko ogreje,
\q2 ni ognja da bi se posedelo kod njega.
\q1 
\v 15 Takvi će biti oni s kojima si se trudila
\q2 i s kojima si trgovala od mladosti svoje,
\q1 razbeći će se svaki na svoju stranu;
\q2 neće biti nikoga da te izbavi.
\c 48
\s1 Gospod traži od svog tvrdovratog naroda da veruje u njegovu milost i spasenje i da ga sluša.
\q1 
\v 1 Čujte ovo, dome Jakovljev,
\q2 koji se zovete imenom Izrailjevim,
\q2 i iz vode Judine izađoste,
\q1 koji se kunete imenom Gospodnjim,
\q2 i Boga Izrailjevog pominjete,
\q2 ali ne po istini i po pravdi.
\q1 
\v 2 Jer se imenuju po Svetom gradu,
\q2 oslanjaju se na Boga Izrailjevog,
\q2 kome je ime Gospod nad vojskama.
\b
\q1 
\v 3 Šta je pre bivalo, kazivah napred odavno,
\q2 i šta iz mojih usta izađe i objavih,
\q2 učinih brzo i zbi se.
\q1 
\v 4 Znao sam da si uporan,
\q2 i vrat da ti je gvozdena žila,
\q2 i čelo da ti je od bronze.
\q1 
\v 5 I zato ti odavna objavih,
\q2 pre nego se zbi kazah ti,
\q1 da ne bi rekao: Idol moj učini to,
\q2 i lik moj rezani i lik moj liveni zapovediše tako.
\b
\q1 
\v 6 Čuo si; pogledaj sve to;
\q2 a vi nećete li objavljivati?
\q1 Odsele ti javljam novo i sakriveno,
\q2 šta nisi znao;
\q1 
\v 7 Sada se stvori, i nedavno,
\q2 i pre ovog dana nisi čuo,
\q2 da ne kažeš: Gle, znao sam.
\q1 
\v 8 Niti si čuo ni znao,
\q2 i pre ti se uši ne otvoriše,
\q1 jer znadoh da ćeš činiti neveru,
\q2 i da se zoveš prestupnik od utrobe materine.
\b
\q1 
\v 9 Imena svog radi ustegnuću gnev svoj,
\q2 i radi hvale svoje uzdržaću se prema tebi,
\q2 da te ne istrebim.
\q1 
\v 10 Evo, pretopiću te, ali ne kao srebro,
\q2 prebraću te u peći nevolje.
\q1 
\v 11 Sebe radi, sebe radi učiniću,
\q2 jer kako bi se hulilo na ime moje?
\q2 I slave svoje neću dati drugom.
\b
\q1 
\v 12 Čuj me, Jakove
\q2 i Izrailju, kog ja pozvah:
\q1 ja sam prvi,
\q2 ja sam i poslednji.
\q1 
\v 13 I moja je ruka osnovala zemlju,
\q2 i moja je desnica izmerila nebesa peđu;
\q2 kad ih zovnem, svi dođu.
\b
\q1 
\v 14 Skupite se svi i čujte:
\q2 ko je od njih objavio ovo?
\q1 Gospod ga miluje,
\q2 on će izvršiti volju Njegovu na Vavilonu,
\q2 i mišica će Njegova biti nasuprot Haldejcima.
\q1 
\v 15 Ja, ja rekoh, i pozvah ga,
\q2 dovešću ga, i biće srećan na svom putu.
\q1 
\v 16 Pristupite k meni, čujte ovo:
\q2 od početka nisam govorio tajno;
\q1 otkako to bi, bejah onde;
\q2 a sada Gospod Gospod posla me i Duh Njegov.
\b
\q1 
\v 17 Ovako veli Gospod, Izbavitelj tvoj,
\q2 Svetac Izrailjev:
\q1 Ja sam Gospod Bog tvoj
\q2 koji te učim da bi napredovao,
\q2 vodim te putem kojim treba da ideš.
\q1 
\v 18 O, da si pazio na zapovesti moje!
\q2 Mir bi tvoj bio kao reka,
\q2 i pravda tvoja kao valovi morski;
\q1 
\v 19 I semena bi tvog bilo kao peska,
\q2 i poroda utrobe tvoje kao zrna njegovih;
\q1 ime se njihovo ne bi zatrlo
\q2 ni istrebilo ispred mene.
\b
\q1 
\v 20 Izađite iz Vavilona,
\q2 bežite od Haldejaca;
\q1 glasno pevajući objavljujte, kazujte,
\q2 razglašujte do krajeva zemaljskih;
\q2 recite: Izbavi Gospod slugu svog Jakova.
\q1 
\v 21 Neće ožedneti kad ih povede preko pustinje;
\q2 vodu iz stene točiće im,
\q2 jer će rascepiti kamen i poteći će voda.
\b
\q1 
\v 22 Nema mira bezbožnicima,
\q2 veli Gospod.
\c 49
\s1 Sluga Božiji videlo idolopoklonicima i spas Izrailjev. Gospod teši narod svoj.
\q1 
\v 1 Poslušajte me, ostrva,
\q2 i pazite narodi daleki.
\q1 Gospod me pozva od utrobe;
\q2 od utrobe matere moje pomenu ime moje.
\q1 
\v 2 I učinio je usta moja da su kao oštar mač,
\q2 u senu ruke svoje sakri me;
\q1 učinio me je sjajnom strelom,
\q2 i tulu svom sakri me.
\q1 
\v 3 I reče mi:
\q1 Ti si sluga moj,
\q2 u Izrailju ću se tobom proslaviti.
\q1 
\v 4 A ja rekoh:
\q1 Uzalud se trudih,
\q2 uzalud i naprazno potroših silu svoju;
\q1 ali opet sud je moj u Gospoda
\q2 i posao moj u Boga mog.
\b
\q1 
\v 5 A sada govori Gospod,
\q2 koji me je sazdao od utrobe materine
\q1 da sam Mu sluga,
\q2 da Mu dovedem natrag Jakova;
\q1 ako se Izrailj i ne sabere,
\q2 opet ću se proslaviti pred Gospodom,
\q2 i Bog će moj biti sila moja.
\q1 
\v 6 I reče mi:
\q1 Malo je da mi budeš sluga
\q2 da se podigne pleme Jakovljevo
\q2 i da se vrati ostatak Izrailjev,
\q1 nego te učinih videlom narodima
\q2 da budeš moje spasenje do krajeva zemaljskih.
\b
\q1 
\v 7 Ovako veli Gospod,
\q2 Izbavitelj Izrailjev, Svetac njegov,
\q1 onome koga preziru,
\q2 na koga se gadi narod,
\q2 sluzi onih koji gospodare:
\q1 carevi će videti i ustati,
\q2 i knezovi će se pokloniti
\q1 radi Gospoda, koji je veran,
\q2 radi Sveca Izrailjevog, koji te je izabrao.
\b
\q1 
\v 8 Ovako veli Gospod:
\q1 U vreme milosno usliših te,
\q2 i u dan spasenja pomogoh ti;
\q1 i čuvaću te
\q2 i daću te da budeš zavet narodu
\q1 da utvrdiš zemlju
\q2 i naslediš opustelo nasledstvo;
\q1 
\v 9 Da kažeš sužnjima: Izađite;
\q2 onima koji su u mraku: Pokažite se.
\q1 Oni će pokraj puteva pasti,
\q2 i paša će im biti po svim visokim mestima.
\q1 
\v 10 Neće biti gladni ni žedni,
\q2 neće ih biti vrućina ni sunce;
\q1 jer kome ih je žao, on će ih voditi,
\q2 i pokraj izvora vodenih provodiće ih.
\q1 
\v 11 I sve gore svoje obratiću u puteve,
\q2 i staze će moje biti povišene.
\q1 
\v 12 Gle, ovi će iz daleka doći,
\q2 gle, i oni od severa i od zapada,
\q2 i oni iz zemlje sinske.
\b
\q1 
\v 13 Pevajte, nebesa,
\q2 i veseli se, zemljo,
\q2 podvikujte, gore, veselo;
\q1 jer Gospod uteši svoj narod,
\q2 i na nevoljnike svoje smilova se.
\b
\q1 
\v 14 Ali Sion reče:
\q2 Ostavi me Gospod,
\q2 i zaboravi me Gospod.
\b
\q1 
\v 15 Može li žena zaboraviti porod svoj
\q2 da se ne smiluje na čedo utrobe svoje?
\q1 A da bi ga i zaboravila,
\q2 ja neću zaboraviti tebe.
\q1 
\v 16 Gle, na dlanovima sam te izrezao;
\q2 zidovi su tvoji jednako preda mnom.
\q1 
\v 17 Pohitaće sinovi tvoji,
\q2 a koji te raskopavaše i pustošiše,
\q2 otići će od tebe.
\q1 
\v 18 Podigni oči svoje unaokolo, i vidi:
\q2 svi se oni skupljaju i idu k tebi.
\q1 Tako bio ja živ, veli Gospod,
\q2 svima njima kao nakitom zaodenućeš se,
\q2 i uresićeš se njima kao nevesta.
\b
\q1 
\v 19 Jer razvaline tvoje i pustoline
\q2 i potrvena zemlja tvoja
\q1 biće tada tesna za stanovnike
\q2 kad se udalje oni koji te proždiraše.
\q1 
\v 20 I deca koju ćeš imati,
\q2 pošto si bila bez dece,
\q2 reći će da čuješ:
\q1 Tesno mi je ovo mesto,
\q2 pomakni se da se mogu nastaniti.
\q1 
\v 21 A ti ćeš reći u srcu svom:
\q1 Ko mi ih rodi,
\q2 jer bejah sirota i inokosna,
\q2 zarobljena i prognana?
\q1 I ko ih othrani?
\q2 Eto, ja bejah ostala sama,
\q2 a gde oni behu?
\b
\q1 
\v 22 Ovako veli Gospod Gospod:
\q1 Evo, podignuću ruku svoju k narodima,
\q2 i k plemenima ću podignuti zastavu svoju,
\q1 i doneće sinove tvoje u naručju,
\q2 i kćeri tvoje na ramenima će se nositi.
\q1 
\v 23 I carevi će biti hranitelji tvoji
\q2 i carice njihove tvoje dojkinje,
\q1 i klanjaće ti se licem do zemlje,
\q2 i prah s nogu tvojih lizaće,
\q1 i poznaćeš da sam ja Gospod,
\q2 i da se neće osramotiti oni koji mene čekaju.
\b
\q1 
\v 24 Hoće li se junaku uzeti plen
\q2 i hoće li se oteti roblje pravednome?
\q1 
\v 25 Jer ovako govori Gospod:
\q1 i roblje junaku uzeće se
\q2 i plen jakome oteće se,
\q1 jer ću se ja preti s onima koji se s tobom pru,
\q2 i sinove tvoje ja ću izbaviti;
\q1 
\v 26 I koji ti krivo čine,
\q2 nahraniću ih njihovim mesom
\q2 i opiće se svojom krvlju kao novim vinom;
\q1 i poznaće svako telo da sam ja Gospod
\q2 Spasitelj tvoj i Izbavitelj tvoj,
\q2 jaki Bog Jakovljev.
\c 50
\s1 Izrailj se odbacuje zbog svojih bezakonja. Sluga Gospodnji donosi spasenje.
\q1 
\v 1 Ovako veli Gospod:
\q2 Gde je raspusna knjiga matere vaše
\q2 kojom je pustih?
\q1 Ili koji je između rukodavalaca mojih
\q2 kome vas prodadoh?
\q1 Gle, za bezakonja svoja prodadoste se
\q2 i za vaše prestupe bi puštena mati vaša.
\q1 
\v 2 Zašto kad dođoh ne bi nikoga?
\q2 Kad zvah, niko se ne odazva?
\q1 Da nije kako god okraćala ruka moja,
\q2 te ne može iskupiti?
\q1 Ili nema u mene snage da izbavim?
\q1 Gle, pretnjom svojom isušujem more;
\q2 obraćam reke u pustinju
\q1 da se usmrde ribe njihove
\q2 zato što nestane vode, i mru od žeđi.
\q1 
\v 3 Oblačim nebesa u mrak,
\q2 i kostret im dajem za pokrivač.
\b
\q1 
\v 4 Gospod Gospod dade mi jezik učen
\q2 da umem progovoriti zgodnu reč umornom;
\q1 budi svako jutro, budi mi uši,
\q2 da slušam kao učenici.
\q1 
\v 5 Gospod Gospod otvori mi uši,
\q2 i ja se ne protivih, ne odstupih natrag.
\q1 
\v 6 Leđa svoja podmetah onima koji me bijahu
\q2 i obraze svoje onima koji me čupahu;
\q2 ne zaklonih lice svoje od ruga ni od zapljuvanja.
\b
\q1 
\v 7 Jer mi Gospod Gospod pomaže,
\q2 zato se ne osramotih,
\q1 zato stavih čelo svoje kao kremen,
\q2 i znam da se neću postideti.
\q1 
\v 8 Blizu je Onaj koji me pravda;
\q2 ko će se preti sa mnom?
\q1 Stanimo zajedno;
\q2 ko je suparnik moj?
\q2 Neka pristupi k meni.
\q1 
\v 9 Gle, Gospod Gospod pomagaće mi:
\q2 ko će me osuditi?
\q1 Gle, svi će oni kao haljina ovetšati,
\q2 moljac će ih izjesti.
\b
\q1 
\v 10 Ko se među vama boji Gospoda
\q2 i sluša glas sluge Njegovog?
\q1 Ko hodi po mraku i nema videla,
\q2 neka se uzda u ime Gospodnje
\q2 i neka se oslanja na Boga svog.
\q1 
\v 11 Gle, svi koji ložite oganj
\q2 i opasujete se iskrama,
\q1 idite u svetlosti ognja svog
\q2 i u iskrama koje raspaliste.
\q1 To vam je iz moje ruke,
\q2 u mukama ćete ležati.
\c 51
\s1 Pravedni se vraćaju i nastaje radost u Sionu.
\q1 
\v 1 Poslušajte me koji idete za pravdom,
\q2 koji tražite Gospoda;
\q1 pogledajte stenu iz koje ste isečeni,
\q2 i duboku jamu iz koje ste iskopani;
\q1 
\v 2 Pogledajte Avrama, oca svog,
\q2 i Saru, koja vas je rodila,
\q1 kako ga inokosnog pozvah
\q2 i blagoslovih ga i umnožih ga.
\q1 
\v 3 Jer će Gospod utešiti Sion,
\q2 utešiće sve razvaline njegove,
\q1 i pustinju njegovu učiniće da bude kao Edem
\q2 i pustoš njegova kao vrt Gospodnji,
\q1 radost će se i veselje nalaziti u njemu,
\q2 zahvaljivanje i pevanje.
\b
\q1 
\v 4 Poslušaj me, narode moj,
\q2 i čuj me, rode moj;
\q1 jer će zakon od mene izaći
\q2 i sud svoj postaviću da bude videlo narodima.
\q1 
\v 5 Blizu je pravda moja,
\q2 izaći će spasenje moje,
\q2 i mišice će moje suditi narodima;
\q1 mene će ostrva čekati
\q2 i u moju će se mišicu uzdati.
\q1 
\v 6 Podignite k nebu oči svoje
\q2 i pogledajte dole na zemlju;
\q1 jer će nebesa iščeznuti kao dim
\q2 i zemlja će kao haljina ovetšati,
\q2 i koji na njoj žive pomreće takođe;
\q1 a spasenje će moje ostati doveka,
\q2 a pravde moje neće nestati.
\b
\q1 
\v 7 Poslušajte me koji znate pravdu,
\q2 narode, kome je u srcu zakon moj.
\q1 Ne bojte se ruženja ljudskog
\q2 i od huljenja njihovog ne plašite se.
\q1 
\v 8 Jer će ih moljac izjesti kao haljinu,
\q2 i kao vunu izješće ih crv;
\q1 a pravda moja ostaje doveka
\q2 i spasenje moje od kolena na koleno.
\b
\q1 
\v 9 Probudi se, probudi se,
\q2 obuci se u silu, mišico Gospodnja;
\q1 probudi se kao u staro vreme,
\q2 za naraštaja prošlih;
\q1 nisi li ti isekla Ravu i ranila zmaja?
\q1 
\v 10 Nisi li ti isušila more,
\q2 vodu bezdana velikog,
\q1 od dubine morske načinila put
\q2 da prođu izbavljeni?
\q1 
\v 11 Tako oni koje iskupi Gospod
\q2 neka se vrate i dođu u Sion pevajući,
\q2 i veselje večno neka bude nad glavom njihovom;
\q1 radost i veselje neka zadobiju,
\q2 a žalost i uzdisanje neka beži.
\b
\q1 
\v 12 Ja, ja sam utešitelj vaš;
\q2 ko si ti da se bojiš čoveka smrtnog
\q2 i sina čovečjeg, koji je kao trava?
\q1 
\v 13 I zaboravio si Boga Tvorca svog,
\q2 koji je razapeo nebesa i osnovao zemlju?
\q1 I jednako se bojiš svaki dan
\q2 gneva onog koji te pritešnjuje kad se sprema da zatire?
\q2 A gde je gnev onog koji pritešnjuje?
\q1 
\v 14 Brzo će se oprostiti sužanj,
\q2 neće umreti u jami,
\q2 niti će biti bez hleba.
\q1 
\v 15 Jer sam ja Gospod Bog tvoj,
\q2 koji raskidam more,
\q2 da valovi njegovi buče;
\q1 Gospod nad vojskama ime mi je.
\q1 
\v 16 Ja ti metnuh u usta reči svoje
\q2 i senom ruke svoje zaklonih te,
\q1 da utvrdim nebesa i osnujem zemlju,
\q2 i kažem Sionu: Ti si moj narod.
\b
\q1 
\v 17 Probudi se, probudi se,
\q2 ustani, Jerusalime!
\q1 Koji si pio iz ruke Gospodnje čašu gneva Njegovog,
\q2 pio si, i talog iz strašne čaše ispio si.
\q1 
\v 18 Od svih sinova koje je rodio
\q2 nijedan ga nije vodio,
\q1 i od svih sinova koje je othranio
\q2 nijedan ga nije prihvatio za ruku.
\q1 
\v 19 Ovo te dvoje zadesi;
\q2 ko te požali?
\q1 Pustoš i rasap, i glad i mač;
\q2 ko će te utešiti?
\q1 
\v 20 Sinovi tvoji obamrli leže po krajevima svih ulica
\q2 kao bivo u mreži
\q1 puni gneva Gospodnjeg,
\q2 i karanja Boga tvog.
\b
\q1 
\v 21 Zato čuj ovo, nevoljni,
\q2 i pijani, ne od vina.
\q1 
\v 22 Ovako veli Gospod tvoj,
\q2 Gospod i Bog tvoj, koji brani svoj narod:
\q1 Evo uzimam iz tvoje ruke čašu strašnu,
\q2 talog u čaši gneva svog;
\q2 nećeš više piti.
\q1 
\v 23 Nego ću je dati u ruke onima koji te muče,
\q2 koji govoriše duši tvojoj:
\q2 Sagni se da pređemo,
\q1 i ti si im podmetao leđa svoja da budu kao zemlja
\q2 i kao ulica onima koji prelaze.
\c 52
\s1 Glasnici mira objavljuju spasenje Siona.
\q1 
\v 1 Probudi se, probudi se,
\q2 obuci se u silu svoju, Sione;
\q1 obuci krasne haljine svoje,
\q2 Jerusalime grade sveti;
\q1 jer neće više ući u tebe neobrezani i nečisti.
\q1 
\v 2 Otresi prah sa sebe,
\q2 ustani, sedi, Jerusalime;
\q1 skini okove s vrata svog,
\q2 zarobljena kćeri sionska.
\b
\p 
\v 3 Jer ovako veli Gospod: Zabadava se prodadoste, i iskupiste se bez novca.
\v 4 Jer ovako veli Gospod Gospod: U Misir siđe moj narod pre da onde žive kao došljaci, ali Misirci im činiše silu ni za šta.
\v 5 A sada šta ću tu? veli Gospod. Jer je narod moj zaboravljen nizašta; koji vladaju njim, cvele ga, veli Gospod, i jednako svaki dan huli se na ime moje.
\v 6 Zato će poznati narod moj ime moje, zato će poznati u onaj dan da sam ja koji govorim: Evo me.
\b
\q1 
\v 7 Kako su krasne na gorama
\q2 noge onog koji nosi dobre glase,
\q1 koji oglašuje mir,
\q2 koji javlja dobro,
\q1 oglašuje spasenje,
\q2 govori Sionu: Bog tvoj caruje.
\q1 
\v 8 Stražari će tvoji podignuti glas,
\q2 podignuće glas, i svi će zapevati,
\q2 jer će očima videti gde Gospod vodi natrag Sion.
\q1 
\v 9 Klikujte i pevajte,
\q2 razvaline jerusalimske,
\q1 jer Gospod uteši narod svoj,
\q2 izbavi Jerusalim.
\q1 
\v 10 Zagali Gospod svetu mišicu svoju pred svim narodima,
\q2 da vide svi krajevi zemaljski spasenje Boga našeg.
\b
\q1 
\v 11 Odstupite, odstupite, izađite odatle,
\q2 ne dotičite se ničeg nečistog;
\q1 izađite ispred njega,
\q2 očistite se vi koji nosite sudove Gospodnje.
\q1 
\v 12 Jer nećete izaći u hitnji,
\q2 niti ćete ići bežeći;
\q1 jer će Gospod ići pred vama,
\q2 i zadnja vojska biće vam Bog Izrailjev.
\b
\q1 
\v 13 Gle, sluga će moj biti srećan,
\q2 podignuće se i uzvisiće se i proslaviće se.
\q1 
\v 14 Kako se mnogi začudiše Tebi,
\q2 što beše nagrđen u licu mimo svakog čoveka,
\q2 i u stasu mimo sinova čovečjih,
\q1 
\v 15 Tako će opet udiviti mnoge narode,
\q2 carevi će pred Njim zatisnuti usta svoja,
\q1 jer će videti šta im nije kazivano
\q2 i razumeće šta nisu slušali.
\c 53
\s1 Patnja i slava sluge Božijeg.
\q1 
\v 1 Ko verova propovedanju našem,
\q2 i mišica Gospodnja kome se otkri?
\q1 
\v 2 Jer izniče pred Njim kao šibljika,
\q2 i kao koren iz suve zemlje;
\q1 ne bi obličja ni lepote u Njega;
\q1 i videsmo Ga, i ne beše ništa na očima,
\q2 čega radi bismo Ga poželeli.
\q1 
\v 3 Prezren beše i odbačen između ljudi,
\q2 bolnik i vičan bolestima,
\q1 i kao jedan od koga svak zaklanja lice,
\q2 prezren da Ga nizašta ne uzimasmo.
\b
\q1 
\v 4 A On bolesti naše nosi
\q2 i nemoći naše uze na se,
\q1 a mi mišljasmo da je ranjen,
\q2 da Ga Bog bije i muči.
\q1 
\v 5 Ali On bi ranjen za naše prestupe,
\q2 izbijen za naša bezakonja;
\q1 kar beše na Njemu našeg mira radi,
\q2 i ranom Njegovom mi se iscelismo.
\q1 
\v 6 Svi mi kao ovce zađosmo,
\q2 svaki nas se okrenu svojim putem,
\q1 i Gospod pusti na Nj bezakonje svih nas.
\b
\q1 
\v 7 Mučen bi i zlostavljen,
\q2 ali ne otvori usta svojih;
\q1 kao jagnje na zaklanje vođen bi
\q2 i kao ovca nema pred onim koji je striže
\q2 ne otvori usta svojih.
\q1 
\v 8 Od teskobe i od suda uze se,
\q2 a rod Njegov ko će iskazati?
\q1 Jer se istrže iz zemlje živih
\q2 i za prestupe naroda mog bi ranjen.
\q1 
\v 9 Odrediše Mu grob sa zločincima,
\q2 ali na smrti bi s bogatim,
\q1 jer ne učini nepravdu,
\q2 niti se nađe prevara u ustima Njegovim.
\b
\q1 
\v 10 Ali Gospodu bi volja da Ga bije,
\q2 i dade Ga na muke;
\q1 kad položi dušu svoju u prinos za greh,
\q2 videće natražje, produžiće dane,
\q1 i šta je Gospodu ugodno
\q2 napredovaće Njegovom rukom.
\q1 
\v 11 Videće trud duše svoje
\q2 i nasitiće se;
\q1 pravedni sluga moj opravdaće mnoge svojim poznanjem,
\q2 i sam će nositi bezakonja njihova.
\q1 
\v 12 Zato ću Mu dati deo za mnoge,
\q2 i sa silnima će deliti plen,
\q1 jer je dao dušu svoju na smrt,
\q2 i bi metnut među zločince,
\q1 i sam nosi grehe mnogih,
\q2 i za zločince se moli.
\c 54
\s1 Bog obriče svom narodu da će se rasprostraniti po celom svetu i zajemčava mu svoju večnu milost.
\q1 
\v 1 Veseli se, nerotkinjo koja ne rađaš,
\q2 zapevaj i poklikni ti, koja ne trpiš muke od porođaja,
\q1 jer pusta ima više dece
\q2 nego li ona koja ima muža, veli Gospod.
\q1 
\v 2 Raširi mesto šatora svog,
\q2 i zavese stana tvog neka se razastru,
\q1 ne brani, produži uža svoja,
\q2 kolje svoje utvrdi.
\q1 
\v 3 Jer ćeš se nadesno i nalevo rasprostraniti,
\q2 i seme će tvoje naslediti narode,
\q2 i puste će gradove naseliti.
\b
\q1 
\v 4 Ne boj se, jer se nećeš osramotiti,
\q2 i nemoj se stideti, jer nećeš biti prekorna,
\q1 nego ćeš zaboraviti sramotu mladosti svoje,
\q2 i prekora udovištva svog nećeš se više sećati.
\q1 
\v 5 Jer ti je muž Tvorac tvoj,
\q2 ime Mu je Gospod nad vojskama,
\q1 i Izbavitelj ti je Svetac Izrailjev,
\q2 Bog svoj zemlji zvaće se.
\q1 
\v 6 Jer kao ženu ostavljenu i u duhu ožalošćenu
\q2 dozva te Gospod,
\q1 i kao mladu ženu puštenu,
\q2 govori Gospod.
\q1 
\v 7 Zamalo ostavih te,
\q2 ali s velikom milošću pribraću te.
\q1 
\v 8 U malom gnevu sakrih za čas lice svoje od tebe,
\q2 ali ću te večnom milošću pomilovati,
\q1 veli Izbavitelj tvoj Gospod.
\b
\q1 
\v 9 Jer mi je to kao potop Nojev:
\q2 jer kao što se zakleh da potop Nojev neće više doći na zemlju,
\q2 tako se zakleh da se neću razgneviti na te niti ću te karati.
\q1 
\v 10 Ako će se i gore pomaknuti i humovi se pokolebati,
\q2 opet milost moja neće se odmaknuti od tebe,
\q2 i zavet mira mog neće se pokolebati,
\q1 veli Gospod, koji ti je milostiv.
\b
\q1 
\v 11 Nevoljnice, koju vetar razmeće,
\q2 koja si bez utehe,
\q1 evo ja ću namestiti kamenje tvoje na mramoru porfirnom,
\q2 i osnovaću te na safirima.
\q1 
\v 12 I načiniću ti prozore od kristala,
\q2 i vrata od kamena rubina,
\q2 i sve međe tvoje od dragog kamenja.
\q1 
\v 13 A sinovi će tvoji svi biti naučeni od Gospoda,
\q2 i obilan mir imaće sinovi tvoji.
\q1 
\v 14 Pravdom ćeš se utvrditi,
\q2 daleko ćeš biti od nasilja, te se nećeš bojati,
\q2 i od strahote, jer ti se neće približiti.
\q1 
\v 15 Gle, biće ih koji će se sabirati na te,
\q2 ali neće biti od mene;
\q2 koji se god saberu na te, pašće.
\q1 
\v 16 Gle, ja sam stvorio kovača
\q2 koji raspaljuje ugljevlje i vadi oruđe za svoj posao,
\q1 ja sam stvorio i krvnika da ubija.
\q2 
\v 17 Nikakvo oružje načinjeno protiv tebe neće biti srećno,
\q2 i svaki jezik koji se podigne na te na sudu saprećeš.
\q1 To je nasledstvo sluga Gospodnjih
\q2 i pravda njihova od mene,
\q2 veli Gospod.
\c 55
\s1 Opšti poziv na zavet milosti. Sila reči Božije.
\q1 
\v 1 Oj žedni koji ste god,
\q2 hodite na vodu,
\q1 i koji nemate novca,
\q2 hodite, kupujte i jedite;
\q1 hodite, kupujte bez novca i bez plate vino i mleko.
\q1 
\v 2 Zašto trošite novce svoje na ono što nije hrana,
\q2 i trud svoj na ono što ne siti?
\q1 Slušajte me, pa ćete jesti šta je dobro,
\q2 i duša će se vaša nasladiti pretiline.
\q1 
\v 3 Prignite uho svoje i hodite k meni;
\q2 poslušajte, i živa će biti duša vaša,
\q1 i učiniću s vama zavet večan,
\q2 milosti Davidove istinite.
\q1 
\v 4 Evo, dadoh ga za svedoka narodima,
\q2 za vođu i zapovednika narodima.
\q1 
\v 5 Evo, zvaćeš narod koji nisi znao,
\q2 i narodi koji te nisu znali steći će se k tebi,
\q1 radi Gospoda Boga tvog
\q2 i Sveca Izrailjevog, jer te proslavi.
\b
\q1 
\v 6 Tražite Gospoda, dok se može naći;
\q2 prizivajte Ga, dokle je blizu.
\q1 
\v 7 Neka bezbožnik ostavi svoj put
\q2 i nepravednik misli svoje;
\q1 i neka se vrati ka Gospodu,
\q2 i smilovaću se na nj,
\q1 i k Bogu našem,
\q2 jer prašta mnogo.
\q1 
\v 8 Jer misli moje nisu vaše misli,
\q2 niti su vaši putevi moji putevi,
\q2 veli Gospod;
\q1 
\v 9 Nego koliko su nebesa više od zemlje,
\q2 toliko su putevi moji viši od vaših puteva,
\q1 i misli moje od vaših misli.
\b
\q1 
\v 10 Jer kako pada dažd ili sneg s neba
\q2 i ne vraća se onamo,
\q1 nego natapa zemlju
\q2 i učini da rađa i da se zeleni,
\q1 da daje seme da se seje
\q2 i hleb da se jede,
\q1 
\v 11 Tako će biti reč moja kad izađe iz mojih usta:
\q2 neće se vratiti k meni prazna,
\q1 nego će učiniti šta mi je drago,
\q2 i srećno će svršiti na šta je pošaljem.
\b
\q1 
\v 12 Jer ćete s veseljem izaći,
\q2 i u miru ćete biti vođeni;
\q1 gore i bregovi pevaće pred vama od radosti,
\q2 i sva će drveta poljska pljeskati rukama.
\q1 
\v 13 Mesto trnja niknuće jela,
\q2 mesto koprive niknuće mirta;
\q1 i to će biti Gospodu u slavu,
\q2 za večan znak, koji neće nestati.
\c 56
\s1 Opominjanje na spasenje koje će doći. Obraćanje neznabožaca. Kazna rđavih narodnih pastira.
\q1 
\v 1 Ovako veli Gospod:
\q1 Pazite na sud, i tvorite pravdu,
\q2 jer će skoro doći spasenje moje,
\q2 i pravda će se moja objaviti.
\q1 
\v 2 Blago čoveku koji tako čini,
\q2 i sinu čovečjem koji se drži toga
\q1 čuvajući subotu da se ne oskvrni,
\q2 čuvajući ruku svoju da ne učini zlo.
\b
\q1 
\v 3 I neka ne govori tuđin koji pristane uz Gospoda:
\q2 Gospod me je odlučio od svog naroda;
\q1 i neka ne govori uškopljenik:
\q2 Gle, ja sam suvo drvo.
\q1 
\v 4 Jer ovako veli Gospod za uškopljenike:
\q1 Koji drže subote moje i izbiraju šta je meni ugodno, i drže zavet moj,
\q1 
\v 5 Njima ću dati u domu svom i među zidovima svojim mesto i ime
\q2 bolje nego sinova i kćeri,
\q2 ime večno daću svakome od njih, koje se neće zatrti.
\b
\q1 
\v 6 A tuđine koji pristanu uz Gospoda
\q2 da Mu služe i da ljube ime Gospodnje, da Mu budu sluge,
\q2 koji god drže subotu da je ne oskvrne i drže zavet moj,
\q1 
\v 7 Njih ću dovesti na svetu goru svoju
\q2 i razveseliću ih u domu svom molitvenom;
\q1 žrtve njihove paljenice i druge žrtve biće ugodne na oltaru mom,
\q2 jer će se dom moj zvati dom molitve svim narodima.
\q1 
\v 8 Gospod Gospod govori,
\q2 koji sabira prognanike Izrailjeve:
\q1 Još ću mu sabrati osim onih koji su sabrani.
\b
\q1 
\v 9 Sve zveri poljske, hodite da jedete, sve zveri šumske.
\q1 
\v 10 Svi su mu stražari slepi, ništa ne znaju,
\q2 svi su psi nemi, ne mogu lajati,
\q2 sanjivi su, leže, mio im je dremež.
\q1 
\v 11 I psi su proždrljivi, koji ne znaju za sitost;
\q1 i pastiri su koji ne znaju za razum,
\q2 svaki se okreće svojim putem,
\q2 svaki za svojom korišću sa svog kraja.
\q1 
\v 12 Hodite, uzeću vina i napićemo se silovitog pića,
\q2 i sutra će biti kao danas, i još mnogo više.
\c 57
\s1 Mir pravednika i u smrti; nemir bezbožnika.
\q1 
\v 1 Pravednik mre, i niko ne mari;
\q2 i pobožni se ljudi uzimaju,
\q2 a niko se ne seća da se pred zlo uzima pravednik;
\q1 
\v 2 Dolazi u mir i počiva na postelji svojoj
\q2 ko god hodi pravim putem.
\q1 
\v 3 A vi sinovi vračarini,
\q2 rode kurvarski, koji se kurvate,
\q2 pristupite ovamo.
\q1 
\v 4 Kim se rugate?
\q2 Na koga razvaljujete usta i plazite jezik?
\q2 Niste li sinovi prestupnički, seme lažno?
\q1 
\v 5 Koji se upaljujete za lugovima,
\q2 pod svakim zelenim drvetom,
\q1 koljete sinove svoje u potocima,
\q2 pod vrletima kamenim.
\q1 
\v 6 Deo ti je među glatkim kamenjem potočnim;
\q2 to je, to je tvoj deo;
\q1 njemu liješ naliv svoj, prinosiš dar;
\q2 time li ću se umiriti?
\q1 
\v 7 Na gori visokoj i uzvišenoj mećeš postelju svoju;
\q2 i onamo izlaziš da prineseš žrtvu.
\q1 
\v 8 I iza vrata i iza dovrataka mećeš spomen svoj;
\q2 odstupivši od mene otkrivaš se,
\q1 i izašavši gore širiš odar svoj,
\q2 ugovaraš s njima,
\q1 mila ti je postelja njihova,
\q2 gde ugledaš mesto.
\q1 
\v 9 Ideš k caru s uljem,
\q2 s mnogim mirisima svojim;
\q1 šalješ poslanike svoje daleko
\q2 i ponižuješ se do groba.
\q1 
\v 10 Od dalekog puta svog umorna ne kažeš: Zaludu.
\q2 Nalaziš život ruci svojoj, zato ne sustaješ.
\b
\q1 
\v 11 I od koga si se uplašila
\q2 i koga si se pobojala,
\q1 te si slagala
\q2 i nisi se mene opominjala niti si marila?
\q1 Što ja ćutah odavna,
\q2 zato li me se ne bojiš?
\q1 
\v 12 Ja ću objaviti tvoju pravdu i tvoja dela;
\q2 ali ti neće pomoći.
\q1 
\v 13 Kad staneš vikati,
\q2 neka te izbave oni koje si sabrala;
\q1 ali će ih sve vetar odneti,
\q2 i uzeće ih taština.
\q1 Ali ko se u me uzda,
\q2 naslediće zemlju i dobiće svetu goru moju.
\b
\q1 
\v 14 I reći će se:
\q1 Poravnite, poravnite, pripravite put,
\q2 uklonite smetnje s puta naroda mog.
\q1 
\v 15 Jer ovako govori Visoki i uzvišeni,
\q2 koji živi u večnosti, kome je ime Sveti:
\q1 Na visini i u svetinji stanujem
\q2 i s onim ko je skrušenog srca i smernog duha
\q2 oživljujući duh smernih i oživljujući srce skrušenih.
\q1 
\v 16 Jer se neću jednako preti
\q2 niti ću se doveka gneviti,
\q1 jer bi iščezao preda mnom duh
\q2 i duše koje sam stvorio.
\q1 
\v 17 Za bezakonje lakomosti njegove razgnevih se,
\q2 i udarih ga, sakrih se i razgnevih se,
\q2 jer odmetnuvši se otide putem srca svog.
\q1 
\v 18 Vidim puteve njegove, ali ću ga isceliti,
\q2 vodiću ga i daću opet utehu njemu i njegovima koji tuže.
\q1 
\v 19 Ja stvaram plod usnama:
\q2 mir, mir onome ko je daleko i ko je blizu, veli Gospod,
\q2 i isceliću ga.
\q1 
\v 20 A bezbožnici su kao more uskolebano,
\q2 koje se ne može umiriti
\q2 i voda njegova izmeće nečistoću i blato.
\q1 
\v 21 Nema mira bezbožnicima,
\q2 veli Bog moj.
\c 58
\s1 Kazna za prividnu svetost. Blagoslov za istinsku službu Bogu.
\q1 
\v 1 Viči iz grla, ne usteži se,
\q2 podigni glas svoj kao truba,
\q1 i objavi narodu mom bezakonja njegova
\q2 i domu Jakovljevom grehe njihove,
\q1 
\v 2 Premda me svaki dan traže
\q2 i radi su znati puteve moje,
\q1 kao narod koji tvori pravdu
\q2 i ne ostavlja sud Boga svog;
\q1 ištu od mene sudove pravedne,
\q2 žele približiti se k Bogu.
\q1 
\v 3 Zašto postismo, vele, a Ti ne pogleda,
\q2 mučismo duše svoje, a Ti ne hte znati?
\q1 Gle, kad postite, činite svoju volju
\q2 i izgonite sve šta vam je ko dužan.
\q1 
\v 4 Eto postite da se prete i svađate
\q2 i da bijete pesnicom bezbožno.
\q1 Nemojte postiti tako kao danas,
\q2 da bi se čuo gore glas vaš.
\q1 
\v 5 Takav li je post koji izabrah
\q2 da čovek muči dušu svoju jedan dan?
\q1 Da savija glavu svoju kao sita
\q2 i da stere poda se kostret i pepeo?
\q1 To li ćeš zvati post
\q2 i dan ugodan Gospodu?
\b
\q1 
\v 6 A nije li ovo post što izabrah:
\q1 da razvežeš sveze bezbožnosti,
\q2 da razrešiš remenje od bremena,
\q1 da otpustiš potlačene,
\q2 i da izlomite svaki jaram?
\q1 
\v 7 Nije li da prelamaš hleb svoj gladnome,
\q2 i siromahe prognane da uvedeš u kuću?
\q1 Kad vidiš golog, da ga odeneš,
\q2 i da se ne kriješ od svog tela?
\q1 
\v 8 Tada će sinuti videlo tvoje kao zora,
\q2 i zdravlje će tvoje brzo procvasti,
\q1 i pred tobom će ići pravda tvoja,
\q2 slava Gospodnja biće ti zadnja straža.
\q1 
\v 9 Tada ćeš prizivati, i Gospod će te čuti;
\q2 vikaćeš, i reći će: Evo me.
\q1 Ako izbaciš između sebe jaram
\q2 i prestaneš pružati prst i govoriti zlo;
\q1 
\v 10 I ako otvoriš dušu svoju gladnome,
\q2 i nasitiš dušu nevoljnu;
\q1 tada će zasjati u mraku videlo tvoje
\q2 i tama će tvoja biti kao podne.
\q1 
\v 11 Jer će te Gospod voditi vazda,
\q2 i sitiće dušu tvoju na suši,
\q1 i kosti tvoje krepiće,
\q2 i bićeš kao vrt zaliven
\q2 i kao izvor kome voda ne presiše.
\q1 
\v 12 I tvoji će sazidati stare pustoline,
\q2 i podignućeš temelje koji će stajati od kolena do kolena,
\q1 i prozvaćeš se:
\q2 Koji sazida razvaline i opravi puteve za naselje.
\b
\q1 
\v 13 Ako odvratiš nogu svoju od subote
\q2 da ne činiš šta je tebi drago na moj sveti dan,
\q1 i ako prozoveš subotu milinom,
\q2 sveti dan Gospodnji slavnim,
\q1 i budeš ga slavio ne idući svojim putevima
\q2 i ne čineći šta je tebi drago, ni govoreći reči,
\q1 
\v 14 Tada ćeš se veseliti u Gospodu,
\q2 i izvešću te na visine zemaljske,
\q1 i daću ti da jedeš nasledstvo Jakova oca svog;
\q2 jer usta Gospodnja rekoše.
\c 59
\s1 Pokvarenost bezbožnog naroda. Obricanje spasitelja.
\q1 
\v 1 Gle, nije okraćala ruka Gospodnja
\q2 da ne može spasti,
\q1 niti je otežalo uho Njegovo
\q2 da ne može čuti.
\q1 
\v 2 Nego bezakonja vaša rastaviše vas s Bogom vašim,
\q2 i gresi vaši zakloniše lice Njegovo od vas, da ne čuje.
\q1 
\v 3 Jer su ruke vaše oskvrnjene krvlju
\q2 i prsti vaši bezakonjem;
\q1 usne vaše govore laž
\q2 i jezik vaš izriče opačinu.
\q1 
\v 4 Nema nikoga da viče za pravdu,
\q2 niti ima da se pre za istinu;
\q1 uzdaju se u ništavilo, i govore laž;
\q2 začinju nevolju, i rađaju muku.
\q1 
\v 5 Nose jaja aspidina
\q2 i tkaju paučinu;
\q1 ko pojede jaje njihovo umre,
\q2 i ako koje razbije, izađe guja.
\q1 
\v 6 Platno njihovo nije za haljine,
\q2 niti će se oni odenuti svojim poslom;
\q1 posao je njihov bezakonje
\q2 i u rukama je njihovim nasilje.
\q1 
\v 7 Noge im trče na zlo
\q2 i brze su na prolivanje krvi prave;
\q1 misli su njihove bezakonje;
\q2 na putevima je njihovim pustoš i rasap.
\q1 
\v 8 Put mirni ne znaju,
\q2 i na putevima njihovim nema pravde;
\q1 načinili su sebi krive staze;
\q2 ko god ide po njima, ne zna za mir.
\b
\q1 
\v 9 Zato je sud daleko od nas,
\q2 i pravda ne dolazi do nas;
\q1 čekamo videlo, a ono, eto mrak;
\q2 svetlost, a ono hodimo po tami.
\q1 
\v 10 Pipamo kao slepci zid,
\q2 kao oni koji nemaju očiju pipamo;
\q1 spotičemo se u podne kao u sumračje;
\q2 u obilju smo kao mrtvi.
\q1 
\v 11 Ričemo svikoliki kao medvedi,
\q2 i jednako učemo kao golubice;
\q1 čekamo sud, a njega nema,
\q2 spasenje, a ono je daleko od nas.
\q1 
\v 12 Jer se prestupi naši umnožiše pred Tobom
\q2 i gresi naši svedoče na nas;
\q1 jer su prestupi naši kod nas
\q2 i bezakonja svoja znamo,
\q1 
\v 13 Da neveru učinismo i slagasmo Gospodu,
\q2 i odstupismo od Boga svog,
\q1 govorismo o nasilju i odmetu, da,
\q2 sastavljasmo i iznosismo iz srca reči lažne.
\b
\q1 
\v 14 Zato sud odstupi natrag,
\q2 i pravda stoji daleko;
\q1 jer istina pade na ulici
\q2 i pravda ne može da prođe.
\q1 
\v 15 I istine je nestalo,
\q2 i ko se uklanja od zla, postaje plen.
\q1 To vide Gospod,
\q2 i ne bi Mu milo što nema suda.
\b
\q1 
\v 16 I vide gde nema čoveka,
\q2 i začudi se što nema posrednika;
\q1 zato učini Mu spasenje mišica Njegova,
\q2 i pravda Njegova podupre Ga.
\q1 
\v 17 Jer se obuče u pravdu kao u oklop,
\q2 i šlem spasenja metnu na glavu;
\q1 odenu se osvetom kao odelom,
\q2 i ogrte se revnošću kao plaštem.
\q1 
\v 18 Po delima, po delima da vrati
\q2 gnev protivnicima svojim,
\q1 platu neprijateljima svojim,
\q2 ostrvima da plati.
\q1 
\v 19 I bojaće se imena Gospodnjeg sa zapada,
\q2 i slave Njegove s istoka sunčanog;
\q1 jer će neprijatelj navaliti kao reka,
\q2 a Duh će Gospodnji podignuti zastavu suprot njemu.
\b
\q1 
\v 20 I doći će Izbavitelj u Sion
\q2 i k onima od Jakova koji se obraćaju od greha,
\q2 veli Gospod.
\b
\p 
\v 21 A ovo će biti zavet moj s njima, veli Gospod: Duh moj, koji je u tebi, i reči moje, koje metnuh u usta tvoja, neće otići od usta tvojih ni od usta semena tvog, ni od usta semena semena tvog, veli Gospod, odsele i doveka.
\c 60
\s1 Slava Siona. Obraćanje neznabožaca. Gospod je večno videlo svog naroda.
\q1 
\v 1 Ustani, svetli se,
\q2 jer dođe svetlost tvoja,
\q2 i slava Gospodnja obasja te.
\q1 
\v 2 Jer, gle, mrak će pokriti zemlju
\q2 i tama narode;
\q1 a tebe će obasjati Gospod
\q2 i slava Njegova pokazaće se nad tobom.
\q1 
\v 3 I narodi će doći k videlu tvom
\q2 i ka svetlosti koja će te obasjati.
\b
\q1 
\v 4 Podigni oči svoje unaokolo, i vidi:
\q2 svi se skupljaju i idu k tebi,
\q1 sinovi će tvoji iz daleka doći
\q2 i kćeri tvoje nosiće se u naručju.
\q1 
\v 5 Tada ćeš videti, i obradovaćeš se,
\q2 i srce će ti se udiviti i raširiti,
\q1 jer će se k tebi okrenuti mnoštvo morsko
\q2 i sila naroda doći će k tebi.
\q1 
\v 6 Mnoštvo kamila prekriliće te,
\q2 dromedari iz Madijana i Efe;
\q1 svi iz Save doći će,
\q2 zlato i kad doneće,
\q2 i slavu Gospodnju javljaće.
\q1 
\v 7 Sva stada kidarska skupiće se k tebi,
\q2 ovnovi navajotski biće ti za potrebu;
\q1 prineseni na oltaru mom biće ugodni,
\q2 i dom slave svoje proslaviću.
\b
\q1 
\v 8 Ko su ono što lete kao oblaci
\q2 i kao golubovi na prozore svoje?
\q1 
\v 9 Ostrva će me čekati
\q2 i prve lađe tarsiske,
\q1 da dovezu sinove tvoje iz daleka,
\q2 i s njima srebro njihovo i zlato njihovo,
\q1 imenu Gospoda Boga tvog i Sveca Izrailjevog,
\q2 jer te proslavi.
\b
\q1 
\v 10 I tuđini će sazidati zidove tvoje,
\q2 i carevi njihovi služiće ti;
\q1 jer u gnevu svom udarih te,
\q2 a po milosti svojoj pomilovaću te.
\q1 
\v 11 I tvoja će vrata biti svagda otvorena,
\q2 neće se zatvoriti ni danju ni noću,
\q1 da ti se dovede sila naroda,
\q2 i carevi njihovi da se dovedu.
\q1 
\v 12 Jer narod i carstvo, koje ti ne bi služilo, poginuće,
\q2 takvi će se narodi sasvim zatrti.
\q1 
\v 13 Slava livanska tebi će doći,
\q2 jela, brest i šimšir,
\q1 da ukrase mesto svetinje moje
\q2 da bi proslavio mesto nogu svojih.
\q1 
\v 14 I sinovi onih koji su te mučili
\q2 doći će k tebi klanjajući se,
\q1 i svi koji te preziraše
\q2 padaće k stopalima nogu tvojih,
\q1 i zvaće te gradom Gospodnjim,
\q2 Sionom Sveca Izrailjevog.
\b
\q1 
\v 15 Što si bio ostavljen i mrzak
\q2 tako da niko nije prolazio kroza te,
\q1 mesto toga ću ti učiniti večnu slavu,
\q2 i veselje od kolena do kolena.
\q1 
\v 16 Jer ćeš mleko naroda sati,
\q2 i sise carske dojićeš,
\q1 i poznaćeš da sam ja Gospod
\q2 Spasitelj tvoj i Izbavitelj tvoj, Silni Jakovljev.
\b
\q1 
\v 17 Mesto bronze doneću zlata,
\q2 i mesto gvožđa doneću srebra,
\q1 i bronze mesto drva,
\q2 i gvožđa mesto kamenja,
\q1 i postaviću ti za upravitelje mir
\q2 i za nastojnike pravdu.
\q1 
\v 18 Neće se više čuti nasilje u tvojoj zemlji
\q2 ni pustošenje i potiranje na međama tvojim;
\q1 nego ćeš zvati zidove svoje spasenjem
\q2 i vrata svoja hvalom.
\b
\q1 
\v 19 Neće ti više biti sunce videlo danju,
\q2 niti će ti sjajni mesec svetliti;
\q1 nego će ti Gospod biti videlo večno
\q2 i Bog tvoj biće ti slava.
\q1 
\v 20 Neće više zalaziti sunce tvoje,
\q2 niti će mesec tvoj pomrčati;
\q1 jer će ti Gospod biti videlo večno,
\q2 i dani žalosti tvoje svršiće se.
\q1 
\v 21 I tvoj će narod biti sav pravedan,
\q2 naslediće zemlju navek;
\q1 mladica koju sam posadio,
\q2 delo ruku mojih biće na moju slavu.
\q1 
\v 22 Od malog će postati hiljada
\q2 i od nejakog silan narod;
\q1 ja Gospod brzo ću učiniti to kad bude vreme.
\c 61
\s1 Jevanđelje o budućem Mesiji punom milosti.
\q1 
\v 1 Duh je Gospoda Boga na meni,
\q2 jer me Gospod pomaza
\q1 da javljam dobre glasove krotkima,
\q2 posla me da zavijem ranjene u srcu,
\q1 da oglasim zarobljenima slobodu
\q2 i sužnjima da će im se otvoriti tamnica.
\q1 
\v 2 Da oglasim godinu milosti Gospodnje
\q2 i dan osvete Boga našeg,
\q2 da utešim sve žalosne,
\q1 
\v 3 Da učinim žalosnima u Sionu
\q2 i dam im nakit mesto pepela,
\q1 ulje radosti umesto žalosti,
\q2 odelo za pohvalu umesto duha tužnog,
\q1 da se prozovu hrastovi pravde,
\q2 sad Gospodnji za slavu Njegovu.
\q1 
\v 4 I oni će sazidati davnašnje pustoline,
\q2 podignuće stare razvaline
\q1 i ponoviće gradove puste,
\q2 što leže razvaljeni od mnogo naraštaja.
\b
\q1 
\v 5 I tuđini će stajati i pasti stada vaša,
\q2 i inostranci će biti vaši orači i vinogradari.
\q1 
\v 6 A vi ćete se zvati sveštenici Gospodnji,
\q2 Sluge Boga našeg govoriće vam se,
\q1 blago naroda ješćete
\q2 i slavom njihovom hvalićete se.
\q1 
\v 7 Za dvostruku sramotu vašu,
\q2 i što se pevaše: Rug je deo njihov,
\q1 zato će u zemlji njihovoj naslediti dvojinom
\q2 i imaće večnu radost.
\b
\q1 
\v 8 Jer ja Gospod ljubim pravdu
\q2 i mrzim na grabež sa žrtvom paljenicom,
\q1 i daću im platu uistinu,
\q2 i večan zavet učiniću s njima.
\q1 
\v 9 I seme će se njihovo znati u narodima
\q2 i natražje njihovo među plemenima;
\q1 ko ih god vidi poznaće ih
\q2 da su seme koje je blagoslovio Gospod.
\b
\q1 
\v 10 Veoma ću se radovati u Gospodu,
\q2 i duša će se moja veseliti u Bogu mom,
\q1 jer me obuče u haljine spasenja
\q2 i plaštem pravde ogrte me,
\q1 kao kad ženik namesti nakit
\q2 i kao kad se nevesta ukrasi uresom svojim.
\q1 
\v 11 Jer kao što iz zemlje raste bilje
\q2 i u vrtu niče šta se poseje,
\q1 tako će Gospod Bog učiniti da nikne pravda
\q2 i pohvala pred svim narodima.
\c 62
\s1 Buduća slava Siona.
\q1 
\v 1 Siona radi neću umuknuti,
\q2 i Jerusalima radi neću se umiriti,
\q1 dokle ne izađe kao svetlost pravda njegova
\q2 i spasenje se njegovo razgori kao sveća.
\q1 
\v 2 Tada će videti narodi pravdu tvoju
\q2 i svi carevi slavu tvoju,
\q1 i prozvaćeš se novim imenom,
\q2 koje će usta Gospodnja izreći.
\q1 
\v 3 I bićeš krasan venac u ruci Gospodnjoj
\q2 i carska kruna u ruci Boga svog.
\q1 
\v 4 Nećeš se više zvati ostavljena,
\q2 niti će se zemlja tvoja zvati pustoš,
\q1 nego ćeš se zvati milina moja
\q2 i zemlja tvoja udata,
\q1 jer ćeš biti mio Gospodu
\q2 i zemlja će tvoja biti udata.
\q1 
\v 5 Jer kao što se momak ženi devojkom,
\q2 tako će se sinovi tvoji oženiti tobom;
\q1 i kako se raduje ženik nevesti,
\q2 tako će se tebi radovati Bog tvoj.
\b
\q1 
\v 6 Na zidovima tvojim, Jerusalime,
\q2 postavih stražare,
\q1 koji neće umuknuti nikada,
\q2 ni danju ni noću.
\q1 Koji pominjete Gospoda,
\q2 nemojte ćutati.
\q1 
\v 7 I ne dajte da se umukne o Njemu
\q2 dokle ne utvrdi i učini Jerusalim slavom na zemlji.
\q1 
\v 8 Zakle se Gospod desnicom svojom
\q2 i krepkom mišicom svojom:
\q1 neću više dati žito tvoje neprijateljima tvojim da jedu,
\q2 niti će tuđini piti vino tvoje, oko koga si se trudio;
\q1 
\v 9 Nego koji ga žanju, oni će ga jesti
\q2 i hvaliti Gospoda,
\q1 i koji ga beru oni će ga piti
\q2 u tremovima svetinje moje.
\b
\q1 
\v 10 Prođite, prođite kroz vrata,
\q2 pripravite put narodu;
\q1 poravnite, poravnite put,
\q2 uklonite kamenje,
\q2 podignite zastavu narodima.
\q1 
\v 11 Evo, Gospod oglasi do krajeva zemaljskih;
\q1 recite kćeri sionskoj:
\q2 evo, Spasitelj tvoj ide;
\q1 evo, plata je Njegova kod Njega
\q2 i delo Njegovo pred Njim.
\q1 
\v 12 I oni će se prozvati narod sveti,
\q2 iskupljenici Gospodnji;
\q1 a ti ćeš se prozvati:
\q2 traženi, grad neostavljeni.
\c 63
\s1 Gospod gazi neprijatelje. Osvrt na stare dane. Molitva za spasenje.
\q1 
\v 1 Ko je ono što ide iz Edoma,
\q2 iz Vosora, u crvenim haljinama?
\q1 Krasno odeven,
\q2 koračajući u veličini sile svoje?
\q1 Ja sam, koji govorim pravdu
\q2 i vredan sam spasti.
\b
\q1 
\v 2 Zašto Ti je crveno odelo
\q2 i haljine Ti kao u onog koji gazi u kaci?
\b
\q1 
\v 3 Gazih sam u kaci,
\q2 i niko između naroda ne beše sa mnom;
\q1 ali ih izgazih u gnevu svom
\q2 i potlačih u ljutini svojoj;
\q1 i krv njihova poprska mi haljine
\q2 i iskaljah sve odelo svoje.
\q1 
\v 4 Jer je dan od osvete u srcu mom,
\q2 i dođe godina da se moji iskupe.
\q1 
\v 5 Pogledah, a nikoga ne beše da pomogne,
\q2 i začudih se što nikoga ne beše da podupre;
\q1 ali me desnica moja izbavi
\q2 i jarost moja podupre me.
\q1 
\v 6 I izgazih narode u gnevu svom,
\q2 i opojih ih jarošću svojom,
\q2 i prolih na zemlju krv njihovu.
\b
\q1 
\v 7 Pominjaću dobrotu Gospodnju, hvalu Gospodnju
\q2 za sve što nam je učinio Gospod,
\q1 i mnoštvo dobra što je učinio domu Izrailjevom
\q2 po milosti svojoj i po velikoj dobroti svojoj.
\q1 
\v 8 Jer reče: Doista su moj narod,
\q2 sinovi, koji neće izneveriti.
\q2 I bi im Spasitelj.
\q1 
\v 9 U svakoj tuzi njihovoj On beše tužan,
\q2 i anđeo, koji je pred Njim, spase ih.
\q1 Ljubavi svoje radi i milosti svoje radi On ih izbavi,
\q2 i podiže ih i nosi ih sve vreme.
\b
\q1 
\v 10 Ali se odmetaše i žalostiše Sveti Duh Njegov;
\q2 zato im posta neprijatelj, i ratova na njih.
\q1 
\v 11 Ali se opomenu starih vremena,
\q2 Mojsija, naroda svog:
\q1 gde je Onaj koji ih izvede iz mora s pastirom stada svog?
\q2 Gde je Onaj što metnu usred njih Sveti Duh svoj?
\q1 
\v 12 Koji ih vodi slavnom mišicom svojom
\q2 za desnicu Mojsijevu?
\q1 Koji razdvoji vodu pred njima,
\q2 da steče sebi večno ime?
\q1 
\v 13 Koji ih vodi preko bezdana kao konja preko pustinje,
\q2 da se ne spotakoše?
\q1 
\v 14 Duh Gospodnji vodi ih tiho,
\q2 kao kad stoka silazi u dolinu;
\q1 tako si vodio svoj narod
\q2 da stečeš sebi slavno ime.
\b
\q1 
\v 15 Pogledaj s neba,
\q2 i vidi iz stana svetinje svoje i slave svoje,
\q1 gde je revnost Tvoja i sila Tvoja,
\q2 mnoštvo milosrđa Tvog i milosti Tvoje?
\q1 Eda li će se meni ustegnuti?
\q1 
\v 16 Ti si zaista Otac naš,
\q2 ako i ne zna Avram za nas,
\q2 i Izrailj nas ne poznaje;
\q1 Ti si, Gospode, Otac naš,
\q2 ime Ti je, otkako je veka, Izbavitelj naš.
\q1 
\v 17 Zašto si nam dao da zađemo, Gospode,
\q2 s puteva Tvojih?
\q1 Da nam otvrdne srce
\q2 da Te se ne bojimo?
\q1 Vrati se radi sluga svojih,
\q2 radi plemena nasledstva svog.
\q1 
\v 18 Zamalo nasledi narod svetosti Tvoje;
\q2 neprijatelji naši pogaziše svetinju Tvoju.
\q1 
\v 19 Postasmo kao oni kojima nisi nikada vladao
\q2 niti je prizivano ime Tvoje nad njima.
\c 64
\s1 Nastavak molitve za spasenje.
\q1 
\v 1 O da bi razdro nebesa i sišao,
\q2 da se rastope gore od Tebe,
\q1 
\v 2 Kao što se na ognju razgori granje
\q2 i voda uzavri od ognja,
\q1 da ime Tvoje poznaju neprijatelji Tvoji
\q2 i da narodi drhću od Tebe.
\q1 
\v 3 Kad si činio strahote kojima se ne nadasmo,
\q2 Ti si silazio, i gore se rastapahu od Tebe.
\q1 
\v 4 Otkako je veka ne ču se,
\q2 niti se ušima dozna,
\q1 niti oko vide Boga osim Tebe
\q2 da bi tako učinio onima koji Ga čekaju.
\q1 
\v 5 Sretao si onog koji se raduje tvoreći pravdu;
\q2 pominju Te na putevima Tvojim;
\q1 gle, Ti si se razgnevio što grešismo;
\q2 da na njima jednako ostasmo, bismo se spasli.
\q1 
\v 6 Ali svi bejasmo kao nečisto šta,
\q2 i sva naša pravda kao nečista haljina;
\q1 zato opadosmo svi kao list,
\q2 i bezakonja naša kao vetar odnesoše nas.
\q1 
\v 7 Nikoga ne bi da priziva ime Tvoje,
\q2 da ustane da se Tebe drži,
\q1 jer si sakrio lice svoje od nas
\q2 i rastopio si nas bezakonjem našim.
\b
\q1 
\v 8 Ali sada, Gospode, Ti si naš Otac;
\q2 mi smo kao, a Ti si naš lončar,
\q2 i svi smo delo ruku Tvojih.
\q1 
\v 9 Gospode, ne gnevi se veoma,
\q2 i ne pominji doveka bezakonje;
\q2 evo, pogledaj; mi smo svi Tvoj narod.
\q1 
\v 10 Gradovi svetosti Tvoje opusteše;
\q2 Sion opuste, Jerusalim posta pustoš.
\q1 
\v 11 Dom naše svetinje i naše krasote,
\q2 u kome Te slaviše oci naši,
\q1 izgore ognjem,
\q2 i sve što nam beše drago potrveno je.
\q1 
\v 12 Hoćeš li se na to uzdržati, Gospode,
\q2 i ćutati, i jednako nas mučiti?
\c 65
\s1 Odgovor Gospodnji: primanje neznabožaca i ostatka od Izrailja. Kažnjavanje naroda koji se otpadio. Novo nebo i nova zemlja.
\q1 
\v 1 Potražiše me koji ne pitahu za me;
\q2 nađoše me koji me ne tražahu;
\q1 rekoh narodu koji se ne zove mojim imenom:
\q2 Evo me, evo me.
\q1 
\v 2 Vas dan pružah ruke svoje narodu nepokornom,
\q2 koji ide za svojim mislima putem koji nije dobar,
\q1 
\v 3 Narodu, koji me jednako gnevi u oči,
\q2 koji prinosi žrtve u vrtovima
\q2 i kadi na opekama;
\q1 
\v 4 Koji sede kod grobova
\q2 i noće u pećinama,
\q1 jedu meso svinjsko
\q2 i supa im je nečista u sudovima;
\q1 
\v 5 Koji govore: Odlazi, ne dohvataj me se,
\q2 jer sam svetiji od tebe,
\q1 ti su dim u nozdrvama mojim,
\q2 dim koji gori vas dan.
\q1 
\v 6 Eto, napisano je preda mnom:
\q1 neću ćutati, nego ću platiti,
\q2 platiću im u nedra.
\q1 
\v 7 Za bezakonja vaša
\q2 i za bezakonja otaca vaših,
\q2 veli Gospod,
\q1 koji kadiše na gorama,
\q2 i na humovima ružiše me,
\q1 izmeriću im u nedra platu
\q2 za dela koja činiše od početka.
\b
\q1 
\v 8 Ovako veli Gospod:
\q1 Kao kad ko nađe vino u grozdu, pa reče:
\q2 Ne kvari ga, jer je blagoslov u njemu,
\q1 tako ću učiniti radi sluga svojih,
\q2 neću ih potrti sve,
\q1 
\v 9 Jer ću izvesti seme iz Jakova
\q2 i iz Jude naslednika gorama svojim,
\q1 i naslediće ih izabranici moji,
\q2 i sluge moje naseliće se onde.
\q1 
\v 10 A Saron će biti tor za ovce
\q2 i dolina ahorska počivalište za goveda
\q2 narodu mom koji me traži.
\q1 
\v 11 A vi, koji ostavljate Gospoda,
\q2 koji zaboravljate svetu goru moju,
\q1 koji postavljate sto Gadu
\q2 i lijete naliv Meniju,
\q1 
\v 12 Vas ću izbrojati pod mač,
\q2 i svi ćete pripasti na klanje,
\q1 jer zvah a vi se ne odazivaste,
\q2 govorih a vi ne slušaste,
\q1 nego činiste šta je zlo preda mnom
\q2 i izabraste šta meni nije po volji.
\b
\q1 
\v 13 Zato ovako veli Gospod Gospod:
\q1 Gle, sluge će moje jesti,
\q2 a vi ćete gladovati;
\q1 gle, sluge će moje piti,
\q2 a vi ćete biti žedni;
\q1 gle, sluge će se moje veseliti,
\q2 a vi ćete se stideti.
\q1 
\v 14 Gle, sluge će moje pevati od radosti u srcu,
\q2 a vi ćete vikati od žalosti u srcu
\q2 i ridaćete od tuge u duhu.
\q1 
\v 15 I ostavićete ime svoje
\q2 izabranima mojim za uklin;
\q1 i Gospod će te Bog ubiti,
\q2 a sluge će svoje nazvati drugim imenom.
\q1 
\v 16 Ko se uzblagosilja na zemlji,
\q2 blagosiljaće se Bogom istinitim;
\q1 a ko se uskune na zemlji,
\q2 kleće se Bogom istinitim;
\q1 jer će se prve nevolje zaboraviti
\q2 i sakrivene će biti od očiju mojih.
\b
\q1 
\v 17 Jer, gle, ja ću stvoriti nova nebesa i novu zemlju,
\q1 i šta je pre bilo neće se pominjati
\q2 niti će na um dolaziti.
\q1 
\v 18 Nego se radujte i veselite se doveka
\q2 radi onog što ću ja stvoriti;
\q1 jer gle, ja ću stvoriti Jerusalim da bude veselje
\q2 i narod njegov da bude radost.
\q1 
\v 19 I ja ću se veseliti radi Jerusalima,
\q2 i radovaću se radi naroda svog,
\q2 i neće se više čuti u njemu plač ni jauk.
\q1 
\v 20 Neće više biti onde malog deteta ni starca
\q2 koji ne bi navršio dana svojih;
\q1 jer će dete umirati od sto godina,
\q2 a grešnik od sto godina biće proklet.
\q1 
\v 21 I oni će graditi kuće i sedeće u njima;
\q2 i sadiće vinograde i ješće rod njihov.
\q1 
\v 22 Neće oni graditi a drugi se naseliti,
\q2 neće saditi a drugi jesti,
\q1 jer će dani narodu mom biti kao dani drvetu,
\q2 i izabranicima će mojim ovetšati dela ruku njihovih.
\q1 
\v 23 Neće raditi uzalud,
\q2 niti će rađati za strah,
\q1 jer će biti seme blagoslovenih od Gospoda,
\q2 i natražje će njihovo biti s njima.
\q1 
\v 24 I pre nego poviču, ja ću se odazvati;
\q2 još će govoriti, a ja ću uslišiti.
\q1 
\v 25 Vuk i jagnje zajedno će pasti,
\q2 i lav će jesti slamu kao vo;
\q1 a zmiji će biti hrana prah;
\q2 neće uditi ni potirati na svoj svetoj gori mojoj,
\q2 veli Gospod.
\c 66
\s1 Kažnjavanje pretvorica. Spas novog Jerusalima i značaj za sve narode. Poslednji sud.
\q1 
\v 1 Ovako veli Gospod:
\q2 Nebo je presto moj
\q2 i zemlja podnožje nogama mojim:
\q1 gde je dom koji biste mi sazidali,
\q2 i gde je mesto za moje počivanje?
\q1 
\v 2 Jer je sve to ruka moja stvorila,
\q2 to je postalo sve, veli Gospod.
\q1 Ali na koga ću pogledati?
\q1 Na nevoljnog
\q2 i na onog ko je skrušenog duha
\q2 i ko drhće od moje reči.
\b
\q1 
\v 3 Ko kolje vola,
\q2 to je kao da ubije čoveka;
\q1 ko kolje ovcu,
\q2 to je kao da zakolje psa;
\q1 ko prinosi dar,
\q2 to je kao da prinese krv svinjsku;
\q1 ko kadi kadom,
\q2 to je kao da blagoslovi idola.
\q1 To oni izabraše na putevima svojim,
\q2 i duši se njihovoj mile gadovi njihovi.
\q1 
\v 4 Izabraću i ja prema nevaljalstvu njihovom,
\q2 i pustiću na njih čega se boje;
\q1 jer zvah a niko se ne odazva,
\q2 govorih a oni ne slušaše,
\q1 nego činiše šta je zlo preda mnom
\q2 i izabraše šta meni nije po volji.
\b
\q1 
\v 5 Slušajte reč Gospodnju,
\q2 koji drhćete od Njegove reči:
\q1 braća vaša, koja mrze na vas
\q2 i izgone vas imena mog radi, govore:
\q1 Neka se pokaže slava Gospodnja.
\q2 I pokazaće se na vašu radost,
\q2 a oni će se posramiti.
\b
\q1 
\v 6 Vika ide iz grada, glas iz crkve,
\q2 glas Gospodnji koji plaća neprijateljima svojim.
\b
\q1 
\v 7 Ona se porodi pre nego oseti bolove,
\q2 pre nego joj dođoše muke, rodi detića.
\q1 
\v 8 Ko je ikada čuo to?
\q2 Ko je video takvo šta?
\q1 Može li zemlja roditi u jedan dan?
\q2 Može li se narod roditi ujedanput?
\q2 A Sion rodi sinove svoje čim oseti bolove.
\q1 
\v 9 Eda li ja, koji otvaram matericu,
\q2 ne mogu roditi? veli Gospod.
\q1 Eda li ću ja, koji dajem da se rađa,
\q2 biti bez poroda, veli Bog tvoj.
\b
\q1 
\v 10 Radujte se s Jerusalimom i veselite se u njemu svi koji ga ljubite;
\q2 radujte se s njim svi koji ga žaliste.
\q1 
\v 11 Jer ćete sati sise od utehe njegove, i nasitićete se,
\q2 ješćete i naslađivaćete se u svetlosti slave njegove.
\b
\q1 
\v 12 Jer ovako veli Gospod:
\q1 Gle, ja ću kao reku dovesti k njemu mir
\q2 i slavu naroda kao potok bujan,
\q2 pa ćete sati;
\q1 bićete nošeni na rukama
\q2 i milovani na kolenima.
\q1 
\v 13 Kao kad koga mati njegova teši
\q2 tako ću ja vas tešiti,
\q2 i utešićete se u Jerusalimu.
\q1 
\v 14 Videćete i obradovaće se srce vaše
\q2 i kosti će se vaše pomladiti kao trava,
\q1 i znaće se ruka Gospodnja na slugama Njegovim
\q2 i gnev na neprijateljima Njegovim.
\b
\q1 
\v 15 Jer, gle, Gospod će doći s ognjem,
\q2 i kola će Mu biti kao vihor,
\q1 da izlije gnev svoj u jarosti
\q2 i pretnju u plamenu ognjenom.
\q1 
\v 16 Jer će Gospod suditi ognjem i mačem svojim svakom telu,
\q2 i mnogo će biti pobijenih od Gospoda.
\b
\p 
\v 17 Koji se osveštavaju i koji se očišćavaju u vrtovima jedan za drugim javno, koji jedu meso svinjsko i stvari gadne i miševe, svi će izginuti, veli Gospod.
\p 
\v 18 A ja znam dela njihova i misli njihove, i doći će vreme, te ću sabrati sve narode i jezike, i doći će i videće slavu moju.
\v 19 I postaviću znak na njih, i poslaću između njih koji se spasu k narodima u Tarsis, u Ful i u Lud, koji natežu luk, u Tuval i u Javan i na daleka ostrva, koja ne čuše glas o meni niti videše slavu moju, i javljaće slavu moju po narodima.
\v 20 I svu će braću vašu iz svih naroda dovesti Gospodu na dar na konjima i na kolima i na nosilima i na mazgama i na kamilama ka svetoj gori mojoj u Jerusalim, veli Gospod, kao što prinose sinovi Izrailjevi dar u čistom sudu u dom Gospodnji.
\v 21 I između njih ću uzeti sveštenike i Levite, veli Gospod.
\b
\q1 
\v 22 Jer kao što će nova nebesa i nova zemlja, što ću ja načiniti,
\q2 stajati preda mnom,
\q1 veli Gospod,
\q2 tako će stajati seme vaše i ime vaše.
\q1 
\v 23 I od mladine do mladine, i od subote do subote
\q2 dolaziće svako telo da se pokloni preda mnom,
\q2 veli Gospod.
\b
\p 
\v 24 I izlaziće i gledaće mrtva telesa onih ljudi koji se odmetnuše od mene; jer crv njihov neće umreti i oganj njihov neće se ugasiti, i biće gad svakom telu. 
