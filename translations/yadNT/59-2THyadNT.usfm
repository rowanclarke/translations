\id 2TH - Yagua NT -Peru 2008 (web -2013)
\h 2 Tesadónica
\toc1 Tamitya Catera Tesadonica Ja̱nvajyu̱
\toc2 2 Tesadónica
\toc3 2Te
\mt1 Tamitya Catera Tesadonica Ja̱nvajyu̱
\c 1
\s1 Pávuruvedabay nu̱yadara catera Tesadónicamu siityari̱vavyedabajyu̱
\p 
\v 1 Ray Pávuru, Sinubánuta, Timutévuta jarye, nu̱ñú̱rya catera jiryejyu̱, Tesadónicamu vichavay, jiryatiy savicha Vuryi̱ndenu jiryejye̱, savicha Jesucrístu jiryentyityu̱ntiy.
\v 2 Samirya jirye̱cha, samirya ra̱cha jiryejechiy varidye, Vu̱jye̱ Ju̱denumusiy, Nutyityu̱ Jesucrístumusiy jarye ra̱cha darya jiryejyu̱.
\s1 Sa̱tanuvu̱nu Ju̱denu riy juuchatavay sa̱numatiy ju̱ti̱ Crístu
\p 
\v 3 Nu̱ryijchana̱tyasarani̱ Ju̱denu jiryenchiy, ratyeryi̱veda, daryanuma nu̱tyu samirya nta ra̱sa̱ñuma jaryi jiryetyuva̱choda Ju̱denumu, ja̱murava̱ju̱numa jiryevya̱ta̱da nu̱ñi ti̱quimusiy jiryedye.
\v 4 Daryamusiy nu̱ñi tu̱chunumaya̱ Ju̱denu siityari̱vajyuuva jiryenchiy, nu̱ñi̱chana̱tya variy jirye, jiryatiy jiryetyuva̱chodamucha simu Ju̱denu paru̱cha̱riñubera, rirya̱vittyuyada nijya̱nvay variy jirye, jiryejechi̱ntyara jarupadoda.
\p 
\v 5 Ramusiy ji̱ta jvadichara darya Ju̱denu murichedoda samiy, sa̱tidye jtay: “Jiryeñi ji̱ta rasa̱ra̱vay varidye rañsu̱jyomu jayadaju̱,” ne jiryi̱nu̱y ramu jayasa̱diva jarupanusavay jiryedye.
\v 6 Ju̱denu ra̱paru̱tyatanijeya̱ rivantidyeryi rityi paru̱tyatanijeya̱ jiryentyidye.
\p 
\v 7-8 Sa̱sa̱y variy jiituyada jirye, jiryatiy jarupanusavay daryaju̱ jiryevyichanu̱yada, jirya̱tidye jiituy variy nu̱dyisa̱, sa̱numatiy dityanu Nutyityu̱ Jesús variy jarichumusiyu, su̱pa̱vajyuu yisa̱, jiryatiy sa̱jpa̱ jivyanu̱yadata riy; sa̱tidye murichenutaniy jiidatya variryi, jaryi quivedatara, jiryatiy ne ridyetyaru̱y daryaju̱ni̱ Ju̱denu, ne rityuva̱churu̱y ramu samitu̱choda sanchiy Vu̱yntyityu̱ Jesúsntiy.
\v 9-10 Riñi jmu̱tya̱ra ramurichenusa̱da, rirya̱parutaye̱ Ju̱denu mo̱musiy, sadá vandamusiy, jiryatiy savanu̱yadadára, sa̱numatiy ju̱ti̱ sa̱tidye vicha vanda nu̱yadati̱ jijyiintyasavamyu, sa̱cha ti̱ttasi̱ variy rijyu̱ ti̱ta̱ju̱ simu tuva̱chuvay variryundamu, jiryatiy jiryetyuva̱choda daryaju̱ nu̱tyu̱chodamu.
\v 11-12 Ramuni̱tiy nu̱tyu̱chusara sisa̱ Vuryi̱ndenu jiryeyadaju̱, sa̱tidye bay rasa̱ra̱vay variy jirye, sanatuyadaju̱, (jiryatiy sanatuy yentyutya̱daju̱ vu̱y), sa̱tidye jto̱taniy variy jiryimura ti̱ta̱ju̱ samiy jvaaryu̱yada, ti̱ta̱ju̱ jvaayada jiryatiy jiryivaay jityuva̱chodamura, savanu̱yadata, rirya̱tidye jchana̱tya nijya̱nvarya Vu̱yntyityu̱ Jesús jtya, rirya̱jchana̱tya jiryimusirya, rirya̱jchana̱tya simusiy jiryentyidye, Vuryi̱ndenu jmu̱tya̱data, Nutyityu̱ Jesucrístu jmu̱tya̱data jarye.
\c 2
\s1 Juuchuveda ja̱mi̱
\p 
\v 1-2 Nu̱jechiñu̱y ji̱ta jiryiva, ratyeryi̱veda, ne jirye̱cha vani̱ra siquityavay jiryejechipiya̱jadamu, ne ra̱jnutay jiryejechiy variy ranchiy, Vu̱yntyityu̱ Jesucrístu mu̱ti̱jadanchiy, jiryatiy vurya̱ntye̱ryaniy variy si̱dcho̱ju̱ vu̱y. Ne ra̱siquitya jiryejechiy variy saryityi tu̱chu ti̱ jiryiva: “Rajo̱tanuma Nutyityu̱ runda,” dantyamu̱y ne saryityi jtay sadatya Ju̱denu Jnutumusirya, dantyamu̱y ne saryityi jtay satuva̱chu rañiquera, dantyamu̱y ne saryityi jtay su̱mutya̱ra catera rimusiy.
\v 3 Ne jirya̱quivu̱chutaniy ti̱tayu, mitya. Ne jiryi̱nu̱y ne ra̱jo̱ta Nutyityu̱ runda, netimyu̱ ne rirya̱janumitye nijya̱nvay sayaro̱ju̱ Ju̱denu, netimyu̱ ne sa̱dityanu juuchadodaja̱mi̱ dayu, ni̱tiy parutedaju̱si̱ day.
\v 4 Ni̱ni̱ mityasiiyanu sayaro̱ju̱ ti̱ta̱ju̱ jiryatiy ru̱tay Ju̱denu dañi̱, sadirya jibeyada variy jaryiñu̱yu, ti̱ta̱ju̱ nijya̱nvay va̱tasi̱ju̱, jasicha̱ra̱ju̱tiy sa̱ma̱sa Ju̱denu vichajomu, Ju̱denu nta sadityadoda variyu.
\v 5 Ne viy jiryejechipityara jiryatiy ratyu̱choda jiryivara, variñumatiy ravyicha̱da jiryisa̱.
\v 6 Diye ji̱ta jiryedyetyi̱satya ta̱ra richechuja̱ni̱, sañuma dityanu jiryundajisiyu.
\v 7-8 Tapi rivaañuma juuchuveda dutya̱damusiyu, vinu ni̱tiy richechuja̱ diyera, sa̱richechuja̱ sasipyatedasa̱ra̱ju̱ rajachesiyu, variñumatiy sa̱dityanu juuchadodaja̱mi̱yu, ni̱tiy sa̱jvay Nutyityu̱ Jesús jiñe̱rye̱ya̱jadata, sa̱jvay jimyu̱ti̱jadadáta variñi̱.
\p 
\v 9-10 Juuchadodaja̱mi̱ mu̱ti̱jada ji̱ta ra̱cha Satanásiy vanu̱tya̱damusidye, ti̱ta̱ju̱ vanu̱yadata, datyadoda quivu̱chusarata jarye, ti̱ttasara quivu̱chusarata jarye risa̱ju̱, ti̱ta̱ju̱ va̱cha quivu̱yadata rijyu̱ paruti̱savay, jiryatimyu̱ ne rityuva̱churu̱yada ramu si̱tenu niquejada day, rirya̱tidye vicha jantyutyasavay variy.
\v 11-12 Ramuni̱tiy su̱pa̱sara Ju̱denu ruumura vanu̱tya̱da quivu̱yada, rirya̱tidye tuva̱chu quivu̱yadamu, rirya̱tidye vicha jatyasavay, rityimyu̱ ne tuva̱churu̱y ramu si̱tenu niquejada, ru̱canuyada ji̱tara va̱cha vicha̱da day.
\s1 Sajaryeta̱da Ju̱denu yentyutya̱daju̱riy Tesadónica ja̱nvavyedabay
\p 
\v 13 Nu̱y ji̱ta raryi jchana̱tyasarani̱ Ju̱denu jiryenchiy, ratyeryi̱veda, jiryatiy Nutyityu̱ va̱tasavay jirye, tapi sajaryeta̱da rajo̱ttya̱musiy jiryedye, jiryeyada ra̱yadaju̱, jiintya̱damusiy, jiryatiy sajiintya yimuju̱ Yintuta jirye, tuva̱chodamusiy jarye jiryatiy jiryetyuva̱choda ramu si̱tenu tu̱choda.
\v 14 Ramu ji̱ta sanatuyada jirye samitu̱chodata jiryatiy nu̱tyu̱chura, jirya̱tidye ca̱na̱rya Vu̱yntyityu̱ vanda, jiryatiy Jesucrístudá darya.
\v 15 Daryantya ji̱ta, ratyeryi̱veda, jirya̱ntya suru̱tyaniyu, jirya̱ntya jiriryi̱ra datyadoda jiryatiy nu̱dyetyadoda jiryerya, varimyata nu̱ñiquera, daryantya nu̱ñu̱y cateravara.
\p 
\v 16 Vu̱yntyityu̱ Jesucrístu ji̱ta, Vu̱jye̱ Ju̱denu jarye, ni̱tiy va̱ta̱da vu̱y, ni̱tiy sa̱jeya̱sara jachisuru̱tya̱da vu̱y, sasa̱y samirya nutuyada vu̱y, samirya jachipiya̱jadamuju̱.
\v 17 Sa̱ntya vanu̱tyara jiryejechiy, sa̱ntya surá̱ jirye, jirya̱tidye jvaay samirya ti̱ta̱ju̱ra, jirya̱nique samirya ti̱ta̱ju̱ntirya.
\c 3
\s1 Jirya̱tu̱chu Ju̱denujsa̱ nu̱dyeyadaju̱
\p 
\v 1 Nu̱ñi̱tay ji̱ta tamitya, ratyeryi̱veda, jirya̱ntya tu̱chu sisa̱ Ju̱denu nu̱dyeyadaju̱, ra̱tidye ra̱y Ju̱denu niquejada, rirya̱jchana̱tya nijya̱nvay varirya nu̱tyu jiryi̱chana̱tyatiy jiryerya.
\v 2 Jirya̱jachiñu̱y sivantiy, sa̱tidye jantyuy nu̱dyiva rirya̱jisiy taji jachipiya̱vay, va̱cha jvaavye jaryentiy, jiryi̱nu̱vyitya ne tuva̱chuvay ti̱ta̱ju̱ daryi.
\v 3 Jto̱tanirya ji̱ta Vu̱ntyityu̱ day, ni̱day ra̱vanu̱tya jirye, sa̱jantyuy jiryiva, va̱cha jachipiya̱jada ja̱mi̱jisiy.
\p 
\v 4 Nu̱dyetya ji̱ta Nutyityu̱mu jiryenchiy, jiryatiy jiryivaarya nu̱tyu̱choda, jirya̱jvaajeya̱sarantirya.
\v 5 Sa̱ntya vasenu Nutyityu̱ra jiryejechiy, Ju̱denu va̱ta̱damuju̱, Crístu jachi̱dedamuju̱ntiy.
\s1 Vurye̱cha jvaavye
\p 
\v 6 Nu̱ñi̱tay ji̱ta jiryiva, ratyeryi̱veda, Nutyityu̱ Jesucrístu jtyamu nu̱ñi̱tay: Jirya̱jiintye rirya̱jisiy vu̱tyeryi̱veda jiryatiy pituvyeryi, ne rityuva̱churu̱y variy ramu nu̱dyetyadoda jiryatiy jiryi̱mutya̱jada nu̱dyimusirya.
\p 
\v 7-8 Jiryeñi ji̱ta datyara nu̱tyuramusiy jirya̱jantyara nu̱dyivaayada, nu̱tyuramu nu̱vyichanu̱yada ne pituvye jiryimu, dantyamu̱y ne nu̱ñi̱myiñu̱yada mityara ti̱ jmyi̱sara, nu̱tyu paru̱cha̱rityi nu̱dyivaañu̱yada nupora jarye, nu̱ryiñuma jiyasanta riy jiryetyevay.
\v 9 Ne nu̱vyichasara jiryi̱myi̱sarata, nu̱tyu nusu̱byimiy nu̱ña̱vicha jiryimusiy, nu̱ña̱tidye barya jantyasara jiryejyu̱, jirya̱tidye jvaay daryantidye.
\v 10 Nu̱ñi vicha̱danumatiy jiryisa̱ nu̱ñi̱teda variy jiryiva: Ni̱timyu̱ ne ra̱jvaay, ne sa̱jmyi.
\v 11 Nu̱tyuva̱chuma̱ daryaju̱: Tavay rupiñumaya̱ jiryetyevay, pituvye, tama̱ ruvaaryu̱y, tama̱, mitya riityenumaya̱ ti̱sa̱ variyu.
\v 12 Davyevyani̱ ji̱ta nu̱ñi̱tachara, nu̱dyeyasanta jarye risa̱ju̱ riy, Nutyityu̱ Jesucrístu jtyamu, rirya̱tidye jvaay samidye, rirya̱tidye jmyi varirya nu̱ñi jimyi̱sara day.
\p 
\v 13 Jirye ji̱ta, ratyeryi̱veda, ne jirya̱paru̱y riva samirya jvaayada.
\v 14 Ni̱timyu̱ ne tuva̱churu̱rya nu̱ñi̱teda caterava, jirya̱ntya jnu̱y mitya sana̱cho̱, jiryeñuma rupi sisa̱, sa̱tidye jada riva.
\v 15 Ne jirya̱jnu̱y variy jamiryamusiy sana̱cho̱; jirya̱datyanu samirya vicha̱datani̱, ne jiryi̱nu̱y jityeryi̱ dañi̱.
\s1 Sa̱cha Ju̱denu jiryisa̱
\p 
\v 16 Ni̱day ji̱ta jiryatiy samirya vicha̱da ja̱mi̱ni̱, sa̱ntya sa̱jeya̱sara jiryerya samirya vichasa̱da. Sa̱cha Nutyityu̱ jiryisa̱ ti̱ta̱ju̱.
\p 
\v 17 Ramyu̱chuvay tamitya jirye, ray Pávuru. Rañu̱y rajyomututara. Ranuma rani̱cha rañu̱rya racyaterava.
\v 18 Samirya ra̱cha ti̱ta̱ju̱ jiryejyu̱, Vu̱yntyityu̱ Jesucrístumusiy.
\cls Sayanuma jiryetyeryi̱ Pávuru
