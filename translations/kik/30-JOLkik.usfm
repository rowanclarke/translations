\id JOL - Biblica® Open Kikuyu Holy Word of God 
\h Joeli 
\toc1 Joeli 
\toc2 Joeli 
\toc3 Joel 
\mt1 JOELI 
\c 1  
\p  
\v 1 Ĩno nĩyo ndũmĩrĩri ya Jehova, ĩrĩa yakinyĩrĩire Joeli mũrũ wa Pethueli. 
\s1 Gũtharĩkĩrwo nĩ Ngigĩ 
\q1  
\v 2 Ta iguai ũhoro, inyuĩ athuuri; 
\q2 o na inyuĩ inyuothe arĩa mũtũũraga bũrũri ũyũ thikĩrĩriai. 
\q1 Kũrĩ gwekĩka ũndũ ta ũyũ matukũ-inĩ manyu, 
\q2 o na kana matukũ-inĩ ma maithe manyu ma tene? 
\q1  
\v 3 Heei ciana cianyu ũhoro ũcio, 
\q2 na mũreke ciana cianyu ciĩre ciana ciacio, 
\q2 nacio ciana ciacio ikeera rũciaro rũrĩa rũkaarũmĩrĩra. 
\q1  
\v 4 Kĩndũ kĩrĩa gĩtigĩtio nĩ mũrumbĩ wa ngigĩ-rĩ, 
\q2 nĩkĩrĩtwo nĩ ngigĩ iria nene; 
\q1 kĩrĩa gĩtigĩtio nĩ ngigĩ iria nene-rĩ, 
\q2 nĩkĩrĩtwo nĩ itono; 
\q1 kĩrĩa itono icio itigĩtie-rĩ, 
\q2 nĩkĩrĩtwo nĩ ngigĩ ingĩ. 
\b  
\q1  
\v 5 Arahũkai, inyuĩ arĩĩu aya mũrĩre! 
\q2 Girĩkai, inyuothe anyui a ndibei; 
\q1 girĩkai nĩ ũndũ wa ndibei ya mũhihano, 
\q2 nĩgũkorwo nĩĩhurĩtio kuuma tũnua-inĩ twanyu. 
\q1  
\v 6 Harĩ rũrĩrĩ rũtharĩkĩire bũrũri wakwa, 
\q2 rũrĩrĩ rũrĩ hinya na rũtangĩtarĩka; 
\q1 rũrĩ na magego mahaana ta ma mũrũũthi, 
\q2 magego manene ta ma mũrũũthi wa mũgoma. 
\q1  
\v 7 Nĩ rwanangĩte mĩthabibũ yakwa, 
\q2 na rũgathũkia mĩkũyũ yakwa. 
\q1 Nĩrũmĩũnũrĩte makoni rũkamate, 
\q2 rũgatiga honge ciayo irĩ nyũnũre. 
\b  
\q1  
\v 8 Cakayai ta mũirĩtu gathirange ehumbĩte nguo ya ikũnia, 
\q2 akĩrĩrĩra mũthuuriwe wa wĩthĩ wake. 
\q1  
\v 9 Maruta ma ngano, o na maruta ma kũnyuuo 
\q2 nĩmatigĩte kũrehwo nyũmba-inĩ ya Jehova. 
\q1 Athĩnjĩri-Ngai nĩmaracakaya, 
\q2 o acio matungatagĩra Jehova. 
\q1  
\v 10 Mĩgũnda nĩmĩthũkie, 
\q2 nayo thĩ ĩkooma; 
\q1 ngano nĩnyanange, 
\q2 ndibei ya mũhihano nĩĩniarĩte, 
\q2 o namo maguta magathira. 
\q1  
\v 11 Ũrwoi nĩ hinya, inyuĩ arĩmi, 
\q2 na mũgirĩke, inyuĩ arĩa mũkũragia mĩthabibũ; 
\q1 mwĩthikĩrei nĩ ũndũ wa ngano na cairi, 
\q2 tondũ magetha ma mĩgũnda nĩmanangĩtwo. 
\q1  
\v 12 Mĩthabibũ nĩyũmĩte, 
\q2 nayo mĩkũyũ ĩkahooha; 
\q1 mĩkomamanga, na mĩtende, na mĩcungwa: 
\q2 ĩĩ, mĩtĩ yothe ya mũgũnda nĩyũmĩte. 
\q1 Ti-itherũ gĩkeno kĩa andũ a thĩ nĩgĩthirĩte. 
\s1 Andũ kwĩrwo Meerire 
\q1  
\v 13 Mwĩhumbei nguo cia makũnia, inyuĩ athĩnjĩri-Ngai, na mũcakae; 
\q2 girĩkai, inyuĩ mũtungataga kĩgongona-inĩ. 
\q1 Ũkai, mũraare mwĩhumbĩte nguo cia makũnia, 
\q2 inyuĩ mũtungatagĩra Ngai wakwa; 
\q1 nĩgũkorwo maruta ma ngano, na maruta ma kũnyuuo-rĩ, 
\q2 nĩmagĩte gũtwarwo nyũmba-inĩ ya Ngai wanyu. 
\q1  
\v 14 Anĩrĩrai gĩathĩ kĩamũre gĩa kwĩhinga kũrĩa irio; 
\q2 ĩtanai kĩũngano gĩtheru. 
\q1 Tũmanĩrai athuuri 
\q2 na andũ arĩa othe matũũraga bũrũri ũyũ 
\q1 moke nyũmba ya Jehova Ngai wanyu, 
\q2 nĩguo mũkaĩre Jehova. 
\b  
\q1  
\v 15 Wũi, kaĩ mũthenya ũcio ũrĩ na haaro-ĩ! 
\q2 Nĩgũkorwo mũthenya wa Jehova\f + \fr 1:15 \ft Mũthenya wa Jehova nĩ mũthenya ũrĩa Ngai agatooria thũ ciake, na rĩmwe ũtũmagĩrwo kuuga mũthenya ũrĩa Kristũ agaacooka thĩ.\f* ũrĩ hakuhĩ; 
\q1 mũthenya ũcio ũgooka ta mwanangĩko 
\q2 uumĩte kũrĩ Mwene-Hinya-Wothe. 
\b  
\q1  
\v 16 Githĩ irio itithirĩte 
\q2 o tũkĩĩonagĩra na maitho maitũ: 
\q1 gĩkeno na gũcanjamũka 
\q2 igathira kuuma kũu nyũmba ya Ngai witũ? 
\q1  
\v 17 Mbeũ nĩkũbutha irabuthĩra 
\q2 tĩĩri-inĩ kũrĩa ihaandĩtwo. 
\q1 Nyũmba cia kũigwo indo nĩnyanange, 
\q2 namo makũmbĩ ma irio makamomorwo, 
\q2 nĩgũkorwo ngano nĩyũmĩte. 
\q1  
\v 18 Kaĩ ngʼombe nĩicaaĩte-ĩ. 
\q2 Ndũũru cia ngʼombe iroorũũra o ũguo, 
\q1 tondũ itirĩ na gwa kũrĩithio; 
\q2 o nacio ndũũru cia ngʼondu nĩirathĩĩnĩka. 
\b  
\q1  
\v 19 Wee Jehova, nĩwe ndĩrakaĩra, 
\q2 nĩgũkorwo mwaki nĩũniinĩte ũrĩithio wa werũ-inĩ, 
\q1 nacio nĩnĩmbĩ igacina mĩtĩ yothe ya gĩthaka. 
\q1  
\v 20 O na nyamũ cia gĩthaka nĩirakwanĩria; 
\q2 tũrũũĩ nĩtũhwĩte, 
\q2 naguo mwaki nĩũniinĩte ũrĩithio wa werũ-inĩ. 
\c 2  
\s1 Mbũtũ ya Ngigĩ 
\q1  
\v 1 Huhai karumbeta kũu Zayuni, 
\q2 na muuge mbu kũu kĩrĩma-inĩ gĩakwa gĩtheru! 
\q1 Andũ arĩa othe matũũraga bũrũri ũyũ nĩmainaine, 
\q2 nĩgũkorwo mũthenya wa Jehova nĩũrooka. 
\q1 Mũthenya ũcio nĩ ta mũkinyu: 
\q2  
\v 2 nĩ mũthenya wa nduma na wa mairia, 
\q2 mũthenya wa matu na nduma ndumanu. 
\q1 Mbũtũ nene na ĩrĩ hinya ya ngigĩ nĩĩroka 
\q2 ta ruoro rũgĩtema irĩma-inĩ, 
\q1 na gũtirĩ kwagĩa ĩngĩ tayo kuuma tene, 
\q2 na gũtikagĩa ĩngĩ tayo matukũ marĩa magooka. 
\b  
\q1  
\v 3 Mbere yacio nĩ mwaki wa kũniina, 
\q2 na thuutha wacio nĩ rũrĩrĩmbĩ rũracina bũrũri. 
\q1 Bũrũri ũrĩa ũrĩ mbere yacio ũhaana ta mũgũnda wa Edeni, 
\q2 no thuutha wacio ũgaatigwo ũhaana ta werũ mwanangĩku: 
\q2 gũtirĩ kĩndũ kĩngĩĩhonokia harĩ cio. 
\q1  
\v 4 Mũhianĩre wacio nĩ ta wa mbarathi cia ita; 
\q2 ihanyũkaga ta thigari ihaicĩte mbarathi. 
\q1  
\v 5 Irĩ na mũrurumo ta wa ngaari cia ita; 
\q2 irũgaga tũcũmbĩrĩ twa irĩma 
\q1 ta mwaki ũracarĩka ũgĩcina itira cia ngano, 
\q2 ihaana ta mbũtũ ya ita ĩrĩ hinya ĩthagathagĩtwo nĩ ũndũ wa mbaara. 
\b  
\q1  
\v 6 Na rĩrĩa cionwo-rĩ, ndũrĩrĩ nĩinyiitagwo nĩ ruo rũnene; 
\q2 andũ othe magatukia ithiithi. 
\q1  
\v 7 Itharĩkagĩra ta njamba cia ita; 
\q2 ihaicaga thingo ta thigari. 
\q1 Ithiiaga ciothe na mĩhari, 
\q2 itekũhĩtia kũrĩa cierekeire. 
\q1  
\v 8 Itihatĩkanaga ĩmwe na ĩrĩa ĩngĩ; 
\q2 o ĩmwe ĩthiiaga yerekeire mbere. 
\q1 Itoonyaga kũrĩa kũgitĩre, 
\q2 gũtirĩ kĩndũ kĩngĩcigiria. 
\q1  
\v 9 Iguthũkagĩra itũũra inene, 
\q2 igatengʼerera rũthingo-inĩ. 
\q1 Ikahaica, igatoonya nyũmba, 
\q2 igatoonyera ndirica ta aici. 
\b  
\q1  
\v 10 Thĩ ĩthingithaga mbere yacio, 
\q2 na igũrũ rĩkainaina, 
\q1 riũa na mweri ikagĩa nduma, 
\q2 na njata igatiga kwara. 
\q1  
\v 11 Jehova araruruma ta ngwa 
\q2 atongoretie ita; 
\q1 thigari ciake itingĩtarĩka, 
\q2 arĩa maathĩkagĩra watho wake marĩ hinya. 
\q1 Mũthenya wa Jehova nĩ mũnene, 
\q2 na nĩ wa gwĩtigĩrwo. 
\q2 Nũũ ũngĩkĩhota kũwĩtiiria? 
\s1 Tembũrangai Ngoro Cianyu 
\q1  
\v 12 Jehova aroiga atĩrĩ, 
\q2 “O na rĩu-rĩ, njokererai na ngoro cianyu ciothe, 
\q2 mwĩhingĩte kũrĩa irio, mũkĩrĩraga na mũgĩcakayaga.” 
\b  
\q1  
\v 13 Tembũrangai ngoro cianyu 
\q2 no ti nguo cianyu. 
\q1 Cookererai Jehova Ngai wanyu, 
\q2 nĩgũkorwo nĩ mũtugi na nĩ mũigua-tha, 
\q1 ndahiũhaga kũrakara, na aiyũrĩtwo nĩ wendo, 
\q2 na nĩericũkagwo, akaaga gwĩka andũ ũũru. 
\q1  
\v 14 Nũũ ũngĩmenya? Hihi no agarũrũke na aigue tha, 
\q2 atige atũrathima: 
\q1 atũhe indo iria irutagwo magongona ma mũtu, 
\q2 na iria irutagwo magongona ma kũnyuuo, 
\q2 cia kũrutĩrwo Jehova Ngai wanyu. 
\b  
\q1  
\v 15 Huhai karumbeta kũu Zayuni, 
\q2 anĩrĩrai gĩathĩ kĩamũre gĩa kwĩhinga kũrĩa irio, 
\q2 ĩtanai kĩũngano gĩtheru. 
\q1  
\v 16 Cookanĩrĩriai andũ, 
\q2 amũrai kĩũngano kĩu; 
\q1 rehei athuuri hamwe, 
\q2 na mũcookanĩrĩrie ciana, o na tũkenge tũrĩa tũronga. 
\q1 Mũhikania nĩoime kanyũmba gake, 
\q2 nake mũhiki nĩoime kĩrĩrĩ gĩake. 
\q1  
\v 17 Athĩnjĩri-Ngai, arĩa matungataga mbere ya Jehova, 
\q2 nĩmarĩrĩre gatagatĩ ga gĩthaku kĩa Hekarũ na kĩgongona. 
\q1 Nĩmoige atĩrĩ, “Kĩhonokie andũ aku, Wee Jehova. 
\q2 Ndũkareke igai rĩaku rĩtuĩke kĩndũ gĩa kũnyũrũrio, 
\q2 kana tuunagwo thimo gatagatĩ-inĩ ka ndũrĩrĩ. 
\q1 Nĩ kĩĩ kĩngĩtũma ndũrĩrĩ ciũranagie atĩrĩ, 
\q2 ‘Kaĩ Ngai wao akĩrĩ ha?’ ” 
\s1 Icookia rĩa Jehova 
\q1  
\v 18 Ningĩ Jehova nĩakaigua ũiru nĩ ũndũ wa bũrũri wake, 
\q2 na aiguĩre andũ ake tha. 
\p  
\v 19 Jehova nĩakamacookeria atĩrĩ: 
\q1 “Nĩngũmũrehithĩria ngano, na ndibei ya mũhihano, na maguta, 
\q2 indo cia kũmũigana biũ; 
\q1 na ndigacooka kũreka mũtuĩke 
\q2 kĩndũ gĩa kũnyũrũrio nĩ ndũrĩrĩ rĩngĩ. 
\b  
\q1  
\v 20 “Nĩngaingata mbũtũ ĩyo ya ita ya kuuma gathigathini ĩthiĩ kũraya na inyuĩ, 
\q2 ndĩmĩtindĩkĩrĩrie bũrũri mũũmũ na mũhĩnju, ũtangĩgĩa irio. 
\q1 Mbũtũ yao ĩrĩa ĩtoongoretie ndĩmĩitĩrĩre iria-inĩ rĩa mwena wa irathĩro, 
\q2 na ĩrĩa ĩrĩ thuutha ndĩmĩitĩrĩre iria-inĩ rĩa mwena wa ithũĩro. 
\q1 Nakĩo kĩheera gĩa ciimba ciayo kĩambate na igũrũ; 
\q2 mũnungo wayo naguo ũiguĩke.” 
\b  
\q1 Ti-itherũ nĩekĩte maũndũ manene. 
\q1  
\v 21 Wee bũrũri, tiga gwĩtigĩra; 
\q2 kena na ũcanjamũke. 
\q1 Ti-itherũ Jehova nĩekĩte maũndũ manene. 
\q2  
\v 22 Inyuĩ nyamũ cia gĩthaka, tigai gwĩtigĩra, 
\q2 nĩgũkorwo ũrĩithio wa werũ-inĩ nĩũramera nyeki. 
\q1 Mĩtĩ nĩĩraciara maciaro mayo, 
\q2 nayo mĩkũyũ na mĩthabibũ ĩgaciara mũno. 
\q1  
\v 23 Inyuĩ andũ a Zayuni, canjamũkai, 
\q2 mũkenere Jehova Ngai wanyu, 
\q1 nĩgũkorwo nĩamũheete mbura ya mbere 
\q2 nĩ ũndũ wa ũthingu wake. 
\q1 Nĩamuurĩirie mbura nyingĩ 
\q2 ya mbere na ya thuutha, o ta mbere. 
\q1  
\v 24 Nacio ihuhĩro cia ngano nĩikaiyũra ngano; 
\q2 mĩtũngi nayo nĩĩkaiyũrĩrĩra 
\q1 ndibei ya mũhihano na maguta. 
\b  
\q1  
\v 25 “Nĩngamũrĩha mĩaka ĩrĩa yothe irio cianyu ciarĩirwo nĩ ngigĩ: 
\q2 ngigĩ iria nene, na itono cia ngigĩ, 
\q1 na ngigĩ iria ingĩ, na mĩrumbĩ ya ngigĩ; 
\q2 icio nĩ mbũtũ ciakwa nene cia ita iria ndaatũmĩte thĩinĩ wanyu. 
\q1  
\v 26 Nĩmũkagĩa na irio nyingĩ cia kũrĩa, o nginya mũhũũne, 
\q2 na inyuĩ nĩmũkagoocaga rĩĩtwa rĩa Jehova Ngai wanyu, 
\q2 ũrĩa ũmwĩkĩire maũndũ ma magegania; 
\q1 andũ akwa matigacooka gũconorithio rĩngĩ. 
\q1  
\v 27 Hĩndĩ ĩyo nĩmũkamenya atĩ niĩ ndĩ thĩinĩ wa Isiraeli, 
\q2 na atĩ niĩ nĩ niĩ Jehova Ngai wanyu, 
\q2 na atĩ gũtirĩ ũngĩ; 
\q1 andũ akwa matigacooka gũconorithio rĩngĩ. 
\s1 Mũthenya wa Jehova 
\q1  
\v 28 “Na thuutha wa maũndũ macio-rĩ, 
\q2 nĩngaitĩrĩria andũ othe Roho wakwa. 
\q1 Ariũ anyu na airĩtu anyu nĩmakarathaga mohoro, 
\q2 nao athuuri anyu nĩmakarootaga irooto, 
\q2 nao aanake anyu monage cioneki. 
\q1  
\v 29 O na ningĩ ndungata ciakwa cia arũme, na cia andũ-a-nja, 
\q2 nĩngaciitĩrĩria Roho wakwa matukũ-inĩ macio. 
\q1  
\v 30 Nĩngonania morirũ kũu igũrũ, o na gũkũ thĩ, 
\q2 namo nĩ ma thakame, na ma mwaki, 
\q2 o na ma ndogo ĩkwambata na igũrũ. 
\q1  
\v 31 Riũa nĩrĩkagarũrwo rĩtuĩke nduma, 
\q2 naguo mweri ũtuĩke ta thakame, 
\q2 mbere ya mũthenya ũcio mũnene na wa kũmakania wa Jehova ũtanakinya. 
\q1  
\v 32 Na nĩgũgakinya atĩrĩ, 
\q2 atĩ mũndũ o wothe ũgaakaĩra rĩĩtwa rĩa Jehova nĩakahonoka; 
\q1 nĩgũkorwo kĩrĩma-inĩ gĩa Zayuni na Jerusalemu 
\q2 nĩgũgakorwo na ũhonokio, 
\q2 o ta ũrĩa Jehova oigĩte, 
\q1 atĩ gatagatĩ-inĩ ka matigari 
\q2 nĩgũgakorwo na arĩa Jehova eĩtĩire. 
\c 3  
\s1 Ndũrĩrĩ Gũtuĩrwo Ciira 
\q1  
\v 1 “Matukũ-inĩ macio, na ihinda rĩu, 
\q2 rĩrĩa ngaacookeria Juda na Jerusalemu ũgaacĩru wacio-rĩ, 
\q1  
\v 2 nĩngacookanĩrĩria ndũrĩrĩ ciothe, 
\q2 na ndĩciikũrũkie nginya Gĩtuamba kĩa Jehoshafatu.\f + \fr 3:2 \ft Rĩĩtwa Jehoshafatu nĩ kuuga “Jehova nĩwe mũtuanĩri ciira”; Gĩtuamba kĩa Jehoshafatu no kĩo gĩĩtagwo gĩtuamba gĩa ituĩro (3:14).\f* 
\q1 Kũu nĩkuo ngaamatuĩra ciira ũkoniĩ igai rĩakwa, 
\q2 nĩo andũ akwa a Isiraeli, 
\q1 nĩgũkorwo nĩmahurunjire andũ akwa ndũrĩrĩ-inĩ, 
\q2 na makĩgayana bũrũri wakwa. 
\q1  
\v 3 Nĩmacuukĩire andũ akwa mĩtĩ. 
\q2 Maaheanire tũmwana twao tũrĩ irĩhi kũrĩ maraya; 
\q1 na makĩendia airĩtu ndibei 
\q2 nĩguo mamĩnyue. 
\p  
\v 4 “Na rĩrĩ, nĩ kĩĩ mũranjũria, inyuĩ Turo na Sidoni o na inyuĩ ngʼongo ciothe cia Filistia? Anga nĩmũkwĩrĩhĩria ũndũ ndanamwĩka? Akorwo nĩmũkwĩrĩhĩria-rĩ, na niĩ nĩngatũma mũcookererwo nĩ kwĩrĩhĩria kũu kwanyu o narua na ihenya.  
\v 5 Nĩgũkorwo nĩmuoire betha na thahabu ciakwa, na mũgĩkuua mĩthiithũ ya indo ciakwa iria njega mũno mũgĩcitwara hekarũ-inĩ cianyu.  
\v 6 Nĩmwendirie andũ a Juda na a Jerusalemu kũrĩ Ayunani nĩguo mũmatware kũndũ kũraya na bũrũri wao. 
\p  
\v 7 “Atĩrĩrĩ, nĩngũmarahũra moime kũndũ kũrĩa guothe mwamendirie, na nĩngamũcookereria ũndũ ũcio mwĩkĩte.  
\v 8 Niĩ nĩngendia ariũ anyu na airĩtu anyu kũrĩ andũ a Juda, nao mamenderie andũ a Sheba, rũrĩrĩ rwa kũraya mũno.” Nĩ Jehova warĩtie ũndũ ũcio. 
\q1  
\v 9 Hunjanĩriai ũhoro ũyũ ndũrĩrĩ-inĩ: 
\q2 Mwĩhaarĩriei gũthiĩ mbaara-inĩ! 
\q1 Arahũrai njamba cia ita! 
\q2 Andũ othe a ita nĩmakuhĩrĩrie, matharĩkĩre. 
\q1  
\v 10 Turai mĩraũ yanyu ĩtuĩke hiũ cia njora, 
\q2 o nacio hiũ cianyu cia gũceeha mĩtĩ ituĩke matimũ. 
\q1 Mũndũ ũrĩa ũtarĩ hinya nĩoige atĩrĩ, 
\q2 “Niĩ ndĩ na hinya!” 
\q1  
\v 11 Ũkai na ihenya, inyuĩ ndũrĩrĩ cia kũndũ guothe, 
\q2 mũngane, mwĩcookanĩrĩrie hamwe. 
\b  
\q1 Wee Jehova, tũma njamba ciaku cia ita ciikũrũke kuo. 
\b  
\q1  
\v 12 “Ndũrĩrĩ nĩciarahũrwo; 
\q2 nĩcithiĩ Gĩtuamba kĩa Jehoshafatu, 
\q1 nĩgũkorwo kũu nĩkuo ngaikarĩra gĩtĩ, 
\q2 nduĩre ndũrĩrĩ ciothe cia mĩena yothe ciira. 
\q1  
\v 13 Hiũria-i rũhiũ rwa kũgetha, 
\q2 nĩgũkorwo magetha nĩ makinyu. 
\q1 Ũkai, rangĩrĩriai thabibũ, 
\q2 nĩgũkorwo kĩhihĩro kĩa ndibei nĩkĩiyũru, 
\q1 na mĩtũngi ĩkaiyũra, ĩgaitĩkĩrĩra thĩ: 
\q2 ũguo noguo waganu wao ũnenehete!” 
\b  
\q1  
\v 14 Gũgaakorwo irĩndĩ na irĩndĩ, 
\q2 kũu gĩtuamba gĩa ituĩro! 
\q1 Nĩgũkorwo mũthenya wa Jehova 
\q2 wa gũkinya kũu gĩtuamba gĩa ituĩro ũrĩ hakuhĩ. 
\q1  
\v 15 Riũa na mweri nĩikaagĩa nduma, 
\q2 nacio njata itigacooka kwara rĩngĩ. 
\q1  
\v 16 Jehova nĩakararama arĩ kũu Zayuni 
\q2 na arurume ta ngwa arĩ Jerusalemu; 
\q2 thĩ na igũrũ nĩikainaina. 
\q1 No rĩrĩ, Jehova nĩwe ũgaatuĩka rĩũrĩro rĩa andũ ake, 
\q2 na atuĩke kĩĩhitho kĩrũmu kĩa andũ a Isiraeli. 
\s1 Irathimo cia Andũ a Ngai 
\q1  
\v 17 “Hĩndĩ ĩyo nĩguo mũkaamenya atĩ niĩ, Jehova Ngai wanyu, 
\q2 ndũũraga Zayuni, kĩrĩma-inĩ gĩakwa kĩrĩa gĩtheru. 
\q1 Narĩo itũũra rĩa Jerusalemu rĩgaakorwo rĩrĩ rĩamũre; 
\q2 gũtirĩ hĩndĩ ĩngĩ andũ a kũngĩ magaacooka kũrĩtharĩkĩra. 
\b  
\q1  
\v 18 “Mũthenya ũcio-rĩ, irĩma-inĩ nĩgũgatataga ndibei ya mũhihano, 
\q2 na tũrĩma-inĩ nĩgũgathereraga iria, 
\q2 natuo tũrũũĩ tuothe twa Juda nĩtũgathereraga maaĩ. 
\q1 Nakuo nyũmba ya Jehova nĩgũgakunũka gĩthima, 
\q2 na maaĩ makĩo maikũrũkage o kũu Gĩtuamba gĩa Shitimu. 
\q1  
\v 19 No bũrũri wa Misiri nĩgũkira ũgaakira ihooru, 
\q2 nakuo Edomu gũtuĩke werũ ũtarĩ kĩndũ, 
\q1 nĩ ũndũ wa maũndũ ma ũhinya marĩa meekire andũ a Juda, 
\q2 ma gũitithia thakame ĩtarĩ na ũũru kũu bũrũri wao. 
\q1  
\v 20 Juda gũgaatũũrwo tene na tene, 
\q2 nakuo Jerusalemu gũtũũrwo njiarwa na njiarwa. 
\q1  
\v 21 Wĩhia wao wa ũiti wa thakame, 
\q2 ũcio itarĩ ndaamarekera-rĩ, nĩngamarekera.” 
\b  
\q4 Jehova atũũraga Zayuni!