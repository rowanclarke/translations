\id MRK  
\h SAN MARCOS 
\toc1 Ja Loil It Jel Tzamali Ja Jastal Stz'ijba Can Ja San Marcosi 
\toc2 SAN MARCOS 
\toc3 Mr. 
\mt1 El Santo Evangelio Según San Marcos 
\mt2 Ja Loil It Jel Tzamali Ja Jastal Stz'ijba Can Ja San Marcosi 
\c 1  
\s1 Ja Juan ja ma' yaa bautismo ti yala ja yabal ja Dios ja ba ch'ayan lugari 
\r (Mt. 3:1‑12; Lc. 3:1‑9, 15‑17; Jn. 1:19‑28) 
\p  
\v 1 Ja abal it jel tzamali, ja' huax yala jastal ay ja Jesucristo ja yunin ja Diosi, jach q'ue ja jastal iti:  
\v 2 Ja najate lequi, yalunej ni jastal ay ja aluman‑Dios Isaiasi. Ata huabilex ja jas yala can tac: 
\q1 Q'uelahuilex, bajtan oj jec ja cala jecabanumi, jaxa yeni oj sam ja hua beji, ti oj cho huajan nochan ja hueni. 
\q1  
\v 3 Ja jecabanum jahui ti oj ajyuc ec' ja ba ch'ayan lugar jumasa. Tzatz lec oj c'umanuc eq'ue. Oj yal ja jastal iti: Ja jastal huaxa jamahuex ja bej ja cuando oj jac ja ma' ay yateli, jach oja huaex puesto ja hua c'ujolexi porque oj xa jac ja Cajualtiqui. 
\m Jach bi oj yal yab ja cristiano, xchi ja Isaiasi.  
\v 4 Jayujil huaj to yabye ja cristiano jumasa, ti xa bi ay ba jun ch'ayan lugar ja Juani, ja' ni ja Juan it huax yaa bautismo. Huan yaljel que aa xa bi suchuc ja sc'ujol ja cristiano, ti xa bi oj c'ulajuque perdonara, ti xa bi oj yie jaa.  
\v 5 Jaxa spetzanil ja cristiano suinquil ja Judea soc jach ni ba Jerusaleni, lom xta xnololjiye huaj smaclaye ja jas huax yala ja Juani. Cuando yabye ja jas yalai, ti ch'ac el stie ja smulei, ti xa aaji yie jaa.  
\v 6 Jaxa Juani, ja' c'ulubal soc ja stzotzil camello ja sc'ui, jaxa snalani, pitan soc jun sincho tz'uum, jaxa suaeli, ja' tz'itit soc yaal chab.  
\v 7 Con gana huan xcholjel ja yabal ja Dios ja Juani. Ti huax yalaa: ―Meran, ti xa ayon ja queni pero oj to jacuc ja ma' jel tzatz juntiro ja yateli. Mi ni ba oj sop yi ja xanabi oj maconucon ja queni.  
\v 8 Ja queni huax ca huiex ja', jaxa yeni oj yaa huilex ja Espíritu Santo, pero con todo yip, xchi ni ec' ja Juana. 
\s1 Aaji yi ja' ja Jesusi 
\r (Mt. 3:13‑17; Lc. 3:21‑22) 
\p  
\v 9 Ja c'ac'u jumasa jahui ja Jesusi ti el ja ba Nazaret ba lugar Galilea. Ti huaj ja bay ja Juani, ti aaji yi ja' yuj ja Juani. Ja ba nihuanja Jordán ti yiaj ja' ja Jesusi.  
\v 10 Iday, cuando huan xa elel jan ja ba sti ja ja' ja Jesusi, huaj to yile, jamxi ja satq'uinali, jaxa Espíritu Santo ti co t'ucan sbaj, pero entero splanta jastal paloma.  
\v 11 Ti yab jun c'umal ja ba satq'uinali: ―Mero cunina ja hueni. Jel juntiro yaj huax cabya. Jel huaxa huaa qui gusto, xchi ja c'umal jahui. 
\s1 C'ulaji probar ja Jesusi 
\r (Mt. 4:1‑11; Lc. 4:1‑13) 
\p  
\v 12 Ja Jesusi ti yab ja ba sc'ujoli que jel bi t'ilan oj huajuc ba jun ch'ayan lugar pero ja' alji yab yuj ja Espíritu Santo.  
\v 13 Ti ajyi cuarenta c'ac'u ja tihui, pero mero ch'ayan lugar nia. Jel ja sbaal ja huitzi. Ti jel c'ulaji probar yuj ja Satanasi pero ja mas tzaani ti jac ja ángel jumasa ba oj scoltaye ja Jesusi. 
\s1 Ja Jesusi q'ue ja yatel ja ba Galilea 
\r (Mt. 4:12‑17; Lc. 4:14‑15) 
\p  
\v 14 Ja c'ac'u jumasa jahui, aaji och preso ja Juani. Ti to lutana cuando cho cumxi ja ba Galilea ja Jesusi. Ti huaj ja ba Galilea ba oj see yi ja cristiano ja yabal ja Diosi.  
\v 15 Ti yalaa: ―Ora xa nia. Tiempo xa oja huaa bajex ja ba sc'ab ja Diosi. Aa xa suchuc ja hua c'ujolexi. C'uanic xa ja ajc'ach abal it huax cala huabyexi porque jel tzamal juntiro, xchi ja Jesusi. 
\s1 Ja Jesusi stzaa chanhuane yamachayi 
\r (Mt. 4:18‑22; Lc. 5:1‑11) 
\p  
\v 16 Jun c'ac'u ja Jesusi ti huan bejyel ec' ja ba sti ja ja' ja ba Galilea. Jaxa tihui ti yila ja Simoni soc ja yijtz'in Andresi. Ti huane sipjel yoj ja' ja yenubei, como yamachaye nia.  
\v 17 Ti yala ja Jesusi: ―Ti la jacyex jmoca. Eso sí meran, quechan huajel ac'ujolex ja syamjel ja chayi pero ja yaani ja' oja huaa c'ujolex ja sleejel ja cristiano ba oj jac jmoc, x'utjiye ja Simón soc ja Andresi.  
\v 18 Jayuj ja yenlei ti yaahue can ja yenubei. Ti huajye soc ja Jesusi.  
\v 19 Cuando huajye ta jun maq'uei, ti yilahue ja Jacobo soc ja yijtz'in Juani, ja' ni ja yuntiquil ja Zebedeo. Ti aye ba jun barco. Ti huane stz'acbajel ja yenubei.  
\v 20 Ti ya q'ueuc ja sloilei. Ti xa yala ja Jesusi: ―¿Mi ma xa c'anahuex oj huajanic jmoc ba? xchi ja Jesusi. Jaxa Jacobo soc ja Juani ti xa yaahue can ja statei soc ja yatjume tey ba yoj barco. Ti xa huajye soc ja Jesusi. 
\s1 Jun huinic ixtalanubal yuj ja pucuji 
\r (Lc. 4:31‑37) 
\p  
\v 21 Ti huajye ba Capernaum, jaxa sc'ac'uil ja jijleli, ti huaj ba iglesia ja Jesusi. Och see yi ja cristiano.  
\v 22 Cuando abji ja jas huax yala, jel och juntiro ja spensar ja cristiano jumasa. Lajan bi soc jun ma' jel tzatz ja yateli. Mi bi oj slaj ja yenle ja ma' huas seahue ja smandar ja Moisesi.  
\v 23 Jaxa ba mismo iglesia jahui, huaj to yile, tey jun huinica. Ja yeni ixtalanubal juntiro yuj ja pucuji. Ti och ahuanuca:  
\v 24 ―Ja huen Jesús nazareño, ¿jas ahuocheloticon ja quenticoni? ¿Yuj ama huaxa c'ana oja ch'ayoticon ja huen ba? Huan nix naaticon abaja. Eso sí, ja hueni mi ni huaxa taa tan amul tac. ¡Yunina ni ja Diosa! Jach el sti ja huinic jahui.  
\v 25 Ti xa yal yab ja Jesusi: ―Ch'abananic ja huenlexi. Actayic can ja huinic iti, x'utjiye ja tantic pucuji.  
\v 26 Jaxa pucuj jumasa ti syamahue ja huiniqui. Ya q'uitc'onuc spetzanil ja scuerpo. Ti ya ahuanuc tzatz leca. Ti xa actaji can ja huinic jahui.  
\v 27 Jaxa cuando yila ja cristiano jumasa, jel xiuye juntiro. Ti huax yala sbajea: ―¿Jastal ay ja iti? ¿Yuj ama ay jas yajc'achil ay ba? Pero ¡huas sc'ulan mandar ja tantic pucuj tac, y huax c'uaji! xchiye xta.  
\v 28 Huego huego ch'ac pucxuc yabalil ja Jesusi. Ch'ac yabye ja cristiano ja ba sutanal ja Galilea. 
\s1 Ja Jesusi ya tojbuc ja snial ja Pedro 
\r (Mt. 8:14‑15; Lc. 4:38‑39) 
\p  
\v 29 Ja Jesusi ti el ja ba iglesia jahui. Ti xa huaj ja ba snaj ja Simón soc ja Andresi. Ti smoj ja Jacobo soc ja Juani.  
\v 30 Cuando c'otye ja tihui, ti alji yab ja Jesusi que ti baan ec' ja snial ixuc ja Simoni. Jel bi yioj c'ac'.  
\v 31 Jaxa Jesusi ti huaj och ja bayi. Syama yi ja sc'ab ja chamumi. Ya q'ueuc. Huaj to yabi, mi xa ay ja sc'ajc'ali. Yen xa ya ec'uc ja suaele ja huiniquei. 
\s1 Ja Jesusi ya tojbuc jitzan ja ma' malo ayi 
\r (Mt. 8:16‑17; Lc. 4:40‑41) 
\p  
\v 32 Cuando mucxi ta c'ac'ui, oj xa q'uicbuc ja q'uinali, ti iiji jan yi ja Jesús spetzanil ja matic malo ayi soc ja matic ixtalanubale yuj ja pucuji.  
\v 33 Spetzanil ja suinquil ja chonabi ti ch'ac jacuque montón ja ba sti naitz ja bay ja Jesusi.  
\v 34 Jaxa yeni, jitzan ja ma' ya tojbuc ja ora jahui. Tuctuquil tiq'ue chamel yioje, jaxa pucuji, yaa yi mandar que oj yactaye can ja cristiano jumasa. Mi aaji c'umanuque yuj ja Jesusi porque huas snaa machunc'a ja yeni. 
\s1 Ja Jesusi ti sloilta ja ba Galilea 
\r (Lc. 4:42‑44) 
\p  
\v 35 Jaxa el ja c'ac'u, ja Jesusi jel saj q'uei, q'uic' to ja q'uinali. Ti huaj sc'umuc ja Dios ja ba jun ch'ayan lugar.  
\v 36 Ti huaj leejuc yuj ja Simoni soc ja smoj jumasa.  
\v 37 Yajni staahuei, ti yalahue yaba: ―Pero huana leejel yuj ja cristiano jumasa tac, xyutaje.  
\v 38 Ti yala ja Jesusi: ―Pero oj ni huajtic ja ba lugar mojan yaman tac. Oj cho huaj choltic ja yabal ja Dios ja tihui. Jayuj ti xa ni ayon ja il tac, xchi ja Jesusi.  
\v 39 Jaxa ba spetzanil ja yal lugar ba Galilea, ti xa och see yi ja ba yiglesiae ja smoj judioili. Chican ba huax huaj ec'a, huan ni sc'ulan ec' mandar ja pucuj jumasa ba oj yactaye can ja cristiano. 
\s1 Ja Jesusi ya tojbuc jun huinic huan c'ael ja sbacteli 
\r (Mt. 8:1‑4; Lc. 5:12‑16) 
\p  
\v 40 Jun c'ac'u ti jac jun huinic soc jun chamel huan c'ael ja sbacteli. Ti jac sc'an yi stz'acatal ja Jesusi. Co mec'an ja ba sti sati: ―Cajual, ta jach c'a huaxa c'ana, oj ni hua tojbucona, xchi ja huiniqui.  
\v 41 Jaxa Jesusi jel stalna syaujulal. Ti ya cajan ja sc'ab ja ba scuerpo ja huiniqui: ―Huan nix c'ana oj tojbana hijo, xchi.  
\v 42 Mi tox el yuj ja palabra jahui, ch'ay huego ja spieroil ja sbacteli. Huego huego tojbi.  
\v 43-44 Ja Jesusi ti yalaa: ―Pero huax cala huabi, moc ma' ahual yab que quen ca tojban. Cax xa. Cax jea baj yi ja pagre. Aa yi ja jastal ni yalunej ja Moisesi ba oj yil ja cristiano que lec xa ni ayaa. Cuando ch'ac yala jastal it ja Jesusi, ti xa spila sbaja.  
\v 45 Pero iday, lajan soc yal yab ba oj spuc eq'ue. Ja' xta huan xcholjel ec' jastal tojbi, jayuj ja Jesusi mi xax bob och satalajel abal ja ba chonab jumasa. Jayuj ti xa can ja ba jun ch'ayan lugar ba mey lec ja suinquili. Pero ja cristiano huaj ni stae ja bayi. Ba spetzanil lugar ch'ac jacuque ja cristiano. 
\s1 Ja Jesusi ya tojbuc jun huinic tulido ay 
\r (Mt. 9:1‑8; Lc. 5:17‑26) 
\c 2  
\p  
\v 1 Ja Jesusi ti ajyi chaboxe c'ac'u ja tihui, ti xa cho cumxi ja ba Capernaumi. Ti abji yabalil que ti xa bi ay ba jun naitz.  
\v 2 Yajni ch'ac yab ja cristiano ja jastal jahui, sac ajnel xta ch'ac huaj yile. But' ja ba naitz jahui. Mi ni ba mojan ja puerta huax bob ochuque. Pec' man fuera ja cristiano. Jaxa Jesusi ja' ni mero huan xta yaljel ja yabal ja Diosi.  
\v 3 Ti xa c'ot chaboxe cristianoa. Chanhuane slicuneje jan jun huinic mi xax bob snic ja scuerpo.  
\v 4 Pero ja c'otyei, mi ni modo huax bob ochuque c'uban porque jel juntiro ja cristiano, jayuj ti xa q'ueye ja ba s'olom ja naitzi. Sotohue ja tihui, ti yaahue couque ja chamumi soc ja xch'atilteili.  
\v 5 Jaxa Jesusi cuando yila jel huax c'uaji yuj ja cristiano jumasa jahui, ti yal yab ja chamumi: ―Hijo, perdonado xa ay ja hua muli, xyutaj.  
\v 6 Pero ti ni aye chaboxe ja ma' huas sea ja smandar ja Moisesi, ti culane ec'a. Huan xta c'umal ja sc'ujolei.  
\v 7 ―¿Jasyuj jach huax yala ja iti? ¡Huan amax yala que Dios ja yen ba! ¿Mi ma quechanuc ja Dios oj bob c'ulhuanuc perdonar ba? ¡Jel piero juntiro ja jas huax yala tac!  
\v 8 Pero ja Jesusi como huan ni snaa que jach huan xta loil ja sc'ujole ja jau jumasa, jayuj ti yalaa: ―¿Jas lom huan xta c'umal ja hua c'ujolexi?  
\v 9 ¿Mi ma jun xta ni ja huax cal yab que perdonado ay ja smul ba, ma ja' huaxa c'anahuex oj cal yab a q'ueuc, a stul ja xch'ati, a bejyuc? ¿Baya mas lec ba? x'utjiye.  
\v 10 Ja queni ti ni coelon jan ja ba satq'uinali pero ba oja c'uuquex que huax bob jc'ul perdonar ja mulali, ba oja naex que tzatz ni ayon ja ba luumi, ay ni jas oj cal yab ja chamum iti. Ti yal yab ja ma' mix bob snic sbaji:  
\v 11 ―Ja huen hijito, q'uean xa. Iaj xa hua huaynubi. Cax xa ba hua naji, xyutaj.  
\v 12 Jaxa huinic jahui, huego huego q'uei. Ti ba sat ja cristiano ch'ac spac ja xch'atilteili, ti huaja. Jaxa cristiano jel och juntiro ja spensarei: ―¡A stz'acatal juntiro ja Diosi! Jun ta ora huax quilatic ja jastal iti, xchiye. 
\s1 Ja Jesusi stzaa ja Leví 
\r (Mt. 9:9‑13; Lc. 5:27‑32) 
\p  
\v 13 Ja Jesusi ti cho huaj ja ba sti ja jai, jaxa tihui ti c'ot spetzanil ja cristiano ba oj jeejuc yile.  
\v 14 Jaxa cuando ch'ac see yi ja cristiano, ti xa cho huaja. Ti ec' ja ba colecturía ba huax och ja scontribucion ja cristiano jumasa. Jaxa tihui ti culan ec' jun atjum sbiil Leví, ja' stat ja Alfeo. Ja Jesusi ti och loil soca: ―¿Jaxa mila huaj jmoc ba? xchi. Jaxa Levii ti q'ue huegoa. Ti huaj soca.  
\v 15 Jun c'ac'u ti huaj ba snaj ja Leví jau ja Jesusi. Ti och culan ja ba mesa, soc tey jitzan ja ma' huax atji ba colecturía soc tey ja ma' ay smulei soc ti ni aye ja snebuman jumasa. Pero smoj ni sbaje huaela. Ja tiempo jumasa iti, jel xa jitzan ja ma' tey ec' soc ja Jesusi.  
\v 16 Jaxa fariseo jumasa soc ja ma' huas seahue ja smandar ja Moisesi ti yilahue smoj sbaje huael ja Jesusi soc ja colector jumasa soc ja ma' jel bi ja smulei. Jayuj ti ochye loil soc ja snebuman jumasa: ―Pero ¿jastal ay ja iti? Ja hua maestroexi, pero ti huan huael soc ja tantic colector tac soc ja mulanum tac, xchiye xta.  
\v 17 Pero ja Jesusi c'ot xchiquin ja jas huane yaljeli, ti yalaa: ―Pe ¡mi jas yioj! Ja' ni yuj jaquelon taca, ba oj colta ja ma' ay smuli. Ja mulanum jumasa huan ni sc'ulane necesitar jun doctor pero ja huenlexi, como jel lec ayex, mi ni ayuc ja hua nesesidaexi. ¡Jas lom oj coltayex! xchi ja Jesusi. 
\s1 Ja Jesusi jobji yi jas sbej mi scomo ja suaelei 
\r (Mt. 9:14‑17; Lc. 5:33‑39) 
\p  
\v 18 Ja snebuman jumasa ja Juani soc jach ni ja snebuman ja fariseo jumasa, culan yujile tola vida huas scomo ja suaelei. Ti huaj sobe yi ja Jesusi: ―Ja janec' ayticon snebumanil ja Juani soc ja fariseo jumasa, c'ajyeloticon huan nix como ja juaelticon tola vidaa. Iday, jaxa hua nebuman ja hueni, mi ni t'usan huas scomo ja suaelei. ¿Jaxa yuj ba?  
\v 19 Ti yala ja Jesusi: ―Pero q'uelahuilex jun ch'ac abal. Ja loc jumasa mi ni modo oj scom ja suaelei como ti ni tzomane soc ja nupanumi. Jel ja sgustoei. Mi ni sbejuc oj scom ja suaelei como ti ni ay soc ja ma' huan nupaneli.  
\v 20 Pero oj ni jacuc ja c'ac'u ja' oj ch'ay yujile ja nupanumi, jaxa tiempo jahui, eso sí, sbej ni oj scom ja suaelea. Oj ni but'uque yuj ja stristeilea.  
\v 21 Meran huax cala huabyex, jel huocol huaxa huabyex huaxa huaahuex can ja viejo scostumbre ja jmojtic judioili. Porque q'uelahuilex jun poco c'uutz. Mas lec mix hua ochuquex smactonil ba yajc'achil. Huan c'ax ochi, jaxa yajc'achili oj sujbuc y toj coleto huax huaji.  
\v 22 Jach ni jun oxom ba ay syaj. Mix bob hua och taan ba yajc'achil to. Jach c'a huaxa c'ulan, huaj to ahuile, leutz'uji ta snalan ja oxomi, jaxa taani, oj ch'ac co bulan ba luum. Mi xa lecuc ja taani, jaxa oxomi, lom nia. Ta yajc'achil c'a ja taani, mas lec, aa ba jun oxom mey syaj. 
\s1 Ja snebuman ja Jesusi stuch'uhue ja trigo ja sc'ac'uil ja jijleli 
\r (Mt. 12:1‑8; Lc. 6:1‑5) 
\p  
\v 23 Jun sc'ac'uil ja jijleli, ti huane eq'uel ba yoj alajaltiqui ja Jesusi soc ja snebuman jumasa. Ti och stuch'e ja sni ja trigo.  
\v 24 Cuando yilahue ja fariseo jumasa, ti yalahuea: ―Q'uelahuil ja hua nebuman jumasa. ¿Sbej ama jach huane sc'ulajel ba? ¿Mi ma jauc ja sc'ac'uil ja jijlel ja yaan ba?  
\v 25 Ti sac'a jan ja Jesusi: ―Bob ta mey xa q'uelahuex ja juun ja ba huax yala jas sc'ulan ja rey David ja najatei cuando jel bi och huain xyabi. Y mi quechanuc ja yen, jach ni spetzanil ja smoj jumasa.  
\v 26 Och bi ja ba snaj ja Diosi. Ti bi ch'ac suee ja pan it ti jian ec' ja ba sti sat ja Diosi, iday, mi sbejuc cualquier cristiano oj sue ja pan jahui. Ja' sbaj quechan oj sue ja pagre jumasa. Pero ja ora jahui, ja Davidi suea nia soc cho yaa yi ja smoj jumasa, y mi ni malouc iljia. Ja nihuan pagre ja ora jahui, ja' ni ja Abiatari.  
\v 27 Ja sc'ac'uil ja jijleli ac'ubal yi ja cristiano ba slequilei, mi jauc ja ba yibc'abal oj yaa sbaje ja c'ac'u jahui.  
\v 28 Ja queni ti ni coelon jan ja ba satq'uinali. Quena ni oj cal jasunc'a lec sc'ulajel ja ba c'ac'u jijleli porque ac'ubal ni qui ba quen oj cal jasunc'a lec oj c'ulaxuqui, xchi ja Jesusi. 
\s1 Tojbi jun huinic jiman ec' ja sc'abi 
\r (Mt. 12:9‑14; Lc. 6:6‑11) 
\c 3  
\p  
\v 1 Ja Jesusi ti cho huaj otro vuelta ja ba yiglesia ja judio jumasa. Huaj to yile, tey jun huinic jiman xa ec' ja sc'abi. Mi xa ni modo xbob ya q'ueuca.  
\v 2 Como ja' ni ja sc'ac'uil ja jijleli, jaxa scondra jumasa ja Jesusi quechan huane xta smajlajel ba oj yile ta oj ya tojbuc ja chamum jahui. Ta huan c'a bix aaji tojbuc, ti bi oj sta smul ja Jesusi.  
\v 3 Ja Jesusi ti yal yab ja huinic it jiman ec' ja sc'abi: ―Q'uean xa ja ba culana ec' ja hueni, ti la jac ba sti jsaticoni, x'utji ja huiniqui.  
\v 4 Ja Jesusi ti yal yab ja cristiano: ―Q'uelahuilex ja huenlexi. Ja yaan c'ac'u ja' ni sc'ac'uil ja jijleli. Mi sbejuc oj c'ultic yi malo ja jmojtic ja c'ac'u iti. Oj ni jc'ultic ja ba leca. Oj coltatic, mi oj caatic chamuc, xchi. Jaxa scondra ja Jesusi, mi jun palabra sama stiei.  
\v 5 Ja Jesusi ti och stojtoq'uel ja cristiano. Coraja ay soc huax jac jun stristeil porque jel ch'uuy juntiro ja sc'ujolei. Ti yal yab ja huinic jahui: ―A q'ueuc ja hua c'abi, xyutaj. Iday, ja huiniqui ti ya q'ueuca, jaxa sc'abi, huego staa slugar ja jastal ja otro jun sc'abi.  
\v 6 Jaxa fariseo jumasa ti elye ja tihui. Huaj yii yabal sbaje soc ja yamigo jumasa ja rey Herodesi. Huaj xchape yabalil ja Jesusi. 
\s1 Ja Jesusi tzajlaji yuj jitzan cristiano ba sti ja jai 
\p  
\v 7 Jaxa Jesusi ti huaj ba sti jaa. Ja' smoj ja snebuman jumasa. Ti huaj nochan jun nole cristiano sbaj Galilea soc sbaj Judea,  
\v 8 Soc jach ni ba Jerusalén soc ba Idumea. Cho jacye ja ba otro lado c'ax ja ba nihuanja Jordani, soc ba tuctuquil lugar ba Tiro soc ja ba Sidoni. Cuando ch'ac yabye spetzanil ja jas jel nihuan huan sc'ulajel ec' ja Jesusi, lom xta xnololji ch'ac jacuc ja cristiano.  
\v 9 Ti yal yab ja snebuman jumasa que oj yae puesto jun barco ba cualquiera ora oj bob q'ueuque ja tihui porque jel bi juntiro ja cristiano. Ay bi modo oj batalajuc.  
\v 10 Jaxa chamum jumasa, jitzan lec ya tojbuc, jaxa matic mi tox ya tojbuqui, huane xta sutbintalaan sbaje siquiera oj huaj syame ja Jesusi.  
\v 11 Jaxa ma' ixtalanubal yuj ja pucuji, cuando huax yilahue ja Jesusi, huax coye pacan ja ba sti sati: ―Ja hueni yunina ni ja Diosa, xchiye xta, pero tzatz lec huax c'umaniye.  
\v 12 Jaxa Jesusi c'ac' lec huax comhuani ba mi oj yale machunc'a ja yeni. 
\s1 Ja Jesusi stzaa lajchahuane ja snebumani 
\r (Mt. 10:1‑4; Lc. 6:12‑16) 
\p  
\v 13 Ti q'ue ba jun huitz ja Jesusi. Ti spaya jan ja matic huas sc'ana oj sc'uluc ja yateli. Ti cho q'ueye ba huitz ja yenle chomajquili.  
\v 14 Ti tzaajiye can lajchahuanea ba oj ajyuc ec' soc ja Jesusi. Oj bi huaj xchole ja yabal ja Diosi.  
\v 15 Soc aaji yipe ba oj cho bob ya tojbuque ja matic malo ayi soc oj bi sc'uluque mandar ja pucuj jumasa ba mi xa oj yixtalauc ja cristiano.  
\v 16 Stzaa ja Simoni, ti slea yi otro sbiila. Yaa yi Pedroil.  
\v 17 Cho stzaa ja Jacobo soc ja yijtz'in Juani, ja' state ja Zebedeo. Jaxa yenlei, jel bi t'usan ja xchijnaq'uei. Lajane bi soc ja mentzululi porque snicjele xta nia.  
\v 18 Cho stzaa ja Andresi, soc ja Felipe, soc ja Bartolomé, soc ja Mateo, soc ja Tomasi, soc ja Jacobo ja' stat ja Alfeo, soc ja Tadeo, soc ja Simón cananero,  
\v 19 Soc ja Judas Iscariote, ja ma' sc'ulan endregal ja mas tzaani. 
\s1 Ja Jesusi alji sbaj que ja' yip ja diablo ja yioji 
\r (Mt. 12:22‑32; Lc. 11:14‑23; 12:10) 
\p Yaj ni ch'ac stzai, ti xa cumxiye ja ba snajea.  
\v 20 Ja cristiano jumasa ti xta nolane ja bay ja Jesusi, jaxa yeni soc ja snebumani, mi xax bob huauque.  
\v 21 Ti c'ot xchiquin ja yermano jumasa ja Jesusi, jayuj ti huaj yilea. Ti yalahuea: ―Loco xa ma quermanotiqui. Mas lec huan xax jac jmoctic, xchiye.  
\v 22 Jaxa matic ti jac ja ba Jerusaleni soc ja matic huas sea ja smandar ja Moisesi mi huax yalahue que loco. Ja' huax yaahue smojuc ja diablo, soc yen bi mero statalil ja diablo, ja' bi yuj huax bob sc'ul mandar ja pucuj jumasa. Como ay ni bi yipa, ja' bi yuj huax bob yal yab que oj actajuc can ja cristiano.  
\v 23 Ja Jesusi ti spaya jan ja matic jach huan yaljeli. Ti yala jun loila: ―Pero ¿sbej ama jach huanex yaljel ba? Ja Satanasi, ¿oj ma snutz el ja smoj Satanasil ba?  
\v 24 Q'uelahuilex, ja cristiano ma' jun ta lugar ayei, ta tola vida huas snutzu sbaje, oj jomuc ja lugar jahui.  
\v 25 Y jach ay ba jun naitz. Ja suinquili, ta puro pleito aye, oj ni jomuca.  
\v 26 Pero jach ni ja Satanás soc ja smoj jumasa tac. Ta toj pleito c'a aye, huan c'a snutzu ja smoji, oj ni jomuquea. Ti ni oj ch'acuquea.  
\v 27 Ja diablo jel tzatz juntiro. Jel jitzan ja ma' yaa ta och smozoil ja ba snaji. Mi ni nunca oj bob ochan ba snaj oj hua el libre ja smozo jumasa. Quechan ta huaxa mocho bajtan ja mero statalili, eso sí, oj bob ochan ja ba snaji. Ti oj bob oj el libre ja smozo jumasa.  
\v 28 Huax cala, pero meran, spetzanil ja specado ja cristiano oj c'ulajuc yi perdonar, anima jel piero ja jas huax el ja ba stii.  
\v 29 Pero ta huan c'ax yaahue och pucujil ja Espíritu Santo, mi ni nunca oj c'ulajuque perdonar. Mi ni nunca oj ch'ac ja scastigoei.  
\v 30 Jach yala ja Jesusi yuj ja yalahue sbaj que ja' bi yip ja diablo yioji. 
\s1 Ja snan soc ja yermano ja Jesusi 
\r (Mt. 12:46‑50; Lc. 8:19‑21) 
\p  
\v 31 Cuando ch'ac yal jachuc ja Jesusi, ti c'otye ja yermano jumasa soc ja snani. Secahue spayjel ba oj huaj sc'umuque porque ti aye ba fuera.  
\v 32 Jaxa cristiano ja ma' ti culane ec' mojan stz'eel ja Jesusi, ti yalahuea: ―Abi, ti bi ay ba fuera ja hua nani soc ja hua huermano jumasa. Huan bi sc'ana oj sc'umuca.  
\v 33 Pero ¿machunc'a ja jnan ba? ¿Machunc'a ja quermano jumasa? xchi ja Jesusi.  
\v 34 Ti stojtoq'uela ja cristiano ja matic culane ec' ba stz'eeli: ―Ja it jumasa, ja' jnan, ja' quermano jumasa  
\v 35 Porque spetzanil ja ma' huas sc'uan ja smandar ja Diosi, ja jau jumasa, ja' ni ja quermano soc ja quermana soc ja jnani, xchi ja Jesusi. 
\s1 Ja loil sbaj ja tica‑inati 
\r (Mt. 13:1‑9; Lc. 8:4‑8) 
\c 4  
\p  
\v 1 Ja Jesusi ti cho och see yi ja cristiano. Ti tzoman aye ja ba sti ja jai, pero montón xta aye. Jayuj ti huaj culan ba yoj barco ti lac'an ba yoj ja'. Jaxa cristiano ti ch'ac canuque ba sti ja jai.  
\v 2 Jel jitzan ja jas jeeji yile yuj ja Jesusi pero soc jun loil:  
\v 3 ―Maclayic. Jun c'ac'u jun huinic huaj stic ja yintil ja trigo.  
\v 4 Cuando huan sticjel ec' ja inat jahui, iday, ay ba co ba yoj bej. Pero jac ja yalchani, ti stuch'u ela.  
\v 5 Soc ay ba co yoj ton ba mey lec ja luumi. Huego el jani porque mi pimuc ja luumi.  
\v 6 Iday, cuando el q'uen ja c'ac'u, huego huego tacji, como mey yech.  
\v 7 Soc ay tuc inat ti co ba yoj q'uiix. Jaxa tihui, huax q'ui ja q'uiixi, jayuj ja inat jahui, c'utzji sq'uiel. Mi ni satinia.  
\v 8 Pero ay ba co ja ba lequil luumi. Huaj to yile, tz'ipan xa ec' ja yal trigoi. Jel tzamal q'uii. Ajyi sat. Ja jun sat inati, ya pojxuc treinta, jaxa otro juni, sesenta, jaxa otro juni, ya pojxuc cien.  
\v 9 Ja ma' ay xchiquini, a yabi, xchi ja Jesusi. 
\s1 Ja jastal ja sbej ja loil it yala ja Jesusi 
\r (Mt. 13:10‑17; Lc. 8:9‑10) 
\p  
\v 10 Jaxa mas tzaani, canye stuch'il ja Jesusi soc ja lajchahuanei soc chaboxe ja ma' mas yamigo sbajei. Ti och sobe yi ja Jesús jas sbej ja loil jau ja jas ch'ac yal yab ja cristiano.  
\v 11 Ti yala ja Jesusi: ―Ja ajyi, mi ni mero huax chijcaji jastal huas sc'ulan mandar ja Dios ja ba c'ujolali pero ja yaani sbej ni claro oja huabyexa. Pero ja tuc jumasa, sbej ni oj yabye jastal jun loil, porque mi nix c'ocxiyea.  
\v 12 Huas smaclaye pero mi ni huax yabyea. Eso sí, huax yilahue, pero ja smeranili, lajan soc mi ni huax yilahuea. Jayuj huax cal yab soc loil tac. Mi c'a, oj to huaja huabi, lec, oj chique. La xa c'uuctic siquiera oj c'ulajuc perdonar ja jmultiqui, pero yib ta ni abal oj yalea. 
\s1 Ja Jesusi yala jas sbej ja loil sbaj ja tica‑inati 
\r (Mt. 13:18‑23; Lc. 8:11‑15) 
\p  
\v 13 Pero ja huenlexi, ¿casta mi ahuabyex ja sbeji? ¿Jastal xa oja huabyex sbej ja otro loil oj to cal ba?  
\v 14 Ja ma' huaj stic ja inati, ja' ni ja ma' huan xcholjel ja yabal ja Diosi.  
\v 15 Jaxa ma' huas smacla ja yabal ja Diosi pero cuando huax ch'ac yabi, ti huax jac ja diablo. Huax jac sap yi ja jas ti xa ay ba sc'ujoli. Ja jun tiq'ue cristiano jahui lajane soc ja inat ti co ba yoj beji.  
\v 16 Soc ay ma' cuando huax yabye ja yabal ja Diosi, huego huas sc'ulane gusto. Lajane soc ja inati jau ti co yoj ton it huego eli,  
\v 17 Porque cuando huax q'ue ja huocoli, coraja huax iljiye yuj ja sc'uan ja yabal ja Diosi, mi huas sc'ulane ahuantar. Huax yaa can ja yabal ja Diosi. Mey yahuantare. Ja' ni smoj ja yal trigo jau tacji porque mey yech.  
\v 18-19 Jaxa ma' huax yab ja yabal ja Diosi, pero ja' huajel sc'ujol ja svida ba mundo, huax lolajiye yuj ja taq'uini, huax oc' sc'ujole ja cosa jumasa, pues, spetzanil ja jastic jahui, lajan soc huax jac sc'utz sq'uiel ja yabal ja Diosi. Mi huax ajyi sat. Lajane ni soc ja inat jau co ba yoj q'uiixi.  
\v 20 Pero ja ma' huax yab ja yabal ja Diosi y huas sc'uan merani, ja' ni smoj ja inat jau co ba lequil luum ja it yaa sati. Ay ba yaa treinta, ay ba yaa sesenta soc ay ba yaa cien. Iday, quechan jun yala sat tz'unji. 
\s1 Ja loil sbaj ja yajlel ja candela 
\r (Lc. 8:16‑18) 
\p  
\v 21 Ja jas huax jea, lajan soc jun candela huan ajleli. Jaxa candela, mi jauc ja ba oj nujxuc soc jun cajón, mi ni ba oj aaxuc ba yib ch'at. Sbaj ni oj aaxuc ba jun candelerio ba oj ijlabanuca.  
\v 22 Porque mi ni modo oj can musan ja jas huax jea. Sbaj ni t'ilan oj chicnajuca. Eso sí, ja huego nac'an musan to t'usan ja jas huanon yaljeli pero oj ni ch'ac abxuc sbeja.  
\v 23 Ja ma' ay xchiquin, a yabi, xchi ja Jesusi.  
\v 24 Ti cho yalaa: ―Ja jas huax cala huabyexi, toj a ajyuc ja hua c'ujolexi. Chican ja jastal huaxa c'anahuex yi ja Diosi, jach ni oj yaa huilexa. Ta soc spetzanil ja hua c'ujolex huaxa maclayex ja yabali, entonces ja Diosi oj ya jac ac'ujolex mas.  
\v 25 Porque ja ma' huax yab sbej ja jas huax cala, oj to ni jamxuc mas ja sata. Jaxa ma' quechan huas smacla, mi jachucuc ay ja sc'ujoli, ja t'usan huas snaa, oj ni aajuc ch'ay sc'ujola. 
\s1 Ja loil sbaj ja inat it tz'unji 
\p  
\v 26 Ja Diosi ja jastal huax atji ja ba sc'ujol ja ma' yaunej sbaj ba oj c'ulajuc mandar, lajan soc jun huinic huas stz'unu can ja inati,  
\v 27 Ti xa huax huaja. Huax huaj como jastal ja smodo culan yuji. Ja acuali huax huayi, jaxa sacbeli huax q'uei. Mi jauc huan sc'ulajel pensar ta huan sitz'el ja inat jau stz'ununeji. Mey sc'ulan pensar jas ora oj eluc.  
\v 28 Como smodo ni ja luuma. Stuch'il huax q'ui ja sbaali. Bajtan huax q'uii, ti huax jac ja yal jia, jaxa tzaani, ti huax ajyi ja sata.  
\v 29 Cuando c'an xa, es que yuj ni mojan xa jach'oji. 
\s1 Ja loil sbaj ja sbac mostaza 
\r (Mt. 13:31‑32; Lc. 13:18‑19) 
\p  
\v 30 Ti cho yala ja Jesusi: ―Ja jastal huax pojxi el ja abal it jastal huax c'ulhuani mandar ja Diosi, oj cala huabyex otro jun loil.  
\v 31 Lajan soc ja ch'in sbac mostaza. Jel ja inat ja ba luumi pero quechan mas ch'in ja iti. Cuando huax moc' ja ba yoj alaji,  
\v 32 Huaj to ahuile, tz'ipan xa eq'ue. Jun jabil mi ma' oj sc'oc ja sc'abi, quechan yen mas nihuan oj ajyuc soc ja smoj c'ulili. Jel huax ajyi ja sc'abi, jaxa yalchani huax jac sc'ul ja soj ja ba spimil ja sc'abi como ay yaxubil ja tihui, xchi ja Jesusi ja huan seejel yi ja cristiano. 
\s1 Ja Jesusi yala jas sbej yuj ja puro loil huas sea 
\r (Mt. 13:34‑35) 
\p  
\v 33 Jel ni sea yi ja cristiano ja Jesús ja yabal ja Diosi pero mi juntiro clarouc yala. Pero cuando huax yila ja Jesús mi xa huan to smaclayei, ti xa huax ch'ajbajia.  
\v 34 Huax ya slaj loil ja jas huax yal yab ja cristiano pero ja snebuman jumasa, claro ni huax yal yabyea.  
\v 35 Ja mismo c'ac'u jahui, cuando och ja acuali, ti yal yabye ja snebuman jumasa: ―Huajtiquic xa. Oj xa ec' jc'utztic ja jai, xchi.  
\v 36 Ti ch'ac sc'um can ja cristiano jumasa. Jaxa yeni mi ni t'un xchapa sbaja. Jach ni huaj ja jastal ni ayi. Ja' ni huajye soc ja mismo barco ja ba culane eq'ue. Soc ay ni chaboxe yal barco huaj nochana.  
\v 37 Bej xa aye cuando jac jun tzatzal ic'. Spuctzin sbaj ja ja' ja ba barco. But' ja' ja yoj barco, jaxa snebumani huane xta yaljel que oj bi ibjaaxuc ja sbarco.  
\v 38 Jaxa Jesusi huan huayel ja ba stop ja barco. Ti baan ec' ba jun scolchonil ja barco. Ti huaj syujquesea, ti yalahuea: ―Jaxa huen Maestro, ¿mi huaxa naa que oj xa huajcotic ja' ba? xchiye.  
\v 39 Jaxa Jesusi ti xa q'uea. Ti scomo ja iq'ui. Ti yal yab ja ja' que oj ch'ajbajuc. ―Laman la ajyi, xyutaj. Jaxa ch'ac yali, ch'abaji huego ja iq'ui. Xlamami huaj juntiro.  
\v 40 Ti yal yab ja snebumani: ―¿Jasyuj ja huanex ta xihueli? ¿Yuj ama mi ni t'usan huaxa c'uanex ba? x'utjiye.  
\v 41 Jaxa yenlei jel och juntiro ja spensarei. Ti yala sbaje yenle itaa: ―¿Jas huiniquil ja iti? Ja jai soc ja iq'ui, ¡pe huax c'uaji tac! 
\s1 Ja huinic ixtalanubal yuj ja pucuj ja ba Gadara 
\r (Mt. 8:28‑34; Lc. 8:26‑39) 
\c 5  
\p  
\v 1 Ja Jesusi soc ja snebuman jumasa ti c'otye ja ba otro lado sti ja jai, ja' ni ja slugare ja suinquil ja Gadara.  
\v 2 Cuando ch'ac couc ja ba barco ja Jesusi, ti jac tajuc huego yuj jun huinica jaxa huinic jahui, ja' ixtalanubal lec yuj ja pucuji. Ti el jan ja ba campo santo  
\v 3 Porque ti xa ni huax ajyi ec' ja tihui. Mi xa ni huan tox bob mochjuca, mi ni soc cadena.  
\v 4 Mi naben jaye vuelta huax mochji yi ja yoqui. Huax aaji och yi scadenail pero ja cadena, pedazo huax ch'ac ya huajuc, jaxa cuando mochan ja yoqui, lajan soc mi mochanuc huax yab ja yen. Mi ni june ja ma' huax bob ochuc ja ba sti sati.  
\v 5 C'ac'u acual huax bejyi eq'ue. Huax huaj ja ba huitzi, ti huax cho huaj ja ba campo santo. Lom xta huan ahuanel eq'ue. Ti huas stulu jun ton. Huax ch'ia soc ja sbactel ja ton jahui.  
\v 6 Jun ta repente yila najat ja Jesusi. Ti huaj ajnela. Huaj stae. Ti co mec'an ja ba sti sati:  
\v 7 ―A Jesús, ja huena ni ja yunina Dios jel nihuani. ¿Jastal aya jmoc ja huen ba? Por Diosito, tz'acataluca, moc lomuc jas oja c'ul qui, xchi ja huiniqui.  
\v 8 Jach yala porque yala ja Jesusi que oj bi yacta can ja huinic jau ja pucuji.  
\v 9 Ti yala ja Jesusi: ―Jaxa hueni, ¿jas abiil ba? ―Jel ni ja jbiil huax alji jbaji porque jel ni jitzanoticon, xchi ja huiniqui.  
\v 10 Ti och sc'an yi lec pavor ja Jesusi que mi bi oj jecjuque ba otro lugar, ti bi oj canuque ja ba mismo lugar jahui.  
\v 11 Iday, tey jun huitz ti ta mojan ay ja tihui. Tey jun montón chitam huan huael ja ba huitz jahui.  
\v 12 ―C'ulan quiticon lec pavor. Jecahuoticon soc ja tantic chitam jumasa jahui ba oj bob ochcoticon ja ba scuerpoei, xchiye xta spetzanil ja pucuj jumasa.  
\v 13 ―Pues lec, caaxic, xchi ja Jesusi. Jaxa pucuj jumasa ti yactaye can ja huiniqui. Ti huajye soc ja chitam jumasa jahui. Chab mil ja chitam jau huane huaeli. Iday, ja chitam jumasa, lom xta xbalali ch'ac couque jan ja ba huitzi. Ti ch'ac couque ja ba yoj jai. Ti ch'ac siq'ue jaa. Ch'ac chamuque spetzanil ja chab mil chitam jahui.  
\v 14 Jaxa matic huan stalnajel ja chitam jumasa jahui, ti ch'ac spaque ajnela. Ti huajye ba yoj chonabi soc huajye ba sti ja chonabi. Ch'ac sloilta yabye ja cristiano jumasa, jaxa yenlei lom xta xnololji ch'ac huaj yile.  
\v 15 Ti c'otye ja bay ja Jesusi soc ja ma' ixtalanubal yuj ajyi ja pucuji. Ja huinic jahui ti xa culan ec'a. Lapan xa sc'u. Siempre xa smodo. Mi xa locouc. Pero ja cristiano, xihuel xihuel ni aya.  
\v 16 Jaxa matic yilahue tojbi ja huinic jahui, ti cho och yale yab ja tuqui, cho yalahue jastal yilahue huaj ja chitami.  
\v 17 Jaxa cristiano jumasa ti och sc'an yi stz'acatal ja Jesusi. Sc'anahue yi lec pavor que a el huego, que oj bi yacta can ja slugarei.  
\v 18 Jaxa Jesusi ti q'ue ja ba barco, jaxa huinic jau ja ma' ixtalanubal ajyi yuj ja pucuji, ti och sc'an yi jitzan stz'acatal ja Jesús ta ay modo oj huaj soc.  
\v 19 Jaxa Jesusi mi sc'ana oj huajuc: ―Miyuc. Mas lec cax ba hua naji soc ja hua huermano jumasa. Al yabye ja jastal jel tzamal jc'ulan ahuii, jastal jtalna ja hua yaujulali. Jach sc'ulan qui ja Cajuali, oja huute, xchi ja Jesusi.  
\v 20 Ti huaj ja huiniqui, jaxa slugari, Decápolis sbiil. Ti och spuc ec' ja jastal jel tzamal c'ulaji yi yuj ja Jesusi, jaxa cristiano jel och juntiro ja spensarei. 
\s1 Ja yunin ja Jairo soc ja ixuc ja ma' syama yi ja snich ja sc'ui 
\r (Mt. 9:18‑26; Lc. 8:40‑56) 
\p  
\v 21 Como ti ni ay ba yojol ja barco ja Jesusi, ti xa ec' sc'utz otro vuelta ja jai. Cuando c'ot ja ba jun lado sti ja jai, ti ch'ac stzom sbaj jitzan lec ja cristiano, jaxa Jesusi ti can ja ba mero sti ja jai.  
\v 22 Ti jac june ja ma' ay yatel ba yiglesia ja judio jumasa, Jairo sbiil. Cuando yila bay ja Jesusi, ti co mec'an ja ba sti sati.  
\v 23 Ti och sc'an yi lec pavora: ―Ja caq'uixi jel juntiro huan huocol. Oj c'ana hui pavor oj huajan jmoc ba oja yam yi ja scuerpo ja caq'uixi ba oj tojbuc, ba mi oj chamuc, xchi ja Jairo.  
\v 24 Jaxa Jesusi ti huaj soca. Jaxa cristiano ti ch'ac huajuque nochana. Pero jel aaye juntiro. Huan xta sbatalaan sbaje.  
\v 25 Jaxa ba yojol ja cristiano jumasa tey jun ixuca. Ay xa lajchahue jabil mi xax ec' ja scuenta.  
\v 26 Jel yiaj ta huocol. Jel xa jitzan ja doctor yajna ta pero mas to huax aaji ipaxuc cani. Ch'ac ta spetzanil ja staq'uini. Lajan soc mi anuc huax yab ja scuerpo. Pegor xa ay.  
\v 27 Ja ixuc jahui yab yabalil ja Jesusi, jayuj ti xa nochan ec' soca, pero ti lapan ja ba yojol ja cristiano. Jaxa ixuc jahui, ti syama yi ja sc'u ja Jesusi porque  
\v 28 Huan xta yaljel ja sc'ujoli, anima bi quechanuc ja sc'u oj syam yii, oj ni bi tojbuca, xchi.  
\v 29 Y meran nia, cuando ch'ac syam yi ja sc'u ja Jesusi, huego huego c'ot tec'an ja scuenta, jaxa scuerpo, jel xliquiqui huaji. Snaa huego que tojbi ta ja xchameli.  
\v 30 Jach ni ja Jesusi. Yab sc'ujol que ay ma' ya tojbuc porque c'ot man ba scuerpo. Jayuj ti sutu sbaja. Sobo yi ja cristiano jumasa: ―Machunc'a cab syama qui ja jc'ui? xchi ja Jesusi.  
\v 31 ―Pe xa huila latzan ay ja cristiano tac, iday huaxa jobo mach'a huas syamahuoni, la chi, xchi ja snebuman jumasa.  
\v 32 Pero ja Jesusi q'uelan jacan ay eq'ue. Huan sleejel machunc'a yamji yuji.  
\v 33 Jaxa ixuqui xiu juntiro. Och q'uitc'onuc ja scuerpo pero huan ni snaa jastal huaja. Ti huaj ja ba stz'eel ja Jesusi. Co mec'an ja ba sti sati: ―Quena jyamahua Cajual, xchi.  
\v 34 Ti alji yab yuj ja Jesusi: ―Hija, yuj ja hua c'uani, tojbiya ta. Mix cham ac'ujol. Cax xa. Mi xa ni oj cho coan soc ja chamel iti, x'utji ja ixuqui.  
\v 35 Jach huan yaljel ja Jesusi cuando c'ot jun jecabanum. Ti el jan ja ba snaj ja Jairo, como jepe ay ja ba yiglesia ja judio jumasa. Ti yalaa: ―Ja huala aq'uixi cham ta. ¿Jas to yatel oj josjonan soc mas ja Maestro? xchi ja jecabanumi.  
\v 36 Pero ja Jesusi cuando ch'ac yab ja jas yala ja jecabanum jahui, ti yal yab ja sepeil ja yiglesia ja judio, ja' ni ja Jairo ja ma' cham ta bi ja yunini: ―Mix cham ac'ujol, como c'uan, x'utji.  
\v 37 Ja Jesusi ti yala que quechan oj huaj soc ja Pedro soc ja Jacobo soc ja Juan ja yijtz'in ja Jacobo.  
\v 38 Ti c'otye ja ba snaj ja sepeil ja yiglesia ja judio jumasa. Jaxa naitz jahui but'el xa ja cristiano. Lom xta xuooljiye. Tuc ma' huan meba oq'uel, tuc ma' huan q'ueel sni sc'ujol yuj ja oq'ueli. Ja Jesusi, cuando yila,  
\v 39 Ti och ja ba yoj naitzi. Ti yalaa: ―¿Jasyuj lom jel huanex oq'ueli? ¿Jasyuj jel juntiro huaxa huaahuex ja ruido? Ja aq'uix iti mi chameluc. Huan huayel tac, xchi.  
\v 40 Jaxa mucuanum jumasa: ―Lom huan c'umal ja iti, xchiye. Pero ja Jesusi ti yal yab ja mucuanum jumasa que oj ch'ac eluque. Ti can ba yoj naitz ja snan stat ja aq'uixi soc ti ni ay ja ma' stzaunej ni ja Jesusi. Ti ochye ja ba liban ec' ja aq'uixi.  
\v 41 Ti syama yi ja sc'ab ja aq'uixi: ―Talita cumi, xchi soc ja sc'umali, jaxa soc ja jc'umaltiqui: Nina, huax cala huabi, q'uean, xyutaj ja aq'uixi.  
\v 42 Jaxa aq'uixi, huego huego q'uei. Q'ue bejyuc. Lajchahue jabil yioj ja aq'uix jahui. Jaxa cristiano ch'ac boboaxuque juntiro.  
\v 43 Pero ja Jesusi ti ch'ac scom c'ac' lec ja cristiano que mi bi ma' oj yale yab ja jastal huaj ja aq'uix jahui. Ti yala que oj xa aajuc yi ja suael ja aq'uixi. 
\s1 Ja Jesusi huaj ba Nazaret 
\r (Mt. 13:53‑58; Lc. 4:16‑30) 
\c 6  
\p  
\v 1 Ja Jesusi ti yaa can ja lugar jahui. Ti huaj ja ba slugar ja yeni. Ja' smoj ja snebuman jumasa.  
\v 2 Jaxa ba sc'ac'uil ja jijleli, ti huaj ba yiglesia ja judio jumasa, jaxa tihui, ti och see yi ja cristiano. Ja matic huan yabjeli, jel och juntiro ja spensarei, ti yalahuea: ―¿Jastal ay ja iti? ¿Ba yiaj ja svivoili? Huax bob sc'ul milagro tac. ¿Ma' ac'uni yip ja huinic iti?  
\v 3 Pero ja' yunin ja carpintero tac, jaxa snani, ja' ni ja men María, jaxa yijtz'ini, ja' ni ja tan Jacobo soc ja tan José, soc ja tan Judas, soc ja tan Simoni. Jaxa ixuquei, pero jmojtic ni taca, xchiye xta. Jayuj mi ni t'un yaahue casoa.  
\v 4 Jayuj ti yala ja Jesusi: ―Jach ni ja aluman‑Dios jumasa. Jel gusto iljiye ja ba otro lugari, pero ja ba mero xchonabilei, soc ja yermano jumasa, ja ba yoj snajei, jel ch'in iljiye.  
\v 5 Jayuj mi ni bob sc'ul milagro ja tiu ja Jesusi. Quechan syama yi ja scuerpo chaboxe cristiano ja ma' malo ayei, jaxa yenlei tojbiye.  
\v 6 Pero ja tuc jumasa, jel och ja spensar ja Jesusi porque mi ni t'un huax c'uajia, jayuj ti el ja tihui. Ti xa huaj ec' ja ba yal hacienda jumasa ja ba mojan yaman ja tihui. Huaj see yi ja cristiano. 
\s1 Ja Jesusi seca ja snebumani ba oj huaj sloiltaye ja yabal ja Diosi 
\r (Mt. 10:5‑15; Lc. 9:1‑6) 
\p  
\v 7 Jaxa ec' ja c'ac'u jumasa jahui, ti c'umajiye ja lajchahuane jau yuj ja Jesusi. Naca cuagrilla cuagrilla bi oj yi sbaje ja ba oj huajuquei. ―Caxic xa. Huax caa huatelex ba oj bob ac'uluquex mandar ja pucuji, x'utjiye.  
\v 8 Mi bi jas oj yie eq'ue. Mi bi oj yii ja snutiei, soc mi ni ja yoot spichei, soc mi ni bi jun centavo oj yie ja ba smorralei. Quechan bi oj yie ja snajbantei.  
\v 9 Soc oj bi slap ja xanabei pero malan bi soc ja sc'ue lapan yujilei.  
\v 10 ―Huan c'ax aaji ochanic ba jun naitz, ti la ajyiyex ja tihui masan to oj elanic ja ba lugar jahui.  
\v 11 Pero ta ay c'a jun lugar mi huas sc'ulanex recibir, mi huas smacla ja jas huaxa hualahuexi, pues elanic ja tihui. Tzijunic can ja spolvoil ja hua huoquexi. A yil can sbaje. Ja c'ac'u oj yae yi cuenta ja Diosi, ¡ay pobre ja yenlei! Mas lec oj ajyuc ja suinquil ja Sodoma soc ja suinquil ja Gomorra que yuj ja suinquil ja chonab jahui, xchi ja Jesusi.  
\v 12 Jaxa snebuman ja Jesusi ti huaj yale yab ja cristiano jumasa que aa xa bi suchuc ja sc'ujolei.  
\v 13 Jel jitzan ja cristiano actaji can yuj ja pucuj jumasa yuj ja jach ni sc'ulan mandar ja snebuman ja Jesusi, jaxa matic malo ayei, quechan jaxji yile aceite ja s'olomei, ch'ac ni tojbuquea. 
\s1 Ja Juan ja ma' yaa bautismo, chami 
\r (Mt. 14:1‑12; Lc. 9:7‑9) 
\p  
\v 14 Ja rey Herodesi ti yab yabalil ja Jesusi porque pucan xa ni yabalila: ―Ja' ni ja Juan it huax yaa bautismo ajyi, jayuj jel ja jas huax bob yujili. Eso sí, cham ta nia, pero seguro cho sacui ta, xchi ja Herodesi.  
\v 15 Jaxa tuqui: ―Miyuc. Ja' ni ja Eliasi. Jaxa tuqui: ―Ja' ma aluman‑Diosi, ma ja' june ja aluman‑Dios ba najatei, xchiye.  
\v 16 Jach c'ot xchiquin ja rey Herodesi. Ti yalaa: ―Seguro ja' ni ja Juani. Eso sí, cham nia porque jeca ni c'utzuman ja s'olomi, pero cho sacui ta, xchi.  
\v 17 Porque yena ni ja Herodes jau yaa smandar ba oj yamjuc ja Juan ajyi. Xch'ica ba preso y cho smocho soc cadena. Jach ni sc'ulana yuj ja scuentosil ja ixuc Herodíasi. Ja Herodíasi, ja' statam ja yijtz'in ja rey Herodesi, Felipe sbiil. Jaxa xcheum ja Felipe, japji yuj ja sbanquil rey Herodesi.  
\v 18 Jaxa rey Herodesi ti alji yab yuj ja Juani: ―Ja ixuc jahui, ja' ni sbaj ja hua huijtz'ini. Mi sbejuc huaxa cheuman, x'utji.  
\v 19 Jayuj ja ixuc Herodíasi, jel coraja ay soc ja Juani. Huan xchapjel yabalil. Huas sc'ana oj smile pero mi bob yujil  
\v 20 Porque ja rey Herodesi, xihuel xihuel ay yuj ja Juani. Huas snaa que jel toj ay soc mi huas slea ja smuli, jayuj mix yaa orden ba ay jas oj c'ulajuc yi ja Juani. Huas smacla ja jas huax yala ja Juani, anima mix yab sbej, pero jel ni ja sganaa.  
\v 21 Pero c'ot ni ja c'ac'u bob yujil ja jas huas sc'ana ja ixuqui. Ja rey Herodesi yaa jun q'uin, como ja' ni ja sc'ac'uil ja sq'uini. Sloco ja ma' ay yatel yuji, soc ja soldado jumasa, soc ja ma' ay yatel ba Galilea. Sloco ba jun huaelal.  
\v 22 Ti och ja yal ja ixuc Herodíasi. Ti och chaanuca. Jaxa rey Herodesi, jel sgusto, jach ni ja smoj huael jumasa. Ja reyi ti yal yab ja aq'uixi: ―Chican jas huaxa c'ana qui, oj ni caa huia.  
\v 23 Xila Dios, hasta snalan ja ba huax c'ulan mandari, oj caa hui, xchi ja reyi.  
\v 24 Jaxa aq'uixi ti ela. Ti huaj yii yabal ja snani. ―¿Jasunc'a lec oj c'an yii? xchi ja aq'uixi. Jaxa snani ti yalaa: ―C'ana yi ja s'olom ja tan Juan it huax yaa bautismo, xyutaj.  
\v 25 Jaxa aq'uixi, ti cho och huego ja ba sti sat ja reyi, ti yal yaba: ―Ay ni jas huax c'ana oj c'an ahui Señor Rey. Huax c'ana oja pach jan qui ba jun plato ja s'olom ja tan Juan it huax yaa bautismo. Pero aa qui huego, xchi.  
\v 26 Jaxa rey Herodesi, jel tristeaxi pero como yab ja smoj huael jumasa soc jel tzatz ja sti yala, jayuj mi sc'ana oj stucbes ja spalabra.  
\v 27 Huego spaya jan june ja soldado ja matic huas stalna ja snaj ja reyi. Oj bi huaj yii jan ja s'olom ja Juani.  
\v 28 Ti huaj ja soldado jahui, jaxa ba yoj preso, ti sc'utzu el yi ja s'olomi. Ti yaa ba jun plato. Ti spacha och yi ja aq'uixi, jaxa aq'uixi ti yaa yi ja snani.  
\v 29 Ti c'ot xchiquin ja snebuman ja Juani. Ti jac yie ja scuerpo. Ti smucuhue ba jun q'ueen. 
\s1 Ja Jesusi ya huauc joe mil huinic 
\r (Mt. 14:13‑21; Lc. 9:10‑17; Jn. 6:1‑14) 
\p  
\v 30 Jaxa matic jecji yuj ja Jesús ba oj huaj sloiltaye ja yabal ja Diosi, cuando ch'ac sloiltaye eq'ue, ti cumxiyea. Ti huaj yale yab ja Jesusi ja jastic sc'ulanei. Cho yalahue yab jastic seahue yi ja cristiano.  
\v 31 Ti yala ja Jesusi: ―Lec ay, la xa huajtic ba jun lugar ba mey lec ja suinquili ba oja huii ahuipexi, xchi ja Jesusi. Porque jel xa jitzan ja cristiano. Tuc ma' huan cumxel ba snajei, tuc ma' huan c'otel ja bay ja yenlei. Mi xa ni ba oj huauque, mi xax bob yujile.  
\v 32 Jayuj ti spila sbajea. Soc barco huajye ba jun ch'ayan lugar.  
\v 33 Pero iday, mi bob yujile. Iljiye huajye. Naaji sbaje que yenle. Jaxa ma' yila, ja' ni ja suinquil ja chonab jumasa mojan ja tihui. Ti cho huajye nochan ja yenlea. Soc yoque soybaye ja jai, jaxa mi tox c'ot ja Jesús soc ja snebuman jumasa, ti xa aye ja cristiano jumasa. Huane xta smajlajel oj c'otuc ja Jesusi.  
\v 34 Jaxa Jesusi, cuando c'ot ja tihui, ti co ja ba barco. Cuando yila tey jun nole ja cristiano, ti stalna syaujulalea. Lajane bi soc jun nole chej pero mey talnuman. Ti och see yi jitzan cosa.  
\v 35 Cuando jel xa och ta c'ac'u, ja snebuman jumasa ti jac ja bay ja Jesusi. Ti yalahuea: ―Pero ja lugar iti, jel najat ay y jel xa och ta c'ac'u.  
\v 36 Mas lec al yab ja cristiano que aa xa huajuque. Tix huajye ja ba yal hacienda ja ba yal lugar jumasa ba mojani. A huaj sman ja yoot spichei porque mi xa ni jas yiojea, xchi ja snebuman jumasa.  
\v 37 Ti yala ja Jesusi: ―¿Jaxa mi xa huaahuex yi ja suaele ja huenlex ba? Ti yala ja yenlei: ―Pero Cajual, ¿jastal ay ba? ¿Oj ma bob huaj manticon dosciento peso ja pan ja quenticon ba oj caaticon ja suaele ba? xchiye.  
\v 38 ―Cax ilahuic jaye pan ahuiojex ja huenlex ba, xchi ja Jesusi. Jaxa snebuman jumasa, cuando yilahue jaye pan yiojei, ti yalahue yaba: ―Pe quechan xta joe pan soc chab ala chay, xchiye.  
\v 39 Ti yala ja Jesús que oj bi ochuque culan ba yoj job ja cristiano jumasa, que oj bi yii sbaje jujun nole.  
\v 40 Jach ni sc'ulanea. Ay ba yioj sbaje cien, soc ay ba cincuenta cada yal nole jahui.  
\v 41 Jaxa Jesusi ti yiaj ja joe pani soc ja chab chayi. Sq'uela q'ue ja ba satq'uinali, ti yaa yi stz'acatal ja Diosi. Ti spilaa. Yaa yile ja snebuman jumasa ba oj ya ec' yi ja cristiano. Soc jach ni ja chab chayi. Spilahue yi ja cristiano, iday, yaa ba spetzanile.  
\v 42 Mi ni june ma' mi huaa. Ch'ac but'uque lec.  
\v 43 Cuando ch'ac stzome ja sobra ja pani soc ja sobra ja chayi, cho but' lajchahue mooch.  
\v 44 Jaxa janec' huaayei, cinco mil huinic. 
\s1 Ja Jesusi bejyi ja ba sat jai 
\r (Mt. 14:22‑27; Jn. 6:16‑21) 
\p  
\v 45 Ja Jesusi ti yal yab ja snebuman jumasa que oj xa bi huajuque soc barco ba Betsaida ja ba otro lado sti ja jai. Jaxa yeni oj to bi sc'um can ja cristiano jumasa, ti bi oj cho huajuca.  
\v 46 Jaxa cuando ch'ac sc'um can ja cristiano jumasa, ti huaj sc'umuc ja Diosi ja ba jun huitz.  
\v 47 Jaxa och ja acuali, ti xa ay ja snebuman jumasa ja ba sbarcoei ja ba snalan ja jai, jaxa Jesusi ti to ay ja ba huitzi.  
\v 48 Ja Jesusi yila que jel huane huocol soc ja sbarcoei. Jel xa yajtique soc ja snicjeli porque ja iq'ui ti jacum ja ba lado huane huajeli. Ja Jesusi ti huaj snoch ja snebuman jumasa, pero ti huan bejyel och ja ba sat ja jai ba oj ec' toj eq'uel, pero sbaj xa xchanil gallo.  
\v 49 Pero ja snebuman jumasa, cuando yilahue que ti huan bejyel jan ja ba sat ja jai, mi snaahue machunc'a. Jel tuc yilahue ja scuerpo. Ti ch'ac ahuanuquea.  
\v 50 Jel xiuye juntiro. Spetzanile ch'ac yile. Jaxa Jesusi ti c'umani: ―Mi la xiuyex. Quena nia. Tzatz la ajyiyex.  
\v 51 Ti q'ue ba barco ja Jesusi. Scomo ja iq'ui. Jaxa snebuman jumasa ch'ac paxuque boboil. Jel och juntiro ja spensarei.  
\v 52 Ja ora jahui, eso sí, yilahue jastal jitzanbi ja pani, pero mi jauc jac sc'ujole. Lajan soc mi yilunejuque. 
\s1 Ja Jesusi ya tojbuc ja ma' malo ay ja ba Genesareti 
\r (Mt. 14:34‑36) 
\p  
\v 53 Cuando ch'ac sc'utze ja jai, ti c'otye ja ba jun lugar Genesaret. Ti smochohue can ja sbarcoei ja ba sti ja jai.  
\v 54 Cuando ch'ac couque ja ba barco, huego huego naaji sbaj ja Jesusi.  
\v 55 Jaxa ba spetzanil ja lugar ja ba mojan yamani, sac ajnel xta ch'ac jacuque ja cristiano jumasa. Ch'ac yie jan ja ma' malo ayi. Soc xch'atilteil huas slicahue jani, chican ba lugaril huax yabye bay ja Jesusi.  
\v 56 Chican ba huax huaj ja Jesusi, sea ba yal hacienda, sea ba chonab, ma ba sti ja chonabi, ti huax huaj tajuc yuj ja cristiano. Huax yiaje jan ja chamum jumasa. Ti huax yaahue can ba calle. Ti huax huaj sc'ane yi lec pavor ja Jesusi, anima bi quechanuc ja snich ja sc'u oj yamjuc yii. Y meran nia, spetzanil ja ma' syama, ch'ac ni tojbuquea. 
\s1 Ja jas huax jomji yuj ja cristiano 
\r (Mt. 15:1‑20) 
\c 7  
\p  
\v 1 Ja fariseo jumasa soc chanjoe ja ma' huas sea ja smandar ja Moisesi ti huajye ja bay ja Jesusi. Ja yenlei ti elye jan ja ba Jerusaleni.  
\v 2 Cuando yilahue jastal huane huael chaboxe ja snebuman ja Jesusi, ti sleahue yi ja smula porque mi bi sbejuc ja jastal sac'ahue ja sc'abei. Jel bi cux ja sc'ab huas syamahue ja suaelei.  
\v 3 Ja fariseo jumasa, jach ni spetzanil ja cristiano judio, culan ni yujile jitzan vuelta huas sac'a ja sc'abei. Ja costumbre iti, ja' ni sbaj ja ma' ec' pax ta yujilei. Mi c'a huas sac'ahue jitzan vuelta, mi ni bi modo oj bob huauque.  
\v 4 Cuando huax huajye ba plaza ti huax cumxiye ja ba snajei, mi c'a huas sac'a jitzan vuelta ja sc'abei, mi ni bi oj huauquea. Jitzan lec ja scostumbre yioje xa ja jastal jahui. Jach ni ja svasoe ja ba huax yuaje ja' soc ja jarro jumasa soc ja oxom taq'uini. Hasta ja suaynubei, huas sac'ahue lec.  
\v 5 Jayuj ti jac sobe yi ja Jesusi ja fariseo jumasa soc ja ma' huas sea ja smandar ja Moisesi: ―Ja hua nebuman jumasa mi ni t'un huas squitz'ahue ja scostumbre ja ma' ec' pax ta cujtiqui. Pe scuxil sc'ab huax huaaye tac. ¿Jasyuj jach huas sc'ulane ba?  
\v 6 Ti yala ja Jesusi: ―Ja huenlexi toj chab cara ayex. Meran ni ja jastal staahuex ti' ja Isaiasi: 
\q1 Ja cristiano jumasa iti huas sea sbaje que huas squitz'ahuone. 
\q1  
\v 7 Jel tzamal ja sc'umalei, pero iday, ja sc'ujolei, mi ni t'un huas squitz'ahuone. Ja' bi ja ba sti jsati huas stzomo sbaje, pero lom ni juntiroa. Ja jas huane seejeli, spensar ni yenlea, 
\m xchi ni ja Isaías tac.  
\v 8 Huaxa huaahuex can jun lado ja smandar ja Diosi, jaxa jastic culan ahuujilexi, ja' jel nihuan ahuiojex. Q'uelahuilex ja jastal huaxa sac'ahuex ja hua jarroex soc ja hua vasoexi. Montón jastal jau huaxa c'ulanexi, xchi ja Jesusi.  
\v 9 Soc ay jas mas yala: ―Jel ni vivoexa. Jel xa naahuex jastal huaxa c'ulan ja hua costumbreexi, jaxa smandar ja Diosi, huaxa huaahuex can jun lado.  
\v 10 ¿Mi ma yala ja Moisesi que oj bi yajtatic ja jnan jtatiqui, jaxa ma' huas staahue ti' malo ja snan stati, oj ni bi aajuc ch'ay snaajela?  
\v 11 Jaxa huenlexi, at ja jas huaxa hualahuexi: Naney, tatey, eso sí, huax c'ana jcoltayex nique ajyi pero spetzanil ja jas quioji, naca caunej yi ja Diosi, huaxa huutajex ja hua nan atatexi. Jach huaxa jeahuex yi ja cristiano.  
\v 12 Jaxa cristiano, mix bob scolta mas ja snan statei pero ja' yuj ja hua mul ja huenlexi.  
\v 13 Lamlamil jach huaxa jeahuex yi ja cristiano. Puro ja' hua costumbreexi, jaxa yabal ja Diosi, lom ni altiro ahuujilexa. But'elex soc ja hua modoex ja jastal jahui, x'utji ja fariseo jumasa.  
\v 14 Ja Jesusi ti spaya jan ja jun nole cristiano ja tihui, ti ch'ac och aljuc yabyea: ―Maclayic apetzanilex. Naahuic t'unuc ja sbeji.  
\v 15 Ja jas huax och ba hua tiexi, mi jauc oj jomanic yuj. Ja jas huax el ja ba hua tiexi, ja' mero huas somohuex.  
\v 16 Ja ma' ay xchiquin, a yabi, xchi ja Jesusi.  
\v 17 Ti xa spila sbaj soc ja cristiano jumasa. Cuando och ja ba yoj naitzi, ti jobji yi yuj ja snebuman jumasa jastal ay ja loil it ch'ac ta yali.  
\v 18 Ti yala ja Jesusi: ―Jaxa huenlex chomajquili, ¿yuj ama mi ni t'un huaxa huabyex slugaril ba?  
\v 19-20 ¿Mi ma huaxa naahuex ja jas huax och ba hua tiexi, mi jauc oj jomanic yuj? Ja jahui mi jas yioj ba hua hualtzilexi. Ja jas huax och ba hua tiexi, ti huax co ba hua lucumexi, jaxa ba ja hua lucumexi, toj eq'uel huax eq'ui, xchi ja Jesusi. Cuando jach yala, slugar que yala que lec yabjel spetzanil ja huaelali.  
\v 21 Ja' bi ja jas huax el ja ba jtiitiqui, ja' bi oj jomcotic yuj, mi bi jauc ja juaeltiqui. Porque ja' ni ja caltziltiqui, ti huax jac ja malo jpensartiqui. Huax leatic ja tuc jcheumtiqui, ma ja tuc huiniqui. Lajan soc chante ja jpensartiqui, huala milhuanitic, como ti ni ay ja ba caltziltica.  
\v 22 Huala elc'anitic. Jex c'anc'oni ja jc'ujoltiqui, chican jas malo huax c'ulantiqui. Huax lola jbajtic. Toj malo ja jpensartiqui, envidiosootic, huala c'umanitic malo, huax toyo jbajtic, jel bobootic.  
\v 23 Spetzanil ja jastal jahui, ti ni cajan jc'ujoltica. Juntiro huax jomo jbajtic. 
\s1 Jun ixuc ba tuc raza sc'uan ja Jesusi 
\r (Mt. 15:21‑28) 
\p  
\v 24 Ja Jesusi ti xa el ja tihui, ti huaj ja ba lugar mojan ja ba Tiro soc ja ba Sidoni. Cuando c'ot ja tihui, ti och ba jun naitz. Mi sc'ana oj see sbaj satalajel abal pero mi ni modo huax bob yujila.  
\v 25 Ti abji yabalil yuj jun ixuc, jaxa ixuc jahui, ay yal. Ja yal yaq'uixi ixtalanubal yuj ja pucuji. Ti huaj ja bay ja Jesusi, jaxa ixuqui ti co mec'an ja ba sti sati.  
\v 26 Ti och sc'an yi jitzan pavor ba oj sc'ul mandar ja pucuji ba oj actajuc can ja yali. Sirofeñera ja yeni. Griego huax c'umani.  
\v 27 Ti alji yab yuj ja Jesusi: ―¿Mi ma sbejuc bajtan huax huaa ja yal untic ba? Jel piero ta huan c'ax japxi ja suael ja yal untiqui oj aaxuc yi ja ma' mix naaxi sbaji, xchi ja Jesusi.  
\v 28 ―Meran Cajual. Eso sí, anima tz'iuc pero q'uelahuil jun ula tac. Huax jac ja ba jun naitz, anima jauc ja sobra pero oj ni aajuc yia, xchi ja ixuqui.  
\v 29 Ti yala ja Jesusi: ―Caax xa. Yuj ja jel tzamal ja jas ahualai, ja hua huali libre xa aaji ta can yuj ja pucuji, xyutaj.  
\v 30 Y meran nia. Yajni c'ot ja ba snaj ja ixuqui, huaj yile, lec xa ay ja yali. Ti to ni baan ec' ba sat ch'at pero mi xa ixtalanubaluc yuj ja pucuji.  
\v 31 Ja Jesusi ti yaa can ja lugar mojan ba Tiro. Toj eq'uel ec' ba Sidón soc ba Decápolis masan c'ot ja ba ja' sbaj Galilea.  
\v 32 Cuando ti xa ay c'ot ja tihui, ti iiji jan yi jun huinic sordo ay y jel queec huax c'umani. Ti c'anji yi pavor ja Jesusi ba oj syam yi ja scuerpo.  
\v 33 Ja Jesusi ti spila sbaj soc jun maq'ue ja huinic jau sordo ay y queec huax c'umani. Ti smaca soc ja xchiquin ja yal sc'abi. Yajni ch'ac sc'uluc ja jachuqui, ti tzujbania. Ti syama yi ja yac'a.  
\v 34 Ja Jesusi ti sq'uela q'ue ja satq'uinali. Sic'a sc'ujol: ―Efata, xchi soc ja sc'umali. Oj xa huab q'uinal. Oj xa bob c'umanan claro. Jach sbej ja jas yala.  
\v 35 Y meran nia. Huego huego jamxi ja xchiquini, jaxa yaq'ui lajan soc tzatzbel ajyi, jaxa ora jahui, huego huego c'umbi. Jel claro el ja sc'umali.  
\v 36 Ja Jesusi ti och sc'an yi lec pavor ja cristiano jumasa que mi ni ma' oj yale yab ja jastal tojbi ja huinic jahui. Pero lajan soc sulbes ita ja cristiano. Yochele ec' ch'ac spuque ec' jastal tojbi ja huiniqui.  
\v 37 Jel och juntiro ja spensarei, ti yalahuea: ―Jel ni tzamal spetzanil ja jas huas sc'ulani. Huax ya yab q'uinal ja ma' tupel xchiquin, jaxa matic mudo, huax ya c'umanuc, xchiye xta. 
\s1 Ja Jesusi ya huauc chane mil cristiano 
\r (Mt. 15:32‑39) 
\c 8  
\p  
\v 1 Ja c'ac'u jumasa jahui lom xta xnoloji huax jac ja cristiano jumasa ja bay ja Jesusi, iday, mi xa ay ja suaelei, como ch'ac ta. Ja Jesusi ti spaya jan ja snebumani, ti yalaa:  
\v 2 ―¡Jel ajul ja sbaj ja cristiano jumasa iti! Ay xa oxe c'ac'u ti jmoctica y ch'ac ta yoot spichiei.  
\v 3 Huan c'ax cal yab oj huajuque ba snajei, oj ch'ac yipe ja ba beji porque oj xta syatz'atz'uc ja yaltzilei yuj ja huaini porque ay ma' jel najat jaquele, xchi ja Jesusi.  
\v 4 Ti yala ja snebuman jumasa: ―Pero Cajual, jel ch'ayan lugar juntiro tac. ¿Ba xa oj yie ja suaele ba? ¿Jastal oj bob but'uque ja ili?  
\v 5 Ti yala ja Jesusi: ―¿Jaye ja pan ahuiojex ba? ―Quechan xta juque, xchiye.  
\v 6 Ja Jesusi ti yal yab ja cristiano oj ochuque culan ba yoj job. Ti yiaj ja juque pani. Yaa yi stz'acatal ja Diosi, ti spila yi ja snebuman jumasa, jaxa snebumani ch'ac ya ec' yi ja cristiano jumasa.  
\v 7 Ja snebuman jumasa cho ay yioje chaboxe chay. Ja Jesusi ti sc'ana yi stz'acatal ja Diosi. Ti yal yab ja snebumani oj cho ch'ac yaa yi ja cristiano.  
\v 8 Ja cristiano jumasa ti och huauquea. Butye lec. Cuando ch'ac huauquei, ti och stzome ja jas can sobra. But' juque mooch.  
\v 9 Chane mil cristiano huaa ja ora jahui. Jaxa Jesusi, ti xa sc'uman can ja cristiano jumasa. Ti q'ue jun barco soc ja snebuman jumasa.  
\v 10 Ti huajye ba jun lugar Dalmanuta. 
\s1 Ja Jesusi c'anji yuj ja fariseo ba oj yile jun milagro 
\r (Mt. 16:1‑4; Lc. 12:54‑56) 
\p  
\v 11 Jaxa ba lugar jahui, ti jacye chaboxe ja fariseo jumasa. Jac yie loil ja Jesusi. Eso sí, jacye pero mi slequiluc sc'ujole. Oj bi jeejuc yile jun seña ja ba satq'uinali ti bi oj snae que meran tey soc ja Dios ja Jesusi, pero como quechan huane sc'ulajel probar.  
\v 12 Ja Jesusi ti syatz'a sbaj ja yaltzili, ti yalaa: ―Ja cristiano iti, quechan huane sc'anjel que oj bi yile jun seña ba jel ja smilagro pero ja mero smeranili, mi jas oj jeexuc yile, xchi ja Jesusi. Quechan alji can yabye jachuc,  
\v 13 Ti xa huaja. Cho q'ue ja ba barco, ti cho ec' sc'utz ja jaa. 
\s1 Ja slevadura ja fariseo jumasa 
\r (Mt. 16:5‑12) 
\p  
\v 14 Pero ja snebuman jumasa ch'ay sc'ujole mi yiaje jan ja pani. Quechan june altiro ja pan ti nolan yujile ja ba barco.  
\v 15 Ti yala ja Jesusi: ―Aa cuidadoex soc ja slevadurail ja fariseo jumasa soc ja tan Herodesi, xchi.  
\v 16 ―¿Jas sbej jach huax yala cabtic ba? ¿Yuj ama jayujil huax yala yuj ja ch'ay jc'ujoltic mi quiajtic jan ja pan ba? Jach och sobtalauc sbaje ja snebuman jumasa.  
\v 17 Ja Jesusi cuando yab ja jas huane yaljeli, ti yalaa: ―¿Ja' ma pan huanex xta staajel ti' ba? Mi ni t'un huaxa naahuexa. ¿Mi ni ma t'un huax jac ac'ujolex ba? Lajan soc mi teyuc ja hua c'ujolex huaxa huilahuex ja jas huax c'ulani.  
\v 18 Eso sí, ay asatex, pero mila ilhuaniyex. Ay achiquinex pero lajan soc mi xa huabyex q'uinal. A jac t'un ac'ujolex.  
\v 19 Ja yora quechan xta joe pan quiojtiqui, jpila yi ja cristiano jumasa, iday, joe mil huaaye, jaxa sobrai, ¿jaye mooch atzomohuex ba? ―Lajchahue, xchi ja yenlei.  
\v 20 ―Jaxa it yora quechan xta juque pan quiojtiqui, jpila yi ja cristiano jumasa, ¿jaye mooch atzomohuex ja sobra ba? ―Juque, xchiye.  
\v 21 ―Iday, ja huilunejex pero mi ni t'un huax jac ac'ujolexa, xchi ja Jesusi. 
\s1 Ja Jesusi ya tojbuc jun ma' tupel sat ja ba Betsaida 
\p  
\v 22 Ti c'otye ja ba lugar Betsaida jaxa tihui, ti iiji jan yi jun huinic tupel sat. Ti c'anji yi pavor ba oj syam ja sati.  
\v 23 Ja Jesusi ti syama yi ja sc'ab ja huiniqui. Xchecha el ja ba sti hacienda, jaxa cuando ti xa aye ja tihui, ja Jesusi ti ya och yi t'usan ja yaal sti ja ba sat ja huiniqui. Ti saxa yi ja sati. Sobo yi ta ay jas huax yila.  
\v 24 Jaxa huiniqui ti sacha ja sati, ti yalaa: ―Lajan soc te' huax quila pero ¡huan bejyel tac! ¡Ja' ma cristiano jahui! xchi.  
\v 25 Jaxa Jesusi ti syama yi otro vuelta ja sati. Yajni ch'ac syam yi, huego huego yila q'uinal lec. Tojbi ja sati. Claro juntiro huax yila ja cristiano, y najat lec.  
\v 26 ―Lec, caax xa. Cax ba hua naji. Moc lom huajan ja ba yoj hacienda. Mi lom xa hual yab ja suinquil ja hacienda jastal tojbia, xyutaj ja Jesusi. 
\s1 Ja Pedro yala claro que ja Jesusi, ja' ni ja Cristo 
\r (Mt. 16:13‑20; Lc. 9:18‑21) 
\p  
\v 27 Ja Jesusi soc ja snebuman jumasa ti stulu ja sbejei. Yabalil ti oj huajuque ja ba yal lugar jumasa ja ba huas sc'ulan mandar ja Filipo, Cesarea sbiil. Cuando bej to aye, ja Jesusi ti sobo yi ja snebuman jumasa: ―Jaxa cristiano ba, ¿mach ayon ja huax yalahuei? xchi.  
\v 28 Ti sac'a jan ja snebuman jumasa: ―Ay ma' huax yalahue que huena bi ja Juan it huax yaa bautismo ajyi. Jaxa tuqui huax yalahue que Eliasa, jaxa tuqui huax yala que huena bi june ja aluman‑Diosi, xchiye.  
\v 29 Jaxa huenlexi, ¿machunquilon huaxa hualahuex ba? Ti yala ja Pedro: ―¡Pero huena ni ja Cristoa tac!  
\v 30 Cuando yab ja Jesús ja jas yala ja Pedro, ti sc'ana yile lec pavor que mi bi ma' oj yale yab ja jastal jahui. 
\s1 Ja Jesusi yala que oj chamuc 
\r (Mt. 16:21‑28; Lc. 9:22‑27) 
\p  
\v 31 Ja Jesusi ti och see yi ja snebuman jumasa. Ja yeni ti bi coel jan ja ba satq'uinali pero oj to bi yii jitzan huocol. ―Ja banquilal jumasa soc ja nihuac pagre jumasa soc ni ja ma' huas seahue ja smandar ja Moisesi mi oj squitz'one, xchi. Oj ni chamcona pero ja huax ec' oxe c'ac'u, ti oj sachuucona, xchi ja Jesusi.  
\v 32 Jel claro juntiro yala jachuc. Ja Pedro ti spaya ja Jesusi. Cuando stuch'ilei, ti yala ja Pedro que mi bi lec huax yala jachuc ja Jesusi.  
\v 33 Pero ja Jesusi ti sutu sbaj ja bay ja tuc snebuman jumasa. Stojtoq'uela lec, ti yal yab ja Pedro: ―Elan ba jtz'eel ja huen diablo. Mi jauc ja Dios huajel ja hua c'ujoli. Quechan cajan ac'ujol ja spensar ja cristiano, xyutaj.  
\v 34 Ja Jesusi ti spaya jan ja cristiano jumasa soc ja snebuman jumasa, ti yalaa: ―Ta ay c'a ma' huas sc'ana ajyuc jmoqui, mi yen mismo oj syajta sbaj. A yaa sbaj juntiro, anima huax aaji locan ja ba cruzi. A stul ja jmodo ja queni.  
\v 35 Spetzanil ja ma' huajel sc'ujol ba quechan oj ajyuc tzamali, huan nix ch'aya sbaja. Pero ja ma' huax yala, ta huala chamyon, ti la chamyona, pero siquiera oj ajyuc lec ja caltzili ‑ ja ma' jach huax yala yuj ja queni ‑ huax yala jachuc yuj ja jas jel tzamal ajc'ach huan yabjeli ‑ pues ja yeni oj ni sta ja svida ba jel lequi.  
\v 36 Ja ma' tey ba sc'ab spetzanil ja jas ay ja ba mundo, pero ta huan c'ax ch'ay ja yaltzili, ¿ja' ma ba slequil ja jau ba?  
\v 37 ¡Mi xa huala que oj bob yaa taq'uin siquiera ba oj ajyuc lec ja yaltzil ja ora jahui!  
\v 38 Ja cristiano, mi huajeluc sc'ujole soc ja Diosi. Otro lado ay juntiro. Mulanume nia. Oj to q'uixhuucon yuj ja yenlei. Ja queni ti coelon jan ja ba satq'uinali pero ja c'ac'u jau oj cho jacon soc ja jTati soc ja cangel jau mi cualquierauqui, oj lijpucon. Ja c'ac'u jahui oj q'uixhuucon juntiro yuj ja smodoe ja cristiano jumasa iti, xchi ja Jesusi. 
\c 9  
\p  
\v 1 Ti cho yala ja Jesusi: ―Huax cala, pero meran, ay chaboxe ti ayex ja ili pero mi oj chamanic masan to oja huilex jastal jel tzamal ja ba huas sc'ulan mandar ja Diosi. Oja huilex que jel juntiro ja yipi, xchi ja Jesusi. 
\s1 Ja Jesusi stucbes sbaj 
\r (Mt. 17:1‑13; Lc. 9:28‑36) 
\p  
\v 2 Cuando ch'ac yal ja jachuqui, ti ec' huaque c'ac'ua. Ja Jesusi ti yal yab ja Pedro soc ja Jacobo soc ja Juani que oj bi huajuque stuch'ile ba jun chaanil huitz. Cuando c'otye ja tihui, ja Jesusi ti stucbes sbaj ba sti sat ja yenlei.  
\v 3 Ja sc'ui ch'ac lijpuc juntiro. Sact'ost'os xta ch'ac huajuc. Ja sacal ja sc'ui mi ni june ma' oj bob chuc'ulanuc ja jastal jahui.  
\v 4 Huaj to cho yile, ti xa ay ja Eliasi soc ja Moisés ja ma' ch'ac ni chamuque ja najatei. Ti xa huane loil soc ja Jesusi.  
\v 5 Ti yala ja Pedro: ―Maestro, ¡jel lec juntiro ja ti ayotic ja ili! Oj c'ulticon oxe yal naitz, june ja hua baji, soc june sbaj ja tat Moisesi soc june sbaj ja tat Eliasi, xchi.  
\v 6 Pero lom huan bulbunuc ja Pedro. Mi huas snaa jasunc'a huan yaljeli. Xihuel xihuel ay. Jach ni ja Jacobo soc ja Juani.  
\v 7 Huaj to yile, jac musjuque yuj ja asoni, jaxa ba yojol ja ason jahui ti yabye jun c'umala: ―Ja iti, ja' ni ja cunini. Jel yaj huax cabi. Maclayic ja jas huax yala, xchi ja c'umali.  
\v 8 Huaj to cho yile, mi xa ma' tey soc ja Jesusi.  
\v 9 Cuando huane xa coel ja ba huitz jahui, ti comjiye yuj ja Jesusi. Mi ni bi ma' oj yale yab ja jas ch'ac yilei. Ja yeni ti bi coel jan ja ba satq'uinali. Oj to bi chamuc pero cuando huas sacui, ti to bi oj yale ja jas ch'ac yile ja ora jahui.  
\v 10 Jach ni sc'ulanea. Ti och sob sbajea: ―¿Jas sbej ja huax yala oj chamuqui y huax yala oj cho sac‑huuc?  
\v 11 Ti sobohue yi ja Jesusi: ―Jaxa matic huas sea ja smandar ja Moisesi huax yalahue que t'ilan bi bajtan oj jacuc ja Eliasi. ¿Jasyuj jach huax yalahue ba? xchi ja yenlei.  
\v 12 Ti yala ja Jesusi: ―Meran nia, bajtan ni oj jac ja Eliasa. Yen oj ch'ac stojbes spetzanil. Jaxa queni, ti ni coelon jan ja ba satq'uinali pero ¿huan ma xa naahuex jas huax yala ja yabal ja Diosi, que oj ni bi quii jitzan huocola? Mi ni bi oj quitzjucona.  
\v 13 Ja mero smeranili, jac ni ja Eliasi, iday, sc'ulan ja sgusto ja cristiano, como jach ni huax yala ja yabal ja Diosa, xchi ja Jesusi. 
\s1 Jun querem ixtalanubal yuj ja pucuji 
\r (Mt. 17:14‑21; Lc. 9:37‑43) 
\p  
\v 14 Ja Jesusi soc ja Pedro soc ja Jacobo soc ja Juani ti c'otye ja bay ja otro snebuman jumasa. Cho tey jun nole cristiano, jaxa matic huas sea ja smandar ja Moisesi, cho ti ni ayea. Jaxa yenlei, huane xta huooljuc c'umal.  
\v 15 Jun ta repente yilahue ja Jesús ja cristiano. Cham yabye. Sac ajnel ch'ac huaj yae yi Dios.  
\v 16 Ti sobo ja Jesusi: ―¿Jasunc'a ja hua loilex ba? xchi ja Jesusi.  
\v 17 Ti sac'a jan june ja yenlei: ―Maestro, ja queni quiaj jan ahui ja cunini. Ixtalanubal juntiro yuj ja pucuji. Mix aaji c'umanuc.  
\v 18 Jun ta repente huas syama ja scuerpo. Huax ya q'uitc'onuc juntiro. Huax puuxani ja stii, jaxa yeji huax ya jechjech'uc. ¡Jel xa ajul ja sbaj juntiro! Jel xa el ta sgana. Jc'ana yi stz'acatal ja hua nebuman jumasa ba oj sc'ul mandar ja tan pucuji ba oj yacta can ja cunini pero mi bob yujile, xchi ja huiniqui.  
\v 19 Ti yala ja Jesusi: ―¡A, ja cristiano iti mi ni t'un huas sc'uane! Ay xa tiempo ti ayex jmoc pero lom nia. ¿Jaye to tiempo oj caa jpasensia amoquex? Ja Jesusi ti yal yab ja huiniqui: ―Caax. Iaj jan qui ja hua huunini.  
\v 20 Ti iiji jan yi ja querem jahui. Jaxa pucuji, cuando yila ja Jesusi, ti cho och ya q'uitc'onuc tzatz lec ja queremi. Ya moc' man luum. Och sc'oc sbaj ja scuerpo. Cho ya puuxanuc ja stii.  
\v 21 Ja Jesusi ti sobo yi ja stat ja querem jahui: ―¿Ay xa ma tiempo jach ay ja hua huunini? ―Desde xch'inil jach huas sc'ulan, xchi ja tatali.  
\v 22 Vuelta huas sipa sbaj c'ac', vuelta huas sipa sbaj ba yoj ja'. Huas sc'ana miljuc. C'ulan quiticon ja pavori. Talna jyaujulalticon, coltayoticon ta huan c'ax bob ahuuj, xchi ja stat ja querem jahui.  
\v 23 Ti yala ja Jesusi: ―¿Huan ma xa c'uan ta oj bob cujil? Ta huan c'a xa c'uan, mi jas mi oj bobuc. Oj ni bobuca, xchi ja Jesusi.  
\v 24 Huan nix c'uana, jaxa janec' mix c'uani, coltayon, xchi ja tatali, pero tzatz lec yala jachuqui.  
\v 25 Ja Jesusi ti yila que huan xta jaquel mas ja cristiano ja ba stz'eeli. Ti sc'ulan mandar ja pucuji: ―¡Diablo ja hueni! Huaxa maca ja sti ja querem iti. Huax hua tupuc ja xchiquini. Ja yaani huax cala huabi, elan ja ba stz'eel ja querem iti. Mi xa ni nunca oj bob ahuixtalauc mas, x'utji.  
\v 26 Jaxa pucuji ahuani tzatz lec. Con gana ya q'uitc'onuc ja queremi. Ti yacta cana. Jaxa ma' ixtalanubal ajyi, ti tup can yic'a. Lajan soc cham cani. Jaxa cristiano yala que cham ta bi.  
\v 27 Pero ja Jesusi ti syama ja sc'abi. Scolta ba oj q'ue culan. Jaxa queremi xachachi xta q'ue tec'an.  
\v 28 Jaxa ch'ac sc'uluc ja jastal jahui, ja Jesusi soc ja snebuman jumasa ti ochye ba jun naitz. Ti sobohue ja snebuman jumasa: ―Jaxa quenticon ba, ¿jastal lec mi sc'uan quiticon ja cabalticon ja tan pucuj jahui? xchiye.  
\v 29 Ti yala ja Jesusi: ―Ja jun tiq'ue jahui, mi c'a xa c'umanex ja Diosi, mi c'a xa como ja hua huaelexi, mi ni nunca oj yacta can ja yixtalajel ja cristiano. 
\s1 Ja Jesusi cho yala jastal oj chamuc 
\r (Mt. 17:22‑23; Lc. 9:43‑45) 
\p  
\v 30 Ja Jesusi soc ja snebuman jumasa ti yaahue can ja lugar jahui. Bejyel huajye ja ba sutanal ja Galilea pero ja Jesusi mi huas sc'ana oj abjuc ba huajumea  
\v 31 Porque ja' huan seejel yi ja snebuman jumasa: ―Ja queni ti coelon jan ja ba satq'uinali pero oj c'ulajucon entregar ja ba sc'ab ja cristiano jumasa ba oj miljucon. Oj ni chamcona pero ja ba yoxil c'ac'u ti oj cho sac‑huucona, xchi.  
\v 32 Pero ja snebuman jumasa, mi ni huax yabye sbeja pero como huax xiuye, jayuj mi ni sobohuea. 
\s1 Ja Jesusi yala machunc'a ja mas nihuani 
\r (Mt. 18:1‑5; Lc. 9:46‑48) 
\p  
\v 33 Ja Jesusi soc ja snebuman jumasa ti c'otye ba Capernaum. Cuando ti xa aye ba yoj snaj ja Jesusi, ti jobji yile yuj ja Jesusi: ―Jel huanex loil ja ba beji. ¿Jasunc'a ja hua loilex ba?  
\v 34 Jaxa snebuman jumasa, ti ch'abaji juntiroa porque ja' huane yaljel mach bi junuca mas nihuan oj huajuquei. Jach ni mero sloilea.  
\v 35 Ja Jesusi ti och culana. Spaya jan ja lajchahuane snebumani. Ti och sob yia: ―¿Jel ama x'oc' ac'ujolex que jel nihuan oj iljanic ba? Pues ta jach c'a huaxa c'anahuex, t'ilan oj ch'inbanic juntiro ja ba sti sat ja hua mojexi, y oj cho ahuateltayex.  
\v 36 Ti spaya jan jun yal querem. Ti yaa ba snalan ja yenlei, ti stelaa:  
\v 37 ―Huan c'a xa yajta ja yal untic ja jastal ja yal querem iti, pero ja c'a yuj ja queni, quena ni huaxa yajtayonexa. Iday, ta quen c'a huaxa yajtayonex, entonces ja ma' secahuon coni, jach ni huaxa yajtayexa. 
\s1 Ja Jesusi yala que mi c'a condra huax ilji, yamigo nia 
\r (Lc. 9:49‑50; Mt. 10:42) 
\p  
\v 38 Ti sac'a jan ja Juani: ―Maestro, pero quilaticon jun huinic: Ja huen pucuj, acta can ja huinic iti, huax cala huab yuj ja sbiil ja Jesusi, pe xchi tac. Pero ja quenticoni jcomoticon porque mi ni jauc ja jmojtica, xchi.  
\v 39 Ti yala ja Jesusi: ―Pero ¿jas sbej ja hua comohuexi? Ta ja' c'a yuj ja queni huas sc'ulan ja milagro, mi xa hualahuex que ta oj bob staon ti' malo.  
\v 40 Mi c'a condra huax yilahuotic, camigotic nia.  
\v 41 Q'uelahuilex. Ja queni Cristoon nia, jaxa huenlexi, ti xa ayex jmoca. Ta ja' c'a yuj ja jbiili, anima jun vaso ja' huax aaji ahuilex, mi lomuc ja jahui. Ay ni jas oj sc'uluque recibir ja ma' ay jas huax yaa huilexi. 
\s1 Mi loiltajneluc ja mulali 
\r (Mt. 18:6‑9; Lc. 17:1‑2) 
\p  
\v 42 Q'uelahuilex ja yal querem iti soc ja smoj yal untiquili ja janec' huas sc'uanonei. Ta ay c'a ma' huax jac som ja spensarei, mas lec a mochjuc jun sc'ab cha' ja ba snuq'ui, a jipjuc ba yoj ja'.  
\v 43 Jach ni ja huenlex chomajquili. Ta ja' c'a hua c'abex huax ya le ja hua mulexi, mas lec, a ch'ay snaajel. Mas lec tunco oj ochanic ja ba vida jau jel tzamali que no que tz'ican ac'abex oj huajanic yoj inpierno ja ba mi ni nunca huax bob tupuc ja sc'ajc'ali  
\v 44 Jaxa yaljai mix chamye. Ja c'ac' ja tihui mi ni nunca huax tupi.  
\v 45 Ta ja' c'a hua huoquex huax ya le ja hua mulexi, mas lec a ch'ay snaajel. Mas lec renco oj ochan ja ba vida jau jel tzamali que no que tz'ican ahuoquex oj huajanic ba yoj inpierno ja ba mi ni nunca huax bob tupuc ja sc'ajc'ali  
\v 46 Jaxa yaljai mix chamye. Ja c'ac' ja tihui mi ni nunca huax tupi.  
\v 47 Ta ja c'a june ja hua sat huax ya le ja hua mulexi, mas lec a ch'ay snaajel. Mas lec quechan june ja hua satex oj ochanic ja ba huas sc'ulan mandar ja Diosi que no que tey xchabil ja hua sat oj huajanic ja ba yoj inpierno ja ba mi ni nunca huax bob tupuc ja sc'ajc'ali  
\v 48 Jaxa yaljai mix chamye. Ja c'ac' ja tihui mi ni nunca huax tupi.  
\v 49 Jayuj jel ni t'ilan juntiro oj iixuc ja huocol ja janec' ti to oj ajyucotic ja ba mundo iti.  
\v 50 Pero tzatz la ajyiyex. Moc alajex ja atz'am it huax pooxi, mi xa nix maconi ja mas tzaani. Pero ja huenlexi, laman la ajyiyex. 
\s1 Ja Jesusi yala que mi sbejuc oj spil sbaj ja ma' nupaneli 
\r (Mt. 19:1‑12; Lc. 16:18) 
\c 10  
\p  
\v 1 Cuando elye ja ba Capernaum, ti huajye ja ba Judea ba c'ax jun lado ja nihuanja ba Jordani. Jaxa cristiano ti stzomo sbaje otro vuelta ja bay ja Jesusi, jaxa Jesusi, como jach ni ja smodoa, ti cho och see yi ja cristiano.  
\v 2 Ti jac ja ba stz'eel chaboxe fariseo jumasa pe quechan ba oj sc'uluque probar ja Jesusi. Ti sobohue yi ta lec c'a oj sip can ja xcheum jun huinic.  
\v 3 Ja Jesusi ti yalaa: ―¿Jasunc'a yala can ja Moisés ba?  
\v 4 ―Ja Moisesi yena ni yala que lec bi oj sip can sbaj soc ja xcheumi pero oj bi ya el suunil, xchiye ja fariseo jumasa.  
\v 5 ―Meran nia, pero ja' yujil jel ch'uuy ja hua c'ujolexi, jayuj jach yala.  
\v 6 Pero cuando ch'ac cujlajuc ja satq'uinali, huinic soc ixuc sc'ulan ja Diosi.  
\v 7 Jayuj jun huinic oj bi yaa can ja snan stati, ja' oj yii ja xcheumi.  
\v 8 Eso sí meran, chahuane ajyi, pero cuando huax nupaniyei, jun ita huax huajyea. Jayuj mi xa ni chahuaneuque toa porque june ita ni ayea.  
\v 9 Jayuj mi sbejuc oja pilex ja jas ya staa sbaj ja Diosi, xchi ja Jesusi.  
\v 10 Cuando ochye ja ba naitzi, ja snebuman jumasa ti cho sobohue yi otro vuelta jastal ay ja jahui.  
\v 11 Jaxa Jesusi ti yalaa: ―Jun huinic, ta huan c'a sipa can ja xcheumi, tuc ja ma' huax yiaji, ja yeni staa ta ni smul soc ja mero xcheuma.  
\v 12 Soc jach ni ja ixuqui. Ta huan c'a sipa can ja statami, tuc statam c'a huax yiaj, jach ni ja yeni, cho staa ta ni smula. 
\s1 Ja Jesusi sc'ulan bendiciar ja yal untiqui 
\r (Mt. 19:13‑15; Lc. 18:15‑17) 
\p  
\v 13 Ja Jesusi ti iiji jan yi jitzan yal untic ba oj yamjuc ja s'olomei. Jaxa snebuman jumasa ti yalahue yab ja matic huan yiijel jani que mi xa bi oj yie jani.  
\v 14 Cuando yab ja Jesús ja jas huane yaljeli, mi sc'ulan gusto, ti yalaa: ―Lec ja huax jac ja yal untiqui. Mi lom xa comohuex. Ja jastal ja sc'ujol ja yal untic iti, jach ni ay ja sc'ujole ja matic yaunej xa ni sbaj ba sc'ab ja Diosi.  
\v 15 Huax cala huabyex, pero meran, mi c'a la ch'inbiyex jastal jun yal untic cuando huaxa huaa bajex ja ba sc'ab ja Diosi, mi ni modo oj bob ochanic soc ja Diosi.  
\v 16 Ja Jesusi ti stela ja yal untiqui. Syama yi ja s'olomei, ti sc'ulan bendiciara. 
\s1 Jun querem rico sc'uman ja Jesusi 
\r (Mt. 19:16‑30; Lc. 18:18‑30) 
\p  
\v 17 Ja Jesusi ti el ja ba naitz jahui. Oj xa stul ja sbeji, huaj to yile, ti huan jaquel jun huinica, pero ajnel ay. Jac tajuc sc'ab. Ja huiniqui ti yalaa: ―Maestro, jel leca juntiro. Ala cab jasunc'a lec oj c'uluc oj quil ja vida jau ba jel lequi.  
\v 18 Ti yala ja Jesusi: ―¿Jasyuj huaxa huala jel leconi? Mi ni june ma' lec, quechan ja Diosi.  
\v 19 ¿Mi ma huaxa naa ja mandar jumasa ja ba huax yala mi oja lea mul soc jun ixuc soc mi ni oj milhuanan? Mi oj elc'anan. Moc lomuc alee mentira. Moca lola ja hua moji. Yajta ja hua nan atati, xchi ja Jesusi.  
\v 20 Ti yala ja huinic jahui: ―Pero jach ni huax c'ulan man jch'inila.  
\v 21 Ja Jesusi ti stojtoq'uelaa. Jel yaj yabi. Ti yalaa: ―Pero ay to jas huas sc'ulan ahui palta. Cax chono can spetzanil ja jastic ahuioji. Aa yi ja pobre jumasa. Jach c'a huaxa c'ulan, jel ja jas oj aajuc ahui ja ba satq'uinali. Pero caax. Cax c'ulan jachuc, ti la jac jmoca. C'uanon anima huala aaji locan ja ba cruzi, xchi ja Jesusi.  
\v 22 Pero ja huiniqui, cuando yab ja jas ch'ac aljuc yabi, cham yabi. Tristeaxi juntiro porque jel ja jastic sbaji.  
\v 23 Ja Jesusi ti sq'uela ja snebuman jumasa, ti yalaa: ―Ja ma' jel ja jastic sbaji, jel huocol juntiro oj yaa sbaj ja ba sc'ab ja Diosi.  
\v 24 Cuando yabye ja jas yala ja Jesusi, cham yabye ja snebuman jumasa. Ti cho yala ja Jesusi: ―Cuntiquil, ja ma' huajel sc'ujol soc ja sastic sbaji, jel huocol juntiro huas sipa sc'ujol soc ja Diosi.  
\v 25 Mas mi huocoluc oj ec' jun camello ja ba sotol ja tz'istaq'uini que soc oj yaa sbaj ba sc'ab ja Dios jun rico, xchi ja Jesusi.  
\v 26 ―Ta jel c'a huocol oj sc'uuc ja Dios ja ma' ay staq'uini, ¿machunc'a oj bob coltajuc ba? Jach sobo ja snebuman jumasa porque cham yabye juntiro ja jas yala ja Jesusi.  
\v 27 Ja Jesusi ti stojtoq'uela otro vuelta: ―Ja cristiano, mi ni oj bob yujila pero ja Diosi, oj ni bob yujila. Ja Diosi huax bob yuj spetzanil, xchi.  
\v 28 Ja Pedro ti yalaa: ―Entonces ¿jaxa quenticon ba, Cajual? Caunejticon can spetzanil ja jastic quiojticoni ba oj ajyucoticon amoc, xchi.  
\v 29 Ti yala ja Jesusi: ―Pues oj cala huabyex ja smeranili. Spetzanil ja ma' yaunej can ja snaji, ma ja yermano jumasa, ma ja yermana jumasa, ma ja snan stati, ma ja xcheumi, ma ja yuntiquili, ma ja slugari, mi ni lomuca. Ta ja c'a yuj ja queni, ma ja' yujil ja abal it jel tzamali, mi ni lomuca.  
\v 30 Oj ni sc'ul recibir cien tanto mas ja tiempo iti. Oj sc'ul recibir cien tanto ja snaji soc ja yermano jumasa, soc ja yermana jumasa, soc ja snan stati, soc ja yuntiquili, soc ja slugari, pero oj ni yie ja huocola. Pero ja ba otro vida oj yil ja vida jau ba mi ni nunca oj ch'acuqui.  
\v 31 Pero jitzan ja ma' huax ilji nihuan ja huego, jel ch'in oj huajuque ja tihui, jaxa matic jel ch'in huax ilji ja huego, ay modo jel nihuan oj huajuque ja ora jahui. 
\s1 Ja Jesusi cho yala otro vuelta jastal oj chamuc 
\r (Mt. 20:17‑19; Lc. 18:31‑34) 
\p  
\v 32 Ja Jesusi soc ja snebuman jumasa soc jun nole cristiano ti huane huajel ja ba Jerusaleni. Yen bajtan ay ja Jesusi. Ti nochan ja snebuman jumasa pero xihuel xihuel aye. Jel ja spensarei. Ja Jesusi ti ch'ac spay ja ba stz'eel ja snebuman jumasa. Och yal yabye jastal oj to c'ulajuc yi:  
\v 33 ―Q'uelahuilex. Ti xa huajumotic ja ba Jerusaleni. Ja queni ti ni coelon jan ja ba sat'quinali pero anima, oj ni c'ulajucon endregal ba sc'ab ja nihuac pagre soc ja ma' huas sea ja smandar ja Moisesi. Huane xa ni xchapjel cabalila. Oj ni sc'ulucone endregal ja ba sc'ab ja ma' mi sc'uan ja Diosi.  
\v 34 Oj yaahue qui burla. Oj smac'one. Oj tzujbayone. Oj smilone pero x'ec' oxe c'ac'u, oj cho sac‑huucon, xchi ja Jesusi. 
\s1 Ja Jacobo soc ja Juani sc'ana yi pavor ja Jesusi 
\r (Mt. 20:20‑28) 
\p  
\v 35 Ti jac ba stz'eel ja Jesús ja Jacobo soc ja Juani, ja' yuntiquil ja Zebedeo. Ti yalahuea: ―Maestro, ay jas oj c'anticon ahui. C'ulan quiticon ja pavori.  
\v 36 ―¿Jasunc'a huaxa c'ana oj c'uluc ahuilex ba? xchi ja Jesusi.  
\v 37 ―Pues, oj c'anticon ahui pavor, cuando ti xa aytic ja ba jel tzamal huana sc'ulajel mandari, oja huaa quiticon ja catelticon ba mas tzatzi, xchiye.  
\v 38 Ti yala ja Jesusi: ―Pero mi xa naahuex jasunc'a huanex sc'anjeli. Ja queni oj ni quii ja huocola. ¿Oj ma bob ahuiex huocol ja huenlex ba? Jel ja jas oj c'ul ahuantar, ¿jaxa huenlex ba? ¿Oj ma bob ac'uluquex ahuantar?  
\v 39 ―Pues ojo, xchiye. Ti yala ja Jesusi: ―Pues meran nia, ja jastal oj quii ja huocoli, jach ni oj cho huiex ja huenlex chomajquili. Ja jastal oj c'ul ahuantar ja queni, jach ni oj cho ac'uluquex ahuantar ja huenlex chomajquili.  
\v 40 Pero ba oj caa huilex ja atel ba mas tzatzi, mi ni sbajuc oj caa huilexa. Tzaubal ni ja ma' oj aajuc yii.  
\v 41 Jaxa lajunhuane ja snebumani, cuando ch'ac yabye ja iti, jel q'ue ja scorajae soc ja Jacobo soc ja Juani.  
\v 42 Ja Jesusi ti spaya jan ja otro snebuman jumasa, ti yalaa: ―Ja ba spetzanil ja lugar jumasa, ja ma' ay yateli, jel nihuan huax yaa sbaje. Jel tzatz ja smandarei.  
\v 43 Pero ja huenlexi, mi jachucuc oja c'uluquex. Ta huan c'a xa c'ana nihuan oj ajyanic, sbej ni oj ch'inbanica ba oja huateltayex ja tuqui.  
\v 44 Ta huan c'a xa c'ana nihuan oj ajyan ja ba sti sat ja Diosi, sbej ni ch'in oja jee abajex ja ba sti sat ja hua mojexi.  
\v 45 Ja queni, ti ni coelon jan ja ba satq'uinali pero mi jaquelucon ba oj ateltajucon. Jaquelon ba oj catelta ja cristiano soc oj caa ja jvida ba oj huajuc libre jitzan ja yenlei. 
\s1 Ja Jesusi ya tojbuc ja Bartimeo ja ma' tupel ja sat ajyi 
\r (Mt. 20:29‑34; Lc. 18:35‑43) 
\p  
\v 46 Ti c'otye ja ba jun chonab, Jericó sbiil. Ja Jesusi soc ja snebuman jumasa ti cho smoje jun nole cristiano. Cuando elye ja ba chonab Jericó, huaj to yile, ti culan ec' jun huinic ba sti bej, jaxa huinic jahui, Bartimeo sbiil, pero tupel ja sati. Ja' stat ja Timeo. Jaxa Bartimeo huan sc'anjel limosna.  
\v 47 Ti yab que ja' huan eq'uel ja Jesús ja tihui, jayuj ti ahuania: ―¡Jesús, ja hueni, ja' ni ja yintila rey David tac! Talna jyaujulal, xchi xta, pero ahuanel.  
\v 48 Ti comji yuj jitzan cristiano pero lajan soc alji yab ba oj ahuanuc mas tzatz: ―¡Ja huen yintila rey Davidi, talna jyaujulal! xchi xta ja Bartimeo.  
\v 49 Ti c'ot tec'an ja Jesusi, ti yalaa: ―A jacuc ja huinic jahui, xchi ja Jesusi. Ti huaj aljuc yab ja ma' tupel ja sati: ―Mix cham ac'ujol. Q'uean xa. Cax bi oche, xyutaj.  
\v 50 Ja Bartimeo ti sipa can ja scotoni. Q'uei. Ti huaj ja ba stz'eel ja Jesusi.  
\v 51 ―¿Jasunc'a huaxa c'ana oj c'uluc ahui? xchi ja Jesusi. ―Maestro, huax c'ana oj quil q'uinal, xchi ja ma' tupel ja sati.  
\v 52 ―Huan ni xa c'uan merana. Caax xa, x'utji. Iday, huego huego yila q'uinal ja Bartimeo. Ti huaj nochan soc ja Jesusi. 
\s1 Ja jastal och c'ot ba Jerusalén ja Jesusi 
\r (Mt. 21:1‑11; Lc. 19:28‑40; Jn. 12:12‑19) 
\c 11  
\p  
\v 1 Ja Jesusi soc ja snebuman jumasa soc jun nole lec ja cristiano mojan xa yioje ja Jerusaleni. Ti xa aye ba jun huitz Olivos sbiil, jaxa tihui ay chab yal hacienda, Betfagé soc Betania. Ja Jesusi ti yal yab chahuane ja snebumani:  
\v 2 ―Q'uelahuilex ja yal hacienda jau mojan xa quiojtiqui. Caxic ja huenlexi. Ja ba sti ja hacienda ti oja taex jun yal burro mochante. Mi to ni ma' huax q'uea. Tucuhuic. Iajic jani.  
\v 3 Ta ay c'a ma' huas sobo huilex jasyujil huaxa tucuhuexi, ti xa hualahuex yabi que ja' oj maconuc yuj ja Cajualtiqui, oj bi ya cumxuc jan huego, utajic, xchi ja Jesusi.  
\v 4 Ti huajye ja chahuane snebuman jahui. Ti ni staahue ja yal burro ti mochan ba sti ja puerta ja ba huas spila sbaj ja beji. Ti xa stucuhuea.  
\v 5 Ti yilahue chaboxe ja ma' tey tihui. Ti yalahuea: ―¿Jas sbej ja huaxa tucuhuex ja yal burro jau ba?  
\v 6 Jaxa jecabanum jahui ti yalahue ja jas alji yabye yuj ja Jesusi. ―Entonces ta jachuc, lec, iajic, x'utjiye.  
\v 7 Ti yiaje och ja yal burro ja bay ja Jesusi. Ti yaahue bacan ja sc'uei, jaxa Jesusi, ti q'uea.  
\v 8 Jaxa cristiano, jel ja ma' ch'ac slich'e ja sc'ue ja ba yoj beji. Soc ay ma' sc'utzu ja spoohuil ja tei, ti xcholohue ja ba beji.  
\v 9 Jitzan ja cristiano bajtan ba sti sat ja Jesusi soc jitzan lec ja ma' tzaan ba spatiqui. Ti yalahuea: ―¡Viva! ¡Stz'acatal lec ja ma' jac yuj ja sbiil ja Cajualtiqui!  
\v 10 Oj ni och sc'ul mandar june ja yintil ja rey Davidi, como quintiltic nia. ¡Stz'acatal huax c'anatic yi! ¡Viva ja ma' tey ba satq'uinali! xchiye xta ja cristiano, pero ahuanel huane.  
\v 11 Ti xa huane ochel ja ba yoj chonab ba Jerusalén. Ti c'otye ja ba templo, jaxa Jesusi ti ch'ac sq'uel ec' spetzanil ja ba yojol ja templo. Jaxa cuando oj xa ochuc ja acuali, ti xa cumxi ba Betania soc ja lajchahuane ja snebumani. 
\s1 Ja Jesusi, ja jastal yala que mi oj ajyuc ja sat ja higo 
\r (Mt. 21:18‑19) 
\p  
\v 12 Ti canye jun acual ja ba Betania, jaxa el ja c'ac'u, ti cho stulu ja sbeja. Ti to ay ba nalan bej ja Jesusi cuando och huain xyabi.  
\v 13 Ti yila najat jun steil higo. Ay xa lec spoohuil. Ti huaj c'ubana ba oj yil ta ay sat pero cuando c'uban xa ayi, huaj to yile, mi ni jun sat ay. Jel xa ja spoohuili pero mi to ayuc ja sati como mi to ni stiempouca ja higo.  
\v 14 Ja Jesusi ti yal yab ja steil ja higo jahui: ―Mi ni nunca oja huaa sat ja hueni, xchi. Jaxa snebuman jumasa ti yabye ja jas yal yab ja steil ja higo jahui. 
\s1 Ja Jesusi snutzu el ja ma' ay jas huane sc'ulajel ja ba templo 
\r (Mt. 21:12‑17; Lc. 19:45‑48; Jn. 2:13‑22) 
\p  
\v 15 Ja Jesusi soc ja snebuman jumasa ti c'otye ba Jerusalén, jaxa Jesusi ti och ja ba templo. Ti snutzu el ja ma' huane xchonjel cosa ja ba yojol ja templo soc ja ma' huane smanjeli, jaxa ma' huan sc'ulajel cambiar taq'uini, suichpun el ja smesaei. Jachuc ja ma' huane xchonjel paloma, ch'ac sutbuc el ja sillaei.  
\v 16 Spetzanil ja matic huan scuchjel ja sastic sbajei, mi huax yaa licensia oj ec'uque ja ba spatioil ja temploi.  
\v 17 Ti och yal ja jas huax yala ja yabal ja Diosi. Ja templo ja' ni ba oj maconuc yuj spetzanil ja cristiano ba oj sc'umuque ja Diosi. ―¿Mi ma jach ni huax yala ja suun ja Dios ba? Pero ja huenlexi huaahuex ta pax snaj lagronil, xchi ja Jesusi.  
\v 18 Jaxa ma' huas sea ja smandar ja Moisesi soc ja nihuac pagre jumasa ti huane smaclajela. Juntiro ch'ac xihuuque yuj ja Jesusi porque spetzanil ja cristiano jel huas sc'ulane gusto ja jas huan yaljeli, jaxa yenlei ti och xchape yabalila.  
\v 19 Jaxa Jesusi, cuando och ja acuali, ti xa el ja chonab jahui. 
\s1 Tacji ja steil ja higo 
\r (Mt. 21:20‑22) 
\p  
\v 20 Jaxa el ja c'ac'u, huaj to yile ja snebuman jumasa, taquin xa juntiro ja steil ja higo, pero man yech.  
\v 21 Ti jul sc'ujol ja Pedro: ―Q'uelahuil Maestro, ja jastal ahual yab ja steil ja higo, meran nia. ¡Taquin xa ni juntiro taca!  
\v 22 Ti yala ja Jesusi: ―C'uanic ja Diosi.  
\v 23 Q'uelahuilex ja huitz iti. Huan c'a xa hualahuex yab oj stucbes ja slugari, huan c'a xa hualahuex yab oj sip sbaj ba yoj ja', oj ni bobuca. Pero mi oj c'umanuc ja hua c'ujolexi. Oja c'uuquex que oj ni c'otuc ja jas huaxa hualahuexi. Huax cala huabyex, pero meran.  
\v 24 Cuando huaxa c'umanex ja Diosi, c'uanic que oj aajuc ahuilex spetzanil ja jas huaxa c'anahuex yi ja Diosi y oj ni ahuilex sata.  
\v 25 Cuando huanex sc'umajel ja Diosi, ta ay c'a ma' timan ahuabalex soc, c'ulanic perdonar. Jachuc, ja hua Tatex tey ba satq'uinali oj sc'ul perdonar ja hua mulex ja huenlexi.  
\v 26 Pero ta mi c'a xa c'ulan perdonar ja hua moji, jach ni ja hua Tatex tey ba satq'uinali, mi ni oj sc'uluquex perdonar ja huenlex chomajquili, xchi ja Jesusi. 
\s1 Ja Jesusi jobji yi ma' ac'uni ja yateli 
\r (Mt. 21:23‑27; Lc. 20:1‑8) 
\p  
\v 27 Ti cho huajye otro vuelta ja ba Jerusaleni. Ja Jesusi ti och ja ba templo, jaxa nihuac spagreil ja judio soc ja matic huas sea ja smandar ja Moisesi soc ja banquilal jumasa ti huajye ja ba huan bejyel ec' ja Jesusi.  
\v 28 Ti yalahuea: ―¿Yuj ama ay ahuatel ja huen huaxa c'ulan ja cosa jumasa iti? Entonces, ¿ma' yaa hui ja hua huatel ba? xyutaje.  
\v 29 ―Jachuc ja queni, ay jas huax c'ana oj job ahuilex. Ta huan c'a xa hualahuex cabi, entonces oj cala huabyex ma' yaa qui oj c'uluc ja cosa jumasa iti.  
\v 30 Ja Juani, ¿machunc'a yala oj sc'ul bautizar ja cristiano? ¿Ja' ma alji yab yuj ja ma' tey ba satq'uinali ma ja' alji yab yuj ja cristiano? Alahuic cab ba, xchi ja Jesusi.  
\v 31 Jaxa yenlei ti ochye loil yenle itaa: ―Huan c'ax calatic ja ma' tey ba satq'uinali, entonces oj yal cabtic: Entonces ¿jaxa yuj ja mi xa c'uanex ba? oj yutotic.  
\v 32 Iday, ta huan c'ax cho calatic que ja' sbaj cristiano … mi snaa jas oj yale porque xihuel xihuel aye yuj ja cristiano porque ja cristiano toyobal yujile ja Juani que mero aluman‑Dios bi.  
\v 33 Ti yalahue yab ja Jesusi: ―Mix naaticon, xchiye. ―Entonces jachuc ja queni, mi oj cala huabyex ma' yaa qui ja cateli, xchi ja Jesusi. 
\s1 Ja loil sbaj ja tantic malo atjumi 
\r (Mt. 21:33‑46; Lc. 20:9‑19) 
\c 12  
\p  
\v 1 Ja Jesusi ti och yal yab ja cristiano pero soc jun loil: ―Ay jun huinic, jaxa yeni stz'unu jun yalajil tz'usub. Smacba. Sboyo jun sq'uejnal ja strapichi. Ya q'ue jun sluchayub ba huax q'ue yil ja yalaji. Cuando ch'ac sc'uluc ja jachuqui, ti sc'ulan trato soc chaboxe ja ma' oj yil can ja yatel ja yalaji, jaxa yeni ti huaj najata.  
\v 2 Ti sc'ulan tantear ja tiempo. Ti seca jun smozo ba oj yii jan ja sbaal ja yalaji.  
\v 3 Cuando c'ot ja mozo jahui, ti yamji yuj ja matic canel ba sc'ab ja ateli. Smac'ahue. Telan sc'ab yaahue huajuc.  
\v 4 Jaxa suinquil ja yalajil tz'usubi ti cho seca otro ja smozo pero iday, yajni yilahue, ti och xch'oje tona. Yaahue yajbuc ja s'olomi. Xihuel ja sbaj ja jas sc'ulane yii.  
\v 5 Jaxa suinquil ja alaji otro vuelta cho seca june ja smozo, jaxa mozo jahui, smilahue. Jel ja ma' seca pero ¡malaya, ay ma' puro golpe yaahue yi, jaxa tuc jumasa, smilahue!  
\v 6 Pero ja suinquil ja yalajil tz'usubi, ay to ni yioj junea, ja' ni ja yunini. Jel yaj huax yabi. Ti yal yaba: ―Ja huego, cax ja hueni. Oj sc'uluca respetar porque mero cunina, xyutaj.  
\v 7 Pero cuando c'ot ja yunini, ti yalahue yenle itaa: ―Ja iti, ja' ni ja ma' oj yii can ja dote. ¿Jaxa mix milatiqui? Ta cham c'a, quen oj bajuctic can ja sdotea, xchiye.  
\v 8 Ti syamahuea. Smilahue. Ti yiaje el ba spat alaj.  
\v 9 Cuando ch'ac ja loil jahui, ti sobo ja Jesusi: ―Jaxa huenlexi, ¿jas la chiyex? Cuando huax cumxi ja suinquil ja alaj jahui, ¿mi ma oj xch'ay snaajel ja tantic huinique jahui, tuc ja ma' oj yaa ba sc'abi?  
\v 10 ¿Yuj ama mi huaxa q'uelahuex ja juun ja jastal huas staahuon ti' ba? Huax yala que quena ni ja oy it jel tzamal tac. Pero q'uelahuilex: 
\q1 Ay jun oy ba jel tzamali pero ja c'ulanaitzi mi squitz'ahue, iday, jaxa oy jau mi squitz'ahuei, ja' mero oj yaa mas yip ja naitzi. 
\q1  
\v 11 Ja Cajualtic Diosi, yena ni sc'ulan ja iti. Jel tzamal juntiro huax cabticon, 
\m xchi ja yabal ja Dios tac, xchi ja Jesusi.  
\v 12 Pero ja loil it yala ja Jesusi, huego jac sc'ujole que yenle ja huax tajiye tii. Jayuj huas sc'anahue oj syame pero mi bob yujile porque huax xiuye yuj ja cristiano jumasa. Ti yaahue cana. Huajye. 
\s1 Ja Jesusi jobji yi ta sbej oj yae ja contribucioni 
\r (Mt. 22:15‑22; Lc. 20:20‑26) 
\p  
\v 13 Ja mas tzaani ti huajye chaboxe fariseo jumasa soc chaboxe yamigo ja Herodesi. Ti huajye ja bay ja Jesusi, pero jecubal huajye. Bob ta ay bi jas oj el sti.  
\v 14 Cuando c'otye ja bay ja Jesusi, ti yiaje loila: ―Maestro, huax naaticon que ja jas huaxa huala ja hueni, que meran. Mi ni huala xiu yuj ja cristiano tac. Mi huanuca sleejel oj iljan lec pero ja' huaxa jea ja sbej ja Diosi, pero puro smeranil. Jac jobticon ahui, ¿lec ama oj caatic yi contribución ja gobierno César ma miyuc? ¿Jas la chi ba? ¿Oj ma caatic yi ma miyuc? xchiye.  
\v 15 Jaxa Jesusi huego snaa que xchabil lado aye. Ti yalaa: ―¿Yuj ama oja c'uluconex probar ba? Lec ay. Jeahuic qui ja taq'uini. Oj q'uele.  
\v 16 Ti seahue yi ja taq'uini. Ti sobo ja Jesusi: ―Jaxa olomal jahui, ¿ma' sbaj ba? Jaxa sletraili, ¿ma' sbiil ba? ―Ja' sbaj Cesari, xchiye.  
\v 17 ―Entonces ta ja c'a ba Cesari, aahuic yi ja César ja ba sbaji, jaxa jas sbaj ja Diosi, aahuic yi, x'utjiye yuj ja Jesusi. Jaxa yenlei smaca juntiro ja stiei. 
\s1 Ja Jesusi yala jastal huax aaji sac‑huuc ja cristiano 
\r (Mt. 22:23‑33; Lc. 20:27‑40) 
\p  
\v 18 Jaxa jun c'ole cristiano jumasa, saduceo sbiile, ti huajye ja bay ja Jesusi. Ja yenlei mi huas sc'uane ta huas sacui ja ma' huax chami. Ti yalahuea:  
\v 19 ―Maestro, ja Moisesi yala can ta huan c'ax cham jun banquilal y huax yaa can ja xcheumi pero mey yuntiquile, entonces oj bi iijuc ja xcheum ja chamhuiniqui yuj ja yijtz'in ja ma' nochan soqui, jaxa yuntiquil ja yenlei que oj bi bob aljuc que ja' bi yuntiquil ja chamhuinic banquilali.  
\v 20 ¿Jaxa ta lec ay jucuane yermano sbaje ba? Ja banquilali huax nupani pero huax chami. Mi ni jun yuntiquil huax cani.  
\v 21 Jaxa xcheum ja banquilal jahui, jaxa ta lec ja' tax cho iiji yuj ja yijtz'in nochan soc ja statam ajyi y ta huan c'a cho xcham ja yen chomajquili, y mi ni ja yeni, mix yaa can yuntiquil … ja lec jach cho sc'ulan ja ba yoxil ijtz'inali …  
\v 22 ¿Jaxa ta lec jach xch'ac ec'uque sucuanile ba? ¡Y ta mi ni c'a jun yuntiquil huax can spetzanile! Ja lec ti xa huax cho cham ja ixuc jahui,  
\v 23 Jaxa ba otro lado, cuando oj sac‑huuc ja scuerpoei, ¿machunc'a mero oj yii ja ixuc jau ba? porque spetzanile xcheumane ja ba luumi, xchi ja saduceo jumasa.  
\v 24 Ti yala ja Jesusi: ―Ja spetzanilex mi ni jas huaxa naahuex t'usana. Mi ni t'un huaxa huabyex sbej ja slibro ja Diosi, mi ni huaxa c'uanex ja jastal ja yipi.  
\v 25 Porque cuando oj sac‑huuc ja scuerpo ja ma' huax chamyei, mi xa oj to ajyuc nupanel. Mi xa oj to aajuc nupanuque. Ja tihui mi xa ma' oj yii sbaje. Oj ajyuque jastal ja ángel jumasa ja ba satq'uinali.  
\v 26 Jaxa ma' huax chamyei, oj ni sac‑huuquea. Bob ta mey xa q'uelahuex ja slibro ja Moisesi. Ja Diosi, cuando ti c'umani ba yoj q'uiixi, ti yal yab ja Moisesi: 
\q1 Ja queni sDioson ni ja Abrahami, sDioson ja Isaqui, sDioson ja Jacobi, 
\m jach bi alji yab ja Moisesi, iday, ja ora jahui, mi xa ni huaanuc to ch'ac chamuque ja oxhuane jahua.  
\v 27 Jach yala porque ja oxhuane huinique jahui ti ni aye soc ja Diosi. Ja ba sti sat ja Diosi mi ni ma' huax cham juntiro. Mi ni jas huaxa naahuex t'usana, xchi ja Jesusi. 
\s1 Ja mandar mas nihuani 
\r (Mt. 22:34‑40) 
\p  
\v 28 Ti jac c'uban june ja ma' huas sea ja smandar ja Moisesi. Yab sloile soc ja saduceo jumasa. Huas snaa que jel lec ja jastal sutji yile ja sloil ja saduceo jumasa. Ti sobo ja huinic jahua: ―Ja ba spetzanil ja mandar jumasa ¿bay ja mas t'ilan ba?  
\v 29 Ti yala ja Jesusi: ―Ja mandar ja ba mas t'ilani huax yala jachuc: Israeleño jumasa abyic. Ja Cajualtic Diosi, quechan ni june ja Cajualtica.  
\v 30 Yaj oja huab ja Huajual Diosi soc spetzanil ja hua c'ujoli soc spetzanil ja hua hualtzili, soc spetzanil ja hua pensari, soc spetzanil ja hua huipi. Ja jahui, ja' ni ja mandar mas t'ilani.  
\v 31 Soc ay otro mandar oj slaj ja iti: Ja jastal huaxa yajta baj ja huen mismo, jach oja yajta ja hua moji. Mey otro mandar oj slaj ja jastal ja chab mandar jahui, xchi ja Jesusi.  
\v 32 ―Meran Maestro, meran ja jas huaxa huala. Quechan june ja Diosi, mey otro.  
\v 33 Mas ni t'ilan ja mandar ba oj yajtatic soc spetzanil ja jc'ujoltiqui, soc spetzanil ja jpensartiqui, soc spetzanil ja caltziltiqui, soc spetzanil ja quiptiqui. Soc oj ni yajtatic ja jmojtic ja jastal huax yajta jbajtiqui. Mas jel t'ilan juntiro oj c'ultic jachuc que oj quiitic jan chante ba oj tzicxuc ja ba sti sat ja Diosi, xchi ja huiniqui.  
\v 34 Ja Jesusi, cuando yab que jel lec ja jas yala ja huiniqui, ti yal yaba: ―Ja hueni, jel t'usan sc'ana oja jip ac'ujol soc ja Diosi ba oja huaa baj ja ba smandari, x'utji. Jaxa cristiano ti ch'ac canuque jac'ana. Mi xa ni june ma' huax yaa sbaj jas oj sob yi ja Jesusi. 
\s1 Ja Jesusi sobo yi ja cristiano ma' yintil ja Cristo 
\r (Mt. 22:41‑46; Lc. 20:41‑44) 
\p  
\v 35 Ja Jesusi ti huaj see ba templo, ti yalaa: ―Ja ma' huas seahue ja smandar ja Moisesi huax yalahue que cuando oj bi manxuc ja Cristo, ti bi oj jac manxuc ja ba yintil ja rey Davidi.  
\v 36 Pero ja rey Davidi, julbesnubal yuj ja Espíritu Santo yala jachuc: 
\q1 Ja Dios Tatali ti yal yab ja Cajual Cristoi: Quechan ja huen oj ajyuc ja huatel mas tzatz. Oj caa ba yib ac'ab ja hua condra jumasa, x'utji. 
\m  
\v 37 Ja huabyex que yajualan ja Cristo ja Davidi, iday, yena ni yintila pero mi to nix manxi ja Cristo tac. Jaxa ma' huas sea ja smandar ja Moisesi huax yala que ja Cristo oj to manxuqui, ja' ni bi ja yintil ja rey Davidi, iday, huan xax yajualan. ¿Jastal ay ja it ba? xchi ja Jesusi. Jaxa cristiano jel juntiro ja ma' jel sgusto huax yabye ja jas huax yalai.  
\v 38 Ay to mas ja jas yala ja Jesusi cuando huan seejel yi ja cristiano: ―Ja yenle ja ma' huas seahue ja smandar ja Moisesi ja' sgustoe huan xta huecheljuc ec' soc ja snajtil sc'uei soc ja' mero sgustoe oj jac tajuc sc'abe ja ba plaza.  
\v 39 Jaxa ba yiglesiaei huan ita sq'uelahue ja lugar ba huax och culan ja ma' ay yateli. Jach ni ja huax huajye ba jun huaelal, ja' mero huas sleahue ja lugar ba mas tzamali.  
\v 40 Pero iday, ja viguda jumasa, huas sapahue yi ja snajei. Albel lec huax och sc'umuque ja Diosi ja' ba lec oj iljuque. ¡A smajlaye! Ja it jumasa oj ni yii ja castigo ba mas tzatzi, xchi ja Jesusi. 
\s1 Ja jastal yaa slimosna jun viguda pobre 
\r (Lc. 21:1‑4) 
\p  
\v 41 Ja Jesusi ti och culan ja ba mojan ja cajón ja ba huax yaahue can ja slimosna ja cristiano. Yila que huax yaa can jitzan taq'uin ja rico jumasa.  
\v 42 Ti jac jun viguda jel pobre, jaxa yeni ti yaa can chab yal sat taq'uin.  
\v 43 Ja Jesusi ti spaya jan ja snebuman jumasa: ―Q'uelahuilex ja viguda jahui. Pero ja mero smeranili, mas jel yaa can ja yen ja ba yoj cajoni que yuj spetzanil ja tuc jumasa.  
\v 44 Ja yenlei quechan ja ba sobraei huax yaahue cani pero ja viguda iti, pobre juntiro. Yaunej spetzanil ja janec' yioji. Mi ni jas huax can sobra yujil, xchi ja Jesusi. 
\s1 Ja Jesusi yala jastal oj jemjuc ja templo 
\r (Mt. 24:1‑2; Lc. 21:5‑6) 
\c 13  
\p  
\v 1 Cuando elye ja ba templo, june ja snebuman jumasa ti yal yab ja Jesusi: ―Maestro, q'uelahuil ja snajtzil jumasa ja templo. ¡Jel tzamal juntiro ja stojnali! xchi.  
\v 2 ―Meran nia. Jel nihuan juntiro ja naitz jumasa pero iday, mi ni jun ton oj can latzana. Polvo oj ch'ac huajuc spetzanil, xchi ja Jesusi. 
\s1 Ja jas oj ilxuc cuando oj xa jacuc ja Cajualtiqui 
\r (Mt. 24:3‑28; Lc. 21:7‑24; 17:22‑24) 
\p  
\v 3 Ja Jesusi soc ja snebuman jumasa ti huajye ja ba huitz Olivos, jaxa tihui, ti och culan ja ba spunto ja templo ja Jesusi. Jaxa Pedro soc ja Jacobo soc ja Juani soc ja Andresi ti jac ba stz'eel ja Jesusi.  
\v 4 Ti sobohuea: ―Pero Maestro, huaxa huala mi oj can latzan ja stojnal ja templo. Ala cabticon jas ora jach oj ec'uc ba. ¿Oj ma naaticon jas ora oj ec'uc ja it ba? ¿Oj ma ajyuc seña ba?  
\v 5 Ti yala ja Jesusi: ―Moca huaa bajex ba oj lolajananic.  
\v 6 Porque cuando mojan ja tiempo jahui jel ja ma' oj yii ja jbiili: Ja queni Cristoon nia. Stzaunejon ja Diosi, oj chiuque. Oj slolaye jitzan lec ja cristiano.  
\v 7 Oja huabyex yabalil ja guerra. Ja' mero oj sloiltaye ja guerra ja cristiano pero moc lom chamuc ac'ujolex. T'ilan ni oj c'ot smeranil ja jastal ita. Pero ja jahui, mi to jauc ja mero oj c'ot tic'an ja tiempo.  
\v 8 Ja lugar jumasa puro coraja oj yil sbaje. Ja gobierno jumasa oj ochuque pleito. Oj ajyuc templor ba jitzan lugar. Jel oj ajyuc ja huaini. Oj jomuc juntiro ja mundo pero spetzanil, cuando huas staa ja jastal iti, yuj ni huan tox och q'ueuc. Mi to jauc ja mero.  
\v 9 Pero aa cuidadoex porque oj soquex parte ja ba sat ja ma' ay yateli, jaxa ba yoj yiglesiaei oj yaa huilex golpe. Oj ya huajanic ba sti sat ja gobierno jumasa soc ja rey jumasa pero ja' yujil ja huaxa loiltayonex eq'ue, pero anima, oj ni cho yabye ja yenle chomajquila.  
\v 10 Ja mi tox c'ot tic'an ja tiempo, jel ni t'ilan oj loiltaxuc ba spetzanil ja lugar jumasa ja abal it jel tzamali.  
\v 11 Pero cuando huax yiajex ja ba sat ja ma' ay yateli, mix cham ac'ujolex ja jas oja hualexi. Mi t'ilanuc oja c'uluquex pensar ja jas oja hualex ja ora jahui porque ja mero ora oj aajuc jac ac'ujolex ja jas oja hualexi. Ja' oja hualex. Mi ni ahuenuquex oj c'umananica ja ora jahui, ja' ni ja Espíritu Santo.  
\v 12 Jun huinic, ja mero yermano oj sc'ul endregal ba oj chamuc. Jach ni jun tatal, oj sc'ul endregal ja yunini. Jaxa jun nanal tatali, condra oj iljuque yuj ja yuntiquilei. Oj smile can ja snan statei.  
\v 13 Quechan yuj ja huiojex ja jbiili jel coraja oj iljanic yuj spetzanil ja cristiano. Pero ja ma' oj cuch yujil ja huocol iti hasta man xc'ot tic'an ja tiempo jahui, oj ni coltajuque ja yenlea.  
\v 14 Ja ma' huas sq'uela ja juun iti, a yab sbej. A sna que ja cuando huaxa huilahuex ja cosa jau jel quistal juntiro tey ba lugar jau ba mi sbejuc ti oj ajyuqui, entonces ja suinquil ja Judea, mas lec aa xa spaque ajnel ja ba huitzi porque ti xa ay ja huocol ba jel tzatzi. Ja yen ja aluman‑Dios Danieli yen ch'ac yal can ja jastal iti.  
\v 15 Ja ora jahui, ta ay c'a ma' tey ba xchabil lame ja naitzi, toj eq'uel a huajuc cuando huax coi. Moc xa lom jas oj och yii ja ba yoj snaji.  
\v 16 Jaxa ma' tey ba huitz, moc xa lom oj cumxuc oj huaj yii ja xchompa.  
\v 17 ¡Jel ajul ja sbaj ja ma' cuchan yuj ja nihuac chameli soc ja ma' ay to yioje ja yal alatz huan to chuuneli!  
\v 18 C'anahuic yi ja Dios cuando ora oja paquex ajneli que mi jauc stiempo chee  
\v 19 Porque ja huocol iti jel tzatz juntiro. Quechan huocol mas tzatz oj ajyuc masan ya cujlajuc ja satq'uinal ja Diosi. Mi ni nunca ba ilxia soc mi ni nunca oj jac otro vuelta ja jastal iti.  
\v 20 Stz'acatal ja Cajualtic Diosi oj bob scom ja sc'ac'uil ja huocol jahui porque ta mi c'a comtic'anuc t'usani, mi ni june ma' oj el librea. Pero ja' yujil ja matic tzaubale ni yuj ja Diosi, jayuj comtic'an ni t'usan oj yaa ja huocoli.  
\v 21 Pero ta ay c'a ma' huax jac yala huabyex, q'uelahuilex, jul bi ja il ja Cristo, ma q'uelahuilex, ti bi aya, pero moc lomuc ac'uuquex.  
\v 22 Ay ni ma' oj yal que Cristo, que tzaubal bi yuj ja Diosi, soc ay ma' oj stoy sbaj que aluman‑Dios bi. Ay jas oj sea huilex siquiera ba oj slolayex. Oj bob sc'uluque milagro. Hasta ja ma' stzaunej ni ja Diosi, ay modo jastal oj lolajuque ta mi c'a tzatz ayuquei.  
\v 23 Pero ja huenlexi, aa cuidadoex. Con tiempo huax cala huabyex. 
\s1 Ja jastal oj jacuc ja ma' oj co jan ja ba satq'uinali 
\r (Mt. 24:29‑35, 42‑44; Lc. 21:25‑36) 
\p  
\v 24 Ja tiempo jahui, cuando huax ch'ac ec' ja huocoli, ja c'ac'u oj tupuc, jaxa luna oj ch'acuc,  
\v 25 Jaxa c'anal jumasa oj ch'ac lujbajuc con ja ba satq'uinali. Oj ni ch'ac syoopes ja yip ja Dios ja ba satq'uinali.  
\v 26 Ja queni ti ni coelon jan ja ba satq'uinali, jaxa ora jahui, oj cho cocon jan otro vuelta. Ti oj cocon jan ba yoj ason. Jel tzatz oj ajyucon. Oj ni lijpucona. Jaxa cristiano jumasa, oj ni yilonea.  
\v 27 Oj jec ja cangel jumasa ja ba xchanil xchiquin ja satq'uinali. Oj huaj stzome jan spetzanil ja ma' jtzauneji ja ba spetzanil ja mundo.  
\v 28 Q'uelahuilex ja steil ja higo. Cuando yaau xa ja sc'abi, huan ni xa naahuex que q'ue ta stiempo ja'.  
\v 29 Jachuc, cuando huaxa huilahuex spetzanil ja cosa iti, naahuic que jel xa mojan ja tiempo, ja' xa nia.  
\v 30 Huax cala, pero meran, ja cristiano ma' sac'an ja ora jahui, mi oj chamuque masan to huax c'ot smeranil spetzanil ja jastal jahui.  
\v 31 Anima huax ch'ac ja satq'uinali soc ja luumi pero ja jas huax cala, t'ilan ni oj c'ot smeranila.  
\v 32 Pero ja c'ac'u jahui soc ja mero yorail oj ec'uc ja cosa jumasa iti, mi ni june ma' oj snaa, mi ni ja ángel jumasa tey ba satq'uinali. Ja queni mero yuninon ja jTati pero mi ni oj naa. Quechan ja jTati oj snae.  
\v 33 Jayuj chapan ajyanic. Q'uelan jacan ajyanic. C'umanic ja Diosi porque mi xa naahuex jas ora oj jaconi.  
\v 34 Lajan soc ja huinic jau yaa can ja snaji ba oj huajuc najat lec. Yaa ba sc'ab ja smozo jumasa. Cada mozo yaa yi ja yateli. Ti yal yab ja ma' huas stalna ja puerta: Q'uelan jacan xta la ajyi, xyutaj.  
\v 35 Jachuc ja huenlex chomajquili. Q'uelan jacan ajyanic porque mi xa naahuex jas ora oj cumxuc ja suinquil ja naitzi. Bob ta oj jacuc cuando huan xax och ja acuali, ma nalan acual, ma xchabil gallo, ma sacbi q'uinal.  
\v 36 Q'uelan jacan ajyanic porque jun ta ch'ay c'ujol oj jacuc ja suinquil ja naitzi. Q'uixhuel ja sbaj ta huanex c'a huayel oj staexi.  
\v 37 Jayujil huax cala huabyex ja huenlexi soc spetzanil ja cristiano, q'uelan jacan ajyanic apetzanilex. 
\s1 Chapji yabalil ja Jesusi 
\r (Mt. 26:1‑5; Lc. 22:1‑2; Jn. 11:45‑53) 
\c 14  
\p  
\v 1 Ja c'ac'u yala jachuc ja Jesusi, quechan xta chab c'ac'u sc'ana ja syalq'uinal ja judio jumasa, ja' ni ja q'uin it huas sueahue ja pan it mey slevaduraili. Ja nihuac spagreil ja judio jumasa soc ja ma' huas seahue ja smandar ja Moisesi huane xa xchapjel yabalil ja Jesusi. Ta ay bi modo jastal oj bob syame, oj bi yaahue ch'ay snaajel.  
\v 2 Pero mi bi jauc ja mero sc'ac'uil ja q'uini porque ja cristiano lom bi oj q'ueuque soc pleito. 
\s1 Jun ixuc spec'a yi perpume ja Jesusi 
\r (Mt. 26:6‑13; Jn. 12:1‑8) 
\p  
\v 3 Jaxa Jesusi ti xa ay ba yal hacienda Betania ja ba snaj ja Simón ja ma' huax alji sbaj yaj chamel xta ajyi yuj ja huan c'ael ja sbacteli. Cuando ti culan ec' ba mesa ja Jesusi, ti jac jun ixuca. Yiaj jan yi jun perpume c'ulubal soc puro nardo ba jel ja stz'acoli. Jaxa yetali, c'ulubal soc jun ton alabastro sbiil. Ja ixuqui ti spojo ja alabastro, jaxa perpume ti spec'a yi ja ba s'olom ja Jesusi.  
\v 4 Pero ay chaboxe ja tihui, lom xta xuatati ja sc'ujolei. Ti yalahuea: ―¡Jel lástima juntiro jach huax ch'ay lom ja perpume iti! ¿Jasyuj jach huas sc'ulan ba?  
\v 5 Mas lec chonxuc to. Oj chonxuc mas que milquinientos peso, jaxa taq'uin jahui, oj aaxuc yi ja ma' pobre, xchiye. Xbulbuniye xta sbaj ja ixuqui.  
\v 6 Ti yala ja Jesusi: ―Ch'abananic ja huenlexi. ¿Jasyuj huanex staajel ti' ja ixuc iti? Jel tzamal juntiro ja jas sc'ulunej quii.  
\v 7 Ja matic pobre, tola vida oj ajyuc amoquex. Cualquiera ora oj bob acoltayex, pero ja queni, mi tola vidauc oj ajyucon amoquex.  
\v 8 Ja ixuc iti sc'ulunej spetzanil ja jas huax bob yujili. Meran nia, mi to la chamyon pero ja yeni spec'a ta qui ja jcuerpo ja perpume. Ja' xa ni huax xchapahuon ja ba jmuculabili.  
\v 9 Jaxa abal it jel tzamali, chican ba lugar ja ba spetzanil ja mundo oj to cholxuqui, oj ni abjuc ja jas sc'ulan qui ja ixuc iti. Mi ni nunca oj ch'ay snaajel ja jas sc'ulan quii, xchi ja Jesusi. 
\s1 Ja Judasi yiaj spatic ja Jesusi 
\r (Mt. 26:14‑16; Lc. 22:3‑6) 
\p  
\v 10 Jaxa Judas Iscariote, ja' ni june ja lajchahuanei, ti huaj soc ja nihuac pagre jumasa. Huaj sc'ul trato ba oj sc'ul yile endregal ja Jesusi.  
\v 11 Jaxa pagre jumasa cuando jach alji yabyei, jel gusto juntiro yabye. Ti sc'ulane trato. Oj bi yae yi taq'uin ja Judas. Jaxa Judasi ti oj slee jastal oj sc'ul endregal ja Jesusi. 
\s1 Ja cena sbaj ja Cajualtiqui 
\r (Mt. 26:17‑29; Lc. 22:7‑23; Jn. 13:21‑30; 1 Cor. 11:23‑26) 
\p  
\v 12 Ja q'uin it huas sueahue ja pan mey slevaduraili ja' ni ja mero sbajtanil c'ac'u ja q'uin jahui, culan yujile huas smilahue jun chej cada syalq'uinal. Ja c'ac'u jahui ja snebuman jumasa ti sobohue yi ja Jesusi: ―¿Ba huaxa c'ana oj huaj chapticon ba, porque syalq'uinal xa tac. Sbej xa ni oj c'uxtic ja chej ja jastal ni culan cujtiqui.  
\v 13 Ti yal yab chabe ja snebuman jumasa: ―Caxic xa ba chonab. Cuando ti xa ayex ja ba sti ja chonabi, ti oja taex bej jun huinic cuchan xch'ub, ti xa tzajlayexa.  
\v 14 Ti oj c'ot ja ba jun naitz, jaxa suinquil ja naitz jahui oja jobex yi bay ja cuarto jau ba nalan chaani. ¿Ba bi oj sc'ux ja xchejil ja syalq'uinal ja Maestro soc ja snebuman jumasa? oja huutex.  
\v 15 Jaxa yeni oj sea huilex jun nihuan cuarto ba nalan chaani, chapan xa. Jaxa huenlexi ti oja tojbesex leca, xchi ja Jesusi.  
\v 16 Ja snebuman jumasa ti huajyea. Jaxa ba sti ja chonabi, ti ni staahue ja jastal ni alji yabyei. Stojbese ja ba oj ec' yujile ja syalq'uinali.  
\v 17 Cuando och ja acuali, ja Jesusi soc ja snebuman jumasa ti huajye ja ba cuarto jahui.  
\v 18 Ti ochye culan ja ba mesa. Huane xa huael cuando yala ja Jesusi: ―Huax cala, pero meran, june ja huenlexi, ja' ni ja jmoj huaeli, oja c'uluconex endregal, xchi.  
\v 19 Jaxa yenlei ch'ac jom juntiro ja s'olomei. Ti och sobe yi chol ja Jesusi: ―¿Quen ama? xchiye xta.  
\v 20 Jaxa Jesusi ti yalaa: ―June ni ja huenlex ja lajchahuaneexi. Lajan ni huanon xchicjel soc ja juaela.  
\v 21 Meran nia, ti ni coelon jan ja ba satq'uinali pero oj ni chamcona. Como jach ni tz'ijbanubal ja ba yabal ja Diosi pero ¡pobre ja huinic jau ja ma' oj sc'ulucon endregal! ¡Mas lec moc to manxuc ja huinic jahui! xchi ja Jesusi.  
\v 22 Huane to huael cuando yiaj jun pan ja Jesusi. Cuando ch'ac sc'an yi stz'acatal ja Diosi, ti xet'aa: ―Hueanic. Ja iti, ja' ni ja jcuerpoa, xchi.  
\v 23 Ti syama jun vaso but'el yaalel tz'usub. Yaa yi stz'acatal ja Diosi, ti cho yaa yi ja snebuman jumasa, jaxa yenlei ch'ac yue spetzanile.  
\v 24 Ti yala ja Jesusi: ―Ja yaalel tz'usub iti, ja' ni ja jchiq'uela. Ja Diosi sc'ulunej jun yajc'achil trato soc ja cristiano, ja' cuando xpec' ja jchiq'ueli, oj bi huajuque libre soc ja smulei.  
\v 25 Huax cala, pero meran, ja yaani mi xa oj to cu otro vuelta ja yaalel ja tz'usubi man to cuando ti xa aytic jpetzaniltic ja ba lugar jau ja ba huas sc'ulan mandar ja jTati, ti xa oj xiitalauc jbajtic yuj ja jgustotiqui, xchi ja Jesusi. 
\s1 Ja Jesusi yala jastal oj nacjuc yuj ja Pedro 
\r (Mt. 26:30‑35; Lc. 22:31‑34; Jn. 13:36‑38) 
\p  
\v 26 Cuando ch'ac yale jun stz'eboj Dios, ti huajye ja ba huitz Olivosi.  
\v 27 Ti yala ja Jesusi: ―Ja jastal oj ec' cujil ja yaan acuali, oj xihuanic juntiro. Como jach ni tz'ijbanubala: 
\q1 Oj ca yajbuc ja tanumcheji, jaxa jun nole ja xcheji, sactantan oj ch'ac huajuc, 
\m xchi nia.  
\v 28 Oj ni miljucona pero oj cho sac‑huucon, ti oj huajcon ba Galileaa. Tix cho la huajyex ja huenlexi.  
\v 29 Pero ja Pedro ti yalaa: ―Ja tuqui, bob ta oj xch'aya sc'ujol pero ja queni, miyuc, xchi xta.  
\v 30 ―Huax cala, pero meran, cuando mi tox oc' ja xchabil gallo ja yaan acuali, oxe vuelta oja hual que mi xa naa jbaj, xchi ja Jesusi.  
\v 31 Pero ja Pedro jel tzatz juntiro ja stii: ―Anima huala chamyon amoc, pero mi ni nunca oj cal que mix naa baj. Jach ni ja tuc snebuman jumasa, jach ni ch'ac yale chomajquila. 
\s1 Ja Jesusi huaj sc'umuc ja Dios ja ba Getsemaní 
\r (Mt. 26:36‑46; Lc. 22:39‑46) 
\p  
\v 32 Ti c'otye ba jun lugar sbiil Getsemaní. Ja Jesusi ti yal yab ja snebuman jumasa: ―Culananic ja ili jaxa queni oj huaj c'umuc ja Diosi, xchi.  
\v 33 Ti yal yab ja Pedro soc ja Jacobo soc ja Juani: ―Laic ja huenlexi, xyutaj. Pero ja Jesusi och tristeaxuc juntiro ja ora jahui. Syatz'a sbaj ja yaltzili.  
\v 34 Ti yalaa: ―Jel yatz'an ja caltzili. Lajan soc oj xa chamcon mas ligero. Cananic ja ili pero moc lomuc hua ochuc ja hua huayelexi.  
\v 35 Ti huaj och otro jun maq'ue mas ja Jesusi. Ti co pacan ba luum. Ti och sc'an yi stz'acatal ja Diosi, ta ay modo oj bob ec'uc ja huocol jahui.  
\v 36 ―Tatey, ja hueni, huax bob ahuuj spetzanil. A ec' qui ja huocol iti pero mi jauc ja jas huax c'ana ja queni pero ja' ni ja jas huaxa c'ana ja hueni, xchi.  
\v 37 Ti xa cumxi ja bay ja oxhuane snebuman jumasa. Naca huane xa huayel jac stae. Ti yal yab ja Pedro: ―Simón, pero ¡huana xa huayel tac! ¿Mi ni ma jun ora oj bob atec' ja hua huayelex ba?  
\v 38 Mi lom la huayex. C'umanic ja Diosi ba mi oja lee ja hua mulexi. Ja hua hualtzilexi jel huas sc'ana oj sc'uluc ja ba lequi, jaxa hua cuerpoexi, jel yaau juntiro. Mey yip.  
\v 39 Ti cho huaj otro vueltaa. Jun xta mismo ja jas och sc'an yi ja Diosi.  
\v 40 Ti cho cumxi otro vuelta ja bay ja oxhuane snebuman jumasa. Cho huane huayel staa. Lajan soc but'el tz'iilel ja satei. Jaxa yenlei mi snaahue jas oj yale.  
\v 41 Jaxa ba yoxil vuelta, ja Jesusi ti yalaa: ―¿Huanex to ma huayel ba? Lec xa. Jijlanic xa. Malan xa soca porque ja queni chapanon xa nia ba oj chamcona. Meran nia, ja queni ti ni coelon jan ja ba satq'uinali pero iday, jpatic huanon iijel. Oj xa aajucon ja ba sc'ab ja mulanum jumasa.  
\v 42 Q'ueanic huego. Huajtic xa. Ti xa huax jac ja ma' yionej jpatiqui, xchi ja Jesusi. 
\s1 Yamji ja Jesusi 
\r (Mt. 26:47‑56; Lc. 22:47‑53; Jn. 18:2‑11) 
\p  
\v 43 Mi tox ch'ac el yujila, huaj to yile, ti xa ay ja Judasi, ja' ni june ja lajchahuane snebumani. Smoj jun nole cristiano. Naca ay smachite soc sgarrotee. Jecubale yuj ja pagre mas nihuaqui soc ja ma' huas seahue ja smandar ja Moisesi soc ja ma' banquilal ay yuj ja cristiano.  
\v 44 Pero ja mi tox c'otyei, ti alji yabye yuj ja Judas ja ma' yionej spatic ja Jesusi: ―Ja ma' oj huaj cujtz'uqui, yena nia. Ti xa yamahuexa. Mi huocoluc oja huiex, xchi ja Judasi.  
\v 45 Cuando mojan xa ay ja Jesusi, ti huaj yaa yi Diosa, ti yujtz'ana, como smodoe nia.  
\v 46 Jaxa smoj jumasa ja Judasi ti syamahuea, pero con gana.  
\v 47 Jayuj ti xa stasa ja smachit june ja yenlei. Aaji yi ja smozo ja pagre mas nihuani. C'utzji el yi june ja xchiquini.  
\v 48 Ti cho yala ja Jesusi: ―¿Yuj ama lagronon soc machit soc garrote huax jac ayamonex ba?  
\v 49 Cada c'ac'u huaxa huilahuex huanon seejel ja ba templo. ¿Jasyuj ja mi ti ayamahuonex ja tihui? Jach ni huaxa c'ulanexa yuj ja jach ni tz'ijbanubal ja ba yabal ja Diosi.  
\v 50 Cuando ch'ac yal jachuc ja Jesusi, ja snebuman jumasa ti xa elye ja tihui. Spacahue ajnel. 
\s1 Ja querem ja ma' spaca ajneli 
\p  
\v 51 Pero ay jun soltero ja tihui, ja' ni june ja ma' huax bejyi ec' soc ja Jesús ajyi. Bech'an soc jun sábana. Pero ja cristiano ti syamahuea pero ja yeni soco sbaj.  
\v 52 Cholpiji can ja sábana. Basan spaca ajnel. 
\s1 Ja Jesusi tey ba yoj junta 
\r (Mt. 26:57‑68; Lc. 22:54‑55, 63‑71; Jn. 18:12‑14, 19‑24) 
\p  
\v 53 Ja Jesusi ti iiji och ba sti sat ja pagre mas nihuani. Ti jac nolan sbaj spetzanil ja nihuac pagre jumasa soc ja banquilal jumasa soc ja ma' huas seahue ja smandar ja Moisesi.  
\v 54 Jaxa Pedro ti huaj nochana. Najtic najtic huas sq'uela. Ti och ja ba spatioil ja snaj ja pagre mas nihuani. Ti och culan ba sti c'ac'. Tey jun nole mozo jumasa soc ja criada jumasa. Naca huane c'atnel.  
\v 55 Jaxa Jesusi, mi xax yilahue ora jastal oj bob smile. Ja nihuac pagre soc spetzanil ja ma' tzoman sbaji, huane xta sleejel ja smul ja Jesusi, pero mi ni jas huax bob yujilea.  
\v 56 Jitzan ja ma' och testigoili, pero puro mentira huane. Tuctuquil ja jas huax yalahuei.  
\v 57 Ti cho jac chaboxe masa. Jac yale que testigoe bi pero tuc juntiro ja jas jac yalei.  
\v 58 Yabye bi que oj bi sem ja templo: ―Ja templo iti c'ulubal soc c'abal pero ja queni oj jem ele. Jaxa ba yoxil c'ac'u oj cho ca sta slugar siempre pero mi soc c'abaluc oj sta slugar. ―Jach huax yala, xchi ja testigo jumasa jahui.  
\v 59 Pero mi ni modoa. Mix lajxi ja jas huax yalahuei.  
\v 60 Jaxa pagre mas nihuani xachachi xta q'ue tec'an ja ba sat ja cristiano. Ti och sob yi ja Jesusi: ―Jaxa hueni, ¿jas la chi ba? ¿Ja huab ama jas yala ja it jumasa?  
\v 61 Pero ja Jesusi mi ni jun palabra sama ja stii. Mi sac'a jan ja jas jobji yii. Jaxa nihuan pagre ti cho och sob yi otro vuelta: ―¿Meran ama huen ja Cristo ja ma' stzaunej ja Diosi? ¿Yunina ama ja Dios ja ma' jel huax yajtaticoni? xchi.  
\v 62 ―Quena nia. Ja queni ti ni coelon jan ja ba satq'uinali. Jel tzatz juntiro oj ajyucon yuj ja yip ja Dios ja ma' jel nihuani. Oj to cocon jan ja ba satq'uinali ba yoj asoni. Oj ni ahuilonexa, xchi ja Jesusi.  
\v 63 Jaxa pagre mas nihuani ti st'uxpin ec' ja sc'ab yuj ja scoraja. Ti yalaa: ―¿Jas yatel cujtic mas testigo?  
\v 64 ¡Ja huabyex yala que yen bi yunin Dios tac! ¿Jas la chiyex? Spetzanile huax yalahue que sbej ni oj chamuca, que mas bi lec oj chamuc.  
\v 65 Jaxa tuqui ti och stzujbaye ja sat ja Jesusi. Smacahue yi ja sati, ti och st'uxpuque vueltaa: ―Naa quitic sbaj ja ma' huas smac'ahuai. Ala machunc'a huax yaa hui vuelta, xchiye xta. Jaxa policía jumasa ti cho och smac'taluque ja ba sati. 
\s1 Ja Pedro snac'a ja Jesusi 
\r (Mt. 26:69‑75; Lc. 22:56‑62; Jn. 18:15‑18, 25‑29) 
\p  
\v 66 Jaxa Pedro mi teyuc ja tihui. Ti ni ay ba spatioil ja sti naitzi. Ti jac june ja scriada ja pagre mas nihuani.  
\v 67 Ja criada ti yila que ti huan c'atnel ja Pedro. Stojtoq'uela lec, ti yalaa: ―Ja hueni, ja' ni ja hua moj ja tan Jesús nazareño, x'utji ja Pedro.  
\v 68 Jaxa Pedro yala que miyuc. ―Mi ni huax naa sbaj. Mix cab ja jas huaxa huala cabi, xchi. Ch'ac yal jachuc ja Pedro, ti huaj tec'an ja ba puerta calle. Ti oc' ja galloa.  
\v 69 Jaxa criada cho sq'uela otro vuelta. Ti och yab ja ma' tey tihui: ―Ja tan huinic iti, ja' ni june ja yenlei, xchi.  
\v 70 Jaxa Pedro cho yala otro vuelta que mi bi snaa sbaj. Ti cho ec' jutz'ina. Jaxa matic tey ja tihui, ti yalahuea: ―Ja hueni galileñoa nia. Ja mero smeranili, ja' ni ja hua moj ja yenlei porque jun xta ja hua c'umalex tac.  
\v 71 Jaxa Pedro och xta bulbunuc. Jel piero ja jas yala: ―Xila Dios mix naa sbaj ja tan huinic jau huaxa taahuex tii, xchi.  
\v 72 Ti xa oc' ja xchabil galloa. Malan soc ja jahui, ti jul sc'ujol ja Pedro ja jas alubal yab yuj ja Jesusi, que ja mi tox oc' chab vuelta ja gallo, oxe vuelta oj yal que mi snaa sbaj. Cuando jac sc'ujol ja Pedro, ti och oc'uc leca. 
\s1 Ja Jesusi iiji ba sti sat ja Pilato 
\r (Mt. 27:1‑2, 11‑14; Lc. 23:1‑5; Jn. 18:28‑38) 
\c 15  
\p  
\v 1 Ja nihuac pagre sbaj ja judio jumasa soc ja banquilal jumasa soc ja ma' huas seahue ja smandar ja Moisesi soc spetzanil ja matic tey ba yoj junta, lajti abal xa ni ayea. Saj to lec smochohue ja Jesusi. Yiaje och ja ba sti sat ja Pilato ja ma' ay yateli.  
\v 2 Jaxa Pilato ti sobo yi ja Jesusi: ―Jaxa huen, ala cabi, ¿meran ama huen sreya ja hua moj judioili? ―Quena nia como jach ni huana yaljela, xchi ja Jesusi.  
\v 3 Jaxa nihuac pagre ti och slee yi ja smuli, pero xuooljiye xta.  
\v 4 Jaxa Pilato ti cho yalaa: ―¿Jasyuj mi la c'umani? ¡Ata huab ja jas huax yalahue abaji!  
\v 5 Pero ja Jesusi mi ni soc ja jahui, mi ni jun palabra sama stii. Jel och juntiro ja spensar ja Pilato. 
\s1 Ja Jesusi, t'ilan aaji chamuc 
\r (Mt. 27:15‑31; Lc. 23:13‑25; Jn. 18:38‑19:16) 
\p  
\v 6 Ja mero sc'ac'uil ja q'uin jahui, culan ni yujil ja ma' ay yatel huax ya el libre jun presoanum pero tzaubal huax ya eluc ja cristiano.  
\v 7 Jaxa q'uin jahui, lutan jun nole huinique ja ma' milhuaniye ja yora q'ue jun nihuan spleitoe. Ay june ja yenle lutan preso, Barrabás sbiil.  
\v 8 Jaxa c'ac'u jahui, ti jac jun nole ja cristiano. Jac sc'ane yi ja Pilato que oj sc'uluc ja jastal ni culan yujile ja ba q'uin jahui.  
\v 9 Ti sobo ja Pilato: ¿Mi ma xa c'anahuex ja oj sijpuc ahuilex ja hua reyexi?  
\v 10 Como huas snaa ja Pilato que puro envidioso aye ja nihuac pagre, jayuj sc'ulane entregar ja Jesusi.  
\v 11 Pero ja nihuac pagre jumasa huane xta yaljel yab ja cristiano ba oj sc'ane yi ja Pilato ba oj sijpuc ja tan Barrabasi.  
\v 12 Jaxa Pilato ti sobo yi otro vuelta ja cristiano: ―Entonces jaxa ma' huaxa hualahuex que ja' hua reyexi, ¿jasunc'a huaxa c'anahuex oj c'ul yi ba?  
\v 13 ―¡A chamuc ba cruz! xchiye xta, pero ahuanel huane.  
\v 14 ―Pero ¿jasunc'a ja smuli? xchi ja Pilato. Lom xta xuooljiye huax q'ueye: ―¡A chamuc ba cruz! xchiye.  
\v 15 Jaxa Pilato, como huas sc'ana oj can lec soc ja cristiano, ti ya el libre ja Barrabasi, ti yaa endregal ja Jesusi ba oj ni mac'juca. Ti yaa ba sc'ab ja ma' oj yaa locan ba cruz.  
\v 16 Jaxa soldado jumasa ti yiaje ja Jesusi. Yiaje och ba yoj presidencia, pretorio sbiil yujile. Ti spaya jan spetzanil ja smoj soldadoili.  
\v 17 Cuando jacyei, ti yaahue slap jun c'ual morado ja jastal huas slapa ja reyi. Jaxa ba s'olomi, yaahue cajan jun corona pero puro q'uiix sc'uluneje.  
\v 18 Ti yalahuea: ―¡Viva ja srey ja judio jumasa!  
\v 19 Ti syamahue jun aja. Smac'ahue soc ja s'olomi. Stzujbaye, ti ochye mec'an ja ba sti sati, pero puro burla huane.  
\v 20 Cuando el ja sganae soc ja burla, ti sopohue yi ja c'ual morado. Yaahue slap ja mero sc'ui. Ti yaahue eluc ba oj yae locan ba cruz. 
\s1 Ja Jesusi aaji locan ja ba cruzi 
\r (Mt. 27:32‑44; Lc. 23:26‑43; Jn. 19:17‑27) 
\p  
\v 21 Jaxa ba beji, ti ec' jun huinic cireño, Simón sbiil, jaxa yuntiquili sbiil Alejandro soc Rufo. Ch'ac ta cumxuc jan ba huitz. Jaxa soldado jumasa, ti yalahue yab ja Simón jahui que oj scuch och ja cruzi.  
\v 22 Jaxa Jesusi ti yiaje och ba jun lugar sbiil Gólgota. Jach sbiil yujile como ja' ni el ja splanta ja sbaquel ja s'olom ja chamhuiniqui.  
\v 23 Ti yaahue yi ja Jesús t'usan yaalel tz'usub pero paj xa, socan soc jun an sbiil mirra, ja' bi ba mi oj yab ja syajal ja suocoli. Oj bi yue pero ja Jesusi mi yuaj.  
\v 24 Ti yaahue locan ja ba cruzi. Ti yiaje ja sc'u jumasa ja Jesusi. Sc'ulane ripar ba oj yile machunc'a oj co sbaj yujile ja soldado jumasa.  
\v 25 Ja mero ora aaji locan ba cruz ja Jesusi, como las nueve de la mañana.  
\v 26 Ti stz'ijbaye can jas sbej ja huax yaahue locan ja ba cruzi: Ja srey ja judio jumasa, xchi ja letrero sc'ulanei.  
\v 27 Cho ay chab lagron ti cho yaahue locan ja ba stz'eel ja scruz ja Jesusi. Ja juni, ti yaahue ba lado stojol sc'ab ja Jesusi, jaxa juni, tey ba lado surdero.  
\v 28 Jachuc, c'ot ni smeranil ja jas huax yala ja yabal ja Diosi, ja' ni aaji smojuc ja ma' jel ja smulei.  
\v 29 Jaxa matic huax ec' ja tihui, huane xta burla. Naca huane xta seetalajel ja sc'abi, ti huax yalahuea: ―¿Baya huaxa huala oja jem ja stemplo ja Diosi jaxa yoxil c'ac'u oj hua sta slugar?  
\v 30 Colta baj ja huen mismo ba. ¿Jaxa mi la co ja ba cruz ba? xchiye xta.  
\v 31 Jachuc ja nihuac pagre, huane xta burla ja yenle chomajquili. Huax yiaj sbaje loil soc ja matic huas seahue ja smandar ja Moisesi, ti huax yalahuea: ―Ja tuqui, jel huas scolta, jaxa yeni mix bob scolta sbaj.  
\v 32 Pero ¡Cristoa tac! ¡Huaxa toya baj que huena jreyaticon tac! ¿Jastal lec mi la co ja ba cruz ja huego ba? ¡Colta baj ba, ti oj c'uucaticona! xchiye xta. Jachuc ja chahuane ja ma' lajan locane ja ba cruzi, huane xta burla. 
\s1 Cham ja Jesusi 
\r (Mt. 27:45‑56; Lc. 23:44‑49; Jn. 19:28‑30) 
\p  
\v 33 Jaxa mero culan c'ac'u q'uicbi juntiro ja satq'uinali. Masan to ec' ja oxe ora, ti xa cho lijpia.  
\v 34 Cuando oj xa lijpuc ja satq'uinali, ti c'umani ja Jesusi, pero tzatz lec c'umani: ―Eloi, Eloi, ¿lami sabactani? xchi soc ja mero yabali. Dios mío, Dios mío, ¿jas lom ahuaahuon ta cani? Jach ni sbej ja jas yala soc ja yabali.  
\v 35 ―Ata huabilex, huan xa spayjel ja Eliasi, xchiye chaboxe ja ma' tey tihui cuando yab ja yahuaneli.  
\v 36 Jaxa june ja yenlei ti huaj ajnel huegoa. Yiaj jun yojol c'aem, ti sbut'u soc vinagre. Ti xch'ica jun tea. Ti jac sach q'ue yia ba oj xchuuc ja Jesusi: ―¡Actayic cani! Oj quiltic ta oj jac sc'ul librar ja Eliasi, xchi june ja huinique jahui.  
\v 37 Jaxa Jesusi ti cho ahuani otro vueltaa. Ti chama.  
\v 38 Jaxa ba yojol ja templo ay jun nihuan scortinail, jaxa ora jahui, xch'ia sbaj snalan. Ja xch'ielali, stulu con man sti q'ueel. El con man ba luum.  
\v 39 Jaxa ba sti sat ja Jesusi, ti tec'an ec' jun capitán soldado. Ja soldado jahui, yila quechan pavor ch'ac ahuanuc ja Jesusi, cham huego, ti yalaa: ―Ja huinic jahui, yunin ni ja Dios merana.  
\v 40 Soc ay jun c'ole ixuque ti huane q'uelhuanela pero najat aye. Tey ja María sbaj Magdala, soc ja María snan ja ch'in Jacobo soc ja José, soc tey ja ixuc Salomé.  
\v 41 Ja ixuque jumasa jahui, jel scoltaye ja Jesús cuando yora ti huan bejyel ec' ba Galilea. Soc ay to jitzan ja ixuque ja matic smojane ja Jesús ja yora huaj ja ba Jerusaleni. 
\s1 Ja Jesusi mucji 
\r (Mt. 27:57‑61; Lc. 23:50‑56; Jn. 19:38‑42) 
\p  
\v 42 Ja och c'ac'u jau cuando ti to locan ba cruz ja Jesusi, ja' ni ja yoch c'ac'uil huax q'ue xchap sbaj ja cristiano porque ja otro c'ac'u, sc'ac'uil xa ni sijlelea.  
\v 43 Jaxa och c'ac'u jahui, ti och ba sti sat ja Pilato ja José ba Arimatea. Ja yeni ay ni yatela. Jel lec huax ilji yuj ja smoj jumasa. Ja yeni huan ni smajlajel jas ora oj sc'ul mandar ja Diosi. Pero ja och c'ac'u jahui, mi xihui. Ti och sc'an yi pavor ja Pilato ba oj aajuc yi ja scuerpo ja Jesusi.  
\v 44 Jaxa Pilato cham yab que cham ta ja Jesusi. Ti spaya jan ja soldado captiani. Sobo ta meran cham ta ja Jesusi.  
\v 45 ―Cham ta nia, xchi ja capitani. Cuando yab jachuc ja Pilato, ti yal yab ja José que lec bi oj yii ja scuerpo.  
\v 46 Jaxa José ti smana jun sábanaa. Ti ya couc ja ba cruz ja scuerpo ja Jesusi. Sbech'a soc ja sábana jahui. Ti yaa ba jun q'ueen pero ja q'ueen jahui jotobal ba jun nihuan patac'. Ti sbaltzun jan jun tona. Ti smaca can lec ja sti ja q'ueeni.  
\v 47 Pero cuando jach to huan sc'ulajel ja Josei, ti culane ec' ba stz'eel ja q'ueeni ja María sbaj Magdala soc ja María snan ja José. 
\s1 Ja Jesusi sacui 
\r (Mt. 28:1‑10; Lc. 24:1‑12; Jn. 20:1‑10) 
\c 16  
\p  
\v 1 Entonces ja cristiano ti xa jijliyea, como ja' ni ja sc'ac'uil sijlelei. Jaxa otro c'ac'u, como ja' ni sbajtanil c'ac'u ja semana, ja María sbaj Magdala soc ja María snan ja Jacobo soc ja Salomé ti smanahue jun perpume ba oj saxe yi ja scuerpo ja Jesusi.  
\v 2 Ti huajye saj to leca. Cuando c'otye ja ba q'ueeni huan xa elel q'uen ja c'ac'u.  
\v 3 ―Saber ta ay ma' oj ya el quitic ja ton ja ba sti ja q'ueeni, xchiye.  
\v 4 Pero cuando ti xa aye ja tihui, ti yilahue que mi xa macanuc ja q'ueeni. Ja nihuan ton jahui, ti xa ay ba jun lado.  
\v 5 Ti ochye ba yoj q'ueeni, jaxa ba lado stojol ja sc'abei, ti culan ec' jun soltero, jaxa sc'u lapan yuji, jel najat soc jel sac. Jaxa ixuquei, xiuye juntiro.  
\v 6 Pero ja soltero jahui ti yalaa: ―Mi lom la xiuyex. Huanex ni sleejel ja Jesús ja nazareño, ja' ni ja ma' aaji locan ba cruz pero mi xa teyuca. Sacui ta. Q'uelahuilex ja lugar ja ba aaji can ja scuerpo tac.  
\v 7 Caaxic xa. Cax alahuic yab ja snebuman jumasa soc ja Pedro que ti xa huaj ta ba Galilea ja Jesusi. Al yab aa xa huajuc ja yenle chomajquili. Ti oja c'umuquex ja tihui ja jastal ni yala huabyexi, xchi ja angeli.  
\v 8 Jaxa ixuquei ajnel elye ja ba q'ueeni porque huane xa q'uitc'onel yuj ja xihueli. Mi ni june ma' huax yalahue yab ja ba beji porque jel juntiro ja xihueli. 
\s1 Ja jastal sea sbaj yi ja María sbaj Magdala ja Jesusi 
\r (Jn. 20:11‑18) 
\p  
\v 9 Ja Jesusi, ja' ni ja sbajtanil c'ac'u ja semana sacui, pero saj to lec. Jaxa ma' mero bajtan sea sbaj yi, ja' ni ja María sbaj Magdala. Ja ixuc jahui, ixtalanubal yuj juque pucuj ajyi pero ja Jesusi yen ya el libre.  
\v 10 Jaxa María, cuando ch'ac yil ja Jesusi, ti huaj yal yab ja ma' smojan ec' ja Jesús ajyi. Ja yenlei jel triste aye juntiro. Huane xta oq'uel.  
\v 11 Jaxa cuando yabye que sac'an xa bi ja Jesusi, que yila bi, mi ni modo huas sc'uanea. 
\s1 Ja Jesusi sea sbaj yi ja chab snebumani 
\r (Lc. 24:13‑35) 
\p  
\v 12 Jaxa mas tzaani, ja Jesusi ti sea sbaj yi chahuane huinique cuando bej to aye. Ti to huane eq'uel ba huitz.  
\v 13 Soc jach ni ja yenlei, cho huaj yale yab ja tuc jumasa, pero mi ni soc ja jastal jahui, mi sc'uane. 
\s1 Ja Jesusi yaa yi yatel ja secabanum jumasa 
\r (Mt. 28:16‑20; Lc. 24:36‑49; Jn. 20:19‑23) 
\p  
\v 14 Jaxa mas tzaan ja jahui, ti culane ec' ba mesa ja juluchuane snebumani. Ja Jesusi ti jac see sbaj yilea. Ti och aljuc yabye t'un abala yuj ja mi bi huas sc'uane. Jel bi ch'uuy juntiro ja sc'ujolei. Mi ni modo huas sc'uane ja jas huax alji yabye yuj ja matic yilahue que sacui ta.  
\v 15 Ti alji yabyea: ―Caxic xa ba spetzanil ja mundo. Loiltayic ec' ja abal it jel tzamali. Alahuic yab ba spetzanil ja cristiano.  
\v 16 Jaxa ma' mi sc'uani, oj ni aajuc yi ja scastigoa, jaxa ma' huas sc'uani soc huax yiaj jai, oj ni coltajuquea.  
\v 17 Ja ma' huas sc'uanonei, ay jas oj bob sc'uluque ba oj naajuc que meran ni huas sc'uanonea. Quechan oj stae ti' ja jbiili, jaxa tantic pucuj jumasa oj yacta can ja cristiano ja ma' huax yixtalaanei. Oj bob c'umanuque soc yajc'achil abal.  
\v 18 Oj bob syame ja mal chani. Ta ay c'a jas huax yuaje ba veneno, mi ni jas oj bob sc'uluquea. Oj bob ya cajan ja sc'ab ja ba scuerpo ja ma' malo ayi y oj ni tojbuquea. 
\s1 Ja Jesusi iiji ja ba satq'uinali 
\r (Lc. 24:50‑53) 
\p  
\v 19 Cuando ch'ac yal jachuc ja Cajualtiqui, ti iiji q'ue ja ba satq'uinali, jaxa tihui, ti aaji yi ja yatel ba mas nihuani.  
\v 20 Jaxa snebuman jumasa, ti huajyea. Huaj sloiltaye ja yabal ja Diosi ja ba spetzanil ja lugari. Coltajiye yuj ja Cajualtiqui. Ja yenlei huane sloiltajel, jaxa Cajualtiqui, jitzan cosa jas huax ya chijcajuc ba oj ya snaa ja cristiano que sbaj ni ja Diosa. Ti ch'aca. Amén.