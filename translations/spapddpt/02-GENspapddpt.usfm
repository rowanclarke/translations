\q1
\v 12 \wj \+w Él|strong="H1931"\+w* \+w será|strong="H1961"\+w* un hombre \+w como|strong="H1961"\+w* \+w el|strong="H1931"\+w* asno salvaje.\wj*  
\q1 \wj \+w Su|strong="H1931"\+w* \+w mano|strong="H3027"\+w* \+w estará|strong="H1961"\+w* \+w contra|strong="H5921"\+w* \+w todos|strong="H3605"\+w*, \wj*  
\q1 \wj \+w Y|strong="H3068"\+w* \+w la|strong="H1931"\+w* \+w mano|strong="H3027"\+w* \+w de|strong="H5921"\+w* \+w todos|strong="H3605"\+w* \+w contra|strong="H5921"\+w* \+w él|strong="H1931"\+w*. \wj*  
