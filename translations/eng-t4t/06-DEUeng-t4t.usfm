\s1 Yahweh’s own people  
\p
\v 16 \w Today|strong="H3117"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w is|strong="H3068"\w* \w commanding|strong="H6680"\w* \w you|strong="H6680"\w* \w to|strong="H3068"\w* \w obey|strong="H6213"\w* \w all|strong="H3605"\w* \w these|strong="H2088"\w* \w rules|strong="H2706"\w* \w and|strong="H3068"\w* \w regulations|strong="H4941"\w*. \w So|strong="H6213"\w* \w obey|strong="H6213"\w* \w them|strong="H6213"\w* faithfully, \w with|strong="H3068"\w* \w your|strong="H3068"\w* \w entire|strong="H3605"\w* inner \w being|strong="H5315"\w* [DOU].  
\v 17 \w Today|strong="H3117"\w* \w you|strong="H3117"\w* \w have|strong="H1961"\w* \w declared|strong="H8085"\w* \w that|strong="H3117"\w* \w Yahweh|strong="H3068"\w* \w is|strong="H3068"\w* \w your|strong="H3068"\w* \w God|strong="H3068"\w*, \w and|strong="H3068"\w* \w that|strong="H3117"\w* \w you|strong="H3117"\w* \w will|strong="H3068"\w* \w conduct|strong="H1870"\w* \w your|strong="H3068"\w* \w lives|strong="H1961"\w* \w as|strong="H3117"\w* \w he|strong="H3117"\w* wants \w you|strong="H3117"\w* \w to|strong="H3212"\w* \w do|strong="H3068"\w*, \w and|strong="H3068"\w* \w that|strong="H3117"\w* \w you|strong="H3117"\w* \w will|strong="H3068"\w* \w obey|strong="H8085"\w* \w all|strong="H3212"\w* \w his|strong="H8104"\w* \w commands|strong="H4687"\w* \w and|strong="H3068"\w* \w rules|strong="H2706"\w* \w and|strong="H3068"\w* \w regulations|strong="H4941"\w*, \w and|strong="H3068"\w* \w that|strong="H3117"\w* \w you|strong="H3117"\w* \w will|strong="H3068"\w* \w do|strong="H3068"\w* \w all|strong="H3212"\w* \w that|strong="H3117"\w* \w he|strong="H3117"\w* tells \w you|strong="H3117"\w* \w to|strong="H3212"\w* \w do|strong="H3068"\w*.  
\v 18 \w And|strong="H3068"\w* \w today|strong="H3117"\w* \w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* \w declared|strong="H1696"\w* \w that|strong="H5971"\w* \w you|strong="H3605"\w* \w are|strong="H3117"\w* \w his|strong="H3605"\w* \w people|strong="H5971"\w*, \w which|strong="H3068"\w* \w is|strong="H3068"\w* \w what|strong="H1696"\w* \w he|strong="H3117"\w* \w promised|strong="H1696"\w* \w that|strong="H5971"\w* \w you|strong="H3605"\w* \w would|strong="H3068"\w* \w be|strong="H1961"\w*, \w and|strong="H3068"\w* \w he|strong="H3117"\w* \w commands|strong="H4687"\w* \w you|strong="H3605"\w* \w to|strong="H1696"\w* \w obey|strong="H8104"\w* \w all|strong="H3605"\w* \w his|strong="H3605"\w* \w commands|strong="H4687"\w*.  
\v 19 \w If|strong="H1961"\w* \w you|strong="H5414"\w* \w do|strong="H6213"\w* \w that|strong="H5971"\w*, \w he|strong="H6213"\w* \w will|strong="H3068"\w* \w cause|strong="H5414"\w* \w you|strong="H5414"\w* \w to|strong="H1696"\w* \w become|strong="H1961"\w* greater \w than|strong="H5921"\w* \w any|strong="H3605"\w* \w other|strong="H3605"\w* \w nation|strong="H1471"\w* \w that|strong="H5971"\w* \w he|strong="H6213"\w* \w has|strong="H3068"\w* \w established|strong="H5414"\w*, \w and|strong="H3068"\w* \w he|strong="H6213"\w* \w will|strong="H3068"\w* enable \w you|strong="H5414"\w* \w to|strong="H1696"\w* \w praise|strong="H8416"\w* \w him|strong="H5414"\w* \w and|strong="H3068"\w* \w honor|strong="H8597"\w* \w him|strong="H5414"\w* [DOU]. \w You|strong="H5414"\w* \w will|strong="H3068"\w* \w truly|strong="H6213"\w* \w belong|strong="H1961"\w* \w to|strong="H1696"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w*, \w which|strong="H3068"\w* \w is|strong="H3068"\w* \w what|strong="H6213"\w* \w he|strong="H6213"\w* \w has|strong="H3068"\w* \w promised|strong="H1696"\w*.”   
\c 27  
\s1 The stone tablets set up on Ebal Mountain  
\p
\v 1 \w Moses|strong="H4872"\w*/\w I|strong="H3117"\w*, along \w with|strong="H3117"\w* \w the|strong="H3605"\w* \w other|strong="H3605"\w* Israeli \w leaders|strong="H2205"\w*, said \w this|strong="H8104"\w* \w to|strong="H3478"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w*: “\w Obey|strong="H8104"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w commandments|strong="H4687"\w* \w that|strong="H5971"\w* \w I|strong="H3117"\w* am \w giving|strong="H6680"\w* \w to|strong="H3478"\w* \w you|strong="H6680"\w* \w today|strong="H3117"\w*.  
\v 2-4  \add Soon\add* you will cross the Jordan \add River\add* and enter the land that \w Yahweh|strong="H3068"\w*, the God whom our ancestors \add worshiped\add*, promised to give to you. There, in that very fertile [IDM] land on the \add west\add* side of the Jordan \add River\add*, set up some large stones \add on Ebal Mountain\add*, and cover them with plaster. Then write on those stones all these laws and teachings/instructions.  
\v 5 \w And|strong="H3068"\w* \w build|strong="H1129"\w* \w a|strong="H3068"\w* stone \w altar|strong="H4196"\w* \w there|strong="H8033"\w* \w to|strong="H3068"\w* \w offer|strong="H5130"\w* sacrifices \w to|strong="H3068"\w* \w Yahweh|strong="H3068"\w*, \w but|strong="H3808"\w* \w do|strong="H3068"\w* \w not|strong="H3808"\w* cut \w those|strong="H5921"\w* stones \w with|strong="H3068"\w* \w iron|strong="H1270"\w* tools.  
\v 6 \w The|strong="H5921"\w* \w altar|strong="H4196"\w* \w that|strong="H3068"\w* \w you|strong="H5921"\w* make \w to|strong="H3068"\w* \w burn|strong="H5927"\w* \w sacrifices|strong="H5930"\w* \w to|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* must \w be|strong="H3068"\w* \w made|strong="H1129"\w* \w with|strong="H3068"\w* \w uncut|strong="H8003"\w* stones.  
\v 7 \w And|strong="H3068"\w* \w there|strong="H8033"\w* \w you|strong="H6440"\w* must \w sacrifice|strong="H2076"\w* \w offerings|strong="H8002"\w* \w to|strong="H3068"\w* maintain fellowship \w with|strong="H3068"\w* \w Yahweh|strong="H3068"\w*, \w and|strong="H3068"\w* \w you|strong="H6440"\w* must eat \add your share of those offerings\add* \w and|strong="H3068"\w* \w rejoice|strong="H8055"\w*/celebrate \w in|strong="H3068"\w* \w the|strong="H6440"\w* \w presence|strong="H6440"\w* \w of|strong="H3068"\w* \w Yahweh|strong="H3068"\w*.  
\v 8 \w And|strong="H1697"\w*, \w when|strong="H5921"\w* \w you|strong="H3605"\w* \w write|strong="H3789"\w* \w these|strong="H2063"\w* \w laws|strong="H8451"\w* \w on|strong="H5921"\w* \w those|strong="H3605"\w* stones, \w you|strong="H3605"\w* must \w write|strong="H3789"\w* \w them|strong="H5921"\w* \w very|strong="H3190"\w* clearly.”   
\p
\v 9 \w Then|strong="H1961"\w* \w Moses|strong="H4872"\w*/\w I|strong="H3117"\w*, along \w with|strong="H3068"\w* \w the|strong="H3605"\w* \w priests|strong="H3548"\w*, \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* Israeli \w people|strong="H5971"\w*, “\w You|strong="H3605"\w* Israeli \w people|strong="H5971"\w*, \w be|strong="H1961"\w* quiet \w and|strong="H4872"\w* \w listen|strong="H8085"\w* \add to what I am saying\add*. \w Today|strong="H3117"\w* \w you|strong="H3605"\w* \w have|strong="H1961"\w* \w become|strong="H1961"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* \w who|strong="H3605"\w* \w belong|strong="H1961"\w* \w to|strong="H1696"\w* \w Yahweh|strong="H3068"\w*, \w our|strong="H3068"\w* \w God|strong="H3068"\w*.  
\v 10 \w So|strong="H6213"\w*, \w you|strong="H6680"\w* must \w do|strong="H6213"\w* \w what|strong="H6963"\w* \w he|strong="H3117"\w* tells \w you|strong="H6680"\w*, \w and|strong="H3068"\w* \w obey|strong="H8085"\w* \w all|strong="H6213"\w* \w the|strong="H8085"\w* \w rules|strong="H2706"\w* \w and|strong="H3068"\w* regulations \w that|strong="H3117"\w* \w I|strong="H3117"\w* \w am|strong="H3068"\w* \w giving|strong="H6680"\w* \w to|strong="H3068"\w* \w you|strong="H6680"\w* \w today|strong="H3117"\w*.”   
\s1 The curses from disobeying God  
\p
\v 11 \w On|strong="H3117"\w* \w that|strong="H5971"\w* \w same|strong="H1931"\w* \w day|strong="H3117"\w* \w Moses|strong="H4872"\w*/\w I|strong="H3117"\w* said \w to|strong="H3117"\w* \w the|strong="H3117"\w* Israeli \w people|strong="H5971"\w*,  
\v 12 “\w After|strong="H5921"\w* \w you|strong="H5921"\w* \w have|strong="H5971"\w* \w crossed|strong="H5674"\w* \w over|strong="H5921"\w* \w the|strong="H5921"\w* \w Jordan|strong="H3383"\w* \add River\add*, \w the|strong="H5921"\w* \w tribes|strong="H5975"\w* \w of|strong="H2022"\w* \w Simeon|strong="H8095"\w*, \w Levi|strong="H3878"\w*, \w Judah|strong="H3063"\w*, \w Issachar|strong="H3485"\w*, \w Joseph|strong="H3130"\w*, \w and|strong="H3063"\w* \w Benjamin|strong="H1144"\w* must \w stand|strong="H5975"\w* \w on|strong="H5921"\w* \w Gerizim|strong="H1630"\w* \w Mountain|strong="H2022"\w* \w and|strong="H3063"\w* \add request Yahweh to\add* \w bless|strong="H1288"\w* \w the|strong="H5921"\w* \w people|strong="H5971"\w*.  
\v 13 \w And|strong="H2022"\w* \w the|strong="H5921"\w* \w tribes|strong="H5975"\w* \w of|strong="H2022"\w* \w Reuben|strong="H7205"\w*, \w Gad|strong="H1410"\w*, Asher, \w Zebulun|strong="H2074"\w*, \w Dan|strong="H1835"\w*, \w and|strong="H2022"\w* \w Naphtali|strong="H5321"\w* must \w stand|strong="H5975"\w* \w on|strong="H5921"\w* \w Ebal|strong="H5858"\w* \w Mountain|strong="H2022"\w* \w and|strong="H2022"\w* listen \w to|strong="H5921"\w* \w the|strong="H5921"\w* things \w that|strong="H2022"\w* \w Yahweh|strong="H3068"\w* \w will|strong="H2022"\w* do \w when|strong="H5975"\w* \w he|strong="H5921"\w* \w curses|strong="H7045"\w* \w the|strong="H5921"\w* people.   
\p
\v 14 \w The|strong="H3605"\w* descendants \w of|strong="H6963"\w* \w Levi|strong="H3881"\w* \w must|strong="H3478"\w* \w shout|strong="H6963"\w* \w these|strong="H3605"\w* words \w loudly|strong="H6963"\w*:   
\b  
\q1
\v 15 ‘\w Yahweh|strong="H3068"\w* \w will|strong="H3068"\w* curse \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* \w makes|strong="H6213"\w* \w an|strong="H6213"\w* \w idol|strong="H6459"\w* \w of|strong="H3068"\w* stone, \w or|strong="H3068"\w* \w of|strong="H3068"\w* wood, \w or|strong="H3068"\w* \w of|strong="H3068"\w* \w metal|strong="H6213"\w*, \w and|strong="H3068"\w* \w secretly|strong="H5643"\w* \w sets|strong="H7760"\w* \w it|strong="H7760"\w* \w up|strong="H7760"\w* \add and worships it\add*.  
\q2 \w Yahweh|strong="H3068"\w* considers \w that|strong="H5971"\w* \w those|strong="H3605"\w* \w things|strong="H3605"\w*, \w made|strong="H6213"\w* \w by|strong="H3027"\w* humans [SYN], \w are|strong="H5971"\w* \w detestable|strong="H8441"\w*/\w disgusting|strong="H8441"\w*.’  
\q2 \w And|strong="H3068"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* must \w reply|strong="H6030"\w*, ‘◄Amen/\w We|strong="H6213"\w* want \w that|strong="H5971"\w* \w to|strong="H3068"\w* \w happen|strong="H6213"\w*►.’   
\q1
\v 16 ‘\w Yahweh|strong="H3068"\w* \w will|strong="H5971"\w* curse \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* \w dishonors|strong="H7034"\w* \w his|strong="H3605"\w* father \w or|strong="H5971"\w* \w his|strong="H3605"\w* mother.’  
\q2 \w And|strong="H5971"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* must reply, ‘◄Amen/\w We|strong="H3605"\w* want \w that|strong="H5971"\w* \w to|strong="H5971"\w* happen►.’   
\q1
\v 17 ‘\w Yahweh|strong="H3068"\w* \w will|strong="H5971"\w* curse \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* removes someone \w else|strong="H3605"\w*’s markers \w of|strong="H1366"\w* property boundaries.’  
\q2 \w And|strong="H5971"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* must reply, ‘◄Amen/\w We|strong="H3605"\w* want \w that|strong="H5971"\w* \w to|strong="H5971"\w* happen►.’   
\q1
\v 18 ‘\w Yahweh|strong="H3068"\w* \w will|strong="H5971"\w* curse \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* \w leads|strong="H7686"\w* \w a|strong="H3068"\w* \w blind|strong="H5787"\w* person \w to|strong="H1870"\w* \w go|strong="H5971"\w* ◄\w in|strong="H1870"\w* \w the|strong="H3605"\w* wrong \w direction|strong="H1870"\w*/where \w that|strong="H5971"\w* person does \w not|strong="H1870"\w* want \w to|strong="H1870"\w* \w go|strong="H5971"\w*►.’  
\q2 \w And|strong="H5971"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* must reply, ‘◄Amen/\w We|strong="H3605"\w* want \w that|strong="H5971"\w* \w to|strong="H1870"\w* happen►.’   
\q1
\v 19 ‘\w Yahweh|strong="H3068"\w* \w will|strong="H5971"\w* curse \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* deprives \w foreigners|strong="H1616"\w* \w or|strong="H1616"\w* \w orphans|strong="H3490"\w* \w or|strong="H1616"\w* \w widows|strong="H5971"\w* \w of|strong="H5971"\w* \w the|strong="H3605"\w* \w things|strong="H3605"\w* \w that|strong="H5971"\w* \w the|strong="H3605"\w* laws state must \w be|strong="H1616"\w* \w done|strong="H3605"\w* \w for|strong="H4941"\w* them.’  
\q2 \w And|strong="H4941"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* must reply, ‘◄Amen/\w We|strong="H3605"\w* want \w that|strong="H5971"\w* \w to|strong="H5971"\w* happen►.’   
\q1
\v 20 ‘\w Yahweh|strong="H3068"\w* \w will|strong="H5971"\w* curse \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* ◄shows \w no|strong="H3605"\w* respect \w for|strong="H3588"\w*/disgraces \w his|strong="H3605"\w* father►  
\q2 \w by|strong="H3605"\w* \w having|strong="H3588"\w* \w sex|strong="H7901"\w* \w with|strong="H5973"\w* [EUP] \w any|strong="H3605"\w* \w of|strong="H5971"\w* \w his|strong="H3605"\w* father’s wives.’  
\q2 \w And|strong="H5971"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* must reply, ‘◄Amen/\w We|strong="H3588"\w* want \w that|strong="H3588"\w* \w to|strong="H1540"\w* happen►.’   
\q1
\v 21 ‘\w Yahweh|strong="H3068"\w* \w will|strong="H5971"\w* curse \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* \w has|strong="H3605"\w* \w sex|strong="H7901"\w* [EUP] \w with|strong="H5973"\w* \w any|strong="H3605"\w* animal.’  
\q2 \w And|strong="H5971"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* must reply, ‘◄Amen/\w We|strong="H3605"\w* want \w that|strong="H5971"\w* \w to|strong="H5971"\w* happen►.’   
\q1
\v 22 ‘\w Yahweh|strong="H3068"\w* \w will|strong="H5971"\w* curse \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* \w has|strong="H3605"\w* \w sex|strong="H7901"\w* \w with|strong="H5973"\w* \w his|strong="H3605"\w* sister \w or|strong="H5971"\w* \w with|strong="H5973"\w* \w his|strong="H3605"\w* half-sister.’  
\q2 \w And|strong="H5971"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* must reply, ‘◄Amen/\w We|strong="H3605"\w* want \w that|strong="H5971"\w* \w to|strong="H5971"\w* happen►.’   
\q1
\v 23 ‘\w Yahweh|strong="H3068"\w* \w will|strong="H5971"\w* curse \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* \w has|strong="H3605"\w* \w sex|strong="H7901"\w* \w with|strong="H5973"\w* [EUP] \w his|strong="H3605"\w* mother-in-law.’  
\q2 \w And|strong="H5971"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* must reply, ‘◄Amen/\w We|strong="H3605"\w* want \w that|strong="H5971"\w* \w to|strong="H5971"\w* happen►.’   
\q1
\v 24 ‘\w Yahweh|strong="H3068"\w* \w will|strong="H5971"\w* curse \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* \w secretly|strong="H5643"\w* murders someone \w else|strong="H3605"\w*.’  
\q2 \w And|strong="H5971"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* must reply, ‘◄Amen/\w We|strong="H3605"\w* want \w that|strong="H5971"\w* \w to|strong="H5971"\w* happen►.’   
\q1
\v 25 ‘\w Yahweh|strong="H3068"\w* \w will|strong="H5971"\w* curse \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* \w accepts|strong="H3947"\w* \w a|strong="H3068"\w* \w bribe|strong="H7810"\w* \w to|strong="H5971"\w* murder \w someone|strong="H5315"\w* \w who|strong="H3605"\w* ◄\w is|strong="H5315"\w* \w innocent|strong="H5355"\w*/\w has|strong="H5315"\w* \w not|strong="H3947"\w* \w done|strong="H3605"\w* \w something|strong="H3605"\w* \w that|strong="H5971"\w* \w is|strong="H5315"\w* wrong.►’  
\q2 \w And|strong="H5971"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* \w must|strong="H3947"\w* reply, ‘◄Amen/\w We|strong="H5315"\w* \w want|strong="H5315"\w* \w that|strong="H5971"\w* \w to|strong="H5971"\w* happen►.’   
\q1
\v 26 ‘\w Yahweh|strong="H3068"\w* \w will|strong="H5971"\w* curse \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* disobeys \w these|strong="H6213"\w* \w laws|strong="H8451"\w* \w and|strong="H6965"\w* refuses \w to|strong="H6213"\w* declare \w that|strong="H5971"\w* \w these|strong="H6213"\w* \w laws|strong="H8451"\w* \add are good\add*.’  
\q2 \w And|strong="H6965"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* \w must|strong="H3808"\w* \w reply|strong="H1697"\w*, ‘◄Amen/\w We|strong="H6213"\w* \w want|strong="H3808"\w* \w that|strong="H5971"\w* \w to|strong="H6213"\w* \w happen|strong="H6965"\w*►.’”   
\c 28  
