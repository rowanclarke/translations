\id NUM - Biblica® Open Kurdi Sorani Standard Version
\h سەرژمێری
\toc1 سەرژمێری
\toc2 سەرژمێری
\toc3 سەرژمێری
\mt1 سەرژمێری
\mt3 چوارەم پەڕتووکی موسا
\c 1
\s1 سەرژمێریی یەکەم\f + \fr 1:0 \ft سەرژمێریی یەکەم تایبەت بوو بە ناونووسینی پیاوانی ئیسرائیل بۆ سەربازی لەژێر چاودێری موسا بۆ هێرشبردنە سەر خاکی کەنعان لە ناوچەی قادێش بەرنێعەوە.‏\f*
\p 
\v 1 لە یەکی مانگی دووی ساڵی دووەمی هاتنەدەرەوەی گەلی ئیسرائیل لە خاکی میسر، لە چادری چاوپێکەوتندا لە چۆڵەوانی سینا، یەزدان بە موسای فەرموو:
\v 2 «سەرژمێری هەموو کۆمەڵی نەوەی ئیسرائیل بکەن، بە خێڵەکانیان و بنەماڵەکانیانەوە، بە لیستی ناوی نێرینەکان یەک بە یەک.
\v 3 لە گەنجی بیست ساڵ بەرەو سەرەوە، هەموو ئەوانەی دەتوانن لە ئیسرائیل خزمەت بکەن لە سوپا، تۆ و هارون بەگوێرەی لەشکرەکانیان تۆماریان بکەن.
\v 4 بۆ هەر هۆزێک پیاوێکتان لەگەڵدا بێت، پیاوێک گەورەی بنەماڵەکەی بێت.
\b
\li4 
\v 5 «ئەمەش ناوی ئەو پیاوانەیە کە یارمەتیتان دەدەن:
\b
\li1 «لە هۆزی ڕەئوبێن، ئەلیسوری کوڕی شەدیئور؛
\li1 
\v 6 لە هۆزی شیمۆن، شەلومیێلی کوڕی چووریشەدای؛
\li1 
\v 7 لە هۆزی یەهودا، نەحشۆنی کوڕی عەمیناداب؛
\li1 
\v 8 لە هۆزی یەساخار، نەتەنێلی کوڕی چوعەر؛
\li1 
\v 9 لە هۆزی زەبولون، ئەلیابی کوڕی حێلۆن؛
\li1 
\v 10 لە کوڕەکانی یوسف:
\li2 لە هۆزی ئەفرایم، ئەلیشاماعی کوڕی عەمیهود؛
\li2 لە هۆزی مەنەشە، گەمالائیلی کوڕی پەداهچوور؛
\li1 
\v 11 لە هۆزی بنیامین، ئەبیدانی کوڕی گدعۆنی،
\li1 
\v 12 لە هۆزی دان، ئەحیعەزەری کوڕی عەمیشەدای؛
\li1 
\v 13 لە هۆزی ئاشێر، پەگعیێلی کوڕی عۆخران؛
\li1 
\v 14 لە هۆزی گاد، ئەلیاسافی کوڕی دەعوئێل؛
\li1 
\v 15 لە هۆزی نەفتالی، ئەحیڕەعی کوڕی عێینان.»
\b
\li4 
\v 16 ئەوانە هەڵبژێردراوانی کۆمەڵەکەن، سەرکردەی هۆزی باوکانیانن، سەرۆک خێڵەکانی ئیسرائیلن.
\b
\p 
\v 17 جا موسا و هارون هەموو ئەو پیاوانەیان برد کە باس کران،
\v 18 هەموو کۆمەڵیان لە یەکی مانگی دوو کۆکردەوە. لە گەنجانی بیست ساڵە بەرەو سەرەوە بەگوێرەی ڕەچەڵەکیان خرانەوە سەر خێڵ و بنەماڵەکانیان، یەک بە یەک ناوەکانیان تۆمار کرا،
\v 19 هەروەک یەزدان فەرمانی بە موسا کرد. ئینجا لە چۆڵەوانی سینادا تۆماری کردن.
\b
\li1 
\v 20 لە نەوەی ڕەئوبێن کە نۆبەرەی ئیسرائیلە،
\li2 هەموو نێرینەیەک لە گەنجی بیست ساڵ بەرەو سەرەوە، هەموو ئەوانەی دەتوانن خزمەت بکەن لە سوپادا، یەکە بە یەکە بەپێی ناوەکان ڕێکخران، بەگوێرەی تۆمارکردنی خێڵەکانیان و بنەماڵەکانیان.
\v 21 تۆمارکراوان لە هۆزی ڕەئوبێن چل و شەش هەزار و پێنج سەد کەس بوون.
\b
\li1 
\v 22 لە نەوەی شیمۆن،
\li2 هەموو نێرینەیەک لە گەنجی بیست ساڵ بەرەو سەرەوە، هەموو ئەوانەی دەتوانن خزمەت بکەن لە سوپادا، یەکە بە یەکە ژمێردران و بەپێی ناوەکان ڕێکخران، بەگوێرەی تۆمارکردنی خێڵەکانیان و بنەماڵەکانیان.
\v 23 تۆمارکراوان لە هۆزی شیمۆن پەنجا و نۆ هەزار و سێ سەد کەس بوون.
\b
\li1 
\v 24 لە نەوەی گاد،
\li2 هەموو نێرینەیەک لە گەنجی بیست ساڵ بەرەو سەرەوە، هەموو ئەوانەی دەتوانن خزمەت بکەن لە سوپادا، بەپێی ناوەکان ڕێکخران، بەگوێرەی تۆمارکردنی خێڵەکانیان و بنەماڵەکانیان.
\v 25 تۆمارکراوان لە هۆزی گاد چل و پێنج هەزار و شەش سەد و پەنجا کەس بوون.
\b
\li1 
\v 26 لە نەوەی یەهودا،
\li2 هەموو نێرینەیەک لە گەنجی بیست ساڵ بەرەو سەرەوە، هەموو ئەوانەی دەتوانن خزمەت بکەن لە سوپادا، بەپێی ناوەکان ڕێکخران، بەگوێرەی تۆمارکردنی خێڵەکانیان و بنەماڵەکانیان.
\v 27 تۆمارکراوان لە هۆزی یەهودا حەفتا و چوار هەزار و شەش سەد کەس بوون.
\b
\li1 
\v 28 لە نەوەی یەساخار،
\li2 هەموو نێرینەیەک لە گەنجی بیست ساڵ بەرەو سەرەوە، هەموو ئەوانەی دەتوانن خزمەت بکەن لە سوپادا، بەپێی ناوەکان ڕێکخران، بەگوێرەی تۆمارکردنی خێڵەکانیان و بنەماڵەکانیان.
\v 29 تۆمارکراوان لە هۆزی یەساخار پەنجا و چوار هەزار و چوار سەد کەس بوون.
\b
\li1 
\v 30 لە نەوەی زەبولون،
\li2 هەموو نێرینەیەک لە گەنجی بیست ساڵ بەرەو سەرەوە، هەموو ئەوانەی دەتوانن خزمەت بکەن لە سوپادا، بەپێی ناوەکان ڕێکخران، بەگوێرەی تۆمارکردنی خێڵەکانیان و بنەماڵەکانیان.
\v 31 تۆمارکراوان لە هۆزی زەبولون پەنجا و حەوت هەزار و چوار سەد کەس بوون.
\b
\li4 
\v 32 لە نەوەی یوسف،
\li1 لە نەوەی ئەفرایم،
\li2 هەموو نێرینەیەک لە گەنجی بیست ساڵ بەرەو سەرەوە، هەموو ئەوانەی دەتوانن خزمەت بکەن لە سوپادا، بەپێی ناوەکان ڕێکخران، بەگوێرەی تۆمارکردنی خێڵەکانیان و بنەماڵەکانیان.
\v 33 تۆمارکراوان لە هۆزی ئەفرایم چل هەزار و پێنج سەد کەس بوون.
\li1 
\v 34 لە نەوەی مەنەشە،
\li2 هەموو نێرینەیەک لە گەنجی بیست ساڵ بەرەو سەرەوە، هەموو ئەوانەی دەتوانن خزمەت بکەن لە سوپادا، بەپێی ناوەکان ڕێکخران، بەگوێرەی تۆمارکردنی خێڵەکانیان و بنەماڵەکانیان.
\v 35 تۆمارکراوان لە هۆزی مەنەشە سی و دوو هەزار و دوو سەد کەس بوون.
\b
\li1 
\v 36 لە نەوەی بنیامین،
\li2 هەموو نێرینەیەک لە گەنجی بیست ساڵ بەرەو سەرەوە، هەموو ئەوانەی دەتوانن خزمەت بکەن لە سوپادا، بەپێی ناوەکان ڕێکخران، بەگوێرەی تۆمارکردنی خێڵەکانیان و بنەماڵەکانیان.
\v 37 تۆمارکراوان لە هۆزی بنیامین سی و پێنج هەزار و چوار سەد کەس بوون.
\b
\li1 
\v 38 لە نەوەی دان،
\li2 هەموو نێرینەیەک لە گەنجی بیست ساڵ بەرەو سەرەوە، هەموو ئەوانەی دەتوانن خزمەت بکەن لە سوپادا، بەپێی ناوەکان ڕێکخران، بەگوێرەی تۆمارکردنی خێڵەکانیان و بنەماڵەکانیان.
\v 39 تۆمارکراوان لە هۆزی دان شەست و دوو هەزار و حەوت سەد کەس بوون.
\b
\li1 
\v 40 لە نەوەی ئاشێر،
\li2 هەموو نێرینەیەک لە گەنجی بیست ساڵ بەرەو سەرەوە، هەموو ئەوانەی دەتوانن خزمەت بکەن لە سوپادا، بەپێی ناوەکان ڕێکخران، بەگوێرەی تۆمارکردنی خێڵەکانیان و بنەماڵەکانیان.
\v 41 تۆمارکراوان لە هۆزی ئاشێر چل و یەک هەزار و پێنج سەد کەس بوون.
\b
\li1 
\v 42 لە نەوەی نەفتالی،
\li2 هەموو نێرینەیەک لە گەنجی بیست ساڵ بەرەو سەرەوە، هەموو ئەوانەی دەتوانن خزمەت بکەن لە سوپادا، بەپێی ناوەکان ڕێکخران، بەگوێرەی تۆمارکردنی خێڵەکانیان و بنەماڵەکانیان.
\v 43 تۆمارکراوان لە هۆزی نەفتالی پەنجا و سێ هەزار و چوار سەد کەس بوون.
\b
\li4 
\v 44 ئەوانە تۆمارکراوەکانن، ئەوانەی موسا و هارون و دوازدە سەرۆک هۆزەکانی ئیسرائیل تۆماریان کردن، هەر پیاوێک لە تۆمارکراوەکان نوێنەر بوو بۆ بنەماڵەکەی.
\v 45 جا هەموو نەوەی ئیسرائیل، بەگوێرەی بنەماڵەکانیان لە گەنجی بیست ساڵ بەرەو سەرەوە، هەموو ئەوانەی دەتوانن خزمەت بکەن لە سوپای ئیسرائیلدا تۆمار کران،
\v 46 هەموو تۆمارکراوەکان شەش سەد و سێ هەزار و پێنج سەد و پەنجا کەس بوون.
\b
\p 
\v 47 بەڵام هۆزی لێڤی بنەماڵەکانیان لەگەڵ ئەوان تۆمار نەکران،
\v 48 چونکە یەزدان بە موسای فەرموو:
\v 49 «هۆزی لێڤی تۆمار مەکە و لەنێوان نەوەی ئیسرائیلدا سەرژمێریان مەکە.
\v 50 بەڵکو لێڤییەکان لەسەر چادری پەیمان و هەموو قاپوقاچاغەکەی و هەموو ئەوەی هەیەتی دابنێ، ئەوان چادرەکەی پەرستن بە هەموو قاپوقاچاغەکانییەوە هەڵدەگرن و ئەوان خزمەتی دەکەن، لە چواردەوری چادرەکەی پەرستنیش چادر هەڵدەدەن.
\v 51 لە کاتی گواستنەوەی چادرەکەی پەرستن لێڤییەکان هەڵیدەگرنەوە و لە کاتی هەڵدانی چادرەکەی پەرستنیش لێڤییەکان دایدەمەزرێننەوە. هەرکەسێکی دیکە جگە لە لێڤییەکان لێی نزیک بێتەوە دەکوژرێت.
\v 52 نەوەی ئیسرائیل هەریەکە لە ئۆردوگای خۆی لەژێر بەیداخەکەی خۆی بەپێی لەشکرەکانیان چادر هەڵدەدەن.
\v 53 بەڵام لێڤییەکان لە چواردەوری چادرەکەی پەیمان چادر هەڵدەدەن، هەتا تووڕەیی نەیەتە سەر کۆمەڵی نەوەی ئیسرائیل، جا لێڤییەکان بەرپرسیار دەبن لە پارێزگاری چادری پەیمان.»
\p 
\v 54 نەوەی ئیسرائیلیش ئاوایان کرد، بەگوێرەی هەموو ئەوەی یەزدان فەرمانی بە موسا کرد.
\c 2
\s1 ڕێکخستنی ئۆردوگاکانی هۆزەکان
\p 
\v 1 هەروەها یەزدان بە موسا و هارونی فەرموو:
\v 2 «با نەوەی ئیسرائیل، هەریەکە لەژێر بەیداخەکەی خۆی، بە لافیتەکانی بنەماڵەکانیانەوە چادر هەڵبدەن، ڕووەو چادری چاوپێکەوتن و دەوروبەری.»
\b
\li4 
\v 3 لەلای ڕۆژهەڵات،
\li1 هۆزی یەهودا ڕووەو خۆر هەڵاتن لەژێر بەیداخی ئۆردوگاکەیان بەگوێرەی لەشکرەکانیان چادر هەڵدەدەن، سەرۆکی نەوەی یەهوداش نەحشۆنی کوڕی عەمینادابە.
\v 4 ژمارەی سەربازە تۆمارکراوەکانیش حەفتا و چوار هەزار و شەش سەد کەسە.
\li1 
\v 5 پاشان هۆزی یەساخار لەتەنیشتیانەوە چادر هەڵدەدەن، سەرۆکی نەوەی یەساخاریش نەتەنێلی کوڕی چوعەر.
\v 6 ژمارەی سەربازە تۆمارکراوەکانیش پەنجا و چوار هەزار و چوار سەد کەسە.
\li1 
\v 7 پاشان هۆزی زەبولون دێت، سەرۆکی نەوەی زەبولونیش ئەلیابی کوڕی حێلۆنە.
\v 8 ژمارەی سەربازە تۆمارکراوەکانیش پەنجا و حەوت هەزار و چوار سەد کەسە.
\li4 
\v 9 هەموو پیاوانی دانراویش لە ئۆردوگای یەهودا، بەگوێرەی لەشکرەکانیان سەد و هەشتا و شەش هەزار و چوار سەد کەسن، یەکەمن لە بەڕێکەوتندا.
\b
\li4 
\v 10 لەلای باشوور،
\li1 هۆزی ڕەئوبێن لەژێر بەیداخی ئۆردوگاکەیان بەگوێرەی لەشکرەکانیان چادر هەڵدەدەن، سەرۆکی نەوەی ڕەئوبێنیش ئەلیسوری کوڕی شەدیئورە.
\v 11 ژمارەی سەربازە تۆمارکراوەکانیش چل و شەش هەزار و پێنج سەد کەسە.
\li1 
\v 12 پاشان هۆزی شیمۆن لەتەنیشتیانەوە چادر هەڵدەدەن، سەرۆکی نەوەی شیمۆنیش شەلومیێلی کوڕی چووریشەدایە.
\v 13 ژمارەی سەربازە تۆمارکراوەکانی پەنجا و نۆ هەزار و سێ سەد کەسە.
\li1 
\v 14 پاشان هۆزی گاد دێت، سەرۆکی نەوەی گادیش ئەلیاسافی کوڕی دەعوئێلە.
\v 15 ژمارەی سەربازە تۆمارکراوەکانیش چل و پێنج هەزار و شەش سەد و پەنجا کەسە.
\li4 
\v 16 هەموو پیاوانی دانراویش لە ئۆردوگای ڕەئوبێن، بەگوێرەی لەشکرەکانیان سەد و پەنجا و یەک هەزار و چوار سەد و پەنجا کەسن، دووەمن لە بەڕێکەوتندا.
\b
\li1 
\v 17 ئینجا چادری چاوپێکەوتن، ئۆردوگای لێڤییەکان لەناوەندی ئۆردوگاکان بەڕێ دەکەوێت، چۆن چادر هەڵدەدەن بە هەمان شێوە بەڕێ دەکەون، هەریەکە و لە شوێنی خۆی لەژێر بەیداخەکەی.
\b
\li4 
\v 18 لەلای ڕۆژئاوا،
\li1 هۆزی ئەفرایم لەژێر بەیداخی ئۆردوگاکەیان بەگوێرەی لەشکرەکانیان چادر هەڵدەدەن، سەرۆکی نەوەی ئەفرایمیش ئەلیشاماعی کوڕی عەمیهودە.
\v 19 ژمارەی سەربازە تۆمارکراوەکانی چل هەزار و پێنج سەد کەسە.
\li1 
\v 20 پاشان هۆزی مەنەشە لەتەنیشتیانەوە دێت، سەرۆکی نەوەی مەنەشەش گەمالائیلی کوڕی پەداهچوورە.
\v 21 ژمارەی سەربازە تۆمارکراوەکانی سی و دوو هەزار و دوو سەد کەسە.
\li1 
\v 22 پاشان هۆزی بنیامین دێت، سەرۆک بۆ نەوەی بنیامینیش ئەبیدانی کوڕی گدعۆنییە.
\v 23 ژمارەی سەربازە تۆمارکراوەکانیش سی و پێنج هەزار و چوار سەد کەسە.
\li4 
\v 24 هەموو پیاوانی دانراویش لە ئۆردوگای ئەفرایم، بەگوێرەی لەشکرەکانیان سەد و هەشت هەزار و سەد کەسن، سێیەمن لە بەڕێکەوتندا.
\b
\li4 
\v 25 لەلای باکوور،
\li1 هۆزی دان لەژێر بەیداخی ئۆردوگاکەیان بەگوێرەی لەشکرەکانیان چادر هەڵدەدەن، سەرۆکی نەوەی دانیش ئەحیعەزەری کوڕی عەمیشەدایە.
\v 26 ژمارەی سەربازە تۆمارکراوەکانیش شەست و دوو هەزار و حەوت سەد کەسە.
\li1 
\v 27 پاشان هۆزی ئاشێر دێت، لەتەنیشتیانەوە چادر هەڵدەدەن، سەرۆکی نەوەی ئاشێریش پەگعیێلی کوڕی عۆخرانە.
\v 28 ژمارەی سەربازە تۆمارکراوەکانیش چل و یەک هەزار و پێنج سەد کەسە.
\li1 
\v 29 پاشان هۆزی نەفتالیش دێت، سەرۆکی نەوەی نەفتالیش ئەحیڕەعی کوڕی عێینانە.
\v 30 ژمارەی سەربازە تۆمارکراوەکانیش پەنجا و سێ هەزار و چوار سەد کەسە.
\li4 
\v 31 هەموو پیاوانی دانراویش لە ئۆردوگای دان سەد و پەنجا و حەوت هەزار و شەش سەد کەسن، لەژێر بەیداخەکانیان لە کۆتاییدا بەڕێ دەکەون.
\b
\li4 
\v 32 ئەوانە تۆمارکراوەکانی نەوەی ئیسرائیلن بەگوێرەی بنەماڵەکانیان. هەموو تۆمارکراوان لە ئۆردوگاکان بە لەشکرەکانیانەوە شەش سەد و سێ هەزار و پێنج سەد و پەنجا کەسن.
\v 33 بەڵام لێڤییەکان لەنێوان نەوەی ئیسرائیلدا تۆمار نەکران، هەروەک یەزدان فەرمانی بە موسا کرد.
\b
\p 
\v 34 جا نەوەی ئیسرائیل بەگوێرەی هەموو ئەوەی یەزدان فەرمانی بە موسا کرد، ئاوایان کرد، ئاوا لەژێر بەیداخەکانیان چادریان هەڵدا و ئاوا بەڕێکەوتن، هەریەکە بەگوێرەی خێڵەکەی خۆی لە بنەماڵەکەی.
\c 3
\s1 لێڤییەکان
\p 
\v 1 ئەمەش نەوەی هارون و موسایە، ئەو ڕۆژەی یەزدان لەگەڵ موسادا لە شاخی سینا دوا.
\b
\p 
\v 2 ئەمەش ناوی کوڕەکانی هارونە، نادابی نۆبەرە و ئەبیهو و ئەلعازار و ئیتامار.
\v 3 ئەمەش ناوی نەوەکانی هارونە، کاهینە دەستنیشانکراوەکان ئەوانەی ئەرکی کاهینیێتییان پێ سپێردراوە.
\v 4 ناداب و ئەبیهو لەبەردەم یەزدان مردن، کاتێک لە چۆڵەوانی سینا ئاگرێکی نامۆیان لەبەردەم یەزدان پێشکەش کرد\f + \fr 3:4 \ft بڕوانە \xt لێڤییەکان 10‏:1‏-3.‏\xt*\ft ‏\f*. لەبەر ئەوەی هیچ کوڕیان نەبوو، ئەلعازار و ئیتامار لەبەردەم هارونی باوکیان خزمەتی کاهینیێتییان کرد.
\p 
\v 5 هەروەها یەزدان بە موسای فەرموو:
\v 6 «هۆزی لێڤی بهێنە پێش و لەبەردەم هارونی کاهین ڕایانبگرە و با یاریدەدەری بن،
\v 7 جا هەڵدەستن بە پارێزگاری بۆ ئەو و لە جیاتی هەموو کۆمەڵ لەبەردەم چادری چاوپێکەوتن، بەهۆی کارکردنیان لە چادرەکەی پەرستن.
\v 8 پارێزگاری لە هەموو قاپوقاچاغەکانی چادری چاوپێکەوتن دەکەن و بە کارکردنیان لە چادرەکەی پەرستن کار بۆ نەوەی ئیسرائیل دەکەن.
\v 9 لێڤییەکان دەدەیتە هارون و کوڕەکانی، لەنێو نەوەی ئیسرائیلدا ئەوان بە تەواوەتی پێشکەشکراون بەو.
\v 10 هارون و کوڕەکانی دادەمەزرێنیت و کاهینیێتییەکەیان دەپارێزن و هەرکەسێکی دیکە لە پیرۆزگا نزیک ببێتەوە دەکوژرێت.»
\p 
\v 11 یەزدان بە موسای فەرموو:
\v 12 «ئێستا من لێڤییەکان دەبەم، لەنێو نەوەی ئیسرائیل لە جیاتی هەر نۆبەرەیەکی نێر لە سکی ئافرەت کە لە نەوەی ئیسرائیل بێت. ئیتر لێڤییەکان دەبنە هی من،
\v 13 چونکە هەموو نۆبەرەیەک بۆ منە، ئەو ڕۆژەی لە خاکی میسردا لە هەموو نۆبەرەیەکم دا، ئەوا هەموو نۆبەرەیەک لە ئیسرائیلدا لە خەڵک و لە ئاژەڵ بۆ خۆمم تەرخان کرد، بۆ من دەبن، من یەزدانم.»
\p 
\v 14 هەروەها یەزدان لە چۆڵەوانی سینادا بە موسای فەرموو:
\v 15 «نەوەی لێڤی بەگوێرەی بنەماڵەکانیان و خێڵەکانیان تۆمار بکە، هەموو نێرینەیەک لە کۆرپەی یەک مانگ بەرەو سەرەوە تۆمار دەکەیت.»
\v 16 موساش بەگوێرەی فەرمایشتی یەزدان هەروەک فەرمانی کردبوو، تۆماری کردن.
\b
\li1 
\v 17 ئەمانە ناوی نەوەکانی لێڤی بوو:
\li2 گێرشۆن و قەهات و مەراری.
\li1 
\v 18 ئەوەش ناوی دوو کوڕەکەی گێرشۆنە بەگوێرەی خێڵەکانیان:
\li2 لیبنی و شیمعی.
\li1 
\v 19 نەوەی قەهاتیش بەگوێرەی خێڵەکانیان:
\li2 عەمرام و یەسهار و حەبرۆن و عوزیێل.
\li1 
\v 20 دوو کوڕەکەی مەراریش بەگوێرەی خێڵەکانیان:
\li2 مەحلی و موشی.
\b
\li4 ئەمە خێڵی لێڤییەکانە بەگوێرەی بنەماڵەکانیان.
\b
\li4 
\v 21 بۆ گێرشۆن خێڵی لیبنییەکان و خێڵی شیمعییەکان. ئەمە خێڵەکانی گێرشۆنییەکانە،
\li1 
\v 22 ژمارەی هەموو نێرینەیەکی کوڕی یەک مانگ بەرەو سەرەوە، تۆمارکراوان لێیان حەوت هەزار و پێنج سەد کەس بوون.
\li1 
\v 23 خێڵەکانی گێرشۆنییەکان لە پشت چادری پەرستنەوە بەلای ڕۆژئاوا چادر هەڵدەدەن،
\li1 
\v 24 گەورەی بنەماڵەی گێرشۆنییەکانیش ئەلیاسافی کوڕی لائێل بوو.
\li1 
\v 25 نەوەی گێرشۆن لە چادری چاوپێکەوتن بەرپرسیار بوون لە پارێزگاری چادرەکەی پەرستن و چادرەکە و پۆشەرەکەی، پەردەی دەروازەی چادری چاوپێکەوتن،
\v 26 پەردەکانی حەوشەکە و پەردەی دەروازەی حەوشەکە کە لە دەوری چادرەکەی پەرستنە و لە دەوری قوربانگاکەن بە چواردەوری و گوریسەکانی، لەگەڵ هەموو ئەو خزمەتەی پەیوەست بوو پێیانەوە.
\b
\li4 
\v 27 بۆ قەهاتیش خێڵی عەمرامییەکان، خێڵی یەسهارییەکان، خێڵی حەبرۆنییەکان و خێڵی عوزیێلییەکان بوون. ئەمە خێڵەکانی قەهاتییەکانە
\li1 
\v 28 ژمارەی هەموو نێرینەیەکی کوڕی یەک مانگ بەرەو سەرەوە هەشت هەزار و شەش سەد کەس بوون.
\li1 قەهاتییەکان بەرپرسیار بوون لە پارێزگاری پیرۆزگا.
\li1 
\v 29 خێڵەکانی نەوەی قەهات لەلای باشووری چادرەکەی پەرستن چادر هەڵدەدەن.
\li1 
\v 30 گەورەی بنەماڵەکانی خێڵەکانی قەهاتییەکانیش ئەلیچافانی کوڕی عوزیێل بوو.
\li1 
\v 31 بەرپرسیار بوون لە پارێزگاری سندوقەکە، مێزەکە، چرادانەکە، قوربانگاکان، قاپوقاچاغی پیرۆزگاکە کە خزمەتی پێ دەکەن، پەردەی شوێنی هەرەپیرۆز و هەموو ئەوەی لەگەڵی بەکاردەهێنرێت.
\li1 
\v 32 بۆ سەرۆکی سەرکردەکانی لێڤییەکانیش ئەلعازاری کوڕی هارونی کاهین، سەرپەرشتیار بوو بەسەر ئەو کەسانەی کە بەرپرسیار بوون لە پارێزگاری پیرۆزگا.
\b
\li4 
\v 33 بۆ مەراری، خێڵی مەحلییەکان و خێڵی موشییەکان، ئەمە خێڵەکانی مەرارییە.
\li1 
\v 34 تۆمارکراوان لێیان بەپێی ژمارەی هەموو نێرینەیەکی کوڕی یەک مانگ بەرەو سەرەوە شەش هەزار و دوو سەد کەس بوون.
\li1 
\v 35 گەورەی بنەماڵەی خێڵەکانی مەراریش چووریێلی کوڕی ئەبیحەیلە،
\li1 لەلای باکووری چادرەکەی پەرستن چادر هەڵدەدەن.
\li1 
\v 36 نەوەی مەراریش سەرپەرشتیاری پارێزگاریکردن بوون لە چوارچێوەکانی چادرەکەی پەرستن، هەروەها کاریتە، کۆڵەکە، بناغە، هەموو کەلوپەلەکانی و هەموو ئەوەی لەگەڵیدا بەکاردەهێنرێت،
\v 37 هەروەها کۆڵەکەکانی حەوشەکە لە چواردەوری و بنکە و سنگ و گوریسەکانی.
\b
\li1 
\v 38 موسا و هارون و کوڕەکانی لەلای ڕۆژهەڵاتی چادرەکەی پەرستن، ڕووەو ڕۆژهەڵات لەبەردەم چادری چاوپێکەوتن چادر هەڵدەدەن.
\li1 بەرپرسیار بوون لە پارێزگاری پیرۆزگا لە جیاتی نەوەی ئیسرائیل،
\li1 هەرکەسێکی دیکەش کە لە پیرۆزگا نزیک بکەوتبایەوە دەکوژرا.
\b
\li4 
\v 39 هەموو تۆمارکراوانی لێڤییەکان ئەوانەی موسا و هارون بەپێی فەرمایشتی یەزدان بەگوێرەی خێڵەکانیان تۆماریان کردن، هەموو نێرینەیەکی کوڕی یەک مانگ بەرەو سەرەوە بیست و دوو هەزار کەس بوون.
\b
\p 
\v 40 هەروەها یەزدان بە موسای فەرموو: «هەموو نێرینەیەکی نۆبەرە لە نەوەی ئیسرائیل لە کۆرپەی یەک مانگ بەرەو سەرەوە تۆمار بکە و لیستی ناوەکانیان وەربگرە.
\v 41 من یەزدانم، لێڤییەکان لە جیاتی هەموو نۆبەرەیەکی نەوەی ئیسرائیل و مەڕوماڵاتی لێڤییەکانیش لە جیاتی هەموو نۆبەرەیەک لە مەڕوماڵاتی نەوەی ئیسرائیل بۆ من دادەنێیت.»
\p 
\v 42 جا موسا وەک یەزدان فەرمانی پێ کرد هەموو نۆبەرەیەکی لە نەوەی ئیسرائیل تۆمار کرد،
\v 43 هەموو کۆرپەیەکی نۆبەرەی نێرینە لە تەمەنی یەک مانگ بەرەو سەرەوە لە لیستی ناوەکان تۆمارکران، بیست و دوو هەزار و دوو سەد و حەفتا و سێ کەس بوون.
\p 
\v 44 یەزدان بە موسای فەرموو:
\v 45 «لێڤییەکان لە جیاتی هەموو نۆبەرەیەک لە نەوەی ئیسرائیل دابنێ و مەڕوماڵاتی لێڤییەکانیش لە جیاتی مەڕوماڵاتەکانیان، جا لێڤییەکان بۆ من دەبن. من یەزدانم.
\v 46 بۆ کڕینەوەی ئەو دوو سەد و حەفتا و سێیەش لە نۆبەرەکانی نەوەی ئیسرائیل کە لە لێڤییەکان زیاترن،
\v 47 پێنج شاقل بۆ هەر سەرێک وەردەگریت، بەگوێرەی شاقلی پیرۆزگا وەریدەگریت. هەر شاقلێک بیست گێرایە.
\v 48 زیوەکەش دەدەیتە هارون و کوڕەکانی، کڕینەوەی ئەوانەیە کە لێیان زیادن.»
\p 
\v 49 جا موسا زیوی کڕینەوەیانی وەرگرت، لەوانەی لە کڕینەوەی لێڤییەکان زیاد بوون،
\v 50 لە نۆبەرەکانی نەوەی ئیسرائیل هەزار و سێ سەد و شەست و پێنج زیوی\f + \fr 3:50 \ft نزیکەی 15,5 کیلۆگرام.‏\f* بەگوێرەی شاقلی پیرۆزگا وەرگرت.
\v 51 موساش زیوی کڕینەوەکەی بە هارون و کوڕەکانی دا بەگوێرەی فەرمایشتی یەزدان، هەروەک یەزدان فەرمانی بە موسا کردبوو.
\c 4
\s1 قەهاتییەکان
\p 
\v 1 یەزدان بە موسا و هارونی فەرموو:
\v 2 «سەرژمێری نەوەی قەهات لەنێو نەوەی لێڤییەکان بکەن، بەگوێرەی خێڵەکانیان و بنەماڵەکانیان،
\v 3 لە پیاوی سی ساڵ بەرەو سەرەوە هەتا پەنجا ساڵ، هەموو ئەوانەی دەتوانن بچن بۆ خزمەت هەتا لە چادری چاوپێکەوتن کار بکەن.
\p 
\v 4 «نەوەی قەهات خزمەتی شتە هەرەپیرۆزەکانی ناو چادری چاوپێکەوتن دەکەن.
\v 5 هارون و کوڕەکانی لە کاتی کۆچکردنی ئۆردوگا دێن و پەردەکەی شوێنی هەرەپیرۆز هەڵدەگرنەوە و سندوقی شایەتی پێ دادەپۆشن.
\v 6 ئینجا پۆشەرەکەی لە پێستی مانگای دەریا بەسەردا دەدەن و لەسەر ئەوەشەوە قوماشێک هەمووی ڕیسی مۆر بێت ڕایدەخەن و دارەکانیشی دەخەنە شوێنی خۆی.
\p 
\v 7 «لەسەر مێزی نانی تەرخانکراو بۆ خودا قوماشێکی لە ڕیسی مۆر ڕادەخەن و لەگەن و قاپ و تاس و دۆلکەکانی شەرابی پێشکەشکراوی لەسەری دادەنێن و بەردەوام نانەکەی لەسەر دەبێت.
\v 8 قوماشێکی سووری ئاڵیشی لەسەر ڕادەخەن و بە پۆشەرێک لە پێستی مانگای دەریا دای دەپۆشن و دارەکانی دەخەنە شوێنی خۆی.
\p 
\v 9 «قوماشێک لە ڕیسی مۆر دەبەن و چرادانەکەی ڕووناکی و چراکانی و مەقاش و مەقەڵی و هەموو قاپوقاچاغەکانی زەیتەکەی کە خزمەتی پێ دەکەن دادەپۆشن.
\v 10 لەگەڵ هەموو قاپوقاچاغەکەی دەیخەنە ناو پۆشەرێک لە پێستی مانگای دەریا و دەیخەنە سەر هەڵگرێک.
\p 
\v 11 «لەسەر قوربانگا زێڕینەکەش قوماشێکی ڕیسی مۆر ڕادەخەن و بە پۆشەرێک لە پێستی مانگای دەریا دایدەپۆشن و دارەکانی دەخەنە شوێنی خۆی.
\p 
\v 12 «هەموو قاپوقاچاغەکانی خزمەتکردن کە خزمەتی پێ دەکەن لە پیرۆزگا دەیبەن و لەناو قوماشێکی ڕیسی مۆر دایدەنێن و بە پۆشەرێک لە پێستی مانگای دەریا دای دەپۆشن و دەیخەنە سەر هەڵگرێک.
\p 
\v 13 «خۆڵەمێشی قوربانگا بڕۆنزییەکەش هەڵدەگرن و قوماشێکی ئەرخەوانی لەسەر ڕادەخەن.
\v 14 هەموو قاپوقاچاغەکانی کە لە قوربانگاکە بۆ خزمەت بەکاریدەهێنن دەیخەنە سەری، مەقەڵییەکان، چەنگاڵەکان، خاکەنازەکان و تاسەکان\f + \fr 4:14 \ft کاهین ئەم تاسانەی بۆ پرژاندنی خوێنی قوربانی بەکاردەهێنا، وەک هێمایەک بۆ کەفارەتی گوناهەکانی خەڵک. بڕوانە \xt دەرچوون 29‏:20 و زەکەریا 9‏:15؛ 14‏:20 و عیبرانییەکان 9‏:13‏\xt*\ft ‏.‏\f*، هەموو قاپوقاچاغی قوربانگاکە، پۆشەرێک لە پێستی مانگای دەریاشی بەسەردا ڕادەخەن و دارەکانی دەخەنە شوێنی خۆی.
\p 
\v 15 «کاتێک هارون و کوڕەکانی لە پۆشینی پیرۆزگاکە و هەموو قاپوقاچاغی پیرۆزگاکە دەبنەوە، لە کاتی کۆچکردنی ئۆردوگاکە، ئینجا نەوەی قەهات بۆ هەڵگرتن دێن، بەڵام دەست لە شتە پیرۆزکراوەکان نادەن نەوەک بمرن، ئەوە بارهەڵگرتنی نەوەی قەهاتە لە چادری چاوپێکەوتن.
\p 
\v 16 «ئەلعازاری کوڕی هارونی کاهینیش سەرپەرشتی زەیتی ڕووناکی، بخوورە بۆنخۆشەکە، پێشکەشکراوی دانەوێڵەی بەردەوام و زەیتی دەستنیشانکردن دەکات. هەروەها سەرپەرشتی هەموو چادرەکەی پەرستن دەکات، هەموو ئەوەی تێیدایە، بە شتومەکە پیرۆزەکانی و قاپوقاچاغەکانییەوە.»
\p 
\v 17 هەروەها یەزدان بە موسا و هارونی فەرموو:
\v 18 «خێڵەکانی قەهاتییەکان لەنێو لێڤییەکان دامەبڕن،
\v 19 بەڵکو ئەمەیان بۆ بکەن، جا دەژین و لە کاتی نزیککەوتنەوەیان لە شتە هەرەپیرۆزەکان نامرن، هارون و کوڕەکانی دەچنە ژوورەوەی پیرۆزگاکە و هەرکەسێک لەسەر خزمەتەکەی و بارەکەی دادەنێن.
\v 20 بەڵام بۆ ساتێک قەهاتییەکان ناچنە ژوورەوە بۆ ئەوەی شتە پیرۆزکراوەکان ببینن نەوەک بمرن.»
\s1 گێرشۆنییەکان
\p 
\v 21 یەزدان بە موسای فەرموو:
\v 22 «سەرژمێری نەوەی گێرشۆنیش بکە بەگوێرەی بنەماڵە و خێڵەکانیان.
\v 23 لە پیاوی سی ساڵ بەرەو سەرەوە هەتا پەنجا ساڵ تۆمار بکە، هەموو ئەوانەی کە دێن بۆ ئەوەی لە چادری چاوپێکەوتندا خزمەت بکەن.
\p 
\v 24 «ئەمەش خزمەتی خێڵەکانی گێرشۆنییەکانە لە خزمەت و لە بارهەڵگرتن،
\v 25 پڵاسەکانی چادرەکەی پەرستن و چادری چاوپێکەوتن و پۆشەرەکەی و پۆشەرە پێست مانگای دەریاکە کە لە سەرەوە لەسەریەتی و پەردەکەی دەروازەی چادری چاوپێکەوتن هەڵدەگرن.
\v 26 هەروەها پەردەکانی حەوشەکە، ئەوانەی لە دەوری چادری پەرستن و لە دەوری قوربانگاکەن بە چواردەوریدا، پەردەی دەروازەی حەوشەکە، لەگەڵ گوریسەکانی و هەموو ئەوەی لەگەڵیدا بۆ خزمەت بەکاردەهێنرێت، هەموو ئەوەی بۆیان دیاری دەکرێت، گێرشۆنییەکان دەیکەن.
\v 27 هەموو خزمەتی نەوەی گێرشۆنییەکان چ لە بارهەڵگرتن یان هەر کارێکی دیکە بە سەرپەرشتی هارون و کوڕەکانی دەبێت، تۆش دیاریکردنی بەرپرسیاریێتی هەموو بارەکانی خۆیان پێ دەسپێریت،
\v 28 ئەمە خزمەتی خێڵەکانی نەوەی گێرشۆنییەکانە لە چادری چاوپێکەوتن و ئیتاماری کوڕی هارونی کاهین سەرپەرشتییان دەکات.
\s1 مەرارییەکان
\p 
\v 29 «نەوەی مەراری بەگوێرەی خێڵ و بنەماڵەکانیان تۆمار بکە.
\v 30 لە پیاوی سی ساڵ بەرەو سەرەوە هەتا پەنجا ساڵ تۆمار بکە، هەموو ئەوانەی دەچنە خزمەت هەتا خزمەتەکەی چادری چاوپێکەوتن بکەن.
\v 31 بەرپرسیاریێتی خزمەتەکەشیان لە چادری چاوپێکەوتن، بریتییە لە هەڵگرتنی چوارچێوەکانی چادرەکەی پەرستن و کاریتەکانی، کۆڵەکەکانی، بناغەکانی،
\v 32 کۆڵەکەکانی حەوشەکە بە چواردەوریدا، بناغەکانی، سنگەکانی و گوریسەکانی لەگەڵ هەموو قاپوقاچاغ و هەموو ئەوەی لەگەڵیدا بەکاردەهێنرێت. بە ناویش هەر پیاوێک دیاری بکە بۆ ئەو شتەی پێویستە هەڵیبگرێت.
\v 33 ئەمە خزمەتی خێڵەکانی نەوەی مەرارییە، هەموو خزمەتەکەیان لە چادری چاوپێکەوتن بە سەرپەرشتی ئیتامار کوڕی هارونی کاهینە.»
\s1 تۆمارکردنی خێڵەکانی لێڤییەکان
\li1 
\v 34 جا موسا و هارون و ڕابەرەکانی کۆمەڵ نەوەی قەهاتییەکانیان تۆمار کرد، بەگوێرەی خێڵەکانیان و بنەماڵەکانیان،
\li2 
\v 35 لە پیاوی سی ساڵ بەرەو سەرەوە هەتا پەنجا ساڵ، هەموو ئەوانەی دەچنە خزمەتەوە بۆ خزمەتکردن لە چادری چاوپێکەوتن.
\v 36 جا تۆمارکراوەکانیان بەگوێرەی خێڵەکانیان دوو هەزار و حەوت سەد و پەنجا کەس بوون.
\v 37 ئەوانە تۆمارکراوەکانن لە خێڵەکانی قەهاتییەکان، هەموو ئەوانەی لە چادری چاوپێکەوتندا خزمەت دەکەن، ئەوانەی موسا و هارون بەگوێرەی فەرمایشتی یەزدان لەسەر دەستی موسا تۆماریان کردن.
\b
\li1 
\v 38 تۆمارکراوەکانی نەوەی گێرشۆنیش بەگوێرەی خێڵەکانیان و بنەماڵەکانیان،
\li2 
\v 39 لە پیاوی سی ساڵ بەرەو سەرەوە هەتا پەنجا ساڵ، هەموو ئەوانەی دەچنە خزمەتەوە بۆ خزمەتکردن لە چادری چاوپێکەوتن،
\v 40 تۆمارکراوەکانیان بەگوێرەی خێڵەکانیان و بنەماڵەکانیان دوو هەزار و شەش سەد و سی کەس بوون.
\v 41 ئەوانە تۆمارکراوەکانن لە خێڵەکانی نەوەی گێرشۆن، هەموو ئەوانەی لە چادری چاوپێکەوتندا خزمەت دەکەن، ئەوانەی موسا و هارون بەگوێرەی فەرمایشتی یەزدان تۆماریان کردن.
\b
\li1 
\v 42 تۆمارکراوان لە خێڵەکانی نەوەی مەراریش بەگوێرەی خێڵەکانیان و بنەماڵەکانیان
\li2 
\v 43 لە پیاوی سی ساڵ بەرەو سەرەوە هەتا پەنجا ساڵ، هەموو ئەوانەی دەچنە خزمەتەوە بۆ خزمەتکردن لە چادری چاوپێکەوتندا،
\v 44 تۆمارکراوەکانیان بەگوێرەی خێڵەکانیان سێ هەزار و دوو سەد کەس بوون.
\v 45 ئەوانە تۆمارکراوەکانن لە خێڵەکانی نەوەی مەراری کە موسا و هارون بەگوێرەی فەرمایشتی یەزدان لەسەر دەستی موسا تۆماریان کردن.
\b
\li4 
\v 46 هەموو تۆمارکراوەکانی لێڤییەکان کە موسا و هارون و سەرکردەکانی ئیسرائیل تۆماریان کردن بەگوێرەی خێڵەکانیان و بنەماڵەکانیان،
\v 47 لە پیاوی سی ساڵ بەرەو سەرەوە هەتا پەنجا ساڵ، هەموو ئەوانەی دەچنە خزمەتەوە بۆ کاری خزمەت و کاری بارهەڵگرتن لە چادری چاوپێکەوتندا،
\v 48 تۆمارکراوان لێیان هەشت هەزار و پێنج سەد و هەشتا کەس بوون.
\v 49 بەپێی فەرمایشتی یەزدان لەسەر دەستی موسا، هەرکەسێک بەگوێرەی خزمەتەکەی و بارهەڵگرتنەکەی تۆمارکرا.
\b
\p بەم شێوەیە موسا تۆماری کردن وەک چۆن یەزدان فەرمانی پێ کرد.
\c 5
\s1 پاکی ئۆردوگاکە
\p 
\v 1 یەزدان بە موسای فەرموو:
\v 2 «فەرمان بە نەوەی ئیسرائیل بکە کە هەرکەسێک نەخۆشی گواستراوەی پێست یان ئەوەی لێچوونی گڵاوی\f + \fr 5:2 \ft لێچوونی گڵاوی: بڕوانە \xt لێڤییەکان 15‏\xt*\ft ‏.‏\f* هەبێت، یان ئەوەی بە مردوو گڵاو بووبێت، لە ئۆردوگاکە دووریان بخەنەوە.
\v 3 نێر و مێ دوور دەخەنەوە، بۆ دەرەوەی ئۆردوگا دووریان دەخەنەوە هەتا ئۆردوگاکانیان گڵاو نەکەن کە من لەنێویاندا نیشتەجێم.»
\v 4 جا نەوەی ئیسرائیل ئاوایان کرد و بۆ دەرەوەی ئۆردوگاکە دووریان خستنەوە، هەروەک چۆن یەزدان لەگەڵ موسادا دوا، نەوەی ئیسرائیل ئاوایان کرد.
\s1 قەرەبووکردنەوەی گوناه
\p 
\v 5 یەزدان بە موسای فەرموو:
\v 6 «بە نەوەی ئیسرائیل بڵێ: ”ئەگەر پیاوێک یان ئافرەتێک گوناهێک لە گوناهەکانی مرۆڤ بکات، واتا ناپاکی لەگەڵ یەزدان کرد، ئەوا ئەو کەسە تاوانی کردووە،
\v 7 با دان بە گوناهەکەیدا بنێت کە کردوویەتی و ئەوەی پێی تاوانبار بووە بە تەواوی بیگەڕێنێتەوە، پێنج یەکیشی بۆ زیاد بکات و بیداتە ئەوەی تاوانەکەی لە دژی کردووە.
\v 8 بەڵام ئەگەر ئەو کەسە مردوو بوو و خزمی نزیکی نەبوو هەتا وەریبگرێتەوە، ئەوا ئەوەی پێی تاوانبار بووە دەگەڕێتەوە بۆ یەزدان و بۆ کاهین دەبێت، لەگەڵ بەرانێک کە کەفارەتی پێ دەکات بۆی.
\v 9 هەموو پیتاکێک و دیارییەکی پیرۆزی نەوەی ئیسرائیل کە پێشکەشی کاهینی دەکەن بۆ ئەو دەبێت.
\v 10 هەموو دیارییە پیرۆزکراوەکانی مرۆڤیش بۆ خۆی دەبێت، بەڵام ئەگەر کەسێک شتێکی دا بە کاهین ئەوا بۆ کاهین دەبێت.“»
\s1 سەلماندنی داوێنپاکی ژن
\p 
\v 11 یەزدان بە موسای فەرموو:
\v 12 «لەگەڵ نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”ئەگەر ژنی پیاوێک لەڕێ لایدا و ناپاکی لەگەڵ کرد،
\v 13 لەگەڵ پیاوێک جووت بوو، ئەوەش لە چاوانی پیاوەکەی شاردراوە بوو و داوێنپیسییەکەی\f + \fr 5:13 \ft داوێنپیسییەکەی: لە عیبری نووسراوە (گڵاو) بەو مەبەستەی داوێنپیسی گڵاوییە، هەروەها لە ئایەتەکانی 14 و 19.‏\f* ئاشکرا نەبوو، هیچ شایەتێکیشی بەسەرەوە نەبوو، چونکە لەسەر کردارەکە نەگیرا بوو،
\v 14 کابراش ڕۆحی دڵپیسی دایگرت و لە ژنەکەی بە گومان بوو کە داوێنپیسە، یان ڕۆحی دڵپیسی دایگرت و لە ژنەکەی بە گومان بوو کە داوێنپیس نییە،
\v 15 ئەوا پیاوەکە ژنەکەی دەهێنێتە لای کاهین و پێشکەشکراوەکەشی لەگەڵدا دەهێنێت، دەیەکی ئێفەیەک\f + \fr 5:15 \ft دەیەکی ئێفەیەک: نزیکەی دوو لیتر.‏\f* ئاردی جۆ نە زەیتی بەسەردا دەکات و نە بخوور، چونکە پێشکەشکراوی دانەوێڵەی دڵپیسییە و قوربانی یادگارییە، یادی تاوان دەکاتەوە.
\p 
\v 16 «”کاهینەکە ژنەکە دەهێنێتە پێش و لەبەردەم یەزدان ڕایدەگرێت.
\v 17 کاهینەکە لە گۆزەیەکی گڵین ئاوێکی پیرۆز دەبات و لە تۆزی سەر زەوی چادرەکەی پەرستن هەڵدەگرێت و لەناو ئاوەکەی دەکات.
\v 18 کاهینەکە ژنەکە لەبەردەم یەزدان ڕادەگرێت و سەری ڕووت دەکاتەوە، پێشکەشکراوی دانەوێڵەی یادەوەرییەکە کە پێشکەشکراوی دانەوێڵەی دڵپیسییە دەکاتە ناو دەستی ژنەکە و ئاوە تاڵەکەی نەفرەتیش لە دەستی کاهینەکە دەبێت.
\v 19 ئینجا کاهینەکە ژنەکە سوێند دەدات و پێی دەڵێت: ’ئەگەر هیچ پیاوێک لەگەڵت جووت نەبووە و بە دزی پیاوەکەت بەرەو داوێنپیسی لەڕێ لات نەداوە، لە کاتێکدا ژنی پیاوەکەتی ئەوا بێتاوان بە لەم ئاوەی نەفرەت کە تاڵە.
\v 20 بەڵام ئەگەر بە دزی پیاوەکەت لەڕێ لاتداوە و گڵاو بوویت و پیاوێکی دیکە جیا لە مێردەکەت لەگەڵت جووت بووە،‘
\v 21 لێرە کاهینەکە ژنەکە بە سوێندی نەفرەت سوێند دەدات، کاهینەکە بە ژنەکە دەڵێت، ’یەزدان دەتخاتە بەر نەفرەت و سوێند لەنێو گەلەکەت بەوەی کە یەزدان ڕانت لاواز دەکات و سکت دەئاوسێنێت\f + \fr 5:21 \ft ڕانت لاواز دەکات و سکت دەئاوسێنێت: واتا لە سک و زایین دەکەوێت، هەروەها نەزۆک دەبێت.‏\f*.
\v 22 ئەم ئاوەی نەفرەت دەچێتە ناو هەناوت بۆ ئاوسانی سک و لاوازی ڕان.‘
\p «”ژنەش دەڵێت، ’ئامین، ئامین.‘
\p 
\v 23 «”کاهینیش ئەم نەفرەتانە لە پەڕەیەک دەنووسێت، ئینجا لەناو ئاوە تاڵەکە دەیشواتەوە.
\v 24 ئاوە تاڵەکەی نەفرەتیش دەرخواردی ژنەکە دەدات، ئاوەکەی نەفرەتیش دەچێتە ناوی و دەبێتە ئازاری تاڵی.
\v 25 کاهینەکە پێشکەشکراوی دانەوێڵەی دڵپیسییەکە لە دەستی ژنەکە وەردەگرێت و پێشکەشکراوەکە لەبەردەم یەزدان بەرز دەکاتەوە، ئینجا دەیباتە لای قوربانگاکە.
\v 26 کاهینەکە چنگێک بۆ یادەوەری لە دانەوێڵە پێشکەشکراوەکە دەبات و لەسەر قوربانگاکە دەیسووتێنێت، لەدوای ئەوە ئاوەکە دەرخواردی ژنەکە دەدات.
\v 27 ئەگەر ژنەکە گڵاو بووبێت و ناپاکی لە پیاوەکەی کردبێت، کاتێک ئاوەکەی دەرخوارد دا، ئەوا ئاوە نەفرەتەکە دەبێتە ئازاری تاڵی، دەچێتە ناوی، سکی دەئاوسێت و ڕانی دەکەوێت، ژنەکە لەنێو گەلەکەی دەبێتە نەفرەت.
\v 28 ئەگەر ژنەکەش گڵاو نەببوو بەڵکو پاک بوو، ئەوا بێتاوان دەبێت و سکی پڕ دەبێت.
\p 
\v 29 «”ئەمە فێرکردنەکەیە سەبارەت بە دڵپیسی، ئەگەر ژنێک بە دزی پیاوەکەی لەڕێ لایدا و گڵاو بوو، لە کاتێکدا ژنی پیاوەکەیەتی،
\v 30 یان ئەگەر پیاوێک ڕۆحی دڵپیسی دایگرت، جا دڵی لە ژنەکەی پیس کرد، ژنەکە لەبەردەم یەزدان ڕادەگیرێت و کاهینەکە هەموو ئەم فێرکردنەی بۆ دەکات.
\v 31 جا پیاوەکە لە هەر هەڵەیەک بێتاوان دەبێت، بەڵام ئەو ژنە تاوانی گوناهی لە ئەستۆی خۆی هەڵدەگرێت.“»
\c 6
\s1 نەزرکردن
\p 
\v 1 یەزدان بە موسای فەرموو:
\v 2 «لەگەڵ نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”ئەگەر پیاوێک یان ژنێک سوێندێکی تایبەتی خوارد بەوەی نەزر\f + \fr 6:2 \ft نەزر: (ئاد)یشی پێ دەگوترێت، داوا لە خودا دەکەیت بۆ ئەنجامدانی کارێک، کارەکە پابەند دەکەیت بە مەرجێکەوە. داوا دەکەیت ئەگەر خودا ئەو کارەم بۆ ئەنجام بدات، ئەوا دەرئەنجام منیش ئەو کارەی بۆ ئەنجام دەدەم. بڕوانە \xt سەرژمێری 21‏:2‏\xt*\ft ‏.‏\f* بکات، خۆی بۆ یەزدان تەرخان بکات.
\v 3 لە شەراب و مەی خۆی دوور دەخاتەوە و سرکەی شەراب و سرکەی مەی ناخواتەوە و خۆشاوی ترێ ناخواتەوە و ترێ و کشمیش ناخوات.
\v 4 هەموو ڕۆژانی خۆتەرخانکردنەکەی هیچ شتێک لە هەموو ئەوەی لە بەری مێو دروستدەکرێت ناخوات، تەنانەت تۆو و توێکڵیش.
\p 
\v 5 «”هەموو ڕۆژانی نەزر و خۆتەرخانکردنەکەی گوێزان بە سەریدا ناهێنرێت، پێویستە هەتا تەواوی ئەو ڕۆژانەی خۆی تەرخان کردووە بۆ یەزدان، پیرۆز بێت و قژی بهێڵێتەوە.
\p 
\v 6 «”هەموو ڕۆژانی خۆتەرخانکردنەکەی بۆ یەزدان لە لاشەی مردوو نزیک ناکەوێتەوە،
\v 7 بۆ دایک و باوک و برا و خوشکیشی، خۆی گڵاو ناکات لە کاتی مردنیان، چونکە خۆتەرخانکردنی بۆ خودای خۆی بەسەر سەرەوەیە.
\v 8 هەموو ڕۆژانی خۆتەرخانکردنەکەی بۆ یەزدان پیرۆز دەبێت.
\p 
\v 9 «”ئەگەر یەکێکیش کتوپڕ لەلای مرد و قژە تەرخانکراوەکەی گڵاوکرد، ئەوا لە ڕۆژی پاکبوونەوەکەی سەری دەتاشێت، لە ڕۆژی حەوتەم دەیتاشێت.
\v 10 لە ڕۆژی هەشتەمیش دوو کوکوختی یان دوو بێچووە کۆتر دەهێنێتە لای کاهین بۆ دەروازەی چادری چاوپێکەوتن.
\v 11 کاهینیش یەکێکیان دەکاتە قوربانی گوناه و ئەوەی دیکە قوربانی سووتاندن و کەفارەتی بۆ دەکات لەو گوناهەی بەهۆی ئەو مردووەوە کردوویەتی و لەو ڕۆژەدا سەری تەرخان دەکاتەوە.
\v 12 کاتێک ڕۆژانی خۆتەرخانکردنەکەی بۆ یەزدان تەرخان کردەوە، ئەوا بەرخێکی نێری یەک ساڵە وەک قوربانی تاوان دەهێنێت، بەڵام ڕۆژەکانی پێشتری هەژمارد ناکرێت، چونکە خۆتەرخانکردنەکەی گڵاو کردووە.
\p 
\v 13 «”ئەمەش فێرکردنەکەیە دەربارەی ئەوەی خۆی تەرخان دەکات، ئەو ڕۆژەی ڕۆژانی خۆتەرخانکردنەکەی تەواو دەبێت دەهێنرێتە لای دەروازەی چادری چاوپێکەوتن.
\v 14 جا قوربانییەکەی بۆ یەزدان پێشکەش دەکات، بەرخێکی نێری یەک ساڵەی ساغ بۆ قوربانی سووتاندن، بەرخێکی مێیەی یەک ساڵەی ساغ بۆ قوربانی گوناه، بەرانێکی بێ کەموکوڕی بۆ قوربانی هاوبەشی\f + \fr 6:14 \ft قوربانی هاوبەشی: ئەم قوربانییە هاودەمی قوربانی سووتاندن بوو. تەنها یەک کەس هەڵدەستا بە دابینکردنی ئەم قوربانییە، بەڵام لەگەڵ خەڵکی دیکە بەشی زۆری ئەم قوربانییەیان لەبەردەم خودا دەخوارد وەک هێمایەک بۆ پێکەوە ژیان. بڕوانە \xt لێڤییەکان 7‏:11‏-15.‏\xt*\ft ‏\f*،
\v 15 سەبەتەیەک نان بەبێ هەویرترش\f + \fr 6:15 \ft هەویرترش: لە جیاتی خومرە بۆ هەوێن بەکارهاتووە.‏\f*، کولێرە بە باشترین ئارد، زەیت شێلراو و ناسکە نانی\f + \fr 6:15 \ft ناسکە نان: ناوەشکێنە.‏\f* بە زەیت چەورکراو، لەگەڵ پێشکەشکراوی دانەوێڵەیان و شەرابی پێشکەشکراویان.
\p 
\v 16 «”جا کاهین لەبەردەم یەزدان پێشکەشی دەکات، قوربانی گوناهەکە و قوربانی سووتاندنەکەی دەکات،
\v 17 کاهینەکە سەبەتە نانە فەتیرەکە و بەرانەکەش دەکاتە قوربانی هاوبەشی بۆ یەزدان، لەگەڵ پێشکەشکراوی دانەوێڵە و شەرابی پێشکەشکراو.
\p 
\v 18 «”لەدوای ئەوە لەلای دەروازەی چادری چاوپێکەوتن خۆتەرخانکەرەکە سەرە تەرخانکراوەکەی دەتاشێت و مووی سەرە تەرخانکراوەکەی دەبات و دەیکاتە سەر ئەو ئاگرەی لەژێر قوربانییەکەی هاوبەشییە.
\p 
\v 19 «”پاش ئەوەی خۆتەرخانکەرەکە قژی خۆتەرخانکردنەکەی دەتاشێت، کاهینەکە شانی بەرانەکە بە کوڵاوی و کولێرەیەکی فەتیرە لە سەبەتەکە لەگەڵ ناسکە نانێکی فەتیرە دەبات و دەیانخاتە ناو دەستی خۆتەرخانکەرەکە.
\v 20 کاهینیش لەبەردەم یەزدان وەک قوربانی بەرزکردنەوە بەرزیان دەکاتەوە، ئەو بەشە بۆ کاهین پیرۆزکراوە لەگەڵ سنگی بەرزکراوە و ڕانەکەی کە پێشکەشکراوە، ئینجا ئەوەی خۆی تەرخان کردووە شەراب دەخواتەوە.
\p 
\v 21 «”ئەمە فێرکردنەکەیە دەربارەی خۆتەرخانکەر کە نەزر دەکات، قوربانییەکەی\f + \fr 6:21 \ft سەرباری ئەو قوربانییانەی کە دانراوە بکرێت کەسەکە قوربانییەکی خۆویستانە دەکات، بەهاکەی بەگوێرەی توانای کەسەکە دەبێت.‏\f* بۆ یەزدانە سەرباری خۆتەرخانکردنەکەی، بەگوێرەی ئەو نەزرەی کە کردی، ئاوا دەکات بەگوێرەی فێرکردنی خۆتەرخانکردنەکەی.“»
\s1 بەرەکەتی کاهین
\p 
\v 22 یەزدان بە موسای فەرموو:
\v 23 «لەگەڵ هارون و کوڕەکانی بدوێ و بڵێ: ”بەم شێوەیە داوای بەرەکەت دەکەن بۆ نەوەی ئیسرائیل. پێیان دەڵێن:
\q1 
\v 24 «” ’با یەزدان بەرەکەتدارت بکات و
\q2 بتپارێزێت.
\q1 
\v 25 با ڕووی یەزدان بەسەرتدا بدرەوشێتەوە و
\q2 لەگەڵت میهرەبان بێت.
\q1 
\v 26 با یەزدان ئاوڕت لێ بداتەوە و
\q2 ئاشتیت پێ ببەخشێت.‘ “
\p 
\v 27 «جا ناوم لەسەر نەوەی ئیسرائیل دادەنێن و منیش بەرەکەتداریان دەکەم.»
\c 7
\s1 پێشکەشکراوەکان بۆ تەرخانکردنی قوربانگا
\p 
\v 1 ئەو ڕۆژەی کە موسا لە دانانی چادرەکەی پەرستن تەواو بوو، دەستنیشانی کرد و تەرخانی کرد لەگەڵ هەموو کەلوپەلەکانی، هەروەها قوربانگاکەش و هەموو قاپوقاچاغەکانی دەستنیشان کرد و تەرخانی کرد.
\v 2 ئینجا سەرۆکەکانی ئیسرائیل، گەورەی بنەماڵەکانیان کە سەرۆکی هۆزەکان بوون، بەرپرسیار بوون لەسەر تۆمارکراوەکان، پێشکەشکراوەکانیان بەخشی.
\v 3 دیارییەکانیان هێنایە بەردەم یەزدان، شەش عەرەبانەی داپۆشراو و دوازدە گای خەساو\f + \fr 7:3 \ft گای خەساو توانای زاوزێکردنی نییە، هەروەها تایبەت دانراوە بۆ کارکردن.‏\f*، هەر عەرەبانەیەک بۆ دوو سەرۆک و بۆ هەر یەکێکیان گایەکی خەساو، کە هێنایان بۆ بەردەم چادرەکەی پەرستن.
\p 
\v 4 جا یەزدان بە موسای فەرموو:
\v 5 «لێیان وەربگرە بۆ کاری خزمەتی چادری چاوپێکەوتن دەبن و بیدە بە لێڤییەکان، بۆ هەر یەکێک بەگوێرەی خزمەتەکەی.»
\p 
\v 6 موساش عەرەبانەکان و گایە خەساوەکانی وەرگرت و بە لێڤییەکانی دا.
\v 7 دووان لە عەرەبانەکان و چوار گای خەساوی بە نەوەی گێرشۆن دا بەگوێرەی خزمەتیان،
\v 8 چوار لە عەرەبانەکان و هەشت گای خەساوی بە نەوەی مەراری دا بەگوێرەی خزمەتیان لەژێر سەرپەرشتی ئیتاماری کوڕی هارونی کاهین.
\v 9 بەڵام موسا هیچی نەدا بە نەوەی قەهات، چونکە خزمەتی شتە پیرۆزکراوەکان لە ئەستۆی ئەوان بوو، لەسەر شانەکانیان هەڵیاندەگرت.
\p 
\v 10 سەرۆکەکانیش بۆ تەرخانکردنی قوربانگاکە لە ڕۆژانی دەستنیشانکردنی دیارییان دەهێنا و لەبەردەم قوربانگاکە پێشکەشیان دەکرد.
\v 11 یەزدانیش بە موسای فەرمووبوو: «هەموو ڕۆژێک یەکێک لە سەرۆکەکان پێشکەشکراوەکەی دەهێنێت بۆ تەرخانکردنی قوربانگاکە.»
\b
\m 
\v 12 ئەوەی ڕۆژی یەکەم پێشکەشکراوەکەی هێنا نەحشۆنی کوڕی عەمیناداب بوو لە هۆزی یەهودا.
\mi1 
\v 13 پێشکەشکراوەکەشی لەگەنێک بوو لە زیو کە کێشەکەی سەد و سی شاقل\f + \fr 7:13 \ft نزیکەی 1,5 کیلۆگرام.‏\f* بوو، تاسێک لە زیو کێشەکەی حەفتا شاقل\f + \fr 7:13 \ft نزیکەی 0,8 کیلۆگرام.‏\f* بوو بە شاقلی پیرۆزگا، هەردووکیان پڕ بوون لە باشترین ئاردی بە زەیت شێلراو وەک پێشکەشکراوی دانەوێڵە؛
\v 14 قاپێکی زێڕ کێشەکەی دە شاقل و پڕ لە بخوور؛
\v 15 یەک جوانەگا\f + \fr 7:15 \ft لەو کاتەوەی کە گوێرەکەی نێر لە شیر دەبڕدرێتەوە پێی دەگوترێت (نۆبەن) یان (جوانەگا).‏\f* و بەرانێک و بەرخێکی نێری یەک ساڵە بۆ قوربانی سووتاندن؛
\v 16 گیسکێکی نێرینە بۆ قوربانی گوناه؛
\v 17 بۆ قوربانی هاوبەشیش دوو گا و پێنج بەران و پێنج تەگە\f + \fr 7:17 \ft نێری، سابرێن.‏\f* و پێنج بەرخی نێری یەک ساڵە. ئەمە پێشکەشکراوی نەحشۆنی کوڕی عەمینادابە.
\b
\m 
\v 18 لە ڕۆژی دووەمدا نەتەنێلی کوڕی چوعەر سەرۆکی یەساخار پێشکەشکراوەکەی هێنا.
\mi1 
\v 19 پێشکەشکراوەکەی کە هێنابووی لەگەنێک بوو لە زیو کە کێشەکەی سەد و سی شاقل بوو، تاسێک لە زیو کێشەکەی حەفتا شاقل بوو بە شاقلی پیرۆزگا، هەردووکیان پڕ بوون لە باشترین ئاردی بە زەیت شێلراو وەک پێشکەشکراوی دانەوێڵە؛
\v 20 قاپێکی زێڕ کێشەکەی دە شاقل و پڕ لە بخوور؛
\v 21 یەک جوانەگا و بەرانێک و بەرخێکی نێری یەک ساڵە بۆ قوربانی سووتاندن؛
\v 22 گیسکێکی نێرینە بۆ قوربانی گوناه؛
\v 23 بۆ قوربانی هاوبەشیش دوو گا و پێنج بەران و پێنج تەگە و پێنج بەرخی نێری یەک ساڵە. ئەمە پێشکەشکراوی نەتەنێلی کوڕی چوعەرە.
\b
\m 
\v 24 لە ڕۆژی سێیەمدا سەرۆکی نەوەی زەبولون، ئەلیابی کوڕی حێلۆن، پێشکەشکراوەکەی هێنا.
\mi1 
\v 25 پێشکەشکراوەکەشی لەگەنێک بوو لە زیو کە کێشەکەی سەد و سی شاقل بوو، تاسێک لە زیو کێشەکەی حەفتا شاقل بوو بە شاقلی پیرۆزگا، هەردووکیان پڕ بوون لە باشترین ئاردی بە زەیت شێلراو وەک پێشکەشکراوی دانەوێڵە؛
\v 26 قاپێکی زێڕ کێشەکەی دە شاقل و پڕ لە بخوور؛
\v 27 یەک جوانەگا و بەرانێک و بەرخێکی نێری یەک ساڵە بۆ قوربانی سووتاندن؛
\v 28 گیسکێکی نێرینە بۆ قوربانی گوناه؛
\v 29 بۆ قوربانی هاوبەشیش دوو گا و پێنج بەران و پێنج تەگە و پێنج بەرخی نێری یەک ساڵە. ئەمە پێشکەشکراوی ئەلیابی کوڕی حێلۆنە.
\b
\m 
\v 30 لە ڕۆژی چوارەمدا سەرۆکی نەوەی ڕەئوبێن، ئەلیسوری کوڕی شەدیئور، پێشکەشکراوەکەی هێنا.
\mi1 
\v 31 پێشکەشکراوەکەشی لەگەنێک بوو لە زیو کە کێشەکەی سەد و سی شاقل بوو، تاسێک لە زیو کێشەکەی حەفتا شاقل بوو بە شاقلی پیرۆزگا، هەردووکیان پڕ بوون لە باشترین ئاردی بە زەیت شێلراو وەک پێشکەشکراوی دانەوێڵە؛
\v 32 قاپێکی زێڕ کێشەکەی دە شاقل و پڕ لە بخوور؛
\v 33 یەک جوانەگا و بەرانێک و بەرخێکی نێری یەک ساڵە بۆ قوربانی سووتاندن؛
\v 34 گیسکێکی نێرینە بۆ قوربانی گوناه؛
\v 35 بۆ قوربانی هاوبەشیش دوو گا و پێنج بەران و پێنج تەگە و پێنج بەرخی نێری یەک ساڵە. ئەمە پێشکەشکراوی ئەلیسوری کوڕی شەدیئورە.
\b
\m 
\v 36 لە ڕۆژی پێنجەمدا سەرۆکی نەوەی شیمۆن، شەلومیێلی کوڕی چووریشەدای، پێشکەشکراوەکەی هێنا.
\mi1 
\v 37 پێشکەشکراوەکەشی لەگەنێک بوو لە زیو کە کێشەکەی سەد و سی شاقل بوو، تاسێک لە زیو کێشەکەی حەفتا شاقل بوو بە شاقلی پیرۆزگا، هەردووکیان پڕ بوون لە باشترین ئاردی بە زەیت شێلراو وەک پێشکەشکراوی دانەوێڵە؛
\v 38 قاپێکی زێڕ کێشەکەی دە شاقل و پڕ لە بخوور؛
\v 39 یەک جوانەگا و بەرانێک و بەرخێکی نێری یەک ساڵە بۆ قوربانی سووتاندن؛
\v 40 گیسکێکی نێرینە بۆ قوربانی گوناه؛
\v 41 بۆ قوربانی هاوبەشیش دوو گا و پێنج بەران و پێنج تەگە و پێنج بەرخی نێری یەک ساڵە. ئەمە پێشکەشکراوی شەلومیێلی کوڕی چووریشەدایە.
\b
\m 
\v 42 لە ڕۆژی شەشەمدا سەرۆکی نەوەی گاد، ئەلیاسافی کوڕی دەعوئێل، پێشکەشکراوەکەی هێنا.
\mi1 
\v 43 پێشکەشکراوەکەشی لەگەنێک بوو لە زیو کە کێشەکەی سەد و سی شاقل بوو، تاسێک لە زیو کێشەکەی حەفتا شاقل بوو بە شاقلی پیرۆزگا، هەردووکیان پڕ بوون لە باشترین ئاردی بە زەیت شێلراو وەک پێشکەشکراوی دانەوێڵە؛
\v 44 قاپێکی زێڕ کێشەکەی دە شاقل و پڕ لە بخوور؛
\v 45 یەک جوانەگا و بەرانێک و بەرخێکی نێری یەک ساڵە بۆ قوربانی سووتاندن؛
\v 46 گیسکێکی نێرینە بۆ قوربانی گوناه؛
\v 47 بۆ قوربانی هاوبەشیش دوو گا و پێنج بەران و پێنج تەگە و پێنج بەرخی نێری یەک ساڵە. ئەمە پێشکەشکراوی ئەلیاسافی کوڕی دەعوئێلە.
\b
\m 
\v 48 لە ڕۆژی حەوتەم سەرۆکی نەوەی ئەفرایم، ئەلیشاماعی کوڕی عەمیهود، پێشکەشکراوەکەی هێنا.
\mi1 
\v 49 پێشکەشکراوەکەشی لەگەنێک بوو لە زیو کە کێشەکەی سەد و سی شاقل بوو، تاسێک لە زیو کێشەکەی حەفتا شاقل بوو بە شاقلی پیرۆزگا، هەردووکیان پڕ بوون لە باشترین ئاردی بە زەیت شێلراو وەک پێشکەشکراوی دانەوێڵە؛
\v 50 قاپێکی زێڕ کێشەکەی دە شاقل و پڕ لە بخوور؛
\v 51 یەک جوانەگا و بەرانێک و بەرخێکی نێری یەک ساڵە بۆ قوربانی سووتاندن؛
\v 52 گیسکێکی نێرینە بۆ قوربانی گوناه؛
\v 53 بۆ قوربانی هاوبەشیش دوو گا و پێنج بەران و پێنج تەگە و پێنج بەرخی نێری یەک ساڵە. ئەمە پێشکەشکراوی ئەلیشاماع کوڕی عەمیهودە.
\b
\m 
\v 54 لە ڕۆژی هەشتەمدا سەرۆکی نەوەی مەنەشە، گەمالائیلی کوڕی پەداهچوور، پێشکەشکراوەکەی هێنا.
\mi1 
\v 55 پێشکەشکراوەکەشی لەگەنێک بوو لە زیو کە کێشەکەی سەد و سی شاقل بوو، تاسێک لە زیو کێشەکەی حەفتا شاقل بوو بە شاقلی پیرۆزگا، هەردووکیان پڕ بوون لە باشترین ئاردی بە زەیت شێلراو وەک پێشکەشکراوی دانەوێڵە؛
\v 56 قاپێکی زێڕ کێشەکەی دە شاقل و پڕ لە بخوور؛
\v 57 یەک جوانەگا و بەرانێک و بەرخێکی نێری یەک ساڵە بۆ قوربانی سووتاندن؛
\v 58 گیسکێکی نێرینە بۆ قوربانی گوناه؛
\v 59 بۆ قوربانی هاوبەشیش دوو گا و پێنج بەران و پێنج تەگە و پێنج بەرخی نێری یەک ساڵە. ئەمە پێشکەشکراوی گەمالائیلی کوڕی پەداهچوورە.
\b
\m 
\v 60 لە ڕۆژی نۆیەم سەرۆکی نەوەی بنیامین، ئەبیدانی کوڕی گدعۆنی، پێشکەشکراوەکەی هێنا.
\mi1 
\v 61 پێشکەشکراوەکەشی لەگەنێک بوو لە زیو کە کێشەکەی سەد و سی شاقل بوو، تاسێک لە زیو کێشەکەی حەفتا شاقل بوو بە شاقلی پیرۆزگا، هەردووکیان پڕ بوون لە باشترین ئاردی بە زەیت شێلراو وەک پێشکەشکراوی دانەوێڵە؛
\v 62 قاپێکی زێڕ کێشەکەی دە شاقل و پڕ لە بخوور؛
\v 63 یەک جوانەگا و بەرانێک و بەرخێکی نێری یەک ساڵە بۆ قوربانی سووتاندن؛
\v 64 گیسکێکی نێرینە بۆ قوربانی گوناه؛
\v 65 بۆ قوربانی هاوبەشیش دوو گا و پێنج بەران و پێنج تەگە و پێنج بەرخی نێری یەک ساڵە. ئەمە پێشکەشکراوی ئەبیدانی کوڕی گدعۆنییە.
\b
\m 
\v 66 لە ڕۆژی دەیەمدا سەرۆکی نەوەی دان، ئەحیعەزەری کوڕی عەمیشەدای، پێشکەشکراوەکەی هێنا.
\mi1 
\v 67 پێشکەشکراوەکەشی لەگەنێک بوو لە زیو کە کێشەکەی سەد و سی شاقل بوو، تاسێک لە زیو کێشەکەی حەفتا شاقل بوو بە شاقلی پیرۆزگا، هەردووکیان پڕ بوون لە باشترین ئاردی بە زەیت شێلراو وەک پێشکەشکراوی دانەوێڵە؛
\v 68 قاپێکی زێڕ کێشەکەی دە شاقل و پڕ لە بخوور؛
\v 69 یەک جوانەگا و بەرانێک و بەرخێکی نێری یەک ساڵە بۆ قوربانی سووتاندن؛
\v 70 گیسکێکی نێرینە بۆ قوربانی گوناه؛
\v 71 بۆ قوربانی هاوبەشیش دوو گا و پێنج بەران و پێنج تەگە و پێنج بەرخی نێری یەک ساڵە. ئەمە پێشکەشکراوی ئەحیعەزەری کوڕی عەمیشەدایە.
\b
\m 
\v 72 لە ڕۆژی یازدەیەم سەرۆکی نەوەی ئاشێر، پەگعیێلی کوڕی عۆخران، پێشکەشکراوەکەی هێنا.
\mi1 
\v 73 پێشکەشکراوەکەشی لەگەنێک بوو لە زیو کە کێشەکەی سەد و سی شاقل بوو، تاسێک لە زیو کێشەکەی حەفتا شاقل بوو بە شاقلی پیرۆزگا، هەردووکیان پڕ بوون لە باشترین ئاردی بە زەیت شێلراو وەک پێشکەشکراوی دانەوێڵە؛
\v 74 قاپێکی زێڕ کێشەکەی دە شاقل و پڕ لە بخوور؛
\v 75 یەک جوانەگا و بەرانێک و بەرخێکی نێری یەک ساڵە بۆ قوربانی سووتاندن؛
\v 76 گیسکێکی نێرینە بۆ قوربانی گوناه؛
\v 77 بۆ قوربانی هاوبەشیش دوو گا و پێنج بەران و پێنج تەگە و پێنج بەرخی نێری یەک ساڵە. ئەمە پێشکەشکراوی پەگعیێلی کوڕی عۆخرانە.
\b
\m 
\v 78 لە ڕۆژی دوازدەیەمدا سەرۆکی نەوەی نەفتالی، ئەحیڕەعی کوڕی عێینان، پێشکەشکراوەکەی هێنا.
\mi1 
\v 79 پێشکەشکراوەکەشی لەگەنێک بوو لە زیو کە کێشەکەی سەد و سی شاقل بوو، تاسێک لە زیو کێشەکەی حەفتا شاقل بوو بە شاقلی پیرۆزگا، هەردووکیان پڕ بوون لە باشترین ئاردی بە زەیت شێلراو وەک پێشکەشکراوی دانەوێڵە؛
\v 80 قاپێکی زێڕ کێشەکەی دە شاقل و پڕ لە بخوور؛
\v 81 یەک جوانەگا و بەرانێک و بەرخێکی نێری یەک ساڵە بۆ قوربانی سووتاندن؛
\v 82 گیسکێکی نێرینە بۆ قوربانی گوناه؛
\v 83 بۆ قوربانی هاوبەشیش دوو گا و پێنج بەران و پێنج تەگە و پێنج بەرخی نێری یەک ساڵە. ئەمە پێشکەشکراوی ئەحیڕەعی کوڕی عێینانە.
\b
\p 
\v 84 ئەمە پێشکەشکراوی سەرۆکەکانی ئیسرائیل بوو، بۆ تەرخانکردنی قوربانگاکە لە کاتی دەستنیشانکردنی: دوازدە لەگەنی زیو و دوازدە تاسی زیو و دوازدە قاپی زێڕ.
\v 85 هەر لەگەنێک سەد و سی شاقل زیو و هەر تاسێک حەفتا شاقل بوو، هەموو زیوی قاپوقاچاغەکان دوو هەزار و چوار سەد\f + \fr 7:85 \ft دوو هەزار و چوار سەد شاقل: نزیکەی 28 کیلۆگرام.‏\f* بوون بە شاقلی پیرۆزگا.
\v 86 قاپە زێڕەکانیش دوازدەی پڕ لە بخوور، هەر قاپێک دە شاقل بوو بە شاقلی پیرۆزگا، هەموو زێڕی قاپەکان سەد و بیست شاقل بوو.
\v 87 هەموو گایەکانی قوربانی سووتاندن دوازدە جوانەگا بوو، بەرانەکانیش دوازدە و بەرخە نێرە یەک ساڵەکانیش دوازدە لەگەڵ پێشکەشکراوی دانەوێڵەیان، گیسکە نێرەکانیش دوازدە بوون بۆ قوربانی گوناه،
\v 88 هەموو گایەکانی قوربانی هاوبەشیش بیست و چوار گا بوون، بەرانەکانیش شەست و تەگەکانیش شەست و بەرخە نێرە یەک ساڵەکانیش شەست. ئەمە پێشکەشکراوەکان بوو بۆ تەرخانکردنی قوربانگاکە لەدوای دەستنیشانکردنی.
\p 
\v 89 جا کاتێک موسا چووە ناو چادری چاوپێکەوتنەوە تاکو قسە لەگەڵ یەزدان بکات، گوێی لە دەنگەکە دەبوو کە لەگەڵی دەدوا لە قەپاغی کەفارەتەوە\f + \fr 7:89 \ft قەپاغێکە بۆ داپۆشینی سندوقی پەیمان، لە ڕۆژی کەفارەت خوێنی قوربانی لەسەر ڕژاوە بۆ لێخوشبوونی گوناه. بڕوانە \xt دەرچوون 25‏:17‏\xt*\ft ‏.‏\f* کە لەسەر سندوقی شایەتی بوو، لەنێوان دوو کەڕوبەکەوە\f + \fr 7:89 \ft دوو کەڕوب: جووتێک پەیکەری بوونەوەری ئاسمانی باڵدار لە شێوەی ئاژەڵ و مرۆڤ بۆ پارێزگاریکردن لە هەردوو لای کەناری بەشی کۆتایی سندوقی پەیمان دانرابوون، بڕوانە \xt دەرچوون 25‏:18 و عیبرانییەکان 9‏:5‏\xt*\ft ‏.‏\f*، بەم شێوەیە خودا قسەی لەگەڵ کرد.
\c 8
\s1 بەرزکردنەوەی چراکان
\p 
\v 1 یەزدان بە موسای فەرموو:
\v 2 «لەگەڵ هارون بدوێ و پێی بڵێ: ”کاتێک چراکانت بەرزکردەوە، با ڕووناکی حەوت چراکە بۆ پێش چرادانەکە بێت.“»
\p 
\v 3 هارون چراکانی وا بەرزکردەوە هەتا ڕووناکی بە پێشی چرادانەکە بدات وەک یەزدان فەرمانی بە موسا کرد.
\v 4 ئەمەش دروستکردنی چرادانەکەیە، لە زێڕی کوتراو، لە قەدەکەیەوە هەتا خونچەکانی کوتران، چرادانەکەی بەگوێرەی ئەو شێوەیە دروستکرد کە یەزدان پیشانی موسای دا.
\s1 جیاکردنەوەی لێڤییەکان
\p 
\v 5 یەزدان قسەی بۆ موسا کرد و فەرمووی:
\v 6 «لێڤییەکان لەنێو نەوەی ئیسرائیلدا ببە و بەپێی ڕێوڕەسم\f + \fr 8:6 \ft ڕێوڕەسمی ئایینی.‏\f* پاکیان بکەرەوە.
\v 7 ئاواش دەکەیت بۆ پاککردنەوەیان: ئاوی پاککردنەوەیان بەسەردا بپرژێنە، با هەموو لەشیان بتاشن و جلەکانیان بشۆن. بەم شێوەیە خۆیان پاک بکەنەوە.
\v 8 ئینجا جوانەگایەک لەگەڵ پێشکەشکراوی دانەوێڵەکەی کە باشترین ئاردی بە زەیت شێلراوە ببەن و جوانەگایەکی دیکەش بۆ قوربانی گوناه ببە.
\v 9 جا لێڤییەکان دەبەیتە پێش چادری چاوپێکەوتن و هەموو کۆمەڵی ئیسرائیل کۆدەکەیتەوە،
\v 10 لێڤییەکان دەبەیتە بەردەم یەزدان و نەوەی ئیسرائیل دەستیان دەخەنە سەر.
\v 11 جا هارون لێڤییەکان لەبەردەم یەزدان پێشکەش دەکات وەک قوربانی بەرزکردنەوە لەلایەن نەوەی ئیسرائیلەوە بۆ ئەوەی ئامادەبن بۆ پەرستنی یەزدان.
\p 
\v 12 «ئینجا لێڤییەکان دەستیان دەخەنە سەر دوو جوانەگاکە، یەکێکیان وەک قوربانی گوناه پێشکەش دەکرێت و ئەوەی دیکە قوربانی سووتاندن بۆ یەزدان، بۆ کەفارەتکردن بۆ لێڤییەکان.
\v 13 جا لێڤییەکان لەبەردەم هارون و کوڕەکانی ڕادەگریت و وەک قوربانی بەرزکردنەوە بۆ یەزدان پێشکەشیان دەکەیت.
\v 14 بەم شێوەیە لێڤییەکان لەنێو نەوەی ئیسرائیل جیا دەکەیتەوە، لێڤییەکان بۆ من دەبن.
\p 
\v 15 «لەدوای ئەوەی لێڤییەکانت پاک کردەوە و وەک قوربانی بەرزکردنەوە پێشکەشت کردن، دێن بۆ ئەوەی خزمەتی چادری چاوپێکەوتن بکەن،
\v 16 چونکە ئەوان لەنێو نەوەی ئیسرائیلەوە بە تەواوی بە من دراون، لە جیاتی هەموو نۆبەرەیەکی نێری سک لە نەوەی ئیسرائیلدا من بۆ خۆمم داناون.
\v 17 هەموو نۆبەرەیەکی نێر، خەڵک یان ئاژەڵ لە نەوەی ئیسرائیلدا بۆ منە. ئەو ڕۆژەی لە هەموو نۆبەرەیەکم دا\f + \fr 8:17 \ft لە هەموو نۆبەرەیەکم دا: بڕوانە \xt دەرچوون 12‏:29‏\xt*\ft ‏.‏\f* لە خاکی میسر، بۆ خۆمم تەرخان کردن.
\v 18 ئینجا لێڤییەکانم بۆ خۆم دانا لە جیاتی هەموو نۆبەرەیەک لە نەوەی ئیسرائیل.
\v 19 لێڤییەکانم بە تەواوی بە هارون و کوڕەکانی بەخشیوە لەنێو نەوەی ئیسرائیل، هەتا لە چادری چاوپێکەوتندا لە جیاتی نەوەی ئیسرائیل خزمەت بکەن، هەروەها بۆ کەفارەتکردن بۆ نەوەی ئیسرائیل تاکو نەوەی ئیسرائیل تووشی هیچ دەردێک نەبێت لە کاتی نزیککەوتنەوەیان لە پیرۆزگا.»
\p 
\v 20 موسا و هارون و هەموو کۆمەڵی نەوەی ئیسرائیل ئاوایان بۆ لێڤییەکان کرد، بەگوێرەی هەموو ئەوەی یەزدان فەرمانی بە موسا کرد سەبارەت بە لێڤییەکان.
\v 21 جا لێڤییەکان خۆیان پاککردەوە و جلەکانیان شوشت، هارون لەبەردەم یەزدان وەک قوربانی بەرزکردنەوە پێشکەشی کردن، هارون کەفارەتی بۆ کردن بۆ پاکبوونەوەیان.
\v 22 لەدوای ئەوە لێڤییەکان هاتن هەتا لە چادری چاوپێکەوتندا لەبەردەم هارون و لەبەردەم کوڕەکانی خزمەتەکەیان بکەن، وەک چۆن یەزدان فەرمانی بە موسا کرد سەبارەت بە لێڤییەکان، ئاوایان لەگەڵدا کردن.
\p 
\v 23 یەزدان بە موسای فەرموو:
\v 24 «ئەمە بۆ لێڤییەکانە، لە گەنجی بیست و پێنج ساڵ بەرەو سەرەوە دێنە ناو خزمەتەوە بۆ خزمەتی چادری چاوپێکەوتن.
\v 25 لە تەمەنی پەنجا ساڵەشەوە دەست لە خزمەت هەڵدەگرن و ئیتر خزمەت ناکەن.
\v 26 یارمەتی براکانیان دەدەن لە چادری چاوپێکەوتن لە پارێزگاری، بەڵام هیچ خزمەتێک ناکەن. ئاوا بۆ لێڤییەکان دەکەیت لە پارێزگارییەکانیان.»
\c 9
\s1 جەژنی پەسخە
\p 
\v 1 لە ساڵی دووەمی هاتنەدەرەوەیان لە خاکی میسر لە مانگی یەک لە چۆڵەوانی سینا یەزدان بە موسای فەرموو:
\v 2 «با نەوەی ئیسرائیل جەژنی پەسخە لە کاتی خۆیدا بکەن،
\v 3 لە ڕۆژی چواردەی ئەم مانگە لە زەردەپەڕدا\f + \fr 9:3 \ft کاتی ڕۆژئاوابوون و تاریک داهاتن.‏\f*، لە کاتی خۆیدا دەیکەن، بەگوێرەی هەموو فەرز و ڕاسپاردەکان.»
\p 
\v 4 موساش لەگەڵ نەوەی ئیسرائیل دوا بۆ ئەوەی جەژنی پەسخە بکەن،
\v 5 جا لە چواردەی مانگی یەک لە زەردەپەڕدا لە چۆڵەوانی سینا جەژنی پەسخەیان کرد، بەگوێرەی هەموو ئەوەی یەزدان فەرمانی بە موسا کرد، نەوەی ئیسرائیل ئاوایان کرد.
\p 
\v 6 بەڵام هەندێک کەس بەهۆی مردووێکەوە بەپێی ڕێوڕەسم گڵاو ببوون و دروست نەبوو بۆیان لەو ڕۆژەدا جەژنی پەسخە بکەن، جا لەو ڕۆژەدا هاتنە بەردەم موسا و هارون.
\v 7 ئەو خەڵکە پێیان گوت: «ئێمە بەهۆی کەسێکی مردووەوە گڵاوین، بۆچی لە کاتی خۆیدا لەنێو نەوەی ئیسرائیلدا وەلابنرێین و قوربانی بۆ یەزدان پێشکەش نەکەین؟»
\p 
\v 8 موساش وەڵامی دانەوە: «بوەستن با گوێم لێ بێت یەزدان سەبارەت بە ئێوە چی فەرمان دەکات.»
\p 
\v 9 جا یەزدان بە موسای فەرموو:
\v 10 «لەگەڵ نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”هەرکەسێک لە ئێوە یان لە نەوەکانتان، ئەگەر بە مردووێک گڵاو ببوو یان لە گەشتێکی دوور بوو، با جەژنی پەسخە بۆ یەزدان بکات.
\v 11 لە ڕۆژی چواردەی مانگی دوو لە زەردەپەڕدا دەیکەن، بەرخەکە بە نانی فەتیرە و بە گیای تاڵەوە دەخۆن.
\v 12 هیچی بۆ بەیانی ناهێڵنەوە و هیچ ئێسقانێکی لێ ناشکێنرێت. بەگوێرەی هەموو فەرزەکانی جەژنی پەسخە دەیکەن.
\v 13 بەڵام ئەگەر یەکێک پاک بوو و لە گەشت نەبوو، جەژنی پەسخەی نەکرد، ئەو گیانە لە گەلەکەی دادەبڕدرێت، چونکە لە کاتی خۆیدا قوربانی یەزدانی پێشکەش نەکردووە، ئەو کەسە ئۆباڵی گوناهەکەی خۆی هەڵدەگرێت.
\p 
\v 14 «”ئەگەر نامۆیەک لەنێو ئێوەدا بژیێت و ویستی جەژنی پەسخە بۆ یەزدان بگێڕێت، بەگوێرەی فەرزی پەسخە و یاساکانی ئاوا دەکات، یەک فەرز دەبێت بۆتان، بۆ نامۆ و بۆ هاوڵاتی خاکەکە.“»
\s1 هەور لەسەر چادری پەرستن
\p 
\v 15 لە ڕۆژی دامەزراندنی چادرەکەی پەرستن کە بە چادری پەیمان ناسراوە، هەورێک چادرەکەی پەرستنی داپۆشی. هەر لە ئێوارەوە هەتا بەیانی هەورەکە لەسەر چادرەکەی پەرستن وەک دیمەنی ئاگر بوو.
\v 16 بە بەردەوامی ئاوا بوو، هەور دایدەپۆشی و بە شەویش هەورەکە دیمەنی ئاگری هەبوو.
\v 17 هەر کاتێکیش هەورەکە لەسەر چادرەکە بەرز دەبووەوە، ئەوا نەوەی ئیسرائیل لەدوای ئەوە بەڕێ دەکەوتن. لەو شوێنەی هەورەکە بنیشتبایەوە ئەوا نەوەی ئیسرائیل لەوێ چادریان هەڵدەدا.
\v 18 بە فەرمانی یەزدان نەوەی ئیسرائیل بەڕێ دەکەوتن و بە فەرمانی یەزدان چادریان هەڵدەدا، هەموو ڕۆژانی نیشتنی هەورەکە بەسەر چادرەکەی پەرستندا ئەوان لە چادرەکانی خۆیان دەمانەوە.
\v 19 هەر کاتێک هەورەکە چەند ڕۆژێکی زۆر لەسەر چادرەکەی پەرستن دەمایەوە، ئەوا نەوەی ئیسرائیل گوێڕایەڵی یەزدان دەبوون و بەڕێ نەدەکەوتن.
\v 20 هەر کاتێک هەورەکە چەند ڕۆژێکی کەم لەسەر چادری پەرستن دەمایەوە، ئەوا بەگوێرەی فەرمانی یەزدان چادریان هەڵدەدا و بەگوێرەی فەرمانی یەزدان بەڕێ دەکەوتن.
\v 21 هەندێک جار هەورەکە لە ئێوارەوە هەتا بەیانی دەمایەوە و لە بەیانیدا بەرز دەبووەوە، ئەو کاتە بەڕێ دەکەوتن. یان شەو و ڕۆژێک بمابایەوە و بەرز بووایەوە، ئەوا بەڕێ دەکەوتن.
\v 22 بەم جۆرە هەورەکە دوو ڕۆژ یان مانگێک یان ساڵێک، هەرچەندێک لەسەر چادرەکەی پەرستن بمابایەوە و بنیشتبایەوە، ئەوا نەوەی ئیسرائیل لە چادرەکانیان دەمانەوە و بەڕێ نەدەکەوتن، هەر کاتێکیش بەرز بووایەوە ئەوا بەڕێ دەکەوتن.
\v 23 بە فەرمانی یەزدان چادریان هەڵدەدا و بە فەرمانی یەزدان بەڕێ دەکەوتن و ئەرکی یەزدانیان دەپاراست، بەگوێرەی فەرمانی یەزدان لەسەر دەستی موسا.
\c 10
\s1 کەڕەنا زیوەکان
\p 
\v 1 یەزدان بە موسای فەرموو:
\v 2 «دوو کەڕەنا لە زیوی کوتراو بۆ خۆت دروستبکە، بۆ بانگکردنی کۆمەڵ و بۆ بەڕێکەوتنی ئۆردوگاکان.
\v 3 ئەگەر هەردووکیان لێدران ئەوا هەموو کۆمەڵ بۆ لای دەروازەی چادری چاوپێکەوتن لەلات کۆدەبنەوە،
\v 4 ئەگەر تەنها یەکێکیان لێدرا ئەوا سەرکردەکان لەلات کۆدەبنەوە، کە سەرۆک خێڵەکانی ئیسرائیلن.
\v 5 ئەگەر وەک نیشانەی ئاگادارکردنەوە لێتاندا ئەوا ئەو ئۆردوگایانەی لەلای ڕۆژهەڵات چادریان هەڵداوە بەڕێ دەکەون،
\v 6 ئەگەر دووبارە وەک نیشانەی ئاگادارکردنەوە لێتاندا ئەوا ئەو ئۆردوگایانەی لەلای باشوور چادریان هەڵداوە بەڕێ دەکەون، بۆ بەڕێکەوتنەکانیان وەک نیشانەی ئاگادارکردنەوە لێدەدەن.
\v 7 کاتێک کۆمەڵ کۆدەکەنەوە ئەوا کەڕەنا لێدەدەن، بەڵام وەک نیشانەی ئاگادارکردنەوە ناکەن.
\p 
\v 8 «کوڕانی هارونی کاهین کەڕەناکان لێدەدەن، جا بۆتان دەبێتە فەرزێکی هەتاهەتایی بۆ نەوەکانتان.
\v 9 ئەگەر لە خاکی خۆتان بۆ جەنگ چوونە سەر دوژمنێک کە ستەمتان لێدەکات، ئەوا کەڕەناکان وەک نیشانەی ئاگادارکردنەوە لێدەدەن و لەبەردەم یەزدانی پەروەردگارتان یاد دەکرێنەوە و لە دوژمنەکانتان ڕزگارتان دەبێت.
\v 10 هەروەها لە ڕۆژی خۆشیتان و لە جەژن و لە دەستپێکی مانگی نوێتان\f + \fr 10:10 \ft هەموو مانگێک لە کاتی دەرکەوتنی مانگ گەلی خودا بۆ ماوەی 24 کاتژمێر ئاهەنگیان گێڕاوە و ئەو ڕۆژە کەس بۆی نەبووە کار بکات. بڕوانە پەڕتووکی \xt سەرژمێری 28‏:11‏-15 و ئامۆس 8‏:5.‏\xt*\ft ‏\f* کەڕەناکان لێدەدەن، لەسەر قوربانی سووتاندنەکانتان و قوربانییەکانی هاوبەشیتان، جا دەبێتە یادەوەریتان لەبەردەم خوداکەتان. من یەزدانی پەروەردگارتانم.»
\s1 ئیسرائیلییەکان لە سیناوە بەڕێ دەکەون
\p 
\v 11 لە بیستی مانگی دووی ساڵی دووەمدا هەورەکە لەسەر چادری پەیمان بەرزبووەوە.
\v 12 جا نەوەی ئیسرائیل لە قۆناغەکەیان لە چۆڵەوانی سیناوە بەڕێکەوتن و هەورەکە لە چۆڵەوانی پاران نیشتەوە.
\v 13 بەپێی فەرمانی یەزدان و لە ڕێگەی موساوە بۆ یەکەمین جار دەستیان بە کۆچەکەیان کرد.
\p 
\v 14 لەژێر بەیداخەکەیان ئۆردوگای نەوەی یەهودا بەگوێرەی لەشکرەکانیان یەکەم جار بەڕێکەوتن و نەحشۆنی کوڕی عەمیناداب سوپاسالاریان بوو.
\v 15 سەرلەشکری هۆزی نەوەی یەساخاریش نەتەنێلی کوڕی چوعەر بوو،
\v 16 سەرلەشکری هۆزی نەوەی زەبولونیش ئەلیابی کوڕی حێلۆن بوو.
\v 17 ئینجا چادرەکەی پەرستن هەڵگیرایەوە و نەوەی گێرشۆن و نەوەی مەراری چادرەکەی پەرستنیان هەڵگرت و بەڕێکەوتن.
\p 
\v 18 لەدوای ئەوان لەژێر بەیداخەکەیان ئۆردوگای ڕەئوبێن بەگوێرەی لەشکرەکانیان بەڕێکەوتن، ئەلیسوری کوڕی شەدیئور سوپاسالاریان بوو.
\v 19 سەرلەشکری هۆزی نەوەی شیمۆنیش شەلومیێلی کوڕی چووریشەدای بوو،
\v 20 سەرلەشکری هۆزی نەوەی گادیش ئەلیاسافی کوڕی دەعوئێل بوو.
\v 21 ئینجا قەهاتییەکان شتە پیرۆزکراوەکانیان هەڵگرت و بەڕێکەوتن، هەتا گەیشتن چادرەکەی پەرستن هەڵدرابوو.
\p 
\v 22 ئینجا لەژێر بەیداخەکەیان نەوەی ئەفرایم بەگوێرەی لەشکرەکانیان بەڕێکەوتن و ئەلیشاماعی کوڕی عەمیهود سوپاسالاریان بوو،
\v 23 سەرلەشکری هۆزی نەوەی مەنەشەش گەمالائیلی کوڕی پەداهچوور بوو،
\v 24 سەرلەشکری هۆزی نەوەی بنیامینیش ئەبیدانی کوڕی گدعۆنی بوو.
\p 
\v 25 لە کۆتاییدا لەژێر بەیداخەکەیان ئۆردوگای نەوەی دان بەڕێکەوت و پاشڕەو و پاسەوانی هەموو ئۆردوگاکان بوو، بەگوێرەی لەشکرەکانیان، ئەحیعەزەری کوڕی عەمیشەدای سوپاسالاریان بوو.
\v 26 سەرلەشکری هۆزی نەوەی ئاشێریش پەگعیێلی کوڕی عۆخران بوو.
\v 27 سەرلەشکری هۆزی نەوەی نەفتالیش ئەحیڕەعی کوڕی عێینان بوو.
\v 28 ئەمە ڕێکخستنی نەوەی ئیسرائیلە بە لەشکرەکانیانەوە کاتێک بەڕێکەوتن.
\p 
\v 29 موسا بە حۆڤاڤی کوڕی ڕەعوئێلی میدیانی گوت، کە ڕەعوئێل خەزووری موسا بوو: «ئێمە دەچین بۆ ئەو شوێنەی یەزدان فەرمووی: ”پێتانی دەدەم.“ لەگەڵمان وەرە و بۆت باش دەبین، چونکە یەزدان بەڵێنی داوە بۆ ئیسرائیل چاک دەبێت.»
\p 
\v 30 ئەویش پێی گوت: «ناڕۆم، بەڵکو بۆ لای خاکی خۆم و گەلی خۆم دەچم.»
\p 
\v 31 جا موسا گوتی: «تکایە بەجێمان مەهێڵە، لەبەر ئەوەی شارەزایت لە چۆڵەوانی لەکوێ چادر هەڵبدەین، ببە بە چاو بۆمان.
\v 32 ئەگەر لەگەڵمان بێیت، ئەوا بەو چاکەیەی یەزدان لەگەڵ ئێمەی دەکات، ئێمەش چاکەت لەگەڵدا دەکەین.»
\p 
\v 33 جا لە کێوی یەزدانەوە بۆ سێ ڕۆژە ڕێ بەڕێکەوتن و سندوقی پەیمانی یەزدانیش سێ ڕۆژە ڕێ پێشیان کەوتبوو، هەتا بۆ پشوودان نشینگەیەکیان بۆ بدۆزێتەوە.
\v 34 هەوری یەزدانیش بە ڕۆژ بەسەریانەوە بوو، کاتێک لە ئۆردوگاوە بەڕێکەوتن.
\p 
\v 35 لە کاتی بەڕێکەوتنی سندوقەکەش موسا دەیگوت:
\q1 «هەستە یەزدان!
\q2 با دوژمنانت پەرتەوازە بن و
\q2 ناحەزانت لەبەردەمت هەڵبێن.»
\p 
\v 36 لە کاتی چادرهەڵدانیش دەیگوت:
\q1 «ئەی یەزدان، بگەڕێوە
\q2 بۆ لای هەزاران هەزارانی ئیسرائیل.»
\c 11
\s1 ئاگر لە یەزدانەوە
\p 
\v 1 گەل دەربارەی ناخۆشییان بۆڵەبۆڵیان کرد، گەیشتە لای یەزدان. یەزدان کە ئەمەی بیست پێی خراپ بوو، تووڕەیی جۆشا، ئیتر ئاگری یەزدان تێیاندا گڕی گرت و قەراغی ئۆردوگاکەی سووتاند.
\v 2 لەبەر ئەوە گەل هاواریان بۆ موسا کرد، موساش لە یەزدان پاڕایەوە و ئاگرەکە کوژایەوە.
\v 3 ئەو شوێنەش ناونرا تەبعیرە، چونکە ئاگری یەزدان تێیاندا گڕی گرت.
\s1 سوێسکە لە یەزدانەوە
\p 
\v 4 ئەو ئاژاوەگێڕانەی لەنێویان دەژیان ئارەزووی گۆشتیان دەکرد، جا نەوەی ئیسرائیلیش گەڕانەوە و گریان و گوتیان: «کێ گۆشتمان دەرخوارد دەدات.
\v 5 ئەو ماسیەی لە میسر بەخۆڕایی دەمانخوارد بەبیرمان هاتەوە، لەگەڵ خەیار و شووتی و کەوەر و پیاز و سیر.
\v 6 ئێستاش وا گیانمان وشک بوو، هیچ شتێک نییە و هەر چاومان لەسەر ئەو مەنەیە!»
\p 
\v 7 مەنیش وەک تۆوی گژنیژ وابوو، دیمەنی وەک دیمەنی سرێشی دار درەوشاوە بوو.
\v 8 گەلیش دەسووڕانەوە هەتا هەڵیبگرنەوە، ئینجا بە دەستاڕ دەیانهاڕی یان لە هاون دەیانکوتایەوە و لە مەنجەڵ لێیان دەنا و دەیانکردە کولێرە، تامەکەشی وەک تامی کولێرە برژاوی بە زەیت بوو.
\v 9 هەر کاتێک بە شەو شەونم بەسەر ئۆردوگاکەدا دەهاتە خوارەوە، ئەوا مەنیش لەگەڵیدا دەهاتە خوارەوە.
\p 
\v 10 کاتێک موسا گوێی لێبوو هەموو گەل دەگریێن، هەریەکە بەخۆی و بنەماڵەکەیەوە لەبەر دەروازەی چادرەکەی ڕاوەستاوە، تووڕەیی یەزدان زۆر زیادی کرد، موسا بەمە دڵگران بوو.
\v 11 جا موسا بە یەزدانی گوت: «بۆچی لەگەڵ خزمەتکارەکەت خراپ بوویت؟ بۆچی لەلات پەسەند نەبووم، تەنانەت باری هەموو ئەم گەلەت خستە سەر من؟
\v 12 ئایا سکم بەم هەموو خەڵکە پڕ بووە یان لە منەوە لەدایک بوونە؟ بۆچی پێم دەڵێی بە باوەش هەڵیانبگرە، هەروەک چۆن دایەن منداڵی ساوا هەڵدەگرێت، بیانبە ئەو خاکەی سوێندت بۆ باوانیان خوارد؟
\v 13 گۆشتم لەکوێ بوو تاکو بە هەموو ئەم گەلەی بدەم؟ بەسەرمەوە دەگرین و دەڵێن: ”گۆشتمان بدەرێ بیخۆین!“
\v 14 من بە تەنها ناتوانم هەموو ئەم گەلە هەڵبگرم، چونکە بۆ من گرانە.
\v 15 جا ئەگەر وام پێدەکەیت، بمکوژە ئەگەر لەلات پەسەندم، با تووشی بەڵای خۆم نەبم.»
\p 
\v 16 یەزدانیش بە موسای فەرموو: «لە پیرانی ئیسرائیل حەفتا پیاوم بۆ کۆبکەرەوە، ئەوانەی دەزانیت کە ڕیش سپی و کوێخای گەلن و بیانهێنە لای چادری چاوپێکەوتن و با لەوێ لەگەڵتدا ڕاوەستن.
\v 17 جا من دێمە خوارەوە و لەوێ لەگەڵتدا دەدوێم و لەو ڕۆحەی بەسەرتەوەیە دەبەم و دەیخەمە سەریان، جا لەگەڵتدا بارگرانی گەلەکە هەڵدەگرن، ئیتر تۆ بە تەنها هەڵیناگریت.
\p 
\v 18 «بە گەلیش دەڵێیت: ”بۆ بەیانی خۆتان تەرخان بکەن ئینجا گۆشت دەخۆن، چونکە یەزدان گوێی لێبوو کە گریان و گوتتان، ’کێ گۆشتمان دەرخوارد دەدات؟ لە میسر حاڵمان خۆشتر بوو!‘ ئێستا یەزدان گۆشتتان دەداتێ و دەیخۆن.
\v 19 نە ڕۆژێک، نە دوو ڕۆژ، نە پێنج ڕۆژ، نە دە ڕۆژ و نە بیست ڕۆژ،
\v 20 بەڵکو ماوەی مانگێکی تەواو دەیخۆن، هەتا لە کونی لووتتان دێتە دەرەوە و ڕقتان لێی دەبێتەوە، چونکە یەزدانتان ڕەتکردەوە کە لەنێوتاندایە و لەبەردەمیدا گریان و گوتتان: ’بۆچی ئەمەمان کرد و لە میسر هاتینە دەرەوە؟‘ “»
\p 
\v 21 بەڵام موسا گوتی: «ئەو گەلەی من لەنێویانم شەش سەد هەزار پیادەیە، تۆش فەرمووت: ”گۆشتیان دەدەمێ لێی بخۆن بۆ ماوەی مانگێک!“
\v 22 ئایا مەڕ و مانگایان بۆ سەردەبڕدرێت هەتا بەشیان بکات، یان هەموو ماسی دەریایان بۆ کۆدەکرێتەوە هەتا بەشیان بکات؟»
\p 
\v 23 یەزدانیش بە موسای فەرموو: «ئایا یەزدان بێ دەسەڵاتە؟ ئێستا دەبینیت ئاخۆ قسەکانم دێتە دی یان نا.»
\p 
\v 24 موساش چووە دەرەوە و بە فەرموودەی یەزدان لەگەڵ گەلدا دوا. حەفتا پیاوی لە پیرانی گەل کۆکردەوە، لە دەوروبەری چادرەکە ڕایگرتن.
\v 25 یەزدانیش لە هەوردا هاتە خوارەوە و لەگەڵیدا دوا و لەو ڕۆحە پیرۆزەی کە لەسەری بوو بردی و خستییە سەر حەفتا ڕیش سپییەکە. کاتێک ڕۆحەکە هاتە سەریان ئیتر پەیامی خودایان ڕاگەیاند، بەڵام یەک جار و زیاتر نا.
\p 
\v 26 دوو پیاویش لە ئۆردوگاکە مانەوە، ناوی یەکێکیان ئەلداد و ناوی ئەوەی دیکە میداد بوو، ڕۆحی خودا لەسەریان نیشتەوە، ئەوانیش لە ڕیش سپییەکان بوون، بەڵام نەچووبوونە لای چادرەکە، جا لە ئۆردوگاکە پەیامی خودایان ڕاگەیاند،
\v 27 لاوێکیش ڕایکرد و هەواڵی دایە موسا و گوتی: «ئەلداد و میداد لە ئۆردوگاکە پەیامی خودا ڕادەگەیەنن!»
\p 
\v 28 یەشوعی کوڕی نونیش کە لە گەنجیێتیەوە خزمەتکاری موسا بوو وەڵامی دایەوە و گوتی: «موسای گەورەم ڕێیان لێ بگرە!»
\p 
\v 29 موساش پێی گوت: «ئایا لە جیاتی من ئیرەیی دەبەیت؟ خۆزگە هەموو گەلی یەزدان پێغەمبەر بوونایە، کە یەزدان ڕۆحی خۆی دەخستە سەریان!»
\v 30 ئینجا موسا و پیرانی ئیسرائیل گەڕانەوە بۆ ئۆردوگاکە.
\p 
\v 31 بایەکیش لەلایەن یەزدانەوە هەڵیکرد و سوێسکەی\f + \fr 11:31 \ft سوێسکە: باڵندەیەکی بچووکە، لە شێوەی کەودایە، بە پۆلی گەورە کۆچ دەکەن، لە ئاستێکی نزمدا دەفڕن و لەو کاتەدا خەڵکی تۆڕیان بەکاردەهێنا بۆ گرتنیان. بڕوانە \xt دەرچوون 16‏:13‏\xt*\ft ‏.‏\f* لە دەریاوە هێنا بۆ ئۆردوگاکە. بۆ ماوەی ڕۆژە ڕێیەک لەم لا و ڕۆژە ڕێیەک لەو لا لە چواردەوری ئۆردوگاکە و بە بەرزی دوو باڵ\f + \fr 11:31 \ft دوو باڵ: نزیکەی یەک مەتر.‏\f* لەسەر ڕووی زەوییەوە بڵاوی کردنەوە.
\v 32 گەلیش هەستان و بە درێژایی ئەو ڕۆژە و بە درێژایی شەو و ڕۆژی دواتریش سوێسکەیان کۆکردەوە، کەمترینیان دە حۆمەری\f + \fr 11:32 \ft حۆمەر: باری گوێدرێژ. دە حۆمەر: دەشێت 6‏،1 تەنی سوێسکە بێت.‏\f* کۆکردەوە و بۆ خۆیان بە چواردەوری ئۆردوگاکە ڕایانخست.
\v 33 لەو کاتەشدا کە هێشتا گۆشت لەژێر ددانەکانیان بوو پێش ئەوەی بیجوون، تووڕەیی یەزدان بەسەر گەلدا جۆشا و یەزدان گەلی تووشی دەردێکی گران کرد،
\v 34 جا ئەو شوێنە ناونرا قیبرۆت هەتەڤا\f + \fr 11:34 \ft بە واتای گۆڕستانی نەوسنان.‏\f*، چونکە لەوێ ئەو خەڵکانەیان ناشت کە نەوسیان هەستا.
\p 
\v 35 لە قیبرۆت هەتەڤاشەوە گەل بۆ حەچێرۆت بەڕێکەوتن، جا لەوێ چادریان هەڵدا.
\c 12
\s1 قسەکردنی مریەم و هارون لە دژی موسا
\p 
\v 1 مریەم و هارون لە دژی موسا قسەیان کرد، لەبەر ئەو ژنە کوشییەی کە خواستی، چونکە ژنێکی کوشی\f + \fr 12:1 \ft وڵاتێکە لە سەرووی ڕووباری نیل.‏\f* خواستبوو.
\v 2 جا گوتیان: «ئایا یەزدان تەنها لەگەڵ موسادا دواوە، باشە لەگەڵ ئێمەش قسەی نەکرد؟» یەزدانیش گوێی لێبوو.
\p 
\v 3 (موساش لە هەموو خەڵکی سەر ڕووی زەوی بێفیزتر بوو.)
\p 
\v 4 جا یەزدان دەستبەجێ بە موسا و هارون و مریەمی فەرموو: «ئەو سێیەتان وەرنە دەرەوە بۆ لای چادری چاوپێکەوتن.» ئینجا هەرسێکیان هاتنە دەرەوە.
\v 5 یەزدانیش لە ستوونی هەوردا دابەزی و لە دەروازەی چادرەکە وەستا، بانگی هارون و مریەمی کرد، هەردووکیان بەرەو پێشەوە چوون.
\v 6 جا فەرمووی: «باش گوێ لە قسەم بگرن:
\q1 «کاتێک پێغەمبەری یەزدان لەنێوتانە،
\q2 ئەوا بە بینین خۆمی بۆ ئاشکرا دەکەم،
\q2 لە خەوندا لەگەڵی دەدوێم.
\q1 
\v 7 بەڵام موسای بەندەم ئاوا نییە،
\q2 بەڵکو بەوەفایە لە هەموو ماڵەکەم،
\q1 
\v 8 ڕوو بە ڕوو لەگەڵی دەدوێم،
\q2 بە ڕوونی نەک بە مەتەڵ،
\q2 شێوەی یەزدان دەبینێت.
\q1 ئیتر بۆچی نەترسان
\q2 کە لە دژی موسای بەندەم دوان؟»
\p 
\v 9 جا تووڕەیی یەزدان لێیان جۆشا و ڕۆیشت.
\p 
\v 10 کاتێک هەورەکە لەسەر چادرەکە بەرزبووەوە مریەم گەڕوگول\f + \fr 12:10 \ft گەڕوگول: وشە عیبرییەکە بۆ چەند نەخۆشی جیاوازی پێست بەکارهێنراوە.‏\f* بوو، وەک بەفر سپی هەڵگەڕا، جا هارون ئاوڕی لە مریەم دایەوە و بینی گەڕوگول بووە.
\v 11 هارون بە موسای گوت: «گەورەم داوات لێدەکەم ئەو سزایەمان نەخەیتە سەر کە گێلایەتیمان کرد و گوناهمان پێی کرد،
\v 12 تکایە با وەک ئەو کۆرپە لەبارچووە نەبێت کە پووکاوەتەوە.»
\p 
\v 13 موساش هاواری بۆ یەزدان کرد و گوتی: «خودایە، تکایە چاکی بکەوە.»
\p 
\v 14 یەزدانیش بە موسای فەرموو: «ئەگەر باوکی تفی لە چارەی دەکرد، ئایا حەوت ڕۆژ شەرمەزار نەدەبوو؟ با حەوت ڕۆژ لە دەرەوەی ئۆردوگاکە دەستبەسەر بێت و ئینجا بێتەوە.»
\v 15 جا مریەم حەوت ڕۆژ لە دەرەوەی ئۆردوگاکە دەستبەسەر بوو و گەلیش بەڕێ نەکەوتن هەتا مریەم نەهاتەوە.
\p 
\v 16 پاش ئەمە گەل لە حەچێرۆتەوە بەڕێکەوتن و لە چۆڵەوانی پاران چادریان هەڵدا.
\c 13
\s1 سیخوڕی خاکی کەنعان
\p 
\v 1 ئینجا یەزدان بە موسای فەرموو:
\v 2 «چەند پیاوێک بنێرە بۆ سیخوڕیکردن لە خاکی کەنعان کە من بە نەوەی ئیسرائیلم داوە، لە هەر هۆزێک لە باوکانیان پیاوێک دەنێرن، هەر یەکێکیان سەرکردە بێت لەناویاندا.»
\p 
\v 3 بەپێی فەرمانی یەزدان موسا لە چۆڵەوانی پارانەوە ئەوانی نارد. هەموویان لە نەوەی ئیسرائیل ڕابەر بوون.
\b
\li4 
\v 4 ئەمەش ناوەکانیانە:
\b
\li1 لە هۆزی ڕەئوبێن شەموعی کوڕی زەکور،
\li1 
\v 5 لە هۆزی شیمۆن شافاتی کوڕی حۆری،
\li1 
\v 6 لە هۆزی یەهودا کالێبی کوڕی یەفونە،
\li1 
\v 7 لە هۆزی یەساخار یەگالی کوڕی یوسف،
\li1 
\v 8 لە هۆزی ئەفرایم هۆشێیەعی کوڕی نون،
\li1 
\v 9 لە هۆزی بنیامین پەلتیی کوڕی ڕافو،
\li1 
\v 10 لە هۆزی زەبولون گەدیێلی کوڕی سۆدی،
\li1 
\v 11 لە هۆزی یوسف، لە هۆزی مەنەشە گەدیی کوڕی سوسی،
\li1 
\v 12 لە هۆزی دان عەمیێلی کوڕی گەمەلی،
\li1 
\v 13 لە هۆزی ئاشێر سەتوری کوڕی میکائیل،
\li1 
\v 14 لە هۆزی نەفتالی نەحبیی کوڕی ڤۆفسی،
\li1 
\v 15 لە هۆزی گاد گوئێلی کوڕی ماکی.
\b
\li4 
\v 16 ئەوە ناوی ئەو پیاوانە بوو کە موسا ناردنی بۆ سیخوڕی خاکەکە. موساش هۆشێیەعی کوڕی نونی ناو نا یەشوع.
\b
\p 
\v 17 جا موسا ناردنی بۆ سیخوڕی خاکی کەنعان و پێی گوتن: «لێرەوە بەناو نەقەبدا\f + \fr 13:17 \ft ناوچەیەکی وشکە دەکەوێتە باشووری خاکی بەڵێندراو.‏\f* بڕۆن و بۆ ناوچە شاخاوییەکە سەربکەون و
\v 18 بڕوانن خاکەکە چۆنە، ئەو گەلەش تێیدا دەژیێت بە هێزە یان لاوازە؟ کەمن یان زۆرن؟
\v 19 ئەو خاکەی تێیدا نیشتەجێن چۆنە، باشە یان خراپە؟ ئەو شارۆچکانە چین کە تێیدا نیشتەجێن، خێوەتگان یان قەڵابەندن؟
\v 20 هەروەها ئەو خاکە چۆنە، بەپیتە یان بێپیتە؟ داری لێیە یان نا؟ چاونەترس بن و هەندێک لە بەروبوومی خاکەکە بهێنن.» ئەو ڕۆژانەش ڕۆژانی یەکەم بەری ترێ بوو.
\p 
\v 21 ئەوانیش سەرکەوتن و سیخوڕی خاکەکەیان کرد، لە چۆڵەوانی چنەوە هەتا ڕەحۆڤ لە نزیک دەروازەی حەمات.
\v 22 بەناو نەقەبدا سەرکەوتن و هاتنە حەبرۆن. لەوێش ئەحیمەن و شێشەی و تەلمەی نەوەی عەناقی لێبوو، حەبرۆنیش پێش چۆعەنی میسر بە حەوت ساڵ بنیاد نرابوو.
\v 23 ئیتر هاتنە دۆڵی ئەشکۆل و لەوێ لقێکیان بە هێشووە ترێیەکەوە لێکردەوە و بە دارێک هەڵیانگرت لەنێوان دووانیان و لەگەڵ هەندێک هەنار و هەنجیر.
\v 24 جا ئەو شوێنە ناونرا دۆڵی ئەشکۆل بەهۆی ئەو هێشووەی نەوەی ئیسرائیل لەوێ لێیان کردەوە.
\v 25 ئینجا لەدوای چل ڕۆژ لە سیخوڕیەتی خاکەکە هاتنەوە.
\s1 هەواڵ هێنانەوە
\p 
\v 26 سیخوڕەکان هاتنە لای موسا و هارون و هەموو کۆمەڵی نەوەی ئیسرائیل لە چۆڵەوانی پاران، لە قادێش، هەواڵیان بۆ ئەوان و بۆ هەموو کۆمەڵ هێنایەوە و بەروبوومی خاکەکەیان پیشاندان.
\v 27 هەواڵیان پێیدا و گوتیان: «بۆ ئەو خاکە چووین کە تۆ ئێمەت بۆی نارد و بە ڕاستی شیر و هەنگوینی لێ دەڕژێت! ئەمەش بەرەکەیەتی.
\v 28 بەڵام ئەو گەلەی لە خاکەکەدا نیشتەجێن بە هێزن و شارەکان قەڵابەند و زۆر مەزنن، هەروەها نەوەی عەناقیشمان لەوێ بینی.
\v 29 عەمالێقییەکان لە خاکی نەقەبدا نیشتەجێن، حیتی و یەبوسی و ئەمۆرییەکان لە ناوچە شاخاوییەکەدا نیشتەجێن، کەنعانییەکانیش لەلای دەریا و لەسەر کەناری ڕووباری ئوردون نیشتەجێن.»
\p 
\v 30 بەڵام کالێب گەلی بۆ موسا بێدەنگ کرد و گوتی: «با سەربکەوین و دەستی بەسەردا بگرین، چونکە توانامان بەسەریدا هەیە.»
\p 
\v 31 بەڵام ئەو پیاوانەی لەگەڵیدا چووبوون، گوتیان: «ناتوانین سەربکەوین و دژایەتی ئەو گەلە بکەین، چونکە لە ئێمە بەهێزترن.»
\v 32 جا هەواڵێکی خراپیان لەنێو نەوەی ئیسرائیلدا بڵاوکردەوە سەبارەت بەو خاکەی سیخوڕیان تێدا کردبوو و گوتیان: «ئەو خاکەی پێیدا چووین هەتا سیخوڕی بکەین، خاکێکە کە دانیشتووانەکەی قووت دەدات. هەموو ئەو گەلەی تێیدا بینیمان باڵا بەرز بوون.
\v 33 هەروەها لەوێ نەفیلیممان\f + \fr 13:33 \ft نەفیلیم: بڕوانە \xt پەیدابوون 6‏:4‏\xt*\ft ‏.‏\f* بینی، نەوەی عەناق کە لە ڕەگەزی نەفیلیمن، لە چاوی خۆماندا وەک پێکوڕە وابووین، بە هەمان شێوەش لەچاو ئەوان.»
\c 14
\s1 یاخیبوونی گەلەکە
\p 
\v 1 کۆمەڵ هەموو دەنگیان بەرزکردەوە و هاواریان کرد و ئەو شەوە گەل گریان.
\v 2 هەموو نەوەی ئیسرائیل دەستیان بە بۆڵەبۆڵ کرد بەسەر موسا و هارون و هەموو کۆمەڵ، پێیان گوتن: «خۆزگە لە میسر دەمردین! خۆزگە لە چۆڵەوانیدا دەمردین!
\v 3 بۆچی یەزدان ئێمە دەهێنێتە ئەم خاکە بۆ ئەوەی بە شمشێر بکوژرێین و ژن و منداڵمان بە تاڵان ببردرێن؟ ئایا باشتر نییە بگەڕێینەوە میسر؟»
\v 4 جا بە یەکتریان گوت، «سەرۆکێک بۆ خۆمان دادەنێین و دەگەڕێینەوە میسر.»
\p 
\v 5 ئینجا موسا و هارون بەسەر ڕوویاندا کەوتن لەبەردەم هەموو کۆمەڵی نەوەی ئیسرائیل کە لەوێ کۆببوونەوە.
\v 6 یەشوعی کوڕی نون و کالێبی کوڕی یەفونەش لەوانە بوون کە سیخوڕی خاکەکەیان کردبوو، جلەکانی خۆیان دڕاند و
\v 7 لەگەڵ هەموو کۆمەڵی نەوەی ئیسرائیلدا دوان و گوتیان: «ئەو خاکەی پێیدا چووین هەتا سیخوڕی بکەین خاکێکی زۆر زۆر باشە،
\v 8 ئەگەر یەزدان پێمان دڵشاد بێت ئەوا دەمانباتە ناو ئەو خاکەی پێمان دەدات، خاکێک کە شیر و هەنگوینی لێ دەڕژێت.
\v 9 بەڵام لە یەزدان یاخی مەبن و لە گەلی ئەو خاکە مەترسن، چونکە نێچیری ئێمەن، ئەوەتا سێبەریان نەماوە و یەزدان لەگەڵمانە، لێیان مەترسن.»
\p 
\v 10 بەڵام هەموو کۆمەڵ گوتیان، «با ئەو دووانە بەردباران بکرێن.» ئینجا شکۆمەندی یەزدان لە چادری چاوپێکەوتندا بۆ هەموو نەوەی ئیسرائیل دەرکەوت.
\v 11 یەزدانیش بە موسای فەرموو: «هەتا کەی ئەم گەلە سووکایەتیم پێ دەکەن و هەتا کەی باوەڕم پێ ناکەن، سەرباری ئەو هەموو نیشانانەی لەنێویاندا کردم؟
\v 12 من تووشی دەردیان دەکەم و لەناویان دەبەم، بەڵام تۆ دەکەمە گەلێکی گەورەتر و مەزنتر لەوان.»
\p 
\v 13 موساش بە یەزدانی گوت: «ئینجا میسرییەکان کە تۆ بە دەسەڵاتی خۆت ئەم گەلەت لەنێویان دەرهێنا گوێیان لێ دەبێت و
\v 14 بە دانیشتووانی ئەم خاکەی دەڵێن. ئەی یەزدان، ئەوانەی گوێیان لێبووە تۆ لەنێو ئەم گەلە دایت. ئەی یەزدان، تۆ ڕوو بە ڕوو بۆیان دەرکەوتیت و هەورەکەت لەسەریان وەستاوە و تۆش بە ستوونی هەور بە ڕۆژ و بە ستوونی ئاگر بە شەو پێشیان دەکەویت.
\v 15 ئەگەر ئەم گەلە لە هەمان کاتدا بکوژیت، ئەوا نەتەوەکان کە گوێیان لە هەواڵت بووە، دەڵێن،
\v 16 ”چونکە یەزدان نەیتوانی بیانباتە ئەو خاکەی کە سوێندی بۆیان خواردبوو، ئیتر لە چۆڵەوانی کوشتنی.“
\p 
\v 17 «ئێستاش با توانای پەروەردگار مەزن بێت هەروەک فەرمووت:
\v 18 ”یەزدان پشوودرێژە و خۆشەویستی نەگۆڕی زۆرە، لە گوناه و یاخیبوون خۆشدەبێت، بەڵام تاوانبار ئەستۆپاک ناکات، بەڵکو لەسەر تاوانی باوکان سزای نەوەکان دەدات هەتا نەوەی سێیەم و چوارەم.“
\v 19 تکایە لە گوناهی ئەم گەلە خۆشبە، ئەوەندەی مەزنی خۆشەویستییە نەگۆڕەکەت، وەک چۆن لەم گەلە خۆشبوویت لە میسرەوە هەتا ئێرە.»
\p 
\v 20 یەزدانیش فەرمووی: «لەسەر داواکەت لێیان خۆشبووم.
\v 21 بەڵام بە گیانی خۆم و بەو شکۆمەندییەی یەزدانیش کە هەموو جیهان پڕ دەکاتەوە،
\v 22 تەنها یەکێکیش لەو پیاوانەی شکۆمەندی من و ئەو نیشانانەی بینیبێت کە لە میسر و لە چۆڵەوانی کردم و هەتا ئێستا دە جار تاقییان کردمەوە و گوێیان لە قسەکانم نەگرت،
\v 23 تەنها یەکێکیش لەوانە ئەو خاکە نابینێت کە سوێندم بۆ باوکانیان خوارد. هەموو ئەوانەی سووکایەتییان پێ کردووم نایبینن.
\v 24 بەڵام کالێبی بەندەم لەبەر ئەوەی ڕۆحێکی دیکەی لەگەڵدا بوو و بە تەواوی دوام کەوت، ئەوا دەیبەمە ناو ئەو خاکەی بۆی چوو و دەبێتە میرات بۆ نەوەکەی.
\v 25 لەبەر ئەوەی عەمالێقییەکان و کەنعانییەکان لە دۆڵ نیشتەجێن، ئێوە بەیانی لە ڕێگای دەریای سوورەوە\f + \fr 14:25 \ft عیبری \tl سوف‏\tl* واتا (زەل). دەشێت مەبەست لە دەریای سوف بێت، ئەو دەریایە بێت کە دەکەوێتە سەرووی باکووری کەنداوی سوێسی ئەمڕۆ، بەڵام لە دەقی یۆنانی پەیمانی نوێ هەر بە دەریای سوور نووسراوە. بڕوانە \xt عیبرانییەکان 11‏:29‏\xt*\ft ‏.‏\f* بڕۆن و بەرەو چۆڵەوانی بەڕێ بکەون.»
\p 
\v 26 هەروەها یەزدان بە موسا و هارونی فەرموو:
\v 27 «هەتا کەی ئەم کۆمەڵە بەدکارە بۆڵەبۆڵەکەرە لە دژم دەوەستن؟ من گوێم لە بۆڵەبۆڵی نەوەی ئیسرائیل بوو کە لەسەر من دەیکەن.
\v 28 پێیان بڵێ: ”یەزدان دەفەرموێت: بە گیانی خۆم، وەک ئەوەی کە لە ئێوەوە گوێم لێ بوو، ئاواتان لێدەکەم.
\v 29 لەم چۆڵەوانییە لاشەکانتان دەکەوێت، هەموو تۆمارکراوەکانتان بەگوێرەی سەرژمێریتان لە گەنجی بیست ساڵ بەرەو سەرەوە لەوانەی بۆڵەبۆڵیان لە دژم کرد،
\v 30 ناچنە ناو ئەو خاکەی کە سوێندم خوارد تێیدا نیشتەجێتان بکەم، تەنها کالێبی کوڕی یەفونە و یەشوعی کوڕی نون نەبێت.
\v 31 بەڵام منداڵەکانتان کە گوتتان دەبنە نێچیر، ئەوا من دەیانبەمە ناوی و شارەزای ئەو خاکە دەبن کە ئێوە ڕەتتان کردەوە.
\v 32 جا لاشەکانی ئێوە لەم چۆڵەوانییە دەکەوێت.
\v 33 منداڵەکانیشتان بۆ ماوەی چل ساڵ لە چۆڵەوانی دەبنە شوان و ئازار دەچێژن بۆ بێوەفاییتان\f + \fr 14:33 \ft عیبری: داوێنپیسییەکەتان، بڕوانە \xt هۆشەع 1‏:2‏\xt*\ft ‏.‏\f* هەتا دواهەمین لاشەکانتان لە چۆڵەوانیدا کۆتایی پێدێت.
\v 34 وەک ژمارەی ئەو ڕۆژانەی سیخوڕی خاکەکەتان کرد کە چل ڕۆژ بوو، بۆ هەر ڕۆژێک ساڵێک، چل ساڵ گوناهەکانتان هەڵدەگرن و تێدەگەن دژایەتیکردنی من چۆنە.“
\v 35 من یەزدانم و فەرمانم کرد، دەبێت ئاوا لە هەموو ئەم کۆمەڵە بەدکارە ڕێککەوتووەی لە دژی خۆم بکەم، لەم چۆڵەوانییە لەناودەچن و دەمرن.»
\p 
\v 36 بەڵام ئەو پیاوانەی موسا ناردنی بۆ سیخوڕی خاکەکە، هاتنەوە و هەموو کۆمەڵیان لێ هاندا بەوەی هەواڵی خراپیان لەسەر خاکەکە بڵاوکردەوە،
\v 37 ئەو پیاوانە لەبەردەم یەزدان بە دەرد مردن، لەبەر بڵاوکردنەوەی هەواڵێکی خراپ لەسەر خاکەکە.
\v 38 بەڵام یەشوعی کوڕی نون و کالێبی کوڕی یەفونە لەو پیاوانە بوون کە بۆ سیخوڕی خاکەکە چووبوون و ژیان.
\p 
\v 39 کاتێک موسا باسی ئەم قسانەی بۆ هەموو نەوەی ئیسرائیل کرد، گەل دەستیان بە شیوەن کرد.
\v 40 ئینجا بەیانی زوو هەستان و چوونە سەرەوە بەرەو بەرزاییەکانی ناوچە شاخاوییەکە و گوتیان: «ئەوەتا ئێمە دەچینە ئەو شوێنەی یەزدان بەڵێنی داوە، چونکە ئێمە گوناهمان کرد.»
\p 
\v 41 موساش گوتی: «بۆچی لە فەرمانی یەزدان دەردەچن، ئەمە سەر ناگرێت!
\v 42 مەڕۆن، چونکە یەزدان لەنێوتاندا نییە، نەوەک لەبەردەم دوژمنتان ببەزن،
\v 43 چونکە عەمالێقییەکان و کەنعانییەکان لەوێن، لەپێشتانن و بە شمشێر دەکوژرێن، ئێوە لە یەزدان هەڵگەڕانەوە و یەزدان لەگەڵتاندا نابێت.»
\p 
\v 44 بەڵام ئەوان خۆیان هەڵکێشا و بەرەو بەرزاییەکانی ناوچە شاخاوییەکە سەرکەوتن، نە سندوقی پەیمانی یەزدان و نە موساش لە ناوەڕاستی ئۆردوگاکە دەرنەچوون.
\v 45 جا عەمالێقییەکان و کەنعانییەکانی دانیشتووی ئەو ناوچە شاخاوییانە هاتنە خوارەوە و هەتا حۆرما لێیاندان و تێکیان شکاندن.
\c 15
\s1 پێشکەشکراوەکانی دیکە
\p 
\v 1 یەزدان بە موسای فەرموو:
\v 2 «لەگەڵ نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”کاتێک هاتنە ناو خاکی نیشتەجێبوونتان کە من پێتانی دەدەم و
\v 3 قوربانی بە ئاگرتان بۆ یەزدان کرد لە گا یان بەران، جا قوربانی سووتاندن یان قوربانی سەربڕاو بۆ بەجێهێنانی نەزرێکی تایبەت یان بەخشینی ئازاد\f + \fr 15:3 \ft بەخشینی ئازاد: بڕوانە \xt دەرچوون 35‏:29 و 36‏:3.‏\xt*\ft ‏\f* یان لە جەژنەکانتان بۆ ئەو بۆنەی کە یەزدان پێی خۆشە،
\v 4 ئەوەی قوربانییەکەی بۆ یەزدان پێشکەش کرد، پێشکەشکراوی دانەوێڵەش لە باشترین ئارد دەیەکی ئێفەیەک شێلراو بە چارەکە هەینێک لە زەیت پێشکەش دەکات.
\v 5 شەرابیش بۆ شەرابی پێشکەشکراو چارەکە هەینێک ئامادە بکە، لەسەر قوربانی سووتاندنەکە یان قوربانییە سەربڕدراوەکە بۆ یەک بەرخ.
\p 
\v 6 «”بەڵام لەگەڵ بەران، پێشکەشکراوی دانەوێڵە لە باشترین ئارد دوو دەیەکی ئێفەیەک\f + \fr 15:6 \ft دوو دەیەکی ئێفەیەک: نزیکەی 4,5 لیتر.‏\f* شێلراو بە سێیەکی هەینێک\f + \fr 15:6 \ft سێیەکی هەینێک: نزیکەی 1,2 لیتر، لێرە و لە ئایەتی 7.‏\f* لە زەیت دەکەیت و
\v 7 شەرابیش بۆ شەرابی پێشکەشکراو سێیەکی هەینێک، وەک ئەو بۆنەی یەزدان پێی خۆشە پێشکەش دەکرێت.
\p 
\v 8 «”ئەگەر جوانەگایەکت کردە قوربانی سووتاندن یان قوربانی سەربڕاو بۆ بەجێهێنانی نەزر یان قوربانی هاوبەشی بۆ یەزدان،
\v 9 ئەوا لەگەڵ جوانەگاکە پێشکەشکراوی دانەوێڵە سێ دەیەکی ئێفەیەک\f + \fr 15:9 \ft سێ دەیەکی ئێفەیەک: نزیکەی 6,5 لیتر.‏\f* لە باشترین ئاردی شێلراو بە نیو هەین\f + \fr 15:9 \ft نیو هەین: نزیکەی دوو لیتر، لێرە و لە ئایەتی دە.‏\f* زەیت پێشکەش دەکەیت و
\v 10 نیو هەین شەرابیش بۆ شەرابی پێشکەشکراو پێشکەش دەکەیت، قوربانی بە ئاگرە، ئەو بۆنەی یەزدان پێی خۆشە.
\v 11 ئاوا بۆ گایەک یان بەرانێک یان بەرخ یان کارەبزن دەکرێت،
\v 12 ئاوا دەکەن بەگوێرەی ژمارەیان، بۆ هەر یەکێک بەگوێرەی ژمارەیان.
\p 
\v 13 «”هەر هاوڵاتییەک بۆ پێشکەشکردنی قوربانی بە ئاگر ئەو بۆنەی یەزدان پێی خۆشە ئاوا دەکات.
\v 14 ئەگەر نامۆیەک لەنێوتان نیشتەجێ بوو، یان هەرکەسێکی دیکە لەنێوتان نیشتەجێیە، نەوە دوای نەوە ویستی قوربانی بە ئاگر بکات، ئەو بۆنەی یەزدان پێی خۆشە، دەبێت وەک ئێوە بیکات.
\v 15 کۆمەڵ بۆ ئێوە و بۆ ئەو نامۆیەی لەنێوتاندا بژیێت، یەک فەرزی هەتاهەتاییە نەوە دوای نەوە. نامۆکەش وەک ئێوە دەبێت لەبەردەم یەزدان،
\v 16 یەک فێرکردن و یەک یاسا دەبێت بۆ ئێوە و بۆ ئەو نامۆیەی لەنێوتاندا دەژیێت.“»
\p 
\v 17 هەروەها یەزدان بە موسای فەرموو:
\v 18 «لەگەڵ نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”کاتێک چوونە ناو ئەو خاکەی کە من ئێوەی بۆ دەبەم،
\v 19 جا کاتێک لە نانی خاکەکە دەخۆن ئەوا پێشکەشکراو بۆ یەزدان دەبەخشن.
\v 20 لە یەکەم ئاردی هاڕاوتان کولێرەیەک دەکەنە پیتاک وەک پێشکەشکراوی جۆخین\f + \fr 15:20 \ft جۆخین یان سەرخەرمان ئەو زەوییە تەرخانکراوەیە کە لەلایەن وەرزێر و جوتیارەوە بەکارهێنراوە بۆ کوتانی دانەوێڵە لەسەری لەدوای کۆکردنەوەی لە کێڵگە.‏\f* دەیبەخشن.
\v 21 نەوە لەدوای نەوە لە یەکەم ئاردی هاڕاوتان بەخشین بۆ یەزدان پێشکەش دەکەن.
\s1 پێشکەشکراوەکان بۆ گوناهکردنی بێ ئەنقەست
\p 
\v 22 «”ئەگەر بەبێ ئەنقەست\f + \fr 15:22 \ft بەبێ ئەنقەست: ئەگەر کەسێک لە سنووری ئەندازەی ڕێپێدراودا گوناهی کرد چ لە ڕێگەی گوێ پێنەدان و نەزانینەوە بێت. ئەوا لێخۆشبوونی بۆ دەبێت لە ڕێگەی قوربانی بۆ گوناه. هەروەها ئەگەر کەسێک تووشی گڵاوبوون بووبێت ئەوا بە هەمان شێوە پاک دەبێتەوە. بڕوانە \xt لێڤییەکان 4‏:2‏\xt*\ft ‏.‏\f* هەموو ئەم فەرمانانەتان بەجێنەهێنا کە یەزدان بە موسای سپارد،
\v 23 هەموو ئەوەی یەزدان لەسەر دەستی موسا فەرمانی پێ کردوون، لەو ڕۆژەوەی یەزدان فەرمانی پێ کردووە و بەردەوام نەوە دوای نەوە،
\v 24 ئەگەر بەبێ ئەنقەست و بێ بوونی زانیاری کۆمەڵ ئەمە ئەنجام درا، ئەوا بەپێی فەرزەکان هەموو کۆمەڵ جوانەگایەک لەگەڵ پێشکەشکراوی دانەوێڵە و شەرابی پێشکەشکراو دەکەنە قوربانی سووتاندن، وەک ئەو بۆنەی یەزدان پێی خۆشە، لەگەڵ گیسکێکی نێرینە وەک قوربانی گوناه.
\v 25 جا کاهین کەفارەت بۆ هەموو کۆمەڵی ئیسرائیل دەکات و لێخۆشبوونیان بۆ دەبێت، چونکە بەبێ ئەنقەست بووە. جا ئەگەر قوربانییەکەیان وەک قوربانی بە ئاگر بۆ یەزدان هێنا و قوربانییەکەی گوناهیان بۆ بەردەم یەزدان هێنا لەبەر بێئاگاییەکەیان،
\v 26 ئەوا هەموو کۆمەڵی نەوەی ئیسرائیل و ئەو نامۆیەش کە لەنێویان دەژیێت لێخۆشبوونی بۆ دەبێت، چونکە هەموو گەل بەبێ ئەنقەست تێوەگلاون.
\p 
\v 27 «”ئەگەر یەک کەس بەبێ ئەنقەست گوناهی کرد، ئەوا بزنێکی یەک ساڵە پێشکەش دەکات وەک قوربانی گوناه.
\v 28 کاهین لەبەردەم یەزدان کەفارەت بۆ ئەو کەسە دەکات کە بێئاگا بوو کاتێک گوناهی بەبێ ئەنقەست کرد، کەفارەتی بۆ دەکات و لێخۆشبوونی بۆ دەبێت.
\v 29 بۆ هاوڵاتی لە نەوەی ئیسرائیل و بۆ ئەو نامۆیەش کە لەنێویان دەژیێت، یەک یاسا دەبێت بۆ ئەوەی بەبێ ئەنقەست گوناهی کردبێت.
\p 
\v 30 «”بەڵام ئەو کەسەی هاوڵاتی بێت یان نامۆ بە دەستی ئەنقەست گوناه بکات، ئەو کەسە کفری بەرامبەر بە یەزدان کردووە، ئەو کەسە لەنێو گەلەکەی دادەبڕدرێت،
\v 31 چونکە سووکایەتی بە فەرمایشتی یەزدان کردووە و فەرمانی ئەوی شکاندووە، بێگومان ئەو کەسە دادەبڕدرێت و ئۆباڵی خۆی لە ملی خۆی.“»
\s1 شکاندنی یاسای شەممە
\p 
\v 32 کاتێک نەوەی ئیسرائیل لە چۆڵەوانی بوون پیاوێکیان بینی لە ڕۆژی شەممەدا داری کۆدەکردەوە،
\v 33 جا ئەوانەی بینییان دار کۆدەکاتەوە بردیانە بەردەم موسا و هارون و هەموو کۆمەڵ.
\v 34 ئینجا لە بەندیخانەیان دانا، چونکە ئاشکرا نەبوو بوو چی لێ دەکرێت.
\v 35 جا یەزدان بە موسای فەرموو: «ئەو پیاوە دەبێت بکوژرێت، لە دەرەوەی ئۆردوگا هەموو کۆمەڵ بەردبارانی دەکەن.»
\v 36 جا هەموو کۆمەڵ بردیانە دەرەوەی ئۆردوگا و بەردبارانیان کرد و مرد، وەک یەزدان فەرمانی بە موسا کرد.
\s1 گوڵنگ لەسەر جلوبەرگ
\p 
\v 37 هەروەها یەزدان بە موسای فەرموو:
\v 38 «لەگەڵ نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”با گوڵنگ لە لچکی\f + \fr 15:38 \ft لاولوێچ یان لچک مەبەست لە سەرگۆشەی قوماشە یان جل و بەرگ.‏\f* جلەکانتان دروستبکەن، نەوە دوای نەوە و لەسەر لچکەکانی خوارەوە گوڵنگی مۆر دابنێن.
\v 39 کاتێک ئەم گوڵنگانە دەبینن هەموو فەرمانەکانی یەزدانتان بەبیر دێتەوە و جێبەجێی دەکەن و بەدوای ئارەزووی دڵ و چاوتان ناکەون هەتا بەدوایاندا بەدڕەوشتی بکەن،
\v 40 هەتا بەبیرتان بێتەوە و هەموو فەرمانەکانی یەزدان جێبەجێ بکەن و بۆ خوداتان پیرۆز بن.
\v 41 من یەزدانی پەروەردگارتانم کە لە خاکی میسر دەریهێنان هەتا ببێت بە خوداتان، من یەزدانی پەروەردگارتانم.“»
\c 16
\s1 قۆرەح و داتان و ئەبیرام
\p 
\v 1 قۆرەحی کوڕی یەسهار کوڕی قەهات کوڕی لێڤی و داتان و ئەبیرامی کوڕانی ئەلیاب و ئۆنی کوڕی پەلەت لە نەوەی ڕەئوبێن
\v 2 لە دژی موسا هەستانەوە. چەند کەسێکیش لە نەوەی ئیسرائیل لەگەڵیان بوون، دوو سەد و پەنجا کەس لە ڕابەرەکانی کۆمەڵ لە ئەنجومەن هەڵبژێردرابوون، کە زۆر ناسراو بوون،
\v 3 جا لەسەر موسا و هارون کۆبوونەوە و پێیان گوتن: «ئێوە زیادەڕۆییتان کردووە! هەموو کۆمەڵ پیرۆزن و یەزدانیش لەنێوانیاندایە، ئیتر بۆچی خۆتان لەسەر کۆمەڵی یەزدان بەرز دەکەنەوە؟»
\p 
\v 4 جا موسا گوێی لێبوو و بەسەر ڕوودا کەوت.
\v 5 ئینجا بە قۆرەح و هەموو کۆمەڵەکەی گوت: «بەیانی یەزدان پیشانی دەدات کێ بۆ ئەوە و کێ پیرۆزە تاکو لە خۆی نزیکی بکاتەوە، جا هەرکەسێک هەڵبژێرێت ئەو لە خۆی نزیک دەکاتەوە.
\v 6 ئەمە بکەن، بخووردان بۆ خۆتان ببەن، قۆرەح و هەموو کۆمەڵەکەی،
\v 7 بەیانی ئاگری لەناو دابنێن و لەبەردەم یەزدان بخووری بەسەردا بکەن، جا ئەو پیاوەی یەزدان هەڵیدەبژێرێت ئەو پیرۆزە، ئیتر ئەی نەوەی لێڤی ئەمەتان بەس بێت!»
\p 
\v 8 هەروەها موسا بە قۆرەحی گوت: «ئەی نەوەی لێڤی گوێ بگرن،
\v 9 ئایا بە کەمی دەزانن کە خودای ئیسرائیل لەنێو کۆمەڵی ئیسرائیل جیای کردنەوە بۆ ئەوەی لە خۆی نزیکتان بکاتەوە، تاکو خزمەتی چادری پەرستنی یەزدان بکەن و لەبەردەم کۆمەڵ بوەستن بۆ خزمەتکردنی؟
\v 10 جا تۆ و هەموو براکانت لە نەوەی لێڤی لە خۆی نزیک کردەوە و داوای کاهینیێتیش دەکەن؟
\v 11 کەواتە تۆ و هەموو کۆمەڵەکەت لەسەر دژایەتیکردنی یەزدان ڕێک کەوتوون، بەڵام هارون کێیە هەتا بۆڵەبۆڵی لەسەر بکەن؟»
\p 
\v 12 جا موسا ناردی هەتا بانگی داتان و ئەبیرامی کوڕانی ئەلیاب بکەن، بەڵام ئەوان گوتیان: «نایەین!
\v 13 ئایا ئەمە بەس نییە کە تۆ لە خاکێک دەرتهێناین کە شیر و هەنگوینی لێ دەڕژێت هەتا لە چۆڵەوانی بمانمرێنیت و ئێستاش خۆت بکەیت بە میر بەسەرمانەوە،
\v 14 هەروەها ئێمەت نەهێناوەتە خاکێک شیر و هەنگوینی لێ بڕژێت و کێڵگە و ڕەزت بە میرات پێنەداین. ئایا چاوی ئەو کەسانە دەردەهێنیت؟\f + \fr 16:14 \ft دەربڕینێکە بە واتای ئەوەی «ئایا ئەو خەڵکە هەڵدەخەڵەتێنی؟»‏\f* ئێمە نایەین!»
\p 
\v 15 جا موسا زۆر تووڕە بوو و بە یەزدانی گوت: «ئاوڕ لە قوربانییەکەیان مەدەوە. نە گوێدرێژێکم لێ بردوون و نە خراپەم لەگەڵ کەسیان کردووە.»
\p 
\v 16 ئینجا موسا بە قۆرەحی گوت: «بەیانی تۆ و هەموو کۆمەڵەکەت لەبەردەم یەزدان بن، تۆ و ئەوان و هارونیش.
\v 17 هەریەکە بخووردانەکەی ببات و بخووری تێبکات و لەبەردەم یەزدان بخووردانەکەی پێشکەش بکات، دوو سەد و پەنجا بخووردان، تۆ و هارونیش هەریەکە و بخووردانی خۆتان.»
\v 18 جا هەریەکە بخووردانەکەی خۆی برد و ئاگریان تێکرد و بخووریان بەسەردا کرد و لەگەڵ موسا و هارون لەلای دەروازەی چادری چاوپێکەوتن ڕاوەستان.
\v 19 قۆرەحیش هەموو کۆمەڵی لە دژی ئەوان لەلای دەروازەی چادری چاوپێکەوتن کۆکردەوە، جا شکۆمەندی یەزدان بۆ هەموو کۆمەڵ دەرکەوت.
\v 20 ئینجا یەزدان بە موسا و هارونی فەرموو:
\v 21 «خۆتان لەم کۆمەڵە جیا بکەنەوە، وا من دەستبەجێ لەناویان دەبەم.»
\p 
\v 22 بەڵام موسا و هارون بەسەر ڕوویاندا کەوتن و گوتیان: «خودایە، ئەی ئەو خودایەی ژیان بە ئادەمیزاد دەبەخشیت، ئایا یەک پیاو گوناه بکات، تۆ لە هەموو کۆمەڵ تووڕە دەبیت؟»
\p 
\v 23 جا یەزدان بە موسای فەرموو:
\v 24 «لەگەڵ کۆمەڵ بدوێ و بڵێ: ”لە دەوروبەری چادرەکانی قۆرەح و داتان و ئەبیرام دوور بکەونەوە.“»
\p 
\v 25 موسا هەستا و چوو بۆ لای داتان و ئەبیرام، پیرەکانی ئیسرائیلیش دوای کەوتن،
\v 26 ئینجا موسا بە کۆمەڵەکەی گوت: «لە چادرەکانی ئەو کەسە بەدکارانە دوور بکەونەوە و دەست لە هیچ شتێکی ئەوان مەدەن، نەوەک بە هەموو گوناهەکانی ئەوانەوە لەناوبچن.»
\v 27 ئیتر ئەوانیش لە دەوروبەری چادرەکانی قۆرەح و داتان و ئەبیرام دوورکەوتنەوە و داتان و ئەبیرامیش هاتنە دەرەوە و لەگەڵ ژن و کوڕ و منداڵەکانیان لە دەرگای چادرەکانیان وەستان.
\p 
\v 28 ئینجا موسا گوتی: «بەمە دەزانن کە یەزدان ناردوومی بۆ ئەوەی ئەم هەموو کارانە بکەم و ئەمەش لە خۆمەوە نییە.
\v 29 ئەگەر ئەم پیاوانە وەک مردنێکی سروشتی بمرن و وەک هەموو مرۆڤێک بە مەرگی ئاسایی مردن، ئەوا یەزدان منی نەناردووە.
\v 30 بەڵام ئەگەر یەزدان شتێکی نوێی داهێنا و زەوی دەمی کردەوە و قووتی دان لەگەڵ هەموو ئەوەی هەیانە و بە زیندوویی چوونە خوارەوە بۆ ناو جیهانی مردووان، ئەوا دەزانن کە ئەو کۆمەڵە سووکایەتییان بە یەزدان کردووە.»
\p 
\v 31 کاتێک لە هەموو ئەم قسانە بووەوە، زەوییەکەی ژێریان شەق بوو و
\v 32 زەوی دەمی کردەوە و قووتی دان لەگەڵ ماڵەکانیان و هەموو پیاوەکانی قۆرەح و لەگەڵ هەموو سامانەکانیان.
\v 33 جا خۆیان و هەموو ئەوەی هەیان بوو بە زیندوویی چوونە خوارەوە بۆ ناو جیهانی مردووان و زەوی بەسەریاندا هاتەوە یەک و لەنێو کۆمەڵدا لەناوچوون.
\v 34 هەموو ئیسرائیلیش کە لە چواردەوریان بوون لە هاواریان هەڵاتن و گوتیان: «نەوەک زەوی قووتمان بدات!»
\p 
\v 35 ئاگرێکیش لەلایەن یەزدانەوە هات و دوو سەد و پەنجا پیاوەکەی هەڵلووشی کە بخووریان پێشکەش کرد.
\p 
\v 36 ئینجا یەزدان بە موسای فەرموو:
\v 37 «بە ئەلعازاری کوڕی هارونی کاهین بڵێ، با بخووردانەکان لەناو ئاگرەکە هەڵبگرێت و پاشماوەی ئاگرەکە لە دوور و بە فراوانی بڵاو بکاتەوە،
\v 38 چونکە بخووردانەکانی ئەوانەی لە دژی نرخی ژیانی خۆیان گوناهبارن پیرۆزکراون. با بخووردانەکان بکوتن و بیکەنە چەند پلێتێک و قوربانگاکەی پێ دابپۆشرێت، چونکە لەبەردەم یەزدان پێشکەشیان کرد و پیرۆز بوو. با نەوەی ئیسرائیل پەند لەمە وەربگرن.»
\p 
\v 39 ئینجا ئەلعازاری کاهین بخووردانە بڕۆنزییەکانی برد کە ئەوانەی سووتێنرابوون پێشکەشیان کردبوو و کوتایان و کردیانە پۆشەر بۆ قوربانگاکە،
\v 40 وەک یەزدان پێی فەرموو لەسەر دەستی موسا. ئەمە وەک بەبیرهێنانەوەیەک بوو بۆ نەوەی ئیسرائیل، ئەگەر پیاوێکی بێگانە کە لە نەوەی هارون نەبێت لەبەردەم یەزدان بۆ بخوور سووتاندن نزیک بکەوێتەوە، ئەوا وەک قۆرەح و کۆمەڵەکەی لێدێت.
\p 
\v 41 جا هەموو کۆمەڵی نەوەی ئیسرائیل بۆ بەیانی دەستیان بە بۆڵەبۆڵ کرد لەسەر موسا و هارون و گوتیان: «ئێوە گەلی یەزدانتان کوشت.»
\p 
\v 42 کاتێک کۆمەڵ لە دژی موسا و هارون کۆبوونەوە ئەوان چوونە لای چادری چاوپێکەوتن، لەپڕ هەورێک دایپۆشی و شکۆمەندی یەزدان دەرکەوت.
\v 43 جا موسا و هارون هاتنە بەردەم چادری چاوپێکەوتن.
\v 44 یەزدانیش بە موسای فەرموو:
\v 45 «لەنێو ئەم کۆمەڵە بچنە دەرەوە، من بە ساتێک لەناویان دەبەم.» جا بەسەر ڕوویاندا کەوتن.
\p 
\v 46 ئینجا موسا بە هارونی گوت: «بخووردانەکە ببە و لەسەر قوربانگاکەوە ئاگری تێبکە، بخووری لەسەر دابنێ، بە خێرایی بیبە لای کۆمەڵ و کەفارەتیان بۆ بکە. لەبەر ئەوەی تووڕەیی یەزدان جۆشاوە، وا دەردەکە دەستی پێکرد.»
\v 47 ئیتر هارون لەسەر قسەی موسا ڕایکرد بۆ ناو کۆمەڵ، بەڵام دەردەکە لەنێو گەلدا دەستی پێکردبوو، ئەویش بخوورەکەی پێشکەش کرد و کەفارەتی بۆ گەل کرد.
\v 48 هارون لەناوەندی مردووان و زیندوواندا ڕاوەستا، دەردەکەش وەستا،
\v 49 جا ئەوانەی بە دەردەکە مردن چواردە هەزار و حەوت سەد بوون، بێجگە لەوانەی بەهۆی قۆرەحەوە مردن.
\v 50 ئینجا هارون گەڕایەوە لای موسا بۆ لای دەروازەی چادری چاوپێکەوتن، لەبەر ئەوەی دەردەکە وەستابوو.
\c 17
\s1 خونچەکردنی گۆچانی هارون
\p 
\v 1 یەزدان بە موسای فەرموو:
\v 2 «لەگەڵ نەوەی ئیسرائیل بدوێ و گۆچانیان لێ وەربگرە، بۆ هەر هۆزێک گۆچانێک، لە هەموو سەرۆکەکانیان بەگوێرەی هۆزەکانیان دوازدە گۆچان و ناوی هەریەکەیان لەسەر گۆچانەکەی دەنووسیت و
\v 3 ناوی هارونیش لەسەر گۆچانی لێڤی دەنووسیت، چونکە بۆ هەر سەرۆک هۆزێک یەک گۆچانە.
\v 4 لە چادری چاوپێکەوتن لەبەردەم سندوقی پەیمان دایبنێ، لەو شوێنەی لەگەڵتان کۆ دەبمەوە.
\v 5 جا ئەو پیاوەی هەڵیدەبژێرم گۆچانەکەی چەکەرە دەکات، ئەوسا ئەو بۆڵەبۆڵەی نەوەی ئیسرائیل لەسەر خۆم کپ دەکەم کە لە دژی ئێوە دەیکەن.»
\p 
\v 6 ئینجا موسا قسەی لەگەڵ نەوەی ئیسرائیل کرد، هەموو سەرکردەکان هەریەکە گۆچانێکیان دایێ، دوازدە گۆچان بەگوێرەی ژمارەی سەرۆک هۆزەکان، گۆچانەکەی هارونیش لەنێو گۆچانەکانی ئەوان بوو.
\v 7 جا موسا گۆچانەکانی لەناو چادری پەیمان لەبەردەم یەزدان دانا.
\p 
\v 8 بۆ بەیانیش موسا چووە ناو چادری شایەتی و بینی گۆچانەکەی هارون کە سەر بە بنەماڵەی لێڤییە چەکەرەی کردووە، خونچەی کردووە و گوڵی کردووە و بادەمی گرتووە و پێگەیشتووە.
\v 9 جا موسا هەموو گۆچانەکانی لەبەردەم یەزدان بردە دەرەوە بۆ هەموو نەوەی ئیسرائیل، تەماشایان کرد و هەریەکە گۆچانی خۆی بردەوە.
\p 
\v 10 یەزدانیش بە موسای فەرموو: «گۆچانەکەی هارون بگەڕێنەوە بەردەم سندوقی پەیمان، بۆ ئەوەی بپارێزرێت و یاخیبووان پەندی لێ وەربگرن. بەو شێوەیە چیتر بۆڵەبۆڵم بەسەردا ناکەن، تاکو نەمرن.»
\v 11 موساش ئاوای کرد، هەروەک یەزدان فەرمانی پێ کرد.
\p 
\v 12 ئینجا نەوەی ئیسرائیل بە موسایان گوت: «ئێمە لەناوچووین و ون بووین، هەموومان ون بووین!
\v 13 هەموو ئەوانەی لە چادری پەرستنی یەزدان نزیک دەبنەوە دەمرن، ئایا هەموومان لەناودەچین؟»
\c 18
\s1 خزمەتی کاهین و لێڤی
\p 
\v 1 یەزدان بە هارونی فەرموو: «تۆ و کوڕەکانت و بنەماڵەکەت ئۆباڵی ئەو گوناهانە هەڵدەگرن کە لە پیرۆزگا دەکرێت، تۆ و کوڕەکانت ئۆباڵی ئەو گوناهانە هەڵدەگرن کە لە کاهینیێتییەکەتان دەکرێت.
\v 2 هەروەها براکانت، هۆزی لێڤی، هۆزی باوکت، لە خۆت نزیک بکەوە، ئینجا بە تۆوە پابەند دەبن و پاڵپشتی تۆ و کوڕەکانت دەکەن لەبەردەم چادری پەیمان.
\v 3 ئەوان بەردەستی خۆت و هەموو کاروباری چادرەکە دەکەن، بەڵام لە قاپوقاچاغی پیرۆزگاکە و لە قوربانگاکە نزیک ناکەونەوە، نەوەک ئەوان و ئێوەش، هەمووتان بمرن.
\v 4 پابەندت دەبن و بەرپرسیاریش دەبن لە پارێزگاری چادری چاوپێکەوتن لەگەڵ هەموو خزمەتی چادرەکە، هیچ کەسێکی دیکەش لێتان نزیک ناکەوێتەوە.
\p 
\v 5 «بەڵکو ئێوە بەرپرسیار دەبن لە پارێزگاری پیرۆزگاکە و قوربانگاکە، تاکو جارێکی دیکە تووڕەیی نەیەتە سەر نەوەی ئیسرائیل.
\v 6 من خۆم لێڤییەکانی براتانم لەنێو نەوەی ئیسرائیل هەڵبژارد و دامەوە ئێوە، بۆ یەزدان تەرخانکراون تاکو خزمەتەکەی چادری چاوپێکەوتن بەجێبگەیەنن.
\v 7 تەنها تۆ و کوڕەکانت لەگەڵت خزمەتی کاهینیێتی دەکەن، لەگەڵ هەموو ئەوەی پەیوەندی بە قوربانگاکە هەیە و ئەوەی لەناو پەردەکەیە دەپارێزن. کاهینیێتی پێدراوێکی تایبەت بە ئێوەیە و پێمداون و هەرکەسێکی دیکە ئەوەی لە پیرۆزگا نزیک بکەوێتەوە دەکوژرێت.»
\s1 بەشی کاهین و لێڤییەکان
\p 
\v 8 یەزدان بە هارونی فەرموو: «ئێستا من بەرپرسیاریێتی پێشکەشکراوەکان کە بۆ منی بەرز دەکەنەوە داومەتە تۆ، هەموو پێشکەشکراوە پیرۆزەکانی نەوەی ئیسرائیل، دەیدەمە خۆت و کوڕەکانت وەک بەشە کاهینیێتیتان و بەشێکی چەسپاوە.
\v 9 ئەم بەشە بۆ تۆ دەبێت لە پێشکەشکراوە هەرەپیرۆزەکان ئەوەی لە ئاگر دەپارێزرێت. لە هەموو قوربانییەکانیان و هەموو پێشکەشکراوەکانی دانەوێڵەیان و هەموو قوربانییەکانی گوناهیان و هەموو قوربانییەکانی تاوانیان کە بۆ منی دەهێنن، ئەو بەشە هەرەپیرۆزە بۆ تۆ و بۆ کوڕەکانتە.
\v 10 وەک شتێکی هەرەپیرۆز دەیخۆیت، هەموو نێرینەیەک لێی دەخوات، بۆ تۆ پیرۆز دەبێت.
\p 
\v 11 «ئەوەی لە بەخشین و قوربانی بەرزکردنەوەی ئیسرائیلییەکان بەلاوەدەنرێت، بۆ تۆیە. بەشێکی چەسپاوە داومەتە تۆ و کوڕ و کچەکانت. ئیتر هەموو کەسێک لە ماڵەکەت کە بەپێی ڕێوڕەسم پاکە لێی دەخوات.
\p 
\v 12 «باشترین زەیت و باشترین شەراب و باشترین دانەوێڵە، یەکەمین بەرهەمەکانیان کە بە یەزدانی دەدەن، من هەموویم داوەتە تۆ،
\v 13 یەکەمین بەرهەمی هەموو شتێکی زەوییەکەیان کە بۆ یەزدانی پێشکەش دەکەن بۆ تۆ دەبێت، هەموو کەسێک لە ماڵەکەت ئەوەی بەپێی ڕێوڕەسم پاکە لێی دەخوات.
\p 
\v 14 «هەموو تەرخانکراوێک\f + \fr 18:14 \ft لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان.‏\f* بۆ یەزدان لە ئیسرائیل بۆ تۆ دەبێت،
\v 15 هەر نۆبەرەیەکی سک کە پێشکەشی یەزدانی دەکەن لە مرۆڤ و لە ئاژەڵ، بۆ تۆ دەبێت، بەڵام پێویستە کوڕە نۆبەرەی مرۆڤ و نۆبەرە نێرینەی ئاژەڵی گڵاویش بکڕیتەوە.
\v 16 پێویستە لە تەمەنی یەک مانگییەوە بیانکڕیتەوە، نرخی کڕینەوەش پێنج شاقل لە زیو بەگوێرەی خەمڵاندنی شاقلی پیرۆزگا، کە بیست گێرایە\f + \fr 18:16 \ft بیست گێرا: نزیکەی 12 گرام. بڕوانە \xt دەرچوون 30‏:13‏\xt*\ft ‏.‏\f*.
\p 
\v 17 «بەڵام پێویستە نۆبەرەی مانگا و مەڕ و بزن نەکڕیتەوە، ئەوان پیرۆزن و خوێنەکەیان بەسەر قوربانگاکەدا دەڕژێنیت و پیوەکەیان\f + \fr 18:17 \ft پیوەکەی: واتا بەزەکەی.‏\f* دەسووتێنیت، قوربانی بە ئاگرە، ئەو بۆنەی یەزدان پێی خۆشە.
\v 18 گۆشتەکەشی بۆ تۆ دەبێت وەک سنگی قوربانی بەرزکردنەوە و ڕانی ڕاستە.
\v 19 هەرچییەک کە بەلاوە دەنرێت لە پێشکەشکراوە پیرۆزەکانی نەوەی ئیسرائیل کە بۆ یەزدانی پێشکەش دەکەن وەک بەشێکی چەسپاو داومە بە تۆ و کوڕ و کچەکانت، دەبێتە پەیمانی نمەک بۆ تۆ و نەوەکەت کە هەتاهەتایە لەبەردەم یەزدان دەچەسپێت.»
\p 
\v 20 هەروەها یەزدان بە هارونی فەرموو: «لە زەوییەکەیان هیچ میراتت بەرناکەوێت و لەنێویان بەشت نابێت، لەنێو نەوەی ئیسرائیل من بەش و میراتی تۆم.
\p 
\v 21 «بەڵام نەوەی لێڤی لەبری ئەو خزمەتەی دەیکەن، خزمەتی چادری چاوپێکەوتن، ئەوا من لە ئیسرائیل وەک میرات هەموو دەیەکێکم پێداون.
\v 22 لە ئێستا بەدواوە نەوەی ئیسرائیل لە چادری چاوپێکەوتن نزیک ناکەونەوە، هەتا گوناهێک هەڵبگرن کە بۆ مردن بێت،
\v 23 بەڵکو لێڤییەکان خزمەتی چادری چاوپێکەوتن دەکەن، ئەوان بەرپرسیاریێتی هەڵدەگرن وەک فەرزێکی هەتاهەتایی نەوە دوای نەوە، لەنێو نەوەی ئیسرائیلدا هیچ میراتیان بەرناکەوێت.
\v 24 دەیەکەکانی نەوەی ئیسرائیل کە بۆ یەزدانی پێشکەش دەکەن وەک بەخشینی بەرزکراوە، من داومە بە لێڤییەکان، میراتی ئەوانە، بۆیە پێیانم فەرموو کە لەنێو نەوەی ئیسرائیلدا هیچ میراتیان بەرناکەوێت.»
\p 
\v 25 یەزدان بە موسای فەرموو:
\v 26 «لەگەڵ لێڤییەکان دەدوێیت و پێیان دەڵێیت: ”کاتێک دەیەکەکە وەردەگرن لە نەوەی ئیسرائیل کە من وەک میرات بە ئێوەم داوە، بەخشینی بەرزکراوەی یەزدانی لێ پێشکەش دەکەن، دەیەک لە دەیەک.
\v 27 جا بە بەخشینی بەرزکراوەتان دادەنرێت، وەک دانەوێڵەی جۆخین و پڕی بەرهەمی گوشەرەکە\f + \fr 18:27 \ft واتا ئاوی ترێ.‏\f*.
\v 28 بەم شێوەیە ئێوەش بەخشینی بەرزکراوەی یەزدان لە هەموو دەیەکەکانتان پێشکەش دەکەن کە لە نەوەی ئیسرائیلی وەردەگرن، لەوە بەخشینی بەرزکراوەی یەزدان بە هارونی کاهین دەدەن.
\v 29 لە هەموو بەخشینەکانتان هەموو بەرزکراوەیەک بۆ یەزدان پێشکەش دەکەن کە لە هەرە باشترین و پیرۆزترین بێت.“
\p 
\v 30 «پێیان دەڵێیت: ”کاتێک باشترینەکەی پێشکەش دەکەن، وەک بەرهەمی جۆخین و گوشەر\f + \fr 18:30 \ft بڕوانە ئایەتی 27.‏\f* بۆ لێڤییەکان هەژمارد دەکرێت.
\v 31 ئێوە و ماڵەکانتان لە هەموو شوێنێک دەیخۆن، چونکە کرێی ئێوەیە لەبری خزمەتتان لە چادری چاوپێکەوتن.
\v 32 بەهۆیەوە گوناهباریش نابن ئەگەر لە باشترینەکەی پێشکەش بکەن، بەڵام پێشکەشکراوە پیرۆزەکانی نەوەی ئیسرائیل گڵاو مەکەن نەوەک بمرن.“»
\c 19
\s1 ئاوی پاککردنەوە
\p 
\v 1 یەزدان بە موسا و هارونی فەرموو:
\v 2 «ئەمە فەرزی فێرکردنەکەیە کە یەزدان فەرمانی پێ کردووە و دەفەرموێت، بە نەوەی ئیسرائیل بڵێ با نوێنگینێکی\f + \fr 19:2 \ft نوێنگین: بە گوێرەکە مێینەیەک دەگوترێت کاتێک کە لە شیر دەبڕدرێتەوە، کە تەمەنی لە یەک ساڵ تێبپەڕێنێ.‏\f* سووری ساغت بۆ بهێنن کە کەموکوڕی تێدا نەبێت و نیری\f + \fr 19:2 \fq نیر: \ft دارێکە دەخرێتە سەر شانی گا یان ڕەشەوڵاخ بۆ ڕاکێشانی عەرەبانە یان ئامێری جووت.\f* نەخرابێتە سەر.
\v 3 بدرێتە ئەلعازاری کاهین و دەبردرێتە دەرەوەی ئۆردوگا و لەبەردەمی سەردەبڕدرێت.
\v 4 ئەلعازاری کاهینیش بە پەنجەی لە خوێنەکەی دەبات و بەرەو ڕووی چادری چاوپێکەوتن حەوت جار دەیپرژێنێت.
\v 5 نوێنگینەکەش لەبەرچاوی دەسووتێنرێت، پێستی و گۆشتی و خوێنی و ڕیخۆڵەکەی دەسووتێنرێت.
\v 6 کاهینیش پارچە دارێکی ئورز و بەنی سووری ئاڵ و زوفا دەبات و هەڵیاندەداتە ناو ئاگری نوێنگینەکە.
\v 7 ئینجا کاهین جلەکانی دەشوات و خۆی بە ئاو دەشوات و لەدوای ئەوە دێتە ناو ئۆردوگاکەوە، هەتا ئێوارەش گڵاو دەبێت.
\v 8 ئەوەش کە سووتاندی جلەکانی بە ئاو دەشوات و خۆی بە ئاو دەشوات و هەتا ئێوارەش گڵاو دەبێت.
\p 
\v 9 «پیاوێکی پاکیش خۆڵەمێشی نوێنگینەکە کۆدەکاتەوە و لە دەرەوەی ئۆردوگاکە لە شوێنێکی پاک بەپێی ڕێوڕەسم دایدەنێت. پێویستە کۆمەڵی نەوەی ئیسرائیل بیپارێزن و بۆ ئاوی پاککردنەوە بەکاریبهێنن؛ بۆ پاکبوونەوە لە گوناه.
\v 10 ئەوەی خۆڵەمێشی نوێنگینەکەشی کۆکردەوە جلەکانی دەشوات و هەتا ئێوارە گڵاو دەبێت، جا بۆ نەوەی ئیسرائیل و ئەو نامۆیەش کە لەنێویانە، دەبێت بە فەرزێکی هەتاهەتایی.
\p 
\v 11 «ئەوەی دەست لە لاشەی کەسێکی مردوو بدات ئەوا حەوت ڕۆژ گڵاو دەبێت.
\v 12 پێویستە لە ڕۆژی سێیەمدا خۆی پێ پاک بکاتەوە\f + \fr 19:12 \ft پێ پاک بکاتەوە: واتا بە ئاوی پاککردنەوە، بڕوانە ئایەتی 9.‏\f* و لە ڕۆژی حەوتەم پاک دەبێت، بەڵام ئەگەر لە ڕۆژی سێیەمدا خۆی پاک نەکاتەوە ئەوا لە ڕۆژی حەوتەم پاک نابێت.
\v 13 هەرکەسێک دەست لە لاشەی کەسێکی مردوو بدات و خۆی پاک نەکاتەوە ئەوا چادری پەرستنی یەزدان گڵاو دەکات، ئەو کەسە لە ئیسرائیل دادەبڕدرێت، چونکە ئاوی پاککردنەوەی بەسەردا نەپرژێنراوە و گڵاوە، گڵاوییەکەی هێشتا تێدا ماوە.
\p 
\v 14 «ئەمە فێرکردنەکەیە، ئەگەر کەسێک لەناو چادرێکدا مرد ئەوا هەر یەکێک بێتە ناو چادرەکە و هەموو ئەوانەی لەناو چادرەکە بوون حەوت ڕۆژ گڵاو دەبن،
\v 15 هەموو دەفرێکی\f + \fr 19:15 \ft جام یان دەوری بۆ پێداویستی خواردن.‏\f* کراوەش کە بە باشی سەری دانەخرابێت ئەوا گڵاوە.
\p 
\v 16 «هەرکەسێک لە دەشتودەر دەست لە کوژراوێکی بە شمشێر یان مردووێک یان ئێسکی مرۆڤێک یان گۆڕێک بدات، ئەوا حەوت ڕۆژ گڵاو دەبێت.
\p 
\v 17 «جا بۆ گڵاو لە خۆڵەمێشی ئاگری قوربانی پاکبوونەوە دەبەن و لە گۆزەیەکدا ئاوێکی سازگاری بەسەردا دەکەن.
\v 18 پیاوێکی پاکیش بەپێی ڕێوڕەسم زوفایەک دەبات و نوقومی ناو ئاوەکەی دەکات و بەسەر چادر و هەموو شتومەکەکانیدا دەپرژێنێت، بەسەر ئەو کەسانەشدا دەپرژێنێت کە لەوێ بوون، هەروەها ئەوەش کە دەستی لە ئێسک یان کوژراو یان مردوو یان گۆڕ داوە.
\v 19 کەسە پاکەکەش لە ڕۆژی سێیەم و ڕۆژی حەوتەم ئاوەکە بەسەر کەسە گڵاوەکەدا دەپرژێنێت، لە ڕۆژی حەوتەم پاکی دەکاتەوە. ئەویش جلەکانی دەشوات و خۆی بە ئاو دەشوات و بۆ ئێوارە پاک دەبێت.
\v 20 بەڵام ئەو کەسەی گڵاو دەبێت و خۆی پاک ناکاتەوە، ئەوا ئەو گیانە لەنێو کۆمەڵدا دادەبڕدرێت، چونکە پیرۆزگای یەزدانی گڵاو کردووە، ئاوی پاککردنەوەی بەسەردا نەپرژێنراوە، گڵاوە.
\v 21 جا بۆیان دەبێتە فەرزێکی هەتاهەتایی.
\p «ئەوەی ئاوی پاککردنەوەی پرژاندووە جلەکانی دەشوات، ئەوەی دەستی لە ئاوی پاککردنەوە داوە، هەتا ئێوارە گڵاو دەبێت،
\v 22 هەرچییەک ئەو گڵاوە دەستی لێ بدات گڵاو دەبێت و ئەو کەسەش کە دەستی لێ بدات هەتا ئێوارە گڵاو دەبێت.»
\c 20
\s1 ئاو لە تاشەبەردەکەوە
\p 
\v 1 ئینجا نەوەی ئیسرائیل، هەموو کۆمەڵەکە هاتنە چۆڵەوانی چن لە مانگی یەکدا و گەل لە قادێش چادریان هەڵدا و لەوێدا مریەم مرد و لەوێش نێژرا.
\p 
\v 2 ئاو نەبوو بۆ کۆمەڵ، جا لە دژی موسا و هارون کۆبوونەوە و
\v 3 گەل کردیان بە دەمەقاڵێ لەگەڵ موسا و گوتیان: «خۆزگە وەک براکانمان لەبەردەم یەزدان لەناوبچووینایە!
\v 4 بۆچی کۆمەڵی یەزدانتان هێنایە ئەم چۆڵەوانییە هەتا تێیدا خۆمان و مەڕوماڵاتمان بمرین؟
\v 5 بۆچی ئێمەتان لە میسرەوە هێنایە دەرەوە تاکو بمانهێنن بۆ ئەم شوێنە خراپە؟ ئەم شوێنە دانەوێڵە و هەنجیر و مێو و هەناری لێ نییە، ئاوی خواردنەوەشی لێ نییە!»
\p 
\v 6 جا موسا و هارون لەبەردەم کۆمەڵەوە هاتنە لای دەروازەی چادری چاوپێکەوتن و بەسەر ڕوویاندا کەوتن و شکۆمەندی یەزدانیان بۆ دەرکەوت.
\v 7 یەزدانیش بە موسای فەرموو:
\v 8 «گۆچانەکە ببە و کۆمەڵ کۆبکەرەوە، تۆ و هارونی برات لەبەرچاویاندا بەو تاشەبەردە بڵێن هەتا ئاوەکەی بدات، جا لە تاشەبەردەکەوە ئاویان بۆ هەڵدەقوڵێت و کۆمەڵ و مەڕوماڵاتەکانیان ئاو دەدەیت.»
\p 
\v 9 موساش گۆچانەکەی لەبەردەم یەزدانەوە برد وەک فەرمانی پێ کرد.
\v 10 موسا و هارون جەماوەریان لەپێش تاشەبەردەکە کۆکردەوە، موسا پێی گوتن: «ئەی یاخیبووان گوێ بگرن، ئایا لەم بەردەوە ئاوتان بۆ دەربهێنین؟»
\v 11 موسا دەستی بەرزکردەوە و بە گۆچانەکەی دوو جار لە تاشەبەردەکەی دا، جا ئاوێکی زۆر هەڵقوڵا و کۆمەڵ و مەڕوماڵاتەکانیشیان لێیان خواردەوە.
\p 
\v 12 بەڵام یەزدان بە موسا و هارونی فەرموو: «لەبەر ئەوەی متمانەتان پێ نەکردم، تاکو لەبەرچاوی گەلی ئیسرائیل من بە پیرۆز نیشان بدەن، هەر لەبەر ئەوە ئەم کۆمەڵە نابەنە ناو ئەو خاکەی پێم داون.»
\p 
\v 13 ئەمە مێرگی مەریبایە کە نەوەی ئیسرائیل لەگەڵ یەزداندا دەمەقاڵێیان کرد و ئەویش لەنێویاندا پیرۆزی خۆی نیشان دان.
\s1 ئەدۆم ڕێگا بە ئیسرائیل نادات
\p 
\v 14 ئینجا موسا لە قادێشەوە چەند نێردراوێکی بۆ لای پاشای ئەدۆم نارد:
\pm «ئیسرائیلی برات ئاوا دەڵێت: تۆ بە هەموو ناخۆشییەکانت زانی کە تووشمان هات.
\v 15 باوکانمان چوونە میسر و ڕۆژانێکی زۆر لە میسر ماینەوە. میسرییەکان ئێمە و باوکانی ئێمەیان زەلیل کرد،
\v 16 بەڵام هاوارمان بۆ یەزدان کرد و گوێی لە دەنگمان بوو، فریشتەیەکی نارد و لە میسر دەریهێناین.
\pm «ئێستا ئێمە لە قادێشین کە شارۆچکەیەکە لە نزیکی سنووری خاکەکەت.
\v 17 تکایە ڕێمان بدە بە خاکەکەتدا تێبپەڕین، نە بە کێڵگەیەکدا دەڕۆین و نە بە ڕەزێکدا و نە ئاوی بیرێک دەخۆینەوە، لە شاڕێگای پاشاوە\f + \fr 20:17 \ft عیبری: ڕێگای پاشا، مەبەست لەو ڕێگایە کە لەژێر چاودێری و دەسەڵاتی پاشادایە.‏\f* دەڕۆین، نە بەلای ڕاست لادەدەین و نە بەلای چەپ هەتا لە خاکەکەت دەچینە دەرەوە.»
\p 
\v 18 بەڵام ئەدۆم وەڵامی دانەوە:
\pm «بە خاکەکەماندا\f + \fr 20:18 \ft عیبری: بەناو مندا.‏\f* ناڕۆن، ئەگینا بە شمشێرەوە پەلامارتان دەدەم.»
\p 
\v 19 نەوەی ئیسرائیلیش گوتیان:
\pm «بە ڕاستەڕێدا دەڕۆین، ئەگەر خۆمان و مەڕوماڵاتەکانمان لە ئاوی تۆمان خواردەوە ئەوا نرخەکەی دەدەین، هیچی دیکە ناکەین تەنها بە پێیەکانمان تێدەپەڕین.»
\p 
\v 20 دیسان ئەدۆم وەڵامی دانەوە:
\pm «تێناپەڕن.»
\p ئینجا ئەدۆم بە سوپایەکی گەورە و دەستێکی توندەوە بۆ بەرەنگاربوونەوەی دەرچوو.
\v 21 ئەدۆم ڕازی نەبوو ئیسرائیل بە خاکی ئەودا تێبپەڕێت، ئیسرائیلیش لێی لادا.
\s1 مردنی هارون
\p 
\v 22 هەموو کۆمەڵی نەوەی ئیسرائیل لە قادێشەوە کۆچیان کرد و هاتنە کێوی هۆر،
\v 23 یەزدانیش لە کێوی هۆر لەسەر سنووری خاکی ئەدۆم بە موسا و هارونی فەرموو:
\v 24 «هارون دەچێتە پاڵ گەلەکەی، چونکە ناچێتە ناو ئەو خاکەی بە نەوەی ئیسرائیلم داوە، چونکە ئێوە لەلای مێرگی مەریبا لە فەرمانم یاخی بوون.
\v 25 هارون و ئەلعازاری کوڕی ببە سەر کێوی هۆر و
\v 26 جلەکان لەبەر هارون دابکەنە و لەبەر ئەلعازاری کوڕی بکە، جا هارونیش دەچێتە پاڵ گەلەکەی و لەوێ دەمرێت.»
\p 
\v 27 موساش ئاوای کرد وەک یەزدان فەرمانی دا و لەبەرچاوی هەموو کۆمەڵ بەسەر کێوی هۆر کەوتن.
\v 28 ئینجا موسا جلەکانی لەبەر هارون داکەند و لەبەر ئەلعازاری کوڕی کرد، هارونیش لەوێ لەسەر لووتکەی کێوەکە مرد. ئینجا موسا و ئەلعازار لە کێوەکە هاتنە خوارەوە.
\v 29 کاتێک هەموو کۆمەڵ بینییان هارون مرد، هەموو بنەماڵەی ئیسرائیل سی ڕۆژ بۆ هارون گریان.
\c 21
\s1 وێرانکردنی عەراد
\p 
\v 1 کاتێک کەنعانییەکەی پاشای عەراد کە لە نەقەب نیشتەجێ بوو بیستی نەوەی ئیسرائیل لە ڕێگای ئەتاریمەوە هاتووە، شەڕی لەگەڵ ئیسرائیلییەکاندا کرد و هەندێکی لێیان بە دیل گرت.
\v 2 نەوەی ئیسرائیلیش نەزرێکیان بۆ یەزدان کرد و گوتیان، «ئەگەر ئەو نەتەوەیە بخەیتە ژێر دەستمان، ئەوا شارەکانی بە تەواوی وێران دەکەین\f + \fr 21:2 \ft وێران دەکەین: لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f*.»
\v 3 یەزدانیش گوێی لە هاواری ئیسرائیل گرت و کەنعانییەکانی دایە دەست و خۆیان و شارۆچکەکانیان بە تەواوی وێران کردن، ئیتر ئەو شوێنە ناونرا حۆرما.\f + \fr 21:3 \ft حۆرما: واتا وێرانکردن.‏\f*
\s1 موسا مارێک لە بڕۆنز دروستدەکات
\p 
\v 4 ئینجا لە کێوی هۆرەوە بە ڕێگای دەریای سوور کۆچیان کرد هەتا بە خاکی ئەدۆمدا بسوڕێنەوە، جا گەل لە ڕێگادا ئارامییان لێ بڕا.
\v 5 گەل لە دژی خودا و موسا قسەیان کرد و گوتیان: «بۆچی لە میسر دەرتانهێناین هەتا لە چۆڵەوانی بمرین؟ نە نان هەیە و نە ئاو! ئەم خواردنە بێ تامەمان لەبەرچاو کەوتووە.»
\p 
\v 6 یەزدانیش ماری ژەهراوی بۆ سەر گەل نارد و بە گەلیانەوە دا و خەڵکێکی زۆر لە ئیسرائیل مردن.
\v 7 ئینجا گەل هاتنە لای موسا و گوتیان: «گوناهمان کرد لە دژی یەزدان و لە دژی تۆش قسەمان کرد. لەبەر ئەوە نزا بۆ یەزدان بکە هەتا ئەو مارانەمان لەسەر هەڵبگرێت.» موساش لە پێناوی گەل نزای کرد.
\p 
\v 8 یەزدانیش بە موسای فەرموو: «مارێکی ژەهراوی دروستبکە و لەسەر ستوونێک هەڵیبواسە، جا هەر یەکێک پێیەوەدرا و تەماشای کرد دەژیێت.»
\v 9 موساش مارێکی لە بڕۆنز دروستکرد و لەسەر ستوونێک هەڵیواسی، ئەوە بوو هەر کاتێک کەسێک مار پێوەی دەدا و تەماشای مارە بڕۆنزییەکەی دەکرد، دەژیا.
\s1 بەرەو مۆئاب
\p 
\v 10 ئینجا نەوەی ئیسرائیل کۆچیان کرد و لە ئۆڤۆت چادریان هەڵدا،
\v 11 لە ئۆڤۆتەوەش کۆچیان کرد و لە عییی عەڤاریم لە چۆڵەوانی بەرامبەر مۆئاب ڕووەو خۆر هەڵاتن چادریان هەڵدا.
\v 12 لەوێشەوە کۆچیان کرد و لە دۆڵی زەرەد چادریان هەڵدا،
\v 13 لەوێشەوە کۆچیان کرد و لە قەراغی باکووری ڕووباری ئەرنۆن چادریان هەڵدا کە لە چۆڵەوانییە لە دەرەوەی سنووری ئەمۆرییەکانە، چونکە ئەرنۆن سنووری مۆئابە لەنێوان مۆئاب و ئەمۆرییەکان،
\v 14 لەبەر ئەوە پەڕتووکی جەنگەکانی یەزدان دەڵێت:
\q1 «شاری واهێڤ لە سوفە و شیوەکانی،
\q2 ئەرنۆن و
\v 15 نشێوی شیوەکان،
\q1 ئەوەی هەتا نشینگەی عار شۆڕ بووەتەوە،
\q2 پشتی بە سنووری مۆئابەوە داوە.»
\m 
\v 16 لەوێشەوە بۆ بئێر بەردەوام بوون، ئەوەش ئەو بیرەیە کە لەوێ یەزدان بە موسای فەرموو، «گەل کۆبکەرەوە ئاویان دەدەمێ.»
\p 
\v 17 ئەوسا ئیسرائیل ئەم گۆرانییەیان چڕی:
\q1 «ئەی بیر هەڵبقوڵێ،
\q2 گۆرانی لە بارەوە بڵێن،
\q1 
\v 18 بیرێک میرەکان لێیان داوە،
\q2 پیاوماقوڵانی گەل هەڵیانکەندووە،
\q2 ئەو پیاوماقوڵانە بە داردەست و گۆچانەکانیان.»
\m لە چۆڵەوانییەوە هەتا مەتانە چوون،
\v 19 لە مەتانەوە هەتا نەحەلیێل و لە نەحەلیێلەوە هەتا بامۆت\f + \fr 21:19 \ft بڕوانە \xt 22‏:41‏\xt*\ft .‏\f*،
\v 20 لە بامۆتەوە هەتا دۆڵێک کە لە مۆئابە و لە لووتکەی چیای پسگە کە دەڕوانێتە سەر ڕووی چۆڵەوانی.
\s1 شکاندنی سیحۆن و عۆگ
\p 
\v 21 ئینجا ئیسرائیل نێردراوی بۆ سیحۆنی پاشای ئەمۆرییەکان نارد و گوتی:
\pm 
\v 22 «ڕێمان بدە بە خاکەکەتدا تێپەڕین، نە بەلای کێڵگەیەک و نە بەلای ڕەزە مێوێک لانادەین و ئاو لە بیر ناخۆینەوە، هەتا لە خاکەکەت دەچینە دەرەوە بە شاڕێگادا دەڕۆین.»
\p 
\v 23 بەڵام سیحۆن نەیهێشت ئیسرائیل بە خاکەکەیدا تێبپەڕێت، بەڵکو هەموو سوپاکەی کۆکردەوە و بۆ بەرەنگاربوونەوەی ئیسرائیل بۆ چۆڵەوانی دەرچوو، هاتە یەهەچ و شەڕی لەگەڵ ئیسرائیل کرد.
\v 24 ئیسرائیلیش بە شمشێر لێیدا و دەستی بەسەر خاکەکەیدا گرت، لە ئەرنۆنەوە هەتا یەبۆق و هەتا نەوەی عەمۆن، چونکە سنووری عەمۆنییەکان بەهێز بوو.
\v 25 ئیسرائیل هەموو ئەم شارانەی گرت، ئیسرائیل لە هەموو شارەکانی ئەمۆرییەکان نیشتەجێ بوو، لە حەشبۆن و لە هەموو گوندەکانی.
\v 26 لەبەر ئەوەی حەشبۆن شاری سیحۆنی پاشای ئەمۆرییەکان بوو، شەڕی لەگەڵ پاشای پێشووی مۆئاب کردبوو و هەموو خاکەکەی لە دەستی سەندبوو هەتا ئەرنۆن.
\p 
\v 27 لەبەر ئەوە شیعرەکان دەڵێن:
\q1 «وەرنە حەشبۆن بنیاد دەنرێتەوە،
\q2 شاری سیحۆن نۆژەن دەکرێتەوە.
\b
\q1 
\v 28 «ئاگرێک لە حەشبۆنەوە کڵپەی کرد،
\q2 گڕێک لە شاری سیحۆنەوە،
\q1 عاری مۆئابی هەڵلووشی،
\q2 پیاوانی بەرزاییەکانی ئەرنۆن.
\q1 
\v 29 قوڕبەسەرت مۆئاب!
\q2 ئەی گەلی کەمۆش لەناوچوویت!
\q1 کوڕەکانی ئاوارە کرد و
\q2 کچەکانی ڕاپێچ کرد
\q2 بۆ سیحۆنی پاشای ئەمۆرییەکان.
\b
\q1 
\v 30 «بەڵام وا ئەوانمان ڕووخاند،
\q2 حەشبۆن لەناوچوو هەتا دیڤۆن،
\q1 تێکمان دا هەتا نۆفە
\q2 کە هەتا مادەبا درێژ دەبێتەوە.»
\p 
\v 31 جا ئیسرائیل لە خاکی ئەمۆرییەکاندا مایەوە.
\p 
\v 32 ئینجا موسا هەندێک کەسی نارد بۆ سیخوڕیکردن لە یەعزێر، ئیتر گوندەکانیان گرت و ئەو ئەمۆرییانەیان دەرکرد کە لەوێ بوون.
\v 33 ئینجا ڕوویان وەرگێڕا و بە ڕێگای باشاندا سەرکەوتن، جا عۆگی پاشای باشان لەگەڵ هەموو سوپاکەی بۆ بەرەنگاربوونەوەیان گەیشتە ئەدرەعی.
\p 
\v 34 یەزدانیش بە موسای فەرموو: «لێی مەترسە، چونکە خۆی و هەموو سوپاکەی و خاکەکەیم داوەتە دەستت، ئەوەی پێ دەکەیت کە بە سیحۆنی پاشای ئەمۆرییەکانت کرد کە لە حەشبۆن فەرمانڕەوا بوو.»
\p 
\v 35 جا لە خۆی و کوڕەکانی و هەموو سوپایەکەیان دا و کەس دەرباز نەبوو، بوونە خاوەنی خاکەکەی.
\c 22
\s1 بالاق بانگی بەلعام دەکات
\p 
\v 1 ئینجا نەوەی ئیسرائیل کۆچیان کرد و لە دەشتاییەکانی مۆئاب لەلای کەناری ڕووباری ئوردون بەرامبەر ئەریحا چادریان هەڵدا.
\p 
\v 2 کاتێک بالاقی کوڕی چیپور هەموو ئەو شتانەی بینی کە ئیسرائیل بە ئەمۆرییەکانی کرد،
\v 3 مۆئاب لە گەلەکە تۆقی، چونکە زۆر بوون، مۆئاب بەهۆی نەوەی ئیسرائیل ترسی لێ نیشت.
\p 
\v 4 مۆئابییەکان بە پیرەکانی میدیانیان گوت: «ئێستا ئەم ئاپۆرەی خەڵکە هەموو چواردەورمان دەلێسنەوە وەک چۆن گا سەوزایی کێڵگە دەلێسێتەوە.»
\p لەو سەردەمە بالاقی کوڕی چیپور پاشای مۆئاب بوو.
\v 5 چەند نێردراوێکی بۆ لای بەلعامی کوڕی بەعۆر نارد بۆ پەتور کە نزیک ڕووباری فوراتە لە خاکی نەوەی گەلەکەی، بۆ ئەوەی بانگی بکات و بڵێت:
\pm «وا گەلێک لە میسر هاتووە و ڕووی زەوی داپۆشیوە و لەتەنیشتم نیشتەجێیە.
\v 6 ئێستاش وەرە و نەفرەت لەم گەلە بکە بۆم، چونکە لە من مەزنترن. بەڵکو بتوانم بیانشکێنم و لە خاکەکە دەریانبکەم، چونکە زانیومە ئەوەی داوای بەرەکەتی بۆ بکەیت بەرەکەتدار کراوە و ئەوەی نەفرەتی لێ بکەیت نەفرەت لێکراوە.»
\p 
\v 7 پیرانی مۆئاب و پیرانی میدیان بە کرێی فاڵگرتنەوە بەڕێکەوتن و هاتنە لای بەلعام و بە وتەکانی بالاق لەگەڵیدا دوان.
\p 
\v 8 ئەویش پێی گوتن: «ئەمشەو لێرە بمێننەوە، یەزدان چیم پێ بڵێت، ئاوا وەڵامتان دەدەمەوە.» ئینجا پیاوە گەورەکانی مۆئاب لەلای بەلعام مانەوە.
\p 
\v 9 ئینجا خودا هاتە لای بەلعام و فەرمووی: «ئەو پیاوانە کێن کە لەلاتن؟»
\p 
\v 10 بەلعامیش بە خودای گوت: «بالاقی کوڕی چیپوری پاشای مۆئاب بەدوامدا ناردوویەتی و دەڵێت،
\v 11 ”ئەو گەلەی لە میسرەوە هاتووە ڕووی زەوی داپۆشیوە. ئێستا وەرە و نەفرەتیان لێ بکە بۆم، تاکو بتوانم لەگەڵیاندا بجەنگم و دەریانبکەم.“»
\p 
\v 12 بەڵام خودا بە بەلعامی فەرموو: «لەگەڵیاندا مەڕۆ و نەفرەت لە گەلەکە مەکە، چونکە بەرەکەتدارن.»
\p 
\v 13 بەلعام بەیانی هەستا و بە پیاوە گەورەکانی بالاقی گوت: «بۆ خاکەکەتان بگەڕێنەوە، چونکە یەزدان ڕازی نەبوو ڕێم بدات لەگەڵتان بێم.»
\p 
\v 14 پیاوە گەورەکانی مۆئابیش هەستان و هاتنە لای بالاق و گوتیان: «بەلعام ڕازی نەبوو لەگەڵماندا بێت.»
\p 
\v 15 ئینجا بالاق دووبارە پیاوی گەورەی زۆرتر و بەڕێزتری لەوانەی پێشووتر نارد.
\v 16 ئەوانیش هاتنە لای بەلعام و پێیان گوت:
\pm «بالاقی کوڕی چیپور ئاوا دەڵێت: با هیچ شتێک ڕێت لێ نەگرێت بێیت بۆ لام،
\v 17 چونکە پاداشتێکی گەورەت دەکەم، ئەوەی پێم بڵێی دەیکەم، ئێستا وەرە و نەفرەت لەم گەلە بکە بۆم.»
\p 
\v 18 بەڵام بەلعام وەڵامی دایەوە و بە خزمەتکارانی بالاقی گوت: «ئەگەر بالاق بە پڕی کۆشکەکەی زێڕ و زیوم پێبدات ناتوانم لە فەرمانی یەزدانی پەروەردگارم دەربچم، بۆ ئەوەی شتێکی بچووک یان گەورە بکەم.
\v 19 ئێوەش ئێستا ئەمشەو لێرە بمێننەوە، هەتا بزانم یەزدان ئەم جارە چیم پێ دەڵێت.»
\p 
\v 20 خودا لە شەودا هاتە لای بەلعام و پێی فەرموو: «لەبەر ئەوەی ئەو پیاوانە هاتوون هەتا بانگت بکەن، هەستە و لەگەڵیاندا بڕۆ، بەڵام تەنها ئەو قسەیەی کە من پێت دەڵێم ئەوە دەکەیت.»
\s1 ماکەری بەلعام
\p 
\v 21 بەلعامیش بەیانی هەستا و ماکەرەکەی کورتان کرد و لەگەڵ پیاوە گەورەکانی مۆئاب بەڕێکەوت.
\v 22 بەڵام کاتێک بەڕێکەوت تووڕەیی خودا جۆشا، ئینجا فریشتەی یەزدان لەسەر ڕێگا بۆی وەستا، هەتا بەربەرەکانێی بکات. لەو کاتەی بەلعام سواری ماکەرەکەی ببوو و هەردوو خزمەتکارەکەشی لەگەڵی بوون.
\v 23 کە ماکەرەکە فریشتەی یەزدانی بینی لەسەر ڕێگاکە وەستاوە و شمشێرەکەی هەڵکێشاوە و بە دەستیەوەیە، ماکەرەکە لە ڕێگاکە لایدا و دایەوە ناو کێڵگە، بەلعامیش لە ماکەرەکەی دا هەتا بیگەڕێنێتەوە سەر ڕێگاکە.
\p 
\v 24 ئینجا فریشتەی یەزدان لە ڕێچکەیەکی باریکدا لەنێوان دوو ڕەزدا وەستا کە لەملا و ئەولا دیواری هەبوو،
\v 25 کاتێک ماکەرەکە فریشتەی یەزدانی بینی ملی دا بە دیوارەکە و پێی بەلعام بەر دیوارەکە کەوت. ئینجا دیسان لە ماکەرەکەی دایەوە.
\p 
\v 26 دواتر فریشتەی یەزدان پێشیان کەوتەوە و لە شوێنێکی تەنگەبەر وەستا کە هیچ ڕێگا نەبوو بۆ سووڕانەوە، نە بەلای ڕاست و نە بەلای چەپدا.
\v 27 کە ماکەرەکە فریشتەی یەزدانی بینی، لەژێر بەلعامدا خۆی کێشایەوە، تووڕەیی بەلعام جۆشا و بە گۆچانەکەی لە ماکەرەکەی دا،
\v 28 ئینجا یەزدان دەمی ماکەرەکەی کردەوە و بە بەلعامی گوت: «چیم لێکردوویت کە سێ جار لێت دام؟»
\p 
\v 29 بەلعامیش بە ماکەرەکەی گوت: «لەبەر ئەوەی سووکایەتیم پێ دەکەیت، ئەگەر شمشێرم لە دەست بووایە ئێستا دەمکوشتیت.»
\p 
\v 30 ماکەرەکەش بە بەلعامی گوت: «باشە من ماکەرەکەی تۆ نیم کە لەو کاتەوەی هەی سوارم دەبیت هەتا ئەمڕۆ، ئایا من لێڕاهاتووم وات لێ بکەم؟»
\p ئەویش گوتی: «نا.»
\p 
\v 31 ئینجا یەزدان چاوی بەلعامی کردەوە و فریشتەی یەزدانی بینی لەسەر ڕێگاکە وەستاوە و شمشێری هەڵکێشاوە و بە دەستیەوەیە، جا بەسەر ڕوویدا کەوت و کڕنۆشی برد.
\p 
\v 32 فریشتەی یەزدانیش پێی فەرموو: «بۆچی هەتا ئێستا سێ جار لە ماکەرەکەی خۆتت داوە؟ ئەوەتا من بۆ بەربەرەکانێت هاتووم، چونکە لەبەرچاوی من ڕێگاکەت لاساریکردنە.
\v 33 ماکەرەکە منی بینی هەتا ئێستا سێ جار لە بەرامبەرم خۆی لادا، ئەگەر لە بەرامبەرم خۆی لانەدەدا، ئێستا من تۆم دەکوشت و ئەوم دەهێشتەوە.»
\p 
\v 34 بەلعام بە فریشتەی یەزدانی گوت: «گوناهم کرد، من نەمزانی کە تۆ بوویت ئەوەی لەسەر ڕێگا لەپێشم وەستاویت بۆ بەربەرەکانێم، ئێستاش ئەگەر پێت ناخۆشە من دەگەڕێمەوە.»
\p 
\v 35 فریشتەی یەزدانیش بە بەلعامی فەرموو: «لەگەڵ پیاوەکاندا بڕۆ، بەڵام تەنها ئەو قسەیەی کە من پێت دەڵێم ئەوە دەکەیت.» ئیتر بەلعام لەگەڵ پیاوە گەورەکانی بالاق بەڕێکەوت.
\p 
\v 36 کاتێک بالاق بیستی کە بەلعام هاتووە، چوو بۆ پێشوازیکردنی بۆ ئەو شارۆچکەیەی مۆئاب کە لەسەر سنووری ئەرنۆنە، لەوپەڕی خاکەکەی.
\v 37 بالاق بە بەلعامی گوت: «ئایا بەدوای تۆمدا نەنارد، هەتا بانگت بکەم، ئیتر بۆ نەهاتی؟ ئایا بەڕاستی من ناتوانم پاداشتت بکەم؟»
\p 
\v 38 بەلعامیش بە بالاقی گوت: «ئەوەتا ئێستا هاتم بۆ لات، ئایا ئێستا هیچ توانایەکم هەیە کە خۆم شتێک بڵێم؟ ئەو وشەیەی خودا دەیخاتە دەمم ئەوە دەڵێم.»
\p 
\v 39 بەلعام و بالاق بەڕێکەوتن و هاتنە قیریەت حوچۆت،
\v 40 ئینجا بالاق مەڕ و مانگای سەربڕی و بەدوای بەلعام و ئەو پیاوە گەورانەی نارد کە لەگەڵی بوون.
\v 41 بۆ بەیانی بالاق بەلعامی بردە سەرەوە بۆ بامۆت‌بەعل\f + \fr 22:41 \ft مەبەست لە شوێنێکی بەرزە بۆ قوربانیکردن و ڕێوڕەسمی پەرستنی بتی بەعل.‏\f* و لەوێوە ئەوپەڕی گەلی بینی.
\c 23
\s1 یەکەم پەیامی بەلعام
\p 
\v 1 بەلعام بە بالاقی گوت: «لێرە حەوت قوربانگام بۆ دروستبکە و هەر لێرە حەوت گا و حەوت بەرانم بۆ ئامادە بکە.»
\v 2 بالاقیش بەم جۆرەی کرد، وەک بەلعام گوتی. ئیتر بالاق و بەلعام بۆ سەر هەر قوربانگایەک گایەک و بەرانێکیان سەرخست.
\p 
\v 3 ئینجا بەلعام بە بالاقی گوت: «تۆ لەلای قوربانی سووتاندنەکەت بوەستە و من دەڕۆم، لەوانەیە یەزدان بۆ بینینم بێت و هەرچی پیشانم بدات پێت دەڵێم.» ئینجا بۆ شوێنێکی بەرز و چۆڵ چوو.
\p 
\v 4 خودا هاتە لای بەلعام، بەلعامیش پێی گوت: «حەوت قوربانگام ئامادە کرد و گایەک و بەرانێکم خستە سەر هەر قوربانگایەک.»
\p 
\v 5 یەزدان وشەی خستە دەمی بەلعام و فەرمووی: «بۆ لای بالاق بگەڕێوە و ئاوا بڵێ.»
\p 
\v 6 ئەویش گەڕایەوە لای و بینی وا لەگەڵ هەموو پیاوە گەورەکانی مۆئاب لەلای قوربانی سووتاندنەکەی وەستاوە.
\v 7 ئیتر بەلعام پەیامەکەی ڕاگەیاند و گوتی:
\q1 «لە ئارامەوە بالاقی پاشای مۆئاب منی هێنا،
\q2 لە چیاکانی ڕۆژهەڵاتەوە،
\q1 گوتی ”وەرە نەفرەت لە یاقوب بکە بۆم،
\q2 وەرە جنێو بە ئیسرائیل بدە.“
\q1 
\v 8 چۆن نەفرەت بکەم
\q2 کە خودا نەفرەتی لێیان نەکردبێت،
\q1 چۆن جنێو بدەم
\q2 کە یەزدان جنێوی پێیان نەدابێت؟
\q1 
\v 9 لەسەر تاوێرەکانەوە دەیبینم،
\q2 لە گردەکانەوە تەماشای دەکەم،
\q1 گەلێک وا بە تەنها نیشتەجێ بووە،
\q2 خۆی بە یەکێک لە نەتەوەکان دانانێت.
\q1 
\v 10 کێ خۆڵی یاقوبی هەژمار کردووە،
\q2 کێ چارەکی ئیسرائیلی ژماردووە؟
\q1 با وەک مردنی سەرڕاستان بمرم و
\q2 کۆتاییم وەک ئەوان بێت!»
\p 
\v 11 بالاق بە بەلعامی گوت: «چیت پێکردم! بۆ نەفرەتکردن لە دوژمنانم تۆم هێنا، کەچی وا داوای بەرەکەتیان بۆ دەکەیت!»
\p 
\v 12 ئەویش وەڵامی دایەوە و گوتی: «ئایا ئەوە نەڵێم، ئەوەی کە یەزدان دەیخاتە سەر زارم تاکو بیڵێم؟»
\s1 دووەم پەیامی بەلعام
\p 
\v 13 ئینجا بالاق پێی گوت: «لەگەڵم وەرە بۆ شوێنێکی دیکە هەتا بیانبینیت، بەڵام تەنها بەشێکی دەبینیت و هەمووی نابینیت، لەوێوە نەفرەتیان لێ بکە.»
\v 14 جا بردیە کێڵگەی چۆفیم بۆ سەری پسگە و حەوت قوربانگای بنیاد نا و هەر قوربانگایەک گایەک و بەرانێکی سەرخستە سەری.
\p 
\v 15 بەلعام بە بالاقی گوت: «لێرە لەلای قوربانی سووتاندنەکەت بوەستە و من دەچمە ئەوێ بۆ گەیشتن بە یەزدان.»
\p 
\v 16 یەزدان بە بەلعام گەیشت و وشەی خستە دەمی و فەرمووی: «بگەڕێوە لای بالاق و ئاوا بڵێ.»
\p 
\v 17 ئەویش هاتە لای و بینی وا لەگەڵ پیاوە گەورەکانی مۆئاب لەلای قوربانی سووتاندنەکەی وەستاوە. بالاق لێی پرسی: «یەزدان چی فەرموو؟»
\p 
\v 18 ئیتر پەیامەکەی ڕاگەیاند و گوتی:
\q1 «ئەی بالاق، هەستە و گوێ بگرە،
\q2 ئەی کوڕی چیپور، گوێم بۆ شل بکە،
\q1 
\v 19 خودا مرۆڤ نییە کە درۆ بکات،
\q2 کوڕی مرۆڤیش نییە کە بڕیاری بگۆڕێت.
\q1 ئایا قسە دەکات و ئەنجامی نەدات؟
\q2 یان بەڵێن دەدات و نایباتە سەر؟
\q1 
\v 20 فەرمانم پێدراوە داوای بەرەکەت بکەم،
\q2 ئەو بەرەکەتداری کردووە و من ناتوانم بیگۆڕم.
\b
\q1 
\v 21 «لە یاقوبدا بەدبەختی بەرچاو نەکەوتووە،
\q2 لە ئیسرائیلدا مەراقی نەبینیوە،
\q1 یەزدانی پەروەردگاریان لەگەڵیاندایە،
\q2 هوتافی پاشا لەنێویاندایە.
\q1 
\v 22 خودا لە میسر دەریهێنان،
\q2 ئەوانە هێزی گای کێوییان هەیە.
\q1 
\v 23 جادووگەری لە دژی یاقوب بە کەڵک نایەت،
\q2 فاڵگرتنەوەش لە دژی ئیسرائیل بێ سوودە.
\q1 ئێستا دەربارەی یاقوب و ئیسرائیل دەگوترێت،
\q2 ”سەیر بکە خودا چی کردووە!“
\q1 
\v 24 گەلێک وەک شێرە مێ هەڵدەستێت،
\q2 وەک نەڕەشێر بەرز دەبێتەوە،
\q1 ناخەوێت هەتا نێچیرێک نەخوات و
\q2 خوێنی کوژراوان نەخواتەوە.»
\p 
\v 25 ئینجا بالاق بە بەلعامی گوت: «نە نەفرەتی لێ بکە و نە داوای بەرەکەتی بۆ بکە.»
\p 
\v 26 بەلعامیش وەڵامی دایەوە: «پێم نەگوتیت ئەوەی یەزدان بیڵێت، ئەوە دەکەم؟»
\s1 سێیەم پەیامی بەلعام
\p 
\v 27 بالاقیش بە بەلعامی گوت: «وەرە بتبەمە شوێنێکی دیکە، بەڵکو لەبەرچاوی خودا باش بێت و لەوێوە بۆ من نەفرەتیان لێ بکە.»
\v 28 ئینجا بالاق بەلعامی بردە سەر لووتکەی پەعۆر کە دەڕوانێتە سەر چۆڵەوانی.
\p 
\v 29 بەلعامیش بە بالاقی گوت: «لێرە حەوت قوربانگام بۆ دروستبکە و هەر لێرە حەوت گا و حەوت بەرانم بۆ ئامادە بکە.»
\v 30 بالاقیش وەک بەلعام چی گوت ئاوای کرد، بۆ سەر هەر قوربانگایەک گایەک و بەرانێکی خستە سەری.
\c 24
\p 
\v 1 کاتێک بەلعام بینی لەبەرچاوی یەزدان پەسەندە کە ئیسرائیل بەرەکەتدار بکات، وەک جاری یەکەم و دووەم بەڕێ نەکەوت بۆ جادووگەری، بەڵکو ڕووی لە چۆڵەوانی کرد.
\v 2 کاتێک بەلعام چاوی هەڵبڕی نەوەی ئیسرائیلی بینی هۆز لەتەنیشت هۆز چادریان هەڵداوە، ڕۆحی خوداش هاتە سەری،
\v 3 ئیتر پەیامەکەی ڕاگەیاند و گوتی:
\q1 «پەیامەکەی بەلعامی کوڕی بەعۆر،
\q2 پەیامەکەی ئەو پیاوەی چاوی کراوەیە،
\q1 
\v 4 پەیامی ئەوەی گوێی لە وشەکانی خودایە،
\q2 ئەوەی خودای هەرە بەتوانا بینینی بۆ ئاشکرا دەکات،
\q2 ئەوەی بەسەر ڕوودا دەکەوێت، بەڵام چاو کراوەیە:
\b
\q1 
\v 5 «ئەی یاقوب، چادرەکانت چەند جوانن،
\q2 ئەی ئیسرائیل، نشینگەکانت چەند خۆشن!
\b
\q1 
\v 6 «وەک ئەو دۆڵانەی درێژ بوونەتەوە،
\q2 وەک باخچەی کەناری ڕووبار،
\q1 وەک ئەو درەختە ئەلوایانەی\f + \fr 24:6 \ft ڕووەکێکی دڕکاوییە وەک (سەباڕ)، شلەیەکی تێدایە بۆ پێست باشە.‏\f* کە یەزدان چاندبێتی،
\q2 وەک ئورزی قەراغی ئاو،
\q1 
\v 7 گۆزەکانی ئاویان لێ دەڕژێت و
\q2 تۆوی ئەوان لەسەر ئاوی زۆر دەبێت.
\b
\q1 «پاشای لە ئەگاگ باڵاتر دەبێت و
\q2 شانشینەکەی پایەدار دەبێت.
\b
\q1 
\v 8 «خودا لە میسر دەریهێنان،
\q2 وەک شاخی گای کێوییە بۆیان،
\q1 ئەو نەتەوانەی ناحەزی دەکەن دەیانخۆن و
\q2 ئێسکیان تێکدەشکێنن و
\q2 بە تیرەکانیان دەیانبڕن.
\q1 
\v 9 خۆیان وەک شێر ماتداوە و ڕاکشاون،
\q2 وەک شێرە مێ، کێ هەڵیاندەستێنێت؟
\b
\q1 «بەرەکەتدار بن ئەوانەی بەرەکەتدارتان دەکەن،
\q2 نەفرەت لێکراو بن ئەوانەی نەفرەتتان لێ دەکەن.»
\p 
\v 10 ئینجا تووڕەیی بالاق بەسەر بەلعامەوە گڕی گرت، چەپڵەی لێدا و بە بەلعامی گوت: «بۆ نەفرەتکردن لە دوژمنەکانم بانگم کردوویت، کەچی تۆ سێ جار داوای بەرەکەتت بۆ کردن،
\v 11 ئێستاش بگەڕێوە شوێنی خۆت، گوتم پاداشتێکی گەورەت دەکەم، بەڵام یەزدان ڕێگری لێ کردیت کە پاداشتەکەت وەربگریت.»
\p 
\v 12 بەلعامیش بە بالاقی گوت: «ئەی من بە نێردراوەکانتم نەگوت کە بۆ لای منت ناردبوون،
\v 13 ”ئەگەر بالاق بە پڕی خانووەکەی زێڕ و زیوم پێبدات ناتوانم لە فەرمانی یەزدان دەربچم، بۆ ئەوەی لە خۆمەوە چاکەیەک یان خراپەیەک بکەم، ئەوەی یەزدان بیڵێت ئەوە دەڵێم؟“
\v 14 ئێستاش وا من بۆ لای گەلەکەم بەڕێ دەکەوم، بەڵام وەرە با پێت بڵێم کە ئەم گەلە لە دوارۆژدا چی لە گەلەکەت دەکات.»
\s1 چوارەم پەیامی بەلعام
\p 
\v 15 ئیتر پەیامەکەی ڕاگەیاند و گوتی:
\q1 «پەیامی بەلعامی کوڕی بەعۆر،
\q2 پەیامی ئەو پیاوەی چاوی کراوەیە،
\q1 
\v 16 پەیامی ئەوەی گوێی لە وشەکانی خودایە،
\q2 کە زانینی هەیە لە هەرەبەرزەوە،
\q1 ئەوەی خودای هەرە بەتوانا بینینی بۆ ئاشکرا دەکات،
\q2 ئەوەی بەسەر ڕوودا دەکەوێت، بەڵام چاوی کراوەیە:
\b
\q1 
\v 17 «دەیبینم، بەڵام ئێستا نا،
\q2 چاوم پێی دەکەوێت، بەڵام بەم نزیکانە نا.
\q1 ئەستێرەیەک لە یاقوب دەردەکەوێت و
\q2 داردەستێک لە ئیسرائیل هەڵدەستێت.
\q1 ناوچەوانی مۆئاب دەشکێنێت،
\q2 کاسەسەری هەموو نەوەی شیت\f + \fr 24:17 \ft نەوەی شیت کوڕی ئادام، واتا گەلی مۆئاب.‏\f* تێکدەشکێنێت.
\q1 
\v 18 ئەدۆم داگیر دەکرێت،
\q2 سێعیری دوژمنیشی دەبێتە خاوەندار،
\q2 بەڵام ئیسرائیل قارەمانیێتی دەنوێنێت.
\q1 
\v 19 ئەوەی لە یاقوبەوەیە دەسەڵاتدار دەبێت،
\q2 بەجێماوەکان لە شار لەناودەبات.»
\s1 پێنجەم پەیامی بەلعام
\p 
\v 20 ئینجا بەلعام عەمالێقی بینی و پەیامەکەی ڕاگەیاند و گوتی:
\q1 «عەمالێق یەکەمی نەتەوەکان بوو،
\q2 بەڵام کۆتاییەکەی لەناوچوونە.»
\p 
\v 21 ئینجا قێنییەکانی بینی و پەیامەکەی پێ ڕاگەیاندن و گوتی:
\q1 «نشینگەکەتان پتەوە و
\q2 هێلانەکەتان لەناو تاشەبەردە،
\q1 
\v 22 بەڵام ئەی قێنییەکان، ئێوە وێران دەبن،
\q2 کاتێک ئەشوورییەکان بە دیلتان دەگرن.»
\p 
\v 23 ئیتر پەیامەکەی ڕاگەیاند و گوتی:
\q1 «ئای کێ دەژیێت کاتێک خودا ئاوا دەکات،
\q2 
\v 24 لەلای کەنارەکانی کیتیمەوە\f + \fr 24:24 \ft قوبرس و کەنارەکانی ڕۆژئاوای.‏\f* کەشتییەکان دێن و
\q1 ئەشوور و عێبەر ژێردەستە دەکات،
\q2 بەڵام ئەوانیش بۆ لەناوچوونن.»
\p 
\v 25 ئینجا بەلعام هەستا و بەڕێکەوت و گەڕایەوە شوێنی خۆی، بالاقیش بە ڕێگای خۆیدا ڕۆیشت.
\c 25
\s1 مۆئاب کوڕانی ئیسرائیل هەڵدەخەڵەتێنێت
\p 
\v 1 کاتێک ئیسرائیل لە شەتیم چادریان هەڵدا و گەل دەستیان بە بەدڕەوشتی کرد لەگەڵ کچانی مۆئاب،
\v 2 ئەوانیش گەلیان بانگهێشت کرد بۆ قوربانییە سەربڕدراوەکانی خوداوەندەکانیان. گەلیش خواردی و کڕنۆشی بۆ خوداوەندەکانیان برد.
\v 3 ئیسرائیل پەیوەست بوو بە بەعلی پەعۆرەوە\f + \fr 25:3 \ft ‏بەعلی پەعۆر: ناوێکی مۆئابییە بۆ ئەو خوداوەندەی لە کێوی پەعۆر دەیانپەرست.‏\f*، تووڕەیی یەزدانیش بەسەر ئیسرائیلدا جۆشا.
\p 
\v 4 یەزدان بە موسای فەرموو: «هەموو ڕابەرانی گەل ببە و بۆ یەزدان بەرامبەر بە خۆر هەڵیانبواسە، ئەوسا کوڵی تووڕەیی یەزدان لەسەر ئیسرائیل دادەمرکێتەوە.»
\p 
\v 5 موساش بە دادوەرانی ئیسرائیلی گوت: «هەر یەک لە ئێوە ئەو پیاوانەی خۆی بکوژێت کە پەیوەست بوونە بە بەعلی پەعۆرەوە.»
\p 
\v 6 لەو کاتەدا پیاوێک هات کە لە نەوەی ئیسرائیل بوو و کچێکی میدیانی هێنایە ناو کەسوکارەکەی، لەبەرچاوی موسا و هەموو کۆمەڵی نەوەی ئیسرائیل کە لەلای دەروازەی چادری چاوپێکەوتن دەگریان.
\v 7 کاتێک فینەحاسی کوڕی ئەلعازاری کوڕی هارونی کاهین ئەمەی بینی، لەنێو کۆمەڵەکە هەستا و دەستی دایە ڕمێک،
\v 8 بەدوای پیاوە ئیسرائیلییەکەدا چووە ناو چادرەکە، بە ڕمەکەی بە یەک جار سکی پیاوە ئیسرائیلییەکە و کچەکەشی بڕی. ئینجا دەردەکە لە نەوەی ئیسرائیل بڕایەوە.
\v 9 بەڵام ئەوانەی بە دەردەکە مردن بیست و چوار هەزار بوون.
\p 
\v 10 هەروەها یەزدان بە موسای فەرموو:
\v 11 «فینەحاسی کوڕی ئەلعازاری کوڕی هارونی کاهین، تووڕەیی منی لەسەر نەوەی ئیسرائیل ڕەواندەوە. لەبەر ئەوەی دڵگەرم بوو بۆ شکۆمەندی من لەنێویان بەو جۆرەی کە من بۆ شکۆمەندی خۆم دڵگەرمم، نەوەی ئیسرائیلم بە دڵگەرمی خۆم لەناو نەبرد.
\v 12 لەبەر ئەوە پێی بڵێ ئەوەتا من پەیمانی ئاشتی خۆمی لەگەڵ دەبەستم.
\v 13 بۆ خۆی و بۆ نەوەکەی دوای خۆی دەبێتە پەیمانی کاهینیێتی هەتاهەتایی، لەبەر ئەوەی دڵگەرم بوو بۆ خودا و کەفارەتی بۆ نەوەی ئیسرائیل کرد.»
\p 
\v 14 ناوی ئەو پیاوە ئیسرائیلییەش کە لەگەڵ کچە میدیانییەکە کوژرا زیمریی کوڕی سالو بوو، گەورەی بنەماڵەیەک بوو لە شیمۆنییەکان،
\v 15 ناوی کچە میدیانییە کوژراوەکەش کۆزبیی کچی چوور بوو، ئەویش سەرۆکی هۆزێک بوو لە بنەماڵەیەکی میدیانی.
\p 
\v 16 یەزدان بە موسای فەرموو:
\v 17 «تەنگ بە میدیانییەکان هەڵبچنن و لێیان بدەن،
\v 18 چونکە ئەوان بە فریودانەکانیان تەنگیان پێ هەڵچنین، سەبارەت بە پەعۆر و کۆزبی خوشکیان، کچی سەرۆکێکی میدیان کە لە ڕۆژی دەردەکە بەهۆی پەعۆرەوە کوژرا.»
\c 26
\s1 سەرژمێریی دووەم\f + \fr 26:0 \ft سەرژمێریی دووەم تایبەت بوو بە ناونووسینی پیاوانی ئیسرائیل بۆ سەربازی لەژێر چاودێری یەشوع بۆ هێرشبردنە سەر خاکی کەنعان لە بەری ڕۆژهەڵاتی ڕووباری ئوردونەوە.‏\f*
\p 
\v 1 لەدوای دەردەکە، یەزدان بە موسا و ئەلعازاری کوڕی هارونی کاهینی فەرموو:
\v 2 «ژمارەی هەموو کۆمەڵی نەوەی ئیسرائیل وەربگرە، لە گەنجی بیست ساڵ بەرەو سەرەوە، بەگوێرەی بنەماڵەکانیان، هەموو ئەوانەی لە ئیسرائیلدا دەتوانن بجەنگن.»
\v 3 ئینجا موسا و ئەلعازاری کاهین لە دەشتی مۆئاب لەسەر ڕووباری ئوردون بەرامبەر ئەریحا لەگەڵیاندا دوان و گوتیان:
\v 4 «سەرژمێری لە گەنجی بیست ساڵ بەرەو سەرەوە بکەن، وەک چۆن یەزدان فەرمانی بە موسا کرد.»
\b
\li4 نەوەی ئیسرائیلیش ئەوانەی لە خاکی میسر هاتنە دەرەوە ئەمانەن:
\b
\li1 
\v 5 نەوەی ڕەئوبێنی نۆبەرەی ئیسرائیل:
\li2 بۆ حەنۆک خێڵی حەنۆکییەکان،
\li2 بۆ پەڵو خێڵی پەڵووییەکان،
\li2 
\v 6 بۆ حەسرۆن خێڵی حەسرۆنییەکان،
\li2 بۆ کەرمی خێڵی کەرمییەکان.
\li4 
\v 7 ئەمانە خێڵەکانی ڕەئوبێنییەکانن، تۆمارکراوەکانیان چل و سێ هەزار و حەوت سەد و سی کەس بوون.
\li2 
\v 8 ئەلیابیش کوڕی پەڵو بوو،
\v 9 نەوەی ئەلیابیش نەموئێل و داتان و ئەبیرام، داتان و ئەبیرامیش ئەوانەن کە کۆمەڵەکەیان بانگکرد بۆ بەربەرەکانێی موسا و هارون، لە کۆمەڵی قۆرەح کاتێک بەربەرەکانێی یەزدانیان کرد.
\v 10 زەوی دەمی کردەوە و لەگەڵ قۆرەح هەڵیلووشین، کاتێک ئەو کۆمەڵە مردن، دوو سەد و پەنجا پیاو سووتان، ئەوان بوون بە پەند.
\v 11 بەڵام نەوەی قۆرەح نەفەوتان.
\b
\li1 
\v 12 نەوەی شیمۆن بەگوێرەی خێڵەکانیان:
\li2 لە نەموئێل خێڵی نەموئێلییەکان،
\li2 لە یامین خێڵی یامینییەکان،
\li2 لە یاکین خێڵی یاکینییەکان،
\li2 
\v 13 لە زەرەح خێڵی زەرەحییەکان،
\li2 لە شائوول خێڵی شائوولییەکان.
\li4 
\v 14 ئەمانە خێڵەکانی شیمۆنییەکانن، بیست و دوو هەزار و دوو سەد کەس بوون.
\b
\li1 
\v 15 نەوەی گاد بەگوێرەی خێڵەکانیان:
\li2 لە چیفۆن خێڵی چیفۆنییەکان،
\li2 لە حەگی خێڵی حەگییەکان،
\li2 لە شونی خێڵی شونییەکان،
\li2 
\v 16 لە ئۆزنی خێڵی ئۆزنییەکان،
\li2 لە عێری خێڵی عێرییەکان،
\li2 
\v 17 لە ئەرۆدی خێڵی ئەرۆدییەکان،
\li2 لە ئەرئێلی خێڵی ئەرئێلییەکان.
\li4 
\v 18 ئەمانە خێڵەکانی نەوەی گادن، بەگوێرەی ژمارەیان چل هەزار و پێنج سەد کەس بوون.
\b
\li4 
\v 19 ئێر و ئۆنان کوڕانی یەهودا بوون، بەڵام لە خاکی کەنعان مردن.
\li1 
\v 20 نەوەی یەهودا بەگوێرەی خێڵەکانیان:
\li2 لە شالەح خێڵی شالەحییەکان،
\li2 لە پێرێز خێڵی پێرێزییەکان،
\li2 لە زەرەح خێڵی زەرەحییەکان،
\li2 
\v 21 نەوەکانی پێرێزیش:
\li3 لە حەسرۆن خێڵی حەسرۆنییەکان،
\li3 لە حامول خێڵی حامولییەکان.
\li4 
\v 22 ئەمانە خێڵەکانی یەهودان، بەگوێرەی ژمارەیان حەفتا و شەش هەزار و پێنج سەد کەس بوون.
\b
\li1 
\v 23 نەوەی یەساخار بەگوێرەی خێڵەکانیان:
\li2 لە تۆلاع خێڵی تۆلاعییەکان،
\li2 لە پوڤە خێڵی پوڤەییەکان،
\li2 
\v 24 لە یاشوڤ خێڵی یاشوڤییەکان،
\li2 لە شیمرۆن خێڵی شیمرۆنییەکان.
\li4 
\v 25 ئەمانە خێڵەکانی یەساخارن، بەگوێرەی ژمارەیان شەست و چوار هەزار و سێ سەد کەس بوون.
\b
\li1 
\v 26 نەوەی زەبولون بەگوێرەی خێڵەکانیان:
\li2 لە سەرەد خێڵی سەرەدییەکان،
\li2 لە ئێلۆن خێڵی ئێلۆنییەکان،
\li2 لە یەحلئێل خێڵی یەحلئێلییەکان.
\li4 
\v 27 ئەمانە خێڵەکانی زەبولونییەکانن، بەگوێرەی ژمارەیان شەست هەزار و پێنج سەد کەس بوون.
\b
\li4 
\v 28 نەوەی یوسف بەگوێرەی خێڵەکانی مەنەشە و ئەفرایم:
\li1 
\v 29 نەوەی مەنەشە:
\li2 لە ماکیر خێڵی ماکیرییەکان، ماکیر باوکی گلعاد بوو،
\li2 لە گلعاد خێڵی گلعادییەکان.
\li2 
\v 30 ئەمانە نەوەی گلعادن:
\li3 لە ئیعەزەر خێڵی ئیعەزەرییەکان؛
\li3 لە حێلەق خێڵی حێلەقییەکان؛
\li3 
\v 31 لە ئەسریێل خێڵی ئەسریێلییەکان؛
\li3 لە شەخەم خێڵی شەخەمییەکان؛
\li3 
\v 32 لە شەمیداع خێڵی شەمیداعییەکان؛
\li3 لە حێفەر خێڵی حێفەرییەکان.
\li3 
\v 33 بەڵام سەلۆفحادی کوڕی حێفەر کوڕی نەبوو، تەنها کچ و ناوی کچەکانی سەلۆفحاد مەحلە و نۆعا و حۆگلە و میلکە و تیرزە بوو.
\li4 
\v 34 ئەمانە خێڵەکانی مەنەشەن و تۆمارکراوەکانیان پەنجا و دوو هەزار و حەوت سەد کەس بوون.
\li1 
\v 35 ئەمانەش نەوەی ئەفرایمن بەگوێرەی خێڵەکانیان:
\li2 لە شوتەلەح خێڵی شوتەلەحییەکان،
\li2 لە بەکەر خێڵی بەکەرییەکان،
\li2 لە تەحەن خێڵی تەحەنییەکان،
\li2 
\v 36 ئەمانەش نەوەی شوتەلەحن:
\li3 لە عیران خێڵی عیرانییەکان.
\li4 
\v 37 ئەمانە خێڵەکانی نەوەی ئەفرایمن، بەگوێرەی ژمارەیان سی و دوو هەزار و پێنج سەد کەس بوون.
\li4 ئەمانە نەوەی یوسفن بەگوێرەی خێڵەکانیان.
\b
\li1 
\v 38 نەوەی بنیامین بەگوێرەی خێڵەکانیان:
\li2 لە بەلەع خێڵی بەلەعییەکان،
\li2 لە ئەشبێل خێڵی ئەشبێلییەکان،
\li2 لە ئەحیرام خێڵی ئەحیرامییەکان.
\li2 
\v 39 لە شوفام خێڵی شوفامییەکان،
\li2 لە حوفام خێڵی حوفامییەکان.
\li2 
\v 40 نەوەی بەلەعیش ئەرد و نەعمان بوون:
\li3 لە ئەرد خێڵی ئەردییەکان و
\li3 لە نەعمان خێڵی نەعمانییەکان.
\li4 
\v 41 ئەمانە نەوەی بنیامینن بەگوێرەی خێڵەکانیان و تۆمارکراوەکانیان چل و پێنج هەزار و شەش سەد کەس بوون.
\b
\li1 
\v 42 ئەمانە نەوەی دانن بەگوێرەی خێڵەکانیان:
\li2 لە شوحام خێڵی شوحامییەکان.
\li4 ئەمە خێڵەکانی دانە بەگوێرەی خێڵەکانیان،
\v 43 هەموو خێڵەکانی شوحامییەکان بەگوێرەی ژمارەیان شەست و چوار هەزار و چوار سەد کەس بوون.
\b
\li1 
\v 44 نەوەی ئاشێر بەگوێرەی خێڵەکانیان:
\li2 لە یمنە خێڵی یمنییەکان،
\li2 لە یەشڤی خێڵی یەشڤییەکان،
\li2 لە بەریعە خێڵی بریعییەکان،
\li2 
\v 45 لە نەوەی بەریعە:
\li3 لە حەڤەر خێڵی حەڤەرییەکان،
\li3 لە مەلکیێل خێڵی مەلکیێلییەکان،
\li4 
\v 46 کچەکەی ئاشێریش ناوی سەرەح بوو.
\li4 
\v 47 ئەمانە خێڵەکانی نەوەی ئاشێرن، بەگوێرەی ژمارەیان پەنجا و سێ هەزار و چوار سەد کەس بوون.
\b
\li1 
\v 48 نەوەی نەفتالی بەگوێرەی خێڵەکانیان:
\li2 لە یەحزئێل خێڵی یەحزئێلییەکان،
\li2 لە گۆنی خێڵی گۆنییەکان،
\li2 
\v 49 لە یێچەر خێڵی یێچەرییەکان،
\li2 لە شلێم خێڵی شلێمییەکان.
\li4 
\v 50 ئەمانە خێڵەکانی نەفتالین بەگوێرەی خێڵەکانیان و تۆمارکراوەکانیان چل و پێنج هەزار و چوار سەد کەس بوون.
\b
\li4 
\v 51 ئەمانە تۆمارکراوەکانن لە نەوەی ئیسرائیل، شەش سەد و یەک هەزار و حەوت سەد و سی.
\b
\p 
\v 52 یەزدان بە موسای فەرموو:
\v 53 «خاکەکە بۆ ئەمانە بەگوێرەی ژمارەی ناوەکان بە میرات دابەش دەکەیت.
\v 54 بۆ هۆزە گەورەکان میراتیان زۆر دەکەیت و بۆ هۆزە بچووکەکان میراتیان کەم دەکەیت، هەریەکە بەگوێرەی تۆمارکراوەکانی میراتی دەدرێتێ،
\v 55 بەڵام خاکەکە بە تیروپشک دابەش دەکەیت، بەگوێرەی ناوی هۆزەکانی باوکانیان بە میراتی دەگرن،
\v 56 لەنێو کۆمەڵەی گەورە و بچووک بەگوێرەی تیروپشک میراتەکەیان بۆ دابەش دەکرێت.»
\b
\li1 
\v 57 ئەمانەش تۆمارکراوەکانن لە لێڤییەکان، بەگوێرەی خێڵەکانیان:
\li2 بۆ گێرشۆن خێڵی گێرشۆنییەکان،
\li2 بۆ قەهات خێڵی قەهاتییەکان،
\li2 بۆ مەراری خێڵی مەرارییەکان.
\li1 
\v 58 ئەمە خێڵەکانی لێڤییە:
\li2 خێڵی لیبنییەکان،
\li2 خێڵی حەبرۆنییەکان،
\li2 خێڵی مەحلییەکان،
\li2 خێڵی موشییەکان،
\li2 خێڵی قۆرەحییەکان.
\li2 عەمرام لە ڕەچەڵەکی قەهات بوو.
\v 59 ژنەکەی عەمرامیش ناوی یۆخەڤەد بوو، لە نەوەی لێڤی بوو، لە خێزانی لێڤییەکیش لە میسر لەدایک بوو. لە عەمرام هارون و موسا و مریەمی خوشکیانی بوو.
\v 60 هارونیش باوکی ناداب و ئەبیهو و ئەلعازار و ئیتامار بوو.
\v 61 بەڵام ناداب و ئەبیهو کاتێک ئاگرێکی نامۆیان لەبەردەم یەزدان پێشکەش کرد مردن.
\b
\li4 
\v 62 تۆمارکراوەکانی لێڤییەکان بیست و سێ هەزار کەس بوون، هەموو نێرینەیەک لە کۆرپەی یەک مانگی بەرەو سەرەوە، چونکە لەگەڵ نەوەی ئیسرائیلدا تۆمار نەکران، لەبەر ئەوەی لەنێو نەوەی ئیسرائیلدا میراتیان پێنەدرا.
\b
\p 
\v 63 ئەمانە بوون کە موسا و ئەلعازاری کاهین تۆماریان کردن، کاتێک نەوەی ئیسرائیلیان لە دەشتی مۆئاب لەسەر ڕووباری ئوردون بەرامبەر ئەریحا تۆمار کرد.
\v 64 ئەمانەش کەسیان تێدا نەبوو لەوانەی موسا و هارونی کاهین تۆماریان کردن، کاتێک نەوەی ئیسرائیلیان لە چۆڵەوانی سینادا تۆمار کرد.
\v 65 لەبەر ئەوەی یەزدان پێی فەرموون، «لە چۆڵەوانیدا دەمرن،» ئیتر کەسیان لێ نەمایەوە، تەنها کالێبی کوڕی یەفونە و یەشوعی کوڕی نون نەبێت.
\c 27
\s1 کچانی سەلۆفحاد
\p 
\v 1 کچانی سەلۆفحادی کوڕی حێفەر کوڕی گلعاد کوڕی ماکیر کوڕی مەنەشە لە خێڵەکانی مەنەشەی کوڕی یوسف هاتنە پێش. ئەمەش ناوی کچەکانییەتی: مەحلە و نۆعا و حۆگلە و میلکە و تیرزە،
\v 2 لەبەردەم موسا و ئەلعازاری کاهین و سەرۆکەکان و هەموو کۆمەڵ لەلای دەروازەی چادری چاوپێکەوتن وەستان و گوتیان:
\v 3 «باوکمان لە بیابان مرد و لەو کۆمەڵەدا نەبوو کە لەگەڵ قۆرەح لە دژی یەزدان کۆبوونەوە، بەڵکو بە گوناهی خۆی مرد و هیچ کوڕی نەبوو.
\v 4 بۆچی ناوی باوکمان لەنێو خێڵەکەی بسڕێتەوە لەبەر ئەوەی کوڕی نییە؟ لەنێو برایانی باوکمان موڵکمان بدەرێ.»
\p 
\v 5 موساش داواکارییەکەی ئەوانی بردە بەردەم یەزدان.
\v 6 جا یەزدان بە موسای فەرموو:
\v 7 «کچانی سەلۆفحاد ڕاست دەڵێن. تۆش لەنێو برایانی باوکیان موڵکی میراتیان دەدەیتێ و میراتی باوکیان دەدرێتە ئەوان.
\p 
\v 8 «بە نەوەی ئیسرائیلیش دەڵێیت: ”هەر پیاوێک مرد و کوڕی نەبوو میراتەکەی بۆ کچی دەبێت،
\v 9 ئەگەر کچیشی نەبوو، میراتەکەی دەدەنە براکانی،
\v 10 ئەگەر براشی نەبوو ئەوا میراتەکەی دەدەنە برایانی باوکی،
\v 11 ئەگەر باوکیشی برای نەبوو ئەوا میراتەکەی دەدەنە نزیکترین کەسی لە خێڵەکەی و ئەو دەبێتە میراتگری. ئەمە بۆ نەوەی ئیسرائیل بووە فەرزێکی یاسایی، هەروەک یەزدان فەرمانی بە موسا کرد.“»
\s1 موسا دەست لەسەر یەشوع دادەنێت
\p 
\v 12 ئینجا یەزدان بە موسای فەرموو: «بڕۆ سەر ئەم چیایە لە زنجیرە چیای عەڤاریم و تەماشای ئەو خاکە بکە کە بە نەوەی ئیسرائیلم داوە.
\v 13 کاتێک تەماشات کرد تۆش دەچیتە ڕیزی گەلەکەت، وەک هارونی برات چووە ڕیزەوە،
\v 14 چونکە لە چۆڵەوانی چن کاتێک کۆمەڵەکە یاخی بوون، ئێوە هەردووکتان قسەتان شکاندم و منتان لەلای ئەوان پیرۆز نیشان نەدا.» (ئەو شوێنە ئاوی مەریبای قادێشە لە چۆڵەوانی چن بوو.)
\p 
\v 15 موسا بە یەزدانی گوت:
\v 16 «ئەی یەزدان، ئەی ئەو خودایەی ژیان بە ئادەمیزاد دەبەخشیت، پیاوێک لەسەر کۆمەڵەکە دابنێ
\v 17 بەڕێوەیان ببات و لە شەڕدا ڕابەرایەتییان بکات، هەتا کۆمەڵی یەزدان وەک مەڕی بێ شوانیان لێ نەیێت.»
\p 
\v 18 یەزدانیش بە موسای فەرموو: «یەشوعی کوڕی نون ببە، پیاوێکە ڕۆحی تێدایە و دەستی لەسەر دابنێ.
\v 19 لەبەردەم ئەلعازاری کاهین و هەموو کۆمەڵەکە ڕای بگرە و لەبەرچاویان ئەرکی پێ بسپێرە.
\v 20 هەندێک لە دەسەڵاتی خۆتی بدەرێ هەتا هەموو کۆمەڵی ئیسرائیل گوێڕایەڵی بن.
\v 21 ئەو لەبەردەم ئەلعازاری کاهین ڕادەوەستێت، لەبەردەم یەزدان بەپێی حوکمی ئوریم\f + \fr 27:21 \ft دوو بەردی گرانبەها بوون، لە کاتی بڕیاردان بۆ زانینی خواستی خودا بەکارهێنراون، بڕوانە \xt دەرچوون 28‏:30 و یەکەم ساموئێل 23‏:9‏-12.‏\xt*\ft ‏\f* بۆی دەپرسێت. بە قسەی ئەو دەردەچن و بە قسەی ئەو دێنە ژوورەوە، ئەو و هەموو کۆمەڵی ئیسرائیل لەگەڵی.»
\p 
\v 22 موسا هەروەک یەزدان فەرمانی پێ کرد، ئاوای کرد. یەشوعی برد و لەبەردەم ئەلعازاری کاهین و لەبەردەم هەموو کۆمەڵەکە ڕایگرت،
\v 23 دەستی لەسەر دانا و ئەرکی پێ سپارد، هەروەک یەزدان لە ڕێگەی موساوە فەرمانی دا.
\c 28
\s1 قوربانی و پێشکەشکراوەکانی ڕۆژانە
\p 
\v 1 هەروەها یەزدان بە موسای فەرموو:
\v 2 «فەرمان بە نەوەی ئیسرائیل بکە و پێیان بڵێ: ”قوربانی من، ئەو بۆنەی پێم خۆشە، ئاگاداربن کە لە کاتی خۆی خۆراکم بە قوربانی بە ئاگر پێشکەش بکەن.“
\v 3 پێشیان بڵێ: ”ئەمە ئەو قوربانی بە ئاگرەیە کە ڕۆژانە بۆ یەزدان پێشکەشی دەکەن: دوو بەرخی نێری یەک ساڵەی ساغ، قوربانی سووتاندنی بەردەوام.
\v 4 یەکێک لە بەرخەکان لە بەیانی پێشکەش بکە و بەرخی دووەمیش لە کاتی خۆرئاوابوون.
\v 5 لەگەڵ دەیەکی ئێفەیەک لە باشترین ئارد بۆ پێشکەشکراوی دانەوێڵە بە چارەکە هەینێک زەیتی زەیتوونی گوشراو شێلرابێت،
\v 6 قوربانی سووتاندنی بەردەوام، ئەوەی لە شاخی سینا کراوە، بۆنێکی خۆشە و قوربانی بە ئاگرە بۆ یەزدان،
\v 7 لەگەڵ شەرابە پێشکەشکراوەکەشی، چارەکە هەینێک مەی بۆ بەرخی یەکەم، لە پیرۆزگا بۆ یەزدان پێشکەشی بکە.
\v 8 هەروەها بەرخی دووەمیش لە کاتی خۆرئاوابووندا پێشکەش بکە، لەگەڵ پێشکەشەکراوی دانەوێڵەکەی و شەرابە پێشکەشکراوەکەی، وەک ئەوەی لە بەیانیدا کردووتە، قوربانی بە ئاگرە، ئەو بۆنەی یەزدان پێی خۆشە.
\s1 قوربانی و پێشکەشکراوەکانی ڕۆژی شەممە
\p 
\v 9 «”لە ڕۆژی شەممە\f + \fr 28:9 \ft مەبەستی ڕۆژی حەسانەوەیە کە ڕۆژی دوای شەش ڕۆژی بەدیهێنان خودا حەسایەوە، بڕوانە \xt پەیدابوون 2‏:2‏\xt*\ft ‏.‏\f* دوو بەرخی یەک ساڵەی ساغ پێشکەش بکەن لەگەڵ دوو دەیەکی ئێفەیەک\f + \fr 28:9 \ft دوو دەیەکی ئێفەیەک: نزیکە 4,5 لیتر.‏\f* لە باشترین ئاردی بە زەیت شێلراو وەک پێشکەشکراوێکی دانەوێڵە لەگەڵ شەرابە پێشکەشکراوەکەی، کە ئەمەش
\v 10 قوربانی سووتاندنی هەموو ڕۆژێکی شەممەیە، سەرەڕای قوربانی سووتاندنی بەردەوام و شەرابە پێشکەشکراوەکەی.
\s1 قوربانی و پێشکەشکراوەکانی مانگانە
\p 
\v 11 «”لە دەستپێکی هەموو مانگێکدا قوربانی سووتاندن بۆ یەزدان بکەن، دوو جوانەگا و بەرانێک و حەوت بەرخی نێری یەک ساڵەی ساغ،
\v 12 لەگەڵ سێ دەیەکی ئێفەیەک\f + \fr 28:12 \ft سێ دەیەکی ئێفەیەک: نزیکەی 6,5 لیتر.‏\f* لە باشترین ئاردی بە زەیت شێلراو، پێشکەشکراوێکی دانەوێڵەیە بۆ هەر جوانەگایەک و دوو دەیەکی ئێفەیەک لە باشترین ئاردی بە زەیت شێلراو، پێشکەشکراوێکی دانەوێڵەیە بۆ هەر بەرانێک.
\v 13 یەک دەیەکی ئێفەیەک لە باشترین ئاردی بە زەیت شێلراو، پێشکەشکراوێکی دانەوێڵەیە بۆ هەر بەرخێک، قوربانی سووتاندنە، ئەو بۆنەی یەزدان پێی خۆشە، قوربانی بە ئاگرە بۆ یەزدان.
\v 14 شەرابە پێشکەشکراوەکەشیان نیو هەین\f + \fr 28:14 \ft نزیکەی دوو لیتر بوو.‏\f* بۆ جوانەگا و سێیەکی هەین\f + \fr 28:14 \ft نزیکەی 1,2 لیتر بوو.‏\f* بۆ بەران و چارەکە هەینێک بۆ بەرخ. ئەمە قوربانی سووتاندنە لە دەستپێکی هەموو مانگەکانی ساڵ.
\v 15 سەرەڕای قوربانی سووتاندنی بەردەوام لەگەڵ شەرابە پێشکەشکراوەکەی، هەروەها گیسکێکی نێریش بۆ قوربانی گوناه بۆ یەزدان پێشکەش بکرێت.
\s1 جەژنی پەسخە
\p 
\v 16 «”لە چواردەی مانگی یەک، جەژنی پەسخەیە بۆ یەزدان،
\v 17 لە ڕۆژی پازدەی ئەم مانگەدا جەژنە، حەوت ڕۆژ نانی فەتیرە بخۆن.
\v 18 لە ڕۆژی یەکەم کۆبوونەوەی پیرۆزبوون\f + \fr 28:18 \ft بیرۆکەی بنەڕەتی سەرجەم جەژنەکان دەگەڕێتەوە بۆ دوو بنەمای سەرەکی: (1) یادکردنەوەی کار و چاکە مەزنەکانی خودا بەرامبەر بە گەلەکەی؛ (2) خۆتەرخانکردن لەم ڕۆژانەدا تەنها بۆ ستایش و پەرستنی خودا و فێربوون.‏\f* ببەستن، هیچ کارێکی ئاسایی مەکەن.
\v 19 قوربانی بە ئاگر، قوربانی سووتاندن بۆ یەزدان پێشکەش بکەن، دوو جوانەگا و بەرانێک و حەوت بەرخی نێری یەک ساڵەی ساغ لەلایەن ئێوەوە بێت.
\v 20 پێشکەشکراوی دانەوێڵەشیان لە باشترین ئاردی بە زەیت شێلراو، سێ دەیەکی ئێفەیەک بۆ هەر جوانەگایەک، دوو دەیەک بۆ هەر بەرانێک،
\v 21 دەیەکێک بۆ هەر بەرخێک لە حەوت بەرخەکە بکە.
\v 22 گیسکێکی نێریش قوربانی گوناه بێت بۆ کەفارەتکردن بۆتان،
\v 23 سەرەڕای قوربانی سووتاندنی بەیانییان کە بۆ قوربانی سووتاندنی بەردەوام دەیکەن.
\v 24 بە هەمان شێواز بۆ ماوەی حەوت ڕۆژ هەموو ڕۆژێک ئاوا بکەن، خۆراک پێشکەش بکەن، قوربانی بە ئاگرە، ئەو بۆنەی یەزدان پێی خۆشە، سەرەڕای قوربانی سووتاندنی بەردەوام لەگەڵ شەرابە پێشکەشکراوەکەی.
\v 25 لە ڕۆژی حەوتەمیش کۆبوونەوەی پیرۆزبوون ببەستن، هیچ کارێکی ئاسایی مەکەن.
\s1 جەژنی هەفتەکان
\p 
\v 26 «”لە ڕۆژی یەکەمین بەرهەم، کاتێک پێشکەشکراوێکی دانەوێڵەیی نوێ بۆ یەزدان پێشکەش دەکەن، لە جەژنی هەفتەکانتان\f + \fr 28:26 \ft جەژنی هەفتەکان، هەروەها وەک جەژنی دروێنەش ناسراوە (بڕوانە \xt دەرچوون 23‏:16‏\xt*\ft ‏)، 50 ڕۆژ دوای جەژنی فەتیرە بووە، کە دەکاتە حەوت هەفتە.‏\f* کۆبوونەوەی پیرۆزبوون ببەستن، هیچ کارێکی ئاسایی مەکەن.
\v 27 قوربانی سووتاندن پێشکەش بکەن، بۆ ئەو بۆنەی یەزدان پێی خۆشە، دوو جوانەگا و بەرانێک و حەوت بەرخی نێری یەک ساڵە،
\v 28 هەروەها پێشکەشکراوی دانەوێڵەشیان لە باشترین ئاردی بە زەیت شێلراو، سێ دەیەکی ئێفەیەک بۆ جوانەگا، دوو دەیەک بۆ بەران،
\v 29 دەیەکێک بۆ هەر بەرخێک لە حەوت بەرخەکە.
\v 30 گیسکێکی نێریش بۆ کەفارەتکردن بۆتان.
\v 31 سەرەڕای قوربانی سووتاندنی بەردەوام و پێشکەشکراوی دانەوێڵەکە بیکەن، دڵنیا بن لەوەی ئاژەڵەکان ساغن و لەگەڵ شەرابە پێشکەشکراوەکەیان بیکەن.
\c 29
\s1 ڕۆژی دەنگی کەڕەنا
\p 
\v 1 «”لە یەکی مانگی حەوت، کۆبوونەوەی پیرۆزبوون دەبەستن، هیچ کارێکی ئاسایی ناکەن، بۆتان دەبێتە ڕۆژی دەنگی کەڕەنا.
\v 2 قوربانی سووتاندنێک دەکەن بۆ ئەو بۆنەی یەزدان پێی خۆشە، یەک جوانەگا و یەک بەران و حەوت بەرخی نێری یەک ساڵەی ساغ،
\v 3 هەروەها پێشکەشکراوی دانەوێڵەشیان لە باشترین ئاردی بە زەیت شێلراو، سێ دەیەکی ئێفەیەک\f + \fr 29:3 \ft سێ دەیەکی ئێفەیەک نزیکەی 6,5 و دوو دەیەک نزیکەی 4,5 لیتر.‏\f* بۆ جوانەگاکە و دوو دەیەک بۆ بەرانەکە و
\v 4 دەیەکێک\f + \fr 29:4 \ft دەیەکێک: نزیکەی دوو لیتر.‏\f* بۆ هەر بەرخێک لە حەوت بەرخەکە.
\v 5 گیسکێکی نێریش بۆ قوربانی گوناه بۆ کەفارەتکردن بۆتان،
\v 6 سەرەڕای قوربانی سووتاندنی سەرەمانگان و ڕۆژانە، لەگەڵ پێشکەشکراوی دانەوێڵەکەیان و شەرابە پێشکەشکراوەکەیان وەک نەریتەکەیان، قوربانی بە ئاگرن بۆ یەزدان، ئەو بۆنەیە کە یەزدان پێی خۆشە.
\s1 ڕۆژی کەفارەت
\p 
\v 7 «”لە ڕۆژی دەیەمی ئەم مانگی حەوتەدا کۆبوونەوەی پیرۆزبوون دەبەستن و گیانی خۆتان زەلیل\f + \fr 29:7 \ft مەبەستی لە خۆبێبەشکردنە لە (خواردن و خواردنەوە یان جووتبوون لەگەڵ هاوسەر… هتد). لێرەدا زیاتر کات تەرخان دەکرێت بۆ نوێژکردن و پاڕانەوە. بڕوانە یەکەم نامەی پۆڵس بۆ باوەڕدارانی کۆرنسۆس 7‏:5 و \xt یۆحەنا 4‏:34‏\xt*\ft ‏.‏\f* دەکەن، هیچ کارێک ناکەن.
\v 8 قوربانی سووتاندن بۆ یەزدان پێشکەش دەکەن، ئەو بۆنەی پێی خۆشە، یەک جوانەگا و یەک بەران و حەوت بەرخی نێری یەک ساڵەی ساغ بن، لەلایەن ئێوەوە دەبێت.
\v 9 پێشکەشکراوی دانەوێڵەشیان لە باشترین ئاردی بە زەیت شێلراو، سێ دەیەکی ئێفەیەک بۆ جوانەگا و دوو دەیەک بۆ بەران و
\v 10 دەیەکێک بۆ هەر بەرخێک لە حەوت بەرخەکە.
\v 11 گیسکێکی نێریش بۆ قوربانی گوناه، سەرەڕای قوربانی گوناه بۆ کەفارەتکردن و قوربانی سووتاندنی بەردەوام و پێشکەشکراوی دانەوێڵەکەی لەگەڵ شەرابە پێشکەشکراوەکەیان.
\s1 جەژنی کەپرەشینە
\p 
\v 12 «”لە ڕۆژی پازدەی مانگی حەوتیش کۆبوونەوەی پیرۆزبوون دەبەستن، هیچ کارێکی ئاسایی ناکەن و حەوت ڕۆژ بۆ یەزدان دەیکەن بە جەژن.
\v 13 قوربانی سووتاندنیش پێشکەش دەکەن، قوربانی بە ئاگر، ئەو بۆنەی یەزدان پێی خۆشە، سێزدە جوانەگا و دوو بەران و چواردە بەرخی نێری یەک ساڵەی ساغ لەلایەن ئێوەوە دەبێت.
\v 14 پێشکەشکراوی دانەوێڵەشیان لە باشترین ئاردی بە زەیت شێلراو، سێ دەیەکی ئێفەیەک بۆ هەریەک لە سێزدە جوانەگاکە و دوو دەیەک بۆ هەریەک لە دوو بەرانەکە.
\v 15 دەیەکێک بۆ هەریەک لە چواردە بەرخەکە.
\v 16 هەروەها گیسکێکی نێر بۆ قوربانی گوناه، سەرەڕای قوربانی سووتاندنی بەردەوام لەگەڵ پێشکەشکراوی دانەوێڵەکەی و شەرابە پێشکەشکراوەکەی.
\p 
\v 17 «”لە ڕۆژی دووەم دوازدە جوانەگا و دوو بەران و چواردە بەرخی نێری یەک ساڵەی ساغ ئامادە بکەن.
\v 18 لەگەڵ جوانەگاکان و بەرانەکان و بەرخەکان، پێشکەشکراوی دانەوێڵەیان و شەرابی پێشکەشکراویان ئامادە بکەن، بەگوێرەی ژمارەیان وەک نەریتەکەیان.
\v 19 گیسکێکی نێریش بۆ قوربانی گوناه، سەرەڕای قوربانی سووتاندنی بەردەوام و پێشکەشکراوی دانەوێڵەکەی لەگەڵ شەرابە پێشکەشکراوەکەیان.
\p 
\v 20 «”لە ڕۆژی سێیەم یازدە جوانەگا و دوو بەران و چواردە بەرخی نێری یەک ساڵەی ساغ ئامادە بکەن.
\v 21 لەگەڵ جوانەگاکان و بەرانەکان و بەرخەکان، پێشکەشکراوی دانەوێڵەیان و شەرابی پێشکەشکراویان ئامادە بکەن، بەگوێرەی ژمارەیان وەک نەریتەکەیان.
\v 22 هەروەها گیسکێکی نێریش بۆ قوربانی گوناه، سەرەڕای قوربانی سووتاندنی بەردەوام لەگەڵ پێشکەشکراوی دانەوێڵەکەی و شەرابە پێشکەشکراوەکەی.
\p 
\v 23 «”لە ڕۆژی چوارەم دە جوانەگا و دوو بەران و چواردە بەرخی نێری یەک ساڵەی ساغ ئامادە بکەن.
\v 24 لەگەڵ جوانەگاکان و بەرانەکان و بەرخەکان، پێشکەشکراوی دانەوێڵەیان و شەرابی پێشکەشکراویان ئامادە بکەن، بەگوێرەی ژمارەیان وەک نەریتەکەیان.
\v 25 هەروەها گیسکێکی نێریش بۆ قوربانی گوناه، سەرەڕای قوربانی سووتاندنی بەردەوام لەگەڵ پێشکەشکراوی دانەوێڵەکەی و شەرابە پێشکەشکراوەکەی.
\p 
\v 26 «”لە ڕۆژی پێنجەم نۆ جوانەگا و دوو بەران و چواردە بەرخی نێری یەک ساڵەی ساغ ئامادە بکەن.
\v 27 لەگەڵ جوانەگاکان و بەرانەکان و بەرخەکان، پێشکەشکراوی دانەوێڵەیان و شەرابی پێشکەشکراویان ئامادە بکەن، بەگوێرەی ژمارەیان هەروەک نەریتەکەیان.
\v 28 گیسکێکی نێریش بۆ قوربانی گوناه، سەرەڕای قوربانی سووتاندنی بەردەوام لەگەڵ پێشکەشکراوی دانەوێڵەکەی و شەرابە پێشکەشکراوەکەی.
\p 
\v 29 «”لە ڕۆژی شەشەم هەشت جوانەگا و دوو بەران و چواردە بەرخی نێری یەک ساڵەی ساغ ئامادە بکەن.
\v 30 لەگەڵ جوانەگاکان و بەرانەکان و بەرخەکان، پێشکەشکراوی دانەوێڵەیان و شەرابی پێشکەشکراویان ئامادە بکەن، بەگوێرەی ژمارەیان وەک نەریتەکەیان.
\v 31 هەروەها گیسکێکی نێریش بۆ قوربانی گوناه، سەرەڕای قوربانی سووتاندنی بەردەوام لەگەڵ پێشکەشکراوی دانەوێڵەکەی و شەرابە پێشکەشکراوەکەی.
\p 
\v 32 «”لە ڕۆژی حەوتەم حەوت جوانەگا و دوو بەران و چواردە بەرخی نێری یەک ساڵەی ساغ ئامادە بکەن.
\v 33 لەگەڵ جوانەگاکان و بەرانەکان و بەرخەکان، پێشکەشکراوی دانەوێڵەیان و شەرابی پێشکەشکراویان ئامادە بکەن، بەگوێرەی ژمارەیان وەک نەریتەکەیان.
\v 34 هەروەها گیسکێکی نێریش بۆ قوربانی گوناه، سەرەڕای قوربانی سووتاندنی بەردەوام لەگەڵ پێشکەشکراوی دانەوێڵەکەی و شەرابە پێشکەشکراوەکەی.
\p 
\v 35 «”لە ڕۆژی هەشتەم ئاهەنگی کۆتایی دەگێڕن، هیچ کارێکی ئاسایی ناکەن.
\v 36 قوربانی سووتاندن پێشکەش دەکەن، قوربانی بە ئاگر، ئەو بۆنەی یەزدان پێی خۆشە، یەک جوانەگا و یەک بەران و حەوت بەرخی نێری یەک ساڵەی ساغ،
\v 37 پێشکەشکراوی دانەوێڵەشیان و شەرابی پێشکەشکراویان بۆ جوانەگا و بەران و بەرخەکان بەگوێرەی ژمارەیان وەک نەریتەکەیان،
\v 38 گیسکێکی نێریش بۆ قوربانی گوناه، سەرەڕای قوربانی سووتاندنی بەردەوام لەگەڵ پێشکەشکراوی دانەوێڵەکەی و شەرابە پێشکەشکراوەکەی.
\p 
\v 39 «”لە جەژنەکانتان، سەرەڕای نەزر و بەخشینە ئازادەکانتان، ئەمانە بۆ یەزدان پێشکەش دەکەن: قوربانی سووتاندن و پێشکەشکراوی دانەوێڵە و شەرابی پێشکەشکراو و قوربانی هاوبەشی.“»
\p 
\v 40 موسا بەگوێرەی هەموو ئەوەی یەزدان فەرمانی پێ کرد، لەگەڵ نەوەی ئیسرائیلدا دوا.
\c 30
\s1 نەزرکردن
\p 
\v 1 هەروەها موسا بە سەرۆک هۆزەکانی نەوەی ئیسرائیلی گوت: «ئەمە ئەو شتەیە کە یەزدان فەرمانی پێی کردووە،
\v 2 ئەگەر پیاوێک نەزرێکی بۆ یەزدان کرد یان سوێندی خوارد بۆ پابەندبوون بە شتێک، با قسەی خۆی نەشکێنێت و بەگوێرەی هەموو ئەوەی گوتوویەتی ئاوا بکات.
\p 
\v 3 «بەڵام ئافرەت ئەگەر نەزرێکی بۆ یەزدان کرد و بە شتێک خۆی پابەند کرد، لە ماڵی باوکی، لە کاتی کچێنی و
\v 4 باوکی گوێی لە نەزرەکەی و ئەو شتە بوو کە خۆی پێ پابەند کردووە، ئەگەر خۆی لێ بێدەنگ کرد، ئەوا هەموو نەزرەکانی و هەموو ئەو شتانەی خۆی پێ پابەند کردووە دەچەسپێت.
\v 5 بەڵام ئەگەر باوکی لە ڕۆژی بیستنی نەیهێشت، ئەوا هەموو نەزر و ئەو شتانەی خۆی پێ پابەند کردووە ناچەسپێت، یەزدانیش لێی خۆشدەبێت، چونکە باوکی نەیهێشتووە.
\p 
\v 6 «ئەگەر شووی کرد دوای ئەوەی نەزرێکی کرد یان شتێکی بە دەمدا هات کە خۆی پێ پابەند دەکات و
\v 7 مێردەکەی بیستی و لە ڕۆژی بیستنەکەی بێدەنگ بوو، ئەوا نەزرەکانی دەچەسپێت و ئەو شتانەش کە خۆی پێ پابەند کردووە دەچەسپێت.
\v 8 بەڵام ئەگەر مێردەکەی لە کاتی بیستنی ئەوەدا ڕێگەی نەدا، ئەوا نەزرەکەی بەتاڵ دەبێتەوە، هەروەها ئەو شتەش بەتاڵ دەبێتەوە کە بە دەمیدا هاتووە و خۆی پێ پابەند کردبوو، یەزدانیش لێی خۆشدەبێت.
\p 
\v 9 «بەڵام نەزری بێوەژن یان تەڵاقدراو، ئەوا هەموو ئەوەی خۆی پێ پابەند دەکات لەسەری دەچەسپێت.
\p 
\v 10 «بەڵام ئەگەر ژنێک لە ماڵی مێردی نەزری کرد و خۆی بە سوێند بە شتێکەوە پابەند کرد،
\v 11 مێردەکەی بیستی و بێدەنگ بوو، ڕێی لێ نەگرت، ئەوا هەموو نەزرەکانی دەچەسپێن و هەموو ئەو شتانەی خۆی پێ پابەند کردووە دەچەسپێت.
\v 12 بەڵام ئەگەر مێردەکەی لە ڕۆژی بیستنی بەتاڵی کردەوە، ئەوا هەرچی گوتوویەتی لە نەزر و پابەندبوونەکانی ناچەسپێن، چونکە مێردەکەی بەتاڵی کردووەتەوە، یەزدانیش لێی خۆشدەبێت.
\v 13 هەموو نەزرێک و هەموو سوێندێکی پابەندبوون بۆ زەلیلکردنی گیان، مێردەکەی دەیچەسپێنێت و مێردەکەی بەتاڵی دەکاتەوە.
\v 14 ئەگەر مێردەکەی ڕۆژ لەدوای ڕۆژ لێی بێدەنگ بوو، ئەوا هەموو نەزرەکانی یان هەموو ئەو پابەندبوونانەی لەسەریەتی دەچەسپێن، چەسپاندوویەتی چونکە لەو ڕۆژەی بیستوویەتی لێی بێدەنگ بوو،
\v 15 جا ئەگەر لەدوای بیستنی بەتاڵی کردەوە، ئەوا تاوانەکەی دەکەوێتە ئەستۆی ئەو.»
\p 
\v 16 ئەمە ئەو فەرزانەیە کە یەزدان فەرمانی بە موسا کرد لەنێوان مێرد و ژنەکەی و لەنێوان باوک و کچەکەی لە کاتی کچێنیدا لە ماڵی باوکی.
\c 31
\s1 تۆڵە لە میدیانییەکان
\p 
\v 1 هەروەها یەزدان بە موسای فەرموو:
\v 2 «بە تەواوی تۆڵە بۆ نەوەی ئیسرائیل لە میدیانییەکان بکەرەوە، ئینجا دەچیتە پاڵ گەلەکەت.»
\p 
\v 3 موساش بە گەلی گوت: «لەنێو خۆتان هەندێک پیاو چەکدار بکەن بۆ جەنگ، هەتا بچنە سەر میدیان و تۆڵەی یەزدان لە میدیان بکەنەوە،
\v 4 لە هەر هۆزێک هەزار کەس لە هەموو هۆزەکانی ئیسرائیل بۆ جەنگ دەنێرن.»
\v 5 ئینجا لە خێڵەکانی ئیسرائیلدا لە هەر هۆزێک هەزار کەس هەڵبژێردرا، دوازدە هەزار کەس بۆ جەنگ چەکدار کران.
\v 6 ئینجا موسا ناردنی بۆ جەنگ، لە هەر هۆزێک هەزار، لەگەڵ فینەحاسی کوڕی ئەلعازاری کاهین، قاپوقاچاغی پیرۆزگا و کەڕەناکانی هوتافیشی بەدەستەوە بوو.
\p 
\v 7 ئەوان لە دژی میدیانییەکان جەنگان، وەک یەزدان فەرمانی بە موسا کرد، هەموو نێرینەیەکیان کوشت.
\v 8 پاشاکانی میدیانیشیان لەگەڵ کوژراوەکانیاندا کوشت، ئاڤی و ڕاقەم و چوور و حوور و ڕێڤەع، پێنج پاشای میدیان، بەلعامی کوڕی بەعۆریشیان بە شمشێر کوشت.
\v 9 هەروەها نەوەی ئیسرائیل ژن و منداڵی میدیانیان ڕاپێچ کرد و هەموو ئاژەڵ و مەڕ و مانگا و هەموو موڵکیانیان تاڵان کردن.
\v 10 هەموو ئەو شارۆچکانەش کە میدیانییەکان تێیدا نیشتەجێ بوون و خێوەتگاکانیان سووتاند.
\v 11 لە دەستکەوت و تاڵانییەکەش لە مرۆڤ و ئاژەڵ هەموویان برد.
\v 12 ئینجا بە ڕاپێچکراوان و تاڵان و دەستکەوتەوە هاتنە لای موسا و ئەلعازاری کاهین، کۆمەڵی نەوەی ئیسرائیل لە ئۆردوگاکە لە دەشتی مۆئاب کە لەسەر ڕووباری ئوردون بوو بەرامبەر ئەریحا.
\p 
\v 13 موسا و ئەلعازاری کاهین و هەموو ڕابەرانی کۆمەڵ بۆ پێشوازییان چوونە دەرەوەی ئۆردوگاکە.
\v 14 بەڵام موسا لە سەرکردەکانی سوپا تووڕە بوو، کە فەرماندەکانی هەزاران و سەدان بوون و لە جەنگەوە هاتبوونەوە.
\p 
\v 15 موسا لێی پرسین: «ئایا هەموو ئافرەتێکتان بە زیندوویی هێشتووەتەوە؟
\v 16 ئەوانە بوون بە قسەی بەلعامیان کرد و بوونە هۆی ناپاکی نەوەی ئیسرائیل لەگەڵ یەزدان لە کێشەکەی پەعۆر، جا دەرد لەناو کۆمەڵی یەزدان بڵاو بووەوە.
\v 17 ئێستاش هەموو منداڵە نێرینەکان بکوژن لەگەڵ هەر ژنێک کە لەگەڵ نێر سەرجێیی کردووە،
\v 18 بەڵام هەموو ئەو کچانەی لەگەڵ پیاو سەرجێییان نەکردووە بۆ خۆتان بە زیندوویی بیانهێڵنەوە.
\p 
\v 19 «ئێوەش حەوت ڕۆژ لە دەرەوەی ئۆردوگاکە چادر هەڵبدەن و خۆتان پاک بکەنەوە، هەرکەسێک یەکێکی کوشتووە یان دەستی لە کوژراوێک داوە، با لە ڕۆژی سێیەم و حەوتەم خۆی پاک بکاتەوە، ئێوە و ڕاپێچکراوانتان.
\v 20 هەروەها هەر بەرگێک یان شتێک لە پێست یان لە مووی بزن دروستکرابێت و هەر شتێک لە دار دروستکرابێت، پاکی دەکەنەوە.»
\p 
\v 21 ئەلعازاری کاهینیش بە پیاوانی سوپاکەی گوت کە چووبوون بۆ جەنگ: «ئەمە فەرزی فێرکردنەکەیە کە یەزدان فەرمانی بە موسا کرد،
\v 22 زێڕ و زیو و بڕۆنز و ئاسن و تەنەکە و قورقوشم،
\v 23 هەموو ئەو شتانەی بەرگەی ئاگر دەگرێت، بەناو ئاگردا تێپەڕی دەکەن و پاشان بە ئاوی پاککردنەوە خاوێن دەبێتەوە. هەموو ئەو شتانەش کە بەرگەی ئاگر ناگرێت، ئەوا بەناو ئاودا تێپەڕی دەکەن.
\v 24 لە ڕۆژی حەوتەمیش جلەکانتان دەشۆن و ئێوە پاک دەبنەوە، ئینجا دێنەوە ناو ئۆردوگاکە.»
\s1 دابەشکردنی تاڵان
\p 
\v 25 هەروەها یەزدان بە موسای فەرموو:
\v 26 «تۆ و ئەلعازاری کاهین و گەورەی بنەماڵەکانی کۆمەڵ تاڵانە ڕاپێچکراوەکە لە خەڵک و لە ئاژەڵ بژمێرن.
\v 27 تاڵانییەکە بە یەکسانی دابەش بکە لەنێوان ئەو سەربازانەی کە لە جەنگ بەشداریان کرد و هەروەها هەموو کۆمەڵ.
\v 28 بەشی یەزدانیش دەربهێنە لە بەشی ئەوانەی بەشدارییان لە جەنگ کردووە، یەک لە پێنج سەدی خەڵک و گاوگۆتاڵ\f + \fr 31:28 \ft گاوگۆتاڵ: بە واتای ئاژەڵی بچووک و ئاژەڵی گەورە دێت.‏\f* و گوێدرێژ.
\v 29 لە نیوەکەی ئەوان وەریدەگرن و دەیدەنە ئەلعازاری کاهین، بەخشینی بەرزکراوەیە بۆ یەزدان.
\v 30 لە نیوەکەی نەوەی ئیسرائیلیش یەک لە پەنجا لە خەڵک و گاوگۆتاڵ و گوێدرێژ و مەڕ یان لە هەر ئاژەڵێکی دیکە دەبەیت و دەیدەیتە لێڤییەکان کە بەرپرسیارن لە بایەخدان بە چادری پەرستنی یەزدان.»
\v 31 جا موسا و ئەلعازاری کاهین وەک یەزدان فەرمانی بە موسا کرد، ئاوایان کرد.
\p 
\v 32 کۆی تاڵانییەکەش کە دەستکەوتی پیاوانی سوپاکە بوو، شەش سەد و حەفتا و پێنج هەزار مەڕ و
\v 33 حەفتا و دوو هەزار مانگا و
\v 34 شەست و یەک هەزار گوێدرێژ بوون،
\v 35 لە مرۆڤیش لەو ئافرەتانەی کە لەگەڵ پیاو سەرجێییان نەکردبوو سی و دوو هەزار کەس بوون.
\b
\li4 
\v 36 جا نیوەکەی کە بەشی ئەوانە بوو بۆ جەنگ چووبوون:
\b
\li1 سێ سەد و سی و حەوت هەزار و پێنج سەد مەڕ بوو،
\v 37 بەشی یەزدانیش لە مەڕەکان شەش سەد و حەفتا و پێنج بوو،
\li1 
\v 38 مانگاکانیش سی و شەش هەزار بوو و بەشی یەزدانیش حەفتا و دوو بوو،
\li1 
\v 39 گوێدرێژیش سی هەزار و پێنج سەد بوو، بەشی یەزدانیش شەست و یەک بوو.
\li1 
\v 40 مرۆڤیش شازدە هەزار بوو، بەشی یەزدانیش سی و دوو بوو.
\b
\p 
\v 41 جا بەشەکە کە بەخشینی بەرزکراوە بوو بۆ یەزدان، موسا دایە ئەلعازاری کاهین، وەک یەزدان فەرمانی بە موسا کرد.
\p 
\v 42 بەڵام نیوەکەی ئیسرائیل کە موسا لە پیاوانی سوپاکەی جیا کردبووەوە،
\v 43 نیوەکەی کۆمەڵ سێ سەد و سی و حەوت هەزار و پێنج سەد مەڕ بوو،
\v 44 مانگاش سی و شەش هەزار بوو،
\v 45 گوێدرێژیش سی هەزار و پێنج سەد بوو،
\v 46 لە مرۆڤیش شازدە هەزار بوو.
\v 47 جا موسا لە نیوەکەی نەوەی ئیسرائیل یەک لە پەنجای خەڵک و ئاژەڵی برد و دایە لێڤییەکان کە بەرپرسیار بوون لە بایەخدان بە چادری پەرستنی یەزدان، وەک یەزدان فەرمانی بە موسا کرد.
\p 
\v 48 ئینجا سەرکردەی یەکەکانی سوپاکە هاتنە پێش بۆ لای موسا، فەرماندەکانی هەزاران و سەدان،
\v 49 بە موسایان گوت: «ئێمەی خزمەتکارانت ژمارەی ئەو پیاوانەی جەنگمان وەرگرت کە لەژێر فەرمانمان بوون و کەسمان لەدەست نەداوە.
\v 50 ئەوەتا قوربانی یەزدانمان پێشکەش کرد، هەریەکە هەرچی کەلوپەلی زێڕی دەست کەوتووە لە خڕخاڵ و بازن و ئەنگوستیلە و گوارە و ملوانکە، بۆ کەفارەتکردن بۆمان لەبەردەم یەزدان.»
\p 
\v 51 جا موسا و ئەلعازاری کاهین هەموو کەلوپەلێکی لە زێڕ دروستکراویان لێ وەرگرتن.
\v 52 هەموو زێڕەکەی بەخشینی بەرزکراوە کە لەلایەن فەرماندەکانی هەزاران و سەدان بۆ یەزدان بەرز کرایەوە، شازدە هەزار و حەوت سەد و پەنجا شاقل بوو.
\v 53 بەڵام پیاوانی سوپاکە ئەوەی دەستیان کەوتبوو بۆ خۆیان بوو.
\v 54 جا موسا و ئەلعازاری کاهین زێڕەکەیان لە فەرماندەکانی هەزاران و سەدان وەرگرت و هێنایانە ناو چادری چاوپێکەوتنەوە، وەک یادگاری بۆ نەوەی ئیسرائیل لەبەردەم یەزدان.
\c 32
\s1 هۆزەکانی ئەوبەری ڕووباری ئوردون
\p 
\v 1 بەڵام نەوەی ڕەئوبێن و نەوەی گاد گاوگۆتاڵی زۆریان هەبوو، کاتێک بینییان خاکی یەعزێر و خاکی گلعاد شوێنی مەڕوماڵاتە،
\v 2 ئیتر نەوەی گاد و نەوەی ڕەئوبێن هاتن و بە موسا و ئەلعازاری کاهین و ڕابەرەکانی کۆمەڵیان گوت:
\v 3 «عەتەرۆت و دیڤۆن و یەعزێر و نیمرا و حەشبۆن و ئەلعالێ و سەڤام و نیبۆ و بەعۆن،
\v 4 ئەو خاکەی یەزدان لەبەردەم کۆمەڵی ئیسرائیل بەزاندی، ئەوە خاکی مەڕوماڵاتە و خزمەتکارەکانیشت مەڕوماڵاتیان هەیە.»
\v 5 هەروەها گوتیان: «ئەگەر لەبەرچاوت پەسەندین، با ئەو خاکە بدرێت بە خزمەتکارەکانت و ببێت بە موڵکمان و لە ڕووباری ئوردون مەمانپەڕێنەوە.»
\p 
\v 6 موساش بە نەوەی گاد و ڕەئوبێنی گوت: «ئایا دەبێت براکانتان بۆ جەنگ بڕۆن و ئێوەش لێرە دانیشن؟
\v 7 بۆچی دڵی نەوەی ئیسرائیل سارد دەکەنەوە لە پەڕینەوەیان بۆ ئەو خاکەی یەزدان پێیداون؟
\v 8 باوکانتان ئاوایان کرد کاتێک لە قادێش بەرنێعەوە ئەوانم نارد بۆ ئەوەی تەماشای خاکەکە بکەن،
\v 9 بە دۆڵی ئەشکۆلدا سەرکەوتن و تەماشای خاکەکەیان کرد و دڵی نەوەی ئیسرائیلیان سارد کردەوە لە چوونە ناو ئەو خاکەی یەزدان پێیداون.
\v 10 لەو ڕۆژەدا تووڕەیی یەزدان جۆشا و سوێندی خوارد و فەرمووی:
\v 11 ”ئەو خەڵکەی کە لە میسر هاتنە دەرەوە، لە گەنجی بیست ساڵ بەرەو سەرەوە، ناچنە ناو ئەو خاکەی سوێندم لەسەری خوارد بۆ ئیبراهیم و ئیسحاق و یاقوب، چونکە بە هەموو دڵیانەوە دوام نەکەوتن،
\v 12 تەنها کالێبی کوڕی یەفونەی قەنیزی و یەشوعی کوڕی نون نەبێت، چونکە بە هەموو دڵیانەوە دوای یەزدان کەوتن.“
\v 13 تووڕەیی یەزدان بەسەر ئیسرائیلدا جۆشا و چل ساڵ لە چۆڵەوانی وێڵی کردن، هەتا هەموو ئەو نەوەیە لەناوچوون کە لەبەرچاوی یەزدان خراپەیان کرد.
\p 
\v 14 «ئەوەتا ئێوەش لە جیاتی باوکانتان هەستاون، کۆمەڵە خەڵکێکی گوناهبارن، تاکو کوڵی تووڕەیی یەزدان لەسەر ئیسرائیل زیاتر بکەن.
\v 15 ئەگەر لێی هەڵگەڕێنەوە، ئەوا دیسان لەم چۆڵەوانییە وازیان لێ دەهێنێت، ئیتر دەبنە هۆی لەناوچوونی هەموو ئەم گەلە.»
\p 
\v 16 ئەوانیش لێی هاتنە پێش و گوتیان: «لێرە پشتیر\f + \fr 32:16 \ft پشتیر: گەوڕ، شوێنێکی تایبەت بووە بە پەروەردەکردنی ئاژەڵ.‏\f* بۆ ماڵاتەکانمان و چەند شارێک بۆ ژن و منداڵەکانمان بنیاد دەنێین،
\v 17 بەڵام خۆمان چەک هەڵدەگرین و بە خێرایی پێش نەوەی ئیسرائیل دەکەوین هەتا دەیانبەینە شوێنەکەیان. هەروەها ژن و منداڵەکانیشمان لەبەر دانیشتووانی ئەم خاکە لە شاری قەڵابەند دەبن.
\v 18 ناگەڕێینەوە ماڵەکانمان هەتا نەوەی ئیسرائیل هەریەکە میراتگری میراتەکەی خۆی نەبێت،
\v 19 ئێمە لە پشتی ڕووباری ئوردون و بەو لاوە میراتمان لەگەڵیان نابێت، چونکە میراتی خۆمان لە بەری ڕۆژهەڵاتی ڕووباری ئوردون وەرگرت.»
\p 
\v 20 موساش پێی گوتن: «ئەگەر ئەمەتان کرد، ئەگەر لەبەردەم یەزدان چەکتان بۆ جەنگ هەڵگرت و
\v 21 هەموو چەکدارەکانتان لە ڕووباری ئوردون پەڕینەوە، هەتا هەموو دوژمنەکانی لەبەردەمی خۆی دەرکرد و
\v 22 خاکەکە لەبەردەم یەزدان ژێردەستە کرا و لەدوای ئەمە گەڕانەوە، ئەوا سەبارەت بە یەزدان و بە ئیسرائیل ئازاد دەبن لە پابەندییەکەتان و لەبەردەم یەزدان ئەم خاکە دەبێتە موڵکتان.
\p 
\v 23 «بەڵام ئەگەر وا نەکەن، ئەوا گوناه لە دژی یەزدان دەکەن و باش دەزانن کە گوناهەکەتان چیتان بەسەردەهێنێت.
\v 24 بۆ خۆتان چەند شارێک بۆ ژن و منداڵەکانتان و پشتیر بۆ ماڵاتەکانتان بنیاد بنێن، ئەوەی بەڵێنتان دا بیکەن.»
\p 
\v 25 نەوەی گاد و نەوەی ڕەئوبێن بە موسایان گوت: «خزمەتکارەکانت ئاوا دەکەن، وەک گەورەم فەرمانی دا،
\v 26 ژن و منداڵ و گاوگۆتاڵەکانمان لەوێ لە شارەکانی گلعاد دەبن.
\v 27 بەڵام خزمەتکارەکانت، هەموو چەک هەڵگرەکان لەبەردەم یەزدان بۆ جەنگ دەپەڕنەوە، وەک گەورەمان گوتی.»
\p 
\v 28 موساش لەبارەی ئەوانەوە فەرمانی بە ئەلعازاری کاهین و یەشوعی کوڕی نون و گەورەی بنەماڵەکانی هۆزەکانی نەوەی ئیسرائیل کرد و
\v 29 پێی گوتن: «ئەگەر نەوەی گاد و نەوەی ڕەئوبێن، هەموو چەک هەڵگرەکان بۆ جەنگ، لەبەردەم یەزدان لەگەڵتان لە ڕووباری ئوردون پەڕینەوە، کاتێک خاکەکە کەوتە ژێر دەستتان، ئەوا دەبێت خاکی گلعادیان وەک موڵک پێبدەن.
\v 30 بەڵام ئەگەر بە چەکەوە لەگەڵتان نەپەڕینەوە، ئەوا لەنێوتان لە خاکی کەنعان موڵکیان دەبێت.»
\p 
\v 31 نەوەی گاد و نەوەی ڕەئوبێن وەڵامیان دایەوە و گوتیان: «ئەوەی یەزدان سەبارەت بە خزمەتکارەکانت فەرمووی، ئاوا دەکەین.
\v 32 ئێمە بە چەکەوە لەبەردەم یەزدان بۆ خاکی کەنعان دەپەڕینەوە، بەڵام لە ڕۆژهەڵاتی ڕووباری ئوردون بەشە میراتمان دەدرێتێ.»
\p 
\v 33 ئینجا موسا پاشایەتییەکەی سیحۆنی پاشای ئەمۆرییەکان و پاشایەتییەکەی عۆگی پاشای باشان، تەواوی خاکەکە لەگەڵ شارەکانی و بە سنوورەکانی دەوروبەریەوە دایە نەوەی گاد و نەوەی ڕەئوبێن و نیوەی هۆزی مەنەشەی\f + \fr 32:33 \ft هۆزی مەنەشە دابەش ببوون بۆ سەر دوو بەش، هەریەکەیان کەوتبووە لایەکی ڕووباری ئوردون.‏\f* کوڕی یوسف.
\p 
\v 34 نەوەی گاد دیڤۆن و عەتەرۆت، عەرۆعێر،
\v 35 عەترۆت شۆفان، یەعزێر، یۆگبەها،
\v 36 بێت‌نیمرا و بێت‌هارانیان کردە شاری قەڵابەند، پشتیری مەڕیشیان بنیاد نا،
\v 37 نەوەی ڕەئوبێنیش حەشبۆن و ئەلعالێ و قیریاتەیم و
\v 38 نیبۆ و بەعل‌مەعۆن کە ناوەکەیان گۆڕیوە و هەروەها سیڤما، ناویشیان لەو شارانە نا کە بنیادیان ناوە.
\p 
\v 39 نەوەی ماکیری کوڕی مەنەشەش چوونە گلعاد و گرتیان، ئەو ئەمۆرییانەیان دەرکرد کە تێیدا بوون.
\v 40 ئینجا موساش گلعادی دا بە ماکیرییەکان، کە نەوەی مەنەشەن، ئەوانیش تێیدا نیشتەجێ بوون.
\v 41 یائیری نەوەی مەنەشەش چوو و دەستی بەسەر ئاوەدانییەکانیاندا گرت و ناوی لێنان حەڤۆت یائیر.
\v 42 نۆڤەحیش چوو و دەستی بەسەر قەنات و ئاوەدانییەکانیدا گرت و بە ناوی خۆیەوە ناوی لێنا نۆڤەح.
\c 33
\s1 کۆچەکانی نەوەی ئیسرائیل
\p 
\v 1 ئەمانە قۆناغەکانی کۆچی نەوەی ئیسرائیلن کە بە لەشکرەکانیانەوە لەسەر دەستی موسا و هارون لە خاکی میسرەوە هاتنە دەرەوە.
\v 2 موساش بەپێی فەرمانی یەزدان قۆناغی کۆچەکانیانی تۆمار کرد. ئەمەش کۆچەکانیانە، قۆناغ بە قۆناغ:
\b
\pi1 
\v 3 لە ڕۆژی پازدەی مانگی یەک، لە ڕۆژی دوای جەژنی پەسخە لە ڕەعمسێسەوە کۆچیان کرد. نەوەی ئیسرائیل بوێرانە لەبەرچاوی هەموو میسرییەکان چوونە دەرەوە.
\v 4 لەو کاتەدا میسرییەکان هەموو نۆبەرەکانی خۆیانیان دەناشت کە یەزدان لێیدابوون، چونکە یەزدان حوکمی خوداوەندەکانی ئەوانی دابوو.
\pi1 
\v 5 نەوەی ئیسرائیل لە ڕەعمسێسەوە کۆچیان کرد و لە سوکۆت چادریان هەڵدا.
\pi1 
\v 6 ئینجا لە سوکۆتەوە کۆچیان کرد و لە ئێتام چادریان هەڵدا کە لە قەراغی چۆڵەوانییە.
\pi1 
\v 7 پاشان لە ئێتامەوە کۆچیان کرد و گەڕانەوە لای پی‌هەحیرۆت، کە لە ڕۆژهەڵاتی بەعل‌چیفۆنە و بەرامبەر مگدۆل چادریان هەڵدا.
\pi1 
\v 8 پاشان لە پی‌هەحیرۆتەوە کۆچیان کرد و بەناو دەریادا پەڕینەوە بۆ چۆڵەوانی و سێ ڕۆژە ڕێ لە چۆڵەوانی ئێتامدا ڕۆیشتن، لە مارا چادریان هەڵدا.
\pi1 
\v 9 پاشان لە ماراوە کۆچیان کرد و هاتنە ئێلیم، لە ئێلیمیش دوازدە کانیاو و حەفتا دار خورمای لێبوو، لەوێ چادریان هەڵدا.
\pi1 
\v 10 پاشان لە ئێلیمەوە کۆچیان کرد و لەلای دەریای سوور چادریان هەڵدا.
\pi1 
\v 11 پاشان لەلای دەریای سوورەوە کۆچیان کرد و لە چۆڵەوانی سین\f + \fr 33:11 \ft لە ڕۆژئاوای نیمچە دوورگەی سینا چۆڵەوانییەک هەبوو بە ناوی سین.‏\f* چادریان هەڵدا.
\pi1 
\v 12 پاشان لە چۆڵەوانی سینەوە کۆچیان کرد و لە دۆفقە چادریان هەڵدا.
\pi1 
\v 13 پاشان لە دۆفقەوە کۆچیان کرد و لە ئالوش چادریان هەڵدا.
\pi1 
\v 14 پاشان لە ئالوشەوە کۆچیان کرد و لە ڕەفیدیم چادریان هەڵدا، لەوێ هیچ ئاو نەبوو تاکو گەل بیخۆنەوە.
\pi1 
\v 15 پاشان لە ڕەفیدیمەوە کۆچیان کرد و لە چۆڵەوانی سینا چادریان هەڵدا.
\pi1 
\v 16 پاشان لە چۆڵەوانی سیناوە کۆچیان کرد و لە قیبرۆت هەتەڤا چادریان هەڵدا.
\pi1 
\v 17 پاشان لە قیبرۆت هەتەڤایەوە کۆچیان کرد و لە حەچێرۆت چادریان هەڵدا.
\pi1 
\v 18 پاشان لە حەچێرۆتەوە کۆچیان کرد و لە ڕیتمە چادریان هەڵدا.
\pi1 
\v 19 پاشان لە ڕیتمەوە کۆچیان کرد و لە ڕیمۆن پێرێز چادریان هەڵدا.
\pi1 
\v 20 پاشان لە ڕیمۆن پێرێزەوە کۆچیان کرد و لە لیڤنا چادریان هەڵدا.
\pi1 
\v 21 پاشان لە لیڤناوە کۆچیان کرد و لە ڕیسە چادریان هەڵدا.
\pi1 
\v 22 پاشان لە ڕیسەوە کۆچیان کرد و لە قەهێلاتە چادریان هەڵدا.
\pi1 
\v 23 پاشان لە قەهێلاتەیەوە کۆچیان کرد و لە کێوی شافەر چادریان هەڵدا.
\pi1 
\v 24 پاشان لە کێوی شافەرەوە کۆچیان کرد و لە حەرادە چادریان هەڵدا.
\pi1 
\v 25 پاشان لە حەرادەوە کۆچیان کرد و لە مەقهێلۆت چادریان هەڵدا.
\pi1 
\v 26 پاشان لە مەقهێلۆتەوە کۆچیان کرد و لە تاحەت چادریان هەڵدا.
\pi1 
\v 27 پاشان لە تاحەتەوە کۆچیان کرد و لە تارەح چادریان هەڵدا.
\pi1 
\v 28 پاشان لە تارەحەوە کۆچیان کرد و لە میتقە چادریان هەڵدا.
\pi1 
\v 29 پاشان لە میتقەوە کۆچیان کرد و لە حەشمۆنە چادریان هەڵدا.
\pi1 
\v 30 پاشان لە حەشمۆنەوە کۆچیان کرد و لە مۆسێرۆت چادریان هەڵدا.
\pi1 
\v 31 پاشان لە مۆسێرۆتەوە کۆچیان کرد و لە بەنێ یەعقان چادریان هەڵدا.
\pi1 
\v 32 پاشان لە بەنێ یەعقانەوە کۆچیان کرد و لە حۆر هەگیدگاد چادریان هەڵدا.
\pi1 
\v 33 پاشان لە حۆر هەگیدگادەوە کۆچیان کرد و لە یۆتباتە چادریان هەڵدا.
\pi1 
\v 34 پاشان لە یۆتباتەیەوە کۆچیان کرد و لە عەڤرۆنە چادریان هەڵدا.
\pi1 
\v 35 پاشان لە عەڤرۆنەیەوە کۆچیان کرد و لە عەچیۆن گەڤەر چادریان هەڵدا.
\pi1 
\v 36 پاشان لە عەچیۆن گەڤەرەوە کۆچیان کرد و لە چۆڵەوانی چن کە قادێشە چادریان هەڵدا.
\pi1 
\v 37 پاشان لە قادێشەوە کۆچیان کرد و لە کێوی هۆر چادریان هەڵدا کە لە نزیکی سنووری خاکی ئەدۆمە.
\v 38 لە یەکی مانگی پێنجی چلەمین ساڵی هاتنەدەرەوەی نەوەی ئیسرائیل لە خاکی میسر، هارونی کاهین بەپێی فەرمانی یەزدان بۆ سەر کێوی هۆر سەرکەوت و لەوێ مرد.
\v 39 هارون تەمەنی سەد و بیست و سێ ساڵ بوو کاتێک لە کێوی هۆر مرد.
\pi1 
\v 40 پاشای عەرادیش کە کەنعانی بوو و لە نەقەب لە خاکی کەنعان نیشتەجێ بوو، هاتنی نەوەی ئیسرائیلی بیست.
\pi1 
\v 41 ئینجا لە کێوی هۆرەوە کۆچیان کرد و لە چەلمۆنا چادریان هەڵدا.
\pi1 
\v 42 پاشان لە چەلمۆنایەوە کۆچیان کرد و لە پونۆن چادریان هەڵدا.
\pi1 
\v 43 پاشان لە پونۆنەوە کۆچیان کرد و لە ئۆڤۆت چادریان هەڵدا.
\pi1 
\v 44 پاشان لە ئۆڤۆتەوە کۆچیان کرد و لە عییی عەڤاریم چادریان هەڵدا، کە لە سنووری مۆئابە.
\pi1 
\v 45 پاشان لە عییی عەڤاریم کۆچیان کرد و لە دیڤۆن گاد چادریان هەڵدا.
\pi1 
\v 46 پاشان لە دیڤۆن گادەوە کۆچیان کرد و لە عەلمۆن دیڤلاتایم چادریان هەڵدا.
\pi1 
\v 47 پاشان لە عەلمۆن دیڤلاتایمەوە کۆچیان کرد و لە زنجیرە چیای عەڤاریم ڕووبەڕووی نیبۆ چادریان هەڵدا.
\pi1 
\v 48 پاشان لە زنجیرە چیای عەڤاریمەوە کۆچیان کرد و لە دەشتی مۆئاب لەسەر کەناری ڕووباری ئوردون بەرامبەر ئەریحا چادریان هەڵدا،
\v 49 لە کەناری ڕووباری ئوردون لە بێت‌یەشیمۆتەوە هەتا ئابێل شیتیم لە دەشتی مۆئاب چادریان هەڵدا.
\b
\p 
\v 50 یەزدان لە دەشتی مۆئاب لەسەر کەناری ڕووباری ئوردون بەرامبەر ئەریحا بە موسای فەرموو:
\v 51 «لەگەڵ نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”کاتێک ئێوە لە ڕووباری ئوردون دەپەڕنەوە بۆ خاکی کەنعان،
\v 52 هەموو دانیشتووانی خاکەکە لەپێش خۆتان دەربکەن. هەموو پەیکەرە تاشراو و بتە داڕێژراوەکانیان لەناوببەن، هەموو نزرگەکانی سەر بەرزاییان\f + \fr 33:52 \ft مەبەست لەو شوێنە بەرزانەیە کە بۆ قوربانیکردن و ڕێوڕەسمی پەرستنی بتەکان بووە.‏\f* تێکبدەن.
\v 53 خاکەکە داگیر بکەن و تێیدا نیشتەجێ بن، چونکە من خاکەکەم پێداون بۆ ئەوەی ببنە خاوەنی و
\v 54 خاکەکەش بەگوێرەی خێڵەکانتان بە تیروپشک دابەش بکەن، میراتی زۆر بدەنە زۆرەکان و میراتی کەم بدەنە کەمەکان، لەکوێ تیروپشکی بۆ دەرچوو ئەوێ بۆ ئەو بێت، بەگوێرەی هۆزەکانی باوکانتان میراتگری بکەن.
\p 
\v 55 «”ئەگەر دانیشتووانی خاکەکەش لەپێش خۆتان دەرنەکەن، ئەوا ئەوانەی دەیانهێڵنەوە دەبنە چقڵ لە چاوتان و دڕک لە کەلەکەتان و لەو خاکەی تێیدا نیشتەجێن تەنگتان پێ هەڵدەچنن،
\v 56 ئینجا بە ئێوەی دەکەم، ئەوەی بەتەمام بەوانی بکەم.“»
\c 34
\s1 سنوورەکانی کەنعان
\li4 
\v 1 هەروەها یەزدان بە موسای فەرموو:
\v 2 «فەرمان بە نەوەی ئیسرائیل بکە و پێیان بڵێ: ”کاتێک ئێوە دەچنە ناو خاکی کەنعانەوە، ئەمە ئەو خاکەیە کە دەبێتە میراتتان، خاکی کەنعان بە سنوورەکانییەوە:
\b
\li1 
\v 3 «”لەلای باشووری ئێوە لە چۆڵەوانی چنەوە لەلای ئەدۆم دەبێت، سنووری باشوورتان لە ڕۆژهەڵات لە کۆتایی دەریای مردووەوە\f + \fr 34:3 \ft عیبری: دەریای خوێ.‏\f* دەستپێدەکات.
\v 4 هەروەها سنوورەکە لە باشووری هەورازی دووپشکەوە بۆتان دەسووڕێتەوە و بەردەوام دەبێت هەتا چن و لە باشووری قادێش بەرنێعەوە هەتا حەچەر ئەدار دەچێت و تێدەپەڕێت بۆ عەچمۆن،
\v 5 لە عەچمۆنیش دەسووڕێتەوە و دەگاتە دۆڵی میسر، کۆتاییەکەی لەلای دەریای سپی ناوەڕاست\f + \fr 34:5 \ft لەلای دەریای سپی ناوەڕاستەوە: عیبری: لەلای دەریاوە.‏\f* دەبێت.
\li1 
\v 6 بەڵام سنووری ڕۆژئاوا، ئەوا دەریای سپی ناوەڕاست\f + \fr 34:6 \ft دەریای سپی ناوەڕاست: عیبری: دەریای مەزن، لێرە و لە ئایەتی 7.‏\f* دەبێت. ئەمەیە سنووری ڕۆژئاواتان.
\li1 
\v 7 بۆ دیاریکردنی سنووری باکوورتان، هێڵێک بکێشن لە دەریای سپی ناوەڕاستەوە هەتا کێوی هۆر،
\v 8 هەروەها لە کێوی هۆرەوە هەتا دەروازەی حەمات. پاشان سنوورەکە دەچێت بۆ چەداد،
\v 9 بەردەوام دەبێت بۆ زیفرۆن و کۆتاییەکەی لە حەچەر عێینان دەبێت. ئەمە دەبێتە سنووری باکوورتان.
\li1 
\v 10 هەروەها سنوور بۆ خۆتان دەکێشن بۆ ڕۆژهەڵات، لە حەچەر عێینانەوە هەتا شەفام.
\v 11 لە شەفامەوە بەرەو خوارەوە دەچێت هەتا ڕیڤلە لە ڕۆژهەڵاتی عەین. ئینجا سنوورەکە بەرەو خوارەوە دەچێت لە بناری کێوەکانی دەریاچەی جەلیل\f + \fr 34:11 \ft دەریاچەی جەلیل: عیبری: دەریای کینەرەت. بڕوانە \xt مەتا 4‏:18‏\xt*\ft ‏.‏\f* دەدات بەلای ڕۆژهەڵاتدا،
\v 12 پاشان سنوورەکە بە درێژایی کەناری ڕووباری ئوردون بەرەو خوارەوە دەچێت و کۆتاییەکەی لەلای دەریای مردوو دەبێت.
\b
\li4 «”ئەم خاکە بە سنوورەکانی و چواردەوریشییەوە بۆ ئێوە دەبێت.“»
\b
\p 
\v 13 موساش فەرمانی بە نەوەی ئیسرائیل کرد و گوتی: «ئەمە ئەو خاکەیە کە بە تیروپشک میراتگری دەکەن، کە یەزدان فەرمانی دا بە نۆ هۆز و نیوەکە بدرێت،
\v 14 چونکە هۆزی نەوەی ڕەئوبێن بەگوێرەی بنەماڵەکانیان و هۆزی نەوەی گاد بەگوێرەی بنەماڵەکانیان و نیوەی هۆزی مەنەشە میراتی خۆیان وەرگرت.
\v 15 دوو هۆز و نیوەکە میراتی خۆیان لە ڕۆژهەڵاتی ڕووباری ئوردون لەلای ئەریحا بەرەو ڕۆژهەڵات وەرگرت.»
\p 
\v 16 هەروەها یەزدان بە موسای فەرموو:
\v 17 «ئەمە ناوی ئەو دوو پیاوەیە کە خاکەکەتان بۆ دابەش دەکەن، ئەلعازاری کاهین و یەشوعی کوڕی نون،
\v 18 لە هەر هۆزێکیش ڕابەرێک دەبەن بۆ بەمیراتکردنی خاکەکە.
\b
\li4 
\v 19 «ئەمەش ناوی پیاوەکانە:
\b
\li1 «کالێبی کوڕی یەفونە لە هۆزی یەهودا؛
\li1 
\v 20 شەموئێلی کوڕی عەمیهود لە هۆزی نەوەی شیمۆن؛
\li1 
\v 21 ئەلیدادی کوڕی کیسلۆن لە هۆزی بنیامین؛
\li1 
\v 22 بوقی کوڕی یۆگلی، ڕابەر لە هۆزی نەوەی دان؛
\li1 
\v 23 حەنیێلی کوڕی ئێفۆد، ڕابەر لە هۆزی نەوەی مەنەشە، کوڕی یوسف؛
\li1 
\v 24 قەموئێلی کوڕی شیفتان، ڕابەر لە هۆزی نەوەی ئەفرایم، کوڕی یوسف؛
\li1 
\v 25 ئەلیچافانی کوڕی پەرناخ، ڕابەر لە هۆزی نەوەی زەبولون؛
\li1 
\v 26 پەلتیێلی کوڕی عەزان، ڕابەر لە هۆزی نەوەی یەساخار؛
\li1 
\v 27 ئەحیهودی کوڕی شەلۆمی، ڕابەر لە هۆزی نەوەی ئاشێر؛
\li1 
\v 28 پەدەهەئێلی کوڕی عەمیهود، ڕابەر لە هۆزی نەوەی نەفتالی.»
\b
\li4 
\v 29 ئەمانە ئەو کەسانەن کە یەزدان فەرمانی پێ کردن، هەتا میراتگیری خاکی کەنعان بۆ نەوەی ئیسرائیل دابەش بکەن.
\c 35
\s1 چەند شارۆچکەیەک بۆ لێڤییەکان
\p 
\v 1 ئینجا یەزدان لە دەشتی مۆئاب لەسەر ڕووباری ئوردون بەرامبەر ئەریحا بە موسای فەرموو:
\v 2 «فەرمان بە نەوەی ئیسرائیل بکە، با لە موڵکی میراتیان چەند شارۆچکەیەک بۆ نیشتەجێبوون و لەوەڕگاش لە چواردەوری شارۆچکەکان بە لێڤییەکان بدەن.
\v 3 ئینجا شارۆچکەکان بۆ نیشتەجێبوونیان دەبێت و لەوەڕگاکانیش بۆ گاوگۆتاڵ و هەموو مەڕوماڵاتێکی دیکەیان دەبێت.
\p 
\v 4 «ئەو لەوەڕگایانەش کە دەیدەنە لێڤییەکان، لە شوورای شارۆچکەکانەوە بەلای دەرەوە، هەزار باڵ\f + \fr 35:4 \ft هەزار باڵ: نزیکەی 450 مەتر.‏\f* بە چواردەوریدا دەبێت.
\v 5 لە دەرەوەی شار بەلای ڕۆژهەڵاتدا دوو هەزار باڵ\f + \fr 35:5 \ft دوو هەزار باڵ: نزیکەی 900 مەتر.‏\f* دەژمێرن، بەلای باشووردا دوو هەزار باڵ، بەلای ڕۆژئاوادا دوو هەزار باڵ، بەلای باکووردا دوو هەزار باڵ و شارۆچکەکەش لە ناوەڕاست دەبێت. ئەمە دەبێتە لەوەڕگای شارۆچکەکان بۆیان.
\s1 شارەکانی پەناگا
\p 
\v 6 «شەش لەو شارۆچکانەش کە بە لێڤییەکانی دەدەن دەبنە شاری پەناگا، بۆ ئەوەی هەرکەسێک کەسێکی دیکە بکوژێت بۆ ئەوێ هەڵبێت. سەرباری ئەمانەش چل و دوو شارۆچکەی دیکە دەدەنە لێڤییەکان.
\v 7 هەموو ئەو شارۆچکانەی دەیاندەنە لێڤییەکان، چل و هەشت شارۆچکەن بە لەوەڕگاکانیانەوە.
\v 8 ئەو شارۆچکانەش کە لە موڵکی نەوەی ئیسرائیل دەیدەنە لێڤییەکان، هەریەکە بەگوێرەی میراتی هەر هۆزێک. لەو هۆزانەی کە شارۆچکەیان زۆرە، زۆر وەردەگرن و لەو هۆزانەش کە کەمە، کەم وەردەگرن.»
\p 
\v 9 هەروەها یەزدان بە موسای فەرموو:
\v 10 «لەگەڵ نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”کاتێک ئێوە لە ڕووباری ئوردون دەپەڕنەوە بۆ خاکی کەنعان،
\v 11 چەند شارۆچکەیەک بۆ خۆتان دەستنیشان دەکەن و دەبنە شاری پەناگا، تاکو ئەو کەسەی کە بەبێ ئەنقەست کەسێک بکوژێت بۆ ئەوێ هەڵبێت.
\v 12 ئەو شارانە بۆتان دەبنە پەناگا لە دەست خوێنگر، بۆ ئەوەی تۆمەتبارکراو بە کوشتن، نەکوژرێت هەتا لەبەردەم ئەنجومەن دەوەستێت بۆ دادوەری.
\v 13 ئەو شەش شارۆچکانەش کە ئێوە دەیدەن دەبنە شاری پەناگا بۆتان.
\v 14 سێ لە شارۆچکەکان لەوبەری ڕووباری ئوردون دەدەن و سێ شارۆچکەش لە خاکی کەنعان دەدەن، دەبنە شاری پەناگا،
\v 15 بۆ نەوەی ئیسرائیل و نامۆ و ئەوەی لەنێویاندا نیشتەجێیە. ئەم شەش شارە بۆ پەناگا دەبن، هەتا هەرکەسێک کە بەبێ ئەنقەست کەسێک بکوژێت بۆ ئەوێ هەڵبێت.
\p 
\v 16 «”ئەگەر یەکێک بە ئامرازێکی ئاسن لە کەسێکی دا و مرد، ئەوا بە بکوژ دادەنرێت، دەبێت بکوژ بکوژرێتەوە.
\v 17 ئەگەر کەسێک بەردێکی بە دەستەوە بوو کە بکوژێت و بەو بەردە لە کەسێکی دا و مرد، ئەوا بە بکوژ دادەنرێت، دەبێت بکوژ بکوژرێتەوە.
\v 18 یان ئەگەر کەسێک هەر شتێکی لە دار دروستکراوی بە دەستەوە بوو کە بکوژێت، لە کەسێکی دیکەی دا، ئەوا بە بکوژ دادەنرێت، دەبێت بکوژ بکوژرێتەوە.
\v 19 خوێنگرەکە\f + \fr 35:19 \ft ‏خوێنگر: خوێنخوا، نزیکترین پلەی کۆمەڵایەتی کە مافی هەیە داوای تۆڵەی خوێنی بکات.‏\f* بکوژ دەکوژێت، هەر کاتێک تووشی بێت دەیکوژێتەوە.
\v 20 یان ئەگەر کەسێک بە ڕقەوە پاڵی بە کەسێکی دیکەوە نا یان بە ئەنقەست شتێکی بۆ هاویشت و مرد،
\v 21 یان ئەگەر بە دوژمنایەتییەوە بە مستەکۆڵە لێیدا و مرد، ئەوا دەستدرێژیکەر دەبێت بکوژرێتەوە، چونکە بکوژە، خوێنگرە تۆڵەسێنەرەکە هەر کاتێک تووشی بکوژ بێت دەیکوژێتەوە.
\p 
\v 22 «”بەڵام ئەگەر کەسێک لەناکاو پاڵی بە کەسێکی دیکەوە نا بەبێ دوژمنایەتی یان بەبێ ئەنقەست شتێکی بۆ هاویشت،
\v 23 یان بێ ئەوەی بیبینێت، بەردێکی گەورەی بەسەریدا بەردایەوە و مرد، ئەگەر چی دوژمنیشی نییە و خراپەی ئەوی ناوێت،
\v 24 ئەوا ئەنجومەن بەگوێرەی ئەم یاسایانە دادوەری لەنێوان تۆمەتبارکراوەکە و خوێنگرە تۆڵەسێنەرەکە دەکات.
\v 25 ئەنجومەن فریای تۆمەتبارکراوەکە دەکەوێت لە دەست خوێنگرە تۆڵەسێنەرەکە و دەیگەڕێنێتەوە بۆ ئەو شارەی پەناگا کە بۆی هەڵاتبوو. لەوێ دەمێنێتەوە هەتا سەرۆکی کاهین دەمرێت کە بە زەیتی پیرۆز دەستنیشان کراوە.
\p 
\v 26 «”بەڵام ئەگەر تۆمەتبارکراوەکە لە سنووری شاری پەناگای کە بۆی هەڵاتووە، چووە دەرەوە و
\v 27 خوێنگری تۆڵەسێنەر ئەوی لە دەرەوەی سنووری شاری پەناگا بینییەوە و خوێنگرە تۆڵەسێنەرەکە تۆمەتبارکراوەکەی کوشت، ئەوا مافی تاوانبارکردنی خوێنی نییە،
\v 28 چونکە دەبێت هەتا مردنی سەرۆکی کاهین ئەو کەسە لە شاری پەناگا بێت، بەڵام لەدوای مردنی سەرۆکی کاهین، دەگەڕێتەوە موڵکەکەی خۆی.
\p 
\v 29 «”ئەمە بۆتان دەبێتە فەرزێکی یاسایی بۆ نەوەکانتان لە هەموو نشینگەکانتان.
\p 
\v 30 «”هەرکەسێک کەسێکی دیکە بکوژێت، ئەوا لەسەر دەمی چەند شایەتێک بە بکوژ دادەنرێت و دەبێت بکوژرێتەوە، یەک شایەت بەس نییە بۆ شایەتیدان لەسەر کەسێک بۆ مردن.
\p 
\v 31 «”خوێنبایی وەرمەگرە بۆ بکوژێک کە شایانی سزای مردنە، بەڵکو دەبێت بکوژرێتەوە.
\p 
\v 32 «”هەروەها خوێنبایی وەرمەگرن بۆ ئەو کەسەی بۆ شاری پەناگا هەڵبێت، تاوەکو پێش مردنی سەرۆکی کاهین بگەڕێتەوە و لە زەوی خۆی نیشتەجێ بێت.
\p 
\v 33 «”ئەو خاکەی ئێوە تێیدان گڵاوی مەکەن، چونکە خوێن خاک گڵاو دەکات، هیچ شتێک کەفارەتی ئەو خوێنە ناکات کە لە خاکەکە ڕژاوە، تەنها خوێنی خوێنڕێژەکە نەبێت.
\v 34 کەواتە ئەو خاکەی کە ئێوە تێیدا نیشتەجێن و من لە ناوەڕاستیدا نیشتەجێم گڵاوی مەکەن، چونکە من کە یەزدانم لەنێو نەوەی ئیسرائیلدا نیشتەجێم.“»
\c 36
\s1 میراتەکەی کچانی سەلۆفحاد
\p 
\v 1 گەورەی بنەماڵەکانی خێڵی نەوەی گلعادی کوڕی ماکیر کوڕی مەنەشە کە لە خێڵەکانی نەوەی یوسفن، هاتنە پێش و لەبەردەم موسا و بەردەم گەورەی بنەماڵەکانی نەوەی ئیسرائیل دوان و
\v 2 گوتیان: «کاتێک یەزدان فەرمانی بە گەورەم کرد، کە خاکەکە بە میرات بە تیروپشک بداتە نەوەی ئیسرائیل، هەروەها فەرمانی پێ کردیت کە میراتەکەی سەلۆفحادی برامان بدەیتە کچەکانی.
\v 3 جا ئەگەر گریمان بوونە ژنی پیاوێک لە هۆزەکانی نەوەی ئیسرائیل، ئەوا میراتەکەیان لە میراتی باوکانمان دەبردرێت و دەخرێتە سەر میراتی ئەو هۆزە کە بۆ ئەوان بوون، جا بەشێک لە تیروپشکی میراتەکەمان دەبردرێت.
\v 4 کاتێک بووە ساڵی یۆبیل\f + \fr 36:4 \ft ساڵی یۆبیل: یۆبیل وشەیەکی عیبرییە بە واتای بەران دێت، ساڵی یۆبیل ساڵی ئازادکردنی کۆیلە و لێخۆشبوونە لە قەرز، لەو ساڵەدا کە فوو بە قۆچی بەران دەکەن وەک کەڕەنا ئیتر ئەوە ڕاگەیاندنە بۆ گەڕانەوەی هەموو ماڵوموڵکێک بۆ خاوەنەکەی خۆی. بڕوانە \xt لێڤییەکان 25‏:8‏-55.‏\xt*\ft ‏\f* بۆ نەوەی ئیسرائیل، ئەوا میراتەکەیان دەچێتە سەر میراتی ئەو هۆزەی کە بۆیان بوون و لە میراتی هۆزی باوکانمان میراتیان دەبردرێت.»
\p 
\v 5 جا موسا بەگوێرەی فەرمایشتی یەزدان فەرمانی بە نەوەی ئیسرائیل کرد و گوتی: «هۆزی نەوەی یوسف ڕاستیان گوت.
\v 6 یەزدان فەرمانی ئەمەی کرد سەبارەت بە کچانی سەلۆفحاد و فەرمووی، ئەوەی ئەوان پێیان خۆشە با شووی پێ بکەن، بە مەرجێک لە خێڵی هۆزی باوکانیان بێت.
\v 7 میراتی نەوەی ئیسرائیل لە هۆزێکەوە بۆ هۆزێکی دیکە ناگوازرێتەوە، بەڵکو نەوەی ئیسرائیل هەریەکە پابەندی میراتی هۆزی باوکانی دەبێت.
\v 8 هەر کچێکیش لە هۆزەکانی نەوەی ئیسرائیل میراتی وەرگرت، ئەوا دەبێتە ژنی یەکێک لە خێڵی هۆزی باوکی، هەتا نەوەی ئیسرائیل هەریەکە ببێتە میراتگری میراتی باوکانی.
\v 9 هیچ میراتێک لە هۆزێکەوە بۆ هۆزێکی دیکە ناگوازرێتەوە، بەڵکو هۆزەکانی نەوەی ئیسرائیل هەریەکە پابەندی میراتی خۆی دەبێت.»
\p 
\v 10 وەک یەزدان فەرمانی بە موسا کرد، کچانی سەلۆفحاد ئاوایان کرد.
\v 11 مەحلە و تیرزە و حۆگلە و میلکە و نۆعا کە کچانی سەلۆفحادن بوونە ژنی ئامۆزاکانیان؛
\v 12 بوونە ژن لە خێڵەکانی نەوەی مەنەشەی کوڕی یوسف، ئیتر میراتەکەیان لە خێڵ و هۆزی باوکانیان مایەوە.
\b
\p 
\v 13 ئەمە ئەو فەرمان و ڕێسایانەیە کە یەزدان فەرمانی بە نەوەی ئیسرائیل کرد، بە دەستی موسا لە دەشتی مۆئاب لەسەر ڕووباری ئوردون بەرامبەر ئەریحا.
