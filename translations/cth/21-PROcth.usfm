\id PRO - Baibal Kathoung New Testament 
\h CINGTHUILAWKNAW 
\toc1 CINGTHUILAWKNAW 
\toc2 Cingthuilawknaw 
\toc3 Ctl 
\mt1 CINGTHUILAWKNAW  
\c 1  
\s1 Lungang kamtawngnae  
\p
\v 1 Isarel siangpahrang, Devit capa Solomon e cingthuilawknaw:   
\q1
\v 2 Lungangnae hoi cangkhainae panue hane hoi  
\q2 thaipanuenae lawk hah thaipanuek hane hoi,   
\q1
\v 3 lungangnae, lannae, lawkcengnae hoi lannae koelah  
\q2 cangkhainae pang hane hoi,   
\q1
\v 4 kamawngrame kâhruetcuet poe hane hoi,  
\q2 thoundounnaw ni panuenae hoi poukthainae a tawn awh nahanlah,   
\q1
\v 5 tami lungkaang ni a thai navah lungang a kâthap vaiteh,  
\q2 thaipanueknae ka tawn e ni lamthung patue thainae a hmu han.   
\q1
\v 6 Cingthuilawk hoi bangnuenae,  
\q2 lungangnae hoi kâpâvêinae naw thaipanuek nahanlah,   
\q1
\v 7 BAWIPA takinae teh panuenae kamtawngnae doeh.  
\q2 Hatei, tamipathunaw ni teh lungangnae hoi cingthuinae hah a dudam awh.   
\s1 Kahawihoeh e khokhannae hah roun haw  
\q1
\v 8 Ka capa, na pa e pâtunae hah thai nateh,  
\q2 na manu e kâlawk hai pahnawt hanh.   
\q1
\v 9 Hothateh na lû dawk kamthoupnae sammuem lah awm vaiteh,  
\q2 na lahuen dawk awi e dingyin lah ao han.   
\q1
\v 10 Ka capa, tamikayonnaw ni na pasawt pawiteh,  
\q2 ngai pouh hanh.   
\q1
\v 11 Kai koe tho van haw, tami thei hanelah pawm sei.  
\q2 A khuekhaw awm laipalah yonnae ka tawn hoeh naw hah  
\q2 arulahoi pawm awh sei.   
\q1
\v 12 Sheol patetlah a hring lahoi payawp awh vaiteh,  
\q2 kadungpoung e tangkom dawk ka bawt e patetlah,   
\q1
\v 13 Aphu kaawm e hno pueng la awh vaiteh,  
\q2 lawphno hoi mamae im dawk kawi sak awh sei.   
\q1
\v 14 Kaimouh koe kambawng van leih,  
\q2 maimae tangkabom suekâvan sak awh sei ati awh nakunghai,   
\q1
\v 15 ka capa, ahnimouh koe kambawng hanh.  
\q2 Ahnimae lamthung hah roun hanelah kâyawmh.   
\q1
\v 16 Ahnimae khok teh yonnae koe lah a yawng teh,  
\q2 tami thei hanelah a hue a rang awh.   
\q1
\v 17 Bangpatet e tava nakunghai  
\q2 a hmunae koe tamlawk yangda pawiteh, ayawm doeh.   
\q1
\v 18 Hatei, ahnimouh teh amamouh hoi  
\q2 amamouh kâthei hanlah a kâpawp awh teh,  
\q2 amamae hringnae arulahoi ka pawm e lah doeh ao awh.   
\q1
\v 19 Hot patetlah, kamsoumhoehe pungdawnae koe lah  
\q2 kahounlounnaw e hringnae teh, katawnkung hringnae hah a thei awh.   
\s1 Lungang hanelah kawnae  
\q1
\v 20 Lungangnae ni a lawi lahoi kacaipounglah a kaw teh,  
\q2 lam tangkuem dawk lawk ceiceikapanglah a oung.   
\q1
\v 21 Tami kamkhuengnae koe a oung teh,  
\q2 khopui kâennae longkha koe lawk a dei.   
\q1
\v 22 Nangmouh kamawngramenaw,  
\q2 nâtotouh maw cungkeihoehe kamawngrame hah  
\q2 na lungpataw awh han rah.  
\q2 Kadudamnaw ni, dudamnae dawk a nawm awh teh,  
\q2 tamipathunaw ni panuethainae hah a hmuhma awh.   
\q1
\v 23 Kaie yuenae koe kamlang awh,  
\q2 nangmae thung ka muitha ka awi vaiteh,  
\q2 ka lawk hah na panue sak han.   
\q1
\v 24 Na kaw awh ei, na ngai awh hoeh.  
\q2 Ka kut ka dâw ei, apinihai banglah na pouk awh hoeh.   
\q1
\v 25 Kâhruetcuet na poe awh e puenghai na hnoun awh teh,  
\q2 na yuenae puenghai buet touh boehai bout na tarawi awh hoeh.   
\q1
\v 26 Hatdawkvah, yawthoenae na kâhmo awh toteh,  
\q2 na panuikhai vaiteh, lungpuennae na kâhmo awh to hai na panuikhai awh han.   
\q1
\v 27 Takinae kahlî kathout ni na kanawi awh teh,  
\q2 bongparui ni na parit awh toteh,  
\q2 kângairu temdengnae a tho toteh, na panuikhai han.   
\q1
\v 28 Hatnavah, na kaw awh han, hatei, na pato awh mahoeh.  
\q2 Atangcalah na tawng awh han, hatei, na hmawt awh mahoeh.   
\q1
\v 29 Panuethainae hah a hmuhma awh teh,  
\q2 BAWIPA taki hane hah na kârawi awh hoeh.   
\q1
\v 30 Pouknae ka poe e hah ngai awh hoeh,  
\q2 ka yuenae puenghai banglah noutna awh hoeh.   
\q1
\v 31 Hatdawkvah, a hringnuen pawhik hah amamouh ni a ca awh han.  
\q2 A khopouk awh e ni letlang a paha sak han.   
\q1
\v 32 Bangkongtetpawiteh, kamawngrame ni a phen saknae ni a thei awh vaiteh,  
\q2 lawlulawlei ka panuek laipalah, a onae ni a raphoe awh han.   
\q1
\v 33 Hatei, ka lawk ka tarawi e teh,  
\q2 karoumcalah kho a sak han.  
\q2 Thoenae taket laipalah karoumcalah ao awh han.   
\c 2  
\s1 Lungang a sungrennae  
\q1
\v 1 Ka capa, ka lawk hah ngâi nateh,  
\q2 kaie kâpoelawknaw e hah na lungthung vah na pâkuem pawiteh,   
\q1
\v 2 Lungangnae koe lah na hnâpakeng nateh,  
\q2 na thai panuek nahanelah na lungthin na poe pawiteh,   
\q1
\v 3 Kapek thai nahanelah na kaw teh,  
\q2 thaipanueknae tawn hanelah na hram pawiteh,   
\q1
\v 4 ngun patetlah na tawng teh,  
\q2 hro e hno patetlah na tawng pawiteh,   
\q1
\v 5 BAWIPA takinae na panue vaiteh,  
\q2 Cathut panuenae hah na hmu han.   
\q1
\v 6 Bangkongtetpawiteh, BAWIPA ni lungangnae a poe teh,  
\q2 a pahni hoi panuenae hoi thaipanueknae hah ouk a tâco sak.   
\q1
\v 7 Tamikalannaw hanelah lungangnae  
\q2 katang hah a pâkhueng pouh teh,  
\q2 kalan lah kacetnaw hanelah bahling lah ao.   
\q1
\v 8 Kângingnae lam hah a ring teh,  
\q2 a tamikathoungnaw e lamthung hah a ngue pouh.   
\q1
\v 9 Hottelahoi, kângingnae hoi lannae na thaipanuek vaiteh,  
\q2 ngaima tawnhoehnae hoi kahawi e lamthung hai na panue han.   
\q1
\v 10 Na lungthin dawk lungangnae a kâen toteh,  
\q2 panuenae teh, na hringnae kanawm sakkung lah ao han.   
\q1
\v 11 Poukpanueknae ni na ngue vaiteh,  
\q2 thaipanueknae ni na ring han.   
\q1
\v 12 Tamikathoutnaw e lamthung dawk hoi na rungngang han.  
\q2 Lawk longkawi lah ka dei e,   
\q1
\v 13 Lannae lamthung ka pahnawt niteh,  
\q2 hmonae lamthung dawn hanelah ka cet e,   
\q1
\v 14 thoenae saknae dawk lungkahawi e,  
\q2 tamikathout lanhoehnae dawk a lungkahawi e,   
\q1
\v 15 Lam longkawi ka dawn niteh,  
\q2 a lamthung dawk yuemkamcu hoeh e,   
\q1
\v 16 Kahlong lae napui hoi  
\q2 pasawtpanep lawk ka hno e,   
\q1
\v 17 A naw nah hui ka cettakhai niteh,  
\q2 a Cathut lawkkam kapahnimnaw koehoi  
\q2 nang hah na rungngang han.   
\q1
\v 18 Bangkongtetpawiteh, ahnie im ni duenae koe lah a hrawi teh,  
\q2 ahnie lam ni tamikadoutnaw koelah a pâtam.   
\q1
\v 19 Ahni koe kacetnaw teh ban boihoeh toe.  
\q2 Hringnae lam hah dawn boi awh hoeh toe.   
\q1
\v 20 Nang teh tamikahawinaw e lamthung na dawn vaiteh,  
\q2 lannae lamthung pou na dawn thai nahane doeh.   
\q1
\v 21 Bangkongtetpawiteh, tamikalan teh ram dawk kho a sak vaiteh,  
\q2 tami kakuep teh hawvah pou ao han.   
\q1
\v 22 Hatei, tamikathout teh talai van hoi takhoe lah awm vaiteh,  
\q2 yuemkamcu hoeh naw hah phawk lah ao awh han.   
\c 3  
\s1 Nawsainaw hanelah lamthung hmusaknae  
\q1
\v 1 Ka capa, kaie kâlawk hah pahnim hanh.  
\q2 Kaie kâpoelawknaw hah na lung dawk pâkuemh.   
\q1
\v 2 Bangkongtetpawiteh, hote ni na hringsawnae hoi  
\q2 roumnae na thap sin han.   
\q1
\v 3 Lungmanae hoi lawkkatang ni na cettakhai hanh naseh.  
\q2 Na lahuen dawk awi nateh, na lungthin dawkvah thut haw.   
\q1
\v 4 Hottelah Cathut hoi tami hmalah,  
\q2 minhmai kahawi na hmu vaiteh, tawmrasang lah na o han.   
\q1
\v 5 Na lungthin buem hoi BAWIPA kâuep nateh,  
\q2 nama e thaipanueknae hah kângue hanh.   
\q1
\v 6 Na lamthung pueng dawk ama na panuek haw,  
\q2 na lamthung pueng dawk na hrawi han.   
\q1
\v 7 Namahoima lungkaang lah kâsak hanh.  
\q2 BAWIPA hah taket nateh yon cettakhaih.   
\q1
\v 8 Na takthai hanelah damnae lah ao vaiteh,  
\q2 na hru hanelah thasainae lah ao han.   
\q1
\v 9 Na tawnta e naw hoi aluepawnaw hoi  
\q2 BAWIPA hah bari haw.   
\q1
\v 10 Hahoi na capai dawk a kawi vaiteh,  
\q2 misur katinnae tangkom dawk misur katha hoi a kawi han.   
\q1
\v 11 Ka capa, BAWIPA yuenae hah dudam hanh.  
\q2 Na phep e hai hmuhma hanh.   
\q1
\v 12 Bangkongtetpawiteh, na pa ni a lungpataw e capa teh  
\q2 ouk a yue e patetlah,  
\q2 BAWIPA ni a lungpataw e naw hah ouk a yue.   
\q1
\v 13 Lungmanae kahmawtnaw teh a lung kahawi e tami lah ao awh teh,  
\q2 Thaipanueknae ka tawn e tami hai a lung kahawi e tami lah ao.   
\q1
\v 14 Bangkongtetpawiteh, ngun pungdaw sak e hlak,  
\q2 lungmanae pungdaw sak e hah ahawihnawn.   
\q1
\v 15 Talungpaling hlak hai aphu ao teh,  
\q2 na ngai e pueng ni hai phat hoeh rah.   
\q1
\v 16 Aranglae kut dawk hringsawnae ao teh,  
\q2 avoilah e kut dawk hnopai hoi barinae ao.   
\q1
\v 17 A lamthung teh lamthung kanawm lah ao teh,  
\q2 a lamthung pueng teh roumnae lah ao awh.   
\q1
\v 18 Kakuennaw hanelah hringnae thingkung lah ao teh,  
\q2 ka hringkhaie pueng teh tami lung kahawi e lah ao awh.   
\q1
\v 19 BAWIPA ni lungangnae lahoi talai hah a kangdue sak teh,  
\q2 thaipanueknae lahoi kalvan a cak sak.   
\q1
\v 20 A panuenae lahoi talî a kapek teh,  
\q2 tâmai ni tadamtui a bo sak.   
\q1
\v 21 Ka capa, lungangnae katang hoi  
\q2 panuethainae hah kuen nateh,  
\q2 na mit hoi kâhlat sak hanh.   
\q1
\v 22 Hottelah pawiteh, na muitha hanelah hringnae lah awm vaiteh,  
\q2 na lahuen hanelah pahrennae lah ao han.   
\q1
\v 23 Hottelah na lamthung dawk karoumcalah na cet vaiteh,  
\q2 na khok na kamthui mahoeh.   
\q1
\v 24 Na i navah na taket mahoeh,  
\q2 ihmu katuilah na i han.   
\q1
\v 25 Taki ka tho e kaluekalapnae hai taket hanh.  
\q2 Hoehpawiteh, tamikathoutnaw ni  
\q2 a kâhmo awh e runae hai taket hanh.   
\q1
\v 26 Bangkongtetpawiteh, BAWIPA teh na kânguenae lah awm vaiteh,  
\q2 na khok teh karap dawk hoi a hlout sak han.   
\q1
\v 27 Sak nahane kâ na kut dawk ao nahlangva,  
\q2 hmu hanelah kakamcunaw hah  
\q2 hnokahawi pasoung laipalah awm hanh.   
\q1
\v 28 Poe hane na sin nahlangva, cet ei, bout tho lah a,  
\q2 tangtho torei na poe han, telah na imri koe tet pouh hanh.   
\q1
\v 29 Na imri taranlahoi thoenae sak hanelah kâcai hanh.  
\q2 Bangkongtetpawiteh, nang na ka ring e doeh.   
\q1
\v 30 Nang dawk patawnae na poe hoeh pawiteh,  
\q2 a khuekhaw awm laipalah tami taran hanh.   
\q1
\v 31 Tami rep kacoungroenaw e hnopai noe awh hanh.  
\q2 Ahnimae lamthung hai rawi awh hanh.   
\q1
\v 32 Bangkongtetpawiteh, a lungthin ka longkawi e teh  
\q2 BAWIPA hanelah panuet a tho teh, a lungthin kalan e teh,  
\q2 ama hoi arulahoi kâponae ao.   
\q1
\v 33 Tamikathoutnaw e im dawk,  
\q2 BAWIPA thoebonae ao, hatei,  
\q2 tamikalannaw e im teh, yawhawi a poe.   
\q1
\v 34 Dudam lahoi kaawmnaw hah a dudam teh,  
\q2 ka kârahnoumnaw hah pahrennae a poe.   
\q1
\v 35 Tami lungkaang ni bawilennae râw a coe han.  
\q2 Hatei, tamipathunaw ni a coe awh e râw teh, kayanae doeh.   
\c 4  
\s1 Lungangnae dawk kânguenae  
\q1
\v 1 Ka canaw, na pa ni na cangkhainae hah thai awh nateh,  
\q2 thaipanueknae hah panue hanelah na hnâpakeng awh.   
\q1
\v 2 Bangkongtetpawiteh, cangkhainae kahawi hah na poe dawkvah,  
\q2 kaie kâlawk hah cettakhai hanh.   
\q1
\v 3 Apa e capa lah ka o navah, anu e capa a pahren e  
\q2 tawntoe e capa lah ka o.   
\q1
\v 4 Pâtu hai na pâtu teh, na lungthin hoi ka lawknaw hah pâkuem haw.  
\q2 Kaie kâpoelawknaw hah tarawi nateh hring haw.   
\q1
\v 5 Lungangnae hah tawn nateh, thaipanueknae hah tawn haw.  
\q2 Ka pahni dawk hoi ka tâcawt e lawknaw hah pahnim laipalah,  
\q2 kamlang takhai hanh.   
\q1
\v 6 Cettakhai hanh, na ring nakaima.  
\q2 Lungpataw haw na ngue han kaima.   
\q1
\v 7 Lungangnae teh a lawkpui poung doeh.   
\q1
\v 8 Talue sak haw, na tawmrasang han.  
\q2 Tapam haw, barinae koe na ceikhai han.   
\q1
\v 9 Na lû dawk lungmanae na kâmuk sak han,  
\q2 bawilennae bawilakhung hah na kâmuk sak han.   
\q1
\v 10 Ka capa, ka dei e hah thai nateh, dâw haw.  
\q2 Na hringyung a saw sak han.   
\q1
\v 11 Lungangnae lamthung na cangkhai teh,  
\q2 lamkalan dawk na hrawi.   
\q1
\v 12 Na cei navah, na khok hanelah kamthuinae awm mahoeh,  
\q2 na yawng navah na tâlaw mahoeh.   
\q1
\v 13 Na cangkhainae hah kacaklah kuen nateh,  
\q2 tha laipalah pou kuen haw.  
\q2 Bangkongtetpawiteh, na hringnae doeh.   
\q1
\v 14 Tamikathoutnaw e lamthung dawk kâen awh hanh.  
\q2 Tami kahawihoehnaw e lamthung dawn hanh.   
\q1
\v 15 Roun nateh, khoeroe dawn hanh,  
\q2 kamlang takhai nateh, cettakhaih.   
\q1
\v 16 Bangkongtetpawiteh, hno kathout sak hoeh pawiteh,  
\q2 ip thai awh hoeh niteh,  
\q2 tami buetbuet touh tâlaw sak hoehpawiteh,  
\q2 ihmu tho awh hoeh.   
\q1
\v 17 Bangkongtetpawiteh, thoenae vaiyei hah a ca awh teh,  
\q2 rektapnae yamu hah a nei awh.   
\q1
\v 18 Hatei, tamikalannaw e lamthung teh,  
\q2 kanî raeng, kanî tuengtalueng a thunnae kanî ang patetlah ao.   
\q1
\v 19 Tamikathoutnaw e lamthung teh khohmo patetlah ao teh,  
\q2 tâlawnae akungcing hai panuek awh hoeh.   
\q1
\v 20 Ka capa, ka lawk kahawicalah thai haw,  
\q2 ka dei e hah atangcalah pouk.   
\q1
\v 21 Na mit hoi kâhlat sak hanh,  
\q2 na lungthin dawk pâkuemh.   
\q1
\v 22 Bangkongtetpawiteh, kahmawtnaw hanelah hringnae lah ao teh,  
\q2 a takthai abuemlah hanelah damnae lah ao.   
\q1
\v 23 Hno pueng hlak hoi na lungthin hah kahawicalah ring haw.  
\q2 Bangkongtetpawiteh, hringnae akungtuen lah ao.   
\q1
\v 24 Dumyennae pahni hah pahnawt nateh,  
\q2 payonnae pahni hah ahlanae koe takhoe haw.   
\q1
\v 25 Na mit hoi hmalah kalan lah khen nateh,  
\q2 na hmalah kalan lah radoung haw.   
\q1
\v 26 Na lamthung hah hmaloe rip nateh,  
\q2 na lamthung pueng hah cak sak.   
\q1
\v 27 Aranglah nakunghai, avoilah nakunghai phen hanh.  
\q2 Thoenae lamthung hah roun haw.   
\c 5  
\s1 Dumnae hah roun haw  
\q1
\v 1 Ka capa, poukpanueknae na tawn nahane hoi,  
\q2 na pahni ni panuenae a pâkuem thai nahanelah,   
\q1
\v 2 kaie lungangnae hah thai nateh,  
\q2 kaie thaipanueknae dawk na hnâpakeng haw.   
\q1
\v 3 Bangkongtetpawiteh, napui kathoutnaw e pahni teh,  
\q2 khoitui patetlah a radip, a lawk teh sathaw hlak hai a pâhnan.   
\q1
\v 4 Hatei, apoutnae koe lateh, hmue patetlah a kha teh,  
\q2 avoivang kahran e sarai patetlah a hran.   
\q1
\v 5 A khok ni duenae lamthung a pâtam teh,  
\q2 a khok takan ni sheol hmai a pâtam.   
\q1
\v 6 Hoehpawiteh, a hringnae lamthung na pouk hoeh vaiteh,  
\q2 a lamthung a cak hoeh e hah na panuek mahoeh.   
\q1
\v 7 Hatdawkvah, ka canaw, atuvah, ka lawk thai awh haw.  
\q2 Ka dei e lawknaw hah pahnawt awh hanh.   
\q1
\v 8 Hatei, ahlanae koe kampuen awh nateh,  
\q2 ahnie im takhang hoi hai hnai awh hanh.   
\q1
\v 9 Hoehpawiteh, barinae na hmu e hah  
\q2 ayâ alouk koe kampuen payon vaih.  
\q2 Tami nuen kamathoutnaw rahak vah,  
\q2 na hringnae be na hno payon vaih.   
\q1
\v 10 Hoehpawiteh, ramlouknaw ni  
\q2 na tawntanae dawk nawm awh vaiteh,  
\q2 na thaw tawk e a pawnaw hah  
\q2 ramlouknaw im vah phat payon vaih.   
\q1
\v 11 Apoutnae koe lah, na takthai a kamsoe toteh,  
\q2 na khui payon vaih.   
\q1
\v 12 Bangtelamaw, cangkhainae hah koe ka hmuhma teh,  
\q2 yuenae hah ka lungthin hoi koe ka dudam toe.   
\q1
\v 13 Na kacangkhaikung e lawk hah koe ka tarawi ngaihoeh niteh,  
\q2 na cangkhainae hah koe ka thai ngaihoeh heh ma.   
\q1
\v 14 Tamimaya hoi kamkhuengnaw koe  
\q2 rawknae kâhmo hoeh e dueng doeh hei na ti han na kaima.   
\q1
\v 15 Nange tuikhu, na tuikhu hoi  
\q2 ka tâcawt e tui roeroe hah na nei han.   
\q1
\v 16 Na tuiphuek hah ram tangkuem lawng vaiteh  
\q2 tamimaya ceinae lamnaw dawk a lawng han na maw.   
\q1
\v 17 Nama hanelah dueng awm seh,  
\q2 ayâ alouke hoi kâkabawpkhai hane nahoeh.   
\q1
\v 18 Na tuikhu teh yawhawi seh,  
\q2 na naw nah e na yu koe na lungkuep lawih.   
\q1
\v 19 Ngai kaawm e sayuk hoi a meikahawi e sayukhre patetlah,  
\q2 a sannunaw ni na lungkuep sak naseh.  
\q2 A lungpatawnae ni na lungkuep sak naseh.   
\q1
\v 20 Bangtelamaw, ka capa nang ni napui kahawihoehe hah  
\q2 na ngai vaiteh, khuet na tapam han vaw.   
\q1
\v 21 Bangkongtetpawiteh, tami hringnae lamthungnaw teh,  
\q2 BAWIPA ni koung a hmu teh,  
\q2 a lamthung pueng koung a pouk pouh.   
\q1
\v 22 Ama pouknae ni tamikayon teh a man vaiteh,  
\q2 a yonnae tangron hoi pâkhi lah ao han.   
\q1
\v 23 Cangkhainae a vout dawkvah, a due vaiteh,  
\q2 puenghoi a pathu dawkvah, a kahma han.   
\c 6  
\s1 Lawkkam e taki a tho  
\q1
\v 1 Ka capa, na hui hanelah lawk na kam teh,  
\q2 ayâ alouk hoi na kut na tambei pawiteh,   
\q1
\v 2 na dei e lawk dawk letlang na kâman toe.  
\q2 Na dei e lawk hoi la lah na o toe.   
\q1
\v 3 Hatnavah, ka capa, hettelah namahoima na kârungngang han.  
\q2 Bangtelamaw na hui kut dawk na pha toung dawkvah,  
\q2 kârahnoumnae lahoi cet nateh, kâhet lah a.   
\q1
\v 4 Ip hanh, ngam takhai hanh.   
\q1
\v 5 Moi ka me e koehoi sakhi ni a yawng takhai e patetlah,  
\q2 yawng takhai haw, tangkam dawk hoi  
\q2 kahlout e tava patetlah kamleng takhai haw.   
\q1
\v 6 Nange tami ka pangak, lungkhi koe cet nateh,  
\q2 a oangnae lahoi lungangnae kamtu haw.   
\q1
\v 7 Ahnimouh teh, kahrawikung, karipkung,  
\q2 kaukkung, tawn awh hoeh eiteh,   
\q1
\v 8 kawmpoi vah rawca a pâtung awh teh,  
\q2 canga tue nah rawca a pâtung awh.   
\q1
\v 9 Oe, tami ka pangak, nâtotouh maw na i han.  
\q2 Nâtuek maw na kâhlaw han.   
\q1
\v 10 Ka ip ei haw pawiteh, dongdeng ka yan ei haw pawiteh,  
\q2 kut kâtapam hoi dongdeng kâhat ei haw pawiteh, na ti lahun nah,   
\q1
\v 11 mathoenae ni karum kâva e patetlah vaitalahoi na tho sin vaiteh,  
\q2 voutthoupnae ni kutdaw patetlah na tho sin han.   
\q1
\v 12 Tami cungkeihoeh e, tami kahawihoehe teh,  
\q2 tamthoe hoi a kâhlai.   
\q1
\v 13 A mit a kaluek teh, a khok hoi mitnout a poe teh,  
\q2 a kutdawn hoi a takhi teh a pâtu.   
\q1
\v 14 A lungpouk a longkawi teh, pout laipalah,  
\q2 hawihoehnae dueng a pouk teh, kâyuenae cati doeh ouk a tu.   
\q1
\v 15 Hatdawkvah, kahmakatanae ni vaitalahoi a tho sin han.  
\q2 Vaitalahoi damthaihoehnae kahmakatanae a kâhmo han.   
\q1
\v 16 Hete hno taruk touh heh, BAWIPA ni a hmuhma.  
\q2 Bokheiyah, a panuet e hno sari touh a pha.   
\q1
\v 17 Kâoupnae mit, laithoe ka deinae lai,  
\q2 yon ka tawn hoeh e tami theinae kut,   
\q1
\v 18 Hawihoehnae meng ka pouk e lungthin,  
\q2 kahawihoehe sak nahanelah a hue ka rang e khok,   
\q1
\v 19 Laithoe ouk ka dei e kapanuekkhaikung kaphawk hoi,  
\q2 hmaunawngha rahak kâpohoehnae cati ka patuekungnaw doeh .   
\s1 Uicuknae kâhruetcuet poenae  
\q1
\v 20 Ka capa, na pa e kâpoelawk hah tarawi nateh,  
\q2 na manu e kâlawk hah cettakhai hanh.   
\q1
\v 21 Na lungthung pâkuem nateh,  
\q2 na lahuen dawk awi haw.   
\q1
\v 22 Alouklah na cei toteh, hote kâlawk ni na hrawi han,  
\q2 na i navah na ring vaiteh, na kâhlaw toteh, na pato han.   
\q1
\v 23 Bangtelah tetpawiteh, kâpoe e teh,  
\q2 hmaiim lah ao teh, kâlawk teh angnae lah ao.  
\q2 Cingthuilasak e teh hringnae lamthung doeh.   
\q1
\v 24 Napui kathout hoi pasawtpanepnae koehoi  
\q2 na hlout sak han.   
\q1
\v 25 Na lungthin hoi a meihawinae nôe hanh lah a,  
\q2 a mit padainae ni na man hanh naseh.   
\q1
\v 26 Bangkongtetpawiteh, kâyawt e napui kecu dawk,  
\q2 tongpatang heh vaiyei tangen lah a coung teh,  
\q2 ayâ yu ka yonkhai e ni, ka sungren e a hringnae hah a raphoe.   
\q1
\v 27 Tami ni a kho e angki kang laipalah  
\q2 hmaisaan a yawm thai han na maw.   
\q1
\v 28 Tami ni a khok kang laipalah,  
\q2 hmaisaan van a cei thai han na maw.   
\q1
\v 29 Hot patetvanlah, a imri yu ka ipkhai e tami hai hot patetlah doeh ao.  
\q2 Ayâ yu ka ipkhai e tami teh, yonnae hoi hlout hoeh.   
\q1
\v 30 A vonhlam dawk tami ni parawt pawiteh,  
\q2 hote tamru teh tami ni pacekpahlek hoeh.   
\q1
\v 31 Hmu lah awm pawiteh, let sari touh hoi a patho roeroe hanelah ao.  
\q2 A im dawk kaawm e hno pueng a rawng hanelah ao.   
\q1
\v 32 Ayâ yu hoi ka uicuk e tami pueng teh,  
\q2 panuenae ka tawn hoeh e tami doeh.  
\q2 Ama hringnae ka raphoekung lah ao.   
\q1
\v 33 Hmâtan cat vaiteh, min mathoe a kâhmo han.  
\q2 A kayanae teh roum thai mahoeh.   
\q1
\v 34 Bangkongtetpawiteh, dipmanae ni  
\q2 vanaw puenghoi a lung ouk a khuek sak.  
\q2 Moipathungnae hnin navah hlout thai mahoeh   
\q1
\v 35 Rawng e hno nâyittouh hai banglah noutna mahoeh.  
\q2 Hno moikapap ka poe nakunghai a lung roum sak thai mahoeh.   
\c 7  
\q1
\v 1 Ka capa, ka lawk hah hringkhai nateh,  
\q2 kaie kâpoelawknaw hah na thung vah pâkuem haw.   
\q1
\v 2 Kaie kâpoelawk hah, pâkuem nateh, hringkhai haw.  
\q2 Hahoi, Kaie kâpoelawknaw hah na mitmu patetlah ring haw.   
\q1
\v 3 Na kutdawnnaw dawk pâkhit nateh,  
\q2 na lungthin dawkvah thut haw.   
\q1
\v 4 Lungangnae koevah, ka tawncanu lah na o tet nateh,  
\q2 thaipanueknae hah na tawncanu patetlah pouk haw.   
\q1
\v 5 Het niyah napui kahawihoehnaw koehoi na hlout sak vaiteh,  
\q2 lawk radip lawk pâhnan naw koehoi na ring han.   
\s1 Ka kâyawtnaw huengonae  
\q1
\v 6 Kama im e hlalangaw dawk hoi ka khet boteh,   
\q1
\v 7 Kamawngrame thung dawk,  
\q2 nawsai buet touh hah tanglanaw rahak vah ka hmu.   
\q1
\v 8 Hote napui aonae lamtakin koe a pha awh toteh,  
\q2 ahni im lah ceinae lamtalawi hah a dawn.   
\q1
\v 9 Tangmin karumsaning a pha toteh,   
\q1
\v 10 hawvah, hak kamthoup niteh,  
\q2 ka kâyawt e napui ni a kâhmo.   
\q1
\v 11 Hote napui teh a im vah duem kaawm thai hoeh e,  
\q2 a lungkatang e lah ao.   
\q1
\v 12 Lamthung hoi lam takin koe ao teh  
\q2 tamipueng hah ouk a pawp.   
\q1
\v 13 A takawi teh, tang a paco  
\q2 Lungpuennae awm laipalah, hettelah a dei.   
\q1
\v 14 Roum thueng hane ka tawn.  
\q2 Sahnin ka lawkkam ka kuep sak han.   
\q1
\v 15 Hatdawkvah nang dawn hanelah ka tho.  
\q2 Na tawng teh na kâhmo toe.   
\q1
\v 16 Ka ikhun dawk a meikahawi poung e hni  
\q2 Izip lukkarei a em kaawm e sut ka phai toe.   
\q1
\v 17 Ka ikhun teh, murah hoi aloe,  
\q2 nakzik hmuitui hoi ka pathoup toe.   
\q1
\v 18 Tho haw, khodai totouh, lungpatawnae lahoi  
\q2 phaibongcito roi sei.   
\q1
\v 19 Bangkongtetpawiteh, ka vâ teh im vah awm hoeh.  
\q2 Tangkabom a sin teh, kho hlanae koe kahlawng yo a cei toe.   
\q1
\v 20 Thapa a kamhluem to doeh  
\q2 tho ti toe telah atipouh.   
\q1
\v 21 Lawkdeithoumnae ni a tâ teh,  
\q2 lawk pâhnan hoi a tacuek thai   
\q1
\v 22 Maitotan ni moi theinae koe a pâtam e patetlah thoseh,  
\q2 sayuk ni a lungthin pala ni a cusin hoehnahlan  
\q2 karap coungroe e patetlah thoseh,   
\q1
\v 23 Tava ni a due nahanelah patung e tangkam a panue hoeh teh,  
\q2 karanglah a kâen e patetlah thoseh,  
\q2 thoundoun teh hote napui hnuk tang a kâbang.   
\q1
\v 24 Hatdawkvah, ka capanaw, ka lawk heh tarawi awh nateh,  
\q2 ka dei e lawk hah kahawicalah pouk awh.   
\q1
\v 25 Na lungthin hah hote napui koelah, kamlang sak hanh,  
\q2 a dawn e lam dawk dawn hanh.   
\q1
\v 26 Bangkongtetpawiteh, tami moikapap hmâ a paca teh,  
\q2 athakaawme tami moikapap a kamlei sak toe.   
\q1
\v 27 Ahnie im teh phuen koe ceinae lamkalen lah ao teh,  
\q2 duenae tangkom thung na ka hrawi e lah ao.   
\c 8  
\s1 Lungangnae hoe ahawi  
\q1
\v 1 Lungangnae ni a kaw teh,  
\q2 thaipanueknae ni a lawk a cai sak nahoehmaw.   
\q1
\v 2 Monsom vah tahungnae a sak teh,  
\q2 lam teng hoi lamtalawi koe ouk a kangdue.   
\q1
\v 3 Khopui kâennae longkha koehoi,  
\q2 kâennae thonaw koevah, kacaipounglah a oung.   
\q1
\v 4 Oe, taminaw, nangmouh hah na kaw awh.  
\q2 Ka lawk hah taminaw hane doeh.   
\q1
\v 5 Oe kamawngrame, lungangnae hah thaipanuek awh.  
\q2 Nangmouh tamipathunaw thaipanueknae lungthin tawn awh haw.   
\q1
\v 6 Thai awh haw, kahawi poung e hah ka dei vaiteh,  
\q2 ka pahni dawk hoi ka tâcawt e teh, kalan e han doeh.   
\q1
\v 7 Bangkongtetpawiteh, ka pahni ni lawkkatang a dei han,  
\q2 thoenae teh ka pahni hanelah panuet a tho.   
\q1
\v 8 Ka pahni hoi ka dei e lawk pueng teh, lannae doeh.  
\q2 Kâcawngmet e hoi ka longkawi e awm hoeh.   
\q1
\v 9 Kathaipanueknaw hanelah a kamceng teh,  
\q2 panuenae katawnnaw hanelah a lan.   
\q1
\v 10 Tangka hlak kaie cangkhainae hah dâw awh.  
\q2 Sui kahawi hlak panuenae heh kârawi awh.   
\q1
\v 11 Bangkongtetpawiteh, lungangnae teh  
\q2 Rubies talung hlak ahawihnawn.  
\q2 Ngai kawi e hno pueng hoi hote hno hah bangnue thai mahoeh.   
\q1
\v 12 Kai, lungangnae teh lungang laihoi ka o.  
\q2 Panuinae hoi poukthainae hai ka tawn.   
\q1
\v 13 BAWIPA taki e teh yon hmuhma e doeh.  
\q2 Kâoupnae hoi kaisuenae, yonnae lamthung hoi  
\q2 lawk kalan deihoehnae pahninaw heh ka hmuhma.   
\q1
\v 14 Kâpankhainae hoi lungangnae  
\q2 katang hateh, kaie naw doeh.  
\q2 Thaipanueknae lah ka o teh thaonae ka tawn.   
\q1
\v 15 Kai pawlawk hoi siangpahrangnaw ni a uk awh teh,  
\q2 ukkungnaw ni kalan lah laidei ouk a tâtueng awh.   
\q1
\v 16 Kai pawlawk hoi ukkungnaw hoi  
\q2 tami kalennaw hoi bari kaawmnaw hoi  
\q2 talai van e lawkcengkung pueng ni uknae kâ a tawn awh.   
\q1
\v 17 Kai lungpataw e teh, kai ni ka lungpataw van,  
\q2 atangcalah na katawngnaw ni na hmu awh han.   
\q1
\v 18 Tawntanae hoi barinae teh kai koe kaawm e naw doeh.  
\q2 Kangning e tawntanae hoi lannae doeh.   
\q1
\v 19 Kaie a paw teh sui hlak hai ahawihnawn.  
\q2 Bokheiyah, sui kathoung hlak hai ahawihnawn.  
\q2 Hahoi ka hmu e hnopai teh, kahawi e ngun hlak hai ahawihnawn.   
\q1
\v 20 Lannae hoi kângingnae lamthung lungui vah ka cei.   
\q1
\v 21 Hottelah, kai lungpataw naw koe hnopai tabu dawk,  
\q2 hno akawi nahanlah hnopai ka coe sak han.   
\q1
\v 22 BAWIPA ni a kamtawng lahun nahoi,  
\q2 ayan e thaw a tawk hoehnahlan vah, yo na tawn toe.   
\q1
\v 23 Talai ao hoehnahlan hoi a kamtawng hoehnahlan vah,  
\q2 a yungyoe caksak lah ka o toe.   
\q1
\v 24 Kadungpoung e talî ao hoehnahlan hoi,  
\q2 tuinaw pueng a tâco hoehnahlan vah, yo ka tâco toe.   
\q1
\v 25 Talai hoi vaiphu ao hoehnahlan,  
\q2 talai hoi ramnaw a sak hoehnahlan,   
\q1
\v 26 Montamnaw ao hoehnahlan vah,  
\q2 yo ka tâco toe.   
\q1
\v 27 Kalvannaw a rakueng lahun navah, yo ka o toe.  
\q2 Kadungpoung e talî dawk e kâheinae a sak navah,   
\q1
\v 28 Kalvan e tâmai a yam sak navah, kadungpoung e talî,  
\q2 ka lawng e palang, tha a poe navah,   
\q1
\v 29 Tui ni a kâpoelawk a ek hoeh nahanlah,  
\q2 talîpui hanelah a langri a khuen pouh navah, talai du a ung navah,   
\q1
\v 30 Kai teh kawk e capa patetlah ama koe ka o teh,  
\q2 pout laipalah ama lung kahawi sakkung lah ka o.  
\q2 A hmalah ka konawm.   
\q1
\v 31 O nahanelah a sak e talai ni, ka konawm sak,  
\q2 taminaw ni ka ko hoe a nawm sak.   
\q1
\v 32 Hatdawkvah, ka canaw, atu ka lawk thai awh haw.  
\q2 Bangkongtetpawiteh, ka lamthung kadawnnaw teh  
\q2 tami yaw kahawi e lah ao awh.   
\q1
\v 33 Cangkhainae heh thai awh nateh,  
\q2 lungang awh haw, banglah noutna laipalah awm hanh awh.   
\q1
\v 34 Hnin tangkuem kaie longkha koehoi na ring teh,  
\q2 takhang koehoi na ngaihawi.  
\q2 Ka lawk ka ngâi e teh, tami yaw kahawi e doeh.   
\q1
\v 35 Bangkongtetpawiteh, kai na kahmawt e pueng teh  
\q2 hringnae ka hmawt e lah ao.  
\q2 BAWIPA ni ngaikhainae hai ouk a hmu awh.   
\q1
\v 36 Hatei, kai dawk yonnae kasaknaw ni amae hringnae a raphoe teh,  
\q2 na ka maithoe e pueng teh duenae ka lungpataw naw doeh.   
\c 9  
\s1 Lungangnae lamthung  
\q1
\v 1 Lungangnae ni a im a sak teh  
\q2 khom sari touh a ung.   
\q1
\v 2 Moi a thei teh misurtui a phunphun hoi  
\q2 a kalawt teh ca hanelah caboi van a pâtoum.   
\q1
\v 3 A san tanglanaw a patoun teh,  
\q2 khopui hmuenrasang koehoi a oung awh.   
\q1
\v 4 Kamawngrame pueng hi lavah kamlang awh naseh.  
\q2 Oe, thaipanueknae kavoutnaw hai tho awh.   
\q1
\v 5 Kaie vaiyei hah cat awh.  
\q2 Aphunphun kalawt e misurtui hah net awh a ti.   
\q1
\v 6 Kamawngrame hah cettakhai awh nateh, hring awh.  
\q2 Hahoi thaipanueknae lamthung hah dawn awh.   
\q1
\v 7 Ayâ ka dudam e tami hah ka yue e teh, yeirai a po han.  
\q2 Tamikathout ka yue e teh pacekpahleknae a kâhmo han.   
\q1
\v 8 Ayâ ka dudam e tami hah na yue pawiteh, na hmuhma han.  
\q2 Tamilungkaang e na yue pawiteh, ahni ni na lungpataw han.   
\q1
\v 9 Tamilungkaang hah yue haw, a lung hoe a ang han.  
\q2 Tamikalan hah pâtu haw thoumthainae a kâthap han.   
\q1
\v 10 BAWIPA takinae teh lungang kamtawngnae a kung doeh.  
\q2 Kathounge Cathut panue e teh thaipanueknae doeh.   
\q1
\v 11 Bangkongtetpawiteh, na hnin hah kai ni ka pap sak vaiteh,  
\q2 na hringyung kum na thap pouh han.   
\q1
\v 12 Na lungang pawiteh, na lungangnae phu na hmu han.  
\q2 Na dudam pawiteh, nama ni na khang han.   
\s1 Pathunae lamthung  
\q1
\v 13 Napui pathu teh a hramki teh,  
\q2 kamawngrame lah ao dawkvah, banghai panuek hoeh.   
\q1
\v 14 A im takhang koe a tahung teh,  
\q2 khopui hmuen rasang tahungnae koe a tahung.   
\q1
\v 15 Lam dawk amamae lamthung dawk  
\q2 kacetnaw hah a kaw teh,   
\q1
\v 16 kamawngrame pueng hivah tho awh,  
\q2 lungangnae ka tawn hoeh naw,   
\q1
\v 17 paru e tui teh a radip, arulahoi ca e vaiyei teh  
\q2 hoe a tui telah ouk a ti.   
\q1
\v 18 Hatei, hawvah tamikadoutnaw ao teh,  
\q2 amae imyinnaw teh adungnae koe sheol dawk ao awh tie hah  
\q2 hote tongpa ni panuek hoeh.   
\c 10  
\s1 Solomon cingthuinae  
\q1
\v 1 Solomon e cingthuilawk: Capa a lungkaang e ni teh,  
\q2 a na pa a lunghawi sak. Hatei, capa ka pathu e teh,  
\q2 a manu lung ka mathout sakkung doeh.   
\q1
\v 2 Thoenae lahoi pâkhueng e hnopai teh, hawinae awmhoeh.  
\q2 Hatei, lannae ni teh duenae koehoi a rungngang.   
\q1
\v 3 BAWIPA ni tamikalannaw a pasai teh,  
\q2 tamikathoutnaw ngainae hah a tâkhawng pouh.   
\q1
\v 4 Pangaknae ni mathoenae a tâco sak teh,  
\q2 hratbatnae ni tawntanae a tâcokhai.   
\q1
\v 5 Kawmpoi tueng navah rawca ka pâkhueng e teh,  
\q2 a lungkaang e capa doeh.  
\q2 Canga lahun nah ka ip e capa teh  
\q2 yeirai ka po sakkung doeh.   
\q1
\v 6 Tamikalan lû dawk yawhawinae ao teh,  
\q2 tamikathoutnaw e pahni teh rektapnae hoi akawi.   
\q1
\v 7 Tamikalannaw pahnimhoehnae heh yawhawinae lah ao han.  
\q2 Hatei, tamikathoutnaw e min teh a pawk han.   
\q1
\v 8 Tami lungkaang ni teh kâpoelawknaw a lungthin hoi a dâw,  
\q2 hatei, a lawk kapap e tamipathu teh a rawp han.   
\q1
\v 9 Lannae lahoi ka cet e tami teh karoumcalah a cei,  
\q2 hatei lam longkawi ka dawn e teh panue lah ao han.   
\q1
\v 10 Mit cumasipnae ni lungmathoenae a tâco sak,  
\q2 lawk kapap e tamipathu teh a rawk han.   
\q1
\v 11 Tamikalan e pahni teh hringnae tuiphuek doeh.  
\q2 Hatei, tami kahawihoehnaw e pahni teh moikainae ni a ramuk.   
\q1
\v 12 Hmuhmanae ni kâpohoehnae a tâco sak.  
\q2 Hatei, lungpatawnae niteh, yonnae pueng a ramuk pouh.   
\q1
\v 13 Thaipanueknae ka tawn e pahni dawk  
\q2 lungangnae hah hmu e lah a o,  
\q2 hatei, hemnae bongpai teh  
\q2 thaipanueknae ka tawn hoeh e a hnukthun vah a bo.   
\q1
\v 14 Tami a lungkaangnaw niteh, thoumthainae heh a pâkhueng awh,  
\q2 hatei, tamipathu e pahni niteh, rawknae hah a hnai.   
\q1
\v 15 Tami katawntanaw hanelah teh,  
\q2 a tawntanae hah ka cak e khopui lah ao teh,  
\q2 tamimathoenaw rawknae teh, a mathoenae doeh .   
\q1
\v 16 Tamikalan thaw tawknae ni hringnae a tâcokhai teh,  
\q2 tamikathoutnaw e tawkphu teh, thoe khangnae hah doeh.   
\q1
\v 17 Cangkhainae ka tarawi e teh, hringnae lamthung dawk ao.  
\q2 Hatei, yuenae ka ek e teh, lamthung ka phen e doeh.   
\q1
\v 18 Hmuhmanae hah laithoe deinae pahni hoi ka ramuk e tami,  
\q2 ayâ min mathoe nahanelah ka dei e tami teh tamipathu doeh.   
\q1
\v 19 Lawk pap pawiteh, payon e hai a pap.  
\q2 Hatei, a pahni ka cakuep e tami teh tami a lungkaang e doeh.   
\q1
\v 20 Tamikalan e lai teh, kahawi e ngun patetlah ao teh,  
\q2 tamikathout e lungthin teh aphu awm hoeh.   
\q1
\v 21 Tamikalan e pahni ni tami moikapap a kawk.  
\q2 Hatei, tamipathu teh lungangnae a vout dawkvah a due.   
\q1
\v 22 BAWIPA yawhawinae ni tami a tawnta sak teh,  
\q2 lungmathoenae thokhai boihoeh.   
\q1
\v 23 Tamipathu hanelah teh, yonnae sak e heh a nawmnae lah a coung.  
\q2 Hatei, thaipanueknae ka tawn e niteh, lungangnae a tawn.   
\q1
\v 24 Tamikathout teh a taki e patetlah a lathueng a pha vaiteh,  
\q2 tamikalan teh a ngai e hah poe lah ao han.   
\q1
\v 25 Bongparui a kâkaven toteh, tamikathoutnaw teh a kahma han.  
\q2 Hatei, tamikalan ni teh a yungyoe adu hungnae a tawn.   
\q1
\v 26 Tami pangak patoun e teh, misurtui kathut e ni hah a kip sak e hoi,  
\q2 hmaikhu ni mit a ut e patetlah doeh ao.   
\q1
\v 27 BAWIPA takinae ni hringyung a saw sak, hatei,  
\q2 tamikathout e hringyung teh duem sak lah ao han.   
\q1
\v 28 Tamikalan ni ngaihawi e teh lunghawinae lah ao,  
\q2 hatei, tamikathout e ngaihawinae teh a kahma han.   
\q1
\v 29 Tamikalan hanelah BAWIPA e lamthung teh thaonae doeh.  
\q2 Hatei, thoenae ka sak e teh, rawkkahmanae koe a pha han.   
\q1
\v 30 Tamikalan teh hmuen dawk hoi nâtuek hai puen lah awm mahoeh.  
\q2 Hatei, tamikathoutnaw ni talai heh onae lah hno awh mahoeh   
\q1
\v 31 Tamikalan e pahni ni lungangnae a tâcokhai,  
\q2 hatei ka longkawi e lai teh, tâtueng pouh lah ao han.   
\q1
\v 32 Tamikalan e pahni ni ngai kawi e hno hah a panue,  
\q2 hatei tamikathout e pahni niteh,  
\q2 kâtarannae lawk doeh ouk a dei.   
\c 11  
\q1
\v 1 Kânging hoeh e yawcu teh BAWIPA hanelah panuet a tho teh,  
\q2 kânging e bangnuenae teh a ngai e lah ao.   
\q1
\v 2 Kâoup navah yeiraiponae ao teh,  
\q2 kârahnoum navah lungangnae ao.   
\q1
\v 3 Tamikalan teh yuemkamcunae ni a hrawi han,  
\q2 hatei, yuemkamcu hoeh e khopouknae niteh  
\q2 amamouh a raphoe han.   
\q1
\v 4 Lungkhueknae tueng navah hnopai teh cungkeihoeh,  
\q2 hatei lannae ni teh duenae koehoi a rungngang han.   
\q1
\v 5 Lannae ni teh toun kaawm hoeh e naw hah lam kalan a pâtue han,  
\q2 hatei, tamikathoutnaw teh  
\q2 thoenae dawk letlang a rawp awh han.   
\q1
\v 6 Tamikalannaw teh lannae ni a rungngang awh han,  
\q2 hatei, yuemkamcu hoeh e naw teh  
\q2 amamae ngainae dawk a kâman awh han.   
\q1
\v 7 Tamikathoutnaw a due awh toteh  
\q2 a ngaihawi awh e puenghai a kahma vaiteh,  
\q2 tamikalanhoehnaw e ngaihawinae puenghai a kahma han.   
\q1
\v 8 Tamikalan teh runae thung hoi a hlout vaiteh,  
\q2 hote runae teh tamikathoutnaw ni a pang awh han.   
\q1
\v 9 Cathut ka taket hoeh e niteh, a pahni hoi a imri ouk a raphoe,  
\q2 hatei, tamikalan teh thoumthainae lahoi rungngang lah ao han.   
\q1
\v 10 Tamikalan ni hawinae a coe navah khobuem a konawm awh,  
\q2 hatei, tamikathout a due toteh a lunghawi awh.   
\q1
\v 11 Tamikalan ni yawhawi a coe navah khopui hai tawmrasang lah a o,  
\q2 hatei, tamikathoutnaw e pahni ni teh ouk a raphoe.   
\q1
\v 12 Lungangnae ka vout e tami ni teh a imri hah ouk a dudam,  
\q2 hatei, thaipanueknae ka tawn e teh duem ao.   
\q1
\v 13 Yuengyoe ka pai ni teh lawk kapap e tami ni hrolawk hah  
\q2 ouk a pâpho, hatei, yuemkamcu e ni teh ouk a hro.   
\q1
\v 14 Pouknae kahawi poenae a ohoehnae koe  
\q2 khocanaw ouk a kahma teh,  
\q2 pouknae kahawi poenae apapnae koe teh  
\q2 khocanaw roumnae a coe awh.   
\q1
\v 15 Panue hoeh e tami panuesaknae teh a khang han, hatei,  
\q2 lawkpanuesaknae dawk kut tambeinae  
\q2 ka ngai hoeh e teh a hlout han.   
\q1
\v 16 Pahrennae ka tawn e napui ni barinae a coe,  
\q2 hatei, a thakasai e tongpa ni teh tawntanae a coe.   
\q1
\v 17 Pahrennae ka tawn e tami ni a hringnae han lah hnokahawi a sak,  
\q2 hatei, tamikathout teh  
\q2 a takthai hanelah runae kapoekung doeh.   
\q1
\v 18 Tamikathout ni dumnae phu ouk a hmu awh,  
\q2 hatei, lannae cati katukkungnaw ni tawkphu katang teh  
\q2 a coe awh han.   
\q1
\v 19 Lannae ni hringnae lamthung dawk tami a hrawi e patetlah,  
\q2 thoenae ka sak e ni ouk a duekhai.   
\q1
\v 20 Lungthin ka longkawi e teh BAWIPA hanelah panuet a tho,  
\q2 hatei, tamikalan kakuepcingnaw e hringnae teh  
\q2 amamouh letlang lunghawinae doeh.   
\q1
\v 21 Lungkânging lah ao awh nakunghai,  
\q2 tamikathout teh rek laipalah awm mahoeh.  
\q2 Hatei, tamikalannaw e canaw teh hloutsak lah ao han.   
\q1
\v 22 A meihawi eiteh pouknae ka tawn hoeh e napui teh,  
\q2 vok hnawng dawk suikuthrawt bang pouh e patetlah doeh ao.   
\q1
\v 23 Tamikalan ni ngainae teh hawinae dueng doeh,  
\q2 hatei, tamikathout ni a ring e teh lungkhueknae dueng doeh.   
\q1
\v 24 Thouk ka poe e teh, thouk a tawnta,  
\q2 hatei moikapap a pâkhueng eiteh, ka mathoe e tami hai ao.   
\q1
\v 25 Hring ka pasoung e teh tawnta sak lah ao han.  
\q2 Ayâ tui ka awi e teh ama hai tui awi lah ao han.   
\q1
\v 26 Cakang ka haw e tami teh ayâ ni thoe a bo han.  
\q2 hatei, kayawtkung koe teh yawhawinae ao han.   
\q1
\v 27 Hawinae ka tawng katang e ni barinae a coe han.  
\q2 hatei, thoenae ka tawng koe teh runae a pha han.   
\q1
\v 28 Hnopai kâuep e teh a rawp han,  
\q2 hatei tamikalan teh phokung patetlah dikhring han.   
\q1
\v 29 Ma e imthung runae ka poe e ni a coe e râw teh kahlî lah ao vaiteh,  
\q2 tamipathu teh a lungkaangnaw koe san lah ao han.   
\q1
\v 30 Tamikalannaw e a paw teh hringnae thing paw lah ao teh,  
\q2 muitha ka man e teh tami a lungkaang e doeh.   
\q1
\v 31 Tamikalan patenghai talai van reknae khang pawiteh,  
\q2 cathutlaipa e hoi tamikayon teh  
\q2 banghloimaw hoe a khang han vai.   
\c 12  
\p
\v 1 Cangkhainae ka ngai e teh panuenae hah a ngai toe,  
\q2 hatei yuenae ka hmuhma e teh tamipathu doeh.   
\q1
\v 2 Tami kahawi ni teh BAWIPA ni ngaikhai e hah ouk a hmu,  
\q2 hatei hawihoehnae sak hanelah kakâcainaw teh  
\q2 yonpen lah ao awh han.   
\q1
\v 3 Hawihoehnae ni tami caksak boi hoeh,  
\q2 hatei tamikalan e adu teh tahruet thai lah awm hoeh.   
\q1
\v 4 Napui kahawi teh a vâ hanelah bawilukhung lah ao,  
\q2 hatei yeirai ka po sak e napui teh  
\q2 a vâ e hru ka hmawnsakkung doeh.   
\q1
\v 5 Tamikalan pouknae teh a lan,  
\q2 hatei tamikathoutnaw e pouknae teh dumyennae doeh.   
\q1
\v 6 Tamikathoutnaw e lawk teh,  
\q2 thei hanelah pawm awh sei, tie hah doeh.  
\q2 Hatei tamikalan e pahni ni teh a rungngang han.   
\q1
\v 7 Tamikathout teh tâkhawng lah ao teh awm hoeh toe,  
\q2 hatei tamikalan e imthung teh a cak han.   
\q1
\v 8 Tami a lung a ang awh e patetlah rip oup lah ao,  
\q2 hatei a lungthin ka longkawi e teh dudam lah ao han.   
\q1
\v 9 Amahoima a kâoup teh ca hane kaawm hoeh e tami hlak teh,  
\q2 apinihai oup laipalah mae thaw duem ka tawk e bet ahawihnawn.   
\q1
\v 10 Tamikalan ni teh amae saringnaw hah a pasai,  
\q2 hatei tamikathout teh a pahrennae dawk patenghai a moikai.   
\q1
\v 11 Amae laikawk ka thawn e ni kaboumlah a ca han,  
\q2 hatei ayawmyin lah kho ka sak e tami teh  
\q2 thaipanueknae ka tawn hoeh e tami doeh.   
\q1
\v 12 Tamikathout ni tamikathoutnaw e tangkhek hah a doun awh,  
\q2 hatei tamikalannaw e kung ni teh apaw a paw sak.   
\q1
\v 13 Tamikathout teh amae eknae dawk ouk a kâman,  
\q2 hatei tamikalan teh runae thung hoi ouk a hlout.   
\q1
\v 14 Tami ni amae pahnipaw hah kaboumlah a ca han,  
\q2 amae a kut hoi a tawk e a paw hai poe lah ao han.   
\q1
\v 15 Tamipathu ni amae lamthung hah kalan poung e lah a pouk,  
\q2 hatei pouknae poe e ka ngâi e tami teh a lungkaang e doeh.   
\q1
\v 16 Tamipathu e lungkhueknae teh tang a kamnue,  
\q2 hatei kahawicalah kho ka pouk e ni teh kayanae hah ouk a ramuk.   
\q1
\v 17 Lawkkatang ka dei e ni lannae a kamnue sak,  
\q2 hatei kapanuekkhaikung kaphawk niteh  
\q2 kadumyennaw hah a kamnue sak.   
\q1
\v 18 Tahloi hoi thut e patetlah lawk ka dei e ao awh,  
\q2 hatei tami lungkaangnaw e lawk ni teh a dam sak.   
\q1
\v 19 Lawkkatang pahni teh a yungyoe caksak lah ao han,  
\q2 hatei laithoe deinae lai teh dongdengca hanelah doeh.   
\q1
\v 20 Hawihoehnae pouknae lungthin dawk dumyennae ao,  
\q2 hatei roumnae kadeikungnaw ni konawmnae a tawn awh.   
\q1
\v 21 Tamikalan koe thoenae phat mahoeh,  
\q2 hatei tamikathout teh thoenae hoi a kawi han.   
\q1
\v 22 Laithoe pahni teh BAWIPA ni a hmuhma e doeh,  
\q2 hatei kalan lah ka tawk e teh lunghawikhai e lah ao.   
\q1
\v 23 Kho ka pouk thai e tami ni teh a panue e patenghai a hro rah,  
\q2 hatei tamipathu e lungthin ni teh pathunae dueng doeh a pâpho.   
\q1
\v 24 Tami ka hratbat e kut ni a uk han,  
\q2 hatei ka pangak e teh lawkceng vaiteh  
\q2 thama lahoi tawk sak lah ao han.   
\q1
\v 25 Khopouk papnae ni lungmathoenae a tâco sak,  
\q2 hatei lawkkahawi ni tami konawm sak.   
\q1
\v 26 Tamikalan ni teh a imri hah lamthung a patue,  
\q2 tamikathout ni teh lam a phen sak.   
\q1
\v 27 Tami ka pangak niteh, kahrawng a cei ei,  
\q2 moi thokhai e boehai cat mahoeh.   
\q1
\v 28 Lannae lamthung dawk hringnae ao teh,  
\q2 hote lamthung dawk teh duenae awm hoe.   
\c 13  
\q1
\v 1 Capa lungkaang ni teh na pa e cangkhainae hah alawkpui lah a ta,  
\q2 hatei kadudamnaw ni teh cangkhainae hah ngai awh hoeh.   
\q1
\v 2 Tami ni amae pahnipaw hah kahawicalah a ca han,  
\q2 hatei yuemkamcu hoeh e tami teh rektapnae hoi a kâkawk han.   
\q1
\v 3 A pahni ka ring e ni teh a hringnae hah a ring toe,  
\q2 hatei ka kaw lah a kâko ka ang e teh rawknae koe a pha han.   
\q1
\v 4 Tami pangaknaw ni teh a ngai poung awh ei banghai tawn awh hoeh,  
\q2 hatei tami kahratbat e teh tawnta sak lah ao han.   
\q1
\v 5 Tamikalan ni teh laithoe dei e a hmuhma,  
\q2 hatei tamikathout teh panuet ka tho e hoi  
\q2 kayanae kaphawtkung doeh.   
\q1
\v 6 Toun han kaawm hoeh e lamthung ni lannae a ring,  
\q2 hatei thoenae ni tamikayon a tâkhawng.   
\q1
\v 7 Tami ka tawnta lah a kâpouk ei banghai ka tawn hoeh e tami ao,  
\q2 hatei kamathoe poung lah a kâpouk ei ka tawnta poung e ao.   
\q1
\v 8 Tami ka tawnta e ni kâratang nahane hnopai a tawn,  
\q2 hatei mathoe ni yuenae kâhmo boihoeh.   
\q1
\v 9 Tamikalannaw e angnae teh kahawi poung e angnae doeh,  
\q2 hatei tamikathoutnaw e hmaiim teh a due han.   
\q1
\v 10 Kâoupnae dawk doeh kâyuenae a tâco,  
\q2 hatei pouknae kahawi poe e tarawinae teh lungangnae doeh.   
\q1
\v 11 Kamsoumhoehe lah hnopai la e teh tang a kahma han,  
\q2 hatei panki laihoi hmu e hnopai teh a pung han.   
\q1
\v 12 Ring e hno tang hmu hoeh e ni lung a pataw sak,  
\q2 hatei ngaikuepnae teh hringnae thingkung doeh.   
\q1
\v 13 Lawk banglahai ka noutna hoeh e teh rawk sak lah ao han,  
\q2 hatei kâpoelawk e ka bari e teh tawkphu poe lah ao han.   
\q1
\v 14 Tami lungkaangnaw e kâpoelawk e teh  
\q2 hringnae tuiphuek lah ao teh,  
\q2 duenae karap rounnae lamthung lahai ao.   
\q1
\v 15 Thaipanueknae ni minhmai kahawi a poe,  
\q2 hatei yuemkamcu hoeh naw e lamthung teh a ru poung.   
\q1
\v 16 Kho kapoukthai e pueng ni panuenae hoi a kâroe awh,  
\q2 hatei tamipathu ni teh a pathunae a kamnue sak.   
\q1
\v 17 Patoune kathout teh runae dawk a rawp,  
\q2 hatei yuemkamcu e laicei ni teh damnae a thokhai.   
\q1
\v 18 Tounnae banglahai ka ngaihoeh e tami koe  
\q2 voutnae hoi yeiraiponae a pha han,  
\q2 hatei tounnae alawkpui lah ka tat e teh bari lah ao han.   
\q1
\v 19 Ngaikuepnae teh a radip, hatei payonnae rounnae  
\q2 hateh tamikathoutnaw ni a hmuhma awh.   
\q1
\v 20 Tamilungkaangnaw hoi kamyawng e teh a lung a ang han,  
\q2 hatei, tamikathoutnaw hoi kamyawng e teh a rawk han.   
\q1
\v 21 Tamikayon teh thoenae ni a pâlei,  
\q2 hatei tamikalan teh hawinae a pang han.   
\q1
\v 22 Tamikahawi ni teh a ca catounnaw hanelah râw a parâw pouh,  
\q2 hatei tamikayonnaw e hnopai teh  
\q2 tamikalannaw hanelah pâkhueng lah ouk ao.   
\q1
\v 23 Tamimathoe ni laikawk thawnnae lahoi rawca moi ao,  
\q2 hatei thoenae dawk doeh rawknae koe ouk pha awh.   
\q1
\v 24 Bongpai ka hno ngai hoeh e teh a capa ka hmuhma e lah ao,  
\q2 hatei a capa lung ka pataw e ni teh a nawca hoi ouk a yue toe.   
\q1
\v 25 Tamikalan teh a von a paha,  
\q2 hatei tamikathout teh a vonhlam han.   
\c 14  
\q1
\v 1 A lungkaang e napui ni teh a im hah a sak,  
\q2 hatei ka pathu e ni teh amae kut hoi ouk a raphoe.   
\q1
\v 2 Kalanlah ka hring e ni BAWIPA a bari,  
\q2 hatei a hringnae ka longkawi e ni teh a dumdam.   
\q1
\v 3 Tamipathu e pahni dawk kaisuenae bongpai ao,  
\q2 hatei tamilungkaang e pahni ni teh kânguenae a poe.   
\q1
\v 4 Maitotan ohoehnae koe maito im a thoung,  
\q2 hatei moikapap pungnae teh maitotha dawk doeh ao.   
\q1
\v 5 Yuemkamcu e ka panuekkhaikung teh laithoe dei hoeh,  
\q2 hatei kapanuekkhaikung kaphawk ni doeh laithoe ouk a dei.   
\q1
\v 6 Ka dudam e tami ni teh lungangnae  
\q2 ka tawng nakunghai hmawt mahoeh,  
\q2 hatei kathaipanueknaw hanelah teh panuenae heh ayawica.   
\q1
\v 7 A pahni panuenae na hmu hoeh toteh,  
\q2 tamipathu teh cettakhai yawkaw.   
\q1
\v 8 Ma e coungnae panue e heh poukthainae ka tawn e lungangnae doeh,  
\q2 hatei tamipathunaw e pathunae teh dumnae doeh .   
\q1
\v 9 Tamipathu ni teh yonnae a panuikhai,  
\q2 hatei tamikalannaw koe ngaikhainae ao.   
\q1
\v 10 Lungthin patawnae heh lungthin ni doeh a panue,  
\q2 ayânaw ni teh lunghawinae hai hmawngkhai katang hoeh.   
\q1
\v 11 Tamikathout imthung teh ka rawk han doeh,  
\q2 hatei tamikalan e rim teh a kamhlawng han.   
\q1
\v 12 Tami pouknae lahoi teh lam kalan lah a kamcu eiteh,  
\q2 apoutnae koe lah duenae koe ka phat e lam hai ao.   
\q1
\v 13 Panui lahun nahai lung a mathoe teh,  
\q2 panuinae a poutnae heh lungmathoenae lah a coung thai.   
\q1
\v 14 Lungthin hoi hnuklah ka ban e teh, ama ngainae hoi a kawi han,  
\q2 hatei tamikahawi teh hot patet e lathueng vah  
\q2 ao dawkvah a lunghawi han.   
\q1
\v 15 Kamawngrame ni dei e pueng a yuem awh,  
\q2 hatei kâhruetcuet e tami ni teh  
\q2 a cei nahane lamthung kahawicalah a pouk.   
\q1
\v 16 Tamilungkaang ni teh a taki dawkvah yonnae hah a roun,  
\q2 hatei tamipathu ni teh amahoima a kâyuem teh a taran a hawi sak.   
\q1
\v 17 Tami lungkaduem teh pathu laihoi a kâroe,  
\q2 hatei tamikathout e noenae teh hmuhmanae doeh.   
\q1
\v 18 Kamawngrame e coe e teh pathunae doeh,  
\q2 hatei kho ka pouk e teh panuenae kâmuksak lah ao.   
\q1
\v 19 Tamikahawi teh tamikahawi hmalah a tabut vaiteh,  
\q2 tamikathout teh tamikalan e takhang koe a tabut han.   
\q1
\v 20 Tamikathout teh a imri ni hai a hmuhma,  
\q2 hatei tami ka tawnta ni hui moi a tawn.   
\q1
\v 21 A imri ka dudam e teh tamikayon doeh,  
\q2 hatei tamimathoe ka pahren e teh a lungkahawi e lah ao.   
\q1
\v 22 Hnokathout ka pouk e teh lam a phen toung nahoehmaw,  
\q2 hatei lungmanae hoi lawkkatang teh  
\q2 hawinae kapouknaw hane doeh.   
\q1
\v 23 Tawknae pueng dawk meknae ao teh,  
\q2 pahni hoi dei rumram e teh voutnae doeh.   
\q1
\v 24 Tamilungkaangnaw e bawilukhung teh tawntanae doeh,  
\q2 hatei tamipathu pathunae hateh a pathunae doeh .   
\q1
\v 25 Kapanuekkhaikung katang ni teh hringnae a rungngang,  
\q2 hatei kapanuekkhaikung kaphawk ni teh laithoe ouk a dei.   
\q1
\v 26 BAWIPA takinae dawkvah a taranhawi laihoi a tha ao teh,  
\q2 a canaw ni kânguenae a pang awh han.   
\q1
\v 27 BAWIPA takinae teh hringnae tuiphuek lah ao teh,  
\q2 duenae karap dawk hoi kamlang sakkung lah ao.   
\q1
\v 28 Tamimaya koe siangpahrang barinae ao teh,  
\q2 tami younca koe e ukkung teh rawkphainae doeh.   
\q1
\v 29 A lung kasawe ni thaipanueknae a tawn,  
\q2 hatei tami lungkaduem e teh pathu tawmrasangnae doeh.   
\q1
\v 30 Lungthin damnae teh tak hanelah hringnae lah ao teh  
\q2 utsinnae teh hru ka rawk sakkung doeh.   
\q1
\v 31 Tamimathoe repcoungroe e teh  
\q2 ama kasakkung dudam e lah ao,  
\q2 hatei kasakkung ka bari e ni tami kavoutthoupnaw pahrennae a tawn.   
\q1
\v 32 Tamikathout teh a thoenae ni letlang a pâlei teh,  
\q2 tamikalan teh a duenae koe kânguenae a tawn.   
\q1
\v 33 Thaipanueknae katawnnaw lungthin dawk lungangnae ao,  
\q2 hatei tamipathu e lungthung kaawm e teh kamnue sak lah ao toe.   
\q1
\v 34 Lannae ni miphun a tawmrasang,  
\q2 hatei yonnae teh tami pueng hanelah min mathoenae doeh.   
\q1
\v 35 Tamilungkaang okhai e teh siangpahrang ni a ngai pouh,  
\q2 hatei yeirai ka po sakkung koe a lung ouk a khuek   
\c 15  
\q1
\v 1 Lawkkanem ni lungkhueknae a roum sak,  
\q2 hatei lawkkahram ni lungkhueknae a pâhlaw.   
\q1
\v 2 Tamilungkaang e lai ni teh, panuenae hah kalan lah ouk a hno,  
\q2 hatei tamipathu ni teh pathunae hah  
\q2 a pahni dawk hoi ouk a tâco sak.   
\q1
\v 3 BAWIPA e mit teh hmuen tangkuem a kâhlai teh  
\q2 hnokahawi hoi hnokathout hah ouk a khet.   
\q1
\v 4 A tak ka dam e lai teh hringnae thingkung doeh,  
\q2 hatei lawkkahram ni teh lung a mathoe sak.   
\q1
\v 5 Tamipathu ni a na pa e cangkhainae hah banglah ngâi hoeh,  
\q2 hatei yuenae ka tarawi e tami teh kho ka pouk thai e doeh.   
\q1
\v 6 Tamikalan im vah hnopai moikapap ao teh,  
\q2 tamikathout ni a hmu e teh rucatnae hah doeh.   
\q1
\v 7 Tamilungkaang e pahni ni teh panuenae a pung sak,  
\q2 hatei tamipathu e lungthin ni teh hottelah sak boihoeh.   
\q1
\v 8 Tamikathout ni thueng e teh BAWIPA hanelah panuet a tho,  
\q2 hatei tamikalan ni ratoum e teh a lunghawinae doeh.   
\q1
\v 9 Tamikathout hringnuen teh BAWIPA hanelah panuet a tho,  
\q2 hatei lannae katarawinaw hah teh a lung a pataw.   
\q1
\v 10 Lam kalan kaphennaw teh puenghoi yue lah ao teh,  
\q2 yuenae kahmuhmanaw teh a due han.   
\q1
\v 11 Sheol hoi rawkphainae teh BAWIPA hmalah a kamnue,  
\q2 tami canaw e lungthin teh hoe a kamnue han.   
\q1
\v 12 Ka dudam e tami teh yuenae ngai hoeh,  
\q2 tamilungkaang koehai cet ngai hoeh.   
\q1
\v 13 Lungthin nawmnae ni minhmai a pan sak teh,  
\q2 lungreithainae teh lungreknae doeh.   
\q1
\v 14 Thaipanueknae lungthin ka tawn e ni panuenae ouk a tawng,  
\q2 hatei tamipathu ni teh pathunae lawk hoi ouk a kâkawk.   
\q1
\v 15 Runae kâhmo e tami hanelah teh hnin pueng kathout seng doeh,  
\q2 hatei lungthin kanawm e ni teh pawi pou tonae lah ao.   
\q1
\v 16 BAWIPA taki laihoi younca tawn e teh  
\q2 baruengbaraw o laihoi moikapap tawn e hlak a hawihnawn.   
\q1
\v 17 Lungpatawnae lahoi ankahring hoi vai touh ca e teh,  
\q2 kâhmuhmanae koe maito buem pui ca e hlak ahawihnawn.   
\q1
\v 18 Tami lungkathout ni kâyuenae a tâcokhai,  
\q2 hatei ka panguep thai e ni teh a roum sak.   
\q1
\v 19 Kapangaknaw e lamthung teh pâkhing hoi khak a cak,  
\q2 hatei tamikalannaw e lamthung teh a ngaca.   
\q1
\v 20 Capa a lungkaang ni teh a na pa a konawm sak,  
\q2 ka pathu e ni teh a manu a dumdam.   
\q1
\v 21 Lungangnae ka tawn hoeh e naw niteh  
\q2 pathunae heh a lunghawinae lah a o,  
\q2 hatei thaipanueknae katawnnaw teh kalancalah ouk a cei awh.   
\q1
\v 22 Kâpankhainae awm hoeh pawiteh  
\q2 noenae hai kangcoung thai hoeh,  
\q2 hatei kâpankhaikung pap pawiteh noenae a kangcoung.   
\q1
\v 23 Pahni hoi dei e lawk ni lunghawinae a tâco sak,  
\q2 a tue a pha torei dei e lawk teh ahawi poung.   
\q1
\v 24 Tamilungkaangnaw e hringnae lamthung teh kahlun lah a luen,  
\q2 hothateh rahim lae sheol lam dawk hoi a kamlang thainae doeh.   
\q1
\v 25 BAWIPA ni tami kâoupnaw e im hah a raphoe pouh han,  
\q2 hatei lahmainu imhmuen teh a caksak han.   
\q1
\v 26 Tamikathoutnaw e pouknae teh BAWIPA hanelah panuet a tho,  
\q2 hatei a lung kathoungnaw lawk teh thai a nawm.   
\q1
\v 27 Ka hounloun e ni ama imthung totouh runae a poe,  
\q2 hatei tadawnghno ka hmuhma e teh a hring han.   
\q1
\v 28 Tamikalan lungthin ni teh pato nahane hmaloe a kamtu,  
\q2 hatei tamikathout e pahni ni teh hnokathout ouk a tâco sak.   
\q1
\v 29 BAWIPA teh tamikathout koehoi ahla,  
\q2 hatei tamikalan e ratoumnae teh ouk a thai.   
\q1
\v 30 Lunghawinae minhmai ni lungthin a nawm sak teh,  
\q2 kamthang kahawi teh hru hanelah hawinae lah ao.   
\q1
\v 31 Hring tounnae ka tarawi e tami teh  
\q2 tamilungkaangnaw koe pouh ao han.   
\p
\v 32 Cangkhainae banglah ka pouk hoeh e tami teh  
\q2 amae hringnae banglah ka pouk hoeh e tami doeh,  
\q2 hatei yuenae alawkpui lah ka pouk e ni thaipanueknae a hmu.   
\q1
\v 33 BAWIPA takinae teh lungangnae cangkhainae lah o teh,  
\q2 barinae ao hoehnahlan kârahnoumnae hmaloe ao.   
\c 16  
\q1
\v 1 Lungthin hoi pouknae teh tami e doeh,  
\q2 hatei laihoi bout deinae teh BAWIPA koehoi e doeh.   
\q1
\v 2 Tami hmunae pueng heh ama ni hmunae lahoi teh a thoung,  
\q2 hatei BAWIPA ni muitha hah yawcu dawk a khing.   
\q1
\v 3 Na thaw teh BAWIPA dawk poe haw  
\q2 na pouknae caksak lah ao han.   
\q1
\v 4 BAWIPA ni bangpueng hai ama hanelah a sak.  
\q2 Tamikathoutnaw haiyah thoenae kâhmo hnin hanelah  
\q2 sak e lah ao.   
\q1
\v 5 A lungthin hoi kâoup e tami teh BAWIPA han lah panuet a tho,  
\q2 a lung kânging awh nakunghai, rek lah ao mingming han.   
\q1
\v 6 Lungmanae hoi yonthanae lawkkatang teh  
\q2 BAWIPA takinae lahoi tami ni yonnae ouk a ceitakhai.   
\q1
\v 7 Tami e hringnuen ni BAWIPA a lungyouk torei teh,  
\q2 a taran hoi patenghai a kâpo sak.   
\q1
\v 8 Kamsoumhoehe lahoi moikapap tawn e hlak teh,  
\q2 lannae lahoi yitca tawn e ahawihnawn.   
\q1
\v 9 Tami e lungthin ni amae lamthung ouk a pouk,  
\q2 hatei BAWIPA ni teh a khoktakan hah ouk a hrawi.   
\q1
\v 10 Siangpahrang pahni dawk Cathut lawk pâpho hane ao,  
\q2 lawkcengnae koe a pahni a payon sak hanelah awm hoeh.   
\q1
\v 11 Kânging e yawcu hoi khinglung teh BAWIPA e doeh,  
\q2 congko dawk e khinglung puenghai a kut thawtawknae doeh.   
\q1
\v 12 Thoenae lahoi sak e heh siangpahrang hanelah teh panuet a tho,  
\q2 bangkongtetpawiteh, bawitungkhung teh  
\q2 lannae lahoi caksak lah ao.   
\q1
\v 13 Lannae pahni teh siangpahrang hanelah konawmnae lah ao teh,  
\q2 lawkkatang kadeinaw hah a lungpataw.   
\q1
\v 14 Siangpahrang lungkhueknae teh duenae patounenaw patetlah ao,  
\q2 hatei tamilungkaang ni teh a roum sak han.   
\q1
\v 15 Siangpahrang mithmaiang dawk hringnae ao,  
\q2 a ngaikhainae teh a hnukteng e kho tâmai patetlah ao.   
\q1
\v 16 Sui hlak hai lungangnae tawn e heh banghloimaw ahawi,  
\q2 hahoi ngun hlak hai thaipanueknae heh kârawi hanelah ao.   
\q1
\v 17 Tamikalannaw e lamthung teh yonnae ceitakhai e hah doeh,  
\q2 a lamthung ka ring e ni a hringnae a ring.   
\q1
\v 18 Rawk hoehnahlan kâoupnae ao teh,  
\q2 rawp hoehnahlan lunglennae muitha ao.   
\q1
\v 19 Kâoupnae lahoi lawphno kârei hlak teh,  
\q2 kârahnoumnae hoi ka rahnoumcalah o e ahawihnawn.   
\q1
\v 20 Kâhruetcuetcalah hoi lawk ka tarawi e ni hnokahawi a hmu vaiteh,  
\q2 BAWIPA ka kâuep e teh tami yawkahawi e doeh.   
\q1
\v 21 Lungthin hoi a lungkaang e teh  
\q2 kho ka pouk e doeh tie lah ao vaiteh,  
\q2 lawkradip ni thoumthainae a pung sak.   
\q1
\v 22 Thaipanueknae heh ka tawn hanelah teh  
\q2 hringnae tuiphuek lah ao teh,  
\q2 tamipathunaw e cangkhainae teh pathunae doeh.   
\q1
\v 23 Tamilungkaang ni teh a pahni hah a cangkhai teh,  
\q2 a pahni hoi thoumthainae hah ouk a kâthap.   
\q1
\v 24 Lawkkahawi teh khoipha patetlah ao,  
\q2 hring nahanelah a radip teh hru hanelah damnae lah ao.   
\q1
\v 25 Tami pouknae lateh lamkalan lah a kamcu ei,  
\q2 apoutnae koe teh duenae lamthung doeh.   
\q1
\v 26 Thaw ka tawk e teh ama hanelah doeh a tawk,  
\q2 bangkongtetpawiteh a vonhlamnae pahni ni a patoun e doeh.   
\q1
\v 27 Cathut ka taket hoeh e ni thoenae tangkom a tai teh,  
\q2 a pahni teh hmaisaan patetlah ao.   
\q1
\v 28 Lungthin longkawi ni kâyuenae cati a kahei teh,  
\q2 tamcueklawk ka dei e ni hai huiko a kapek.   
\q1
\v 29 Kaisue e ni a imri a pasawtpanep teh,  
\q2 hawihoehnae lamthung dawk ouk a hrawi.   
\q1
\v 30 A mitmasip teh kahawihoehe dueng doeh a pouk,  
\q2 a pahni a kâroe sak teh thoenae dueng doeh a tâco sak.   
\q1
\v 31 Lannae lamthung dawk hmu e lah awm pawiteh,  
\q2 sampo teh bawilennae bawilakhung doeh.   
\q1
\v 32 Athakaawme tami hlak a lungkasaw e tami ahawihnawn,  
\q2 a hringnae kâcakuep thai e kaukkung teh  
\q2 khopui ka lawm e hlak ahawihnawn.   
\q1
\v 33 Congko dawk cungpam teh rayu lah ao,  
\q2 hatei laideitâtuengnae pueng teh BAWIPA e doeh.   
\c 17  
\q1
\v 1 Kâyue kâoun laihoi im dawk yikkawi e pawitonae bu hlakvah  
\q2 karoumcalah lahoi bukaro kam touh ca e ahawihnawn.   
\q1
\v 2 A lungkaang e san ni yeirai ka phawt e capa hah a uk teh,  
\q2 hmaunawnghanaw hoi cungtalah râw a coe han.   
\q1
\v 3 Ngun sôlêi nahanelah manang, sui sôlêi nahanelah takhuenhmai,  
\q2 hatei BAWIPA ni lungthin a tanouk.   
\q1
\v 4 Thoenae kasaknaw ni teh laithoe dueng a thai ngai awh teh,  
\q2 laithoe kadeinaw ni hai laithoe lawk a thai ngai awh.   
\q1
\v 5 Tamimathoe ka dudam e ni kasakkung a dudam teh,  
\q2 ayânaw runae a kâhmo navah  
\q2 a lungkahawi e tami hai hlout mahoeh.   
\q1
\v 6 Mincanaw teh matawngnaw e bawilukhung doeh,  
\q2 camonaw bawilennae teh a napanaw doeh.   
\q1
\v 7 Lawkkanem hoi tamipathu kamcu hoeh,  
\q2 laithoe deinae pahni teh bawi hoi hoe kamcu hoeh.   
\q1
\v 8 Tadawnghno teh ka dâw e tami koe talung phukaawm hoi a kâvan,  
\q2 a kangvawi tangkuem koe hawinae a hmu.   
\q1
\v 9 Lawkeknae ka ramuk pouh e ni lungpatawnae a tawng,  
\q2 hatei boutbout ka dei pouh e tami ni teh huiko a kapek.   
\q1
\v 10 Tamipathu avai cum touh hem e hlak  
\q2 tamilungkaang vai touh yue e aphuohnawn.   
\q1
\v 11 Tamikahawihoeh ni kâtaran nahane dueng doeh a tawng,  
\q2 hatdawkvah patoune kathout hoi a kâhmo han.   
\q1
\v 12 Tamipathu a pathu lahun nah kâhmo e hlak teh,  
\q2 a ca kahmat e tavom hoi kâhmo pawiteh bet ahawihnawn.   
\q1
\v 13 Hawinae hah thoenae hoi ka pathung e tami teh  
\q2 hnokathout ni a imthung tâcawt takhai mahoeh.   
\q1
\v 14 Kâyuenae teh tuiim dawk hoi tui ka yu e patetlah ao,  
\q2 hatdawkvah kâyue hoehnahlan kâounnae hah roun lawih.   
\q1
\v 15 Tamikayon a yon ka ngaithoum e tami hoi,  
\q2 tamikalan yon kapen e tami hah BAWIPA ni a panuet   
\q1
\v 16 Tamipathu ni lungangnae a ngai hoeh dawkvah,  
\q2 lungangnae ran nahane hnopai hah  
\q2 bangkongmaw ahni kut dawk poe han vaw.   
\q1
\v 17 Hui ni teh nâtuek hai lung na pataw teh,  
\q2 hmaunawngha teh runae kâhmo tueng nahanelah doeh a khe.   
\q1
\v 18 Thaipanueknae ka tawn hoeh e niteh  
\q2 kuttabei kâtambei hoi a hui hmalah lawk a kam.   
\q1
\v 19 Lawkeknae ka ngai e ni teh kâyuenae hai a ngai,  
\q2 a longkha ka rasangsak e ni rawknae hah a tawng.   
\q1
\v 20 Dumyennae lungthin ka tawn e ni hnokahawi hmawt mahoeh,  
\q2 laithoe ka dei e tami teh runae hoi a kâhmo han.   
\q1
\v 21 Tamipathu ka khe e tami teh amahoima a lungmathoe sak,  
\q2 ka pathu e capa ka tawn e tami teh konawmnae tawn hoeh.   
\q1
\v 22 Lungthin konawm e heh kahawipoung e tâsi hoi a kâvan teh,  
\q2 lungthin reknae ni hru a ke sak.   
\q1
\v 23 Tamikathout ni lannae lamthung phen hanelah  
\q2 a hnukkhu lahoi hno ouk a lawp.   
\q1
\v 24 Lungangnae teh thaipanueknae katawnkung hmalah ao teh,  
\q2 tamipathu e mit ni teh talai pout totouh ouk a khet.   
\q1
\v 25 Capa pathu e teh na pa lung kamathoutsakkung lah ao teh,  
\q2 kakhekung manu hanelah hai ka khat poung e lah ao.   
\q1
\v 26 Tamikalan rek hanelah awm hoeh,  
\q2 ka talue e hai a hawi nahlangva hem hanelah awm hoeh.   
\q1
\v 27 Panuenae ka tawn e ni lawk a kâsum teh,  
\q2 thaipanueknae ka tawn e teh roumnae muitha ka tawn e doeh.   
\q1
\v 28 Tamipathu hai duem awm pawiteh,  
\q2 tamilungkaang patetlah pouk e lah ao,  
\q2 a pahnicakuep pawiteh thaipanueknae ka tawn patetlah pouk e lah ao.   
\c 18  
\q1
\v 1 Amadueng kaawm e ni ama ngainae dueng a tawng teh,  
\q2 lungangnae pueng hai a taran.   
\q1
\v 2 Tamipathu ni thaipanueknae dawk konawmnae tawn laipalah a  
\q2 mae lungthin dueng a kamnue sak.   
\q1
\v 3 Tamikathout a tho toteh dudamnae ao,  
\q2 yeiraiponae hoi yuenae hai hmawi ao van.   
\q1
\v 4 Tami e pahni dawk hoi ka tâcawt e lawk teh  
\q2 kadung e tui patetlah ao teh,  
\q2 lungangnae tuikhu teh ka lawng e palang patetlah ao.   
\q1
\v 5 Tamikathout e minhmai khet lahoi  
\q2 tamikalan sung sak nahanlah lawkceng e heh hawihoeh.   
\q1
\v 6 Tamipathu e pahni dawk hoi kâyuenae lawk a tâco teh  
\q2 a lawk ni hemnae hah a tâcosak.   
\q1
\v 7 Tamipathu e pahni teh ama rawknae lah ao teh,  
\q2 a pahni teh ama hanelah karap lah ao.   
\q1
\v 8 Tamcueklawk teh katuipounge rawca patetlah ao teh,  
\q2 von thung a thung totouh a kâen.   
\q1
\v 9 A thaw dawk ka pangak e teh karaphoekung e  
\q2 hmaunawngha lah ao.   
\q1
\v 10 BAWIPA e min teh kacake imrasang lah ao,  
\q2 tamikalan ni a kâen teh roumnae a hmu.   
\q1
\v 11 Tami katawntanaw e tawntanae teh,  
\q2 amamouh pouknae dawkvah,  
\q2 kacake khopui, karasang e rapan lah a o.   
\q1
\v 12 Rawknae kâhmo hoehnahlan tami lungpouk a rasang teh,  
\q2 barinae ao hoehnahlan kârahnoumnae ouk ao.   
\q1
\v 13 Thai hoehnahlan lawk pathung e teh  
\q2 pathunae hoi yeiraiponae doeh.   
\q1
\v 14 Tami e muitha ni a patawnae hah a khang thai,  
\q2 hatei muitha rek e teh apinimaw a khang thai han.   
\q1
\v 15 Kho ka pouk e lungthin ni panuenae hah a pang teh,  
\q2 tamilungkaang e hnâ ni panuenae hah a tawng.   
\q1
\v 16 Poehno poe e ni lam a kâko sak teh,  
\q2 kacuenaw hmalah na phakhai.   
\q1
\v 17 Amahoima hmaloe ka kâdei e teh  
\q2 tamikalan lah pouk e lah ao eiteh,  
\q2 a imri ni akung ouk a khei.   
\q1
\v 18 Cungpam rayunae ni kâounnae a roum sak teh  
\q2 athakaawmnaw hah a roum sak.   
\q1
\v 19 Hmaunawngha lungkuep sak hoeh e teh  
\q2 khopui tâ e hlak aruhnawn,  
\q2 lawk kâounnae teh sum hoi kâtaren e patetlah ao.   
\q1
\v 20 A pahni dawk hoi ka tâcawt e a paw hoi a von a paha vaiteh,  
\q2 a pahni paw hoi a lung a kuep han.   
\q1
\v 21 Hringnae hoi duenae teh lai bahu dawk ao teh,  
\q2 lai ka lungpataw e ni laipaw a ca han.   
\q1
\v 22 Yu kahmawt e ni hnokahawi a hmu teh,  
\q2 BAWIPA koehoi ngaikhainae ka pang e tami doeh.   
\q1
\v 23 Tamimathoe ni teh a kâhei, hatei ka tawnta e niteh  
\q2 lawk kahram lah ouk a dei.   
\q1
\v 24 Hui kapap ka tawn e teh hui kahawi lah  
\q2 ao van hanelah ao,  
\q2 hatei hmaunawngha hlak kahnai e huiko hai ao.   
\c 19  
\q1
\v 1 A lawk ka longkawi e tamipathu hlak,  
\q2 mathoe laihoi yuemkamcu hringnae ahawihnawn.   
\q1
\v 2 Panuenae tawn laipalah hringnae hai hawi hoeh,  
\q2 a khok a hue ka rang e hai a payon thai.   
\q1
\v 3 A pathunae ni lamthung a payon sak teh,  
\q2 a lungthung hoi BAWIPA ouk a taran.   
\q1
\v 4 Hnopai ni huiko moi a sak,  
\q2 hatei tamimathoe teh a hui ni a ceitakhai.   
\q1
\v 5 Ka panuekkhaikung kaphawk teh rek laipalah tâcawt mahoeh,  
\q2 laithoe ka dei e hai hlout mahoeh.   
\q1
\v 6 Tami kapap ni bawi e lungyouk hanelah a kâcai awh,  
\q2 poehno ka poe e tami hai tami pueng ni a kamyawngkhai.   
\q1
\v 7 Tamimathoe teh a hmaunawngha pueng ni hai a hmuhma,  
\q2 a huinaw natawng teh ahlanae koe doeh hoe ao awh,  
\q2 lawkkanem lahoi a pâlei ei nakunghai hoe a yawng takhai awh.   
\q1
\v 8 Lungangnae ka hmawt e ni hringnae a lungpataw teh,  
\q2 thaipanueknae ka pâkuem e ni hnokahawi a hmu han.   
\q1
\v 9 Ka panuekkhaikung kaphawk teh rek laipalah tâcawt mahoeh,  
\q2 laithoe ka dei e hai a rawk han.   
\q1
\v 10 Hringnawmnae heh tamipathunaw hanelah kamcu hoeh,  
\q2 san ni khobawi a uk e heh hoe kamcu hoeh.   
\q1
\v 11 Poukpanueknae ka tawn e ni a lungsaw sak teh,  
\q2 kâtapoenae ka pahnim pouh e teh ama ka bawilen sakkung doeh.   
\q1
\v 12 Siangpahrang lungkhuek e teh sendek ka huk e patetlah ao,  
\q2 hatei a ngaikhainae teh hram dawk  
\q2 ka bawt e tadamtui patetlah ao.   
\q1
\v 13 Capa ka pathu e teh a na pa hanelah  
\q2 thoenae kaphawtkung lah ao teh,  
\q2 lai ka roe e yu teh tui ka yu e patetlah ao.   
\q1
\v 14 Im hoi tawntanae teh napanaw koehoi coe e râw doeh,  
\q2 hatei yu kahawi teh BAWIPA koehoi e doeh.   
\q1
\v 15 Thathoenae ni ihmu a tho sak,  
\q2 ka pangak e teh a vonhlam han.   
\q1
\v 16 Kâpoelawk ka tarawi e teh a hringnae a ring,  
\q2 hatei ka pahnawt e teh a due han.   
\q1
\v 17 Tamimathoe ka pahren e teh BAWIPA koe a cawi sak toe,  
\q2 a poe tangcoung e hno hah bout poe lah ao han.   
\q1
\v 18 Ngaihawinae ao navah na capa hah yue haw,  
\q2 a kahma nahanelah pouk hanh.   
\q1
\v 19 A lung puenghoi ka khuek sak e ni reknae a kâhmo han,  
\q2 bangkongtetpawiteh, na rungngang nakunghai  
\q2 boutbout rungngang a ngai han doeh.   
\q1
\v 20 Kâpankhainae hah thai haw, cangkhainae hah dâw haw,  
\q2 bangkongtetpawiteh, hmalah na lung a ang han.   
\q1
\v 21 Tami e lungthin ni hno moikapap a kâcai,  
\q2 hatei BAWIPA e khokhangnae dueng doeh kangning han.   
\q1
\v 22 Tami ni a ngai poung e teh pahrennae hah doeh,  
\q2 laithoe dei e hlak mathoe e ahawihnawn.   
\q1
\v 23 BAWIPA takinae ni hringnae koe lah a ceikhai,  
\q2 hote hringnae ka tawn e teh a lung a kuep vaiteh,  
\q2 hnokathout ni thosin mahoeh.   
\q1
\v 24 Tami ka pangak ni a kut a kâyap teh  
\q2 rawca a kâtu hane boehai ngai hoeh.   
\q1
\v 25 Ka dudam e tami hah hem haw,  
\q2 kamawngrame tami teh a kâhlaw yawkaw han doeh,  
\q2 a lungkaang e tami hah yue haw patopatang han   
\q1
\v 26 Na pa roedeng ka poe ni teh manu ka hrek e teh,  
\q2 yeiraiponae hoi min mathoenae ka phawt e capa doeh.   
\q1
\v 27 Ka capa cangkhainae thai e heh na kâhat payon pawiteh,  
\q2 lungangnae lamthung na phen han doeh.   
\q1
\v 28 Cungkeihoehe kapanuekkhaikung ni  
\q2 lawkcengnae kalan a dudam teh,  
\q2 tamikathout e pahni ni payonpakainae a payawp.   
\q1
\v 29 Lawkcengnae heh kadudamnaw hanelah hruek e lah ao teh,  
\q2 hemnae bongpai teh tamipathunaw e hnukthun hane doeh.   
\c 20  
\q1
\v 1 Misurtui teh ayâ ni panuikhainae doeh,  
\q2 yamu teh kâyuenae doeh,  
\q2 hot patet e hno ni tami lungang sak boihoeh.   
\q1
\v 2 Siangpahrang lungkhuek e teh sendek ka huk e patetlah ao,  
\q2 a lung ka khuek sak e tami teh a hringnae hanlah runae doeh.   
\q1
\v 3 Kâyuenae karoumsakkung teh bari a kamcu,  
\q2 tamipathu ni kâhemnae pou a kamtawng.   
\q1
\v 4 Tami ka pangak ni a pâding dawk laikawk kanawk ngaihoeh,  
\q2 canga toteh a ca hane banghai tawn mahoeh.   
\q1
\v 5 Tami lungthin hoi pouknae teh ka dungpoung e tui hoi a kâvan,  
\q2 hatei thaipanueknae ka tawn e ni teh haw hoi a tâco sak han.   
\q1
\v 6 Tami kapap ni amamouh hawinae dueng doeh ouk a dei awh,  
\q2 hatei apinimaw yuemkamcu e a hmu thai han.   
\q1
\v 7 Tamikalan teh yuemkamcu lah ouk a hring,  
\q2 a canaw ni hai ahnie yawhawi ouk a hmawng awh.   
\q1
\v 8 Lawkcengnae tungkhung dawk ka tahung e siangpahrang ni,  
\q2 a mithmu e hnokathout pueng koung a takhoe.   
\q1
\v 9 Ka lungthin ka thoung sak toe,  
\q2 yon hoi ka hlout toe telah apinimaw a dei thai.   
\q1
\v 10 Yawcu kânginghoehe hoi khinglung ka kuep hoeh e teh  
\q2 BAWIPA hmalah panuet a tho.   
\q1
\v 11 Camo hai a tawk e lahoi panue thai,  
\q2 a tawk e hno a thoung hoi a lan e lahoi bangnue thai.   
\q1
\v 12 Thaithainae hnâ hoi hmuthainae mit heh  
\q2 BAWIPA ni a sak e doeh.   
\q1
\v 13 I e hah lungpataw hanh na mathoe han,  
\q2 na mit pakkaw lah khenhaw! cakhuem rawca na tawn han.   
\q1
\v 14 Hno karankung ni hawihoeh ati,  
\q2 hatei a cei hnukkhu a ran e hah a kâoupkhai.   
\q1
\v 15 Sui hoi talung phukaawm moikapap ao,  
\q2 hatei panuenae pahni teh talung phukaawm e lah ao.   
\q1
\v 16 Tamitavan hanelah amahkhankung teh angki amahkhan  
\q2 nahanelah la pouh lah ao vaiteh napui koe poe naseh.   
\q1
\v 17 Dumnae vaiyei teh a tui eiteh,  
\q2 a ca hnukkhu a kâko dawk sadi hoi a kawi han.   
\q1
\v 18 Noenae heh kâpankhai hnukkhu caksak lah ouk ao,  
\q2 kahawicalah kâpan hnukkhu na taran hah tuk.   
\q1
\v 19 Yapliyaplap kaawm e tami ni arulawk hah ouk a pâpho,  
\q2 hatdawkvah a lawk ka pâhnan e tami hoi kamyawng hanh.   
\q1
\v 20 Apipatethai, a manu hoehpawiteh a na pa thoe ka bo e teh,  
\q2 khohmo um a hmaiim a due pouh han.   
\q1
\v 21 Râw hah hmaloe pang thai eiteh,  
\q2 apoutnae koe yawhawinae lah awm hoeh.   
\q1
\v 22 Moi ka pathung han telah tet hanh,  
\q2 BAWIPA hah ring haw, ama ni na rungngang han.   
\q1
\v 23 Khinglung kâvan hoeh e heh BAWIPA mithmu vah panuet a tho teh,  
\q2 kânging hoeh e yawcu hai hawihoeh.   
\q1
\v 24 Tami ceinae lamthungnaw heh BAWIPA ni a sak e doeh,  
\q2 hatdawkvah tami ni ama ceinae lamnaw hah  
\q2 bangtelamaw a panue thai han.   
\q1
\v 25 Hetheh poehno kathoung doeh telah  
\q2 lungrang laihoi dei e teh tami hanelah karap doeh,  
\q2 lawkkam hnukkhu pankângainae ouk ao.   
\q1
\v 26 A lungkaang e siangpahrang ni tamikathoutnaw hah  
\q2 a kâyatsak teh lengkhok hoi a coungroe.   
\q1
\v 27 Tami e muitha teh BAWIPA e hmaiim doeh,  
\q2 a lungthin thung e pueng pheng a tue.   
\q1
\v 28 Lungmanae hoi lawkkatang ni siangpahrang teh a kountouk,  
\q2 a bawitungkhung teh lungpatawnae lahoi kangdue sak lah ao.   
\q1
\v 29 Thoundounnaw e bawilennae teh a thaonae doeh,  
\q2 matawngnaw e kamcunae teh a sampo doeh.   
\q1
\v 30 Puenghoi hemnae ni hno kathout a thoung sak,  
\q2 hemnae ni thung lah von dawk e pueng hai a thoung sak.   
\c 21  
\q1
\v 1 Siangpahrang lungthin teh tui ka lawng e patetlah ao teh,  
\q2 BAWIPA kut dawk ao dawkvah, a ngainae koe lah a lawng sak.   
\q1
\v 2 Ma e hmunae dawk teh mae hringnuen heh a lan telah pouk awh,  
\q2 hatei BAWIPA ni lungthin heh yawcu dawk a khing.   
\q1
\v 3 Lannae hoi kânging lah sak e heh  
\q2 thuengnae hlak BAWIPA ni a ngaihnawn.   
\q1
\v 4 Kâoupnae minhmai hoi lunglennae lungthin hoi  
\q2 tamikathoutnaw e hmaiim teh yon doeh.   
\q1
\v 5 Tami ka hratbat e pouknae ni tawntannae a tâcokhai,  
\q2 hatei kâhruetcuet hoeh e pouknae ni voutnae a tâcokhai.   
\q1
\v 6 Laithoe dei laihoi hmu e hnopai teh  
\q2 duenae ka tawng ni teh kahmat e patetlah ao.   
\q1
\v 7 Tamikathoutnaw e lawpnae ni amamouh a raphoe han,  
\q2 bangkongtetpawiteh kânginglah lawkcengnae hah a pahnawt awh.   
\q1
\v 8 Tamikayon e lamthung teh a longkawi,  
\q2 hatei tamikalan hanelah teh a tawk e hah kalan e doeh.   
\q1
\v 9 Ka hrawang e yu hoi im kalen dawk o hlak teh,  
\q2 lemphu imtakin koe awm pawiteh bet ahawihnawn.   
\q1
\v 10 Tamikathout hringnae ni hnokathout a ngai,  
\q2 a imrinaw ni ahnie pahrennae hmawt awh hoeh.   
\q1
\v 11 Kadudame taminaw reknae dawkvah  
\q2 kamawngrame ni lungang a kâla awh,  
\q2 hatei tamilungkaangnaw cangkhai navah panuenae a hmu awh.   
\q1
\v 12 Tamikalan ni tamikathout imthung hah kahawicalah a pouk,  
\q2 hatei Cathut ni tamikathoutnaw teh  
\q2 amamae thoenae lahoi a tâkhawng.   
\q1
\v 13 Tamimathoe hramnae lawk thai ngai laipalah  
\q2 a hnâ ka tabuem e teh,  
\q2 ama hai a hram toteh apinihai thai pouh mahoeh.   
\q1
\v 14 Arulahoi poe e poehno ni lungphuennae,  
\q2 a lungtabue dawk poe e tadawnghno ni  
\q2 puenghoi lungkhueknae a roum sak.   
\q1
\v 15 Kalan lah lawkcengnae e teh tamikalan hanelah konawmnae doeh,  
\q2 hatei yonnae kasaknaw teh rawknae koe a pha awh han.   
\q1
\v 16 Thaipanueknae lam kaphennaw teh  
\q2 tamikadoutnaw kamkhuengnae koe a kâhat van han.   
\q1
\v 17 Nawmnae dueng ka ngai e teh a mathoe han,  
\q2 misurtui hoi satui ka ngai poung e teh tawnta mahoeh.   
\q1
\v 18 Tamikathout teh tamikalan hanelah,  
\q2 Yuemkamcuhoeh e teh tamikalan ratangnae lah ao.   
\q1
\v 19 A lungkaduem ni teh ka hrawang e yu hoi o hlak teh,  
\q2 ramkenae koe awm pawiteh bet ahawihnawn.   
\q1
\v 20 Tamilungkaang onae koe hno ngai kaawm hoi satui ao teh,  
\q2 tamipathu ni teh a kaseikasak.   
\q1
\v 21 Lannae hoi lungmanae katawngnaw ni hringnae hoi  
\q2 lannae hoi barinae ouk a hmu awh.   
\q1
\v 22 Tamilungkaang ni kacakpounge khopui dawk a kâen teh,  
\q2 khocanaw ni a kângue e rapanim hah a tip sak.   
\q1
\v 23 A laihoi a pahni ka ring e teh runae thung hoi  
\q2 a hringnae ouk a hlout.   
\q1
\v 24 Tami moikai hoi kâoup e teh a min patenghai  
\q2 dudamkung telah a phung awh teh,  
\q2 kâoup lungkhuek laihoi ouk a kâroe.   
\q1
\v 25 Tami ka pangak e teh thaw a tawk ngaihoeh dawkvah,  
\q2 a doun e ni ama a thei.   
\q1
\v 26 Hnintangkuem nôe laihoi ao, hatei tamikalan niteh  
\q2 pasai laipalah a poe.   
\q1
\v 27 Tamikathout e thuengnae teh panuet a tho,  
\q2 hnokathout ngainae lungthin hoi thuengnae teh panuet hoe a tho.   
\q1
\v 28 Kapanuekkhaikung kaphawk teh takhoe lah ao han,  
\q2 hatei kapanuekkhaikung katang ni a panue e patetlah  
\q2 a dei e teh dâw lah ao han.   
\q1
\v 29 Tamikathout ni a minhmai tamundun lah a ta,  
\q2 hatei tamikalan ni a lamthung a cak sak.   
\q1
\v 30 BAWIPA taranlahoi lungangnae, thaipanueknae,  
\q2 hoi kâpankhainae awm hoeh.   
\q1
\v 31 Marangtan teh tarantuk hnin hanelah rakueng lah ao,  
\q2 tânae teh BAWIPA e doeh.   
\c 22  
\q1
\v 1 Hnopai moikapap hlak hai minhawinae heh rawi hanelah ao,  
\q2 tangka hoi sui hlak hai ayâ ni pahrennae heh  
\q2 ngaihnawn hanelah ao.   
\q1
\v 2 Tami ka tawnta hoi tamimathoe rei a tawn roi e teh,  
\q2 BAWIPA teh bangpueng kasakkung doeh.   
\q1
\v 3 Kâhruetcuet e ni teh hnokathout a hmu navah a kâhro,  
\q2 hatei kamawngrame ni teh a ceisin teh rek e lah ouk ao.   
\q1
\v 4 Kârahnoumnae hoi BAWIPA takinae ni tawntanae hoi  
\q2 barinae hoi hringnae a tâcokhai.   
\q1
\v 5 Lam longkawi dawk teh pâkhing hoi karap ao teh,  
\q2 a hringnae lamthung ka ring e teh  
\q2 hotnaw hoi ahlanae koe doeh ao.   
\q1
\v 6 Camo ni a dawn hane lamthung pâtu haw,  
\q2 a matawng to hai phen mahoeh toe.   
\q1
\v 7 Tami ka tawnta ni tamimathoe a uk,  
\q2 ka câwi e tami teh kacâwisakkung koe san lah ao.   
\q1
\v 8 Payonpakainae cati ka tu e ni lungmathoenae a a vaiteh,  
\q2 a lungkhueknae sonron a khoe han.   
\q1
\v 9 Pahrennae mit ka tawn e teh yawhawi a coe han,  
\q2 bangkongtetpawiteh tamimathoenaw ouk a kawk toe.   
\q1
\v 10 Dudamnaw pâlei haw kâounnae tang a roum han,  
\q2 kâyuenae hoi kâpakungnae hai a roum han.   
\q1
\v 11 A lungthin ka thoung e teh,  
\q2 kamcu e lawk a dei dawkvah  
\q2 siangpahrang e hui kahawicalah ao han.   
\q1
\v 12 BAWIPA mit ni panuenae a kountouk,  
\q2 hatei yuemnae ka tawn hoeh e lawk teh ouk a takhoe.   
\q1
\v 13 Ka pangak e tami ni alawilah sendek ao,  
\q2 lam vah na kei han doeh, ouk a ti.   
\q1
\v 14 Napui kahawihoehe pahni teh kadunge tangkom doeh,  
\q2 BAWIPA ni a panuet e teh hawvah a bo han.   
\q1
\v 15 Pathunae heh camo lungthin dawk a kâbet teh,  
\q2 yuenae bongpai ni ahlanae koe ouk a pâlei.   
\q1
\v 16 Ma mek nahanelah tamimathoenaw ka rektap e hoi,  
\q2 katawntanaw ka poe e tami teh hoehoe a mathoe han.   
\s1 Lungangnae lawknaw  
\q1
\v 17 Tamilungkaangnaw e lawk heh kahawicalah thai nateh,  
\q2 na lungthin hoi kaie lungangnae hah dâw haw.   
\q1
\v 18 Bangkongtetpawiteh, na thung hoi na pâkuem pawiteh  
\q2 hothateh lunghawinae doeh, na pahni dawk pou awm seh.   
\q1
\v 19 Hottelahoi BAWIPA teh na kâuep thai han,  
\q2 sahnin vah nang koe na panuesak toe.   
\q1
\v 20 Kâpankhainae hoi panuenae kahawi poung e hah  
\q2 na thut pouh toe nahoehmaw.   
\q1
\v 21 Nang ni lawkkatang katang na panue vaiteh,  
\q2 nang koe patoun e naw hah lawkkatang lawk  
\q2 bout na dei pouh thai han.   
\q1
\v 22 Mathoenaw e mathoenae hah thakâla hoi  
\q2 ahnie hno lawm hanh, ka cunathoehnaw hai  
\q2 kho longkha koe coungroe hanh.   
\q1
\v 23 Bangkongtetpawiteh, BAWIPA ni ahnimae kong a pouk han doeh,  
\q2 ahnimae hno kalawmnaw e hringnae a lawp pouh van han.   
\q1
\v 24 A lungkaduem e tami hah kamyawngkhai hanh,  
\q2 a lungkhuek thai poung e tami hai kamyawngkhai hanh.   
\q1
\v 25 Ahnimae nuen na kamtu vaiteh,  
\q2 na hringnae a kâman han.   
\q1
\v 26 Kut tambei e taminaw hoi laiba patho pouh hanelah  
\q2 lawk kâkam e taminaw koe bawk van hanh.   
\q1
\v 27 Patho nahane na tawn hoeh pawiteh,  
\q2 na ikhun tawm awh vaiteh oun na la pouh awh han nahoehmaw.   
\q1
\v 28 Na mintoenaw ni ung e  
\q2 khori hah takhoe hanh.   
\q1
\v 29 Thaw kahawicalah ka tawk ni teh ka cuem e na hmu boi ou,  
\q2 siangpahrangnaw hmalah hai a kangdue han doeh,  
\q2 tami rumram e hmalah kangdout mahoeh.   
\c 23  
\s1 Namahoima kâcakuep  
\q1
\v 1 Khobawinaw hoi rawca rei na ca toteh,  
\q2 na hmalah apimaw ka tahung tie kahawicalah pouk.   
\q1
\v 2 Na kâso e lah na awm pawiteh,  
\q2 tahloi hoi na lawkron hah nue haw.   
\q1
\v 3 Atuinae dueng pouk hanh,  
\q2 bangkongtetpawiteh dumyennae rawca doeh.   
\q1
\v 4 Tawnta hanelah kâcai hanh,  
\q2 na panuenae kâuep hanh.   
\q1
\v 5 Ka coung thai hoeh e hah na ngaihawi kawi namaw.  
\q2 Tawntanae ni amahmawk rathei a sak teh  
\q2 mataw patetlah kahlun lah koung a kamleng.   
\q1
\v 6 Utsinnaw e rawca cat pouh hanh,  
\q2 ahnie rawcanaw hai nôe pouh hanh.   
\q1
\v 7 Bangkongtetpawiteh, a lung hoi a pouk e patetlah doeh ao,  
\q2 cat nateh net ati nakunghai a lungthin teh nang koe awm mahoeh.   
\q1
\v 8 Na ca e hai na palo vaiteh,  
\q2 na oupnae hai a hrawnghrang lah ao han.   
\q1
\v 9 Tamipathu thainae koe lawk dei hanh,  
\q2 bangkongtetpawiteh na lungangnae lawk hah  
\q2 banglahai noutna mahoeh.   
\q1
\v 10 Ayan e khori hai takhoe hanh,  
\q2 naranaw e ram hai lawm hanh.   
\q1
\v 11 Bangkongtetpawiteh, ahnimouh ratangkung teh a tha ao,  
\q2 ahnimouh koelah kampang lahoi na taran payon vaih.   
\q1
\v 12 Cangkhainae koelah na lungthin poe nateh,  
\q2 panuenae lawk thainae koe na hnâpakeng haw.   
\q1
\v 13 Camo hah yue laipalah awm hanh,  
\q2 hem yawkaw dout mahoeh.   
\q1
\v 14 Bongpai hoi hem nateh a hringnae hah  
\q2 sheol dawk hoi rungngang haw.   
\q1
\v 15 Ka capa na lungang pawiteh, ka lung ahawi katang han.   
\q1
\v 16 Bokheiyah, na pahni ni lawk kalan dei pawiteh,  
\q2 ka lung ahawi katang han.   
\q1
\v 17 Na lungthin ni tamikayon nôe hanh naseh,  
\q2 hatei kanîruirui BAWIPA takinae tawn haw.   
\q1
\v 18 Bangkongtetpawiteh, apoutnae teh ka phat han,  
\q2 na ngaihawi e teh ahrawnghrang lah awm mahoeh.   
\q1
\v 19 Ka capa thai nateh lungang haw,  
\q2 na lungthin teh lamkalan dawk tat haw.   
\q1
\v 20 Misurtui kâsonaw hah kamyawngkhai hanh,  
\q2 moi kâsonaw hai kamyawngkhai hanh.   
\q1
\v 21 Bangkongtetpawiteh, yamuhri hoi moi kâso e teh  
\q2 a mathoe han, iparuinae ni tami napon a kâkhusak.   
\q1
\v 22 Kakhekung na pa e lawk hah ngâi nateh,  
\q2 na matawng toteh na manu dudam hanh.   
\q1
\v 23 Lawkkatang hah ran nateh yawt hanh, lungangnae hai,  
\q2 cangkhainae hai, thaipanueknae hai a sak.   
\q1
\v 24 Tamikalan ni a na pa puenghoi a lunghawisak,  
\q2 capa lungkaang ka khe e hai a lunghawi katang han.   
\q1
\v 25 Na manu hoi na pa teh lunghawi hoi awm awh naseh,  
\q2 kakhekung hai lunghawi naseh.   
\q1
\v 26 Ka capa na lungthin na poe haw,  
\q2 na mit ni ka onae nuen khen naseh.   
\q1
\v 27 Kâyawt e teh kadung poung e tangkom doeh,  
\q2 kahlong lae napui hai kabueng e tuikhu doeh.   
\q1
\v 28 A man thai e naw hah ouk a pawp,  
\q2 tongpa naw koe yuemkamcuhoehnae ouk a pungsak   
\q1
\v 29 Apimaw a lung ka mathout, apimaw kângaikâthung,  
\q2 apimaw ayâ hoi kâyue, apimaw ka phuenang,  
\q2 apimaw a khuekhaw awm laipalah hmâ ka cat,  
\q2 apimaw a mit ka paling tetpawiteh,   
\q1
\v 30 Yamu koe pou kaawm niteh,  
\q2 yamu aphunphun ouk kalawt e taminaw doeh.   
\q1
\v 31 Ka paling e yamu hah khen hanh,  
\q2 manang dawk kamlaw niteh,  
\q2 kamcu e yamu hah khen lah boehai khen hanh.   
\q1
\v 32 Apoutnae koe tahrun patetlah na khuek vaiteh,  
\q2 hrunthok patetlah na khue han.   
\q1
\v 33 Na mit ni napuinaw kathoute hmawt vaiteh,  
\q2 na lungthin ni lawk longkawi a dei han.   
\q1
\v 34 Bokheiyah, talî dawk ka ip e patetlah na awm vaiteh,  
\q2 long dawk yap e hni van ka ip e patetlah doeh na awm ti.   
\q1
\v 35 Na hem awh teh pataw hoeh, na tam awh ei ka panuek hoeh,  
\q2 nâtuek vaimoe ka kâhlaw vaiteh  
\q2 bout ka parui han vai na ti han doeh.   
\c 24  
\q1
\v 1 Tamikayonnaw hah nôe awh hanh,  
\q2 ahnimouh koehai kambawng hanh.   
\q1
\v 2 Bangkongtetpawiteh, rawk nahane dueng a pouk awh teh,  
\q2 runae kâhmo nahan dueng doeh a dei awh.   
\q1
\v 3 Lungangnae hoi im sak lah ao teh,  
\q2 thaipanueknae lahoi caksak lah ao.   
\q1
\v 4 Thoumthainae lahoi rakhannaw teh aphukaawm niteh  
\q2 ngai kaawm e hnonaw hoi a kawisak.   
\q1
\v 5 Tamilungkaang e teh a tha ao,  
\q2 panuenae ka tawn e ni a tha ao sak.   
\q1
\v 6 Bangkongtetpawiteh, lungkaangnaw hoi kâpankhai e lahoi  
\q2 na taran na tâ vaiteh kâpankhaikung a papnae koe hloutnae ao.   
\q1
\v 7 Lungangnae heh tamipathu hanelah teh a rasang poung dawkvah,  
\q2 kho longkha koe dei hane panuek hoeh.   
\q1
\v 8 Thoenae sak hanelah kâcai e tami teh,  
\q2 thoenae khokhankung telah kaw lah ao han.   
\q1
\v 9 Tamipathunaw e pouknae teh yonnae doeh,  
\q2 ayâ ka dudam e teh ayâ hanelah panuet a tho.   
\q1
\v 10 Runae na kâhmo navah na lungpout pawiteh,  
\q2 na tha a youn han.   
\q1
\v 11 Due hanelah a hrawi awh e hah rungngang awh nateh,  
\q2 thei hanelah a hrawi awh e hah ratang awh haw.   
\q1
\v 12 Thai haw, hetteh ka panuek hoeh, na tet pawiteh,  
\q2 na lungthin yawcu dawk kakhingkung ni pouk mahoeh namaw.  
\q2 Na hringnae kountoukkung ni panuek mahoeh na maw.  
\q2 Tamipueng a tawk awh e patetlah patho mahoeh namaw.   
\q1
\v 13 Ka capa khoitui hah cat haw, bangkongtetpawiteh ahawi,  
\q2 ka radip e khoipha hah cat haw.   
\q1
\v 14 Hot patetlah, panuenae hoi lungangnae hai  
\q2 na hringnae hanlah tho van seh.  
\q2 Hot hah na hmawt pawiteh ngaihawi hane ao teh  
\q2 na ngaihawinae teh ayawmyin lah awm mahoeh.   
\q1
\v 15 Oe tamikathout, tamikalan onae im hah pawm hanh,  
\q2 a kâhatnae hmuen hai raphoe hanh.   
\q1
\v 16 Bangkongtetpawiteh, tamikalan teh vaisari touh  
\q2 ka rawm nakunghai bout a thaw hah,  
\q2 hatei tamikathout teh rawknae koe a rawp han.   
\q1
\v 17 Na taran a rawp navah na konawm hanh,  
\q2 a kamthui navah na lunghawi hanh naseh.   
\q1
\v 18 Hatnavah, BAWIPA ni hmawt vaiteh,  
\q2 a lunghawi hoeh langvaih,  
\q2 hahoi ahni koe a lungkhueknae hai a roum sak thai.   
\q1
\v 19 Thoenae kasaknaw kecu dawk na lungpuen hanh,  
\q2 tamikathoutnaw hai ut hanh.   
\q1
\v 20 Bangkongtetpawiteh, tamikathoutnaw hanelah  
\q2 ngaihawinae awm hoeh,  
\q2 tamikathoutnaw e hmaiim teh padue pouh lah ao han.   
\q1
\v 21 Ka capa, BAWIPA hoi siangpahrang teh taket haw,  
\q2 kaletkalang kaawm e hah kamyawngkhai hanh.   
\q1
\v 22 Bangkongtetpawiteh, vaitahoi rawknae a pha han,  
\q2 ahnimouh roi e rawknae teh apinimaw a panue thai.   
\s1 Lungangnae lawk alouklouknaw  
\q1
\v 23 Het hai tamilungkaangnaw e doeh,  
\q2 lawkceng nah tami kapek e teh hawi hoeh.   
\q1
\v 24 Tamikathout koe, nang teh na lan, ka tet e teh,  
\q2 tamipueng ni thoebo vaiteh miphun pueng ni a panuet han.   
\q1
\v 25 Hatei, tamikathout ka yue e teh kabawpnae a tawn han,  
\q2 a lathueng yawhawinae kahawi a pha han.   
\q1
\v 26 Kalan lah ka pato e pahni teh  
\q2 tami pueng ni a paco han.   
\q1
\v 27 Alawilah na thaw hah kâcai haw,  
\q2 law thaw tawk hanelah kâcai haw, hathnukkhu na im hah sak.   
\q1
\v 28 A khuekhaw awm laipalah na imri taranlahoi  
\q2 kapanuekkhaikung lah awm hanh,  
\q2 bangkongtetpawiteh na pahni hoi na dum han namaw.   
\q1
\v 29 Ahni ni kai dawk a sak e patetlah ahni dawk ka sak han,  
\q2 amae moi rueng ka pathung han telah tet hanh.   
\q1
\v 30 Ka pangak law ka cei teh,  
\q2 thaipanueknae ka tawn hoeh naw e misur takha koe ka cei.   
\q1
\v 31 Pâkhing ni king a kayo, pho king a cak,  
\q2 rapan koung a tip toe.   
\q1
\v 32 Ka khet teh kahawicalah ka pouk,  
\q2 cangkhainae ao telah ka panue.   
\q1
\v 33 Dongdeng ka yan ei nei, dongdeng ka ip ei nei,  
\q2 kut tapam laihoi kâhat einei na ti lahun nah,   
\q1
\v 34 mathoenae ni imyin patetlah tho vaiteh,  
\q2 na voutnae teh ransa patetlah a tho han.   
\c 25  
\s1 Solomon ni dei e lungangnae lawk alouknaw  
\q1
\v 1 Hethaiyah, Solomon e cingthuilawk,  
\q2 Judah siangpahrang Hezekiah e taminaw ni  
\q2 patuen a thut awh e doeh.   
\q1
\v 2 Hro e hno teh Cathut bawilennae doeh,  
\q2 hatei hno pakhingpalang e teh siangpahrang bawilennae doeh.   
\q1
\v 3 Kalvan a rasang teh talai a dung e patetlah  
\q2 siangpahrang lungthin hai koung panuek thai hoeh.   
\q1
\v 4 Ngun ei hah takhoe haw,  
\q2 kahlunkung ni manang kahawi a sak thai han.   
\q1
\v 5 Siangpahrang hmalah hoi tamikathout hah takhoe pawiteh,  
\q2 a bawitungkhung teh lannae lahoi a cak han.   
\q1
\v 6 Siangpahrang hmalah mahoima kârasang sak hanh,  
\q2 siangpahrang hmuen koe hai kangdout hanh.   
\q1
\v 7 Na mit ni a hmu e bawitungkhung hmalah  
\q2 pahoung hanelah puen e lah na o hlak teh,  
\q2 hi tho, telah kaw e ahawihnawn.   
\q1
\v 8 Lawkcengnae hmuen koe karanglah cet hanh,  
\q2 bangkongtetpawiteh, na imrinaw ni  
\q2 yeirai na po sak vaiteh bangtelamaw na ti han.   
\q1
\v 9 Na imri hoi na lawk teh kâpankhai awh nateh,  
\q2 arulawk hah ayânaw koe dei awh hanh.   
\q1
\v 10 Hoehpawiteh ka thai e ni hoe pâpho vaiteh,  
\q2 yeirai na ponae hah hoe kamnuek langvaih.   
\q1
\v 11 Kamculah dei e lawk teh ngun manang dawk e  
\q2 suipaw hoi a kâvan.   
\q1
\v 12 Kahawicalah yuenae ka tarawi e tami teh,  
\q2 suihnapacap hoi sôlêi e sui hoi kamthoup e patetlah ao.   
\q1
\v 13 Kapatounkung hanelah yuemkamcu lah  
\q2 kaawm e patoune teh canganae tadamtui patetlah ao,  
\q2 bangkongtetpawiteh a bawi lung a roum sak.   
\q1
\v 14 Ka poe han tihoi a kâoup hnukkhu  
\q2 poe laipalah kaawm e tami teh,  
\q2 khotui laipalah e tâmai hoi kahlî hoi a kâvan.   
\q1
\v 15 Lungsawnae ni lawkcengkung a tâ thai,  
\q2 lawkkanem ni hru a khoe thai.   
\q1
\v 16 Khoitui na hmu boimaw, na boum totouh duengma cat.  
\q2 Na kâso pawiteh na palo han.   
\q1
\v 17 Na imri koe ekvoi cet hanh, na hmawt vaiteh  
\q2 na hmuhma payon vaih.   
\q1
\v 18 A imri taranlahoi panuekkhaikung kaphawk lah kaawm e tami teh,  
\q2 bongpai, tahloi, kahran e pala hoi a kâvan.   
\q1
\v 19 Runae kâhmo lahun nah yuemkamcu hoeh e kâuep e teh,  
\q2 hâ kâkhoenae, hru kamhoutnae patetlah doeh ao.   
\q1
\v 20 A lungkamathout koe la ka sak e teh  
\q2 pâding nah angki ka rading e hoi hmâ dawk  
\q2 longtui awi e hawi a kâvan.   
\q1
\v 21 Na taran a vonhlam pawiteh,  
\q2 a ca hane rawca poe nateh tui kahran pawiteh  
\q2 nei hane tui poeh.   
\q1
\v 22 Bangkongtetpawiteh, hottelah na sak pawiteh  
\q2 a lû dawk hmaisaan na pâpawp pouh e lah ao teh,  
\q2 BAWIPA ni tawkphu na poe han.   
\q1
\v 23 Atunglah e kahlî ni kho a thokhai teh,  
\q2 tamcuek lawk deinae lai ni lungkhueknae minhmai a thokhai.   
\q1
\v 24 Ka hrawk'ang e yu hoi im kalen dawk o hlak teh,  
\q2 lemphu imtakin koe o e ahawihnawn.   
\q1
\v 25 Ahlanae koe e kamthang kahawi thai e heh,  
\q2 tuikahran e tami koe tuipading hoi a kâvan.   
\q1
\v 26 Tamikathout hmalah tamikalan lawk dei payon e teh tui pânut e,  
\q2 kapawk e tuikhu hoi a kâvan.   
\q1
\v 27 Khoitui ek kapap ca e hawi hoeh,  
\q2 hot patetlah mahoima bawilennae tawng e teh bawilennae nahoeh.   
\q1
\v 28 Ma e muitha ka uk thai hoeh e teh  
\q2 rapan tawn laipalah karawk e khopui hoi a kâvan   
\c 26  
\q1
\v 1 Kawmpoi e tadamtui hoi canganae kho patetlah,  
\q2 tamipathu hoi barinae kamcu hoeh.   
\q1
\v 2 Kamleng rumram e pusu hoi pingpit patetlah,  
\q2 a khuekhaw awm laipalah thoebo e teh api koehai bawt mahoeh.   
\q1
\v 3 Marang hanelah ruibongpai,  
\q2 la hanelah kammoumrui,  
\q2 tamipathu e keng hanelah bongpai teh a kamcu doeh.   
\q1
\v 4 Tamipathu teh a pathunae patetlah pato hanh,  
\q2 hoehpawiteh ama patetlah na awm payon vaih.   
\q1
\v 5 Tamipathu teh a pathunae patetlah pato,  
\q2 hoehpawiteh a lungkaang lah kâpouk payon vaih.   
\q1
\v 6 Tamipathu koe lawk ka thui e tami teh  
\q2 amae khok ka tâtueng ni teh rawknae tui ka net e lah ao.   
\q1
\v 7 Khokkhem e khoktakan a kânging hoeh e patetlah,  
\q2 tamipathu e pahni dawk cingthuilawk teh ao.   
\q1
\v 8 Tamipathu bari e teh tâyaicung dawk  
\q2 hluemhluem kawm e patetlah doeh ao.   
\q1
\v 9 Tamipathunaw ni dei e cingthuilawk teh  
\q2 yamuhri kut dawk ka um e pâkhing hoi a kâvan.   
\q1
\v 10 Bangpuengpa kasakkung lentoe Cathut ni  
\q2 tamipathu hoi kâtapoe kung aphu a poe.   
\q1
\v 11 Ui ni a palo bout a ca e patetlah tamipathu ni  
\q2 a pathunae hah a kamnue sak.   
\q1
\v 12 Ama pouknae dawk tamilungkaang lah ka kâpouk e na hmu ou.  
\q2 Hote tami koehoi hlak teh tamipathu koehoi  
\q2 ngaihawinae bet aohnawn.   
\q1
\v 13 Tami pangak ni, lam dawk sendek ao,  
\q2 thongma vah sendek ao telah a ti.   
\q1
\v 14 Tho teh takhang dawk a kâhei e patetlah  
\q2 tami pangak teh ikhun dawk a kâhei.   
\q1
\v 15 Tami pangak ni rawca a kâyap teh  
\q2 a kâtu hane boehai ngai hoeh.   
\q1
\v 16 Ka pangak e ni, kahawicalah khopouk thai e tami sari touh hlak  
\q2 ka lunganghnawn telah a kâpouk.   
\q1
\v 17 Yuengyoe cei lahoi ayânaw e kong dawk ka bawk e tami teh  
\q2 ui hnâ ka kuen e hoi a kâvan.   
\q1
\v 18 Na pacai e doeh na a tihoi,  
\q2 a imri ka dum e tami teh,   
\q1
\v 19 hmaito, pala, duenae hoi  
\q2 ka ka e tamipathu hoi a kâvan.   
\q1
\v 20 Thing awm hoehpawiteh hmai a roum e patetlah,  
\q2 tamcueklawk deinae awm hoehpawiteh kâyuenae hai a roum.   
\q1
\v 21 Hmaisaan ni hmaisaei a kamtawi sak,  
\q2 thing ni hmai a kak sak e patetlah,  
\q2 kâoun ka ngai e ni kâyuenae a kamtawi sak.   
\q1
\v 22 Tamcueklawk teh katuipounge rawca patetlah ao teh,  
\q2 von thung a kâen.   
\q1
\v 23 Apâhni pâhnan hoi lungthinkathout e tami teh,  
\q2 talai hlaam ngun hoi pâbing e hoi a kâvan.   
\q1
\v 24 Tami hmuhmanae ka tawn e tami ni a pahni hoi a hro teh,  
\q2 a lung thung dumyennae hah a hro.   
\q1
\v 25 Pahren lahoi, ati ei nakunghai yuem hanh,  
\q2 bangkongtetpawiteh a lungthung vah panuettho e sari touh ao.   
\q1
\v 26 A hmuhmanae hah dumnae lahoi ka hrawk nakunghai,  
\q2 thoenae teh tamimaya ni panuenae koe  
\q2 kamnue sak lah ao han.   
\q1
\v 27 Tangkom kataikung teh a tai e tangkom dawk a bo han,  
\q2 talung kapaletkung koe talung bout a kamlei han.   
\q1
\v 28 Laithoe ka dei e ni a rektap e naw hah ouk a hmuhma,  
\q2 oupnae kaphawk ni rawknae a tâcokhai.   
\c 27  
\q1
\v 1 Tangtho e hnin hanlah kâoup hanh,  
\q2 bangkongtetpawiteh bangmaw a tâcokhai han tie na panuek hoeh.   
\q1
\v 2 Namahoima laipalah ayâ ni na pholen naseh,  
\q2 nama e pahni ni laipalah alouke ni na pholen naseh.   
\q1
\v 3 Talung hai a ri teh sadi hai a ri,  
\q2 hatei tamipathu lungkhueknae teh hotnaw hlak a ri hnawn.   
\q1
\v 4 Lungkhueknae teh a mathoe,  
\q2 lungphuennae teh a matheng,  
\q2 hatei utnae teh apinimaw a khang thai han.   
\q1
\v 5 Hro e lungpatawnae hlak teh  
\q2 hmantang yue e ahawihnawn.   
\q1
\v 6 Hmâ na ka paca e hui teh yuem a kamcu,  
\q2 hatei taran ni na paco e teh dumyennae doeh.   
\q1
\v 7 A von ka paha tangcoung e ni teh khoipha patenghai  
\q2 ngai mahoeh toe,  
\q2 hatei a von ka hlam e tami hanelah teh kakhat e patenghai a radip.   
\q1
\v 8 Ma e imlaw ka palum ngai hoeh e teh,  
\q2 tava a tabu dawk kaawm ngai hoeh e hoi a kâvan.   
\q1
\v 9 Satui hoi hmuitui ni lungthin a konawm sak teh,  
\q2 hui kahawi ni pouknae na poe e ni hringnae konawm sak.   
\q1
\v 10 Na pa e hui hoi nama e hui kapek hanh,  
\q2 runae na kâhmo navah na hmaunawngha im kuekluek cet hanh,  
\q2 ahlanae koe e na hmaunawngha hlak teh  
\q2 a hnainae koe e na hui a hawihnawn.   
\q1
\v 11 Na ka pacekpahlek e ka pathung thai nahanlah ka capa,  
\q2 lungang haw, ka lungthin konawm sak haw.   
\q1
\v 12 Tamilungkaang ni thoenae hah sut a hmu teh a kâhro,  
\q2 kamawngrame ni teh a kâphumsin teh rek e lah ouk ao.   
\q1
\v 13 Tamitavan hanelah amahkhankung teh  
\q2 a angki amahkhan nahanelah la pouh lah ao vaiteh  
\q2 napui koe poe naseh.   
\q1
\v 14 Amom a thaw teh kacaipounglah a hui yawhawi ka poe e teh,  
\q2 thoebonae lah pouk pouh lah ao han.   
\q1
\v 15 Lai pou ka roe e yu teh,  
\q2 Puenghoi khonan hnin e khoramei hoi a kâvan.   
\q1
\v 16 Hote napui ka pâkuem e teh, kahlî ka pâkuem niteh,  
\q2 aranglae kut dawk satui kasum e hoi a kâvan.   
\q1
\v 17 Sum teh sum hoi doeh letlang hran sak thai,  
\q2 hot patetlah tami ni a hui e a minhmai ouk a pan sak.   
\q1
\v 18 Thaibunglung kung ka tawn e pueng ni thaibunglung paw a ca han,  
\q2 hot patetlah a bawi e thaw ka tawk e teh bari lah ao han.   
\q1
\v 19 Tui dawk coungnae a kamnue,  
\q2 hot patetlah tami lungthin ni tami a kamnue sak.   
\q1
\v 20 Sheol hoi rawkkahmanae teh khout boihoeh,  
\q2 hot patetlah tami e mit ni a khout tie tawn boihoeh.   
\q1
\v 21 Sôlêinae manang teh ngun hanelah,  
\q2 takhuenhmai teh sui hanelah ao.  
\q2 Tami teh oup e lahoi a bawilennae panue lah ao.   
\q1
\v 22 Tamipathu teh sumdawk cakang hoi  
\q2 mek ka phawm nakunghai a pathunae ni cettakhai pawm mahoeh.   
\q1
\v 23 Na tuhu kong panue nahanlah panki loe,  
\q2 na saringhu hah kahawicalah a kountouk.   
\q1
\v 24 Bangkongtetpawiteh, tawntanae heh a yungyoe kangning hoeh,  
\q2 hoehpawiteh bawilukhung heh se pueng dawk kangning hoeh.   
\q1
\v 25 Phonaw hai a pâw, catinaw hai a pâw,  
\q2 law e a pawnaw hai khue lah ao.   
\q1
\v 26 Tunaw ni na khohna hane  
\q2 hmaenaw ni lawhmuen ran nahane ouk a thokhai.   
\q1
\v 27 Nang ni na ca hane, imthungnaw ca hane,  
\q2 sannunaw ca hanelah hmae sanutui teh a khout han doeh.   
\c 28  
\q1
\v 1 Tamikathout teh apinihai pâlei hoeh eiteh a yawng,  
\q2 hatei tamikalan teh sendek patetlah a taran ahawi.   
\q1
\v 2 Khocanaw lawkeknae kecu dawk  
\q2 khobawinaw tuhoitu a kâthung awh,  
\q2 hatei thaipanueknae hoi panuenae katawnnaw kecu dawk  
\q2 ram a kangning han.   
\q1
\v 3 Tamimathoe ni tamimathoe repcoungroe e teh  
\q2 ca hane pek laipalah ka cetkhai e longhotui hoi a kâvan.   
\q1
\v 4 Kâlawk ka cettakhai e ni tamikathout a pholen,  
\q2 hatei kâlawk ka tarawi ni ouk a tuk awh.   
\q1
\v 5 Tamikathoutnaw ni lannae thaipanuek awh hoeh,  
\q2 hatei BAWIPA katawngnaw ni bangpueng hai a thaipanuek.   
\q1
\v 6 Tawnta laihoi a khuekhaw awm laipalah hring hlak teh  
\q2 tamimathoe yuemkamculah kaawm e ahawihnawn.   
\q1
\v 7 Kâlawk ka tarawi e teh a lungkaang e capa doeh,  
\q2 ka kâso e hoi kamyawng e ni a na pa yeirai a po sak.   
\q1
\v 8 Apung ka cat ni teh kalan hoeh e lahoi hnopai ka tawnta e ni  
\q2 tamimathoe kabawmkung hanelah a pâtung pouh.   
\q1
\v 9 Kâlawk ka tarawi ngai hoeh e teh a ratoumnae hai panuet a tho.   
\q1
\v 10 Thoenae lam dawk tamikalan lam ka phen sak e teh  
\q2 ama ni a tai e tangkom dawk a bo han,  
\q2 hatei toun kaawm hoeh e ni hnokahawi a coe han.   
\q1
\v 11 Ka tawnta e ni amahoima a lungkaang lah a kâpouk,  
\q2 hatei thaipanueknae ka tawn e tamimathoe ni peng a pâpho han.   
\q1
\v 12 Tamikalan a lunghawi navah kalen e bawilennae ao,  
\q2 hatei tamikathout a kangdue toteh taminaw a kâhro awh.   
\q1
\v 13 Amae yonae ka hrawk e teh hawinae hmawt mahoeh,  
\q2 hatei ka pâpho e ni pahrennae a hmu han.   
\q1
\v 14 Takinae pou ka tawn e teh a yawkahawi e doeh,  
\q2 hatei a lung pou ka patak e teh rawkkahmanae hoi a kâhmo han.   
\q1
\v 15 Mathoenaw kaukkung bawi kathout teh  
\q2 sendek ka huk e hoi tavom ka hram e patetlah ao.   
\q1
\v 16 Thaipanueknae ka vout e ukkung niteh  
\q2 rep a coungroe hatei hounlounnae ka hmuhma e ukkung teh  
\q2 a hringsaw han.   
\q1
\v 17 Tamikathet e teh phuen tangkom koe yawng na lawiseh,  
\q2 apinihai ngang nahan seh.   
\q1
\v 18 Lam kalan dawk ka dawn e tami teh a hlout han,  
\q2 hatei lam longkawi dawk ka dawn e teh vaitalahoi a rawp han.   
\q1
\v 19 Laikawk ka thawn e teh rawca moi a tawn han,  
\q2 hatei ayawmyinlah kaawm e tami teh a mathoe han.   
\q1
\v 20 Yuemkamcu e ni yawhawinae kapap a hmu han,  
\q2 hatei dongdengca dawk tawnta hanelah  
\q2 kâcai e teh rek laipalah awm mahoeh.   
\q1
\v 21 Minhmai khet tawnnae teh hawi hoeh,  
\q2 vaiyei tangen kecu dawk tami kâlawk ouk a tapoe awh.   
\q1
\v 22 Dongdengca dawk tawnta hanelah  
\q2 kâcai e tami teh thoenae mit a tawn,  
\q2 bout mathoe han doeh tie pouk hoeh.   
\q1
\v 23 Tami ka oup e hlak teh tami ka yue e ni  
\q2 a hnukkhu pholennae a coe han.   
\q1
\v 24 A manu hoi a na pa hno ka lawm niteh,  
\q2 kâtapoenae nahoeh ka tet e tami teh,  
\q2 karaphoekung e hui doeh.   
\q1
\v 25 Tami kâoup e lungthin ni kâyuenae a tâcokhai,  
\q2 hatei BAWIPA kâuep e teh a lamcawn han.   
\q1
\v 26 Amae pouknae ka kâuep e teh tamipathu doeh,  
\q2 hatei lungang lahoi kaawm e teh hlout lah ao han.   
\q1
\v 27 Tamimathoenaw hno ka poe e teh vout mahoeh,  
\q2 hatei ka roun e tami teh puenghoi thoebonae a hmu han.   
\q1
\v 28 Tamikathoutnaw a kangdue toteh  
\q2 taminaw amahmawk a kâhro awh,  
\q2 hatei a rawk awh toteh tamikalannaw a pung awh.   
\c 29  
\q1
\v 1 Voutsout yue eiteh a lahuen ka patak sak e tami teh,  
\q2 hawinae awm laipalah hmawi a rawk han.   
\q1
\v 2 Tamikalan ni kâtawnnae a tawn toteh tamimaya a konawm awh,  
\q2 hatei tamikathout ni a uk navah tamimaya a cingou awh.   
\q1
\v 3 Lungangnae ka ngai e ni a na pa a konawm sak,  
\q2 hatei kâyawt e hoi kamyawng e tami ni a hnopai koung a pâbaw.   
\q1
\v 4 Siangpahrang ni lawkcengnae lahoi ram a caksak,  
\q2 hatei tadawnghno ni ram a rawk sak.   
\q1
\v 5 A imri laithoe lahoi ka oup e teh a khok kâman nahanlah  
\q2 tamlawk a yangda pouh.   
\q1
\v 6 Kâtapoenae ni tamikathout a man,  
\q2 hatei tamikalan teh la sak lahoi a lunghawi.   
\q1
\v 7 Tamikalan ni tamimathoe hanlah a pouk,  
\q2 hatei tamikathout ni teh banglahai noutna hoeh.   
\q1
\v 8 Kadudamnaw ni khopui hmai a sawi,  
\q2 hatei tamilungkaang ni teh lungkhueknae a takhoe thai.   
\q1
\v 9 Tamilungkaang ni tamipathu hoi kâyue pawiteh,  
\q2 tamipathu a panui hai thoseh,  
\q2 a lungphuen hai thoseh banglahai tho hoeh.   
\q1
\v 10 Tami kathetnaw ni tamikalan a hmuhma awh,  
\q2 tamikalan teh hawinae hah a tawng.   
\q1
\v 11 Tamipathu ni a pouk e pueng hah a dei,  
\q2 hatei tamilungkaang ni teh a panguep.   
\q1
\v 12 Ukkung ni laithoe dei e banghai nahoeh tet pawiteh,  
\q2 a sannaw pueng teh tamikathout lah koung a coung awh.   
\q1
\v 13 Tamimathoe hoi repcoungroenaw ni cungtalah a hmawng e teh,  
\q2 BAWIPA ni a mit reirei a ang sak.   
\q1
\v 14 Atangcalah tamimathoe hanelah  
\q2 lawkcengkung siangpahrang teh,  
\q2 a bawitungkhung a yungyoe caksak lah ao han.   
\q1
\v 15 Bongpai hoi yuenae ni tami a lungangsak teh,  
\q2 ka pangak e camo ni a manu yeirai a po sak.   
\q1
\v 16 Tamikathout apapnae koe kâtapoenae apap,  
\q2 hatei tamikalan ni a rawk awh e hah a hmu.   
\q1
\v 17 Na capa hah yue yaw lannae na poe han,  
\q2 hothloilah hring nawmnae na poe han.   
\q1
\v 18 Vision ohoehnae koe tami pueng a thathoe awh,  
\q2 hatei kâlawk ka tarawi e teh tami yawkahawi e doeh.   
\q1
\v 19 San teh lawk hoi dueng yue thai lah awm hoeh,  
\q2 bangkongtetpawiteh a thai eiteh tarawi laipalah ao thai.   
\q1
\v 20 Pouk laipalah lawk ka deirumram e ouk na hmu ou,  
\q2 hot patet e tami koe hlak teh  
\q2 tamipathu koe ngaihawine bet aohnawn.   
\q1
\v 21 Camo nah ekvoi pahren e san teh a cue torei teh  
\q2 calan e lah ao han.   
\q1
\v 22 A lung ka khuek e ni kâyuenae a tâcokhai teh,  
\q2 ka matheng e ni kâtapoenae pou a tâcokhai.   
\q1
\v 23 Ma e kâoupnae ni na rahnoumsak han,  
\q2 hatei muitha lahoi kârahnoum e ni barinae a coe.   
\q1
\v 24 Tamru hoi kamyawng e teh  
\q2 amae hringnae ka hmuhma e tami doeh,  
\q2 lawkkatang dei hanelah thoe a kâbo ei dei kalawn hoeh.   
\q1
\v 25 Tami barinae ni karap patetlah na man,  
\q2 hatei BAWIPA kâuep e teh rungngang lah ao han.   
\q1
\v 26 Tami kapap ni ukkungnaw e lungyouknae hah a tawng awh,  
\q2 hatei taminaw hanelah lawkcengnae teh  
\q2 BAWIPA koehoi doeh a tho.   
\q1
\v 27 Tamikalanhoehe teh tamikalan hanelah panuet a tho e patetlah,  
\q2 tamikalan teh tamikalanhoehnaw hanelah panuet a tho van.   
\c 30  
\s1 Agur lungangnae  
\q1
\v 1 Jakeh capa Agur ni a dei e lawk.  
\q2 Ama ni Ithiel, Ithiel hoi Ucal koe hettelah a dei.   
\q1
\v 2 Tamipueng hlak tamipathu poung lah ka o teh,  
\q2 thaipanueknae hai ka tawn hoeh.   
\q1
\v 3 Lungangnae hai kamtu van hoeh niteh,  
\q2 tamikathoungnaw e panuenae hai ka tawn hoeh.   
\q1
\v 4 Kalvan ka luen ni teh ka kum e teh apimaw,  
\q2 Talai poutnae pueng kacaksakkung teh apimaw,  
\q2 A min apimaw, a capa min hai apimaw, na panue maw.   
\q1
\v 5 Cathut lawk pueng teh a thoung,  
\q2 ka kânguenaw pueng hanelah kânguenae lah ao.   
\q1
\v 6 A lawk hah thap hanh, hoehpawiteh na yue vaiteh,  
\q2 na laithoe e hah a hmu han.   
\q1
\v 7 Hno kahni touh ka hei han,  
\q2 ka due hoehnahlan na poe haw.   
\q1
\v 8 Ahrawnghrang hoi laithoenae heh kai hoi  
\q2 ahlanae koe na tat pouh haw, mathoenae nakunghai,  
\q2 tawntanae nakunghai na poe hanh,  
\q2 ka panki e rawca hoi na kawk haw.   
\q1
\v 9 Hoehpawiteh ka tawnta vaiteh na pahnawt payon vaih,  
\q2 BAWIPA teh apimaw, ka tet payon vaih.  
\q2 Hoehpawiteh, ka mathoe vaiteh hno ka parawt vaiteh  
\q2 Cathut min ka mathout sakpayon vaih.   
\q1
\v 10 San teh a bawi koe pathoe hanh,  
\q2 hoehpawiteh thoe na bo vaiteh,  
\q2 nang dawk yonnae ao han.   
\q1
\v 11 A na pa thoe a bo teh  
\q2 a manu yawhawi a poe ngaihoehnae se ao.   
\q1
\v 12 Ama mithmu vah kathoung poung lah kâpouknae ao,  
\q2 hatei a khinnae koehoi pâsu hoeh rah.   
\q1
\v 13 Khopouk ka rasang ni teh moungnae a o,  
\q2 a khopouk teh a rasang katang.   
\q1
\v 14 A hâ teh sendek patetlah,  
\q2 a hâkamnaw teh sarai patetlah a onae se a o,  
\q2 het talai van e tami mathoenaw hoi  
\q2 kavoutthoupnaw hah koung ca hanelah kakâcainaw doeh.   
\q1
\v 15 Tavat ni canu kahni touh a tawn teh,  
\q2 na poe na poe a ti.  
\q2 Ka boum thai hoeh e kathum touh ao.  
\q2 A khout toe ka tet boihoeh e hno pali touh a o   
\q1
\v 16 Tangkom, kating e thun,  
\q2 tui ka boum hoeh e talai,  
\q2 a khout toe ka tet boihoeh e hmai naw hah doeh.   
\q1
\v 17 A na pa ka dudam niteh  
\q2 a manu banglah ka noutna hoeh naw e mit teh,  
\q2 vonga ni a cawngkhawi pouh vaiteh,  
\q2 matawcanaw ni a ca awh han.   
\q1
\v 18 Kai hanlah kângairu hno kathum touh a o,  
\q2 ka thaipanuek hoeh e hno pali touh teh,   
\q1
\v 19 Kahlî dawk mataw kamlengnae lamthung,  
\q2 Lungphen van tahrun ceinae, tuipui van long ceinae,  
\q2 hoi thoundoun ni tangla painae lam naw hah doeh.   
\q1
\v 20 Napui kahawihoeh hai hottelah doeh ao van,  
\q2 a ca hnukkhu a pahni a hui teh yonnae ka sak hoeh, telah ouk a ti.   
\q1
\v 21 Hno kathum touh kecu talai heh taki hoi ouk a pâyaw,  
\q2 bokheiyah, hno pali touh khang thai hoeh e ao.   
\q1
\v 22 Siangpahrang lah kâsak e san,  
\q2 king ka boum e tamipathu,   
\q1
\v 23 Vâ ka sak e napui kathout,  
\q2 a bawipa e yu ka khawng e sannu hetnaw hah doeh.   
\q1
\v 24 Talaivan a thoungca eiteh  
\q2 a lungkaang e hno pali touh ao.   
\q1
\v 25 Atha awm hoeh eiteh kompawi vah  
\q2 ama hane rawca ka pâtung e lungkhi,   
\q1
\v 26 a tha ayoun eiteh  
\q2 lungha rahak kaawm e saveh.   
\q1
\v 27 siangpahrang tawn hoeh eiteh  
\q2 ahuhu lahoi ka cet e samtong,   
\q1
\v 28 a khok hoi a kâbang eiteh  
\q2 siangpahrang im kaawm e bombanaw hah doeh.   
\q1
\v 29 Hno kathum touh kahawicalah ka cet thai e a o,  
\q2 bokheiyah pali touh hah teh,   
\q1
\v 30 Saring pueng dawk athakaawme sendek,  
\q2 bang ni hai ngang thai hoeh.   
\q1
\v 31 Ransa marang, hmaetan,  
\q2 apinihai ngang thai hoeh e siangpahrang hetnaw hah doeh.   
\q1
\v 32 Mahoima kâtalue totouh na pathu pawiteh,  
\q2 hoehpawiteh hnokathout sak hanelah na kâcai pawiteh,  
\q2 na kut hoi na pahni tabuemh.   
\q1
\v 33 Bangkongtetpawiteh, maitosanutui kalaw e ni  
\q2 sanutuikamkak a tâcosak e patetlah,  
\q2 hnawng kapennae ni hnawngthi a lawng sak.  
\q2 Hot patetlah lungkhueknae ni kâyuenae a tâcokhai.   
\c 31  
\s1 Lemuel e lawknaw  
\q1
\v 1 Siangpahrang Lemuel lawk,  
\q2 a manu ni a cangkhai e naw teh:   
\q1
\v 2 Bangtelane ka capa, bangtelane ka khe e capa,  
\q2 bangtelane ka lawkkam capa.   
\q1
\v 3 Siangpahrangnaw patenghai karaphoekung napui koe  
\q2 na thaonae poe hanh.   
\q1
\v 4 Aw Lemuel, misurtui nei e hoi yamu nei e teh  
\q2 siangpahrangnaw hane nahoeh.   
\q1
\v 5 Hoehpawiteh, net awh vaiteh  
\q2 kâlawk pahnim awh vaiteh mathoenaw hanelah  
\q2 kalanhoehe lah lawkceng awh langvaih.   
\q1
\v 6 Meimei kadout e hah yamu pânei awh nateh,  
\q2 lungrei ka thai e hah misurtui pânei awh.   
\q1
\v 7 Net awh naseh, a reithainae hah pahnim awh naseh,  
\q2 a lungmathoenae pahnim totouh net awh naseh.   
\q1
\v 8 Lawkanaw hanlah dei pouh nateh,  
\q2 due hanelah lawk tâtueng pouh e naw hane hai dei pouh.   
\q1
\v 9 Kalan lah lawkceng nateh tamimathoe hoi  
\q2 tamikavout hanlah kâhet pouh.   
\s1 Yu kahawi  
\q1
\v 10 Yu kahawi apinimaw a hmu thai han.  
\q2 Bangkongtetpawiteh talung phukaawm hlak hai aphuohnawn.   
\q1
\v 11 A vâ ni a lungthin hoi a kâuep teh hawinae awm laipalah  
\q2 awm mahoeh.   
\q1
\v 12 A hring nathung thoenae laipalah  
\q2 hawinae dueng doeh a sak pouh.   
\q1
\v 13 Tumuen hoi pahla hah a tawng teh  
\q2 a kut hoi amahmawk ouk a tawk.   
\q1
\v 14 Hno ka yawt e long patetlah ao teh,  
\q2 ahlanae koehoi rawca ouk a thokhai.   
\q1
\v 15 Amom a thaw teh a imthungnaw hah rawca a paca teh,  
\q2 a sannunaw hah thaw rip a boun.   
\q1
\v 16 Lawhmuen hah a khet teh a ran,  
\q2 a tawkphu hoi misur takha a sak.   
\q1
\v 17 A keng dawk tha a kâyeng teh,  
\q2 a kuttha hai a patung.   
\q1
\v 18 Hno a yo e a mek tie a panue dawkvah  
\q2 tangmin patenghai hmaiim dout hoeh.   
\q1
\v 19 A kut hoi rahakut a kuet teh,  
\q2 avanglae kut hoi yâcung a kuet.   
\q1
\v 20 Tamimathoe hanelah a kut a kâyap,  
\q2 bokheiyah kavoutnaw totouh a kut ni koung a pha.   
\q1
\v 21 Tadamtui ka bawt nakunghai  
\q2 a imthungnaw hanelah taki hane awm hoeh,  
\q2 bangkongtetpawiteh a imthungnaw ni  
\q2 dikpalingca e khohna kabet e a khohna awh.   
\q1
\v 22 Ama hanlah hni a kawng teh,  
\q2 loukloukkaang e hoi pu doeh a khohna.   
\q1
\v 23 A vâ hai kho longkha koe khobawinaw hoi  
\q2 a tahung toteh mithmaiben e lah ao.   
\q1
\v 24 Loukloukkaang e hni a kawng teh a yo,  
\q2 hno kayawtnaw koe taisawm hah a yo.   
\q1
\v 25 A kawng e khohna teh a khaw,  
\q2 ahawi dawkvah ahni teh hmalah a konawm han.   
\q1
\v 26 Lungangnae hoi lawk a dei,  
\q2 a lawk teh pahrennae kâlawk lah ao.   
\q1
\v 27 A imthung khosaknae kahawicalah koung a khetyawt,  
\q2 rawca hai pamda laihoi cat boihoeh.   
\q1
\v 28 A canaw a thaw awh teh a manu koe a lunghawi awh.  
\q2 A vâ ni hai a oup van,   
\q1
\v 29 napui kapap ni kahawicalah a tawk awh toe,  
\q2 hatei nang ni ahnimanaw na tapuet toe, atipouh.   
\q1
\v 30 Raimonae teh dumnae doeh,  
\q2 meihawinae hai a yawmyin doeh.  
\q2 Hatei BAWIPA ka taket e napui teh oup lah ao han.   
\q1
\v 31 A kut hoi a tawk e a paw hah poe awh nateh,  
\q2 longkha koe ama roeroe hah a tawk e ni oup naseh.   