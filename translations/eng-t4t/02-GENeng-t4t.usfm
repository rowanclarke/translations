\mt2 This book contains the account of God making the world and everything there is and of his choosing the descendants of Abraham to be his people. We call this book
\mt1 Genesis
\c 1
\s1 God made the earth and the sky
\p 
\v 1 Long, long ago \w God|strong="H8064"\w* \w created|strong="H1254"\w* \w the|strong="H1254"\w* \w heavens|strong="H8064"\w* \w and|strong="H8064"\w* \w the|strong="H1254"\w* \w earth|strong="H8064"\w*.
\v 2 \w When|strong="H1961"\w* \w he|strong="H5921"\w* \w began|strong="H1961"\w* \w to|strong="H1961"\w* create \w the|strong="H6440"\w* earth, \w it|strong="H5921"\w* \w was|strong="H1961"\w* shapeless \w and|strong="H6440"\w* completely desolate/chaotic. \w Darkness|strong="H2822"\w* covered \w the|strong="H6440"\w* \w deep|strong="H8415"\w* \w water|strong="H4325"\w* \w that|strong="H4325"\w* surrounded \w the|strong="H6440"\w* earth. \w And|strong="H6440"\w* \w the|strong="H6440"\w* \w Spirit|strong="H7307"\w* \w of|strong="H6440"\w* God \w was|strong="H1961"\w* \w hovering|strong="H7363"\w* \w over|strong="H5921"\w* \w the|strong="H6440"\w* \w water|strong="H4325"\w*.
\v 3 God said, “\w I|strong="H1961"\w* want light \w to|strong="H1961"\w* shine!” \w And|strong="H1961"\w* light shone.
\v 4 God \w was|strong="H2896"\w* \w pleased|strong="H2896"\w* \w with|strong="H2896"\w* \w the|strong="H7200"\w* light. \w Then|strong="H7200"\w* \w he|strong="H3588"\w* made \w the|strong="H7200"\w* light \w to|strong="H7200"\w* shine \w in|strong="H7200"\w* some places, \w and|strong="H7200"\w* \w in|strong="H7200"\w* other places \w there|strong="H7200"\w* \w was|strong="H2896"\w* \w still|strong="H3588"\w* \w darkness|strong="H2822"\w*.
\v 5 \w He|strong="H3117"\w* \w gave|strong="H7121"\w* \w to|strong="H1961"\w* \w the|strong="H3117"\w* light \w the|strong="H3117"\w* \w name|strong="H7121"\w* ‘\w day|strong="H3117"\w*’, \w and|strong="H3117"\w* \w he|strong="H3117"\w* \w gave|strong="H7121"\w* \w to|strong="H1961"\w* \w the|strong="H3117"\w* \w darkness|strong="H2822"\w* \w the|strong="H3117"\w* \w name|strong="H7121"\w* ‘\w night|strong="H3915"\w*’. \w After|strong="H1961"\w* \w that|strong="H3117"\w*, \w there|strong="H1961"\w* \w was|strong="H1961"\w* \w an|strong="H1961"\w* \w evening|strong="H6153"\w* \w which|strong="H3117"\w* \w was|strong="H1961"\w* \w followed|strong="H1961"\w* \w by|strong="H3117"\w* \w a|strong="H3068"\w* \w morning|strong="H1242"\w*. \w He|strong="H3117"\w* \w called|strong="H7121"\w* \w that|strong="H3117"\w* \w whole|strong="H3117"\w* \w period|strong="H3117"\w* \w of|strong="H3117"\w* \w time|strong="H3117"\w* ‘\w the|strong="H3117"\w* \w first|strong="H3117"\w* \w day|strong="H3117"\w*’.
\v 6 \w Then|strong="H1961"\w* God said, “\w I|strong="H1961"\w* command \w that|strong="H4325"\w* \w there|strong="H1961"\w* \w be|strong="H1961"\w* \w an|strong="H1961"\w* empty space \w like|strong="H1961"\w* \w a|strong="H3068"\w* huge dome \w to|strong="H1961"\w* separate \w the|strong="H8432"\w* \w water|strong="H4325"\w* \w that|strong="H4325"\w* \w is|strong="H1961"\w* above \w it|strong="H8432"\w* \w from|strong="H1961"\w* \w the|strong="H8432"\w* \w water|strong="H4325"\w* \w on|strong="H1961"\w* \w the|strong="H8432"\w* earth \w that|strong="H4325"\w* \w is|strong="H1961"\w* below \w it|strong="H8432"\w*!”
\v 7 \w And|strong="H6213"\w* \w that|strong="H3651"\w* \w is|strong="H3651"\w* \w what|strong="H6213"\w* \w happened|strong="H1961"\w*. God \w gave|strong="H6213"\w* \w to|strong="H1961"\w* \w the|strong="H5921"\w* space \w the|strong="H5921"\w* name ‘sky’.
\v 8 \w Then|strong="H1961"\w* \w there|strong="H1961"\w* \w was|strong="H1961"\w* \w another|strong="H8145"\w* \w evening|strong="H6153"\w*, \w which|strong="H3117"\w* \w was|strong="H1961"\w* \w followed|strong="H1961"\w* \w by|strong="H3117"\w* \w another|strong="H8145"\w* \w morning|strong="H1242"\w*. \w He|strong="H3117"\w* \w called|strong="H7121"\w* \w that|strong="H3117"\w* \w period|strong="H3117"\w* \w of|strong="H3117"\w* \w time|strong="H3117"\w* ‘\w the|strong="H3117"\w* \w second|strong="H8145"\w* \w day|strong="H3117"\w*’.
\p 
\v 9 \w Then|strong="H1961"\w* \w God|strong="H8064"\w* \w said|strong="H3651"\w*, “\w I|strong="H3651"\w* want \w the|strong="H7200"\w* \w water|strong="H4325"\w* \w that|strong="H7200"\w* \w is|strong="H3651"\w* \w below|strong="H8478"\w* \w the|strong="H7200"\w* \w sky|strong="H8064"\w* \w to|strong="H1961"\w* \w come|strong="H1961"\w* \w together|strong="H6960"\w*, \w and|strong="H8064"\w* \w dry|strong="H3004"\w* \w ground|strong="H3004"\w* \w to|strong="H1961"\w* \w appear|strong="H7200"\w* \w and|strong="H8064"\w* \w rise|strong="H4325"\w* above \w the|strong="H7200"\w* \w water|strong="H4325"\w*.” \w And|strong="H8064"\w* \w that|strong="H7200"\w* \w is|strong="H3651"\w* \w what|strong="H7200"\w* \w happened|strong="H1961"\w*.
\v 10 God \w gave|strong="H7121"\w* \w to|strong="H4325"\w* \w the|strong="H7200"\w* \w ground|strong="H3004"\w* \w the|strong="H7200"\w* \w name|strong="H7121"\w* ‘earth’, \w and|strong="H7200"\w* \w he|strong="H3588"\w* \w gave|strong="H7121"\w* \w to|strong="H4325"\w* \w the|strong="H7200"\w* \w water|strong="H4325"\w* \w that|strong="H3588"\w* \w came|strong="H4325"\w* \w together|strong="H7121"\w* \w the|strong="H7200"\w* \w name|strong="H7121"\w* ‘oceans’. God \w was|strong="H4325"\w* \w pleased|strong="H2896"\w* \w with|strong="H4325"\w* \w the|strong="H7200"\w* earth \w and|strong="H7200"\w* \w the|strong="H7200"\w* oceans.
\v 11 \w Then|strong="H1961"\w* God \w said|strong="H3651"\w*, “\w I|strong="H5921"\w* want \w the|strong="H5921"\w* earth \w to|strong="H1961"\w* \w produce|strong="H6529"\w* \w plants|strong="H6212"\w*, including \w plants|strong="H6212"\w* \w that|strong="H3651"\w* \w will|strong="H1961"\w* \w produce|strong="H6529"\w* \w seeds|strong="H2233"\w* \w and|strong="H6086"\w* \w trees|strong="H6086"\w* \w that|strong="H3651"\w* \w will|strong="H1961"\w* \w produce|strong="H6529"\w* \w fruit|strong="H6529"\w*. Each \w kind|strong="H4327"\w* \w of|strong="H2233"\w* \w tree|strong="H6086"\w* \w will|strong="H1961"\w* \w bear|strong="H6213"\w* \w its|strong="H5921"\w* \w own|strong="H1961"\w* \w kind|strong="H4327"\w* \w of|strong="H2233"\w* \w fruit|strong="H6529"\w*.”
\v 12 \w Then|strong="H3318"\w* \w plants|strong="H6212"\w* grew \w on|strong="H7200"\w* \w the|strong="H7200"\w* earth; each \w kind|strong="H4327"\w* \w of|strong="H2233"\w* \w plant|strong="H6212"\w* began \w to|strong="H3318"\w* \w produce|strong="H6529"\w* \w its|strong="H6213"\w* own \w kind|strong="H4327"\w* \w of|strong="H2233"\w* \w seed|strong="H2233"\w*.
\v 13 \w Then|strong="H1961"\w* \w there|strong="H1961"\w* \w was|strong="H1961"\w* another \w evening|strong="H6153"\w* \w which|strong="H3117"\w* \w was|strong="H1961"\w* \w followed|strong="H1961"\w* \w by|strong="H3117"\w* another \w morning|strong="H1242"\w*. God called \w that|strong="H3117"\w* \w period|strong="H3117"\w* \w of|strong="H3117"\w* \w time|strong="H3117"\w* ‘\w the|strong="H3117"\w* \w third|strong="H7992"\w* \w day|strong="H3117"\w*’.
\p 
\v 14 \w Then|strong="H1961"\w* \w God|strong="H8064"\w* said, “\w I|strong="H3117"\w* want \w a|strong="H3068"\w* sun, \w a|strong="H3068"\w* moon, \w and|strong="H3117"\w* many stars \w to|strong="H1961"\w* shine \w in|strong="H8141"\w* \w the|strong="H3117"\w* \w sky|strong="H8064"\w*. \w The|strong="H3117"\w* sun \w will|strong="H1961"\w* shine \w in|strong="H8141"\w* \w the|strong="H3117"\w* daytime \w and|strong="H3117"\w* \w the|strong="H3117"\w* moon \w and|strong="H3117"\w* stars \w will|strong="H1961"\w* shine \w during|strong="H3117"\w* \w the|strong="H3117"\w* nighttime. \w By|strong="H8141"\w* \w the|strong="H3117"\w* changes \w in|strong="H8141"\w* \w their|strong="H1961"\w* appearance \w they|strong="H3117"\w* \w will|strong="H1961"\w* indicate \w the|strong="H3117"\w* various \w seasons|strong="H4150"\w* (\w OR|strong="H3068"\w*, \w the|strong="H3117"\w* \w times|strong="H3117"\w* \w for|strong="H3117"\w* special celebrations), \w and|strong="H3117"\w* \w will|strong="H1961"\w* enable people \w to|strong="H1961"\w* know \w when|strong="H1961"\w* \w days|strong="H3117"\w* \w and|strong="H3117"\w* \w years|strong="H8141"\w* begin.
\v 15 \w I|strong="H5921"\w* want \w them|strong="H5921"\w* \w also|strong="H8064"\w* \w to|strong="H1961"\w* \w be|strong="H1961"\w* \w like|strong="H1961"\w* \w lights|strong="H3974"\w* \w in|strong="H5921"\w* \w the|strong="H5921"\w* \w sky|strong="H8064"\w* \w that|strong="H3651"\w* \w will|strong="H1961"\w* shine \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w earth|strong="H8064"\w*.” \w And|strong="H8064"\w* \w that|strong="H3651"\w* \w is|strong="H3651"\w* \w what|strong="H5921"\w* \w happened|strong="H1961"\w*.
\v 16 God \w made|strong="H6213"\w* \w two|strong="H8147"\w* \w of|strong="H3117"\w* \w them|strong="H6213"\w* \w that|strong="H3117"\w* \w were|strong="H3117"\w* \w like|strong="H6213"\w* big \w lights|strong="H3974"\w*. \w The|strong="H6213"\w* \w bigger|strong="H1419"\w* \w one|strong="H6996"\w*, \w the|strong="H6213"\w* sun, shines \w during|strong="H3117"\w* \w the|strong="H6213"\w* \w day|strong="H3117"\w* \w and|strong="H3117"\w* \w the|strong="H6213"\w* \w smaller|strong="H6996"\w* \w one|strong="H6996"\w*, \w the|strong="H6213"\w* moon, shines \w during|strong="H3117"\w* \w the|strong="H6213"\w* \w night|strong="H3915"\w*. \w He|strong="H3117"\w* \w also|strong="H6213"\w* \w made|strong="H6213"\w* \w the|strong="H6213"\w* \w stars|strong="H3556"\w*.
\v 17 \w God|strong="H5414"\w* \w set|strong="H5414"\w* \w all|strong="H5414"\w* \w of|strong="H5921"\w* \w them|strong="H5414"\w* \w in|strong="H5921"\w* \w the|strong="H5921"\w* \w sky|strong="H8064"\w* \w to|strong="H5921"\w* shine \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w earth|strong="H8064"\w*,
\v 18 \w to|strong="H3117"\w* \w rule|strong="H4910"\w* \w the|strong="H7200"\w* \w day|strong="H3117"\w* \w and|strong="H3117"\w* \w the|strong="H7200"\w* \w night|strong="H3915"\w*, \w and|strong="H3117"\w* \w to|strong="H3117"\w* separate \w the|strong="H7200"\w* light \w of|strong="H3117"\w* \w the|strong="H7200"\w* daytime \w from|strong="H3117"\w* \w the|strong="H7200"\w* \w darkness|strong="H2822"\w* \w of|strong="H3117"\w* \w the|strong="H7200"\w* nighttime. God \w was|strong="H3117"\w* \w pleased|strong="H2896"\w* \w with|strong="H3117"\w* \w these|strong="H3117"\w* \w things|strong="H2896"\w* \w he|strong="H3588"\w* \w had|strong="H3588"\w* made.
\v 19 \w Then|strong="H1961"\w* \w there|strong="H1961"\w* \w was|strong="H1961"\w* another \w evening|strong="H6153"\w* \w which|strong="H3117"\w* \w was|strong="H1961"\w* \w followed|strong="H1961"\w* \w by|strong="H3117"\w* another \w morning|strong="H1242"\w*. \w He|strong="H3117"\w* called \w that|strong="H3117"\w* \w period|strong="H3117"\w* \w of|strong="H3117"\w* \w time|strong="H3117"\w* ‘\w the|strong="H3117"\w* \w fourth|strong="H7243"\w* \w day|strong="H3117"\w*’.
\v 20 Then \w God|strong="H8064"\w* said, “\w I|strong="H5921"\w* \w want|strong="H5315"\w* many \w creatures|strong="H2416"\w* \w to|strong="H5921"\w* \w live|strong="H2416"\w* \w in|strong="H5921"\w* \w all|strong="H5921"\w* \w the|strong="H6440"\w* oceans, \w and|strong="H8064"\w* \w I|strong="H5921"\w* \w also|strong="H5315"\w* \w want|strong="H5315"\w* \w birds|strong="H5775"\w* \w to|strong="H5921"\w* \w fly|strong="H5774"\w* \w in|strong="H5921"\w* \w the|strong="H6440"\w* \w sky|strong="H8064"\w* \w above|strong="H5921"\w* \w the|strong="H6440"\w* \w earth|strong="H8064"\w*.”
\v 21 \w So|strong="H3588"\w* God \w created|strong="H1254"\w* huge \w sea|strong="H8577"\w* \w creatures|strong="H2416"\w* \w and|strong="H1419"\w* \w every|strong="H3605"\w* \w other|strong="H3605"\w* \w kind|strong="H4327"\w* \w of|strong="H4325"\w* \w creature|strong="H5315"\w* \w that|strong="H3588"\w* \w moves|strong="H7430"\w* \w in|strong="H5315"\w* \w the|strong="H3605"\w* \w water|strong="H4325"\w*, \w and|strong="H1419"\w* caused \w them|strong="H7200"\w* \w to|strong="H4325"\w* \w live|strong="H2416"\w* \w in|strong="H5315"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* oceans. \w He|strong="H3588"\w* \w also|strong="H5315"\w* \w created|strong="H1254"\w* \w many|strong="H7200"\w* \w kinds|strong="H4327"\w* \w of|strong="H4325"\w* \w birds|strong="H5775"\w*. God \w was|strong="H5315"\w* \w pleased|strong="H2896"\w* \w with|strong="H5315"\w* \w all|strong="H3605"\w* \w those|strong="H3605"\w* \w creatures|strong="H2416"\w*.
