\p
\v 22 \w Ils|strong="H6440"\w* \w tombèrent|strong="H5307"\w* \w le|strong="H6440"\w* \w visage|strong="H6440"\w* \w contre|strong="H6440"\w* \w terre|strong="H6440"\w*, \w et|strong="H6440"\w* \w dirent|strong="H6440"\w* : « Ô \w Dieu|strong="H6440"\w*, \w Dieu|strong="H6440"\w* \w des|strong="H6440"\w* \w esprits|strong="H7307"\w* \w de|strong="H6440"\w* \w toute|strong="H3605"\w* \w chair|strong="H1320"\w* ! \w Un|strong="H6440"\w* \w seul|strong="H6440"\w* \w homme|strong="H6440"\w* \w a|strong="H3068"\w* \w péché|strong="H2398"\w*, \w et|strong="H6440"\w* \w tu|strong="H6440"\w* \w t|strong="H6440"\w*'\w irriterais|strong="H7107"\w* \w contre|strong="H6440"\w* \w toute|strong="H3605"\w* \w la|strong="H6440"\w* communauté ? »   
\p
\v 23 \w Le|strong="H3068"\w* \w SEIGNEUR|strong="H1696"\w* \w parla|strong="H1696"\w* \w à|strong="H3068"\w* \w Moïse|strong="H4872"\w* :  
\v 24 « \w Parle|strong="H1696"\w* \w à|strong="H1696"\w* \w la|strong="H5927"\w* communauté \w et|strong="H5927"\w* dis-lui : « Éloignez-vous \w des|strong="H5927"\w* \w environs|strong="H5439"\w* \w de|strong="H5927"\w* \w la|strong="H5927"\w* \w tente|strong="H5927"\w* \w de|strong="H5927"\w* Coré, \w de|strong="H5927"\w* \w Dathan|strong="H1885"\w* \w et|strong="H5927"\w* d'Abiram ! » »   
\p
