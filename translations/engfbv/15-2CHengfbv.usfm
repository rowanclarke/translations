\p
\v 15 \w Now|strong="H5921"\w* \w my|strong="H3605"\w* lord, please \w send|strong="H5927"\w* \w to|strong="H5927"\w* \w us|strong="H5921"\w* \w his|strong="H3605"\w* servants \w the|strong="H3605"\w* wheat, barley, olive oil, \w and|strong="H6086"\w* wine \w he|strong="H3605"\w* spoke \w about|strong="H5921"\w*.  
