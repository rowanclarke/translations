\id PRO - Biblica® Open Ewe Contemporary Scriptures 2020 
\h Lododowo 
\toc1 Salomo ƒe Lododowo 
\toc2 Lododowo 
\toc3 Lod 
\mt1 Salomo 
\mt2 ƒe Lododowo 
\c 1  
\ms1 Susu si ta woŋlɔ Salomo ƒe lododowo ɖo kple nyati si dzi wotui ɖo 
\p  
\v 1 Israel fia Solomo, David ƒe vi ƒe lododowo nye esiawo: 
\q1  
\v 2 na nunya kple amehehe, 
\q2 na nya goglowo gɔmesese, 
\q1  
\v 3 hena agbe dzɔdzɔe kple agbe ɖevi nɔnɔ, 
\q2 be woawɔ nu si dzɔ, 
\q2 nu si le eteƒe kple nu si nyo, 
\q1  
\v 4 be ame gblɔewo nadze aɖaŋu eye woana nunya 
\q2 kple sidzedze sɔhɛwo, 
\q1  
\v 5 nunyalawo neɖo to, 
\q2 ne woasrɔ̃ nu akpe ɖe esi wonya xoxo la ŋu 
\q2 eye ame siwo si sidzedze le xoxo la naxɔ aɖaŋu, 
\q1  
\v 6 be woase nunyalawo ƒe lododowo 
\q2 abebubuwo kple adzowo gɔme. 
\b  
\q1  
\v 7 Yehowa vɔvɔ̃e nye nunya ƒe gɔmedzedze, 
\q2 ke bometsilawo doa vlo nunya kple amehehe. 
\ms1 Dzidede ƒo na amewo be woasrɔ̃ nunya 
\s1 Nuxɔxlɔ̃ amewo le ha baɖa dede ŋuti 
\q1  
\v 8 Vinye, ɖo to fofowò ƒe nuxɔxlɔ̃ 
\q2 eye mègagbe nu le dawò ƒe nufiame gbɔ o. 
\q1  
\v 9 Anye seƒoƒokuku aɖo atsyɔ̃ na wò ta 
\q2 kple kɔga anɔ kɔwò. 
\b  
\q1  
\v 10 Vinye, ne nu vɔ̃ wɔlawo le nuwò blem la, 
\q2 mègalɔ̃ na wo o. 
\q1  
\v 11 Ne wogblɔ na wò be, 
\q2 “Va kplɔ mí ɖo, 
\q1 na míade xa ɖe ame aɖe ƒe ʋu ŋuti, 
\q2 na míanɔ xame na luʋɔ maɖifɔ aɖe, 
\q1  
\v 12 ne míamii agbagbee abe tsiẽƒe ene, 
\q2 eye míamii blibo abe ame siwo ge dze ʋe globo me ene 
\q1  
\v 13 ekema nu xɔasi vovovowo asu mía si 
\q2 eye míatsɔ afunyinuwo ayɔ míaƒe xɔwo mee 
\q1  
\v 14 eya ta de mía dzi 
\q2 ale be míana gakotoku ɖeka wò” la, 
\q1  
\v 15 vinye, mègakplɔ wo ɖo o, 
\q2 mègaka afɔ woƒe toƒewo o 
\q1  
\v 16 elabena woƒe afɔ ɖea abla ɖe nu vɔ̃ ŋu 
\q2 eye wogona ɖe ʋukɔkɔɖi ŋu. 
\q1  
\v 17 Enye movidzɔdzɔ be woaɖo ɖɔ ɖi na xeviwo 
\q2 le wo katã ƒe ŋkume! 
\q1  
\v 18 Ame siawo de xa ɖi na woawo ŋutɔ 
\q2 ƒe ʋu eye wole adeklo dzi ɖe woawo ŋutɔ ɖokuiwo ŋu! 
\q1  
\v 19 Aleae ame siwo tia viɖe ƒoɖi yome la ƒe nuwuwu anɔ, 
\q2 elabena eɖea ame siwo ƒe asi su edzi la ƒe agbe ɖa. 
\s1 Nuxɔxlɔ̃ amewo le nunyagbegbe ŋuti 
\q1  
\v 20 Nunya le ɣli dom le mɔtata dzi 
\q2 eye wòkɔ gbe dzi le ƒuƒoƒewo. 
\q1  
\v 21 Ele ɣli dom le mɔtata siwo dzi zinyenye 
\q2 le la ƒe dzogoewo dzi eye wòle eƒe nyawo gblɔm 
\q2 le dua ƒe agbowo me be, 
\b  
\q1  
\v 22 “Va se ɖe ɣe ka ɣi mi gegemewo mialɔ̃ bometsinuwɔwɔ? 
\q2 Va se ɖe ɣe ka yi fewuɖulawo akpɔ dzidzɔ le fewuɖuɖu ŋu, 
\q2 bometsilawo alé fu sidzedze? 
\q1  
\v 23 Ne ɖe mietrɔ ɖe nye mokaname ŋu la, 
\q2 anye ne metrɔ nye dzi kɔ ɖe anyi na mi 
\q2 eye mena mienya nye susuwo. 
\q1  
\v 24 Ke esi miegbe tɔtɔ nam esi meyɔ mi, 
\q2 esi meke nye abɔwo me, 
\q2 mietsɔ ɖeke le eme o 
\q1  
\v 25 eye miedo toku nye aɖaŋuɖoɖowo, 
\q2 hegbe nye mokaname ta la, 
\q1  
\v 26 nye hã mako mi le miaƒe gbegblẽ ta 
\q2 eye maɖe alɔme le mia ŋu ne dzɔgbevɔ̃e ƒo ɖe mia dzi, 
\q1  
\v 27 ɛ̃, ne eƒo ɖe mia dzi abe ahom sesẽ ene, 
\q2 gbegblẽ hã zɔ to mia dzi abe yali ene, 
\q2 eye xaxa kple hiã va mia dzi kpoyi! 
\b  
\q1  
\v 28 “Ekema woayɔm gake nyematɔ o, 
\q2 woadim gake womakpɔm o. 
\q1  
\v 29 Le esi wolé fu sidzedze 
\q2 eye wometia Yehowavɔvɔ̃ o, 
\q1  
\v 30 le esi wogbe nye aɖaŋuɖoɖo 
\q2 hedo vlo nye mokaname ta. 
\q1  
\v 31 Azɔ la woaɖu woƒe mɔwo ƒe kutsetse 
\q2 eye woƒe ɖoɖowo ƒe kutsetse aɖi ƒo na wo 
\q1  
\v 32 elabena gegemewo ƒe afɔɖeɖe baɖawo awu wo 
\q2 eye bometsilawo ƒe ɖekematsɔleme atsrɔ̃ wo. 
\q1  
\v 33 Ke ame sia ame si ɖoa tom la, anɔ agbe le dedinɔnɔ me 
\q2 eye aɖe dzi ɖi bɔkɔɔ, mavɔ̃ na dzɔgbevɔ̃e o.” 
\c 2  
\s1 Agbe nyui nɔnɔ si doa go tso nunya me ƒe viɖe 
\q1  
\v 1 Vinye, ne èxɔ nye nyawo 
\q2 eye nèdzra nye sededewo ɖo ɖe mewò, 
\q1  
\v 2 ne ètrɔ to ɖe nunya ŋu 
\q2 hetsɔ wò dzi na gɔmesese, 
\q1  
\v 3 ne èyɔ sidzedze 
\q2 eye nèdo ɣli na gɔmesese, 
\q1  
\v 4 ne èdii abe klosalo 
\q2 alo kesinɔnu si woɣla ene la, 
\q1  
\v 5 ekema àse Yehowavɔvɔ̃ gɔme 
\q2 eye àke ɖe Mawu nyanya ŋu 
\q1  
\v 6 elabena Yehowae naa nunya, 
\q2 eye sidzedze kple gɔmesese doa go tso eƒe nu me. 
\q1  
\v 7 Eɖo dziɖuɖu ɖi na nuteƒewɔlawo 
\q2 eye wònye akpoxɔnu na ame siwo ƒe zɔzɔme ŋu fɔɖiɖi mele o, 
\q1  
\v 8 elabena edzɔa ame dzɔdzɔewo ƒe toƒewo ŋu 
\q2 eye wòkpɔa eƒe nuteƒewɔlawo ƒe mɔwo ta. 
\b  
\q1  
\v 9 Ekema àse nu si nyo, 
\q2 le dzɔdzɔe eye wòdze la gɔme, 
\q2 ɛ̃, àse mɔ nyui ɖe sia ɖe gɔme, 
\q1  
\v 10 elabena nunya age ɖe wò dzi me, 
\q2 eye sidzedze ado dzidzɔ na wò luʋɔ. 
\q1  
\v 11 Tamebubu nyui akpɔ tawò, 
\q2 eye gɔmesese adzɔ ŋuwò. 
\b  
\q1  
\v 12 Nunya aɖe wò tso ame vɔ̃ɖiwo ƒe mɔwo dzi, 
\q2 tso nya tovo gblɔlawo ƒe asi me, 
\q1  
\v 13 ame siwo gblea mɔ dzɔdzɔetɔwo ɖi hezɔna 
\q2 le mɔ doblukɔwo dzi, 
\q1  
\v 14 ame siwo nu gbegblẽ wɔwɔ doa dzidzɔ na, 
\q2 eye wotsoa aseye le nu tovo ƒe vɔ̃ɖinyenye ŋu, 
\q1  
\v 15 ame siwo ƒe mɔwo glɔ̃ 
\q2 eye wotrana le woƒe mɔwo dzi. 
\b  
\q1  
\v 16 Nunya aɖe wò le nyɔnu ahasitɔ hã ƒe asi me 
\q2 kple srɔ̃nyɔnu si da afɔ la ƒe amenubeble me 
\q1  
\v 17 ame si gblẽ eƒe ɖetugbimesrɔ̃ ɖi 
\q2 eye mewɔ ɖe nu si wòbla kplii 
\q2 le Mawu ŋkume la dzi o 
\q1  
\v 18 elabena eƒe aƒe ɖo ta ku me 
\q2 eye eƒe mɔwo ɖo ta ame siwo le tsiẽƒe la ƒe gbɔgbɔwo gbɔ. 
\q1  
\v 19 Ame siwo katã yia egbɔ la megatrɔna gbɔna loo 
\q2 alo gena ɖe agbemɔ la dzi o. 
\b  
\q1  
\v 20 Ale àto ame nyuiwo ƒe mɔwo dzi 
\q2 eye àlé ame dzɔdzɔewo ƒe mɔwo ɖe asi. 
\q1  
\v 21 Ame dzɔdzɔewo anɔ anyigba dzi 
\q2 eye ame maɖifɔwo asusɔ ɖe edzi 
\q1  
\v 22 gake woatsrɔ̃ ame vɔ̃ɖiwo ɖa le anyigba dzi 
\q2 eye woaho nuteƒemawɔlawo ɖa le edzi. 
\c 3  
\s1 Nunya ƒe viɖe bubuwo 
\q1  
\v 1 Vinye, mègaŋlɔ nye nufiame be o, 
\q2 eye nàlé nye sededewo ɖe wò dzi me, 
\q1  
\v 2 elabena woadidi wò agbenɔƒewo ɖe edzi 
\q2 ƒe geɖe, eye woahe dzidzedzekpɔkpɔ vɛ na wò. 
\b  
\q1  
\v 3 Lɔlɔ̃ kple nuteƒewɔwɔ megate ɖa le gbɔwò gbeɖe o, 
\q2 tsɔ wo de kɔ eye nàŋlɔ wo ɖe wò dzi ƒe nuŋlɔkpe dzi. 
\q1  
\v 4 Ekema àkpɔ amenuveve kple ŋkɔ nyui 
\q2 le Mawu kple amewo ŋkume. 
\b  
\q1  
\v 5 Ɖo ŋu ɖe Yehowa ŋu kple wò dzi blibo, 
\q2 mègaku ɖe wò ŋutɔ wò nugɔmesese ŋu o; 
\q1  
\v 6 ɖo ŋu ɖe eŋu le wò mɔwo katã dzi 
\q2 ekema awɔ wò toƒewo dzɔdzɔe. 
\b  
\q1  
\v 7 Mèganye nunyala le wò ŋutɔ wò ŋkume o, 
\q2 ke boŋ vɔ̃ Yehowa eye nàtsri vɔ̃. 
\q1  
\v 8 Esia ahe dɔyɔyɔ vɛ na wò ŋutilã 
\q2 kple nunyiame vɛ na wò ƒuwo. 
\b  
\q1  
\v 9 De bubu Yehowa ŋu kple wò kesinɔnuwo 
\q2 kple wò agblemenukuwo ƒe ŋgɔgbetɔwo, 
\q1  
\v 10 ekema wò avawo ayɔ agbagba, 
\q2 eye wain yeye ayɔ wò ahazewo agbagba. 
\b  
\q1  
\v 11 Vinye, mègado vlo Yehowa ƒe amehehe o 
\q2 eye mègagbe eƒe mokaname o 
\q1  
\v 12 elabena Yehowa ɖɔa ame siwo wòlɔ̃ la ɖo 
\q2 abe ale si fofo wɔna na vi si ƒe nu dzea eŋu la ene. 
\b  
\q1  
\v 13 Woayra ame si ke ɖe nunya ŋu 
\q2 kple ame si si gɔmesese su 
\q1  
\v 14 elabena nunya xɔ asi wu klosalo 
\q2 eye viɖe geɖe le eme wu sika. 
\q1  
\v 15 Asixɔxɔ le eŋu wu adzagba 
\q2 eye nu siwo katã dim nèle la, 
\q2 ɖeke mesɔ kplii o. 
\q1  
\v 16 Agbe didi le eƒe ɖusi ƒe asi me, 
\q2 eye kesinɔnuwo kple bubu le eƒe miasi ƒe asi me. 
\q1  
\v 17 Eƒe mɔwo nye mɔ siwo dzi vivi le 
\q2 eye ŋutifafa le eƒe toƒewo katã. 
\q1  
\v 18 Enye agbeti na ame siwo xɔ eya amea 
\q2 eye ame siwo ƒe asi su edzi la woayra wo. 
\b  
\q1  
\v 19 Nunyae Yehowa tsɔ ɖo anyigba la ƒe gɔmeɖokpe anyii 
\q2 eye wòtsɔ gɔmesese ɖo dziƒowo ɖe wo teƒe. 
\q1  
\v 20 Etsɔ eƒe nunya ma gogloƒewoe 
\q2 eye lilikpowo dzaa zãmu. 
\b  
\q1  
\v 21 Vinye, lé afia nyui tsotso kple sidzedze me ɖe asi, 
\q2 mègana woadzo le ŋkuwòme o. 
\q1  
\v 22 Woanye agbe na wò 
\q2 kple kɔga aɖo atsyɔ̃ na wò kɔ. 
\q1  
\v 23 Ekema àlé wò mɔ atsɔ le dedinɔnɔ me 
\q2 eye wò afɔ maɖiɖi o. 
\q1  
\v 24 Ne èmlɔ anyi la, màvɔ̃ o, 
\q2 ne èmlɔ anyi la, àdɔ alɔ̃ vivi. 
\q1  
\v 25 Mègavɔ̃ ŋɔdzi si ava kpoyi 
\q2 alo gbegblẽ si vaa ame vɔ̃ɖiwo dzi o 
\q1  
\v 26 elabena Yehowa anye wò dzideƒo 
\q2 eye mana wò afɔ naɖo mɔ me o. 
\b  
\q1  
\v 27 Mègagbe nyuiwɔwɔ na ame siwo dze nɛ, 
\q2 ne ele wò ŋusẽ me be nàwɔe o. 
\q1  
\v 28 Mègagblɔ na wò aƒelika be, 
\q2 “Yi nàtrɔ va, etsɔ matsɔe na wò” esi wòle asiwò fifia o. 
\q1  
\v 29 Mègaɖo vɔ̃ ɖe wò aƒelika, 
\q2 ame si le gbɔwò le anukwareɖiɖi me la ŋu o. 
\q1  
\v 30 Mègatsɔ nya ɖe ame aɖeke ŋu dzodzro 
\q2 esi mewɔ vɔ̃ aɖeke ɖe ŋuwò o. 
\b  
\q1  
\v 31 Mègabiã ŋu ŋutsu nu sesẽ wɔla 
\q2 alo azɔ le eƒe mɔ aɖeke dzi o, 
\q1  
\v 32 elabena Yehowa nyɔa ŋu ŋutsu nu tovo wɔla 
\q2 gake elɔ̃a ame siwo wɔa nu dzɔdzɔe. 
\b  
\q1  
\v 33 Yehowa ƒe fiƒode le ame vɔ̃ɖiwo 
\q2 ƒe aƒe dzi, ke eyrana ɖe ame dzɔdzɔewo ƒe aƒe dzi. 
\q1  
\v 34 Yehowa ɖua fewu le dadala fewuɖulawo ŋu, 
\q2 ke evea ame siwo bɔbɔa wo ɖokui la nu. 
\q1  
\v 35 Nunyalawo nyia bubu ƒe dome, 
\q2 ke bometsilawo la, etsɔa wo dea asi na ŋukpe. 
\c 4  
\s1 Nunya ƒo nuwo katã ta 
\q1  
\v 1 Vinyewo, mise mia fofo ƒe nufiame; 
\q2 miɖo to ne miaxɔ gɔmesese. 
\q1  
\v 2 Nusɔsrɔ̃ deto mele mia nam 
\q2 eya ta migagbe nye nufiafia o. 
\q1  
\v 3 Esi menye ɖevi sue kple vi fɛ̃ le fofonye ƒe aƒe me 
\q2 kple vi ɖekɛ na danye la, 
\q1  
\v 4 efia num hegblɔ be, 
\q2 “Ku ɖe nye nyawo ŋu kple wò dzi katã, 
\q2 lé nye sededewo me ɖe asi ekema ànɔ agbe. 
\q1  
\v 5 Dze nunya, di gɔmesese, 
\q2 mègaŋlɔ nye nyawo be alo aƒo asa na wo o. 
\q1  
\v 6 Mègagbe nu le nunya gbɔ o ekema adzɔ ŋuwò, 
\q2 lɔ̃e ekema akpɔ tawò. 
\q1  
\v 7 Nunya ƒo nuwo katã ta 
\q2 eya ta dze nunya. 
\q1 Togbɔ be wò nunɔamesiwo katã nàtsɔ aƒlee hã la, 
\q2 di gɔmesese. 
\q1  
\v 8 De asixɔxɔ eŋu ekema ado wò ɖe dzi, 
\q2 xɔe atuu ekema ade bubu ŋuwò. 
\q1  
\v 9 Atsɔ amenuveve aɖɔ na wò ta abe seƒoƒotsihe ene 
\q2 eye wòatsɔ atsyɔ̃fiakuku aɖɔ na wò.” 
\b  
\q1  
\v 10 Ɖo to afii, vinye, 
\q2 ne nàxɔ nye nyawo, ekema wò agbenɔƒewo asɔ gbɔ fũu. 
\q1  
\v 11 Mele nunya ƒe mɔ fiam wò 
\q2 eye mekplɔ wò to toƒe dzɔdzɔewo. 
\q1  
\v 12 Ne èle zɔzɔm la, naneke maxe mɔ na wò 
\q2 afɔɖeɖewo o eye ne èsi du la, màkli nu o. 
\q1  
\v 13 Lé nufiame ɖe asi, mègana wòado le asiwò o; 
\q2 dzɔ eŋuti nyuie elabena eyae nye agbe na wò. 
\q1  
\v 14 Mègaka afɔ ame vɔ̃ɖiwo ƒe toƒewo 
\q2 alo nàzɔ ame vɔ̃ɖiwo ƒe mɔ dzi o. 
\q1  
\v 15 Ƒo asa na woƒe mɔwo, mègazɔ wo dzi o, 
\q2 lé wò mɔ tsɔ nàyi afi si yim nèle 
\q1  
\v 16 elabena ne womewɔ nu vɔ̃ɖi o kpaa, 
\q2 womedɔa alɔ̃ o eye womedɔa akɔlɔ̃e teti hã o 
\q2 va se ɖe esime woana ame aɖe nadze anyi. 
\q1  
\v 17 Woɖua vɔ̃ɖinyenye ƒe abolo 
\q2 eye wonoa nu sesẽ wɔwɔ ƒe wain. 
\b  
\q1  
\v 18 Ke ame dzɔdzɔewo ƒe toƒe le abe ŋdi kanya ƒe ɣetotoe ene, 
\q2 eklẽna, gaklẽna ɖe edzi ne ŋu ɖe le eme nyuie. 
\q1  
\v 19 Ke ame vɔ̃ɖiwo ƒe mɔ le abe viviti tsiɖitsiɖi ene 
\q2 eye womenya nu si na wole nu klim o. 
\b  
\q1  
\v 20 Vinye, lé to ɖe nye nyawo ŋu 
\q2 eye nàƒu to anyi ɖe nya si gblɔm mele la ŋu. 
\q1  
\v 21 Mègana woadzo le wò ŋkume o, 
\q2 ke boŋ dzra wo ɖo ɖe wò dzi me, 
\q1  
\v 22 elabena wonye agbe na ame siwo 
\q2 ke ɖe wo ŋu kple dɔyɔyɔ na ame ƒe ŋutilã blibo la. 
\q1  
\v 23 Dzɔ wò dzi ŋu wu nuwo katã, 
\q2 elabena eyae nye agbe ƒe vudo. 
\q1  
\v 24 Ɖe nya dzodzrowo ɖa le wò nu me, 
\q2 eye te aʋatsonyawo ɖa xaa tso wò nuyiwo gbɔ. 
\q1  
\v 25 Wò ŋkuwo nekpɔ ŋgɔ tẽe 
\q2 eye wò mo nelé mɔ ɖeka tsɔ le ŋgɔwò. 
\q1  
\v 26 Ɖe toƒe sɔsɔewo na wò afɔwo 
\q2 eye nàlé mɔ siwo dzi sẽ nyuie la ko atsɔ. 
\q1  
\v 27 Mègadze ɖe ɖusime alo miame o, 
\q2 eye ɖe wò afɔ ɖa le vɔ̃ me. 
\c 5  
\s1 Nuxɔxlɔ̃ amewo le ahasiwɔwɔ ŋuti 
\q1  
\v 1 Vinye, lé to ɖe nye nunya ŋu 
\q2 eye nàƒu to anyi nyuie ɖe nye sidzedze ƒe nyawo ŋu, 
\q1  
\v 2 be nànya nu si nàwɔ 
\q2 eye wò nuyiwo adzra gɔmesese ɖo 
\q1  
\v 3 elabena nyɔnu ahasitɔ ƒe nuyiwo le anyitsi tsyɔm, 
\q2 eye eƒe numenyawo zrɔ̃ wu ami 
\q1  
\v 4 gake le nuwuwu la evena wu veve 
\q2 eye wòɖana wu yi nuevee. 
\q1  
\v 5 Eƒe afɔ yina ɖe tsĩeƒe ke 
\q2 eye eƒe afɔɖeɖewo yina ɖe yɔdo me tẽe 
\q1  
\v 6 Mebua ta me le ale si wòanɔ agbee ŋu kura o, 
\q2 eƒe toƒewo glɔ̃ gake menyae o 
\q1  
\v 7 eya ta azɔ la, vinyewo, miɖo tom, 
\q2 migaƒo asa na nu si megblɔ na mi o. 
\q1  
\v 8 Miaƒe toƒewo nete ɖa xaa tso egbɔ, 
\q2 migagogo eƒe aƒe ƒe agbonu o, 
\q1  
\v 9 ne menye nenema o la, 
\q2 miava gblẽ miaƒe ɖekakpuime 
\q1 ƒe ŋusẽ ɖe ame bubuwo ŋu 
\q2 kple miaƒe ƒewo ɖe ame vɔ̃ɖi ŋu. 
\q1  
\v 10 Ne menye nenema o la, 
\q2 amedzrowo anye avuzi le miaƒe kesinɔnuwo dzi 
\q2 eye nu si nète fifia kpɔ la aɖo atsyɔ̃ na ame bubu ƒe aƒe me. 
\q1  
\v 11 Le wò agbe ƒe nuwuwu la, ànɔ ŋeŋem, 
\q2 ne wò ŋutilã kple wò ameti blibo la vɔ le eme. 
\q1  
\v 12 Àgblɔ be, “Metsri amehehe kɔkɔkɔ! 
\q2 Eye nye dzi do vlo ɖɔɖɔɖo! 
\q1  
\v 13 Nyemaɖo to nye nufialawo 
\q2 alo aƒu to anyi ɖe nye amegãwo ŋu o. 
\q1  
\v 14 Esusɔ vie donyeme nagblẽ keŋkeŋ 
\q2 le ameha la katã dome.” 
\b  
\q1  
\v 15 No tsi tso wò ŋutɔ wò tsiʋe me 
\q2 kple tsi dzidzi tso wò ŋutɔ wò vudo me. 
\q1  
\v 16 Ɖe wòle be wò tsitsetsewo nagbagba ɖe mɔtatawo dzi 
\q2 kple wò tsi sisi ɖe du ƒe ablɔwo mea? 
\q1  
\v 17 Wonenye wò ɖeka ko tɔ, 
\q2 mègamae kple ame tutɔwo gbeɖe o. 
\q1  
\v 18 Woayra wò vudo eye nàkpɔ dzidzɔ 
\q2 ɖe wò ɖekakpuimesrɔ̃ ŋu. 
\q1  
\v 19 Eyae nye zinɔ lɔlɔ̃a kple sãde dzeani la, 
\q2 eƒe nowo neɖi kɔ na wò ɣe sia ɣi, 
\q2 eye eƒe lɔlɔ̃ nede dzo mewò ɖaa. 
\q1  
\v 20 Vinye, nu ka ŋuti nàƒo kpakpakpa ɖe nyɔnu ahasitɔ ŋu? 
\q2 Nu ka ŋuti nàlé alime na ame bubu srɔ̃? 
\b  
\q1  
\v 21 Elabena ame sia ame ƒe mɔ le ƒuƒlu le Yehowa ŋkume 
\q2 eye wòdoa woƒe mɔwo katã kpɔ. 
\q1  
\v 22 Ame vɔ̃ɖi ƒe nu vɔ̃ɖi siwo wòwɔna la zua mɔ ɖenɛ, 
\q2 eye eƒe nu vɔ̃ zua ka blanɛ sesĩe. 
\q1  
\v 23 Aku le ɖokuidzimaɖumaɖu ta 
\q2 eye eƒe bometsitsi gã la akplɔe atrae. 
\c 6  
\s1 Nuxɔxlɔ̃ amewo le bometsitsi ŋuti 
\q1  
\v 1 Vinye, ne ède megbe na wò aƒelika, 
\q2 eye nèsi akpe tsɔ do ŋugbee na ame tutɔ, 
\q1  
\v 2 ne ŋugbe si nèdo zu mɔ me nèɖo 
\q2 eye wò numenyawo bla wò la, 
\q1  
\v 3 ekema vinye, wɔ esia ne nàtsɔ aɖe ɖokuiwòe, 
\q2 esi nège ɖe hawòvi ƒe asi me ta. 
\q1 Yi nàbɔbɔ ɖokuiwò, 
\q2 ɖe kuku na hawòvi la amenubletɔe! 
\q1  
\v 4 Wò ŋkuwo megadɔ alɔ̃ o 
\q2 eye wò aɖaba megadɔ akɔlɔ̃e o. 
\q1  
\v 5 Ɖe ɖokuiwò le eƒe asi me abe ale si sãde sina le adela ƒe asi me ene 
\q2 alo abe ale si xevi dona le xevimɔtrela ƒe kamɔ mee ene. 
\b  
\q1  
\v 6 Wò, kuviatɔ, yi anyidi gbɔ; 
\q2 kpɔ eƒe mɔwo ɖa, eye nàdze nunya! 
\q1  
\v 7 Gbeɖela loo dzikpɔla 
\q2 alo dziɖula aɖeke mele esi o, 
\q1  
\v 8 gake le dzomeŋɔli la eƒoa eƒe nuhiahiãwo nu ƒu 
\q2 eye wòƒoa eƒe nuɖuɖu nu ƒu le nuŋeɣi. 
\b  
\q1  
\v 9 Wò, kuviatɔ va se ɖe ɣe ka ɣi nàmlɔ afi ma? 
\q2 Ɣe ka ɣi nànyɔ tso alɔ̃ me? 
\q1  
\v 10 Dɔ alɔ̃ vie, dɔ akɔlɔ̃e sẽe, 
\q2 ŋlɔ wò abɔwo nàdzudzɔ vie, 
\q1  
\v 11 tete ahedada aƒo ɖe dziwò abe adzodala ene 
\q2 eye hiã abe aʋakalẽtɔ si bla akpa ene. 
\b  
\q1  
\v 12 Yakame kple ame baɖa 
\q2 si le yiyim kple alakpadada, 
\q2  
\v 13 le ŋku tem, tsɔ afɔ le dzesi fiam 
\q2 eye wòtsɔ eƒe asi le nya gblɔmii, 
\q2  
\v 14 ame si ɖoa nu vɔ̃ɖi, beble le eƒe dzi me, 
\q2 eye ɣe sia ɣi wòdea dzre aƒe la 
\q1  
\v 15 eya ta gbegblẽ aƒo ɖe edzi kpoyi 
\q2 eye woatsrɔ̃ eya amea zi ɖeka, naneke maɖee le eme o. 
\b  
\li1  
\v 16 Nu adree Yehowa tsri, 
\li2 eye nu adree nye nu siwo wònyɔa ŋui: 
\li3  
\v 17 dadaŋkuwo, alakpaɖe, 
\li3 asi siwo kɔa ʋu maɖifɔ ɖi, 
\li3  
\v 18 dzi si ɖoa nu vɔ̃ɖiwo, 
\li3 afɔ siwo ɖea abla ɖe vɔ̃wɔwɔ ŋuti 
\li3  
\v 19 aʋatsoɖaseɖila si kɔa alakpa ɖi, 
\li3 kple ŋutsu si dea dzre nɔviwo dome. 
\s1 Nuxɔxlɔ̃ amewo le ahasiwɔwɔ ŋuti 
\q1  
\v 20 Vinye, lé fofowò ƒe sededewo me ɖe asi 
\q2 eye mègagblẽ dawò ƒe nufiame ɖi o. 
\q1  
\v 21 Bla wo ɖe wò dzi ŋuti tegbee 
\q2 eye nàsae ɖe wò kɔ ŋuti. 
\q1  
\v 22 Ne èle zɔzɔm la, woafia mɔ wò, ne èle alɔ̃ dɔm la, 
\q2 woadzɔ ŋuwò eye ne ènyɔ la, woaƒo nu na wò 
\q1  
\v 23 elabena sedede siawo nye akaɖi, 
\q2 nufiafia sia nye kekeli eye ɖɔɖɔɖo 
\q2 si amehehe hena vɛ la nye agbe ƒe mɔ, 
\q1  
\v 24 esi aɖe wò tso nyɔnu ahasitɔ ƒe asi me 
\q2 kple srɔ̃nyɔnu dzego la ƒe aɖe ŋanɛ ƒe asi me. 
\b  
\q1  
\v 25 Eƒe tugbedzedze megana eƒe nu nadzro wò 
\q2 le wò dzi me alo nàna eƒe ŋku mawo nalé wò o, 
\q1  
\v 26 elabena gbolo aɖi gbɔ̃ wò, 
\q2 nànɔ abe abolo ko ene eye nyɔnu ahasitɔ aɖe agbe le mewò. 
\q1  
\v 27 Ɖe ŋutsu aɖe aɖe dzo ɖe atata 
\q2 eye eƒe awuwo nagbe fiafia? 
\q1  
\v 28 Ɖe ŋutsu aɖe azɔ le dzoka xɔxɔ dzi 
\q2 eye eƒe afɔwo nagbe fiafia? 
\q1  
\v 29 Nenemae wòanɔ na ŋutsu si dɔna kple ŋutsu bubu srɔ̃, 
\q2 womagbe tohehe na ame si ka asi eŋuti o. 
\b  
\q1  
\v 30 Womedoa vlo fiafitɔ ne efi fi be wòatsɔ atsi eƒe dɔwuame nu, 
\q2 ne dɔ la ewum o 
\q1  
\v 31 gake ne wolée la, ele nɛ be wòaɖo nua teƒe zi adre, 
\q2 esia ana eƒe kesinɔnu siwo katã le esi le eƒe aƒe me la navɔ le esi. 
\q1  
\v 32 Ke ame si wɔ ahasi kple srɔ̃tɔ la mebua ta me o 
\q2 eye ame si wɔnɛ la gblẽa eɖokui dome. 
\q1  
\v 33 Ƒoƒo kple kɔ kple vlododo nye etɔ gome 
\q2 eye womaɖe eƒe ŋukpe ɖa akpɔ gbeɖe o 
\q1  
\v 34 elabena ŋuʋaʋã ana srɔ̃ŋutsu ƒe dɔmedzoe nafla 
\q2 eye ne ele hlɔ̃ biam la, makpɔ nublanui o. 
\q1  
\v 35 Maxɔ avulénu aɖeke o, 
\q2 eye maxɔ zãnu aɖeke hã o, aleke gbegbee wòloloe hã. 
\c 7  
\s1 Kpɔ nyuie le nyɔnu ahasitɔ ŋuti 
\q1  
\v 1 Vinye, lé nye nyawo me ɖe asi 
\q2 eye nàdzra nye sededewo ɖo ɖe mewò. 
\q1  
\v 2 Lé nye sededewo me ɖe asi ekema ànɔ agbe 
\q2 eye dzɔ nye nufiamewo ŋuti abe wò gadaglamakui ene. 
\q1  
\v 3 Bla wo ɖe wò asibidɛwo ŋu 
\q2 eye nàŋlɔ wo ɖe wò dzi ƒe nuŋlɔkpe dzi. 
\q1  
\v 4 Gblɔ na nunya be, 
\q2 “Nɔvinye nyɔnu nènye.” 
\q2 Eye nàyɔ ƒometɔ na gɔmesese, 
\q1  
\v 5 woana nyɔnu ahasitɔ la nanɔ adzɔge na wò, 
\q2 eye woaɖe wò le srɔ̃nyɔnu dzego la ƒe amenublenyawo ƒe asi me. 
\b  
\q1  
\v 6 Mele nye xɔ ƒe fesrẽ nu, 
\q2 hekpɔ nu to fesrẽnuvɔ la me. 
\q1  
\v 7 Mekpɔ ame aɖe le bebewuwo dome, 
\q2 mekpɔ ɖekakpui si tsi bome la le sɔhɛwo dome. 
\q1  
\v 8 Ele zɔzɔm le kpɔdome, 
\q2 ɖo ta dzogoe si me nyɔnu la le la me; 
\q2 ezɔ ɖo ta afi si nyɔnu la ƒe aƒe le, 
\q1  
\v 9 le fiẽ me, esime anyigba nɔ tsyɔtsyɔm, 
\q2 eye zã do blukɔ. 
\b  
\q1  
\v 10 Tete nyɔnu aɖe do go va kpee, 
\q2 edo awu abe gbolo ene eye ayedzedze le mo nɛ. 
\q1  
\v 11 Eƒe gbe le dzi dem, 
\q2 metsɔ ɖeke le eme na ame aɖeke o 
\q2 eye eƒe afɔwo gbe tɔtɔ ɖe aƒe me, 
\q1  
\v 12 ele kpɔdome fifia, kasia egado ɖe ablɔme xoxo 
\q2 eye wòdea xa ɖe dzogoe ɖe sia ɖe dzi. 
\q1  
\v 13 Elé ɖekakpui la hegbugbɔ nu nɛ ŋɔnɔe 
\q2 eye wòɖo mo kplalaa gblɔ nɛ be, 
\q1  
\v 14 “Ŋutifafavɔsa le aƒenye me, 
\q2 egbe mexe nye adzɔgbeɖefewo o, 
\q1  
\v 15 eya ta medo be mava do go wò, 
\q2 medi wò eye meke ɖe ŋuwò! 
\q1  
\v 16 Meɖo aklala biɖibiɖi ƒe abadzivɔ si wode amadede vovovowoe, 
\q2 esi wowɔ le Egipte la ɖe nye aba dzi. 
\q1  
\v 17 Mewu lifi, 
\q2 anowɔtre kple ami ʋeʋĩ vovovowo ɖe nye aba dzi, 
\q1  
\v 18 eya ta va, míano lɔlɔ̃ wòasu mí va se ɖe ŋdi, 
\q2 na míatsɔ lɔlɔ̃ ado vivi ɖe mía ɖokuiwo ŋu! 
\q1  
\v 19 Nye aƒetɔ mele aƒe o, 
\q2 ezɔ mɔ didi aɖe. 
\q1  
\v 20 Etsɔ eƒe gakotoku si ga yɔ fũu la dzoe 
\q2 eye ne dzinu sɔ tegblẽ hafi wòagbɔ.” 
\b  
\q1  
\v 21 Etsɔ amenublenya siawo blee 
\q2 eye wòtsɔ eƒe aɖe ŋanɛ la kplɔe trae. 
\q1  
\v 22 Etso zia enumake hekplɔe ɖo abe nyitsu 
\q2 wokplɔ yina wuwu ge 
\q1 alo abe zi si ɖo afɔ mɔ me ene. 
\q2  
\v 23 Va se ɖe esime aŋutrɔ naƒo ɖe eƒe aklã, 
\q1 abe xevie dzo ɖe kamɔ dzi 
\q2 eye menyae be yeƒe ku le afi ma o la ene 
\q1  
\v 24 eya ta azɔ la, vinyewo, 
\q2 miɖo tom eye miƒu to anyi ɖe nu si megblɔ la ŋu. 
\q1  
\v 25 Migana miaƒe dzi natrɔ ɖe eƒe mɔwo ŋu loo, 
\q2 alo miatra age ɖe eƒe toƒewo o. 
\q1  
\v 26 Elabena ame siwo tsi esi me la sɔ gbɔ, 
\q2 eye ame siwo wòwu la de ha. 
\q1  
\v 27 Eƒe aƒe nye tsiẽƒe ƒe mɔ gbadza 
\q2 siwo ɖo ta ku ƒe xɔgãwo me. 
\c 8  
\s1 Nunya ƒe ameyɔyɔ 
\q1  
\v 1 Ɖe nunya mele ɣli dom le ame yɔm oa? 
\q2 Ɖe gɔmesese mekɔ eƒe gbe dzi oa? 
\q1  
\v 2 Etsi tsitre ɖe kɔkɔƒe siwo le mɔto la tame, 
\q2 afi si afɔmɔwo do go le. 
\q1  
\v 3 Ele tsitre ɖe dua ƒe agbowo ƒe mɔ xa 
\q2 kple agbo la me le ɣli dom sesĩe be, 
\q1  
\v 4 “O ŋutsuwo, miawoe mele ɣli dom na 
\q2 eye mekɔ nye gbe dzi na amegbetɔƒomea katã. 
\q1  
\v 5 Mi bebewuwo, midze nunya; 
\q2 mi bometsilawo gɔmesese nesu mia si. 
\q1  
\v 6 Miɖo to elabena nya xɔasiwo le asinye be magblɔ; 
\q2 meke nye nu be magblɔ nu si le dzɔdzɔe. 
\q1  
\v 7 Nye nu gblɔa nu si le eteƒe, 
\q2 elabena nye nuyi tsri vɔ̃ɖivɔ̃ɖi. 
\q1  
\v 8 Nye numenyawo katã le dzɔdzɔe; 
\q2 ɖeke meglɔ̃ alo nye ayemenya o. 
\q1  
\v 9 Wo katã le dzɔdzɔe na ame si si sidzedze le; 
\q2 fɔɖiɖi mele wo ŋu na ame siwo si gɔmesese le o. 
\q1  
\v 10 Tia nye amehehe ɖe klosalo teƒe 
\q2 kple nye gɔmesese ɖe sika nyuitɔ teƒe 
\q1  
\v 11 elabena nunya xɔ asi wu adzagba 
\q2 eye nu siwo dim wò dzi le la ƒe ɖeke mesɔ kplii o. 
\b  
\q1  
\v 12 “Nye, nunya kple ŋuɖɔɖoe nɔa teƒe ɖeka; 
\q2 gɔmesese kple sidzedze le asinye. 
\q1  
\v 13 Yehowa vɔvɔ̃e nye be nàlé fu vɔ̃, 
\q2 eya ta metsri dada kple ɖokuidodoɖedzi, 
\q2 agbe baɖa nɔnɔ kple nya dzodzrowo gbɔgblɔ. 
\q1  
\v 14 Tɔnyee nye aɖaŋudede kple afia nyui tsotso, 
\q2 gɔmesese kple ŋusẽ le asinye. 
\q1  
\v 15 Dzinyee fiawo tona ɖua fia 
\q2 eye dziɖulawo dea se siwo le dzɔdzɔe. 
\q1  
\v 16 Dzinyee dumegãwo tona kplɔa du 
\q2 eye nenema kee nye bubume 
\q2 siwo le dzi ɖum le anyigba dzi. 
\q1  
\v 17 Melɔ̃a ame siwo lɔ̃am 
\q2 eye ame siwo diam la kpɔam. 
\q1  
\v 18 Hotsui kple bubu bɔ ɖe asinye, 
\q2 nenema kee nye kesinɔnu 
\q2 siwo megblẽna o kple dzidzedze. 
\q1  
\v 19 Nye kutsetse nyo wu sika nyuitɔ, 
\q2 eye nu si dona tso menye la ƒo klosalo nyuitɔ ta sãa. 
\q1  
\v 20 Mezɔna le dzɔdzɔenyenye ƒe mɔ dzi 
\q2 kple nuteƒewɔwɔ ƒe toƒewo, 
\q1  
\v 21 eye mekɔa kesinɔnu ɖe ame siwo lɔ̃am la dzi, 
\q2 henana woƒe nudzraɖoƒewo gbagbana. 
\b  
\q1  
\v 22 “Yehowa dzim abe eƒe nuwɔwɔwo ƒe ŋgɔgbetɔ ene, 
\q2 hafi wòava wɔ nuwo le blema. 
\q1  
\v 23 Etɔ asi dzinye tso mavɔ me ke, 
\q2 tso gɔmedzedzea me, 
\q2 hafi xexea me nava dzɔ. 
\q1  
\v 24 Wodzim esime atsiaƒuwo menɔ anyi o, 
\q2 eye vudo siwo dzia tsi fũu la hã menɔ anyi o. 
\q1  
\v 25 Hafi woatsɔ towo ada ɖe woƒe nɔƒewo, eye togbɛwo nadzɔ la, 
\q2 nye la, wodzim xoxo. 
\q1  
\v 26 Hafi wòava wɔ anyigba alo gbegbe 
\q2 alo anyigbadziʋuʋudediwo gɔ̃ hã la, wodzim xoxo. 
\q1  
\v 27 Menɔ afi ma hafi wòtsɔ dziƒowo ɖo wo nɔƒe 
\q2 eye wòdzidze dzite da ɖe gogloƒewo tame. 
\q1  
\v 28 Esi wòɖo lilikpowo ɖe dziƒo, 
\q2 eye wòli ke tɔ goglowo ƒe dzɔtsoƒe, 
\q1  
\v 29 esi wòɖo liƒo na atsiaƒu be 
\q2 eƒe tsiwo magbɔ teƒe si wòde se be woase la dzi o 
\q1 eye wòɖo anyigba gɔme la, medzɔ xoxo. 
\q2  
\v 30 Ale menye aɖaŋudɔwɔla nɔ eƒe axadzi, 
\q2 dzidzɔ yɔ menye gbe sia gbe 
\q2 eye metsoa aseye le eŋkume ɣe sia ɣi. 
\q1  
\v 31 Medzɔ dzi le eƒe xexe blibo la me 
\q2 eye amegbetɔwo ƒe nu do dzidzɔ nam. 
\b  
\q1  
\v 32 “Eya ta, azɔ la, mi vinyewo, miɖo tom; 
\q2 woayra ame siwo lé nye mɔwo me ɖe asi. 
\q1  
\v 33 Ɖo to nye sededewo eye nàdze nunya, 
\q2 mègado tokue o. 
\q1  
\v 34 Woayra ame si ɖoa tom, 
\q2 nɔa ŋudzɔ le nye ʋɔtru nu gbe sia gbe 
\q2 eye wòlalana le nye kpui nu 
\q1  
\v 35 elabena ame si ke ɖe ŋutinye la, 
\q2 ke ɖe agbe ŋu eye wòxɔa amenuveve tso Yehowa gbɔ. 
\q1  
\v 36 Ke ame si mete ŋu ke ɖe ŋutinye o la, 
\q2 wɔa nu vevi eɖokui eye ame siwo katã léa fum la lɔ̃a ku.” 
\c 9  
\s1 Nunya kple bometsitsi ƒe amekpekpe 
\q1  
\v 1 Nunya tu eƒe xɔ 
\q2 eye wòɖo eƒe sɔti adreawo te. 
\q1  
\v 2 Etrɔ asi le eƒe lã si wòwu ŋu, 
\q2 tɔtɔ eƒe wain, eye wòɖo eƒe kplɔ̃ hã. 
\q1  
\v 3 Edɔ eƒe dɔlanyɔnuwo 
\q2 eye wòtsi tsitre ɖe dua ƒe kɔkɔƒe ke hedo ɣli be, 
\q1  
\v 4 “Mi bebewuwo katã mige ɖe eme le afii!” 
\q2 Egblɔ na numanyalawo be, 
\q1  
\v 5 “Miva, miɖu nye nu 
\q2 eye mino nye wain si metɔtɔ. 
\q1  
\v 6 Miɖe asi le bometsitsi ŋu, 
\q2 ekema mianɔ agbe eye miazɔ le gɔmesese me. 
\b  
\q1  
\v 7 “Ame si le nya gbem na fewuɖula la le eƒe dzu dɔm 
\q2 eye ame si ka mo na ame vɔ̃ɖi la xɔa dzudzu. 
\q1  
\v 8 Mègaka mo na fewuɖula o, ne menye nenema o la, 
\q2 alé fu wò; ke boŋ ka mo na nunyala eye alɔ̃ wò nya. 
\q1  
\v 9 Fia nu nunyala, aganya nu ɖe edzi wu, 
\q2 fia nu ame dzɔdzɔe eye agasrɔ̃ nu akpe ɖe esi wònya xoxo la ŋuti. 
\b  
\q1  
\v 10 “Yehowa vɔvɔ̃e nye nunya ƒe gɔmedzedze 
\q2 eye sidzedze Kɔkɔetɔ la nye gɔmesese 
\q1  
\v 11 elabena to dzinye wò ŋkekewo adzi ɖe edzi fũu 
\q2 eye woatsɔ ƒewo akpe wò agbenɔƒewo. 
\q1  
\v 12 Ne èdze nunya la, wò nunya ahe viɖe vɛ na wò; 
\q2 ke ne ènye fewuɖula la, wò ɖeka koe akpe fu.” 
\b  
\q1  
\v 13 Nyɔnu bometsila la le ɣli dom, 
\q2 womekplae o eye menya nu hã o. 
\q1  
\v 14 Enɔ anyi ɖe eƒe aƒe ƒe ʋɔtru nu, 
\q2 enɔ anyi ɖe zikpui dzi le du la ƒe kɔkɔƒe kekeake 
\q1  
\v 15 le ame siwo va le eme tsom la yɔm, 
\q2 ame siwo lé woƒe mɔ tsɔ tẽe be, 
\q1  
\v 16 “Mí ame siwo katã nye bebewuwo la, 
\q2 mige ɖe eme le afii!” 
\q1 Egblɔna na ame siwo menya nu o la be, 
\q2  
\v 17 “Tsi si wofi la vivina, 
\q2 eye nu si woɖu le vivime la vivina!” 
\q1  
\v 18 Ke womenya gɔ̃ hã be ame kukuwo le afi ma o 
\q2 eye eƒe ame kpekpewo le yɔdo ƒe gogloƒe ke o. 
\c 10  
\ms1 Salomo ƒe lododowo 
\p  
\v 1 Solomo ƒe lododowo: 
\q1 Ɖevi si nya nu la nana fofoa kpɔa dzidzɔ, 
\q2 ke ɖevi si tsi bome la hea nuxaxa vɛ na dadaa. 
\b  
\q1  
\v 2 Kesinɔnu si wokpɔ to mɔ fitifitiwo dzi la menye viɖe aɖeke o, 
\q2 gake dzɔdzɔnyenye ɖea ame tso ku me. 
\b  
\q1  
\v 3 Yehowa menaa dɔ wua ame dzɔdzɔewo o, 
\q2 ke egblẽa ame vɔ̃ɖiwo ƒe didiwo me. 
\b  
\q1  
\v 4 Asi si wɔa kuvia la nana ame ɖoa ko 
\q2 gake asi si doa vevi nu la hea kesinɔnu vɛ. 
\b  
\q1  
\v 5 Ame si ƒoa nukuwo nu ƒu le dzomeŋɔli la nye vi nyanu, 
\q2 ke ame si dɔa alɔ̃ le nuŋeɣi la, vi ŋukpenuwɔlae. 
\b  
\q1  
\v 6 Yayra anye fiakuku anɔ ame dzɔdzɔe ƒe ta 
\q2 ke ŋutasesẽ yɔa ame vɔ̃ ƒe nu me. 
\b  
\q1  
\v 7 Ŋkuɖoɖo ame dzɔdzɔe dzi anye yayra, 
\q2 ke ame vɔ̃ɖiwo ƒe ŋkɔ aƒaƒã. 
\b  
\q1  
\v 8 Ame si nunya le dzi me na la xɔa sededewo, 
\q2 ke bometsila, nukpoloeƒola, atsrɔ̃. 
\b  
\q1  
\v 9 Ame si ŋu fɔɖiɖi mele o la zɔna le dedinɔnɔ me, 
\q2 ke asi atu ame si toa mɔ gɔglɔ̃wo dzi. 
\b  
\q1  
\v 10 Ame si tea ŋku ɖe ame kple dziku la 
\q2 hea nuxaxa vɛ, eye bometsila, nukpoloeƒola, atsrɔ̃. 
\b  
\q1  
\v 11 Ame dzɔdzɔe ƒe nu nye agbevudo, 
\q2 ke ŋutasesẽ yɔa ame vɔ̃ɖi ƒe nu me. 
\b  
\q1  
\v 12 Fuléle hea mama vɛ, 
\q2 gake lɔlɔ̃ tsyɔa dzidadawo katã dzi. 
\b  
\q1  
\v 13 Nunya le nugɔmeselawo ƒe nuyi dzi, 
\q2 ke ameƒoti adze dzime na numanyalawo. 
\b  
\q1  
\v 14 Nunyalawo dzraa gɔmesese ɖo, 
\q2 ke bometsila ƒe nu hea gbegblẽ vɛ. 
\b  
\q1  
\v 15 Kesinɔtɔwo ƒe kesinɔnuwo nye du si ŋu wotɔ glikpɔ sesẽ ɖo, 
\q2 ke hiãtɔwo ƒe ahedada nye woƒe gbegblẽ. 
\b  
\q1  
\v 16 Ame dzɔdzɔe ƒe dɔwɔfetu hea agbe vɛ nɛ, 
\q2 gake ame vɔ̃ɖi ƒe viɖe hea tohehe vɛ nɛ. 
\b  
\q1  
\v 17 Ame si ɖo to amehehe la le agbemɔ fiam 
\q2 gake ame si gbea ɖɔɖɔɖo la kplɔa ame bubuwo tranae. 
\b  
\q1  
\v 18 Ame si ɣla fuléle ɖe eƒe dzi me la, alakpanuyi le esi 
\q2 eye ame si nɔa ame ŋu gblẽm la, bometsilae. 
\b  
\q1  
\v 19 Afi si nya geɖe le la, nu vɔ̃ megbea afi ma nɔnɔ o, 
\q2 ke ame si lé eƒe aɖe la, nunyalae. 
\b  
\q1  
\v 20 Ame dzɔdzɔe ƒe aɖe le abe klosalo nyuitɔ ene, 
\q2 ke viɖe mele ame vɔ̃ɖi ƒe dzi ŋu o. 
\b  
\q1  
\v 21 Ame dzɔdzɔe ƒe nuyi hea nunyiame vɛ na ame geɖewo, 
\q2 gake bometsilawo kuna le simadzemadze ta. 
\b  
\q1  
\v 22 Yehowa ƒe yayra hea kesinɔnu vɛ, 
\q2 eye metsɔa fukpekpe aɖeke kpena ɖe eŋu o. 
\b  
\q1  
\v 23 Bometsila kpɔa dzidzɔ le nu tovo wɔwɔ ŋu, 
\q2 ke ame si sea nu gɔme la, 
\q2 nunyae nye eƒe dzidzɔ. 
\b  
\q1  
\v 24 Nu si vɔ̃m ame vɔ̃ɖi le lae ava tui, 
\q2 ke nu si dim dzɔdzɔetɔ le la, eyae woanae. 
\b  
\q1  
\v 25 Ne ahomya ƒo va yi la, 
\q2 ame vɔ̃ɖi la maganɔ anyi o, 
\q2 ke ame dzɔdzɔe ya anɔ te sesĩe ɖaa. 
\b  
\q1  
\v 26 Abe ale si aha tsitsi nɔna na aɖu 
\q2 eye dzudzɔ nɔna na ŋku ene la, 
\q2 nenema kuviatɔ le na ame siwo dɔ dɔe. 
\b  
\q1  
\v 27 Yehowavɔvɔ̃ nana agbe didina. 
\q2 Ke ame vɔ̃ɖi ƒe agbenɔƒewo le kpuie. 
\b  
\q1  
\v 28 Ame dzɔdzɔe ƒe viɖee nye dzidzɔ 
\q2 gake ame vɔ̃ɖiwo ƒe mɔkpɔkpɔ zua dzodzro. 
\b  
\q1  
\v 29 Yehowa ƒe mɔ nye sitsoƒe na ame dzɔdzɔe, 
\q2 ke enye gbegblẽ na nu tovo wɔlawo. 
\b  
\q1  
\v 30 Womaho ame dzɔdzɔe la akpɔ gbeɖe o 
\q2 gake ame vɔ̃ɖi ya manɔ anyigba la dzi o. 
\b  
\q1  
\v 31 Nunya dona tso dzɔdzɔetɔ la ƒe nu me, 
\q2 gake woalã alakpaɖe la ɖa. 
\b  
\q1  
\v 32 Ame dzɔdzɔe ƒe nuyiwo nya nya dzeto gbɔgblɔ, 
\q2 gake ame vɔ̃ɖi ƒe nu gblɔa nya tovowo. 
\b  
\c 11  
\q1  
\v 1 Yehowa tsri nudanu amebatɔ, 
\q2 ke nudakpe si de blibo la nye eƒe dzidzɔ. 
\b  
\q1  
\v 2 Dada doa ŋgɔ na ŋukpeɖuɖu, 
\q2 ke ɖokuibɔbɔ hea nunya vɛ. 
\b  
\q1  
\v 3 Ame dzɔdzɔewo ƒe ta me nyui ɖoɖo kplɔa wo, 
\q2 ke nuteƒemawɔlawo la, 
\q2 woƒe dzi me eve susu tsrɔ̃a wo. 
\b  
\q1  
\v 4 Kesinɔnu nye nu dzodzro le dzikudogbe, 
\q2 ke dzɔdzɔenyenye ɖea ame tso ku me. 
\b  
\q1  
\v 5 Ame maɖifɔwo ƒe dzɔdzɔenyenye taa mɔ dzɔdzɔe ɖe wo ŋgɔ, 
\q2 ke ame vɔ̃ɖiwo ƒe vɔ̃wɔwɔ hea wo ƒua anyi. 
\b  
\q1  
\v 6 Ame dzɔdzɔewo ƒe nu dzɔdzɔe wɔwɔ ɖea wo, 
\q2 ke didi vlowo zua mɔ ɖea nuteƒemawɔlawo. 
\b  
\q1  
\v 7 Ne ame vɔ̃ɖi ku la, 
\q2 eƒe mɔkpɔkpɔ tsrɔ̃na, 
\q1 nu siwo katã wòle mɔ kpɔm na tso 
\q2 eƒe ŋusẽ me la zua tofloko. 
\b  
\q1  
\v 8 Woɖea ame dzɔdzɔe tso fu me 
\q2 eye wòvaa ame vɔ̃ɖi la dzi boŋ. 
\b  
\q1  
\v 9 Mawumavɔ̃la tsɔa eƒe nu gblẽa ehavi domee, 
\q2 ke woɖea ame dzɔdzɔe la to sidzedze me. 
\b  
\q1  
\v 10 Ne nu dze edzi na ame dzɔdzɔe la, 
\q2 du blibo kpɔa dzidzɔ, 
\q1 ke ne ame vɔ̃ɖi tsrɔ̃ la, 
\q2 wodoa dzidzɔɣli. 
\b  
\q1  
\v 11 To dzɔdzɔetɔ ƒe yayra dzi wodoa du ɖe dzi, 
\q2 ke wotsrɔ̃nɛ to ame vɔ̃ɖi ƒe nu dzi. 
\b  
\q1  
\v 12 Ame manyanu doa vlo ehavi, 
\q2 ke ŋutsu nugɔmesela léa eƒe aɖe. 
\b  
\q1  
\v 13 Amenyagblɔla ʋua go nya ɣaɣla, 
\q2 ke ame ɖɔʋu ɣlaa nya. 
\b  
\q1  
\v 14 Dukɔ aɖe dzea anyi, ne mɔfiala meli o, 
\q2 ke dziɖuɖu vana to aɖaŋuɖola geɖewo dzi. 
\b  
\q1  
\v 15 Ame si de megbe na ame bubu la akpe fu, 
\q2 ke ame si gbe akpesisi abe ŋugbedodo ƒe dzesi ene la anɔ dedie. 
\b  
\q1  
\v 16 Wodea bubu nyɔnu dɔmenyotɔ ŋu, 
\q2 ke ŋutsu ŋutasẽlawo ƒe asi sua kesinɔnu ko dzi. 
\b  
\q1  
\v 17 Ŋuistu dɔmenyotɔ wɔa nyui na eɖokui, 
\q2 gake ŋutsu ŋutasẽla hea hiã vaa eɖokui dzii. 
\b  
\q1  
\v 18 Woxea fetu si me beble le la na ame vɔ̃ɖi, 
\q2 ke ame si ƒã dzɔdzɔenyenye ƒe ku la axa nu geɖe. 
\b  
\q1  
\v 19 Ame si nye dzɔdzɔetɔ vavã la, akpɔ agbe, 
\q2 ke ame si ti nu vɔ̃ɖi yome la yia eƒe ku me. 
\b  
\q1  
\v 20 Yehowa tsri ame siwo ƒe dzi daa alakpa, 
\q2 ke ame siwo fɔɖiɖi mele woƒe mɔwo ŋu o la ƒe nu nyoa eŋu. 
\b  
\q1  
\v 21 Maka ɖe esia dzi na mi be, 
\q2 womagbe tohehe na ame vɔ̃ɖi la o, 
\q2 ke woana ablɔɖe ame dzɔdzɔewo. 
\b  
\q1  
\v 22 Abe ale si sikaŋɔtigɛ nɔa ha ƒe ŋɔtimee ene la, 
\q2 nenema kee nye nyɔnu dzetugbe si meɖoa ŋu ɖo o. 
\b  
\q1  
\v 23 Ame dzɔdzɔewo ƒe didiwo vaa eme na wo nyuie, 
\q2 ke ame vɔ̃ɖiwo ƒe mɔkpɔkpɔ wua nu le dziku me. 
\b  
\q1  
\v 24 Ame ɖeka naa nu faa 
\q2 gake egakpɔa geɖe ɖe edzi, 
\q1 ame bubu vea nu le nu si wòle be wòana la ŋu 
\q2 gake ahe ko wòdana. 
\b  
\q1  
\v 25 Nu adze dzi na ame si na nu faa, 
\q2 ame si na amewo ƒe dzi dze eme la, 
\q2 woana eya ŋutɔ hã ƒe dzi nadze eme. 
\b  
\q1  
\v 26 Ame si tsɔ bli ɣla la amewo aƒo fi adee 
\q2 gake yayra ava ame si lɔ̃ be yeadzra etɔ la dzi. 
\b  
\q1  
\v 27 Ame si ti nyui yome la, amewo adi nyui nɛ 
\q2 gake vɔ̃ vana na ame si le vɔ̃ dim. 
\b  
\q1  
\v 28 Ame si tsɔ eƒe mɔkpɔkpɔ da ɖe eƒe kesinɔnuwo dzi la 
\q2 adze anyi gake ame dzɔdzɔe awɔ mlɔmlɔmlɔ abe gbe dama ene. 
\b  
\q1  
\v 29 Ame si he dzɔgbevɔ̃e va eƒe ƒome dzi la, 
\q2 ya anye eƒe domenyinu 
\q2 eye bometsila anye subɔla na nunyala. 
\b  
\q1  
\v 30 Ame dzɔdzɔe ƒe kutsetse nye agbeti, 
\q2 eye ame si ɖea luʋɔwo la, nunyalae. 
\b  
\q1  
\v 31 Ne ame dzɔdzɔewo xɔ wo tɔ gome le anyigba dzi la, 
\q2 ekema aleke wòahanɔ na mawumavɔ̃lawo kple nu vɔ̃ wɔlawo! 
\b  
\c 12  
\q1  
\v 1 Ame si lɔ̃ amehehe la lɔ̃a sidzedze, 
\q2 ke ame si lé fu mokaname la, bometsilae. 
\b  
\q1  
\v 2 Yehowa vea ame nyui la nu, 
\q2 ke ebua fɔ ayemenuwɔla ya. 
\b  
\q1  
\v 3 Womatsɔ vɔ̃ɖivɔ̃ɖi aɖo ame gɔme anyii o 
\q2 gake womate ŋu aho ame dzɔdzɔe ya o. 
\b  
\q1  
\v 4 Srɔ̃nyɔnu zazɛ̃ nye fiakuku na srɔ̃ŋutsua, 
\q2 ke srɔ̃nyɔnu ŋukpenanuwɔla nye ŋuɖui le ƒu tome na srɔ̃a. 
\b  
\q1  
\v 5 Ame dzɔdzɔe ƒe ɖoɖowo toa mɔ ɖeka, 
\q2 ke ame vɔ̃ɖi ƒe aɖaŋuɖoɖo nye beble. 
\b  
\q1  
\v 6 Ame vɔ̃ɖiwo ƒe nyawo le lalam na ʋu 
\q2 gake dzɔdzɔetɔwo ƒe nuƒoƒo ɖea wo. 
\b  
\q1  
\v 7 Wotutua ame vɔ̃ɖiwo ƒua anyi eye womeganɔa anyi o, 
\q2 ke ame dzɔdzɔe ƒe aƒe lia ke ɖaa. 
\b  
\q1  
\v 8 Wokafua ame le nunya si le esi la ta, 
\q2 ke wodoa vlo ŋutsu tagbɔ kuku tɔwo. 
\b  
\q1  
\v 9 Enyo be nànye ame tsɛ aɖe ko eye subɔla nanɔ asiwò, 
\q2 wu be nàwɔ ɖokuiwò amegãe eye nuɖuɖu manɔ asiwò o. 
\b  
\q1  
\v 10 Ame dzɔdzɔe léa be na eƒe lãwo 
\q2 ke dɔmenyo siwo ame vɔ̃ɖiwo ya wɔna la nye ŋutasesẽ. 
\b  
\q1  
\v 11 Ame si ŋlɔ eƒe agble la akpɔ nuɖuɖu geɖe, 
\q2 ke ame si kplɔa blezibledi ɖo la, numanyalae. 
\b  
\q1  
\v 12 Ame vɔ̃ɖiwo ƒe nu siwo woha la le ŋutasẽlawo dzrom, 
\q2 ke ame dzɔdzɔewo ƒe ke ƒona ɖe to sesĩe. 
\b  
\q1  
\v 13 Ame vɔ̃ɖi ƒe nu vlo ƒoƒo zua mɔ ɖenɛ, 
\q2 ke ame dzɔdzɔe dona le fu me. 
\b  
\q1  
\v 14 Ame ƒe nu ƒe kutsetse hea nu nyuiwo vɛ nɛ taŋtaŋtaŋ, 
\q2 eye enye nyateƒe be dɔ si ame tsɔ eƒe asi wɔ lae hea viɖe vɛ nɛ. 
\b  
\q1  
\v 15 Bometsila ƒe mɔ dzɔna le eya ŋutɔ ƒe ŋkume, 
\q2 ke ame dzɔdzɔe xɔa aɖaŋuɖoɖo. 
\b  
\q1  
\v 16 Bometsila ɖea eƒe dziku fiana zi ɖeka, 
\q2 ke nunyala doa toku dzudzu. 
\b  
\q1  
\v 17 Ɖasefo nyateƒetɔ gblɔa nya si le eteƒe le ʋɔnu, 
\q2 ke aʋatsoɖasefo daa alakpa le ʋɔnu. 
\b  
\q1  
\v 18 Nya vlowo ƒona ɖe ame abe yi ene, 
\q2 ke ame dzɔdzɔe ƒe aɖe hea dɔyɔyɔ vɛ. 
\b  
\q1  
\v 19 Nyateƒenuyiwo nɔa anyi ɖikaa, 
\q2 ke alakpaɖe nu mesena yina o. 
\b  
\q1  
\v 20 Beble le ame siwo ɖoa nu vɔ̃ɖi la ƒe dzi me, 
\q2 ke dzidzɔ nɔa ame siwo hea ŋutifafa vɛ la ƒe dzi me. 
\b  
\q1  
\v 21 Dzɔgbevɔ̃e medzɔna ɖe ame dzɔdzɔe dzi o, 
\q2 ke ame vɔ̃ɖiwo la, xaxa yɔa wo me fũu. 
\b  
\q1  
\v 22 Yehowa lé fu alakpanuyiwo, 
\q2 ke ekpɔa dzidzɔ ɖe ame siwo toa nyateƒe la ŋu. 
\b  
\q1  
\v 23 Nunyala mekɔa nu le sidzedze si su esi la dzi o, 
\q2 ke bometsilawo ƒe dzi ɖea gbeƒã woƒe bometsitsi. 
\b  
\q1  
\v 24 Asi si doa vevi nu la aɖu fia, 
\q2 ke kuviawɔwɔ kplɔa ame ɖona ɖe dɔ sesẽ me. 
\b  
\q1  
\v 25 Nuxaxa le dzi me tea ame ɖe anyi, 
\q2 ke amenuvenya dea dzi ƒo na ame. 
\b  
\q1  
\v 26 Ame dzɔdzɔe ɖoa ŋu ɖo le xɔlɔ̃wɔwɔ me, 
\q2 ke ame vɔ̃ɖiwo ƒe mɔ kplɔa wo tranae. 
\b  
\q1  
\v 27 Kuviatɔ memea eƒe adelã o, 
\q2 ke nunyala léa be na eƒe nunɔamesiwo. 
\b  
\q1  
\v 28 Agbe le dzɔdzɔenyenye ƒe mɔ me, 
\q2 makumaku le mɔ ma dzi. 
\b  
\c 13  
\q1  
\v 1 Vi nyanu ɖoa to fofoa ƒe amehehe, 
\q2 ke fewuɖula metsɔa ɖeke le mokaname me o. 
\b  
\q1  
\v 2 Ame ƒe nu ƒe kutsetsee wòtsɔna ɖua nu nyuiwoe, 
\q2 ke nuteƒemawɔlawo ƒe dzi tsi dzi ɖe nu vlo wɔwɔ ŋuti. 
\b  
\q1  
\v 3 Ame si dzɔa eƒe nuyiwo ŋuti la dzɔa eƒe agbe ŋuti, 
\q2 ke ame si kea nu kabakaba la atsrɔ̃. 
\b  
\q1  
\v 4 Nu dzroa kuviatɔ vevie gake mekpɔa naneke o, 
\q2 ke vevidonula ƒe didiwo vaa eme nɛ. 
\b  
\q1  
\v 5 Ame dzɔdzɔe léa fu alakpanya, 
\q2 ke ame vɔ̃ɖiwo ya hea ŋukpe kple vlododo vɛ. 
\b  
\q1  
\v 6 Dzɔdzɔenyenye dzɔa ŋutsu fɔmaɖila ƒe agbe ŋuti, 
\q2 ke vɔ̃ɖivɔ̃ɖi léa nu vɔ̃ wɔla ƒua anyi. 
\b  
\q1  
\v 7 Ame aɖe wɔna abe kesinɔtɔe wònye ene, evɔ naneke mele esi o, 
\q2 ame bubu wɔa eɖokui ame dahee, evɔ kesinɔnu geɖe le esi. 
\b  
\q1  
\v 8 Ame ƒe kesinɔnuwo ate ŋu aƒle eƒe agbe ta 
\q2 gake ame dahe mesea ŋɔdzidoname aɖeke o. 
\b  
\q1  
\v 9 Ame dzɔdzɔe ƒe kekeli klẽna nyuie, 
\q2 ke wotsia ame vɔ̃ɖi ƒe akaɖi. 
\b  
\q1  
\v 10 Dzre sɔŋ ko dada hena vɛ, 
\q2 ke nunya tsoa aƒe ɖe ame siwo sea aɖaŋu la gbɔ. 
\b  
\q1  
\v 11 Ga si wokpɔ to mɔ fitifiti dzi la nu va yina, 
\q2 ke ame si dia ga vivivi la wɔnɛ be wòdzina ɖe edzi. 
\b  
\q1  
\v 12 Mɔkpɔkpɔ si woɖe ɖa la nana dzi léa dɔ, 
\q2 ke didi si va eme la nye agbeti. 
\b  
\q1  
\v 13 Ame si doa vlo amehehe la xɔa eŋufetu, 
\q2 ke ame si ɖoa to sedede la xɔa eteƒeɖoɖo. 
\b  
\q1  
\v 14 Nunyala ƒe nufiafia nye agbevudo, 
\q2 eye wòɖea ame tso ku ƒe mɔkawo me. 
\b  
\q1  
\v 15 Gɔmesese nyui hea amenuveve vanɛ, 
\q2 ke nuteƒemawɔlawo ƒe mɔ dzi sesẽna. 
\b  
\q1  
\v 16 Nunyala ɖe sia ɖe wɔa nu kple gɔmesese, 
\q2 ke bometsila ɖea eƒe bometsitsi fiana. 
\b  
\q1  
\v 17 Dɔtsɔla vɔ̃ɖi gena ɖe dzɔgbevɔ̃e me, 
\q2 ke dɔtsɔla si wɔa nuteƒe la hea dɔyɔyɔ vanɛ. 
\b  
\q1  
\v 18 Ame si do toku amehehe la, 
\q2 ahedada kple ŋukpe vaa edzi, 
\q2 ke wodea bubu ame si lɔ̃a mokaname ŋuti. 
\b  
\q1  
\v 19 Didi si vaa eme la vivina na luʋɔ, 
\q2 ke vɔ̃tsitsri nye ŋunyɔ na bometsilawo. 
\b  
\q1  
\v 20 Ame si zɔna kple nunyala la, dzea nunya, 
\q2 ke ame si dzea xɔ̃ bometsilawo la 
\q2 gena ɖe fuwɔame me. 
\b  
\q1  
\v 21 Dzɔgbevɔ̃e tia vɔ̃wɔla yome 
\q2 gake dzɔgbenyui nye ame dzɔdzɔe ƒe fetu. 
\b  
\q1  
\v 22 Ame nyui gblẽa domenyinu ɖi na via ƒe viwo, 
\q2 ke woɖoa ame vɔ̃ɖi ƒe kesinɔnuwo ɖi na ame dzɔdzɔewo. 
\b  
\q1  
\v 23 Ame dahe ƒe agble wɔa nuku geɖe, 
\q2 ke amebaba kplɔnɛ dzonae. 
\b  
\q1  
\v 24 Ame si vea nu le ameƒoti gbɔ la léa fu via, 
\q2 ke ame si lɔ̃a via la kpɔa egbɔ be yehee nyuie. 
\b  
\q1  
\v 25 Ame dzɔdzɔe ɖua nu ɖia ƒo, 
\q2 ke dɔ wua ame vɔ̃ɖi ya. 
\b  
\c 14  
\q1  
\v 1 Nyɔnu nyanu tua eya ŋutɔ ƒe xɔ, 
\q2 ke nyɔnu bometsila ya tsɔa eya ŋutɔ 
\q2 ƒe asi vuvua xɔ si wòtu la kɔna ɖe anyi. 
\b  
\q1  
\v 2 Ame si ƒe zɔzɔme ŋu fɔɖiɖi mele o la vɔ̃a Yehowa, 
\q2 ke ame siwo ƒe mɔ le gɔdɔ̃gɔdɔ̃ la doa vloe. 
\b  
\q1  
\v 3 Bometsila ƒe nuƒo nana ameƒoti dzea eƒe dzimegbe, 
\q2 ke nunyala ƒe nuyi kpɔa eta. 
\b  
\q1  
\v 4 Ne nyiwo meli o la, nyikpo me ɖia gbɔlo, 
\q2 ke woxaa nuku geɖe to nyitsu ƒe ŋusẽ me. 
\b  
\q1  
\v 5 Ɖasefo nyateƒetɔ meblea ame o, 
\q2 ke aʋatsoɖasefo ya trɔa alakpa kɔna ɖi glẽglẽglẽ. 
\b  
\q1  
\v 6 Fewuɖula dia nunya gake mekpɔa ɖeke o, 
\q2 ke gɔmesese vana na ame si si sidzedze le la bɔbɔe. 
\b  
\q1  
\v 7 Te ɖa le bometsila gbɔ 
\q2 elabena màkpɔ gɔmesese le eƒe nu me o. 
\b  
\q1  
\v 8 Ayedzelawo ƒe nunyae nye be woabu ta me le woƒe mɔwo ŋu, 
\q2 ke bometsilawo ƒe bometsitsie nye alakpa. 
\b  
\q1  
\v 9 Bometsilawo le alɔme ɖem le nuvɔ̃ŋutivɔsa ŋuti, 
\q2 ke ŋudzedzekpɔkpɔ le dzɔdzɔetɔwo dome. 
\b  
\q1  
\v 10 Dzi ɖe sia ɖe nya eya ŋutɔ ƒe vevesese 
\q2 eye ame aɖeke hã mate ŋu ama eƒe dzidzɔ kplii o. 
\b  
\q1  
\v 11 Woatsrɔ̃ ame vɔ̃ɖiwo ƒe aƒe, 
\q2 ke ame dzɔdzɔewo ƒe agbadɔ anɔ anyi ɖaa. 
\b  
\q1  
\v 12 Mɔ aɖe li, si le dzɔdzɔe le ame ƒe ŋkume, 
\q2 ke le nuwuwua la, ekplɔa ame yia ku mee. 
\b  
\q1  
\v 13 Le nukoko gɔ̃ hã me la, 
\q2 dzi ase veve eye dzidzɔkpɔkpɔ awu nu le nuxaxa me. 
\b  
\q1  
\v 14 Woaxe fe na tosẽlawo le woƒe mɔwo ta 
\q2 eye nenema ke ame nyui hã axɔ eƒe fetu. 
\b  
\q1  
\v 15 Susu wodzoetɔ xɔa nya sia nya dzi sena, 
\q2 ke nunyala dea ŋugble le eƒe afɔɖeɖewo ŋuti. 
\b  
\q1  
\v 16 Nunyala léa fu vɔ̃ eye wòvɔa Yehowa, 
\q2 ke bometsila doa dziku kabakaba eye wòwɔa nu dzimagbɔɖitɔe. 
\b  
\q1  
\v 17 Ame si doa dɔmedzoe kabakaba la wɔa bometsinuwo 
\q2 eye wòléa fu ayedzela. 
\b  
\q1  
\v 18 Susu wodzoetɔwo ƒe domenyinue nye bometsitsi, 
\q2 ke wotsɔa sidzedze ɖɔna na nunyalawo. 
\b  
\q1  
\v 19 Ame vɔ̃ɖiwo adze klo ɖe ame nyuiwo ŋkume 
\q2 eye nenema ke nu tovo wɔlawo awɔ le ame dzɔdzɔewo ƒe agbonu. 
\b  
\q1  
\v 20 Ame dahewo ƒe aƒelikawo ke hã ƒoa asa na wo, 
\q2 ke xɔlɔ̃ geɖe nɔa kesinɔtɔwo si. 
\b  
\q1  
\v 21 Ame si do vlo ehavi la wɔ nu vɔ̃, 
\q2 ke woayra ame si nyo dɔ me na hiãtɔ. 
\b  
\q1  
\v 22 Ame siwo ɖoa nu vɔ̃ɖi la traa mɔ 
\q2 ke ame siwo wɔa ɖoɖo ɖe nu nyui wɔwɔ ŋu la xɔa lɔlɔ̃ 
\q2 kple nuteƒewɔwɔ ƒe teƒeɖoɖo. 
\b  
\q1  
\v 23 Kutrikuku ɖe dɔwɔna ŋu hea viɖe vɛ, 
\q2 ke nukpoloeƒoƒo ɖeɖe hea ame yia ahedada mee. 
\b  
\q1  
\v 24 Nunyalawo ƒe kesinɔnue nye woƒe fiakuku, 
\q2 gake bometsilawo ƒe bometsinuwɔwɔ hea bometsitsi vanɛ. 
\b  
\q1  
\v 25 Ɖasefo nyateƒetɔ ɖea ame geɖewo ƒe agbe, 
\q2 ke aʋatsoɖasefo nye ameblela. 
\b  
\q1  
\v 26 Ame si vɔ̃a Yehowa la, 
\q2 mɔ sesẽ aɖe le esi eye wòanye bebeƒe na viawo. 
\b  
\q1  
\v 27 Yehowa vɔvɔ̃e nye agbe ƒe vudo 
\q2 eye wòɖea ame tso ku ƒe mɔkawo me. 
\b  
\q1  
\v 28 Ame xexlẽme gbogbo nye fia ƒe ŋutikɔkɔe, 
\q2 ke ne amewo mele du aɖe me o la, 
\q2 gbegblẽ vaa dumegã dzi. 
\b  
\q1  
\v 29 Sidzedze gã aɖe sua ŋutsu dzigbɔɖitɔ si, 
\q2 ke ŋutsu si doa dziku kabakaba la, 
\q2 ɖea eƒe bometsitsi fiana. 
\b  
\q1  
\v 30 Dzi si me ŋutifafa le la nana agbe ŋutilã 
\q2 gake ŋubiã nana ƒuwo ƒaƒãna. 
\b  
\q1  
\v 31 Ame si tea ame dahewo ɖe anyi la doa vlo wo Wɔla, 
\q2 ke ame si nyoa dɔ me na hiãtɔ la dea bubu Mawu ŋuti. 
\b  
\q1  
\v 32 Ne dzɔgbevɔ̃e dzɔ la, ame vɔ̃ɖiwo yia to, 
\q2 ke le ku me ke hã la, ame dzɔdzɔewo kpɔa sitsoƒe. 
\b  
\q1  
\v 33 Ame si si sidzedze su la, nunya tsoa aƒe ɖe eƒe dzi me, 
\q2 eye le bometsilawo dome gɔ̃ hã la, enana wodzea si ame si ƒomevi wònye. 
\b  
\q1  
\v 34 Dzɔdzɔenyenye doa dukɔ ɖe dzi, 
\q2 ke nu vɔ̃ nye ŋukpe na dukɔmeviwo. 
\b  
\q1  
\v 35 Dɔla nyanu ƒe nu nyoa fia ŋu, 
\q2 ke eƒe dɔmedzoe vaa dɔla ŋukpenanuwɔla dzi. 
\b  
\c 15  
\q1  
\v 1 Nyaŋuɖoɖo kple gbe bɔbɔe tsia dziku nu, 
\q2 ke nyagbɔgblɔ kple gbedaɖeame nana dɔmedzoe flana. 
\b  
\q1  
\v 2 Nunyalawo ƒe aɖe ɖea gɔmesese fiana, 
\q2 gake bometsinyawo dona tso bometsila nu glẽglẽglẽ. 
\b  
\q1  
\v 3 Yehowa ƒe ŋkuwo le afi sia afi 
\q2 eye eƒe ŋkuwo le ame vɔ̃ɖiwo 
\q2 kple ame nyuiwo siaa ŋu. 
\b  
\q1  
\v 4 Aɖe si hea dɔyɔyɔ vɛ la nye agbeti, 
\q2 ke alakpaɖe gbãa gbɔgbɔ gudugudugudu. 
\b  
\q1  
\v 5 Bometsila doa vlo fofoa ƒe amehehe, 
\q2 ke ame si xɔa ɖɔɖɔɖo la, nunyalae. 
\b  
\q1  
\v 6 Kesinɔnu gã aɖe nɔa aƒe me na nunyala, 
\q2 ke ame vɔ̃ɖiwo ƒe hokpɔkpɔ hea dzɔgbevɔ̃e vɛ na wo. 
\b  
\q1  
\v 7 Nunyalawo ƒe nuyiwo kakaa sidzedze, 
\q2 ke mele alea le bometsilawo ƒe dzi me o. 
\b  
\q1  
\v 8 Yehowa léa fu ame vɔ̃ɖiwo ƒe vɔsa, 
\q2 ke dzɔdzɔetɔwo ƒe gbedodoɖa dzea eŋu. 
\b  
\q1  
\v 9 Yehowa léa fu ame vɔ̃ɖiwo ƒe mɔ, 
\q2 ke elɔ̃a ame siwo tia dzɔdzɔenyenye yome la ƒe mɔ. 
\b  
\q1  
\v 10 Tohehe sesẽ le ame si tra le mɔ dzi la lalam 
\q2 eye ame si lé fu ɖɔɖɔɖo la aku. 
\b  
\q1  
\v 11 Ku kple tsiẽƒe le nuvo le Yehowa ŋkume, 
\q2 kaka wòahanye amegbetɔwo ƒe dzi! 
\b  
\q1  
\v 12 Fewuɖula tsri nyagbename 
\q2 eya ta mabia aɖaŋu le nunyalawo gbɔ o. 
\b  
\q1  
\v 13 Dzi si me dzidzɔ le la nana mo klẽna, 
\q2 gake dzi si le veve sem la gbãa gbɔgbɔ gudugudugudu. 
\b  
\q1  
\v 14 Dzi si si sidzedze su la dia gɔmesese 
\q2 gake bometsitsi zua nuɖuɖu na bometsila ƒe nu. 
\b  
\q1  
\v 15 Ame siwo wole fu wɔmii la ƒe ŋkekewo katã nye vɔ̃ 
\q2 gake dzi si me dzidzɔ le la tua aglo atraɖii. 
\b  
\q1  
\v 16 Nu sue si ŋu Yehowavɔvɔ̃ kpe ɖo la nyo wu 
\q2 kesinɔnu geɖe si ŋu dzimaɖeɖi le. 
\b  
\q1  
\v 17 Amagbenuɖuɖu si ŋu lɔlɔ̃ kpe ɖo la nyo wu 
\q2 nyivi dami ɖuɖu si ŋu fuléle kpe ɖo. 
\b  
\q1  
\v 18 Dɔmedzoetɔ hea mama vɛ, 
\q2 ke dzigbɔɖitɔ tsia dzre nu. 
\b  
\q1  
\v 19 Ŋuwo le kuviatɔ ƒe mɔ dzi, 
\q2 ke dzɔdzɔetɔ ƒe mɔ nye mɔtata. 
\b  
\q1  
\v 20 Viŋutsu nunyala hea dzidzɔ vɛ na fofoa, 
\q2 ke bometsila doa vlo dadaa. 
\b  
\q1  
\v 21 Bometsinuwɔwɔ doa dzidzɔ na ame manyanu, 
\q2 ke nugɔmesela léa mɔ ɖeka tsɔna. 
\b  
\q1  
\v 22 Ɖoɖowo me gblẽna ne aɖaŋudede meli o, 
\q2 ke ne aɖaŋuɖolawo li fũu la, wokpɔa dzidzedze. 
\b  
\q1  
\v 23 Nyaŋuɖoɖo ɖe nunya me doa dzidzɔ na ame 
\q2 eye aleke nya si wogblɔ le egblɔɣi la mehenyoe o? 
\b  
\q1  
\v 24 Nunyalawo ƒe agbemɔ ɖo ta dzi, 
\q2 be wòakpe ɖe eŋu magaɖiɖi ayi ɖe tsiẽƒe o. 
\b  
\q1  
\v 25 Yehowa gbãa dadalawo ƒe aƒe ƒua anyi, 
\q2 ke enana ahosiwo ƒe liƒo nɔa anyi pɛpɛpɛ. 
\b  
\q1  
\v 26 Yehowa léa fu ame vɔ̃ɖiwo ƒe tameɖoɖo, 
\q2 ke ame siwo dza la tɔ ya doa dzidzɔ nɛ. 
\b  
\q1  
\v 27 Ŋuklẽla hea fukpekpe vaa eƒe aƒe dzi, 
\q2 ke ame si lé fu zãnuxɔxɔ la anɔ agbe. 
\b  
\q1  
\v 28 Ame dzɔdzɔe ƒe dzi daa eƒe nyaŋuɖoɖowo kpɔ, 
\q2 ke nu vɔ̃ɖi doa go tso ame vɔ̃ɖiwo ƒe nu me bababa. 
\b  
\q1  
\v 29 Yehowa le adzɔge na ame vɔ̃ɖiwo, 
\q2 ke esea ame dzɔdzɔewo ƒe gbedodoɖa. 
\b  
\q1  
\v 30 Mo si kɔ la doa dzidzɔ na dzi, 
\q2 eye nya nyui dea agbe ƒuwo me. 
\b  
\q1  
\v 31 Ame si ɖoa to mokaname si hea agbe vɛ la, 
\q2 ƒe dzi adze eme le nunyalawo dome. 
\b  
\q1  
\v 32 Ame si doa toku amehehe la, doa vlo eɖokui, 
\q2 ke ame si xɔa mokaname la gɔmesese sua esi. 
\b  
\q1  
\v 33 Yehowavɔvɔ̃ fiaa nunya ame 
\q2 eye ɖokuibɔbɔ doa ŋgɔ na bubu. 
\b  
\c 16  
\q1  
\v 1 Amegbetɔ tɔe nye dzi ƒe nuɖoɖowo, 
\q2 ke nyaŋuɖoɖo na aɖe tsoa Yehowa gbɔ. 
\b  
\q1  
\v 2 Fɔɖiɖi menɔa ame ŋutɔ ƒe mɔwo ŋu le eya ŋutɔ ƒe ŋkume o, 
\q2 ke Yehowa daa susuwo kpɔ. 
\b  
\q1  
\v 3 Tsɔ nu sia nu si nèwɔna la de Yehowa ƒe asi me, 
\q2 ekema wò ɖoɖowo adze edzi na wò. 
\b  
\q1  
\v 4 Yehowa wɔ nu sia nu le eƒe ŋudɔwɔnu ta, 
\q2 eɖo ame vɔ̃ɖi la gɔ̃ hã ɖi hena dzɔgbevɔ̃eŋkeke la. 
\b  
\q1  
\v 5 Dadalawo katã nye ŋunyɔnu na Yehowa. 
\q2 Maka ɖe edzi na wò be, 
\q2 womagbe tohehe na wo o. 
\b  
\q1  
\v 6 Woɖea nu vɔ̃ ɖa to lɔlɔ̃ kple nuteƒewɔwɔ me 
\q2 eye ame ƒoa asa na nu vɔ̃ɖi to Yehowavɔvɔ̃ me. 
\b  
\q1  
\v 7 Ne ame aɖe ƒe mɔwo nyo Yehowa ŋu la, 
\q2 enana eƒe futɔwo gɔ̃ hã nɔa anyi kplii le ŋutifafa me. 
\b  
\q1  
\v 8 Nu sue si ŋu dzɔdzɔenyenye kpe ɖo la nyo wu 
\q2 nu geɖe si ŋu madzɔmadzɔ kpe ɖo. 
\b  
\q1  
\v 9 Ame wɔa ɖoɖo ɖe ale si wòazɔe ŋu le eƒe dzi me, 
\q2 gake Yehowae fiaa ale si wòaɖe afɔe. 
\b  
\q1  
\v 10 Fia ƒe nuyiwo ƒoa nu abe nya gblɔm wòle ɖi ene 
\q2 eya ta eƒe nu megatso afia gbegblẽ o. 
\b  
\q1  
\v 11 Nudakpe kple nudanu vavãwo tso Yehowa gbɔ 
\q2 eye nenema ke nudakpe siwo katã 
\q2 le akplo me hã nye eƒe nuwɔwɔ. 
\b  
\q1  
\v 12 Nu tovo wɔwɔ nye ŋunyɔnu na fiawo 
\q2 elabena woɖoa fiazikpui anyi ɖe dzɔdzɔenyenye dzi. 
\b  
\q1  
\v 13 Nuyi siwo dzi alakpa mele o la, 
\q2 doa dzidzɔ na fiawo, 
\q2 wodea asixɔxɔ ame si toa nyateƒe la ŋu. 
\b  
\q1  
\v 14 Fia ƒe dziku nye ku ƒe dɔla, 
\q2 ke nunyala alé avui. 
\b  
\q1  
\v 15 Ne fia ɖo mo kɔkɔe la, 
\q2 egɔmee nye agbe 
\q2 eye eƒe amenuveve le abe tsiɖoɖo le adame ene. 
\b  
\q1  
\v 16 Aleke nunyaxɔxɔ mehenyo wu sikae o, 
\q2 eye gɔmesesetiatia mehenyo wu klosaloe o! 
\b  
\q1  
\v 17 Ame dzɔdzɔewo ƒe mɔtata ƒoa asa na nu vɔ̃ɖi 
\q2 eye ame si dzɔa eƒe mɔ ŋu la dzɔa eƒe agbe ŋuti. 
\b  
\q1  
\v 18 Dada doa ŋgɔ na gbegblẽ 
\q2 eye ɖokuidodoɖedzi doa ŋgɔ na anyidzedze. 
\b  
\q1  
\v 19 Enyo be woabɔbɔ ame ɖokui ɖe anyi 
\q2 le hiãtɔwo dome wu be woama afunyinuwo kple dadalawo. 
\b  
\q1  
\v 20 Nu dzea edzi na ame si ɖoa to nufiame 
\q2 eye woayra ame si tsɔ eƒe mɔkpɔkpɔ da ɖe Yehowa dzi. 
\b  
\q1  
\v 21 Woyɔa ame siwo nunya le woƒe dzi me la be sidzelawo, 
\q2 eye nya vivi doa nufiame ɖe ŋgɔ. 
\b  
\q1  
\v 22 Gɔmesese nye agbetsidzidzi na ame siwo ke ɖe eŋuti, 
\q2 ke bometsitsi hea tohehe vɛ na bometsilawo. 
\b  
\q1  
\v 23 Nunyala ƒe dzi dzɔa eƒe nu ŋuti 
\q2 eye eƒe nuyiwo doa nufiame ɖe ŋgɔ. 
\b  
\q1  
\v 24 Nya nyuiwo nye anyitsito, 
\q2 enana luʋɔ sea vivi, eye wòhea dɔyɔyɔ vɛ na ƒuwo. 
\b  
\q1  
\v 25 Mɔ aɖe li si le dzɔdzɔe le ame ƒe ŋkume, 
\q2 ke le nuwuwua la, ekplɔa ame yia ku mee. 
\b  
\q1  
\v 26 Agbatedɔwɔla ƒe nudzodzro wɔa dɔ nɛ, 
\q2 dɔwuame doa ŋusẽe be wòayi edzi. 
\b  
\q1  
\v 27 Yakame le nu vɔ̃ɖi ɖom 
\q2 eye eƒe nuƒoƒo le abe dzo si le bibim sesĩe la ene. 
\b  
\q1  
\v 28 Ame vɔ̃ɖi dea dzre aƒe 
\q2 eye amenyagblɔla maa xɔlɔ̃ veviwo dome. 
\b  
\q1  
\v 29 Ame dzeaglã blea eƒe aƒelika nu, 
\q2 eye wòkplɔnɛ toa mɔ gɔglɔ̃ dzi. 
\b  
\q1  
\v 30 Ame si le ŋku trom la le nu vɔ̃ɖi aɖe ɖom, 
\q2 eye ame si mia eƒe nu ɖe nu dzi la awɔ vɔ̃ godoo. 
\b  
\q1  
\v 31 Ta si ƒo wɔ la nye atsyɔ̃fiakuku, 
\q2 agbe dzɔdzɔe nɔnɔe henɛ vɛ. 
\b  
\q1  
\v 32 Enyo be nànye ŋutsu dzigbɔɖitɔ wu kalẽtɔ, 
\q2 ame si ɖu eƒe dziku dzi la nyo wu ame si xɔ du. 
\b  
\q1  
\v 33 Wolɔa hotsui ɖe akɔ hetsɔna kaa nui, 
\q2 ke nyametsotso ɖe sia ɖe tso Yehowa gbɔ. 
\b  
\c 17  
\q1  
\v 1 Abolo ƒuƒlu sue ɖuɖu si ŋu ŋutifafa kple dziɖeɖi kpe ɖo la nyo wu 
\q2 aƒe si me yɔ fũu kple agbeɖuɖu 
\q2 eye dzre kpe ɖe eŋu. 
\b  
\q1  
\v 2 Dɔla nyanu aɖu aƒetɔ ɖe viŋutsu ŋukpenanuwɔla dzi 
\q2 eye ama domenyinu la kpli wo abe wo nɔviŋutsu wònye ene. 
\b  
\q1  
\v 3 Sonu li na klosalo eye dzokpo li na sika, 
\q2 ke Yehowae doa dziwo katã kpɔ. 
\b  
\q1  
\v 4 Ame vɔ̃ɖi ɖoa to nuyi vɔ̃ɖiwo 
\q2 eye aʋatsotɔ ƒua to anyi ɖe aɖe si gblẽa ame ŋu la ŋu. 
\b  
\q1  
\v 5 Ame si ɖea alɔme le ame dahe ŋuti la doa vlo woƒe Wɔla 
\q2 eye ame si kpɔa dzidzɔ be dzɔgbevɔ̃e dzɔ la, 
\q2 womagbe tohehe nɛ o. 
\b  
\q1  
\v 6 Ame si ku amegã la ƒe fiakukue nye viawo ƒe viwo 
\q2 eye dzilawo nye atsyɔ̃ na wo viwo. 
\b  
\q1  
\v 7 Nuyi siwo doa wo ɖokuiwo ɖe dzi la medzena bometsila 
\q2 kaka alakpanuyiwo nahayi dziɖula dze ge o! 
\b  
\q1  
\v 8 Zãnu nye kpe xɔasi na ame si nae, 
\q2 afi sia afi si wòayi la, edzea dzi nɛ. 
\b  
\q1  
\v 9 Ame si tsɔ nu tsyɔ vodada dzi la doa lɔlɔ̃ ɖe ŋgɔ 
\q2 eye ame si gawɔ nu si wòwɔ va yi la maa xɔlɔ̃ veviwo dome. 
\b  
\q1  
\v 10 Mokaname dea ta me na ame si si sidzedze le 
\q2 wu nu si ƒoƒo alafa ɖeka nye na bometsila. 
\b  
\q1  
\v 11 Ame vɔ̃ɖi la ɖoe kplikpaa be yeadze aglã 
\q2 eya ta woadɔ dumegã sẽŋuta ɖe eŋu. 
\b  
\q1  
\v 12 Enyo be nàdo go sisiblisi si ŋu woɖe viwo le wu 
\q2 esi nàdo go bometsila le eƒe bometsitsi me. 
\b  
\q1  
\v 13 Ne ŋutsu tsɔ vɔ̃ ɖo nyui teƒe la, 
\q2 vɔ̃ madzo ɖa le eƒe aƒe me kpɔ gbeɖe o. 
\b  
\q1  
\v 14 Dzregɔmetoto le abe ale si woŋɔa tɔʋu ene; 
\q2 eya ta ɖe asi le nya ŋu hafi wòava zu dzre. 
\b  
\q1  
\v 15 Afiatsotso na agɔdzela, 
\q2 kple fɔbubu agɔmadzela siaa nye nu si Yehowa tsri. 
\b  
\q1  
\v 16 Ŋudɔwɔnu ka ga nye le bometsila ƒe asi me, 
\q2 esi didi aɖeke mele eme ɖe nunyadidi ŋuti o? 
\b  
\q1  
\v 17 Xɔlɔ̃ lɔ̃a ame ɣeawo katã ɣi, 
\q2 ke wodzi nɔviŋutsu hena hiãgbe. 
\b  
\q1  
\v 18 Ame manyanu ƒua asi akɔ 
\q2 eye wòdoa ŋugbe tsɔa eɖokui daa megbee na ehavi si nyi fe. 
\b  
\q1  
\v 19 Ame si lɔ̃ dzrewɔwɔ la lɔ̃a nu vɔ̃ 
\q2 eye ame si de agbo kɔkɔ eƒe aƒe nu la le gbegblẽ dim. 
\b  
\q1  
\v 20 Ame si si dzi dovo le la nu medzea edzi nɛ o 
\q2 eye ame si si alakpaɖe le la gena ɖe fukpekpe me. 
\b  
\q1  
\v 21 Viŋutsu si tsi bome la hea veve vɛ, 
\q2 eye fofo si, si vi tsibome le la makpɔ dzidzɔ o. 
\b  
\q1  
\v 22 Dzi si kpɔa dzidzɔ la nye atike nyui, 
\q2 ke gbɔgbɔ si wote ɖe to la nana ƒu tome ƒuna kplakplakpla. 
\b  
\q1  
\v 23 Ame vɔ̃ɖi xɔa zãnu le bebeme be 
\q2 wòatrɔ nya dzɔdzɔe atsyɔ anyi. 
\b  
\q1  
\v 24 Ame si si sidzedze le la ƒe ŋku nɔa nunya ŋu, 
\q2 ke bometsila ƒe ŋkuwo tsana, 
\q2 dona ɖe anyigba ƒe mlɔenu ke. 
\b  
\q1  
\v 25 Viŋutsu tsibome hea nuxaxa vɛ na fofoa 
\q2 kple veve vɛ na ame si dzii. 
\b  
\q1  
\v 26 Menyo be woahe to na fɔmaɖila 
\q2 alo aƒo dɔnunɔla ɖe eƒe nuteƒewɔwɔ ta o. 
\b  
\q1  
\v 27 Ame si si sidzedze su la nya vlowo medona le enu o 
\q2 eye ame si si gɔmesese le la ɖɔa ŋu ɖo, 
\q2 medoa dziku dzodzro o. 
\b  
\q1  
\v 28 Wobua bometsila gɔ̃ hã nunyalae nenye be ezi ɖoɖoe, 
\q2 eye wobunɛ sidzelae ne ekpɔ eƒe aɖe dzi nyuie. 
\b  
\c 18  
\q1  
\v 1 Ɖokuitɔdila dia eɖokui ko tɔ 
\q2 eye meɖoa to nunyanya siwo gblɔm wole la o. 
\b  
\q1  
\v 2 Bometsila medoa vivi ɖe gɔmesese ŋu o, 
\q2 ke boŋ ekpɔa dzidzɔ le eya ŋutɔ ƒe susuɖegblɔ ŋu. 
\b  
\q1  
\v 3 Ne vɔ̃ɖivɔ̃ɖi va la, vlododo kplɔnɛ ɖo 
\q2 eye ne alɔmeɖeɖe va la, ŋukpe dzea eyome. 
\b  
\q1  
\v 4 Ame ƒe numenyawo nye tɔ goglo, 
\q2 ke nunya ƒe vudo nye ta si le dzidzim. 
\b  
\q1  
\v 5 Menyo be woade ame vɔ̃ɖi dzi 
\q2 alo atrɔ ame maɖifɔ ƒe nya dzɔdzɔe atsyɔ anyi o. 
\b  
\q1  
\v 6 Bometsila ƒe nuyiwo denɛ dzre me 
\q2 eye eƒe nu hea ƒoƒo vaa edzii. 
\b  
\q1  
\v 7 Nu si bometsila ƒe nu gblɔ la, 
\q2 metso eya ŋutɔ gbɔ o, eye eƒe nuyi nye mɔka na eƒe luʋɔ. 
\b  
\q1  
\v 8 Amenyagblɔla ƒe nyawo vivina 
\q2 abe nuɖuɖu vivi si woka de nu me la ene; 
\q2 woyina ɖe ame ƒe dɔgbowo me ke. 
\b  
\q1  
\v 9 Ame si wɔa alɔgblɔdɔ le eƒe dɔ 
\q2 ŋuti la nye nugblẽla nɔvi. 
\b  
\q1  
\v 10 Yehowa ƒe ŋkɔ nye mɔ sesẽ, 
\q2 ame dzɔdzɔewo sina yia eme eye wonɔa dedie. 
\b  
\q1  
\v 11 Kesinɔtɔwo ƒe kesinɔnuwo nye woƒe du sesẽ 
\q2 eye wobuna be wonye gli kɔkɔ si ame aɖeke mate ŋu aflɔ o. 
\b  
\q1  
\v 12 Hafi ame aɖe nadze anyi la, 
\q2 dada nɔa eƒe dzi me, 
\q2 ke ɖokuibɔbɔ doa ŋgɔ na bubu. 
\b  
\q1  
\v 13 Enye bometsitsi kple ŋukpe na ame, 
\q2 be wòaɖo nya ŋu hafi ase nu si gblɔm wole. 
\b  
\q1  
\v 14 Ame ƒe gbɔgbɔ lénɛ ɖe te le dɔléle me, 
\q2 ke ame ka ate ŋu atsɔ gbɔgbɔ si gbã gudugudu? 
\b  
\q1  
\v 15 Sidzela ƒe dzi kpɔa gɔmesese 
\q2 eye nunyala ƒe to dia gɔmesese. 
\b  
\q1  
\v 16 Nunana ʋua mɔ na nunala 
\q2 eye wòkplɔnɛ gena ɖe amegã la ƒe ŋkumee. 
\b  
\q1  
\v 17 Ame gbãtɔ si to eƒe nya la dzena dzɔdzɔetɔe 
\q2 va se ɖe esime ame aɖe va bia gbee. 
\b  
\q1  
\v 18 Nudzidze tsia dzre nu 
\q2 eye wòtsoa nya me na ame sesẽ siwo le dzre wɔm. 
\b  
\q1  
\v 19 Nɔviŋutsu si dzi wodze agɔ le la sẽ wu du si ŋu woɖo gli sesẽ ɖo 
\q2 eye dzrewɔwɔ le abe fiasã si ƒe agbowo ŋu wode gameti sesẽwoe ene. 
\b  
\q1  
\v 20 Ame ƒe numekutsetse ɖia ƒo nɛ 
\q2 eye nuŋeŋe si doa go tso eƒe nuyiwo me la ana eƒe dzi nadze eme. 
\b  
\q1  
\v 21 Ku kple agbe ƒe ŋusẽ le aɖe si, 
\q2 eye ame siwo lɔ̃e la aɖu eƒe kutsetse. 
\b  
\q1  
\v 22 Ame si si srɔ̃nyɔnu su la ke ɖe nu nyui ŋu 
\q2 eye wòxɔa amenuveve tso Yehowa gbɔ. 
\b  
\q1  
\v 23 Ame dahe ɖea kuku biaa nublanuikpɔkpɔ, 
\q2 ke kesinɔtɔ ya ɖoa nya ŋu adãtɔe. 
\b  
\q1  
\v 24 Ame si si xɔlɔ̃ geɖe le la ate ŋu awu nu le gbegblẽ me, 
\q2 gake xɔlɔ̃ aɖe li si kuna ɖe ame ŋu wu dadavi gɔ̃ hã. 
\b  
\c 19  
\q1  
\v 1 Anyo be nànye ame dahe si ƒe zɔzɔme ŋu fɔɖiɖi mele o, 
\q2 wu bometsila si ƒe nuyiwo gblɔa nya tovo. 
\b  
\q1  
\v 2 Menyo be dzo nanɔ mewò ɖe nuwo wɔwɔ ŋu gɔmesesemanɔmee 
\q2 alo atsi dzi ahabu mɔ o. 
\b  
\q1  
\v 3 Ame ŋutɔ ƒe bometsitsie gblẽa eƒe agbe dome, 
\q2 evɔ eƒe dzi bina ɖe Yehowa ŋu. 
\b  
\q1  
\v 4 Kesinɔnunɔamesi dzea xɔlɔ̃ geɖe na ame, 
\q2 gake ame dahe ƒe xɔlɔ̃wo kakana le eŋu. 
\b  
\q1  
\v 5 Womagbe tohehe na aʋatsoɖasefo o 
\q2 eye ame si trɔa alakpa kɔna ɖi bababa la, 
\q2 madzo le ablɔɖe me o. 
\b  
\q1  
\v 6 Ame geɖewo wɔa nu be woadze fia ŋu, 
\q2 eye ame si naa nu ame faa la, ame sia ame dzea xɔ̃e. 
\b  
\q1  
\v 7 Ame dahe ƒe ƒometɔwo katã ɖea kɔ ɖa le eŋu, 
\q2 aleke exɔlɔ̃wo magbee geɖe wu o! 
\q1 Togbɔ be etia wo yome nɔa kuku ɖem na wo hã la, 
\q2 womedea nu eme nɛ o. 
\b  
\q1  
\v 8 Ame si, si nunya su la lɔ̃a eya ŋutɔ ƒe luʋɔ 
\q2 eye ame si melɔ̃a nu le gɔmesese gbɔ o la, 
\q2 nu dzea edzi nɛ. 
\b  
\q1  
\v 9 Womagbe tohehe na aʋatsoɖasefo o 
\q2 eye ame si trɔa alakpa kɔna ɖi bababa la atsrɔ̃. 
\b  
\q1  
\v 10 Agbe vivi nɔnɔ medze bometsila ʋuu keke 
\q2 wòahanye be kluvi ɖu aƒetɔ ɖe dumegãwo dzi o. 
\b  
\q1  
\v 11 Ame ƒe nunya nana wògbɔa dzi ɖi 
\q2 eye ŋutikɔkɔe wònye nɛ ne eŋe aɖaba ƒu dzidada dzi. 
\b  
\q1  
\v 12 Fia ƒe dziku le abe dzata ƒe gbetete ene, 
\q2 ke eƒe amenuveve le abe zãmu le gbedzi ene. 
\b  
\q1  
\v 13 Viŋutsu tsibome nye fofoa ƒe gbegblẽ 
\q2 eye srɔ̃nyɔnu dzrewɔla le abe tsitrɔnu si le ɖuɖum ɖaa ene. 
\b  
\q1  
\v 14 Aƒewo kple kesinɔnuwo nye domenyinu tso dzilawo gbɔ, 
\q2 ke srɔ̃nyɔnu nyanu ya, 
\q2 Yehowa gbɔe wòtsona. 
\b  
\q1  
\v 15 Kuvia nana ame dɔa alɔ̃ yia eme ʋĩi 
\q2 eye dɔ wua ƒomewɔla. 
\b  
\q1  
\v 16 Ame si wɔna ɖe sedede dzi la dzɔa eƒe agbe ŋu, 
\q2 ke ame si metsɔ ɖeke le eƒe mɔwo ŋu o la aku. 
\b  
\q1  
\v 17 Ame si nyo dɔ me na hiãtɔ la, 
\q2 do nugbana na Yehowa, aɖo nu si wòwɔ la teƒe nɛ. 
\b  
\q1  
\v 18 He to na viwò ŋutsuvi elabena eya mee mɔkpɔkpɔ le; 
\q2 ke mègakpe ɖe ame siwo le eƒe ku dim la ŋuti o. 
\b  
\q1  
\v 19 Ame si dzi kuna helĩhelĩ la, 
\q2 axe eŋutife; ne èɖee le eme la, agawɔe ake. 
\b  
\q1  
\v 20 Ɖo to aɖaŋuɖoɖo, 
\q2 nàxɔ amehehe eye le nuwuwua la, àdze nunya. 
\b  
\q1  
\v 21 Nu geɖewo ame ɖo ɖe eƒe dzi me, 
\q2 gake Yehowa ƒe ɖoɖo koe vaa eme. 
\b  
\q1  
\v 22 Nu si ame dina lae nye lɔlɔ̃ si meʋãna o; 
\q2 enyo be nànye ame dahe wu alakpatɔ. 
\b  
\q1  
\v 23 Yehowavɔvɔ̃ kplɔa ame yia agbe gbɔe. 
\q2 Ekema ànɔ anyi aɖe dzi ɖi 
\q2 eye kuxi aɖeke maƒo go wò o. 
\b  
\q1  
\v 24 Ne kuviatɔ de asi nuɖugba me la, 
\q2 maɖee ɖa atsɔ yi nu gbɔe teti gɔ̃ hã o! 
\b  
\q1  
\v 25 Ƒo fewuɖula kple ati, 
\q2 ekema gegemewo adze nunya; 
\q2 ka mo na ame si si sidzedze le, ekema gɔmesese asu esi. 
\b  
\q1  
\v 26 Ame si daa adzo fofoa, 
\q2 nyaa dada doa goe lae nye viŋutsu si hea ŋukpe 
\q2 kple vlododo vɛ. 
\b  
\q1  
\v 27 Vinye, ne èdzudzɔ amehenyawo sese la, 
\q2 ekema àtra tso gɔmesese ƒe nyawo gbɔ. 
\b  
\q1  
\v 28 Aʋatsoɖasefo ɖua fewu le afia nyui tsotso ŋu 
\q2 eye ame vɔ̃ɖi ƒe nu miaa nu vɔ̃ɖi. 
\b  
\q1  
\v 29 Woɖo tohehe ɖi na fewuɖulawo 
\q2 eye woɖo ƒoƒo ɖi na bometsilawo ƒe dzime. 
\b  
\c 20  
\q1  
\v 1 Wain nye fewuɖula eye aha muame nye avuwɔla, 
\q2 ame si wokplɔ trae la menya nu o. 
\b  
\q1  
\v 2 Fia ƒe dziku doa vɔvɔ̃ abe dzata ƒe gbetete ene 
\q2 ame si do dziku nɛ la bua eƒe agbe. 
\b  
\q1  
\v 3 Bubu wònye na ŋutsu ne eƒo asa na dzre 
\q2 gake bometsila ɖe sia ɖe wɔa dzre kabakaba. 
\b  
\q1  
\v 4 Kuviatɔ meŋlɔa agble le agbledeɣi o, 
\q2 eya ta edia nu le nuŋeɣi doa kpoe. 
\b  
\q1  
\v 5 Ŋutsu ƒe tameɖoɖowo nye tɔ goglo, 
\q2 gake ame si si nugɔmesese su la akui wòavɔ. 
\b  
\q1  
\v 6 Ŋutsu geɖewo gblɔna be lɔlɔ̃ matrɔ le yewo si 
\q2 gake ame ka ate ŋu akpɔ ŋutsu nuteƒewɔla? 
\b  
\q1  
\v 7 Ame dzɔdzɔe nɔa agbe si ŋu kpɔtsɔtsɔ mele o; 
\q2 yayra anɔ viawo dzi emegbe gɔ̃ hã. 
\b  
\q1  
\v 8 Ne fia nɔ anyi ɖe eƒe fiazikpui dzi be yeadrɔ̃ ʋɔnu la, 
\q2 eɖe vɔ̃wo katã ɖa kple eƒe ŋkuwo. 
\b  
\q1  
\v 9 Ame ka ate ŋu agblɔ bena, 
\q2 “Mewɔ nye dzi dzadzɛe, 
\q2 ŋutinye kɔ eye vɔ̃ mele ŋutinye o?” 
\b  
\q1  
\v 10 Yehowa lé fu nudakpe vovovo eve 
\q2 kple nudzidzenu vovovo eve siaa. 
\b  
\q1  
\v 11 Wonyaa ɖevi gɔ̃ hã to eƒe nuwɔna me, 
\q2 ne ele agbe dzadzɛ eye eƒe nuwɔnawo le eteƒe. 
\b  
\q1  
\v 12 Yehowa wɔ to si sea nu 
\q2 kple ŋku si kpɔa nu la siaa. 
\b  
\q1  
\v 13 Mègalɔ̃ alɔ̃ tsu dɔdɔ o, ne menye nenema o la, 
\q2 àva zu hiãtɔ, nɔ ŋu ekema àɖu nu wòasusɔ. 
\b  
\q1  
\v 14 Nuƒlela gblɔna be, 
\q2 “Menyo o, menyo o,” 
\q2 emegbe la, eyina ɖanɔa adegbe ƒom be yeƒle nu ɖiɖi. 
\b  
\q1  
\v 15 Sika li, adzagba hã li fũu 
\q2 gake nuyi siwo gblɔa nunyanya la, kpe xɔasi veviwo wonye. 
\b  
\q1  
\v 16 Xɔ avɔ le ame si da megbe na amedzro la si, 
\q2 tsɔe ɖo awɔbae ne eda megbe na nyɔnu gbolowɔla. 
\b  
\q1  
\v 17 Nuɖuɖu si wokpɔ to amefuflu me la vivina na ŋutsu, 
\q2 gake le nuwuwu la, eƒe nu me yɔna kple kpekui sɔŋ. 
\b  
\q1  
\v 18 Wɔ ɖoɖo to aɖaŋuxɔxɔ me, 
\q2 ne èle aʋa wɔm la, bia mɔfiame. 
\b  
\q1  
\v 19 Amenyagblɔla ʋua go nya ɣaɣla 
\q2 eya ta ƒo asa na ŋutsu nukpoloeƒola. 
\b  
\q1  
\v 20 Ne ŋutsu do ɖiŋu na fofoa alo dadaa la, 
\q2 woatsi eƒe akaɖi ne ele viviti tsiɖitsiɖi me. 
\b  
\q1  
\v 21 Domenyinu si wokpɔ to mɔ kpui dzi le gɔmedzedzea me la, 
\q2 yayra manɔ edzi le nuwuwua o. 
\b  
\q1  
\v 22 Mègagblɔ be, 
\q2 “Maɖo vɔ̃ si nèwɔ ɖe ŋunye la teƒe na wò” o! 
\q2 Kpɔ Yehowa ƒe asinu ekema aɖe wò. 
\b  
\q1  
\v 23 Yehowa lé fu nudakpe ƒomevi vovovowo 
\q2 eye nudanu amebatɔ hã menyoa Yehowa ŋu o. 
\b  
\q1  
\v 24 Yehowa fiaa afɔɖeɖe ame, 
\q2 ke aleke ame aɖe awɔ ase eya ŋutɔ ƒe mɔwo gɔme? 
\b  
\q1  
\v 25 Mɔ wònye na ame ne ekɔ nane ŋu tamemabumabutɔe 
\q2 eye emegbe hafi wòva bu adzɔgbe si wòɖe la ŋuti. 
\b  
\q1  
\v 26 Fia nyanu gbɔa ame vɔ̃ɖiwo 
\q2 eye wòzɔa wo dzi kple luƒotasiaɖam. 
\b  
\q1  
\v 27 Yehowa ƒe akaɖi kpɔa ame ƒe gbɔgbɔ me 
\q2 eye wòdzroa eƒe ememe ke kpɔ. 
\b  
\q1  
\v 28 Lɔlɔ̃ kple nuteƒewɔwɔ nana fia nɔa dedinɔnɔ me 
\q2 eye to lɔlɔ̃ me eƒe fiazikpui lia ke. 
\b  
\q1  
\v 29 Ɖekakpuiwo ƒe ŋusẽe nye woƒe ŋutikɔkɔe 
\q2 eye ta ƒowɔ nye ame tsitsiwo ƒe atsyɔ̃. 
\b  
\q1  
\v 30 Kɔ kple abixɔxɔ ɖea vɔ̃ ɖa 
\q2 eye ƒoƒo klɔa ame ƒe ememe ke. 
\b  
\c 21  
\q1  
\v 1 Fia la ƒe dzi le Yehowa ƒe asi me; 
\q2 efiaa mɔe wòtoa afi sia afi si wòlɔ̃ la 
\q2 abe ale si woɖea toƒe na tsi si si tso tsidzɔtsoƒe ene. 
\b  
\q1  
\v 2 Ŋutsu ƒe mɔwo katã dzea eŋu 
\q2 gake Yehowae daa dziwo kpɔ. 
\b  
\q1  
\v 3 Nu dzɔdzɔe kple nu si 
\q2 le eteƒe wɔwɔ doa dzidzɔ na Yehowa wu vɔsa. 
\b  
\q1  
\v 4 Ŋku gã kple dzi si me dada 
\q2 le lae nye ame vɔ̃ɖiwo ƒe akaɖi, 
\q2 evɔ wòhenye nu vɔ̃. 
\b  
\q1  
\v 5 Vevidonula ƒe ɖoɖoɖowo hea viɖe vɛ 
\q2 nenema kee dzitsitsi hea ahedada vɛ. 
\b  
\q1  
\v 6 Kesinɔnu si wotsɔ alakpaɖe kpɔe la nu va yina kaba 
\q2 abe ƒuƒu ene eye wònye mɔ si ŋu aɖi vɔ̃ɖi le. 
\b  
\q1  
\v 7 Ame vɔ̃ɖiwo ƒe ŋutasẽnuwɔwɔ ahe wo adzoe 
\q2 elabena wogbe be yewomawɔ nu nyui o. 
\b  
\q1  
\v 8 Fɔɖila ƒe mɔ le gɔdɔ̃gɔdɔ̃ 
\q2 gake fɔmaɖila ƒe nuwɔwɔ le dzɔdzɔe. 
\b  
\q1  
\v 9 Enyo be woanɔ dzogoe dzi le xɔta wu be woanɔ xɔ ɖeka me 
\q2 kple srɔ̃nyɔnu dzrewɔla. 
\b  
\q1  
\v 10 Nu vɔ̃ɖi wɔwɔ dzroa ame vɔ̃ɖi vevie, 
\q2 mekpɔa nublanui na ehavi o. 
\b  
\q1  
\v 11 Ne wohe to na fewuɖula la, 
\q2 bometsilawo dzea nunya; 
\q2 ne wofia nu nunyala la, sidzedze sua esi. 
\b  
\q1  
\v 12 Dzɔdzɔetɔ la ɖea ŋku ɖe ame vɔ̃ɖi ƒe aƒe ŋu, 
\q2 eye wòhea gbegblẽ vaa ame vɔ̃ɖi la dzi. 
\b  
\q1  
\v 13 Ne ame aɖe do toku ame dahe ƒe ɣlidodo la, 
\q2 ne eya hã do ɣli la, 
\q2 ame aɖeke masee nɛ o. 
\b  
\q1  
\v 14 Nunana si wona le adzame la faa dziku nu 
\q2 eye zãnu si woɣla ɖe awu ʋlaya te hafi tsɔ vɛ la 
\q2 léa avu dziku helĩhelĩ. 
\b  
\q1  
\v 15 Afia nyui tsotso hea dzidzɔ vɛ na ame dzɔdzɔe, 
\q2 ke ehea ŋɔdzi vɛ na vɔ̃ wɔlawo. 
\b  
\q1  
\v 16 Ŋutsu si tra tso gɔmesese ƒe mɔ dzi la 
\q2 va dzudzɔna le ame kukuwo ƒe ha me. 
\b  
\q1  
\v 17 Ame si lɔ̃a agbeɖuɖu la azu hiãtɔ 
\q2 eye ame si lɔ̃a wain kple ami la makpɔ hotsui o. 
\b  
\q1  
\v 18 Ame vɔ̃ɖi zua avulénu ɖe ame dzɔdzɔe teƒe 
\q2 eye nenema ke nuteƒemawɔla ɖea nuteƒewɔla nu. 
\b  
\q1  
\v 19 Enyo be nànɔ dzogbe wu be nànɔ anyi 
\q2 kple srɔ̃nyɔnu dzrewɔla kple dɔmedzoedola. 
\b  
\q1  
\v 20 Nuɖuɖu vivi kple ami bɔ ɖe nunyala ƒe aƒe me fũu, 
\q2 gake bometsila ɖua nu sia nu si le esi. 
\b  
\q1  
\v 21 Ame si tia dzɔdzɔenyenye kple lɔlɔ̃ la, 
\q2 tia agbe, dzidzedze kple bubu. 
\b  
\q1  
\v 22 Nunyala dze kalẽtɔ ƒe du dzi 
\q2 eye wòmu mɔ sesẽ si ŋu wole dzi ɖom ɖo la ƒu anyi. 
\b  
\q1  
\v 23 Ame si kpɔa eƒe nu kple eƒe aɖe dzi la, 
\q2 ɖea eɖokui tso dzɔgbevɔ̃e me. 
\b  
\q1  
\v 24 Ŋutsu dadala, ɖokuiŋudzela, 
\q2 si wɔa nu tovo kple dada la, eyae woyɔna be, “Fewuɖula.” 
\b  
\q1  
\v 25 Kuviatɔ ƒe nudzodzro ahe ku vɛ nɛ, 
\q2 elabena eƒe asiwo gbe be yewomawɔ dɔ o. 
\q1  
\v 26 Ele nu dzrom ŋkeke blibo la, 
\q2 ke ame dzɔdzɔe la nana faa, eye metea ame o. 
\b  
\q1  
\v 27 Ame vɔ̃ɖi ƒe vɔsa nye ŋunyɔnu, 
\q2 kaka wòahanye be etsɔe vɛ kple susu vɔ̃ɖi. 
\b  
\q1  
\v 28 Aʋatsoɖasefo atsrɔ̃ eye ame si ɖoa toe la atsrɔ̃ gbidigbidi. 
\b  
\q1  
\v 29 Ame vɔ̃ɖi ɖoa mo kplala ɖi, 
\q2 ke dzɔdzɔetɔ léa ŋku ɖe eƒe mɔwo ŋu. 
\b  
\q1  
\v 30 Nunya, gɔmesese kple ɖoɖo aɖeke meli si adze edzi o, 
\q2 ne etsi tsitre ɖe Yehowa ŋu. 
\b  
\q1  
\v 31 Woblaa akpa na sɔ ɖe aʋakpegbe ŋu, 
\q2 gake Yehowa ƒe asimee dziɖuɖu ya le. 
\b  
\c 22  
\q1  
\v 1 Ŋkɔ nyui didi nyo wu kesinɔnuwo 
\q2 eye ŋudzedzekpɔkpɔ nyo wu klosalo kple sika. 
\b  
\q1  
\v 2 Nu ɖeka siae nàkpɔ le kesinɔtɔ kple ame dahe ŋu: 
\q2 Yehowae nye wo katã Wɔla. 
\b  
\q1  
\v 3 Nunyala kpɔ dzɔgbevɔ̃e gbɔna eye wòɣla eɖokui 
\q2 gake bometsila ya yiyim ko wòle eye wòkpea fu ɖe enu. 
\b  
\q1  
\v 4 Ɖokuibɔbɔ kple Yehowavɔvɔ̃ hea kesinɔnu, 
\q2 bubu kple agbe vɛ. 
\b  
\q1  
\v 5 Ŋu kple mɔkawo le ame vɔ̃ɖi la ƒe mɔ dzi, 
\q2 ke ame si dzɔ eƒe luʋɔ ŋuti la, ate ɖa xaa tso wo gbɔ. 
\b  
\q1  
\v 6 He ɖevi ɖe mɔ si wòato la dzi eye ne etsi la, 
\q2 mate ɖa le edzi o. 
\b  
\q1  
\v 7 Kesinɔtɔwo ɖua gã ɖe ame dahewo dzi 
\q2 eye nugbanadola zua dɔla na ame si do nugbana la nɛ. 
\b  
\q1  
\v 8 Ame si ƒã vɔ̃ɖivɔ̃ɖi la axa dzɔgbevɔ̃e, 
\q2 eye woatsrɔ eƒe dɔmedzoe ƒe ameƒoti. 
\b  
\q1  
\v 9 Woayra ame si nyoa dɔ me na amewo 
\q2 elabena emaa eƒe nuɖuɖu kple ame dahewo. 
\b  
\q1  
\v 10 Nya fewuɖula la do goe eye dzre hã ado go, 
\q2 nenema ke nyahehe kple dzudzu hã awu nu. 
\b  
\q1  
\v 11 Ame si lɔ̃ dzi dzadzɛ kple nuƒoƒo si me nya dzetowo le la, 
\q2 eyae fia la adze xɔ̃e. 
\b  
\q1  
\v 12 Yehowa ƒe ŋkuwo le nugɔmesese ŋu, 
\q2 ke etrɔa gbo nuteƒemawɔlawo ƒe nyawo. 
\b  
\q1  
\v 13 Kuviatɔ gblɔna be, 
\q2 “Dzata le gota!” alo “Woava wum le ablɔ dzi!” 
\b  
\q1  
\v 14 Nyɔnu ahasitɔ ƒe nu la, ʋe globo wònye 
\q2 eye ame si dzi Yehowa ƒe dziku le la eyae age adze eme. 
\b  
\q1  
\v 15 Wobla bometsitsi ɖe ɖevi ƒe dzi ŋu, 
\q2 ke ɖɔɖɔɖo ƒe ameƒoti ana wòate ɖa xaa tso egbɔ. 
\b  
\q1  
\v 16 Ame si tea ame dahewo ɖe anyi be 
\q2 yeadzi yeƒe kesinɔnuwo ɖe edzi 
\q2 kple ame si naa nu kesinɔtɔ la siaa age ɖe hiã me. 
\ms1 Nunyala ƒe nya blaetɔ̃awo 
\s2 Nya gbãtɔ 
\q1  
\v 17 Ƒu to anyi eye nàse nunyalawo ƒe nyawo, 
\q2 na wò dzi naku ɖe nu si fiam mele ŋuti, 
\q1  
\v 18 elabena edoa dzidzɔ na ame ne èɣla wo ɖe wò dzi me, 
\q2 eye wo katã nanɔ klalo le wò nuyiwo dzi. 
\q1  
\v 19 Ale be nàɖo dzi ɖe Yehowa ŋu, 
\q2 esia ta mele nu fiam wò ɖo egbea, 
\q2 ɛ̃, wòe mele nu fiam. 
\q1  
\v 20 Ɖe nyemeŋlɔ nufiamenya blaetɔ̃ na wò, 
\q2 aɖaŋuɖonyawo kple nugɔmesenyawo 
\q1  
\v 21 be woafia nyateƒe kple kakaɖedzinyawo 
\q2 wò be nàtsɔ nunyanyawo aɖo nya ŋu 
\q2 na ame si dɔ wò la oa? 
\s2 Nya evelia 
\q1  
\v 22 Mègaba ame dahewo le esi woda ahe ta o 
\q2 eye mègate hiãtɔ ɖe to le ʋɔnu o, 
\q1  
\v 23 elabena Yehowa axɔ nya ɖe wo nu 
\q2 eye wòaha ame si ha wo. 
\s2 Nya etɔ̃lia 
\q1  
\v 24 Mègadze xɔ̃ ŋutsu dɔmedzoetɔ o 
\q2 eye mègade ha kple ame si doa dziku kabakaba o, 
\q1  
\v 25 ne menye nenema o la, àva srɔ̃ eƒe mɔwo 
\q2 eye nàtsɔ ɖokuiwò ade mɔ me. 
\s2 Nya enelia 
\q1  
\v 26 Mèganye ame si ƒua asi akɔ ɖe fenyila nu 
\q2 alo dea megbe na ame si do nugbana la o; 
\q1  
\v 27 eye ne mèkpɔ ga axe fea o la, 
\q2 woaɖe aba si dzi nèmlɔna la gɔ̃ hã le tewò. 
\s2 Nya atɔ̃lia 
\q1  
\v 28 Mègaɖe blemaliƒokpe 
\q2 si fofowòwo ɖi la ɖa o. 
\s2 Nya adelia 
\q1  
\v 29 Èkpɔ ame si bi ɖe eƒe dɔ me la le dɔ wɔma? 
\q2 Asubɔ le fiawo ŋgɔ 
\q2 eye menye le ame tsɛwo ŋgɔ o. 
\c 23  
\s2 Nya adrelia 
\q1  
\v 1 Ne ènɔ kplɔ̃ ŋu be yeaɖu nu kple fia la, 
\q2 lé ŋku ɖe nu si wotsɔ ɖo akɔwò me la ŋu nyuie 
\q1  
\v 2 eye tsɔ hɛ ɖo wò ve dzi 
\q2 ne ènye nutsuɖula. 
\q1  
\v 3 Mègadzro eƒe nuɖuɖu kpeɖiwo o 
\q2 elabena nuɖuɖu ma nye beble. 
\s2 Nya enyilia 
\q1  
\v 4 Mègaku kutri vivivo, 
\q2 agbɔdzɔ ɖokuiwò be yeakpɔ hotsui o, 
\q2 dze nunya nàlé avu ɖokuiwò. 
\q1  
\v 5 Kasia wò ŋku nabe yeato kesinɔnuwo dzi la, 
\q2 wo nu va yi xoxo 
\q1 elabena woato aʋala godoo 
\q2 eye woadzo adzo ayi ɖe dziƒo ʋĩi abe hɔ̃ ene. 
\s2 Nya asiekelia 
\q1  
\v 6 Mègaɖu ŋutsu nuvela ƒe nuɖuɖu o, 
\q2 eye eƒe nuɖuɖu kpeɖiwo megadzro wò o, 
\q1  
\v 7 elabena enye ame si le ga si wòagblẽ ɖe nua ɖaɖa ŋuti la ŋu bum. 
\q2 Egblɔ na wò be, 
\q1 “Ɖu nu, nàno nu” 
\q2 gake megblɔe tso eƒe dzi me o. 
\q1  
\v 8 Àdzɔ nu sue si nèɖu la hã 
\q2 eye àtsɔ wò kafukafunya siwo nègblɔ la hã ada ahee. 
\s2 Nya ewolia 
\q1  
\v 9 Mègaƒo nu ɖe bometsila ƒe to me o, 
\q2 elabena ado vlo wò nunyanyawo. 
\s2 Nya wuiɖekɛlia 
\q1  
\v 10 Mègaɖe blemaliƒokpewo ɖa 
\q2 alo age ɖe tsyɔ̃eviwo ƒe agble me o 
\q1  
\v 11 elabena ŋusẽtɔe nye wo ta ʋlila; 
\q2 eye awɔ avu kpli wò ɖe wo nu. 
\s2 Nya wuievelia 
\q1  
\v 12 Tsɔ wò dzi ku ɖe nufiame ŋu 
\q2 eye wò towo natrɔ ɖe gɔmesese ŋu. 
\s2 Nya wuietɔ̃lia 
\q1  
\v 13 Mègagbe tohehe na ɖevi o, 
\q2 ne èƒoe kple ati la, mele kuku ge o. 
\q1  
\v 14 Tsɔ ameƒoti he to nɛ 
\q2 eye àɖe eƒe luʋɔ tso ku me. 
\s2 Nya wuienelia 
\q1  
\v 15 Vinye, ne wò dzi dze nunya la, 
\q2 ekema nye hã nye dzi akpɔ dzidzɔ 
\q1  
\v 16 eye nye ememe ke atso aseye ne wò 
\q2 nuyiwo gblɔ nu si le dzɔdzɔe. 
\s2 Nya wuiatɔ̃lia 
\q1  
\v 17 Mègana wò dzi naʋã ŋu nu vɔ̃ wɔlawo o, 
\q2 ke boŋ tsɔ dzo ɖe Yehowavɔvɔ̃ ŋu. 
\q1  
\v 18 Vavã, mɔkpɔkpɔ le asiwò hena etsɔ si gbɔna 
\q2 eye wò mɔkpɔkpɔ mazu dzodzro o. 
\s1 Nya wuiadelia 
\q1  
\v 19 Vinye, ɖo tom ne nàdze nunya 
\q2 eye na wò dzi nanɔ mɔ dzɔdzɔetɔ dzi. 
\q1  
\v 20 Mègade ha kple ame siwo nye waintsunolawo 
\q2 alo lã geɖe ɖulawo o. 
\q1  
\v 21 Elabena ahatsunolawo kple nutsuɖulawo la, 
\q2 ahee wodana eye alɔ̃ tsu dɔdɔ nana wonɔa awu vuvuwo me. 
\s2 Nya wuiadrelia 
\q1  
\v 22 Ɖo to fofowò, ame si dzi wò 
\q2 eye mègado vlo dawò ne eku nyagã o. 
\q1  
\v 23 Ƒle nyateƒe la eye mègadzrae o; 
\q2 ƒle nunya, amehehe kple gɔmesese. 
\q1  
\v 24 Ame dzɔdzɔe fofo atso aseye geɖe 
\q2 eye ame si si vi nyanu le la akpɔ dzidzɔ le eŋu. 
\q1  
\v 25 Dawò kple fofowò nekpɔ dzidzɔ 
\q2 eye nyɔnu si dzi wò la netso aseye! 
\s2 Nya wuienyilia 
\q1  
\v 26 Vinye, tsɔ wò dzi nam 
\q2 eye wò ŋkuwo nenɔ nye mɔwo ŋu 
\q1  
\v 27 elabena gbolo la, ʋe globoe wònye 
\q2 eye srɔ̃nyɔnu ahasitɔ la, 
\q2 vudo xaxɛ wònye. 
\q1  
\v 28 Ede xa ɖi abe adzodala ene 
\q2 eye wòdzia ŋutsu ahasitɔwo ƒe xexlẽme ɖe edzi. 
\s2 Nya wuiasiekelia 
\q1  
\v 29 Ame kae le hũu ɖem? 
\q2 Ame kae le veve sem? 
\q1 Ame kae le nu xam? 
\q2 Ame kae le eƒe nuteɖeamedziwo gblɔm? 
\q1 Ame kae xɔ abi yakatsyɔ? 
\q2 Ame ka ƒe ŋkue biã abe ʋu ene? 
\q1  
\v 30 Ame siwo tsia wainze te la tɔe, 
\q2 ame siwo yina ɖaɖɔa wain si wotɔtɔ kpɔ la tɔe. 
\q1  
\v 31 Mègaɖɔ wain kpɔ ne ebiã dzẽe, 
\q2 ne ele fu tsɔm le kplu me, 
\q2 ne eto vetome heɖiɖi ɖe dɔ me o! 
\q1  
\v 32 Le nuwuwu la, 
\q2 eɖua ame abe da ene 
\q2 eye wònyɔa aɖi abe ƒli ene. 
\q1  
\v 33 Wò ŋkuwo akpɔ nu tutɔ manyatalenuwo 
\q2 eye wò susu anɔ nu baɖabaɖawo susum. 
\q1  
\v 34 Ànɔ abe ame si mlɔ atsiaƒu gbana dzi 
\q2 alo ame si mlɔ abala dzi ene. 
\q1  
\v 35 Àgblɔ be, 
\q2 “Woxlã nu ɖem gake nyemexɔ abi o! 
\q1 Woƒom gake mevem o! 
\q2 Ɣe ka ɣi gɔ̃ manyɔ ne magadi ahayomemɔ?” 
\c 24  
\s2 Nya blaevelia 
\q1  
\v 1 Mègabiã ŋu ame vɔ̃ɖiwo o, 
\q2 mègadi woƒe hamenɔnɔ o 
\q1  
\v 2 elabena woƒe dzi ɖoa nu tovo 
\q2 eye woƒe nuyiwo ƒoa nu tso nu gbegblẽ wɔwɔ ŋuti. 
\s2 Nya blaeve-vɔ-ɖekɛlia 
\q1  
\v 3 Nunya wotsɔna tua xɔe 
\q2 eye gɔmesese wotsɔna ɖoa egɔme anyie, 
\q1  
\v 4 to sidzedze me wotsɔa nu nyui tɔxɛ siwo mebɔ o 
\q2 kple kesinɔnu nyuiwo yɔa woƒe xɔwo mee. 
\s2 Nya blaeve-vɔ-evelia 
\q1  
\v 5 Ŋusẽ gã aɖe le nunyala si 
\q2 eye ame si si gɔmesese le la dzia eƒe ŋusẽ ɖe edzi. 
\q1  
\v 6 Èhiã nufiame hafi adze aʋa eye hafi dziɖuɖu nava la, 
\q2 èhiã aɖaŋuɖola geɖewo. 
\s2 Nya blaeve-vɔ-etɔ̃lia 
\q1  
\v 7 Nunya kɔ boo na bometsila akpa; 
\q2 le amehawo dome, le agbo nu la, nya aɖeke mele esi wòagblɔ o. 
\s2 Nya blaeve-vɔ-enelia 
\q1  
\v 8 Ame si ɖo vɔ̃ be yeawɔ 
\q2 lae woyɔna be ame vɔ̃ɖi. 
\q1  
\v 9 Bometsinuwo ɖoɖo nye nu vɔ̃ eye amewo tsria fewuɖula. 
\s2 Nya blaeve-vɔ-atɔ̃lia 
\q1  
\v 10 Ne èʋuʋu le xaxaɣi la, 
\q2 aleke wò ŋusẽ mehele sue o? 
\q1  
\v 11 Ɖe ame siwo wokplɔ yina wuwu ge 
\q2 eye xɔ na ame siwo le yiyim sɔgɔsɔgɔ yina ɖe ku me. 
\q1  
\v 12 Ne ègblɔ be, 
\q2 “Míenya naneke tso nu sia ŋuti o” la, 
\q2 ɖe ame si daa dziwo kpɔ la menyae oa? 
\q1 Ɖe wòle nyanya na ame si kpɔa wò agbe ta? 
\q2 Ɖe maɖo eteƒe na ame sia ame ɖe nu si wòwɔ la nu oa? 
\s2 Nya blaeve-vɔ-adelia 
\q1  
\v 13 Vinye, no anyitsi elabena enyo; 
\q2 anyitsi tso anyito me avivi le wò nu me. 
\q1  
\v 14 Nyae hã be, nunya avivi wò luʋɔ nu; 
\q2 ne èke ɖe eŋu la, 
\q1 mɔkpɔkpɔ li na wò hena etsɔ si gbɔna 
\q2 eye wò mɔkpɔkpɔ mazu dzodzro o. 
\s2 Nya blaeve-vɔ-adrelia 
\q1  
\v 15 Mègade xa ɖe ame dzɔdzɔe ƒe aƒe ŋu o, 
\q2 mègava ha enɔƒe o 
\q1  
\v 16 elabena togbɔ be ame dzɔdzɔe adze anyi zi adre hã la, 
\q2 agafɔ gake ame vɔ̃ɖiwo ya la, 
\q2 dzɔgbevɔ̃e ahe wo aƒu anyi. 
\s2 Nya blaeve-vɔ-enyilia 
\q1  
\v 17 Mègakpɔ dziɖuɖu ƒe dzidzɔ ne wò futɔ dze anyi o, 
\q2 eye ne ekli nu la, 
\q2 dzi megadzɔ wò o, 
\q1  
\v 18 elabena Yehowa akpɔe, eye madze eŋu o, 
\q2 eye wòaɖe eƒe dziku ɖa le edzi. 
\s2 Nya blaeve-vɔ-asiekelia 
\q1  
\v 19 Mègadzo nyanyanya le ame vɔ̃ɖiwo ta 
\q2 alo aʋã ŋu ŋutasẽla o, 
\q1  
\v 20 elabena mɔkpɔkpɔ aɖeke meli na ame vɔ̃ɖi ɖe etsɔ si gbɔna ŋuti o 
\q2 eye woatsi ŋutasẽlawo ƒe akaɖi. 
\s2 Nya blaetɔ̃lia 
\q1  
\v 21 Vinye, vɔ̃ Yehowa kple fia la 
\q2 eye mègade aglãdzelawo dzi o 
\q1  
\v 22 elabena ame eve mawo ana gbegblẽ naƒo ɖe wo dzi kpoyi 
\q2 eye ame kae nya dzɔgbevɔ̃e si woate ŋu ahe vɛ? 
\ms1 Nunyalawo ƒe nyagbɔgblɔ bubuwo 
\p  
\v 23 Esiawo hã nye nunyalawo ƒe nyagbɔgblɔwo: 
\q1 Akpa ɖeka dzi dede le ʋɔnudɔdrɔ̃ me menyo o. 
\q1  
\v 24 Ame si agblɔ na fɔɖila be, 
\q2 “Mèdze agɔ o” la, amewo ado ɖiŋu nɛ 
\q2 eye dukɔwo anyɔ ŋui. 
\q1  
\v 25 Ke eme anyo na ame siwo abu fɔ agɔdzela 
\q2 eye yayra gãwo ava wo ameawo dzi. 
\b  
\q1  
\v 26 Nyaŋuɖoɖo ɖe ɖoɖo nu le 
\q2 abe nugbugbɔ ene. 
\b  
\q1  
\v 27 Wu wò gotadɔwo nu 
\q2 eye nàdzra wò agble me ɖo, 
\q2 ema megbe la, tu wò xɔ. 
\b  
\q1  
\v 28 Mègaɖu ɖasefo ɖe hawòvi ŋu dzodzro 
\q2 alo atsɔ wò nuyiwo aka aʋatsoe o. 
\q1  
\v 29 Mègagblɔ be, 
\q2 “Mele ewɔ ge nɛ abe ale si wòwɔe ɖe ŋutinye ene, 
\q2 mele eteƒe ɖo ge na ŋutsu sia ɖe nu si wòwɔ la ta” o. 
\b  
\q1  
\v 30 Meto kuviatɔ kple ame manyanu 
\q2 ƒe waingble ŋu yi; 
\q1  
\v 31 ŋu vu tsyɔ afi sia afi, 
\q2 gbe to ɖe eme katã eye kpekpɔ la kaka le eŋu. 
\q1  
\v 32 Metsɔ nye dzi ɖo nu si mekpɔ la ŋu 
\q2 eye mesrɔ̃ nu tso nu si mekpɔ la me. 
\q1  
\v 33 Dɔ alɔ̃ vie, dɔ akɔlɔ̃e sẽe, 
\q2 ŋlɔ wò abɔwo nàdzudzɔ vie, 
\q1  
\v 34 tete ahedada aƒo ɖe dziwò abe adzodala ene, 
\q2 eye hiã abe aʋakalẽtɔ si bla akpa ene. 
\c 25  
\ms1 Salomo ƒe lododo bubuwo 
\p  
\v 1 Esiawoe nye Solomo ƒe lododo bubu siwo Yuda fia Hezekia ƒe dɔdzikpɔlawo ŋlɔ da ɖi. 
\q1  
\v 2 Enye Mawu ƒe ŋutikɔkɔe be wòaɣla nya; 
\q2 eye fiawo ƒe bubue nye be woaku nya me. 
\q1  
\v 3 Abe ale si dziƒo kɔe eye anyigba gogloe ene la, 
\q2 nenemae womate ŋu adzro fiawo ƒe dzi me o. 
\b  
\q1  
\v 4 Ɖe ɖi ɖa le klosalo ŋu, 
\q2 ekema klosalonutula kpɔ dɔwɔnu. 
\q1  
\v 5 Ɖe ame vɔ̃ɖi ɖa le fia la ŋkume 
\q2 ekema eƒe fiazikpui ali ke to dzɔdzɔenyenye me. 
\b  
\q1  
\v 6 Mègado ɖokuiwò ɖe dzi le fia la ŋkume o 
\q2 eye mègaʋli nɔƒe le amegãwo dome o. 
\q1  
\v 7 Enyo be wòagblɔ na wò be, 
\q2 “Va dzime le afii” wu be wòaɖiɖi wò le bubumewo ŋkume. 
\b  
\q1 Nu si nèkpɔ kple wò ŋkuwo la, 
\q2  
\v 8 mègatsɔ dzitsitsi ahee va ʋɔnui o 
\q1 elabena nu ka nàwɔ le nuwuwua 
\q2 ne hawòvi la do ŋukpe wò? 
\b  
\q1  
\v 9 Ne èle nya hem kple hawòvi la, 
\q2 mègaʋu go ame bubu ƒe nya ɣaɣla o, 
\q1  
\v 10 ne menye nenema o la, 
\q2 ame si see la ado ŋukpe wò 
\q2 eye ŋkɔ baɖa si le ŋuwò la maɖe ɖa akpɔ gbeɖe o. 
\b  
\q1  
\v 11 Nya si wogblɔ dedie la, 
\q2 le abe “sikaplu” le klosalogba me ene. 
\q1  
\v 12 Ŋutsu nunyala ƒe mokaname le na to si le esem la 
\q2 abe sikatogɛ alo sikatsyɔ̃ɖonu aɖe ene. 
\b  
\q1  
\v 13 Dɔla nuteƒewɔla le na ame siwo dɔe la 
\q2 abe ale si sno fanae le nuŋeɣi ene; 
\q2 enana eƒe aƒetɔwo ƒe gbɔgbɔ gbɔna ɖe eme. 
\q1  
\v 14 Ŋutsu si ƒoa adegbe le nunana siwo mena o ŋu la 
\q2 le abe lilikpododo kple ya si medzaa tsi o la ene. 
\b  
\q1  
\v 15 Dzigbɔɖie wotsɔna blea fia nue 
\q2 eye aɖe bɔbɔe ate ŋu agbã ƒu. 
\b  
\q1  
\v 16 Ne èke ɖe anyitsi ŋu la, no esi sinu nàte ŋui ko, 
\q2 ne ènoe fũu akpa la, àdzɔe. 
\q1  
\v 17 Mègaƒo afɔɖi hawòvi ƒe aƒe me o, 
\q2 ne èle egbɔ dem kabakaba la, ava tsri wò. 
\b  
\q1  
\v 18 Ŋutsu si ɖi aʋatsoɖase ɖe ehavi ŋu la le abe kpo, 
\q2 yi alo aŋutrɔ ɖaɖɛ ene. 
\q1  
\v 19 Dziɖoɖo ɖe nuteƒemawɔla ŋu le xaxaɣiwo le abe aɖu vovo 
\q2 alo afɔ tutu ene. 
\q1  
\v 20 Ame si dzi ha na dzi kpekpe tɔ la le 
\q2 abe ame si ɖe awu kpekpe ɖi le vuvɔwɔgbe 
\q2 alo “vinigae” wokɔ ɖe “soɖa” dzi ene. 
\b  
\q1  
\v 21 Ne dɔ le wò ketɔ wum la, na nui wòaɖu, 
\q2 ne tsikɔ le ewum la, na tsii wòano. 
\q1  
\v 22 Ne èwɔ esia la, 
\q2 àƒo dzoka xɔxɔwo nu ƒu ɖe eƒe ta dzi, 
\q2 eye Yehowa ŋutɔ aɖo eteƒe na wò. 
\b  
\q1  
\v 23 Abe ale si anyieheya hea tsidzadza vɛ ene la, 
\q2 nenema amenyagblɔɖe dea adã mo na amee. 
\b  
\q1  
\v 24 Enyo be woanɔ dzogoe dzi le xɔta wu be 
\q2 woanɔ aƒe ɖeka me kple srɔ̃nyɔnu dzrewɔla. 
\b  
\q1  
\v 25 Abe ale si tsi fafɛ faa akɔ na luʋɔ gbɔdzɔe ene la, 
\q2 nenema kee nya nyui tso duta hã nɔna. 
\q1  
\v 26 Ame dzɔdzɔe si na mɔ ame vɔ̃ɖi la 
\q2 le abe tsitsetse si me blu 
\q2 alo vudo si me wolɔ gbe kɔ ɖo la ene. 
\b  
\q1  
\v 27 Menyo be woano anyitsi fũu 
\q2 alo wònye nu dzeame be ame nadi eya ŋutɔ ƒe bubu o. 
\b  
\q1  
\v 28 Ame si meɖua eɖokui dzi o la 
\q2 le abe du si ŋu wogbã gli le la ene. 
\c 26  
\q1  
\v 1 Abe ale si sno dzanae le dzomeŋɔli 
\q2 alo tsi dzanae le nuŋeɣi ene la, 
\q2 nenemae bubu medze bometsila o. 
\q1  
\v 2 Abe ale si atsutsrɔe dzonae 
\q2 alo sagbadrɛ saa agbae ene la, 
\q1 nenemae ɖiŋu si wodo na 
\q2 ame ɖe madzɔmadzɔ dzi la tsia yamee. 
\q1  
\v 3 Sɔƒoka li na sɔ, numega li na tedzi 
\q2 nenemae ameƒoti li na bometsila ƒe dzimegbe! 
\q1  
\v 4 Mègaɖo nya ŋu na bometsila le eƒe bometsitsi nu o, 
\q2 ne menye nenema o la, wò ŋutɔ hã ànɔ abe eya amea ene. 
\q1  
\v 5 Ɖo nya ŋu na bometsila le eƒe bometsitsi nu, 
\q2 ne menye nenema o la ava bu eɖokui nunyalae le eɖokui gbɔ. 
\q1  
\v 6 Dudede asi na bometsila le 
\q2 abe ame ŋutɔ ƒe afɔ lalã alo dzɔgbevɔ̃e nono ene. 
\q1  
\v 7 Abe ale si atatututɔ ƒe afɔ nɔa yamee ene la, 
\q2 nenemae lododo le le bometsila ƒe nu mee. 
\q1  
\v 8 Abe ale si wotsɔa kpe dea akafomee ene la, 
\q2 nenemae bubudede bometsila ŋu le. 
\q1  
\v 9 Abe ale si ŋuti nɔna le ahamula ƒe asimee ene la, 
\q2 nenemae lododo nɔna le bometsila ƒe nu mee. 
\q1  
\v 10 Ame si daa aŋutrɔ bometsila dzodzro la le 
\q2 abe ame si dɔa dɔ ame si le eme tsom la ene. 
\q1  
\v 11 Abe ale si avu trɔna gayia nu si wòdzɔ gbɔe ene la, 
\q2 nenemae bometsila gawɔa bometsinu si wòwɔ va yi. 
\q1  
\v 12 Èkpɔ ame aɖe si nye nunyala le eya ŋutɔ ŋkume kpɔa? 
\q2 Mɔkpɔkpɔ geɖe li na bometsila wu eya amea. 
\b  
\q1  
\v 13 Kuviatɔ gblɔna be, 
\q2 “Dzata le mɔa dzi, dzata si le gbe tem ŋɔdzitɔe la 
\q2 le tsatsam le ablɔwo me!” 
\q1  
\v 14 Abe ale si ʋɔtru trona le eƒe megbega mee ene la, 
\q2 nenemae kuviatɔ nɔa tɔtrɔm le eƒe aba dzii. 
\q1  
\v 15 Kuviatɔ tsɔ eƒe asi de nuɖugba me 
\q2 gake kuvia ɖoe ale gbegbe be, 
\q2 edede nu me zu dɔ nɛ. 
\q1  
\v 16 Kuviatɔ nye nunyala le eya ŋutɔ ƒe ŋkume, 
\q2 wu ame adre siwo ɖoa nya ŋu nunyatɔe. 
\b  
\q1  
\v 17 Ame si le eme tsom gake de nu dzrenya si metsɔ egbɔ o 
\q2 me la le abe ame si lé towo kple eve na avu ene. 
\b  
\q1  
\v 18 Abe ale si aɖaʋatɔ daa akakati bibi 
\q2 alo aŋutrɔ si ŋu aɖi le la ene la, 
\q1  
\v 19 nenemae nye ame si ble ehavi 
\q2 eye emegbe wògblɔ nɛ be, 
\q2 “Fefem ko mele!” 
\b  
\q1  
\v 20 Ne nake meli o la, 
\q2 dzo tsina; ne sakplitɔ meli o la, dzre kena. 
\q1  
\v 21 Abe ale si aka léa dzo eye nake doa dzo ene la, 
\q2 nenema ŋutsu dzretɔ ƒlɔa dzre ɖoe. 
\q1  
\v 22 Amenyagblɔla ƒe nyawo vivina 
\q2 abe nuɖuɖu vivi si woka de nu me la ene; 
\q2 eyina ɖe ame ƒe dɔgbowo me ke. 
\b  
\q1  
\v 23 Abe ale si wofaa sikatsi ɖe anyikplu ŋu ene la, 
\q2 nenema nuyi xɔdzo si ŋu dzi vɔ̃ɖi kpe ɖo la le. 
\q1  
\v 24 Ame baɖa tsɔa eƒe nuyi trɔa eɖokui bubue, 
\q2 gake eɣlaa beble ɖe eƒe dzi me. 
\q1  
\v 25 Togbɔ be eƒe nyawo nya le sesem hã la, mègaxɔ edzi se o 
\q2 elabena ŋunyɔnu adre le eƒe dzi me. 
\q1  
\v 26 Eƒe susu baɖa aɣla ɖe beble megbe, 
\q2 gake woaʋu go eƒe vɔ̃ɖivɔ̃ɖi le amehawo dome. 
\q1  
\v 27 Ne ame aɖe ɖe ʋe la, eya ŋutɔ age adze eme 
\q2 eye ame si amli kpe la, 
\q2 kpe si wòmli la age adze eya ŋutɔ dzi. 
\q1  
\v 28 Alakpaɖe léa fu ame siwo ŋuti wòle abi demii, 
\q2 eye nu si blea ame la hea gbegblẽ vɛ. 
\b  
\c 27  
\q1  
\v 1 Mègaƒo adegbe le etsɔ si gbɔna ŋu o 
\q2 elabena mènya nu si ŋkeke la ahe vɛ o. 
\b  
\q1  
\v 2 Na ame bubu nakafu wò, 
\q2 ke menye wò ŋutɔ wò nu o, 
\q2 ame bubu newɔe, menye wò ŋutɔ wò nuyiwo o. 
\b  
\q1  
\v 3 Kpe nye nu kpekpe eye ke nye agba kpekpe 
\q2 gake bometsila ƒe dzikudoname kpena wu wo ame evea. 
\b  
\q1  
\v 4 Dziku la ŋutasẽlae eye dɔmedzoe la agbodzelae, 
\q2 ke ame ka ate ŋu anɔ te ɖe ŋuʋaʋã nu? 
\b  
\q1  
\v 5 Mokaname le ame dome nyo 
\q2 wu lɔlɔ̃ si woɣla. 
\b  
\q1  
\v 6 Àte ŋu aka ɖe xɔlɔ̃ ƒe abideameŋu dzi 
\q2 gake ketɔ ƒe nugbugbɔ dzina ɖe edzi. 
\b  
\q1  
\v 7 Ƒoɖila doa vlo anyitsi, 
\q2 ke hena dɔwuitɔ la, nu veve gɔ̃ hã vivina nɛ. 
\b  
\q1  
\v 8 Ame si tra tso eƒe aƒe me la 
\q2 le abe xevi si bu eƒe atɔmemɔ ene. 
\b  
\q1  
\v 9 Ami ʋeʋĩ kple dzudzɔdonu ʋeʋĩ doa dzidzɔ na dzi, 
\q2 xɔlɔ̃ ƒe nunyoamenu tsoa eƒe aɖaŋuɖoɖo vavãwo me. 
\b  
\q1  
\v 10 Mègagblẽ xɔ̃wò alo fofowò xɔlɔ̃ ɖi o, 
\q2 eye mègayi nɔviwò ƒe aƒe me ne dzɔgbevɔ̃e ƒo go wò o, 
\q1 anyo na wò be nàyi hawòvi si tsɔ ɖe gbɔwò la gbɔ wu 
\q2 nɔviwò si le adzɔge. 
\b  
\q1  
\v 11 Vinye, dze nunya eye nàhe dzidzɔ vɛ na nye dzi; 
\q2 ekema mate ŋu aɖo nya ŋu na ame si ado vlom. 
\b  
\q1  
\v 12 Nunyala kpɔ dzɔgbevɔ̃e gbɔna eye wòɣla eɖokui 
\q2 gake bometsila le yiyim eye wòkpe fu ɖe eta. 
\b  
\q1  
\v 13 Xɔ avɔ le ame si da megbe na amedzro la si, 
\q2 tsɔe de awɔba me, ne eda megbe na nyɔnu ahasitɔ. 
\b  
\q1  
\v 14 Ne ŋutsu aɖe le eƒe aƒelika yram kple ɣli le ŋdi kanya la, 
\q2 woatsɔe abe ɖiŋudodo ene. 
\b  
\q1  
\v 15 Srɔ̃nyɔnu dzrewɔla le abe tsitrɔnu si 
\q2 le ɖuɖum madzudzɔmadzudzɔe le tsidzagbe ene. 
\q1  
\v 16 Asiɖoɖo edzi le abe asiɖoɖo ya dzi ene 
\q2 alo asitsɔtsɔ ku ami ene. 
\b  
\q1  
\v 17 Abe ale si ga nyrea ga ene la, 
\q2 nenema kee ame nyrea amee. 
\b  
\q1  
\v 18 Ame si lé be na eƒe gboti nyuie la aɖu eƒe tsetsea 
\q2 eye woade bubu ame si kpɔ eƒe aƒetɔ dzi la ŋu. 
\b  
\q1  
\v 19 Abe ale si ame ƒe mo dzena le tsi dzii ene la, 
\q2 nenema ame ƒe dzi ɖea eƒe nɔnɔme fianae. 
\b  
\q1  
\v 20 Ku kple tsiẽƒe meɖia ƒo gbeɖe o 
\q2 nenema kee nye ame ƒe ŋku. 
\b  
\q1  
\v 21 Sonu li na klosalo, eye dzokpo li na sika, 
\q2 gake wodoa ame kpɔ to kafukafu si wotsɔ nɛ la dzi. 
\b  
\q1  
\v 22 Togbɔ be èto bometsila le to me, 
\q2 ètoe kple tati abe bli ene hã la, 
\q2 màte ŋu aɖe eƒe bometsitsi ɖa le eŋu o. 
\b  
\q1  
\v 23 Ka ɖe edzi be wò alẽhawo ƒe nɔnɔme le nyanya na wò 
\q2 eye wò ŋku le wò lãhawo ŋu ɖaa; 
\q1  
\v 24 elabena kesinɔnuwo menɔa anyi ɖikaa o 
\q2 eye fiakuku hã menɔa anyi hena dzidzimewo katã o. 
\q1  
\v 25 Ne woƒo gbe eye gbe mumu mie ɖe eteƒe, 
\q2 ne wolã gbe siwo le togbɛwo dzi ƒo ƒui la, 
\q1  
\v 26 ekema alẽviawo ana avɔ wò 
\q2 eye gbɔ̃wo anye ga si nàtsɔ aƒle agblee. 
\q1  
\v 27 Gbɔ̃notsi anɔ asiwò fũu 
\q2 be wò kple wò aƒemetɔwo miano 
\q2 eye wòanye nunyiame na wò dɔlanyɔnuwo. 
\b  
\c 28  
\q1  
\v 1 Ame vɔ̃ɖi la léa du tsɔna, 
\q2 evɔ ame aɖeke menyae ɖe du nu o, 
\q2 ke dzi le ame dzɔdzɔe ƒo abe dzata ene. 
\b  
\q1  
\v 2 Dziɖulawo sɔ gbɔ ɖe dukɔ si me aglãdzedze le, 
\q2 ke ŋutsu si si gɔmesese kple sidzedze le la hea ɖoɖodziwɔwɔ vɛ. 
\b  
\q1  
\v 3 Dziɖula si tea hiãtɔwo ɖe anyi la le abe tsidzadza si ɖe anyigba 
\q2 eye megblẽ nuɖuɖu aɖeke ɖi o la ene. 
\b  
\q1  
\v 4 Ame siwo gbe nu le sea gbɔ la kafua ame vɔ̃ɖiwo 
\q2 ke sedziwɔlawo tsia tsitre ɖe wo ŋu. 
\b  
\q1  
\v 5 Ame vɔ̃ɖiwo mesea afiatsotso nyui gɔme o 
\q2 gake ame siwo dia Yehowa ya sea egɔme nyuie. 
\b  
\q1  
\v 6 Enyo be nànye hiãtɔ si ƒe zɔzɔme ŋu fɔɖiɖi mele o, 
\q2 wu nànye kesinɔtɔ si ƒe mɔwo to vo. 
\b  
\q1  
\v 7 Ame si léa sea me ɖe asi la nye vi nyanu 
\q2 gake ame si dea ha kple nutsuɖulawo la doa ŋukpe fofoa. 
\b  
\q1  
\v 8 Ame si dzi eƒe kesinɔnuwo ɖe edzi to demegaxɔxɔ me la, 
\q2 le kɔ lim nuwo na ame bubu si anyo dɔ me na ame dahewo. 
\b  
\q1  
\v 9 Ne ame aɖe doa toku sea la, 
\q2 eƒe gbedodoɖawo gɔ̃ hã zua ŋunyɔnu. 
\b  
\q1  
\v 10 Ame si kplɔ nu dzɔdzɔe wɔla to mɔ vɔ̃ dzi la, 
\q2 age ɖe eya ŋutɔ ƒe mɔ me. 
\q1 Ke ame siwo ŋu fɔɖiɖi mele o la, 
\q2 axɔ domenyinu nyui. 
\b  
\q1  
\v 11 Kesinɔtɔ nye nunyala le eya ŋutɔ gbɔ 
\q2 gake hiãtɔ si si sidzedze le la kpɔa egɔme. 
\b  
\q1  
\v 12 Ne ame dzɔdzɔe ɖu dzi la, 
\q2 dzidzɔkpɔkpɔ teƒe mekɔna o, 
\q1 ke ne ame vɔ̃ɖi zu fia la, 
\q2 amewo sina bena. 
\b  
\q1  
\v 13 Nu medzea edzi na ame si ɣla eƒe nu vɔ̃ o, 
\q2 ke wokpɔa nublanui na ame si ʋu eƒe nu vɔ̃wo me 
\q2 eye wògbe nu le wo gbɔ. 
\b  
\q1  
\v 14 Woayra ŋutsu si vɔ̃a Yehowa ɣe sia ɣi, 
\q2 ke ame si sẽa eƒe dzi me la gena ɖe xaxa me. 
\b  
\q1  
\v 15 Ŋutasẽla si le ame dahewo dzi ɖum la 
\q2 le abe dzata si le gbe tem alo sisiblisi si le ade tam ene. 
\b  
\q1  
\v 16 Dziɖula tamesesẽtɔ menyaa nu o, 
\q2 ke ame si lé fu kesinɔnu ƒoɖi la anɔ agbe didi, ase vivi. 
\b  
\q1  
\v 17 Hlɔ̃dola si hlɔ̃dodo la zu agba na la anye tsatsala va se ɖe eƒe kugbe; 
\q2 ame aɖeke megakpe ɖe eŋu o. 
\b  
\q1  
\v 18 Ame si fɔɖiɖi mele eƒe zɔzɔme ŋu o la anɔ dedie, 
\q2 ke ame si ƒe mɔwo to vo la adze anyi kpata. 
\b  
\q1  
\v 19 Ame si ŋlɔ eƒe agble la akpɔ nuɖuɖu geɖe, 
\q2 ke ame si ƒe susu le nu manyatalenuwo 
\q2 yome la, ahedada axɔ aƒe nɛ. 
\b  
\q1  
\v 20 Woayra ŋutsu nuteƒewɔla fũu, 
\q2 ke womagbe tohehe na ame si tsi dzi ɖe 
\q2 kesinɔnuwo kpɔkpɔ ŋuti o. 
\b  
\q1  
\v 21 Amedzidede menyo o 
\q2 gake ame ayi aɖawɔ vɔ̃ ɖe abolo kakɛ ta. 
\b  
\q1  
\v 22 Ŋutsu nuvela tsi dzi ɖe hotsuikpɔkpɔ ŋu, 
\q2 evɔ mehenya be ahedada le ye lalam o. 
\b  
\q1  
\v 23 Ame si ka mo na ŋutsu la, 
\q2 axɔ amenuveve ɖe amenuveve dzi wu 
\q2 ame si alakpaɖe le nume na. 
\b  
\q1  
\v 24 Ame si da adzo fofoa alo dadaa hegblɔ be, 
\q2 “Medze vɔ̃ o” la, nye kpeɖeŋutɔ na nugblẽla. 
\b  
\q1  
\v 25 Ŋutsu ŋubiala hea mama vɛ 
\q2 ke ame si ɖoa dzi ɖe Yehowa ŋu la, nu adze edzi nɛ. 
\b  
\q1  
\v 26 Ame si ɖoa dzi ɖe eɖokui ŋu la, bometsilae, 
\q2 ke ame si zɔna le nunya me la anɔ dedie. 
\b  
\q1  
\v 27 Ame si naa nu hiãtɔ la, 
\q2 naneke mahiãe o, 
\q1 ke ame si miaa ŋku ɖe woƒe hiahiãwo dzi la, 
\q2 axɔ fiƒode geɖe. 
\b  
\q1  
\v 28 Ne tamesesẽtɔ zu dziɖula la, 
\q2 amewo sina bena, ke ne ame vɔ̃ɖiwo tsrɔ̃ la, 
\q2 ame dzɔdzɔewo tsina. 
\b  
\c 29  
\q1  
\v 1 Ame si woka mo na zi gede gake wògbe lia kɔ la, 
\q2 atsrɔ̃ zi ɖeka kpata xɔnamemanɔŋutɔe. 
\b  
\q1  
\v 2 Ne ame dzɔdzɔewo le dzi ɖum la, amewo dzɔa dzi; 
\q2 ke ne dziɖuɖu ge ɖe ame vɔ̃ɖiwo ƒe asi me la, amewo ŋena. 
\b  
\q1  
\v 3 Ame si lɔ̃a nunya la hea dzidzɔ vɛ na fofoa, 
\q2 ke ame si dze xɔ̃ gbolowo la gblẽa eƒe ga dome. 
\b  
\q1  
\v 4 To afia nyui tsotso me fia hea dedinɔnɔ vɛ na dukɔ, 
\q2 ke fia si klẽa ŋu ɖe zãnuxɔxɔ ŋu la gbãa du. 
\b  
\q1  
\v 5 Ame si do fuflugba na ehavi la le ɖɔ ɖom na eya ŋutɔ ƒe afɔ. 
\b  
\q1  
\v 6 Ame vɔ̃ɖi ƒe nu vɔ̃ denɛ mɔ me, 
\q2 ke ame dzɔdzɔe adzi ha atso aseye. 
\b  
\q1  
\v 7 Ame dzɔdzɔewo tsɔa ɖe le afiatsotso na hiãtɔwo me 
\q2 gake ame vɔ̃ɖiwo ya metsɔa ɖeke le eme o. 
\b  
\q1  
\v 8 Fewuɖulawo dea ʋunyaʋunya du me, 
\q2 ke nunyalawo tsia dziku nu. 
\b  
\q1  
\v 9 Nunyala yi ʋɔnudrɔ̃ƒe kple bometsila, 
\q2 bometsila le adã fiam, le fewu ɖum eye ŋutifafa meli o. 
\b  
\q1  
\v 10 Hlɔ̃dolawo lé fu ŋutsu nuteƒewɔla 
\q2 eye wodina be yewoawu dzi dzadzɛ tɔ. 
\b  
\q1  
\v 11 Bometsila ɖea eƒe dziku katã fiana, 
\q2 ke nunyala ɖua eɖokui dzi. 
\b  
\q1  
\v 12 Ne dziɖula ɖo to beblenyawo la, 
\q2 eƒe dɔnunɔlawo katã zua ŋutasẽlawo. 
\b  
\q1  
\v 13 Nu ɖeka sia le hiãtɔ kple ameteɖetola siaa si, 
\q2 Yehowae wɔ ŋku na wo ame evea. 
\b  
\q1  
\v 14 Ne fia drɔ̃ ʋɔnu na hiãtɔ ɖe dzɔdzɔenyenye dzi la, 
\q2 eƒe fiazikpui anɔ dedie ɣe sia ɣi. 
\b  
\q1  
\v 15 Ameƒoti si wotsɔna ɖɔa ame ɖoe la fiaa nunya ame, 
\q2 gake ɖevi si womehe o la dea ŋukpe mo na dadaa. 
\b  
\q1  
\v 16 Ne ame vɔ̃ɖiwo le dzi ɖum la, 
\q2 nu vɔ̃ hã dea dzi, ke ame dzɔdzɔewo akpɔ woƒe anyidzedze. 
\b  
\q1  
\v 17 Ne èhe viwò ŋutsuvi la, ekema àkpɔ ŋutifafa 
\q2 eye wòahe dzidzɔ vɛ na wò luʋɔ. 
\b  
\q1  
\v 18 Afi si ɖeɖefia mele o la, 
\q2 amewo wɔa woƒe lɔlɔ̃nu; 
\q2 ke woayra ame si léa sea me ɖe asi. 
\b  
\q1  
\v 19 Numenya ɖeɖe mate ŋu aɖɔ dɔla ɖo o, 
\q2 togbɔ be ese egɔme hã la, mawɔ ɖe edzi o. 
\b  
\q1  
\v 20 Èkpɔ ame si ƒoa nu blablablaa? 
\q2 Mɔkpɔkpɔ geɖe li na bometsila wu eya amea gɔ̃ hã. 
\b  
\q1  
\v 21 Ne ŋutsu aɖe wɔ vi na eƒe subɔviŋutsu tso eƒe ɖevime la, 
\q2 ahe nuxaxa vɛ le nuwuwua. 
\b  
\q1  
\v 22 Ŋutsu dɔmedzoetɔ dea dzre amewo dome 
\q2 eye ame si doa dziku kabakaba la wɔa nu vɔ̃ geɖe. 
\b  
\q1  
\v 23 Ŋutsu si dana la ɖua ŋukpe, 
\q2 ke wobua ŋutsu si bɔbɔa eɖokui ɖe anyi le gbɔgbɔ me. 
\b  
\q1  
\v 24 Ame si wɔ ɖeka kple fiafitɔ la nye eya ŋutɔ ƒe futɔ; 
\q2 wonana wòkaa atam 
\q2 eye mekpɔ mɔ akɔ nu le edzi o. 
\b  
\q1  
\v 25 Vɔvɔ̃ si le ame aɖe me lae nyea mɔ nɛ, 
\q2 ke ame si ka ɖe Yehowa dzi la nɔa dedie. 
\b  
\q1  
\v 26 Ame geɖewo dina be yewoado ɖe dziɖula ŋkume, 
\q2 aƒo nu kplii gake Yehowa gbɔ ame ƒe afiatsotso tsona. 
\b  
\q1  
\v 27 Nu gbegblẽ wɔla nye ŋunyɔ na ame dzɔdzɔe 
\q2 eye nu dzɔdzɔe wɔla nye ŋunyɔ na ame vɔ̃ɖi. 
\c 30  
\ms1 Agur ƒe nyawo 
\p  
\v 1 Yake vi Agur ƒe nyagblɔɖi. 
\q1 Ŋutsu sia gblɔ na Itiel, kple Ukal be: 
\b  
\q1  
\v 2 “Nyee tsi bome wu le amewo dome; 
\q2 ame ƒe nugɔmesese mele asinye o. 
\q1  
\v 3 Nyemesrɔ̃ nunya 
\q2 alo nya naneke le Kɔkɔetɔ la ŋu o. 
\q1  
\v 4 Ame kae lia yi dziƒo gagbɔ kpɔ? 
\q2 Ame kae lɔ ya ɖe eƒe asiƒome? 
\q1 Ame kae bla tsiwo katã ɖe eƒe awu ʋlaya me? 
\q2 Ame kae ɖo anyigba ƒe mlɔenu ke anyi? 
\q1 Eŋkɔ ɖe, via ŋkɔ ɖe? 
\q2 Gblɔe nam, ne ènyae! 
\b  
\b  
\q1  
\v 5 “Kpɔtsɔtsɔ mele Mawu ƒe nya aɖeke ŋu o; 
\q2 enye akpoxɔnu na ame siwo sii tso. 
\q1  
\v 6 Mègatsɔ nya kpe eƒe nyawo o, 
\q2 ne menye nenema o la, aka mo na wò 
\q2 eye woakpɔe be ènye alakpatɔ. 
\b  
\q1  
\v 7 “O Yehowa, nu evee mebia wò; 
\q2 mègatem hafi maku o. 
\q1  
\v 8 Te aʋatsokaka kple alakpa ɖa xaa tso gbɔnye, 
\q2 mègatsɔ ahedada alo hotsuikpɔkpɔ nam o, 
\q2 ke boŋ na nye gbe sia gbe ƒe abolo kom. 
\q1  
\v 9 Ne menye nenema o la, mava ɖi ƒo akpa, 
\q2 agbe nu le gbɔwò ahabia be, 
\q1 ‘Ame kae nye Yehowa?’ 
\q2 Alo mada ahe akpa, afi fi. 
\b  
\q1  
\v 10 “Mègagblẽ dɔla ŋu na eƒe aƒetɔ o, 
\q2 ne menye nenema o la, ado ɖiŋu na wò 
\q2 eye nàkpe fu ɖe eta. 
\b  
\q1  
\v 11 “Ame aɖewo li, 
\q2 siwo doa ɖiŋu na wo fofowo 
\q2 eye womeyraa wo dadawo hã o; 
\q1  
\v 12 ame siwo dza le woawo ŋutɔ ƒe ŋkume, evɔ womeklɔ ɖi si 
\q2 woƒo la ɖa le wo ŋuti o; 
\q1  
\v 13 ame siwo si ŋku gã le ɣe sia ɣi, 
\q2 eye wokpɔa ame ɖeƒomevie; 
\q1  
\v 14 ame siwo ƒe aɖu le abe yi ene 
\q2 eye woƒe glãwo le abe hɛ ɖaɖɛwo ene, 
\q1 ne woavuvu ame dahewo le anyigba dzi 
\q2 eye woaɖe hiãtɔwo ɖa le amegbetɔwo dome. 
\b  
\q1  
\v 15 “Vinyɔnu eve le axɔ̃ si, 
\q2 wole avi fam be, ‘Nam! Nam!’ 
\b  
\li1 “Nu etɔ̃ li siwo nu meɖia ƒo na gbeɖe o, 
\li2 eye enelia megblɔna be, ‘Enyo gbɔ!’ o: 
\li3  
\v 16 woawoe nye, yɔdo, 
\li3 vidzidɔ si tsi ko, 
\li3 anyigba si tsi meɖia kɔ na o, 
\li3 kple dzo si megblɔna gbeɖe be, ‘Enyo gbɔ!’ o. 
\b  
\q1  
\v 17 “Ŋku si ɖua fewu le fofoa ŋu, 
\q2 eye wòdoa vlo bubudede dadaa ŋu la, 
\q1 balime ƒe akpaviãwo ahoe le etome, 
\q2 eye akagawo aɖui. 
\b  
\li1  
\v 18 “Nu etɔ̃ li siwo wɔ nuku nam akpa, 
\li2 eye nyemese enelia gɔme o: 
\li3  
\v 19 hɔ̃ ƒe mɔ le yame, 
\li3 da ƒe mɔ le agakpe dzi, 
\li3 tɔdziʋu ƒe mɔ le atsiaƒuwo dzi 
\li3 kple ŋutsu ƒe mɔ le ɖetugbi gbɔ. 
\b  
\q1  
\v 20 “Esiae nye nyɔnu ahasitɔ ƒe mɔ. 
\q2 Eɖua nu hetutua nuto gblɔna be, 
\q2 ‘Nyemewɔ nu gbegblẽ aɖeke o.’ 
\b  
\li1  
\v 21 “Nu etɔ̃ tee anyigba ʋuʋuna le kpekpekpe, 
\li2 eye le enelia te ya la, mate ŋu atsɔe o: 
\li3  
\v 22 woawoe nye, dɔla si va zu fia, 
\li3 bometsila si si nuɖuɖu bɔ ɖo fũu, 
\li3  
\v 23 ne nyɔnu si ame aɖeke melɔ̃ eƒe nya o, 
\li3 la ɖe srɔ̃ kple ne dɔlanyɔnu xɔ ɖe eƒe aƒenɔ teƒe. 
\b  
\li1  
\v 24 “Nu ene le anyigba dzi le sue, 
\li2 gake woƒe nunya gbɔ metsɔ o: 
\li2  
\v 25 anyidiwo nye nuwɔwɔ si ŋu ŋusẽ sue aɖe ko le, 
\li3 gake woƒoa woƒe nuɖuɖu nu ƒu le dzomeŋɔli; 
\li2  
\v 26 kpetomefiwo nye lã siwo ŋu ŋusẽ sue aɖe ko le, 
\li3 gake wowɔa woƒe nɔƒe ɖe agakpewo tome; 
\li2  
\v 27 Fia mele ʋetsuviwo si o, 
\li3 gake woƒe ha blibo la yia teƒewo le ɖoɖo me; 
\li2  
\v 28 woate ŋu alé adoglo kple asi, 
\li3 gake fiawo ƒe aƒewo mee wokpɔa wo le. 
\b  
\li1  
\v 29 “Nu etɔ̃e zɔa agozɔli 
\li2 eye nu enee zɔna abe fia ene: 
\li3  
\v 30 dzata si nye gã le lã wɔadãwo dome eye medoa megbefɔ le naneke gbɔ o; 
\li3  
\v 31 koklotsu, 
\li3 gbɔ̃tsu, 
\li3 kple fia si eƒe aʋakɔwo ƒo xlãe. 
\b  
\q1  
\v 32 “Ne ètsi bome hedo ɖokuiwò ɖe dzi 
\q2 alo ɖo nu vɔ̃ɖi aɖe la, 
\q2 tsɔ wò asi tsyɔ wò nu! 
\q1  
\v 33 Elabena abe ale si ne woƒo nyinotsi wòzua bɔta 
\q2 eye ne wofia ŋɔti ʋu dona ene la, 
\q2 nenema kee ne wode dzo dziku me la, dzre dzɔna.” 
\c 31  
\ms1 Fia Lemuel ƒe nyawo 
\p  
\v 1 Fia Lemuel ƒe nyawo, nyagblɔɖi si dadaa fiae lae nye esi: 
\q1  
\v 2 “Oo vinye, 
\q2 O nye dɔmevi, O nye adzɔgbeɖevi, 
\q1  
\v 3 Mègagblẽ wò ŋusẽ ɖe nyɔnuwo ŋu 
\q2 kple wò lãmeka ɖe ame siwo gblẽa fiawo dome la ŋu o. 
\b  
\q1  
\v 4 “O Lemuel, esia menye fiawo tɔ o, 
\q2 menye fiawo tɔ be woano wain o 
\q2 eye menye dziɖulawo tɔ be woadzro aha sesẽ o. 
\q1  
\v 5 Ne menye nenema o la, 
\q2 woamu aha aŋlɔ nu si sea gblɔ la be 
\q2 eye woaxɔ ablɔɖe le ame siwo wote ɖe anyi la si. 
\q1  
\v 6 Tsɔ aha muame na ame siwo le tsɔtsrɔ̃m 
\q2 kple wain na ane siwo le nuxaxa me, 
\q1  
\v 7 na woanoe aŋlɔ woƒe ahedada be 
\q2 eye womagaɖo ŋku woƒe hiãtuame dzi akpɔ o. 
\b  
\q1  
\v 8 “Ƒo nu ɖe ame siwo mate ŋu aƒo nu ɖe 
\q2 wo ɖokui nu o la nu eye nàʋli amemanɔsitɔwo ƒe ablɔɖe ta. 
\q1  
\v 9 Ƒo nu eye nàdrɔ̃ ʋɔnu dzɔdzɔe, 
\q2 ʋli ame dahewo kple hiãtɔwo ƒe ablɔɖe ta.” 
\ms1 Nuwunyawo: Srɔ̃nyɔnu bubume ƒe nɔnɔme 
\q1  
\v 10 Ame ka akpɔ srɔ̃nyɔnu si ƒe agbe dze ame ŋu? 
\q2 Exɔ asi wu adzagba. 
\q1  
\v 11 Srɔ̃a kana ɖe edzi blibo 
\q2 eye nu sia nu si ŋu asixɔxɔ le la mevena le egbɔ o. 
\q1  
\v 12 Le nyɔnu sia ƒe agbemeŋkekewo katã me la, 
\q2 ehea nyui ko vɛ, ke menye vɔ̃ o. 
\q1  
\v 13 Edia ɖetifu kple avemeka 
\q2 eye wòwɔa dɔ kple eƒe asiwo faa. 
\q1  
\v 14 Ele abe asiʋu ene 
\q2 eye wòhea nuɖuɖu tso didiƒe vaa aƒee. 
\q1  
\v 15 Efɔna ne ŋu mekpɔ ke o, 
\q2 edia nuɖuɖu na eƒe ƒometɔwo eye wòmaa dɔ na eƒe dɔlanyɔnuwo. 
\q1  
\v 16 Ebua ta me le agble ŋu eye wòƒlenɛ, 
\q2 eɖena tso eƒe nukpɔkpɔwo me tsɔna dea waingblee. 
\q1  
\v 17 Ewɔa dɔ kple ŋkubiã 
\q2 eye eƒe alɔwo sẽna ɖe eƒe dɔwo ŋu. 
\q1  
\v 18 Ekpɔa egbɔ be yeƒe asitsatsa ɖe vi geɖe 
\q2 eye yeƒe akaɖi metsina le zã me o. 
\q1  
\v 19 Ɖetifutreti le eƒe asi me 
\q2 eye wòtsɔa eƒe asibidɛwo léa ɖetitrekekee. 
\q1  
\v 20 Eʋua asi na ame dahewo 
\q2 eye wòdoa asi ɖe hiãtɔwo gbɔ. 
\q1  
\v 21 Ne snodzaɣi ɖo la, 
\q2 mevɔ̃na ɖe eƒe aƒekɔ nu o 
\q2 elabena wo katã tsyɔ kuntru dzĩ. 
\q1  
\v 22 Elɔ̃a abadzivɔ na eƒe aba 
\q2 eye wòdoa aklala biɖibiɖi ƒe awu kple awu blɔ. 
\q1  
\v 23 Wodea bubu srɔ̃a ŋu le dua ƒe agbonu 
\q2 ne enɔ anyigba la dzi dumegãwo dome. 
\q1  
\v 24 Etɔa aklala biɖibiɖi ƒe awuwo dzrana 
\q2 eye wòdzraa alidziblanu na asitsalawo. 
\q1  
\v 25 Edo ŋusẽ kple bubu abe awu ene 
\q2 eye ate ŋu ako ŋkeke siwo gbɔna. 
\q1  
\v 26 Eƒoa nu kple nunya 
\q2 eye nufiame anukwaretɔ le eƒe aɖe dzi. 
\q1  
\v 27 Ekpɔa eƒe aƒekɔ ƒe nyawo gbɔ nyuie 
\q2 eye meɖua kuviabolo o. 
\q1  
\v 28 Viawo tsona yɔnɛ be yayratɔ, 
\q2 nenemae srɔ̃a hã yɔnɛ, hekafunɛ be, 
\q1  
\v 29 “ ‘Nyɔnu siwo wɔa nu ɖɔʋuwo la li fũu, 
\q2 gake wò la, èƒo wo katã ta.’ 
\q1  
\v 30 Nyonyo la, beblee, 
\q2 eye tugbedzedze nu hã va yina kaba; 
\q2 gake woakafu nyɔnu si vɔ̃a Yehowa. 
\q1  
\v 31 Mitsɔ fetu si wòdze na la nɛ, 
\q2 eye eƒe dɔwɔwɔwo ahe kafukafu vɛ nɛ 
\q2 le dua ƒe agbowo nu.”