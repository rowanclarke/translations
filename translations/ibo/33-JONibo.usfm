\id JON - Biblica® Open Igbo Contemporary Bible 2020
\h Jona
\toc1 Jona
\toc2 Jona
\toc3 Jon
\mt1 Jona
\c 1
\s1 Jona agbapụ ọsọ
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* bịakwutere Jona nwa Amitai, na-asị,
\v 2 “Bilie, gaa Ninive, bụ obodo ukwu ahụ, kwusaa okwu megide ya, nʼihi na ajọ omume ha abịarutela nʼihu m.”
\p 
\v 3 Ma Jona gbapụrụ ọsọ site nʼihu \nd Onyenwe anyị\nd* chee ihu ya ije Tashish. O biliri jee Jopa, nʼebe ọ hụrụ ụgbọ mmiri nke na-aga Tashish. Ọ kwụrụ ụgwọ ije ụgbọ, banye isoro gaa Tashish ka o nwee ike gbapụ site nʼihu \nd Onyenwe anyị\nd*.
\p 
\v 4 Ma \nd Onyenwe anyị\nd* mere ka ifufe dị egwu malite ife nʼelu osimiri ahụ, ebili mmiri bidokwara na-amagharị, chọọ itiwasị ụgbọ mmiri ahụ.
\v 5 Mgbe ahụ, ndị niile na-arụ ọrụ nʼụgbọ ahụ tụrụ oke egwu, malite itiku chi ha. Ha malitekwara itufu ihe niile dị nʼụgbọ mmiri ahụ, ime ka ụgbọ ahụ dị mfe.
\p Ma nʼoge ihe ndị a na-eme, Jona nọrịị nʼala ala ụgbọ mmiri ahụ ebe o dinara ala na-arahụ ụra.
\v 6 Onyeisi ụgbọ jekwuru Jona sị ya, “Gịnị ka ị nọ nʼebe a na-eme, ị na-arahụ ụra? Bilie, kpọkuo chi gị, ma eleghị anya o nwere ike ileta anyị anya, meere anyị ebere, zọpụta anyị.”
\p 
\v 7 Mgbe ahụ, ndị nọ nʼụgbọ sịrịtara ibe ha, “Bịanụ ka anyị fee nza mata onye ihe ọjọọ dị otu a sị nʼaka ya bịakwasị anyị.” Ya mere, ha fere nza, nza ahụ a maa Jona.
\v 8 Nʼihi ya, ha sịrị ya, “Gwa anyị, onye mere ka ihe dị otu a bịakwasị anyị. Gịnị bụ ọrụ gị? Ebee ka i si bịa? Ị bụ onye obodo ebee? Ole agbụrụ i si na ya pụta?”
\p 
\v 9 Ọ sịrị, “Abụ m onye Hibru, na onye na-akpọ isiala nye \nd Onyenwe anyị\nd*, bụ Chineke nke eluigwe, onye kere osimiri na ala akọrọ.”
\p 
\v 10 Egwu dị ukwuu tụrụ ụmụ nwoke ahụ, ha sịrị ya, “Gịnị ka i mere?” Nʼihi na ha matara na o si nʼihu \nd Onyenwe anyị\nd* na-agbapụ ọsọ, nʼihi na ọ gwala ha rịị na ọ bụ otu o si dị.
\p 
\v 11 Ma ebili mmiri ahụ gara nʼihu na-amali nʼike nʼike. Nʼihi ya, ha sịrị, “Gịnị ka anyị ga-eme gị, nke ga-eme ka osimiri dajụọ?”
\p 
\v 12 Ọ gwara ha, “Bulienụ m tụnye nʼime osimiri. Nke a ga-emekwa ka ọ dajụọ. Nʼihi na amaara m na ọ bụ nʼihi m ka ebili mmiri ọjọọ a ji na-abịakwasị unu.”
\p 
\v 13 Kama, ndị ikom ahụ ji ike nyasie ụgbọ ahụ ichigharị ya laghachi nʼelu ala, ma ha enweghị ike. Nʼihi na oke osimiri ahụ na-amali elu karịa ka ọ dị na mbụ.
\v 14 Mgbe ahụ, ha tikuru \nd Onyenwe anyị\nd* mkpu akwa sị, “\nd Onyenwe anyị\nd*, biko ekwela ka anyị nwụọ nʼihi ọnwụ nwoke a. Biko, atụkwasịkwala ọbara nwoke a na-emeghị ihe ọjọọ nʼisi anyị, nʼihi na gị \nd Onyenwe anyị\nd* emeela dịka i si chọọ.”
\v 15 Ya mere, ha buliri Jona elu tụnye ya nʼime osimiri ahụ, ebili mmiri ahụ dajụkwara.
\v 16 Mgbe nke a mere ndị ikom ahụ tụrụ egwu \nd Onyenwe anyị\nd* nke ukwuu. Ha chụụrụ \nd Onyenwe anyị\nd* aja, kwekwa ya nkwa dị iche iche.
\s1 Ekpere Jona
\p 
\v 17 Ma \nd Onyenwe anyị\nd* akwadolarị otu azụ buru ibu ka o loo Jona. Ya mere, Jona nọrọ nʼafọ azụ ahụ ụbọchị atọ, ehihie na abalị.
\c 2
\nb 
\v 1 Mgbe ahụ, Jona sitere nʼafọ azụ ahụ kpeere \nd Onyenwe anyị\nd* Chineke ekpere.
\v 2 Ọ sịrị,
\q1 “Esitere m nʼahụhụ m kpọkuo \nd Onyenwe anyị\nd*,
\q2 ọ zakwara m.
\q1 Nʼafọ ala mmụọ ka m si tikuo gị,
\q2 ị nụkwara olu akwa m.
\q1 
\v 3 Ị tụnyere m nʼime mmiri dị omimi,
\q2 nʼetiti oke osimiri.
\q2 Osimiri dịkwa m gburugburu,
\q1 ebili mmiri gị na mmali mmiri gị
\q2 gabigakwara m nʼisi.
\q1 
\v 4 Mgbe ahụ, asịrị m, ‘E sitela nʼihu gị
\q2 chụpụ m;
\q1 ma otu ọ dị, aga m elegidekwa anya m ọzọ
\q2 nʼebe ụlọnsọ ukwu gị dị.’
\q1 
\v 5 Mmiri gbara m gburugburu, ruo nʼolu m,
\q2 ogbu mmiri na-erikpu m.
\q2 Achara mmiri kekụkwara m nʼisi.
\q1 
\v 6 Arịdaruola m nʼala ugwu ugwu nke osimiri,
\q2 ala ahụ ihe ntụchi ya niile kpachitara m ruo mgbe ebighị ebi.
\q1 Ma i meela ka m si nʼolulu pụta na ndụ,
\q2 \nd Onyenwe anyị\nd*, bụ Chineke m.
\b
\q1 
\v 7 “Mgbe mmụọ m na-ada mba nʼike nʼike,
\q2 e chetara m gị \nd Onyenwe anyị\nd*,
\q1 ma ekpere m bịakwutere gị,
\q2 nʼime ụlọnsọ ukwu gị dị nsọ.
\b
\q1 
\v 8 “Ndị na-arapara nʼarụsị dị iche iche na-enweghị uru ha bara,
\q2 na-agbakụta ebere Chineke azụ.
\q1 
\v 9 Ma ọ bụ olu abụ ekele
\q2 ka mụ onwe m ga-eji chụọrọ gị aja.
\q1 Aga m akwụghachi nkwa niile m kwere.
\q2 Nʼihi na ‘Nzọpụta bụ nke \nd Onyenwe anyị\nd*.’ ”
\p 
\v 10 Mgbe ahụ, \nd Onyenwe anyị\nd* nyere azụ ahụ iwu, nke mere ka ọ gbọpụta Jona nʼala akọrọ.
\c 3
\s1 Jona agaa Ninive
\p 
\v 1 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* ruru Jona ntị nke ugboro abụọ na-asị,
\v 2 “Bilie, jee nʼobodo ukwu ahụ bụ Ninive, kwusaara ya ozi ahụ m ziri gị.”
\p 
\v 3 Jona biliri gaa Ninive dịka okwu nke Onyenwe anyị si dị. Ninive bụ nnọọ obodo dị ukwuu, nke ga-ewe ụbọchị atọ ịga ya gburugburu.
\v 4 Jona malitere ịba nʼobodo ahụ, ma mgbe ọ gara ije otu ụbọchị, o kwusara sị, “Iri ụbọchị anọ ka ọ fọdụrụ tupu alaa Ninive nʼiyi.”
\v 5 Ndị Ninive kwenyeere na Chineke, kpọsaa obubu ọnụ, ha niile site nʼonye ukwu ruo nʼonye nta, onye ọbụla yikwasịrị uwe mkpe.
\p 
\v 6 Mgbe akụkọ a rutere eze Ninive ntị, o sitere nʼocheeze ya rituo, wezuga uwe eze ya, yikwasị uwe mkpe, nọkwasịkwa na ntụ.
\v 7 Nke a bụ nkwusa ya nʼime Ninive:
\pmo Nke a bụ iwu sitere nʼaka eze na ndị a maara aha ha:
\pm “Ka mmadụ ọbụla, maọbụ anụmanụ, igwe ehi maọbụ anụ ụlọ ọbụla, ghara idetu ihe ọbụla nʼọnụ, ka ha ghara iri ihe maọbụ ṅụọ mmiri.
\v 8 Kama ka onye ọbụla yiri akwa mkpe, ma mmadụ ma anụmanụ, ka ha kpọkusikwaa Chineke ike, ka ha sikwa nʼụzọ ọjọọ ha chegharịa, sikwa nʼọrụ ọjọọ ha na ime ihe ike ha niile chegharịa.
\v 9 Onye maara? Ma eleghị anya, Chineke ga-ejide oke iwe ya, ma site nʼọmịiko ya wezuga iwe ọkụ ya si otu a mee ka anyị ghara ịla nʼiyi.”
\p 
\v 10 Mgbe Chineke hụrụ ihe niile ha mere, na otu ha siri site nʼụzọ ọjọọ ha niile chegharịa, Chineke chegharịrị uche banyere ịla ha nʼiyi. O mekwaghị ka nzube ya ibibi obodo ahụ mezuo.
\c 4
\s1 Iwe Jona nʼihi ọmịiko \nd Onyenwe anyị\nd*
\p 
\v 1 Ma ihe a jọrọ Jona njọ nʼobi nke ukwuu, iwe ya dịkwa ọkụ.
\v 2 Nʼihi ya, o kpeere \nd Onyenwe anyị\nd* ekpere sị, “O, \nd Onyenwe anyị\nd*, nke a ọ bụghị ihe m kwuru, mgbe m nọ nʼala m? Ọ bụ ya mere m ji chọọ ịgbalaga na Tashish na mbụ nʼihi na amaara m na ị bụ Chineke onye na-eme amara, na onye jupụtara nʼobi ebere, na onye na-adịghị ewe iwe ọsịịsọ, nke bara ụba nʼịhụnanya, onye na-anaghị ata mmadụ ahụhụ dịka mmehie ya siri dị.
\v 3 Ugbu a, O, \nd Onyenwe anyị\nd* napụ m ndụ m. Ọ ga-adị m mma ịnwụ anwụ karịa ịdị ndụ.”
\p 
\v 4 Ma \nd Onyenwe anyị\nd* sịrị, “O ziri ezi na ị ga-esi otu a wee oke iwe dị ọkụ?”
\p 
\v 5 Mgbe ahụ, Jona si nʼebe ahụ pụọ jee nọdụ ala nʼakụkụ ọwụwa anyanwụ nke obodo ahụ. O weere ahịhịa meere onwe ya ụlọ ndo, nọdụ nʼime ya, chere ka ọ hụ ihe gaje ime obodo ahụ.
\v 6 Ma \nd Onyenwe anyị\nd* Chineke rọpụtara otu osisi nwere akwụkwọ sara mbara,\f + \fr 4:6 \ft Emeghị ka anyị amata ụdị osisi ọ bụ ma ụfọdụ akwụkwọ na-ede osisi ogiri ugba.\f* nke tolitere nʼelu isi Jona, ka o ghọọrọ ya ndo ịnapụta ya nʼọnọdụ ahụ mgbakasị. Jona ṅụrịrị ọṅụ maka osisi ahụ.
\v 7 Ma nʼisi ụtụtụ echi ya, Chineke mere ka otu ikpuru pụta nke riri osisi ahụ site nʼogwe ya, si otu a mee ka ọ kpọnwụọ.
\v 8 O ruo, mgbe anyanwụ wara, Chineke mere ka ifufe na-ekpo ọkụ site nʼọwụwa anyanwụ, anyanwụ a chara Jona nʼisi nke ukwuu nke mere nʼike gwụsịrị ya. Ọ rịọrọ ka ọnwụ gbuo ya, na-asị, “ọ ga a kaara m mma na m nwụrụ anwụ, karịa na m dị ndụ.”
\p 
\v 9 Ma Chineke sịrị Jona, “Ọ bụ ihe ziri ezi ka i wee iwe maka osisi a?”
\p Ọ sịrị, “E, ana m ewe oke iwe, ọ bụladị na m chọrọ ịnwụ.”
\p 
\v 10 Mgbe ahụ \nd Onyenwe anyị\nd* kwuru, “I nwere obi ebere nʼebe osisi a dị, nke ị na-akụghị na nke i mekwaghị ka o too, bụ nke toro nʼanyasị, nwụọkwa nʼanyasị.
\v 11 Mụ onwe m, m ga-aghara inwe obi ebere nʼahụ obodo ukwu a dịka Ninive, nke nwere ihe karịrị narị puku ndị mmadụ na iri puku mmadụ abụọ, bụ ndị na-amaghị nke bụ aka nri ha maọbụ aka ekpe ha, na nke ọtụtụ anụmanụ dịkwa nʼime ya?”
