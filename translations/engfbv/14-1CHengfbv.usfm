\v 19 \w Eber|strong="H5677"\w* \w had|strong="H3205"\w* \w two|strong="H8147"\w* \w sons|strong="H1121"\w*. \w One|strong="H1121"\w* \w was|strong="H8034"\w* \w named|strong="H8034"\w* \w Peleg|strong="H6389"\w*,\f + \fr 1:19 \ft The word means “divided.”\f* \w because|strong="H3588"\w* \w in|strong="H3117"\w* \w his|strong="H3588"\w* \w time|strong="H3117"\w* \w the|strong="H3588"\w* earth \w was|strong="H8034"\w* \w divided|strong="H6385"\w*; \w the|strong="H3588"\w* \w name|strong="H8034"\w* \w of|strong="H1121"\w* \w his|strong="H3588"\w* brother \w was|strong="H8034"\w* \w Joktan|strong="H3355"\w*.
