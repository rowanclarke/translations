\id 1TI Ika New Testament 2009
\h 1 Timoti
\toc1 Ẹkụkwọ-Ozi Ibuzọ Pọlụ Dejẹnni Timoti Timoti, Nke Ibuzọ
\toc2 Timoti, Nke Ibuzọ
\toc3 1Tim
\mt2 Ẹkụkwọ-Ozi Ibuzọ Pọlụ Dejẹnni
\mt2 Timoti
\mt1 Timoti, Nke Ibuzọ
\c 1
\cl Isi Nke Ohu
\p 
\v 1 Mmẹ wụ Pọlụ de ẹkụkwọ-ozini; m wụ onyẹ-ozi pụ-ichẹn Kraịstị Jizọsị. Osolobuẹ wụ Onyẹ-nzụọpụha ẹnyi lẹ Kristi wụ Jesu onyẹ ẹnyi gi dọn ẹnya tumẹ m.
\v 2 M rị e dejẹnni Timoti wụ nwa m esi imẹ okukwe. Ẹfọma lẹ omikẹn lẹ udọn hụn gha ẹka Chuku-Nẹdi lẹ Jesu Kristi Nna ẹnyi bịa ya rịnị ị.
\s1 Mkpịnsịn ẹka Banyeni Eje-nkuzi
\p 
\v 3 Nọdị nwan Ẹfẹsọsị kẹ m dọn gwa ị ogẹn m gi jẹnkọ Masẹdonia, kẹni ị gwa ndị hụ rị a kuzi ihiẹn wụlẹni ezioku w'a kuzizilẹ ihiẹn ndị hụ wẹ rị a kuzi;
\v 4 w'e gọnzilẹ ntịn akịkọ nwọnlẹni isi lẹ itu-mpupu ihiẹn hụn w'e tusọnmẹ hụn nwẹlẹni njẹdẹnmẹ—makẹni ihiẹn ndịnị e mẹ ịhịan a masọnmẹ ọmụma nwẹlẹni alị hụn nkẹ o gi yeni ịhịan ẹka bi obibi okukwe hụn Osolobuẹ chọ.
\v 5 Ihiẹn haịn i k'e gi gwa wẹ ẹrịra wụ nị ịhịan hụn ụzọ gi ihiẹn-ọsụsụọ e bi—ihiẹn-ọsụsụọ hụn gha obi rị mma lẹ ịhọrị rị mma lẹ okukwe gha akpakalị obi pụha.
\v 6 O nwẹọlẹ ndị latọ ihiẹn ndịnị, kpahu, sọnmẹ oku nwọnlẹni isi.
\v 7 Wẹ chọ nị wẹ wụrụ ndị nkuzi Iwu Mozizi, bụ aghọtanị wẹ ihiẹn ndị wẹ rị e ku mọbụ ihiẹn ndị wẹ rị e ku oku wẹ—e ku, a dụ ẹka obi.
\p 
\v 8 Ẹnyi a marịnghọ nị Iwu rị mma—omẹni ịhịan a marịnghọ gi ẹ mẹ ihiẹn wẹ gi ifiri ẹ ye Iwu.
\v 9 O furu nị ịhịan ghọta nị ẹlẹ ifiri ndị ezi-omumẹ kẹ wẹ gi ye iwu. Kama, wẹ gi ifiri ndị a dan iwu lẹ ndị e nupụ-isi ye ẹ, uwẹ lẹ ndị ghalẹni e fe Osolobuẹ lẹ ndị e mẹ njọ, ndị e mẹ ihiẹn rụnị lẹ ndị e lelịa ihiẹn rị nsọ, ndị e gbu nẹdi wẹ mọbụ nnẹ wẹ lẹ ndị izighẹ.
\v 10 Wẹ yezi ẹ makẹ ndị ughẹrẹ, makẹ ikẹnnyẹ hụn e mẹsọn ikẹnnyẹ mgba lẹ ikpoho hụn e mẹsọn ikpoho mgba, ndị e re ịhịan lẹ ndị e ṅọn ịhịan, ndị-ntụ, ndị a shịa ẹri-ntụ lẹ ndị e mẹ ihiẹn ndị ọzọ ọwụlẹ wẹ lẹ ezigbo nkuzi ghalẹni a dangbama.
\v 11 Ezigbo nkuzini rị imẹ oziọma hụn Osolobuẹ, Onyẹ hụ rịchanrịn mma, buche m ẹka.
\s1 Ikele Chuku Makẹni O Mẹ Ebere Nabanhan Ẹnyi
\p 
\v 12 M rị a kpanmịn Kraịstị wụ Jizọsị Di-nwọnni-ẹnyi hụn ye m ikẹn m gi rị a rụn ọrụn, makẹni o weri m nọkẹ onyẹ o gi dọn-ẹnya, we m ọrụn,
\v 13 ọsụọn'a nị m te kutọ a, kpokpo ndị nke ẹ, gi ẹka-ikẹn sọn wẹ. Kanị ọ nọ mẹ ebere m, makẹni amarịn m ihiẹn m rị e mẹ ogẹn ahụn, m'e ke kwerizikwọ ogẹn ahụn.
\v 14 Di-nwọnni-ẹnyi nọ gi ẹka rị mma sọn m, mẹ ni m omikẹn ọda-ọda, wezi okukwe lẹ ihiẹn-ọsụsụọ rị imẹ Jizọsị ye m ọda-ọda.
\v 15 Okuni wụ ezioku hụn furu w'a nabanhanchanrịn: nị, “Kraịstị wụ Jizọsị bịa imẹ ụwa d'a zụọpụha ndị njọ”—hụn o mẹ ni mmẹ kachanrịn njọ imẹ uwẹ ile.
\p 
\v 16 Kanị, ufiri ẹ kẹ Osolobuẹ gi mẹni m omikẹn, mmẹ hụn kachanrịn njọ e mẹ, kẹni Kraịstị wụ Jizọs' hụn ụzọ gi m ghọsịchanrịn ndidi zu oke, gi m mẹ ihiẹn nleri, kẹni ndị ọzọ, hụn k'e kweri n'ẹ gi ẹ marịn nị wẹ lẹ enwẹn wẹ jẹnkọ d'e nwọn ndụn itẹbitẹ.
\p 
\v 17 Eze Itẹbitẹ kẹ Osolobuẹ wụ! Eze Ghalẹni a nwụn! Onyẹ wẹ ghalẹni e legha ẹnya! Chuku ohu sụọ rịnị! Mgbaye lẹ ọghọ ya rịn'a jẹnrin ejẹn! Isẹẹ.
\s1 Gi Oku Osolobuẹ Lẹ Ịhọrị Rị Mma Lụnị Osolobuẹ Ogụn
\p 
\v 18 Timoti nwa m, m rị e ye i iwu ndịnị nọkẹ kẹ amụma ndị wẹ busọnmẹ banyeni i mbụ dọn ku, kẹni ị saẹka gi ihiẹn wẹ ku imẹ amụma ndị ahụn lụ ọgụn hụ rị mma,
\v 19 e kwọnkẹnmẹ okukwe lẹ ịhọrị rị mma. O nwẹgụọ ndị latọ ịhọrị wẹ, sụkpọpụ okukwe wẹ.
\v 20 Himẹnọsị lẹ Alẹzanda rị imẹ wẹ. E wegụọ m wẹ ẹbụọ ye Ekwensụ n'o mẹ wẹ ihiẹn, kẹni wẹ marịn kubehi arụ.
\c 2
\cl Isi Nke Ẹbụọ
\s1 Ife Ofufe Imẹ Ụka
\p 
\v 1 Igi bidọn nwan, m sị ọnụ a rịọsọnmẹni ni ịhịan ile Osolobuẹ; e mẹni ni wẹ ekpere; a rịọdọnni ni wẹ; e gi ni ifiri wẹ a kpanmịn a,
\v 2 e mẹzini ni ndị-nze lẹ ndị ile rị isi-ọkịkị ya, kẹni ẹnyi hụn ụzọ e bi obibi mẹ jụụ, e gi udọn e bi, e bi obibi ndị e fe Osolobuẹ, e yetarị mgbaye.
\v 3 Makẹni ụdị ekpereni rị mma, wụzịkwọ ihiẹn a sụọ Osolobuẹ wụ Onyẹ-nzụọpụha ẹnyi ụsụọ,
\v 4 makẹni Osolobuẹ chọ nị onyẹ ọwụlẹ nwọn nzụọfụha, marịnzịkwọ ezioku.
\q1 
\v 5 Makẹni,
\q1 Osolobuẹ ohu sụọ rị;
\q1 Onyẹ ohu sụọ rịzịkwọ
\q2 hụn e wegbama Osolobuẹ lẹ ịhịan.
\q1 Onyẹni wụ Kraịst wụ Jizọsị
\q2 hụn wụzịkwọ ịhịan;
\q2 
\v 6 hụn we enwẹn ẹ ye,
\q2 kẹni ọ wụrụ ihiẹn w'e gi gbapụha ịhịan ile—
\p Osolobuẹ a shịagụọ ẹri banyeni ihiẹnni ogẹn furuni.
\p 
\v 7 Wẹ tumẹ m onyẹ e zisọnmẹ ozi ihiẹnni lẹ onyẹ-ozi pụ-ichẹn lẹ onyẹ a kuzi ndị anị ndị ọzọ wụlẹni ndị Ju okukwe lẹ ezioku. M rị e ku ezioku, arị m a tụ ntụ!
\p 
\v 8 Ya wụ, m chọ nị ikẹnnyẹ rị ebe ọwụlẹ hụn a nị wẹ e mẹ ekpere. Wẹ gha a kịshi ẹka ekpere elu, ya wụrụkwọ ẹka rị nsọ, ẹlẹkwọ hụn wẹ gi iwe lẹ ndọndọ mẹrụ.
\p 
\v 9 M chọzịkwọ nị ikpoho e gi uche e kẹn ekikẹn: w'e yile ihiẹn e mẹ ifẹnrẹn, w'e yi ihiẹn furuni. Ekikẹn wẹ y'e mẹlẹ ịchọ ntutu mma, mọbụ iyi goru mọbụ ihiẹn-mma mọbụ ẹkwa ndị ṅanrannị.
\v 10 Kama, w'e gi ọrụn-ọma e kọn ekikẹn—k'o furu nị ikpoho ndị rị e fe Osolobuẹ, a tụ egun ẹ, e mẹ.
\p 
\v 11 Wẹ gha a kuzi, ikpoho w'a gba-nkịntịn, e gọn ntịn ihiẹn wẹ rị a kuzi, wẹ wechanrịn enwẹn wẹ che okpuru.
\v 12 M sị okpoho\f + \fr 2:12 \ft nwunyẹ ịhịan\f* y'a kuzilẹ; y'a kịlẹ okẹnnyẹ; y'a gba nkịntịn.
\v 13 Makẹni Adam' kẹ wẹ buzọ ke nị wẹ d'e ke Ivu;
\v 14 e dufieni wẹ Adam', kama, okpoho kẹ wẹ dufie, ọ nọ wụrụ onyẹ njọ.
\v 15 Kanị Osolobuẹ jẹnkọ d'a zụọfụha ikpoho amamgbe isi wẹ a tọ nsọngbu rị ọmụmụ nwa, ka sị a mẹni e bisọnmẹghọ wẹ imẹ okukwe, ihiẹn-ọsụsụọ lẹ ịrị-nsọ, e kwọndọn enwẹn wẹ.
\c 3
\cl Isi Nke Ẹtọ
\s1 Ndị-isi Ụka
\p 
\v 1 Okuni w'e ku wụ ezioku, nị, “Onyẹ ọrụn onyẹ-isi ụka n'a dụ, ọrụn rị mma k'ọ chọ nọ rụn.”
\p 
\v 2 Ya wụ, onyẹ-isi ụka k'a wụrịrị onyẹ nwọnlẹni nkọrịanị. O k'a wụrịrị onyẹ nwọn nwunyẹ ohu sụọ; onyẹ e kwọndọn enwẹn ẹ; onyẹ nwọn uche; onyẹ nwọn mgbaye. O k'a wụrịrị onyẹ ma nabanhan ndị ọbịa; onyẹ ma kuzi
\v 3 O mẹkọ onyẹ-manya mọbụ onyẹ ẹka-ikẹn, kanị onyẹ e mẹ nwayọ; ẹlẹ onyẹ-ikpe mọbụ onyẹ egho a sụọ.
\v 4 Ọ k'a wụrịrị onyẹ hụn e ri-ẹka a kị ikpun-ụlọ a ọhụnma, a hụn a nị ụmụ a hụ e humẹ isi, a gbaye ịhịan ụzọ ile.
\v 5 Makẹni, omẹni ịhịan a sanị ẹka kị ikpun-ụlọ a, nanị k'o dọn lepụ ụka Osolobuẹ ẹnya?
\v 6 Ọ wụkọ onyẹ rogharị nke ọhụn, onyẹ sọnmẹ ụzọ Kraịstị nke ọhụn, amamgbe ọ họnrọnma bụ o nwọnni ihiẹn ọ marịn, ikpe ma Ekwensụ a ma a.
\v 7 O k'a wụzịrịrị onyẹ ndị rị ogbe e ku oku ẹ ọhụnma, amamgbe ọ danban ọnyan Ekwensụ, fa.
\s1 Ndị-ọrụn Ụka
\p 
\v 8 Ẹrịrazịkwọ, ndị-ọrụn ụka k'a wụrịrị ndị ghalẹni e gi ihiẹn wẹ buche wẹ ẹka e gu egu; awụkọ wẹ ndị irenaị; awụkọ wẹ ndị okẹn-manya mọbụ ndị egho rị ẹnya.
\v 9 Wẹ k'a wụrịrị ndị e kwọnkẹnmẹ ihiẹn ndị ahụn mini rị ofufe-Kraịstị, wụrụzịkwọ ndị ghalẹni e mẹ ihiẹn obi gi e gbu wẹ mgbu.
\v 10 Wẹ k'e burịrị ụzọ lelegụụ wẹ. Omẹni enwọn wẹ nkọrịanị, wẹ rụnma nị ụka.
\p 
\v 11 Ẹrịrazịkwọ, ikpoho wẹ k'a wụrịrị ndị nwọn mgbaye; awụkọ wẹ ndị-nkutọ. Wẹ k'a wụrịrị ndị ẹnya dọn, ẹlẹ ndị okẹn-manya; wẹ k'a wụrịrị ndị w'e gi e dọn ẹnya imẹ ihiẹn ile.
\p 
\v 12 Ndị-ọrụn ụka k'a wụrịrị ndị nwọn nwunyẹ ohu sụọ; ndị a kị ụmụ wẹ lẹ ikpun-ụlọ wẹ ọhụnma.
\v 13 Ndị hụn rụn ọrụn-ụkanị ọhụnma k'e wẹhẹ ni enwẹn wẹ ezigbo ẹfan, ya wụ ọrụn k'e mẹzikwọ obi rukẹnmẹ wẹ alị imẹ okweri wẹ kwerini Kraịstị-Jizọsị.
\s1 Okukwe Ẹnyi Emikẹ!
\p 
\v 14 M bu ẹ obi nị m lala d'a hụn ị ẹgwa. Kanị, m rị e de ni i ihiẹn ndịnị
\v 15 kẹni, omẹni m bie d'a bịa, n'ị marịn k'o furu nị ịhịan e bi imẹ ikpun-ụlọ Osolobuẹ, ụka Osolobuẹ, Osolobuẹ hụn rị ndụn. Ụka a nị wụ iyetọ lẹ idẹn hụn gi ezioku.
\p 
\v 16 W'a rụ ụka a, ihiẹn ahụn ẹnyi kweri e mikẹ; ihiẹn ahụn mini wụ banyeni:
\q1 Onyẹ\f + \fr 3:16 \ft Ndị Kolosi 1.26-27; 2.2\f* ahụn gi ẹhụ pụha;
\q2 ọ nọ ghọsị nị ịya rọ nke-esi
\q2 ghahanị Mmọn-nsọ;
\q1 ndị mmọn-ozi a hụnghọ a.
\q1 Ịhịan e zisọnmẹgụọ ozi ẹ alị ichẹn-ichẹn;
\q1 e kwerigụọ nị w'a imẹ ụwa.
\q1 Ọ gi ọghọ lashi elu-igwee.
\c 4
\cl Isi Nke Ẹnọ
\s1 Eje-nkuzi
\p 
\v 1 Mmọn-nsọ e kupụgụọ a n'o ru ogẹn ịkpazụụn, o nwẹ ndị k'a latọ okukwe-Kraịstị, sọnmẹ mmọn ndị hụn e dufieni lẹ ihiẹn eje-mmọn rị ichẹn-ichẹn a kuzisọnmẹ,
\v 2 ebe wẹ n'e sọn nkuzi ndị-ntụ lẹ ndị ihunnaị ịhọrị wẹ nwụngụụ nọkẹ sị wẹ gi igwe-ọkụn dagbu ẹ.
\v 3 Wẹ k'a kuzimẹ ịhịan w'a lụlẹ di-lẹ-nwunyẹ. O nwẹghọzị ihiẹn-oriri ndị wẹ k'a sị wẹ sọma, ihiẹn-oriri Osolobuẹ ke kẹni ndị hụn kwerini, hụn marịn ezioku, hụn ụzọ e ri, e ye ẹ ekele.
\v 4 Ihiẹn ile Osolobuẹ ke rị mma, o nwọnni hụn w'a jụ, ka sị a mẹ ni wẹ gi ekele narịn a,
\v 5 makẹni oku Osolobuẹ lẹ ekpere e dọn ẹ nsọ.
\s1 Ezigbo Odibo Jesu Kristi
\p 
\v 6 Ị gwa umunẹ ẹnyi imẹ okukwe ihiẹn ndịnị wẹ, ya wụ nị ị wụ ezigbo onyẹ-ọrụn Kraịstị-Jizọsị, hụn wẹ gi ihiẹn ndị rị imẹ okukwe-Kraịstị lẹ ezigbo nkuzi hụ ị rị e sọn zụn.
\p 
\v 7 Latọ ilu ndị ahụn nwẹlẹni erere ọ ban ebe ihiẹn Osolobuẹ rị, hụn ndị marịnlẹni ihiẹn gi e dọn. Kama, e gi ihiẹn Osolobuẹ a zụn enwẹn i.
\v 8 Makẹni, w'a sị, “Erere hụọghọ ịzụn ẹhụ ịhịan, kanị igi ihiẹn Osolobuẹ a zụn enwẹn ịhịan kẹ erere ka a rị ụzọ ile, makẹni w'e ri erere ẹ imẹ ndụnnị lẹ imẹ ndụn lalanị.”
\v 9 Ezioku rọ, o furu nị wẹ nabanhan a ọhụnma-ọhụnma.
\v 10 Ya haịn ẹnyi gi a rụngbu enwẹn ẹnyi, a lụgbu enwẹn ẹnyi, makẹni ẹnyi gi Osolobuẹ rị ndụn dọn-ẹnya, Osolobuẹ hụn wụ Onyẹ-nzụọpụha ịhịan ile—tụmadụ ndị kwerini.
\p 
\v 11 A gwa wẹ nị wẹ k'e mẹrịrị ihiẹn ndịnị, a kuzi wẹ ya.
\v 12 Anịkwọlẹ onyẹ ọwụlẹ legber'i n'ị wụ nwata. Ka wụrụ onyẹ ndị kwerini e leri oku-ọnụ a, obibi ẹ, ihiẹn-ọsụsụọ a, okukwe ẹ lẹ k'o dọnmẹ obi ẹ ọchan.
\v 13 M gini d'a bịa, hụn a nị ị hụ a gụnpụha Ẹkụkwọ-nsọ ebe ịhịan ile rị, e gi oku-Chuku a kpasu mmọn wẹ, a kuzi wẹ ogẹn ile.
\v 14 Alatọkwọlẹ oyiye hụn rị imẹ i, hụn Osolobuẹ ye i ogẹn hụ wẹ gi bu amụma banyeni i, ndị-isi ụka nọ bu ẹka kwasị ị.
\p 
\v 15 Hụn a nị ị hụ e mẹ ihiẹn ndịnị ile; wechanrịn enwẹn i che imẹ wẹ, kẹni ịhịan ile hụn a nị ị hụ e mẹ wẹ ọhụnma, a rụnpụha ihiẹn rịn'a.
\v 16 E leban enwẹn i lẹ nkuzi i ẹnya; e mẹsọnmẹ ihiẹn ndịnị wẹ. Makẹni, i gha e mẹ wẹ, i sikọ d'a zụọfụha kẹ enwẹn i kẹ ndị rị e gọn i ntịn.
\c 5
\cl Isi Nke Isẹn
\s1 Ẹka W'e Gi E Sọn Ndị Rị Ichẹn-ichẹn Rị Ụka
\p 
\v 1 Aganlẹ okẹnnyẹ-ọba, ka gi mgbaye gwa a oku lẹkẹ onyẹ rị a gwa nẹdi ẹ oku; a gwa ikẹnnyẹ rị ibe anị oku lẹkẹ umunẹ-ikẹnnyẹ;
\v 2 a gwa ikpoho-ọba oku lẹkẹ onyẹ rị a gwa nnẹ ẹ; a gwa ikpoho rị ibe alị oku lẹkẹ umunẹ-ikpoho—ka dọnmẹchanrịnkwọ enwẹn i ọchan.
\p 
\v 3 E lepụ ndị di wẹ nwụn hụn nwẹlẹni eyemẹka nke-esi ẹnya, n'i gi ẹ tụ nị wẹ ụya.
\v 4 Omẹni okpoho di ẹ nwụn e nwọnghọ ụmụ, mọbụ ụmụ-oyẹ, ndịnị wẹ mụrụngụdẹ kẹ wẹ dọn a rụn ihiẹn furu nị wẹ rụnnị ndị ezi-lẹ-ụlọ wẹ, e gi ẹka wẹ rị e yeni ndị mụnị wẹ a kụkinbelụa wẹ ụgwọ, makẹni ịya a sụọ Osolobuẹ.
\v 5 Nke okpoho di ẹ nwụn hụn wụ ogbẹnnyẹ nke-esi, hụn nwọnlẹni onyẹ ọwụlẹ, o k'a rị e gi Osolobuẹ e dọn ẹnya, e mẹsọnmẹ ekpere, a rịọ Osolobuẹ uhinhin lẹ efinnaị.
\v 6 Kanị, hụn rị e bi obibi ẹhụ-ufu anwụnhụngụọlẹ—ọsụọn'a nị ọ rị ndụn.
\v 7 Hụn a nị y'e yezi wẹ iwu ndịnị amamgbe wẹ a wụrụ ndị nwọn nkọrịanị.
\v 8 Onyẹ ọwụlẹ ghalẹni e lefụ ndị nke ẹ ẹnya, tụmadụ ikpun-ụlọ a, a jụgụọ okukwe-Kraịstị, onyẹ ahụn ka onyẹ kwerilẹni njọ.
\s1 Ikpoho Di Wẹ Nwụn Hụn Ụka Jẹnkọ D'e Lepụ Ẹnya
\r (Ọrụn Ndị-Ozi 6.1; 9.36-39)
\p 
\v 9 Okpoho di ẹ nwụn hụn rugụụ ahụa ọgụn ẹtọ mọbụ karị sụọ kẹ wẹ jẹnkọ d'a gụnye ikpoho di wẹ nwụn hụn ụka jẹnkọ d'e lepụ ẹnya; o k'a wụrịrị onyẹ lụkarịlẹni di ohu.
\v 10 Ọ k'a wụrịrị onyẹ wẹ gi ọrụn ọma ọ rụnsọnmẹ marịn: ya wụ, n'ọ zụnghọ ụmụ; n'ọ nabanhanghọ ndị ọbịa; n'o feghọ ndị-nke Osolobuẹ, chanchanpụ wẹ unyin ụkụ; n'o yeghọnị ndị rị nsọngbu ẹka; n'o gighọ enwẹn ẹ kwanị ọrụn ọma ụzọ ile.
\s1 Ikpoho Di Wẹ Nwụn Hụn Kelẹni Ka Ẹgẹdi
\p 
\v 11 Ka ekwerilẹ gụnye ikpoho di wẹ nwụn hụn kelẹni ka ẹgẹdi. Makẹni, ihiẹn a gụn ẹhụ nwẹ ikẹn ban ẹgbata wẹ lẹ Kraịstị, a chọma wẹ nị wẹ lụrụ di.
\v 12 Ogẹn hụ ikpe a ma wẹ makẹni e tikpọgụọ wẹ nkwa ibuzọ wẹ kwe.
\p 
\v 13 Wezụkadẹ ọhụn, o ru, a mụnrụn wẹ ẹka-nkụtọpụ, a gha ụnọ-ụnọ. Ẹlẹdẹ ẹka-nkụtọpụ sụọ, a sị sị-sị-sị, e busọnmẹ ẹka e che ọrụn rulẹni wẹ, e kusọnmẹ ihiẹn furulẹni nị wẹ ku.
\v 14 Ufiri ọnwan, ndụnmọdụn m wụ: ikpoho di wẹ nwụn hụn kelẹni ka ẹgẹdi wẹ lụrụ di, wẹ mụ ụmụ, wẹ e lepụ ikpun-ụlọ wẹ ẹnya—amamgbe eṅẹnrẹn a hụn oghere o gi kuja oku ẹnyi.
\v 15 Makẹni, ndị hụ imẹ ikpoho ndịnị wẹ a kpahugụọlẹ, sọnmẹ Ekwensụ.
\p 
\v 16 Okpoho ọwụlẹ kweri ni Jesu hụn ndị di wẹ nwụn wụ ndị-igbẹnnyẹ nke-esi rị ikpun-ụlọ wẹ, ya yeni wẹ ẹka, makẹ ụka gha e bu okẹn ibu—kẹni ụka hụn ụzọ saẹka e yeni ndị ahụn di wẹ nwụn hụn nwẹlẹni onyẹ e yeni wẹ ẹka nke-esi ẹka.
\s1 Ẹka Wẹ Gi E Sọn Ndị-isi Ụka
\p 
\v 17 Ndị-isi ụka rị a kị ọhụnma ru w'e ye ọghọ lẹ ụgwọ-ọrụn furu w'e ye ndị-isi—ụzọ ẹbụọ, tụmadụ ndị rị a gbakẹnmẹ ebe iku oku-Chuku lẹ ikuzi n'ẹ rị.
\v 18 Makẹni, Ẹkụkwọ-nsọ sị, “Ekẹnmẹlẹ efin ọnụ ebe ọ rị a zọkpọ ọka,” sịzị, “Onyẹ-ọrụn e furughọ hụn w'a kụ ụgwọ-ọrụn a.”
\p 
\v 19 Wẹ kinghọsị ị ihiẹn ọwụlẹ banyeni onyẹ-isi, egikwọlẹ ẹ dọn, mmanị madụ ẹbụọ mọbụ ẹtọ pụha ọshẹri.
\v 20 Nke ndị hụn e mẹsọnmẹ njọ, jụgbọ wẹ id'ẹnya ịhịan ile, kẹni egun hụn ụzọ tụma ndị họdụnị.
\p 
\v 21 M rị a gba ị mkpịnsịn-ẹka id'ẹnya Osolobuẹ lẹ Kraịstị wụ Jizọsị lẹ ndị mmọn-ozi nsọ: e dọnmẹ iwu ndịnị; egbeyekwọlẹ ni onyẹ ọwụlẹ; elekwọlẹ ịhịan ẹnya ihun.
\p 
\v 22 Ahụhụkwọlẹ bu ẹka kwasị onyẹ ọwụlẹ tumẹ ẹ onyẹ ọrụn-ụka, bụ y'e leban n'a ẹnya ọhụnma. Kpachanfụ ẹnya amamgbe y'e bi ẹka ye njọ ndị ọzọ mẹ; dọnmẹ enwẹn i ọchan.
\p 
\v 23 Arazịlẹ mirin sụọ, kama, a rarị ẹkẹrẹ manya makẹ ufiri ẹfọ ị lẹ makẹ emu hụn a kụ n'ị mbụ-lẹ-ẹbụọ.
\p 
\v 24 O nwẹ ndị njọ wẹ a pụhachanrịn ifọn, a ma wẹ ikpe wẹ kebe kinmẹ wẹ ikpe, kanị nke ndị ọzọ, njọ wẹ a ra fụha ifọn ẹgwa, kanị ọ hụ e sọn wẹ, wẹ kingụụ wẹ ikpe ọ pụha ifọn.
\v 25 Ẹrịra kẹ ọrụn ọma dọnzịkwọ a pụhachanrịn ifọn. Ọsụọdẹn'a n'o ke pụhachanrịn ifọn, o zuerikọ jẹnrin ejẹn.
\c 6
\cl Isi Nke Isin
\p 
\v 1 Ndị ile wụ igbọn mọbụ odibo ẹka ịhịan wẹ weri ndị wẹ rị okpuru wẹ nị e rughọ wẹ ogo mgbaye, a gbayechanrịn wẹ—makẹ ịhịan gha e kutọ ẹfan Osolobuẹ lẹ ihiẹn ẹnyi rị a kuzi.
\v 2 Emẹni ịhịan rị e fe onyẹ kwerini, y'e benụakwọlẹ mgbaye o ye ẹ makẹni wẹ wụ umunẹ imẹ okukwe. Kama, ya fedẹ ẹ karị, makẹni onyẹ rị e ri erere ọrụn a wụ onyẹ kwerini lẹ onyẹ rị Osolobuẹ obi.
\p A kuzi wẹ ihiẹn ndịnị, e nu wẹ e mẹ wẹ.
\s1 Eje-nkuzi Lẹ Ihiẹn E Buhẹn'ẹ
\p 
\v 3 Onyẹ ọwụlẹ hụn a kuzisọnmẹ ihiẹn ọzọ wụlẹni ezioku, onyẹ hụn ghalẹni e kweye ni oku ndị hụ zu oke Onyẹ-nwẹni-ẹnyi wụ Jizọs' Kraịstị ku lẹ nkuzi furu ofufe Osolobuẹ,
\v 4 rịhụ a pache; o nwọnni ihiẹn ọ marịn. Adụdụ ịdọ-ndọndọ lẹ ịrụ-ụka mkpụrụ-oku wụ nsọngbu ẹ. Eje-adụdụnị e buhẹ iwe-ẹnya, ikpe, nkutọ, inyọnsọnmẹ-ịhịan onyinyọn rịlẹni mma
\v 5 lẹ idọsọnmẹ ndọndọ—hụn o mẹni o nwẹ ndị e mẹn'ẹ. Uche ndị nọ ẹrịra arị mma; ezioku a nahịngụọ wẹ. Wẹ rị e ro nị ife Osolobuẹ wụ ụzọ wẹ gi e nwẹ erere. [Esọnkwọlẹ ndị nọ ẹrịra a kpa.]
\s1 Ezigbo Akụ-lẹ-ụba
\p 
\v 6 Ifedẹ Osolobuẹ wụ erere hi-ogbe nke-esi omẹni ịhịan a nị ihiẹn o nwẹ jun ẹ ẹfọ.
\v 7 Makẹni, o nwọnni ihiẹn ẹnyi wẹhẹ imẹ ụwa, o nwọnzikwọnị ihiẹn ọwụlẹ ẹnyi jẹnkọ d'e weri imẹ ẹ ẹnyi pụkọnị.
\v 8 Ya wụ, o mẹhụ ni ẹnyi e nwọnghọ ihiẹn-oriri lẹ ẹkwa\f + \fr 6:8 \ft lẹ ebe ẹnyi e buche isi\f*, ya jun ẹnyi ẹfọ.
\v 9 Kanị, ndị rị a chọ nị wẹ hi ọdafịn a danbansọnmẹ imẹ ọnwụnwan; ẹgụn rị ichẹn-ichẹn nwọnlẹni isi a nwụndọn wẹ kẹ ọnyan—ẹgụn rị ichẹn-ichẹn hụn a rụ ịhịan ẹhụ, a dọ ịhịan e ye imẹ iwi lẹ ntikpọ.
\v 10 Makẹni, ẹkpịrị-egho wụ mkpọgụn ụdị eje-ihiẹn ile gha a suepụha. O nwẹghọ ndị ghagụụ imẹ okukwe kpahu ebe ihi-ọdafịn n'a dụ wẹ, mẹsọnmẹ ihiẹn bu ọda obi gi e gbusọnmẹ wẹ mgbu.
\s1 Ndụnmọdụn Rịnị Onyẹ-ọrụn Osolobuẹ
\p 
\v 11 Kanị, ịyụ wụ onyẹ nke Osolobuẹ, na ihiẹn ndịnị ile tọ. Chụma ezi-omumẹ Osolobuẹ chọ, ife-Chuku ọhụnma, okukwe, ihiẹn-ọsụsụọ, ndidi lẹ imẹ-jụụ.
\v 12 Lụ ezigbo ọgụn ahụn okukwe ẹnyi chọ, y'e kwọnkẹnmẹ ndụn itẹbitẹ hụn Osolobuẹ gi ufiri ẹ kpọ ị, hụn i gizi ifiri ẹ nọ id'ẹnya ndị bu ọda ku ẹ n'i kwerichanrịn nị Jizọsị.
\v 13 Ihun ẹnya Osolobuẹ hụn e ye ihiẹn ile ndụn lẹ Jizọs' Kraịstị hụn nọ id'ẹnya Pọntus' Paịleti ku ezioku, kwerichanrịn n'ọ wụ Onyẹ ọ wụ\f + \fr 6:13 \ft Jọn 18.33-37\f*, m sị ị
\v 14 dọnmẹchanrịn iwuni; enwọnkwọlẹ ntụpọ mọbụ nkọrịanị ebe ị n'e dọnmẹ ẹ d'e ru ọbịbịa Onyẹ-nwẹni-ẹnyi wụ Jesu Kristi.
\v 15 Ọbịbịa Jesu, hụn Osolobuẹ jẹnkọ d'e mẹ n'o mẹzu ogẹn furuni. Osolobuẹ, Onyẹ hụn rịchanrịn mma, Onyẹ ya sụọ wụ Eze nke-esi, Eze ndị-nze lẹ Nna ndị-nna;
\v 16 Ịya sụọ wụ onyẹ ghalẹni a nwụn; Onyẹ hụn bi imẹ ukpẹ wẹ ghalẹni a saẹka a nọkunmẹ; Onyẹ ịhịan leghatulẹni bụ asakọ wẹ ẹka legha a! Mgbaye lẹ ọkịkị itẹbitẹ ya rịn'a! Isẹẹ.
\s1 Ihiẹn Wẹ K'a Kuzi Ndị-ịdafịn
\p 
\v 17 Nke ndị wụ ọdafịn imẹ ndụnnị, gba wẹ mkpịnsịn ẹka, sị wẹ a pachelẹ mọbụ gi akụ-lẹ-ụba dọn ẹnya, akụ-lẹ-ụba hụn ghalẹni a tọ. Ka wẹ gi Osolobuẹ dọn ẹnya, ịya wụ onyẹ hụn e yesọnmẹ ẹnyi ihiẹn ile, e yekwasị, kẹni ẹfọ hụn ụzọ a sụọ ẹnyi ụsụọ.
\v 18 Sị wẹ mẹsọnmẹ mma, a wụ ọdafịn ebe ịrụn ọrụn-ọma rị; wẹ a ha-ẹka, wẹ wụrụ ndị a chọ nị wẹ yebeye ndị ọzọ ihiẹn—
\v 19 e gi ụzọnị e dọnmẹtọnị enwẹn wẹ akụ-lẹ-ụba wụ akụ-lẹ-ụba nke-esi, e gi ẹ e gbetọnị enwẹn wẹ ezigbo iyetọ makẹ ogẹn hụ lalanị, kẹni wẹ hụn ụzọ kwọndọn ndụn hụ wụ ndụn nke-esi.
\p 
\v 20 Euu, Timoti, kwọnkẹnmẹkwọ ihiẹn wẹ buche i ẹka-o; latọkwọ oku ndị ahụn nwẹlẹni erere ọ ban ebe ihiẹn Osolobuẹ rị lẹ oku rijunlẹni ẹfọ wẹ rị a kpọ, “Amamihiẹn” bụ ẹlẹ ya.
\v 21 Makẹni, o nwẹgụọ ndị ghagụụ imẹ okukwe-Kraịstị kpapụ, ebe wẹ n'e sọn ya wụ ihiẹn.
\p Ẹfọma Osolobuẹ ya rị nị ụnụ ile.
