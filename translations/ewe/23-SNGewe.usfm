\id SNG - Biblica® Open Ewe Contemporary Scriptures 2020
\h Hawo
\toc1 Hawo ƒe ha
\toc2 Hawo
\toc3 Haw
\mt1 Hawo
\mt2 ƒe ha
\c 1
\s1 Xɔlɔ̃wo ƒe lɔlɔ̃ na wo nɔewo
\p 
\v 1 Solomo ƒe hawo ƒe ha.
\b
\q1 
\v 2 Tsɔ wò nu gbugbɔ nu nam,
\q2 elabena wò lɔlɔ̃ doa dzidzɔ nam wu wain.
\q1 
\v 3 Wò ami ʋeʋĩ si nèsi la le ʋeʋẽm ɖem nyuie;
\q2 wò ŋkɔ le abe ami si wowu la ene.
\q1 Mewɔ nuku be ɖetugbiwo lɔ̃ wò nenema gbegbe o!
\q1 
\v 4 Kplɔm ɖe asi, na míaɖe abla!
\q2 Fia la nekplɔm yi eƒe xɔ mee.
\q1 Míatso aseye, akpɔ dzidzɔ ɖe ŋutiwò,
\q2 eye míakafu wò lɔlɔ̃ wu wain.
\q1 Ele eteƒe be wole lɔ̃wòm alea!
\b
\q1 
\v 5 O! Yerusalem vinyɔnuwo, ame yie menye,
\q2 ke menyo abe Kedar ƒe agbadɔwo
\q2 kple Solomo ƒe agbadɔ ƒe mɔnuvɔwo ene.
\q1 
\v 6 Mègate ŋku nɔ kpɔyem, elabena menyo o;
\q2 nyae be ɣee ɖum menyɔ alea.
\q1 Danyevi ŋutsuwo do dɔmedzoe ɖe ŋunye,
\q2 eye wona mekpɔ woƒe waingblewo dzi,
\q2 ke megblẽ nye ŋutɔ nye waingble ya ɖi.
\q1 
\v 7 Gblɔe nam, wò ame si melɔ̃na,
\q2 afi ka nènyia wò lãhawo le, eye ne ŋdɔ ʋu la,
\q2 afi ka nènana wotsyɔa akɔ ɖo?
\q1 Nu ka ŋuti manɔ abe nyɔnu si tsyɔ nu ŋkume ene
\q2 le xɔ̃wòwo ƒe lãhawo gbɔ?
\q1 
\v 8 Wò, tugbewo ƒe fia, ne mènyae o la,
\q2 do afɔ na alẽhawo, eye nànyi wò gbɔ̃viwo
\q2 le lãkplɔlawo ƒe agbadɔwo gbɔ.
\q1 
\v 9 Nye lɔlɔ̃tɔ, metsɔ wò sɔ kple sɔnɔ si
\q2 wotsi ɖe Farao ƒe tasiaɖam ɖeka ŋuti.
\q1 
\v 10 Togɛ si nède la wɔe be wò alɔgo nya kpɔ nyuie,
\q2 eye kɔga siwo nède la hã dze wò.
\q1 
\v 11 Míawɔ sikatogɛwo na wò,
\q2 eye woawɔ klosalokpɛviwo ɖe ete.
\q1 
\v 12 Esi fia la le nuɖukplɔ̃ ŋu la,
\q2 nye ami ʋeʋĩe le ya ɖem.
\q1 
\v 13 Nye lɔlɔ̃tɔ le nam abe lifigoe
\q2 le nye akɔnu ene.
\q1 
\v 14 Nye lɔlɔ̃tɔ le nam abe henaseƒoƒo si
\q2 wogbe hebla tso En Gedi waingble me ene.
\q1 
\v 15 Nye lɔlɔ̃tɔ, èdze tugbe loo!
\q2 O, aleke nènya le kpɔkpɔm ale!
\q2 Wò ŋkuwo le abe ahɔnɛtɔwo ene.
\q1 
\v 16 Nye lɔlɔ̃tɔ, èdze ɖeka ŋutɔ!
\q2 O, aleke nèhedze ɖekae nye esi!
\q2 Míaƒe aba de ama nyuie.
\q1 
\v 17 Míaƒe xɔ ƒe daɖedziwo nye sedatiwo,
\q2 eye míaƒe xɔ ƒe dzisasãwo nye vɔvɔli.
\c 2
\s1 Lɔlɔ̃tɔwo di wo nɔewo vevie
\q1 
\v 1 Nyee nye Saron seƒoƒo
\q2 kple dzogbenya le balimewo.
\q1 
\v 2 Abe ale si dzogbenya le ŋuwo domee ene la,
\q2 nenemae nye nye lɔlɔ̃tɔ le ɖetugbiwo dome.
\q1 
\v 3 Abe ale si apluti nɔna le avemetiwo dome ene la,
\q2 nenemae nye nye lɔlɔ̃tɔ le ɖekakpuiwo dome.
\q1 Melɔ̃a anyinɔnɔ ɖe eƒe vɔvɔli te,
\q2 eye eƒe kutsetse vivia nunye ŋutɔ.
\q1 
\v 4 Ekplɔm yi ɖe afi si woɖo kplɔ̃ ɖo,
\q2 eye lɔlɔ̃ nye aflaga si wòtsɔ tsyɔ dzinye.
\q1 
\v 5 Etsɔ waintsetsebolo do ŋusẽm kple aplu fa dzi nam,
\q2 elabena lɔlɔ̃ na meku ƒenyi.
\q1 
\v 6 Etsɔ eƒe miabɔ de nye ta te,
\q2 eye wòtsɔ eƒe ɖusibɔ kpla kɔ nam.
\q1 
\v 7 Yerusalem nyɔnuviwo,
\q2 meta sãde kple zinɔ le gbe me be,
\q1 “Migaʋuʋu lɔlɔ̃ alo anyɔe o,
\q2 va se ɖe esime eya ŋutɔ lɔ̃ hafi.”
\b
\q1 
\v 8 Nye lɔlɔ̃tɔ, ɖo to afii!
\q2 Kpɔ ɖa, nye lɔlɔ̃tɔe nye ekem gbɔna,
\q1 le kpo tim flɔ towo, eye wòle kpo dzom
\q2 le togbɛwo tame.
\q1 
\v 9 Nye lɔlɔ̃tɔ le abe sãde alo zivi ene.
\q2 Kpɔ ɖa, eyae nye ekem
\q2 le tsitre ɖe míaƒe kpɔ godo,
\q1 le nu kpɔm to fesre nu,
\q2 eye wòdo ŋku ɖa to fesrenuvɔ me.
\q1 
\v 10 Nye lɔlɔ̃tɔ ƒo nu kplim be,
\q2 “Nye dzi lɔlɔ̃a, tsi tsitre,
\q2 eye nye tugbefia, va dze yonyeme.
\q1 
\v 11 Kpɔ ɖa, vuvɔŋɔli nu va yi,
\q2 tsidzadza ke, eye enu va yi.
\q1 
\v 12 Seƒoƒo ke ɖe anyigba dzi,
\q2 hadzidzi ƒe ɣeyiɣi ɖo,
\q1 eye wose akpakpawo ƒe xɔxlɔ̃
\q2 le míaƒe anyigba dzi.
\q1 
\v 13 Gbotiwo de asi tsetse me xoxo,
\q2 eye wainkawo ƒe seƒoƒo le ya ɖem nyuie.
\q1 Tso va, nye dzi lɔlɔ̃a;
\q2 nye tugbefia, va dze yonyeme.”
\q1 
\v 14 Nye ahɔnɛ le agakpewo tome,
\q2 le towo ƒe bebeƒewo,
\q1 do wò mo ɖa, eye na mase wò gbe,
\q2 elabena wò gbe vivina, eye wò mo nya kpɔna.
\q1 
\v 15 Milé abeiwo nam,
\q2 abeivi siwo le wainkawo gblẽm,
\q2 eye wole míaƒe wainka siwo ƒo se la gblẽm.
\q1 
\v 16 Nye lɔlɔ̃tɔ nye tɔnye, eye nye hã menye etɔ,
\q2 eya ame si le tsa ɖim le dzogbenyawo dome.
\q1 
\v 17 Nye lɔlɔ̃tɔ, trɔ gbɔ hafi ŋu nake,
\q2 viviti nasi dzo, eye nànɔ abe sãde
\q2 alo zivi le togbɛ tsakliwo dzi ene.
\c 3
\s1 Lɔlɔ̃tɔ ƒe anukwareɖiɖi
\q1 
\v 1 Medi ame si nye dzi lɔ̃na la
\q2 le nye aba dzi zã blibo la katã;
\q2 medii, gake nyemekpɔe o.
\q1 
\v 2 Matso azɔ ayi aɖadii le dua me,
\q2 le ablɔwo dzi kple kpɔdomewo.
\q1 Matsa adi ame si nye dzi lɔ̃na la,
\q2 ale medii ʋuu keke, gake nyemekpɔe o.
\q1 
\v 3 Esi mele tsatsam le dua me
\q2 le edim la, medo go zãdzɔlawo,
\q2 eye mebia wo be,
\q2 “Miekpɔ ame si nye dzi lɔ̃na la mahã?”
\q1 
\v 4 Nyemekpɔ dze le wo ŋu hafi kpɔ
\q2 ame si nye dzi lɔ̃na la o.
\q1 Meku ɖe eŋu goŋgoŋgoŋ be madzo o,
\q2 va se ɖe esime mekplɔe yi danye ƒe aƒe me,
\q2 yi ɖe ame si dzim la ƒe xɔ me.
\q1 
\v 5 Yerusalem nyɔnuviwo,
\q2 meta sãde kple zinɔ le gbe me na mi be,
\q1 “Migaʋuʋu lɔlɔ̃ alo anyɔe o,
\q2 va se ɖe esime eya ŋutɔ nalɔ̃ hafi.”
\s1 Xɔlɔ̃ ƒe atsyɔ̃ɖoɖo
\q1 
\v 6 Ame kae nye esi gbɔna tso gbegbe abe dzudzɔ babla
\q2 si wotɔtɔ kple lifi kple atike ʋeʋĩ si wowɔ
\q2 kple nu vovovo siwo woƒle le asitsalawo si la ene?
\q1 
\v 7 Kpɔ ɖa, Solomo ƒe tasiaɖam ye!
\q2 Kalẽtɔ blaade
\q1 siwo nye aʋakalẽtɔ akuakuawo tso Israel
\q2 ƒe aʋakɔwo dome la le eŋu dzɔm.
\q1 
\v 8 Wo katã wota yi ɖe aklito,
\q2 wobi ɖe aʋawɔwɔ me,
\q1 woƒe asiwo le woƒe yiwo dzi,
\q2 eye wole klalo na zãmeŋɔdzi ɖe sia ɖe.
\q1 
\v 9 Fia Solomo ŋutɔe wɔ tasiaɖam la na eɖokui,
\q2 ewɔe kple ʋuƒo siwo wotsɔ tso Lebanon.
\q1 
\v 10 Ewɔ eƒe afɔtiwo kple klosalo,
\q2 eye wòwɔ egɔme kple sika.
\q1 Wotsɔ agovɔ nyuitɔ wɔ zikpui si le eme,
\q2 eye wotsɔ Yerusalem nyɔnuviwo ƒe lɔlɔ̃ ɖo atsyɔ̃ na emee.
\q1 
\v 11 Mi Zion vinyɔnuwo,
\q2 mido go va kpɔ Fia Solomo si ɖɔ fiakuku,
\q1 kuku si dadaa ɖɔ nɛ le eƒe srɔ̃ɖegbe,
\q2 gbe si gbe eƒe dzi kpɔ dzidzɔ vevie la ɖa.
\c 4
\s1 Lɔlɔ̃ na xɔlɔ̃
\q1 
\v 1 Nye lɔlɔ̃tɔ, èdze tugbe loo!
\q2 O, èdze tugbe ŋutɔ!
\q1 Wò ŋkuwo le abe ahɔnɛ ƒe ŋkuwo ene
\q2 le wò moxevɔ la me.
\q1 Wò taɖa le abe gbɔ̃ha siwo
\q2 le ɖiɖim tso Gilead to dzi la ene.
\q1 
\v 2 Wò aɖuwo fu tititi abe alẽha siwo
\q2 woko fu na teti, eye wole tsi na wo la ene.
\q1 Ɖe sia ɖe le zɔzɔm eveve,
\q2 eye ɖeke metsi akogo o.
\q1 
\v 3 Wò nuyiwo le abe ɖablanu dzĩ ene,
\q2 eye wò nu nya kpɔna ŋutɔ.
\q1 Wò tonuƒuiwo le dzedzem le wò moxevɔ me
\q2 abe atɔtɔ si me woma ɖe eve la ene.
\q1 
\v 4 Wò kɔ le abe David ƒe xɔ tsrala
\q2 si le dzedze tɔxɛ me, eye wotsɔ kalẽtɔ akpe nanewo
\q2 ƒe akpoxɔnu ku ɖe eŋuti la ene.
\q1 
\v 5 Wò nowo le abe sãdevi eve ene
\q2 alo abe sãde ƒe evenɔvi siwo le gbe ɖum
\q2 le dzogbenyawo me ene.
\q1 
\v 6 Mayi lifitowo kple dzudzɔdonu ʋeʋĩ togbɛwo dzi
\q2 va se ɖe esime ŋu nake, eye viviti nasi adzo.
\q1 
\v 7 Nye dzi lɔlɔ̃a, nu sia nu de le ŋuwò,
\q2 eye kpɔtsɔtsɔ aɖeke mele ŋuwò o.
\b
\q1 
\v 8 Nye ŋugbetɔ, va mídzo le Lebanon,
\q2 kplɔm ɖo ne míado go le Lebanon.
\q1 Ɖiɖi tso Amana tame,
\q2 tso Senir kple Hermon tame,
\q2 tso dzatawo ƒe do me kple lãkletowo dzi.
\q1 
\v 9 Wò nu lé dzi nam, nɔvinye nyɔnu kple nye ŋugbetɔ;
\q2 wò nu lé dzi nam esi nètsɔ wò ŋkuwo kpɔm zi ɖeka pɛ ko,
\q2 eye nye ŋkuwo lɔ kɔga si nède la.
\q1 
\v 10 Nɔvinye nyɔnu, nye ŋugbetɔ,
\q2 wò lɔlɔ̃ vivina loo!
\q1 Wò lɔlɔ̃ vivina wu wain,
\q2 eye ami ʋeʋĩ si nèsi la
\q2 ƒe ʋeʋẽ ƒo atike ʋeʋĩwo katã ta!
\q1 
\v 11 Nye ŋugbetɔ, wò nuyiwo le vivim abe anyitsito ene,
\q2 eye notsi kple anyitsi le wò aɖe te.
\q1 Awu siwo nèdo la
\q2 le ʋeʋẽm lĩlĩlĩ abe Lebanon ƒe ʋeʋẽ ene.
\q1 
\v 12 Nye ŋugbetɔ, nɔvinye nyɔnu,
\q2 èle abe abɔ si ƒe ʋɔ wotu la ene.
\q1 Eye nèle abe vudo si nu wotu nu ɖo
\q2 kple tsitsetse si nu wotre la ene.
\q1 
\v 13 Wò nuku siwo nèƒã ɖe agble me la woe nye:
\q2 atɔtɔ, sikɔni, adrike,
\q2 
\v 14 gbe ʋeʋĩwo, agumetaku, sabala,
\q2 sinamon kple atike ʋeʋĩ vovovowo kpe ɖe lifi,
\q2 aloe kple nu ʋeʋĩ nyuitɔwo ŋu.
\q1 
\v 15 Èle abe tsi dzidzi si le abɔ me,
\q2 kple vudo si yɔ gbã go hele sisim tso Lebanon ene.
\q1 
\v 16 Nyɔ, anyieheya, ne nàva;
\q2 dzieheya, wò hã va!
\q1 Ƒo to nye abɔ me,
\q2 be eƒe ʋeʋẽ nakaka ɖe yame.
\q1 Na be nye lɔlɔ̃tɔ nava eƒe abɔ me,
\q2 eye wòaɖɔ eƒe kutsetse nyuitɔwo kpɔ.
\c 5
\s1 Lɔlɔ̃tɔ kafu xɔlɔ̃a ƒe nyonyo
\q1 
\v 1 Meva nye abɔ me, nɔvinye nyɔnu, nye ŋugbetɔ;
\q2 megbe nye lifi kple nu ʋeʋĩwo.
\q1 Meɖu nye anyito, heno nye anyitsi;
\q2 meno nye wain kple nye notsi.
\q1 Miɖu nu, eye miano nu, O xɔlɔ̃wo,
\q2 miɖu nu miaɖi ƒo, O lɔlɔ̃tɔwo.
\q1 
\v 2 Medɔ alɔ̃, gake nye dzi ya le ŋu.
\q2 Miɖo to! Nye lɔlɔ̃tɔ le ʋɔ ƒom!
\q1 “Ʋu ʋɔ nam, nɔvinye nyɔnu, nye dzi lɔlɔ̃a,
\q2 nye ahɔnɛ kple nye kpɔkpɔmatikɔe.
\q1 Ahũ ƒo nye ta bekee,
\q2 eye nye ɖa me yɔ fũu kple zãmu.
\q1 
\v 3 Meɖe nye awuwo ɖi;
\q2 ɖe magatsɔ wo adoa?
\q1 Meklɔ nye afɔwo;
\q2 ɖe magaƒo ɖi woa?
\q1 
\v 4 Nye lɔlɔ̃tɔ do asi ɖe fesre nu,
\q2 nye dzi tso tititi ɖe eŋu.
\q1 
\v 5 Metso be maʋu ʋɔ na nye lɔlɔ̃tɔ,
\q2 eye ami ʋeʋĩ le tsyɔtsyɔm le nye asi kple asibidɛwo ŋu,
\q2 heɖuɖu ɖe gameti la ƒe asiléƒe ŋu.
\q1 
\v 6 Meʋu ʋɔ na nye lɔlɔ̃tɔ,
\q2 gake nye lɔlɔ̃tɔ dzo;
\q2 megale ʋɔa godo o.
\q1 Esi wòdzo la, nye dzi ge ɖe dɔ me nam.
\q2 Metsa dii, gake nyemekpɔe o.
\q2 Meyɔe, gake metɔ o.
\q1 
\v 7 Zãɖiala siwo le tsatsam le dua me la do gom.
\q2 Woƒom, de abi ŋunye;
\q1 dzɔla siwo le gliwo ŋu dzɔm la hã xɔ
\q2 awu kpekpe si medo ɖe awu dzi la le asinye!
\q1 
\v 8 O Yerusalem vinyɔnuwo, meta mi;
\q2 ne miekpɔ nye lɔlɔ̃tɔ la, nya kae miagblɔ nɛ?
\q2 Migblɔ nɛ be lɔlɔ̃ de dɔ lãme nam.
\q1 
\v 9 Wò, tugbefia,
\q2 aleke wò lɔlɔ̃tɔ nyo wu lɔlɔ̃tɔ bubuawoe?
\q1 Nu ka wò lɔlɔ̃tɔ tsɔ ƒo bubuawo tae
\q2 hafi nèta nu na mí alea?
\q1 
\v 10 Nye lɔlɔ̃tɔ le keklẽm, eye wòbiã,
\q2 ale wòƒo ame akpe ewo ta.
\q1 
\v 11 Eƒe ta nye sika nyuitɔ,
\q2 eƒe taɖa le mlɔmlɔmlɔ,
\q2 eye wònyɔ abe akpaviã ƒe fu ene.
\q1 
\v 12 Eƒe ŋkuwo le abe ahɔnɛ siwo
\q2 le tɔʋuwo to la tɔwo ene,
\q1 woklɔ wo kple notsi,
\q2 eye wosɔ ɖe ŋkutome nɛ abe dzonu ene.
\q1 
\v 13 Eƒe alɔgowo le abe kutsetse ʋeʋĩ si ɖo ɖe ɖoɖo nu,
\q2 eye wòle ya ɖem nyuie la ene.
\q1 Eƒe nuyiwo le abe dzogbenya
\q2 si le ami ʋeʋĩ tsyɔm la ene.
\q1 
\v 14 Eƒe abɔwo le abe sikati si ŋuti
\q2 woɖo sohamkpe ɖo la ene.
\q1 Eƒe ŋutigbalẽ le abe nyiɖu si ŋuti wotutu wòzrɔ̃ nyuie,
\q2 eye wotsɔ safir ɖo atsyɔ̃ ɖe eŋu la ene.
\q1 
\v 15 Eƒe afɔwo le abe kpe xɔasi sɔti si
\q2 wotsɔ sika nyuitɔ ɖo gɔmeɖokpe na la ene.
\q1 Eƒe dzedzeme le abe Lebanon ene,
\q2 eye wòxɔ asi abe eƒe sedatiwo ene.
\q1 
\v 16 Vivi le eƒe nu me gɔ̃ hã,
\q2 eye eya amea dzeani ŋutɔ.
\q1 O Yerusalem vinyɔnuwo,
\q2 esiae nye nye lɔlɔ̃tɔ,
\q2 esiae nye xɔ̃nye.”
\c 6
\s1 Dzidzɔkpɔkpɔ le ɖekawɔwɔ ŋuti
\q1 
\v 1 Tugbewo ƒe fia,
\q2 afi ka wò lɔlɔ̃tɔ yi?
\q1 Mɔ ka wò lɔlɔ̃tɔ to,
\q2 ne míakpe ɖe ŋuwò adii?
\q1 
\v 2 Nye lɔlɔ̃tɔ yi ɖe eƒe abɔ me;
\q2 eyi atike ʋeʋĩwo ƒe bo dzi,
\q1 ne wòatsa le wo me agbe dzogbenyawo.
\q1 
\v 3 Nye lɔlɔ̃tɔ nye tɔnye, eye nye hã menye etɔ;
\q2 ele tsa ɖim le dzogbenyawo dome.
\q1 
\v 4 Nye dzi lɔlɔ̃a, èdze tugbe abe Tirza ene,
\q2 ènya kpɔ abe Yerusalem ene,
\q1 eye fianyenye le ŋutiwò abe asrafoha
\q2 siwo lé aflaga ɖe asi ene.
\q1 
\v 5 Ɖe wò ŋku ɖa le ŋunye;
\q2 wowu gbɔgblɔ nam,
\q1 wò taɖa le abe gbɔ̃ha
\q2 siwo ɖi tso Gilead to dzi la ene.
\q1 
\v 6 Wò aɖuwo fu abe alẽha siwo tso tsileƒe ene.
\q2 Wo katã wole zɔzɔm eveve,
\q2 eye ɖeke metsi akogo o.
\q1 
\v 7 Wò tonuƒui le dzedzem le moxevɔ me
\q2 abe atɔtɔ si woma ɖe eve la ene.
\q1 
\v 8 Fiasrɔ̃wo le blaade, ahiãviwo le blaenyi,
\q2 hekpe ɖe ɖetugbi dzadzɛ siwo mele xexlẽme o la ŋuti;
\q1 
\v 9 gake nye ahɔnɛ si de blibo si le tɔxɛ,
\q2 dadaa ƒe vinyɔnu ɖeka hɔ̃ɔ lae nye
\q2 ame si nye dzila ƒe malɔ̃nulegbɔa.
\q1 Ɖetugbiawo kpɔe, eye woyɔe be yayratɔ;
\q2 fiasrɔ̃wo kple ahiãviawo hã kafui.
\q1 
\v 10 Ame kae nye esi le dzedzem abe agudzedze ene,
\q2 nyo abe ɣleti ene,
\q1 le keklẽm abe ɣe ene,
\q2 eye wòle zɔzɔm fiatɔe
\q2 abe ɣletiviwoe le asaɖa bɔm ene?
\q1 
\v 11 Meyi ɖe azitiwo te,
\q2 ne makpɔ gbe fɛ̃ siwo le balime,
\q1 ne makpɔe ɖa be wainkawo te tsetse
\q2 alo yevuzitiwo ƒo se mahã.
\q1 
\v 12 Hafi mava nya la,
\q2 nye didi kplɔm yi ɖe nye dukɔ
\q2 ƒe fia ƒe tasiaɖamwo dome.
\q1 
\v 13 Trɔ va, trɔ va,
\q2 O Sulamitɔ trɔ va, trɔ va,
\q2 be míalé ŋku ɖe ŋuwò sẽe!
\q1 Nu ka ta miebe míalé ŋku ɖe Sulamitɔ ŋu
\q2 abe ale si miewɔna ne
\q2 wole Mahanaim ɣe ɖum la ene?
\c 7
\s1 Lɔlɔ̃tɔwo ƒe dzeɖoɖo
\q1 
\v 1 Wò, dumegã ƒe vinyɔnu,
\q2 atokota dze afɔ na wò loo!
\q1 Wò zɔzɔme le tɔxɛ abe dzonu vavã
\q2 si aɖaŋuwɔla wɔ la ene.
\q1 
\v 2 Wò agbɔgbɔnu sɔ tebee abe wainkplu
\q2 si me wain si wotɔtɔ la mevɔna le o la ene.
\q1 Wò alime keke abe bli si woli kɔe,
\q2 eye dzogbenya ɖe to ɖee la ene.
\q1 
\v 3 Wò nowo le abe sãdevi eve
\q2 siwo nye zi ƒe evenɔviwo la ene.
\q1 
\v 4 Wò kɔ le tsralɛ abe nyiɖuxɔ tsrala ene.
\q2 Wò ŋkuwo le abe Hesbon ƒe tsita
\q2 si le Bat Rabingbo nu la ene.
\q1 Wò ŋɔti le abe Lebanon ƒe xɔ tsrala
\q2 si dze ŋgɔ Damasko la ene.
\q1 
\v 5 Wò ta le tegblẽe abe Karmel to ene,
\q2 eye wò taɖa le abe fia ƒe avɔ si
\q1 wotsɔ ka vovovowo lɔ̃e la ene.
\q2 Eƒe dzedzeme ɖe aboyo fia la.
\q1 
\v 6 Èdze tugbe ŋutɔ, eye wò nu hã nyoa ame ŋu.
\q2 O lɔlɔ̃, wò nuwɔna ɖe sia ɖe doa dzidzɔ na nye dzi!
\q1 
\v 7 Wò kɔkɔme le abe deti ene,
\q2 eye wò nowo le toɖoe
\q2 abe atikutsetse siwo le kpo ŋuti la ene.
\q1 
\v 8 Megblɔ be, “Made deti la dzi,
\q2 eye malé eƒe tsetsea ɖe asi.”
\q1 Wò nowo nenɔ abe wainkpo siwo le wainka ŋu la ene,
\q2 wò gbɔgbɔ naʋẽ lĩlĩlĩ abe aplu ene,
\q1 
\v 9 eye wò nu me nenye wain nyuitɔ.
\q2 Wain la neto nye lɔlɔ̃tɔ ƒe nu me
\q2 kple eƒe aɖutame wɔlii.
\q1 
\v 10 Menye nye lɔlɔ̃tɔ tɔ,
\q2 eye eya hã ƒe dzi le yonyeme.
\q1 
\v 11 Nye lɔlɔ̃tɔ, va;
\q2 na míayi gbe me,
\q2 eye míatsi kɔƒe me adɔ.
\q1 
\v 12 Na míafɔ kaba ayi waingblewo me,
\q2 akpɔe ɖa be wainkawo te tsetse,
\q1 woƒe seƒoƒowo ke, eye gbotiwo hã le tsetsem mahã;
\q2 le afi ma matsɔ nye lɔlɔ̃ na wò.
\q1 
\v 13 Adrikewo le ya ɖem nyuie,
\q2 eye atikutsetse vivi vovovowo
\q1 le míaƒe ʋɔtru nu, eye medzra yeyeawo
\q2 kple xoxoawo siaa ɖo na wò, nye lɔlɔ̃tɔ.
\c 8
\s1 Anukwareɖiɖi si anɔ anyi ɖaa
\q1 
\v 1 Ɖe nànɔ nam abe nɔviŋutsu
\q2 si no danye ƒe no la ene!
\q1 Ekema ne medo go wò le kpɔdome la,
\q2 magbugbɔ nu na wò,
\q2 eye ame aɖeke mado vlom o.
\q1 
\v 2 Makplɔ wò adzoe, ayi ɖe danye,
\q2 ame si fia num la ƒe aƒe me.
\q1 Mana wain si me wode atike ʋeʋĩi
\q2 kple atɔtɔŋutitsi la wò nàno.
\q1 
\v 3 Eƒe miabɔ le nye ta te,
\q2 eye wòtsɔ eƒe ɖusibɔ kpla kɔ nam.
\q1 
\v 4 Yerusalem vinyɔnuwo, meta mi:
\q2 migaʋuʋu alo mianyɔ lɔlɔ̃ o,
\q2 va se ɖe esi eya ŋutɔ nalɔ̃ hafi.
\q1 
\v 5 Ame kae nye esi gbɔna tso gbegbe,
\q2 eye wòziɔ ɖe eƒe lɔlɔ̃tɔ ŋu?
\q1 Menyɔ wò le apluti te;
\q2 afi mae dawò fɔ wò fu le,
\q2 afi mae ame si le ku lém la dzi wò ɖo.
\q1 
\v 6 Lém ɖe wò dzi kple wò abɔ ŋuti abe nutrenu ene.
\q2 Elabena lɔlɔ̃ sesẽ wu ku,
\q2 eye ŋuʋaʋã gbea tanana abe yɔdo ene.
\q1 Ebina abe dzo ene,
\q2 eye wòflana abe Yehowa ƒe dzo ene.
\q1 
\v 7 Tsi geɖe mate ŋu atsi lɔlɔ̃ ƒe dzo o,
\q2 eye tɔsisi aɖeke mate ŋu akplɔe dzoe o.
\q1 Ne ame aɖe atsɔ eƒe aƒemekesinɔnuwo katã
\q2 ana ɖe lɔlɔ̃ ta la,
\q2 anye alɔmeɖenu wòawɔ.
\q1 
\v 8 Nɔvinyɔnu ɖetugbivi aɖe le mía si
\q2 mekpɔ te no haɖe o.
\q1 Nu ka míawɔ na mía nɔvinyɔnu la
\q2 gbe si gbe woava bia eta?
\q1 
\v 9 Nenye glie wònye la,
\q2 míatsɔ klosalo atu xɔ tsrala ɖe edzi.
\q1 Nenye agboe wònye la,
\q2 míatsɔ sedaʋuƒowo aklã ɖe eŋuti godoo.
\q1 
\v 10 Menye gli, eye nye nowo
\q2 le abe xɔ tsralawo ene.
\q1 Ale mele eƒe ŋkume abe
\q2 ame si tsɔ dzidzeme vɛ la ene.
\q1 
\v 11 Waingble le Solomo si le Baal Hamon;
\q2 eye wòtsɔ agble la de asi na agbledzikpɔlawo,
\q1 be wo dometɔ ɖe sia ɖe nana klosalo
\q2 kilogram wuiɖekɛ kple afã ɖe waintsetseawo ta.
\q1 
\v 12 Nye ŋutɔ nye waingble le asinye be matsɔ ana;
\q2 O Solomo, klosalo kilogram wuiɖekɛ kple afã la nye tɔwò,
\q2 eye kilogram eve kple afã nye agbledzikpɔlawo tɔ.
\q1 
\v 13 Wò ame si le abɔwo me,
\q2 eye xɔlɔ̃wo ƒo xlã wò,
\q2 na mase wò gbe!
\q1 
\v 14 Nye lɔlɔ̃tɔ,
\q2 si va, eye nànɔ abe sãde
\q2 alo zivi si le gbe ʋeʋĩwo ƒe towo dzi la ene.
