\id JUD
\h يَاهُوذَا 
\toc1 يَاهُوذَا 
\toc2 يَاهُوذَا 
\toc3 يَاه. 
\mt1 يَاهُوذَا  
\c 1
\m
\v 1 يَاهُوذَا، أَمْسخَّارْ ن يَاسُوع لْمَاسِيحْ، ذ ؤُمَاسْ ن يَاعْقُوبْ.  
\m إِ ڒڭْنُوسْ إِتّْوَاڒَاغَانْ، إِنِّي إِتّْوَاعِيزّنْ زِي أَربِّي، بَابَاثْنغْ، ذ إِنِّي إِتّْوَاحْضَانْ زِي يَاسُوع لْمَاسِيحْ.  
\v 2 إِڒِي أَذْ غَارْومْ ثمَّارْنِي أَرّحْمثْ ذ ڒهْنَا ذ ثَايْرِي.   
\b  
\m
\v 3 \add أَ\add* إِمْعِيزّنْ إِنُو، ؤُمِي شطَّارغْ مَاحنْذْ أَذْ أَومْ د-أَرِيغْ خْ ثُوذَارْثْ نّغْ إِمُوننْ، أَقَا ؤُفِيغْ بلِّي إِتّْخصَّا أَيِي أَذْ أَومْ د-أَرِيغْ س ؤُزِييَّارْ، حِيمَا أَذْ ثمّنْغمْ س جّهْذْ خْ لْ-إِيمَانْ إِ إِمّوْشنْ إِشْثْ ن ثْوَاڒَا \add إِ ڒبْذَا\add* إِ إِمْقدَّاسنْ.  
\v 4 مِينْزِي شَا ن إِوْذَانْ خْثُوتّْڒنْ غَارْ ذَاخڒْ، إِنِّي ثُوغَا إِتّْوَازمّمنْ إِ ڒْحُوكْمْ-أَ قْبڒْ: أَقَا نِيثْنِي ذ إِعفَّاننْ، إِنِّي إِبدّْڒنْ أَرْضَا ن أَربِّي نّغْ ذڭْ إِجّْ ن نّْعِي ن ؤُفُوشّحْ، ؤُشَا نكَّارنْ أَينِّي ن سِيذِي أَربِّي ذ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 1:‏4 \xt 1 بُط. 2‏:‏8؛ 2 بُط. 2‏:‏1، 3. \x*   
\m
\v 5 مَاشَا خْسغْ أَذْ كنِّيوْ سّْعقْڒغْ، أَقَا مَارَّا كنِّيوْ ثسّْنمْ مَانْ أَيَا مْلِيحْ، بلِّي أَربِّي، ؤُمِي إِفكّْ ڒْڭنْسْ زِي ثمُّورْثْ ن مِيصْرَا، ثُوغَا إِسّْهلّكْ أَوَارْنِي مَانْ أَيَا إِنِّي وَارْ يُومِيننْ شَا. \x ◘ \xo 1:‏5 \xt ڒخْڒ. 14‏:‏29؛ 26‏:‏64، 65؛ إِزهد. 106‏:‏26؛ 1 كُور. 10‏:‏5؛ عبر. 3‏:‏17. \x*  
\v 6 ؤُشَا لْمَالَاكَاثْ نِّي وَارْ حْضِينْثْ أَوقَّارْ نْسنْ أَمزْوَارُو، مَاشَا جِّينْثْ ثَازذِّيغْثْ نْسنْ، أَقَا نتَّا إِحْضَا خَاسنْ س سّْنَاسڒْ وَارْ إِتّْوِيڒِينْ سَاذُو ثَادْجسْثْ إِ ڒْحُوكْمْ ن وَاسّْ أَمقّْرَانْ، \x ◘ \xo 1:‏6 \xt 2 بُط. 2‏:‏4. \x*  
\v 7 أَمْ مَامّشْ سَاذُومْ ذ عَامُورَّا ذ ثْندَّامْ إِ ذ أَسْ د-إِنّْضنْ، مَانِي ڭِّينْ نِيثْنِي فَارْقْ-شّْغڒْ س وبْرِيذْ ذ إِجّنْ أَمْ ڭِّينْثْ ثِينَا \add س ثْنَاينْ\add* ؤُ ضْفَارنْثْ دَّاثْ نّغْنِي، أَقَا تّْوَامَّارْسنْثْ ذ إِمذْيَا ن ثْمسِّي إِتّْذُومَانْ، تّْوَاحكْمنْثْ غَارْ شّْرعْ. \x ◘ \xo 1:‏7 \xt أَمز. 19‏:‏24؛ أَعَوذ. 29‏:‏22؛ إِشا. 13‏:‏19؛ إِرْم. 50‏:‏40؛ حِز. 16‏:‏49؛ حُوش. 11‏:‏8؛ عَام. 4‏:‏11؛ لك. 17‏:‏29؛ 2 بُط. 2‏:‏6. \x*   
\m
\v 8 أَمنِّي عَاوذْ \add إِ غَا هلّْكنْ\add* إِنَا، إِنِّي إِسّخْمَاجنْ دَّاثْ أَمْ د-تَّاذْفنْ ذِي ثِيرْجَا، إِنِّي إِمّنْضَارنْ صُّولْطَا \add ن إِجنْوَانْ\add* ؤُشَا تّْشقَّافنْ ذڭْ ؤُعُودْجِي \add نّسْ\add*.   
\m
\v 9 مَاشَا ڒَامِي ثُوغَا إِسَّاوَاڒْ مِيخَايِيلْ، أَزدْجِيفْ ن لْمَالَاكَاثْ، أَكْ-ذ إِبْڒِيسْ خْ أَرِّيمثْ ن مُوسَا، وَارْ خَاسْ إِحْكِيمْ س إِجّْ ن ڒْحُوكْمْ إِتّْشقَّافنْ، مَاشَا إِنَّا: ”سِيذِي أَذْ شكْ إِخدْجصْ!“ \x ◘ \xo 1:‏9 \xt دَان. 10‏:‏13؛ 12‏:‏1؛ زَاك. 3‏:‏2؛ 2 بُط. 2‏:‏11؛ أَسَا. 12‏:‏7. \x*  
\v 10 مَاشَا إِنَا تّْشقَّافنْ ذِي مَارَّا مِينْ وَارْ سِّيننْ، ؤُشَا س ثْمسْڒَايِينْ إِ غَارْ تّْوَاجبّْذنْ نِيثْنِي أَمْ إِمُودَّارنْ إِڭْنَاونْ عْلَاحْسَابْ طّْبِيعثْ نْسنْ، أَقَا أَردّْدْجنْ نِيثْنِي إِخفْ نْسنْ. \f ◼ \fr 1:‏10 \ft \+bd ’إِمُودَّارنْ‘\+bd* - نِيغْ ’لْحَايَاوَانَاثْ‘.\f*  \x ◘ \xo 1:‏10 \xt 2 بُط. 2‏:‏12. \x*  
\v 11 ؤُشْثْ خَاسنْ، مِينْزِي نِيثْنِي ؤُيُورنْ أَبْرِيذْ ن قَايِينْ ؤُشَا ؤُمِي تّْمژْرنْ ذِي ڒْمُونثْ ضْفَارنْ نِيثْنِي أَغكّْوِي ن بَالْعَامْ ؤُ تّْوَاهلْكنْ ذڭْ ؤُغوّغْ ن كُورَاخْ. \x ◘ \xo 1:‏11 \xt أَمز. 4‏:‏8؛ ڒخْڒ. 16‏:‏1؛ 22‏:‏7، 21؛ 2 بُط. 2‏:‏15؛1 يُوح. 3‏:‏12. \x*   
\m
\v 12 إِنَا ذ إِنِّي إِسّْفطَّاحنْ إِخفْ نْسنْ س ؤُنشْوثْ نْسنْ، وَارْ تّْسضْحِينْ شَا أَذْغبَّانْ. أَقَا أَثنْ ذ إِسيْنُوثنْ بْڒَا أَنْژَارْ، تّْوَاعَارّْننْ زِي سَّا غَارْ ذِيهَا س ؤُسمِّيضْ، أَقَا أَثنْ ذ ثِيشجُّورَا نِّي ذِي ثدْجَا ڒْغِيدْجثْ نْسنْثْ ثْودَّارْ، أَقَا وَارْ ذَايْسنْثْ ثدْجِي بُو ڒْغِيدْجثْ، مُّوثنْثْ وِيسّْ مَارْثَاينْ ؤُشَا تّْوَاقڒْعنْثْ زڭْ إِژوْرَانْ نْسنْثْ. \x ◘ \xo 1:‏12 \xt 2 بُط. 2‏:‏13، 17. \x*  
\v 13 نِيثْنِي ذ ڒمْوَاجْ ن ڒبْحَارْ إِهَاجنْ، إِنِّي إِسُّوسُوفنْ إِكُوفَّانْ ن ڒفْضِيحثْ نْسنْ، أَقَا أَثنْ ذ إِثْرَانْ ودَّارنْ، إِنِّي ؤُمِي ثتّْوَاسّوْجذْ ثُوبَّارْشنْثْ ن ثَادْجسْثْ إِ ڒبْذَا. \x ◘ \xo 1:‏13 \xt إِشا. 57‏:‏20. \x*   
\m
\v 14 مَاشَا حَانُوخْ، ونِّي ذ وِيسّْ سبْعَا زِي أَذَامْ، إِنبَّا خَاسنْ، إِنَّا: ”خْزَارْ، سِيذِي أَذْ د-يَاسْ أَكْ-ذ ڒُوڒُوفْ ن ڒُوڒُوفْ ن إِمْقدَّاسنْ نّسْ، \x ◘ \xo 1:‏14 \xt أَمز. 5‏:‏18؛ دَان. 7‏:‏10؛ ڒخ. 1‏:‏11؛ 1 تس. 1‏:‏10؛ 2 تس. 1‏:‏10؛ أَسَا. 1‏:‏7. \x*  
\v 15 حِيمَا أَذْ إِڭّْ ڒْحُوكْمْ نّسْ خْ مَارَّا إِوْذَانْ زِي سِّيبّثْ ن مَارَّا ثِيمڭَّا ن يِينِّي إِڭِّينْ ثُوعفّْنَا، ؤُ زِي سِّيبّثْ ن وَاوَاڒنْ إِقسْحنْ إِ زِي سِّيوْڒنْ إِمذْنَابْ إِغشَّاشنْ.“ \x ◘ \xo 1:‏15 \xt مت. 12‏:‏36. \x*   
\m
\v 16 إِنَا تّْعكَّاسنْ، تّْشثْشَانْ خْ كُوڒْ دَّابْ ن سِّيبّثْ، أَمْ ڭُّورنْ غَارْ نّشْوَاثْ نْسنْ، أَقمُّومْ نْسنْ إِسَّاوَاڒْ س ثْمسْڒَايِينْ ثِيعفَّانِينْ أَڒْ طَّارْفْ، تّڭّنْ ثِيقدُّوحِينْ إِ إِوْذَانْ إِ ثِيزِي ن يِيخفْ نْسنْ. \x ◘ \xo 1:‏16 \xt 2 بُط. 2‏:‏18. \x*   
\b  
\m
\v 17 مَاشَا كنِّيوْ، \add أَ\add* إِمْعِيزّنْ إِنُو،عقْڒمْ أَوَاڒنْ إِ إِزَّارْ سِّيوْڒنْ \add زَّايْسنْ\add* رُّوسُولْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، \f ◼ \fr 1:‏17 \ft \+bd ’رُّوسُولْ‘\+bd* - نِيغْ ’إِمَازَاننْ‘.\f*  
\v 18 إِنِّي ذ أَومْ إِنَّانْ، أَقَا ذڭْ ؤُنڭَّارْ ن زّْمَانَاثْ أَذْ ذِينْ إِڒِينْ إِمسْثهْزَاينْ، إِنِّي إِ غَا إِضْفَارنْ ڒقْجَاهثْ عْلَاحْسَابْ نّشْوَاثْ نْسنْ. \x ◘ \xo 1:‏18 \xt ڒخ. 20‏:‏29؛ 1 تِيم. 4‏:‏1؛ 2 تِيم. 3‏:‏1؛ 4‏:‏3؛ 2 بُط. 2‏:‏1؛ 3‏:‏3. \x*  
\v 19 أَقَا ذ يِينَا ذ إِنِّي إِفَارّْزنْ إِخفْ نْسنْ أَمْ إِوْذَانْ إِضفَّارنْ طّْبِيعثْ ن يِيخفْ نْسنْ، مِينْزِي وَارْ غَارْسنْ بُو أَرُّوحْ.   
\b  
\m
\v 20 مَاشَا كنِّيوْ، \add أَ\add* إِمْعِيزّنْ إِنُو، تّْوَابْنَامْ زڭْ ؤُزدْجِيفْ ذِي لْ-إِيمَانْ نْومْ إِقدّْسنْ س أَرُّوحْ إِقدّْسنْ، أَمْ ثژَّادْجَامْ.  
\v 21 أجّْ أَنغْ أَذْ نحْضَا إِخفْ نّغْ ذِي ثَايْرِي ن أَربِّي أَمْ نتّْرَاجَا أَرّحْمثْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ إِ ثُوذَارْثْ نّغْ إِتّْذُومَانْ.  
\v 22 قڒْعمْ شَا زَّايْسنْ زِي ثْمسِّي.  
\v 23 مَاڒَا ثُوبنْ نِيثْنِي، سشْنمْ أَسنْ أَرّحْمثْ، مَاشَا أَكْ-ذ ثِيڭّْوُوذِي، \add وَاهْ،\add* عِيفّمْ عَاذْ زِي ثْشَامِيرْ إِ إِتّْوَاسّْخمْجنْ زڭْ ويْسُومْ.   
\b  
\m
\v 24 مَاشَا إِ نتَّا، ونِّي إِزمَّارنْ أَذْ أَنغْ إِحْضَا بْڒَا أَنقْڒَاضْ ؤُ بْڒَا ڒخْمجْ ؤُ \add ونِّي\add* أَذْ \add أَنغْ\add* يڭّْ أَذْ نْبدّْ نِيشَانْ بْڒَا ڒْعِيبْ زَّاثْ إِ ؤُعُودْجِي نّسْ س ڒفْرَاحثْ  
\v 25 - أَقَا نتَّا ذ أَربِّي وحّْذسْ، أَمْسنْجمْ نّغْ - أَقَا إِ نتَّا د-إِتَّاسْ ؤُسمْغَارْ ذ ڒْعزّْ ذ شَّانْ ذ لْعَاضَامَا، أَمْ ڒخُّو أَمْ إِ ڒبْذَا قَاعْ. أَمِينْ. \x ◘ \xo 1:‏25 \xt رُوم. 16‏:‏27؛ 1 تِيم. 1‏:‏17. \x*   