\id EZR - Kuna, San Blas - Bible -Panama 2014 (DBL -2014)
\h Esdras
\toc1 Esdras-Garda
\toc2 Esdras
\toc3 Esd
\mt1 ESDRAS-GARDA
\mt2 ESDRAS
\imt2 GEBE-SOGLENAID
\imt1 Garda-nug
\ip \it Esdras-Garda.\it* Esdras, dule garda-narmaked-duled, degi, Israel-e-Bab-Dummad-Jehová Moisésʼba-Igar-uksa-gusad nue-wisbalid. \it Bab-Dummad-dule-bendakedye,\it* Esdras-nug obarileged.
\is1 Esdras-Gardagi weyob sunmaklenaid
\ip We-garda, Nehemías-gardabogwa soggwenna guenad. Neggusmaladi, ibagan-sekalaa-gusmarye sogleged. Amba emar-emargii sunmaklenai-inigwele, bur bule na e-ibmar-sogbiedgi akargusiid. Esdras odurdakedsailaye gin-sogleged. Bur Bab-Dummad-walikaa-gudigumalaga emar-odurdaksa gusad.
\ip We-gardagine, Persa-e-rey-Ciroʼgi iduakwaa sunmaklesgusad. We-reyde gebe-megided-birgagi, Cristo-idu birga-538ʼgi, Judíoʼmar-Babiloniaʼgi-bukwamaladga igar-uksagusad, gannar e-yarse namalagar. Judío-dulemar e-yarse-nonimargu, gannar Bab-Jehováʼga Jerusalén-neggweburse neg-sobnonimalad. Adi, Bab-Jehováʼse-gordii gumalagar.
\ip We-gardagine, weyob ilemakar sunmaklenaid:
\io1 1. Israel-dulemar gannar e-yarse-nadmalad (1:1–2:70).
\io1 2. Bab-Jehováʼse-goled-neg sobsamalad (3:1–6:22).
\io1 3. Esdras Jerusalén-neggweburse nonikid (7:1–8:36).
\io1 4. Esdras-e-arbaed (9:1–10:44).
\ip Be itogua.
\c 1
\ms1 1. ISRAEL-DULEMAR GANNAR E-YARSE-NADMALAD
\mr (1:1–2:70)
\s1 Rey-Ciro-igar-uksad
\r (2 Crónicas 36:22-23)
\p 
\v 1 Rey-Ciro, Persia-yar-e-reyga maigusad. Ciro-gebe-reyga-megided-birgagi, Bab-Jehová, Rey-Ciro-e-gwage ebusad, adi, bela e-yar-dakmaidgi igar-mesegar. Adi, we-igar-megoedba, nabir Bab-Jehová Jeremíasʼba gayaburba-sogsadba guegar. Degine, Rey-Ciro bela yar-ganikidgi igar-mesisad sogsa gusad, degi, gardagi-narmakar imaksabalid. Weyob sogsad:
\p 
\v 2 “Persia-rey-Ciro weyob soged:
\pi1 ” ‘Bab-Dummad-Jehová-Nibneggi-Maidi, anga we-napneg-dirbir-naidgi bela yarmar-nanaid uksad. Degi, anga sogsabalid, Judá-yargi Jerusalén-neggwebur-siidgi ese-goled-neg ega soboye.
\v 3 Degisoggu, anmar-abargi-Judá-dulemar-gudimalad Jerusalén-neggweburse be namar. Israel-dulemar-e-Bab-Dummad-Jehováʼga ese-goled-neg be sobnamar. We-Bab-Dummadde, Jerusalénʼgi maid. Degi, a-Bab-Dummad bemarba naena gadin.
\v 4 A-ukinbali, an igar-ukbardo, dule-bamaladi Judío-dulemar-amba-gudidimalad-bendakega we-ibmar ukmalo: Mani, olo, ibmar-nuegan, degi, e-ibmar-durgan ukmalo. De-ukinbali, dulemar Bab-Dummadga-ibmar-ukleged e-binsaedba Bab-Dummadse-goled-negga ukbalo.’ ”
\s1 Israel-dulemar gannar e-yarse nonimalad
\p 
\v 5 Degidgine, Judá-wagan-e-dummagan-neguya-sedimalad, Benjamín-wagan-e-dummagan-neguya-sedimalad, dule-irwa-Bab-Dummadse-gormalad, degi, Levita-dulemar, degi, Bab-Dummad bela dule-gwenna-gwenna-e-gwage-ebusmaladmala, amar Jerusalén-neggweburse Bab-Dummadse-goled-neg-sobnaega guakwaa ambikusmalad.
\v 6 Bela dulemar e-neg-nagaba-mamaimalad bendaksamarmogad. We-ibmarmar ega uksamalad: Mani, or, ibmar-nuegan, ibmar-durgan, degi, ibmar-gargerbamalad ega uksamalad. Deginbali, dulemar, bela ibmarmar-akar-akar e-binsaedba Bab-Dummadse-goled-negga uksamarbalid.
\v 7 Epenne, Jerusalénʼgi Bab-Jehováʼse-goled-neggi-ibmar-ebulemalad, Nabucodonosor Babiloniaʼse sear gusad. Geb e-bab-dummadse-goled-negse urbenoni gusad. Emide, a-ibmarmar Persa-rey-Ciro onisad.
\v 8 Degi, Persia-rey-Ciro, e-mani-daked-Mitrídatesʼga ibmar-onilesmalad uksad, adi, ebisegar. Bela ebichisgu, Judá-dulemar-e-dummad-Sesbasarʼga we-ibmarmar uksad.
\q1 
\v 9 Ar ibmar-ebislesmalad, wemalad:
\q2 Bate-dummagan-orbiid, gwadulagwen-gakambe (30).
\q2 Bate-dummagan-manibiid, miligwen (1,000).
\q2 Estin, gadulagwen-gakabakebak (29).
\q2 
\v 10 Nog-orbiid, gwadulagwen-gakambe (30).
\q2 Nog-manibiid, gwadulataled-ilabake gakambe (410).
\q2 Degi, ibmar-baigan-ebulemalad, miligwenba (1,000).
\p 
\v 11 Ibmar-ebulemalad-orbiid, degi, manibiid, bela miliatar gaka dulataled-ilabake-mergu (5,400) daklealid. Bela we-ibmarmar Sesbasar gannar Jerusalén-neggweburse sesa gusad, deun Judá-dulemarga soglesgu, bemar gannar Babilonia-neggweburgi-bukwad Jerusalén-neggweburse namaloye.
\c 2
\s1 Israel-dulemar gannar e-yarse-nonimalad-e-nugmar
\r (Nehemías 7:5-73)
\p 
\v 1 Babilonia-rey-Nabucodonosor, Judá-yargi dulemar-bukidar Babilonia-yarse sesa gusad. Geb a-sorba, ise barmiar Jerusalén-neggweburse imaksad, degi, Judá-yargi neggweburmar-bukwadse barmisbalid. Degine, dulemar na e-neggwebur-e-neggweburse nonigusmalad.
\q1 
\v 2 Dulemar-Zorobabelʼba-nonigusmaladi, wemalad:
\q2 Jesúa, Nehemías, Seraías,
\q2 Reelaías, Mardoqueo, Bilsán,
\q2 Mispar, Bigvai, Rehum, Baana.
\q1 Israel-dulemar e-yarse-nonimaladi, wemalad:
\q2 
\v 3 Paros-wagan, milibo gaka dulabaabak-gakambe-gakabo (2,172).
\q2 
\v 4 Sefatías-wagan, dulataled-ilapaa gaka dulapaa-gakambe-gakabo (372).
\q2 
\v 5 Ara-wagan, dulataled-ilagugle gaka dulapaa-gakambe-gakatar (775).
\q2 
\v 6 Pahat-Moab-wagan, a sogleged, Jesúa-e-waganye, degi, Joab-e-waganye, milibo gaka dulataled-ilabaabak gakambe-gakabo (2,812).
\q2 
\v 7 Elam-wagan, miligwen gaka dulataled-ilabo gaka dulabo-gakambe-gakabake (1,254).
\q2 
\v 8 Zatu-wagan, dulataled-ilabakebak gaka dulabo-gakatar (945).
\q2 
\v 9 Zacai-wagan, dulataled-ilagugle gaka dulapaa (760).
\q2 
\v 10 Bani-wagan, dulataled-ilanergwa gaka dulabo-gakabo (642).
\q2 
\v 11 Bebai-wagan, dulataled-ilanergwa gaka dulagwen-gakapaa (623).
\q2 
\v 12 Azgad-wagan, miligwen gaka dulataled-ilabo gaka dulagwen-gakabo (1,222).
\q2 
\v 13 Adonicam-wagan, dulataled-ilanergwa gaka dulapaa-gakanergwa (666).
\q2 
\v 14 Bigvai-wagan, milibo gaka dulabo-gakambe-gakanergwa (2,056).
\q2 
\v 15 Adín-wagan, dulataled-ilabake gaka dulabo-gakambe-gakabake (454).
\q2 
\v 16 Ater-wagan, a sogleged Ezequías-e-waganye, dulabake-gakambe-gakabaabak (98).
\q2 
\v 17 Bezai-wagan, dulataled-ilapaa gaka dulagwen-gakapaa (323).
\q2 
\v 18 Jora-wagan, dulatar-gakambe-gakabo (112).
\q2 
\v 19 Hasum-wagan, dulataled-ilabo gaka dulagwen-gakapaa (223).
\q2 
\v 20 Gibar-wagan, dulabake-gakambe-gakatar (95).
\q2 
\v 21 Belén-neggweburginmalad, dulanergwa-gakapaa (123).
\q2 
\v 22 Netofa-neggweburginmalad, dulabo-gakambe-gakanergwa (56).
\q2 
\v 23 Anatot-neggweburginmalad, dulanergwa-gakabaabak (128).
\q2 
\v 24 Azmavet-neggweburginmalad, dulabo-gakabo (42).
\q2 
\v 25 Quiriat-Jearim-neggweburginmalad, Cafiraʼginmalad, degi, Beerotʼginmalad, dulataled-ilagugle gaka dulabo-gakapaa (743).
\q2 
\v 26 Ramá-neggweburginmalad, degi, Gebaʼginmalad, dulataled-ilanergwa gaka dulagwen-gakagwensak (621).
\q2 
\v 27 Micmas-neggweburginmalad, dulanergwa-gakabo (122).
\q2 
\v 28 Betel-neggweburginmalad, degi, Haiʼginmalad, dulataled-ilabo gaka dulagwen-gakapaa (223).
\q2 
\v 29 Nebo-neggweburginmalad, dulabo-gakambe-gakabo (52).
\q2 
\v 30 Magbis-neggweburginmalad, dulagugle-gakambe-gakanergwa (156).
\q2 
\v 31 Elam-neggweburginmalad, miligwen gaka dulataled-ilabo gaka dulabo-gakambe-gakabake (1,254).
\q2 
\v 32 Harim-neggweburginmalad, dulataled-ilapaa gaka dulagwen (320).
\q2 
\v 33 Lod-neggweburginmalad, Hadidʼginmalad, degi, Onoʼginmalad, dulataled-ilagugle gaka dulagwen-gakatar (725).
\q2 
\v 34 Jericó-neggweburginmalad, dulataled-ilapaa gaka dulabo-gakatar (345).
\q2 
\v 35 Senaa-neggweburginmalad, milipaa gaka dulataled-ilanergwa gaka dulagwen-gakambe (3,630).
\q1 
\v 36 Dule-irwa-Bab-Dummadse-gormalad-nonimalad, wemalad:
\q2 Jesúa-gwenadgansikid Jedaías-wagan, dulataled-ilabakebak gaka dulapaa-gakambe-gakapaa (973).
\q2 
\v 37 Imer-wagan, miligwen gaka dulabo-gakambe-gakabo (1,052).
\q2 
\v 38 Pasur-wagan, miligwen gaka dulataled-ilabo gaka dulabo-gakagugle (1,247).
\q2 
\v 39 Harim-wagan, miligwen gakambe-gakagugle (1,017).
\q1 
\v 40 Levita-dulemar-nonimalad, wemalad:
\q2 Jesúa-wagan, degi, Cadmiel-wagan, a sogleged Hodavías-e-waganye, dulapaa-gakambe-gakabake (74).
\q1 
\v 41 Dule-namakmalad-nonimalad, wemalad:
\q2 Asaf-wagan, dulanergwa-gakabaabak (128).
\q1 
\v 42 Bab-Dummadse-goled-neg-yawagak-dakmalad-nonimalad, wemalad:
\q2 Salum-wagan, Ater-wagan, Talmón-wagan,
\q2 Acub-wagan, Hatita-wagan, degi, Sobai-wagan.
\q3 Amar, dulanergwa-gakambe-gakabakebak (139) mergued.
\q1 
\v 43 Bab-Dummadse-goled-neggi-arbamalad, wemalad:
\q2 Ziha-wagan, Hasufa-wagan, Tabaot-wagan,
\q2 
\v 44 Queros-wagan, Siaha-wagan, Padón-wagan,
\q2 
\v 45 Lebana-wagan, Hagaba-wagan, Acub-wagan,
\q2 
\v 46 Hagab-wagan, Salmai-wagan, Hanán-wagan,
\q2 
\v 47 Gidel-wagan, Gahar-wagan, Reaía-wagan,
\q2 
\v 48 Rezín-wagan, Necoda-wagan, Gazam-wagan,
\q2 
\v 49 Uza-wagan, Paseah-wagan, Besai-wagan,
\q2 
\v 50 Asena-wagan, Meunim-wagan, Nefusim-wagan,
\q2 
\v 51 Bacbuc-wagan, Hacufa-wagan, Harhur-wagan,
\q2 
\v 52 Bazlut-wagan, Mehída-wagan, Harsa-wagan,
\q2 
\v 53 Barcos-wagan, Sísara-wagan, Tema-wagan,
\q2 
\v 54 Nezía-wagan, degi, Hatifa-wagan.
\q1 
\v 55 Salomónʼga-arbamalad-e-wagan, wemalad:
\q2 Sotai-wagan, Soferet-wagan, Peruda-wagan,
\q2 
\v 56 Jaala-wagan, Darcón-wagan, Gidel-wagan,
\q2 
\v 57 Sefatías-wagan, Hatil-wagan,
\q2 Poqueret-Hazebaim-wagan, degi, Ami-wagan.
\q3 
\v 58 Bab-Dummadse-goled-neggi-arbamalad-e-wagan, degi, Salomónʼga-arbamalad-e-wagan, bela dulataled-ilapaa gaka dulabake-gakambe-gakabo (392) mergued.
\p 
\v 59 Deginbali, dulemar-baigan geg oyo gusmalad, doamar e-dadganmala, degine, emarde bule-nabir Israel-dule-gumarbali.
\q1 We-neggweburmargi noar gusmalad:
\q2 Tel-Mela-neggweburgi, Tel-Harsa-neggweburgi,
\q2 Querub-neggweburgi, Addán-neggweburgi,
\q2 degi, Imer-neggweburgi noarmaladid.
\q1 
\v 60 A-dulemarde, wemalad:
\q2 Delaía-wagan, Tobías-wagan, Necoda-wagan,
\q3 bela dulataled-ilanergwa gaka dulabo-gakambe-gakabo (652) mergued.
\p 
\v 61 Dule-irwa-Bab-Dummadse-gormalad abala geg oyo gusmarmogad, doamar e-dadganmala, emarde bule-nabir Israel-dule-gumarbali.
\q1 Amala, wemalad:
\q2 Habaía-wagan, Cos-wagan, degi, Barzilai-wagan.
\p Ar ade, dule, Barzilai-Galaadʼgined-e-sisgwa nikus gusad. Degidbali, a-dule e-sakba Barzilaiʼye nuggunonikid, degi, e-wagan Barzilai-waganye bilenonikid.
\v 62 Wemala na e-dadgan-nug amidmargu, amissurgusmalad. Degisoggu, dule-swilidiksulid-soglesadba, dule-irwa-Bab-Dummadse-goledga onolesmalad.
\p 
\v 63 Degidgine, dule-dummadga-negdakmaid igar-uksad, we-dulemar melle Bab-Dummadga-ibmar-ukleged gunnamaloye, dule-irwa-Bab-Dummadse-goled-gwensak, Urimʼba, degi, Tumimʼba Bab-Dummadse idakedseye.
\p 
\v 64 Bela dulemar dule-wargwennayob danar-ambikunonimaladi mili-dulabo-gakabo gaka dulataled-ilapaa gaka dulapaa (42,360) mergued.
\v 65 Wemar-abargi e-mai-machergan, degi, e-mai-omegan, miligugle gaka dulataled-ilapaa gaka dulagwen-gakambe-gakagugle (7,337) mergueddi obarlesulid. Degine, e-namakmalad-machergan, e-namakmalad-omegan, dulataled-ilabo (200) mergu-nikaddi obarlesurbalid.
\q1 
\v 66 A-ukinbali, dulemar-gannar-nonimaladi, ibmar-durgan-ibmar-semalad, weyob nikamalad:
\q2 Moli, dulataled-ilagugle gaka dulagwen-gakambe-gakanergwa (736).
\q2 Moli-uaya-senigwadmar, dulataled-ilabo gaka dulabo-gakatar (245).
\q2 
\v 67 Moli-yargan-muremalad, dulataled-ilabake gaka dulagwen-gakambe-gakatar (435).
\q2 Moli-uayasuid, milinergwa gaka dulataled-ilagugle gaka dulagwen (6,720) nikamalad.
\p 
\v 68 Gwenna-gwenna babgan-neguya-sedimaladi, Jerusalén-neggweburgi Bab-Jehováʼse-goled-neg-siidse nonimalad. Agine, na e-binsaed-e-binsaedba ibmar-nuegan Bab-Dummadse-goled-negga uksamalad, adi, Bab-Jehováʼse-goled-neg gebe-iduar-sii-gusadgi gannar sobegar.
\v 69 Degine, dulemar e-ganguedba, Bab-Dummadse-goled-neg-soblenaid-e-mani-dakedga ibmar uksamalad.
\q1 A-ibmarmar wemalad:
\q2 Or, nibir-miligwen gaka dulatar aidiku (1,100) uksamalad.
\q2 Mani, nibir-milinergwa aidiku (6,000) uksamarbalid.
\q2 Degine, dule-irwa-Bab-Dummadse-gormalad-e-mormar, goadulatar (100) uksamarbalid.
\p 
\v 70 Degine, dule-irwa-Bab-Dummadse-gormaladi, Levita-dulemar, dule-namakmaladi, degine, dulemar-bamaladi, Jerusalénʼgi megismalad. Degi, dule-yawagak-dakmaladi, dule-Bab-Dummadse-goled-neggi-arbamaladi, e-neggwebur-e-neggweburgi megismalad. Degine, bela Israel-dulemar-baigan na e-neggwebur-e-neggweburgi megis nanaed.
\c 3
\ms1 2. BAB-JEHOVÁʼSE-GOLED-NEG SOBSAMALAD
\mr (3:1–6:22)
\s1 Ibmar-ogumakar-ukleged-aila soblesad
\p 
\v 1 Bela Israel-dulemar nii-walaguglegus (7) bato e-neggwebur-e-neggweburgi mamaimaladgi, Jerusalén-neggweburgi bulakwaa dule-soggwennayobi ambikunonimalad.
\v 2 Degidgine, dule-irwa-Bab-Dummadse-goled-Jesúa Josadac-e-machi, na e-gwenadgan-dule-irwa-Bab-Dummadse-gormaladbo, degi, Salatiel-machi-Zorobabel, na e-gwenadganmala, Israel-e-Bab-Dummadga ibmar-ogumakar-ukleged-aila sobdemalad. Adi agine, Israel-dulemar-e-Bab-Dummadga ibmar-ogumakar ukmalagar. Igi Bab-Dummad-e-mai-Moisés-e-Igar narmakar-mai, deyob gusad.
\p 
\v 3 Ar Israel-dulemar, dulemar-baid-baid-bukwadgi nue-dobe ito-inigwele, Bab-Dummadga-ibmar-ogumakar-ukleged-aila gebe-iduar-sii-gusadgine gannar sobsamalad. Geb bane-bane wakdaradba, sedogidba, ibmar-ogumakar-ukleged, Bab-Jehováʼga-ibmar-ogumakar-ukleged-ailagi ukdemalad.\fig Israel-dulemar Jerusalén-neggwebur-oichosadse gannar-nonigu, Babse-ibmar-ukleged-aila gannar sobsamalad. (Esdras 3:3) |src="CO01246B.TIF" size="col" ref="Esdras 3:3"\fig*
\p 
\v 4 Deyobi, Igar-narmakar-sogmaidbali Neg-Matargana-Sobaled-E-Iba-islidikid onosmalad. A-iba-onolegedgi, gusgu-bane-bane-ibmar-uklegedba Bab-Dummadga ibmar-ogumakar-ukleged-bukidar uksamalad.
\p 
\v 5 A-ukinbali, gusgu ibmar-ogumakar-ukleged Bab-Jehováʼga ukdamalad, degi, nii-gwapid-yoleged-irba ibmar-ogumakar-ukleged uksamarbalid. Geb degine, Bab-Jehováʼga iba-dummagan-onolegedgi-ibmar-ukleged uksamarbalid. Degi, dule na-e-binsaedba, Bab-Jehováʼga ibmar-ukleged uksamarbalid.
\v 6 Amba-yoo Bab-Jehováʼse-goled-neg-e-saila-sobleda-inigwele, gebe-nii-walagugled (7) gwisgusadgi, dulemar Bab-Jehováʼga ibmar-ogumakar-ukleged ukdemalad.
\s1 Bab-Dummadse-goled-neg sobleded
\p 
\v 7 Geb agine, akwa-neg-sobedgi-arbamaladga, urgo-sobedgi-arbamaladga mani uksamalad. Sidón-dulemarga, Tiro-dulemarga, gobed, masi, olivo-gwallu uksamalad, adi, Ciro Persia-yar-e-rey, a-igar-uksadba, wemar nabir urwar-urgo Líbano-yar-akale, demarba, Jope-neggweburse sedamalagar.
\p 
\v 8 Israel-dulemar birgabogus Jerusalén-neggweburse-nonimaladgine, a-nii-warbogi Bab-Dummadse-goled-neg sobbarmalad. Salatiel-machi-Zorobabel, Josadac-machi-Jesúa, degi, na e-gwenadgan-dule-irwa-Bab-Dummadse-gormalad-abargi, degi, Levita-dulemarmala, degi, dule-galesgusmalad-Jerusalénʼse-nonimalad-abargi Bab-Jehováʼse-goled-neg sobdemalad. Levita-dulemar birga-dulagwen (20) nikamaladi, degi, birga-durgwen-obine (20+) nikamaladi, Bab-Jehováʼse-goled-neg-soblenaid-dakedga nugsasmalad:
\q1 
\v 9 Degidgine, Jesúa, e-masmalamala,
\q2 degi, e-gwenadganmala arbadmalad.
\q1 Degine, Judá-dule-Cadmiel, e-masmalamala arbadmalad.
\q2 Amardi, Hodavías-e-waganad.
\q1 Degine, Henadad-e-wagan, e-masmalamala,
\q2 degi, e-gwenadganmala arbadmalad.
\q3 Bela-a-dulemar, Levita-dulemalad. Amala, bulale dule-wargwennayobi dulemar-Bab-Dummadse-goled-neggi-arbananaid-dakega arbadmalad.
\p 
\v 10 Dule-akwa-neg-sobedgi-arbamalad Bab-Jehováʼse-goled-neg-e-saila mesismargu, dule-irwa-Bab-Dummadse-gormalad na e-mor yoyoidbi, gar-trompeta gani-gani gwisguarmalad. Degine, Asaf-wagan-Levita-dulemardi, gar-címbalo-abin-abin-gormalad gani-gani gwisguarmarmogad, igi Israel-rey-David, igar-uksagusadyob, Bab-Jehová-nug odummogegar.
\v 11 Bela namakdemalad, Bab-Jehová-nug ogannodmalad, degine, Bab-Jehováʼga dog-nuedye sogdemalad, degi, baigandi sogdemalad:
\q1 “Bab-Jehová bela-belad dule-nuedid,
\q2 wile Israel-dulemar-dakmai degisadeguad.”
\p Bela dulemar weligwaledba oimakdemalad, degine, Bab-Jehová-nug ogannodmalad. Ar ade, Bab-Jehováʼse-goled-neg-e-saila megis dakmalad.
\p 
\v 12 Bukidar dule-irwa-Bab-Dummadse-gormalad, Levita-dulemar, degi, babgan-neguya-sedimalad bato selebagusmalad. Amala, gebe-Bab-Jehováʼse-goled-neg-soblesad daksamalad. A-ulale, Bab-Jehováʼse-goled-neg gannar soblenai dakarmarbargu, bela-belad binnasuli ise-boale bodmalad. Baigandina, weligwaledba binnasuli oimakbukwad.
\v 13 Dulemar oimakbukwadbali, dulemar-bobukwad itolesulid, ar ade, dulemar ise-gandikidba oimakbukwad, degine, e-oimakedi dikasuli-bannabaa itoleged.
\c 4
\s1 Bab-Dummadse-goled-neg-soblenaid galesad
\p 
\v 1 Judá-dulemar-e-isdarmalad, degi, Benjamín-dulemar-e-isdarmalad wisguarmargu, dulemar-galesgusmalad gannar e-neggweburse-nonimaladi, Israel-e-Bab-Dummad-Jehováʼse-goled-neg sobnanaiye.
\v 2 Geb agine, a-isdarmalad Zorobabelʼse, degi, Israel-dulemar-neguya-sedimalad-e-dummaganse nonimalad, ega weyob sognonimalad:
\p —Anmar Bab-Dummadse-goled-neg bemarba sobbimarmodo. Ar ade, bemar-Bab-Dummad-nug-odummodiid, a-Bab-Dummad-nug anmar odummodimarmogad. Asiria-rey-Esar-Hadón we-yarse anmar-senonikid-akale, be-Bab-Dummadga ibmar-ogumakar-ukleged anmar ukdimogad.
\p 
\v 3 Geb degine, Zorobabel, Jesúa, degi, Israel-dulemar-neguya-sedimalad-e-dummagan, abin-sogdemalad:
\p —Suli. Anmarba be Bab-Dummadse-goled-neg-sobega anmar be-abesuli. Ar anmarbi, Israel-dulemar-Bab-Dummadga, Bab-Jehováʼse-goled-neg soboed. Ar igi Persa-yar-e-rey-Ciro, anmarga igar-uksadba.
\p 
\v 4 Degidgine, Judá-yar-dikarba-dulemar-bukwad, Judá-dulemar-niga-egwannega ese urwenonimalad, degine, ogwakismalad, adi, mer bar Bab-Dummadse-goled-neg-sobnanai gumalagar.
\v 5 A-ukinbali, a-dulemar, dule-binsaed-dakmalad-gwenna-gwenna manigi binsaed-gasbalid, adi, Bab-Dummadse-goled-neg-soblenaid galegegar. Ciro, Persia-yar-e-reyga maigusad-akale, Persia-yar-e-rey-Darío-megis-gusadse, deyob gusad.
\s1 Judío-dulemargi-gwisgulenonikid
\p 
\v 6 Deginbali, Rey-Asuero gebe reyga megnonigua, Judá-dulemar-e-isdarmalad, reyse garda narmakar barmismalad. Judá-dulemargi, degi, Jerusalén-dulemargi, yamo ise-yolegar egi sunmaksamalad.
\p 
\v 7 Geb sorba, Artajerjes, Persa-dulemar-e-reyga megnonikid. A-ibagangine, amba deyob Bislam, Mitrídates, Tabeel, degi, e-sordamar-baigan, Rey-Artajerjesʼse garda narmaksamarmogad. A-garda, Arameo-gayaba narmaklesad, geb Persa-gayaba odulolesad.
\p 
\v 8 A-ukinbali, dule-dummad-neg-dakmaid-Rehum, degi, dule-garda-narmaked-Simsai, Rey-Artajerjesʼse garda narmakar barmismalad. A-gardagi Jerusalén-dulemargi ise-yolegar sunmaksamalad.
\p 
\v 9 Dule-dummad-neg-dakmaid-Rehum, degi, dule-garda-narmaked-Simsai, we-garda narmaksad.
\q1 Deginbali, we-e-sorda-bakamalad we-gardagi e-goo-burba mesismalad:
\q2 Dule-igar-nabiromalad,
\q2 saila-dummagan,
\q2 dule-dummagan,
\q2 Persaʼginmalad,
\q2 Erecʼginmalad,
\q2 Babiloniaʼginmalad,
\q2 degi, Elam-dulemar Susaʼginmalad.
\p 
\v 10 We-gardagi, dule-baigan e-goo-burba mesismarmogad. Epenne, dule-dummad-dule-nug-nikad-Asnapar, we-dulemar-gasa-sesa-gusad, geb Samaria-yalagangi oambikudap gusad, degi, Éufrates-diwar-dad-argwanedsik neggweburmar-baigangi oambikudap gusbalid. Bela amala we-gardagi e-goo-burba mesismarmogad. We-gardagi weyob sogsiid:
\pi1 
\v 11 “Rey-Artajerjes, be-maimar Éufrates-diwar-dad-argwanedsik-bukmalad bega sogsiid:
\pi1 
\v 12 ”Rey, na be wisguega, anmarse be Judío-dulemar-barmialidi, Jerusalén-neggweburse nonimalad. Emide, we-dulemar we-neggwebur-isgana, degi, beba-ibmar-imaksulid, gannar sobnanaid. Bato neggwebur-e-saila mesisbinmalad. Degine, we-neggwebur-e-galu-matusulid gannar sobnanaimalad.
\pi1 
\v 13 ”A-ukinbali, Dummad, an be-owisobardo, ar bela galu-matusulid-ogusmalale, degi, gandik neggwebur-sigisale, wemar begi gwisgudamaloed, gwen mani-galeged bennukosurmalad, neggweburga-mani-weleged ukosurmarbalid, degi, ibmar-ebumaloed gwen bennukosurmarbalid. Degisoggu, reyga bar manimar ubogosulid.
\v 14 Ar anmar be-neggi bega-arbamaladsoggu, geg anmar be-nug-mesagwar imaked. Agala, be-owisogega, anmar bega garda barmisimalad.
\v 15 Dummad, be-garda-bukwadgi, be-sergan-e-gardamar-mamaidgi be e-igar amisale, a-gardagi we-dulemar-ibmar-imaksamalad be dakdagoed. Agi, be wisguoed, we-Jerusalén-dorgande bela-bela galagwensuli gudii gusad, degi, reymargi, neggwebur-bamaladgi yoledii gusad. Degi, dikasurgus we-neggweburginmaladde reymargi gwisgudii gusmalad. A-ulale, we-neggweburde bela oitoles gusad.
\v 16 Rey, a-ulale, an bega sogdo, we-neggwebur gannar soblesdibele, e-galu-matusulid-bela-ogulesale, neggweburmar-Éufrates-diwar-dad-argwanedsik-bukwadi bar begadga guosulid.”
\p 
\v 17 Geb degi, rey abin-sogsamogad:
\pi1 “Ani, Rey-Artajerjes, an bemarse garda barmisimogad:
\q2 Dule-dummadga-negdakmaid-Rehum,
\q2 dule-garda-narmaked-Simsai,
\q2 geb bela e-sordamar-Samaria-neggweburgi-bukmalad,
\q2 degi, dule-baigan Éufrates-diwar-dad-argwanedsik-bukmalad: ‘Bemar nued sogeye.’
\pi1 
\v 18 ”Bemar, anga garda-barmiarmaladi, bela ise-mag-itoleale anga absolesad.
\v 19 Degine, Jerusalénʼginmalad-e-igarmar-amiega an igar uksad. Agi, daklealid, we-neggweburginmaladde dikasurgusa bato reymar-baigangi gwisgudimala, a-sogedba igar-imakdisurmala, gusgu na urwed-onodii damala.
\v 20 Degine, Jerusalén-neggweburgine, reymar-gangued-nikmaladi megis nanae. We-reymar bela yarmargi Éufrates-diwar-dad-argwanedsiki, e-ganguedba negsemamai gusmala. Degine, daklearbalid, dulemar neggwebur-bennuklegedi ega ukdii gusmala, neggweburga-mani-weleged ega ukdii gusmala, degi, neg-mamaid-bennukdii nanasmala.
\v 21 Degisoggu, an sogdo, we-dulemarga be-sogmalo, melle bar arbamaloye, melle bar we-neggwebur-sobmaloye, ani an gannar igar-ukedse.
\v 22 Degisoggu, an bega-we-igar-ukedi melle be ieged-imakmalo, adi, melle anga boni-dummad onogega, melle an-mani-bukwad galakuega.”
\p 
\v 23 Rey-Artajerjes-garda-barmialidi Rehum-asabin, dule-garda-narmaked-Simsai-asabin, degi, e-sorda-bamalad-asabin absolesgu, bela Jerusalén-neggweburse duurmakdemalad. Geb sabsur-urwedigine, Judío-dulemar-neg-sobnanaidi ganonimalad, mer bar neg-sobmalagar.
\v 24 Weyob, Rey-Darío, Persa-yargi birgabogus negsemai-gusadse, Bab-Dummadse-goled-neg Jerusalén-neggweburgi-soblenaidi galesad.
\c 5
\s1 Bab-Dummadse-goled-neg gannar sobleded
\p 
\v 1 Bab-Dummad-gayaburba-barsogmalad Hageo, degi, Iddo-wagwa-Zacarías, amar Judíoʼmar Judá-yargi-gudimaladga, degi, Jerusalénʼginmaladga, Israel-dulemar-e-Bab-Dummad-nuggi, Bab-Dummad-gayaburba barsognai guarmalad.
\v 2 Degidgine, Salatiel-machi-Zorobabel, degi, Josadac-machi-Jesúa, Bab-Dummadse-goled-neg Jerusalén-neggweburgi-siid gannar sobdemalad. Agine, Bab-Dummad-gayaburba-barsogmalad, we-dummaganba gudii gusad, degine, amar-bendakdii gusad.
\p 
\v 3 Amba a-ibagangine, Tatnai, Éufrates-diwar-dad-argwanedsik dummadga-negdakmaidi, degi, Setar-Boznai, degi, e-sordamarmala Judío-dulemarse modapid, geb ese egichidmalad: “¿Doa bemarga igar-uksa, we-Bab-Dummadse-goled-neg sobega, e-galumar sobega?”
\v 4 Degine, ese egichismarbalid: “Dulemar-neg-sobnanaid-e-idumalad, ¿we igi nugmala?”
\v 5 Ar Bab-Dummad Judío-dulemar-e-dummagan nue-bendakmaisoggu, dummagan-negdakmamaid Rey-Daríoʼse neg-soblenaid-garda-barmidedse, geb rey-e-abin-imakedse, Judíoʼmar neg-sobnanaid gwen indaksasurmalad.
\v 6 Geb Tatnai Éufrates-diwar-dad-argwanedsik dummadga-negdakmaidi, degi, Setar-Boznai, degi, e-sordamar Éufrates-diwar-dad-argwanedsik-dummaganga-negdakmamaidi, Rey-Daríoʼse garda barmismalad.
\v 7 Garda wegii sogsiid:
\pi1 “Rey-Darío, bitigine be nued-gudina gadin.
\pi1 
\v 8 ”Rey, anmar na be-owisosun, anmar Judea-yalase arbimalad, Bab-Dummad-Dule-Dummad-e-negse. A-nega, akwa-dummagangi soblenaid, degi, bato urgomar e-galu-dikargi nasiklenaid, e-arbalenaidi nue-nasgumaid, gwae-gwae arbalenaid.
\pi1 
\v 9 ”Geb degi, anmar e-dummaganse egichismalad: ‘¿Doa bega igar-uksamala we-Bab-Dummadse-goled-neg be sobmaloye, e-galumar be sobmarbaloye?’
\v 10 Deginbali, anmar ese egichisbalid, dule-arbananaid-e-dummagan igi-nugmarye, adi, bese gardagi-narmakar barmidegar.
\pi1 
\v 11 ”Geb Judío-dummagan anmar-abin-imaksamalad:
\pi1 ” ‘Anmar Bab-Dummad-Nibneg-Dakmaid-e-mai, degi, Napneg-Dakmaid-e-mai gumalad. Anmar Bab-Dummadse-goled-neg dikasurgus birgabargus-soblesgusad, anmar gannar sobnanaid. A-neg, Israel-dulemar-e-rey-gandikidi bela ogus gusad.
\v 12 Ar anmar-dadgan Bab-Dummad-Nibneg-Dakmaid-oulusgussoggu, Bab-Dummad, Babilonia-rey-Nabucodonosorʼga Caldeo-dulega, anmar-dadgan-urmaksasunnad. A-rey a-Bab-Dummadse-goled-neg earis gusad. Geb agine, Babilonia-yarse, dulemar-gasa sesa gusad.
\pi1 
\v 13 ” ’Geb a-sorba, Babilonia-dulemar-e-rey-Ciro, gebe reyga-megided-birgagine, Bab-Dummadse-goled-neg gannar soblegega igar uksad.
\v 14 A-ukinbali, epenne Nabucodonosor Jerusalén-neggweburgi Bab-Dummadse-goled-neggi ibmarmar-ebuleged-orbiid, manibiid, Babilonia-dulemar-e-bab-dummadse-goled-negse sesagusad. A-ibmarmar, Rey-Ciro onisad. Geb Rey-Ciro Sesbasarʼga, Judá-yar-e-dummadga-nug-imaksadga a-ibmarmar uksagusad.
\v 15 Degine, Rey-Ciro Sesbasarʼga sogsad: We-ibmar-ebulemalad be sue, be nae, Jerusalén-neggweburgi Bab-Dummadse-goled-neg-siidse gannar be sede. Gannale Bab-Dummadse-goled-neg be sobo, bia-gebe-iduar-sii-gusadgi.
\v 16 Geb degi, Sesbasar Jerusalén-neggweburse nonisunnad. Geb Bab-Dummadse-goled-neg-e-saila mesnonikid. Emide, emi-ibase amba-soblenaid, amba yoo ogule naid.’
\pi1 
\v 17 ”Rey, ar be nabir-itogele, Babilonia-e-reymar-ibmar-imaksad-gardagi igar-maid be-amiodo. Be adi dakegar, bule-nabiri Rey-Ciro Judío-dulemarga igar-uksagusa, Jerusalén-neggweburgi Bab-Dummadse-goled-neg gannar-sobegar. De-ukinbali, be anmar-owisogodo, igi we-igarsik be nue-binsamoga. Be itogua.”
\c 6
\s1 Rey-Ciro-garda-maid amilesad
\p 
\v 1 Geb degine, Rey-Darío igar-uksad, Babilonia-yargi-ibmar-nuegan-saboleged-neggi gardamar-sabolegedgi, garda-mamaid amioye.
\v 2 Degi, Acmeta-neggweburgi, reyneg-gandikidgi garda amilesad. Acmeta-neggweburde Media-yargi siid. A-gardagi weyob narmakar naid:
\pi1 
\v 3 “Rey-Ciro gebe reyga-megided-birgagi, e-sunnad, Bab-Dummadse-goled-neg Jerusalénʼgi-siid-sobega, Judío-dulemarga igar-uksad: Bab-Dummadse-goled-neg Jerusalén-neggweburgi-sii-gusanad be gannar sobmar, e-neg-saila be mesmar. Adi agine, Bab-Dummadga ibmar-ogumakar ukmalagar. We-nega-e-nibguedi daliambe-gakatar-sugu (15) be imako, degi, e-yaadungued amba deyob be imakbalo.
\v 4 Degine, akwa-dummagan ile-sogapaa be sobmalo, degi, urgodi ile-wargwen sobmarbalo. We-ibmarmar-baklegoedi, rey-manigi bela bennuklegoed.
\v 5 A-ukinbali, Jerusalénʼgi Bab-Dummadse-goled-neggi ibmarmar-ebuleged-orbiid, degi, manibiid, Nabucodonosor-Babiloniaʼse-sesa-gusadi be gannar Jerusalénʼse sedamalo. Degi, ibmar gannar e-ambikuedgi Bab-Dummadse-goled-neg-Jerusalénʼgi be urbemalo.”
\s1 Rey-Darío igar-uksad
\p 
\v 6 Degidgine, Rey-Darío, Tatnaiʼga igar-uksasunnad. Tatnaiʼde, Éufrates-diwar-dad-argwanedsik dummadga-negdakmaid. Degine, Setar-Boznaiʼga, degi, e-sordamar-dummadga-negdakmamaidga, weyob igar-uksad:
\pi1 “Jerusalén-dulemargi be bangumar.
\v 7 Melle Bab-Dummadse-goled-neg-soblenaidi, be igar-gamalo. Baisuli, na e-itomaladba Judío-dulemar-e-dummad-negsemaid, degi, girmar-dummagan, na e-sordagan-bulakwaa Bab-Dummadse-goled-neg, gebe-iduar-sii-gusadgi sobmaloed.
\pi1 
\v 8 ”Deginbali, an igar ukbalid: Bemar, Judío-girmar-dummagan-bendakmalo, adi, nabir bemar Bab-Dummadse-goled-neg sobnai guegar. Dulemar-Éufrates-diwar-dad-argwanedsik-bukmalad neggweburgi-mani-bennuklegedgi rey-bennukdamalad. A-mani, Judío-dulemarga iba-sogedba be ukmalo, adi, ibmar-baklesmaladi bennukegar. Deyobsulile, Bab-Dummadse-goled-neg-soblenaidi galegoed.
\v 9 A-ukinbali, bemar bane-bane ibmar-ukoed: Moli-bebe-nikad-sapingana, sibad-wawaad-machergan, sibad-wawaad-sapingana be ukmalo. Adi, Bab-Dummad-Nibneg-Dakmaidga ogumakar ukegar. Deginbali, dule-irwa-Bab-Dummadse-gormalad-Jerusalénʼgi-bukmalad-sogedba, orosgi-dakleged-trigoʼdibe, baludibe, vinoʼdibe, igi, olivo-gwalludibe, bemar ukbaloed. Melle ukesuli be gumalo.
\v 10 Ar deyobi, wemar-Babse-gormalad, nabir Bab-Dummad-Nibneggi-Maidga yeer-itogedgi ibmar-ogumakar-ukleged ukmaloed, degi, Bab-Dummadse anga-gormaloed, degi, an-masmalaga gormarbaloed.
\pi1 
\v 11 ”Degine, an igar ukbalid: Doa-dule, an igar-uksadba dasulile, a-dule-ibe, e-neg-nagubir ungilegoed. Geb a-dule a-nagubir-swiswidikidgi yolegar nasiklegoed. Geb, bela e-neg eyarlegoed.
\v 12 Bela reymar, igi, dulemar-yar-baid-baidgi-bukmaladi, we-igar-an-mesnaid oakalobimalale, Bab-Dummad-Jerusalén-neggweburgi-maidi a-dulemar-obelosun. Deginbali, Bab-Dummadse-goled-neg Jerusalén-neggweburgi-siid e-yarbimalale, a-dulemar-obelobarsun.
\pi1 ”Ani, Rey-Darío, an we-igar mesisad. Degisoggu, we-igar-maid-sogedba be nuekwa damalo.”
\s1 Bab-Dummadse-goled-neg ogulesad
\p 
\v 13 Geb degi, Tatnai Éufrates-diwar-dad-argwanedsik dummadga-negdakmaidi, degi, Setar-Boznai, degi, e-sordaganmala, Rey-Darío-igar-uksadba nue-inniki imaksamarsunnad.
\v 14 Igi Bab-Dummad-gayaburba-barsoged-Hageo, degi, Iddo-wagwa-Zacarías-sogsagusa, deyobi Judío-dulemar-e-dummagan, Bab-Dummadse-goled-neggi-arbalenaid-nasomai gusmalad. Deyobi, Bab-Dummadse-goled-neggi-arbalenaid obelosmalad. Israel-dulemar-e-Bab-Dummad-sogsagusadba, degi, Persa-yar-e-reymar: Ciro, Darío, Artajerjes, we-reymar-igar-uksadba, Bab-Dummadse-goled-neg bela ogulesad.
\v 15 Rey-Darío birga-nergwagusa (6) negdakmaidgi Bab-Dummadse-goled-neg ogulesad, Adar-nii-gwichid-ibapaagi.
\p 
\v 16 Degidgine, Israel-dulemar: Dule-irwa-Bab-Dummadse-gormalad, Levita-dulemar, dule-baigan-gales-gannar-nonimalad, amar weligwaledgi Bab-Dummadse-goled-neg-soblesadi, Bab-Dummadga nug-imaksamalad.
\q1 
\v 17 We-neg Bab-Dummadga nug-imaksamaladgi, Bab-Dummadga we-ibmar-durgan ogumakar uksamalad:
\q2 Moli-bebe-nikad-sapingana, waladulatar (100).
\q2 Sibad-wawaad-machergan, waladulataled-ilabo (200).
\q2 Sibad-wawaad-sapingwagwad, waladulataled-ilabakebar (400).
\q2 Degi, Israel-dulemar e-dadgan-warambe-gakabogwad-iliba (12),
\q2 e-isgued-ular, na war-wargwen sibad-machergan, warambe-gakabo (12) uksamarbalid.
\p 
\v 18 Geb degine, dule-irwa-Bab-Dummadse-gormalad e-arbaed-imakega urbilesad, degi, Levita-dulemar amar e-ibmar-imakedgi-bendakega urbilesmogad, adi, Jerusalén-neggweburgi Bab-Dummadse-goled-neggi Bab-Dummadga arbamalagar. Igi Moisés-gardagi-narmakar-nai, deyob gusad.
\s1 Israel-dulemar Oburgwilegoenad-Iba onosad
\p 
\v 19 Dulemar-galesgusmalad Jerusalén-neggweburse-gannar-nonimaladi, gebe nii-onoded-ibambe-gakabakegi, Oburgwilegoenad-Iba onosmalad.
\v 20 Ar dule-irwa-Bab-Dummadse-gormalad, Levita-dulemar dule-wargwennayobi bato na san-uruksamalad, bela na swilidik-gusmalad. Degisoggu, Levita-dulemar, Israel-dulemar-gales-gannar-noni-gusmaladga, Oburgwilegoenad-Ibagi gusgu sibad-wawaad-sapingwagwad-oburgwedamalad, oburgwismalad. Degi, Levitaʼmar, dule-irwa-Bab-Dummadse-gormaladga, degine, na e-nuki oburgwismarmogad.
\v 21 Israel-dulemar-galesgusmalad gannar Jerusalén-neggweburse-nonimaladi, Oburgwilegoenad-Ibagi sibad-wawaad-sapingwagwad guchamalad. Amar-abargi, dule-baigan Israel-Bab-Dummad-Jehová-igarba-nanaega, dulemar-galagwensulidaedgi-bangusmaladi, a-mas guchamarmogad.
\v 22 Judíoʼmar, ibagugle (7), Madu-Inasuli-Gulleged-Iba weligwaledba onosmalad. Ar ade, Bab-Jehová, Asiria-dulemar-e-rey Israel-e-Bab-Dummadse-goled-neg gannar-sobega imaksadba, yeer-itosmalad.
\c 7
\ms1 3. ESDRAS JERUSALÉN-NEGGWEBURSE NONIKID
\mr (7:1–8:36)
\s1 Esdras Jerusalén-neggweburse nonikid
\p 
\v 1 Bela we-ibmarmar-gusad-sorbali, Artajerjes Persa-dulemar-e-rey, yar-semaiunni, dule-wargwen gudii gusad.
\q1 A-dulede, Esdrasʼye nugad.
\q2 Esdras, Seraías-e-machi. Seraía, Azarías-e-machi.
\q2 Azarías, Hilcías-e-machi.
\v 2 Hilcías, Salum-e-machi.
\q2 Salum, Sadoc-e-machi. Sadoc, Ahitob-e-machi.
\q2 
\v 3 Ahitob, Amarías-e-machi. Amarías, Azarías-e-machi.
\q2 Azarías, Meraiot-e-machi.
\v 4 Meraiot, Zeraías-e-machi.
\q2 Zeraías, Uzi-e-machi. Uzi, Buqui-e-machi.
\q2 
\v 5 Buqui, Abisúa-e-machi. Abisúa, Finees-e-machi.
\q2 Finees, Eleazar-e-machi. Eleazar, Aarón-e-machi.
\q2 Aarónʼde, gebe dule-irwa-Bab-Dummadse-goledga gusadid.
\p 
\v 6 We-Esdras Babilonia-neggwebur-akar nonikid. A-dule, dule garda-narmaked-duled, degi, Israel-e-Bab-Dummad-Jehová Moisésʼba-Igar-uksa-gusad nue-wisbalid. Ar Israel-e-Bab-Dummad-Jehová Esdrasʼba nue gudigusoggu, Rey-Artajerjes, Esdras ese-ibmar-egichisadi bela ega-sogedba uksad.
\p 
\v 7 Rey-Artajerjes birgaguglegus-yar-dakmaidgi (7), Israel-dulemar gwenna-gwenna Esdrasʼba Jerusalén-neggweburse nonimalad
\q1 Amarde, wemalad:
\q2 Dule-irwa-Bab-Dummadse-gormalad,
\q2 Levita-dulemar, dule-namakmalad,
\q2 dule-yawagak-dakmalad,
\q2 degi, dule-Bab-Dummadse-goled-neggi-arbamalad.
\q3 Amala, Esdrasʼba Jerusalénʼse nonimalad.
\p 
\v 8 Degisoggu, Esdras, Rey-Artajerjes birgaguglegus (7), negdakmaidgi a-nii-walatargine, Jerusalén-neggweburse nonigusad.
\v 9 Esdras Babilonia-neggweburgi gebe-nii-gwisgusad-iba-onodedgine, noaligusad. Ar Bab-Dummad dule-wiledaked-maid eba gudigussoggu, geb Jerusalén-neggweburse gebe-nii-walatar-gwisgusad-ibagi nonigusad.
\v 10 Esdras, Bab-Jehová-Igar-Maid-durdakegala Bab-Igargi nue-alamaknai gusad. A-Igar-Maid-sogedba-ibmar-saega, degi, Bab-Jehová-Igar-Maidgi, degine, Bab-Dummad-Igar-sogsadgi Israel-dulemar-odurdakega Bab-Igargi nue-alamaknai gusad.
\s1 Rey-Artajerjes Esdrasʼse garda barmisad
\p 
\v 11 Rey-Artajerjes, dule-irwa-Bab-Dummadse-goled-Esdrasʼga we-garda uksagusad. Dule-garda-narmaked-Esdrasʼde, Bab-Jehová-Igar-Maid nue-wisidid. Deginbali, Bab-Dummad Israel-dulemarga-ibmar-sogsad nue-wisbalid. Rey weyob garda narmaksad:
\pi1 
\v 12 “Ani Artajerjes, reymar-e-rey, Esdrasʼse an we-garda an-barmisiid. Bedi dule-irwa-Bab-Dummadse-goledid, degi, garda-narmaked-dule-gubalid. Deginbali, Bab-Dummad-Nibneg-Dakmaid-Igar be nue wisbalid: Bitigine be nueganbina gadin.
\pi1 
\v 13 ”An igar-uksad: Bela Israel-dulemar an-yargi-bukwad, dule-irwa-Bab-Dummadse-gormaladi, degi, Levita-dulemarse-bakale, Jerusalén-neggweburse beba nabimalale, namalodo.
\v 14 Ani rey, degi, anga-binsaed-dakmalad-gugled-nuggine (7), Judea-yalase, Jerusalén-neggweburse, dulemar-daknaega an be-barmisiid. Igi be be-Bab-Dummad-Igar-wisi, deyobi bule-nabiri, we-Judío-dulemar Bab-Dummad-Igar-Maidba nanabukmarmodibe.
\pi1 
\v 15 ”Deginbali, or be sedo, mani be sedbalo. Wede, ani rey, degi, dulemar-ega-binsaed-dakmalad e-binsaedba Israel-e-Bab-Dummadga uksamalad. We-Bab-Dummadde, Sión-yalagi, Jerusalén-neggweburgi maid.
\v 16 Degine, Babilonia-yalagi, mani, ormar bega uklesale, be sedbalo. Deginbali, dulemar, dule-irwa-Bab-Dummadse-gormalad, Bab-Dummadse-goled-neg Jerusalén-neggweburgi-siidga e-binsaedba-ibmar-ukmaloedba be sedmalo.
\v 17 A-manigi, ibmar-durgan be baksuli gudager: Moli-bebe-nikad-sapingana, sibad-wawaad-machergan, sibad-wawaad-sapingana. De-ukinbali, Bab-Dummadga-ibmar-uklebaloed be bakbalo: Ibmar-gwagmar, vinoʼmar. Geb degi, Jerusalén-neggweburgi bemar-Bab-Dummadse-goled-neggi Bab-Dummadga ibmar-ogumakar-ukleged-aila-siidgine, bemar we-ibmarmar Bab-Dummadga-ogumakar ukoed.
\pi1 
\v 18 ”Mani-gwabgumaloedi, or-gwabgumaloedi, be dakedba, degi, be-gwenadgan-dakedba na be imakmaloed. Degi-inigwele, bemar-Bab-Dummad-sogedba be imakmalo.
\v 19 Bab-Dummadse-goled-neggi ibmar-ebulemalad bega-uklesadi, a-neggi be urboed. Adi, Jerusalén-neggweburgi be-Bab-Dummadse-goled-neggi ebulegegar.
\v 20 Ibmar-baigan be-Bab-Dummadse-goled-negga nue abegele, rey-mani-bukwadgi, baklegoed.
\pi1 
\v 21 ”Emide ani, Rey-Artajerjes, bela dulemar Éufrates-diwar-dad-argwanedsik mani-dakmalad-bukmaladga an we-igar uked: Dule-irwa-Bab-Dummadse-goled-Esdras, Bab-Dummad-Nibneggi-Maid-e-Igar nue-wisidi, bemarse ibmar egichialile, ega be ibmar ukmalo.
\q2 
\v 22 Sunna ega be we-ibmar ukmaloed:
\q3 Mani, nibir-miligugle gaka dulataled-ilabo gaka dulapaa (7,260).
\q3 Orosgi-dakleged-trigoʼye-nugad, tambor-gwadulatar (100).
\q3 Vino, galón-gwa-dulataled-ilatar gaka dulabo-gakambe (550).
\q3 Olivo-gwallu, galón-gwa-dulataled-ilatar gaka dulabo-gakambe (550).
\q3 Degine, baludi, wilubsarsuli ega be ukmaloed.
\pi1 
\v 23 ”Bela Bab-Dummad-Nibneggi-Maid igar-uksadba, a-sogedbali, ese-goled-negga inniki be ibmar-ukmaloed, ar adi melle Bab-Dummad, rey-negsemaidgi, degi, e-masmalagi urwegar.
\q2 
\v 24 An bemar-owisobalid, melle we-dulemar neggwebur-bennukega be imakmalo:
\q3 Dule-irwa-Bab-Dummadse-gormalad, Levita-dulemar,
\q3 degi, dule-namakmalad. Deginbali, dule-yawagak-dakmalad,
\q3 dule-Bab-Dummadse-goled-neggi-arbamalad,
\q3 degi, dule-Bab-Dummadse-goled-neggi-ibmar-imakmalad,
\pi1 ”Melle we-dulemarse ibmar-weleged be egismarbalo, degi, ibmar-sedanikidgi-mani-galeged melle bennukega be imakmarbalo.
\pi1 
\v 25 ”Esdras, bedi, Bab-Dummad-binsaed nue-nikasoggu, dule-igar-nabiromaladi, dule-dummagan-neggwebur-semaladi be nug-imako. Adi, amar bela dulemar-Éufrates-diwar-dad-argwanedsik-bukmaladga igar-nabogegar. A-dulemardi, bela dulemar Bab-Dummad-Igar-Maid wismaladid. Deginbali, dulemar amba Bab-Dummad-Igar-Maid-wissulile, be amar-odurdakbalo.
\v 26 Ar, dule-gwensak be-Bab-Dummad-Igar-Maidba ibmar-imaksulile, degi, rey-igar-mesisadba dasurbalile, we-dule ise-sabsur-odurdaklegoed: Oburgwilegodibe, neggweburyagi ononnolegodibe, igi egi-mani-dummad galegodibe, igi, esgaryagi odolegodibe.”
\s1 Esdras Bab-Dummadse gochad
\p 
\v 27 Geb degidgine, Esdras Bab-Dummadse gotesunnad:
\pi1 “Bab-Jehová, anmar-dadgan-e-Bab-Dummadye, be nug odummolesun. Emide, Rey-Artajerjes-e-gwage be ebusad, Jerusalén-neggweburgi bese-goled-neg-siid ogannogegar.
\v 28 Bab-Dummad, bedi wile an-dakedbali, rey, degi, dulemar-ega-binsaed-dakmalad, dule-dummagan-gangued-nikamalad, a-dulemar-asabinni, yeer an-dakega be an-imaksad. Bab-Jehová, bedi anba gudigusoggu, an-niga gangusad.”
\p Degisoggu, Israel-dule-dummagan, Jerusalén-neggweburse anba-naega an oambikusad.
\c 8
\s1 Dulemar-Esdrasʼba-nonimalad-e-nugmar
\p 
\v 1 Rey-Artajerjes Babilonia-yalagi negdakmaiunni, babgan-neguya-sedimaladi, degi, dulemar e-dadgan-e-dadganba-ilemakar-nug-mamaidi Babilonia-akale, Jerusalén-neggweburse anba-noni-gusmalad.
\q1 Amarde, wemalad:
\q2 
\v 2 Finees-wagansikid, Gersón.
\q2 Itamar-wagansikid, Daniel.
\q2 David-wagansikid, Hatús.
\q3 
\v 3 Hatúsʼde, Secanías-wagansikidid.
\q1 Paros-wagansikid, Zacarías.
\q2 Zacaríasʼbali, machergan, dulagugle-gakambe-mergu (150) nonikid.
\q1 
\v 4 Pahat-Moab-wagansikid, Zeraías-machi-Elioenai.
\q2 Elioenaiʼbali, machergan, dulataled-ilabo-mergu (200) nonikid.
\q1 
\v 5 Secanías-wagansikid, Jahaziel-machi.
\q2 Jahaziel-machibali, machergan, dulataled-ilapaa-mergu (300) nonikid.
\q1 
\v 6 Adín-wagansikid, Jonatán-machi-Ebed.
\q2 Ebedʼbali, machergan, dulabo-gakambe-mergu (50) nonikid.
\q1 
\v 7 Elam-wagansikid, Atalías-machi-Jesaías.
\q2 Jesaíasʼbali, machergan, dulapaa-gakambe-mergu (70) nonikid.
\q1 
\v 8 Sefatías-wagansikid, Micael-machi-Zebadías.
\q2 Zebadíasʼbali, machergan, dulabake-mergu (80) nonikid.
\q1 
\v 9 Joab-wagansikid, Jehiel-machi-Obadías.
\q2 Obadíasʼbali, machergan, dulataled-ilabo gakambe-gakabaabak-mergu (218) nonikid.
\q1 
\v 10 Selomit-wagansikid, Josifías-machi.
\q2 Josifías-machibali, machergan, dulabaabak-mergu (160) nonikid.
\q1 
\v 11 Bebai-wagansikid, Bebai-machi-Zacarías.
\q2 Zacaríasʼbali, machergan, dulagwen-gakabaabak-mergu (28) nonikid.
\q1 
\v 12 Azgad-wagansikid, Hacatán-machi-Johanán.
\q2 Johanánʼbali, machergan, dulatar-gakambe-mergu (110) nonikid.
\q1 
\v 13 Napi-sorba-nonimaladi, Adonicam-wagansikmalad, wemalad:
\q2 Elifelet, Jeiel, Semaías.
\q2 Amarbali, machergan, dulapaa-mergu (60) nonikid.
\q1 
\v 14 Degine, Bigvai-wagansikmalad, Utai, Zabud.
\q2 Amarbali, machergan, dulapaa-gakambe-mergu (70) nonikid.
\s1 Esdras, Jerusalén-neggweburse aligusad
\p 
\v 15 Ani, Esdras, Ahavaʼse dii-iirmakmaid-gakaba dulemar an oambikusad. Agi, ibapaa anmar ambikusad. Agi bela dulemar-bukwa, degi, dule-irwa-Bab-Dummadse-gormalad-bukwa an daksad. Levita-dulemardi an gwen daksasulid.
\q1 
\v 16 Geb degine, dule-dummaganse an gochad:
\q2 Eliezerʼse, Arielʼse, Semaíasʼse,
\q2 Elnatánʼse, Jaribʼse, baid-dule-Elnatánʼse,
\q2 Natánʼse, Zacaríasʼse, degi, Mesulamʼse.
\q2 Degi, odurdaked-sailagan-Joiaribʼse, Elnatánʼse, an gochabalid.
\p 
\v 17 Degi, Iddoʼse geb we-dulemar an barmisad. Iddoʼde, Casifiaʼye-neg-nugad-e-dummadid. Amar bela Iddoʼga ibmar-sogmaloedi, Iddo-e-gwenadganga ibmar-sogmaloedi, Casifiaʼginmaladga-ibmar-sogmaloedi, an ega sogsad. Adi, anmar-Bab-Dummadse-goled-negga, anmarga dule-arbamalad-barmidagegar.
\p 
\v 18 Dog-nuedye anmar-Bab-Dummadga an sogdo. Bab-Jehová nued-anmargi binsamaid. Anmargala, dule-ibmar-nue-wisid Serebíasʼye-nugad barmialid. Serebíasʼde Mahli-wagangi-danikid. Mahliʼdi, Leví-wagangi-danimogad. Levíʼdi, Israel-e-machid. Serebías, e-machimala, degi, e-gwenadgan nonimalad. Serebíasʼbali bela machergan, warambe-gakabaabak-mergu (18) nonikid.
\p 
\v 19 Deginbali, anmarga Hasabías barmilearbalid. Hasabíasʼbali, Jesaías Merari-wagangi-danikid nonimogad, degi, e-gwenadgan, degi, e-machimala nonimogad. Bela machergan, waladulagwen-mergu (20) nonikid.
\p 
\v 20 Deginbali, anmargala, dulemar-Bab-Dummadse-goled-neggi-arbamalad dulataled-ilabo gaka dulagwen-mergu (220) barmiarbalid. Deun a-dulemar-e-dadgande, epenne, David-maiun, degi, e-dummagan-bukwaun, Levita-dulemar-bendakega na nug-imaksa gusad. Geb e-nugmar bela megisgusad.
\p 
\v 21 Degine, Ahava-dii-iirmakmaid-walikaa anmar mas-gunsuli-Bab-Dummadse-golega ambikusad, adi, anmar-Bab-Dummad-asabin na san-bipi-imakegar. Degine, anmar-naoedba Bab-Dummad anmar-bendakega. De-ukinbali, anmar-mimmigan, degi, anmar-ibmar-nuegan-sedoedi bonisuli guegar.
\v 22 Sordamar igarba anmar-isdarmaladgi anmar-bendakega, an reyse, sordamar danar-danar-bukwad anga barmidagega, an binge egisgusad. Deginbali, dule-moligi-urwemalad anga barmidagega, an binge ese egisgusbalid. Ar ade, anmar bato reyga sogsagusbinned: Dule Bab-Dummadba-gudimaladi, Bab-Dummad nue bendakmaiye, egi nued binsamaibarye. Degi-inigwele, dule-Bab-Dummad-igarba-dasurmaladdi, Bab-Dummad ourwega na imakdamarye.
\v 23 Degisoggu, anmar Bab-Dummadse-golega mas-gunsuli-gudii gussunnad, degi, anmar-Bab-Dummadse anmar nue gochad, adi, anmar-bendakegar. Degine, Bab-Dummad anmar-ese-goled itosad, geb anmar-bendaknonikid.
\p 
\v 24 A-sorbali, dule-irwa-Bab-Dummadse-gormalad-dummagan, e-dummagan-warambe-gakabo (12) an bachikii urbisad. Amarde, wemardo: Serebías, Hasabías, degi, e-gwenadgan e-ambebar (10).
\v 25 Geb agine, rey, ibmar-ebulemaladi, mani, olo, anmar-Bab-Dummadga uksagusad, degine, dule-ega-binsaed-dakmalad, dule-dummagan, degi, bela Israel-dulemar-gudigusmalad uksamarmogad, Bab-Dummadse-goled-neg-sobega. A-ibmarmala a-dulemar-asabinni nibirgi an wilubdaksad.
\q1 
\v 26 Nibirgi an wilub-daksadi, wemalad:
\q2 Mani, nibir-milidulabo-gakabaabak gaka dulataled-ilagugle gaka dulabo-gakambe (48,750).
\q2 Ibmar-ebulemalad-manibiid, nibir-miligugle gaka dulataled-ilatar (7,500).
\q2 Ormar, nibir-miligugle gaka dulataled-ilatarba (7,500).
\q1 
\v 27 De-ukinbali, nog-dummagan-orbiid gwadulagwenba (20).
\q2 A-nogmar nibirambe-gakabakebak (19) aidikued.
\q1 Nog-nuegan-esgoro-gordikidgi-sobaled ise-daarmakarmalad, oryob-gargeguedi, gwabobar.
\p 
\v 28 Geb a-sorbali, dule-irwa-Bab-Dummadse-gormaladga an sogded: “Bemala, degi, Bab-Dummadse-goled-neggi-ibmar-ebulemalad, Bab-Jehováʼga nug-imaklesmalad. E-binsaedba-ibmar-uksamaladi, we-ibmarmalad: Mani, degi, olo. Amardi, Bab-Jehová-anmar-dadgan-e-Bab-Dummadgadid.
\v 29 Nue we-ibmarmar be dakmalo, nue sabomalo, Jerusalén-neggweburgi Bab-Jehováʼse-goled-neg-imbagi ibmar-wilub-imaklegedse. Agi, dule-irwa-Bab-Dummadse-gormalad-e-dummagan-asabin, degi, Levita-dulemar, babgan-neguya-sedimalad-asabin, wilub-imaklegoed.”
\p 
\v 30 Degisoggu, mani, olo, Bab-Dummadse-goled-neggi-ibmar-ebulemalad, bela wilub-imaklesadi, dule-irwa-Bab-Dummadse-gormaladga, degi, Levita-dulemarga, uklesad, adi, amar Jerusalénʼse anmar-Bab-Dummadse-goled-negse sedmalagar.
\p 
\v 31 Gebe-Nii-gwichid-ibambe-gakabogi anmar Ahava-dii-iirmakmaidgi-bukwa, Jerusalénʼse aligusad. Igarbali, Bab-Dummad bela-belad anmar-bendaksad, anmar-isdarmaladgi, degi, dule-ibmar-atursamaladgi anmar-bendaksabalid.
\v 32 Geb Jerusalénʼse anmar modapidgi, wis ibapaa an obunnosmalad.
\p 
\v 33 Geb ibabakegi, anmar-Bab-Dummadse-goled-neggi, mani, olo, Bab-Dummadse-goled-neggi-ibmar-ebulemalad, anmar wilub-imaksamalad. Geb, dule-irwa-Bab-Dummadse-goled-Meremot Urías-machi, aga ibmar-wilub-imaklesadi anmar uksad. Degine, Finees-machi-Eleazar, Meremot-walik gwismogad. Amar-abargi Levita-dulemar gwismarmogad. Amardi, wemalad: Jesúa-machi-Jozabad, degi, Binúi-machi-Noadías.
\v 34 A-ibagi bela ibmarmar ebislesad, degi, wilub-imaklesad, degi, bela e-aidikuedi narmaklesad.
\p 
\v 35 A-sorbali, Israel-Dulemar-galesgusmalad-gannar-nonimaladi Israel-e-Bab-Dummadga ibmar-ogumakar-ukleged ukdemalad.
\q1 A-dulemar we-ibmar-durgan uksamalad:
\q2 Moli-bebe-nikad-sapingana, warambe-gakabo (12).
\q2 Sibad-wawaad-machergan, waladulabake-gakambe-gakanergwa (96).
\q2 Sibad-wawaad-sapingana, waladulapaa-gakambe-gakagugle (77).
\q1 Degine, e-isgued-ular uksamarbalid:
\q2 Sibad-machergan, warambe-gakabo (12).
\q3 Bela Bab-Jehováʼga weligwaledgi we-ibmarmar-ogumakar uklesad.
\p 
\v 36 Geb degine, Éufrates-diwar-dad-argwanedsik dummagan-negdakmamaidga, degi, suar-ibed-dummaganga, rey-igar-uksadi, uklesad. Amarde, Israel-dulemar-bendaksamarmogad, Bab-Dummadse-goled-neg-soblesad bendaksamarbalid.
\c 9
\ms1 4. ESDRAS-E-ARBAED
\mr (9:1–10:44)
\s1 Israel-dulemar-isgusad
\p 
\v 1 Bela we-ibmarmar-bergusad-sorbali, dule-dummaganga-mamaid anse nonimalad, weyob anga sognonimalad: “Anmar-Israel-dulemar, dule-irwa-Bab-Dummadse-gormalad, degi, Levita-dulemarse-bakale, dulemar-baigangi bangusurmalad, degine, e-galagwensur-daedgi amba nanadimalad.
\q1 A-dule-baigan, wemalad:
\q2 Canaán-dulemar, Het-dulemar, Ferezeo-dulemar,
\q2 Jebuseo-dulemar, Amón-dulemar, Moab-dulemar,
\q2 Egipto-dulemar, degi, Amorreo-dulemar.
\q1 Israel-dulemardi, a-dulemar-daedba ibmar-isgana imakdimarmogad.
\p 
\v 2 ”Ar Israel-dulemar, we-dulemar-baigan-omegan-nikudmalad. Deginbali, Israel-dulemar, e-masmalaga, dule-baigan-e-sisgan-ukdemalad. Bab-Dummad-na-e-dulemar-susadi, emide, dulemar-baiganbo ablis-apurudmalad. Dule-dummagan, dule-negsemamaid, a-inseba na we-isguedgi isgudmalad.”
\p 
\v 3 Deyob an itosgua, an mor-yoidi, degi, an-suba-dummad-yoidi, nunmak-itogedbali, siir-siir an imaksad, sailagia unge-unge an imaksad, degi, aku-sigamarse-bakale, deyob an imaksad. Geb degi, nue-wile-itogedbali, napagi-maada an sigisad.
\v 4 Dulemar-galesgusmalad-nonimalad-e-isgusad-ular, anse Israel-e-Bab-Dummad-Igar-Maidba-gudimaladi ambikunonimalad. Ar andi, neg-sedoguedse Bab-Dummadga-ibmar-ogumakar-ukleged-wachise gwage-nunmak an itosii gusad.
\s1 Esdras, Bab-Dummadse gochad
\p 
\v 5 Sedogusgua, Bab-Dummadga-ibmar-ogumakar-ukleged-wachigine, an gwage-nunmakedi wis gadigusad. Degi, an mor-yoidi, suba-dummad-yoibalidi esiirmakagwale, napagi yokorgi-sindigar an-Bab-Dummad-Jehováʼse-golega an argan onakwisad.
\v 6 Degi, Bab-Dummadga an sogded:
\pi1 “Bab-Dummadye, bela-belad an akusunna itoged, an bingedar bese goled. Ar anmar-isguedi nue anmargi wilub-obicha naid. Anmar galagwensuli-bela-bela-isguedgi-nanadiidi bese warmaksa naid.
\v 7 Anmar-dadgan-ibagan-akale, emi-ibagansega, bela-belad anmar begine dummad-nodiid. Anmar-isgued-ular, bela anmar, anmar-reymar, degi, anmar-irwa-bese-gormalad, reymar-yar-baid-baidsik-negdakmamaidga anmar urmaklesad. Anmala, emarse es-suidgi naibigusad, gales gusad, anmar-ibe ibmar sulesad, ise-mesagwale anmar gusad, emi-ibagi amba imaklediidyob.
\pi1 
\v 8 ”Anmar-Bab-Dummad-Jehováʼye, emide be, sikwas be-sabguedi be anmarse oyosad. Anmar-gwenna-gwenna dulemargi-ollor-guega wis be anmar-imaksad. Bese-goled-neg-islidikidgi-ambikuega be anmar-imaksabalid. Degi, ibagan-nued be anmarse oyosad, anmar maiga-bukwa-gusadgi dula-gudiguega wis be anmar-imaksabalid.
\v 9 Bab-Dummadye, anmar dulemar-e-maiga-gudigus-inigwele, bedina gwen anmargi bangussulid. Aka bur Persia-yar-e-reymar wile anmar-dakega be imaksad. Bese-goled-neg-bibichis-gusadi, gannar-sobega be anmargi burba-nuegan oubosad. Judá-yalagi, degi, Jerusalén-neggweburgi be anmar-bendakmaid, adi, melle bonigan anmarse warmakegar.
\pi1 
\v 10 ”Emide, Bab-Dummadye, anmar we-ibmar-isgana-imaksadgine, ¿ibu an bega sogmaloe? Ar ade, anmar be-Igar-Maidbali gwen ibmar imaksasulid.
\v 11 Be-maigan-be-gayaburba-barsogmaladba, be iduakwaa anmar-owisosgusad. Deun, weyob be sogsagusad: ‘Bemar we-yarse dogmaloedi, degi, we-yar be gamaloedi, nue-isgus-naiye, dule-gudimalad ibmar-isgana-imakedba, bela-belad we-yar nue-gagalesye. Bela a-yala nue-isgus-naiye be anmar-owisosanad.’
\v 12 Deginbali, be anmarga sogsagusbalid: ‘Bemar, melle be-sisgan, we-macherganga be ukmaloye. We-dulemar-e-bunamaladi, melle be-masmalaga be ukmarbaloye. Degine, we-dulemarbo, melle be igar mesmaloye. Melle be bendakmaloye, adi, bemar gandikidba nanadii-gumalaga, degi, we-yargi ibmar-nuegan-nikad-gundii gumarbaligar. We-yar-nued geb be-mimmiganga degisadegu be obemaloye.’
\pi1 
\v 13 ”Bab-Dummadye, anmar bela-belad isgusad an na magar itoged. Anmar sabsur-odurdaklegedwilubbinad. Degite, be anmar-Bab-Dummad-guedgi, be sabsur anmar-odurdaksasulid. Wile be anmar-dakedbali, napi-ichee be anmar-obedapid.
\v 14 Bab-Dummadye, ¿anmarde Be-Igar-Maidba bar nanasuli gumalode? ¿Gannar we-dulemar-baigan-omegan ibmar-galagwensuli-imakmaladbo nikumai gumarbalode? Adi surbali. Bab-Dummad, ar deyobile, ¿be anmarse ulussulirde, be anmar obelossulirde? Be anmarse ulusale, bela be anmar-obelosale, dule wargwensaar begi gwen wakichasuliled.
\pi1 
\v 15 ”Bab-Jehováʼye, Israel-e-Bab-Dummad, bedi dule-napiragwadid. Bedi, emi-ibasega, nabir danakwaa wis-ambikuega be anmar-imaksad. Anmar be-asabin ambikued-wilubsulinad. Ar anmar begi isgusad, degi-inigwele, anmar be-asabinni bukwamalad.”
\c 10
\s1 Israel-dulemar na e-isgued barsogsamalad
\p 
\v 1 Esdras Bab-Dummadse-goled-neg-asabin, Israel-dulemar-isgusad-ular, ise-boale, degi, yokorgi-sindigar, Bab-Dummadse gorsiidgine, bukidar Israel-dulemar: Machergan, omegan, mimmiganse-bakale, ese ambikunonikid. A-dulemar, bela ise-boedbimarmogad.
\v 2 Geb degine, Jehiel-machi-Secanías, Elam-wagangi-danikid, Esdrasʼse aligusad.
\p Geb weyob ega sogded: “Anmar, omegan-Israel-dulesurmalad nikus-nanasoggu, anmar-Bab-Dummadgi nue-nosad. Degi-inigwele, amba sunna anmar bendakleged.
\v 3 Degisoggu, anmar, anmar-Bab-Dummadbo, igar mesmardo. Emi, bela we-omegan-Israel-dulesurmalad anmar metemaloye, mimmigangi bangumarbaloye, be anmargala binsaed-uksadba, deyob anmar imakodo. Degi, dule-Bab-Dummad-Igar-Maidba-nanadimalad-sogsamogadba, deyob anmar imakodo.” Degisoggu, Bab-Dummad-Igar-Maidba imaklesundo.
\p 
\v 4 Geb degi, Esdrasʼga sogdemalad: “Gwichibin be imake, ar we-igarde be imakergebed, ar anmar be-bendakmogoed, gandik be-sae, be ibmar imake.”
\p 
\v 5 Degidgine, Esdras gwichibin imaksad. Geb Esdras, dule-irwa-Bab-Dummadse-gormalad-e-dummagan, Levita-dulemala, bela Israel-dulemala ibmar-sogsamaladba-ise-sogar-imakega, imaksad. Degisoggu, Israel-dulemala ise-sogar eyeye na sogsamalad, deyob imakmaloye.
\v 6 Geb agi, Esdras, Bab-Dummadse-goled-neg-asabin-sii nadsunnad. Geb Johanán-e-gabednegse naded. Johanánʼde, Eliasib-machid. Agine, dulemar-galesgusmalad-gannar-nonimalad-e-isgusadba, Esdras, nue bukib-binsaedba, gwen gobsasuli, mas-guchasuli, gabided.
\p 
\v 7 Geb sorbali, dulemar-galesgusmalad-nonimaladse gorlesad. We-dulemarse gorlesad: Judá-yalagi-bukmaladse, degi, Jerusalénʼgi-bukmaladse. Ega weyob soglesad: “Jerusalén-neggweburse ambikunonimaloye.”
\p 
\v 8 Degi, ega soglesbalid: “Dule ibapaagwadgi nonisulile, bela ei e-nainumar-nikadi sulegoye. Ar igi-dummagan, degi, Judío-girmar-dummagan igar-mesisa, deyob guoye. Degi, dulemar-galesgusmalad-nonimalad-imbagi, bemar-ononnolegoye,” ega soglesad.
\p 
\v 9 Geb degine, a-ibapaagwadgi, bela machergan Judá-yarginmalad, degi, Benjamín-yarginmalad, Jerusalén-neggweburse ambikunonimalad. Deunni, nii-walabakebakgi, e-iba-durgwengi, bela dulemar Bab-Dummadse-goled-neggi ambikued-neg-naidgi ambikusmalad. Degi, weyob ibmar-soglesadba, nue dobee itodmalad. De-ukinbali, dii nue-winaibarsoggu, a-bakas bela-belad wawanmakbukwad.
\v 10 Geb degi, dule-irwa-Bab-Dummadse-goled-Esdras gwichibin imaksad. Geb amarga weyob sogded:
\p —Bemar, bela-belad Bab-Dummadgi nue isgusad, omegan-Israel-dulemarsurmalad be nikusmalad. Degidbali, bela-belad Israel-dulemar-isguega be imaksamalad.
\v 11 Emi, anmar-dadgan-e-Bab-Dummad-Jehová-asabin, be-isgusmalad be barsogmarsun. Bab-Jehová-ibmar-abegedba be imakmalo. Degine, dule-Bab-Jehová-wissurmaladgi be bangumalo, omegan-be-dulamarsulid be metemalo.
\p 
\v 12 Geb, bela dulemar gandikidba, Esdras-abin sogdemalad:
\p —Ar deyobdo. Degiirdi nabir, be-sogedba anmar imako.
\v 13 Degi-inigwele, anmar bukidarsoggu, degine, diide nue-winaibarsoggu, anmar geg weyob magaba bukwa gued. Ar we-igarde binsa ibagwenadye, degi, ibabogwadye soglesulid, ar ade, anmar bukidar na we-igargi isgusmaladbiid.
\p 
\v 14 ”Degisoggu, anmar sogsundo, dule e-neggweburga-dummadga-gudimalad, e-sordagan-ular, wegi beoye, adi, amar-ular sunmakegar. Geb dulemar-omegan-Israel-dulesulid-nikusmalad iba-sogedba nonimaloed. Wemar dule-dummagan-abargi, dule-igar-nabiromalad-abargi, degi, e-neggwebur-e-neggwebur-iliba wese nonimaloed. Adi, Bab-Dummad anmar egi-isgusad-ular anmarse-urwemaidi, melle bar anmarse urwegar.”
\p 
\v 15 Geb degi, unnila Asael-machi-Jonatán, Ticva-machi-Jahazías, wemar-ebogwad, we-ibmar-sogsamaladgi gwisgusad, degine, Levita-dulemar-ebogwad Mesulam, Sabetai, we-dulemarba nai gusmarmogad.
\v 16 Dulemar-gales-selesgusmalad-nonimaladdi, na sogedba imaksad. Geb degine, dule-irwa-Bab-Dummadse-goled-Esdras, neguya-gwenna-gwennagi dummadga-gudimalad amisad, adi, dulemar-omegan-Israel-dulesulid-nikusmaladga igar-amiegar. Geb, nii-warambegi, a-ibagwenadgi, dulemar e-neggweburmar-ular dummadga-besmaladi na igar-amidmalad.
\v 17 Degi, gebe-nii-yolesad-ibagwenadgi, bela-dulemar omegan-Israel-dulemarsulid-nikusmaladga igar-nabiroleged bergusad.
\s1 Dulemar-omegan-Israel-dulemarsulid-nikusmalad-e-nugmar
\q1 
\v 18 Dule-irwa-Bab-Dummadse-gormalad-e-wagan, omegan-Israel-dulesulid-nikusmalad, wemalad:
\q2 Josadac-machi-Jesúa, Josadac-wagangi-danikid,
\q2 degi, e-gwenadgan: Maasías, Eliezer, Jarib, Gedalías.
\p 
\v 19 We-dulemar na nue-ise-sogar sogsamalad, we-omegan-Israel-dulesurmalad anmar metemaloye. Degine, amarde, e-isgued-eliega, Bab-Dummadga sibad-wawaad-machered-wargwen ogumakar uksamarbalid.
\q1 
\v 20 Imer-wagansikid:
\q2 Hanani, Zebadías.
\q1 
\v 21 Harim-wagansikid:
\q2 Maasías, Elías, Semaías, Jehiel, Uzías.
\q1 
\v 22 Pasur-wagansikid:
\q2 Elioenai, Maasías, Ismael, Natanael, Jozabad, Elasa.
\q1 
\v 23 Levita-wagansikid:
\q2 Jozabad, Simei, Kelaía. Kelaíaʼde, Kelita-duled.
\q2 Petaías, Judá, Eliezer.
\q1 
\v 24 Dule-Namakmalad-e-wagansikid:
\q2 Eliasib.
\q1 Dule-yawagak-dakmalad-e-wagansikid:
\q2 Salum, Telem, Uri.
\q1 
\v 25 Deginbali, Israel-dulemar-baigansikmalad.
\q1 Paros-wagansikid:
\q2 Ramía, Jezías, Malquías, Mijamín,
\q2 Eleazar, Malquías, Benaía.
\q1 
\v 26 Elam-wagansikid:
\q2 Matanías, Zacarías, Jehiel, Abdi, Jeremot, Elías.
\q1 
\v 27 Zatu-wagansikid:
\q2 Elioenai, Eliasib, Matanías, Jeremot, Zabad, Aziza.
\q1 
\v 28 Bebai-wagansikid:
\q2 Johanán, Hananías, Zabai, Atlai.
\q1 
\v 29 Bani-wagansikid:
\q2 Mesulam, Maluc, Adaía, Jasub, Seal, Ramot.
\q1 
\v 30 Pahat-Moab-wagansikid:
\q2 Adna, Quelal, Benaía,
\q2 Maasías, Matanías, Bezaleel, Binúi, Manasés.
\q1 
\v 31 Harim-wagansikid:
\q2 Eliezer, Isías, Malquías, Semaías, Simeón,
\q2 
\v 32 Benjamín, Maluc, Semarías.
\q1 
\v 33 Hasum-wagansikid:
\q2 Matenai, Matata, Zabad, Elifelet, Jeremai,
\q2 Manasés, Simei.
\q1 
\v 34 Bani-wagansikid:
\q2 Madai, Amram, Uel,
\v 35 Benaía, Bedías, Quelúhi,
\q2 
\v 36 Vanías, Meremot, Eliasib,
\v 37 Matanías, Matenai, Jaasai,
\q2 
\v 38 Bani, Binúi, Simei,
\v 39 Selemías, Natán, Adaía,
\q2 
\v 40 Macnadebai, Sasai, Sarai,
\v 41 Azareel, Selemías, Semarías,
\q2 
\v 42 Salum, Amarías, José.
\q1 
\v 43 Nebo-wagansikid:
\q2 Jeiel, Matatías, Zabad, Zebina, Jadau, Joel, degi, Benaía.
\p 
\v 44 Bela-wemar, omegan-Israel-dulemarsurmalad-nikusmaladid. Geb degi, na e-omegangi bangudmarsunnad, e-mimmigangi aibatemarsunnad.
