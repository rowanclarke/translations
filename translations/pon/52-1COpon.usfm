\id 1CO - Old Pohnpeian2 
\h Men Korint I 
\toc1 EN PAULUJ A KIJIN LIKAU KAIEU ON MEN KORINT 
\toc2 Men Korint I 
\toc3 1 Kor 
\mt2 EN PAULUJ A KIJIN LIKAU KAIEU ON  
\mt1 MEN KORINT  
\c 1  
\p
\v 1 PAULUJ me paeker, en wiala wanporon en Iejuj Krijtuj amen pan kupur en Kot o ri atail Jojtenej,  
\v 2 On momodijou en Kot me mi Korint, me jaraui kila Krijtuj Iejuj, me paeker en jaraui o karoj me kin likwir on mar en atail Kaun Iejuj Krijtuj ni deu arail o deu at.  
\v 3 Mak o popol jan ren Kot Jam atail a atail Kaun Iejuj Krijtuj en mi re omail!  
\v 4 I kin danke ai Kot kaukaule pweki mak en Kot on komail, me papana don komail jan ren Krijtuj Iejuj,  
\v 5 Pwe komail me pai kidar i ni meakaroj, ni majan karoj o lolekon karoj;  
\v 6 Duen kadede iran Krijtuj a teniten re omail;  
\v 7 Pwe jota pai en mak eu, me komail jaik pai kidar; ni omail auiaui kajanjal en atail Kaun Iejuj Krijtuj.  
\v 8 Me pil pan kotin kajone komail di lao lel imwi, pwe en jolar dip omail lao lel ni ran en atail Kaun Iejuj Krijtuj.  
\v 9 Kot me melel, me komail paekerdo, pwen jau pena ren japwilim a Ol Iejuj Krijtuj atail Kaun.  
\v 10 Ri ai kan, i panaui komail ni mar en atail Kaun Iejuj Krijtuj, komail en wiaki eu ni omail kajoi kan, pwe komail de wuki pajan nan pun omail, a komail en mi ni lamalam ta pot o kapun ta ieu.  
\v 11 Ri ai kan a kalok don ia jan toun im en Kloe, me dene komail kin akamai pena nan pun omail.  
\v 12 A iet me i men inda, amen komail kin inda: Nai nain Pauluj amen; a nai nain Apoloj amen; a nai nain Kepaj amen; a nai nain Krijtuj amen.  
\v 13 Iaduen, Krijtuj me lop pajan? Iaduen, Pauluj me lopu kin komail er? De komail paptaijekier ni mar en Pauluj?  
\v 14 Nai me danke Kot, me jota meamen re omail, me i paptaijela, Krijpuj eta o Kaiuj;  
\v 15 Pwe amen de inda, me nai wia paptaije on ni pein ad ai.  
\v 16 A toun im en Jtepanaj i pil paptaijela; a jolar me i aja, me i paptaijela.  
\v 17 Pwe kaidin en wia paptaij, me Krijtuj poron kin ia la, a pwen padaki ronamau, kaidin ni tiak kadek lokaia, pwe lopun Krijtuj de mal la.  
\v 18 Pwe majan duen lopu me mal kot ren me lokidokilar akan, a manaman en Kot on ir, me pan dorela.  
\v 19 Pwe a intinidier: I pan tiakedi lolekon en me lolekonkan, o karotonala marain en me marain akan.  
\v 20 Ia me lolekon o? O ia jaunkawewe o? Ia me lolekon o en pali pa? Dadue, Kot jota wia lamponki me erpit en pali pa?  
\v 21 Aramaj akan jota aja Kot pweki udan ar lolekon. Kot ap kupureda, en kamaur kida, me pojon akan padak monai.  
\v 22 Pwe Juj akan kin poeki kilel akan, a men Krik kin roporop lolekon.  
\v 23 A kit kin padaki Krijtuj me lopuedar, men kamakar on Juj akan o on men liki kan kajoi mal.  
\v 24 A on me paeker akan, men Juj o pil men Krik, je kaweweda Krijtuj manaman en Kot o erpit en Kot.  
\v 25 Pwe joerpit en Kot me jikida jan en aramaj akan ar lolekon, o luet en Kot me kelail jan en aramaj akan ar kelail.  
\v 26 Ri ai kan, komail kilan duen omail paeker. Pwe kaidin me toto ren me lolekon en pali uduk kan. Pil kaidin me toto ren me poe kan, pil kaidin toto ren me majamaj akan, me pilipildar.  
\v 27 A Kot kotin piladar me jo lolekon nin jappa, pwen kapoui ala me lolekon kan; o Kot me kotin piladar me luet nin jappa kan, pwen kapouiala me kelail akan.  
\v 28 O me mal nin jappa, o me jo konekon, i me Kot kotin piladar, o me jota meakot, pwen kawela me lapalap.  
\v 29 Pwe uduk der akjuaiki mon Kot.  
\v 30 A komail tapi jan i ren Krijtuj Iejuj, me wialar atail erpit jan ren Kot, o pun, o jaraui, o maur patail.  
\v 31 Pwe duen a intinidier: Mo men juaiki, i en juaiki Kaun o.   
\c 2  
\p
\v 1 RI ai kan, ni ai pwara won komail er, kaidin ni kadek lokaia de lolekon en aramaj, me I padaki on komail er kadede en Kot.  
\v 2 Pwe i jota wia kin ia, en aja meakot nan pun omail, Iejuj Krijtuj eta o a kalopuela.  
\v 3 O nai mimi re omail ni ai luet, o majak, o rerer toto.  
\v 4 O ai kajoi o ai padak kaidin ni kadek lokaia en lolekon, a ni kadede en Neno manaman.  
\v 5 Pwe omail pojon de pajoneki lolekon en aramaj akan, a manaman en Kot.  
\v 6 Ari jo, me kit kin padapadaki me lolekon ren me unjok kan, a kaidin lolekon en jappa et, o pil kaidin en jaupeidi kan en jappa et, me pan jarodi,  
\v 7 A kit kin padaki duen erpit en Kot me rir, iei me jo janjal, me Kot kotin kileledier ni en jappa jaik mia, pwen kalinanada kitail,  
\v 8 Me jota jaupeidi en jappa men ajadar, pwe ma re ajaer i, re jota pan kalopuela Kaun en linan.  
\v 9 A duen a intinidier: Me jota maj udialer, o me jota jalon eu ronadar, o me jota ko on nan monion en aramaj amen, iei me Kot kotin kaonop on, me pok on i.  
\v 10 A Kot kotin kadiarok on kitail ki Nen e, pwe Nen kin kotin rapaki meakaroj, pil duen kupur en Kot.  
\v 11 Pwe ij aramaj, me kin aja duen lol en aramaj akan, pwe nen en aramaj eta me mi re a? Iduen Kot, jota me aja meakan me udan Kot, pwe Nen en Kot eta.  
\v 12 A kaidin nen en jappa, me kit aleer, a Nen en Kot, pwe kit en ajada meakan, me Kot kotiki on kitail er.  
\v 13 I me kit pil kin padaki wei, kaidin ni lokaia o manin pan lolekon en aramaj, a ni majan akan, me Nen kotin kaweweda, kareda dipijou wenin akan.  
\v 14 A aramaj ip pwel jota kin ale meakot ren Nen en Kot, pwe me mal kot on i, pwe a jota kak on, pwe mepukat kin kajauiada ren Nen.  
\v 15 A me wenin kin kajauiada meakaroj, ap jota amen me pan kak kajauiada i.  
\v 16 Pwe ij me aja duen kupur en Kaun o, de ij me pan kak padaki on i meakot? A Nen en Krijtuj kotikot lol atail.   
\c 3  
\p
\v 1 ARI ri ai kan i jota kak padaki on komail dueta on aramaj wenin, a on me uduken o kijin jeri en Krijtuj akan.  
\v 2 I kamana kin komail pil en didi, a kaidin kijin mana, pwe komail jaikenta kak on, o komail pil jota kak on anjau wet.  
\v 3 Pwe komail non uduken pwe iaduen, ma peirin o akamai, mi re omail, komail jo uduken o weweid ni tiak en aramaj akan?  
\v 4 Pwe amen kin inda: Nai nain Pauluj amen, a amen: Nai nain Apoloj amen. Komail jo kin mi nin tiak en aramaj?  
\v 5 Pwe ij Apoloj? O ij Pauluj, kaidin papa kai, me komail aja janer lamalam duen Kaun o kotin pan on amen amen?  
\v 6 Nai me padukedier, a Apoloj me kalamu ir adar, a Kot me kotin kaparadar. wiaw.  
\v 7 Ari kaidin i meakot, me padukedi, pil kaidin i, me kalamu ir adar, a Kot eta, me kotikidar wa kan.  
\v 8 Ari, me kin padukedi o me kin kalamu ir adar, ira dupeneta, o amen pan katinki iran ara dodok.  
\v 9 Pwe kit me jauaj pan dodok en Kot, a komail japajap en Kot, o japwilim en Kot a kakau im.  
\v 10 Nai me wiadar pajon ki mak en Kot me i aleer duen jauje lolekon amen, a amen ujewei kakau poa, a amen amen en kalaka duen a kakau pon pajon wet!  
\v 11 Pwe jota me pan kak wia eu pajon, me pan toror jan me wiauier, i eta: Iejuj Krijtuj.  
\v 12 Ari, ma amen pan kauada pon pajon wet kold, jilper, takai, kajampwal, tuka, ra, pain kit akan,  
\v 13 Nan wiawia en amen amen pan janjaleda, pwe ran o pan kapareda due, pwe a pan kadiarok kida kijiniai. Pwe kijiniai pan kaialeda wiawia en amen amen.  
\v 14 Ma wiawia en amen, me a kauadar poa, pan mimieta, a pan katin.  
\v 15 A ma wiawia en amen pan ronala, a jota pan katin. A pein i pan dorela duen amen, me pitila jan nan kijiniai.  
\v 16 Komail jota aja, me komail tanpaj en Kot, o Nen en Kot kotikot lol omail?  
\v 17 A ma amen kawela tanpaj en Kot, nan Kot pan kawela i, pwe tanpaj en Kot me jaraui, ari iei komail.  
\v 18 Jota amen en kotaue pein i! Ma amen nan pun omail lamelame anjau wet, me a lolekon, mak eta, en wiala ol pweipwei men, pwen wiala lolekon amen.  
\v 19 Pwe lolekon en jappa et me jon en pweipwei ren Kot, pwe a intinidier: A kin kaloe kidi me aklolekon pein ar widiwidin.  
\v 20 Pil eu! Kaun o kotin mani, lamalam en me aklolekon kan, me mal.  
\v 21 Ari, jota amen en akkeleki aramaj akan, pwe omail meakaroj;  
\v 22 Ma Pauluj, de Apoloj, de Kepaj, de jappa, de memaur, de mela, de ma men met, de men mur, pwe karoj me omail.  
\v 23 A komail japwilim en Krijtuj, a Krijtuj japwilim en Kot.   
\c 4  
\p
\v 1 ARAMAJ akan en wia kin kit papa en Krijtuj o jaunkoa pan me rir akan ren Kot.  
\v 2 A iaduen jaunkoa kan? Amen amen en lelapok.  
\v 3 I jota injenoki, me komail de kapun en aramaj kajaui ia da. Pein nai pil jota kajaui ia da.  
\v 4 Pwe jota me i pein aja, a kaidin met, me i pun kila, a Kaun o me kin kajaui ia da.  
\v 5 Ari, komail depa kajaui okot me mon a anjau, a lao Kaun o pan kotido, me pan kajanjale dan marain okiok en me rotorot akan o kadiarokada lamalam en nan monioin akan, amen amen ap pan indandeki ren Kot.  
\v 6 Ri ai kan, mepukat i kin inda duen nai o Apoloj, pwe komail en ale jan kit, pwe amen ender lamelame, me a jiki jan me intinidier, pwe komail ender aklapalapaki amen, ap palian me teio.  
\v 7 Pwe ij me mone kin uk? A jota, me mi re om, me koe jota aleer. A ma koe aleer meakaroj, menda koe kin juaiki, likamata koe jota aleer?  
\v 8 Komail medier o kapwapwalar, o komail kin kaunda, ap jota ale jan kit. I men, komail en kaunda, pwe kit ap pil pan ian komail kaunda.  
\v 9 Pwe i lamelame, me Kot kotin wiai on kit wanporon akan, en tikitik melel, me mau on mela, pwe kit wialar men kapuriamui eu ni jappa mon tounlan o aramaj akan.  
\v 10 Kit me jon en pweipwei pweki Krijtuj, a komail me lolekonki Krijtuj; kit me luet, a komail me kelail; komail me indand mau, a kit me indand jued.  
\v 11 Kokodo lel auer met kit mm manadar, o pil men nim piladar, o kilijo, o je kin kalokolok, o jota deu at.  
\v 12 O dodok ni pein pa at; kit me kalok jued, a je kin kapaiada, kit me kalokolok, a je kin nenen la; Ni at pakaraun mal, kit kin kapakap.  
\v 13 Kit wialar tatan kid o kopataun aramaj karoj.  
\v 14 I intiniedier mepukat kaidin pwen kanamenok komail, a pwen panaui komail nai jeri kompok kan.  
\v 15 Pwe ma omail jaunpadak pan Krijtuj me nen, nan jam omail akan me jota non toto, pwe nai me kaipwi komail ren Krijtuj Iejuj ki ronamau.  
\v 16 I ari poeki re omail komail en idauen ia do.  
\v 17 Pwe i me i kadarki won komail Timoteuj nai jeri kompoke o lelapok pan Kaun o pwen kataman kin komail duen al ai kan pan Krijtuj, duen me i kawewedar ni momodijou karoj.  
\v 18 Akai komail me aklapalap likomata i jota pan pwar won komail.  
\v 19 A i pan pwar won komail madan, ma Kaun o pan kotin kupura. I ap pan kilan kaidin padak en me aklapalap akan, a me manaman.  
\v 20 Pwe wein Kot jota mi ni kajoi a ni manaman.  
\v 21 Da me komail mauki? I en pwar won komail wa jokon, de limpok o nen en opampap?   
\c 5  
\p
\v 1 I PIL ronadar, me nenek kin wiaui nan pun omail. A eu jon on nenek, me jota kin wiaui ren men liki kan; pwe dene amen paudeki on a papa a paud.  
\v 2 A komail me aklapalap, ap jota injen juedeki o kajapokela jan komail, me wiadar met.  
\v 3 A ni ai doo jan komail ni pali war, ap koren ion komail ni pali nen i iet me i kapunadar, dueta amen, me mi re omail,  
\v 4 Ni mar en atail Kaun Iejuj, ni atail pokon pena re omail ni pali nen atail, ki manaman en atail Kaun Iejuj.  
\v 5 Me wiadar met i panalan Jatan, pwen kawela uduk o, pwe nen o en kamaurela ni ran en Kaun Iejuj.  
\v 6 Kaidin me mau omail juaiki. Komail jota aja, me kalap kij kin kamutala dolepa karoj?  
\v 7 Ari, kokowei jan kalap kitai, pwe komail en wiala plaua amaj kap, pwe komail udan plaua amaj kap, pwe atail paja Krijtuj kamatalar.  
\v 8 Kitail ari en wiada atail paja, kaidin ni kalap kitai, pil kaidin ni kalap lemai de me jued, a ni plaua amaj kap ni pun o melel.  
\v 9 Na, i intin won komail er nan kijin likau o, pwe komail ender waroki on me nenek kan.  
\v 10 Ari mepukat i jota kin inda duen me nenek ren men liki kan, de me norok kapwa, de me lolap akan, de me wun ani, pwe ma idue, komail en katoror wei jan jappa.  
\v 11 A met i intin won komail er ender waroki on amen, me adaneki jaulan, ap nenek, de me norok kapwa, de kati ani mal, de lalaue amen, de kamom joko, de me lolap; komail ender ian I mana.  
\v 12 Pwe menda re i men liki? Kaidin ai dodok en kadeik irail ada. Komail jota kin kadeikada nan pun omail?  
\v 13 A me mi liki ko, Kot pan kotin kajapoke wei jan re omail me jued o!   
\c 6  
\p
\v 1 A MA amen wia japun on amen, menda komail kapun pena mon men liki kan, a jo mon me jaraui kan?  
\v 2 De komail jota aja, me jaraui kan pan kadeikada jappa? A ma jappa pan pakadeikeki komail, iaduen, komail jota itar on kadeikada kijin dodok tikitik kan?  
\v 3 Komail jota aja, me kitail pan kadeikada tounlan kan? Nan melel kaualap pil kijin tiak tikitik en maur et.  
\v 4 A ma komail kin kadeikeki tiak en maur et iaduen, komail kin kapukapun ianaki me jota indand mau ren momodijou?  
\v 5 Mepukat i indai on komail, pwen kanamenok komail. Pwe jota amen re omail, me lolekon? Jota amen me itar on en wiada kapun nan pun en ri a kan?  
\v 6 A amen kin akamai on amen ri a mon me jopojon akan.  
\v 7 Ari, omail akamai nan pun omail pil udan japun. Menda komail jota mueidala meakot? Menda komail jota kin nenenla?  
\v 8 A komail kin japun o kotaue on ri omail akan.  
\v 9 De komail jota aja, me japun kan jota pan jojoki wein Kot? Kalaka pein komail! pwe me nenek de me kati ani likam akan, de me kamal, de me dir en inon jued, de me madon jaut on ol oko.  
\v 10 De men pirap, de me norok kapwa, de kamom joko, de kinekine mal, de kuli kapwa kan jota pan jojoki wein Kot.  
\v 11 Iduen akai komail maj o, a met komail wideudier, o kajarauialar, o pun kilar mar en Kaun Iejuj o Nen en atail Kot.  
\v 12 A muei on ia meakaroj, a kaidin karoj me kin kamau ia la; a muei on ia meakaroj, a jota, me pan poe ia di.  
\v 13 Melel, kijin mana me mau on kaped o, o nan kapedi wajan kijin mana en ko on ia. A Kot pan kotin kawe ira la karoj. A pali war o wiaui on Kaun o, a kaidin on nenek, a Kaun kotin apapwali pali war o.  
\v 14 A Kot me kotin kaiajadar Kaun o, a pil pan kotin kaiaja kida kitail manaman.  
\v 15 Komail jota aja, me war omail kokon en Krijtuj? A iaduen, i en ale kokon en Krijtuj, wia kin ir kokon en li nenek amen? O jo!  
\v 16 De komail jota aja, meamen me waroki on li nenek amen, me ira pan wiala war ta ieu? Pwe a kotin majanier: Ira pan wiala uduktaieu.  
\v 17 A me waroki on Kaun o nan a pan nen ta ieu re a.  
\v 18 Komail tane wei jan nenek, pwe dip karoj, me aramaj kin wia, kin wiaui likin war a, a me kin nenek, kin wiada dip on pein war a.  
\v 19 De komail jo aja, me war omail tanpaj en Nen jaraui me kotikot lol omail, me komail aleer jan ren Kot, a kaidin uta ’mail komail.  
\v 20 Pwe komail neti kidar pai eu, komail ari kalinanada Kot ki war omail.   
\c 7  
\p
\v 1 A IET duen me komail intine don ia, a mau on aramaj amen, a ender jair li amen.  
\v 2 Ari jo, amen amen en ale pein a warok li, o amen amen en ale pein a warok ol, pwen der dender.  
\v 3 Ol o en wiai on a warok li me inen, a pil dueta li on a warok ol.  
\v 4 Li o jota kak poedi pein war a, a a warok. Pil dueta ol o jota kak poedi pein war a, a a warok.  
\v 5 Der jo oke amen amen, ma jo, pweki inau anjau kij, pwen mot ijejol rer ekij o kapakap, ap pur pena, pwe Jatan de kajonejon komail omail jo oke pena.  
\v 6 Mepukat kaidin kujoned eu, pwe pein ai lamelam.  
\v 7 A i men aramaj akan karoj en dueta nai. A amen amen aleer pein a pai en mak jan ren Kot duen amen amen.  
\v 8 A nai indai on me jo papaud o li odi kan, me mau irail en dadaur dueta nai.  
\v 9 A ma irail jota kak on, irail en papaud; me mau papaud jan dender.  
\v 10 O on me papaud akan nai me ilaki wei, a kaidin nai pwe Kauno: Li papaud ender kamuei wei jan a warok!  
\v 11 A ma a muei wei janer, i en dadaurete a kirip de kadeke a warok, o ol ender kajela a warok.  
\v 12 Kaidin Kaun o, pwe nai men indan me tei kan: Ma ri atail ol amen mia, me a paud jopojon amen, ap men mimieta re a, a ender kajela li o.  
\v 13 Pil dueta li amen, ma a warok jopojon amen o a men mimieta re a, a ender kajela ol o,  
\v 14 Pwe ol jopojon me kajaraui kilar li o, o li jopojon kajaraui kilar ol o, pwe ma a jo due met, noumail jeri kan me jamin, a met irail me jaraui.  
\v 15 A ma me jopojon o pan muei wei jan, ari i en muei wei jan; ri ol de ri li jota kin kaupindi ni mepukat. A Kot me kotin molipe kitail, pwen popol pena.  
\v 16 Pwe iaduen, koe li o, koe aja, me koe pan kak kamaurela ol o? De koe ol, koe pan kamaurela li o?  
\v 17 A duen Kaun o pan on amen amen, duen Kot molipe on amen amen, iduen dadaurata; nan iduen nai ilakilan momodijou akan karoj.  
\v 18 Ma amen me paeker ni jirkomjaij, i en dadaurata a jirkomjaij, a ma amen me paeker ni jojirkomjaij, i ender ian jirkomjaij.  
\v 19 Pwe kaidin meakot jirkomjaij, o pil kaidin meakot jojirkomjaij, a wiawia kujoned en Kot akan.  
\v 20 Amen amen en dadaurata udan a koa ni a paeker.  
\v 21 Ma koe paeker ni om ladu, koe der injenjuedeki, a ma koe pan kak maioda jan, ari pil me mau.  
\v 22 Pwe ladu men, me paeker on Kaun o, nan a maio ren Kaun o; o pil dueta me maio men paeker ap pan ladun Krijtuj men.  
\v 23 Komail me neti kidar pai eu, der wiala ladun aramaj akan.  
\v 24 Ri ai kan, amen amen dadaurata ut arail ren Kot.  
\v 25 A duen peinekap akan, jota kujoned eu jan ren Kaun o; a pein ai lamelam mia, pwe i aleer mak en Kaun, pwen kak melel.  
\v 26 let me i lameda, me mau on aramaj jota papaud, pwe ni anjau apwal wet.  
\v 27 Ma koe kapapaud on li amen, ender men muei jan, a ma jo om paud mia, ender rapaki li amen.  
\v 28 A kaidin dip eu, ma koe pan papaud; o ma jeripein amen pan papaud, kaidin dip. A a pan apwal on mepukat ni pali uduk arail. A nai jota men, me apwal kot en lel on komail.  
\v 29 A ri ai kan, mepukat i indada, pweki anjau o me motomot. A pil eu: Me mau on me ar warok mier, en wia dene jota ar warok;  
\v 30 O me kin janejan, dene jota janejan; o me kin pereperen, dene jota ar peren; o me kin netinet, dene jota ar kapwa.  
\v 31 O me dodokki jappa, ren kalaka, pwe eder wiaki me jued. Pwe mom en jappa et pan rojala.  
\v 32 A i men, komail ender lodi on me apwal. Me jota papaud, kin apwali me japwilim en Kaun o, duen a pan kaperenda Kaun o.  
\v 33 A me papaud, kin lamelame, me kon on jappa, duen a pan kaperenda a paud.  
\v 34 A nan pun en li papaud o peinekap me wuk pajan: Me jota papaud, kin apwali me japwilim en Kaun o, pwen jaraui ni pali war o pil ni pali nen; a me papaud, kin inon ion me kijan jappa, duen a pan kak kaperenda a warok.  
\v 35 Mepukat i inda wei, pwen kamaui komail, a kaidin pwen jaliedi komail, a pwen jauaja komail, pwe karoj en inen o pun re omail, o pwe komail en papa Kaun o.  
\v 36 A ma amen lamelame, me japun, ma a jota pan mueid on na jeripein, me mau on papaud, en papaud; ari, a pan wia duen me a mauki, pwe kaidin dip, ma a pan mueid on i en papaud.  
\v 37 A ma amen me kelail ni monion i, pil kelail on kaunda, pein injen a, ap inauki on nan monion i en kolekol na jeripein, I me mau.  
\v 38 Ari, ma amen pan papaud me mau, a ma amen jota pan papaud, me mau jan.  
\v 39 Li papaud amen me kaupina kidi pun en papaud arain a warok memaur; a ol o lao mela, nan a maio on kapapaud, me a mauki, i eta; a en wiaui ren Kaun.  
\v 40 Meid pai, ma a pan dadaurata a kirip duen me i lameda, A nai aja, me Nen en Kot pil kotikot re i.   
\c 8  
\p
\v 1 A kitail ajaer duen mairow on ani mal, pwe kitail karoj me lolekow. A lolekow eta kin kaaklapalapiela, a limpok kin kamauiela. wiaw. in. iu  
\v 2 A ma amen aklapalapaki a lolekon, nan a jota non dedeki duen me itar on en aja.  
\v 3 A ma amen pok on Kot, nan Kot me mani i.  
\v 4 A kitail dedekier duen mana uduk en mairon on ani mal akan, pwe ani mal amen jota katepa nin jappa, o jota amen Kot, pwe I me ta men.  
\v 5 Pwe ma akai mia, me adaneki kot, me kin mimi nanlaw de nin jappa, pwe kot toto o monjap toto mia;  
\v 6 A atail Kot me ta men, me Jam, me dipijou karoj tapi jan re a, o me kitail wiaui on. O atail Kaun me ta men: Iejuj Krijtuj, me wiadar meakaroj, o me kitail pil wiaui kidar i.  
\v 7 A kaidin karoj me aja mepukat, pwe akai mia, me lamelame, me ani mal meakot, ap kankan uduk en mairon on ani mal, o iei injen luet arail kin jamin kila.  
\v 8 A kijin mana jota kin jauaja kitail ren Kot. Ma kitail jota pan mana, kitail jota pan jued kila, a ma kitail pan mana, kitail jota pan mau kila.  
\v 9 A kalaka komail, pwe omail jaladokalar ender kadipikelekel on me luet akan!  
\v 10 Pwe ma koe, me aja tiak, ap manamana nan im en ani mal o, a me luet amen pan kilan om manamana, ap aima kida nan injen a, ap ian manamana mairon en ani mal akan,  
\v 11 Iduen ri atail luet amen, me Krijtuj mata kilar, pan mekila om jaladok.  
\v 12 A ma iduen omail dip ion ri atail akan, me kin kawela injen luet arail, nan komail kin wia dip ion Krijtuj.  
\v 13 Ari ma kijin mana kamakar ri ai, i jolar pan mana uduk kokolata, pwe i de kamakar ri ai.   
\c 9  
\p
\v 1 KAIDIN nai maiodar? Kaidin wanporon amen nai? I jota udialer Iejuj atail Kaun? Kaidin ai wiawia pan Kaun o komail?  
\v 2 Ma i jota wanporon amen on me tei ko, a on komail; pwe komail kajale pan ai koa en wanporon pan Kaun o.  
\v 3 Iduen i kin japenki, ma meamen kin kalelapok re i.  
\v 4 A jota muei ow kit er, en mana o nim?  
\v 5 A jota muei on kit er, en paudeki li amen, me pan ian kit jailok jili, duen me wanporon tei kan, o ri en Kaun o, o Kepaj kin wiada?  
\v 6 De nai o Parnapaj eta me a jota muei on liki jan dodok en pa at?  
\v 7 Ij me kin ian mauin ap pwain pein i? Ij me wiada mat en wain eu, me jota kin kan kijan wa? Ij me kin kamana pwin man akan me jota kin kan pil en didi en man oko?  
\v 8 Mepukat i jota kin inda nin tiak en aramaj akan, pwe kaidin kapun o me pil majanier due?  
\v 9 Pwe a intinidier nan kapun en Mojej: Koe der pira pena au en kau ol amen, me kin tiaka pajan korn. Iaduen, Kot kin apapwali kau ol akan?  
\v 10 De kaidin pweki kit, me a kotin majaniekier mepukat? Pwe me kin japajap, en kaporoporeki a dodok; o me kin dolun en kaporoporeki, me a pan ian ale kijan wa.  
\v 11 Pwe ma kit wiai on komail japajap nenin, a kaidin me kajampwal kot, me komail pan apwali kit ni pali uduk.  
\v 12 A ma a muei on me tei kan, ale jan omail dipijou kan, nan kit me jo mau on jan irail? Ari jo, kit jota kol on kit tiak wet, a je men mia ni at apwal akan, pwe jen de karompwa ronamau en Krijtuj.  
\v 13 Komail jota aja, me irail, me jopijokki jaraui, pil manamana jan nan im en kaudok, o me irail, me kin papan pei jaraui, pil aleki pwaij ar jan pei jaraui?  
\v 14 Iduen Kaun o kotin majani, me irail, me padaki ronamau, pil pan manaki ronamau.  
\v 15 A nai jota kin kol on ia eu ren mepukat, o i jota intin wei mepukat, pwe komail en kapwai on ia mepukat, pwe a mau on ia en mela, mon amen pan kawela mar ai.  
\v 16 Pwe ma i padaki ronamau, jota me i en juaiki, pwe i en udan wiada; pwe jued on ia, ma i jota padaki ronamau.  
\v 17 Pwe ma i peren kida dodok wet, i pan ale katin, a ma i kan wiada, nan kujoned mia, i en wiada.  
\v 18 Ari, ia katin pai ni ai padaki ronamau ap jota pwaipwai, pwe i ender akapwaipwaiki jan ronamau meakot.  
\v 19 Pwe nai me udan maiodar jan amen amen, ari jo, i wia kin ia ladun amen amen, pwe i en kamaurela me toto duen i kak on.  
\v 20 I wia kin ia Juj amen on Juj akan, pwen kamaurela Juj akan; o on irail, me mi pan kapun, dueta pan kapun amen, pwen kamaur ir ala, me mi pan kapun; ari jo, nai jolar mi pan kapun.  
\v 21 On irail me jota mi pan kapun, i wia kin ia me jota mi pan kapun amen; ari jo, kaidin nai me likin kapun mon Kot, pwe I kin mi pan kapun en Krijtuj, pwen kamaurela me jota mi pan kapun.  
\v 22 On me luet akan, i wia kin ia me luet amen, pwen kamaurela me luet akan. Nai wiala jon karoj on amen amen, pwen kamaurela akai waja karoj.  
\v 23 I me i kin wiawia pweki ronamau, pwe i en ian i pwai jaijki.  
\v 24 Komail jota aja, duen men weir en tan, irail karoj kin tan, a amen ta, me pan ale pai? Komail ari en tan idipok, pwe komail en ale.  
\v 25 A amen amen me aktan idipok, kin ijejol pokon. Irail kin wia me, pwen ale mar kamon a kitail, pwen ale me jo kamon.  
\v 26 Arai ari aktan jopuiok; nai kin pepei, a kaidin dueta me woki nan wawa;  
\v 27 Pwe i kin jok pon war ai, pwen katenedi, pwe i de padaki on akai, ap pein lokidokila.   
\c 10  
\p
\v 1 PWE ri ai kan, i men, komail en aja duen jam atail akan, me mi pan palin dapok eu o kotela madau o.  
\v 2 Irail karoj ap paptaij on Mojej ni palin dapok o ni madau o,  
\v 3 O karoj tunoler jak nenin,  
\v 4 O karoj nim jan pil nenin; pwe irail nim jan paip nenin, me kotikot re ’rail, iei paip o Krijtuj.  
\v 5 A me toto re ’rail, me Kot jota kak kupuramauki, pwe irail lokidokilar nan jap tan.  
\v 6 A mepukat wiauier, pwe kitail de kaalemoni, pwe kitail ender inon ion me jued akan duen irail inon ion.  
\v 7 Komail pil ender kati ani mal due irail, duen a intinidier: Aramaj pukat mondi penan nam o nim ap uda madomadon.  
\v 8 Kitail pil der wia nenek, duen me akai irail wiadar, ap rianen jilekid mekilar ni ran ta ieu.  
\v 9 Kitail pil der kajonejon Krijtuj, duen akai irail kajonejon i, ap mekilar jerpent kai.  
\v 10 Komail pil der lipaned, duen akai ir lipanededar, ap kame kilar men kamekam men.  
\v 11 Mepukat karoj wiaui on irail men kaalemoni; ap intinidier, pwe men panaui kin kitail, pwe kitail leler imwin kaua.  
\v 12 Ari ma amen lamelame, me a kajinenda, en kalaka pein i, pwe a de pupedi.  
\v 13 Jota jonejon eu lel on komail, i eta, me aramaj itar on pwe Kot me melel, me jota kin mueid on komail Jonejon eu me komail jota itar on, A ni jonejon a pan kotin kaimwijokela duen me pan kak pa omail  
\v 14 Ari kompoke pai kan, komail tane jan kati ani mal!  
\v 15 Mepukat i indai on komail, pwe komail me lolekon; a pein komail kajauiada, me i inda.  
\v 16 Dal en pai me kit kin kapaiada, kaidin i dal en atail jaupena ren ntan Krijtuj? O prot me kit kin pilitiki pajan, kaidin i atail jaupena en war en Krijtuj?  
\v 17 Pwe kitail me toto me lopon ta ieu, o war ta ieu, pwe kitail karoj tunole jan lopon ta ieu.  
\v 18 Komail kilan Ijrael pali uduk. Irail me kin kan jan mairon, kaidin irail pil minimini on pei jaraui?  
\v 19 A da me i en inda? I en inda me mairon on ani mal meakot? De dikedik en ani mal meakot?  
\v 20 A karoj me men liki kan maironki, re kin maironki on tewil akan a kaidin on Kot. A I jota mauki, komail en minimin on tewil akan.  
\v 21 Komail jota kak nima jan dal en Kaun o pil jan dal en tewil akan; komail jota kak ian tepel en Kaun o pil tepel en tewil akan.  
\v 22 De kitail en palian Kaun o? Kitail me kelail jan i?  
\v 23 A muei oner meakaroj, a kaidin karoj me kin kamaula; a muei oner meakaroj, a kaidin karoj me kin kapunla.  
\v 24 Jota amen me pan apwali pein a dipijou, a en amen.  
\v 25 Karoj me kin netila nan wajan netikila uduk, komail kan, ap der kalelapok duen jon ar, pwe komail der katoutouki injen omail.  
\v 26 Pwe japwilim en Kaun jappa o audepa kan.  
\v 27 A ma amen, me jopojon pan luke komail, en toun kapara kamadip, o ma komail men ian, ari, karoj me pan nek on komail, komail en kan, ap der kalelapok duen jon a, pwe komail der ka toutouki injen omail.  
\v 28 A ma amen pan indan komail: Met kijan mairon en ani mal, komail der kan pweki i, me kajaledar, pwe komail der kawela injen arail.  
\v 29 A met i jolar inda duen pein injen om a duen injen en amen. Pwe menda injen en amen pan kajauiada ai jaladokelar?  
\v 30 Pwe ma i ian kan ki danke, menda i en kalok jued, pwe i tunole ni ai danke?  
\v 31 Ari, ma komail kan de nim de wia meakot, komail en wia meakaroj, pwen wauneki Kot.  
\v 32 Komail der kadipikelekel men Juj, de men Krik, de momodijou en Kot,  
\v 33 Duen i kin pok on amen amen ni ai wiawia kan karoj, o jo moneki me pein ai, pwen jauaja me toto, pwe irail en dorela.   
\c 11  
\p
\v 1 KOMAIL idauen ia do duen I kin idauen Krijtuj.  
\v 2 I kin kapinaki komail omail tamataman ia ni meakan karoj, o dadaurata pun kan, duen i kakalikidi on komail er.  
\v 3 A i men, komail en ajadar, me Krijtuj tapwin ol akan, a ol me tapwin li, a Kot me tapwin Krijtuj.  
\v 4 A ma amen amen ren ol akan wia kapakap de kokop ap lijoropedi, a kin kajuedeki pein mon a.  
\v 5 A ma li amen wia kapakap de kokop, ap jota lijoropedi, nan I kin kajuedeki pein mon a, pwe a rajon me pit en mon a jeijei jan.  
\v 6 Pwe ma li amen jota lijoropedi, en koteda, a ma a kanamenok li en kotedar o kotokot, i en pwaindi mon a.  
\v 7 A ol o ender lijoropedi, pwe i me kajanjal o linan en Kot, a li o me linan en ol o.  
\v 8 Pwe ol jo tapi jan li, a li jan ol o.  
\v 9 Pwe ol jota wiaui on li, a li wiaui on ol o.  
\v 10 I me li o en kida manaman eu pon mon a pweki tounlan kan,  
\v 11 Ari jo, li amen jota kak mia ma jota ol; o ol amen jota kak mia, ma jota li, a mepukat ren Kaun o.  
\v 12 Pwe duen li o a tapi jan ol, iduen ol o wiaui kida li, a karoj wiauier ren Kot.  
\v 13 Komail en pein kajauiada, ma a janjal mau, ma li amen kapakap on Kot, ap jo lijoropedi.  
\v 14 De pein komail aja, me kanamenok pan ol, ma a pwili peipei.  
\v 15 A linan en li a pwilipeipei, pwe pid en mon a en ko on i, en pwaindi i.  
\v 16 A ma amen re omail men akamai, a en aja, me kit jota kin wia due, momodijou en Kot akan pil jo.  
\v 17 A ni ai kujonededa me pukat i jota kin kapina omail pokon pena, me jota kin ka maui a kajuedeki komail,  
\v 18 Pwe ni omail pokon pena nan momodijou, i ronadar, me komail kin liak toror pajan, o i mur kamelele.  
\v 19 Pwe komail en liak toror pajan, pwe me pun kan en janjal kida re omail.  
\v 20 Komail lao pokon pena waja kij, kaidin i jak kamadip en Kaun o.  
\v 21 Pwe ni kamadip toun kapar kin amatan maj, a amen men manadar, a amen jokolar.  
\v 22 Jota im omail, waja en mana o nim? De komail kin mamaleki momodijou en Kot o kanamenok ir ala, me jota ar tunol? Da me i en inda? I en kapin komail? Ni mepukat i jota pan kapina.  
\v 23 Pwe i aleer jan ren Kaun o, me i pwiliki on komail er, me Kaun Iejuj pon ota en a panala, a limada prot,  
\v 24 Murin a laolaoki, kamauieda, pilitiki pajan, majani: Ale tunole war ai met et, me pilitiki on komail, en wia, pwen katakataman kin ia.  
\v 25 A murin jak, a pil kotin limada dal majani: Dal wet iei inau kap, me wiaui kidar nt’ ai. Pan pak en omail nima jan, komail wiaki men kataman kin ia.  
\v 26 Pwe pan pak en omail kan prot wet o nima jan dal wet, Komail kajanjaleda en Kaun a matala, lao a kotido.  
\v 27 Ari me kan prot wet o nim jan dal en Kaun o ap jo war on iei me dip ion war o ntan Kaun o.  
\v 28 Amen amen en kajauiada pein i, ap kan jan prot o nima jan dal o.  
\v 29 Pwe me kan o nim jowar, kin kan o nim kadeik on pein i, pwe a jota kajampwaleki war o.  
\v 30 Nan i me toto nan pun omail me luetalar o jomaudar, o me toto mairedier.  
\v 31 Pwe ma kitail kajauiada pein kitail, kitail jota pan pakadeikada.  
\v 32 A ma kitail pan pakadeikada, kitail pan kalokolok ren Kaun o, pwe kitail de ian men liki lokidokila.  
\v 33 Ari ri ai ol akan, komail lao pokon pena pwen jak, en papajan pena amen amen.  
\v 34 A ma amen men manadar, i en mana maj nan im a; pwe komail de pokon penan kadeik o. A me lua kan i pan kapunala ni ai pwara won.   
\c 12  
\p
\v 1 RI ai kan, i jota men, komail en jaja duen pwaij nenin akan.  
\v 2 Komail ajaer, me komail tikidar men liki, ap kakalua ren dikedik en ani loten akan, duen komail kakaluaer.  
\v 3 I me i men kaaja kin komail, jota amen, me lokaiaki Nen en Kot, kak kariala Iejuj. o jota amen me pan kak inda: Main Iejuj, ma jo ren A Nen jaraui.  
\v 4 A pai en mak akan me wuki pajan, a Nen me ta men.  
\v 5 A jon en dodok me toto, a kaun me ta men.  
\v 6 O akai jon en manaman mia, a Kot me ta men, me kotin wiawia meakaroj ren amen amen.  
\v 7 A pwaij en Nen jaraui me pan on amen amen, pwen men kamauiada.  
\v 8 Pwe amen ereki majan en erpit ren Nen, a amen majan en kaparok ren Nen ota.  
\v 9 O on amen, en pojon, a ren Nen ota, o on amen pai kan, men kakelada me jomau kan, a ren Nen ota.  
\v 10 O on amen, en wiada manaman, o on amen, en deideikop, o on amen, en kajaui nen akan, o on amen, en lokaia nil wuki pajan, o on amen, en kawukila nil akan.  
\v 11 A mepukat karoj wiawian Nen ota, nene on amen amen duen kupur a.  
\v 12 Pwe duen war eu ta ap kokon toto mia, a kokon en war karoj wiala war ta ta ieu, iduen Krijtuj.  
\v 13 Pwe Nen ta ieu, me kitail paptaijeki on war ta ieu, ma kitail men Juj de men Krik, ma ladu de me maioda, kitail karoj me paptaijeki Aen ta ieu.  
\v 14 Pwe war kaidin kokon ta ieu, pwe kokon toto.  
\v 15 A ma pat en na pan inda: Nai kaidin kumut eu, o i me nai jota kijan war; a iaduen, i me a jota pan kak kijan war o?  
\v 16 A ma jalon o pan inda: Kaidin nai kijan war o, pwe kaidin por en maj eu nai; a iaduen, i me a jota kijan war o?  
\v 17 Ma war pokon por en maj eu, da me pan jalon o? A ma war pokon pan jalon o, da me pan tuma?  
\v 18 Ari, Kot me kotin kokon penan war ta ieu kajon akan, duen a kotin kupureda.  
\v 19 A ma kokon karoj wiala kokon ta ieu, ia pan war o?  
\v 20 Ari, kokon akan me toto, a war o me ta ieu.  
\v 21 Por en maj eu jota kak indan kumut: Kaidin meakot re i koe; de pil tapwi jota kak indai on pat en na kan: Kaidin meakot re i koma.  
\v 22 Pwe kokon en war kai likamata re me luet, a jo, pwe re me kajampwal.  
\v 23 O kokon en war kai, me kitail kin lamelame, me re jota non mau, kitail kin apapwali jan me tei kan, o irail me jota non janjal mau, kitail kin kapwataki.  
\v 24 Pwe irail me janjal mau, jota kin mau on en kapwataki. A Kot kotin kapad pena war o kapwataki me luet oko jan me tei kan,  
\v 25 Pwe war de japarok pajan, a kokon akan en apapwali pena.  
\v 26 O ma kajan ta ieu matakada, kajan karoj ap ian matakada; o ma kajan ta ieu pan kalinanada, kokon karoj pan ian polauleki.  
\v 27 A komail war en Krijtuj o kokon akan amen amen duen pwaij a.  
\v 28 A iet akan, me Kot kotiki on momodijou: Kaieu wanporon akan, ap jaukop akan, a kajilu jaunpadak kan, ap me wiada manaman akan, ap pai kan men kakelada me jomau kan, ap men jauaja, o jaumaj akan, o jon en lokaia.  
\v 29 Iaduen irail karoj me wanporon akan? Karoj me jaukop akan? Karoj me jaunpadak kan? Karoj me men wia manaman akan?  
\v 30 Karoj ar pai en mak kan, men kakelada me jomau kan mi ren karoj? Karoj kin lokaia nil pajan? Karoj kin kajiriwuk lokaia?  
\v 31 A komail inon ion pai en mak lapalap akan, i ap pan kajale on komail al apot, me mau jan mepukat karoj.   
\c 13  
\p
\v 1 MA i aja lokaia en aramaj akan o tounlan kan, ap jota limpok, nan i rajon nil en mata mal de nil en jimpel.  
\v 2 O ma i aja deideikop o ereki me rir akan karoj, o tiak kan karoj, o nai dir en pojon, me itar on en kamokid wei nana kan, ap jota limpok nan jota meakot nai.  
\v 3 O ma i pan kijakija wei ai dipijou karoj, pwen katunoleki me jamama kan, o ma i kida war ai, pwen karonala, ap jota limpok, nan jota katepa on ia.  
\v 4 Limpok kin kanonama o kadek, limpok jota kin peirin limpok jota kin akmomo o jo kejej.  
\v 5 A jota kin aklemai, a jota kin roporop on pein i, a jo jerkailon, a jota kin depuk on en amen a jued.  
\v 6 A jota kin peren me japun, a a kin perenki me melel.  
\v 7 A kin kak pa meakaroj, o kin pojon karoj, a kaporoporeki karoj, o lolin on meakaroj.  
\v 8 Limpok jota pan tukedi, a deideikop akan pan tukedi, o lokaia kan pan jola, o lolekon pan kunla.  
\v 9 Pwe kitail me er pali ta, o kokop pali ta.  
\v 10 A lao kaunjokala, me pali ta pan momela.  
\v 11 Ni ai jeri i kin lokaia dueta jeri amen o i lamelame dueta jeri amen, o kajaui dueta jeri amen, a i lao wiala ol amen, i muei jan tau en jeri.  
\v 12 Pwe anjau wet kitail kin ireron nan klaj edied eu, a mur a pan janjal mau. Anjau wet i ekij lolekonlar, a mur i pan aja duen a aja ia.  
\v 13 Ari jon jilu pukat: Pojon, kaporopor o limpok pan mimieta, a me lapalap re ’rail limpok.   
\c 14  
\p
\v 1 KOMAIL anane limpok, pil inon ion pai nenin akan, a iet me kajampwal re ’rail, kokopada!  
\v 2 Pwe me kin lokaia kida nil en wai, kaidin aramaj akan, me a kin lokaia on, a on Kot, pwe jota amen kin dedeki; ari jo, ni nen o a kin lokaia kida me rir akan.  
\v 3 A me kin kokop, kin padaki on aramaj akan, pwen kamaui, o panau o kamait ir ala.  
\v 4 A me lokaiaki nil en wai, kin kamaui pein i, a me kin kokop, kin kamaui momodijou.  
\v 5 I men, komail karoj en aja lokaia ki nil toror, a mak eta, komail en kokopada, pwe me kin kokopada, me lapa jan me kin kaparok ki nil toror, ma a jo kak kajiriwukila, pwe momodijou en kamaukila.  
\v 6 Ari ri ai kan, ma i pwara won komail, ap lokaia ki nil toror, da katepa on komail, ma I jota kaweweda de kajanjaleda, de kokopada, de padak?  
\v 7 Iduen meakan, me kin lokolokaia ap jota memaur, ma men kwai de arp jota pan nor pajan, ij me pan kak dedeki, da me ira kauleki?  
\v 8 O ma koronete pan popeuk pin, ij me pan onopadan mauin?  
\v 9 A iduen komail, ma komail pan lokaia ki nil toror, ap jota kaweweda, ij me pan dedeki? Pwe omail lokaia pan me mal kot.  
\v 10 Jon en lokaia toto nan jappa, a jota eu me jo puloi.  
\v 11 A ma i jaja wewe en lokaia eu, i pan rajon men wai men on me kin kaparok, o me kin kaparok, pan rajon men wai men on ia.  
\v 12 A pil dueta komail, pwe komail kin anane pai nenin akan, komail ari pil nonki kakairida ni mepukat, pwen kamauie kila momodijou.  
\v 13 A ma amen lokaia kida nil en wai, i en kapakap ap pil kajiriwukila.  
\v 14 Pwe ma i wia kapakap ki lokaia nil en wai eu, nen i kin kapakap ap jota katepa on amen.  
\v 15 Ari, da me i pan wia? I pan kapakap ni nen i ap pil pan kapakap ni ai lamelam; i pan kapina ni nen i ap pil kapina ni ai lamelam.  
\v 16 A ma koe pan kapaiada ki nen o, iaduen me jota dedeki pan kak inda amen murin om kapina? Pwe a jaja me koe indinda.  
\v 17 Ei me mau melel om kapikapina, a jota kadepa on me teio.  
\v 18 I kin danke Kot, pweki i kin lokaiaki nil toror jan komail.  
\v 19 Ari jo nan momodijou i men kida lep in lokaia limau, me pwili jan ai lamelam jan lep in lokaia nen ni nil toror, pwen padaki on me tei kan.  
\v 20 Ri ai kan, komail der wiala jeri ni omail lamelam, a ni me jued komail en rajon kijin jeri, a ni omail lamelam komail en unjokela.  
\v 21 A intinidier nan kapun: Lokaia o kil en aua toror, me I pan lokaiaki on kainok wet, a re pil jota pan duki on ia, me Kaun o kotin majani.  
\v 22 Nan i me lokaia toror mia, pwen kileledi kaidin me pojon akan, a me jopojon akan; a deideikop kaidin on me jopojon akan, pwe on me pojon akan.  
\v 23 A ma momodijou pan pokon pena waja kij, o ma karoj pan lokaia ni nil toror, a ma akai ian me jota dedeki, de akai me jopojon, irail jota pan inda, me komail iakalar?  
\v 24 A ma karoj kin kokop, o amen pan pwarado, me jopojon, o me jota dedeki, karoj pan kajanjale on i dip a, o a pan pakajaui ren karoj.  
\v 25 Iduen a me rir akan nan monion i pan janjaleda, o a pan tairokedi ni maj a, kaudoki on Kot, o pan inda, melel Kot kotikot re omail.  
\v 26 Ri ai kan, iaduen komail ni omail pokon pena, kaidin amen amen kin kida pjalm eu? A amen kin kawewe, a amen nil toror, a amen kajanjal eu, a amen kin kajiriwukila; a karoj en wiaui, en kamauiada.  
\v 27 A ma amen pan wia nil en wai, me ta riamen, de ma me toto, re pan jilimen, a irail pan irok wei a amen en kajirawukila.  
\v 28 A ma jota men kajiriwuk mia, i en nenenla nan momodijou; a en kajoi on pein i o Kot.  
\v 29 A riamen de jilimen ren jaukop akan pan kak kaparok, a me tei kan en kajauiada.  
\v 30 A ma amen, ren me momod waja o, pan diar kajanjal eu, men maj ap pan nenenla.  
\v 31 A komail karoj kak kokop, irok weida, pwe karoj en padakki o kamaitala.  
\v 32 A nen en jaukop akan kin duki on jaukop akan.  
\v 33 Pwe kaidin komoan me pin men Kot, a en popol duen ni momodijou en jaraui akan karoj.  
\v 34 Omail li akan en nenenla nan momodijou kan, pwe a jota muei on irail, en kaparok; a irail en papa, duen kapun me pil majani.  
\v 35 A ma irail men aja okotme, irail en kalelapok ren arail warok kan ni deu ’rail, pwe me kanamenok, li en kaparok nan momodijou.  
\v 36 De majan en Kot tapi jan komail? De a ko won komail eta?  
\v 37 A ma amen lamelame, me a jaukop amen, de me a nenin, a en aja wewe en me i intinki won komail, pwe mepukat kujoned en Kaun o.  
\v 38 A ma amen lolepon, i en lolepon.  
\v 39 Ari ri ai kan en inon ion kokop, o ender kainapwi lokaia nil toror.  
\v 40 A meakaroj en wiaui nin tiak mau o pun.   
\c 15  
\p
\v 1 RI ai kan i men kataman kin komail ronamau, me i padaki on komail er, me komail pil aleer o pil tinain kidar.  
\v 2 O me komail pil dore kila, ma komail pan dadaurata majan o, me i padaki on komail er, ma komail jo pojon mal.  
\v 3 Pwe i ujaki on komail er, me i pil aleer duen Krijtuj, me kamata kilar dip atail akan duen kijin likau kan.  
\v 4 O me a jaredier o kaiajadar ni kajilu en ran duen kijin likau kan,  
\v 5 O me a pwara won Kepaj, ap on irail me ekriamen ko,  
\v 6 Ap kotin pwara won jaulan limepuki jama ni anjau takij; kij arail me toto mimieta lei met, a akai mairedier.  
\v 7 Murin met a kotin pwara won Iakopuj, ap on wanporon akan karoj.  
\v 8 A ikmuri a kotin pwara don ia mon ai ip japal,  
\v 9 Pwe pokindidi ren wanporon akan nai, me jota war on kaindinda wanporon amen, pweki ai pei on momodijou en Kot.  
\v 10 A mak en Kot, me i wanoron kilar. A kaidin mak mal eu on ia, pwe i dodok laud jan irail karoj, ari kaidik nai, pwe mak en Kot, me mi re i.  
\v 11 Ari, ma nai de irail, pwe iduen at padaki wei, o iduen komail pojonlar.  
\v 12 A ma i aude pan at padak, me Krijtuj iajadar jan ren me melar akan, a da me akai re omail kin inda, dene me melar akan jolar pan mauredar?  
\v 13 A ma me melar akan jota pan maureda, nan Krijtuj pil jota iajadar.  
\v 14 O ma Krijtuj jota iajadar, at padak me mal, o omail pojon pil me mal.  
\v 15 O kitail pil pan diarokada, me je jaunkadede likam ren Kot, aki at kadededar, me Kot kotin kaiajadar Krijtuj, me a jo kaiajadar, ma me melar akan jota pan kamaureda.  
\v 16 Pwe ma me melar akan jota pan kamaureda, nan Krijtuj pil jo kaiajadar.  
\v 17 A ma Krijtuj jo kaiajadar, omail pojon me mal, o komail mimieta ni dip omail.  
\v 18 Iduen pil irail, me melar ren Krijtuj akan, lokidokila.  
\v 19 A ma kitail kaporoporeki Krijtuj nan maur et eta, nan kitail me jued jan aramaj akan karoj.  
\v 20 A melel, Krijtuj kaiajadar jan ren me melar akan, ap wiala mejeni nan pun en ir me mamair akan.  
\v 21 Pwe mela tapi jan aramaj ta men, iduen maureda jan ren me melar akan tapi jan aramaj ta men.  
\v 22 Pwe duen karoj me mela ki Adam, nan iduen karoj pan kamaurela ren Krijtuj,  
\v 23 A amen amen ni kakairokdo: Krijtuj maj ap me japwilim en Krijtuj, ni a pan kotin pwarado;  
\v 24 A murin mepukat pan imwi, a lao kotiki on Kot o Jam a wei, a lao kaloedier kaun akan karoj, o me poe kan, o manaman akan.  
\v 25 Pwe a pan kotin kaunda, lao a imwintiti karoj lodi on pan aluwilu a kan.  
\v 26 A ikmurin imwintiti iei mela.  
\v 27 Pwe a kotin mueid on meakaroj pan aluwilu a. Ari ni a kotin majanier me karoj lodier a janjaledar, me i jota ian me kotin kaloedi on i meakaroj.  
\v 28 A meakaroj lao lodi on i, Na ap pil pan upan i, me kotin kaloedi on i meakaroj, pwe Kot en kotin poedi meakan karujia.  
\v 29 A ma me melar akan jolar pan kamaureda, da me irail en wia, me kin paptaijeki on me melar akan? Menda re paptaijeki on irail?  
\v 30 O menda kit kin kalokolok anjau karoj?  
\v 31 Pwe ran karoj i kin mela, pweki kapin pa i, me i aleer ren Krijtuj Iejui atail Kaun.  
\v 32 A ma i pei on man laualo nan Epijuj, duen aramaj akan kin wiada, da kadepa on ia, ma me melar akan jota pan kamaureda? Kitail en mana o nim, pwe lakap kitail pan mela.  
\v 33 Der duki on, me kajonejon komail! Kajoi jued kin kawela tiak mau.  
\v 34 Komail ari punala, o pirida o der wiada dip! Pwe akai jaja duen Kot. Mepukat i indai on komail, pwen kanamenokki komail.  
\v 35 A ele amen pan inda: Iaduen me melar akan ar pan kamaureda? O iaduen war ar, me re pan maur kida?  
\v 36 Pweipwei men koe! Pwe me koe kin kamoredi, jota pan maureda, ma a jota pan mela.  
\v 37 O me koe kamoredi, kaidin war ota me pan para, pwe wan korn eu ta, ele wan wit de eu wa toror.  
\v 38 A Kot pan kotiki on war a, duen a kotin kupura, o eu eu en war akan pan ale udan mom a.  
\v 39 Uduk karoj kaidin jon ta ieu, pwe eu jon uduk en aramaj akan, a eu jon uduk en man akan, a eu jon en manpir akan, a eu jon en mam akan.  
\v 40 A war lan o war pwel akan mia, a linan en war lan eu jon o linan en war pwel eu jon.  
\v 41 A eu jon linan en katipin, o eu linan en maram, o eu linan en uju kan, pwe nan uju kan me wuki pajan ki ar linan eu eu.  
\v 42 Nan iduen en me melar akan ar pan maureda. A kin kamoremoredi ap mor pajan, o pan kamaureda jo mor pajan.  
\v 43 A kin kamoremoredi ni jo linan, o pan maureda ni linan; a kin kamoremoredi ni luet, o pan maureda ni manaman;  
\v 44 A pan kamoremoredi war pwel o pan kamaureda war nenin; pwe ma war pwel mia, nan a pil pan war nenin.  
\v 45 Duen a intinidier: Tapin aramaj Adam wiauier, pwen nen maur amen, a Adam tia mur, pwen nen en kamaur.  
\v 46 A war nenin kaidin i men maj pwe war pwel, a muri me nenin.  
\v 47 Tapin aramaj wiaui kida pwel, a aramaj kariamen kotido jan nanlan.  
\v 48 A duen tapin aramaj wiauiki pwel, iduen karoj me wiauiki pwel o duen men nanlan o, iduen men nanlan kan.  
\v 49 O duen kitail wa mom en pwel, iduen kitail pil pan wa mom en lan.  
\v 50 Ri ai kan, iet me i men inda: Uduk o nta jota kak jojoki wein Kot; o me mor pajan kan jota pan jojoki me jo mor pajan.  
\v 51 Kilan, nai me kadiarok on komail kaponepon eu: Kaidin kitail karoj pan mela, a kitail karoj pan nitwilida.  
\v 52 Madan ni marep ta ieu, koronete en muri lao popeuk. Pwe koronete pan popeuk, a me melar akan ap pan kamauredan jomor pajan a kitail pan kawilikapada.  
\v 53 Pwe mor pajan wet pan kiawikilan jo mor pajan; o mela wet kiawikilan jomela.  
\v 54 A mor pajan wet lao kia wikilan jo mor pajan o mela wet kiawikilan jomela, majan o ap pan pwaida, me intinidier: Maur kadalala mela.  
\v 55 Mela koe, ia om tata? Mela ia om poedi?  
\v 56 Mana en mela dip, a manaman en dip kapun.  
\v 57 Danke on Kot, pwe a kotiki on kitail, en poediki atail Kaun Iejuj Krijtuj.  
\v 58 Ari ri ai kompok kan, komail kelail kaukaule o der wukiwuk jili, a kakairida ni omail wiawia en Kaun o, pwe komail aja, me omail dodok on Kaun o kaidin dodok mal.   
\c 16  
\p
\v 1 A DUEN kijakij on jaraui kan, me komail pan ki pena, i men, komail en wiada, duen i kakaliki on momodijou en Kalejia kan.  
\v 2 Ni at en ran en wik kan amen amen re omail en nikidala ekij, o ki pena duen wan a kak on pwe onop de wiaui, i lao pwara won.  
\v 3 I lao pwara weilar, meakai, me komail pan kileledi, irail me i pan ilakewei, en walan Ierujalem omail kijakij ianiaki kijin likau.  
\v 4 O ma a kon on, i en pil jailok wei; irail ap pan ian ia jailokala.  
\v 5 A i pan pwara won komail ni ai dauli Majetonien, pwe i pan weid nan Majetonien.  
\v 6 Ele i pan mimieta re omail, anjaun kapau lao nikier, pwe komail en kalua ia la waja, me i pan jailokala ia.  
\v 7 Pwe anjau wet i jota pan jup re omail, pwe i kaporoporeki, me I pan mimieta re omail anjau kij, ma Kaun pan kotin mueid on ia.  
\v 8 A i pan mimieta Epijuj lao pentikoj.  
\v 9 Pwe wanim talap ritida mo i, me kareda wa toto; a imwintiti me toto.  
\v 10 A Timoteuj lao pwara won komail, apwali i, pwen jondi mau re omail, pwe a kin ian ia wiawia dodok en Kaun o.  
\v 11 Jota amen en mamaleki i, a kalua i don ia popol, pwe nai o ri atail akan kin auiaui i.  
\v 12 A duen ri atail Apoloj, nai me poeki re a pan pak toto, en ian ri atail akan pwara won komail, a a kan pwara wei anjau wet; a a pan pwara wei lao anjau mau.  
\v 13 Komail majamajan o dadaurata ni pojon, komail wia duen ol melel, o komail en kelail.  
\v 14 Meakaroj en wiaui ni limpok  
\v 15 I ari panaui komail, ri ai kan, pwe komail aja penainai en Jtepanaj, me ir tapida jaulan en Akaia, o me pein irail inon ion dodok on jaraui kan,  
\v 16 Pwe komail en peiki on irail, o on irail karoj me ian ni ar wiawia o dodok.  
\v 17 I peren kida en Jtepanaj, o Portunatuj, o Akaiuj ar pwarador, pwe mekij, me komail jo ki on ia mepukat ki don ia.  
\v 18 Irail kaperenda nen i o pil nen omail; komail ari wauneki me due met.  
\v 19 En momotijou en Ajien akan ar ranamau won komail. A Akwila o Prijila kin ranamau won komail pan Kaun o momodijou nan im ara.  
\v 20 Ri atail ol akan karoj kin ranamau won komail. Komail ranamauki pena metik jaraui.  
\v 21 Nai Pauluj me intin kilan komail ai ranamau ki pein pa i.  
\v 22 Ma amen jota kin pok on Kaun Iejuj Krijtuj, a pan anatema! Maranata! let wewe; A pan riala! Atail Kaun kotido.  
\v 23 Mak en Kaun Iejuj Krijtuj en mimieta re omail!  
\v 24 Ai limpok on komail pan Krijtuj Iejuj pan mimieta re omail! Amen.   