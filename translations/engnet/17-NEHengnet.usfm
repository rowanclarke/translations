\p 
\v 15 \w It|strong="H6213"\w* \w so|strong="H6213"\w* \w happened|strong="H6213"\w* \w that|strong="H5704"\w* \w when|strong="H5704"\w* \w our|strong="H3318"\w* adversaries heard \w that|strong="H5704"\w* \w we|strong="H3068"\w* \w were|strong="H3318"\w* aware \w of|strong="H3318"\w* \w these|strong="H6213"\w* matters, God frustrated \w their|strong="H2388"\w* intentions. \w Then|strong="H3318"\w* \w all|strong="H6213"\w* \w of|strong="H3318"\w* \w us|strong="H6213"\w* \w returned|strong="H5927"\w* \w to|strong="H5704"\w* \w the|strong="H6213"\w* wall, each \w to|strong="H5704"\w* \w his|strong="H6213"\w* \w own|strong="H2388"\w* \w work|strong="H4399"\w*.
\v 16 \w From|strong="H3117"\w* \w that|strong="H5971"\w* \w day|strong="H3117"\w* \w forward|strong="H1571"\w*, \w half|strong="H8432"\w* \w of|strong="H3117"\w* \w my|strong="H1961"\w* \w men|strong="H5288"\w* \w were|strong="H1961"\w* doing \w the|strong="H8432"\w* \w work|strong="H4399"\w* \w and|strong="H3117"\w* \w half|strong="H8432"\w* \w of|strong="H3117"\w* \w them|strong="H8432"\w* \w were|strong="H1961"\w* taking \w up|strong="H1961"\w* spears, shields, bows, \w and|strong="H3117"\w* body armor. \w Now|strong="H1961"\w* \w the|strong="H8432"\w* officers \w were|strong="H1961"\w* behind \w all|strong="H3885"\w* \w the|strong="H8432"\w* \w people|strong="H5971"\w* \w of|strong="H3117"\w* Judah
