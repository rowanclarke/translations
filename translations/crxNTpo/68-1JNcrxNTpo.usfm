\id 1JN - Central Carrier NT -Canada 2011 (DBL -2013) 
\h 1 John 
\toc1 'Udechoo 'Udustl'us John 'Uk'eyánguz-i 
\toc2 1 John 
\toc3 1 Jn 
\mt1 'Udechoo 'Udustl'us John 'Uk'eyánguz-i 
\c 1  
\s1 Ndi khuni be ts'úkhuna-i, 'i ghun 
\p  
\v 1 Soo 'udechoo da' whuts'un hoonli-un soo ts'ih'un un'a whuzdánts'o-un, nena be cha ts'onalh'en, 'ink'ez nela be cha oot'áts'aznai khuni be ts'úkhuna-i, 'i ghun. 
\p  
\v 2 Ndi be ts'ukhuna-i nenalhts'et hahóolts'ut 'ink'ez ts'ohon'en 'ink'ez howu yats'alhduk. Ndi 'ilhiz be ts'ukhuna-i neBá bulh 'unt'oh. 'I nenalhts'et hahóolts'ut, 'et huwun nohts'udáni'. 
\p  
\v 3 Ndet la ts'ohon'en-un 'ink'ez ts'odánts'o-un, 'et huwun nohts'útni. 'Et whe la lhulh 'uts'int'oh ts'oole'. 'Et 'alha neBá 'ink'ez ooYe' Sizi Gri 'enne bubulh 'ilho uzdidowh. 
\p  
\v 4 'Ink'ez ndi ts'iyawh huwun nohts'ó k'e'ts'anguz, 'et whe la tube cho whunólhni. 
\s1 Ndi be hoot'en-i, 'i ooniz ts'idulh de, 'et de 'ilhoh 'uts'int'ohne ts'inli 
\p  
\v 5 Ndi khuni ts'odánts'o-un 'i 'unt'oh, 'en ts'ahálts'ut-i, 'i ghun nohts'útni Yak'usda be hóot'en-i 'unt'oh, 'ink'ez 'aw tsálhgus ooghu hooloh gaih. 
\p  
\v 6 'En bulh lhulh 'úts'int'oh ts'utni de, 'ink'ez tsálhgus yo ts'e ts'idulh de, 'et ts'uwhuts'it whe' ts'utni, 'ink'ez 'aw khuni 'alha' 'unt'oh-i ook'unulhe'ts'ust'en. 
\p  
\v 7 'Et hoonts'i be hoot'en-i bulh 'unt'oh, 'i ooniz ts'idulh de, 'et de 'ilhoh lhulh 'uts'int'ohne ts'inli 'ink'ez ooYe' Sizi Gri buzkai' be nelubeshi ts'iyawh yuna'alhde. 
\p  
\v 8 'Aw lubeshi lhts'it'ih ts'utni de, na'uzdunut'ah 'ink'ez khuni 'alha 'unt'oh-i neghu hooloh. 
\p  
\v 9 Lubeshi 'uts'alh'en ts'utni de, 'aw nelalhdutisni 'ink'ez ts'ih'un 'unt'oh whe nelubeshi neba yunaoodutilnoh 'ink'ez tank'us un'a 'uhoont'oh-un, ts'iyawh whuch'a neyuna'tilhdoh. 
\p  
\v 10 'Aw lubeshi lhe'ts'ílel ts'utni de, Yak'usda whuts'it-un 'unt'oh ts'utni whe' ts'utni, 'ink'ez ooghuni, 'aw neghu hooloh. 
\c 2  
\p  
\v 1 Suzkehkeyaz, 'aw lubeshi 'utilh'elh whuch'a 'et huwa ndi khuni 'i be nohts'ó k'e'usges. Mbene la lubeshi 'ulh'enne, 'enne buba neBá Yak'usda but neba yatilhduk-un, Sizi Gri, ts'ih'un un'a 'unt'oh-un, 'en 'unt'oh. 
\p  
\v 2 'Ink'ez 'en 'unt'oh nelubeshi k'elha dazsai. 'Aw wheni za iloh. Yinka ndulcho whe whulubeshi k'elha cha. 'I be la neBá soo cho nets'u naítot'en 'et hukwa. 
\s1 Sizi Gri mbe unli, whuz un'a t'ezninzun 
\p  
\v 3 Khuni netl'aidan'ai-i ook'une' ts'ut'en de, 'et whuz un'a t'ets'onínzun 'i gha Sizi Gri t'ezninzun. 
\p  
\v 4 Mbe la 'en t'enuszun ni de, 'ink'ez yughuni yuk'unulhe'ust'en de, 'en whuts'it-un 'unt'oh 'ink'ez ndi khuni 'alha' 'unt'oh-i 'aw lhiyít'ih whe 'unt'oh. 
\p  
\v 5 'Et mbe la yughuni k'une' 'ut'en-un, 'en 'alha Yak'usda ye nék'entsi'-i be ts'ih'un un'a lhadúlya whe 'unt'oh. Njan huwa t'ets'onínzun Sizi Gri ooyúzdults'i whe' ts'int'oh. 
\p  
\v 6 Mbe la ye yudínda-un ni de, nts'en'a la nusuya-un, 'et whuz un'a za nóya' huba' hoont'oh. 
\p  
\v 7 Sulhutsinke\f + \fr 2:7 \ft Ndi khuni, “Sulhutsinke,” mbene la Sizi Gri ooba 'alha' yint'ohne, 'enne 'ants'i lhuzkehke hinli le'hint'oh. 'Et huwa lhulhutsin 'ink'ez lhulhtuske hudli whe' hint'oh.\f* 'aw khuni 'andidi-i netl'aidan'ai-i, 'i ghun iloh nohts'ó k'e'usges. 'Udechoo whuts'un t'enahzun ndi khuni 'uda'-i 'unt'oh. Ndi khuni 'uda'-i, 'udechoo whuts'un dahts'o-i, 'i 'unt'oh. 
\p  
\v 8 Tsalhgus yo 'awet whedúdeh 'ink'ez ts'ih'un be hóot'en-i 'awet be hóot'en suli'. 'Et huwa nohts'ó k'e'usges 
\m 'ink'ez doo cha 'unohdúsni, 'andit khuni netl'aídan'ai-i, 'i ndi 'alha khuni 'i yulh 'únt'oh, 'ink'ez nohni cha bulh 'áht'oh. 
\p  
\v 9 Mbe la be hóot'en niz 'unt'oh ni de, 'ink'ez dulhutsin ts'udutni, 'en 'awhuz tsalhgus yo usda whé 'unt'oh. 
\p  
\v 10 Mbe la dudulhutsin k'entsi'-un, 'en be hóot'en toh 'unt'oh 'ink'ez 'aw tank'us 'utit'elh-un whuts'u nóot'i ait'oh. 
\p  
\v 11 'Et hoonts'i mbe dudulhutsin ts'udutni-un, 'en tsálhgus yo 'unt'oh 'ink'ez tsálhgus yo nuya. 'Ink'ez nts'e tizya-un 'aw t'eoonúszun, ndi tsahólhgus-i be hoos̱'en suli' 'et huwa. 
\s1 Yak'usda ba ulhtusne huzdli' 
\q1  
\v 12 Ts'oodunneyaz Sizi Gri boozi' gha nohlubeshi nohba buna'ide, 
\q2 'et huwa nohts'ó k'e'usges. 
\q1  
\v 13 Nebáke ndult'ohne ndun mbe 'udechoo whuts'un hoonli-un, 
\q2 'en t'enahzun, 'et huwa nohts'ó k'e'usges. 
\q1 Chilke ntsi'-un ooch'a' nulhde 'et huwa nohts'ó k'e'usges. 
\q1 Ts'oodunne neBá t'enahzun, 
\q2 'et huwa nohts'ó k'e'usges. 
\q1  
\v 14 Nebáke mbe la 'udechoo whuts'un 'unt'oh-un t'enahzun, 
\q2 'et huwa nohts'ó k'e'isguz. 
\q1 Chilke ulhtus 'ink'ez Yak'usda ooghuni nohyudín'ai, 
\q2 'ink'ez ntsi'-un ooch'a' nulhde, 
\q2 'et huwa nohts'ó k'e'isguz. 
\s1 Ndiz un'a ndi yun k'ut uzdólts'i' 
\p  
\v 15 Ndi yun k'ut tank'us 'uwhut'en-un 'ink'ez ndi yun k'ut hoonli, 'i cha, whuts'u nóoht'i junih. Mbe la ndi yun k'ut tank'us ne'whut'en ndóohoont'oh-un whuts'u nint'i de, 'aw neBá ye nék'entsi'-i ooghu wheyooloh whe 'unt'oh. 
\p  
\v 16 Neyust'e whuts'ú nint'i-un, 'ink'ez nena whuts'u nínt'i-un cha, 'ink'ez ndai la aht'i-un be 'ududulhti' de, ndi 'i ts'iyawh ndi yun k'ut huba 'unt'oh, 'ink'ez 'aw neBá ts'u halhúhoolts'ut 'et huwa. 
\p  
\v 17 Ndi yun 'awet whewhúlts'it 'ink'ez oots'úznint'i-i cha, 'et hoonts'i Yak'usda hukwa' ninzun te ne'út'en-un, 'en 'ilhiz khutinalh. 
\s1 Mbene la Christ ch'az ditnine, 'enne buch'a khóhdle' 
\p  
\v 18 Ts'oodunne 'awet 'et né'hunint'o whe' hoont'oh. Christ ch'az ditni-un whuz de úyalh whulh údahts'o whe' hoont'oh. 'Andit hoonts'i Christ ch'az ditnine huldlai whe' hoont'oh. 'Et whe t'ets'onínzun 'awet 'et né'hunint'o whe' hoont'óh. 
\p  
\v 19 Nets'u hahándil whe' hint'oh 'et hoonts'i 'aw nebulh didowhne iloh 'uhint'oh. Nebulh didowhne 'uhint'oh de, nebulh za da' hoot'e' oole'. 'Et hoonts'i whehandil 'et huwa la ts'iyanne t'ebunózin 'aw nebulh didowhne lhuhíloh. 
\p  
\v 20 'Et hoonts'i ndun Christ lubeshi ooghu hooloh-un, 'en Ndoni nohyúidan'ai 'ink'ez ts'iyantsuk t'eoonáhzun. 
\p  
\v 21 Ndi khuni 'alha 'unt'oh-i t'enuzahzun huwa iloh nohts'ó k'e'isguz. Ndi khuni t'enahzun 'et huwa nohts'ó k'e'isguz 'ink'ez ndi khuni 'alha' 'unt'oh-i whuts'it ooghu hooloh. 
\p  
\v 22 Mbe la Sizi 'en Christ 'unli 'et whuts'oodidlai-un, 'en whuts'it-un 'unt'oh. 'En Christ ch'az ditni-un 'unt'oh. 'En 'unt'oh neBá 'ink'ez ooYe' bulh whuts'oodidlai. 
\p  
\v 23 Mbe la neBá ooYe' ts'oodidlai-un, neBá cha lhiyít'ih whe 'unt'oh. Mbe la neBá ooYe' ooba 'alha' yint'oh de, ooBá cha yut'i whe 'unt'oh. 
\s1 'Udechoo whuts'un whudáhts'o-un 'ilhiz wheni bulh 'óoht'e' 
\p  
\v 24 'Et huwa 'udechoo whuts'un whudáhts'o-un 'ilhiz wheni bulh 'óoht'e'. 'Et 'udechoo whuts'un whudáhts'o-un nohbulh 'úhoont'oh de, 'et de la neBá 'ink'ez ooYe' cha bubulh útiht'elh. 
\p  
\v 25 Njan nets'ú hoozi-un, 'ilhiz ts'ukhutinalh-un, 'et 'uwhúlhni. 
\p  
\v 26 Mbene la nanohunti'ah hukwa' 'ut'enne, 'enne bughun ndi nohts'ó k'e'isguz. 
\p  
\v 27 'Et hoonts'i Ndoni neBá nohyeídan'ai-i, 'ilhiz nohbulh 'únt'oh, 'ink'ez 'uyoonne dune 'aw 'on 'un whunohodoolh'eh huba lhe'hóot'oh. 'Et k'us ndi nohyudílts'ut-i ts'iyantsuk whunohdulh'eh 'ink'ez ts'ih'un 'unt'oh, 'aw whuts'it-i iloh 'unt'oh. 'Et soo nts'en'a la whunohdalh'e', whuz un'a za bulh 'óoht'e'. 
\s1 Wheni Yak'usda oodune'ne, 'aw hoonli hukwaya lhts'iloh whe la oobut núzdolya' 
\p  
\v 28 Ts'oodunneyaz ndun 'en za bulh 'óoht'e'. 'Et whe la nohnalh ts'et hainya de, 'ink'ez whusanája de, nedzi ulhtus unli 'ink'ez 'aw hoonli hukwaya lhts'iloh whe la oobut núzdolya'. 
\p  
\v 29 'En ts'ih'un un'a 'unt'oh t'eoonáhzun de, t'eoonahzun mbene la ts'ih'un ne'út'enne 'enne Yak'usda yé ulhtus-i be huwhuzdli whe' hint'oh. 
\c 3  
\p  
\v 1 Dalcho-i be la neBá nek'entsi'-un negha óonin'ai, Yak'usda dich'oh uneúlhni buzkeh 'uts'int'oh soo cho whunulh'en. 'Et huwa ndi yun k'ut whut'enne t'enehunúszun, didut 'aw t'ehinúszun 'et huwa. 
\p  
\v 2 Ook'esi'ne 'andit Yak'usda buzkeh ts'inli. Daztit'elh-un 'awhuz nenalhts'et halhúwhulhts'it. 'Et hoonts'i t'ets'oninzun ts'an'en de, soo bunduz tilt'elh, soo nts'en'a la dantoh, whuz un'a uztilh'elh 'et huwa. 
\p  
\v 3 'Ink'ez mbene la whuz un'a hits'un hukwa tse hooline, dutsun hooloh na'hudutiltselh, dant'oh la ootsun hooloh, whuz un'a. 
\s1 Lubeshi 'uts'ulh'en-un ts'iyawh whulazdootnih huba' hoont'oh 
\p  
\v 4 Mbe la lubeshi 'ulh'en, 'aw khuni yuk'únulhe'ust'en-un whe 'unt'oh. 'Et khuni k'uts'uyus de, lubeshi 'uhoont'oh. 
\p  
\v 5 'Ink'ez t'eoonáhzun nelubeshi neba 'ún yutoolhdilh ha ndi yun k'ut nusuya. 'Ink'ez didut 'aw lubeshi ooghu hooloh whe 'unt'oh. 
\p  
\v 6 Mbe la ye yudinda-un, 'aw lubeshi oolh'en ait'oh whe 'unt'oh. Mbe la lubeshi 'ulh'en-un, 'aw lhuyí'el 'ink'ez 'aw t'einúszun. 
\p  
\v 7 Ts'oodunneyaz 'uyoon nanohnoo'ah junih. Mbe la ts'ih'un ne'ut'en-un, 'en ts'ih'un 'unt'oh. Dant'oh la Sizi Gri ts'ih'un 'unt'oh, whuz un'a ndunt'oh whé 'unt'oh. 
\p  
\v 8 'Udechoo whuts'un netsudule lubeshi 'ulh'en. Mbe la lubeshi 'ulh'en, 'en netsudule uniyalh-un 'únt'oh. Njan 'et huwa Yak'usda ooYe' ndi yun k'ut nusúya, 'et whe la netsudule be 'ut'en musai yoolhtselh ha. 
\p  
\v 9 Mbe la Yak'usda yé ulhtus-i bé whuzdli-un, 'en lubeshi lhe'ulh'en. Ndi Yak'usda ts'u hainzut-i, 'i be 'ilhiz wheni ts'ukhutinalh, 'ink'ez 'ilhiz wheni yulh 'unt'oh. 'Et mbene la 'i be whuzdline, 'enne 'aw lubeshi 'uhoolh'en ait'oh. 
\s1 Wheni Sizi Gri unidulhne ts'iyawh lhk'ets'ootsi' 
\p  
\v 10 'Et ndiz un'a Yak'usda buzkeh 'ink'ez netsudule buzkeh cha t'ehunudzun: Mbe la ts'ih'un nulhe'ust'en, k'us dudulhutsin k'elhítsi', 'en Yak'usda uniyalh-un iloh 'unt'oh whe 'unt'oh. 
\p  
\v 11 Soo 'udechoo whe' whudit'en whuts'un ndi khuni dahts'o nja dutni, lhk'ets'ootsi', ni. 
\p  
\v 12 Ndun dune Cain 'en k'un'a iloh. 'En ndun ntsi'-un uniyalh-un 'unt'oh 'ink'ez dudulhutsin yuzilhghi. Ndet hukwa' yinla yuzilhghi? Be 'ut'en untsi' 'ink'ez bulhutsin 'en ts'ih'un ne'ut'en, 'et hukwa' yinla. 
\p  
\v 13 Sulhutsinke ndi yun k'ut whut'enne nohts'o dutni de, khun te nohba hócha junih. 
\p  
\v 14 Neulhutsinke buk'ets'intsi', 'et huwa t'ets'oninzun dats'uzsai le'ts'int'oh 'ink'ez nats'ukhítna' le'ts'int'oh. Mbe la dulhutsin k'elhitsi'-un, 'awhuz dazsai le'unt'oh. 
\p  
\v 15 Mbe la dulhutsin ts'u dutni-un, 'en neghan-un 'unt'oh. 'Ink'ez t'eoonáhzun mbe la neghan-un, 'en 'ilhiz be ts'ukhuna-i ooghu wheyooloh whe 'unt'oh. 
\s1 Sizi Gri neba daja la 'et huwa be lhk'ets'utsi'-i t'ezninzun 
\p  
\v 16 Sizi Gri 'en ye khuna-i neba yuladitni, 'et huwa be lhk'ets'utsi'-i t'ezninzun. 'Ink'ez wheni cha neulhutsinke be ts'úkhuna-i buba oolazdootnih huba' hoont'oh. 
\p  
\v 17 'Et hoonts'i mbe la ndi yun k'ut hoonli ut'i-un whe bulhutsin 'e'dunidzit de, 'ink'ez dudzi be 'aw yugha telhe'nizil de, nts'en'a Yak'usda ye nék'entsi'-i yulh 'útit'elh? 'Et dut'en de, nts'en'a Yak'usda k'etitsi'? 
\p  
\v 18 Ts'oodunneyaz 'aw khuni be za lhk'ets'utsi' uzdoon'. Soo ts'ih'un un'a ne-e'ut'en be cha lhk'ets'ootsi'. 
\p  
\v 19 Njan 'et huwa la t'ets'oninzun khuni 'alha' 'unt'oh-i bulh 'uts'int'oh. 'Et de la oobut nedzi ts'ih'un 'oot'e'. 
\p  
\v 20 Nedzi gha neba nahisda de, Yak'usda 'on nus negha te'ninzun whe 'unt'oh, ts'iyantsuk t'eoonínzun 'et huwa. 
\p  
\v 21 Ook'esi'ne nedzi neba nalhuhusye de, whélhts'uniljut whe Yak'usda oobut núzdilhya. 
\p  
\v 22 Di la oots'o óoka' ts'utni-i, 'i negha íyunle, ooghun-i ts'oontun 'ink'ez hoonzoo whe oonalh ne'ts'ut'en 'et huwa. 
\p  
\v 23 Ndi dughuni netl'aídan'ai, ooYe' Sizi Gri mbe unli neba 'alha' 'oot'e' 'ink'ez lhk'ets'ootsi'. 'Et whuz un'a dughuni netl'aídan'ai. 
\s1 Soo cho huwohle' lhane whe nus hoo'enne na'hududil'i 'uda' netoh 'uhut'en whe' hoont'oh 
\p  
\v 24 Mbe la yughuni oontun-un, 'en Yak'usda yudínda 'ink'ez Yak'usda cha yulh 'unt'oh. Ndoni neyídan'ai 'en be t'ets'onínzun neyo ts'e nebulh 'unt'oh. 
\c 4  
\p  
\v 1 Ook'esi'ne, nudúdeh-i ts'iyawh iloh nohba 'alha 'oot'e'. Ndi nududeh-i oozúlhdzih Yak'usda ba ts'ih'un 'unt'oh tilah. Lhane huwhuts'it whe nus húhoo'enne yun k'ehindil 'et huwa. 
\p  
\v 2 Ndai la nududeh-i Sizi Gri duyust'e be ndi yun k'ut nuseya, ni de, 'i Yak'usda ba ts'ih'un whe 'unt'oh. 'Et whe la Yak'usda ooyughi mbe unli t'ets'onínzun. 
\p  
\v 3 Ts'iyai nududeh-i Sizi Gri duyust'e be ndi yun k'ut nuseya, 'aw lhdusnih de, 'aw Yak'usda bulh lhé'it'oh whe 'unt'oh. 'Et ndi nududeh-i, 'i Christ ch'az ditni-i, 'i 'unt'oh. Whusatiyalh whulhúdahts'o 'ink'ez 'uda' ndi yun k'ut hoonli whe 'unt'oh. 
\p  
\v 4 Ts'oodunneyaz Yak'usda bulh áht'oh 'ink'ez ndunne Christ ch'az ditnine 'uda' buch'a' nulhde. Mbe la nohyudinda-un, 'en ndi yun k'ut 'unt'oh-un netsudule 'en 'unt'oh, yanus 'ultus whe 'unt'oh 'et huwa. 
\p  
\v 5 Ndunt'ohne ndi yun k'ut whuch'e' hinli. 'Et huwa yun k'ut whut'enne buk'un'a yahalhduk 'ink'ez yun k'ut whut'enne buboohoozílhts'ai. 
\p  
\v 6 Wheni Yak'usda ooch'e'ne ts'inli. Mbene la Yak'usda t'eninzunne, 'enne nehudits'o. Mbene la Yak'usda ooch'e' lhilohne, 'enne 'aw lhunehoozílhts'ai. 'Et njan 'et huwa nududeh-i ts'ih'un 'unt'oh-i 'ink'ez tank'us 'unt'oh-i nudúdeh-i t'ebuznínzun. 
\s1 Ts'iyanne lhk'etsi'ne, 'enne Yak'usda yé ulhtus-i bé huwhuzdli 'ink'ez Yak'usda t'ehinínzun 
\p  
\v 7 Ook'esi'ne ts'iyawh lhk'ets'ootsi'. Bé lhk'ets'utsi'-i Yak'usda ts'u hálts'ut whe 'unt'oh. Ts'iyanne lhk'etsi'ne, 'enne Yak'usda yé ulhtus-i bé huwhuzdli 'ink'ez Yak'usda t'ehinínzun. 
\p  
\v 8 Mbe la dulhdune k'elhítsi'-un, Yak'usda t'enuszun whe 'unt'oh, Yak'usda 'en nek'entsi'-un 'unt'oh 'et huwa. 
\p  
\v 9 'Aw 'ílhoghun duYe' 'en ndi yun k'uz yútilh'a'. 'En be la 'ilhiz wheni ts'ukhoona' ha. 'Et whuz un'a Yak'usda ye nék'entsi'-i yunénilhtan. 
\p  
\v 10 Ndiz un'a nja duwhutni, wheni Yak'usda ook'elhts'ítsi' inle', 'et hoonts'i nek'entsi' 'ink'ez duYe' whusayálh'a' nelubeshi k'elha datitsa ha. 'I be la soo cho nets'u naítat'en. 
\p  
\v 11 Ook'esi'ne, 'et whuz un'a Yak'usda nek'entsi' de, wheni cha lhk'ets'ootsi' huba' hoont'oh. 
\s1 Lhk'ets'utsi' de, Yak'usda neyudinda 
\p  
\v 12 'Aw dune Yak'usda yan'enne hooloh. Lhk'ets'utsi' de, Yak'usda neyudinda 'ink'ez ye nék'entsi'-i nedzi yo soo ts'ih'un un'a lhaóodulya. 
\p  
\v 13 Njan 'et huwa t'ets'oninzun Ndoni negha ínin'ai 'et whe bulh 'uts'int'oh 'ink'ez didut cha neyudínda. 
\p  
\v 14 Ndi yun k'ut whut'enne ubutilhyis-un ha neBá duYe' whusayálh'a'. 'Et ts'ohon'en 'ink'ez howu yats'ulhduk. 
\p  
\v 15 Mbe la Sizi Yak'usda ooYe' 'unt'oh ni-un, 'en Yak'usda yuyudínda 'ink'ez didut cha Yak'usda bulh 'unt'oh whé 'unt'oh. 
\p  
\v 16 Ndi Yak'usda ye nék'entsi'-i t'eznanzin 'ink'ez neba 'alha' hoont'oh. Yak'usda nek'entsi'-un 'unt'oh. Mbe la bé lhk'ets'utsi'-i bulh 'únt'oh-un, 'en Yak'usda bulh 'unt'oh 'ink'ez Yak'usda yuyudínda whe 'unt'oh. 
\s1 Ndiz un'a be lhk'ets'utsi'-i soo ts'ih'un un'a neba lhadúlya suli' 
\p  
\v 17 Neba nahudeh dzin 'et si nedzi oolhtus ha, 'et whuz un'a be lhk'ets'utsi'-i soo ts'ih'un un'a neba lhadúlya suli'. Christ didut 'et dunt'oh huwa, wheni cha ndi yun k'ut 'et duts'ínt'oh 'et huwa. 
\p  
\v 18 Bé lhk'ets'utsi'-i 'aw nujut ooghu hooloh. 'Et hoonts'i bé lhk'ets'utsi' soo ts'ih'un un'a lhadúlya suli'-i, 'i nujut 'un whenaínuyukw. Nujut dzoh nunéulhdzut whe 'unt'oh. Mbe la nuljut-un, 'en bé lhk'ets'utsi'-i ooyo soo ts'ih'un un'a lhálhdit'oh whe 'unt'oh. 
\p  
\v 19 Yak'usda didut 'udechoo nek'entsi' 'et huwa ook'ets'intsi'. 
\s1 Be 'alha' hoont'oh-i, 'i be Yak'usda ook'une' ts'oot'en 
\p  
\v 20 Mbe la Yak'usda ook'esi'ne ni de, 'ink'ez dudulhutsin ts'udutni, 'en whuts'it-un 'unt'oh. Nts'en'a dudulhutsin yunilh'en hoonts'i yuk'elhítsi' de, Yak'usda 'aw lhuyis'en, 'ink'ez nts'en'a yuk'etitsi'? 
\p  
\v 21 'Ink'ez ndi khuni netl'aídan'ai-i, ndiz un'a nja dúhoont'oh; mbe la Yak'usda k'entsi'-un, dudulhutsin cha k'eootsi' huba' hoont'oh. 
\c 5  
\p  
\v 1 Mbe la Sizi, 'en Christ 'unt'oh, ooba 'alha' hoont'oh-un, 'en Yak'usda yé ulhtus-i be whuzdli-un 'unt'oh. Mbene la ndun 'ilhiz be ts'ukhutinalh-un negha óonin'ai-un, hik'entsi' de, mbene la 'en be yé ulhtus-i whuzdline, 'enne cha buk'ehootsi' huba' hoont'oh. 
\p  
\v 2 Yak'usda ook'ets'intsi' 'ink'ez ooghuni ts'oontun de, 'et njan 'et huwa t'ets'oninzun Yak'usda buzkeh buk'ets'intsi'. 
\p  
\v 3 Ndi ooghuni ts'oontun de, 'et whuz un'a Yak'usda ook'ets'intsi'. 'Ink'ez ndi ooghuni 'aw oogha lhúhoolna' whe ook'une' ts'oot'en. 
\p  
\v 4 Mbene la Yak'usda yé ulhtus-i be whuzdline, 'enne ndi yun k'ut 'ut'en ntsi'-i ch'a' nilhde. Bé neba 'alha' hoont'oh-i, 'i be whuch'a' nilhde. 
\p  
\v 5 Mbe la Sizi 'en Yak'usda ooYe' unli ooba 'alha' hoont'oh-un, 'en ndi yun k'ut 'ut'en ntsi'-i ch'a' ulhdeh. 
\s1 Yak'usda duYe' dant'oh-un 'unt'oh whunénulhtun 
\p  
\v 6 Sizi 'en Christ 'unt'oh. 'En too 'ink'ez 'uskai' be whusainya. 'Aw too be za iloh. Too 'ink'ez buzkai' be whusainya. Ndoni ts'ih'un be' hoont'oh-i 'unt'oh. 'Et huwa 'en 'uja oonalh 'óohooja. 
\p  
\v 7 'Et tane 'enne yak'uz whuts'un bunalh 'óohooja. NeBá, 'ink'ez ndun khuni cha, 'ink'ez Ndoni cha. Ndunne tane 'ilhoghun za hinli. 
\p  
\v 8 'Et ndi ta 'i ndi yun k'ut oonalh 'óohooja. Ndoni 'ink'ez too 'ink'ez buzkai' cha. Ndi ta 'i lhghá' 'uhudija. 
\p  
\v 9 Dune oonalh 'óohoojane bughuni ts'ilhchoot de, Yak'usda oonalh 'óohooja-un 'on nus hooncha whe' hoont'oh, 'ink'ez ndi Yak'usda duYe' yughu yailhduk-i, 'i 'unt'oh. 
\p  
\v 10 Mbe la Yak'usda ooYe' ooba 'alha' yint'oh-un, Yak'usda daja ni-un, 'et cha ooba 'alha' hoont'oh whuzdli'. Mbe Yak'usda ooba 'alha lhe'yit'oh-un, 'en Yak'usda whuts'it ninzun. Yak'usda duYe' yughu yailhduk-un ooba 'alha lhe'yít'oh 'et huwa. 
\p  
\v 11 Ndi oonalh 'óohooja-i, 'i Yak'usda 'ilhiz ts'ukhutinalh-un negha óonin'ai. Ndi 'ilhiz be ts'úkhuna-i, 'i ooYe' bulh 'únt'oh. 
\p  
\v 12 Mbe la ooYe' ut'i-un 'ilhiz be ts'ukhuna-i ut'i whe 'unt'oh. Mbe la Yak'usda ooYe' lhit'ih-un, 'en 'aw 'ilhiz be ts'ukhuna-i lhit'ih whe 'unt'oh. 
\p  
\v 13 Mbene la Yak'usda ooYe' boozi' ooba 'alha' yint'ohne ndowhi nohts'ó k'esguz. 'Et whe la 'ilhiz khutihnalh-un whaht'i t'eoonóhzin, 'ink'ez Yak'usda ooYe' boozi' nohba 'alha' 'oot'e' za 'ooht'e'. 
\s1 Yak'usda uniyalhne, 'enne ndet oots'o hukwa' hutni-un, ts'iyawh ubudits'o 
\p  
\v 14 'Et whelhts'uniljut whe oots'u tezdudli, 'et 'i 'unt'oh, ndet la hoonli oots'u hukwa' ts'utni de, hukwa' ninzun de, nedits'o. 
\p  
\v 15 'Ink'ez nedits'o t'ets'oninzun de, ndet oots'o húkwa' ts'utni, ndi whutso da' oots'u húkwa' ts'utni-un, 'et nawh lhe'hoot'oh negha tíkulh. 
\p  
\v 16 Mbe la bulhutsin lubeshi 'aw yuk'é dalhtisah-i 'ulh'en, yunilh'en de, Yak'usda yoodolhkut 'ink'ez 'et la nyoon lubeshi 'aw yuk'é dalhtisah 'ulh'en-un, 'en khutinalh-un yugha óota'alh. 'Et lubeshi ooghá daztisah-i cha hoonli. 'Aw 'et huba tenadondli lhduzúsni. 
\p  
\v 17 Ts'ih'un be nulhe'ts'ust'en-i, 'i ts'iyawh lubeshi 'unt'oh. 'Ink'ez lubeshi ooghá daztitsah-i, 'i cha hoonli. 
\s1 Mbe la Yak'usda yé ulhtus-i gha whuzdli-un, 'aw lubeshi lhe'ulh'en 
\p  
\v 18 Mbe la Yak'usda yé ulhtus-i gha whuzdli-un, 'aw lubeshi lhe'ulh'en, 'et t'ets'oninzun. 'Et hoonts'i mbe la Yak'usda yé ulhtus-i gha whuzdli-un didutch'oh khudli whe 'unt'oh, 'ink'ez ntsi'-un 'aw yut'aóonalh ait'oh. 
\p  
\v 19 Wheni Yak'usda bulh 'úts'int'oh t'ets'oninzun. 'Ink'ez ndi yun k'ut whut'enne, ntsi'-un ts'iyawh k'úne' bul'en. 
\p  
\v 20 Yak'usda ooYe' whusainya 'ink'ez t'ets'onínzun njan t'ets'onózin-un, 'et negha óonin'ai. 'Et whe la ndun 'alha' 'unt'oh-un t'eznoozeh ha. Ndun 'alha' 'unt'oh-un, 'en bulh 'uts'int'oh. OoYe' Sizi Gri 'en cha bulh 'uts'int'oh. Ndun 'en 'unt'oh soo 'alha Yak'usda 'unt'oh 'ink'ez 'ilhiz be ts'úkhuna-i unli whe 'unt'oh. 
\p  
\v 21 Ts'oodunneyaz 'uk'eltsi-i ooch'a khahdli. 'Et ndo honeh.