\v 4  \w Samuel|strong="H8050"\w* \w did|strong="H6213"\w* \w what|strong="H6213"\w* \w the|strong="H6213"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w told|strong="H1696"\w* \w him|strong="H6213"\w*. \w When|strong="H1696"\w* \w he|strong="H6213"\w* arrived \w in|strong="H3068"\w* \w Bethlehem|strong="H1035"\w*, \w the|strong="H6213"\w* \w elders|strong="H2205"\w* \w of|strong="H3068"\w* \w the|strong="H6213"\w* \w city|strong="H5892"\w* \w were|strong="H5892"\w* \w afraid|strong="H2729"\w* \w to|strong="H1696"\w* \w meet|strong="H7122"\w* \w him|strong="H6213"\w*. \w They|strong="H3068"\w* \w said|strong="H1696"\w*, “\w Do|strong="H6213"\w* \w you|strong="H6213"\w* \w come|strong="H7122"\w* \w in|strong="H3068"\w* \w peace|strong="H7965"\w*?”  
