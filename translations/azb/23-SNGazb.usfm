\id SNG Azeri-N: Azerbaijani Bible 2008
\h NƏĞMƏLƏR NƏĞMƏSİ
\toc1 Nəğmələr Nəğməsi Kitabi
\toc2 Nəğmələr Nəğməsi
\toc3 Nəğ
\mt1 NƏĞMƏLƏR NƏĞMƏSİ
\mt2 KİTABI
\imt1 GİRİŞ
\ip \bk «Nəğmələr Nəğməsi»\bk* poetik kitab olub məhəbbət şeirlərindən ibarətdir. Kitabın baş qəhrəmanı qızdır. Burada əsasən qız oğlanla, oğlan qızla şeirlərlə deyişir. Bu şeirlərdə insan məhəbbətinin ecazkar qüvvəsindən bəhs edilir.
\ip Məhəbbət insana Allah tərəfindən verilmişdir. Buna görə də Müqəddəs Kitaba \bk «Nəğmələr Nəğməsi»\bk*nin daxil olması heç də təəccüblü deyil. Bu şeirlərin şərhi məcazi məna daşıyır. Bu məhəbbət nəğmələri yəhudilər tərəfindən Allahla xalqının münasibətlərinin əyani təsviri kimi şərh edilir. Məsihçilər isə bunu İsa Məsihlə imanlılar arasında olan münasibətlərin əksi kimi şərh edirlər.
\iot Kitabın məzmunu:
\io2 1:1–2:7 Birinci nəğmə
\io2 2:8–3:5 İkinci nəğmə
\io2 3:6–5:1 Üçüncü nəğmə
\io2 5:2–6:3 Dördüncü nəğmə
\io2 6:4–8:4 Beşinci nəğmə
\io2 8:5-14 Altıncı nəğmə
\c 1
\q1 
\v 1 \x * \xo 1:1 \xt 1Pad. 4:32 \x* Bu nəğmələr nəğməsi Süleymanındır.
\sp Qız:
\q1 
\v 2 Qoy dodaqların məni öpdükcə öpsün,
\q1 Çünki eşqin şərabdan da yaxşıdır.
\q1 
\v 3 Vurduğun ətrin qoxusu nə gözəldir,
\q1 Adın belə, ətirqabıdan tökülən ətri xatırladır,
\q1 Ona görə qızların sevimlisi olmusan.
\q1 
\v 4 Bağrına bas məni, səninlə qaçaq,
\q1 Qoy padşah məni otağına aparsın.
\sp Qızın rəfiqələri:
\q1 Səninlə sevinib biz şadlanarıq,
\q1 Şərabdan da artıq eşqinizi anarıq.
\sp Qız:
\q1 Sənə heyran olanlar haqlıdır.
\q1 
\v 5 Ey Yerusəlimdəki qızlar,
\q1 Qedar çadırları tək,
\q1 Süleymanın pərdələri tək
\q1 Qaralsam da mən,
\q1 Yenə gözələm.
\q1 
\v 6 Baxmayın ki, mən qarayanızam,
\q1 Günəşdən qaralmışam,
\q1 Qardaşlarımın mənə qəzəbi tutarkən
\q1 Məni üzümlüklərinə qarovulçu qoydular.
\q1 Mən də öz üzümlüyümə baxa bilmədim.
\q1 
\v 7 Ey könlümün sevgilisi, söylə mənə:
\q1 Sürünü harada otarırsan?
\q1 Günorta sürünü harada yatırırsan?
\q1 Niyə sənin dostlarının sürülərinin yanında gedən,
\q1 Üz-gözünü bürüyən bir qadına bənzəyim?
\sp Qızın rəfiqələri:
\q1 
\v 8 Ey gözəllər gözəli, əgər yerini tapa bilməsən,
\q1 Sürülərin izi ilə get,
\q1 Oğlaqlarını çoban çadırlarının yanında otar.
\sp Oğlan:
\q1 
\v 9 Ey yarım, sən
\q1 Fironun arabalarını çəkən
\q1 Gözəl madyana bənzəyirsən.
\q1 
\v 10 Yanağına düşən bəzəklərlə,
\q1 Boynundakı daş-qaşdan olan boyunbağı ilə
\q1 Bax nə qədər gözəlsən.
\q1 
\v 11 Sənə düymələri gümüşdən
\q1 Qızıl silsilə düzəldəcəyik.
\sp Qız:
\q1 
\v 12 Padşah süfrəsində oturarkən
\q1 Hər yanı nard çiçəyimin ətri bürüyür.
\q1 
\v 13 Mənim üçün sevgilim
\q1 Döşlərimin arasında yatan mirra kisəsidir.
\q1 
\v 14 Mənim üçün sevgilim
\q1 En-Gedinin üzüm bağlarındakı bir dəstə xınagülüdür.
\sp Oğlan:
\q1 
\v 15 Ey yarım, nə gözəlsən, nə gözəlsən!
\q1 Göyərçin gözlüsən!
\sp Qız:
\q1 
\v 16 Ey sevgilim, nə gözəlsən,
\q1 Sən nə qədər şirinsən!
\q1 Yaşıldır yatağımız.
\sp Oğlan:
\q1 
\v 17 Evlərimizin dirəkləri sidr ağacındandır,
\q1 Tavanımızın oymaları şam ağacındandır.
\c 2
\sp Qız:
\q1 
\v 1 Mən Şaron nərgiziyəm,
\q1 Dərələrdə bitən zanbağam.
\sp Oğlan:
\q1 
\v 2 Mənim yarım qızlar arasındadır,
\q1 Elə bil bir zanbaq tikanlar arasındadır.
\sp Qız:
\q1 
\v 3 Mənim sevgilim oğlanlar arasındadır,
\q1 Meşədəki ağaclar arasında alma ağacına oxşayır.
\q1 Kölgəsində oturmaqdan zövq alıram,
\q1 Meyvəsinin dadı damağımdan getmir.
\b
\q1 
\v 4 O məni ziyafət evinə apardı,
\q1 Sevgisi bayraq kimi üzərimdə dalğalanır.
\q1 
\v 5 Mən eşq xəstəsiyəm,
\q1 Kişmiş verin, qüvvətlənim,
\q1 Alma verin, cana gəlim.
\b
\q1 
\v 6 Sevgilim sol əlini başımın altına salır,
\q1 Sağ əli ilə məni qucağına alır.
\q1 
\v 7 Ey Yerusəlimdəki qızlar, sizi and verirəm
\q1 Dişi ceyranlara, çöldəki marallara!
\q1 Bizi bu sevgidən oyatmayın, ayıltmayın,
\q1 Qoy könül istəyənəcən qalsın.
\b
\q1 
\v 8 Bu, sevgilimin hənirtisidir!
\q1 O, dağlardan aşaraq, təpələrdən sıçrayaraq gəlir.
\q1 
\v 9 Sevgilim ahuya, maral balasına oxşayır,
\q1 Budur, hasarımızın o tayında dayanır,
\q1 Pəncərələrdən boylanır, barmaqlıqlardan baxır.
\q1 
\v 10 Mənə belə dedi sevgilim:
\q1 «Dur gəl, yarım, gözəlim.
\q1 
\v 11 Budur, artıq qış keçib,
\q1 Yağıntılar kəsilib.
\q1 
\v 12 Hər yanda güllər bitib,
\q1 Nəğmə oxumağın zamanı yetib,
\q1 Qumrunun səsi torpağı bürüyüb.
\q1 
\v 13 Əncir yaşıl bar gətirib,
\q1 Üzüm çiçəklənib ətrini saçır.
\q1 Dur gəl, yarım, gözəlim!»
\sp Oğlan:
\q1 
\v 14 Ey gözəl göyərçinim,
\q1 Sanki sal qayalarda, sıldırımlarda gizlənmisən.
\q1 Qoy üzünü görüm, səsini eşidim,
\q1 Çünki şirin səsli, gözəl surətlisən.
\b
\q1 
\v 15 Tülküləri, kiçik tülküləri tutun,
\q1 Üzümlükləri korlamağa qoymayın,
\q1 Çünki bağlarımız çiçəklənib.
\sp Qız:
\q1 
\v 16 Sevgilim mənimdir, mən də onunam,
\q1 O, sürüsünü zanbaqlıq içərisində otarır.
\q1 
\v 17 Gün sərinləşənəcən, kölgələr düşənəcən,
\q1 Ey sevgilim, geri qayıt,
\q1 Şişuclu dağların qoynunda olan
\q1 Ahuya, maral balasına bənzərsən.
\b
\c 3
\q1 
\v 1 Yatağımda bütün gecə
\q1 Könlümün sevgilisini axtardım,
\q1 Axtardım, amma tapa bilmədim.
\q1 
\v 2 Dedim: «Qoy könlümün sevgilisini axtarım,
\q1 Durub şəhəri dolaşım,
\q1 Küçələrdə, meydanlarda axtarım».
\q1 Axtardım, amma tapa bilmədim.
\q1 
\v 3 Şəhər asayişini qoruyanlar məni tapdı,
\q1 Onlardan soruşdum: «Könlümün sevgilisini görməmisiniz ki?»
\q1 
\v 4 Onlardan ayrılanda könlümün sevgilisini tapdım,
\q1 Tutub onu buraxmadım.
\q1 Onu anamın evinə –
\q1 Məni doğan qadının otağına apardım.
\b
\q1 
\v 5 Ey Yerusəlimdəki qızlar, sizi and verirəm
\q1 Dişi ceyranlara, çöldəki marallara!
\q1 Bizi bu sevgidən oyatmayın, ayıltmayın,
\q1 Qoy könül istəyənəcən qalsın.
\b
\q1 
\v 6 Səhradan keçən,
\q1 Tüstü sütunları kimi gələn,
\q1 Tacirlərin ətirli bitkiləri içərisində
\q1 Mirra və kündür ətri verən kimdir?
\q1 
\v 7 Budur Süleymanın taxt-rəvanı!
\q1 Ətrafını İsrail igidlərindən altmışı bürüyüb.
\q1 
\v 8 Onların hamısı qılınc daşıyır,
\q1 Mahir döyüşçüdür,
\q1 Hər biri qılıncını belinə bağlayıb,
\q1 Təhlükəli gecələr üçün hazırlanıb.
\q1 
\v 9 Taxt-rəvanını padşah Süleyman
\q1 Livanın ağaclarından düzəltdirib.
\q1 
\v 10 Sütunları gümüşdən, söykənəcəyi qızıldan,
\q1 Oturacağı tünd qırmızı qumaşdan düzəltdirib,
\q1 Yerusəlim qızları bu qumaşa zövqlə naxış vurub.
\q1 
\v 11 Ey Sion qızları, çıxın,
\q1 Padşah Süleymana baxın!
\q1 O, toy günündə, ürəkdən sevindiyi gündə
\q1 Başına anasının verdiyi tacı qoyub!
\c 4
\sp Oğlan:
\q1 
\v 1 Ey yarım, nə gözəlsən, nə gözəlsən,
\q1 Yaşmaq altda gözlərin göyərçinə oxşayır,
\q1 Saçların Gilead dağının yamaclarından
\q1 Tökülən keçi sürüsü tək qapqaradır.
\q1 
\v 2 Dişlərin qırxılmış, yenicə yuyunub çıxan qoyun sürüsü tək düzülüb,
\q1 Bu qoyunların hamısının əkiz balası var,
\q1 Aralarında balasız olanı yoxdur.
\q1 
\v 3 Dodaqların qırmızı qaytan kimi aldır,
\q1 Dilin nə qədər şirindir,
\q1 Kəsilmiş nar kimi yaşmaqladığın yanaqlarından qan damır.
\q1 
\v 4 Boynun sursat üçün tikilmiş Davud qülləsi kimi vüqarlıdır,
\q1 Sanki buradan pəhləvan qalxanı olan min sipər asılmışdır.
\q1 
\v 5 Döşlərin cüt ceyran balası kimi qoşadır,
\q1 Zanbaqlıqda otlayan əkiz maral balasına oxşayır.
\b
\q1 
\v 6 Gün sərinləşənəcən, kölgələr düşənəcən,
\q1 Mirra dağına, kündür təpəsinə gedəcəyəm.
\b
\q1 
\v 7 Təpədən dırnağa qədər gözəlsən,
\q1 Yarım, tamamilə eyibsizsən.
\b
\q1 
\v 8 Ay gəlin, Livan bölgəsindən mənimlə gəl,
\q1 Gəl, Livandan mənimlə gəl.
\q1 Amana təpəsindən, Senir, Xermon təpələrindən, dağlardan,
\q1 Aslanlar yurdundan, dağlardan, bəbirlər məskənindən en.
\b
\q1 
\v 9 Ay həmdəmim, ay gəlin!
\q1 Bir baxışınla qəlbimi aldın.
\q1 Ləl-cəvahiratı boynuna saldın,
\q1 Gözəlliyinlə qəlbimi aldın.
\q1 
\v 10 Ay həmdəmim, ay gəlin!
\q1 Sevgin necə gözəldir,
\q1 Eşqin şərabdan da ləzzətlidir,
\q1 Sənin ətrin ətirlərin ən gözəlidir.
\q1 
\v 11 Ay gəlin, dodaqlarından şanı balı axır,
\q1 Bal və süd sənin dilinin altındadır.
\q1 Paltarlarından Livanın ətri gəlir.
\q1 
\v 12 Ay həmdəmim, ay gəlin!
\q1 Bir qapısı bağlı bağçasan,
\q1 Örtülü bir bulaq, möhürlənmiş bulaqsan.
\q1 
\v 13 Sənin fidanların nar bağçasına oxşayır,
\q1 Elə bil cənnətdir, orada seçmə meyvələr,
\q1 Xına və nard çiçəkləri var.
\q1 
\v 14 Nard çiçəyi və zəfəran,
\q1 Ətirli qamışla darçınlar,
\q1 Hər cür buxur ağacı,
\q1 Mirralar və əzvaylar,
\q1 Hər cür seçmə ətriyyat var.
\q1 
\v 15 Sən bağçaların bulağısan,
\q1 Canlı su qaynağısan,
\q1 Livanın axar suyusan.
\sp Qız:
\q1 
\v 16 Oyan, ey şimal küləyi,
\q1 Dur gəl, ey cənub küləyi,
\q1 Gəlin mənim bağçamda əsin,
\q1 Qoy o, ətrini hər yana versin.
\q1 Sevgilim öz bağçasına gəlsin,
\q1 Seçmə meyvələrdən yesin.
\c 5
\sp Oğlan:
\q1 
\v 1 Ay həmdəmim, ay gəlin! Öz bağçama girmişəm,
\q1 Ətriyyatlarımla mirramı yığmışam.
\q1 Şanı balını – öz balımı yemişəm,
\q1 Şərabımı və südümü içmişəm.
\sp Qızın rəfiqələri:
\q1 Ay dostlar, yeyin,
\q1 Ay sevgililər, için, doyunca için!
\sp Qız:
\q1 
\v 2 Yatsam da, qəlbim oyaq idi.
\q1 Qapını döyən sevgilimin səsi gəldi:
\q1 «Qapını aç, ay həmdəmim, ay yarım!
\q1 Ay göyərçinim, ay eyibsizim!
\q1 İslandı başım şehdən,
\q1 Saçım gecənin nəmindən».
\q1 
\v 3 Soyunmuşam paltarımı,
\q1 Geyinimmi təzədən?
\q1 Yumuşam ayaqlarımı,
\q1 Bulaşdırımmı yenidən?
\q1 
\v 4 Sevgilim əlini qapının deşiyindən uzatdı,
\q1 Onun üçün mənim köksüm oynadı.
\q1 
\v 5 Mən sevgilim üçün qapı açmağa qalxdım,
\q1 Əllərimə mirra damdı,
\q1 Barmaqlarımdan süzüldü,
\q1 Cəftə üstə töküldü.
\q1 
\v 6 Mən sevgilimə qapı açanda
\q1 Sevgilim çıxıb getmişdi.
\q1 O məni çağıranda huşumu itirmişdim.
\q1 Mən onu axtardım, tapa bilmədim,
\q1 Mən onu çağırdım, lakin cavab gəlmədi.
\q1 
\v 7 Şəhər asayişini qoruyanlar məni tapdılar,
\q1 Döyüb bədənimi yaraladılar,
\q1 Hasar keşikçiləri örpəyimi açdılar.
\q1 
\v 8 Ey Yerusəlimdəki qızlar, mən sizə and verirəm,
\q1 Tapsanız sevgilimi, deyin ona: «Mən eşq xəstəsiyəm».
\sp Qızın rəfiqələri:
\q1 
\v 9 Ey gözəllər gözəli,
\q1 Sevgilinin digərlərindən fərqi nədir?
\q1 Onu fərqləndirən nədir?
\q1 Axı niyə bizə belə and verirsən?
\sp Qız:
\q1 
\v 10 Sevgilim nur saçır, əlvan rənglidir,
\q1 O, on minlərin arasından seçilir.
\q1 
\v 11 Başı sanki saf qızıldır,
\q1 Qıvrım saçı qara qarğa tək qaradır.
\q1 
\v 12 Gözləri axar sular kənarındakı göyərçinlərə oxşayır,
\q1 Süd içində yuyunmuşlar,
\q1 Öz yuvasında cəvahir tək görünərlər.
\q1 
\v 13 Yanaqları ətirli gülüstana oxşayır,
\q1 Hər yana ətir saçır,
\q1 Dodaqları zanbaqlara bənzəyir,
\q1 Ondan mirra tökülür.
\q1 
\v 14 Əlləri sanki sarı yaqutla bəzənən qızıl budaqdır,
\q1 Qaməti sanki yaqutlarla naxışlanan fil dişidir.
\q1 
\v 15 Qıçları saf qızıl ayaqlıqlar üstündə dayanan
\q1 Mərmər sütunlara oxşar.
\q1 Görkəmi Livanın dağları kimidir,
\q1 Nadir sidr ağacları kimidir.
\q1 
\v 16 Şirindillidir,
\q1 Təpədən dırnağadək gözəldir.
\q1 Ey Yerusəlimdəki qızlar, mənim sevgilim budur,
\q1 Mənim yarım budur.
\c 6
\sp Qızın rəfiqələri:
\q1 
\v 1 Ey gözəllər gözəli, sevgilin hara gedib?
\q1 O hansı yana dönüb?
\q1 Səninlə birgə onu axtarmağa gedək.
\sp Qız:
\q1 
\v 2 Sevgilim öz bağçasına –
\q1 Ətirli gülüstana gedib,
\q1 Bağçalarda sürüsünü otarmağa,
\q1 Zanbaq gülü toplamağa gedib.
\q1 
\v 3 Mən sevgilimin, sevgilim də mənimdir,
\q1 O, sürüsünü zanbaqlıq içərisində otarır.
\sp Oğlan:
\q1 
\v 4 Ey yarım, sən
\q1 Tirsa şəhəri qədər gözəlsən,
\q1 Yerusəlim kimi sevimlisən,
\q1 Müzəffər ordu kimi möhtəşəmsən.
\q1 
\v 5 Gözlərini məndən ayır,
\q1 Onlar məni mat qoyur.
\q1 Saçların Gilead dağının yamaclarından
\q1 Tökülən keçi sürüsü tək qapqaradır.
\q1 
\v 6 Dişlərin yenicə yuyunub çıxan qoyun sürüsü tək düzülüb,
\q1 Bu qoyunların hamısının əkiz balası var,
\q1 Aralarında balasız olanı yoxdur.
\p 
\v 7 Kəsilmiş nar kimi yaşmaqladığın yanaqlarından qan damır.
\q1 
\v 8 Altmış mələkə var,
\q1 Cariyələr səksənə çatır,
\q1 Kənizlər isə saysızdır.
\q1 
\v 9 Göyərçinimin, eyibsizimin tayı yoxdur,
\q1 Anasının yeganə qızıdır,
\q1 Onu doğanın canı-gözüdür.
\q1 Qızlar onu görərkən
\q1 Söyləyirlər: «Bəxtəvərsən!»
\q1 Mələkələr və cariyələr də onu mədh edir.
\sp Qızın rəfiqələri:
\q1 
\v 10 Şəfəq saçan,
\q1 Ay tək gözəl, gün tək parlayan,
\q1 Müzəffər ordu kimi möhtəşəm olan kimdir?
\sp Qız:
\q1 
\v 11 Mən qoz bağına endim,
\q1 Yaşıllaşan vadini görmək istədim.
\q1 Üzüm tumurcuqlanıbmı, narlar çiçəklənibmi?
\q1 Bunu seyr edim.
\q1 
\v 12 Heç özüm də bilmədən ruhum məni apardı,
\q1 Şanlı xalqımın döyüş arabalarının üstünə qaldırdı.
\sp Qızın rəfiqələri:
\q1 
\v 13 Qayıt, ey Şulam qızı, qayıt,
\q1 Qayıt, səni görək, qayıt.
\sp Oğlan:
\q1 Maxanayim oyununa tamaşa etdiyiniz kimi
\q1 Niyə Şulam qızına baxmaq istəyirsiniz?
\b
\c 7
\q1 
\v 1 Ey əsilzadə qızı, başmaqlı ayaqların gözəldir,
\q1 Budlarını sanki heykəltəraş yonub, cəvahirə bənzəyir.
\q1 
\v 2 Göbəyin cürbəcür şərabların tükənmədiyi
\q1 Dəyirmi piyaləyə bənzəyir.
\q1 Belin zanbaqlara bürünən
\q1 Bir dəstə sünbülə bənzəyir,
\q1 
\v 3 Döşlərin cüt ceyran balası kimi,
\q1 Əkiz maral balası kimi qoşadır.
\q1 
\v 4 Boynun fil dişi qülləsi kimi gözəldir.
\q1 Gözlərin Bat-Rabbim darvazası yanındakı
\q1 Xeşbon hovuzuna bənzəyir.
\q1 Burnun Dəməşqə baxan Livan qülləsi kimi gözəldir.
\q1 
\v 5 Başın Karmel dağı kimi dik durur,
\q1 Başındakı tellər tünd qırmızı rəngə çalır,
\q1 Padşah zülfünün əsiri olur.
\q1 
\v 6 Nə qəşəngsən, nə şirinsən,
\q1 Ey məlahətli sevgilim.
\q1 
\v 7 Qamətin xurma ağacına,
\q1 Döşlərin salxımlara bənzəyir.
\q1 
\v 8 Dedim: «Qoy xurma ağacına çıxım,
\q1 Meyvəli budaqlarından yapışım».
\q1 Döşlərindən üzüm salxımları kimi dadım,
\q1 Nəfəsindən alma ətrini duyum.
\q1 
\v 9 Dodaqların gözəl şərab dadı verir.
\sp Qız:
\q1 Bu şərab birbaşa sevgilim üçün tökülsün,
\q1 Biz yatanların dodaqlarına süzülsün.
\q1 
\v 10 Mən sevgiliminkiyəm,
\q1 Onun meyl etdiyi mənəm.
\q1 
\v 11 Sevgilim, gəl çölə gedək,
\q1 Kəndlərdə gecələyək.
\q1 
\v 12 Səhər tezdən üzüm bağlarına gedək,
\q1 Üzüm tumurcuqlanıbmı, pöhrə veribmi?
\q1 Narlar çiçəklənibmi? Bunu seyr edək.
\q1 Qoy orada sevgimi sənə verim.
\q1 
\v 13 Ey sevgilim, məhəbbət otları ətir saçır,
\q1 Qapımızın yanında köhnə, təzə – cürbəcür meyvələr var,
\q1 Sənin üçün saxlanılıb.
\b
\c 8
\q1 
\v 1 Kaş ki mənə ananın döşlərindən süd əmən
\q1 Bir qardaş kimi olaydın,
\q1 Küçədə səninlə rastlaşarkən səni öpərdim,
\q1 Heç kim məni qınamazdı.
\q1 
\v 2 Qarşına düşəydim, mənə öyüd verən
\q1 Anamın evinə aparaydım.
\q1 Şirin şərabdan, narımın şirəsindən
\q1 Sənə içirəydim.
\b
\q1 
\v 3 Sevgilim sol əlini başımın altına salır,
\q1 Sağ əli ilə məni qucağına alır.
\q1 
\v 4 Ey Yerusəlimdəki qızlar, sizi and verirəm
\q1 Dişi ceyranlara, çöldəki marallara!
\q1 Bizi bu sevgidən oyatmayın, ayıltmayın,
\q1 Qoy könül istəyənəcən qalsın.
\sp Qızın rəfiqələri:
\q1 
\v 5 Sevgilisinə söykənib çöldən gələn
\q1 Bu gözəl kimdir?
\sp Qız:
\q1 Alma ağacı altda səni oyatdım.
\q1 Sən orada ananın bətninə düşmüsən,
\q1 Orada anan ağrı çəkib, səni doğub.
\b
\q1 
\v 6 Məni qəlbinin başında, qolunun üstündə
\q1 Bir möhür kimi saxla.
\q1 Çünki sevgi ölüm qədər qüvvətlidir,
\q1 Qısqanclıq ölülər diyarı kimi möhkəmdir,
\q1 Onun odu alovlanır,
\q1 O, atəşdir, tamamilə yandırıb-yaxır.
\q1 
\v 7 Sevgini ümman sular söndürə bilməz,
\q1 Onu çağlayan çaylar batıra bilməz.
\q1 Bir insan sevgisi uğrunda var-yoxunu versə belə,
\q1 Hamı ona xor baxar.
\sp Qızın rəfiqələri:
\q1 
\v 8 Bir kiçik bacımız var,
\q1 Hələ döşləri çıxmayıb.
\q1 Bacımıza elçi gələn gün
\q1 Onun üçün nə edək?
\q1 
\v 9 Əgər o, bir hasar olsaydı,
\q1 Biz üstünə gümüşdən bürc vurardıq.
\q1 Əgər o, bir qapı olsaydı,
\q1 Onu sidrdən xonça bağlayıb dövrəyə alardıq.
\sp Qız:
\q1 
\v 10 Mən bir hasaram,
\q1 Döşlərim qüllələrə oxşar,
\q1 Ona görə yarımın gözləri məndən razı qalar.
\q1 
\v 11 Süleymanın Baal-Hamonda bir üzüm bağı var idi,
\q1 O bu bağı kirayəyə verirdi.
\q1 Məhsula görə hər kirayə alan
\q1 Ona min parça gümüş gətirməli idi.
\q1 
\v 12 Mənim də bağım var, onun sahibiyəm,
\q1 Ey Süleyman, min parça gümüş sənin olsun,
\q1 İki yüz gümüş kirayə alanlara qalsın.
\sp Oğlan:
\q1 
\v 13 Sən, ey bağçalarda məskən salan gözəl,
\q1 Dostlar səni dinləyir,
\q1 Mənə də səsini eşitdir.
\sp Qız:
\q1 
\v 14 Ey sevgilim, qaç,
\q1 Ətir saçan dağların üstündə,
\q1 Bir ahu, bir maral balası kimi ol. 
