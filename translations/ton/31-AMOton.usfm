\id AMO
\h  ĽAmosi
\toc1 Ko E Tohi  Ľae PalŇćfita Ko  ĽAmosi
\toc2  ĽAmosi
\toc3  ĽAm
\mt2 KO E TOHI
\mt3  ĽAE PALŇĆFITA KO
\mt1  ĽAMOSI
\cl KO E VAHE
\c 1
\cd \it 1  ĽOku fakahńĀ  Ľe  ĽAmosi  Ľae fakamaau  Ľae  ĽOtua ki Silia, 6 Pea ki he Filisitaine, 9 Pea ki Taia, 11 Pea ki  ĽItomi, 13 Pea ki  ĽAmoni.\it*
\p 
\v 1 Ko e ngaahi lea  Ľa  ĽAmosi,  Ľaia na Ľe  Ľi he kau tauhimanu  Ľo Tikoa, ko e me Ľa na Ľa ne mamata ai  Ľoku kau ki  ĽIsileli  Ľi he ngaahi  Ľaho  Ľo  ĽUsaia ko e tu Ľi  Ľo Siuta, pea  Ľi he ngaahi  Ľaho  Ľo Selopoami ko e foha  Ľo Soasi ko e tu Ľi  Ľo  ĽIsileli,  Ľi hono ua ta Ľu na Ľe mu Ľomu Ľa  Ľi he mofuike.
\v 2 Pea na Ľa ne pehńď,
\q1 ‚Äú ĽE  Ľu Ľulu  Ľa Sihova mei Saione,
\q2 pea  Ľe fakaongo hono le Ľo mei SelŇęsalema;
\q1 pea ko e ngaahi fale  Ľoe kau tauhimanu  Ľe tangi,
\q2 pea  Ľe mŇćmoa  Ľae tumutumu  Ľo Kameli.‚ÄĚ
\p 
\v 3 ‚ÄĆ ĽOku pehńď  Ľe Sihova;
\q1 ‚ÄúKoe Ľuhi ko e talangata Ľa  Ľe tolu  Ľa Tamasikusi, pea mo hono fńĀ,
\q2  Ľe  Ľikai te u fakaafe  Ľae tautea mei ai;
\q2 he kuo nau haha  Ľa Kiliati  Ľaki  Ľae ngaahi me Ľa haha ukamea:
\q1 
\v 4 Pea te u fekau  Ľae afi ki he fale  Ľo Hasaeli,
\q2  Ľaia te ne kai  Ľo  Ľosi  Ľae ngaahi fale faka Ľei Ľeiki  Ľo Penihatati.
\q1 
\v 5 Te u fesi Ľi foki  Ľae va Ľa  Ľo Tamasikusi,
\q2 pea te u motuhi  Ľae kakai mei he toafa ko  ĽAveni,
\q2 pea mo ia  Ľoku ma Ľu  Ľae tokotoko mei he fale  Ľo  ĽIteni:
\q2 pea  Ľe  Ľalu pŇćpula  Ľae kakai Silia ki Kili,‚ÄĚ
\p he  Ľoku pehńď  Ľe Sihova.
\p 
\v 6 ¬∂  ĽOku pehńď  Ľe Sihova;
\q1 ‚ÄúKoe Ľuhi ko e talangata Ľa  Ľe tolu  Ľa Kesa, pea mo hono fńĀ,
\q2  Ľe  Ľikai te u fakaafe \add  Ľae tautea \add*mei ai;
\q2 he na Ľa nau  Ľave pŇćpula  Ľae kau pŇćpula kotoa pńď,
\q2 koe Ľuhi ke nau tuku  Ľakinautolu ki  ĽItomi:
\q1 
\v 7 Ka te u fekau  Ľae afi ki he  ĽńĀ  Ľo Kesa,
\q2  Ľaia te ne kai  Ľo  Ľosi  Ľae ngaahi fale faka Ľei Ľeiki  Ľi ai:
\q1 
\v 8 Pea te u motuhi  Ľae kakai mei  ĽAsitoti,
\q2 pea mo ia  Ľoku ma Ľu  Ľae tokotoko mei  ĽAsikeloni,
\q1 pea te u hiki hoku nima ki  ĽEkiloni:
\q2 pea ko e toenga  Ľoe kau Filisitia  Ľe  Ľauha,‚ÄĚ
\p he  Ľoku pehńď  Ľe Sihova.
\p 
\v 9 ¬∂  ĽOku pehńď  Ľe Sihova;
\q1 ‚ÄúKoe Ľuhi ko e talangata Ľa  Ľe tolu  Ľa Taia, pea mo hono fńĀ,
\q2  Ľe  Ľikai te u fakaafe \add hono tautea \add* Ľo ia;
\q2 he na Ľa nau tuku  Ľae kau pŇćpula kotoa pńď ki  ĽItomi,
\q2 pea na Ľe  Ľikai te nau manatu Ľi  Ľae fuakava fakakńĀinga:
\q1 
\v 10 Ka te u fekau  Ľae afi ki he  ĽńĀ  Ľo Taia,
\q2  Ľaia te ne kai  Ľo  Ľosi  Ľae ngaahi fale faka Ľei Ľeiki  Ľi ai.‚ÄĚ
\p 
\v 11 ¬∂  ĽOku pehńď  Ľe Sihova;
\q1 ‚ÄúKoe Ľuhi ko e talangata Ľa  Ľe tolu  Ľa  ĽItomi, pea mo hono fńĀ,
\q2  Ľe  Ľikai te u fakaafe \add hono tautea \add* Ľo ia;
\q2 he na Ľa ne tuli hono tokoua  Ľaki  Ľae heletńĀ,
\q2 pea na Ľe li Ľaki  Ľae manava Ľofa,
\q2 pea na Ľe hae Ľi  Ľe ia  Ľi he Ľene  Ľita ma Ľuaipńď,
\q2 pea na Ľa ne fakatolonga  Ľene lili  Ľo ta Ľengata:
\q1 
\v 12 Ka te u fekau  Ľae afi ki Timani,
\q2  Ľaia  Ľe kai  Ľo  Ľosi  Ľae ngaahi fale faka Ľei Ľeiki  Ľo Posila.‚ÄĚ
\p 
\v 13 ¬∂  ĽOku pehńď  Ľe Sihova;
\q1 ‚ÄúKoe Ľuhi ko e talangata Ľa  Ľe tolu  Ľae fńĀnau  Ľa  ĽAmoni, pea mo hono fńĀ,
\q2  Ľe  Ľikai te u fakaafe \add honau tautea\add*;
\q2 he na Ľa nau hae Ľi  Ľae kau fefine feitama  Ľi Kiliati,
\q2 koe Ľuhi ke nau totolo mai honau mata fonua:
\q1 
\v 14 Ka te u tutu  Ľae afi  Ľi he  ĽńĀ  Ľo Lapa,
\q2 pea te ne kai  Ľae ngaahi fale faka Ľei Ľeiki  Ľo ia,
\q2  Ľi he kaila  Ľi he  Ľaho  Ľoe tau,
\q2 mo e afńĀ  Ľi he  Ľaho  Ľoe  Ľahiohio:
\q1 
\v 15 Pea  Ľe  Ľalu honau tu Ľi ki he pŇćpula,
\q2  Ľaia mo hono ngaahi hou Ľeiki fakataha,‚ÄĚ
\p  Ľoku pehńď  Ľe Sihova.
\c 2
\cd \it 1 Ko e houhau  Ľae  ĽOtua ki Moape; 4 Mo Siuta, 6 Pea mo  ĽIsileli. 9  ĽOku lńĀunga  Ľae  ĽOtua  Ľi he Ľenau ta Ľefa Ľafakafeta Ľi.\it*
\p 
\v 1 ‚ÄĆ ĽOku pehńď  Ľe Sihova,
\q1 ‚ÄúKoe Ľuhi ko e talangata Ľa  Ľe tolu  Ľa Moape, mo hono fńĀ,
\q2  Ľe  Ľikai te u fakaafe \add hono tautea  Ľo ia\add*;
\q2 he na Ľa ne ta Ľo  Ľae ngaahi hui  Ľae tu Ľi  Ľo  ĽItomi ke lahe:
\q1 
\v 2 Ka te u fekau  Ľae afi ki Moape,
\q2 pea te ne kai  Ľo  Ľosi  Ľae ngaahi fale faka Ľei Ľeiki  Ľo Kiliote:
\q2 pea  Ľe mate  Ľa Moape  Ľi he maveuveu, mo e kaila, pea mo e ongo  Ľoe me Ľalea:
\q1 
\v 3 Pea te u motuhi  Ľae fakamaau mei honau ha Ľoha Ľonga,
\q2 pea tńĀmate Ľi  Ľae hou Ľeiki kotoa pńď mo ia:‚ÄĚ
\p  Ľoku pehńď  Ľe Sihova.‚ÄĚ
\p 
\v 4 ¬∂  ĽOku pehńď  Ľe Sihova;
\q1 ‚ÄúKoe Ľuhi ko e talangata Ľa  Ľe tolu  Ľa Siuta, pea mo hono fńĀ,
\q2  Ľe  Ľikai te u fakaafe hono \add tautea  Ľo ia\add*;
\q2 he kuo nau va Ľinga  Ľaki  Ľae fono  Ľa Sihova,
\q2 pea na Ľe  Ľikai te nau tauhi  Ľene ngaahi fekau,
\q2 pea na Ľa nau hńď ko e me Ľa  Ľi he Ľenau loi,
\q2  Ľaia na Ľe muimui ki ai  Ľenau ngaahi tamai:
\q1 
\v 5 Ka te u fekau  Ľae afi ki Siuta,
\q2 pea te ne kai  Ľo  Ľosi  Ľae ngaahi fale faka Ľei Ľeiki  Ľo SelŇęsalema.‚ÄĚ
\p 
\v 6 ¬∂  ĽOku pehńď  Ľe Sihova;
\q1 ‚ÄúKoe Ľuhi ko e talangata Ľa  Ľe tolu  Ľa  ĽIsileli, pea mo hono fńĀ,
\q2  Ľe  Ľikai te u fakaafe \add hono tautea  Ľo ia\add*;
\q2 he kuo nau fakatau  Ľae kakai mńĀ Ľoni Ľoni ki he siliva,
\q2 pea mo e kakai masiva  Ľaki ha topuva Ľe;
\q2 
\v 7 ‚ÄĆ ĽAia  Ľoku feinga ke  Ľai  Ľae efu  Ľoe kelekele  Ľi he  Ľulu  Ľoe kakai masiva,
\q2 pea  Ľoku fakahńď Ľi  Ľae hala  Ľoe angamalŇę:
\q2 pea ko e tangata mo  Ľene tamai  Ľoku na mohe ki he fefine pe taha,
\q2 ke fakaongokovi hoku huafa tńĀpuhńĀ:
\q2 
\v 8 Pea  Ľoku nau tokoto  Ľi he ngaahi kofu  Ľoku tuku ko e fakamo Ľoni ki he totongi  Ľi he ve Ľe feilaulau Ľanga kotoa pńď,
\q2 pea  Ľoku nau inu  Ľae uaine  Ľoe halaia  Ľi he fale  Ľo  Ľenau tamapua.
\q1 
\v 9 Ka na Ľaku faka Ľauha  Ľae kakai  ĽAmoli  Ľi honau  Ľao,
\q2  Ľaia na Ľe mńĀ Ľolunga hangńď ko e sita,
\q2 pea na Ľe mńĀlohi hangńď ko e oke;
\q2 ka na Ľaku faka Ľauha hono fua mei  Ľolunga,
\q2 pea mo hono aka  Ľi lalo.
\q1 
\v 10 Pea na Ľaku  Ľomi foki  Ľakimoutolu mei he fonua ko  ĽIsipite,
\q2 pea na Ľaku tataki  Ľakimoutolu  Ľi he toafa  Ľi he ta Ľu  Ľe fńĀngofulu,
\q2 ke ma Ľu  Ľae fonua  Ľoe kakai  ĽAmoli.
\q1 
\v 11 Pea na Ľaku tu Ľutu Ľuni mei ho ngaahi foha  Ľae kau palŇćfita,
\q2 pea mei ho Ľo kau talavou  Ľae kakai na Ľe fakamavahe.
\q1  ĽIkai  Ľoku pehńď pe,
\q2  Ľe fńĀnau  Ľa  ĽIsileli?‚ÄĚ  Ľoku pehńď  Ľe Sihova.
\q1 
\v 12 ‚ÄúKa na Ľa mou  Ľatu  Ľae uaine ke inu  Ľe he kau Fakamavahe;
\q2 pea ne mou fekau  Ľae kau palŇćfita,  Ľo pehńď, ‚Äė ĽOua na Ľa kikite.‚Äô
\q1 
\v 13 Vakai,  Ľoku ou ta Ľomia  Ľiate kimoutolu,
\q2 hangńď ko e saliote  Ľi he ngaahi  ĽŇę koane.
\q1 
\v 14 Ko ia  Ľe mole  Ľae fa Ľa lele mei he ve Ľe vave,
\q2 pea ko e mńĀlohi  Ľe  Ľikai te ne fakamńĀlohi Ľi  Ľe ia ia;
\q2 pea  Ľe  Ľikai fakahaofi  Ľae mńĀlohi  Ľe ia ia:
\q2 
\v 15 Pea  Ľe  Ľikai tu Ľu ia  Ľoku ne teke  Ľae kaufana;
\q2 pea  Ľe  Ľikai fakahaofi  Ľae ve Ľe vave  Ľe ia ia:
\q2 pea ko ia  Ľoku heka hoosi  Ľe  Ľikai fakahaofi  Ľe ia ia.
\q1 
\v 16 Pea ko ia  Ľoku lototo Ľa  Ľi he kau mńĀlohi te ne hola telefua  Ľi he  Ľaho ko ia,‚ÄĚ
\p  Ľoku pehńď  Ľe Sihova.
\c 3
\cd \it 1 Hono  Ľaonga  Ľoe fakamaau  Ľae  ĽOtua ki  ĽIsileli. 9 Ko hono fakahńĀ  Ľo ia, mo hono tupu Ľanga.\it*
\p 
\v 1 Fanongo ki he folofola ni  Ľa Sihova  Ľaia kuo ne folofola Ľaki kiate kimoutolu,  Ľe fńĀnau  Ľa  ĽIsileli, ki he kau nofo Ľanga kotoa pńď na Ľaku  Ľomi mei he fonua ko  ĽIsipite,  Ľo pehńď,
\q1 
\v 2 ‚ÄúKo kimoutolu pe kuo u  Ľilo  Ľi he ngaahi fa Ľahinga kotoa pńď  Ľo mńĀmani:
\q2 ko ia te u tautea  Ľakimoutolu koe Ľuhi ko ho Ľomou angahia kotoa pńď.‚ÄĚ
\q1 
\v 3 ‚ÄĆ ĽE fa Ľa  Ľa Ľeva ha toko ua,
\q2 ka  Ľoku  Ľikai te na fe Ľofo Ľofani pe?
\q1 
\v 4 ‚ÄĆ ĽE ngungulu ha laione  Ľi he vao  Ľakau,
\q2  Ľoka  Ľikai ha me Ľakai?
\q1  ĽE tangi ha laione mui  Ľi hono  Ľana,
\q2  Ľi he  Ľikai te ne mo Ľua ha me Ľa?
\q1 
\v 5 ‚ÄĆ ĽE mo Ľua ha manupuna  Ľi he fonua
\q2  Ľoka  Ľikai tauhele Ľi?
\q1  ĽE to Ľo  Ľae tauhele mei he fonua,
\q2  Ľoku te Ľeki ke tŇć ki ai ha me Ľa si Ľi  Ľe taha?
\q1 
\v 6 ‚ÄĆ ĽE ifi  Ľae me Ľalea  Ľi he kolo,
\q2 ka  Ľe  Ľikai manavahńď  Ľae kakai?
\q1  ĽE hoko ha kovi ki he kolo,
\q2 ka kuo  Ľikai fai ia  Ľe Sihova?
\q1 
\v 7 Ko e mo Ľoni  Ľe  Ľikai fai ha me Ľa  Ľe Sihova ko e  ĽOtua,
\q2 kae ta ĽefakahńĀ ia ki he Ľene kau tamaio Ľeiki ko e kau palŇćfita.
\q1 
\v 8 Kuo ngungulu  Ľae laione,
\q2 ko hai  Ľe  Ľikai manavahńď?
\q1 Kuo folofola  Ľa Sihova ko e  ĽOtua,
\q2 ko hai  Ľe  Ľikai kikite?
\q1 
\v 9 Fanongonongo  Ľi he ngaahi fale faka Ľei Ľeiki  Ľo  ĽAsitoti,
\q2 pea  Ľi he ngaahi fale faka Ľei Ľeiki  Ľo  ĽIsipite,
\q1  Ľo pehńď, ‚ÄúFakataha  Ľakimoutolu ki he ngaahi mo Ľunga  Ľo Samńďlia,
\q2 pea vakai  Ľae ngaahi maveuveu lahi  Ľi ai,
\q2 pea mo e fakamńĀlohia  Ľi he lotolotonga  Ľo ia.‚ÄĚ
\q1 
\v 10 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚Äú ĽOku  Ľikai te nau  Ľilo ke fai totonu,
\q2  Ľoku fokotu Ľu  Ľae fakamńĀlohi mo e kaiha Ľa  Ľi honau fale faka Ľei Ľeiki.‚ÄĚ
\p 
\v 11 Ko ia  Ľoku pehńď  Ľe Sihova ko e  ĽOtua,
\q1 ‚Äú ĽE ai ha fili te ne takatakai  Ľae fonua;
\q2 pea te ne holoki ho Ľo mńĀlohi meiate koe,
\q2 pea  Ľe maumau Ľi ho ngaahi fale faka Ľei Ľeiki.‚ÄĚ
\p 
\v 12 ‚ÄĆ ĽOku pehńď  Ľe Sihova,
\q1 ‚ÄúHangńď  Ľoku to Ľo  Ľe he tangata tauhimanu  Ľae alanga  Ľe ua,
\q2 pe ko e konga  Ľoe telinga mei he ngutu  Ľoe laione;
\q2  Ľe pehńď  Ľae to Ľo  Ľae fńĀnau  Ľa  ĽIsileli,  Ľoku nofo  Ľi he tuliki  Ľoe mohe Ľanga  Ľi Samńďlia,
\q2 pea  Ľi he tokoto Ľanga  Ľi Tamasikusi.‚ÄĚ
\q1 
\v 13 ‚ÄúMou fanongo, pea fakahńĀ  Ľi he fale  Ľo Sńďkope,‚ÄĚ  Ľoku pehńď  Ľe Sihova ko e  ĽOtua, ko e  ĽOtua  Ľoe ngaahi kautau.
\q1 
\v 14 ‚ÄúKoe Ľuhi  Ľi he  Ľaho ko ia, te u  Ľa Ľahi ki he ngaahi talangata Ľa  Ľa  ĽIsileli  Ľiate ia,
\q2 te u  Ľa Ľahi foki ki he ngaahi feilaulau Ľanga  Ľo Peteli:
\q2 pea  Ľe tutu Ľu  Ľae ngaahi nifo  Ľoe feilaulau Ľanga,
\q2 pea te nau tŇć ki he kelekele.
\q1 
\v 15 Pea te u taa Ľi  Ľae fale  Ľoe fa Ľahita Ľu momoko fakataha mo e fale  Ľoe fa Ľahita Ľu mafana;
\q2 pea mo e ngaahi fale lei  Ľe  Ľauha,
\q2 pea  Ľe  Ľosi  Ľae ngaahi fale lahi,‚ÄĚ
\p he  Ľoku pehńď  Ľe Sihova.
\c 4
\cd \it 1  ĽOku ne valoki Ľi  Ľa  ĽIsileli koe Ľuhi ko e fakamńĀlohi, 4 Mo e tauhi tamapua, 6 Pea mo  Ľenau angafefeka.\it*
\p 
\v 1 Fanongo ki he lea,  Ľakimoutolu ko e fanga pulu  Ľa Pesani,  Ľoku  Ľi he ngaahi mo Ľunga  Ľo Samńďlia,  Ľakimoutolu  Ľoku fakamńĀlohi Ľi  Ľae masiva, pea  Ľoku ta Ľomia ai  Ľae paea,  Ľakimoutolu  Ľoku mou pehńď ki honau ngaahi  Ľeiki, ‚Äú ĽOmi, ka mau inu.‚ÄĚ
\q1 
\v 2 Kuo fuakava ki he Ľene mńĀ Ľoni Ľoni  Ľe Sihova ko e  ĽOtua,  Ľo pehńď,
\q2 ‚ÄúVakai,  Ľe hoko  Ľae ngaahi  Ľaho kiate kimoutolu  Ľaia  Ľe  Ľave kimoutolu  Ľaki  Ľae ngaahi mńĀta Ľu,
\q2 pea mo homou hako  Ľaki  Ľae mńĀta Ľu ika.
\q1 
\v 3 Pea te mou  Ľalu kitu Ľa  Ľi he ngaahi ava,
\q2  Ľae fanga pulu kotoa pńď ki he me Ľa  Ľoku  Ľi hono  Ľao,
\q2 pea te mou lńę  Ľakinautolu ki he fale faka Ľei Ľeiki,‚ÄĚ  Ľoku pehńď  Ľe Sihova.
\q1 
\v 4 ‚ÄúHa Ľu ki Peteli, pea fai hala;
\q2 ki Kilikali, pea fakalahi  Ľae talangata Ľa;
\q1 pea  Ľomi ho Ľomou ngaahi feilaulau  Ľi he pongipongi kotoa pńď,
\q2 mo ho Ľomou fatongia lotu hili  Ľae ta Ľu  Ľe tolu;
\q1 
\v 5 Pea hifo  Ľaki  Ľae feilaulau fakafeta Ľi mo e me Ľa fakatapu,
\q2 pea malanga Ľaki mo fakahńĀ  Ľae ngaahi hifo mata Ľata ĽatńĀ:
\q2 he  Ľoku mou manako ai,  Ľe fńĀnau  Ľa  ĽIsileli,‚ÄĚ  Ľoku pehńď  Ľe Sihova ko e  ĽOtua.
\q1 
\v 6 ‚ÄúPea na Ľaku tuku  Ľae nifo ma Ľa kiate kimoutolu  Ľi homou ngaahi kolo kotoa pńď,
\q2 pea mo e masiva mńĀ  Ľi homou ngaahi potu kotoa pńď:
\q2 ka na Ľe  Ľikai te mou tafoki kiate au,‚ÄĚ  Ľoku pehńď  Ľe Sihova.
\q1 
\v 7 ‚ÄúPea na Ľaku ta Ľofi foki  Ľae  Ľuha meiate kimoutolu,
\q2  Ľi he kei toe  Ľae mńĀhina  Ľe tolu ki he ututa Ľu:
\q2 pea na Ľaku pehńď ke  Ľuha ki he kolo  Ľe taha,
\q2 kae  Ľikai ke  Ľuha ki he kolo  Ľe taha:
\q1 na Ľe  Ľuha ki he potu  Ľe taha,
\q2 pea ko e potu na Ľe  Ľikai ke  Ľuha ki ai ne mae ia.
\q1 
\v 8 Pea na Ľe fononga  Ľae kolo  Ľe ua pe tolu ki he kolo  Ľe taha, ke inu vai;
\q2 ka na Ľe  Ľikai te nau fiu:
\q2 ka na Ľe  Ľikai te mou tafoki kiate au,‚ÄĚ  Ľoku pehńď  Ľe Sihova.
\q1 
\v 9 ‚ÄúKuo taa Ľi  Ľakimoutolu  Ľaki  Ľae mae mo e mahunu:  Ľi he tupu  Ľa ho Ľomou ngoue, mo e ngoue vaine,
\q2 mo e  Ľakau ko e fiki mo e  Ľolive, na Ľe kai ia  Ľe he  Ľunufe maumau:
\q2 ka na Ľe  Ľikai te mou tafoki kiate au,‚ÄĚ  Ľoku pehńď  Ľe Sihova.
\q1 
\v 10 ‚ÄúKuo fekau kiate kimoutolu  Ľae mahaki lahi  Ľo hangńď ko  ĽIsipite:
\q2 kuo tńĀmate Ľi ho Ľomou kau talavou  Ľaki  Ľae heletńĀ,
\q2 pea kuo  Ľave ho Ľomou fanga hoosi:
\q2 pea kuo u ngaohi ke hoko  Ľae namukŇę  Ľoe nofo Ľanga  Ľo homou kau tau ki homou ava Ľi ihu:
\q2 ka na Ľe  Ľikai te mou tafoki kiate au,‚ÄĚ  Ľoku pehńď  Ľe Sihova.
\q1 
\v 11 ‚ÄúKuo u fulihi ho Ľomou ni Ľihi,
\q2 hangńď na Ľe fulihi  Ľe he  ĽOtua  Ľa Sotoma mo Komola,
\q2 pea na Ľa mou hangńď ko e potupotu Ľi afi kuo hamusi mei he vela:
\q2 ka na Ľe  Ľikai te mou tafoki kiate au,‚ÄĚ  Ľoku pehńď  Ľe Sihova.
\q1 
\v 12 ‚ÄúKo ia,  Ľe pehńď pe  Ľa  Ľeku fai kiate koe,  Ľe  ĽIsileli:
\q2 pea koe Ľuhi te u fai eni kiate koe,
\q2 teuteu ke fe Ľiloaki mo ho  ĽOtua,  Ľe  ĽIsileli.
\q1 
\v 13 Koe Ľuhi, vakai, ko ia ia na Ľe ngaohi  Ľae ngaahi mo Ľunga,
\q2 pea ne fakatupu  Ľae matangi,
\q2 pea  Ľoku ne fakahńĀ ki he tangata pe ko e hńĀ  Ľene mahalo,
\q2  Ľoku ne ngaohi  Ľae pongipongi ko e po Ľuli,
\q2 pea  Ľoku ne malaki  Ľae ngaahi potu mńĀ Ľolunga  Ľo mńĀmani,
\q2 Ko Sihova, ko e  ĽOtua  Ľoe ngaahi kautau  Ľa hono huafa.‚ÄĚ
\c 5
\cd \it 1 Ko e tangilńĀulau koe Ľuhi ko  ĽIsileli, 4 Ko e enginaki ki he fakatomala. 21  ĽOku li Ľaki  Ľe he  ĽOtua  Ľa  Ľenau ngńĀue fakamńĀlualoi.\it*
\p 
\v 1 Fanongo ki he lea ni,  Ľoku ou  Ľai kiate kimoutolu,  Ľi he tangilńĀulau,  Ľe fale  Ľo  ĽIsileli.
\q1 
\v 2 ‚ÄúKuo hinga  Ľae ta Ľahine  Ľa  ĽIsileli,
\q2  Ľe  Ľikai te ne toetu Ľu;
\q1 kuo li Ľaki ia  Ľi hono fonua;
\q2  Ľoku  Ľikai ha taha ke toe fokotu Ľu ia.‚ÄĚ
\q1 
\v 3 He  Ľoku pehńď  Ľe Sihova, ko e  ĽOtua;
\q1 ‚ÄúKo e kolo na Ľe  Ľalu ai  Ľae toko taha afe,  Ľe toe pe  Ľae toko teau,
\q2 pea ko ia na Ľe  Ľalu ai  Ľae toko teau,  Ľe toe pe  Ľae toko hongofulu, ki he fale  Ľo  ĽIsileli.
\p 
\v 4 ¬∂ Pea  Ľoku pehńď  Ľe Sihova ki he fale  Ľo  ĽIsileli,
\q2 ‚ÄúKumi kiate au, pea te mou mo Ľui:
\q1 
\v 5 Kae Ľoua na Ľa kumi  Ľa Peteli,
\q2 pe hŇę ki Kilikali,
\q2 pea  Ľoua na Ľa laka ki Peasipa:
\q1 koe Ľuhi  Ľe  Ľalu mo Ľoni  Ľa Kilikali ke pŇćpula,
\q2 pea  Ľe hoko  Ľa Peteli ko e me Ľa noa pńď.
\q1 
\v 6 Kumi kia Sihova, pea te mou mo Ľui telia na Ľa hńĀ mai ia,
\q2 hangńď ko e afi  Ľi he fale  Ľo Siosefa,
\q2 pea ne keina ia, kae  Ľikai ha taha  Ľi Peteli ke fu Ľifu Ľi ia.
\q1 
\v 7 Ko kimoutolu  Ľoku liliu  Ľae fakamaau ko e  Ľakau kona,
\q2 pea mou tuku  Ľae angatonu  Ľi he fonua,
\q1 
\v 8 \add Kumi ia \add*na Ľa ne ngaohi  Ľae fetu Ľu  Ľe fitu mo  ĽOlioni,
\q2 pea  Ľoku ne liliu  Ľae  Ľata  Ľoe mate ko e pongipongi,
\q2 pea ne ngaohi  Ľae  Ľaho ke po Ľuli  Ľi he pŇć:
\q2 pea  Ľoku ne ui  Ľae ngaahi vai  Ľoe tahi,
\q2 pea ne lilingi ia ki he funga  Ľoe fonua: ko Sihova hono huafa:
\q1 
\v 9 ‚ÄĆ ĽOku ne fakamńĀlohi  Ľae vetekina ki he mńĀlohi,
\q2 koe Ľuhi ke tau Ľi  Ľe he vetekina  Ľae kolo.
\q1 
\v 10 ‚ÄĆ ĽOku nau fehi Ľa kiate ia  Ľoku fai  Ľae valoki  Ľi he matapńĀ,
\q2 pea  Ľoku nau fńĀkalili Ľa kiate ia  Ľoku lea  Ľi he angatonu.
\q1 
\v 11 Koe Ľuhi ko e me Ľa  Ľi ho Ľomou malaki Ľi  Ľae kakai masiva,
\q2 pea  Ľoku mou to Ľo meiate ia  Ľae ngaahi kavenga uite:
\q2 kuo mou langa  Ľae ngaahi fale  Ľaki  Ľae maka kuo tńĀ,
\q2 ka  Ľe  Ľikai te mou nofo ai;
\q1 kuo mou tŇć  Ľae ngaahi ngoue vaine matamatalelei,
\q2 ka  Ľe  Ľikai te mou inu uaine mei ai.
\q1 
\v 12 He  Ľoku ou  Ľilo ho Ľomou ngaahi talangata Ľa lahi,
\q2 pea mo ho Ľomou fungani angahala:
\q2  Ľoku nau fakamamahi Ľi  Ľae angatonu,
\q2  Ľoku nau ma Ľu tukungoue,
\q2 pea  Ľoku nau fakateketeke atu  Ľae kakai masiva  Ľi he matapńĀ.
\q1 
\v 13 Ko ia  Ľe longo ai  Ľae fakapotopoto  Ľi he kuonga ko ia;
\q2 he ko e kuonga kovi.
\q1 
\v 14 Kumi  Ľae lelei, kae  Ľikai ko e kovi,
\q2 koe Ľuhi ke mou mo Ľui:
\q2 ko ia, ko Sihova ko e  ĽOtua  Ľoe ngaahi tokolahi, te ne  Ľiate kimoutolu,
\q2  Ľo hangńď ko ho Ľomou lea.
\q1 
\v 15 Fehi Ľa ki he kovi, pea  Ľofa ki he lelei,
\q2 pea fokotu Ľuma Ľu  Ľae fakamaau  Ľi he matapńĀ;
\q2 hei Ľilo pe  Ľe  Ľalo Ľofa  Ľa Sihova, ko e  ĽOtua  Ľoe ngaahi kautau, ki he toenga  Ľo Siosefa.‚ÄĚ
\p 
\v 16 Ko ia ko Sihova ko e  ĽOtua  Ľoe ngaahi kautau, ko e  ĽEiki,  Ľoku pehńď,
\q1 ‚Äú ĽE  Ľi ai  Ľae tangi  Ľi he ngaahi hala kotoa pńď;
\q2 pea te nau pehńď  Ľi he ngaahi hala motu Ľa kotoa pńď, ‚Äė ĽOiauńď!  ĽOiauńď!‚Äô
\q2 Pea te nau ui  Ľae tangata ngoue ki he tangi,
\q2 pea mo kinautolu  Ľoku poto  Ľi he tangilńĀulau ke fai  Ľae tangi.
\q1 
\v 17 Pea  Ľe  Ľi ai  Ľae tangi  Ľi he ngoue vaine kotoa pńď:
\q2 he te u laka mai  Ľiate koe,‚ÄĚ  Ľoku pehńď  Ľe Sihova.
\q1 
\v 18 ‚ÄúMala Ľia kiate kimoutolu  Ľoku holi ki he  Ľaho  Ľo Sihova!
\q2 He koe Ľuma ĽńĀ ia kiate kimoutolu?
\q1 Ko e  Ľaho  Ľo Sihova kuo po Ľuli,
\q2 kae  Ľikai maama.
\q1 
\v 19 Hangńď ko e tangata  Ľoku hola mei he laione,
\q2 pea  Ľoku ne fakafetaulaki mo ha pea;
\q1 pe ko ha taha ne hŇę ki fale, pea ne fa Ľaki hono nima ki he holisi,
\q2 ka na Ľe  Ľuusi ia  Ľe ha ngata.
\q1 
\v 20 ‚ÄĆ ĽIkai  Ľe po Ľuli  Ľae  Ľaho  Ľo Sihova, pea  Ľikai maama?
\q2  ĽIo, ko e po Ľuli  Ľaupito, ka  Ľe  Ľikai  Ľi ai ha maama si Ľi ke ulo?
\q1 
\v 21 ‚Äú ĽOku ou fehi Ľa,  Ľoku ou fakalili Ľa ki homou ngaahi  Ľaho kńĀtoanga,
\q2 pea  Ľe  Ľikai te u nanamu ki ho Ľomou ngaahi fakataha mamafa.
\q1 
\v 22 Neongo  Ľoku mou hifo  Ľaki  Ľae ngaahi feilaulau tutu mo e ngaahi feilaulau me Ľakai,
\q2  Ľe  Ľikai te u ma Ľu ia:
\q2 pea  Ľe  Ľikai te u tokanga Ľi  Ľae ngaahi feilaulau fakalelei  Ľo ho Ľomou fanga manu sino.
\q1 
\v 23 Hiki ke mama Ľo  Ľiate au  Ľae longoa Ľa  Ľo ho Ľomou hiva;
\q2 he  Ľe  Ľikai te u fanongo ki he mńĀlie  Ľo ho Ľomou ngaahi me Ľa faiva.
\q1 
\v 24 Ka  Ľe tuku  Ľae fakamaau ke tafe hangńď ko e vai,
\q2 pea mo e angatonu hangńď ko e vaitafe mńĀlohi.
\p 
\v 25 ‚ÄúKuo mou hifo  Ľaki  Ľae ngaahi feilaulau mo e ngaahi hifo kiate au,  Ľi he ta Ľu  Ľe fńĀngofulu  Ľi he toafa,  Ľe fale  Ľo  ĽIsileli?
\v 26 Ka kuo mou fua  Ľae fale fehikitaki  Ľo homou Moloke mo Kiuni, ko ho Ľomou ongo tamapua, ko e fetu Ľu  Ľo homou  Ľotua,  Ľaia na Ľa mou ngaohi mo Ľomoutolu.
\v 27 Ko ia te u pule ke mou  Ľalu pŇćpula kitu Ľa Tamasikusi:‚ÄĚ  Ľoku pehńď  Ľa Sihova,  Ľaia ko hono huafa, ko e  ĽOtua  Ľoe ngaahi kautau.
\c 6
\cd \it 1 Ko e angafakalusa  Ľa  ĽIsileli. 7  ĽE tautea  Ľaki  Ľae fakalala. 12 Ko  Ľenau angafefeka.\it*
\p 
\v 1 Mala Ľia kiate kinautolu  Ľoku fakafiemńĀlie kovi  Ľi Saione,
\q2 pea  Ľoku falala ki he mo Ľunga  Ľo Samńďlia,
\q2  Ľoku ui ko e tu Ľu ki mu Ľa  Ľi he ngaahi pule Ľanga,
\q2  Ľaia na Ľe ha Ľu ki ai  Ľae fale  Ľo  ĽIsileli!
\q1 
\v 2 Laka koe ki Kaline, pea vakai:
\q2 pea  Ľalu mei ai ki Hamati lahi:
\q2 pea toki  Ľalu hifo ki Kati  Ľoe kakai Filisitia:
\q1  Ľoku nau lelei lahi końĀ  Ľi he ngaahi pule Ľanga ni?
\q2 Pe  Ľoku lahi hake honau mata fonua,  Ľi homou mata fonua?
\q1 
\v 3 Ko kimoutolu  Ľoku tuku mama Ľo atu  Ľae  Ľaho kovi,
\q2 pea  Ľoku pule ke  Ľunu Ľunu mai  Ľae nofo Ľa  Ľoe fakamńĀlohi;
\q1 
\v 4 Pea  Ľoku tokoto  Ľi he ngaahi mohenga lei,
\q2 pea  Ľoku fakatokoto  Ľekinautolu  Ľi he ngaahi tokoto Ľanga,
\q2 pea  Ľoku kai  Ľae fanga lami mei he fanga manu,
\q2 pea mo e  Ľuhiki pulu mei he fale manu;
\q2 
\v 5 Pea  Ľoku hivehiva ki he le Ľo  Ľoe me Ľa faiva,
\q2 pea  Ľoku filio Ľi ke ngaohi ma Ľanautolu  Ľae ngaahi me Ľa faiva ke hiva  Ľaki, hangńď ko Tevita;
\q2 
\v 6 Pea  Ľoku inu uaine mei he ngaahi ipu,
\q2 pea  Ľoku tńĀkai  Ľakinautolu  Ľaki  Ľae lolo mahu Ľinga:
\q2 ka  Ľoku  Ľikai te nau mamahi  Ľi he tu ĽutńĀmaki  Ľa Siosefa.
\q1 
\v 7 Ko ia te nau  Ľalu ke pŇćpula mo e kakai  Ľoku tomu Ľa  Ľalu ki he pŇćpula,
\q2 pea ko e kńĀtoanga kai  Ľanautolu na Ľe fakatokoto  Ľe fetuku.
\q1 
\v 8 ‚ÄúKuo fuakava  Ľa Sihova  Ľi he Ľene  Ľafio,‚ÄĚ  Ľoku pehńď  Ľe Sihova, ko e  ĽOtua  Ľoe ngaahi kautau,
\q2 ‚Äú Ľoku ou fehi Ľa ki he lelei  Ľo Sńďkope,
\q2 pea fńĀkalili Ľa ki hono ngaahi fale faka Ľeiki;
\q2 ko ia te u tukuange  Ľae kolo mo ia kotoa pńď  Ľoku  Ľi ai.
\q1 
\v 9 Pea  Ľe pehńď, ka ai ha kau tangata  Ľe toko hongofulu kuo tuku  Ľi he fale  Ľe taha,
\q2 te nau mate.
\p 
\v 10 ‚Äú ĽE to Ľo  Ľae tangata  Ľe he Ľene tu Ľasina, pea mo ia ne tutu ia, ke  Ľomi  Ľae ngaahi hui mei he fale, pea te ne pehńď kiate ia  Ľoku  Ľi he ve Ľe fale, ‚Äė ĽOku ai ha taha mo koe?‚Äô Pea te ne pehńď, ‚Äė ĽIkai.‚Äô Pea te ne toki pehńď, ‚Äė ĽOua te ke lea: he  Ľoku tapu ke takua  Ľae huafa  Ľo Sihova.‚Äô
\b
\q1 
\v 11 ‚ÄúKoe Ľuhi, vakai,  Ľoku fekau  Ľe Sihova, pea te ne taa Ľi  Ľae fale lahi ke avaava,
\q2 pea mo e fale si Ľi ke mafahifahi.
\q1 
\v 12 ‚ÄĆ ĽE lele końĀ  Ľae fanga hoosi  Ľi he funga maka?
\q2  ĽE ai ha taha te ne toho huo ai  Ľaki  Ľae fanga pulu?
\q1 He kuo mou liliu  Ľae fakamaau ko e  Ľahu,
\q2 pea ko e fua  Ľoe angatonu ko e hemiloki:
\q1 
\v 13 ‚ÄĆ ĽAkimoutolu  Ľoku fiefia  Ľi he me Ľa noa pe, pea lea pehńď,
\q2 ‚Äė ĽIkai kuo tau ma Ľu  Ľae nifo,  Ľi hotau mńĀlohi pe?‚Äô‚ÄĚ
\q1 
\v 14 Ka  Ľoku pehńď  Ľe Sihova, ko e  ĽOtua  Ľoe ngaahi kautau,
\q2 ‚ÄúVakai; te u fokotu Ľu kiate kimoutolu ha pule Ľanga,  Ľe fale  Ľo  ĽIsileli;
\q2 pea te nau fakamamahi  Ľakimoutolu mei he hŇę Ľanga ki Hamati  Ľo a Ľu ki he vaitafe  Ľoe toafa.‚ÄĚ
\c 7
\cd \it 1 Ko e tautea  Ľae fanga he Ľe, 4 Pea mo e afi,  Ľoku fakaafe  Ľi he lotu  Ľa  ĽAmosi. 7  ĽI he  ĽńĀ na Ľe ngaohi ki he afo fuofua  Ľoku hńĀ ai hono li Ľaki  Ľo  ĽIsileli. 10  ĽOku lńĀunga  Ľa  ĽAmasia kia  ĽAmosi. 14  ĽOku fakahńĀ  Ľe  ĽAmosi hono uiui Ľi. 16 Pea mo e fakamaau  Ľo  ĽAmasia.\it*
\p 
\v 1 ‚ÄĆ ĽOku pehńď hono fakahńĀ mai kiate au  Ľe he  ĽEiki ko e  ĽOtua; pea vakai, na Ľa ne ngaohi  Ľae ngaahi he Ľe  Ľi he kamata Ľanga  Ľoe tupu hake  Ľae ta Ľu tokamui; pea vakai, ko e tokamui ia hili  Ľae tu Ľusi ma Ľa e tu Ľi.
\v 2 Pea na Ľe hoko, hili  Ľenau kai  Ľo  Ľosi  Ľae mohuku  Ľoe fonua, pea ne u pehńď, ‚Äú ĽE Sihova ko e  ĽOtua,  Ľoku ou kole kiate koe, ke ke fakamolemole:  Ľe toetu Ľu  Ľa Sńďkope ia hai? He  Ľoku si Ľi ia.‚ÄĚ
\p 
\v 3 Na Ľe fakatomala  Ľa Sihova  Ľi he me Ľa ni:  Ľoku pehńď  Ľe Sihova, ‚Äú ĽE  Ľikai hoko ia.‚ÄĚ
\p 
\v 4 ‚ÄĆ ĽOku pehńď hono fakahńĀ mai kiate au  Ľe he  ĽEiki ko e  ĽOtua; pea vakai, na Ľe ui  Ľe he  ĽEiki ko e  ĽOtua ke tau  Ľaki  Ľae afi, pea na Ľa ne kai  Ľae moana lahi, pea ne folo  Ľae vahe  Ľe taha?
\v 5 Pea na Ľaku toki pehńď,  ĽE Sihova ko e  ĽOtua, ‚Äú ĽOku ou kole kiate koe ke tuku  ĽńĀ:  Ľe toetu Ľu  Ľa Sńďkope  Ľia hai? He  Ľoku si Ľi ia.‚ÄĚ
\v 6 Na Ľe fakatomala  Ľa Sihova  Ľi he me Ľa ni:  Ľoku pehńď  Ľe he  ĽEiki ko e  ĽOtua, ‚Äú ĽE  Ľikai hoko eni foki.‚ÄĚ
\p 
\v 7 ¬∂ Na Ľe pehńď  Ľene fakahńĀ mai ia kiate au: pea vakai, na Ľe tu Ľu  Ľae  ĽEiki  Ľi he fukahi  ĽńĀ na Ľe ngaohi ki he afo fuofua, pea na Ľe  Ľai  Ľae afo fuofua  Ľi hono nima.
\v 8 Pea na Ľe pehńď  Ľe Sihova kiate au, ‚Äú ĽAmosi, ko e hńĀ  Ľoku ke mamata ai?‚ÄĚ Pea na Ľaku pehńď, ‚ÄúKo e afo fuofua.‚ÄĚ Pea ne pehńď  Ľe he  ĽEiki, ‚ÄúVakai, te u  Ľai  Ľae afo fuofua ki he lotolotonga  Ľo hoku kakai ko  ĽIsileli:  Ľikai te u toe laka  Ľiate kinautolu:
\v 9 Pea  Ľe lala  Ľae ngaahi potu mńĀ Ľolunga  Ľo  ĽAisake, pea  Ľe ngaongao  Ľae ngaahi falelotu  Ľo  ĽIsileli; pea te u tu Ľu hake mo e heletńĀ ki he fale  Ľo Selopoami.‚ÄĚ
\p 
\v 10 ¬∂ Pea ne toki fekau  Ľe  ĽAmasia ko e taula Ľeiki  Ľi Peteli, kia Selopoami ko e tu Ľi  Ľo  ĽIsileli,  Ľo pehńď, ‚ÄúKuo angatu Ľu  Ľa  ĽAmosi kiate koe  Ľi he lotolotonga  Ľoe fale  Ľo  ĽIsileli:  Ľe  Ľikai fa Ľa kńĀtaki  Ľe he fonua  Ľa  Ľene ngaahi lea kotoa pńď.
\v 11 Koe Ľuhi  Ľoku pehńď  Ľe  ĽAmosi, ‚Äė ĽE mate  Ľa Selopoami  Ľi he heletńĀ, pea ko e mo Ľoni  Ľe taki pŇćpula  Ľa  ĽIsileli mei honau fonua  Ľonautolu.‚Äô‚ÄĚ
\v 12 Pea ne pehńď foki  Ľe  ĽAmasia kia  ĽAmosi, ‚Äú ĽA koe  Ľoku mamata me Ľa,  Ľalu, puna atu ki he fonua  Ľo Siuta, pea kai ai  Ľae mńĀ, mo kikite ai:
\v 13 Kae  Ľoua na Ľa toe kikite  Ľi Peteli he ko e falelotu ia  Ľoe tu Ľi, pea ko e nofo Ľanga  Ľoe tu Ľi.‚ÄĚ
\p 
\v 14 ¬∂ Pea na Ľe tali  Ľe  ĽAmosi,  Ľo ne pehńď kia  ĽAmasia, ‚ÄúNa Ľe  Ľikai ko e palŇćfita au, pe ko e foha  Ľo ha palŇćfita; ko e tangata tauhimanu au, pea ko e tńĀnaki \add au \add* Ľoe fua  Ľoe sukamino:
\v 15 Pea na Ľe  Ľave au  Ľe Sihova  Ľi he Ľeku muimui ki he fanga manu, pea na Ľe pehńď  Ľe Sihova kiate au, ‚Äė ĽAlu,  Ľo kikite ki hoku kakai ko  ĽIsileli.‚Äô
\p 
\v 16 ¬∂ Pea ko eni, fanongo koe ki he folofola  Ľa Sihova:  Ľoku ke pehńď, ‚Äė ĽOua na Ľa kikite ki  ĽIsileli, pea  Ľoua na Ľa tŇć \add ho Ľo lea \add*ki he fale  Ľo  ĽAisake.‚Äô
\v 17 Ko ia  Ľoku pehńď  Ľe Sihova; ‚Äė ĽE hoko ho uaifi ko e fefine fe Ľauaki  Ľi he kolo, pea ko ho ngaahi foha mo ho ngaahi  Ľofefine,  Ľe tŇć  Ľi he heletńĀ, pea  Ľe vahevahe ho fonua  Ľaki  Ľae afo; pea te ke mate  Ľi ha fonua pani  Ľuli: pea  Ľe  Ľalu mo Ľoni  Ľa  ĽIsileli mei hono fonua ki he pŇćpula.‚Äô‚ÄĚ
\c 8
\cd \it 1  ĽI he kato fua Ľi  Ľakau  Ľoe fa Ľahita Ľu mafana  Ľoku fakahńĀ  Ľoku ofi  Ľae ngata Ľanga  Ľo  ĽIsileli. 4  ĽOku valoki Ľi  Ľae fakamńĀlohi. 11  ĽOku faka Ľilo  Ľae honge folofola.\it*
\p 
\v 1 ‚ÄĆ ĽOku pehńď hono fakahńĀ mai kiate au  Ľe he  ĽEiki ko e  ĽOtua: pea vakai, ko e kato fua Ľi  Ľakau  Ľoe fa Ľahita Ľu mafana.
\p 
\v 2 Pea na Ľa ne pehńď, ‚Äú ĽAmosi, Ko e hńĀ  Ľoku ke mamata ai?‚ÄĚ
\p Pea u pehńď, ‚ÄúKo e kato fua Ľi  Ľakau  Ľoe fa Ľahita Ľu mafana.‚ÄĚ
\p Pea na Ľe pehńď  Ľe Sihova kiate au,
\q1 ‚ÄúKuo hoko hono ngata Ľanga ki hoku kakai ko  ĽIsileli;
\q2  Ľe  Ľikai te u toe laka  Ľiate kinautolu.‚ÄĚ
\q1 
\v 3 ‚ÄĆ ĽOku pehńď  Ľe Sihova ko e  ĽOtua, ‚Äú ĽE hoko  Ľae ngaahi hiva  Ľoe fale tapu, ko e tangi fakalŇćloa  Ľi he  Ľaho ko ia:
\q2  Ľe lahi  Ľae  Ľanga Ľanga  Ľi he potu kotoa pńď;  Ľe lńę  Ľakinautolu kitu Ľa  Ľi he fakalongo pńď.
\q1 
\v 4 Fanongo eni,  Ľakimoutolu  Ľoku folo hifo  Ľae paea,
\q2  Ľio, ke faka Ľosi  Ľae kakai masiva mei he fonua,
\q2 
\v 5 ‚ÄĆ ĽO pehńď, ‚Äė ĽE  Ľosi  Ľafńď  Ľae mńĀhina fo Ľou, ka tau fakatau koane?
\q2 Pea mo e  Ľaho tapu, ka tau vakili  Ľae uite,
\q2  Ľo fakasi Ľisi Ľi  Ľae efa, pea fakalahi  Ľae sikeli,
\q2 pea fakakehe  Ľae me Ľa fua tautau  Ľi he kńĀkńĀ?
\q1 
\v 6 Pea ke tau fakatau  Ľae kakai masiva  Ľaki  Ľae siliva,
\q2 pea mo e paea  Ľaki ha topuva Ľe:
\q2 pea ke fakatau  Ľae uite kovi?‚Äô‚ÄĚ
\q1 
\v 7 Kuo fuakava  Ľaki  Ľe Sihova  Ľae lelei  Ľo Sńďkope,
\q2 ‚ÄúKo e mo Ľoni  Ľe  Ľikai ngalo  Ľiate au  Ľenau ngaahi ngńĀue  Ľo lauikuonga.
\q1 
\v 8 ‚ÄĆ ĽIkai  Ľe tetetete  Ľae fonua koe Ľuhi ko eni,
\q2 pea taki taha tangi  Ľaia  Ľoku nofo  Ľi ai?
\q1 Pea  Ľe tupu kńĀtoa ia  Ľo hangńď ko e lŇćmaki;
\q2 pea  Ľe lńę ia kitu Ľa  Ľo melemo, hangńď ko e malofa  Ľi  ĽIsipite.
\q1 
\v 9 ‚ÄĆ ĽOku pehńď  Ľe Sihova ko e  ĽOtua, ‚Äú Ľe hoko  Ľi he  Ľaho ko ia,
\q2 te u pule ke tŇć  Ľae la ĽńĀ  Ľi he ho ĽatńĀmńĀlie,
\q2 pea te u fakapo Ľuli Ľi  Ľa mńĀmani  Ľi he kei  Ľaho  Ľaupito:
\q1 
\v 10 Pea te u liliu ho Ľomou ngaahi kńĀtoanga ko e tangi,
\q2 pea mo ho Ľomou hiva kotoa pńď ki he tangilńĀulau;
\q1 pea te u  Ľomi  Ľae tauanga Ľa ki homou kongaloto kotoa pńď,
\q2 pea  Ľe tekefua  Ľae  Ľulu kotoa pńď;
\q1 pea te u ngaohi ia ke hangńď ko e tangi koe Ľuhi ko e pele pe taha,
\q2 pea ko hono ngata Ľanga ke hangńď ko e  Ľaho  Ľoe mamahi kona.
\q1 
\v 11 Vakai,  Ľoku hoko  Ľae ngaahi  Ľaho,‚ÄĚ  Ľoku pehńď  Ľe Sihova ko e  ĽOtua,
\q2 ‚Äú ĽAia te u fekau  Ľae honge ki he fonua,
\q2 kae  Ľikai ko e honge mńĀ,
\q2 pe ko e fieinu vai,
\q2 ka ko e fanongo ki he ngaahi folofola  Ľa Sihova:
\q1 
\v 12 Pea te nau  ĽńĀuhńď mei he tahi ki he tahi,
\q2 pea mei he tokelau ki hahake,
\q2 te nau lele fano pe ke kumi  Ľae folofola  Ľa Sihova,
\q2 ka  Ľe  Ľikai te nau  Ľilo ia.
\q1 
\v 13 ‚ÄĆ ĽI he  Ľaho ko ia  Ľe pongia  Ľae kau ta Ľahine hoihoifua,
\q2 mo e kau talavou  Ľi he fieinu.
\q1 
\v 14 Ko kinautolu  Ľoku fuakava ki he angahala  Ľa Samńďlia,
\q2 pea lea pehńď, ‚Äė ĽOku mo Ľui ho  Ľotua,  Ľe Tani;‚Äô
\q2 pea ‚ÄėKo e anga  Ľo Peasipa  Ľoku mo Ľui;‚Äô
\q2 te nau tŇć, pea  Ľe  Ľikai te nau toetu Ľu  Ľo lauikuonga.‚ÄĚ
\c 9
\cd \it 1 Ko hono mo Ľoni  Ľoe fakalala. 11 Ko e fakafo Ľou  Ľoe fale fehikitaki  Ľo Tevita.\it*
\p 
\v 1 Na Ľa ku mamata kia Sihova na Ľe  Ľafio mei he feilaulau Ľanga: pea na Ľa ne pehńď, ‚ÄúTaa Ľi  Ľae  Ľakau fakalava  Ľoe matapńĀ, kae lulululu hono pou; pea taa Ľi  Ľakinautolu kotoa pńď  Ľi honau  Ľulu; pea te u tńĀmate Ľi  Ľae tomui  Ľokinautolu  Ľaki  Ľae heletńĀ: ko ia  Ľoku hola  Ľe  Ľikai te ne hao, pea ko ia  Ľoku hao  Ľe  Ľikai fakamo Ľui ia.
\v 2 Neongo  Ľoku nau keli hifo ki heli,  Ľe ma Ľu  Ľakinautolu mei ai  Ľe hoku nima; neongo  Ľoku nau kaka hake ki he langi, te u  Ľomi  Ľakinautolu ki lalo:
\v 3 Neongo  Ľoku nau fufŇę  Ľakinautolu  Ľi he funga  Ľo Kameli, te u kumi pea  Ľave  Ľakinautolu mei ai; pea neongo  Ľoku nau fufŇę mei hoku  Ľao  Ľi he kilisi tahi, te u fekau mei ai  Ľae ngata, pea te ne  Ľuusi  Ľakinautolu:
\v 4 Pea neongo  Ľoku nau  Ľalu pŇćpula  Ľi he  Ľao  Ľo honau ngaahi fili, te u fekau mei ai  Ľae heletńĀ, pea te ne tńĀmate Ľi  Ľakinautolu: pea te u hanga hoku fofonga kiate kinautolu ke kovi, pea  Ľikai ke lelei.‚ÄĚ
\v 5 Pea ko e  ĽEiki, ko e  ĽOtua  Ľoe ngaahi kautau, ko ia ia  Ľoku ala ki he fonua, pea  Ľe vai ia, pea ko kinautolu  Ľoku nofo ai te nau tangi; pea  Ľe tupu ia hangńď ha lŇćmaki: pea  Ľe melemo hifo, hangńď ko e malofa  Ľi  ĽIsipite.
\v 6 Ko ia ia  Ľoku langa hono ngaahi fale fata  Ľi he langi, pea kuo tńĀnaki  Ľene kautau  Ľi mńĀmani;  Ľaia  Ľoku ne ui  Ľae ngaahi vai  Ľoe tahi, pea ne hua Ľi ia  Ľi he funga  Ľoe fonua: ko Sihova hono huafa.
\v 7 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚Äú ĽIkai  Ľoku mou hangńď ko e fńĀnau  Ľae kakai  ĽItiopea kiate au,  ĽE fńĀnau  Ľa  ĽIsileli?  ĽIkai na Ľaku  Ľomi  Ľa  ĽIsileli mei he fonua ko  ĽIsipite? Pea mo e Filisitia mei Kafitoli, pea mo e kau Silia mei Kili?
\v 8 Vakai, ko e fofonga  Ľoe  ĽEiki ko e  ĽOtua,  Ľoku  Ľi he pule Ľanga angahala, pea te u faka Ľauha ia mei he funga fonua; ka  Ľe  Ľikai  Ľauha  Ľaupito  Ľae fale  Ľo Sńďkope,  Ľoku pehńď  Ľe Sihova.
\v 9 Koe Ľuhi, vakai, te u fakatanga  Ľae fale  Ľo  ĽIsileli  Ľi he ngaahi pule Ľanga, hangńď  Ľoku fakatanga  Ľae koane  Ľi he me Ľa fakatanga, ka  Ľe  Ľikai tŇć ha fo Ľi tenga ki he kelekele.
\v 10 ‚ÄĆ ĽE mate  Ľi he heletńĀ  Ľae kau angahala kotoa pńď  Ľa hoku kakai,  Ľoku lea pehńď, ‚Äė ĽE  Ľikai mo Ľua pe ta Ľofi  Ľakitautolu  Ľe he kovi.‚Äô
\v 11 ‚ÄĆ ĽI he  Ľaho ko ia te u toe langa  Ľae fale fehikitaki  Ľo Tevita  Ľaia kuo hinga, pea tńĀpuni  Ľae ngaahi ava  Ľo ia; pea te u toe fokotu Ľu  Ľae ngaahi me Ľa kuo holoki, pea te u langa Ľi ia  Ľo hangńď ko e ngaahi  Ľaho  Ľi mu Ľa:
\v 12 Koe Ľuhi ke nau ma Ľu  Ľae toenga  Ľo  ĽItomi, pea mo e hiteni kotoa pńď,  Ľoku ui  Ľaki hoku huafa:‚ÄĚ  Ľoku pehńď  Ľe Sihova,  Ľaia  Ľoku fai eni:
\q1 
\v 13 ‚ÄúVakai,‚ÄĚ  Ľoku pehńď  Ľe Sihova,
\q2 ‚Äú ĽOku hoko  Ľae ngaahi  Ľaho,  Ľe ma Ľu atu  Ľe he tangata tauhi huo toho  Ľae tangata tu Ľusi,
\q2 pea ko ia  Ľoku malaki  Ľae kńĀlepi,  Ľaia  Ľoku tŇętuu Ľi  Ľae tenga;
\q2 pea  Ľe to Ľi Ľi  Ľae uaine melie  Ľe he ngaahi mo Ľunga,
\q2 pea  Ľe vai  Ľae ngaahi tafungofunga kotoa pńď:
\q1 
\v 14 Pea te u toe  Ľomi  Ľae pŇćpula  Ľo hoku kakai ko  ĽIsileli,
\q2 pea te nau toe langa  Ľae kolo na Ľe lala, pea nofo ai;
\q2 pea te nau tŇć ngoue vaine, pea inu  Ľae uaine  Ľo ia;
\q1 te nau ngoue foki,
\q2 pea kai hono fua.
\q1 
\v 15 Pea te u tŇć  Ľakinautolu  Ľi honau fonua,
\q2 pea  Ľe  Ľikai toe ta Ľaki  Ľakinautolu mei he fonua,  Ľaia kuo u foaki kiate kinautolu,‚ÄĚ
\q2  Ľoku pehńď  Ľe Sihova ko ho  ĽOtua. 
