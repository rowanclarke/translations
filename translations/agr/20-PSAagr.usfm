\id PSA - Aguaruna 
\h Salmos 
\toc1 Salmos 
\toc2 (Salmos) 
\toc3 Sal. 
\mt1 Salmos 
\c 1  
\ms1 LIBRO I 
\mr (Salmos 1—41) 
\s1 Dekaskenum shiig aneasa pujamu 
\q1  
\v 1 Aents pegkegchau aidau 
\q1 chichainamun antujus umiju wekaechauk 
\q1 shiig aneas pujustinai. 
\q1 Tudau aidau takatan 
\q1 wakejus taka wekaechauk, 
\q1 tuja Apajuín pegkegchau chichajuidaujai ijunag, 
\q1 ditajai betek chichá wekaechauk 
\q1 shiig aneas pujustinai. 
\q1  
\v 2 Wagki niig nuna wekaetutsuk, 
\q1 Apajuí chichame umikta 
\q1 timauwa nuna umiak, 
\q1 kashish, tsawaish tuke nuwig 
\q1 anentaimas pujau asa. 
\q1  
\v 3 Nuadui nunú aentsuk makichik numi 
\q1 yuminum ijusa ajaamu, 
\q1 pegkeg, senchi nejen, 
\q1 dukesh kaketsama imanai. 
\q1 ¡Iman asa ashí nii takamuji aidauk 
\q1 shiig pegkeg ainawai! 
\b  
\q1  
\v 4 Untsu aents pegkegchau aina duka 
\q1 nunú aentsjaig betekchau ainawai, 
\q1 nuadui ditak ajusa wampujin dase umpui ajapama numamtin ainawai. 
\q1  
\v 5 Aents pegkegchau aidaunak 
\q1 Apajuí dita takasbaujin 
\q1 diijus suwimkan susatnai. 
\q1 Tuja aents pegkejan takau aidau 
\q1 Apajuí pujutain ijunjagtina 
\q1 nuwig ditak wayachagtinai. 
\q1  
\v 6 Tuke Pujuuk aents 
\q1 pegkeg aidaun kuitamui. 
\q1 Untsu aents pegkegchau aidauk 
\q1 dita pegkegchaujinig waittsagtinai. 
\c 2  
\s1 Ametme mina uchigmek 
\q1  
\v 1 ¿Wagka aents pegkegchau aidaush 
\q1 Tuke Pujuujai shiwagmagainakush 
\q1 ijunjash pampandayinawa? 
\q1 ¿Wagka chicham jegamainchaunash 
\q1 wainkash tuu yujawa? 
\q1  
\v 2 Nugkanmaya apu aidau 
\q1 yaakta apuji aidaujai ijunag 
\q1 Apajuín kajejuinak, nii etegka 
\q1 apu adaikauwa nunashkam 
\q1 shiwagmainak wakenmataik 
\q1 chichaman umijuinawai. 
\q1  
\v 3 Nuninak senchi untsumkag: 
\q1 “¡Achikbaujai betek batsatag 
\q1 duka ankanmagawagmi! 
\q1 ¡Tuja jigkaja emetuamujai betek 
\q1 batsatag dushakam 
\q1 agkanmagawagmi!” wajainawai. 
\b  
\q1  
\v 4 Imatiagtai Apajuík niina pujusa inamtaijin 
\q1 nayaimpinum pujus dushikiawai. 
\q1  
\v 5 Dutikak kajejuk uwakeawai, 
\q1 untsu nuni senchi kajejuk chichajak: 
\q1  
\v 6 “Wi etegkan apu emamugnak 
\q1 muja etegkamua nuwi Jerusalén 
\q1 pujus inamjati tusan 
\q1 wi apusajai”, tawai. 
\b  
\q1  
\v 7 Tuja Tuke Pujuu mina tujutma 
\q1 nuna etsegkatjai. 
\q1 Tuke Pujuu chichagtak: 
\q1 “Ametme mina uchigmek, 
\q1 amek wi akiinati tima akiinauwaitme. 
\q1  
\v 8 Ame wakegamu segatta, 
\q1 Wi nunak imatiksanuk ashí nugkanmaya 
\q1 aents aidaun amastatjame aminu atinun. 
\q1  
\v 9 Ichinak najanamu shigki basegbauwai 
\q1 awati tsaimaina numamtuk, 
\q1 apu pegkegchau aina duka 
\q1 ame tsaika utsagtatme”, tujutmae. 
\b  
\q1  
\v 10 ¡Apu nugkanum inamin aidauwah, 
\q1 shiig antuktajum, nunikjum 
\q1 juju chicham shiig unuimagtajum! 
\q1  
\v 11 Nuniakjum Apajuí 
\q1 eme anentsajum umigkujum 
\q1 shiig aneasjum ememattajum. 
\q1  
\v 12 Apajuí eme anentsajum ememattajum 
\q1 kajegtamkainum, nii kajegtamkamtaig 
\q1 jinumain ainagme, wagki nii kajeamujig 
\q1 makichkish imijtumaitsui. 
\q1 Aents Apajuíyai kajinas anentaimaidauk 
\q1 nii kuitamsam pujuidau asag, 
\q1 shiig aneas pujusagtinai. 
\c 8  
\s1 Apajuí imanjiya nunú aentsu pujutjijai 
\d David kantamamu 
\q1  
\v 1 Tuke Pujuuwah, ametme iina apuji, 
\q1 ashí tikich aidau nagkaesau muunmek. 
\q1 ¡Amina daagmek 
\q1 ashí nugkanum antunawai! 
\q1 ¡Amina imanjumek nayaim 
\q1 múunta nuna nagkaesauwai!\fig |alt="David playing harp in countryside" src="CO01012b.tif" size="col" loc="Psalm 8.1" ref="Sal. 8.1" \fig* 
\q1  
\v 2 Amina shiwaajum kajegtamainak 
\q1 mantamatag tinu aina duka, 
\q1 uchi tsakat aidau, 
\q1 uchi muntsu muntsuaku aidaujai 
\q1 shiig pegkegchin kantamaina duwi 
\q1 amina senchijum iwaintukam itatmikajume. 
\b  
\q1  
\v 3 Ame nayaim najanamua 
\q1 nuna diisan, tuja nantu, 
\q1 yaya aidaujai ame najankamu aidau 
\q1 nayaimpinum ayá nunashkam wainkun 
\q1  
\v 4 anentaimsan: 
\q1 ¡Aents aidautik pegkegmakesh ainatsji! 
\q1 ¡Tikima wainkauch ainaji! 
\q1 Nunin ajinish ¿wagka tujash 
\q1 puyatkagtusmesh kuitamkagtame? 
\q1  
\v 5 Aentsuk ángelchawashit tumain najanauwaitme. 
\q1 Nuadui apu kuitamaina 
\q1 imatiksam kuitamam duka dutikame. 
\q1  
\v 6 Tuja ashí ame najankamu aina duka 
\q1 ashí nii idaitusuitme, dutikakum 
\q1 tikich ame najankamu aina 
\q1 nuna nagkaesau emam apusauwaitme. 
\q1  
\v 7 Dutikam uwig aidau 
\q1 buey aidau, kuntin ikamia aidau, 
\q1  
\v 8 chigki yakí nanamin aidau, 
\q1 namak nayantsanmaya aidau, 
\q1 tuja tikich kuntin aidau 
\q1 nayantsanum ayá duka 
\q1 ashí nii idaitusuitme. 
\b  
\q1  
\v 9 Tuke Pujuuwah, ametme iina apujimek, 
\q1 ametme ashí tikich aidaun 
\q1 nagkaesau dekas muunmek. 
\q1 ¡Amina daagminak 
\q1 ashí nugkanum dekainawai! 
\c 14  
\s1 Aents pegkegchau aidaun pujutji 
\d David kantamamu 
\q1  
\v 1 Aents anentainkachu aidauk: 
\q1 “Apajuík atsawai”, tuinawai. 
\q1 Nuadui dita anentainig 
\q1 ima pegkegchau aina nunú takatak ajuinawai, 
\q1 nuadui dita takamuji aina duka shiig dakitmainai. 
\q1 Tiki makichkiuchikesh 
\q1 pegkejan takauk shiig atsawai. 
\q1  
\v 2 Apajuík aents aidaunak 
\q1 nayaimpinum pujusag 
\q1 diyawai, makichkikesh 
\q1 shiig anentaimkau Apajuí 
\q1 umigmain atsuash tusa wainkatatus. 
\q1  
\v 3 Tujash aents aidauk 
\q1 pegkegchau takatan yujajui, 
\q1 nunidau asag ashí betek tunamakaje. 
\q1 ¡Tiki makichkikesh pegkejan 
\q1 takauk shiig atsawai! 
\b  
\q1  
\v 4 Pegkegchaun takau aina 
\q1 duka anentaimainatsui. 
\q1 Pag yuwa wamak amutiama numamtuk 
\q1 mina aentsug aidaun amuinawai. 
\q1 Nunú aents aidauk 
\q1 Apajuí yainkati tusagkesh makichkish 
\q1 Tuke Pujuunak segachu ainawai. 
\q1  
\v 5 Nunú aents pegkegchaun takaina duka 
\q1 sapigmainak kujaidiagtatui. 
\q1 Tuja Apajuík aents ima niina chichamen 
\q1 umin aidaunum pujawai. 
\b  
\q1  
\v 6 Atum pegkegchau aidautijum 
\q1 aents ujudauch ememachu aina nunú 
\q1 atsaneakjum dushikiagme, 
\q1 tujash Tuke Pujuu ditanak kuitamui. 
\b  
\q1  
\v 7 ¡Israel aents aidaun uwemtijatin utusag 
\q1 Siógka mujajinia taawa! tusan wakegajai. 
\q1 Tuke Pujuu niina aentsji aina nuna 
\q1 pujutjin iwagtugmataig, 
\q1 Jacob Israel daagtina nuna 
\q1 uchiji aidauk ashí shiig aneasagtinai. 
\c 15  
\s1 Apajuí jee pegkegmanum aents aidau pujumain 
\d David kantamamu 
\q1  
\v 1 Tuke Pujuuwah, 
\q1 ¿aentsush wajuku aidauwa 
\q1 amina jem pegkegma 
\q1 nuwish pujumainaita? 
\q1 Tuja ¿wajuku aidauwa muja ame etegkamua 
\q1 nuwish pujumainaita? 
\q1  
\v 2 Nuwi pujusagtina duka 
\q1 aents pegkeg bakumamainji 
\q1 atsugbau, pegkejan takau, 
\q1 waitjutsuk dekaskea nuna chichau; 
\q1  
\v 3 tikichnash pegkegchaun chichagchau, 
\q1 niina kumpajinash pegkegchau awagmachu, 
\q1 tuja nii ijutkamu aidaunash inatsauchu; 
\q1  
\v 4 aents Apajuín dakitaujaig 
\q1 makichkish ijunchau, 
\q1 untsu Tuke Pujuun eme anentaunak 
\q1 niishkam eme anentus diin, 
\q1 tuja waitiakush 
\q1 nii anagkagtuamunak betek umin. 
\q1  
\v 5 Kuichkin tsagkatkagtukash 
\q1 ewaekam akigkata tusa waitkagkagtuchu, 
\q1 tuja aents takamsachu aig, 
\q1 tsanumjugta akiktagme tamash dakitin. 
\q1 Nunú aents imanis puja duka shiig aneas tajimat pujustinai. 
\c 16  
\s1 Apajuí mina sujusua nuna nagkaesau pegkejak atsawai 
\d David agagbau 
\q1  
\v 1 Chah, Tuke Pujuuwah, kuitamjukta, 
\q1 wika aminí ejamatnak egajai. 
\q1  
\v 2 Wi amina chichagkun: 
\q1 “Ametme mina apug 
\q1 pegkegnum yainnumek, 
\q1 tikich amea ibauk atsawai.” 
\q1  
\v 3 Ame chichagtakum: 
\q1 “Mina aentsug nugka batsata nunú 
\q1 minak umigtuidau asag 
\q1 shiig awajtuinawai. 
\q1  
\v 4 Untsu tikich aents aidau apajuíchun apajuímainak niina umijuina duka 
\q1 senchi waittsagtinai”, tame. 
\q1 Nuadui wika nunak 
\q1 tuké etsagjashtinaitjai. 
\q1 Tuja nunú apajuímtai aina 
\q1 nunak makichkish emematchattajai. 
\q1 Nuna daajinakesh makichkish adaikashtinaitjai. 
\q1  
\v 5 Tuke Pujuuwah, 
\q1 ametme mina ashí sujinmek. 
\q1 Ame sujame kuashat pegkeg aidau, 
\q1 mina pujutjua duka aminí awai. 
\q1  
\v 6 Nugka shiig pegkeg aidau 
\q1 makichkish wi anentaimtujakchamu ajutui, 
\q1 Apajuí anagtuamu wi jukitin ajuta duka 
\q1 dekas shiig pegkejai. 
\b  
\q1  
\v 7 Tuke Pujuunak shiig pegkegnum chichagtinaitjai, 
\q1 nii minak pegkegnum jintinjau asamtai. 
\q1 Dekas mina iyashjunash jintinjutui, 
\q1 dutijak kashishkam esetawai. 
\q1  
\v 8 Tuke Pujuu mina Apajuíjua duka 
\q1 tuke wijai ijutkau pujawai. 
\q1 Wika niini emetuman wajau asamtai, makichkish ajunjashtin ainawai. 
\q1  
\v 9 Wika shiig aneasan dakunkut pujajai, 
\q1 ima niyaig kajintsa anentaimsan pujuttajai. 
\q1  
\v 10 Apajuíjuh, amek minak 
\q1 jakati tusamek idaituschattame, 
\q1 tuja ¡pegkegmaitak ukumatainum ukusam 
\q1 kaugti tusamesh idaituschattame! 
\q1  
\v 11 Jinta pujutnum ekagtina nunú 
\q1 ame iwaintugkattame. 
\q1 Ame pujamugmia nuwig 
\q1 shiig dakujamu awai. 
\q1 Aminí awai dakujut tuke atina nunú. 
\c 19  
\s1 Apajuí imanjiya duka nii najankamu aina duwi dekanui 
\d David kantamamu 
\q1  
\v 1 Apajuí imanjiya nunak 
\q1 nayaimpia nunú ujajatui, 
\q1 nayaim wigkaya nunú wainku, 
\q1 dekas Apajuíyap najanauwaita taji. 
\q1  
\v 2 Tsawaiya nunú, kashia nujai, 
\q1 Apajuí imanjinak tuke etsejuinawai. 
\q1  
\v 3 Chichainachiatak, 
\q1 makichik chichamnakesh tuinachiatak, 
\q1 tuja chichamujigkesh antugchatayaitak, 
\q1  
\v 4 ashí nugka nagkatkamunum 
\q1 dita chichainamuk antugainawai. 
\q1 Tuja nayaimpinum etsa ekemsatnunak 
\q1 Apajuí umikui. 
\q1  
\v 5 Etsag nuwi eketu makichik aents 
\q1 yama nuwan nuwatuk 
\q1 nii kanutaijin pujau 
\q1 jiinama numamtuk kashikmas jiinui. 
\q1 Nunik jiinki aents 
\q1 tupikain uminas shiig aneas 
\q1 wemaina numamtuk weawai. 
\q1  
\v 6 Nunik nayaim tikich yantamnumia etsa jiinki, 
\q1 tentea wea weakua, 
\q1 yaja tikich yantamnum jegaa kintamui. 
\q1 Nuadui etsa etsantun uwemtumainuk makichkish atsawai. 
\b  
\q1  
\v 7 Tuke Pujuun chichamega duka 
\q1 yamajam pujutan sukagtau asa, shiig pegkejai. 
\q1 Tuke Pujuun chichamega duka 
\q1 waitchauwai, shiig dekaske, 
\q1 wagki nunú aents 
\q1 kakagchauchin unuidau asa. 
\q1  
\v 8 Tuke Pujuun chichame 
\q1 umiktina duka pegkejai, 
\q1 anentainum dakujutan sukagtau asa. 
\q1 Tuke Pujuun chichame umiktina duka 
\q1 dekas shiig pegkeg tsaaptinun anentaimtikagtinai. 
\q1  
\v 9 Tuke Pujuu puyatjusa 
\q1 umigbauwa duka shiig pegkejai, 
\q1 tuja nii chichamega dusha 
\q1 tuke megkaekashtinai. 
\q1 Tuke Pujuun chichame umiktina duka waitchauwai, 
\q1 dekaskenum ashí pegkejai. 
\q1  
\v 10 ¡Nunú chichamak oro tsuwatjinchau 
\q1 shiig pegkeg akika nuna nagkaesauwai, 
\q1 tuja dapa yumiji yumimitu pegkejama 
\q1 nuna nagkaesau shiig pegkejai! 
\q1  
\v 11 Wika amina inakmetag duwi pegkegchaun takasai tujutu asa, 
\q1 amina chichamjumea nunú jintinjawai. 
\q1 Nunú chichaman umiauk shiig pujustinai. 
\b  
\q1  
\v 12 Makichik aentsuk niina tudaujinak 
\q1 nigki anentaimsag dekagmamaitsui. 
\q1 Nuadui, Tuke Pujuuwah, 
\q1 ¡wi pegkegchaun takamsatjai tusan 
\q1 wakegachiatkun takamsamug aidaush tsagkugtugta! 
\q1  
\v 13 Tuja mina ememataijush emegkatjukta. 
\q1 Mina emematug wagagtuki, idaitusaipa. 
\q1 Aatsan wisha ibau tudau ajuta 
\q1 nuna agkanmagatjai. 
\b  
\q1  
\v 14 Tuke Pujuuwah, mina chichamjush 
\q1 mina anentaimtagjai, 
\q1 ame diismash pegkeg, wakemain ati. 
\q1 Chah, Tuke Pujuuwah, 
\q1 ametme mina ayamjutkam uwemtijinmek. 
\c 22  
\s1 Waitiamunum pujusa Apajuí emematku kantabau 
\d David kantamamu 
\q1  
\v 1 ¡Apajuíjuh, Apajuíjuh! 
\q1 ¿Wagka minash idaitusume? 
\q1 ¿Wagka taamesh uwemtijatsme? 
\q1 ¿Wagka wi imanikan amina segaakun 
\q1 buutaish pachittsume? 
\q1  
\v 2 Mina Apajuíjuh, tsawaish, 
\q1 kashish untsuajame, 
\q1 imatjamash aigtsume. 
\q1 ¡Wi ayabaujuk atsugtawai! 
\b  
\q1  
\v 3 Tujash ametme pegkegmamek, 
\q1 ametme apumek, iman asamin 
\q1 Israel wegantu aidau emematjamainawai. 
\q1  
\v 4 Iina apachji aajaku aina duka 
\q1 aminí kajinmamsag 
\q1 anentaimajaku ainawai; 
\q1 aminí kajinmamsag 
\q1 anentaimaidau asamtai, 
\q1 agkanmitkauwaitme. 
\q1  
\v 5 Yainkata tusa segapainakuish, 
\q1 ame agkanmitkauwaitme, 
\q1 tuja aminí kajitmamsag 
\q1 anentaimaidau asagmatai, 
\q1 tsanugmek idaisachuitme. 
\b  
\q1  
\v 6 Tuja wika aents tamak amaitsujai, 
\q1 wika bagajai betekaitjai. 
\q1 ¡Wika aents aidaun dushiktaiyaitjai! 
\q1  
\v 7 Mina waituidauk dushijuinawai, 
\q1 nuninak buuken pegainawai. 
\q1  
\v 8 Nuninak: “¡Tuke Pujuuwai 
\q1 kajinmamas anentaima pujuuwe 
\q1 nuadui, nii taa uwemtikjati! 
\q1 ¡Imatika aneau asa, nii uwemtijati!” tuinawai. 
\b  
\q1  
\v 9 Tuu yujatnume: 
\q1 Ame minak akiinati tujutiu asamin, 
\q1 mina dukuju waken 
\q1 egkemkan akiinawaitjai. 
\q1 Tuja ame minak mina dukuju kuntujin 
\q1 patattsam kuitamjukmayume. 
\q1  
\v 10 Duwik nagkamsam wi akiintsaig, 
\q1 ame minak kuitamjukuitme. 
\q1 Tuja mina dukuju wakeen pujubiag 
\q1 duwi nagkamsamek 
\q1 mina Apajuíg aayume. 
\q1  
\v 11 Ima minakek idaitusaipa, 
\q1 wika waittanum jegantan pujajai. 
\q1 Tuja mina yainmainuk atsugtawai. 
\b  
\q1  
\v 12 Mina shiwag aidauk, 
\q1 baságnumia toro kajen aina 
\q1 iman tententuawaje. 
\q1  
\v 13 Dutijuawag ikamyawa kajen 
\q1 shinuwama imatuinak 
\q1 esattatus tsekenjuinawai. 
\q1  
\v 14 Tuja wika yumi ukagag 
\q1 megkagama numamtinaitjai; 
\q1 mina ukunchig aidauk 
\q1 akaejaujai betek wajase. 
\q1 Tuja mina anentaijuk 
\q1 wiya yumimeaujai betek wajase. 
\q1  
\v 15 Mina wenujuk ichinak yama inajuamu 
\q1 bukuama nunin wajase. 
\q1 Mina idaijush kayakmataijui nujamjutkae. 
\q1 ¡Jakaujai betek minak 
\q1 nugka yukukuntunum aepjukiume! 
\q1  
\v 16 Aents pegkegchaun takau aidau 
\q1 yawajai betek tuwagtukaje; 
\q1 tuja mina dawegnak, 
\q1 mina uwejujai ichinjujaje. 
\q1  
\v 17 Mina ukunchig aidaunash 
\q1 pan wainmain dekapeajai; 
\q1 tuja mina shiwag aidauk 
\q1 ayatak diiju batsatui. 
\q1  
\v 18 Mina jáanchjun jujutkiag, yana daajig jiinkiti, 
\q1 nunú jukiti tusag, 
\q1 nunú dutika dekatain 
\q1 wasugkamainawai. 
\b  
\q1  
\v 19 Tujash Tuke Pujuuwah, 
\q1 ametme mina senchimtijinmek. 
\q1 ¡Tupanjutsuk, wamak taam yainkata! 
\q1  
\v 20 Puyajai ijutiag mantuawainum 
\q1 minash agkanmitkajuata. 
\q1 Yawajai betek aina nunú 
\q1 maatnume tusamek idaitusaipa. 
\q1  
\v 21 Leónjai betek kajen aina nunú mantuawainum ayamjutkata. 
\q1 ¡Toro kajen kachujin 
\q1 magkagtina iman aina nunú 
\q1 mantuawainum ayamjutkata! 
\b  
\q1  
\v 22 Ame ayamjutkamin, wi amina pachisan 
\q1 mina yatsug aidaun ujaktajai; 
\q1 dutikan ditajai ijunjan 
\q1 amina emematkun kantamatjai. 
\q1  
\v 23 ¡Atum Israel aents aidautijum, 
\q1 Tuke Pujuu eme anentin aidautigmek, 
\q1 Niina senchiji anentaimtusjum ememattajum! 
\q1  
\v 24 Apajuík ujudauch aidau waitiamun 
\q1 wainiatkug waittsatnume tusag 
\q1 pachitskek idaitsui. 
\q1 Tuja uumjutnakesh uumjuchui. 
\q1 Yainkata tusa segamak antujui, 
\q1 nunik betek yayawai. 
\q1  
\v 25 Apajuíjuh, 
\q1 ima aminak ememattagme, 
\q1 amina aentsjum eme anenjamin aidau 
\q1 kuashat tuwakbaunum nunak umiktatjai. 
\b  
\q1  
\v 26 Ujunauch aidautigmek 
\q1 yutai yuwajum shiig ejemagtajum. 
\q1 Tuja Apajuí wainkatasa 
\q1 egautigmek nii ememattajum, 
\q1 nuniakjum kuashat mijan pujustajum. 
\q1  
\v 27 Ashí aents tikich nugkanmaya 
\q1 ditash niimtin aidau, 
\q1 chichamnash tikich 
\q1 chichaman chichaaku aidauwah, 
\q1 Tuke Pujuu kajimatkigpajum. 
\q1 Niiyai jeganjum, 
\q1 ¡tikishmaja pujusjum ememattajum! 
\q1  
\v 28 Tuke Pujuuwai apua duka, 
\q1 iman asa ashí nugkanum inamui. 
\q1  
\v 29 Shiig atsumkas pujautigmesh, 
\q1 tuja ashí jaka pujautigmeshkam, 
\q1 ima Apajuíya duke tsuntsumjuajum etsagjatajum, 
\q1 wagki ima atumkek 
\q1 pujutak jukichu asajum. 
\b  
\q1  
\v 30 Wi wegantu aidauk 
\q1 Tuke Pujuun emematuinak, 
\q1 tuké niina pachisag etsejiagtin ainawai. 
\q1  
\v 31 Nuninak atakea duwi 
\q1 akiinawagtina nunashkam 
\q1 Apajuín takatji pegkeja nuna, 
\q1 kuashat wainchatai aidaun 
\q1 iwainajua nujai pachisag ujakagtinai. 
\c 23  
\s1 Apajuí minak  //  aents uwija kuitamnujai betek  //  kuitamjawai 
\d David kantamamu 
\q1  
\v 1 Aents uwigjin puyatjus 
\q1 kuitamna numamtuk 
\q1 mina kuitamjauk Tuke Pujuuwai, 
\q1 nuadui wi atsumamuk atsugtawai.\fig |alt="The good shepherd" src="LB00001b.tif" size="col" loc="Psalm 23" ref="Sal. 23" \fig* 
\q1  
\v 2 Aents niina uwigjin chijichi pegkejan 
\q1 ayu ayugkawa pimpiagtai, 
\q1 yajuak bikintunum ayamtikama numamtuk, 
\q1 Tuke Pujuu minak ayamtijawai. 
\q1 Tuja kitamamun uwagti tusashkam 
\q1 entsa pegkeg wiyakunum ejetawai. 
\q1  
\v 3 Niig tuke anenka ibau asa, 
\q1 wi pimpitaishkam ichichtawai, 
\q1 dutijua pujut pegkegnum etawai. 
\b  
\q1  
\v 4 Nugka ségaju ishamain 
\q1 suwenum nagkaemaknush, 
\q1 ame wijai wekagu asamin, ishamkashtatjai. 
\q1 Uwija kuitamin uwigjin ayamjuktatus 
\q1 ushujutaijin takus wekagama numamtuk, 
\q1 amek mina ayamjutkatasam wekaeme. 
\q1 Nuadui jamainnum jegaknush ishamkashtatjai. 
\b  
\q1  
\v 5 Mina shiwag kajegtin aidaun emtin, 
\q1 ame minak yutai pegkeg aidau umigtame. 
\q1 Aents ipaamujin shiig anentus juwak 
\q1 buuken kugkuinai nijau aina imatiksam 
\q1 minak shiig awajtukume. 
\q1 Umutai umikbau pinignum aun 
\q1 aents wainak shiig anegama numamtuk, 
\q1 minashkam shiig anemtijusume. 
\q1  
\v 6 Amina anenkagmia nunú, 
\q1 wait anenkagtutaigmijai 
\q1 ashí tsawantai tuke uyuuntawai. 
\q1 Tuke Pujuuwah, wika 
\q1 ame pujam nuwi tuke pujustinaitjai. 
\c 24  
\s1 Ashí najankamu aina nuna apuji 
\d David kantamamu 
\q1  
\v 1 Nugkak ashí Tuke Pujuunui, 
\q1 nunú nugkanum ashí ayá duka, 
\q1 nuwi batsamin aidaujai 
\q1 ashí niinu ainawai. 
\q1  
\v 2 Wagki nugka tujig asatnunak nii umikui, 
\q1 dutika nayantsanum, 
\q1 namak aidaunum aatus 
\q1 emetug idaisauwai. 
\b  
\q1  
\v 3 Tuke Pujuu mujaji etegkamua nuwish 
\q1 ¿yaki wakainta? 
\q1 Apajuí jee pegkegma imannummash 
\q1 ¿yaki wayash pujusainta? 
\q1  
\v 4 Nunak aents pegkegchaun takachu, 
\q1 anentai pegkeg, 
\q1 dakumka najanamun emematchau, 
\q1 umikchatnaitak tsanumak 
\q1 Apajuí daajin adayas 
\q1 dekas umiktatjai tuu wekaechau, 
\q1 nuwig wayawagtinai. 
\q1  
\v 5 Nunú aentsnak 
\q1 niina apuji Apajuíya nunú uwemtijatnai. 
\q1 Tuja niinak Tuke Pujuu 
\q1 pegkegnum yumigkig, 
\q1 ayamjuk shiig pujutan susatnai. 
\q1  
\v 6 Tuke Pujuu, Jacopa Apajuíjiyah, 
\q1 aents amina egapaidauk, 
\q1 dutika yayaam agtinai. 
\q1 Tuja amina segapaina nuna uchiji aidaushkam 
\q1 dutiksaik yayaam agtinai. 
\b  
\q1  
\v 7 ¡Jerusalégka waitijiya nunú ujaitajum! 
\q1 ¡Yaunchuk waitai aajakua 
\q1 nunú ujai idaisatajum! 
\q1 ¡Apu pegkejam niina imanjin nayaimpinum, 
\q1 nugkanmash inamna nunú wayattawai! 
\q1  
\v 8 Apu pegkejam niina imanjin nayaimpinum, 
\q1 nugkanmash inamna dusha ¿yaita? 
\q1 Duka dekas iina apuji 
\q1 Tuke Pujuu niina shiwaajinash ishamchau, 
\q1 wajiuwa nunuwai. 
\q1  
\v 9 ¡Jerusalégka waitijiya nunú ujaitajum! 
\q1 ¡Yaunchuk waitai aajakua 
\q1 duka ujai idaisatajum! 
\q1 ¡Apu pegkejam niina imanjin nayaimpinum, 
\q1 nugkanmash inamna nunú wayattawai! 
\q1  
\v 10 ¿Yaita nayaimpinum, 
\q1 nugkanum inamna dusha? 
\q1 ¡Duka Israel aents aidaun Apujiyai! 
\q1 ¡Duka Tuke Pujuu ashí senchigtina nunuwai! 
\q1 ¡Niiyai dekas apu pegkejam, 
\q1 niina imanjin nayaimpin, nugkan apujiya nunú! 
\c 27  
\s1 Apajuíyai mina tsaaptinjuk, mina uwemtaijuk 
\d David kantamamu 
\q1  
\v 1 Tuke Pujuuwai mina tsaaptinjuk, 
\q1 Tuke Pujuuwai mina uwemtaijuk, 
\q1 Tuke Pujuuwai mina pujutjun kuitamjutuk, 
\q1 nunin aish ¿yanak wisha ishamkainja? 
\q1  
\v 2 Aents pegkegchau 
\q1 mina shiwag aina nunú, 
\q1 ijunainawai mina mantuawagtatus, 
\q1 tujash ditak tukumak iyajag jinuinawai. 
\q1  
\v 3 Kuashat suntag mina tententuinakuish, 
\q1 wika ishamkashtatjai, 
\q1 tuja mina jetetkagtatus uminainakuish, 
\q1 wika puyattsuk pujuttajai. 
\b  
\q1  
\v 4 Ima makichkia nunak 
\q1 Tuke Pujuun segabiajai, 
\q1 tuja wika ima makichkia nunak wakegajai: 
\q1 Wika iwaku pujag duikik 
\q1 kashi kashinig Tuke Pujuun emematkun 
\q1 niina jee pegkegma nuwi 
\q1 pujustatajai, niina pegkegmajiya 
\q1 nuna wainkatasan. 
\q1  
\v 5 Tsawan utugchat ajuttaish, 
\q1 Apajuí niina jee pegkegma nuwi uugkattawai, 
\q1 Tuja kaya muunnum waka 
\q1 uwemaina numamtuk uwemtijugtatui. 
\q1  
\v 6 Nuadui mina shiwag aidau 
\q1 tententuinakuish, ishamkashtatjai 
\q1 Apajuí depetmikaju asamtai. 
\q1 Nuadui kuntinu maan 
\q1 Apajuí jee pegkegma nuwi 
\q1 apeakun niina ememattatjai; 
\q1 shiig aneasan senchi kantamkun 
\q1 Tuke Pujuun ememattatjai. 
\b  
\q1  
\v 7 ¡Tuke Pujuuwah, 
\q1 amina segajame, antugtukta! 
\q1 ¡Minash wait anenjujam, aigkata! 
\q1  
\v 8 Mina anentaig chichagtak: 
\q1 “Apajuí egakta”, tujutui. 
\q1 Nuadui amina wainkatasan egagme. 
\q1  
\v 9 ¡Wait aneasam uumjutkaipa! 
\q1 ¡Kajegtukam aigtsuk idaitusaipa! 
\q1 ¡Ima ameketme mina yainnumek! 
\q1 Nuadui mina ayamjutmain atsugtaigkik, 
\q1 ima minakek idaitusaipa, 
\q1 wagki ametme mina Apajuíg uwemtijin. 
\q1  
\v 10 Mina apag mina dukugjai 
\q1 ima minak idaituinakuish, 
\q1 Tuke Pujuuwah, 
\q1 ame minak jujukim kuitamjuktinaitme. 
\b  
\q1  
\v 11 Mina shiwag aidau egatuinawai, 
\q1 nuadui Tuke Pujuuwah, 
\q1 amina jintim pegkeja nunú iwaintugkata, 
\q1 tuja wisha wajuk pujumainaitja nunú tujutta. 
\q1  
\v 12 Mina shiwag aidau dita wakegamujin uminak, 
\q1 maatnume tusamek tsagkamjukaipa, 
\q1 mina shiwag tsanumin aidau nantagtujaje. 
\q1  
\v 13 Tujash wika eke jatsuk 
\q1 iwaku juju nugka juwig pujusan, 
\q1 amina pegkegmagmia nuna 
\q1 wainkatnunak shiig dekajai. 
\b  
\q1  
\v 14 ¡Tuke Pujuuwai 
\q1 kajinmamsam anentaimsata! 
\q1 ¡Ishamkagtutsuk, ichichmamjata! 
\q1 ¡Ehe, dekas ima Tuke Pujuuwaig 
\q1 kajinmamsam anentaimsata! 
\c 32  
\s1 Tudau etsegtumaka tsagkugnamu 
\d David kantamamu 
\q1  
\v 1 Tudauji ashí tsagkujamua duka 
\q1 shiig aneastinai. 
\q1  
\v 2 Aents pegkegchau takatan 
\q1 anentaimtus wekaetuchuk shiig aneastinai. 
\q1 Tuja tudauji ashí tsagkujamushkam shiig aneastinai. 
\q1  
\v 3 Wika mina tudaujun etsegtumachkunuk, 
\q1 wake besemag pujau asan ayatak jamaijai. 
\q1  
\v 4 Nuadui ame dekapjau asamin, 
\q1 tsawaish tuja kashish 
\q1 senchi waitmaijai. 
\q1 Yagkug etsa sukuam kagama 
\q1 numamtuk dekapmamkun, 
\q1 kakaumainchau dekapmaijai. 
\b  
\q1  
\v 5 Nuniakun mina pegkegchaugnak, 
\q1 makichkish uutsuk etsegtumaktajai 
\q1 tusan amina ashí ujakmaijame, 
\q1 nuadui ame mina tudaujuk 
\q1 ashí tsagkugtugmayume. 
\q1  
\v 6 Nuadui amina umigtamin aidauk, 
\q1 waituinakush amina segapainawai. 
\q1 Nuadui nujag dujajak 
\q1 nugka punag weakush, 
\q1 ditanak amaigkashtinai. 
\q1  
\v 7 Ametme mina ejamataigmek, 
\q1 ishamainnumash ame kuitamjame; 
\q1 nuadui ame agkanmitkajuamun anentaimtusan 
\q1 shiig aneakun, kantamjagme. 
\b  
\q1  
\v 8 Apajuí chichaak: 
\q1 “Wi aminak diyakjame, 
\q1 nuadui amina unuinagtasan jintintuattagme, 
\q1 tuja wiki jintan inaktusan kuitamkattagme. 
\q1  
\v 9 Nuadui caballo, burrojai anentaimchau 
\q1 asamtai, jagken jijui jinka emetua 
\q1 mai japia, mai japia, 
\q1 awajam wegama numamtinuk, amek aipa”, 
\q1 tujamui Apajuí. 
\b  
\q1  
\v 10 Aents pegkegchaun takau aina duka 
\q1 kuashat waituinawai. 
\q1 Untsu ima Tuke Pujuuwaig 
\q1 kajinas anentaimaina nunak, 
\q1 niina anenke múunta duwi 
\q1 tuke ijik kuitamui. 
\q1  
\v 11 Aents pegkeg, 
\q1 tuja takatjish pegkeg aidautigmek, 
\q1 Tuke Pujuuwai shiig dakujustajum, 
\q1 ¡Nuniakjum nii emematkujum shiig aneasjum senchi kantamjuatajum! 
\c 33  
\s1 Shiig aneasa Apajuí emematku kantamjamu 
\q1  
\v 1 Aents pegkeg aidauwah, shiig aneasjum 
\q1 Tuke Pujuu emematkujum kantamatajum. 
\q1 Aents pegkeg aidau kantabauk yajautsui. 
\q1  
\v 2 Arpa awatku kantamtai kantamkujum 
\q1 Tuke Pujuu see titajum. 
\q1  
\v 3 ¡Kantamtai pegkeg aina nunú 
\q1 kantamkujum nii ememattajum! 
\q1 Tuja yamajam kantamtai 
\q1 kantamkujum nii eme anentsajum 
\q1 shiig aneakjum untsumtajum. 
\q1  
\v 4 Tuke Pujuun chichamega duka 
\q1 waitchauwai, shiig dekaske, 
\q1 nuadui nii tibauwa duka ashí betek uminui. 
\q1  
\v 5 Tuke Pujuuk pegkeg takata nuna 
\q1 dekaskea nujai aneawai. 
\q1 ¡Nuadui niina anenkega duka 
\q1 ashí nugkan jamag awai! 
\q1  
\v 6 Tuke Pujuuk ima niina chichamenig 
\q1 nayaim aidaun, nantu, etsa, yaya aidaun 
\q1 aatus ashí najankauwai. 
\q1  
\v 7 Apajuíyai kucha múun aidaunmayan 
\q1 yumi yajuak makichkinmak ijumjauwa duka. 
\b  
\q1  
\v 8 ¡Aents ashí nugkanmaya aidautijum 
\q1 Tuke Pujuu eme anentsajum umigkatajum! 
\q1  
\v 9 Wagki nii niina chichamenig 
\q1 ashí najankauwai. 
\q1 Tuja nii nunikti timauwa duka imanisag 
\q1 makichkish wajukachmin wajas asauwai. 
\b  
\q1  
\v 10 Tuke Pujuuk aents pegkegchau 
\q1 tikich nugkanmaya aidau 
\q1 pegkegchaun dutikatag tusa 
\q1 anentaimtugbaujin betek umikti 
\q1 tusag ayatkek idaitsui. 
\q1  
\v 11 Untsu Tuke Pujuu nuna dutikatjai tibauwa duka 
\q1 makichkish yapajinchauwai. 
\q1  
\v 12 Aents aidau Tuke Pujuuwai dekas iina 
\q1 Apajuíjig tuina duka 
\q1 shiig aneasag pujusagtinai, 
\q1 wagki midau ati tusa etegkamu asag. 
\q1  
\v 13 Tuke Pujuuk nayaimpinum pujusag 
\q1 ashí aents aidaunak diyakui. 
\q1  
\v 14 Nii puja nuwi pujusag 
\q1 aents nugkanmaya aidaush 
\q1 wajukenawa nunak ashí wainui. 
\q1  
\v 15 Apajuíyai iina anentain najadauk, 
\q1 nuadui ashí ii takamunak diigtamkawai. 
\b  
\q1  
\v 16 Makichik apua duka 
\q1 niina suntaji aina nujaig 
\q1 ayamjumakag uwemaitsui, 
\q1 tuja aents aidaushkam 
\q1 niina senchijinigkik ayamjumamaitsui. 
\q1  
\v 17 Tuja caballo aina duka 
\q1 senchigtin ainayatkush, 
\q1 aentsu ayamjukag uwemtikmaitsui. 
\b  
\q1  
\v 18 Untsu Tuke Pujuun eme anentus, 
\q1 ima niyaig kajinmamas anentaimaina 
\q1 nunak nii tuké kuitamui. 
\q1  
\v 19 Tuja nujan tepeamtaish, 
\q1 nujantai jakati tusag idaitsui. 
\b  
\q1  
\v 20 Ii aidautik Tuke Pujuuwai kajinmamsa anentaimji, 
\q1 nuniajin ¡nii kuitamjamak yaimpaji! 
\q1  
\v 21 Iina anentain Apajuí anentaimtusa shiig aneaji. 
\q1 Nuniaku niina daaji pegkegma nuwi 
\q1 kajinmamsa anentaimji. 
\q1  
\v 22 ¡Tuke Pujuuwah, 
\q1 aminí anentaimsa pujau asajin, 
\q1 amina anenkagmia nunú uyunkagtusti! 
\c 34  
\s1 Apajuí wait anenkagtamu anentaimtusa kantabau 
\d David Abimelec maatag tama mantuawai tusa tsanumak imaanjaujai betek wajatai, jiiki awemam pujus agagbau 
\q1  
\v 1 Wika Tuke Pujuunak kashi kashinig 
\q1 pegkegnum chichagkun, 
\q1 tuke ememattinaitjai. 
\q1  
\v 2 Wika Tuke Pujuuwai eme anenmamjai; 
\q1 nunú antukjum ememachu aidautigmek, 
\q1 shiig aneastajum. 
\q1  
\v 3 Tuke Pujuu daaji múunta nunú 
\q1 ashí ijuntusaja emematiagmi. 
\b  
\q1  
\v 4 Wika Tuke Pujuun segabiajai yainkati tusan, 
\q1 dutika ai sapigmamujun agkanmitkajuabi. 
\q1  
\v 5 Tuke Pujuuwai anentaimas pujuidauk, 
\q1 shiig aneasag pujuinawai, 
\q1 nuadui datsan ipatmak achagtinai. 
\q1  
\v 6 Wika wainkauchitjai, 
\q1 nuniau asan Tuke Pujuun segabiajai. 
\q1 Tusa segai nii antugtuk, 
\q1 wi waitiamujun agkanmitkajuabi. 
\q1  
\v 7 Aents Apajuín eme anentus umijin aidaunak 
\q1 Tuke Pujuu aentsji ángel awemamua nunú 
\q1 kuitamui. 
\q1  
\v 8 Tuja Tuke Pujuush dekas pegkejashit tusajum 
\q1 dekaatasa wakegakjumek dekapsatajum: 
\q1 ¡Aents Apajuíyai kajinmamas anentaimaidauk, 
\q1 shiig aneas pujusagtinai! 
\q1  
\v 9 Tuke Pujuunu atajai tumamiu aidautigmek, 
\q1 nii eme anentsajum ememattajum; 
\q1 wagki niina umijuidauk makichkish atsumchagtinai. 
\q1  
\v 10 Wiakuch aina duka ujudauch wajasag 
\q1 nujantai waituinawai. 
\q1 Untsu aents Tuke Pujuun egau aina duka 
\q1 tuke waittsachagtinai. 
\b  
\q1  
\v 11 Mina uchig aidauwah, 
\q1 minai minitajum, nunikjum antugtuktajum, 
\q1 Tuke Pujuu umigtan wi jintituatjime. 
\q1  
\v 12 ¿Kuashat tsawan pujustasamesh wakegamek? 
\q1 Iwaku pujusam shiig takakum 
\q1 dakujustasamesh ¿wakegamek? 
\q1  
\v 13 Nuniakmek, 
\q1 pegkegchau chichamak chichatsuk pujusta, 
\q1 tuja wait aina duka makichkish chichakaipa. 
\q1  
\v 14 Pegkegchau takat aina duka idaisata, 
\q1 nunikam pegkeja duke takasta; 
\q1 nuniakum kakanmamsata maak agkan pujutnum. 
\b  
\q1  
\v 15 Tuke Pujuuk aents niina shiig umijin aina nuna kuitamui, 
\q1 dutikak nii sumamunash antujuk yayawai. 
\q1  
\v 16 Untsu tudaun takau aidaunak 
\q1 Tuke Pujuu kajejawai, 
\q1 dutikak ijina atakesh adeagchatnun 
\q1 emegkagtatui. 
\q1  
\v 17 Tuke Pujuuk niina umijin aidau 
\q1 sumamun betek antujui; 
\q1 dutikak nii waitiamujinash agkanmitkawai. 
\q1  
\v 18 Aents wika uwemjashtinapitja tusa 
\q1 anentaimak waitiaun uwemtijatatus 
\q1 Tuke Pujuuk tikijuch pujawai. 
\b  
\q1  
\v 19 Tuke Pujuun umigna duka 
\q1 kuashat utugchatan igkuawai, 
\q1 tujash niinak Apajuí depetmatnak suwawai. 
\q1  
\v 20 Tuja niina ukunchi aidaunashkam 
\q1 nii kuitamjawai; 
\q1 nuadui makichik ukunchinakesh kupigkachagtinai. 
\q1  
\v 21 Aents pegkegchau aina duka 
\q1 ditá tudau takamsamujin waituinawai, 
\q1 tuja Apajuí umijin aidaun kajejuina dushakam 
\q1 suwimkan jukiagtinai. 
\q1  
\v 22 Tujash Tuke Pujuuk niina inake aidaun uwemtikawai. 
\q1 Nuadui ¡Tuke Pujuuwai kajinmamas anentaimaidauk 
\q1 suwimak suwamak achagtinai! 
\c 37  
\s1 Apajuíyaig kajitmamsa anentaimat 
\d David kantamamu 
\q1  
\v 1 Aents pegkegchaun pujutji diigsam kajekaipa, 
\q1 tuja aents pegkegchau aidau 
\q1 atsumkas pujuinakui, nunú diisam kajegkagtukaipa. 
\q1  
\v 2 Wagki nunú aents aina duka 
\q1 dupa tsupikam wamak kagaja megkagama 
\q1 numamtin ainawai. 
\b  
\q1  
\v 3 Tuke Pujuuwaig kajinmamsam anentaimsata, 
\q1 nuniakum ima pegkeja duke takasta. 
\q1 Nuniamin Apajuí yaimpasmatai, 
\q1 juju nugkanum pujusa takakum 
\q1 shiig yuwa pujusminum. 
\q1  
\v 4 Tuke Pujuu shiig anentsam aneeta, 
\q1 nii umiktatui ame senchi wakegamunak. 
\q1  
\v 5 Amina pujutjumek Tuke Pujuu idaitusta, 
\q1 dutikakum niyai kajinmamsam pujusta, 
\q1 nuniamin nii yaimpaktatui. 
\q1  
\v 6 Ame shiig pujamugmea nunú, 
\q1 tuja amina takatjum pegkeja dushakam 
\q1 etsa tajimak shiig etsantama iman atinai. 
\b  
\q1  
\v 7 Tuke Pujuu emtin wainka chichá wekaetsuk 
\q1 takamtak pujusta; 
\q1 nuniakum dakasta nii yaimpakti. 
\q1 Tuja aents pegkegchau aidau 
\q1 shiig atsumkas pujuinakui, 
\q1 nunú diisam kajegkagtukaipa. 
\b  
\q1  
\v 8 Tuja kajeta duka idaisata, 
\q1 kajeka jiyanita dushakam ukukta, 
\q1 kajekaipa, wagki kajeamua duka utugchatan itawai. 
\q1  
\v 9 Aents pegkegchau aina duka ijina utsaam agtinai. 
\q1 Untsu aents aidau Apajuín umijuinak 
\q1 niinig anentaimas kajinas batsata nunú 
\q1 Tuke Pujuu nugkan anagkagtuawa nuna jukiagtinai. 
\b  
\q1  
\v 10 Aents pegkegchaun takau aidauk, 
\q1 dukap atsuk megkaejattawai; 
\q1 nunikagmatai wainkatasa egaakmesh 
\q1 makichkish wainkashtinaitme. 
\q1  
\v 11 Untsu aents ememachu aina nunú nugka pegkegnum wayawag, 
\q1 tutit chicham atsamunum shiig pujusagtinai. 
\q1  
\v 12 Untsu aents pegkegchauwa duka 
\q1 aents pegkejan kajejak 
\q1 pegkegchau awajkatatus egatui. 
\q1  
\v 13 Tujash Apajuík nunú aents aidaunak dushikiawai, 
\q1 wagki dita megkaejatnuk tsawan jegau asamtai. 
\q1  
\v 14 Aents pegkegchau aina duka 
\q1 ujudauch aidaun, ememachu aidaun, 
\q1 pujutji pegkeg aidaun aatus maawagtatus 
\q1 puyagjin akentaijijai uminawai. 
\q1  
\v 15 Tujash ditak, dita puyagjinig maam agtatui, 
\q1 untsu akentaiji aina duka 
\q1 kupija utsantam agtatui. 
\b  
\q1  
\v 16 Aents pegkegma duka 
\q1 wajiji kuashat achataish, 
\q1 aents wiakuch pegkegchaun 
\q1 nagkaesau shiig pujawai. 
\q1  
\v 17 Wagki Tuke Pujuuk 
\q1 aents pegkegchau aidaun ijinak, 
\q1 aents pegkeg aidaun kuitamkattawai. 
\b  
\q1  
\v 18 Apajuík aents tudaugtuchu aidaun kuitamui, 
\q1 tuja ditak ajumaish tuke atina nuna jukiagtinai. 
\q1  
\v 19 Tsawan waitiamu jegataish, 
\q1 ditak waittsachagtinai, 
\q1 tuja nujan tepeamtaish, 
\q1 dita yuwatnuk kuashat ajiagtinai. 
\b  
\q1  
\v 20 Aents pegkegchau aina duka 
\q1 dupa kagakujai betek keekagtinai. 
\q1 Tuja Apajuín shiwaaji aidaushkam 
\q1 jii bukuiti megkagama numamtuk 
\q1 megkaejatin ainawai. 
\q1  
\v 21 Aents pegkegchauwa duka 
\q1 tsagkatjukta takui tsagkatkamash akikmachui; 
\q1 untsu aents pegkeja duka 
\q1 tsagkatkamak nuni ewagas akikmawai. 
\q1  
\v 22 Apajuí pegkegnum yumigsamu aina nunú 
\q1 nugka pegkegnum pujusagtinai; 
\q1 untsu nii pegkegchaunum 
\q1 yumigjamu aina duka, ijina utsam agtinai. 
\b  
\q1  
\v 23 Tuke Pujuuk aentsu pujutjin diijus 
\q1 nii wakegamujai betek pegkeg ataik, 
\q1 shiig pujusti tusa yayawai. 
\q1  
\v 24 Tuja nunú aentsuk 
\q1 pegkegchaunum iyakush, 
\q1 nunisagkek megkaekashtinai, 
\q1 wagki nigka Tuke Pujuu achiakbau asa. 
\b  
\q1  
\v 25 Wi datsa asan pujuyag duwikish, 
\q1 tuja yamai múuntuch wajasan pujag duwish, 
\q1 makichkish waintsujai aents pegkeg aidau 
\q1 Apajuí kajimatki idaisamu asag waituidaunak, 
\q1 tuja dita uchiji aidaukesh 
\q1 yumain atsujam waituinak 
\q1 sumá yujaunak makichkish waintsujai. 
\q1  
\v 26 Aents pegkeg aina duka 
\q1 ashí tsawantai wait anenkagtinai, 
\q1 nuniau asa tsagkatkagtinai; 
\q1 tuja niina uchiji aidaushkam 
\q1 pegkegnum chichajam agtinai. 
\b  
\q1  
\v 27 Pegkegchau takata duka tupanjata, 
\q1 nunikam pegkeja duke takasta, 
\q1 nuniakum ame pujustinun Apajuí anagtabauwa 
\q1 nuwi tuke pujustinaitme. 
\q1  
\v 28 Wagki Tuke Pujuuk 
\q1 shiig takamua nuna wakegawai; 
\q1 nuadui niina umijuidaunak kajimatkig idaitsui; 
\q1 untsu pegkegchau aidaunak 
\q1 dita uchiji aidaujai ashí ijinui. 
\q1  
\v 29 Nugkan Apajuí anagkagtuawa nuwig 
\q1 aents niina umijin aidau tuke pujusagtinai. 
\b  
\q1  
\v 30 Aents pegkejak shiig anentaimas chichawai; 
\q1 nuniak tuke pegkeja nunak chichawai. 
\q1  
\v 31 Nuniau asa niina anentainishkam 
\q1 Apajuí jintintuamua nunak tuke aneakui; 
\q1 ¡nuadui niig makichkish pegkegchaunmak 
\q1 iyaumaitsui! 
\b  
\q1  
\v 32 Aents pegkegchauwa duka 
\q1 aents pegkejan tsanumjug, 
\q1 maatnume tusa sujuktatus wekaetawai. 
\q1  
\v 33 Tujash Tuke Pujuuk aents pegkegchauwa nunú 
\q1 maati tusag idaisashtatui; 
\q1 tuja nuigtushkam tsanumjujagmatai, 
\q1 achikag waitkastinme tusagkesh idaisashtatui. 
\b  
\q1  
\v 34 Tuja amek Tuke Pujuuwai kajinmamsam pujusta, 
\q1 nuniakum niina chichame umigkata; 
\q1 wagki nii aminak tikich aidaun nagkaesau etamtatui, 
\q1 dutijama nugkan anagtabauwa nuna amastinai. 
\q1 ¡Nuwi pujusam aents pegkegchau aidau 
\q1 jinuidau wainkatnaitme! 
\b  
\q1  
\v 35 Aents pegkegchauwa nunú 
\q1 numi múun wajaama numamtuk 
\q1 ememas wajaun wainkabiajai. 
\q1  
\v 36 Tujash wajukayawas, megkaekabi, 
\q1 wainkatasan egaknush wainkachmaijai. 
\b  
\q1  
\v 37 Aents shiig anentaimkauwa nunú diista, 
\q1 nunú aentsuk tutit chicham atsaunum agkan pujustinai. 
\b  
\q1  
\v 38 Untsu aents antumtikmainchau 
\q1 intimkiu aina duka 
\q1 ashí ijina utsaam agtinai; 
\q1 nuadui ditak jinatnujin dakainawai. 
\b  
\q1  
\v 39 Tuke Pujuuk aents pegkeg aidaun 
\q1 yaigka uwemtiknai, 
\q1 tuja tsawan waitiamu jegataish, 
\q1 nii ejaka kuitamui. 
\q1  
\v 40 Tuja ditanak Tuke Pujuu ayamjuk agkanmitkawai, 
\q1 wagki niyai kajinmamas 
\q1 anentaimaidau asagmatai. 
\c 40  
\s1 Apajuíjuh, ame wakegamun umiktasan wakegajai 
\r (Sal. 70) 
\d David kantamamu 
\q1  
\v 1 Wika Tuke Pujuu yainkati tusan 
\q1 niiyai kajitmamsa pujusan segabiajai; 
\q1 tusa segai nii antugtukmayi. 
\q1  
\v 2 Tuja wi jamainnum jeganta pujaish, 
\q1 nii uwemtijugmayi. 
\q1 Tuja kuchanum tepea 
\q1 jamaina numamtuk ashí jaka pujai, 
\q1 Apajuí uwemtijugmayi. 
\q1 Dutijua kaya múun 
\q1 makichkish buchitmainchaunum wajasa iyaumaitsu iman etibi. 
\q1 Nuadui wi wekaesatnunak nii umigtuke. 
\q1  
\v 3 Dutijak yamajam kantamtain 
\q1 Apajuí kantamjutain kantamati tusa jintinjuabi; 
\q1 nuna wi kantabau kuashat aents aidau 
\q1 anentain antinkabi, 
\q1 dutikam Tuke Pujuuwaig kajinas anentaibiagmayi. 
\q1  
\v 4 ¡Aents ememachu 
\q1 tuja wainka apajuímtai aidaunash emematchau, 
\q1 ima Tuke Pujuuwaig kajinmamas anentaimaina duka 
\q1 shiig aneas pujustinai! 
\b  
\q1  
\v 5 Tuke Pujuu mina Apajuíjuh, 
\q1 amek jutii wait anenkagtakum, 
\q1 kuashat ishamain wainchatai aidau iwainajuitme. 
\q1 ¡Makichkish amejai betekak atsawai! 
\q1 Nuna pachisan etsegkatag takunush, 
\q1 ashí etsegmainchau dekapeajai. 
\q1  
\v 6 Apajuí tsagkugtugti tusag 
\q1 kuntinu maawag nuna nejen ashí apeatnume, 
\q1 dutikainak ajak aidaunashkam anentag sujustinme tusamek sumatsme. 
\q1 Untsu Apajuín chichamen antukti tujutiume. 
\q1  
\v 7 Nuadui, papiinum agagbau 
\q1 mina pachitus tawa nujai betek, 
\q1 chichaakun: Juwi pujajai, timajai. 
\q1  
\v 8 Apajuíjuh, ame wakegamu takata nunú minak shiig awajtawai. 
\q1 ¡Ame jintinjuamua nunú mina anentaijui ajutui! 
\b  
\q1  
\v 9 Amina aentsjum aidau 
\q1 kuashat tuwaka ijunbaunum 
\q1 amina takatjum pegkegma nuna iwainakmajai. 
\q1 ¡Tuke Pujuuwah, wi aminun pachisa etsegtsuk 
\q1 uuka pujatsug duka amek shiig dekame! 
\q1  
\v 10 Tuja aents aidau wait anentakum, 
\q1 dita tudaujish tsagkugnaitam nunú pachisa 
\q1 etsegtanmak itattsachmajai. 
\q1 Tuja ame anagkagtuamuk betek uminaitam nuna 
\q1 ame uwemtikagtamujai pachisan chichagkagtukmajai. 
\q1 Nuigtush amina aentsjum kuashat aina 
\q1 nuna emtinig amina anenkagminak 
\q1 dekaskegmijaig, makichkish uukchamjai. 
\b  
\q1  
\v 11 Nuadui Tuke Pujuuwah, amesh minash wait aneasam 
\q1 amina anenkagmea duka atushat etugtipa. 
\q1 ¡Amina anenkagmin 
\q1 pegkegmagmea nujai yainkata! 
\q1  
\v 12 Untsu ame kuitamjachkuminig wika jamainaitjai, 
\q1 wagki wi waitiamua duka 
\q1 dekapakuish makichkish ejemaitsui. 
\q1 Mina tudaujuk mina intashjun nagkaesau 
\q1 shiig kuashat ajutui. 
\q1 Iman asamtai, datsaamakun shiig niimsachmin, 
\q1 nuigtush shiig pujuschamin jakamin dekapeajai. 
\b  
\q1  
\v 13 Tuke Pujuuwah, ¡wait aneasam, 
\q1 minash agkanmitkajuata, 
\q1 dutijakum wamak yainkata! 
\q1  
\v 14 Aents aidau mina mantuawagtatus 
\q1 wakejutuina duka ame inatsakta; 
\q1 dutikamu asag, 
\q1 mina pegkegchau awajtuktatus 
\q1 anentaimaina duka 
\q1 datsantin pisagtinme. 
\q1  
\v 15 Tuja mina dushijuina duka 
\q1 datsagkag pisagtinme. 
\b  
\q1  
\v 16 Untsu amina egapaina duka shiig aneastinme; 
\q1 tuja ame uwemtikagtinaitam  //  nuna wakejuina duka: 
\q1 “¡Apajuíyai dekas múunta duka!” tusag 
\q1 tuke emematjamtin atinme. 
\q1  
\v 17 Tuja wi shiig senchi waitiakun 
\q1 wake besemag pujag nunú, 
\q1 minash wait aneasam Tuke Pujuuwah, kajimatjukipa. 
\q1 Ametme mina yainkam uwemtijinmek; 
\q1 nuadui Apajuíjuh, minash wamak yainkata. 
\c 42  
\ms1 LIBRO II 
\mr (Salmos 42—72) 
\s1 Wi jinta niimjamua duka Apajuíyai 
\d Coré uchiji aidau kantamawagbau 
\q1  
\v 1 Japa senchi kitamak uwagtatus yumin egama numamtuk 
\q1 wika Apajuíjuh, amina egajame. 
\q1  
\v 2 Apajuí pujuta sukagtina nuna wainkatasan, 
\q1 aents kitakai waitiak yumin egamaina 
\q1 numamtuk egajai. 
\q1 ¿Wajutik wisha ataktush 
\q1 Apajuí jee pegkegma nuwish wayatja? tusan 
\q1 anentaima pujajai. 
\q1  
\v 3 Nuadui tsawaish, 
\q1 tuja kashish buutú pujajai, 
\q1 nuniai aents aidau inintuinak: 
\q1 “¿Amina Apajuígmesha?” tujutuinawai. 
\b  
\q1  
\v 4 Nuwi anentaimkunuk 
\q1 wake besemag dekapeajai. 
\q1 Wi yaunchuk aents aidaun yajuakan 
\q1 Apajuí jee pegkegma nuwi emai, 
\q1 shiig aneasag Apajuín emematuinak 
\q1 untsumki shimuyanum nuna anentaimjai. 
\q1 ¡Yajauwajah ijunja Apajuí emematbau! 
\b  
\q1  
\v 5 Iman aish ¿wagkanuk wisha mijaktaja? 
\q1 Wi puyatjumainuk atsawai. 
\q1 Apajuí uwemtikagtina nuwig 
\q1 kajintsan anentaimtatjai, 
\q1 nuniakun ima niinak ememattatjai. 
\b  
\q1  
\v 6 Shiig aneasa pujuschamin 
\q1 wake besemag dekapeajai, 
\q1 nuniakun muja Hermón 
\q1 tuja muja Misar tutainum 
\q1 namak Jordágka nujinchi jinagbaunum 
\q1 pujusan aminí senchi anentaimjai. 
\q1  
\v 7 Tuja ame najankamu aidau 
\q1 mujanum wajasa antam, 
\q1 namaka nujinchi chichijam 
\q1 tuna detau aidau senchi uutak, 
\q1 ishamain wajama imanik 
\q1 wi waitiamua duka minitjawai. 
\q1  
\v 8 Tujash kashi kashinig 
\q1 Tuke Pujuu niina anenkega duwi minak yaintui; 
\q1 nuadui wishakam 
\q1 Apajuí mina pujutan suja nuna emematkun 
\q1 kashi kantamtanak mijattsujai, 
\q1 nuniakun segatnashkam segatskek idaitsujai. 
\q1  
\v 9 Apajuí mina ayamjutna nuna chichagkun: 
\q1 “¿Wagka minash kajimatjukiume? 
\q1 ¿Wagkanuk wisha mina shiwag aintuinakuish, 
\q1 wake besemjash wekaetaja?” tajai. 
\q1  
\v 10 Mina shiwag aidau dushiktuinak: 
\q1 “¿Amina Apajuígmesha?” 
\q1 tusa aju ajumag inintuinawai. 
\q1 Imatjutiagtai mina ukunchig najautuinawai. 
\b  
\q1  
\v 11 Tuja ¿wagkanuk wisha mijaktaja? 
\q1 Wi puyatjumainuk atsawai. 
\q1 Apajuí uwemtikagtina nuwig 
\q1 kajintsan anentaimtatjai, 
\q1 nuniakun ima niinak ememattatjai. 
\q1 ¡Niyai mina Apajuíg uwemtijinuk! 
\c 43  
\q1  
\v 1 Apajuíyah, wi pegkegchau takamsamu 
\q1 atsugta duka ame dekame, 
\q1 nuniau asam ¡aents pegkegchau aina nunú 
\q1 maawai tusam ayamjutkata! 
\q1 ¡Aents pegkegchau waitjin aidaunum agkanmitkajuata, 
\q1  
\v 2 wagki ametme mina Apajuíg kuitamjinmek! 
\q1 ¿Wagka minash idaitusume? 
\q1 ¿Wagkanuk wisha mina shiwag aintuinakuish 
\q1 wake besemjash wekaetaja? tajai. 
\q1  
\v 3 Amina tsaaptinjum 
\q1 dekaskegmijai sujusta, nunú jintinjuati. 
\q1 Muja ame etegkamunum pujam nuwi 
\q1 wakatag tusaish wajuk wemainaita nuna. 
\q1  
\v 4 Nuwi wakan amina altarjumin jegantan, 
\q1 arpa awatkun amina ememattajame; 
\q1 wagki shiig aneasa pujuta nunú ame sujau asamin. 
\b  
\q1  
\v 5 Tuja ¿wagkanuk wisha mijaktaja? 
\q1 Wi puyatjumainuk atsawai. 
\q1 Apajuí uwemtikagtina nuwig kajintsan anentaimtatjai, 
\q1 nuniakun ima niinak ememattatjai. 
\q1 ¡Niyai mina Apajuíg uwemtijinuk! 
\c 46  
\s1 Apajuík jutijai pujawai 
\d Coré uchiji aidau agajagbau  //  Juka jaka ukumamunum kantamajakbauwai 
\q1  
\v 1 Apajuíyai iina kuitamjamin, 
\q1 iina senchimtijamin, 
\q1 tuja utugchat ataish tuke yaijatin. 
\q1  
\v 2 Nuadui nugka buchittai, 
\q1 muja aidau yumpunainak, 
\q1 nayantsanum kakegu 
\q1 wainkuish ishamaitsuji. 
\q1  
\v 3 Nayants senchi tsukatbau, 
\q1 kedegtak muja aidaun senchi umuchiak 
\q1 ishamain wajakuish ishamaitsuji. 
\b  
\q1  
\v 4 Namakak nii tsegkeakbaujijai 
\q1 Apajuí yaaktajin aents batsatun shiig anemtikui, 
\q1 nunú yaaktak dekas tikich yaakat aidaun nagkaesau 
\q1 shiig pegkegmai, Apajuí pujutai asa. 
\q1  
\v 5 Apajuík nunú yaakta ejapeen pujawai, 
\q1 nuadui makichkish tsaimainchau ainawai. 
\q1 Tuja Apajuí aentsji aidau, 
\q1 nunú yaaktanum batsatunak kashikiuch nagkamas yayawai. 
\q1  
\v 6 Aents nugka muunnumia aidauk, 
\q1 nugka múun aidaun apuji aidaujai 
\q1 Apajuí chichamun antukag 
\q1 ishamainak senchi pampainawai. 
\q1 Tuja nugkashkam Apajuí chichatai, 
\q1 yumpuna tsainak megkaewai. 
\b  
\q1  
\v 7 ¡Tuke Pujuu ashí senchigtina duka jutijai pujawai! 
\q1 ¡Jacopan Apajuíjiya nunuwai iina kuitamjamin! 
\b  
\q1  
\v 8 Tuke Pujuu ishamain wainchatai aidaun 
\q1 juju nugkanum iwainajua nunú 
\q1 taajum diistajum. 
\q1  
\v 9 Maanitak ashí nugkanum atsuti tusa tine. 
\q1 Nuadui maaniaku flecha akentai aidaunak 
\q1 nagki aidaujai kupigmayi, 
\q1 dutikak carro maaniaku jutai aidaunashkam 
\q1 apeka utsagmayi. 
\q1  
\v 10 ¡Anuig nagkankatajum! 
\q1 ¡Witjai Apajuínuk, nunú dekatajum! 
\q1 Ashí nugkanmaya aidauk mina umigtukagtatui. 
\b  
\q1  
\v 11 ¡Tuke Pujuu ashí senchigtina duka jutijai pujawai! 
\q1 ¡Jacopa Apajuíjiya nunuwai iina kuitamjamnuk! 
\c 47  
\s1 Apajuíyai ashí nugka apujig 
\d Coré uchiji aidau kantamawagbau 
\q1  
\v 1 Ashí aents aidautijum Apajuí uwejum awatitajum. 
\q1 Tuja nii emematkujum 
\q1 shiig aneasjum senchi kantamatajum. 
\q1  
\v 2 Wagki Tuke Pujuuwai ishamtai múun, ashí nugka apujiya duka. 
\q1  
\v 3 Aents tikich nugkanmaya aidaun Apajuí depetuk, 
\q1 atum inagtajum tusa iina idaitugmasui. 
\q1  
\v 4 Apajuí Jacopan aneau asa, 
\q1 nii wegantu aidautin etegtamjauwai, 
\q1 dutijama nugka pegkejan 
\q1 nii anagtabauwa nuna sujamsajui. 
\q1 Nunú nugka duwi ii eme anenmamji. 
\b  
\q1  
\v 5 Tuke Pujuu Apajuík niina aentsji aidau 
\q1 shiig aneasag senchi kantamainak, 
\q1 nuigtu uwija kachujin umpuinak 
\q1 pampainamunum niina pujusa inamtaijin 
\q1 waya ekemsae. 
\q1  
\v 6 ¡Kantamtai Apajuí kantamjuatajum! 
\q1 ¡Kantamtai iina apuji kantamjuawagmi! 
\q1  
\v 7 Apajuíyai ashí nugkanmaya aidaun apuji, 
\q1 nuadui shiig aneasjum kantamjuatajum. 
\q1  
\v 8 Apajuík nii pujusa inamtaiji 
\q1 pegkegma nuwi pujusag, 
\q1 ashí aents nugkanmaya aidaun inawai. 
\q1  
\v 9 Tuja ashí tikich nugkanmaya 
\q1 apu eme anentsa diitai aidauk, 
\q1 Abrahama Apajuíjin ememattatus 
\q1 nii wegantu aidaujai ijunainawai. 
\q1  
\v 10 Ashí aents nugkanmaya aina duka Apajuínu ainawai. 
\q1 Nuadui nii ashí inawai. 
\c 51  
\s1 Apawa wait aneasam mina tudaujush tsagkugtugta 
\d David Betsabén nuwatkamtai\f + \fr 51:0 \ft Nunú pachisa ausata 2 Sam 12.1-12.\f* profeta Natán jiyakam pujusa juna aatus agajui 
\q1  
\v 1 Apajuíyah, amina anenkagmin wait anenjugta; 
\q1 tuja amina wait anenkagtutaigmin 
\q1 mina tudaujush tsagkugtugta. 
\q1  
\v 2 ¡Mina anentaijui pegkegchau ayá nunú nijatjugta! 
\q1 Tuja mina tudaujush jaipja utsanjukta. 
\q1  
\v 3 Mina pegkegchaugnak wika shiig dekagmamjai. 
\q1 Tuja wi pegkegchau takamsamua duka 
\q1 mina anentaijuig sakamtsui. 
\q1  
\v 4 Ame dakitamun amina emtimin 
\q1 pegkegchaun takamsan 
\q1 ikajeakun waitkagme. 
\q1 Nuadui minak dekaskenum 
\q1 suwimkak sujustatme. 
\q1 Wika pegkegmaitjai tusanuk tumaitsujai. 
\b  
\q1  
\v 5 Wika dekas wi akiinawaitag 
\q1 duwi nagkamsanuk tudauwaitjai; 
\q1 tuja mina dukuju muntsujin muntsuaku asanuk tudau ayajai. 
\q1  
\v 6 Amek dekas aents ememachu 
\q1 dekaskenum chichauwa nunú aneame; 
\q1 nuadui shiig anentaimja pujut sujusume. 
\q1  
\v 7 Wi pegkegchau takamsamu 
\q1 mina anentaijui ajuta nunú hisopowai\f + \fr 51:7 \ft “Hisopo” tawa duka makichik ajak ajakui. Nuna duke juki jaipmaina numamtuk jaipjugti tusa David tiuwai.\f* jaipja ajapjutuata, 
\q1 dutijuawamin pegkeg wajastajai; 
\q1 ashí minak nijatjata, dutijuawamin 
\q1 yujagkim pujuama nuna nagkaesau wajastajai. 
\q1  
\v 8 Suwimak sujakum waitkagsau akumesh, 
\q1 yamaik minash shiig aneasa pujut sujusta. 
\q1  
\v 9 Mina tudaug aina duka kajimatkita, 
\q1 nuniakum mina pegkegchaug aina nunú 
\q1 ashí esaktujata. 
\b  
\q1  
\v 10 Apajuíyah, mina anentaijush tudaugtuchu yamajam etugtita, 
\q1 dutikakum pegkeg anentaimat 
\q1 ima aminak umigtamain sujusta. 
\q1  
\v 11 Tikima ajapjutak ajapjuawaipa, 
\q1 tuja amina Wakanim Pegkegma dusha jujutkipa. 
\q1  
\v 12 Tuja ame uwemtikagtujamin shiig aneamu 
\q1 ajutkagtuwama nunú ataktu sujusta, 
\q1 nuniakum amina Wakanim wait anenkagtina nujai 
\q1 kuitamjukta. 
\q1  
\v 13 Dutijuawamin aents amina chichamjumin umitan 
\q1 dakitin aina nuna jintintuatjai, 
\q1 amina nemagtamkatnume tusan. 
\q1 Dutika ai aents tudau aidaush dita tudaujin idaisag 
\q1 ima aminak umigtamkatnume. 
\q1  
\v 14 Apajuíyah, ametme mina uwemtijinmek, 
\q1 tuja wi pegkegchaun takamsauwaitag duwi 
\q1 maatnume tusamek idaitusaipa. 
\q1 Wisha ame wait anenkagtutaigmea nuna 
\q1 pachisan etsegkun shiig aneasan 
\q1 kantamtain senchi kantamjuatjame. 
\b  
\q1  
\v 15 Apuh, minash kantamati tujutta, 
\q1 wisha kantamtain amina kantamjuatjame. 
\q1  
\v 16 Tuja uwija maan nuna nejen ashí apeakun, 
\q1 nuigtu anentag aidaun amaakun 
\q1 amina ememattag takunush 
\q1 dutikmainchau dekapeajai, 
\q1 wagki duka aminak shiig awajtamchau asamtai. 
\q1  
\v 17 Apajuíyah, amek aents wika tudauwapitja tusa 
\q1 anentaimak waitia nunú shiig anentame. 
\q1 Tuja aents wika tudauwapitja tusa 
\q1 awake anentaimag tsagkugtugta tusa 
\q1 segapakuig, yaitskek idaichauwaitme. 
\b  
\q1  
\v 18 Apuh, wait aneasam 
\q1 Isarael aents aina nunú 
\q1 wait anenjam kuitamkata. 
\q1 Dutikakum Jerusalén peejamu tsaikbauwa nuna 
\q1 ataktu peejatnume tusam yaigta. 
\q1  
\v 19 Dutikawamin kuntinu maawag 
\q1 nuna nejen ashí apeawagtata 
\q1 nunú shiig awajtamkattawai. 
\q1 Nuadui amina emematjamainak 
\q1 toro tsakat aidaun maawag apeawagtinai. 
\c 63  
\s1 Apajuí anenkeg  //  pujutan nagkaesauwai 
\d David Judá wegantu aidau nugken uwegshunum pujusa agagbau 
\q1  
\v 1 Apajuíjuh, 
\q1 ametme mina Apajuígmek, 
\q1 Yama tsawamuik kashikmasan 
\q1 wakejusan segajame, 
\q1 wika amina wainkatasan wakegakun 
\q1 kitamaku wajuktayama imaniajai. 
\q1 Tuja yumi yutushtai nugka buku wajas, 
\q1 yumin atsumak wajukchawash imaniawai, 
\q1 mina iyashjuk amina atsumjamak. 
\q1  
\v 2 Amina jem pegkegma nuwi wayan, 
\q1 amina imanjumea nuna 
\q1 senchigmijai wainkatasan wakegajai, 
\q1  
\v 3 wagki amina anenkagmea duka 
\q1 pujutan nagkaesauwai, 
\q1 nuadui kantamkun ememattatjame. 
\q1  
\v 4 Wika aminak tuke ememattinaitjame, 
\q1 nuniakun mina uwejun takuin 
\q1 amina aujtatjame. 
\q1  
\v 5 Aents yutai pegkejan yuwa 
\q1 shiig aneas pujuuwa numamtuk wika shiig aneasan pujuttajai, 
\q1 nuadui shiig aneasan 
\q1 kantamkun ememattatjame. 
\b  
\q1  
\v 6 Kashi kanaku tepesnush 
\q1 aminí anentaimsanuk tepajai. 
\q1  
\v 7 Ametme mina yaintumek; 
\q1 nuadui aminí yunumsan 
\q1 ame kuitamjusamin shiig aneasan pujujai. 
\q1  
\v 8 Ashí mina pujutjua nunak 
\q1 amina amaajai, wagki ame minak 
\q1 amina senchigmin kuitamjame. 
\q1  
\v 9 Mina mantuawagtatus 
\q1 wakejutuina duka ijinata, 
\q1 dutikam initak yutuam emegkagta. 
\q1  
\v 10 ¡Ditak nagkí iju maam agtinai, 
\q1 dutikamun ikamia yawá yukagtin aidau 
\q1 ditá iyashinak yuwawagtinai! 
\q1  
\v 11 ¡Untsu apuk, Apajuíyai shiig aneastinai! 
\q1 ¡Tuja ashí aents Apajuín daajin chichau aidaushkam 
\q1 shiig anentsag kantamjuawagtinai! 
\q1 Untsu waitjin aina nuna weninak 
\q1 Apajuí ashí epetjatnai. 
\c 65  
\s1 Ima Apajuíke ememattaig 
\d David kantamamu 
\q1  
\v 1 Apajuíyah, muja Siógnum pujuuwah, 
\q1 ¡ametme eme anentsa 
\q1 kantamjam amainmek! 
\q1 Amina takagsatjame tusa anagtabau aidauk 
\q1 betek umigtamain ainawai. 
\q1  
\v 2 Amek ii segamash antugkagtame; 
\q1 tuja ashí nugkanmaya aidauk aminí mininawai. 
\q1  
\v 3 Iina tudauji aidau wagagkagtakuish, 
\q1 ame tsagkugkagtame. 
\q1  
\v 4 Ame aents aidau etegjam, 
\q1 ame jem pegkegma nuwi amejai pujustinme 
\q1 tiuwaitam duka shiig aneasagtinai. 
\q1 ¡Tuja ame jem pegkegma nuwi pujusa 
\q1 amina pegkegmagmea nunú wainkau asaja shiig aneastatji! 
\b  
\q1  
\v 5 Apajuíyah, ametme jutiin uwemtikagtinmek, 
\q1 nuadui aents pegkegchau aidau suwimak suwakum 
\q1 amina umigtamaidauk shiig anennaitme. 
\q1 Nuadui ashí nugkanum pujuidauk 
\q1 tuja nayantsa amain atushat batsamin aidaushkam 
\q1 ima aminig kajinmamas anentaimainawai. 
\q1  
\v 6 Muja aidauk amina senchigmijai najanauwaitme, 
\q1 dutikam buchittsuk asatnume tusam kuitame. 
\q1  
\v 7 Amek nayants tsukatbaujish imignaitme, 
\q1 tuja aents aidau pampaidaush, 
\q1 bitat asatajum tusam itatmitkauwaitme. 
\q1  
\v 8 Tuja atushat batsamin aidaushkam ame amina senchigmin 
\q1 wainchatai aidau iwainamun wainkag kujainawai. 
\q1 Tuja ashí nugkanum batsamin aidaush 
\q1 aminí shiig aneenak untsumainawai. 
\q1  
\v 9 Ametme nugka kuitamnumek; 
\q1 tuja yumishkam yutumtikame, 
\q1 dutikam ajak aidaush tsapapitkame. 
\q1 Ame yumi yutumtikjamu betsaka akagak 
\q1 nugkan uchupjamtai, trigo aidaush 
\q1 shiig tsapainiag nejenawai. 
\q1  
\v 10 Ajak ajakmatasa nugka taimu aidaush 
\q1 yumi yutumtikjam uchupiame, 
\q1 wagki ajak aidau tsapainiag senchi nejektinme tusam. 
\q1  
\v 11 Ajak aidau mijadai kuashat nejektinme 
\q1 tusamesh nejemtiknaitme. 
\q1 Tuja yumi kuashat yutau asamtai, 
\q1 yumi atsumakuish waitnatsui. 
\q1  
\v 12 Nuadui uwegshunmash 
\q1 dupa tsapaka samekbau pegkeg wajas awai. 
\q1 Tuja muja aidaushkam 
\q1 samekbau pegkejan iwagmamainawai. 
\q1  
\v 13 Tuja nugka nain pegkeg aidaunmak, 
\q1 tagku aidau piyake, 
\q1 tuja nugka paka aidaunmak 
\q1 kuashat trigo ayawai. 
\q1 ¡Ashí nunú aidau shiig anenawai! 
\c 66  
\s1 Apawa amina takatjumek shiig pegkejai 
\d Kantamtai agagbau 
\q1  
\v 1 Ashí nugkanmaya aidautijum 
\q1 shiig aneasjum Apajuí kantamjuatajum. 
\q1  
\v 2 Apajuí daaji pegkegma nunú pachisjum 
\q1 kantamtai kantamatajum. 
\q1 Tuja niina imanjiya nunú pachisjumshakam 
\q1 kantamtai kantamatajum. 
\q1  
\v 3 Apajuí chichagkujum: 
\q1 “Amina takatjumek shiig pegkeg ainawai. 
\q1 Ame ima senchigtin asamin, 
\q1 amina shiwaajum aidauk 
\q1 ishamjamainak aminí yunumainawai. 
\q1  
\v 4 Nuninak ashí amina etsagtamainawai, 
\q1 nuninak amina daagmin pachisag 
\q1 kantamtain kantamainawai”, titajum. 
\b  
\q1  
\v 5 Apajuí aents aidautin ayamjutpak 
\q1 ishamain wainchatai aidaun iwainajua 
\q1 nunú anentaimtustajum. 
\q1  
\v 6 Nigki nayantsanash ukuya buku emauwai, 
\q1 dutikamtai ii muunji aajaku aidau bukunum katiajajui. 
\q1 Nuadui ¡ima Apajuíyaig shiig aneasagmi! 
\q1  
\v 7 Apajuí niina senchijiya duwi 
\q1 aents aidaunak tuke inawai; 
\q1 untsu niina umigtan dakitin aidaunak 
\q1 niijai shiwagmagawainum tusa tuke diyakui. 
\q1  
\v 8 ¡Ashí aents aidautijum, 
\q1 iina Apajuíjiya nunú 
\q1 pegkegnum chichagtajum! 
\q1 ¡Dutikakjum kantamtai kantamjuatajum! 
\q1  
\v 9 Wagki nii iinak kuitamjamui. 
\q1 Pegkegchaun takastinme tusag idaikagtatsui. 
\q1  
\v 10 Iina Apajuíjiyah, 
\q1 amek ima aminigkiash 
\q1 kajinas anentaima tusam 
\q1 dekapkagtusuitme, 
\q1 nuadui plata jinum jiyamu 
\q1 pegkejama iman ekagtiuwaitme. 
\q1  
\v 11 Tuja kuntin achiktinun 
\q1 dakamtikak, kuntinun achiyajama numamtuk, 
\q1 shiwaaji achiktinme tusam 
\q1 tsagkamkagtukume. 
\q1 Nuigtush shiig kuashat waitkagkagtusume. 
\q1  
\v 12 Nuadui aents pegkegchau aidau 
\q1 waitkastinme tusam 
\q1 agkan idaisabiume, 
\q1 tuja jutiik yuminmash tuja 
\q1 jiinmashkam nagkaemakmaiji. 
\q1 Dutika ashí dekapkagtusam, 
\q1 juju nugka pegkeja imagnum 
\q1 pujustinme tusam apujkagtusmayume. 
\q1  
\v 13-14 Nuadui wi yaunchuk 
\q1 ishamainnum pujusan amina chichagkun: 
\q1 Ame yaintsamin juna nagkaikinuk, 
\q1 amina emematkun anentag amastinaitjame 
\q1 tiuwaitjam, nuna imatiksanuk amina jem 
\q1 pegkegma nuwi wayan kuntinu maan, 
\q1 nuna nejen ashí apeakun ememattatjame. 
\q1  
\v 15 Tuja kuntin duwejam aidaun 
\q1 uwija wiyaji aidaujai 
\q1 amina eme anentsan ashí apeattajai. 
\q1 Nuigtushkam toro aidaun, chivo aidaun, 
\q1 amina emematkun apeattajai. 
\b  
\q1  
\v 16 ¡Ashí atum Apajuí umijin 
\q1 aidautigmek minitajum! 
\q1 Nunikjum antuktajum 
\q1 Apajuí mina yainka nuna pachisan ujaktajime. 
\q1  
\v 17 Apajuín untsukmaijai, 
\q1 dutikan niina emematkun kantamjuamiajai. 
\q1  
\v 18 Wi ayatak pegkegchaunmak 
\q1 anentaimsan pujutaik, 
\q1 Apajuík antugtukchatnuyi. 
\q1  
\v 19 Tujash minak antugtuku asa, 
\q1 wi segamunash yainkabi. 
\q1  
\v 20 ¡Apajuík wi segamunak dakitjachmayi, 
\q1 tuja niina anenkenash sujitjukchabi, 
\q1 nuadui tuke ememattai atin ati! 
\c 69  
\s1 Waitiaku pujusa Apajuí segamu 
\d David kantamamu 
\q1  
\v 1 Apajuíjuh, kuashat waitiakun 
\q1 atsanmainchau dekapeajai, 
\q1 wait aneasam yainkata. 
\q1  
\v 2 Kucha amutnunum tepeajai, 
\q1 wajai emetumainkesh atsugtawai. 
\q1 Dekas namaka kunajin akaejai, 
\q1 namak chichijam asa ajektawai. 
\q1  
\v 3 Untsu untsumkawan sagagjai; 
\q1 mina suweg dajautawai. 
\q1 ¡Apajuín daka dakakuan jiijuish yawegjai! 
\q1  
\v 4 Mina shiwaajuk intash kuashta 
\q1 nuna nagkaesau ainawai, 
\q1 utugchat atsugtaig kajegtuinak, 
\q1 mantuatag tuinawai. 
\q1 Tuja makichkish kasamkachu aig, 
\q1 kasamkamujum awagkita tusa imatjutuinawai. 
\b  
\q1  
\v 5 Apajuíjuh, ame dekame wika pegkegchau ayajai; 
\q1 nuadui mina tudaugnak ugmaitsugme. 
\q1  
\v 6 Tuke Pujuu Apajuí ashí senchigtinuh, 
\q1 ¡aminí kajinmamas anentaimin aina nunú, 
\q1 wainak mina pegkegchaujui 
\q1 datsaama yujainum idaisaipa! 
\q1 Israel aents aidaun Apajuíjiyah, 
\q1 aents amina egapau aina nunú 
\q1 mina pegkegchaujui datsaama 
\q1 yujainum kuitamkata. 
\q1  
\v 7 Amina umiju asan 
\q1 kajegtuinakuish katsuntajai. 
\q1 Datsanjui mina yapijuk nimpawai. 
\q1  
\v 8 ¡Mina yatsuchig aidaush, 
\q1 tikich aents itugmaina dutijuinawai! 
\b  
\q1  
\v 9 Amina jemin akasmatkun senchi waitiajai. 
\q1 Tuja amina pegkegchaun chichagtamainakui, 
\q1 nuna antakun kajeajai. 
\q1  
\v 10 Buutkun yujumkan yutsuk 
\q1 ijagmaan pujai, dushiktuinakuish katsuntajai. 
\q1  
\v 11 Jakamunum nugkutain 
\q1 nugkuai, dushiktuinakuish katsuntajai. 
\q1  
\v 12 Ashí aents aidauk 
\q1 pegkegchaun chichagtuinawai. 
\q1 Tuja nampen aidaushkam 
\q1 tuke aneas dushiktuinak kantamjutuinawai. 
\b  
\q1  
\v 13 Tujash Tuke Pujuuwah, 
\q1 wika amina segajame, 
\q1 ¡wait aneasam yainkata! 
\q1 Amek anenkaitme, tuke kuitamkagtinaitme, 
\q1 iman asam minash uwemtijugta. 
\q1  
\v 14 Tsakusnum tepean tepag nunú 
\q1 eke jatsaig jiigkita, 
\q1 tuja mina kajegtuina dusha agkanmitkajuata. 
\q1 Tuja namak chichijam ajapjuattak 
\q1 awajta nunú uwemtijugta. 
\q1  
\v 15 ¡Namak chichijam 
\q1 ajekjati tusamek idaitusaipa! 
\q1 Tuja wainchi ishamaina nunú 
\q1 yutua emegkakti tusamesh idaitusaipa. 
\b  
\q1  
\v 16 ¡Tuke Pujuuwah, 
\q1 amek pegkeg, anentak wajasuitme, 
\q1 iman asam minash aigkata! 
\q1 Amek wait anenkagtinaitam 
\q1 iman asam minash antugtukta. 
\q1  
\v 17 ¡Juju amina inakem 
\q1 segapa nunú antugtsuk idaisaipa! 
\q1 ¡Utugchat ishamain ajutui, wamak yainkata! 
\q1  
\v 18 ¡Juwi taam, shiwag aidau 
\q1 waitkajuina nunú ayamjutkata! 
\q1  
\v 19 Amek mina dushiktuinak 
\q1 inastuina duka shiig dekame. 
\q1 Tuja mina shiwaajush ya ainawa 
\q1 dushakam amek dekame. 
\q1  
\v 20 Ima imatjutuinakua ipimtukiaje, 
\q1 nuadui shiig aneasa pujumainchau 
\q1 kakaagchamin dekapeajai. 
\q1 Yaki wait anenjug 
\q1 anentaijun ichichtujainta tusan, 
\q1 egaknush wainkachmaijai. 
\q1  
\v 21 Yapajaish, yutainum jatain egketjiagmayi, 
\q1 tuja kitamaish chujuinun sujiagmayi. 
\b  
\q1  
\v 22 Nuadui dita jiistamaina nunú 
\q1 yutaiji aina nunú aatus ditan pempeentuki 
\q1 utugchatan apujtusti. 
\q1  
\v 23 ¡Tuja wainmachu, 
\q1 kakaumainchau emakta! 
\q1  
\v 24 Dutikakum ame kajekbauwai 
\q1 makichkish idaitsuk ashí ijinata. 
\q1  
\v 25 Dutikawamin dita jee aina duka 
\q1 agkan juwajagtatui, 
\q1 tuja nunú jega aidaunmak 
\q1 makichkish pujuschatnume. 
\q1  
\v 26 Wagki ame mina suwimak sujusamin 
\q1 waitiaish, ditak minak diigtsuk 
\q1 ayá dushiktuinak, nuni senchi waitkajuinawai. 
\q1  
\v 27 Nuadui ameshkam 
\q1 pegkegchaunmak ikata. 
\q1 ¡Tuja makichkish dita tudaujig tsagkujaipa! 
\q1  
\v 28 ¡Aents tuke pujusagtin aina nuna daaji 
\q1 papiinum agatkamua nuwi, dita daaji ayá 
\q1 duka ashí esakatjata! 
\q1 Tuja aents amina umigtamin aidaun 
\q1 daaji agatkamua nuwig, 
\q1 dita daajig makichkish agatjaipa. 
\q1  
\v 29 Apajuíyah, wi jakun wake besemag 
\q1 dushikiam pujag nunú minash 
\q1 wait aneasam yainkam uwemtijugta. 
\b  
\q1  
\v 30 ¡Apajuín see tusan kantamtain kantamkun, 
\q1 shiig aneasan ashí iwainakan 
\q1 niina daajin ememattatjai! 
\q1  
\v 31 Nunú dekas, kuntin aidau 
\q1 maa apeamun nagkaesau 
\q1 Tuke Pujuunak shiig awagmaktatui. 
\q1  
\v 32 Tuja aents Apajuín segau aidau 
\q1 wake besemag batsatuk, 
\q1 nuna wainkag shiig aneasagtatui; 
\q1 nuninak ichichmamjagtatui. 
\q1  
\v 33 Wagki Tuke Pujuuk aents waitiak 
\q1 wake besemag pujus sumaunak antujui; 
\q1 tuja niina aentsji aidau achikam batsamas 
\q1 waitiagtaish, dakitjag idaitsui. 
\b  
\q1  
\v 34 Nugka, nayaim, nayants aidautigmesh 
\q1 Apajuí ememattajum, 
\q1 tuja ashí nuwi batsamin aidautigmeshkam 
\q1 Apajuí ememattajum. 
\q1  
\v 35 Apajuí Jerusalégnak kuitamkattawai, 
\q1 dutikak Judá wegantu aidaun 
\q1 yaaktaji aidau tsaikbau aina nunak 
\q1 ataktu iwagkattawai. 
\q1 Dutikamtai niina aentsji aidau 
\q1 nuwi batsamsagtinai. 
\q1  
\v 36 Nunú nugkak niina aentsji aidaun 
\q1 uchiji wegantu aidaunu atinai. 
\q1 Tuja nunú nugkanmak Apajuín aneen aidau 
\q1 shiig batsamsagtinai. 
\c 72  
\s1 Apu eme anentsa Apajuí segatbau 
\d Salomón kantamjuamu 
\q1  
\v 1 Apajuíjuh, 
\q1 juju apu amina takatjum pegkeja nuna 
\q1 niishkam shiig takasti tusam yaigta. 
\q1 Tuja tikich apu atina dushakam 
\q1 dutiksag shiig takastin atinme. 
\q1  
\v 2 Aatus amina aentsjum aidaun, 
\q1 tuja nuigtu waitkam batsatu aidaun apuji wajas, 
\q1 inamak shiig takastin ati. 
\q1  
\v 3 Tuja muja aina nuwiya jiinjag, 
\q1 agkan maanitsuk pujutan, 
\q1 pegkeg takatjai aents aidaun jintintuati. 
\q1  
\v 4 ¡Ujudauch aidaun ayamjukti! 
\q1 ¡Tuja aents waituina nuna 
\q1 uchiji aidaunashkam ayamjukti! 
\q1 ¡Tuja untsu tsanumag kasamin aina nunak waitkasti! 
\b  
\q1  
\v 5 ¡Nii tuké iina apuji atin ati, 
\q1 Tuja etsa, nantu megkaekashtinun tuke auwa 
\q1 nujai betek pujustin ati! 
\q1  
\v 6 ¡Yumi yutak nugkan uchupig, ajakan shiig tsapapama iman ati! 
\q1  
\v 7 ¡Nii apu wajas inamtata duik shiig agkan pujusa takamu ati! 
\q1 ¡Tuja nii inabaujig nantu tuke auwa 
\q1 nujai betek atin ati! 
\q1  
\v 8 ¡Nunú apua duka 
\q1 etsa jiintaya imanui nagkamas, 
\q1 etsa akaetaiya aatus 
\q1 ashí nugkanum inamjatin ati! 
\q1  
\v 9 ¡Tuja niina shiwaaji aidau 
\q1 uwegshunum batsata duka 
\q1 nii tabaun umiktinme! 
\q1  
\v 10 ¡Nuninak Tarsis nugkan apuji aidau, 
\q1 ajuntai aidaunum batsamnun apuji aidau, 
\q1 Sabá nugkan apuji aidau, 
\q1 nuigtu Sebá nugkan apuji aidau aatus 
\q1 waji aidaun ikautiagtinai! 
\q1  
\v 11 ¡Ashí apu aidauk 
\q1 ima niinak tikishmatjagtatui! 
\q1 ¡Tikich nugkanmaya aidaushkam 
\q1 ima niinak umigkagtatui! 
\q1  
\v 12 Ujudauch aidau atsumainak 
\q1 sumainamunak nii yaigtatui, 
\q1 tuja waitiak wake besemag 
\q1 pujaunashkam nii ayamjuktatui. 
\q1  
\v 13 Ujudauch aidaun wait anenjattawai, 
\q1 dutikak wake besemag pujaunash 
\q1 yaigka uwemtijattawai. 
\q1  
\v 14 Ujudauch aidaun waitkainak maaniagtaish, 
\q1 nii ayamjuk uwemtijattawai. 
\q1 Wagki dita pujutji aina duka 
\q1 nii diismak akik ainawai. 
\b  
\q1  
\v 15 ¡Niig tuke iina apuji atin ati! 
\q1 ¡Sabánmaya oronak ashí susatnume! 
\q1 ¡Nii pachisa tuke Apajuí segattai ati! 
\q1 ¡Tuke pegkegnum chichagtai ati! 
\q1  
\v 16 ¡Tuja ashí juju nugkanmak 
\q1 trigo shiig kuashat aittawai, 
\q1 imaniak muja titijinak ijia emegkaktatui! 
\q1 Imaniau asa muja Líbano tutainum 
\q1 trigo aijakua iman wajasti, 
\q1 nuniak nuna yagkuji aidauk 
\q1 dupa yagkujuwama imanik yagkujuk asattawai. 
\q1  
\v 17 ¡Apu daajig etsa tuke ekemna iman 
\q1 tuke pegkegnum chichagtai ati! 
\q1 ¡Aents ashí nugkanmaya aidauk 
\q1 niina daajin pegkegnum yumigkiam agtinai! 
\q1 Ashí nugkanmaya aidauk niina 
\q1 pegkegnum chichajiagtinai. 
\b  
\q1  
\v 18 Tuke Pujuu, Israel aents aidaun Apajuíjiya duka 
\q1 tuke pegkegnum chichagtai ati, 
\q1 wagki ima nigki wainchatai aidaunash iwaidau asamtai. 
\b  
\q1  
\v 19 Apajuí daaji pegkegma duka 
\q1 tuke pegkegnum chichagtai ati. 
\q1 ¡Niina imanjiya nunú ashí nugkan jamagti! 
\q1 ¡Aatus ati! 
\b  
\m  
\v 20 Jesé uchiji David aajakua nunú kantamamuk juwi amuewai. 
\c 73  
\ms1 LIBRO III 
\mr (Salmos 73—89) 
\s1 Apajuí wait anenkagtamu 
\d Asaf kantamamu 
\q1  
\v 1 Israel aents aidau anentaimtaji pegkeg aidaunak 
\q1 Apajuí shiig kuitamui. 
\q1  
\v 2 Namput wajaschabiajai iyautnak, 
\q1 jukea akunuk iyagtinuyajai. 
\q1  
\v 3 Aents Apajuín umigchau aidau wiakchamenakui, 
\q1 nuna diisan kajebiajai. 
\b  
\q1  
\v 4 Ditak jamamtuchu batsatu asag 
\q1 jakachainjash tusagkesh puyatuinatsui. 
\q1  
\v 5 Dita utugchatjig atsujuinawai, 
\q1 nuadui tikich aidau waituina imanikag 
\q1 waituinatsui. 
\q1  
\v 6 Nuadui ditak nugkutai pegkeg najanamu 
\q1 nugkumaina numamtuk, 
\q1 dita emematin nugkuaju ainawai. 
\q1 Tuja ditak magkagtutaijinak, 
\q1 jáanchjai betek nugkuaju ainawai. 
\q1  
\v 7 Duwegmatnak duwejam ainawai, 
\q1 tujash dita yapinig wainnawai 
\q1 anentai shiig pegkegchau aina duka. 
\q1  
\v 8 Ememainak tikich aents aidaunash 
\q1 dushikinawai, nuninak 
\q1 makichkish datsaamtsuk, 
\q1 ii wakegakuik pegkegchau takamsattaji 
\q1 tusag awanmainawai. 
\q1  
\v 9 Nuninak Apajuínash pegkegchaun chichajuinawai, 
\q1 tuja aents aidaunash dutiksag pegkegchaun chichajuinawai. 
\b  
\q1  
\v 10 Nuna aents yujajus iniinak 
\q1 yajau chichainatsui tusag 
\q1 shiig antuju yujaush ainawai. 
\q1  
\v 11 Nuninak: “¿Apajuísh wajuk dekatki iina pujutjinash? 
\q1 Tuja Apajuí nayaimpinum puja aniaush 
\q1 aents takainamunash 
\q1 ¿wajuk dekamainaita?” tuinawai. 
\q1  
\v 12 ¡Diisjua aents pegkegchau aina nunú! 
\q1 Ditak utugchatji atsau, 
\q1 shiig pujusag wiakuch wenawai. 
\q1  
\v 13 ¡Wi pegkegchau takatan 
\q1 ashí idaisauwaitag duka minak 
\q1 makichkish pegkegnumak yaintsui! 
\q1  
\v 14 Minak wa wamak utugchatan itagtuinawai, 
\q1 tuja kashi kashikmasan suwimkanak igkuajai. 
\b  
\q1  
\v 15 Tuja wisha dita anentaimaina nujai betek anentaimkunuk, 
\q1 amina aentsjum aina nunak kajimatki idaikunus, 
\q1 wi wakegamun takasu aintagtai. 
\q1  
\v 16 Tuja ibau tudaugtin aidaush, 
\q1 ¿wajukag wiakchash wenawa? tusa 
\q1 anentaimsan ejetakamanush 
\q1 ejemainchau dekapjabiajai. 
\q1  
\v 17 Nuni pujaun Apajuí jee pegkegma nuwi 
\q1 niijai chichastasan waya ai, 
\q1 aents pegkegchau aidaush 
\q1 wajukatnuk ainawa 
\q1 nuna Apajuí dekamtijuabi. 
\q1  
\v 18 Nunú aents aidauk ishamainnum batsasume, 
\q1 dutikamu asag dita megkaejatnunum shimawai. 
\q1  
\v 19 ¡Nunú aidauk pachiachbau 
\q1 shiig wamak ijina utsam agtatui! 
\q1 ¡Ditak sapijai jinawagtinai! 
\q1  
\v 20 Tuke Pujuuwah, aents kanag tepau nantak 
\q1 nii kajamjamujin kajimatama numamtuk, 
\q1 ame nantakum aents pegkegchau aidau 
\q1 ditash ima pegkeg ainawa tumain aina duka 
\q1 emegkagtatme. 
\b  
\q1  
\v 21 Wi senchi kajekan pujubiajai, 
\q1 nuniai mina anentaig dajautibi. 
\q1  
\v 22 Wika aents pegkegchau aina nuna 
\q1 pujutjin dekajuatasan wakegakun, 
\q1 kuntin jintiag anentaimchau asa 
\q1 wajukmaina numamtuk wajabiajai. 
\q1  
\v 23 Nuniayatkun amejaig tuke pujubiajai, 
\q1 nuniau asamtai tudaunum iyawai tusam 
\q1 egkegsam awekatmayume. 
\q1  
\v 24 Umigtukti tujutu asam 
\q1 ame chichagtukmayume, 
\q1 nuadui wi jakamtaish, 
\q1 eme anenjusam jujuktinaitme. 
\q1  
\v 25 ¿Amina nagkaetamsaush tikichish 
\q1 nayaimpinmash ya pujawa? Duka atsawai, 
\q1 ima ameketme. 
\q1 Amejai pujaknuk juju nugkanmaya aidaunak 
\q1 makichkish wakejumaitsujai. 
\q1  
\v 26 Mina pujutjua duka nagkankattawai, 
\q1 tujash Apajuíya nunú 
\q1 pujut tuke atinun sujustatui, 
\q1 tuja nii mina anentaijuish ichichtawai. 
\q1  
\v 27 Aents amina nemagtamtan dakitauk, jinawagtinai; 
\q1 tuja ima aminig kajinas 
\q1 anentaimainachushkam ijinatnaitme. 
\q1  
\v 28 Untsu wika ima Apajuíyaig 
\q1 anentaimsan pujustinaitjai, 
\q1 nunú minak shiig awajtawai. 
\q1 Ametme Tuke Pujuu Apajuí, mina ayamjutkatnumek. 
\q1 Nuadui ashí ame dutikamu aina nunak etsegkattajai. 
\c 80  
\s1 Tuke Pujuuwah, wait anenkagtugta 
\d Asaf kantamamu 
\q1  
\v 1 Apajuí, Israel aents aidaun kuitamnuh, 
\q1 ¡ame José wegantu aina duka 
\q1 aents uwigjin kuitamas awekauwama numamtuk 
\q1 kuitamsa awekame! 
\q1 ¡Ame querubin aidauk iname! 
\q1 ¡Iman asam Efraín wegantu aidau, 
\q1  
\v 2 Benjamín wegantu aidau, 
\q1 Manasés wegantu aidau wait anenjata! 
\q1 Dutikakum amina senchigmijai uwemtikagtugta. 
\q1  
\v 3 Tuke Pujuuwah, ¡iina pujutji yapagkagtuam 
\q1 yaunchuk ayag iman ekagtita! 
\q1 Dutikagtuawaminig jutiishkam uwemjagtatji. 
\b  
\q1  
\v 4 Tuke Pujuu ashí senchigtinuh, 
\q1 amina aentsjum aidau 
\q1 segapainakui dakitam dusha 
\q1 ¿wajupa kuashta aikash pujugtatme? 
\q1  
\v 5 Yutai sukagtumaina nunú 
\q1 waitut sukagtusmayume, 
\q1 tuja umutai umumaina nunú 
\q1 waitiaku buutbau sukagtusmayume. 
\q1  
\v 6 Iina nugkega nuna yantamen batsamin aina 
\q1 nunú atsaneaku dushiktai ekagtiume. 
\q1  
\v 7 Apajuí ashí senchigtinuh, 
\q1 ¡iina pujutji yapajiam 
\q1 yaunchuk ayag iman ekagtita! 
\q1 Dutikagtuawaminig jutiishkam uwemjagtatji. 
\b  
\q1  
\v 8 Uva numiji\f + \fr 80:8 \ft “Uva numiji” tawa nunak Israel aents aidau Egipto nugkanum batsatun Apajuí jiija yajuak Canaán nugkanum ikaunma, nuwi aents aidaun jiija utsaak nunú nugkanum batsasua nuna taku tawai.\f* egiptunmaya jukim 
\q1 juwi itaam, aents pegkegchau aidau 
\q1 jiija utsaakum juju nugkanum ajabiume. 
\q1  
\v 9 Dutikam shiig tsapaiti tusam nugka iwajabiume, 
\q1 dutikawamin nuwi tsapaka 
\q1 ashí nugkan jamagmayi. 
\q1  
\v 10 Imaniku asa nunú tsakaak 
\q1 muja aidaunak bikintu awajsabi; 
\q1 dutikak numi múun aidaunash 
\q1 nagkagag niina kanawen yutua asabi. 
\q1  
\v 11 Imaniau asa kanawe aidauk 
\q1 nayantsanum jegabi. 
\q1 Tuja nuwi yama tsapaidaushkam 
\q1 namak Eufratesa imanui jegabi. 
\q1  
\v 12 Uva ajakbau peejamua dusha 
\q1 ¿wagka yumpuntuamesh agkantash awajtusume, 
\q1 aents aidau nagkaemainak 
\q1 akajag yajumtinme tusamesh? 
\q1  
\v 13 Paki utsantua tegaja ijinui. 
\q1 ¡Kuntin ikamia aidau amuinawai! 
\b  
\q1  
\v 14 Amek Apajuí ashí senchigtinaitme, 
\q1 iman asam wait aneasam 
\q1 nayaimpinum pujusam 
\q1 juju uva ajakbauwa nunú kuitamkata. 
\q1  
\v 15 Juju uva ayá duka ame ajakbau ainawai, 
\q1 nuadui kuitamkata. 
\q1  
\v 16 Tuja uva numijin tsupig apea ijinuk, 
\q1 ameshkam dutiksamek ijinata. 
\q1  
\v 17 Untsu apu ati tusa ame etegkamua duka 
\q1 kuitamkata, dutikakum yaigta. 
\q1  
\v 18 Tuja yamai nagkamsaik 
\q1 makichkish aminig tsujakchattaji. 
\q1 ¡Pujut sukagtusta ima aminig 
\q1 kajitmamsa batsamsagmi! 
\b  
\q1  
\v 19 Chah, Tuke Pujuuwah, ametme 
\q1 Apajuí ashí senchigtinmek, 
\q1 nuadui ¡iina pujutji yapajiam 
\q1 yaunchuk ayag iman ekagtita! 
\q1 ¡Dutikagtuawaminig jutiishkam uwemjagtatji! 
\c 84  
\s1 Apajuí jee pegkegma nuwi pujustasan ima senchi wakegajai 
\d Coré uchiji aidau kantamawagbau 
\q1  
\v 1 ¡Tuke Pujuu, ashí senchigtinuh, 
\q1 amina jemea duka shiig pegkejai! 
\q1  
\v 2 ¡Wika Tuke Pujuu jee pegkegma nuwi pujustasan 
\q1 shiig senchi wakegajai! 
\q1 ¡Nuniakun Apajuí pujuta sukagtina nuna 
\q1 shiig anentsan senchi kantamjajai! 
\q1  
\v 3 Tuke Pujuuwah, ametme ashí senchigtinum. 
\q1 Mina apug, Apajuíjuh, 
\q1 tiki pishakchikesh amina jemin waya, 
\q1 pasugmak uchijin muumpitkamainuk 
\q1 agkantak ayawai. 
\q1  
\v 4 ¡Amina jem pegkegma nuwi pujuidauk 
\q1 shiig aneasag batsatainawai, 
\q1 nunidau asag amina emematjamtanak 
\q1 makichkish mijamainatsui! 
\q1  
\v 5 Tuja aents aidau aminiyan 
\q1 senchimetan juwina duka shiig aneasagtatui, 
\q1 tuja amina jemin minitag tusa 
\q1 wakeyin aina dushakam shiig aneasagtatui. 
\q1  
\v 6 Nugka paka buutbau tutai 
\q1 yumi atsaunum weakush, 
\q1 yumi pukuni jiinaidaun waintinai; 
\q1 tuja yumigmat taimunmaya yumi 
\q1 kuyua megkaetaish, yumi yutak 
\q1 ashí nugka waa aidaunmak pimasua waigtinai. 
\q1  
\v 7 Apajuíyah, amina senchigmejai 
\q1 ditak tuké senchimeawagtinai. 
\q1 Tuja Siógnum jegawag 
\q1 Apajuí senchigtina nuna wainkagtinai. 
\b  
\q1  
\v 8 Tuke Pujuu, ashí senchigtin, 
\q1 Jacopan Apajuíjiyah, 
\q1 ¡wi sumamush antugtukta! 
\q1  
\v 9 Apajuíyah, jutii ejamaktin 
\q1 ame etegkam apu emauwaitam 
\q1 nunú shiig anentsam kuitamkata. 
\q1  
\v 10 Amina jem pegkegma nuwi waya, 
\q1 makichik tsawan pujamua duka, 
\q1 mil tsawan agá pujumaina 
\q1 nuna nagkaesau ima pegkejai. 
\q1 Wika aents pegkegchau aina nujai 
\q1 ijunja pujutnak idaikun, 
\q1 dekas amina jem pegkegman waitijiya nuna 
\q1 kuitamin atajai tusan wakegajai. 
\q1  
\v 11 Wagki Tuke Pujuu Apajuí iinak ejapak kuitamjamui; 
\q1 tuja aents tudau takatsuk batsata nunak, 
\q1 nii wait anentak eme anentus kuitamui, 
\q1 dutikak waji pegkeg aidaunak sujitatsui. 
\b  
\q1  
\v 12 Tuke Pujuu, ashí senchigtinuh, 
\q1 ¡aminí kajinmamas anentaimaidauk 
\q1 shiig aneasagtinai! 
\c 87  
\s1 Jerusalén pachisa kantamamu 
\d Coré uchiji aidau kantamawagbau 
\q1  
\v 1 Yaakat Jerusalégkak muja pegkejam 
\q1 Apajuínu tutaiya nuwi yaaktamamui. 
\q1  
\v 2 Tuke Pujuuk Israel aents aidaun yaaktaji, 
\q1 tikich aina nuna nagkagas, 
\q1 Jerusalégkan ima senchi aneawai. 
\q1  
\v 3 Apajuín yaaktajiya nuna 
\q1 Jerusalégkan pachisag, 
\q1 shiig pegkejan augmatuinawai. 
\q1  
\v 4 Apajuí chichaak: 
\q1 “Aents aidau mina emematjuina duka 
\q1 Egipto nugkanum, Babilonia nugkanum, 
\q1 Tironum, Etiopía nugkanum, Filisteo nugkanum aatus batsatui. 
\q1 Nunú nugkanmaya aents aidau chichainak: 
\q1 ‘Apajuínak Jerusalégnum wainkabiajai’ tiagtatui”, tiuwai. 
\b  
\q1  
\v 5 Tuja Siógnumia aidaun chichajuinak: 
\q1 “¿Wagkag ditash ibau pegkegnumash batsamsajabi? 
\q1 Dita batsamsatnunak dekas Apajuíyap 
\q1 umigkauwaita”, tiagtinai. 
\q1  
\v 6 Aents aidaun daaji agattainum 
\q1 Tuke Pujuu dita daajinak: 
\q1 “Juka Siógnum akiinauwai”, tuu agatjatnai. 
\b  
\q1  
\v 7 Nuadui nuwiya aents aidauk nantsemki, 
\q1 kantamkabaikia chichainak: 
\q1 “Mina pujutaijuk Jerusalégkai”, tiagtinai. 
\c 89  
\s1 Apajuí Davitjai chicham umikbau 
\d Esrahita aents Etán aajakua nunú kantamamu 
\q1  
\v 1 Tuke Pujuuwah, wi kantamkunuk, 
\q1 amek tuke wait anenkagtinaitme titatjame, 
\q1 tusan aju ajumag kantamjittagme. 
\q1  
\v 2 Nuniakun amina anenkem tuke auwa nuna, 
\q1 tuja ame anagkagtuamuk 
\q1 nayaim yapajinchauwa imana nuna etsegkattajai. 
\q1  
\v 3 Amek Davidjai chichamak umikuitme; 
\q1 dutikau asam nii anagkuakum: 
\q1  
\v 4 “Ame jakaminig, 
\q1 ame wegantunmaya apu wajasa 
\q1 ame pujusa inamtaigmin pujus inamjatnai”, 
\q1 tiuwaitme. 
\b  
\q1  
\v 5-7 Chah, Tuke Pujuuwah, 
\q1 nayaim aidauk amina takatjum pegkeja 
\q1 nuna diisag emematjamainawai, 
\q1 tuja ashí ángel aidauk 
\q1 amina anenkagmin pachisag chichainawai; 
\q1 ima aminak eme anenjamainawai. 
\q1 Tuke Pujuuwah, ametme 
\q1 tikich aents aidaun apajuíji aina 
\q1 nuna nagkaesau ishamtai dekas muunmek. 
\b  
\q1  
\v 8 Tuke Pujuu ashí senchigtinuh, 
\q1 ame senchigtinum chichakbaugmek 
\q1 betek uminaitam imanuk tikichik 
\q1 makichkish atsawai. 
\q1  
\v 9 Ame nayantsak inau asam, 
\q1 tsukatak ishamain wajakuish, 
\q1 mijaakta tusam imijiame. 
\q1  
\v 10 Nayantsanmaya kuntin múun depetkam, 
\q1 amina senchigmin shiwaajum aidau 
\q1 uwaakam ipisjabiume. 
\q1  
\v 11 Nayaim, nugka aina duka aminu ainawai, 
\q1 ame nugkak, tuja ashí nugkanum 
\q1 ayá nujai najankauwaitme. 
\q1  
\v 12 Tsumujinish, nujinchinish 
\q1 ame ashí nugkak najanauwaitme. 
\q1 Tuja muja Tabor, muja Hermógjai 
\q1 amina daagmin pachisag kantamainawai. 
\q1  
\v 13 Amina kuntugmek senchigtinai, 
\q1 tuja amina uwejum untsuja dushakam 
\q1 senchigtin depetbauwai. 
\q1  
\v 14 Amek pegkegnum anenkajai inaame, 
\q1 tujash nuna nagkaesau dekas 
\q1 amina anenkagmin 
\q1 tuke kuitamkagtame. 
\q1  
\v 15-16 Chah, Tuke Pujuuwah, 
\q1 aents amina emematjamin, 
\q1 amina tsaaptinjumin wekayin, 
\q1 tuja amina takatjum pegkegma nuna diis 
\q1 tuke shiig anea duka 
\q1 amek eme anentame, 
\q1 dutikakum pegkegnum yumigkiame. 
\q1  
\v 17 Wagki dita imanji aina duka, 
\q1 tuja senchiji aina nujai ame susauwaitme. 
\q1 Nuadui jutii aidautik aan nagkaemasam 
\q1 senchigtin ekagtame. 
\b  
\q1  
\v 18 Israel aents aidaun Apajuíji, Tuke Pujuuwah, 
\q1 ametme iina apuji pegkegmamek, 
\q1 tuja ametme ejajatkam kuitamkagtaumek. 
\q1  
\v 19-20 Amina chichamjumin etsejin 
\q1 yaunchuk kajanum chichagkum: 
\q1 “Mina aentsug aina nuwiyan 
\q1 makichik wajiun etegkajai, 
\q1 duka mina inakeg Davitai, 
\q1 wi niinak yaigkan, chichame antugtai emajai. 
\q1 Dutikan ¡Israel aents aidaun apuji adaikajai! 
\q1  
\v 21 Niinak yaitskek idaisashtinaitjai. 
\q1 Mina senchigjai senchimtikatnaitjai. 
\q1  
\v 22 Niina shiwaaji aidaush jetekchagtin ainawai, 
\q1 tuja aents pegkegchau aidaushkam 
\q1 depetkachagtin ainawai. 
\q1  
\v 23 Niina shiwaaji aidaunak 
\q1 niish wainaig ijinatnaitjai, 
\q1 tuja niina kajejuidaunash ijinatnaitjai. 
\q1  
\v 24 Wi niina aneamua duka tuke atinai, 
\q1 wi kuitamsam kuashat kaweg 
\q1 senchigtin wajastinai. 
\q1  
\v 25 Tuja niig nayants Mediterraneo tutaya 
\q1 nuwi nagkamas namak 
\q1 Eufratesa aatus inamjatnai. 
\q1  
\v 26 Tuja nii chichagtak: 
\q1 ‘Ametme mina apag kuitamjaumek; 
\q1 tuja ametme mina Apajuíg uwemtijinmek’, tujuttinai. 
\q1  
\v 27 Tuja wi niinak mina uchig iwai, 
\q1 ashí tikich apu aidaunash 
\q1 nagkaesau apu emattajai. 
\q1  
\v 28 Wika niinak tuke anetnaitjai, 
\q1 tuja wi niijai chichaman umikuitag 
\q1 dushakam tuke atinai. 
\q1  
\v 29 Nayaim awa nunisag aigkik, 
\q1 niina uchiji wegantu aidaunmayag 
\q1 tuke apu wegagtin ainawai. 
\q1  
\v 30 Untsu dita chicham umiktinun 
\q1 wi jintintuau ainag nuna 
\q1 kajimatkiag batsamas, 
\q1  
\v 31 nunú chichaman uminachkuig, 
\q1  
\v 32 dita pegkegchaujin 
\q1 suwimak ishamainun susatnaitjai. 
\q1  
\v 33 Untsu Davidnak tuke anetnaitjai, 
\q1 tuja wi niina anagkuawaitag nunashkam 
\q1 umitskek idaisashtinaitjai. 
\q1  
\v 34 Wi niijai chichaman umikuitag nunak 
\q1 tuke idaisashtinaitjai, 
\q1 nunak tuke umiktinaitjai. 
\q1  
\v 35 Makichik tsawantai 
\q1 wi Davitan anagkuawaitag nunak 
\q1 dekas umiktatjai tusan tumamjai. 
\q1  
\v 36 Etsa eketa nunisag eketaigkik, 
\q1 niina uchiji wegantu aidauk 
\q1 tuke apu wegagtin ainawai. 
\q1  
\v 37 ¡Nii wegantu aidauk, 
\q1 nantu tuke ekemna iman atinai! 
\q1 ¡Nii pujusa inamtaijishkam nayaim tuke auwa iman atinai!” tiuwaitme. 
\b  
\q1  
\v 38 Tusa tiuwaitkum ame apu etegkamu aig, 
\q1 kajegkam dakitja idaisaume. 
\q1  
\v 39 Dutikau asam niijai chicham umikuitam duka 
\q1 umitsuk, David kajimatkim idaisaume. 
\q1  
\v 40 Tuja yaakat Jerusalén peejamua dushakam 
\q1 yumpua tsaikam ayamjumamainchau 
\q1 emam idaisaume. 
\q1  
\v 41 Ashí aents nuni nagkaemaidauk 
\q1 wayawag dita wakegamun kasamainawai, 
\q1 tuja aents dita nugkega nuna yantamen 
\q1 batsamin aidau dushikinawai. 
\q1  
\v 42 Nuadui Davita shiwaaji aidauk shiig anenawai, 
\q1 wagki dita ima senchijinawaju asag. 
\q1  
\v 43 Niina maanitaiji puyagshakam atankiume; 
\q1 dutikau asam maaniakuish yaigchaume. 
\q1  
\v 44 Eme anentai aajakua duka 
\q1 wainkauch idaisaume; 
\q1 dutikakum apu wajasa inamtaijishkam 
\q1 tikima wainkauch awajtusume. 
\q1  
\v 45 Tuja nuigtush kuashat mijan 
\q1 pujuschati tusam atankiume, 
\q1 dutikakum datsa datsantak awajsaume. 
\q1  
\v 46 Chah, Tuke Pujuuwah, 
\q1 ¿uumjutkamek pujuttam? 
\q1 ¿Kajegtukbaukek pujuttam? 
\q1  
\v 47 Apuh, mina pujutug piipichia nunú adeagta; 
\q1 ame aents najanamua duka 
\q1 ujumak tsawantak pujus jauwai. 
\q1  
\v 48 ¡Makichik aentsuk jatsukek iwakuk pujumaitsui! 
\q1 ¡Tuja jakashtajai tusa, 
\q1 jata uwemtumainchakam makichkish atsawai! 
\q1  
\v 49 Apuh, ¿ame yama nagkamchakum: 
\q1 Davita tuke anetnaitjame tusam 
\q1 tiuwaitam dusha wajukame? 
\q1  
\v 50 Apuh, iinak kuashat dushiktamainawai, 
\q1 imatika dushiktamainakuish atsaneaji. 
\q1  
\v 51 Tuke Pujuuwah, amina shiwaajum aidau 
\q1 ¡aatus iina pegkegchaun chichagtamainawai! 
\q1 ¡Aatus ame apu etegkamua nuna 
\q1 aju ajumag pegkegchaun chichajuinawai! 
\q1  
\v 52 ¡Tuke Pujuuk, tuke pegkegnum chichagtai atin ati! 
\q1 Maake, aatus ati. 
\c 90  
\ms1 LIBRO IV 
\mr (Salmos 90—106) 
\s1 Aentsuk Apajuí tuke pujuuwa nuninchauwai 
\d Moisés Apajuí etegkamu aajakua nunú Apajuín ausamu 
\q1  
\v 1 Apuh, amek yaunchuk nagkamsam 
\q1 jutiik tuké yaijatnaitme. 
\q1  
\v 2 Tuja muja aidaush najaneatsaig, nugkashkam najaneatsaig, 
\q1 yaunchuk nagkamsam, 
\q1 yamaya juish, tuja atakea duishkam 
\q1 ameketme Apajuímek. 
\q1  
\v 3 Amina chichamjuminig 
\q1 aents aidauk jakag nugka najanenawai. 
\b  
\q1  
\v 4 Ame diismak mil mijana duka 
\q1 makichik tsawan nagkaema nuninai; 
\q1 tuja mil mijana duka 
\q1 kiyag tsawak megkagama 
\q1 numamtuk nagkaemawai. 
\q1  
\v 5 Amek namak chichigmajai betek 
\q1 aents aidauk utsame, 
\q1 tuja iina pujutjig kajanum kajamja 
\q1 shintaku ukutiama nujai betekai. 
\q1  
\v 6 Aents aidauk dupajai betek ainawai, 
\q1 dupa kashikmas yagkujuk, 
\q1 etsa akagai kagaka 
\q1 jinuwama numamtuk wajaji. 
\b  
\q1  
\v 7 Ame kajekbaugmin amujatme, 
\q1 tuja ame kajekamin ishamka 
\q1 imaanjaujai betek pujaji. 
\q1  
\v 8 Iina tudauji pegkegchauwa duka 
\q1 ame shiig dekame. 
\q1  
\v 9 ¡Ame kajegkagtukaminig 
\q1 ii iwaku batsatag duka, 
\q1 mayai mayati ajaptayama 
\q1 numamtuk jaka megkaemainaitji! 
\q1  
\v 10 Iik ayatak setenta mijan pujusa jainaji, 
\q1 tuja nuni wajiu aidau ochenta mijan jegainawai; 
\q1 tujash imaan mijan pujakuish, 
\q1 ima waitiamua duke utugchatjai igkunui. 
\q1 ¡Mijanak jutii pujutjijai betek 
\q1 wamak nagkaemawai! 
\b  
\q1  
\v 11 Ame senchi kajeamugminash 
\q1 ¿ya dekamainaita? 
\q1 Ame kajekbaujum ishamaina nunash 
\q1 ¿yaki dekamainaita? 
\q1  
\v 12 ¡Iik tuke jakatnapitji tusa, 
\q1 shiig dekau ata nunú jintinkagtuata! 
\q1 ¡Nunú dekau asaja, 
\q1 pegkegnum pujuta nunú puyatjukagmi! 
\b  
\q1  
\v 13 ¡Tuke Pujuuwah, ataktu yaijatkata! 
\q1 ¿Wajupa asamea yaijatkattame? 
\q1 ¡Juju amina inakem aina nunú wait anenjata! 
\q1  
\v 14 Kashikmasa nagkamsam 
\q1 amina anenkagmea nunú sukagtusta, 
\q1 dutikagtuawaminig ashí tsawantai, 
\q1 shiig aneasa tuké kantamtinaitji. 
\q1  
\v 15 Kuashat mijanai waitujakuitag 
\q1 imatiksamek shiig aneasa pujut sukagtusta. 
\q1  
\v 16 ¡Juju amina inakem aina nunú 
\q1 dita wegantu aidaujai amina imanjumin 
\q1 senchigmejai wainkatnume tusam iwaintukta! 
\q1  
\v 17 ¡Iina Apajuíji Tuke Pujuuwa 
\q1 nuna wait anenkagtutaijig jutinii asati! 
\q1 ¡Apajuíjuh, iina takatjish pegkegnum yumigsata! 
\q1 ¡Ehe, dekas iina takatjig pegkegnum yumigsata! 
\c 91  
\s1 Apajuíyai iina kuitamjamnuk 
\q1  
\v 1 Apajuí múun, ashí senchigtina nunú 
\q1 kuitamsam pujauk, 
\q1  
\v 2 Tuke Pujuun chichajak: “Ametme 
\q1 mina ejamataijuk, 
\q1 wi uumka ayamjumataig. 
\q1 ¡Ametme mina Apajuíg, 
\q1 ima aminig kajintsan anentaimjai!” tawai. 
\q1  
\v 3 Wakan pegkegchau 
\q1 utugchatan apujtugmataish, 
\q1 tuja jata aidaunmashkam 
\q1 ima nigki ayamjutpamainai. 
\q1  
\v 4 Wagki niig atash niina nanapen uchuchiji aidaun 
\q1 dukuka kuitamama numamtuk kuitamjamnai, 
\q1 nuadui amek puyattsuk 
\q1 shiig aneasam pujustinaitme.\fig |alt="Hen and chicks" src="LB00061b.tif" size="col" loc="Psalm 91.4" ref="Sal. 91.4" \fig* 
\q1 ¡Niina anenkega duwi 
\q1 aminak tantag ejamatia numamtuk 
\q1 ejapak kuitamjamkattawai! 
\q1  
\v 5 Nuadui kashi ishamainnum pujakmesh, 
\q1 tuja tsawai wekaekumesh, 
\q1 mantuachagtimpash tusamek ishamkaipa. 
\q1  
\v 6 Tuja jata kashi magkagtin, 
\q1 tsawai magkagtinkesh iyanjugmatai, 
\q1 jakashtajash tusamek ishamkaipa. 
\q1  
\v 7 Amina menagmea nuni mil aents jinitnai, 
\q1 tuja untsugmea nunishkam 
\q1 diez mil aents jinitnai, 
\q1 tujash amek makichkish wajukashtinaitme. 
\q1  
\v 8 Untsu aents pegkegchau aidaun Apajuí suwimak susam jinuidau waintinaitme, 
\q1  
\v 9 wagki aminak Tuke Pujuu múun, 
\q1 ashí senchigtina nunú 
\q1 ejapak kuitamjamu asamtai. 
\b  
\q1  
\v 10 Aminak makichik pegkegchaukesh 
\q1 waitkagmaschatnai, 
\q1 tuja jatashkam amina jeminig utugmashtinai. 
\q1  
\v 11 Wagki Apajuí ángel aidaun ishiaktatui 
\q1 ame tuwi wekaetatme nuwi kuitamjamkatnun. 
\q1  
\v 12 Nunú ángel aidau achigmaku agtatui, 
\q1 kaya tukumak iyajai tusa. 
\q1  
\v 13 Nuadui, ikamyawa yukagtin aidau, 
\q1 tuja tikich kuntin ishamain ayaunum 
\q1 wekaekumesh, uyumat aneakas wekaetatme. 
\b  
\q1  
\v 14 Apajuí chichaak: 
\q1 “Juju aentsuk mina waitui, 
\q1 anentanash anentui, nuniau asamtai 
\q1 wi niinak ayamjukan uwemtikjattajai. 
\q1  
\v 15 Tuja yainkati tusa mina segatkuishkam, 
\q1 aiktinaitjai, dutikakun ¡niijaig pujutnaitjai! 
\q1 ¡Tuja waitiakuishkam agkanmitkatnaitjai! 
\q1 ¡Dutikakun eme anentsa diitai awajsatnaitjai! 
\q1  
\v 16 Tuja kuashat mijan 
\q1 shiig pujustin ati titinaitjai. 
\q1 ¡Dutikakun pujut nagkanchau tuke atina nuwi pujus 
\q1 dakujusti tusan jukitnaitjai!” tawai Apajuí. 
\c 93  
\s1 Apajuíyai dekas apuk 
\q1  
\v 1 ¡Tuke Pujuuwai dekas apua duka! 
\q1 Tuke Pujuuk etsantug tsaaptin wajas eketui, 
\q1 niyai ashí senchigtina duka, 
\q1 tuja nugka buchitkai tusashkam kuitamui. 
\q1  
\v 2 Amek yaunchuk nagkamsam apuitme, 
\q1 ¡Amek tuke pujuuwaitme! 
\q1  
\v 3 Chah, Tuke Pujuuwah, 
\q1 namak senchi tsukatak uutui. 
\q1  
\v 4 Tujash apujuh, amek nayaimpinum pujusmek, 
\q1 namak tsukatak uutuina nuna nagkaesau, 
\q1 tuja nayants uutbaun nagkaesau 
\q1 senchigtinaitme. 
\b  
\q1  
\v 5 Chah, Tuke Pujuuwah, 
\q1 amina chichamjum umiktina duka 
\q1 yapajinchau tuke auwai. 
\q1 ¡Amina pegkegmagmea duka 
\q1 makichik jeganum yagkug 
\q1 nenaja iwajamuama imanik, 
\q1 amina jem pegkegma nuwi tuke awai! 
\c 95  
\s1 Apajuí shiig anentsa kantamjuawagmi 
\q1  
\v 1 Kaunatajum, 
\q1 Tuke Pujuu, iina kuitamjamak 
\q1 uwemtijamna nunú 
\q1 shiig aneasa kantamjuawagmi. 
\q1  
\v 2 Nii pujamunum wayawaja 
\q1 nii emematku kantamtai kantamjuawagmi. 
\q1  
\v 3 Wagki Tuke Pujuuwai dekas múun senchigtin, 
\q1 ashí tikich apajuímtai aina nunashkam Apujiyai. 
\q1  
\v 4 Nugkak initken nagkamas 
\q1 ashí Apajuí emetuam awai, 
\q1 tuja muja tsakaju aidaushkam niinu ainawai. 
\q1  
\v 5 Tuja nayantsashkam 
\q1 nii najanamu asa ima niinuke. 
\q1 ¡Nugkanashkam nigki najanauwai! 
\b  
\q1  
\v 6 Minitajum, 
\q1 Tuke Pujuu, iina najapauwa nunú 
\q1 tikishmatja emematiagmi. 
\q1  
\v 7 Niyai iina Apajuíjig, 
\q1 tuja iik niina aentsji ainaji, 
\q1 nuadui uwija kuitamin 
\q1 niina uwigjin kuitamama numamtuk 
\q1 iinash kuitamjamui. 
\q1 Apajuí yamai atumin tujama 
\q1 nunú antuktajum. 
\q1  
\v 8 “Yaunchuk Meribánum, 
\q1 tuja uwejush Masánmashkam 
\q1 Apajuí chichamen intimjukiu aina 
\q1 numamtuk wajakaigpajum. 
\q1  
\v 9 Atumin muunjum aajaku aina duka 
\q1 kuashat wainchatai aidaun 
\q1 wi iwainamun wainainayatak, 
\q1 dekaskechua nunin diisu ainawai. 
\q1  
\v 10 Nuadui nunú aents aidaun 
\q1 dakitjan cuarenta mijan pujubiajai, 
\q1 nuniakun: ‘Juju aents aidauk 
\q1 shiig wainak yujawai; núnidau asag 
\q1 mina chichamjunak umigtuinatsui’. 
\q1  
\v 11 Nuadui kajekan, 
\q1 chicham yapajiashtinun chichaakun: 
\q1 ‘Dita shiig batsamsatnun nugka pegkejan 
\q1 wi ditan anagkuawaitag 
\q1 nuwig ditak jegashtin atinme’ tiabiajai”, 
\q1 tiuwai Apajuí. 
\c 96  
\s1 Yamajam kantamtai ii apuji kantamjamu 
\q1  
\v 1 Ashí nugkanmaya aents aidautijum 
\q1 yamajam kantamtai 
\q1 Tuke Pujuu kantamjuatajum. 
\q1  
\v 2 Tuke Pujuu kantamjakjum, 
\q1 niina daaji pegkegnum chichagtajum. 
\q1 Tuja Apajuíyai uwemtikagtinuk tusajum 
\q1 kashi kashinig etsegtajum. 
\q1  
\v 3 Apajuí imanjiya nunú, 
\q1 niina pegkegmajijai pachisjum 
\q1 ashí nugka múun aidaunum etsegkatajum. 
\q1  
\v 4 Wagki Tuke Pujuuwai dekas múuntak, 
\q1 ima nigki eme anentsa kantamjam amainuk. 
\q1 Niyai tikich apajuímtai aina 
\q1 nuna nagkaesau ishamain. 
\q1  
\v 5 Tikich aents aidaun apajuímtaiji aina duka 
\q1 wainak ainawai; 
\q1 tuja Tuke Pujuuwai nayaimpin najanauk. 
\q1  
\v 6 ¡Apajuín tsaaptinjiya duka jiin utsumakui! 
\q1 ¡Nii pujamujiya nuwig niina senchiji, 
\q1 pegkegmajiya nujai awai! 
\b  
\q1  
\v 7 Ashí nugkanmaya aidautijum: 
\q1 “Ameketme senchigtinum, 
\q1 ameketme pegkegmamek”, 
\q1 tusajum Tuke Pujuu ememattajum. 
\q1  
\v 8 Tuke Pujuu anentag susatin jukijum, 
\q1 nii jega nuna agájin ikaunmajum, 
\q1 tikishmaja pujusjum Apajuí etsagjatajum. 
\q1  
\v 9 Apajuí jee pegkegma nuwi 
\q1 wayajum etsagjatajum. 
\q1 ¡Ashí nugkanmaya aidauk 
\q1 amina ishamjamainak kujaitnume! 
\q1  
\v 10 Ashí aents nugkanmaya aidau chichagkujum: 
\q1 “¡Tuke Pujuuwai iina apujiya duka! 
\q1 Nugkanak jasa buchittsuk asatnun nii najanauwai, 
\q1 tuja ashí aents aidaunak 
\q1 nii inak betek diyakui. 
\q1  
\v 11 ¡Nayaim aidaush, tuja nugkashkam 
\q1 shiig aneastinme! 
\q1 ¡Tuja nayantsashkam, 
\q1 tikich namak múun aidaujai 
\q1 shiig aneenak uuttinme! 
\q1  
\v 12 ¡Tuja nugkashkam, 
\q1 nunú nugkanum batsamin aidaujaí 
\q1 shiig aneastinme! 
\q1 ¡Tuja numi ikam ayaushkam shiig aneenak, 
\q1  
\v 13 juju nugka juwi inamjatin 
\q1 mina nuna emtin pampaitnume! 
\q1 ¡Tuke Pujuu dekas 
\q1 iina nugken inamjatatus taattawai! 
\q1 Nunik taa aents aidau takasbaujin 
\q1 diijus etegjattawai.” 
\c 100  
\s1 Apajuí iina najapauwa duwi niinu ainaji 
\d See taku kantamtai 
\q1  
\v 1 Ashí nugkanmaya aidautijum 
\q1 shiig aneasjum Apajuí kantamjuatajum. 
\q1  
\v 2 Shiig aneasjum 
\q1 Tuke Pujuu etsagjatajum. 
\q1 ¡Shiig aneasa untsumkujum 
\q1 Apajuí jee pegkegma nuwi minitajum! 
\q1  
\v 3 ¡Tuke Pujuuwapi dekas apuk titajum! 
\q1 Iinak nii najapauwai, nuadui iik niinu ainaji. 
\q1 ¡Niina aentsji ainag duwi, 
\q1 aents uwigjin kuitamama numamtuk 
\q1 kuitamjamui! 
\q1  
\v 4 Nuadui Apajuí jee pegkegma 
\q1 nuna waitijin kaunajum, 
\q1 Apajuí see takujum niina daaji pachisjum 
\q1 kantamtai kantamkujum ememattajum. 
\q1  
\v 5 Wagki Tuke Pujuuk dekas pegkejai, 
\q1 tuja niina anenkajishkam tuke auwai, 
\q1 antsag nii anagkagtuamujig 
\q1 makichkish yapajinchauwai. 
\c 103  
\s1 Ashí mina senchigjai Apajuínak ememattajai 
\d David kantamamu 
\q1  
\v 1 Ashí mina anentaigjai 
\q1 Tuke Pujuun emematkun 
\q1 pegkegnum chichagtinaitjai; 
\q1 niina daaji pegkegma nuna 
\q1 pachisan ashí mina senchigjai 
\q1 pegkegnum chichagtinaitjai. 
\q1  
\v 2 Ashí mina wakanjujai 
\q1 Tuke Pujuun emematkun 
\q1 pegkegnum chichagtinaitjai; 
\q1 tuja nii mina yainkauwa nunak 
\q1 makichkish kajimatkishtinaitjai. 
\q1  
\v 3 Niyai mina tudaujun tsagkugtauk; 
\q1 nigki wi jaaku pujaish etsaentinuk. 
\q1  
\v 4 Tuja jamainnum jeganta aish, 
\q1 niyai mina uwemtijinuk. 
\q1 Tuja nigki niina anejattaijiya nuna 
\q1 mina anentaijui suja duka. 
\q1  
\v 5 Niig ashí pegkeg aina nuna sujawai. 
\q1 Tuja wi múuntuch wajasan pujaish, 
\q1 nii minak ataktu senchimtijua 
\q1 ukukui yakí nanamama iman etawai. 
\q1  
\v 6 Tuke Pujuuk, pegkegma iman asa, 
\q1 aents waituidaunash yaigka 
\q1 agkanmitkawai. 
\q1  
\v 7 Moisés Israel aents aidaujai 
\q1 dutikatnun, tuja dita umikagtinun 
\q1 aatus Apajuí jintintuauwai. 
\q1  
\v 8 Tuke Pujuuk kakagchauch 
\q1 wait anenkagtinai; 
\q1 wamak kajechui, 
\q1 tuja anentak wajasui. 
\q1  
\v 9 Apajuík jiyajatu pujuchui; 
\q1 tuja kajegkagtukbaujish tukek achauwai. 
\q1  
\v 10 Ii pegkegchau takamtaijin 
\q1 shiig kuashat suwimak jumain ajinig, 
\q1 imatikagkesh amaschauwai. 
\q1  
\v 11 Niina umijin aidaunak Apajuík 
\q1 nayaim múun nagkatkachua nuni 
\q1 nagkaemas aneawai. 
\q1  
\v 12 Etsa jiintaijiya nuna 
\q1 etsa akaetaijiya nujai 
\q1 atushat akankauwa numamtuk, 
\q1 iina tudaujinak atushat datupajui. 
\q1  
\v 13 Tuke Pujuuk niina umijuina nunak, 
\q1 makichik múun uchijin shiig anentus 
\q1 kuitamama imatikas kuitamui. 
\q1  
\v 14 Wagki iish wajiyai najanamuitji 
\q1 nunak nii dekawai; 
\q1 iik nugka yukukuntujai najanamuitji, 
\q1 nuna nii shiig dekawai. 
\b  
\q1  
\v 15 Aentsu pujutjiya duka 
\q1 dupajai betekmamtinai; 
\q1 dupa tsapai yagkujuwama numamtuk wajawai. 
\q1  
\v 16 Tuja yagkugnak dase dasentak umpui utsauwame, 
\q1 dutikamu asamtai, ataktu awagkik wainchataiyai. 
\q1  
\v 17 Untsu Tuke Pujuu anenkega duka 
\q1 niina umijin aidaunmak 
\q1 megkaekashtinun tuke atinai. 
\q1 Nuadui, nuna uchiji wegantu aidaunash, 
\q1  
\v 18 tuja ditajai chicham umikbauwa nuna 
\q1 betek umidaun, nuigtu diez chicham umiktin 
\q1 agagbaun kajimattsuk umidaun 
\q1 aatus tuke yaigtinai. 
\q1  
\v 19 Tuke Pujuun pujusa inamtaijiya duka 
\q1 nayaimpinum awai; 
\q1 nuwi ekemas ashí nugkanum inamui. 
\b  
\q1  
\v 20 ¡Nayaimpinmaya aents ángel senchigtin, 
\q1 Apajuí chichame umijin, 
\q1 tuja nii inapakui umiktasajum 
\q1 batsamin aidautijum 
\q1 Tuke Pujuu ememattajum! 
\q1  
\v 21 ¡Atum niina suntaji aidautijum nii takajin, 
\q1 tuja nii inapamu betek umijin aidautijum 
\q1 Tuke Pujuu ememattajum! 
\q1  
\v 22 ¡Tuja Apajuí najankamu 
\q1 ashí nugkanum batsamin aidautijum 
\q1 Tuke Pujuu ememattajum! 
\q1 Tuja wishakam ashí mina wakanjujai 
\q1 Tuke Pujuun ememattajai. 
\c 104  
\s1 Apajuí emematbau 
\q1  
\v 1 Ashí mina wakanjujai Tuke Pujuun 
\q1 emematkun pegkegnum chichagtinaitjai. 
\q1 ¡Tuke Pujuu mina Apajuíjuh, 
\q1 amek dekas múuntaitme! 
\q1 Tuja amek amina imanjumea nunú ijiam, 
\q1 etsanjam pujame. 
\q1  
\v 2 Amek dekas tsaaptin ijimakume. 
\q1 ¡Ame nayaimpia duka 
\q1 jáanchjai betek ejauwaitme! 
\q1  
\v 3 Dutikam yaki nayaimpinum 
\q1 ame pujustinjum umikuitme. 
\q1 Amina carrogmin yujagminum 
\q1 egkemkam wekaeme. 
\q1 ¡Amina nanapjumin 
\q1 dasenum nanaakam wekaeme! 
\q1  
\v 4 Dase aina duka ame iname, 
\q1 ame nunikti tama jiishkam kegawai. 
\q1  
\v 5 Apajuík nugkanak nigki 
\q1 buchitmainchaun najanauwai; 
\q1 nuadui makichkish umuchmainchau atinai. 
\b  
\q1  
\v 6 Ame nayants pimumtikjam 
\q1 nugka yutuabiume, 
\q1 dutikakum ashí muja 
\q1 múun tsakaku aidaush yutuabiume. 
\q1  
\v 7 Imanikmataish, 
\q1 kuyua buku wajasti timayume, 
\q1 tusa tabaugmin amina chichamjumin 
\q1 ipamtajai betek antuk wamak kuyuabi. 
\q1  
\v 8 Nuadui, yumi piyag 
\q1 muja aidaun amuja auk, 
\q1 wake aidaunum akaiki, 
\q1 ame nuwi ijumnagti tibaunak imanisag 
\q1 nuwi ijumnajui. 
\q1  
\v 9 Nunikmatai ataktu pimak 
\q1 nugkan utujai tusam, 
\q1 juwig nagkankati, nuwi nagkama 
\q1 pima pimakuag wechati tiuwaitme. 
\q1  
\v 10 Untsu yumi mujanum pukuni jiinki, 
\q1 entsa najanea pakajin jegak, 
\q1 namak múun wajasti tusam idaime. 
\q1  
\v 11 Nunú yumin kuntin ikamia aidau 
\q1 burro ikamia aidaujai kitamainak 
\q1 umin ainawai. 
\q1  
\v 12 Nunú namaka yantamen numi ayaunum, 
\q1 nuna kanawen chigki aidau pasugmak petsainak, 
\q1 shinuinamu antunawai. 
\q1  
\v 13 Tuke Pujuuwah, amek 
\q1 nayaimpinum pujusam yumi yutumtijam, 
\q1 ikam ukatkam pegkeg emame; 
\q1 tuja amina anenkagmea nunú 
\q1 nugkanak shiig anemtikui. 
\q1  
\v 14 Apajuí dupanak tsapapitkawai, 
\q1 kuntin nuna yuu aidau 
\q1 yuwatnume tusa, 
\q1 tuja ajak aidaunashkam 
\q1 tsapapitkawai, nunú nejekmatai 
\q1 aents aidau yuwatnume tusa. 
\q1  
\v 15 Tuja pagkan yuwa ichichmamtain, 
\q1 tuja vino uwaja shiig aneastinun, 
\q1 nuigtu aceite kugkuin yapinum 
\q1 nijamtain aatus ashí umikui. 
\q1  
\v 16 Tuke Pujuu numi najankamua duka 
\q1 yumi uchupiam shiig ijunui, 
\q1 tuja Líbanonmaya setug aidaun 
\q1 nii tsapapitkakua dushakam, 
\q1 yumi yutak nugkan uchupiau asamtai 
\q1 shiig ijunui. 
\q1  
\v 17 Nuna kanawe aidaunum 
\q1 chigki aidau pasugmak petsainawai; 
\q1 nuwi pishak cigueñashkam pujawai. 
\q1  
\v 18 Tuja muja tsakaku aina duka 
\q1 cabra ikamia aidau batsamtai ainawai; 
\q1 untsu kaya múun aina duka 
\q1 wapujushan uumka batsamtai ainawai. 
\b  
\q1  
\v 19 Apajuí nantunak najanauwai, 
\q1 wajupa nantuk weawa tusa dekatnun; 
\q1 tuja tsawan dekapa dekatain etsan najanauwai. 
\q1  
\v 20 Etsa akaetaik kiyawai, 
\q1 nunikmatai kashi kuntin 
\q1 ikamia aidau jiinag yujawai. 
\q1  
\v 21 Tuja león aidaushkam kashi jiinag, 
\q1 dita yumainji atsutai shinuinawai, 
\q1 Apajuín segainak. 
\q1  
\v 22 Untsu tsawak etsa jiintai, 
\q1 dita waajin akuumag megkagainawai. 
\q1  
\v 23 Tsawan tsawagmatai, 
\q1 aents aidau takatjin jiintukiag, 
\q1 takai takainakua agkutai ukuinawai. 
\q1  
\v 24 ¡Tuke Pujuuwah, 
\q1 amek shiig kuashat najankauwaitme! 
\q1 Tuja ashí duka 
\q1 amina yachagmijai umikuitme. 
\q1 ¡Nugka ame najanamua 
\q1 nuwig ashí ame najankamu aina nunú batsatui! 
\q1  
\v 25 Diisia ame najanamu 
\q1 nayants shiig múun, 
\q1 nuwig kuntin múun aidau, 
\q1 kuntin piipich aidau shiig kuashat 
\q1 makichkish dekapamainchau ayawai. 
\q1  
\v 26 Nuwi yujawai lancha múun aidau; 
\q1 tuja nuwi semagkau múun 
\q1 najanawaitam nunú 
\q1 shiig aneak wasugkamui. 
\q1  
\v 27 Nunú aidauk ashí 
\q1 amina dakagmainawai, 
\q1 wajutik yutainash amasat tusag. 
\q1  
\v 28 Nuadui ame dita yuwatnuk suwame, 
\q1 dutikam jukiag shiig yuwinawai. 
\q1  
\v 29 Untsu ame uumjukmak, 
\q1 senchi ishamainawai; 
\q1 tuja ame mayatut jujamshakam jawai, 
\q1 nunik iyashig yukukuntu najaneawai. 
\q1  
\v 30 Tujash ame Wakanim suwamak 
\q1 ashí nugkanmaya aents aidauk 
\q1 yamajam pujutan juwinawai. 
\q1  
\v 31 ¡Tuke Pujuu imanjiya duka tuke auwai! 
\q1 ¡Tuke Pujuuk nii najankamujin diisa shiig aneawai! 
\q1  
\v 32 Tuja Apajuí diyamak nugkak kujawai, 
\q1 untsu muja aidauk 
\q1 Apajuí antiamak bukuituinawai. 
\q1  
\v 33 Wi eke iwaku pujuttag nuaduik 
\q1 Tuke Pujuun, mina Apajuíjun emematkun 
\q1 kantamtain kantamjuattajai. 
\q1  
\v 34 Tuja Tuke Pujuu wi anentaibaujua 
\q1 nuna shiig aneas diigtusti, 
\q1 wagki minak niyai shiig aneamujuk ajutui. 
\b  
\q1  
\v 35 ¡Aents pegkegchaun takau aidau 
\q1 Apajuí ememattan dakituidauk 
\q1 ashí jinawag megkaejatnume! 
\b  
\q1 ¡Ashí mina wakanjujai Tuke Pujuun emematkun 
\q1 pegkegnum chichagtinaitjai! 
\q1 ¡Yajauwajah! Tuke Pujuun daaji ememattai ati. 
\c 105  
\s1 Apajuí Israel aents aidaun yaigbau 
\q1  
\v 1 ¡Tuke Pujuu see titajum! 
\q1 ¡Niina daaji pachisjum 
\q1 aents aidau ujaktajum! 
\q1 Dutikakjum nii takatji 
\q1 tikich nugkanmaya aidaush ujaktajum. 
\q1  
\v 2 Apajuí wainchatai aidaun 
\q1 iwainajua nunú anentaimtusjum, 
\q1 kantamtai kantamjuatajum. 
\q1  
\v 3 Niina daaji pegkegma nunú 
\q1 anentaimtusjum eme anenmamtajum. 
\q1 ¡Tuke Pujuun umijin aidautigmek, 
\q1 shiig aneastajum! 
\q1  
\v 4 Ashí tsawantai Tuke Pujuu egaktajum, 
\q1 nuniakjum niina senchijiya nunú segatajum. 
\q1 ¡Tuké Apajuí egaktajum! 
\q1  
\v 5-6 Apajuí ii aidautin, tuja niina inake Abraham, Jacob aajaku aina 
\q1 nunú wegantu aidaun etegjauwa nuna, 
\q1 ayamjak wainchatai ishamain aidaun 
\q1 iwainajua nunú anentaimtustajum. 
\q1 Tuja chicham umiktin agagbauwa 
\q1 dushakam adeagtajum. 
\q1  
\v 7 Niyai Tuke Pujuu, iina Apajuíjiya nunú; 
\q1 niyai ashí aents aina nuna apujig. 
\q1  
\v 8 Kuashat mijan nagkaemataish, 
\q1 nuna dutikatjai tusa anagkagtuamujinak 
\q1 Apajuík tuke kajimatkishtinai. 
\q1  
\v 9 Nunak Abrahamjai umikua nuna, 
\q1 Isaakjaishkam ataktu umikui. 
\q1  
\v 10 Nuna Jacobjaishkam umikui, 
\q1 tuja nunú tuke asatin 
\q1 Israel aents aidaunum juwakui. 
\q1  
\v 11 Nuadui Apajuí niina chichajak: 
\q1 “Wi nugka Canaágnak amastajai, 
\q1 aminu tuke atina nuna”, tiuwai. 
\q1  
\v 12 Israel wegantu aidauk 
\q1 ujumchik aajaku aina duwik 
\q1 nugkenchau asag, 
\q1 Canaán nugkanmak ijagjai betek 
\q1 wainak yujajaku ainawai. 
\q1  
\v 13 Nunidau asag, 
\q1 tikich nugkanum shiyakag, 
\q1 nuwi batsamas, nuna ukuinak 
\q1 tikich apu aidau batsatbaunum jegawag, 
\q1 nuwi ujumchik tsawan pujusag, 
\q1 waja yujayanume. 
\q1  
\v 14 Tujash Apajuík 
\q1 waitkastinme tusag idaisachmayi, 
\q1 nuadui ditan ayamjak 
\q1 apu aidaun suwimkan susabi. 
\q1  
\v 15 Nuadui apu aidaun chichajak: 
\q1 “Mina aentsug wi etegjamu aina duka, 
\q1 tuja mina chichamjun etsejin aidaushkam 
\q1 makichkish waitkasaigpajum”, tiuwai. 
\b  
\q1  
\v 16 Tuja Canaán nugkanum 
\q1 Apajuí ajak aidaun ashí ijinabi, 
\q1 dutikamu asa nujan tepeabi. 
\q1  
\v 17 Tujash eke nujan tepeatsaig, 
\q1 Apajuí Josén emtika Egipto nugkanum 
\q1 awemauwai, dita yachi aidau 
\q1 wainka inataijai betek sujukajua nuna. 
\q1  
\v 18 Dutikam Egipto nugkanum jegamtai, 
\q1 Josénak jijui dawenum jigkajag 
\q1 jukiag aents achika egketainum 
\q1 egkeawagmayi. 
\q1  
\v 19 Tuja José kajamjamuji uminkati tusa, 
\q1 Tuke Pujuu niina dekapeak 
\q1 kuashat tsawan waitkastinme tiuwai. 
\q1  
\v 20 Nunik waitu pujaun, 
\q1 Egipto nugkan apuji José jiiktajum tusa 
\q1 inamjamtai jiikiagmayi, 
\q1 dutika agkanmitkabi. 
\q1  
\v 21 Dutika jiiki niina jeen apuji ema, 
\q1 nuigtu niinu aidau Egipto nugkanum ayaunak ashí diisti tusa niina idaitusui. 
\q1  
\v 22 Tuja nuigtushkam apu atuwe aidaun, 
\q1 tuja tikich apu aidaunashkam 
\q1 nigki jintintua unuinakti tusa idaitusui. 
\q1  
\v 23 Nunikbaunum Jacob Israel daagtin 
\q1 aajakua nunú Egipto nugkanum jegauwai. 
\q1 Nunik jegaa tikich nugkanmayayaitak 
\q1 Cam nugkanum pujusui. 
\q1  
\v 24 Nunik pujusmatai, Apajuí 
\q1 nii aentsji aidaun kuashat uyujkauwai, 
\q1 dutika niina shiwaaji aidaun 
\q1 nagkaesau senchigtin emauwai. 
\q1  
\v 25 Tujash egiptunmaya aidau 
\q1 Israel aents aidaun kajejiagti, 
\q1 dutikainak tsanujagtinme tusa 
\q1 Apajuí tsagkamkauwai. 
\b  
\q1  
\v 26 Tuja kuashat waitkagtai, 
\q1 Apajuí niina inake etegkamujin Moisésan Aarógjai 
\q1 Egipto nugkanum awemauwai. 
\q1  
\v 27 Nuadui Apajuí senchijin 
\q1 wainchatai ishamain aidaun Egipto nugkanum, Cam nugkanum iwainakajui. 
\q1  
\v 28 Tuja Egipto nungkak ashí suwe wajasti tusa 
\q1 Apajuí suwe emabi. 
\q1 Nuna wainainayatak 
\q1 egiptunmaya aents aidauk, 
\q1 Apajuí chichamenak 
\q1 antugkachaju ainawai. 
\q1  
\v 29 Tuja yumi aidaunak ashí numpa awajtusui; 
\q1 imanikmatai, namak aidaushkam jinawajui. 
\q1  
\v 30 Takash aidaunashkam, 
\q1 ashí yaaktanum piyakti, 
\q1 nuniak apu pegajinish 
\q1 tuja nii ekemtaijinish utsaniag 
\q1 waitkasti tusa ishitkabi. 
\q1  
\v 31 Apajuí nunikti timatai, 
\q1 anchi teteejai pachimnag, 
\q1 yujagkim wajukama imanik 
\q1 Egipto nugkanak akijuawabi. 
\q1  
\v 32 Tuja yumin yutumtiktsuk, 
\q1 bicha kaya iman najaneaku 
\q1 jiijai pachimag nayaimpinmayan 
\q1 Egipto nugkanum yutumtikjabi. 
\q1  
\v 33 Nunú yutak uva ajakbau aidaun, 
\q1 higo aidaunash ijinabi. 
\q1 Dutikak numi kanawe 
\q1 aidaunashkam ashí kupijabi. 
\q1  
\v 34 Tuja Apajuí ataktushkam nunikti tusa timatai, 
\q1 manchi aidau shiig kuashat kaketukmayi. 
\q1 ¡Shiig kuashat asa dekapatash dekapamaichabi! 
\q1  
\v 35 ¡Imaniau asa ajak ajanum ayaunak, 
\q1 tuja dupa aidaunak ashí amukagmayi! 
\q1  
\v 36 ¡Dutiksag egiptunmaya aents aidaun 
\q1 uchiji iwai aidaunashkam ijituabi! 
\q1  
\v 37 Dutika nuadui, 
\q1 iina muunji aidaunak Apajuí 
\q1 oro aidaun, tuja plata aidaun 
\q1 aatus uyumitkak jiigmayi. 
\q1 Nunik shimakush Israel aents aidauk 
\q1 makichik kayanakesh tukumkachagmayi. 
\q1  
\v 38 Nunik shimiagtai, egiptunmaya aidauk 
\q1 ishamkagtu batsatu asag, 
\q1 shiig aneasaju ainawai. 
\q1  
\v 39 Dutika jiija yujagmin awetiuwai, 
\q1 niina aentsji aidaun ejakti tusa; 
\q1 tuja dutiksag kashi diisag 
\q1 shiyaktinnashkam jii kegaun awetiuwai. 
\q1  
\v 40 Tuja yumainji atsujam yapajuinak sumagtaish, 
\q1 codornisan ishitkabi; 
\q1 tuja nayaimpinmaya yutai susam 
\q1 nuna yuwawag ejemajag 
\q1 shiig aneasagmayi. 
\q1  
\v 41 Tuja Moisés kayan awatmatai, 
\q1 kayanmaya yumi jiinkibi, 
\q1 nunik entsajai betek wajas 
\q1 uwegshunum akaikibi. 
\q1  
\v 42 Apajuí yaunchuk Abrahaman 
\q1 anagkuamunak betek umikmayi. 
\b  
\q1  
\v 43 Aatus Apajuí niina aentsji aidau 
\q1 Egipto nugkanum batsatun jiigmayi. 
\q1 Dutikam aents aidauk 
\q1 shiig aneenak untsumiagmayi. 
\q1  
\v 44 Dutika yajuak nugka 
\q1 tikich aents aidau batsamtain susabi, 
\q1 dutikak ajak tikich aents aidau 
\q1 ajakbau aidaunashkam susabi. 
\q1  
\v 45 Nunak Apajuí dutikauwai, 
\q1 juwi batsamas chicham umiktin agagbauwa nuna umiktinme tau asa. 
\q1 ¡Yajauwajah! Apajuí emematiagmi. 
\c 107  
\ms1 LIBRO V 
\mr (Salmos 107—150) 
\s1 Apajuíyai pimpiki wake besemag pujajinish yaijatnuk 
\q1  
\v 1 Tuke Pujuu see titajum, 
\q1 wagki niyai pegkejak, 
\q1 niina anenkajig tuke auwai. 
\q1  
\v 2 Iina shiwaaji aidau inaku 
\q1 waitkatai batsatutin Tuke Pujuu 
\q1 niina senchijijai jiigmag 
\q1 agkanmitkagmabi titajum. 
\q1  
\v 3 Dutijama etsa jiintai, etsa akaetai, 
\q1 nujinum, tsumunum batsamin 
\q1 aidautin yajupak ijupagmayi. 
\q1  
\v 4 Tuja iina muunji aajakajua duka, 
\q1 wainak megkagag uwegshunum yujajakui, 
\q1 yaakat dita batsamainun 
\q1 wainainachu asag. 
\q1  
\v 5 Nuninak nujantai, kitakai 
\q1 ashí jinawag yujagmayi. 
\q1  
\v 6 Nunik waituinak Tuke Pujuun 
\q1 yaijatkata tusag segagmayi, 
\q1 nuna nii antujuk, dita 
\q1 waitiamujin yaigka agkanmitkabi. 
\q1  
\v 7 Dutika jintintua dita 
\q1 shiig batsamsatnunum ejegawagmayi. 
\q1  
\v 8 Nuadui Tuke Pujuu emematiagmi, 
\q1 niina anenkajin iina ayamjutpak 
\q1 ishamain wainchatai aidaun iwainajua, 
\q1 nunú pachisaja. 
\q1  
\v 9 Wagki Apajuíyai aents kitakai jaunash, 
\q1 tuja nujantai jaunashkam suwa duka. 
\b  
\q1  
\v 10 Tuja iina apachji aajakajua duka, 
\q1 inaku waitkainam pimpikiag 
\q1 wake besemag pujuagmayi. 
\q1  
\v 11 Nunak Tuke Pujuun shiwagmainak, 
\q1 chicham umiktinun susauwa nunash 
\q1 uminachu asag nunikajui. 
\q1  
\v 12 Nuadui Apajuí suwimak susam 
\q1 shiig senchi waitujakajui, 
\q1 dita yaimainuk makichkish 
\q1 atsugsamu asa. 
\q1  
\v 13 Nunik waituinak Tuke Pujuun 
\q1 yaijatkata tusa segagmayi, 
\q1 nuna Apajuí antujuk, dita 
\q1 waitiamujin yaigka agkanmitkabi. 
\q1  
\v 14 Dutika senchi inainaku waitkam batsatun 
\q1 agkanmitkabi. 
\q1  
\v 15 ¡Tuke Pujuu anenkega nunú see titajum, 
\q1 wagki nii jutiin ayamjutpak 
\q1 kuashat wainchatai ishamain 
\q1 aidaun iwainajua nuadui! 
\q1  
\v 16 ¡Waiti bronce najanamunash, 
\q1 tuja jiju awajamu aidaujai, 
\q1 Apajuí ashí tsaikui! 
\q1  
\v 17 Tuja iina apachji aidauk anentainkachu asag, 
\q1 dita pegkegchaujin jata achikam 
\q1 senchi waitiagmayi. 
\q1  
\v 18 Nunik jinuinak yujumkan tsumainak 
\q1 yutsuk, nujantai ashí jinaa batsabi. 
\q1  
\v 19 Nunik waituinak Tuke Pujuun 
\q1 yaijatkata tusa segagmayi, 
\q1 nuna Apajuí antujuk, 
\q1 dita waitiamujin yaigka agkanmitkabi. 
\q1  
\v 20 Ashí niina chichamenig etsagakmayi. 
\q1 ¡Aatus ashí jinaa batsatun uwemtikjabi! 
\q1  
\v 21 Tuke Pujuun anenkega nunú see titajum, 
\q1 wagki nii jutiin ayamjutpak, 
\q1 kuashat wainchatai ishamain aidaun 
\q1 iwainajua nuadui. 
\q1  
\v 22 Apajuí yaimpakua nunú anentaimtusjum, 
\q1 see takujum kuntin maa apeatajum, 
\q1 dutikakjum nii dutikamuji pachisjum 
\q1 shiig aneasjum senchi 
\q1 untsumkajum etsegkatajum. 
\q1  
\v 23 Iina apachji aajaku aina nunú 
\q1 lanchanum nayants shiyaku aidauk, 
\q1 nayantsa amain tikich nugkanum 
\q1 wajiin sujak yujau ainawai. 
\q1  
\v 24 Ibau nayants muunnum yujasag, 
\q1 junak dekas Tuke Pujuuwap najanauwaita 
\q1 tusa dekawajui. 
\q1  
\v 25 Apajuí chichakmatai, 
\q1 dase ishamain iyagmayi, 
\q1 imaniak nayantsan shiig senchi 
\q1 tsukatmitkabi. 
\q1  
\v 26 Imatikak lanchanak 
\q1 yaki ema ema ajuibi. 
\q1 ¡Imaniau asamtai, 
\q1 ayamjumamainchau dekapiagmayi! 
\q1  
\v 27 Nuninak nampekujai betek 
\q1 winchainag tukumak iyainiagmayi. 
\q1 Imaaninak lanchanum 
\q1 yujatan yacha ainayatak 
\q1 dutikmainchau dekapiagmayi. 
\q1  
\v 28 Imanitai ishamainak 
\q1 Tuke Pujuun segagmayi, 
\q1 tusa segam antujuk yaigka uwemtijabi. 
\q1  
\v 29 Dutikak dase ishamain wajak 
\q1 nayantsan tsukatmitkaunak imijakmayi. 
\q1  
\v 30 Nunik mijakmatai, shiig aneasagmayi, 
\q1 tuja Apajuí ditanak yajuak 
\q1 dita jegatag tibaunum ejegauwai. 
\q1  
\v 31 ¡Tuke Pujuu anenkega nunú see titajum! 
\q1 Wagki nii jutiin ayamjutpak, 
\q1 kuashat wainchatai ishamain aidaun 
\q1 iwainajua nuadui. 
\q1  
\v 32 ¡Ashí aents aidautijum ijunjajum 
\q1 Apajuí ememattajum! 
\q1 Tuja Israel aents aidaun apuji 
\q1 múun aidautigmesh ijunjajum 
\q1 Apajuí ememattajum. 
\b  
\q1  
\v 33 Apajuík namak múun aidaunash 
\q1 ukuya uwejush emawai, 
\q1 tuja yumi pukuni jiinunash 
\q1 ukuya buku emawai. 
\q1  
\v 34 Tuja nugka ajak shiig tsapaunash, 
\q1 nuwiya aents aidau tudaujin 
\q1 ajak tsapachu emawai. 
\q1  
\v 35 Uwejush yumi atsaunash 
\q1 kucha ain emawai, 
\q1 dutikak nugka buku ataish, 
\q1 yumi pukuni jiinin emawai. 
\q1  
\v 36 Tuja aents nujantai waituidaunak 
\q1 yajuak nuwi batsawai, 
\q1 dutikam nuwi dita batsamsatnun 
\q1 yaaktan najanainawai. 
\q1  
\v 37 Nuwi batsamas uva ajakag 
\q1 kuashat nejekun juuka yuwinawai. 
\q1  
\v 38 Apajuí ditanak yayawai, 
\q1 tuja dita tagkuji aidaunashkam 
\q1 kuashat ikauntawai. 
\q1  
\v 39 Untsu tikich aidauk 
\q1 kuashat waitkainamu asag, 
\q1 ujudauch ainawai. 
\q1  
\v 40 Tuja Apajuík aents pegkegchau 
\q1 waitkagkagtin aina nunak kajejawai. 
\q1 Nuadui ditanak uwegshunum wainak yujas 
\q1 jinaati tusa idaisauwai. 
\q1  
\v 41 Tuja aents ujudauch 
\q1 wake besemag pujaunash 
\q1 nii agkanmitkawai. 
\q1 Dutika nii uchijinak 
\q1 tagkujai betek kuashat uyujtawai. 
\q1  
\v 42 Nuna aents Apajuí umijin aidau 
\q1 diisag shiig anenawai. 
\q1 Untsu aents pegkegchau aidauk 
\q1 datsaamainak ataktuk tumainchau 
\q1 dekapenawai. 
\q1  
\v 43 Aents shiig anentaimkauk juna anentaimas diisti. 
\q1 Nuniak Tuke Pujuun anenkega nuna dekattawai. 
\c 110  
\s1 Apajuí apunak senchimtiknai 
\d David kantamamu 
\q1  
\v 1 Tuke Pujuu mina apujun chichajak: 
\q1 “Mina untsujui ekemsata, nunikamin 
\q1 wi amina shiwaajum aidaunak depetkan 
\q1 aminí ikaunmakmatai, 
\q1 ame inagminum”, tiuwai. 
\q1  
\v 2 Jerusalégnum pujusa inamjati tusa 
\q1 Tuke Pujuu amina umigtamkae. 
\q1 Tuja amina shiwaajum aidaunak nii depeteawai. 
\q1  
\v 3 Ame apu wajasamin, 
\q1 amina aentsjum aidau shiig aneas kaunawag, 
\q1 ame tabau umikmi tusa tujabiagtin ainawai. 
\q1 Tuja amek kashikmas 
\q1 jegashjuk tsawauwama numamtuk, 
\q1 kashi kashinig yamajam senchi jutatme. 
\q1  
\v 4 Tuke Pujuu nii umiktinjin 
\q1 yapajinashtinun chichaak: 
\q1 “Ametme sacerdote Melquisedec aajakua 
\q1 nujai betek tuke sacerdote atinmek”, tiuwai. 
\b  
\q1  
\v 5 Apajuík amejaig pujawai amina yaimpaktatus. 
\q1 Makichik tsawantai nii kajeka 
\q1 apu aidaunak ijinattawai. 
\q1  
\v 6 Aents aidaun suwimkan susa ijinatnai, 
\q1 dutikam ashí nugkanmak 
\q1 aents jinauk tuwasua weaku atinai. 
\q1 ¡Nugka múun aidaun 
\q1 apuji aidaunash ashí ijinatnai! 
\q1  
\v 7 Depetmak jintá minis 
\q1 yumi entsanmayan uwagtinai; 
\q1 nunik ataktu ichichmamjatnai. 
\c 115  
\s1 Iina Apajuíjig nayaimpinum pujawai 
\q1  
\v 1 Tuke Pujuuwah, jutiik eme anenkagtusaipa, 
\q1 dekas ima amek eme anenmamta, 
\q1 amina anenkagmin, 
\q1 tuja dekaskegmijai eme anenmamta. 
\q1  
\v 2 Wagkag aents pegkegchau aidaush 
\q1 jutiin chichagtamainakush ¿tuwi pujawa 
\q1 atumi Apajuígmesh, tusash tujamiajainta? 
\q1  
\v 3 Iina Apajuíjig nayaimpinum pujawai, 
\q1 tuja nii wakegamu aidaun ashí najankauwai. 
\q1  
\v 4 Aents pegkegchau aidau 
\q1 apajuímtaijig oro, plata ainawai. 
\q1 Tuja duka aents najankamu ainawai. 
\q1  
\v 5 Dita apajuímtaijig weni ajamaitak 
\q1 chichachu ainawai; 
\q1 jiishkam ajamaitak wainmachu ainawai. 
\q1  
\v 6 Kuwishish ajuidau, tujash antuchu; 
\q1 nujintin, tujash mayatchau; 
\q1  
\v 7 uwegtin aidau, tujash achimchau; 
\q1 nawentin aidau, tujash wekaechau; 
\q1 ¡makichik chichamujigkesh 
\q1 antugchatai ainawai! 
\q1  
\v 8 Nuniau asamtai aents nuna najanin, 
\q1 tuja nunú dakumka najanamua 
\q1 nuna emematin aina duka 
\q1 dita apajuímtaijijai betek ainawai. 
\b  
\q1  
\v 9 ¡Israel aents aidautigmek, 
\q1 Tuke Pujuuwaig kajinmamsa anentaimsatajum! 
\q1 Wagki nii jutiinak yaimpawai, 
\q1 tuja nigki kuitamjamui. 
\q1  
\v 10 Sacerdote aidautigmesh 
\q1 ima Tuke Pujuuwaig kajinmamsa 
\q1 anentaimtajum. 
\q1 Wagki nii jutiinak yaimpawai, 
\q1 tuja nigki kuitamjamui. 
\q1  
\v 11 Ashí aents Tuke Pujuu umijin aidautigmek, 
\q1 ¡Tuke Pujuuwaig kajinmamsa anentaimsatajum! 
\q1 Wagki nii jutiinak yaimpawai, 
\q1 tuja nigki kuitamjamui. 
\q1  
\v 12 ¡Tuke Pujuu iinak kajimatjamtsuk 
\q1 pegkegnum yumigtamjatnai! 
\q1 ¡Israel aents aidaunashkam 
\q1 pegkegnum yumigjatnai! 
\q1 ¡Sacerdote aidaunashkam 
\q1 pegkegnum yumigjatnai! 
\q1  
\v 13 Aents Tuke Pujuun eme anentus 
\q1 umijin aidaun: 
\q1 aents eme anentsa diishtai, 
\q1 eme anentsa diitai aidaujai 
\q1 Apajuí ashí ditanak pegkegnum yumigjatnai. 
\b  
\q1  
\v 14 Tuke Pujuu atumi uchijum aidaunash, 
\q1 tuja nuna uchiji aidaunash uyujtugmaktinai. 
\q1  
\v 15 ¡Tuke Pujuu nayaimpin, nugkajai najanauwa nunú 
\q1 aminak pegkegnum yumigtamsattawai! 
\b  
\q1  
\v 16 Nayaimpia auk Tuke Pujuunui, 
\q1 tuja nugka nuna aents aidaun susauwai. 
\q1  
\v 17 Jakau aidauk chichamainchau asag, 
\q1 Tuke Pujuunak emematmainchau ainawai. 
\q1  
\v 18 Untsu ii iwaku aidautik 
\q1 tuke ememattinaitji. 
\q1 ¡Yajauwajah! 
\q1 Iina Apajuíji ememattai ati. 
\c 116  
\s1 Apajuí see tabau 
\q1  
\v 1 Wika Tuke Pujuunak aneajai, 
\q1 wagki wi segamun antugtuku asamtai. 
\q1  
\v 2 Wagki wi segamun antugtuku asamtai, 
\q1 wi iwaku pujaknuk, 
\q1 niina tuke segatnaitjai. 
\q1  
\v 3 Jata achigkamtaimpap 
\q1 jakattaja tusan ishamkabiajai, 
\q1 nuniakun wake besemag pujubiajai. 
\q1  
\v 4 Nuniakun Tuke Pujuun segabiajai 
\q1 uwemtijugta tusan. 
\q1  
\v 5 Tuke Pujuuk pegkejam, wait anenkagtinai, 
\q1 iina Apajuíjiya duka 
\q1 kakagchauch anejatin wajasui. 
\q1  
\v 6 Tuke Pujuuk aents kakakchau 
\q1 aidaunash kuitamui. 
\q1 Wi kakaumainchau wajasan pujaishkam, 
\q1 nii minak uwemtijugmayi. 
\q1  
\v 7 ¡Yamaik shiig aneasan pujumainaitjai, 
\q1 Tuke Pujuu pegkeg etiu asamtai! 
\q1  
\v 8 Wagki Apajuí jamainun uwemtijug 
\q1 wi wake besemag buutku 
\q1 pujamugnash yaintuk uwemtijuja nuadui. 
\q1  
\v 9 Tuja iwaku juju nugka juwi pujag nuaduik, 
\q1 Tuke Pujuunak tuke umigkatnaitjai. 
\q1  
\v 10 Wika senchi waitiaknushkam, Apajuínak dekaskeapi tibaijai. 
\q1  
\v 11 Tuja wi waugtukan chichaakun: 
\q1 “Ashí aents aidauk waitjin ainawai”, 
\q1 tibaijai. 
\q1  
\v 12 ¿Tuke Pujuu mina pegkegnum 
\q1 yainkamunmash, 
\q1 wisha wajuk akimainaitja? 
\q1  
\v 13 Tuja nii mina uwemtijugbaunum 
\q1 vinon anentag Tuke Pujuun suwakun, 
\q1 niina daajin pachisan ememattajai. 
\q1  
\v 14 Wi umiktajai tusan 
\q1 Tuke Pujuun tiuwaitag nunak, 
\q1 yamai ashí niina aentsji aidau 
\q1 wainainamunum umiktatjai. 
\q1  
\v 15 Tuke Pujuuk niina umijin aina 
\q1 nunú jakamtaig, 
\q1 wake besemag dekapeawai. 
\q1  
\v 16 ¡Tuke Pujuuwah, wika amina inakmetjai! 
\q1 ¡Wika nuwa amina inakmea 
\q1 nuna uchijiyaitjai! 
\q1 ¡Ame minak achikbaujai betek 
\q1 ashí jakan pujai uwemtijugmayume! 
\b  
\q1  
\v 17 Tuke Pujuuwah, ame uwemtijugbaunum 
\q1 see takun uwija maan apeakun ememattatjame, 
\q1 dutikakun daagmin pachisan segattajame. 
\q1  
\v 18 Wi umiktajai tusan 
\q1 Tuke Pujuun tiuwaitag nunak, 
\q1 yamai ashí niina aentsji aidau 
\q1 wainainamunum umiktatjai. 
\q1  
\v 19 Yaakat Jerusalégkan ejapeen, 
\q1 Tuke Pujuu jee pegkegma 
\q1 nuna waitijin jegantatak agkaju 
\q1 ayatak shugkuk ajigmauwa nuwi nunak dutikattajai. 
\q1 ¡Yajauwajah! 
\q1 Apajuí daaji ememattai ati. 
\c 118  
\s1 Tuke Pujuu uwemtikagtugbaunum see tabau 
\q1  
\v 1 Tuke Pujuu see titajum, 
\q1 wagki niyai pegkejak; 
\q1 niina anenkajig tuke auwai. 
\q1  
\v 2 Israel aents aidauk yamaikiuch: 
\q1 “Apajuí anenkeg tuke auwai”, titinme. 
\q1  
\v 3 Sacerdote aidaushkam: 
\q1 “Apajuí anenkeg tuke auwai”, titinme. 
\q1  
\v 4 Tuke Pujuun eme anentus diin aidaushkam: 
\q1 “Apajuí anenkeg tuke auwai”, titinme. 
\b  
\q1  
\v 5 Waittanum pujusan 
\q1 Tuke Pujuun untsukbaijai, 
\q1 dutika ai, aijuk uwemtijugmayi. 
\q1  
\v 6 Tuke Pujuu wijaig pujawai; 
\q1 nuadui wika ishamkagtatsjai; 
\q1 minak makichkish pegkegchauk 
\q1 awajtumain ainatsui. 
\q1  
\v 7 Tuke Pujuu wijaig pujawai; 
\q1 nuniau asa minak nii yaintui. 
\q1 ¡Nuadui mina shiwag aidau 
\q1 mina kajegtuina nuna nii ijinamun wainkattajai! 
\q1  
\v 8 Aentsnum kajintsa anentaima wekaetsuk, 
\q1 dekas Tuke Pujuuwaig kajintsa anentaimainaitji. 
\q1  
\v 9 Apu aidaunum kajintsa anentaima wekaetsuk, 
\q1 dekas Tuke Pujuuwaig kajintsa anentaimainaitji. 
\q1  
\v 10 Tikich nugkanmaya aents aidau 
\q1 tuwagtukagmayi; 
\q1 tujash Tuke Pujuu daajin depetkamiajai. 
\q1  
\v 11 Ashí tententuawagmayi; 
\q1 tujash Tuke Pujuu daajin depetkabiajai. 
\q1  
\v 12 Etejai betek tuwagtukagmayi; 
\q1 tujash jagki ijumjamun jii apea 
\q1 emegkauwama imatikan ajapabiajai; 
\q1 ¡Tuke Pujuu daajin depetkabiajai! 
\q1  
\v 13 Ajua maami tusag shitatkiagmayi; 
\q1 tujash minak Tuke Pujuu ayamjutkabi. 
\q1  
\v 14 Wika Tuke Pujuu mina senchimtija 
\q1 nuna kantamjajai. 
\q1 ¡Niiyai mina uwemtijinuk! 
\b  
\q1  
\v 15 Aents Apajuín umijin aina nuna jenig 
\q1 shiig aneas untsumainak: 
\q1 “Tuke Pujuun senchijiya nunú depetmake”, 
\q1 titinme. 
\q1  
\v 16 ¡Tuke Pujuun senchijiya duka 
\q1 augmatkuish, makichkish ejemaitsui! 
\q1 ¡Tuke Pujuun senchijiya nunú depetmakui! 
\q1  
\v 17 ¡Jakashtatjai, iwaku pujuttajai, 
\q1 wagki Tuke Pujuu iina ayamjutpak 
\q1 dutikauwa nuna etsegkatasan! 
\q1  
\v 18 Tuke Pujuu minak shiig senchi 
\q1 suwimkan sujusmayi; 
\q1 tujash jakati tusag idaituschabi. 
\b  
\q1  
\v 19 ¡Apajuí jee pegkegma nuna 
\q1 waitiji ujatjitajum; 
\q1 nuwi wayan Tuke Pujuun see titag tajai! 
\q1  
\v 20 Juju waitiya duka 
\q1 Tuke Pujuu pujamunum waitaiyai; 
\q1 aents Apajuín nemajin aidauk 
\q1 nunú waitiya nuni wayawagtinai. 
\b  
\q1  
\v 21 Tuke Pujuuwah, see tajame 
\q1 wagki ame antugtukam uwemtijuju asamin. 
\q1  
\v 22 Kaya ekenag jegamin aidau 
\q1 kaya pegkegchauwai tusag, 
\q1 dakitjajua nunú yamai 
\q1 dekas kaya ima pegkeg atsumtai wajase. 
\q1  
\v 23 Nunak Tuke Pujuu dutikae, 
\q1 duka yamaik puyattsa diimainai. 
\q1  
\v 24 Juju tsawanta juwai, 
\q1 Tuke Pujuu iina ayamjutpakua nunú; 
\q1 nuadui ¡yamai shiig anenaku jiistamawagmi! 
\b  
\q1  
\v 25 Tuke Pujuuwah, ¡wait aneasam uwemtikagtugta! 
\q1 Tuke Pujuuwah, ¡wait aneasam yaijatkata, 
\q1 shiig batsamsagmi! 
\q1  
\v 26 ¡Tuke Pujuu awemamu mina nunú 
\q1 dekas ememattai ati! 
\q1 ¡Tuja Tuke Pujuu jee pegkegma nuwi pujusan atumin pegkegnum yumigkiajime! 
\q1  
\v 27 Tuke Pujuuk Apajuíyai. 
\q1 ¡Apajuíyai tsaaptinun sujamsauk! 
\q1 Yagkug aidau yajuaka altarnum 
\q1 ejegawagmi, dutikawaja Apajuí 
\q1 aentsji aidau nuwi batsata nunú uyuntsagmi. 
\b  
\q1  
\v 28 Amek mina Apajuíg asamin see tajame, 
\q1 nuniakun amina imanjumin emematjai. 
\b  
\q1  
\v 29 Tuke Pujuu see titajum, 
\q1 wagki niyai pegkejak; 
\q1 niina anenkajig tuke auwai. 
\c 119  
\q1  
\v 97 ¡Amina chichamjum umiktin sukagtusuitam nuna 
\q1 shiig senchi aneau asan, 
\q1 kashi kashinig nuwig anentaimjai! 
\q1  
\v 98 Nunú chicham umiktin agagbau 
\q1 umiktajum tusa sukagtusuitam nunú 
\q1 mina shiwag aidaun 
\q1 nagkaesau yachamtijawai, 
\q1 wagki nunú jintinjau asamtai. 
\q1  
\v 99 Wika nuna ausa dekau asan, 
\q1 mina jintinjin aidaun nagkaesau 
\q1 chicham umiktin agagbauwa nuwi anentaimjai. 
\q1  
\v 100 Tuja amina chichamjum umiktin 
\q1 sukagtusuitam nuna umiau asan, 
\q1 múun amina chichamjumin etsejin aidaun 
\q1 nagkaesau amina chichamjumnak dekajai. 
\q1  
\v 101 Amina chichamjumin umiktag tau asan, 
\q1 pegkegchau aina nunak idaisabiajai. 
\q1  
\v 102 Tuja ame minak jintinjau asamin, 
\q1 aminu chicham umiktina nunak idaisachmaijai. 
\q1  
\v 103 Ame umiktin anagkagtuawaitam 
\q1 nunak mina kayakmataijuig 
\q1 shiig yumintsak dekapeajai, 
\q1 tuja mina wenujui dapa yumijin nagkaesau 
\q1 yumintsak dekapeajai. 
\q1  
\v 104 Amina chichamjum umiktin 
\q1 sukagtusuitam nuwiya unuimaju asan, 
\q1 waitjut aina nunak kajejajai. 
\b  
\q1  
\v 105 Amina chichamjum agagbauwa nunú 
\q1 jii ekemakbaujai betek, 
\q1 wi weamunum tsaaptin emawai, 
\q1 tukumak iyajai tusa. 
\q1  
\v 106 Wi yaunchuk chichaakun, 
\q1 umiktajai tiuwaitag nunak, ataktushkam tajai: 
\q1 “Amina chichamem 
\q1 pegkegma nunak dekas umiktatjai.” 
\q1  
\v 107 ¡Tuke Pujuuwah, shiig pimpikin 
\q1 wake besemag pujajai! 
\q1 ¡Ataktu ichichtugta, ame chichamjum 
\q1 wajintu chichawa dutiksamek! 
\q1  
\v 108 Tuke Pujuuwah, 
\q1 wi amina emematjam nunú 
\q1 shiig aneasam jujutkita, 
\q1 nuniakum amina chichamjumia nunú jintinjuata. 
\q1  
\v 109 Wika tuké jamainnum pujajai, 
\q1 tujash ame jintinjuamua nunak kajimattsujai. 
\q1  
\v 110 Aents pegkegchau aidau, 
\q1 utugchatan apujtujuinawai, 
\q1 tujash amina chichamjum umiktin 
\q1 sukagtusuitam nunak kajimatkinuk idaitsujai. 
\q1  
\v 111 Amina chichamjum umiktina nunú 
\q1 minak tuké shiig aneasa pujutan sujawai. 
\q1  
\v 112 Wika amina chichamjum umiktin 
\q1 sukagtusuitam nunak wakejusan, 
\q1 atakea duwish tuke umiktin atajai, 
\q1 tusan tumamjai. 
\b  
\q1  
\v 129 Amina chichamjum umiktina 
\q1 duka shiig pegkejai; 
\q1 nuadui wika betek umiajai. 
\q1  
\v 130 Amina chichamjum etsegbauwa duka 
\q1 tsaaptinjai betekai; 
\q1 nuniau asa aents kakagchauchinak 
\q1 shiig dekamtikawai. 
\q1  
\v 131 Amina chichamjum umiktin sukagtusuitam 
\q1 nuna dekatasan wakegajai, 
\q1 nuniakun itugkanuk shiig dekawag 
\q1 tusa anentaimkun waitiajai. 
\q1  
\v 132 Tuke Pujuuwah, amina anempau aidau 
\q1 wait anentam dutiksamek, 
\q1 minash diigsam wait anenjugta. 
\q1  
\v 133 Amina chichamjum wajintua dutiksamek awekattsata; 
\q1 pegkegchau wagagkiti tusamek idaitusaipa. 
\q1  
\v 134 Aents pegkegchau aidau 
\q1 mantuawainum ayamjutkata, 
\q1 wika amina chichamjum umiktin 
\q1 sukagtusuitam nuna umiktasan wakegajai. 
\q1  
\v 135 Wi amina inakmetag dusha 
\q1 shiig aneasam diigsata, 
\q1 nuniakum nunú chichamem jintinjuata. 
\q1  
\v 136 Amina chichamjumin 
\q1 eme anentus uminachu asamtai, 
\q1 shiig senchi buutjai. 
\q1  
\v 137 Tuke Pujuuwah, amek pegkegmaitme; 
\q1 tuja ame suwimak sukagtam 
\q1 dushakam pegkegnum jintinkagtawai. 
\q1  
\v 138 Chicham umiktin ame sukagtusuitam 
\q1 duka waitchauwai, betek uminnai. 
\q1  
\v 139 Mina shiwag aidau 
\q1 amina chichamjumin uminachkui, 
\q1 kajeakun shiig senchi waitiajai. 
\q1  
\v 140 Amina chichamjumik 
\q1 ashí dekapsamu dekas pegkegmai, 
\q1 nuadui wika amina 
\q1 inakminuk nuna wakegajai. 
\q1  
\v 141 Wika dushiktai, wainkauchitjai, 
\q1 tujash amina chichamjum umiktin 
\q1 sukagtusuitam nunak kajimattsujai. 
\q1  
\v 142 Amina takatjum pegkeja duka 
\q1 tuké imanisag auwai, 
\q1 tuja amina chichamjum umiktin 
\q1 agagbauwa duka dekas shiig pegkegmai. 
\q1  
\v 143 Waitiakun wake besemag pujubiajai; 
\q1 tujash amina chichamjum umiktin sukagtusuitam 
\q1 nunak minak shiig anemtijusmayi. 
\q1  
\v 144 Ame chicham umikuitam 
\q1 duka makichkish yapajinchauwai. 
\q1 ¡Yainkata wisha nuna shiig antukan umiktajai! 
\c 121  
\s1 Tuke Pujuuwai amina kuitamjamnuk 
\d Atushat wekaeku Apajuíyai anentaimsa kantabau 
\q1  
\v 1 Muja aidaun pagkain diyakun: 
\q1 ¿Tuwiya taag minash ayamjutkainta? tajai. 
\q1  
\v 2 Minak Tuke Pujuu nayaimpin nugkajai najanauwa nunú yainkattawai. 
\q1  
\v 3 ¡Apajuík waitkastinme tusag 
\q1 makichkish idaituschattawai! 
\q1 ¡Amina kuitamjamna duka makichkish kanatsui! 
\q1  
\v 4 Nigka makichkish kanuchui; 
\q1 Israel aents aidaun kuitamna duka 
\q1 makichkish kanuchui. 
\b  
\q1  
\v 5 Tuke Pujuu aminak kuitamjamui; 
\q1 Tuke Pujuu aminak ejaka kuitamjamui. 
\q1 Niig amina yaimpaktatus amejai ijutkawai. 
\q1  
\v 6 Tuja tsawaishkam etsag senchi sukupakug 
\q1 waitkagmaschattawai, 
\q1 antsag nantushkam waitkagmaschattawai. 
\b  
\q1  
\v 7 Ishamain ataish, 
\q1 Tuke Pujuu ejapak kuitamjamui; 
\q1 tuja nii amina pujutjumnash kuitamjutpawai. 
\q1  
\v 8 Tuke Pujuuk yamaya juwish, tuja ajumaish 
\q1 ame tuwi wetatme nuniaminish, 
\q1 tuja wakitki minaminish, 
\q1 nigki tuké kuitamjamkatnai. 
\c 122  
\s1 Jerusalén kantamjuamu 
\d David Jerusalén wakatatus wesa shiig aneak kantamamu 
\q1  
\v 1 Tuke Pujuu jee pegkegma nuwi wemi 
\q1 tujutuinakui, wika shiig anebiajai. 
\q1  
\v 2 Jerusalégkah, yamai juwi waitinum kaunaji. 
\q1  
\v 3 Jerusalén yaaktamamua nuwi 
\q1 ashí tikich yaakat aidaushkam ijutkau ainawai. 
\q1  
\v 4 Ashí Israel aents Tuke Pujuun aentsji aidauk 
\q1 Jerusalén tuwainawai, Apajuín emematuinak, 
\q1 wagki nuwi Apajuí ememattajum 
\q1 tibau asag, nuna umiinak. 
\q1  
\v 5 Nuwi awai chicham inagnatai, 
\q1 tuja Davitan pujusa inamtaijishkam. 
\b  
\q1  
\v 6 Nuadui: “Jerusalégkah, 
\q1 aminak utugchatak atsugtamti; 
\q1 tuja amina anempaina dushakam 
\q1 agkan pujustinme. 
\q1  
\v 7 Yaakat peeja apakbauwa nuna initken 
\q1 aents batsata dushakam agkan, 
\q1 tuja jega apu pujusa inamtaijiya 
\q1 dushakam waitkaschamu ati”, titajum. 
\b  
\q1  
\v 8 Tuja mina yatsug aidaun 
\q1 kumpag aidaujai chichagkun: 
\q1 “Atumnash utugchatak atsugtamtinme”, tajai. 
\q1  
\v 9 Untsu Jerusalégkah, 
\q1 aminig pujut pegkeg ati tusa wakegajai, 
\q1 wagki Tuke Pujuu amina Apajuígmi 
\q1 jee pegkegma nunú au asamtai. 
\c 124  
\s1 Apajuík tuke yaijatui 
\d David Jerusalén wakatatus wesa shiig aneak kantamamu 
\q1  
\v 1 Ashí Israel aents aidautigmek, 
\q1 Tuke Pujuu iina yaimpakchau akuish, 
\q1 wajukauk ainji, tumamtajum. 
\b  
\q1  
\v 2 Tuke Pujuu iina yaimpakchau ataik, 
\q1 aents aidau jetepagmaya nuaduik, 
\q1  
\v 3 ashí ijipamain awajtamkajui, 
\q1 senchi kajegtamkaju asag. 
\q1  
\v 4 Dutijamawagmatai namak dujajak tajaka 
\q1 ajapama numamtuk ajapeam amain wajakuitji. 
\q1  
\v 5 Namak chichijam tajaka ajapama 
\q1 numamtuk ajapjamain awajtamkajui. 
\b  
\q1  
\v 6 ¡Tuke Pujuuk tuke pegkegnum chichagtai ati, 
\q1 wagki shiwaaji ijinatnume 
\q1 tusa idaitamsachu asamtai! 
\q1  
\v 7 Aents chigkin achiktatus detuamunum 
\q1 chigki nemak tsujimak wegama numamtuk, 
\q1 iishkam shiwag achigmak 
\q1 mantamatag tujamainakui, pisaja uwemjabiaji. 
\q1  
\v 8 Tuke Pujuu nayaimpin nugkajai 
\q1 najanauwa nunuwai ayamkagtinuk. 
\c 126  
\s1 Achija yajuakbau waketjagbau 
\d Jerusalén wakatatus wesag shiig aneenak kantamawagbau 
\q1  
\v 1 Achija yajupakagmatai, waitu batsatutin 
\q1 Tuke Pujuu awagtamag Jerusalén ikaupamtai, 
\q1 kajanmatskait dekapin ayaji. 
\q1  
\v 2 Nuniaku senchi dushimiaji, 
\q1 imaniaku shiig aneasa senchi kantamaiji. 
\q1 Nuniajin tikich nugkanmaya aents 
\q1 pegkegchau aidau chichainak: 
\q1 “¡Tuke Pujuu ditanak 
\q1 shiig pegkegnum yaigke!” tuyanume. 
\q1  
\v 3 Duka dekaske, ¡Tuke Pujuu 
\q1 iinak yaimpak agkanmitkagmabi! 
\q1 ¡Nuadui iishkam shiig anebiaji! 
\q1  
\v 4 ¡Tuke Pujuuwah, yumi uwegshunum yututai, 
\q1 entsa najanea akagama numamtuk, 
\q1 ataktu awagkim Jerusalén itajatuata! 
\q1  
\v 5 Aents buu buuttajai ajakmaku aidauk, 
\q1 atakea duwi shiig aneas juukagtinai. 
\q1  
\v 6 Tuja aents aidau ajak pegkejan juki 
\q1 ajakmatatus buutkabaikia shiyakaju aidauk, 
\q1 dita ajakmamunmayan juukag, 
\q1 shiig aneas kantamkiag 
\q1 dita jeen wakitkiagtinai. 
\c 127  
\s1 Ashí Tuke Pujuunmaya junawai 
\d Salomón Jerusalén wakatatus wesa shiig aneak kantamamu 
\q1  
\v 1 Tuke Pujuu jegan jegamchataik, 
\q1 jegá jegamin aidauk wainak takak waituinawai; 
\q1 tuja Tuke Pujuu yaakta kuitamchataik, 
\q1 yaaktan kuitamin aidauk 
\q1 wainak kuitamak waituinawai. 
\q1  
\v 2 Ajakma yuwatatus takak, 
\q1 kashikmas nantaki tuke etsan akapakush, 
\q1 kuashat juuka yuwatnunig 
\q1 wainak imanik waituinawai. 
\q1 Nuninai Apajuík niina kumpajinak kanak tepetaish, 
\q1 nii yuwatnujinak ashí suwawai. 
\q1  
\v 3 Iina uchiji aina duka, 
\q1 Tuke Pujuu anentag pegkejuch amasbau ainawai. 
\q1  
\v 4 Ii datsa ajin iina uchiji akiinaina duka, 
\q1 aents maanitan yacha nuna 
\q1 flechajijai betek ainawai. 
\q1  
\v 5 Nuadui aents kuashat uchigtina duka 
\q1 shiig aneasagtin ainawai. 
\q1 Tuja niina shiwaaji aidaujai igkuniakush dushikiam achatnai, 
\q1 niina uchiji kuashat asa, apajin ayamjukagtinai. 
\c 130  
\s1 Tuke Pujuuwai kajintsa anentaibau 
\d Jerusalén wakatatus wesag shiig anenaku kantamawagbau 
\q1  
\v 1 Tuke Pujuuwah, waanum initak 
\q1 egkema pujusan amina untsuagme. 
\q1  
\v 2 ¡Apuh, wi untsuajam nunú antugtukta! 
\q1 ¡Wi amina egakun untsumag 
\q1 nunú antugtukam yainkata! 
\b  
\q1  
\v 3 Tuke Pujuuwah, 
\q1 ame tsagkugkagtugchawaitkuminig, 
\q1 iwakuk batsamaitsuji. 
\q1  
\v 4 Tujash ame tsagkugkagtau asam, 
\q1 eme anentsa umijam atatme. 
\q1  
\v 5 Wika Tuke Pujuuwai ashí mina anentaigjai, 
\q1 kajintsan pujajai. 
\q1 Tuja nii anagkagtuawa nunashkam 
\q1 dekaskeapi tajai. 
\b  
\q1  
\v 6 Wika yaakta kuitamin 
\q1 wajupa asag tsawajat tusa, 
\q1 tsawantan dakajama numamtuk 
\q1 mina Apajuíjun dakajai. 
\q1  
\v 7 Israel aents aidautigmek 
\q1 Tuke Pujuu taatnuji dakastajum; 
\q1 wagki niyai awai anentak, tuja ashí agkanmaetashkam. 
\q1  
\v 8 Apajuí Israel aents aidaun tudaujinak 
\q1 ashí tsagkujug agkanmitkattawai. 
\c 137  
\s1 Achija Babilonia nugkanum yajuakbau 
\q1  
\v 1 Babilonia namak aidaunum 
\q1 uwet pekaamsaja, 
\q1 Jerusalén anentaimtusa buutiaji. 
\q1  
\v 2 Nuwi numi ayaunum nuna kanawen 
\q1 iina arpaji aidau nenayaji. 
\q1  
\v 3 Nunika nuwi batsatjin 
\q1 suntag iina achipag yajupaku aidau 
\q1 chichagtamainak: 
\q1 “¡Shiig aneasjum kantamatajum, 
\q1 tuja atumi nugkem Sión pachisjumshakam 
\q1 kantamatajum!” tusa waitkagmayanume. 
\q1  
\v 4 Iik makichkish iina Apajuíji kantamjutaig 
\q1 tikich nugkanmak kantamaitsuji, tuyaji. 
\q1  
\v 5 ¡Jerusalégkah, 
\q1 wi amina kajimatkin idaitaik, 
\q1 mina uweg untsujua duka makichkish achika 
\q1 takamainchau wajasti! 
\q1  
\v 6 ¡Tuja wi amina eme anentsuk, 
\q1 kajimatkin idaikun shiig aneasan pujutaik, 
\q1 mina idaijuk kayakmataijui nujamak asati. 
\b  
\q1  
\v 7 Tuke Pujuuwah, 
\q1 babilonianmaya aents aidau 
\q1 Jerusalégkan tsaikajua duwi, 
\q1 Edom aents aidau chichainak: 
\q1 “¡Ashí tsaiktajum!” tusa imatianum 
\q1 nunú kajimatki idaisaipa! 
\b  
\q1  
\v 8 ¡Babiloniah, ameshkam tsayam atatme! 
\q1 ¡Ame jutii aidauti waitkagkagtam 
\q1 nuna iiktamainak tsaipaidauk 
\q1 shiig aneasagtin atinme! 
\q1  
\v 9 ¡Amina uchijum aidaun achika yajuakag 
\q1 kayanum anugkag tsupig ijinawagtina nunak 
\q1 Apajuí pegkegnum yumigjatin ati! 
\c 139  
\s1 Apajuík ashí wainui 
\d David kantamamu 
\q1  
\v 1 Tuke Pujuuwah, ame minak shiig dekagme. 
\q1  
\v 2 Ame wi dutikamu aina duka ashí dekame, 
\q1 amek atushat pujusmesh, 
\q1 wi wajuk anentaimja dushakam dekame. 
\q1  
\v 3 Wi wajuk wekaeja duka amek ashí dekame, 
\q1 ¡wi wajina takaja dushakam ashí dekame! 
\q1  
\v 4 Wika eke chichatsaig, 
\q1 wi wajina titag taja duka amek 
\q1 emtikam dekame. 
\q1  
\v 5 Ame minak ashí tententuam, 
\q1 amina uwegmin achigsam pujame. 
\q1  
\v 6 Wika amina yachajum imana nunak 
\q1 kakajus dekamainchau dekapeajai. 
\q1 Mina dekatjuk nuwig makichkish jegatsui. 
\b  
\q1  
\v 7 Amina Wakanmin ukuknush ¿tuki wetaja? 
\q1 Ame ashí nugkanum dekam nuniaish, 
\q1 ¿wisha itug tupikaknuk uumjuktagme? 
\q1  
\v 8 Wi nayaimpinum wakamtaish, 
\q1 amek nuwi pujuttame, 
\q1 tuja wi nugka initken akaikimtaish, 
\q1 amek nuwishkam pujuttame. 
\q1  
\v 9-10 Wi nanaakan etsa minitaiya nuni wemataish, 
\q1 ame minak achigkau atatme, 
\q1 tuja etsa akaetaiya nuni nayantsa amain wenu 
\q1 pujusmataishkam, ame minak yainkattame. 
\q1  
\v 11 Wi suwenum uumkatjai tumainaitjai, 
\q1 tuja nuniachkush tsawaiya nunú suwe wajasmataish, 
\q1  
\v 12 suwea duka minak aminig ugmaitsui; 
\q1 ame diismak kashia duka tsaaptinai. 
\q1 ¡Ame diismak suwea duka tsaaptinjai betekai! 
\b  
\q1  
\v 13 Ame mina iyashjuk najatjuawaitme, 
\q1 ame minak, mina dukuju wakeen najatuawaitme. 
\q1  
\v 14 Wika ame imatiksa najanamu asan see tajame, 
\q1 ame najanamu aina duka ashí pegkejai. 
\q1 ¡Wika nunak shiig dekajai! 
\q1  
\v 15-16 Wi initak wainkachbau 
\q1 mina dukuju wakeen najaneauwaitag duka ame waitmayume, 
\q1 eke najaneaig wajupa tsawan pujustinaitja duka 
\q1 ame umigtukuitme. 
\q1 ¡Nunú amina papiigmin agagbauwai! 
\b  
\q1  
\v 17 Chah Apajuíjuh, 
\q1 amina anentaimtagmia nunak 
\q1 shiig anentaimja ejeyin 
\q1 dekamainchau dekapeajai. 
\q1 ¡Untsu nuna pachisan augmattsatag takun 
\q1 ima utugchat dekapmainaitjai! 
\q1  
\v 18 Nuna dekapagtajai takunush, 
\q1 kamatak kuashta iman asamtai, 
\q1 kakajus dekapamaitsujai. 
\q1 ¡Tuja kanaja shintaish amek wijaig pujame! 
\b  
\q1  
\v 19 Apajuíyah, aents pegkegchau aina duka ijinata, 
\q1 dutikakum magkagtin aidaushkam datupatjukta. 
\q1  
\v 20 Nunú aents aidauk amina daagmin pachisag 
\q1 pegkegchaun chichainawai. 
\q1 Nuninak amijai wainak shiwagmagainawai. 
\q1  
\v 21 Tuke Pujuuwah, 
\q1 amina kajegtamaidaunak wishakam kajejajai, 
\q1 tuja amina dakitjamaidaunashkam 
\q1 dutiksanuk dakitajai. 
\q1  
\v 22 ¡Nunú aents aidaunak shiig senchi kajejajai! 
\q1 Amina shiwaajum aina duka 
\q1 mina shiwag ainawai. 
\q1  
\v 23 Chah Apajuíyah, 
\q1 mina anentaijush shiig diigtusta, 
\q1 dutikam mina anentaimtajush shiig dekapjuttsata. 
\q1  
\v 24 Tudau jintan aintsujash nunú diigtusta, 
\q1 nuniakum jinta pujut nagkankashtinnum 
\q1 ekagtina nuni etita. 
\c 145  
\s1 Ashí aents aidauk Apajuín ememattinme 
\d David kantamamu 
\q1  
\v 1 Mina apug Apajuíyah, 
\q1 amina daajum ajumaish tuke atina 
\q1 nuna pachisan etsegkatjai. 
\q1 Tuja amina daagminak tuké pegkegnum 
\q1 chichagtinaitjai. 
\q1  
\v 2 Ashí tsawantai aminak pegkegnum chichagtatjame, 
\q1 nuniakun amina daagmin tuke ememattinaitjai. 
\q1  
\v 3 Tuke Pujuuk dekas múuntai, 
\q1 iman asa ima nigki emematam amainai, 
\q1 iman asamtai anentaimsaish, kakajus dekamaitsui. 
\q1  
\v 4 Uchi akiinak wegagtina duka 
\q1 ame pegkeg iwainajuitam nuna emematiagtinai. 
\q1 Tuja amina senchigmejai 
\q1 wainchatai ishamain aidau 
\q1 iwainajuitam nunú etsegnaktinai. 
\q1  
\v 5 Amina imanjumin tsaaptinjumjai pachisag 
\q1 etsejiagtinai. 
\q1 Nuninakui wishakam 
\q1 ame iwainajuitam nuna pachisan chichattajai. 
\q1  
\v 6 Amina senchigmin shiwaajum aidau 
\q1 depetnaitam nuna pachisag chichagtinai. 
\q1 Nuninakui wishakam ame múuntaitam 
\q1 nuna pachisan chichattajai. 
\q1  
\v 7 Amina wait anenkagtutaigmin 
\q1 pachisag etsejiagtinai; 
\q1 nuninak shiig aneas kantamainak: 
\q1 ¡Apajuíyai pegkegmak! tujamiagtinai. 
\b  
\q1  
\v 8 Tuke Pujuuk kakagchauch, wait anenkagtin; 
\q1 wamak kajechu anentak wajasui. 
\q1  
\v 9 Tuke Pujuuk ashí aents aidaun kuitamui; 
\q1 tuja tikich nii najankamu aina nunashkam puyatjus kuitamui. 
\b  
\q1  
\v 10 ¡Tuke Pujuuwah, 
\q1 ashí ame najankamu aidau emematjamtinme! 
\q1 ¡Tuja amina umigtamin aidaushkam 
\q1 pegkegnum chichagtamtinme! 
\q1  
\v 11 ¡Amina inamtaijum pegkegma nuna 
\q1 pachisag chichatnume! 
\q1 ¡Tuja amina senchigmejai 
\q1 wainchatai ishamain aidau 
\q1 iwainajuitam nuna pachisag chichagtatui! 
\q1  
\v 12 ¡Tuja amina senchigmea nuna, 
\q1 ame inamtaijum pegkegma nujai 
\q1 ashí aents aidau dekaatnume! 
\q1  
\v 13 Amina inamtaigmea duka 
\q1 ajumaish tuke atinai, 
\q1 nuadui ajumaish amek tuke inamtinaitme. 
\b  
\q1  
\v 14 Tuke Pujuu aents wake besemag pujaunash yayawai, 
\q1 tuja kakakchau wajas pujaunash senchimtikawai. 
\q1  
\v 15 Apujuh, ashí aents aidauk 
\q1 amina dakagmainawai, yutain sujamsati tusa. 
\q1  
\v 16 Nuninakui ame shiig aneasam suwame, 
\q1 nuna ashí iwaku aidauk 
\q1 yuwawag ejemakag shiig anenawai. 
\q1  
\v 17 Tuke Pujuuk ashí 
\q1 nii anagkagtuamunak betek uminai, 
\q1 tuja nii najankamu aina nunak 
\q1 shiig anentawai. 
\q1  
\v 18 Tuke Pujuuk aents niina dekaskenum 
\q1 segau aina nujai ijutkawai. 
\q1  
\v 19 Tuja niina eme anentus umijin aina nunú 
\q1 segamak antujuk yaigka uwemtikui. 
\q1  
\v 20 Tuke Pujuuk niina aneen aidaun kuitamui; 
\q1 untsu aents pegkegchau aidaunak ijina utsawai. 
\b  
\q1  
\v 21 ¡Wika kantamkun Tuke Pujuun ememattatjai! 
\q1 ¡Ashí aents nugkanum batsamin aidauk 
\q1 Apajuí daaji pegkegma nuna pachisag 
\q1 tuké ajumaish ememattin atinme! 
\c 148  
\s1 Apajuí najankamu aidautigmek nii ememattajum 
\q1  
\v 1 ¡Iina Apajuíji emematiagmi! 
\q1 ¡Nayaim aidautijum Tuke Pujuu ememattajum! 
\q1 ¡Yakí agkajunum Apajuí ememattajum! 
\q1  
\v 2 ¡Atum Apajuí aentsji ángel aidautijum 
\q1 Apajuí ememattajum! 
\q1 ¡Nayaimpinmaya suntag aidauwah, 
\q1 Apajuí ememattajum! 
\q1  
\v 3 ¡Etsa, nantu aidauwah, 
\q1 Apajuí ememattajum! 
\q1 ¡Yaya aidautigmesh Apajuí ememattajum! 
\q1  
\v 4 ¡Yumi yakiya aidautigmesh 
\q1 Apajuí ememattajum! 
\q1 ¡Nayaim shiig múunta 
\q1 dushakam Apajuín emematti! 
\b  
\q1  
\v 5 Tuke Pujuu daaji ememattajum, 
\q1 wagki nii chichakmatai, 
\q1 ashí najaneakua nuadui. 
\q1  
\v 6 Nii ashí umikui tuke asatnun; 
\q1 dutika chichaman umikui atakesh yapajinashtinun. 
\q1  
\v 7 ¡Nugkaya aidautigmesh, 
\q1 tuja nayantsanum batsamin 
\q1 kuntin múun aidautigmesh, 
\q1 nayantsa initken batsamin aidaujaí 
\q1 Tuke Pujuu ememattajum! 
\q1  
\v 8 ¡Chaajip, bicha, nieve, yujagkim aidautigmesh, 
\q1 tuja dase Apajuí dasenkati tima 
\q1 ishamain dasentin aidautigmesh, 
\q1  
\v 9 muja aidautigmesh, nain aidautigmesh, 
\q1 tuja ashí setug aidautigmesh, 
\q1 numi neje yujutai aidautigmesh 
\q1 Apajuí ememattajum! 
\q1  
\v 10 ¡Kuntin tagkumtai, kuntin tagkumchatai, 
\q1 chigki aidau, kuntin japiinas yujau aidautigmesh, 
\q1  
\v 11 tuja ashí nugka múun aidaun 
\q1 apuji aidautigmesh, atumi aentsjum aidaujai, 
\q1 apu ashí nugkanmaya aidautigmesh, 
\q1  
\v 12 aishmag, nuwa, 
\q1 datsa, múuntuch aidautigmesh, 
\q1  
\v 13 ashí Tuke Pujuun daaji ememattajum, 
\q1 wagki ima niina daajiya duke múuntak! 
\q1 ¡Niina imanjiya duka nayaimpin 
\q1 nugkajai nagkaesau múuntai! 
\b  
\q1  
\v 14 ¡Apajuí niina aentsji aidaunak senchimtikawai! 
\q1 Nuadui niina aentsji Israel wegantu aidautik 
\q1 nii emematuinaji. 
\q1 ¡Yajauwajah! 
\q1 Apajuí ememattai ati. 
\c 150  
\s1 Ashí aentstijum Apajuí kantamjuatajum 
\q1  
\v 1 ¡Yajauwajah! 
\q1 ¡Apajuí niina jee pegkegma nuwi ememattajum! 
\q1 ¡Apajuí nayaim wigkaya nuna 
\q1 niina senchijijai najanauwa nuwi ememattajum! 
\q1  
\v 2 ¡Niina senchijin wainchatai aidaun iwainajua 
\q1 duwi ememattajum! 
\q1 ¡Niina imanjig nagkatkachua 
\q1 duwi ememattajum! 
\q1  
\v 3 ¡Uwija kachuji aidau umpuakjum ememattajum, 
\q1 arpa, salterio aatsa awatkujum ememattajum! 
\q1  
\v 4 ¡Pandero aidau awatkujum 
\q1 nantsemkijum ememattajum! 
\q1 ¡Pigkui umpuakjum, 
\q1 guitarra awatkujum ememattajum! 
\q1  
\v 5 ¡Platillo awatkujum ememattajum! 
\q1 ¡Platillo senchi shinin aina nunú 
\q1 awatkujum ememattajum!\fig ¡Yajauwajah, Apajuí emematbau!|alt="Instruments" src="BK00174b.tif" size="col" loc="Psalm 150.3-5" ref="Sal. 150.3-5" \fig* 
\q1  
\v 6 ¡Ashí pujutji ajamu aidauk 
\q1 Tuke Pujuun ememattinme! 
\b  
\q1 ¡Yajauwajah!