\id PSA
\h Salmu
\toc1 Salmu
\toc2 Salmu
\toc3 Salmu
\mt1 Salmu
\c 1
\s1 Dalan ksolok nian
\b
\q1 
\v 1 Ema nebee hetan ksolok mak ema nebee la moris tuir ema aat sira nia lia menon,
\q2 la sama sala nain sira nia ain fatin,
\q2 la tuur hamutuk ho ema kontra door sira,
\q1 
\v 2 maibee nia gosta teb-tebes NAI Maromak nia lei;
\q2 loron-kalan nia medita ba lei nee.
\q1 
\v 3 \x + \xo 1:3 \xt Jeremias 17:8\x*Ema nee hanesan ai huun ida nebee kuda besik iha bee dalan,
\q2 nia foo fuan tebar tuir nia tempu,
\q1 nia tahan nunka namlaik.
\q2 Nia halo saida deit, hetan rezultadu diak.
\b
\q1 
\v 4 Ema aat sira nee oin seluk;
\q2 sira hanesan hare kulit mamuk nebee anin huu lakon tiha.
\q1 
\v 5 Entaun ema aat sira nee sei la aguenta iha loron justisa;
\q2 sala nain sira nee la bele tama hamutuk ho ema nebee moris loos.
\q1 
\v 6 Tanba NAI Maromak kuidadu lalaok ema moris loos nian,
\q2 maibee ema aat sira nia lalaok lori sira ba mate.
\c 2
\s1 Liurai nebee Nai Maromak hili
\b
\q1 
\v 1 \x + \xo 2:1 \xt Apostolu sira nia Istoria 4:25,26\x*Nusaa mak nasaun jentiu sira kombina malu?
\q2 Povu sira tau lia ba malu atu manaan saida?
\q1 
\v 2 Liurai sira iha mundu hamriik hamutuk;
\q2 nai ulun sira nee futu lia
\q1 kontra NAI Maromak
\q2 no kontra liurai nebee mak Nia foti tiha ona.
\q1 Ema sira nee dehan,
\q1 
\v 3 “Mai ita halo ita nia aan livre husi Maromak ho liurai nebee Nia hili nee;
\q2 mai ita harahun tiha korenti nebee mak futu metin ita.”
\b
\q1 
\v 4 Nai Maromak hamnasa fali sira;
\q2 Nia tuur iha lalehan hodi goza sira.
\q1 
\v 5 Depois Nia hasee sira ho hirus;
\q2 Nia hatauk sira ho laran nakali dehan,
\q1 
\v 6 “Hau hatuur tiha ona Hau nia liurai
\q2 iha Siaun, Hau nia foho santu.”
\b
\q1 
\v 7 \x + \xo 2:7 \xt Apostolu sira nia Istoria 13:33; Ebreu 1:5, 5:5\x*Liurai dehan, “Hau sei foo sai buat nebee NAI Maromak deklara tiha ona mai hau.
\q2 Nia deklara nunee:
\q1 ‘O nee Hau nia oan.
\q2 Agora ba oin, Hau o nia Aman.
\q1 
\v 8 Husu mai Hau mak Hau sei foo nasaun hotu-hotu ba o;
\q2 husi rai ulun too rai ikun sei sai o nia riku-soin.
\q1 
\v 9 \x + \xo 2:9 \xt Apokalipse 2:26,27, 12:5, 19:15\x*O sei baku tohar sira ho rota besi;
\q2 o sei halo rahun sira hanesan ema baku rahun sanan rai.’”
\b
\q1 
\v 10 Nee duni liurai sira, sai matenek ba;
\q2 nai ulun mundu nian, aprende di-diak ba.
\q1 
\v 11-12 Serbi NAI Maromak ho hamtauk,
\q2 hakruuk ba Nia\f + \fr 2:11-12 \ft Liafuan “hakruuk ba Nia” ho lian Ebreu la klaru.\f* ho nakdedar.
\q1 Se lae Nia hirus, halo imi mate derepenti iha dalan,
\q2 tanba Nia laran nakali lalais.
\b
\q1 Ema hotu nebee hamahon aan iha Nia, sira hetan ksolok.
\c 3
\s1 Orasaun husu tulun iha tempu susar
\d Salmu David nian, bainhira nia halai sees husi nia oan Absalão.
\b
\q1 
\v 1 NAI Maromak, hau nia inimigu barak loos;
\q2 iha ema barak hamriik kontra hau!
\q1 
\v 2 Ema barak koalia kona ba hau dehan,
\q2 “Maromak sei la salva nia.”
\b
\q1 
\v 3 Maibee NAI, Ita Boot defende hau;
\q2 Ita Boot tane aas hau no foti sae hau nia ulun.
\q1 
\v 4 Hau bolu NAI Maromak;
\q2 husi Nia foho santu Nia hataan hau.
\b
\q1 
\v 5 Hau toba hakmatek no hadeer fali ho diak,
\q2 tanba NAI kuidadu hau.
\q1 
\v 6 Hau la tauk hau nia inimigu rihun ba rihun
\q2 nebee asalta hau husi sor-sorin.
\b
\q1 
\v 7 NAI, hamriik ba;
\q2 hau nia Maromak, mai salva hau ba!
\q1 Tuku tiha hau nia inimigu sira nia hasan;
\q2 halo tohar tiha ema aat sira nia nehan.
\q1 
\v 8 NAI Maromak, salvasaun mai husi Ita Boot.
\q2 Foo bensaun ba Ita Boot nia povu.
\c 4
\s1 Orasaun molok deskansa kalan
\d Salmu David nian, ba dirijenti koru. Akompanha ho viola.
\b
\q1 
\v 1 Maromak, Ita Boot sempre defende hau;
\q2 hataan hau bainhira hau bolu Ita Boot!
\q1 Uluk hau iha fatin kloot, Ita Boot foo fatin luan mai hau;
\q2 hanoin hau ba, rona hau nia orasaun.
\b
\q1 
\v 2 Imi ema sira nee, imi atu hafoer hau nia naran too bainhira?
\q2 Too bainhira loos mak imi gosta buat nebee la iha folin,
\q2 no duni tuir lia falsu?\f + \fr 4:2 \ft Matenek nain balu dehan, liafuan “lia falsu” nee hatudu ba maromak falsu.\f*
\q1 
\v 3 Keta haluha katak NAI Maromak hili tiha ona ema nebee moris loos hodi sai Ninian;
\q2 NAI rona bainhira hau bolu Nia.
\b
\q1 
\v 4 \x + \xo 4:4 \xt Éfezu 4:26\x*Maski tauk ho nakdedar, maibee la bele halo sala;
\q2 bainhira o iha o nia toba fatin, hakmatek hodi reflete aan.
\q1 
\v 5 Fiar ba NAI Maromak
\q2 hodi oferese sakrifisiu nebee loos ba Nia.
\b
\q1 
\v 6 Iha ema barak mak husu, “See mak sei foo moris diak ba ami?
\q2 NAI, leno ami ho Ita Boot nia oin.”
\q1 
\v 7 Ksolok nebee Ita Boot foo tiha ona mai hau
\q2 boot liu fali ksolok nebee sira hetan husi sira nia ai haan ho tua bar-barak.
\q1 
\v 8 NAI, hau sei toba dukur ho hakmatek;
\q2 Ita Boot deit mak halo hau moris seguru.
\c 5
\s1 Orasaun iha dadeer-saan atu Nai Maromak proteje
\d Salmu David nian, ba dirijenti koru. Akompanha ho korneta.
\b
\q1 
\v 1 NAI Maromak, see tilun ba hau nia liafuan;
\q2 foo atensaun ba hau nia halerik.
\q1 
\v 2 Hau nia Liurai, hau nia Maromak,
\q2 hau harohan husu tulun ba Ita Boot deit;
\q2 rona hau nia orasaun ba.
\q1 
\v 3 NAI Maromak, dadeer-dadeer Ita Boot rona hau nia lian;
\q2 iha dadeer-saan hau hasae hau nia orasaun ba Ita Boot
\q2 hodi hein Ita Boot nia resposta.
\b
\q1 
\v 4 Tanba Ita Boot Maromak ida nebee la haksolok ho hahalok aat;
\q2 buat aat la bele hela iha Ita Boot nia prezensa.
\q1 
\v 5 Ema nebee foti aan la bele hamriik iha Ita Boot nia oin;
\q2 Ita Boot odi ema aat hotu-hotu.
\q1 
\v 6 NAI Maromak, Ita Boot sempre harahun bosok-teen sira;
\q2 Ita Boot hakribi ema nebee hamrook raan ho lohi door sira.
\b
\q1 
\v 7 Maibee tanba Ita Boot nia domin rohan-laek,
\q2 hau bele tama iha Ita Boot nia uma;
\q1 hau hakruuk ba Ita Boot nia fatin santu
\q2 hodi adora Ita Boot.
\q1 
\v 8 NAI Maromak, hanorin hau atu moris tuir Ita Boot nia lia loos\f + \fr 5:8 \ft Lian Ebreu iha nee bele mos signifika “Ita Boot sempre halo buat nebee loos.”\f*
\q2 tanba hau iha inimigu barak;
\q1 halo tetuk Ita Boot nia dalan iha hau nia oin para hau bele lao tuir.
\b
\q1 
\v 9 \x + \xo 5:9 \xt Roma 3:13\x*Liafuan nebee sai husi hau nia inimigu sira nia ibun, la iha ida mak loos;
\q2 sira nia laran nakonu ho hanoin aat.
\q1 Sira nia kakorok hanesan rate nebee nakloke;
\q2 sira nia liafuan kos-kose ema.
\q1 
\v 10 Maromak, tesi sira nia lia hodi kastigu sira;
\q2 husik sira nia manobra halo sira rasik monu.
\q1 Sira kontra ona Ita Boot;
\q2 hasai sira husi Ita Boot nia prezensa tanba sira nia sala barak.
\b
\q1 
\v 11 Maibee see-see deit mak buka mahon iha Ita Boot, sira kontenti;
\q2 sira sempre hananu haksolok.
\q1 Proteje ema nebee hadomi Ita Boot
\q2 atu nunee sira nia laran bele haksolok.
\q1 
\v 12 Tebes duni, NAI Maromak, Ita Boot foo bensaun ba ema nebee moris loos;
\q2 Ita Boot nia laran diak haleu sira hodi defende sira.
\c 6
\s1 Ema moras halerik husu tulun
\d Salmu David nian, ba dirijenti koru. Akompanha ho viola tali walu.\f + \fr 6:0 \ft Orijinal laduun klaru, karik instrumentu muzika ida ho tali walu, bele mos termu muzika ida seluk.\f*
\b
\q1 
\v 1 \x + \xo 6:1 \xt Salmu 38:1\x*NAI Maromak, maski Ita Boot hirus hela hau, maibee keta siak hau;
\q2 maski Ita Boot nia laran nakali hela, maibee keta kastigu hau.
\q1 
\v 2 NAI, hau nia forsa lakon tiha, hanoin hau ba!
\q2 NAI, hau nia ruin sira moras hotu kura hau ba!
\q1 
\v 3 Hau nia laran susar teb-tebes.
\q2 Too bainhira NAI, too bainhira?
\b
\q1 
\v 4 NAI, see Ita Boot nia oin mai hau;
\q2 salva hau ba!
\q1 Hatudu Ita Boot nia domin rohan-laek mai hau
\q2 hodi hasai hau husi susar laran.
\q1 
\v 5 Tanba ema nebee mate ona la temi tan Ita Boot nia naran.
\q2 Iha ema mate sira nia fatin, see mak atu hahii Ita Boot?
\b
\q1 
\v 6 Hau halerik too kole teb-tebes;
\q2 kalan tomak, hau nia matan been suli habokon hau nia kama;
\q2 hau tanis too hau nia toba fatin bokon hotu.
\q1 
\v 7 Hau nia matan sai malahuk tiha tanba hau nia laran dodok nee;
\q2 hau nia matan haree la moos ona tanba hau nia inimigu sira nia hahalok.
\b
\q1 
\v 8 \x + \xo 6:8 \xt Mateus 7:23; Lucas 13:27\x*Imi hotu nebee halo buat aat, hadook aan husi hau,
\q2 tanba NAI Maromak rona ona hau nia halerik.
\q1 
\v 9 Hau husu tulun ba NAI, Nia rona ona hau;
\q2 NAI simu hau nia orasaun.
\q1 
\v 10 Hau nia inimigu sira hotu sei moe ho tauk teb-tebes;
\q2 derepenti sira hakiduk ho moe boot.
\c 7
\s1 Orasaun husu justisa
\d Salmu nee David kanta ba NAI Maromak kona ba Kuxe, ema ida husi suku Benjamim.
\b
\q1 
\v 1 NAI, hau nia Maromak, hau hamahon aan iha Ita Boot.
\q2 Iha ema buka atu halo aat hau;
\q2 tulun hau no salva hau ba.
\q1 
\v 2 Se lae, sira hanesan liaun lees matak tiha hau;
\q2 sira sei lees hau nia isin halo rohan-rohan, ema atu salva hau la iha.
\b
\q1 
\v 3-4 NAI, hau nia Maromak, hau nia sala saida?
\q2 Hau halo aat ba hau nia belun ka?
\q1 Hau halo violensia arbiru deit hasoru hau nia inimigu ka?
\q2 Se karik hau halo buat sira nee,
\q1 
\v 5 entaun husik hau nia inimigu duni hau hodi kaer tiha hau ba;
\q2 husik nia sama hau ba rai
\q3 too latan tiha hau iha rai rahun.
\b
\q1 
\v 6 NAI Maromak, hamriik ho hirus ba.
\q2 Tuba rai metin hodi hasoru hau nia inimigu tanba sira nia laran nakali.
\q2 Hau nia Maromak, hadeer ona ba hodi foo sai lia loos.
\q1 
\v 7 Halibur hamutuk povu husi rai hotu-hotu para haleu Ita Boot;
\q2 tuur iha fatin aas hodi ukun sira.
\q1 
\v 8 NAI mak tesi povu sira nia lia.
\q2 NAI, hau ema ida nebee moris loos no la sala ida.
\q2 Maromak Aas Liu, foo justisa mai hau ba.
\b
\q1 
\v 9 \x + \xo 7:9 \xt Apokalipse 2:23\x*Maromak, Ita Boot sempre halo buat nebee loos;
\q2 Ita Boot koko ema nia neon ho laran.
\q1 Hapara tiha ema aat sira nia hahalok aat;
\q2 foo hakmatek ba ema nebee moris loos.
\b
\q1 
\v 10 Maromak mak defende hau;
\q2 Nia salva ema sira nebee laran moos.
\q1 
\v 11 Maromak sempre tesi lia ho loos;
\q2 loro-loron Nia hamonu kastigu ba ema aat.
\b
\q1 
\v 12 Se sira la hakribi sira nia sala,
\q2 entaun Maromak sei kadi Nia surik,
\q2 Nia sei dada Nia rama atu hana.
\q1 
\v 13 Sasaan kroat para hamate ema, Nia prepara tiha ona;
\q2 rama oan nebee Nia atu hana, Nia sunu lakan tiha ona.
\b
\q1 
\v 14 Haree ba, ema sira nee kuda hahalok aat,
\q2 sira haburas hanoin aat
\q2 hodi foo rezultadu liafuan bosok.
\q1 
\v 15 Sira kee rai kuak ba ema seluk,
\q2 maibee sira rasik monu tama ba laran.
\q1 
\v 16 Hahalok aat nebee sira halo kona fali sira;
\q2 violensia nebee sira halo hanehan fali sira nia ulun.
\b
\q1 
\v 17 Hau sei foo agradese ba NAI Maromak tanba Nia sempre halo buat nebee loos;
\q2 hau sei hananu hahii NAI Maromak Aas Liu nia naran.
\c 8
\s1 Nai Maromak iha lalehan foti aas ema kriatura
\d Salmu David nian, tuir muzika Gitit. Ba dirijenti koru.
\b
\q1 
\v 1 NAI Maromak, ami nia Nai,
\q2 Ita Boot nia naran furak teb-tebes iha mundu tomak!
\b
\q1 Ita Boot nia naran aas liu lalehan;
\q2 
\v 2 \x + \xo 8:2 \xt Mateus 21:16\x*labarik ho kiikoan sira nebee sei susu hela hahii Ita Boot.
\q1 Ita Boot hatuur tiha ona Ita nia kbiit hodi hasoru Ita Boot nia inimigu sira,
\q2 halo funu baluk sira ho ema nebee mak rai odi sai nonook tiha.
\b
\q1 
\v 3 Hau hateke sae ba lalehan; lalehan nee Ita Boot nia liman fuan mak halo;
\q2 hau haree ba fulan ho fitun nebee mak Ita Boot hatuur tiha ona iha nia fatin.
\q1 
\v 4 \x + \xo 8:4 \xt Jó (Ayub) 7:17,18; Salmu 144:3; Ebreu 2:6-8\x*Ami ema kriatura see loos, too Ita Boot interese ami?
\q2 Ami ema kbiit-laek nee see loos, too Ita Boot tau matan mai ami?
\b
\q1 
\v 5 Ita Boot halo ami kiik liu uitoan anju sira;
\q2 Ita Boot foo fatin aas ba ami hodi foti aas ami nia naran.
\q1 
\v 6 \x + \xo 8:6 \xt 1 Korintu 15:27; Éfezu 1:22; Ebreu 2:8\x*Ita Boot foti ami ukun buat hotu-hotu nebee Ita Boot nia liman halo tiha ona;
\q2 Ita Boot halo buat hotu-hotu hakruuk mai ami:
\q1 
\v 7 bibi ho karau sira hotu,
\q2 ho mos animal fuik sira,
\q1 
\v 8 manu fuik iha lalehan,
\q2 ikan iha tasi laran
\q2 ho saida deit mak moris iha tasi laran.
\b
\q1 
\v 9 NAI Maromak, ami nia Nai,
\q2 Ita Boot nia naran furak teb-tebes iha mundu tomak!
\c 9
\s1 Kantiku hahii Nai Maromak tanba Nia justisa
\d Salmu David nian, ba dirijenti koru. Tuir muzika “Oan mane mate.”\f + \fr 9:0 \ft Liafuan Ebreu nee nia signifikadu la klaru.\f*
\b
\q1 
\v 1 NAI Maromak, hau sei agradese ba Ita Boot ho hau nia laran tomak;
\q2 hau sei hatete sai buat furak hotu nebee Ita Boot halo.
\q1 
\v 2 Hau sei kontenti ho haksolok tanba Ita Boot nia diak;
\q2 Maromak Aas Liu, hau sei hananu hahii Ita Boot nia naran.
\b
\q1 
\v 3 Hau nia inimigu sira hakiduk tiha ona;
\q2 sira sidi monu, sira mate iha Ita Boot nia oin.
\q1 
\v 4 Tanba Ita Boot tuur iha kadeira ukun nudar Juis nebee loos,
\q2 Ita Boot defende hau hodi foo justisa lo-loos mai hau.
\q1 
\v 5 Ita Boot siak ona nasaun jentiu sira;
\q2 Ita Boot halo rahun ona ema aat sira;
\q2 Ita Boot halakon tiha ona sira nia naran too tinan ba tinan.
\q1 
\v 6 Hau nia inimigu sira mate mohu ona, sira hanesan uma nebee rahun tiha ona.
\q2 Ita Boot fokit sai tiha sira nia sidade hotu;
\q2 ema nunka atu hanoin tan sira tinan ba tinan.
\b
\q1 
\v 7 Maibee NAI Maromak ukun tinan ba tinan;
\q2 Nia hametin tiha ona Nia kadeira ukun para tesi lia.
\q1 
\v 8 Nia ukun mundu ho justisa;
\q2 Nia tesi lia ba ema hotu ho lo-loos.
\q1 
\v 9 NAI nee abrigu ba ema kbiit-laek sira;
\q2 Nia sai sira nia abrigu iha tempu susar.
\q1 
\v 10 NAI, ema nebee konhese Ita Boot konfia Ita Boot,
\q2 tanba Ita Boot nunka husik ema nebee mak harohan ba Ita Boot.
\b
\q1 
\v 11 Hananu hahii NAI Maromak ba, Nia ukun iha Siaun;\f + \fr 9:11 \ft Iha nee “Siaun” hatudu ba sidade Jerusalém.\f*
\q2 foo sai ba nasaun jentiu sira kona ba buat nebee Nia halo tiha ona.
\q1 
\v 12 Tanba Maromak buka tuir ema oho door;
\q2 Nia sempre hanoin ema kbiit-laek sira;
\q2 Nia la haluha sira nia halerik.
\b
\q1 
\v 13 NAI Maromak, haree ba, hau nia inimigu sira hanehan hau!
\q2 Hanoin hau ba, hasees tiha hau husi odamatan mate nian,
\q1 
\v 14 atu hau bele baa tuur iha odamatan sidade Jerusalém nian\f + \fr 9:14 \ft Lian Ebreu dehan “Oan feto Siaun”. Nee hatudu ba sidade Jerusalém.\f*
\q2 hodi konta sai Ita Boot nia diak
\q2 no haksolok tanba Ita Boot salva tiha ona hau.
\b
\q1 
\v 15 Nasaun jentiu sira monu tiha ona ba rai kuak nebee sira rasik mak kee;
\q2 sira nia ain belit tiha ona iha lasu nebee sira rasik mak monta subar.
\q1 
\v 16 Bainhira NAI Maromak foo justisa, Nia hatudu sai Nia Aan;
\q2 ema aat sira nia hahalok rasik sai lasu hodi halo sira monu.
\b
\q1 
\v 17 Ema aat sira tuun dadauk ba ema mate sira nia fatin;
\q2 nasaun hotu-hotu nebee mak haluha Maromak sei sai nunee.
\q1 
\v 18 Maibee Maromak sei la haluha ema kiak sira;
\q2 ema kbiit-laek sira nia esperansa sei la mohu.
\b
\q1 
\v 19 NAI Maromak, hamriik ba! Keta husik ema kriatura mak manaan fali Ita Boot;
\q2 haruka nasaun jentiu sira hotu hataan iha Ita Boot nia oin.
\q1 
\v 20 NAI, hatauk sira ba;
\q2 nasaun sira nee tenki hatene katak sira ema kriatura deit.
\c 10
\s1 Orasaun husu justisa
\q1 
\v 1 NAI Maromak, tansaa mak Ita Boot hamriik dook nunee?
\q2 Tansaa mak Ita Boot subar Aan bainhira ami iha susar laran?
\q1 
\v 2 Ema aat sira foti aan hodi hanehan ema kbiit-laek sira;
\q2 husik sira monu ba lasu nebee mak sira rasik halo tiha ona.
\q1 
\v 3 Ema aat sira gaba aan kona ba saida mak sira nia laran kaan;
\q2 ema nebee matan naklosu ba sasaan hatete aat NAI Maromak hodi hatuun Nia naran.
\b
\q1 
\v 4 Ema aat sira nee foti aan dehan Maromak sei la husu tuir sira;
\q2 iha sira nia neon tomak la iha fatin ba Maromak.
\q1 
\v 5 Sira nia moris diak hela deit;
\q2 sira la interese Maromak nia lei;\f + \fr 10:5 \ft Lian Ebreu iha nee la klaru. Bele mos signifika, “Ita Boot nia justisa aas liu, sira la haree.”\f*
\q2 sira sempre hamoe sira nia inimigu.
\q1 
\v 6 Sira hatete ba sira nia aan, “La iha buat ida mak atu doko hau;
\q2 susar nunka atu kona hau.”
\b
\q1 
\v 7 \x + \xo 10:7 \xt Roma 3:14\x*Sira nia ibun nakonu ho hotar, lia bosok ho ameasa;
\q2 sira kaan koalia liafuan nebee halo susar ema no halo aat ema.
\q1 
\v 8 Sira subar nonook besik aldeia;
\q2 husi sira nia subar fatin sira oho ema nebee la hatene buat ida.
\q1 Sira hafuhu ema nebee sira atu oho;
\q2 
\v 9 sira hein hanesan liaun nebee helik iha ai huun.
\q1 Sira hein atu kaer ema kbiit-laek;
\q2 sira kaer ema kbiit-laek sira nee ho lasu hodi dada sai.
\q1 
\v 10 Ho sira nia forsa sira hamonu tiha vitima sira nee
\q2 hodi sama hanehan ba rai.
\q1 
\v 11 Sira hatete ba sira nia aan, “Maromak sei la nota ida;
\q2 Nia taka tiha ona Nia matan, Nia la haree saida mak hau halo.”
\b
\q1 
\v 12 NAI Maromak, hamriik ba! Maromak, foti Ita Boot nia liman hasoru sira;
\q2 keta haluha ema kbiit-laek sira.
\q1 
\v 13 Tansaa mak ema aat sira hatete aat Maromak?
\q2 Tansaa mak sira dehan ba sira nia aan, “Nia sei la kastigu hau”?
\q1 
\v 14 Maibee Ita Boot nia matan haree duni ema nebee iha terus ho susar laran;
\q2 Ita Boot nia liman sempre prontu hodi tulun sira.
\q1 Vitima sira nee oferese sira nia aan ba Ita Boot;
\q2 Ita Boot mak ajudador ba oan kiak sira.
\b
\q1 
\v 15 Silu tohar tiha ema aat sira nia liman ba;
\q2 eziji sira para hataan hotu hahalok aat nebee sira halo tiha ona.
\q1 
\v 16 NAI Maromak nee Liurai tinan ba tinan;
\q2 nasaun jentiu sira sei lakon mohu husi Nia rain.
\q1 
\v 17 NAI, Ita Boot rona ema mukit sira nia hakarak;
\q2 Ita Boot hametin sira nia laran hodi see tilun ba sira nia halerik.
\q1 
\v 18 Ita Boot defende oan kiak sira ho vitima sira nebee ema hanehan,
\q2 atu nunee ema iha mundu la bele halo teror tan.
\c 11
\s1 Laran metin ba NAI Maromak iha susar laran
\d Salmu David nian, ba dirijenti koru.
\b
\q1 
\v 1 NAI Maromak mak hau nia mahon.
\q2 Nusaa mak imi dehan fali mai hau,
\q2 “Salva o nia aan hanesan manu fuik nebee mak semo ba foho.
\q1 
\v 2 O haree ka lae, ema aat sira prepara hela sira nia rama;
\q2 sira tau hela rama oan ba rama inan;
\q2 sira hein iha fatin nakukun atu hana ema diak sira.
\q1 
\v 3 Bainhira lei nia huun rahun tiha ona,
\q2 ema nebee moris loos atu halo saida tan?”
\b
\q1 
\v 4 NAI Maromak iha hela Nia uma santu;
\q2 NAI tuur hela iha Nia kadeira ukun iha lalehan.
\q1 Nia matan haree tu-tuir ema hotu-hotu iha mundu
\q2 hodi koko sira.
\q1 
\v 5 Ema nebee moris loos ho mos ema aat sira, NAI koko hotu;
\q2 ema nebee gosta violensia, Maromak hakribi.
\q1 
\v 6 Nia sei fakar tuun ahi klaak ho fatuk lakan ba ema aat sira;
\q2 Nia sei haruka anin manas hodi halo terus sira.
\q1 
\v 7 NAI sempre halo buat nebee loos;
\q2 Nia gosta hahalok nebee loos;
\q2 ema diak sei haree Nia oin.
\c 12
\s1 Orasaun bainhira iha ema aat sira nia klaran
\d Salmu David nian, ba dirijenti koru. Akompanha ho viola tali walu.\f + \fr 12:0 \ft Orijinal laduun klaru, karik instrumentu muzika ida ho tali walu, bele mos termu muzika ida seluk.\f*
\b
\q1 
\v 1 NAI Maromak, salva ami ba! Tanba ema nebee moris loos la iha tan ona;
\q2 ema nebee foo laran ba Ita Boot, sira lakon mohu tiha ona husi mundu nee.
\q1 
\v 2 Hela deit ema nebee gosta lohi sira nia maluk;
\q2 sira nia ibun kos-kose ema;
\q2 sira nia laran nakonu ho buat bosok.
\q1 
\v 3 Hau harohan atu NAI Maromak taka tiha ibun nebee kos-kose ema,
\q2 hapara tiha nanaal nebee nakonu ho gaba aan.
\q1 
\v 4 Ema sira nee dehan, “Hodi ami nia liafuan, ami sei manaan;
\q2 saida mak ami hakarak koalia, ami koalia deit; see mak atu manda tan ami?”
\b
\q1 
\v 5 NAI Maromak dehan, “Sira hanehan ema kiak;
\q2 sira halo ema kbiit-laek halerik.
\q1 Nunee Hau sei hamriik;
\q2 Hau sei hatuur ema kbiit-laek sira iha fatin seguru nebee durante nee sira hein hela.”
\q1 
\v 6 NAI nia promesa perfeitu hotu,
\q2 hanesan osan mutin nebee hamoos dala hitu ona iha ahi.
\b
\q1 
\v 7 NAI Maromak, Ita Boot sei kuidadu ema kbiit-laek sira;
\q2 Ita Boot sei hamahon ami husi ema aat sira tinan ba tinan.
\q1 
\v 8 Ema hotu-hotu iha mundu gaba hahalok aat,
\q2 too ema aat sira lao livre iha fat-fatin.
\c 13
\s1 Halerik husu tulun ba Nai Maromak
\d Salmu David nian, ba dirijenti koru.
\b
\q1 
\v 1 NAI Maromak, Ita Boot atu haluha hau too bainhira? Too tinan ba tinan ka?
\q2 Ita Boot atu subar oin husi hau too bainhira?
\q1 
\v 2 Too bainhira mak hau nia laran tenki susar nunee;
\q2 hau nia fuan loron-kalan taridu hela deit?
\q2 Too bainhira mak hau nia inimigu sira manaan hela deit?
\b
\q1 
\v 3 NAI, hau nia Maromak, hateke mai hau, no hataan hau ba;
\q2 foo iis foun mai hau.
\q1 Se lae hau mate,
\q2 
\v 4 depois hau nia inimigu dehan, nia manaan tiha ona;
\q1 haree hau monu nunee,
\q2 hau nia funu baluk haklalak.
\b
\q1 
\v 5 Maibee hau konfia Ita Boot nia domin rohan-laek;
\q2 hau nia laran haksolok tanba Ita Boot sei salva hau.
\q1 
\v 6 Hau sei hananu ba NAI Maromak
\q2 tanba Nia halo tiha ona buat diak mai hau.
\c 14
\s1 Halerik tanba ema nia hahalok aat
\d Salmu David nian, ba dirijenti koru.
\b
\q1 
\v 1 \x + \xo 14:1 \xt Roma 3:10-12\x*Ema beik sira koalia iha sira nia laran dehan,
\q2 “Maromak la iha!”
\q1 Ema sira nee mesak aat deit; sira nia hahalok aat teb-tebes;
\q2 la iha ema ida mak halo buat diak.
\b
\q1 
\v 2 NAI Maromak hateke tuun husi lalehan mai ita ema
\q2 hodi haree iha ema balu matenek ka lae,
\q2 ema balu harohan ba Maromak ka lae.
\q1 
\v 3 Maibee ema hotu lao sala dalan ona, sira hotu sai aat tiha ona;
\q2 la iha ema ida mak halo buat diak;
\q2 ida mos la iha.
\b
\q1 
\v 4 Ema aat sira nee la hatene buat ida ka?
\q2 Sira haan matak hau nia povu hanesan fali sira haan halimar paun fuan ida;
\q2 sira nunka bolu NAI Maromak nia naran.
\q1 
\v 5 Maibee haree ba, ema sira nee sei tauk teb-tebes,
\q2 tanba Maromak hamutuk ho ema nebee moris loos.
\q1 
\v 6 Imi ema aat sira hamnasa fali ema kbiit-laek sira nia planu,
\q2 maibee NAI Maromak foo mahon ba kbiit-laek sira nee.
\b
\q1 
\v 7 Hau harohan atu Maromak hamriik iha foho Siaun hodi salva Israel.
\q2 Bainhira NAI Maromak hadia fali Nia povu nia moris,
\q2 Jacó nia jerasaun sei haksolok, Israel sei kontenti.
\c 15
\s1 See mak bele adora Nai Maromak
\d Salmu David nian.
\b
\q1 
\v 1 NAI Maromak, see mak bele tama ba iha Ita Boot nia uma kreda?
\q2 See mak bele sae ba iha Ita Boot nia foho santu?
\b
\q1 
\v 2 Ema nebee lao iha dalan loos,
\q2 no halo buat nebee loos;
\q3 nia koalia lia loos husi nia laran.
\q1 
\v 3 Nia la hatete aat ema,
\q2 no la halo buat aat hasoru nia maluk;
\q3 nia la hatuun ema seluk.
\q1 
\v 4 Nia hakribi ema aat,
\q2 maibee respeita ema nebee hamtauk NAI Maromak;
\q3 nia kaer metin nia promesa maski todan ba nia.
\q1 
\v 5 Nia foo empresta osan ba ema kiak,
\q2 la husu funan.
\q1 Nia lakohi simu ema nia osan para foo sasin falsu
\q2 kontra ema nebee la sala.
\b
\q1 See deit mak halo buat sira nee
\q2 nunka atu nakdoko.
\c 16
\s1 Haksolok tanba Nai Maromak nia diak
\d Salmu\f + \fr 16:0 \ft Lian Ebreu dehan, “\it Miktam\it*”. Liafuan nee nia signifikadu la klaru.\f* David nian.
\b
\q1 
\v 1 Maromak, kuidadu hau ba,
\q2 tanba hau hamahon aan iha Ita Boot.
\q1 
\v 2 NAI Maromak, hau hatete ba Ita Boot dehan, “Ita Boot mak hau nia Nai;
\q2 buat diak hotu-hotu nebee hau iha mai husi Ita Boot.”
\b
\q1 
\v 3 Maromak nia povu santu iha rai nee furak teb-tebes;
\q2 hau kontenti liu ho sira.
\b
\q1 
\v 4 Ema nebee halai ba maromak sel-seluk sei susar ba beibeik.
\q2 Hau sei la foo oferta raan nian ba maromak sira nee;
\q2 hau nia ibun sei la temi sira nia naran.
\b
\q1 
\v 5 NAI Maromak, hau nia riku-soin mak Ita Boot;
\q2 Ita Boot foo bensaun mai hau;
\q2 hau nia destinu iha Ita Boot nia liman laran.
\q1 
\v 6 Fatin nebee Ita Boot foo mai hau furak;
\q2 riku-soin nebee Ita Boot foo mai hau kapaas teb-tebes.
\b
\q1 
\v 7 Hau sei hahii NAI Maromak, tanba Nia hatudu dalan mai hau;
\q2 iha oras kalan mos hau nia konsiensia hanorin hau.
\q1 
\v 8 Hau nia matan sempre hateke ba NAI;
\q2 Nia iha hela hau nia sorin, nunee la iha buat ida mak bele halo hau nakdoko.
\b
\q1 
\v 9 Nee mak hau nia laran haksolok, hau nia fuan kontenti;
\q2 hau nia isin mos hakmatek hela.
\q1 
\v 10 \x + \xo 16:10 \xt Apostolu sira nia Istoria 13:35\x*Tanba Ita Boot sei la husik hau iha ema mate sira nia fatin;
\q2 ema ida nebee moris loos, Ita Boot la husik nia isin dodok iha rate laran.
\q1 
\v 11 \x + \xo 16:11 \xt Apostolu sira nia Istoria 2:25-28\x*Ita Boot hatudu ona dalan moris mai hau;
\q2 Ita Boot sei halo hau nia laran haksolok teb-tebes iha Ita Boot nia oin;
\q2 hau kontenti tinan ba tinan iha Ita Boot nia liman loos.
\c 17
\s1 Ema laran moos halerik husu justisa
\d Orasaun David nian.
\b
\q1 
\v 1 NAI Maromak, hau husu justisa, rona hau ba;
\q2 foo atensaun ba hau nia halerik.
\q1 See tilun ba hau nia orasaun
\q2 tanba hau nia ibun la bosok ida.
\q1 
\v 2 Ita Boot sei deklara sai katak hau la sala,
\q2 tanba Ita Boot hatene saida mak loos.
\b
\q1 
\v 3 Ita Boot hatene mo-moos hau nia laran;
\q2 iha kalan Ita Boot mai investiga hau.
\q1 Ita Boot koko tiha ona hau maibee la hetan buat aat ida iha hau;
\q2 hau nia ibun sempre koalia buat nebee loos.
\q1 
\v 4 Hau la halo tuir ema aat nia hahalok;
\q2 hau hadook aan husi dalan violensia nian,
\q2 tanba hau kaer metin Ita Boot nia ukun fuan.
\q1 
\v 5 Hau sempre lao tuir Ita Boot nia dalan;
\q2 hau nia ain la sidi ida.
\b
\q1 
\v 6 Maromak, hau harohan ba Ita Boot, tanba Ita Boot sei hataan hau;
\q2 see tilun hodi rona hau nia lian.
\q1 
\v 7 Hatudu Ita Boot nia domin rohan-laek mai hau.
\q2 Ita Boot mak salva ema nebee buka mahon iha Ita Boot;
\q1 Bainhira sira iha Ita Boot nia liman loos,
\q2 sira nia inimigu la bele halo buat ida.
\b
\q1 
\v 8 Proteje hau hanesan Ita Boot kuidadu Ita Boot nia matan fuan;
\q2 subar hau iha Ita Boot nia liras okos
\q1 
\v 9 atu ema aat la bele ataka hau;
\q2 atu inimigu sira nebee haleu hau la bele oho hau.
\q1 
\v 10 Ema sira nee fuan toos;
\q2 sira koalia gaba aan.
\q1 
\v 11 Agora sira lao toman ona hau hodi haleu hau,
\q2 sira nia matan lakan atu soe tuun hau ba iha rai.
\q1 
\v 12 Sira hanesan liaun nebee mak hakarak atu lees hau;
\q2 sira hanesan liaun siak nebee mak hafuhu hela atu ataka hau.
\b
\q1 
\v 13 NAI Maromak, hamriik hasoru sira ba, hamonu sira ba;
\q2 ho Ita Boot nia surik salva hau husi ema aat sira nee.
\q1 
\v 14 NAI, hodi Ita Boot nia liman salva hau husi sira,
\q2 husi ema sira nebee mak hetan diak deit iha mundu nee.
\q1 Hau harohan atu buat nebee Ita Boot rai ba ema aat sira bele enxe sira nia kabun halo nakonu,
\q2 too sira nia oan sira bosu di-diak;
\q2 sira nia oan nurak sira mos hetan hotu.
\q1 
\v 15 Maibee hau nia matan sei haree Ita Boot,
\q2 tanba hau moris loos;
\q1 bainhira hau hadeer fali,
\q2 hau sei haksolok haree Ita Boot nia ilas.
\c 18
\s1 Liurai David agradese ba Nai Maromak tanba halakon nia inimigu
\d Salmu husi NAI Maromak nia atan David, ba dirijenti koru. Salmu nee nia kanta ba NAI Maromak bainhira NAI Maromak hasai nia husi Saul nia liman laran ho mos husi nia inimigu sira. David kanta nunee.
\b
\q1 
\v 1 NAI Maromak, hau hadomi Ita Boot;
\q2 Ita Boot mak hau nia forsa.
\b
\q1 
\v 2 NAI mak fatuk kuak boot nebee hau subar iha laran;
\q2 Nia mak lutu haleu hau;
\q2 Nia hau nia Salvador.
\b
\q1 Nia mak hau nia Maromak;
\q2 Nia mak fatuk kuak boot nebee hau subar iha laran.
\q1 Nia defende hau;
\q2 Nia kbiit salva hau;
\q2 Nia mak hau nia abrigu.
\q1 
\v 3 Hahii NAI Maromak! Tanba hau temi Nia naran,
\q2 Nia salva hau husi hau nia inimigu sira.
\b
\q1 
\v 4 Uluk tali mate nian bobar tiha hau;
\q2 mota tuun makaas halo hau mout;
\q1 
\v 5 korenti rate nian futu ona hau;
\q2 lasu mate nian iha hela hau nia oin.
\q1 
\v 6 Iha susar laran hau temi NAI Maromak nia naran;
\q2 hau halerik husu tulun ba Maromak.
\q1 Husi Nia hela fatin, Nia rona hau nia lian;
\q2 hau nia lia halerik tama too iha Nia tilun.
\b
\q1 
\v 7 Depois rai nakdoko no nakdedar;
\q2 foho nia huun nakdoko no nakdedar hotu,
\q2 tanba Nia hirus.
\q1 
\v 8 Suar sai husi Nia inus laran;
\q2 ahi lakan makaas sai husi Nia ibun laran;
\q2 ahi klaak lakan mean sai husi Nia ibun.
\q1 
\v 9 Nia loke lalehan hodi tuun mai;
\q2 kalohan metan iha hela Nia ain okos.
\q1 
\v 10 Nia manda anju tula Nia semo mai;
\q2 Nia haruka anin lori Nia mai lalais.
\q1 
\v 11 Nia falun Aan ho nakukun;
\q2 Nia taka Aan ho kalohan metan.
\q1 
\v 12 Iha Nia oin rai lakan fera kalohan metan nee,
\q2 jelu fatuk ho ahi lakan monu tuun.
\q1 
\v 13 NAI Maromak nia lian tarutu husi lalehan;
\q2 Maromak Aas Liu nia lian sai mai.
\q1 
\v 14 Nia hana Nia rama, inimigu sira halai namkari;
\q2 Nia haruka rai lakan boot duni lakon tiha sira.
\q1 
\v 15 NAI, Ita Boot siak sira
\q2 hodi huu iis makaas sai husi inus.
\q1 Ho nunee Ita Boot halo tasi been sai maran tiha,
\q2 no kolu molik tiha mundu.
\b
\q1 
\v 16 Husi fatin aas nebaa, Maromak nia liman kaer metin hau;
\q2 Nia dada hau sai husi bee naruk nia laran.
\q1 
\v 17 Nia salva hau husi hau nia inimigu nebee forti,
\q2 husi ema nebee odi hau no makaas liu hau.
\q1 
\v 18 Iha dezastre laran sira ataka hau,
\q2 maibee NAI Maromak tane hau.
\q1 
\v 19 Nia lori hau ba iha rai luan;
\q2 Nia salva hau tanba Nia haksolok ho hau.
\q1 
\v 20 NAI haree hau diak tanba hau moris loos;
\q2 Nia halo diak mai hau tanba hau nia liman moos.
\q1 
\v 21 Hau lao tuir nafatin NAI nia dalan;
\q2 hau nunka fila kotuk ba hau nia Maromak.
\q1 
\v 22 Nia lei tomak sempre iha hau nia oin;
\q2 hau la lao sees husi Nia ukun fuan.
\q1 
\v 23 Nia haree hau nia laran moos hela;
\q2 hau kuidadu hau nia aan atu la bele halo sala.
\q1 
\v 24 NAI halo diak mai hau tanba hau moris loos,
\q2 Nia hatene hau nia liman moos.
\b
\q1 
\v 25 NAI Maromak, Ita Boot foo laran ba ema nebee foo laran ba Ita Boot;
\q2 Ita Boot hatudu laran diak ba ema nebee laran moos.
\q1 
\v 26 Ita Boot sempre halo loos ba ema nebee moris loos,
\q2 maibee Ita Boot hatene oinsaa hasoru ema nebee halo manobra.
\q1 
\v 27 Ita Boot salva ema kbiit-laek sira,
\q2 maibee hatuun ema nebee mak foti aan.
\q1 
\v 28 NAI Maromak, Ita Boot mak halakan hau nia ahi oan:
\q2 Hau nia Maromak leno hau iha nakukun laran.
\q1 
\v 29 Ho Ita Boot nia tulun
\q2 hau bele avansa hodi kontra tropas inimigu sira;
\q1 ho hau nia Maromak nia ajuda
\q2 hau bele haksoit liu sira nia moru aas hodi tama ba laran.
\b
\q1 
\v 30 NAI Maromak nee, Nia dalan perfeitu:
\q2 Nia liafuan sempre loos;
\q2 Nia defende ema nebee mak buka mahon iha Nia.
\q1 
\v 31 So NAI deit mak Maromak, la iha tan seluk.
\q2 So ita nia Maromak deit mak fatuk lolon boot nebee hau helik ba.
\q1 
\v 32 Maromak mak foo forsa mai hau;
\q2 Nia kuidadu hau iha dalan.
\q1 
\v 33 \x + \xo 18:33 \xt Habakuk 3:19\x*Nia halo hau nia ain hanesan rusa fuik nian;
\q2 Nia halo hau hamriik metin iha fatin aas.
\q1 
\v 34 Nia treinu hau atu halo funu,
\q2 nunee hau bele uza rama diak nian hodi hana.
\q1 
\v 35 NAI Maromak, Ita Boot defende hau hodi salva hau nia moris;
\q2 Ita Boot tane hau;
\q2 Ita Boot nia tulun halo hau sai ema boot.
\q1 
\v 36 Ita Boot prepara dalan luan atu hau lao tuir,
\q2 ho nunee hau nia ain la sidi ba buat ida.
\b
\q1 
\v 37 Hau duni tuir hau nia inimigu sira too toman sira;
\q2 hau la hakiduk too sira mohu hotu.
\q1 
\v 38 Hau halo rahun tiha sira too sira la bele hamriik tan;
\q2 sira monu iha hau nia ain okos.
\q1 
\v 39 Ita Boot foo forsa mai hau atu halo funu;
\q2 Ita Boot halo ema nebee kontra hau hakruuk mai hau.
\q1 
\v 40 Ita Boot halo hau nia inimigu sira halai rungu-ranga;
\q2 hau halo rahun tiha ema nebee odi hau.
\q1 
\v 41 Sira tanis husu tulun, maibee la iha ema ida atu salva sira;
\q2 sira halerik husu tulun ba NAI Maromak, maibee Nia la hataan.
\q1 
\v 42 Hau baku rahun sira hanesan rai rahun nebee anin lori;
\q2 hau sama sira hanesan ema sama tahu iha dalan.
\q1 
\v 43 Ita Boot salva hau bainhira povu ataka hau;
\q2 Ita Boot halo hau sai nai ulun ba nasaun jentiu sira;
\q2 ema nebee uluk hau la konhese agora serbi hau.
\q1 
\v 44 Ema rai liur foin rona hau nia lian, sira halo tuir kedas;
\q2 sira lao hakruuk too iha hau nia oin.
\q1 
\v 45 Sira nia fuan lakon;
\q2 sira sai husi sira nia abrigu ho tauk no nakdedar.
\b
\q1 
\v 46 Hahii NAI Maromak! Maromak nee moris!
\q2 Nia mak fatuk lolon boot nebee hau helik ba.
\q1 Foti aas Nia naran!
\q2 Nia mak hau nia Salvador.
\q1 
\v 47 Maromak mak selu fali buat nebee hau nia inimigu sira halo mai hau;
\q2 Nia hamonu nasaun jentiu sira iha hau nia okos;
\q1 
\v 48 Maromak salva hau husi hau nia inimigu sira.
\q2 Tebes, Ita Boot foti hau aas liu hau nia funu baluk sira;
\q2 Ita Boot salva hau husi ema nebee gosta violensia.
\q1 
\v 49 \x + \xo 18:49 \xt Roma 15:9\x*Tanba nee NAI Maromak, hau sei hahii Ita Boot iha nasaun hotu-hotu nia klaran;
\q2 hau sei hananu hahii Ita Boot nia naran.
\q1 
\v 50 Maromak foo vitoria ba liurai nebee Nia hili hodi halo nia manaan liu dook;
\q2 Nia hatudu Nia laran luak ba liurai nebee mak Nia fihir,
\q2 ba David ho nia jerasaun nafatin ba nafatin.
\c 19
\s1 Nai Maromak nia liman fatin ho Nia lei hatudu sai Nia furak
\d Salmu David nian, ba dirijenti koru.
\b
\q1 
\v 1 Lalehan konta sai Maromak nia kbiit boot
\q2 hodi deklara buat furak nebee Nia liman kria tiha ona.
\q1 
\v 2 Loron hatoo lia menon ba loron;
\q2 kalan foo sai matenek ba kalan.
\q1 
\v 3 Lalehan nee la koalia, la uza liafuan;
\q2 la iha lian ruma mak atu bele rona husi nebaa.
\q1 
\v 4 \x + \xo 19:4 \xt Roma 10:18\x*Maski nunee lalehan nia lian sai ba iha rai tomak;
\q2 nia liafuan too iha rai ulun rai ikun iha mundu tomak.
\b
\q1 Iha lalehan Maromak harii hela tenda ba loro matan.
\q1 
\v 5 Loro matan nee mosu mai hanesan noivu ida nebee hakat sai husi nia festa kazamentu;
\q2 nia lao hanesan mane forti ida nebee haksolok hodi halai tuir dalan.
\q1 
\v 6 Loromatan lao tuir lalehan husi rohan ba rohan;
\q2 buat hotu-hotu senti loron nia manas.
\b
\q1 
\v 7 NAI Maromak nia lei perfeitu,
\q2 halo ita nia moris sai matak.
\q1 NAI nia mandamentu ita bele konfia,
\q2 halo ema matan tomak sai matenek.
\q1 
\v 8 NAI nia regra loos,
\q2 halo haksolok ita nia laran.
\q1 NAI nia ukun fuan nabilan,
\q2 leno ita nia matan.
\q1 
\v 9 Ita hamtauk ba NAI, nee diak,
\q2 dura tinan ba tinan.
\q1 NAI nia desizaun sempre loos,
\q2 justu ba ema hotu-hotu.
\q1 
\v 10 Buat sira nee folin boot liu osan mean,
\q2 liu fali osan mean moos nian;
\q1 midar liu bani been,
\q2 liu fali bani been nebee husi nia knuuk.
\q1 
\v 11 Buat sira nee hanorin Ita Boot nia atan;
\q2 see mak kaer metin, hetan bensaun boot.
\b
\q1 
\v 12 Maibee see mak bele hatene nia sala rasik?
\q2 Perdua hau nia sala nebee hau rasik la rekonhese.
\q1 
\v 13 Kuidadu mos Ita Boot nia atan hau husi hahalok nebee hau rasik hatene katak nee sala;
\q2 keta husik sala hirak nee domina hau.
\q1 Nunee hau sei livre husi hahalok aat;
\q2 hau sei la halo sala hasoru Ita Boot.
\b
\q1 
\v 14 Hau harohan atu hau nia liafuan ho hau nia reflesaun
\q2 monu ba Ita Boot nia laran.
\q1 NAI Maromak, Ita Boot mak fatuk lolon boot nebee hau helik ba;
\q2 Ita Boot mak hau nia Salvador.
\c 20
\s1 Orasaun atu liurai manaan funu
\d Salmu David nian, ba dirijenti koru.
\b
\q1 
\v 1 Hau harohan atu NAI Maromak hataan o nia orasaun bainhira o iha susar laran;
\q2 atu Jacó nia Maromak hamahon o.
\q1 
\v 2 Hau harohan atu Nia haraik tulun ba o husi Nia fatin santu;
\q2 atu Nia foo suporta ba o husi foho Siaun.
\q1 
\v 3 Hau harohan atu Nia konsidera o nia oferta hotu;
\q2 animal nebee o tunu hodi halo sakrifisiu mos monu ba Nia laran.
\b
\q1 
\v 4 Hau harohan atu Maromak foo buat nebee o nia laran hakarak,
\q2 no halo o nia planu hotu sai diak.
\q1 
\v 5 Depois ita sei haklalak kontenti tanba o manaan;
\q2 ita sei foti sae ita nia bandeira hodi ita nia Maromak nia naran.
\q1 Hau harohan atu NAI Maromak foo hotu buat nebee o husu.
\b
\q1 
\v 6 Agora hau hatene katak,
\q2 NAI Maromak salva liurai nebee Nia hili ona;
\q1 husi Nia lalehan santu, Nia hataan liurai nia orasaun;
\q2 hodi Nia kbiit, Nia halo liurai manaan.
\q1 
\v 7 Ema balu konfia nia kareta funu, balu konfia nia kuda,
\q2 maibee ami konfia ami nia NAI Maromak nia naran.
\q1 
\v 8 Sira sei monu hakdasak,
\q2 maibee ami sei hadeer hodi tuba rai metin.
\b
\q1 
\v 9 NAI, halo liurai manaan ba;
\q2 bainhira ami harohan ba Ita Boot, hataan ami ba!
\c 21
\s1 Kantiku hahii Nai Maromak tanba liurai manaan funu
\d Salmu David nian, ba dirijenti koru.
\b
\q1 
\v 1 NAI Maromak, liurai haksolok haree Ita Boot nia kbiit;
\q2 nia kontenti teb-tebes tanba Ita Boot halo nia manaan.
\q1 
\v 2 Ita Boot foo buat nebee nia laran hakarak;
\q2 buat nebee nia ibun husu, Ita Boot hataan duni.
\b
\q1 
\v 3 Ita Boot simu liurai hodi foo bensaun boot ba nia;
\q2 Ita Boot tau koroa osan mean diak nian ba iha nia ulun.
\q1 
\v 4 Nia husu Ita Boot atu foo vida naruk, Ita Boot foo;
\q2 Ita Boot halo nia moris nafatin ba nafatin.
\q1 
\v 5 Ita Boot halo liurai manaan, nunee nia naran sai boot;
\q2 Ita Boot halo nia sai konhesidu, no ema respeita teb-tebes nia.
\q1 
\v 6 Loos duni, Ita Boot foo bensaun ba nia la hotu la remata;
\q2 Ita Boot halo nia haksolok teb-tebes iha Ita Boot nia oin.
\q1 
\v 7 Liurai konfia NAI Maromak;
\q2 Maromak Aas Liu nia domin rohan-laek
\q2 halo liurai la nakdoko.
\b
\q1 
\v 8 Liurai, o nia liman sei kaer o nia inimigu sira hotu;
\q2 o nia liman loos sei kaptura ema nebee odi o.
\q1 
\v 9 Bainhira o mosu iha sira nia oin,
\q2 o sei soe sira ba iha ahi lakan boot.
\q1 NAI Maromak sei hirus hodi tolan tiha sira;
\q2 Nia ahi sei haan mutuk tiha sira.
\q1 
\v 10 O sei halo rahun tiha sira nia jerasaun iha mundu;
\q2 sira nia bei-oan sei lakon mohu husi ema nia klaran.
\q1 
\v 11 Maski o nia inimigu sira kombina malu hasoru o
\q2 hodi halo manobra oi-oin, sira sei la manaan.
\q1 
\v 12 O hana sira ho o nia rama,
\q2 halo sira halai tiha.
\b
\q1 
\v 13 NAI Maromak, hodi Ita Boot nia forsa hamriik ba!
\q2 Ami sei hananu hodi hahii Ita Boot nia kbiit.
\c 22
\s1 Harohan ba Nai Maromak iha susar laran
\d Salmu David nian, ba dirijenti koru. Tuir muzika Rusa Dadeer-saan.
\b
\q1 
\v 1 \x + \xo 22:1 \xt Mateus 27:46; Marcos 15:34\x*Hau nia Maromak, hau nia Maromak, tansaa mak Ita Boot husik hau mesak?
\q2 Hau halerik ho laran dodok para Ita Boot tulun hau;
\q3 tansaa mak Ita Boot dook loos husi hau?
\q1 
\v 2 Hau nia Maromak, loron hau halerik husu tulun, maibee Ita Boot la hataan;
\q2 hau halerik kalan, maibee la hetan pas.
\b
\q1 
\v 3 Ita Boot mak santu;
\q2 Ita Boot mak Liurai nebee ema Israel sira adora.
\q1 
\v 4 Ami nia bei-ala sira fiar Ita Boot;
\q2 sira fiar mak Ita Boot tulun sira.
\q1 
\v 5 Sira tanis hakilar ba Ita Boot mak Ita Boot salva sira;
\q2 sira fiar ba Ita Boot la saugati.
\b
\q1 
\v 6 Maibee hau hanesan ular oan deit, laos ema;
\q2 ema hotu hatete aat hau, no hakribi hau.
\q1 
\v 7 Ema hotu nebee haree hau hamoe hau;
\q2 sira dulas ibun mai hau hodi doko ulun.
\q1 
\v 8 Sira dehan, “Nia fiar NAI Maromak;
\q2 husik Maromak mak salva nia.
\q1 Se Maromak kontenti ho nia,
\q2 entaun Maromak mak hasai nia ba.”
\b
\q1 
\v 9 Maibee Ita Boot mak lori hau sai husi hau nia inan nia kanotak;
\q2 Ita Boot hatoba hau iha hau nia inan nia hirus matan.
\q1 
\v 10 Husi kedas hau moris, hau nee Ita Boot nian;
\q2 dezde hau sei iha hau nia inan nia kabun laran, Ita Boot sai tiha ona hau nia Maromak.
\b
\q1 
\v 11 Keta dook husi hau,
\q2 tanba susar besik hela hau,
\q3 no ema atu tulun hau la iha.
\q1 
\v 12 Karau aman barak haleu hau;
\q2 karau aman mesak forti deit mak serku hau.
\q1 
\v 13 Sira hanesan liaun nebee hakilar hodi lees ema;
\q2 sira loke sira nia ibun luan hodi kontra hau.
\b
\q1 
\v 14 Hau nia forsa hanesan bee nebee fakar sai ba rai;
\q2 hau nia ruin sira hotu naksalak tiha ona.
\q1 Hau nia fuan hanesan lilin
\q2 nebee nabeen tiha ona iha hau nia laran.
\q1 
\v 15 Hau nia ibun maran dekor hanesan sanan rai;
\q2 hau nia nanaal toos tiha ona iha hau nia ibun laran;
\q2 Ita Boot latan tiha ona hau iha rai rahun.
\b
\q1 
\v 16 Ema aat lubuk ida hobur hau;
\q2 sira serku hau hanesan asu;
\q3 sira sona borus hau nia liman ho ain.\f + \fr 22:16 \ft Orijinal iha linha nee la klaru. \f*
\q1 
\v 17 Hau nia ruin tomak bele sura;
\q2 ema hateke mai hau no fihir hau.
\q1 
\v 18 Sira fahe hau nia hena ba malu;
\q2 sira dada rifa para hatene, hau nia hena nee monu ba see.
\b
\q1 
\v 19 Maibee NAI Maromak, Ita Boot keta dook husi hau.
\q2 Ita Boot mak hau nia forsa; mai lalais tulun hau.
\q1 
\v 20 Salva hau husi surik;
\q2 salva hau nia moris husi asu forti sira nee.
\q1 
\v 21 Dada sai hau husi liaun nia ibun laran;
\q2 salva hau husi karau fuik nia dikur.\f + \fr 22:21 \ft Orijinal iha linha nee la klaru.\f*
\b
\q1 
\v 22 Hau sei koalia sai ba hau nia maluk sira kona ba Ita Boot nia diak;
\q2 iha povu nia leet hau sei hahii Ita Boot.
\q1 
\v 23 Imi sira nebee hamtauk NAI Maromak, hahii NAI ba!
\q2 Imi Jacó nia jerasaun, hotu-hotu foti aas NAI ba!
\q2 Imi Israel nia jerasaun, hotu-hotu respeita Nia ho tauk ba!
\q1 
\v 24 Tanba Nia la hakribi no la hatuun
\q2 ema nebee terus ho susar.
\q1 Nia la subar oin ba sira,
\q2 maibee see tilun ba sira bainhira sira halerik husu tulun.
\b
\q1 
\v 25 Hau sei hahii Ita Boot iha ema lubuk boot nia leet;
\q2 iha fiar nain sira nia oin hau sei foo oferta nebee hau promete tiha ona atu foo ba Ita Boot.
\q1 
\v 26 Ema kiak sira sei haan too bosu;
\q2 ema nebee buka NAI Maromak sei hahii Nia.
\q2 Hau hein katak sira hetan moris diak too tinan ba tinan.
\b
\q1 
\v 27 Ema husi rai ulun too rai ikun iha mundu tomak
\q2 sei hanoin NAI Maromak hodi fila ba Nia;
\q1 ema husi suku hotu-hotu
\q2 sei hakneak hakruuk iha Nia oin.
\q1 
\v 28 Tanba NAI mak Ukun Nain;
\q2 Nia ukun nasaun hotu-hotu.
\b
\q1 
\v 29 Ema riku hotu-hotu iha mundu sei halo festa hodi adora Nia;
\q2 ema nebee atu tuun ba iha rai rahun, sira hotu sei hakneak iha Nia oin.
\q1 
\v 30 Ema nebee seidauk moris sei serbi Nia;
\q2 jerasaun sira aban-bainrua sei koalia kona ba Nai Maromak.
\q1 
\v 31 Sira sei foo sai Nia salvasaun; \f + \fr 22:31 \ft Liafuan Ebreu iha nee bele signifika “salvasaun”, bele mos “justisa”.\f*
\q2 sira sei foo hatene ba ema sira nebee seidauk moris
\q2 katak Maromak salva tiha ona Nia povu.
\c 23
\s1 Nai Maromak mak hau nia Bibi Atan
\d Salmu David nian.
\b
\q1 
\v 1 NAI Maromak mak hau nia Bibi Atan;
\q2 hau la falta buat ida.
\q1 
\v 2 \x + \xo 23:2 \xt Apokalipse 7:17\x*Nia halo hau toba iha duut matak;
\q2 Nia lori hau ba iha bee matan.
\q1 
\v 3 Nia hafoun fali hau nia laran;
\q2 Nia lori hau tuir dalan loos
\q3 atu ema foti aas Nia naran.
\q1 
\v 4 Maski hau lao
\q2 iha fatin nebee nakukun teb-tebes,
\q1 hau la tauk buat ida
\q2 tanba Ita Boot hamutuk ho hau.
\q1 Ita Boot nia ai tonka ho rota
\q2 proteje hau hodi halo hau nia laran hakmatek.
\b
\q1 
\v 5 Ita Boot tau meza mai hau
\q2 iha hau nia inimigu sira oin;
\q1 Ita Boot simu hau hanesan bainaka boot ida,
\q2 no enxe hau nia kopu too nakonu.
\q1 
\v 6 Tebes duni, Ita Boot nia diak ho Ita Boot nia laran luak sei hamutuk ho hau
\q2 iha hau nia moris tomak;
\q1 hau sei hela iha NAI Maromak nia uma
\q2 nafatin ba nafatin.
\c 24
\s1 Nai Maromak mak Liurai boot
\d Salmu David nian.
\b
\q1 
\v 1 \x + \xo 24:1 \xt 1 Korintu 10:26\x*Mundu ho buat hotu iha mundu nee, NAI Maromak nian;
\q2 rai ho buat hotu nebee moris iha rai nee, Ninian hotu.
\q1 
\v 2 Tanba Nia mak harii buat hirak nee iha tasi leten;
\q2 Nia hatuur buat sira nee hotu iha bee leten.
\b
\q1 
\v 3 See mak bele sae ba NAI Maromak nia foho?
\q2 See mak bele hamriik iha Nia fatin santu?
\q1 
\v 4 \x + \xo 24:4 \xt Mateus 5:8\x*Ema nebee liman moos ho laran moos,
\q2 ema nebee la adora fatuk lulik ka ai lulik,
\q2 ema nebee la halo juramentu falsu.
\q1 
\v 5 Ema sira nee sei simu bensaun husi NAI Maromak;
\q2 Maromak nudar sira nia Salvador sei deklara katak sira la sala.
\q1 
\v 6 Ema hanesan nee mak harohan ba Maromak;
\q2 sira hakbesik aan ba Jacó nia Maromak.
\b
\q1 
\v 7 Imi portaun sira, foti sae imi nia ulun ba;
\q2 imi odamatan antigu nian, loke aan ba,
\q2 para Liurai kbiit boot bele tama mai.
\q1 
\v 8 Liurai kbiit boot nee see?
\q2 Nia nee NAI Maromak, Nia forsa teb-tebes ho kbiit boot;
\q2 Nia nee NAI Maromak, funu nain boot.
\q1 
\v 9 Imi portaun sira, foti sae imi nia ulun ba;
\q2 imi odamatan antigu nian, loke aan ba,
\q2 para Liurai kbiit boot bele tama mai.
\q1 
\v 10 Liurai kbiit boot nee see?
\q2 NAI Maromak Aswain,
\q2 Nia mak Liurai kbiit boot.
\c 25
\s1 Orasaun husu tulun ba Nai Maromak
\d Salmu David nian.
\b
\q1 
\v 1 NAI, hau nia Maromak,
\q2 hau konfia Ita Boot.
\q1 
\v 2 Hau fiar Ita Boot;
\q2 keta husik hau moe leet;
\q2 keta husik hau nia inimigu sira mak manaan.
\q1 
\v 3 Ema nebee laran metin ba Ita Boot,
\q2 sei la moe leet;
\q1 ema nebee traidor nar-naran deit,
\q2 nia mak moe.
\b
\q1 
\v 4 NAI Maromak, hatudu Ita Boot nia dalan mai hau;
\q2 hanorin hau atu lao tuir Ita Boot nia ain fatin.
\q1 
\v 5 Tulun hau atu moris tuir Ita Boot nia lia loos, no hanorin hau,
\q2 tanba Ita Boot mak hau nia Salvador;
\q2 loron-kalan hau laran metin ba Ita Boot.
\q1 
\v 6 NAI, hori uluk kedas Ita Boot hatudu ona Ita Boot nia laran luak ho domin rohan-laek;
\q2 hatudu nafatin ba.
\q1 
\v 7 Keta hanoin tan pekadu nebee hau halo bainhira sei joven;
\q2 haluha tiha sala nebee hau halo kontra Ita Boot.
\q1 NAI, hanoin hau ba,
\q2 tanba Ita Boot nia domin ho Ita Boot nia diak.
\b
\q1 
\v 8 NAI Maromak nee laran diak no laran moos,
\q2 nunee mak Nia hanorin sala nain sira tuir Nia dalan.
\q1 
\v 9 Nia tulun ema mukit sira atu halo buat nebee loos;
\q2 Nia hanorin sira kona ba Nia dalan.
\q1 
\v 10 NAI nia dalan nakonu ho domin ho lia loos;
\q2 Nia hatudu dalan nee ba ema sira nebee kaer metin Nia promesa ho Nia lei.
\b
\q1 
\v 11 NAI Maromak, hau nia sala boot, perdua hau ba,
\q2 atu nunee ema foti aas Ita Boot nia naran.
\q1 
\v 12 Ema nebee mak hamtauk NAI Maromak,
\q2 Maromak sei hanorin sira oinsaa atu moris.
\q1 
\v 13 Sira sei moris diak;
\q2 sira nia jerasaun sei hela metin nafatin iha sira nia rain.
\q1 
\v 14 NAI sai belun ba ema nebee hamtauk Nia;
\q2 Nia foo hatene Nia promesa ho Nia lei ba sira.
\q1 
\v 15 Hau nia matan hateke metin ba NAI,
\q2 tanba so Nia deit mak sei hasai hau nia ain husi lasu laran.
\b
\q1 
\v 16 See oin mai hau hodi hanoin hau ba,
\q2 tanba hau mesak deit no kbiit-laek.
\q1 
\v 17 Halo kamaan susar nebee iha hau nia laran;
\q2 hasai hau husi terus laran.
\q1 
\v 18 Hateke ba hau nia naha todan ho hau nia laran taridu;
\q2 hamoos tiha hau nia sala hotu.
\q1 
\v 19 Haree ba, hau nia inimigu barak teb-tebes;
\q2 sira odi loos hau!
\q1 
\v 20 Kuidadu hau nia moris hodi salva hau;
\q2 keta husik ema hamoe hau,
\q2 tanba hau hamahon aan iha Ita Boot.
\q1 
\v 21 NAI Maromak, hau hein katak hau nia hahalok loos ho laran moos bele proteje hau,
\q2 tanba hau laran metin iha Ita Boot.
\b
\q1 
\v 22 Maromak, salva Israel
\q2 husi susar laran ba!
\c 26
\s1 Ema laran moos harohan husu justisa
\d Salmu David nian.
\b
\q1 
\v 1 NAI Maromak, foo justisa mai hau,
\q2 tanba hau ema nebee moris loos;
\q2 hau konfia NAI ho laran tomak.
\q1 
\v 2 NAI, koko hau no prova hau ba;
\q2 tetu di-diak hau nia neon ho laran,
\q1 
\v 3 tanba hau sempre hanoin hela deit Ita Boot nia domin rohan-laek,
\q2 no hau konfia Ita Boot tanba Ita Boot sempre kaer metin Ita Boot nia liafuan.
\q1 
\v 4 Hau la tuur hamutuk ho ema lohi door;
\q2 hau mos la ranxu ema nebee koalia oin ida hahalok oin seluk.
\q1 
\v 5 Hau haree ema aat sira halibur hamutuk, hau hakribi;
\q2 hau lakohi tuur hamutuk ho ema nebee hahalok aat.
\q1 
\v 6 NAI Maromak, hau nia liman moos hatudu katak hau la sala;
\q2 hau lao haleu Ita Boot nia altar
\q1 
\v 7 hodi hahii Ita Boot ho lian makaas
\q2 no konta sai buat furak nebee Ita Boot halo tiha ona.
\q1 
\v 8 NAI Maromak, hau gosta uma nebee mak Ita Boot hela ba,
\q2 fatin nebee mak Ita Boot nia naroman nabilan horik ba.
\b
\q1 
\v 9 Keta dasa sai hau hamutuk ho sala nain sira;
\q2 keta hasai hau nia vida hamutuk ho ema nebee hamrook ba raan.
\q1 
\v 10 Sira nia liman toman halo buat aat;
\q2 sira nia liman loos nakonu ho korupsaun.
\q1 
\v 11 Maibee hau nee ema nebee moris loos;
\q2 salva hau, hatudu Ita Boot nia laran luak mai hau.
\q1 
\v 12 Hau nia ain hamriik metin iha rai tetuk;
\q2 Hau sei hahii NAI Maromak iha ema lubuk boot nia leet.
\c 27
\s1 Hahii Nai Maromak no husu tulun
\d Salmu David nian.
\b
\q1 
\v 1 NAI Maromak nia naroman leno hau nia dalan;
\q2 Nia mak hau nia Salvador.
\q2 Hau atu tauk see?
\q1 NAI mak abrigu ba hau nia moris.
\q2 Hau atu nakdedar ba see?
\b
\q1 
\v 2 Bainhira ema aat mai atu tolan hau,
\q2 hau nia inimigu ho funu baluk sira nee mak sei sidi no monu.
\q1 
\v 3 Maski tropas mai serku hau,
\q2 hau nia laran sei la tauk;
\q1 maski funu mosu kontra hau,
\q2 hau fiar nafatin.
\b
\q1 
\v 4 Iha deit buat ida mak hau husu ba NAI Maromak;
\q2 ida nee deit mak hau buka.
\q1 Hau hakarak atu loro-loron durante hau nia moris tomak,
\q2 hau hela iha NAI nia uma
\q1 hodi hateke ba NAI nia furak,
\q2 no harohan ba Nia iha Nia uma kreda.
\q1 
\v 5 Tanba iha tempu susar,
\q2 Nia sei halo hau hakmatek iha Nia tenda laran;
\q1 Nia sei subar hau iha Nia fatin santu;
\q2 Nia sei hatuur hau iha fatuk boot ida nia leten.
\q1 
\v 6 Nia foti aas tiha ona hau
\q2 iha hau nia inimigu sira hotu nia klaran.
\q1 Hau sei haklalak hodi lori sakrifisiu ba iha Nia fatin santu;
\q2 hau sei hananu no halo muzika ba NAI.
\b
\q1 
\v 7 NAI Maromak, bainhira hau bolu Ita Boot, see tilun mai hau;
\q2 hatudu Ita Boot nia laran diak hodi hataan mai hau.
\q1 
\v 8 Hau hatete ba hau nia aan, “Adora Nia ba!”
\q2 NAI, hau sei adora duni Ita Boot.
\q1 
\v 9 Keta subar Ita Boot nia oin mai hau;
\q2 keta duni sai Ita Boot nia atan ho hirus,
\q2 tanba Ita Boot tulun tiha ona hau.
\q1 Maromak hau nia salvador,
\q2 keta duni hau fila, keta husik hau mesak.
\q1 
\v 10 Maski hau nia inan-aman husik hau mesak mos,
\q2 NAI, Ita Boot sei simu hau.
\b
\q1 
\v 11 NAI Maromak, hanorin Ita Boot nia dalan mai hau;
\q2 lori hau tuir dalan loos
\q2 tanba hau iha inimigu barak.
\q1 
\v 12 Keta saran hau ba hau nia funu baluk sira,
\q2 tanba iha sasin falsu hamriik hasoru hau;
\q2 sira duun matak hau hodi ameasa hau.
\b
\q1 
\v 13 Hau fiar katak hau sei moris
\q2 hodi haree NAI nia diak.
\q1 
\v 14 Laran metin ba NAI;
\q2 sai forti ba, aten brani ba.
\q2 Laran metin ba NAI!
\c 28
\s1 Harohan husu tulun
\d Salmu David nian.
\b
\q1 
\v 1 NAI Maromak, hau harohan ba Ita Boot.
\q2 Ita Boot mak fatuk lolon boot nebee hau helik ba;
\q2 keta taka tilun mai hau.
\q1 Se Ita Boot nonook nafatin,
\q2 hau sei sai hanesan sira nebee mak tuun ba rai kuak.
\q1 
\v 2 Hau see oin ba iha Ita Boot nia Fatin nebee Lulik Liu
\q2 hodi foti sae hau nia liman;
\q1 hau halerik husu tulun ba Ita Boot;
\q2 rona hau nia lian ba!
\b
\q1 
\v 3 Keta duni sai hau hamutuk ho ema aat sira,
\q2 hamutuk ho sira nebee mak toman halo buat aat,
\q1 sira nebee mak finji koalia diak ba sira nia maluk,
\q2 maibee rai odi iha laran.
\q1 
\v 4 \x + \xo 28:4 \xt Apokalipse 22:12\x*Selu fali sira tuir saida mak sira halo;
\q2 foo ba sira tuir sira nia hahalok aat.
\q1 Selu fali sira tuir saida mak sira nia liman halo tiha ona;
\q2 foo todan ba sira tuir sira merese simu.
\q1 
\v 5 Sira la rekonhese buat nebee mak NAI Maromak halo tiha ona
\q2 ho buat nebee mak Nia liman kria tiha ona.
\q1 Nunee Nia sei sobu sira,
\q2 no nunka atu harii fila fali.
\b
\q1 
\v 6 Hahii NAI Maromak,
\q2 tanba Nia rona ona hau nia halerik husu tulun.
\q1 
\v 7 NAI mak hau nia forsa, Nia defende hau;
\q2 hau nia laran metin ba Nia;
\q1 Nia tulun hau hodi halo hau nia laran haksolok teb-tebes;
\q2 hau hananu hau nia kantiku hodi hahii Nia.
\b
\q1 
\v 8 NAI Maromak foo forsa ba Nia povu;
\q2 Nia mak abrigu hodi salva liurai nebee mak Nia hili tiha ona.
\q1 
\v 9 NAI, salva Ita Boot Nia povu.
\q2 Sira nee Ita Boot nia riku-soin, foo bensaun ba!
\q1 Sai sira nia Bibi Atan
\q2 hodi tau matan ba sira tinan ba tinan.
\c 29
\s1 Nai Maromak nia lian hanesan rai lakan ho rai tarutu
\d Salmu David nian.
\b
\q1 
\v 1 \x + \xo 29:1 \xt Salmu 96:7-9\x*Imi sira nebee hela iha lalehan, hahii NAI Maromak ba;
\q2 hahii NAI tanba Nia kbiit boot ho forsa.
\q1 
\v 2 Hahii NAI tanba nia naran boot;
\q2 adora Nia tanba Nia santu ho furak.
\b
\q1 
\v 3 NAI Maromak nia lian baku iha tasi leten;
\q2 Maromak kbiit boot nia lian tarutu;
\q2 NAI nia lian tarutu iha tasi boot nia leten.
\q1 
\v 4 NAI nia lian makaas teb-tebes;
\q2 NAI nia lian hatudu sai Nia kbiit.
\q1 
\v 5 NAI nia lian silu tohar ai huun boot sedru;
\q2 too ai huun boot iha foho Líbanu nian mos NAI fera tiha sai rohan-rohan.
\q1 
\v 6 Nia halo foho Líbanu nian haksoit hanesan fali karau oan;
\q2 foho Sirión\f + \fr 29:6 \ft Foho Sirión nia naran seluk mak Hermon.\f* mos haksoit hanesan karau fuik nia oan.
\q1 
\v 7 NAI nia lian halo rai lakan makaas.
\q1 
\v 8 NAI nia lian doko rai fuik maran;
\q2 NAI doko rai fuik maran Kades nian.
\q1 
\v 9 NAI nia lian dulas ai huun boot,
\q2 too ai huun sira iha ai laran tuan mos tahan namtate hotu.
\q1 Iha Nia uma kreda, ema hotu-hotu haklalak dehan,
\q2 “Foti aas Nia naran!”
\b
\q1 
\v 10 NAI Maromak tuur iha Nia kadeira ukun iha bee boot leten;
\q2 NAI tuur hodi ukun nudar Liurai tinan ba tinan.
\q1 
\v 11 NAI foo kbiit ba Nia povu;
\q2 NAI foo bensaun ba Nia povu hodi foo pas ho hakmatek ba sira.
\c 30
\s1 Agradese ba Nai Maromak tanba hetan kura
\d Salmu David nian. Kantiku bainhira selebra loron inaugurasaun uma kreda.
\b
\q1 
\v 1 NAI Maromak, hau sei gaba Ita Boot,
\q2 tanba Ita Boot dada tiha ona hau sai husi rai kuak;
\q2 Ita Boot la husik hau nia inimigu sira foti aan hasoru hau.
\q1 
\v 2 NAI, hau nia Maromak, uluk hau halerik husu tulun ba Ita Boot;
\q2 agora Ita Boot kura tiha ona hau.
\q1 
\v 3 NAI, Ita Boot lori ona hau sai husi matebian sira nia fatin;
\q2 Ita Boot la husik hau lao hamutuk ho ema sira nebee tuun dadauk ba rai kuak.
\b
\q1 
\v 4 Imi povu nebee foo laran ba NAI Maromak, hananu hahii Nia ba;
\q2 hahii Nia naran santu,
\q1 
\v 5 tanba Nia hirus iha tempu badak deit,
\q2 maibee Nia hatudu Nia laran luak ba ita durante ita nia moris tomak.
\q1 Ita bele tanis halerik iha oras kalan,
\q2 maibee iha dadeer-saan ita hetan ksolok.
\b
\q1 
\v 6 Uluk hau senti hakmatek, hau dehan,
\q2 “Hau nunka atu nakdoko.”
\q1 
\v 7 NAI Maromak, bainhira Ita Boot hatudu Ita Boot nia laran luak mai hau,
\q2 Ita Boot halo hau hamriik metin hanesan foho boot ida.
\q1 Maibee bainhira Ita Boot subar oin mai hau,
\q2 hau nia fuan taridu.
\b
\q1 
\v 8 NAI Maromak, uluk hau harohan ba Ita Boot;
\q2 hau husu atu Nai hanoin hau.
\q1 
\v 9 Hau dehan, “Se karik hau mate,
\q2 se karik hau tuun ba iha rai kuak, iha folin saida?
\q1 Rai rahun bele hahii Ita Boot ka?
\q2 Rai rahun bele deklara katak Ita Boot nia laran diak dura nafatin ka?
\q1 
\v 10 NAI, rona hau, hatudu Ita Boot nia laran luak mai hau;
\q2 NAI, ajuda hau ba!”
\b
\q1 
\v 11 Uluk hau tanis lelir,
\q2 maibee Ita Boot foo ksolok mai hau, halo hau bidu.
\q1 Ita Boot hasai tiha hena lutu nian husi hau
\q2 hodi foo hatais fali hena ksolok nian.
\q1 
\v 12 Nunee hau sei la nonook; hau sei hananu hahii Ita Boot.
\q2 NAI, hau nia Maromak, hau sei agradese ba Ita Boot tinan ba tinan.
\c 31
\s1 Hakmatek iha Nai Maromak nia liman laran
\d Salmu David nian, ba dirijenti koru.
\b
\q1 
\v 1 NAI Maromak, hau hamahon aan iha Ita Boot;
\q2 keta husik hau moe leet;
\q2 salva hau tanba Ita Boot sempre halo buat nebee loos.
\q1 
\v 2 See tilun mai hau;
\q2 mai lalais hodi salva hau.
\q1 Sai hau nia subar fatin, hanesan fatuk lolon boot para hau helik ba;
\q2 sai hanesan lutu metin ida hodi satan netik hau.
\q1 
\v 3 Ita Boot mak fatuk kuak nebee hau subar iha laran;
\q2 Ita Boot mak lutu haleu hau.
\q1 Lori hau hodi hatudu dalan mai hau,
\q2 atu nunee ema foti aas Ita Boot nia naran.
\q1 
\v 4 Kuidadu hau para hau la bele monu ba lasu nebee ema prepara hela ba hau,
\q2 tanba Ita Boot mak hau nia subar fatin.
\q1 
\v 5 \x + \xo 31:5 \xt Lucas 23:46\x*Hau entrega hau nia moris ba iha Ita Boot nia liman;
\q2 NAI Maromak, Ita Boot nia laran sempre hanoin hau, salva hau ba.
\b
\q1 
\v 6 NAI Maromak, hau\f + \fr 31:6 \ft Iha dokumentu Ebreu antigu ida ho mos tradusaun antigu balu dehan, “Ita Boot”. \f* odi ema nebee adora estatua lulik, buat sira nee la iha folin.
\q2 Hau laos hanesan ema sira nee, hau konfia Ita Boot.
\q1 
\v 7 Hau sei kontenti haksolok
\q2 tanba Ita Boot nia domin rohan-laek.
\q1 Ita Boot haree tiha ona hau nia terus;
\q2 Ita Boot hatene ona hau nia laran susar.
\q1 
\v 8 Ita Boot la entrega hau ba inimigu sira nia liman laran,
\q2 maibee tau hau nia ain iha fatin luan.
\b
\q1 
\v 9 NAI Maromak, hau iha fatin kloot laran;
\q2 hanoin hau ba.
\q1 Hau nia matan sai malahuk tiha tanba hau nia laran dodok;
\q2 hau nia isin ho klamar terus hotu.
\q1 
\v 10 Hau nia vida nakonu ho tristi;
\q2 hau nia moris tomak hau halerik hela deit.
\q1 Terus ho susar nee halo hau nia forsa tuun ba dadauk
\q2 too hau nia ruin sira mamar hotu ona.
\q1 
\v 11 Hau nia inimigu sira hatuun hau;
\q2 hau nia vizinhu sira hatete aat hau;
\q1 hau nia belun sira haree hau, sira tauk;
\q2 ema nebee hasoru hau iha estrada halai sees tiha.
\q1 
\v 12 Ema haluha hau hanesan fali hau mate tiha ona;
\q2 hau hanesan vazu nebee nakfera tiha ona.
\q1 
\v 13 Hau rona ema barak bis-bisu
\q2 hodi hatauk hau husi sor-sorin.
\q1 Sira kombina malu hodi kontra hau;
\q2 sira halo planu atu hasai hau nia vida.
\b
\q1 
\v 14 Maibee NAI, hau konfia Ita Boot;
\q2 hau dehan, “Ita Boot mak hau nia Maromak.”
\q1 
\v 15 Hau nia vida tomak iha Ita Boot nia liman laran;
\q2 hasai hau husi hau nia inimigu sira nia liman,
\q2 husi ema nebee halo terus hau.
\q1 
\v 16 Halo Ita Boot nia oin leno Ita Boot nia atan hau;
\q2 salva hau hodi Ita Boot nia domin rohan-laek.
\q1 
\v 17 NAI, hau harohan ba Ita Boot;
\q2 keta husik hau moe leet.
\q1 Husik ema aat sira mak moe ba;
\q2 husik sira tuun lian-laek ba iha ema mate nia fatin.
\q1 
\v 18 Halo sira nia ibun nonook tiha,
\q2 tanba sira foti aan hatuun ema nebee moris loos
\q2 hodi hatete aat sira.
\b
\q1 
\v 19 Ita Boot rai hela buat mesak furak
\q2 hodi foo ba ema nebee hamtauk Ita Boot;
\q1 iha ema hotu nia oin, Ita Boot haraik buat diak sira nee
\q2 ba ema nebee buka mahon iha Ita Boot.
\q1 
\v 20 Ita Boot subar sira iha Ita Boot nia prezensa
\q2 atu ema nia planu aat la bele kona sira;
\q1 Ita Boot halo sira seguru iha Ita Boot nia fatin,
\q2 dook husi ema nebee duun sira.
\b
\q1 
\v 21 Hahii NAI Maromak,
\q2 tanba Nia hatudu Nia domin nebee furak teb-tebes mai hau.
\q1 Bainhira inimigu sira serku hau,
\q2 
\v 22 hau tauk hodi hanoin,
\q2 “Maromak dasa sai tiha ona hau husi Nia oin!”
\q1 Maibee lae, bainhira hau halerik husu tulun ba Nia,
\q2 Nia rona hela hau nia orasaun.
\b
\q1 
\v 23 Povu hotu nebee foo laran ba NAI Maromak, hadomi Nia ba!
\q2 NAI tau matan ba ema nebee moris loos,
\q2 maibee ema nebee foti aan, Nia foo kastigu tuir sira nia hahalok.
\q1 
\v 24 Imi sira nebee laran metin ba NAI,
\q2 sai forti ba, aten brani ba!
\c 32
\s1 Haksolok tanba hetan perdaun husi Nai Maromak
\d Salmu David nian para hanorin ema.
\b
\q1 
\v 1 \x + \xo 32:1 \xt Roma 4:7,8\x*Se ema kontra Maromak nia lei maibee Maromak foo perdaun,
\q2 ema nee hetan bensaun.
\q1 Se nia halo sala maibee Maromak hamoos tiha nia sala,
\q2 ema nee hetan ksolok.
\q1 
\v 2 Se NAI Maromak la husu tuir ona nia sala,
\q2 no ema nee la hatene bosok,
\q2 ema nee hetan bensaun.
\b
\q1 
\v 3 Uluk bainhira hau lakohi foo sai hau nia sala,
\q2 loron tomak hau halerik hela deit,
\q2 too hau nia ruin sira sai mamar hotu.
\q1 
\v 4 Tanba loron-kalan
\q2 Ita Boot nia liman hanehan makaas hau;
\q1 hau nia forsa lakon tiha
\q2 hanesan bee nebee maran iha bailoron.
\b
\q1 
\v 5 Too ikus hau foo sai tiha hau nia sala ba Ita Boot;
\q2 hau la subar tan hau nia pekadu.
\q1 Hau dehan, “Hau sei konfesa hau nia hahalok aat ba NAI Maromak.”
\q2 Nunee Ita Boot hamoos tiha hau nia sala hodi halo hau livre.
\b
\q1 
\v 6 Nee duni diak liu ema nebee foo laran ba Ita Boot aproveita harohan ba Ita Boot
\q2 durante sira sei bele. \f + \fr 32:6 \ft Iha nee orijinal laduun klaru. Bele mos signifika “iha susar laran”.\f*
\q1 Bainhira bee boot sae,
\q2 sei la too iha sira.
\q1 
\v 7 Ita Boot mak hau nia subar fatin;
\q2 Ita Boot kuidadu hau para susar la bele kona hau.
\q1 Ema sei haleu hau hodi haklalak hahii Ita Boot
\q2 tanba Ita Boot salva ona hau.
\b
\q1 
\v 8 Hau\f + \fr 32:8 \ft Matenek nain balu dehan, “Hau” nee Maromak.\f* sei hanorin o hodi hatudu dalan ba o;
\q2 Hau sei sai o nia matadalan hodi tau matan ba o.
\q1 
\v 9 Keta neon-laek hanesan kuda ka kuda buru,
\q2 tenki tau tali ba iha nia ibun laran para bele domina nia;
\q2 se lae nia la halo tuir o nia hakarak.
\b
\q1 
\v 10 Ema aat hetan terus barak,
\q2 maibee NAI Maromak nia domin rohan-laek haleu ema nebee mak konfia iha Nia.
\q1 
\v 11 Imi nebee moris loos, haksolok ho kontenti tanba NAI nia diak;
\q2 imi nebee laran moos, haklalak ho hananu ba!
\c 33
\s1 Hahii adora Nai Maromak
\q1 
\v 1 Imi nebee moris loos, haklalak ba NAI Maromak;
\q2 ema laran moos hahii Nia, nee buat furak ida.
\q1 
\v 2 Toka viola hodi hahii NAI;
\q2 halo muzika ba Nia ho viola tali sanulu.
\q1 
\v 3 Hananu kantiku foun ba Nia;
\q2 toka di-diak muzika hodi haklalak.
\b
\q1 
\v 4 Tanba NAI Maromak nia liafuan loos;
\q2 Nia sempre halo buat nebee loos.
\q1 
\v 5 NAI gosta lia loos ho justisa;
\q2 Nia domin rohan-laek halo nakonu mundu rai klaran.
\b
\q1 
\v 6 NAI Maromak koalia deit, lalehan iha;
\q2 Nia huu deit iis husi ibun, loro matan, fulan ho fitun mosu.
\q1 
\v 7 Nia butuk hamutuk tasi been iha fatin ida;
\q2 Nia haloot tasi been iha armazen laran.
\q1 
\v 8 Mundu tomak, hamtauk NAI Maromak ba;
\q2 ema hotu iha mundu, admira ba,
\q1 
\v 9 tanba Nia koalia deit, buat hotu iha;
\q2 Nia foo orden deit, buat hotu hamriik metin.
\b
\q1 
\v 10 NAI Maromak teri netik tiha nasaun jentiu sira nia planu;
\q2 Nia halo povu jentiu sira nia hakarak la sai realidade.
\q1 
\v 11 Maibee NAI nia planu dura nafatin ba nafatin;
\q2 buat nebee Nia laran hakarak, sempre realiza husi jerasaun ba jerasaun.
\b
\q1 
\v 12 Nasaun nebee rekonhese katak NAI mak sira nia Maromak, sira hetan ksolok;
\q2 povu nebee Nia hili sai Ninian, sira hetan bensaun.
\b
\q1 
\v 13 NAI Maromak hateke tuun husi lalehan
\q2 hodi haree ema hotu-hotu;
\q1 
\v 14 husi Nia kadeira ukun, Nia fihir
\q2 buat hotu nebee moris iha mundu.
\q1 
\v 15 Nia mak foo neon ba ema hotu;
\q2 Nia hatene buat hotu nebee sira halo.
\q1 
\v 16 Liurai ida bele iha militar barak too iha nebee mos, sira la bele salva nia;
\q2 funu nain ida bele iha forsa boot too iha nebee mos, sei la ajuda nia.
\q1 
\v 17 Ema laran metin ba kuda forti ida atu manaan funu, laran metin saugati;
\q2 kuda bele makaas too iha nebee mos, la bele salva nia.
\b
\q1 
\v 18 Maibee NAI Maromak nia matan hateke ba ema nebee hamtauk Nia;
\q2 Nia tau matan ba ema nebee laran metin ba Nia domin rohan-laek,
\q1 
\v 19 atu salva sira husi mate;
\q2 atu foo moris ba sira iha tempu rai hamlaha.
\b
\q1 
\v 20 Ita hein ho laran metin ba NAI Maromak;
\q2 Nia mak tulun ita no defende ita.
\q1 
\v 21 Ita nia laran haksolok,
\q2 tanba ita konfia Nia naran santu.
\q1 
\v 22 NAI, haraik Ita Boot nia domin rohan-laek nafatin mai ami,
\q2 tanba ami laran metin ba Ita Boot.
\c 34
\s1 Hahii Nai Maromak tanba Nia foo mahon ba ita
\d Salmu David nian, bainhira nia finji bulak iha Abimelek nia oin, nunee Abimelek duni sai nia.
\b
\q1 
\v 1 Hau sei foti aas NAI Maromak iha hau nia moris tomak;
\q2 hau nia ibun sei hahii nafatin Nia.
\q1 
\v 2 Hau sei hahii adora NAI;
\q2 ema kbiit-laek sira, rona hodi haksolok ba.
\q1 
\v 3 Mai ita hamutuk foti aas NAI nia naran;
\q2 hamutuk ho hau tane aas Nia.
\b
\q1 
\v 4 Uluk hau harohan ba NAI Maromak, Nia hataan hau;
\q2 Nia salva tiha hau husi buat hotu nebee hatauk hau.
\q1 
\v 5 Ema nebee hateke ba Nia sei kontenti haksolok;
\q2 sira nunka atu moe.
\q1 
\v 6 Iha tempu nebaa hau, ema kbiit-laek nee halerik, NAI Maromak rona hau;
\q2 Nia hasai hau husi terus hotu-hotu.
\q1 
\v 7 NAI nia anju harii nia tenda
\q2 haleu ema nebee hamtauk Maromak
\q2 hodi salva sira.
\b
\q1 
\v 8 \x + \xo 34:8 \xt 1 Pedro 2:3\x*Mai koko hodi haree NAI nia diak;
\q2 ema nebee hamahon aan iha Nia, sira hetan ksolok.
\q1 
\v 9 Imi NAI Maromak nia povu, hamtauk Nia ba,
\q2 tanba ema nebee hamtauk Nia, sira la falta buat ida.
\q1 
\v 10 Liaun karik bele hamlaha tanba la hetan hahaan,
\q2 maibee ema nebee buka NAI Maromak, buat diak ida la falta ba nia.
\b
\q1 
\v 11 Oan sira, mai rona hau nia liafuan;
\q2 hau sei hanorin imi oinsaa hamtauk NAI Maromak.
\q1 
\v 12 \x + \xo 34:12 \xt 1 Pedro 3:10-12\x*Imi sira nee, see mak buka moris diak,
\q2 no hakarak teb-tebes atu hetan moris naruk ho haksolok?
\q1 
\v 13 Tenki kuidadu imi nia ibun para la bele koalia aat,
\q2 no la bele koalia bosok.
\q1 
\v 14 Fila kotuk ba buat aat hodi halo buat nebee diak;
\q2 hakaas aan atu moris dame malu ho ema hotu-hotu, buka nafatin dame too hetan.
\b
\q1 
\v 15 NAI Maromak tau matan ba ema nebee mak moris loos;
\q2 Nia see tilun ba sira nia halerik.
\q1 
\v 16 Maibee NAI kontra ema nebee mak halo aat,
\q2 too hasai tiha sira nia naran husi mundu.
\q1 
\v 17 Ema moris loos halerik, NAI rona sira;
\q2 Nia hasai sira husi sira nia susar.
\q1 
\v 18 NAI besik ba ema nebee laran dodok;
\q2 Nia salva ema nebee lakon esperansa.
\b
\q1 
\v 19 Ema moris loos hetan terus oi-oin,
\q2 maibee NAI Maromak hasai sira husi terus hirak nee hotu.
\q1 
\v 20 \x + \xo 34:20 \xt João 19:36\x*Nia kuidadu ema nee nia ruin tomak;
\q2 ruin ida mos la tohar.
\b
\q1 
\v 21 Ema aat sei mate ho nia hahalok rasik;
\q2 see mak odi ema moris loos, sira sei hetan kastigu.
\q1 
\v 22 NAI Maromak sei salva Nia atan sira;
\q2 ema nebee buka mahon iha Nia, la iha ida mak hetan kastigu.
\c 35
\s1 Orasaun husu tulun bainhira hasoru inimigu
\d Salmu David nian.
\b
\q1 
\v 1 NAI Maromak, ema nebee halo funu hasoru hau, Ita Boot halo funu hasoru sira ba;
\q2 ema nebee ataka hau, Ita Boot ataka sira ba.
\q1 
\v 2 Kaer metin ekipamentu funu nian hodi satan netik hau;
\q2 hamriik hodi mai tulun hau.
\q1 
\v 3 Foti Ita Boot nia diman ho baliu funu nian
\q2 kontra ema nebee mak duni tuir hau.
\q1 Hatete mai hau katak,
\q2 Ita Boot mak hau nia Salvador.
\q1 
\v 4 Hau harohan atu ema nebee hakarak halakon hau nia vida
\q2 sai moe boot ho oin tuun.
\q1 Hau husu atu ema nebee hanoin aat mai hau
\q2 hakiduk ho oin mean.
\q1 
\v 5 Haruka NAI nia anju duni sai tiha sira
\q2 hanesan anin huu lakon hare kulit.
\q1 
\v 6 NAI nia anju duni hela sira,
\q2 husik dalan nebee sira liu sai nakukun ho namdoras.
\q1 
\v 7 Tanba sira subar lasu mai hau maski hau la sala;
\q2 maski hau la sala, sira kee rai kuak mai hau.
\q1 
\v 8 Hau harohan atu dezastre boot kona sira derepenti;
\q2 husik sira monu ba iha lasu nebee sira rasik monta mai hau;
\q2 husik sira mate mohu iha rai kuak laran.
\b
\q1 
\v 9 Nunee hau nia laran sei haksolok;
\q2 hau sei kontenti tanba NAI Maromak salva ona hau.
\q1 
\v 10 Ho hau nia aan tomak hau sei deklara,
\q2 “NAI, see mak hanesan Ita Boot?!
\q1 Ita Boot salva kbiit-laek sira husi ema nebee forsa liu sira;
\q2 ema kiak ho ema kbiit-laek sira nebee ema hanehan, Ita Boot tulun sira.”
\b
\q1 
\v 11 Ema aat sira hamriik foo sasin falsu hasoru hau;
\q2 sira husu hau kona ba buat nebee hau la hatene.
\q1 
\v 12 Hau nia diak, sira selu fali ho hahalok aat;
\q2 hau tristi teb-tebes.
\q1 
\v 13 Uluk sira moras, hau hatais hena lutu
\q2 hodi haraik aan ho jejun.
\q1 Hau hakruuk hodi harohan
\q2 
\v 14 hanesan fali hau harohan ba hau nia belun ka hau nia maun-alin.
\q1 Hau hakruuk hodi tanis ho laran susar
\q2 hanesan fali hau tanis halerik ba hau nia inan.
\q1 
\v 15 Maibee bainhira hau monu, sira hotu kontenti;
\q2 sira haleu hau hodi hatete aat hau.
\q1 Ema fuik nebee hau la konhese
\q2 koalia aat hau la para.
\q1 
\v 16 Ema nebee la fiar Maromak, tarata aat hau;
\q2 sira ruun nehan mai hau.
\b
\q1 
\v 17 NAI Maromak, Ita Boot hateke deit nunee too bainhira?
\q2 Salva hau tanba sira ataka hau;
\q2 salva hau nia moris husi liaun sira nee.
\q1 
\v 18 Depois hau sei agradese ba Ita Boot iha povu nia leet;
\q2 hau sei hahii Ita Boot iha ema lubun boot nia klaran.
\q1 
\v 19 \x + \xo 35:19 \xt Salmu 69:4; João 15:25\x*Keta husik hau nia inimigu bosok-teen sira nee haksolok fali ho hau nia terus.
\q2 Sira odi hau maski hau la sala; keta husik sira baku matan ba malu kona ba hau.
\q1 
\v 20 Sira la koalia liafuan dame nian,
\q2 maibee sira konta fali istoria falsu
\q2 kontra ema sira nebee hela hakmatek iha rai nee.
\q1 
\v 21 Sira halo ibun luan hodi hatete,
\q2 “Ha! Buat nebee o halo, ami haree rasik ho matan.”
\b
\q1 
\v 22 NAI Maromak, Ita Boot haree ona ida nee; keta nonook deit;
\q2 Nai, keta dook husi hau.
\q1 
\v 23 Hadeer ona, hamriik hodi defende hau;
\q2 hau nia Nai, hau nia Maromak, sai hau nia Defensor ba!
\q1 
\v 24 NAI hau nia Maromak, Ita Boot sempre halo buat nebee loos;
\q2 deklara ba katak hau la sala ida.
\q2 Keta husik sira haksolok fali ho hau nia terus.
\q1 
\v 25 Keta husik sira dehan ba malu,
\q2 “Haree ba, saida mak ita hakarak nee akontese tiha ona!”
\q1 Keta husik sira dehan,
\q2 “Ita tolan tiha ona nia.”
\b
\q1 
\v 26 Hau harohan atu ema nebee kontenti bainhira susar kona hau,
\q2 sira sai moe too bilaan tiha;
\q1 husik ema nebee mak foti aan hasoru hau,
\q2 sira moe boot ho oin tuun.
\q1 
\v 27 Hau harohan atu ema nebee hakarak haree hau manaan justisa,
\q2 ema sira nee haklalak ho haksolok hodi hatete fila-fila,
\q1 “NAI Maromak nee boot!
\q2 Nia kontenti bainhira Nia atan hetan diak.”
\q1 
\v 28 Hau nia ibun sei foo sai Ita Boot nia justisa;
\q2 loron-kalan hau sei hahii Ita Boot.
\c 36
\s1 Ema aat nia sala ho Nai Maromak nia diak
\d Husi NAI Maromak nia atan David. Ba dirijenti koru.
\b
\q1 
\v 1 \x + \xo 36:1 \xt Roma 3:18\x*Ema aat sira nia hahalok aat sai fali matadalan ba sira;
\q2 ema sira nee la hatene hamtauk Maromak.
\q1 
\v 2 Iha sira nia matan rasik, sira diak loos,
\q2 too sira la haree sira nia sala, no la hakribi sira nia hahalok.
\q1 
\v 3 Liafuan nebee sai husi sira nia ibun mesak aat ho bosok;
\q2 sira lakohi halo tan buat nebee mak diak ho buat nebee loos.
\q1 
\v 4 Maski iha sira nia toba fatin mos, sira planu buat aat;
\q2 sira tau sira nia aan iha dalan nebee la loos;
\q2 sira nunka fila kotuk ba buat aat.
\b
\q1 
\v 5 NAI Maromak, Ita Boot nia domin too iha lalehan aas ba;
\q2 Ita Boot nia lia loos too iha kalohan.
\q1 
\v 6 Ita Boot nia diak hanesan foho aas sira;
\q2 Ita Boot nia justisa hanesan tasi nia klean.
\q1 NAI, Ita Boot foo mahon ba ema ho mos ba animal.
\q1 
\v 7 Maromak, Ita Boot nia domin folin boot;
\q2 ema hotu hamahon aan iha Ita Boot nia liras okos.
\q1 
\v 8 Sira haan too bosu ho hahaan diak nian husi Ita Boot nia uma;
\q2 Ita Boot foo bee ksolok nian husi Ita Boot nia mota ba sira hemu.
\q1 
\v 9 Tanba Ita Boot mak buat moris hotu nia huun;
\q2 husi Ita Boot nia naroman ami bele hetan naroman.
\b
\q1 
\v 10 Foo domin nafatin ba ema nebee mak konhese Ita Boot;
\q2 foo Ita Boot nia justisa ba ema nebee mak moris loos.
\q1 
\v 11 Keta husik ema foti aan sira sama hau;
\q2 la bele husik ema aat sira nia liman duni lakon hau.
\q1 
\v 12 Haree ba, ema aat sira nee monu oinsaa;
\q2 sira monu tuun ba rai too la bele hamriik fali!
\c 37
\s1 Keta laran moras ba ema aat
\d Salmu David nian.
\b
\q1 
\v 1 Keta preokupa ho ema aat sira;
\q2 keta laran moras ba ema nebee halo sala.
\q1 
\v 2 Tanba sira hanesan duut nebee fasil namlaik;
\q2 sira sei mate hanesan ai matak nebee la kleur maran tiha.
\b
\q1 
\v 3 Fiar ba NAI Maromak no halo buat nebee diak;
\q2 hela iha rai nee ho hakmatek.
\q1 
\v 4 Buka o nia ksolok husi NAI
\q2 mak Nia sei foo buat nebee o nia laran hakarak.
\b
\q1 
\v 5 Entrega o nia moris ba NAI Maromak;
\q2 fiar ba Nia mak Nia sei halo ida nee ba o:
\q1 
\v 6 Nia sei leno sai o nia hahalok loos
\q2 hanesan loro matan dadeer nian leno rai;
\q1 ema sei haree katak o nee loos hela,
\q2 hanesan ema haree loro matan meudia nian.
\b
\q1 
\v 7 Hakmatek iha NAI Maromak nia oin ba;
\q2 pasiensia hodi hein Nia.
\q1 Keta preokupa ema nia planu aat;
\q2 lalika laran susar bainhira ema aat hetan moris diak.
\b
\q1 
\v 8 Hadook aan husi hirus, keta laran nakali;
\q2 lalika preokupa, nee sei lori o ba dalan aat.
\q1 
\v 9 Tanba ema aat sei lakon mohu,
\q2 maibee ema nebee laran metin ba NAI Maromak, sira sei hela nafatin iha rai nee.
\b
\q1 
\v 10 La kleur tan, ema aat sira nee sei mohu tiha;
\q2 o buka sira mos la hetan.
\q1 
\v 11 \x + \xo 37:11 \xt Mateus 5:5\x*Maibee ema nebee haraik aan sei hela metin iha rai nee;
\q2 sira sei moris haksolok iha pas ho hakmatek nia laran.
\b
\q1 
\v 12 Ema aat halo planu foer hasoru ema nebee moris loos
\q2 hodi ruun nehan ba sira.
\q1 
\v 13 Maibee NAI Maromak hamnasa fali ema aat sira nee,
\q2 tanba Nia hatene katak sira nia loron besik ona.
\b
\q1 
\v 14 Ema aat losu sai sira nia surik
\q2 no dada sira nia rama
\q1 atu hamonu ema kiak ho kbiit-laek sira,
\q2 atu hamate ema nebee lao tuir dalan loos.
\q1 
\v 15 Maibee sira nia surik sei sona borus fali sira nia fuan rasik;
\q2 sira nia rama sei silu tohar.
\b
\q1 
\v 16 Diak liu moris loos ho sasaan uitoan deit
\q2 duke sai ema aat ho riku-soin barak.
\q1 
\v 17 Tanba ema aat sira nia liman sei silu tohar,
\q2 maibee NAI Maromak tane ema nebee moris loos.
\b
\q1 
\v 18 NAI Maromak tau matan ba ema laran moos;
\q2 rai nebee Nia foo ba sira sai sira nian nafatin ba nafatin.
\q1 
\v 19 Iha tempu susar, sira laos mes-mesak;
\q2 rai hamlaha, sira hetan hahaan too bosu.
\b
\q1 
\v 20 Maibee ema aat sei mate mohu.
\q2 NAI Maromak nia inimigu hanesan ai funan iha rai fuik;
\q2 sira sei mohu, sei mohu lakon hanesan ahi suar.
\b
\q1 
\v 21 Ema aat empresta, la foo fila,
\q2 maibee ema nebee moris loos gosta foo ba ema.
\q1 
\v 22 Ema nebee NAI Maromak foo bensaun, sira sei hela metin iha rai nee,
\q2 maibee ema nebee Maromak foo malisan, sei lakon mohu.
\b
\q1 
\v 23 Ema nebee halo haksolok NAI Maromak nia laran,
\q2 Maromak sei hatudu dalan ba nia.
\q1 
\v 24 Maski nia sidi maibee nia la monu,
\q2 tanba NAI kaer metin nia liman.
\b
\q1 
\v 25 Hori uluk hau sei joven too agora hau katuas ona,
\q2 hau seidauk haree Maromak husik ema laran moos moris mesak;
\q2 hau seidauk haree sira nia oan sira tane liman hodi husu hahaan ba ema.
\q1 
\v 26 Sira foo ho laran luak no sempre prontu foo sasaan ba ema empresta;
\q2 sira nia oan sira sai bensaun ba ema.
\b
\q1 
\v 27 Fila kotuk ba buat aat hodi halo buat diak,
\q2 nunee o sei hela iha rai nee tinan ba tinan.
\q1 
\v 28 Tanba NAI Maromak gosta justisa;
\q2 ema nebee foo laran ba Nia, Nia nunka husik mesak.
\b
\q1 Ema aat sira sei rahun hotu;
\q2 sira nia jerasaun sei lakon mohu.
\q1 
\v 29 Ema moris loos sei hela metin iha rai nee;
\q2 sira sei horik iha rai nee tinan ba tinan.
\b
\q1 
\v 30 Ema moris loos nia ibun foo sai buat matenek nian;
\q2 nia nanaal hatete buat nebee loos.
\q1 
\v 31 Nia rai Maromak nia lei iha nia laran;
\q2 nia ain sei la sidi.
\b
\q1 
\v 32 Ema aat hafuhu ema moris loos
\q2 hodi buka dalan atu oho sira.
\q1 
\v 33 Maibee NAI Maromak sei la husik sira iha ema aat nia liman laran;
\q2 ema lori sira too iha tribunal mos, Maromak la husik juis hamonu kastigu ba sira.
\b
\q1 
\v 34 Laran metin ba NAI Maromak;
\q2 lao tuir nafatin Nia dalan.
\q1 Nia sei foti o hela metin iha rai nee;
\q2 bainhira ema aat mohu hotu, o sei haree.
\b
\q1 
\v 35 Hau haree ona ema aat sira hanehan ema;
\q2 ema aat sira nee moris buras hanesan ai huun boot.
\q1 
\v 36 Maibee hau liu tan husi nebaa, sira la iha tiha ona;
\q2 maski hau buka sira, la hetan tan.
\b
\q1 
\v 37 Hateke ba ema nebee laran moos; haree ba ema nebee moris loos.
\q2 Tanba ema nebee mak buka dame sei hetan futuru nebee diak.
\q1 
\v 38 Maibee sala nain sira sei mate mohu;
\q2 ema aat sira nia futuru sei la iha.
\b
\q1 
\v 39 NAI Maromak mak salva ema nebee moris loos;
\q2 iha tempu susar, Nia mak sira nia subar fatin.
\q1 
\v 40 NAI tulun sira hodi lori sira sai;
\q2 Nia hasai sira husi ema aat hodi salva sira,
\q2 tanba sira buka mahon iha Nia.
\c 38
\s1 Ema moras halerik husu tulun
\d Salmu David nian, husu Maromak atu hanoin nia.
\b
\q1 
\v 1 NAI Maromak, maski Ita Boot hirus hela hau, maibee keta siak hau;
\q2 maski Ita Boot nia laran nakali hela, maibee keta kastigu hau.
\q1 
\v 2 Ita Boot nia rama oan tama ona hau nia isin;
\q2 Ita Boot nia liman hanehan hela hau.
\q1 
\v 3 Ita Boot nia laran nakali halo hau nia isin sai moras hotu;
\q2 hau nia sala halo hau nia isin lolon tomak sai fraku tiha.
\q1 
\v 4 Hau mout tiha iha hau nia hahalok aat nia laran;
\q2 hau senti hau nia sala todan liu ona.
\q1 
\v 5 Hau nia hahalok beik
\q2 halo hau nia kanek sai dodok dois.
\q1 
\v 6 Hau hakruuk too bonko;
\q2 loro-loron hau laran susar hela deit.
\q1 
\v 7 Isin manas sunu hau nia aan tomak;
\q2 hau nia isin sai moras hotu.
\q1 
\v 8 Hau la bele liu ona; hau nia forsa mohu ona;
\q2 hau laran dodok hodi halerik.
\b
\q1 
\v 9 Nai Maromak, Ita Boot hatene hotu hau nia hakarak;
\q2 Ita Boot rona hau nia halerik.
\q1 
\v 10 Hau nia fuan nakdedar; hau nia forsa la iha ona;
\q2 hau nia matan sai malahuk tiha ona.
\q1 
\v 11 Hau nia belun sira ho maluk sira lakohi besik hau tanba hau nia kanek,
\q2 too hau nia familia sira mos hamriik husi dook deit.
\q1 
\v 12 Ema nebee hakarak oho hau monta lasu mai hau;
\q2 ema nebee hakarak halo terus hau kombina malu atu hamonu hau;
\q2 loro-loron sira halo manobra tuun-sae.
\b
\q1 
\v 13 Hau hanesan fali ema tilun diuk, la bele rona buat ida;
\q2 hau hanesan ema monok, la hatene koalia.
\q1 
\v 14 Hau hanesan ema nebee la rona buat ida;
\q2 hau hanesan ema nebee la bele foo resposta.
\q1 
\v 15 NAI Maromak, hau hein hela Ita Boot;
\q2 Nai, hau nia Maromak, Ita Boot sei hataan hau,
\q1 
\v 16 tanba hau husu tiha ona ba Ita Boot dehan,
\q2 “Keta husik sira haksolok fali ho hau nia terus
\q2 ka foti aan hasoru hau bainhira hau monu.”
\b
\q1 
\v 17 Hau besik atu monu;
\q2 hau terus la hotu.
\q1 
\v 18 Hau foo sai hau nia sala;
\q2 hau nia hahalok aat halo hau la hakmatek.
\q1 
\v 19 Hau nia inimigu sira mesak bo-boot deit;
\q2 iha ema barak teb-tebes odi hau, maski hau la halo buat aat ba sira.
\q1 
\v 20 Hau nia hahalok diak, sira selu fali ho hahalok aat;
\q2 sira kontra hau tanba hau hakarak halo buat nebee diak.
\q1 
\v 21 NAI Maromak, keta husik hau mesak;
\q2 hau nia Maromak, keta dook nafatin husi hau.
\q1 
\v 22 Hau nia Nai, hau nia Salvador,
\q2 mai lalais hodi tulun hau.
\c 39
\s1 Ita ema nia moris badak deit
\d Salmu David nian, ba dirijenti koru Jedutun.
\b
\q1 
\v 1 Iha tempu ida hau dehan, “Hau sei kuidadu hau nia lalaok
\q2 atu hau nia ibun la bele koalia sala;
\q1 bainhira ema aat iha hela hau nia oin,
\q2 hau sei taka hau nia ibun.”
\q1 
\v 2 Hau nonook deit,
\q2 la hatete buat ida; atu koalia buat diak mos lae.
\q1 Maski hau nonook, maibee hau nia laran susar ba beibeik;
\q2 
\v 3 hau nia fuan la hakmatek.
\q1 Hau hanoin hela, hau nia neon aumenta susar
\q2 too hau loke ibun hodi koalia:
\q1 
\v 4 “NAI Maromak, foo hatene took mai hau kona ba hau nia destinu,
\q2 no hau moris too tinan hira;
\q2 foo hanoin mai hau katak, hau nia moris badak deit.
\q1 
\v 5 Ita Boot halo hau nia tinan badak hanesan sasukat liman ida-rua deit.
\q2 Tuir Ita Boot haree, hau nia vida tomak hanesan buat malahuk ida,
\q2 hanesan fali anin nebee huu liu deit.
\q1 
\v 6 Loos duni, ema kriatura hanesan lalatak nebee liu ona;
\q2 sira moris fadigadu hela hodi rai riku-soin,
\q1 maibee saugati deit;
\q2 sira la hatene aban-bainrua see mak atu hetan riku-soin nee.
\b
\q1 
\v 7 Nai Maromak, agora hau hein tan saida?
\q2 Hau laran metin ba Ita Boot.
\q1 
\v 8 Hasai hau husi hau nia hahalok aat hotu;
\q2 keta husik ema beik hamnasa fali hau.
\q1 
\v 9 Hau nonook, la loke hau nia ibun,
\q2 tanba Ita Boot rasik mak halo ida nee mai hau.
\q1 
\v 10 Hasai tiha Ita Boot nia kastigu husi hau;
\q2 hau la bele ona, tanba Ita Boot nia liman baku hela hau.
\q1 
\v 11 Bainhira Ita Boot siak ema
\q2 hodi kastigu nia tanba nia sala,
\q1 Ita Boot estraga tiha nia riku-soin hanesan fali ular mak haan.
\q2 Loos duni, ema hotu-hotu nia moris hanesan anin nebee huu liu deit.
\b
\q1 
\v 12 NAI Maromak, rona hau nia orasaun;
\q2 see tilun mai hau nia halerik husu tulun;
\q2 keta fila kotuk ba hau nia matan been.
\q1 Tanba hau iha nee hanesan Ita Boot nia bainaka ida;
\q2 hau ema lao rai hanesan hau nia bei-ala sira.
\q1 
\v 13 Hasees tiha Ita Boot nia oin husi hau,
\q2 atu hau bele kontenti fali
\q2 molok hau baa no la iha tan.”
\c 40
\s1 Orasaun agradese no husu tulun
\d Salmu David nian, ba dirijenti koru.
\b
\q1 
\v 1 Hau hein NAI Maromak ho pasiensia;
\q2 too ikus Nia fila oin mai hau hodi rona hau nia halerik.
\q1 
\v 2 Nia foti hau sai husi rai kuak perigu nian;
\q2 Nia hasai hau husi tahu boot nia laran.
\q1 Nia tau hau nia ain iha fatuk leten
\q2 hodi foo fatin seguru atu hau hamriik metin.
\q1 
\v 3 Nia tau knananuk foun iha hau nia ibun,
\q2 kantiku hodi hahii ita nia Maromak.
\q1 Ema barak sei haree;
\q2 sira sei hamtauk NAI Maromak hodi konfia Nia.
\b
\q1 
\v 4 See mak konfia NAI Maromak,
\q2 see mak la sadere ba ema nebee foti aan,
\q2 see mak la lao hamutuk ho ema nebee adora maromak falsu,
\q2 ema sira nee mak hetan ksolok.
\q1 
\v 5 NAI, hau nia Maromak,
\q2 Ita Boot halo tiha ona buat furak barak mai ami;
\q2 Ita Boot nia planu ba ami nia moris mos boot.
\q1 La iha ida mak hanesan Ita Boot;
\q2 hau atu konta sai buat nebee Ita Boot halo,
\q2 barak teb-tebes, hau sura la bele.
\b
\q1 
\v 6 \x + \xo 40:6 \xt Ebreu 10:5-7\x*Ita Boot nia hakarak laos atu ema lori oferta no oho animal sai sakrifisiu ba Ita Boot;
\q2 Ita Boot la presiza animal nebee ema tunu halo sakrifisiu.
\q1 Ita Boot la husu sakrifisiu nebee ema foo hodi husu perdaun,
\q2 maibee Ita Boot loke ona hau nia tilun.
\q1 
\v 7-8 Entaun hau dehan, “Maromak, hau mak nee, hau mai ona.
\q2 Hau gosta teb-tebes halo tuir Ita Boot nia hakarak,
\q1 hanesan hakerek ona kona ba hau iha Livru Sagradu.
\q2 Ita Boot nia lei iha hela hau nia laran.”
\b
\q1 
\v 9 NAI Maromak, hau foo sai tiha ona iha povu nia leet katak
\q2 Ita Boot salva ami.
\q1 Ita Boot hatene katak
\q2 hau la taka hau nia ibun.
\q1 
\v 10 Hau la subar Ita Boot nia lia loos iha hau nia laran;
\q2 hau koalia sai katak Ita Boot sempre foo laran ba Ita Boot nia povu, Ita Boot mak Salvador.
\q1 Hau la taka ba ema lubuk boot katak,
\q2 Ita Boot sempre hadomi Ita Boot nia povu no kaer metin Ita Boot nia liafuan.
\b
\q1 
\v 11 NAI Maromak, keta taka Ita Boot nia laran luak mai hau;
\q2 halo Ita Boot nia domin ho Ita Boot nia lia loos hamahon hau nafatin.
\q1 
\v 12 Tanba susar nebee haleu hau barak teb-tebes, hau sura la bele;
\q2 hau nia sala butuk aas liu ona, halo hau la haree rai;
\q1 hau nia sala barak liu fali hau nia fuuk lahan;
\q2 hau nia forsa la iha tiha.
\b
\q1 
\v 13 NAI Maromak, favor salva hau;
\q2 NAI, mai lalais tulun hau ba.
\q1 
\v 14 Hau harohan atu ema hotu nebee hakarak hasai hau nia vida
\q2 moe boot ho oin tuun;
\q1 husik ema nebee hakarak atu hau hetan dezastre
\q2 hakiduk ho naran aat.
\q1 
\v 15 Husik ema nebee hamnasa hahaek mai hau
\q2 sai moe boot too bilaan tiha.
\b
\q1 
\v 16 Maibee halo ema hotu nebee harohan ba Ita Boot
\q2 sai kontenti ho haksolok;
\q1 husik ema nebee buka Ita Boot nia salvasaun dehan beibeik,
\q2 “NAI Maromak nee boot!”
\q1 
\v 17 Hau nee ema kiak ho kbiit-laek,
\q2 maibee Nai Maromak hanoin hau.
\q1 Ita Boot mak tulun hau no salva hau;
\q2 hau nia Maromak, keta demora.
\c 41
\s1 Orasaun husu Nai Maromak atu kura moras
\d Salmu David nian, ba dirijenti koru.
\b
\q1 
\v 1 Ema nebee konsidera ema kiik, sira hetan ksolok;
\q2 bainhira sira iha susar laran, NAI Maromak salva sira.
\q1 
\v 2 NAI foo mahon ba sira hodi kuidadu sira;
\q2 sira moris haksolok iha rai nee.
\q2 Nia la husik sira monu iha sira nia inimigu nia liman laran.
\q1 
\v 3 Bainhira sira moras iha sira nia toba fatin, NAI tau matan ba sira
\q2 hodi foo fali isin diak ba sira.
\b
\q1 
\v 4 Uluk hau harohan nunee: “NAI Maromak, hanoin hau ba!
\q2 Hau halo sala kontra Ita Boot; kura hau ba.”
\q1 
\v 5 Hau nia inimigu sira hatete aat hau dehan,
\q2 “Bainhira mak nia mate, atu nia naran la temi tan?”
\q1 
\v 6 Kuandu sira ida mai haree hau,
\q2 sira finji koalia diak mai hau,
\q1 maibee sira nia laran hakarak buka hatene hau nia susar,
\q2 depois sira sai baa konta iha fat-fatin.
\q1 
\v 7 Ema nebee odi hau bis-bisu ba malu kona ba hau;
\q2 sira hanoin buat aat mai hau dehan,
\q1 
\v 8 “Moras aat kona ona nia;
\q2 atu hamriik tan husi nia toba fatin mos la bele ona.”
\q1 
\v 9 \x + \xo 41:9 \xt Mateus 26:23; Marcos 14:18; Lucas 22:21; João 13:18\x*Maski hau nia belun diak,
\q2 hau konfia loos nia,
\q1 nia tuur haan hamutuk ho hau,
\q2 nia sai fali hau nia inimigu.
\b
\q1 
\v 10 NAI Maromak, hanoin hau ba;
\q2 foti sae hau, nunee hau bele selu fali sira.
\q1 
\v 11 Hau hatene katak Ita Boot nia laran haksolok ho hau,
\q2 tanba hau nia inimigu la manaan hau.
\q1 
\v 12 Ita Boot tulun hau tanba hau nia laran moos;
\q2 Ita Boot hatuur hau iha Ita Boot nia oin too tinan ba tinan.
\b
\q1 
\v 13 \x + \xo 41:13 \xt Salmu 106:48\x*Hahii NAI, Israel nia Maromak,
\q2 nafatin ba nafatin.
\q1 Amen, amen.
\c 42
\s1 Hamrook buka Nai Maromak
\d Salmu husi Korá nia oan para hanorin ema. Ba dirijenti koru.
\b
\q1 
\v 1 Hanesan rusa hamrook teb-tebes atu hemu bee mota nian,
\q2 nunee mos hau hamrook teb-tebes ba Ita Boot, hau nia Maromak.
\q1 
\v 2 Hau hamrook ba Ita Boot, Maromak Moris.
\q2 Bainhira loos mak hau baa too iha Ita Boot nia oin?
\q1 
\v 3 Loron-kalan matan been mak sai fali hau nia hahaan,
\q2 tanba loron tomak ema hatete mai hau dehan,
\q2 “O nia Maromak iha nebee?”
\b
\q1 
\v 4 Hau nia laran susar;
\q2 hau hanoin hetan
\q1 uluk hau baa iha Maromak nia uma,
\q2 iha Kbiit Nain nia mahon.
\q1 Hau hamutuk ho ema lubun boot
\q2 haklalak haksolok hahii Maromak.
\b
\q1 
\v 5 Hau husu ba hau nia aan,
\q2 “Tansaa mak o tristi?
\q2 Tansaa mak o nia laran la hakmatek?”
\q1 Laran metin ba Maromak ba,
\q2 tanba hau sei hahii fila fali Nia,
\q2 hau nia Salvador ho hau nia Maromak.
\q1 
\v 6 Hau nia laran tristi teb-tebes;
\q2 tanba nee, husi rai Jordaun nian nee,
\q1 husi foho Hermon nia tutun, husi foho Mizar,
\q2 hau hanoin Ita Boot.
\q1 
\v 7 Ita Boot nia mota tuun ho lian makaas
\q2 too bee boot mos tarutu simu malu iha fat-fatin.
\q2 Ita Boot nia laloran nadodon mai, halo mout tiha hau.
\q1 
\v 8 Iha loron, NAI Maromak hatudu Nia domin rohan-laek;
\q2 iha kalan, hau hananu ba Nia,
\q2 hanesan orasaun ida ba Maromak, hau nia moris huun.
\b
\q1 
\v 9 Maromak mak fatuk kuak boot nebee hau subar iha laran.
\q2 Hau hatete ba Nia,
\q1 “Tansaa mak Ita Boot haluha hau?
\q2 Tansaa mak hau nia inimigu hanehan hau
\q2 too hau moris halerik nunee?”
\q1 
\v 10 Hau nia inimigu hamoe hau,
\q2 halo hau nia ruin sira rahun tiha.
\q1 Loron tomak sira hatete mai hau dehan,
\q2 “O nia Maromak iha nebee?”
\b
\q1 
\v 11 Hau husu ba hau nia aan,
\q2 “Tansaa mak o tristi?
\q2 Tansaa mak o nia laran la hakmatek?”
\q1 Laran metin ba Maromak ba,
\q2 tanba hau sei hahii fila fali Nia,
\q2 hau nia Salvador ho hau nia Maromak.
\c 43
\s1 Orasaun halerik iha ema nia rain
\q1 
\v 1 Hau nia Maromak, tesi hau nia lia ba hodi deklara katak hau la sala;
\q2 defende hau kontra nasaun nebee la fiar Ita Boot;
\q2 salva hau husi ema sira nebee laran aat ho bosok-teen.
\q1 
\v 2 Tanba Ita Boot mak Maromak, hau nia subar fatin.
\q2 Tansaa mak Ita Boot soe hela hau?
\q1 Tansaa mak hau nia inimigu hanehan hau
\q2 too hau moris halerik nunee?
\q1 
\v 3 Haruka Ita Boot nia naroman ho Ita Boot nia lia loos
\q2 hodi gia hau;
\q1 husik buat sira nee lori hau ba iha Ita Boot nia foho santu,
\q2 ba iha fatin nebee Ita Boot hela ba.
\q1 
\v 4 Too iha nebaa, hau sei baa iha Maromak nia altar oin;
\q2 hau sei baa iha Maromak, hau nia ksolok nia huun.
\q1 Maromak, hau nia Maromak,
\q2 hau sei toka viola hodi hahii Ita Boot.
\b
\q1 
\v 5 Hau husu ba hau nia aan,
\q2 “Tansaa mak o tristi?
\q2 Tansaa mak o nia laran la hakmatek?”
\q1 Laran metin ba Maromak ba,
\q2 tanba hau sei hahii fila fali Nia,
\q2 hau nia Salvador ho hau nia Maromak.
\c 44
\s1 Orasaun bainhira inimigu hanehan
\d Salmu husi Korá nia oan para hanorin ema. Ba dirijenti koru.
\b
\q1 
\v 1 Maromak, ami rona tiha ona ho ami nia tilun rasik;
\q2 ami nia bei-ala sira konta tiha ona mai ami
\q1 buat nebee Ita Boot halo iha sira nia tempu,
\q2 iha tempu uluk nian.
\q1 
\v 2 Ho Ita Boot nia liman, Ita Boot duni sai tiha nasaun jentiu sira
\q2 hodi tau fali ami nia bei-ala sira;
\q1 Ita Boot halo rahun tiha povu jentiu sira,
\q2 no halo ami nia bei-ala sira sai buras.
\q1 
\v 3 Sira laos uza sira nia surik mak hadau rai nee;
\q2 sira laos uza sira nia forsa rasik mak manaan,
\q1 maibee sira manaan tanba Ita Boot nia liman loos ho Ita Boot nia forsa,
\q2 ho mos Ita Boot nia oin nabilan,
\q2 tanba Ita Boot nia laran kontenti ho sira.
\b
\q1 
\v 4 Ita Boot mak hau nia Liurai ho hau nia Maromak;
\q2 Ita Boot deklara katak Jacó nia jerasaun sei manaan. \f + \fr 44:4 \ft Jacó nia jerasaun mak povu Israel. \f*
\q1 
\v 5 Ho Ita Boot nia kbiit ami duni sai ami nia inimigu sira;
\q2 ho Ita Boot nia naran ami sama ami nia funu baluk sira.
\q1 
\v 6 Hau la tau hau nia fiar iha hau nia rama;
\q2 hau nia surik la halo hau manaan.
\q1 
\v 7 Maibee Ita Boot mak halo ami manaan ami nia inimigu sira;
\q2 Ita Boot halo moe ami nia funu baluk sira.
\q1 
\v 8 Iha loron tomak ami konta Ita Boot nia diak;
\q2 ami sei hahii Ita Boot nia naran nafatin ba nafatin.
\b
\q1 
\v 9 Maibee agora Ita Boot fila kotuk hodi hatuun fali ami;
\q2 Ita Boot la hamutuk tiha ona ho ami nia militar sira.
\q1 
\v 10 Ita Boot halo ami hakiduk iha ami nia inimigu sira nia oin;
\q2 ami nia funu baluk sira hadau tiha ami nia sasaan.
\q1 
\v 11 Ita Boot husik ema oho ami hanesan fali ema oho bibi;
\q2 sira halo ami namkari iha nasaun jentiu sira.
\q1 
\v 12 Ita Boot faan Ita Boot nia povu ho folin baratu deit,
\q2 la interese atu husu folin diak nian.
\q1 
\v 13 Ita Boot halo ami moe iha vizinhu sira nia oin;
\q2 ema nebee haleu ami hatete aat ami no hatuun ami.
\q1 
\v 14 Ita Boot halo ami sai naran aat iha nasaun jentiu sira nia leet;
\q2 estranjeiru sira doko ulun ba ami.
\q1 
\v 15 Loron-kalan hau senti hau nia naran sai foer tiha ona;
\q2 hau moe boot,
\q1 
\v 16 tanba rona ema hatuun ami ho tarata ami,
\q2 no haree inimigu sira ho ema nebee odi ami.
\q1 
\v 17 Buat hirak nee hotu mai iha ami nia leten,
\q2 afinal ami la haluha Ita Boot;
\q2 ami la kontra Ita Boot nia lei ho promesa.
\q1 
\v 18 Ami la fila kotuk ba Ita Boot;
\q2 ami la lao sees husi Ita Boot nia dalan.
\q1 
\v 19 Maibee Ita Boot harahun tiha ami iha animal fuik nia hela fatin;
\q2 Ita Boot falun ami ho nakukun boot.
\q1 
\v 20 Se karik ami haluha tiha ami nia Maromak nia naran
\q2 ka tane liman fali ba maromak seluk,
\q1 
\v 21 Ita Boot hatene hela,
\q2 tanba Ita Boot hatene hotu ema nia segredu iha laran.
\q1 
\v 22 \x + \xo 44:22 \xt Roma 8:36\x*Loron-kalan ema buka dalan atu oho ami tanba ami tuir Ita Boot.
\q2 Sira haree ami hanesan bibi malae nebee mak sira atu oho.
\b
\q1 
\v 23 Nai Maromak, hadeer ona ba! Nusaa mak Ita Boot toba dukur?
\q2 Hamriik ba! Keta husik hela ami tinan ba tinan.
\q1 
\v 24 Tansaa mak Ita Boot subar Ita Boot nia oin?
\q2 Tansaa Ita Boot haluha ami nia terus ho susar?
\q1 
\v 25 Ami monu tuun tiha ona ba iha rai rahun;
\q2 ami monu taka rabat iha rai.
\q1 
\v 26 Hamriik hodi tulun ami ba;
\q2 salva ami tanba Ita Boot nia domin rohan-laek.
\c 45
\s1 Kantiku ba liurai nia festa kazamentu
\d Salmu husi Korá nia oan, para hanorin ema. Kantiku kazamentu nian, tuir muzika “Ai funan liriu.” Ba dirijenti koru.
\b
\q1 
\v 1 Hau nia laran nakonu ho liafuan murak;
\q2 hau nia ibun hanesan matenek nain nia lapizeira;
\q2 hau hakarak oferese hau nia poezia ba liurai.
\b
\q1 
\v 2 O mak bonitu liu ema hotu-hotu;
\q2 liafuan mesak furak sai husi o nia ibun;
\q2 Maromak foo bensaun ba o nafatin ba nafatin.
\q1 
\v 3 Aswain, sikat o nia surik iha o nia kanotak;
\q2 hatudu sai o nia kbiit ho o nia furak!
\q1 
\v 4 Uza o nia kbiit nee lao ba oin too manaan
\q2 hodi defende lia loos, hahalok haraik aan ho justisa;
\q2 uza o nia forsa hodi halo buat boot.
\q1 
\v 5 Liurai, o nia rama oan kroat,
\q2 tama borus o nia inimigu sira nia fuan;
\q2 nasaun jentiu sira monu iha o nia ain okos.
\b
\q1 
\v 6 \x + \xo 45:6 \xt Ebreu 1:8,9\x*Nai,\f + \fr 45:6 \ft Lian Ebreu dehan “Maromak”. \f* o sei ukun tinan ba tinan;
\q2 o sempre ukun o nia reinu ho lo-loos.
\q1 
\v 7 O haksolok bainhira ema halo buat diak;
\q2 o hakribi hahalok aat.
\q1 Tanba nee, Nai o nia Maromak foti o aas liu o nia maluk sira;
\q2 Nia kose mina ba o nia ulun hodi halo o nia laran haksolok.
\q1 
\v 8 O nia ropa hotu-hotu tau ai morin ho mina morin diak nian ho ai kameli;
\q2 o nia palasiu enfeita ho elefante nia nehan;
\q2 muzika viola nian halo kontenti o nia laran.
\q1 
\v 9 Feto nebee hela iha o nia palasiu, balu raan liurai;
\q2 liurai nia noiva hatais osan mean husi rai Ofir hodi tuur iha o nia sorin loos.
\b
\q1 
\v 10 Liurai feto, rona mai, hanoin di-diak hodi see tilun;
\q2 haluha tiha o nia o nia povu ho o nia aman nia uma laran.
\q1 
\v 11 O nia furak halo liurai gosta teb-tebes o;
\q2 nia mak o nia nai; hakruuk ba nia.
\q1 
\v 12 Povu husi sidade Tiru sei mai foo prezenti;
\q2 ema riku sira iha povu nia leet sei buka manaan o nia laran.
\q1 
\v 13 Liurai feto nee iha nia kuartu laran,
\q2 nia bonita teb-tebes.
\q1 Nia vestidu naruk enfeita ho osan mean;
\q2 
\v 14 nia hena kor oi-oin deit.
\q1 Ema lori nia ba iha liurai nia oin;
\q2 nia maluk feto raan sira akompanha nia husi kotuk.
\q1 
\v 15 Ho kontenti ho haksolok,
\q2 sira hakat dadauk mai tama iha liurai nia palasiu.
\b
\q1 
\v 16 Liurai,\f + \fr 45:16 \ft Lian Ebreu la temi “liurai”.\f* o sei iha oan mane hodi tuur iha o nia kadeira ukun;
\q2 o sei foti sira hodi ukun rai tomak.
\q1 
\v 17 Hau sei foti aas o nia naran husi jerasaun ba jerasaun,
\q2 nunee nasaun hotu-hotu sei gaba o tinan ba tinan.
\c 46
\s1 Nai Maromak Aswain hamutuk ho ita
\d Kantiku ida husi jerasaun Korá nian, tuir muzika Alamot. Ba dirijenti koru.
\b
\q1 
\v 1 Maromak mak foo mahon mai ita no foo forsa mai ita;
\q2 Nia sempre tulun ita iha susar laran.
\q1 
\v 2 Tanba nee ita sei la tauk,
\q2 maski rai nakdoko
\q2 too foho naksobu tuun ba tasi klaran.
\q1 
\v 3 Maski tasi siak nafurin sae
\q2 too laloran baku makaas halo foho nakdoko,
\q2 ita sei la nakdedar.
\b
\q1 
\v 4 Iha mota ida halo haksolok povu iha Maromak nia sidade,
\q2 Maromak Aas Liu hela iha fatin santu nee.
\q1 
\v 5 Maromak iha fatin nee, nunee sidade nee sei la monu.
\q2 Dadeer-saan rai huun mutin, Maromak sei tulun sidade nee.
\q1 
\v 6 Nasaun jentiu sira rungu-ranga, liurai sira nakdoko;
\q2 Maromak nia lian tarutu halo rai nabeen tiha.
\q1 
\v 7 NAI Maromak Aswain hamutuk ho ita;
\q2 Jacó nia Maromak mak ita nia abrigu.
\b
\q1 
\v 8 Mai hodi haree saida mak NAI Maromak halo tiha ona.
\q2 Haree ba! Nia hatudu buat boot iha mundu.
\q1 
\v 9 Nia hapara funu husi rai ulun too rai ikun iha mundu tomak.
\q2 Nia silu tohar tiha rama no halo rahun tiha diman.
\q2 Ai belar nebee ema uza hodi defende aan, Nia sunu tiha.
\b
\q1 
\v 10 Maromak dehan, “Hakmatek ba, no rekonhese katak Hau mak Maromak.
\q2 Ema iha nasaun hotu-hotu haboot Hau nia naran;
\q2 ema iha mundu tomak foti aas Hau nia naran.”
\b
\q1 
\v 11 NAI Maromak Aswain hamutuk ho ita;
\q2 Jacó nia Maromak mak ita nia abrigu.
\c 47
\s1 Nai Maromak Liurai boot
\d Salmu husi Korá nia oan, ba dirijenti koru.
\b
\q1 
\v 1 Povu husi nasaun hotu-hotu, basa liman ba;
\q2 haklalak hahii Maromak ho haksolok.
\q1 
\v 2 Tanba NAI Maromak Kbiit Nain nee makaas;
\q2 Nia mak Liurai boot hodi ukun mundu tomak.
\q1 
\v 3 Nia halo nasaun jentiu sira hakruuk mai ita;
\q2 Nia halo povu jentiu sira monu iha ita nia ain okos.
\q1 
\v 4 Nia hili rai nee hodi foo ba ita povu Israel;\f + \fr 47:4 \ft Lian Ebreu hakerek “Jacó”. Nee hatudu ba Jacó nia jerasaun, povu Israel. \f*
\q2 Nia hadomi teb-tebes ita, ita mos kontenti ho rai nee.
\b
\q1 
\v 5 NAI Maromak sae dadauk baa tuur iha Nia kadeira ukun, povu haklalak;
\q2 NAI hakat sae, korneta lian akompanha Nia.
\q1 
\v 6 Hananu hahii Maromak, hananu hahii ba Nia;
\q2 hananu hahii ba ita nia Liurai, hananu hahii ba,
\q1 
\v 7 tanba Maromak nee mundu tomak nia Liurai;
\q2 hananu salmu hodi hahii Nia ba.
\q1 
\v 8 Maromak ukun nasaun hotu-hotu;
\q2 Maromak tuur iha Nia kadeira ukun santu nian.
\q1 
\v 9 Nai ulun nasaun sira nee halibur hamutuk
\q2 ho povu nebee Abraão nia Maromak hili nanis ona,
\q1 tanba liurai hotu-hotu iha mundu nee Maromak nian;
\q2 Nia mak boot liu hotu-hotu.
\c 48
\s1 Jerusalém Nai Maromak nia sidade
\d Salmu husi Korá nia oan. Kantiku ida.
\b
\q1 
\v 1 NAI Maromak nee boot;
\q2 ita nia Maromak merese duni atu ita hahii
\q1 iha Nia sidade,
\q2 iha Nia foho santu.
\q1 
\v 2 \x + \xo 48:2 \xt Mateus 5:35\x*Foho nee aas ho furak,
\q2 halo haksolok mundu tomak.
\q1 Nee mak foho Siaun, iha liu parte norte,
\q2 Liurai boot nia sidade.
\q1 
\v 3 Iha sidade nia moru laran,
\q2 Maromak hatudu ona katak Nia rasik mak defende sidade nee.
\b
\q1 
\v 4 Liurai nasaun sel-seluk halibur sira nia tropas;
\q2 sira hamutuk avansa ba oin.
\q1 
\v 5 Bainhira sira haree sidade nee, sira hakfodak;
\q2 sira tauk hodi halai.
\q1 
\v 6 Iha nebaa, sira nakdedar makaas;
\q2 sira terus hanesan feto nebee atu tuur ahi;
\q2 
\v 7 sira hanesan roo Tarsis nebee anin lorosae riba tuun-sae.
\b
\q1 
\v 8 Uluk ita rona tiha ona;
\q2 agora ita mos haree ona
\q1 iha NAI Maromak Aswain nia sidade,
\q2 iha ita nia Maromak nia sidade.
\q1 Maromak harii metin sidade nee too tinan ba tinan.
\b
\q1 
\v 9 Maromak, iha Ita Boot nia uma kreda,
\q2 ami medita Ita Boot nia domin rohan-laek.
\q1 
\v 10 Maromak, ema iha fat-fatin temi Ita Boot nia naran,
\q2 too ema husi rai ulun rai ikun iha mundu tomak mos hahii Ita Boot;
\q2 Ita Boot nia liman loos nakonu ho justisa.
\q1 
\v 11 Foho Siaun haksolok;
\q2 Judá oan sira kontenti
\q2 tanba Ita Boot nia justisa.
\b
\q1 
\v 12 Lao haleu Siaun, hadulas sidade nee tomak;
\q2 sura took nia tore aas;
\q1 
\v 13 fihir di-diak sidade nia moru;
\q2 sukat moru nia aas no mahar,
\q1 atu nunee o bele konta ba jerasaun tuir mai katak,
\q1 
\v 14 Maromak nee mak ita nia Maromak nafatin ba nafatin;
\q2 Nia sai ita nia matadalan too tinan ba tinan.
\c 49
\s1 Konfia riku-soin la iha folin
\d Salmu husi Korá nia oan, ba dirijenti koru.
\b
\q1 
\v 1-2 Imi husi nasaun hotu-hotu, rona mai!
\q1 Kiik ho boot, riku ho kiak,
\q2 hotu-hotu nebee moris iha mundu, see tilun mai.
\q1 
\v 3 Hau nia ibun sei koalia buat matenek;
\q2 buat nebee hau nia laran medita sei halo imi kompriende.
\q1 
\v 4 Hau sei see tilun ba lia matenek nian;
\q2 hau sei toka viola hodi esplika lia matenek nee.
\b
\q1 
\v 5 Iha loron dezastre,
\q2 bainhira ema aat haleu hau, hau atu tauk saida?
\q1 
\v 6 Sira nee konfia sira nia riku-soin;
\q2 sira foti aan tanba riku boot.
\q1 
\v 7 La iha ema ida mak bele selu kotu nia vida
\q2 ka foo nia riku ba Maromak atu salva nia moris.
\q1 
\v 8 Tanba ema nia vida folin karun liu;
\q2 nia selu ho riku-soin saida deit mos la too
\q1 
\v 9 atu nia bele moris nafatin ba nafatin,
\q2 atu nia la bele tama ba rai kuak.
\b
\q1 
\v 10 Ita hotu haree katak ema matenek mate,
\q2 hanesan mos ema nebee beik-teen la hatene buat ida.
\q2 Sira hotu husik sira nia riku-soin ba ema seluk.
\q1 
\v 11 Uluk sira iha rai luan;
\q2 too ikus rate mak sai fali sira nia uma tinan ba tinan;
\q2 rai kuak mak sai sira nia hela fatin husi jerasaun ba jerasaun.
\q1 
\v 12 Maski ema riku, nia la bele moris nafatin;
\q2 nia hanesan animal nebee too tempu ida sei mate.
\q1 
\v 13 Ema nebee konfia nia aan, nia dalan mak nee;
\q2 ida nee mak destinu ba ema nebee mak laran metin ba nia lia fuan rasik.
\q1 
\v 14 Sira nia destinu mak mate;
\q2 sira hanesan bibi malae,
\q1 mate mak sira nia bibi atan hodi lori sira ba matebian sira nia fatin;
\q2 sira tuun kedas ba iha rai kuak.
\q1 Rai sei haan tiha sira nia isin;
\q2 sira dook tiha ona husi sira nia uma diak nian.
\q1 
\v 15 Maibee Maromak sei salva hau husi matebian sira nia fatin;
\q2 Nia sei dada hau sae ba iha Nia prezensa.
\b
\q1 
\v 16 Keta preokupa bainhira ema seluk hetan riku;
\q2 se nia riku-soin aumenta ba beibeik mos lalika tauk,
\q1 
\v 17 tanba ema nee mate, sei la lori buat ida;
\q2 nia riku-soin la baa hamutuk ho nia.
\q1 
\v 18 Iha nia moris tomak nia konsidera nia aan ema nebee hetan bensaun;
\q2 ema nebee moris diak hanesan nee, ema seluk sempre gaba.
\q1 
\v 19 Maski nunee nia sei baa hamutuk ho sira nebee baa uluk ona;
\q2 nia nunka atu haree tan naroman moris nian.
\q1 
\v 20 Ema nebee riku maibee falta kompriensaun,
\q2 sira hanesan animal nebee too tempu ida sei mate.
\c 50
\s1 Sakrifisiu nebee loos
\d Salmu Asaf nian.
\b
\q1 
\v 1 NAI Maromak Kbiit Nain
\q2 lia tuun hodi bolu ema iha mundu tomak,
\q1 husi lorosae too loromonu.
\q1 
\v 2 Maromak nia naroman leno sai
\q2 husi foho Siaun, fatin nebee furak teb-tebes.
\q1 
\v 3 Ita nia Maromak mai,
\q2 Nia sei la nonook;
\q1 ahi lakan boot iha hela Nia oin;
\q2 anin makaas haleu Nia.
\q1 
\v 4 Nia bolu lalehan ho rai atu asisti
\q2 bainhira Nia foo justisa ba Nia povu; Nia dehan,
\q1 
\v 5 “Halibur povu nebee foo laran mai Hau;
\q2 sira nee halo promesa ho Hau liu husi sakrifisiu tunu.”
\q1 
\v 6 Lalehan foo sai katak Maromak tesi lia sempre loos,
\q2 tanba Nia nee Justisa Nain.
\b
\q1 
\v 7 “Hau nia povu, rona mai, Hau sei koalia;
\q2 Israel, Hau sei foo sasin kontra o.
\q2 Hau mak Maromak, o nia Maromak.
\q1 
\v 8 Laos tanba o nia sakrifisiu la too mak Hau foo sala ba o;
\q2 sakrifisiu tunu nebee imi foo, sempre iha Hau nia oin.
\q1 
\v 9 Hau la presiza karau husi o nia luhan
\q2 ka bibi husi o nia luhan laran,
\q1 
\v 10 tanba animal hotu-hotu iha ai laran Hau nian;
\q2 karau iha foho rihun ba rihun mos Hau nian.
\q1 
\v 11 Hau hatene manu hotu-hotu iha foho;
\q2 buat saida deit mak book aan iha rai fuik, Hau nian hotu.
\q1 
\v 12 Se Hau hamlaha karik, Hau la hatete ba o,
\q2 tanba mundu ho buat hotu nebee mak iha laran, nee Hau nian.
\q1 
\v 13 Imi hanoin katak Hau haan naan karau aman ka?
\q2 Hau hemu bibi aman nia raan ka?
\q1 
\v 14 Diak liu foo agradesimentu nudar o nia sakrifisiu ba Maromak;
\q2 halo tuir o nia promesa ba Maromak Aas Liu.
\q1 
\v 15 Bainhira o iha susar laran, harohan mai Hau
\q2 mak Hau sei salva o, no o sei foti aas Hau nia naran.”
\b
\q1 
\v 16 Maibee ba ema aat, Maromak hatete nunee:
\q1 “O temi beibeik Hau nia ukun fuan atu halo saida?
\q2 O nia ibun koalia hela deit hau nia promesa atu halo saida?
\q1 
\v 17 Afinal o lakohi atu Hau koriji o;
\q2 o soe Hau nia liafuan ba kotuk.
\q1 
\v 18 Bainhira o haree naok-teen, o baa hamutuk ho nia;
\q2 o ranxu ema nebee halo sala seksual.
\q1 
\v 19 O husik o nia ibun koalia buat aat;
\q2 o foo o nia nanaal ba liafuan bosok.
\q1 
\v 20 O tuur koalia aat o nia maun-alin;
\q2 o hatete aat o nia inan nia oan.
\q1 
\v 21 Bainhira o halo buat sira nee, Hau nonook deit,
\q2 too o hanoin Hau mos hanesan ho o.
\q1 Maibee agora Hau foo sala ba o
\q2 hodi foo sai o nia hahalok ida-idak.
\b
\q1 
\v 22 Imi sira nebee haluha Maromak, rona mai!
\q2 Se lae Hau sei lees tiha imi, la iha ema ida bele salva imi.
\q1 
\v 23 Bainhira ema foo agradese mai Hau,
\q2 nee mak sakrifisiu ida nebee foti aas Hau nia naran;
\q1 ema nebee mak lao iha dalan loos,
\q2 Hau, Maromak sei hatudu Hau nia salvasaun ba nia.”
\c 51
\s1 Orasaun husu perdaun
\d Salmu David nian, bainhira profeta Natan mai hasee David tanba nia halo sala ho Batseba. Ba dirijenti koru.
\b
\q1 
\v 1 Nai Maromak, hanoin hau ba!
\q2 Tanba Ita Boot nia domin nunka hotu.
\q1 Ita Boot nee laran luak,
\q2 nunee halakon tiha hau nia hahalok aat hotu-hotu.
\q1 
\v 2 Fase moos hau nia pekadu;
\q2 hamoos hau nia sala.
\q1 
\v 3 Tanba hau rekonhese hau nia hahalok aat;
\q2 hau nia sala sempre mosu iha hau nia hanoin.
\q1 
\v 4 \x + \xo 51:4 \xt Roma 3:4\x*Hau halo sala kontra Ita Boot, so Ita Boot deit;
\q2 hau halo tiha ona buat nebee aat iha Ita Boot nia oin.
\q1 Nunee Ita Boot hakotu hau nia lia, kona duni;
\q2 Ita Boot hatuun kastigu mai hau nee loos.
\q1 
\v 5 Tebes duni, hau moris mai sala nanis kedas;
\q2 hau sala nain husi tempu nebee hau nia inan foin isin rua.
\q1 
\v 6 Maibee Ita Boot hakarak atu hau nia laran tenki moos,
\q2 nunee hanorin hau atu hau sai matenek.
\b
\q1 
\v 7 Hisik bee ba hau hodi ai hisopu para hau sai moos;
\q2 fase moos tiha hau mak hau sei sai mutin liu fali kabas rahun.
\q1 
\v 8 Foo ksolok ho kontenti mai hau.
\q2 Ita Boot harahun tiha ona hau nia ruin;
\q2 agora husik hau hamriik fali ho haksolok.
\q1 
\v 9 Keta haree ba hau nia sala;
\q2 halakon tiha hau nia pekadu.
\b
\q1 
\v 10 Maromak, halo hau nia neon moos;
\q2 hafoun hau nia laran halo hau laran metin ba Ita Boot.
\q1 
\v 11 Keta duni sai hau husi Ita Boot nia oin;
\q2 keta hasai Ita Boot nia Espiritu Santu husi hau.
\q1 
\v 12 Halo hau haksolok fila fali tanba Ita Boot salva tiha ona hau;
\q2 halo hau nia laran prontu atu moris tuir Ita Boot nia hakarak.
\b
\q1 
\v 13 Depois hau sei hanorin Ita Boot nia dalan ba ema sala nain sira,
\q2 atu nunee sira bele fila fali ba Ita Boot.
\q1 
\v 14 Maromak hau nia Salvador,
\q2 salva hau husi ema nebee mak eziji hau nia raan fakar.\f + \fr 51:14 \ft Lian Ebreu iha nee dehan, “salva hau husi raan”. La klaru, salmista tauk ema seluk atu oho nia ka, nia oho tiha ona ema seluk ka, nia husu para aban-bainrua nia la bele oho ema.\f*
\q2 Nunee hau sei hananu kona ba Ita Boot nia salvasaun.
\q1 
\v 15 Nai Maromak, loke hau nia ibun
\q2 mak hau sei hahii Ita Boot.
\q1 
\v 16 Se hau oho animal hodi halo sakrifisiu ba Ita Boot, nee la halo haksolok Ita Boot nia laran;
\q2 Maski hau lori sakrifisiu tunu mos, la halo Ita Boot kontenti.
\q1 
\v 17 Maromak, hau nia sakrifisiu mak hau nia fuan nebee rahun,
\q2 hau nia laran nebee dodok, nakonu ho arependimentu.
\q2 Sakrifisiu nee monu duni ba Ita Boot nia laran.
\b
\q1 
\v 18 Hatudu Ita Boot nia laran diak ba povu Siaun para povu bele hetan diak;
\q2 harii fila fali moru haleu sira nia sidade Jerusalém nee.
\q1 
\v 19 Depois Ita Boot nia laran sei kontenti ho sakrifisiu lo-loos,
\q2 sakrifisiu tunu nebee ami oferese tomak ba Ita Boot.
\q2 Ami sei oferese karau aman boot hodi tunu iha Ita Boot nia altar.
\c 52
\s1 Kastigu ba ema aat sira
\d Salmu David nian, bainhira ema Edom ida naran Doeg baa kesar ba Saul dehan, “David baa tiha ona iha Ahimelek nia uma.” Salmu nee para hanorin ema. Ba dirijenti koru.
\b
\q1 
\v 1 Eroi boot, nusaa mak o gaba aan kona ba hahalok aat
\q2 hasoru ema nebee Maromak hadomi?
\q1 
\v 2 Lohi door, o iha planu atu halo aat ema;
\q2 o nia ibun kroat hanesan tudik.
\q1 
\v 3 O gosta buat aat liu fali buat diak;
\q2 o gosta koalia bosok liu fali koalia buat nebee loos.
\q1 
\v 4 Lohi-teen, o gosta koalia liafuan nebee halo terus ema.
\b
\q1 
\v 5 Nee duni, Maromak sei riba tuun o tinan ba tinan;
\q2 Nia sei kaer o hodi rakut o sai husi o nia tenda;
\q2 Nia sei fokit o sai husi ema moris sira nia rain.
\q1 
\v 6 Ema nebee moris loos sei haree no tauk;
\q2 sira sei hamnasa o hodi dehan,
\q1 
\v 7 “Haree took ema nee!
\q2 Nia la buka mahon iha Maromak,
\q1 maibee konfia fali nia riku-soin bar-barak,
\q2 no hamahon aan iha hahalok nebee aat.”
\b
\q1 
\v 8 Maibee hau nee hanesan ai huun oliveira
\q2 nebee moris buras iha Maromak nia uma.
\q1 Hau konfia Maromak nia domin rohan-laek
\q2 nafatin ba nafatin.
\q1 
\v 9 Maromak, hau sei agradese ba Ita Boot tinan ba tinan
\q2 tanba buat nebee Ita Boot halo tiha ona;
\q1 hau sei haklaken Ita Boot nia naran iha Ita Boot nia povu nia leet,
\q2 tanba Ita Boot nee diak.
\c 53
\s1 Ema nia hahalok aat
\d Salmu David nian para hanorin ema. Tuir muzika “Mahalat.” Ba dirijenti koru.
\b
\q1 
\v 1 \x + \xo 53:1 \xt Roma 3:10-12\x*Ema beik sira koalia iha sira nia laran dehan,
\q2 “Maromak la iha!”
\q1 Ema sira nee mesak aat deit; sira nia dalan aat teb-tebes;
\q2 la iha ema ida mak halo buat diak.
\b
\q1 
\v 2 Maromak hateke tuun husi lalehan mai ita ema
\q2 hodi haree, iha ema balu matenek ka lae,
\q2 ema balu harohan ba Maromak ka lae.
\q1 
\v 3 Maibee ema hotu lao sala dalan ona, sira hotu sai aat tiha ona;
\q2 la iha ema ida mak halo buat diak;
\q2 ida mos la iha.
\b
\q1 
\v 4 Ema aat sira nee la hatene buat ida ka?
\q2 Sira haan matak hau nia povu hanesan fali sira haan halimar paun fuan ida;
\q2 sira nunka bolu Maromak nia naran.
\q1 
\v 5 Maibee haree ba, ema sira nee sei tauk teb-tebes;
\q2 tauk nee laos tauk baibain nebee sira senti iha sira nia moris.
\q1 Maromak nia povu, ema nebee ataka imi, Maromak sei halo sira nia ruin naklekar;
\q2 Maromak lakohi simu sira, nunee imi sei hatuun sira.
\b
\q1 
\v 6 Hau harohan atu Maromak hamriik iha foho Siaun hodi salva Israel.
\q2 Bainhira Maromak hadia fali Nia povu nia moris,
\q2 Jacó nia jerasaun sei haksolok, Israel sei kontenti.
\c 54
\s1 Orasaun husu Nai Maromak proteje
\d Salmu David nian, bainhira ema Zifi sira baa kesar ba Saul dehan, “David subar hela iha ami nia leet.” Salmu nee para hanorin ema. Akompanha ho viola. Ba dirijenti koru.
\b
\q1 
\v 1 Maromak, hodi Ita Boot nia naran salva hau ba;
\q2 hodi Ita Boot nia kbiit foo justisa mai hau.
\q1 
\v 2 Maromak, rona hau nia orasaun;
\q2 see tilun ba hau nia lia fuan.
\q1 
\v 3 Ema foti aan sira mai hodi ataka hau;
\q2 ema laran aat hakarak hasai hau nia vida;
\q2 sira la interese Maromak.
\b
\q1 
\v 4 Maibee Maromak mak ajuda hau;
\q2 Nai Maromak sempre kuidadu hau.
\q1 
\v 5 Husik hau nia inimigu sira nia hahalok aat fila fali ba sira;
\q2 harahun tiha sira, tanba Ita Boot sempre halo buat nebee loos.
\b
\q1 
\v 6 NAI Maromak, ho laran tomak hau sei oferese sakrifisiu ba Ita Boot;
\q2 hau sei hahii Ita Boot nia naran, tanba Ita Boot nee diak.
\q1 
\v 7 Ita Boot salva tiha ona hau husi susar laran;
\q2 hau nia matan haree tiha ona hau nia inimigu sira lakon.
\c 55
\s1 Halerik bainhira belun diak sai fali inimigu
\d Salmu David nian para hanorin ema. Akompanha ho viola. Ba dirijenti koru.
\b
\q1 
\v 1 Maromak, see tilun ba hau nia orasaun;
\q2 keta fila kotuk ba hau nia hamulak.
\q1 
\v 2 Rona hau hodi hataan hau ba;
\q2 hau hanoin la hetan too hau nia laran dodok.
\q1 
\v 3 Tanba hau nia inimigu sira hakilar hau;
\q2 ema aat ameasa hau;
\q1 sira hanehan hau;
\q2 sira odi hau ho laran nakali.
\b
\q1 
\v 4 Hau nia fuan nakdedar;
\q2 ameasa mate nian hanehan hau.
\q1 
\v 5 Hau tauk ho nakdedar
\q2 too isin fulun hamriik.
\q1 
\v 6 Hau hanoin, “Diak liu hau iha liras manu pombu nian,
\q2 atu hau bele semo sai hodi hakmatek.
\q1 
\v 7 Hau atu semo dook
\q2 baa hela iha rai fuik;
\q1 
\v 8 hau atu baa lalais buka fatin mahon,
\q2 dook husi anin boot ho udan boot.”
\b
\q1 
\v 9 Nai Maromak, halo ema aat sira nia neon lakon tiha;
\q2 husik sira koalia arbiru ba,
\q2 tanba hau haree violensia ho rungu-ranga iha sidade laran.
\q1 
\v 10 Loron-kalan sira lao haleu sidade hodi kontrola iha moru leten;
\q2 iha moru laran nakonu ho hanoin aat ho krimi.
\q1 
\v 11 Estraga door sira lao hela iha sidade nee;
\q2 iha estrada ninin sira hanehan ema no haan matak ema nia riku-soin la para.
\b
\q1 
\v 12 Se karik hau nia inimigu mak hatete aat hau,
\q2 hau sei aguenta;
\q1 se karik funu baluk ida mak foti aan hasoru hau,
\q2 hau sei bele subar aan husi nia.
\q1 
\v 13 Maibee o mak halo fali, o ho hau hanesan;
\q2 o nee hau nia maluk, hau nia belun diak.
\q1 
\v 14 Ita nain rua uluk ranxu malu diak loos;
\q2 ita tama iha Maromak nia uma kreda iha ema barak nia leet.
\b
\q1 
\v 15 Husik hau nia inimigu sira mate mean;
\q2 husik sira tuun moris ba ema mate sira nia fatin,
\q1 tanba hahalok aat iha hela sira nia uma,
\q2 iha hela sira nia laran.
\b
\q1 
\v 16 Maibee hau harohan ba NAI Maromak
\q2 mak Maromak salva hau.
\q1 
\v 17 Iha tempu kalan, dadeer-saan ho meudia,
\q2 hau halerik ho laran susar;
\q2 Nia rona hau nia lian.
\q1 
\v 18 Nia salva hau;
\q2 maski ema nadodon mai hodi ataka hau,
\q2 buat ida la kona hau.
\q1 
\v 19 Maromak nee Liurai hori uluk kedas;
\q2 Nia sei rona hau hodi hatuun sira,
\q1 tanba sira nee lakohi arepende,
\q2 no la hamtauk Maromak.
\b
\q1 
\v 20 Hau nia kolega ataka fali nia maun-alin koran sira;
\q2 nia kontra fali nia promesa ho sira.
\q1 
\v 21 Nia koalia ho ibun midar,
\q2 maibee nia laran hakarak funu;
\q1 nia liafuan kabeer liu fali mina,
\q2 maibee kroat hanesan surik.
\b
\q1 
\v 22 Entrega o nia preokupasaun ba NAI Maromak
\q2 mak Nia sei kuidadu o;
\q2 Nia nunka husik ema nebee moris loos atu nakdoko.
\b
\q1 
\v 23 Maibee Maromak, Ita Boot sei soe tuun tiha ema aat sira
\q2 ba iha rai kuak naruk;
\q1 oho-door ho traidor sira nia vida sei la naruk;
\q2 sira mate ho tinan badak.
\q1 Maibee hau nee konfia Ita Boot.
\c 56
\s1 Laran metin ba Nai Maromak iha tempu susar
\d Salmu David nian, bainhira ema Filístia sira kaer nia iha sidade Gat. Salmu nee para hanorin ema. Tuir muzika “Manu pombu iha ai huun nebee dook.” Ba dirijenti koru.
\b
\q1 
\v 1 Maromak, hatudu Ita Boot nia laran luak mai hau,
\q2 tanba ema sama hela hau;
\q2 loron-kalan hau nia inimigu sira hanehan hau.
\q1 
\v 2 Hau nia funu baluk sira sama hela hau loron-kalan;
\q2 ema barak foti aan ataka hau.
\q1 
\v 3 Maromak Aas Liu, bainhira hau tauk,
\q2 hau konfia Ita Boot.
\q1 
\v 4 Hau hahii Maromak tanba buat nebee Nia promete ona;
\q2 hau fiar Nia, nunee hau la tauk.
\q2 Ema mundu nee bele halo saida ba hau?
\b
\q1 
\v 5 Loron-kalan hau nia inimigu sira bobar hau nia liafuan;
\q2 sira sempre iha hanoin aat ba hau.
\q1 
\v 6 Sira kombina malu;
\q2 sira hafuhu hau;
\q1 sira haree tu-tuir hau nia dalan;
\q2 sira hakarak atu hasai hau nia vida.
\q1 
\v 7 Maromak, keta husik sira moris, tanba sira nia hahalok aat;
\q2 hamonu nasaun jentiu sira ho hirus ba.
\b
\q1 
\v 8 Hau nia terus Ita Boot mak sura;
\q2 hau nia matan been Ita Boot tau iha botir.
\q2 Buat sira nee hotu Ita Boot hakerek iha Ita Boot nia livru.
\b
\q1 
\v 9 Bainhira hau harohan,
\q2 hau nia inimigu sira sei hakiduk.
\q2 Hau hatene katak Maromak hamutuk ho hau.
\q1 
\v 10 Hau hahii Maromak tanba buat nebee Nia promete ona;
\q2 hau hahii NAI Maromak tanba promesa nebee Nia halo.
\q1 
\v 11 Hau fiar Maromak, nunee hau la tauk.
\q2 Ema mundu nee bele halo saida ba hau?
\b
\q1 
\v 12 Maromak, hau sei kumpri hau nia juramentu ba Ita Boot;
\q2 hau sei foo oferta agradesimentu nian ba Ita Boot.
\q1 
\v 13 Tanba Ita Boot hasai tiha ona hau husi mate;
\q2 Ita Boot kuidadu hau nia ain la sidi,
\q1 nunee hau bele lao iha Maromak nia oin,
\q2 iha naroman moris nian.
\c 57
\s1 Orasaun ho laran metin ba Nai Maromak iha tempu susar
\d Salmu David nian, bainhira nia halai sees husi Saul hodi tama iha fatuk kuak laran. Salmu nee para hanorin ema. Tuir muzika “Keta harahun.” Ba dirijenti koru.
\b
\q1 
\v 1 Maromak, hatudu Ita Boot nia laran luak mai hau;
\q2 hanoin hau ba,
\q2 tanba hau hamahon aan iha Ita Boot.
\q1 Hau sei hamahon aan iha Ita Boot nia liras okos
\q2 too dezastre liu tiha.
\q1 
\v 2 Hau harohan ba Maromak Aas Liu;
\q2 hau husu tulun ba Maromak tanba Nia halo buat diak mai hau.
\q1 
\v 3 Nia sei hatuun salvasaun husi lalehan mai hau;
\q2 Nia sei hamoe ema sira nebee mak sama hau.
\q1 Maromak haraik Nia domin rohan-laek ho Nia lia loos.
\b
\q1 
\v 4 Hau toba hela iha liaun nia klaran;
\q2 sira gosta lees matak ema hodi haan;
\q1 sira nia nehan hanesan diman ho rama oan;
\q2 sira nia nanaal kroat hanesan surik.
\b
\q1 
\v 5 Maromak, hatudu Ita Boot nia Aan aas liu lalehan;
\q2 halo Ita Boot nia kbiit domina mundu tomak.
\b
\q1 
\v 6 Hau nia inimigu sira monta tiha ona redi ba hau nia ain;
\q2 hau sai muroon tiha;
\q1 sira kee rai kuak iha dalan nebee hau atu liu,
\q2 maibee sira rasik mak monu tama ba laran.
\b
\q1 
\v 7 Maromak, hau laran metin ba Ita Boot;
\q2 hau nia laran metin;
\q2 hau sei toka muzika hodi hananu hahii Ita Boot.
\q1 
\v 8 Hau hatete ba hau nia aan, hadeer ba!
\q2 Viola ho viola tali sanulu, hadeer ba!
\q2 Hau sei fanu loro matan.
\q1 
\v 9 Nai Maromak, hau sei hahii Ita Boot iha nasaun hotu-hotu nia klaran;
\q2 hau sei hananu ba Ita Boot iha povu sira nia leet,
\q1 
\v 10 tanba Ita Boot nia domin boot too iha lalehan;
\q2 Ita Boot nia lia loos firmi too iha kalohan.
\b
\q1 
\v 11 Maromak, hatudu Ita Boot nia Aan aas liu lalehan;
\q2 halo Ita Boot nia kbiit domina mundu tomak.
\c 58
\s1 Orasaun husu justisa
\d Salmu David nian para hanorin ema. Tuir muzika “Keta harahun.” Ba dirijenti koru.
\b
\q1 
\v 1 Ukun nain sira, imi koalia lia loos ka?
\q2 Imi tesi ema nia lia ho lo-loos ka lae?
\q1 
\v 2 Lae, imi nia hanoin aat;
\q2 imi nia liman halao violensia iha rai.
\q1 
\v 3 Husi kabun laran kedas ema aat lao sala dalan;
\q2 moris mai kedas sira lao sala hodi bosok ema.
\q1 
\v 4 Sira iha veneno hanesan samea nia veneno,
\q2 hanesan samea kobra nebee taka tiha nia tilun
\q1 
\v 5 para nia nain toka muzika, nia la bele rona;
\q2 muzika bele kapaas mos, nia lakohi atu rona.
\b
\q1 
\v 6 Maromak, harahun tiha sira nia nehan iha sira nia ibun laran;
\q2 NAI, halo tohar tiha liaun sira nee nia nehan ba.
\q1 
\v 7 Husik sira lakon hanesan bee nebee suli lakon;
\q2 husik sira sai namlaik hanesan duut iha dalan.
\q1 
\v 8 Halo sira mohu hanesan karakol nia kabeen nebee maran tu-tuir;
\q2 halo sira hanesan bebee nebee abortu tiha, nunka hetan loro matan.
\q1 
\v 9 Molok ema bele sunu ai sanak lotuk hodi hamanas sanan,
\q2 Maromak sei dasa sai tiha ema aat sira.\f + \fr 58:9 \ft Versikulu nee iha lian Ebreu la klaru.\f*
\b
\q1 
\v 10 Ema moris loos sei haksolok bainhira sira haree Maromak kastigu ema aat sira;
\q2 sira sei solur sira nia ain iha ema aat sira nia raan laran.
\q1 
\v 11 Ema sei dehan, “Loos duni, ema moris loos sei simu nia kolen;
\q2 tebes, Maromak mak foo justisa ba mundu.”
\c 59
\s1 Husu tulun ba Nai Maromak hodi kontra inimigu
\d Salmu David nian, bainhira Saul haruka ema hafuhu David nia uma para oho nia. Salmu nee para hanorin ema. Tuir muzika “Keta harahun.” Ba dirijenti koru.
\b
\q1 
\v 1 Maromak, salva hau husi hau nia inimigu sira;
\q2 satan netik hau husi sira nebee mak ataka hau.
\q1 
\v 2 Salva hau husi ema sira nebee halo aat;
\q2 hasai hau husi ema oho door sira nia liman laran.
\q1 
\v 3 NAI Maromak, haree ba, sira hein hela hau atu hakotu hau nia vida;
\q2 ema forti sira kombina malu hodi kontra hau;
\q2 afinal hau la halo buat ida ba sira.
\q1 
\v 4 Hau la sala, maibee sira halai mai atu asalta hau.
\q2 Hamriik hodi tulun hau, haree rasik ba.
\q1 
\v 5 NAI Maromak Aswain,
\q2 Ita Boot mak Israel nia Maromak;
\q1 hadeer ba hodi kastigu nasaun jentiu sira;
\q2 keta hanoin tan traidor laran aat sira.
\b
\q1 
\v 6 Sira fila iha oras kalan,
\q2 hakilar hanesan asu nebee hatenu
\q2 hodi lao haleu sidade.
\q1 
\v 7 Haree ba, sira fakar sai liafuan tarata husi sira nia ibun;
\q2 liafuan nebee sai husi sira nia ibun kroat hanesan surik;
\q2 sira hanoin dehan, “See mak atu rona?”
\q1 
\v 8 Maibee NAI Maromak, Ita Boot hamnasa fali sira;
\q2 Ita Boot goza fali nasaun jentiu sira nee hotu.
\q1 
\v 9 Ita Boot mak hau nia forsa, hau laran metin ba Ita Boot;
\q2 Maromak, Ita Boot mak hau nia abrigu.
\q1 
\v 10 Hau nia Maromak nia domin rohan-laek, Nia sei mai simu hau;
\q2 hau nia Maromak sei halo hau manaan hau nia inimigu sira.
\b
\q1 
\v 11 Nai Maromak, Ita Boot defende ami;
\q2 keta oho sira, atu nunee hau nia povu la bele haluha.
\q1 Ho Ita Boot nia kbiit halo sira namkari
\q2 hodi hatuun tiha sira ba.
\q1 
\v 12 Sala sai husi sira nia ibun;
\q2 sira nia ibun koalia buat aat,
\q2 nunee husik sira nia hahalok foti aan sai lasu ba sira nia aan rasik.
\q1 Sira gosta foo malisan no koalia liafuan bosok,
\q2 
\v 13 nunee hamohu sira ho Ita Boot nia hirus ba;
\q2 hamohu sira too sira la iha tan.
\q1 Depois ema husi rai ulun too rai ikun hatene katak,
\q2 Maromak ukun Jacó nia jerasaun.\f + \fr 59:13 \ft Jacó nia jerasaun mak ema Israel. \f*
\b
\q1 
\v 14 Sira fila iha oras kalan,
\q2 hakilar hanesan asu nebee hatenu
\q2 hodi lao haleu sidade.
\q1 
\v 15 Sira lao rai buka ai haan;
\q2 bainhira sira la bosu, sira hakilar.
\b
\q1 
\v 16 Maibee hau sei hananu kona ba Ita Boot nia forsa;
\q2 iha dadeer-saan hau sei kanta sai Ita Boot nia domin rohan-laek,
\q1 tanba Ita Boot mak hau nia abrigu,
\q2 hau nia subar fatin iha tempu susar.
\q1 
\v 17 Ita Boot mak hau nia forsa; hau hananu hahii Ita Boot;
\q2 Maromak, Ita Boot mak hau nia abrigu;
\q2 hau nia Maromak, Ita Boot hadomi hau.
\c 60
\s1 Orasaun husu atu manaan funu
\d Salmu David nian, bainhira David funu hasoru ema Aram Naharaim ho Aram Zoba. Iha tempu nebaa, Joab fila fali hodi oho tiha ema Edom rihun sanulu resin rua iha Rai Masin. Salmu nee para hanorin ema. Tuir muzika “Ai funan promesa nian.” Ba dirijenti koru.
\b
\q1 
\v 1 Maromak, Ita Boot soe tiha ona ami, halo ami lakon;
\q2 Ita Boot hirus hela ami, simu fali ami ba!
\q1 
\v 2 Ita Boot halo rai nakdoko hodi fera rai nakloke tiha;
\q2 halo tomak fila fali ba, tanba atu naksobu ona.
\q1 
\v 3 Ita Boot halo Ita Boot nia povu terus aat liu ona;
\q2 Ita Boot obriga ami hemu tua too lanu todan.
\q1 
\v 4 Maibee ema nebee hamtauk Ita Boot,
\q2 Ita Boot foo sinal atu sira sees aan husi rama oan.
\b
\q1 
\v 5 Hodi Ita Boot nia liman loos salva ami no tulun ami ba,
\q2 atu nunee ema nebee Ita Boot hadomi bele hetan salvasaun.
\q1 
\v 6 Maromak lia tuun husi Nia hela fatin dehan,
\q2 “Hau sei manaan!
\q1 Hau sei fahe rai Sikem ba Hau nia povu;
\q2 Hau sei sukat rai Sukot.
\q1 
\v 7 Rai Gileade Hau nian,
\q2 rai Manassés mos Hau nian;
\q1 ema Efraim Hau nia kapaseti,
\q2 ema Judá Hau nia rota.
\q1 
\v 8 Rai Moab Hau nia basia hodi fase liman;
\q2 rai Edom fatin para soe Hau nia sandalias ba;
\q2 Hau haksolok haklalak tanba Hau manaan rai Filístia.”
\b
\q1 
\v 9 Maromak, see loos mak atu lori hau ba iha sidade nebee forti?
\q2 See loos mak atu lori hau ba iha rai Edom?
\q1 
\v 10 Maromak, Ita Boot soe duni ami ka?
\q2 Maromak, Ita Boot lakohi avansa ho ami nia militar sira ka?
\q1 
\v 11 Tulun ami hodi kontra inimigu sira,
\q2 tanba ema kriatura nia ajuda la iha folin.
\q1 
\v 12 Hamutuk ho Maromak ita sei manaan;
\q2 Nia sei sama ita nia inimigu sira.
\c 61
\s1 Orasaun husu atu Nai Maromak proteje
\d Salmu David nian, akompanha ho viola. Ba dirijenti koru.
\b
\q1 
\v 1 Maromak, rona hau nia halerik;
\q2 see tilun ba hau nia orasaun.
\q1 
\v 2 Husi rai dook hau harohan ba Ita Boot,
\q2 tanba senti la bele ona.
\q1 Lori hau baa tau iha fatuk nebee aas liu hau,
\q2 
\v 3 tanba Ita Boot mak hau nia fatin seguru;
\q2 Ita Boot mak fatin seguransa nebee metin hasoru inimigu sira.
\b
\q1 
\v 4 Husik hau hela iha Ita Boot nia tenda tinan ba tinan;
\q2 husik hau hamahon aan iha Ita Boot nia liras okos.
\q1 
\v 5 Tanba Maromak, Ita Boot rona tiha ona hau nia promesa;
\q2 bensaun nebee Ita Boot rai ba ema nebee hamtauk Ita Boot, hau mos simu ona.
\b
\q1 
\v 6 Foo vida naruk ba liurai;
\q2 husik nia moris too jerasaun ba jerasaun.
\q1 
\v 7 Hau husu atu liurai bele ukun iha Maromak nia prezensa nafatin ba nafatin;
\q2 proteje nia hodi Ita Boot nia domin rohan-laek ho lia loos.
\b
\q1 
\v 8 Nunee hau sei hananu hahii Ita Boot nia naran nafatin ba nafatin;
\q2 hau sei halo tuir hau nia promesa loron ba loron.
\c 62
\s1 Laran metin ba Nai Maromak
\d Salmu David nian, ba dirijenti koru Jedutun.
\b
\q1 
\v 1 Hau besik Maromak mak hau nia laran hakmatek;
\q2 so Nia deit mak bele salva hau.
\q1 
\v 2 Nia mak fatuk lolon boot nebee hau helik ba;
\q2 Nia mak hau nia Salvador.
\q1 Nia mak hau nia abrigu;
\q2 la iha buat ida bele doko hau.
\b
\q1 
\v 3 Imi hotu atu ataka hau too bainhira?!
\q2 Imi atu hamonu hau
\q1 hanesan fali imi hamonu moru nebee haliis tiha ona
\q2 ka lutu nebee besik naksobu.
\q1 
\v 4 Ema sira nee halo planu atu hatuun hau husi hau nia fatin aas;
\q2 sira gosta bosok.
\q1 Sira nia ibun foo bensaun,
\q2 maibee sira nia laran foo malisan.
\b
\q1 
\v 5 Hau besik Maromak mak hau nia laran hakmatek;
\q2 Nia deit mak foo esperansa mai hau.
\q1 
\v 6 Nia mak fatuk lolon boot nebee hau helik ba;
\q2 Nia mak hau nia Salvador.
\q1 Nia mak hau nia abrigu;
\q2 la iha buat ida bele doko hau.
\q1 
\v 7 Maromak mak salva hau no tane aas hau;
\q2 Nia mak fatuk lolon boot teb-tebes nebee hau helik ba;
\q2 Nia mak foo mahon mai hau.
\b
\q1 
\v 8 Maluk sira, konfia ba Maromak iha imi nia moris tomak;
\q2 saida mak iha imi nia laran fakar sai ba Nia,
\q2 tanba Maromak mak foo mahon mai ita.
\b
\q1 
\v 9 Ema kiik sira hanesan buat mamuk ida;
\q2 ema boot sira hanesan lia mamuk deit.
\q1 Se tetu iha dasin karik,
\q2 sira hotu kamaan liu fali anin.
\b
\q1 
\v 10 Keta mehi atu uza violensia hodi sai riku;
\q2 keta laran metin ba sasaan nebee o hadau husi ema.
\q1 Se karik o nia riku-soin aumenta barak mos,
\q2 lalika laran metin ba riku-soin nee.
\b
\q1 
\v 11 Maromak koalia tiha ona;
\q2 hau rona fila-fila ona katak,
\q1 kbiit tomak Maromak nian;
\q2 
\v 12 \x + \xo 62:12 \xt Jó (Ayub) 34:11; Jeremias 17:10; Mateus 16:27; Roma 2:6; Apokalipse 2:23\x*Nai Maromak, Ita Boot nia domin nunka hotu.
\q1 Ita Boot selu ema ida-idak
\q2 tuir buat nebee sira halo tiha ona.
\c 63
\s1 Hamrook ba Nai Maromak
\d Salmu David nian, bainhira nia iha rai fuik maran Judá nian.
\b
\q1 
\v 1 Maromak, Ita Boot mak hau nia Maromak;
\q2 hau hakarak teb-tebes atu besik Ita Boot;
\q1 hau nia laran hamrook ba Ita Boot;
\q2 hau nia aan tomak buka Ita Boot;
\q1 hau hanesan rai nebee maran dekor,
\q2 krekas, la iha bee.
\q1 
\v 2 Hau haree tiha ona Ita Boot iha fatin santu;
\q2 hau fihir Ita Boot nia kbiit ho Ita Boot nia forsa.
\q1 
\v 3 Ita Boot nia domin diak liu fali vida,
\q2 nunee hau nia ibun sei hahii Ita Boot.
\q1 
\v 4 Hau nia moris tomak hau sei agradese ba Ita Boot;
\q2 hau sei foti sae hau nia liman hodi harohan ba Ita Boot.
\q1 
\v 5 Ita Boot sei habosu hau ho hahaan mesak di-diak deit;
\q2 hau sei hananu ho haksolok hodi hahii Ita Boot.
\b
\q1 
\v 6 Iha hau nia toba fatin hau hanoin kona Ita Boot;
\q2 iha kalan tomak hau medita kona ba Ita Boot,
\q1 
\v 7 tanba Ita Boot mak tulun hau;
\q2 iha Ita Boot nia liras okos, hau hamahon aan hodi hananu ho haksolok.
\q1 
\v 8 Hau neon metin ba Ita Boot;
\q2 Ita Boot nia liman loos tane hau.
\b
\q1 
\v 9 Maibee ema nebee hakarak hakotu hau nia vida,
\q2 sira sei tuun ba iha rai kuak naruk nia laran.
\q1 
\v 10 Sira sei mate ho surik;
\q2 sira sei sai asu fuik nia ai haan.
\q1 
\v 11 Maibee liurai sei haksolok tanba Maromak nia diak;
\q2 ema hotu nebee jura hodi Maromak nia naran sei hahii Nia,
\q2 tanba ema bosok-teen sira nia ibun sei taka metin tiha.
\c 64
\s1 Orasaun husu tulun hasoru inimigu
\d Salmu David nian, ba dirijenti koru.
\b
\q1 
\v 1 Hau nia Maromak, rona hau nia lia halerik;
\q2 hau nia inimigu hatauk hau, kuidadu hau nia vida ba.
\q1 
\v 2 Ema aat sira kombina malu hasoru hau, subar hau ba;
\q2 ema lubun boot gosta halo buat aat, proteje hau ba.
\q1 
\v 3 Sira halo kroat sira nia liafuan hanesan fali halo kroat surik;
\q2 sira nia ibun foo sai liafuan moruk hanesan rama inan tiru sai rama oan.
\q1 
\v 4 Sira hafuhu ema laran moos hodi tiru;
\q2 sira tiru lalais deit, la tauk buat ida.
\q1 
\v 5 Sira foo korajen ba malu ho planu aat;
\q2 sira foo ideia ba malu atu monta sira nia lasu iha fatin subar;
\q2 sira dehan, “See mak atu haree?”
\q1 
\v 6 Sira kombina malu ho planu aat hodi dehan,
\q2 “Ita prontu ona, ita nia planu diak loos ona.”
\q2 Tebes, ema nia fuan ho laran klean duni!
\b
\q1 
\v 7 Maibee Maromak sei hana sira ho rama oan;
\q2 sira kanek derepenti deit.
\q1 
\v 8 Nia sei halo sira nia liafuan rasik kona fali sira
\q2 hodi hamohu tiha sira;
\q2 ema hotu nebee haree sei doko ulun hodi hatete aat sira.
\q1 
\v 9 Nunee ema hotu-hotu sei tauk;
\q2 sira sei rekonhese Maromak nia servisu;
\q2 sira sei foo sai buat diak nebee Maromak halo tiha ona.
\q1 
\v 10 Ema moris loos sei haksolok tanba NAI Maromak nia diak;
\q2 sira sei hamahon aan iha Nia;
\q1 ema hotu nebee moris ho laran moos sei tane aas Maromak nia naran.
\c 65
\s1 Hananu agradese ba Nai Maromak nia bensaun
\d Salmu David nian. Kantiku ida, ba dirijenti koru.
\b
\q1 
\v 1 Maromak, ami hahii Ita Boot iha sidade Siaun;
\q2 ami sei halo tuir ami nia promesa ba Ita Boot.
\q1 
\v 2 Ita Boot hataan ema nebee harohan ba Ita Boot;
\q2 ema hotu-hotu sei mai adora Ita Boot.
\q1 
\v 3 Bainhira sala barak hanehan ami,
\q2 Ita Boot hamoos tiha ami nia sala sira nee.
\q1 
\v 4 Ema sira nebee Ita Boot hili
\q2 hodi lori baa hela iha Ita Boot nia fatin santu,
\q2 ema sira nee hetan ksolok.
\q1 Iha Ita Boot nia uma,
\q2 iha Ita Boot nia uma kreda santu,
\q1 ami hetan buat mesak diak deit,
\q2 halo ami bosu.
\b
\q1 
\v 5 Maromak ami nia Salvador,
\q2 Ita Boot hatudu Ita Boot nia forsa hodi hataan ami no salva ami.
\q1 Ema husi rai ulun too rai ikun iha mundu tomak konfia Ita Boot;
\q2 ema nebee hela iha tasi balu mos laran metin ba Ita Boot.
\q1 
\v 6 Ita Boot mak forma foho hodi Ita Boot nia kbiit,
\q2 Ita Boot hatudu sai Ita Boot nia forsa.
\q1 
\v 7 Ita Boot hapara tasi siak ho laloran boot;
\q2 Ita Boot hakalma nasaun sira nebee rungu-ranga.
\q1 
\v 8 Ema husi rai ulun too rai ikun iha mundu tomak
\q2 admira ho Ita Boot nia milagre;
\q1 ema husi lorosae too loromonu,
\q2 Ita Boot halo sira haklalak ho haksolok.
\b
\q1 
\v 9 Ita Boot tau matan ba rai nee hodi rega rai
\q2 sai buras teb-tebes.
\q1 Mota Maromak nian, bee nakonu;
\q2 Ita Boot prepara rai nunee
\q2 para povu bele hetan ai haan.
\q1 
\v 10 Ita Boot hatuun udan ba rai nebee toos nain fila tiha ona;
\q2 Ita Boot foo udan been hodi halo rai sai mamar tiha;
\q2 Ita Boot foo bensaun ba ai horis sira.
\q1 
\v 11 Tanba Ita Boot nia diak mak tin-tinan Ita Boot foo rezultadu diak ba toos;
\q2 Ita Boot nia ain fatin halo rai sai bokur tiha.
\q1 
\v 12 Duut iha rai fuik sai matak ho buras;
\q2 foho sira mos haksolok hotu.
\q1 
\v 13 Iha rai luan bibi nakonu;
\q2 iha toos trigu buras;
\q2 hotu-hotu haklalak hananu ho haksolok.
\c 66
\s1 Hahii Nai Maromak
\d Salmu. Kantiku ida, ba dirijenti koru.
\b
\q1 
\v 1 Mundu tomak, haklalak ho haksolok ba Maromak;
\q2 
\v 2 hananu foti aas Nia naran ba;
\q2 hahii tane aas Nia naran!
\q1 
\v 3 Hatete ba Maromak dehan, “Ita Boot halo buat mesak furak!
\q2 Ita Boot nia kbiit boot teb-tebes,
\q2 halo Ita Boot nia inimigu hakruuk lambe rai iha Ita Boot nia futar oin.
\q1 
\v 4 Mundu tomak hakruuk ba Ita Boot;
\q2 sira hananu hahii Ita Boot;
\q2 sira hananu hahii Ita Boot nia naran.”
\b
\q1 
\v 5 Mai hodi haree buat nebee Maromak halo tiha ona;
\q2 Nia halo buat mesak furak ba ita ema.
\q1 
\v 6 \x + \xo 66:6 \xt Ézodu (Keluaran) 14:21; \xt Josué 3:14-17\x*Nia halo tasi fila ba rai maran;
\q2 Nia povu lao ain hodi hakur mota.
\q1 Mai ita haksolok tanba Nia diak.
\q2 
\v 7 Nia ukun ho kbiit tinan ba tinan;
\q1 Nia matan haree nasaun jentiu sira;
\q2 ema nebee kontra Maromak lalika foti aan.
\b
\q1 
\v 8 Povu jentiu sira, hahii ami nia Maromak ba;
\q2 hasae imi nia lian sai makaas hodi hahii Nia.
\q1 
\v 9 Nia kuidadu ami nia moris;
\q2 Nia halo ami nia ain hamriik metin.
\b
\q1 
\v 10 Maromak, Ita Boot koko ona ami,
\q2 hanesan ema koko osan mutin.
\q1 
\v 11 Ita Boot lori tiha ona ami ba iha dadur laran;
\q2 Ita Boot tula naha todan ba iha ami nia kabaas.
\q1 
\v 12 Inimigu sira sae kuda sama ami nia ulun, Ita Boot husik deit;
\q2 ami lao ona liu husi ahi laran ho bee laran,
\q2 maibee too ikus Ita Boot lori ami ba iha fatin nebee nakonu ho buat diak.
\b
\q1 
\v 13 Hau sei mai iha Ita Boot nia uma lori sakrifisiu tunu;
\q2 hau sei kumpri hau nia promesa
\q1 
\v 14 nebee mak hau nia ibun temi tiha ona,
\q2 buat nebee hau promete bainhira hau iha susar laran.
\q1 
\v 15 Hau sei oferese animal nebee bokur ba Ita Boot nudar sakrifisiu tunu;
\q2 hau sei tunu bibi malae aman halo suar morin sae;
\q2 hau sei oferese karau aman ho bibi aman ba Ita Boot.
\b
\q1 
\v 16 Imi hotu nebee hamtauk Maromak, mai rona ba;
\q2 hau hakarak foo sai ba imi buat nebee mak Nia halo ona mai hau.
\q1 
\v 17 Uluk hau nia ibun husu tulun ba Nia ho lian makaas;
\q2 hau nia nanaal hahii hela Nia.
\q1 
\v 18 Se karik hau rai hela buat aat ruma iha hau nia laran,
\q2 Nai Maromak la rona hau nia orasaun.
\q1 
\v 19 Maibee Maromak rona duni;
\q2 Nia see tilun tiha ona ba hau nia orasaun.
\q1 
\v 20 Hahii Maromak,
\q2 tanba Nia nunka fila kotuk ba hau nia orasaun;
\q2 Nia la hakotu Nia domin rohan-laek mai hau.
\c 67
\s1 Agradese ba Nai Maromak tanba hetan bensaun oi-oin
\d Salmu. Kantiku ida, akompanha ho viola, ba dirijenti koru.
\b
\q1 
\v 1 Maromak, hanoin ami no foo bensaun ba ami;
\q2 halo Ita Boot nia oin nabilan leno ami,
\q1 
\v 2 atu nunee ema iha mundu nee bele hatene Ita Boot nia dalan;
\q2 nasaun hotu-hotu bele rekonhese Ita Boot nia kbiit atu salva ema.
\b
\q1 
\v 3 Maromak, hau harohan atu povu hotu-hotu hahii Ita Boot;
\q2 nasaun hotu-hotu hahii Ita Boot.
\q1 
\v 4 Halo nasaun sira nee kontenti hodi hananu haksolok,
\q2 tanba Ita Boot ukun ema ho justisa
\q2 no hatudu dalan ba nasaun sira iha mundu.
\b
\q1 
\v 5 Maromak, hau harohan atu povu hotu-hotu hahii Ita Boot;
\q2 nasaun hotu-hotu hahii Ita Boot.
\b
\q1 
\v 6 Toos foo tiha ona nia rezultadu;
\q2 Maromak, ita nia Maromak, foo ona bensaun ba ita.
\q1 
\v 7 Maromak foo bensaun ba ita,
\q2 atu ema husi rai ulun too rai ikun iha mundu tomak hamtauk Nia.
\c 68
\s1 Israel haklalak tanba manaan funu
\d Salmu David nian. Kantiku ida, ba dirijenti koru.
\b
\q1 
\v 1 Bainhira Maromak hamriik, Nia inimigu sira halai namkari;
\q2 Nia funu baluk sira halai sees husi Nia oin.
\q1 
\v 2 Nia huu lakon tiha sira hanesan huu ahi suar;
\q2 ema aat sira sei mate mohu iha Maromak nia oin
\q2 hanesan lilin nebee nabeen bainhira besik ahi.
\q1 
\v 3 Maibee ema moris loos haksolok;
\q2 sira kontenti iha Maromak nia oin;
\q2 sira haklalak ho haksolok.
\q1 
\v 4 Hananu ba Maromak;
\q2 hananu hahii Nia naran.
\q1 Nia tuur iha kalohan leten;
\q2 foti aas Nia naran ba!
\q1 Nia naran mak NAI;
\q2 haksolok haklalak iha Nia oin ba!
\b
\q1 
\v 5 Maromak iha hela Nia fatin santu, Nia mak aman ba oan kiak sira;
\q2 Nia mak defende feto faluk sira.
\q1 
\v 6 Maromak foo uma ba ema nebee mak la iha maluk;
\q2 Nia hasai ema dadur sira hodi foo moris diak ba sira,
\q2 maibee kontra door sira hela deit iha rai fuik maran.
\b
\q1 
\v 7 Maromak, bainhira Ita Boot lao iha Ita Boot nia povu nia oin;
\q2 bainhira Ita Boot marxa liu husi rai fuik maran,
\q1 
\v 8 \x + \xo 68:8 \xt Ézodu (Keluaran) 19:18\x*rai nakdoko, lalehan mos hatuun udan
\q2 tanba Sinai nia Maromak mai tiha ona;
\q2 Israel nia Maromak too tiha ona.
\q1 
\v 9 Maromak, Ita Boot hatuun udan boot mai
\q2 hodi halo Ita Boot nia rai nebee maran dekor sai matak fali ona.
\q1 
\v 10 Nunee Ita Boot nia povu hela metin iha nebaa;
\q2 Maromak, Ita Boot habosu tiha ona ema kbiit-laek sira tanba Ita Boot laran diak.
\b
\q1 
\v 11 Nai Maromak hatuun Nia orden;
\q2 feto barak mos hatutan Nia liafuan dehan,
\q1 
\v 12 “Liurai sira ho militar sira halai hotu!”
\q2 Sasaan nebee tropas sira hadau, feto sira iha uma mak fahe ba malu.
\q1 
\v 13 Too ema nebee toba deit iha bibi luhan mos
\q2 simu manu pombu, nia liras taka ho osan mutin,
\q2 nia fulun osan mean nebee nabilan.
\q1 
\v 14 Maromak Kbiit Nain halo liurai sira namkari
\q2 hanesan neve nebee monu iha foho Zalmon leten.
\b
\q1 
\v 15 Foho Basán, foho boot;
\q2 foho Basán, foho nebee iha tutun barak.
\q1 
\v 16 Foho tutun barak nee,
\q2 tansaa mak o laran moras
\q1 ba foho nebee Maromak hili atu sai Nia hela fatin?
\q2 NAI Maromak sei hela iha nebaa tinan ba tinan.
\b
\q1 
\v 17 Maromak nia kuda kareta rihun ba rihun,
\q2 tokon ba tokon;
\q1 Nai Maromak mai tiha ona husi Sinai, tama iha fatin santu.
\q1 
\v 18 \x + \xo 68:18 \xt Éfezu 4:8\x*Bainhira Nia sae ba iha fatin aas,
\q2 Nia lori inimigu sira nebee Nia kaer iha funu laran;
\q1 Nia simu prezenti husi ema,
\q2 too ema kontra door sira mos foo prezenti.
\q2 Depois NAI Maromak hela iha nebaa.
\b
\q1 
\v 19 Hahii Nai Maromak, ita nia Salvador;
\q2 loro-loron Nia lori ita nia naha.
\q1 
\v 20 Ita nia Maromak nee Maromak Salvador;
\q2 NAI Maromak Kbiit Nain hasai ita husi mate.
\b
\q1 
\v 21 Tebes duni, Maromak sei baku rahun tiha Nia inimigu sira nia ulun;
\q2 ema sira nebee moris nafatin iha sala laran, Maromak sei halo rahun tiha sira nia ulun fatuk.
\q1 
\v 22 Nai hatete, “Hau sei lori inimigu sira mai husi rai Basán;
\q2 sira nebee iha tasi kidun mos, Hau sei lori hotu
\q1 
\v 23 atu o nia ain bele sama iha funu baluk sira nee nia raan,
\q2 no o nia asu sira mos lambe hotu.”
\b
\q1 
\v 24 Maromak, ami haree Ita Boot nia prosisaun lao mai;
\q2 Hau nia Maromak, hau nia Liurai, Ita Boot nia prosisaun lao ba iha fatin santu.
\q1 
\v 25 Koru lao iha oin, tokador sira toka husi kotuk;
\q2 iha klaran feto klosan sira baku babadook.
\q1 
\v 26 Sira kanta, “Hahii Maromak iha ema lubuk boot nia leet;
\q2 Israel oan sira, hahii NAI Maromak ba.”
\q1 
\v 27 Haree ba, suku kiik Benjamim lao uluk iha prosisaun;
\q2 nai ulun Judá sira lao hamutuk;
\q2 nai ulun Zebulón ho nai ulun Naftali lao tuir.
\b
\q1 
\v 28 Maromak, manda Ita Boot nia kbiit ba;
\q2 Maromak, hatudu Ita Boot nia forsa mai ami hanesan uluk Ita Boot hatudu tiha ona.
\q1 
\v 29 Bainhira Ita Boot sai mai husi Ita Boot nia uma kreda iha Jerusalém,
\q2 liurai sira lori oferta ba Ita Boot.
\q1 
\v 30 Siak tiha animal fuik sira nebee subar hela iha duut manulain nia laran;
\q2 hasee makaas karau aman forti sira nebee helik iha karau oan nia leet.
\q1 Sama hanehan tiha sira nebee mak duni tuir osan mutin;
\q2 duni lakon tiha nasaun sira nebee mak gosta funu.
\q1 
\v 31 Ema lori sasaan folin karun husi rai Ejitu;
\q2 rai Etiópia sei lolo liman ba Maromak.
\b
\q1 
\v 32 Imi povu husi nasaun hotu-hotu, hananu ba Maromak;
\q2 hananu hahii Nai Maromak ba.
\q1 
\v 33 Nia sae kuda haleu kalohan antigu nian;
\q2 rona ba, Nia lian sai mai boot makaas hanesan rai tarutu.
\q1 
\v 34 Foo sai Maromak nia kbiit;
\q2 Nia ukun iha Israel;
\q2 Nia forsa iha kalohan laran.
\q1 
\v 35 Maromak nee makaas iha Nia fatin santu;
\q2 Israel nia Maromak foo forsa ho kbiit ba Nia povu.
\b
\q1 Hahii Maromak!
\c 69
\s1 Orasaun bainhira iha susar laran
\d Salmu David nian, tuir muzika “Ai funan liriu.” Ba dirijenti koru.
\b
\q1 
\v 1 Maromak, salva hau,
\q2 tanba bee sae too tiha ona hau nia kakorok.
\q1 
\v 2 Hau mout iha tahu been naruk laran;
\q2 hau nia ain la sama metin ba rai.
\q1 Hau iha hela bee boot laran;
\q2 korenti makaas atu halo hau mout.
\q1 
\v 3 Hau halerik husu tulun too fraku ona;
\q2 hau nia kakorok sai maran tiha;
\q1 hau hein Maromak nia tulun
\q2 too hau nia matan sai kole tiha.
\q1 
\v 4 \x + \xo 69:4 \xt Salmu 35:19; João 15:25\x*Ema odi hau maski hau la halo aat ba sira;
\q2 sira nee barak liu fali hau nia fuuk lahan.
\q1 Ema barak loos sai hau nia inimigu maski hau la halo sala hasoru sira;
\q2 sira hakarak atu halakon hau nia vida.
\q1 Sira eziji hau atu foo fali sira nia sasaan;
\q2 afinal hau nunka hadau buat ida husi sira.
\b
\q1 
\v 5 Maromak, Ita Boot hatene hau nee ema beik ida;
\q2 Ita Boot haree mo-moos hau nia sala.
\q1 
\v 6 NAI, Nai Maromak Aswain,
\q2 keta husik ema nebee laran metin ba Ita Boot sai moe bainhira haree hau.
\q1 Israel nia Maromak,
\q2 keta husik ema nebee buka Ita Boot sai moe too oin tuun tanba hau.
\q1 
\v 7 Ema tarata hau tanba hau tuir Ita Boot;
\q2 sira hamoe hau aat loos.
\q1 
\v 8 Hau sai tiha ona ema fuik ba hau nia familia rasik;
\q2 hau sai ema leet ba hau nia maun-alin sira.
\b
\q1 
\v 9 \x + \xo 69:9 \xt João 2:17; \xt Roma 15:3\x*Hau foo aan tomak hodi defende Ita Boot nia uma, maski ida nee lori hau ba mate;
\q2 ema hatete aat Ita Boot, sira nia liafuan kona hotu hau.
\q1 
\v 10 Bainhira hau haraik aan ho jejun,
\q2 ema insulta fali hau;
\q1 
\v 11 bainhira hau tau hena lutu,
\q2 ema soe piadas mai hau.
\q1 
\v 12 Ema nebee tuur iha portaun sidade nian konta hau nia vida;
\q2 ema lanu-teen sira mos kanta kona ba hau.
\b
\q1 
\v 13 Maibee NAI Maromak, hau harohan ba Ita Boot;
\q2 Maromak, iha tempu nebee Ita Boot desidi,
\q2 hataan hau hodi salva hau
\q1 tanba Ita Boot nia domin boot teb-tebes
\q2 no Ita Boot sempre halo buat nebee loos.
\q1 
\v 14 Hasai hau husi tahu laran;
\q2 keta husik hau mout.
\q1 Salva hau husi ema nebee mak odi hau;
\q2 dada sai hau husi bee naruk laran.
\q1 
\v 15 Keta husik mota boot halo mout hau
\q2 ka bee naruk tolan hau;
\q2 keta husik rai kuak naruk taka tiha hau.
\b
\q1 
\v 16 NAI Maromak, hataan hau, tanba Ita Boot nia domin rohan-laek nee diak;
\q2 Ita Boot laran luak teb-tebes, see oin mai hau.
\q1 
\v 17 Keta subar Ita Boot nia oin ba Ita atan hau;
\q2 hau iha hela susar laran, hataan ho lalais ba.
\q1 
\v 18 Mai besik hau hodi foo liberdade mai hau;
\q2 salva hau husi hau nia inimigu sira.
\b
\q1 
\v 19 Ita Boot hatene katak ema hatete aat hau,
\q2 ema hamoe hau no hafoer hau nia naran;
\q2 hau nia inimigu sira, Ita Boot hatene hotu.
\q1 
\v 20 Sira nia liafuan aat kona ba hau halo hau laran dodok
\q2 too hau lakon esperansa;
\q1 hau hein atu ema hanoin netik hau, maibee la iha;
\q2 hau hein atu ema foo korajen mai hau, maibee ida mos la mosu.
\q1 
\v 21 \x + \xo 69:21 \xt Mateus 27:48; Marcos 15:36; Lucas 23:26; João 19:28,29\x*Sira kahur buat moruk ba hau nia hahaan;
\q2 bainhira hau hamrook, sira foo fali tua siin.
\b
\q1 
\v 22 \x + \xo 69:22 \xt Roma 11:9,10\x*Hau harohan atu hahaan nebee prepara hela iha sira nia oin sai lasu ba sira;
\q2 husik sira nia selebrasaun sai fali rai kuak ba sira.
\q1 
\v 23 Husik sira nia matan sai delek atu sira la bele haree;
\q2 husik sira lori todan too sira nia kotuk bonko tinan ba tinan.
\q1 
\v 24 Fakar tiha Ita Boot nia hirus ba iha sira nia leten;
\q2 husik Ita Boot nia laran nakali kona sira ba.
\q1 
\v 25 \x + \xo 69:25 \xt Apostolu sira nia Istoria 1:20\x*Husik sira nia fatin sai fuik;
\q2 la iha ema ida hela tan iha sira nia tenda laran.
\q1 
\v 26 Tanba ema nebee mak Ita Boot baku, sira halo nia terus tan;
\q2 ema nebee Ita Boot hakanek, sira konta ba-mai kona ba nia terus.
\q1 
\v 27 Foo sai sira nia sala ida-ida;
\q2 la bele salva tan sira.
\q1 
\v 28 \x + \xo 69:28 \xt Ézodu (Keluaran) 32:32; Apokalipse 3:5, 13:8, 17:8\x*Hasai tiha sira nia naran husi lista ema moris nian;
\q2 keta husik sira nia naran hakerek hamutuk ho ema nebee mak moris loos.
\b
\q1 
\v 29 Maibee hau nee terus ho laran susar;
\q2 Maromak, foo Ita Boot nia salvasaun hodi hamahon hau.
\b
\q1 
\v 30 Depois hau sei kanta hodi hahii Maromak;
\q2 hau sei agradese hodi foti aas Nia naran.
\q1 
\v 31 Ida nee sei halo haksolok NAI Maromak nia laran liu fali oferta karau aman,
\q2 liu fali sakrifisiu karau aman dikur naruk.
\q1 
\v 32 Bainhira ema mukit haree hau hahii Maromak, sira sei kontenti;
\q2 imi nebee adora Maromak, laran metin fali ba.
\q1 
\v 33 Tanba NAI Maromak rona ema nebee kiak;
\q2 Nia la fila kotuk ba Nia ema sira nebee mak iha dadur laran.
\b
\q1 
\v 34 Lalehan ho rai, hahii Nia ba;
\q2 tasi ho buat hotu nebee moris iha laran, hahii Nia ba!
\q1 
\v 35 Tanba Maromak sei salva Siaun;
\q2 Nia sei harii fali sidade sira nebee mak iha rai Judá,
\q1 depois Nia povu sei hela iha nebaa
\q2 hodi sai nain ba rai.
\q1 
\v 36 Too Nia atan sira nia jerasaun mos sei sai nain nafatin ba rai nee;
\q2 ema nebee hadomi Nia naran sei hela iha nebaa.
\c 70
\s1 Orasaun husu tulun ba Nai Maromak
\d Salmu David nian, husu atu Maromak hanoin nia. Ba dirijenti koru.
\b
\q1 
\v 1 Maromak, favor salva hau;
\q2 NAI, mai lalais tulun hau.
\q1 
\v 2 Hau harohan atu ema nebee hakarak hasai hau nia vida,
\q2 sai moe boot ho oin tuun;
\q1 husik ema nebee hakarak atu hau hetan dezastre,
\q2 hakiduk ho naran aat.
\q1 
\v 3 Husik ema nebee hamnasa hahaek mai hau
\q2 fila ho moe boot.
\q1 
\v 4 Maibee halo ema hotu nebee harohan ba Ita Boot
\q2 sai kontenti ho haksolok;
\q1 husik ema nebee buka Ita Boot nia salvasaun
\q2 dehan beibeik, “Maromak nee boot!”
\q1 
\v 5 Hau nee ema kiak ho kbiit-laek;
\q2 Maromak, mai lalais ona.
\q1 Ita Boot mak tulun hau no salva hau;
\q2 NAI, keta demora.
\c 71
\s1 Katuas ida harohan atu Nai Maromak proteje
\q1 
\v 1 NAI Maromak, hau hamahon aan iha Ita Boot;
\q2 keta husik hau moe leet.
\q1 
\v 2 Ita Boot sempre halo buat nebee loos;
\q2 salva hau ba, hasai tiha hau husi susar laran;
\q2 see tilun mai hau hodi salva hau.
\q1 
\v 3 Ita Boot mak fatuk lolon boot, husik hau helik ba;
\q2 hatuun orden atu salva hau,
\q1 tanba Ita Boot mak fatuk kuak nebee hau subar iha laran;
\q2 Ita Boot mak lutu haleu hau.
\q1 
\v 4 Hau nia Maromak, hasai tiha hau husi ema aat sira nia liman laran;
\q2 salva hau husi ema laran aat ho hanehan door sira.
\q1 
\v 5 Nai Maromak, Ita Boot mak hau nia esperansa;
\q2 NAI, husi joven kedas hau konfia Ita Boot.
\q1 
\v 6 Husi kedas hau moris mai, hau sadere nanis ona ba Ita Boot;
\q2 husi hau nia inan nia kabun laran, Ita Boot tau matan mai hau.
\q2 Hau sempre hahii Ita Boot.
\b
\q1 
\v 7 Hau sai tiha ona ezemplu ba ema barak;
\q2 Ita Boot mak fatin seguru diak nian mai hau.
\q1 
\v 8 Hau nia ibun sempre hahii Ita Boot;
\q2 iha loron tomak hau haklaken Ita Boot nia furak.
\q1 
\v 9 Keta soe hau bainhira hau idade ona;
\q2 keta husik hau bainhira hau nia forsa hotu.
\q1 
\v 10 Tanba hau nia inimigu sira hatete aat hau;
\q2 ema nebee hein atu oho hau, sira kombina malu hela.
\q1 
\v 11 Sira dehan, “Maromak husik ona nia.
\q2 Mai ita duni nia hodi kaer tiha nia,
\q2 tanba la iha ida mak atu salva nia.”
\b
\q1 
\v 12 Hau nia Maromak, keta dook husi hau;
\q2 Maromak, mai lalais tulun hau.
\q1 
\v 13 Hau harohan atu ema nebee kontra hau, Ita Boot hatuun sira hodi halo sira lakon;
\q2 husik ema nebee mak hakarak halo aat hau, sai moe boot ho oin tuun.
\q1 
\v 14 Maibee hau nee sempre laran metin ba Ita Boot;
\q2 hau sei kontinua hahii Ita Boot liu tan.
\q1 
\v 15 Hau nia ibun sei foo sai buat diak nebee Ita Boot halo tiha ona;
\q2 loron-kalan hau sei foo sai Ita Boot nia salvasaun,
\q2 maski hau sura la bele.
\q1 
\v 16 NAI Maromak Kbiit Nain, hau sei gaba buat makaas nebee Ita Boot halo;
\q2 hau sei gaba Ita Boot nia justisa, so Ita Boot nian deit.
\b
\q1 
\v 17 Maromak, husi kedas hau joven, Ita Boot hanorin ona hau;
\q2 too agora hau foo sai nafatin buat furak nebee Ita Boot halo.
\q1 
\v 18 Maromak, agora hau katuas fuuk mutin ona,
\q2 keta husik hau mesak,
\q1 atu hau foo sai Ita Boot nia kbiit ba jerasaun tuir mai,
\q2 atu hau konta Ita Boot nia forsa ba ema hotu nebee sei moris aban-bainrua.
\b
\q1 
\v 19 Maromak, Ita Boot nia justisa too iha lalehan;
\q2 Ita Boot halo buat mesak boot.
\q2 Maromak, see mak hanesan Ita Boot?
\q1 
\v 20 Maski Ita Boot halo hau terus ho susar barak,
\q2 Ita Boot sei halo hau moris fali;
\q1 hau too iha rai kuak laran mos,
\q2 Ita Boot sei dada hau sai.
\q1 
\v 21 Ita Boot sei halo hau nia naran boot liu fali uluk;
\q2 Ita Boot sei foo ksolok fali mai hau.
\b
\q1 
\v 22 Hau nia Maromak, hau sei toka viola hodi hahii Ita Boot,
\q2 tanba Ita Boot sempre kaer metin Ita Boot nia liafuan.
\q1 Israel nia Maromak santu,
\q2 hau sei hananu hahii Ita Boot ho muzika viola tali walu.
\q1 
\v 23 Hau nia ibun sei haklalak ho haksolok;
\q2 hau sei hananu hahii Ita Boot,
\q2 tanba Ita Boot salva tiha ona hau.
\q1 
\v 24 Loron-kalan hau nia ibun sei koalia sai Ita Boot nia justisa,
\q2 tanba ema sira nebee hakarak halo aat hau
\q2 sai moe boot ho oin tuun tiha.
\c 72
\s1 Orasaun ba liurai
\d Salmu Salomão nian.
\b
\q1 
\v 1 Maromak, hanorin Ita Boot nia justisa ba liurai;
\q2 hanorin Ita Boot nia lia loos ba liurai oan,
\q1 
\v 2 atu liurai bele foo justisa ba Ita Boot nia povu tuir dalan loos,
\q2 atu nia bele tesi lia lo-loos ba Ita Boot nia ema nebee kbiit-laek.
\q1 
\v 3 Nunee foho sira nee sei buras hodi foo moris diak ba povu,
\q2 no ema iha rai nee bele moris loos.
\q1 
\v 4 Hau harohan atu liurai bele defende ema kbiit-laek iha povu nia leet,
\q2 salva ema kiak nia oan,
\q2 no halakon tiha hanehan door sira.
\q1 
\v 5 Hau harohan atu liurai dura hanesan loro matan,
\q2 dura hanesan fulan, husi jerasaun ba jerasaun.
\q1 
\v 6 Halo liurai sai hanesan udan been monu tuun mai rai
\q2 hodi rega duut nebee foin lere.
\q1 
\v 7 Durante nia ukun, halo ema moris loos sai buras
\q2 hodi moris diak, too fulan lakon tiha husi lalehan.
\b
\q1 
\v 8 \x + \xo 72:8 \xt Zacarias 9:10\x*Hau harohan atu liurai ukun husi tasi ba tasi,
\q2 husi Mota Eufrates too rai ulun rai ikun iha mundu tomak.
\q1 
\v 9 Halo suku sira iha rai fuik maran hakneak hakruuk iha liurai nia oin;
\q2 halo nia inimigu sira lambe rai.
\q1 
\v 10 Hau harohan atu liurai Tarsis ho liurai sira husi tasi balu
\q2 lori prezenti ba nia,
\q1 no liurai sira husi rai Sabá ho Seba
\q2 lori prezenti foo ba nia.
\q1 
\v 11 Hau harohan atu liurai hotu-hotu hakneak hakruuk ba nia,
\q2 no nasaun hotu-hotu serbi nia.
\b
\q1 
\v 12 Tanba liurai salva ema kiak sira nebee halerik ba nia;
\q2 nia ajuda ema kbiit-laek sira nebee mak la iha ema atu tau matan.
\q1 
\v 13 Nia hanoin ema kiik ho ema kiak sira
\q2 hodi salva sira nia moris.
\q1 
\v 14 Nia salva sira husi ema nebee hanehan sira ho ema nebee halo violensia ba sira,
\q2 tanba sira nia moris folin boot iha nia matan.
\b
\q1 
\v 15 Viva liurai!
\q2 Hau harohan atu ema lori oferta osan mean husi rai Sabá foo ba liurai,
\q1 no ema sempre halo orasaun ba nia
\q2 hodi foo bensaun ba nia iha loron tomak.
\q1 
\v 16 Hau harohan atu iha nia rai tomak iha hahaan barak;
\q2 iha foho tutun mos toos bele buras.
\q1 Hau husu atu ai fuan tebar hanesan iha rai Líbanu,
\q2 no nia povu iha sidade mos buras hanesan duut matak iha rai fuik.
\q1 
\v 17 Hau harohan atu liurai nia naran dura ba nafatin,
\q2 dura hanesan loro matan iha lalehan.
\q1 Hau husu atu nasaun hotu-hotu hetan bensaun liu husi nia,
\q2 no ema bolu nia ema ida nebee hetan ksolok.
\b
\q1 
\v 18 Hahii NAI Maromak, Israel nia Maromak!
\q2 Nia mesak deit mak halo buat furak.
\q1 
\v 19 Hahii, foti aas Nia naran tinan ba tinan.
\q2 Hau harohan atu Maromak nia kbiit hakonu mundu tomak.
\q3 Amen, amen.
\b
\p 
\v 20 Orasaun husi David, Jessé nia oan too iha nee deit.
\c 73
\s1 Nai Maromak mak Justisa Nain
\d Salmu Asaf nian.
\b
\q1 
\v 1 Maromak nee diak ba Israel;
\q2 tebes, Nia diak ba ema nebee mak laran moos.
\q1 
\v 2 Maibee hau nee, hau nia ain besik atu sidi;
\q2 uitoan tan hau atu monu ona,
\q1 
\v 3 tanba hau laran moras ba ema nebee foti aan;
\q2 hau haree sira moris diak maski sira nia hahalok aat.
\q1 
\v 4 Ema sira nee la hatene terus;
\q2 sira nia isin diak no forti.
\q1 
\v 5 Sira la hetan susar nebee ema baibain hetan iha mundu nee;
\q2 dezastre la kona sira hanesan ema seluk.
\q1 
\v 6 Tanba nee sira hahenu sira nia hahalok foti aan;
\q2 sira foo hatais sira nia aan ho violensia.
\q1 
\v 7 Sira nia laran hakiak sala;
\q2 sira nia neon nakonu ho buat nebee la iha folin.
\q1 
\v 8 Sira soe lia hodi hatete buat mesak aat;
\q2 sira foti aan hodi ameasa atu hanehan ema seluk.
\q1 
\v 9 Sira loke ibun hodi kontra lalehan;
\q2 sira nia liafuan foti aan lao haleu mundu tomak.
\q1 
\v 10 Tanba nee povu fila hodi tuir sira,
\q2 no fiar sira nia liafuan hotu.
\q1 
\v 11 Sira dehan, “Oinsaa Maromak atu hatene buat sira nee?
\q2 Maromak Aas Liu hatene saida?”
\q1 
\v 12 Ema aat sira hanesan nee duni;
\q2 sira sempre moris diak, sira nia riku-soin aumenta ba beibeik.
\b
\q1 
\v 13 Hau kuidadu beibeik atu moris ho laran moos,
\q2 maibee saugati deit;
\q1 hau fase hau nia liman hanesan sinal katak hau la sala ida,
\q2 maibee la vale buat ida.
\q1 
\v 14 Tanba loron tomak hau terus hela deit;
\q2 iha dadeer-dadeer hau hetan kastigu.
\b
\q1 
\v 15 Se karik hau dehan nunee,
\q2 entaun hau hanesan fali traidor ba Ita Boot nia povu.
\q1 
\v 16 Bainhira hau koko atu kompriende buat sira nee,
\q2 hau senti susar teb-tebes.
\q1 
\v 17 Too hau tama iha Maromak nia uma kreda
\q2 mak foin hau kompriende ema sira nee nia destinu.
\q1 
\v 18 Tebes duni, Ita Boot tau sira iha fatin namdoras;
\q2 Ita Boot halo sira monu too rahun tiha.
\q1 
\v 19 Derepenti deit sira mohu;
\q2 sira tauk teb-tebes too tauk nee hamate fali sira.
\q1 
\v 20 Sira hanesan mehi deit,
\q2 ita hadeer mai la iha tiha;
\q1 Nai Maromak, bainhira Ita Boot hamriik,
\q2 Ita Boot sei la hanoin tan sira.
\b
\q1 
\v 21 Bainhira hau nia laran senti tristi
\q2 no hau nia fuan moras,
\q1 
\v 22 hau sai beik tiha, la kompriende buat ida;
\q2 hau nia hahalok hasoru Ita Boot hanesan fali animal fuik.
\q1 
\v 23 Maski nunee hau nafatin besik Ita Boot;
\q2 Ita Boot kaer metin hau nia liman loos.
\q1 
\v 24 Ita Boot hanorin hau no hatudu dalan mai hau;
\q2 too ikus Ita Boot sei simu hau hodi foti sae hau.
\q1 
\v 25 Iha lalehan nebaa, Ita Boot mak tulun hau; se laos Ita Boot, see tan?
\q2 Iha mundu nee, hau hakarak mak Ita Boot deit.
\q1 
\v 26 Hau nia isin ho hau nia laran bele sai fraku,
\q2 maibee Maromak mak hakbiit hau nia laran;
\q2 hau nia riku-soin mak Nia too tinan ba tinan.
\b
\q1 
\v 27 Ema nebee dook husi Ita Boot sei mate mohu;
\q2 Ita Boot harahun tiha ema nebee mak la foo laran ba Ita Boot.
\q1 
\v 28 Maibee hau nee gosta liu besik Maromak;
\q2 hau hamahon aan iha NAI Maromak Kbiit Nain;
\q2 hau sei foo sai buat diak nebee Ita Boot halo.
\c 74
\s1 Halerik ba Nai Maromak tanba uma kreda rahun
\d Salmu Asaf nian para hanorin ema.
\b
\q1 
\v 1 Maromak, tansaa mak Ita Boot soe ami nafatin ba nafatin?
\q2 Tansaa mak Ita Boot laran nakali hasoru Ita Boot nia bibi sira?
\q1 
\v 2 Hori uluk kedas Ita Boot hili povu ida nee;
\q2 Ita Boot salva tiha ona povu nee sai Ita Boot nian;
\q2 hanoin fila fali ami ba!
\q1 Uluk Ita Boot hela iha foho Siaun;
\q2 hanoin fali fatin nee ba.
\q1 
\v 3 Hakmaan Ita Boot nia ain lao ba iha fatin santu;
\q2 fatin nee rahun aat liu ona;
\q2 buat hotu-hotu inimigu estraga tiha ona.
\b
\q1 
\v 4 Ita Boot nia funu baluk haklalak ona iha Ita Boot nia fatin santu;
\q2 sira hasae tiha ona sira nia bandeira.
\q1 
\v 5 Sira tama hanesan fali ema nebee kaer baliu
\q2 hodi tesi ai huun buras.
\q1 
\v 6 Sira kaer baliu ho martelu
\q2 hodi sobu rahun tiha uma nia didin nebee ema bahat halo furak.
\q1 
\v 7 Sira sunu mutuk tiha Ita Boot nia fatin santu too rai;
\q2 sira hafoer Ita Boot nia hela fatin.
\q1 
\v 8 Sira hatete iha sira nia laran, “Mai ita hanehan makaas ema sira nee hotu!”
\q2 Fatin hotu-hotu nebee ema adora Maromak iha rai nee, sira sunu hotu ona.
\b
\q1 
\v 9 Ami la haree tan sinal husi Maromak;
\q2 profeta mos la iha ona;
\q2 ami sira nee la iha ida mak hatene bainhira mak hotu.
\q1 
\v 10 Maromak, inimigu sira sei hatete aat Ita Boot too bainhira?
\q2 Funu baluk sira nee sei koalia aat Ita Boot nia naran nafatin ba nafatin ka?
\q1 
\v 11 Tansaa mak Ita Boot dada fali Ita Boot nia liman loos?
\q2 Foti Ita Boot nia liman hodi halo mohu tiha sira ba.
\b
\q1 
\v 12 Maibee Maromak nee hau nia Liurai hori uluk kedas;
\q2 Ita Boot lori salvasaun ba mundu.
\q1 
\v 13 \x + \xo 74:13 \xt Ézodu (Keluaran) 14:21\x*Uluk Ita Boot hafahe tasi hodi Ita Boot nia kbiit;
\q2 Ita Boot mak fera samea boot nia ulun iha tasi laran.
\q1 
\v 14 \x + \xo 74:14 \xt Jó (Ayub) 41:1; Salmu 104:26; Isaias 27:1\x*Samea boot Leviatán nia ulun fatuk bar-barak, Ita Boot harahun tiha
\q2 hodi foo haan animal nebee hela iha rai fuik maran.
\q1 
\v 15 Ita Boot loke tiha bee matan ho mota;
\q2 mota sira nebee suli la para, Ita Boot hamaran tiha.
\q1 
\v 16 Loron Ita Boot nian, kalan mos Ita Boot nian;
\q2 Ita Boot hatuur fulan ho loro matan.
\q1 
\v 17 Ita Boot tau mundu nia baliza;
\q2 tempu udan no tempu bailoron, Ita Boot halo rua nee hotu.
\b
\q1 
\v 18 NAI Maromak, keta haluha katak inimigu hamnasa fali Ita Boot;
\q2 ema beik-teen sira nee hatete aat Ita Boot nia naran.
\q1 
\v 19 Keta entrega Ita Boot nia manu pombu\f + \fr 74:19 \ft Matenek nain barak dehan, “manu pombu” hatudu ba povu Israel.\f* ba animal fuik;
\q2 keta haluha Ita Boot nia povu kbiit-laek sira tinan ba tinan.
\b
\q1 
\v 20 Hanoin nafatin Ita Boot nia promesa mai ami,
\q2 tanba fatin nakukun iha rai nee mesak violensia nia knuuk deit.
\q1 
\v 21 Keta husik ema hamoe tan vitima sira;
\q2 halo ema kiak ho kbiit-laek hahii Ita Boot nia naran.
\b
\q1 
\v 22 Maromak, hamriik ba! Defende Ita Boot nia lia;
\q2 keta haluha katak ema beik-teen sira hatete aat Ita Boot iha loron tomak.
\q1 
\v 23 Keta haluha Ita Boot nia inimigu sira nia lian;
\q2 ema nebee kontra Ita Boot hakilar la para.
\c 75
\s1 Nai Maromak mak Justisa Nain
\d Salmu Asaf nian, tuir muzika “Keta halo rahun.” Ba dirijenti koru.
\b
\q1 
\v 1 Maromak, ami hahii Ita Boot.
\q2 Ami hahii Ita Boot tanba Ita Boot besik ami.
\q2 Ema konta sai buat furak nebee Ita Boot halo.
\b
\q1 
\v 2 Ita Boot dehan, “Hau hili tiha ona tempu atu foo justisa;
\q2 too tempu nee Hau sei tesi lia ho lo-loos.
\q1 
\v 3 Bainhira mundu ho ema hotu iha mundu nakdoko,
\q2 Hau mak halo metin mundu nia huun.
\q1 
\v 4 Ba ema nebee foti aan, Hau dehan, ‘Keta foti aan tan.’
\q2 Ba ema aat, Hau dehan, ‘Keta foti sae imi nia dikur.
\q1 
\v 5 Keta foti sae imi nia dikur hasoru lalehan;
\q2 keta koalia kontra demais.’”
\b
\q1 
\v 6 La iha ema ida mak bele foti sae nia aan;
\q2 atu husi lorosae ka loromonu ka husi rai fuik maran, la bele hotu.
\q1 
\v 7 Maromak mak Justisa Nain;
\q2 Nia mak hatuun ema balu no foti sae ema seluk.
\q1 
\v 8 Iha NAI Maromak nia liman laran iha kopu ida
\q2 nakonu ho tua ulun;
\q1 Nia fui tua nee foo ba ema aat ida-idak iha mundu;
\q2 sira tenki hemu too tua nia teen hotu kedas.
\b
\q1 
\v 9 Maibee hau sei foo sai Maromak nia diak nafatin ba nafatin;
\q2 hau sei kanta hahii Jacó nia Maromak.
\q1 
\v 10 Maromak dehan, “Hau sei tesi sai tiha ema aat sira nia dikur hotu,
\q2 maibee ema moris loos sira nia dikur, Hau sei foti sae.”
\c 76
\s1 Nai Maromak manaan tiha ona Nia inimigu sira
\d Salmu Asaf nian. Kantiku ida, akompanha ho viola. Ba dirijenti koru.
\b
\q1 
\v 1 Maromak konhesidu iha rai Judá;
\q2 Nia naran boot iha Israel.
\q1 
\v 2 Nia uma harii tiha ona iha Jerusalém;
\q2 Nia hela fatin iha Siaun.
\q1 
\v 3 Iha nebaa Nia silu tohar ona inimigu nia rama oan nebee nabilan;
\q2 surik ho ekipamentu funu nian sel-seluk, Nia halo tohar hotu.
\b
\q1 
\v 4 Ita Boot nabilan furak tebes;
\q2 Ita Boot makaas liu fali foho nebee iha hori uluk kedas.
\q1 
\v 5 Inimigu aswain sira nia sasaan ema hadau tiha;
\q2 inimigu sira nee toba latan tiha ona;
\q2 funu nain sira nia forsa lakon tiha ona.
\q1 
\v 6 Jacó nia Maromak, Ita Boot nia lian makaas
\q2 halo kuda ho nia nain toba latan hotu.
\b
\q1 
\v 7 Ita Boot makaas teb-tebes!
\q2 Bainhira Ita Boot hirus, see mak aguenta hamriik iha Ita Boot nia oin?
\q1 
\v 8-9 Maromak, Ita Boot hamriik tiha ona hodi foo justisa,
\q2 atu salva ema mukit sira hotu iha mundu.
\q1 Bainhira Ita Boot hatuun Ita Boot nia desizaun husi lalehan,
\q2 mundu tauk hodi nonook tiha.
\q1 
\v 10 Ema bele hirus mos, sira sei hahii liu tan Ita Boot;
\q2 mate restu sira sei adora Ita Boot.\f + \fr 76:10 \ft Lian Ebreu iha versikulu nee, signifikadu la klaru.\f*
\b
\q1 
\v 11 Halo promesa ba NAI o nia Maromak, no halo tuir promesa nee;
\q2 ema hotu nebee hela haleu Nia, lori imi nia oferta foo ba Ida nebee halo ema tauk.
\q1 
\v 12 Nia halo ukun nain sira lakon esperansa;
\q2 liurai sira iha mundu hamtauk Nia.
\c 77
\s1 Iha tempu susar, hanoin Nai Maromak nia diak uluk nian
\d Salmu Asaf nian, ba dirijenti koru Jedutun.
\b
\q1 
\v 1 Hau halerik husu tulun ba Maromak;
\q2 hau halerik ba Maromak atu Nia rona hau.
\q1 
\v 2 Iha susar laran, hau buka Nai Maromak;
\q2 kalan-kalan hau lolo liman la kole,
\q2 maibee hau la hetan ksolok.
\q1 
\v 3 Bainhira hau hanoin kona ba Maromak, hau halerik;
\q2 bainhira hau medita, hau lakon esperansa liu tan.
\b
\q1 
\v 4 Ita Boot halo hau toba la dukur;
\q2 hau laran susar too hau la iha liafuan.
\q1 
\v 5 Hau hanoin fila fali loron uluk nian;
\q2 hau hanoin hetan tempu uluk nian.
\q1 
\v 6 Iha tempu nebaa hau kanta iha oras kalan.
\q2 Agora hau nia laran medita, hau husu ba hau nia aan,
\q1 
\v 7 “Nai Maromak soe tiha ona ita nafatin ba nafatin ka?
\q2 Nia lakohi hatudu tan ona Nia laran diak ka?
\q1 
\v 8 Nia domin rohan-laek nee lakon tinan ba tinan ka?
\q2 Nia promesa nebee Nia halo la vale tan ona ka?
\q1 
\v 9 Maromak haluha ona Nia laran diak ka?
\q2 Nia hirus taka tiha Nia laran luak ka?”
\q1 
\v 10 Nunee hau hanoin, “Maromak Aas Liu nia liman loos la tulun ita hanesan uluk ona;
\q2 ida nee mak halo hau nia laran moras.”
\b
\q1 
\v 11 Maibee NAI Maromak, hau sei hanoin buat diak nebee Ita Boot halo;
\q2 hau sei la haluha Ita Boot nia milagre husi tempu uluk nian.
\q1 
\v 12 Hau sei hanoin beibeik Ita Boot nia servisu hotu
\q2 hodi medita buat furak nebee Ita Boot halo.
\b
\q1 
\v 13 Maromak, Ita Boot nia dalan nee santu;
\q2 la iha tan maromak ida mak boot hanesan ami nia Maromak.
\q1 
\v 14 Ita Boot Maromak ida nebee halo milagre;
\q2 Ita Boot hatudu sai Ita Boot nia kbiit iha nasaun hotu-hotu nia leet.
\q1 
\v 15 Ita Boot salva ona Ita Boot nia povu hodi Ita Boot nia liman rasik;
\q2 Ita Boot salva Jacó ho José nia jerasaun.
\b
\q1 
\v 16 Maromak, uluk bee haree Ita Boot mai;
\q2 bainhira haree, bee nakdoko tiha,
\q2 too tasi klean boot mos nakdedar.
\q1 
\v 17 Kalohan fakar tuun bee;
\q2 lalehan tarutu makaas;
\q2 Ita Boot nia rama oan semo baa semo mai nabilan loos.
\q1 
\v 18 Ita Boot halo rai tarutu makaas iha anin fuik laran;
\q2 rai lakan husi Ita Boot leno mundu;
\q2 rai nakdedar too nakdoko.
\q1 
\v 19 Ita Boot lao liu husi tasi laran;
\q2 Ita Boot nia dalan liu husi bee boot,
\q2 maibee Ita Boot nia ain fatin la haree hetan.
\q1 
\v 20 Ita Boot foti Moisés ho Arão hodi lori Ita Boot nia povu
\q2 hanesan bibi atan nebee lori nia bibi.
\c 78
\s1 Lisaun husi Israel nia istoria
\d Salmu Asaf nian para hanorin ema.
\b
\q1 
\v 1 Hau nia povu, rona hau nia hanorin;
\q2 see tilun ba hau nia liafuan.
\q1 
\v 2 \x + \xo 78:2 \xt Mateus 13:35\x*Hau sei konta istoria;
\q2 hau sei foo sai liafuan matenek nian nebee dezde uluk taka hela.
\q1 
\v 3 Buat sira nee ita rona tiha ona no hatene tiha ona;
\q2 ita nia bei-ala sira konta tiha ona mai ita.
\q1 
\v 4 Ita sei la subar buat sira nee ba sira nia oan sira;
\q2 ita sei konta ba jerasaun tuir mai
\q1 buat furak nebee mak NAI Maromak halo,
\q2 Nia kbiit, ho milagre nebee mak Nia halo tiha ona.
\q1 
\v 5 Nia foo Nia regra ba Jacó nia jerasaun;
\q2 Nia hatuur Nia lei iha Israel.
\q1 Nia haruka ita nia bei-ala sira nee
\q2 hanorin tutan lei nee ba sira nia oan sira,
\q1 
\v 6 atu nunee jerasaun tuir mai bele hatene,
\q2 too jerasaun nebee seidauk moris mos
\q2 bele hanorin tutan ba sira nia oan sira.
\q1 
\v 7 Nunee sira sei konfia iha Maromak;
\q2 sira sei la haluha buat nebee mak Nia halo tiha ona,
\q2 maibee sira sei moris tuir Nia lei.
\q1 
\v 8 Sira sei la hanesan sira nia bei-ala sira uluk.
\q2 Bei-ala sira nee ulun toos no kontra door;
\q1 sira nia laran la metin ba Maromak;
\q2 sira la foo laran ba Nia.
\b
\q1 
\v 9 Uluk tropas suku Efraim nian kaer hela rama,
\q2 too iha loron funu nian, sira hakiduk.
\q1 
\v 10 Sira la kaer metin Maromak nia promesa;
\q2 sira lakohi moris tuir Nia lei.
\q1 
\v 11 Sira haluha saida mak Nia halo tiha ona,
\q2 milagre nebee Nia hatudu tiha ona ba sira.
\q1 
\v 12 \x + \xo 78:12 \xt Ézodu (Keluaran) 7:8—12:32\x*Nia halo buat boot iha sira nia bei-ala sira nia oin,
\q2 iha rejiaun Zoan iha Ejitu nia rain.
\q1 
\v 13 \x + \xo 78:13 \xt Ézodu (Keluaran) 14:21,22\x*Nia fahe tiha tasi halo dalan para sira bele hakur;
\q2 Nia halo tasi been hamriik hanesan moru.
\q1 
\v 14 \x + \xo 78:14 \xt Ézodu (Keluaran) 13:21,22\x*Loron, Nia foo kalohan hodi hatudu dalan ba sira;
\q2 kalan tomak, Nia foo ahi hodi leno sira nia dalan.
\q1 
\v 15 Nia fera tiha fatuk bo-boot iha rai fuik
\q2 hodi foo bee ba sira hemu, bee nee boot hanesan tasi.
\q1 
\v 16 \x + \xo 78:16 \xt Ézodu (Keluaran) 17:1-7; Númerus (Bilangan) 20:2-13\x*Nia halo bee suli sai husi fatuk kuak,
\q2 too bee suli tuun hanesan mota.
\b
\q1 
\v 17 Maski nunee sira halo sala nafatin hasoru Maromak;
\q2 iha rai fuik maran, sira kontra Maromak Aas Liu.
\q1 
\v 18 \x + \xo 78:18 \xt Ézodu (Keluaran) 16:2-15; Númerus (Bilangan) 11:4-23,31-35\x*Sira koko Maromak
\q2 hodi eziji hahaan nebee mak sira kaan.
\q1 
\v 19 Sira sadik Maromak dehan,
\q2 “Maromak bele tau meza iha rai fuik nee ka?
\q1 
\v 20 Loos duni, Nia fera tiha fatuk
\q2 hodi halo bee fakar sai;
\q2 bee nee suli sai makaas.
\q1 Maibee Nia bele foo paun ba ita ka?
\q2 Nia bele fahe naan ba Nia povu ka?”
\b
\q1 
\v 21 Bainhira NAI Maromak rona ida nee, Nia hirus teb-tebes;
\q2 Nia ahi lakan makaas kontra Jacó nia jerasaun;
\q2 Nia laran nakali hasoru Israel,
\q1 
\v 22 tanba sira la fiar ba Nia;
\q2 sira la fiar Nia kbiit atu salva sira.
\q1 
\v 23 Maibee Maromak foo orden ba kalohan;
\q2 Nia loke odamatan lalehan nian.
\q1 
\v 24 \x + \xo 78:24 \xt João 6:31\x*Nia hamonu paun manaa ba sira hanesan udan para sira bele haan;
\q2 Nia foo hahaan lalehan nian ba sira.
\q1 
\v 25 Ema mundu nian haan tiha ona hahaan anju sira nian;
\q2 Nia foo hahaan ba sira too sira bosu di-diak.
\q1 
\v 26 Nia foo orden ba anin lorosae nian;
\q2 hodi Nia kbiit Nia halo anin tasi mane huu,
\q1 
\v 27 lori manu fuik barak loos hanesan rai henek iha tasi ibun;
\q2 Nia hamonu naan manu barak teb-tebes hanesan rai rahun.
\q1 
\v 28 Nia halo manu sira nee monu tuun ba iha sira nia akampamentu,
\q2 haleu sira nia tenda hotu.
\q1 
\v 29 Sira haan too bosu di-diak,
\q2 tanba Nia foo tiha ona ba sira buat nebee mak sira kaan.
\q1 
\v 30 Maibee naan nee sei iha hela sira nia ibun laran,
\q2 sira sei kaan nafatin atu haan tan,
\q1 
\v 31 Maromak nia laran nakali hasoru sira.
\q2 Nia hamate mane forti sira iha sira nia leet;
\q2 Nia lere tiha mane klosan Israel nian.
\b
\q1 
\v 32 Maski Maromak halo nunee mos, sira halo sala nafatin;
\q2 maski Nia halo tiha ona milagre, sira la fiar nafatin.
\q1 
\v 33 Entaun sira nia moris la vale buat ida, no tauk domina sira,
\q2 too Nia hakotu sira nia iis, Nia habadak sira nia tinan.
\q1 
\v 34 Bainhira Maromak oho sira balu, sira seluk sempre hakbesik ba Nia;
\q2 sira fila fali hodi harohan ba Nia.
\q1 
\v 35 Sira hanoin fali katak Maromak mak fatuk lolon boot hodi satan netik sira;
\q2 Maromak Aas Liu mak sira nia Salvador.
\q1 
\v 36 Maibee sira gaba Nia ho sira nia ibun tutun deit;
\q2 sira nia nanaal bosok Nia.
\q1 
\v 37 \x + \xo 78:37 \xt Apostolu sira nia Istoria 8:21\x*Sira nunka foo laran ba Nia;
\q2 sira la kaer metin Nia promesa.
\q1 
\v 38 Bele nunee mos Nia hatudu nafatin Nia laran diak ba sira;
\q2 Nia hamoos sira nia sala
\q2 hodi la halo mohu sira.
\q1 Dala barak Nia hirus iha Nia laran deit;
\q2 Nia la fakar sai Nia laran nakali.
\q1 
\v 39 Nia rekonhese katak ema sira nee isin ho raan deit,
\q2 hanesan anin nebee huu liu tiha la fila ona.
\b
\q1 
\v 40 Dala barak sira kontra Maromak iha rai fuik;
\q2 iha rai fuik maran nee sira halo Nia laran dodok!
\q1 
\v 41 Sira koko Maromak fila-fila;
\q2 sira halo Israel nia Maromak Santu laran moras.
\q1 
\v 42 Sira haluha tiha Nia kbiit;
\q2 sira la hanoin tan tempu nebee Nia liberta sira husi inimigu sira.
\q1 
\v 43 Iha tempu nebaa Nia hatudu sai sinal iha rai Ejitu;
\q2 Nia hatudu milagre iha rejiaun Zoan nian.
\q1 
\v 44 \x + \xo 78:44 \xt Ézodu (Keluaran) 7:17-21\x*Mota iha sira nia rain, Nia halo nakfilak sai raan hotu,
\q2 nunee sira la bele hemu tan bee husi mota.
\q1 
\v 45 \x + \xo 78:45 \xt Ézodu (Keluaran) 8:20-24; \xt Ézodu (Keluaran) 8:1-6\x*Nia haruka lalar barak hobur sira hodi haan tiha sira;
\q2 Nia manda manduku hodi estraga rai nee.
\q1 
\v 46 \x + \xo 78:46 \xt Ézodu (Keluaran) 10:12-15\x*Ai haan nebee iha sira nia toos laran, Nia foo ba lakataru haan;
\q2 produsaun toos nian, gafanhotu haan tiha.
\q1 
\v 47 \x + \xo 78:47 \xt Ézodu (Keluaran) 9:22-25\x*Nia halo mate sira nia uvas ho udan jelu fatuk;
\q2 Nia hamate sira nia ai figeira ho jelu fatuk.
\q1 
\v 48 Nia halo udan jelu fatuk monu ba sira nia karau leten;
\q2 Nia husik rai lakan kona sira nia bibi.
\q1 
\v 49 Nia fakar sai Nia laran nakali ba sira;
\q2 Nia hirus teb-tebes, Nia hakribi sira nia hahalok, Nia kontra sira.
\q2 Nia haruka Nia anju lubuk ida atu baa hamohu sira.
\q1 
\v 50 Nia prepara dalan atu hasai Nia hirus;
\q2 Nia la salva sira husi mate,
\q2 maibee Nia entrega sira ba iha moras aat.
\q1 
\v 51 \x + \xo 78:51 \xt Ézodu (Keluaran) 12:29\x*Nia oho dasa tiha ema Ejitu sira nia oan mane boot hotu;
\q2 husi Ham nia jerasaun, oan mane primeiru mate mohu.
\b
\q1 
\v 52 \x + \xo 78:52 \xt Ézodu (Keluaran) 13:17-22\x*Depois Nia lori sai Nia povu liu husi rai fuik
\q2 hanesan bibi atan lori nia bibi.
\q1 
\v 53 \x + \xo 78:53 \xt Ézodu (Keluaran) 14:26-28\x*Nia tau matan ba sira iha dalan, nunee sira la tauk,
\q2 maibee tasi halo mout tiha sira nia inimigu.
\q1 
\v 54 \x + \xo 78:54 \xt Ézodu (Keluaran) 15:17; Josué 3:14-17\x*Nia lori Nia povu ba iha Nia rai santu,
\q2 ba iha foho nebee Nia hadau tiha ona ho Nia kbiit.
\q1 
\v 55 \x + \xo 78:55 \xt Josué 11:16-23\x*Nia duni sai tiha nasaun sira nebee hela iha nebaa
\q2 para Nia povu avansa ba oin.
\q1 Nia fahe rai nee ba Nia povu para sai sira nian;
\q2 ema sira nee nia uma Nia foo ba suku Israel mak hela fali.
\b
\q1 
\v 56 \x + \xo 78:56 \xt Juis sira 2:11-15\x*Maibee ema Israel koko nafatin Maromak Aas Liu
\q2 hodi kontra Nia;
\q2 sira la halo tuir Nia regra.
\q1 
\v 57 Sira la foo laran ba Maromak, sira fila kotuk ba Nia hanesan sira nia bei-ala sira;
\q2 sira nee kleuk tuun-sae hanesan rama aat ida.
\q1 
\v 58 Sira halo Maromak hirus tanba sira hamulak iha sira nia foho lulik;
\q2 sira halo Nia laran moras tanba sira adora fali estatua lulik.
\q1 
\v 59 Haree nunee Maromak nia laran nakali;
\q2 Nia fila kotuk ba ema Israel sira.
\q1 
\v 60 \x + \xo 78:60 \xt Josué 18:1; Jeremias 7:12-14, 26:6\x*Nia husik tiha Nia hela fatin iha sidade Silo;
\q2 Nia abandona tenda nebee Nia harii tiha ona iha ema mundu nia leet.
\q1 
\v 61 \x + \xo 78:61 \xt 1 Samuel 4:4-22\x*Nia husik tiha inimigu sira hadau kaixoti promesa nian;
\q2 kaixoti nebee hatudu sai Nia kbiit ho Nia furak monu fali ba inimigu sira nia liman laran.
\q1 
\v 62 Nia hirus teb-tebes Nia povu;
\q2 Nia husik Nia ema rasik mate ho surik.
\q1 
\v 63 Ahi haan tiha sira nia mane klosan sira;
\q2 sira nia feto klosan sira la kanta tan iha festa kazamentu.
\q1 
\v 64 Sira nia nai lulik sira mate ho surik;
\q2 feto faluk sira la bele tanis lelir.
\b
\q1 
\v 65 Depois Nai Maromak hadeer fali hanesan ema hadeer husi matan dukur,
\q2 hanesan funu nain tua lanu nebee hatene tuir nia aan fali.
\q1 
\v 66 Nia duni lakon tiha Nia inimigu sira;
\q2 Nia halo sira moe tinan ba tinan.
\q1 
\v 67 Maibee Nia la simu José nia jerasaun;
\q2 Nia la hili ona suku Efraim.
\q1 
\v 68 Nia hili fali suku Judá;
\q2 Nia laran monu ba foho Siaun.
\q1 
\v 69 Iha nebaa Nia harii Nia uma kreda hanesan foho aas ida;
\q2 uma kreda nee dura nafatin ba nafatin hanesan mundu.
\q1 
\v 70 \x + \xo 78:70 \xt 1 Samuel 16:11,12; 2 Samuel 7:8; 1 Krónikas (Tawarikh) 17:7\x*Nia hili Nia atan David sai liurai;
\q2 Nia fihir David husi nia servisu nudar bibi atan.
\q1 
\v 71 David tau matan hela ba bibi, Maromak bolu nia
\q2 atu sai fali bibi atan ba Maromak nia povu rasik,
\q2 ba ema Israel, Jacó nia jerasaun.
\q1 
\v 72 David tau matan ba sira ho fuan ho laran;
\q2 nia ukun sira ho matenek.
\c 79
\s1 Orasaun husu Nai Maromak salva nasaun
\d Salmu Asaf nian.
\b
\q1 
\v 1 \x + \xo 79:1 \xt 2 Liurai sira (Reis, Raja-raja) 25:8-10; 2 Krónikas (Tawarikh) 36:17-19; Jeremias 52:12-14\x*Maromak, nasaun jentiu sira tama tiha ona iha Ita Boot nia rain;
\q2 sira halo foer Ita Boot nia uma kreda santu;
\q2 sira sobu rahun tiha ona sidade Jerusalém.
\q1 
\v 2 Sira husik Ita Boot nia atan sira nia mate isin
\q2 sai fali manu fuik nia hahaan;
\q1 Ita Boot nia povu nia mate isin
\q2 sai tiha ona hahaan ba animal fuik.
\q1 
\v 3 Sira halo Ita Boot nia povu nia raan suli haleu Jerusalém tomak hanesan fali bee;
\q2 la iha ema ida atu hakoi mate isin sira nee.
\q1 
\v 4 Ami moe iha vizinhu sira nia oin;
\q2 ema nebee haleu ami hatete aat ami no hatuun ami.
\b
\q1 
\v 5 NAI Maromak, Ita Boot atu hirus ami too bainhira?
\q2 Too tinan ba tinan ka?
\q2 Too bainhira mak Ita Boot nia laran nakali mai ami?
\q1 
\v 6 Fakar tuun Ita Boot nia hirus ba nasaun sira nebee la konhese Ita Boot,
\q2 ba iha nasaun sira nebee la bolu Ita Boot nia naran.
\q1 
\v 7 Tanba sira haan hotu tiha ona Jacó nia jerasaun;
\q2 sira estraga tiha ona nia hela fatin.
\q1 
\v 8 Keta sura ami nia bei-ala sira nia sala ba iha ami nia leten;
\q2 hatudu lalais ita Boot nia laran luak mai ami,
\q2 tanba ami fraku liu ona.
\q1 
\v 9 Maromak, ami nia Salvador, tulun ami ba
\q2 atu ema foti aas Ita Boot nia naran;
\q1 salva ami no perdua ami nia sala
\q2 atu ema tane aas Ita Boot nia naran.
\q1 
\v 10 La bele husik nasaun jentiu sira dehan fali,
\q2 “Ema sira nee nia Maromak iha nebee?”
\q1 Halo ami haree Ita Boot selu fali nasaun jentiu sira
\q2 tanba sira fakar Ita Boot nia atan sira nia raan.
\q1 
\v 11 See tilun ba ema dadur sira nia halerik;
\q2 hodi Ita Boot nia forsa salva sira nebee mak ema atu oho.
\b
\q1 
\v 12 Nai, liafuan aat nebee mak ami nia vizinhu sira koalia hasoru Ita Boot,
\q2 tiru fali ba iha sira nia hirus matan dala hitu.
\q1 
\v 13 Nunee ami nudar Ita Boot nia povu,
\q2 nudar bibi nebee Ita Boot tau matan,
\q1 ami sei agradese ba Ita Boot tinan ba tinan;
\q2 ami sei hahii Ita Boot husi jerasaun ba jerasaun.
\c 80
\s1 Orasaun atu Nai Maromak hadia fali nasaun
\d Salmu Asaf nian, tuir muzika “Ai funan liriu promesa nian.” Ba dirijenti koru.
\b
\q1 
\v 1 \x + \xo 80:1 \xt Ézodu (Keluaran) 25:22\x*Bibi atan Israel,
\q2 Ita Boot hatudu dalan ba José nia jerasaun hanesan bibi atan ida lori nia bibi;
\q2 see tilun mai ami ba.
\q1 Ita Boot tuur iha anju kerubin nia leten hodi ukun;
\q2 hatudu Ita Boot nia naroman nabilan
\q2 
\v 2 ba Efraim, Benjamim ho Manassés sira nia jerasaun.
\q1 Hatudu Ita Boot nia kbiit;
\q2 mai salva ami ba.
\b
\q1 
\v 3 Maromak, hadia fali ami nia moris ba;
\q2 halo Ita Boot nia oin nabilan leno ami,
\q2 atu nunee ami bele hetan salvasaun.
\b
\q1 
\v 4 NAI Maromak Aswain,
\q2 too bainhira mak Ita Boot nia laran nakali hodi lakohi rona Ita Boot nia povu nia orasaun?
\q1 
\v 5 Ita Boot foo laran tristi ba ami hanesan fali hahaan;
\q2 Ita Boot foo ami hemu matan been manko nakonu.
\q1 
\v 6 Ita Boot halo nasaun vizinhu sira istori malu kona ba ami nia rain;
\q2 Ita Boot husik ami nia inimigu sira hamnasa hahaek mai ami.
\b
\q1 
\v 7 Maromak Aswain, hadia fali ami nia moris ba;
\q2 halo Ita Boot nia oin nabilan leno ami,
\q2 atu nunee ami bele hetan salvasaun.
\q1 
\v 8 Ami nee hanesan ai uvas huun ida nebee Ita Boot lori sai husi rai Ejitu;
\q2 Ita Boot duni sai tiha nasaun jentiu sira hodi kuda fali ai uvas nee.
\q1 
\v 9 Ita Boot hamoos tiha rai ba ai uvas nee,
\q2 nunee nia abut tama klean iha rai too buras nakonu rai nee.
\q1 
\v 10 Foho sira hamahon aan iha nia lalatak;
\q2 ai huun boot sedru helik iha nia sanak.
\q1 
\v 11 Nia sanak naruk too iha tasi Mediteráneu;
\q2 nia dikin too iha mota Eufrates.
\q1 
\v 12 Maibee tansaa mak Ita Boot halo rahun tiha lutu?
\q2 Agora ema nebee liu bele foti uvas nee nia fuan;
\q1 
\v 13 fahi fuik husi ai laran mai estraga hela;
\q2 animal husi rai fuik mai haan dadauk.
\b
\q1 
\v 14 Maromak Aswain, fila fali mai ami;
\q2 hateke tuun husi lalehan hodi haree.
\q1 Tau matan ba uvas huun nee;
\q2 
\v 15 ida nee Ita Boot nia liman loos mak kuda;
\q2 ida nee oan mane nebee Ita Boot rasik foti sae sai Ita Boot nian.
\q1 
\v 16 Ita Boot nia uvas huun ema tesi tuun tiha ona;
\q2 ahi haan mutuk tiha ona.
\q1 Hatudu Ita Boot nia oin hirus ba ema sira nee;
\q2 halo sira mate mohu tiha.
\q1 
\v 17 Proteje ema ida nebee mak iha hela Ita Boot nia liman loos;
\q2 nia nee ema nia oan mane nebee Ita Boot rasik foti sae sai Ita Boot nian.
\q1 
\v 18 Depois ami sei la fila kotuk ba Ita Boot;
\q2 halo ami moris nafatin mak ami sei temi Ita Boot nia naran.
\b
\q1 
\v 19 NAI Maromak Aswain, hadia fali ami moris ba;
\q2 halo Ita Boot nia oin nabilan leno ami,
\q2 atu nunee ami bele hetan salvasaun.
\c 81
\s1 Kantiku selebrasaun nian
\d Salmu Asaf nian, tuir muzika Gitit. Ba dirijenti koru.
\b
\q1 
\v 1 Haklalak haksolok ba Maromak, Nia mak ita nia forsa;
\q2 hananu haklalak ba Jacó nia Maromak!
\q1 
\v 2 Hananu ba, baku babadook ba;
\q2 toka viola ho viola tali sanulu.
\q1 
\v 3 \x + \xo 81:3 \xt Númerus (Bilangan) 10:10\x*Huu karau dikur iha tempu fulan nurak;
\q2 huu tan bainhira fulan nakonu hodi loke ita nia loron boot.
\q1 
\v 4 Ida nee mak Israel nia lei,
\q2 regulamentu husi Jacó nia Maromak.
\q1 
\v 5 Bainhira Maromak baa kontra ema Ejitu,
\q2 Nia foo orden nee ba José.
\b
\q1 Hau rona ona lian ida nebee hau la konhese dehan,
\q1 
\v 6 “Hau muda sai tiha naha todan iha imi nia kabaas;
\q2 imi nia liman livre ona husi bote todan.
\q1 
\v 7 \x + \xo 81:7 \xt Ézodu (Keluaran) 17:7; Númerus (Bilangan) 20:13\x*Uluk imi iha susar laran, imi harohan mai Hau, Hau salva tiha imi;
\q2 Hau hataan imi husi kalohan ho rai tarutu nia laran;
\q2 Hau koko tiha ona imi iha bee Meriba nian.
\b
\q1 
\v 8 Hau nia povu, rona mai, Hau sei foo atensaun ba imi;
\q2 Israel, tuir loos imi rona mai Hau!
\q1 
\v 9 \x + \xo 81:9 \xt Ézodu (Keluaran) 20:2,3; Deuteronómiu (Ulangan) 5:6,7\x*Iha imi nia leet maromak seluk la bele iha;
\q2 imi la bele adora maromak falsu.
\q1 
\v 10 Hau mak NAI imi nia Maromak;
\q2 Hau mak lori imi sai husi rai Ejitu.
\q2 Loke imi nia ibun ba mak Hau foo haan imi too bosu.
\b
\q1 
\v 11 Maibee Hau nia povu lakohi rona Hau;
\q2 Israel lakohi hakruuk mai Hau.
\q1 
\v 12 Nunee Hau halo sira nia fuan toos tiha
\q2 hodi tuir deit sira nia hanoin rasik.
\q1 
\v 13 Hau hakarak atu Hau nia povu rona mai Hau;
\q2 Hau hakarak tebes atu Israel lao tuir Hau nia dalan.
\q1 
\v 14 Se sira rona Hau, Hau sei halo sira nia inimigu sira lakon lalais deit;
\q2 Hau fila Hau nia liman hodi kontra sira nia funu baluk.
\q1 
\v 15 Ema nebee odi NAI Maromak, sira sei tauk ho nakdedar iha Nia oin;
\q2 sira sei hetan kastigu tinan ba tinan.
\q1 
\v 16 Maibee Hau sei foo haan paun diak nian ba imi;
\q2 Hau sei habosu imi ho bani been husi fatuk kuak.”
\c 82
\s1 Nai Maromak mak Juis boot
\d Salmu Asaf nian.
\b
\q1 
\v 1 Maromak tuur iha Nia fatin iha tribunal lalehan nian
\q2 hodi foo justisa ba maromak sel-seluk.\f + \fr 82:1 \ft Matenek nain barak dehan, “maromak sel-seluk” nee hatudu ba maromak sira nebee mak nasaun jentiu sira adora. Balu tan dehan ida nee hatudu ba ukun nain sira.\f*
\q1 
\v 2 Nia dehan, “Too bainhira mak imi tesi lia la loos
\q2 hodi defende fali ema aat?
\q1 
\v 3 Imi tenki foo justisa lo-loos ba ema kiik ho oan kiak sira;
\q2 defende ema kbiit-laek ho ema mukit sira nia direitu.
\q1 
\v 4 Salva ema kiik ho kiak sira;
\q2 hasai sira husi ema aat sira nia liman laran.
\b
\q1 
\v 5 Maromak sel-seluk nee la hatene buat ida, sira la kompriende;
\q2 sira lao iha nakukun laran;
\q2 nunee mundu rai klaran nakdoko tiha.
\q1 
\v 6 \x + \xo 82:6 \xt João 10:34\x*Hau dehan, ‘Imi sira nee maromak;
\q2 imi hotu Maromak Aas Liu nia oan.’
\q1 
\v 7 Maski nunee too tempu ida imi sei mate hanesan ema hotu mate;
\q2 imi nia vida sei remata hanesan ukun nain sira seluk.”
\b
\q1 
\v 8 Maromak, hamriik ba hodi foo justisa mai mundu,
\q2 tanba nasaun hotu-hotu Ita Boot nian.
\c 83
\s1 Orasaun husu tulun hodi kontra inimigu
\d Salmu Asaf nian. Kantiku ida.
\b
\q1 
\v 1 Maromak, la bele nonook deit;
\q2 keta taka tilun;
\q2 Maromak, keta lian-laek nunee.
\q1 
\v 2 Haree ba, Ita Boot nia inimigu sira book aan ona;
\q2 ema nebee odi Ita Boot foti aas sira nia ulun.
\q1 
\v 3 Sira futu lia hasoru Ita Boot nia povu;
\q2 sira kombina malu kontra ema nebee Ita Boot tau matan.
\q1 
\v 4 Sira dehan, “Mai ita harahun tiha sira nia nasaun
\q2 atu nunee ema la temi tan Israel nia naran.”
\q1 
\v 5 Sira lian ida halo planu;
\q2 sira konkorda hamutuk atu kontra Ita Boot.
\q1 
\v 6 Sira nee mak ema Edom ho ema Ismael,
\q2 ema Moab ho ema Hagar,
\q1 
\v 7 ema Gebál, Amon ho Amalék,
\q2 ema Filístia, ho ema husi sidade Tiru.
\q1 
\v 8 Ema Asíria mos hamutuk tiha ona ho sira
\q2 hodi haforsa Ló nia jerasaun sira nee.
\b
\q1 
\v 9 \x + \xo 83:9 \xt Juis sira 7:1-23; \xt Juis sira 4:6-22\x*Halakon sira ba, hanesan Ita Boot uluk halakon ema Midián,
\q2 hanesan Ita Boot halakon komandante Sízera ho liurai Jabín iha mota Kisón;
\q1 
\v 10 sira nee mate mohu iha rai Endor;
\q2 sira sai tiha ona adubu ba rai nee.
\q1 
\v 11 \x + \xo 83:11 \xt Juis sira 7:25; \xt Juis sira 8:12\x*Halo sira nia ema boot sira sai hanesan jeneral Oreb ho Zeeb;
\q2 halo sira nia ukun nain sira hotu sai hanesan liurai Zebah ho Zalmuna;
\q1 
\v 12 sira nain rua dehan, “Mai ita hadau tiha rai nebee Maromak tau matan
\q2 hodi sai fali ita nian.”
\b
\q1 
\v 13 Hau nia Maromak, halo sira hanesan rai rahun nebee anin fuik lori,
\q2 hanesan duut maran nebee anin huu lakon tiha.
\q1 
\v 14-15 Duni tuir sira ho Ita Boot nia anin makaas;
\q2 hatauk sira ho Ita Boot nia anin fuik,
\q1 hanesan ahi haan ai laran,
\q2 hanesan ahi sunu mutuk foho.
\q1 
\v 16 NAI Maromak, halo sira moe boot,
\q2 atu nunee sira bele buka Ita Boot.
\q1 
\v 17 Halo sira moe ho oin tuun tinan ba tinan;
\q2 husik sira mate ho naran aat.
\q1 
\v 18 Halo sira rekonhese katak Ita Boot mak NAI Maromak;
\q2 Ita Boot mesak mak Maromak Aas Liu iha mundu rai klaran.
\c 84
\s1 Hakarak atu hela iha Nai Maromak nia uma
\d Salmu husi Korá nia oan, tuir muzika “Gitit.” Ba dirijenti koru.
\b
\q1 
\v 1 NAI Maromak Aswain,
\q2 Ita Boot nia hela fatin furak teb-tebes!
\q1 
\v 2 Hau lakohi hein tan, hau hakarak teb-tebes
\q2 atu tama iha NAI nia uma kreda;
\q1 hau nia isin ho klamar haklalak haksolok
\q2 ba Maromak Moris.
\q1 
\v 3 NAI Maromak Aswain,
\q2 hau nia Liurai, hau nia Maromak,
\q1 besik iha Ita Boot nia altar,
\q2 manu liin halo nia knuuk;
\q1 manu lakateu mos halo nia uma
\q2 para luut sira nia oan iha nebaa.
\q1 
\v 4 Ema nebee hela iha Ita Boot nia uma
\q2 hodi adora hela deit Ita Boot, sira hetan ksolok.
\q1 
\v 5 Ema nebee mak hetan kbiit husi Ita Boot,
\q2 ema nebee hakarak ho laran atu baa iha Ita Boot nia foho santu, sira hetan ksolok.
\q1 
\v 6 Bainhira sira lao liu husi Rai Klean Tanis nian,
\q2 bee matan barak mosu iha nebaa;
\q2 udan monu rai hodi foo bensaun ba rai nee.
\q1 
\v 7 Sira lao forti ba dadauk,
\q2 too sira ida-ida tama iha Maromak nia prezensa iha foho Siaun.
\b
\q1 
\v 8 NAI Maromak Aswain, rona hau nia orasaun;
\q2 Jacó nia Maromak, see tilun mai hau.
\q1 
\v 9 Maromak, haree di-diak liurai nebee mak defende ami;
\q2 tau matan ba liurai nebee mak Ita Boot hili ona nee.
\b
\q1 
\v 10 Diak liu loron ida iha Ita Boot nia uma kreda
\q2 duke loron rihun ida iha fatin seluk.
\q1 Hau gosta liu hein odamatan iha hau nia Maromak nia uma
\q2 duke hela iha ema aat nia tenda laran.
\q1 
\v 11 Tanba NAI Maromak mak loro matan hodi leno ita, Nia defende ita;
\q2 Nia hatudu laran diak ba ita no foti aas ita;
\q1 NAI nunka subar buat diak
\q2 ba ema nebee lao tuir dalan loos.
\q1 
\v 12 NAI Maromak Aswain,
\q2 ema hotu nebee laran metin ba Ita Boot, sira hetan ksolok.
\c 85
\s1 Orasaun atu nasaun moris diak
\d Salmu husi Korá nia oan, ba dirijenti koru.
\b
\q1 
\v 1 NAI Maromak, uluk Ita Boot hatudu laran diak ba Ita Boot nia rain
\q2 hodi halo Jacó nia jerasaun moris diak fali.
\q1 
\v 2 Ita Boot perdua tiha ona hahalok aat nebee Ita Boot nia povu halo
\q2 hodi taka tiha sira nia sala hotu-hotu.
\q1 
\v 3 Ita Boot lakohi hirus tan sira,
\q2 no la fakar tan Ita Boot nia laran nakali ba sira.
\b
\q1 
\v 4 Maromak ami nia Salvador, hadia fali ami nia moris ba;
\q2 halakon tiha Ita Boot nia laran moras ba ami.
\q1 
\v 5 Ita Boot sei hirus ami nafatin ba nafatin ka?
\q2 Ita Boot atu hanaruk Ita Boot nia hirus husi jerasaun ba jerasaun ka?
\q1 
\v 6 Halo Ita Boot nia povu moris fali ba
\q2 atu ami bele haksolok ho Ita Boot nia diak.
\q1 
\v 7 NAI Maromak, hatudu Ita Boot nia domin rohan-laek mai ami
\q2 hodi salva ami.
\b
\q1 
\v 8 Hau sei see tilun ba buat nebee NAI Maromak koalia;
\q2 Nia promete pas ba Nia povu, ba ema nebee foo laran ba Nia,
\q2 naran katak sira la bele fila fali ba buat beik.
\q1 
\v 9 Tebes, Nia salvasaun besik ema nebee mak hamtauk Nia,
\q2 nunee Nia kbiit sei hela metin iha ita nia rain.
\b
\q1 
\v 10 Domin ho lia loos hasoru malu;
\q2 justisa ho pas rei malu.
\q1 
\v 11 Lia loos sei moris buras husi rai;
\q2 justisa sei hateke tuun husi lalehan.
\q1 
\v 12 Loos duni, NAI Maromak sei haraik buat nebee diak;
\q2 ita nia toos sei foo ai haan barak.
\q1 
\v 13 Lia loos lao uluk iha Nia futar oin
\q2 hodi prepara dalan ba Nia atu lao tuir.
\c 86
\s1 Orasaun husu tulun
\d Orasaun David nian.
\b
\q1 
\v 1 NAI Maromak, rona hau hodi hataan hau ba,
\q2 tanba hau kiak ho kbiit-laek.
\q1 
\v 2 Kuidadu hau nia moris, tanba hau foo laran ba Ita Boot;
\q2 salva Ita Boot nia atan hau, tanba hau konfia Ita Boot.
\q2 Ita Boot mak hau nia Maromak.
\q1 
\v 3 Nai, loron-kalan hau halerik ba Ita Boot;
\q2 hanoin hau ba.
\q1 
\v 4 Nai, foo ksolok ba Ita Boot nia atan hau,
\q2 tanba hau fiar Ita Boot.
\q1 
\v 5 Nai, Ita Boot nee diak no gosta perdua ema;
\q2 Ita Boot sempre hatudu domin rohan-laek ba ema nebee mak harohan ba Ita Boot.
\q1 
\v 6 NAI Maromak, rona hau nia orasaun;
\q2 hau halerik husu tulun ba Ita Boot, see tilun ba.
\q1 
\v 7 Iha tempu susar, hau harohan ba Ita Boot;
\q2 Ita Boot sei hataan hau.
\b
\q1 
\v 8 Nai Maromak, iha maromak sel-seluk nia leet, la iha ida mak hanesan Ita Boot;
\q2 la iha buat ida mak bele kompara ho buat nebee Ita Boot halo tiha ona.
\q1 
\v 9 \x + \xo 86:9 \xt Apokalipse 15:4\x*Nai, nasaun hotu-hotu nebee Ita Boot halo
\q2 sei mai adora Ita Boot;
\q2 sira sei foti aas Ita Boot nia naran.
\q1 
\v 10 Tanba Ita Boot makaas no halo buat mesak furak;
\q2 Ita Boot deit mak Maromak.
\b
\q1 
\v 11 NAI Maromak, hanorin Ita Boot nia dalan mai hau,
\q2 atu hau bele moris tuir Ita Boot nia lia loos;
\q1 halo hau nia laran firmi,
\q2 atu hau bele hamtauk deit ba Ita Boot nia naran.
\q1 
\v 12 Nai, hau nia Maromak, hau sei hahii Ita Boot ho hau nia laran tomak;
\q2 hau sei foti aas Ita Boot nia naran tinan ba tinan.
\q1 
\v 13 Tanba Ita Boot nia domin mai hau boot teb-tebes;
\q2 Ita Boot salva tiha ona hau nia vida husi matebian sira nia fatin.
\b
\q1 
\v 14 Maromak, ema foti aan sira ataka hela hau;
\q2 grupu laran aat hakarak hasai hau nia vida;
\q2 sira la interese Ita Boot.
\q1 
\v 15 Maibee Nai, Ita Boot nee Maromak laran diak no laran luak;
\q2 Ita Boot Pasiensia Nain, nakonu ho domin rohan-laek no sempre halo buat nebee mak loos.
\q1 
\v 16 Fila oin mai hau hodi hanoin hau ba;
\q2 haraik Ita Boot nia forsa ba Ita Boot nia atan hau;
\q2 hau Ita Boot nia atan feto nia oan, salva hau ba.
\q1 
\v 17 Hatudu netik sinal ida katak Ita Boot laran diak mai hau.
\q2 Nunee ema nebee odi hau bele haree no moe,
\q2 tanba NAI Maromak, Ita Boot tulun ona hau no foo ksolok mai hau.
\c 87
\s1 Sidade Siaun nee Nai Maromak nian
\d Salmu husi Korá nia oan. Kantiku ida.
\b
\q1 
\v 1 NAI Maromak harii tiha ona Nia sidade iha foho santu.
\q1 
\v 2 NAI gosta portaun sidade Siaun nian
\q2 liu fali hela fatin hotu-hotu iha rai Israel. \f + \fr 87:2 \ft Lian Ebreu dehan “Jacó”. Iha nee refere ba Israel.\f*
\q1 
\v 3 Maromak nia sidade,
\q2 ema konta buat mesak furak kona ba o.
\b
\q1 
\v 4 Maromak dehan, “Bainhira Hau temi ema sira nebee rekonhese Hau,
\q2 Hau temi mos rai Rahab \f + \fr 87:4 \ft Rahab nee mak rai Ejitu. Naran nee uza iha poezia.\f* ho Babilónia nia naran,
\q1 ho tan rai Filístia, Tiru ho Etiópia.
\q2 Hau sei foo sai dehan, sira mos Siaun oan.”
\q1 
\v 5 Loos duni, kona ba Siaun ema sei dehan,
\q2 “Sira nee hotu moris iha nebaa,
\q2 no Maromak Aas Liu rasik sei harii sidade nee.”
\q1 
\v 6 Bainhira NAI rejista Nia povu, Nia sei hakerek,
\q2 “Ida nee moris iha Siaun.”
\b
\q1 
\v 7 Ema sei bidu rame-rame hodi hananu,
\q2 “Siaun, o mak hau nia bee matan inan.”
\c 88
\s1 Orasaun iha tempu susar boot
\d Salmu husi Korá nia oan, tuir muzika “Mahalat Leanot.” Kantiku ida husi Heman, ema Kanaán, para hanorin ema. Ba dirijenti koru.
\b
\q1 
\v 1 NAI Maromak, hau nia Salvador,
\q2 loron-kalan hau halerik husu tulun ba Ita Boot.
\q1 
\v 2 Simu hau nia orasaun ba;
\q2 see tilun ba hau nia harohan.
\q1 
\v 3 Hau nia laran nakonu ho susar;
\q2 hau besik ona ba iha ema mate nia fatin.
\q1 
\v 4 Ema sura tiha ona hau hamutuk ho ema nebee lao tuun dadauk ba rai kuak;
\q2 hau hanesan ema ida nebee la iha forsa.
\q1 
\v 5 Hau hela mes-mesak iha ema mate sira nia klaran;
\q2 hau hanesan vitima nebee ema oho hodi latan iha rate laran.
\q1 Ema mate sira nee Ita Boot la hanoin tan ona;
\q2 Ita Boot la tulun ona sira.
\q1 
\v 6 Ita Boot soe tiha ona hau tuun liu iha rai kuak naruk,
\q2 iha fatin nakukun teb-tebes.
\q1 
\v 7 Ita Boot nia hirus halo todan hau;
\q2 Ita Boot halo laloran makaas mai hotu hodi hanehan hau.
\b
\q1 
\v 8 Ita Boot haketak tiha hau husi hau nia belun diak;
\q2 Ita Boot halo sira hakribi hau;
\q1 hau iha hela fatin kloot, no sai la diak;
\q2 
\v 9 hau nia matan malahuk tanba hau tristi liu.
\q1 NAI Maromak, loro-loron hau harohan ba Ita Boot;
\q2 hau hasae hau nia liman ba Ita Boot.
\q1 
\v 10 Ita Boot hatudu milagre ba ema mate sira ka?
\q2 Matebian sira hadeer fali hodi hahii Ita Boot ka?
\q1 
\v 11 Ema foo sai Ita Boot nia domin iha rate laran ka?
\q2 Ema deklara Ita Boot nia salvasaun iha mate sira nia rain ka?
\q1 
\v 12 Iha fatin nakukun nian, ema rekonhese Ita Boot nia milagre ka?
\q2 Iha fatin nebee ema haluha buat hotu-hotu, ema sei hatene Ita Boot nia justisa ka?
\b
\q1 
\v 13 Maibee NAI Maromak, hau harohan husu tulun ba Ita Boot;
\q2 dadeer-dadeer hau nia orasaun sae ba iha Ita Boot nia oin.
\q1 
\v 14 NAI, tansaa mak Ita Boot la simu hau?
\q2 Tansaa mak Ita Boot subar oin mai hau?
\b
\q1 
\v 15 Komesa husi joven, hau hetan terus no besik atu mate;
\q2 Ita Boot husik hela todan iha hau nia leten too hau lakon esperansa.
\q1 
\v 16 Ita Boot nia laran nakali domina hela hau;
\q2 Ita Boot asalta hau halo hau mohu.
\q1 
\v 17 Iha loron tomak Ita Boot nia hirus hanesan bee boot ida nebee dulas haleu,
\q2 halo hau mout sal-sala.
\q1 
\v 18 Ita Boot hasai tiha ona hau husi hau nia belun ho vizinhu sira;
\q2 agora nakukun mak sai fali hau nia belun.
\c 89
\s1 Nai Maromak nia promesa ba liurai David
\d Salmu husi Etán, ema Kanaán, para hanorin ema.
\b
\q1 
\v 1 NAI Maromak, hau sei hananu tinan ba tinan kona ba Ita Boot nia domin rohan-laek;
\q2 husi jerasaun ba jerasaun hau nia ibun sei foo sai katak Ita Boot sempre halo buat nebee mak loos.
\q1 
\v 2 Hau sei deklara katak Ita Boot nia domin metin nafatin ba nafatin;
\q2 Ita Boot nia lia loos dura hanesan lalehan.
\b
\q1 
\v 3 Uluk Ita Boot hatete nunee: “Hau halo ona promesa ho ema ida nebee Hau hili;
\q2 Hau jura tiha ona ba Hau nia atan David dehan,
\q1 
\v 4 \x + \xo 89:4 \xt 2 Samuel 7:12-16; 1 Krónikas (Tawarikh) 17:11-14; Salmu 132:11; Apostolu sira nia Istoria 2:30\x*‘Hau sei halo o nia jerasaun ukun tinan ba tinan;
\q2 sira sei sai liurai husi jerasaun ba jerasaun.’”
\b
\q1 
\v 5 NAI Maromak, lalehan hahii buat furak nebee Ita Boot halo;
\q2 espiritu bo-boot sira halibur malu hahii NAI tanba NAI sempre halo buat nebee mak loos.
\q1 
\v 6 Iha lalehan, see mak bele kompara ho NAI?
\q2 Hotu-hotu nebee iha lalehan, see mak hanesan NAI?
\q1 
\v 7 Maromak makaas liu fali espiritu bo-boot nebee haleu Nia;
\q2 sira hotu hamtauk teb-tebes Nia.
\q1 
\v 8 NAI Maromak Aswain, see mak makaas hanesan Ita Boot?
\q2 NAI, Ita Boot sempre halo buat nebee mak loos.
\b
\q1 
\v 9 Ita Boot mak ukun tasi nebee nafurin sae;
\q2 bainhira laloran makaas, Ita Boot mak halo hakmatek fali.
\q1 
\v 10 Ita Boot buti mate samea boot Rahab;
\q2 hodi Ita Boot nia liman forti Ita Boot halo inimigu sira halai namkari tiha.
\q1 
\v 11 Lalehan nee Ita Boot nian, rai mos Ita Boot nian hotu;
\q2 mundu ho buat hotu-hotu iha laran, Ita Boot mak harii.
\q1 
\v 12 Parte norte ho sul, Ita Boot mak kria;
\q2 foho Tabor ho Hermon haksolok hodi hahii Ita Boot nia naran.
\q1 
\v 13 Ita Boot nia liman forsa;
\q2 Ita Boot nia liman forti;
\q2 Ita Boot nia liman loos makaas teb-tebes.
\q1 
\v 14 Ita Boot ukun nudar Liurai tuir lia loos ho justisa;
\q2 Ita Boot ukun ho domin, no sempre halo buat nebee mak loos.
\q1 
\v 15 NAI Maromak, ema nebee hatene haklalak hodi hahii Ita Boot,
\q2 ema nebee lao iha Ita Boot nia futar oin naroman,
\q2 sira nee hetan ksolok.
\q1 
\v 16 Loron-kalan sira haksolok tanba Ita Boot nia naran;
\q2 sira haksolok haklalak tanba Ita Boot nia lia loos.
\q1 
\v 17 Tanba Ita Boot mak sira nia kbiit no sira nia forsa;
\q2 Ita Boot nia laran diak halo ami manaan.
\q1 
\v 18 Tebes duni, NAI Maromak mak hili ema ida sai ami nia defensor;
\q2 ami nia liurai nee nia Nain mak Israel nia Maromak Santu.
\b
\q1 
\v 19 Uluk Ita Boot koalia liu husi mehi
\q2 hodi hatete ba Ita Boot nia povu santu dehan,
\q1 “Hau tau tiha ona koroa liurai nian ba iha aswain ida nia ulun;
\q2 Hau foti sae mane joven ida husi povu nia leet.
\q1 
\v 20 \x + \xo 89:20 \xt 1 Samuel 13:14; Apostolu sira nia Istoria 13:22; \xt 1 Samuel 16:12\x*Hau hetan Hau nia atan David;
\q2 Hau kose Hau nia mina santu ba nia hodi halo nia sai liurai.
\q1 
\v 21 Hau nia liman sei tane nia;
\q2 Hau nia liman sei halo nia forsa.
\q1 
\v 22 Inimigu sira sei la liu nia;
\q2 ema aat sei la hanehan nia.
\q1 
\v 23 Hau sei sama hanehan nia funu baluk sira iha nia oin;
\q2 ema nebee odi nia, Hau sei oho tiha.
\q1 
\v 24 Hau sei hadomi nia hodi kaer metin Hau nia promesa ba nia;
\q2 hodi Hau nia naran, nia sei manaan.
\q1 
\v 25 Hau sei halo nia liman ukun tasi;
\q2 nia liman loos ukun mota.
\q1 
\v 26 Nia sei dehan sai mai Hau,
\q2 ‘Ita Boot mak hau nia Aman,
\q2 hau nia Maromak;
\q2 Ita Boot mak fatuk lolon boot nebee hau helik ba para hetan salvasaun.’
\q1 
\v 27 \x + \xo 89:27 \xt Apokalipse 1:5\x*Hau sei foti nia nudar Hau nia oan mane boot;
\q2 nia mak liurai boot liu iha mundu.
\q1 
\v 28 Hau sei foo Hau nia domin ba nia tinan ba tinan;
\q2 Hau nia promesa ho Hau nia lei la hotu la remata.
\q1 
\v 29 Hau sei halo nia jerasaun ukun tinan ba tinan;
\q2 sira nia ukun sei dura hanesan lalehan.
\q1 
\v 30 Se karik nia oan sira husik tiha Hau nia lei,
\q2 no la tuir Hau nia regulamentu,
\q1 
\v 31 se karik sira viola Hau nia regra,
\q2 no la kaer metin Hau nia ukun fuan,
\q1 
\v 32 entaun Hau sei kastigu sira ho rota tanba sira halo sala hasoru Hau;
\q2 Hau sei baku sira ho sikoti tanba sira halo pekadu.
\q1 
\v 33 Maibee Hau sei la hasai fali Hau nia domin husi nia;
\q2 Hau sei la haluha Hau nia promesa.
\q1 
\v 34 Hau sei la kontra hau nia promesa ho nia;
\q2 liafuan nebee sai husi Hau nia ibun, sei la muda.
\q1 
\v 35 Hau sei la bosok David;
\q2 Hau jura tiha ona dala ida hodi Hau nia naran santu;
\q2 juramentu nee dura ba nafatin katak,
\q1 
\v 36 nia jerasaun sei ukun tinan ba tinan;
\q2 nia ukun dura iha Hau nia oin hanesan loro matan;
\q1 
\v 37 nia ukun harii metin nafatin ba nafatin hanesan fulan;
\q2 fulan nee mos foo sasin lo-loos husi kalohan.”
\b
\q1 
\v 38 Maibee agora Ita Boot la simu liurai hodi soe tiha nia;
\q2 Ita Boot hirus teb-tebes ho ema nebee mak Ita Boot hili ona nee.
\q1 
\v 39 Ita Boot kansela tiha promesa ho Ita Boot nia atan;
\q2 Ita Boot soe nia koroa ba iha rai rahun.
\q1 
\v 40 Ita Boot baku rahun tiha hotu moru sidade nian
\q2 hodi estraga tiha nia fatin seguru.
\q1 
\v 41 Ema hotu nebee liu husi nebaa hadau nia sasaan;
\q2 nia vizinhu sira hamnasa fali nia.
\q1 
\v 42 Ita Boot halo nia funu baluk sira manaan;
\q2 Ita Boot halo nia inimigu sira hotu kontenti.
\q1 
\v 43 Ita Boot mos fila tiha nia surik nia kroat,
\q2 no la ajuda nia iha funu laran.
\q1 
\v 44 Ita Boot hasai tiha nia poder;
\q2 nia kadeira ukun, Ita Boot soe tiha ba rai.
\q1 
\v 45 Ita Boot habadak tiha ona nia vida joven;
\q2 Ita Boot falun nia ho moe.
\b
\q1 
\v 46 NAI Maromak, Ita Boot subar Aan beibeik too bainhira? Too tinan ba tinan ka?
\q2 Ita Boot nia hirus lakan hanesan ahi too bainhira?
\q1 
\v 47 Keta haluha katak hau nia moris badak deit;
\q2 Ita Boot kria ema umanu la iha folin.
\q1 
\v 48 See mak bele moris ba beibeik no nunka mate?
\q2 See mak bele halai sees husi forsa rai kuak nian?
\b
\q1 
\v 49 Nai Maromak, uluk Ita Boot jura ho laran atu foo domin rohan-laek ba David.
\q2 Agora Ita Boot nia domin nee iha nebee ona?
\q1 
\v 50 Nai, haree ba, ema tarata Ita Boot nia atan hau;
\q2 hau hulan hela liafuan aat nebee ema barak hatete kona ba hau.
\q1 
\v 51 NAI, Ita Boot nia inimigu sira tarata hau;
\q2 iha nebee-nebee deit sira hatete aat liurai nebee Ita Boot hili tiha ona.
\b
\q1 
\v 52 Hahii NAI Maromak tinan ba tinan!
\q2 Amen, amen.
\c 90
\s1 Husu Nai Maromak nia laran diak tanba ita ema nia moris badak deit
\d Orasaun husi Moisés, Maromak nia liman-ain.
\b
\q1 
\v 1 Nai Maromak, Ita Boot mak ami nia hela fatin
\q2 husi jerasaun ba jerasaun.
\q1 
\v 2 Molok Ita Boot halo mundu rai klaran,
\q2 foho sira seidauk mosu,
\q1 Ita Boot Maromak nanis kedas ona;
\q2 Ita Boot Maromak nafatin ba nafatin.
\b
\q1 
\v 3 Ita Boot halo ema fila fali ba rai rahun;
\q2 Ita Boot dehan, “Imi ema isin ho raan, fila fali ba rai rahun ba.”
\q1 
\v 4 \x + \xo 90:4 \xt 2 Pedro 3:8\x*Ba Ita Boot, tinan rihun ida
\q2 hanesan fali loron ida, liu lalais deit,
\q2 hanesan oras balu nebee ema seguransa hein iha tempu kalan.
\q1 
\v 5 Ita Boot dasa sai tiha ema, sira lakon hanesan mehi;
\q2 sira hanesan duut nebee moris iha dadeer-saan.
\q1 
\v 6 Iha dadeer duut nee tubun buras,
\q2 maibee iha lokraik namlaik tiha too maran.
\b
\q1 
\v 7 Ita Boot nia hirus halo ami atu mohu;
\q2 Ita Boot nia laran nakali halo ami tauk teb-tebes.
\q1 
\v 8 Ita Boot halekar ami nia pekadu iha Ita Boot nia oin;
\q2 ami nia sala segredu Ita Boot leno sai mo-moos.
\q1 
\v 9 Loron ba loron Ita Boot nia hirus taka tomak ami nia moris;
\q2 ami nia moris remata ho halerik.
\q1 
\v 10 Ami nia vida too tinan hitu-nulu deit;
\q2 se ami iha forsa karik, bele too walu-nulu.
\q1 Bele nunee mos, tinan hirak nee hotu ami hetan susar ho terus;
\q2 tempu nee liu lalais deit, depois ami semo lakon tiha.
\q1 
\v 11 La iha ema ida bele hatene Ita Boot nia hirus nee forsa too iha nebee.
\q2 Ita Boot nia laran nakali makaas liu, halo ami hamtauk teb-tebes Ita Boot.
\q1 
\v 12 Hanorin ami atu hatene sura ami nia loron,
\q2 nunee ami bele sai matenek.
\b
\q1 
\v 13 NAI Maromak, fila mai ba!
\q2 Ita Boot atu hirus too bainhira?
\q2 Hanoin Ita Boot nia atan sira ba.
\q1 
\v 14 Iha dadeer-saan, habosu ami ho Ita Boot nia domin rohan-laek,
\q2 atu ami bele kanta haksolok ho kontenti iha ami nia moris tomak.
\q1 
\v 15 Durante tempu naruk Ita Boot halo ami terus;
\q2 foo ksolok fali mai ami durante tempu naruk ba;
\q1 durante tinan barak ami hetan susar;
\q2 halo ami haksolok fali durante tinan barak.
\q1 
\v 16 Husik Ita Boot nia atan ami haree buat nebee mak Ita Boot halo;
\q2 husik ami nia oan sira haree Ita Boot nia furak.
\q1 
\v 17 Nai ami nia Maromak, hatudu laran diak mai ami;
\q2 halo ami nia servisu lao ba oin;
\q2 halo ami nia knaar lao ba oin.
\c 91
\s1 Hela iha Nai Maromak nia mahon
\q1 
\v 1 Ema nebee moris hamahon aan iha Maromak Aas Liu,
\q2 ema nebee hakmatek iha Maromak Kbiit Nain nia mahon,
\q1 
\v 2 nia sei hatete ba NAI Maromak,
\q2 “Ita Boot mak fatin seguru mai hau, Ita Boot mak lutu haleu hau;
\q2 hau nia Maromak, hau konfia Ita Boot.”
\b
\q1 
\v 3 Tebes duni, Maromak sei salva o
\q2 husi lasu nebee kasador sira tau iha dalan,
\q2 no husi moras aat nebee hamate ema.
\q1 
\v 4 Nia sei falun o hodi Nia liras;
\q2 o sei hamahon aan iha Nia liras okos;
\q2 Nia domin sei haleu o hodi defende o.
\q1 
\v 5 O sei la tauk buat aat iha kalan;
\q2 o sei la tauk rama oan nebee semo iha loron.
\q1 
\v 6 Moras aat nebee lao iha nakukun laran,
\q2 ka moras nebee ameasa ema iha loron manas mos o sei la tauk.
\q1 
\v 7 Maski ema rihun ida monu iha o nia sorin,
\q2 maski ema rihun sanulu monu iha o nia liman loos,
\q2 maibee buat ida la kona o.
\q1 
\v 8 O nia matan sei hateke tuir deit;
\q2 o sei haree oinsaa ema aat hetan kastigu.
\b
\q1 
\v 9 Se o halo NAI Maromak sai o nia fatin seguru,
\q2 se o halo Maromak Aas Liu sai o nia hela fatin,
\q1 
\v 10 entaun buat aat sei la kona o;
\q2 dezastre sei la mai besik o nia hela fatin.
\q1 
\v 11 \x + \xo 91:11 \xt Mateus 4:6; Lucas 4:10\x*Tanba Maromak sei haruka Nia anju sira mai kuidadu o
\q2 iha o nia moris tomak.
\q1 
\v 12 \x + \xo 91:12 \xt Mateus 4:6; Lucas 4:11\x*Sira sei lolo liman hodi tane o,
\q2 atu o nia ain la bele kona fatuk.
\q1 
\v 13 \x + \xo 91:13 \xt Lucas 10:19\x*O sei sama liaun ho samea kobra;
\q2 o sei sama hanehan liaun forti ho samea boot.
\b
\q1 
\v 14 NAI Maromak dehan, “Hau sei salva ema nebee hadomi Hau;
\q2 Hau sei proteje ema nebee hatene tuir Hau nia naran.
\q1 
\v 15 Bainhira nia husu tulun mai Hau, Hau sei hataan;
\q2 Hau sei hamutuk ho nia iha susar laran;
\q2 Hau sei defende nia no foti aas nia.
\q1 
\v 16 Hau sei haraik vida naruk ba nia hodi halo nia kontenti;
\q2 Hau sei hatudu Hau nia salvasaun ba nia.”
\c 92
\s1 Kantiku hahii Nai Maromak
\d Salmu. Kantiku ba loron Sabadu.
\b
\q1 
\v 1 Hahii NAI Maromak nee buat diak ida;
\q2 Maromak Aas Liu, hananu hahii Ita Boot nia naran nee furak.
\q1 
\v 2-3 Iha dadeer-saan hau toka viola
\q2 hodi foo sai Ita Boot nia domin rohan-laek;
\q1 iha kalan hau halo muzika ho viola tali sanulu
\q2 hodi deklara katak Ita Boot sempre halo buat nebee loos;
\q2 hahii Ita Boot nunee buat furak ida.
\b
\q1 
\v 4 NAI Maromak, hau kontenti tanba buat nebee Ita Boot halo;
\q2 hau hananu haksolok tanba buat nebee Ita Boot nia liman halo tiha ona.
\q1 
\v 5 NAI, Ita Boot nia servisu furak loos;
\q2 Ita Boot nia hanoin klean teb-tebes.
\q1 
\v 6 Ema sira nebee kakutak mamuk la hatene;
\q2 ema beik-teen la kompriende katak,
\q1 
\v 7 ema aat bele buras lalais hanesan duut;
\q2 ema nebee gosta hahalok aat bele moris diak,
\q2 maibee too ikus sira sei mohu tinan ba tinan.
\b
\q1 
\v 8 Maibee NAI Maromak, Ita Boot iha fatin aas tinan ba tinan.
\q1 
\v 9 Tebes duni NAI,
\q2 ema nebee hahalok aat sei halai namkari hotu;
\q2 Ita Boot nia inimigu sira sei mate mohu.
\q1 
\v 10 Ita Boot hasae tiha ona hau nia dikur hanesan karau aman fuik nia dikur;
\q2 Ita Boot fui mina morin diak nian ba hau nia leten.
\q1 
\v 11 Hau nia matan haree ona hau nia inimigu sira monu;
\q2 hau nia tilun rona ona hau nia funu baluk sira halai saruntu malu.
\q1 
\v 12 Ema nebee moris loos sei buras hanesan ramus huun;
\q2 sira sei sai forti hanesan ai huun sedru iha rai Líbanu.
\q1 
\v 13 Sira nee kuda tiha ona iha NAI Maromak nia uma;
\q2 sira sei buras iha ita nia Maromak nia uma kreda.
\q1 
\v 14 Maski sira idade ona mos, sira sei matak ho buras;
\q2 sira sei foo fuan ba beibeik.
\q1 
\v 15 Sira foo sai dehan, “NAI Maromak nee sempre halo buat nebee loos;
\q2 Nia mak fatuk lolon boot nebee hau helik ba;
\q2 la iha buat aat ida iha Nia.”
\c 93
\s1 Nai Maromak ukun tinan ba tinan
\q1 
\v 1 NAI Maromak mak Liurai, Nia hatais murak mean;
\q2 NAI hatudu sai Nia kbiit.
\q1 Nia harii metin mundu nee,
\q2 mundu nunka atu nakdoko.
\b
\q1 
\v 2 Ita Boot ukun nanis kedas;
\q2 Ita Boot iha hori uluk liu.
\q1 
\v 3 NAI Maromak, laloran tasi hasae lian;
\q2 tasi nia lian makaas;
\q2 laloran tasi tarutu hasae nia lian.
\q1 
\v 4 NAI iha fatin aas ba, Nia makaas teb-tebes;
\q2 makaas liu bee boot nebee tarutu,
\q2 makaas liu laloran tasi nebee baku ba-mai.
\q1 
\v 5 NAI, Ita Boot nia mandamentu dura nafatin;
\q2 Ita Boot nia uma santu teb-tebes too tinan ba tinan.
\c 94
\s1 Nai Maromak mak Justisa Nain
\q1 
\v 1 NAI Maromak, Ita Boot mak kastigu ema nebee halo buat aat;
\q2 Ita Boot mak selu fali buat aat nebee sira halo;
\q2 Maromak, hatudu Aan ba!
\q1 
\v 2 Juis mundu tomak nian, hamriik ba;
\q2 selu fali ema foti aan sira tuir buat nebee sira merese hetan.
\q1 
\v 3 NAI, ema aat sira atu kontenti too bainhira?
\q2 Ema aat sira nee sei haklalak too bainhira?
\q1 
\v 4 Sira muta sai liafuan gaba aan;
\q2 ema nebee hahalok aat, sira mesak foti aan deit.
\q1 
\v 5 NAI, sira sama rahun Ita Boot nia povu;
\q2 sira hanehan povu nebee Ita Boot rasik hili.
\q1 
\v 6 Sira oho feto faluk ho ema lao rai;
\q2 sira hakotu oan kiak sira nia vida.
\q1 
\v 7 Sira dehan, “NAI la haree ida;
\q2 Jacó nia Maromak la preokupa.”
\b
\q1 
\v 8 Imi kakutak mamuk sira iha povu nia leet, rona mai.
\q2 Imi ema beik-teen sira nee, bainhira mak imi bele kompriende?
\q1 
\v 9 Ida nebee kria tilun nee la rona fali ka?
\q2 Ida nebee halo matan nee la haree fali ka?
\q1 
\v 10 Ida nebee foo disiplina ba nasaun jentiu sira la hatene foo kastigu ka?
\q2 Ida nebee hanorin ema, Nia konhesimentu la iha fali ka?
\q1 
\v 11 \x + \xo 94:11 \xt 1 Korintu 3:20\x*NAI hatene ema hotu nia hanoin;
\q2 Nia konsidera ema nia hanoin buat mamuk ida.
\b
\q1 
\v 12 NAI Maromak, ema nebee Ita Boot koriji,
\q2 ema nebee Ita Boot hanorin kona ba Ita Boot nia lei,
\q2 sira nee hetan ksolok.
\q1 
\v 13 Ita Boot halo sira hakmatek iha tempu susar,
\q2 too rai kuak prontu ona ba ema aat sira.
\q1 
\v 14 Tanba NAI Maromak nunka soe Nia povu;
\q2 Nia nunka husik hela povu nebee Nia rasik hili ona.
\q1 
\v 15 Justisa sei bazeia fali ba lia loos,
\q2 no ema nebee laran moos sei moris tuir.
\b
\q1 
\v 16 See mak sei hamriik defende hau hodi hasoru ema aat?
\q2 See mak atu firmi defende hau kontra ema nebee gosta halo aat?
\q1 
\v 17 Se laos NAI Maromak mak ajuda hau,
\q2 la kleur tan hau sei baa hela iha rai kuak nebee la iha lian.
\q1 
\v 18 NAI, bainhira hau dehan, “Hau nia ain kois,”
\q2 Ita Boot nia domin rohan-laek suporta hau.
\q1 
\v 19 Bainhira hau preokupa buat barak iha hau nia laran,
\q2 Ita Boot konsola hau, halo hau haksolok.
\b
\q1 
\v 20 Ukun nain laran aat nebee uza lei hodi hanehan povu
\q2 bele koopera ho Ita Boot ka?
\q1 
\v 21 Ema aat sira nee kombina malu kontra ema nebee moris loos;
\q2 sira foo kastigu mate ba ema nebee laran moos.
\q1 
\v 22 Maibee NAI sai tiha ona hau nia abrigu;
\q2 hau nia Maromak mak fatuk lolon boot nebee hau helik ba.
\q1 
\v 23 Nia sei kastigu sira tuir buat aat nebee sira halo;
\q2 Nia sei oho tiha sira tanba sira nia hahalok aat;
\q2 NAI ita nia Maromak sei dasa sai tiha sira.
\c 95
\s1 Kantiku hahii nian
\q1 
\v 1 Mai ita hananu haksolok ba NAI Maromak;
\q2 mai ita haklalak makaas tanba Nia mak fatuk lolon boot hodi salva ita.
\q1 
\v 2 Mai ita baa iha Nia oin hodi foo agradese,
\q2 no toka muzika hodi hananu hahii Nia.
\q1 
\v 3 Tanba NAI nee Maromak boot;
\q2 Nia mak Liurai boot, Nia aas liu maromak sel-seluk.
\q1 
\v 4 Rai nee nia klean iha Nia liman laran;
\q2 foho aas hotu-hotu Ninian.
\q1 
\v 5 Tasi nee Ninian, tanba Nia mak kria;
\q2 Nia liman mak forma rai maran.
\b
\q1 
\v 6 Mai ita hakruuk hodi adora Nia;
\q2 mai ita hakneak iha NAI Maromak ita nia Kriador nia oin.
\q1 
\v 7 \x + \xo 95:7 \xt Ebreu 3:7-11\x*\x + \xo 95:7 \xt Ebreu 3:15, 4:7\x*Tanba Nia mak Ita nia Maromak;
\q2 ita nee Nia povu nebee Nia tau matan,
\q2 bibi nebee Nia kuidadu.
\b
\q1 Ohin loron, imi tenki rona Nia liafuan;
\q1 
\v 8 \x + \xo 95:8 \xt Ézodu (Keluaran) 17:1-7; Númerus (Bilangan) 20:2-13\x*la bele ulun toos hanesan imi nia bei-ala sira uluk halo iha rai Meriba,
\q2 hanesan uluk sira halo iha area Masá iha rai fuik maran.
\q1 
\v 9 Iha nebaa sira haree Hau nia milagre,
\q2 maibee sira koko Hau nafatin;
\q2 sira sadik nafatin Hau.
\q1 
\v 10 Durante tinan haat-nulu Hau hirus sira hodi dehan,
\q1 “Sira nee povu ida nebee sempre lao sees husi dalan loos,
\q2 no lakohi rona Hau nia liafuan.”
\q1 
\v 11 \x + \xo 95:11 \xt Númerus (Bilangan) 14:20-23; Deuteronómiu (Ulangan) 1:34-36; Ebreu 4:3,5; \xt Deuteronómiu (Ulangan) 12:9,10\x*Nee mak Hau hirus too Hau jura dehan,
\q2 “Ema sira nee sei la tama iha Hau nia fatin deskansa.”
\c 96
\s1 Nai Maromak mak Liurai ho Juis boot
\q1 
\v 1 Hananu kantiku foun ba NAI Maromak;
\q2 mundu tomak, hananu ba NAI.
\q1 
\v 2 Hananu ba NAI, hahii Nia naran;
\q2 loro-loron foo sai Nia salvasaun.
\q1 
\v 3 Deklara sai ba nasaun hotu-hotu kona ba Nia kbiit;
\q2 konta sai ba povu hotu-hotu kona ba buat furak nebee Nia halo tiha ona.
\q1 
\v 4 NAI Maromak nee boot, Nia serve atu ita hahii;
\q2 ema tenki hamtauk Nia liu fali maromak sel-seluk.
\q1 
\v 5 Tanba nasaun jentiu sira nia maromak la vale buat ida,
\q2 maibee NAI mak halo lalehan.
\q1 
\v 6 Nia hatudu sai Nia naran boot ho Nia naroman nabilan;
\q2 Nia kbiit ho Nia furak iha hela Nia fatin santu.
\b
\q1 
\v 7 \x + \xo 96:7 \xt Salmu 29:1,2\x*Imi nasaun sira hotu, hahii NAI Maromak;
\q2 hahii NAI tanba Nia kbiit boot ho forsa.
\q1 
\v 8 Foti aas NAI nia naran, tanba Nia merese duni;
\q2 lori oferta hodi mai iha Nia uma kreda.
\q1 
\v 9 Adora NAI iha Nia fatin santu ho furak;
\q2 mundu tomak, nakdedar iha Nia oin ba.
\q1 
\v 10 Hatete ba nasaun hotu-hotu dehan,
\q2 “NAI Maromak mak Liurai.
\q1 Mundu nee hamriik metin no nunka atu muda;
\q2 Nia sei tesi lia ba povu hotu-hotu ho lo-loos.”
\b
\q1 
\v 11 Lalehan, haksolok ba; mundu, kontenti ba;
\q2 tasi ho buat hotu iha laran, hasai lian ba;
\q2 
\v 12 rai maran ho buat hotu nebee iha rai leten, haklalak ba.
\q1 Ai huun hotu-hotu iha ai laran sei hananu ho haksolok
\q2 
\v 13 iha NAI Maromak nia oin
\q1 tanba Nia mai,
\q2 Nia mai atu foo justisa ba mundu.
\q1 Nia sei foo justisa ba mundu ho lo-loos;
\q2 Nia tesi povu nia lia tuir Nia lia loos.
\c 97
\s1 Nai Maromak mak Ukun Nain boot
\q1 
\v 1 NAI Maromak mak Liurai;
\q2 mundu rai klaran, kontenti ba;
\q2 rai sira iha tasi balu, haksolok ba!
\q1 
\v 2 Kalohan nakukun haleu hela Nia;
\q2 Nia ukun nudar Liurai tuir lia loos ho justisa.
\q1 
\v 3 Ahi lakan iha Nia oin
\q2 hodi haan Nia inimigu sira iha fat-fatin.
\q1 
\v 4 Rai lakan husi Nia leno mundu;
\q2 haree nunee, rai nakdedar tiha.
\q1 
\v 5 Foho sira nabeen iha NAI Maromak nia oin hanesan fali lilin;
\q2 iha mundu tomak nia Nai nia prezensa, foho sira nabeen tiha.
\q1 
\v 6 Lalehan foo sai katak Maromak sempre halo buat nebee loos;
\q2 nasaun hotu-hotu haree Nia kbiit boot.
\q1 
\v 7 Ema hotu nebee adora estatua lulik,
\q2 sira nebee gaba aan kona ba buat maten, sira sei moe leet;
\q2 maromak hirak nee hotu-hotu tenki hakruuk ba Nia.
\b
\q1 
\v 8 NAI Maromak, bainhira Ita Boot foo justisa,
\q2 ema iha sidade Siaun rona hodi haksolok;
\q2 vila hotu-hotu iha rai Judá kontenti.
\q1 
\v 9 Tanba NAI, Ita Boot mak ukun mundu tomak;
\q2 Ita Boot aas liu dook maromak sel-seluk.
\b
\q1 
\v 10 Imi nebee hadomi NAI Maromak, hakribi buat aat ba,
\q2 tanba Nia tau matan ba ema nebee foo laran ba Nia;
\q2 Nia hasai sira husi ema aat nia liman laran.
\q1 
\v 11 Naroman leno ema nebee moris loos;
\q2 ksolok leno ema nebee laran moos.
\q1 
\v 12 Imi sira nebee moris loos, haksolok tanba NAI nia diak;
\q2 hahii Nia naran santu ba.
\c 98
\s1 Nai Maromak mak ukun mundu
\d Salmu.
\b
\q1 
\v 1 Hananu kantiku foun ba NAI Maromak,
\q2 tanba Nia halo ona buat furak teb-tebes.
\q1 Hodi Nia liman loos;
\q2 hodi Nia liman santu,
\q2 Nia manaan tiha ona Nia inimigu.
\q1 
\v 2 NAI deklara tiha ona Nia vitoria;
\q2 Nia hatudu sai Nia justisa ba nasaun hotu-hotu.
\q1 
\v 3 Nia hatudu Nia domin rohan-laek ba Israel;
\q2 Nia kaer metin Nia promesa ba ita;
\q1 rai ulun too rai ikun iha mundu tomak haree tiha ona
\q2 salvasaun husi ita nia Maromak.
\b
\q1 
\v 4 Mundu tomak, haklalak haksolok ba NAI Maromak ba;
\q2 toka muzika hodi hananu ho haksolok.
\q1 
\v 5 Toka viola halo muzika ba NAI;
\q2 toka viola ho knananuk murak.
\q1 
\v 6 Huu korneta, huu karau dikur;
\q2 haklalak haksolok iha NAI nia oin; Nia mak Liurai.
\b
\q1 
\v 7 Tasi ho buat hotu iha laran, hasai lian ba;
\q2 mundu ho buat hotu nebee moris iha laran mos hasae lian ba.
\q1 
\v 8 Mota sira, basa liman ba;
\q2 foho sira, hananu rame-rame hodi haksolok ba.
\q1 
\v 9 Hananu iha NAI Maromak nia oin,
\q2 tanba Nia mai atu foo justisa ba mundu.
\q1 Nia sei foo justisa ba mundu ho lo-loos;
\q2 Nia foo justisa ba povu tuir lia loos.
\c 99
\s1 Nai Maromak mak Liurai santu
\q1 
\v 1 \x + \xo 99:1 \xt Ézodu (Keluaran) 25:22\x*NAI Maromak nee Liurai;
\q2 nasaun hotu-hotu tauk ho nakdedar.
\q1 Nia tuur iha anju kerubin nia leten hodi ukun;
\q2 rai nakdoko.
\q1 
\v 2 NAI Maromak nee Ukun Nain boot iha Siaun;
\q2 Nia domina nasaun hotu-hotu.
\q1 
\v 3 Sira sei hahii Nia
\q2 tanba Nia naran boot ho makaas;
\q2 Nia nee santu.
\b
\q1 
\v 4 Liurai Kbiit Nain, Ita Boot gosta justisa;
\q2 Ita Boot hatuur lia loos;
\q2 Ita Boot harii justisa ho lo-loos iha Israel\f + \fr 99:4 \ft Lian Ebreu dehan “Jacó”. Iha nee hatudu ba povu Israel.\f*.
\b
\q1 
\v 5 Foti aas NAI ita nia Maromak;
\q2 hakruuk iha Nia ain hodi adora Nia;
\q2 Nia nee santu.
\b
\q1 
\v 6 Uluk Moisés ho Arão serbi Nia nudar nai lulik;
\q2 Samuel mos ema ida nebee bolu Maromak nia naran.
\q1 Sira harohan ba NAI Maromak
\q2 mak Nia hataan sira.
\q1 
\v 7 \x + \xo 99:7 \xt Ézodu (Keluaran) 33:9\x*Husi kalohan riin laran, Nia koalia ba sira;
\q2 sira kaer metin lei no mandamentu nebee Nia foo ba sira.
\q1 
\v 8 NAI ami nia Maromak, Ita Boot hataan sira;
\q2 Maromak, Ita Boot perdua sira nia sala,
\q2 maibee Ita Boot mos kastigu sira tanba sira nia sala.
\b
\q1 
\v 9 Foti aas NAI ita nia Maromak;
\q2 adora Nia iha Nia foho santu,
\q2 tanba NAI ita nia Maromak nee santu.
\c 100
\s1 Haklalak haksolok ba NAI Maromak
\d Salmu agradesimentu nian.
\b
\q1 
\v 1 Mundu tomak, haklalak haksolok ba NAI Maromak;
\q2 
\v 2 adora NAI Maromak ho kontenti;
\q2 mai iha Nia oin ho hananu haksolok.
\q1 
\v 3 Rekonhese katak NAI mak Maromak;
\q2 Nia mak halo ita, ita nee Ninian.
\q1 Ita nee Nia povu;
\q2 ita hanesan bibi nebee iha Nia luhan laran.
\b
\q1 
\v 4 Hakat tama liu husi portaun boot ba iha Nia uma oin
\q2 hodi foo agradese ba Nia no foti aas Nia naran.
\q1 
\v 5 \x + \xo 100:5 \xt 1 Krónikas (Tawarikh) 16:34; 2 Krónikas (Tawarikh) 5:13, 7:3; Esdras (Ezra) 3:11; Salmu 106:1, 107:1, 118:1, 136:1; Jeremias 33:11\x*Tanba NAI Maromak nee diak;
\q2 Nia domin dura tinan ba tinan;
\q2 Nia foo laran ba ita husi jerasaun ba jerasaun.
\c 101
\s1 Liurai nia promesa ba Nai Maromak
\d Salmu David nian.
\b
\q1 
\v 1 NAI Maromak, hau sei kanta kona ba domin ho justisa;
\q2 hau sei hananu hahii Ita Boot.
\q1 
\v 2 Hau sei kuidadu hau nia aan hodi moris tuir dalan loos.
\q2 Bainhira mak Ita Boot atu mai?
\q1 Hau sei moris ho laran moos
\q2 iha hau nia uma laran.
\q1 
\v 3 Hau sei la tau buat aat iha hau nia oin;
\q2 hau hakribi buat nebee ema fiar-laek sira halo;
\q2 hau sei la hola parte iha sira nia hahalok.
\q1 
\v 4 Hau sei hadook aan husi ema nebee hanoin kleuk;
\q2 hau sei la partisipa iha buat aat saida deit.
\q1 
\v 5 Ema nebee mak hatete aat nia maluk iha kotu-kotuk,
\q2 hau sei halo nia mohu;
\q1 see-see deit mak foti aan no gaba aan,
\q2 hau la tolera.
\b
\q1 
\v 6 Hau nia matan sei fihir ema nebee foo laran ba Maromak iha rai nee,
\q2 atu sira hela hamutuk ho hau;
\q1 ema nebee moris tuir dalan loos
\q2 sei serbi hau.
\q1 
\v 7 Lohi door sira sei la hela iha hau nia uma;
\q2 bosok-teen sira sei la hamriik iha hau nia oin.
\q1 
\v 8 Dadeer-dadeer hau sei halo mohu tiha
\q2 ema aat hotu-hotu iha rai nee;
\q1 ema nebee gosta halo buat aat,
\q2 hau sei halakon tiha husi NAI Maromak nia sidade.
\c 102
\s1 Orasaun iha susar laran
\d Ema kbiit-laek ida nia orasaun, bainhira nia fraku, nunee nia fakar sai nia susar ba NAI Maromak.
\b
\q1 
\v 1 NAI Maromak, rona hau nia orasaun;
\q2 simu hau nia halerik ba.
\q1 
\v 2 Keta subar Ita Boot nia oin mai hau
\q2 bainhira hau iha susar laran.
\q1 See Ita Boot nia tilun mai hau;
\q2 bainhira hau harohan, hataan hau ho lalais ba.
\q1 
\v 3 Tanba hau nia moris liu lalais deit hanesan ahi suar;
\q2 hau nia isin tomak manas hanesan ahi klaak.
\q1 
\v 4 Hau nia fuan namlaik tiha hanesan duut nebee ema baku ba rai;
\q2 hau la hanoin tan atu haan.
\q1 
\v 5 Iha terus laran hau halerik makaas;
\q2 hau sai krekas, kulit taka ruin.
\q1 
\v 6 Hau hanesan manu kakuuk iha rai fuik,
\q2 hanesan manu kakuuk iha uma dodok nia laran.
\q1 
\v 7 Hau toba la dukur,
\q2 hau hanesan manu fuik nebee mes-mesak loos iha uma kakuluk leten.
\q1 
\v 8 Loron tomak hau nia inimigu sira hatete aat hau;
\q2 sira nebee koalia hasoru hau temi hau nia naran hodi foo malisan mai hau.
\q1 
\v 9 Hau nia hahaan mak ahu kdesan;
\q2 hau hemu fali hau nia matan been.
\q1 
\v 10 Tanba Ita Boot hirus teb-tebes hau;
\q2 Ita Boot foti hau hodi soe tiha ona hau.
\q1 
\v 11 Hau nia moris hanesan lalatak nebee mohu bainhira loro matan monu;
\q2 hau namlaik hanesan tiha duut.
\b
\q1 
\v 12 Maibee NAI Maromak, Ita Boot ukun tinan ba tinan;
\q2 Ita Boot nia naran dura husi jerasaun ba jerasaun.
\q1 
\v 13 Ita Boot sei hamriik hodi hatudu Ita Boot nia domin ba sidade Siaun,
\q2 tanba tempu ona atu Ita Boot hatudu Ita Boot nia diak ba sidade nee;
\q2 tempu nebee Ita Boot marka nee too tiha ona.
\q1 
\v 14 Tanba Ita Boot nia atan sira hadomi sidade nee nia fatuk;
\q2 too rai rahun nebee iha dalan mos, sira hanoin teb-tebes.
\q1 
\v 15 Nasaun hotu-hotu sei hamtauk NAI nia naran;
\q2 liurai sira iha mundu sei tauk Ita Boot nia kbiit.
\q1 
\v 16 Tanba NAI Maromak sei harii fila fali Siaun
\q2 hodi hatudu sai Nia kbiit boot.
\q1 
\v 17 Nia sei hataan ema kiak rabat rai sira nia orasaun;
\q2 Nia sei la fila kotuk ba sira nia hamulak.
\b
\q1 
\v 18 Hakerek ida nee ba jerasaun tuir mai,
\q2 atu ema nebee seidauk moris bele hahii NAI Maromak.
\q1 
\v 19 NAI iha Nia fatin santu iha leten aas ba hateke tuun;
\q2 husi lalehan Nia haree mai mundu
\q1 
\v 20 hodi rona ema dadur sira nia halerik,
\q2 no hasai sira nebee hetan kastigu mate.
\q1 
\v 21-22 Nunee liurai sira ho povu sira sei halibur hamutuk
\q2 hodi adora NAI Maromak.
\q1 Sira sei hahii NAI Maromak iha Jerusalém;
\q2 sira sei foo sai Nia naran iha Siaun.
\b
\q1 
\v 23 Hau nia moris foin too iha klaran, Maromak halo hau nia isin nebee forti sai fraku tiha;
\q2 Nia habadak hau nia vida.
\q1 
\v 24 Nunee hau dehan,
\q1 “Hau nia Maromak, Ita Boot moris tinan ba tinan;
\q2 hau foin too iha dalan klaran, keta hasai hau nia iis.”
\q1 
\v 25 \x + \xo 102:25 \xt Ebreu 1:10-12\x*Hori uluk liu Ita Boot halo mundu nee;
\q2 lalehan nee Ita Boot nia liman fatin.
\q1 
\v 26 Buat sira nee hotu aban-bainrua sei lakon, maibee Ita Boot iha nafatin;
\q2 buat sira nee sei sai bosan hanesan faru tuan.
\q1 Ita Boot sei troka buat sira nee hanesan troka hena,
\q2 no sei la iha tan.
\q1 
\v 27 Maibee Ita Boot nunka muda;
\q2 Ita Boot nia moris sei la remata.
\q1 
\v 28 Ita Boot nia atan sira nia oan sei moris ho hakmatek;
\q2 sira nia jerasaun sei dura iha Ita Boot nia oin.
\c 103
\s1 Nai Maromak nia domin
\d Salmu David nian.
\b
\q1 
\v 1 Hau hatete ba hau nia aan, hahii NAI Maromak ba;
\q2 ho laran tomak, hahii Nia naran santu ba.
\q1 
\v 2 Hau hatete ba hau nia aan, hahii NAI Maromak ba;
\q2 keta haluha Nia laran diak.
\q1 
\v 3 Tanba Nia foo perdaun ba o nia sala hotu,
\q2 no kura o nia moras hotu-hotu.
\q1 
\v 4 Nia hasai o husi rai kuak laran
\q2 hodi foo domin rohan-laek no laran luak ba o.
\q1 
\v 5 Nia foo buat diak ba o tuir o nia hakarak,
\q2 atu nunee Nia halo o joven fila fali hanesan manu makikit.
\b
\q1 
\v 6 NAI Maromak sempre halo buat nebee loos
\q2 hodi foo justisa ba vitima sira nebee ema hanehan.
\b
\q1 
\v 7 Nia foo hatene Nia dalan ba Moisés;
\q2 Nia hatudu Nia hahalok ba ema Israel.
\q1 
\v 8 \x + \xo 103:8 \xt Tiago 5:11\x*NAI Maromak nee laran diak no laran luak;
\q2 Nia Pasiensia Nain, no nakonu ho domin rohan-laek.
\q1 
\v 9 Nia bele foo sala mai ita maibee laos beibeik;
\q2 Nia bele hirus ita maibee la rai hirus nafatin ba nafatin.
\q1 
\v 10 Nia bele kastigu ita maibee kastigu nia todan la too buat nebee ita merese simu;
\q2 Nia foo kastigu ita laos tuir buat aat hotu nebee ita halo tiha ona.
\q1 
\v 11 Tanba hanesan lalehan aas liu mundu,
\q2 nunee mos Maromak nia domin aas teb-tebes ba ema nebee mak hamtauk Nia.
\q1 
\v 12 Hanesan lorosae dook husi loromonu,
\q2 nunee mos Nia hadook ita nia sala husi ita.
\q1 
\v 13 Nudar aman hadomi nia oan sira,
\q2 nunee mos NAI Maromak hadomi ema nebee mak hamtauk Nia.
\q1 
\v 14 Tanba Nia hatene ita nee halo husi saida;
\q2 Nia la haluha katak ita nee rai rahun.
\q1 
\v 15 Ita ema nia moris hanesan duut;
\q2 ita buras hanesan ai funan iha rai fuik.
\q1 
\v 16 Bainhira anin huu, semo lakon tiha;
\q2 ema atu buka tuir nia fatin, la hetan ona.
\q1 
\v 17 Maibee husi huun too rohan
\q2 NAI Maromak hadomi ema nebee mak hamtauk Nia,
\q2 no Nia laran diak hamutuk ho sira nia oan bei-oan sira,
\q1 
\v 18 ho ema nebee kaer metin Nia promesa,
\q2 no la haluha halo tuir Nia lei.
\b
\q1 
\v 19 NAI Maromak harii tiha ona Nia kadeira ukun iha lalehan;
\q2 Nia mak Liurai hodi ukun buat hotu-hotu.
\b
\q1 
\v 20 Imi anju sira, hahii NAI ba.
\q2 Imi nee iha forsa boot hodi halao Nia orden;
\q2 imi halo tuir Nia liafuan.
\q1 
\v 21 Tropas lalehan nian, hahii NAI ba.
\q2 Imi nee Nia atan hodi halo tuir Nia hakarak.
\q1 
\v 22 Buat hotu nebee Nia halo,
\q2 iha nebee-nebee deit mak Nia ukun, hahii NAI ba.
\b
\q1 Hau hatete ba hau nia aan, hahii NAI Maromak ba.
\c 104
\s1 Hahii ita nia Kriador
\q1 
\v 1 Hau hatete ba hau nia aan, hahii NAI Maromak ba.
\b
\q1 NAI hau nia Maromak, Ita mak boot teb-tebes;
\q2 Ita Boot hatudu sai Ita nia naran boot ho naroman nabilan.
\q1 
\v 2 Ita Boot falun Aan ho naroman hanesan fali hena naruk;
\q2 Ita Boot haluan lalehan hanesan ema dada tenda.
\q1 
\v 3 Ita Boot harii Ita Boot nia hela fatin iha kalohan mahar nia leten;
\q2 Ita Boot halo kalohan sai Ita Boot nia kuda kareta;
\q2 Ita Boot sae anin nia liras hanesan ema sae kuda.
\q1 
\v 4 \x + \xo 104:4 \xt Ebreu 1:7\x*Ita Boot haruka anin lori Ita Boot nia lia menon,
\q2 no halo ahi lakan sai Ita Boot nia atan.
\b
\q1 
\v 5 Ita Boot hatuur mundu ba iha nia fatin;
\q2 mundu nunka atu sees husi nia fatin nee.
\q1 
\v 6 Ita Boot falun mundu ho bee naruk hanesan hena naruk;
\q2 bee nee taka tomak foho aas sira.
\q1 
\v 7 Depois Ita Boot siak halo bee halai tiha;
\q2 Ita Boot nia lian tarutu halo bee suli sees tiha.
\q1 
\v 8 Bee suli liu husi foho tuun ba iha rai klean,
\q2 too iha fatin nebee Ita Boot hatudu ona.
\q1 
\v 9 Ita Boot tau baliza atu bee la bele suli liu;
\q2 bee sei la taka mundu tan.
\b
\q1 
\v 10 Ita Boot halo bee matan suli ba mota kiik;
\q2 bee nee suli tuun liu husi foho nia leet.
\q1 
\v 11 Nunee animal fuik bo-boot sira bele hemu;
\q2 kuda buru fuik hemu too hamrook lakon.
\q1 
\v 12 Manu fuik halo nia knuuk besik bee nee;
\q2 manu sira nee hananu iha ai sanak leten.
\q1 
\v 13 Husi Ita Boot nia uma iha leten, Ita Boot hatuun udan been ba foho;
\q2 Ita Boot nia liman fatin halo rai nee bosu.
\q1 
\v 14 Ita Boot halo duut buras ba animal,
\q2 no halo ai horis atu ema bele uza.
\q1 Nunee rai bele produs ai haan,
\q2 
\v 15 tua hodi halo ema nia laran kontenti,
\q1 mina hodi halo ema nia oin nabilan,
\q2 no hahaan hodi halo sira forti.
\q1 
\v 16 Ai huun sedru rai Líbanu nian hetan bee diak;
\q2 ai huun nee NAI Maromak nian, Nia mak kuda.
\q1 
\v 17 Iha nebaa manu fuik halo sira nia knuuk;
\q2 manu fuik boot halo nia uma iha ai sentru nia sanak.
\q1 
\v 18 Foho aas sai bibi fuik sira nia hela fatin;
\q2 fatuk kuak sai laku nia subar fatin.
\b
\q1 
\v 19 Ita Boot halo fulan hodi marka tempu;
\q2 loro matan hatene bainhira mak atu tuun.
\q1 
\v 20 Ita Boot foo nakukun, halo rai kalan tiha,
\q2 nunee animal ai laran nian sai mai.
\q1 
\v 21 Liaun forti lian boot hodi kasa animal,
\q2 atu buka ai haan nebee Maromak prepara.
\q1 
\v 22 Bainhira loro matan sae, liaun sira nee fila fali
\q2 hodi latan aan iha sira nia hela fatin.
\q1 
\v 23 Depois ema lao sai baa halao sira nia servisu;
\q2 sira halo sira nia knaar too kalan.
\b
\q1 
\v 24 NAI Maromak, Ita Boot nia liman fatin barak teb-tebes!
\q2 Ita Boot halo buat sira nee hotu ho matenek;
\q2 mundu nee nakonu ho buat nebee Ita Boot halo.
\q1 
\v 25 Haree ba, iha tasi boot teb-tebes, luan teb-tebes;
\q2 iha tasi laran iha buat moris kiik no boot,
\q2 barak loos, sura la bele.
\q1 
\v 26 \x + \xo 104:26 \xt Jó (Ayub) 41:1; Salmu 74:14; Isaias 27:1\x*Iha nebaa roo lao baa lao mai;
\q2 iha mos samea boot Leviatán, Ita Boot forma nia atu halimar iha tasi laran.
\b
\q1 
\v 27 Kriatura hotu-hotu laran metin ba Ita Boot
\q2 atu foo ai haan ba sira tuir nia tempu.
\q1 
\v 28 Bainhira Ita Boot foo ba sira,
\q2 sira foti tiha;
\q1 bainhira Ita Boot loke liman,
\q2 sira bosu ho hahaan mesak diak nian.
\q1 
\v 29 Bainhira Ita Boot subar Ita Boot nia oin,
\q2 sira fuan lakon tiha;
\q1 bainhira Ita Boot hasai tiha sira nia iis,
\q2 sira mate hodi fila fali ba rai rahun.
\q1 
\v 30 Bainhira Ita Boot foo Ita Boot nia iis
\q2 mak kriatura sira hetan moris;
\q2 Ita Boot hafoun mundu rai klaran.
\b
\q1 
\v 31 Maromak nia naroman nabilan sei dura nafatin ba nafatin;
\q2 hau hein atu NAI haksolok ho buat nebee Nia kria tiha ona.
\q1 
\v 32 Bainhira Nia hateke ba mundu, rai nakdedar;
\q2 Nia liman kaer kona foho, foho suar sae.
\b
\q1 
\v 33 Iha hau nia moris tomak hau sei hananu ba NAI;
\q2 durante hau sei iha iis, hau sei hananu hahii hau nia Maromak.
\q1 
\v 34 Hau hein katak hau nia liafuan hirak nee bele halo kontenti Nia laran;
\q2 hau haksolok tanba NAI Maromak.
\q1 
\v 35 Hau harohan atu sala nain sira bele lakon husi mundu,
\q2 no ema aat la iha tan.
\q1 Hau hatete ba hau nia aan, hahii NAI Maromak ba.
\b
\q1 Hahii NAI Maromak!
\c 105
\s1 Nai Maromak kaer metin Nia promesa ba Nia povu
\q1 
\v 1 Foo agradese ba NAI Maromak, haboot Nia naran ba;
\q2 foo konhese ba nasaun jentiu sira kona ba saida mak Nia halo tiha ona.
\q1 
\v 2 Hananu ba Nia, kanta hahii ba Nia;
\q2 foo sai buat furak hotu nebee Nia halo.
\q1 
\v 3 Tane aas Nia naran santu;
\q2 imi sira nebee mak buka NAI, haksolok ba.
\q1 
\v 4 Foti matan ba NAI Maromak, hateke ba Nia kbiit;
\q2 buka beibeik Nia oin.
\q1 
\v 5-6 Imi Maromak nia atan Abraão nia jerasaun sira,
\q2 Jacó nia oan sira, Maromak hili ona imi,
\q1 keta haluha buat furak nebee Nia halo tiha ona,
\q2 Nia milagre ho Nia desizaun nebee Nia hatuun nudar Juis.
\b
\q1 
\v 7 Nia mak NAI ita nia Maromak;
\q2 Nia foo justisa ba iha mundu tomak.
\q1 
\v 8 Nia hanoin nafatin Nia promesa too tinan ba tinan;
\q2 buat nebee Nia promete ona, Nia kaer metin nafatin too jerasaun rihun ba rihun.
\q1 
\v 9 \x + \xo 105:9 \xt Jénesis 12:7, 17:8; \xt Jénesis 26:3\x*Nee mak promesa nebee Nia halo ho Abraão,
\q2 juramentu nebee Nia halo ho Isac.
\q1 
\v 10 \x + \xo 105:10 \xt Jénesis 28:13\x*Nia hametin juramentu nee ba Jacó nudar lei ida;
\q2 Nia promesa ba Israel nee vale tinan ba tinan.
\q1 
\v 11 Nia promete dehan, “Hau sei foo rai Kanaán ba o
\q2 hodi sai o nia riku-soin.”
\b
\q1 
\v 12 Fo-foun bei-ala sira nee ema uitoan deit, uitoan teb-tebes;
\q2 sira sei oin foun hela iha rai Kanaán nee.
\q1 
\v 13 Iha tempu nebaa sira lao rai husi nasaun ba nasaun,
\q2 husi liurai ida nia reinu ba liurai seluk nia rain.
\q1 
\v 14 \x + \xo 105:14 \xt Jénesis 20:3-7\x*Bele nunee mos Maromak la husik atu ema hanehan sira;
\q2 Nia defende sira hodi siak liurai sira dehan,
\q1 
\v 15 “Keta book ema nebee Hau hili;
\q2 keta halo aat Hau nia profeta sira.”
\b
\q1 
\v 16 \x + \xo 105:16 \xt Jénesis 41:53-57\x*Depois Maromak hamosu rai hamlaha
\q2 hodi halo aat tiha ai haan hotu-hotu iha rai Kanaán.
\q1 
\v 17 \x + \xo 105:17 \xt Jénesis 37:28, 45:5\x*Nia haruka ema ida baa uluk iha rai Ejitu;
\q2 nee mak José, ninia maun sira faan tiha nia nudar atan.
\q1 
\v 18 \x + \xo 105:18 \xt Jénesis 39:20—40:23\x*Ema hakanek nia ain ho korenti besi;
\q2 sira tau besi kabuar ba iha nia kakorok,
\q1 
\v 19 too buat nebee nia foo sai akontese duni,
\q2 no NAI Maromak nia liafuan hatudu katak nia nee loos.
\q1 
\v 20 \x + \xo 105:20 \xt Jénesis 41:14\x*Too ikus liurai haruka ema hasai José husi dadur laran;
\q2 ukun nain nasaun halo nia livre.
\q1 
\v 21 \x + \xo 105:21 \xt Jénesis 41:39-41\x*Liurai foti nia sai nai ulun iha palasiu,
\q2 atu tau matan ba liurai nia riku-soin hotu,
\q1 
\v 22 atu manda liurai nia liman-ain sira tuir nia hakarak,
\q2 no hanorin matenek ba katuas lia nain sira.
\b
\q1 
\v 23 \x + \xo 105:23 \xt Jénesis 46:6; \xt Jénesis 47:11\x*Hotu tiha Jacó tama ba iha rai Ejitu;
\q2 Israel hela iha ema Ham nia rain nudar estranjeiru.
\q1 
\v 24 \x + \xo 105:24 \xt Ézodu (Keluaran) 1:7-14\x*NAI Maromak halo Nia povu sai buras teb-tebes;
\q2 Nia halo sira forsa liu fali sira nia funu baluk sira.
\q1 
\v 25 Nia halo funu baluk sira nia laran fila atu odi Nia povu,
\q2 atu kombina malu hodi kontra Nia atan sira.
\b
\q1 
\v 26 \x + \xo 105:26 \xt Ézodu (Keluaran) 3:1—4:17\x*Maromak haruka Nia atan Moisés
\q2 hamutuk ho ema ida nebee Nia hili, nee mak Arão.
\q1 
\v 27 Sira nain rua hatudu Maromak nia milagre iha Ham nia rain;
\q2 sira hatudu sai Nia sinal iha povu nia klaran.
\q1 
\v 28 \x + \xo 105:28 \xt Ézodu (Keluaran) 10:21-23\x*Maromak haruka nakukun taka metin rai
\q2 tanba Ejitu oan sira kontra tiha ona Nia liafuan.
\q1 
\v 29 \x + \xo 105:29 \xt Ézodu (Keluaran) 7:17-21\x*Nia halo sira nia bee nakfilak ba raan
\q2 hodi hamate tiha ikan hotu-hotu.
\q1 
\v 30 \x + \xo 105:30 \xt Ézodu (Keluaran) 8:1-6\x*Sira nia rai nakonu tiha ho manduku,
\q2 too tama iha ukun nain sira nia kuartu laran.
\q1 
\v 31 \x + \xo 105:31 \xt Ézodu (Keluaran) 8:20-24; \xt Ézodu (Keluaran) 8:16,17\x*Nia foo orden mak lalar barak mosu mai,
\q2 susuk nakonu tiha sira nia nasaun.
\q1 
\v 32 \x + \xo 105:32 \xt Ézodu (Keluaran) 9:22-25\x*Nia la hatuun udan ba sira nia rain, maibee hatuun fali udan jelu fatuk;
\q2 rai lakan taa ba-mai iha sira nia rain.
\q1 
\v 33 Nia baku tuun tiha sira nia ai uvas ho ai figeira;
\q2 ai huun iha sira nia rain tomak, Nia silu tohar tiha.
\q1 
\v 34 \x + \xo 105:34 \xt Ézodu (Keluaran) 10:12-15\x*Nia foo orden mak gafanhotu mosu mai,
\q2 barak teb-tebes, sura la bele.
\q1 
\v 35 Gafanhotu hirak nee haan ai horis hotu-hotu iha sira nia rain;
\q2 buat nebee moris iha rai leten, gafanhotu haan hotu kedas.
\q1 
\v 36 \x + \xo 105:36 \xt Ézodu (Keluaran) 12:29\x*Nia oho dasa tiha sira nia oan mane boot hotu iha rai nee;
\q2 sira nia oan mane primeiru mate mohu.
\b
\q1 
\v 37 \x + \xo 105:37 \xt Ézodu (Keluaran) 12:33-36\x*Depois Maromak lori Israel oan sira sai husi rai Ejitu;
\q2 sira sai lori ho osan mutin ho osan mean;
\q2 husi Israel nia suku hotu, la iha ema ida mak lao sidi.
\q1 
\v 38 Bainhira sira hakat sai, ema Ejitu sira laran kamaan,
\q2 tanba sira tauk ona ema Israel.
\q1 
\v 39 \x + \xo 105:39 \xt Ézodu (Keluaran) 13:21,22\x*Maromak habelar kalohan hodi taka Nia povu,
\q2 no prepara ahi lakan atu foo naroman iha kalan.
\q1 
\v 40 \x + \xo 105:40 \xt Ézodu (Keluaran) 16:2-15\x*Sira husu naan, Nia haruka manu kiukae barak ba sira;
\q2 Nia hatuun paun husi lalehan, sira haan too bosu.
\q1 
\v 41 \x + \xo 105:41 \xt Ézodu (Keluaran) 17:1-7; Númerus (Bilangan) 20:2-13\x*Nia loke fatuk boot, bee haksoit sai,
\q2 suli iha rai fuik maran hanesan mota.
\q1 
\v 42 Tanba Nia hanoin nafatin Nia promesa santu
\q2 nebee uluk Nia foo ba Nia atan Abraão.
\b
\q1 
\v 43 Nunee Maromak lori sai Nia povu ho haksolok;
\q2 povu nebee Nia hili, Nia halo sira livre ho haklalak ho kontenti.
\q1 
\v 44 \x + \xo 105:44 \xt Josué 11:16-23\x*Nia foo tiha nasaun sira seluk nia rain ba sira;
\q2 buat nebee ema seluk halo too kosar metan suli, sira mak sai nain fali,
\q1 
\v 45 atu nunee sira kaer metin Nia ukun fuan,
\q2 no halo tuir Nia lei.
\b
\q1 Hahii NAI Maromak!
\c 106
\s1 Nai Maromak nia diak ba Nia povu
\q1 
\v 1 \x + \xo 106:1 \xt 1 Krónikas (Tawarikh) 16:34; 2 Krónikas (Tawarikh) 5:13, 7:3; Esdras (Ezra) 3:11; Salmu 100:5, 107:1, 118:1, 136:1; Jeremias 33:11\x*Hahii NAI Maromak!
\b
\q1 Foo agradese ba NAI Maromak, tanba Nia nee diak;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 2 See mak bele foo sai buat boot nebee NAI halo?
\q2 See mak bele hahii lo-loos Nia?
\q1 
\v 3 Ema nebee mak kaer metin justisa,
\q2 ema nebee sempre halo buat nebee loos,
\q2 sira nee hetan ksolok.
\b
\q1 
\v 4 NAI Maromak, bainhira Ita Boot hatudu laran luak ba Ita Boot nia povu, keta haluha hau;
\q2 bainhira Ita Boot salva povu nee, tulun hotu hau ba,
\q1 
\v 5 atu hau bele moris diak hamutuk ho ema sira nebee Ita Boot hili tiha ona,
\q2 atu hau bele haksolok ho Ita Boot nia povu,
\q2 atu hau bele tane aas Ita Boot hamutuk ho Ita Boot nia ema rasik.
\b
\q1 
\v 6 Ami halo tiha ona sala, hanesan mos ami nia bei-ala sira;
\q2 ami halo tiha ona pekadu, ami nia hahalok aat.
\q1 
\v 7 \x + \xo 106:7 \xt Ézodu (Keluaran) 14:10-12\x*Uluk bainhira ami nia bei-ala sira iha rai Ejitu,
\q2 sira la foo folin ba milagre nebee Ita Boot halo;
\q1 sira la hanoin tan domin rohan-laek nebee Ita Boot hatudu fila-fila ba sira;
\q2 sira kontra Maromak Aas Liu iha Tasi Mean.
\q1 
\v 8 Maski nunee Maromak salva sira,
\q2 atu ema bele foti aas Nia naran,
\q2 atu Nia bele hatudu sai Nia kbiit boot.
\q1 
\v 9 \x + \xo 106:9 \xt Ézodu (Keluaran) 14:21-31\x*Nia siak Tasi Mean, tasi maran kedas;
\q2 Nia lori sira liu husi tasi klaran hanesan fali liu iha rai fuik maran.
\q1 
\v 10 Nia salva sira husi funu baluk sira nia liman;
\q2 Nia liberta sira husi inimigu sira nia liman laran.
\q1 
\v 11 Bee halo mout tiha ema nebee kontra sira;
\q2 ema sira nee la iha ida mak moris.
\q1 
\v 12 \x + \xo 106:12 \xt Ézodu (Keluaran) 15:1-21\x*Depois bei-ala sira fiar ba Nia promesa,
\q2 no hananu hahii Nia.
\b
\q1 
\v 13 Maibee lalais deit sira haluha fali buat nebee Maromak halo tiha ona;
\q2 sira lakohi hein tan Nia lia menon.
\q1 
\v 14 \x + \xo 106:14 \xt Númerus (Bilangan) 11:4-34\x*Iha rai fuik, sira kaan teb-tebes atu haan hahaan diak nian;
\q2 iha rai fuik maran sira koko Maromak.
\q1 
\v 15 Nunee Nia foo ba sira buat nebee sira husu,
\q2 maibee Nia mos haruka moras aat ba iha sira nia leet.
\q1 
\v 16 \x + \xo 106:16 \xt Númerus (Bilangan) 16:1-35\x*Iha sira nia akampamentu, sira laran moras ba Moisés ho Arão,
\q2 Arão nee NAI Maromak mak hili sai nai lulik.
\q1 
\v 17 Nunee rai nakloke aan hodi tolan tiha Datan;
\q2 rai taka hakoi tiha Abiram ho nia grupu.
\q1 
\v 18 Ahi lakan sae iha sira nia klaran
\q2 hodi haan mutuk tiha ema aat sira nee.
\b
\q1 
\v 19 \x + \xo 106:19 \xt Ézodu (Keluaran) 32:1-14\x*Iha foho Horeb ami nia bei-ala sira halo estatua karau oan;
\q2 sira adora fali estatua nebee fui husi osan mean.
\q1 
\v 20 Maromak ida nebee kbiit boot sira husik tiha;
\q2 sira troka fali ho estatua karau aman, animal nebee haan duut deit.
\q1 
\v 21 Sira haluha tiha Maromak, sira nia Salvador;
\q2 Maromak nee mak halo buat boot iha rai Ejitu,
\q1 
\v 22 Nia halo milagre iha ema Ham nia rain,
\q2 no halo buat nebee makaas iha Tasi Mean.
\q1 
\v 23 Nee mak Nia dehan, Nia hakarak halo mohu tiha sira.
\q2 Maibee Moisés, ema ida nebee Nia hili tiha ona hamriik iha klaran
\q1 hodi tahan netik Nia hirus ba sira.
\q2 Nunee Maromak la konsege halo mohu sira.
\b
\q1 
\v 24 \x + \xo 106:24 \xt Númerus (Bilangan) 14:1-35\x*Depois bei-ala sira nee lakohi simu rai nebee furak nee;
\q2 sira la fiar ba Nia promesa.
\q1 
\v 25 Sira murmura iha sira nia tenda laran,
\q2 no lakohi rona NAI Maromak.
\q1 
\v 26 Nunee Nia foti Nia liman hodi jura katak,
\q2 Nia sei hamate tiha sira iha rai fuik maran.
\q1 
\v 27 \x + \xo 106:27 \xt Levítiku (Imamat) 26:33\x*Nia sei halo sira nia jerasaun namkari iha nasaun sel-seluk;
\q2 sira sei lao lemo rai iha rai sel-seluk.
\b
\q1 
\v 28 \x + \xo 106:28 \xt Númerus (Bilangan) 25:1-13\x*Sira entrega aan ba estatua Baal iha foho Peor
\q2 hodi haan fali naan sakrifisiu nebee ema foo ba matebian sira.
\q1 
\v 29 Sira nia hahalok nee halo Maromak hirus,
\q2 nunee moras aat mosu iha sira nia klaran.
\q1 
\v 30 Maibee Fineias hamriik hodi tahan netik,
\q2 nee mak moras aat nee para tiha.
\q1 
\v 31 Buat nebee Fineias halo nee, buat diak ida,
\q2 no ema sei la haluha husi jerasaun ba jerasaun.
\b
\q1 
\v 32 \x + \xo 106:32 \xt Númerus (Bilangan) 20:2-13\x*Iha bee Meriba nian, bei-ala sira halo NAI Maromak hirus;
\q2 Moisés hetan terus tanba sira nia hahalok aat nee,
\q1 
\v 33 tanba sira kontra Maromak nia Espiritu,
\q2 nunee Moisés la hatene tuir liafuan nebee sai husi nia ibun laran.
\b
\q1 
\v 34 \x + \xo 106:34 \xt Juis sira 2:1-3, 3:5,6\x*Sira lakohi halo mohu nasaun jentiu sira
\q2 nebee NAI Maromak haruka sira halo mohu,
\q1 
\v 35 maibee sira ba ranxu fali nasaun sira nee
\q2 hodi halo tuir fali sira nia lisan.
\q1 
\v 36 Sira adora fali ema jentiu sira nia estatua;
\q2 ida nee lori sira ba rai kuak.
\q1 
\v 37 \x + \xo 106:37 \xt 2 Liurai sira (Reis, Raja-raja) 17:17\x*Sira oho sira nia oan mane ho oan feto
\q2 nudar sakrifisiu ba maromak falsu.
\q1 
\v 38 \x + \xo 106:38 \xt Númerus (Bilangan) 35:33\x*Sira oho ema nebee la sala;
\q2 sira fakar sira nia oan feto ho oan mane nia raan
\q1 hodi foo ba ema Kanaán nia maromak falsu nudar sakrifisiu.
\q2 Nunee raan nebee fakar nee halo rai nee sai foer tiha.
\q1 
\v 39 Sira hafoer sira nia aan ho buat nebee sira halo;
\q2 sira nia hahalok nee hanesan feto kaben nain nebee halai tuir fali mane seluk.
\b
\q1 
\v 40 \x + \xo 106:40 \xt Juis sira 2:14-18\x*Tanba nee NAI Maromak nia laran nakali ba Nia povu;
\q2 Nia hakribi fali povu nebee Nia hili nudar Nia riku-soin.
\q1 
\v 41 Nia entrega sira ba iha nasaun jentiu sira nia liman laran,
\q2 atu sira nia funu baluk mak ukun fali sira.
\q1 
\v 42 Sira nia inimigu hanehan sira
\q2 hodi ukun sira ho kroat.
\q1 
\v 43 Dala barak Maromak salva sira,
\q2 maibee sira fila kontra fali Nia,
\q2 nunee sira mout dadauk ba iha sira nia sala.
\q1 
\v 44 Maski nunee Nia rona sira nia halerik;
\q2 Nia foo atensaun ba sira iha susar laran.
\q1 
\v 45 Nia hanoin nafatin Nia promesa ba sira;
\q2 Nia la kastigu sira, tanba Nia domin boot teb-tebes.
\q1 
\v 46 Inimigu sira hotu nebee dadur tiha Nia povu,
\q2 Nia halo sira nia laran hanoin fali dadur sira nee.
\b
\q1 
\v 47 \x + \xo 106:47 \xt 1 Krónikas (Tawarikh) 16:35,36\x*NAI ami nia Maromak, salva ami ba;
\q2 halibur fali ami husi nasaun sel-seluk,
\q1 atu ami bele foo agradese ba Ita Boot nia naran santu,
\q2 no haksolok hahii Ita Boot.
\b
\q1 
\v 48 Hahii NAI, Israel nia Maromak,
\q2 nafatin ba nafatin.
\q1 Ema hotu-hotu dehan, “Amen!”
\b
\q1 Hahii NAI Maromak!
\c 107
\s1 Agradese ba Nai Maromak tanba Nia domin rohan-laek
\q1 
\v 1 \x + \xo 107:1 \xt 1 Krónikas (Tawarikh) 16:34; 2 Krónikas (Tawarikh) 5:13, 7:3; Esdras (Ezra) 3:11; Salmu 100:5, 106:1, 118:1, 136:1; Jeremias 33:11\x*Foo agradese ba NAI Maromak tanba Nia nee diak;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 2 Imi sira nebee NAI salva ona, konta imi nia istoria ba;
\q2 Nia hasai tiha ona imi husi funu baluk sira nia liman laran;
\q1 
\v 3 Nia halibur imi fila fali husi nasaun sel-seluk,
\q2 husi lorosae-loromonu, husi tasi feto tasi mane.
\b
\q1 
\v 4 Iha ema balu lao lemo-lemo tiha iha rai fuik maran,
\q2 la hetan dalan ba sidade ida atu hela.
\q1 
\v 5 Sira hamlaha-hamrook;
\q2 sira lakon esperansa ona.
\q1 
\v 6 Iha susar laran, sira halerik ba NAI Maromak;
\q2 Nia salva tiha sira husi susar nee.
\q1 
\v 7 Nia lori sira tuir dalan loos
\q2 too iha sidade ida nebee sira bele hela.
\q1 
\v 8 Sira tenki foo agradese ba NAI tanba Nia domin rohan-laek;
\q2 agradese ba buat furak nebee mak Nia halo ba ita ema.
\q1 
\v 9 Tanba sira nebee hamrook, Nia foo hemu too hamrook lakon;
\q2 sira nebee hamlaha, Nia foo ai haan diak nian ba sira too bosu.
\b
\q1 
\v 10 Iha ema balu dadur tiha, sira tuur hela iha fatin nebee nakukun teb-tebes;
\q2 korenti besi halo sira terus,
\q1 
\v 11 tanba sira kontra tiha ona Maromak nia liafuan,
\q2 no lakohi simu Maromak Aas Liu nia lia menon.
\q1 
\v 12 Nunee Nia hatodan sira ho servisu too kosar metan suli;
\q2 sira atu monu sal-sala no la iha ema ida mak tulun.
\q1 
\v 13 Iha susar laran, sira halerik ba NAI Maromak;
\q2 Nia salva sira husi susar nee.
\q1 
\v 14 Nia lori sira sai husi fatin nakukun liu,
\q2 no hakotu tiha korenti nebee kesi sira.
\q1 
\v 15 Sira tenki foo agradese ba NAI tanba Nia domin rohan-laek;
\q2 agradese ba buat furak nebee mak Nia halo ba ita ema.
\q1 
\v 16 Tanba Nia sobu aat tiha portaun boot nebee halo husi riti;
\q2 Nia taa kotu tiha besi nebee satan portaun.
\b
\q1 
\v 17 Iha ema balu hetan moras tanba sira nia hahalok aat;
\q2 sira hetan terus tanba sira nia pekadu rasik.
\q1 
\v 18 Sira baruk ho hahaan hotu-hotu;
\q2 sira besik too ona iha odamatan mate nian.
\q1 
\v 19 Iha susar laran, sira halerik ba NAI Maromak;
\q2 Nia salva sira husi susar nee.
\q1 
\v 20 Nia lia tuun mak sira hetan kura;
\q2 Nia salva sira husi rai kuak.
\q1 
\v 21 Sira tenki foo agradese ba NAI tanba Nia domin rohan-laek;
\q2 agradese ba buat furak nebee mak Nia halo ba ita ema.
\q1 
\v 22 Sira tenki foo oferta agradesimentu nian,
\q2 no kanta ho haksolok hodi foo sai buat nebee Nia halo.
\b
\q1 
\v 23 Iha ema balu sae roo hodi lao iha tasi laran;
\q2 sira hakur tasi boot hodi halo kontratu.
\q1 
\v 24 Sira haree buat nebee mak NAI Maromak halo,
\q2 buat furak nebee Nia halo iha tasi klean.
\q1 
\v 25 Nia lia tuun, anin boot sai mai
\q2 hodi hiit sae laloran.
\q1 
\v 26 Laloran hirak nee sae too lalehan, tuun too rai klean;
\q2 marineiru sira iha perigu laran, sira tauk teb-tebes.
\q1 
\v 27 Sira oin halai no lao rungu-ranga hanesan ema lanu;
\q2 sira nia neon lakon tiha.
\q1 
\v 28 Iha susar laran, sira halerik ba NAI Maromak;
\q2 Nia hasai sira husi susar nee.
\q1 
\v 29 Nia hapara anin boot,
\q2 no halo laloran hakmatek.
\q1 
\v 30 Sira hotu kontenti tanba buat sira nee sai kalma fali;
\q2 Nia lori sira ba rai nebee mak sira atu baa.
\q1 
\v 31 Sira tenki foo agradese ba NAI tanba Nia domin rohan-laek;
\q2 agradese ba buat furak nebee mak Nia halo ba ita ema.
\q1 
\v 32 Sira tenki foti aas Nia naran iha ema lubuk boot nia klaran,
\q2 no hahii Nia iha nai ulun sira nia leet.
\b
\q1 
\v 33 Maromak halo mota sai tiha rai fuik maran;
\q2 Nia halo bee matan sai fali rai maran dekor.
\q1 
\v 34 Rai nebee bokur sai tiha rai masin,
\q2 tanba ema nebee hela iha fatin nee, sira nia hahalok aat.
\q1 
\v 35 Nia halo rai fuik maran nakfilak ba bee lihun;
\q2 rai maran dekor, Nia halo sai fali bee matan.
\q1 
\v 36 Ema sira nebee hamlaha, Nia lori sira baa moris iha nebaa;
\q2 sira mos harii sidade iha nebaa atu bele hela.
\q1 
\v 37 Sira kari fini iha toos no kuda uvas;
\q2 sira hetan rezultadu barak.
\q1 
\v 38 Nia foo bensaun ba sira, nunee sira aumenta barak;
\q2 sira nia animal mos la menus.
\b
\q1 
\v 39 Depois ema hanehan sira no halo sira susar ho tristi
\q2 hodi hatuun sira no halo sira balu mate.
\q1 
\v 40 Maromak hamoe fali nai ulun hanehan door sira
\q2 hodi halo sira lao lemo rai iha rai fuik nebee la iha dalan.
\q1 
\v 41 Maibee Nia foti sae ema kiak sira husi susar laran,
\q2 no halo sira nia familia aumenta barak hanesan bibi.
\q1 
\v 42 Ema moris loos haree hodi haksolok,
\q2 maibee ema aat hotu-hotu taka sira nia ibun.
\q1 
\v 43 Ema nebee iha matenek sei foo atensaun ba buat sira nee
\q2 hodi medita NAI Maromak nia domin rohan-laek.
\c 108
\s1 Orasaun husu tulun tanba inimigu ataka
\d Salmu David nian.
\b
\q1 
\v 1 Maromak, hau laran metin ba Ita Boot;
\q2 ho hau nia laran tomak, hau sei toka muzika hodi hananu hahii Ita Boot.
\q1 Hau hatete ba hau nia aan, hadeer ba!
\q2 
\v 2 Viola ho viola tali sanulu, hadeer ba!
\q2 Hau sei fanu loro matan.
\q1 
\v 3 NAI Maromak, hau sei foo agradese ba Ita Boot iha nasaun hotu-hotu nia klaran;
\q2 hau sei hananu hahii Ita Boot iha povu sira nia leet.
\q1 
\v 4 Tanba Ita Boot nia domin aas liu lalehan;
\q2 Ita Boot nia lia loos firmi too iha kalohan.
\q1 
\v 5 Maromak, hatudu Ita Boot nia Aan aas liu lalehan;
\q2 halo Ita Boot nia kbiit domina mundu tomak.
\b
\q1 
\v 6 Hodi Ita Boot nia liman loos salva ami no tulun ami ba,
\q2 atu nunee ema nebee Ita Boot hadomi bele hetan salvasaun.
\q1 
\v 7 Maromak lia tuun husi Nia hela fatin dehan,
\q2 “Hau sei manaan!
\q1 Hau sei sukat rai Sikem hodi foo ba Hau nia povu;
\q2 Hau sei fahe rai Sukot ba sira.
\q1 
\v 8 Rai Gileade Hau nian,
\q2 rai Manassés mos Hau nian;
\q1 ema Efraim Hau nia kapaseti,
\q2 ema Judá Hau nia rota liurai.
\q1 
\v 9 Rai Moab Hau nia basia hodi fase liman;
\q2 rai Edom fatin para soe Hau nia sandalias ba;
\q2 Hau haksolok haklalak tanba Hau manaan rai Filístia.”
\b
\q1 
\v 10 Maromak, see loos mak atu lori hau ba iha sidade nebee forti?
\q2 See loos mak atu lori hau ba iha rai Edom?
\q1 
\v 11 Maromak, Ita Boot soe duni ami ka?
\q2 Maromak, Ita Boot lakohi avansa ho ami nia militar sira ka?
\q1 
\v 12 Tulun ami hodi kontra inimigu sira,
\q2 tanba ema kriatura nia ajuda la iha folin.
\q1 
\v 13 Hamutuk ho Maromak ita sei manaan;
\q2 Nia sei sama ita nia inimigu sira.
\c 109
\s1 Ema laran moras halerik ba Nai Maromak
\d Salmu David nian, ba dirijenti koru.
\b
\q1 
\v 1 Hau nia Maromak, hau hahii Ita Boot;
\q2 keta nonook deit,
\q1 
\v 2 tanba ema aat ho ema lohi door loke sira nia ibun hodi kontra hau;
\q2 sira nia ibun koalia lia bosok hasoru hau.
\q1 
\v 3 Sira haleu hau hodi foo sai liafuan odi;
\q2 sira ataka hau maski hau la sala.
\q1 
\v 4 Hau hadomi sira no halo orasaun ba sira,
\q2 maibee sira duun fali hau.
\q1 
\v 5 Hau nia hahalok diak, sira selu fali ho aat;
\q2 hau hadomi sira maibee sira odi fali hau.
\b
\q1 
\v 6 Foti ema aat ruma hodi kontra hau nia inimigu;
\q2 haruka ema ida hamriik iha nia liman loos hodi foo sala ba nia.
\q1 
\v 7 Bainhira juis tesi nia lia, hau husu atu juis hatuun desizaun katak nia sala duni;
\q2 konsidera nia orasaun mos hanesan pekadu ida.
\q1 
\v 8 \x + \xo 109:8 \xt Apostolu sira nia Istoria 1:20\x*Habadak tiha nia vida ba;
\q2 husik ema seluk hadau tiha nia kargu.
\q1 
\v 9 Husik nia oan sira sai oan kiak,
\q2 no nia feen sai faluk tiha.
\q1 
\v 10 Husik nia oan sira lao lemo rai hodi tane liman ba ema seluk;
\q2 husik ema duni sira sai husi sira nia uma nebee naksobu tiha ona.
\q1 
\v 11 Halo nia la bele selu fali nia tusan too osan nain foti tiha nia riku-soin hotu;
\q2 husik ema fuik mai hadau hotu tiha buat nebee nia hetan husi nia kosar been.
\q1 
\v 12 Hau husu atu la iha ema ida halo tan buat diak ba nia,
\q2 ka hanoin nia oan nebee nia husik hela.
\q1 
\v 13 Halo nia jerasaun sira lakon mohu,
\q2 nunee sira nia naran hasai tiha husi jerasaun tuir mai.
\q1 
\v 14 NAI Maromak, hanoin hetan nafatin nia bei-ala sira nia sala ba;
\q2 keta hamoos nia inan nia pekadu.
\q1 
\v 15 Husik sira nia sala hela nafatin iha NAI Maromak nia oin,
\q2 atu nia naran la temi tan iha mundu nee.
\q1 
\v 16 Tanba nia nunka hanoin atu hatudu laran diak ba ema,
\q2 maibee nia halo terus ema kiak ho kbiit-laek sira ho ema nebee lakon esperansa
\q2 hodi oho sira.
\q1 
\v 17 Nia gosta foo sai malisan ba ema;
\q2 husik malisan nee fila fali ba nia.
\q1 Nia lakohi foo bensaun ba ema;
\q2 husik bensaun mos dook tiha husi nia.
\q1 
\v 18 Malisan sai tiha hanesan fali hena nebee nia hatais loro-loron;
\q2 halo malisan tama tiha ona iha nia isin lolon hanesan bee nebee nia hemu;
\q2 halo malisan tama liu ba iha nia ruin hanesan mina nebee nia kose.
\q1 
\v 19 Halo malisan falun nia hanesan ropa nebee nia hatais,
\q2 no sempre kesi metin nia hanesan sintu.
\b
\q1 
\v 20 NAI Maromak, hatuun kastigu hirak nee hodi selu fali ema nebee duun hau;
\q2 foo kastigu nee ba ema nebee mak hatete aat hau.
\q1 
\v 21 Maibee NAI Maromak Kbiit Nain,
\q2 tulun hau, atu ema foti aas Ita Boot nia naran;
\q2 salva hau, tanba Ita Boot nia domin nee diak teb-tebes.
\q1 
\v 22 Tanba hau kiak no kbiit-laek,
\q2 no hau nia fuan kanek too laran.
\q1 
\v 23 Uitoan tan hau lakon hanesan lalatak nebee mohu bainhira loro matan monu;
\q2 hau hanesan gafanhotu nebee anin huu lakon tiha.
\q1 
\v 24 Hau nia ain tuur nakdedar tanba jejun;
\q2 hau nia isin sai krekas, kulit taka ruin.
\q1 
\v 25 \x + \xo 109:25 \xt Mateus 27:39; Marcos 15:29\x*Ema nebee duun hau hamnasa fali hau;
\q2 sira haree hau, sira doko ulun.
\b
\q1 
\v 26 NAI hau nia Maromak, tulun hau ba;
\q2 salva hau tuir Ita Boot nia domin rohan-laek.
\q1 
\v 27 Foo hatene ba sira katak Ita Boot nia liman mak halo ida nee,
\q2 NAI Maromak mak salva hau.
\q1 
\v 28 Sira bele hotar hau,
\q2 maibee Ita Boot sei foo bensaun;
\q1 husik ema nebee ataka hau hetan moe,
\q2 maibee Ita Boot nia atan hau hetan ksolok.
\q1 
\v 29 Husik ema nebee duun hau hetan naran foer
\q2 hodi falun aan ho moe hanesan fali taka hena.
\b
\q1 
\v 30 Hau nia ibun sei agradese ba NAI Maromak;
\q2 hau sei hahii Nia iha ema lubuk boot nia klaran.
\q1 
\v 31 Tanba Maromak defende ema kbiit-laek sira
\q2 hodi salva sira husi ema nebee atu hamonu kastigu mate ba sira.
\c 110
\s1 Nai Maromak foo kbiit ba liurai
\d Salmu David nian.
\b
\q1 
\v 1 \x + \xo 110:1 \xt Mateus 22:44; Marcos 12:36; Lucas 20:42,43; Apostolu sira nia Istoria 2:34,35; 1 Korintu 15:25; Éfezu 1:20-22; Kolose 3:1; Ebreu 1:13, 8:1, 10:12,13\x*NAI Maromak hatete ona ba hau nia nai nunee:
\q2 “Mai tuur iha Hau nia sorin loos,
\q2 too Hau halo o nia inimigu sira taka rabat iha o nia ain okos.”
\b
\q1 
\v 2 NAI Maromak sei haboot o nia kbiit nudar liurai;
\q2 o ukun husi Siaun;
\q2 too o nia inimigu sira mos o sei ukun!
\q1 
\v 3 Iha loron nebee o hamriik iha foho santu atu halo funu,
\q2 o nia tropas sira sei prontu;
\q1 o nia mane joven sira sei mai
\q2 hanesan mahobeen iha dadeer-saan.
\b
\q1 
\v 4 \x + \xo 110:4 \xt Ebreu 5:6, 6:20, 7:17,21\x*NAI Maromak jura tiha ona,
\q2 no sei la muda Nia promesa dehan,
\q2 “O sai nai lulik tinan ba tinan, hanesan Melkizedek.”
\b
\q1 
\v 5 Nai Maromak iha hela o nia sorin loos;
\q2 iha loron nebee Nia fakar sai Nia hirus,
\q2 Nia sei hamohu tiha liurai husi rai sel-seluk.
\q1 
\v 6 Nia sei hamonu kastigu ba nasaun jentiu sira
\q2 hodi halakon tiha ukun nain sira iha mundu tomak,
\q2 too mate isin bar-barak bou hamutuk.
\q1 
\v 7 Liurai sei hemu bee husi mota oan iha dalan ninin,
\q2 nunee nia sei forti fali hodi foti sae nia ulun.
\c 111
\s1 Mai ita hahii Nai Maromak
\q1 
\v 1 Hahii NAI Maromak!
\b
\q1 Hau sei agradese ba NAI Maromak ho hau nia laran tomak
\q2 bainhira hau halibur malu ho ema nebee moris loos.
\q1 
\v 2 NAI Maromak halo buat mesak furak;
\q2 see mak gosta haree buat nebee Maromak halo, sira medita buat sira nee.
\q1 
\v 3 Nia hahalok hatudu sai Nia naran boot ho Nia naroman nabilan;
\q2 Nia sempre halo buat nebee loos too tinan ba tinan.
\q1 
\v 4 Nia halo ita la bele haluha Nia milagre;
\q2 NAI nee laran luak no laran diak.
\q1 
\v 5 Nia foo ai haan ba ema nebee mak hamtauk Nia;
\q2 Nia hanoin nafatin Nia promesa tinan ba tinan.
\q1 
\v 6 Nia hatudu Nia kbiit ba Nia povu
\q2 hodi entrega nasaun seluk nia rai ba sira.
\q1 
\v 7 Nia sempre halo buat nebee loos ho justu;
\q2 Nia lei tomak ita bele konfia.
\q1 
\v 8 Lei sira nee vale too tinan ba tinan;
\q2 ita tenki moris tuir ho fuan tomak ho laran moos.
\q1 
\v 9 Maromak foo liberdade ba Nia povu;
\q2 Nia hatuur Nia promesa ho lei ba sira tinan ba tinan.
\q2 Nia naran santu, Nia makaas teb-tebes.
\q1 
\v 10 \x + \xo 111:10 \xt Jó (Ayub) 28:28; Provérbiu 1:7, 9:10\x*Matenek nia huun mai husi hamtauk NAI Maromak;
\q2 ema hotu nebee halo tuir Nia liafuan sei hatene klean.
\q1 Hahii Nia tinan ba tinan!
\c 112
\s1 Ema diak hetan ksolok
\q1 
\v 1 Hahii NAI Maromak!
\b
\q1 Ema nebee hamtauk NAI Maromak,
\q2 no gosta teb-tebes Nia ukun fuan,
\q2 sira hetan ksolok.
\q1 
\v 2 Sira nia oan sira naran boot iha rai nee;
\q2 ema moris loos nia jerasaun sei hetan bensaun.
\q1 
\v 3 Sira nia uma laran sei iha riku-soin bar-barak;
\q2 sira nia hahalok diak nafatin too tinan ba tinan.
\q1 
\v 4 Maski iha nakukun laran, naroman sempre leno ema nebee laran moos;
\q2 sira nee laran diak, laran luak no moris loos.
\q1 
\v 5 Ema nebee liman nakloke hodi foo empresta osan ba ema seluk,
\q2 no halao sira nia moris ho lo-loos,
\q2 sira hetan diak.
\q1 
\v 6 Tebes duni, ema nebee moris ho laran moos nunka atu nakdoko;
\q2 ema seluk sei hanoin nafatin sira tinan ba tinan.
\q1 
\v 7 Sira sei la tauk bainhira rona notisia nebee la diak;
\q2 sira nia laran metin, sira abut metin iha NAI Maromak.
\q1 
\v 8 Sira nia laran hakmatek, sira sei la tauk;
\q2 too ikus sira haree sira nia inimigu lakon.
\q1 
\v 9 \x + \xo 112:9 \xt 2 Korintu 9:9\x*Sira fahe buat bar-barak ba ema kiak sira;
\q2 sira nia hahalok diak iha nafatin too tinan ba tinan;
\q2 sira sei makaas, no hetan respeitu.
\q1 
\v 10 Haree nunee, ema aat sira sei hirus;
\q2 sira sei ruun nehan too sira lakon mohu tiha;
\q2 ema aat sira nia hakarak sei la vale tiha.
\c 113
\s1 Nai Maromak nia diak
\q1 
\v 1 Hahii NAI Maromak!
\b
\q1 NAI Maromak nia atan sira, hahii Nia ba;
\q2 hahii NAI nia naran.
\q1 
\v 2 Foti aas NAI nia naran
\q2 agora too tinan ba tinan.
\q1 
\v 3 Husi lorosae too loromonu,
\q2 hahii NAI nia naran ba.
\b
\q1 
\v 4 NAI Maromak nee domina nasaun hotu-hotu;
\q2 Nia kbiit aas liu lalehan.
\b
\q1 
\v 5 See mak hanesan ita nia NAI Maromak?
\q2 Nia tuur iha leten aas ba hodi ukun.
\q1 
\v 6 Husi nebaa Nia hakruuk hodi hateke tuun
\q2 mai lalehan ho rai.
\q1 
\v 7 Nia foti sae ema kiak husi rai rahun;
\q2 Nia hasae ema kbiit-laek husi ahu kdesan laran.
\q1 
\v 8 Nia halo sira tuur hamutuk ho liurai oan sira;
\q2 sira tuur hamutuk ho nai ulun sira nebee ukun Nia povu.
\q1 
\v 9 Feto nebee la kous, Maromak halo nia hetan oan,
\q2 nunee nia moris ho haksolok iha nia uma laran.
\b
\q1 Hahii NAI Maromak!
\c 114
\s1 Nai Maromak lori sai Nia povu husi rai Ejitu
\q1 
\v 1 \x + \xo 114:1 \xt Ézodu (Keluaran) 12:51\x*Uluk povu Israel sai husi rai Ejitu;
\q2 Jacó nia jerasaun sai husi rai nebee koalia lian estranjeiru.
\q1 
\v 2 Iha tempu nebaa rai Judá sai Maromak nia fatin santu;
\q2 ema Israel sai povu nebee Nia ukun.
\b
\q1 
\v 3 \x + \xo 114:3 \xt Ézodu (Keluaran) 14:21; \xt Josué 3:16\x*Tasi haree, halai sees tiha;
\q2 mota Jordaun hakiduk fali ba kotuk.
\q1 
\v 4 Foho boot sira haksoit hanesan bibi aman;
\q2 foho kiik sira haksoit hanesan bibi oan.
\q1 
\v 5 Tasi, tansaa mak o halai sees tiha?
\q2 Mota Jordaun, tansaa mak o hakiduk fali ba kotuk?
\q1 
\v 6 Foho boot sira, tansaa mak imi haksoit hanesan bibi aman?
\q2 Foho kiik sira, tansaa mak imi haksoit hanesan bibi oan?
\b
\q1 
\v 7 Mundu tomak, tauk ho nakdedar iha Nai Maromak nia oin ba;
\q2 hamtauk iha Jacó nia Maromak nia oin.
\q1 
\v 8 \x + \xo 114:8 \xt Ézodu (Keluaran) 17:1-7; Númerus (Bilangan) 20:2-13\x*Nia halo fatuk lolon boot sai fali bee lihun;
\q2 fatuk nebee toos sai tiha bee matan.
\c 115
\s1 NAI mesak deit mak Maromak boot
\q1 
\v 1 NAI Maromak, ami laos husu atu Ita Boot tane aas ami nia naran, nee lae!
\q2 Maibee tane aas Ita Boot nia naran,
\q1 tanba Ita Boot nia domin rohan-laek
\q2 no Ita Boot sempre kaer metin Ita Boot nia liafuan.
\b
\q1 
\v 2 Tansaa mak nasaun jentiu sira husu fali dehan,
\q2 “Sira nia Maromak iha nebee?”
\q1 
\v 3 Ami nia Maromak iha lalehan;
\q2 Nia halo saida deit tuir Nia hakarak.
\q1 
\v 4 \x + \xo 115:4 \xt Salmu 135:15-18; Apokalipse 9:20\x*Maibee ema jentiu sira adora fali estatua lulik nebee ema kriatura mak halo
\q2 husi osan mean ho osan mutin.
\q1 
\v 5 Iha ibun maibee la bele koalia;
\q2 iha matan maibee la bele haree.
\q1 
\v 6 Iha tilun maibee la bele rona;
\q2 iha inus maibee la bele horon.
\q1 
\v 7 Iha liman maibee la bele senti;
\q2 iha ain maibee la bele lao;
\q2 sira la bele hasai lian husi sira nia kakorok.
\q1 
\v 8 Ema nebee kria estatua lulik sira nee, sira sai hanesan fali buat nebee sira kria nee;
\q2 ema nebee fiar ba estatua sira nee mos sei sai nunee hotu.
\b
\q1 
\v 9 Israel oan sira, laran metin ba NAI Maromak ba;
\q2 Nia mak tulun imi no defende imi.
\q1 
\v 10 Arão nia jerasaun, laran metin ba NAI Maromak ba;
\q2 Nia mak tulun imi no defende imi.
\q1 
\v 11 Imi sira nebee hamtauk NAI Maromak, laran metin ba NAI Maromak ba;
\q2 Nia mak tulun imi no defende imi.
\b
\q1 
\v 12 NAI hanoin ita, no sei foo bensaun ba ita;
\q2 Nia sei foo bensaun ba povu Israel;
\q2 Nia sei foo bensaun ba Arão nia jerasaun.
\q1 
\v 13 \x + \xo 115:13 \xt Apokalipse 11:18, 19:5\x*Ema kiik ka ema boot nebee hamtauk NAI,
\q2 Nia sei foo bensaun ba sira.
\b
\q1 
\v 14 Hau harohan atu NAI Maromak halo imi sai buras,
\q2 atu imi ho imi nia oan sira aumenta barak.
\q1 
\v 15 NAI foo bensaun ba imi;
\q2 Kriador lalehan ho rai nian foo bensaun ba imi.
\q1 
\v 16 Lalehan nebaa NAI nian,
\q2 maibee mundu nee Nia foo tiha ona ba ema kriatura.
\q1 
\v 17 Laos ema mate mak hahii NAI;
\q2 laos ema nebee mak tuun tiha ona ba fatin lian-laek mak gaba Nia.
\q1 
\v 18 Maibee ita nee mak hahii adora NAI,
\q2 agora too tinan ba tinan.
\b
\q1 Hahii NAI Maromak!
\c 116
\s1 Agradese ba Nai Maromak nia salvasaun
\q1 
\v 1 Hau hadomi NAI Maromak tanba Nia rona hau nia lian;
\q2 Nia rona hau bainhira hau husu tulun.
\q1 
\v 2 Nia see tilun mai hau,
\q2 nunee durante hau sei moris, hau sei harohan nafatin ba Nia.
\q1 
\v 3 Uluk tali mate nian bobar hela hau;
\q2 susar rate nian haleu hau;
\q2 hau tristi ho laran dodok.
\q1 
\v 4 Depois hau bolu NAI Maromak nia naran;
\q2 hau harohan, “NAI, mai salva hau ba!”
\b
\q1 
\v 5 NAI nee laran diak no sempre halo buat nebee loos;
\q2 ita nia Maromak nee laran luak.
\q1 
\v 6 NAI foo mahon ba ema nebee mak matan tomak;
\q2 Nia salva hau bainhira hau la bele halo buat ida.
\q1 
\v 7 Hau hatete ba hau nia aan, “Hakmatek fila fali ba,
\q2 tanba NAI halo buat diak ba o.”
\b
\q1 
\v 8 NAI, Ita Boot hasai tiha ona hau husi mate;
\q2 Ita Boot hamaran tiha hau nia matan been,
\q2 no halo hau nia ain la sidi.
\q1 
\v 9 Nunee hau lao iha NAI nia prezensa,
\q2 iha ema moris sira nia rain.
\q1 
\v 10 \x + \xo 116:10 \xt 2 Korintu 4:13\x*Uluk hau dehan, “Hau terus aat liu.”
\q2 Bele nunee mos hau konfia NAI Maromak.
\q1 
\v 11 Iha konfuzaun laran hau dehan,
\q2 “Ema hotu-hotu bosok-teen.”
\b
\q1 
\v 12 Oinsaa mak hau bele selu fali
\q2 NAI Maromak nia diak tomak nebee Nia halo ona mai hau?
\q1 
\v 13 Hau sei hasae oferta tua hodi agradese tanba NAI salva tiha ona hau;
\q2 hau sei bolu NAI nia naran.
\q1 
\v 14 Ho nunee hau kumpri hau nia promesa ba NAI
\q2 iha Nia povu hotu nia oin.
\b
\q1 
\v 15 NAI Maromak hanoin teb-tebes
\q2 bainhira Nia ema ida mate.
\q1 
\v 16 Tebes duni NAI, hau serbi Ita Boot;
\q2 hau nee Ita Boot nia atan, hanesan mos hau nia inan.
\q2 Ita Boot hasai tiha ona hau husi lasu.
\q1 
\v 17 Hau sei foo oferta agradesimentu nian ba Ita Boot
\q2 hodi bolu Ita Boot nia naran.
\q1 
\v 18 Hau sei kumpri hau nia promesa ba NAI
\q2 iha Nia povu hotu nia oin,
\q1 
\v 19 iha NAI nia uma oin
\q2 iha Jerusalém.
\b
\q1 Hahii NAI Maromak!
\c 117
\s1 Mundu tomak hahii Nai Maromak
\q1 
\v 1 \x + \xo 117:1 \xt Roma 15:11\x*Imi nasaun hotu-hotu, hahii NAI Maromak;
\q2 povu hotu-hotu, haboot Nia naran ba.
\q1 
\v 2 Tanba NAI nia domin mai ita boot teb-tebes,
\q2 no Nia promesa ba ita dura tinan ba tinan.
\b
\q1 Hahii NAI Maromak!
\c 118
\s1 Orasaun agradesimentu tanba manaan funu
\q1 
\v 1 \x + \xo 118:1 \xt 1 Krónikas (Tawarikh) 16:34; 2 Krónikas (Tawarikh) 5:13, 7:3; Esdras (Ezra) 3:11; Salmu 100:5, 106:1, 107:1, 136:1; Jeremias 33:11\x*Foo agradese ba NAI Maromak, tanba Nia nee diak;
\q2 Nia domin dura tinan ba tinan.
\b
\q1 
\v 2 Israel oan sira, dehan sai ba,
\q2 “Nia domin dura tinan ba tinan.”
\q1 
\v 3 Arão nia jerasaun sira, dehan sai ba,
\q2 “Nia domin dura tinan ba tinan.”
\q1 
\v 4 Ema nebee hamtauk NAI Maromak, dehan sai ba,
\q2 “Nia domin dura tinan ba tinan.”
\b
\q1 
\v 5 Bainhira susar hanehan hau, hau halerik ba NAI Maromak;
\q2 Nia lori tiha hau ba iha rai luan.
\q1 
\v 6 \x + \xo 118:6 \xt Ebreu 13:6\x*NAI hamutuk ho hau, nunee hau la tauk ida.
\q2 Ema mundu nee bele halo saida ba hau?
\q1 
\v 7 NAI hamutuk ho hau; Nia mak tulun hau;
\q2 hau sei haree hau nia inimigu sira lakon.
\q1 
\v 8 Diak liu hamahon aan iha NAI
\q2 duke tau laran ba ema mundu nee.
\q1 
\v 9 Diak liu hamahon aan iha NAI
\q2 duke tau laran ba ukun nain sira.
\b
\q1 
\v 10 Uluk nasaun jentiu hotu-hotu mai serku hau,
\q2 maibee hodi NAI nia naran, hau baku tuun tiha sira.
\q1 
\v 11 Sira serku hau husi sor-sorin,
\q2 maibee hodi NAI nia naran, hau baku tuun tiha sira.
\q1 
\v 12 Sira hobur hau hanesan bani,
\q2 maibee ahi haan sira lalais hanesan fali ahi haan ai tarak;
\q2 hodi NAI nia naran hau baku tuun tiha sira.
\q1 
\v 13 Ema dudu hau ba kotuk, hau besik atu monu,
\q2 maibee NAI tulun tiha hau.
\q1 
\v 14 \x + \xo 118:14 \xt Ézodu (Keluaran) 15:2; Isaias 12:2\x*NAI mak hau nia forsa; hau hananu ba Nia;
\q2 Nia sai tiha ona hau nia Salvador.
\q1 
\v 15 Ema moris loos haksolok iha sira nia tenda laran tanba sira manaan;
\q2 sira haklalak dehan, “NAI nia liman loos halo ona buat boot!
\q1 
\v 16 NAI foti aas tiha ona Nia liman loos;
\q2 NAI nia liman loos halo ona buat boot!”
\q1 
\v 17 Hau sei la mate maibee moris,
\q2 no hau sei foo sai buat nebee mak NAI halo tiha ona.
\q1 
\v 18 NAI foo ona kastigu todan mai hau,
\q2 maibee Nia la entrega hau ba mate.
\b
\q1 
\v 19 Loke portaun moris loos nian mai hau,
\q2 atu hau bele tama ba laran hodi foo agradese ba NAI Maromak.
\q1 
\v 20 Ida nee mak NAI nia portaun;
\q2 ema nebee moris loos sei tama husi nee.
\q1 
\v 21 Hau foo agradese ba Ita Boot, tanba Ita Boot rona ona hau;
\q2 Ita Boot sai tiha ona hau nia Salvador.
\b
\q1 
\v 22 \x + \xo 118:22 \xt Lucas 20:17; Apostolu sira nia Istoria 4:11; 1 Pedro 2:7\x*\x + \xo 118:22 \xt Mateus 21:42; Marcos 12:10,11\x*Iha fatuk ida nebee badaen fatuk sira lakohi uza,
\q2 maibee agora fatuk nee mak sai fali fatuk nebee prinsipal.
\q1 
\v 23 NAI Maromak rasik mak hili fatuk nee;
\q2 ita haree ba furak teb-tebes.
\q1 
\v 24 Ohin loron mak NAI Maromak halo nunee;
\q2 mai ita haksolok ho kontenti iha loron ida nee.
\b
\q1 
\v 25 \x + \xo 118:25 \xt Mateus 21:9; Marcos 11:9; João 12:13\x*NAI Maromak, favor salva ami!
\q2 NAI, foo rezultadu diak ba ami nia servisu.
\q1 
\v 26 \x + \xo 118:26 \xt Mateus 21:9, 23:39; Marcos 11:9; Lucas 13:35, 19:38; João 12:13\x*NAI foo bensaun ba ema ida nebee mai lori NAI nia naran;
\q2 husi NAI nia uma ami foo bensaun ba imi.
\q1 
\v 27 NAI mak Maromak;
\q2 Nia foo tiha ona Nia naroman hodi leno ita.
\q1 Kaer ramus tahan iha liman laran ba
\q2 hodi halo prosisaun too iha altar.
\b
\q1 
\v 28 Ita Boot mak hau nia Maromak, hau sei hahii Ita Boot;
\q2 Ita Boot mak hau nia Maromak, hau sei foti aas Ita Boot nia naran.
\b
\q1 
\v 29 Foo agradese ba NAI Maromak, tanba Nia nee diak;
\q2 Nia domin dura tinan ba tinan.
\c 119
\s1 Nai Maromak nia lei
\b
\q1 
\v 1 Ema nebee moris livre husi sala,
\q2 no lao tuir NAI Maromak nia lei, sira hetan bensaun.
\q1 
\v 2 Ema nebee kaer metin Nia mandamentu,
\q2 no buka Nia ho laran tomak, sira hetan bensaun.
\q1 
\v 3 Sira la halo sala;
\q2 sira lao tuir Nia dalan.
\q1 
\v 4 NAI, Ita Boot hatuur tiha ona regra
\q2 atu ami halo tuir tomak.
\q1 
\v 5 Hau hakarak teb-tebes atu iha hau nia moris tomak,
\q2 hau kaer metin Ita Boot nia lei.
\q1 
\v 6 Nunee hau sei la moe leet
\q2 bainhira hau fihir metin Ita Boot nia ukun fuan hotu-hotu.
\q1 
\v 7 Ita Boot nia regulamentu loos; hau aprende dadauk
\q2 hodi hahii Ita Boot ho laran moos.
\q1 
\v 8 Hau sei halo tuir Ita Boot nia lei;
\q2 keta husik hau mesak.
\b
\q1 
\v 9 Oinsaa mak joven ida bele moris loos nafatin?
\q2 Nia presiza moris tuir Ita Boot nia liafuan.
\q1 
\v 10 Hau buka Ita Boot ho hau nia laran tomak;
\q2 keta husik hau lao sees fali husi Ita Boot nia ukun fuan.
\q1 
\v 11 Hau rai metin Ita Boot nia liafuan iha hau nia laran
\q2 atu hau la bele halo sala hasoru Ita Boot.
\q1 
\v 12 NAI Maromak, hau hahii Ita Boot;
\q2 hanorin Ita Boot nia lei mai hau.
\q1 
\v 13 Regulamentu hotu-hotu nebee Ita Boot nia ibun hatete sai,
\q2 hau sei konta sai.
\q1 
\v 14 Hau kontenti halo tuir Ita Boot nia mandamentu
\q2 hanesan fali ema kontenti ho nia riku-soin boot.
\q1 
\v 15 Hau medita Ita Boot nia regra,
\q2 no fihir metin Ita Boot nia dalan.
\q1 
\v 16 Hau haksolok teb-tebes ho Ita Boot nia regulamentu;
\q2 hau sei la haluha Ita Boot nia liafuan.
\b
\q1 
\v 17 Halo diak ba Ita Boot nia atan hau,
\q2 atu hau bele moris hodi halo tuir Ita Boot nia liafuan.
\q1 
\v 18 Loke hau nia matan atu hau bele haree
\q2 buat furak iha Ita Boot nia lei.
\q1 
\v 19 Hau ema lao rai iha mundu nee;
\q2 keta subar Ita Boot nia ukun fuan mai hau.
\q1 
\v 20 Loron-kalan hau hamlaha-hamrook
\q2 ba Ita Boot nia regulamentu.
\q1 
\v 21 Ita Boot siak ema nebee foti aan;
\q2 see mak lao sees husi Ita Boot nia ukun fuan, sira hetan malisan.
\q1 
\v 22 Hasai tiha liafuan insulta no liafuan aat nebee sira hatete mai hau,
\q2 tanba hau kaer metin Ita Boot nia mandamentu.
\q1 
\v 23 Maski nai ulun sira tuur hodi kombina malu hasoru hau,
\q2 maibee Ita Boot nia atan hau sei medita Ita Boot nia lei.
\q1 
\v 24 Ita Boot nia mandamentu mak hau nia ksolok;
\q2 mandamentu nee mak hau nia matadalan.
\b
\q1 
\v 25 Hau tuur hakdasak hela iha rai rahun;
\q2 hodi Ita Boot nia liafuan hafoun fali hau nia moris ba.
\q1 
\v 26 Hau nia lalaok moris nian hau konta tiha ona ba Ita Boot, no Ita Boot hataan;
\q2 hanorin Ita Boot nia lei mai hau.
\q1 
\v 27 Halo hau kompriende Ita Boot nia regra nia lalaok oinsaa,
\q2 atu hau bele medita buat furak nebee Ita Boot halo.
\q1 
\v 28 Hau tristi ho laran susar;
\q2 hodi Ita Boot nia liafuan haforsa hau ba.
\q1 
\v 29 Hadook hau husi dalan bosok nian;
\q2 hanoin hau, hanorin Ita Boot nia lei mai hau.
\q1 
\v 30 Hau hili tiha ona dalan loos nian;
\q2 hau foo aan tomak hodi halo tuir Ita Boot nia regulamentu.
\q1 
\v 31 NAI Maromak, hau kaer metin hela Ita Boot nia mandamentu;
\q2 keta husik hau moe leet.
\q1 
\v 32 Hau duni tuir Ita Boot nia ukun fuan,
\q2 tanba Ita Boot halo hau kompriende klean.
\b
\q1 
\v 33 NAI Maromak, hanorin hau kona ba Ita Boot nia lei nia lalaok,
\q2 atu hau bele lao tuir too rohan.
\q1 
\v 34 Halo hau kompriende, nunee hau sei kaer metin Ita Boot nia lei
\q2 hodi halo tuir ho laran tomak.
\q1 
\v 35 Tulun hau atu moris tuir Ita Boot nia ukun fuan,
\q2 tanba ida nee foo ksolok mai hau.
\q1 
\v 36 Halo hau nia laran ba deit Ita Boot nia mandamentu,
\q2 laos ba riku-soin.
\q1 
\v 37 Hasees tiha hau nia matan husi buat nebee la iha folin;
\q2 hodi Ita Boot nia liafuan hafoun fali hau nia moris ba.
\q1 
\v 38 Halo tuir Ita Boot nia promesa ba Ita Boot nia atan hau;
\q2 promesa nee foo ba ema nebee hamtauk Ita Boot.
\q1 
\v 39 Ema nia liafuan insulta halo hau laran todan atu rona; hasai tiha ba,
\q2 tanba Ita Boot nia regra diak.
\q1 
\v 40 Hau hakarak teb-tebes halo tuir Ita Boot nia regra;
\q2 hafoun fali hau nia moris tanba Ita Boot nee diak.
\b
\q1 
\v 41 NAI Maromak, hau husu atu Ita Boot nia domin rohan-laek mai too iha hau;
\q2 salva hau tuir Ita Boot nia promesa.
\q1 
\v 42 Nunee hau bele hataan ema nebee mak hatete aat hau,
\q2 tanba hau kaer metin Ita Boot nia liafuan.
\q1 
\v 43 Keta hasai lia loos husi hau nia ibun,
\q2 tanba hau laran metin ba ita Boot nia regulamentu.
\q1 
\v 44 Hau sei halo tuir Ita Boot nia lei beibeik,
\q2 too tinan ba tinan.
\q1 
\v 45 Hau sei lao ho livre,
\q2 tanba hau buka Ita Boot nia regra.
\q1 
\v 46 Hau sei koalia kona ba Ita Boot nia mandamentu iha liurai sira nia oin;
\q2 hau sei la moe.
\q1 
\v 47 Hau haksolok teb-tebes ho Ita Boot nia ukun fuan,
\q2 tanba hau nia laran monu ba ukun fuan sira nee.
\q1 
\v 48 Hau nia laran monu, nunee hau tane aas ita Boot nia ukun fuan sira nee;
\q2 hau medita Ita Boot nia lei.
\b
\q1 
\v 49 Hanoin nafatin Ita Boot nia liafuan ba Ita Boot nia atan hau,
\q2 tanba liafuan nee foo esperansa mai hau.
\q1 
\v 50 Buat nebee konsola hau iha terus laran mak nee:
\q2 Ita Boot nia promesa hafoun fali hau nia moris.
\q1 
\v 51 Ema foti aan sira sempre hatuun hau,
\q2 maibee hau la lao sees husi Ita Boot nia lei.
\q1 
\v 52 NAI Maromak, hau hanoin nafatin regulamentu nebee Ita Boot foo hori uluk liu;
\q2 regulamentu nee halo hau nia laran hakmatek.
\q1 
\v 53 Bainhira ema aat fila kotuk ba Ita Boot nia lei,
\q2 hau nia laran nakali.
\q1 
\v 54 Hau hela iha nebee deit,
\q2 hau hananu kona ba Ita Boot nia lei.
\q1 
\v 55 NAI Maromak, iha kalan hau hanoin Ita Boot nia naran;
\q2 hau kaer metin Ita Boot nia lei.
\q1 
\v 56 Hau sempre halo tuir Ita Boot nia regra;
\q2 ida nee mak hau nia lalaok moris.
\b
\q1 
\v 57 NAI Maromak, hau nia riku-soin mak Ita Boot;
\q2 hau promete tiha ona atu halo tuir Ita Boot nia liafuan.
\q1 
\v 58 Ho laran tomak hau husu atu Ita Boot haree hau diak;
\q2 hanoin hau tuir Ita Boot nia promesa.
\q1 
\v 59 Hau tetu hau nia hahalok;
\q2 hau fila hodi hakat tuir Ita Boot nia mandamentu haruka.
\q1 
\v 60 Hau sei halo tuir kedas Ita Boot nia ukun fuan;
\q2 hau sei la demora.
\q1 
\v 61 Ema aat sira nia talin kesi metin hau;
\q2 bele nunee mos hau sei la haluha Ita Boot nia lei.
\q1 
\v 62 Iha kalan boot hau hadeer hodi foo agradese ba Ita Boot,
\q2 tanba Ita Boot nia regulamentu nee loos.
\q1 
\v 63 Hau sai belun ba ema hotu nebee mak hamtauk Ita Boot,
\q2 ba ema nebee mak kaer metin Ita Boot nia regra.
\q1 
\v 64 NAI Maromak, mundu nee nakonu ho Ita Boot nia domin rohan-laek;
\q2 hanorin Ita Boot nia lei mai hau.
\b
\q1 
\v 65 NAI Maromak, Ita Boot halo ona buat diak ba Ita Boot nia atan hau
\q2 tuir Ita Boot nia lia fuan.
\q1 
\v 66 Hanorin hau atu hau bele matenek hodi foti desizaun ho loos,
\q2 tanba hau fiar ba Ita Boot nia ukun fuan.
\q1 
\v 67 Uluk hau lao sala dalan, Ita Boot halo hau terus,
\q2 maibee agora hau kaer metin Ita Boot nia liafuan.
\q1 
\v 68 Ita Boot nee diak, no buat nebee Ita Boot halo mos diak;
\q2 hanorin Ita Boot nia lei mai hau.
\q1 
\v 69 Ema foti aan sira bosok hodi hafoer hau nia naran,
\q2 maibee ho laran tomak hau kumpri ita Boot nia regra.
\q1 
\v 70 Sira nia fuan toos,
\q2 maibee hau haksolok teb-tebes ho Ita Boot nia lei.
\q1 
\v 71 Uluk Ita Boot halo hau terus, nee diak ba hau
\q2 atu hau bele aprende Ita Boot nia lei.
\q1 
\v 72 Lei nebee sai husi Ita Boot nia ibun nee diak ba hau
\q2 liu fali osan mean osan mutin rihun ba rihun.
\b
\q1 
\v 73 Ita Boot nia liman mak kria hau no forma hau;
\q2 loke hau nia neon atu hau aprende Ita Boot nia ukun fuan.
\q1 
\v 74 Ema sira nebee hamtauk Ita Boot haksolok bainhira sira haree hau,
\q2 tanba hau laran metin ba Ita Boot nia liafuan.
\q1 
\v 75 NAI Maromak, hau hatene Ita Boot sempre tesi lia ho lo-loos;
\q2 uluk Ita Boot halo hau terus, tanba Ita Boot sempre hakarak atu hau sai diak.
\q1 
\v 76 Hau husu atu Ita Boot nia domin rohan-laek bele halo hau nia laran hakmatek,
\q2 hanesan Ita Boot promete ona ba Ita Boot nia atan hau.
\q1 
\v 77 Hatudu Ita Boot nia laran luak mai hau atu hau bele moris,
\q2 tanba Ita Boot nia lei halo haksolok hau nia laran.
\q1 
\v 78 Halo ema foti aan sira moe leet tanba sira duun matak hau;
\q2 hau medita hela Ita Boot nia regra.
\q1 
\v 79 Hau harohan atu ema sira nebee hamtauk Ita Boot, hakbesik mai hau,
\q2 atu sira bele kompriende Ita Boot nia mandamentu.
\q1 
\v 80 Tulun hau atu halo tuir Ita Boot nia lei ho laran moos,
\q2 atu nunee hau la bele moe leet.
\b
\q1 
\v 81 Hau hein Ita Boot nia salvasaun too fraku ona,
\q2 maibee hau laran metin ba Ita Boot nia liafuan.
\q1 
\v 82 Hau nia matan kole ona hodi buka Ita Boot nia promesa;
\q2 hau dehan, “Bainhira loos mak Ita Boot atu foo konsola hau?”
\q1 
\v 83 Hau hanesan tua fatin nebee kuak tiha ona;
\q2 bele nunee mos hau la haluha Ita Boot nia lei.
\q1 
\v 84 Ita Boot nia atan hau tenki hein too bainhira tan?
\q2 Bainhira loos mak Ita Boot kastigu ema nebee halo terus hau?
\q1 
\v 85 Ema foti aan sira kee rai kuak atu hamonu hau;
\q2 hahalok nee kontra Ita Boot nia lei.
\q1 
\v 86 Ita Boot nia ukun fuan hotu-hotu ema bele konfia;
\q2 tulun hau tanba ema halo terus hau maski hau la sala.
\q1 
\v 87 Sira besik atu halakon hau nia vida husi mundu nee,
\q2 maibee hau la husik Ita Boot nia regra.
\q1 
\v 88 Hodi Ita Boot nia domin rohan-laek hafoun fali hau nia moris ba,
\q2 atu hau bele kaer metin mandamentu nebee sai husi Ita Boot nia ibun.
\b
\q1 
\v 89 NAI Maromak, Ita Boot nia liafuan dura nafatin ba nafatin;
\q2 liafuan nee firmi iha lalehan.
\q1 
\v 90 Ita Boot kaer metin Ita Boot nia liafuan husi jerasaun ba jerasaun;
\q2 Ita Boot mak harii mundu nee, nunee mundu iha nafatin.
\q1 
\v 91 Buat hirak nee hotu dura too ohin loron
\q2 tanba hotu-hotu tuir Ita Boot nia orden.
\q1 
\v 92 Se karik hau la haksolok ho Ita Boot nia lei,
\q2 entaun iha momentu hau hetan terus, hau mate tiha ona.
\q1 
\v 93 Hau nunka atu haluha Ita Boot nia regra,
\q2 tanba liu husi regra sira nee mak ita Boot hafoun hau nia moris.
\q1 
\v 94 Hau Ita Boot nian, salva hau ba,
\q2 tanba hau buka Ita Boot nia regra.
\q1 
\v 95 Ema aat sira hein hela atu halakon hau nia vida,
\q2 maibee hau sei reflete Ita Boot nia regra.
\q1 
\v 96 Hau haree buat hotu-hotu iha rohan,
\q2 maibee Ita Boot nia ukun fuan la iha rohan.
\b
\q1 
\v 97 Hau gosta teb-tebes Ita Boot nia lei;
\q2 hau medita lei nee iha loron tomak.
\q1 
\v 98 Ita Boot nia ukun fuan sempre hamutuk ho hau,
\q2 halo hau matenek liu hau nia inimigu sira.
\q1 
\v 99 Hau kompriende liu fali hau nia mestri sira,
\q2 tanba hau medita Ita Boot nia mandamentu.
\q1 
\v 100 Hau kompriende klean liu fali ferik-katuas sira,
\q2 tanba hau halo tuir Ita Boot nia regra.
\q1 
\v 101 Hau kuidadu hau nia aan husi dalan aat saida deit,
\q2 atu nunee hau bele halo tuir Ita Boot nia liafuan.
\q1 
\v 102 Hau nunka lao sees husi Ita Boot nia regulamentu,
\q2 tanba Ita Boot rasik mak hanorin hau.
\q1 
\v 103 Ita Boot nia liafuan midar tebes mai hau,
\q2 midar liu bani been iha hau nia ibun.
\q1 
\v 104 Hau hetan matenek husi Ita Boot nia regra;
\q2 tanba nee hau hakribi hahalok aat saida deit.
\b
\q1 
\v 105 Ita Boot nia liafuan foo naroman atu hau bele lao ba oin;
\q2 liafuan nee ahi oan hodi leno hau nia dalan.
\q1 
\v 106 Ita Boot nia regulamentu loos hotu, hau jura tiha ona atu halo tuir,
\q2 no hau sei kumpri juramentu nee.
\q1 
\v 107 NAI Maromak, hau terus liu ona;
\q2 hodi Ita Boot nia liafuan hafoun fali hau nia moris ba.
\q1 
\v 108 Hau hasae orasaun agradesimentu nian ba Ita Boot nudar oferta ida; NAI, simu ba
\q2 hodi hanorin Ita Boot nia regulamentu mai hau.
\q1 
\v 109 Maski dala barak hau iha perigu laran,
\q2 hau sei la haluha Ita Boot nia lei.
\q1 
\v 110 Ema aat sira tau ona lasu mai hau,
\q2 maibee hau la lao sees husi Ita Boot nia regra.
\q1 
\v 111 Ita Boot nia mandamentu mak hau nia riku-soin tinan ba tinan,
\q2 no halo hau nia laran haksolok.
\q1 
\v 112 Hau foo laran hodi halo tuir Ita Boot nia lei
\q2 agora too rohan.
\b
\q1 
\v 113 Hau odi ema nebee laran ru-rua,
\q2 maibee hau gosta teb-tebes Ita Boot nia lei.
\q1 
\v 114 Ita Boot mak hau nia subar fatin; Ita Boot mak defende hau;
\q2 hau tau fiar ba Ita Boot nia liafuan.
\q1 
\v 115 Imi ema aat sira, dook tiha husi hau,
\q2 atu hau bele halo tuir hau nia Maromak nia ukun fuan.
\q1 
\v 116 Tane hau tuir Ita Boot nia promesa, atu nunee hau bele moris;
\q2 hau laran metin ba Ita Boot, keta husik hau moe leet.
\q1 
\v 117 Tulun hau mak hau sei hetan salvasaun;
\q2 nunee hau sei foo laran beibeik ba Ita Boot nia lei.
\q1 
\v 118 Ita Boot la simu ema sira nebee lao sees husi Ita Boot nia lei;
\q2 sira lohi tuun lohi sae mos la iha folin.
\q1 
\v 119 Ita Boot haree ema aat iha mundu nee hanesan lixu;
\q2 tanba nee hau gosta teb-tebes Ita Boot nia mandamentu.
\q1 
\v 120 Hau nia isin nakdedar tanba hau tauk Ita Boot;
\q2 hau tauk Ita Boot nia justisa.
\b
\q1 
\v 121 Hau halo tiha ona buat nebee loos ho justu;
\q2 la bele husik hela hau iha hanehan door sira nia liman laran.
\q1 
\v 122 Kuidadu hau ata nia moris;
\q2 keta husik ema foti aan sira hanehan hau.
\q1 
\v 123 Hau nia matan kole ona tanba hein hela Ita Boot atu salva hau
\q2 tuir Ita Boot promete tiha ona.
\q1 
\v 124 Halo diak ba Ita Boot nia atan hau, tuir Ita Boot nia domin rohan-laek;
\q2 hanorin Ita Boot nia lei mai hau.
\q1 
\v 125 Hau nee Ita Boot nia atan, halo hau kompriende,
\q2 atu hau hatene Ita Boot nia mandamentu.
\q1 
\v 126 NAI Maromak, agora mak tempu ba Ita Boot atu hamriik,
\q2 tanba ema la halo tuir tiha ona Ita Boot nia lei.
\q1 
\v 127 Hau gosta Ita Boot nia ukun fuan
\q2 liu fali osan mean, liu fali osan mean diak nian.
\q1 
\v 128 Hau haree Ita Boot nia regra hotu-hotu loos;
\q2 tanba nee hau hakribi hahalok aat saida deit.
\b
\q1 
\v 129 Ita Boot nia mandamentu furak;
\q2 tanba nee hau halo tuir.
\q1 
\v 130 Ita Boot nia liafuan nakloke hodi foo naroman,
\q2 halo ema matan tomak sira kompriende.
\q1 
\v 131 Hau hamrook teb-tebes ba Ita Boot nia ukun fuan,
\q2 hanesan ema nebee hamrook too kakorok maran.
\q1 
\v 132 Fila mai hau hodi hanoin hau,
\q2 hanesan Ita Boot hanoin ema hotu nebee hadomi Ita Boot.
\q1 
\v 133 Hatudu dalan mai hau atu hau bele lao tuir Ita Boot nia liafuan;
\q2 keta husik buat aat ukun hau.
\q1 
\v 134 Salva hau husi ema nebee hanehan hau,
\q2 atu hau bele halo tuir Ita Boot nia regra.
\q1 
\v 135 Halo Ita Boot nia oin leno Ita Boot nia atan hau;
\q2 hanorin Ita Boot nia lei mai hau.
\q1 
\v 136 Hau nia matan been suli hanesan bee mota nian,
\q2 tanba ema la halo tuir Ita Boot nia lei.
\b
\q1 
\v 137 NAI Maromak, Ita Boot sempre halo buat nebee loos;
\q2 Ita Boot nia regulamentu loos hotu.
\q1 
\v 138 Mandamentu nebee Ita Boot hatuur nee loos;
\q2 ema bele konfia.
\q1 
\v 139 Hau nia laran nakali
\q2 tanba hau nia inimigu sira la interese Ita Boot nia liafuan.
\q1 
\v 140 Promesa nebee Ita Boot halo nunka falha;
\q2 nee mak Ita Boot nia atan hau gosta teb-tebes.
\q1 
\v 141 Hau nee kiik no ema haree hau la iha folin,
\q2 maibee hau la haluha Ita Boot nia regra.
\q1 
\v 142 Ita Boot sempre halo buat nebee loos nafatin ba nafatin;
\q2 Ita Boot nia lei sempre loos.
\q1 
\v 143 Susar ho terus iha hela hau nia leten,
\q2 maibee hau haksolok ho Ita Boot nia ukun fuan.
\q1 
\v 144 Ita Boot nia mandamentu loos nafatin ba nafatin;
\q2 halo hau kompriende ba, atu hau bele moris.
\b
\q1 
\v 145 NAI Maromak, ho laran tomak hau halerik husu tulun, hataan hau ba;
\q2 hau sei halo tuir Ita Boot nia lei.
\q1 
\v 146 Hau hasae lia ba Ita Boot, salva hau ba,
\q2 atu hau bele kaer metin Ita Boot nia mandamentu.
\q1 
\v 147 Hau hadeer iha dadeer-saan nakukun hodi halerik husu tulun;
\q2 hau laran metin ba Ita Boot nia liafuan.
\q1 
\v 148 Hau nia matan loke nafatin iha kalan tomak,
\q2 atu hau bele medita Ita Boot nia promesa.
\q1 
\v 149 Hodi Ita Boot nia domin rohan-laek rona hau nia lian ba;
\q2 NAI Maromak, hodi Ita boot nia justisa hafoun fali hau nia moris ba.
\q1 
\v 150 Ema sira nebee duni tuir hau ho hanoin aat, sira besik dadauk hau;
\q2 sira nee dook husi Ita Boot nia lei.
\q1 
\v 151 Maibee NAI, Ita Boot besik hela hau;
\q2 Ita Boot nia ukun fuan hotu-hotu loos.
\q1 
\v 152 Husi kiik kedas hau aprende Ita Boot nia mandamentu;
\q2 husi nebaa hau kompriende katak, Ita Boot hatuur mandamentu nee atu dura tinan ba tinan.
\b
\q1 
\v 153 Haree ba, hau terus hela, hasai hau husi terus laran nee,
\q2 tanba hau la haluha Ita Boot nia lei.
\q1 
\v 154 Ema duun hela hau, defende hau hodi salva hau ba;
\q2 hafoun fali hau nia moris tuir Ita Boot nia promesa.
\q1 
\v 155 Salvasaun dook husi ema aat sira,
\q2 tanba sira la buka Ita Boot nia lei.
\q1 
\v 156 NAI Maromak, Ita Boot laran luak teb-tebes;
\q2 hodi Ita Boot nia regulamentu hafoun fali hau nia moris ba.
\q1 
\v 157 Iha funu baluk barak mak halo terus hau,
\q2 maibee hau nunka lao sees husi Ita Boot nia mandamentu.
\q1 
\v 158 Hau haree traidor sira, hau hakribi fali,
\q2 tanba sira la kaer metin Ita Boot nia liafuan.
\q1 
\v 159 Haree ba, hau gosta teb-tebes Ita Boot nia regra;
\q2 NAI Maromak, hodi Ita Boot nia domin rohan-laek hafoun fali hau nia moris ba.
\q1 
\v 160 Ita Boot nia liafuan loos hotu;
\q2 Ita Boot nia regulamentu hotu-hotu loos no dura nafatin ba nafatin.
\b
\q1 
\v 161 Nai ulun sira halo terus hau maski hau la sala,
\q2 maibee hau nia laran tauk ho nakdedar deit ba Ita Boot nia liafuan.
\q1 
\v 162 Hau haksolok ho Ita Boot nia liafuan
\q2 hanesan ema nebee hetan riku-soin boot.
\q1 
\v 163 Hau la simu lia bosok, hau hakribi liu,
\q2 maibee hau gosta teb-tebes Ita Boot nia lei.
\q1 
\v 164 Hau loro-loron hahii Ita Boot dala hitu,
\q2 tanba Ita Boot nia regulamentu loos.
\q1 
\v 165 Ema nebee gosta Ita Boot nia lei, sira hetan pas no hakmatek nebee boot;
\q2 la iha buat ida mak halo sira sidi.
\q1 
\v 166 NAI Maromak, hau hein hela Ita Boot atu salva hau;
\q2 hau moris tuir Ita Boot nia ukun fuan.
\q1 
\v 167 Hau halo tuir Ita Boot nia mandamentu,
\q2 tanba hau gosta teb-tebes.
\q1 
\v 168 Hau halo tuir Ita Boot nia regra ho mandamentu,
\q2 tanba Ita Boot hatene hotu hau nia lalaok moris.
\b
\q1 
\v 169 NAI Maromak, simu hau nia lia halerik ba;
\q2 hodi Ita Boot nia liafuan halo hau kompriende.
\q1 
\v 170 Simu hau nia orasaun ba;
\q2 salva hau tuir Ita Boot nia promesa.
\q1 
\v 171 Hau nia ibun sei la para hahii Ita Boot,
\q2 tanba Ita Boot hanorin Ita Boot nia lei mai hau.
\q1 
\v 172 Hau nia nanaal hananu kona ba Ita Boot nia liafuan,
\q2 tanba Ita Boot nia ukun fuan hotu-hotu loos.
\q1 
\v 173 Hau harohan atu Ita Boot nia liman prontu hodi tulun hau,
\q2 tanba hau hili atu tuir Ita Boot nia regra.
\q1 
\v 174 NAI Maromak, hau hakarak teb-tebes atu Ita Boot salva hau;
\q2 Ita Boot nia lei halo haksolok hau nia laran.
\q1 
\v 175 Halo hau moris atu hau bele hahii Ita Boot;
\q2 hau harohan atu Ita Boot nia regulamentu ajuda hau.
\q1 
\v 176 Hau lao sala dalan ona hanesan bibi nebee lakon;
\q2 buka tuir Ita Boot nia atan hau ba,
\q2 tanba hau la haluha Ita Boot nia ukun fuan.
\c 120
\s1 Orasaun husu tulun iha tempu susar
\d Kantiku peregrinasaun nian.
\b
\q1 
\v 1 Iha susar laran hau halerik ba NAI Maromak;
\q2 Nia hataan hau.
\q1 
\v 2 NAI, salva hau
\q2 husi ema bosok-teen ho lohi door sira.
\b
\q1 
\v 3 Imi lohi door sira,
\q2 Imi sei simu todan saida husi Maromak?
\q2 Nia sei foo kastigu imi oinsaa?
\q1 
\v 4 Nia sei uza aswain nia rama oan nebee kroat,
\q2 no ahi klaak boot.
\b
\q1 
\v 5 Hau terus hela, tanba hau ema lao rai iha rai Mezek;
\q2 hau tenki hela iha ema Kedar nia tenda nia leet.
\q1 
\v 6 Hau hela kleur liu ona
\q2 hamutuk ho ema nebee la gosta pas.
\q1 
\v 7 Hau hakarak pas ho hakmatek;
\q2 maibee bainhira hau koalia sai, sira hakarak funu.
\c 121
\s1 Nai Maromak kuidadu Nia povu
\d Kantiku peregrinasaun nian.
\b
\q1 
\v 1 Hau foti matan hateke ba foho;
\q2 hau atu hetan tulun husi nebee?
\q1 
\v 2 Hau hetan tulun husi NAI Maromak,
\q2 Ida nebee halo lalehan ho rai.
\b
\q1 
\v 3 Nia sei la husik o nia ain sidi;
\q2 Ida nebee tau matan ba o sei la dukur.
\q1 
\v 4 Tebes duni, Ida nebee tau matan ba Israel nee,
\q2 Nia matan sei la dukur, Nia matan moos hela deit.
\b
\q1 
\v 5 NAI Maromak tau matan ba o;
\q2 NAI iha hela o nia sorin loos hodi foo mahon ba o.
\q1 
\v 6 Loro matan meudia nian sei la halo o terus;
\q2 fulan iha kalan mos lae.
\b
\q1 
\v 7 NAI Maromak sei kuidadu o husi buat aat hotu-hotu;
\q2 Nia sei tau matan ba o nia moris.
\q1 
\v 8 NAI sei kuidadu o bainhira o sai husi uma no fila fali ba uma,
\q2 agora too tinan ba tinan.
\c 122
\s1 Orasaun ba sidade Jerusalém
\d Kantiku peregrinasaun husi David.
\b
\q1 
\v 1 Hau haksolok bainhira ema dehan mai hau,
\q2 “Mai ita baa iha NAI Maromak nia uma.”
\q1 
\v 2 Jerusalém, ami nia ain hakat tama tiha ona
\q2 ba iha o nia portaun boot.
\q1 
\v 3 Jerusalém nee harii metin
\q2 nudar sidade nebee la nakdoko.
\q1 
\v 4 Suku sira iha Israel sae mai iha nee;
\q2 NAI Maromak nia povu sae mai,
\q1 atu hahii NAI nia naran
\q2 tuir mandamentu nebee Nia foo tiha ona ba Israel.
\q1 
\v 5 Iha nee liurai David nia jerasaun sira tuur iha kadeira ukun
\q2 hodi tesi povu nia lia.
\b
\q1 
\v 6 Halo orasaun atu ema Jerusalém bele moris diak:
\q2 “Jerusalém, hau harohan atu ema nebee hadomi o, bele moris hakmatek,
\q1 
\v 7 o nia palasiu laran iha pas,
\q2 iha o nia moru laran ema bele hela hakmatek.”
\q1 
\v 8 Hau hakarak atu hau nia familia ho kolega sira bele hetan diak,
\q2 nunee hau dehan, “Imi ema Jerusalém, moris iha pas nia laran ba.”
\q1 
\v 9 Hau hakarak atu NAI ita nia Maromak nia uma bele hetan diak,
\q2 nunee hau buka atu povu Jerusalém moris diak.
\c 123
\s1 Orasaun husu Nai Maromak nia laran luak
\d Kantiku peregrinasaun nian.
\b
\q1 
\v 1 NAI, hau foti matan hateke ba Ita Boot;
\q2 Ita Boot tuur iha kadeira ukun iha lalehan.
\q1 
\v 2 Hanesan atan sira nia matan hateke ba patraun,
\q2 hanesan atan feto ida nia matan hateke ba patraun feto,
\q1 nunee mos ami nia matan hateke ba NAI ami nia Maromak,
\q2 too Nia hatudu laran luak mai ami.
\b
\q1 
\v 3 NAI Maromak, hatudu Ita Boot nia laran luak mai ami; hanoin ami ba,
\q2 tanba ema hamoe ami la hotu-hotu.
\q1 
\v 4 Ami terus aat liu ona,
\q2 tanba ema nebee moris diak, sira hatete aat ami;
\q2 ema foti aan sira hamoe ami.
\c 124
\s1 Agradese tanba Nai Maromak foo mahon ba Nia povu
\d Kantiku peregrinasaun husi David.
\b
\q1 
\v 1 Se uluk NAI Maromak la tulun ita karik, ita oinsaa loos?
\q2 Povu Israel koalia tuir ba:
\q1 
\v 2 “Se uluk NAI Maromak la tulun ita karik
\q2 bainhira inimigu ataka ita, ita oinsaa loos?”
\q1 
\v 3 Bainhira sira nia laran nakali hasoru ita,
\q2 sira sei tolan ita moris.
\q1 
\v 4 Bee sei sae hodi taka ita;
\q2 mota boot sei halo ita mout;
\q2 
\v 5 korenti bee sei sae makaas hodi dasa sai tiha ita.
\b
\q1 
\v 6 Hahii NAI Maromak,
\q2 tanba Nia la husik atu ema lees ita ho sira nia nehan.
\q1 
\v 7 Kasador sira tau lasu mai ita,
\q2 maibee ita halai sai tiha ona hanesan manu fuik;
\q1 lasu nee kotu tiha ona,
\q2 nunee ita sai ho livre.
\q1 
\v 8 Ita hetan tulun husi NAI Maromak;
\q2 Nia mak halo lalehan ho rai.
\c 125
\s1 Hakmatek Tanba Nai Maromak foo mahon
\d Kantiku peregrinasaun nian.
\b
\q1 
\v 1 Ema nebee laran metin ba NAI Maromak, sira hanesan foho Siaun;
\q2 sira nunka atu nakdoko, sira metin nafatin ba nafatin.
\q1 
\v 2 Hanesan foho haleu Jerusalém,
\q2 nunee mos NAI Maromak haleu Nia povu
\q2 agora too tinan ba tinan.
\q1 
\v 3 Nai ulun laran aat ukun iha ema moris loos nia rain,
\q2 sira nia ukun sei la dura;
\q1 se lae keta halo be ema moris loos lolo sira nia liman
\q2 hodi halo fali buat aat.
\q1 
\v 4 NAI, halo diak ba ema nebee diak;
\q2 foo bensaun ba ema nebee laran moos.
\q1 
\v 5 Maibee ema nebee tuir fali dalan kleuk,
\q2 NAI sei soe sai hamutuk ho ema nebee hahalok aat.
\q1 Pas ho hakmatek ba Israel!
\c 126
\s1 Orasaun atu Nai Maromak hadia fali povu nia moris
\d Kantiku peregrinasaun nian.
\b
\q1 
\v 1 Uluk NAI Maromak hadia fila fali povu Siaun nia moris,
\q2 ita senti ida nee mehi deit.
\q1 
\v 2 Iha tempu nebaa ita nia ibun nakonu ho hamnasa;
\q2 ita nia nanaal hananu haksolok.
\q1 Ema husi nasaun sel-seluk dehan,
\q2 “NAI halo tiha buat boot ba sira.”
\q1 
\v 3 Loos duni, iha tempu nebaa NAI halo duni buat boot ba ita,
\q2 nunee ita haksolok.
\b
\q1 
\v 4 NAI, agora hadia fali ami nia moris ba,
\q2 hanesan bee suli hodi haburas rai fuik maran Negebe.
\q1 
\v 5 Ema nebee kuda fini ho matan been,
\q2 too tempu kolheta sei hananu haksolok.
\q1 
\v 6 Ema nebee tanis tuir dalan
\q2 bainhira lori fini atu kuda iha toos,
\q1 sira sei lori rezultadu toos nian ba uma
\q2 hodi hananu ho haksolok.
\c 127
\s1 Nai Maromak mak buat diak hotu nia huun
\d Kantiku peregrinasaun husi Salomão.
\b
\q1 
\v 1 Se karik NAI Maromak la harii uma,
\q2 badaen uma nian servisu saugati.
\q1 Se karik NAI la foo seguransa ba sidade,
\q2 ema nebee kontrola sidade servisu saugati deit.
\q1 
\v 2 Imi nebee hadeer molok rai huun mutin
\q2 hodi servisu haluha aan too fali kalan boot
\q1 atu buka moris, imi servisu saugati deit,
\q2 tanba NAI foo deskansa ba ema nebee Nia hadomi.
\b
\q1 
\v 3 Oan sira hanesan riku-soin husi NAI Maromak;
\q2 sira nee prezenti nebee Nia foo.
\q1 
\v 4 Oan mane nebee moris bainhira nia aman sei joven,
\q2 sira hanesan rama oan iha funu nain nia liman laran.
\q1 
\v 5 Ema nebee iha rama oan barak,
\q2 ema nee hetan ksolok.
\q1 Bainhira nia koalia hasoru nia inimigu sira iha fatin tesi lia nian,
\q2 nia sei la moe leet.
\c 128
\s1 Bensaun ba ema nebee hamtauk Nai Maromak
\d Kantiku peregrinasaun nian.
\b
\q1 
\v 1 Ema nebee hamtauk NAI Maromak
\q2 hodi lao tuir Nia dalan, ema nee hetan ksolok.
\q1 
\v 2 O sei haan husi o nia kosar been rasik;
\q2 o sei hetan bensaun no moris diak.
\q1 
\v 3 O nia feen sei hanesan ai uvas nebee foo fuan barak iha o nia uma;
\q2 o nia oan sira sei hanesan ai oliveira dikin hodi haleu o nia meza.
\q1 
\v 4 Loos duni, ema nebee hamtauk NAI Maromak,
\q2 sei hetan bensaun nunee.
\b
\q1 
\v 5 Hau harohan atu NAI Maromak foo bensaun ba o husi Siaun;
\q2 hau harohan atu o haree Jerusalém moris diak
\q2 iha o nia vida tomak.
\q1 
\v 6 Hau harohan atu o moris too haree o nia bei-oan sira.
\q2 Pas ho hakmatek ba Israel!
\c 129
\s1 Orasaun hasoru inimigu
\d Kantiku peregrinasaun nian.
\b
\q1 
\v 1 “Hau nia inimigu sira hanehan hau husi joven kedas.”
\q2 Israel oan sira hatete tuir ba:
\q1 
\v 2 “Hau nia inimigu sira hanehan hau husi joven kedas,
\q2 maibee sira nunka manaan hau.
\q1 
\v 3 Sira taa hau nia kotuk too kanek todan,
\q2 hanesan fali toos nain taa rai.
\q1 
\v 4 Maibee NAI Maromak sempre halo buat nebee loos;
\q2 ema aat nia talin nebee futu hau, Nia hakotu tiha.”
\b
\q1 
\v 5 Hau harohan atu Siaun nia inimigu sira hotu
\q2 hakiduk ho moe.
\q1 
\v 6 Husik sira sai hanesan duut nebee moris iha uma kakuluk;
\q2 foin tubun, namlaik tiha ona.
\q1 
\v 7 La iha ema ida mak interese atu tesi duut nee;
\q2 la iha ida mak hakarak atu futu hamutuk.
\q1 
\v 8 Hau hein katak ema nebee liu husi nebaa nunka kumprimenta sira dehan,
\q2 “NAI Maromak nia bensaun hela ho imi;
\q2 ami foo bensaun ba imi hodi NAI nia naran.”
\c 130
\s1 Laran metin hodi hein Nai Maromak nia tulun
\d Kantiku peregrinasaun nian.
\b
\q1 
\v 1 NAI Maromak, hau iha hela susar boot laran,
\q2 nee mak hau halerik husu tulun ba Ita Boot.
\q1 
\v 2 Nai, rona hau nia lian ba;
\q2 see tilun ba hau nia harohan.
\b
\q1 
\v 3 NAI Maromak, se karik Ita Boot hanoin nafatin ami nia sala,
\q2 Nai, see mak bele aguenta?
\q1 
\v 4 Maibee Ita Boot foo perdaun,
\q2 atu ami bele hamtauk Ita Boot.
\b
\q1 
\v 5 Hau laran metin hodi hein NAI Maromak;
\q2 hau nia aan tomak hein hela Nia;
\q2 hau konfia Nia liafuan.
\q1 
\v 6 Hau laran metin hodi hein Nai Maromak,
\q2 liu fali ema seguransa hein loro matan sae;
\q2 liu fali ema seguransa hein atu rai loron lalais.
\b
\q1 
\v 7 Israel, laran metin ba NAI Maromak ba,
\q2 tanba NAI nia domin rohan-laek,
\q2 no Nia gosta teb-tebes atu salva ita.
\q1 
\v 8 \x + \xo 130:8 \xt Mateus 1:21; Tito 2:14\x*Nia rasik sei halo ema Israel livre
\q2 husi sira nia sala hotu.
\c 131
\s1 Laran metin ba Nai Maromak
\d Kantiku peregrinasaun husi David.
\b
\q1 
\v 1 NAI Maromak, hau la foti aan;
\q2 hau la gaba aan.
\q1 Hau la duni tuir buat nebee boot liu hau nia kapasidade,
\q2 ka buat nebee aas liu mai hau.
\q1 
\v 2 Maibee hau kalma hela, hau hakmatek hela.
\q2 Hanesan bebee nebee susu bosu tiha hakmatek hela iha nia inan nia sorin,
\q2 hau mos hakmatek nunee.
\b
\q1 
\v 3 Israel oan sira, laran metin ba NAI Maromak ba,
\q2 agora too tinan ba tinan.
\c 132
\s1 Nai Maromak nia promesa ba liurai David
\d Kantiku peregrinasaun nian.
\b
\q1 
\v 1 NAI Maromak, hanoin nafatin David ba;
\q2 keta haluha terus ho susar nebee nia hasoru.
\q1 
\v 2 Nia jura ba NAI;
\q2 Nia halo ona juramentu ba Jacó nia Maromak Kbiit Nain dehan,
\q1 
\v 3 “Hau sei la tama iha hau nia uma laran
\q2 ka deskansa iha hau nia toba fatin;
\q1 
\v 4 hau sei halo hau nia matan lakan hela deit;
\q2 hau lakohi dukur,
\q1 
\v 5 too hau hetan fatin ida ba NAI Maromak;
\q2 too hau hetan hela fatin ba Jacó nia Maromak Kbiit Nain.”
\b
\q1 
\v 6 \x + \xo 132:6 \xt 2 Krónikas (Tawarikh) 6:41,42\x*Iha rai Efrata ita rona kona ba kaixoti promesa nian;
\q2 ita hetan kaixoti nee iha rejiaun Jaar nian.
\q1 
\v 7 Depois ita dehan, “Mai ita baa iha NAI nia hela fatin;
\q2 mai ita hakruuk iha Nia ain hodi adora Nia.”
\b
\q1 
\v 8 NAI Maromak, hamriik ba hodi tama iha Ita Boot nia fatin deskansa;
\q2 lori ho kaixoti promesa nian, ida nee hatudu sai Ita Boot nia kbiit.
\q1 
\v 9 Hau harohan atu Ita Boot nia nai lulik sira hatais lia loos,
\q2 no Ita Boot nia povu santu hananu haksolok.
\q1 
\v 10 Keta fila kotuk ba liurai nebee Ita Boot hili ona,
\q2 tanba Ita Boot promete tiha ona ba Ita Boot nia atan David.
\q1 
\v 11 \x + \xo 132:11 \xt 2 Samuel 7:12-16; 1 Krónikas (Tawarikh) 17:11-14; Salmu 89:3,4; Apostolu sira nia Istoria 2:30\x*NAI Maromak jura tiha ona ba David;
\q2 Nia jura ho lo-loos, no sei la dada fila fali. Nia dehan,
\q1 “Hau sei foti o nia oan ida
\q2 hodi sai liurai iha o nia fatin.
\q1 
\v 12 Se o nia oan sira kaer metin hau nia promesa
\q2 no halo tuir lei nebee Hau hanorin ba sira,
\q1 entaun sira nia oan sira mos sei tuur
\q2 hodi ukun iha o nia fatin tinan ba tinan.”
\b
\q1 
\v 13 NAI Maromak hili tiha ona Siaun;
\q2 Nia hakarak sidade nee sai Nia hela fatin. Nia dehan,
\q1 
\v 14 “Ida nee Hau nia fatin deskansa tinan ba tinan;
\q2 Hau sei hela iha nee tanba Hau nia hakarak mak nee duni.
\q1 
\v 15 Hau sei haraik bensaun ba sidade nee too ai haan nakonu;
\q2 Hau sei foo ai haan ba ema kiak sira haan too bosu.
\q1 
\v 16 Nai lulik sira iha sidade nee, Hau sei foo hatais ho salvasaun;
\q2 povu santu nebee hela iha sidade nee sei hananu haksolok.
\q1 
\v 17 \x + \xo 132:17 \xt 1 Liurai sira (Reis, Raja-raja) 11:36\x*Iha sidade nee Hau sei foo kbiit ba David;
\q2 Hau sei halo nia ahi oan lakan beibeik tanba Hau mak hili nia sai liurai.
\q1 
\v 18 Hau sei halo nia inimigu sira moe boot,
\q2 maibee liurai nia koroa sei nabilan.”
\c 133
\s1 Moris iha unidade nia laran buat furak ida
\d Kantiku peregrinasaun husi David.
\b
\q1 
\v 1 Bainhira maluk sira moris neon ida laran ida,
\q2 nee diak no furak teb-tebes.
\q1 
\v 2 Unidade nee hanesan mina folin karun nian
\q2 nebee fui ba iha nai lulik boot Arão nia ulun;
\q1 mina nee suli tuun ba iha nia hasan rahun;
\q2 suli too kona nia batina nia gola.
\q1 
\v 3 Unidade nee hanesan mahobeen foho Hermon nian
\q2 nebee turu tuun ba iha foho Siaun.
\q1 Tanba iha foho Siaun nee NAI Maromak hatuun Nia bensaun,
\q2 moris tinan ba tinan.
\c 134
\s1 Hahii Nai Maromak iha oras kalan
\d Kantiku peregrinasaun nian.
\b
\q1 
\v 1 NAI Maromak nia atan hotu-hotu, hahii NAI ba;
\q2 imi nebee serbi iha NAI nia uma iha oras kalan, hahii NAI ba.
\q1 
\v 2 Foti sae imi nia liman iha fatin santu
\q2 hodi hahii NAI.
\b
\q1 
\v 3 NAI Maromak mak kria lalehan ho rai;
\q2 hau harohan atu husi foho Siaun Nia haraik bensaun ba imi.
\c 135
\s1 Kantiku hahii Nai Maromak
\q1 
\v 1 Hahii NAI Maromak!
\b
\q1 Hahii NAI nia naran;
\q2 NAI nia atan sira, hahii Nia ba.
\q1 
\v 2 Imi nebee halao knaar iha NAI nia uma,
\q2 iha ita nia Maromak nia uma kreda laran, hahii Nia ba.
\b
\q1 
\v 3 Hahii NAI Maromak tanba NAI nee diak;
\q2 hananu hahii Nia naran, tanba nee buat furak ida.
\q1 
\v 4 Tanba NAI hili ona Jacó atu sai Ninian;
\q2 Nia hili povu Israel sai nudar Nia riku-soin rasik.
\b
\q1 
\v 5 Hau hatene katak NAI Maromak nee boot;
\q2 ita nia Nai nee boot liu maromak sel-seluk.
\q1 
\v 6 NAI halo saida deit tuir Nia hakarak,
\q2 iha lalehan no iha rai,
\q2 iha tasi leten no mos iha tasi okos.
\q1 
\v 7 Nia halo kalohan mosu husi rai ulun too rai ikun iha mundu tomak;
\q2 Nia haruka rai lakan akompanha udan;
\q2 Nia lori sai anin husi Nia armazen laran.
\b
\q1 
\v 8 Nia oho dasa tiha ema Ejitu nia oan mane boot;
\q2 ema nia oan primeiru ho mos animal nia oan primeiru, Nia oho hotu.
\q1 
\v 9 Imi ema Ejitu, uluk Nia haruka Nia sinal ho milagre ba iha imi nia klaran
\q2 hodi kontra imi nia liurai ho nia atan sira hotu.
\q1 
\v 10 Nia hamonu nasaun barak
\q2 hodi oho liurai bo-boot,
\q1 
\v 11 hanesan Sihon, ema Amori nia liurai,
\q2 Og, rai Basán nia liurai,
\q2 ho liurai hotu-hotu iha rai Kanaán.
\q1 
\v 12 Nia foo rai nee ba Nia povu Israel
\q2 nudar sira nia riku-soin.
\b
\q1 
\v 13 NAI Maromak, Ita Boot nia naran dura tinan ba tinan;
\q2 NAI, Ita Boot nia naran sei temi beibeik husi jerasaun ba jerasaun.
\q1 
\v 14 Tanba NAI sei foo justisa ba Nia povu;
\q2 Nia sei hanoin Nia atan sira.
\b
\q1 
\v 15 \x + \xo 135:15 \xt Salmu 115:4-8; Apokalipse 9:20\x*Nasaun jentiu sira adora fali estatua lulik
\q2 nebee ema kriatura mak halo husi osan mean ho osan mutin.
\q1 
\v 16 Iha ibun maibee la bele koalia,
\q2 iha matan maibee la bele haree.
\q1 
\v 17 Iha tilun maibee la bele rona,
\q2 no la iha iis sai husi sira nia ibun.
\q1 
\v 18 Ema nebee kria estatua lulik sira nee, sira sai hanesan fali buat nebee sira kria nee;
\q2 ema nebee fiar ba estatua sira nee mos sei sai nunee hotu.
\b
\q1 
\v 19 Israel oan sira, hahii NAI ba;
\q2 Arão nia jerasaun sira, hahii NAI ba;
\q1 
\v 20 Levi nia jerasaun sira, hahii NAI ba;
\q2 imi sira nebee hamtauk NAI, hahii NAI ba.
\q1 
\v 21 Hahii NAI iha Siaun,
\q2 iha Nia hela fatin Jerusalém.
\b
\q1 Hahii NAI Maromak!
\c 136
\s1 Nai Maromak nia domin ba povu Israel
\q1 
\v 1 \x + \xo 136:1 \xt 1 Krónikas (Tawarikh) 16:34; 2 Krónikas (Tawarikh) 5:13, 7:3; Esdras (Ezra) 3:11; Salmu 100:5, 106:1, 107:1, 118:1; Jeremias 33:11\x*Foo agradese ba NAI Maromak, tanba Nia nee diak;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 2 Foo agradese ba maromak sel-seluk nia Maromak;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 3 Foo agradese ba nai hotu-hotu nia Nai;
\q2 Nia domin dura tinan ba tinan.
\b
\q1 
\v 4 Nia mesak deit mak halo milagre bo-boot;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 5 \x + \xo 136:5 \xt Jénesis 1:1\x*Hodi Nia matenek, Nia halo lalehan;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 6 \x + \xo 136:6 \xt Jénesis 1:2\x*Nia hatuur mundu iha bee leten;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 7 \x + \xo 136:7 \xt Jénesis 1:16\x*Nia halo loro matan ho fulan hodi foo naroman;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 8 Nia halo loro matan hodi domina tempu loron;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 9 Nia halo fulan ho fitun hodi domina tempu kalan;
\q2 Nia domin dura tinan ba tinan.
\b
\q1 
\v 10 \x + \xo 136:10 \xt Ézodu (Keluaran) 12:29\x*Nia oho dasa tiha ema Ejitu nia oan mane boot sira;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 11 \x + \xo 136:11 \xt Ézodu (Keluaran) 12:51\x*Nia lori povu Israel sai husi ema Ejitu nia klaran;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 12 Hodi Nia liman forti, hodi Nia liman makaas, Nia lori sira sai;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 13 \x + \xo 136:13 \xt Ézodu (Keluaran) 14:21-29\x*Nia fera tiha Tasi Mean fahe ba rua;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 14 Nia lori sai ema Israel liu husi tasi klaran;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 15 Maibee Nia soe tiha liurai Ejitu ho nia militar sira ba iha Tasi Mean;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 16 Nia lori Nia povu lao liu husi rai fuik maran;
\q2 Nia domin dura tinan ba tinan.
\b
\q1 
\v 17 Nia oho dasa tiha liurai bo-boot;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 18 Nia oho tiha liurai nebee forti;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 19 \x + \xo 136:19 \xt Númerus (Bilangan) 21:21-30\x*Nia oho tiha Sihon, ema Amori nia liurai;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 20 \x + \xo 136:20 \xt Númerus (Bilangan) 21:31-35\x*Nia mos oho Og, ema Basán nia liurai;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 21 Nia foo sira nia rai ba Nia povu nudar sira nia riku-soin;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 22 Nia foo rai nee nudar riku-soin ba Nia atan Israel sira;
\q2 Nia domin dura tinan ba tinan.
\b
\q1 
\v 23 Nia hanoin ita bainhira ema hatuun ita;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 24 Nia hasai ita husi ita nia inimigu sira nia liman laran;
\q2 Nia domin dura tinan ba tinan.
\q1 
\v 25 Nia foo ai haan ba kriatura ida-idak;
\q2 Nia domin dura tinan ba tinan.
\b
\q1 
\v 26 Foo agradese ba Maromak iha lalehan;
\q2 Nia domin dura tinan ba tinan.
\c 137
\s1 Israel oan sira halerik iha ema nia rain tanba Jerusalém rahun
\q1 
\v 1 Iha mota Babilónia nia ninin, ami tuur hodi tanis halerik
\q2 bainhira ami hanoin kona ba Siaun.
\q1 
\v 2 Iha mota ninin nee ami tara ami nia viola
\q2 iha ai huun nia sanak.
\q1 
\v 3 Tanba iha nebaa ema nebee halo ami dadur haruka ami kanta;
\q2 ema nebee halo ami terus obriga ami hananu knananuk ksolok nian;
\q2 sira haruka ami hananu kantiku ida kona ba Siaun iha sira nia oin.
\b
\q1 
\v 4 Oinsaa mak ami bele hananu ba NAI Maromak
\q2 durante ami iha hela ema nia rain?
\q1 
\v 5 Jerusalém, se karik hau haluha o,
\q2 husik ba, hau nia liman loos nia forsa lakon tiha ba.
\q1 
\v 6 Jerusalém, se karik hau la hanoin kona o,
\q2 se karik hau la konsidera o nudar ksolok ida nebee boot liu mai hau,
\q2 husik hau nia nanaal toos tiha iha hau nia ibun laran ba.
\b
\q1 
\v 7 NAI Maromak, keta haluha buat nebee mak ema Edom halo
\q2 iha loron nebee sidade Jerusalém monu.
\q1 Sira hakilar dehan, “Halo rahun tiha;
\q2 halo rahun too nia huun!”
\q1 
\v 8 \x + \xo 137:8 \xt Apokalipse 18:6\x*Babilónia oan sira, susar boot sei kona imi.
\q2 Ema nebee mak selu fali imi nia hahalok aat hasoru ami,
\q2 sira hetan ksolok.
\q1 
\v 9 Ema nebee hadau imi nia oan kiik oan sira hodi riba ba fatuk,
\q2 sira hetan ksolok.
\c 138
\s1 Kantiku agradese tanba Nai Maromak nia tulun
\d Salmu David nian.
\b
\q1 
\v 1 NAI Maromak, ho laran tomak hau foo agradese ba Ita Boot;
\q2 iha maromak sel-seluk nia oin, hau hananu hahii Ita Boot.
\q1 
\v 2 Hau see oin hakruuk ba iha Ita Boot nia fatin santu,
\q2 no hahii Ita Boot nia naran,
\q1 tanba Ita Boot nia domin rohan-laek no Ita Boot sempre kaer metin Ita Boot nia liafuan;
\q2 Ita Boot tane Ita Boot nia naran ho Ita Boot nia liafuan aas liu buat hotu-hotu.
\q1 
\v 3 Bainhira hau halerik husu tulun, Ita Boot hataan hau;
\q2 Ita Boot nia kbiit halo hau aten brani.
\b
\q1 
\v 4 NAI Maromak, hau harohan atu liurai hotu-hotu iha mundu nee bele hahii Ita Boot
\q2 bainhira sira rona liafuan nebee sai husi Ita Boot nia ibun.
\q1 
\v 5 Hau harohan atu sira hananu kona ba NAI nia dalan,
\q2 tanba NAI nia kbiit boot.
\q1 
\v 6 Maski NAI iha leten aas ba, Nia haree diak ema kiik,
\q2 maibee ema foti aan sira, Nia konhese husi dook deit.
\b
\q1 
\v 7 Maski hau lao iha susar laran,
\q2 Ita Boot proteje hau nia vida.
\q1 Bainhira hau nia funu baluk sira hirus, Ita Boot nia liman kontra sira;
\q2 Ita Boot salva hau hodi Ita Boot nia liman loos.
\q1 
\v 8 NAI, Ita Boot nia planu ba hau sei sai realidade;
\q2 Ita Boot nia domin dura tinan ba tinan;
\q2 NAI, keta husik hela Ita Boot nia liman fatin mes-mesak.
\c 139
\s1 Orasaun ba Nai Maromak Matenek Nain
\d Salmu David nian, ba dirijenti koru. Kantiku.
\b
\q1 
\v 1 NAI Maromak, Ita Boot koko tiha ona hau,
\q2 no konhese hau mo-moos.
\q1 
\v 2 Atu hau tuur ka hau hamriik, Ita Boot hatene hotu;
\q2 husi dook Ita Boot hatene hau nia hanoin.
\q1 
\v 3 Atu hau lao ka hau toba, Ita Boot haree tuir;
\q2 Ita Boot hatene hau nia moris tomak.
\q1 
\v 4 NAI, molok liafuan ruma sai husi hau nia ibun,
\q2 Ita Boot hatene hotu ona.
\q1 
\v 5 Ita Boot besik loos hau husi oin no husi kotuk;
\q2 Ita Boot tula Ita Boot nia liman ba iha hau nia leten.
\q1 
\v 6 Ita Boot konhese mo-moos hau nunee, furak teb-tebes mai hau;
\q2 matenek hanesan nee aas teb-tebes, hau la bele kompriende too iha nebaa.
\b
\q1 
\v 7 Hau tenki baa iha nebee atu bele haketak aan husi Ita Boot nia Espiritu?
\q2 Hau tenki halai baa iha nebee atu bele sees husi Ita Boot nia oin?
\q1 
\v 8 Hau sae ba iha lalehan, Ita Boot iha nebaa;
\q2 hau halo hau nia toba fatin iha matebian sira nia fatin, Ita Boot iha nebaa.
\q1 
\v 9 Se hau semo ba iha lorosae,
\q2 ka halo hau nia hela fatin iha tasi nia rohan ba,
\q1 
\v 10 iha nebaa mos Ita Boot nia liman sei hatudu dalan mai hau;
\q2 Ita Boot nia liman loos kaer metin hau.
\q1 
\v 11 Karik hau dehan, “Husik nakukun subar tiha hau;
\q2 husik naroman nebee haleu hau sai fali nakukun.”
\q1 
\v 12 Maibee iha nakukun laran mos Ita Boot nia matan haree borus;
\q2 ba Ita Boot, kalan iha naroman hanesan fali loron nian;
\q2 ba Ita Boot, nakukun ho naroman hanesan deit.
\b
\q1 
\v 13 Ita Boot mak kria hau nia laran;
\q2 Ita Boot soru hau hamutuk iha hau nia inan nia kabun laran.
\q1 
\v 14 Hau hahii Ita Boot tanba Ita Boot nee makaas;
\q2 hau rekonhese ho laran tomak katak,
\q2 Ita Boot nia liman fatin furak teb-tebes.
\q1 
\v 15 Bainhira Ita Boot forma hau iha fatin segredu,
\q2 iha momentu Ita Boot suku hau iha hau nia inan nia kabun laran hanesan ema suku borda,
\q2 Ita Boot haree mo-moos hau nia ruin sira nee.
\q1 
\v 16 Hau nia isin lolon seidauk forma hamutuk,
\q2 Ita Boot nia matan haree tiha ona hau.
\q1 Hau nia loron moris mai seidauk too,
\q2 loron hotu-hotu nebee Ita Boot atu foo mai hau, hakerek tiha ona iha Ita Boot nia livru.
\b
\q1 
\v 17 Maromak, Ita Boot nia hanoin, hau imajina la hetan;
\q2 Ita Boot nia ideia barak teb-tebes, sura la bele.
\q1 
\v 18 Hau atu sura karik,
\q2 barak liu fali rai henek musan iha mundu;
\q2 bainhira hau hadeer, hau sei hamutuk nafatin ho Ita Boot.
\b
\q1 
\v 19 Maromak, hau hein atu Ita Boot hamate tiha ema aat sira.
\q2 Imi sira nebee hamrook ba raan, dook tiha husi hau.
\q1 
\v 20 Sira koalia aat kona ba Ita Boot;
\q2 sira hatete aat Ita Boot nia naran.
\q1 
\v 21 NAI, hau odi ema nebee mak odi Ita Boot;
\q2 hau hakribi ema nebee kontra Ita Boot.
\q1 
\v 22 Hau odi loos sira;
\q2 hau konsidera sira nee hau nia inimigu.
\b
\q1 
\v 23 Maromak, koko hau hodi hatene tuir hau nia laran;
\q2 prova hau hodi hatene hau nia hanoin.
\q1 
\v 24 Haree ba, keta hau halo buat aat ruma karik;
\q2 lori hau tuir dalan moris rohan-laek nian.
\c 140
\s1 Orasaun husu atu Nai Maromak proteje
\d Salmu David nian, ba dirijenti koru.
\b
\q1 
\v 1 NAI Maromak, salva hau husi ema aat ba;
\q2 proteje hau husi ema nebee gosta violensia.
\q1 
\v 2 Sira sempre hanoin aat;
\q2 loron-kalan sira sadik ema atu halo funu.
\q1 
\v 3 \x + \xo 140:3 \xt Roma 3:13\x*Sira halo sira nia liafuan kroat hodi hakanek ema hanesan samea nebee tata ema;
\q2 liafuan nebee sai husi sira nia ibun hanesan samodok nia veneno.
\b
\q1 
\v 4 NAI Maromak, kuidadu hau atu ema aat nia liman keta kona hau;
\q2 proteje hau husi ema nebee gosta violensia,
\q2 tanba sira kombina malu atu hamonu hau.
\q1 
\v 5 Ema foti aan sira tau ona lasu mai hau;
\q2 sira nahe redi mai hau;
\q2 sira monta gaiola iha hau nia dalan.
\b
\q1 
\v 6 Hau hatete ba NAI, “Ita Boot mak hau nia Maromak.”
\q2 NAI, hau halerik husu tulun, rona hau ba.
\q1 
\v 7 NAI, hau nia Maromak, Ita Boot nia kbiit makaas hodi salva hau;
\q2 Ita Boot taka hau nia ulun iha funu laran.
\q1 
\v 8 NAI, keta foo dalan ba ema aat sira nia hakarak;
\q2 keta husik sira nia planu sai realidade, se lae sira sei foti aan.
\b
\q1 
\v 9 Ema nebee haleu hau foti sira nia ulun;
\q2 husik liafuan aat nebee sira hatete mai hau, fila fali ba sira.
\q1 
\v 10 Halo ahi klaak monu tuun iha sira nia leten;
\q2 halo sira monu tama ba iha rai kuak klean, nunka atu sai fali.
\q1 
\v 11 Hau hein katak sira nebee gosta hatete aat ema, la bele hela metin iha rai nee;
\q2 husik dezastre duni tuir ema nebee gosta violensia.
\b
\q1 
\v 12 Hau hatene katak NAI Maromak foo justisa lo-loos ba ema kbiit-laek
\q2 hodi defende ema kiak sira.
\q1 
\v 13 Loos duni, ema nebee moris loos sei hahii Ita Boot nia naran;
\q2 ema nebee laran moos sei hela iha Ita Boot nia prezensa.
\c 141
\s1 Orasaun bainhira iha tentasaun laran
\d Salmu David nian.
\b
\q1 
\v 1 NAI Maromak, hau harohan ba Ita Boot, mai lalais tulun hau;
\q2 rona hau nia lia halerik ba.
\q1 
\v 2 \x + \xo 141:2 \xt Apokalipse 5:8\x*Bainhira hau hasae orasaun ba Ita Boot,
\q2 simu ba nudar ai been morin;
\q1 bainhira hau hasae liman ba Ita Boot,
\q2 simu ba nudar oferta sakrifisiu iha oras kalan.
\b
\q1 
\v 3 NAI Maromak, tau seguransa ba hau nia ibun;
\q2 kontrola hau nia liafuan.
\q1 
\v 4 Keta husik hau nia laran monu ba buat nebee la diak;
\q2 la bele husik hau mete hahalok aat
\q1 hamutuk ho ema nebee gosta halo buat aat;
\q2 hau lakohi tama iha sira nia festa hodi haan hamutuk ho sira.
\b
\q1 
\v 5 Se ema moris loos baku hau karik, nee hatudu domin;
\q2 se nia siak hau, nee hanesan kose mina ba hau nia ulun;
\q1 hau sei simu.
\q2 Maibee hau sempre halo orasaun kontra ema aat sira nia hahalok.
\q1 
\v 6 Bainhira ema entrega sira ba iha juis atu hamonu kastigu ba sira,
\q2 ema aat sira sei rekonhese katak hau nia liafuan loos duni.
\q1 
\v 7 Hanesan fatuk nebee ema baku rahun iha rai,
\q2 nunee mos sira nia ruin sei naklekar iha portaun rate nian.\f + \fr 141:7 \ft Lian Ebreu iha versikulu nee la klaru.\f*
\b
\q1 
\v 8 Maibee NAI Maromak Kbiit Nain, hau nia matan hateke nafatin ba Ita Boot;
\q2 hau hamahon aan iha Ita Boot, keta husik hau sai mate mean.
\q1 
\v 9 Kuidadu hau husi lasu nebee ema aat tau ona mai hau;
\q2 proteje hau husi gaiola nebee sira monta ba hau.
\q1 
\v 10 Husik ema aat monu tama ba sira nia redi rasik,
\q2 maibee hau lao liu ho livre.
\c 142
\s1 Orasaun husu tulun
\d Salmu David nian para hanorin ema. Orasaun bainhira David iha fatuk kuak laran.
\b
\q1 
\v 1 Hau harohan ba NAI Maromak ho lian makaas;
\q2 hau hasae hau nia lian ba NAI hodi husu Nia tulun.
\q1 
\v 2 Hau fakar sai hau nia lia halerik iha Nia oin;
\q2 hau konta hau nia susar ba Nia.
\q1 
\v 3 Bainhira hau lakon esperansa,
\q2 Ita Boot hatene tuir hau nia moris.
\q1 Iha dalan nebee hau lao tuir,
\q2 ema subar lasu ba hau.
\q1 
\v 4 Haree ba, la iha ema ida iha hau nia liman loos;
\q2 la iha ema ida interese mai hau;
\q1 la iha tan subar fatin ba hau;
\q2 la iha ema ida hanoin hau.
\q1 
\v 5 NAI Maromak, hau halerik husu tulun ba Ita Boot;
\q2 hau dehan, “Ita Boot mak hau nia fatin seguru;
\q2 Ita Boot mak hau nia riku-soin iha mundu nee.”
\q1 
\v 6 Rona hau nia lia halerik ba,
\q2 tanba hau la bele liu ona;
\q1 salva hau husi ema nebee duni tuir hau,
\q2 tanba sira forsa liu hau.
\q1 
\v 7 Hasai hau husi dadur laran,
\q2 atu hau bele hahii Ita Boot nia naran.
\q1 Depois ema moris loos sei mai hodi haleu hau,
\q2 tanba Ita Boot haree hau diak.
\c 143
\s1 Orasaun husu tulun
\d Salmu David nian.
\b
\q1 
\v 1 NAI Maromak, rona hau nia orasaun;
\q2 see tilun ba hau nia halerik, tanba Ita Boot sempre kaer metin Ita Boot nia liafuan;
\q2 hataan hau ba, tanba Ita Boot sempre halo buat nebee loos.
\q1 
\v 2 \x + \xo 143:2 \xt Roma 3:20; Galásia 2:16\x*Keta haruka hau ata hataan iha Ita Boot nia oin kona ba sala nebee hau halo tiha ona,
\q2 tanba la iha ema ida mak moris loos iha Ita Boot nia futar oin.
\q1 
\v 3 Inimigu sira duni tuir hau;
\q2 sira sama hau ba rai;
\q2 sira dadur hau iha fatin nakukun
\q2 hanesan fali ema nebee mak mate kleur ona.
\q1 
\v 4 Nunee hau lakon esperansa;
\q2 hau nia laran tauk teb-tebes.
\q1 
\v 5 Hau hanoin fila fali tempu uluk nian;
\q2 hau reflete Ita Boot nia servisu hotu;
\q2 hau medita saida mak Ita Boot nia liman halo tiha ona.
\q1 
\v 6 Hau hasae hau nia liman halo orasaun ba Ita Boot;
\q2 hau hamrook ba Ita Boot hanesan rai maran dekor nebee hamrook ba udan been.
\b
\q1 
\v 7 NAI Maromak, hataan hau lalais ba;
\q2 hau nia esperansa lakon ba dadauk.
\q1 Keta subar Ita Boot nia oin mai hau;
\q2 se lae hau sei hanesan ema nebee mak lao tuun dadauk ba rai kuak.
\q1 
\v 8 Dadeer-dadeer foo hanoin mai hau kona ba Ita Boot nia domin rohan-laek,
\q2 tanba hau laran metin ba Ita Boot.
\q1 Hatudu dalan nebee mak hau atu lao tuir,
\q2 tanba hau entrega hau nia moris ba Ita Boot.
\q1 
\v 9 NAI Maromak, salva hau husi hau nia inimigu sira,
\q2 tanba hau helik aan iha Ita Boot.
\q1 
\v 10 Hanorin hau atu halo tuir Ita Boot nia hakarak,
\q2 tanba Ita Boot mak hau nia Maromak.
\q1 Ita Boot nia Espiritu laran diak;
\q2 haruka Nia lori hau ba iha rai tetuk.
\q1 
\v 11 NAI Maromak, kuidadu hau nia moris atu ema foti aas Ita Boot nia naran;
\q2 hasai hau husi susar laran, tanba Ita Boot sempre halo buat nebee loos.
\q1 
\v 12 Ita Boot hadomi teb-tebes hau, nunee halo hau nia inimigu sira nonook tiha ba;
\q2 halo rahun tiha hau nia funu baluk sira,
\q2 tanba hau nee Ita Boot nia atan.
\c 144
\s1 Liurai agradese Nai Maromak tanba manaan funu
\d Salmu David nian.
\b
\q1 
\v 1 Hahii NAI Maromak, Nia mak fatuk lolon boot nebee satan netik hau;
\q2 Nia mak treinu hau nia liman atu halo funu;
\q2 Nia treinu hau nia liman fuan atu kaer kroat.
\q1 
\v 2 Nia nee hau nia Maromak Domin Nain, Nia mak lutu haleu hau,
\q2 hau nia abrigu no hau nia Salvador.
\q1 Nia mak defende hau, no hau hamahon aan iha Nia;
\q2 Nia halo nasaun sira seluk hakruuk mai hau.
\b
\q1 
\v 3 \x + \xo 144:3 \xt Jó (Ayub) 7:17,18; Salmu 8:4\x*NAI Maromak, ami ema kriatura nee see loos, too Ita Boot hanoin ami?
\q2 Ami ema kbiit-laek nee see loos, too Ita Boot interese ami?
\q1 
\v 4 Ami nee hanesan fali anin nebee huu liu deit;
\q2 ami nia moris hanesan lalatak nebee liu lalais deit.
\b
\q1 
\v 5 NAI Maromak, loke Ita Boot nia lalehan hodi tuun mai;
\q2 kaer kona foho, atu nunee foho suar sai.
\q1 
\v 6 Haruka rai lakan hodi halo inimigu sira halai namkari;
\q2 hana Ita Boot nia rama oan halo sira halai lakon.
\q1 
\v 7 Husi leten aas ba hatuun Ita Boot nia liman mai
\q2 hodi hasai hau husi bee boot laran;
\q2 salva hau husi inimigu rai liur sira nia liman laran.
\q1 
\v 8 Tanba sira nia ibun nakonu ho buat bosok;
\q2 sira foti liman hodi halo juramentu falsu.
\b
\q1 
\v 9 Maromak, hau sei hananu kantiku foun ba Ita Boot;
\q2 hau sei toka muzika ba Ita Boot ho viola tali sanulu.
\q1 
\v 10 Ita Boot mak halo liurai manaan;
\q2 Ita Boot salva Ita Boot nia atan David.
\q1 
\v 11 Salva hau husi surik nebee hamate ema;
\q2 hasai hau husi inimigu rai liur nia liman laran.
\q1 Sira nia ibun nakonu ho buat bosok;
\q2 sira foti liman hodi halo juramentu falsu.
\b
\q1 
\v 12 Ami harohan atu ami nia oan mane joven sira
\q2 sai hanesan ai huun nebee buras ba dadauk,
\q1 no ami nia oan feto sira
\q2 sai hanesan ai riin palasiu nian nebee bahat tiha halo furak.
\q1 
\v 13 Ami husu atu ami nia armazen nakonu
\q2 ho ai haan oi-oin,
\q1 ami nia bibi aumenta rihun ba rihun,
\q2 tokon ba tokon iha ami nia rai,
\q2 
\v 14 no ami nia karau kabuk todan.
\q1 Ami harohan atu inimigu sira la bele baku rahun moru nebee haleu ami nia sidade,
\q2 inimigu sira la bele lori ami baa dadur iha rai seluk,
\q2 no la iha tanis halerik iha ami nia estrada boot.
\q1 
\v 15 Povu nebee mak moris hanesan nee, sira hetan ksolok;
\q2 povu nebee adora NAI nudar sira nia Maromak, sira hetan ksolok.
\c 145
\s1 Hahii Nai Maromak tanba Nia laran diak
\d Salmu hahii nian husi David.
\b
\q1 
\v 1 Hau nia Maromak, hau nia Liurai, hau sei foti aas Ita Boot;
\q2 hau sei hahii Ita Boot nia naran too tinan ba tinan.
\q1 
\v 2 Loro-loron hau sei hahii Ita Boot;
\q2 hau sei tane aas Ita Boot nia naran tinan ba tinan.
\q1 
\v 3 NAI Maromak nee boot, Nia serve atu ita hahii;
\q2 Nia boot teb-tebes, la iha ida mak bele kompriende too iha nebaa.
\b
\q1 
\v 4 Jerasaun ida sei gaba Ita Boot nia servisu ba jerasaun tuir mai;
\q2 sira konta tutan buat boot nebee Ita Boot halo.
\q1 
\v 5 Hau sei foo sai Ita Boot nia naran boot ho kbiit nebee furak;
\q2 hau sei medita buat furak nebee Ita Boot halo tiha ona.
\q1 
\v 6 Sira sei konta buat makaas nebee Ita Boot halo;
\q2 hau sei foo sai katak Ita Boot nee makaas teb-tebes.
\q1 
\v 7 Sira selebra Ita Boot nia laran osan mean,
\q2 no haksolok hananu kona ba Ita Boot nia lia loos.
\b
\q1 
\v 8 NAI Maromak nee laran luak no laran diak;
\q2 Nia Pasiensia Nain, no nakonu ho domin rohan-laek.
\q1 
\v 9 NAI diak ba ema hotu-hotu;
\q2 Nia hadomi buat hotu nebee Nia kria ona.
\q1 
\v 10 NAI, Ita Boot nia liman fatin sei agradese ba Ita Boot;
\q2 Ita Boot nia povu santu sei hahii Ita Boot.
\q1 
\v 11 Sira foo sai Ita Boot nia kbiit boot nudar Liurai,
\q2 no konta kona ba Ita Boot nia forsa,
\q1 
\v 12 atu nunee ema hotu bele hatene buat makaas nebee Ita Boot halo,
\q2 no Ita Boot nia ukun makaas ho furak teb-tebes.
\q1 
\v 13 Ita Boot mak Liurai tinan ba tinan;
\q2 Ita Boot ukun husi jerasaun ba jerasaun.
\b
\q1 NAI Maromak sempre kaer metin Nia promesa;
\q2 Ninia hahalok tomak nakonu ho domin.
\q1 
\v 14 NAI tane ema nebee monu ba susar laran;
\q2 Nia foti sae ema nebee bonko tanba naha todan.
\q1 
\v 15 Kriatura hotu-hotu nia matan hateke ba Ita Boot,
\q2 atu Ita Boot foo ai haan ba sira tuir nia tempu.
\q1 
\v 16 Ita Boot loke liman,
\q2 buat moris hotu-hotu hetan ai haan too bosu.
\q1 
\v 17 NAI halo saida deit sempre loos;
\q2 Ninia hahalok tomak nakonu ho domin.
\q1 
\v 18 NAI besik ema nebee harohan ba Nia;
\q2 Nia besik ba see-see deit mak harohan ba Nia ho laran.
\q1 
\v 19 Nia hataan ema nebee hamtauk Nia tuir sira nia hakarak;
\q2 Nia rona sira nia halerik hodi salva sira.
\q1 
\v 20 NAI tau matan ba ema hotu nebee hadomi Nia,
\q2 maibee Nia sei halo rahun tiha ema aat sira hotu.
\b
\q1 
\v 21 Hau nia ibun sei hahii NAI Maromak;
\q2 kriatura ida-idak hahii Nia naran santu
\q2 tinan ba tinan.
\c 146
\s1 Hahii Nai Maromak tanba Nia diak
\q1 
\v 1 Hahii NAI Maromak!
\b
\q1 Hau hatete ba hau nia aan, hahii NAI ba!
\q2 
\v 2 Iha hau nia moris tomak, hau sei hahii NAI;
\q2 durante hau sei moris hau hananu hahii hau nia Maromak.
\b
\q1 
\v 3 Lalika tau laran ba ukun nain sira;
\q2 keta tau fiar ba ema kriatura, tanba sira la bele salva ema.
\q1 
\v 4 Bainhira sira nia iis kotu, sira fila fali ba rai rahun;
\q2 iha loron nee kedas, sira nia planu mos mate ona.
\b
\q1 
\v 5 Ema nebee rekonhese Jacó nia Maromak nudar sira nia Ajudador,
\q2 ema nebee laran metin ba NAI nudar sira nia Maromak, sira hetan ksolok.
\q1 
\v 6 \x + \xo 146:6 \xt Apostolu sira nia Istoria 4:24, 14:15\x*Nia mak Kriador lalehan ho rai,
\q2 tasi ho buat hotu iha laran;
\q2 Nia kaer metin Nia liafuan too tinan ba tinan.
\q1 
\v 7 Nia foo justisa ba sira nebee ema seluk hanehan;
\q2 Nia foo ai haan ba sira nebee hamlaha.
\b
\q1 NAI hasai dadur sira;
\q2 
\v 8 NAI halo ema matan delek bele haree;
\q1 NAI foti sae ema nebee bonko tanba naha todan;
\q2 NAI hadomi ema nebee moris loos.
\q1 
\v 9 NAI tau matan ba ema lao rai;
\q2 Nia tulun oan kiak ho feto faluk sira,
\q2 maibee Nia halo kleuk tiha ema aat sira nia dalan.
\b
\q1 
\v 10 NAI Maromak ukun tinan ba tinan;
\q2 Siaun oan sira, imi nia Maromak ukun husi jerasaun ba jerasaun.
\b
\q1 Hahii NAI Maromak!
\c 147
\s1 Salmu hahii Nai Maromak
\q1 
\v 1 Hahii NAI Maromak!
\b
\q1 Ita hananu hahii ita nia Maromak, nee diak no furak teb-tebes,
\q2 tanba Nia serve duni atu ita hahii.
\q1 
\v 2 NAI Maromak harii fali Jerusalém;
\q2 Nia halibur fila fali Israel oan sira nebee ema soe ba iha rai seluk.
\q1 
\v 3 Nia kura ema nebee laran dodok,
\q2 no kurtivu sira nia kanek.
\q1 
\v 4 Nia desidi fitun hira mak iha lalehan
\q2 hodi foo naran ba fitun ida-idak.
\q1 
\v 5 Ita nia Nai nee boot ho kbiit makaas;
\q2 Nia matenek la iha rohan.
\q1 
\v 6 NAI Maromak foti sae ema mukit,
\q2 maibee soe ema aat tuun ba iha rai.
\b
\q1 
\v 7 Hananu kantiku agradese nian ba NAI Maromak;
\q2 toka viola halo muzika ba ita nia Maromak.
\q1 
\v 8 Nia hodi kalohan taka lalehan;
\q2 Nia foo udan ba rai
\q2 hodi halo duut moris iha foho leten.
\q1 
\v 9 Nia foo ai haan ba animal
\q2 ho mos ba manu metan oan nebee lian hodi husu ai haan.
\q1 
\v 10 Laos kuda nia forsa mak halo kontenti NAI nia laran;
\q2 Nia laos haksolok tanba funu nain nebee forti.
\q1 
\v 11 Maibee NAI kontenti ho ema nebee mak hamtauk Nia;
\q2 Nia haksolok ho ema nebee mak laran metin ba Nia domin rohan-laek.
\b
\q1 
\v 12 Jerusalém, tane aas NAI Maromak ba;
\q2 Siaun, hahii o nia Maromak ba.
\q1 
\v 13 Tanba Nia haforsa o nia portaun boot,
\q2 no foo bensaun ba o nia povu.
\q1 
\v 14 Nia halo o nia fronteira seguru,
\q2 no habosu o nia povu ho hahaan diak nian.
\q1 
\v 15 Nia hatuun Nia orden ba iha rai;
\q2 Nia liafuan semo lalais liu.
\q1 
\v 16 Nia kari neve\f + \fr 147:16 \ft Neve ho lian Indonézia dehan “salju”.\f* hanesan bibi fulun mutin;
\q2 Nia halo namkari jelu fatuk rahun hanesan ahu kdesan.
\q1 
\v 17 Nia tuda tuun udan jelu fatuk hanesan britas.
\q2 See mak bele aguenta malirin boot nebee Nia hatuun nee?
\q1 
\v 18 Nia foo orden mak jelu nee nabeen;
\q2 Nia haruka anin mak bee suli tuun.
\q1 
\v 19 Nia foo sai Nia liafuan ba Jacó nia jerasaun;
\q2 Nia hatuun Nia lei ho regulamentu ba Israel.
\q1 
\v 20 Nia nunka halo nunee ba nasaun sel-seluk;
\q2 sira la hatene Nia lei.
\b
\q1 Hahii NAI Maromak!
\c 148
\s1 Lalehan ho rai hahii Nai Maromak ba!
\q1 
\v 1 Hahii NAI Maromak!
\b
\q1 Imi nebee iha lalehan, hahii NAI Maromak ba;
\q2 buat hotu iha leten aas ba, hahii Nia ba.
\q1 
\v 2 Maromak nia anju sira hotu, hahii Nia;
\q2 tropas lalehan nian, hahii Nia ba.
\q1 
\v 3 Loro matan ho fulan, hahii Nia;
\q2 fitun sira hotu nebee lakan nabilan, hahii Nia ba.
\q1 
\v 4 Lalehan leten aas ba, hahii Nia,
\q2 nunee mos bee hotu iha kalohan leten.
\q1 
\v 5 Buat sira nee hotu hahii NAI Maromak nia naran ba,
\q2 tanba Nia foo orden mak buat sira nee iha.
\q1 
\v 6 Nia harii buat sira nee nafatin ba nafatin;
\q2 orden nebee Nia foo nee vale tinan ba tinan.
\b
\q1 
\v 7 Buat hotu-hotu iha mundu, hahii NAI Maromak ba!
\q2 Tasi laran klean ho animal bo-boot tasi nian,
\q1 
\v 8 rai lakan ho udan jelu fatuk, neve ho abu-abu,
\q2 anin boot makaas nebee halao Nia orden,
\q1 
\v 9 foho bo-boot ho foho kiik sira hotu,
\q2 ai nebee foo fuan ho ai huun sedru hotu-hotu,
\q1 
\v 10 animal fuik ho karau hotu-hotu,
\q2 animal nebee dolar iha rai ho mos manu fuik,
\q1 
\v 11 liurai mundu nian ho povu nasaun hotu-hotu,
\q2 liurai oan sira ho ukun nain sira hotu iha mundu,
\q1 
\v 12 mane klosan ho feto klosan sira,
\q2 ferik-katuas ho labarik sira.
\b
\q1 
\v 13 Hotu-hotu hahii NAI Maromak nia naran ba,
\q2 tanba Nia naran boot liu hotu-hotu;
\q2 Nia kbiit aas liu lalehan ho rai.
\q1 
\v 14 Nia halo Nia povu sai forti tiha,
\q2 atu sira bele hahii Nia.
\q1 Sira nee mak ema nebee foo laran ba Nia;
\q2 sira nee ema Israel, ema nebee besik Nia.
\b
\q1 Hahii NAI Maromak!
\c 149
\s1 Kantiku hahii Nai Maromak tanba Nia tulun Israel
\q1 
\v 1 Hahii NAI Maromak!
\b
\q1 Hananu kantiku foun ba NAI Maromak;
\q2 hahii Nia iha Nia povu santu sira nia klaran.
\b
\q1 
\v 2 Israel oan sira, kontenti ba, tanba Nia mak ita nia Kriador;
\q2 Siaun oan sira, haksolok ba, tanba Nia mak ita nia Liurai.
\q1 
\v 3 Mai ita bidu hodi hahii Nia naran;
\q2 mai ita baku tambor ho toka viola hodi halo muzika ba Nia,
\q1 
\v 4 tanba NAI Maromak nia laran haksolok ho Nia povu;
\q2 Nia tane aas ema mukit sira hodi halo sira manaan.
\q1 
\v 5 Maromak nia povu santu, mai ita haksolok tanba Nia foti aas ita;
\q2 mai ita hananu haksolok iha ita nia toba fatin.
\b
\q1 
\v 6 Ita nia ibun sei hahii Maromak;
\q2 ita nia liman kaer surik oin-kotuk kroat hotu
\q1 
\v 7 hodi selu fali nasaun jentiu sira nia hahalok aat,
\q2 no kastigu sira nia povu;
\q1 
\v 8 atu kesi sira nia liurai ho korenti;
\q2 atu futu sira nia nai ulun sira ho korenti besi,
\q1 
\v 9 atu kastigu nasaun sira nee tuir desizaun nebee Maromak hatuun tiha ona.
\q2 Ho nunee Nia povu santu sai naran boot.
\b
\q1 Hahii NAI Maromak!
\c 150
\s1 Knananuk hahii Nai Maromak
\q1 
\v 1 Hahii NAI Maromak!
\b
\q1 Hahii Maromak iha Nia fatin santu;
\q2 hahii Nia iha Nia lalehan aas nebaa.
\q1 
\v 2 Hahii Nia tanba Nia halo buat mesak furak;
\q2 hahii Nia tanba Nia boot liu buat hotu-hotu.
\q1 
\v 3 Huu karau dikur hodi hahii Nia;
\q2 toka viola oi-oin hodi hahii Nia.
\q1 
\v 4 Baku tambor no bidu hodi hahii Nia;
\q2 toka viola no huu fafulu hodi hahii Nia.
\q1 
\v 5 Baku taxu hodi hahii Nia;
\q2 baku taxu halo lian boot hodi hahii Nia.
\q1 
\v 6 Buat hotu-hotu nebee iha iis, hahii NAI Maromak ba.
\b
\q1 Hahii NAI Maromak! 
