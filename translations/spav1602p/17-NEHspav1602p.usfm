\c 11
\m 
\v 1 \w Y|strong="H3068"\w* \w HABITARON|strong="H3427"\w* \w los|strong="H3427"\w* \w príncipes|strong="H8269"\w* \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w* \w en|strong="H4480"\w* \w Jerusalem|strong="H3389"\w*; \w mas|strong="H4480"\w* \w el|strong="H5307"\w* resto \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w* \w echó|strong="H5307"\w* \w suertes|strong="H1486"\w* \w para|strong="H4480"\w* traer uno \w de|strong="H4480"\w* \w diez|strong="H6235"\w* \w que|strong="H4480"\w* morase \w en|strong="H4480"\w* \w Jerusalem|strong="H3389"\w*, \w ciudad|strong="H5892"\w* \w santa|strong="H6944"\w*, y las \w nueve|strong="H8672"\w* \w partes|strong="H3027"\w* \w en|strong="H4480"\w* las \add otras\add* \w ciudades|strong="H5892"\w*.
