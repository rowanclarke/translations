\id MRK  
\h Marcos 
\toc1 TU'UN VA'A NI CHAA SAN MARCOS 
\toc2 Marcos 
\toc3 Mr. 
\mt2 EL SANTO EVANGELIO SEGUN SAN MARCOS 
\mt1 TU'UN VA'A NI CHAA SAN MARCOS 
\c 1  
\s1 Juan, cha̱a skuánducha 
\p  
\v 1 Yá'a kéjá'á tú'un va̱'a máá Jesucristo, Se̱'e Dios.  
\v 2 Te súan ni̱ chaa Isaías tutu̱, chi cha̱a jáni tu̱'un Dios ni̱ kuu‑de sáá: Kuni so̱'o‑ró, chi̱ tájí‑rí ndajá'a̱‑rí kuxnúú‑de jaa̱‑de sátu̱'a‑de ichi‑ro.  
\v 3 Te ndajá'a̱‑ún, kana jaa‑de onde̱ nuu̱ ñú'un té'é: Sátu̱'a‑ró íchi máá Jíto'o̱‑yo̱ te sándóó‑ró íchi‑yá, achi̱‑de, áchí Isaías.  
\v 4 Te Juan, ni̱ skuánducha‑dé onde̱ nuu̱ ñú'un té'é. Te ni̱ jani‑de tu̱'un jánducha jíín tú'un nakani ini̱, náva̱'a sá'a Dios tu̱ká'nu ini̱ nuu̱ kuáchi.  
\v 5 Te ni̱ cha̱koyo ta̱ká ña̱yɨvɨ ndáñúu̱ Judea, jíín táká ña̱yɨvɨ ñúu̱ Jerusalén. Te ni̱ skuánducha‑dé‑i ini̱ yu̱cha Jordán. Te kánakani ndaa̱‑i kua̱chi‑i yúan.  
\v 6 Te sa'ma ní ñu̱'un Juan ni̱ kuu ixi camello, jíín ɨ́ɨn sánchi̱i ñii nú'ni̱ chi̱i‑de. Te ni̱ yee‑dé ndɨkuá'yú jíín ndúxi yoko̱ yuku.  
\v 7 Te ni̱ jani‑de tu̱'un: Ichi yatá‑rí va̱i ɨɨn I'a̱ kúñá'nu‑ga̱ vásá rúu̱, ja̱ tú kúñá'nu‑ri̱ jukui̱ta ndee‑ri̱ te ndájí‑rí ñii yí'i ndija̱n‑yá, áchí‑de.  
\v 8 Te ruu̱, chi̱ jíín ndúcha skuánducha‑rí róó jíná'an‑ró, ko I'a̱‑ún, chi̱ jíín Espíritu Santo skuánducha‑yá róó, áchí Juan. 
\s1 Ja̱ ní janducha Jesús ni̱ sá'a Juan 
\p  
\v 9 Te ni̱ kuu kɨvɨ̱. Te Jesús, ni̱ kenda‑ya̱ ñúu̱ Nazaret ndañúu̱ Galilea. Te ni̱ janducha‑yá ni̱ sá'a Juan ini̱ yu̱cha Jordán.  
\v 10 Te ni̱ nana‑ni‑ya̱ iní nducha‑ún. Te ni̱ jini̱‑ya̱ já ní nuña andɨ́vɨ́. Te Espíritu ni̱ jungava sɨkɨ̱‑yá nátu̱'un paloma.  
\v 11 Te ichi ándɨ́vɨ́ ní kenda ɨɨn tu̱'un ni̱ ka'a̱n: Máá‑ró kúu Se̱'e‑ri̱, te kúndá'ú ini̱‑ri̱ róó. Te kúsɨɨ̱ iní‑ri̱ jíín‑ró. Achí. 
\s1 Sɨkɨ̱ já ní jito nchaa̱ tá'an Satanás jíín‑yá 
\p  
\v 12 Yúan‑na te máá Espíritu, ni̱ chundá'á‑ni‑ya̱ kuá'a̱n‑ya̱ ondé ñu'un té'é.  
\v 13 Te ni̱ kanchaa̱‑ya̱ núu̱ ñú'un té'é yúan uu̱ xiko kɨvɨ̱, te vásá ní jito nchaa̱ tá'an Satanás jíín‑yá. Te ni̱ kandee‑ya̱ jíín kɨ́tɨ xáa̱n. Te máni ndajá'a̱ ándɨ́vɨ́ ní ka̱jatíñu nuu̱‑yá. 
\s1 Ndasa ni̱ kejá'á Jesús jáni‑ya̱ tú'un 
\p  
\v 14 Yúan‑na te onde̱ ni̱ kɨ̱vɨ Juan veka̱a, te ni̱ jaa̱ Jesús ndañúu̱ Galilea, jáni‑ya̱ tú'un va̱'a Dios.  
\v 15 Te ni̱ kachi̱‑ya̱: A ni̱ ji̱nu kɨvɨ̱, te a yani koo ñuu̱ nuu̱ tá'ú Dios tiñu. Nakani ini̱ jíná'an‑ró, te kandíja‑ró tú'un va̱'a‑ya̱. 
\s1 Ja̱ ní kana‑ya̱ xiní kúu̱n tá'a̱n cha̱a 
\p  
\v 16 Te ni̱ ja̱'a‑ya̱ xíin mar Galilea kua'a̱n‑ya̱. Te ni̱ jini̱‑ya̱ núu̱ Simón jíín ñaní‑de Andrés, káskuíta ka'nu‑de ñunu‑dé ini̱ mar, chi cha̱a kátɨɨn ti̱yáká kákuu‑de.  
\v 17 Te ni̱ ka'a̱n Jesús jíín‑de: Kundiki̱n ruu̱ kikoyo‑ró, te ná násá'a‑ri̱ róó cha̱a tɨɨn ña̱yɨvɨ. Achí‑ya̱.  
\v 18 Yúan‑na te ni̱ ka̱xndóo‑ni‑de ñunu‑dé. Te ni̱ kandiki̱n‑de‑ya̱.  
\v 19 Te ni̱ jika‑ya̱ ɨ́ɨn tí'lí‑ga̱. Te ni̱ jini̱‑ya̱ núu̱ Jacobo jíín ñaní‑de Juan. Se̱'e Zebedeo kákuu cha̱a‑ún. Suni ká'i̱in cha̱a‑ún ini̱ barco, kánaku'ni̱‑de ñunu‑dé.  
\v 20 Te ni̱ kana‑ni‑ya̱ xiní‑dé. Te ni̱ ka̱skéndo̱o‑de táa̱‑de Zebedeo ini̱ barco‑ún jíín mozo‑de, te kua̱ngoyo‑de yata̱‑yá. 
\s1 Ja̱ ní keñi'in‑ya̱ tachí kíni 
\p  
\v 21 Te ni̱ kɨ̱vɨ koyo‑de ini̱ ñuu̱ Capernaum. Te ta̱ká kɨvɨ̱ ndéta̱tú ni̱ kɨ̱vɨ‑ni Jesús ini̱ ve̱'e sinagoga, te ni̱ stá'a̱n‑ya̱ tú'un.  
\v 22 Te ni̱ ka̱naa ini‑i kájini so̱'o‑i tu̱'un stá'a̱n‑ya̱, chi ni̱ stá'a̱n‑ya̱ nátu̱'un cha̱a ndíso tíñu, nasu̱ nátu̱'un cha̱a káchaa tutu̱.  
\v 23 Te ini̱ ve̱'e sinagoga‑ún kándee ɨɨn cha̱a tá'a̱n tachi̱ kíni. Te cha̱a‑ún, ni̱ kana kó'ó‑de:  
\v 24 Na̱ún kuní‑ní jíín‑ná jíná'an‑ná, Jesús ñuu̱ Nazaret. Va̱i‑ní xnáa‑ní náá náún. A jiní‑ná na̱ níí kúu, cha̱a íó ndoo nuu̱ Dios, áchí.  
\v 25 Te Jesús, ni̱ ka'a̱n xaa̱n‑yá jíín: Kasu̱ yu'u‑ro, te kenda‑ró‑de, áchí‑ya̱.  
\v 26 Te máá tachí kíni‑ún, xaa̱n ní ja'ni yí'í cháa‑ún. Te ni̱ kana jíkó'ó. Te ni̱ kenda kua'a̱n ini̱‑de.  
\v 27 Te ndivii‑í ni̱ ka̱naa iní‑i kánde̱'é‑i. Te kánda̱tu̱'ún máá‑i: Na̱ún kúu ya̱'á. Tu̱'un jáá kúu náún, chi̱ tá'ú ní'in‑de tiñu nuu̱ tachí kíni, te kájandatu̱ nuu̱‑dé, áchí‑i.  
\v 28 Te ni̱ jicha̱ nu̱u‑ni tu̱'un‑ya̱ kuá'a̱n nɨ́ɨ́ táká ndañúu̱ ja̱ ní jíkó ndúu̱ yuñúu̱ Galilea.  
\v 29 Te ni̱ ka̱ndenda‑ni‑ya̱ iní ve̱'e sinagoga. Te ni̱ cha̱koyo‑ya̱ jíín Jacobo jíín Juan onde̱ ve'e Simón jíín Andrés.  
\v 30 Te náchi̱só Simón, kátúu‑ñá yí'i ki̱ji‑ña. Te ni̱ kaka'a̱n‑ni‑de jíín‑yá ndasa kuu máá‑ña.  
\v 31 Yúan‑na te ni̱ jaa̱‑ya̱. Te ni̱ tɨɨn‑ya̱ ndá'a‑ñá. Te ni̱ ndukani‑ya̱‑ñá. Te ni̱ kee‑ni ki̱ji‑ún‑ña. Te ni̱ jatíñu‑ña núu̱‑yá jíná'an‑ya̱. 
\s1 Ja̱ ní nasáva̱'a‑ya̱ kuá'a̱ ñáyɨvɨ káku'u̱ 
\p  
\v 32 Te nuu̱ ní ini, ni̱ ke̱e ndika̱ndii, te ni̱ cha̱koyo cha̱a kándi̱so ña̱yɨvɨ káku'u̱, jíín ñáyɨvɨ tá'a̱n tachi̱ kíni.  
\v 33 Te ta̱ká ña̱yɨvɨ ñúu̱‑ún, ni̱ ka̱kutútú‑i yuxé'é yúan.  
\v 34 Te ni̱ nasáva̱'a‑ya̱ kuá'a̱ ñáyɨvɨ káku'u̱ tɨnɨ̱ nuu̱ kué'e̱. Te ni̱ kiñi'in‑ya̱ kuá'a̱ tachí kíni kája'a̱n. Te tú ní já'a‑ya̱ tú'un ka'a̱n tachi̱ kíni‑ún, chi̱ a kájini̱‑ún‑yá. 
\s1 Ja̱ ní jika̱n ta'u̱‑yá nuu̱ ñú'un té'é 
\p  
\v 35 Te ña'a̱n xaa̱n ní nduko̱o‑ya̱, onde̱ ná íñaa‑gá. Te ni̱ kenda‑ya̱ te kua'a̱n‑ya̱ ɨ́ɨn lugar ñu'un té'é. Te yúan ni̱ jika̱n ta'u̱‑yá.  
\v 36 Te Simón jíín cháa káxiu̱kú jíín‑de, ni̱ kandiki̱n‑de‑ya̱.  
\v 37 Te ni̱ ka̱nani'i̱n‑dé‑ya̱. Te káka'a̱n‑de jíín‑yá: Ta̱ká ña̱yɨvɨ, kánandúkú‑i níí, áchí‑de.  
\v 38 Te ni̱ kachi̱‑ya̱ jíín‑de: Ná kí'o̱n sáva‑ga̱ ñuu̱ káxiu̱kú yáni, náva̱'a kani‑ri̱ tu̱'un yúan, chi ja̱ yúán ní chaa̱‑ri̱. Achí‑ya̱.  
\v 39 Te kua'a̱n‑ya̱. Te ni̱ jani‑ya̱ tú'un ini̱ ta̱ká ve'e sinagoga nɨ́ɨ́ ndáñúu̱ Galilea. Te ni̱ kiñi'in‑ya̱ tachí kíni kája'a̱n. 
\s1 Ja̱ ní nasáva̱'a‑ya̱ ɨ́ɨn cha̱a té'yu̱ ndɨ̱'yi 
\p  
\v 40 Te ɨɨn cha̱a té'yu̱ ndɨ̱'yi, ni̱ chaa̱‑de nuu̱‑yá. Te ni̱ jukuiñi̱ jítɨ́‑de nuu̱‑yá, ká'a̱n nda̱'ú‑de jíín‑yá: Nú kuní‑ní, te kuu nasándoo‑ní náá, áchí‑de.  
\v 41 Te Jesús, ni̱ kundá'ú ini̱‑ya̱‑dé. Te ni̱ skáa̱‑ya̱ ndá'a‑yá. Te ni̱ ké'é‑yá‑de. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Kuní‑ri̱. Ná ndúndoo‑ró. Achí‑ya̱.  
\v 42 Te máá súan‑ni ni̱ ka'a̱n‑ya̱, te ndɨ̱'yi té'yu̱ cha̱a‑ún, kua'a̱n‑ni. Te ni̱ ndundoo‑ni‑de.  
\v 43 Yúan‑na te ni̱ ka'a̱n xaa̱n‑yá jíín‑de. Te tájí‑ni‑ya̱‑dé ki'i̱n‑de.  
\v 44 Te ká'a̱n‑ya̱ jíín‑de: Koto‑ró, ma̱ ká'a̱n kutɨ‑ro jíín ní ɨɨn‑i, chi̱ kuá'án, te stá'a̱n‑ro̱ máá‑ró núu̱ sutú. Te kundá'á‑ró ndátíñu stá'a̱n‑ro̱ núu̱‑dé, náva̱'a kuni̱‑de ja̱ ní ndundoo‑ró, nátu̱'un ni̱ tá'ú Moisés tiñu sáá, áchí‑ya̱.  
\v 45 Ko máá‑de, ni̱ kenda‑de kua'a̱n‑de. Te ni̱ kejá'á‑de ni̱ jacha̱ xaa̱n‑dé tu̱'un. Te ni̱ kachi̱‑de ná ni̱ ta'a̱n‑de. Te tuká‑ni ní kúu kɨ̱vɨ ndiji̱n Jesús onde̱ ini̱ ñuu̱, ko ni̱ kanchaa̱ sɨ́ɨn‑ya̱ ɨ́ɨn lugar ñu'un té'é. Te yúan ni̱ kikoyo ña̱yɨvɨ táká lado nuu̱‑yá. 
\c 2  
\s1 Cha̱a ni̱ kuyúnú 
\p  
\v 1 Te ni̱ kuu yaku̱ kɨvɨ̱. Te ni̱ kɨ̱vɨ tuku‑ya̱ ñúu̱ Capernaum. Te ni̱ kenda tu̱'un ja̱ vé'e kánchaa̱‑ya̱.  
\v 2 Te ni̱ ka̱kutútú kuá'a̱ xáa̱n ñáyɨvɨ núu̱‑yá. Te tuká ní kánda kutɨ yúxé'é kuíñi‑i. Te ni̱ jani‑ya̱ tú'un nuu̱‑í.  
\v 3 Yúan‑na te ni̱ chaa̱ yaku̱ cha̱a nuu̱‑yá jíín ɨ́ɨn cha̱a ni̱ kuyúnú, ja̱ kúu̱n tá'a̱n‑de kándi̱so‑de cha̱a‑ún.  
\v 4 Te ja̱ kuá'a̱ ñáyɨvɨ‑ún, te tú ní kúu kɨ̱vɨ‑de nuu̱‑yá jíín cháa‑ún. Te ni̱ ka̱juña‑de xini̱ vé'e nuu̱ kándee‑ya̱‑ún. Te nuu̱ ní kakaa̱n‑de yau̱‑ún, ni̱ ka̱skúun‑de ji̱to yuu núu̱ kátúu cháa ni̱ kuyúnú‑ún.  
\v 5 Te ni̱ jini̱ Jesús ja̱ kákandíja máá‑de. Te ni̱ ka'a̱n‑ya̱ jíín cháa ni̱ kuyúnú‑ún: Hijo, a íó tu̱ká'nu ini̱ nuu̱ táká kua̱chi‑ró, áchí‑ya̱.  
\v 6 Te yúan káxiu̱kú yakú cha̱a káchaa tutu̱. Te yu̱án, ni̱ ka̱jani ini̱:  
\v 7 Naja̱ ká'a̱n cha̱a yá'a súan. Núsáá te tu̱'un ndɨva̱'a ká'a̱n‑de. Ndéja̱ kúu sá'a tu̱ká'nu ini̱ nuu̱ kuáchi, chi̱ ɨɨn‑ni máá Dios, áchí.  
\v 8 Te ni̱ juku̱'un‑ni ini̱ Jesús ja̱ súan kájani ini̱. Te ni̱ ka'a̱n‑ya̱ jíín: Naja̱ kájani ini̱‑ro̱ súan.  
\v 9 Te ja̱ úu̱ tu̱'un yá'a, ndéja̱ yíí‑ga̱ káa. Á ka'a̱n‑ri̱ jíín cháa ni̱ kuyúnú yá'a: A íó tu̱ká'nu ini̱ nuu̱ táká kua̱chi‑ró; xí ká'a̱n‑ri̱ jíín‑de: Nduko̱o, te naki'in‑ró jíto yuu‑ro, te ki'i̱n‑ro̱ jíín, achi̱‑ri̱ náún.  
\v 10 Ko náva̱'a ná kuní‑ro̱ já máá Sé'e cha̱a, ndíso‑ya̱ tíñu ini̱ ñu̱yɨ́vɨ yá'a ja̱ sá'a‑ya̱ túká'nu ini̱ nuu̱ kuáchi, te ná ká'a̱n‑ri̱ ɨnga̱ tu̱'un jíín cháa ni̱ kuyúnú yá'a núsáá:  
\v 11 Jíín‑ró ká'a̱n‑ri̱: Nduko̱o, te naki'in‑ró jíto yuu‑ro, te no'o̱n‑ro̱ vé'e‑ró, áchí‑ya̱ jíín‑de.  
\v 12 Te máá cháa‑ún, ni̱ nduko̱o‑ni‑de. Te ni̱ naki'in‑de ji̱to yuu‑dé. Te ni̱ ndenda‑de kua'a̱n‑de nuu̱ ñáyɨvɨ kuá'a̱‑ún. Te ndivii‑í, ni̱ ka̱kee nuu̱‑í kánde̱'é‑i. Te ni̱ ka̱nakana jaa‑i Dios: Na̱ tú kájini̱ kutɨ‑yo súan nátu̱'un ya̱'á, áchí‑i. 
\s1 Ja̱ ní kana‑ya̱ xiní Leví 
\p  
\v 13 Te ni̱ kenda tuku Jesús kua'a̱n‑ya̱ ondé yu'u mar. Te ta̱ká ña̱yɨvɨ, ni̱ ja̱koyo‑i nuu̱‑yá. Te ni̱ stá'a̱n‑ya̱ tú'un nuu̱‑í.  
\v 14 Te ni̱ ja̱'a‑ya̱ kuá'a̱n‑ya̱. Te ni̱ jini̱‑ya̱ núu̱ Leví, se̱'e Alfeo, kánchaa̱‑de nuu̱ kútútú xú'ún ñúu̱. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Kundiki̱n‑ro̱ rúu̱, áchí‑ya̱. Te ni̱ ndukuiñi̱‑de. Te ni̱ ndiki̱n‑de‑ya̱.  
\v 15 Te Jesús, ni̱ yee‑yá staa̱ iní ve̱'e‑de. Te suni kua'a̱ cháa xíní jíín cháa ká'i̱o kua̱chi, káyee‑dé staa̱ jíín Jesús jíín cháa káskuá'a jíín‑yá, chi̱ íó kua'a̱‑dé kándiki̱n‑de‑ya̱.  
\v 16 Te cha̱a káchaa tutu̱, jíín cháa fariseo, kánde̱'é‑de ja̱ yée‑yá staa̱ jíín cháa xíní jíín cháa ká'i̱o kua̱chi. Te ni̱ kaka'a̱n‑de jíín cháa káskuá'a jíín‑yá: Naja̱ yée‑yá jí'i‑ya̱ jíín cháa xíní jíín cháa ká'i̱o kua̱chi, áchí‑de.  
\v 17 Yúan‑na te ni̱ jini so̱'o Jesús. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Cha̱a ká'i̱o ndáján, tú kánandɨ'ɨ‑de cha̱a táná, chi cha̱a káku'u̱ kúu ja̱ kájinu ñú'ún. Na̱ tú va̱i‑ri̱ kana‑ri̱ xini̱ cháa ndaa̱, chi cha̱a ká'i̱o kua̱chi kána‑ri̱ xini̱, áchí‑ya̱. 
\s1 Sɨkɨ̱ já kóndicha̱ ini̱ 
\p  
\v 18 Te cha̱a káskuá'a jíín Juan, jíín já káskuá'a jíín cháa fariseo, ká'i̱o ndicha̱ ini̱‑de. Te ni̱ cha̱koyo cha̱a‑ún. Te ni̱ kaka'a̱n‑de jíín‑yá: Cha̱a káskuá'a jíín Juan jíín já káskuá'a jíín cháa fariseo, naja̱ ká'i̱o ndicha̱ ini̱‑de, te cha̱a káskuá'a jíín‑ní, tú ká'i̱o ndicha̱ ini̱‑de, áchí‑de.  
\v 19 Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Á kuu kondicha̱ ini̱ ña̱yɨvɨ ká'i̱in viko tánda'a, te nú kánchaa̱ yii jíín‑i. Chi̱ nú nini kánchaa̱ yii jíín‑i, ma̱ kúu kondicha̱ ini̱‑i.  
\v 20 Ko chaa̱ ɨɨn kɨvɨ̱ já yíi‑ún, kuxio‑de nuu̱‑í. Te kɨvɨ̱‑ún, kuu kondicha̱ ini̱‑i.  
\v 21 Tú ni ɨɨn nachu'un sa'ma jáá núu̱ sú'nu̱ tu̱'ú. Chi̱ nú súan, te suni máá já ní nuku̱'un jáá‑ún ka'ncha̱‑ga̱ ja̱ tu̱'ú‑ún, te ja̱ te̱'ndé‑ún ví'í‑gá te'nde̱.  
\v 22 Te tú ni ɨɨn chu'un vino jáá iní ñii tú'ú. Chi̱ nú súan, te máá vino jáá‑ún ndátá ñíi‑ún, te katɨ vino‑ún, te ñii‑ún naa‑ní. Ko ñii jáá jíín vino jáá, kúu ja̱ kúu ku'un, áchí‑ya̱. 
\s1 Ja̱ ní ka̱kachi‑de yoko trigo kɨvɨ̱ ndéta̱tú 
\p  
\v 23 Te ɨɨn kɨvɨ̱ ndéta̱tú ni̱ ja̱'a Jesús kua'a̱n‑ya̱ ɨ́ɨn nuu̱ káa trigo. Te cha̱a káskuá'a jíín‑yá, kájika‑de kua'a̱n‑de. Te kákachi‑de yoko.  
\v 24 Yúan‑na te cha̱a fariseo, ni̱ kaka'a̱n‑de jíín‑yá: Na̱ún kúu jia̱n. Naja̱ kásá'a‑de súan kɨvɨ̱ ndéta̱tú, chi̱ tú íó ley. Achí‑de.  
\v 25 Te máá‑yá, ni̱ ka'a̱n‑yá jíín‑de: Á tú ní káka'u kutɨ‑ro tutú na̱ún ní sá'a David, kɨvɨ̱ ní kii tu̱ndó'o nuu̱‑dé. Te ni̱ ji'i̱‑de so̱ko, onde̱ jíín cháa ni̱ kaxiu̱kú jíín‑de.  
\v 26 Te ni̱ kɨ̱vɨ‑de ini̱ ve̱'e Dios. Te Abiatar ni̱ kuu máá sutú ñá'nu‑ga̱. Te ni̱ yee‑dé sta̱tilá ii̱ káxiu̱kú ndijín, ja̱ tú íó ley kee ní ɨɨn cha̱a, chi̱ máni sutu̱ káyee núú. Te suni ni̱ ja̱'a‑de nuu̱ cháa káxiu̱kú jíín‑de, áchí‑ya̱.  
\v 27 Te suni ni̱ ka'a̱n‑ya̱ jíín‑de: Kɨvɨ̱ ndéta̱tú ni̱ jungo̱o ja̱ sɨkɨ́ cháa; nasu̱ cháa ja̱ sɨkɨ́ kɨvɨ́ ndéta̱tú.  
\v 28 Núsáá te máá Sé'e cha̱a, suni Jito'o̱ kɨvɨ̱ ndéta̱tú kúu‑ya̱, áchí‑ya̱. 
\c 3  
\s1 Ɨɨn cha̱a ni̱ ichi̱ nda'a 
\p  
\v 1 Te ɨnga̱ jínu ni̱ ndɨ̱vɨ Jesús ini̱ ve̱'e sinagoga. Te yúan ni̱ i̱o ɨɨn cha̱a ni̱ ichi̱ káján ɨ́ɨn nda'a‑dé.  
\v 2 Te kánde̱'é‑de nú nasáva̱'a‑ya̱‑dé kɨvɨ̱ ndéta̱tú, náva̱'a kaka̱n‑de kua̱chi sɨkɨ̱‑yá.  
\v 3 Yúan‑na te ni̱ ka'a̱n‑ya̱ jíín cháa kátí'íchi nda'a‑ún: Ichi má'ñú yá'a jukuiñi̱‑ro̱, áchí‑ya̱.  
\v 4 Te ni̱ ka'a̱n‑ya̱ jíín‑de jíná'an‑de: Ndé ley íó sɨkɨ̱ kɨvɨ́ ndéta̱tú. Á sá'a va̱'a‑yó, xí sá'a ñáá‑yo̱. Á nama‑yó ɨ́ɨn cha̱a a yani kuu̱, xí ká'ni‑yo ɨ́ɨn ndɨ̱yi, áchí‑ya̱. Te máá‑de, tú ní káka'a̱n kutɨ‑dé.  
\v 5 Te ndé'é‑yá nuu̱‑dé ja̱ ká'i̱in‑de xiin‑yá. Te ni̱ kiti̱ ini̱‑ya̱. Te ni̱ kukuí'a̱ ini̱‑ya̱ já ndáva iní añú‑de jíná'an‑de. Te ni̱ ka'a̱n‑ya̱ jíín cháa‑ún: Skáa̱ nda'a‑ro, áchí‑ya̱. Te ni̱ skáa̱‑de nda'a‑dé. Te nda'a‑dé‑ún, ni̱ nduva̱'a ii̱‑ní.  
\v 6 Yúan‑na te ni̱ kenda koyo cha̱a fariseo. Te ni̱ kanda̱tu̱'ún‑ni‑de jíín cháa herodiano sɨkɨ̱‑yá, ndasa ka'ni‑dé‑ya̱. 
\s1 Kua'a̱ ñáyɨvɨ ní kandiki̱n‑i‑ya̱ 
\p  
\v 7 Te Jesús, ni̱ kusɨ́ɨn‑ni‑ya̱ kuá'a̱n‑ya̱ ondé yu'u mar jíín cháa káskuá'a jíín‑yá. Te ña̱yɨvɨ kuá'a̱ xáa̱n ndáñúu̱ Galilea jíín ndáñúu̱ Judea, ni̱ kandiki̱n‑i‑ya̱.  
\v 8 Te suni onde̱ ñuu̱ Jerusalén jíín Idumea, jíín ɨngá lado yu̱cha Jordán, jíín ndáñúu̱ Tiro jíín Sidón. Kua'a̱ xáa̱n ñáyɨvɨ, ni̱ ka̱jini tu̱'un‑i ná ñá'nu tiñu ni̱ sá'a‑ya̱. Te ni̱ cha̱koyo‑i nuu̱‑yá.  
\v 9 Te ni̱ ka'a̱n‑ya̱ jíín cháa káskuá'a jíín‑yá ja̱ ná kótu̱'a ɨɨn barco lúlí kɨ́vɨ‑ya̱, náva̱'a tú kaxi̱n‑i‑ya̱. Chi̱ kua'a̱ xáa̱n ñáyɨvɨ‑ún íó.  
\v 10 Chi ni̱ nasáva̱'a‑ya̱ ñáyɨvɨ kuá'a̱. Te ta̱ká ña̱yɨvɨ káku'u̱ kue'e̱, ni̱ ka̱kandita‑i nuu̱‑yá, ja̱ ké'é‑i‑ya̱ kákuni̱‑i.  
\v 11 Te tachi̱ kíni nú ni̱ kajini̱ nuu̱‑yá, te kájukuiñi̱ jítɨ́ núu̱‑yá. Te kákana kó'ó: Máá‑ní kúu Se̱'e Dios, áchí jíná'an.  
\v 12 Ko máá‑yá, ni̱ ka'a̱n xaa̱n‑yá jíín já ná tú stá'a̱n ndiji̱n‑ún‑yá. 
\s1 Ja̱ ní ka̱ji‑ya̱ uxí uu̱ cha̱a skuá'a jíín‑yá 
\p  
\v 13 Te ni̱ kaa‑ya̱ kuá'a̱n‑ya̱ ondé yuku. Te ni̱ kana‑ya̱ xiní ndé cha̱a játa'a̱n ini̱ máá‑yá. Te ni̱ ja̱koyo‑de nuu̱‑yá.  
\v 14 Te ni̱ jani‑ya̱ uxí uu̱ tá'a̱n cha̱a, kuiñi‑de jíín‑yá. Te tájí‑yá‑de ki̱ngoyo‑de kani‑de tu̱'un.  
\v 15 Te kundiso‑de tiñu ja̱ násáva̱'a‑de ña̱yɨvɨ kú'u̱. Te kiñi'in‑de tachi̱ kíni ki̱ngoyo.  
\v 16 Te Simón, ni̱ naskúnání‑yá‑de Pedro.  
\v 17 Te Jacobo, se̱'e Zebedeo, jíín Juan ñani̱ Jacobo, ni̱ naskúnání‑yá ndendúú‑de Boanerges, ja̱ kuní ka'a̱n: Cha̱a nátu̱'un taja.  
\v 18 Te sava‑ga̱‑de nání‑de Andrés, Felipe, Bartolomé, Mateo, Tomás, Jacobo se̱'e Alfeo, Tadeo, Simón ñuu̱ Caná,  
\v 19 onde̱ jíín Judas Iscariote, ja̱ ní nastúu‑de‑ya̱. Yúan‑na te ni̱ kɨ̱vɨ koyo‑de ɨɨn ve'e jíín‑yá.  
\v 20 Te ni̱ ndutútú tuku kua'a̱ ñáyɨvɨ. Te ni tuká ní kúu kee‑yá staa̱ jíín‑de.  
\v 21 Te ni̱ ka̱jini tu̱'un tá'an‑ya̱. Te ni̱ ka̱kenda‑de va̱i‑de ja̱ tɨ́ɨn‑de‑ya̱. Chi ni̱ kaka'a̱n‑de: Káku'u̱‑de, áchí‑de. 
\s1 Tu̱'un ndɨva̱'a sɨkɨ̱ Espíritu Santo 
\p  
\v 22 Te ja̱ káchaa tutu̱, ni̱ kikoyo onde̱ ñuu̱ Jerusalén, ni̱ kaka'a̱n: Yí'i‑de Beelzebú. Te jíín tachí kíni ñá'nu kíñi'in‑de tachi̱ kíni kája'a̱n, áchí.  
\v 23 Te ni̱ kana‑ya̱ xiní jíná'an. Te ni̱ ka'a̱n‑ya̱ tú'un yátá jíín: Ndasa kuu kiñi'in Satanás‑ún Satanás kí'i̱n, áchí‑ya̱.  
\v 24 Te nú ɨɨn ñuu̱ sásɨ́ɨn máá te kánakua̱tá'an máá, te ñuu̱ yúan ma̱ kúni̱'in.  
\v 25 Te nú ɨɨn ve'e sásɨ́ɨn máá te kánakua̱tá'an máá, te ve'e yúan ma̱ kúni̱'in.  
\v 26 Te nú Satanás kánakua̱tá'an máá te sásɨ́ɨn máá, ma̱ kúni̱'in, chi̱ sasua naa, áchí‑ya̱.  
\v 27 Tú ni ɨɨn cha̱a kuu kɨ̱vɨ‑de ini̱ ve̱'e cha̱a kándáján te sákuí'ná‑de ndatíñu, te nú tú xna'a̱n‑ga̱ ku'ni̱‑de cha̱a ndáján‑ún. Yúan‑na te kuu sákuí'ná‑de ndatíñu cha̱a‑ún.  
\v 28 Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró já kóo tu̱ká'nu ini̱ nuu̱ táká kua̱chi kásá'a cha̱a, te suni nuu̱ tú'un ndɨva̱'a nú na̱ni ka'a̱n‑de jíná'an‑de.  
\v 29 Ko nú ɨɨn cha̱a ká'a̱n‑de tu̱'un ndɨva̱'a sɨkɨ̱ Espíritu Santo, ma̱ kóo kutɨ túká'nu ini̱‑ya̱ núu̱‑dé, chi̱ sua kundiso‑de kua̱chi nɨ́ɨ́ káni, áchí‑ya̱.  
\v 30 Chi ni̱ kaka'a̱n‑de: Tá'a̱n‑de tachi̱ kíni, áchí‑de. 
\s1 Náa̱‑ya̱ jíín ñaní‑ya̱ 
\p  
\v 31 Te ni̱ chaa̱ náa̱‑ya̱ jíín ñaní‑ya̱, te ká'i̱in‑ña yatá ké'e. Te ni̱ ka̱tájí‑ña tú'un kua'a̱n kákana‑ña xiní‑yá.  
\v 32 Te ña̱yɨvɨ kuá'a̱ káxiu̱kú nɨ́ɨ́ núu̱‑yá‑ún, ni̱ kaka'a̱n‑i jíín‑yá: Kuánde̱'é‑ní, chi ni̱ chaa̱ náa̱‑ní jíín ñaní‑ní ká'i̱in‑ña yatá ké'e kánandúkú‑ña níí, áchí‑i.  
\v 33 Te máá‑yá, ni̱ ka'a̱n‑ya̱: Ndéja̱ kúu náa̱‑ri̱ te ndéja̱ kákuu ñani̱‑ri̱, áchí‑ya̱.  
\v 34 Te ndé'é‑yá nuu̱ ñáyɨvɨ káxiu̱kú nɨ́ɨ́ núu̱‑yá‑ún, te ni̱ ka'a̱n‑ya̱ jíín‑i: Kuni so̱'o‑ró, chi ya̱'á kúu náa̱‑ri̱ jíín ñaní‑ri̱.  
\v 35 Chi ña̱yɨvɨ skíkuu tiñu kuní Dios, jia̱n kúu ñani̱‑ri̱, kúu kua̱'a‑ri̱, kúu náa̱‑ri̱, áchí‑ya̱. 
\c 4  
\s1 Tu̱'un yátá sɨkɨ́ cháa sáka trigo 
\p  
\v 1 Te yu'u mar ni̱ kejá'á tuku‑ya̱ ní stá'a̱n‑ya̱ tú'un. Te ni̱ ka̱ndutútú kuá'a̱ xáa̱n ñáyɨvɨ núu̱‑yá. Te ja̱ yúán ní kɨ̱vɨ‑ya̱ ní jungo̱o‑ya̱ iní ɨɨn barco nuu̱ mar. Te ta̱ká ña̱yɨvɨ‑ún, ni̱ ka̱kendo̱o‑i káxiu̱kú‑i nuu̱ ñú'un.  
\v 2 Te ni̱ stá'a̱n‑ya̱ kuá'a̱ tú'un yátá núu̱‑í. Te ni̱ ka'a̱n‑ya̱ jíín‑i:  
\v 3 Kuni so̱'o te kuni̱‑ro̱: Ɨɨn cha̱a sáka trigo, ni̱ kenda‑de sáka‑dé.  
\v 4 Te ni̱ kuu ja̱ ní kenda‑de sáka‑dé, te ɨɨn nuni̱‑ún, ni̱ jungava yu'íchi. Te ni̱ chaa̱ tɨsaa̱. Te ni̱ ka̱kókó‑tɨ́.  
\v 5 Te ɨnga̱, ni̱ jungava nuu̱ ñú'un yúu̱, nuu̱ tú íó kua'a̱ ñú'un. Te ni̱ kana yachi̱‑ni, chi̱ tú íó kókon ñu'un.  
\v 6 Te nuu̱ ní kana ndika̱ndii, te ni̱ kasu̱n‑ni. Te ni̱ ichi̱, chi̱ tú yo'o ní íó.  
\v 7 Te ɨnga̱, ni̱ jungava ma̱'ñú ínu. Te ni̱ ja'nu iñu‑ún. Te ni̱ jasu̱ nuu̱. Te tú ní kúun nuni̱.  
\v 8 Te sava, ni̱ ka̱jungava nuu̱ ñú'un vá'a. Te ni̱ ka̱ja'nu. Te ni̱ nako̱ko. Te ni̱ kuun nuni̱. Ɨɨn ja̱ okó uxi̱, ɨnga̱ ja̱ uní xiko, te ɨnga̱ ja̱ ɨ́ɨn ciento, áchí‑ya̱.  
\v 9 Yúan‑na te ni̱ ka'a̱n‑ya̱ jíín‑de: Cha̱a íó so̱'o kuni ná'ín, te ná kúni so̱'o‑de.  
\v 10 Te nuu̱ ní ndo̱o máá‑na̱‑ya̱, te cha̱a ká'i̱in yani nuu̱‑yá jíín ndɨ́'uxí uu̱ cha̱a káskuá'a jíín‑yá, ni̱ kajika̱ tu̱'ún‑de‑ya̱ sɨkɨ́ tú'un yátá‑ún.  
\v 11 Te ni̱ ka'a̱n‑ya̱ jíín‑de: A kuaju̱ku̱'un ini̱‑ro̱ tú'un yísa̱'í yá'a, ndasa koo ñuu̱ nuu̱ tá'ú Dios tiñu. Ko jíín já sɨ́ɨn sɨkɨ̱ ká'i̱in, chi̱ máni jíín tú'un yátá ká'a̱n‑ri̱ ta̱ká tu̱'un.  
\v 12 Náva̱'a va̱sa kánde̱'é, ná ndé'é ko ma̱ chú'un ini̱. Te va̱sa kájini so̱'o, ná kúni so̱'o ko ma̱ júku̱'un ini̱. Náva̱'a ma̱ ná jíó káva ini̱, te koo tu̱ká'nu ini̱ nuu̱ táká kua̱chi, áchí‑ya̱.  
\v 13 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Tú kájuku̱'un ini̱‑ro̱ tú'un yátá yá'a náún. Ndasa juku̱'un ini̱‑ro̱ sáva‑ga̱ tu̱'un yátá núsáá.  
\v 14 Cha̱a sáka trigo kúu cha̱a sáka tú'un.  
\v 15 Te nuni̱ ní ka̱jungava yu'íchi kákuu cha̱a ni̱ saka̱ tú'un ini̱‑de. Ko nú ni̱ ka̱jini so̱'o‑de, te cháa̱‑ni Satanás te jánchaa̱‑ni tu̱'un ni̱ saka̱ iní añú‑de‑ún kua'a̱n‑ni jíín.  
\v 16 Te nuni̱ ní saka̱ núu̱ ñú'un yúu̱, kákuu cha̱a kájini so̱'o tu̱'un, te kúsɨɨ̱ iní‑de jíín.  
\v 17 Ko túu nuu̱ káka yo'o iní‑de. Te yaku̱‑ni kɨvɨ̱ kánda. Te nú ni̱ ndonda tu̱ndó'o sɨkɨ̱‑dé, xí nú ni̱ sándɨva̱'a‑i jíín‑de sɨkɨ̱ tú'un‑ún, te kánayu̱'ú‑ni‑de.  
\v 18 Te nuni̱ ní saka̱ má'ñú íñu kákuu cha̱a kájini so̱'o tu̱'un.  
\v 19 Ko kákutéñu‑de jíín ndátíñu‑de. Te kákuni̱‑de kukúká‑de, te káxndá'ú‑de máá‑de jíín. Te kákutóó iní‑de sɨkɨ̱ sáva‑ga̱ ndatíñu. Ndɨ'ɨ ya̱'á sátéñu‑de te jasú nuu̱ tú'un‑ún, te tú kúun nuni̱.  
\v 20 Te nuni̱ ní saka̱ núu̱ ñú'un vá'a kákuu cha̱a kájini so̱'o tu̱'un. Te kájatá'ú‑de te kája̱'a‑de nuni̱. Ɨɨn‑de oko̱ uxi̱, ɨnga̱‑de uni̱ xiko, te ɨnga̱‑de ɨɨn ciento, áchí‑ya̱. 
\s1 Tu̱'un yitɨ 
\p  
\v 21 Te suni ni̱ ka'a̱n‑ya̱ jíín‑de: Á júkuiñi̱ yitɨ já kúndii̱ sa̱'í chi̱i nu̱ndóó, xí chíi ji̱to. Á tú kundii̱ nuu̱ candelero.  
\v 22 Chi̱ tú íó ni ɨɨn tiñu yísa̱'í sáni, chi ta̱ká‑ni stá'a̱n ndiji̱n‑ya̱. Ni tú íó ni ɨɨn tu̱'un yísa̱'í sáni, chi ta̱ká‑ni va̱i ndiji̱n sá'a‑ya̱.  
\v 23 Cha̱a íó so̱'o kuni ná'ín, te ná kúni so̱'o‑de, áchí‑ya̱.  
\v 24 Te suni ni̱ ka'a̱n‑ya̱ jíín‑de: Ná kúni so̱'o va̱'a‑ró. Chi̱ jíín kú'a ja̱ káchikua̱'á‑ro̱, suni naku̱kua̱'á‑ro̱. Te ndaa‑ga̱ sɨkɨ̱ máá‑ró já kájini so̱'o‑ró.  
\v 25 Chi cha̱a ja̱ á ñáva̱'a, te kii‑ga̱ nuu̱‑dé. Te cha̱a ja̱ ná tú ñáva̱'a, va̱sa ja̱ á ñáva̱'a‑de‑ún te kuxio ki'i̱n, áchí‑ya̱. 
\s1 Tu̱'un tata̱ ni̱ ja'nu 
\p  
\v 26 Te ni̱ ka'a̱n‑ga̱‑ya̱: Ñuu̱ nuu̱ tá'ú Dios tiñu kúu nátu̱'un ɨɨn cha̱a ni̱ chi'i‑de tata̱ nuu̱ ñú'un.  
\v 27 Te kixí‑de ñúú te ndúko̱o‑de ndúú. Te tata̱‑ún a kána te já'nu. Te máá‑de, tú jiní‑de ndasa sá'a.  
\v 28 Chi̱ máá ñú'un kúu ja̱ já'a nuni̱. Xna'a̱n‑ga̱ vi̱u, te vásá kána yoko. Yúan‑na te nuni̱ ndóo chíi yoko‑ún.  
\v 29 Te nú ni̱ kuaan nuní‑ún, te skɨ́vɨ‑ni‑de jóso̱, chi̱ a ni̱ jaa̱ kɨvɨ̱ tá'nu̱, áchí‑ya̱. 
\s1 Tu̱'un ndɨkɨn yuá mostaza 
\p  
\v 30 Te ni̱ ka'a̱n‑ya̱: Na̱ jíín ká'a̱n‑yo̱ já ndása kuní koo ñuu̱ nuu̱ tá'ú Dios tiñu. Xí na̱ tu̱'un yátá skétá'an‑yó jíín.  
\v 31 Kúu nátu̱'un ndɨkɨn yuá mostaza ja̱ nú ni̱ jicha̱ nuu̱ ñú'un, te yu̱án kúu ɨɨn tata̱ lúlí‑ga̱ vásá táká tata̱ íó nuu̱ ñú'un‑ún yá'a.  
\v 32 Ko nú a ni̱ jicha̱. Te kana, te já'nu xaa̱n‑gá vásá táká‑ga̱ yua̱. Te kúná'nu nda'a. Te tɨsaa̱ íó andɨ́vɨ́ va̱tu‑ni sá'a‑tɨ́ taká‑tɨ̱ chíi katɨ‑ún, áchí‑ya̱.  
\v 33 Te kua'a̱ tú'un yátá súan ni̱ ka'a̱n‑ya̱ jíín ñáyɨvɨ, ndasa ni̱ ka̱kanda máá‑i kuni so̱'o‑i.  
\v 34 Te nú tú tu̱'un yátá te tú ká'a̱n‑ya̱ jíín‑i. Chi̱ máni máá‑ni nuu̱ cháa káskuá'a jíín‑yá ni̱ kachi̱ ka̱jí‑yá ta̱ká tu̱'un. 
\s1 Ja̱ ní jukuiñi̱ tachi̱ xáa̱n ní sá'a‑ya̱ 
\p  
\v 35 Te ni̱ ini kɨvɨ̱‑ún. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Ná kíja̱'a‑yó íchi lado‑ún, áchí‑ya̱.  
\v 36 Te ni̱ ka̱xndóo‑de ña̱yɨvɨ kuá'a̱‑ún. Te súan‑ni ni̱ ka̱jaka‑de‑ya̱ iní ɨɨn barco. Te suni kua'a̱n yaku̱‑ga̱ barco lúlí jíín‑yá.  
\v 37 Te ni̱ ndonda ɨɨn tachi̱ xáa̱n. Te suni ni̱ ndonda su'ma̱ mar, ni̱ kɨ̱vɨ ini̱ barco‑ún. Te barco‑ún kuní chítú ndúcha iní núú.  
\v 38 Te máá‑yá, kándee‑ya̱ ondé yata̱ barco‑ún, kixí‑ya̱ sɨkɨ́ ɨ́ɨn sa'ma yí'i xini̱. Te ni̱ ka̱xndúko̱o‑de‑ya̱. Te káka'a̱n‑de jíín‑yá: Maestro, á tú nákani ini̱‑ní ja̱ náa‑yo, áchí‑de.  
\v 39 Te ni̱ nduko̱o‑ya̱. Te ni̱ ka'a̱n xaa̱n‑yá nuu̱ tachí‑ún. Te ni̱ ka'a̱n‑ya̱ jíín mar‑ún: Ná'ín‑ni koo‑ró, jukuiñi̱, áchí‑ya̱. Te ni̱ jukuiñi̱ tachi̱‑ún, te ná'ín yúú íi̱‑ní ni̱ kuu.  
\v 40 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Naja̱ káyu̱'ú‑ro̱. Naja̱ tú kákandíja‑ró, áchí‑ya̱.  
\v 41 Te ni̱ kayu̱'ú xaa̱n‑dé. Te ni̱ kaka'a̱n‑de: Ndé cha̱a kúu cha̱a yá'a núsáá, ja̱ ondé tachi̱ jíín mar kájandatu̱ nuu̱‑dé, áchí‑de. 
\c 5  
\s1 Cha̱a tá'a̱n tachi̱ kíni ndañúu̱ Gadara 
\p  
\v 1 Te ni̱ ja̱koyo‑ya̱ ɨngá lado mar ndañúu̱ Gadara.  
\v 2 Te ni̱ kenda‑ya̱ iní barco‑ún. Te onde̱ ve'e añú ni̱ kenda ɨɨn cha̱a tá'a̱n tachi̱ kíni, te ni̱ ketá'an‑ni‑de jíín‑yá.  
\v 3 Te ncháá‑de ma̱'ñú vé'e añú. Te tú ni ɨɨn kúndéé kú'ni̱‑de jíín cadena.  
\v 4 Chi̱ kua'a̱ xáa̱n jínu ni̱ nu'ni̱‑de jíín manea jíín cadena. Ko cadena‑ún, ndɨ'ɨ‑ni ni̱ ja'nu̱ sava‑de. Te manea‑ún, ndɨ'ɨ‑ni ni̱ kukuáchí ní sá'a‑de. Te tú ni ɨɨn kúndéé jíín‑de ka'nu̱‑de.  
\v 5 Te ta̱ká kɨvɨ̱ ndúú ñúú‑ni jíka‑de yuku jíín má'ñú vé'e añú. Te kána jíín‑de, te stují‑dé máá‑de jíín yúu̱.  
\v 6 Te ni̱ jini̱‑de ja̱ á jíká‑ga̱ va̱i Jesús. Te ni̱ chaa‑de corre kua'a̱n‑de nuu̱‑yá. Te ni̱ jukuiñi̱ jítɨ́‑de nuu̱‑yá.  
\v 7 Te ni̱ kana kó'ó‑de: Na̱ún sá'a‑ní jíín‑ná Jesús, Se̱'e Dios, I'a̱ kúñá'nu xaa̱n. Ká'a̱n nda̱'ú‑ná jíín‑ní onde̱ jíín Dios, ma̱ xndó'o‑ní náá, áchí‑de.  
\v 8 Chi ni̱ ka'a̱n‑ya̱: Tachi̱ kíni, kenda ki'i̱n‑ro̱ iní cha̱a yá'a, áchí‑ya̱.  
\v 9 Te ni̱ jika̱ tu̱'ún‑yá‑de: Na̱ún nání‑ró. Te máá‑de, ni̱ ka'a̱n‑de: Cha̱a kua'a̱ xáa̱n nání‑ná, chi̱ kua'a̱‑ná íó, áchí‑de.  
\v 10 Te ni̱ ka'a̱n nda̱'ú‑de jíín‑yá ja̱ má kíñi'in‑ya̱‑dé ñuu̱‑ún ki'i̱n‑de.  
\v 11 Te yani yuku yúan íó ɨɨn tɨku'ni̱ ká'nu kɨnɨ̱ kájitu‑tɨ̱.  
\v 12 Te tachi̱ kíni‑ún, ni̱ kaka'a̱n nda̱'ú jíín‑yá: Tájí‑ní náá ná kíngoyo‑ná kɨ̱vɨ‑ná ini̱ kɨnɨ̱ yúan, áchí.  
\v 13 Te Jesús, ni̱ ja̱'a‑ya̱ tú'un. Te ni̱ kenda tachi̱ kíni‑ún kája'a̱n. Te ni̱ kɨ̱vɨ koyo ini̱ kɨnɨ̱. Te tɨku'ni̱ kɨnɨ̱‑ún, ni̱ ka̱jungoyo‑tɨ̱ ɨ́ɨn yukáva onde̱ ini̱ mar. Te kɨnɨ̱‑ún íó nátu̱'un uu̱ mil‑tɨ̱. Te nuu̱ mar ni̱ kaji'i̱‑tɨ̱.  
\v 14 Te cha̱a kándi̱to‑tɨ̱ yúan, ni̱ ka̱jinu‑de. Te ni̱ kaka̱stu̱'ún‑de nuu̱ ñúu̱ jíín núu̱ rancho. Te ni̱ cha̱koyo ña̱yɨvɨ‑ún kánde̱'é‑i na̱ún ní kuu.  
\v 15 Te ni̱ cha̱koyo‑i nuu̱ Jesús. Te ni̱ kajini̱‑i nuu̱ cháa ni̱ ndo'o jíín tachí kíni‑ún. Te kánchaa̱‑de, ñú'un‑de sa'ma, te a ni̱ nduva̱'a xini̱‑dé. Te ni̱ kayu̱'ú‑i.  
\v 16 Te cha̱a ni̱ kajini̱‑ún, ni̱ kaka̱stu̱'ún‑de nuu̱ ñáyɨvɨ vái koyo ndasa ni̱ ta'a̱n cha̱a ni̱ yi̱'i tachi̱ kíni‑ún, te ndasa ni̱ kuu jíín kɨnɨ́‑ún.  
\v 17 Te ni̱ ka̱kejá'á‑de ni̱ kaka'a̱n‑de jíín‑yá ja̱ ná kénda‑ya̱ ñúu̱‑de ki'i̱n‑ya̱.  
\v 18 Te ni̱ kɨ̱vɨ‑ya̱ iní barco. Te cha̱a ni̱ ta'a̱n tachi̱ kíni‑ún ká'a̱n nda̱'ú‑de jíín‑yá, ja̱ kúndee‑de jíín‑yá kuní‑de.  
\v 19 Ko Jesús, tú ní já'a‑ya̱ tú'un, chi ni̱ ka'a̱n‑ya̱ jíín‑de: Kuáno'on vé'e‑ró núu̱ tá'an‑ró. Te kani‑ró tú'un ná ñá'nu xaa̱n tíñu ni̱ sá'a máá Jíto'o̱‑ro̱ jíín‑ró, te ndasa ni̱ kundá'ú ini̱‑ya̱ róó, áchí‑ya̱.  
\v 20 Te ni̱ kee‑de kua'a̱n‑de. Te ni̱ kejá'á‑de ni̱ jacha̱‑de tu̱'un ini̱ ñuu̱ Decápolis ná ñá'nu xaa̱n tíñu ni̱ sá'a Jesús jíín‑de. Te ndivii ñáyɨvɨ yúan, ni̱ ka̱naa iní‑i kájini tu̱'un‑i. 
\s1 Tu̱'un se̱sɨ́'ɨ́ Jairo 
\p  
\v 21 Te ni̱ ja̱'a tuku Jesús kua'a̱n‑ya̱ jíín barco ɨnga̱ lado. Te ni̱ ka̱ndutútú kuá'a̱ xáa̱n ñáyɨvɨ núu̱‑yá. Te máá‑yá, kándii̱‑ya̱ yú'u mar.  
\v 22 Te ni̱ chaa̱ ɨɨn cha̱a nání‑de Jairo kúñá'nu‑de ini̱ ve̱'e sinagoga. Te ni̱ jini̱‑de nuu̱‑yá. Te ni̱ jukuiñi̱ jítɨ́‑de nuu̱‑yá.  
\v 23 Te ni̱ ka'a̱n nda̱'ú téyíí‑de jíín‑yá: Se̱sɨ́'ɨ́‑ná a yani kuu̱‑i. Ki'i̱n‑yo̱ te xndée‑ní nda'a‑ní sɨkɨ̱‑í náva̱'a ná káku‑i, te nachaku̱‑i, áchí‑de.  
\v 24 Te ni̱ kee‑ya̱ kuá'a̱n‑ya̱ jíín‑de. Te ni̱ kandiki̱n kua'a̱ ñáyɨvɨ kája'a̱n‑i jíín‑yá. Te ni̱ kajaxi̱n‑i‑ya̱. 
\s1 Ja̱ ní nasáva̱'a‑ya̱ ɨ́ɨn ña'an kú'u̱ kue'e̱ nɨñi̱ 
\p  
\v 25 Te yúan íó ɨɨn ña'an ní kuu uxi̱ uu̱ kuia̱ ndó'o‑ña kué'e̱ játɨ nɨñi̱‑ñá.  
\v 26 Te xaa̱n ní ndo'o‑ña jíín ñáta̱ná. Te ni̱ janu̱‑ña táká ja̱ ñáva̱'a‑ña jíín. Te tú kutɨ ní kúu tana̱, chi̱ sasua ví'í‑gá ni̱ sá'a.  
\v 27 Te ni̱ jini tu̱'un‑ña tú'un Jesús. Te ni̱ jaa̱‑ña íchi yatá‑yá ma̱'ñú ñáyɨvɨ kuá'a̱‑ún. Te ni̱ ké'é‑ña sá'ma‑yá.  
\v 28 Chi ni̱ ka'a̱n‑ña: Nú ná ké'é‑rí va̱sté sá'ma‑yá, te ka̱ku‑ri̱. Achí‑ña.  
\v 29 Te onde̱ nuu̱ kána nɨñi̱‑ñá‑ún, ni̱ ichi̱‑ni. Te ni̱ jini̱‑ña já ondé ini̱ yikɨ kúñu‑ña ní nduva̱'a tu̱ndó'o tá'a̱n‑ña‑ún.  
\v 30 Te Jesús, ni̱ jini̱‑ni ini̱ máá‑yá ja̱ ní kenda fuerza‑ya̱ kuá'a̱n. Te ni̱ jíó káva‑ya̱ núu̱ ñáyɨvɨ kuá'a̱. Te ni̱ ka'a̱n‑ya̱: Ndéja̱ ní ké'é sá'ma‑rí, áchí‑ya̱.  
\v 31 Te cha̱a káskuá'a jíín‑yá, ni̱ kaka'a̱n‑de: Ndé'é‑ní ja̱ ñáyɨvɨ kuá'a̱ yá'a kájaxi̱n‑i níí, te áchí‑ní: Ndéja̱ ní ké'é rúu̱, áchí‑de.  
\v 32 Te máá‑yá, yá'a yúan ndé'é‑yá náva̱'a kuni̱‑ya̱ ndéja̱ ní sá'a.  
\v 33 Yúan‑na te ña'an‑ún, yú'ú‑ña te kɨ́sɨ‑i‑ña, chi̱ a jiní‑ña ndasa ni̱ ta'a̱n‑ña. Te ni̱ chaa̱‑ña. Te ni̱ jukuiñi̱ jítɨ́‑ña núu̱‑yá. Te ni̱ kachi̱ ndaa̱‑ña táká tu̱'un.  
\v 34 Te máá‑yá, ni̱ ka'a̱n‑ya̱ jíín‑ña: Hija, ni̱ kandíja‑ró te yu̱án ní ka̱ku‑ró. Ma̱ yú'ú‑ro̱, chi ni̱ nduva̱'a‑ró túndó'o tá'a̱n‑ro̱, áchí‑ya̱. 
\s1 Ja̱ ní nachaku̱ se̱sɨ́'ɨ́ Jairo 
\p  
\v 35 Te sá súan ká'a̱n‑ya̱, te ni̱ cha̱koyo ña̱yɨvɨ ká'i̱in ve'e cha̱a kúñá'nu ini̱ ve̱'e sinagoga, te ni̱ kaka'a̱n‑i jíín‑de: A ni̱ ji'i̱ se̱sɨ́'ɨ́‑ní. Naja̱ stá'a̱n‑ga̱‑ní Maestro, áchí‑i.  
\v 36 Te Jesús, ni̱ jini so̱'o‑ya̱ tú'un yá'a ja̱ súan ni̱ kaka'a̱n‑i jíín cháa kúñá'nu ini̱ ve̱'e sinagoga. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Ma̱ yú'ú‑ro̱. Kandíja te ni̱ kuu‑ni, áchí‑ya̱.  
\v 37 Te tú ní já'a‑ya̱ tú'un kundiki̱n ni ɨɨn yata̱‑yá, chi̱ máá‑ni Pedro jíín Jacobo jíín ñaní‑de Juan.  
\v 38 Te ni̱ cha̱koyo‑ya̱ vé'e cha̱a kúñá'nu ini̱ ve̱'e sinagoga. Te ni̱ jini̱‑ya̱ já kúvaa̱, kánde'e̱, kákana jíkó'ó xáa̱n kákuu.  
\v 39 Te ni̱ kɨ̱vɨ‑ya̱. Te ni̱ ka'a̱n‑ya̱: Naja̱ kákuvaa̱‑ro̱ kánde'e̱‑ro̱. Te su̱chí sɨ́'ɨ́ yá'a, tú ní jí'i̱‑i, chi̱ kixí‑ni‑i, áchí‑ya̱.  
\v 40 Te ni̱ ka̱sákátá ñáyɨvɨ‑ún nuu̱‑yá. Ko máá‑yá, ni̱ kiñi'in ndɨ'ɨ‑ya̱‑í kája'a̱n‑i yata̱ ké'e. Te ni̱ ki'in‑ya̱ máá‑ni táa̱ náa̱ su̱chí sɨ́'ɨ́‑ún, jíín cháa ká'i̱in jíín‑yá, te ni̱ kɨ̱vɨ‑ya̱ núu̱ kátúu súchí sɨ́'ɨ́‑ún kua'a̱n‑ya̱.  
\v 41 Te ni̱ tɨɨn‑ya̱ ndá'a súchí sɨ́'ɨ́‑ún. Te ni̱ ka'a̱n‑ya̱ jíín‑i: Talita cumi, ja̱ kuní ka'a̱n: Súchi̱, jíín‑ró ká'a̱n‑ri̱, nduko̱o, áchí‑ya̱.  
\v 42 Te ni̱ nduko̱o‑ni su̱chí sɨ́'ɨ́‑ún. Te ni̱ jika‑i, chi̱ a íó‑i uxi̱ uu̱ kuia̱. Te ni̱ ka̱naa iní‑de kánde̱'é‑de, te xaa̱n káyu̱'ú‑de.  
\v 43 Te Jesús, ni̱ ka'a̱n xaa̱n‑yá jíín‑de ja̱ tú ni ɨɨn kuni tu̱'un. Te ni̱ ka'a̱n‑ya̱ jíín‑de ja̱ ná kuá'a‑de ja̱ kée‑í. 
\c 6  
\s1 Ja̱ ní ka̱ské'ichi̱‑i‑ya̱ ñúu̱ Nazaret 
\p  
\v 1 Te ni̱ kenda‑ya̱ yúan. Te ni̱ najaa̱‑ya̱ ñúu̱‑ya̱. Te cha̱a káskuá'a jíín‑yá, ni̱ kandiki̱n‑de‑ya̱ kája'a̱n‑de.  
\v 2 Te máá kɨvɨ́ ndéta̱tú ni̱ stá'a̱n‑ya̱ tú'un ini̱ ve̱'e sinagoga. Te kua'a̱ ñáyɨvɨ, ni̱ ka̱naa iní‑i kájini ná'ín‑i. Te káka'a̱n‑i: Ndé ni̱ ni'i̱n cháa yá'a tu̱'un yá'a. Te na̱ún kuní ka'a̱n tu̱'un ndíchí ní ni'i̱n‑dé‑ún. Te na̱ún sɨkɨ̱ kúu tiñu ñá'nu ja̱ sá'a‑de jíín ndá'a‑dé‑ún.  
\v 3 Nasu̱ yá'á kúu cha̱a tújí yúnu. Te nasu̱ sé'e María, ñani̱ Jacobo jíín José jíín Judas jíín Simón kúu‑de náún. Á tú ká'i̱in kua̱'a‑de jíín‑yó yá'a, áchí‑i. Te súan ni̱ ka̱kujá'a̱ ini̱‑i jíín‑yá.  
\v 4 Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑i: Cha̱a jáni tu̱'un Dios, máni ñuu̱‑de jíín tá'an‑de jíín iní ve̱'e‑de kúu ja̱ tú káka'a̱n tu̱'un jíñú'ún jíín‑de, áchí‑ya̱.  
\v 5 Te tú ní kúu sá'a‑ya̱ ní ɨɨn tiñu ñá'nu yúan. Chi̱ yaku̱‑ni ña̱yɨvɨ káku'u̱ ni̱ nasáva̱'a‑ya̱, já ní xndée‑ya̱ ndá'a‑yá sɨkɨ̱‑í.  
\v 6 Te náa iní‑ya̱ ndé'é‑yá ja̱ tú kákandíja máá‑i. Te ni̱ jíkó núu‑ya̱ nɨ́ɨ́ ñúu̱ yani. Te ni̱ stá'a̱n‑ya̱ tú'un. 
\s1 Ja̱ ní tájí‑yá ndɨ́'uxí uu̱‑de kája'a̱n‑de 
\p  
\v 7 Te ni̱ kana‑ya̱ xiní uxí uu̱ cha̱a káskuá'a jíín‑yá. Te tájí‑yá ndɨ́'úu̱ ndɨ́'úu̱‑de ki̱ngoyo‑de. Te ni̱ ja̱'a‑ya̱ fuerza ini̱‑de ja̱ kúndéé‑de jíín tachí kíni.  
\v 8 Te ni̱ tá'ú‑yá tiñu nuu̱‑dé ja̱ tú kutɨ na̱ún kúndiso‑de kuu‑de ichi. Ni ñunu, ni sta̱tilá, ni xu̱'ún kúnu'ni̱ sánchi̱i‑de. Chi̱ máá vara‑ni kundá'á‑de.  
\v 9 Ko kɨ'vɨ‑de ndija̱n. Te tú ku'un‑de uu̱ su'nu̱, áchí‑ya̱.  
\v 10 Te suni ni̱ ka'a̱n‑ya̱ jíín‑de: Na̱ni ve'e kúu nú ni̱ kɨ̱vɨ‑ró, te kendo̱o‑ró iní ve̱'e‑ún onde̱ nú ni̱ kenda‑ró yúan kua'a̱n‑ro̱.  
\v 11 Te ta̱ká ñuu̱ tú kájatá'ú róó yúan, ni tú káchu'un ini̱ tu̱'un ká'a̱n‑ro̱, onde̱ nú ni̱ kenda‑ró yúan te skóyo‑ró tɨ́kacha̱ iní ja'a̱‑ro̱, te súan kani ndaa̱‑ro̱ tú'un nuu̱‑í. Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró ja̱ vítá‑ga̱ koo kua̱chi sɨkɨ̱ ñúu̱ Sodoma jíín ñúu̱ Gomorra kɨvɨ̱ kíi juicio, vásá sɨkɨ́ ñúu̱‑ún, áchí‑ya̱.  
\v 12 Te ni̱ kenda koyo‑de. Te ni̱ ka̱jani‑de tu̱'un ja̱ táká ña̱yɨvɨ ná nákani ini̱‑i.  
\v 13 Te suni kua'a̱ tachí kíni ni̱ ka̱kiñi'in‑de kája'a̱n. Te jíín aceite ni̱ ka̱chi'i‑de ña̱yɨvɨ káku'u̱, te ni̱ ka̱nasáva̱'a‑de‑i. 
\s1 Ja̱ ní ji'i̱ Juan, cha̱a skuánducha 
\p  
\v 14 Te rey Herodes, ni̱ jini tu̱'un‑de tu̱'un Jesús, chi̱ sɨ́'vɨ́‑yá ni̱ jicha̱ nu̱u ndiji̱n kua'a̱n. Te ni̱ ka'a̱n‑de: Ja̱n jaa̱n, Juan ja̱ ní skuánducha‑ún, ni̱ nachaku̱ ma̱'ñú ndɨ́yi. Ja̱ yúán sátiñu tiñu ñá'nu xaa̱n iní núsáá, áchí‑de.  
\v 15 Ko sava‑i ni̱ kaka'a̱n‑i: Elías kúu‑de. Te sava‑ga̱‑i ni̱ kaka'a̱n tuku‑i: Ɨɨn cha̱a jáni tu̱'un Dios kúu‑de, nátu̱'un cha̱a ni̱ ka̱jani tu̱'un‑ya̱ ondé sáá, áchí‑i.  
\v 16 Te ni̱ jini tu̱'un Herodes. Te ni̱ ka'a̱n‑de: Yu̱án kúu Juan ja̱ ní janchaa̱‑ri̱ xini̱, te ni̱ nachaku̱ núsáá, áchí‑de.  
\v 17 Chi̱ suni máá Herodes, a ni̱ tájí‑de cha̱a ni̱ jatɨ̱ɨn Juan. Te ni̱ ju'ni̱‑de cha̱a. Te ni̱ chindee‑de cha̱a veka̱a ja̱ kuáchi Herodías, ñasɨ́'ɨ́ Felipe ñani̱ máá Herodes. Chi ni̱ janchaa̱‑de‑ña kúu tuku‑ña ñásɨ́'ɨ́‑de.  
\v 18 Te Juan, a ni̱ kana jíín‑de nuu̱ Herodes: Tú íó ley kuaka‑ró ñásɨ́'ɨ́ ñani̱‑ro̱, áchí‑de.  
\v 19 Ko ña'an, Herodías‑ún, ni̱ jito yu'u‑ñá Juan, chi̱ ka'ni‑ñá‑de kuní‑ña núú. Ko tú ní kúu sá'a‑ña.  
\v 20 Chi̱ Herodes, ni̱ yu̱'ú‑de ni̱ jito‑de Juan, chi̱ jiní Herodes ja̱ cháa ndaa̱ cha̱a ndoo kúu Juan. Te ni̱ ndi̱to va̱'a‑de cha̱a. Te jíni ná'ín‑de ja̱ ká'a̱n Juan, te náa iní‑de ndé'é‑de. Te ni̱ i̱o ini̱ ni̱ i̱o añú‑de ni̱ jini ná'ín‑de tu̱'un ká'a̱n Juan.  
\v 21 Te ɨɨn kɨvɨ̱ ní kusɨɨ̱ iní Herodes. Te ni̱ sá'a‑de ɨɨn viko kɨvɨ́ ní kaku‑de. Te ni̱ sá'a‑de ɨɨn ja̱ kúxíni cha̱a kákuñá'nu jíín‑de, jíín cháa kákuu general, jíín cháa kákuñá'nu ñuu̱ Galilea.  
\v 22 Te ni̱ kɨ̱vɨ se̱sɨ́'ɨ́ máá Herodías jíta já'á‑i. Te Herodes jíín táká cha̱a káyee stáa̱ jíín‑de, ni̱ ka̱kusɨɨ̱ iní‑de ni̱ sá'a‑i. Te rey‑ún, ni̱ ka'a̱n‑de jíín súchí sɨ́'ɨ́‑ún: Kaka̱n na̱ún kuní‑ro̱ núu̱‑rí te ná kuá'a‑ri̱ nuu̱‑ro̱, áchí‑de.  
\v 23 Te ni̱ jatu̱'un téyíí‑de: Ta̱ká na̱ún kuní‑ro̱ kakán‑ro̱ núu̱‑rí te ná kuá'a‑ri̱ nuu̱‑ro̱, va̱sa onde̱ sava ñuu̱ ja̱ tɨ́ɨn‑ri̱, áchí‑de.  
\v 24 Te ni̱ kenda‑i kua'a̱n‑i. Te ni̱ ka'a̱n‑i jíín náa̱‑i: Na̱ún kakán‑ná nuu̱‑dé, áchí‑i. Te ni̱ ka'a̱n‑ña jíín‑i: Xini̱ Juan ja̱ skuánducha‑ún kaka̱n‑ro̱, áchí‑ña.  
\v 25 Yúan‑na te máá‑i, ni̱ ndɨ̱vɨ‑ni‑i nuu̱ rey. Te ni̱ jika̱n‑i: Vina nchaa te kuní‑ná kua̱'a‑ní xini̱ Juan ja̱ skuánducha‑ún nuu̱‑ná kundee nuu̱ ɨ́ɨn ko'o̱, áchí‑i jíín‑de.  
\v 26 Te rey‑ún, ni̱ kuxíí xáa̱n iní‑de. Ko sɨkɨ̱ já ní jatu̱'un téyíí‑de, jíín sɨkɨ́ já ní ka̱jini so̱'o cha̱a káyee stáa̱ jíín‑de, te tú ní kuní‑de sásá'án‑de kua̱'a‑de nuu̱‑í.  
\v 27 Te rey‑ún, ni̱ tájí‑ni‑de ɨɨn soldado ndíto yuxé'é‑ún kua'a̱n kuaki̱'in xini̱ Juan.  
\v 28 Te soldado‑ún, ni̱ ja'a̱n. Te ni̱ janchaa̱ xini̱ Juan ini̱ veka̱a. Te ni̱ chaa̱ jíín xiní‑ún kándee nuu̱ ɨ́ɨn ko'o̱. Te ni̱ ja̱'a nuu̱ súchí sɨ́'ɨ́‑ún. Te su̱chí‑ún, ni̱ ja̱'a‑i nuu̱ náa̱‑i.  
\v 29 Te ni̱ ka̱jini tu̱'un cha̱a káskuá'a jíín Juan. Te ni̱ ja̱koyo‑de, ni̱ ka̱ndañaa‑de yikɨ kúñu‑ún. Te ni̱ ka̱chindee‑de ini̱ ve̱'e añú. 
\s1 Ja̱ ní ka̱ndutútú cháa apóstol nuu̱‑yá 
\p  
\v 30 Te cha̱a apóstol, ni̱ ka̱ndutútú‑de nuu̱ Jesús. Te ni̱ ka̱nakani‑de tu̱'un ta̱ká tiñu ni̱ ka̱sá'a‑de, jíín tú'un ni̱ ka̱stá'a̱n‑de.  
\v 31 Te máá‑yá, ni̱ ka'a̱n‑ya̱ jíín‑de: Ña'a̱n sɨ́ɨn ɨɨn lugar ñu'un té'é, te ndeta̱tú‑ro̱ ɨ́ɨn tí'lí, áchí‑ya̱. Chi̱ kua'a̱n va̱i kua'a̱ ñáyɨvɨ kákuu‑i. Te ni tú ní kánuña‑ya̱ já kée‑yá staa̱.  
\v 32 Te kája'a̱n‑ya̱ iní ɨɨn barco onde̱ nuu̱ íó sɨ́ɨn ñu'un té'é.  
\v 33 Te ni̱ kajini̱ ña̱yɨvɨ já kája'a̱n‑ya̱. Te ni̱ ka̱nakuni̱‑i‑ya̱. Te onde̱ ta̱ká ñuu̱ ni̱ ka̱jinu‑i ni̱ ka̱kutútú‑i yúan. Te ni̱ ja̱koyo‑i xna'a̱n‑ga̱ vásá máá‑yá. Te ni̱ ka̱kutútú‑i nuu̱‑yá.  
\v 34 Te ni̱ kenda Jesús. Te ni̱ jini̱‑ya̱ ñáyɨvɨ kuá'a̱ xáa̱n‑ún. Te ni̱ kundá'ú ini̱‑ya̱‑í, chi̱ nátu̱'un rɨɨ̱ tú jito'o̱ súan ká'i̱in‑i. Te ni̱ stá'a̱n‑ya̱ kuá'a̱ tú'un nuu̱‑í. 
\s1 Ja̱ ní skée‑yá u'u̱n mil ña̱yɨvɨ 
\p  
\v 35 Te sáá chi̱ a kua̱'ini, te cha̱a káskuá'a jíín‑yá, ni̱ jaa̱‑de nuu̱‑yá. Te ni̱ kaka'a̱n‑de: Yá'a chi̱ máá ñú'un té'é kúu, te a kua̱'ini.  
\v 36 Núsáá te tájí‑ní‑i ná kíngoyo‑i ta̱ká rancho jíín táká ñuu̱ yani yá'a, te ná kuáan máá‑i staa̱ kée‑í, chi̱ tú na̱ún kée‑í, áchí‑de.  
\v 37 Te máá‑yá, ni̱ ka'a̱n‑ya̱: Kua̱'a máá‑ró já kée‑í, áchí‑ya̱ jíín‑de. Te ni̱ kaka'a̱n‑de jíín‑yá: Ki̱ngoyo‑ná te kuaan‑ná uu̱ ciento peso staa̱ te kua̱'a‑ná kee‑í náún, áchí‑de.  
\v 38 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Na̱saa staa̱ kándi̱so‑ró. Kuánde̱'é, áchí‑ya̱. Te nuu̱ ní kajini̱‑de, te ni̱ kaka'a̱n‑de: U'u̱n sta̱tilá te uu̱ ti̱yáká íó, áchí‑de.  
\v 39 Yúan‑na te ni̱ tá'ú‑yá tiñu nuu̱ ñáyɨvɨ‑ún ja̱ ná júngo̱o sɨ́ɨn ɨɨn nuu ɨ́ɨn nuu‑í sɨkɨ̱ ichá kuíi.  
\v 40 Te ni̱ kaju̱ngo̱o yuku̱n‑i, ɨɨn ciento, ɨɨn ciento‑i, jíín úu̱ xiko uxi̱, uu̱ xiko uxi̱‑i.  
\v 41 Te ni̱ ki'in‑ya̱ ndɨ́'ú'u̱n sta̱tilá‑ún jíín úu̱ ti̱yáká‑ún. Te ni̱ ndakoto‑ya̱ íchi ándɨ́vɨ́. Te ni̱ jika̱n ta'u̱‑yá ja'a̱ státilá. Te ni̱ sákuáchí‑yá sta̱tilá‑ún. Te ni̱ ja̱'a‑ya̱ núu̱ cháa káskuá'a jíín‑yá ni̱ ka̱jani‑de nuu̱‑í. Te ni̱ saka‑yá ndɨ́'úu̱ ti̱yáká‑ún nuu̱ táká‑i.  
\v 42 Te ndivii ñáyɨvɨ‑ún, ni̱ ka̱yee‑í. Te ni̱ kanda'a̱ chi̱i‑i.  
\v 43 Te ni̱ ka̱nastútú‑de ja̱ ní kendo̱o kuáchí, onde̱ uxi̱ uu̱ ji̱ka chítú ndɨ́ɨ kúu, onde̱ jíín tíyáká.  
\v 44 Te cha̱a ni̱ ka̱yee‑ún jínu onde̱ u'u̱n mil‑de. 
\s1 Ja̱ ní jika já'á‑yá nuu̱ mar 
\p  
\v 45 Yúan‑na te ni̱ skandá‑ni Jesús cha̱a káskuá'a jíín‑yá, ni̱ kɨ̱vɨ koyo‑de ini̱ barco. Te ná kúxnúú‑de nuu̱‑yá ki̱ngoyo‑de ɨnga̱ lado yu'u mar nuu̱ ñúu̱ Betsaida. Chi̱ kuéé jachá‑ya̱ ñáyɨvɨ kuá'a̱‑ún.  
\v 46 Te ni̱ nakuatá'ú‑yá nuu̱ ñáyɨvɨ‑ún kua̱ngoyo‑i. Te ni̱ kee‑ya̱ kuá'a̱n‑ya̱ ondé yuku kuákaka̱n ta'u̱‑yá.  
\v 47 Te ni̱ ini, te barco‑ún a kándee onde̱ ma̱'ñú mar. Te máá ɨ́ɨn‑na̱‑ya̱ ní ndo̱o‑ya̱ núu̱ ñú'íchí.  
\v 48 Te ni̱ jini̱‑ya̱ já ní kakui̱tá‑de káskáka‑de barco‑ún, chi̱ sua ni̱ nana nuu tachi̱. Te tɨ́kuáán‑na̱ kúu, te ni̱ chaa̱‑ya̱ núu̱‑dé jíka já'á‑yá nuu̱ mar. Te a ja̱'a‑ya̱ núu̱‑dé ki'i̱n‑ya̱ núú.  
\v 49 Te ni̱ kajini̱‑de‑ya̱ já jíka‑ya̱ núu̱ mar. Te ni̱ ka̱jani ini̱‑de ja̱ añú kúu. Te ni̱ ka̱kana kó'ó‑de.  
\v 50 Chi̱ ndɨ'ɨ‑de, ni̱ kajini̱‑de nuu̱‑yá. Te ni̱ kayu̱'ú‑de. Yúan‑na te ni̱ ka'a̱n‑ni‑ya̱ jíín‑de: Ndéé sá'a‑ró iní‑ro̱. Máá‑rí kúu. Ma̱ yú'ú‑ro̱, áchí‑ya̱.  
\v 51 Te ni̱ kaa‑ya̱ ní kɨ̱vɨ‑ya̱ jíín‑de ini̱ barco‑ún. Te ni̱ jukuiñi̱ tachi̱. Te máá‑de, ni̱ ka̱naa xáa̱n iní‑de kánde̱'é‑de nuu̱‑yá.  
\v 52 Chi̱ ni tú ní kájuku̱'un ini̱‑de ja̱ ní kuu jíín státilá‑ún, chi̱ ndava iní añú‑de. 
\s1 Ña̱yɨvɨ káku'u̱ ñuu̱ Genesaret 
\p  
\v 53 Te ni̱ kaja̱'a‑ya̱ vái‑ya̱ ɨngá lado. Te ni̱ cha̱koyo‑ya̱ ñú'íchí ñúu̱ Genesaret. Te yundúcha‑ún ni̱ ka̱jukuiñi̱‑ya̱.  
\v 54 Te nuu̱ ní kenda koyo‑ya̱ iní barco, te ña̱yɨvɨ yúan, ni̱ ka̱nakuni̱‑ni‑i Jesús.  
\v 55 Te ni̱ kajicha̱ nu̱u‑i ta̱ká ndañúu̱ yúan. Te ni̱ ka̱kejá'á‑i ni̱ ka̱skuíndíso‑i ña̱yɨvɨ káku'u̱ jíín jíto yuu, onde̱ nuu̱ ní ka̱jini tu̱'un‑i kándee‑ya̱.  
\v 56 Te ndéni ni̱ kuu nú ni̱ kɨ̱vɨ‑ya̱, á ñuu̱ lúlí, á ñuu̱ ká'nu, á rancho, te kájani‑i ña̱yɨvɨ káku'u̱‑ún ini̱ ichi. Te káka'a̱n nda̱'ú‑i jíín‑yá va̱sté yúsá'ma‑yá ná ké'é‑i. Te ta̱ká ña̱yɨvɨ ní ka̱ké'é sá'ma‑yá‑ún, ni̱ kandu̱va̱'a‑i. 
\c 7  
\s1 Sɨkɨ̱ ndása kuchá'án ñáyɨvɨ 
\p  
\v 1 Te cha̱a fariseo jíín yakú cha̱a káchaa tutu̱, ni̱ kikoyo‑de ichi ñúu̱ Jerusalén. Te ni̱ ka̱kutútú‑de nuu̱ Jesús.  
\v 2 Te cha̱a‑ún, ni̱ kajini̱‑de ja̱ sáva cha̱a káskuá'a jíín‑yá káyee‑dé staa̱ jíín ndá'a chá'án‑de, kua̱chi ja̱ tú ní ka̱nandá'á‑de. Te ni̱ ka̱ndonda sɨkɨ̱‑dé.  
\v 3 (Chi cha̱a fariseo jíín táká cha̱a judío, nú tú nandá'á ná'án‑de, tú káyee‑dé staa̱. Chi̱ káñava̱'a‑de tani̱nu aná'án.  
\v 4 Te nú ni̱ ka̱najíó káva‑de ja̱ ní kaja'a̱n‑de nu̱yá'u, te nú tú nasándoo‑de máá‑de, tú káyee‑dé. Te íó kua'a̱‑gá tani̱nu káñava̱'a‑de te káchiñú'ún‑de, nátu̱'un ndúndoo vaso, tɨndo'o̱, ko'o̱ káa, jíín jíto.)  
\v 5 te cha̱a fariseo jíín cháa káchaa tutu̱, ni̱ kajika̱ tu̱'ún‑de‑ya̱. Te cha̱a káskuá'a jíín‑ró, naja̱ tú káchiñú'ún‑de tani̱nu cha̱a aná'án. Naja̱ káyee‑dé staa̱ jíín ndá'a chá'án‑de, áchí‑de.  
\v 6 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Cha̱a uu̱ xini̱ kákuu‑ró. Bueno ni̱ jani Isaías tu̱'un sɨkɨ̱‑ro̱, chi̱ súan ni̱ chaa máá‑de tu̱'un sáá: Ña̱yɨvɨ yá'a jíín yú'u‑í káchiñú'ún‑i ruu̱, ko jíín añú‑i chi̱ jíká‑ni kákuu ini̱‑i jíto‑i ruu̱.  
\v 7 Te káchiñú'ún sáni‑i ruu̱, chi̱ kástá'a̱n‑i tu̱'un jáni ini̱ ɨɨn cha̱a, áchí Isaías.  
\v 8 Chi ni̱ ka̱sía̱‑ro̱ tíñu ni̱ tá'ú Dios nuu̱‑ro̱, te káchiñú'ún‑ró táni̱nu ni̱ kajaki̱n cha̱a, ja̱ ndúndoo tɨndo'o̱ jíín vaso. Te káñava̱'a‑ró kuá'a̱‑gá tani̱nu súan, áchí‑ya̱.  
\v 9 Te suni ni̱ ka'a̱n‑ya̱: Bueno‑ni kástɨ́vɨ́‑ró tú'un tá'ú tíñu Dios náva̱'a chiñú'ún‑ró táni̱nu ni̱ kajaki̱n máá‑ró.  
\v 10 Chi̱ Moisés, ni̱ ka'a̱n‑de: Kuandatu̱‑ro̱ núu̱ táa̱‑ro̱ núu̱ náa̱‑ro̱. Chi̱ nú ndéja̱ ká'a̱n ndɨva̱'a jíín táa̱ jíín náa̱, ná kúu̱ nú kuu̱. Achí‑de.  
\v 11 Ko máá‑ró káka'a̱n‑ro̱: Nú íó ndatíñu ja̱ xíin ɨ́ɨn cha̱a. Te a kuu ni'i̱n tíñu ja̱ kuní táa̱‑de xí náa̱‑de, ko nú xna'a̱n‑ga̱ ka'a̱n‑de ja̱ Corbán kúu (ja̱ kuní ka'a̱n, a ni̱ soko̱‑rí nuu̱ Dios),  
\v 12 yúan‑na te tuká jínu ñú'ún kútɨ sá'a‑de ja̱ kuní táa̱‑de xí já kuní náa̱‑de, áchí‑ro̱.  
\v 13 Te súan kástɨ́vɨ́‑ró tú'un Dios jíín táni̱nu ni̱ kajaki̱n‑ro̱. Te kua'a̱‑gá tiñu súan kásá'a‑ró, áchí‑ya̱.  
\v 14 Te ni̱ kana tuku‑ya̱ xiní ñáyɨvɨ kuá'a̱‑ún. Te ni̱ ka'a̱n‑ya̱ jíín‑i: Ndɨ'ɨ‑ró ná kúni so̱'o‑ró tú'un ká'a̱n‑ri̱, te chu'un ini̱‑ro̱.  
\v 15 Ta̱ká ndatíñu íó ichi fuera cha̱a, nú ni̱ kɨ̱vɨ ini̱ yu'u‑dé, ma̱ kúchá'án‑de sá'a. Chi ja̱ kénda ini̱ yu'u‑dé, yu̱án kúu ja̱ kúchá'án‑de sá'a.  
\v 16 Cha̱a íó so̱'o kuni ná'ín, te ná kúni so̱'o‑de, áchí‑ya̱.  
\v 17 Te nuu̱ ní kusɨ́ɨn‑ya̱ núu̱ ñáyɨvɨ kuá'a̱‑ún, te ni̱ ndɨ̱vɨ‑ya̱ iní ve̱'e. Te cha̱a káskuá'a jíín‑yá, ni̱ kajika̱ tu̱'ún‑de‑ya̱ sɨkɨ́ tú'un yátá‑ún.  
\v 18 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Suni tú kájuku̱'un ini̱ máá‑ró náún. Á tú kájini̱‑ro̱ já táká ja̱ kɨ́vɨ ini̱ cha̱a, ma̱ kúu kuchá'án‑de sá'a,  
\v 19 chi̱ tú kɨ́vɨ ini̱ añú‑de, chi̱ toko‑dé kɨ́vɨ, te ndénda‑ni kua'a̱n, áchí‑ya̱. Súan ni̱ stá'a̱n‑ya̱ já íó ndoo ta̱ká ndeyu.  
\v 20 Te ni̱ ka'a̱n‑ga̱‑ya̱: Ja̱ kénda ichi iní ña̱yɨvɨ, yu̱án kúu ja̱ kúchá'án‑i sá'a.  
\v 21 Chi̱ onde̱ ichi iní añú kénda ja̱ jáni ñáá ini̱, ja̱ ísɨ́kɨ ncháa̱ tá'a̱n, ja̱ kuáxán iní, ja̱ já'ni ndɨ́yi,  
\v 22 ja̱ sákuí'ná, ja̱ tóó iní, ja̱ ñáá, ja̱ xndá'ú ñá'án, ja̱ tuká kúka nuu̱, ja̱ ndákoto xaa̱n, ja̱ ká'a̱n sɨkɨ̱ tá'an, ja̱ sávixi̱ máá, ja̱ xiní ñáá.  
\v 23 Ta̱ká tu̱'un ñáá yá'a, máni ichi iní añú kénda te kúchá'án‑i sá'a, áchí‑ya̱.  
\v 24 Te ni̱ ndukuiñi̱‑ya̱ yúan. Te kua'a̱n‑ya̱ ondé raya ñuu̱ Tiro jíín ñúu̱ Sidón. Te ni̱ kɨ̱vɨ‑ya̱ ɨ́ɨn ve'e. Te kuní‑ya̱ já tú ni ɨɨn kuni tu̱'un. Ko tú ní kúu kundee sá'í‑ya̱ yúan. 
\s1 Ña'an sirofenicia 
\p  
\v 25 Chi̱ ɨɨn ña'an íó ɨɨn se̱sɨ́'ɨ́‑ña tá'a̱n‑i tachi̱ kíni. Te ni̱ jini tu̱'un‑ña tú'un‑ya̱. Te ni̱ chaa̱‑ni‑ña. Te ni̱ jukuiñi̱ jítɨ́‑ña núu̱‑yá.  
\v 26 Te ña'an‑ún, ña'an griega kúu‑ña. Te onde̱ ñuu̱ Sirofenicia va̱i tata̱‑ña. Te ni̱ ka'a̱n nda̱'ú‑ña jíín‑yá ja̱ ná kíñi'in‑ya̱ tachí kíni tá'a̱n se̱sɨ́'ɨ́‑ña‑ún ki'i̱n.  
\v 27 Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑ña: Sía̱, ná ndá'a̱ xna'a̱n‑ga̱ chi̱i ta̱ká su̱chí yá'a, chi̱ tú íó va̱'a ja̱ kuánchaa̱‑yo̱ stáa̱‑í te skána‑yó núu̱ lúsu, áchí‑ya̱.  
\v 28 Te ni̱ ka'a̱n‑ña: Ja̱ndáa̱ ká'a̱n‑ní Táta̱, ko lúsu‑ún ichi chíi mesa náchii‑tɨ́ staa̱ kua̱chí kóyo yu'u‑í yáji‑tɨ́, áchí‑ña.  
\v 29 Yúan‑na te ni̱ ka'a̱n‑ya̱ jíín‑ña: Kuá'án núsáá, chi tu̱'un va̱'a kúu ja̱ ní ka'a̱n‑ro̱ yá'a. Te tachi̱ kíni‑ún, a ni̱ kenda kua'a̱n ini̱ se̱sɨ́'ɨ́‑ro̱, áchí‑ya̱.  
\v 30 Te ni̱ kee‑ña kuáno'on‑ñá ve'e‑ña. Te ni̱ jini̱‑ña já kátúu sésɨ́'ɨ́‑ña núu̱ jíto. Te a ni̱ kenda tachi̱ kíni‑ún kua'a̱n. 
\s1 Cha̱a só'ó kástété 
\p  
\v 31 Te ni̱ kenda tuku‑ya̱ ondé raya ñuu̱ Tiro, ni̱ kii‑ya̱ íchi Sidón. Te ni̱ jaa̱‑ya̱ mar Galilea. Te ni̱ ja'ncha̱ sava‑ya̱ raya ñuu̱ Decápolis va̱i‑ya̱.  
\v 32 Te ni̱ ka̱kinchaka‑i ɨɨn cha̱a só'ó kástété núu̱‑yá. Te ni̱ kaka'a̱n nda̱'ú‑i jíín‑yá ja̱ ná xndée‑ya̱ ndá'a‑yá sɨkɨ̱‑dé.  
\v 33 Te ni̱ kiñi'in sɨ́ɨn‑ya̱‑dé nuu̱ ñáyɨvɨ kuá'a̱‑ún. Te ni̱ chindee‑ya̱ ndá'a‑yá so̱'o‑de. Te ni̱ tɨvɨ̱ sɨ̱'vɨ́‑yá. Te ni̱ ké'é‑yá yáa‑dé.  
\v 34 Te ni̱ ndakoto‑ya̱ íchi ándɨ́vɨ́. Te ni̱ jaka̱ nu̱u ini̱‑ya̱. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Efata, áchí‑ya̱. Ja̱ kuní ka'a̱n: Nanuña.  
\v 35 Te ni̱ nanuña so̱'o‑de. Te ni̱ nduvi̱tá yáa‑dé. Te ni̱ kuu‑ni ni̱ naka'a̱n kájí‑de.  
\v 36 Te ni̱ ka'a̱n xaa̱n‑yá jíín ñáyɨvɨ‑ún ja̱ tú ni ɨɨn nuu̱ kachí‑i. Te va̱sa ni̱'in ni̱ ka'a̱n xaa̱n‑yá jíín‑i, ko ví'í‑gá ni̱ kajacha̱‑i tu̱'un‑ya̱.  
\v 37 Te ni̱ ka̱naa xáa̱n iní‑i kánde̱'é‑i. Te ni̱ kaka'a̱n‑i: Bueno sá'a‑ya̱ táká tiñu; chi cha̱a só'ó nákuni so̱'o‑de, te cha̱a ñí'ín náka'a̱n‑de sá'a‑ya̱, áchí‑i. 
\c 8  
\s1 Ja̱ ní skée‑yá kuu̱n mil ña̱yɨvɨ 
\p  
\v 1 Te kɨvɨ̱‑ún, ni̱ i̱o kua'a̱ xáa̱n ñáyɨvɨ, te tú na̱ún káji‑í. Te ni̱ kana Jesús xini̱ cháa káskuá'a jíín‑yá. Te ni̱ ka'a̱n‑ya̱ jíín‑de:  
\v 2 Kúndá'ú ini̱‑ri̱ ña̱yɨvɨ kuá'a̱ yá'a, chi̱ a ni̱ kuu uni̱ kɨvɨ̱ káxiu̱kú‑i jíín‑rí, te tú na̱ún káji‑í.  
\v 3 Te nú natájí‑rí‑i no'o̱n ndicha̱‑i ve'e‑i, te sava ichi te kui̱tá ii̱‑í, chi̱ íó sava‑i jíká vái koyo‑i, áchí‑ya̱.  
\v 4 Te cha̱a káskuá'a jíín‑yá, ni̱ kaka'a̱n‑de jíín‑yá: Te ndéchi kíi staa̱ kée ndá'a̱ chi̱i ña̱yɨvɨ yá'a, chi̱ máni ñu'un té'é kúu yá'a. Achí‑de.  
\v 5 Te ni̱ jika̱ tu̱'ún‑yá‑de: Na̱saa staa̱ kándi̱so‑ró. Achí‑ya̱. Te ni̱ kaka'a̱n‑de: Usia̱‑ni sta̱tilá, áchí‑de.  
\v 6 Yúan‑na te ni̱ tá'ú‑yá tiñu nuu̱ ñáyɨvɨ kuá'a̱‑ún ja̱ ná júngo̱o‑i nuu̱ ñú'un. Te ni̱ ki'in‑ya̱ ndɨ́'usiá sta̱tilá‑ún. Te ni̱ jika̱n ta'u̱‑yá. Te ni̱ sákuáchí‑yá. Te ni̱ ja̱'a‑ya̱ núu̱ cháa káskuá'a jíín‑yá, ja̱ ná káni‑de nuu̱ ñáyɨvɨ kuá'a̱‑ún. Te ni̱ ka̱jani‑de nuu̱‑í.  
\v 7 Te suni kándi̱so‑de yaku̱ ti̱yáká lúlí. Te ni̱ jika̱n ta'u̱‑yá ja'a̱‑tɨ́. Te ni̱ tá'ú‑yá tiñu ja̱ súni ná káni‑de nuu̱‑í.  
\v 8 Te ni̱ ka̱yee‑í. Te ni̱ kanda'a̱ chi̱i‑i. Te ni̱ kendo̱o‑ga̱. Te ni̱ ka̱nastútú‑de usia̱ ndo'o̱ já ní kendo̱o kuáchí.  
\v 9 Te ña̱yɨvɨ ní ka̱yee‑ún íó nátu̱'un kuu̱n mil‑i. Te ni̱ jacha̱‑ya̱‑í kua'a̱n‑i.  
\v 10 Yúan‑na te ni̱ kɨ̱vɨ‑ni‑ya̱ iní barco jíín cháa káskuá'a jíín‑yá. Te ni̱ chaa̱‑ya̱ ndáñúu̱ Dalmanuta. 
\s1 Tu̱'un yujan íá cháa fariseo 
\p  
\v 11 Te yúan ni̱ cha̱koyo cha̱a fariseo. Te ni̱ ka̱kejá'á‑de káxndichí‑de‑ya̱ kájika̱n‑de tuni̱ ichi ándɨ́vɨ́ núu̱‑yá chi̱ koto nchaa̱‑de‑ya̱ kákuni̱‑de.  
\v 12 Te ni̱ jaka̱ nu̱u ini̱‑ya̱. Te ni̱ ka'a̱n‑ya̱: Naja̱ kájika̱n ña̱yɨvɨ yá'a tuni̱ nuu̱‑rí. Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró ma̱ kuá'a‑ri̱ ni ɨɨn tuni̱ nuu̱ ñáyɨvɨ yá'a.  
\v 13 Te ni̱ skéndo̱o‑ya̱‑dé jíná'an‑de. Te ni̱ ndɨ̱vɨ tuku‑ya̱ iní barco, te kua'a̱n‑ya̱ ɨngá lado.  
\v 14 Te cha̱a káskuá'a jíín‑yá, ni̱ ka̱naa iní‑de kundiso‑de staa̱. Chi̱ ɨɨn‑ni sta̱tilá kándi̱so‑de ini̱ barco.  
\v 15 Te ni̱ ka'a̱n xaa̱n‑yá jíín‑de: Koto va̱'a‑ró máá‑ró núu̱ yújan íá cháa fariseo jíín núu̱ yújan íá Herodes, áchí‑ya̱.  
\v 16 Te kándatu̱'ún máá‑de: Sɨkɨ̱ já tú kándi̱so‑yó stáa̱ núsáá, áchí‑de.  
\v 17 Te ni̱ jini̱ Jesús. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Naja̱ kándatu̱'ún‑ró. Ja̱ tú kándi̱so‑ró stáa̱ náún. Á tú kájini̱‑ro̱. Á cha'a̱n‑ga̱ juku̱'un ini̱‑ro̱. Sáni ndava iní añú‑ro̱ náún.  
\v 18 Ká'i̱o so̱'o‑ró, te á tú kájini so̱'o‑ró. Ká'i̱o nduchi‑ro, te á tú kánde̱'é‑ró, te á tú kánuku̱'un ini̱‑ro̱.  
\v 19 Te na̱saa ji̱ka chítú ndɨ́ɨ státilá ni̱ kendo̱o kuáchí ní ka̱nastútú‑ró kɨvɨ́ ní sákuáchí‑rí u'u̱n sta̱tilá ni̱ ka̱yee ú'u̱n mil cha̱a, áchí‑ya̱. Te ni̱ kaka'a̱n‑de: Uxi̱ uu̱‑ni, áchí‑de.  
\v 20 Te ni̱ ka'a̱n tuku‑ya̱: Te na̱saa ndo'o̱ chítú ndɨ́ɨ státilá ni̱ kendo̱o kuáchí ní ka̱nastútú‑ró kɨvɨ́ ní sákuáchí‑rí usia̱ sta̱tilá ni̱ ka̱yee kúu̱n mil ña̱yɨvɨ, áchí‑ya̱. Te ni̱ kaka'a̱n‑de: Usia̱‑ni, áchí‑de.  
\v 21 Yúan‑na te ni̱ ka'a̱n‑ya̱ jíín‑de: Te onde̱ vina tú kájuku̱'un ini̱‑ro̱ náún, áchí‑ya̱. 
\s1 Ja̱ ní nasáva̱'a‑ya̱ cháa kuáá ñúu̱ Betsaida 
\p  
\v 22 Te ni̱ jaa̱‑ya̱ ñúu̱ Betsaida. Te ni̱ ka̱kinchaka‑i ɨɨn cha̱a kuáá núu̱‑yá. Te ni̱ kaka'a̱n nda̱'ú‑i jíín‑yá ja̱ ná ké'é‑yá‑de.  
\v 23 Yúan‑na te ni̱ tɨɨn‑ya̱ ndá'a cháa kuáá‑ún. Te ni̱ kiñi'in‑ya̱‑dé ñuu̱‑ún. Te ni̱ tɨvɨ̱ sɨ̱'vɨ́‑yá nduchi‑dé. Te ni̱ xndée‑ya̱ ndá'a‑yá sɨkɨ̱‑dé. Te ni̱ jika̱ tu̱'ún‑yá‑de: Á jiní‑ro̱ yakú, áchí‑ya̱.  
\v 24 Te máá‑de, ni̱ ndakoto‑de. Te ni̱ ka'a̱n‑de: Jiní‑ná ta̱ká cha̱a. Ko nátu̱'un yunu jiní‑ná‑de kájika‑de, áchí‑de.  
\v 25 Yúan‑na te ni̱ chaa tuku‑ya̱ ndá'a‑yá sɨkɨ̱ ndúchi‑dé. Te ni̱ ndakoto va̱'a‑de. Te ni̱ nduva̱'a ii̱‑dé. Te onde̱ jíká te ni̱ jini̱ kájí‑de ndivii.  
\v 26 Te ni̱ na̱tájí‑yá‑de kua̱no'on‑dé ve'e‑de. Te ni̱ ka'a̱n‑ya̱: Ma̱ kɨ́vɨ‑ró iní ñuu̱. Te ni ɨɨn nuu̱ cháa ñuu̱‑ún ma̱ kachí‑ro̱, áchí‑ya̱. 
\s1 Tu̱'un ni̱ ka'a̱n ndaa̱ Pedro 
\p  
\v 27 Te ni̱ kenda Jesús jíín cháa káskuá'a jíín‑yá kua'a̱n‑ya̱ jíín‑de ichi táká ñuu̱ ndañúu̱ Cesarea de Filipo. Te ichi‑ún ni̱ jika̱ tu̱'ún‑yá‑de: Te ruu̱, na̱ cha̱a kúu‑ri̱ káka'a̱n ña̱yɨvɨ, áchí‑ya̱ jíín cháa káskuá'a jíín‑yá.  
\v 28 Te ni̱ kaka̱stu̱'ún‑de nuu̱‑yá: Juan ja̱ skuánducha, káka'a̱n‑i. Te sava‑i: Elías. Te sava‑ga̱‑i: Ɨɨn cha̱a ni̱ jani tu̱'un Dios onde̱ sáá, áchí‑de.  
\v 29 Yúan‑na te ni̱ ka'a̱n‑ya̱ jíín‑de: Te róó, na̱ cha̱a kúu‑ri̱ káka'a̱n máá‑ró, áchí‑ya̱. Te ni̱ ka'a̱n Pedro: Máá‑ní kúu Cristo, áchí‑de jíín‑yá.  
\v 30 Te ni̱ ka'a̱n xaa̱n‑yá jíín‑de jíná'an‑de ja̱ tú ni ɨɨn nuu̱ kachí‑de tu̱'un‑ya̱. 
\s1 Jíín kɨvɨ́ ní ka'a̱n‑ya̱ já kúu̱‑ya̱ 
\p  
\v 31 Te ni̱ kejá'á‑yá ni̱ stá'a̱n‑ya̱ núu̱‑dé ja̱ jínu ñú'ún ndó'o xaa̱n máá Sé'e cha̱a. Te cha̱a ni̱ ka̱yii jíín táká sutu̱ ñá'nu jíín cháa káchaa tutu̱ ma̱ kuátú'ún‑de‑ya̱, chi̱ ka'ni‑dé‑ya̱. Te nuu̱ uní kɨvɨ̱ te nachaku̱‑ya̱, áchí‑ya̱.  
\v 32 Te kájí ní ka'a̱n‑ya̱ tú'un yá'a. Yúan‑na te Pedro, ni̱ tɨɨn‑de‑ya̱. Te ni̱ kejá'á‑de ká'a̱n xaa̱n‑dé nuu̱‑yá.  
\v 33 Te máá‑yá, ni̱ jíó káva‑ya̱. Te ni̱ ndakoto‑ya̱ núu̱ cháa káskuá'a jíín‑yá. Te ni̱ ka'a̱n xaa̱n‑yá nuu̱ Pedro: Satanás, kuxio ki'i̱n‑ro̱, chi̱ tú júku̱'un ini̱‑ro̱ tú'un Dios, chi̱ sa tu̱'un cha̱a júku̱'un ini̱‑ro̱, áchí‑ya̱.  
\v 34 Te ni̱ kana‑ya̱ xiní ñáyɨvɨ kuá'a̱‑ún jíín cháa káskuá'a jíín‑yá. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Na̱ni cha̱a nú kuní‑de kii‑de yata̱‑rí, te ma̱ chíñú'ún‑de máá‑de, te ná kuándéé iní‑de jíín túndó'o kii sɨkɨ̱‑dé, te ná kúndiki̱n‑de ruu̱ kii‑de.  
\v 35 Chi cha̱a jítú iní‑de ka̱ku‑de chi̱i tu̱ndó'o kii sɨkɨ̱‑dé, naa‑dé. Te va̱sa ná kúu̱ ɨɨn cha̱a ja̱ sɨkɨ́ rúu̱ jíín sɨkɨ́ tú'un va̱'a‑ri̱, ko ka̱ku‑de.  
\v 36 Chi na̱ún ní'i̱n cháa va̱sa ná kúndéé‑de ni'i̱n‑dé nɨ́ɨ́ ñúyɨ́vɨ, te nú xnáa‑dé añú‑de.  
\v 37 Xí na̱ún chúnáa cháa añú‑de.  
\v 38 Chi̱ nú ndé cha̱a kúka nuu̱ iní‑de nuu̱‑rí jíín núu̱ tú'un ká'a̱n‑ri̱ ma̱'nú ñáyɨvɨ yá'a ja̱ kái̱sɨ́kɨ ncháa̱‑i Dios jíín má'ñú cháa kásá'a kua̱chi, te suni súan kuka nuu̱ iní máá Sé'e cha̱a nuu̱‑dé, kɨvɨ̱ ndíi‑ya̱ jíín táká ndajá'a̱ ndóo‑ya̱. Te kɨvɨ̱‑ún ndúñá'nu‑ya̱ sá'a Táa̱‑ya̱, áchí‑ya̱. 
\c 9  
\p  
\v 1 Te suni ni̱ ka'a̱n‑ya̱ jíín‑de jíná'an‑de: Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró: Ió sava cha̱a ká'i̱in yá'a ja̱ má kúu̱ kutɨ‑dé onde̱ nú tú kuni̱‑de ñuu̱ nuu̱ tá'ú Dios tiñu, ndasa kii jíín fuerza, áchí‑ya̱. 
\s1 Sɨkɨ̱ já túku ni̱ nduu‑ya̱ 
\p  
\v 2 Yúan‑na te nuu̱ iñú kɨvɨ̱ te ni̱ jaka Jesús Pedro jíín Jacobo jíín Juan, te máni máá‑ni‑de ni̱ kiñi'in sɨ́ɨn‑ya̱‑dé kua'a̱n‑ya̱ jíín‑de ɨɨn yuku súkún. Te yúan, tuku ni̱ nduu‑ya̱ núu̱‑dé.  
\v 3 Te sa'ma‑yá ni̱ ka̱nandii ncháa̱, kɨyi̱ xaa̱n, nátu̱'un yu'a̱ volcán. Te tú íó ni ɨɨn ja̱ súan kuu nakacha kɨyi̱ ini̱ ñu̱yɨ́vɨ yá'a.  
\v 4 Te ni̱ ka̱ndenda Elías jíín Moisés ni̱ kajini̱‑de. Te ni̱ kanda̱tu̱'ún cháa‑ún jíín Jesús.  
\v 5 Yúan‑na te ni̱ ka'a̱n Pedro: Maestro, va̱'a‑ga̱ ná kéndo̱o‑yó yá'a, te sá'a‑ná uni̱ ve'e kuii. Ɨɨn kuu máá‑ní, ɨnga̱ kuu Moisés, te ɨnga̱ kuu Elías, áchí‑de jíín Jesús.  
\v 6 Chi̱ tú ní jiní‑de ndasa ka'a̱n‑de, chi̱ káyu̱'ú xáa̱n‑dé.  
\v 7 Te ni̱ chaa̱ ɨɨn viko̱ nu̱'ún. Te ni̱ jasu̱ nɨ́ɨ́ núu̱‑dé. Te nuu̱ vikó nu̱'ún‑ún ni̱ kenda ɨɨn tu̱'un ja̱ ní ka'a̱n: Ya̱'á kúu Se̱'e‑ri̱ ja̱ kúndá'ú ini̱‑ri̱, te kuni ná'ín‑ró tú'un ká'a̱n‑ya̱. Achí.  
\v 8 Te ni̱ ka̱ndakoto‑ni‑de. Te tuká ni ɨɨn na̱ún ní kájini̱‑de, chi̱ máá ɨ́ɨn‑na̱ Jesús.  
\v 9 Te kánuu‑de yuku‑ún, te ni̱ ka'a̱n xaa̱n‑yá jíín‑de ja̱ tú ni ɨɨn nuu̱ kachí‑de ja̱ súan ni̱ kajini̱‑de‑ún, chi̱ onde̱ ná náchaku̱ máá Sé'e cha̱a ma̱'ñú ndɨ́yi. Achí‑ya̱.  
\v 10 Te ni̱ kañu̱'un ini̱ máá‑de tu̱'un‑ún. Te kájika̱ tu̱'ún tá'an‑de na̱ún tu̱'un kúu: Ja̱ náchaku̱ ma̱'ñú ndɨ́yi.  
\v 11 Te ni̱ kajika̱ tu̱'ún‑de‑ya̱: Te cha̱a káchaa tutu̱ naja̱ káka'a̱n‑de ja̱ kánúú ndíi Elías xna'a̱n‑ga̱, áchí‑de.  
\v 12 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Ja̱ndáa̱ kúu ja̱ ndíi Elías xna'a̱n‑ga̱, te nasájáá‑de ta̱ká ndatíñu. Te suni yóso tú'un nuu̱ tutú ja̱ ndó'o xaa̱n máá Sé'e cha̱a te sájá'a̱ ini̱‑i nuu̱‑yá.  
\v 13 A ká'a̱n‑ri̱ jíín‑ró ja̱ Elías, a ni̱ kii‑de. Te ni̱ ka̱sá'a‑i ta̱ká ja̱ ní ka̱kuu ini̱‑i jíín‑de, nátu̱'un yóso tú'un‑de nuu̱ tutú, áchí‑ya̱. 
\s1 Su̱chí ñí'ín 
\p  
\v 14 Te ni̱ nchaa̱‑ya̱ núu̱ sáva‑ga̱ cha̱a káskuá'a jíín‑yá. Te ni̱ jini̱‑ya̱ ñáyɨvɨ kuá'a̱ xáa̱n, ni̱ ka̱jíkó ndúu̱‑i nɨ́ɨ́ núu̱‑dé. Te cha̱a káchaa tutu̱ kástátá'an jíín‑de.  
\v 15 Yúan‑na te ta̱ká ña̱yɨvɨ‑ún, ni̱ kajini̱‑ni‑i nuu̱‑yá. Te ni̱ ka̱naa iní‑i kánde̱'é‑i nuu̱‑yá. Te ni̱ katau̱‑i kua'a̱n‑i nuu̱‑yá. Te ni̱ kaka'a̱n‑i jíín‑yá.  
\v 16 Te ni̱ jika̱ tu̱'ún‑yá‑i: Na̱ sɨkɨ̱ kástátá'an‑ró jíín‑de jíná'an‑de, áchí‑ya̱.  
\v 17 Yúan‑na te ni̱ ka'a̱n ɨɨn cha̱a ma̱'ñú ñáyɨvɨ kuá'a̱‑ún: Maestro, va̱i nchaka‑ná se̱'e‑ná nuu̱‑ní, chi̱ tá'a̱n‑i ɨɨn tachi̱ ñí'ín.  
\v 18 Te tachi̱‑ún, ndéni kúu te nú ni̱ tɨɨn‑ni‑i, te já'ni yí'í‑ni‑i. Te sjáa‑ni ti'iñu̱ yu'u‑í. Te skɨ́'ñi nu̱'un‑i. Te kua̱'ichi̱‑i sá'a. Te ni̱ ka'a̱n‑ná jíín cháa káskuá'a jíín‑ní ja̱ ná kíñi'in‑de ki'i̱n. Te tú ní kákuu sá'a‑de, áchí‑de.  
\v 19 Te ni̱ ka'a̱n‑ya̱ jíín‑i: Ña̱yɨvɨ xáa̱n ní'in ini̱ kákuu‑ró. Na̱saa‑ga̱ kɨvɨ kúnchaa̱‑ri̱ jíín‑ró. Te na̱saa‑ga̱ kɨvɨ̱ ndó'o‑ri̱ jíín‑ró. Kua̱'a‑i ná kíi‑i nuu̱‑rí núsáá, áchí‑ya̱.  
\v 20 Te ni̱ kaja̱'a‑de‑i nuu̱‑yá. Te ni̱ jini̱‑i‑ya̱. Te tachi̱‑ún, ni̱ ja'ni yí'í xáa̱n‑ní‑i. Te ni̱ ndua̱‑i nuu̱ ñú'un. Te ni̱ tuu‑í. Te ni̱ jaa ti'iñu̱ yu'u‑í.  
\v 21 Te Jesús, ni̱ jika̱ tu̱'ún‑yá táa̱‑i: Na̱saa kɨvɨ̱ ní kuu tá'a̱n‑i tachi̱ yá'a, áchí‑ya̱. Te ni̱ ka'a̱n‑de: Onde̱ lúlí‑i.  
\v 22 Te tondó tɨnɨ̱ jínu ni̱ kuu chíndee‑i nuu̱ ñú'u̱n jíín núu̱ ndúcha, ja̱ ká'ni‑í kuní. Ko nú kuu sá'a‑ní, kundá'ú ini̱‑ní náá. Te chindéé chítuu‑ní náá, áchí‑de.  
\v 23 Te ni̱ ka'a̱n Jesús jíín‑de: Te nú kándíja‑ró, chi cha̱a kándíja te kuu ta̱ká ja̱ kuní‑de, áchí‑ya̱.  
\v 24 Yúan‑na te máá táa̱ su̱chí‑ún, ni̱ ka'a̱n jaa‑ni‑de: Kándíja‑ná, ko chindéé chítuu‑ní náá chi̱ tú kándíja va̱'a va̱'a‑ná, áchí‑de.  
\v 25 Te ni̱ jini̱ Jesús ja̱ ní katau̱ ña̱yɨvɨ kuá'a̱‑ún kua'a̱n‑i nuu̱‑yá. Te ni̱ ka'a̱n xaa̱n‑yá jíín tachí kíni‑ún: Tachi̱ ñí'ín só'ó, ruu̱ tá'ú‑rí tiñu nuu̱‑ro̱. Kenda‑ró iní‑i, te ma̱ ndɨ́vɨ‑ga̱‑ro̱ iní‑i, áchí‑ya̱ jíín.  
\v 26 Yúan‑na te tachi̱‑ún, ni̱ kana kó'ó. Te tɨnɨ̱ jínu ni̱ ja'ni yí'í xáa̱n‑gá‑i. Te ni̱ kenda kua'a̱n. Te máá súchí‑ún, ni̱ kundɨ̱yi‑ni‑i. Te ni̱ kaka'a̱n tɨnɨ̱ ña̱yɨvɨ: A ni̱ ji'i̱‑i, áchí.  
\v 27 Te Jesús, ni̱ tɨɨn‑ya̱ ndá'a‑í, te ni̱ ndukani‑ya̱‑í. Te ni̱ ndukuiñi̱‑i.  
\v 28 Te nuu̱ ní kɨ̱vɨ Jesús ini̱ ve̱'e, te cha̱a káskuá'a jíín‑yá, ni̱ kajika̱ tu̱'ún sɨ́ɨn‑de‑ya̱: Naja̱ tú ní kákuu kiñi'in‑ná tachi̱‑ún ki'i̱n, áchí‑de.  
\v 29 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Ɨɨn tá'an yu̱án, ni ma̱ kénda kutɨ kí'i̱n, te nú tú kaka̱n ta'u̱‑yo̱ te kondicha̱ ini̱‑yo̱, áchí‑ya̱. 
\s1 Ja̱ ní ka'a̱n tuku‑ya̱ já kúu̱‑ya̱ 
\p  
\v 30 Te ni̱ ka̱kenda‑ya̱ yúan. Te ni̱ kaja̱'a‑ya̱ kuá'a̱n‑ya̱ íchi ndáñúu̱ Galilea. Te tú ní kuní‑ya̱ já kúni tu̱'un ni ɨɨn.  
\v 31 Te ni̱ stá'a̱n‑ya̱ núu̱ cháa káskuá'a jíín‑yá: Ña̱yɨvɨ yá'a nastúu‑i máá Sé'e cha̱a nuu̱ ndá'a sáva‑ga̱ cha̱a. Te cha̱a‑ún, ka'ni‑dé‑ya̱. Ko nú ni̱ ji'i̱‑ya̱, te nuu̱ uní kɨvɨ̱ te nachaku̱‑ya̱, áchí‑ya̱ jíín‑de.  
\v 32 Te máá‑de, tú ní kájuku̱'un ini̱‑de tu̱'un yá'a. Te ni̱ kayu̱'ú‑de kaka̱ tu̱'ún‑de‑ya̱. 
\s1 Ja̱ ní ka̱státá'an‑de ndé cha̱a kúñá'nu‑ga̱ 
\p  
\v 33 Te ni̱ jaa̱‑ya̱ ñúu̱ Capernaum. Te nuu̱ ní kɨ̱vɨ‑ya̱ iní ve̱'e, te ni̱ jika̱ tu̱'ún‑yá‑de: Na̱ún tu̱'un ni̱ kanda̱tu̱'ún‑ró íchi‑ún, áchí‑ya̱.  
\v 34 Te máá‑de, tú ní káka'a̱n kutɨ‑dé. Chi̱ ichi‑ún ni̱ ka̱státá'an‑de ndé cha̱a kuu ñá'nu‑ga̱.  
\v 35 Yúan‑na te ni̱ jungo̱o‑ya̱. Te ni̱ kana‑ya̱ xiní ndɨ́'uxí uu̱‑de. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Nú ndé cha̱a kuní‑de kunúú‑de, te nduu‑de sandɨ̱'ɨ́‑na̱ nuu̱ táká tá'an‑de. Te kuatíñu‑de nuu̱ tá'an‑de.  
\v 36 Te ni̱ tɨɨn‑ya̱ ɨ́ɨn su̱chí lúlí. Te ni̱ jani‑ya̱‑í ma̱'ñú‑de. Te ni̱ junu nchaa̱‑ya̱‑í. Te ni̱ ka'a̱n‑ya̱ jíín‑de:  
\v 37 Cha̱a ja̱ jíín sɨ́'vɨ́‑rí kuatá'ú‑de ɨɨn su̱chí lúlí nátu̱'un su̱chí yá'a, te ruu̱ kuatá'ú‑de. Te cha̱a kuatá'ú rúu̱, nasu̱ rúu̱, chi̱ I'a̱ ni̱ tájí rúu̱ va̱i‑ri̱ kuatá'ú‑de, áchí‑ya̱.  
\v 38 Te ni̱ ka'a̱n Juan jíín‑yá: Maestro, ni̱ kajini̱‑ná ɨɨn cha̱a ja̱ jíín sɨ́'vɨ́‑ní ni̱ kiñi'in‑de tachi̱ kíni kája'a̱n. Te tú ndikín‑de yóó. Te ni̱ kajasu̱‑ná nuu̱‑dé. Chi̱ tú ndikín‑de yóó, áchí‑de.  
\v 39 Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Ma̱ kasú‑ro̱ núu̱‑dé, chi̱ ɨɨn cha̱a ja̱ jíín sɨ́'vɨ́‑rí sá'a‑de tiñu ñá'nu, ma̱ kúu naka'a̱n‑de sɨkɨ̱‑rí.  
\v 40 Chi cha̱a tú ká'a̱n sɨkɨ̱‑yo̱, ndújíín‑de jíín‑yó.  
\v 41 Te nú ndé cha̱a kua̱'a‑de ɨɨn yajin ndúcha kó'o‑ró jíín sɨ́'vɨ́‑rí, te nú súan ná sá'a‑de chi̱ kándujíín‑ró jíín Cristo, ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró ja̱ má xnáa‑dé ya̱'u‑de. 
\s1 Sɨkɨ̱ já skɨ́vɨ yóó nuu̱ kuáchi 
\p  
\v 42 Te nú ɨɨn su̱chí lúlí yá'a kándíja‑i ruu̱ te kɨ̱vɨ‑i kua̱chi sá'a ɨɨn cha̱a, te va'a̱‑ga̱ nú ní nú'ni̱ ɨɨn yo̱só ká'nu suku̱n‑dé, te kenda‑de ki'i̱n‑de nuu̱ ndúcha mar núú.  
\v 43 Te nú nda'a‑ro kuní skɨ́vɨ róó nuu̱ íó kua̱chi, xɨtɨ ná kí'i̱n. Va'a̱‑ga̱ ja̱ kúchaku̱ tɨ́kú'lu‑ró, nasu̱ já kóo ndendúú nda'a‑ro kí'i̱n‑ro̱ núu̱ infierno, nuu̱ kayú ñu'u̱n ja̱ má ndá'va̱ kutɨ.  
\v 44 Te yúan, ni tɨ̱ndákú‑de ma̱ kúu̱‑tɨ̱. Te ni ñu'u̱n‑ún ma̱ ndá'va̱ kutɨ.  
\v 45 Te nú ja'a̱‑ro̱ kuní skɨ́vɨ róó nuu̱ íó kua̱chi, xɨtɨ ná kí'i̱n. Va'a̱‑ga̱ ja̱ kúchaku̱ tɨ́kú'lu‑ró, nasu̱ já kóo ndendúú ja'a̱‑ro̱ kí'i̱n‑ro̱ núu̱ infierno, nuu̱ kayú ñu'u̱n ja̱ má ndá'va̱ kutɨ.  
\v 46 Te yúan, ni tɨ̱ndákú‑de ma̱ kúu̱‑tɨ̱. Te ni ñu'u̱n‑ún ma̱ ndá'va̱ kutɨ.  
\v 47 Te nú nduchi‑ro kuní skɨ́vɨ róó nuu̱ íó kua̱chi, tava ná kí'i̱n. Va'a̱‑ga̱ kɨ́vɨ‑ró ñúu̱ nuu̱ tá'ú Dios tiñu jíín ɨ́ɨn‑ni nduchi‑ro, nasu̱ já kóo ndendúú nduchi‑ro kí'i̱n‑ro̱ núu̱ infierno.  
\v 48 Te yúan, ni tɨ̱ndákú‑de ma̱ kúu̱‑tɨ̱. Te ni ñu'u̱n‑ún ma̱ ndá'va̱ kutɨ.  
\v 49 Chi ta̱ká cha̱a kuu u'a̱‑de sá'a ñu'u̱n. Te ta̱ká ku̱ñu ni̱ soko̱, kuu u'a̱ sá'a ñii̱.  
\v 50 Va̱'a íó ñii̱. Ko nú ñii̱‑ún ná náa xikó u'a̱, ndasa ndu'u'a̱ sá'a‑ró núsáá. Ná kúñava̱'a‑ró ñíi̱ iní máá‑ró. Te ma̱ kána̱á‑ro̱ jíín tá'an‑ró, áchí‑ya̱ jíín‑de. 
\c 10  
\s1 Sɨkɨ̱ tú'un tú xndóo tá'an 
\p  
\v 1 Te ni̱ kenda‑ya̱ yúan, te ni̱ chaa̱‑ya̱ ondé raya ñuu̱ Judea jíín ɨngá lado yata̱ yúcha Jordán. Te ni̱ kutútú tuku ña̱yɨvɨ kuá'a̱ núu̱‑yá. Te ni̱ stá'a̱n tuku‑ya̱ tú'un nuu̱‑í, nátu̱'un sá'a‑ya̱.  
\v 2 Te ni̱ ja̱koyo cha̱a fariseo nuu̱‑yá ja̱ kóto nchaa̱‑de‑ya̱. Te ni̱ kajika̱ tu̱'ún‑de‑ya̱: Á íó ley ja̱ skéndo̱o ɨɨn cha̱a ñasɨ́'ɨ́‑de, xí túu, áchí‑de.  
\v 3 Te máá‑yá, ni̱ ka'a̱n‑ya̱ jíín‑de: Na̱ún tiñu ni̱ tá'ú Moisés nuu̱‑ro̱, áchí‑ya̱.  
\v 4 Yúan‑na te ni̱ kaka'a̱n‑de: Moisés, ni̱ jatu̱'un‑de ja̱ kúva̱'a acta ndusɨ́ɨn, te ndo̱o‑ña, áchí‑de.  
\v 5 Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Sɨkɨ já ní'in ini̱ añú‑ro̱ jíná'an‑ró, yu̱án súan ni̱ tá'ú‑de tiñu yá'a nuu̱‑ro̱.  
\v 6 Ko onde̱ xnáñúú kɨvɨ́ ní jungo̱o ñu̱yɨ́vɨ, chi ja̱ yíí jíín já sɨ̱'ɨ́ ní sá'a Dios.  
\v 7 Ja̱ yúán kúu ja̱ skéndo̱o cha̱a táa̱‑de náa̱‑de, te ketá'an‑de jíín ñásɨ́'ɨ́‑de.  
\v 8 Te ja̱ ní kuu uu̱ tá'a̱n, ɨɨn‑na̱ kúu. Na̱ tuká kúu uu̱, chi̱ ɨɨn‑na̱ kúu.  
\v 9 Núsáá te ja̱ á ni̱ skétá'an Dios, ma̱ ndúsɨ́ɨn kutɨ sá'a ɨɨn ña̱yɨvɨ, áchí‑ya̱.  
\v 10 Te onde̱ ve'e te cha̱a káskuá'a jíín‑yá, ni̱ kajika̱ tu̱'ún tuku‑de‑ya̱ sɨkɨ́ tú'un‑ún.  
\v 11 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Nú ndé cha̱a skéndo̱o‑de ñasɨ́'ɨ́‑de te ta̱nda'a‑dé jíín ɨngá ña'an, te ísɨ́kɨ ncháa̱‑de ñasɨ́'ɨ́‑de nú súan.  
\v 12 Te nú máá ñásɨ́'ɨ́‑ún xndóo‑ña yíi‑ñá te ta̱nda'a‑ñá jíín ɨngá‑de, te tu̱'un ísɨ́kɨ ncháa̱ sá'a‑ña. Achí‑ya̱. 
\s1 Jesús jíín súchí lúlí 
\p  
\v 13 Te ni̱ cha̱koyo sava ña̱yɨvɨ núu̱‑yá jíín súchí lúlí ja̱ ké'é‑yá‑i. Te cha̱a káskuá'a jíín‑yá, ni̱ kaka'a̱n xaa̱n‑dé nuu̱ ñáyɨvɨ vái koyo jíín‑i.  
\v 14 Te ni̱ jini̱ Jesús. Te ni̱ kiti̱ ini̱‑ya̱. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Sía̱, ná kíkoyo su̱chí lúlí núu̱‑rí, te ma̱ kasú‑ro̱ íchi‑í, chi̱ tá'an súan kákuu ja̱ xíín ñúu̱ nuu̱ tá'ú Dios tiñu.  
\v 15 Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró: Nú ɨɨn cha̱a tú játú'ún‑de ñuu̱ nuu̱ tá'ú Dios tiñu nátu̱'un játú'ún ɨ́ɨn su̱chí lúlí, ma̱ kɨ́vɨ kutɨ‑dé yúan, áchí‑ya̱.  
\v 16 Te ni̱ junu nchaa̱‑ya̱‑í. Te ni̱ xndée‑ya̱ ndá'a‑yá xini̱‑í jíná'an‑i. Te ni̱ jika̱n ta'u̱‑yá ja'a̱‑í. 
\s1 Cha̱a kúká 
\p  
\v 17 Yúan‑na te ni̱ ki'in‑ya̱ íchi kuá'a̱n‑ya̱. Te jínu ɨɨn cha̱a súchí ni̱ chaa̱‑de. Te ni̱ jukuiñi̱ jítɨ́‑de nuu̱‑yá. Te ni̱ jika̱ tu̱'ún‑de‑ya̱: Cha̱a va̱'a kúu‑ní Maestro. Ndasa sá'a‑ná te ni'i̱n tá'u̱‑ná kuchaku̱‑ná nɨ́ɨ́ káni, áchí‑de.  
\v 18 Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Naja̱ ká'a̱n‑ro̱ cháa va̱'a jíín‑rí. Tú ni ɨɨn cha̱a va̱'a íó chi̱ máá ɨ́ɨn‑ni Dios.  
\v 19 A jiní‑ro̱ tú'un ni̱ tá'ú tíñu‑ya̱ núu̱‑ro̱: Ma̱ kúsɨ́kɨ ncháa̱ tá'an‑ró, ma̱ ká'ni‑ro ndɨ́yi, ma̱ sákuí'ná‑ró, ma̱ ká'a̱n‑ro̱ tú'un tú'ún, ma̱ kuánchaa̱‑ro̱ ndátíñu tá'an‑ró; kuandatu̱ nuu̱ táa̱‑ro̱ núu̱ náa̱‑ro̱, áchí‑ya̱.  
\v 20 Te máá‑de, ni̱ ka'a̱n‑de jíín‑yá: Ta̱ká tiñu yá'a a ni̱ skíkuu‑ná onde̱ ná lúlí‑ná, Maestro, áchí‑de.  
\v 21 Yúan‑na te ni̱ ndakoto Jesús nuu̱‑dé. Te ni̱ kumani̱‑yá jíín‑de. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Ɨɨn‑na̱ tiñu kúmani̱ sá'a‑ró núsáá. Kuá'án, te xi̱kó ndɨ́'ɨ‑ró já ñáva̱'a‑ró, te kua̱'a‑ró núu̱ ñáyɨvɨ ndá'ú. Te onde̱ andɨ́vɨ́ kóo yaji̱‑ro̱. Yúan‑na te kii‑ró, kundiki̱n‑ro̱ rúu̱ ki'o̱n, te kua̱ndéé iní‑ro̱ jíín túndó'o kii sɨkɨ̱‑ro̱, áchí‑ya̱.  
\v 22 Te máá cháa súchí‑ún, ni̱ kuxíí iní‑de ja̱ súan ni̱ ka'a̱n‑ya̱. Te ni̱ kee‑de kua'a̱n‑de. Te ndúkuí'a̱ ini̱‑de. Chi̱ kua'a̱ xáa̱n ndátíñu ñáva̱'a‑de.  
\v 23 Yúan‑na te Jesús, ni̱ ndakoto‑ya̱ nɨ́ɨ́ xíin‑yá. Te ni̱ ka'a̱n‑ya̱ jíín cháa káskuá'a jíín‑yá: Xaa̱n ú'u̱ kɨ̱vɨ ɨɨn cha̱a kúká iní ñuu̱ nuu̱ tá'ú Dios tiñu, áchí‑ya̱.  
\v 24 Yúan‑na te cha̱a káskuá'a jíín‑yá, kánaa iní‑de kájini so̱'o‑de tu̱'un ni̱ ka'a̱n‑ya̱‑ún. Ko ni̱ ka'a̱n tuku Jesús jíín‑de: Hijo, cha̱a ja̱ xáa̱n káchiñú'ún‑de xu̱'ún, xaa̱n ú'u̱ kɨ̱vɨ‑de ñuu̱ nuu̱ tá'ú Dios tiñu.  
\v 25 Yachi̱‑ga̱ ja̱'a ɨɨn camello yau̱ yikɨ tɨ́kuɨ́, vásá ɨ́ɨn cha̱a ku̱ká kɨ́vɨ‑de ñuu̱ nuu̱ tá'ú Dios tiñu, áchí‑ya̱.  
\v 26 Te máá‑de, ví'í‑gá kánaa iní‑de, kájani ini̱‑de: Ndé cha̱a ka̱ku núsáá.  
\v 27 Yúan‑na te Jesús, ni̱ ndakoto‑ya̱ núu̱‑dé. Te ni̱ ka'a̱n‑ya̱: Jíín cháa ma̱ kúu kutɨ, ko tú súan kúu jíín Dios. Chi ta̱ká‑ni tiñu ndɨ'ɨ‑ni kúu sá'a Dios, áchí‑ya̱.  
\v 28 Yúan‑na te Pedro, ni̱ ka'a̱n‑de jíín‑yá: Náá, ni̱ ka̱skéndo̱o‑ná ta̱ká ndatíñu‑ná. Te ni̱ kandiki̱n‑ná níí va̱i‑yó, áchí‑de.  
\v 29 Te ni̱ ka'a̱n Jesús: Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró: Nú ɨɨn cha̱a ni̱ skéndo̱o‑de ve'e‑de, xí ñaní‑de, xí kuá'a‑de, xí táa̱‑de, xí náa̱‑de, xí ñásɨ́'ɨ́‑de, xí sé'e‑de, xí tá'u̱‑dé, ja̱ sɨkɨ́ rúu̱ jíín sɨkɨ́ tú'un va̱'a ká'a̱n‑ri̱,  
\v 30 te nani'i̱n‑dé ɨɨn ciento vuelta vina kúu ve'e, kúu ñani̱, kúu kua̱'a, kúu náa̱, kúu se̱'e, kúu ta'u̱. Ko chindiki̱n‑i‑de. Ko onde̱ ɨnga̱ vida chaa̱, yúan‑na te kuchaku̱‑de nɨ́ɨ́ káni.  
\v 31 Te kua'a̱ cháa kúnúú, nduu‑de sandɨ̱'ɨ́‑na̱. Te cha̱a sandɨ̱'ɨ́‑na̱, ndunúú‑de, áchí‑ya̱. 
\s1 Ja̱ ní ka'a̱n tuku‑ya̱ já kúu̱‑ya̱ 
\p  
\v 32 Te ká'i̱in‑de ichi ní ka̱kaa‑de kája'a̱n‑de ñuu̱ Jerusalén. Te Jesús, yóxnúú‑yá nuu̱‑dé. Te ni̱ ka̱naa iní‑de kájini so̱'o‑de. Te ña̱yɨvɨ káindiki̱n‑ya̱‑ún káyu̱'ú‑i. Yúan‑na te ni̱ kana sɨ́ɨn tuku‑ya̱ xiní ndɨ́'uxí uu̱ cha̱a‑ún. Te ni̱ kastu̱'ún‑yá nuu̱‑dé ta̱ká tu̱'un kii sɨkɨ̱‑yá:  
\v 33 Ná kuní‑ro̱: Kaa‑yó kí'i̱n‑yo̱ ñúu̱ Jerusalén. Te yúan natu̱u máá Sé'e cha̱a nuu̱ táká sutu̱ ñá'nu, jíín núu̱ cháa káchaa tutu̱. Te ndonda‑de sɨkɨ̱‑yá kuu̱‑ya̱. Te nachi'i‑de‑ya̱ ndá'a cháa sɨ́ɨn nación.  
\v 34 Te cha̱a‑ún, sákátá‑de nuu̱‑yá. Te kua̱'a‑de ta'u̱‑yá. Te tɨvɨ̱ sɨ̱'vɨ́‑de nuu̱‑yá. Te ka'ni‑dé‑ya̱. Ko nuu̱ uní kɨvɨ̱ te nachaku̱‑ya̱, áchí‑ya̱. 
\s1 Favor jikán Jacobo jíín Juan nuu̱‑yá 
\p  
\v 35 Yúan‑na te Jacobo jíín Juan, se̱'e Zebedeo, ni̱ ja̱koyo‑de nuu̱‑yá. Te ni̱ kaka'a̱n‑de jíín‑yá: Maestro, kákuni̱‑ná ja̱ sá'a‑ní ɨɨn ja̱ kakán‑ná nuu̱‑ní, áchí‑de.  
\v 36 Te máá‑yá, ni̱ ka'a̱n‑ya̱ jíín‑de: Ndasa kákuni̱‑ro̱ já sá'a‑ri̱ jíín‑ró, áchí‑ya̱.  
\v 37 Te ni̱ kaka'a̱n‑de jíín‑yá: Kua̱'a‑ní xiin‑ní kuxiu̱kú‑ná jíín‑ní, ɨɨn‑ná ichi ndává'a‑ní, te ɨnga̱‑ná ichi ndávésé‑ní, kɨvɨ̱ ndúñá'nu‑ní, áchí‑de.  
\v 38 Yúan‑na te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Tú kájini̱‑ro̱ na̱ún kúu ja̱ kájika̱n‑ro̱. Á kuu ndo'o ta'a̱n‑ro̱ jíín‑rí jíín túndó'o kii sɨkɨ̱‑rí, xí kúu kuanducha‑ro núu̱ ní janducha‑rí, áchí‑ya̱.  
\v 39 Te máá‑de, ni̱ kaka'a̱n‑de: Kuu sá'a‑ná, áchí‑de. Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Ja̱ndáa̱, ja̱ ndó'o ta'a̱n‑ro̱ jíín‑rí jíín túndó'o kii sɨkɨ̱‑rí, te nuu̱ ní janducha‑rí, kuanducha‑ro,  
\v 40 ko ja̱ kúxiu̱kú‑ró íchi ndává'a‑ri̱ jíín íchi ndávésé‑rí, nasu̱ máá‑rí tá'ú tíñu ja̱ kuá'a‑ri̱ nuu̱‑ro̱, chi̱ íó tu̱'a ja̱ kúu ɨɨn cha̱a, te cha̱a‑ún ni'i̱n, áchí‑ya̱.  
\v 41 Te uxi̱‑ga̱ cha̱a‑ún, ni̱ ka̱jini so̱'o‑de tu̱'un yá'a. Te ni̱ kakiti̱ ini̱‑de nuu̱ Jacobo jíín núu̱ Juan.  
\v 42 Te Jesús, ni̱ kana‑ya̱ xiní‑dé. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Kájini̱‑ro̱ já táká cha̱a kájito‑de nátu̱'un cha̱a kákuñá'nu nuu̱ ñáyɨvɨ, te kátá'ú téyíí‑de tiñu nuu̱‑í. Te ja̱ kákuñá'nu sɨkɨ̱ máá‑de, suni kátɨ̱ɨn ni̱'in so̱'o‑de.  
\v 43 Ko sɨkɨ̱ róó jíná'an‑ró, na̱ tú súan koo: Chi̱ nú ndé róó kuní kuñá'nu nuu̱ tá'an‑ró, te róó kúu ja̱ kuátíñu nuu̱ tá'an‑ró.  
\v 44 Te nú ndé róó kuní kunúú, yu̱án ndúu mozo nuu̱ táká‑ro̱.  
\v 45 Chi̱ máá Sé'e cha̱a na̱ tú va̱i‑ya̱ já kuátíñu ña̱yɨvɨ núu̱‑yá, chi̱ sua játíñu‑ya̱ núu̱ ñáyɨvɨ te kua̱'a‑ya̱ máá‑yá kuu̱‑ya̱ já nákuaan‑ya̱ kuá'a̱ ñáyɨvɨ, áchí‑ya̱. 
\s1 Bartimeo, cha̱a kuáá 
\p  
\v 46 Yúan‑na te ni̱ ja̱koyo‑ya̱ ñúu̱ Jericó. Te yúan ni̱ ndenda‑ya̱ jíín cháa káskuá'a jíín‑yá jíín ñáyɨvɨ kuá'a̱ xáa̱n. Te Bartimeo cha̱a kuáá, se̱'e Timeo, kánchaa̱‑de yu'íchi, jikán‑de caridad.  
\v 47 Te ni̱ jini tu̱'un‑de ja̱ Jesús ñuu̱ Nazaret kúu‑ya̱. Te ni̱ kejá'á‑de kána kó'ó‑de: Jesús, Se̱'e David, kundá'ú ini̱‑ní náá, áchí‑de.  
\v 48 Te kua'a̱‑í, ni̱ kaka'a̱n xaa̱n‑í nuu̱‑dé, ja̱ ná kasú‑de yu'u‑dé. Ko máá‑de, ví'í‑gá ni̱ kana kó'ó‑de: Táta̱ Se̱'e David, kundá'ú ini̱‑ní náá vii̱, áchí‑de.  
\v 49 Yúan‑na te Jesús, ni̱ jukuiñi̱‑ya̱. Te ni̱ ka'a̱n‑ya̱: Kana xini̱‑dé ná kíi‑de, áchí‑ya̱. Te ni̱ ka̱kana‑i cha̱a kuáá‑ún: Ma̱ ndúkuí'a̱ ini̱‑ro̱. Ndukuiñi̱ ná chó'o̱, chi̱ kána‑ya̱ róó, áchí‑i jíín cháa‑ún.  
\v 50 Yúan‑na te máá cháa‑ún, ni̱ skána‑de tɨka̱chí‑de. Te ni̱ ndukuiñi̱‑de. Te ni̱ jaa̱‑de nuu̱ Jesús.  
\v 51 Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Na̱ún sá'a‑ri̱ jíín‑ró kuní‑ro̱, áchí‑ya̱. Te cha̱a kuáá‑ún, ni̱ ka'a̱n‑de jíín‑yá: Maestro, ja̱ ná ndúndiji̱n nduchi‑ná kuní‑ná, áchí‑de.  
\v 52 Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Kuá'án núsáá. Ja̱ kándíja‑ró ní nama róó, áchí‑ya̱. Te ni̱ ndundiji̱n‑ni nduchi‑dé. Te ni̱ ndiki̱n‑de Jesús kua'a̱n‑de ichi‑ún jíín‑yá. 
\c 11  
\s1 Ja̱ ní kɨ̱vɨ Jesús ñuu̱ Jerusalén 
\p  
\v 1 Te ni̱ ka̱kuyani‑ya̱ ñúu̱ Jerusalén, ñuu̱ Betfagé, jíín ñúu̱ Betania, chi̱i yuku Olivos. Te ni̱ tájí‑yá uu̱ cha̱a káskuá'a jíín‑yá kua'a̱n‑de.  
\v 2 Te ká'a̱n‑ya̱ jíín‑de: Kuá'án ñuu̱ kánchaa̱ nuu̱‑ro̱ jián. Te nuu̱ kɨ́vɨ‑ni‑ró yúan, te ni'i̱n‑ro̱ ɨ́ɨn burro nú'ni̱‑tɨ̱, ja̱ ní ɨɨn cha̱a té koso‑gá‑de‑tɨ̱. Te ndájí‑ró‑tɨ́, te kii‑ró jíín‑tɨ́.  
\v 3 Te nú ndé cha̱a ká'a̱n jíín‑ró: Naja̱ sá'a‑ró súan, achi̱‑de. Te kachi̱‑ro̱ kúni‑de: Máá Jíto'o̱‑yo̱ jínu ñú'ún‑yá‑tɨ̱, achi̱‑ro̱. Yúan‑na te tájí‑ni‑de‑tɨ̱ kíi‑ró jíín‑tɨ́, áchí‑ya̱ jíín‑de.  
\v 4 Te ni̱ kaja'a̱n‑de. Te ni̱ kani'i̱n‑dé burro‑ún nú'ni̱‑tɨ̱ yúxé'é íchi yatá ké'e, nuu̱ náketá'an uu̱ ichi. Te ni̱ ka̱ndájí‑de‑tɨ̱.  
\v 5 Te sava ja̱ ká'i̱in yúan, ni̱ kaka'a̱n jíín‑de: Na̱ún kásá'a‑ró sá burro jia̱n kándájí‑ró, áchí.  
\v 6 Yúan‑na te máá‑de, ni̱ kaka'a̱n‑de jíín‑ún, nátu̱'un ni̱ tá'ú Jesús tiñu nuu̱‑dé. Te vásá ní ka̱sía̱‑ún‑de va̱i‑de.  
\v 7 Te ni̱ chaa̱‑de jíín burro‑ún nuu̱ Jesús. Te ni̱ ka̱xndée‑de tɨka̱chí‑de sɨkɨ̱‑tɨ́. Te ni̱ jukoso̱‑yá‑tɨ̱.  
\v 8 Te kua'a̱‑dé, ni̱ kajaki̱n‑de tɨka̱chí‑de ini̱ ichi, te sava‑ga̱‑de, ni̱ kaja'nu̱‑de numa yúnu. Te ni̱ kajaki̱n‑de ini̱ ichi‑ún.  
\v 9 Te ña̱yɨvɨ kája'a̱n ichi núu̱‑yá, jíín ñáyɨvɨ kándiki̱n ichi yatá‑yá, káka'a̱n jaa‑i: Xáán va̱'a I'a̱ kúu‑ya̱. Ná nákana jaa‑yó‑yá, chi̱ ndíso‑ya̱ tíñu máá Tatá Dios.  
\v 10 Te kákusɨɨ̱ iní‑yo̱, chi̱ táa̱‑yo̱ David, a yani tá'ú‑de tiñu nuu̱‑yo̱. Xáán va̱'a I'a̱ kúu‑ya̱ ondé andɨ́vɨ́, áchí‑i.  
\v 11 Te ni̱ kɨ̱vɨ Jesús ini̱ ñuu̱ Jerusalén, jíín iní ve̱'e ii̱. Te ni̱ ndakoto‑ya̱ núu̱ táká ndatíñu íin nɨ́ɨ́ yúan. Te nuu̱ ní ini, te ni̱ kenda‑ya̱ kuá'a̱n‑ya̱ ñúu̱ Betania jíín máá uxí uu̱‑de. 
\s1 Tu̱'un mérkexe̱ 
\p  
\v 12 Te kɨvɨ̱ xía̱n‑ún, ni̱ ka̱kenda‑ya̱ kuá'a̱n‑ya̱ iní ñuu̱ Betania. Te ni̱ chaa̱ so̱ko chi̱i‑ya̱.  
\v 13 Te onde̱ jíká ní jini̱‑ya̱ ɨ́ɨn mérkexe̱ ja̱ íó numa ndá'a. Te ni̱ kandita‑ya̱ kuá'a̱n‑ya̱, jáni ini̱‑ya̱ já ní'i̱n‑yá ja̱ kée‑yá núú. Te nuu̱ ní jaa̱‑ya̱ núu̱ mérkexe̱‑ún, tú kutɨ na̱ún ní ní'i̱n‑yá, chi̱ máá núma‑ní íó. Chi̱ nasu̱ kɨvɨ́ kúun nde'e̱ kúu.  
\v 14 Yúan‑na te Jesús, ni̱ ka'a̱n‑ya̱: Ni ɨɨn tuká na̱ún kée kútɨ ndé'e̱ xiní‑ro̱ nɨ́ɨ́ káni, áchí‑ya̱ jíín mérkexe̱‑ún. Te cha̱a káskuá'a jíín‑yá, ni̱ ka̱jini so̱'o‑de ja̱ súan ni̱ ka'a̱n‑ya̱. 
\s1 Ja̱ ní sándoo‑ya̱ vé'e ii̱ 
\p  
\v 15 Te ni̱ ja̱koyo‑ya̱ ñúu̱ Jerusalén. Te ni̱ kɨ̱vɨ Jesús ini̱ ve̱'e ii̱. Te ni̱ kiñi'in‑ya̱ ñáyɨvɨ kájaan káxi̱kó íin‑i ini̱ ve̱'e ii̱‑ún kája'a̱n‑i. Te ni̱ skuíó káni‑ya̱ mesa cha̱a káxndái xu̱'ún, jíín silla cha̱a káxi̱kó paloma.  
\v 16 Te tú ní já'a‑ya̱ tú'un ja̱'a ni ɨɨn‑i jíín kɨ́yi ini̱ ve̱'e ii̱‑ún.  
\v 17 Te ni̱ stá'a̱n‑ya̱ tú'un nuu̱‑í: Á tú yóso núu̱ tutú ja̱ vé'e‑ri̱, ve'e nuu̱ kájika̱n ta'u̱ táká ña̱yɨvɨ nání. Ko máá‑ró, a ni̱ ka̱nasá'a‑ró yaú kava ñákui̱'ná, áchí‑ya̱.  
\v 18 Te cha̱a káchaa tutu̱ jíín sutú ñá'nu, ni̱ ka̱jini so̱'o‑de tu̱'un‑ún. Te kándúkú‑de modo ndasa ka'ni‑dé‑ya̱. Ko káyu̱'ú‑de‑ya̱, chi ta̱ká ña̱yɨvɨ kánaa iní‑i kájini so̱'o‑i tu̱'un stá'a̱n‑ya̱.  
\v 19 Te nuu̱ kuá'ini, te ni̱ kenda Jesús ini̱ ñuu̱‑ún, kua'a̱n‑ya̱. 
\s1 Ja̱ ní ichi̱ mérkexe̱ 
\p  
\v 20 Te ja̱ñá'a̱n ɨnga̱ kɨvɨ̱, ni̱ kana̱ja̱'a‑ya̱ kuá'a̱n‑ya̱. Te ni̱ kajini̱‑ya̱ mérkexe̱‑ún ja̱ á ni̱ ichi̱ onde̱ yo'o.  
\v 21 Yúan‑na te ni̱ nuku̱'un ini̱ Pedro. Te ni̱ ka'a̱n‑de jíín‑yá: Maestro, nde̱'é‑ní mérkexe̱‑ún ja̱ ní ka'a̱n ndɨva̱'a‑ní jíín. Te vina a ni̱ ichi̱ ii̱, áchí‑de.  
\v 22 Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Kandíja nuu̱ Dios,  
\v 23 chi ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró: Nú ndé cha̱a ka'a̱n‑de jíín yúku yá'a: Kuxio, te jungo̱o‑ró ondé nuu̱ mar, te nú tú kani sɨ̱kɨ́ ini̱‑de, chi̱ sua kándíja‑de ja̱ súan kuu ja̱ ní ka'a̱n‑de‑ún, te ja̱ ní jika̱n‑de‑ún, ni'i̱n‑dé.  
\v 24 Ja̱ yúán ká'a̱n‑ri̱ jíín‑ró: Ta̱ká ja̱ jikán‑ro̱, te kaka̱n ta'u̱‑ro̱ jíín, te ná kándíja‑ró já ní'i̱n‑ro̱, te ni'i̱n‑ro̱.  
\v 25 Te nú kájika̱n ta'u̱‑ro̱, te kuña ká'nu ini̱‑ro̱ núu̱ ndé ɨɨn cha̱a jíto u'u̱ róó, náva̱'a máá Táa̱‑ro̱ kánchaa̱‑ya̱ ondé andɨ́vɨ́, suni kuña ká'nu ini̱‑ya̱ núu̱ kuáchi‑ró.  
\v 26 Chi̱ nú tú kuña ká'nu ini̱‑ro̱, suni súan máá Táa̱‑ro̱ kánchaa̱‑ya̱ ondé andɨ́vɨ́, ma̱ kúña ká'nu ini̱‑ya̱ núu̱ kuáchi‑ró, áchí‑ya̱. 
\s1 Sɨkɨ̱ tíñu ndíso Jesús 
\p  
\v 27 Te ni̱ naja̱koyo tuku‑ya̱ ñúu̱ Jerusalén. Te jíka kuu‑ya̱ iní ve̱'e ii̱. Te sutu̱ ñá'nu, jíín cháa káchaa tutu̱, jíín cháa ni̱ ka̱yii, ni̱ cha̱koyo‑de nuu̱‑yá.  
\v 28 Te ni̱ kaka'a̱n‑de jíín‑yá: Na̱ jíín tú'un sá'a‑ró tíñu yá'a. Te ndéja̱ ní ka'a̱n jíín‑ró sá'a‑ró tíñu yá'a, áchí‑de.  
\v 29 Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Ná kaká tu̱'ún‑rí róó ɨɨn tu̱'un, te kachi̱‑ro̱ núu̱‑rí. Yúan‑na te ná kachí‑ri̱ nuu̱‑ro̱ na̱ jíín tú'un sá'a‑ri̱ tiñu yá'a.  
\v 30 Ja̱ ní skuánducha Juan sáá, á onde̱ andɨ́vɨ́ ní kii tu̱'un, xí cháa ni̱ tá'ú tíñu. Kastu̱'ún, áchí‑ya̱.  
\v 31 Yúan‑na te ni̱ kanda̱tu̱'ún máá‑de: Nú ka'a̱n‑yo̱: Ja̱ ondé andɨ́vɨ́. Te kachi̱‑de kuni‑yó: Naja̱ tú ní kákandíja‑ró núu̱‑dé núsáá.  
\v 32 Te nú ka'a̱n‑yo̱ já cháa ni̱ tá'ú tíñu. Te káyu̱'ú‑yo̱ ñáyɨvɨ, chi̱ ndivii‑í kájani ndaa̱ ini̱‑i ja̱ cháa ni̱ jani tu̱'un Dios ni̱ kuu Juan, áchí‑de jíín tá'an‑de.  
\v 33 Ja̱ yúán ní kaka'a̱n‑de: Tú kájini̱‑ri̱, áchí‑de jíín Jesús. Yúan‑na te ni̱ ka'a̱n Jesús: Suni ruu̱, tú kachi̱‑ri̱ nuu̱‑ro̱ na̱ jíín tú'un sá'a‑ri̱ tiñu yá'a núsáá, áchí‑ya̱ jíín‑de. 
\c 12  
\s1 Cha̱a kásátiñu nuu̱ itú uva 
\p  
\v 1 Te ni̱ kejá'á‑yá ni̱ ka'a̱n‑ya̱ tú'un yátá jíín‑de jíná'an‑de: Ɨɨn cha̱a, ni̱ nachu'un‑de ɨɨn itu̱ uva. Te ni̱ jasu̱‑de ja̱kú. Te ni̱ jacha‑de ɨɨn yau̱ nuu̱ kaxín‑de. Te ni̱ ndukani‑de ɨɨn torre. Te ni̱ xndóo‑de nuu̱ cháa kásátiñu jíín. Te ni̱ kee‑de kua'a̱n jíká‑de.  
\v 2 Te ɨɨn kɨvɨ̱ te ni̱ tájí‑de ɨɨn mozo‑de va̱i nuu̱ já kásátiñu jíín uva‑ún, ja̱ vái naki'in‑de nde'e̱ itú uva nuu̱ já ní ka̱sátiñu‑ún.  
\v 3 Ko máá‑ún, ni̱ ka̱katɨɨn‑ún mozo‑de. Te ni̱ ka̱stují‑dé. Te ni̱ ka̱kiñi'in‑ún‑de. kua̱no'on sáni‑ni‑de.  
\v 4 Te máá jíto'o̱, ni̱ na̱tájí tuku‑de ɨnga̱ mozo‑de va̱i nuu̱ já kásátiñu‑ún. Te ni̱ ka̱stují‑ún xiní mozo‑de. Te ni̱ ka̱sákátá nuu̱‑dé. Te ni̱ ka̱kiñi'in‑ún‑de kua̱no'on‑dé.  
\v 5 Te máá jíto'o̱ uva, ni̱ na̱tájí tuku‑de ɨnga̱ cha̱a va̱i. Te ni̱ ka̱ja'ni‑ún‑de jíín kuá'a̱‑gá‑de. Te sava‑de ni̱ ka̱stují. Te sava‑de ni̱ ka̱ja'ni.  
\v 6 Ko máá jíto'o̱, íó ɨɨn se̱'e‑de ja̱ kúndá'ú ini̱‑de. Te onde̱ sandɨ̱'ɨ́‑na̱ ni̱ tájí‑de se̱'e‑de va̱i nuu̱ cháa kásátiñu. Te ni̱ ka'a̱n‑de: Ná kóo jíñú'ún yúán núu̱ sé'e‑ri̱, áchí‑de.  
\v 7 Ko máá já kásátiñu‑ún, ni̱ kanda̱tu̱'ún: Cha̱a yá'a xíin tá'u̱. Ná chó'o̱, ná ká'ni‑yo‑dé, te ná ndóo ta'u̱‑dé kuu‑yó, áchí.  
\v 8 Te ni̱ ka̱katɨɨn‑ún sé'e‑de. Te ni̱ ka̱ja'ni‑ún‑i. Te ni̱ ka̱skána ndɨ̱yi‑ún yatá itú uva.  
\v 9 Ndasa sá'a jito'o̱ itu̱ uva‑ún núsáá. Chaa̱‑de, te xnáa‑dé ja̱ ní ka̱sátiñu‑ún. Te kua̱'a‑de itu̱ uva‑ún nuu̱ sáva‑ga̱ cha̱a, áchí‑ya̱.  
\v 10 Ni tutu̱ ii̱ yá'a té ka'u‑ga̱‑ro̱ náún. Yuu̱ já ní ka̱ské'ichi̱ cha̱a káchutá'an, ya̱'á kúu máá yúu̱ ndíso fuerza jiki̱.  
\v 11 Máá Tatá Dios, ni̱ sá'a‑ya̱ súan. Te kánaa iní‑yo̱ ndé'é‑yó tíñu yá'a, áchí‑ya̱ jíín‑de.  
\v 12 Te kándúkú‑de modo tɨɨn‑de‑ya̱. Chi ni̱ kaju̱ku̱'un ini̱‑de ja̱ sɨkɨ́ máá‑de kúu tu̱'un yátá ní ka'a̱n‑ya̱‑ún. Ko ni̱ kayu̱'ú‑de ni̱ ka̱jito‑de ña̱yɨvɨ. Te ni̱ ka̱xndóo‑de‑ya̱, te kája'a̱n‑de. 
\s1 Sɨkɨ̱ xú'ún yóo̱ 
\p  
\v 13 Te ni̱ ka̱tájí‑de sava cha̱a fariseo jíín cha̱a herodiano kája'a̱n‑de nuu̱‑yá, náva̱'a tɨɨn yátá‑de‑ya̱ jíín yakú tu̱'un.  
\v 14 Te ni̱ cha̱koyo‑de. Te ni̱ kaka'a̱n‑de jíín‑yá: Maestro, kájini̱‑ná ja̱ ká'a̱n ndaa̱‑ní. Te tú yú'ú‑ní jito‑ní ni ɨɨn cha̱a, chi̱ tú ndé'é‑ní ndasa jíto ta̱ká cha̱a, chi̱ sua stá'a̱n ndaa̱‑ní ichi Dios. Á kuu kua̱'a‑yó xú'ún yóo̱ nuu̱ César, xí túu. Á kua̱'a‑yó, xí ma̱ kuá'a‑yó, áchí‑de jíín‑yá.  
\v 15 Yúan‑na te máá‑yá, a ni̱ juku̱'un ini̱‑ya̱ já xndá'ú‑de‑ya̱ kákuni̱‑de. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Naja̱ kájito nchaa̱‑ro̱ rúu̱. Kua̱'a xu̱'ún jián ná kíi nde̱'é‑rí, áchí‑ya̱.  
\v 16 Te máá‑de, ni̱ kaja̱'a‑de xu̱'ún‑ún nuu̱‑yá. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Ndé cha̱a kúu cha̱a ncháá nuu̱ yá'a, jíín tú'un yóso yá'a, áchí‑ya̱. Te ni̱ kaka'a̱n‑de jíín‑yá: César kúu, áchí‑de.  
\v 17 Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Kua̱'a ja̱ xíin César nuu̱ César, te ja̱ xíin Dios nuu̱ Dios, áchí‑ya̱. Te ni̱ ka̱naa xáa̱n iní‑de ni̱ ka̱jini so̱'o‑de tu̱'un ni̱ ka'a̱n‑ya̱. 
\s1 Sɨkɨ̱ já náchaku̱ ndɨ̱yi 
\p  
\v 18 Yúan‑na te ni̱ cha̱koyo cha̱a saduceo nuu̱‑yá. Te cha̱a‑ún, káka'a̱n‑de ja̱ tú nachaku̱ kutɨ ndɨ́yi. Te ni̱ kajika̱ tu̱'ún‑de‑ya̱:  
\v 19 Maestro. Moisés, ni̱ chaa‑de tutu̱ ni̱ ndo̱o jíín‑yó, nú ñani̱ ɨɨn cha̱a kuu̱‑de, te ndo̱o ñasɨ́'ɨ́‑de, te nú tú se̱'e‑de ní íó, te ñani̱‑de naki'in ñasɨ́'ɨ́‑de, te nandaki̱n‑de tata̱ ñani̱‑de, áchí tutu̱‑ún.  
\v 20 Te ni̱ ka'i̱o usia̱ ñani̱. Te cha̱a núú, ni̱ ta̱nda'a‑dé. Yúan‑na te ni̱ ji'i̱‑de. Te tú ní xndóo‑de tata̱‑de.  
\v 21 Te cha̱a uu̱, ni̱ naki'in‑de‑ña. Te ni̱ ji'i̱‑de. Te ni cha̱a‑ún, tú ní xndóo‑de tata̱‑de. Te cha̱a uni̱, suni súan.  
\v 22 Te ndɨ́'usiá‑de, ni̱ kancha̱ka‑de‑ña. Te tú ni ɨɨn‑de ní xndóo‑de tata̱. Te onde̱ sandɨ̱'ɨ́‑na̱ te ni̱ ji'i̱ máá ñá'an‑ún.  
\v 23 Núsáá te kɨvɨ̱ náchaku̱ ta̱ká ndɨ̱yi, ja̱ náchaku̱ máá ñaní jíná'an‑de, te ndé ɨɨn‑de kuu‑ña ñásɨ́'ɨ́‑de, chi̱ ndɨ́'usiá‑de, ni̱ kancha̱ka‑de‑ña, áchí‑de jíín‑yá.  
\v 24 Yúan‑na te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Tú kájuku̱'un ini̱‑ro̱ jíín tutú ii̱, ni jíín fuerza Dios. Yu̱án ní ka̱stɨ́vɨ́‑ró tú'un.  
\v 25 Chi̱ kɨvɨ̱ náchaku̱‑de ma̱'ñú ndɨ́yi, ni tuká ta̱nda'a kútɨ‑dé, ni ma̱ náta̱nda'a máá‑ña. Chi̱ nduu‑de nátu̱'un ndajá'a̱ ká'i̱o andɨ́vɨ́.  
\v 26 Te sɨkɨ̱ ndɨ́yi ja̱ náchaku̱, á té ka'u‑ga̱‑ro̱ tutú Moisés, ndasa ni̱ ka'a̱n Dios jíín‑de ma̱'ñú yukú: Máá‑rí kúu Dios Abraham, Dios Isaac, Dios Jacob, áchí‑ya̱ jíín Moisés.  
\v 27 Ko nasu̱ Dios cha̱a ni̱ kaji'i̱ kúu‑ya̱, chi̱ sua Dios cha̱a káichaku̱ kúu‑ya̱. Xaa̱n kástɨ́vɨ́‑ró tú'un núsáá, áchí‑ya̱ jíín‑de. 
\s1 Tu̱'un tá'ú tíñu kánúú xáa̱n‑gá 
\p  
\v 28 Te ɨɨn cha̱a cháa tutu̱ ni̱ jini so̱'o‑de kástátá'an‑de, ni̱ jaa̱‑de. Te ni̱ jini̱‑de ja̱ vá'a ni̱ nachísó‑yá tu̱'un nuu̱‑dé. Te ni̱ jika̱ tu̱'ún‑de‑ya̱: Ndé tu̱'un kánúú xáa̱n‑gá nuu̱ táká tu̱'un ni̱ tá'ú‑yá tiñu sáá, áchí‑de.  
\v 29 Te ni̱ ka'a̱n Jesús jíín‑de: Ya̱'á kúu tu̱'un kánúú xáa̱n‑gá nuu̱ táká‑ga̱: Kuni so̱'o Israel, máá Tatá‑yo̱ Dios, máá ɨ́ɨn‑ni‑ya̱ íó.  
\v 30 Núsáá te kumani̱‑ro̱ jíín máá Tatá‑ro̱ Dios onde̱ jíín iní jíín añú‑ro̱, jíín nɨ́ɨ́ núu̱ jiní tuní‑ro̱, jíín nɨ́ɨ́ fuerza‑ro̱. Ya̱'á kúu tu̱'un tá'ú tíñu kánúú xáa̱n‑gá.  
\v 31 Te tu̱'un uu̱ kúu suni nátu̱'un ɨnga̱‑ún: Kundá'ú ini̱‑ro̱ tá'an‑ró nátu̱'un kúndá'ú ini̱‑ro̱ máá‑ró. Tuká ɨnga̱ tu̱'un tá'ú tíñu kánúú‑ga̱ íó, chi ya̱'á‑na̱, áchí‑ya̱ jíín‑de.  
\v 32 Yúan‑na te cha̱a cháa tutu̱, ni̱ ka'a̱n‑de jíín‑yá: Ja̱ndáa̱ Maestro, va̱'a ká'a̱n‑ní, chi̱ Dios ɨɨn‑ni‑ya̱ íó, te tuká ɨnga̱ Dios íó.  
\v 33 Te kumani̱‑yo̱ jíín‑yá onde̱ jíín iní jíín añú‑yo̱, jíín nɨ́ɨ́ núu̱ jiní tuní‑yo̱, jíín nɨ́ɨ́ fuerza‑yo̱, te kundá'ú ini̱‑yo̱ tá'an‑yó nátu̱'un kúndá'ú ini̱‑yo̱ máá‑yó, kánúú xáa̱n‑gá ya̱'á vásá já ká'mu‑yó kɨ́tɨ jíín táká kɨtɨ ká'ni‑yo núu̱‑yá, áchí‑de jíín‑yá.  
\v 34 Yúan‑na te ni̱ jini̱ Jesús ja̱ vá'a xaa̱n ní xndíó káni‑de tu̱'un. Te ni̱ ka'a̱n‑ya̱ jíín‑de: A yani kuu kɨ̱vɨ‑ró ñúu̱ nuu̱ tá'ú Dios tiñu, áchí‑ya̱. Te ni ɨɨn‑de, tuká ní chúndéé iní‑de kaka̱ tu̱'ún‑de‑ya̱: 
\s1 Sɨkɨ̱ Sé'e David 
\p  
\v 35 Te ni̱ stá'a̱n Jesús ini̱ ve̱'e ii̱. Te ni̱ ka'a̱n‑ya̱: Naja̱ káka'a̱n cha̱a káchaa tutu̱ ja̱ Cristo kúu Se̱'e David.  
\v 36 Chi̱ suni máá David, ni̱ ka'a̱n‑de ni̱ sá'a Espíritu Santo jíín‑de: Máá Tatá Dios ni̱ ka'a̱n‑ya̱ jíín Jíto'o̱‑ri̱: Nungo̱o‑ró íchi ndává'a‑ri̱, te ná chúkú‑rí cha̱a kájito u'u̱ róó, kuu‑de teyu̱ kuxndíi ja'a̱‑ro̱, áchí Dios. Achí David.  
\v 37 Chi̱ suni máá David, Jito'o̱, ni̱ ka'a̱n‑de jíín‑yá. Te ndasa kuu máá‑yá se̱'e‑de núsáá, áchí‑ya̱. Te ta̱ká ña̱yɨvɨ ndá'ú, ni̱ ka'i̱o ini̱ ni̱ ka'i̱o añú‑i ni̱ ka̱jini ná'ín‑i ja̱ ká'a̱n‑ya̱. 
\s1 Sɨkɨ̱ já ní kana jíín‑yá nuu̱‑í 
\p  
\v 38 Te ni̱ stá'a̱n‑ya̱ tú'un. Te ni̱ ka'a̱n‑ya̱ jíín‑i: Koto‑ró máá‑ró núu̱ cháa káchaa tutu̱. Chi̱ kákuni̱‑de kaka‑de jíín sú'nu̱ káni. Te kákuni̱‑de ja̱ ká'a̱n sa̱'án‑yo̱ jíín‑de nu̱yá'u.  
\v 39 Te silla onde̱ xini̱ mesa ini̱ ve̱'e sinagoga, jíín silla xini̱ mesa nuu̱ íó xíni kákuni̱‑de.  
\v 40 Te cha̱a yá'a kákókó‑de ve'e ña'an kéndo̱o ndá'ú, te kásá'a‑de ja̱ túu kua̱chi‑de, yu̱án kájika̱n ta'u̱ ná'án‑de. Cha̱a yá'a ví'í‑gá ta'nu̱ ndatu̱‑de, áchí‑ya̱. 
\s1 Ja̱ ní soko̱ ñá'an viuda xu̱'ún 
\p  
\v 41 Te kánchaa̱ Jesús ichi núu̱ janú nuu̱ kásoko̱‑í xu̱'ún. Te ndé'é‑yá ndasa káchu'un kua'a̱ ñáyɨvɨ xú'ún iní janu̱‑ún. Te kua'a̱ cháa kúká, ni̱ ka̱chu'un téyíí‑de.  
\v 42 Te ni̱ chaa̱ ɨɨn ña'an ní kendo̱o ndá'ú. Te ni̱ chindee‑ña úu̱ xu̱'ún yɨ́kɨ́ náa, ja̱ kúu ɨɨn centavo.  
\v 43 Yúan‑na te ni̱ kana‑ya̱ xiní cháa káskuá'a jíín‑yá. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró, ja̱ ñá'an ní kendo̱o ndá'ú yá'a, ni̱ chu'un‑ga̱‑ña vásá táká ña̱yɨvɨ ní ka̱chu'un ini̱ janu̱‑ún.  
\v 44 Chi ta̱ká‑i, ni̱ ka̱chu'un‑i ja̱ ní ndendoso sɨkɨ́‑í. Ko ña'an yá'a, va̱sa kúndá'ú‑ña, ko ni̱ chu'un ndɨ'ɨ‑ña já ñáva̱'a‑ña, onde̱ jíín táká ja̱ kúchaku̱‑ña, áchí‑ya̱ jíín‑de. 
\c 13  
\s1 Tuni̱ nuu̱ kúyani nchaa̱ Jesús 
\p  
\v 1 Te ni̱ ndenda‑ya̱ iní ve̱'e ii̱. Te ɨɨn cha̱a skuá'a jíín‑yá, ni̱ ka'a̱n‑de jíín‑yá: Maestro, nde̱'é‑ní ná xaa̱n lúu yuu̱ te luu ve'e íó, áchí‑de.  
\v 2 Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Á ndé'é‑ró núu̱ táká ve'e ná'nu yá'a. Ma̱ kútá'an‑ga̱ ni ɨɨn yuu̱, chi̱ ɨɨn kɨvɨ̱ te ndɨ'ɨ ndua̱, áchí‑ya̱.  
\v 3 Te ni̱ jungo̱o‑ya̱ ondé yuku Olivos, ichi núu̱ vé'e ii̱. Te Pedro, Jacobo, Juan, jíín Andrés, ni̱ kajika̱ tu̱'ún sɨ́ɨn‑de‑ya̱:  
\v 4 Kastu̱'ún‑ní nuu̱‑ná. Ndé kɨvɨ̱ kóo ta̱ká tiñu yá'a. Te na̱ún tuni̱ koo nuu̱ kúyani chaa̱ ta̱ká tiñu yá'a, áchí‑de.  
\v 5 Te Jesús, ni̱ kejá'á‑yá ká'a̱n‑ya̱ jíín‑de: Koto‑ró máá‑ró jíná'an‑ró, náva̱'a tú xndá'ú ni ɨɨn‑de róó.  
\v 6 Chi̱ kikoyo kua'a̱ cháa ki'in núu‑de sɨ́'vɨ́‑rí, te ka'a̱n‑de: Máá‑rí kúu Cristo, achi̱‑de. Te xndá'ú‑de kua'a̱ xáa̱n ñáyɨvɨ.  
\v 7 Te nú ni̱ ka̱jini tu̱'un‑ró káka'a̱n ja̱ íó guerra xí já kóo guerra, te ma̱ yú'ú‑ro̱. Chi̱ kánúú kóo súan. Ko té ji̱nu‑ga̱ kɨvɨ̱.  
\v 8 Chi̱ ndonda nación sɨkɨ̱ nación, te ñuu̱ sɨkɨ̱ ñúu̱. Te yá'a yúan ta̱an, te nɨ̱'ɨn, te koo tama̱, te nɨ̱'ɨn ña̱yɨvɨ. Ya̱'á kákuu tu̱ndó'o kéjá'á núú. 
\s1 Tu̱'un ndasa ndo'o ña̱yɨvɨ kákandíja 
\p  
\v 9 Te koto‑ró máá‑ró, chi̱ nastúu‑de róó nuu̱ junta. Te ini̱ ve̱'e sinagoga xndó'o‑de róó. Te onde̱ nuu̱ gobernador jíín núu̱ rey kana‑de xini̱‑ro̱ já sɨkɨ́ rúu̱. Te kani ndaa̱‑ro̱ tú'un nuu̱‑dé.  
\v 10 Te jínu ñú'ún já xná'a̱n‑ga̱ kuicha̱ tu̱'un va̱'a‑ri̱ nuu̱ táká ña̱yɨvɨ.  
\v 11 Te nú kincha̱ka‑de róó, ja̱ nástúu‑de róó, ma̱ nákani tu̱'a ini̱‑ro̱ ndasa ka'a̱n‑ro̱ jíín‑de. Chi ja̱ kuá'a‑ya̱ núu̱‑ro̱ hora jia̱n, yu̱án ká'a̱n‑ro̱. Chi̱ nasu̱ máá‑ró ká'a̱n, chi̱ Espíritu Santo ka'a̱n, áchí‑ya̱.  
\v 12 Te ñani̱ jíín ñaní nastúu tá'an ja̱ ná kúu̱. Te táa̱ jíín sé'e, te se̱'e‑ún ndonda sɨkɨ̱ táa̱, te ka'ni tá'an.  
\v 13 Te ta̱ká ña̱yɨvɨ, koto u'u̱‑i róó ja̱ sɨkɨ́ rúu̱. Ko cha̱a kundii̱ ni̱'in onde̱ kɨvɨ̱ jínu, cha̱a‑ún ka̱ku, áchí‑ya̱.  
\v 14 Ko nú ni̱ kajini̱‑ro̱ já káchá'án te ni̱ tucha̱ ta̱ká ndatíñu nuu̱ má kúu kutɨ kóo súan núú, nátu̱'un ni̱ ka'a̱n Daniel cha̱a ni̱ jani tu̱'un Dios (cha̱a ká'u, ná júku̱'un ini̱‑de), yúan‑na te ña̱yɨvɨ káxiu̱kú iní ñuu̱ Judea, ná kúnu‑i ki̱ngoyo‑i onde̱ yuku.  
\v 15 Te cha̱a kándee xini̱ vé'e, ma̱ núu‑de ndɨ̱vɨ‑de ini̱ ve̱'e ki'in‑de ndatíñu‑de.  
\v 16 Te cha̱a kándee onde̱ rancho, ma̱ náxíó káva yátá‑de náki'in‑de tɨka̱chí‑de ichi yatá‑dé.  
\v 17 Ko kɨvɨ̱‑ún naka̱ ndá'ú kuu ja̱ káñu̱'un se̱'e, jíín já káskáxin‑í.  
\v 18 Ná kakán ta'u̱‑ro̱ núsáá, náva̱'a tú kunu‑ró máá víko víjin ki'i̱n‑ro̱.  
\v 19 Chi̱ kɨvɨ̱‑ún koo tu̱ndó'o, ja̱ té tuká koo onde̱ kɨvɨ̱ ní sá'a Dios ñu̱yɨ́vɨ, te onde̱ vina, te ni ma̱ kóo‑ga̱.  
\v 20 Te nú máá Tatá Dios, tú ní náxndɨ́yi‑ya̱ kɨvɨ́‑ún núú, ni ɨɨn cha̱a ma̱ káku kutɨ‑dé núú. Ko ja̱ sɨkɨ́ cháa ni̱ naka̱ji‑ya̱, yu̱án ní na̱xndɨ́yi‑ya̱ kɨvɨ́‑ún. 
\s1 Tuni̱ máá kɨvɨ́ sándɨ̱'ɨ́‑na̱ 
\p  
\v 21 Núsáá te nú ndé cha̱a ká'a̱n jíín‑ró: Yá'a nde̱'é‑ró kánchaa̱ Cristo, xí: Yúan nde̱'é‑ró kánchaa̱‑ya̱, ma̱ kándíja‑ró já ká'a̱n‑de.  
\v 22 Chi̱ kenda Cristo xndá'ú, jíín cháa kani tu̱'un tú'ún. Te sá'a‑de tuni̱ tiñu ñá'nu xaa̱n, náva̱'a xndá'ú‑de onde̱ cha̱a ni̱ naka̱ji‑ya̱, te nú ná kúu sá'a‑de.  
\v 23 Koto‑ró máá‑ró, chi̱ a ni̱ kachi̱ ndɨ'ɨ‑ri̱ nuu̱‑ro̱, áchí‑ya̱.  
\v 24 Te kɨvɨ̱ ndɨ́'ɨ koo tu̱ndó'o‑ún, kutúún ndika̱ndii, te yoo̱ ma̱ ndíi‑gá.  
\v 25 Te tiñu̱ú xíní, jungoyo‑tɨ̱ íchi ándɨ́vɨ́ kíi‑tɨ̱. Te ta̱ká fuerza andɨ́vɨ́, ndɨ'ɨ ka'ya.  
\v 26 Yúan‑na te kuni̱ ña̱yɨvɨ núu̱ máá Sé'e cha̱a kii‑ya̱ íchi ándɨ́vɨ́ núu̱ vikó nu̱'ún jíín kuá'a̱ fuerza ja̱ ndúñá'nu‑ya̱.  
\v 27 Yúan‑na te tájí‑yá ndajá'a̱‑yá ki̱ngoyo. Te nastútú‑yá ña̱yɨvɨ ní naka̱ji‑ya̱ ndɨ́kúu̱n lado ñu̱yɨ́vɨ, onde̱ nuu̱ ndɨ́'ɨ ñu'un, te onde̱ nuu̱ ndɨ́'ɨ andɨ́vɨ́.  
\v 28 Vina te skuá'a‑ró ndasa sá'a yunu mérkexe̱. Nú a ni̱ nduyúcha núma, te ni̱ na̱jaa nda'a, te a kájini̱‑ro̱ já á ni̱ kuyani viko sáú.  
\v 29 Suni súan róó, nú a ni̱ kajini̱‑ro̱ kuákuu ta̱ká tiñu yá'a, te kuni̱‑ro̱ já á yani jaa̱ kɨvɨ̱‑ún.  
\v 30 Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró ja̱ má náa ñáyɨvɨ yá'a, onde̱ ná skíkuu ta̱ká tiñu yá'a.  
\v 31 Andɨ́vɨ́ jíín ñúyɨ́vɨ chi̱ naa, ko tu̱'un ká'a̱n‑ri̱ chi ma̱ náa. 
\s1 Sɨkɨ̱ já kúndito‑i 
\p  
\v 32 Ko kɨvɨ̱ kóo‑ún, jíín hora, tú ni ɨɨn cha̱a jiní, ni ndajá'a̱ ká'i̱o andɨ́vɨ́, ni máá Sé'e‑ya̱, chi̱ máá ɨ́ɨn‑ni máá Táa̱‑yo̱ Dios jiní‑ya̱.  
\v 33 Koto‑ró máá‑ró, te kundito‑ró, te kaka̱n ta'u̱‑ro̱. Chi̱ tú kájini̱‑ro̱ na̱ kɨvɨ̱ kóo.  
\v 34 Chi̱ nátu̱'un ɨɨn cha̱a kua'a̱n jíká‑de. Te ni̱ xndóo‑de ve'e‑de. Te ni̱ ja̱'a‑de tu̱'un nuu̱ mozo‑de, ná tiñu sá'a ɨɨn ɨɨn‑de. Te cha̱a ndíto yuxé'é, ni̱ ta'u̱ tíñu nuu̱‑dé, ná kúndito‑de.  
\v 35 Núsáá te kundito‑ró, chi̱ tú kájini̱‑ro̱ na̱ hora nchaa̱ jito'o̱ ve'e‑ún, á aíni, á ñúú, á kána lí'li, á ja̱ñá'a̱n.  
\v 36 Chi̱ sánaa iní‑ro̱ te nchaa̱‑ni‑ya̱. Te ni'i̱n‑yá róó kákixi̱‑ro̱.  
\v 37 Te ta̱ká tu̱'un ká'a̱n‑ri̱ jíín‑ró yá'a, suni ká'a̱n‑ri̱ jíín ndívii‑í jíná'an‑i. Kundito jíná'an‑ró, áchí‑ya̱. 
\c 14  
\s1 Ja̱ ní ka̱natɨɨn tu̱'un tá'an sɨkɨ̱ Jesús 
\p  
\v 1 Te uu̱‑ga̱ kɨvɨ̱ te vásá ní kuu Pascua jíín víko kóo sta̱tilá tú yí'i yujan íá. Te sutu̱ ñá'nu jíín cháa káchaa tutu̱, ni̱ ka̱ndúkú‑de modo ndasa xndá'ú‑de‑ya̱ te tɨɨn‑de‑ya̱. Te ka'ni‑dé‑ya̱ kákuni̱‑de.  
\v 2 Te ni̱ kaka'a̱n‑de: Ma̱ kúu sá'a‑yó máá kɨvɨ́ víko, chi̱ nú súan te ndonda vaa̱ ña̱yɨvɨ, áchí‑de. 
\s1 Jesús jíín ñá'an ndíso perfume 
\p  
\v 3 Te kándee‑ya̱ ñúu̱ Betania, kánchaa̱‑ya̱ núu̱ mesa ve'e Simón cha̱a té'yu̱ ndɨ̱'yi. Te ni̱ chaa̱ ɨɨn ña'an, kándá'á‑ña ɨ́ɨn tiya'a̱ ñú'un perfume máá nían ita̱ nardo kúu. Te ncháá ya'u téyíí. Te ni̱ tá'ú‑ña tíya'a̱‑ún. Te ni̱ chu'un‑ña xiní‑yá.  
\v 4 Te sava, ni̱ kakiti̱ ini̱. Te ni̱ kaka'a̱n: Naja̱ náa perfume jia̱n.  
\v 5 Chi̱ kuu kuya̱'u ví'í‑gá uni̱ ciento peso, te kua̱'a‑yó núu̱ ñáyɨvɨ ndá'ú núú, áchí. Te ni̱ kaka'a̱n vaa̱ sɨkɨ̱‑ñá.  
\v 6 Ko Jesús, ni̱ ka'a̱n‑ya̱: Sía̱‑ña. Naja̱ kástá'a̱n‑ro̱‑ñá. Tiñu va̱'a sá'a‑ña jíín‑rí, áchí‑ya̱.  
\v 7 Chi̱ nene̱ káxiu̱kú ñáyɨvɨ ndá'ú jíín‑ró. Te nú kákuni̱‑ro̱ te kuu sá'a va̱'a‑ró jíín‑i. Ko ruu̱, na̱ tú nene̱ kánchaa̱‑ri̱ jíín‑ró.  
\v 8 Ya̱'á‑ni ni̱ kuu ni̱ sá'a‑ña. Chi̱ a ni̱ chi'i tu̱'a‑ña perfume yikɨ kúñu‑ri̱ kɨvɨ̱ yúji‑ri̱.  
\v 9 Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró, ja̱ nɨ́ɨ́ ñúyɨ́vɨ nú ná kui̱cha tu̱'un va̱'a yá'a, te tiñu ni̱ sá'a‑ña yá'a, suni koo tu̱'un náva̱'a ná núku̱'un ini̱‑i‑ña, áchí‑ya̱.  
\v 10 Yúan‑na te Judas Iscariote, ɨɨn ja̱ uxí uu̱ yúan, kua'a̱n‑de nuu̱ sutú ñá'nu ja̱ nástúu‑de‑ya̱.  
\v 11 Te súan ni̱ ka̱jini so̱'o sutu̱‑ún. Te ni̱ ka̱kusɨɨ̱ iní. Te ni̱ ka̱keyu'u já kuá'a xu̱'ún núu̱‑dé. Te ná ndúkú‑de modo ndasa nastúu‑de‑ya̱. 
\s1 Viko lélú Pascua 
\p  
\v 12 Te máá kɨvɨ́ kéjá'á víko kóo sta̱tilá tú yí'i yujan íá, suni máá kɨvɨ́ kásoko̱‑dé lélú Pascua, te cha̱a káskuá'a‑ún, ni̱ kaka'a̱n‑de jíín‑yá: Ndénu̱ kuní‑ní ná kísátu̱'a‑ná nuu̱ kée‑ní lélú Pascua, áchí‑de.  
\v 13 Te ni̱ tájí‑yá uu̱ cha̱a káskuá'a jíín‑yá kua'a̱n‑de. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Kuá'án onde̱ ñuu̱. Te yúan ketá'an‑ró jíín ɨ́ɨn cha̱a ndíso ɨɨn kɨ̱yi nducha. Te kundiki̱n‑ro̱‑dé ki'i̱n‑ro̱ jíín‑de.  
\v 14 Te nuu̱ ndɨ́vɨ‑de, yúan ka'a̱n‑ro̱ jíín máá jíto'o̱ ve'e‑ún: Achí máá Maestro: Ndénu̱ íó ɨɨn ve'e kua̱'a núu‑ní nuu̱ kée‑ná lélú Pascua jíín cháa káskuá'a jíín‑ná, achi̱‑ro̱.  
\v 15 Te máá‑de, ná stá'a̱n‑de ɨɨn cuarto ká'nu onde̱ xini̱ vé'e nuu̱‑ro̱, yúan a íó tu̱'a. Te yúan sátu̱'a‑ró ndasa kuu‑yó, áchí‑ya̱ jíín‑de.  
\v 16 Te kája'a̱n cha̱a káskuá'a jíín‑yá. Te ni̱ ja̱koyo‑de ñuu̱‑ún. Te ni̱ kani'i̱n‑dé nátu̱'un ni̱ ka'a̱n‑ya̱ jíín‑de. Te ni̱ ka̱sátu̱'a‑de ndasa kuxíni‑de lélú Pascua.  
\v 17 Te ni̱ ini. Te kua'a̱n‑ya̱ jíín máá uxí uu̱ cha̱a‑ún.  
\v 18 Te káxiu̱kú‑de nuu̱ mesa káyee‑dé staa̱. Te ni̱ ka'a̱n Jesús: Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró, ja̱ ɨ́ɨn róó, ja̱ yée jíín‑rí, nastúu‑ró rúu̱, áchí‑ya̱.  
\v 19 Yúan‑na te ni̱ ka̱kuxíí iní‑de. Te ni̱ kajika̱ tu̱'ún ná ɨɨn ná ɨɨn‑de‑ya̱: Ja̱ náá náún, ja̱ náá náún, ká'a̱n ɨɨn‑de, ká'a̱n ɨnga̱‑de.  
\v 20 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Ɨɨn ja̱ uxí uu̱ ja̱ chíxí'ú núu̱ kó'o̱ jíín‑rí kúu, áchí‑ya̱.  
\v 21 Chi ja̱ndáa̱ máá Sé'e cha̱a ki'i̱n‑ya̱ nátu̱'un yóso tú'un‑ya̱ núu̱ tutú. Ko naka̱ ndá'ú kúu cha̱a nastúu máá Sé'e cha̱a. Va̱'a‑ga̱ nú tú ní káku cha̱a‑ún núú, áchí‑ya̱.  
\v 22 Te káyee‑dé. Te ni̱ ki'in Jesús staa̱. Te ni̱ jika̱n ta'u̱‑yá. Te ni̱ sákuáchí‑yá. Te ni̱ ja̱'a‑ya̱ núu̱‑dé. Te ni̱ ka'a̱n‑ya̱: Kee jíná'an‑ró. Ya̱'á kúu yikɨ kúñu‑ri̱, áchí‑ya̱.  
\v 23 Te ni̱ ki'in‑ya̱ ɨ́ɨn taza. Te ni̱ jika̱n ta'u̱‑yá. Te ni̱ ja̱'a‑ya̱ núu̱‑dé. Te ndɨ'ɨ‑de, ni̱ ka̱ji'i‑de.  
\v 24 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Ya̱'á kúu nɨñi̱‑rí ja̱ sá'a contrato jáá. Te ja̱ sɨkɨ́ ñáyɨvɨ kuá'a̱ te ni̱ jatɨ.  
\v 25 Te ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró: Ma̱ kó'o‑ga̱‑ri̱ nducha ndé'e̱ uva, onde̱ kɨvɨ̱ náko'o‑ri̱ ja̱ jáá iní ñuu̱ nuu̱ tá'ú Dios tiñu, áchí‑ya̱.  
\v 26 Te ni̱ ka̱jita‑ya̱ ɨ́ɨn yaa̱ ii̱. Te ni̱ kenda‑ya̱ kája'a̱n‑ya̱ ondé yuku Olivos.  
\v 27 Yúan‑na te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Ndivii‑ro, nayu̱'ú‑ro̱ já sɨkɨ́ rúu̱ akuáa vína. Chi̱ a yóso núu̱ tutú: Stují‑rí cha̱a ndíto rɨɨ̱, te máá rɨ́ɨ̱‑ún, kuicha̱‑tɨ̱, áchí.  
\v 28 Ko nuu̱ náchaku̱‑ri̱, te xna'a̱n‑ga̱ ruu̱ ki'i̱n‑ri̱ ñuu̱ Galilea vásá róó, áchí‑ya̱.  
\v 29 Ko Pedro, ni̱ ka'a̱n‑de jíín‑yá: Va̱sa ndivii‑dé ná náyu̱'ú‑de, ko náá chi̱ túu, áchí‑de.  
\v 30 Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró, chi̱ róó, akuáa vína, onde̱ ná té kana‑ga̱ lí'li uu̱ jínu, te ma̱ kuátu̱'un‑ró rúu̱ uni̱ jínu, áchí‑ya̱.  
\v 31 Ko máá‑de, téyíí ní ka'a̱n‑de: Va̱sa ná kúu̱‑ná jíín‑ní, ko ma̱ kasú‑ná yu'u‑ná ja̱ kúu níí, áchí‑de. Te suni súan ni̱ kaka'a̱n ndɨ'ɨ‑de. 
\s1 Jesús ini̱ Jardín Getsemaní 
\p  
\v 32 Te ni̱ ja̱koyo‑ya̱ ɨ́ɨn nuu̱ nání Getsemaní. Te ni̱ ka'a̱n‑ya̱ jíín cháa káskuá'a jíín‑yá: Yá'a‑ni jungo̱o‑ró nini ná kakán ta'u̱‑rí, áchí‑ya̱.  
\v 33 Te ni̱ jaka‑ya̱ Pedro jíín Jacobo jíín Juan kája'a̱n‑de jíín‑yá. Te ni̱ kejá'á‑yá yú'ú‑ya̱, te ndúkuí'a̱ ini̱‑ya̱.  
\v 34 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Xaa̱n ndúkuí'a̱ ini̱‑ri̱, chi̱ a yani kuu̱‑ri̱. Yá'a kundatu‑ró, te kundito‑ró, áchí‑ya̱.  
\v 35 Te ni̱ kanduu̱‑ya̱ ɨ́ɨn tí'lí. Te ni̱ jukuiñi̱ jítɨ́‑yá nuu̱ ñú'un. Te ni̱ jika̱n ta'u̱‑yá, te nú kuu ka̱ku‑ya̱ hora‑ún.  
\v 36 Te ni̱ ka'a̱n‑ya̱: Abba, Táa̱. Ta̱ká tiñu kúu sá'a máá‑ní. Chaxio‑ní tu̱ndó'o‑ná yá'a ná kí'i̱n. Ko nasu̱ já kuní máá‑ná, chi ja̱ kuní máá‑ní ná kúu, áchí‑ya̱.  
\v 37 Te ni̱ nchaa̱‑ya̱. Te ni̱ jini̱‑ya̱ já kákixi̱‑de. Te ni̱ ka'a̱n‑ya̱ jíín Pedro: Simón, kixí‑ro̱ náún. Á tú kánda‑ró kúndito‑ró va̱sté ɨ́ɨn hora.  
\v 38 Kundito, te kaka̱n ta'u̱‑ro̱, náva̱'a ma̱ kóto nchaa̱‑ún róó. Chi̱ kuní ndija añú‑ro̱, ko yikɨ kúñu‑ró chi̱ túu, áchí‑ya̱.  
\v 39 Te kua'a̱n tuku‑ya̱. Te ni̱ jika̱n ta'u̱‑yá. Suni ɨɨn‑ni tu̱'un ni̱ ka'a̱n‑ya̱.  
\v 40 Te ni̱ nchaa̱‑ya̱. Te ni̱ jini̱ tuku‑ya̱‑dé kákixi̱‑de, chi̱ xaa̱n káji'i̱‑de numa̱'ná. Te tú kútuní ndasa xndíó káni‑de tu̱'un nuu̱‑yá.  
\v 41 Te ni̱ nchaa̱‑ya̱ vuelta uni̱. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Kusu̱ te ndeta̱tú‑ro̱‑ná. A ni̱ kuu. Vina te ni̱ jaa̱ hora ja̱ máá Sé'e cha̱a natu̱u‑ya̱ núu̱ ndá'a cháa ká'i̱o kua̱chi.  
\v 42 Nduko̱o, ná chó'o̱. Chi ja̱ nástúu ruu̱, a ni̱ kuyani va̱i, áchí‑ya̱. 
\s1 Ja̱ ní ka̱katɨɨn‑de Jesús 
\p  
\v 43 Te súan ká'a̱n‑ya̱, te ni̱ chaa̱‑ni Judas, ɨɨn ja̱ uxí uu̱‑ún. Te ɨɨn nuu já káchindéé tá'an jíín‑de, jíín machete jíín yúnu vái koyo jíín‑de. Chi̱ sutu̱ ñá'nu jíín cháa káchaa tutu̱ jíín cháa ni̱ ka̱yii, ni̱ ka̱tájí cháa‑ún.  
\v 44 Te cha̱a ni̱ nastúu‑ya̱‑ún, ni̱ ja̱'a‑de ɨɨn tuni̱, te ni̱ ka'a̱n‑de: Cha̱a tíyú'ú‑rí‑ún, yu̱án kúu. Katɨɨn jíná'an‑ró, te kunchaka‑ró kí'i̱n‑ro̱ jíín, áchí‑de.  
\v 45 Yúan‑na te ni̱ chaa̱‑de. Te ni̱ kandita‑ni‑de nuu̱‑yá. Te ni̱ ka'a̱n‑de jíín‑yá: Maestro, Maestro, áchí‑de. Te ni̱ tiyú'ú‑de‑ya̱.  
\v 46 Te cha̱a va̱i koyo jíín Judas‑ún, ni̱ ka̱katɨɨn‑de‑ya̱.  
\v 47 Te ɨɨn cha̱a kándii̱ yúan, ni̱ stáa‑de machete‑de. Te ni̱ kachi‑de so̱'o mozo máá sutú ñá'nu‑ga̱.  
\v 48 Te ni̱ ka'a̱n Jesús jíín‑de jíná'an‑de: Nátu̱'un sɨkɨ̱ ɨ́ɨn cha̱a kuí'ná vái koyo‑ró jíín machete jíín yúnu kátɨɨn‑ró rúu̱ náún.  
\v 49 Ndɨta'a̱n kɨvɨ̱ ní ka̱ndee‑ri̱ jíín‑ró iní ve̱'e ii̱, ni̱ stá'a̱n‑ri̱ tu̱'un, te tú ní kákatɨɨn‑ró rúu̱. Ko súan kásá'a‑ró náva̱'a ná skíkuu tutu̱ ii̱, áchí‑ya̱.  
\v 50 Yúan‑na te cha̱a káskuá'a jíín‑yá, ni̱ ka̱skéndo̱o‑de‑ya̱. Te ni̱ ka̱jinu ndɨ'ɨ‑de kája'a̱n‑de.  
\v 51 Te ɨɨn su̱chí, ndikín‑i‑ya̱ kuá'a̱n‑i jíín‑yá. Te ndíi‑i ɨɨn sa'ma kuítá, chi̱ víchí lɨ́ɨ‑í. Te ni̱ ka̱katɨɨn‑de‑i.  
\v 52 Ko máá‑i, ni̱ xndóo‑i sa'ma kuítá‑ún. Te ni̱ jinu víchí lɨ́ɨ‑í kua'a̱n‑i. 
\s1 Ja̱ ní kandii̱ Jesús nuu̱ sutú ñá'nu‑ga̱ 
\p  
\v 53 Te ni̱ ka̱kinchaka‑de Jesús nuu̱ máá sutú ñá'nu‑ga̱. Te ta̱ká sutu̱ ñá'nu jíín cháa ni̱ ka̱yii jíín cháa káchaa tutu̱, ni̱ ka̱ndutútú‑de.  
\v 54 Te Pedro, jíká ndikín‑de‑ya̱ ondé ini̱ yuxé'é máá sutú ñá'nu‑ga̱‑ún. Te ni̱ jungo̱o‑de jíín cháa kájatíñu‑ún, ndúvixi̱‑de ñu'u̱n.  
\v 55 Te ta̱ká sutu̱ ñá'nu jíín táká cha̱a junta, ni̱ ka̱ndúkú‑de ɨɨn tu̱'un sɨkɨ̱ Jesús, ja̱ ká'ni‑dé‑ya̱ kákuni̱‑de. Ko tú ní káni'i̱n‑dé.  
\v 56 Chi̱ kua'a̱‑dé, ni̱ ka̱sátú'ún‑de sɨkɨ̱‑yá. Ko tu̱'un ni̱ kaka'a̱n‑de‑ún, tú ní kétá'an.  
\v 57 Yúan‑na te ni̱ ka̱ndukuiñi̱ sava‑de, ni̱ ka̱sátú'ún‑de sɨkɨ̱‑yá:  
\v 58 Máá‑ná, ni̱ kajini̱‑ná ká'a̱n‑de: Ruu̱, stúncháa̱‑ri̱ ve'e ii̱ yá'a ja̱ ní ka̱sáva̱'a nda'a. Te nuu̱ uní kɨvɨ̱ te ndukani‑ri̱ ɨnga̱ ja̱ tú nɨ́nɨ jíín ndá'a, áchí‑de, áchí jíná'an.  
\v 59 Ko ni súan tú ní kétá'an tu̱'un ni̱ kaka'a̱n.  
\v 60 Yúan‑na te máá sutú ñá'nu‑ga‑ún, ni̱ ndukuiñi̱‑de kándii̱‑de ma̱'ñú. Te ni̱ jika̱ tu̱'ún‑de Jesús: Tú ka'a̱n kutɨ‑ro náún. Ndasa káka'a̱n cha̱a yá'a sɨkɨ̱‑ro̱, áchí‑de jíín‑yá.  
\v 61 Te máá‑yá, tú ní ká'a̱n kutɨ‑yá. Te máá sutú ñá'nu‑ga̱‑ún, ni̱ jika̱ tu̱'ún tuku de‑ya̱: Máá‑ró kúu Cristo, Se̱'e máá I'a̱ ii̱ náún, áchí‑de jíín‑yá.  
\v 62 Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Máá‑rí kúu. Te kuni̱‑ro̱ máá Sé'e cha̱a kunchaa̱‑ya̱ íchi ndává'a Dios nuu̱ íó fuerza‑ya̱. Te ndii‑ya̱ íchi ándɨ́vɨ́ jíín vikó nu̱'ún, áchí‑ya̱.  
\v 63 Yúan‑na te máá sutú ñá'nu‑ga̱‑ún, ni̱ ndátá‑ni‑de sa'ma‑dé. Te ni̱ ka'a̱n‑de: Na̱ún nɨ́nɨ kúni so̱'o‑yó ká'a̱n ɨnga̱‑de núsáá.  
\v 64 Ni̱ kajini̱‑ro̱ ná ndɨva̱'a ká'a̱n‑de. Ndasa kájani ini̱‑ro̱. Achí sutu̱ ñá'nu‑ga̱‑ún. Te ta̱ká cha̱a‑ún, ni̱ ka̱naku̱xndíi‑de‑ya̱ ná kúu̱‑ya̱.  
\v 65 Te sava‑de, ni̱ katɨvɨ̱ sɨ̱'vɨ́‑de nuu̱‑yá. Te ni̱ kajasu̱‑de nuu̱‑yá. Te ni̱ kaja̱'a‑de ji̱kí núu̱‑yá. Te káka'a̱n‑de jíín‑yá: Kani tu̱'un, áchí‑de. Te cha̱a kájatíñu‑ún, ni̱ ka̱stují‑dé‑ya̱ jíín jíkí. 
\s1 Ja̱ tú ní játu̱'un Pedro 
\p  
\v 66 Te ichi chíi yuxé'é yúan kándii̱ Pedro. Te ɨɨn ña'an játíñu nuu̱ máá sutú ñá'nu‑ga̱‑ún, ni̱ chaa̱‑ña.  
\v 67 Te ni̱ jini̱‑ña núu̱ Pedro kándii̱‑de ndúvixi̱‑de. Te ni̱ ndakoto‑ña núu̱‑dé. Te ni̱ ka'a̱n‑ña: Te róó, jíín Jesús ñuu̱ Nazaret jíka‑ró vii, áchí‑ña.  
\v 68 Ko máá‑de, tú ní játu̱'un‑de. Tú jiní‑ná, ni tú júku̱'un ini̱‑ná na̱ún ká'a̱n‑ní, áchí‑de jíín‑ña. Te ni̱ kenda‑de yuxé'é yatá vé'e‑ún. Te ni̱ kana‑ni lí'li.  
\v 69 Te ña'an játíñu‑ún, ni̱ jini̱‑ña núu̱‑dé ɨnga̱ jínu. Te ni̱ ka'a̱n‑ña jíín cháa ká'i̱in yúan. Cha̱a yá'a suni tá'an‑de, áchí‑ña.  
\v 70 Ko máá‑de, tú ní játu̱'un tuku‑de. Te ni̱ kunúu tuku. Te cha̱a ká'i̱in‑ún, ni̱ kaka'a̱n tuku‑de jíín Pedro: Ja̱ndáa̱ ja̱ súni tá'an‑de kúu‑ró, chi cha̱a galileo kúu‑ró. Te tu̱'un ká'a̱n‑ro̱ súan kuní koo, áchí‑de.  
\v 71 Ko máá‑de, ni̱'in ni̱ ka'a̱n ndɨva̱'a‑de: Tú jiní‑ri̱ cha̱a yá'a ja̱ káka'a̱n‑ro̱ tú'un‑de, áchí‑de.  
\v 72 Yúan‑na te ni̱ kana‑ni lí'li vuelta uu̱. Te Pedro, ni̱ nuku̱'un ini̱‑de ta̱ká tu̱'un ni̱ ka'a̱n Jesús jíín‑de núú: Onde̱ ná té kana‑ga̱ lí'li uu̱ jínu, te ma̱ kuátu̱'un‑ró rúu̱ uni̱ jínu, áchí‑ya̱ sáá. Te ni̱ nakani ini̱‑de sɨkɨ̱ tú'un‑ún. Te ni̱ nde'e̱‑de. 
\c 15  
\s1 Ja̱ kuá'a̱n Jesús nuu̱ Pilato 
\p  
\v 1 Te ja̱ñá'a̱n‑ún, te ta̱ká sutu̱ ñá'nu, jíín cháa ni̱ ka̱yii, jíín cháa káchaa tutu̱, jíín ndívii cháa junta, ni̱ ka̱skétá'an‑ni‑de tu̱'un. Te ni̱ kaju'ni̱‑de Jesús kua'a̱n‑de jíín‑yá. Te ni̱ kaja̱'a‑de‑ya̱ núu̱ Pilato.  
\v 2 Te Pilato, ni̱ jika̱ tu̱'ún‑de‑ya̱: Máá‑ró kúu Rey cha̱a judío náún, áchí‑de. Te ni̱ ka'a̱n‑ya̱: Ká'a̱n ndaa̱‑ro̱, áchí‑ya̱ jíín‑de.  
\v 3 Te sutu̱ ñá'nu‑ún, ni̱'in ni̱ kajika̱n‑de kua̱chi sɨkɨ̱‑yá.  
\v 4 Te Pilato, ni̱ jika̱ tu̱'ún tuku‑de‑ya̱: Tú ka'a̱n kutɨ‑ro náún. Nde̱'é, ná kua'a̱ kuáchi kájika̱n‑de sɨkɨ̱‑ro̱, áchí‑de jíín‑yá.  
\v 5 Ko Jesús, tuká ní ká'a̱n kutɨ‑yá. Te ni̱ naa iní Pilato ndé'é‑de nuu̱‑yá.  
\v 6 Te íó costumbre Pilato ja̱ kɨvɨ́ víko‑ún sía̱‑de ɨɨn cha̱a yí'i veka̱a, na̱ni cha̱a kákuu ini̱ ña̱yɨvɨ.  
\v 7 Te ni̱ i̱o ɨɨn cha̱a nání‑de Barrabás, kándee‑de veka̱a jíín tá'an‑de ja̱ ní ka̱ndonda‑de, ni̱ ka̱ja'ni‑dé ndɨ̱yi.  
\v 8 Te ni̱ cha̱koyo kua'a̱ ñáyɨvɨ. Te ni̱ kaka'a̱n‑i jíín Pilato ná sá'a‑de nátu̱'un íó costumbre‑de.  
\v 9 Te ni̱ ka'a̱n Pilato jíín‑i: Kákuni̱‑ro̱ já sía̱‑ri̱ Rey cha̱a judío náún, áchí‑de.  
\v 10 Chi̱ a ni̱ jini̱‑de ja̱ ní ka̱kukuásún iní sutu̱ ñá'nu‑ún, te yu̱án ní kaja̱'a‑ún‑yá nuu̱‑dé.  
\v 11 Chi̱ sutu̱ ñá'nu‑ún, ni̱ ka̱ská'a̱n‑de ña̱yɨvɨ kuá'a̱‑ún ja̱ Pilato va̱'a‑ga̱ ná sía̱‑de Barrabás ki'i̱n.  
\v 12 Te ni̱ ka'a̱n tuku Pilato: Ndasa kákuni̱‑ro̱ já sá'a‑ri̱ jíín cháa káskúnání‑ró Rey judío núsáá, áchí‑de jíín‑i.  
\v 13 Te máá‑i, ni̱ ka̱kana jaa tuku‑i: Kata kaa‑ní cha̱a jia̱n jiká cruz, áchí‑i.  
\v 14 Ko Pilato, ni̱ ka'a̱n‑de jíín‑i: Na̱ún kua̱chi ni̱ sá'a‑de, áchí‑de. Te máá‑i, ví'í‑gá ni̱ ka̱kana jaa‑i: Kata kaa‑ní‑de ná kúu̱‑de, áchí‑i.  
\v 15 Te Pilato, kuní‑de ja̱ ná kúsɨɨ̱ iní ña̱yɨvɨ‑ún. Te ni̱ sía̱‑de Barrabás kua'a̱n. Yúan‑na te ni̱ xndó'o‑de‑ya̱. Te ni̱ ja̱'a‑de‑ya̱ kuíta kaa‑ya̱ já ná kúu̱‑ya̱. 
\s1 Ja̱ ní ka̱sákátá soldado nuu̱‑yá 
\p  
\v 16 Yúan‑na te soldado, ni̱ ka̱ki'in‑de‑ya̱ kuá'a̱n‑de jíín‑yá ini̱ ve̱'e palacio. Te ni̱ ka̱kana xini̱ tá'an‑de ni̱ ka̱ndutútú‑de.  
\v 17 Te ni̱ ka̱chu'un‑de‑ya̱ ɨ́ɨn sa'ma kuá'á tíndí'í. Te ni̱ ka̱tɨɨn‑de ɨɨn corona iñu. Te ni̱ ka̱chu'un‑de xini̱‑yá.  
\v 18 Yúan‑na te ni̱ kaka'a̱n‑de jíín‑yá: Rey judío, ta̱á ndii, áchí‑de.  
\v 19 Te ni̱ ka̱kuun‑de yunu xiní‑yá. Te ni̱ katɨvɨ̱ sɨ̱'vɨ́‑de nuu̱‑yá. Te ni̱ ka̱jukuiñi̱ jítɨ́‑de nuu̱‑yá, te ni̱ ka̱chiñú'ún‑de‑ya̱.  
\v 20 Te nuu̱ ní ndɨ'ɨ ni̱ ka̱sákátá‑de nuu̱‑yá, te ni̱ ka̱tava‑dé sa'ma kuá'á tíndí'í ñú'un‑ya̱‑ún. Te ni̱ ka̱nachu'un‑de‑ya̱ sá'ma máá‑yá, te ni̱ ka̱keni'in‑de‑ya̱ káta kaa‑de‑ya̱.  
\v 21 Te ɨɨn cha̱a nání‑de Simón ñuu̱ Cirene (táa̱ Alejandro jíín Rufo kúu‑de), ni̱ ja̱'a‑de va̱i‑de ichi rancho. Te ni̱ ka̱tetíñu‑de cha̱a‑ún ki'i̱n‑de jíín‑de kundiso‑de cruz‑ya̱.  
\v 22 Te kája'a̱n‑de jíín‑yá onde̱ nuu̱ nání Gólgota, ja̱ kuní ka'a̱n: yikɨ xiní.  
\v 23 Te ni̱ ka̱sáká núu‑de vino jíín súsia ua̱. Te ni̱ kaja̱'a‑de nuu̱‑yá ko'o‑ya̱. Ko máá‑yá, tú ní játá'ú‑yá ko'o‑ya̱. 
\s1 Ja̱ ní ka̱jata kaa‑de‑ya̱ 
\p  
\v 24 Te ni̱ ka̱jata kaa‑de‑ya̱ jiká cruz. Te ni̱ ka̱saka‑dé sa'ma‑yá nuu̱ tá'an‑de. Te ni̱ ka̱sá'a‑de apuesto sɨkɨ̱, ndasa ni'i̱n, ɨ́ɨn ɨɨn‑de.  
\v 25 Te ka̱'ɨɨ̱n ni̱ ka̱jata kaa‑de‑ya̱.  
\v 26 Te nuu̱ tutú kua̱chi sɨkɨ̱‑yá yóso: Ya̱'á kúu Rey cha̱a judío, áchí.  
\v 27 Te ni̱ ka̱jata kaa‑de uu̱ ñakui̱'ná jíín‑yá, ɨɨn ichi ndává'a‑ya̱, te ɨnga̱ ichi ndávésé‑yá.  
\v 28 Te ni̱ skikuu tu̱'un ká'a̱n tutu̱ ii̱: Onde̱ jíín cháa kánda̱ñáá ní ka̱skétá'an‑de‑ya̱, áchí.  
\v 29 Te ña̱yɨvɨ kája̱'a yúan, ni̱ ka̱skuíkó‑i xini̱‑í. Te ni̱ kaka'a̱n ndɨva̱'a‑i jíín‑yá: Ja̱n jaa̱n. Róó, ká'a̱n‑ro̱ já stúncháa̱‑ro̱ vé'e ii̱ Dios, te nuu̱ uní kɨvɨ̱ te ndukani‑ró núú.  
\v 30 Vina te nama‑ró máá‑ró, te nuu‑ró jiká cruz núsáá vii, áchí‑i.  
\v 31 Te suni súan ni̱ ka̱sákátá sutú ñá'nu‑ún nuu̱‑yá. Te kándatu̱'ún jíín cháa káchaa tutu̱: Sava ña̱yɨvɨ á ni̱ kuu ni̱ nama‑de, ko ma̱ kúu nama‑de máá‑de.  
\v 32 Cristo, Rey cha̱a Israel, ná núu‑de jika̱ cruz vina, te ná kuní‑yo̱, te ná kándíja‑yó, áchí. Te cha̱a kándi̱ta kaa jíín‑yá‑ún, suni súan ni̱ kaka'a̱n ndɨva̱'a‑de jíín‑yá.  
\v 33 Te nuu̱ ní kuu ka̱xiuu̱, te ni̱ kuxkɨ́'vɨ̱ nɨ́ɨ́ núu̱ ñú'un onde̱ ka̱'uni̱.  
\v 34 Te nuu̱ ní kuu ka̱'uni̱, te ni̱ ka'a̱n jaa Jesús: Eloi, Eloi, lama sabactani, achí‑ya̱. Ja̱ kuní ka'a̱n: Dios máá‑ná, Dios máá‑ná, naja̱ ní xndóo‑ní náá.  
\v 35 Te sava cha̱a ká'i̱in yúan, ni̱ ka̱jini so̱'o‑de. Te ni̱ kaka'a̱n‑de: Nde̱'é, chi̱ kána‑de xini̱ Elías, áchí‑de.  
\v 36 Te jínu ɨɨn cha̱a ni̱ jaa̱‑de, te ni̱ chíndájí‑de kachi̱ núu̱ vinagre. Te ni̱ chaa‑de xini̱ ɨ́ɨn yunu. Te ni̱ ja̱'a‑de nuu̱‑yá ja̱ kó'o‑ya̱. Te ni̱ ka'a̱n‑de: Ná ndé'ó nú chaa̱ Elías xnúu‑de cha̱a, áchí‑de.  
\v 37 Ko máá Jesús, ni̱ ka'a̱n jaa‑ya̱. Te ni̱ ji'i̱‑ya̱.  
\v 38 Yúan‑na te sa'ma ndíta kaa ini̱ ve̱'e ii̱, ni̱ te'nde̱ uu̱ onde̱ nuu̱ xiní te onde̱ nuu̱ já'a̱.  
\v 39 Te ɨɨn cha̱a capitán kándii̱‑de nuu̱‑yá. Te ni̱ jini̱‑de ja̱ ní kana jaa‑ya̱ ní ji'i̱‑ya̱. Te ni̱ ka'a̱n‑de: Ja̱ndáa̱ ja̱ Sé'e Dios kúu cha̱a yá'a núú, áchí‑de.  
\v 40 Te suni ká'i̱in sava ñasɨ́'ɨ́ kánde̱'é jíká‑ña. Te yúan ká'i̱in María ñuu̱ Magdala, jíín Salomé, jíín María náa̱ José jíín Jacobo súchí.  
\v 41 Chi̱ onde̱ ná kándee‑ya̱ ñúu̱ Galilea, te ña'an‑ún, ni̱ kandiki̱n‑ña‑yá. Te ni̱ ka̱jatíñu‑ña núu̱‑yá. Te suni íó kua'a̱‑gá‑ña, ni̱ kaja'a̱n‑ña jíín‑yá ñuu̱ Jerusalén.  
\v 42 Te ni̱ ini kɨvɨ̱‑ún. Te kásátu̱'a‑de, chi̱ yuchaa̱n kúu kɨvɨ̱ ndéta̱tú.  
\v 43 Te José ñuu̱ Arimatea, cha̱a kúñá'nu nuu̱ junta kúu‑de, te suni ñúkuu ini̱‑de ja̱ kúu ñuu̱ nuu̱ tá'ú Dios tiñu, ni̱ chaa̱‑de. Te ni̱ chundéé iní‑de ni̱ kɨ̱vɨ‑de nuu̱ Pilato. Te ni̱ jika̱n‑de yikɨ kúñu Jesús.  
\v 44 Te Pilato, tú kándíja‑de ja̱ á ni̱ ji'i̱‑ya̱. Te ni̱ kana‑de xini̱ capitán. Te ni̱ jika̱ tu̱'ún‑de cha̱a‑ún nú a ni̱ ji'i̱‑ya̱.  
\v 45 Yúan‑na te ni̱ kundaa̱ ini̱‑de ja̱ ní ka'a̱n capitán‑ún jíín‑de. Te ni̱ ja̱'a‑de yikɨ kúñu‑ya̱ núu̱ José.  
\v 46 Te José, ni̱ jaan‑de ɨɨn sa'ma kuítá. Te ni̱ xnúu‑de‑ya̱. Te ni̱ chisukun‑dé‑ya̱ sá'ma‑ún. Te ni̱ chindee‑de‑ya̱ iní ve̱'e añú ja̱ ní jacha chi̱i ɨɨn kava. Te ni̱ stúu‑dé ɨɨn yuu̱ ní jasu̱‑de yuvé'e añú‑ún.  
\v 47 Te María ñuu̱ Magdala, jíín María náa̱ José, ni̱ kajini̱‑ña núu̱ ní jaki̱n‑de‑ya̱. 
\c 16  
\s1 Ja̱ ní nachaku̱ Jesús 
\p  
\v 1 Te ni̱ ini kɨvɨ̱ ndéta̱tú‑ún. Te María ñuu̱ Magdala, jíín María náa̱ Jacobo, jíín Salomé, ni̱ ka̱jaan‑ña jí'o vixi̱ kichi̱'i‑ña‑yá.  
\v 2 Te ja̱ñá'a̱n kɨvɨ̱ ɨ́ɨn semana, ja̱ á ni̱ kana ndika̱ndii, ni̱ ja̱koyo‑ña núu̱ vé'e añú.  
\v 3 Te káka'a̱n máá‑ña: Ndénu̱ ní'i̱n‑yo̱ ɨ́ɨn cha̱a chaxio yuu̱ yúvé'e añú, áchí‑ña.  
\v 4 Te ni̱ ka̱ndakoto‑ña. Te ni̱ kajini̱‑ña já á ni̱ kuxio yuu̱‑ún kua'a̱n. Te ká'nu xaa̱n.  
\v 5 Te ni̱ kɨ̱vɨ koyo‑ña iní ve̱'e añú‑ún. Te ni̱ kajini̱‑ña ɨ́ɨn cha̱a súchí, ñú'un káni‑dé ɨɨn sa'ma kuíjín, kánchaa̱‑de ichi ndává'a. Te ni̱ kayu̱'ú‑ña.  
\v 6 Te cha̱a‑ún, ni̱ ka'a̱n‑de jíín‑ña: Ma̱ yú'ú‑ro̱. Kánandúkú‑ró Jesús ñuu̱ Nazaret I'a̱ ni̱ ji'i̱ jika̱ cruz. Túu‑ya̱ yá'a, chi̱ a ni̱ nachaku̱‑ya̱. Yá'a nde̱'é‑ró nú ní kajaki̱n‑de‑ya̱.  
\v 7 Kuángoyo núsáá, te kachi̱‑ro̱ núu̱ cháa káskuá'a jíín‑yá, jíín núu̱ Pedro, ja̱ xná'a̱n‑ga̱‑ya̱ kí'i̱n ñuu̱ Galilea vásá kí'i̱n‑ro̱. Yúan kuni̱‑ro̱ núu̱‑yá, nátu̱'un ni̱ ka'a̱n‑ya̱ jíín‑ró sáá, áchí‑de jíín‑ña.  
\v 8 Te máá‑ña, kájinu‑ña ní ndenda‑ña vé'e añú. Chi̱ káyu̱'ú‑ña, te kákɨsɨ‑i‑ña. Te tú ni ɨɨn nuu̱ ní kákachi̱‑ña, chi̱ káyu̱'ú‑ña.  
\v 9 Te Jesús, a ni̱ nachaku̱‑ya̱ máá jáñá'a̱n kɨvɨ̱ ɨ́ɨn semana. Te xnáñúú‑gá ni̱ ndenda ndiji̱n‑ya̱ núu̱ María ñuu̱ Magdala. Ña'an‑ún, ni̱ yi̱'i usia̱ tachi̱ kíni‑ña. Te ni̱ kiñi'in‑ya̱ kuá'a̱n.  
\v 10 Te ni̱ kee‑ña kuá'a̱n‑ña. Te ni̱ kachi̱‑ña núu̱ cháa ni̱ ka̱jika jíín‑yá, chi̱ kándukuí'a̱ ini̱‑de te kánde'e̱‑de.  
\v 11 Te súan ni̱ ka̱jini tu̱'un‑de ja̱ chakú‑ya̱ ní jini̱ ña'an‑ún nuu̱‑yá. Ko tú ní kákandíja‑de tu̱'un ká'a̱n‑ña.  
\v 12 Te ni̱ kuee̱‑ga̱. Te ɨnga̱ modo ni̱ nastá'a̱n ndiji̱n‑ya̱ máá‑yá nuu̱ úu̱‑de kájika‑de kua'a̱n‑de ichi rancho‑de.  
\v 13 Te cha̱a‑ún, ni̱ kaja'a̱n‑de. Te ni̱ kastu̱'ún‑de nuu̱ sáva‑ga̱. Ko ni tú ní kákandíja ja̱ káka'a̱n‑de. 
\s1 Ja̱ kuáno'on‑yá andɨ́vɨ́ 
\p  
\v 14 Yúan‑na te vásá ní nastá'a̱n ndiji̱n‑ya̱ máá‑yá nuu̱ máá uxí ɨɨn‑de, káxiu̱kú‑de káyee‑dé staa̱. Te ni̱ kana jíín‑yá nuu̱‑dé, chi̱ ndava iní añú‑de, te tú ní kákandíja‑de tu̱'un ni̱ kaka'a̱n ja̱ ní kajini̱ nuu̱‑yá ja̱ ní nachaku̱‑ya̱.  
\v 15 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Kuá'án jíná'an‑ró nɨ́ɨ́ ñúyɨ́vɨ, te kani‑ró tú'un va̱'a‑ri̱ nuu̱ táká ña̱yɨvɨ.  
\v 16 Cha̱a kándíja te kuanducha‑dé, ka̱ku‑de. Ko cha̱a tú kándíja, ta'nu̱ ndatu̱‑de.  
\v 17 Te cha̱a kákandíja, sá'a‑de tuni̱ yá'a: Jíín sɨ́'vɨ́‑rí kiñi'in‑de tachi̱ kíni ki̱ngoyo. Te ka'a̱n‑de ɨnga̱ yu'u jáá.  
\v 18 Kuanchaa̱‑de koo̱, te nú ni̱ ji'i‑de veneno, te ma̱ sá'a daño jíín‑de. Te xndée‑de nda'a‑dé sɨkɨ̱ ñáyɨvɨ kú'u̱, te nduva̱'a‑i, áchí‑ya̱ jíín‑de.  
\v 19 Yúan‑na te nuu̱ ní ndɨ'ɨ ni̱ ka'a̱n máá Jíto'o̱‑yo̱ jíín‑de jíná'an‑de, te ni̱ ndaa‑ya̱ kuáno'on‑yá andɨ́vɨ́. Te ni̱ nungo̱o‑ya̱ íchi ndává'a Dios.  
\v 20 Te máá‑de, kája'a̱n‑de. Te ni̱ ka̱jani‑de tu̱'un‑ya̱ táká lado. Te máá Jito'o̱‑yo̱, ni̱ chindéé ní chituu‑ya̱‑dé. Te jíín tuní ni̱ ka̱sá'a‑de‑ún ni̱ stá'a̱n‑ya̱ já íó ndaa̱ ta̱ká tu̱'un yá'a. Amén.