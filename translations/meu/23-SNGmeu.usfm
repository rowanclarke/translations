\id SNG .01, Song of Songs 1, Motu, PNG, RTWP 11/92
\h SOLOMON ENA ANE
\toc1 SOLOMON ENA ANE
\toc2 SOLOMON ENA ANE
\mt1 SOLOMON ENA ANE
\c 1
\p 
\v 1 Ane Herea-daena, Solomon ena.
\b
\q1 
\v 2 Udumu haherahuna amo boma harahugu,
\q2 badina be emu uraheni ese vine ranuna e hereaiamu.
\q1 
\v 3 Emu hedahu muramuradia bonadia na nanamo heherea;
\q2 oi ladamu na dehoro e seiamu na heto.
\q1 Una dainai ulato ese e ura henimumu.
\b
\q1 
\v 4 Murimu ai a verigu kau! Aitala haraḡa;
\q2 hanua pavapavana ese ena ruma ai vada e hakaugu vareai.
\q1 Baia heatolaimu, baia moalelaimu;
\q2 emu uraheni baia imodaia bada, vine ranuna baia imodaia maraḡi.
\q1 Mai badina idia ese e ura henimumu.
\b
\q1 
\v 5 Ierusalem kekenimui e,
\q2 kopigu na korema-korema, to ita-itagu na namo,
\q1 Kedara dabua rumadia na heheto,
\q2 Solomon ena seseahu na heheto.
\q1 
\v 6 Kopigu na korema-korema dainai basio raraigu;
\q2 badina be dina ese vada e raragu.
\q1 Taihugu ese e badu heniguva,
\q2 vine imeadia ireḡudia ai e halaogu;
\q1 a lauegu imea na asina reḡua.
\b
\q1 
\v 7 Egu lalokau taumu e, ba hadibagu,
\q2 emu mamoe na edeseni ai o ubudiamu?
\q1 Dina tubua ai edeseni ai o hahekurediamu?
\q2 Bamomu edia seri badidiai baina loa eva-eva anina be dahaka?
\p *****
\b
\q1 
\v 8 Hane namo e, bema asi dibamu,
\q2 mamoe vatagadia ba ḡavadia;
\q1 emu nani natudia na mamoe ireḡudia taudia
\q2 edia kalaga badidiai ba ubudia.
\p *****
\b
\q1 
\v 9 Egu lalokau e, Farao ena kariota hosina ta ida
\q2 aina haheḡereḡeremu.
\q1 
\v 10 Vahamu mai heraheradia ita-itadia na nanamo heherea,
\q2 bona aiomu mai agevana danu.
\q1 
\v 11 Ihaheralaimu ḡaudia baia kara,
\q2 \it gold\it* heraheradia mai \it silver\it*-dia.
\p *****
\b
\q1 
\v 12 Hanua pavapavana na e ege dihova negana ai,
\q2 egu muramura bonana namona e daeva.
\q1 
\v 13 Egu lalokau na muro\f + \fr 1:13 \ft “Muro” na Heberu taudia edia muramura mai bonana ta.\f* modana ta,
\q2 ratagu padadiai e miamu.
\q1 
\v 14 Egu lalokau na kofere\f + \fr 1:14 \ft “Kofere” na Heberu taudia edia muramura avana ta.\f* buredia idabubuna ta,
\q2 En-gedi vine-imeadia ai.
\p *****
\b
\q1 
\v 15 Egu lalokau e, oi na hane namo,
\q2 momokani, oi na hane namo.
\q1 Matamu na pune.
\p *****
\b
\q1 
\v 16 Egu lalokau e, oi na raho namo taumu;
\q2 momokani, oi na mai hairaimu.
\q1 Eda mahuta patana na gadoka-gadoka,
\q2 
\v 17 eda ruma audia na sida,
\q2 eda ruma toidaedia na beroso\f + \fr 1:17 \ft “Beroso” na au ta ladana, Heberu gado ai.\f* audia.
\c 2
\q1 
\v 1 Lau na Saron vahuvahuna,
\q2 koura ai e varamu sosanana.\f + \fr 2:1 \ft “Sosana” na Heberu taudia edia herahera avana ta.\f*
\p *****
\b
\q1 
\v 2 Ulato bogaragidiai egu lalokau na
\q2 sosana burena siniura bogaragidiai na heto.
\p *****
\b
\q1 
\v 3 Uhau bogaragidiai egu lalokau na
\q2 apolo auna uda audia bogaragidiai na heto.
\q1 Ia ikerukeruna ai na helai mai moale-badagu ida;
\q2 huahuana na mai gaihona udugu ai.
\q1 
\v 4 Aria rumana ai e hakaugu lao;
\q1 ena pepe lau daegu ai na lalokau.
\b
\q1 
\v 5 Vine huahuadia kakorodia amo ba ubugu,
\q2 apolo huahuadia amo ba hagoadagu,
\q2 badina be uraheni ese e hamasegumu.
\b
\q1 
\v 6 Imana laurina amo bema hahekwinagu,
\q2 imana idibana amo bema rosigu.
\b
\q1 
\v 7 Ierusalem kekenimui e, na haḡanimuimu,
\q2 uda nanidia bona dia daidiai,
\q1 uraheni na basio haoa
\q2 ela bona sibona baine noga.
\b
\q1 
\v 8 Egu lalokau tauna gadona!
\q2 A itaia, ia na e maimu;
\q1 ororo badadia ai e roho daemu,
\q2 ororo maraḡidia ai e roho laomu.
\q1 
\v 9 Egu lalokau tauna na uda nanina
\q2 eiava dia natuna na heto.
\b
\q1 A itaia, emai ruma murimurinai e ginimu,
\q2 gaba-mauruna amo e ha-igomu,
\q2 makamaka amo e igo vareaimu.
\q1 
\v 10 Egu lalokau tauna ese e hereva henigumu,
\q2 ini e gwau tomamu:
\b
\q1 Egu lalokau e, a tore isi!
\q2 Hane namo e, aitala!
\q1 
\v 11 Keru negana vada e ore;
\q2 medu vada e doko.
\q1 
\v 12 Tano heraheradia vada e tubu;
\q2 ane-abi negana vada e kau;
\q2 bona pune na e taimu eda tano ai.
\q1 
\v 13 Suke huahuadia e dobimu,
\q2 vine buredia e papamu,
\q2 bonadia na e daemu.
\q1 Egu lalokau e, a tore isi!
\q2 Hane namo e, aitala!
\b
\q1 
\v 14 Egu pune e, oi na nadi matudia ai;
\q2 oi na haga kohuadia ai.
\q1 Vairamu bama itaia,
\q2 bona gadomu bama kamonai;
\q1 badina be gadomu na namo,
\q1 bona vairamu na mai hairaina.
\p *****
\b
\q1 
\v 15 Aoma, mariboi baita idoadia,
\q2 ena be mamaragi to
\q1 idia ese vine imeadia e hadikamu,
\q2 badina na eda vine buredia e papamu.
\p *****
\b
\q1 
\v 16 Ia na egu lalokau, lau be ena lalokau;
\q2 ia ese ena mamoe e ubudiamu, sosana bogaragidiai.
\q1 
\v 17 Egu lalokau taumu e, a kerehai,
\q2 uda nanina eiava dia natuna
\q2 ororo gabaedia ai na heto;
\q1 ela bona dina baine keruma,
\q2 bona hanua baine boi.
\c 3
\q1 
\v 1 Hanuaboi ai, egu mahuta patana ai,
\q2 egu lalokau tauna na tahua;
\q1 na tahua, to asina davaria,
\q2 na boiria, to ia na se haere.
\b
\q1 
\v 2 Aina tore isi, hanua ai baina loa eva-eva,
\q2 ariara ai bona noho-bou gabudia ai
\q1 egu lalokau tauna baina tahua.
\q2 Na tahua, to asina davaria.
\b
\q1 
\v 3 Gima taudia ese e davarigu,
\q2 hanua ai e loa eva-evava ai;
\q1 na tai henidia, nato
\q2 “Egu lalokau tauna so itaia a?”
\b
\q1 
\v 4 Na rakatanidia, bena asi vanahana
\q2 egu lalokau tauna na davaria.
\q1 Na dogoa tao, asina kahua nege,
\q2 ema bona sinagu ena ruma ai,
\q1 e havaragu hahinena ena daiutu ai,
\q2 na hakaua dae.
\b
\q1 
\v 5 Ierusalem kekenimui e, na haḡanimuimu,
\q2 uda nanidia bona dia daidiai,
\q1 uraheni na basio haoa
\q2 ela bona sibona baine noga.
\p *****
\b
\q1 
\v 6 Una na dahaka, tano ḡaḡaena amo e maimu,
\q2 kwalahu dubuna na heto,
\q1 mai bonana, muro bona lebona\f + \fr 3:6 \ft “Muro” bona “lebona” na Heberu taudia edia muramura mai bonadia ladadia.\f*
\q2 bona hoihoi tauna ena muramura mai bonadia ibouboudiai?
\b
\q1 
\v 7 A itaia, Solomon ena ivitoto,
\q2 goada taudia tauratoi-ahui ese e ginia heḡeḡemu!
\q1 
\v 8 Idia na Israel ena goada taudia,
\q2 iboudiai na mai daredia gabadia ai.
\q1 Tuari na mai dibadia;
\q2 ta ta edia dare na koekoedia ai;
\q2 hanuaboi ena hahegari ḡaudia ilao-ahudia.
\b
\q1 
\v 9 King Solomon ena laolao kalagana na
\q2 Lebanon audia amo e karaia.
\q1 
\v 10 Aena na \it silver\it*, tabekau kahana na \it gold\it*;
\q2 helai ḡauna iḡovana na dabua kakakakana.
\q1 Laloma kahana na e haheraia ḡoevaḡoeva,
\q2 Ierusalem kekenidia ese.
\b
\q1 
\v 11 Siona kekenimui e, a raka lasi;
\q2 King Solomon ba itaia.
\q1 Ena havava ḡauna be kwarana ai;
\q2 ena headava dinana ai,
\q1 lalona e moaleva dinana ai,
\q2 sinana ese ia kwarana e havavalaia.
\p *****
\b
\c 4
\q1 
\v 1 Egu lalokau e, oi na hane namo;
\q2 momokani, oi na hane namo.
\q1 Matamu na pune,
\q2 vairamu iḡovalaina dabuana murinai.
\q1 Huimu na nani serina,
\q2 Gilead ororona amo e hekei dihomu na heto.
\q1 
\v 2 Isemu na mamoe serina huidia vada e utu
\q2 bena digu gabuna amo e daemu na heto;
\q1 iboudiai na mai natudia vara-hekapa,
\q2 ta se raka edeamu.
\q1 
\v 3 Udumu bibinadia na varo kakakakadia na heheto;
\q2 udumu na mai hairaina.
\q1 Vahamu ruaosi na rimono\f + \fr 4:3 \ft “Rimono” na Heberu taudia edia au huahua ta.\f* huahuana e ivaia parara na heto,
\q2 vairamu iḡovalaina dabuana murinai.
\b
\q1 
\v 4 Aiomu na David ena kohoro na heto,
\q2 ena tuari ḡaudia e haboumu gabuna;
\q1 unuseni ai kesi daha-ta hetau dadae,
\q2 iboudiai na tuari taudia edia kesi.
\b
\q1 
\v 5 Ratamu ruaosi na uda nanidia natudia rua na heheto,
\q2 uda nanina hahinena natuna vara-hekapa,
\q2 sosana bogaragidiai e anianimu ḡaudia.
\b
\q1 
\v 6 Lau na muro ororona bainala,
\q2 lebona\f + \fr 4:6 \ft “Muro” bona “lebona” na Heberu taudia edia muramura mai bonadia ladadia.\f* ororona baina lao henia,
\q1 ela bona dina baine keruma,
\q2 bona hanua baine boi.
\b
\q1 
\v 7 Egu lalokau e, oi na hane namo;
\q2 oi na asi bebeka-bebekamu.
\b
\q1 
\v 8 Adavagu e, Lebanon amo baita raka hebou,
\q2 Lebanon amo baita raka hebou.
\q1 Amana bona Seniri bona Heremon ororodia doridia,
\q2 bona leona edia kohua bona taiga edia ororo,
\q2 ba rakatanidia.
\b
\q1 
\v 9 Taihugu e, adavagu e,
\q2 lalogu vada o hamanokaia.
\q1 Matamu ena halari tamona ai,
\q2 aiomu agevana ena herahera nadina tamona ai,
\q1 lalogu vada o hamanokaia.
\b
\q1 
\v 10 Taihugu e adavagu e,
\q2 emu uraheni na daka gaiho!
\b
\q1 Emu uraheni ese vine ranuna e hereaiamu,
\q2 emu dehoro bonana ese muramura iboudiai bonadia e hereadiamu.
\q1 
\v 11 Adavagu e, bada-ranuna na udumu bibinadia amo e hetuturumu,
\q2 bada-ranuna bona rata na malamu henunai;
\q1 emu dabua bonadia na
\q2 Lebanon bonana na heto.
\b
\q1 
\v 12 Taihugu, adavagu, na e hekou kunuka-kunuka umana;
\q2 e hekou kunuka-kunuka umana,
\q2 e hekou ahu ranuna.
\q1 
\v 13 Emu uma ai e varamu ḡaudia na
\q2 rimono\f + \fr 4:13 \ft “Rimono” na Heberu taudia edia au huahua ta.\f* audia mai huahuadia herea-daedia,
\q1 bona kofere bona nerede;
\q2 
\v 14 oibe, nerede bona karakomo,
\q1 bona kane bona kinamomo,
\q2 bona lebona audia iboudiai;
\q1 bona muro bona aloe,\f + \fr 4:14 \ft Kofere; nerede; karakomo; kane; kinamomo; lebona; muro; aloe. Ini na Heberu taudia edia muramura mai bonadia haida ladadia.\f*
\q2 bona muramura hereadia iboudiai.
\q1 
\v 15 Hari uma na mai ranu-lohilohi gabuna,
\q2 bona mai mauri-ranuna gurina,
\q1 bona mai sinavai-sinavaina,
\q2 Lebanon amo e arumu.
\p *****
\b
\q1 
\v 16 Lai mirigini e, a noga!
\q2 Diho e, a toa! Egu uma ba toa henia,
\q2 ena muramura bonadia ba oda rohoroholai.
\q1 Egu lalokau tauna na ena uma ai baine raka vareai
\q2 ena huahua herea-daedia baine ani.
\p *****
\b
\c 5
\q1 
\v 1 Tadigu e, adavagu e,
\q2 egu uma lalonai na raka vareaimu.
\q1 Egu muro bona egu muramura mai bonadia na haboudiamu;
\q2 bada mai ranuna ida na aniamu,
\q2 egu vine ranuna bona egu rata na inumu.
\p *****
\b
\q1 O hetura hehenimu taumui e,
\q2 bavaniani, vine ranuna ba inua.
\q1 O helalokau hehenimu taumui e,
\q2 ba inuinu, ba inu momo.
\p *****
\b
\q1 
\v 2 Na mahuta, to lalogu be noga;
\q2 A kamonai, egu lalokau tauna e pidipidimu.
\p *****
\b
\q1 Taihugu e, egu Ialokau,
\q2 egu pune, oi na ḡoeva-dae!
\q2 Iduaragu ba kehoa.
\q1 Badina be hunu ese kwaragu vada e hapariparia,
\q2 hanuaboi hununa ese huigu vada e hapariparia.
\p *****
\b
\q1 
\v 3 A lau be dabua vada na dokia oho,
\q2 ma ede baina dokia lou toma?
\q1 Aegu vada na huridia,
\q2 ma ede baina hamirodia lou toma?
\b
\q1 
\v 4 Egu lalokau tauna imana na iduara ikouna ai e daukau,
\q2 bena kudougu e hetaha.
\q1 
\v 5 Lau na tore isi,
\q2 egu lalokau tauna iduarana baina kehoa.
\q1 Muro na imagu amo e hetuturu,
\q2 muro ranuna na imagu kwakikwakidia amo e hetuturu dobi,
\q2 iduara ikoulaina auna ai.
\b
\q1 
\v 6 Egu lalokau tauna iduarana na kehoa;
\q2 to egu lalokau vada e raka oho, ia na lasihia.
\q1 E hereva negana ai laumagu na e daure,
\q2 a na tahua negana ai asina davaria,
\q2 bona na boi henia negana ai ia na se haere.
\b
\q1 
\v 7 Gima taudia ese e davarigu,
\q2 hanua ai e loa eva-eva ai;
\q1 idia ese e dadabagu bona e haberogu,
\q2 egu hetaru e abihaigu,
\q2 maḡu igimana taudia ese.
\q1 
\v 8 Ierusalem kekenimui e, na haḡanimuimu,
\q2 egu lalokau tauna boma davaria, boma hamaoroa,
\q2 uraheni ese e hamasegumu.
\p *****
\b
\q1 
\v 9 Hane namo e,
\q2 emu lalokau tauna ede e herea tomamu?
\q1 Ede e herea tomamu dainai
\q2 bena ini o haḡanimai tomamu?
\p *****
\b
\q1 
\v 10 Egu lalokau tauna kopina na ḡoevaḡoeva bona kakakaka,
\q2 gerebu-ta bogaragidiai ia mo sibona herea.
\q1 
\v 11 Kwarana na \it gold\it* namo-hereana;
\q2 ia na hui-tuma, bona huina na korema-korema,
\q2 galo huina na heto.
\q1 
\v 12 Matana na ranu badidia ai e nohomu punedia na heheto,
\q2 rata ai e huridiamu, e heato ḡoevadaemu.
\q1 
\v 13 Vahana na muramura avadia umadia na heheto,
\q2 mai bonadia.
\q1 Bibinana na sosana,
\q2 muro\f + \fr 5:13 \ft “Sosana” na Heberu taudia edia herahera avana ta. “Muro” na edia muramura mai honana ta.\f* ranuna na idia amo e vevemu.
\q1 
\v 14 Imana na \it gold\it*, e hakuboroa heḡeḡe ḡauna,
\q2 mai herahera nadidia ida.
\q1 Tauna na aivori,
\q2 mai sapairo\f + \fr 5:14 \ft “Aivori” na eiefant doana. “Sapairo” na Heberu taudia edia nadi hururu-hururuna ta ladana.\f* nadidia ida.
\q1 
\v 15 Aena na bauka-bauka, nadi kurokurona na heto;
\q2 hehedaikau \it gold\it*-na ai e hadaidia kau.
\q1 Ita-itana na Lebanon na heto;
\q2 hairaina na Lebanon sidadia na heheto.
\q1 
\v 16 Ena hereva na gaiho herea;
\q2 lau na ura henia lalo-dikamu.
\q1 Ierusalem kekenimui e, egu lalokau bunai,
\q2 bona turagu bunai.
\c 6
\q1 
\v 1 Hane namo e,
\q2 emu lalokau tauna na ede ela?
\q1 Emu lalokau tauna na ede kaha ai vada e raka siri?
\q2 Edeseni ai baita tahua?
\p *****
\b
\q1 
\v 2 Egu lalokau na ena uma vada ela,
\q2 ena muramura avadia umana.
\q1 Uma ai ena mamoe baine ubudia,
\q2 bona sosana heraheradia baine haboudia.
\b
\q1 
\v 3 Ia na egu lalokau, lau be ena lalokau;
\q2 ia ese ena mamoe e ubudiamu,
\q2 sosana\f + \fr 6:3 \ft “Sosana” na Heberu taudia edia herahera avana ta.\f* bogaragidiai.
\p *****
\b
\q1 
\v 4 Egu lalokau e, oi na mai hairaimu, Tirisa na heto;
\q2 hairaimu na herea, Ierusalem na heto;
\q1 itamu na mai garina, tuari oreana mai pepena na heto.
\q2 
\v 5 Asio raraigu, badina be matamu ese e hamanoka-manokagumu.
\b
\q1 Huimu na nani serina
\q2 Gilead ororona amo e hekei dihomu na heto.
\q1 
\v 6 Isemu na mamoe serina
\q2 digu gabuna amo e daemu na heto;
\q1 iboudiai na mai natudia vara-hekapa,
\q2 ta se raka edeamu.
\q1 
\v 7 Vahamu ruaosi na rimono\f + \fr 6:7 \ft “Rimono” na Heberu taudia edia au huahua ta.\f* huahuana e ivaia parara na heto,
\q2 Vairamu iḡovalaina dabuana murinai.
\b
\q1 
\v 8 Lohia hahinedia na tauratoi-ahui,
\q2 hesiai hahinedia na taurahani-ahui,
\q2 ulato na asi iduahidia.
\q1 
\v 9 Egu pune na ḡoeva-dae, ia mo sibosibona;
\q2 ia na sinana ena lalokau,
\q2 e havaraia hahinena natuna herea-daena.
\q1 Ulato ese e itaia, bena e hanamoa;
\q2 lohia hahinedia bona hesiai hahinedia ese e itaia,
\q2 bena e imodaia.
\q1 
\v 10 Ina be daika, ita-itana na daba e reremu na heto?
\q2 Mai hairaina hua na heto?
\q1 Mai diaridiarina dina na heto?
\q2 Itana na mai garina, tuari oreana mai pepena na heto, ani?
\p *****
\b
\q1 
\v 11 Okari imeana na lao henia,
\q2 koura heraheradia baina itadia;
\q1 baina itaia, vine vada e tubu eiava;
\q2 baina diba, rimono\f + \fr 6:11 \ft “Rimono” na Heberu taudia edia au huahua ta.\f* vada e kobo eiava.
\q1 
\v 12 Asi vanahana na mata hanai: lau na kariota ai,
\q2 egu lohia tauna badibadinai nato.
\p *****
\b
\q1 
\v 13 Sulama kekenina e, a lou mai, a lou mai;
\q2 baina raraimu tao, a lou mai, a lou mai.
\p *****
\b
\q1 Badina be dahaka Sulama kekenina ba raraia,
\q2 Mahanaim mavaruna boma raraia na heto?
\p *****
\c 7
\q1 
\v 1 Lohia kekenimu e,
\q2 emu mai tamakadia ida be daka hairai!
\q1 Mamumu bauka-baukadia na herahera nadidia na heheto,
\q2 karakara tauna namona ese e kara.
\q1 
\v 2 Hudomu na kehere kuboruna na heto,
\q2 vine ranuna ai e honu hanaihanaimu.
\q1 Bogamu na uit isenuna ta,
\q2 sosana\f + \fr 7:2 \ft “Sosana” na Heberu taudia edia herahera avana ta.\f* ese e haheḡeḡea daemu.
\q1 
\v 3 Ratamu ruaosi na uda nanidia natudia rua na heheto,
\q2 uda nanina natuna vara-hekapa.
\q1 
\v 4 Aiomu na kohoro na heto,
\q2 aivori\f + \fr 7:4 \ft “Aivori” na elefant doana.\f* amo e hadaia ḡauna.
\q1 Matamu na Hesebon gohugohudia,
\q2 Batarabim ikoukouna badibadinai.
\q1 Udu-baubaumu na Lebanon kohorona na heto,
\q2 Damasko roha-hekeina.
\q1 
\v 5 Kwaramu na mai hairaina, Karamele ororona na heto;
\q2 bona huimu heveriveridia na varo kakakakadia na heheto,
\q2 hanua pavapavana na huimu ai vada e heau kau.
\p *****
\b
\q1 
\v 6 Lalokau e, moale ihavarana kekenimu,
\q2 oi na hane namo, oi na mai hairaimu.
\q1 
\v 7 Emu lata na buatau auna na heto,
\q2 bona ratamu na buatau takodia na heheto.
\q1 
\v 8 Lau na tomu, Buatau auna baina dae,
\q2 bona takona baina abidia.
\q1 Ratamu na vine takodia ida bae heḡereḡere,
\q2 udumu bonana na apolo bonadia heḡereḡeredia.
\q1 
\v 9 Emu haherahu na vine ranuna namo-hereana na heto,
\q2 i'inuna na mai gaihona,
\q2 bibinagu ai bona isegu ai.
\p *****
\b
\q1 
\v 10 Lau na egu lalokau tauna ena;
\q2 ia ese e ura henigumu.
\b
\q1 
\v 11 Egu lalokau e, aoma!
\q2 aita raka lasi tano paka ai,
\q2 hanua maraḡidia ai baita noho;
\q1 
\v 12 daba ai vine imeadia baitala,
\q2 baita itaia, vine vada e kobo dae eiava,
\q1 baita diba, buredia vada e papa eiava,
\q2 baita tahua, rimono\f + \fr 7:12 \ft “Rimono” na Heheru taudia edia au huahua ta.\f* vada e tubu eiava lasi.
\q1 Unuseni ai baina ura henimu.
\b
\q1 
\v 13 Dudai\f + \fr 7:13 \ft “Dudai” na Heheru taudia edia muramura avana ta.\f* bonadia na e daemu,
\q2 emai iduara daediai na huahua namo-hereadia idau-idau,
\q1 matamatadia bona gunadia,
\q2 vada na haboudia oiemu,
\q2 egu lalokau e!
\c 8
\q1 
\v 1 Bema oi na lau taihugu,
\q2 sinagu ratana e inuava tauna,
\q1 ariara ai baitama hedavari bena bama harahumu,
\q2 bona ta ese basinema ihi-ihiraigu.
\q1 
\v 2 Sinagu ena ruma ai,
\q2 e havaragu hahinena ena daiutu ai,
\q2 bama hakaumu vareai.
\q1 Vine ranuna mai muramurana bama henimu,
\q2 egu rimono ranuna bama ha-inulaimu.
\b
\q1 
\v 3 Imana laurina amo bema hahekwinagu,
\q2 imana idibana amo bema rosigu.
\b
\q1 
\v 4 Ierusalem kekenimui e, na haḡanimuimu,
\q2 uraheni na basio haoa,
\q2 ela bona sibona baine noga.
\p *****
\b
\q1 
\v 5 Una na daika, tano ḡaḡaena amo e maimu,
\q2 ena lalokau tauna enai e tabe kaumu?
\p *****
\b
\q1 Apolo auna henunai na haomu;
\q2 unuseni ai sinamu e hekamonaiva,
\q2 unuseni ai e havaramu hahinena na hisi e aniva.
\b
\q1 
\v 6 Toagu avatoa lalomu ai,
\q2 toagu avatoa imamu ai.
\q1 Lalokau ena goada na mase ena goada heḡereḡerena,
\q2 bona mama ena daḡedaḡe na mase gabuna ena daḡedaḡe heḡereḡerena;
\q1 ena ḡaraḡara na lahi ḡaraḡarana na heto,
\q2 ena siahu na lahi hururu-hururuna siahuna na heto.
\q1 
\v 7 Ranu momo ese lalokau basie habodoa diba;
\q2 utu-utu badadia ese basie utua dae diba.
\q1 Tau ta ese ena taḡa idoinai bema heni dudu kau, lalokau davana,
\q2 to basinema heḡereḡere;
\q2 bema dadaraia vaitani.
\p *****
\b
\q1 
\v 8 Tadimai ta do asi ratana.
\q2 Tadimai ede baia durua toma,
\q2 tau ta ese baine herevalaia negana ai?
\q1 
\v 9 Ia na bema magu, \it silver\it* amo baia ha-aukaia;
\q2 bema iduara, sida reireidia amo baia koua ahu.
\p *****
\b
\q1 
\v 10 Lau na maḡu, ratagu na kohoro na heto;
\q2 e herevalaigu tauna vairanai
\q2 lau na maino imailaina.
\p *****
\b
\q1 
\v 11 Solomon ena vine imeana ta be Baal-hamono ai;
\q2 ia ese imea ireguna taudia e habadinalaidia.
\q1 Ta ta \it silver\it* monidia daha-ta daha-ta e heni,
\q2 imea anina davana.
\b
\q1 
\v 12 Solomon e, oiemu daha-ta bavabia;
\q2 vine ireḡuna taudia edia sinahu-rua bae abi danu.
\q1 A lauegu vine imeana na lauegu korikori,
\q2 lau sibogu egu.
\b
\q1 
\v 13 Imea ai o nohomu taumu e,
\q2 bamogu na e hakalamu, gadomu ikamonaina totona;
\q2 lau danu eremu bama kamonai.
\b
\q1 
\v 14 Egu lalokau e, aoma haraḡa,
\q2 uda nanina eiava dia natuna
\q2 muramura ororodia ai na heto. 
