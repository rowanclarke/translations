\v 13 y sus hermanos, \w jefes|strong="H7218"\w* paternos, 242; y Amasay, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Azarael, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Azay, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Mesilemot, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Imer,
\v 14 \w y|strong="H5921"\w* sus hermanos, \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*, eran 128, \w el|strong="H5921"\w* \w jefe|strong="H6496"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* cuales \w era|strong="H1121"\w* Zabdiel, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Haguedolim.
\p 
\v 15 \w Y|strong="H3068"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*: \w Semaías|strong="H8098"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Hasub, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Azricam|strong="H5840"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Hasabías|strong="H2811"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Buni|strong="H1138"\w*;
\v 16 \w y|strong="H5921"\w* Sabetay \w y|strong="H5921"\w* \w Jozabad|strong="H3107"\w*, \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w jefes|strong="H7218"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w levitas|strong="H3881"\w*, dirigían \w la|strong="H5921"\w* \w obra|strong="H4399"\w* externa \w del|strong="H5921"\w* \w Templo|strong="H1004"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd*;
\v 17 y Matanías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Micaía, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Zabdi|strong="H2067"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Asaf, cantor \w principal|strong="H7218"\w* \w que|strong="H1121"\w* cantaba las acciones \w de|strong="H1121"\w* gracias \w en|strong="H8462"\w* la \w oración|strong="H8605"\w*, y Bacbuquías, \w segundo|strong="H4932"\w* entre sus hermanos, y Abda, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Samúa|strong="H8051"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Galal, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jedutún.
\v 18 \w El|strong="H3605"\w* total de \w los|strong="H3605"\w* \w levitas|strong="H3881"\w* en \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* \w santa|strong="H6944"\w* era 284.
\p 
\v 19 Los \w porteros|strong="H7778"\w* Acub, \w Talmón|strong="H2929"\w* y sus hermanos, guardianes de las \w puertas|strong="H8179"\w*: 172.
\v 20 \w El|strong="H3605"\w* resto de \w Israel|strong="H3478"\w*, de \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* y \w los|strong="H3605"\w* \w levitas|strong="H3881"\w* estaban en \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* de \w Judá|strong="H3063"\w*, \w cada|strong="H3605"\w* uno en su \w heredad|strong="H5159"\w*.
