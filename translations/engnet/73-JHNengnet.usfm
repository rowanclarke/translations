\s1 Peter and the Disciple Jesus Loved  
\p
\v 20  \w Peter|strong="G4074"\w* \w turned|strong="G1994"\w* \w around|strong="G1909"\w* \w and|strong="G2532"\w* \w saw|strong="G2424"\w* \w the|strong="G1722"\w* \w disciple|strong="G3101"\w* \w whom|strong="G3739"\w* \w Jesus|strong="G2424"\w* loved \w following|strong="G1722"\w* \w them|strong="G3588"\w*. (\w This|strong="G3588"\w* \w was|strong="G1510"\w* \w the|strong="G1722"\w* \w disciple|strong="G3101"\w* \w who|strong="G3739"\w* \w had|strong="G2424"\w* leaned \w back|strong="G1994"\w* \w against|strong="G1909"\w* \w Jesus|strong="G2424"\w*’ \w chest|strong="G4738"\w* \w at|strong="G1722"\w* \w the|strong="G1722"\w* meal \w and|strong="G2532"\w* \w asked|strong="G3004"\w*, “\w Lord|strong="G2962"\w*, \w who|strong="G3739"\w* \w is|strong="G1510"\w* \w the|strong="G1722"\w* \w one|strong="G3739"\w* \w who|strong="G3739"\w* \w is|strong="G1510"\w* \w going|strong="G2532"\w* \w to|strong="G2532"\w* \w betray|strong="G3860"\w* \w you|strong="G4771"\w*?”)  
