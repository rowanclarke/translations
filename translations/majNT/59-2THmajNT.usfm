\id 2TH Mazatec of Jalapa de Díaz
\h Xu̱ju̱n xi ma joho xi kin'ekjíhi̱ xu̱ta̱ ni̱nku̱ Tesaloni̱ka̱
\toc1 Xu̱ju̱n xi ma joho xi kits'ínkjihi̱ nda̱ postru̱ Pablo̱ xu̱ta̱ ni̱nku̱ Tesaloni̱ka̱
\toc2 Xu̱ju̱n xi ma joho xi kin'ekjíhi̱ xu̱ta̱ ni̱nku̱ Tesaloni̱ka̱
\toc3 2 Ts.
\mt1 Xu̱ju̱n xi ma joho xi kits'ínkjihi̱ nda̱ postru̱ Pablo̱ xu̱ta̱ ni̱nku̱ Tesaloni̱ka̱
\c 1
\s1 B'i̱ ts'ín kikjaniñaha̱ Pablo̱ xu̱ta̱ ni̱nku̱ xi tjín nanki Tesaloni̱ka̱
\p 
\v 1 An Pablo̱, Silbano̱ ko̱ Timoteo̱ tísuniñai̱hi̱, jun xu̱ta̱ ni̱nku̱ xi tintsu̱bo̱o nanki Tesaloni̱ka̱, xi kikj'áts'e̱nu̱u Nti̱a̱ Na̱'miná ko̱ Nda̱ Nti̱a̱ná Jesucristo̱.
\p 
\v 2 Kas'enu̱u kju̱a̱nda ko̱ kju̱a̱jyu xi tsjáná Nti̱a̱ Na̱'miná ko̱ Nda̱ Nti̱a̱ná Jesucristo̱.
\s1 B'i̱ ts'ín kitsúya Pablo̱ ni xi ka̱mat'ain xu̱ta̱ nk'ie nga kj'u̱a̱í ngáha Jesucristo̱
\p 
\v 3 Jun já nts'e, ji̱n tjíhin nga tehe̱nte k'u̱a̱i̱hi̱ máb'a̱chjíhi̱ Nti̱a̱ná nga ja kichjubó éhe̱n. Kixi̱ tjíhin nga b'a̱ n'e̱i̱, a̱t'aha̱ 'yún tís'ejin sanu̱u éhe̱n Nti̱a̱ná ko̱ a̱t'aha̱ b'i̱ ngján 'yún tín'etjó so xinki̱u.
\v 4 Kui nga tsjo maha̱ni̱ jun a̱jihi̱n xu̱ta̱ ni̱nku̱ xingisoo̱ xi Nti̱a̱ná ta̱ ts'e̱. Tíbixínyai̱ xi nkú ts'ín tín'e chúkju̱o ni xi tímat'on ko̱ xi nkú ts'ín tín'e s'ejiun Nti̱a̱ná, ndaha tsa tín'e unchanu̱u ko̱ nkjin tíkjá kju̱a̱ni̱ma̱ tísakúnu̱u.
\v 5 Kui ni xu'bi̱ xi bakúchji nga kixi̱ basehe̱ Nti̱a̱ná mí nihi xi nda ko̱ tsa xi najmi nda títs'ín xu̱ta̱. Tíb'axki̱nu̱u nga jun xi tsuhu̱nu̱u má batéxuma. Kui kju̱a̱ha nga un tíbehe̱nu̱u.
\p 
\v 6 Kixi̱ ts'i̱ín Nti̱a̱ná nga tsjáha̱ kju̱a̱'un xu̱ta̱ xi títs'ínkj'ajinnu̱u kju̱a̱'un
\v 7 ko̱ nga tsjánu̱u jun xi tín'ekj'ajinnu̱u kju̱a̱'un nga n'e̱kj'áíyako̱ni̱. B'a̱ ka̱ma ni̱stjin nga kj'u̱a̱íkúchji yjoho̱ Nda̱ Nti̱a̱ná Jesu, nk'ie nga ni̱bajenko̱ nk'a ján ntítsjehe̱ xi tjíhi̱n nga'yún nga tje̱njin ts'íhin nd'í.
\v 8 Kj'u̱a̱í ts'ínk'íéchjí xi najmi be Nti̱a̱ná ko̱ xi najmi kint'é'éhe̱n én nda tsuhu̱ Nda̱ Nti̱a̱ná Jesu.
\p 
\v 9 Kui xu̱ta̱ha xi ts'i̱ínkjáíhi̱n kju̱a̱ni̱ma̱ nga ndyja̱ sín. N'e̱kjí t'axín nginku̱n Nda̱ Nti̱a̱ná. Najmi sku̱e̱ kju̱a̱chánkaha̱ ko̱ nga'yúhu̱n.
\v 10 B'a̱ ka̱ma kui ni̱stjiu̱n nk'ie nga ja kj'u̱a̱í ts'ínkjáíhi̱n Nda̱ Nti̱a̱ná kju̱a̱chánkaha̱ a̱jihi̱n xu̱ta̱ xi ts'e̱, ko̱ ngayjee̱ xu̱ta̱ xi kis'ejihi̱n tsjo ka̱maha̱ nga sku̱e̱. Ta̱ cho̱o a̱t'aha̱ kin'e s'ejiun éhe̱n Nti̱a̱ná xi tsixínyai̱ a̱jinnu̱u.
\p 
\v 11 Kui kju̱a̱ha, nk'ie nga chubako̱ho̱ni̱ Nti̱a̱ná tehe̱nte chubantjáíhi̱ ri̱, tu̱ xi k'u̱a̱xki̱hi̱nu̱u Nti̱a̱ná nga jun xi tsuhu̱nu̱u nga ka̱mankuko̱o xu̱ta̱ xi j'ájin. Binchii̱hi̱ Nti̱a̱ná nga kats'íntjusunko̱ nga'yúhu̱n ngayje tíkjá ni xi nda mjenu̱u nga n'o̱o ko̱ ngayjee̱ xá xi tín'o tu̱ nga̱t'aha̱ nga s'ejinnu̱u.
\v 12 Nk'ie nga b'a̱ ka̱ma, sa̱kúhu̱ kju̱a̱chánka Nda̱ Nti̱a̱ná Jesu a̱jinnu̱u ko̱ jun ta̱ sa̱kúnu̱u kju̱a̱chánka nga̱t'aha̱ Nda̱ Nti̱a̱ná, xi nkú ts'ín tje̱he̱n ra̱ kju̱a̱ndaha̱ Nti̱a̱ná ko̱ kju̱a̱ndaha̱ Nda̱ Nti̱a̱ná Jesucristo̱.
\c 2
\s1 B'i̱ ts'ín tsakúya Pablo̱ ni ch'onk'un xi ka̱ma kintehe̱ ni nga kj'u̱a̱íkúchji yjoho̱ Jesucristo̱
\p 
\v 1 Jun já nts'e, nga̱t'a ts'e̱ nga kj'u̱a̱í ngáha Nda̱ Nti̱a̱ná Jesucristo̱ ko̱ nga ka̱ma ñjakúka̱á, ji̱n tíbinchii̱hi̱
\v 2 nga najmi tu̱ ki̱tsa̱ n'ek'óntjaiyo xi nkú ts'ín n'enkjíntak'un. Najmi tu̱ fanta̱ha̱ ru̱u yjonu̱u tsa ku̱i̱nú'yó én nga ja kuichu ni̱stjin nga kj'u̱a̱í ngáha Nda̱ Nti̱a̱ná, ndaha tsa tjín xi b'a̱ ku̱i̱tsu̱ nga Espiri̱tu̱hu̱ Nti̱a̱ná títs'ínkinchja̱ha̱ ko̱ tsa b'a̱ ku̱i̱tsu̱ nga éhe̱n Nti̱a̱ná tíb'éni̱jmí, ko̱ ndaha tsa n'e̱kjóho̱on nku xu̱ju̱n xi nkúhu tsa ji̱n kin'e nibái̱.
\p 
\v 3 Ndaha̱chí najmi tu̱ 'ba̱i̱nto tsa tjín xi k'u̱a̱na̱cha̱nu̱u. A̱t'aha̱ kintehe̱ ni nga ku̱i̱chú kui ni̱stjiu̱n, tjun i̱ncha ts'i̱ín t'axín xu̱ta̱ Nti̱a̱ná ko̱ ku̱a̱kúchji yjoho̱ nda̱ xi ngatitsuu̱n ts'e̱he̱, xi nga̱k'i̱e̱n tje̱he̱n ra̱.
\v 4 Kui xi ts'i̱ín chánka yjoho̱ ko̱ ngju̱a̱i̱ kontra̱ha̱ ngayjee̱ ni xi tsu xu̱ta̱ nga Nti̱a̱ ko̱ ngayjee̱ ni xi benkjún xu̱ta̱. Santaha a̱nte nkjúhu̱n ni̱nku̱hu̱ Nti̱a̱ná k'úéjña nga nti̱a̱ ts'i̱ín ma suba yjoho̱.
\p 
\v 5 ¿A najmi ta̱ f'áítsjehénnu̱u, nk'ie nga tsáte̱jñajinnu̱u kixinyanu̱u ni xu'bi̱?
\v 6 Ko̱ ja yo nd'a̱i̱ mí nihi xi tíb'échjaha̱ nda̱ xi ngatitsuu̱n ts'e̱he̱, tu̱ xi ku̱a̱kúchjihi yjoho̱ nga ku̱i̱chú ni̱stjihi̱n.
\v 7 A̱t'aha̱ ja títs'ínxá nd'a̱i̱ nga'yúhu̱n ngatitsun xi tíjña'moo̱. Tu̱ ni xi ndyjahá sa, ndyja nga chjúxin xi tíb'échjaha̱ nd'a̱i̱.
\v 8 Nk'iehé ku̱a̱kúchji yjoho̱ nda̱ ch'onk'uu̱n. Tu̱nga ntjo̱ ts'ahá Nda̱ Nti̱a̱ná Jesu ts'i̱ín ngana̱ko̱ho̱ ra̱ ko̱ nd'íhi̱ sénni̱stjihi̱n ts'i̱ínkjeko̱o nk'ie nga kj'u̱a̱í.
\p 
\v 9 Nda̱nindoo̱ ts'i̱ínxájihi̱n nda̱ ch'onk'uu̱n nk'ie nga kj'u̱a̱í. Chánka nga'yún xi kj'u̱a̱íko̱. Ts'i̱ín ni xi ku̱a̱kúchji nga'yúhu̱n ko̱ kju̱a̱nkjún tsank'á ts'i̱ín.
\v 10 Ts'i̱ínchjén ngayje tíkjá ni xi najmi nda nga k'u̱a̱na̱cha̱ha̱ xu̱ta̱ xi tjíhin nga ndyja̱. Kui xu̱ta̱ha xi kits'ín t'axín én xi na̱xu̱, én xi ka̱ma ts'i̱ínk'ankihi̱ kai.
\v 11 Kui kju̱a̱ha nga Nti̱a̱ná ts'i̱ín nibáha̱ ra̱ xu̱ta̱ xu'bo̱ nku nga'yún xi k'u̱a̱na̱cha̱ha̱ nga s'e̱jihi̱n én tsank'óo̱.
\v 12 B'a̱ ts'ín n'e̱nijéhe̱ ra̱ ngatentee̱ xi najmi kis'ejihi̱n én xi na̱xu̱, xi tu̱ sahá kama tsjoho̱ ni xi najmi na̱xu̱ nginku̱n Nti̱a̱ná.
\s1 B'i̱ ts'ín kinchja̱ Pablo̱ nga ndjá ku̱i̱nchajin xu̱ta̱ Tesaloni̱ka̱ ni xi ts'e̱ Nti̱a̱ná
\p 
\v 13 Tu̱nga máha ji̱n, tehe̱nte tjíhin nga k'u̱a̱i̱hi̱ máb'a̱chjíhi̱ Nti̱a̱ná a̱t'aha̱ kichjubó éhe̱n. 'Yún tjoho̱ Nda̱ Nti̱a̱ná jun, já nts'eé. A̱t'aha̱ santaha nkúhu nga tuts'ihi̱n ni j'ájinnu̱u Nti̱a̱ná tu̱ xi n'e̱k'ankihi̱nu̱u nga̱t'aha̱ Espiri̱tu̱hu̱ Nti̱a̱ná xi títs'ín jenu̱u nginku̱n ko̱ nga̱t'aha̱ én na̱xu̱ xi kis'ejinnu̱u.
\v 14 Kui kju̱a̱ha kinchja̱ha̱nu̱u Nti̱a̱ná nga kits'ínkint'énu̱u én nda tsu xi y'eni̱jmíi̱ a̱jinnu̱u, tu̱ xi b'a̱ ts'ín sa̱kúhu̱nu̱u kju̱a̱chánkaha̱ Nda̱ Nti̱a̱ná Jesucristo̱.
\p 
\v 15 Kui b'a̱ maha, já nts'e, ndjá ti̱nchahanu ko̱ n'e̱tjusun ni xi tsinchiyó nga kin'ekjas'ei̱hi̱n, ni xi tsixínyai̱hi̱ ko̱ xi y'ét'a xu̱ju̱i̱hi̱n.
\v 16 Tjoho̱ ñá Nti̱a̱ Na̱'miná ko̱ tsjá nga'yúnná ko̱ tsjáná nga chúyaha̱á ni xi nda, a̱t'aha̱ chánka kju̱a̱ndaha̱. Nda̱ Nti̱a̱ná Jesucristo̱ ko̱ Nti̱a̱ Na̱'miná
\v 17 katsjá nga'yúhu̱n ani̱ma̱nu̱u ko̱ kats'ín nga ni xi nda n'o̱o ko̱ chu̱bo.
\c 3
\s1 B'i̱ ts'ín tsanki Pablo̱ nga chu̱bako̱ Nti̱a̱ná
\p 
\v 1 Ni xi xín yanu̱u, já nts'e, chu̱bantjáíni̱ nk'ie nga chu̱bako̱o Nti̱a̱ná. Ti̱nchúhu̱u nga ki̱tsa̱ katjitse ko̱ nda ts'ín kan'ekjáíhi̱n éhe̱n Nda̱ Nti̱a̱ná tu̱ má xi tje̱hén ni. B'a̱ katuma xi nkú nga kama a̱jinnu̱u.
\v 2 Ko̱ ti̱nchíntjaini̱ tu̱ xi Nti̱a̱ná kjéxihi̱nni̱ a̱jihi̱n já xi kits'ínkatsún kju̱a̱nkjintak'uhu̱n ko̱ ch'onk'un xi tjín. A̱t'aha̱ najmi ngayjee̱ xu̱ta̱ s'ejihi̱n Nti̱a̱ná.
\p 
\v 3 Tu̱nga ts'íntjusuhún Nda̱ Nti̱a̱ná ni xi nchja̱. Kui xi ndjá ts'i̱ínkinchánu̱u ko̱ kúnnu̱u a̱jihi̱n ni ch'onk'un xi tjín.
\v 4 Xihi̱ nkuhú Nda̱ Nti̱a̱ná s'ejinná behe̱ tak'ui̱n nga tín'etjusun ko̱ nga tu̱ nku n'e̱tjusunnú kju̱a̱téxuma xi kin'ekjas'ei̱hi̱n.
\v 5 Nda̱ Nti̱a̱ná katsjáni̱yáha̱ ani̱ma̱nu̱u nga n'e̱ mjo xi nkú ts'ín mjehe̱ ñá Nti̱a̱ná ko̱ nga n'e̱ chúkju̱o ni xi tíbitjajíún xi nkú ts'ín kits'ín chúkju̱a̱ Cristo̱.
\s1 B'i̱ ts'ín tsakúya Pablo̱ nk'ie nga ts'i̱ínxá xu̱ta̱ ni̱nku̱ Tesaloni̱ka̱
\p 
\v 6 Jun já nts'e, ngajoho̱ Nda̱ Nti̱a̱ná Jesucristo̱ b'a̱ tí'mii̱hi̱ nga n'e̱ t'axíhu̱un yjonu̱u ngatentee̱ já nts'eé xi tjíntu ts'e, xi najmi tíi̱ncha ts'ín xi nkú ts'ín tíjña én xi tsakuyái̱hi̱ ko̱ kin'ekjóho̱on.
\v 7 A̱t'aha̱ jun ja yo xi nkú ts'ín tjíhin nga ku̱i̱ntsu̱bo̱o nga cha̱se̱ chu̱ba̱yani̱. Najmi tintsu̱ba̱ ts'ei̱ a̱jinnu̱u.
\p 
\v 8 Ndaha nku najmi chu̱ba̱ kichinei̱ nichinehe̱ tsa najmi y'echjíi̱hi̱. Ni̱stjin ni̱stje̱n ní kin'exái̱ ko̱ kiyai̱ kju̱a̱ni̱ma̱ tu̱ xi ndaha nku xi tjín a̱jinnu̱u najmi ji̱n y'enéhe̱ ri̱ yjoni̱.
\v 9 Kju̱axi̱ nga kama tsinchii̱hi̱ ni xi kamachjénni̱ kai, a̱t'aha̱ tjínni̱ kixi̱ nga b'a̱ n'e̱i̱. Tu̱nga tu̱ sa ní kin'exái̱ nga y'ejña chu̱ba̱yai̱hi̱ xu̱ta̱, tu̱ xi b'a̱ ta̱ n'e̱henu xi nkú nga kin'ei̱.
\v 10 A̱t'aha̱ nk'ie nga tintsu̱ba̱i̱ a̱jinnu̱u, kik'a̱i̱hi̱ kju̱a̱téxuma xu'bi̱: “Tsa tjín xi najmi mjehe̱ ts'i̱ínxá, ta̱ najmi kakjine ma.”
\p 
\v 11 A̱t'aha̱ tínu'yái̱ én nga tjín a̱jinnu̱u xi tjíma ts'e, xi najmi chumi nihi xi tíi̱ncha ts'ín, nga tu̱ sahá chu̱ba̱ tíi̱ncha tsungijihín yjoho̱ má najmi kui tje̱he̱n ra̱.
\v 12 Ngajoho̱ Nda̱ Nti̱a̱ná Jesucristo̱ b'a̱ tí'mii̱hi̱ ko̱ tíbinchii̱hi̱ xu̱ta̱ xu'bo̱ nga tu̱ sahá jyukj'i kats'ínxá. B'a̱ ts'ín sa̱kúhu̱ ra̱ ni xi machjéhe̱n.
\p 
\v 13 Ko̱ jun já nts'e, najmi tu̱ n'ekjentoho̱o yjonu̱u nga n'o̱o ni xi nda.
\v 14 Tsa tjín xi najmi ts'i̱ínsihi̱n én xi tíb'et'ai̱ xu̱ju̱i̱n, cha̱se̱ sisiun yá xi b'a̱ ts'i̱ín ko̱ najmi ta̱ mako̱honu, tu̱ xi katuma subaha̱ ra̱.
\v 15 Tu̱nga najmi tu̱ chasehé ru̱u xi nkúhu tsa kui xi xu̱ta̱ kontra̱nu̱u. Tjenni̱yá níhu̱u a̱t'aha̱ nda̱ nts'o maha.
\s1 B'i̱ ts'ín kits'ínkje Pablo̱ xu̱ju̱i̱n
\p 
\v 16 Nda̱ Nti̱a̱ná xi tsjáná kju̱a̱jyu, kui xi katsjá tehe̱ntenu̱u kju̱a̱jyu a̱jihi̱n ni xi ku̱i̱tjájiun. Nda̱ Nti̱a̱ná kat'ejñajinnu̱u ngatentoo̱.
\p 
\v 17 An Pablo̱ ntuna̱ tíb'et'áha̱nu̱u kju̱a̱suniñana̱. Kui xi bakúchji ngayjee̱ xu̱ju̱n xi ts'inkjíhi̱ xu̱ta̱. B'a̱ ts'ín b'et'á.
\p 
\v 18 Ngatentoo̱ kas'enu̱u kju̱a̱ndaha̱ Nda̱ Nti̱a̱ná Jesucristo̱.
