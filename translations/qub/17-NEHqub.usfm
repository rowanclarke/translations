\li3  
\v 26 Belén runacunawan Netofa runacuna 188. 
\li3  
\v 27 Anatot runacuna 128. 
\li3  
\v 28 Bet-azmavet runacuna 42. 
\li3  
\v 29 Quiriat-jearim, Cafira, Beerot runacuna 743. 
\li3  
\v 30 Ramäwan Geba runacuna 621. 
\li3  
\v 31 Micmas runacuna 122. 
\li3  
\v 32 Betelwan Hai runacuna 123. 
