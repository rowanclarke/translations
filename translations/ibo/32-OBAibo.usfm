\id OBA - Biblica® Open Igbo Contemporary Bible 2020
\h Ọbadaya
\toc1 Ọbadaya
\toc2 Ọbadaya
\toc3 Ọbd
\mt1 Ọbadaya
\c 1
\s1 Ọhụ Ọbadaya
\p 
\v 1 Ọhụ nke Ọbadaya hụrụ.
\b
\b
\p Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu banyere Edọm.
\q1 Anyị anụla ozi si nʼọnụ Onyenwe anyị,
\q2 e zipụla onyeozi ka ọ gaa mba niile dị iche iche zie ha ozi, sị,
\q1 “Bilikwanụ ka anyị gaa buo agha megide ya.”
\b
\q1 
\v 2 “Lee, aga m eme ka ị dị nta nʼetiti mba dị iche iche;
\q2 ị ga-abụ ihe a na-elelị anya nke ukwuu.
\q1 
\v 3 Nganga nke obi gị eduhiela gị,
\q2 gị onye bi na mgbawa niile nke nkume dị elu,
\q2 onye ebe obibi ya dị nʼebe dị oke elu.
\q1 Gị onye na-ekwu nʼime obi ya,
\q2 ‘Onye ga-akpụdata m nʼala?’
\q1 
\v 4 A sịkwarị na i felie elu dịka ugo,
\q2 ọ bụrụkwa na ị kpaa akwụ gị nʼetiti kpakpando,
\q2 aga m esite nʼebe ahụ kpụdata gị nʼala.”
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri.
\q1 
\v 5 “Ọ bụrụ na ndị ohi abịakwute gị,
\q2 e, ọ bụrụ na ndị na-apụnara mmadụ ihe abịakwute gị nʼetiti abalị,
\q1 lee, ụdị mbibi na-echere ịdakwasị gị!
\q2 Ọ bụghị naanị ihe ha chọrọ ka ha ga-ezuru?
\q1 Ọ bụrụ na ndị na-aghọ mkpụrụ vaịnị abịakwute gị,
\q2 ọ bụ na ha agaghị ahapụrụ gị mkpụrụ ole na ole?
\q1 
\v 6 Ma lee ka e si nyochapụtachaa ebe niile Ịsọ debere akụ ya,
\q2 lekwaa ka e si chịkọrọ akụ ya niile bụ nke zoro ezo!
\q1 
\v 7 Ndị enyi gị niile aghọgbuola gị, nwee ike imegide gị,
\q2 ndị gị na ha na-adị na mma achụrụla gị ruo nʼoke ala;
\q1 ndị gị na ha na-erikọ nri gị ga-esiri gị ọnya igbudu,
\q2 ma ị gaghị achọpụta ya.
\b
\q1 
\v 8 “Nʼụbọchị ahụ,” otu a ka \nd Onyenwe anyị\nd* kwubiri ya,
\q2 “ọ bụ na mụ agaghị ala ndị oke amamihe niile nọ nʼEdọm nʼiyi,
\q2 bụ ndị nwere mmụọ nghọta nọ nʼugwu Ịsọ?
\q1 
\v 9 Ndị gị bụ dike nʼagha, o Teman, ka ụjọ ga-eri.
\q2 Onye ọbụlakwa nọ nʼugwu Ịsọ niile,
\q2 ka a ga-egbuda nʼagha.
\q1 
\v 10 Nʼihi na i gbuola ma mesokwa nwanne gị bụ Jekọb ihe ike.
\q2 Ihere ga-ekpuchi gị;
\q2 a ga-alakwa gị nʼiyi ruo mgbe ebighị ebi.
\q1 
\v 11 Nʼụbọchị ahụ, ị nọọrọ onwe gị,
\q2 na-ele ndị ọbịa ka ha na-akwakọrọcha akụnụba ya,
\q1 sitekwa nʼọnụ ụzọ ama ya gafee
\q2 fee nza iji kerie Jerusalem.
\q2 Ị dịkwa ka otu onye nʼime ha.
\q1 
\v 12 Ma ị garaghị eleda nwanne gị anya
\q2 nʼụbọchị nsogbu ya,
\q1 ị garaghị aṅụ ndị Juda
\q2 nʼụbọchị ahụ e bibiri ha.
\q1 Ị garaghị anyara ha isi
\q2 nʼụbọchị ahụ ha nọ na nsogbu.
\q1 
\v 13 I kwesighị isite nʼọnụ ụzọ ama ndị m zọọ ije
\q2 nʼụbọchị ha nọ na nsogbu,
\q1 o zighị ezi na i ga-enwe obi aṅụrị nʼoge ihe ọjọọ bịakwasịrị ha,
\q2 nʼụbọchị ha nọ na nsogbu,
\q1 maọbụ jiri aka ike pụnara ha akụ ha
\q2 nʼụbọchị nsogbu ha.
\q1 
\v 14 I kwesighị ịnọchi na ngalaba ụzọ
\q2 igbu ndị na-agbapụ ọsọ ndụ,
\q1 maọbụ were ndị ha fọdụrụ ndụ nyefee ha nʼaka ndị iro ha,
\q2 nʼụbọchị nsogbu ha.
\b
\q1 
\v 15 “Ụbọchị nke Onyenwe anyị dị nso
\q2 nye mba niile.
\q1 Dịka i si mee ndị ọzọ, otu ahụ ka a ga-eme gị;
\q2 ihe i metara ga-adị gị nʼisi.
\q1 
\v 16 Dịka i si site nʼugwu nsọ m ṅụọ ihe ọṅụṅụ
\q2 otu a ka mba niile gbara gị gburugburu ga-esi ṅụọ ma na-adagharị.
\q1 Ha ga-aṅụ, ṅụọ,
\q2 ma ọ gaghị adị ha ka o nwere ihe ha na-aṅụ.
\q1 
\v 17 Ma nʼugwu Zayọn ndị gbara ọsọ ndụ ga-afọdụ,
\q2 ọ ga-adị nsọ,
\q2 ụlọ Jekọb ga-enwetakwa ihe nketa ha ọzọ.
\q1 
\v 18 Ụlọ Jekọb ga-abụ ọkụ,
\q2 ụlọ Josef ga-abụkwa ire ọkụ:
\q1 ma ụlọ Ịsọ ga-aghọkwa ukwu ọka.
\q2 Ha ga-esunyekwa ha ọkụ ma rechapụ ya.
\q1 Ọ dịkwaghị ndị ga-afọdụ ndụ
\q2 site nʼụlọ Ịsọ.”
\q1 \nd Onyenwe anyị\nd* ekwuola ya.
\b
\q1 
\v 19 Mgbe ahụ, ndị bi na Negev ga-ebichi
\q2 nʼugwu ugwu Ịsọ,
\q1 ndị si na Shefela\f + \fr 1:19 \ft Ndị a bi nʼebe ala ala ugwu\f*
\q2 ga-enwekọta ala ndị Filistia.
\q1 Ha ga-anọchi ala ubi niile nke ndị Ifrem na nke Sameria.
\q2 Ndị Benjamin ga-enwetakwa Gilead.
\q1 
\v 20 Ụmụ Izrel gbara ọsọ ndụ gaa na Hala,
\q2 ga-enweta, bido nʼala Fonisia ruo Zarefat.
\q1 Ndị ahụ e mere ka ha si Jerusalem gaa biri na Sefarad,
\q2 ga-enwetakwa obodo niile nke Negeb.
\q1 
\v 21 Ndị nnapụta ga-agbago nʼugwu Zayọn
\q2 maka ịchị ugwu Ịsọ niile.
\q2 Mgbe ahụ alaeze niile ga-abụkwa nke \nd Onyenwe anyị\nd*.
