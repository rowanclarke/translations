\id ISA - Aguaruna 
\h Isaías 
\toc1 Isaías 
\toc2 (Isaías) 
\toc3 Is. 
\mt1 Isaías 
\c 1  
\ms1 Jerusalén Judá wegantu aidaujai pachisa etsegkamu 
\mr (1—6) 
\s1 Judá wegantu aidauk pegkegchaun takau aidau 
\p  
\v 1 Judá wegantu aidaunash waji utugchatak ajitnush ayi nuna pachis Amosa uchijin Isaíasan Apajuí ujakui. Nunak Judá wegantu aidaun apuji aidau Uzías, Jotam, Acaz, Ezequías aatus aajaku aina nunú tsawantin ujakui. 
\p  
\v 2 Dutikam nuna Isaías etsejak: 
\b  
\q1 Nayaim, nugka aidautigmesh 
\q1 Tuke Pujuu tawa nunú antuktajum. 
\q1 Apajuí chichaak: 
\q1 “Wi Israel aents aidaunak mina uchig asagmatai, 
\q1 kuitamkan tsakapakan idaisauwaitjai. 
\q1 Dutikamaitak mina umigtutsuk wijai shiwagmagawaje. 
\q1  
\v 3 Tuja bakak, yaita niina kuitamnush 
\q1 nunak shiig wainui; 
\q1 tuja burro aidaushkam aents niyai entsamak 
\q1 wekaena nunak shiig dekainawai, 
\q1 untsu mina aentsug Israel aents aina duka 
\q1 wi kuitamsam batsatiatak 
\q1 mina shiwagmatuinawai. 
\b  
\q1  
\v 4 “¡Aents ayatak pegkegchaunak takau aidauk, 
\q1 pegkegchau takat aina nuna 
\q1 utuatmamkag batsamin ainawai! 
\q1 ¡Tuja pegkegchaun takajaku aina 
\q1 nuna uchiji wegantu aidaushkam, 
\q1 pegkegchaunak dekainayatak, 
\q1 nuninun yujaju asag 
\q1 Tuke Pujuu, pegkejam, 
\q1 Israel aents aidaun Apajuíjiya nuna 
\q1 kajimatkiag idaisaje! 
\q1  
\v 5 Atumek dekas intimkiu atag tusajum wakegagme, 
\q1 nunin asagmin shiig kuashat suwimkan amasjime. 
\q1 Imatikamu asajum atumi iyashinig 
\q1 pegkeg ayautkauk atsawai. 
\q1 Tuja atumi buuken pujagbauk esamtsui, 
\q1 tuke imanisag ayawai. 
\q1 ¡Nuadui atumek kakakchau wajasugme! 
\q1  
\v 6 Dawemin nagkamas buukmijai 
\q1 ashí atumi iyashig makichkish pegkeg ayautkauk atsawai; 
\q1 tuja anú ibau atumi iyashin ayá nuna 
\q1 ampia pempenjamag kuitamak 
\q1 etsaentamainuk makichkish atsawai. 
\q1 Tuja najaimagminish aceiteyai yakagtamjagkesh, imijtugmakchaje. 
\q1  
\v 7 Atumi nugkenak yaaktajum aidaujai 
\q1 shiwag aidau tsaikagmatai, 
\q1 agkan shiig pujumainchau wajase. 
\q1 Tuja yaakat aidau apeamu keenawai. 
\q1 Tuja atum ajakmamu aidaunmayan 
\q1 shiwag aidau juukag atumesh wainjuminig amuinawai. 
\q1 Yaunchuk yaakat Sodoma tsaikam 
\q1 atsau agkan juwakua numamtuk wajase”, 
\q1 tujamui Apajuí. 
\q1  
\v 8 Untsu ima Jerusalégkak tsaikchamu juwake, 
\q1 nuniku asa melón ajakbaunum nuna ejapeen 
\q1 makichik aak aakmaka pachitsuk idaisamu aama 
\q1 numamtuk wajas awai. 
\q1 Nuniak nuigtushkam makichik yaakat 
\q1 shiwag tenteam aama numamtin wajas awai. 
\q1  
\v 9 Tuja Tuke Pujuu ashí senchigtina nunú 
\q1 jutii ainag nuwiyan ujumak uwemtikchakuig, 
\q1 iik sodomanmaya aents, gomorranmaya 
\q1 aents aidaujai ijinauwa numamtukes wajakagtai. 
\s1 Israel aents aidau Apajuín dekaskenum emematchagbau 
\q1  
\v 10 Israel aents aidaun apuji aidautigmek, 
\q1 sodomanmaya tuja gomorranmaya aents 
\q1 aidaun apuji pegkegchau aajaku aina nunin wajasugme. 
\q1 Nuadui Tuke Pujuun chichamega nunú 
\q1 shiig antuka jukitajum. 
\q1  
\v 11 Tuke Pujuu chichaak: 
\q1 “¡Atum Apajuí anentag suwaji tusajum, 
\q1 kuntin aidau maajum mina emematjaku 
\q1 kuntin patai apetainum patagjum, 
\q1 nuna neje ashí apeajum nunak wika dakitajai! 
\q1 ¡Ataktuk sujusaigpa! 
\q1 Tuja toro aidaun wiyaji, uwig aishmag aidaun, 
\q1 chivo tsakat aidaun numpen wainkunchakam 
\q1 tsumajai. 
\q1  
\v 12 Wika mina emematjitasajum minakjum, 
\q1 kuntin aidau ikaunmatajum tusanuk 
\q1 makichkish atumnak segatsjime. 
\q1 Atumek mina dushiktakjum, 
\q1 mina jegag pegkegma nunú 
\q1 pegkegchau ematasajum kaunjume. 
\q1 ¡Juju jega mina emamatjaku ijuntaya juwig batsamtsuk, 
\q1 jiinja shiyaktajum! 
\q1  
\v 13 Ataktu awagkigmek anentag mina sujamu 
\q1 pegkegchau aina juninuk itagtuawaigpa. 
\q1 Nunú apeamua nunak wika tsumain diyajai. 
\q1 Tuja nantu yama takamunum Apajuí emematku jiistamtai, 
\q1 nuigtu tsawan ayamtain 
\q1 jiistamtai ati tusa umikbauwa nunú 
\q1 jiistamami tusajum aents aidau ipajum ijumjume, 
\q1 tujash wika aents pegkegchaun takau aidau 
\q1 jiistamaina nunak shiig dakitajai. 
\q1  
\v 14 Nantu yama takamunum jiistamjum nunak wika dakitajai; 
\q1 ¡Nunú jiistamjum nunak dakitmain diyajai, 
\q1 nuniakun katsuntu pujumainchau dekapeajai! 
\q1  
\v 15 Tuja atum mina aujtustasajum uwejum takuajum nunak 
\q1 wika makichkish diyatsjime; 
\q1 tuja antugtanakesh antugtsujime. 
\q1 Tuja atumek kuashat aents mainaitjum duwi, 
\q1 uwejum takuajum duka ayatak numpak ainawai. 
\q1  
\v 16 ¡Nijamaktajum! 
\q1 ¡Pegkegchaujum aidau diitan dakitajai! 
\q1 ¡Pegkegchau takatak idaisatajum! 
\q1  
\v 17 ¡Pegkeja nunú takat unuimagtajum, 
\q1 kakanmamsatajum pegkeg takatnum, 
\q1 nuniakjum aents waitkam batsata nunú yaigtajum, 
\q1 dutikakjum uchi bitaik aidaush, 
\q1 tuja waje aidaushkam ayamjuktajum!” 
\b  
\q1  
\v 18 Tuke Pujuu chichagtamak: 
\q1 “Yamai juju pachisa atumjai chichasmi. 
\q1 Tuja atumi tudaujum numpa kapantua imanaitkuish, 
\q1 wi nunak esakatjan yujagkim pujua iman awajtustatjime; 
\q1 tuja jáanch numpa kapantui egkekbauwa imanaitkuish, 
\q1 wi nunak esakatjan lana pujuama iman awajtustatjime. 
\q1  
\v 19 Atum mina umigtakjumek, 
\q1 atumi nugkem pegkeja nuwi ajakmajum yuwattagme. 
\q1  
\v 20 Untsu atum ayatak intimkugmek, 
\q1 duka maaniamunum ijina utsam atatjume”, 
\q1 tujamui Tuke Pujuu tusa, Isaías tiuwai. 
\s1 Apajuí Jerusalégnak iwajattawai 
\q1  
\v 21 ¡Jerusalégnumia aents aidauk 
\q1 yaunchkek shiig anentaimkau, waitjuchu, pegkeg aajabi, 
\q1 tujash yamaik nuwa wainka akika dutiktaijai betek, 
\q1 magkagtin wajasu ainawai! 
\q1  
\v 22 Atumek plata pegkejama iman ayugme, 
\q1 tujash yamaik utsagbaujai betek wajasugme. 
\q1 Yaunchkek vino pegkeja iman ayugme, 
\q1 tujash yamaik chujuin wajasugme. 
\q1  
\v 23 Atumi apuji aidauk aents intimkiu, 
\q1 pegkegchau aina nuna kumpaji ainawai. 
\q1 Kuichik akiam, tuja waji aidau suwam 
\q1 nuna juwinak, 
\q1 aents takamsachunak jujuwai takamsauk tuinawai. 
\q1 Tuja bitaik aidaunash, waje aidaunash waitkainawai, 
\q1 dutikainau asag makichkish yainatsui. 
\b  
\q1  
\v 24 Nuadui apu Tuke Pujuu ashí senchigtina nunú chichaak: 
\q1 “¡Ditak mina shiwag ainawai, 
\q1 nuadui wi ditanak suwimkan susagtatjai! 
\q1  
\v 25 Dutikakun dita tudaujinak waji pegkegchau aidau 
\q1 apetia numamtuk apean utsankattajai, 
\q1 dutikan dita pegkegchau takamtaiji aina nunak esakatjattajai. 
\q1  
\v 26 Dutikan yaunchuk apu chichama epegkin aidau, 
\q1 chichagkagtin aidau shiig takau, 
\q1 waitjuchu aajabia nujai betek emaktatjai. 
\q1 Dutika ai: ‘Jerusalégnumia aents aidauk, 
\q1 pegkejan takau aidau’, nuigtu: 
\q1 ‘Ima Apajuínak umijin aidau’, tujamtin ainawai. 
\q1  
\v 27 Wika wait anenkagtin asan, 
\q1 nuigtush uwemtikagtin asan, 
\q1 Jerusalégnumia aents aidau mina umigtuinakuig, 
\q1 wainka waitkam yujakuish, 
\q1 wi ditanak ayamjuktinaitjai. 
\q1  
\v 28 Untsu aents pegkegchaun takau aina duka 
\q1 ashí jinawagtinai, 
\q1 wagki mina umigtutan dakituidau asag. 
\q1  
\v 29 Tuja atum aidautijum anú yagkug aidau, 
\q1 tuja numi encina aidau ayá nunú shiig wakejusjum 
\q1 kuitamjum nuwi wainka apajuímtai aidau 
\q1 emematjum nunú diisjum datsagtinaitjume. 
\q1  
\v 30 Atum aidautigmek, numi encina duke kakekamtai, 
\q1 wentsamtug wajama numamtin, 
\q1 tuja yagkug yumi ukattsuk idaisamujai betek atinaitjume. 
\q1  
\v 31 Tuja atum ainajum anuiya senchigtina duka 
\q1 chijichi kagaju apeam megkagama 
\q1 numamtuk megkaejatnai. 
\q1 Niina tudauji aina nunuwai jii kegaujai beteka duka. 
\q1 Nuniau asa nunú chijichinak apea ajapeawai. 
\q1 Nuadui niina tudaujijai esatnai, 
\q1 tuja nuna ikagnamainuk makichkish atsutnai.” 
\c 2  
\s1 Ashí nugkanmaya aents aidauk agkan batsamsagtin ainawai 
\p  
\v 1 Apajuí Judá wegantu aidaun, Jerusalégjai pachis, Amosa uchijin Isaíasan ujakua duka jujuwai: 
\b  
\q1  
\v 2 Apajuí emematku ijuntai 
\q1 mujanum jegamkamu awa duka 
\q1 atakea duish eme anentsa diitai atinai. 
\q1 Nuna diinak kuashat aents 
\q1 tikich nugkanmaya aidau kauniagtinai. 
\q1  
\v 3 Kuashat aents aidau kaunainak: 
\q1 “¡Minitajum au muja Tuke Pujuu etegkamua awi wakagmi, 
\q1 tuja jega Apajuí emematku ijuntai 
\q1 jegamkamua awi wakagmi. 
\q1 Awi Apajuí niina chichamen jintinjamamtai, 
\q1 nunú antuka nii tabauwa duke umikagmi!” titinai. 
\q1 Wagki nii chichame umiktin agagbauwa duka Siógnumia wantintinai. 
\q1 Tuja niina chichameshkam 
\q1 Jerusalégnumia jiinki antuetinai. 
\q1  
\v 4 Tuja nugka múun aidaunmayanash 
\q1 Apajuí dita pegkegchaujin diijus suwimkan susatnai. 
\q1 Nuadui ashí nugka múun aidaunmayag 
\q1 dita maanitaiji aidaunak ajak ajakmaku nugka pukutai, 
\q1 arroz tsupitain najankatin ainawai. 
\q1 Dutikawagmatai maaniamuk nagkankatnai, 
\q1 tuja maaniatin jintiamushkam atsustinai. 
\q1  
\v 5 ¡Israel aents aidauwah, 
\q1 Tuke Pujuun chichamega nunú antuka betek umikagmi! 
\c 5  
\s1 Uva ajakbau pachisa kantamamu 
\p  
\v 1 Mina kumpaju daajin pachisan, nii uva ajakmamujiya nuna pachisan, kantamtain wi kantamatjai. 
\b  
\q1 Mina kumpagdau nugka pegkeg 
\q1 shiig tsapaunum uva ajakbau ajuyi. 
\q1  
\v 2 Nuna nugkan pukuja, kaya aidaun utsantuk, 
\q1 uva ajake shiig pegkeg aidaun ajakui. 
\q1 Dutika peegkeg apaka, 
\q1 nunú aja ejapeen kumpinan jiika, 
\q1 vino najanatnunashkam umikui. 
\q1 Dutika umika uva yumimitun tsamakti tusa 
\q1 eke tsamachu asamtai, dakak pujau. 
\q1 Tujash nunú uva aidauk chujuinun tsamakui. 
\q1  
\v 3 Jerusalégnumia aidauwah, 
\q1 Judá aents aidauwah, 
\q1 nunú nunika dusha ¿yanawaita utugchatash, 
\q1 midaukait, atsa uva ajakbauwa nudaukait? 
\q1  
\v 4 ¿Uva chujuin ai tusan wi dutikmainush awak? 
\q1 Wika yumimitun nejekti tusan wakekabiajai, 
\q1 tujash ¿wagkag chujuinnash nejekiawa? 
\q1  
\v 5 Tuja midau uva ajakbauwa nunash, 
\q1 wisha itugkatag tajaki nuna yamai ujaktajime. 
\q1 Wika aunak ashí ijinatnume tusan 
\q1 kuitamtsuk idaisattajai, tuja utsaantuawag, 
\q1 najakag kupig ijinatnume tusan 
\q1 peejamua nunashkam tegajattajai. 
\q1  
\v 6 Dutikan pachitsuk idaisattajai. 
\q1 Tuja tuke nejen ati tusa, 
\q1 kanawe pegkegchau aidau tsupija utsanka 
\q1 pegkeg ematia nunash dutikachagtatui. 
\q1 Tuja dupanash takagsachagtatui, 
\q1 dutikamu asa dupa jagki aidaujai tsapaka 
\q1 akijuatnai. 
\q1 Tuja nuna uchupig pegkeg ematnunash 
\q1 yuminak yutumtijashtatjai. 
\q1  
\v 7 Tuke Pujuu ashí senchigtin uvan wakejus ajakua duka 
\q1 Israel aents Judá wegantujai aina nunuwai. 
\q1 Tuke Pujuuk mina chichamjun umigtuktinme 
\q1 tusa wakekauwai, 
\q1 tujash ditak magkagtin wajasu ainawai. 
\q1 Tuke Pujuuk shiig pegkeg dekaskenum takau atinme 
\q1 tusa wakekauwai, 
\q1 tujash ditak ima pegkegchaunak takaidaun 
\q1 Tuke Pujuu wainui. 
\c 6  
\s1 Apajuí Isaíasan chichaman etsegtugkati tusa etegkamu 
\p  
\v 1 Apu Ozías jakauwa nunú mijantin Apu Apajuí niina ekemsa inamtaiji shiig pegkegnum yakí eketun wainkabiajai. Tuja jega Apajuí emematku ijuntai jegamkamua nuna initkenak nii jáanch nugkuagbauwa nunú dukuka amayi.  
\v 2 Apajuí eketbaunum nuna yakin serafín aidau batsamayi. Maki makichik seis nanaptin agmayi. Jimag nanapega duwi yapin dukuaku agmayi, tikich jimaja duwi nawen dukuaku agmayi, tuja tikich jimaja duwi nanamiagmayi. 
\p  
\v 3 Tuja dita chichainak: 
\q1 “Tuke Pujuu ashí senchigtina duka shiig pegkegmai, 
\q1 tuja niina imanjiya nunú ashí nugkan jajutua awai”, wajagmayi. 
\p  
\v 4 Nunú Apajuín emematuinak imatuinamu, jega Apajuí emematku ijuntai waitiji aidaun senchi umuchmayi, nuniai nunú jeganum bukuituk yujagkim wajas asabi.  
\v 5 Imaniakui chichaakun: 
\q1 “¡Jajapi yamaik! Wagki wika pegkegchaun chichau wajasu, 
\q1 tuja aents pegkegchaun chichau aina nujai ijunjan pujag, 
\q1 nuniayatkunuap Tuke Pujuu ashí senchigtina nuna pan wainkaja”, tusan tibaijai. 
\p  
\v 6 Tusan tai makichik serafín wi wajamunum nanaak tantabi. Nunik minák altarnumian jii kaiji kapaun juki itanmayi.  
\v 7 Dutika duwi mina wenujun antinjuk chichagtak: 
\q1 “Nijah, juju jii kaiji amina wenimin antinjamkae. 
\q1 Juwi Apajuí amina tudaugminak esakatjamjae. 
\q1 Nuadui amina tudaugmek tsagkugnaje”, 
\m tujutmayi. 
\p  
\v 8 Tujutmatai pujai Apajuí chichaak: 
\q1 “¿Yanak awemainja? 
\q1 ¿Yaki iina chichamen etsegnush ati?” 
\m taun antukbaijai. Tusa takui wi ayaakun: 
\q1 “¡Mina awetita, wi amina chichamjumnak etsejin atajai!” 
\m tiabiajai. 
\p  
\v 9 Tusa tai nii chichagtak: 
\q1 “Wetá nunikam juju aents aidau aatsam ujakta: 
\q1 ‘Chichaman antuinakush 
\q1 nunap tawa tusag tichagtatui, 
\q1 tuja pan wainainakush dekachagtatui.’ 
\q1  
\v 10 Juju aents aina nuna dekatig pachimjukta, 
\q1 dutikakum antukchamin, wainmakchamin emakta, 
\q1 dutikamu asag wainmamainchau, antutnash antumainchau, 
\q1 tuja anentaimsash nunap tawa 
\q1 tusa dekamainchau wajastinme, 
\q1 nuninak pujutjinish yapajinmainchau atinme. 
\q1 Nunidau asagmatai, 
\q1 wishakam dita tudaujinak tsagkujashtatjai, 
\q1 tawai tita”, 
\m tujutmayi. 
\p  
\v 11 Tusa tujutkui wi niina iniakun: 
\q1 “Apuh, ¿tujash dusha wajupa tsawanta atatua?” 
\m tibaijai. 
\p Tusa tai nii aijak: 
\q1 “Yaakat aidaun tsainak 
\q1 ashí aents aidau ijinawajam agkan wajastina duwi, 
\q1 tuja jega aidaunmash makichik aents pujaukesh atsutna duwi, 
\q1 aja aidaunmash atsutna duwi, 
\q1  
\v 12 tuja Tuke Pujuu aents aidaun dita nugkenian 
\q1 jiija tikich nugkanum ishiakmatai, 
\q1 dita nugkega nunú aents atsau 
\q1 agkan juwaktina nunú tsawantin nagkankatnai. 
\q1  
\v 13 Tuja cien aents aidaunmaya 
\q1 diezkesh iwaku pujau akushkam ijina utsam agtatui. 
\q1 Dutika ashí ijinawagmataish, 
\q1 numi ajakam wajauti juwama numamtuk, 
\q1 ujumchik Israel Apajuín umijin aidau juwakagtinai. 
\q1 Nuwiya aidau numi ajakbaitak, 
\q1 wajauti ataktu jegama numamtuk wajakagtinai”, 
\m tujutmayi. 
\c 7  
\ms1 Emanuel pachisa agagbau 
\mr (7—12) 
\s1 Isaías apu Acazan yama nagkamchak ujakbau 
\p  
\v 1 Jotama uchiji, Ozíasa tijaji Acaz Judá aents aidaun apuji wajas Jerusalén pujai, Siria nugkan apuji Resín, Remalíasa uchiji Pécah Israel aents aidaun apuji aajakua nujai jimagtukag Jerusalégkan jetekajui, depetka iinu emami tusag. Tujash depetkachajui. 
\p  
\v 2 Dutika jeteagtai, Apu Acaz pujusa inamtaijin niina aentsji aidaujai pujuttaman jegajuawag ujainak: “Sirianmaya aents aidau Israel aents aidaujai jetepakagtatus ijunjaje”, tusa ujakajui. Nuna dekaa niina aentsji aidaujai ishamak kujainak, numi dase umpuam saatama imanidau. 
\p  
\v 3 Imaniagtai Tuke Pujuu Isaíasan chichajak: “Amina uchijum Sear-iasubjai weme apu Acaz igkugta. Duka Gihonnum yumi pukuni jiina nuwiya japiki aimkatin aepá juki yaki yumi aimtainum nain iwakbauwa nuwi ayaumas jáanch nijaku wetai jinta nagkaemakua nuwi igkugtatme. 
\b  
\p  
\v 4 “Nunika chichagkum: 
\q1 “ ‘Kuitamamkata, tujash ishamkaipa; 
\q1 apu Resín, apu Pécahjai shiig senchi kajenawai, 
\q1 tujash ishamkaipa, 
\q1 wagki ditak jii bukuituk wamak kajinama numamtin ainawai’, tita. 
\q1  
\v 5 Tuja sirianmaya aents aidau, Efraín aents aidau 
\q1 Remalíasan uchiji aatus amina 
\q1 mantamatatus chichaman umigtamkagmae. 
\q1 Nunik chichainak: 
\q1  
\v 6 ‘Judá aents aina duka uwaaka depetka utua 
\q1 Tabeelan uchijiya nunú apu adaitukmi’, tuinawai. 
\q1  
\v 7 Tujash Tuke Pujuu chichaak: 
\q1 ‘¡Duka makichkish nunikchattawai! 
\q1  
\v 8-9 Wagki Sirian yaaktaji dekas 
\q1 múunta duka Damaskui, 
\q1 tuja Resínkai Damascon apuji; 
\q1 tuja Efraín aents aina nuna yaaktaji 
\q1 dekas múunta duka Samariayai, 
\q1 tuja Remalíasan uchijiya nunuwai Samarian apuji. 
\q1 Tujash Efraín aents aidau ditash nugkentin aina nunak 
\q1 sesenta y cinco mijan jegai, depetkag 
\q1 nugke atankim nugkenchau juwakagtatui. 
\q1 Tuja atumshakam minai kajintsa 
\q1 anentaimkujum dekaskeapi tusajum, 
\q1 mina umigtachkugmek ijina utsam atatjume’, 
\q1 tawai Apajuí”, tiuwai Isaías. 
\p  
\v 10 Tuja nuigtushkam Tuke Pujuu Acazan chichajak: 
\p  
\v 11 “Ame dutikatnujum wainchatai aidau iwaintugkata tusam Tuke Pujuu amina Apajuíjum segata, tuja ame waji wakegame nunú nayaimpinmayagkesh nuniachkumesh nugka initkeniagkesh segatta, tusa tujamui”, tau. 
\p  
\v 12 Tusa tama Acaz ayaak: 
\p “Atsa make, wika Tuke Pujuun nuna segaakun pegkegchaunum dekaptanak dakitajai”, tiuwai. 
\p  
\v 13 Tutai Isaías chichaak: 
\q1 “Davitan patayi aidautijum antuktajum. 
\q1 ¿Aents atumin chichagtamu antugtsuk intimjakjum 
\q1 waitkajum duke nuniskek, 
\q1 Apajuíyaske waitkastasajum wakegajum? 
\q1  
\v 14 Nunin asagmin atumnak 
\q1 Apajuí nii dutikatnujin iwaintugmaktatui. 
\q1 Nunak: ¡Makichik nuwa muntsujut aentsu takashtai ejapjuktatui, 
\q1 nunik uchi aishmagkun uchigmaktatui, 
\q1 dutika uchigmakmatai, uchi daaji adaikattagme Emanuel!\f + \fr 7:14 \ft “Emanuel” tawa nunak: “Apajuík jutiyai awai” taku tawai.\f* 
\q1  
\v 15 Nunú uchi muumpak ashí anentaimama nuniak 
\q1 baka muntsuji kantemtikamun dapa yumijiyai yutinai. 
\q1  
\v 16 Tujash nunú uchik eke jintiag anentaimtan juwatsaig, 
\q1 jimag nugka múun amina uwaktamaina nuna tsaikagtinai. 
\b  
\q1  
\v 17 “Tuja duwi pujus tikich tsawantin amina, 
\q1 nuigtu amina aentsjum aina nuna, 
\q1 ame wegantu aina nuna aatus 
\q1 Tuke Pujuu suwimak ishamainun awetugmattawai. 
\q1 Dutikamtai yaunchuk Salomón apu pujusmatai, 
\q1 Israel aents aidau 
\q1 Judá wegantu aidaujai kanakajua duwi nagkamsaish, 
\q1 makichkish imanuk wainkachbau shiig ishamain atinai. 
\q1 ¡Duka asirianmaya apu niina suntaji aidaujai 
\q1 waitkagmasagtina nunuwai! 
\q1  
\v 18 Nunú tsawan jegatai, egiptunmaya suntag aidaun, 
\q1 kaapjai betek shiig kuashat, 
\q1 tuja nuigtu asirianmaya suntag aidaun dapa ishamain 
\q1 ijujatin aina imanun Tuke Pujuu ishitjamkatnai. 
\q1  
\v 19 Dutikam kaunak nugka ségaju aidaunum, 
\q1 uwejush aidaunum, kaya múun waa aidaunum, 
\q1 jagki tepaju aidaunum, 
\q1 tuja yumi baka umutai aina nuwi, aatus ashí piyaktinai. 
\q1  
\v 20 Nunú tsawantin namak Eufratesa amainia 
\q1 navaja ikamka itamaina numamtuk, 
\q1 Apajuí asirianmaya aents aidaun apujin 
\q1 niina suntaji aidaujai ikaunmatnai. 
\q1 Dutikam Israel aents aidau intashin, 
\q1 susujin, uje aidaunash ashí kesajug utsankagtinai. 
\b  
\q1  
\v 21 “Nunú tsawantinig makichkiuch bakan, 
\q1 jimagchik uwigjai apujus pujayatak, 
\q1  
\v 22 shiig kuashat nuna muntsujin 
\q1 ijuja juwau asa, nuna kantemtika yutinai. 
\q1 Tuja tikich aents maaniamunum uwemjau 
\q1 aidaushkam nunú baka muntsuji kantemtikamun, 
\q1 dapa yumijijai atsumkas yutin ainawai. 
\q1  
\v 23 Tuja mil uva ajakbaun akike 
\q1 mil plata aajakua duka ayatak jagki tsapaka 
\q1 ikam wajas asatnai. 
\q1  
\v 24 Nunú nugkanmak ashí jagki tsapaka akijua 
\q1 ikam wajasu asamtai, 
\q1 ayatak kuntin maatasa wekaetai atatui. 
\q1  
\v 25 Tuja nain tepetpetu aidaunum 
\q1 pegkeg takatai aajabia duka jagki wajastinai, 
\q1 imanikmatai ishamainak makichkish duka wechagtinai. 
\q1 Ayatak uwig aidau, baka aidau yutai wajastinai.” 
\c 8  
\s1 Isaíasan uchiji akiinatin pachisa etsegkamu 
\p  
\v 1-2 Tuke Pujuu chichagtak: “Sacerdote Urías, Jeberequíasa uchiji Zacaríasjai untsukta. Dutikam dita wainbaunum makichik numi dakakbau wegkajam jukim nuwi shiig pan wainmain: ‘Maher-salal-hasbaz’\f + \fr 8:1-2 \ft “Maher-salal-hasbaz” tawa juka hebreo chichamnumak, “Amujatkatnuk tsawantak ashí jegae” taku tawai.\f* tuu agagta” tujutiabi. 
\p  
\v 3 Tujutmatai nuna agajan pujusan tikich tsawantin mina duwajui uchi aishmagkun akiauwaitjai. Dutika ai Tuke Pujuu chichagtak: “Uchi daajig Maher-salal-hasbaz adaikattame.  
\v 4 Nunú uchik: ‘Apauch, awach’ tusagkesh eke chichatsaig, asirianmaya aidau yaakat Damasconak Samariajai mai tsaikagtinai. Dutikawag dita wajiji aidaunak ashí yajutkagtin ainawai”, tujutmayi.  
\v 5 Nuna tujuti ataktu Tuke Pujuu chichagtak: 
\b  
\q1  
\v 6 “Wika yumi aimkamu Siloé tutai 
\q1 chichigmachua nujai betek kakagchauchitag duwi 
\q1 juju aents Judá wegantu aina duka 
\q1 Siria apuji Rezínkan Israel aents aidaun apuji Pécahjai ishamainak, 
\q1 dita ayamjutpaktinme tuidau asag 
\q1 mina dakitjuinawai”, tiuwai. 
\q1  
\v 7 Nuadui ditanak Apajuí 
\q1 asirianmaya suntag aidaun ishitkattawai, 
\q1 dutikam namak Eufrates dujajak 
\q1 ashí utuja nugkan yumpuag eemak, 
\q1 nuwi ayaunak ashí utsauwama numamtuk ditanak utsagtatui. 
\q1  
\v 8 Imatikau asa Judá wegantu aidaunashkam 
\q1 waji nujagketkuish, ashí utuja suwega iman iwaktinai. 
\q1 Imatikak águilajai betek nanapen ayapatug 
\q1 ashí dukuk uwemainchau awajsatnai. 
\q1 Tujash jutiyaig Apajuí pujawai.\f + \fr 8:8 \ft “Jutijaig Apajuí pujawai” tawa duka hebreo chichamnumak “Emanuel” taku tawai.\f* 
\b  
\q1  
\v 9 Ashí aents nugka muunnum 
\q1 atushat batsamin aidautigmesh antuktajum, 
\q1 atum maaniami tusajum uminkugmesh wainkajum nuniktatjume; 
\q1 tuja maaniami tusajum 
\q1 maanitai aidau umiakjumesh 
\q1 ayatak sapigmaktatjume, 
\q1 nuniakjum ijinam atatjume. 
\q1  
\v 10 Atum waji dutikatag tajume duka umiktajum; 
\q1 tujash nunak Apajuí emegkaktatui; 
\q1 tuja atum waji dutikatasajum 
\q1 wakegagme dushakam chicham umiktajum, 
\q1 dutikakjumesh makichkish umikchattagme, 
\q1 wagki Apajuík jutijai pujawai.\f + \fr 8:10 \ft Juka versículo 8num tawa nujai betekai.\f* 
\s1 Tuke Pujuuwai ishamainuk 
\p  
\v 11 Minak Tuke Pujuu niina uwejen senchi achijuk emetjua chichagtak: “Tikich Judá aents aidau takaina nuninuk amek takasaipa”, tusa tujutmayi. Nuna tujuti nuigtushkam chichagtak: 
\p  
\v 12 “Apajuín shiig umijin aina nunak pempeenkagtuki sujujatna nuninuk chichagmain ainatsui. Nuadui atum ishamkatnume tusa ishamainun chichaina duka makichkish ishamkaigpajum.  
\v 13 Dekas Tuke Pujuu ashí senchigtina nunuwai, shiig pegkejam asamtai, ishamaku ajantusa diimaina duka.  
\v 14 Atumin shiig pujutan sujamna duka Apajuíyai. Tujash Israel aents aidauk Judá wegantu aidaujai nuna dakitjaje. Nunidau asag Apajuí suwimak susam Jerusalégnumia aidauk kaya múun tukumaina numamtuk tukumkag iyaidaun nunú kaya tepegkam nantamainchau wajasag jiniagtinai.  
\v 15 Kuashat aents atum ainajum anuiya kayan tukumak iyajag jinuidau agtinai. Tuja kuashat achija yajubaushkam agtinai.” 
\s1 Isaías niina jintintaiji aidaun anemtikak ujakbau 
\q1  
\v 16 Juju chicham Apajuínun wi etsejag nunú jintinkagtag nujai 
\q1 ashí agagjum shiig ijiajum uuka ukuktajum. 
\q1 Dutikajum tikich tsawantin jintinkagtuatatjum. 
\q1  
\v 17 Tuke Pujuu Jacopan kajejuk uumjuku akuish, 
\q1 wika ima niyaig kajintsan anentaimjai, 
\q1 nuniakun ima niinak dakajai. 
\q1  
\v 18 Mina daagnak, mina uchig aidaun 
\q1 Apajuí sujusbau aina nuna daaji aidaujai 
\q1 Tuke Pujuu ashí senchigtin muja Siógnum pujuuwa nunú 
\q1 Israel aents aidaun utugchatjin iwaintuktatus adaikamu ainaji. 
\q1  
\v 19-20 Tuja atumin chichagtamainak: 
\q1 “Ashí aents aidauk dita apajuímtaiji aidaun 
\q1 iniasag dekainawai. 
\q1 Nuadui atumshakam aents jakau aina nuna wakani, 
\q1 tuja anentaimsa dekaji tinu aina 
\q1 nujai iniasjum dekaatajum, 
\q1 atakea duish waji utugchatak nagkaetamkiajat”, tusag tujabiagtatui. 
\q1 Tujash atumek nuninuk antugkaigpa, 
\q1 duka shiig wainkayai. 
\q1 Atumek dekas Apajuí iniasjum dekaatajum. 
\b  
\q1  
\v 21 Tuja yumain atsutai, 
\q1 tikich nugkanum yujasag waituinak 
\q1 kajekag dita apujin, dita apajuímtaiji aidaujai 
\q1 pegkegchaun chichajiagtinai, 
\q1 nuninak ataktu yakí pagkaidiag niibiagtinai. 
\q1  
\v 22 Untsu nugká niimkama, ayatak waitut, suwe, 
\q1 buutut, wake besemag ayaun wainkagtinai, 
\q1 iman suwenum ditak pujusagtinai. 
\c 9  
\q1  
\v 1 Tujash imanik waituinak wake besemag 
\q1 batsabiagtina duka tuke achatnai. 
\s1 Agkan pujutan sukagtin akiina apu wajas inamjatin 
\p Tuja Sabulógka nugkeg Neftalí nugkejai mai Galileanum aents Apajuín nemagchau aidau batsata nuna ijus awai. Nunú nugkak, namak Jordágka amain nagkamnas nayantsanum jegaa nagkanui. Tuja yaunchuk nunú aidaun Apajuí suwimkan susa ijinauwai. Tujash duwi batsamas ataktu Apajuí anenken wainkau ainawai. 
\p Nunú nuniktinun Isaías pachis etsejak: 
\b  
\q1  
\v 2 “Aents aidau suwenum yujau agma nunú tsaaptinun wainkaje; 
\q1 tuja suwenum batsatunashkam tsaaptin etsantug iyanjae. 
\q1  
\v 3 Apuh, aents aidauk kuashat uyugkaume, 
\q1 tuja shiig aneamushkam múun awajsaume. 
\q1 Nuadui ajak juwamunum shiig aneen aina numamtuk, 
\q1 amina emtimin shiig aneasagtin ainawai. 
\q1 Tuja wiakuch wajiin akantuninak 
\q1 shiig aneen aina numamtuk shiig aneasagtinai. 
\q1  
\v 4 Wagki aents aidau inaku waitkatai wajasag 
\q1 waitu batsamaya duka ame agkanmitkaume. 
\q1 Dutikakum Madián wegantu aidau tsaikuitam dutiksamek 
\q1 yamaishkam ijina utsagkam agkanmitkaume. 
\q1  
\v 5 Tuja suntag aidau maaniatatus shimuinak 
\q1 botasjin wakugtin aajabia duka, 
\q1 jáanchji numpamkamu aidaujai jinum apeam utsankatnaitme. 
\q1  
\v 6 Wagki iinak makichik uchi akiintugmae, 
\q1 Apajuí iinak makichik uchin amase. 
\q1 Nunú uchia nunuwai apu ati tusa etegkamua duka. 
\q1 Nuadui niina daaji aidauk: 
\q1 ‘Shiig chichagkagtin’, 
\q1 ‘Apajuí senchigtin’, 
\q1 ‘Apajuí tuke Pujuu’, 
\q1 ‘Agkan pujutan apuji’ tutai atinai. 
\q1  
\v 7 Nunú uchik apu David inamaajakua nuwi pujus 
\q1 ashí nugkanum inamjatnai. 
\q1 Nuniau asamtai agkan pujuta duka tuke atinai. 
\q1 Tuja nii inabaujig shiig emetjamu atinai, 
\q1 nii inabaujinig shiig takamu, ajantunisa niiniamu atinai. 
\q1 Nunak Tuke Pujuu ashí senchigtina nunú 
\q1 iina anempau asa dutikatnai.” 
\c 11  
\s1 David wegantunmaya apu wajas agkan pujutan sukagtustinai tibau 
\q1  
\v 1 David wegantuk numijai betek ajaka ajuamu atatui, 
\q1 tujash nuna wajautinia yamajam jeeka tsapaitnai. 
\q1  
\v 2 Nunikmatai Tuke Pujuu Wakani niyai pujus 
\q1 unuimatan, shiig anentaimtan, senchimetan, 
\q1 tuja Apajuín shiig wainu asamtai, 
\q1 puyatjus umigtan susatnai. 
\q1  
\v 3 Nunú apuk aentsnak ayatak diisagkek 
\q1 suwimkanak susashtinai, 
\q1 tuja nuigtush ayatak chichaman antamuikik, 
\q1 nuni ati tusag chichamnak iwajachagtinai. 
\q1  
\v 4 Aents kasagtai aidau, 
\q1 ujudauch aidaujai waitkam batsata nuna ayamjuktinai, 
\q1 dutikak untsu aents magkagtin, 
\q1 pegkegchau aidaunak suwimkan susa ijinatnai. 
\q1  
\v 5 Niig pegkeg takatan 
\q1 dekaskea nujai ayamjak maanitkatnai. 
\q1  
\v 6 Tuja nunú tsawan jegamtaig, 
\q1 lobo uwigjai ijunag pujuagtinai; 
\q1 ikamyawa chivojai ijunag kanitnai, 
\q1 untsu baka leónjai ijunag wekagas tsakagtinai, 
\q1 tuja uchi aidau nuna yutaijin ayujuinak yajuak awekaidiagtinai. 
\q1  
\v 7 Tuja baka nuwa, chayú nuwajai shiig kumpaji agtinai, 
\q1 tuja uchiji aidaushkam nujai ijunag kajiitnai, 
\q1 tuja leónshakam bueyejai ijunag chijichin yuwagtinai. 
\q1  
\v 8 Tuja uchi piipich aidaushkam dapijai wasugkabiagtinai, 
\q1 dapi pasugken pujaunash inua achiagtinai. 
\q1  
\v 9 Nunú tsawantinig Tuke Pujuu mujanum puja nuig 
\q1 pegkegchau awajkagtumainuk makichkish atsutnai, 
\q1 wagki yumi nayantsanum pima numamtuk, 
\q1 Tuke Pujuu imanjinak ashí nugkanum dekawagtin ainawai. 
\c 28  
\ms1 Israel aents aidau pachisa kuashat agagbau 
\mr (28—35) 
\s1 Yaakat Samaria tsainkattawai tusa etsegkamu 
\q1  
\v 1 ¡Chah, Samariayah, 
\q1 amina nugkemek pegkeg 
\q1 shiig tsapau wajasuitam duwi, 
\q1 Efraín aents nampen aina duka aminí ememainawai! 
\q1 Untsu atumi apujig yagkug pegkejuch aidau 
\q1 kagaka megkagama numamtuk megkagainawai. 
\q1 Samarianmak ima aents nampen aina duke piyak awai. 
\q1  
\v 2 Makichik aents senchigtin 
\q1 Tuke Pujuu etegkamu pujawai, 
\q1 niina senchijig bicha kakegak ishamain wajama imanai, 
\q1 tuja dase senchi dasentak magkagtina iman, 
\q1 yumi senchi yutug, nujag pimak ijijatna imanai. 
\q1 Iman asa samarianmaya aents 
\q1 aidaunak makichkia shitamuik ajuattawai. 
\q1  
\v 3 Dutikak Efraín wegantu nampen wajasu aidau, 
\q1 yaakat Samaria pegkeg asamtai, 
\q1 emema batsata nunak nii tsaika ajapatnai. 
\q1  
\v 4 Dutikamtai nunú nugka pegkegnum 
\q1 yagkug kagaku ayá duka, 
\q1 higo tsamajun aents ajantutsuk akaka yuwa 
\q1 amuwama numamtuk awajam agtatui. 
\q1  
\v 5 Untsu nunú tsawantin aents niina umijin aidau 
\q1 iwaku juwagtina nuna atsejutaiji, dekas pegkeg atina duka, 
\q1 Tuke Pujuu ashí senchigtina nunuwai. 
\q1  
\v 6 Tuja apu chichama epegkin aidaunashkam 
\q1 Apajuí shiig takau emaktinai, 
\q1 tuja suntag yaaktan kuitamin aidaunash wajiumitkaktinai. 
\s1 Jerusalégnak tsaikagtatui tusa etsegkamu 
\q1  
\v 7 Tuja profeta aidaushkam sacerdote aidaujai, 
\q1 senchi vinon umuidau asag, 
\q1 nampejag winchainainak tukumak iyá yujawai; 
\q1 imanik nampedau asag, 
\q1 Apajuí chichamenak antukchamin batsatui. 
\q1  
\v 8 Nuadui dita mesajinig 
\q1 ayatak tsumain iyakbau ayawai, 
\q1 makichkish iyaka tsuwapachbauk atsawai. 
\q1  
\v 9 Tuja mina chichagtuinak: 
\q1 “¡Taata nunikam aminash Apajuísh 
\q1 wajina iwaintugmake, nunú uchi piipich 
\q1  
\v 10 papii augchau unuimagti 
\q1 tusa a, ba, cha, da, jintinmaina numamtuk 
\q1 jintinkagtuata!” tusa dushiktuinawai. 
\q1  
\v 11 Tuja atumek nampekjum 
\q1 pegkegchau chichá batsatu asajum, 
\q1 chicham antut dakitau asagmin, 
\q1 aents tikich chichaman chichaaku aidau 
\q1 amuktinme tusa Apajuí idaitamsattawai. 
\q1  
\v 12 Yaunchuk Apajuí chichagtamainak: 
\q1 “Juwig utugchatak atsawai, juwi ayamainaitjume, 
\q1 aents pimpikiuk ayamsati”, tusa tujabiuwai. 
\q1 Tujash atumek tusa tujamaig antugkachuitjume. 
\q1  
\v 13 Nuadui Tuke Pujuu atumnak 
\q1 uchi piipich papii augtan unuimagti tusa 
\q1 chichagmaina numamtuk chichagtamkattawai. 
\q1 Uchi piipich yama wekagama numamtin atatjume, 
\q1 nunin asajum tuntupmin iyagjum, 
\q1 najaimakjum nantakchamin dekaptatjume. 
\q1  
\v 14 Atum datsantainchau aidau 
\q1 Jerusalégnum apu wajasjum, inamak batsatu aidautijum 
\q1 Tuke Pujuu tujama nunú antuktajum. 
\q1  
\v 15 Atum chichaakjum: 
\q1 “Ii aidautik jinau aidaujai chicham umikji”, tajume. 
\q1 Tuja atumek asirianmaya suntag aidau ishamakjum 
\q1 iwanchnum sujumankaugme, nii kuitamjamkati tusajum. 
\q1 Nuniku asajum, chichakjum: 
\q1 “Iinak makichkish mantamainchau ainawai, 
\q1 wagki nunú iina shiwaaji aidaunak 
\q1 tsanuja dushijattawai”, tajume. 
\q1  
\v 16 Nuadui Tuke Pujuu chichaak: 
\q1 “Siógnum makichik kaya etegkamu shiig pegkeg akikan apusattajai, 
\q1 nunú atatui dekas ima eme anentsa diitai. 
\q1 Nunú kayanum ekeni jegamnaktatui. 
\q1 Nunú kayanum kajinas anentaimaidauk 
\q1 shiig agkan batsamsagtinai. 
\q1  
\v 17 Nunú jegamku, tunin ai tusa 
\q1 plomo nená diitia numamtin 
\q1 atatui shiig takamua nunú. 
\b  
\q1 “Atumek egiptunmaya aidau 
\q1 ayamjutpaktatui tajume, 
\q1 tujash ditanak asirianmaya suntag senchigtin aidau 
\q1 namak dujajak tajaka ajapama numamtuk ijinawagtinai.” 
\c 30  
\s1 Egiptunmaya aents aidaun emematin aidau pachisa etsegkamu 
\q1  
\v 1 Tuke Pujuu chichaak: 
\q1 “¡Chah, mina uchig intimkiu aina nunak, 
\q1 wait anentuinajai, wijai chichatsuk, 
\q1 wi inachmaitak dita wakegamun takasagtatus chichaman uminawai! 
\q1 ¡Nuninak aan kuashat tudaun utuatmamainawai! 
\q1  
\v 2 Tuja mina inintsuk Egipto nugka apuji 
\q1 ayamjutpakti tusag pisajuinawai. 
\q1  
\v 3 Tujash Egipto nugka apujig, 
\q1 wi ayamjuktajime tiuwaitak, 
\q1 ditanak ayamjukchattawai, 
\q1 dutikam egiptunmaya aidaunum yunumka uwemjami tukama datsajagtatui. 
\q1  
\v 4 Israel aents aidauwah, 
\q1 Soán nugkanum yaakat ayá imanui, 
\q1 tuja yaakat Hanés tutaya imanuishkam 
\q1 aents atumin chichamjutpaktin aidau ishiaku akugmesh, 
\q1  
\v 5 nunú nugkanmaya aidauk atumnak tsanupajagtatui, 
\q1 ditak makichkish yaimpakchagtatui, 
\q1 ayatak utugchatan itagtamawagmatai, 
\q1 waitiakjum datsagtatjume”, tiuwai Apajuí. 
\b  
\q1  
\v 6 Tuja Isaías chichaak: “Juna Apajuí aatus tawai: 
\q1 ‘Israel aents aidauk egiptunmaya aents aidau 
\q1 ayamjutpaktinme tusag dita wajiji aidaun, 
\q1 dita burrojin, camellojin aatus patag yajuakag, 
\q1 Néguev nugka ishamain, león aidau, 
\q1 dapi aidau, dragón nanamtin aidau 
\q1 aatus ayamunum shimuinawai, 
\q1  
\v 7 tujash egiptunmaya aidauk 
\q1 kakagmachu tikima wainkauch ainawai. 
\q1 Nuadui dita daajinak: 
\q1 “Kuntin múun shinakush wainak imatin” 
\q1 tuu adaikauwaitjai’ tawai Apajuí”, tiuwai Isaías. 
\q1  
\v 8 Tusa inagnakmatai Apajuí Isaíasan chichajak: 
\q1 “Wi timag nunú yamai numi pakama najanamunum agagta, 
\q1 atakea duwish wi tibauwa nuna tuke adeagtin atinme”, tiuwai. 
\q1  
\v 9 Tusa tima Isaías chichaak: 
\q1 “Israel aents aidauk intimkiu asag, 
\q1 Tuke Pujuu chichame umiktin agagbauwa 
\q1 nunú umitnak dakituinawai. 
\q1  
\v 10 Nunidau asag Apajuí chichamen etsejin 
\q1 profeta aidaun chichajuinak: 
\q1 ‘Yamai nagkamsagmek atum kajanum wainkamu aidauk etseju yujaigpa. 
\q1 Tuja chicham pegkeg dekaskea dushakam ujajatkaigpa; 
\q1 duka idaikujum dekas nugkaya waji pegkeg aidau ayá 
\q1 nunú ujajatkatajum. 
\q1  
\v 11 Tuja jinta pegkegnum atum wegajum duka idaisatajum, 
\q1 nuniakjum ataktu awagkigmek, 
\q1 Israel aents aidaun Apajuíji pegkegma nunú 
\q1 pachisjumek aujkagtusaigpa’, tuinawai. 
\q1  
\v 12 Nuadui Israelan Apajuíji pegkegma nunú chichaak: 
\q1 ‘Atumek ujamash dakitagme, 
\q1 nuniakjum ayatak pegkegchau, magkagtut, 
\q1 waitjut aina nunú takatnum eme anenmamjume. 
\q1  
\v 13 Nuadui atumek atumi tudaugmin 
\q1 nugka peegmagbau pachiachbau yumpuna 
\q1 iyauwama numamtin ainagme. 
\q1  
\v 14 Tuja ichinak najanamu ashí tsainak ajapnamtai, 
\q1 jii kaijigkesh chimpia jumainchau, 
\q1 tuja yumikesh shikimainchau wegama numamtuk, 
\q1 Apajuí ditanak ashí tsaika emegkagtatui.’ 
\q1  
\v 15 Nuadui Tuke Pujuu Israel aents aidaun Apajuíji 
\q1 pegkegma nunú chichaak: 
\q1 ‘Ataktu mina umigtuktajum, 
\q1 nuniakjumin wi senchimtikattajime. 
\q1 Tuja dekas minai kajintsajum anentaimkugmek, 
\q1 wainkajum chichá batsamtsuk takamtak batsamsatajum, 
\q1 nuniakjum uwemjattagme’, tujamui. 
\q1 Tujash atumek nunú dakitau asajum, 
\q1  
\v 16 chichaakjum: 
\q1 ‘Atsa, dekas caballonum, ekemi pisajagmi’, tajume. 
\q1 Kame takugmek pisagtajum. 
\q1 Tuja nuigtushkam chichaakjum: 
\q1 ‘Carronum egkemja pisagmi’, tajume. 
\q1 Kame takugmek nuniktajum, 
\q1 tujash atumin aintamaidau ima senchi tupikainau 
\q1 asag amaintamkagtatui. 
\q1  
\v 17 Nuadui makichik aents awanmaig, 
\q1 nuna ishamainak mil aents pisajagtatui. 
\q1 Tuja cinco aents awanmakuig nunú ishamakjum, 
\q1 atumek ashí pisagtinaitjume. 
\q1 Nunikagmin ujumchik juwakag, 
\q1 makichik numi mujanum ajiamu wajama numamtuk, 
\q1 tuja mujanum numi ajiamunum bandera jiikbau 
\q1 makichik wajama numamtuk juwaktatjume. 
\s1 Apajuí Israel aents aidaun uwemtijatin 
\p  
\v 18 “Untsu atum tsagkugnagtin tsawan jegamtai, Tuke Pujuu atumin wait anenjamag atumi tudaugmin tsagkugtamjattawai. Apajuík niina anenken iwaintugmaktatus wakegawai, wagki niig pegkegchaunak dakitin asa, ima pegkeja nunak takauwai. ¡Nuadui Apajuíyai kajinas anentaimaidauk shiig aneasagtin ainawai!” tiuwai Isaías. 
\c 31  
\s1 Egiptunmaya suntag aidau ayamjutpakagtatui tinu aidau pachisa ujakbau 
\q1  
\v 1 Egipto nugkanmaya aidaun caballoji maanitai aidau kuashat, 
\q1 tuja carrojishkam imanisag asagmatai, 
\q1 Israel aents aidauk dita yaimpaktinme tusag 
\q1 shimutuina nunak wait anentuinajai, 
\q1 wagki Israel aents aidau ememattai 
\q1 Tuke Pujuu pegkegma nunú yaimpakti tusag, 
\q1 niina segamainun idayinak wainak yujau asagmatai. 
\q1  
\v 2 Tujash Apajuík makichkish tsanushtayai, 
\q1 iman asa suwimkan sukagtinai, 
\q1 tuja nii dutikatjai tibaun yapajiag idaichauwai, 
\q1 betek uminai. 
\q1 Apajuík aents pegkegchaun takau aidaun 
\q1 yayaunak suwimkan susa ijinatnai. 
\q1  
\v 3 Egiptunmaya aidauk Apajuíchu ainawai, 
\q1 ditak aents ainawai; 
\q1 tuja caballoji aidaushkam iyashtin ainawai, wakankesh ainatsui. 
\q1 Tuke Pujuu ditanak suwimkan susattawai. 
\q1 Nuadui Israel aents aidauk ya ditan ayamjawa 
\q1 nujai betek suwimkan jukiag jinawagtatui. 
\q1  
\v 4 Tuja Tuke Pujuu chichagtak tujutmae: 
\q1 “León uwijan maamtai, uwijan kuitamin aidau tuwakag, 
\q1 senchi untsumkag leónkan uwakatajtakush 
\q1 uwakmainchau ainawai. 
\q1 Numamtuk Tuke Pujuu ashí senchigtina nunú taattawai muja Siógnum 
\q1 niina aentsji aidaun ayamjuktatus. 
\q1  
\v 5 Tuja chigki nanaak wekagas 
\q1 niina uchijin kuitamama numamtuk, 
\q1 Tuke Pujuu ashí senchigtina nunú 
\q1 Jerusalégnak kuitamak uwemtikattawai, 
\q1 dutika ayamjuk agkanmitkattawai.” 
\q1  
\v 6 Nuadui Israel aents aidauwah, 
\q1 atum tudau, chicham imtimkiu akugmesh, 
\q1 ataktu Apajuí umigkatajum. 
\q1  
\v 7 Wagki atum aidautijum, 
\q1 oro, plata aidaujai atum dakumka najanamu aidau 
\q1 emematjum nunú idaisagminig, 
\q1  
\v 8 asirianmaya aents aidauk ijina utsam agtatui, 
\q1 tujash nunak aents aidauk ijinashtatui, 
\q1 ayatak maaniamun ishamainak pisajagtatui, 
\q1 tuja datsauch maanitan yacha aidaush 
\q1 wainka inaku waitkatai wajasagtatui. 
\q1  
\v 9 Tuja dita apujig nuna ishamak tupikaki jiinkittawai, 
\q1 tuja suntaja apuji aidaushkam banderajinak ukuinak pisajagtatui. 
\q1 Tuja junashkam Apajuí chichaak: 
\q1 “Niina shiwaaji aidaun suwimak susatnujig 
\q1 Jerusalégnum umikbau awai”, tawai. 
\c 32  
\s1 Makichik aents apu wajas pegkegnum inamjatin 
\q1  
\v 1 Makichik aents apu atinai 
\q1 pegkegnak inamjatin, 
\q1 tuja nuna atuwe aidaushkam 
\q1 shiig takasagtin ainawai. 
\q1  
\v 2 Aents aidauk shiwag jeteamash, 
\q1 tuja utugchatnum jegainakush, 
\q1 tuja pegkegchau takainak waitkainamash, 
\q1 nunú apu aidau shiig takaidau asagmatai, 
\q1 ditai yunumak ayamjumaktin ainawai. 
\q1  
\v 3 Nuadui Israel aents aidauk 
\q1 wainmachu wainmamaina numamtuk 
\q1 Apajuínak pan wainkagtinai. 
\q1 Nuninak Apajuí chichamesh wajintua 
\q1 nuna puyatjus antuktatus wakeyagtinai. 
\q1  
\v 4 Nuadui waugtutsuk emamkemas takasagtatui, 
\q1 nuninak dekaskea nuna shiig antumainun chichagtatui. 
\q1  
\v 5 Aents pegkegchau, tsanumin aina duka 
\q1 eme anentsa diyam achagtinai. 
\q1  
\v 6 Wagki aents pegkegchauwa duka 
\q1 ima pegkegchaunak chichawai; 
\q1 tuja niina anentainish ayatak pegkegchau takatnak anentaimui; 
\q1 nuniak magkagtuta nuna wekaetawai, 
\q1 tuja Apajuínash tsanumjuinak pegkegchaun 
\q1 chichajuinawai; 
\q1 nunidau asag aents nujantai waitiaunash, 
\q1 tuja kitakai waitiaunashkam ajampenatsui. 
\q1  
\v 7 Aents waitjin aina nuna ayamjumataijig ishamainai; 
\q1 tuja pegkegchau takastinun niina anentain umiawai; 
\q1 Nunin asag ujudauch aidau chichamjumak, 
\q1 ayamjumamainchaunak tsanumjug, 
\q1 apunum sujuk waitkainawai. 
\q1  
\v 8 Untsu aents pegkeg aidauk tikichnash yaigtatus wakenai, 
\q1 nuadui niina pegkegjinig shiig anentam atinai. 
\s1 Jerusalégnumia nuwa aidau chichagkamu 
\q1  
\v 9 Atum nuwa daki batsamtin 
\q1 puyatmamchau aidautijum, 
\q1 wi titatjim nunú antuktajum. 
\q1  
\v 10 Atumek yamaik puyatmamtsugme, 
\q1 tujash kuashat tsawan atsuk, yumain atsakui, 
\q1 tuja uva juuka yumainkesh atsakui, 
\q1 makichik mijan nuigtu ewaekajum waitiakjum kujaittagme. 
\q1  
\v 11 Nuwa aidautijum puyatmamtsuk 
\q1 shiig aneasa batsatutigmek puyatakjum kujaitajum; 
\q1 tuja atum pachimakas pujautigmek sapigmakjum kujaitajum. 
\q1 Nuniakjum jáanch pegkeg 
\q1 nugkuagjum duka awika ukuakjum, 
\q1 wake besemag pujaku nugkutai nugkugtajum. 
\q1  
\v 12 Atumdau trigo ajakbau, uva ajakbau aidaujai 
\q1 shiig kuashat pegkeg ayá 
\q1 duka imankek achattawai. 
\q1 Nuadui wake besemag dekapeakjum 
\q1 detsepem ijutajum. 
\q1  
\v 13 Mina nugkag múunta nuwig jagki aidau 
\q1 ashí tsapak akijuattawai, 
\q1 tuja jega pegkejuch aidau yaaktanum ayá nuwi batsamsajum, 
\q1 shiig anee batsatjum duka ashí tsaikam megkaejattawai. 
\q1  
\v 14 Tuja apu pujusa inamtaijishkam ukukim 
\q1 itajak juwaktatui; 
\q1 yaakat muunchakam ukukim agkan juwaktatui. 
\q1 Tuja kumpin jiikbau aidaushkam, 
\q1 yaakat tentea peejamu aidaush, ashí ukukim agkan juwagtatui. 
\q1 Nunikmatai ikamia burro aidau, 
\q1 baka aidau nuwi batsamsagtinai. 
\b  
\q1  
\v 15 Tujash Apajuí ashí waji aidaun 
\q1 najankauwa nuna senchiji ataktu tajutjamattawai, 
\q1 nuniak uwegshunak nugka pegkeg 
\q1 ajak ajakmamain awajsattawai, 
\q1 untsu nugka pegkeja duka yaunchuk aajakua 
\q1 nuna nagkaesau shiig pegkeg wajastatui. 
\q1  
\v 16 Nunikmatai juju nugka múunta juwig 
\q1 ashí yantamnum pegkeja duke takamu atatui. 
\q1  
\v 17 Tuja pegkeg takamua nunuwai atakesh maanitsuk agkan, 
\q1 kajinmamsa pujutan sukagta duka. 
\q1  
\v 18 Nuadui mina aentsug aidauk waitkascham 
\q1 agkan dita jeen puyatkas shiig batsamsagtinai. 
\q1  
\v 19 Bicha kakegak ikaman ijinau akuish, 
\q1 tuja yaakat tsaikbau akuish, 
\q1  
\v 20 ¡atumek yumi ayaunum ajakmajum, 
\q1 nunú yuwakjum pujustinaitjume, 
\q1 tuja burro aidaush, baka aidaush 
\q1 chijichi ayaun yuwinak agkan batsatkui, 
\q1 shiig aneasjum pujustinaitjume! 
\c 33  
\s1 Apajuíyai uwemtak awai 
\q1  
\v 1 Wait anentagme aminak, 
\q1 wagki amek tikich nugkanmaya aidau 
\q1 tsainaitkum tsaikchamuitme, 
\q1 nuigtush amek tikich nugkanmaya aidau 
\q1 tsanuwaitkum tsanugchamuitme. 
\q1 Nuadui amujatut idaisa pujamin, 
\q1 aminashkam tikich nugkanmaya aidau tsaipakagtinai, 
\q1 tuja tsanujatut idaisa pujamin, 
\q1 tikich nugkanmaya aidau tsanupajagtinai. 
\q1  
\v 2 Tuke Pujuuwah, 
\q1 niimpap yaimpaktatua tusa 
\q1 aminig anentaimaidautik wait anenkagtugta. 
\q1 Nuniakum tuké kashikmasam yaijatta, 
\q1 tuja ishamainnum jegamunmash ame uwemtikagtugta. 
\q1  
\v 3 Amina chichamjumin antukag ishamainak, 
\q1 tikich aents aidauk pisainawai, 
\q1 tuja yaakat muunnumia aidauk 
\q1 amina senchijum iwainamun wainainak, 
\q1 ishamkag pampagkag megkagainawai. 
\q1  
\v 4 Nuniagtai dita shiwaaji aidau 
\q1 manchijai betek yumpuntuk utsantuawag, 
\q1 dita wajiji aidaunak ashí yajutuinawai. 
\q1  
\v 5 Tuke Pujuuwai dekas múuntak, 
\q1 niig nayaimpinum pujawai; 
\q1 Jerusalégnumia aidaunak pegkejan takainak, 
\q1 esegag pujustinme tiuwai. 
\q1  
\v 6 Nuadui shiig pujustinme tusa tuké kuitamtinai. 
\q1 Unuimata duka dekata nujai uwemtan sukagtau asa, 
\q1 waji pegkeg aidaun nagkaesauwai. 
\q1 Tuke Pujuu puyatjusa umigbauwa nunuwai 
\q1 waji pegkeg akik aina nuna nagkaesau. 
\q1  
\v 7 ¡Suntag wajiu aidau tikich yaimpaktinme tusag, 
\q1 jintá yujas untsumainawai, 
\q1 tuja agkan pujutan chichaman etsejin 
\q1 aidaushkam kajekag buutuinawai! 
\q1  
\v 8 Jinta aidauk bashiake, 
\q1 makichkish jintanmak yujainatsui, 
\q1 tuja jutijai chichaman umikajua nunash uminatsui; 
\q1 nuadui ajantunisa niniamush atsawai. 
\q1  
\v 9 Israel aents aidaun nugkega duka ajak aidau tsapaachu asamtai, 
\q1 wake besemag wajas awai. 
\q1 Líbano aidaush datsaamainak jajatuk jinawai; 
\q1 tuja nugka paka Sarón tutaya dushakam 
\q1 yaunchkek pegkeg ajak shiig tsapaya nunak 
\q1 yamai uwegshujai betek wajase. 
\q1 Tuja Basán nugka, muja Carmelo tutaya nujai 
\q1 nugka pegkeg numi dukentin ayau asa, 
\q1 pegkeg samekbau wajas ayá duka duke kakekamtai, 
\q1 wentsamtuk ijunui. 
\q1  
\v 10 Nuadui Tuke Pujuu chichaak: 
\q1 “Wi yamai nantagkitjai; 
\q1 nuniakun ashí mina senchijun iwainaktajai. 
\q1  
\v 11 Tuja atum chicham umiamua duka 
\q1 dupa kagakujai betek, 
\q1 nuigtush tsuwatjai betek ainawai. 
\q1 Nunin asamtai wi umpuamua nunú 
\q1 nunak jiijai betek ekemak ajapattajai. 
\q1  
\v 12 Nuadui aents aidauk jagki tsupigbau akaam 
\q1 keegama numamtuk keeka yuku wajasagtatui. 
\b  
\q1  
\v 13 “Atushat pujautigmek, 
\q1 wi dutikauwaitag nunú dekatajum, 
\q1 tuja tikiju pujautigmeshkam, mina senchijua nunú dekaskeapi titajum.” 
\b  
\q1  
\v 14 Aents pegkegchau aidau Jerusalégnum 
\q1 batsata duka sapijin kujainawai, 
\q1 tuja aents Apajuín umigchau aina dushakam sapigmainawai. 
\q1 Nuninak: “¿Ii ainag nuwiyash yaki jii kajinchau 
\q1 tuke kee auwa ibaunmash pujusainta?” 
\q1  
\v 15 Aents pegkejan takau, dekaskenum chichau, 
\q1 tuja tikichin atanki yajutuk wiakchameuchu, 
\q1 tuja akikam yaimchau, 
\q1 magkagtuata tusa tamash dakitin, 
\q1 nuigtush pegkegchaunak makichkish anentaimtuchu, 
\q1  
\v 16 nunú aentsuk waitkascham agkan pujustinai. 
\q1 Niina jeeg utumainchau kaya jegamkamu atinai. 
\q1 Tuja nii yuwatnujish uwagtinjish ashí ajitnai. 
\q1  
\v 17 Tuja ataktu wainkatnaitme 
\q1 apu niina imanjin etsantug tsaaptin wajas eketu. 
\q1 Niig atushat tikich nugka aidaunmash inamjatnai. 
\q1  
\v 18 Ame yaunchuk sapigmayum nunú anentaimtusa chichaakum: 
\q1 “Apu kuichkiji atin akikmakbau aidaun dekapainak, 
\q1 akikmaktajum tusa 
\q1 waitkagmayanum dusha ¿tuwi batsatua? 
\q1 ¿Tuwi batsatua ajak juukbau aidaun 
\q1 dekapau aajabia dusha? 
\q1 Iina uchiji aidaun suntagmagatnume tusa 
\q1 achija yajutjamianum dusha ¿tuwi batsatua?” titinaitjume. 
\q1  
\v 19 Aents pegkegchau tikich chichaman antumainchaun 
\q1 pachimtakan chichaaku aidaujai ijunjajum 
\q1 pujajum duka yamaik nunikchattagme. 
\q1  
\v 20 Jerusalégnum jega Apajuí emematku ijuntainum 
\q1 ijunja jiistamnuweg nunú anentaimtusam diista; 
\q1 Jerusalégkak aak shiig aakmagbau yumpumainchau 
\q1 numi ajigbaush kupimainchau, tuja 
\q1 daekai jigkakbaush tsujimainchauwama iman atinai. 
\q1  
\v 21 Nuwi Tuke Pujuu niina imanjijai iina wantintugmawai. 
\q1 Jerusalégnumak namak múun chichijam aidau ayawai. 
\q1 Namak iman agtaish, shiwag aidauk 
\q1 dita lanchaji wiyanka wekaetai aina duikish, 
\q1 tuja lanchaji múun aina duikish kakajus utuachagtinai. 
\q1  
\v 22 Wagki Tuke Pujuuwai iina ayamjutpa duka, 
\q1 tuja ii umiktinnak nii chichaman sukagtawai. 
\q1 Niyai iina apujig, iina uwemtijamin. 
\q1  
\v 23 Nunú lanchanum numi ajiamu aidau 
\q1 jigkakbauwa duka daekak takatkae, 
\q1 nuniku asamtai jáanch detuamua duka 
\q1 pukugak iyaumain wajawai. 
\q1 Nunitai wemainchau dekapenakui, 
\q1 lanchajin utsaantua wajiji aidau yajutkagtatji, 
\q1 dutikajin aents shutuu ai aidauwaske 
\q1 dita wajiji aidaunak yajuakagtatui. 
\q1  
\v 24 Tuja Judá wegantu aidaun tudaujinak 
\q1 Apajuí tsagkujatnai, 
\q1 nuadui makichik aentskesh: 
\q1 “Jajai”, tusa tauk atsutnai. 
\c 35  
\s1 Israel aents aidau Jerusalégnum waketjamu 
\q1  
\v 1 Uwejush ajak ajakmamainchau 
\q1 buku wajas awa duka 
\q1 nugka pegkeg wajastatui, 
\q1 nunik ajak aidau tsapatai, uwegshuk aents 
\q1 shiig aneemaina numamtuk shiig aneastatui. 
\q1  
\v 2 Nunik ajak aidau kuashat tsapakmatai, 
\q1 uwegshuk shiig aneas senchi kantamtatui. 
\q1 Tuke Pujuuwa nunú uwegshunak, 
\q1 Líbano nugka, Carmelo nugka, 
\q1 Sarón nugka pegkeg aina iman awajsattawai. 
\q1 Dutikamtai ashí aents aidauk 
\q1 iina Apajuíji imanjiya nuna niina senchijijai wainkagtinai. 
\q1  
\v 3 Atum mina chichameg antautigmek, 
\q1 Judá wegantu kakaakchau aina nunú ichichiagtajum, 
\q1 dutikakjum pimpikiu aidaushkam yaigtajum. 
\q1  
\v 4 Tuja sapig aidau chichagkujum: 
\q1 “¡Ishamkagtutsuk, aishmag wajastajum! 
\q1 ¡Amina Apajuíjum juwi pujawai uwemtijamjagtatus, 
\q1 tuja iina shiwaaji aina nunak nii suwimkan susattawai!” titajum. 
\q1  
\v 5 Dutikamtai aents wainmachu aidau wainmakagtinai, 
\q1 tuja empeku aidaushkam chichaman antukagtinai; 
\q1  
\v 6 tuja aents shutuu aidaush 
\q1 japajai betek tsekeniagtatui, 
\q1 nuninai chichachu aidaushkam chichainak shiig aneasag untsumiagtinai. 
\q1 Nuninai uwegshunmashkam 
\q1 shiig kuashat yumi pukuni jiiniagtinai. 
\q1  
\v 7 Imanidau asamtai, 
\q1 uwegshuk yumi wajas asattawai, 
\q1 tuja nugka bukunmashkam kuashat yumi pukuni jiiniagtatui. 
\q1 Tuja lobo batsamtai aina nuwig 
\q1 tagkan kajis aidaujai tsapaktatui. 
\q1  
\v 8 Nuwi atinai makichik jinta. 
\q1 Nuna daajig: “Jinta pegkejam” tutai atinai. 
\q1 Aents pegkeechu aidauk 
\q1 nunú jintanmak wechagtin ainawai; 
\q1 tuja aents anentainkachu aidauk nunú jintanmak yujaschagtin ainawai. 
\q1  
\v 9 Nuwig leónkak atsutnai, 
\q1 tuja tikich kuntin yukagtin aidaukesh 
\q1 nunak makichkish adijkachagtinai. 
\q1 Tuja Tuke Pujuu uwemtikjamu aidauk nunú jinta nuni waketjagtinai. 
\q1  
\v 10 Tuke Pujuu uwemtikjamu aidauk shiig aneas kantamkiag 
\q1 Jerusalén utsanawagtinai. 
\q1 Nunikag tuké shiig aneasag batsamsagtinai. 
\q1 Ditaig ima shiig aneamua duke atinai. 
\q1 Nuadui wake besemjak atsutnai, 
\q1 tuja najaimamushkam atsutnai. 
\c 40  
\s1 Apajuí Jerusalégnumia aidaun anentain ichichtau 
\q1  
\v 1 Iina Apajuíji chichaak: 
\q1 “Shiwag aidau achipag dita nugken yajupakagmatai batsamsagmesh, 
\q1 ¡mina aentsug aina nuna anentai ichichtugtin atajum! 
\q1  
\v 2 Jerusalégnumia aents aidauk shiig anentsajum ausatajum, 
\q1 tuja achija yajuakam yujasag waituina nunú 
\q1 ayamsagtinuk tsawantak jegae”, titajum. 
\q1 Dita tudaujig tsagkugnaje. 
\q1 Dita pegkegchau takasbaujin nagkaesau 
\q1 Tuke Pujuu suwimken jukiag waituinak umikaje. 
\b  
\q1  
\v 3 Makichik aents uwegshunum untsumak: 
\q1 “¡Tuke Pujuu wekaesatin jinta uwegshunum 
\q1 shiig iwaja jintamajum, tunin aidau 
\q1 dakuegjum umiktajum! 
\q1  
\v 4 Nugka ségaju aina duka 
\q1 yutuka aimjajum paka awajsatajum, 
\q1 tuja muja tsakakunum 
\q1 nuna wakeen entsa ayá dushakam 
\q1 yutukjum makichkish wagaku atsau paka awajsatajum. 
\q1  
\v 5 Dutika umikagmin 
\q1 Tuke Pujuu niina imanjin iwainaktinai, 
\q1 nuna ashí aents aidau ijunag wainkagtinai, 
\q1 tawai Tuke Pujuu”, tusa Isaías tiuwai. 
\b  
\q1  
\v 6 Nuna tusa nuigtushkam Isaías chichaak: 
\q1 “Makichik aents chichagtak: 
\q1 ‘¡Untsumkata!’ tujutkui, wi ayaakun: 
\q1 ‘¿Wajintu untsumkattaja?’ tai, nii chichagtak: 
\q1 ‘Ashí aents aidauk dupajai betek, 
\q1 tuja yagkug ikamia niime wainak 
\q1 pegkegchiama nunin ainawai. 
\q1  
\v 7 Tuja Tuke Pujuu dase awemamu dasentak 
\q1 tukua tukuam dupa kagaka ijuname, 
\q1 tuja yagkugshakam kagaka kakegame. 
\q1 Numamtuk aentsuk dupajai betek ainawai. 
\q1  
\v 8 Dupag kagaka jininai, 
\q1 tuja yagkugshakam kagaka kakenai. 
\q1 Tujash Apajuí chichameg makichkish 
\q1 megkaekashtinun tuke auwai’. 
\b  
\q1  
\v 9 “Jerusalégnumia aidauwah, 
\q1 muja titijin wakatajum, 
\q1 nunikjum nuwi ijuntsajum senchi untsumkatajum, 
\q1 aents ashí nugkanmaya aidau antuktinme. 
\q1 Jerusalégnumia aidauwah, 
\q1 chicham etsegtak ishamkagtutsuk 
\q1 senchi untsumkajum etsegkatajum, 
\q1 ashí Judá nugkanmaya yaakta aidaush 
\q1 yamajam chichaman antuktinme. 
\q1 Senchi untsumkajum: 
\q1 ‘Iina Apajuíjiya duka jujuwai’, tusa titajum. 
\q1  
\v 10 Apu Tuke Pujuu niina senchijijai minawai, 
\q1 nuniak nii ima senchigtin asa, ashí depetmak minawai. 
\q1 Nunik minak niina aentsji aidau waitkam batsatun yajuak inimui. 
\q1  
\v 11 Uwija kuitamnujai betek 
\q1 niina aentsji aidaun kuitamak inimui. 
\q1 Uwig tsakat aidaunak pagkuk juki inimak, 
\q1 yama petsakbau aidaunak shiig puyatjus juki minawai.” 
\s1 Israel aents aidau Apajuíjin nagkaesauk tikichik makichkish atsawai 
\q1  
\v 12 “Apajuík nayantsanak makichik uwejenig 
\q1 achika dekapamainai. 
\q1 Tuja nayaimpinashkam tsajam uwejinig 
\q1 ashí achika dekapamainai. 
\q1 Nugkash wajupa kijinkita nuna shiig dekauk Apajuíyai. 
\q1 Apajuí dekawai muja aidaush 
\q1 wajupa kijinuk ainawa nunak. 
\q1  
\v 13 Tuke Pujuun chichagnuk makichkish atsawai. 
\q1 Apajuín jintinmainuk shiig atsawai. 
\q1  
\v 14 Apajuín jintintua unuinajuk makichkish atsawai. 
\q1 Tuja pegkeg takat aina nuna takasti tusa Apajuín jintintushkam atsawai. 
\q1 Niig ashí yachai. 
\q1 Ashí waji ayá dusha wajuk najaneakukita 
\q1 nuna pachis Apajuín jintinmainuk atsawai. 
\q1 Niig ashí dekawai, wagki nii najankau asa. 
\q1 Apajuí yacha ati tusa jintintua unuinajuk atsawai. 
\q1  
\v 15 Nugka múun aina duka nii diismak 
\q1 makichik yumi dakitamua nujai betek, 
\q1 nugka yukukuntunmaya 
\q1 makichik nenentuch piipich juki, 
\q1 balanzanum dekapam kijinji atsumaina numamtinai. 
\q1 Nugka múun aidau nayantsan ijus ayá dushakam 
\q1 makichik kayam piipichia nunin ainawai. 
\q1  
\v 16 Ikam múun Líbano tutaya nuwiya kuntin 
\q1 ashí yajuaka Apajuí emematku apeatin ijumjamash, 
\q1 Apajuí diismak piipichi, tuja kuntin maa apeatin 
\q1 nunú ikamnumia numi ashí yajuaka ijumjamash 
\q1 Apajuí diismak piipichi. 
\q1  
\v 17 Ashí aents maki makichik chichamtin 
\q1 nugka muunnum batsamin aina dushakam 
\q1 Apajuí emtinig shiig wainkauch ainawai. 
\q1 Nii diismak atsaujai betek ainawai. 
\q1  
\v 18 Atumek Apajuík makichkish tikichjai 
\q1 apatkagmek diimaitsugme. 
\q1 Dakumka najanamu aina dukesh 
\q1 Apajuíjai betek amainuk makichkish atsawai. 
\q1  
\v 19 Aents dakumak najanna nunú dakumak najanui, 
\q1 dutikamtai tikich aents patakumtai aidaun najanin 
\q1 orojai ukatuk umiawai, 
\q1 dutika cadenan platayai najatui. 
\q1  
\v 20 Tuja ujunauch aidaunu aents dakumak najanna duka 
\q1 numi katsujam wamak mamumainchaun diisa najanui. 
\q1 Dutika nunú iyaag tsainkai tusa 
\q1 tikich aentsun ame juju chichiag asatin 
\q1 najatuata tusa inawai. 
\b  
\q1  
\v 21 “¿Atumek duka dekachuk ayujum? 
\q1 ¿Nuna pachisag chichaidauk antuchuk ainajum? 
\q1 ¿Yama nagkamchakush ujapaku ainatsuak? 
\q1 Apajuí nugkan najanauwa duwi nagkamas 
\q1 aents aidauk dekau amain ainawai. 
\q1  
\v 22 Apajuí pujusa inamtaijiya duka nayaimpi yakin awai. 
\q1 Nuwi pujus aents aidaunak manchia nuninush diyawai. 
\q1 Tuja nayaimpinak Apajuí carpajai betek ejaa, 
\q1 nuna nugkaan aents aidau batsamsatnume tiuwai. 
\q1  
\v 23 Apajuík aents senchigtin aidaunak 
\q1 tikima wainkauch emawai, 
\q1 tuja nugkaya apu aidaunashkam ijina emegkawai. 
\q1  
\v 24 Nuadui ditak ajak yama ajakmamu 
\q1 kagkape yama achimag wegama nujai betek ainawai. 
\q1 Tuja Apajuí dasen dasenmitkataik pimpika jinawai, 
\q1 tuja dase ishamain iyakug 
\q1 chijichi tsupigbau kagakujai betek umpui utsawai. 
\q1  
\v 25 Tuja Apajuí pegkegma nunú chichaak: 
\q1 ‘Atumek minak makichkish tikichjai 
\q1 apatukjumek diigmaitsugme. 
\q1 Wijai betekak makichkish tikichik atsawai’, tawai. 
\q1  
\v 26 Yakí pagkaijum diistajum: 
\q1 ¿Juju ayá nunash ya najanauwaita? 
\q1 Yaya aidaun, nantu, etsa, 
\q1 nuigtu tikich aidau ayá nuna najanak, 
\q1 maki makichik akanag pekasua nunú 
\q1 nigki nuna daaji aidaunash adaitug umikui. 
\q1 Niig senchigtina ibau asa, 
\q1 makichkikesh najantsuk ampija ukukbaujig atsawai. 
\q1  
\v 27 Jacopa uchiji Israel aents aidauwah, 
\q1 ¿wagka atumesh wainkagmesh chichagme? 
\q1 ¿Wagka wainkagmesh: 
\q1 Tuke Pujuuk wi waitiag nunak dekatsui; 
\q1 tuja Apajuík minak pachittsui, tajume? 
\q1  
\v 28 Apajuí Tuke Pujuu, 
\q1 ashí nugkan, nayaimpijai najanauwa duka 
\q1 makichkish yawechu, nuigtush pimpichu, 
\q1 dekatish amuechauwa duka ¿amek dekatsmek, 
\q1 atsa nuniachkumesh amek antuchukum? 
\q1  
\v 29 Apajuíyai aents pimpikiunash senchimtika 
\q1 wajiu emauwa duka, 
\q1 tuja aents kakakchaunash senchijin ikauntinai. 
\q1  
\v 30 Datsauch aidaush pimpikiag kakaumainchau dekapenawai, 
\q1 tuja aents senchigtin aidaush nugka tukumak iyainawai. 
\q1  
\v 31 Tujash ima Tuke Pujuuwaig kajinas anentaimaina duka 
\q1 yamajam senchin jukiagtin ainawai. 
\q1 Águilajai betek nanaakagtin ainawai, 
\q1 wekaekush yawegchagtin ainawai, 
\q1 makichkish yaweakchau shiig tupikaidiagtinai.” 
\c 41  
\s1 Israel aents aidaunak wi agkanmitkatnaitjai tusa Apajuí tibau 
\q1  
\v 1 Apajuí chichaak: 
\q1 “Yaakat múun nayantsanum ijus ayá nuwi 
\q1 batsamin aidautijum takamtak pujusjum antugtuktajum. 
\q1 Tuja nugka muunnum batsamin aidautigmesh 
\q1 ishamkagtutsuk kaunatajum. 
\q1 Nunikagmin atumesh shiijash batsatjum nunú ijunja dekaami. 
\q1 Nunika atumesh wajukatagmeki 
\q1 nunú chicham umikmi. 
\q1  
\v 2 Etsa minitaiya nuwiya apu 
\q1 tuke depetma nunash ¿ya dutiknaita? 
\q1 Anú apu tikich nugkanmaya aidaun depetuk 
\q1 ijinatnume tusan umiaunuk witjai. 
\q1 Nuadui nunú apu suntaji aidau, puyagjai, 
\q1 nagkijai aatus shaa dekeaja tsaitiama numamtuk 
\q1 tsaikag ijinatnume, 
\q1 dutikawag chijichi kagakun dase umpui dapampaak 
\q1 utsauwama numamtuk emegkagtinme tusan idaijai. 
\q1 Dutikakun dita apuji aidaushkam suntaji amutam 
\q1 sapijin ditai yunumjatnume tusan idaijai. 
\q1  
\v 3 Shiwaajin pataetakush ishamain atsaunum, 
\q1 agkan shiig wamak nanaakas shimatai tumain 
\q1 shimitnume tusash ¿ya dutiknaita? 
\q1  
\v 4 Witjai nuna dutikaunuk. 
\q1 Yama nagkamchakun nugkan nayaimpijai 
\q1 najanawaitag duwi nagkamsan, 
\q1 yaunchuk waji nagkaemajua nunak, 
\q1 tuja yamai nagkaema nunashkam, 
\q1 wi dutiknaitjai. 
\q1 Witjai Tuke Pujuu dekas Apajuínuk. 
\q1  
\v 5 Wi dutikamunak yaakat nayantsanum 
\q1 ijus batsamin aidauk wainin ainawai. 
\q1 Nuna wainainak senchi sapigmainawai. 
\q1 Nugkashkam ashí yantamnum uujui. 
\q1 Aents tikich nugkanmaya aidau ijunjagtatus 
\q1 ashí kaunawag mininawai. 
\b  
\q1  
\v 6 “Maki makichik aents dakumak najanin aidauk 
\q1 niina kumpajinak ima niinakek idaitsui, 
\q1 yayawai dutikak anentain ichichtawai. 
\q1  
\v 7 Dakumak najanin aina duka patakumtain, 
\q1 nugkutain orojai najanin aina nuna chichajuinak: 
\q1 ‘Pegkeg najanme, idaitsuk takasta’, tuinawai. 
\q1 Tuja martillowai takau aidauk, 
\q1 jiju awatug ikag najanin aidaun chichajuinak: 
\q1 ‘Achija umikum duka pegkejai’, tuinawai. 
\q1 Nuna tusag dakumka najanamu iyajai tusag 
\q1 clavowai achiawag ukuinawai.” 
\b  
\q1  
\v 8 Apajuí chichaak: 
\q1 “Jacob wegantu Israel aents aidauwah, antuktajum: 
\q1 Atumek mina inakeg, wi etejamu ainagme. 
\q1 Atumek mina kumpag Abraham aajakua 
\q1 nunú wegantu ainagme. 
\q1  
\v 9 Tuja tikich nugkanum achija yajuakam 
\q1 atushat batsatutigmin wi agkanmitkauwaitjime, 
\q1 dutikan mina takagtustajum tusan chichagkun: 
\q1 ‘Atumek mina inakeg ainagme’, tiuwaitjime. 
\q1 Wi atumnak etegkauwaitjime, 
\q1 nuadui atumnak dakitjankesh idaisachjime. 
\q1  
\v 10 Ishamkagtukaigpa, wi atumjaig pujajai. 
\q1 Ishamkagtukaigpa, witjai atumi Apajuíjinuk. 
\q1 Wi atumnak senchimtikajime, 
\q1 wi atumnak yayajime, 
\q1 mina uweg senchigtin depetmauwa duwi 
\q1 ayamjukan kuitamjime. 
\b  
\q1  
\v 11 “Amina kajegtamin aidaunak, wi inatsaktinaitjai. 
\q1 Dutika ai ememamujinak kajimatkiagtinai. 
\q1 Atumjai maanidaushkam ashí ijinawajam megkaejattawai. 
\q1  
\v 12 Nunik megkaejamtai, wainkatasajum 
\q1 egakjumesh wainkashtinaitjume, 
\q1 wagki amejai maaniatag tinu aidauk 
\q1 ashí amukam megkaejatnai. 
\q1  
\v 13 Tujash aminak wi achiakjame. 
\q1 Wi atumin chichagkun: ‘Ishamkagtukaigpa, 
\q1 wi atumnak yayajime’ tiuwaitjime”, tawai Apajuí. 
\b  
\q1  
\v 14 Tuja Apajuí ataktu awagki chichaak: 
\q1 “Jacob wegantu Israel aents aidautigmek, 
\q1 piipich kakakchau ainakjumesh, 
\q1 ishamkagtukaigpa, wi atumnak yayajime. 
\q1 Witjai Israel aents aidau Apajuíji pegkegmanuk, 
\q1 wi atumnak agkanmitkauwaitjime. 
\q1  
\v 15 Antuktajum nijah: Atum ainajum anuiyan, 
\q1 makichik trigo akatain yamagman, 
\q1 naín batsatkan najanattajai. 
\q1 Dutikamtai nujai muja aidau tsaikam 
\q1 yukukuntu awajsattagme. 
\q1 Tuja nain aina dushakam tsaiktatjume, 
\q1 dutikawagmin chijichi kagaku tuwasua weaku atatui. 
\q1  
\v 16 Nunú yakí takui nagkimjumin, dase umpui utsagtinai. 
\q1 Tuja trigo akagbau, dukee utsankam 
\q1 wampuji juwakun dase shiig senchi dasentak 
\q1 utsauwama numamtuk, 
\q1 atumi shiwaajum aidaun dapampaak utsagtatui. 
\q1 Dutikamtai Israel aents aidaun Apajuíji 
\q1 pegkegma nuwi shiig aneasam pujuttame, 
\q1 nuniakum ima niyaig eme anenmamtatme. 
\b  
\q1  
\v 17 “Aents ujudauch kuichkigtinchau, 
\q1 wajigtuchu wekagas yumi egá egakua 
\q1 wainkacha kitamak umumain atsujam, 
\q1 suweuchijin jujug wekaetatui. 
\q1 Tujash wi niinak yaigtinaitjai, 
\q1 witjai Tuke Pujuu Israel aents aidau Apajuíjinuk, 
\q1 nuadui ditanak kajimatkinuk idaisashtinaitjai. 
\q1  
\v 18 Muja uwegshunum entsa ayau awajsatnaitjai, 
\q1 tuja nugka ségaju paka aidaunmashkam 
\q1 yumi pukuni kuashat jiiniagtinai. 
\q1 Nuadui yumi kuashat ayau asamtai, 
\q1 dupa shiig tsapak aama iman uwegshunak emaktatjai. 
\q1  
\v 19 Uwegshunmak setug aidaun, 
\q1 numi acacia aidaun, arrayan aidaun, 
\q1 nuigtu olivo aidaun tsapapitkatnaitjai; 
\q1 untsu nugka bukunum, numi pino aidaun, 
\q1 abeto aidaun, nuigtu cipre aidaun tsapapitkatnaitjai. 
\q1  
\v 20 Nuna ashí aents aidau wainkatnume, 
\q1 nuninak puyatjus unuimagtinme, 
\q1 wi Tuke Pujuun mina senchigjai dutikag nuna. 
\q1 Witjai Israel aents aidaun Apajuíji pegkegmanuk, 
\q1 wi nunak najanauwaitjai”, tiuwai. 
\s1 Apajuí tikich apajuímtai aidaun atsaneamu 
\q1  
\v 21 Jacob wegantu Israel aents aidaun Apajuíji chichaak: 
\q1 “Apajuímtai dakumka najanamu aidautijum kaunajum, 
\q1 chichamjumaktajum, nuniakjum atumi takatjum ayamjuktajum. 
\q1  
\v 22 Kaunatajum, 
\q1 nunikjum atakea duwi atin etsegkatajum, 
\q1 dutikakjum yaunchuk waji nagkaemajua nunú 
\q1 shiig ujajatkatajum, iish shiig antukagmi 
\q1 atakea duish wajig nagkaemagtinaita nunú, 
\q1 tuja dusha dekas uminkatpash nunú diismi. 
\q1  
\v 23 Atakea duish waji nagkaemagtatua nunú tukagtitajum. 
\q1 Atum dekas Apajuíyaitkugmek nunú iwainaktajum. 
\q1 ¡Atum dutikmain pegkeg aidau, 
\q1 tuja pegkegchaukesh, 
\q1 nuniachkush ishamain iina uwaktamain 
\q1 aidaukesh iwainaktajum! 
\q1  
\v 24 ¡Atumek shiig wainkauch ainagme, 
\q1 nuadui makichkish iwainamaitsugme! 
\q1 ¡Atumin kajintsa anentaimauwa duka 
\q1 pegkegchau shiig wainkayai! 
\b  
\q1  
\v 25 “Makichik aentsun etsa minitaiya nuwiyan jiikjai, 
\q1 dutikan niina daajin untsuka ai nujinmanini minawai. 
\q1 Nunú aentsua nunú tikich apu aidaunak tsakus 
\q1 najamaina numamtuk najaktatui, 
\q1 tuja ichinka najanin duwen nawen najama 
\q1 numamtuk najak ukuktatui. 
\q1  
\v 26 Junak emtikan eke nagkaematsaig wi ashí ujajime. 
\q1 Dakumka najanamu apajuímtai aina duka 
\q1 wi etsejag nunak, wi taatsaigkik yaunchkek 
\q1 makichkish etsegchau ainawai; 
\q1 Dita chichamuk makichkish antugchatayai. 
\q1  
\v 27 Junak makichkish etsegchatain wi Jerusalégnumia aidaun ujakuitjai. 
\q1 Tuja aents achija yajuakbau tikich nugkanum batsata duka, 
\q1 dukap atsuk waketjattawai tusa etsegkatnun 
\q1 wi makichik aentsun akatjan Jerusalén awemajai. 
\q1  
\v 28 Ashí diyajai, tujash makichik apajuímtai 
\q1 dakumka najanamukesh wantintsui; 
\q1 chichaman etsegmainkesh makichkish wantintsui. 
\q1 Tuja wi ditan iniasagmag nuna aigmainkesh 
\q1 makichkish wantintsui. 
\q1  
\v 29 ¡Ditak shiig wainak ainawai! 
\q1 Dita dutikmainuk makichkish atsawai. 
\q1 Ditak dakumka najanamu waa ainawai.” 
\c 42  
\s1 Tuke Pujuun inake 
\q1  
\v 1 “Jujuwai mina inakeg, Wi niinak achiakjai, 
\q1 wi niinak etegkauwaitjai, niini shiig aneajai, 
\q1 niyai mina Wakanjun apusajai; 
\q1 Nii aents ashí nugkanmaya aidaun 
\q1 pujut pegkejan susatnai. 
\q1  
\v 2 Niig senchi jiikag untsumchatnai, 
\q1 chichaakush senchi jiikag chichashtinai, 
\q1 jintá wekagas senchi untsumak chichamujish antuekashtinai. 
\q1  
\v 3 Tagkan kupinak aunash tsujigkag ajapashtinai, 
\q1 tuja lamparin ekemakbau shiig keeshtaish ikagnakchatnai. 
\q1 Niig dekas pegkeg pujutan itaatnai. 
\q1  
\v 4 Tuja ashí nugkanum pujut pegkeg ati tau asa, 
\q1 nii takamujinak makichkish ayamsashtinai, 
\q1 tuja pimpikigkesh idaisashtinai. 
\q1 Tuja nugka múun nayantsa ijus ayá nuwi 
\q1 aents batsamin aidauk, 
\q1 nii jintiamun antuktatus niina dakagtinai, tawai Apajuí”, tiuwai Isaías. 
\b  
\q1  
\v 5 Tuke Pujuu Apajuí nayaimpin najanauwa nunú, 
\q1 tuja nugkanashkam najana, 
\q1 nunú nugkanum tsapau aidaunashkam 
\q1 najankauwa nunú, 
\q1 tuja iwaku pujutan mayattanashkam aents aidaun 
\q1 susauwa nunú niina inaken chichajak: 
\q1  
\v 6 “Witjai Tuke Pujuu Apajuínuk, tikichik atsawai, 
\q1 wi aminak mina takagtusti, nuniak 
\q1 uwemtikagtugti tusan etegkeawaitjame, 
\q1 wi aminak kuitamkatnaitjame, 
\q1 dutikakun achiaku atatjame, 
\q1 wagki wi chichaman ditajai umikuitag nuna umiakun, 
\q1 mina aentsug aidaun amasjai. 
\q1 Ame tsaaptin asam, 
\q1 aents aidau yajuakam minai ikaunmatnaitme. 
\q1  
\v 7 Aents wainmachu aidau wainmitkakta, 
\q1 tuja aents achikbau aidau suwenum chimpija dushakam 
\q1 jiijam agkanmitkata, tusan wakegajai. 
\q1  
\v 8 ¡Wika Tuke Pujuuwaitjai, nunuwai mina daajuk! 
\q1 Mina emematjaku kantamtai aina duka 
\q1 tikichik makichkish kantamjuawaigpa, 
\q1 tuja mina emematjutmaina nunú idaikumek, 
\q1 dakumka najanamu aina duka makichkish emematipa. 
\q1  
\v 9 Wi yaunchuk etsegkauwaitag nunú 
\q1 uminka nunú atumesh anentaimsa diistajum, 
\q1 yamai etsegkattajai yaunchkesh antukchamu yamajam aidaun. 
\q1 Nunú eke wantintsaig, atumnak dekamtikajime”, 
\q1 tiuwai Apajuí. 
\s1 Tuke Pujuu uwemtikagtugbau anentaimtusa kantamtai 
\q1  
\v 10 Yamajam kantamtai Tuke Pujuu kantamjuatajum. 
\q1 Ashí nugka najatamunum batsamin aidautigmesh 
\q1 Apajuí emematkujum kantamatajum, 
\q1 lanchanum nayants yujau aidaush, 
\q1 kuntin nayantsanum batsamin aidaush, 
\q1 tuja nugka múun nayantsa ijus ayá nuwi 
\q1 batsamin aidaush Apajuín ememattinme. 
\q1  
\v 11 Uwegshunum yaaktamak batsamin aidaush, 
\q1 tuja Quedar wegantu aidaujai batsamin aidaushkam shiig aneastinme. 
\q1 Yaakat Selá batsamin aidaushkam shiig aneasag 
\q1 dakunkut Apajuín kantamjuatnume; 
\q1 tuja aents mujanum batsamin aidaushkam 
\q1 depetmaka shiig aneaku untsumaina imattinme. 
\q1  
\v 12 Tuke Pujuu imanjiya nunak ima niinak idaitustinme, 
\q1 tuja nugka muunnum nayantsa ijus batsamin 
\q1 aina dushakam Apajuín emematak kantamjuatnume. 
\q1  
\v 13 Tuke Pujuu, múun, senchigtin asa, maanitan yacha, 
\q1 shiwaaji aidaun kajejuk, 
\q1 suntag maaniamunum untsumajama imati untsumak jiintuki, 
\q1 shiwaaji aidaunak ijinattawai. 
\b  
\q1  
\v 14 Apu Mesías chichaak: 
\q1 “Kuashat tsawantai chichatsuk pujujai, 
\q1 makichik chichamnakesh tutsuk, 
\q1 tuja nuigtush kajetsuk pujujai. 
\q1 Tujash yamaik nuwa uchin uchigmak, 
\q1 buutak mayatama imanittajai. 
\q1  
\v 15 Muja aina nunak nain aina nujai tsaiktatjai, 
\q1 tuja numi aidau, ajak aidau ayá nunashkam ashí ijinattajai. 
\q1 Tuja entsa ayá nunak ukuyuan buku awajsattajai. 
\q1 Dutikakun kucha aidaunashkam ukuyan buku awajsattajai. 
\q1  
\v 16 Wainmachu aidaunak jinta dita wainajakchamunum emattajai. 
\q1 Tuja suwenum yuja nunak tsaaptin etittajai. 
\q1 Tuja jintanum kaya pujutjin weaja 
\q1 nunashkam utsagkan pegkeg awajtustatjai. 
\q1 Wi taja nunak umitskek idaisashtatjai, 
\q1 tuké dutikattajai. 
\q1  
\v 17 Tuja wainka apajuímtai dakumka najanamu aidaun 
\q1 dekaskeapi tinu aina duka 
\q1 dita apajuímtaiji aidaun chichajuinak: 
\q1 ‘Atumetjume jutii apajuíji aidautigmek’, tuinawai. 
\q1 Nuna tinu aina duka datsagkag jiinag 
\q1 megkaejagtinai”, tiuwai Apajuí. 
\s1 Israel aents aidau Apajuí chichamen antuinakush umikchagbau 
\q1  
\v 18 Antuchu aidauwah, antuktajum, 
\q1 wainmachu aidauwah, niimi wainmaktajum. 
\q1  
\v 19 Wi mina takagtustinme tusan, 
\q1 atumin etegkau asan aents aidau chicham ujaktajum tusan 
\q1 ishiakbau ainayatkujum aents antuchu, 
\q1 wainmachu aina nujai betek ainajum, 
\q1 nuninuk tikichik makichkish atsuinawai. 
\q1 Atumin wi mina takagtustinme tusan 
\q1 etegkamu aidautijum chicham antuchu, 
\q1 wainmachujai betek ainajum annuk tikima tikichik 
\q1 makichkish atsawai. 
\q1  
\v 20 Wi atumin yayaakun kuashat dutikawaitag 
\q1 duka atumek wainkauwaitjume, 
\q1 tujash umigtukchau ainagme. 
\q1 Atumek chichamak antagme, 
\q1 tujash wi tajim duka makichkish nunap tawa tusagmek dekatsjume. 
\q1  
\v 21 Tuke Pujuuk uwemtikagtina ibau asa, 
\q1 pegkeg wakemain aina nuna 
\q1 aents aidaun jintintuatjai tusa wakejukui. 
\q1  
\v 22 Tujash juju aents aina nunak, 
\q1 dita shiwaaji aidau kasajainak waitkainawai. 
\q1 Dutikainak achijag waanum, 
\q1 nuigtu aents achika chimpitainum chimpiawag batsamtawai. 
\q1 Dutikawag dita wajiji aidaunak ashí yajutuinawai. 
\q1 Ditan ayamjumainuk makichkish atsawai. 
\q1 Tuja dita patayi aidaunash achika jukiag, 
\q1 akikmakui awagtukmi tusag emegkatuinawai. 
\q1 Tujash ditan ayamjuk awakmainuk atsawai. 
\b  
\q1  
\v 23 Tujash atum ainajum anuiyag 
\q1 makichkish nunak puyatjusagkesh diinatsui. 
\q1 Nunidau asag atakea duish wajukatnukita tusa 
\q1 dekatatus wakegauk makichkish atsawai. 
\q1  
\v 24 Jacob wegantu Israel aents aina nuna 
\q1 shiwag aidau utsaantuawag kasajuinak waitkaina nunash, 
\q1 ya dutikati tima dutikainawa duka 
\q1 atumek shiig dekagme. 
\q1 ¿Tuke Pujuuchukait nuna dutikau? 
\q1 Israel aents aidauk Apajuín pegkegchau takamjusu ainawai, 
\q1 nuninak, Apajuísh ditanash wajuk pujustinme 
\q1 tiyamkiyi nunash umikchau ainawai, 
\q1 núnidau asag nii jintintuawa nuna umitnash dakitjajui. 
\q1  
\v 25 Nuadui atumnak kajegtamak suwimkan amasmatai, 
\q1 maaniamunum ijipau ainawai. 
\q1 Tujash imaanika waitiakjumesh, makichkish unuimatsjume. 
\c 43  
\s1 Ima Tuke Pujuuke uwemtikagtinuk 
\q1  
\v 1 Jacob wegantu Israel aents aidauwah, 
\q1 Tuke Pujuu atumin najapauwa nunú chichagtamak: 
\q1 “Ishamkagtukaigpa, 
\q1 witjai atumin agkanmitkaunuk, 
\q1 wi atumnak daagmin adaisan midau atinme tusan 
\q1 etegkauwaitjime, nuadui atumek midau ainagme. 
\q1  
\v 2 Yumi piyajunum nagkaemakminish, wi kuitamkattagme, 
\q1 tuja namak aidau katitkuminish, jakejai tusan kuitamkattagme; 
\q1 tuja jii kegamunum nagkaemakmesh esashtinaitme, 
\q1 jii kegak nimpaush dekapjashtinaitme. 
\q1  
\v 3 Witjai Tuke Pujuu, amina Apajuígminuk, 
\q1 witjai amina uwemtiknunuk, 
\q1 witjai Israel aents aidaun Apajuíji pegkegmanuk. 
\q1 Wi Egipto nugkan, Etiopía nugkan, Sabá nugkan aatsan sujakun 
\q1 atumnak sumakuitjime.\f + \fr 43:3 \ft “Wi atumnak Egipto nugkan, Etiopía nugkan, Sabá nugkan aatsan sujakun sumakuitjime” tawa nunak “juju nugka aidaunmaya Israel aents aidaun waitka batsatu asamtai, Apajuí dita shiwaajin sujua idayak Israel aents aidaun ayamjuk agkanmitkauwa” nuna taku tawai.\f* 
\q1  
\v 4 Atum iwaku batsamsamnujum tusa tabaunum 
\q1 tikich aidau jinawajui. 
\q1 Atum jinumainun yapajian dekas dita jinatnume tiuwaitjai. 
\q1 Wi nunak dutikauwaitjai, 
\q1 wagki atumin wait anentau asan, 
\q1 atumek dekas waji pegkeg akikama iman ainagme. 
\q1 Wika atumnak aneajime. 
\q1  
\v 5 Ishamkagtukaigpa, wi atumjaig pujajai. 
\q1 Amina aentsjum aidau etsa minitaiya nuni, 
\q1 tuja etsa akaetaiya nuni batsata nuna 
\q1 ijumjatasan yajuakan ikaunmattajai. 
\q1  
\v 6 Tuja aents nujinum batsamin aidaun chichagkun: 
\q1 ‘Awakjatajum’, titatjai. 
\q1 Tuja tsumunum batsamin aidaun chichagkun: 
\q1 ‘Makichkish emetuawaigpa’, titatjai. 
\q1 ‘Mina uchig aidau, mina nawantug aidaujai, 
\q1 atushat nugka nagkatkamunum batstush 
\q1 awakjatajum. 
\q1  
\v 7 Tuja uchi apaji daajin naamama numamtuk 
\q1 mina aentsug asag, mina daajun jukiu aina nunak 
\q1 mina daag ememattai atinun najanauwaitjai; 
\q1 nuadui makichkish emettsuk awakjatajum.’ 
\b  
\q1  
\v 8 “Mina aentsug aidau jiintin ainayatak 
\q1 wainmachujai betek aina nunú, 
\q1 tuja kuishtinaitak antuchu aina nunú dita nugken 
\q1 ashí awakjatajum. 
\q1  
\v 9 Ashí aents aidautijum 
\q1 makichik ijunbaunmak ijunjatajum. 
\q1 Nunikjum tujuttajum atum ainajum anuiyash 
\q1 ¿yaita atakea duwi atinun pachis, tuja yaunchuk 
\q1 nagkaemajua nunash betek etsegnush? 
\q1 Nunin ataik juwi itantinme, 
\q1 dutikam nunú etsegtai antukag dekaskeapi titinme.” 
\b  
\q1  
\v 10 Apajuí chichaak: 
\q1 “Atumek mina chichamjun etsegtugkatnume tusa 
\q1 etegkamu ainagme, 
\q1 wi atumnak etegkauwaitjime, 
\q1 minai kajintsa anentaimkugmek, 
\q1 dekas wi Tuke Pujuuwaitag nunú dekajuattagme. 
\q1 Initaikia duwish tikich apajuí mina nagkaetasuk atsujakui, 
\q1 tuja atakea duwish, duka makichkish atsutnai. 
\q1  
\v 11 Ima wikitjai Tuke Pujuunuk; 
\q1 tikichik uwemtikagtumainuk atsawai.” 
\b  
\q1  
\v 12 Tuke Pujuu chichaak: 
\q1 “Wi atumin ujaakun, uwemtijatnaitjime tusan 
\q1 tiuwaitjim nunak, betek uwemtijauwaitjime; 
\q1 tuja wainka apajuímtai aina duka atumnak uwemtijamjachajui, 
\q1 duka atumek shiig dekagme. 
\q1  
\v 13 Witjai yaunchuk nagkamsan Apajuínuk, 
\q1 tuja atakea duwish wiki atinaitjai Apajuínuk. 
\q1 Makichkish mina suwimkajun uwemtumainuk atsawai. 
\q1 Tuja wi dutikamua nuna emegkaumainush 
\q1 makichkish atsawai.” 
\q1  
\v 14 Tuke Pujuu pegkejam, Israel aents aidaun 
\q1 agkanmitkauwa nunú aatus tawai: 
\q1 “Atumin ayamjakun suntag aidaun Babilonia nugkanum ishiaktatjai, 
\q1 dutika ai dita yaaktaji waitiji aidaunak tsaikagtatui. 
\q1 Dutikawagmatai, caldeo aents aidau shiig aneas 
\q1 batsataina nunak wake besemag juwakagtatui. 
\q1  
\v 15 Witjai Tuke Pujuu, Israel aents aidaun najanaunuk. 
\q1 Witjai atumi Apajuíjum pegkegmanuk.” 
\b  
\q1  
\v 16 Nayants kuna ishamainnum 
\q1 nuna ejapeen Apajuí ukuya buku awajus ikankauwai. 
\q1 Aatus niina aentsji aidaun ikatiajui. 
\q1  
\v 17 Tuja Egipto nugkanmaya suntag maanitan yacha aidau 
\q1 caballo aidaujai, carro aidaujai Israel aents aidaun pataetukajui, 
\q1 tujash nayantsanum tepeawag makichkish jiinkishtinun megkaejabi; 
\q1 tuja lamparin ekemakbau kajinak megkagama numamtuk megkaejabi. 
\q1  
\v 18 Apajuí niina aentsji aidaun yamai chichajak: 
\q1 “Waji nagkaemakiuwa duka pachikaigpa, 
\q1 tuja anentaimtutkesh anentaimtusaigpa. 
\q1  
\v 19 Wi iwainaktatjai yamagman, 
\q1 nunú ame yamaikiuchia duik wainkattame. 
\q1 Uwegshunum jintan jintamattajai, 
\q1 tuja nugka pegkegchau ajak tsapachua nunashkam 
\q1 entsa ayau awajsattajai. 
\q1  
\v 20 Kuntin ikamia kajen lobo aidau, 
\q1 avestruz aidau aatus shiig anenjusagtinai, 
\q1 wagki wi yumi pukuni jiinun uwegshunum kuashat jiiju asamtai. 
\q1 Tuja nugka ajak tsapachunum 
\q1 entsa aidaun kuashat najankattajai, 
\q1 mina aentsug, wi etegkauwaitag nuna, uwajagtinun. 
\q1  
\v 21 Nunú aents aidaunak wi najankauwaitjai, 
\q1 mina emematjitnume tusan. 
\b  
\q1  
\v 22 “Tujash Israel aents 
\q1 Jacob wegantu aidautigmek 
\q1 mina umigtutak kajimatki idaisaugme. 
\q1  
\v 23 Tuja uwig aidaush anenjauchik sujatsjume, 
\q1 kuntin maa nuna neje ashí apeakjumesh emematjatsjume. 
\q1 Wika atumnak anentag sujustajum 
\q1 tusa segaaknuk waitkatsjime, tuja kugkuin incienso 
\q1 apeatajum tusankesh segaaknuk waitkatsjime. 
\q1  
\v 24 Mina anentag sujustinuk pagat kugkuin aina 
\q1 duka sumagtukchabiugme, 
\q1 kuntin aidau wiyajigkesh apeakjumek minak emematjishbaijume. 
\q1 Ayatak pujusjum pegkegchau takamugmin dii diin yawetjajai, 
\q1 nunú pegkegchaugmia nuna diitan tsuwaagjai. 
\q1  
\v 25 Tujash wi amina Apajuíjum asan, 
\q1 ame magkagtutaijum aidaunak esakatjattagme, 
\q1 dutikan atakea duish adeagchatnun kajimatkin idaisattajai. 
\q1  
\v 26 Ame mina utugchatug dekagtakmek 
\q1 yamai tujutta, chichasmi. 
\q1 Pai, ame waji titag tame nunú tita, 
\q1 nunú tiyamin amesh dekas shiig imagnismeash 
\q1 pujam nunú dekaami. 
\q1  
\v 27 Atumi apachjum aajakua nunú, 
\q1 tikich amina chichaman jintinjabianum 
\q1 nujai mai pegkegchaun takainak 
\q1 mina umigtukchau ainawai. 
\q1  
\v 28 Tuja amina apujum aajaku aidau 
\q1 jega mina emematjaku ijuntain shiig kuitamkachu ainawai. 
\q1 Nuadui Jacob wegantu Israel aents aidaunak ijinatnume, 
\q1 dutikawag dushiki batsamtitin atinme 
\q1 tusan idaisauwaitjai”, tawai Apajuí. 
\c 44  
\s1 Israel aents aidauk Apajuínu ainawai 
\q1  
\v 1 Tuke Pujuu chichaak: 
\q1 “Jacob wegantu Israel aents aidautigmin 
\q1 wi mina takagtustinme tusan etegkauwaitjim, 
\q1 nunú aidautijum yamai shiig antuktajum. 
\q1  
\v 2 Witjai Tuke Pujuu, atumin najanaunuk, 
\q1 atumek eke akiintsugminig najanauwaitjime. 
\q1 Wi atumnak yayajime. 
\q1 Amek Jesurún\f + \fr 44:2 \ft Chicham “Jesurún” tawa duka diista Dt. 32.15.\f* Jacob wegantu, mina inakeg 
\q1 wi etegkamuitme, nuadui ishamkagtukaipa. 
\q1  
\v 3 Uwegshunmak yumi kuashat ayau awajsattajai, 
\q1 tuja nugka buku aina nuwishkam entsa kuashat aittawai. 
\q1 Ame wegantu aidaunak mina Wakanjun susagtinaitjai, 
\q1 dutikakun kuashat pegkegnum yaigtinaitjai. 
\q1  
\v 4 Nuadui chijichi yumi ukattai asa, 
\q1 pegkejan muumpama iman, 
\q1 tuja álamo namaka tugkitken tsapaka aiyama 
\q1 iman atinaitjume. 
\q1  
\v 5 Nuwiya makichik chichaak: 
\q1 ‘Wika Tuke Pujuunuitjai’, tumamtinai. 
\q1 Tuja tikichik: 
\q1 ‘Jacob wegantu’, naamkatnai. 
\q1 Untsu tikichik niina uwejen: 
\q1 ‘Wika Apajuínuitjai’ tuu agatmamjatnai. 
\q1 Tuja nuigtu ikak agak, niina apachji daajin 
\q1 ‘Israel’ agagtinai.” 
\b  
\q1  
\v 6 Tuke Pujuu, Israel aents aidaun apuji, Israel aents aidaun uwemtikin, 
\q1 Tuke Pujuu ashí senchigtina nunú chichaak: 
\q1 “Witjai nagkamtinish tuke pujuunuk, 
\q1 tuja atakea duish tuke pujutnaitjai. 
\q1 Tikich Apajuí mina nagkaetasuk atsawai. 
\q1  
\v 7 ¿Yaita wijai betek amainush? 
\q1 Iman akug juwi wajanta tujutti. 
\q1 Tuja mina aentsug agtinun etegkauwaitag 
\q1 duwi nagkamsan atakea duwi 
\q1 nagkaemagtinnash etsegnunuk witjai, 
\q1 tuja wikitjai atakea duish wajig nagkaemagtinaita 
\q1 nuna betek etsegnunuk. 
\q1  
\v 8 ¡Makichkish ishamkagtukaigpa! 
\q1 Yaunchuk nagkamsan emtikan junak ujakuitjime. 
\q1 Duka atumek shiig dekagme, 
\q1 tikich Apajuík wijai betekak makichkish atsawai. 
\q1 Tikich Apajuí atumin kuitamjamainuk atsawai. 
\q1 Wika tikich Apajuínak waintsujai. 
\s1 Dakumka najanamu aidaunak Apajuí dakitau 
\p  
\v 9 “Dakumak najanin aina duka pegkejak ainatsui. Tuja dakumka najanamu aidaun dita shiig anentuina dushakam pegkegchau ainawai. Tuja dakumka najanamun emematuina duka anentainchau wainmachujai betek ainawai, nuadui ditak datsagkag wainak juwakagtatui.  
\v 10 Tuja dita emematiagtinun jiju ukuiyag najanin aina duka shiig pegkegchauwai.  
\v 11 Dakumka najanamun emematin aidauk datsaajagtinai, wagki dakumak najanin aina duka aents wainkauch ainawai. Ashí dita aidauk Apajuí emtin dita utugchatjin dekagmamawag datsaajagtinai, nuninak sapigmakagtinai. 
\p  
\v 12 “Diistajum jiju najanin wajuk takawa nunú: Jinum jiya inimpag, martillowai dekegka tsaika niina senchijin takawai. Nuadui nuna puyatjak yujumkan yutsuk, umutnash umutsuk pujujus pimpiki takamainchau dekapeawai. 
\p  
\v 13 “Tuja numi taumi dakumak najanin aina dushakam anentaimtusa diisagmi: Niig reglayai dekapawai, tuja lápisai, compásai aatus dakumui. Dutika formónkai tai aentsun dakumak najana jega Apajuí emematku ijuntainum awaya apujui. 
\p  
\v 14 “Tuja tikichik setjun ajainawai, dutikamun yumi yutak uchupiam muumpawai, nuadui niinu setug ajaka takamain aittawai. Nuniachkush numi ciprén, roblejai wakegainakug ikam ajawag shiig kuitamainawai kampuagti tusa.  
\v 15 Nunú kampuaju aidaun ajakag kanawen tsupig yajumainawai jiin ikapag anamawagtinun, untsu tikichnak pag inajuatnun juwinawai. Dutikainak wainka apajuímtain dakumak najanatnunashkam juwinawai, dutika najanawag emematuinawai. 
\p  
\v 16 “Tuja numi jimaituk ampinjaun jukiag nuna ikapajag, nuwi kuntinu nejen pegka inajuawag shiig yuwawag senchi tutuinawai. Nunikag nunú jinum ayaumas anamak pujus chichaak: ‘¡Yajautsui jii ijusa pujusa anabauk!’ tuinawai.  
\v 17 Nuwiya numi ampinjaun jukiag wainka apajuímtain dakumak najanainawai, dutikawag nuna emematak tikishmatug pujus segaak: ‘¡Ametme iina apajuíjimek, jutiish uwemtikagtugta!’ tuinawai. 
\p  
\v 18 “Nunú aentsuk makichkish dekatsui, tuja antutnash antatsui, wainmachujai betekai, unuimatish atsau, shiig anentainkachui.  
\v 19 Ekeemsagkesh anentaimainatsui, jintiaja shiig anentaimat atsujuinawai, nuadui ditak: ‘Jimaituk numin apeamjai, dutikan nuna kaijin pagkan inajuamjai, tuja nuigtu neje pegka inajuan yuwamjai, tuja nunú ampinjauwai juna pegkegchaun tsumainun dutikamjai, ¡wika numi tsupikbaun emematu wekaejai!’ tumamainchau ainawai.  
\v 20 Duka dekaskenum yuku yumaina numamtinai. Duka wainka tsanuam nuni wekaemainai. Nunú aents aina duka pujutjinak uwemtijashtin ainawai. Dita takuinaka duka shiig pegkegchauwai. Nunin ataish ditak: ‘Juka pegkegchauwapi’ tusa dekamainchau ainawai”, tiuwai Isaías. 
\s1 Tuke Pujuu Israel aents aidaun wait anentug uwemtijamu 
\q1  
\v 21 “Israel aents Jacob wegantu aidauwah, 
\q1 mina inakeg ainajum nunú adeagtajum; 
\q1 atumek mina inakeg ainagme, 
\q1 atumek mina inakeg wi najanamu ainagme, 
\q1 nuadui ¡minak kajimatjuki idaitusaigpajum! 
\q1  
\v 22 Amina pegkegchaujum aidaunak 
\q1 yujagkim kakegak megkagama numamtuk emegkatkagme. 
\q1 Ataktu wakitkim mina umigtukta, 
\q1 wi aminak agkanmitkauwaitjame” 
\q1 tawai Apajuí. 
\b  
\q1  
\v 23 ¡Nayaimpih, ameshkam Tuke Pujuu dutika 
\q1 nunú anentaimtusam shiig aneakum senchi kantamata! 
\q1 Nugka initken batsatutigmesh 
\q1 senchi untsumkujum aents wajukmaina imattajum. 
\q1 Muja aidautigmesh, ikam aidautigmesh, 
\q1 ashí numi aidaujai shiig aneakjum 
\q1 aents wajukmaina imatkujum senchi untsumtajum. 
\q1 Tuke Pujuu Israel aents Jacob wegantu aina 
\q1 nuna ayamjuk agkanmitkak niina senchijin iwainake. 
\q1  
\v 24 Tuke Pujuu amina uwemtijamin, 
\q1 ame eke akiintsuminig najapauwa nunú chichaak: 
\q1 “Witjai Tuke Pujuu, ashí waji aina nuna najankaunuk, 
\q1 wi nayaimpinak nugkajai najanauwaitjai, 
\q1 mina yainkauk makichkish atsawai. 
\q1  
\v 25 Tuja waita etsejin aina nunú etsegbau 
\q1 betek uminkati tusanuk wika wakegatsjai, 
\q1 anentaimsa dekamji tinu aina nunak anentainchau emajai. 
\q1 Aents yacha aina nuna dekatjinak yapagtuan 
\q1 shiig wainak dekachu emajai. 
\q1  
\v 26 Untsu mina inakeg aidau chichaman etsejuina duka 
\q1 betek uminkati tusan yayajai, 
\q1 tuja aents wi awemamu aidau chichaman umina 
\q1 dushakam imanisag betek uminkati tajai. 
\q1 Tuja Jerusalégnumak ataktu yaaktamak batsamsagtinai. 
\q1 Tuja Judá wegantu aidaun yaaktaji aajaku aina 
\q1 dushakam ataktu awagki yaaktamkamu atatui. 
\q1 Yaakat tsaikbau aidaun ataktu jegamjatnume tusan, 
\q1 jega jegamin aidaun wi inagtatjai. 
\q1  
\v 27 Tuja nayants kuyua buku wajasti, 
\q1 nunikmatai tikich namak aidaushkam 
\q1 buku waigti tusan tumainnuk witjai. 
\q1  
\v 28 Wi apu Ciron chichagkun: 
\q1 ‘Ametme mina uwig aidau kuitamnumek, 
\q1 amek wi wakegamua duke ashí takastatme’ tajai. 
\q1 Tuja Jerusalégkan chichagkun: 
\q1 ‘Amek ataktu yaaktamamu atatme’ titatjai. 
\q1 Untsu jega Apajuí emematku ijuntai jegamkamun chichagkun: 
\q1 ‘Amina ataktu jegamjamkatnun, 
\q1 jega jegamin aidaun awemattajai’ tawai Apajuí”, 
\q1 tusa Isaías tiuwai. 
\c 45  
\s1 Ciro takastinun Apajuí takatan susau 
\q1  
\v 1 Tuke Pujuu Ciron apu adayak, 
\q1 aents tikich nugka múun aidaunum 
\q1 apu senchigtin batsata nuna depetuk, 
\q1 maanitaiji aidaunak atanjati tusa yayaak, 
\q1 egkesa awekajakui. 
\q1 Tuja yaakat peeja apakbau aina nunash 
\q1 tujintsuk utua shiwag aidaun ijinati tawai. 
\q1 Nuadui Apajuí niina chichajak: 
\q1  
\v 2 “Ame weamunmak wi emkan wetatjai, 
\q1 tuja muja aidaunak yumpuajan paka emaktatjai, 
\q1 waiti jiju bronce najanamu aina nunak tsaiktatjai, 
\q1 tuja jiju hierro waiti batsatkamua nunashkam tsaiktatjai. 
\q1  
\v 3 Tuja waji pegkeg aidau 
\q1 makichkish wainmainchau uukbau awa nuna, 
\q1 wi amastatjai. 
\q1 Nunú wainkam, Tuke Pujuu Israel aents aidau 
\q1 Apajuíjinuk ima wikitag nunú dekattame. 
\q1 Wi aminak untsukmajame. 
\q1  
\v 4 Israel aents Jacob wegantu aidau, 
\q1 mina inakeg aina nunú aneamunum, 
\q1 amek minak dekagtsuminig wi aminak etegkamjame, 
\q1 dutikan apu emamjame tikich apu aina nuna 
\q1 nagkaesau ati tusan, nuadui aents aidaush 
\q1 ame tabaun antugtamkagtatui. 
\q1  
\v 5 Witjai Tuke Pujuunuk, 
\q1 tikich mina nagkaetasuk atsawai, 
\q1 amek minak dekagtsuminig wi aminak 
\q1 kuitamkattajame depetmakti tusan. 
\q1  
\v 6 Ashí tikich nugkanum batsamin aidaush 
\q1 tikich Apajuí mina nagkaetasuk atsa nuna 
\q1 dekaatnume tau asan nunak dutikattajai. 
\q1 Witjai Tuke Pujuunuk, tikich mina 
\q1 nagkaetasuk makichkish atsawai. 
\q1  
\v 7 Witjai tsaaptinun suwejai najanaunuk, 
\q1 tsawan pegkeg atinnash, 
\q1 tsawan pegkegchau atinnashkam, 
\q1 ashí nunak wi dutikajai.” 
\s1 Apajuí ashí senchigtin 
\q1  
\v 8 “Ashí nugkanmaya aidauk 
\q1 ima pegkeg takat aina nunak takagtatui, 
\q1 duka Tuke Pujuu jegashik nayaimpinmayan 
\q1 akakea numamtuk atatui. 
\q1 Aatus aents aidau pegkejan takainak uwemtan jukiagtinai.” 
\q1  
\v 9 Pinig duwe juki najanamua duka, 
\q1 aentsjai betekak, niina najanauwa nuna chichagkug: 
\q1 “Amek najantak dekatsme” tusag jiyanimaitsui, 
\q1 tuja tsakusai pegkejan dakumak najannunak: “¿Waji takame?” tusag tsakusak iniatsui. 
\q1  
\v 10 Tuja uchi yama akiinauwa duka 
\q1 niina apajinak dukujijaig: “¿Wagka minash akiintuabiugme?” 
\q1 tusag jiyamaitsui. 
\q1  
\v 11 Apajuí pegkejam, Tuke Pujuu, Israel aents aidaun 
\q1 najanauwa nunú chichaak: 
\q1 “Atumek minak makichkish inatmain ainatsjume, 
\q1 mina aentsug aidaunash wisha itugkatnaitja 
\q1 nuna ujatkati tusagmek wakemaitsugme, 
\q1 tuja wi dutikamujua dushakam jutik dutikata 
\q1 tusagmek jintinjumain ainatsjume. 
\q1  
\v 12 Wi nugkanak najanan, 
\q1 nuwi aents aidaun batsasuitjai, 
\q1 tuja nayaimpinash múun agkajun najanan, 
\q1 nuwi agkajunum etsanjatin aidaun najankauwaitjai. 
\q1  
\v 13 Wi apu Cironak etegkajai, 
\q1 dutikau asan wi niinak Jerusalén mina yaaktajua nuna 
\q1 ataktu jegamag yaaktamkati tusan yaigtatjai. 
\q1 Nuadui Israel aents aidau achija yajuakam 
\q1 Babilonia nugkanum batsata nuna jiigtatui, 
\q1 dutika jiija agkanmitkakush, akikmaktajum tusag 
\q1 makichkish kuichkinak segashtatui”, 
\q1 tusa Tuke Pujuu ashí senchigtina nunú juna aatus tawai. 
\q1  
\v 14 Tuke Pujuu Israel aents aidaun chichajak: 
\q1 “Egiptunmaya aents ajakan ajakbau, 
\q1 tuja etiopíanmaya aents waji sujin aidau, 
\q1 Sabá aents esajam aina dushakam, 
\q1 ashí ditak ima atum tabaunak umigtabiagtatui. 
\q1 Ditak atumi wainka inaku waitkatai agtatui. 
\q1 Imanik waituinak atumi emtin tikishmag pujusag 
\q1 chichainak: 
\q1 ‘Dekas Apajuík ima atumjaig pujawai, 
\q1 tikich Apajuík makichkish atsawai.’ 
\q1  
\v 15 Amek dekas wainmainchauwaitme, 
\q1 tuja ametme Israel aents aidau ayamjukam uwemtiknumek. 
\q1  
\v 16 Wainka apajuímtai aidaun dakumak najanin aina duka datsagkag 
\q1 wainak juwakagtatui. 
\q1  
\v 17 Tuja Israel aents aina nunak 
\q1 Tuke Pujuu tuke batsamsatnun uwemtijatnai. 
\q1 Nuadui ditak wainka inaku waitkatai, 
\q1 dushiktaig achagtinai.” 
\b  
\q1  
\v 18 Tuke Pujuu Apajuí nayaimpin, nugkan najana, 
\q1 juwi aents aidau batsamsatnume tusa 
\q1 umikua nunú chichaak: 
\q1 “Witjai Tuke Pujuunuk, tikichik makichkish atsawai. 
\q1  
\v 19 Wika aents aidau antachbaunum suwenum uumka 
\q1 pujusnuk chichatsjai. 
\q1 Tuja Israel aents aidaun susashtinaitkunuk, 
\q1 segattajum amastajime tusanuk anagkuatsjai. 
\q1 Wika Apajuí dekasken pegkejan chichauwaitjai.” 
\s1 Wainka apajuímtai aidaun atsaneak Tuke Pujuu chichakbau 
\q1  
\v 20 “Ashí nugkanum batsatutijum 
\q1 juwi kaunajum ijunjajum, antuktajum. 
\q1 Atumek anentainkachu ainajume, wainka 
\q1 apajuímtai numi dakumka najanamu makichkish 
\q1 atumin uwemtijamainchau emematjume. 
\q1  
\v 21 Tuja wainka apajuímtai dakumka najanamu 
\q1 emematjum dusha pegkejash aniajum nunú 
\q1 pempeentunikjum ininistajum. 
\q1 ¿Yaita juju waji aidau nagkaemagtinun pachis emtika etsegkaush? 
\q1 Makichik aentskesh juju waji nagkaemaina nuna pachis etsegkauk atsawai. 
\q1 Witjai Tuke Pujuuk juju waji nagkaemaina juniktinun yaunchuk emtikan etsegkaunuk. 
\q1 Tikich Apajuí mina nagkaetasuk makichkish atsawai. 
\q1 Apajuí pegkejam uwemtikagtinuk tikichik atsawai. 
\b  
\q1  
\v 22 “Tikich nugkanum atushat batsatutigmesh 
\q1 minai minitajum, wi uwemtan amastajime, 
\q1 witjai Apajuínuk tikich mina nagkaetasuk atsawai. 
\q1  
\v 23 Wika dekas umiktinjun tumamjai, 
\q1 mina shiwag aina nunak ijinatnaitjai, 
\q1 duka dekas imanisag uminkatnai. 
\q1 Tuja mina emtijui aents aidauk 
\q1 tikishmag batsamsag emematjuinak: 
\q1 ‘Dekas ametme jutii Apajuíjimek’, tujutiagtin ainawai. 
\q1  
\v 24 Tusa chichainak: 
\q1 ‘Pegkeg takata duka ima Tuke Pujuuwaig awai, 
\q1 tuja ima nigki senchigtinuk’ tujutiagtinai. 
\q1 Aents mina chichamjun umitan dakitujaku aina duka 
\q1 datsagkag wainak juwakagtinai. 
\q1  
\v 25 Ashí Israel aents aidauk wi yayamu asag, 
\q1 minak umigtuinak ima pegkeg takata nunak takagtinai”, 
\q1 tawai Tuke Pujuu, tiuwai Isaías. 
\c 46  
\s1 Babilonianmaya aidaun apajuímtaiji aina nujai diismak Apajuí ima senchigtinai 
\q1  
\v 1 Isaías chichaak: 
\q1 “Babilonianmaya aidaun apajuímtaiji Bel, Nebo, 
\q1 aina duka winchainag, nugka iyainawai. 
\q1 Tuja babilonianmaya aidauk, 
\q1 kuntin waji pataja jutai aidaunum dita 
\q1 apajuímtaiji aidaun patajag yajumainak, 
\q1 kijin asamtai kuntinjin waitkainawai. 
\q1  
\v 2 Nunik kijimainak nugka tukumak iyaak 
\q1 ajuajam ayamjumamainchau asag tsainak ajapnainawai. 
\q1 Nunin asagmatai tikich nugkanum yajumainawai”, tiuwai. 
\b  
\q1  
\v 3 Tuja Apajuí chichaak: 
\q1 “Jacob wegantu, Israel aents iwaku batsatutijum antuktajum: 
\q1 Wi atumnak eke akiintsugminig uchi pagkusa 
\q1 kuitamaina numamtuk kuitamkauwaitjime. 
\q1  
\v 4 Tuja atum múuntuch wajasjum jempejuja pujakjuminish, 
\q1 wi atumin najadau asan, yamai kuitamjim dutiksanuk kuitamkan 
\q1 uwemtijatnaitjime. 
\b  
\q1  
\v 5 “Wijai betek tikichik makichkish atsawai. 
\q1 Witjai tikich aina nuna nagkaesaunuk. 
\q1  
\v 6 Tuja awai aents kuashat oron, platan ikaunbau. 
\q1 Dutika ikaunamtai aents wainka apajuímtain 
\q1 dakumak najanin najanamtai, 
\q1 emematmi tusag nunú aentsun egainawai. 
\q1  
\v 7 Tuja nuna najanamtai, yanaki jukiag 
\q1 tuwi pujustatua nuwi ejegan apujuinawai, 
\q1 dutika apujkim makichkish buchittsuk pujawai. 
\q1 Nunik pujaun yaimpakti tusag, 
\q1 senchi untsukag segamash makichkish ayatsui, 
\q1 tuja waituinak nii ayamjutpakti tusa segamash 
\q1 makichkish ayamjumaitsui. 
\q1  
\v 8 Pegkegchaun takau aidauwah, 
\q1 juju adeagtajum, nuniakjum shiig anentaimjatajum, 
\q1  
\v 9 yaunchuk waji aidau nagkaemajua nunú adeagtajum, 
\q1 witjai Apajuínuk tikichik atsawai; 
\q1 witjai Apajuínuk, tikich wijai betekak makichkish atsawai. 
\q1  
\v 10 Tuja tsawan nagkanbaush wajuk atinaita nunak 
\q1 wika yaunchuk nagkamsan dekajai, 
\q1 tuja atakea duish 
\q1 waji nagkaemagtinaita nunashkam etsegjai. 
\q1 Wi wajina dutikatag tusanua wakegaja nunak 
\q1 wika imatiksanuk uminaitjai. 
\q1  
\v 11 Makichik aentsun tikich nugkanmayan 
\q1 etsa minitaiya nuwiyan untsukmajai, 
\q1 duka tuke chuwagjai betek atushtanmaya minittawai, 
\q1 nigka wi tabaun umiktatui. 
\q1 Tuja wi nuna dutikatin atajai tusan tiuwaitag nunak 
\q1 nii imatiksag umiktatui. 
\q1 Wi dutikatnujun chichaman umikuitag nunak tuke umiktatjai. 
\q1 Nunak dekas uminkatnun tajai. 
\q1  
\v 12 Chichaman antakchau, intimkiu aidautijum 
\q1 anentaimsajum, iik wamak agkanmagashtin 
\q1 ainaji tusajum tautijum, wi tajim nunú antuktajum. 
\q1  
\v 13 Wi atumnak wamak agkanmitkattajime, 
\q1 nunak shiig wamak dutikattajai. 
\q1 Tuja Jerusalégnum aents aidau batsata 
\q1 nunak wi ayamjukan agkanmitkattajai. 
\q1 Mina imanjua duka Israel aents aidaunum atatui”, 
\q1 tiuwai Apajuí. 
\c 49  
\s1 Tuke Pujuu minak dukuju wakeen egketaig yaunchuk nagkamas etegtuauwai 
\q1  
\v 1 “Yaakat múun nayantsan ijus ayá 
\q1 nuwi batsamin aidautijum, 
\q1 tuja tikich nugka múun aidaunum atushat 
\q1 batsamin aidautigmeshkam wi tajim nunú antugtuktajum: 
\q1 Tuke Pujuu minak eke akiintsaig etegtuauwai. 
\q1 Tuja mina dukuju wakeen egketaig mina daajun adaitujus untsugkauwai. 
\q1  
\v 2 Apajuí minak senchimtijua chichamtin, 
\q1 puyag etsakamu empekama iman, 
\q1 tuja flecha etsakamu tsakaskatuama iman awajtusmayi. 
\q1 Dutijua makichik waji ejaka kuitamaina numamtuk kuitamjukmayi. 
\q1  
\v 3 Tuja nii chichagtak: 
\q1 ‘Israel aents aidauwah, atumek mina inakeg ainagme, 
\q1 atumiin mina senchignak iwainaktatjai’, tujutmayi. 
\q1  
\v 4 Tuja wi anentaimsan chichaakun: 
\q1 ‘Pegkegnakesh jukitnunig wainka takakun waitiajai’, tibaijai. 
\q1 Tujash wi takasbaunum jukitnujuk Tuke Pujuu 
\q1 senchigtina nuwi amayi. 
\b  
\q1  
\v 5 “Israel aents Jacob wegantu aidau 
\q1 pampagka batsata nuna yajuak 
\q1 atak awakeag ikaunmati, 
\q1 dutikak mina takagtusti tujutu asa, 
\q1 wika eke akiintsaig, Tuke Pujuu minak wait anenjug, 
\q1 yaunchuk nagkamas etegtuauwai. 
\q1  
\v 6 Tuja nii chichagtak: 
\q1 ‘Wika aminak mina inakeg ati, nuniak 
\q1 Jacob wegantu aidau achija yajuakam nugken ukukiag, 
\q1 tikich nugkanum batsata nuna ataktu awakeag, 
\q1 dita nugken ikaunmati tusanuk ima nunakek tatsugme. 
\q1 Tuja ashí tikich aents judíochu aina nuwishkam 
\q1 tsaaptinun iwainakti titatjame. 
\q1 Ashí tikich nugka aidaunum mina chichamjun etsegkati, 
\q1 nunitai ditashkam uwemjatnume tusa’, tujutmayi. 
\q1  
\v 7 Tuke Pujuu uwemtikagtin, 
\q1 Israel aents aidaun Apajuíji pegkegma nunú, 
\q1 niina aentsji tikich nugkanmaya aidau kajejam, 
\q1 wainka inaku waitkatai batsata nuna chichajak: 
\q1 Wi atumnak etegkauwaitjim nuadui apu aidauk 
\q1 niina atuwe aidaujai atumi waipakag, 
\q1 eme anenjamsag, atumi emtimin tikishmag pujusagtinai. 
\q1 Nuadui wi atumin anagkuawaitjim nunak 
\q1 imatiksanuk umiktatjai.” 
\s1 Jesuralén tsaikbauwa nunú ataktu yaaktamatin pachisa etsegkamu 
\q1  
\v 8 Tuke Pujuu chichaak: 
\q1 “Wi wait anenkagtamu tsawan jegau asamtai, 
\q1 untsugkugmin aikmaijime, 
\q1 uwemain tsawan jegagtamiaju asamtai, 
\q1 wi yaigbaijime. 
\q1 Wi atumnak tikich aents aina 
\q1 nuna nagkaesau agtinme tusan etegkauwaitjime. 
\q1 Nuadui atum Israel aents aidautigmek 
\q1 atumi nugkemin ataktu waketjattagme, 
\q1 nunika jegajum atumi shiwaajum aidau 
\q1 yaaktan tsaikajua nunú ataktu yaaktamkatnaitjume. 
\q1  
\v 9 Tuja aents aidau achijam chimpija nunú chichagkujum: 
\q1 ‘Yamaik agkan wajasugme, 
\q1 tuja suwenum batsatutigmeshkam tsaaptin wainkatajum, 
\q1 nunikjum jinta yantamenig chijichi pegkeg ayau wainkattagme. 
\q1 Tuja muja uwegshunmash baka aidaun 
\q1 yumainjig kuashat aittawai’, titajum. 
\q1  
\v 10 Atumek nujantaish tuja kitakaish, etsa sukupainakuish, 
\q1 seekiyaish, makichkish waittsashtin ainagme. 
\q1 Wi atumnak aneau asan uyuntsattajime, 
\q1 tuja nuigtushkam yumi pukuni kuashat jiinaidaun amastinaitjime. 
\q1  
\v 11 Muja aina nunak yumpuajan pakaman, 
\q1 shiig iwaja jintaman esekan tutupit dakuejan umiktatjai. 
\q1  
\v 12 Tuja Israel aents aidautigmek tikich 
\q1 nugka nagkatkamunum atushat batsatutijum 
\q1 juwi kaunatnaitjume. 
\q1 Untsu tikich aidauk nugka Sinim\f + \fr 49:12 \ft Nugka “Sinim” tawa nuna daajig yamaik, “Asuán” adaikamui, nuadui tikich versiónnumak Asuán agagbauwai.\f* batsatu kaunatnai. 
\q1  
\v 13 ¡Nayaimpih, shiig aneakjum kantamatajum! 
\q1 ¡Nugkah, shiig aneasta! 
\q1 ¡Muja aidauwah, shiig aneakjum untsumkatajum! 
\q1 Wagki Tuke Pujuu niina aentsji waituinak 
\q1 wake besemag batsatun, 
\q1 wait anentug anentai ichichtuju asamtai. 
\b  
\q1  
\v 14 “Atum Jerusalén batsamsajum chichaakjum: 
\q1 ‘Tuke Pujuuk jutiinak kajimatjamki idaitamsae’, tuyugme. 
\b  
\q1  
\v 15 “¿Nuwa nii jujegbaujinash wait anentsukesh kajimatkish idainukaih? 
\q1 Nuwa nii jujegbaujin kajimatki idaisaintai, 
\q1 tujash wika aminak makichkish kajimatkinuk idaisashtatjame. 
\q1  
\v 16 Atumek mina aentsug ainajume, 
\q1 mina uwejui agaja takaku amainaitag numamtin ainajume. 
\q1 Jerusalén peeja tenteamu tsaikbauwa nuna tuke anentaimtajai. 
\b  
\q1  
\v 17 “Shiwag aidau Jerusalégkan 
\q1 wamak tsaikajua nuni senchi shiig wamkeuch 
\q1 ataktu jegamjajum yaaktamkatin ainajume. 
\b  
\q1  
\v 18 “Jerusalén batsatutigmek pagkaijum, 
\q1 ashí yantamnum niimsatajum, 
\q1 Israel aents aidau achija yajuakbau aidau 
\q1 ataktu waketug Jerusalén kaunainawai. 
\q1 Junak dekas uminkatnun wi Tuke Pujuun tajai. 
\q1 Dita nunik waketiagtai, nuwa aishinatin tsawan jegamtai, 
\q1 iwagmamak patakumtain patakumama numamtuk Jerusalégkak wajaktatui. 
\q1  
\v 19 Atumi nugkem tsaikam pegkegchau wajas amayi, 
\q1 tujash nuna dutikau aina duka yamaik ukukiaje. 
\q1 Nuadui nunú nugkanum kuashat aents piyakmatai, 
\q1 tikich aents pujumain agkauk atsutnai. 
\q1  
\v 20 Atumi uchijum aidau megkaejamtai, 
\q1 kajimatki idaisamu aidau kaunawag chichagtamainak: 
\q1 ‘Juju nugkak tikima piipich asa ijunja pujumaitsui. 
\q1 Nunin asamtai tikich nugka sukagtusta nuwi pujusagmi’, 
\q1 tujamiagtatui. 
\q1  
\v 21 Tujamainakui atum chichaakjum: 
\q1 ‘¿Ya iinash uchinash imatikash amase? 
\q1 Iik kuashat uchigtuchu ayaji, 
\q1 nuigtush uchijinmainchau ayaji, 
\q1 iik uchiji yajutka ukukim uchigtuchu juwakuitji. 
\q1 Tujash ¿jusha tuwiya kaunae? 
\q1 ¿Jusha ya kuitamkam tsakakuita?’ titinaitjume”, tiuwai. 
\b  
\q1  
\v 22 Nuadui Tuke Pujuu apu chichaak: 
\q1 “Wi nugka múun aina nunak 
\q1 wainchatai ishamain aidaun iwaintuktatjai, 
\q1 dutika ai, nuna wainkag atumi uchijum aidaun, 
\q1 nawanjum aidaun shiig kuitamas yanaki jukiag 
\q1 ikaunmatnume titatjai. 
\q1  
\v 23 Tuja atumek apu aina nunú apajimattagme, 
\q1 untsu apu nawanji aidauk 
\q1 atumi nawanjuchijum aidaun kuitamin agtatui. 
\q1 Nuninak atumin tikishmatjamjag 
\q1 dawem bika wajasun dukatjamiagtinai. 
\q1 Nuninakui anentaimsajum, 
\q1 dekas Tuke Pujuuk pujawapi titatjume. 
\q1 Tuja mina dekaskeapi tujutuidauk tsanuamak achagtinai. 
\b  
\q1  
\v 24 “Aents wajiu maanitan yacha asa, 
\q1 maania depetmak waji jukimujia duka kakajus atanmaitsui. 
\q1 Tuja aents maaniaku achikmauwa dushakam 
\q1 aents wajiun tsanug ukukig tupikaumaitsui. 
\q1  
\v 25 Tujash Tuke Pujuu chichaak: 
\q1 Aents senchigtin maania depetmak, 
\q1 waji aidaun yajuakbaujinak atanjagtinai, 
\q1 tuja tikich aents wajiu aentsun achika 
\q1 jukiuwa nunashkam atankiagtinai. 
\q1 Tuja atum Israel aents aidautigmin 
\q1 utugchatan itagtamainakuig, 
\q1 wi atumi uchijum aidaunak ayamjuktinaitjai. 
\q1  
\v 26 Dutikakun ditak pempeentumakiag yumamatnume, 
\q1 nuninak dita numpenak uwag vinojai betek 
\q1 nampegtinme titatjai. 
\q1 Dutika ai ashí aents nugkanmaya aidauk 
\q1 wi Tuke Pujuu, amina uwemtikin Jacopan Apajuíji 
\q1 senchigtinaitag nuna dekawagtatui. 
\q1 Witjai amina ayamjukan agkanmitkaunuk”, 
\q1 tiuwai Apajuí. 
\c 50  
\p  
\v 1-3 Nuigtushkam Tuke Pujuu chichaak: 
\b  
\q1 “Israel aents aidauwah, 
\q1 wika atumin egaknush wainkachmaijime. 
\q1 Untsukmaijime, tujash aigkashmaijume. 
\q1 Wika atumnak pachitskek idaisachuitjime; 
\q1 tuja mina diwig akikmaktinun kuichkin jukitag tusankesh 
\q1 wainka inaku waitkatai atinme tusanuk sujukchabiajime. 
\q1 Wika atumi tudaugmin idaisabiajime. 
\q1 Tujash atum waitu batsatjum nuna 
\q1 jiiki uwemtikmainuk mina senchijuk ajutui. 
\q1 Aents patayi jakamtai, jáanch bukusean nugkuwama 
\q1 numamtuk nayaimpinak wi bukuseayai dukukan idaijai. 
\q1 Tuja nayants, nuigtu namak aina nunú kuyuatag takug 
\q1 wi nunikti tusan machikiuch tamawaitak kuyumainai. 
\q1 Nunik yumi buku wajasmatai, 
\q1 namak aidau jinaa kaukti tusa nunak nunimainai”, tiuwai. 
\b  
\q1  
\v 4 Tuke Pujuu, apu, minak aents pimpiki 
\q1 batsatun jintintua anentain ichichtugti tusa unuitugmae. 
\q1 Tuja aents chichaman antuk betek umiauk 
\q1 jintintayama duwi minak Apajuí kashi kashinig 
\q1 tuké kashikmas inaantawai, 
\q1 niina chichamen antuk unuimagti tujutu asa. 
\q1  
\v 5 Tuke Pujuu, apu, minak chichama umin ati tusa 
\q1 jintinjuauwai. 
\q1 Nuadui wika niina intimjuknuk umigtsukek idaisachmaijai. 
\q1  
\v 6 Mina tuntupjui asutuinakuish, 
\q1 asutuatnume tusan idaisabiajai, 
\q1 susujun uwegtuinakuish, idaisabiajai. 
\q1 Dushiktuinak yapijui usuktuinakuish, 
\q1 yapignak ejakchabiajai. 
\q1  
\v 7 Tuke Pujuu, apua nunuwai mina yainta duka, 
\q1 nuadui pegkegchaun chichagtuina nunak 
\q1 wika najaimatsjai. 
\q1 Nuadui wika kaya múun umuchmainchawama iman 
\q1 wajasan pujuyajai, 
\q1 nuadui wika wainka inatsamak achattajai. 
\q1  
\v 8 Mina ayamjutna duka wijai pujawai. 
\q1 Tuja ¿wi pegkegchau takamsamujun etsegtugmainush yaita? 
\q1 ¡Nuna dekau akuig, apu chichaman epegkin 
\q1 pegkeg puja nuwi wemi! 
\q1 Wi pegkegchau takamsamun dekau akug nuwi tantati. 
\q1 ¡Nunik mina igkuntua tujutti! 
\q1  
\v 9 Tuke Pujuu, apu, minak kuitamjawai, 
\q1 mina achijuk suwimka sujumainuk makichkish atsawai. 
\q1 Mina shiwag aina duka jáanch mamuk yuwam 
\q1 megkagama numamtuk megkaejagtinai. 
\c 52  
\s1 Jerusalégnumia aents aidaunak agkanmitkattajai tusa Apajuí tibau 
\q1  
\v 1 Jerusalégnumia aidautijum aneaku niimkau pujustajum, 
\q1 Jerusalén yaakat pegkegma nuwi batsatutigmek wajiu wajastajum, 
\q1 nuniakjum shiig iwagmamkatajum, 
\q1 wagki Apajuín umigchau aents pegkegchau aina duka 
\q1 ataktu awagkig atumnak jetepakchagtatui. 
\q1  
\v 2 Jerusalégnumia aidautijum 
\q1 nugká pushugkajum batsatjum duka, 
\q1 datsaamtsuk wajakjum jáanchjum pegakjum yantsaptuktajum, 
\q1 nunikjum apu niina inamtaijin ekemaina numamtuk ekemsatajum. 
\q1 Tuja datsauch aidautigmesh, achija yajuakam 
\q1 batsabaijum nunisjumek yamaikish batsamtsuk, 
\q1 agkanmagatajum. 
\b  
\q1  
\v 3 Tuja Apajuí chichaak: 
\q1 “Atumin achipag yajupakajua nunak minak akigkachu ainawai. 
\q1 Nuadui wishakam atumin awakeaknuk makichkish akikmakchattajai. 
\q1  
\v 4 Yaunchuk mina aentsug aidau Egipto nugkanum shiyakag 
\q1 nugkenchau inaku waitkatai batsamajaku ainawai. 
\q1 Tuja tikich tsawantinchakam makichkish 
\q1 utugchatji atsujunak asirianmaya aents aidau 
\q1 senchi waitkasaju ainawai. 
\q1  
\v 5 Tujash yamaish ¿wagka imatikash waitkainawah? 
\q1 Mina aentsug aina nunak utugchatji atsujunak 
\q1 Babilonia nugkanum yajuakaje. 
\q1 Dutikawag nuna apuji aidau waitkainak 
\q1 ememas chichainak kashi kashinig kajemtijuinawai. 
\q1  
\v 6 Tujash tsawan jegattawai, 
\q1 mina aentsug aidau mina shiig waitkagtina nunú. 
\q1 Nunik waitkag adeajagtinai, wi ditan chichagkun: 
\q1 ‘Witjai apunuk’ tiuwaitag nuna”, tiuwai Apajuí. 
\q1  
\v 7 Aents mujanmaya akaiki wekagas yamajam chichaman 
\q1 agkanmaetan uwemtajai pachis etsejak wekagas, 
\q1 Jerusalégnumia aents aidaun chichajak: 
\q1 “Atumin Apajuíjiyai dekas apuk”, 
\q1 tusa etseja duka shiig anentam auwai. 
\q1  
\v 8 Atumi suntajum jinta niimin aidau 
\q1 Tuke Pujuu Jerusalégnum wakitki midaun wainkag 
\q1 shiig aneenak untsumaina nunú ¡antuktajum! 
\b  
\q1  
\v 9 ¡Jerusalégnumia aidauwah, 
\q1 Tuke Pujuu niina aentsji aidaun wait anentug 
\q1 Jerusalégnashkam agkanmitka duwi 
\q1 nii eme anentsajum kantamtai shiig aneasjum 
\q1 senchi kantamatajum! 
\q1  
\v 10 Ashí aents tikich nugkanmaya aidaush 
\q1 wainainamunum Tuke Pujuu niina senchijin iwainake. 
\q1 Tuja Apajuí iina uwemtijamja nunak ashí nugkanum dekawagtinai. 
\q1  
\v 11 ¡Babilonia nugkanum batsatjum duka 
\q1 jiinjajum ukuktajum! 
\q1 ¡Tuja Tuke Pujuu jeen takastin waji aidau 
\q1 ikaunmatnutigmek kuitamamkatajum, 
\q1 pegkegchau takasaigpa! 
\q1  
\v 12 Tujash wainkajum waugtukaigpa, 
\q1 tuja uumkagmekesh tupikakigpa, 
\q1 atumi aintamuk atsawai. 
\q1 Tuke Pujuu, Israelan Apajuíjiya nunú atumnak 
\q1 kuitamjamainawai. 
\s1 Tuke Pujuun inakeg waitiakush nii yayasam depetmawai 
\q1  
\v 13 Mina inakjuk ashí depetmaktinai, 
\q1 nuadui tikich aidaun nagkaesau eme anentam atinai. 
\q1  
\v 14 Kuashat aents aidau niina yapin diigsag puyatkagtinai, 
\q1 wagki yapi emestujam aents niimtinchau 
\q1 wajasu asamtai. 
\q1  
\v 15 Tuja aents tikich nugkanmaya aidaushkam 
\q1 senchi puyatkagtinai. 
\q1 Tuja apu aidauk nuna wainkag makichkish chichakchagtinai, 
\q1 wagki nunak yaunchkesh antushtain antuinak, 
\q1 waintanashkam wainaidau asag. 
\c 53  
\p  
\v 1 ¡Ii etsegbaunak makichik aentskesh dekaskeap tawa 
\q1 tichau ainawai! 
\q1 ¡Apajuí senchijinak makichik aentskesh wainkachui! 
\q1  
\v 2 Apajuí niina inakenak ajak yama tsapaak kagkape 
\q1 nugka katsugmanum init akagama nunikti tiuwai. 
\q1 Nunú aentsuk imanchauch, eme anentsa diimainchau, 
\q1 nuigtush wait anenmainkesh atsayi. 
\q1  
\v 3 Ashí aents aidauk niina tsumainak dakitianume. 
\q1 Niyai dekas senchi najaimak waittsauwa duka. 
\q1 Niig waitiakush, waitiajai tichauwai, 
\q1 wagki tuke unuimatjau asa. 
\b  
\q1 Nuadui makichik aents ii dakitamu diimaitsu dutikiaji. 
\q1 Tsuwaaja idaisabiaji, nuadui puyatjusaikish diischauwaitji. 
\q1  
\v 4 Tujash niig dutikamaitak ii waitiamujinak nii yajuakmayi, 
\q1 tuja iina najaimatai aidaunak nii yajuakmayi. 
\q1 ¡Iik niina pegkegchaujinis aents aidau eemtin 
\q1 Apajuí suwimak susam waitiatai tuyaji! 
\q1  
\v 5 Niinak iina katseken nagki ijuajui, 
\q1 tuja iina tudaujin shiig senchi waitkasaju ainawai. 
\q1 Nii waittsamunum agkanmagat jukimui, 
\q1 tuja nii ijunbaunum iinak etsaentamjauwai. 
\q1  
\v 6 Tuja yaunchkek iik uwig kuitamkacham wagaka 
\q1 wekagama numamtuk aayaji. 
\q1 Tujash yamaik Tuke Pujuu iina tudaujinak 
\q1 niyai akikmatjamkauwai. 
\q1  
\v 7 Niinak shiwag aidau shiig senchi suwimawagmayi, 
\q1 imatikamash niig ayatak yunumkabi, 
\q1 nuniak makichkish chichakchabi, 
\q1 uwig maatasa juki ematia numamtuk 
\q1 jukiag emagmayi maatasag. 
\q1 Tuja uwig uje tsupigmash takamtak tepegama numamtuk 
\q1 makichkish chichakchabi. 
\q1  
\v 8 Pegkegchaun takamsachunak achikag jukiagmayi, 
\q1 dutika juwagtaish niina ayamjumainuk makichkish atsubi. 
\q1 Tuja niinak makichkish puyatjukchagmayi, 
\q1 ayatak ajak ajaamu tegai ajapmaina numamtuk, 
\q1 mina aentsug aidau tudaujin maawagmayi. 
\q1  
\v 9 Niig makichkish magkagtuachu aig, 
\q1 tuja waitjutnakesh waitjuachu aig, 
\q1 aents pegkegchau aidau jinau ukusbaunum 
\q1 nuna yantamen ukusagmayi. 
\q1  
\v 10 Nunak Tuke Pujuu dutik waitkastajai tusa wakekauwai. 
\b  
\q1 Niig aents aidau tudaujin waittsau asa, 
\q1 kuashat mijan jatsuk iwaku pujus, nii wegantu aidaun 
\q1 uchiji wegantu aidaunak ashí wainjatnai. 
\q1 Tuke Pujuu nii dutikatnujin anentaimtujua 
\q1 duka nunú aents waittsamunum betek uminkatnai. 
\q1  
\v 11 Imanik waitus nagkaikiu asa, 
\q1 dekaattawai dekas Apajuí umigbau ima pegkeja nuna, 
\q1 nunik shiig aneas juwaktinai. 
\q1 Apajuín inake chichaman betek umina nunú aents aidau 
\q1 tudaujinak entsaktinai, dutikak agkanmitkatnai. 
\q1  
\v 12 Nuadui Apajuí niinak senchigtin 
\q1 ashí eme anentsa diitai awajsattawai. 
\q1 Wagki niig pegkegchau takamsachuitak, 
\q1 pegkegchaun takamsaujai betek, 
\q1 aents aidau uwemjatnume tusa, dita tudaujin 
\q1 dita mantamnamainun nii mantamdauwa duwi. 
\c 54  
\s1 Tuke Pujuu anenkeg atakesh nagkankashtinai 
\q1  
\v 1 Isaías chichaak: 
\q1 “Nuwa uchin uchigmachu aidauwah, 
\q1 shiig aneakjum kantamtai senchi kantamatajum, 
\q1 Apajuí chichaak: 
\q1 ‘Nuwa uchin uchigmachu asamtai, 
\q1 idaisamua duka aishinnun nagkaesau uchigtin atatui’, tawai. 
\q1  
\v 2 Israel aents aidauwah, 
\q1 atumin aakjum aina nunú puyattsuk 
\q1 nuni senchi múun awajsatajum, 
\q1 dutikajum daek esajam yajuakjum 
\q1 nunú achimtika jigkaktin numi shiig ajigtajum. 
\q1  
\v 3 Ame wegantu aidauk shiig kuashat yujaktatui, 
\q1 nunikag tikich nugkanum shiyakag 
\q1 makichik yaaktakesh atsaunum dita yaaktamak 
\q1 batsamsagtinai. 
\q1  
\v 4 Ishamkagtukaipa, wainka pegkegchau chichagmak 
\q1 achatnaitme, dushikiamash achattame. 
\q1 Datsa asam uchijum atsau asamtai, 
\q1 dushikiam wekaeyum duka kajimatkita. 
\q1 Ame wajemea pujamin dushiktamainakui, 
\q1 datsaamin ayum duka yamaik nunikchattame. 
\q1  
\v 5 Wagki Apajuí amina najapauwa nunú 
\q1 nuwa nuwatkamujai betek awajtamsattawai. 
\q1 Niina daajig Tuke Pujuu ashí senchigtin tutayai. 
\q1 Amina ayamjutpak uwemtijamna duka 
\q1 Israela Apajuíji pegkejam ashí nugkan jajutua awai. 
\q1  
\v 6 Amek nuwa muntsugtaitak idaisam pujus 
\q1 waitu pujuuwama numamtuk waitu pujubiume. 
\q1 Tujash niina aishi ataktu awagki tsagkujug 
\q1 jumaina numamtuk, 
\q1 Apajuí untsugmawai midau ati tusa, 
\q1 nuadui juna aatus tujamui: 
\q1  
\v 7 ‘Ujumchik tsawantai pachitsuk idaisamjame, 
\q1 tujash wika wait anenkagtinaitag iman asan, 
\q1 ataktu awagkin minai itattagme. 
\q1  
\v 8 Amina kajegkan, ujumak tsawan uumjukan idaisamiagme. 
\q1 Tujash makichkish kajimatmainchaun aneau asan, 
\q1 wait anenjabiagme’, 
\q1 tusa Tuke Pujuu amina uwemtijamjauwa nunú tawai.” 
\b  
\q1  
\v 9 Tuja junashkam Apajuí chichaak: 
\q1 “Yumi ashí nugkanum piyajua nunú tsawantin 
\q1 wi Noén chichagkun: 
\q1 ‘Ataktu awagkinuk nugkanmak yuminak 
\q1 pimumtijashtinaitjai’ tiuwaitag dutiksanuk yamaishkam tajai. 
\q1 Ataktuk aminak kajegkashtatjame, 
\q1 tuja awantanashkam awankashtatjame. 
\q1  
\v 10 Muja aidau tikich yantamnum shimakuish, 
\q1 tuja yumpuna kakekuish, 
\q1 wi amina aneajam nunak anentaignak yapajiashtinaitjai, 
\q1 tuja utugchat akuish, epegkea pujutai atinun 
\q1 chichaman umikuitag dushakam yapajinashtinai, 
\q1 tusa Tuke Pujuu 
\q1 amina wait anenjamja nunú tujamui”, 
\q1 tiuwai Isaías. 
\s1 Yamajam Jerusalén 
\q1  
\v 11 Apajuí chichaak: “¡Jerusalégkah, 
\q1 aminak anentaimin ichichtugmatsuk kajimatki idaitamsagmatai, 
\q1 dase tukua tukuam pegkegchau wajasum nunak 
\q1 ataktu nagkaman iwajattagme! 
\q1 Dutikakun kaya zafiron aepkan nuwi ekenin 
\q1 kaya pegkejuch akik aidauwai peejan umiktatjame. 
\q1  
\v 12 Kumpin aidaunak kaya rubí tutayai najanattajai, 
\q1 tuja waiti aidauk kaya berilo tutayai najanamu agtatui. 
\q1 Untsu yaaktanak kaya pegkejuch aidauwai peejattajai. 
\b  
\q1  
\v 13 “Amina uchijum aidaun, 
\q1 nawanjum aidaujai ashí jintintuattajai, 
\q1 dutika ai, ditak agkan shiig batsamsagtinai. 
\q1  
\v 14 Amek shiig takauwaitam duwi senchi atatme, 
\q1 nuadui makichik aentskesh inapakug waitkagmaschatnai. 
\q1 Tuja sapigmamush atsugtamtinai, 
\q1 ishamain antakum sapigmam duka ataktuk 
\q1 sapigmakchatnaitme. 
\q1  
\v 15 Makichik aentskesh jetepakug, 
\q1 wi inagbau asagkesh jetepakchatnai, 
\q1 dutijamkuish duka ame depetkatnaitme. 
\b  
\q1  
\v 16 “Juju shiig antukta: 
\q1 Aents jiju ukuiyag najanin aina nunak wi najanauwaitjai, 
\q1 tuja aents magkagtak utugchatan 
\q1 aepin aina nunashkam wiki najanauwaitjai. 
\q1  
\v 17 Tuja wi najankauwaitag nuna nagkaesaun magkagtutai 
\q1 amina mantamainun najanauk makichkish atsawai. 
\q1 Nuadui amina mantamatag tuidauk ashí depetkam 
\q1 itatmikagtinaitme. 
\q1 Wika mina inakeg aidaunak: 
\q1 ‘Depetmatan suwajai’ ” tusa Tuke Pujuu tiuwai. 
\c 55  
\s1 Apajuí niina aentsji aidaun ijumjatin 
\q1  
\v 1 Apajuí chichaak: 
\q1 “Aents kitamauk minai taa uwagti. 
\q1 Kuichik atsugbau aidauk minai kaunawag 
\q1 trigo, vino, leche aidaun akikmatsuk yuwatnume. 
\q1  
\v 2 Waittsa takasa kuichik jukimua duka 
\q1 yutai sumaka yuwa yapajamu megkaekashtinaitkuik, 
\q1 wainka akikmakaik ajapmaitsui. 
\q1 Wi tajam nunú antukam yutai pegkeg yuwatnaitme. 
\b  
\q1  
\v 3 “Juwi minai kaunajum wi titatjim nunú antuktajum, 
\q1 nuniakjum iwaku pujustajum. 
\q1 Wi Davita aneau asan anagkuawaitag nuna 
\q1 umiakun, atumjai chichaman umiktatjai 
\q1 atakesh yapajinashtin tuke asatnun. 
\q1  
\v 4 Juju shiig antuktajum, 
\q1 wi niinak mina chichamjun ashí tikich nugkanmaya aidaunash 
\q1 jintintuati tusan apu awajsauwaitjai. 
\q1  
\v 5 Israel aents aidauwah, 
\q1 aents tikich nugkanmaya aidau untsuktinaitjume. 
\q1 Dutikawagmin atumin waipachu ainayatak, 
\q1 tupi tupikainakua kautjamawagtinai. 
\q1 Wi nunak atumin wait anenjamjatnume tusan dutikattajai. 
\q1 Witjai Tuke Pujuu, Israel aents aidaun Apajuíji pegkegmanuk. 
\q1  
\v 6 Tuke Pujuu wainkatag takugmek yamaikiuchia duik egaktajum, 
\q1 tuja tikijuch puja duik untsutash untsuktajum. 
\q1  
\v 7 Pegkegchaun takau aina duka nuninun wekaetutsuk idaisati, 
\q1 tuja pegkegchaun anentaimtin aina dushakam nunak idaisatnume. 
\q1 Ataktu wakitkijum Tuke Pujuu tsagkugkagtina nuwi minitajum, 
\q1 nuniagmin nii wait anenjamjagtatui.” 
\p  
\v 8 Tuke Pujuu chichaak: 
\q1 “Wika atumjai betekak anentaimtsujai. 
\q1 Nuigtush wi takamua duka atum takajum nujaig betekchauwai. 
\q1  
\v 9 Tuja mina anentaimtajuk, 
\q1 atumi anentaimtajin nagkaesauwai, 
\q1 mina takatjushkam atum takajum nuna nagkaesauwai”, 
\q1 tusa Apajuí tujamui. 
\q1  
\v 10 Yumik nayaimpinmaya yutawai, 
\q1 nunikash ataktuk nayaimpinmak wakettsui, 
\q1 ayatak nugkan uchupig ajak tsapamain emawai, 
\q1 dutikamtai ajak aidau tsapawai, 
\q1 nunik nejeku juuka yutayama 
\q1  
\v 11 numamtuk mina chichamjushkam 
\q1 wi tibau umintsukek, 
\q1 tuja wi wakegamua nunashkam dutiktsukek 
\q1 wakitkig minaig waatsui. 
\q1  
\v 12 Atum achija yajuakam batsatjum duka 
\q1 jiinjajum agkan shiig aneasjum, 
\q1 atumi nugkemin waketjajum kaunattagme. 
\q1 Nunika kaunajum muja aidau wainkujum, 
\q1 shiig aneasjum senchi kantamtinaitjume. 
\q1 Atum imatjumin muja aidauk, numi aidauk, 
\q1 aentsjai betek uwejen awatiagtinai. 
\q1  
\v 13 Atumi nugkemin jagki ayá nunú jinaamtai, 
\q1 pino aidau tsapaktinai, 
\q1 tuja naja jinutai arrayán aidau tsapaktinai. 
\q1 Nuna wainainak ashí aents nugkanmaya aidauk 
\q1 Apajuín emematiagtinai. 
\q1 Apajuí niina senchijin umikbaunak makichkish 
\q1 tsaikchagtin ainawai. 
\c 58  
\s1 Ijagma pujusa Apajuí segamu 
\q1  
\v 1 Apajuí mina chichagtak: 
\q1 “¡Ishamkagtutsuk senchi untsumkata, 
\q1 uwija kachuji shinaujai betek senchi chichakta! 
\q1 ¡Imatkum mina aentsug Jacob wegantu aina nunú 
\q1 pegkegchaun takamsamuji pachisam senchi chichagkata! 
\q1  
\v 2 Dutikakum tita: 
\q1 ‘Atumek minak kashi kashinig untsugjume, 
\q1 nuniakjum chichama umin najaneajum 
\q1 mina umigtuktasajum wakegagme. 
\q1 Nuniau asajum ii chicham uminkatna nunú 
\q1 sukagtusta tusajum segatjume, 
\q1 nuniakjum shiig aneagme Apajuí umigji’ tusajum. 
\q1  
\v 3 Tusa tayatkujum: 
\q1 ‘¿Wagkaik wainkaish Apajuí waipatsu nuniaish 
\q1 ijagmash pujutji? 
\q1 ¿Wagkaik ijagmaish waitush wekaetaji Apajuí waipatsu 
\q1 nuniaish?’ tajume. 
\q1 Tau asajum atumek ijagma pujusa Apajuí segatia 
\q1 nunú tsawantin waji sujakjum, 
\q1 atumi takagtamin aidaushkam shiig akitsuk kasagjume. 
\q1  
\v 4 Atumek ijagma pujusa Apajuí segatia 
\q1 nunú tsawantin jiyaniakjum, maaniakjum ijuni batsatjume. 
\q1 Apajuí atum ijagma pujusa segamun 
\q1 antugtukti takugmek, a antajaig takamaitsugme. 
\q1  
\v 5 Ijagma pujusa Tuke Pujuu segaji tayatku, 
\q1 imani batsatmawa duka Apajuínak shiig awagmatsui. 
\q1 Atumek kajis namaka uwet kasua wajama nunikjum 
\q1 tsuntsuma pujusjum, jáanch wake besemag pujaku 
\q1 nugkutai nugkugjum yukunum tepajum nunú, 
\q1 ijagma pujusa Apajuí segaji, tajume. 
\q1 Nuniakjum juju Tuke Pujuunak shiig awagmawai, tajume. 
\q1  
\v 6 Tujash duka dekaskechui. 
\q1 Mina shiig awajkati tujutkugmek, 
\q1 ijagma pujusam: 
\q1 Aents achikam chimpija nunú agkanmitkata, 
\q1 takamsachu aig jigkajam batsata nunú atiam agkanmitkata, 
\q1 inaku waitkatai batsata nunú agkanmitkata. 
\q1 Dutikakum shiig takashtai, pegkegchau aina duka 
\q1 ashí idaisatajum. 
\q1  
\v 7 Nuniakjum, atumdau yutai ajutjamaina nunú 
\q1 tikich aents nujantai waituidau ajamsatajum; 
\q1 tuja aents jenchauwa duka atumi jem jukitajum; 
\q1 tuja nugkumainji atsakuishkam, 
\q1 jáanch susatajum nugkugti. 
\q1 Dutikakjum tikich aidaushkam tuké yaitajum. 
\q1  
\v 8 Nunú dutikakjumek, kashikmas etsa jiinak 
\q1 etsantama iman atatjume. 
\q1 Nuniagmin mina imanjua nunú uyuntamsagtatui. 
\q1 Tuja pegkegchau takataijum aidau tsupimakbaujai betek wajas awa 
\q1 duka wamak esamattawai. 
\q1  
\v 9 Nunikmatai untsugkugminig aiktatjime; 
\q1 tuja yainkata tusajum senchi untsugkugminishkam, 
\q1 wi ayaakun: ‘Juwi pujajai’, titatjime. 
\q1 Tikich aents aidau waitkajum nunú idaisajum 
\q1 pegkegchau chichagtsuk, nuigtush wainka tsanumjutsuk, 
\q1  
\v 10 yumainji atsujush amek anenmamsam ajampeakum, 
\q1 tikich waituidau yayakjumek, 
\q1 suwenum jii kegak tsaaptin emama numamtin atatjume. 
\q1 Tuja amina pegkegchaujum suwe wajas awa duka, 
\q1 yamai pegkeg takagmin, etsa tutupit wegak 
\q1 etsantug tsaaptin emama iman wajastatui. 
\q1  
\v 11 Wi aminak tuké uyuntsattagme, 
\q1 dutikakun uwegshunum pujakminish, 
\q1 shiig kuashat yutain amastatjame, 
\q1 dutikakun senchimtikattagme, 
\q1 nuadui ajak ajakbau yumi ukattai asa pegkejama iman, 
\q1 nuigtu yumi pukuni jiinu tuke amuechau ama iman atatjume. 
\q1  
\v 12 Atum wegantu aidau 
\q1 yaakat yaunchuk tsaikbau aidaun ataktu jegamjagtinai. 
\q1 Dutikainak nunú jegamku kaya aepkamu aidau 
\q1 yumpunawai tusa shiig emetug umikagtinai. 
\q1 Dutikau asagmatai: 
\q1 ‘Yaakat peejamu tsaikbaun ataktu iwajin aidau’, 
\q1 nuigtushkam: ‘Jega tsaikbaun iwajin aidau’ 
\q1 tuu adaikagtinai.” 
\s1 Ayamtai tsawan pachisa jintiamu 
\q1  
\v 13 “Tsawan ayamtaya nunú ajantusjum diistajum, 
\q1 tuja mina tsawantug pegkegma duik 
\q1 atumi takatjumek takasaigpajum. 
\q1 Nunú tsawanta duwi shiig aneasjum ima Tuke Pujuu 
\q1 pegkegma duke ememattajum, tibauwa nuwi anentaimsatajum. 
\q1 Nunú tsawantin atumi takatjum, 
\q1 nuniachkush atum wakegamukesh 
\q1 chichamju yujatsuk ayatak ajantusa diistajum. 
\q1  
\v 14 Nunú umiakjuminig, 
\q1 shiig aneasa pujutan wi amastatjime. 
\q1 Nuigtush nugka múun aidaun apuji awajsattajime. 
\q1 Dutikakun wi atumi apachjum Jacopan 
\q1 anagkuawaitag nuna nugkan amastatjime. 
\q1 Junak dekas wi umiktinjun tajai”, tiuwai Tuke Pujuu. 
\c 60  
\s1 Yamajam Jerusalén 
\q1  
\v 1 Isaías chichaak: 
\q1 “Jerusalégnumia aidauwah, 
\q1 atumnak Tuke Pujuu imanjiya nunú 
\q1 ijipaku asamtai, winchamtin wajasugme. 
\q1  
\v 2 Untsu nugkanak suwe dukuakui, 
\q1 nuniai yaakat múun aidaunak suwe ijike, 
\q1 untsu atumnak Tuke Pujuu etsantug wajantugmattawai, 
\q1 nuniak niina imanjiya nunú wantintugmakagtatui. 
\q1  
\v 3 Aents nugka muunnumia aidauk 
\q1 atumin etsantug awa nuwi miniagtatui, 
\q1 tuja apu aidaushkam atumin tsaaptin awa nuwi miniagtatui. 
\q1  
\v 4 ¡Jerusalégnumia aidauwah, 
\q1 ayampajum ashí niimsatajum, 
\q1 ashí aents aidauk Jerusalén ijunainawai. 
\q1 Atushtanmaya aidau dita patayi aidaujai ashí 
\q1 yajumakag uchin pagkuaku mininawai! 
\q1  
\v 5 Nunú imanik kaunainak, 
\q1 nayantsanmaya waji aidaun, 
\q1 tikich nugka múun aidaunmaya waji aidaun 
\q1 takuinaku mininakui shiig aneastinaitjume. 
\q1  
\v 6 Madiágnumia aidau, efánmaya aidau 
\q1 camellonum entsatkau minidau waintinaitjume. 
\q1 Tuja Sabá nugkanmaya aidaushkam 
\q1 ashí camellon yajuakag oron, kugkuin 
\q1 inciensojai patajag minidau wainkujum, 
\q1 mina emematjitnaitjume wi dutikau asamtai. 
\q1  
\v 7 Tuja Quedarnumia aents aidaun 
\q1 tagkuji ikaunmawagtata duka, 
\q1 Nebaiotnumia uwig tsakat aidaun ikaunmawagtata nujai 
\q1 ashí Apajuín shiig anemtiksatin altarnum pataijum apeattagme. 
\q1 Aatus Apajuí niina jee pegkegma nunak nuni pegkeg awajsattawai. 
\b  
\q1  
\v 8 “¿Aush yujagmijai betek nanaakag, 
\q1 paum dita pasugken shimuwama numamtuk 
\q1 minina dusha ya ainawa? 
\q1  
\v 9 Duka lancha múun Tarsisnumia aidau, 
\q1 atumi uchijum aidaun yajuakag Tuke Pujuu 
\q1 atumi Apajuíjum senchimtijamna nuna emematiagtatus 
\q1 oron, plata aidaujai yajuak mininawai. 
\b  
\q1  
\v 10 “Apajuí atumin kajegtamak suwimkan amasajui. 
\q1 Dutijamayatak yamai wait anenjamjau asamtai, 
\q1 aents tikich nugkanmaya aina nunú 
\q1 yaakat peejamu aidau tsaikbauwa nunak ataktu peegkeg umikagtatui. 
\q1 Tuja apu aidauk amina inakem agtatui. 
\q1  
\v 11 Tikich nugkanmaya apu aidau dita aentsji aidaujai 
\q1 waji aidaun ikaunmawagtin asagmatai, 
\q1 Jerusalégka waitijig kashish, tsawaish tuke ujaim asatnai. 
\b  
\q1  
\v 12 “Ashí aents tikich nugkanmaya aidau 
\q1 atumin takagtamtan dakituidauk ijinam agtinai. 
\q1  
\v 13 Apajuí Jerusalégnumia aidaun chichajak: 
\q1 ‘Líbanonmaya waji aina duka, numi dakaja jegamtai shiig pegkeg: 
\q1 pino, abeto, cipre aina nujai 
\q1 ashí wi pujusa inamjatnun etegkauwaitag nuwi 
\q1 mina jegag awa, 
\q1 nunú iwaja shiig pegkejuch awajsatnun ikaunmawagtinai. 
\q1  
\v 14 Yaunchuk atumin waitkagmajaku aina 
\q1 nuna uchiji aidauk atumin inake waigtatui, 
\q1 tuja atumin yaunchuk dakitjamajaku aidauk 
\q1 atumin tikishmatjamag, Jerusalégkan chichajuinak: 
\q1 “Tuke Pujuu, Israel aents aidaun Apajuíji 
\q1 pegkegma nuna yaaktajiyai”, wajagtinai. 
\q1  
\v 15 Atumek kajimatki idaisamu, kajegtai ayugme. 
\q1 Tujash nunak wi yapajian 
\q1 atumin imanjumek tuke atin ati titatjai. 
\q1 Nuadui atumek ajumaish shiig aneasjum pujustinaitjume. 
\q1  
\v 16 Tikich nugkanmaya aidau atum yuwatnun 
\q1 yutai shiig pegkeg aidaun ikautjabiagtinai, 
\q1 tuja apu aidaushkam waji akik aidaun 
\q1 anentag amasagtinai. 
\q1 Nuna Jerusalégnumia aidau wainainak 
\q1 wi Tuke Pujuu, senchigtin, Israel aents aidaun 
\q1 uwemtiknaitag nuna dekajuawagtinai. 
\b  
\q1  
\v 17 “ ‘Witjai Israel aents aidaun Apajuíjinuk, 
\q1 nudiau asan, agkan shiig takainak batsamsatnume tusan agkan pujutan, 
\q1 waitjutsuk shiig takatan jintintuattajime. 
\q1 Dutikakun bronce amamainaitkun dekas oron amastatjime, 
\q1 tuja hierro amamainun dekas platan amastatjime, 
\q1 tuja numi amamainun dekas broncen amastatjime, 
\q1 tuja kaya amamainun hierron amastatjime. 
\q1  
\v 18 Atumi nugkeminig maaniamuk makichkish antuekashtinai, 
\q1 tuja yaakat tsayamush atumi nugkeminig 
\q1 makichkish atsutnai. 
\q1 Nuadui Jerusalén peejamua duka 
\q1 “Uwemtai” adaikatnaitjume. 
\q1 Untsu waitiji aina nunú “Dakujutai” adaikatnaitjume. 
\b  
\q1  
\v 19 “ ‘Tuja etsantug tsaaptin wajas 
\q1 ajumaish tuke atina duka witjai. 
\q1 Nuadui atumek etsa etsankui yujasmi, 
\q1 tuja nuniachkuish nantu kashi etsantak tsaaptin 
\q1 weakui yujasagmi tusagmek batsamchattagme. 
\q1  
\v 20 Witjai Tuke Pujuu atumi Apajuíjinuk. 
\q1 Nuadui etsag makichkish akaikig megkaekashtinai, 
\q1 tuja nantushkam etsanbaujinak kajinkashtinai. 
\q1 Wi ajumaish atumi tsaaptinjum tuke atinaitjai. 
\q1 Nuadui atum wake besemag pujamuk atsugtamiagtinai. 
\b  
\q1  
\v 21 “ ‘Atumi aentsjum aidauk shiig anentaimkau 
\q1 eme anentsa diitai, nugkeesh atantam achatnaitjume, 
\q1 tuja waji ajakaitkuish wi ajakmamu atinaitjume. 
\q1 Wi nunak mina imanjun iwainaktasan dutikattajai. 
\q1  
\v 22 Kuashtachu aina nunú yujaka mil aents wajastinai, 
\q1 nunú yujaka nugka múun wajastinai. 
\q1 Wi nunak nunú tsawan jegakui wamak dutikattajai. 
\q1 Witjai dekas Tuke Pujuunuk’, tawai Apajuí”, tiuwai Isaías. 
\c 61  
\s1 Israel aents aidaunum uwemat taatin pachisa etsegkamu 
\p  
\v 1 Tuke Pujuu inake chichaak: 
\q1 “Apajuí minak ujudauch aidaun yamajam chichaman ujakti, 
\q1 dutikak waitkam batsata nuna anentain ichichtugti, 
\q1 tuja achikbau aidaunash agkanmitkati, 
\q1 dutikak achikam chimpija nunashkam 
\q1 agkanmitkati tusa awetine. 
\q1 Nuadui niina Wakani minai awai. 
\q1  
\v 2 Nuigtushkam Tuke Pujuu 
\q1 iina wait anenjamjatnuk tsawan jegattawai, 
\q1 tuja nunú tsawantin Apajuí iina shiwaaji 
\q1 waitkagmaina nuna depetuk, uwemtijamjatnuk 
\q1 tsawantak jegattawai tusam etsegkata tusa awetine. 
\b  
\q1 “Tuja aents wake besemag batsatunashkam 
\q1 anentain ichichtugti tusa awetine. 
\q1  
\v 3 Israel aents aidau dita shiwaaji depeteam 
\q1 buutu batsata nuna shiig aneastinme, 
\q1 tuja yukuun ukatmama batsata nuna 
\q1 dakunkut anentain susati tusa awetine. 
\q1 Tuja wi agkanmitkamu asag, numi roble 
\q1 Apajuí ajakbau pejkejush amain aina iman asagmatai, tikich aidau chichajuinak: 
\q1 ‘Roble katsujam tegamainchau’ tiagtinai. 
\b  
\q1  
\v 4 “Tuja yaunchuk yaakat tsaikbau aidau 
\q1 tuwasua wegaka nunú Jerusalégnumia aidautijum 
\q1 ataktu jegamjajum yaaktamkatnaitjume. 
\q1  
\v 5 Dutikawagmin aents tikich nugkanmaya aidau 
\q1 kaunawag tagkuji aidaun, ajajum uva ajakbau aidaujai 
\q1 kuitamjutpakagtinai. 
\b  
\q1  
\v 6 “Tuja atumnak ‘Sacerdote aidau, 
\q1 Tuke Pujuun takajin’ tujamiagtinai. 
\q1 Atumek yutai tikich nugkanmaya aidau 
\q1 shiig pegkeg yutinaitjume. 
\q1 Tuja nugkutai aidaushkam pegkeg iwajamu aidau 
\q1 tikich nugkanmaya iwagmamtinaitjume. 
\q1  
\v 7 Atumek mina aentsug ainayatkujum 
\q1 shiig kuashat datsan chichajam, 
\q1 busainaku dushikiam kuashat waittsau ainagme. 
\q1 Nuadui nuna nagkaesau atumi nugkem 
\q1 waji aidaujai shiig kuashat jukitnaitjume. 
\q1 Dutikajum ajumaish tuké shiig aneasjum pujustinaitjume. 
\q1  
\v 8 Apajuík waitjutsuk shiig takamua nuna aneawai, 
\q1 nuniak kajegdayat, magkagtut aina nunak kajejawai. 
\q1 Nuadui niina aentsji anagkuamunak 
\q1 makichkish ewaetsuk umiktinai. 
\q1 Dutikak chicham tuke atinun ditajai umiktinai. 
\q1  
\v 9 Dutikau asamtai, dita wegantu aidauk 
\q1 tikich aents aidaun nagkaesau shiig kuashat agtinai. 
\q1 Ashí aents aidauk nuna diisag: 
\q1 ‘¡Tuke Pujuuwap ditanak pegkegnum yumigjauwaita!’ tiagtinai. 
\b  
\q1  
\v 10 “Tuke Pujuu minak shiig anemtijawai. 
\q1 Apajuí minak dakunkut pujutan sujawai. 
\q1 Apajuí minak uwemtijuje. 
\q1 Apajuí minak shiig pegkegnum kuitamjuke. 
\q1  
\v 11 Nuadui jigkai ajaamu tsapaama numamtuk, 
\q1 tuja ajak ayaunmaya tikich ajak tsapaama numamtuk, 
\q1 tsanumtsuk shiig takatan 
\q1 shiig aneasa pujutjai ashí aents aidaunum 
\q1 waji ajakaitkuish, Tuke Pujuu tsapapitnai. 
\q1 Nuadui shiig aneenak kantamiagtinai.” 
\c 63  
\s1 Apajuí Israel aents aidaun ayamjak edomnumia aents aidaun ijinatin 
\p  
\v 1 ¿Yaita aush edomnumia yaakat múun 
\q1 Boshrá tutaya nuwiya jáanch kapantui egkekbau tumainun 
\q1 shiig pegkejan nugkuaju ishamain mina dusha? 
\q1 Nunak wi depetmaktinun iwainajai, 
\q1 wika senchigtin asan uwemtikagtumainaitjai. 
\q1  
\v 2 ¿Wagka uva naja najam jáanch kapantu wegama 
\q1 imanush jáanchjumesh wajasuita? 
\q1  
\v 3 Junak imanikjai wiki uvan najakun, 
\q1 makichkish yainkachaje. 
\q1 Senchi kajekmajai, nunikan mina shiwag aidaun 
\q1 suwimkan susamjai. 
\q1 Dutikakun senchi kajeku asan, tepegka ijinmaina imatikamjai, 
\q1 dutikai nuna numpe aidau 
\q1 tsakiantak jáanchjui ukatjukmae. 
\q1  
\v 4 Nunak dutikamjai mina aentsug aidaun ayamjakun, 
\q1 mina shiwag aidau ijinatin tsawan jegau asamtai. 
\q1  
\v 5 Mina yainmainush atsuash tukaman 
\q1 makichkish wainkachmaijai, 
\q1 nunikan anentai jegachmaijai. 
\q1 Nunikan senchi kajekbaujui mina senchigjai depetmakmaijai. 
\q1  
\v 6 Shiig senchi kajekbaujui 
\q1 aents nugka muunnumia aidaunak 
\q1 tepegka ijinmaina numamtuk ijinabiajai. 
\q1 Dutika ai numpa saeki akaikibi. 
\s1 Apajuí Israel aents aidaun wait anenjatin 
\q1  
\v 7 Isaías chichaak: 
\q1 “Apajuí anenken pachisan chichaakun, 
\q1 nii jutiin ayamjutpak kuashat dutikauwa nuna 
\q1 anentaimtusan kantamatasan wakegajai. 
\q1 Apajuík Israel aents aidaun wait anentau asa 
\q1 niina anenkega nuna ditan iwaintak kuashat yaigkui.” 
\q1  
\v 8 Apajuí chichaak: 
\q1 “Ditak mina aentsug asag, mina uchig, 
\q1 mina nawantug aina duwi 
\q1 intimjutmainchau ainawai. 
\q1 Nuadui dita pegkegchaujig kuashat aig, 
\q1 wait anentug uwemtikjauwai. 
\q1  
\v 9 Israel aents aidaun waitkagtaik, 
\q1 niig tikichin akupkag ayamjukchauwai, 
\q1 dekas nii Apajuí taa ayamjukui. 
\q1 Apajuík niina anenken, niina senchijin aatus, 
\q1 Israel aents aidaunak wait anentak 
\q1 tuké ayamjuk uwemtiknai. 
\q1  
\v 10 Imatika yayamash Israel aents aidauk intimjuinak, 
\q1 Apajuí pegkegman ikajejaku ainawai. 
\q1 Nuadui ditan pempeentuki shiwaajui 
\q1 itugmaina numamtuk ditajai maaniauwai. 
\q1  
\v 11 Imanik waituinak yaunchuk Moisés 
\q1 dita apachji aajaku aidaun jiija yajuak 
\q1 uwemtikjauwa nuna anentaimtus chichainak: 
\q1 ‘Moisés Israel aents aidaun apuji aajakua nunú 
\q1 piipich asamtai, namak Nilonum ajugkam jakeaun 
\q1 jiikiuwa dusha Apajuísh ¿tuwi pujawa? 
\q1 Tuja Moisésai Niina Wakani pegkegman 
\q1 apusauwa dusha Apajuísh ¿tuwi pujawa? 
\q1  
\v 12 Apajuí niina senchijijai Moisésan uyunajakua dusha, 
\q1 tuja niina aentsji aidau ishamainun ukumtikak, 
\q1 atakea duish kajimatkishtinun niina senchijin iwainak 
\q1 nayantsan ukuyauwa dusha ¿tuwi pujawa? 
\q1  
\v 13 Caballo mujanum weakush atakuinag iyauchua numamtuk, 
\q1 nayants buku wajasbaunum initak shimakush, 
\q1 atakuinjashtinme tusa umikua dusha Apajuísh yamaish ¿tuwi pujawa? 
\q1  
\v 14 Apajuí niina aentsji aidaun baka aidau nainnum yujau 
\q1 wakeen nugka pakanum utsanawag 
\q1 ayamama numamtuk ayamtikna dusha 
\q1 Apajuísh ¿tuwi pujawa?’ tiagtinai”, tiuwai. 
\b  
\q1 Tuja inagnamua nuna Isaías chichaak: 
\q1 “Apajuín Wakani ditan uyuntsauwai. 
\q1 Aatus niina imanjin ashí iwainak ekemsauwai”, tiuwai. 
\s1 Apajuí yainkati tusa augbau 
\q1  
\v 15 Israel aents aidau Apajuín aujainak: 
\q1 “Chah, Apajuíjuh, ame pujutaijum 
\q1 nayaim pegkegma nuwi pujusam antukta. 
\q1 Amek jikamsa anejatchau dekapeaji, 
\q1 tuja ame senchigtinaitam dusha iwainkagtatsme. 
\q1 ¿Amesh jutiish wajuk diijatme? 
\q1 Atsa amina wait anenkagtutaigmek ¿amuekaek? 
\q1  
\v 16 ¡Ametme jutiin apajimek, 
\q1 Abraham niina uchijichu anenjamkuish, 
\q1 tuja Israel pachipachkuish, 
\q1 ametme iina apajimek! 
\q1 ¡Ametme iina tuke uwemtikagtinmek! 
\q1  
\v 17 Aminí kanaktinme tusamek tukagtipa, 
\q1 tuja intimkiu atinme tusamesh tukagtipa. 
\q1 Amina inakem ainag nunú, 
\q1 amina aentsjum maki makichik wegantu 
\q1 aina nujai aneakmek, ataktu wait anenkagtugta. 
\q1  
\v 18 Amina aentsjum ame etegkamu aina duka 
\q1 dita nugkeenig ujumak tsawanchik batsatui. 
\q1 Ame emematku ijuntaiya nunak 
\q1 iina shiwaaji aidau pegkegchau awajainawai. 
\q1  
\v 19 Ii aidautik amina chichamem umitsuk, 
\q1 nuigtush aminuchu amaina numamtuk batsatji. 
\q1 Wait aneasam amina anenkem 
\q1 ataktu iwainkagtukta”, tiajui. 
\c 64  
\p  
\v 1 Apajuíjuh, utusamek nayaim ujaim 
\q1 akaikim nugká taakum muja aidau pegakam, 
\q1  
\v 2 jii kegak jagki kagakun apegama numamtuk, 
\q1 tuja dutikachkush yumin ukuwama numamtuk 
\q1 awajkam tusa wakegaji. 
\q1 Nuna amina shiwaajum aidau wainainak, 
\q1 Apajuík ima ameketam nuna dekawagtinai. 
\q1 Tuja aents nugka muunnumia aidaush ishamjamainak 
\q1 kujaidiagtinai. 
\q1  
\v 3 Kuashat ishamain aidau iwainajuitam nunú 
\q1 iina uwaktamkauwai. 
\q1 Nuadui muja aidaush amina emtimin 
\q1 senchi buchitiagmayi. 
\q1  
\v 4 Aminí kajinas anentaimaidau yayaakum, 
\q1 ame ishamain aidau iwaintujuitam dutika 
\q1 tikich apajuí niina kajitus anentaidaun yayaak, 
\q1 imanun ditan iwaintukuk yaunchkesh makichkish wainkachbauwai, 
\q1 tuja antutkesh antushtayai. 
\q1  
\v 5 Aminak aents shiig aneas pegkejan takak, 
\q1 chichamjum umiktina nuna 
\q1 aneaku puja nunú shiig awajtamui. 
\q1 Amek ii pegkegchau takaku yaunchuk 
\q1 nagkamsaish ikaje pujag duwi kajekume. 
\q1  
\v 6 Ii aidautik makichik aents tsumaina iman ainaji. 
\q1 Ii pegkeg takaji taji dushakam jáanch tsuwata iman ainawai. 
\q1 Ashí ii aidautik duka kagaka kakekaujai betek ainaji. 
\q1 Tuja iina magkagtutaijiya nunú dasejai betek 
\q1 tukugmi ajapjamainawai. 
\q1  
\v 7 ¡Amina segapauk, tuja amina nii wait anenjugti tusa kakanmamukesh 
\q1 makichkish atsawai! 
\q1 Nuadui amek iina pegkegchaujin uumka idaikagtusume. 
\b  
\q1  
\v 8 Apuh, ii nunin ainajinish, ametme iina apajimek. 
\q1 Ii aidautik duwejai betek ainaji, 
\q1 untsu amek aents duwen namuka najannujai betekaitme. 
\q1 ¡Iik ashí ame najankamu ainaji! 
\q1  
\v 9 Tuke Pujuuwah, imanikmek kajekaipa, 
\q1 tuja iina magkagtutai aidaush pachikaipa. 
\q1 ¡Kame, iik amina aentsjum ainaji! 
\q1  
\v 10 Yaakat ame etegkamu aina duka 
\q1 itajak wajas bashiak ainawai. 
\q1 Jerusalégnak iina shiwaaji aidau tsaikam 
\q1 pegkegchau wajas awai. 
\b  
\q1  
\v 11 Amina jem pegkegmanum iina apachji aidau 
\q1 amina emematjamajaku aina nunak 
\q1 jiiyai apea ashí tsaikajui. 
\q1 ¡Ii ima senchi wakesa diin ayag duka 
\q1 tsaikam pegkegchau wajas awai! 
\b  
\q1  
\v 12 Tuke Pujuuwah, imatikau aina nuna iikmakti 
\q1 tusamek amek ¿yaijatkashtatmek? 
\q1 Atsa ¿ayatkek idaisattam? 
\q1 Nuniakum aan senchi waitkastinme 
\q1 tusamek ¿idaikagtustatam? 
\c 65  
\s1 Apajuín shiwagbaunak nii suwimkan suwawai 
\q1  
\v 1 Apajuí chichaak: 
\q1 “Aents makichkish mina segatchau aajabia 
\q1 nunú mina kautjuinawai; 
\q1 tuja aents mina egatkachu aajabia nunú 
\q1 yamai mina waituinawai. 
\q1 Mina emematjuchu aajabia nuna chichagkun: 
\q1 ‘Juwi pujajai’, tibaijai. 
\q1  
\v 2 Aents intimkiu aidau 
\q1 wijai shiwagmagainak, 
\q1 dita wakegamun pegkegchaun taka yujau aina 
\q1 nunú segatainakui yaigtasan tuke dakabiajai. 
\q1  
\v 3 Nunú aents aidauk mina igkuntuawag 
\q1 tuke inastuinawai. 
\q1 Dita aidauk apajuímtai dakumka najanamun 
\q1 emematuinak, 
\q1 kuntinu maawag ikam yujasag, kaya pataja 
\q1 najanamunum nuwi patainiag apé yujau aajabi. 
\q1 Nuigtushkam ladrillo najanamunum kugkuin incienson 
\q1 apé yujau ainawai. 
\q1  
\v 4 Nunú aents aidauk ukumatainum pekamá yujayanume, 
\q1 nuninak waanum uumak batsamas tsawampa 
\q1 batsamianume. 
\q1 Nunú aents aidauk Apajuí dakitamun 
\q1 kuchi nejen yuyanume, 
\q1 nuigtush dakumkamu emematku kuntin 
\q1 maamu aidau painkamun yumiji ollanmak tsumain aajabi. 
\q1  
\v 5 Nunú aents aidau chichainak: 
\q1 ‘Antijatkaigpa iik Apajuí etegjamu asa 
\q1 pegkejam ainaji’, tuinawai. 
\q1 Nunú aents aina duka jii tuke, 
\q1 tsawantai keeka aama numamtin ainawai. 
\q1 Jii bukuituji dujin amajama 
\q1 numamtuk minak waitkajuinawai”, tiuwai. 
\s1 Nayaim yamajam nugka yamagmajai 
\q1  
\v 17 Apajuí chichaak: 
\q1 “Antuktajum nijah, wi yamajam nayaimpin, 
\q1 nugka yamagmajai najanattajai. 
\q1 Tuja yama nagkamchak nayaim 
\q1 nugkajai aajakua nunak kajimatkiagtinai. 
\q1 Makichkish nunak tuke adeagchagtinai. 
\q1  
\v 18 Wi nuna yamagman najanatin asamtai, 
\q1 ajumaish tuké shiig aneastin atajum. 
\q1 Wi yamajam Jerusalégkan shiig pegkejan 
\q1 najanattajai; 
\q1 dutikamtai nuwi aents aidauk shiig aneasag batsamsagtinai. 
\q1  
\v 19 Tuja wishakam Jerusalégkan diisan 
\q1 shiig aneastatjai; 
\q1 nuniakun mina aentsug aina nuwishkam 
\q1 shiig aneastatjai. 
\q1 Jerusalégnumak jaku buutbaush atsutnai. 
\q1  
\v 20 Nunú nugkanmak uchi akiina jaka megkaguk atsutnai, 
\q1 tuja múunchishkam tsawanjin shiig ejetsuk 
\q1 jauk atsutnai. 
\q1 Tuja makichik aentskesh cien mijan ajamu jauk 
\q1 múuntuch achatnai, datsauch atinai. 
\q1 Tuja cien mijanan ejetsu duka suwimak asamtai nuniktinai. 
\q1  
\v 21 Aents aidauk nunú yaaktanum jegamag batsamas, 
\q1 trigon, uvan ajakmakag nuna nejen juukag yuwagtinai. 
\q1  
\v 22 Dita jegamkamunmak tikich 
\q1 akiinag batsamsachagtinai, 
\q1 tuja dita ajakmamujinash atankiajag yujuachagtinai. 
\q1 Mina aentsug aidauk numijai betek 
\q1 kuashat tsawan iwaku pujusagtinai; 
\q1 Wi etejamu aina duka dita takasbaujinian 
\q1 jukiag shiig batsamsagtinai. 
\q1  
\v 23 Dita aidauk Apajuí pegkegnum yumigjamu asag 
\q1 wainak takainakug waittsachagtinai, 
\q1 tuja dita uchiji aidaushkam 
\q1 tsawan jegatsaigkik jakachagtinai. 
\q1 Nunú uchi aidau wegantu aidaushkam 
\q1 ditajai betek pegkegnum yumigjamu agtinai. 
\q1  
\v 24 Eke dita untsujuinatsaig, 
\q1 wiyá ditanak aiktinaitjai; 
\q1 tuja eke chichakag ashimainatsaig, 
\q1 wiyá ditanak antugkatnaitjai. 
\q1  
\v 25 Lobo uwig tsakatjai jimagtuk yuwawagtinai. 
\q1 Leónkak bueyejai betek chijichin yutinai. 
\q1 Untsu dapi nugka yukukuntun yutinai. 
\q1 Tuke Pujuu chichaak: 
\q1 ‘Jerusalégnumak tikichin pegkegchau awagbauk 
\q1 makichkish atsutnai’ ”, tiuwai. 
\c 66  
\q1  
\v 1 Tuke Pujuu chichaak: 
\q1 “Nayaimpik mina ekemsa inamtaijui. 
\q1 Untsu nugka nunuwai wi najamsa eketbau. 
\q1 Atumek wi ayamsatnuk mina jegajuk 
\q1 jegamjutmaitsugme, 
\q1 tuja nunú jegamainchakam nugka etegkamuk atsawai. 
\q1  
\v 2 Waji ayá nunak wiki ashí najankauwaitjai; 
\q1 dutika ai nunisag juwajui. 
\q1 Witjai Apajuínuk. 
\q1 Wi nunak dutikauwaitjai. 
\q1 Wika aents wakanin pimpiki pujusa 
\q1 mina chichamjun eme anenta nuna diyakjai”, tiuwai.