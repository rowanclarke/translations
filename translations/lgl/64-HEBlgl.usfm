\id HEB - Wala Unicode 
\h Hebrus 
\toc2 Hebrus 
\toc1 Geregerena Fala Jiu Gi Li Hebrus 
\mt2 Geregerena Fala Jiu Gi Li  
\mt1 Hebrus  
\ip Nali ioli iko 'ali gera Kristin, gera sae fafuta'a rasua ala ioli Kristin gi. 'E 'urifo ionada iko 'ali 'oka, ma garani gera ka kalasu lo faasia fitoona gera ala Christ. Gera oga 'ali gera ka oli lo 'ada fala falafala Jiu gi li. Wale 'e 'e geregere fada 'e ilia fada 'ali gera fafu ala dau nasina ala fitoona gera gi li. 'E sae 'uri 'e fada, Jesus Christ mola 'e fatae madakwa ala God faga. Jesus 'e ura nasi talasi 'e famalifii rasua ai, ma 'i lia Wela firi God. Jesus 'e tasa ka liufia lou profet 'i lao gi. Lia ka liufia lou eniselo gi, ma ka liufia lou Moses wasua. 'Are la fo, ioli Kristin gi gera ka ura nasi 'i laola fitoona gera gi, ma ikoso gera oli fae buri fala falafala Jiu gi li.  
\ip God 'e ilia ka sui lo lia Jesus lo fata abu ba'ela io firi, ma ka tasa liufia rasua fata abu 'i lao gi. Ma galona lia ala fata abu na li, Jesus 'e saiala faamurinala ioli gi, 'ali gera sigi tefau faasia ta'ana failia maena. Foasina 'i lao gi gera fatailia mola lului 'are Jesus 'e taua. Wale 'e gerea buka 'e li, 'e ilia fala Kristin gi 'ali gera ura nasi firi ala fitoona gera gi, malaa ioli ba'ela ba 'i lao gi. Wasua talasi ioli gi gera ka malakwaita ada, 'e ilia gera ka ura nasi ala fitoona gera gi.  
\io1 'Are 'ilitoa 'i laola buka 'e li gi li:  
\io1 Jesus 'e tasa ka liufia eniselo gi (1:1—2:18)  
\io1 Jesus 'e tasa ka liufia Moses failia Josua (3:1—4:13)  
\io1 Jesus 'ilito'ola fata abu Kwalaimoki (4:14—7:28)  
\io1 Sae alafuunala Jesus 'e tasa rasua (8:1—9:22)  
\io1 Foasina Jesus 'e tasa rasua (9:23—10:18)  
\io1 Ioli fitoo gi gera ka ura nasi ala fitoona gera gi (10:19-30)  
\io1 Ioli 'i lao mae gera fitoo 'oka ala God gi (11:1-40)  
\io1 Donaa maurinala Jesus (12:1—13:19)  
\io1 Alaana fafu'isi gi (13:20-25)  
\c 1  
\s1 God 'e alaa faga 'alia Wela lia  
\p
\v 1 'Ua lo mae 'i lao, God 'e sae fala koko 'ualo gia gi 'alia profet gi ala talasi afula ma 'alia kwalumolee 'are mamata gi sui.  
\v 2 Ma ala fe atoa fafu'isi 'e gi, 'e sae lo faga 'alia Wela lia. Ma God 'e raunailia 'are gi sui 'alia Wela lia, ma 'i lia lou God 'e filia 'ali ka too ala 'are gi sui.  
\v 3 Wela Wale God 'e fatailia madakwana ala 'ilitoanala God tefau, ma ka rada failia ala malutala tofunai. Ma Wela God 'e dau fanasia 'are gi 'alia nanatana ala saenala 'ali ikoso gera sui. 'I burila Wela 'e lufaa lo abulo ta'ana gia gi, ka bi oli fala 'i nali, ma ka gwauru ala gula aolo ala God 'ilitoa.   
\s1 Wela God 'e 'ilitoa ka tasa  
\p
\v 4 God 'e faa 'ilitoa Wela lia ka tasa liufia eniselo gi, malaa lou ratae 'are 'e kwatea fala Wela lia li 'e 'ilitoa ka tasa liufia ratae 'are 'e kwatea fala eniselo gi li.  
\v 5 Sulia God ba 'e sae 'uri 'e fala Wela lia,  
\q1 “'I'o Wela lau, ma 'i tara'ela 'i lau Mama 'o.”\x + \xo 1:5 \xt Sam 2:7\x*  
\m Ma God iko 'ali sae mola 'urifo fala ta eniselo.  
\p Ma tekwa 'ua lo mae, God ka sae lou 'uri 'e sulia Wela lia,  
\q1 “Lakae Mama 'ala, ma 'i lia kae Wela aagu.”\x + \xo 1:5 \xt 2 Samuel 7:14\x*  
\m Wasua ma God iko 'ali sae mola 'urifo sulia ta eniselo.   
\p
\v 6 Ma talasi 'e garani lo 'ali God ka kwatea mae Wela 'ilitoa lia fala 'i laola molagali li, God ka sae 'uri 'e,  
\q1 “Eniselo lau gi sui gera foasia.”\x + \xo 1:6 \xt Diutronomi 32:43\x*   
\m
\v 7 Me saena God 'e taua sulia eniselo gi li, 'e 'uri 'e,  
\q1 “Eniselo lau gera galo fagu gi, lau kwatea gera ka malaa oru gi failia dunaa gi.”\x + \xo 1:7 \xt Sam 104:4\x*   
\m
\v 8 Ma God ka sae 'uri 'e sulia Wela lia,  
\q1 “'I'o God, ma 'Ilitoana 'o kae io firi.  
\q1 Ma 'o 'ilitoa fafia ioli 'o gi 'alia radana.   
\q1
\v 9 'O babalafe fafia 'are rada gi, ma ko barasi 'alia 'are ta'a gi.  
\q1 'Are la, 'i lau God 'o, lau fili 'o, ma laka kwatea lou babalafena ba'ela famu failia fabaelana la 'e tasa ka liufia kwaima 'o gi.”\x + \xo 1:9 \xt Sam 45:6-7\x*   
\m
\v 10 Ma God ka sae lou 'uri 'e fala Wela lia,  
\q1 “Aofia ala fuli na mae, 'o raunailia wado 'alia limamu 'i talamu, ma ko raunailia raloo.   
\q1
\v 11 'Are fo gi kae sui, wasua 'i'o koe mauri firi. Gera kae furafura ta'a malaa na toro 'ualo.   
\q1
\v 12 Ma koe kalasua malaa na ioli 'e kalasua toro 'ualo. 'O olisia malaa toro.  
\q1 Wasua ma 'i'o, ikoso olisi, maurinamu ikoso sui.”\x + \xo 1:12 \xt Sam 102:25-27\x*   
\m
\v 13 God ka sae lou 'uri 'e fala Wela lia,  
\q1 “'O io 'i gula aolo agu, la la ka dao ala talasi lakae alua koe liufia malimae 'o gi li.”\x + \xo 1:13 \xt Sam 110:1\x*  
\m God iko 'ali sae mola 'urifo fala ta eniselo.   
\p
\v 14 Ta 'e eniselo gi? Eniselo gi aloe 'are gera galo 'ala God gi. God 'e keria eniselo gi fala kwairanaina ala ioli kae faamaurida gi.   
\c 2  
\s1 Falalauna Jesus 'e 'ilitoa ka tasa liufia taki Moses  
\p
\v 1 Ma sulia 'e 'urifo gia ka dau nasi ala falalauna kwalaimoki gia ronoa sui lo sulia Wela God li, tauma gia bi liu rero faasia.  
\v 2 Taki 'e eniselo gi gera kwatea fala Moses, gera kwalaimoki sui mola. Ma ioli ba iko 'ali gera ronosulia gi, God 'e kwatea lo kwaikwaina 'e radaa fada.  
\v 3 'E 'urifo lou, ikoso 'ali gia tafi faasia kwaikwaina lia ala gia aburono ala falalauna sulia tala 'oka 'e God 'e faamauria gia 'alia. Aofia Jesus 'i talala 'e etae faarono 'alia tala 'e God 'e faamauria gia 'alia. Ma ioli gera talae rono lia gi, gera ilia faga, ma gera ka fatailia falalauna fo 'e kwalaimoki.  
\v 4 Ma God 'i talala lou 'e fatailia falalauna kwalaimoki fo. Sulia 'e kwatea nanatana fada 'ali gera fulia 'are mama'ala gi failia 'are mamata li 'aferona 'alida gi. Ma ka kwatea lou nanatana ala Aloe 'are Abu li fada sulia kwaiogalina lia.   
\s1 Jesus 'e talai gia fala 'ilitoana 'i nali  
\p
\v 5 Gia saiai God iko 'ali filia eniselo gi 'ali gera 'ilitoa fafia molagali fa'alu kae dao mae.  
\v 6 Sulia na gula ala Geregerena Abu ba 'e sae 'uri 'e,  
\q1 “God, taa ioli, lia ko malata taki rasua sulia?  
\q1 Sulia 'i gera ioli gi mola.  
\q1 Ma 'utaa ko lio sulida?   
\q1
\v 7 'O taua gera ka ke wawade 'i malula eniselo gi fala ke me talasi dodoko.  
\q1 Ma ko fa'ilitoa gera, ma ko faaba'ela gera,  
\v 8 ma ko alua gera ka 'ilitoa lo fafia 'are gi sui.”\x + \xo 2:8 \xt Sam 8:4-6\x*  
\p Geregerena fo 'e ilia God 'e alua ioli ka 'ilitoa fafia 'are gi sui. 'E fatailia ioli gi kae tatalofa fafia 'are God 'e raunailida gi sui. Wasua ma, ala talasi 'e, iko 'ali gia lesia 'ua 'ali ioli gi 'ilitoa fafia 'are gi sui.  
\v 9 Ma ka 'urifo wasua, gia saiai Jesus lo 'e 'ilitoa. God 'e alu lia ka futali ioli ma ka io 'i malula eniselo gi fala ke me talasi wawade, 'ali 'i lia ka mae fala faamurinala ioli gi sui, sulia kwaimanaa God. Ma talasi 'e, God 'e fa'ilitoa ma ka faaba'elaa, 'i osiala maenala.  
\v 10 God lo 'e raunailia 'are gi sui, ma 'i lia lou ka dau fafia 'are gi sui. Ma ka keria Jesus ka famalifii ma ka mae. Ma 'i osiala famalifiinala Jesus, God ka alua Jesus, wale ali'afu 'e faamauri gia. God 'e taua 'are fo 'ali kwatea ioli afula gi gera ka rau lo 'alia wela lia gi, ma gera ka 'ilitoa lou 'i malaa. Galonala God 'e rada sui.   
\p
\v 11 Jesus ka faakwaga ioli gi faasia ta'ana gera gi. Lia fo gera ka too ala teke Mama failia Jesus. Lia 'e taua Jesus iko 'ali mau 'alia soinada 'alia walefae failia gelifae lia gi.  
\v 12 Ma Jesus ka sae 'uri 'e fala God,  
\q1 “Lakae farono 'alia 'are 'o tauda fala walefae failia gelifae lau gi li, ma lakae batafe 'o 'i laola logona gera.”\x + \xo 2:12 \xt Sam 22:22\x*   
\m
\v 13 Lia ka sae lou 'uri 'e,  
\q1 “Lakae fitoo ala God.”\x + \xo 2:13 \xt Aesea 8:17\x*  
\m Ma ka sae lou 'uri 'e,  
\q1 “Lau 'e 'i lifi'e failia wela God 'e kwateda fagu gi.”\x + \xo 2:13 \xt Aesea 8:18\x*   
\p
\v 14 Ma sulia wela gi gera too ala rabe, Jesus ka rau lou 'alia rabe ma ka futali ioli lou malaa 'i gia. 'E tau 'urifo 'ali so ma, 'alia maenala, ka ofotailia Saetan wale 'e too ala nanatana fafia maena li.  
\v 15 Ma 'e 'urifo Jesus ka lufaa lo ioli Saetan 'e ba'ela fafida 'alia mauna gera 'alia maena li.  
\v 16 Gia saiai, iko lou eniselo gi Jesus 'e ranada 'urifo. Sulia Geregerena Abu ba 'e sae 'uri 'e,  
\q1 “'E ranaa kwalofa Abraham gi.”\x + \xo 2:16 \xt Aesea 41:8, 9\x*   
\p
\v 17 Dunala me 'are fo, ka alu lia ka malaa lo 'i gia walefae fae gelifae lia gi, 'ali ka futali 'ilito'ola fata abu gia 'e kwaiamasi aaga, ma ka 'idufae kwairanai aaga 'i maala God. Ma ka foasina 'alia 'i lia talala, 'ali God ka kwailufa lo 'alia abulo ta'ana gia gi.  
\v 18 Ma talasi 'e, 'e totolia kwairanaina ala ioli Saetan 'e mailitonada gi. Jesus 'e saiala tauna 'urifo, sulia Saetan 'e mailitonala lou ma 'i lia ka famalifii lou malaa ioli gi sui.   
\c 3  
\s1 Jesus 'e 'ilitoa ka tasa liufia Moses  
\p
\v 1 Alae iolifuta abu lau, God 'e fili gia gia kae la 'i nali. 'Amu malata ga sulia Jesus, lia gia soia 'alia 'ilito'ola fata abu gia, ma wale God 'e keria.  
\v 2 Jesus 'e ronosulia kwaiogalina God gi sui, ma God 'e filia ka galo fala, malaa lou Moses 'e ronosulia kwaiogalina God, talasi 'e kwairanai ala ioli God gi li.  
\v 3 Wasua ma Jesus 'e 'ilitoa ka liufia Moses, ka malaa lou wale 'e raunailia luma li, gera batafea ka liufia luma fo 'e raunailia.  
\v 4 Ala gia lesia ta luma, gia saiai ta ioli lo 'e raunailia. God lo 'e raunailia 'are gi sui.   
\p
\v 5 Moses 'e ronosulia God talasi 'e kwairanai ala ioli God gi li. Ma ka alaa sulia 'are God kae sae sulia talasi kae dao mae.  
\v 6 Wasua ma Christ, 'i lia Wela God, ma ka 'idufae kwairanai aga 'i laola galona lia fala 'ilitoana fafia ioli God gi li. Ma 'i gia ioli God gi, ala gia ka dau nasi ala fitoona ma kwaimamalina 'alia fitoona fala 'are 'oka 'e God kae kwateda faga gi.   
\s1 Mamalona 'ala ioli God gi li  
\p
\v 7 'Are la ba Aloe 'are Abu ka sae 'uri 'e,  
\q1 “'I tara'ela, ala 'amu ronoa lo saenala God,  
\v 8 ikoso 'ali 'amu fanasia malatamiu malaa koko 'ualo 'amiu gi ala talasi gera barasi 'alia God, ma gera ka aburono ala God 'i laola abae lifi kwasi li.”   
\p
\v 9 Ma God ka sae 'uri 'e,  
\q1 “Wasua gera ka lesia 'are mama'ala lau tauda sulia fai akwala fe falisi gi li, gera mailitoonagu talasi iko 'ali gera fakwalaimoki agu ma iko 'ali gera ronosuli lau.   
\q1
\v 10 Sulia lau ogata'a rasua fada, laka sae 'uri 'e, ‘Gera aburono agu, ma gera ka 'e'ela 'alia ronona sulia taki lau gi li.’   
\q1
\v 11 Liogu 'e ogata'a, ma laka sae alafuu 'uri 'e, ‘'E 'ato gera ka ruu 'i laola falua 'e lau rerei 'alia 'ali gera ka mamalo ai.’”\x + \xo 3:11 \xt Sam 95:7-11\x*   
\p
\v 12 Alae iolifuta lau 'amu lio suli 'amiu 'i talamiu, tauma ta ioli amiu malatala ka ta'a, ma iko 'ali fakwalaimoki ala Jesus Christ, ma ka 'e'ela lo 'alia God mauri 'e.  
\v 13 Wasua ma 'amu ka rana 'amiu 'i safitamiu 'i tara'ela, sulia Geregerena Abu ba 'e ilia 'i “tara'ela.” 'Amu ka tau 'urifo, tauma ta ioli amiu 'e bi fakwalaimoki ala kotona sulia abulo ta'ana li, ma maurinala ka kalasu 'ala faasia God.  
\v 14 Gia fitoo ala Christ ala talasi gia etae fakwalaimoki. Ma ala gia ka dau nasi ala fitoona gia ala Jesus Christ la la ka dao ala talasi fafu'isi, 'urila God kae kwatea 'are 'e etae sae alafuu lo 'alida gi sui faga.   
\p
\v 15 Sulia Geregerena Abu ba 'e sae 'uri 'e,  
\q1 “'I tara'ela, ala 'amu ronoa saenala God, ikoso 'amu fanasia mola 'amiu malatamiu malaa koko 'ualo 'amiu gi ala talasi gera barasi 'alia God.”\x + \xo 3:15 \xt Sam 95:7-8\x*   
\p
\v 16 Ma ioli ta gi ada ba gera ronoa saenala God, ma gera ka barasi 'alia? 'I gera ioli Jiu ba Moses 'e talaida faasia falua 'i Ejipt li.  
\v 17 Ma ioli ta gi ada ba God 'e ogata'a fada sulia fai akwala fe falisi gi? 'I gera ioli ba gera mae 'i laola abae lifi kwasi li fafia abulo ta'ana gera gi.  
\v 18 Ma nalife ada ba God 'e alafuu 'uri 'e fada, “'E 'ato 'ali gera ruu 'i laola falua 'e lau rerei 'alia 'ali gera ka mamalo ai?” God 'e sae sulia ioli gera 'e'ela 'alia gi.  
\v 19 Ma gia saiai iko 'ali gera totolia ruuna 'i laola falua ala mamalona fo li, sulia iko 'ali gera fakwalaimoki ala God.   
\c 4  
\p
\v 1 Wasua 'ala ioli fo gi iko 'ali gera totolia ruuna 'i laola falua fo fala mamalona li, sae alafuuna God 'e io 'ua mola 'ala. Ma 'i gia God 'e soi gia 'ali gia ruu fala mamalo na failia. 'Are la fo, gia ka lio 'oka suli gia, tauma ta ioli aaga 'e bi talafia ruuna 'i lififo li.  
\v 2 Sulia gia ronoa sui lo ala Faronona 'Oka sulia falua ala mamalona li, malaa lo koko 'ualo gia gi 'i lao mae. Wasua 'ala gera ka ronoa lo faronona fo, iko 'ali ranada mola, sulia talasi gera ronoa, iko 'ali gera fakwalaimoki mola ai.  
\v 3 Ma talifili gia, ioli gia fakwalaimoki lo gi mola gia kae ruu 'i lififo fala mamalona li failia God. Sulia lia ba 'e sae 'uri 'e,  
\q1 “Lau ogata'a, ma laka alafuu 'uri 'e, ‘'E 'ato gera ka ruu 'i laola falua 'e lau rerei 'alia fada fala mamalona li.’”\x + \xo 4:3 \xt Sam 95:11\x*  
\p God 'e sae 'urifo, wasua 'ala 'e galofia sui lo ala lifi li mamalona fo li, ala talasi 'e raunailia molagali li.  
\v 4 Sulia Geregerena Abu ba 'e sae 'uri 'e sulia fiula atoa, “Ala fiula fe atoa, God ka mamalo faasia galona lia gi.”  
\v 5 Ma Geregerena Abu ka sae lou 'uri 'e sulia, “'E 'ato 'ali gera ruu 'i laola falua 'e lau rerei 'alia 'ali gera ka mamalo ai.”  
\v 6 Ioli ba gera etae ronoa Faronona 'Oka li, iko 'ali gera ruu 'ali gera ka mamalo, sulia iko 'ali gera fakwalaimoki. Lia fo, gia saiai, tali ioli mamata God kae ala'alida fala mamalona.  
\v 7 Sulia God 'e alua lo talasi mamata fala ruuna 'i laola mamalona li. Ma God ka ilia talasi fo lo 'e “'i tara'ela.” Sulia 'e tekwa lo mae 'i burila talasi ioli ba 'i lao gi iko 'ali gera fakwalaimoki, David ka gerea saenala God 'i laola Geregerena Abu ba lau ilia ka sui lo 'uri 'e,  
\q1 “'I tara'ela, ala 'amu ronoa lo saenala God, ikoso 'ali 'amu fanasia malatamiu.”\x + \xo 4:7 \xt Sam 95:7, 8\x*   
\p
\v 8 Josua ba iko 'ali kwatea mamalona fala ioli Israel gi, lia fo ka totolia 'ali God ka sae lou 'alia David sulia mamalona ala na talasi mamata 'i buri.  
\v 9 Lia fo, gia saiala mamalona fala ioli God gi li, 'e io 'ua, ma 'e malaa mamalona God 'e taua ala fiula fe atoa li.  
\v 10 Sulia ite 'e mamalo failia God, 'e mamalo sui ala galona lia gi, malaa lou God 'e mamalo talasi 'e faasuia galona lia ala raunailinala molagali li.  
\v 11 Lia fo, gia tau nanata 'ali gia ruu ala lifi li mamalona God 'e rerei 'alia, tauma ta ioli aaga ikoso totolia ruuna, malaa ioli 'i lao gi lia iko 'ali gera fakwalaimoki, ma iko 'ali gera ruu 'i laola mamalona li.   
\p
\v 12 Saenala God 'e malaa na 'are mauri ma ka fulia 'are ba'ela gi. Ma saenala God ka malaa na 'au ba'ela 'e too rua gula, sulia 'e tofu ka ruu 'i laola malataga failia 'i laola maurinaga, sulia 'e fatailia faga 'are 'e 'oka ma 'are ka ta'a 'i laola malataga failia 'i laola kwaiogalina gia gi li.  
\v 13 Ma ikoso ta ioli 'ali faagwaa mola ta 'are faasia God, sulia God 'e lesia lo 'are gi sui. Ma 'i lia kae kwate ma gia ka faarono 'alia 'are gi sui lia gia tautauda.   
\s1 Jesus lo 'ilito'ola fata abu  
\p
\v 14 Ma sulia 'e 'urifo, gia ka dau nasi ala fitoona 'e gia alaa sulia. Sulia gia too ala 'ilito'ola fata abu ba'ela 'e la 'alaa 'i nali, ma ka alaa 'aga 'i maala God. Lia lo Jesus, Wela God.  
\v 15 Ma Jesus lo 'ilito'ola fata abu gia, 'e sai sui ala watoutouna gia gi, ma ka kwairanai aga sulia 'e liufia sui lo ilito'ona gi, malaa lou talasi Saetan 'e mailitoonaga. Ma wasua 'ala Saetan ka mailitonala Jesus, Jesus iko 'ali taua ta me 'are rero.  
\v 16 'Are la fo, ikoso gia mau 'ali la na mae 'i so'ela God 'e 'e kwaiamasi aga li. Sulia kae kwaiamasi aaga ma ka kwairanai aaga, ala talasi gia dao tonala 'atona gi li.   
\c 5  
\p
\v 1 Ala ta wale gera filia faasia matanala ioli gi fala galona ala 'ilito'ola fata abuna li, gera fitonala 'i lia lo fala daona 'i maala God, ma 'i lia wale kae sae 'ala ioli gi li. Ma galona lia lou, lia ka kwatea kwatena gi failia foasina gi fala God 'ali God ka kwailufa lo 'alia abulo ta'ana ioli gi li.  
\v 2 Ma 'ilito'ola fata abu 'i lia ioli mola lou, ma ka taua lou 'are 'e rero gi ala nali talasi, 'urifo ka saiala fafuna failia ioli gera rari 'are ma gera ka rero gi.  
\v 3 Ma sulia rerona lia gi 'i talala, 'e 'oka fala 'ali ka kwatea foasina gi, 'ali God ka kwailufa 'alia abulo ta'ana lia 'i talala failia abulo ta'ana ioli gi li.  
\v 4 Ma iko ta ioli 'ali fili lia 'i talala 'ali ka taua galona ba'ela ala 'ilito'ola fata abuna li, sulia God 'i talala lo 'e totolia filinala, malaa ba 'e filia Aaron 'ua lo mae 'i lao.   
\p
\v 5 'E 'urifo lou, Jesus Christ iko 'ali fili lia 'i talala fala 'ilito'ola fata abuna, 'ali ka too ala galona ba'ela fo. Wasua ma God 'ala 'e filia Jesus Christ, sulia God ba 'e sae 'uri 'e fala,  
\q1 “'I'o Wela lau, ma 'i tara'ela 'i lau Mama 'o.”\x + \xo 5:5 \xt Sam 2:7\x*   
\m
\v 6 Ma God ba 'e sae lou 'i laola na Geregerena Abu 'uri 'e,  
\q1 “Koe fata abu io firi, malaa Melkisadek.”\x + \xo 5:6 \xt Sam 110:4\x*   
\p
\v 7 Ala talasi Jesus 'e io 'ua 'i laola molagali 'e li, 'e foa nanata, ma ka aani ma kwai ka toli 'i maala fala God 'e saiala faamurinala. Ma Jesus ka fawawade lia 'i talala, ma ka soi ba'ela ala God, ma God ka ronoa foana lia gi.  
\v 8 Jesus 'i lia Wela God, wasua ma famalifiina 'e ruu 'i laola gi gera taua ka bi sai 'oka ala ronona sulia God.  
\v 9 Ma famalifiina fo gi gera taua ma Jesus 'ilito'ola fata abu ali'afu, ma ka faamauria ioli gera ronosulia gi sui, 'ali gera ka sakea maurina firi.  
\v 10 Ma God ka soia Jesus Christ 'alia 'ilito'ola fata abu malaa fata abu ba ratala Melkisadek.\f + \fr 5:10 \ft Melkisadek lesia Jenesis 14:17-24\f*   
\s1 Fabasuna fala dau nanatana ala fitoona li  
\p
\v 11 'Are afula gi 'ua lou fali ilia famiu sulia me 'are 'e. Wasua ma 'e 'ato fala falalaunamiu 'alida, sulia iko 'ali 'amu totolia malinae nainali na ali.  
\v 12 'Amu fakwalaimoki ala Jesus ka tekwa lo mae. Ma 'e totolia 'i 'amiu ioli falalau gi lo talasi 'e. Wasua ma 'e 'ato rasua, sulia iko 'ali 'amu sai 'ua ala falalauna etaeta ba gera la mae faasia saenala God gi. 'E 'oka 'ali ta ioli kae falalau 'amiu ka oli lou ala 'are fo gi. 'E malaa 'amu boboo 'ua fala kwai la susuu, sulia iko 'ali 'amu totolia 'ua 'aninala fana nasi gi.  
\v 13 Ala talasi ioli 'e wawade 'ua, fana 'e 'ania mola lo kwai la susuu, ma ka iko 'ali sai 'ua ala 'are rada gi.  
\v 14 Ma talasi ioli 'e ba'ela lo li, ka bi saiala 'aninala fana nasi gi, ma ka sai lo ala ta gi 'e 'oka ma ta gi ka ta'a.   
\c 6  
\p
\v 1 'E totolia gia sai lo ala falalauna talawarau 'urifo gi, ma gia ka sai lo ala falafala Christ gi lia 'e taua fitoona gia gi ka nasi. 'Uta 'e 'amu ka oli, ma gia ka falalau 'amiu lou 'alia etae falalauna ba Jesus gi? Gia sai lo ala lia gia ka bulusi faasia ta'ana li, 'are 'e saiala rauninaga fala maena li. Gia sai lo ala lia gia ka fakwalaimoki ala God.  
\v 2 Ma gia sai lo ala falafala ala sisiuabuna li, ma falafala ala alunala limala ioli gi fafia gwauga. Ma gia sai lo ala lia ioli mae gi gera kae tatae lou faasia maena li. Ma gia sai lou ala lia God kae lokokwaikwaina fala ioli ta'a gi li, ma gera kae famalifii firi.  
\v 3 Ma ala God ka ala'alia, gia ka saiala falafala Christ 'e totolia ioli ba'ela gi li.   
\p
\v 4 Ioli gera fakwalaimoki gi, ala gera taasi faeburi 'alia fitoona gera gi, 'ato rasua 'ali gera bulusi lou ma gera ka fakwalaimoki. 'I lao mae, ala talasi gera fakwalaimoki 'ua, gera io 'i laola madakwana God, ma gera ka sakea kwatena lia, ma gera ka sakea sui lo Aloe 'are Abu ka io failida.  
\v 5 Ma gera sai lou ala 'are 'oka ala saenala God gi. Ma gera ka lesia lou nanatana God kae fatailia ala fe atoa kae dao mae gi li.  
\v 6 Ma wasua 'ala 'are fo gi ka fuli fada, gera bulusi faasia fitoona gera ala God. Ma ka 'ato fala rananada 'ali ma gera ka bulusi lou, sulia 'e malaa gera fotoia lou Wela God ala 'ai rara folo, ma gera ka taua ioli gi gera ka lio ta'a ala.   
\p
\v 7 Ioli gi gera malaa raku uta 'e toofia ala talasi afula gi li. Ala ta ioli ka fasia ta 'ai 'oka ma ka bulao 'oka 'i lififo, God kae fa'oka raku la.  
\v 8 Ma ala 'ai tootoo gi 'o ma fasifasi kwasi gi mola gera bulao, raku fo 'e io gwaugwau mola 'ala, ma God kae kwatea kwaikwaina fala raku fo, ma kae 'agofia.   
\p
\v 9 Alae kwaima lau, wasua 'ala saenameulu famiu ka 'urifo, meulu sai mola 'ameulu ala fitoona 'amiu gi 'e nanata ma iko 'ali ferofero, sulia 'amu too lo ala 'are 'oka ala maurina fa'alu God 'e kwatea lo famiu gi.  
\v 10 God 'e rada talau. 'Ato 'ali 'e bulono 'alia galona 'oka 'amu tauda gi, failia kwaimanaa 'amu fatailia ala ranana 'amu taua ala ioli lia gi li, 'i lao mae, ma ala talasi 'e lou.  
\v 11 Malatameulu famiu lo 'amu ka kwaima ala ioli gi, la la ka dao ala fe atoa fafu'isi, 'ali 'amu sakea 'are 'amu faimasi fai 'i nali gi sui.  
\v 12 Ma iko 'ali meulu oga 'ali 'amu ka io rabe 'e'ela. Wasua ma, 'amu ka malaa ioli gera fakwalaimoki ala God ma gera ka fafu, ma 'urifo gera kae sakea 'are God 'e alafuu 'alida gi.   
\s1 Alafuunala God  
\p
\v 13 'Amu malata ga sulia Abraham. Ala talasi God 'e alafuu fala, 'e fanasia alafuuna lia 'alia ratala 'i talala, sulia iko ta ioli 'ali ba'ela ka liufia God fala falalamanala alafuuna fo.  
\v 14 Ma God ka sae 'uri 'e,  
\q1 “'E kwalaimoki rasua, lakae fa'oka 'o, ma lakae kwatea kwalofa 'o kae afula.”\x + \xo 6:14 \xt Jenesis 22:16, 17\x*   
\p
\v 15 Ma Abraham 'e fafu, ma ka sakea lo 'are God 'e alafuu 'alia fala.  
\v 16 Ma ala ta ioli mola 'ala 'e alafuu, 'i lia ka fanasia 'alia ratala ta ioli 'e 'ilitoa ka liufia 'i lia talala. Ala 'e 'urifo ioli gi sui gera ka fakwalaimoki ala alafuuna 'e fanasia 'urifo ai li.  
\v 17 Ma talasi God 'e sae alafuu fala Abraham, 'e oga ioli gera kae sakea 'are fo gi li, gera ka sai 'oka ala lia kae falalamaa etae alafuuna lia fada. Ma lia 'e kwatea 'i lia ka fanasia lo alafuuna fo.  
\v 18 Rua 'are gi 'e io ma ikoso olisi lo. Etala 'are lo, sae alafuuna God. Ma ruala 'are fanasinala alafuuna lia 'alia ratala. Ma 'i osiala rua 'are fo gi, gia saiai God ikoso koto.  
\p Gia tafi sui lo fala 'i soela God 'e lio suli gia. Ma sae alafuuna God ka raefale gia 'ali gia ura nasi 'alia kwaimamalina maasia 'are 'oka God 'e sae alafuu 'alida gi.  
\v 19 Kwaimamalina maasia 'are 'oka God 'e sae alafuu 'alida gi 'e fanasia maurinaga, malaa na fau li gwalu ba 'e fanasia te faga ba'ela 'ali ikoso afelailia. Ma gia ka fitoo ala Jesus lia 'e ruu 'i laola “lifi abu rasua” 'i laola Luma Abu God 'i nali.  
\v 20 Jesus lo 'ilito'ola fata abu 'e io firi malaa Melkisadek.\x + \xo 6:20 \xt Sam 110:4\x* Ma 'i lia ka ruu 'i lao aaga 'i laola lifi abu rasua fala rananaga.   
\c 7  
\s1 Melkisadek fata abu 'ilitoa ka liufia lou fata abu ala Lifae gi li  
\p
\v 1 Ma Melkisadek 'i lia walelitalona fafia falua 'i Salem, ma 'i lia fata abu God 'e 'ilitoa ka tasa. Ala te talasi, Abraham 'e kwalaa failia fai walelitalona gi, ma ka liufida. Ma talasi Abraham 'e oli fala falua lia li, ka manotonala Melkisadek sulia tala, ma Melkisadek ka fa'oka Abraham.  
\v 2 Ma Abraham ka kwatea tanafulula ala 'are 'e lauda ala kwalaana li fala.  
\p Ma fadanala ratala Melkisadek “walelitalona ala radana li.” Ma 'i lia 'e walelitalona fafia falua 'i Salem, lia fadanai “Walelitalona ala aroarona li.”  
\v 3 Ma iko 'ali gia sai mola ala ite mama lia, ma ite teite lia, ma kwalofa lia. Ma iko 'ali gia sai mola ala ta saena sulia futanala 'o ma maenala. 'Urifo Melkisadek 'e malaa mola Wela God, sulia galona lia ala fata abuna li ikoso sui.   
\p
\v 4 'Amu malata ga sulia 'ilitoanala Melkisadek, sulia koko gia Abraham 'e kwatea tanafulula ala 'are 'e lauda faasia malimae lia gi li fala.  
\v 5 Ma kwalofa ala Lifae gi 'e gera galo ala fata abuna li, taki 'e ilia gera ka sakea tanafulula ala too 'arena gi faasia walefae gera Jiu gi, wasua 'ala gera tatae lou mae faasia kwalofa Abraham.  
\v 6 Ma Melkisadek iko 'ali manotafa mae faasia kwalofa Lifae. Wasua ma 'e sakea mola 'ala tanafulula ala 'are gi lia Abraham 'e sakeda mae, ma ka fa'oka Abraham. Melkisadek 'e tau 'urifo, wasua 'ala Abraham lo God 'e sae alafuu fala.  
\v 7 Ma gia saiai, wale 'e kwatea 'oilakina fala ta ioli, 'i lia 'e 'ilitoa ka liufia ioli 'e sakea 'oilakina fo li.   
\p
\v 8 Ma fata abu gi gera la mae faasia kwalofa Lifae, gera sakea lo tanafulula 'are gi sui, wasua 'ala gera kae mae mola 'ada. Wasua ma Melkisadek, 'e sakea tanafulula ala 'are Abraham gi, ma gia saiai Geregerena Abu 'e ilia Melkisadek 'e mauri 'ua.  
\v 9 Kwalofa Lifae gi, gera saiai gera ka sakea tanafulula ala 'are gi ala talasi 'e. Ma 'e totolia gia ka ilia ala talasi Abraham 'e kwatea tanafulula ala 'are lia gi fala Melkisadek, Lifae lou 'e kwatea tanafulula ala 'are gi fala Melkisadek,  
\v 10 sulia Lifae 'e futa lo 'i buri ala kwalofa Abraham lia 'e kwate tanafulula ala 'are fala Melkisadek.   
\p
\v 11 Gia saiai talasi God 'e kwatea taki fala fuui ioli 'i Israel li, 'i lia ka filia fata abu gera la mae faasia Lifae gi 'ali gera 'ilitoa fafia taki fo gi. Ma ala 'e talawarau fala fata abu fo gi 'ali gera ka taua ioli gi 'ali gera rada ala galona gera gi, God ikoso kwatea mola mae ta fata abu lou malaa Melkisadek. Ma fata abu fa'alu fo iko 'ali malaa Aaron lia 'e la mae faasia kwalofa Lifae.  
\v 12 Sulia ala talasi gera olisia fata abu gi li, 'e totolia lou gera ka olisia taki Moses gi lia gera dau fafia.  
\v 13 Ma Aofia Jesus gera geregere sulia, lia iko 'ali manotafa mae faasia Lifae, ma iko ta ioli lou ala kwalofa Jesus 'ali 'e fata abu.  
\v 14 Sulia gia saiai Jesus 'e futa mae faasia kwalofa Juda. Ma Moses iko 'ali falalau 'alia 'uri ta wale mola 'ala ala kwalofa fo gi gera ka fata abu.   
\s1 Jesus fata abu lou malaa Melkisadek  
\p
\v 15 Ma gia saiala 'are fo gi 'e madakwa rasua, sulia teke fata abu mamata 'e manotafa lou mae lia 'e malaa Melkisadek.  
\v 16 Ma fata abu fa'alu fo iko lou ta fata abu 'i osiala 'e futa ala kwalofa fata abu gi li. 'I lia fata abu 'ala 'i osiala nanatana ala maurina firi lia li.  
\v 17 Sulia Geregerena Abu ba 'e ilia,  
\q1 “'I'o fata abu koe io firi lo 'amua malaa Melkisadek.”\x + \xo 7:17 \xt Sam 110:4\x*   
\p
\v 18 Gia sai sui ala taki sulia fata abuna li, God 'e olisia sui, sulia taki fo iko 'ali rana gia, ma ka dalafa mola 'ala.  
\v 19 Sulia taki fo, 'e 'ato rasua ka farada mola ta 'are. Ma talasi 'e, God 'e kwatea sui lo faga tala 'oka 'ali gia ka la mae 'i so'ela.   
\p
\v 20 Tala fa'alu fo 'e 'oka ka tasa, sulia God 'e sae alafuu 'ato, ala talasi 'e alua Jesus ka fata abu. Ala talasi 'e alua lo kwalofa Lifae gera ka fata abu, iko 'ali sae alafuu 'ato mola 'urifo.  
\v 21 Wasua ma Jesus, God 'e alua fata abuna lia 'alia sae alafuuna fala, sulia Geregerena Abu ba 'e ilia,  
\q1 “God 'e sae alafuu 'ato, ma ikoso olisia lo malatala. ‘Koe fata abu sulia mauri firi.’”\x + \xo 7:21 \xt Sam 110:4\x*   
\p
\v 22 Ma 'i osiala sae alafuuna 'ato God 'urifo, gia saiai sae alafuuna 'e Jesus 'e 'ilitoa fafia, 'e 'oka ka liufia sae alafuuna 'ua ala taki.   
\p
\v 23 Teke me 'are lou 'e kwatea ma gia ka saiala sae alafuuna fa'alu fo 'e 'oka ka tasa. Sulia 'i lao mae, fata abu gera fuli mae faasia kwalofa Lifae gi li gera afula, sulia talasi ta wale ada ka mae, 'e talawarau mola 'ala fala olisinala 'alia ta wale lou.  
\v 24 Ma Jesus 'e io firi, ma galona lia 'alia fata abuna li kae io firi.  
\v 25 Sulia 'e 'urifo, ala talasi gi sui 'e talawarau mola 'ala fala Jesus ka faamauria ioli gera la mae 'i so'ela God gi. Sulia Jesus 'e mauri firi, 'ali ka ranada 'i maala God.   
\p
\v 26 Sulia 'are fo gi, Jesus lo 'ilito'ola fata abu 'e gia boboo fala, sulia lia 'e abu rasua, ma ka rada sui, ma ka iko ta ta'ana ala. God 'e sakea faasia ioli ta'a gi, ma ka alu lia ka io 'i nali.  
\v 27 'I lia iko 'ali malaa 'ilito'ola fata abu ba 'i lao gi. Sulia 'ilito'ola fata abu ba 'i lao gi, gera saiai gera ka abulo ta'a, sulia 'i gera ioli gi mola lou. Lia fo 'e taua ma gera ka kwatea foasina gi sulia atoa gi fala lufaanala abulo ta'ana gera gi, sui bui gera ka bi kwatea foasina fala lufaanala abulo ta'ana ioli mamata gi li. Ma Jesus ikoso 'ali tau mola 'urifo, sulia iko 'ali 'e too ala ta ta'ana. Jesus 'e kwatea maurinala fala teke foasina ala teke talasi mola, ma iko ta foasina lou.  
\v 28 Taki faasia Moses, 'e filia lo wale iko 'ali rada sui 'ali gera ka fata abu. Wasua ma 'e tekwa lo mae 'i burila taki fo gi, God ka sae alafuu ma ka filia lo Wela lia. Ma God ka kwatea Jesus 'ilito'ola fata abu ali'afu io firi.   
\c 8  
\s1 Jesus lo 'ilito'ola fata abu gia  
\p
\v 1 Fadanala 'are 'e meulu sae sulida famiu gi 'e 'uri 'e: 'Ilito'ola fata abu gia 'e 'oka ka tasa, ma 'e io ala lifi 'ilitoa ka tasa 'i nali, sulia 'e io ala gula aolo ala God.  
\v 2 'E taua galona 'ilito'ola fata abu 'i laola lifi abu rasua 'i laola Babala Abu kwalaimoki 'i nali lia Aofia 'e raunailia, ma iko lou ioli gi gera raunailia.   
\p
\v 3 God ka filia lo 'ilito'ola fata abu gi sui 'ali gera ka kwatea foasina fala God. 'E 'urifo lou 'ilito'ola fata abu gia Christ 'e too ala teke foasina.  
\v 4 Ala Christ 'e io 'i laola falua 'i wado, ikoso 'ali galo ala fata abuna, sulia gia too lo ala fata abu afula gi lia gera kwatea lo 'are taki Moses gi 'e ilia.  
\v 5 Ma lifi abu gera galo 'i laola malaa mola 'ala lifi abu 'i nali, wasua ma 'e iko 'ali malaa rasua 'are kwalaimoki 'i nali gi. Sulia talasi Moses 'e garani raunailia Babala Abu God li, God ka ilia fala 'uri 'e,  
\q1 “'O raunae rada lo sulia 'are lau fatailia famu 'i gwaula uo li.”\x + \xo 8:5 \xt Eksodas 25:40\x*   
\p
\v 6 Ma galona Jesus ala fata abuna 'e 'oka ka liufia fata abu 'e 'i wado gi. 'I osiala lia 'e kwatea ma sae alafuuna fa'alu God kae fuli kwalaimoki lia 'e liufia sae alafuuna 'ualo li. Sae alafuuna fa'alu fo, 'e 'ilitoa sulia lia io 'i laola sae alafuuna 'ato God.   
\p
\v 7 Ala sae alafuuna 'ualo 'e galo 'oka mola 'ala, 'urila iko 'ali gia booboo mola fala ta sae alafuuna fa'alu 'i burila.  
\v 8 Wasua ma God 'e lesia ioli lia gi iko 'ali gera rono sulia sae alafuuna 'ualo, ma ka sae 'uri 'e,  
\q1 “'I lau Aofia, ma ala talasi kae lao 'ua mae, lakae alua sae alafuuna fa'alu fala famurinala fuui ioli Israel.   
\q1
\v 9 Ma sae alafuuna fa'alu fo, ikoso malaa mola sae alafuuna 'ualo lau kwatea fala koko 'ualo gera gi li, ala talasi lau talai gera mae faasia falua 'i Ejipt.  
\q1 Iko 'ali gera rono mola sulia sae alafuuna fo. Ma 'i osiala me 'are fo, laka faeburi 'ali gera.   
\q1
\v 10 Sae alafuuna fa'alu 'e lakae taua fala famurinala fuui ioli Israel li 'e 'uri 'e:  
\q1 Lakae alua taki lau gi 'i laola malatada, ma lakae gereda 'i laola maurinada. Ma lakae God 'ada, ma 'i ioli lau gi.   
\q1
\v 11 Ma ikoso gera oga lou ta ioli 'ali kae falalau gera suli lau.  
\q1 Sulia ala atoa fo, ioli gi sui, ioli 'ilitoa gi failia ioli wawade gi, gera kae saiagu.   
\q1
\v 12 Ma lakae kwailufa 'alia abulo ta'ana gera gi, ma lakae bulono 'alia rerona gera gi.”\x + \xo 8:12 \xt Jeremaea 31:31-34\x*   
\p
\v 13 Sulia God 'e sae sulia sae alafuuna fa'alu fo, 'e fatailia sae alafuuna 'i lao 'e 'ua lo. Ma gia ka saiai ala ta 'are 'e 'ua lo, 'urilali ma kae mou kwaitatali, ma ka fulu lo.   
\c 9  
\s1 Foasina 'i fua ma 'i nali  
\p
\v 1 'I laola sae alafuuna 'ualo, God 'e kwatea taki fala foasina, ma ka falalau lou sulia Babala Abu lia 'i wado.\fig Me 'are 'e lulula Babala Abu|src="LB00259" size="col" ref="9:1" \fig*  
\v 2 Gera raunailia Babala Abu fo 'alia 'abae toro, ma ka too ala rua mae tobi gi. Etala mae tobi gera soia 'alia “lifi abu.” Ma gera ka alua fe ulu 'i lififo, failia tatafe, failia berete fala kwatenai fala God ka io 'i fofola.\fig Me 'are 'e lulula lifi abu 'i laola Luma Abu God.|alt="HOLY PLACE" src="BK00278" size="col" ref="9:2" \fig*  
\v 3 Ma gera ka fagegeloa lou 'abae toro 'i matanala rua mae tobi fo gi. Ma ruala mae tobi gera soia 'alia “lifi abu rasua.”  
\v 4 Ma 'i laola maetobi fo, gera alua 'erefau li foasina lia gera raunailia 'alia goulu li. Ma 'erefau li foasina fo gera 'agofia 'ai si'ina 'oka gi 'i fofola. 'I lififo lou gera alua te bokosi ba'ela gera daua fafia 'alia goulu li. Bokosi ba'ela fo 'e fatailia 'alia sae alafuuna God. Ma 'i laola bokosi ba'ela fo te teu gera raunailia 'alia goulu, ma 'i laola gera ka alua fana gera soia 'alia “mana.” Ma 'i laola bokosi ba'ela fo lou, gera ka alua fe kuba Aaron lia 'e bulao, failia rua abae fau gi lia God 'e gerea sae alafuuna ali.  
\v 5 Ma bokosi ba'ela fo gera alua rua lului eniselo gi 'i fofola. Ma eniselo fo gi gera too ala 'aba'abae 'are gi lia 'e fatailia God 'e io 'i lififo. 'Aba'abae 'are fo gi gera tafa 'i fofola lifi la God 'e lafua ta'ana ioli gi li ai. Wasua ma ikoso lau falalau 'afu sulia 'are fo gi ala talasi 'e.   
\p
\v 6 Ma ala talasi gera rerei 'alia 'are 'urifo gi sui, fata abu gi gera ka ruu 'i laola etala mae tobi ala atoa gi sui fala taunala galona gera gi.  
\v 7 Ruala mae tobi lia gera soia 'alia “lifi abu rasua,” teke wale mola ka ruu ma 'i lia 'ilito'ola fata abu, ma ka ruu 'i lifi fo ala teke talasi mola 'i laola teke fe nali. Ma talasi 'e ruu 'i laola, ka sakea 'abu fala foasina 'alia fala lufaanala ta'ana lia gi, failia ta'ana ioli gi gera tauda ala talasi gera raria 'ua.  
\v 8 'Alia 'are fo gi, Aloe 'are Abu ka falalau gia lia ikoso 'ali gia ruu 'ua 'i laola “lifi abu rasua,” ala talasi Babala Abu 'e io 'ua.  
\v 9 Ma 'are fo 'e falalau gia 'alia teke 'are ala talasi 'e. 'E falalau gia 'alia kwatenala kwatena gi failia foasina gi ikoso faakwaga manola ioli gi.  
\v 10 'I osiala taki fo gi gera sae mola sulia fana, ma gouna, failia fakwaganala rabe. Ma taki fo gi gera laa mola sulia aba ala rabe li, ma gera ka 'ilitoa mola la la ka dao ala talasi God 'e olisia 'alia 'are fa'alu li.   
\p
\v 11 Ma ala talasi 'e Jesus Christ 'e dao lo mae fala taunala galona 'ilito'ola fata abu ala tala fa'alu 'e 'oka ka liufia tala 'ualo li. Babala Abu 'e galo 'i laola lia 'i nali, 'e 'oka ka tasa ma ka ba'ela liufia Babala Abu 'i wado. Iko ta ioli 'ali raunailia Babala Abu fo, ma Babala Abu fo iko 'ali io 'i laola molagali 'e.  
\v 12 Ma Jesus Christ ka ruu ala teke talasi mola 'i laola “lifi abu rasua” lia 'e io mae 'i nali, ma ikoso ke ruu lou. Ma talasi 'e ruu, iko 'ali sakea 'abula nanigot gi failia buluka fala foasina. Wasua ma 'e ruu 'ala 'ali ka kwatea 'abula 'i talala fala foasina, ma 'urifo ka taua ka talawarau faga fala iona 'alia maurina firi li.   
\p
\v 13 Sulia taki gi gera falalau 'alia, ala ta ioli iko 'ali kwaga 'i maala God, fata abu ka faakwaga 'alia sigirailianala 'alia 'abula nanigot, ma buluka, failia 'orala kale buluka.  
\v 14 Ma ala 'e talawarau fala ta ioli ka faakwaga 'i lia talala mola 'alia 'abula buluka failia nanigot gi, 'urifo 'e tasa rasua mola lo ala 'e kwaga 'alia 'abula Jesus Christ. Ma 'alia kwairanainala Aloe 'are Abu io firi, Jesus Christ 'e foasina 'alia rabela 'i talala fala God, ma 'i lia iko 'ali too mola ala ta rerona. Ma 'alia 'abula, 'e faakwaga maurinaga sui, 'ali gia galo fala God 'e mauri kwalaimoki. Ma ikoso 'ali gia taua lou tali 'are ka talai gia fala maena.   
\s1 'Abu 'e fatailia lia God 'e alafafia sae alafuuna lia  
\p
\v 15 Ma sulia 'e 'urifo, Jesus Christ lo 'e wale ba'ela lo fafia sae alafuuna fa'alu, 'ali ioli God 'e soida gi, gera kae sakea maurina firi 'e God 'e sae alafuu 'alia. 'E talawarau mola 'ala fala God ka tau 'urifo, 'i osiala maenala Jesus Christ. Ma 'alia maenala Jesus Christ, God ka lufaa lo ta'ana ioli gera tauda ala talasi sae alafuuna 'ualo 'e 'ilitoa 'ua fafida gi.   
\p
\v 16 'Amu malata ga sulia wale 'e io ma ka gerea te 'abae 'are 'ali fatailia kae mae, ite lo kae sakea too 'arena lia gi. Ala talasi wale fo 'e gerea 'abae 'are fo 'e mae, 'e 'ilitoa fala ta ioli lou ka fatae kwalaimoki ala lia 'e mae lo li, sui bui ioli fo 'e sae sulia 'i laola 'abae 'are fo li ka bi sakea lo tootoo 'arena fo gi.  
\v 17 Ma ala wale fo 'e gerea 'abae 'are fo li 'e mauri 'ua mola 'ala, 'are ba 'e gereda gi 'e 'ato 'ali fuli 'ua. Ma ala ka mae bui, 'are 'e gereda gi ka bi fuli.  
\v 18 Lia fo sae alafuuna etaeta ba God 'e dao kwalaimoki talasi gera sigirailia 'alia 'abu li.  
\v 19 'Urifo, Moses 'e falalaua ioli 'i lao gi sulia 'are taki 'e sae nasi gera ka tauda gi, sui ka sakea 'abu faasia buluka gi failia nanigot gi, ma ka dolaa failia kwai. Sui ka fawawaloa ifula sipsip gera famelamelaa failia rarala 'ai gera soia 'alia hisop. Ma ka sigirailia buka gera gerea 'alia taki fo gi li, ma ka sigirailia lou ala ioli gi.  
\v 20 Ma Moses ka sae 'uri 'e, “'Abu fo, 'e fatae kwalaimoki ala sae alafuuna 'e God 'e kwate kwaikaena 'amu ka ronosulia.”  
\v 21 'E 'urifo lou Moses ka sigirailia Babala Abu gera raunailia 'alia 'abae toro li, ma ka sigirailia lou 'are gi sui 'i laola fala foasinala God.  
\v 22 Ma ka 'urifo lou, taki gi ka ilia lia 'e io fala fakwaganala 'are afula gi 'alia 'abu. Ma 'urifo lou, ala iko 'ali gera raunia ta 'are mauri ma 'abula ka afe, 'e 'ato 'ali God 'ali kwailufa 'alia ta'ana ta ioli.   
\s1 Foasina Jesus Christ 'e lufaa ta'ana gi  
\p
\v 23 Ma 'are fala foasinala God 'i wado gi, gera malaa mola lulula 'are kwalaimoki mae 'i nali gi, liafo ioli gi gera ka fakwagada 'alia 'abu 'urifo. Wasua ma 'are kwalaimoki 'i nali gi gera totolia foasina 'e tasa ka liufia foasina 'alia 'abula 'are mauri gi li.  
\v 24 Sulia ala talasi Jesus Christ 'e kwatea lo foasina lia fala God, iko 'ali ruu mae 'i laola Babala Abu 'i wado lia ioli gi gera raunailia ka malaa mola 'ala lulula Babala Abu kwalaimoki 'i nali li. 'E la 'i nali, ma 'i lififo ka io failia God fala rananaga.   
\p
\v 25 Ma sulia fe nali gi sui, 'ilito'ola fata abu ioli Jiu gi li, ka ruu 'i laola “lifi abu rasua” ala Luma Abu God 'i wado, ala teke talasi 'i laola teke fe nali fala kwatenala foasina 'alia 'abula 'are mauri too 'a'ae gi li. Wasua ma Jesus Christ ikoso ruu ala talasi afula gi fala kwatenala foasina 'alia 'i lia talala.  
\v 26 Sulia ala 'e 'urifo, fuli mae ala fulinala raunailinala molagali, 'i lia ka famalifii talau ala talasi afula gi. Ala talasi fafu'isi 'e gi, 'i lia 'e la mae ala teke talasi mola 'ali lufaa ta'ana gi 'alia kwatenala foasina 'alia rabela 'i talala. Ma ikoso 'ali tau faeburi lou 'urifo.   
\p
\v 27 Ma ioli 'i laola molagali 'e li, gera kae mae ala teke talasi mola, sui bui God kae bi kwaida.  
\v 28 Ma 'urifo lou, Jesus Christ 'e mae ala teke talasi mola fala foasina fala lufaanala ta'ana ioli afula gi li. Ma 'i lia kae oli lou mae 'i wado, iko lou fala lufaanala ta'ana ioli gi li, wasua ma kae oli fala faamurinala ioli gera kwaimamali masia gi.   
\c 10  
\p
\v 1 Taki Moses 'e kwateda gi, 'i gera lulula mola 'are kwalaimoki 'e 'oka ka tasa lia 'e Jesus 'e tauda faga gi. Taki lo 'e ilia gera kae 'idufae kwatea foasina gi ala fe nali gi sui. Ma gia saiai taki fo gi, 'ato mola 'ali gera farada ioli gera foasia God gi.  
\v 2 Ala foasina fo 'e taua ma ioli gera foa geraka kwaga lo, iko 'ali gera totolia kwatenala lou ta foasina, sulia gera saiai God kae kwailufa lo 'alia ta'ana gera gi sui, ma ikoso gera kwaimalatai lou.  
\v 3 Sulia nali gi sui, foasina gera gi 'e kwatea gera ka malata oli fala ta'ana gera gi.  
\v 4 Sulia 'e 'ato mola fala 'abula buluka failia nanigot 'ali lafua ta'ana gia gi.   
\p
\v 5 Lia fo ala talasi Jesus Christ 'e garani ka la lo mae 'i laola molagali li, ka sae fala God 'uri 'e,  
\q1 “Iko lou foasina 'alia 'are mauri too 'a'ae gi 'e 'o oga, wasua ma 'o kwatea rabe fagu.   
\q1
\v 6 Sulia iko 'ali 'o babalafe mola failia foasina 'alia 'are mauri too 'a'ae gi lia gera 'agofia failia 'abula 'are too 'a'ae gi fala lufaanala ta'ana gi.   
\q1
\v 7 Sui, laka ilia, ‘God, lau dao lo 'ali lau tau sulia ta gi 'o oga, malaa gera geregere lo suli lau 'i laola Geregerena Abu li.’”\x + \xo 10:7 \xt Sam 40:6-8\x*   
\p
\v 8 Jesus ka ilia lia God iko 'ali oga mola kwatena gi failia foasina gera 'agofia failia 'abula 'are mauri too 'a'ae gi li, fala lufaanala ta'ana gi. Ma iko 'ali babalafe fafia 'are fo gi. Ma ka sae 'urifo, wasua 'ala taki Moses gi gera sae sulia foasina fo gi.  
\v 9 Ma ka sae lou 'uri 'e fala God, “Lau dao lo 'ali lau tau sulia ta gi 'o ogada.” Ma sulia saena fo, gia saiai God ka lafua lo foasina ala taki li, ma ka olisia lo 'alia foasina 'alia Jesus Christ.  
\v 10 Ma sulia Jesus Christ 'e tau sulia kwaiogalina God, God ka lafua lo ta'ana gia gi, ma ka faakwaga gia lo. 'E 'urifo, sulia foasina Jesus Christ 'alia rabela 'i talala ala teke talasi mola, ma ka iko lou ta foasina 'alia rabela ala ruala talasi.   
\p
\v 11 Ma fata abu Jiu gi gera 'idufae ruu 'i laola Luma Abu sulia atoa gi, ma gera ka taua galona gera 'alia foasina ala talasi afula gi. Wasua ma foasina fo gi, iko 'ali gera totolia lufaanala ta'ana ioli gi li.  
\v 12 Ma Jesus Christ lo, 'e kwatea foasina lia ala teke talasi mola fala lufaanala ta'ana gi. Ma iko 'ali oga kae kwatea lou ta foasina ala ta talasi mamataa. Ma talasi 'e kwatea lo foasina lia ka sui, ka io lo 'i gula aolo ala God, sulia galona lia fala foasina 'e sui lo.  
\v 13 Ma Jesus Christ kae io 'i lififo, ka kwaimamali fala talasi God kae kwalaa ka liufia malimae lia gi li.  
\v 14 Sulia teke foasina fo, 'i lia ka lufaa lo ta'ana gia gi, ma ka kwatea ma gia ka rada firi.   
\p
\v 15 Ma Aloe 'are Abu 'e sae lou sulia 'are fo gi 'uri 'e,   
\q1
\v 16 “'I lau Aofia, ma 'i laola atoa kae dao mae, lakae alua ta sae alafuuna fa'alu fada fala famaurinada 'uri 'e:  
\q1 Lakae alua taki lau gi 'i laola malatada, ma lakae gerea 'i laola maurinada.”\x + \xo 10:16 \xt Jeremaea 31:33-34\x*   
\m
\v 17 Ma Aloe 'are Abu ka sae lou 'uri 'e,  
\q1 “Rerona gera gi failia abulo ta'ana gera gi, lakae kwailufa 'alida, ma ikoso 'ali lau malata lou toonali.”\x + \xo 10:17 \xt Jeremaea 31:34\x*   
\p
\v 18 Talasi God 'e kwailufa lo 'alia ta'ana li, iko 'ali totolia fala kwatenala lou ta foasina fala lufaanala ta'ana gi.   
\s1 Gia dau nasi ala fitoona gia ala God.  
\p
\v 19 Alae iolifuta lau 'i osiala maenala Jesus, gia saiai gia ka laa rabetoo fala ruuna 'i laola “lifi abu rasua.”  
\v 20 Sulia Jesus 'e raunailia tala fa'alu faga fala laa na mae 'i so'ela God, 'ali gia ka mauri firi failia. 'E tau 'urifo 'alia foasina 'alia rabela.   
\p
\v 21 Gia too lo ala teke 'ilito'ola fata abu 'oka rasua 'e ba'ela fafia ioli God gi.  
\v 22 Ma sulia 'are fo gi, gia dao 'i so'ela God failia foana 'e kwalaimoki, failia fitoona nanata, ma malatana fa'alu, sulia gia saiai God 'e fakwaga gia lo 'alia Jesus. Ma gia ka sisiu abu lou fala fatailianala God 'e faakwaga gia lo.  
\v 23 Gia ka ilia fala ioli gi lia gia malata kwaimamali fala God. Ma gia ka dau nanata ala fitoona fala 'are ba God 'e sae alafuu 'alida faga gi, sulia gia saiai kae falalamaa saenala.  
\v 24 Ma gia malata sulia kwaiogalina gia 'i safitaga, 'ali gia ka kwairanai aga 'i safitaga, ma gia ka fatailia kwaimanaa faga 'i safitaga 'alia 'are 'oka gia tauda gi.  
\v 25 Ma ikoso 'ali gia io faasia logona failia foasinala God, malaa nali ioli gera kae tautaua. Wasua ma gia ka logo 'ali gia ka raefale gia 'i safitaga, sulia gia saiai atoa fala olinala mae Aofia Jesus 'e garani lo.   
\p
\v 26 Ala gia sai sui lo ala falalauna kwalaimoki gi, ma ala gia galo 'aga ala taunala 'are ta'a gi li, 'urila iko ta foasina 'ali 'e totolia mola lufaanala rerona gia gi.  
\v 27 Ma ala ta ioli 'e tau 'urifo, 'i lia ka mau sulia 'e maasia lo kwaikwaina ba'ela, failia dunaa 'ago'ago God kae fafuta'a 'alia ioli gera tatae bolosia gi.  
\v 28 Ma talasi ba sui, ioli 'e aburono mola 'ala ala taki Moses gi, ma ala ta olu ioli 'o ma ta rua ioli ka sae falalamaa lia ioli fo 'e rero, ikoso gera malataia, geraka raunia lo.  
\v 29 Ma ala 'e 'urifo fala taki Moses gi, kwaikwaina 'e ba'ela ka tasa 'e io fala ioli 'e 'e'ela 'alia Wela God 'i tara'ela. Sulia abulonala ioli 'urifo 'e fatailia lia 'e fia 'uria maenala Jesus Christ iko 'ali 'ilitoa mola, ma ka fia 'uria sae alafuuna fa'alu 'e totolia ka faakwaga lia iko 'ali 'ilitoa lou. Ioli 'urifo 'e sae fafuta'a Aloe 'are Abu lia 'e kwai'ofe ala.  
\v 30 Sulia gia saiai God ba 'e sae 'uri 'e, “Lakae duu, lau lo lakae kwatea kwaikwaina fala ioli gi, 'i osiala abulo ta'ana gera gi.” Ma Geregerena Abu ka sae lou 'uri 'e, “Aofia kae lokokwaikwaina fala ioli lia gi.”  
\v 31 Ala God mauri 'e dau fafia ta ioli fala lokokwaikwaina fala, ioli la kae mau rasua.   
\p
\v 32 Ma 'amu ka malata tonala talasi 'ato afula ba 'amu ruu 'i laola gi, talasi 'amu bi etae too ala madakwana Christ li.  
\v 33 Gera famalifii 'amiu, ma gera ka sae suarae 'amiu maala ioli afula gi. Ma ala nali talasi, 'amu ka marabe fala 'adona failia ioli kwaima 'amiu gi li lia nali ioli gera famalifii gera 'urifo.  
\v 34 Ma ala talasi gera alu ioli fakwalaimoki gi 'i laola raraa li, 'amu ka malataida, ma 'amu ka ranada. Ma 'amu ka babalafe mola 'amiu ala talasi ioli gi gera sakea too 'arena 'amiu gi sui, sulia 'amu saiai 'amu kae too lou ala too 'arena 'oka ka tasa io firi gi 'i nali.  
\v 35 Dunala 'e 'urifo, ikoso 'ali 'amu mau. Ala 'amu ka fakwalaimoki nanata ala God, 'amu kae sakea kwaiara lia famiu 'e 'oka ka tasa.  
\v 36 'Amu ka too ala fafuna, 'ali 'amu tau sulia kwaiogalina God, ma 'amu ka sakea 'are 'e alafuu famiu alida gi.  
\v 37 Sulia Geregerena Abu ba 'e sae 'uri 'e,  
\q1 “Garani kae la mae, ma 'e iko 'ali tekwa lo.   
\q1
\v 38 Ma ioli rada lau gi, gera kae fakwalaimoki ma gera kae mauri.  
\q1 Wasua ma ala ite 'e oli fae buri sulia gera mau, ikoso 'ali lau babalafe mola failida.”\x + \xo 10:38 \xt Habakuk 2:3-4\x*   
\m
\v 39 Wasua ma iko 'ali gia malaa ioli gera sakea kwaikwaina sulia gera la tatau 'urifo. Gia fakwalaimoki ala God, ma 'i lia ka faamauri gia.   
\c 11  
\s1 Gia fitoo ala God kae fulia sae alafuuna lia  
\p
\v 1 Ala gia fitoo ala God, gia saiai gia kae sakea 'are 'oka gia kwaimamali fai faasia gi, wasua 'ala iko 'ali gia lesida 'ua.  
\v 2 Ioli 'ua lo mae 'i lao gi, God 'e alafafida 'alia fitoona gera ala.   
\p
\v 3 Sulia fitoona gia gi, gia saiai God 'e raunailia 'are gi sui 'alia kwaikaena lia. 'Are gia lesida gi sui, gera fuli mae faasia 'are iko 'ali gia lesida gi.   
\p
\v 4 Ebol ba 'e fitoo ala God, ma ka kwatea foasina lia fala God 'e 'oka ka liufia foasina Kein 'e kwatea. Ma 'alia fitoona Ebol, God ka ilia 'e rada, sulia God 'e alafafia kwatena lia gi. 'I osiala Ebol 'e fitoo ala God, 'are 'e tauda gi ka falalau gia 'ua, wasua 'ala 'i lia ka mae lo.   
\p
\v 5 Ma Enok 'e fitoo ala God, ma iko 'ali mae, sulia God 'e sakea fala 'i nali, ma iko ta ioli 'i wado 'ali lesia lou Enok. Geregerena Abu ka ilia God 'e babalafe rasua fafia Enok, ma God ka sakea fala 'i nali.  
\v 6 Ala ta ioli iko 'ali fitoo ala God, 'ato rasua 'ali God ka babalafe fafia. Sulia ioli 'e la mae 'i so'ela God, 'i lia ka fitoo lo lia God 'e io ma ka fa'oka ioli gera la mae 'i so'ela gi.   
\p
\v 7 Noa 'e fitoo ala God, ma ka ronosulia kwaikaena God gi fala sulia kwaibusu kae dao mae. Lia 'e fakwalaimoki, wasua 'ala iko 'ali 'e lesia 'ua kwaibusu fo li. 'E ronosulia God ma ka raunailia te faga ba'ela. Ma talasi kwai ba'ela 'e fonu mae, 'i lia failia lumae ioli lia daulu mauri. Ma talasi 'e tau 'urifo, ka fatailia lia ioli mamata gi gera ta'a ma gera ka totolia sakenala kwaikwaina God. Ma God ka ilia Noa 'e rada 'alia fitoona lia.   
\p
\v 8 Abraham 'e fitoo ala God, ma ka ronosulia saenala. God 'e keria ka la faasia mae falua lia fala na gulae tolo mamata lou ala lifi God 'e alafuu 'alia kae kwatea fala. Lia fo Abraham ka tafisia falua lia, wasua 'ala iko 'ali sai 'ua ala 'i fe 'e kae la fai.  
\v 9 Ma talasi 'e dao ala gulae tolo God 'e alafuu 'alia li, ka io malaa na ioli mamata ala gulae tolo fo, ma ka io mola 'ala 'i laola babala. 'E 'urifo lou ala wela lia Aesak, ma koko lia Jakob. Daro sai lou ala sae alafuuna 'e God 'e ilia fala Abraham 'e io lou fadaroa.  
\v 10 Abraham 'e io 'urifo, 'i osiala 'e kwaimamali fala falua 'oka 'e God 'e raunailia 'i nali lia 'e io firi ma ikoso sui.   
\p
\v 11 Ma 'alia fitoona, Abraham 'e totolia ka too ala wela, wasua 'ala ka waro, ma wateu lia Sara ka 'amara lou. Ma daro too ala wela, sulia daro fitoo ala God kae falalamaa sae alafuuna lia.  
\v 12 Wasua 'ala Abraham 'e waro ma la la ka garani mae lo, daro too ala kwalofa afula rasua gi. Gera afula ka malaa kwalikwali gi 'i laola raloo, failia ole sulia asi li lia iko 'ali totolia iduminai.   
\p
\v 13 Wale fo gi gera fitoo ala God, ma gera ka etae mae sui bui gera ka bi sakea 'are God 'e sae alafuu 'alida fada gi. Ma gera ka malata sulia 'are God 'e sae alafuu 'alida gi, ma gera ka saiai gera kae sakea ala talasi mamata. Ma gera ka ilia lou falua 'e gera too ai, iko lou falua gera, sulia falua kwalaimoki gera 'i lia 'i nali.  
\v 14 Ioli gera sae 'urifo gi, gera fatailia gera rerei fala falua kwalaimoki gera.  
\v 15 Ma Abraham failia wale fo gi lou iko 'ali gera malata lo fala falua ba gera la lo faasia. Ala 'e 'urifo, 'e totolia mola 'ali gera oli lou fala lifi fo gi.  
\v 16 Wasua ma, gera lio 'afia falua 'oka liufia falua ba gera tafisia, sulia gera kwaimamali fala falua gera 'i nali. Sulia me 'are fo, God ka babalafe ala talasi gera soia 'alia God gera li, sulia 'e rerei sui lo 'alia falua ba'ela li iona 'i nali.   
\p
\v 17-18 Gia saiai God 'e sae alafuu fala Abraham, sulia wela lia Aesak lia kwalofa lia kae afula rasua. Ma talasi God 'e mailitonala fitoona Abraham, ka ilia fala ka raunia Aesak fala foasina. Ma fitoona Abraham 'e nanata 'i fofola sae alafuuna God fala, ma ka rerei fala rauninala wela moutae lia Aesak 'ali foasina 'alia.  
\v 19 Abraham 'e tau 'urifo 'i osiala 'e fia 'uria ala Aesak ka mae, God 'e saiai ka fatataea lou faasia maena. Ma ka 'urifo 'e malaa God 'e taea Aesak faasia maena kwalaimoki.   
\p
\v 20 Aesak lou, sulia fitoona lia ala God, ka fa'oka rua wela lia gi Jakob failia Esau, ma ka farono 'alia ta kae fuli mae fadaroa.   
\p
\v 21 Ma Jakob lou, 'alia fitoona lia, ka fa'oka wela wale Josef gi ala talasi Jakob 'e io lo fala maenala. Ma ka ura 'adaoro sulia fe kuba lia, ma ka foasia God.   
\p
\v 22 Ma Josef lou, 'alia fitoona lia, ala talasi 'e io lo maasia maenala, ka sae ka ilia fuui ioli Israel gera kae la faasia falua 'i Ejipt. Ma ka fabasuda, 'ali talasi gera kae la, gera ka sakea lou sulila failida.   
\p
\v 23 Mama Moses lou failia teite lia, daro fitoo ala God. Wasua 'ala walelitalona 'i Ejipt ka sae nasi 'ali gera raunia wela wale wawade Jiu gi li sui, iko 'ali daro mau mola. Ma talasi Moses 'e futa ai, daro ka faagwaa sulia olu madama gi, 'ali ikoso gera raunia, sulia wela fo lesinala 'e 'oka rasua.   
\p
\v 24 Ma Moses ka fitoo lou ala God. Ma talasi 'e ba'ela mae, 'e 'e'ela 'ali gera soia 'alia wela ranolia geli ulao Fero li.  
\v 25 Ma Moses ka oga famalifii na failia ioli God gi li, faasia iona babalafe 'alia ta'ana 'e ikoso 'ali tekwa mola.  
\v 26 Ma ka malataia 'e 'oka 'ali 'e famalifii sulia fitoona lia ala Christ lia God kae kwatea mae. Ma iko 'ali malata sulia too 'arena ba'ela 'e sakea 'i Ejipt. Sulia 'e maasia 'are 'oka God kae kwatea fala ala talasi kae lao 'ua mae li.   
\p
\v 27 Ma 'alia fitoona Moses ka la faasia 'i Ejipt. Ma iko 'ali mau mola 'alia ogata'anala walelitalona 'i Ejipt. 'E malaa Moses 'e lesia God lia iko ta ioli 'ali saiala lesinala. 'Urifo, Moses ka la lo.  
\v 28 Ma 'alia fitoona Moses ka ilia fala fuui ioli Israel 'ali gera la sulia fanana ala Daofae Liu na li, ma gera ka sigirailia mala luma ala luma gera gi 'alia 'abula kale sipsip gi, 'ali eniselo God 'e kwatea mae ikoso raunia fainaonao wela wale gera gi, ma ka dao tarosi faasia luma gera gi.   
\p
\v 29 Ma 'alia fitoona fuui ioli Israel li, gera ka totolia tofolo na ala Asi Melamelaa li. Sulia God 'e ketaa kwai 'ali gera ka la malaa gera liu 'i fofola wado lalana. Ma talasi wale 'i Ejipt gi gera tabalida ko, gera gimolo gera ka mae sui, sulia God 'e taua asi ba'ela ka fonu lou mae fafida.   
\p
\v 30 Fuui ioli Israel gera fitoo ala God. Ma talasi gera dao ala falua 'i Jeriko, gera ka liu galia te balibali fo sulia fiu fe atoa gi, sui God ka ofotailia lo te balibali fo 'i fua.  
\v 31 Ma te geli 'usulabata 'e io 'i laola falua fo 'i Jeriko li, ratala Rahab, 'i lia geli 'e fitoo ala God. Sulia ala talasi rua wale Josua 'e keri daroa daro la agwa mae fala lesinala nanatanala falua fo li, Rahab ka rana daroa. Sui, iko 'ali gera raunia Rahab, ala talasi fuui ioli Israel gera raunia sui ioli gera aburono ala God gi li.   
\p
\v 32 Ma laka mano ga 'urifo ala alaana 'e, sulia iko 'ali lau too lo ala ta talasi fala saena lou sulia fitoona wale malaa Gideon, Barak, Samson, Jefta, David, Samuel, failia profet gi.  
\v 33 Sulia gera fitoo ala God, ma nali ai ada gera kwalaa ka liufia ioli afula ala kwalaana 'i laola falua ba'ela gi li. Ma nali ioli ada gera taua 'are rada gi, ma gera ka sakea lo ta gi God 'e alafuu 'alia fada. Ma nali ai ada ala talasi gera io garania lion gi li, iko ta lion 'ali 'alaida mola.\fig 'Are 'e lulula lion|alt="LION" src="LB00047" size="col" ref="11:33" \fig*  
\v 34 Ma nali ai lou ada, gera fitoo ala God, ma dunaa 'ago'ago ba'ela iko 'ali 'agofida mola. Ma nali ai lou ada, malimae gera gi iko 'ali gera totolia rauninada. Nali ai ada, wasua 'ala gera ka watoutou, God 'e fananatada lou. Sui, gera ka tabalia wale li ofona afula mamata gi.  
\v 35 Ma nali geli 'i lao mae, gera fitoo ala God, ma wela gera 'e mae gi, gera ka mauri lou.  
\p Ma nali ioli lou gera fitoo ala God 'i lao, ma malimae gera gi gera rabusida fala maena. Wasua ma iko 'ali gera oga mola tafina faasia famalifiina fo li, 'i dunala gera sai 'oka ala lia gera kae tatae faasia maena fala maurina kwalaimoki.  
\v 36 Nali ai ada, malimae gera gi gera famauda ma gera ka rabusida. Ma nali ai ada gera ka firi fafida 'alia seni gi ma gera ka alu gera 'i laola raraa.  
\v 37 Nali ai lou ada, gera 'ui gera 'alia fau gi la la gera ka mae. Ma nali ioli lou gera 'oleda 'alia rua tofui 'are. Ma nali ai ada gera ka raunida 'alia 'au li ofona gi, 'i osiala fitoona gera gi. Ma nali ai ada, gera ka toro 'alia sunasunala sipsip failia nanigot gi, sulia gera siofa rasua lo. Ma malimae gera gi ka fafuta'ada ma gera ka famalifiida.  
\v 38 Ma ioli 'i laola molagali 'e li iko 'ali gera totolia iona failia ioli rada fo gi li. Ma nali ioli ada gera tafisia lo luma gera gi, gera ka liu kwailiu mola 'ada malaa ioli iko 'ali gera too ala ta falua gi. Gera io 'i laola abae lifi kwasi gi, ma gwaula uo gi, ma 'i laola 'iguara gi, ma gilu 'i laola wado gi li.   
\p
\v 39 God 'e babalafe rasua fafia ioli fo gi, 'alia fitoona gera gi, wasua ma iko 'ali gera sakea 'are God 'e alafuu 'alida fada gi,  
\v 40 sulia God 'e malata sulia 'are 'oka 'e io rerei 'ua maasi gia gi. 'E oga ioli fo gi gera ka io maasia 'ali gia ka 'ado lou failida, ala talasi kae kwatea lo 'are 'oka 'e sae alafuu 'alida gi.   
\c 12  
\s1 God Mama gia  
\p
\v 1 Ma ioli afula gera fakwalaimoki ala God 'urifo gi, 'e malaa gera io fae gia ala talasi 'e, ma gera ka liolio fala 'are gia tauda gi. Lia fo gia ka taasi faeburi lo 'alia 'are kae fadole gia gi, ma ta'ana 'e dau bebesi aga gi. Sulia gia malaa ioli gera lalao ala nonena ba'ela li. Ma gia ka lalao nanata, la la gia ka dao ala lifi gia kae faasuia ai.  
\v 2 Ma talasi gia lalao 'urifo li, gia ka alua maaga ala Jesus, sulia 'i lia lo kalokalola fitoona gia gi. Lia 'e marabe ka mae ala 'ai rara folo. Ma iko 'ali malata sulia 'ekena 'alia maena 'urifo li, sulia 'e saiai kae too ala babalafena 'i buri. Ma talasi 'e, 'e io lo 'i gula aolo ala God, lifi li 'ilitoana.  
\v 3 'Amu malata tonala 'atona ba gera tauda ala Jesus ala talasi ioli ta'a gi gera suarailia. 'Urifo, malatamiu ikoso 'ali dudu ala fitoona 'amiu gi.  
\v 4 'Amu ka galo nanata fala kwalana failia falafala ala ta'ana li. Wasua ma iko ta ioli amiu 'ali mae 'ua ala kwalana failia ta'ana li.   
\p
\v 5 Ma ikoso 'ali 'amu bulono 'alia alaana li raefalena ba God 'e ilia famiu wela lia gi li, lia ba 'e sae 'uri 'e,  
\q1 “Wela lau ko fafurono 'oka talasi Aofia kae balufi 'o.  
\q1 Ma talasi ka faalalau 'o, malatamu ikoso dudu.   
\q1
\v 6 Sulia Aofia 'e balufia ioli 'e kwaima ada gi.  
\q1 Ma ka kwatea kwaikwaina fala ioli 'e alafafida 'ali gera wela lia gi li.”\x + \xo 12:6 \xt Job 5:17; Provebs 3:11, 12\x*   
\m
\v 7 'Amu ura nasi, ma 'amu ka ala'alia God ka farada 'amiu, sulia 'are fo 'e fatailia lia God 'e lio suli 'amiu, ka malaa lo na mama.  
\v 8 God 'e saiai ka farada wela lia gi sui. Ma suli ala iko 'ali farada 'o, 'urila 'i'o iko lou wela kwalaimoki lia.  
\v 9 Ma talasi mama gia gi 'i lifi'e 'i laola molagali, gera farada gia, gia soi ba'ela ada. 'E 'urifo lou, gia ka ala'alia Mama gia 'i nali ka farada gia, 'ali gia too ala maurina firi.   
\p
\v 10 Mama gia gi 'i laola molagali, gera farada gia sulia talasi wawade mola, sulia falafala gera saiai 'e 'oka. Ma God 'e farada gia 'ali ka rana gia, ma ka farada gia 'ali gia ka io rada lou 'i malaa.  
\v 11 Ma talasi gera farada gia, gia kwaimalatai sulia 'e fii gia. Wasua ma 'i burila faradana, gia saiai gia kae too ala aroarona sulia abulonaga kae rada.   
\s1 Falalauna fala rananala ioli fakwalaimoki gi li  
\p
\v 12 'Arelafo, 'amu ka ura nasi, ma 'amu ka dau nanata ala fitoona 'amiu gi.  
\v 13 Ma 'amu ka liu sulia tala rada, 'ali ioli fakwalaimokina gera gi 'e watoutou, ikoso gera faeburi 'alia fitoona gera gi, wasua ma fitoona gera gi ka nanata.   
\p
\v 14 'Amu mailia fala iona 'alia aroarona failia ioli sui. Ma 'amu ka tau nanata 'ali abulona 'amiu gi ka rada sui. Ala maurinaga iko 'ali rada, 'e 'ato 'ali gia lesia Aofia.  
\v 15 'Amu tau nanata 'ali ikoso ta ioli amiu 'ali 'e'ela 'alia kwai'ofena God. Ma ikoso 'ali 'amu ala'alia ta ioli ka fafuta'a fitoona 'amiu gi, malaa na 'ai 'e too ala fuae 'are maemae gi ma ka fafuta'a lo ioli gi.  
\v 16 'Amu liolio 'oka 'ali ikoso ta ioli ka 'usulabata ma ikoso gera malata ba'ela ala God malaa Esau. Esau 'e foli 'alia 'ilitoana ala fainaonaona lia li sulia 'i lia wela wale 'i lao, fala teke me teu mola ala fana.  
\v 17 Ma gia saiai, 'i burila 'e tau 'urifo, Esau ka bi oga mama lia 'ali fa'oka lia. Wasua ma mama lia 'e 'e'ela 'alia, ma ka fa'oka 'ala walefae lia, sulia 'e 'ato lo fala olifailianala 'are 'e foli sui lo 'alida gi, wasua 'ala ka gwafea mama lia 'alia anina.   
\p
\v 18 Iko 'ali gia la mae fala fe uo, lifi ala dunaa li, maerodo, ma oru, malaa Jiu gi ala fe uo ba 'i Saenae talasi God 'e kwatea taki lia fada.  
\v 19 Ma gera ka ronoa linela bunu, failia linela akwana ba'ela God. Ma talasi ioli fo gi gera ronoa lo line 'are fo li, gera ka mau, ma gera ka anisia 'ali ikoso 'ali sae lou.  
\v 20 Sulia gera mau rasua 'alia saena ba God 'uri 'e, “Ala ta ioli 'o ma ta 'are mauri too 'a'ae wasua ala 'e dau tonala fe uo 'e, 'amu ka 'uia la la ka mae.”\x + \xo 12:20 \xt Eksodas 19:12-13\x*  
\v 21 Ma sulia 'are fo gera lesida gi ala talasi fo 'e taua gera ka mau rasua, Moses wasua ka ilia lou, “Lau mau ma laka lebelebe lo.”\x + \xo 12:21 \xt Diutronomi 9:19\x*   
\p
\v 22 Ma talasi 'e, iko 'ali gia dao garania 'are 'urifo. Sulia gia dao lo ala uo 'i Sion, falua God mauri, falua ba'ela 'i Jerusalem 'i nali. Lifi la logonae molae eniselo gi gera io ai.  
\v 23 Gia logo mae failia wela etaeta God gi lia gera babalafe rasua, ma ratada gera gerea 'i nali. Ma gia ka dao lo 'i so'ela God lia kae lokokwaikwaina fala ioli gi sui. Ma gia ka dao lou 'i so'ela manola ioli 'oka God 'e faradada gi.  
\v 24 Ma gia ka dao 'i so'ela Jesus, wale 'e raunailia sae alafuuna fa'alu faga failia God. Sulia 'abula 'e afe, gia kae sakea 'are 'oka gi, ma 'abula Ebol ikoso kwatea 'are 'oka fo gi.   
\p
\v 25 'Amu ka ronosulia saenala God. Sulia ioli ba gera 'e'ela 'alia ronosuli na ala God ala fe uo 'i Saenae gi li, gera sakea lo kwaikwaina ba'ela. 'Urifo lou, ala 'amu ka 'e'ela 'alia wale 'e sae mae faga faasia 'i nali, 'amu kae sakea kwaikwaina lou.  
\v 26 'E tekwa lo mae, molagali 'e 'asu sulia linela saenala God. Sui ala talasi 'e, 'i lia ka sae alafuu 'uri 'e, “Ta talasi lou, lakae 'asua molagali 'e failia 'i nali lou.”\x + \xo 12:26 \xt Hagae 2:6\x*  
\v 27 Ma saena fo, “ta talasi lou” 'e fatailia God kae 'asua 'are 'e raunailida gi, ma ka lafuda sui, 'ali 'are gera io firi gi mola kae ore.  
\v 28 Sulia gia io 'i laola 'Ilitoana 'e babatoo firi, gia ka batafea God, ma gia ka fababalafea God 'alia foasinala ma fatailianala fabaelanala.  
\v 29 Sulia God 'e gia, 'e saiala fafuta'anala ioli gi 'alia dunaa.   
\c 13  
\s1 Falafala 'e fababalafea God  
\p
\v 1 'I 'amiu alae waasila ala Christ, 'amu ura nasi 'alia kwaimanaa amiu 'i safitamiu.  
\v 2 Ikoso 'ali 'amu bulono 'alia kwalonala ioli dao gi. Sulia nali ioli gera kwaloa ioli gi 'i laola luma gera gi, wasua ma iko 'ali gera saiala lia ioli fo gi eniselo gi 'ada.\x + \xo 13:2 \xt Jenesis 18:1-8; 19:1-3\x*  
\v 3 Ikoso 'ali 'amu bulono lou 'alia ioli gera io 'i laola raraa gi li. 'Amu ka lio 'oka sulida, malaa 'amu io failida 'i laola raraa. Ma 'amu ka ranaa lou ioli gera too ala 'atona gi li, malaa 'amu too lou ala 'atona fo gi failida.   
\p
\v 4 'E 'oka famiu sui 'amu ka fabaelaa io 'adona ala ara araina li. 'Amu ka io kwalaimoki fala arai 'amiu gi ma wateu 'amiu gi. Sulia God kae kwatea kwaikwaina fala ite abulonala 'e midia ma ka kakabara ala lai na.   
\p
\v 5 'Amu ka sigi faasia silinala bata afula. Ma 'amu ka babalafe ala 'are 'amu too lo ali gi. Sulia God ba 'e ilia, “Ikoso 'ali lau la faasi 'amiu, ma ikoso 'ali lau 'e'ela 'ali 'amiu.”  
\v 6 Suli 'e 'urifo, gia ka sae rabetoo 'uri 'e, “Aofia lo wale li kwairanai lau. 'I dunala iko 'ali lau maulia ta 'are ioli gi gera ka taua agu.”   
\p
\v 7 Ikoso 'ali 'amu bulono lou 'alia ioli ba'ela 'amiu gi lia gera falalau 'amiu sui lo 'alia saenala God. 'Amu malata sulia maurina 'oka gera gi failia maenada. Ma 'amu ka tau sulia fitoona gera gi.   
\p
\v 8 Jesus Christ 'e io ma ikoso 'e olisi. 'E rada mola 'ala nalafi, ma 'i tara'ela, ma talasi kae lao mae.  
\v 9 Ma 'amu ka io faasia fakwalaimokinala falalauna mamata gi lia iko 'ali gera kwalaimoki. Kwai'ofena God faga 'e fananata maurinaga. 'Urifo ka kwairanai aga, wasua ma ronona sulia taki ala fana li ikoso kwairanai mola aga.   
\p
\v 10 Wasua ma ioli gera 'idufae donaa taki Jiu gi li ala foasina, iko 'ali gera too ala ta nanatana fala sakenala 'are 'oka gera la mae faasia foasina ala Christ.  
\v 11 'Amu saiai, talasi fuui ioli 'i Israel gera kwatea foasina sulia gera oga fakwaganada faasia ta'ana gera gi li, 'ilito'ola fata abu ka sakea mae 'abu ala 'are mauri too 'a'ae li 'i laola Luma Abu ala “lifi abu rasua.” Ma rabe 'are gi lia gera foasina 'alia, gera ka 'agofia 'i maluma ala falua.  
\v 12 Ma lia 'e kwatea ma Jesus wasua ka mae lou 'i maluma ala falua 'i Jerusalem, 'ali ka faakwaga ioli faasia ta'ana gera gi 'alia 'abula.  
\v 13 'Arelafo 'e taua giaka la lou 'i maluma ala falua 'i Jerusalem 'ali gera ka faa 'eke gia malaa gera taua ala Jesus.  
\v 14 Sulia 'i laola molagali, iko 'ali gia too ala ta falua 'e io firi. Wasua ma gia kwaimamali fala falua 'i nali lia kae dao mae.  
\v 15 Lia fo, gia ka batafea God ala talasi gi sui. Batafena fo, 'i lia foasina gia fala God sulia Jesus lo gia soia 'alia Aofia gia.  
\v 16 Ikoso 'ali 'amu bulono 'alia tau 'okana ma kwairanaina amiu 'i safitamiu. Sulia abulona 'urifo 'e malaa foasina lou lia God 'e babalafe fafia.   
\p
\v 17 'Amu ronosulia fainaonao 'amiu gi. Gera lio sulia manomiu, ma gera kae fuunailia galona gera gi fala God. Ma ala 'amu ronosulia saena gera gi, gera kae babalafe rasua fafia galona gera gi. Ma ala iko 'ali 'amu rono mola sulida, gera kae kwaimalatai sulia galona gera gi, ma 'ato 'ali gera rana 'amiu.   
\p
\v 18 'Amu galo ala foana fameulu. Meulu saiai iko ta 'are ta'a mola 'i laola abulo nameulu, sulia meulu maili fala taunala 'are 'oka gi ala talasi gi sui.  
\v 19 Ma lau suga 'amiu, 'amu ka foa fagu, 'ali God 'ali olifae nainali mae agu 'i soemiu.   
\s1 Foana  
\p
\v 20 God 'e taea Aofia gia Jesus faasia maena. Ma sulia foasina Jesus 'alia maenala, lia 'e malaa na wale 'e lio sulia sipsip lia gi. Ma God ka raunailia sae alafuuna fa'alu 'alia foasina Jesus. Ma sae alafuuna fo ikoso sui.  
\v 21 Lau foa 'ali God ala aroarona li kae kwatea 'are 'oka gi sui lia 'amu boboo fali 'ali 'amu ka taua kwaiogalina lia. Ma lau foa lou 'ali Jesus Christ kae rana 'amiu, ma 'amu ka fulia 'are God 'e babalafe fafida gi. Ma gia batafea Jesus Christ io firi! 'Eo kae 'urifo.   
\s1 Alaana fafu'isi gi  
\p
\v 22 Alae iolifuta lau, lau aniulu famiu 'ali 'amu fafurono fafu fala saena li raefalena lau famiu gi. Sulia geregerena lau, iko 'ali tekwa mola.   
\p
\v 23 Lau oga lakae faarono 'amiu 'alia walefae gia Timoti lia 'e latafa lo faasia raraa. Ala 'e dao nainali mae 'i lifi'e, la kae sakea fae lau ala talasi lakae la ko ai.   
\p
\v 24 'Amu ka kwatea ko sae ailafena 'oka 'ameulu fala ioli fainaonao 'amiu gi sui, ma fala ioli God gi sui lia gera io fae 'amiu. Iolifuta gia gi faasia 'i Itali, gera kwatea lou sae ailafena gera gi famiu.   
\p
\v 25 Lau foa 'ali God kae kwai'ofe amiu sui.   