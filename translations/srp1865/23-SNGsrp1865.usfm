\id SNG
\h Pesma nad pesmama
\toc1 Pesma nad pesmama
\toc2 Pesma nad pesmama
\toc3 Pes
\mt1 Pesma nad pesmama
\c 1
\s1 Prijateljeva i prijateljičina ljubav.
\p 
\v 1 Solomunova pesma nad pesmama.
\b
\q1 
\v 2 Da me hoće poljubiti poljupcem usta svojih!
\q2 Jer je tvoja ljubav bolja od vina.
\q1 
\v 3 Mirisom su tvoja ulja prekrasna;
\q2 ime ti je ulje razlito;
\q2 zato te ljube devojke.
\q1 
\v 4 Vuci me, za tobom ćemo trčati;
\q2 uvede me car u ložnicu svoju;
\b
\q1 radovaćemo se i veselićemo se tobom,
\q2 spominjaćemo ljubav tvoju više nego vino;
\q2 pravi ljube te.
\b
\q1 
\v 5 Crna sam, ali sam lepa,
\q2 kćeri jerusalimske,
\q2 kao šatori kidarski, kao zavesi Solomunovi.
\q1 
\v 6 Ne gledajte me što sam crna,
\q2 jer me je sunce opalilo;
\q1 sinovi matere moje rasrdivši se na me
\q2 postaviše me da čuvam vinograde,
\q2 i ne čuvah svoj vinograd, koji ja imam.
\q1 
\v 7 Kaži mi ti, kog ljubi duša moja,
\q2 gde paseš, gde planduješ?
\q2 Jer zašto bih lutala među stadima drugova tvojih?
\b
\q1 
\v 8 Ako ne znaš, najlepša između žena,
\q2 pođi tragom za stadom,
\q2 i pasi jariće svoje pokraj stanova pastirskih.
\b
\q1 
\v 9 Ti si mi, draga moja,
\q2 kao konji u kolima Faraonovim.
\q1 
\v 10 Obrazi su tvoji okićeni grivnama,
\q2 i grlo tvoje nizovima.
\b
\q1 
\v 11 Načinićemo ti zlatne grivne
\q2 sa šarama srebrnim.
\b
\q1 
\v 12 Dok je car za stolom,
\q2 nard moj pušta svoj miris.
\q1 
\v 13 Dragi mi je moj kita smirne,
\q2 koja među dojkama mojim počiva.
\q1 
\v 14 Dragi mi je moj grozd kiprov
\q2 iz vinograda engadskih.
\b
\q1 
\v 15 Lepa ti si, draga moja,
\q2 lepa ti si!
\q2 Oči su ti kao u golubice.
\b
\q1 
\v 16 Lep ti si, dragi moj, i ljubak!
\q2 I postelja naša zeleni se.
\q1 
\v 17 Grede su nam u kućama kedrove,
\q2 daske su nam jelove.
\c 2
\s1 Čežnja prijateljice za prijateljem.
\q1 
\v 1 Ja sam ruža saronska,
\q2 ljiljan u dolu.
\b
\q1 
\v 2 Šta je ljiljan među trnjem,
\q2 to je draga moja među devojkama.
\b
\q1 
\v 3 Šta je jabuka među drvetima šumskim,
\q2 to je dragi moj među momcima;
\q1 želeh hlad njen, i sedoh,
\q2 i rod je njen sladak grlu mom.
\q1 
\v 4 Uvede me u kuću gde je gozba,
\q2 a zastava mu je ljubav k meni.
\q1 
\v 5 Potkrepite me žbanovima,
\q2 pridržite me jabukama,
\q2 jer sam bolna od ljubavi.
\q1 
\v 6 Leva je ruka njegova meni pod glavom,
\q2 a desnom me grli.
\q1 
\v 7 Zaklinjem vas, kćeri jerusalimske,
\q2 srnama i košutama poljskim,
\q1 ne budite ljubavi moje, ne budite je,
\q2 dok joj ne bude volja.
\b
\q1 
\v 8 Glas dragog mog;
\q2 evo ga, ide skačući preko gora,
\q2 poskakujući preko humova.
\q1 
\v 9 Dragi je moj kao srna ili kao jelenče;
\q2 evo ga, stoji iza našeg zida,
\q2 gleda kroz prozor, viri kroz rešetku.
\q1 
\v 10 Progovori dragi moj i reče mi:
\q2 Ustani, draga moja, lepotice moja, i hodi.
\q1 
\v 11 Jer gle, zima prođe,
\q2 minuše daždi, otidoše.
\q1 
\v 12 Cveće se vidi po zemlji,
\q2 dođe vreme pevanju,
\q2 i glas grličin čuje se u našoj zemlji.
\q1 
\v 13 Smokva je pustila zametke svoje,
\q2 i loza vinova ucvala miriše.
\q2 Ustani, draga moja, lepotice moja, i hodi.
\q1 
\v 14 Golubice moja u raselinama kamenim,
\q2 u zaklonu vrletnom!
\q1 Daj da vidim lice tvoje,
\q2 daj da čujem glas tvoj;
\q1 jer je glas tvoj sladak
\q2 i lice tvoje krasno.
\q1 
\v 15 Pohvatajte nam lisice,
\q2 male lisice, što kvare vinograde,
\q2 jer naši vinogradi cvatu.
\b
\q1 
\v 16 Moj je dragi moj, i ja sam njegova,
\q2 on pase među ljiljanima.
\q1 
\v 17 Dok zahladi dan i senke otidu,
\q2 vrati se, budi kao srna, dragi moj,
\q2 ili kao jelenče po gorama razdeljenim.
\c 3
\s1 Vernost prijateljičina. Slava prijateljeva.
\q1 
\v 1 Na postelji svojoj noću tražih
\q2 onog koga ljubi duša moja,
\q2 tražih ga, ali ga ne nađoh.
\q1 
\v 2 Sada ću ustati, pa idem po gradu,
\q2 po trgovima i po ulicama tražiću
\q1 onog koga ljubi duša moja.
\q2 Tražih ga, ali ga ne nađoh.
\q1 
\v 3 Nađoše me stražari, koji obilaze po gradu.
\q2 Videste li onog koga ljubi duša moja?
\q1 
\v 4 Malo ih zaminuh,
\q2 i nađoh onog koga ljubi duša moja;
\q1 i uhvatih ga, i neću ga pustiti
\q2 dokle ga ne odvedem u kuću matere svoje
\q2 i u ložnicu roditeljke svoje.
\q1 
\v 5 Zaklinjem vas, kćeri jerusalimske,
\q2 srnama i košutama poljskim,
\q1 ne budite ljubavi moje, ne budite je,
\q2 dok joj ne bude volja.
\b
\q1 
\v 6 Ko je ona što ide gore iz pustinje
\q2 kao stupovi od dima, potkađena smirnom i tamjanom
\q2 i svakojakim praškom apotekarskim?
\q1 
\v 7 Gle, odar Solomunov,
\q2 a oko njega šezdeset junaka
\q2 između junaka Izrailjevih:
\q1 
\v 8 Svi imaju mačeve, vešti su boju,
\q2 u svakog je mač o bedru radi straha noćnog.
\q1 
\v 9 Odar je načinio sebi car Solomun
\q2 od drveta livanskog;
\q1 
\v 10 Stupce mu je načinio od srebra,
\q2 uzglavlje od zlata, nebo od skerleta,
\q2 a iznutra nastrt ljubavlju za kćeri jerusalimske.
\q1 
\v 11 Iziđite, kćeri sionske,
\q2 i gledajte cara Solomuna
\q2 pod vencem kojim ga mati njegova okiti
\q1 na dan svadbe njegove
\q2 i na dan veselja srca njegovog.
\c 4
\s1 Miline prijateljičine.
\q1 
\v 1 Lepa ti si, draga moja, lepa ti si,
\q2 oči su ti kao u golubice
\q2 između vitica tvojih;
\q1 kosa ti je kao stado koza
\q2 koje se vide na gori Galadu;
\q1 
\v 2 Zubi su ti kao stado ovaca jednakih,
\q2 kad izlaze iz kupala,
\q2 koje se sve blizne, a nijedne nema jalove.
\q1 
\v 3 Usne su ti kao konac skerleta,
\q2 a govor ti je ljubak;
\q1 kao kriška šipka jagodice su tvoje
\q2 između vitica tvojih;
\q1 
\v 4 Vrat ti je kao kula Davidova
\q2 sazidana za oružje,
\q1 gde vise hiljadama štitovi
\q2 i svakojako oružje junačko;
\q1 
\v 5 Dve su ti dojke kao dva laneta blizanca,
\q2 koji pasu među ljiljanima.
\q1 
\v 6 Dok dan zahladi i senke otidu,
\q2 ići ću ka gori smirnovoj i ka humu tamjanovom.
\q1 
\v 7 Sva si lepa draga moja,
\q2 i nema nedostataka na tebi.
\q1 
\v 8 Hodi sa mnom s Livana, nevesto,
\q2 hodi sa mnom s Livana,
\q1 da gledaš s vrha amanskog,
\q2 s vrha senirskog i ermonskog,
\q2 iz pećina lavovskih, s gora risovskih.
\b
\q1 
\v 9 Otela si mi srce, sestro moja nevesto,
\q2 otela si mi srce jednim okom svojim
\q2 i jednim lančićem s grla svog.
\q1 
\v 10 Lepa li je ljubav tvoja, sestro moja nevesto,
\q2 bolja je od vina ljubav tvoja,
\q2 i miris ulja tvojih od svih mirisnih stvari.
\q1 
\v 11 S usana tvojih kaplje saće, nevesto,
\q2 pod jezikom ti je med i mleko,
\q2 i miris je haljina tvojih kao miris livanski.
\q1 
\v 12 Ti si kao vrt zatvoren, sestro moja nevesto,
\q2 izvor zatvoren, studenac zapečaćen.
\q1 
\v 13 Bilje je tvoje voćnjak od šipaka
\q2 s voćem krasnim,
\q2 od kipra i narda.
\q1 
\v 14 Od narda i šafrana,
\q2 od iđirota i cimeta
\q1 sa svakojakim drvljem za kad,
\q2 od smirne i aloja
\q2 i sa svakim prekrasnim mirisima.
\q1 
\v 15 Izvore vrtovima,
\q2 studenče vode žive
\q2 i koja teče s Livana!
\b
\q1 
\v 16 Ustani severe, i hodi juže,
\q2 i duni po vrtu mom da kaplju mirisi njegovi;
\b
\q1 neka dođe dragi moj u vrt svoj,
\q2 i jede krasno voće svoje.
\c 5
\s1 Prijateljica sluša glas prijateljev, tuguje zbog rastanka s njim i slavi njegovu lepotu.
\q1 
\v 1 Dođoh u vrt svoj, sestro moja nevesto,
\q2 berem smirnu svoju i mirise svoje,
\q1 jedem saće svoje i med svoj,
\q2 pijem vino svoje i mleko svoje;
\b
\q1 jedite, prijatelji, pijte,
\q2 i opijte se, mili moji!
\b
\q1 
\v 2 Ja spavam, a srce je moje budno;
\q1 eto glasa dragog mog,
\q2 koji kuca: Otvori mi, sestro moja,
\q2 draga moja, golubice moja, bezazlena moja;
\q1 jer je glava moja puna rose
\q2 i kosa moja noćnih kapi.
\q1 
\v 3 Svukla sam haljinu svoju,
\q2 kako ću je obući?
\q1 Oprala sam noge svoje,
\q2 kako ću ih kaljati?
\q1 
\v 4 Dragi moj promoli ruku svoju kroz rupu,
\q2 a šta je u meni ustrepta od njega.
\q1 
\v 5 Ja ustah da otvorim dragom svom,
\q2 a s ruku mojih prokapa smirna,
\q2 i niz prste moje poteče smirna na držak od brave.
\q1 
\v 6 Otvorih dragom svom,
\q2 ali dragog mog ne beše, otide.
\q1 Bejah izvan sebe kad on progovori.
\q1 Tražih ga, ali ga ne nađoh;
\q2 vikah ga, ali mi se ne odazva.
\q1 
\v 7 Nađoše me stražari, koji obilaze po gradu,
\q2 biše me, raniše me,
\q2 uzeše preves moj s mene stražari po zidovima.
\q1 
\v 8 Zaklinjem vas, kćeri jerusalimske,
\q2 ako nađete dragog mog, šta ćete mu kazati?
\q2 Da sam bolna od ljubavi.
\b
\q1 
\v 9 Šta je tvoj dragi bolji od drugih dragih,
\q2 o najlepša među ženama?
\q1 Šta je tvoj dragi bolji od drugih dragih,
\q2 te nas tako zaklinješ?
\b
\q1 
\v 10 Dragi je moj beo i rumen,
\q2 zastavnik između deset hiljada;
\q1 
\v 11 Glava mu je najbolje zlato,
\q2 kosa mu je kudrava,
\q2 crna kao gavran;
\q1 
\v 12 Oči su mu kao u goluba na potocima vodenim,
\q2 mlekom umivene, i stoje u obilju;
\q1 
\v 13 Obrazi su mu kao lehe mirisnog bilja,
\q2 kao cveće mirisno;
\q1 usne su mu kao ljiljan,
\q2 s njih kaplje smirna žitka;
\q1 
\v 14 Na rukama su mu zlatni prsteni,
\q2 na kojima su ukovani virili;
\q1 trbuh mu je kao svetla slonova kost
\q2 obložena safirima.
\q1 
\v 15 Gnjati su mu kao stupovi od mramora,
\q2 uglavljeni na zlatnom podnožju;
\q1 stas mu je Livan,
\q2 krasan kao kedri.
\q1 
\v 16 Usta su mu slatka i sav je ljubak.
\q1 Takav je moj dragi, takav je moj mili,
\q2 kćeri jerusalimske.
\b
\q1 
\v 17 Kuda otide dragi tvoj,
\q2 najlepša među ženama?
\q1 Kuda zamače dragi tvoj,
\q2 da ga tražimo s tobom?
\c 6
\s1 Radovanje povratku prijateljičinu.
\q1 
\v 1 Dragi moj siđe u vrt svoj,
\q2 k lehama mirisnog bilja,
\q1 da pase po vrtovima
\q2 i da bere ljiljane.
\q1 
\v 2 Ja sam dragog svog,
\q2 i moj je dragi moj,
\q2 koji pase među ljiljanima.
\b
\q1 
\v 3 Lepa si, draga moja, kao Tersa,
\q2 krasna si kao Jerusalim,
\q2 strašna kao vojska sa zastavama.
\q1 
\v 4 Odvrati oči svoje od mene,
\q2 jer me raspaljuju.
\q1 Kosa ti je kao stado koza
\q2 koje se vide na Galadu.
\q1 
\v 5 Zubi su ti kao stado ovaca kad izlaze iz kupala,
\q2 koje se sve blizne, a nijedne nema jalove.
\q1 
\v 6 Jagodice su tvoje između vitica tvojih
\q2 kao kriška šipka.
\q1 
\v 7 Šezdeset ima carica
\q2 i osamdeset inoča,
\q2 i devojaka bez broja;
\q1 
\v 8 Ali je jedna golubica moja,
\q2 bezazlena moja, jedinica u matere svoje,
\q2 izabrana u roditeljke svoje.
\q1 Videše je devojke i nazvaše je blaženom;
\q2 i carice i inoče hvališe je.
\b
\q1 
\v 9 Ko je ona što se vidi kao zora,
\q2 lepa kao mesec, čista kao sunce,
\q2 strašna kao vojska sa zastavama?
\b
\q1 
\v 10 Siđoh u orašje
\q2 da vidim voće u dolu,
\q1 da vidim cvate li vinova loza,
\q2 pupe li šipci.
\q1 
\v 11 Ne doznah ništa,
\q2 a duša me moja posadi na kola Aminadavova.
\b
\q1 
\v 12 Vrati se, vrati se Sulamko,
\q2 vrati se, vrati se, da te gledamo.
\b
\q1 Šta ćete gledati na Sulamci?
\q2 Kao čete vojničke.
\c 7
\s1 Razgovor između prijatelja i prijateljice.
\q1 
\v 1 Kako su lepe noge tvoje u obući,
\q2 kćeri kneževska;
\q1 sastavci su bedara tvojih kao grivne,
\q2 delo ruku umetničkih.
\q1 
\v 2 Pupak ti je kao čaša okrugla,
\q2 koji nije nikad bez pića;
\q1 trbuh ti je kao stog pšenice
\q2 ograđen ljiljanima;
\q1 
\v 3 Dve dojke tvoje
\q2 kao dva blizanca srnčeta;
\q1 
\v 4 Vrat ti je kao kula od slonove kosti;
\q1 oči su ti kao jezera u Esevonu
\q2 na vratima vatravimskim;
\q1 nos ti je kao kula livanska
\q2 koja gleda prema Damasku;
\q1 
\v 5 Glava je tvoja na tebi kao Karmil,
\q2 i kosa na glavi tvojoj kao carska porfira
\q2 u bore nabrana.
\b
\q1 
\v 6 Kako si lepa i kako si ljupka,
\q2 o ljubavi u milinama!
\q1 
\v 7 Uzrast ti je kao palma,
\q2 i dojke kao grozdovi.
\q1 
\v 8 Rekoh: Popeću se na palmu,
\q2 dohvatiću grane njene;
\q1 i biće dojke tvoje kao grozdovi na vinovoj lozi,
\q2 i miris nosa tvog kao jabuke;
\q1 
\v 9 I grlo tvoje kao dobro vino,
\q2 koje ide pravo dragom mom
\q2 i čini da govore usne onih koji spavaju.
\b
\q1 
\v 10 Ja sam dragog svog,
\q2 i njega je želja za mnom.
\b
\q1 
\v 11 Hodi, dragi moj, da idemo u polje,
\q2 da noćujemo u selima.
\q1 
\v 12 Ranićemo u vinograde
\q2 da vidimo cvate li vinova loza,
\q1 zameće li se grožđe,
\q2 cvatu li šipci;
\q1 onde ću ti dati ljubav svoju.
\q1 
\v 13 Mandragore puštaju miris,
\q2 i na vratima je našim svakojako krasno voće,
\q1 novo i staro,
\q2 koje za te dohranih, dragi moj.
\c 8
\s1 Vernost večno sjedinjenih.
\q1 
\v 1 O da bi mi brat bio,
\q2 da bi sao sise matere moje!
\q1 Našavši te na polju
\q2 poljubila bih te,
\q2 i ne bih bila prekorna.
\q1 
\v 2 Povela bih te
\q2 i dovela bih te u kuću matere svoje;
\q1 ti bi me učio,
\q2 a ja bih te pojila vinom mirisavim,
\q2 sokom od šipaka.
\q1 
\v 3 Leva je ruka njegova meni pod glavom,
\q2 a desnom me grli.
\q1 
\v 4 Zaklinjem vas, kćeri jerusalimske,
\q2 ne budite ljubavi moje,
\q2 ne budite je, dokle joj ne bude volja.
\b
\q1 
\v 5 Ko je ona što ide gore od pustinje
\q2 naslanjajući se na dragog svog?
\b
\q1 Pod jabukom probudih te,
\q2 gde te rodi mati tvoja,
\q2 gde te rodi roditeljka tvoja.
\b
\q1 
\v 6 Metni me kao pečat na srce svoje,
\q2 kao pečat na mišicu svoju.
\q1 Jer je ljubav jaka kao smrt,
\q2 i ljubavna sumnja tvrda kao grob;
\q2 žar je njen kao žar ognjen, plamen Božji.
\q1 
\v 7 Mnoga voda ne može ugasiti ljubavi,
\q2 niti je reke potopiti.
\q1 Da ko daje sve imanje doma svog za tu ljubav,
\q2 osramotio bi se.
\b
\q1 
\v 8 Imamo sestru malenu, koja još nema dojaka.
\q1 Šta ćemo činiti sa sestrom svojom
\q2 kad bude reč o njoj?
\q1 
\v 9 Ako je zid, zagradićemo na njemu dvor od srebra;
\q2 ako li vrata, utvrdićemo ih daskama kedrovim.
\b
\q1 
\v 10 Ja sam zid i dojke su moje kao kule.
\q1 Tada postah u očima njegovim kao ona koja nađe mir.
\b
\q1 
\v 11 Vinograd imaše Solomun u Valamonu;
\q2 dade vinograd čuvarima
\q1 da svaki donosi za rod njegov
\q2 po hiljadu srebrnika.
\q1 
\v 12 Moj vinograd koji ja imam, preda mnom je.
\q1 Neka tebi, Solomune, hiljada,
\q2 i dve stotine onima koji čuvaju rod njegov.
\b
\q1 
\v 13 Koja nastavaš u vrtovima!
\q1 Drugovi slušaju glas tvoj,
\q2 daj mi da ga čujem.
\b
\q1 
\v 14 Brže, dragi moj!
\q2 I budi kao srna ili kao jelenče
\q2 na gorama mirisnim. 
