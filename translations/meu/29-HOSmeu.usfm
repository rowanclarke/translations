\id HOS .01, Hosea 1, Motu, PNG, RTWP 12/92
\h HOSEA
\toc1 HOSEA
\toc2 HOSEA
\mt1 HOSEA
\c 1
\s1 Hosea adavana bona natuna
\p 
\v 1 Ina na Iehova ena hereva, Hosea Be-eri enai e kau herevana, Iuda pavapavadia Usia bona Iotam bona Ahasa bona Hesekia bona Israel pavapavana Ieroboam Ioasa edia nega ai.
\p 
\v 2 Iehova ese Hosea uduna amo e hereva matama negana ai, Iehova ese Hosea e hamaoroa, eto, Aola, ariara hahinena ta bavadavaia, bona ariara memerodia ba havaradia, badina be ina tano taudia e lebulebu hereamu, Iehova irakatanina ai.
\v 3 Taunabunai ia na ela, Gomere, Diblaimi natuna hahinena, e abia; bena hahine na e rogorogo, natuna maruanena ta e abia.
\p 
\v 4 Iehova ese e hamaoroa, eto, Ladana ba nemaia Iesrele; badina be asi vanahana lau ese Iehu iduhuna davana baina henia, Iesrele rarana dainai, bona Israel iduhuna basileiana baine ha-orea.
\v 5 Una dina ai Israel ena peva baina hakwaidua, Iesrele kourana ai.
\p 
\v 6 Hahine na e rogorogo lou, natuna kekenina ta e abia. Iehova ese Hosea e hamaoroa, eto, Ladana ba nemaia “Se bogaia hisimu”; badina be ina murinai lau ese Israel iduhuna taudia basina bogadia hisi, bona edia dika basina gwau tao, lasi ona lasi vaitani.
\v 7 A Iuda iduhuna taudia baina bogadia hisi; lau Iehova, edia Dirava, sibogu ese baina hamauridia, dia peva eiava dare eiava tuari eiava hosi eiava hosi-gui taudia amo.
\p 
\v 8 “Se bogaia hisimu” ese sinana ratana e rakatania murinai, hahine na ma e rogorogo lou, bena mero ta ma e abia.
\v 9 Bena Iehova eto, Ladana ba nemaia “Dia lauegu bese”; badina be umui na dia lauegu bese bona lau na dia emui Dirava.
\p 
\v 10 Ḡau tamona, Israel taudia na bae hutuma, kone mirina na heto, basie hahetohodia bona basie duahidia diba ḡauna. E hamaorodia “Umui na dia lauegu bese” gabuna ai, bae hamaorodia, baeto “Mauri Diravana natuna verina”.
\v 11 Bena Iuda taudia bona Israel taudia na bae hahebou, ikwaradia tauna tamona bae gwauraia hidi. Bena tano amo bae dae lao, badina be Iesrele ena dina baine bada.
\c 2
\s1 Iehova ena uraheni ena gwau-edeede besena enai
\p 
\v 1 Tadikamamui ba hamaorodia, baoto “Egu bese”, bona taihumui ba hamaorodia, baoto “Hebogahisi vada e davaria”.
\q1 
\v 2 Sinamui ba noia,
\q2 badina be ia na dia lau adavagu,
\q2 bona lau na dia ia adavana;
\q1 ba noia, ena ariara karadia na vairana amo baine atodia siri,
\q2 bona ena heuda-hanai ratana padadia amo;
\q1 
\v 3 ena dabua iboudiai baina tapusi oho
\q2 ena vara dinana ai e ga ae heḡereḡerena ai baina halaoa,
\q1 tano ḡaḡaena bona tano kaukauna heḡereḡerena ai baina halaoa,
\q2 bona ranu-mase amo baina alaia na garina.
\q1 
\v 4 Ia natuna danu basina bogadia hisi,
\q2 badina be idia na ariara natudia.
\q1 
\v 5 Badina be sinadia ese ariara karadia vada e kara,
\q2 e havaradia hahinena ese hemarai karadia vada e kara.
\q1 Badina be ia eto: E ura henigumu taudia muridia amo bainala,
\q2 idia ese aniani bona ranu e henigumu,
\q1 egu mamoe huina bona egu varo aukana,
\q2 egu dehoro bona egu inuinu ḡauna danu.
\q1 
\v 6 Taunabunai au ginigini amo baina maḡua ahu,
\q2 ia ilao-ahuna maḡuna baina haginia,
\q2 bena ena dala basine davaridia diba.
\q1 
\v 7 E ura heniamu taudia na baine gavadia,
\q2 to basine lasidia tao;
\q1 baine tahudia,
\q2 to basine davaridia.
\q1 Bena baineto: Lau na bainala,
\q2 adavagu gunana baina lou henia,
\q1 badina be una negana ai egu noho na namo,
\q2 a harihari egu noho na dika.
\q1 
\v 8 Ia na asi dibana,
\q2 uit bona vine ranuna bona dehoro na
\q2 lau ese na henia;
\q1 \it silver\it* be lau ese na henia momomomo,
\q2 bona \it gold\it* danu, Baal e henia ḡauna.
\q1 
\v 9 Taunabunai, egu uit baina abia lou, ena nega ai,
\q2 bona egu vine ranuna danu, ena hua ai;
\q1 egu mamoe huina bona egu varo aukana,
\q2 ia ihadabulaina ḡaudia,
\q2 baina abidia oho.
\q1 
\v 10 Harihari lau ese baina hahemaraia,
\q2 e ura heniamu taudia vairadiai;
\q1 ta ese basine harohoa mauri,
\q2 lau imagu nuana amo.
\q1 
\v 11 Ena moale idoinai baina hadokoa,
\q2 ena aria, ena hua matamatadia bona ena dina helaḡadia,
\q2 bona e gwaurai guna ariadia iboudiai danu.
\q1 
\v 12 Ena vine bona ena suke audia,
\q2 e herevalaidia, eto “Lau davagu bini
\q1 e ura henigumu taudia ese e henigu” ḡaudia na
\q2 lau ese baina havahudia;
\q1 uda ai baina halaodia,
\q2 bena uda boromadia ese bae anidia.
\q1 
\v 13 Baal edia aria dinadia e badinadia dainai,
\q2 lau ese baina hahisia;
\q1 unu dinadia ai muramura mai bonana e gabu henidia,
\q2 ena vaḡivaḡi bona ena herahera nadidia e heralai,
\q1 e ura henia taudia muridia amo ela,
\q2 a lau e lalogu boio.
\q2 Iehova na e herevamu.
\q1 
\v 14 Taunabunai, a itaia, baina ha-uraia,
\q2 tano ḡaḡaena ai baina hakaua lao,
\q2 lalokau herevadia amo baina hereva henia.
\q1 
\v 15 Unuseni ai ena vine imeadia baina henia,
\q2 bona Akoro Kourana na helaro iduarana ai baina halaoa.
\q1 Unuseni ai danu ia na baine haere, ulatona negana ai heḡereḡerena,
\q2 Aigupto tanona amo e raka lasi negana ai heḡereḡerena.
\p 
\v 16 Iehova na e tomu, Una dina ai ba gwauraigu “Lau adavagu”, basio gwauraigu lou “Egu Baal”.
\v 17 Badina be Baal ladadia na uduna amo baina abidia oho, ladadia basine hato lou.
\v 18 Una dina ai baina haherohemui maino, umui bona uda boromadia bona atai manudia bona tano ai e raumu ḡaudia; bona peva, dare, tuari na tano ai baina hadokodia; bena mai mainomui ida ba hekure diba.
\v 19 Maohenigu ai baina halaomui ela bona hanaihanai, oibe, maohenigu ai baina halaomui, kara maoromaoro ai bona hahemaoro ḡoevaḡoeva ai, lalokau ai bona hebogahisi ai.
\v 20 Heabidadama ai maohenigu ai baina halaomui; bena Iehova vada ba dibaia.
\p 
\v 21 Iehova na e tomu: Una dina ai guba baina haere henia, bena guba ese tanobada baine haere henia;
\v 22 tanobada ese uit bona vine ranuna bona dehoro baine haere henidia, bena idia ese Iesrele bae haere henia;
\v 23 tano ai ia baina hadoa lauegu. Bena “Se bogaia hisimu” na baina bogaia hisi; bona “Dia lauegu bese” baina hamaoroa, bainato “Oi na egu bese”, bona ia baineto “Oi na egu Dirava”.
\c 3
\s1 Hosea bona heuda-hanai hahinena
\p 
\v 1 Iehova ese ma e hereva henigu, eto, Ma baola, tau ta ese e eno henia bena ia ida e heuda hanai hahinena na ba ura henia, Iehova ese Israel taudia, dirava idaudia e haḡerediamu bona vine huahuadia kaukaudia manedia e ura henimu taudia, na e ura henidiamu heḡereḡerena.
\v 2 Taunabunai, lau ese \it silver\it* sekeledia gwauta-ima\f + \fr 3:2 \ft Sekele gwauta-ima = ½ lb. sisivana. Homere na Heberu taudia edia hahetoho ḡauna ta.\f* bona bali homere ta mai kahana amo na hoia.
\v 3 Bena na hamaoroa, nato, Dina hoho adavagu ai baola, ariara karadia basio kara, idau tauna ta enai basiola; lau ese danu unu baina karamu toma.
\v 4 Badina be Israel taudia na dina hoho bae noho, asi edia pavapava eiava edia lohia, asi edia boubou ḡauna eiava edia au-tubua, asi edia dabua helaḡana eiava edia kaivakuku.
\v 5 Gabeamo, Israel taudia na bae lou, Iehova, edia Dirava, bona David, edia pavapava, bae tahudia; mai garidia ida Iehova mai ena hebogahisi ida bae lou henidia, dina gabedia ai.
\c 4
\s1 Iehova ena hahebade Israel latanai
\q1 
\v 1 Israel taumui e, Iehova ena hereva ba kamonai;
\q2 badina be Iehova na mai ena hahebade,
\q2 tano inoholaina taudia latadiai.
\q1 Asi heabidadama bona asi hebogahisi ina tano ai,
\q2 bona Dirava asi dibadia danu;
\q1 
\v 2 heuduguirai, koikoi, ala-ala, henao, heuda-hanai na mimia;
\q2 ḡau ta asie laloamu; roroma murina murina.
\q1 
\v 3 Una dainai tano na e taitaimu,
\q2 bona inoholaina taudia iboudiai na e manorimu,
\q1 uda boromadia bona atai manudia danu;
\q2 bona davara gwarumedia na e heabi ohomu.
\b
\q1 
\v 4 Ta basine hepapahuahu, ta basine hahebade,
\q2 badina be, hahelaḡa tauna e, egu hepapahuahu na oi ida.
\q1 
\v 5 Dina ai ba hetutuhi,
\q2 hanuaboi ai peroveta tauna danu oi ida ba hetutuhi;
\q2 bona lau ese sinamu baina alaia mase.
\q1 
\v 6 Asi edia lalo-parara dainai egu bese taudia vada e hebua tari,
\q2 badina be oi ese lalo-parara vada o dadaraia dainai
\q2 lau ese na dadaraimumu, egu hahelaḡa tauna daguna amo;
\q1 bona emu Dirava ena taravatu vada o laloa boio dainai
\q2 lau ese oi natumu baina lalodia boio.
\b
\q1 
\v 7 Idia na e hutumava negana ai,
\q2 idia ese lau e kara dika henigu bada danu;
\q2 idia hairaidia na hemarai ai baina halaoa.
\q1 
\v 8 Egu bese taudia edia kara dika na edia aniani,
\q2 edia kara havara na e ani mata ganiganimu.
\q1 
\v 9 Hahelaḡa tauna hanua taudia na heheḡereḡere;
\q2 edia dala daidiai davadia baina henidia,
\q2 edia kara daidiai ahudia baina henidia.
\q1 
\v 10 Idia na bae aniani, to bogadia basie kunu;
\q2 ariara karadia bae kara, a besedia basie vara;
\q1 badina be idia ese Iehova vada e rakatania,
\q2 ariara karadia iabi-daedia totona.
\b
\q1 
\v 11 Vine ranuna, ena be matamata,
\q2 to ia ese lalo-parara e abia ohomu.
\q1 
\v 12 Egu bese taudia ese au amo e karaia ḡauna na e nanadaiamu,
\q2 bona edia itotohi ese oru edia hereva e henidiamu.
\q1 Badina be ariara karadia iura-henidia ese vada e hakaudia kerere;
\q2 edia Dirava vada e rakatania, ariara karadia helaoreadia.
\q1 
\v 13 Ororo doridia ai boubou karadia e karamu,
\q2 ororo komutadia ai boubou ḡaudia e hahelaḡadiamu,
\q1 \it oak\it* bona poplar bona \it terebinth\it* audia henudiai,
\q2 badina be unu au ikerukerudia na nanamo.
\b
\q1 Taunabunai, natumui hahinedia ese ariara karadia e karamu,
\q2 bona ravamui hahinedia na e heuda hanaimu.
\q1 
\v 14 Natumui hahinedia ese ariara karadia e karamu eiava
\q2 ravamui hahinedia na e heuda hanaimu negadia ai na
\q2 matadia basina hakanidia;
\q1 badina be tatau danu ariara hahinedia ida e raka sirimu,
\q2 bona boubou ḡaudia e hahelaḡadiamu mai lebulebu karadia ida.
\q1 Bese ta taudia bema asi edia lalo-parara,
\q2 idia na bae dika vaitani.
\b
\q1 
\v 15 Israel e, ena be ariara karadia o karamu,
\q2 to Iuda na basioma hakererea.
\q1 Gilgal ai basio raka vareai,
\q2 Bet-avene ai basio dae kau;
\q1 basio gwau hamata, basioto
\q2 “Iehova na e maurimu heḡereḡerena”.
\q1 
\v 16 Boromakau hahinena e daḡedaḡemu na heto,
\q2 Israel na e daḡedaḡemu.
\q1 Harihari Iehova baine ubudia diba
\q2 mamoe naluna rei gabuna badana lalonai na heto a?
\q1 
\v 17 Efraim na kaivakuku ediai e taomu;
\q2 aine noho.
\q1 
\v 18 Idia na kekero oreana, ariara karadia e karamu;
\q2 hemarai e ura henia badamu,
\q2 hairaidia e ura henia maraḡimu.
\q1 
\v 19 Koe-hirihiri ese hanina lalonai vada e koedia,
\q2 bena edia ihaboulaina patadia daidiai bae hemarai.
\c 5
\s1 Israel ena raka-muri davana
\q1 
\v 1 Hahelaḡa taumui e, ina hereva a kamonai!
\q2 Israel iduhuna e, a hakala!
\q1 Hanua pavapavana ena ruma taumui e, a kamonai!
\q2 Badina be hahemaoro herevana na umui emui ai.
\q1 Badina be umui na idoa Mispa ai,
\q2 bona e otoa huona Taboro ororona ai.
\q1 
\v 2 Idia ese Sitim gurina vada e ḡeia dobu;
\q2 a lau ese iboudiai matadia baina hakani.
\b
\q1 
\v 3 Efraim na lau dibagu,
\q2 bona Israel na egu amo se hehunimu.
\q1 Efraim e, ariara karadia vada o kara dainai,
\q2 Israel vada eme miro.
\q1 
\v 4 Edia kara ese e laodia ahumu dainai,
\q2 edia Dirava basie lou henia diba;
\q1 badina be lalodia ese ariara karadia e ura henimu,
\q2 bona asi dibadia Iehova.
\b
\q1 
\v 5 Israel ena hekokoroku ese e hahemaoro heniamu;
\q2 Efraim na ena kerere ai baine hekwakwanai,
\q2 Iuda danu idia iua bae hekwakwanai.
\q1 
\v 6 Mai edia mamoe bona edia nani seridia ida baela,
\q2 Iehova itahuna totona,
\q1 a basie davaria;
\q2 ia na edia amo vada e raka oho.
\q1 
\v 7 Idia ese Iehova vada e koia;
\q2 badina be idau hahinedia ediai natudia vada e havaradia.
\q1 Hari hua matamatana ese baine habuadia,
\q2 mai edia uma ida.
\b
\q1 
\v 8 Gibea ai kibi ba hiriria,
\q2 Rama ai danu ba hiriria;
\q1 Bet-avene ai ba hone;
\q2 Beniamina e, ba heude-heude!
\q1 
\v 9 Mata-hakani dinana ai
\q2 Efraim baine hahevahu;
\q1 Israel iduhudia bogaragidiai
\q2 hereva momokanina na gwauraia hedinaraimu.
\q1 
\v 10 Iuda Iohiadia na
\q2 tano hetoana e abia ohomu taudia
\q2 heḡereḡeredia ai vada e hahelao;
\q1 egu badu na latadiai baina seia dobi,
\q2 ranu na heto.
\q1 
\v 11 Efraim na vada e daḡedaḡe henia, hahemaoro ai vada e taoa tari,
\q2 badina be lalona e ha-aukaia, ḡau asi anidia baine ḡavadia.
\q1 
\v 12 Taunabunai lau na pitopito na heto Efraim enai,
\q2 bona houkahouka na heto Iuda iduhuna enai.
\b
\q1 
\v 13 Efraim sibona ese ena gorere e itaia
\q2 bona Iuda sibona ese berona e itaia negana ai,
\q1 Efraim na Asuria ela,
\q2 hereva e siaia lao, hanua pavapavana badana enai;
\q1 a ia ese basine hamaurimu diba,
\q2 eiava beromu basine hanamoa diba.
\q1 
\v 14 Badina be lau na leona heḡereḡerena ai bainala Efraim enai,
\q2 bona leona natuna heḡereḡerena ai Iuda iduhuna enai.
\q1 Momokani, lau ese baina daredia, bena baina raka oho;
\q2 baina heaulaidia oho, ta ese basine hamauridia.
\s1 Israel ena helalo-kerehai na dia momokani
\b
\q1 
\v 15 Egu gabu baina lou henia,
\q2 ela bona edia kerere bae gwaurai hedinarai,
\q2 bona vairagu bae tahua;
\q1 ela bona edia lalo-hisihisi ai bae tahugu, baeto,
\c 6
\p 
\v 1 Aoma, Iehova aita lou henia;
\q1 badina be vada e dareda, baine hamaurida helaoreana;
\q2 vada e botada, bena ia ese beroda baine kumidia.
\q1 
\v 2 Dina rua muridiai ia ese baine hamaurida;
\q2 dina ihatoina ai ia ese baine hatoreda isi,
\q2 ia vairanai baita mauri helaoreana.
\q1 
\v 3 Iehova baita dibaia,
\q2 baguda baita hololai, ia baita dibaia helaoreana;
\q2 ena raka vaira na momokani, daba na heto;
\q1 ia na dekedai bainema sisimu na heheto,
\q2 bona medu barokodia, tanobada e haparipariamu ḡaudia, na heheto.
\q1 
\v 4 Efraim e, ede baina karamu toma?
\q2 Iuda e, ede baina kara henimu toma?
\q1 Emui uraheni na daba orina na heto,
\q2 eiava hunu, e puki haraḡamu ḡauna, na heto.
\q1 
\v 5 Taunabunai, peroveta taudia imadia amo vada na dapadia,
\q2 udugu herevadia amo vada na aladia mase;
\q2 egu hahemaoro na e lasimu, diari na heto.
\q1 
\v 6 Badina be hebogahisi na uramu, dia boubou karadia,
\q2 Dirava idiba-ḡoevana, dia ḡole-oho bouboudia.
\b
\q1 
\v 7 A Adam ai idia ese taravatu vada e tataia utu;
\q2 unuseni ai idia ese vada e koigu.
\q1 
\v 8 Gilead na kara dika taudia edia hanua;
\q2 vatagadia na mai raradia.
\q1 
\v 9 Dadidadi taudia ese tau ta e bani heniamu na heto,
\q2 hahelaḡa taudia na e haheboumu;
\q1 Sekem dalana ai idia ese taunimanima e roromadiamu,
\q2 oibe, kara dika-hereadia e karamu.
\q1 
\v 10 Israel iduhuna ai ḡau dika-rohorohona ta vada na itaia,
\q2 Efraim ena ariara karadia na unuseni ai;
\q2 Israel vada e hahemiro.
\b
\q1 
\v 11 Iuda e, oi danu, itaboromu negana
\q2 vada e gwauraia guna.
\s1 Israel ena kara havara bona ena daḡedaḡe
\q1 Egu bese taudia edia noho-namo bama havaraia lou nato negana ai,
\c 7
\p 
\v 1 Israel bama hamauria nato negana ai,
\q1 Efraim ena kara havara e hedinaraiva,
\q2 bona Samaria ena kara dika danu;
\q1 badina be idia na e kara koikoimu;
\q2 henao tauna ese ruma habana e dareamu
\q2 bona dadidadi taudia na murimuri ai e dadidadimu.
\q1 
\v 2 To asie haeroamu
\q2 lau ese edia kara dikadia iboudiai na lalodia taomu.
\q1 Harihari edia kara ese e koudia heḡeḡemu;
\q2 idia na lau vairagu ai.
\q1 
\v 3 Edia kara dika amo idia ese hanua pavapavana e hamoaleamu
\q2 bona edia kara hedibaḡani amo hanua lohiadia danu e hamoalediamu.
\q1 
\v 4 Idia iboudiai na heuda-hanai taudia;
\q2 idia na amu siahuna na heto;
\q1 flaoa igabuna tauna ese lahi irakuna e hadokoamu,
\q2 flaoa e kuiamu negana ela bona e tubumu negana.
\q1 
\v 5 Eda pavapava ena dina ai,
\q2 hanua lohiadia na e kekero, vine ranuna siahuna dainai;
\q2 ia ese ḡonaḡona taudia ida imana e toi roro.
\q1 
\v 6 Badina be amu na heto lalodia na edia lalo-hadai koikoidia amo e siahumu;
\q2 hanuaboi idoinai edia badu na gida na heto,
\q2 daba ai e hururumu, lahi hururu-hururuna na heto.
\q1 
\v 7 Iboudiai na e siahumu, amu na heto;
\q2 idia ese edia lohia e ha-orediamu.
\q1 Edia pavapava iboudiai vada e moru;
\q2 idia ta ese se hahane henigumu.
\b
\q1 
\v 8 Efraim na bese idau-idau taudia ida e heturamu,
\q2 Efraim na se hurea hegiro atagana na heto.
\q1 
\v 9 Idau taudia ese ena goada e ha-oreamu,
\q2 to asi dibana;
\q1 huina vada e buruka,
\q2 to asi dibana.
\q1 
\v 10 Israel ena heaḡi ese e habadelaiamu;
\q2 ḡau tamona idia ese Iehova, edia Dirava, asie lou heniamu,
\q2 ina idoinai vada e vara, to asie tahua.
\b
\q1 
\v 11 Efraim na pune na heto,
\q2 kavakava, bona asi darana;
\q1 Aigupto e boi heniamu,
\q2 Asuria e lao heniamu.
\q1 
\v 12 Laodia ai egu huo amo baina koudia,
\q2 atai manudia na heheto baina hamorudia;
\q2 matadia baina hakanidia, edia kara dika daidiai.
\q1 
\v 13 Idia madi! Badina be egu amo vada e raka oho,
\q2 Madi ihabaidia! Badina be vada e daḡedaḡe henigu.
\q1 Bama hamauridia,
\q2 to idia ese koikoi herevadia na latagu ai e gwauraimu.
\b
\q1 
\v 14 Idia ese lalodia amo asie tai henigumu,
\q2 a edia mahuta ḡaudia latadiai e ḡanaḡanamu;
\q1 uit bona vine-ranuna daidiai sibodia e heḡasimu,
\q2 e daḡedaḡe henigumu.
\q1 
\v 15 Ena be lau ese na hadibadibadia bona imadia na ha-aukadia,
\q2 to lau ihadikalaigu e lalo hatamu.
\q1 
\v 16 Idia ese Baal e haḡereamu;
\q2 idia na koikoi pevana na heto.
\q1 Edia lohia na dare ai bae mase,
\q2 edia ere-daḡedaḡe dainai.
\q1 Una dainai bae kirikirilaidia,
\q2 Aigupto tanona ai.
\c 8
\s1 Israel igwau-henina
\q1 
\v 1 Kibi a hiriria,
\q2 badina be bogibada ta na Iehova ena dubu daenai,
\q1 badina be egu gwauhamata asie badinaia,
\q2 egu taravatu e tataia utu.
\q1 
\v 2 Idia ese e boi heigumu, e tomu,
\q2 Egu Dirava e, ai Israel taumai dibamai oi.
\q1 
\v 3 Israel ese namo e dadaraiamu;
\q2 inai taudia ese bae hahavaia.
\b
\q1 
\v 4 Idia ese pavapava e hahelaḡadia, a dia lau daigu ai;
\q2 lohia danu e haginidia, a lau be asi dibagu.
\q1 Edia \it silver\it* bona edia \it gold\it* amo kaivakuku e karadia,
\q2 idia sibodia ihabua-taridia.
\q1 
\v 5 Samaria e, emu boromakau natuna vada na dadaraiamu.
\q2 Egu badu na e ḡaraḡaramu idia latadiai.
\q1 Edena nega ai bae ḡoevaḡoeva,
\q2 Israel lalonai?
\b
\q1 
\v 6 Ima dibaka tauna ese e karaia;
\q2 una na dia Dirava.
\q1 Samaria ena boromakau natuna
\q2 bae hamakohia rohoroho.
\b
\q1 
\v 7 Badina be lai e havaraia,
\q2 bena anina do bae abia, koe-hirihiri.
\q1 Uit na vada e tubu, to asi adadia;
\q2 anidia na basie dobi.
\q1 Anidia bema dobi,
\q2 idau taudia ese bema anidia ore.
\q1 
\v 8 Israel na vada e hadonoa,
\q2 ina harihari idia na ḡau asi anina
\q2 bese idau-idau bogaragidiai.
\q1 
\v 9 Badina be idia na Asuria vada e dae lao,
\q2 uda donikina sibona e loa eva-evamu na heto;
\q2 Efraim ese ariara hahinedia davadia vada e kara.
\q1 
\v 10 Ena be bese idau-idau bogaragidia amo idurudia taudia bae vatudia,
\q2 to lau ese baina.butudia oho.
\q1 Bena pavapava bona lohia ihahelaḡadia na bae hadokoa,
\q2 ina nega sina ai.
\b
\q1 
\v 11 Badina be Efraim ese ihaboulaina patadia vada e hahohodia,
\q2 kara dika ikaradia totona;
\q1 unu na kara dika ihaboulaina patadia ai vada ela,
\q2 ia enai.
\q1 
\v 12 Ena be egu taravatu gerebu gerebu bama tore ia ena,
\q2 to bema haerodia idau ḡau.
\q1 
\v 13 Boubou karadia e ura henidiamu,
\q2 vamu e hahelagaiamu bona e aniamu,
\q2 a Iehova ese se moalelaidiamu.
\q1 Harihari ia ese edia kara havara baine laloa tao,
\q2 bona edia kara dika davadia baine kara;
\q2 idia na Aigupto bae lou lao.
\q1 
\v 14 Badina be Israel ese Ikarana Diravana vada e laloa boio,
\q2 pavapava rumadia vada e haginidia,
\q2 bona Iuda ese hanua mai maḡudia vada e hahohodia;
\q1 a lau ese lahi baina siaia ena hanua latadiai,
\q2 bena ena gabu aukadia baine aradia ore.
\c 9
\s1 Israel ena gwau-edeede davana
\q1 
\v 1 Israel e, basio moale,
\q2 basio hisi dae, bese idau-idau taudia na heheto;
\q1 badina be ariara karadia vada o kara,
\q2 emu Dirava vada o rakatania.
\q1 Ariara karana davana vada o ura henia,
\q2 uit ikwadilaina gabudia iboudiai reireidia latadiai.
\q1 
\v 2 Uit ikwadilaina gabuna bona vine itaolaina gurina ese basie ubudia,
\q2 bona vine-ranuna matamatana ai bae dabu.
\q1 
\v 3 Idia na Iehova ena tano ai basie noho;
\q2 a Efraim taudia ese Aigupto tanona bae lou henia,
\q2 bona idia ese aniani mai taravatudia bae ani Asuria ai.
\b
\q1 
\v 4 Iehova uduna ahuna vine-ranuna basie bubua,
\q2 bona edia boubou karadia amo basie hamoalea.
\q1 Adia aniani na mase itailaina taudia adia heḡereḡerena ai bainela,
\q2 bae ania taudia iboudiai na bae miro;
\q1 badina be adia aniani na boga helaoreana mo,
\q2 Iehova ena dubu ai basie vareailaia.
\q1 
\v 5 E gwauraia guna ariana dinana ai ede ba kara toma?
\q2 Iehova ena aria dinana ai ede ba kara toma?
\q1 
\v 6 Badina be, a itaia, idia na Asuria e laomu;
\q2 Aigupto ese baine haheboudia,
\q2 Memefisi ese baine guridia.
\q1 Ava hegarana ese edia \it silver\it* ḡaudia herea-daedia bae habubunidia,
\q2 au ginigini na edia kalaga ai bae vara.
\b
\q1 
\v 7 Mata-hakani dinadia vada e kau,
\q2 dava-abi dinadia vada e gini dae;
\q2 Israel ese baine dibaia.
\q1 Peroveta tauna na kavakava,
\q2 bona lauma ese e roheamu tauna na kava,
\q1 emu kara havara bada-herea
\q2 bona emu daḡedaḡe bada-herea daidiai.
\q1 
\v 8 Peroveta tauna na Efraim, egu Dirava ena bese, igimana tauna,
\q2 ḡau tamona, manu-tahu tauna ena idoa na ena dala iboudiai lalodiai,
\q2 bona daḡedaḡe na ena Dirava ena dubu ai.
\q1 
\v 9 Idia na sibodia vada e hahemiro herea,
\q2 Gibea\f + \fr 9:9 \ft Gibea dinadia. Hahemaoro Taudia, Karoa 19, lalonai Gibea sivaraina e torea.\f* dinadia heḡereḡeredia ai.
\q1 Edia kara havara baine lalodia tao,
\q2 edia kara dika davadia baine henidia.
\b
\q1 
\v 10 Vine huahuadia tano ḡaḡaena ai na heheto,
\q2 Israel unu na davaria toma.
\q1 Suke au huahuana roboana, ena huahua laḡanina gini-gunana ai,
\q2 senemui unu na itadia toma.
\q1 A idia na Baal-peoro ela,
\q2 sibodia e hahelaḡa Baal enai;
\q1 bena vada e dika rohoroho,
\q2 e ura henia ḡauna heḡereḡerena.
\q1 
\v 11 Efraim hairaina na baine roho oho, manu na heto;
\q2 ta basine vara, ta basine rogorogo,
\q2 ta basine haherogorogo.
\q1 
\v 12 Ena be natudia haida bae havaradia,
\q2 to lau ese mase ai baina abidia oho,
\q2 ela bona ta basine noho.
\q1 Lau ese baina rakatanidia negana ai,
\q2 idia na bae baia.
\q1 
\v 13 Efraim natuna vada na itadia, idia na damu ai baela;
\q2 Efraim ese natuna baine hakaudia lasi, ala-ala enai.
\q1 
\v 14 Iehova e, ḡau ta ba henidia.
\q2 Dahaka ba henidia?
\q1 Mara-dika bogana bona rata asi anidia,
\q2 unu na ba henidia.
\b
\q1 
\v 15 Edia dika iboudiai na Gilgal ai,
\q2 unuseni ai na inai henidia matama.
\q1 Edia kara na dika rohoroho dainai,
\q2 lau ese egu ruma amo baina luludia lasi;
\q1 ina murinai basina ura henidia lou;
\q2 edia lohia iboudiai na mai dagedagedia.
\b
\q1 
\v 16 Efraim taudia na vada e rahudia mase,
\q2 ramudia vada e marai, huahuadia basie dobi.
\q1 Ena be natudia bae havaradia,
\q2 to lau ese edia lalokau memerodia baina aladia mase.
\q1 
\v 17 Egu Dirava ese baine negedia daure,
\q2 badina be idia ese asie kamonai henia;
\q1 idia na bese idau-idau bogaragidiai
\q2 bae loa kava loa kava.
\c 10
\q1 
\v 1 Israel na rigi momo vinena,
\q2 huahuana danu e dobimu.
\q1 Huahuana e momo e laova negana ai
\q2 ena ihaboulaina patadia ma e hahohodia;
\q1 ena tano ena namo e bada e laova negana ai
\q2 ena au-tubua danu ma e hanamodia.
\q1 
\v 2 Lalodia na mai koikoidia;
\q2 harihari edia kerere davadia bae hua.
\q1 Iehova ese edia ihaboulaina patadia baine ḡiḡidia dobi,
\q2 bona edia au-tubua baine hagaridia.
\b
\q1 
\v 3 Badina be harihari idia baeto:
\q2 Ai na asi emai pavapava;
\q1 badina be Iehova garina asia garimu,
\q2 bona pavapava ta ese ede bema hanamomai toma?
\q1 
\v 4 Idia ese hereva asi anidia mo e gwuraimu,
\q2 gwauhamata herevadia asi anidia amo e hegwau hamata hehenimu;
\q1 taunabunai hahemaoro na e tubumu,
\q2 hahemase avadia na uma dadairadia ai e tubumu na heto.
\q1 
\v 5 Samaria inoholaina taudia kudoudia e hetahamu,
\q2 Bet-avene ena boromakau natuna dainai.
\q1 Ena taunimanima ese bae taitailaia,
\q2 ena hahelaḡa taudia, kaivakuku vairadiai hahelaḡa karadia e karamu taudia, na
\q1 latanai bae tai heloḡo-heloḡo,
\q2 vada e rakatania hairaina bae tailaia.
\q1 
\v 6 Oibe, ḡauna na Asuria bae huaia lao,
\q2 heaiva ḡauna ai bainela, pavapava badana ena.
\q1 Efraim na bae hahemaraia,
\q2 bona Israel ese ena kaivakuku hemaraina baine hemarai.
\b
\q1 
\v 7 Samaria pavapavana baine mase,
\q2 au seana ranu kopina ai na heto.
\q1 
\v 8 Avene ena atai gabudia, Israel ena kara dika toadia,
\q2 bae hebua tari.
\q1 Edia ihaboulaina patadia latadiai
\q2 au ginigini bona ava ḡiniḡini na bae tubu.
\q1 Idia ese ororo bae hamaorodia, baeto “Ba ḡovamai ahu”,
\q2 bona ororo komutadia bae noidia, baeto “Ba ḡorumai tao”.
\b
\q1 
\v 9 Israel e, Gibea dinadia amo vada o kara dika;
\q2 unuseni ai vada e kara dika loulou.
\q2 Tuari ese Gibea ai basine lasidia tao a?
\q1 
\v 10 Gwau-edeede taudia baina vasi henidia,
\q2 matadia ihakanidia totona;
\q1 bona bese idauidau bae hahebou,
\q2 idia ihadikadia totona;
\q2 edia kara havara rua davadia bae abi negana ai.
\q1 
\v 11 Efraim na boromakau hahinena matamatana,
\q2 e hamanadaia ḡauna;
\q1 uit imoimoilaina e ura henia,
\q2 bena aiona namona na bogaia hisi;
\q1 a maduna auna na Efraim paḡana ai baina atoa kau,
\q2 Iuda ese tano baine ruaia,
\q2 bona Iakob ese sibona ena tano baine gaua.
\q1 
\v 12 Kara maoromaoro ba hadoa emui,
\q2 hebogahisi huahuana ba utua,
\q2 emui vahu tanona ba ruaia.
\q1 Badina be ina na Iehova itahuna negana,
\q2 ia bainema, hahemauri medu na heto
\q2 latamui ai baine hadihoa helaoreana.
\b
\q1 
\v 13 Kara havara vada o ruaia,
\q2 hahemaoro gageva-gageva vada o utua,
\q2 hereva koikoi huahuadia vada o ani.
\q1 Badina be emui kariota vada o abidadama henidia,
\q2 bona emui tuari taudia hutuma herea danu;
\q1 
\v 14 taunabunai tuari honedia na emui taunimanima bogaragidiai bae dae,
\q2 bona emui kohoro iboudiai na bae hebua tari,
\q1 tuari dinana ai Salamana ese Bet-arabele e habuaia tari na heto;
\q2 una dina ai hahine mai natudia ida e huaridia patapata.
\q1 
\v 15 Israel taumui e, unu bae karamui toma,
\q2 emui kara dika bada-herea dainai.
\q1 Daba rere ai Israel pavapavana na
\q2 baine henege daure vaitani.
\c 11
\s1 Iehova ese Israel e lalokau heniamu
\q1 
\v 1 Israel merona negana ai lau ese na lalokau henia,
\q1 bona natugu na Aigupto amo na boiria lasi.
\q2 
\v 2 Egu boiboi na ediai na habadaia,
\q1 to idia ese edia raka-muri e habadaia;
\q2 Baal itomadiho-henidia asie hadokoa,
\q1 bona muramura mai bonadia e gabu, kaivakuku vairadiai.
\q2 
\v 3 Ḡau tamona, lau ese Efraim taudia na raka na hadibalaidia,
\q1 imagu ai na rosidia,
\q2 to asie diba lau ese vada na hamauridia.
\q1 
\v 4 Hebogahisi varodia bona lalokau iḡuidia amo na hakaudia;
\q2 lau na maduna aukidia amo e abia ohomu tauna heḡereḡerena ai nala;
\q2 na igo diho henidia, na ubudia.
\b
\q1 
\v 5 Idia ese Aigupto tanona bae lou henia,
\q2 Asuria na edia pavapava ai bainela,
\q2 badina be asie ura bae lou henigu.
\q1 
\v 6 Dare ese edia hanua baine ala-ala henidia,
\q2 bona edia ikoukou auridia baine ha-oredia;
\q2 idia danu baine ha-oredia edia kohoro ai.
\q1 
\v 7 Egu bese taudia ese lalodia e ha-aukamu,
\q2 bae rakatanigu e tomu;
\q1 una dainai maduna vada e hegwaurai edia,
\q2 bona ta ese basine abia oho.
\b
\q1 
\v 8 Efraim e, ede baina kahumu nege toma?
\q2 Israel e, haida imadia ai ede baina atomu toma?
\q1 Ad.na heḡereḡerena ai ede baina halaomu toma?
\q2 Seboimi heḡereḡerena ai ede baina kara henimu toma?
\q1 Lalogu ese UilU e dadaraimu;
\q2 egu hebogahisi na e bada e laomu.
\q1 
\v 9 Egu badu ḡaraḡara basina halasia,
\q2 Efraim basina habuaia tari lou.
\q1 Badina be lau na Dirava, dia taunimanima;
\q2 lau na Helaḡa Diravana umui bogaragimui ai,
\q2 hahebua-tari totona basina vasi.
\b
\q1 
\v 10 Idia ese Iehova na bae gavaia,
\q2 ia na leona na heto baine gou;
\q1 oibe, ia na baine gou,
\q2 bena natuna na lahara kahana amo baema
\q2 mai kudou-hetahadia ida;
\q1 
\v 11 mai kudou-hetahadia ida Aigupto amo baema, manu na heheto,
\q2 Asuria tanona amo baema, pune na heheto;
\q1 bena ma baina haloudia, edia noho gabudia korikori baela.
\q2 Iehova na e herevamu.
\s1 Efraim igwau-henina
\q1 
\v 12 Efraim ese koikoi amo vada e haheḡegegu dae
\q2 bona Israel iduhuna ese danu hedibaḡani amo;
\q1 a Iuda na Dirava ese doini e dibaiamu,
\q2 ia na Helaḡa Diravana enai e taomu.
\c 12
\q1 
\v 1 Efraim ese lai e reḡuamu,
\q2 bona laurabada e gavaia loamu, dina idoinai.
\q1 Idia ese koikoi bona daḡedaḡe e habadadiamu,
\q2 Asuria ida e herohe mainomu,
\q2 bona dehoro na Aigupto e laohaiamu.
\b
\q1 
\v 2 Iehova na mai ena hahebade Iuda latanai,
\q2 bona Iakob matana baine hakania, ena dala heḡereḡeredia,
\q2 bona davana baine henia, ena kara heḡereḡeredia.
\q1 
\v 3 Sinana bogana ai ia ese kakana ae-geduna e dogoa tao,
\q2 bona tau-badana ai ia na Dirava ida e hedaverai.
\q1 
\v 4 Aneru ida e hedaverai, bena e kwalimu;
\q2 e taitai, ena lalo-namo e noinoilaia.
\q1 Betele ai ia na Dirava ida e hedavari,
\q2 unuseni ai Dirava na ia ida e hereva;
\q1 
\v 5 Iehova, tuari oreadia edia Dirava,
\q2 ia ladana na Iehova.
\q1 
\v 6 Taunabunai, Dirava ena hekaha ai a lou,
\q2 lalokau bona hahemaoro ḡoevaḡoeva ba dogodia tao,
\q2 bona emu Dirava ba naria tarika-tarika.
\b
\q1 
\v 7 Hoihoi tauna, metau ihahetohona ḡauna koikoina na imana ai
\q2 tauna ese taunimanima ihahisihisidia e uramu.
\q1 
\v 8 Efraim eto “Momokani, to lau vada na taga,
\q2 kohu momo vada na habou egu”.
\q1 Ḡau tamona ena taḡa idoinai ese
\q2 ena kerere basine rohoa.
\q1 
\v 9 Aigupto tanona amo
\q2 lau na Iehova, emui Dirava;
\q1 kalaga ai baina hanohomui lou,
\q2 e gwaurai ariadia dinadia ai heḡereḡerena.
\b
\q1 
\v 10 Peroveta taudia na hereva henidia;
\q2 mata-hanai na hahohodia,
\q1 bona peroveta taudia ududia amo
\q2 sivarai heḡereḡeredia na heni.
\q1 
\v 11 Bema kara havara na Gilead ai mia,
\q2 idia na momokani bae baia;
\q1 bema Gilgal ai boromakau mamaruanedia e hahelagadiamu,
\q2 edia ihaboulaina patadia na nadi senudia ai baela,
\q2 uma dadairadia ai e habou nadi senudia na heheto.
\q1 
\v 12 (Iakob na Aram tanona e heau lao,
\q2 unuseni ai Israel na hesiai karadia e karava,
\q1 adavana idavalaina,
\q2 adavana iabina totona mamoe e regudiava.)
\q1 
\v 13 Peroveta tauna imana amo
\q2 Iehova ese Israel na Aigupto tanona amo e hakaua lasi;
\q1 bona peroveta tauna imana amo
\q2 ia ese e hamauria.
\q1 
\v 14 Efraim vada e daḡedaḡe dikadika,
\q2 taunabunai ena Ḡaubada ese rara ihahebubuna gwauna na
\q1 ia latanai baine hamiaia,
\q2 bona ena maumau na ia latanai ma baine halou henia.
\c 13
\s1 Efraim baine dika vaitani
\q1 
\v 1 Efraim e hereva negadia ai,
\q2 taunimanima na e heude-heude;
\q1 Israel ai idia ese ia e imodaia,
\q2 a Baal dainai e kerere, bena e mase.
\q1 
\v 2 Harihari idia ese edia kara dikadia e hahohodiamu,
\q2 bona edia kaivakuku na e hahetaria aurina amo e karadiamu;
\q1 kaivakuku na \it silver\it* amo e karadiamu mai ima-idibakadia ida,
\q2 iboudiai na ima-idibakadia taudia ese e karadiamu.
\q1 Idia na e tomu “Ini na ba boudia”.
\q2 Taunimanima ese boromakau natudia laulaudia e harahudiamu.
\q1 
\v 3 Taunabunai, idia na daba ninoana heḡereḡerena ai baela,
\q2 eiava e puki haraḡamu hununa heḡereḡerena ai;
\q1 uit ikwadilaina gabuna amo e heoda ohomu momona na heto,
\q2 eiava kwalahu gaba-mauru amo e lasimu na heto.
\b
\q1 
\v 4 Aigupto tanona amo
\q2 lau na Iehova, emui Dirava.
\q1 Dirava ta asi dibamui, lau mo;
\q2 asi ihamaurimui ta, lau mo.
\q1 
\v 5 Tano ḡaḡaena ai na dibamui,
\q2 medu se dihova tanona ai;
\q1 
\v 6 a e ani lava dae negana ai bogadia e kunu,
\q2 bena e hekokorokuva;
\q2 taunabunai e lalogu boio.
\q1 
\v 7 Una dainai lau ese baina kara henidia leona na heto;
\q2 taiga na heto dala isena ai baina bani tao.
\q1 
\v 8 Bea, natuna vada e henaodia ḡauna, na heto,
\q2 latadiai baina roho kau,
\q2 kemedia baina daredia.
\q1 Unuseni ai baina ha-oredia leona na heto,
\q2 uda boromana ese bema daredia na heto.
\b
\q1 
\v 9 Israel e, baina habuamu tari;
\q2 daika ese baine durumu?
\q1 
\v 10 Harihari emu pavapava na edeseni ai,
\q2 bona ede baine hamaurimu toma?
\q1 Emu lohia iboudiai na edeseni ai,
\q2 bona ede bae gimamu toma?
\q1 Umui ese o herevalaidia, oto
\q2 “Pavapava ta bona lohia haida ba henimai”,
\q2 taudia na edeseni ai?
\q1 
\v 11 Egu badu ai pavapava haida vada na henimui,
\q2 bona egu badu ḡaraḡara ai ma vada na abidia oho.
\b
\q1 
\v 12 Efrai ena kara havara na vada e kumia,
\q2 ena kara dika na vada e koua.
\q1 
\v 13 Sinana e hekamonaimu,
\q2 to ia na kavakava merona,
\q1 ena vara negana vada e kau
\q2 to sinana bogana amo se lasimu.
\q1 
\v 14 Mase gabuna amo baina rauadia a?
\q2 Mase amo baina hamauridia a?
\q1 Mase e, emu hahehisi be edeseni ai?
\q2 Mase gabuna e, emu hahebua-tari be edeseni ai?
\q2 Hebogahisi na matagu amo vada eme hehuni.
\b
\q1 
\v 15 Ena be tadikaka bogaragidiai bema bada oho bada oho,
\q2 to laurabada, Iehova ena lai, bainema,
\q2 tano ḡaḡaena amo baine toa;
\q1 ela bona ranuna basine helohilohi,
\q2 bona ena ranu gabuna baine kororo;
\q1 ena habou-habou rumana lalona amo
\q2 ḡau hereadia iboudiai baine ha-oredia.
\q1 
\v 16 Samaria ese ena kerere davana baine huaia,
\q2 badina be ia ese ena Dirava vada e daḡedaḡe henia;
\q1 idia na dare ai bae mase,
\q2 natudia maraḡidia na bae huaridia patapata,
\q2 bona edia rogorogo hahinedia na bae dapadia parara.
\c 14
\s1 Israel inoina
\q1 
\v 1 A Israel e, Iehova, emu Dirava, ba lou henia,
\q2 badina be vada o hekwakwanai, emu kara havara daidiai.
\q1 
\v 2 Mai herevamui ida baola,
\q2 Iehova ba lou henia;
\q1 ba hamaoroa, baoto:
\q2 Kara havara iboudiai bavabi oho;
\q1 ḡau namona bavabia dae;
\q2 bena bibinamai anidia baia henimu.
\q1 
\v 3 Asuria ese basine hamaurimai,
\q2 hosi ai basia gui;
\q1 bona imamai amo a kara ḡaudia basia hereva henidia lou,
\q2 basiato “Emai Dirava”.
\q1 Oiemu ai ihareha ese
\q2 hebogahisi e davariamu.
\b
\q1 
\v 4 Edia kara-hebeatai baina abi oho,
\q2 egu ura-kwalimu ai baina lalokau henidia,
\q2 badina be egu badu na edia amo vada e siri.
\q1 
\v 5 Lau na hunu heḡereḡerena ai bainala, Israel enai,
\q2 ia na baine gara kau, sosana\f + \fr 14:5 \ft “Sosana” na Heberu taudia edia herahera ta ladana; English gado ai ladana na “lily”.\f* herahe-rana na heto;
\q2 ramuna na tano ai bae diho, Lebanon audia na heheto;
\q1 
\v 6 ia tuhutuhuna bae idia roro;
\q2 ia hairaina na olive hairaina heḡereḡerena ai baine hahelao,
\q2 bona bonana na Lebanon bonana heḡereḡerena ai bainela.
\q1 
\v 7 Idia na bae lou mai, lau ikerukerugu ai bae noho;
\q2 bae tubu, uma ḡaudia na heheto.
\q1 Idia na bae huahua, vine auna na heto;
\q2 bonadia bae dae, Lebanon vine-ranuna na heto.
\b
\q1 
\v 8 Efraim e, lauegu ḡaukara kaivakuku ediai be dahaka?
\q2 Lau ese na haere henimumu bona na gimamumu.
\q1 Lau na beroso\f + \fr 14:8 \ft “Beroso” na au ta ladana Heberu gado ai.\f* auna, rauna se hehuhumu ḡauna, na heto;
\q2 huahuamu na lauegu amo e varamu.
\b
\q1 
\v 9 Daika mai aonegana, ia ese ini ḡau baine lalo davari.
\q2 Daika mai lalo-pararana, ia ese baine dibadia.
\q1 Badina be Iehova ena dala na mamaoro-mamaoro;
\q2 kara maoromaoro taudia na lalodiai e rakamu,
\q2 a kara kerere taudia na lalodiai e hekwakwanaimu. 
