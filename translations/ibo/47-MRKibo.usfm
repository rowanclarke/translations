\id MRK - Biblica® Open Igbo Contemporary Bible 2020 
\h Mak 
\toc1 Oziọma Mak 
\toc2 Mak 
\toc3 Mak 
\mt1 Oziọma Mak 
\c 1  
\s1 Jọn omee baptizim edozie ụzọ 
\p  
\v 1 Mmalite oziọma maka Jisọs Kraịst, Ọkpara Chineke.  
\v 2 Dịka e dere ya rịị nʼakwụkwọ Aịzaya onye amụma sị, 
\q1 “Aga m ezipu onyeozi m nʼihu gị, 
\q2 onye ga-edozi ụzọ gị.”\f + \fr 1:2 \ft \xt Mal 3:1\f* 
\q1  
\v 3 “Otu onye na-eti mkpu nʼọzara, na-asị, 
\q1 ‘Dozienụ ụzọ maka Onyenwe anyị, 
\q2 meenụ ka okporoụzọ ya guzozie.’ ”\f + \fr 1:3 \ft \xt Aịz 40:3\f* 
\m  
\v 4 Jọn omee baptizim pụtara na-eme baptizim nʼọzara, ma na-ekwusa baptizim nke nchegharị maka mgbaghara mmehie.  
\v 5 Ndị mmadụ si nʼakụkụ Judịa niile na ndị niile bi na Jerusalem pụrụ jekwuru ya. Ka ha na-ekwupụta mmehie ha, o mere ha baptizim nʼosimiri Jọdan.  
\v 6 Uwe Jọn yi nʼahụ ya bụ nke e ji ajị ịnyịnya kamel mee. O kekwara ihe okike e ji akpụkpọ anụ mee nʼukwu ya. Nri ya bụ igurube na mmanụ aṅụ.  
\v 7 O kwusara sị: “Onye dị ike karịa m na-abịa nʼazụ m. Onye m na-erughị ihudata ala tọpụ eriri akpụkpọụkwụ ya.  
\v 8 Eji m mmiri na-eme unu baptizim, ma ọ ga-eji Mmụọ Nsọ mee unu baptizim.” 
\s1 Baptizim na ọnwụnwa Jisọs 
\p  
\v 9 Nʼoge ahụ, Jisọs sitere na Nazaret nke Galili bịa nʼosimiri Jọdan, ebe Jọn mere ya baptizim.  
\v 10 Ma mgbe o si nʼime mmiri ahụ na-apụta, ọ hụrụ ka eluigwe meghere. Hụkwa Mmụọ Nsọ dị ka nduru ka ọ rịdatara bekwasị ya nʼisi ya.  
\v 11 Otu olu si nʼeluigwe daa, “Ị bụ Ọkpara m hụrụ nʼanya, ihe gị dị m ezi mma.” 
\p  
\v 12 Ngwangwa, Mmụọ Nsọ duuru ya baa nʼime ọzara.  
\v 13 Ọ nọkwara nʼime ọzara ahụ iri ụbọchị anọ, ebe ekwensu nwara ya ọnwụnwa. Ya na ụmụ anụ ọhịa nọkwa. Ma ndị mmụọ ozi jeere ya ozi. 
\s1 Mbido ọrụ nkwusa 
\p  
\v 14 Mgbe e tinyesịrị Jọn nʼụlọ mkpọrọ, Jisọs gara na Galili, na-ekwusa oziọma Chineke.  
\v 15 Ọ sịrị, \wj “Oge ahụ eruola, alaeze Chineke dị nso. Chegharịanụ ma kwerekwanụ nʼoziọma.”\wj* 
\s1 Ọkpụkpọ ndị na-eso ụzọ ya 
\p  
\v 16 Mgbe Jisọs na-aga nʼakụkụ osimiri Galili, ọ hụrụ Saimọn na Andru nwanne ya, ka ha na-awụnye ụgbụ ha nʼime mmiri nʼihi na ha bụ ndị ọkụ azụ.  
\v 17 Jisọs siri ha, \wj “Bịanụ soro m, m ga-emekwa unu ndị ọkụ na-akụta mmadụ.”\wj* 
\v 18 Ngwangwa ha hapụrụ ụgbụ azụ ha ma soro ya. 
\p  
\v 19 Mgbe ọ gatụrụ nʼihu nke nta, ọ hụrụ Jemis nwa Zebedi na nwanne ya bụ Jọn ndị nọ nʼime ụgbọ mmiri, na-ekezi ụgbụ azụ ha.  
\v 20 Ngwangwa, ọ kpọrọ ha, ha hapụrụ nna ha Zebedi na ndị o goro ọrụ nʼime ụgbọ soro ya. 
\s1 Jisọs chụpụrụ mmụọ ọjọọ 
\p  
\v 21 Ha gara Kapanọm, mgbe ụbọchị izuike ruru, ọ bara nʼime ụlọ ekpere ma malite izi ha ihe.  
\v 22 Ozizi ya juru ha anya nke ukwuu, nʼihi na o ziri ha ihe dịka onye nwere ikike, ọ bụghị dị ka nke ndị ozizi iwu.  
\v 23 Ma nʼotu oge ahụ, otu nwoke nọ nʼime ụlọ ekpere ahụ nke mmụọ na-adịghị ọcha bi nʼime ya, tiri mkpu nʼoke olu,  
\v 24 sị, “Gịnị ka anyị na gị nwekọrọ, gị Jisọs onye Nazaret? Ị bịala ịla anyị nʼiyi? Amaara m onye ị bụ, Onye Nsọ nke Chineke.” 
\p  
\v 25 Ma Jisọs baara ya mba sị ya, \wj “Mechie ọnụ sikwa nʼime ya pụta!”\wj* 
\v 26 Mmụọ ahụ na-adịghị ọcha seere ya, mee ka ahụ ya maa jijiji, o tiri mkpu nʼoke olu, ma sikwa nʼime ya pụta. 
\p  
\v 27 Ha niile bụ ndị nọ nʼọnọdụ ihe iju anya ma na-ajụrịtara onwe ha ajụjụ sị, “Gịnị bụ nke a? Ozizi ọhụrụ ya na ikike! Ọ na-enye ọ bụladị mmụọ na-adịghị ọcha iwu. Ha na-erubekwara ya isi.”  
\v 28 Akụkọ banyere ya gbasara ngwangwa ruo akụkụ niile nke Galili. 
\s1 Jisọs agwọọ ọtụtụ mmadụ 
\p  
\v 29 Ngwangwa ha hapụrụ ụlọ ekpere ahụ, ha na Jemis na Jọn soro banye nʼụlọ Saimọn na Andru.  
\v 30 Nʼoge a, nne nwunye Saimọn dina nʼakwa ndina. Ahụ ọkụ jikwa ya. Ha mere ka ọ mata banyere ya.  
\v 31 Ọ gakwuru ya, jide ya nʼaka selite ya elu. Ahụ ọkụ ahụ hapụrụ ya. Ọ malitekwara ile ha ọbịa. 
\p  
\v 32 Nʼoge uhuruchi, mgbe anwụ dara, ha kpọtaara ya ndị niile ahụ na-esighị ike na ndị mmụọ ọjọọ bi nʼime ha.  
\v 33 Obodo ahụ niile gbakọrọ nʼọnụ ụzọ.  
\v 34 Ọ gwọrọ ọtụtụ ndị bu ọrịa dị iche iche, ọ chụpụkwara ọtụtụ mmụọ ọjọọ ma o kweghị ka mmụọ ọjọọ ndị ahụ kwuo okwu nʼihi na ha matara onye ọ bụ. 
\s1 Jisọs apụọ ikpe ekpere naanị ya 
\p  
\v 35 Nʼisi ụtụtụ, mgbe ọchịchịrị ka gbachiri, o biliri, ga ebe ọ ga-anọrọ onwe ya, naanị ya. Nʼebe ahụ kwa ka ọ nọ kpee ekpere.  
\v 36 Saimọn na ndị ya na ha nọ pụrụ na-achọgharị ya.  
\v 37 Ma mgbe ha hụrụ ya, ha sịrị ya, “Mmadụ niile na-achọgharị gị!” 
\p  
\v 38 Ọ zaghachiri ha sị, \wj “Ka anyị gaanụ ebe ọzọ, nʼobodo ndị ọzọ dị anyị gburugburu, ka m zisakwaara ha oziọma. Ọ bụ nʼihi nke a ka m ji bịa.”\wj* 
\v 39 Ya mere, ọ pụrụ jegharịa na Galili niile na-ekwusa oziọma nʼụlọ ekpere ha niile, na-achụpụkwa mmụọ ọjọọ. 
\s1 Jisọs agwọọ onye ekpenta 
\p  
\v 40 Otu onye ekpenta bịakwutere ya gbuo ikpere nʼala rịọọ ya sị, “Ọ bụrụ na ị chọrọ, ị pụrụ ime ka m dị ọcha.” 
\p  
\v 41 Ebe o jupụtara nʼọmịiko, Jisọs setịpụrụ aka ya metụ ya sị, \wj “Achọrọ m, dị ọcha!”\wj* 
\v 42 Ngwangwa ekpenta ya hapụrụ ya, e mekwara ka ọ dị ọcha. 
\p  
\v 43 Mgbe ahụ, Jisọs ji ịdọ aka na ntị zilaga ya,  
\v 44 ọ gwara ya sị, \wj “Hụkwa na ọ dịghị onye ọbụla ị ga-agwa ihe a. Kama gaa gosi onye nchụaja onwe gị. Chụọkwa aja dị ka Mosis nyere nʼiwu, maka ime ka ị dị ọcha gị, ka ọ bụrụ ihe ama nye ha.”\wj* 
\v 45 Ma ọ pụrụ malite ịkọsa akụkọ banyere ọgwụgwọ ya ebe niile. Nʼihi ya Jisọs enwekwaghị ike ịbanye nʼobodo, kama ọ gara nọrọ nʼebe zoro ezo. Ma ndị mmadụ na-abịakwutekwa ya site nʼebe niile dị iche iche. 
\c 2  
\s1 Jisọs agwọọ onye ahụ ya kpọnwụrụ 
\p  
\v 1 Mgbe ụbọchị ole na ole gafesịrị, ọ bataghachiri na Kapanọm. Ndị mmadụ nụrụ na ọ lọghachila.  
\v 2 Igwe mmadụ zukọtara nʼime ụlọ ahụ nke mere na ohere afọdụghị ọ bụladị nʼọnụ ụzọ. O kwusakwaara ha oziọma.  
\v 3 Ndị ikom ụfọdụ buteere ya otu nwoke ahụ ya kpọnwụrụ akpọnwụ. Ọ bụ mmadụ anọ bu ya.  
\v 4 Ebe ha na-enweghị ike ibutere ya Jisọs nʼihi igwe mmadụ, ha gwupuru oghere nʼelu ụlọ ebe ahụ ọ nọ. Mgbe ha gwupusiri ya, ha budatara onye ahụ ahụ ya kpọnwụrụ akpọnwụ nʼute o jiri dina.  
\v 5 Mgbe Jisọs hụrụ okwukwe ha, ọ sịrị onye ahụ ahụ ya kpọnwụrụ akpọnwụ, \wj “Nwa m nwoke, agbagharala gị mmehie gị.”\wj* 
\p  
\v 6 Ma ụfọdụ ndị ozizi iwu nọdụrụ ala nʼebe ahụ na-eche nʼime obi ha sị,  
\v 7 “Gịnị mere onye a ji na-ekwulu Chineke? Onye pụrụ ịgbaghara mmehie ma ọ bụghị naanị Chineke?” 
\p  
\v 8 Ngwangwa Jisọs matara nʼime mmụọ ya na ha na-atule okwu a nʼime obi ha. Ọ sịrị ha, \wj “Gịnị mere unu ji na-eche ihe dị otu a nʼobi unu?\wj* 
\v 9 \wj Olee nke ka mfe: ọ bụ ịgwa onye a akụkụ ahụ ya kpọnwụrụ akpọnwụ, ‘A gbagharala gị mmehie gị niile,’ ka ọ bụ i sị, ‘Bilie chịrị ute gị jegharịa?’\wj* 
\v 10 \wj Ma igosi unu na Nwa nke Mmadụ nwere ikike nʼụwa ịgbaghara mmehie.”\wj* Ọ sịrị onye ahụ akụkụ ahụ ya kpọnwụrụ akpọnwụ,  
\v 11 \wj “Ana m asị gị, bilie, chịrị ute gị laa nʼụlọ gị.”\wj* 
\v 12 O biliri, chịrị ute ya pụọ nʼihu mmadụ niile. Nke a juru ndị niile nọ nʼebe ahụ anya. Ha toro Chineke na-asị, “Anyị ahụbeghị ihe dị otu a mbụ!” 
\s1 Ọkpụkpọ Livayị 
\p  
\v 13 Emesịa, Jisọs pụrụ gaa nʼakụkụ osimiri ahụ. Igwe mmadụ bịakwutere ya. Ọ malitere izi ha ihe.  
\v 14 Mgbe ọ na-aga nʼihu, ọ hụrụ Livayị nwa Alfiọs ka ọ nọdụrụ ala nʼụlọ ịnakọta ụtụ. Ọ sịrị ya, \wj “Soro m,”\wj* o biliri sooro ya. 
\p  
\v 15 Mgbe ọ na-eri nri uhuruchi nʼụlọ Livayị, ọtụtụ ndị ọna ụtụ na ndị mmehie soro ya na ndị na-eso ụzọ ya nọrọ ebe ahụ, nʼihi na ndị na-esogharị ya dị ọtụtụ.  
\v 16 Mgbe ndị ozizi iwu nke ndị Farisii hụrụ ya ka o so ndị mmehie na ndị ọna ụtụ na-eri nri, ha jụrụ ndị na-eso ụzọ ya sị, “Gịnị mere o ji eso ndị mmehie na ndị ọna ụtụ na-erikọ nri?” 
\p  
\v 17 Mgbe ọ nụrụ nke a, Jisọs sịrị ha, \wj “Mkpa dibịa adịghị akpa ndị ahụ dị ike, kama ọ bụ ndị ahụ na-esighị ike. Abịaghị m ịkpọ ndị ezi omume kama ndị mmehie.”\wj* 
\s1 Ajụjụ banyere ibu ọnụ 
\p  
\v 18 Nʼoge a, ndị na-eso ụzọ Jọn na ndị Farisii na-ebu ọnụ. Ndị mmadụ bịara jụọ ya sị, “Gịnị mere ndị na-eso ụzọ Jọn na ndị na-eso ụzọ ndị Farisii ji ebu ọnụ, ma ndị nke gị adịghị ebu ọnụ?” 
\p  
\v 19 Jisọs sịrị ha, \wj “O kwesiri na ndị a kpọrọ oriri ọlụlụ di na nwunye ga-ebu ọnụ mgbe onye na-alụ nwunye ọhụrụ nọ nʼetiti ha? Ha apụghị ibu ọnụ ogologo oge ya na ha nọ.\wj* 
\v 20 \wj Ma oge na-abịa mgbe a ga-ewepụ onye na-alụ nwunye ọhụrụ. Nʼụbọchị ahụ ka ha ga-ebu ọnụ.\wj* 
\p  
\v 21 \wj “Ọ dịghị onye na-eji akwa ọhụrụ kwachie ebe akwa ochie siri dọkaa. Ọ bụrụ na o mee nke a, akwa ọhụrụ ahụ ga-adọkapụ site na nke ochie mee ka ndọka ya dị njọ karịa.\wj* 
\v 22 \wj Ọ dịghị onye na-agbanye mmanya ọhụrụ na karama akpụkpọ ochie. O mee nke a, mmanya ahụ ga-agbawa karama akpụkpọ ochie ahụ, mee ka karama na mmanya laa nʼiyi. Ee, a na-agbanye mmanya ọhụrụ nʼime karama akpụkpọ ọhụrụ.”\wj* 
\s1 Onyenwe ụbọchị izuike 
\p  
\v 23 Otu ụbọchị izuike, ya na ndị na-eso ụzọ ya na-agafe nʼubi a kụrụ ọka. Dị ka ha na-agafe, ndị na-eso ụzọ ya malitere ịghọ ụfọdụ ogbe ọka nʼime ọka ndị ahụ.  
\v 24 Ndị Farisii siri ya, “Lee, gịnị mere ha ji na-eme ihe megidere iwu nʼụbọchị izuike.” 
\p  
\v 25 Ma ọ sịrị ha, \wj “Unu agụtaghị ihe Devid na ndị so ya mere mgbe agụụ gụrụ ha?\wj* 
\v 26 \wj Nʼoge Abịata bụ onyeisi nchụaja, ọ banyere nʼụlọ Chineke taa achịcha e chere nʼihu ya, nke ziri ezi na ọ bụ naanị ndị nchụaja kwesiri ịta ya. O nyetụkwara ndị ya na ha so.”\wj* 
\p  
\v 27 Mgbe ahụ, ọ gwakwara ha sị, \wj “E mere ụbọchị izuike maka mmadụ, emeghị mmadụ maka ụbọchị izuike.”\wj* 
\v 28 \wj Ya mere, Nwa nke Mmadụ bụ Onyenwe ọ bụladị ụbọchị izuike.\wj* 
\c 3  
\s1 Ọgwụgwọ onye aka ya kpọnwụrụ 
\p  
\v 1 Nʼoge ọzọ, ọ banyere nʼụlọ ekpere, otu nwoke aka ya kpọnwụrụ akpọnwụ nọkwa nʼebe ahụ.  
\v 2 Ụfọdụ ha nọ na-achọ ụzọ ha ga-esi boo ya ebubo, ya mere ha lekwasịrị ya anya ịhụ ma ọ ga-agwọ ya ọrịa nʼụbọchị izuike.  
\v 3 Ma ọ gwara nwoke ahụ aka ya kpọnwụrụ akpọnwụ sị, \wj “Bilie guzoro nʼetiti ebe a.”\wj* 
\p  
\v 4 Mgbe ahụ ọ jụrụ ha sị, \wj “Olee nke ziri ezi nʼiwu ime nʼụbọchị izuike: ọ bụ ime ezi ihe ka ọ bụ ime ihe ọjọọ, ịzọpụta ndụ ka ọ bụ ịla ndụ nʼiyi?”\wj* Ma ha gbachiri nkịtị. 
\p  
\v 5 O lere ha anya nʼiwe, o wutere ya nʼihi na obi ha kpọrọ nkụ. Ọ sịrị nwoke ahụ, \wj “Setịpụ aka gị.”\wj* O setịpụrụ aka ya, aka ya dizikwara nke ọma.  
\v 6 Ngwangwa, ndị Farisii sitere nʼebe ahụ pụọ nʼiwe. Gaa soro ndị otu Herọd gbaa izu otu ha ga-esi laa ya nʼiyi. 
\s1 Igwe mmadụ esoro Jisọs 
\p  
\v 7 Ma Jisọs na ndị na-eso ụzọ ya sitere nʼebe ahụ pụọ gaa nọdụ nʼakụkụ osimiri. Igwe mmadụ ndị sitere na Galili sooro ya.  
\v 8 Mgbe ha nụrụ ihe niile ọ na-eme, ọtụtụ mmadụ bịakwutere ya site na Judịa, na Jerusalem, na Idumia na obodo ndị dị nʼofe Jọdan, na gburugburu Taịa na Saịdọn.  
\v 9 Nʼihi ịdị ukwuu nke igwe mmadụ ahụ, ọ gwara ndị na-eso ụzọ ya ka ha debere ya ụgbọ mmiri nta nso ka ọ banye, iji gbochie igwe mmadụ ahụ ịkpagbu ya.  
\v 10 Nʼihi na ọ gwọọla ọtụtụ ndị ọrịa, nke mere na ndị bu ọrịa dị iche iche na-agbalịsị ike ịmetụ ya aka.  
\v 11 Mgbe ọbụla kwa ndị mmụọ na-adịghị ọcha bi nʼime ha hụrụ ya, ha na-ada nʼala nʼihu ya na-eti mkpu na-asị, “Ị bụ Ọkpara Chineke!”  
\v 12 Ma ọ na-enyesi ha iwu ike ka ha hapụ ịkọwa onye ọ bụ. 
\s1 Jisọs họrọ ndị ozi iri na abụọ 
\p  
\v 13 Ọ rigooro nʼelu ugwu ma kpọrọ ndị ọ chọrọ nye onwe ya. Ha bịakwutekwara ya.  
\v 14 Ọ họpụtara mmadụ iri na abụọ ndị ya na ha ga-anọ, mee ha ndị ozi. Ndị ọ ga-ezipụ ikwusa oziọma,  
\v 15 nakwa ndị ga-enwe ikike ịchụpụ mmụọ ọjọọ. 
\b  
\li4  
\v 16 Ndị a bụ mmadụ iri na abụọ ndị ọ họpụtara. 
\b  
\li1 Saimọn (onye ọ kpọrọ Pita). 
\li1  
\v 17 Jemis nwa Zebedi na Jọn nwanne ya (ndị ọ gụgharịrị aha \tl Boanajis\tl*, nke pụtara “ụmụ egbe eluigwe”), 
\li1  
\v 18 Andru, 
\li1 Filip, 
\li1 Batalomi, 
\li1 Matiu, 
\li1 Tọmọs, 
\li1 Jemis nwa Alfiọs, 
\li1 Tadiọs, 
\li1 Saimọn onye a na-akpọ Zilọt, 
\li1  
\v 19 na Judas Iskarịọt, onye raara ya nye. 
\s1 Ebubo ndị ezinaụlọ Jisọs na ndị nkuzi boro ya 
\p  
\v 20 Emesịa, ọ lọtara nʼụlọ, ma igwe mmadụ gbakọtakwara ọzọ nke mere na ha enweghị ohere iri nri.  
\v 21 Mgbe ndị ikwu ya nụrụ nke a, ha bịara gbalịa idulata ya nʼụlọ ha, nʼihi na ndị mmadụ na-asị, “Isi adịghị ya mma.” 
\p  
\v 22 Ma ndị ozizi iwu si Jerusalem bịa sịrị, “Mmụọ Belzebub bi nʼime ya! Ọ bụkwa nʼike onyeisi ndị mmụọ ọjọọ ka o ji achụpụ mmụọ ọjọọ.” 
\p  
\v 23 Ma ọ kpọrọ ha jiri ilu gwa ha okwu sị, \wj “Ekwensu ọ pụrụ ịchụpụ ekwensu?\wj* 
\v 24 \wj Ọ bụrụ na alaeze ekewa megide onwe ya alaeze ahụ apụghị iguzo.\wj* 
\v 25 \wj Ọ bụrụ na ezinaụlọ ekewa megide onwe ya, ezinaụlọ ahụ apụghị iguzo.\wj* 
\v 26 \wj Ọ bụrụkwa na ekwensu ebilie megide onwe ya si otu a nwee nkewa, o nweghị ike iguzo; kama ọgwụgwụ oge ya abịala nso.\wj* 
\v 27 \wj Nʼezie, ọ dịghị onye nwere ike ịbanye nʼụlọ nwoke dị ike kwakọrọ ngwongwo ya niile, ma o bughị ụzọ kee nwoke ahụ siri ike agbụ. Mgbe ahụ ọ ga-enwe ike ịbanye nʼụlọ ya, zukọrọ ngwongwo ya niile.\wj* 
\v 28 \wj Nʼezie agwa m unu, na a ga-agbaghara ụmụ mmadụ mmehie na nkwulu niile nke ha kwuru.\wj* 
\v 29 \wj Ma onye ọbụla ga-ekwulu Mmụọ Nsọ, enweghị ike ịgbaghara ya. Ọ bụ onye ikpe mmehie ebighị ebi mara.”\wj* 
\p  
\v 30 O kwuru nke a nʼihi na ha na-asị, “Mmụọ na-adịghị ọcha bi nʼime ya.” 
\s1 Nne na ụmụnne Jisọs 
\p  
\v 31 Mgbe ahụ, nne ya na ụmụnne ya ndị nwoke bịara, guzoro nʼezi. Ha ziri ozi ka a kpọọ ya.  
\v 32 Igwe mmadụ gbara ya gburugburu mgbe ahụ gwara ya sị, “Lee, nne gị na ụmụnne gị ndị nwoke na ndị nwanyị guzo nʼezi. Ha chọrọ ịhụ gị.” 
\p  
\v 33 Ọ zara sị, \wj “Onye bụ nne m, ndị ole bụkwa ụmụnne m ndị nwoke?”\wj* 
\p  
\v 34 Mgbe ahụ, o lere ndị nọ ya gburugburu anya ma sị, \wj “Ndị a bụ nne m, na ụmụnne m ndị nwoke!\wj* 
\v 35 \wj Onye ọbụla na-eme uche Chineke bụ nwanne m nwoke, na nwanne m nwanyị, na nne m.”\wj* 
\c 4  
\s1 Ilu banyere ọgha mkpụrụ 
\p  
\v 1 Nʼoge ọzọ, ọ malitere izi ihe nʼakụkụ osimiri. Igwe mmadụ dị ukwuu gbara ya gburugburu, nke mere na ọ banyere nʼime ụgbọ nọdụ ala nʼime ya nʼelu mmiri ahụ, ma igwe mmadụ ahụ nọkwa nʼakụkụ osimiri ahụ.  
\v 2 O bidoro i kuziri ha ọtụtụ ihe nʼilu, ma nʼozizi ya, ọ sịrị ha,  
\v 3 \wj “Geenụ ntị! Otu onye ọrụ ubi pụrụ gaa ịkụ mkpụrụ ya.\wj* 
\v 4 \wj Mgbe ọ na-agha mkpụrụ, ụfọdụ mkpụrụ dara nʼakụkụ ụzọ, ụmụ nnụnụ bịara tụtụrịa ha.\wj* 
\v 5 \wj Ụfọdụ mkpụrụ dara nʼala nkume, ebe aja ntakịrị dị. Ha puputara ngwangwa nʼihi na ala dị nʼebe ahụ emighị emi.\wj* 
\v 6 \wj Ma mgbe anwụ wara, ọ chagburu ha, ha kpọnwụọ nʼihi na ha enweghị mgbọrọgwụ.\wj* 
\v 7 \wj Mkpụrụ ndị ọzọ dara nʼetiti ogwu; ogwu ahụ tolitere kpagbuo ha. Ha amịkwaghị mkpụrụ.\wj* 
\v 8 \wj Mkpụrụ ndị ọzọ nke dara nʼezi ala, puru, tolite, ma mịa mkpụrụ na mmụba iri atọ, iri isii, ọ bụladị otu narị.”\wj* 
\p  
\v 9 Ọ sịrị ha, \wj “Onye ọbụla nwere ntị ịnụ ihe, ya nụrụ.”\wj* 
\p  
\v 10 Ma mgbe ọ nọ naanị ya, ndị ozi iri na abụọ ahụ na ndị ọzọ nọ ya gburugburu jụrụ ya ajụjụ banyere ilu ahụ.  
\v 11 Ọ gwara ha sị, \wj “Enyela unu ihe omimi nke alaeze Chineke. Ma ndị nọ nʼezi, a na-agwa ha ihe niile nʼilu,\wj* 
\v 12 \wj nke mere na,\wj* 
\q1 \wj “ ‘Ha ga na-ele anya, hụkwa, ma ha agaghị ahụ ihe ọbụla,\wj* 
\q2 \wj ha ga na-anụ, nụkwa, ma ha agaghị aghọta ihe ọbụla,\wj* 
\q1 \wj ma ọ bụghị ya, ha nwere ike chigharịa bụrụ ndị a gbaghaara.’\wj*\f + \fr 4:12 \ft \xt Aịz 6:9,10\f* \wj ”\wj* 
\p  
\v 13 Mgbe ahụ, ọ jụrụ ha sị, \wj “Ọ bụ na unu aghọtaghị ilu a? Unu ga-esikwa aṅaa ghọta ilu ndị ọzọ?\wj* 
\v 14 \wj Ọgha mkpụrụ ahụ na-agha okwu Chineke.\wj* 
\v 15 \wj Mmadụ ụfọdụ dị ka mkpụrụ ndị ahụ dara nʼakụkụ ụzọ, ebe a kụrụ okwu ahụ. Ngwangwa ha nụrụ ya, ekwensu na-abịa napụ ha okwu ahụ nke a kụrụ nʼime ha.\wj* 
\v 16 \wj Ndị ọzọ dị ka mkpụrụ a kụrụ nʼala nkume. Ha nụrụ okwu ahụ, were ọṅụ nabata ya nʼotu mgbe ahụ.\wj* 
\v 17 \wj Ma ebe ha na-enweghị mgbọrọgwụ nʼime ha, ha na-anọ nwa oge nta. Mgbe nsogbu maọbụ mkpagbu bịara nʼihi okwu ahụ, ngwangwa ha na-adachapụ.\wj*\f + \fr 4:17 \ft Maọbụ, \fqa daa mba\f* 
\v 18 \wj Ndị nke ọzọkwa, dị ka mkpụrụ dara nʼetiti ogwu, nụrụ okwu ahụ;\wj* 
\v 19 \wj ma nchekasị nke ndụ a,\wj*\f + \fr 4:19 \ft Oge a nke anyị nọ nʼime ya\f*\wj na nghọgbu nke akụnụba, na oke ọchịchọ, nakwa ihe ndị ọzọ na-abata, kpagbuo okwu ahụ, mee ka ọ ghara ịmị mkpụrụ.\wj* 
\v 20 \wj Ndị ọzọ, dị ka mkpụrụ a kụrụ nʼezi ala, nụrụ okwu ahụ, nabata ya ma mịa mkpụrụ dị iri atọ, iri isii, maọbụ otu narị.”\wj* 
\s1 Iheọkụ dị nʼelu tebul 
\p  
\v 21 Ọ sịrị ha, \wj “A na-ebute oriọna ka e jiri efere kpuchie ya maọbụ dọnye ya nʼokpuru akwa ndina? Ọ bụghị ka a dọba ya nʼelu ihe ịdọba iheọkụ?\wj*\f + \fr 4:21 \ft Maọbụ, \fqa ihe ịdọba oriọna\f* 
\v 22 \wj Nʼihi na ihe niile e zoro ezo ga-apụta ihe ma ihe niile e kpuchiri ekpuchi ka a ga-emesịa kpughee.\wj* 
\v 23 \wj Onye ọbụla nwere ntị ịnụ ihe, ya nụrụ.”\wj* 
\p  
\v 24 Ọ sịrị ha, \wj “Kpacharanụ anya ihe unu na-anụ. Ọ bụkwa ihe unu ji tụọrọ ndị ọzọ ka a ga-eji tụọrọ unu, maọbụ karịa.\wj* 
\v 25 \wj Onye nwere ihe ka a ga-enye karịa; onye na-enweghị, ọ bụladị nke o nwere ka a ga-anapụ ya.”\wj* 
\s1 Ilu banyere otu mkpụrụ si eto 
\p  
\v 26 Ọ sịkwara, \wj “Alaeze Chineke yiri ihe dị otu a. Ọ dịka mgbe otu onye ghara mkpụrụ nʼala ubi.\wj* 
\v 27 \wj Ehihie na abalị, ma ọ nọ nʼụra ma o tetara, mkpụrụ ahụ na-epupụte na-etokwa, ma ọ maghị ka o si na-eme.\wj* 
\v 28 \wj Ala ahụ nʼonwe ya na-eme ka mkpụrụ ahụ puo. Ọ na-epupụte na mbụ, too oko, emesịa isi ọka, nʼikpeazụ ọ mịkwara mkpụrụ kara aka nʼoko ya.\wj* 
\v 29 \wj Mgbe ọka ahụ chara ịghọ ya, o na-eji mma iwe ihe ubi ya bịa gbutuo ọka ahụ, ghọrọkwa ogbe ọka laa, nʼihi na oge iwe ihe nʼubi eruola.”\wj* 
\s1 Ilu banyere mkpụrụ Mọstaadị 
\p  
\v 30 Ọzọkwa, ọ sịrị, \wj “Gịnị ọzọ ka anyị pụrụ ịsị na alaeze Chineke yiri? Ụdị ilu dị aṅaa ka anyị ga-eji kọwaa ya?\wj* 
\v 31 \wj Ọ dị ka mkpụrụ mọstaadị, nke bụ mkpụrụ dịkarịsịrị nta nke a na-akụ nʼala.\wj* 
\v 32 \wj Ma mgbe a kụrụ ya, ọ na-eto bukarịa ihe niile a kụrụ nʼubi, ọ na-enwe alaka dị ukwuu nke bụ na ụmụ anụ ufe nke eluigwe na-ezukwa ike nʼokpuru ya.”\wj* 
\p  
\v 33 O jiri ọtụtụ ilu yiri ndị a gwa ha okwu dị ka ha pụrụ ịghọta.  
\v 34 O nweghị oge ọbụla ọ gwara ha okwu hapụ iji ilu. Ma ya na ndị na-eso ụzọ ya naanị nọdụ, ọ na-akọwara ha ihe niile. 
\s1 Jisọs emee ka ifufe kwụsị 
\p  
\v 35 Nʼụbọchị ahụ nʼoge uhuruchi, ọ gwara ndị na-eso ụzọ ya sị, \wj “Ka anyị gafee nʼofe nke ọzọ.”\wj* 
\v 36 Ha hapụrụ igwe mmadụ ahụ ma kpọrọ ya, otu ọ dị, ya na ha banyere nʼime ụgbọ. Ụgbọ ndị ọzọ dịkwa na-eso ya.  
\v 37 Oke ifufe dị ike bidoro ife, ebili mmiri na-awụbakwa nʼụgbọ ahụ ruo na ụgbọ ha fọdụrụ ntakịrị ka mmiri mie ya.  
\v 38 Ma Jisọs nọ nʼazụ azụ ụgbọ ahụ na-arahụ ụra nʼelu ohiri isi. Ndị na-eso ụzọ ya kpọtere ya sị ya, “Onye ozizi, o metụghị gị nʼobi na anyị nʼala nʼiyi?” 
\p  
\v 39 Ọ biliri ọtọ, baara ifufe ahụ mba sịkwa osimiri ahụ, \wj “Kwụsị! Dere jii!”\wj* Ifufe ahụ kwụsịrị, ebe niile dajụrụ deere jii. 
\p  
\v 40 Ọ sịrị ndị na-eso ụzọ ya, \wj “Gịnị mere unu ji atụ oke egwu? Ọ bụ na unu enwebeghị okwukwe?”\wj* 
\p  
\v 41 Ha niile tụrụ egwu, jụrịta onwe ha sị, “Onye bụ onye a? Ọ bụladị ifufe na ebili mmiri na-erubere ya isi!” 
\c 5  
\s1 Jisọs agwọọ nwoke mmụọ ọjọọ bi nʼime ya 
\p  
\v 1 Ha gafere nʼofe ọzọ nke osimiri ahụ nʼakụkụ obodo Gerazin.\f + \fr 5:1 \ft Nʼakwụkwọ ochie ụfọdụ, ị nwere ike hụ Gadarin.\f* 
\v 2 Mgbe Jisọs sitere nʼụgbọ ahụ pụta, otu nwoke mmụọ na-adịghị ọcha si nʼebe a na-eli ozu bịa zute ya.  
\v 3 Nwoke a bi nʼetiti ili ndị ahụ. Ọ dịkwaghị onye ọbụla pụrụ ike ya agbụ, ọ bụladị iji eriri igwe kee ya.  
\v 4 Nʼihi na e keela ya agbụ ụkwụ nʼaka ọtụtụ oge ma ọ dọbisiri eriri igwe ndị ahụ, gbajisiekwa mkpọrọ igwe dị ya nʼụkwụ. Ọ dịkwaghị onye nwere ike ijideli ya.  
\v 5 Ọ na-agagharị nʼetiti ili ahụ ehihie na abalị na nʼugwu dị ya gburugburu, na-eti mkpu, na-eji nkume dị nkọ na-egbukasị onwe ya ahụ. 
\p  
\v 6 Mgbe o sitere nʼebe dị anya hụ Jisọs, ọ gbaara ọsọ gaa gbuo ikpere nʼihu ya.  
\v 7 O tiri mkpu nʼoke olu sị, “Gịnị ka mụ na gị nwekọrọ, Jisọs, Ọkpara Chineke Onye kachasị ihe niile elu? Eji m aha Chineke na-arịọ gị, biko, atala m ahụhụ.”  
\v 8 Nʼihi na o nyela ya iwu sị, \wj “Si nʼime nwoke a pụta, gị mmụọ na-adịghị ọcha!”\wj* 
\p  
\v 9 Mgbe ahụ Jisọs jụrụ ya sị, \wj “Gịnị bụ aha gị?”\wj* 
\p Mmụọ ọjọọ ahụ zaghachiri ya sị, “Aha m bụ Lijiọn,\f + \fr 5:9 \ft Nke a bụ site na puku atọ ruo puku isii nʼọnụọgụgụ.\f* nʼihi na anyị dị ọtụtụ.”  
\v 10 Ma ọ rịọsiri ya arịrịọ ike ka ọ ghara ịchụpụ ha site nʼobodo ahụ. 
\p  
\v 11 Igwe ezi nọ nso nʼebe ahụ na-akpa nri, na ndịda ugwu dị nʼebe ahụ.  
\v 12 Mmụọ ọjọọ ndị a rịọrọ ya sị, “Biko ziga anyị nʼetiti igwe ezi ndị a, ma hapụ anyị ka anyị banye nʼime ha.”  
\v 13 Ọ hapụrụ ha; mmụọ ndị ahụ na-adịghị ọcha pụtara baa nʼime igwe ezi ndị ahụ. Igwe ezi ahụ niile, ọnụọgụgụ ha ruru puku abụọ, gbaara ọsọ site na mkputamkpu ala ọnụ mmiri dakpuo nʼime osimiri ebe mmiri riri ha niile. 
\p  
\v 14 Ndị na-elekọta igwe ezi ahụ gbaara ọsọ laa, kọsaa ihe mere nʼime obodo nakwa nʼala ahụ niile. Nʼihi nke a, ọtụtụ mmadụ pụtara ilere ihe mere.  
\v 15 Ha bịakwutere Jisọs, hụ nwoke ahụ nke igwe mmụọ ọjọọ bibu nʼime ya. O yi uwe, nọdụ ala, bụrụkwa onye uche ya zuruoke; egwu jidere ha.  
\v 16 Ndị hụrụ ihe mere kọọrọ ihe niile mere nwoke ahụ mmụọ ọjọọ bibu nʼime ya. Ha kọkwaara ihe mere igwe ezi ndị ahụ.  
\v 17 Mgbe ahụ, ha bidoro ịrịọ Jisọs ka ọ pụọra ha nʼakụkụ ala ha. 
\p  
\v 18 Dị ka ọ na-achọ ịbanye nʼime ụgbọ, nwoke ahụ mmụọ ọjọọ ndị ahụ bibu nʼime ya rịọrọ ya ka o soro ha.  
\v 19 Ma Jisọs ekweghị, kama ọ sịrị ya, \wj “Laa nʼụlọ, lakwuru ndị enyi gị, kọọrọ ha ihe ọma Onyenwe anyị meere gị, na otu o si meere gị ebere.”\wj* 
\v 20 Ya mere, o si nʼebe ahụ pụọ, malitekwa ịkọsa nʼime mpaghara Dekapọlịs ihe ọma Jisọs meere ya. Ihe a juru mmadụ niile anya. 
\s1 Ada Jairọs na nwanyị nwere okwukwe 
\p  
\v 21 Mgbe Jisọs jiri ụgbọ mmiri gafee nʼakụkụ nke ọzọ, ọtụtụ igwe mmadụ zukọrọ gbaa ya gburugburu mgbe ọ nọ nʼakụkụ osimiri.  
\v 22 Ma otu nʼime ndịisi ụlọ ekpere nke aha ya bụ Jairọs bịara, mgbe ọ hụrụ ya, ọ dara nʼala nʼụkwụ ya,  
\v 23 rịọsie ya arịrịọ ike sị, “Ada m nwanyị nke nta nọ nʼọnụ ọnwụ ugbu a. Biko, bịa ka ị bikwasị ya aka gị ka agwọ ya, ka ọ dịkwa ndụ.”  
\v 24 Ya mere, Jisọs soro ya gawa. 
\p Oke igwe mmadụ sokwa ya na-akpagbu ya.  
\v 25 Ma otu nwanyị nọkwa nʼebe ahụ, onye nọrịị na-arịa ọrịa oruru ọbara afọ iri na abụọ.  
\v 26 Ọ taala ahụhụ dị ukwuu nʼaka ndị dibịa, mefukwaa ihe niile o nwere. Ma kama ọrịa ya ịdị mma, ọ na-aga nʼihu ịdị njọ.  
\v 27 Ebe ọ nụrụla akụkọ banyere Jisọs, o sooro igwe mmadụ ndị ahụ, sitere nʼazụ metụ uwe ya aka.  
\v 28 Nʼihi na o kwuolarị nʼime obi ya sị, “Ọ bụrụ nnọọ na m enwe ike metụ naanị uwe ya aka, a ga-agwọkwa m.”  
\v 29 Ngwangwa oruru ọbara ya kwụsịrị. Ọ matakwara nʼime onwe ya na ya enwerela onwe ya site nʼọrịa ya. 
\p  
\v 30 Nʼotu oge ahụ Jisọs matara na ike esitela ya nʼahụ pụọ. Ọ tụgharịrị gburugburu nʼetiti igwe mmadụ ahụ jụọ sị, \wj “Onye metụrụ uwe m aka?”\wj* 
\p  
\v 31 Ndị na-eso ụzọ ya sịrị, “Lee ọtụtụ igwe mmadụ gbara gị gburugburu, i sikwa aṅaa na-ajụ, \wj ‘Onye metụrụ uwe m aka?’\wj* ” 
\p  
\v 32 Ma Jisọs gara nʼihu na-ele anya gburugburu ịhụ onye mere ya.  
\v 33 Ma nwanyị ahụ, ebe ọ matara ihe mere nʼahụ ya, bịara nʼegwu nʼịma jijiji daa nʼụkwụ ya, gwa ya eziokwu niile.  
\v 34 Ọ sịrị ya, \wj “Ada m nwanyị, okwukwe gị agwọọla gị. Laa nʼudo nwerekwa onwe gị site nʼọrịa gị.”\wj* 
\p  
\v 35 Mgbe ọ ka nọ na-ekwu okwu, ụfọdụ ndị mmadụ sitere nʼụlọ onyeisi ụlọ ekpere bịara sị, “Ada gị nwanyị anwụọla, olee ihe mere i ji esogbu onye ozizi a ọzọ?” 
\p  
\v 36 Ma ka ọ nụrụ ihe ha kwuru, Jisọs gwara onyeisi ụlọ ekpere ahụ sị ya, \wj “Atụla egwu, naanị kwere.”\wj* 
\p  
\v 37 O kweghị ka onye ọbụla ọzọ soro ya ma ọ bụghị Pita, na Jemis na Jọn nwanne Jemis.  
\v 38 Mgbe ha bịarutere nʼụlọ onyendu ụlọ ekpere ahụ, ọ nụrụ ụzụ hụkwa ọtụtụ mmadụ ka ha nọ na-akwa akwa na-etikwa mkpu akwa.  
\v 39 Mgbe ọ batara, ọ sịrị ha, \wj “Gịnị mere unu ji na-akwa akwa na-etikwa mkpu akwa? Nwatakịrị a anwụghị anwụ, ọ na-arahụ ụra!”\wj* 
\v 40 Ma ha chịrị ya ọchị. 
\p Mgbe ọ chụpụsịrị ha niile nʼezi, ọ kpọọrọ nne na nna nwantakịrị ahụ, na ndị ya na ha so, banye nʼime ụlọ ebe nwantakịrị ahụ dina.  
\v 41 O jidere ya nʼaka sị ya, \tl \+wj “Talita koum!”\+wj*\tl* (nke pụtara, \wj “Nwa agbọghọ nta, asị m gị bilie!”\wj*).  
\v 42 Otu mgbe ahụ nwaagbọghọ nta ahụ biliri ọtọ bido ijegharị (ọ gbara afọ iri na abụọ). Nke a jụrụ ha niile anya nke ukwuu.  
\v 43 Ma ọ dọsiri ha aka na ntị ike, ka ha ghara ịgwa onye ọbụla ihe mere. Ọ sịrị ha, “Nyenụ ya nri ka o rie.” 
\c 6  
\s1 Onye amụma na-enweghị ugwu 
\p  
\v 1 Ọ sitere nʼebe ahụ pụọ laghachi nʼobodo nke a mụrụ ya. Ndị na-eso ụzọ ya sooro ya gaa.  
\v 2 Nʼụbọchị izuike, ọ banyere nʼụlọ ekpere bido izi ihe. Ozizi ya juru ọtụtụ ndị gere ya ntị anya. 
\p Ha kwuru sị, “Ebee ka nwoke si mụta ihe ndị a niile? Gịnịkwa bụ amamihe nke a e nyere ya? Lekwa ọrụ ebube nke a ọ rụrụ?  
\v 3 Onye a ọ bụghị onye kapinta\f + \fr 6:3 \ft Onye ọkpọ ntu maọbụ onye ǹka\f* ahụ? Ọ bụghị nwa Meri, bụrụkwa nwanne Jemis, Josef,\f + \fr 6:3 \ft Nʼime ụfọdụ akwụkwọ nsọ ị ga-ahụ Joses.\f* Judas na Saimọn? Ụmụnne ya ndị inyom ha esoghị anyị nọrọ nʼebe a?” Iwe were ha nʼebe ọ nọ. 
\p  
\v 4 Ma Jisọs zara ha sị, \wj “Onye amụma adịghị enwe nsọpụrụ ọbụla nʼobodo a mụrụ ya, na nʼetiti ndị ikwu ya na nʼezinaụlọ o siri pụta.”\wj* 
\v 5 Ọ rụghị ọrụ ebube ọbụla nʼebe ahụ. Ihe o mere bụ naanị ibikwasị mmadụ ole na ole ahụ na-esighị ike aka nʼisi gwọọ ha.  
\v 6 Enweghị okwukwe ha juru ya anya. 
\s1 Nzipụ ndị ozi iri na abụọ 
\p O jegharịkwara nʼobodo nta niile gburugburu na-ezi ihe.  
\v 7 Ọ kpọrọ mmadụ iri na abụọ ahụ na-eso ya, nye ha ikike zipụ ha, abụọ abụọ. O nyere ha ikike ịchụpụ mmụọ na-adịghị ọcha. 
\p  
\v 8 Ndị a bụ iwu o nyere: \wj “Unu ewerekwala ihe ọbụla maka njem a, karịkwa mkpanaka. Unu ewela achịcha, maọbụ akpa, unu etinyela ego ọbụla nʼime belịt unu.\wj* 
\v 9 \wj Yirinụ akpụkpọụkwụ unu, unu eyikwala karịa otu uwe.\wj* 
\v 10 \wj Mgbe ọbụla unu banyere nʼụlọ ọbụla, nọgidenụ nʼebe ahụ ruo mgbe unu hapụrụ obodo ahụ.\wj* 
\v 11 \wj Ma ọ bụrụ na obodo ọbụla anabataghị unu maọbụ egeghị unu ntị, kụchapụnụ aja dị nʼụkwụ unu mgbe unu na-apụ, ka ọ bụrụ ihe ama megide ha.”\wj* 
\p  
\v 12 Ha pụrụ kwusara ndị mmadụ ka ha chegharịa.  
\v 13 Ha chụpụrụ ọtụtụ mmụọ ọjọọ, teekwa ọtụtụ ndị ahụ na-esighị ike mmanụ, gwọọ ha. 
\s1 Ọnwụ Jọn omee baptizim 
\p  
\v 14 Eze Herọd nụrụ akụkọ banyere ya, nʼihi na aha Jisọs aghọọla okwu a kpụ nʼọnụ. Ụfọdụ na-asị, na ọ bụ “Jọn omee baptizim; na e meela ka o site na ndị nwụrụ anwụ bilie. Ọ bụkwa nke a mere ka ike ọrụ ebube ji dị nʼime ya.” 
\p  
\v 15 Ndị ọzọ na-asị, “Ọ bụ Ịlaịja.” 
\p Ma ndị ọzọkwa kwuru na ọ bụ onye amụma dị ka otu nʼime ndị amụma mgbe ochie. 
\p  
\v 16 Ma mgbe Herọd nụrụ nke a, ọ sịrị, “Jọn onye ahụ m bipụrụ isi, emeela ka ọ site nʼọnwụ bilie!” 
\p  
\v 17 Nʼihi na Herọd nʼonwe ya nyererị iwu ka e jide Jọn kee ya agbụ tụba ya nʼụlọ mkpọrọ. O mere nke a nʼihi Herodịas bụrịị nwunye Filip nwanne ya, onye ọ kpọrọ dịka nwunye ya.  
\v 18 Nʼihi na Jọn gwara Herọd sị, “Ọ bụghị ihe ziri ezi nʼiwu ka ị kpọrọ nwunye nwanne gị nwoke.”  
\v 19 Nʼihi ya Herodịas bu iro nʼobi megide Jọn na-achọkwa ụzọ igbu ya, mana ọ pụghị ime nke a,  
\v 20 nʼihi na Herọd na-atụ egwu ma na-echekwa Jọn, ebe ọ maara na ọ bụ onye ezi omume na onye dị nsọ. Mgbe ọ nụrụ okwu ya, o nweghị udo nʼobi ma ige ya ntị na-amasị ya. 
\p  
\v 21 Nʼikpeazụ, ohere bịara mgbe Herọd kpọrọ oriri nʼụbọchị ncheta ọmụmụ ya nye ndị ọkwa ha dị elu nʼokpuru ọchịchị ya, ndịisi ndị ọchịagha na ndị bụ ndị ndu nʼobodo Galili.  
\v 22 Mgbe ada Herodịas bịara tee egwu, obi tọrọ Herọd na ndị niile ọ kpọrọ oriri ụtọ. 
\p Eze gwara nwaagbọghọ ahụ sị, “Rịọ m ihe ọbụla ị chọrọ aga m enyekwa gị ya.”  
\v 23 O kwere ya nkwa ṅụọkwa iyi sị, “Ihe ọbụla ị rịọrọ m aga m enye gị, ọ bụladị ọkara alaeze m.” 
\p  
\v 24 Ọ jekwuru nne ya jụọ ya sị, “Gịnị ka m ga-arịọ?” 
\p Ọ zara ya sị, “Isi Jọn omee baptizim.” 
\p  
\v 25 Ngwangwa, ọ bịakwutere eze rịọ ya sị, “Achọrọ m ka i nye m, ugbu a, nʼime efere, isi Jọn omee baptizim.” 
\p  
\v 26 O wutere eze nke ukwuu, ma nʼihi iyi ọ ṅụrụ, na nʼihi ndị ọ kpọrọ oriri, ọ chọghị ịjụ inye ya ihe ọ rịọrọ ya.  
\v 27 Ngwangwa o zipụrụ onye agha na-eche nche nye ya iwu ka ọ gaa bute isi Jọn. Ọ gara, bipụ isi Jọn nʼụlọ mkpọrọ,  
\v 28 tinye isi ahụ nʼime efere butere nwaagbọghọ ahụ onye nara ya bunye nne ya.  
\v 29 Mgbe ndị na-eso ụzọ ya nụrụ nke a, ha bịara buru ozu ya gaa lie. 
\s1 Jisọs enye puku mmadụ ise nri 
\p  
\v 30 Ndị ozi Jisọs gbara ya gburugburu kọọrọ ya ihe niile ha mere, na ihe niile ha kuziri.  
\v 31 Nʼoge ahụ, nʼihi na ọtụtụ ndị mmadụ na-abịa na-apụkwa nke mere na ha enweghị ohere iri nri, ọ sịrị ha, \wj “Soronụ m, unu niile, ka anyị ga ebe dị jụụ, zuo ike nwa oge nta.”\wj* 
\p  
\v 32 Ya mere ha pụrụ baa nʼime ụgbọ mmiri gaa nʼebe ha ga-anọdụrụ naanị onwe ha.  
\v 33 Ma ọtụtụ mmadụ ndị hụrụ ha mgbe ha na-apụ matara ha, sitekwara nʼobodo niile dị ebe ahụ gburugburu gbara ọsọ gbaruo ebe ahụ tupu ya na ndị na-eso ụzọ ya abịaruo.  
\v 34 Mgbe o sitere nʼụgbọ mmiri rịdata, ọ hụrụ oke igwe mmadụ a ka ha zukọrọ. O nwere ọmịiko nʼebe ha nọ, nʼihi na ha dị ka atụrụ na-enweghị onye na-azụ ha. Ọ malitekwara izi ha ọtụtụ ihe. 
\p  
\v 35 Nʼoge a, ọchịchịrị ebidola ịgba, nʼihi ya, ndị na-eso ụzọ ya bịara gwa ya, “Ebe a bụ ọzara, chi ejiekwala.  
\v 36 Zilaga ndị a, ka ha gaa nʼobodo nta ndị dị gburugburu ebe a, zụtara onwe ha ihe ha ga-eri.” 
\p  
\v 37 Ma ọ zara sị ha, \wj “Nyenụ ha ihe ha ga-eri.”\wj* 
\p Ha sịrị ya, “Anyị ga-eje ịzụta ogbe achịcha nke narị denarị\f + \fr 6:37 \ft Otu denarị bụ ihe a na-akwụ dị ka ụgwọ ọrụ otu ụbọchị.\f* abụọ, iji nye ha ka ha rie?” 
\p  
\v 38 Ma ọ jụrụ ha sị, \wj “Ogbe achịcha ole ka unu nwere? Gaanụ chọpụta.”\wj* 
\p Mgbe ha chọpụtasịrị, ha sịrị, “Ogbe achịcha ise na azụ abụọ.” 
\p  
\v 39 Mgbe ahụ o nyere ha iwu ka ha mee igwe mmadụ ahụ ka ha nọdụ ala nʼotu nʼotu nʼelu ahịhịa ndụ.  
\v 40 Ya mere, ha nọdụrụ ala, iri mmadụ ise nʼotu ebe, narị mmadụ nʼebe ọzọ.  
\v 41 Ọ naara ogbe achịcha ise na azụ abụọ ndị ahụ, welie anya ya elu, nye ekele. Ọ nyawara achịcha ahụ nye ya ndị na-eso ụzọ ya ka ha kee ndị mmadụ ahụ. Otu aka ahụkwa ọ nyawakwara azụ abụọ ahụ nyekwa ha niile.  
\v 42 Ha niile riri rijuo afọ.  
\v 43 Ha tụtụkọtara iberibe achịcha na azụ tụtụjuo nkata iri na abụọ.  
\v 44 Ọnụọgụgụ ndị nwoke riri ogbe achịcha ahụ dị puku mmadụ ise. 
\s1 Jisọs agaa ije nʼelu mmiri 
\p  
\v 45 Ngwangwa, o mere ka ndị na-eso ụzọ ya banye nʼụgbọ mmiri buru ya ụzọ gafee nʼofe nke ọzọ nke osimiri Betsaida, ebe ya onwe ya nọdụrụ izilaga igwe mmadụ ahụ.  
\v 46 Mgbe ndị a niile lachara, ọ rigooro nʼelu ugwu ikpe ekpere. 
\p  
\v 47 Mgbe uhuruchi bịara, ụgbọ mmiri ahụ nọ nʼetiti osimiri, ma naanị ya onwe ya nọ nʼelu ala.  
\v 48 Mgbe ọ hụrụ na ha nọ na nsogbu nʼihi na ikuku na-emegide ha, nʼihe dị ka elekere atọ nke ụtụtụ, o bidoro ịga ije nʼelu mmiri ịbịakwute ha, ma o mere dị ka ọ chọrọ ịgafe ha.  
\v 49 Ma mgbe ha hụrụ ya ka ọ na-aga ije nʼelu osimiri, ha chere na ọ bụ mmụọ, tie mkpu akwa.  
\v 50 Nʼihi na ha niile hụrụ ya, oke ụjọ tụkwara ha. 
\p Na-atụfughị oge, ọ gwara ha sị, \wj “Nweenụ obi ike! Ọ bụ m. Unu atụla egwu.”\wj* 
\v 51 Emesịa, ọ rịgokwuru ha nʼime ụgbọ mmiri ahụ, otu mgbe ahụ ikuku ahụ dara juu. Ihe ndị a jukwara ha anya nke ukwuu.  
\v 52 Obi ha mechiri emechi nʼihi na ha aghọtaghị ihe banyere ọrụ ebube ogbe achịcha ndị ahụ. 
\s1 Ọgwụgwọ ọrịa na Genesaret 
\p  
\v 53 Mgbe ha gafere nʼofe nke ọzọ, ha rutere nʼala Genesaret ebe ha kedoro ụgbọ ha.  
\v 54 Ma ngwangwa ha pụtara nʼụgbọ, ndị nọ nʼebe ahụ matara onye ọ bụ.  
\v 55 Ha gbaara ọsọ gaa nʼobodo nta niile dị ebe ahụ gburugburu butere ya ndị ọrịa nʼute ebe ọbụla ha nụrụ na ọ nọ.  
\v 56 Ebe ọbụla ọ bara, nʼobodo ukwu maọbụ na obodo nta, maọbụ nʼubi, ndị mmadụ na-ebute ndị ọrịa nibe ha nʼahịa. Ha rịọrọ ya ka o kwere ka ha metụ ọ bụladị ọnụnụ uwe ya aka; ndị niile metụrụ ya aka nwetara ọgwụgwọ. 
\c 7  
\s1 Ihe dị ọcha na ihe na-adịghị ọcha 
\p  
\v 1 Mgbe ndị Farisii na ụfọdụ ndị ozizi iwu sitere Jerusalem bịa gbara ya gburugburu,  
\v 2 ha hụrụ na ụfọdụ ndị na-eso ụzọ ya ji aka na-adịghị ọcha, ya bụ aka a na-akwọghị akwọ, na-eri nri.  
\v 3 Ndị Farisii na ndị Juu niile adịghị eri nri ma ọ bụrụ na ha akwọghị aka, nʼihi na ha na-ejigidesi aka ike nʼozizi na omenaala nke ndị okenye.  
\v 4 Mgbe ọbụla ha si nʼahịa lọta, ha adịghị eri nri ma ọ bụghị ma ha sachara onwe ha. Ha na-edebekwa ọtụtụ omenaala ndị ọzọ dị ka ịsacha iko, na ite mmiri na ketụlụ.\f + \fr 7:4 \ft Nʼime ụfọdụ akwụkwọ mgbe ochie \fqa ị ga-ahụta ma ihe ndina.\f* 
\p  
\v 5 Ya mere ndị Farisii na ndị ozizi iwu jụrụ ya sị, “Gịnị mere ndị na-eso ụzọ gị adịghị ebi nʼusoro omenaala ndị okenye. Karịa iji aka na-adịghị ọcha rie nri ha?” 
\p  
\v 6 Ọ sịrị ha, \wj “Amụma ahụ Aịzaya buru banyere unu ndị ihu abụọ bụ eziokwu; dị ka e dere ya sị,\wj* 
\q1 \wj “ ‘Ndị a ji egbugbere ọnụ ha na-asọpụrụ m,\wj* 
\q2 \wj ma obi ha dị anya nʼebe m nọ.\wj* 
\q1  
\v 7 \wj Ofufe ha na-efe m bụ ihe efu,\wj* 
\q2 \wj ozizi ha bụkwa ihe mmadụ nyere nʼiwu.’\wj*\f + \fr 7:7 \ft \xt Aịz 29:13\f* 
\m  
\v 8 \wj Unu atụfuola iwu Chineke ma jidesiekwa aka ike nʼomenaala nke mmadụ.”\wj* 
\p  
\v 9 Ma ọ gwakwara ha sị, \wj “Unu nwere ụzọ dị mma nʼanya unu nke unu ji wezuga iwu Chineke ma were omenaala unu dochie nʼọnọdụ ya.\wj* 
\v 10 \wj Nʼihi na Mosis sịrị, ‘Sọpụrụ nne gị na nna gị,’\wj*\f + \fr 7:10 \ft \xt Ọpụ 20:12; Dit 5:16\f*\wj na, ‘onye ọbụla kwujọrọ nne maọbụ nna ya ka e gbuo ya.’\wj*\f + \fr 7:10 \ft \xt Ọpụ 21:17; Lev 20:9\f* 
\v 11 \wj Ma unu na-asị, na ọ bụrụ na mmadụ asị nne ya maọbụ nna ya, ‘Ihe ọbụla bụ nke ị gara erite nʼaka m bụ kọban,’ (nke pụtara onyinye dịrị Chineke).\wj*\f + \fr 7:11 \ft Nke a adịghị nʼiwu Chineke nyere.\f* 
\v 12 \wj Nʼụzọ dị otu a, unu na-akwagide ndị mmadụ ka ha hapụ inyere nne na nna ha aka.\wj* 
\v 13 \wj Nʼụzọ dị otu a, unu na-eme okwu Chineke ka ọ bụrụ ihe efu, site nʼomenaala unu nke unu nyefere nʼaka ndị ọzọ. Ọ dịkwa ọtụtụ ihe ndị ọzọ dị ka nke a unu na-eme.”\wj* 
\p  
\v 14 Ọzọkwa, ọ kpọrọ igwe mmadụ ahụ sị ha, \wj “Geenụ m ntị onye ọbụla, ma ghọtakwanụ nke a.\wj* 
\v 15 \wj Ọ dịghị ihe ọbụla banyere nʼime mmadụ pụrụ imerụ mmadụ, kama ihe na-emerụ mmadụ bụ ihe ahụ na-esite nʼime ya na-apụta.”\wj* 
\v 16 \wj Onye ọbụla nwere ntị ịnụ ihe, ya nụrụ.\wj*\f + \fr 7:16 \ft Ụfọdụ akwụkwọ na-edebanye okwu ndị a dị isi 4 nʼamaokwu nke 23.\f* 
\p  
\v 17 Mgbe ọ hapụrụ igwe ndị mmadụ ahụ banye nʼime ụlọ, ndị na-eso ụzọ ya jụrụ ya maka ilu a.  
\v 18 Ọ sịrị ha, \wj “Unu ọ ka dị ka ndị na-enweghị nghọta? Ọ bụ unu aghọtaghị na ihe ọbụla banyere nʼime mmadụ apụghị imerụ ya.\wj* 
\v 19 \wj Nʼihi na ihe dị otu a anaghị abanye nʼobi ha, kama ọ na-abanye nʼime afọ ha, si nʼebe ahụ a nyụpụ ya nʼụlọ nsị.”\wj* (Site nʼikwu otu a, o mere ka ihe oriri niile dị ọcha.) 
\p  
\v 20 Ọ sịkwara, \wj “Ọ bụ ihe sitere nʼime mmadụ pụta na-emerụ ya.\wj* 
\v 21 \wj Nʼihi na ọ bụ nʼime obi mmadụ ka echiche ọjọọ niile si apụta, ya na ịkwa iko niile dị iche iche, izu ohi, igbu mmadụ,\wj* 
\v 22 \wj ịkwa iko nke ndị nwere di na nwunye, ọchịchọ ịdọtara onwe gị ihe ndị ọzọ nwere, ekworo, aghụghọ niile, adịghị ọcha niile, inwe anya ụfụ nʼebe ndị ọzọ nọ, nkwulu niile, nganga na enweghị uche ọbụla.\wj* 
\v 23 \wj Ihe ọjọọ ndị a niile na-esite nʼime mmadụ a pụta. Ha bụkwa ihe na-emerụ mmadụ.”\wj* 
\s1 Okwukwe nwanyị Siria 
\p  
\v 24 Ọ hapụrụ ebe ahụ gaa nʼakụkụ obodo Taịa.\f + \fr 7:24 \ft Nʼakwụkwọ ochie ụfọdụ i ga-ahụ Taịa na Saịdọn.\f* Nʼebe ahụ ọ banyere nʼime otu ụlọ. Ma o nwekwaghị ike izo onwe ya, nʼagbanyeghị na ọ chọghị ka a mata na ọ nọ ebe ahụ.  
\v 25 Ngwangwa, otu nwanyị nwere otu nwa nwanyị ntakịrị nke mmụọ na-adịghị ọcha bi nʼime ya nụrụ maka ya, ọ bịara daa nʼụkwụ ya.  
\v 26 Nwanyị a bụ onye Griik a mụrụ nʼakụkụ Sairo-Fonisia. Ọ rịọrọ ya ka ọ chụpụrụ ya mmụọ ọjọọ ahụ bi nʼime nwa ya nwanyị. 
\p  
\v 27 Ọ sịrị ya, \wj “Hapụ ka ụmụntakịrị buru ụzọ rie ihe, nʼihi na o zighị ezi na a ga-ewere nri ụmụntakịrị tụpụrụ nkịta.”\wj* 
\p  
\v 28 Ma ọ zaghachiri ya sị, “Onyenwe m, ma ụmụ nkịta na-erikwa iberibe nri ụmụntakịrị si na tebul tụpụ nʼala.” 
\p  
\v 29 Mgbe ahụ, ọ sịrị ya, \wj “Nwanyị, ị zara nke ọma, nʼihi ọsịsa gị, laa, mmụọ ọjọọ ahụ ahapụla nwa gị nwanyị ugbu a.”\wj* 
\p  
\v 30 Ọ laghachiri nʼụlọ ya, hụ nwantakịrị ahụ ka o dina nʼelu ihe ndina, mmụọ ọjọọ ahụ apụọkwala. 
\s1 Ọgwụgwọ onye ntị chiri na onye ogbu 
\p  
\v 31 Emesịa, ọ hapụrụ akụkụ Taịa gabiga Saịdọn bịaruo nʼosimiri Galili ruo nʼobodo ndị dị na Dekapọlịs.  
\v 32 Ha duteere ya otu nwoke ntị chịrị, nke na-asụkwa oke nsụ. Ha rịọrọ ya ka o bikwasị ya aka. 
\p  
\v 33 O duuru ya pụọ nʼebe igwe mmadụ ahụ nọ, rụnye ya mkpịsịaka nʼime ntị ya abụọ. Mgbe ahụ ọ gbụpụkwara ọnụ mmiri metụkwa ya aka nʼire.  
\v 34 O leliri anya nʼeluigwe sụọ ude sị ya, \tl \+wj “Ef fata,”\+wj*\tl* nke pụtara \wj “Meghee!”\wj* 
\v 35 Ngwangwa, ntị ya meghere, a tọpụkwara ire ya, ọ malite ikwu okwu nke ọma. 
\p  
\v 36 Jisọs nyere ha iwu ka ha ghara ịgwa onye ọbụla, ma mgbe ọ na-eme nke a ha gara nʼihu na-akọsa ya ebe niile.  
\v 37 Ọ tụrụ ha nʼanya nke ukwuu, ha kwuo sị, “O meela ihe niile nke ọma. Ọ na-eme ka ọ bụladị ndị ntị chiri nụ ihe, ma mee ka ndị ogbi kwuo okwu.” 
\c 8  
\s1 Jisọs enye puku mmadụ anọ nri 
\p  
\v 1 Nʼoge ahụ, igwe mmadụ ọzọ zukọrọ. Ebe ha na-enweghị ihe ha ga-eri, ọ kpọrọ ndị na-eso ụzọ ya sị ha,  
\v 2 \wj “Enwere m ọmịiko nʼebe igwe mmadụ ndị a nọ. Nke a na-eme ya ụbọchị atọ anyị na ha nọ. Ugbu a, ha enweghị ihe ha ga-eri.\wj* 
\v 3 \wj Ọ bụrụ na m ezilaga ha nʼụlọ ha, ụfọdụ nʼime ha ga-ada nʼụzọ nʼihi agụụ. Nʼihi na ụfọdụ ha si nʼebe dị anya bịa.”\wj* 
\p  
\v 4 Ndị na-eso ụzọ ya zara ya, “Ebee ka mmadụ ga-achọta achịcha ga-ezuru ndị a nʼime ọzara a?” 
\p  
\v 5 Jisọs jụrụ ha sị, \wj “Ogbe achịcha ole ka unu nwere?”\wj* 
\p Ha zara sị, “Asaa.” 
\p  
\v 6 Ọ gwara igwe mmadụ ahụ ka ha nọdụ ala. O weere ogbe achịcha asaa ahụ kpee ekpere. Ọ nyawasịrị ha, nye ha ndị na-eso ụzọ ya ka ha kee igwe mmadụ ahụ niile. Ha kekwara ya nye igwe mmadụ ahụ.  
\v 7 Ha nwekwara azụ ole na ole. O weere ya kpee ekpere, ọ gwara ha ka ha kesaakwa ya.  
\v 8 Ha riri, rijuo afọ. Ha tụtụkọtara iberibe achịcha dafuru nʼebe ndị a nọ rie nri. Ha tụtụjuru nkata asaa.  
\v 9 Ndị riri nri a ruru ihe dịka puku mmadụ anọ. Mgbe ahụ o zilagara ha.  
\v 10 Ngwangwa, ya na ndị na-eso ụzọ ya banyere nʼụgbọ mmiri gaa nʼakụkụ obodo Dalmanuta. 
\p  
\v 11 Ndị Farisii bịakwutere ya malite nrụrịta ụka, na-achọ ihe ịrịbama si nʼeluigwe, iji nwalee ya.  
\v 12 Ọ sụrụ ude nke ukwuu nʼime onwe ya sị, \wj “Gịnị mere ọgbọ a ji achọ ihe ịrịbama? Nʼezie, nʼezie, agwa m unu, o nweghị ihe ịrịbama a ga-egosi ọgbọ a.”\wj* 
\v 13 Ọ hapụrụ ha nʼebe ahụ banyekwa nʼụgbọ mmiri ọzọ, ịgafe nʼofe ọzọ nke osimiri ahụ. 
\s1 Ihe na-eko achịcha nke ndị Farisii na Herọd 
\p  
\v 14 Ndị na-eso ụzọ ya chefuru iwere achịcha. Ọ bụ naanị otu ogbe achịcha fọdụụrụ ha nʼime ụgbọ.  
\v 15 Ọ dọrọ ha aka na ntị sị, \wj “Kpacharanụ anya. Lepụnụ anya maka ihe na-eko achịcha ndị Farisii na nke Herọd.”\wj* 
\p  
\v 16 Ha kparịtara ụka nʼetiti onwe ha na-asị, “Ọ bụ nʼihi na anyị enweghị achịcha.” 
\p  
\v 17 Mgbe Jisọs ghọtara isi mkparịta ụka ha, ọ jụrụ ha sị, \wj “Gịnị mere unu ji na-ekwu okwu maka enweghị achịcha? Ọ pụtara na unu adịghị ahụ maọbụ aghọta? Obi unu o siri ike?\wj* 
\v 18 \wj Unu nwere anya nke na-adịghị ahụ ụzọ? Unu nwere ntị ma unu adịghị anụ ihe? Ọ ga-abụ na unu adịghị echeta?\wj* 
\v 19 \wj Mgbe m ji ogbe achịcha ise zụọ puku mmadụ ise, iberibe achịcha juru nkata ole ka unu tụtụkọtara?”\wj* 
\p Ha zara sị ya, “Nkata iri na abụọ.” 
\p  
\v 20 \wj “Mgbe m ji ogbe achịcha asaa zụọ puku mmadụ anọ, iberibe achịcha juru nkata ole ka unu tụtụkọtara?”\wj* 
\p Ha zara sị ya, “Nkata asaa.” 
\p  
\v 21 Ọ sịrị ha, \wj “Unu ka nọ na-enweghị nghọta?”\wj* 
\s1 Jisọs agwọọ onye ìsì na Betsaida 
\p  
\v 22 Mgbe ha ruru Betsaida, ụfọdụ mmadụ kpọtaara ya otu onye ìsì rịọọ ya ka o metụ ya aka,  
\v 23 Ọ duuru onye ìsì ahụ nʼaka pụọ nʼazụ obodo. Mgbe ahụ, ọ gbụsara ọnụ mmiri nʼanya ya metụkwa ya aka nʼanya. Ọ jụrụ ya sị, \wj “Ị na-ahụ ihe ọbụla?”\wj* 
\p  
\v 24 Nwoke ahụ leliri anya elu ma sị, “Ana m ahụ ndị mmadụ ma ha dị ka osisi na-agagharị agagharị.” 
\p  
\v 25 Nke ugboro abụọ Jisọs metụkwara ya aka nʼanya, mgbe ahụ anya ya meghere. O bidoro ịhụ ihe niile nke ọma.  
\v 26 Ọ zilagara ya ụlọ ya sị ya, \wj “Abanyekwala nʼime obodo.”\wj* 
\s1 Ọgbụgba ama Pita banyere Kraịst 
\p  
\v 27 Mgbe ahụ Jisọs na ndị na-eso ụzọ ya gara nʼobodo nta ndị ọzọ dị gburugburu Sizaria Filipai. Mgbe ha na-aga nʼụzọ, ọ jụrụ ndị na-eso ụzọ ya sị, \wj “Onye ka ndị mmadụ na-asị na m bụ?”\wj* 
\p  
\v 28 Ha zara ya sị, “Ụfọdụ na-asị na ị bụ Jọn omee baptizim, ndị ọzọkwa sị na ị bụ Ịlaịja maọbụ otu nʼime ndị amụma.” 
\p  
\v 29 Ma ọ jụrụ ha sị, \wj “Ma unu onwe unu, ọ bụ onye ka unu na-asị na m bụ?”\wj* 
\p Pita zara sị, “Ị bụ Kraịst\f + \fr 8:29 \ft Maọbụ, \fqa Onye nzọpụta.\f* ahụ.” 
\p  
\v 30 Ọ dọrọ ha aka na ntị sị ha agwakwala onye ọbụla ihe banyere ya. 
\s1 Jisọs ekwuo okwu ọnwụ ya 
\p  
\v 31 Emesịa, o bidoro izi ha ihe na Nwa nke Mmadụ aghaghị ịhụ ọtụtụ ahụhụ dị iche iche, ndị okenye, na ndịisi nchụaja na ndị ozizi iwu ga-ajụ ya, na aghaghị igbu ya, ma ọ ga-ebili nʼọnwụ mgbe ụbọchị nke atọ gasịrị.  
\v 32 Ọ gwaghere ha ihe ndị a ọnụ. Ma Pita kpọọrọ ya pụọ nʼotu akụkụ, bido ịbara ya mba. 
\p  
\v 33 Ma ọ tụgharịrị lee ndị na-eso ụzọ ya anya, baara Pita mba sị ya, \wj “Si nʼebe m nọ pụọ ekwensu! Ihe ị na-eche echiche ya abụghị uche Chineke, ha bụ echiche mmadụ.”\wj* 
\s1 Ihe ọ ga-efu iso Jisọs 
\p  
\v 34 Mgbe ahụ, ọ kpọrọ ndị na-eso ụzọ ya na igwe mmadụ ahụ. Ọ gwara ha sị, \wj “Ọ bụrụ na onye ọbụla achọọ iso m, ya gụọ ndụ ya dị ka ihe furu efu. Mgbe ahụ, ya buru obe ya soro m nʼazụ\wj*.  
\v 35 \wj Nʼihi na onye na-azọ ndụ ya ka ọ ga-efunarị, ma onye ọbụla gụrụ ndụ ya dị ka ihe furu efu nʼihi m, na nʼihi oziọma m, ga-azọpụta ya.\wj* 
\v 36 \wj Uru gịnị ka ọ ga-abara mmadụ, iritecha ụwa niile nʼuru ma tufuo ndụ ha?\wj* 
\v 37 \wj Ọ dị ihe ọzọ dị nʼụwa mmadụ nwere ike iji gbanwere ndụ ya?\wj* 
\v 38 \wj Ọ bụrụ na ihere na-eme onye ọbụla nʼihi m na nʼihi okwu m nʼụwa ọjọọ a, na nʼụwa mmehie a, ihere onye ahụ ga-emekwa Nwa nke Mmadụ, mgbe ọ ga-abịaghachi nʼebube nke Nna ya, ya na ndị mmụọ ozi dị nsọ.”\wj* 
\c 9  
\p  
\v 1 Ma ọ gwara ha sị, \wj “Nʼezie asị m unu, ụfọdụ nʼime ndị guzo nʼebe a, agaghị edetụ ọnwụ ire tupu ha ahụ alaeze Chineke mgbe ọ ga-abịa nʼike.”\wj* 
\s1 Nnwogha Jisọs 
\p  
\v 2 Mgbe ụbọchị isii gasịrị, Jisọs kpọọrọ Pita na Jemis na Jọn, duru ha rigoro nʼelu ugwu dị elu. Nʼebe ahụ ka ha nọdụrụ naanị ha. Nʼebe ahụ, a gbanwere ọdịdị ya nʼihu ha.  
\v 3 Uwe ya na-enwu ọcha karịa ụdị ọcha ọbụla anya hụrụla. Ọ dịkwa ọcha karịa nke onye ọbụla nʼụwa nwere ike ime ka ihe dị ọcha.  
\v 4 Ha hụrụ Ịlaịja na Mosis ka ha pụtara soro Jisọs na-ekwu okwu. 
\p  
\v 5 Pita gwara Jisọs sị, “Onye ozizi, ọ dị mma ka anyị nọdụ nʼebe a. Ka anyị wuo ụlọ ikwu atọ. Otu ga-abụ nke gị, otu a bụrụ nke Mosis, nke ọzọkwa a bụrụ nke Ịlaịja.”  
\v 6 (Ọ makwaghị ihe ọ ga-ekwu nʼihi na oke egwu tụrụ ha.) 
\p  
\v 7 Mgbe ahụ, igwe ojii pụtara kpuchie ha. Olu sitere nʼigwe ojii ahụ daa sị, “Onye a bụ Ọkpara m, onye m hụrụ nʼanya. Geenụ ya ntị.” 
\p  
\v 8 Na mberede, mgbe ha lere anya gburugburu, ọ dịkwaghị onye ọzọ ha hụrụ, karịa naanị Jisọs. 
\s1 Ajụjụ banyere Ịlaịja 
\p  
\v 9 Mgbe ha si nʼelu ugwu ahụ na-arịdata, Jisọs nyere ha iwu ka ha ghara ịgwa onye ọbụla ihe ha hụrụ, tutu ruo mgbe Nwa nke Mmadụ ga-esi nʼọnwụ bilie.  
\v 10 Ha zobere ihe a nʼetiti onwe ha, na-ekwurịtara okwu na-atule ihe isi nʼọnwụ bilie pụtara. 
\p  
\v 11 Ma ha jụrụ ya sị, “Gịnị mere ndị ozizi iwu jiri sị na Ịlaịja aghaghị ibu ụzọ bịa?” 
\p  
\v 12 Ọ gwara ha sị, \wj “Ọ bụ ezie, Ịlaịja ga-ebu ụzọ bịa, na-emekwa ka ihe dị ka ọ dị na mbụ. Ma gịnị mere e jiri dee na Nwa nke Mmadụ ga-ahụ ọtụtụ ahụhụ, bụrụkwa onye a jụrụ ajụ?\wj* 
\v 13 \wj Ka m gwa unu, Ịlaịja abịalarị. Ma ha mesokwara ya mmeso otu ha chọrọ dị ka e dere banyere ya.”\wj* 
\s1 Jisọs agwọọ nwa mmụọ ọjọọ bi nʼime ya 
\p  
\v 14 Mgbe ha bịarutere nʼebe ndị na-eso ụzọ ya nọ, ha hụrụ oke igwe mmadụ ka ha gbara ha gburugburu, hụkwa ụfọdụ ndị ozizi iwu ka ha na ha na-arụrịta ụka.  
\v 15 Ngwangwa, mmadụ ahụ niile hụrụ ya, ụdịdị ya juru ha anya. Ha gbaara ọsọ gaa kelee ya. 
\p  
\v 16 Ọ jụrụ ha sị, \wj “Unu na ha ọ na-arụrịta ụka banyere gịnị?”\wj* 
\p  
\v 17 Otu onye nʼime igwe mmadụ ahụ zara ya sị, “Onye ozizi akpọtaara m gị nwa m nwoke, nke mmụọ ọjọọ bi nʼime ya, nke mekwara ka ọ daa ogbi.  
\v 18 Mgbe ọbụla mmụọ ọjọọ ahụ malitere isogbu ya, ọ na-atụda ya nʼala. Mgbe ahụ, ọ na-agbọ ụfụfụ nʼọnụ ya, na-ata ikikere eze, anụ ahụ ya na-esikwa ike. Arịọrọ m ndị na-eso ụzọ gị ka ha chụpụ mmụọ ọjọọ a, ma ha enweghị ike.” 
\p  
\v 19 Ọ zaghachiri ha sị, \wj “Unu ọgbọ na-enweghị okwukwe. Ruo ole mgbe ka mụ na unu ga-anọ? Ruo ole mgbe ka m ga-anagide unu? Kpọtaranụ m ya!”\wj* 
\p  
\v 20 Ya mere, ha kpọtaara ya nwata ahụ. Mgbe mmụọ ọjọọ ahụ hụrụ ya, ngwangwa, o nugharịrị nwata ahụ nke ukwuu, ọ daa nʼala na-atụrụ onwe ya nʼala, na-agbọkwa ụfụfụ nʼọnụ ya. 
\p  
\v 21 Jisọs jụrụ nna nwata ahụ sị, \wj “Olee mgbe ihe a bidoro?”\wj* 
\p Ọ zara sị, “Site na mgbe ọ bụ nwata nta.  
\v 22 Ọ na-eme ya ka ọ daba nʼọkụ, maọbụ na mmiri, ka ọ laa ya nʼiyi. Ọ bụrụ na ọ dị ihe i nwere ike ime, biko meere anyị ebere, nyere anyị aka.” 
\p  
\v 23 Jisọs sịrị ya, \wj “ ‘Ọ bụrụ na i nwere ike’? Ihe niile pụrụ ime nʼebe onye kwere ekwe nọ.”\wj* 
\p  
\v 24 Ngwangwa, nna nwata ahụ tiri mkpu sị, “Ekweere m, biko nyere ekweghị ekwe m aka!” 
\p  
\v 25 Mgbe Jisọs hụrụ na igwe mmadụ na-agba ọsọ na-abịa nʼebe ahụ, ọ baara mmụọ ahụ na-adịghị ọcha mba sị, \wj “Gị mmụọ ọjọọ ntị ike na ịda ogbi, ana m enye gị iwu, site nʼime nwata a pụta! Abanyekwala nʼime ya ọzọ!”\wj* 
\p  
\v 26 O tiri mkpu nʼoke olu, nugharịa nwata ahụ nke ukwuu ma site nʼime ya pụta. Nwata ahụ tọgbọrọ nʼala dị ka onye nwụrụ anwụ nke mere na ndị niile nọ nʼebe ahụ sịrị, “Ọ nwụọla!”  
\v 27 Ma Jisọs jidere ya nʼaka selite ya elu, mee ka o guzo nʼụkwụ ya. O guzokwara. 
\p  
\v 28 Ma mgbe ọ banyere nʼime ụlọ ndị na-eso ụzọ ya jụrụ ya na nzuzo sị, “Gịnị mere o jiri siere anyị ike ịchụpụ ya?” 
\p  
\v 29 Ọ sịrị ha, \wj “Ọ bụ naanị site nʼike ekpere ka a pụrụ ịchụpụ ụdị a.”\wj*\f + \fr 9:29 \ft Akwụkwọ ochie ndị ọzọ na-edenye, na-ibu ọnụ.\f* 
\s1 Jisọs ekwuokwa okwu ọzọ banyere ọnwụ ya 
\p  
\v 30 Ha siri nʼebe ahụ pụọ gafee Galili. Ọ chọghị ka onye ọbụla mata maka ya,  
\v 31 nʼihi na ọ na-ezi ndị na-eso ụzọ ya ihe. Ọ sịrị ha, \wj “A ga-arara Nwa nke Mmadụ nye nʼaka ụmụ mmadụ, ha ga-egbukwa ya ma ọ ga-ebili nʼọnwụ mgbe mkpụrụ ụbọchị atọ gasịrị.”\wj* 
\v 32 Ma ha aghọtaghị ihe ọ na-agwa ha. Egwu tụkwara ha ị jụ banyere ya. 
\s1 Onye kachasị ukwuu 
\p  
\v 33 Emesịa, ha bịaruru Kapanọm. Mgbe ọ banyere nʼụlọ, ọ jụrụ ha sị, \wj “Gịnị ka unu na-arụrịta ụka banyere ya nʼokporoụzọ?”\wj* 
\v 34 Ma ha gbara nkịtị, nʼihi na ha rụrịtara ụka nʼokporoụzọ banyere onye dị ukwuu karịa ibe ya. 
\p  
\v 35 Ọ nọdụrụ ala kpọọ mmadụ iri na abụọ ahụ, sị ha, \wj “Ọ bụrụ na onye ọbụla chọrọ ịbụ onye mbụ, ọ ghaghị ịbụ onye ikpeazụ, bụrụkwa onye na-ejere mmadụ niile ozi.”\wj* 
\p  
\v 36 Mgbe ahụ o kuuru otu nwantakịrị mee ka o guzoro nʼetiti ha. O kuuru nwata ahụ nʼaka ya sị ha,  
\v 37 \wj “Onye ọbụla nabatara otu nʼime ụmụntakịrị ndị a nʼaha m, na-anabata m. Ma onye ọbụla nabatara m, ọ bụghị m ka ọ nabatara, kama ọ na-anabata onye zitere m.”\wj* 
\s1 Onye na-emegideghị anyị dịnyeere anyị 
\p  
\v 38 Jọn sịrị ya, “Onye ozizi, anyị hụrụ otu onye na-achụpụ mmụọ ọjọọ nʼaha gị, ma anyị gbalịrị igbochi ya nʼihi na ọ bụghị otu onye nʼime anyị.” 
\p  
\v 39 Ma Jisọs gwara ha sị, \wj “Unu egbochila ya, nʼihi na onye ọbụla ji aha m na-arụ ọrụ ebube agaghị ekwu okwu ọjọọ megide m.\wj* 
\v 40 \wj Nʼihi na onye ọbụla na-adịghị emegide anyị dịnyeere anyị.\wj* 
\v 41 \wj Nʼeziokwu asị m unu, onye ọbụla ga-ekunye unu otu iko mmiri nʼaha m, nʼihi na unu bụ ndị nke Kraịst, ga-anatakwa ụgwọ ọrụ ya.\wj* 
\s1 Iduba na mmehie 
\p  
\v 42 \wj “Ọ bụrụkwa na onye ọbụla emee ka otu nʼime ndị a dị nta kweere na m jehie, ọ ga-akara onye ahụ mma ma ọ bụrụ na e kenyere nkume igwe nri buru ibu nʼolu ya, tụnye ya nʼime oke osimiri.\wj* 
\v 43 \wj Ọ bụrụ na aka gị na-eme ka i jehie, gbupụ ya. Ọ ga-akara gị mma inwe ọrụsị baa na ndụ karịa inwe aka abụọ banye nʼọkụ ala mmụọ, ebe ọkụ ya na-adịghị anyụ anyụ;\wj* 
\v 44 \wj ebe\wj* 
\q1 \wj “ ‘ikpuru ya na-adịghị anwụ anwụ,\wj* 
\q2 \wj ọkụ ya adịghị anyụkwa anyụ.’\wj*\f + \fr 9:44 \ft Ụfọdụ akwụkwọ na-edebanye okwu ndị a dị nʼamaokwu nke 48.\f* 
\m  
\v 45 \wj Ọ bụrụ na ụkwụ gị na-eme ka i jehie, gbupụ ya, tufukwaa ya, nʼihi na ọ ga-akara gị mma ịba na ndụ na ngwụrọ karịa inwe ụkwụ abụọ a tụnye gị nʼọkụ ala mmụọ;\wj* 
\v 46 \wj ebe\wj* 
\q1 \wj “ ‘ikpuru ya na-adịghị anwụ anwụ,\wj* 
\q2 \wj ọkụ ya adịghị anyụkwa anyụ.’\wj*\f + \fr 9:46 \ft Ụfọdụ akwụkwọ na-edebanye okwu ndị a dị nʼamaokwu nke 48.\f* 
\m  
\v 47 \wj Ọ bụrụ na anya gị na-eme ka i jehie, ghụpụ ya. Ọ ga-akara gị mma na i nwere otu anya baa nʼalaeze Chineke, karịa inwe anya abụọ a tụnye gị nʼọkụ ala mmụọ,\wj* 
\v 48 \wj ebe\wj* 
\q1 \wj “ ‘ikpuru ya na-adịghị anwụ anwụ,\wj* 
\q2 \wj ọkụ ya adịghị anyụkwa anyụ.’\wj*\f + \fr 9:48 \ft \xt Aịz 66:24\f* 
\m  
\v 49 \wj A ga-eji ọkụ nụchaa onye ọbụla dị ka nnu.\wj* 
\p  
\v 50 \wj “Nnu dị mma, ma ọ bụrụ na ọ dịghị atọkwa ụtọ, olee ka ị ga-esi mee ka ọ tọọ ụtọ ọzọ? Ya mere, nweenụ nnu nʼime onwe unu. Unu na ibe unu biri nʼudo.”\wj* 
\c 10  
\s1 Ozizi banyere ịgba alụkwaghị m 
\p  
\v 1 Ọ hapụrụ ebe ahụ gaa nʼobodo ndị dị na mpaghara Judịa ma gafeekwa nʼofe Jọdan. Igwe mmadụ bịakwutekwara ya, ọzọ, dị ka o si emekwa, o ziri ha ihe. 
\p  
\v 2 Ụfọdụ ndị Farisii bịara, ma nʼihi ị nwalee ya, ha jụrụ ya sị, “O ziri ezi nʼiwu ka nwoke gbaa nwunye ya alụkwaghị m?” 
\p  
\v 3 Ma ọ zara ha sị, \wj “Gịnị ka Mosis nyere unu nʼiwu?”\wj* 
\p  
\v 4 Ha sịrị, “Mosis kwenyere ka nwoke dee asambodo alụkwaghị m, nye nwunye ya ma zilaga ya.” 
\p  
\v 5 Jisọs sịrị ha, \wj “Ọ bụ nʼihi na obi unu siri ike nke ukwuu ka o ji deere unu iwu a.\wj* 
\v 6 \wj Ma na mmalite nke okike ụwa, Chineke ‘kere ha nwoke na nwanyị.’\wj*\f + \fr 10:6 \ft \xt Jen 1:27\f* 
\v 7 \wj ‘Nʼihi nke a ka nwoke ga-eji hapụ nne ya na nna ya e jikọta ya na nwunye ya.\wj* 
\v 8 \wj Ha abụọ ga-abụ otu anụ ahụ.’\wj*\f + \fr 10:8 \ft \xt Jen 2:24\f*\wj Ya mere, ha abụkwaghị mmadụ abụọ ọzọ, kama otu anụ ahụ.\wj* 
\v 9 \wj Ya mere, ihe Chineke jikọtara, ka mmadụ ọbụla atọsala ya.”\wj* 
\p  
\v 10 Mgbe ha banyere nʼụlọ, ndị na-eso ụzọ ya jụrụ ya ọzọ ihe banyere okwu a.  
\v 11 Ọ sịrị ha, \wj “Onye ọbụla gbara nwunye ya alụkwaghị m ma lụrụ nwanyị ọzọ na-eme mmehie ịkwa iko megide ya.\wj* 
\v 12 \wj Ma ọ bụrụ na nwanyị ọbụla agbaa dị ya alụkwaghị m ma lụrụ nwoke ọzọ, ọ na-emekwa mmehie ịkwa iko.”\wj* 
\s1 Jisọs na ụmụntakịrị 
\p  
\v 13 Ndị mmadụ na-ekutere ya ụmụntakịrị ka o metụ ha aka, ma ndị na-eso ụzọ ya baara ha mba.  
\v 14 Ma mgbe Jisọs hụrụ nke a, iwe were ya nke ukwuu, ọ sịrị ha, \wj “Hapụnụ ụmụntakịrị ka ha bịakwute m. Unu egbochikwala ha. Nʼihi na alaeze Chineke bụ nke ndị dị otu a.\wj* 
\v 15 \wj Nʼeziokwu asị m unu, onye ọbụla nke na-agaghị anabata alaeze Chineke dị ka nwantakịrị agaghị aba nʼime ya.”\wj* 
\v 16 Mgbe ahụ, o kuuru ha nʼaka ya, bikwasị ha aka ya abụọ ma gọzie ha. 
\s1 Onye Ọgaranya na Alaeze Chineke 
\p  
\v 17 Mgbe ọ na-ebili njem, otu nwoke gbaara ọsọ bịa gbuo ikpere nʼihu ya. Ọ jụrụ ya sị, “Ezi onye ozizi ọma, gịnị ka m ga-eme ka m keta ndụ ebighị ebi?” 
\p  
\v 18 Jisọs sịrị ya, \wj “Gịnị mere i ji akpọ m ezi mmadụ? Ọ dịghị onye ọbụla bụ ezi mmadụ ma ọ bụghị naanị Chineke.\wj* 
\v 19 \wj Ị maara ihe niile enyere nʼiwu: ‘Egbula mmadụ, a kwala iko, e zula ohi, a gbala ama ụgha, a ghọgbula mmadụ ibe gị, sọpụrụ nne na nna gị.’\wj*\f + \fr 10:19 \ft \xt Ọpụ 20:12-16; Dit 5:16-20\f*\wj ”\wj* 
\p  
\v 20 Ọ sịrị ya, “E, onye ozizi, Edebezuchaala m ha niile siterị na mgbe m bụ nwata.” 
\p  
\v 21 Jisọs lere ya anya, hụ ya nʼanya. Mgbe ahụ, ọ gwara ya sị, \wj “Ọ fọdụrụ naanị otu ihe ị ga-eme. Laa, ugbu a, ree ihe niile i nwere, nyekwa ndị ogbenye ego i retara. I mesịa nke a, ị ga-enwe akụ nʼeluigwe. Mgbe ahụ bịaghachi soro m.”\wj* 
\p  
\v 22 Mgbe ọ nụrụ okwu a, ihu ya gbarụrụ. O sitere nʼebe ahụ pụọ na mwute, nʼihi na ọ bụ ọgaranya nke nwere ọtụtụ akụnụba. 
\p  
\v 23 Jisọs legharịrị anya gwa ndị na-eso ụzọ ya sị, \wj “Lee ka o si bụrụ ihe rara ahụ na onye ọgaranya ga-abanye nʼalaeze Chineke.”\wj* 
\p  
\v 24 Okwu ya tụrụ ndị na-eso ụzọ ya nʼanya, ma Jisọs gwakwara ha ọzọ sị, \wj “Ụmụntakịrị, ọ bụ nnọọ ihe rara ahụ ịbanye nʼalaeze Chineke.\wj* 
\v 25 \wj Ọ dịrị ịnyịnya kamel mfe isite nʼanya agịga gafee, karịa onye ọgaranya ịbanye nʼalaeze Chineke.”\wj* 
\p  
\v 26 Okwu a jubigara ha anya oke. Ha jụrịtara ibe ha sị, “Onye kwanụ ka a ga-azọpụta?” 
\p  
\v 27 Ma Jisọs lere ha anya sị ha, \wj “Nʼebe mmadụ nọ, ọ bụ ihe rara ahụ. Ma nʼebe Chineke nọ, ihe niile dị mfe. Ọ dịghị ihe rara Chineke ahụ ime.”\wj* 
\p  
\v 28 Pita malitere ịgwa ya sị, “Anyị ahapụla ihe niile soro gị!” 
\p  
\v 29 Jisọs sịrị, \wj “Nʼezie, nʼezie, agwa m unu, ọ dịghị onye ọbụla hapụrụ ụlọ ya, maọbụ ụmụnne ya ndị nwoke, maọbụ ụmụnne ya ndị nwanyị, maọbụ nne ya, maọbụ nna ya, maọbụ ụmụntakịrị ya, maọbụ ala ubi ya nʼihi m, na nʼihi oziọma a,\wj* 
\v 30 \wj nke na-agaghị anataghachikwa nʼụwa a, ụlọ, ụmụnne ndị nwoke, ụmụnne ndị nwanyị, nne, ụmụaka na ala ubi, tinyere mkpagbu, ihe ruru okpukpu narị karịa ihe niile nke ọ hapụrụ. Ọ ga-anatakwa ndụ ebighị ebi nʼụwa ọzọ.\wj* 
\v 31 \wj Ma ọtụtụ ndị bu ụzọ ga-abụ ndị ikpeazụ, ma ọtụtụ ndị ikpeazụ ga-abụkwa ndị bu ụzọ.”\wj* 
\s1 Okwu ọzọ Jisọs kwuru banyere ọnwụ ya 
\p  
\v 32 Ha nọ nʼụzọ na-aga Jerusalem, ma Jisọs nọ nʼihu ha, nke a juru ndị na-eso ụzọ ya nʼanya. Otu a kwa, ndị mmadụ niile na-abịa ha nʼazụ tụkwara egwu. Ọzọkwa, ọ kpọpụrụ mmadụ iri na abụọ ahụ nʼakụkụ, malite ịgwa ha ihe gaje ịdakwasị ya.  
\v 33 Ọ sịrị, \wj “Leenụ, anyị na-aga Jerusalem, ebe a ga-arara Nwa nke Mmadụ nyefee nʼaka ndịisi nchụaja na ndị ozizi iwu. Ha ga-ama ya ikpe ọnwụ, nyefekwa ya nʼaka ndị mba ọzọ.\wj* 
\v 34 \wj Ha ga-akwa ya emo, gbụsakwa ya ọnụ mmiri asụ, pịa ya ihe ma gbukwaa ya. Ma mgbe ụbọchị atọ gasịrị, ọ ga-esite nʼọnwụ bilie.”\wj* 
\s1 Arịrịọ Jemis na Jọn 
\p  
\v 35 Jemis na Jọn ụmụ Zebedi bịakwutere ya. Ha sịrị ya, “Onye ozizi, anyị chọrọ ka i meere anyị ihe ọbụla anyị rịọrọ.” 
\p  
\v 36 Ọ sịrị ha, \wj “Gịnị ka unu chọrọ ka m meere unu?”\wj* 
\p  
\v 37 Ha sịrị ya, “Kwere ka otu onye nʼime anyị nọrọ nʼaka nri gị, onye nke ọzọ nʼaka ekpe gị nʼime ebube gị.” 
\p  
\v 38 Ma Jisọs sịrị ha, \wj “Unu amataghị ihe unu na-arịọ. Unu pụrụ ịṅụ iko ahụ mụ onwe m ga-aṅụ maọbụ bụrụ ndị a ga-eme ụdị baptizim a ga-eme m?”\wj* 
\p  
\v 39 Ha zaghachiri ya, “Anyị pụrụ.” 
\p Jisọs sịrị ha, \wj “Unu ga-aṅụ iko m ga-aṅụ, a ga-emekwa unu baptizim nke a ga-eme m.\wj* 
\v 40 \wj Ma ịnọdụ nʼaka nri m maọbụ nʼaka ekpe m abụghị ihe dịrị m inye, kama ọnọdụ ndị a dịịrị ndị a kwadooro ha.”\wj* 
\p  
\v 41 Mgbe mmadụ iri ndị ọzọ nụrụ nke a, iwe jupụtara ha obi nʼihi Jemis na Jọn.  
\v 42 Ma Jisọs kpọkọtara ha niile sị ha, \wj “Dị ka unu onwe unu maara, ndị eze nke ndị mba ọzọ, na ndị a maara aha ha, na-eji aka ike na-achị ndị nọ nʼokpuru ha.\wj* 
\v 43 \wj Ma nʼetiti unu ọ gaghị adị otu a. Kama onye ọbụla chọrọ ịdị ukwuu nʼetiti unu ga-abụ onye na-ejere unu ozi.\wj* 
\v 44 \wj Onye ọbụla nke chọrọ ịbụ onye mbụ nʼetiti unu, ga-abụ ohu mmadụ niile.\wj* 
\v 45 \wj Nʼihi na Nwa nke Mmadụ abịaghị ka e jeere ya ozi. Kama ka o jee ozi ma nyekwa ndụ ya ka ọ bụrụ ihe mgbapụta nke ọtụtụ mmadụ.”\wj* 
\s1 Ọgwụgwọ Batimiọs onyeisi 
\p  
\v 46 Mgbe ha ruru Jeriko, dị ka Jisọs na ndị na-eso ụzọ ya na ọtụtụ igwe mmadụ sitere nʼobodo Jeriko na-apụ, otu nwoke kpuru ìsì aha ya bụ Batimiọs (aha ya pụtara “nwa nwoke Timiọs”), onye arịrịọ nọdụrụ ala nʼakụkụ ụzọ.  
\v 47 Mgbe ọ nụrụ na ọ bụ Jisọs onye Nazaret na-agafe, o bidoro iti mkpu na-asị, “Jisọs, nwa Devid, meere m ebere!” 
\p  
\v 48 Ọtụtụ mmadụ bara ya mba ka o mechie ọnụ. Ma ọ nọgidesịrị ike na-eti mkpu na-asị, “Nwa Devid, meere m ebere!” 
\p  
\v 49 Jisọs kwụsịrị kwuo sị, \wj “Kpọọnụ ya.”\wj* 
\p Ya mere ha kpọrọ onye ìsì ahụ, sị ya, “Mesaa ihu gị bilie nʼụkwụ gị, ọ na-akpọ gị.”  
\v 50 Ọ tufuru uwe mwụda ya, wulie nʼụkwụ ya, bịakwute Jisọs. 
\p  
\v 51 Jisọs sịrị ya, \wj “Gịnị ka ị chọrọ ka m meere gị?”\wj* 
\p Onye ìsì ahụ sịrị ya, “Onye ozizi m, achọrọ m ka m hụ ụzọ.” 
\p  
\v 52 Jisọs sịrị ya, \wj “Laa, okwukwe gị azọpụtala gị.”\wj* Nʼotu oge ahụ, o bidoro ịhụ ụzọ, sorokwa ya gawa nʼụzọ ahụ. 
\c 11  
\s1 Jisọs abaa Jerusalem 
\p  
\v 1 Mgbe ha na-abịaru Jerusalem nso, ha rutere Betfeji na Betani nʼUgwu Oliv. Jisọs zipụrụ mmadụ abụọ nʼime ndị na-eso ụzọ ya.  
\v 2 Ọ gwara ha sị, \wj “Gaanụ nʼime obodo nta dị nʼihu unu. Mgbe unu na-abanye nʼime ya, unu ga-ahụ nwa ịnyịnya e kedoro nʼebe ahụ nke onye ọbụla na-arịkwasịbeghị nʼelu ya. Tọpụnụ ya nʼagbụ, kpụtaranụ m ya.\wj* 
\v 3 \wj Ọ bụrụ na onye ọbụla asị unu, ‘Gịnị mere unu ji na-atọpụ ya nʼagbụ?’ sịnụ onye ahụ, ‘Ọ dị Onyenwe anyị mkpa, ọ ga-akpụghachitekwa ya ngwangwa.’ ”\wj* 
\p  
\v 4 Ha ruru ma hụ otu nwa ịnyịnya e kedoro nʼakụkụ ụzọ, nʼihu otu ụlọ nke dị nʼama. Dị ka ha na-atọpụ ya,  
\v 5 ụfọdụ mmadụ guzo nʼebe ahụ sịrị ha, “Gịnị ka unu na-eme, unu na-atọpụ nwa ịnyịnya a?”  
\v 6 Ha gwara ha ihe Jisọs kwuru, ha hapụkwara ha ka ha tọrọ ịnyịnya ibu ahụ.  
\v 7 Ha kpụtaara Jisọs nwa ịnyịnya ahụ, ma wụkwasịkwa uwe ha nʼelu ya, ọ nọkwasịrị nʼelu ya.  
\v 8 Ọtụtụ mmadụ tụsara uwe ha nʼokporoụzọ, ma ndị ọzọ tụsara alaka osisi ha gbutere nʼọhịa.  
\v 9 Ndị na-aga nʼihu na ndị na-esokwa nʼazụ, tiri mkpu na-asị, 
\q1 “Hozanna!”\f + \fr 11:9 \ft Okwu a Hozanna, pụtara Zọpụta nʼasụsụ Hibru, nke mechara ghọọ mkpu otuto.\f* 
\b  
\q1 “Onye a gọziri agọzi ka onye ahụ bụ nke na-abịa nʼaha Onyenwe anyị!”\f + \fr 11:9 \ft \xt Abụ 118:25,26\f* 
\b  
\q1  
\v 10 “Ngọzị dịrị alaeze ahụ na-abịa nke nna anyị Devid!” 
\b  
\q1 “Hozanna nʼebe kachasị ihe niile elu!” 
\p  
\v 11 Mgbe ọ batara na Jerusalem, ọ gara nʼime nʼụlọnsọ ukwu ahụ. Mgbe o legharịchara anya nʼihe niile dị nʼebe ahụ, ma ebe ọ bụ na chi ejiela, ya na ndị na-eso ụzọ ya pụrụ gaa Betani. 
\s1 Osisi fiig a bụrụ ọnụ 
\p  
\v 12 Nʼechi ya, mgbe ha si Betani na-apụta, agụụ gụrụ ya.  
\v 13 Site nʼebe dị anya, ọ hụrụ otu osisi fiig nke nwere akwụkwọ ndụ. Mgbe ọ bịaruru osisi ahụ nso, ọ gagharịrị nʼukwu ya niile ma ọ ga-achọta mkpụrụ nʼelu ya, ma ọ hụghị mkpụrụ ọbụla, naanị akwụkwọ ndụ, nʼihi na oge a abụghị oge osisi a ji amị mkpụrụ.  
\v 14 Mgbe ahụ, ọ gwara osisi ahụ sị, \wj “Ka mmadụ ọbụla ghara iri mkpụrụ sitere na gị ruo ebighị ebi.”\wj* Ndị na-eso ụzọ ya nụrụ mgbe o kwuru okwu a. 
\s1 Jisọs achụpụ ndị ahịa 
\p  
\v 15 Mgbe ha ruru Jerusalem, ọ banyere nʼime ụlọnsọ ukwu, bido ịchụpụ ndị na-azụ ahịa na ndị na-ere ahịa nʼebe ahụ. O kpugharịrị tebul ndị na-agbanwe ego, kwatuokwa oche niile nʼọdụ ahịa ndị na-ere nduru.  
\v 16 O gbochikwara onye ọbụla iwebata ngwongwo ahịa orire nʼime ụlọnsọ ukwu ahụ.  
\v 17 Ma dị ka ọ na-ezi ha ihe, ọ sịrị, \wj “Ọ bụ na-edeghị ya sị, Ụlọ m ka a ga-akpọ ụlọ ekpere nye mba niile\wj*\f + \fr 11:17 \ft \xt Aịz 56:7\f*\wj ? Ma unu emeela ya ọgba ndị na-apụnara mmadụ ihe nʼike.\wj*\f + \fr 11:17 \ft \xt Jer 7:11\f*\wj ”\wj* 
\p  
\v 18 Mgbe ndịisi nchụaja na ndị ozizi iwu nụrụ nke a, ha malitere na-achọ ụzọ igbu ya ma ha tụrụ egwu ya nʼihi na ozizi ya juru igwe mmadụ niile ahụ anya. 
\p  
\v 19 Mgbe uhuruchi bịara, Jisọs na ndị na-eso ụzọ ya siri nʼobodo ahụ pụọ. 
\s1 Osisi fiig ahụ a kpọnwụọ 
\p  
\v 20 Nʼisi ụtụtụ echi ya, mgbe ha na-agafe, ha hụrụ na osisi fiig a esitela na mgbọrọgwụ ya kpọnwụọ.  
\v 21 Pita chetara ihe merenụ ma sị ya, “Onye ozizi, lee! Osisi fiig ahụ ị bụrụ ọnụ akpọnwụọla!” 
\p  
\v 22 Jisọs zara ha sị, \wj “Nweenụ okwukwe nʼime Chineke.\wj* 
\v 23 \wj Nʼezie agwa m unu, ọ bụrụ na onye ọbụla asị ugwu a, ‘Si nʼebe a wezuga onwe gị, gaa dabanye nʼoke osimiri,’ nke na-enweghị obi abụọ nʼime ya, kama o kweere na ihe o kwuru ga-emezu, ihe ahụ ọ kwuru ga-emezukwa.\wj* 
\v 24 \wj Ya mere, ka m gwa unu, ihe ọbụla unu rịọrọ nʼekpere, kwerenụ na unu anatala ya, ọ ga-abụkwa nke unu.\wj* 
\v 25 \wj Ma mgbe ọbụla unu guzoro na-ekpe ekpere, gbagharanụ, ma ọ bụrụ na unu nwere ihe ọbụla megide onye ọbụla, ka Nna unu nke bi nʼeluigwe gbagharakwa unu mmehie unu.\wj* 
\v 26 \wj Ma ọ bụrụ na unu agbagharaghị, Nna unu nke bi nʼeluigwe agaghị agbagharakwa unu mmehie unu.”\wj*\f + \fr 11:26 \ft Ụfọdụ akwụkwọ na-edebanye okwu ndị a dịka ọ dị nʼakwụkwọ \xt Mat 6:15\ft .\f* 
\s1 Ajụjụ banyere ike Jisọs 
\p  
\v 27 Mgbe ha rutere Jerusalem ọzọ, ọ nọ na-ejegharị nʼime ogige ụlọnsọ ukwu ahụ, ndịisi nchụaja, na ndị ozizi iwu na ndị okenye ndị Juu bịakwutere ya.  
\v 28 Ha sịrị ya, “Olee ikike i ji eme ihe ndị a ị na-eme? Onye nyere gị ikike ime ha?” 
\p  
\v 29 Jisọs sịrị ha, \wj “Aga m ajụ unu otu ajụjụ, unu zaa m ya, aga m agwakwa unu onye nyere m ikike m ji eme ihe ndị a.\wj* 
\v 30 \wj Baptizim nke Jọn, o sitere nʼeluigwe ka ọ bụ nʼaka mmadụ? Gwanụ m.”\wj* 
\p  
\v 31 Ha kparịtara ụka nʼetiti onwe ha ma sị, “Ọ bụrụ na anyị asị, ‘O sitere nʼeluigwe,’ ọ ga-asị anyị, ‘Gịnị mere unu na-ejighị kwenye na ya?’  
\v 32 Ma ọ bụrụ na anyị asị, ‘O sitere nʼaka mmadụ.’ ” (Ha na-atụ egwu ndị mmadụ, nʼihi na ha niile kwenyere na Jọn bụ onye amụma nʼezie.) 
\p  
\v 33 Ya mere ha zara Jisọs sị, “Anyị amaghị.” 
\p Jisọs zaghachikwara ha sị, \wj “Agakwaghị m agwa unu ụdị ikike m ji na-eme ihe ndị a.”\wj* 
\c 12  
\s1 Ilu banyere ndị ọrụ ubi ọjọọ 
\p  
\v 1 Mgbe ahụ, ọ bidoro ịgwa ndị ahụ okwu nʼilu sị, \wj “Otu nwoke kụrụ mkpụrụ vaịnị nʼubi ya, jiri mgbidi gbaa ubi ahụ gburugburu. O gwuru ebe ịnara mmanya si na mkpụrụ vaịnị, wuokwa ụlọ elu. Mgbe o mesịrị, o nyefere ubi vaịnị ahụ nʼaka ndị ọrụ ubi ilekọta ya ma gaa obodo ọzọ.\wj* 
\v 2 \wj Mgbe oge ịghọ mkpụrụ ruru, o zipụrụ otu onye ohu ya ka o jekwuru ndị na-elekọta ubi ahụ, nata ha ụfọdụ nʼime mkpụrụ vaịnị ahụ.\wj* 
\v 3 \wj Ma ha jidere ya tie ya ihe, zilaga ya nʼaka efu.\wj* 
\v 4 \wj Emesịkwa, o zigakwara onye ohu ọzọ. Ma ha tiwara ya isi, mee ya ihe ihere.\wj* 
\v 5 \wj O zigakwara onye ọzọ, ma ha gburu ya. O zigakwara ọtụtụ ndị ozi, ma ha gburu ụfọdụ, tie ndị ọzọ ihe.\wj* 
\p  
\v 6 \wj “O nwere naanị otu onye ọzọ fọdụrụ nke ọ ga-eziga, nke bụ ọkpara ya ọ hụrụ nʼanya. Nʼikpeazụ o zigara ya, buru nʼuche na ha ga-asọpụrụ ọkpara ya.\wj* 
\p  
\v 7 \wj “Ma ndị na-elekọta ubi ahụ sịrịtara onwe ha, ‘Onye a bụ onye nketa ihe niile a. Bịanụ ka anyị gbuo ya, ka ihe nketa a bụrụzia nke anyị.’\wj* 
\v 8 \wj Ha jidere ya gbuo ya, tufee ozu ya nʼazụ mgbidi ubi vaịnị ahụ.\wj* 
\p  
\v 9 \wj “Gịnị ka unu chere onyenwe ubi vaịnị ahụ ga-eme? Ọ ga-abịa laa ndị ajọ mmadụ ahụ nʼiyi. Ọ ga-enyefekwa ubi vaịnị ahụ nʼaka ndị ọzọ.\wj* 
\v 10 \wj Ọ bụ na unu agụbeghị akwụkwọ nsọ a na-asị,\wj* 
\q1 \wj “ ‘Nkume ndị na-ewu ụlọ jụrụ\wj* 
\q2 \wj abụrụla nkume isi ntọala ụlọ.\wj* 
\q1  
\v 11 \wj Ọ bụ Onyenwe anyị rụrụ nke a,\wj* 
\q2 \wj ọ dịkwa ịtụnanya nʼanya anyị’\wj*\f + \fr 12:11 \ft \xt Abụ 118:22,23\f*\wj ?”\wj* 
\p  
\v 12 Mgbe ahụ ndịisi nchụaja, ndị nkuzi iwu na ndị okenye chọrọ ụzọ ha ga-esi jide ya nʼihi na ha matara na ilu ahụ ọ tụrụ megidere ha. Ma ha tụrụ egwu igwe ndị mmadụ ahụ, ya mere ha hapụrụ ya pụọ. 
\s1 Ịtụ ụtụ nye Siza 
\p  
\v 13 Emesịa, ha zigara ụfọdụ mmadụ site nʼotu ndị Farisii na ndị otu Herọd, ile ma ha ga-esite nʼokwu ọnụ ya jide ya.  
\v 14 Ha bịakwutere ya, sị ya, “Onye ozizi, anyị maara na ị bụ onye eziokwu, ị dịghị asọkwa onye ọbụla anya, nʼihi na ị dịghị ele mmadụ anya nʼihu nʼagbanyeghị ndị ha bụ, kama ị na-ezi ụzọ Chineke nʼụzọ eziokwu. O ziri ezi nʼiwu ịtụ ụtụ nye Siza\f + \fr 12:14 \ft Nke a bụ ụtụ a na-ekenye ndị na-abụghị diala obodo Rom ka ha kwụọ.\f* ka ọ bụ na o zighị ezi?  
\v 15 Anyị kwesiri ịkwụ ya ka ọ bụ anyị ekwesighị?” 
\p Ma ebe ọ maara ihu abụọ ha, ya mere ọ sịrị ha, \wj “Gịnị mere unu ji anwa m ọnwụnwa? Wetaranụ m otu mkpụrụ ego ka m lee ya anya.”\wj* 
\v 16 Ha wepụtara otu mkpụrụ ego, Ọ sịrị, \wj “Onye nwe onyinyo a? Aha onye ka e bikwasịrị nʼego a?”\wj* 
\p Ha zara sị, “Ọ bụ nke Siza.” 
\p  
\v 17 Mgbe ahụ Jisọs gwara ha sị, \wj “Nyenụ Siza ihe bụ nke ya, nyekwanụ Chineke ihe bụ nke ya.”\wj* 
\p Ọsịsa ya jụkwara ha anya. 
\s1 Ọlụlụ nwunye nʼoge mbilite nʼọnwụ 
\p  
\v 18 Ụfọdụ ndị Sadusii bụ ndị sịrị na mbilite nʼọnwụ adịghị bịakwutere ya jụọ ya sị,  
\v 19 “Onye ozizi, Mosis nyere anyị iwu na ọ bụrụ na nwoke ọbụla anwụọ na-amụtaghị nwa, na nwanne ya nwoke ga-alụrụ nwunye nwoke ahụ, mụta ụmụ nʼaha nwanne ya nwoke ahụ nwụrụ anwụ.  
\v 20 Ugbu a, e nwere ụmụnne nwoke asaa, nke mbụ lụrụ nwunye ma ọ nwụrụ na-amụtaghị ụmụ ọbụla.  
\v 21 Nke abụọ lụrụ nwanyị ahụ di ya nwụrụ, ma ya onwe ya nwụkwara na-amụtaghị nwa.  
\v 22 Ọ dịghị onye ọbụla nʼetiti ha asaa mụtara nwa ọbụla, nʼikpeazụ nwanyị ahụ nwụkwara.  
\v 23 Nʼoge mbilite nʼọnwụ, nwunye onye ka ọ ga-abụ, ebe ụmụnne asaa ndị a lụtụchara ya?” 
\p  
\v 24 Jisọs zara ha sị, \wj “Ọ bụ na unu adịghị ejehie ụzọ nʼihi na unu aghọtaghị ihe e dere nʼakwụkwọ nsọ, maọbụ ike Chineke?\wj* 
\v 25 \wj Mgbe ha ga-esite nʼọnwụ bilie, ọlụlụ di na nwunye agaghị a dị; kama ha ga-adị ka ndị mmụọ ozi nʼeluigwe.\wj* 
\v 26 \wj Ma nʼokwu banyere ndị nwụrụ anwụ isite nʼọnwụ bilie, ọ bụ na unu agụtabeghị nʼakwụkwọ Mosis ebe e dere maka ọhịa ahụ na-ere ọkụ, na otu Chineke si gwa ya, Abụ m Chineke Ebraham, Chineke nke Aịzik na Chineke nke Jekọb.\wj*\f + \fr 12:26 \ft \xt Ọpụ 3:6\f* 
\v 27 \wj Ọ bụghị Chineke nke ndị nwụrụ anwụ kama nke ndị dị ndụ. Nʼebe ahụ ka unu dahiere nke ukwuu.”\wj* 
\s1 Iwu kachasị mkpa 
\p  
\v 28 Otu nʼime ndị ozizi iwu bịara nʼoge ahụ ha na-arụrịta ụka. Mgbe ọ hụrụ na o nyere ha ezi ọsịsa, ọ jụrụ ya sị, “Nʼime iwu niile olee nke kachasị mkpa?” 
\p  
\v 29 Jisọs zara ya sị, \wj “Nke kachasị mkpa bụ nke a, ‘Nụrụ gị Izrel, Onyenwe anyị bụ Chineke anyị, Onyenwe anyị bụ otu.\wj* 
\v 30 \wj Were obi gị niile na mkpụrụobi gị niile na uche gị niile na ike gị niile hụ Onyenwe anyị bụ Chineke gị nʼanya.’\wj*\f + \fr 12:30 \ft \xt Dit 6:4,5\f* 
\v 31 \wj Nke abụọ ya bụ nke a, ‘Hụ onye agbataobi gị nʼanya dị ka onwe gị.’\wj*\f + \fr 12:31 \ft \xt Lev 19:18\f*\wj Ọ dịghị iwu ọzọ dị nke karịrị ndị a.”\wj* 
\p  
\v 32 Onye ode akwụkwọ ahụ sịrị ya, “Onye ozizi, nʼezie, ị zara nke ọma na Chineke bụ otu, na enweghịkwa chi ọzọ dị karịa ya.  
\v 33 Ịhụ ya nʼanya site nʼiji obi gị niile, na nghọta gị niile, nakwa iji ike gị niile, nʼịhụkwa onye agbataobi gị nʼanya dị ka onwe gị, kachasị onyinye aja nsure ọkụ na ịchụ aja niile.” 
\p  
\v 34 Mgbe Jisọs hụrụ na ọ zara nke ọma, ọ gwara ya sị, \wj “Ị nọ alaeze Chineke nso.”\wj* Site na mgbe ahụ ọ dịkwaghị onye ọbụla nwere obi ike ịjụ ya ajụjụ ọzọ. 
\s1 Kraịst ọ bụ nwa onye? 
\p  
\v 35 Mgbe Jisọs nọ na-ezi ihe nʼụlọnsọ, ọ kwuru sị, \wj “Gịnị mere ndị ozizi iwu ji sị na Kraịst bụ nwa Devid?\wj* 
\v 36 \wj Devid nʼonwe ya sitere nʼike Mmụọ Nsọ kwuo sị,\wj* 
\q1 \wj “ ‘Onyenwe anyị gwara Onyenwe m okwu sị,\wj* 
\q2 \wj “Nọdụ ala nʼaka nri m\wj* 
\q1 \wj ruo mgbe m ga-edebe ndị iro gị\wj* 
\q2 \wj nʼokpuru ụkwụ gị abụọ.” ’\wj*\f + \fr 12:36 \ft \xt Abụ 110:1\f* 
\m  
\v 37 \wj Devid nʼonwe ya kpọrọ ya Onyenwe anyị. Oleekwanụ ụzọ o si bụrụ nwa ya?”\wj* 
\p Igwe mmadụ ahụ jiri obi ụtọ na-ege ya ntị. 
\s1 Ịdọ aka na ntị banyere ndị ozizi iwu 
\p  
\v 38 Dịka ọ na-ezi ihe, ọ siri, \wj “Lezienụ anya nʼebe ndị ozizi iwu nọ.\wj*\f + \fr 12:38 \ft Ya bụ ndị Farisii\f*\wj Ndị iyi uwe mwụda na-ejegharị ebe niile na-amasị, na ịnara ekele pụrụ iche bụ nke a na-ekele ha nʼọma ahịa.\wj* 
\v 39 \wj Ndị ọ na-amasịkwa ịnọkwasị nʼoche kachasị elu nʼụlọ ekpere nakwa nʼoche pụrụ iche na mmemme oriri ọbụla.\wj* 
\v 40 \wj Ha na-eripịa ihe niile dị nʼụlọ ndị inyom ndị di ha nwụrụ anwụ, nʼekpe ogologo ekpere ka a hụta ha. Ndị dị otu a ka a ga-ata ahụhụ dị ukwuu.”\wj* 
\s1 Onyinye nwanyị di ya nwụrụ 
\p  
\v 41 Ọ nọdụrụ ala na ncherita ihu ebe igbe onyinye dị, sị ebe ahụ na-ahụ otu igwe mmadụ ahụ si etinye ego ha nʼime igbe onyinye. Ọtụtụ ndị ọgaranya tụnyere ego buru ibu.  
\v 42 Otu nwanyị bụ ogbenye, nke di ya nwụrụ anwụ, bịara tinye mkpụrụ ego ọla abụọ nke pụtara otu peni. 
\p  
\v 43 Ọ kpọrọ ndị na-eso ụzọ ya sị ha, \wj “Nʼezie agwa m unu, nwanyị a di ya nwụrụ anwụ, bụkwa ogbenye, etinyela ego nʼime igbe onyinye a karịa ndị ọzọ.\wj* 
\v 44 \wj Nʼihi na ndị ọzọ sitere nʼịba ụba nke ego ha nwere tinye, ma nwanyị a sitere nʼogbenye ya tinye ihe niile o nwere, ọ bụladị ihe niile o ji biri.”\wj* 
\c 13  
\s1 Amụma banyere mmebi nke ụlọnsọ ukwu 
\p  
\v 1 Mgbe o sitere nʼụlọnsọ ukwu ahụ na-apụ, otu nʼime ndị na-eso ụzọ ya siri ya, “Onye ozizi, ị hụkwara otu ụlọ a si maa mma. Lee ụdị nkume buru ibu e ji wuo ha.” 
\p  
\v 2 Jisọs zara ha, \wj “Ị hụrụ ụlọ ukwu ndị a? Oge na-abịa mgbe ọ na-adịghị nkume ga-atụkwasị nʼelu ibe ya, nʼihi na a ga-ala ha niile nʼiyi.”\wj* 
\p  
\v 3 Mgbe ọ nọdụrụ ala nʼelu Ugwu Oliv, na ncherita ihu ụlọnsọ ukwu, Pita na Jemis, na Jọn na Andru bịakwutere ya na nzuzo jụọ ya sị,  
\v 4 “Gwa anyị, olee mgbe ihe ndị a ga-emezu? Gịnị ga-abụkwa ihe ịrịbama izi na o ruola mgbe ha niile ga-emezu?” 
\s1 Mmalite nke ahụhụ 
\p  
\v 5 Jisọs malitere ịgwa ha sị, \wj “Lezienụ anya ka onye ọbụla ghara iduhie unu.\wj* 
\v 6 \wj Nʼihi na ọtụtụ ga-abịa nʼaha m sị, ‘Abụ m ya.’ Ha ga-eduhiekwa ọtụtụ ndị ụzọ.\wj* 
\v 7 \wj Mgbe unu nụrụ maka agha na akụkọ agha dị iche iche, unu atụla egwu. Ihe ndị a aghaghị ime ma oge ọgwụgwụ ihe niile erubeghị.\wj* 
\v 8 \wj Mba ga-ebili megide mba ibe ya. Alaeze ga-ebilikwa megide alaeze ibe ya. Ala ọma jijiji na ụnwụ ga-adị nʼebe dị iche iche. Ihe ndị a bụ mmalite nke oke ihe mgbu.\wj* 
\p  
\v 9 \wj “Unu aghaghị ịbụ ndị nọ na nche. A ga-enyefe unu nʼaka ndị na-achị achị, pịakwa unu ihe nʼụlọ ekpere. Nʼihi m, unu ga-eguzo nʼihu ndịisi ọchịchị na ndị eze dị ka ndị ama nye ha.\wj* 
\v 10 \wj Aghaghị ibu ụzọ kwusaa oziọma a nye mba niile.\wj* 
\v 11 \wj Ma mgbe ha jidere unu kpụta unu nʼụlọikpe, unu echegbula onwe unu banyere ihe unu ga-ekwu, kwuonụ naanị ihe batara unu nʼọnụ unu ikwu nʼoge ahụ. Nʼihi na ọ bụghị unu ga-ekwu okwu, kama ọ bụ Mmụọ Nsọ ga-esite nʼọnụ unu kwuo okwu.\wj* 
\p  
\v 12 \wj “Nwanne ga-arara nwanne ya nye ka e gbuo ya. Nna ga-ararakwa nwa ya nye. Ụmụ ga-ebili megide ndị mụrụ ha mee ka e gbuo ha.\wj* 
\v 13 \wj Mmadụ niile ga-akpọ unu asị nʼihi m, ma onye ga-eguzosi ike ruo ọgwụgwụ ka a ga-azọpụta.\wj* 
\p  
\v 14 \wj “Mgbe unu hụrụ ihe arụ nke na-eweta mbibi ka ọ na-eguzo nʼebe ọ na-ekwesighị\wj*\f + \fr 13:14 \ft \xt Dan 9:27; 11:31; 12:11\f*\wj (onye na-agụ ya nwee nghọta), mgbe ahụ, ka ndị nọ na Judịa were ọsọ gbalaga nʼelu ugwu\wj* 
\v 15 \wj Onye ọbụla nọ nʼelu ụlọ ya ghara ịrịdata maọbụ baa nʼime ụlọ ya iwepụta ihe ọbụla.\wj* 
\v 16 \wj Ka onye ọbụla nọ nʼubi ghara ịlọghachi ịchịrị uwe ya.\wj* 
\v 17 \wj Ma ahụhụ ga-adịrị ndị dị ime, na ndị na-enye ụmụaka ara, nʼụbọchị ahụ.\wj* 
\v 18 \wj Kpeenụ ekpere ka ihe ndị a hapụ ime nʼoge oke oyi.\wj* 
\v 19 \wj Nʼihi na oke mkpagbu nke ụbọchị ahụ ga-abụ nke na-adịbeghị na mbụ site na mgbe Chineke kere ụwa ruo ugbu a. Ọ dịkwaghị ihe ga-adịkwa ka ya ọzọ ruo mgbe ebighị ebi.\wj* 
\p  
\v 20 \wj “Ọ bụrụ na Onyenwe anyị emeghị ka ụbọchị ndị ahụ dị mkpụmkpụ, ọ dịghị onye a ga-azọpụta. Ma nʼihi ndị ya, ndị ọ họpụtara, o meela ka ụbọchị ndị ahụ dị mkpụmkpụ.\wj* 
\v 21 \wj Nʼoge ahụ, ọ bụrụ na onye ọbụla asị unu, ‘Lee, Kraịst nọ nʼebe a,’ maọbụ, ‘Lee, ọ nọ nʼebe ahụ,’ unu ekwela.\wj* 
\v 22 \wj Nʼihi na ndị nzọpụta ụgha na ndị amụma ụgha, ga-apụta ma rụọkwa ọrụ ebube na ọrụ ịrịbama dị iche iche iji duhie ndị a họpụtara ma ọ bụrụ na ọ ga-ekwe mee.\wj* 
\v 23 \wj Ya mere, unu nọrọ na nche; nʼihi na agwala m unu ihe niile mgbe ha na-emebeghị.\wj* 
\s1 Ọbịbịa Onye nke nzọpụta 
\p  
\v 24 \wj “Nʼụbọchị ndị ahụ, nke na-esote oge mkpagbu ahụ,\wj* 
\q1 \wj “ ‘anyanwụ ga-agba ọchịchịrị,\wj* 
\q2 \wj ọnwa agaghị enyekwa ìhè ya;\wj* 
\q1  
\v 25 \wj kpakpando ga-esi na mbara eluigwe na-ada,\wj* 
\q2 \wj ike niile dị na mbara eluigwe ga-amakwa jijiji.’\wj*\f + \fr 13:25 \ft \xt Aịz 13:10; 34:4\f* 
\p  
\v 26 \wj “Nʼoge ahụ, ha ga-ahụ Nwa nke Mmadụ, ka ọ na-abịa nʼigwe ojii nʼoke ike na ebube.\wj* 
\v 27 \wj Mgbe ahụ, ọ ga-ezipụ ndị mmụọ ozi ya ka ha kpokọta ndị a họpụtara site nʼakụkụ anọ niile nke ụwa. Site na nsọtụ niile nke ụwa ruo na nsọtụ niile nke eluigwe.\wj* 
\s1 Ihe mmụta site nʼosisi fiig 
\p  
\v 28 \wj “Ugbu a, mụtanụ ihe site nʼosisi fiig. Mgbe ọbụla alaka ya dị nro malite iwepụta akwụkwọ ndụ, unu maara na ọkọchị dị nso.\wj* 
\v 29 \wj Nʼụzọ dị otu a, mgbe unu hụrụ ihe ndị a niile ka ha bidoro ime, matanụ na ọ nọ nso, ọ nọkwa nʼọnụ ụzọ.\wj* 
\v 30 \wj Ana m agwa unu eziokwu na ọgbọ a agaghị agabiga tupu ihe ndị a niile emezuo.\wj* 
\v 31 \wj Eluigwe na ụwa ga-agabiga ma okwu m ga-adịgide.\wj* 
\s1 Mmadụ ọbụla amaghị oge ahụ 
\p  
\v 32 \wj “Ma banyere ụbọchị ahụ, maọbụ oge awa ahụ, o nweghị onye ọbụla maara, ọ bụladị ndị mmụọ ozi nke eluigwe, maọbụ Ọkpara ahụ, kama naanị Nna ahụ maara ya.\wj* 
\v 33 \wj Ebe ọ bụ na unu amaghị mgbe ha ga-emezu, nọrọnụ na nche! Mụrụkwanụ anya!\wj*\f + \fr 13:33 \ft Akwụkwọ ndị ochie na-edenye, na-ekpe ekpere.\f* 
\v 34 \wj Ọ dị ka nwoke hapụrụ ụlọ ya na-aga njem, tinye nʼaka ndị ohu ya ilekọta ihe, onye ọbụla nʼime ha ka o nyere ọrụ ọ ga-arụ ma nyekwa onye nche ọnụ ụzọ iwu ka ọ nọ na nche.\wj* 
\p  
\v 35 \wj “Ya mere nọrọnụ na nche, nʼihi na unu amaghị mgbe Onyenwe ụlọ ga-alọta. Ma ọ bụ nʼuhuruchi maọbụ nʼetiti abalị. Maọbụ mgbe ọkụkụ kwara akwa, maọbụ nʼisi ụtụtụ.\wj* 
\v 36 \wj Ọ bụrụ na ọ lọta na mberede, unu ekwela ka ọ lọkwute unu mgbe unu nọ nʼụra.\wj* 
\v 37 \wj Ihe m gwara unu ka m na-agwakwa mmadụ niile. ‘Nọrọnụ na nche.’ ”\wj* 
\c 14  
\s1 Otite mmanụ Jisọs na Betani 
\p  
\v 1 Abalị abụọ tupu e mee Mmemme Ngabiga\f + \fr 14:1 \ft Mmemme ndị Izrel ji echeta ọpụpụ ha site nʼala Ijipt.\f* na mmemme achịcha na-ekoghị eko, ndịisi nchụaja na ndị ozizi iwu nọkwa na-achọ ụzọ aghụghọ ha ga-esi jide Jisọs gbuo ya.  
\v 2 Ma ha kwuru sị, “Ọ gaghị abụ nʼoge mmemme a, ka ọgbaaghara ghara ịdị.” 
\p  
\v 3 Ka ọ nọdụrụ nʼoche nri na Betani nʼụlọ Saimọn onye ekpenta, otu nwanyị bu karama alabasta mmanụ otite dị oke ọnụahịa, nke e jiri ezigbo naad mee, batara. Ọ kụwara karama ahụ, wụsa ya mmanụ otite ahụ nʼisi. 
\p  
\v 4 Ụfọdụ ndị nọ nʼebe ahụ were iwe nke ukwuu. Ha sịrịtara onwe ha, “Gịnị mere e jiri laa mmanụ otite nke a nʼiyi otu a?  
\v 5 A gaara ere mmanụ otite a ihe karịrị narị denarị atọ, were ego e retara ya nye ndị ogbenye.” Ha baara ya mba nʼolu ike. 
\p  
\v 6 Ma Jisọs sịrị, \wj “Hapụnụ ya aka. Gịnị mere unu ji esogbu ya? Ọ bụ ezi ọrụ ka ọ rụrụ nʼebe m nọ.\wj* 
\v 7 \wj Unu na ndị ogbenye na-anọ oge niile, unu nwekwara ohere inyere ha aka mgbe ọbụla unu chọrọ. Ma mụ na unu agaghị anọ tee anya.\wj* 
\v 8 \wj O mere ihe o nwere ike, ọ na-ete m mmanụ otite a ugbu a iji kwado ahụ m maka olili a ga-eli ya.\wj* 
\v 9 \wj Nʼezie, ana m agwa unu, nʼebe ọbụla a ga-ekwusa oziọma a nʼụwa niile, ọrụ a ọ rụrụ ka a ga-akọkwa akụkọ ya, iji cheta ihe ọma a o mere.”\wj* 
\p  
\v 10 Mgbe ahụ Judas Iskarịọt, otu nʼime ndị ozi iri na abụọ ahụ jekwuuru ndịisi nchụaja ịgba izu otu ọ ga-esi rara ya nye ha nʼaka.  
\v 11 Mgbe ha nụrụ nke a, ha ṅụrịrị ọṅụ kwee ya nkwa inye ya ego. Site nʼụbọchị ahụ, o bidoro ịchọgharị ụzọ ọ ga-esi rara ya nye ha. 
\s1 Oriri Mmemme Ngabiga 
\p  
\v 12 Nʼụbọchị mbụ nke Mmemme achịcha na-ekoghị eko, mgbe ha na-achụ aja atụrụ ngabiga, ndị na-eso ụzọ ya bịakwutere ya sị ya, “Ebee ka ị chọrọ ka anyị gaa kwadoro gị ihe, maka oriri ngabiga?” 
\p  
\v 13 O zipụrụ mmadụ abụọ nʼime ndị na-eso ụzọ ya, sị ha, \wj “Gaanụ nʼime obodo, otu nwoke bu ite mmiri ga-ezute unu. Soronụ ya.\wj* 
\v 14 \wj Ebe ọbụla ọ banyere, sịnụ onyenwe ụlọ ahụ, Onye ozizi sịrị, Olee ụlọ ọbịa a kwadoro m, ebe mụ na ndị na-eso ụzọ m ga-anọ rie oriri ngabiga?\wj* 
\v 15 \wj Ọ ga-egosi unu otu ọnụụlọ buru ibu nʼelu ụlọ ahụ, ebe e dozichara ihe niile. Kwadoonụ ihe anyị nʼebe ahụ.”\wj* 
\p  
\v 16 Ndị na-eso ụzọ ya pụrụ baa nʼime obodo, ha hụrụ ihe niile dị ka ọ gwara ha. Ma kwadokwa nri ngabiga ahụ. 
\p  
\v 17 Mgbe o ruru uhuruchi, ya na ndị ozi ya iri na abụọ ahụ so bịa.  
\v 18 Mgbe ha nọ na-eri nri, Jisọs gwara ha sị, \wj “Nʼezie agwa m unu, otu onye nʼime unu ga-arara m nye. E, otu onye so m ugbu a na-eri nri!”\wj* 
\p  
\v 19 Ha bidoro inwe obi mwute, na-asị ya nʼotu nʼotu, “Ọ bụ m? Ọ bụ m?” 
\p  
\v 20 Ọ sịrị ha, \wj “Ọ bụ otu onye nʼime mmadụ iri na abụọ a. Onye mụ na ya na-amanyekọta aka nʼime otu efere.\wj* 
\v 21 \wj Nwa nke Mmadụ ga-ala dị ka e dere banyere ya. Ma ahụhụ ga-adịrị nwoke ahụ onye a ga-esite nʼaka ya rara Nwa nke Mmadụ nye. Ọ gaara akara onye ahụ mma ma a sị na a mụghị ya amụ.”\wj* 
\s1 Mmalite nke oriri nsọ 
\p  
\v 22 Dị ka ha na-eri nri, o weere achịcha, nye ekele, nyawa ya, nye ha sị, \wj “Rienụ ya, nke a bụ ahụ m.”\wj* 
\p  
\v 23 Mgbe ahụ, o buuru iko, nye ekele bunyekwa ha. Ha niile ṅụrụ site nʼotu iko ahụ. 
\p  
\v 24 Ọ sịrị ha, \wj “Nke a bụ ọbara m nke ọgbụgba ndụ ọhụrụ, nke a na-awụfu nʼihi ọtụtụ mmadụ.\wj* 
\v 25 \wj Nʼezie, nʼezie, agwa m unu, agaghị m aṅụ mmanya vaịnị ọzọ tutu ruo ụbọchị ahụ, mgbe m ga-aṅụ ya ọhụrụ nʼalaeze Chineke.”\wj* 
\p  
\v 26 Mgbe ha bụsịrị abụ, ha pụrụ gaa nʼUgwu Oliv. 
\s1 Jisọs ekwuo maka ngọnarị Pita 
\p  
\v 27 Jisọs sịrị ha, \wj “Unu niile ga-agbahapụ m, nʼihi na e dere ya otu a sị,\wj* 
\q1 \wj “ ‘Aga m etigbu onye ọzụzụ atụrụ,\wj* 
\q2 \wj igwe atụrụ ga-agbasasịkwa.’\wj*\f + \fr 14:27 \ft \xt Zek 13:7\f* 
\m  
\v 28 \wj Ma mgbe e mesịrị ka m si nʼọnwụ bilie, aga m ebu unu ụzọ gaa Galili.”\wj* 
\p  
\v 29 Pita kwuru, “Ọ bụrụ na mmadụ niile agbahapụ gị, agaghị m eme otu a.” 
\p  
\v 30 Jisọs sịrị ya, \wj “Ịgwa gị eziokwu, nʼụbọchị taa, nʼabalị taa, tupu oke ọkụkụ akwaa akwa ugboro abụọ, ị ga-agọnarị m ugboro atọ.”\wj* 
\p  
\v 31 O kwusịrị ike sị, “Ọ bụrụkwa na ihe ọnwụ adapụta, aga m eso gị nwụọ. Agaghị m agọnarị gị!” Ọ bụkwa otu ihe ahụ ka ha niile kwuru. 
\s1 Ekpere Jisọs nʼogige Getsameni 
\p  
\v 32 Ha pụrụ garuo ebe a na-akpọ Getsameni. Nʼebe ahụ, ọ sịrị ndị na-eso ụzọ ya, \wj “Nọdụnụ nʼebe a ka m gaa kpee ekpere.”\wj* 
\v 33 Ọ kpọọrọ Pita, na Jemis na Jọn tinyere onwe ya. Ọ malitere inwe ihe mwute dị ukwuu nakwa obi ịlọ mmiri.  
\v 34 Ọ sịrị ha, \wj “Ọ na-ewute mkpụrụobi m nke ukwuu ruo nʼọnụ ọnwụ. Nọdụnụ nʼebe a na-eche nche.”\wj* 
\p  
\v 35 Ọ gatụrụ nʼihu daa nʼala kpee ekpere, sị, ọ bụrụ na ọ ga-ekwe mee ka oge awa ahụ gabiga ya.  
\v 36 O kwuru sị, \tl \+wj “Abba,\+wj*\tl*\f + \fr 14:36 \ft Nke a pụtara nna nʼasụsụ Aramaik.\f*\wj Nna, ị pụrụ ime ihe niile. Napụ m iko a, ma otu ọ dị, ọ bụghị ka e mee uche m, kama ka e mee uche gị.”\wj* 
\p  
\v 37 Ọ bịara hụ ha ka ha na-arahụ ụra. Ọ sịrị Pita, \wj “Saimọn, ị na-arahụ ụra? Ọ bụ na ị nweghị ike iche nche otu awa?\wj* 
\v 38 \wj Nọrọnụ na nche, na-ekpekwanụ ekpere ka unu ghara ịdaba nʼọnwụnwa. Mmụọ dị ike ma anụ ahụ adịghị ike.”\wj* 
\p  
\v 39 Ọ pụkwara ọzọ, gaa kpee ekpere, na-ekwukwa otu okwu ahụ.  
\v 40 Mgbe ọ lọghachiri azụ ọ hụrụ na ha na-arahụ ụra, nʼihi na anya ha dị arọ nke ukwuu. Ha amakwaghị ihe ha ga-agwa ya. 
\p  
\v 41 Mgbe ọ lọghachiri nke ugboro atọ, ọ sịrị ha, \wj “Unu ka nọ na-arahụ ụra na-ezukwa ike? O zuola! Oge awa ahụ abịala. Lee, a rarala Nwa nke Mmadụ nye nʼaka ndị mmehie.\wj* 
\v 42 \wj Bilienụ! Ka anyị gawa! Lee, onye na-arara m nye nọ nso.”\wj* 
\s1 Njide e jidere Jisọs 
\p  
\v 43 Mgbe ọ ka kpụ okwu nʼọnụ, Judas, otu nʼime ndị ozi iri na abụọ ahụ batara, ya na igwe mmadụ, ndị ji mma agha na mkpọ. Ọ bụ ndịisi nchụaja, na ndị ozizi iwu, na ndị ode akwụkwọ, na ndị okenye ndị Juu zitere ha. 
\p  
\v 44 Ma onye na-arara ya nye, nyere ha rịị ihe ịrịbama sị, “Onye ahụ nke m ga-esutu ọnụ bụ ya; jidenụ ya, kpụrụnụ ya gawa, ma jidesiekwanụ ya ike.”  
\v 45 Ngwangwa o jekwuuru Jisọs, sị ya, “Onye ozizi!” ma sutukwa ya ọnụ.  
\v 46 Ndị ikom ahụ jidere Jisọs ma sekpụrụ ya nʼike.  
\v 47 Ma otu onye nʼime ndị guzo nʼebe ahụ, mịpụtara mma agha ya, gbuo ohu onyeisi nchụaja, gbupụ ntị ya. 
\p  
\v 48 Jisọs sịrị ha, \wj “Abụ m onyendu nke ndị na-enupu isi nke mere unu ji were mma agha na mkpọ bịa ijide m?\wj* 
\v 49 \wj Ụbọchị niile ka mụ na unu nọ mgbe m na-ezi ihe nʼụlọnsọ ukwu, ma unu ejideghị m. Ma ihe akwụkwọ nsọ kwuru aghaghị imezu.”\wj* 
\v 50 Mgbe ahụ, ha niile hapụrụ ya gbalaga. 
\p  
\v 51 Ọ dị otu nwokorobịa na-eso ya, ọ ji naanị akwa ọcha linin kpuchie onwe ya. Mgbe ha jidere ya,  
\v 52 ọ hapụụrụ ha akwa ọcha linin ya, gbara ọtọ gbalaga. 
\s1 Jisọs nʼihu ndị ikpe ndị Juu 
\p  
\v 53 Ha duuru Jisọs gakwuru onyeisi nchụaja, ha niile bụ ndịisi nchụaja, na ndị okenye na ndị ozizi iwu zukọrọ nʼebe ahụ.  
\v 54 Pita sooro ha, ma ọ nọ nʼebe dị anya. O sooro ha bata nʼobi onyeisi nchụaja. Nʼebe ahụ, o sooro ndị nche nọdụ ọdụ na-anya ọkụ. 
\p  
\v 55 Ndịisi nchụaja na ndịisi ikpe nʼụlọikpe ukwu\f + \fr 14:55 \ft Ha dị iri asaa nʼotu nʼọnụọgụgụ ma bụrụkwa ndị gbara site nʼafọ atọ nʼotu gaa nʼihu.\f* nọ na-achọ ama megide Jisọs, ka ha nwee ike gbuo ya. Ma ọ dịghị nke ha chọtara.  
\v 56 Ọtụtụ bịara gbaa ama ụgha megide ya, ma ama ha abụghị otu. 
\p  
\v 57 Mgbe ahụ ụfọdụ biliri gbaa ama ụgha megide ya, sị,  
\v 58 “Anyị nụrụ mgbe o kwuru sị, ‘Aga m akwatu ụlọnsọ ukwu a nke e ji aka wuo, nʼụbọchị atọ aga m ewukwa ụlọ ọzọ, nke a na-ejighị aka wuo.’ ”  
\v 59 Ọ bụladị na nke a, ama ha niile adakọtakwaghị nʼotu. 
\p  
\v 60 Mgbe ahụ, onyeisi nchụaja biliri ọtọ nʼihu ha, jụọ Jisọs ajụjụ sị, “Ọ bụ na ị nweghị ihe ọbụla ị ga-aza? Gịnị ka i nwere ikwu banyere ama ndị a a na-agba megide gị?”  
\v 61 Ma ọ gbakwara nkịtị, ọ zaghị ihe ọbụla. 
\p Ọzọkwa, onyeisi nchụaja jụrụ ya sị, “Ị bụ Kraịst, Ọkpara Onye a gọziri agọzi?” 
\p  
\v 62 Jisọs sịrị, \wj “Abụ m ya, unu ga-ahụkwa Nwa nke Mmadụ ka ọ na-anọdụ ala nʼaka nri nke Onye ji ike niile, na-abịakwa nʼigwe ojii nke eluigwe.”\wj* 
\p  
\v 63 Onyeisi nchụaja dọwara uwe ya kwuo sị, “Gịnị mere anyị ji achọ ndị akaebe ọzọ?  
\v 64 Unu anụla okwu nkwulu si ya nʼọnụ pụta! Gịnị bụ mkpebi unu?” 
\p Ha niile mara ya ikpe sị, “O kwesiri ka ọ nwụọ!”  
\v 65 Mgbe ahụ ụfọdụ bidoro ịgbụ ya ọnụ mmiri asọ, jiri akwa kechie ya anya, tiekwa ya aka na-asị, “Buo amụma!” Ndị nche kpụpụtara ya tiekwa ya ihe. 
\s1 Pita agọnarị Jisọs 
\p  
\v 66 Dịka Pita nọ nʼobi ahụ, otu nʼime ụmụ agbọghọ na-ejere onyeisi nchụaja ozi bịara nso ebe ọ nọ.  
\v 67 Mgbe ọ hụrụ Pita ka ọ na-anya ọkụ, o leziri ya anya nke ọma, sị, “Ị bụ otu nʼime ndị na-eso Jisọs onye Nazaret ahụ.” 
\p  
\v 68 Ma ọ gọrọ agọ sị, “Amaghị m, maọbụ ghọtakwa ihe ị na-ekwu.” Ma ọ pụrụ gaa nʼụzọ e si abata. Mgbe ahụ oke ọkụkụ kwara akwa. 
\p  
\v 69 Mgbe nwaagbọghọ ahụ hụrụ Pita ọzọ, o gosiri ya ndị ọzọ nọ nʼebe ahụ sị ha, “Nwoke a bụkwanụ otu nʼime ha.”  
\v 70 Ma ọ gọkwara agọ ọzọ. 
\p Mgbe oge nta gasịrị, ndị guzo Pita nso sịrị ya, “Nʼezie, ị bụ otu nʼime ha, nʼihi na ị bụ onye Galili.” 
\p  
\v 71 Mgbe ahụ o bidoro ịbụ onwe ya ọnụ, na ịṅụ iyi na-asị, “Amaghị m onye nwoke a unu na-ekwu okwu ya bụ.” 
\p  
\v 72 Nʼotu oge ahụ, oke ọkụkụ kwara akwa nke ugboro abụọ. Mgbe ahụ Pita chetara okwu Jisọs gwara ya sị, \wj “Tupu oke ọkụkụ akwaa akwa ugboro abụọ, ị ga-agọnarị m ugboro atọ.”\wj* Obi tiwara ya mee ka ọ kwaa akwa. 
\c 15  
\s1 Jisọs nʼihu Pailet 
\p  
\v 1 Nʼezigbo isi ụtụtụ, ndịisi nchụaja na ndị okenye na ndị ozizi iwu, na ndị nzukọ ndị okenye niile, nwere mkpebi. Ha kere Jisọs agbụ, duru ya nyefee nʼaka Pailet. 
\p  
\v 2 Pailet jụrụ ya sị, “Ị bụ eze ndị Juu?” 
\p Ọ zara sị ya, \wj “Gị onwe gị kwuru ya.”\wj* 
\p  
\v 3 Mgbe ahụ ndịisi nchụaja boro ya ebubo banyere ọtụtụ ihe.  
\v 4 Pailet jụrụ ya ajụjụ ọzọ sị, “Ọ bụ na ị nweghị ọsịsa ọbụla? Lee ọtụtụ ebubo ha na-ebo gị.” 
\p  
\v 5 Ma Jisọs azaghị ihe ọzọ. Nke a juru Pailet anya. 
\p  
\v 6 Ugbu a, ọ bụ omenaala nʼoge mmemme, na a ga-ahapụ otu onye mkpọrọ, bụ onye ha rịọrọ ka a hapụ.  
\v 7 Nʼoge ahụ kwa, otu nwoke a na-akpọ Barabas nọ nʼụlọ mkpọrọ, ya na ụfọdụ ndị biliri megide isi ọchịchị, ndị gbukwara mmadụ nʼoge ọgbaaghara ahụ.  
\v 8 Igwe mmadụ gbakọrọ na-arịọ Pailet ka o mezuoro ha omenaala ha. 
\p  
\v 9 Mgbe ahụ ọ jụrụ ha sị, “Unu chọrọ ka m hapụrụ unu eze ndị Juu?”  
\v 10 Ebe ọ maara na ọ bụ nʼihi ekworo ka ndịisi nchụaja ji nyefee Jisọs nʼaka ya.  
\v 11 Ma ndịisi nchụaja kpaliri igwe mmadụ ahụ ka ha kwagide ya ka ọ hapụrụ ha Barabas. 
\p  
\v 12 Pailet jụrụ ha ọzọ sị, “Gịnị ka m ga-eme nwoke a unu kpọrọ eze ndị Juu?” 
\p  
\v 13 Ma ha tiri mkpu ọzọ sị, “Kpọgide ya nʼobe!”\f + \fr 15:13 \ft Nʼụzọ dị otu a a jụrụ Jisọs Kraịst.\f* 
\p  
\v 14 Ma Pailet jụrụ ha sị, “Ọ bụ nʼihi gịnị? Olee ihe ọjọọ o mere?” 
\p Ma ha tiri mkpu karịa ka ha si eti na mbụ, na-asị, “Kpọgide ya nʼobe!” 
\p  
\v 15 Ma ebe Pailet chọrọ ime ihe ga-atọ igwe mmadụ ahụ ụtọ, ọ hapụụrụ ha Barabas, nyefee ha Jisọs nʼaka ka ha pịa ya ihe ma kpọgidekwa ya nʼobe. 
\s1 Ndị agha ejiri Jisọs mee ihe ọchị 
\p  
\v 16 Ndị agha ahụ duuru ya pụọ baa nʼime ụlọeze a na-akpọ Pritoriọm. Ha kpọkọtakwara ndị agha ndị otu ha ndị ọzọ.  
\v 17 Ha yinyere ya uwe mwụda na-acha odo odo, kpukwasịkwa ya okpueze nke e ji ogwu kpaa nʼisi.  
\v 18 Emesịa, ha malitere na-ekele ya sị, “Ekele, eze ndị Juu.”  
\v 19 Ha ji osisi kụọ ya nʼisi ọtụtụ mgbe, na-agbụ ya ọnụ mmiri asọ. Ha gbukwara ikpere nʼihu ya, na-akpọ isiala na-enye ya.  
\v 20 Mgbe ha ji ya mechaa ihe ọchị, ha yipụrụ ya uwe odo odo ahụ, yinyekwa ya uwe nke ya. Emesịa, ha duuru ya pụọ gawa ịkpọgide ya nʼobe. 
\s1 Mkpọgide Jisọs nʼobe 
\p  
\v 21 Ha zutere otu onye na-agata nʼụzọ, aha ya bụ Saimọn, onye Sirini, bụ nna Alegzanda na Rufọs. Ha manyere ya ka o buru obe ya.  
\v 22 Nʼikpeazụ, ha duuru Jisọs ruo ebe a na-akpọ Gọlgọta (nke pụtara “ebe okpokoro isi”).  
\v 23 Ha nyere ya mmanya a gwara máá, ma ọ jụrụ ịṅụ ya.  
\v 24 Emesịa, ha kpọgidere ya nʼobe, ma kee uwe ya nʼetiti onwe ha site nʼife nza onye ga-enwe nke ọ ga-ewe. 
\p  
\v 25 Ha kpọgidere ya nʼobe nʼelekere itoolu nke ụtụtụ.  
\v 26 Ha depụtara ebubo ha boro ya kwụba ya nʼelu obe ahụ, nke bụ: 
\pc Eze ndị Juu. 
\p  
\v 27 Ha kpọgidekwara ya na ndị ohi abụọ nʼobe, otu nʼaka nri ya, nke ọzọ nʼaka ekpe ya.  
\v 28 A gụkọtara ya na ndị na-emebi iwu.\f + \fr 15:28 \ft Ụfọdụ akwụkwọ na-edebanye okwu ndị a dịka ọ dị nʼakwụkwọ \xt Luk 22:37\ft .\f* 
\v 29 Ndị mmadụ si nʼebe ahụ gafee fufere isi ha na-ekwutọ ya, na-asị, “Leenụ gị! Onye ga-akwada ụlọnsọ ma wugharịa ya nʼabalị atọ.  
\v 30 Zọpụtanụ onwe gị! Si nʼelu obe ahụ rịdata.”  
\v 31 Ọ bụladị ndịisi nchụaja, na ndị ozizi iwu na ndị ode akwụkwọ nọ na-akwa ya emo nʼetiti onwe ha na-asị, “Ọ zọpụtara ndị ọzọ, ma ọ pụghị ịzọpụta onwe ya!  
\v 32 Ka Kraịst a, bụ Eze Izrel, si nʼelu obe a rịdata ka anyị hụ ma kwerekwa.” Ndị ahụ a kpọgidekọrọ ha na ya nʼobe nọkwa na-akparị ya. 
\s1 Ọnwụ Jisọs 
\p  
\v 33 Mgbe ọ kụrụ elekere iri na abụọ nke ehihie, ọchịchịrị gbachikọtara nʼala ahụ niile. Ọchịchịrị a dịgidere ruo nʼelekere atọ nke ehihie.  
\v 34 Nʼelekere atọ nke ehihie, Jisọs tiri mkpu akwa nʼoke olu sị, \tl \+wj “Elọi, Elọi, lama sabaktani!”\+wj*\tl* (nke pụtara, \wj “Chineke m, Chineke m, gịnị mere i jiri hapụ m?”\wj*).\f + \fr 15:34 \ft \xt Abụ 22:1\f* 
\p  
\v 35 Ma ụfọdụ ndị guzo nso nʼebe ahụ, mgbe ha nụrụ nke a, sịrị, “Lee, ọ na-akpọ Ịlaịja!” 
\p  
\v 36 Ya mere, otu onye gbaara ọsọ gaa weta ogbo, denye ya nʼime mmanya gbara ụka, fanye ya na okporo osisi, nye ya ka ọ ṅụọ, ma na-asị, “Hapụnụ ya, ka anyị lee ma Ịlaịja ọ ga-abịa tọtuo ya.” 
\p  
\v 37 Ma Jisọs tiri mkpu nʼolu ike, kubie ume. 
\p  
\v 38 Akwa mgbochi nke ụlọnsọ ukwu sitere nʼelu gbawaa abụọ ruo nʼọnụ ala ala ya.  
\v 39 Mgbe ọchịagha guzo nʼihu ya, hụrụ otu o si kubie ume, o kwuru sị, “Nʼezie, nwoke a bụ Ọkpara Chineke.” 
\p  
\v 40 O nwere ụfọdụ ụmụ nwanyị guzo nʼebe dị anya na-ele ihe na-eme, nʼetiti ha bụ Meri Magdalin, Meri nne Jemis nke nta, na Josef,\f + \fr 15:40 \ft Nʼasụsụ Griik \fqa Joses \ft bụkwa \fq Josef\fqa .\f* na Salomi.  
\v 41 Ndị a bụ ndị naara eso ya na-ejekwara ya ozi, mgbe ọ nọ na Galili. Ọ dịkwa ndị inyom ọzọ nọkwa nʼebe ahụ, bụ ndị sooro ya bịa na Jerusalem. 
\s1 Olili Jisọs 
\p  
\v 42 Nʼoge uhuruchi (ya bụ ụbọchị na-abọta ụbọchị izuike), ebe ọ bụ Ụbọchị Nkwadebe,  
\v 43 Josef onye Arimatia, otu nʼime ndị otu nʼụlọ nzukọ, onye a na-asọpụrụ, onye na-echere ọbịbịa nke alaeze Chineke, ji obi ike jekwuru Pailet rịọ ya ka o bunye ya ahụ Jisọs.  
\v 44 Ọ juru Pailet anya ịnụ na ọ nwụọla. Ọ kpọrọ ọchịagha ahụ jụọ ya ma ọ nwụọla.  
\v 45 Mgbe ọchịagha ahụ gwara ya na ọ nwụọla, o kwere ka Josef buru ahụ ya.  
\v 46 Josef zụtara akwa ọcha linin, wedata ahụ ya jiri akwa ahụ fụchie ya. O buuru ya buba ya nʼime ili nke o gwuru nʼime nkume. Emesịa o nuketara otu nkume buru ibu, jiri ya mechie ọnụ ụzọ ili ahụ.  
\v 47 Meri Magdalin na Meri nne Josef hụkwara ebe e bubara ahụ ya. 
\c 16  
\s1 Mbilite nʼọnwụ Jisọs 
\p  
\v 1 Mgbe ụbọchị izuike gafere, Meri Magdalin na Meri nne Jemis na Salomi zụtara ụda dị iche iche ha ga-eji tee ahụ ya mmanụ.  
\v 2 Nʼisi ụtụtụ ụbọchị mbụ nke izu, mgbe anyanwụ wara, ha biliri gawa nʼili ahụ.  
\v 3 Ha jụrịtara onwe ha na-asị, “Onye ga-enupuru anyị nkume ahụ dị nʼọnụ ụzọ ili ahụ?” 
\p  
\v 4 Ma mgbe ha leliri anya, ha hụrụ na e nupụla nkume ukwu ahụ.  
\v 5 Mgbe ha banyere nʼime ili ahụ, ha hụrụ otu nwokorobịa yi uwe ọcha ka ọ nọdụrụ ala nʼakụkụ aka nri nke ili ahụ. Ha tụrụ oke egwu. 
\p  
\v 6 Ma ọ sịrị ha, “Unu atụla egwu. Unu na-achọ Jisọs onye Nazaret a kpọgidere nʼobe. E meela ka o site nʼọnwụ bilie! Ọ nọkwaghị nʼebe a. Lee ebe e nibere ya.  
\v 7 Ma gaanụ gwa ndị na-eso ụzọ ya nakwa Pita, ‘O burula unu ụzọ gawa Galili. Ebe ahụ ka unu ga-ahụ ya dị ka ọ gwararịị unu.’ ” 
\p  
\v 8 Ha gbapụtara site nʼili ahụ, nʼọnọdụ mgbagwoju anya na ahụ ịma jijiji. Ha akọrọghị onye ọbụla ihe ọbụla, nʼihi na egwu jupụtara ha obi. 
\iex [Ọtụtụ akwụkwọ mbụ na ụfọdụ ndị mgbe ochie enweghị amaokwu itoolu ruo na nke iri abụọ 9–20.] 
\p  
\v 9 \it Mgbe Jisọs biliri nʼọnwụ nʼisi ụtụtụ nʼụbọchị mbụ nke izu, onye mbụ o gosiri onwe ya bụ Meri Magdalin, onye ahụ o siri nʼahụ ya chụpụ mmụọ ọjọọ asaa.\it* 
\v 10 \it Ọ lara gaa kọrọ ndị ya na ha na-anọ na mbụ, bụ ndị nọrịị na-ebe akwa ma na-erukwa ụjụ.\it* 
\v 11 \it Mgbe ha nụrụ na ọ dị ndụ, na ọ hụkwala ya, ha ekweghị.\it* 
\p  
\v 12 \it Mgbe ihe ndị a gasịrị, o gosiri mmadụ abụọ nʼime ha onwe ya nʼụdị ọzọ, mgbe ha na-abanye nʼime obodo.\it* 
\v 13 \it Ndị a laghachiri bịa kọọrọ ndị nke ọzọ ma ha ekwetakwaghị.\it* 
\p  
\v 14 \it Emesịa, Jisọs gosiri ndị na-eso ụzọ ya iri na otu ahụ onwe ya, mgbe ha nọkọrọ na-eri nri. Ọ baara ha mba nʼihi enweghị okwukwe ha nakwa mkpọchi obi ha, nʼihi na ha jụrụ ikwenye nʼihe ndị ọzọ hụrụ ya gwara ha mgbe e mesịrị ka ọ si nʼọnwụ bilite.\it* 
\p  
\v 15 \it Ọ gwara ha sị, \+wj “Gaanụ nʼime ụwa niile kwusaara ihe niile e kere eke oziọma.\+wj*\it* 
\v 16 \it \+wj Onye ọbụla kweerenụ na onye e mekwara baptizim ka a ga-azọpụta. Ma a ga-ama onye ọbụla na-ekwereghị ikpe.\+wj*\it* 
\v 17 \it \+wj Ihe ịrịbama ndị a ga-esokwa ndị kwerenụ. Site nʼaha m, ha ga-achụpụ mmụọ ọjọọ; kwuokwa okwu nʼasụsụ ọhụrụ dị iche iche.\+wj*\it* 
\v 18 \it \+wj Ha ga-eji aka ha abụọ atụtụlie agwọ, ṅụọkwa nsi ma ọ gaghị emerụ ha ahụ ma otu. Ha ga-ebikwasị ndị ọrịa aka, ahụ ga-adịkwa ha mma.”\+wj*\it* 
\p  
\v 19 \it Mgbe Onyenwe anyị Jisọs gwasịrị ha okwu ndị a, e weliri ya elu, baa nʼeluigwe, ebe ọ nọdụ ala nʼakụkụ aka nri Chineke.\it* 
\v 20 \it Ha pụrụ kwusaa oziọma nʼebe niile. Onyenwe anyị nọnyekwaara ha, mee ka okwu ya guzosie ike site nʼihe ịrịbama dị iche iche nke na-eso ya.\it*