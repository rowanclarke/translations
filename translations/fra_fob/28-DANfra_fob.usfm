\c 6
\p 
\v 1 Il plut \w à|strong="H4437"\w* \w Darius|strong="H1868"\w* d'établir sur \w le|strong="H6902"\w* \w royaume|strong="H4437"\w* cent vingt satrapes, \w qui|strong="H4437"\w* devaient être répartis dans tout \w le|strong="H6902"\w* \w royaume|strong="H4437"\w*,
\v 2 \w Et|strong="H6966"\w* au-dessus \w d|strong="H1768"\w*'eux trois ministres, \w au|strong="H5922"\w* nombre desquels était Daniel, \w afin|strong="H1768"\w* \w que|strong="H1768"\w* \w ces|strong="H3606"\w* \w satrapes|strong="H3606"\w* \w leur|strong="H5922"\w* \w rendissent|strong="H1934"\w* \w compte|strong="H5922"\w*, \w et|strong="H6966"\w* \w que|strong="H1768"\w* \w le|strong="H5922"\w* \w roi|strong="H6925"\w* \w ne|strong="H4437"\w* \w souffrît|strong="H1934"\w* \w aucun|strong="H3606"\w* dommage.
\v 3 Or \w Daniel|strong="H1841"\w* \w surpassait|strong="H1934"\w* \w les|strong="H4481"\w* ministres \w et|strong="H4430"\w* \w les|strong="H4481"\w* satrapes, parce \w qu|strong="H1768"\w*'\w il|strong="H4481"\w* \w y|strong="H4481"\w* \w avait|strong="H4430"\w* \w en|strong="H4430"\w* \w lui|strong="H4481"\w* \w un|strong="H1934"\w* esprit extraordinaire; \w et|strong="H4430"\w* \w le|strong="H4481"\w* \w roi|strong="H4430"\w* \w pensait|strong="H4430"\w* \w à|strong="H4481"\w* l'établir \w sur|strong="H3809"\w* tout \w le|strong="H4481"\w* royaume.
\v 4 \w Et|strong="H4430"\w* \w les|strong="H3606"\w* ministres \w et|strong="H4430"\w* \w les|strong="H3606"\w* \w satrapes|strong="H3606"\w* cherchaient \w une|strong="H1934"\w* \w occasion|strong="H6903"\w* \w d|strong="H1768"\w*'accuser \w Daniel|strong="H1841"\w*, \w au|strong="H5922"\w* \w sujet|strong="H5922"\w* \w des|strong="H4430"\w* \w affaires|strong="H3606"\w* \w du|strong="H5922"\w* \w royaume|strong="H4437"\w*; mais \w ils|strong="H4437"\w* \w ne|strong="H4430"\w* purent trouver \w aucune|strong="H3606"\w* \w occasion|strong="H6903"\w*, \w ni|strong="H3606"\w* \w aucune|strong="H3606"\w* malversation, car \w il|strong="H5922"\w* \w était|strong="H4430"\w* fidèle; \w et|strong="H4430"\w* \w il|strong="H5922"\w* \w ne|strong="H4430"\w* \w se|strong="H4430"\w* trouvait \w en|strong="H4430"\w* \w lui|strong="H5922"\w* \w ni|strong="H3606"\w* faute \w ni|strong="H3606"\w* malversation.
\v 5 \w Ces|strong="H3606"\w* \w hommes|strong="H3606"\w* dirent donc: \w Nous|strong="H5922"\w* \w ne|strong="H3809"\w* \w trouverons|strong="H7912"\w* \w point|strong="H3809"\w* \w d|strong="H1768"\w*'\w occasion|strong="H6903"\w* \w contre|strong="H5922"\w* \w ce|strong="H5922"\w* \w Daniel|strong="H1841"\w*, \w à|strong="H5922"\w* \w moins|strong="H5922"\w* \w que|strong="H1768"\w* \w nous|strong="H5922"\w* n'\w en|strong="H1934"\w* \w trouvions|strong="H7912"\w* \w contre|strong="H5922"\w* \w lui|strong="H5922"\w* \w dans|strong="H5922"\w* \w la|strong="H3606"\w* \w loi|strong="H5922"\w* \w de|strong="H5922"\w* \w son|strong="H5922"\w* \w Dieu|strong="H5922"\w*.
\v 6 Alors \w ces|strong="H1836"\w* ministres \w et|strong="H3809"\w* \w ces|strong="H1836"\w* \w satrapes|strong="H3606"\w* \w se|strong="H1841"\w* rendirent \w en|strong="H1768"\w* tumulte \w auprès|strong="H5922"\w* \w du|strong="H5922"\w* roi, \w et|strong="H3809"\w* \w lui|strong="H5922"\w* \w parlèrent|strong="H5922"\w* \w ainsi|strong="H1836"\w*: Roi Darius, vis éternellement!
\v 7 Tous \w les|strong="H5922"\w* \w chefs|strong="H5632"\w* \w du|strong="H5922"\w* royaume, \w les|strong="H5922"\w* préfets, \w les|strong="H5922"\w* satrapes, \w les|strong="H5922"\w* conseillers \w et|strong="H4430"\w* \w les|strong="H5922"\w* gouverneurs sont d'avis d'établir \w une|strong="H4430"\w* ordonnance \w royale|strong="H4430"\w* \w et|strong="H4430"\w* \w une|strong="H4430"\w* défense expresse, portant que quiconque adressera \w une|strong="H4430"\w* requête \w à|strong="H5922"\w* quelque \w dieu|strong="H5922"\w* ou \w à|strong="H5922"\w* quelque homme \w pendant|strong="H5922"\w* trente jours, excepté \w à|strong="H5922"\w* \w toi|strong="H5922"\w*, ô \w roi|strong="H4430"\w*! \w sera|strong="H4430"\w* \w jeté|strong="H4430"\w* \w dans|strong="H5922"\w* \w la|strong="H5922"\w* \w fosse|strong="H5922"\w* \w aux|strong="H5922"\w* lions.
\v 8 Maintenant, ô \w roi|strong="H4430"\w*! \w confirme|strong="H6966"\w* \w la|strong="H4481"\w* \w défense|strong="H4481"\w*, \w et|strong="H4430"\w* mets-la \w par|strong="H4481"\w* écrit, \w afin|strong="H1768"\w* \w qu|strong="H1768"\w*'\w il|strong="H4481"\w* n'\w y|strong="H4481"\w* \w soit|strong="H4430"\w* \w rien|strong="H1768"\w* changé, selon \w la|strong="H4481"\w* \w loi|strong="H1156"\w* \w des|strong="H4481"\w* \w Mèdes|strong="H4481"\w* \w et|strong="H4430"\w* \w des|strong="H4481"\w* Perses, \w qui|strong="H4437"\w* \w est|strong="H4437"\w* irrévocable.
\v 9 C'est pourquoi \w le|strong="H1768"\w* \w roi|strong="H4430"\w* \w Darius|strong="H4430"\w* \w écrivit|strong="H7560"\w* \w le|strong="H1768"\w* \w décret|strong="H3792"\w* \w et|strong="H4430"\w* \w la|strong="H1768"\w* défense.
\v 10 \w Et|strong="H4430"\w* quand Daniel eut appris \w que|strong="H3606"\w* \w le|strong="H3606"\w* \w décret|strong="H3792"\w* \w était|strong="H4430"\w* \w écrit|strong="H7560"\w*, \w il|strong="H4430"\w* entra \w dans|strong="H3606"\w* sa maison, \w et|strong="H4430"\w*, \w les|strong="H3606"\w* \w fenêtres|strong="H3606"\w* \w de|strong="H4430"\w* sa chambre étant ouvertes \w du|strong="H6903"\w* côté \w de|strong="H4430"\w* Jérusalem, \w il|strong="H4430"\w* \w se|strong="H4430"\w* \w mettait|strong="H4430"\w* trois fois \w le|strong="H3606"\w* jour \w à|strong="H4430"\w* genoux, \w et|strong="H4430"\w* \w il|strong="H4430"\w* priait \w et|strong="H4430"\w* \w il|strong="H4430"\w* célébrait son \w Dieu|strong="H3606"\w* \w comme|strong="H6903"\w* auparavant.
\v 11 Alors \w ces|strong="H1836"\w* \w hommes|strong="H3606"\w* accoururent \w en|strong="H1934"\w* tumulte, \w et|strong="H4481"\w* trouvèrent \w Daniel|strong="H1841"\w* priant \w et|strong="H4481"\w* faisant \w des|strong="H4481"\w* supplications \w à|strong="H5922"\w* \w son|strong="H5922"\w* \w Dieu|strong="H4481"\w*.
\v 12 Puis ils s'approchèrent \w du|strong="H6925"\w* \w roi|strong="H6925"\w*, \w et|strong="H1841"\w* \w lui|strong="H6925"\w* \w dirent|strong="H6925"\w* \w au|strong="H6925"\w* \w sujet|strong="H6925"\w* \w de|strong="H1841"\w* \w la|strong="H1156"\w* défense royale: N'as-tu pas rendu par écrit \w une|strong="H7912"\w* défense, portant \w que|strong="H7912"\w* tout \w homme|strong="H1400"\w* \w qui|strong="H1400"\w* \w adresserait|strong="H1156"\w* \w une|strong="H7912"\w* requête \w à|strong="H7912"\w* \w quelque|strong="H7912"\w* \w dieu|strong="H6925"\w* ou \w à|strong="H7912"\w* \w quelque|strong="H7912"\w* \w homme|strong="H1400"\w* pendant trente jours, excepté \w à|strong="H7912"\w* toi, ô \w roi|strong="H6925"\w*! serait jeté \w dans|strong="H7912"\w* \w la|strong="H1156"\w* fosse aux lions? \w Le|strong="H6925"\w* \w roi|strong="H6925"\w* répondit \w et|strong="H1841"\w* dit: \w La|strong="H1156"\w* chose est certaine, selon \w la|strong="H1156"\w* \w loi|strong="H1156"\w* \w des|strong="H6925"\w* \w Mèdes|strong="H6925"\w* \w et|strong="H1841"\w* \w des|strong="H6925"\w* Perses, \w qui|strong="H1400"\w* est irrévocable.
