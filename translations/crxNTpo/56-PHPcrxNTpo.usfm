\id PHP - Central Carrier NT -Canada 2011 (DBL -2013)
\h Philippi Whut'enne
\toc1 Paul Philippi Whut'enne Buts'ó K'eyanguz-i
\toc2 Philippi Whut'enne
\toc3 Php
\mt1 Paul Philippi Whut'enne Buts'ó K'eyanguz-i
\c 1
\s1 Paul Philippi whut'enne, hadih, ubulhni
\p 
\v 1 Wheni Paul 'ink'ez Timothy 'et Sizi Gri be 'ulhnane ts'inli. Nohni keyoh Philippi whut'enne mbene la Christ, Sizi ts'utni-un, 'en gha Yak'usda ooch'e'ne 'uht'oh, 'ink'ez mbene la huwunline 'ink'ez yula 'ut'enne cha, nohni ts'iyawh hadih nohdítni.
\p 
\v 2 Yak'usda neBá 'ink'ez Sizi Gri neMoodihti, 'en ts'un ye unzoo-i 'ink'ez be nedzi dizghel-i nohgha ínin'ai, 'i ts'iyawh nohbulh 'óot'e' nohba hukwa' nuszun.
\s1 Nohnaznih totsuk 'et huwa Yak'usda ts'un musi dusni
\p 
\v 3 Nohnaznih totsuk, 'et huwa Yak'usda ts'un musi dusni.
\p 
\v 4 Tenadusdli totsuk hoonúst'e' whe nohni ts'iyawh nohba tenadusdli.
\p 
\v 5 'Udechoo dzin 'ink'ez 'andit whuts'un ts'iyanne khuni unzoo-i be yasduk, 'et whe nohni cha sla 'uht'en.
\p 
\v 6 Njan 'et sba nawh lhe'hoot'oh, mbe la nohni nohbulh ndi 'ut'en unzoo-i whe' yudilh'en-un Sizi Gri oodzin de, 'et de lhaídutileh.
\p 
\v 7 Ts'ih'un 'uhoont'oh hukw'un'a huwun nuni nuszut. 'Inka sdzi yo 'unohusdzun. Nts'en'a dast'oh njan lhuztih tl'ool be whédust'i, 'et hoonts'i ndi khuni unzoo-i, 'i ba susyin 'ink'ez ts'iyanne t'ehontázin 'et 'alha' hoont'oh. 'Et whuz un'a nohni cha ye unzoo-i ts'iyawh lhundúniltsuk whe lhtats'úlya.
\p 
\v 8 Yak'usda nalh nohdusni, nts'en'a la Sizi Gri dudzi ndulcho-i be nek'etsi'-i, 'et whuz un'a si cha tube nohk'énisli.
\p 
\v 9 Ndiz un'a nohba tenadusdli, be t'éoonudzun-i, 'i be cha 'ink'ez ye whunih-i cha ts'iyawh 'i be, 'et whuz un'a be nek'ets'intsi'-i, 'et lhat-un lhk'uz te nohba whutáleh.
\p 
\v 10 'Et whuz un'a ndet la 'uk'enus hoonzoo-un, 'et t'ewhuntihzeh. 'Et huwa Christ oodzin whusahóolts'ut de, 'et de nohtsun hooloh 'ink'ez 'aw whe hoonli-unyaz nohk'éholts'it-un hootáloh.
\p 
\v 11 'Ink'ez Sizi Gri 'en gha 'ut'en ts'ih'un 'unt'oh-i, 'et whuz un'a ndutiht'elh. 'Et whuz un'a Yak'usda ba ts'odólhti' 'ink'ez 'on nus uzdólhti'.
\s1 Christ 'en ooghu yaduk
\p 
\v 12 Sulhutsinke sulh dahooja la, 'et whulagha ts'e 'on nus lhane dune ndi khuni unzoo-i huyoozílhts'ai suli'. 'Et t'ewhuntahzin hukwa' nuszun.
\p 
\v 13 'Et huwa lerwe ooyoh whucho, ndunne saldanne 'ink'ez 'onghohne, 'enne cha, 'et ts'iyanne t'ehoninzun Christ 'en gha lhuztih tl'ool be whédust'i lé'ust'oh.
\p 
\v 14 'Ink'ez mbene la neMoodihti be lhulhutsinke unline, 'enne ndi sluztih tl'ool 'i gha 'enne 'on nus 'ulcho-i be whélhoniljut Yak'usda ooghuni unzoo-i yahutilhduk ha.
\p 
\v 15 'Alha whulohne sghe hoolnih, 'ink'ez sondólhdah hukwa' hut'en. 'Et hoonts'i whulohne si sts'un budzi unzoo. 'Et whuz un'a Christ 'en ghu yahalhduk.
\p 
\v 16 Ndunne sghe 'oolnihne, dich'oh 'ahuninzun hukw'un'a, Christ 'en ghu yahulhduk. 'Aw ts'ih'un un'a iloh 'uhut'en. 'Ants'i 'adus'ai-un 'on nus sba hoontsi' huhoolhtselh hukwa' hut'en.
\p 
\v 17 'Et hoonts'i whulohne 'enne be nek'ets'intsi'-i, 'i be Christ 'en ghu yahalhduk. T'ehonínzun ndi khuni unzoo-i ba njan susyin, 'et hukwa 'asodilh'ai.
\p 
\v 18 'Et nts'en'a la yahalhduk 'et whunilhchoh sba 'ants'i 'uhoont'oh. Dich'oh duk'un'a tilah yahalhduk k'us khuni 'alha' 'unt'oh-i tilah 'uhutni. Christ 'en ghu yahalhduk 'et huwa hoonust'i'. 'Ink'ez 'et nduwhulyiz 'et whuz un'a za hoonúst'i'.
\s1 Ts'ukhuna-un, 'et Christ 'unt'oh
\p 
\v 19 Nohni ts'iyawh t'enohnuszun, mbene la sba tenadudline, 'ink'ez ndai la Sizi Gri ooyughi 'i be sla ewhudíja, 'et 'i be 'et huwa sla nahudutitnih.
\p 
\v 20 Ndet la hukwa tse hoosdli-un, 'et daooduzni nts'oh ne'ust'en, 'et hoonts'i 'aw hukwaya oosdle' ait'oh. 'Et k'us whutso da' ndast'en inle' la, 'et 'andit whuz un'a za 'utist'elh, 'et huwa 'aw hukwaya lhotisdleh. Khusna k'us dasusai 'et whuz un'a za be khusna-i, 'i be Christ 'et whe dústi'.
\p 
\v 21 Ndiz un'a sba nja duhoont'oh, 'awhuz khusna za 'ust'oh de, Christ, 'en za 'unt'oh. K'us dasúsai de, 'et de whuch'a hootásdoh.
\p 
\v 22 'Et 'awhuz khusna za 'ust'oh de, se' 'ut'en 'i mai le'tinelh. Nts'en'a 'utahaootisalh 'aw t'eoonuzúszun.
\p 
\v 23 'Et sba nawh 'uhooja njan 'et 'ants'i whulhetoh nenúzts'ut. Nts'e suba hoolhtus oole', 'et whuz un'a la 'oosneh. Ndo Christ bulh natisdalh hukwa' nuszun. 'Et 'uk'enus hootázoo' whe' hoont'oh.
\p 
\v 24 'Et hoonts'i dálhusal de, 'et 'on nus nohni nohba hootázoo'.
\p 
\v 25 'Et whuz un'a 'uk'enus soo' hoont'oh, 'et dulcho whe sba 'alha' hoont'oh. 'Et huwa t'eoonuszun dálhusal de, 'ink'ez njan za tisdalh 'ink'ez nohni ts'iyawh nohbulh za tist'elh. 'Et whuz un'a be nohba 'alha' hoont'oh-i 'on nus untiyeh, 'ink'ez 'on nus hootáht'e'. 'Et whuz un'a 'uwhutát'elh.
\p 
\v 26 'Et whuz un'a za nohghu nánusja de, 'et de si sgha lhk'uz te Sizi Gri dutálhti'.
\s1 Christ ba soo uznoot'i 'ink'ez 'en ba dzoh nuts'oozut
\p 
\v 27 Nts'oh dahooja hoonts'i, Christ ooghuni unzoo-i, nts'en'a la nohba hukwa' ninzun, whuz un'a za yun ka dúlhts'i. Khun nohbulh 'ust'oh de, k'us nohch'oh 'ust'oh de, ts'iyantsuk whe nohbulh údutasts'o nohyughi 'ink'ez nohzul bulh 'ilho za lé'unt'oh. 'Et whuz un'a za Sizi ba oohyin. Ndi khuni unzoo-i, 'et 'i be be 'alha' hoont'oh-i ts'ut'ih, 'et 'i be 'alhgoh 'ants'i 'ilho za lé'aht'oh 'et 'i be hukwa 'aht'en.
\p 
\v 28 'Ink'ez mbene la nohch'az ditnine, 'enne bube noolhjut junih. 'Et whuz un'a ndaht'oh de, 'et soo ts'et whucho whúbunulhtun, 'enne musai tilehne 'uhint'oh. 'Et hoonts'i nohni dujihne ahli. Yak'usda 'en nohba' hoonla.
\p 
\v 29 'Et Christ 'en ba nohtl'ahóolts'ut, 'aw nohba 'alha' 'unt'oh za iloh, ooba dzoh nahdeh-un cha.
\p 
\v 30 'Et huwa ndet la whe dzoh nusuzut-un, 'et whunulh'en 'ink'ez whudahts'o, 'et nohni cha whuz un'a za 'et ndaht'oh.
\c 2
\s1 Te'uzdudil'en whe 'alhgoh 'ilho za ts'oole'
\p 
\v 1 'Et huwa Christ 'en nohbulh 'unt'oh nohla' tinelh ha eh? Christ ye nohk'entsi'-i, 'i be eh k'enánohni'ah? Ndoni 'alhgoh eh nohbulh 'únt'oh? 'Ink'ez nohts'un únzoo eh? 'Ink'ez nohgha te'ninzun eh?
\p 
\v 2 'Et whuz un'a 'uhoont'oh, 'inka be hóonust'i'-i ts'iyawh lhadáhla. 'Et whuz un'a hukwa' nuhzun de, 'et noheni ts'iyawh 'alhgoh 'oot'e'. Be lhk'ehts'-i, 'i cha 'ilho za 'utit'elh. Nohzul bulh 'ilho sahli' le'ooht'e'. 'Et whe nts'en'a la daja nahzun, 'et 'ilhoghi za tileh.
\p 
\v 3 Nohnich'oh hukwa' nahzun te za ne'óoht'en junih. 'Ants'i yo údudulhdzun 'ink'ez 'uyoonne nohanus hinzoo noohzin.
\p 
\v 4 Khun nohnich'oh za khun nuni noohzut junih. 'Et k'us 'uyoonne cha bughu nuní nahzut bula tiht'elh ha.
\s1 Christ, Yak'usda unli, 'et hoonts'i te'dudil'en whe ndi yun k'ut inda'
\p 
\v 5 'Oh da' ndet la Christ, Sizi ts'utni-un, 'en howu nuni nuzut, nohni cha 'et za howu nuni noohdeh.
\q1 
\v 6 Yak'usda dant'oh, whuz un'a za 'unt'oh.
\q2 'Ink'ez Yak'usda yundult'oh whe 'unt'oh.
\q2 'Et hoonts'i dich'oh Yak'usda yulh hulhgha 'unt'oh-un 'aw whe lhé'dudilti'.
\q2 'Et huwa 'aw Yak'usda gho tiz'ai lhnízun.
\q1 
\v 7 'Et k'us ts'iyawh whuladitni whe be 'ulhnane dahint'oh la,
\q2 'et hóolhchoot, 'ink'ez dune dót'en suli'.
\q1 
\v 8 'Ink'ez dune dót'en whe hinilh'en
\q2 'ink'ez dich'oh ts'iyanne an yo 'unt'oh na'dudulhtsi.
\q2 Datítsah whuts'un duBá yuk'une' 'ut'en tulalhgus k'ut datítsah 'et hoonts'i.
\q1 
\v 9 Et huwa Yak'usda ts'iyantsuk whando whe yudálhti'
\q2 'ink'ez boozi' 'uk'enus hooncha hukw'un'a yoozi' whulhtsi.
\q1 
\v 10 'Et whuz un'a ndi Sizi boozi',
\q2 'i gha ts'iyanne dugwutsi be hits'un nudútalyalh whe' hoont'oh.
\q2 Yak'uz whut'enne 'ink'ez ndi yun k'ut whut'enne,
\q2 'ink'ez yun t'ah 'unt'ohne, 'enne cha ts'iyawh.
\q1 
\v 11 'Et ts'iyawh lhen yoo khuni be yalhdukne,
\q2 'enne ts'iyawh nja duwhúdutinelh,
\q2 Sizi Gri neMoodihti 'unt'oh.
\q2 'Et whuz un'a nduhútni, 'et whe Yak'usda neBá,
\q2 'en hidílhti' whe' hutni.
\s1 Be hoot'en-i nulene.
\p 
\v 12 'Et huwa ook'esi'ne nts'en'a daht'oh nohbulh 'ust'en inle' whe Yak'usda k'une' aht'en. 'Andit 'aho 'aw nohbulh lhe'ust'oh 'et hoonts'i 'on nus 'uk'une' 'ut'enne tihleh, 'et nohts'u hukwa' nuszun. 'Et huwa soo ts'ih'un un'a nohdusni, nts'en'a la dihjiz inle', 'et whénulhjut 'ink'ez nohyust'e dutlut, 'et whuz un'a lhadáhleh hukwa 'uht'en.
\p 
\v 13 Yak'usda 'en 'unoh'ulh'en. Ndai yuka' ninzun 'ink'ez nts'en'a hukwa' ninzun, 'oh te né'nohulh'en.
\p 
\v 14 Ts'iyantsuk whe lhdulhyoh 'udoohni' junih. 'Ink'ez khun te lhch'a holh'e' junih.
\p 
\v 15 Nohk'ehóotalts'ulh-un, 'et whuyit 'uht'oh 'ink'ez soo ts'ih'un ootsun hoolohne oohle', 'et whuz un'a Yak'usda buzkeh tihleh 'et whe 'aw nohk'e' holtsit ait'oh. Ndunne tank'us 'únt'ohne 'ink'ez lubeshi 'uk'enus ntsi'-i 'ooleh hukwa 'ut'enne, 'enne butoh 'ulhdzis be hoot'en-i k'un'a 'ooht'e'.
\p 
\v 16 Ndi khuni be ts'ukhuna-i, 'i za soo cho oohtun. 'Et whuz un'a Christ oodzin de, dalcho-i be hootást'e'. 'Oh de de, whusúntilhtun niz de ndet la hukwa 'ist'en-un 'ink'ez ndai la 'is'en-i, 'i ts'iyawh 'aw 'ants'et lhe'úst'el.
\p 
\v 17 'Et hoonts'i be nohba 'alha' hoont'oh-i, 'ink'ez Yak'usda ba 'aht'en-un, 'ohwhi 'ants'i Yak'usda gha t'aih-i le'unt'oh. 'I k'ut be khusna-i 'ants'i nadísjul le'ust'oh, 'et huwa hoonúst'i', 'ink'ez ts'iyawh nohbulh whúnusni.
\p 
\v 18 'Et huwun za nohni cha hoonáht'i' 'ink'ez sulh whunulhni.
\s1 Paul Timothy ghu yalhduk
\p 
\v 19 'Et Sizi neMoodihti 'en oot'aninustan whe Timothy 'aho nohts'un tis'alh. 'Et whusanája de, daht'oh la sudáni' de, 'et la hóst'e'.
\p 
\v 20 'Aw dune yundult'ohne hooloh. 'En la soo cho nohghole'.
\p 
\v 21 'Uyoonne ts'iyawh didutch'oh dude 'ut'en k'oh za hukwa hunuta, 'aw Sizi Gri be 'ut'en k'oh iloh.
\p 
\v 22 'Et hoonts'i Timothy nts'en'a la dune unli, nohni ts'iyawh t'eoonúhzun. Dune ooye' nts'en'a la dubá yula 'ut'en, 'et whuz un'a za 'ulhna k'un'a ndi khuni unzoo-i, 'i be lhla 'ít'en.
\p 
\v 23 'Et huwa 'et njan nts'en'a sulh daootanelh-un, 'et nawhus'ai de, 'aho tilah nohts'ún tóos'a'.
\p 
\v 24 'Et hoonts'i neMoodihti 'en oot'anínustan si cha 'aho nohts'u tisyalh nuszun.
\s1 Paul Epaphroditus yudálhti'
\p 
\v 25 'Et howu nuni nuszut, Epaphroditus 'en nohts'u tóos'a' huba' hoont'oh. 'En neulhutsin 'unt'oh. Sulh 'ut'en-un cha 'unt'oh 'ink'ez 'ilhoh salda ídli. 'Et nohni nohba khuni na'á-un cha unli. 'En 'unt'oh ndet hukwa' nuszun-un, 'et whunilhchoh whe sla 'ut'en.
\p 
\v 26 'Oh da' ndun bulh údahts'o nduda inle'. 'Et huwun oodzi únduda 'ink'ez nohni ts'iyawh nohk'éninli.
\p 
\v 27 'Ink'ez 'alha tube ndida'. 'Ankw'us dazsai, 'et hoonts'i Yak'usda yugha té'ninzin. 'Aw 'en za iloh, si cha sgha té'ninzun. 'Et huwa 'on 'un lhan'un te ts'odi lhúsdloh.
\p 
\v 28 'Et huwa 'aoodunih be nohts'u whes'a'. Ah'en de, 'et de la hóht'e'. 'Ink'ez la 'aw tube sdzi lhundoosdoh.
\p 
\v 29 'Inka neMoodihti 'en gha hoonáht'i' whe yoh danúlhtih. 'Et ndunt'ohne, ubudúlhti'.
\p 
\v 30 'Et Christ 'en be 'ut'en k'oh huwa, 'ut'en ooba lhai k'et, 'ankw'us dazsai. Dich'oh ye khuna-i, 'i hoonts'i ooba 'ants'i yint'oh. 'Et huwa ndet whe sla tihnelh inle', ndai la be sla lhe'áhnel-i, 'i ts'iyawh dich'oh be sla 'uja.
\c 3
\s1 Christ 'en za ba ts'oot'en
\p 
\v 1 Sulhutsinke njan 'et 'udek'ez-un 'uhoont'oh, 'et nohdusni. NeMoodihti 'en bulh ts'ónilhni! Ndai la nohts'ó k'esgus-i, 'i za 'unt'oh. 'Et hoonts'i sba 'ants'i hoonli, 'ink'ez bé dóohjih sih.
\p 
\v 2 Mbene la lhike dult'ohne buch'a huwahli. 'Ink'ez 'ut'en ntsi'-i 'ulh'enne, 'enne cha buch'a huwahli. 'Ink'ez mbene la yané'dudut'asne, 'enne cha buch'a huwahli.
\p 
\v 3 'Et wheni ts'ih'un un'a ts'ot'az 'et huwa. 'Ink'ez wheni Ndoni 'en be Yak'usda ts'un teni' uznilhdzun. 'Ink'ez Christ, Sizi ts'utni-un, 'en ba ts'odilhti'. 'Ink'ez neyust'e k'oh ts'e 'et 'aw whut'anílhts'unítan.
\p 
\v 4 'Et hoonts'i si cha hukwa' nuszun de, syust'e k'oh ts'e, 'et za whut'aninustan 'et hoonts'i hukwa lhe'núszun. Soo cho whunulh'en, 'et 'uyoonne cha duyust'e k'oh ts'e 'uhint'oh, 'et si 'on nus whuz un'a 'ust'oh.
\p 
\v 5 Whuzusdli whuts'un lhk'udit dzin 'et nts'en'a la ooka dune ts'inli k'ut nehoot'as, 'et ndusíhinla. Israel oots'u hainzut-un usdli. Benjamin bulh didowhne, 'enne 'ilhoghun 'ust'oh, 'ink'ez Hebrew bughuni k'oh ts'e 'uk'enus soo yasduk-un 'ust'oh. 'Ink'ez ndunne pharaseene, 'enne dahoont'oh whe Moses be 'udustl'us k'une' hut'en, 'et si cha bubulh didowh-un 'ust'oh.
\p 
\v 6 Soo tube cho hoolhtus whe 'ust'en. 'Ink'ez mbene la Yak'usda ba 'ilhunaoodulhne, 'enne dzoh nubusdeh inle'. 'Ink'ez nts'en'a la dune Moses be 'udustl'us be ts'ih'un 'unt'oh-un tileh de 'et huwa 'aw whe sk'ehóotalts'ulh-un hootáloh whe 'ust'oh.
\p 
\v 7 'Et hoonts'i ndóohoolcho whe 'on nus sba hoonzoo sutilhtselh inle', 'et Christ 'en ba 'ants'et 'íst'en whuzdli' 'et nawhus'ai.
\p 
\v 8 'Aw 'et za iloh 'uwhudusni, Christ, Sizi ts'utni-un, 'en sMoodihti dant'oh la t'ezninzun-un, 'et hooncha k'et 'aw uzdooni' ait'oh. 'Ink'ez ndet la dáhoont'oh ooghu t'eoonúszun-un sghu hóolhchoot-un, 'et whunilhchoh whuladisni. 'I ts'iyawh 'un tukat-i sba 'unli 'et huwa 'on nus Christ t'enooszeh ha.
\p 
\v 9 'Ink'ez 'en ooyudúsda. Ndi Moses be 'udustl'us, 'aw 'i gha ts'ih'un dune lhúsdloh inle'. 'Et k'us Christ sba 'alha' 'unt'oh 'et huwa ts'ih'un dune susdli'. Ndi be ts'ih'un un'a be dune ts'inli-i, be 'alha' hoont'oh-i, 'i be Yak'usda ts'u hawhúlts'uk.
\p 
\v 10 'Et Sizi Gri ' en soo cho t'entiszeh hukwa' nuszun. Ye ulhtus-i, 'i be dunaidilhti, 'ink'ez dahoont'oh whe dzoh nusuzut, 'et cha t'ewhuntiszeh. 'Et nts'en'a dazsai, si cha whuz un'a za 'utisnelh.
\p 
\v 11 'Et 'alha' hoont'oh, si cha yaidlanne toh ye dunadija-i, si cha uncha ndúsja.
\s1 Ndo whuz za hukwa' ts'oot'en
\p 
\v 12 'Awhuz 'aw whunilhchoh huba soo lhe'ust'oh. 'Ink'ez soo 'et lhadúlya-un susdli', 'aw howu yalhuzusduk. 'Et hoonts'i nust'i za 'ust'oh. Di ha Christ, Sizi ts'utni-un, 'en silhchoot, 'et whuz un'a si cha itáschulh.
\p 
\v 13 Sulhutsinke sich'oh 'awhuz hootáschulh lhnúszun, 'et hoonts'i 'ilhoghun huba za 'et ndust'en. Ndet la senghu hooskat-un, 'et 'aw howu nuní lhnuzuszut whe whunaoodíznoh. 'Ink'ez stso ts'e hoonli-i, 'i za óschoot hukwa 'ust'en.
\p 
\v 14 Ndai la Yak'usda Christ, Sizi ts'utni-un, ndo negha whúta'alh-un, 'et whuts'un za hukwa 'ust'en.
\p 
\v 15 'Et huwa mbene la lhadulyane, 'enne cha whuz un'a za nuni hunoodeh, 'ink'ez nohni 'uts'un un'a unahzun de, 'et hoonts'i ts'iyawh Yak'usda t'enohwhuntilhdzeh.
\p 
\v 16 'Et hoonts'i ndet la 'uda' neghá whults'ut-un, whuz un'a za nuts'óodilh 'ink'ez lhk'un'a za nuni uznoodeh.
\s1 'Awet ndi yun k'ut uzdilhts'i 'et hoonts'i yak'uz nekeyoh whe' hoont'oh
\p 
\v 17 Sulhutsinke sk'un'a aht'en. 'Ink'ez 'uyoonne si sk'un'a neMoodihti ba yinka dilhts'ine, 'enne cha bunulh'en. Wheni nek'oh ts'e 'ooht'e' ha 'uts'int'oh.
\p 
\v 18 'Et lhane 'aw whuz un'a yinka lhuwhudílts'ih. Lhat nohdásni'. Doo cha za snatsul too' hoonli whe nohdúsni, 'et ndunt'ohne, 'enne Christ ootulalhgus ch'az ditnine 'uhint'oh.
\p 
\v 19 'Et ndunne ooba 'alha lhe'hoot'ohne ninta' hutit'elh. Bubut 'i buba Yak'usda unli. Ndi yun k'ut yooya ts'iyawh hiyulh 'unt'oh 'ink'ez 'i za hiba whudílhti'. Ndi yun k'ut hoonli-i, 'i za ghu nuni hunudeh.
\p 
\v 20 Wheni 'et yak'uz nekeyoh whe' hoont'oh 'et huwa. 'Et whuts'un neulhyis-un nets'u tiyalh, 'et huba néznisdil. Sizi Gri neMoodihti, 'en 'unt'oh.
\p 
\v 21 'Ink'ez neyust'e tel'en-i, 'i duyust'e dizti'-i k'un'a 'unt'oh yutilhtselh. Ndai la ye ulhtus-i, 'i be ts'iyantsuk ook'une' whut'en, 'i be 'uyoo yust'e neba itilhtselh.
\c 4
\p 
\v 1 'Et huwa sulhutsinke ook'esi'ne nohk'énisli cha 'ust'oh. Nohni nohgha hoonúst'i', 'ink'ez nohni sba be whuch'a whundeh-i ahli. Ook'esi'ne, neMoodihti 'en ba soo cho núdulhya.
\p 
\v 2 Nohni ts'ekoo Euodia 'ink'ez Syntyche, nohts'u tedusdli, neMoodihti 'en be lhk'un'a za nuni nuhzut.
\s1 'Ilhoh za ts'oot'e', 'alhgoh ts'uhót'e', 'ink'ez tenazdoodli
\p 
\v 3 'Ink'ez nyun ts'ih'un sts'úditni-un inli, nts'u tedusdli, ndunne ts'ekoo, khuni unzoo-i be sla 'it'enne, 'enne bula 'oneh. Clement, 'en cha, 'ink'ez 'onghohne cha sla 'it'enne, 'enne ts'iyawh ndi 'udustl'us khunane buboozi' ook'usguz-i, 'i k'ut 'enne cha buboozi' 'uk'usguz.
\p 
\v 4 NeMoodihti 'ahoolhyiz 'en be whunúlhni! Doo cha za 'udusni, whunúlhni!
\p 
\v 5 Ts'iyanne dune soo ne'bulh'en. NeMoodihti whusanátidalh-un 'awet whenghoh 'úhoont'oh.
\p 
\v 6 Hoonli huwu ni oohle' junih! 'Et k'us ts'iyaitsuk ooba tenadahdli. 'Ink'ez tedahdlih, 'ink'ez musi dóhni'. Ndai la be ndunihzut-i, 'i ts'iyawh Yak'usda ts'un ooka' dahni.
\p 
\v 7 'Ink'ez Yak'usda be nedzi dizghel-i, hooncha k'et 'aw t'eznoozeh ait'oh. 'Et Christ, Sizi ts'utni-un, 'en be ndi be nedzi dizghel-i, 'i nohdzi yo 'ink'ez noheni yo cha 'et ts'iyawh yughu tileh.
\s1 Ts'iyawh ndet la nohba whudizti'-un, 'et za howu nuni nuhzut
\p 
\v 8 Sulhutsinke ndi khuni, 'i 'udek'ez-i 'únt'oh. Ndai la 'alha' 'unt'oh-i, ndai la k'us hóoncha-un, ndet la ts'ih'un 'uhoont'oh-un cha, di la ootsun hooloh-i, di la 'uzoo'-i, ndet la 'et nduhoont'oh-un hoonzoo whe howu yats'ulhduk, ndi ts'iyawh nohba whudizti'-un, 'et za howu nuni nahdeh.
\p 
\v 9 Ndet la si sgha whe hodilh'e'-un, 'ink'ez ndai sghuni ulhchoot-i, 'ink'ez whudáhts'o-un, 'ink'ez nohnalh 'ist'en-un, 'et cha, whuz un'a ne'ooht'en. 'Ink'ez Yak'usda be whúdizghel-un, 'en si nohbulh 'óot'e'.
\s1 Philippi whut'enne dahinzoo
\p 
\v 10 'Et sa' inle' whe doo cha za sghu nuní nahzut 'ink'ez 'ahoolhyiz snalhnih 'et hoonts'i whe sla' tiht'elh 'aw nohgha lhuwhulhtsit. 'Et huwa neMoodihti 'en be hoonúst'i'.
\p 
\v 11 'Aw be ndunusdzit-i, 'i ooghu yalhuzusduk. Nts'en'a la dast'oh, 'et hoonts'i hoonúst'i'. 'Et whuz un'a hodiz'e'.
\p 
\v 12 T'eoonuszun nts'en'a la hoonliyaz ezdunidzit, 'ink'ez lhai ust'i-un, 'et cha t'eoonuszun. 'Et huwa nts'oh dahoont'oh hoonts'i sye'últs'ilh-un, 'ink'ez unusdai-un cha, 'ink'ez 'usdlai-un cha, 'ink'ez 'endunisdzit-un, ts'iyawh t'eoonuszun.
\p 
\v 13 Christ 'en 'uja be stus-i sgha nín'ai. 'En be ts'iyantsuk 'uwhus'en.
\p 
\v 14 'Et hoonts'i dzoh nusúszut-un huwa, 'et hoonzoo whe 'ahja sla 'iht'en.
\p 
\v 15 Philippi whut'enne, nohni za sla 'áhja. 'Udechoo khuni unzoo-i be yawhenusduk whe, 'ink'ez hukw'elh'az yun k'ut Macedonia howu natísja whe, ndunne Yak'usda ba 'ilhunaoodulhne ts'iyawh, 'aw 'ilhoghun hoonts'i hoonliyaz sgha lhi'al. Nohni za 'et ndúsahla.
\p 
\v 16 Keyoh Thessalonica 'et susda whe, ndai lhúst'i inle', nat lhk'elh'az stso tl'a'ih'ai.
\p 
\v 17 'Aw hoonliyaz sgha' tih'alh-un, 'et hukw'úlhnuzust'oh. Nus de nohba 'uk'elha tileh-i, 'i za nohba ooka' nuszun.
\p 
\v 18 'Alha ts'iyai lhai ust'i. Epaphroditus 'en be ndai la stso tl'ahla-i, 'i ts'iyawh úschoot, 'ink'ez 'unísdai. Sooltsun-i, 'i ndulcho whe oonawhultsun leúnt'oh. 'I huwa t'aih-i 'unt'oh. 'Et huwa Yak'usda tube cho hoont'i'.
\p 
\v 19 'Ink'ez Christ, Sizi ts'utni-un, ye dizti'-i, 'i gha sYak'usda ndai la be ndunihdzit-i, ts'iyawh nohgha ítalelh.
\p 
\v 20 'Et neYak'usda 'ink'ez neBá, 'en ts'un 'ilhiz wheni tube cho uzdílhti'. 'Et ndo honeh.
\s1 Ts'iyanne Yak'usda ooch'e'ne, 'enne ts'iyawh hadih budohni
\p 
\v 21 Mbene la Christ, Sizi ts'utni-un, 'en be Yak'usda ooch'e'ne, 'enne ts'iyawh hadih sba budohni. 'Et mbene la sulhutsinke szih dilhts'ine, 'enne cha hadih nohuhútni.
\p 
\v 22 'Ink'ez Yak'usda ooch'e'ne njan dilhts'ine, 'enne ts'iyawh hadih nohuwhutni. Mbene la Ceasar ooyoh dilhts'ine, 'enne soo hadih hutni.
\p 
\v 23 NeMoodihti Sizi Gri ye unzoo-i, nohni ts'iyawh nohbulh 'oot'e'. 'Et ndo honeh.
