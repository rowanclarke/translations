\ms1 Paul's defense of his apostolic authority
\s1 Weapons of spiritual warfare
\m 
\v 1 \w Now|strong="G1161"\w* \w I|strong="G1473"\w*, \w Paul|strong="G3972"\w*, \w am|strong="G1473"\w* \w myself|strong="G1473"\w* \w appealing|strong="G3870"\w* \w to|strong="G1519"\w* \w you|strong="G5210"\w* \w by|strong="G1223"\w* \w the|strong="G1722"\w* \w meekness|strong="G4240"\w* \w and|strong="G2532"\w* \w gentleness|strong="G4240"\w* \w of|strong="G1223"\w* \w Christ|strong="G5547"\w* (\w I|strong="G1473"\w* \w who|strong="G3739"\w* \w am|strong="G1473"\w* ‘\w humble|strong="G5011"\w* \w when|strong="G1161"\w* \w present|strong="G2596"\w*’ \w among|strong="G1722"\w* \w you|strong="G5210"\w*, \w but|strong="G1161"\w* ‘\w bold|strong="G2292"\w* \w when|strong="G1161"\w* absent’ \w toward|strong="G1519"\w* \w you|strong="G5210"\w*).
