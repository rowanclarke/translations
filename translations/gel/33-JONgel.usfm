\id JON - Fakai Translation
\h Yunana
\toc1 Ran-u Yunana
\toc2 Yunana
\toc3 Yuna
\mt2 Ran-u
\mt1 Yunana
\c 1
\s1 Yunana so̱mo̱g du̱gu̱-du̱ Yawe
\p 
\v 1 Rem-u̱s Yawe haagu̱n u̱du̱ Yunana wa'-u̱ Amitai.
\v 2 <<Yu̱ne̱ bo̱ do̱'e̱ u̱ Neneba bo̱-u yat-o̱, bo̱ waru̱ u̱n rem-u̱s ri, remu̱ no̱m-u̱t yo̱-to̱ u̱n teegu̱n u̱du̱ ri.>>
\p 
\v 3 Se̱di Yunana gu̱gu̱m. Wa som u̱ irig m-ha bo̱-u yat-o̱ u̱ na foge̱ Jopa tu̱msu̱ wa top shik, se̱ wa irig u̱-me̱ hat-u yat-ya m-ha bo̱-u̱ Tarshis. Wa aru̱k remu̱ u̱zu̱ wa o̱o̱g u̱ssa wa so̱m du̱gu̱-du̱ Yawe.
\p 
\v 4 U̱n o̱ te̱k u̱r-no̱k, Yawe to̱ko̱n mya-mu̱ u̱r-be̱b u̱-me̱ m-sa, hat-yu̱ u̱t-sa u̱t-u̱ku̱s.
\v 5 A-nak-du̱ hat-u yat-ya hog u-gye̱r sok. Ko̱wan hu̱ ko̱n-du̱ ru̱-u wa. U̱n guns cwu̱-u̱t u̱n u̱-me̱ m-sa remu̱ hab-du̱ m-no hat-u yat-ya.
\p Se̱di Yunana o̱ u̱-me̱ dak-u̱ hat-u yat-ya wa roog-mu̱ ho̱o̱g wa.
\v 6 Da-u o̱ yu̱-Yat-ya yu̱ hat-u yat-ya haan u̱du̱ Yunana wa zu̱, <<¿Remu̱ yan-o̱ bo̱ o̱tte̱ m-roog? Yu̱ne̱! Bo̱ ko̱n ru̱-u ró, ko wa ho̱gu̱ o̱n-u̱r in, wa u̱ku̱r in du̱gu̱ m-mar.>>
\p 
\v 7 Ku̱na a-nak-du̱ hat-u yat-ya ne̱ zu̱tte̱, <<Haanu̱n, in gunu̱n u-gwe̱mbi remu̱ na nu̱pu̱t wa-u̱t-ba'as.>> U̱ da-u o̱ u̱n nom u-gwe̱mbi, u̱n nu̱p u̱zu̱ Yunana wa, wa-u̱t-ba'as.
\v 8 U̱n zu̱ wu̱n, <<U̱ da-o̱ waru̱ it. ¿Yan-o̱ bo̱ no̱me̱ na o̱tte̱ swadu̱ u̱r-ko̱b? ¿Yan-o̱ o̱ ank-m ró? ¿He̱ne̱ bo̱ rwu̱tu̱n ne̱? ¿Yan-o̱ dim-du̱ bo̱-u̱ bo̱ rwu̱tu̱n? ¿Yan ko̱-de̱ bo̱ rwu̱tu̱n?>>
\p 
\v 9 Yunana zu̱ u̱n, <<Me̱ ne̱t-u̱ Isra wa, tu̱msu̱ me̱ wa doru̱ Yawe wa, Ru̱-u̱ do̱m u-ru̱, wu̱ no̱me̱ m-sa u-dak ne̱.>>
\p 
\v 10 Tu̱msu̱ wa waru̱ u̱n, u̱zu̱ wa o̱ u̱ so̱m-du̱ Yawe. Da-u o̱ gye̱r-u̱ ship ne̱t-u̱t to̱, u̱n zu̱ wu̱n, <<¿Remu̱ yan-o̱ bo̱ nomte̱ iya?>>\f + \fr 1:10\ft Ye̱so̱ shu̱ku̱t iyane̱ \xt Mati 12:40\xt*\ft .\f*
\v 11 Yu̱-u̱ m-mya u̱-me̱ m-sa sur u̱r-be̱b sok, u̱n zu̱ wu̱n, <<¿Yan-o̱ it do̱'e̱ no̱mu̱ bo̱ u̱ yu̱-u̱ m-mya yakte̱ no̱mu̱ in u-gwu̱z?>>
\p 
\v 12 Yunana zu̱ u̱n, <<U̱m nak yu̱-u̱ m-mya haagu̱n u̱-do̱mu̱ no̱ u̱ remu̱ ba'as-u̱t ri. Kabu̱n me̱ no̱ guns me̱ u̱-me̱ m-sa ko̱-uyan o̱ u̱t-re̱s.>>
\p 
\v 13 Se̱di u̱n waste̱ u̱ rem-u̱s Yunana ne̱ da. A-nak-du̱ hat-u yat-ya ne̱ hu̱ mat-du̱ u̱s-hund e̱ teet kit m-sa, remu̱ be̱b-du̱ m-mya re u-shu̱ m-swu̱r u̱n kerge̱ da.
\v 14 U̱n nom u̱s-kan u̱du̱ Yawe, u̱n zu̱, <<Yawe u-Ru̱, it ko̱no̱g bo̱, a-bo̱ yage̱ it mar remu̱ kab-du̱ fat-du̱ ne̱t unwa da. Yawe u-Ru̱, a-bo̱ ship it a-u̱t-ba'as remu̱ kab-du̱ fat-du̱ wa-za-u̱t-ba'as unwa da. Se̱di no̱m no̱m-u̱ citu̱ bo̱.>>
\v 15 U̱n ku̱b Yunana, u̱n guns wa u̱-me̱ m-sa. Da-u̱ u̱n gu̱nse̱ Yunana, yu̱-u̱ m-mya res te̱k.
\v 16 Da-u o̱, ne̱t-tu̱ hog gye̱r-u̱ Yawe sok. U̱n no̱m este̱du̱ u̱s-rem u̱du̱ Yawe, tu̱msu̱ u̱n nom u̱r-to̱o̱g u̱du̱ wa.
\p 
\v 17 Da-u̱ u̱n gunse̱ Yunana m-sa, Yawe to̱mo̱n jan-u yat-ya, ya toros Yunana. Yunana shu̱'u̱t u̱-me̱ me̱n-tu̱ u-jan u̱t-ho̱ u̱t-tu̱t.
\c 2
\s1 To̱o̱g-u̱s Yunana u̱du̱ u-Ru̱
\p 
\v 1 Da-u̱ wa o̱o̱ge̱ u̱-me̱ me̱n-tu̱ u-jan, Yunana no̱ng u̱s-to̱o̱g u̱du̱ Yawe u-Ru̱.
\v 2 Wa zu̱,
\q1 <<U̱m fak Yawe u̱ te̱k-u̱
\q2 swadu̱ u̱r-ko̱b u̱ ri,
\q1 tu̱msu̱ wa shu̱s to̱o̱g-u̱s ri.
\q2 U̱-me̱ be-du̱ u̱r-shu̱'u̱t
\q2 du̱ marimari ne̱,
\q1 tu̱msu̱ bo̱ hog ko̱n-u̱s ri.
\q1 
\v 3 Bo̱ gwu̱nu̱g me̱ u̱-me̱ m-bu̱ mu̱ u̱r-ra,
\q2 u̱ te̱k-u̱ dak-u̱ m-sa.
\q1 U̱m o̱ u̱-me̱ m-bu̱,
\q2 tu̱msu̱ jwak m-bu̱, re̱e̱g be̱b-u̱r ri.
\q1 
\v 4 U̱m zu̱u̱g, <Ko̱ bo̱ hastu̱ me̱ du̱gu̱-du̱ ró,
\q2 ko ba shu̱'u̱te̱ iya,
\q1 me̱ u̱t-sur m-hyan
\q2 pyu̱-u̱ u-he̱n u̱ ró.>
\q1 
\v 5 Bu̱-mu̱ re̱e̱g me̱ u̱r-hi,
\q2 bu̱-mu̱ m-sa taku̱ste̱ me̱ u-be̱e̱t.
\q1 Gwa-su̱ me̱ m-sa
\q2 taku̱ste̱ hi-u̱r ri.\f + \fr 2:5 \ft Gwa-tu̱ apne̱ u̱-me̱ m-sa.\f*
\q1 
\v 6 U̱m yi'iste̱ u̱-ta
\q2 m-sa m-te u̱ be-du̱ u̱t-ta'ar.
\q1 U̱m o̱ u̱-me̱ be-du̱ marimari ne̱.
\q2 Yawe, u-Ru̱ u̱ ri,
\q1 bo̱ wa ruutu̱ me̱ u̱-me̱ u-kub.
\b
\q1 
\v 7 <<Yawe, da-u̱ u̱m ho̱ge̱ fat-u̱r ri
\q2 o̱ m-rwu̱;
\q1 tu̱msu̱ u̱m nom u̱s-to̱o̱g u̱du̱ ró,
\q2 Tu̱msu̱ bo̱ hog ko̱n-u̱s ri
\q1 u̱-me̱ be-du̱ u-he̱n u̱ ró.
\b
\q1 
\v 8 <<Ne̱t-tu̱ o̱o̱ge̱ no̱m-du̱ u̱t-huuk m-gir,
\q2 e̱ gu̱gu̱mte̱ o̱n-du̱ u̱
\q2 cwan-tu̱ u-Ru̱ ne̱.
\q1 
\v 9 Se̱di me̱, u̱ nu-u̱ u̱t-vam.
\q2 U̱m de̱ no̱m-du̱ to̱o̱g u̱du̱ ró.
\q1 Me̱ shu̱su̱ este̱du̱ u̱s-rem u̱ ri,
\q2 remu̱ u̱ku̱r u̱ o̱o̱n du̱gu̱ Yawe.>>
\p 
\v 10 Se̱ Yawe wu̱' jan-yu̱ gwa'u̱n Yunana u̱-kit m-sa.
\c 3
\s1 Yunana o̱ m-ha u̱ Neneba
\p 
\v 1 Rem-u̱s Yawe sur m-haan u̱du̱ Yunana u-yu̱ru̱mse̱. Wa zu̱,
\v 2 <<Yu̱ne̱ bo̱ ha u̱ Neneba bo̱-u yat-o̱, bo̱ waru̱ ne̱t-tu̱ o̱ u̱ku̱n rem-su̱ u̱m waru̱ bo̱.>>
\p 
\v 3 Yunana er rem-u̱s Yawe, se̱ wa yu̱ne̱ wa hu̱ u̱ Neneba. Bo̱-u̱ Neneba o̱o̱g u̱ yat-o̱ o̱ sok, se̱ ne̱t no̱ng m-roog u̱t-tu̱t kanda wa hyan bo̱-u o̱ u-be̱e̱t.
\v 4 Ho̱-du̱ Yunana cwaye̱ u̱-me̱ bo̱-u̱ Neneba, wa nom u̱r-hoot u̱r-gan. Se̱ wa he̱e̱se̱ no̱m-du̱ u̱r-do̱nse̱ u̱zu̱, <<Kwu̱ku̱s m-roog u̱t-shik u̱t-yu̱r u̱ na haatu̱n u̱ ho̱-du̱ bo̱-u̱ Neneba.>>
\v 5 Ne̱t-tu̱ Neneba hog rem-u̱s u-Ru̱, e̱ dor se̱. E̱ nom u̱r-do̱nse̱ kowan u̱ no̱m u-swaat, iya o̱ hen u̱ ne̱t-u̱t wu̱to̱ u̱ ya'ag-u̱ re̱k-e̱, kowan nom u-swaat, tu̱msu̱ e̱ wu̱ cwu̱-tu̱ ko̱se̱-du̱ namu̱ jab remu̱ ba'as-u̱t u̱n.
\p 
\v 6 Da-u̱ faru̱k-u̱ Neneba ho̱ge̱ rem-su̱ Yunana ware̱, wa yu̱ne̱ du̱gu̱ pora-du̱ u̱r-faru̱k-u̱ wa. Wa wu̱' cwu̱-tu̱ ko̱se̱ namu̱ jab. Wa shu̱'u̱t u-dak u̱ do̱m m-cwa remu̱ ko̱ste̱ u̱zu̱ wa yakke̱ u̱t-ba'as.
\v 7 U̱ da-u o̱, faru̱k wu̱' na no̱m u̱r-do̱nse̱ u̱-me̱ bo̱-u wa u-be̱e̱t u̱zu̱:
\pmo Du̱gu̱ nu-u faru̱k-u̱ i-yate̱ wa ne̱.
\pm <<Ana yage̱ ne̱t ko̱ u-bisa o̱ rak no̱m u̱t-re̱ da, a waku̱n u̱ re no̱m u̱t-re̱ ko̱ wa swa m-bu̱ da.
\v 8 Yage̱ ne̱t, u̱t-bisa ne̱ u̱ wa' kus-tu̱ ko̱se̱ namu̱ jab. Tu̱msu̱ yage̱ ko̱wan u̱ fag u-Ru̱ m-ho̱r-m-ho̱r. Ko̱wan byu̱ru̱n du̱gu̱ fu̱n-u̱s yo̱-se̱ wa, u̱ yu̱nu̱s-du̱ jab-su̱ u̱t-ne̱t ne̱.
\v 9 Jiya Ru̱-o̱ u̱t-ho̱g u̱r-o̱n, wa toros jab-u̱ wa remu̱ ba'as-u̱t in, wa yage̱ mo̱ttu̱ ho̱-du̱ in.>>
\p 
\v 10 Da-u̱ Ru̱-u̱ hyane̱ u̱zu̱ u̱n yakke̱ u̱t-ba'as u̱ remu̱ yage̱-du̱ no̱m-du̱ no̱m-u̱t yo̱-to̱ u̱n, se̱ wa hog o̱n-u̱r u̱n. Wa yage̱ mo̱ttu̱ ho̱-du̱ u̱n tu̱ wa o̱o̱ge̱ wa zo̱ngte̱.
\c 4
\s1 Ryab-u̱s Yunana remu̱ o̱n-u̱r Yawe
\p 
\v 1 Yunana hog u̱s-ryab sok, remu̱ o̱n-du̱ Ru̱-u̱ ho̱ge̱ u̱ do̱m-u̱ ne̱t-tu̱ Neneba.
\v 2 Yunana nom u̱s-to̱o̱g u̱du̱ Yawe wa zu̱, <<¿Yawe, inya o̱ u̱m zu̱tte̱ da-u̱ u̱m o̱o̱ge̱ u̱ bo̱-u ri? De̱ wu̱te̱ u̱m somot m-ho̱r m-ho̱r m-ha u̱ Tarshis. Ko̱ ba u̱m nape̱ u̱zu̱ bo̱ wa-u-nya wa tu̱msu̱ Ru̱-u̱ u̱r-o̱n, tu̱msu̱ wa za ho̱r-mu̱ u̱s-ryab, bo̱ o̱ u̱t-cwan ne̱ tu̱ baru̱mte̱ da, tu̱msu̱ ko mu̱ne̱ bo̱ o̱ zo̱ngi zo̱ngi bo̱ hast jab-u̱ ró du̱gu̱ hatu̱n swadu̱ u̱r-ko̱b.
\v 3 Yawe, kab fat-u̱r ri da-o̱, rem u̱zu̱ ze̱k u̱r-zwar u̱m mar.>>
\v 4 Yawe zu̱, <<¿No̱ng u̱r-zwar bo̱ no̱m u̱s-ryab u̱ mo̱t-u̱t tun-to̱?>>
\v 5 Yunana aru̱k m-rwu̱ du̱gu̱ me̱ u-bo̱ wa do̱'e̱ wa shu̱'u̱t u̱ de̱ku̱n be-de̱ u-do̱m u-bo̱ ne̱. Wa no̱m de̱ku̱n rimpa-de̱ remu̱ wa kum-u̱t m-yara. Wa shu̱'u̱t u̱ me̱, wa hyen-u̱t no̱m-tu̱ Ru̱-u̱ de̱ no̱mu̱ bo̱-u̱ Neneba.
\v 6 Da-u̱ wa o̱o̱ge̱ u̱-me̱ u̱r-rimpa, Yawe u-Ru̱ wu̱' yaku̱n ku̱wu̱t-du̱ u̱t-ran apu̱n remu̱ ya habte̱ wu̱n du̱ng-mu̱ u̱r-hi, ya rogom ya no̱mu̱ wu̱n m-yara. Yunana nom u̱r-so̱ sok remu̱ ku̱wu̱t-du̱ u̱t-ran ya.
\v 7 Da-u̱ is gase̱ u̱r-wu̱n te̱p te̱p, Ru̱-u to̱mo̱n u̱t-zwa, tu̱ tu̱'se̱ ku̱wu̱t-du̱ u̱t-ran ya, ya gu̱u̱s.
\v 8 Da-u̱ ho̱-du̱ rwu̱ne̱, Ru̱-u̱ to̱mo̱n mya-m yat-mo̱ du̱gu̱ u-do̱m. Ho̱-yu̱ gu̱p Yunana u̱r-hi har wa o̱o̱g u̱ssa u̱t-byu̱z, wa o̱ u̱t-sa m-mar. Se̱ wa zu̱, <<Ze̱k u̱r-zwar u̱m m-mar u̱zu̱ u̱m fot ne̱.>>
\p 
\v 9 Ru̱-u̱ zu̱ Yunana, <<¿No̱mu̱g bo̱ u̱r-zwar bo̱ no̱m u̱s-ryab u̱ remu̱ mar-mu̱ ku̱wu̱t-du̱ u̱t-ran de̱?>>
\p Yunana zu̱, <<Kamu̱g u̱m no̱m u̱s-ryab, ryab-su̱ te m-mar.>>
\p 
\v 10 Yawe zu̱, <<¿Kamu̱g bo̱ ho̱g o̱n-du̱ ku̱wu̱t-du̱ u̱t-ran yu̱ o̱ zu̱ bo̱ kawe̱ ya da? Bo̱ wa'e̱ tu̱msu̱ ya ne̱n-u̱t da. Ya apku̱n u̱ gyu̱p-mu̱ m-gan ya mu̱r u̱ mo̱ko̱n gyu̱p-mo̱.
\v 11 ¿Kamu̱g u̱m ho̱g o̱n-du̱ Neneba bo̱-u yat-o̱ da? Bo̱-u̱ o̱tte̱ ya'ag i ze̱ge̱ u̱t-zo̱ngu u-ko̱k u̱ kwaz-du̱ u̱r-gan (120,000) i nape̱ no̱m-u so̱-o̱ u̱ yo̱-o̱ ne̱ da. Tu̱msu̱ bisa-tu̱ o̱ro u-tát u̱-me bo̱-u o̱. ¿Ku̱mge̱ u̱m ho̱g o̱n-du̱ bo̱-u o̱ da?>>
