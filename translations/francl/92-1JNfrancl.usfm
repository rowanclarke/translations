\v 20 \w Mais|strong="G1161"\w* \w nous|strong="G2249"\w* \w savons|strong="G1492"\w* \w que|strong="G3754"\w* \w le|strong="G2532"\w* \w Fils|strong="G5207"\w* \w de|strong="G2532"\w* \w Dieu|strong="G2316"\w* \w est|strong="G3588"\w* \w venu|strong="G2240"\w*, \w et|strong="G2532"\w* \w qu|strong="G3754"\w*’\w il|strong="G2532"\w* \w nous|strong="G2249"\w* \w a|strong="G1722"\w* \w donné|strong="G1325"\w* \w l|strong="G1161"\w*’\w intelligence|strong="G1271"\w* \w pour|strong="G2532"\w* \w connaître|strong="G1097"\w* \w le|strong="G2532"\w* \w vrai|strong="G3588"\w* \add Dieu\add*, \w et|strong="G2532"\w* \w nous|strong="G2249"\w* \w sommes|strong="G2249"\w* \w en|strong="G1722"\w* \w ce|strong="G3778"\w* \w vrai|strong="G3588"\w* \add Dieu\add*, \add étant\add* \w en|strong="G1722"\w* \w son|strong="G1722"\w* \w Fils|strong="G5207"\w* \w Jésus-Christ|strong="G1722"\w*. \w C|strong="G3778"\w*’\w est|strong="G3588"\w* \w lui|strong="G2532"\w* \w qui|strong="G3588"\w* \w est|strong="G3588"\w* \w le|strong="G2532"\w* \w Dieu|strong="G2316"\w* \w véritable|strong="G2532"\w* \w et|strong="G2532"\w* \w la|strong="G2532"\w* \w vie|strong="G2222"\w* \w éternelle|strong="G2222"\w*.\f + \fr 5:20 \ft 20. Vulgate : \fq Afin que nous connaissions le vrai Dieu, et que nous soyons en son vrai Fils. — Connaître le Véritable\ft , le vrai (Dieu) c. à d. non pas un dieu fictif, mais le seul vrai.\f*  
