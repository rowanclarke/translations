\id REV - Okphela 
\h Irọkhasẹ 
\toc1 Irọkhasẹ 
\toc2 Irọkhasẹ 
\toc3 Irọ 
\mt1 Irọkhasẹ 
\mt2 Ni iJọni ọ kẹkẹ 
\c 1  
\s1 Ikhueghie ungmemhi-a 
\p  
\v 1 Ebe ona a kẹkẹ imekẹguele oyi iJesu iKirisiti shi ni Ẹshinẹgba ọ rọ nali ni e khi emini a ya mẹ ni odẹ ọa ke nuẹ, ni ọ rọte obọ oyi agẹni rọkhasẹ iJọni ọni ọọ ga ọyọli.  
\v 2 IJọni ọ pfi ọtsẹlẹ shi emhi nya ni ọ mẹ ni o khi ungmemhi oyi Ẹshinẹgba ali ọtsẹlẹ oyi iJesu iKirisiti.  
\v 3 Ikhivọsẹ o khi na ọgbọ ni ọ́ ya zẹ ingmemhi eyi imẹguele ena, ikhivọsẹ o li ya khi na ọgbọ ni ọ suọ wẹ, ali ọni ọ ri emini a kẹkẹ shi ọ gbe akanya, irari khi oni ẹghẹghẹ ni a rọ ya mẹ eni emhi enana nya o she ti bhale.  
\v 4 IJọni ọ ri otsẹ ghi igbaa nya eyi eni e mie iJesu iKirisiti suọ ishilua ni e la ekẹ Esha. 
\p Okhale ali opfọmhẹ o ka khi oyẹẹ rọte obọ oyọli, Ọni ọ khi lọli, ni ọ kie kpẹ khi lọli, ni ọ kie gbo ya bhale. Iyẹmhẹ ishilua ni e migha odalo ukpẹkhomhi oyọli e li ẹ tsẹ ẹ.\f + \fr 1:4 \ft Li zẹ \fq Okiali 3.14; Irọ 4.5\f* 
\v 5 Li shi iJesu iKirisiti ni ọ khi ọtsẹlẹ ọna igẹsikia, ọni ọ te ododẹ mu eghuli ọ le, ni ọ mhẹsẹ na ighie na agbọ, ọ li ri otsẹ ghi ẹ.\f + \fr 1:5 \ft Li zẹ \fq Aza 55.4; Iwolo 89.27\f* 
\p Lọli ni ọ nono ingme oyawa, ni ọ ri ọlia eyọli rue awa olamhẹ eyawa le,  
\v 6 ọ she ri awa khi ighie ali ekpodalo-ugamhi eyi Ẹshinẹgba ni ẹ ke ga Ẹshinẹgba ọyọli ali itali. Ufumhi ali ekpabọ e khi eyọli agbọagbọ ya je agbọagbọ! Atsẹ.\f + \fr 1:6 \ft Li zẹ \fq Okiali 19.6; Irọ 5.10\f* 
\q1  
\v 7 A ghe i, ọ ya la 
\q2 elemhi otughunu 
\q2 ke bhale, 
\q2 ukpẹloe nya e ya mẹ ọli, 
\q1 ghe ẹgbọ ni e sọnọ li iwẹrẹ. 
\q2 Ẹgbọ nya na ekẹ agbọ 
\q1 e ya viẹ oya irari oyọli. 
\q2 Ighọ o ya li! Atsẹ.\f + \fr 1:7 \ft Li zẹ \fq iDan 7.13; iMat 24.30; iMak 13.26; iLuk 21.27; 1 iTẹsa 4.17; iZaka 12.10; iJọn 19.34,37\f* 
\p  
\v 8 “Mhẹmhẹ mhi khi Aafa ali Omega.” Ẹshinẹgba Ọnọmhuẹ Nọfunẹ nya ọ ngme ghọ, Ọni ọ khi lọli, ni ọ kie kpẹ khi lọli, ali ni ọ ya bhale.\f + \fr 1:8 \ft Li zẹ \fq iRom 1.17; Irọ 22.13; Okiali 3.14\f* 
\s1 Ọni ọ li abi Omi ọgbọ 
\p  
\v 9 Mhẹmhẹ iJọni ni mhi khi inyọghuo ẹ ni awa ga mẹ osoli, ni awa ga mhọli obọ shi omhẹsẹ ali ni awa kuegbe-a regbemie itobọ iJesu. Abi mhi rọ la ekẹ ni i la iteva okẹ oniẹmhi ni a lu iPatimọsi irari ungmemhi oyi Ẹshinẹgba ali ọtsẹlẹ oyi iJesu.  
\v 10 Ayẹmhẹ ọ tiemhile shi mhẹ ọ ogbẹlẹ oyi Ọnọmhuẹ, mhi suọ uruli na leghe nabi akala ukhokho oyẹmhẹ.  
\v 11 Oni uruli ọọ, “Kẹkẹ emini u mẹ shi ebe, ni u rue ọli ghi igbaa nya eyi eni e mie iJesu iKirisiti suọ ishilua eni e la ẹoli Efesọsi, ali iSimirina ali iPagamu ali iTiatira ali iSadisi ali iFiladefia ali iLaodisha.”  
\v 12 Mhi mu egbe nyenẹ ni mhi mẹ uruli ni o nu mhẹ ẹ ngme. Abi mhi rọ nyenẹ egbe, mhi mẹ ikhuli igolu ishilua ni a ri ikpa ru ẹ nga.  
\v 13 Ifui eni ikhuli ni a ri ákpá ru ẹ nga, mhi mẹ ọgbọ, “Ni ọ li abi Omi Ọgbọ.”\f + \fr 1:13 \ft Li zẹ \fq iDan 7.13\f* Ọ sọ itsua na dogo ni e ramhi ọli imẹkẹnẹ awẹ, ni ọ ri ugbhogbho igolu mu aye.  
\v 14 Ukhomhi ali itsu eyọli ee pfuasẹ abi afuolu, ee pfuasẹ pẹpẹpẹ abi otughunu opfopfo, ikpamhi alo eyọli e li abi ẹlẹmhi erali.  
\v 15 Awẹ eyọli e gẹ nyagha abi akhuli idẹ. Uruli oyọli oo de limhilimhi abi ikhoshẹ oyi utumhi okẹ nofunẹ ni o rọte ikhomhi echẹ tu ẹ tiemhile.\f + \fr 1:15 \ft Li zẹ \fq Ezik 1.24; 43.2\f*\f + \fr 1:15 \ft Li zẹ \fq iDan 7.9; 10.6\f* 
\v 16 Obita oyọli ọ mu ikpẹtata ishilua mhuẹ, itakobi ọzalo eva o rọte unu oyọli lasele. Alo eyọli e ga nyanyanya abi ovọ o khueghie unu-a.  
\v 17 Abi mhi rọ mẹ ọli, mhi de yẹshi ọli awẹ abi ọni ọ she ghu-a. Ama ọ ri obita oyọli nga mhẹ egbe, ọọ mhẹ, “Khi na ulishi, mhẹmhẹ mhi khi Ọnododẹ ni mhi khi ọni ọ kpe ukhokho.\f + \fr 1:17 \ft Li zẹ \fq Aza 44.6; 48.12; Irọ 2.8; 22.13\f* 
\v 18 Mhẹmhẹ mhi khi Ọni ọ la agbọ, Mhi kpẹ ghua, ghe khẹ khi mhi la agbọ agbọagbọ. Mhi mu okpẹ eghuli ali ilimhi mhuẹ obọ. 
\p  
\v 19 “Irarighọ, kẹkẹ emini u mẹ, emini áá mẹ mena, ali emini a ya mẹ ini oo dẹnẹ.  
\v 20 Osheli oyi ikpẹtata ishilua ni u mẹ mhẹ obita ali ikhuli igolu ishilua ni a ri ikpa ru ẹ nga na. Eni ikpẹtata ishilua wẹwẹ e khi eni igẹni ena igbaa oyi eni e mie iJesu iKirisiti suọ ishilua, eni ikhuli ikpa ishilua e khi igbaa nya eyi eni e mie iJesu iKirisiti suọ ishilua. 
\c 2  
\s1 Ebe ni a kẹkẹ ghi igba eni e miesuọ ena ẹoli Efesọsi 
\p  
\v 1 “Kẹkẹ enana ghi agẹni na igbaa oyi eni e mie iJesu iKirisiti suọ ni o la ẹoli Efesọsi: Enana e khi ingmemhi eyi ọni ọ mu ikpẹtata ishilua mhuẹ obita, ni ọọ kia ifuabọ eyi ikhuli igolu ni a ri ikpa ru ẹ nga.\fig Ikhuli ishilua ni a ri ikpa ru ẹẹ nga|src="bk00154c.tif" size="col" loc="REV 2.1" copy="TIF" ref="2.1" \fig* 
\v 2 Mhi lẹsẹ onete ni áá riẹlẹ ali itotobọ gbe akanya oyẹẹ ali iregbemie oyẹ ẹ. Mhi lẹsẹ khi aa ya sọ ẹgbọ ọkhọlọ shi iteva oyẹ ẹ, ali khi a she mu ẹgbọ ni ẹ lu egbewẹ ighiusomhi na kẹẹ fẹ bino, a mẹ khi ẹgbhọli ẹẹ lo.  
\v 3 A she mhuẹ iregbemie, a ri egbe mie ọmunu irari eva oyẹmhẹ, aa ti egbe je ukhokho.  
\v 4 Ama mhi mhọli ona ya gue shi ẹ egbe, khi a she kie inono ni a te ekẹ mhuẹ.  
\v 5 A sato ashini a ti nga ramhi elemhi ayẹmhẹ ni a te de. A mu pfi, ni a riẹlẹ emini a kpẹ̀ te ekẹ ẹ riẹlẹ gbo ke riẹlẹ. Ini aa mu pfi, mhi ya bhale deba ẹ ya wolọ ikhuli ni a ri ikpa ru ẹ nga eyẹ ẹ ashini e la le.  
\v 6 Ama a mhuẹ onete ona ni a riẹlẹ. Eri angeli eyi ẹgbọ iNikolaita ẹ kpasẹ ẹ, ni o khia khi e lili ẹ kpasẹ mhẹ.  
\v 7 Ọni ọ zẹ esọ, ọ rọ suọ abi Ayẹmhẹ ọ gue ẹ ye igbaa oyi eni e mie iJesu iKirisiti suọ nya.\f + \fr 2:7 \ft Li zẹ \fq Igbae 2.9; Irọ 22.2; Ezik 28.13; 31.8\f* Ọni o da mu ọ le ne, mhi ya lama na li ni ọ le ukpamhi ọọra oyi agbọ ni o la Apfẹ oyi Ẹshinẹgba ni o la iloghie. 
\s1 Ebe ni a kẹkẹ ghi igba eni e miesuọ ena ẹoli iSimirina 
\p  
\v 8 “Kẹkẹ enana ghi agẹni na igbaa oyi eni e mie iJesu iKirisiti suọ na ẹoli iSimirina.\f + \fr 2:8 \ft Li zẹ \fq Aza 44.6; 48.12; Irọ 1.17; 22.13\f* 
\p “Enana e khi ingmemhi eyi ọni ọ ralo ni o gbo kpe ukhokho, ni ọ ghu-a ni ọ gbo bhale agbọ.  
\v 9 Mhi lẹsẹ osoli ali umhamẹ oyẹẹ, ama a mhọli ẹpfue. Mhi lẹsẹ ungmemhi opfuẹchẹ ni ẹgbọ ni ẹ lu egbewẹ iJu ni ẹa khi, e rọ ọ pfuẹchẹ ẹ-a, no khia khi ẹgbọ owa ugamhi oyi ọkphaghiẹ e khi.  
\v 10 A khi na ulishi osoli ni ọọ bhale na ẹ. A ghe i, ọkphaghiẹ ọ ya pfi eghuo lo ọgba ighumha ni a mu ẹ fẹ bino, a ya nasẹ ẹ ogbẹlẹ igbe. A mu irudunga oyẹẹ mhuẹ ramhi eghuli, ẹghẹghẹ aghọ, mhi ya ri arula oghie agbọ na ẹ.  
\v 11 Ọni ọ zẹ esọ, ọ rọ suọ abi Ayẹmhẹ ọ gue ẹ yẹ igbaa oyi eni e mie iJesu iKirisiti suọ nya. Ọni ọ da mu ọ le ne, eghuli ni uzeva ọa ya ramhi ọli egbe.\f + \fr 2:11 \ft Li zẹ \fq Irọ 20.14; 21.8\f* 
\s1 Ebe ni a kẹkẹ ghi igba eni e miesuọ ena ẹoli iPagamu 
\p  
\v 12 “Kẹkẹ ona ghi agẹni na igbaa oyi eni e mie iJesu iKirisiti suọ na iPagamu. 
\p “Enana e khi ingmemhi eyi ọni ọ mhọli itakobi ọzalo-eva ni o lolo ẹ mu.  
\v 13 Mhi lẹsẹ ashini a la, ikhi ashini ọkphaghiẹ ọ ri ukpẹkhomhi oyọli shi. Ama a kie mu eva oyẹmhẹ mhuẹ. Aa kie irudunga ni a mhọli na mhẹ. Gbo li shi ẹghẹghẹ oyi Atipasi, ni ọ khi ọtsẹlẹ ọyẹmhẹ ni ọ migha shi igẹsikia, ni a gbe-a shi ifu apfẹ oyẹẹ ashini ọkphaghiẹ ọ ngeli.  
\v 14 Ama mhi mhuẹ ikuku ingme shi ẹ egbe. A mhọli ẹgbọ eghuo iteva oyẹẹ ni e mu osẹsẹ oyi iBelamu mhuẹ. Lọli ọ sẹsẹ oghie iBalaki ọ di ẹgbọ iZirẹni lo olamhẹ. Eri ọ gueyẹ wẹ e le eminale ni a rọ luasẹ obo na ikhumhi ali e ke ku itsẹbọ.\f + \fr 2:14 \ft Li zẹ \fq iNọba 22.5,7; 31.16; iDẹut 23.4; iNọba 25.1-3\f* 
\v 15 Ighọ a gbo mhuẹ ẹgbọ ni e mu osẹsẹ oyi iNikolaita mhuẹ.  
\v 16 Irarighọ, a mupfi. Ini ọa khi ighọ, mhi ya kẹlẹ bhale ya ri itakobi ni o la mhẹ unu nu wẹ khọli.  
\v 17 Ọni ọ zẹ esọ ọ rọ suọ abi Ayẹmhẹ ọ gueyẹ igbaa oyi eni e mie iJesu iKirisiti suọ nya. Ọnini ọ da mu ọ le, mhi ya ri ibulẹdi eghuo ni a rọ sheli na li le. Mhi gbo li ya ri ẹchẹ opfopfo na li ni a kẹkẹ eva onogbọ shi, ni ọgbọ okhọghuo ọa lẹsẹ, sẹ ni ọgbọ ni ọ mie oni ẹchẹli.\f + \fr 2:17 \ft Li zẹ \fq Okiali 16.14-15; 16.33-34; iJọn 6.48-50; Aza 62.2; 65.15\f* 
\s1 Ebe ni a kẹkẹ ghi igba eni e miesuọ ena ẹoli iTiatira 
\p  
\v 18 “Kẹkẹ ona ghi agẹni na igbaa oyi eni e mie iJesu iKirisiti suọ na ẹoli iTiatira: Enana e khi ingmemhi eyi Omi Ẹshinẹgba ni ọ mhuẹ ikpamhi alo ni ẹ gẹ abi ẹlẹmhi erali, ni awẹ eyọli e li abi idẹ.  
\v 19 Mhi lẹsẹ ikanya eyẹ ẹ, abi a li mhọli inono ali irudunga ali abi a li ga egbe ẹ ali iregbemie ni a mhọli. A gbolo ẹ riẹlẹ memena dọsẹ abi a te ekẹ li.  
\v 20 Ama mhi mhuẹ ingme onana ni mhi ya gue shi ẹ egbe. A mie ọni ọkpotso iJezebẹ ọghọ lama, ọni ọ lu egbọli ọmekẹguele. Rọte osẹsẹ oyọli ọ te di eni ẹẹ ga eyẹmhẹ ya lo itsẹbọ, ni e gbolo a le eminale ni a rọ luasẹ ikhumhi.\f + \fr 2:20 \ft Li zẹ \fq 1 Ighie 16.31; 2 Ighie 9.22,30\f* 
\v 21 Mhi she ri ẹghẹghẹ na li ni ọ rọ mupfi lase itsẹbọ eyọli le, ama ọa ghọle ọli.  
\v 22 A ghe i, mhi ya ri ughuamhi pfi ọli gbe she ukpho osoli, mhi ya pfi ẹgbọ ni e nu ọli kia okia lo osoli, sẹẹ ni e mupfi lase odẹ ọkhọlọ oyọli le.  
\v 23 Mhi ya ri eghuli gbe imiọli, ẹghẹghẹ aghọ eni igbaa nya eyi eni e mie iJesu iKirisiti suọ e ya lẹsẹ khi mhẹmhẹ khi ọni ọọ bino udu ali isamhi eyi ọgbọ. Mhi ya fali ẹ ota abi ọgbọgbọ ọ li gbe.\f + \fr 2:23 \ft Li zẹ \fq Iwolo 7.9; iJere 17.10; Iwolo 62.12\f* 
\p  
\v 24 “Ama ẹẹ ni e kpọle shi ẹoli iTiatira ni ẹa lama mu osẹsẹ eyi iJezebẹ mhuẹ, ni aa lama wẹna owẹna eyi ọkphaghiẹ ni ẹẹ lu osheli ni e limhi, mhi aa ya khi omhẹsẹ olese nga ẹ ike.  
\v 25 A lẹsẹ mu emini a mhọli mhuẹ obọ egbegbọ ya ramhi ni mhi rọ ya bhale.  
\v 26 Ọni ọ mu ọ le, ni ọ ri ọghuẹmhẹ oyẹmhẹ gbe ya ramhi ukpẹsẹ, mhi ya ri ishishi nali ke mhẹsẹ shi.  
\v 27 ‘Ọ ya ri akhuli mhuẹ obọ ke mhẹsẹ na wẹ, ọ ya guọghọ wẹ-a abi a liẹ ma ekhe.’\f + \fr 2:27 \ft Li zẹ \fq Iwolo 2.8-9\f* 
\v 28 Ọ ya mhọli afu onabi mhi rọte obọ oyi Itamhẹ mie. Mhi gbo ri ukpẹtata anukpesumegie na ẹluzogbe na li. 
\p  
\v 29 “Ọni ọ zẹ esọ, ọ rọ suọ abi Ayẹmhẹ ọ gueyẹ eni igbaa nya oyi eni e mie iJesu iKirisiti suọ. 
\c 3  
\s1 Ebe ni a kẹkẹ ghi igba eni e miesuọ ena ẹoli iSadisi 
\p  
\v 1 “Kẹkẹ ona ghi agẹni na igbaa oyi eni e mie iJesu iKirisiti suọ na ẹoli iSadisi. 
\p “Enana e khi ingmemhi eyi ọni ọ mu iyẹmhẹ ishilua eyi Ẹshinẹgba ali ikpẹtata ishilua mhuẹ. Mhi lẹsẹ ikanya eyẹẹ. À mhọli eva onete abi ẹzẹzẹ khi a la agbọ, ama eri a ghua.  
\v 2 A guale ni a zese emini o kpọ ẹ le-a ni ẹ nono ni e ghua. Irari khi mhi mẹ ikanya eyẹẹ khi ẹa gba pfo odalo oyi Ẹshinẹgba ọyẹmhẹ.  
\v 3 A ri itobọ ighọ sato emini a she mie ni a suọ, a ri ọli gbe akanya, a mupfi. Ama ini aa da guale, mhi ya bhale abi oghiatọ, aa ya lẹsẹ ẹghẹghẹ ni mhi rọ ya bhale na ẹ.\f + \fr 3:3 \ft Li zẹ \fq iMat 24.43-44; iLuk 12.39-40; Irọ 16.15\f* 
\v 4 Abi o kie li ena, à kie mhuẹ ẹgbọ eghuo ẹoli iSadisi ni ẹa ri ichimhi mu itsua eyẹwẹ. E ya sọ itsua epfopfo nu mhẹ kia, irari khi e tẹ ọ.  
\v 5 Ọni o mu ọ le, ighọ ọ li ya sọ itsua epfopfo. Mhi aa ya shishi eva oyọli ebe ni a kẹkẹ eva oyi eni e ya mhọli agbọ na agbọagbọ shi-a. Ama mhi ya ngme ingme oyọli le khasẹ itamhẹ ali igẹni eyọli.\f + \fr 3:5 \ft Li zẹ \fq Okiali 32.32-33; Iwolo 69.28; Irọ 20.12; iMat 10.32; iLuk 12.8\f* 
\v 6 Ọni ọ zẹ esọ, ọ rọ suọ emini Ayẹmhẹ ọ gueyẹ eni igbaa oyi eni e mie iJesu iKirisiti suọ nya. 
\s1 Ebe ni a kẹkẹ ghi igba eni e miesuọ ena ẹoli iFiladefia 
\p  
\v 7 “Kẹkẹ ona ghi agẹni na igbaa oyi eni e mie iJesu iKirisiti suọ na ẹoli iFiladefia. Ena e khi ingmemhi eyi ọni ọ pfuasẹ, ni ọ khi igẹsikia, ni ọ mhọli okpẹ oyi iDefidi. Ọni ọ kha khueghie-a, ọgbọ ọa laọ ni ọ dobẹ ya khukhu, ọni ọ kha khukhu, ọgbọ ọa dobẹ khueghie-a.\f + \fr 3:7 \ft Li zẹ \fq Aza 22.22; iJobu 12.14\f* 
\v 8 Mhi lẹsẹ ikanya eyẹ ẹ. A ghe i, mhi she khueghie odẹ-a shi ekẹ na ẹ, ni ọgbọ ọa dobẹ ya khukhu. Mhi lẹsẹ khi ukuku itoto a mhọli, abotseku khi ighọ, a kie ri ungmemhi oyẹmhẹ ẹ gbe akanya, aa tigbe kie eva oyẹmhẹ.  
\v 9 A ghe i, mhi ya ri eni e la owa ugamhi oyi ọkphaghiẹ ni ẹ lu egbewẹ iJu ni o khia khi ẹgbhọli ẹ lo, bhale ya nyẹsẹ ukhomhi shi ẹ ufuẹgẹ ni e lẹsẹ khi mhi nono ingme oyẹẹ.\f + \fr 3:9 \ft Li zẹ \fq Aza 49.23; 60.14; 43.4\f* 
\v 10 Irari khi a ri omhẹsẹ oyẹmhẹ gbe akanya ni o gueyẹ ẹ a ri irabọmudu ri egbe mie, mhi ya rue ẹ imufẹ le, ni ọọ bhale ekẹ agbọ nya. Imufẹ ni o ya mu ẹgbọ na agbọ nya fẹ bino.  
\v 11 Mhi ya kẹlẹ bhale. Mu emini u mhọli mhuẹ toto, ini ọgbọkhọghuo ọ khi mie ẹ arula oghie oyẹ.  
\v 12 Ọni ọ da mu ọ le ne, mhi ya rọli khi ọchẹ elemhi Owa ugamhi oyi Ẹshinẹgba ọyẹmhẹ. Ọa ya tigbe rọte aghọ vu. Mhi ya kẹkẹ eva oyi Ẹshinẹgba ọyẹmhẹ shi ọli egbe, li shi eva oyi ẹoli oyi Ẹshinẹgba ọyẹmhẹ ni o khi iJerusalẹmu onogbọ, ni o rọte Eghiele oyi Ẹshinẹgba ọyẹmhẹ ẹ tiemhile ali eva onogbọ oyẹmhẹ.\f + \fr 3:12 \ft Li zẹ \fq Irọ 21.2; Aza 62.2; 65.15\f* 
\v 13 Ọni ọ zẹ esọ, ọ suọ emini Ayẹmhẹ o gue ẹ yẹ eni igbaa oyi eni e mie iJesu iKirisiti suọ nya. 
\s1 Ebe ni a kẹkẹ ghi igba eni e miesuọ ena ẹoli iLaodisha 
\p  
\v 14 “Kẹkẹ ona li ghi agẹni na igbaa oyi eni e mie iJesu iKirisiti suọ na ẹoli iLaodisha. Enana e khi ingmemhi eyi Atsẹ, ni ọ khi ọtsẹlẹ ọni ọ zẹ ri egbe ẹ nga, ni ọ khi igẹsikia, ọni ọ mhẹsẹ ẹ na emini Ẹshinẹgba ọ ma nya.\f + \fr 3:14 \ft Li zẹ \fq Ekpi 8.22\f* 
\v 15 Mhi lẹsẹ ikanya eyẹ ẹ khi, aa mhuẹ utomhi wẹkhi eri a pfọ. O kha ti ini a khi oghuo ọ lọ.  
\v 16 Irarighọ, itobọ khi a rimhẹ, ni aa rọ to wẹkhi eri a pfọ, mhi ya rọte unu oyẹmhẹ to ẹ pfia.  
\v 17 Irari khi a liẹ, ‘Mhi pfue, mhi she ti ẹpfue ma, mhi aa ke mhuẹ emini o to mhẹ.’ Ama aa lẹsẹ khi ẹgbọ eyẹmhẹ a khi, eni a viẹ osoli ẹ na, ena umhamẹ, ni e khi ezalo ali ebanọa.  
\v 18 Irarighọ, mhia ye ẹ ude ni a nu mhẹ dẹ ẹlomho ni a ri erali nye-a ini a mele eni e pfue-a, ni a mhọli itsua epfopfo ni aa sọ, ni a rọ khukhu irumheba omama eyẹ ẹ. Ni mhi ri ogugu na ẹ vi shi alo ni a ke mẹ ekẹ.  
\v 19 Ẹgbọ ni mhi nono ingme oyẹwẹ, mhi ya dese, mhi gbo sheshe wẹ shi odẹ, irarighọ a mhuẹ ọmuegbe ni a mu nyenẹ.\f + \fr 3:19 \ft Li zẹ \fq Ekpi 3.12; Iburu 12.6\f* 
\v 20 A ghe i! Mhi migha odẹ mhia kpheli obọ ọ, ini ọgbọkhọghuo ọ suọ uruli oyẹmhẹ ni ọ rọ khueghie-a na mhẹ, mhi ya lo le, mhi nu ọli le, ọ nu mhẹ le.  
\v 21 Ọni ọ mu ọ le, mhi ya lama na li ni ọ nu mhẹ shitọ ukpẹkhomhi oghie oyẹmhẹ, ẹzẹzẹ abi mhẹmhẹ mhi li mu ọ le ni mhi nu Itamhẹ shitọ ukpẹkhomhi oghie oyọli.  
\v 22 Ọni ọ zẹ esọ, ọ rọ suọ emini Ayẹmhẹ o gueyẹ eni igbaa nya eyi eni e mie iJesu iKirisiti suọ.” 
\c 4  
\s1 Ugamhi na iloghie 
\p  
\v 1 Abi mhi rọ mẹ ena dọsẹ se, mhi ke gbo mẹ imekẹ olese. Mhi mẹ khi odẹ o khueghie-a shi iloghie, mhi suọ khi uruli ni o kpẹ nu mẹ mhẹ ngme abi akala. Ọọ mhẹ, “Bhale odane ana, khi mhi ya rẹ khasẹ emini a ya mẹ ini ena e dọsẹ sẹ.”  
\v 2 Utoghuo kpe mhi la elemhi Ayẹmhẹ, mhi mẹ odalo oyẹmhẹ khi ukpẹkhomhi o migha iloghie, khi ọgbọ ọ shitọ nga ọ.  
\v 3 Ọni ọ shitọ ọ, ọ li abi ẹchẹ ni ọọ gẹ ni a lu ijasipa ali ikanẹliani. Ogaji ni o li abi ẹchẹ ughegbe ni a lu ẹmẹradi o vi gasẹ oni ukpẹkhomhi.\f + \fr 4:3 \ft Li zẹ \fq Ezik 1.26-28; 10.1\f* 
\v 4 Ikpẹkhomhi uye ali ene elese e la gasẹ oni ukpẹkhomhi. Egbhali uye ọgbọ ali aane e shitọ eni ikpẹkhomhi. E sọ itsua epfopfo, e rughu irula oghie igolu shi ukhomhi.  
\v 5 Rọte oni ukpẹkhomhi oghie, inyamhisalo amẹ ali ingmolo oyi akphala e te ọ ọ lasele. Rọte oni ukpẹkhomhi oghie ikpa ishilua e lala ni e khi Ayẹmhẹ ishilua eyi Ẹshinẹgba.\f + \fr 4:5 \ft Li zẹ \fq Okiali 19.16; Irọ 8.5; 11.19; 16.18; Ezik 1.13; Irọ 1.4; iZaka 4.2\f* 
\v 6 Ali khi oni ukpẹkhomhi khi emini o li abi okẹ ighegbe oniẹmhi o la odalo ọli ni o pfuasẹ ni a te ẹ mẹ ekẹ gboo. 
\p Elamhakọ aane ni e mhuẹ ayẹmhẹ ni e zẹ alo gasẹ egbe odalo ali ukhokho, e le gasẹ oni ukpẹkhomhi oghie rọli shi iteva.  
\v 7 Emini ọ mhuẹ ayẹmhẹ ọnododẹ ọ li abi idu, ọnuzava ọ li abi ẹna, ọnuzasẹ ọ zẹ alo abi ọgbọ, ọnuzi-aane o li abi ākpā ọ̄degbe ni ọọ fiala.\f + \fr 4:7 \ft Li zẹ \fq Ezik 1.22,5-10; 10.14\f* 
\v 8 Eni elamhakọ aane ena e mhọli ipfua esesa esesa, e mhọli ikpamhi alo gasẹ idiegbe, li ghe elemhi ipfua eyẹwẹ, Ẹlẹ ọguota ali ẹlẹ iyọsẹ ẹa tigbe ẹ yẹmhẹ-a, eri e lẹsẹ liẹ, 
\q1 “Ipfuasẹ, ipfuasẹ, ipfuasẹ 
\q2 khi Ẹshinẹgba Ọnọmhuẹ 
\q2 Nọfunẹ nya, 
\q1 Ọni ọ khi lọli, 
\q2 ni ọ kie kpẹ khi lọli, 
\q2 ali ni ọ ya bhale.”\f + \fr 4:8 \ft Li zẹ \fq Ezik 1.18; 10.12; Aza 6.2-3\f* 
\p  
\v 9 Ini eni elamhakọ aane eghọ e da ri ufumhi ali ekpẹ ali ikphẹmhi na ọni ọ shitọ oni ukpẹkhomhi oghie ne, ni ọ laọ a lẹ ẹlẹ na agbọagbọ,  
\v 10 eni egbhali uye ọgbọ ali aane eghọ, e de ya yẹshi na ọni ọ shitọ oni ukpẹkhomhi, e ri kphẹmhi na ọni laọ a lẹ ẹlẹ na agbọagbọ. E gueghie irula eghiele eyẹwẹ shi ekẹ odalo oni ukpẹkhomhi oghie, ẹẹ liẹ. 
\q1  
\v 11 “U tẹọ Ọnọmhuẹ ali 
\q2 Ẹshinẹgba ọyanye, 
\q1 Ni ọ mie ufumhi 
\q2 ali ekpẹ ali ekpabọ, 
\q1 Irari khi yẹyẹ u ma emhikpa. 
\q2 Ọghuẹmhẹ oyẹ u rọ ma wẹ, 
\q2 lọli e gbo rọ laọ abi a li ma wẹ.” 
\c 5  
\s1 Ebe ali Omi Osumha 
\p  
\v 1 Mhi ke gbo mẹ ọni ọ shitọ oni ukpẹkhomhi oghie khi ọ mu ebe ni a kẹkẹ emhi shi odalo ọli ali ukhokho ọli mhuẹ obita. A ri ẹruẹli rọte asha ishilua to ọli ma.\f + \fr 5:1 \ft Li zẹ \fq Ezik 2.9-10; Aza 29.11\f* 
\v 2 Mhi mẹ agẹni ni ọ funẹ ni ọ tsẹsẹ ngme leghe ọọ liẹ, “Ọghuo ọ ya dobẹ maghiẹ eni ẹruẹli oni ebe-a?”  
\v 3 Ama ọgbọkhọghuo ọa la iloghie, wẹkhi ekẹ agbọ, wẹkhi ikpọkẹ na agbọ, ni ọ dobẹ khueghie oni ebe-a, ukẹneta khi eri ọ dobẹ ya bino elemhi oni ebe.  
\v 4 Mhi viẹ egbegbọ irari khi aa mẹ ọgbọ ni ọ tẹọ ni ọ ya khueghie oni ebe-a wẹkhi ni ọ bino elemhi ọli.  
\v 5 Ọtuọghuo eni egbhali eghọ ọọ mhẹ, “Khi ke viẹ! Ghe khẹ, Ọdumhi na unuẹkpẹ oyi iJuda, Omiomi iDefidi ọ she mu ọ le. Ọ dobẹ ya khueghie oni ebe-a ali ẹruẹli ishilua eyọli.”\f + \fr 5:5 \ft Li zẹ \fq Igbae 49.9; Aza 11.1,10\f* 
\p  
\v 6 Ighọ mhi mẹ khi Omi Osumha khi ọ migha odalo oyi oni ukpẹkhomhi oghie ni elamhakọ aane eghọ, ali eni egbhali e gasẹ. Ọ li abinẹ khi a she kpẹ gbe ọli-a. Ọ zẹ ekphali ishilua ali ikpamhi alo ishilua ni e khi Ayẹmhẹ ishilua eyi Ẹshinẹgba ni ọ she ghie je ekẹ agbọ nya.\f + \fr 5:6 \ft Li zẹ \fq Aza 53.7; iZaka 4.10\f* 
\v 7 Ọni omi osumha ọ le ya rue oni ebe obita oyi ọni ọ shitọ oni ukpẹkhomhi oghie.  
\v 8 Abi ọ rọ rue oni ebe se, eni elamhakọ aane eghọ ali egbhali uye ọgbọ ali aane, e de yẹshi odalo oyi ọni Omi osumha. Wẹwẹ nya ọgbọgbọ ọ mu ẹfa mhọli obọ ali itasa igolu ni ituale afu ẹẹra ni a tosẹ e vọ, ni e khi iromhi ni eni Ẹshinẹgba ọ she pfa na e sọ.\f + \fr 5:8 \ft Li zẹ \fq Iwolo 141.2\f* 
\v 9 E to uwolo onogbọ, e liẹ, 
\q1 “U tẹ ọni ọ rue oni ebe, 
\q2 u gbo tẹ ọni ọ ya maghiẹ 
\q2 ẹruẹli ni a rọ ma ọ-a, 
\q1 Irari khi a gbe-a, 
\q2 U ri ọlia eyẹ dẹ ẹgbọ 
\q2 na Ẹshinẹgba, 
\q1 ẹgbọ ni e rọte agbọ nya bhale 
\q2 rọte unuẹkpẹ nya ali 
\q2 ẹmuẹ ọdọda ali ẹgbọ ọdọda nya.\f + \fr 5:9 \ft Li zẹ \fq Iwolo 33.3; 98.1; Aza 42.10\f* 
\q1  
\v 10 U rẹwẹ mele ighie 
\q2 ali ekpodalo-ugamhi ni ẹ ga 
\q2 Ẹshinẹgba ọyawa-a. 
\q1 E ya la agbọ ke mhẹsẹ.”\f + \fr 5:10 \ft Li zẹ \fq Okiali 19.6; Irọ 1.6\f* 
\p  
\v 11 Mhi bino mhi suọ iruli eyi igẹni ebubu ni e ramhi igbẹlẹ ali idududu. E le gasẹ oni ukpẹkhomhi oghie ali elamhakọ eghọ ali eni egbhali.\f + \fr 5:11 \ft Li zẹ \fq iDan 7.10\f* 
\v 12 E ri ukpokpomhi uruli i to uwolo, e liẹ, 
\q1 “Ọni ọ tẹọ Omi osumha 
\q2 ni a gbe-a ọ khi, 
\q1 ni ọ mie ekpabọ ali ẹpfue 
\q2 ali ilẹsingme ali itoto, 
\q1 ali ekpẹ ali ufumhi 
\q2 ali ikuẹghiẹ!” 
\p  
\v 13 Mhi tigbe suọ khi emhikpa ni a ma na iloghie ali ekẹ agbọ ali ikpọkẹ na agbọ ali ena okẹ oniẹmhi ali emini e laọ elemhi ọli nya khi ẹ to uwolo, ẹẹ liẹ, 
\q1 “Ọni ọ shitọ oni ukpẹkhomhi 
\q2 ali Omi osumha, 
\q1 Ikuẹghiẹ ali ekpẹ 
\q2 ali ufumhi ali ekpabọ, 
\q1 e khi eyẹẹ, rọte 
\q2 agbọagbọ ya je agbọagbọ!” 
\m  
\v 14 Eni elamhakọ aane eghọ ẹ li, “Atsẹ,” eni egbhali eghọ, e de yẹshi, e ga li. 
\c 6  
\s1 Eni ẹruẹli 
\p  
\v 1 Mhi tọkpẹ bino abi ọni Omi Osumha ọ rọ maghiẹ ẹruẹli onododẹ elemhi eni ẹruẹli ishilua-a. Mhi suọ khi ọghuo eni elamhakọ eghọ o ngme abi uruli akphala, ọọ li, “Bhale!”  
\v 2 Mhi bino, ghe achi ọpfopfo odalo oyẹmhẹ khẹ! Ọmọse ni ọ nga li ọ mu usheli mhuẹ, a ri arula oghie na li, ọ nga ọni achi ya fiẹ abi ọkhọli-okhuẹ ni ọ khọli mu ọ le ni ọ gbo vu ya khọli mu ọ le.\f + \fr 6:2 \ft Li zẹ \fq iZaka 1.8; 6.3,6\f* 
\p  
\v 3 Abi ọni Omi Osumha ọ rọ maghiẹ ẹruẹli onuzi-eva-a, mhi suọ khi ẹlamhakọ ọnuzava ọ ngme, ọọ li, “Bhale!”  
\v 4 Mhi mẹ khi achi ọlese ni ọọ yilẹ nyọghọ ọ fiẹ lasele. A ri afu na ọni ọ nga li ni ọ rọ rue opfọmhẹ ekẹ agbọ-a, ni ọ rọ ri ẹgbọ ke gbolo egbe wẹ-a. A ri ọgbhọrọ oniẹmhi na li.\f + \fr 6:4 \ft Li zẹ \fq iZaka 1.8; 6.2\f* 
\p  
\v 5 Abi ọni Omi Osumha ọ rọ maghiẹ ẹruẹli onuzi-esẹ-a, mhi suọ khi ẹlamhakọ ọnuzi-aasẹ ọ ngme, ọọ li, “Bhale!” Mhi bino, ghe achi ọbishi odalo oyẹmhẹ khẹ! Ọni ọ nga li ọ mu emini a rọ ọ mhẹsẹ ukhọmhi oyi emhi.\f + \fr 6:5 \ft Li zẹ \fq iZaka 6.2,6\f*\fig Emini a rọ mhẹsẹ ukhọmhi oyi emhi|src="hk00156c.tif" size="col" loc="REV 6.5" copy="TIF" ref="6.5" \fig* 
\v 6 Mhi suọ khi emini o li abi uruli o la elemhi ifuabọ oyi eni elamhakọ aane eghọ ngme, ọọ liẹ, “Ifata ogbẹlẹghuo a ri ago oghuo oyi ado ẹ dẹ, idiakpala esẹ oyi ọakpa, o li migha shi ifata ogbẹlẹghuo. Khi yese oili olivu-a ali onyọ!” 
\p  
\v 7 Abi ọni Omi Osumha ọ rọ maghiẹ ẹruẹli onuzi-ene-a, mhi suọ khi uruli oyi ẹlamhakọ ọnuzi-aane ọọ li, “Bhale!”  
\v 8 Ighọ mhi mẹ achi ni ọ li abi ọni ọ ya ghu-a. Ọni ọ nga li a lui Eghuli, ali eghiele ilimhi oo deba li udidi, a ri afu na wẹ ni e rọ ri ọgbhọrọ ali okiamhi ali ighuamhi ali elamhakọ okhẹna gbolo ẹgbọ iku akemhishi asha ene ẹgbọ na ekẹ agbọ-a.\f + \fr 6:8 \ft Li zẹ \fq Ezik 14.21\f* 
\p  
\v 9 Abi ọni Omi Osumha ọ rọ maghiẹ ẹruẹli onuzi-ishe-a, mhi mẹ iyẹmhẹ eyi ẹgbọ na gbolo-a irari ungmemhi oyi Ẹshinẹgba ali ọtsẹlẹ ni e mu mhuẹ ufui oni atẹtẹ.  
\v 10 Ee viẹ leghe, e liẹ, “Ọnọmhuẹ ni ọ khi ọna ipfuasẹ ali igẹsikia, ẹghẹghẹ onoghuo u rọ ya gue ẹgbọ na agbọ ẹzọ, ni u rọ ya ye okhuẹ ọlia eyi anye obọ oyẹwẹ na anye?”  
\v 11 Ẹghẹghẹ aghọ, a ri itsua epfopfo na wẹ. A gueyẹ wẹ e migha ne ukuku ọ, ramhi ẹghẹghẹ ni eni ẹẹ ga nabi wẹwẹ etuangmẹ ni a nono ni a li gbolo-a e rọ ya gba. Ẹzẹzẹ abi a li gbolo wẹwẹ-a. 
\p  
\v 12 Mhi bino abi ọ li khueghie ẹruẹli onuzi-esesa-a. Ukpokpomhi ekẹ o kuluẹ. Ovọ o bishi-a abi ode abuma ni a ri iriria ẹlamhi do. Uki nya o yilẹ-a abi ọlia.\f + \fr 6:12 \ft Li zẹ \fq Irọ 11.13; 16.18; Aza 13.10; iJọẹ 2.10,31; 3.15; iMat 24.29; iMak 13.24-25; iLuk 21.25\f* 
\v 13 Ikpẹtata na idane e deno kule ekẹ abi ikpamhi ọkhua-eni ni ẹa yilẹ ne e liẹ de kule ini akpekpeli ni o ze o jighise wẹ.  
\v 14 Irarogbe o khili odẹ-a abi a liẹ khili ighẹlẹ ekẹ-a. Ite nya ali ekẹ ni e la iteva okẹ, a rue wẹ ashini e la le.\f + \fr 6:14 \ft Li zẹ \fq Irọ 16.20\f*\f + \fr 6:14 \ft Li zẹ \fq Aza 34.4\f* 
\p  
\v 15 Ẹghẹghẹ aghọ, ighie na ekẹ agbọ ali ekhẹmhuẹ ali idenọmọ okhọli ali eni e mhọli ẹpfue ali eni e mhọli ekpabọ ali ọgbọkpa ali ighumha ali eni ẹa khi ighumha, e na ya sheli ifui irui ali echẹ na ite.\f + \fr 6:15 \ft Li zẹ \fq Aza 2.19,21\f* 
\v 16 Ee viẹ lu ite ali echẹ eniẹmhi, e liẹ wẹ, “A de mu anye ni a ri anye sheli ẹloe oyi ọni ọ shitọ oni ukpẹkhomhi oghie ali ofu oyi ọni Omi Osumha!\f + \fr 6:16 \ft Li zẹ \fq Osia 10.8; iLuk 23.30\f* 
\v 17 Irari khi ogbẹlẹ ofu oniẹmhi oyi Ẹshinẹgba o she ramhi ni o rọ ya tiemhile shi wẹ ọ, ọghuo ọ dobẹ ya migha?”\f + \fr 6:17 \ft Li zẹ \fq iJọẹ 2.11; iMala 3.2\f* 
\c 7  
\s1 Ẹgbọ agbẹlẹ egbhuẹshilua ali ene (144,000) ni a shi ọlẹlẹ 
\p  
\v 1 Ona o dọsẹ sẹ, mhi ke gbo mẹ khi igẹni aane e migha iguabọ enenene na ekẹ agbọ. E mu akpekpeli enenene na iguabọ ekẹ agbọ gba ini akpekpeli o khi ke li ekẹ agbọ, wẹẹ ukhomhi okẹ oniẹmhi wẹẹ ẹẹra.\f + \fr 7:1 \ft Li zẹ \fq iJere 49.36; iDan 7.2; iZaka 6.5\f* 
\v 2 Ighọ mhi kẹ mẹ agẹni ọlese khi ọ rọte obini ovọ o te ẹ ngale lasele, ọ tsua akhuli ni a rọ ọ shi emhi ọlẹlẹ oyi Ẹshinẹgba ni ọ la agbọ. Ọ ri uruli na leghe lu eni igẹni aane eghọ ni a ri ekpabọ na ni e rọ yese ekẹ ali okẹ oniẹmhi-a.  
\v 3 Ọọ wẹ, “A khi yese ekẹ-a wẹẹ okẹ oniẹmhi wẹẹ ẹẹra, sẹ khi awa shi ọlẹlẹ shi eni ẹẹ ga eyi Ẹshinẹgba alukpo se.”\f + \fr 7:3 \ft Li zẹ \fq Ezik 9.4,6\f* 
\v 4 Ighọ mhi suọ khi eni a rọte elemhi ẹdẹli eyi iZirẹni nya shi ọlẹlẹ, e ya khi ẹgbọ agbẹlẹ egbhuẹshilua ali ene (144,000). 
\q1  
\v 5 A rọte unuẹkpẹ oyi iJuda, 
\q1 shi ọlẹlẹ shi ẹgbọ 
\q1 agbẹlẹ igbẹva egbe (12,000). 
\q1 A rọte unuẹkpẹ oyi iRubẹni, 
\q1 shi ọlẹlẹ shi ẹgbọ 
\q1 agbẹlẹ igbẹva egbe (12,000). 
\q1 A rọte unuẹkpẹ oyi iGadi, 
\q1 shi ọlẹlẹ shi ẹgbọ 
\q1 agbẹlẹ igbẹva egbe (12,000). 
\q1  
\v 6 A rọte unuẹkpẹ oyi Asha, 
\q1 shi ọlẹlẹ shi ẹgbọ 
\q1 agbẹlẹ igbẹva egbe (12,000). 
\q1 A rọte unuẹkpẹ oyi iNafutali, 
\q1 shi ọlẹlẹ shi ẹgbọ 
\q1 agbẹlẹ igbẹva egbe (12,000). 
\q1 A rọte unuẹkpẹ oyi iManasẹ, 
\q1 shi ọlẹlẹ shi ẹgbọ 
\q1 agbẹlẹ igbẹva egbe (12,000). 
\q1  
\v 7 A rọte unuẹkpẹ oyi iSamọ, 
\q1 shi ọlẹlẹ shi ẹgbọ 
\q1 agbẹlẹ igbẹva egbe (12,000). 
\q1 A rọte unuẹkpẹ oyi iLiva, 
\q1 shi ọlẹlẹ shi ẹgbọ 
\q1 agbẹlẹ igbẹva egbe (12,000). 
\q1 A rọte unuẹkpẹ oyi iSaka, 
\q1 shi ọlẹlẹ shi ẹgbọ 
\q1 agbẹlẹ igbẹva egbe (12,000). 
\q1  
\v 8 A rọte unuẹkpẹ oyi iZebulọ, 
\q1 shi ọlẹlẹ shi ẹgbọ 
\q1 agbẹlẹ igbẹva egbe (12,000). 
\q1 A rọte unuẹkpẹ oyi iJosẹfu, 
\q1 shi ọlẹlẹ shi ẹgbọ 
\q1 agbẹlẹ igbẹva egbe (12,000). 
\q1 A rọte unuẹkpẹ oyi iBẹjami, 
\q1 shi ọlẹlẹ shi ẹgbọ 
\q1 agbẹlẹ igbẹva egbe (12,000.) 
\p  
\v 9 Ona o dọsẹ se, mhi bino, ghe ebubu ẹgbọ ni ọgbọkhọghuo ọa dobẹ ya leli khẹ! Ishishi khi ishishi ali unuẹkpẹ nya ali ẹgbọ ali ẹmuẹ ọdọda e te bhale. Ighọ e migha odalo oyi oni ukpẹkhomhi oghie, e migha odalo oyi ọni Omi Osumha, e sọnọ itsua epfopfo, e muno eyamhi mhọli abọ.  
\v 10 E tsẹsẹ leghe, e liẹ. 
\q1 “Ẹshinẹgba ọni ọ shitọ 
\q2 oni ukpẹkhomhi oghie, 
\q1 Ọ mhọli ekpabọ 
\q2 ni ọ rọ mie ẹgbọ eyọli pfuese, 
\q1 ighọ li khi ọni Omi Osumha.” 
\p  
\v 11 Igẹni nya e migha gasẹ ọni ukpẹkhomhi oghie, ali eni egbhali ali elamhakọ aane e de ta alo mu ekẹ odalo oni ukpẹkhomhi oghie e ga Ẹshinẹgba.  
\v 12 E liẹ, 
\q1 “Atsẹ! 
\q2 Ikuẹghiẹ ali ufumhi, 
\q1 ali ẹgbhẹ ali 
\q2 ikphẹmhi ali ekpẹ, 
\q1 ali ekpabọ ali itoto, 
\q2 e khi eyi Ẹshinẹgba ọyawa, 
\q1 ẹlẹ na agbọagbọ. 
\q2 Atsẹ!” 
\p  
\v 13 Ighọ ọgbhali ọghuo elemhi wẹ ọ nu mhẹ ngme ọ mhẹ, “Eghuo eghọ e khi ni e sọnọ itsua epfopfo? U lẹsẹ obini e tẹ bhale?” 
\p  
\v 14 Mhiẹ ọli, “Ọga, yẹyẹ u ya lẹsẹ.”\f + \fr 7:14 \ft Li zẹ \fq iDan 12.1; iMat 24.21; iMak 13.19\f* 
\p Ọọ mhẹ, “Ena e khi eni e pfue oni ukpokpomhi ajilimhẹ, e she pfuẹ itsua eyẹwẹ-a, e ri ọlia eyi ọni Omi Osumha rẹwẹ pfuasẹ.  
\v 15 Irarighọ, 
\q1 “E rọ migha odalo 
\q1 ukpẹkhomhi oghie 
\q1 oyi Ẹshinẹgba. 
\q2 Ni e la 
\q1 elemhi Owa oyi Ẹshinẹgba oyọli 
\q2 ke ga li ẹlẹ ọguota ali ẹliyọsẹ. 
\q1 Ọni ọ shitọ oni 
\q1 ukpẹkhomhi oghie oyọli, 
\q1 ọ ya ri okholo oyọli 
\q2 khukhu wẹ. 
\q1  
\v 16 Okiamhi ọa ke 
\q2 gbo ya gbe wẹ ghue, 
\q2 wẹkhi okiamẹ o kẹ ya gbe wẹ ghue. 
\q1 A ya khukhu wẹ ovọ ererẹ, 
\q2 ọa kẹ tosẹ wẹ ghue.\f + \fr 7:16 \ft Li zẹ \fq Aza 49.10\f* 
\q1  
\v 17 Irari khi ọni Omi Osumha 
\q1 ni ọ migha odalo oni 
\q2 ukpẹkhomhi oghie, 
\q1 ọ ya ri ẹloe ke khu wẹ. 
\q2 O rẹwẹ je okẹ amẹ 
\q2 ni o ri agbọ a na ọgbọ. 
\q1 Ẹshinẹgba ọ ya shishi wẹ ameviẹ alo-a.”\f + \fr 7:17 \ft Li zẹ \fq Iwolo 23.1; Ezik 34.23; Iwolo 23.2; Aza 49.10; 25.8\f* 
\c 8  
\s1 Ẹruẹli onuzi-ishilua 
\p  
\v 1 Abi ọni Omi Osumha ọ rọ maghiẹ ẹruẹ onuzi-ishilua-a, iloghie o kẹkẹkẹ elemhi iminiti uye ali igbe. 
\p  
\v 2 Ighọ mhi mẹ igẹni oshilua ni ẹẹ migha odalo oyi Ẹshinẹgba, khi a ri ikala ishilua na wẹ. 
\p  
\v 3 Agẹni ọlese ọ bhale ya migha atẹtẹ. Ọ tsua ilolo oyi ẹlomho. A ri afu ituale ne e bu na li ni ọ ya tosẹ, gbo li shi iromhi ni eni Ẹshinẹgba ọ she pfa na e sọ. Ọ la oni atẹtẹ ẹlomho ni o la oni eghiele tosẹ wẹ.\f + \fr 8:3 \ft Li zẹ \fq Emọ 9.1; Okiali 30.1,3\f* 
\v 4 Ewọli eyi oni ituale afu ẹẹra ni aa tosẹ ali iromhi eyi eni Ẹshinẹgba ọ she pfa na, e rọte obọ oyi ọni agẹni nga idane deba Ẹshinẹgba.  
\v 5 Ighọ ọni agẹni ọ rue oni ilolo, ọ wẹ erali ni e la ukhomhi oni atẹtẹ vọ ọ. Ọ pfi ọli tiemhi ekẹ agbọ, ighọ ikphala e de, ali ingmolo, ali inyamhise alo amẹ, ali ekẹ ikuluẹ.\f + \fr 8:5 \ft Li zẹ \fq iLẹv 16.12; Ezik 10.2; Okiali 19.16; Irọ 11.19; 16.18\f* 
\s1 Eni ikala 
\p  
\v 6 Mena, igẹni oshilua ni e mhọli ikala ishilua e mu egbe ni e rọ pfi wẹ. 
\p  
\v 7 Agẹni ọnododẹ ọ pfi akala oyọli, echẹ amẹ ali erali e kuma ọlia wushe kugbe, e de ku shi ekẹkhẹ. Ukiẹkiẹ opfoghuo akemhishi esẹ oyi ekẹ agbọ, o to-a. Asheghuo akhemhi shi esẹ oyi ẹẹra nya e toa, ebuli nya e toa.\f + \fr 8:7 \ft Li zẹ \fq Okiali 9.23-25; Ezik 38.22\f* 
\p  
\v 8 Agẹni ọnuzi ava o pfi akala oyọli, emini o li abi ute o lala, a pfi ọli lo okẹ oniẹmhi. Ukiẹkiẹ oghuo ini a kemhi oni okẹ oniẹmhi shi asha esẹ o mele ọlia-a  
\v 9 asheghuo akemhi shi esẹ elamhakọ ni e laọ e ghuloa, asheghuo akemhishi esẹ ọkọ-okẹ eniẹmhi ni e la oni okẹ e tsẹkẹ-a. 
\p  
\v 10 Agẹni ọnuzasẹ ọ pfi akala oyọli, ukpokpomhi ukpẹtata ni o lala abi ugbili, o rọte idane pfa, o de ya shi asheghuo akemhi okẹ nya shi asha-esẹ ali inu wẹ ni okẹ e te ẹ chọchọ.\f + \fr 8:10 \ft Li zẹ \fq Aza 14.12\f* 
\v 11 Eva oyi ọni ukpẹtata a lu Oyala. Asheghuo akemhi-shi esẹ amẹ eyi okẹ nya ni o de pfilo eghọ e yala, ebubu ẹgbọ e ghuloa irari khi eni amẹ okẹ e yala.\f + \fr 8:11 \ft Li zẹ \fq iJere 9.15\f* 
\p  
\v 12 Agẹni ọnuzi-aane o pfi akala oyọli, a gbe emhi shi asheghuo akhi ovọ-a shi asha esẹ, ali akhi uki-a shi asha esẹ, ali akhi ikpẹtata-a shi asha esẹ. Eni asha esesesẹ ena e bishi-a. A khi ogbe-a shi asha esẹ, o bi obili-a, ighọ a li li khi ẹliyọsẹ-a shi asha esẹ, ákpá ọa gẹ.\f + \fr 8:12 \ft Li zẹ \fq Aza 13.10; Ezik 32.7; iJọẹ 2.10,31; 3.15\f* 
\p  
\v 13 Abi mhi li bino eghọ, mhi suọ khi ākpā ọ̄degbe ni ọ la irarogbe fiala, ọ viẹ, ọ liẹ, “Epfua, Epfua! Epfua o khi na eni e la ekẹ agbọ itobọ ikala ni igẹni aasẹ enekpọle e ya pfi.” 
\c 9  
\p  
\v 1 Agẹni ọnuzi-oshe ọ pfi akala oyọli. Mhi mẹ ukpẹtata ni o rọte idane de tiemhile ekẹkhẹ. A ri okpẹ oyi odẹ oyi ilimhi na ningọlọ na li.  
\v 2 Abi ọ rọ khueghie odẹ oyi oni ilimhi na ningọlọ-a, ewọli e rọte ọ lasele abi ewọli ni e rọte avuerẹ lasele. Ovọ ali irarogbe e bishi-a irari eni ewọli ni e rọte oni ilimhi na ningọlọ lasele.\f + \fr 9:2 \ft Li zẹ \fq Igbae 19.28\f* 
\v 3 Initso e rọte eni ewọli vẹ ẹ kule ekẹ agbọ, a ri afu na wẹ ni e rọ mhuẹ ekpabọ nabi eyi izage.\f + \fr 9:3 \ft Li zẹ \fq Okiali 10.12-15\f* 
\v 4 A gueyẹ wẹ e khi ri unu ti ebuli ali emhi ẹkọmhi ọkhọghuo wẹkhi ọọra na ekẹ agbọ, ama e ke nasẹ ẹgbọ ni ẹa mhọli ọlẹlẹ oyi Ẹshinẹgba shi alukpo oyẹwẹ.\f + \fr 9:4 \ft Li zẹ \fq Ezik 9.4\f* 
\v 5 Aa liẹ wẹ e gbolo eni ẹgbọ ena-a, ama ni e rọ nasẹ wẹ iki ishe. Utomhi ni e to wẹ, eri e li abi utomhi oyi okpi ini ọ ta ọgbọ.  
\v 6 Ẹghẹghẹ ni a ngme ena, ẹgbọ e ya ke nono eghuli ama ẹa ya mẹ, o ya ghọle wẹ ni e ghu-a ama eghuli o ya mẹ wẹ na.\f + \fr 9:6 \ft Li zẹ \fq iJobu 3.21; iJere 8.3\f* 
\p  
\v 7 Eni initso e li abi ichi ni a mu egbe shi okhọli. E rughu emini o li abi arula oghie igolu shi ukhomhi, alo eyẹwẹ e li abi alo ẹgbọ.\f + \fr 9:7 \ft Li zẹ \fq iJọẹ 2.4\f* 
\v 8 Itsu eyẹwẹ e li abi itsu eyi ikpotso, akọ eyẹwẹ e li abi akọ idumhi.\f + \fr 9:8 \ft Li zẹ \fq iJọẹ 1.6\f* 
\v 9 E zẹ ipfiapfia shi egbe abi awulu akhuli ni ọkhọli-okhuẹ ọ rọ a mu aye. Okeke ni ipfua eyẹwẹ e kpe, e li abi okeke oyi ichi ikhuli ni e lo bu ni e na lẹ okhuẹ.\f + \fr 9:9 \ft Li zẹ \fq iJọẹ 2.5\f* 
\v 10 E zẹ ighia ali ẹka, ee ta abi ikpi, e mhọli ekpabọ shi eni ighia ni e rọ na ẹgbọ osoli iki ishe.  
\v 11 E mhọli oghie ọyẹwẹ ni ọ khi agẹni oyi ilimhi na ningọlọ. Abi a lu eva oyọli o khi Abadọni a lu ọli ẹlẹmhi Iburu. Ama Apoliọni a lu ọli ẹlẹmhi iGiriki. (Ọni ọ Yese-a a ri ona ngme.) 
\p  
\v 12 Epfua onododẹ ó she dọsẹ, ama epfua eva elese ẹa bhale ne. 
\s1 Akala onuzi-esesa 
\p  
\v 13 Agẹni ọnuzi-osasa ọ pfi akala oyọli, mhi suọ khi uruli o rọte igo ene oyi atẹtẹ igolu ni o kpọ ekẹ le ni o la odalo oyi Ẹshinẹgba ngme lasele.\f + \fr 9:13 \ft Li zẹ \fq Okiali 30.1-3\f* 
\v 14 Ọ gueyẹ ọni agẹni ọnuzi-osasa ọghọ ọọ li, “Taghiẹ igẹni aane ni a gẹ shi epfẹ okẹ oniẹmhi na lu iYufiretisi-a.”  
\v 15 Ighọ a li rue eni igẹni aane eghọ obọ-a, ni a she gẹ shi aghọ, rọ khẹ oni ẹghẹghẹ ona, ali ogbẹlẹ ali uki ona, ali ukpe ona, ni e ya gbolo ẹgbọ igbekhi esẹ na ekẹ agbọ ona-a.  
\v 16 Ekhọli-okhuẹ etuangmẹ ni a rọ shi ekẹ ẹ khẹ okhọli e bu ramhi udududu asha egbhuẹgbe, 200,000,000. Mhi suọ etuangmẹ ni a lu wẹ. 
\p  
\v 17 Abi eni ichi ali eni e nga wẹ e li na, abi mhi mẹ wẹ elemhi imẹalo oyẹmhẹ. Iwulu ikhuli ni ekhọli-okhuẹ e rọ ọ mu aye eyẹwẹ, ee yilẹ nyọghọ abi erali, e li abi ẹgholi ibulu na koli, o mhọli oyilẹ abi ófu. Ikhomhi eyi eni ichi e li abi ikhomhi idumhi, erali, ewọli ali ofulu e rọte wẹ unu lasele.  
\v 18 Igbekhi asha esẹ ẹgbọ nya, eni erali ali ewọli ali ofulu ni e rọte wẹ unu lasele e gbolo-a.  
\v 19 Ekpabọ eyi eni ichi e la wẹ unu ali ighia. Irari khi eri ighia eyẹwẹ e li abi enyẹ, e zẹ ikhomhi ni e rọ kuale ẹgbọ utse. 
\p  
\v 20 Ẹgbọ ni e kpọle shi agbọ ni oni opfuse ọa gbolo-a, ẹa kie mu pfi lase ikanya abọ eyẹwẹ le. Ẹa lase ekphaghiẹ igaga le, li shi ugamhi eyi ikhumhi ni a ri igolu ali ẹlomho ali idẹ ali ẹẹra khali. Ikhumhi ni ẹa ya mẹ ekẹ wẹkhi eri ẹẹ suọ esọ, wẹkhi eri e dobẹ ẹ kia.\f + \fr 9:20 \ft Li zẹ \fq Iwolo 115.4-7; 135.15-17; iDan 5.23\f* 
\v 21 Wẹkhi eri e lama mu pfi lase ugbeli le, ali imhẹsẹ imumu ali itsẹbọ ilili ali ighiatọ idodo. 
\c 10  
\s1 Ọni agẹni ali ebe nikeke 
\p  
\v 1 Ighọ mhi mẹ agẹni nọfunẹ ọlese, khi ọ rọte idane e tiemhile, ọ ri otughunu khukhu egbe, ogaji o vi gasẹ ọli ukhomhi, alo eyọli e li abi ovọ, awẹ eyọli e li abi ọchẹ erali.  
\v 2 Ọ mhọli ukuku ebe mhọli obọ ni o khueghie-a shi ekẹ. Ọ gbọsẹ owẹ obita oyọli shi elemhi okẹ oniẹmhi, ọ ri owẹ ọgobọ nga ekẹ.  
\v 3 Ọ ri ukpokpomhi uruli pfie lasele leghe abi ọdumhi ọọ khoshẹ. Abi ọ rọ pfie, uruli ikphala ishilua e ngme.  
\v 4 Abi eni ikphala ishilua e rọ ngme se, mhi nono ni mhi kẹkẹ shi ebe, ama mhi suọ khi uruli ọ rọte idane liẹ, “Ri emini eni ikphala ishilua eghọ e ngme sheli, khi kẹkẹ wẹ shi ekẹ.” 
\p  
\v 5 Ighọ ọni agẹni ni mhi mẹ ni ọ migha okẹ oniẹmhi ali ekẹkhẹ eghọ, ọ yasẹ obita oyọli nga ukhui.  
\v 6 Ọ ri eva oyi Ẹshinẹgba ni ọ laọ le ẹlẹ na agbọagbọ romhi ishe. Ọni ọ ma ukhui ali emhikpa ni e laọ, ali ekẹ ali emhikpa ni e la ọ ali okẹ oniẹmhi ali emhikpa ni e laọ. Ọọ, “Emhi enana ẹa ke ya tẹsẹ ni e rọ bhale ya tsẹ.  
\v 7 Ama khi ogbẹlẹ ni agẹni ọnuzi-oshilua ọ da ya pfi akala oyọli, Ẹshinẹgba ọ ya khueghie osheli oyọli-a ni ọ gba abi ọ li gue ọli yẹ eni ẹẹ ga ni e khi emekẹguele eyọli.”\f + \fr 10:7 \ft Li zẹ \fq Okiali 20.11; iDẹut 32.40; iDan 12.7; Emọ 3.7\f* 
\p  
\v 8 Ighọ uruli ni mhi rọte iloghie suọ eghọ o gbo nu mhẹ ngme, ọọ mhẹ, “Lẹ ya mie agẹni ni ọ migha okẹ oniẹmhi ali ekẹkhẹ ighẹlẹ ebe ni o khueghie-a, ni o la li obọ.” 
\p  
\v 9 Ighọ mhi lẹ deba ọni agẹni mhiẹ ọ ri oni ebe nikeke oghọ na mhẹ. Ọọ mhẹ, “Mọ ọli le. O ya yese ẹ elemhi-a, ama o ya viọlọ ẹ unu abi iwọ.”  
\v 10 Mhi mie ọni agẹni oni ebe nikeke obọ, mhi rọli le. O viọlọ mhẹ unu abi iwọ, ama abi mhi rọ rọli le se, oo yala mhẹ elemhi.\f + \fr 10:10 \ft Li zẹ \fq Ezik 2.8--3.3\f* 
\v 11 Ighọ a gueyẹ mhẹ, “U mema ya mekẹguele shi ebubu unuẹkpẹ, ali ẹgbọ ali ẹmuẹ ọdọda ali ighie egbe.” 
\c 11  
\s1 Eni ọtsẹlẹ aava 
\p  
\v 1 Ighọ a ri ufulọ ni o li abi ukpokpo ni a rọ ọ mhẹsẹ emhi na mhẹ, a gueyẹ mhẹ, “Lẹ ya mhẹsẹ Owa Ugamhi oyi Ẹshinẹgba ali atẹtẹ ali eni ẹ ga ugamhi akaghọ.\f + \fr 11:1 \ft Li zẹ \fq Ezik 40.3; iZaka 2.1-2\f* 
\v 2 Khi mhẹsẹ atukpapfẹ oniẹmhi oyọli, khi mhẹsẹ ọli irari khi a she rọli na iJẹta. Wẹwẹ e ya lighi oni ẹoli no pfuasẹ ekẹ-a elemhi iki egbhuẹva ali eva (42.)\f + \fr 11:2 \ft Li zẹ \fq iLuk 21.24\f* 
\v 3 Mhi ya ri afu na ọtsẹlẹ aava eyẹmhẹ. E ya mekẹ guele elemhi ogbẹlẹ agbẹlẹ ali egbhuẹgbẹsẹ (1,260.) E sọ ide ibuma.”  
\v 4 Ọtsẹlẹ aava ena e khi ẹẹra olivu eva ali emhi eva ni a ri ákpá ru ẹ nga ni e migha odalo oyi Ọnọmhuẹ ni ọ mhuẹ ekẹ agbọ.\f + \fr 11:4 \ft Li zẹ \fq iZaka 4.3,11-14\f* 
\v 5 Ini ọgbọkhọghuo ọọ dua ni lọli kwale wẹ utse, erali e rọte wẹ unu fiẹ ya tosẹ eni ebe wẹ-a. Ina ebe wẹ ni e nono ni e kwale wẹ utse e mema li ya ghua.  
\v 6 E mhọli afu ni e rọ pfi okpẹ ukhui ini amẹ o khi ruẹ ẹghẹghẹ ni e rọ da mẹ guele ne. E gbo mhọli afu ni e rọ mu amẹ okẹ mele ọlia-a. E gbo ku ighuamhi khi ighuamhi she ekẹ abi o li ghọle wẹ shi.\f + \fr 11:6 \ft Li zẹ \fq 1 Ighie 17.1; Okiali 7.17-19; 1 iSam 4.8\f* 
\p  
\v 7 Ini e da pfi ọ ọtsẹlẹ se ne, inyagbemhi ni ọ ya rọte ilimhi na ningọlọ lasele ọ ya tsua mu wẹ, ọ mu wẹ ọ le, ọ gbolo wẹ-a.\f + \fr 11:7 \ft Li zẹ \fq iDan 7.7,21; Irọ 13.5-7; 17.8\f* 
\v 8 Ilimhi eyẹwẹ e ya de yẹshi ifui ẹoli ni o funẹ ashini a la gbe Ọnọmhuẹ ọyẹwẹ-a shi apfida. Irọkhọkhọ iSodomu ali iJipiti ẹoli ona o khi.\f + \fr 11:8 \ft Li zẹ \fq Aza 1.9-10\f* 
\v 9 Ogbẹlẹ esẹ ali ukhukui, ẹgbọ na agbọ nya ali ẹdẹli ali ẹmuẹ ali ushishi e ya ke nise uruli bino ilimhi eyẹwẹ, ẹa lama rẹwẹ tọ.  
\v 10 Ẹgbọ na ekẹ agbọ e ya ke ghẹlẹ shi eghuli ni e ghu, ẹẹ bọla, e dẹ isomhopfa a ghi egbewẹ, irari khi emekẹguele aava eghọ, e she nasẹ ẹgbọ ni e la ekẹ agbọ khue. 
\p  
\v 11 Ama abi ẹlẹ esẹ ali ukhukhui e rọ dọsẹ, Ayẹmhẹ oyi Ẹshinẹgba ni mhọli agbọ o lo wẹ egbe, e vule migha. Ulishi oniẹmhi o lo ẹgbọ ni e mẹ wẹ egbe.\f + \fr 11:11 \ft Li zẹ \fq Ezik 37.10\f* 
\v 12 Ighọ e suọ uruli na leghe o rọte idane ngme. Ọọ wẹ, “Ngale odane oola.” Ighọ e li nga idane elemhi otughunu. Ebe wẹ e lẹsẹ fẹ kpee.\f + \fr 11:12 \ft Li zẹ \fq 2 Ighie 2.11\f* 
\p  
\v 13 Oni ẹghẹghẹ a mẹ ukpokpomhi inighise ekẹ ni o ku ekẹ asheghuo akemhishi igbe oyi oni ẹoli luẹ. Ẹgbọ agbẹlẹ oshilua, 7,000, e ghuloa, ulishi o mu ẹgbọ ni e kpọle, e kuẹghiẹ Ẹshinẹgba ni o la iloghie. 
\p  
\v 14 Opfuse onuzi-eva o she dọsẹ, opfuse onuzi-esẹ o kẹlẹ ya bhale. 
\s1 Akala onuzi-ishilua 
\p  
\v 15 Ighọ agẹni ọnuzi-oshilua o pfi akala oyọli, ighọ ikpokpo iruli e la idane ngme. Ee liẹ, 
\q1 “Eghiele agbọ o she mele 
\q2 eghiele oyi Ọnọmhuẹ ọyawa-a, 
\q2 ali onayi iKirisiti ọyọli-a. 
\q1 Ọ ya mhẹsẹ ke le agbọagbọ.”\f + \fr 11:15 \ft Li zẹ \fq Okiali 15.18; iDan 2.44; 7.14,27\f* 
\m  
\v 16 Egbhali uye ali aane ni e shitọ ukpẹkhomhi oyẹwẹ odalo Ẹshinẹgba, e de ya ta alo mu ekẹ ga Ẹshinẹgba.  
\v 17 Ee liẹ, 
\q1 “Anye ri ikphẹmhi nẹ, 
\q2 Ẹshinẹgba Ọnọmhuẹ Nọfunẹ nya, 
\q2 Ọni ọ khi lọli, ọni ọ kpẹ khi lọli, 
\q1 irari khi u she rue 
\q2 ekpabọ eniẹmhi eyẹ, 
\q2 u she ẹ mhẹsẹ. 
\q1  
\v 18 Abi elemhi e rọ bi ishishi, 
\q2 yẹyẹ u li mhọli ofu.\f + \fr 11:18 \ft Li zẹ \fq Iwolo 2.5; 110.5; 115.13\f* 
\q1 Ẹghẹghẹ o she ramhi 
\q2 ni u rọ ya guẹ eni eghua ẹzọ, 
\q1 ni u rọ ya ri eleli na eni ẹẹ ga eyẹ 
\q2 ni e khi emekẹguele, 
\q1 ali eni Ẹshinẹgba ọ she pfa na 
\q2 ni e ri ekpẹ na eva oyẹ, 
\q1 ghe ẹgbọ ni ẹa mu ẹloe 
\q1 ali ekhẹmhuẹ, 
\q1 abi u li pfuse eni e pfuse ekẹ agbọ-a.” 
\p  
\v 19 Ighọ a li khueghie Owa ugamhi oyi Ẹshinẹgba na iloghie-a, a mẹ Akpati Ishobọ aghọ. Ighọ inyamhisalo ali ukpimhi ali ingmolo ali ikphala, ekẹ e de kuluẹ, echẹ rọte idane deno kule.\f + \fr 11:19 \ft Li zẹ \fq Irọ 8.5; 16.18,21\f* 
\c 12  
\s1 Ọni Ọkpotso ali Oligio ọniẹmhi 
\p  
\v 1 Ukpokpomhi irọkhasẹ ọnyaloa o feli shi idane: Ọkpotso ọ ya laọ ni itsua ni ọ sọ e khi ovọ, uki o kpọkẹ awẹ eyọli, arula oghie oyi ikpẹtata igbẹva o rughu ọli ukhomhi.  
\v 2 Ọọ mẹ. Ọ tsẹsẹ leghe elemhi ọtomhẹ abi ọ rọ ya bia.  
\v 3 Ighọ emhi olese o gbo feli shi idane, ukpokpomhi Oligio ọniẹmhi ọyilẹ ni ọ zẹ ikhomhi ishilua ali ekphali igbe, ali ọ rughu irula oghie ishilua shi ukhomhi.\f + \fr 12:3 \ft Li zẹ \fq iDan 7.7\f* 
\v 4 Ọ ri ughia oyọli fuomhi asheghuo akemhishi esẹ ikpẹtata ni e la ukhuli pfino kule ekẹ agbọ. Ọni Oligio ọniẹmhi ọ migha ọni ọkpotso ni oku ọ to eghọ odalo, ni o ba mẹ asha gbe ọli ọni ọmọ ọghọ le, ini a lẹsẹ bia li lasele.\f + \fr 12:4 \ft Li zẹ \fq iDan 8.10\f* 
\v 5 Ọni ọkpotso ọ bia ọmọse ni ọ ya ri ọtsuọdu akhuli mhẹsẹ na ẹgbọ ni e la ekẹ agbọ nya. Ama a ba ọni ọmọ ekẹ rue ya nga idane ghi Ẹshinẹgba ali ukpẹkhomhi eghiele oyọli.\f + \fr 12:5 \ft Li zẹ \fq Aza 66.7; Iwolo 2.9\f* 
\v 6 Ọni ọkpotso, ọ na je ọdagbe ifufu asha ni Ẹshinẹgba o riẹlẹ shi ekẹ khẹ ọli ni a la ya dua li egbe ogbẹlẹ agbẹlẹ ali egbhuẹgbẹsẹ (1,260.) 
\p  
\v 7 Ighọ okhọli o lasele shi obini iloghie, iMakiẹni ali igẹni eyọli, e nu ọni inyagbemhi i khọli. Ọni Oligio ọniẹmhi ali igẹni eyọli e mie wẹ abọ oni okhọli.\f + \fr 12:7 \ft Li zẹ \fq iDan 10.13,21; 12.1; iJu 9\f* 
\v 8 Ama ọa mhuẹ ekpabọ tẹ iMakẹni ali igẹni eyọli oni okhọli. Ashini a kpẹ rọ na wẹ obini iloghie o de wẹ obọ-a.  
\v 9 A pfi ọni ukpokpomhi ọni Oligio ọniẹmhi ọghọ tiemhile ekẹ agbọ, ọni ẹnyẹ ọnẹdẹ ọghọ ni a lu Etse ali Ọkphaghiẹ, ọni ọ di agbọ nya ya da odẹ, a pfi oli tiemhile ekẹ agbọ, a li pfi igẹni eyọli li tiemhile.\f + \fr 12:9 \ft Li zẹ \fq Igbae 3.1; iLuk 10.18\f* 
\v 10 Ighọ mhi suọ ukpokpomhi uruli obini iloghie khi ọọ li, 
\q1 “Mena, imiepfuese 
\q2 ali ekpabọ ali 
\q1 Eghiele oyi Ẹshinẹgba ọyawa 
\q2 e she bhale! 
\q1 IKirisiti ọyọli ni ọ zẹ 
\q2 ọ she ri afu oyọli khasẹ. 
\q1 Irari khi Ọkphaghiẹ, 
\q2 ni ọ gue ẹzọ ọ shi 
\q2 inyọghuo awa egbe, 
\q1 odalo oyi Ẹshinẹgba 
\q2 ghe ẹlẹ ọguota ghe ẹlẹ-iyọsẹ, 
\q2 a she pfi ọli tiemhile.\f + \fr 12:10 \ft Li zẹ \fq iJobu 1.9-11; iZaka 3.1\f* 
\q1  
\v 11 E gbe ọli mu ọli le, 
\q2 itobọ ọlia eyi ọni Omi Osumha 
\q2 ali ingmemhi ọtsẹlẹ oyẹwẹ. 
\q1 Ẹa lighọ nono ingme agbọ oyẹwẹ, 
\q2 ni o rẹwẹ ya ke 
\q2 ti je ukhokho na eghuli. 
\q1  
\v 12 Irarighọ, a ke ghẹlẹ, 
\q1 ẹẹ iloghie ali ẹgbọ 
\q2 ni e la elemhi ọli. 
\q1 Ama epfua o khi na 
\q2 ẹ ekẹ ali okẹ oniẹmhi, 
\q1 irari khi Ọkphaghiẹ 
\q2 ọ she ri ofu tiemhie deba ẹ! 
\q1 Ofu o she vọ li elemhi, 
\q2 irari khi ọ lẹsẹ khi 
\q2 ukuku ẹghẹghẹ ọ ke mhọli.” 
\p  
\v 13 Abi ọni Oligio ọniẹmhi ọ rọ mẹ khi a she pfi luẹ tiemhile ekẹ, ọ khu ọni ọkpotso ni ọ bia ọni ọmọ ọmọse.  
\v 14 Ama a ri ipfua eva eyi ākpā ọ̄degbe ọniẹmhi na li, ni ọ rọ fiala je ọdagbe ifufu. Ikhi obini a riẹlẹ shi ekẹ khẹ ọli ni a la ya ri ẹloe khu ọli, ẹghẹghẹ ali ighẹghẹ ali ukhukhui ẹghẹghẹ ni o khi ikpe esẹ ali ukhukhui, ini ọni inyagbemhi ọ khi ri emhi li ọ.\f + \fr 12:14 \ft Li zẹ \fq iDan 7.25; 12.7\f* 
\v 15 Ọni Oligio ọniẹmhi ọ rọte unu ku amẹ lasele abi okẹ ni oo tu, rọ khu ọni ọkpotso ni o ba ri ochikpho fuomhi ọli ya gbe.  
\v 16 Ama ekẹ o kpaghiẹ ọni ọkpotso obọ irari khi ekẹ o nya unu-a ri oni okẹ da ni ọni Oligio ọniẹmhi ọ rọte unu kpa ku le.  
\v 17 Ighọ ọni inyagbemhi ọ pfaa deba ọni ọkpotso, ọ ya mu okhọli vule shi imi ọli enekpọle ọ, ikhi eni e ri Omhẹsẹ eyi Ẹshinẹgba gbe akanya, ni e ri igẹsikia mu ọtsẹlẹ oyi iJesu.  
\v 18 Ighọ ọni Oligio ọniẹmhi ọ migha egele okẹ oniẹmhi. 
\c 13  
\s1 Ọni Inyagbemhi ni ọ rọte okẹ oniẹmhi lasele 
\p  
\v 1 Mhi mẹ inyagbemhi khi ọ rọte elemhi okẹ oniẹmhi ngale. Ọ zẹ ekphẹ igbe ali ikhomhi ishilua, ọ rughu irula oghie igbe shi eni ekphali. Ukhomhi ọgbọgbọ a kẹkẹ eva ni o khi ungmemhi ipfiunu-a shi.\f + \fr 13:1 \ft Li zẹ \fq iDan 7.3; Irọ 17.3,7-12\f* 
\v 2 Ọni inyagbemhi ni mhi mẹ, ọ li abi ẹkpẹ, awẹ eyọli e li abi eyi akpogene, unu oyọli o li abi unu ọdumhi. Ọni oligio ọniẹmhi ọ ri afu na ọni inyagbemhi ni o rọ mhọli ekpabọ rọ ke mhẹsẹ abi oghie.\f + \fr 13:2 \ft Li zẹ \fq iDan 7.4-6\f* 
\v 3 A kuale ọni inyagbemhi ukpokpomhi utse ni o gẹ ugboko oniẹmhi. Ama oni ugboko oghọ o bie. O ri abọ sha agbọ nya, e vẹ deba li.  
\v 4 Ẹgbọ ee ga ọni Oligio ọniẹmhi irari khi ọ she ri afu na ọni ẹlamhakọ, ẹgbọ e li ga ọni ẹlamhakọ, e liẹ, “Ọghuo ọ li abi ọni inyagbemhi!” “Ọghuo ọ dobẹ ya nu ọni inyagbemhi khọli?” 
\p  
\v 5 A ri unu na ọni ẹlamhakọ ni ọ rọ ngme ingmemhi ẹmuẹbe ali ipfiunu-a. A ri ẹghẹghẹ na li ni ọ rọ ri afu oyọli gbe akanya iki egbhuẹva ali eva.  
\v 6 Ọ khueghie unu-a, ọ ngme ipfiunu-a deba Ẹshinẹgba, rọ pfuẹchẹ eva oyi Ẹshinẹgba ali ashini ọọ la ali ẹgbọ ni e nu ọli la iloghie-a.\f + \fr 13:6 \ft Li zẹ \fq iDan 7.8,25; 11.36\f* 
\v 7 A ri afu na li ni ọ nu eni Ẹshinẹgba ọ she pfa na khọli, ali ni ọ mu wẹ ọ le. A ri afu na li ni ọ mhẹsẹ shi ẹdẹli nya, ẹgbọ ali ẹmuẹ ọdọda ali ishishi.\f + \fr 13:7 \ft Li zẹ \fq iDan 7.21\f* 
\v 8 Ẹgbọ ni e la ekẹ agbọ nya e ya ke ga ọni inyagbemhi. Eni ẹa ga ọni inyagbemhi ọna, e khi eni a kẹkẹ eva oyẹwẹ shi ebe ni a kẹkẹ eva oyi eni e ya mhọli agbọ na agbọagbọ shi, neni a ma agbọ. Oni ebe agbọ ona o khi ebe agbọ oyi Omi Osumha ni a rọ luasẹ obo.\f + \fr 13:8 \ft Li zẹ \fq Iwolo 69.28\f* 
\p  
\v 9 Ọni ọ mhọli esọ, ọ rọ suọ! 
\q1  
\v 10 Eni okhọli o ya mu, 
\q2 o mema ya mu wẹ. 
\q1 Eni a ya gbolo-a, 
\q2 a mema ri itakobi 
\q1 ya gbolo wẹ-a. 
\m Eri a ri ona liẹ eni Ẹshinẹgba ọ pfa na e ri irabọmudu ri egbe mie, e ri igẹsikia ke khasẹ.\f + \fr 13:10 \ft Li zẹ \fq iJere 15.2; 43.11\f* 
\s1 Ọni Inyagbemhi ni ọ rọte agbọ lasele 
\p  
\v 11 Ighọ mhi gbo mẹ inyagbemhi ọlese ni ọ rọte ekẹ ẹ lasele. Ọ zẹ ekphali eva abi omi osumha, ọọ ngme abi oligio ọniẹmhi.  
\v 12 Ọ ri afu oyi inyagbemhi ọni ododẹ ẹ gbe akanya na li. Ọ ri itoto ri ẹgbọ na ekẹ agbọ ọ ga inyagbemhi ọnododẹ, ikhi ọni ukpokpomhi ugboko oyọli o she bie.  
\v 13 Ọ riẹlẹ irọkhasẹ ọnyaloa enefunẹ, ọ ga ri erali rọte idane e tiemhile, ni ẹgbọ ee mẹ.  
\v 14 Itobọ irọkhasẹ ni a ri afu oyi inyagbemhi ọnododẹ lina a riẹlẹ, ọ di ẹgbọ ni e la ekẹ agbọ. Ọ gueyẹ wẹ e khali ikhumhi, rọ khi ufumhi na ọni inyagbemhi ni oni itakobi o kuali utse, ni ọ kie la agbọ.  
\v 15 A ri afu na li ni ọ ri ayẹmhẹ na oni ikhumhi irọkhọkhọ oyi ọni inyagbemhi ọnododẹ, ni ọ dobẹ ke ngme, ali ni a ke gbolo ẹgbọ ni ẹa lama ga li-a.  
\v 16 Ọ gbo ri itoto mu ọgbọkpa shi ọlẹlẹ shi obita okekhi alukpo, ghe ẹgbọ eniẹmhi ali enikeke, ghe eni ẹ mhọli ẹpfue ali eni ẹa mhọli, ghe eni ẹa khi ighumha ali eni e khi ighumha.  
\v 17 Ọgbọkhọghuo ọa dobẹ ke e dẹ emhikhọghuo wẹkhi eri ọ rọ ọ dẹ, sẹ ni ọni ọ mhọli ọlẹlẹ oghọ, ni o khi eva oyi ọni inyagbemhi ali inọba oyi eva oyọli. 
\p  
\v 18 Eri onana gueyẹ awa, awa mhọli ilẹsingme. Ọni ọ lolo lẹsẹ ingme ọ sa abi a ri oni inọba ona ngme. Oni inọba khi (666), egbhuẹ uye ali igbe ali egbhuẹsẹ ikpamhi esesa. Inọba ni o migha shi ọgbọ na. 
\c 14  
\s1 Ọni Omi Osumha ali eni ẹgbọ agbẹlẹ egbhuẹshilua ali ene (144,000) 
\p  
\v 1 Ighọ mhi bino. Ghe Omi Osumha odalo oyẹmhẹ khi ọ migha Ute iZayọ. Ẹgbọ 144,000 (agbẹlẹ egbhuẹshilua ali ene) ni a kẹkẹ eva oyọli ali eva oyi itali shi wẹ alukpo e nu ọli migha.\f + \fr 14:1 \ft Li zẹ \fq Ezik 9.4; Irọ 7.3\f* 
\v 2 Mhi ya rọte idane suọ uruli abi ikhoshẹ oyi utumhi oyi okẹ nofunẹ ni o rọte ikhomhi echẹ tu ẹ tiemhile. Oo ngmolo abi akphala. Oni uruli ni mhi suọ, o li abi ini eni ẹ kpheli ẹfa, ẹẹ kpheli ẹfa.  
\v 3 E to uwolo onogbọ odalo ukpẹkhomhi oghie ali ukpẹloe oyi eni elamhakọ aane ni Ẹshinẹgba ọ ma ali ukpẹloe oyi eni egbhali. Ọgbọkhọghuo ọa dobẹ wẹna oni uwolo oghọ, sẹ ni ẹgbọ agbẹlẹ egbhuẹshilua ali ene eghọ (144,000), ni a she rọte ekẹ agbọ pfashekẹ.  
\v 4 Enana e khi ẹgbọ ni ẹa ri ikpotso ri ichimhi mu egbewẹ, irari khi eri e ri egbewẹ shi ipfuasẹ. E deba ọni Omi Osumha a je obiobini ọ je kpa. Eni a rọte ifuabọ ẹgbọ pfashekẹ e khi ni a rọte ododẹ rọ na Ẹshinẹgba ali ọni Omi Osumha pfo.  
\v 5 Ọgbọ ọa mẹ ẹgbhọli okhọghuo unu oyẹwẹ, irari khi ẹa mhọli umhaguẹli okhọghuo.\f + \fr 14:5 \ft Li zẹ \fq iZef 3.13\f* 
\s1 Eni Igẹni Aasẹ 
\p  
\v 6 Ighọ mhi mẹ agẹni ọlese khi ọ la iteva irarogbe ẹ fiala, ọ mhuẹ usomhi onete na agbọagbọ ni ọ rọ ya tsabọ gueyẹ ẹgbọ na agbọ, ikhi eni e la ishishi nya, ali ẹdẹli nya, ali ẹmuẹ-khi-ẹmuẹ ali ẹgbọ kpa.  
\v 7 Ọ ri ukpokpomhi uruli liẹ, “Na ulishi Ẹshinẹgba, ri ufumhi nali, irari khi ẹghẹghẹ iguẹzọ oyọli o she ramhi, a ke ga ọni ọ ma idane ali ekẹ ni ọ ma okẹ oniẹmhi ali ashini amẹ o te ẹ chọchọ.” 
\p  
\v 8 Agẹni ọlese ọnuzava ọ deba li, ọọ, “IBabilọ okẹkhui o de, ọni ọ ri onyọ ni ọa pfuasẹ oyọli ona okia na ishishi nya da.”\f + \fr 14:8 \ft Li zẹ \fq Aza 21.9; iJere 51.8; Irọ 18.2\f* 
\p  
\v 9 Agẹni ọnuzi-aasẹ ọ deba wẹ, ọ ri ukpokpomhi uruli liẹ, “Ini ọgbọkhọghuo ọ ga ọni inyagbemhi ali ikhumhi oyọli, ni ọ rọ mie ọlẹlẹ oyọli shi alukpo, okekhi obọ,  
\v 10 ọni ọgbọ oghọ, ọ ya rọte onyọ elemhi ibibi oyi Ẹshinẹgba li da, ikhi onyọ ni aa pfọsẹ-a ni a she ku vọ uko elemhi ibibi oyọli. A ya ri ofulu ni ọọ lala biobiobio tosẹ ọli-a ukpẹloe oyi igẹni eni e pfuasẹ ali ukpẹloe oyi ọni Omi Osumha.\f + \fr 14:10 \ft Li zẹ \fq Aza 51.17; Igbae 19.24; Ezik 38.22\f* 
\v 11 Ewọli oyi anasẹmhẹ eyẹwẹ ee nga idane agbọagbọ. Eni e ga ọni inyagbemhi ali inyagbemhi ni a khali, ali ọnini ọ da mie ọlẹlẹ oyi eva eyọli ne, ẹa mhuẹ iyẹmhẹa shi ẹlẹọguota, shi ẹliyọsẹ.”\f + \fr 14:11 \ft Li zẹ \fq Aza 34.10\f* 
\v 12 Eri onana o gueyẹ eni Ẹshinẹgba ọ pfa na e ri irabọmudu ri egbe mie, ikhi eni e ri omhẹsẹ eyi Ẹshinẹgba a gbe akanya, ni e ri igẹsikia a deba iJesu. 
\p  
\v 13 Ighọ mhi suọ khi uruli o rọte idane liẹ, “Kẹkẹ onana: Ikhivọsẹ o khi na eni e ghu-a shi elemhi Ọnọmhuẹ rọte memena vu.” 
\p “Ikhivọsẹ o khi na wẹ egbegbọ!” “Ighọ Ayẹmhẹ ọ ngme, khi e ya yẹmhẹ inyama-egbe agbọ-a, irari khi eminete ni e riẹlẹ, e ya deba wẹ!” 
\s1 Ikhiẹsẹ oyi ekẹ agbọ 
\p  
\v 14 Ighọ mhi bino, mhi mẹ otughunu opfopfo odalo oyẹmhẹ. Ọni ọ shitọ ọ, “Ọ li abi Omi Ọgbọ.” Ọ rughu arula igolu oyi oghie shi ukhomhi, o ri agaga ni ọọ mu mhọli obọ.\f + \fr 14:14 \ft Li zẹ \fq iDan 7.13\f* 
\v 15 Agẹni ọlese ọ rọte Owa oyi Ẹshinẹgba lasele ri ukpokpomhi uruli lu ọni ọ shitọ nga ukhomhi otughunu eghọ leghe, ọọ li, “Rue agaga oyẹ ni u ke khiẹsẹ, irari khi ẹghẹghẹ ikhiẹsẹ o she ramhi, irari khi agbọ o she bie ni a khiẹsẹ.”\f + \fr 14:15 \ft Li zẹ \fq iJọẹ 3.13\f* 
\v 16 Ighọ ọni ọ shitọ otughunu eghọ, ọ ri agaga oyọli khiẹsẹ agbọ. 
\p  
\v 17 Agẹni ọlese ọ rọte Owa oyi Ẹshinẹgba na iloghie fiẹ lasele, lọli ọ li mhọli agaga ni ọọ mu.  
\v 18 Ighọ agẹni ọlese o rọte atẹtẹ fiẹ lasele, ikhi agẹni ni ọ mhọli omhẹsẹ shi erali. Ọ ri uruli oniẹmhi lu ọni o mhọli agaga ni ọọ mu eghọ leghe, ọọ li, “Rue agaga oni ọọ mu oyẹ, ni u rọ khiẹsẹ ipfonu ekẹ agbọ-a, irari khi ipfonu e she yilẹ!”  
\v 19 Ighọ ọni agẹni ọ pfi agaga oyọli gasẹ ekẹ agbọ, ọ khiẹsẹ ipfonu nya, ọ ku wẹ lo ashini a te ẹ mino onyọ. Amino onyọ ona, elemhi ibibi oyi Ẹshinẹgba o migha shi.  
\v 20 Ighọ a la ashini a la amino onyọ ni o la olase oni ẹoli ri awẹ gue wẹ. Ọlia e rọte oni amino onyọ tu lasele. Utumhi oyi oni ọlia o ga nuata ramhi imali egbhuẹgbe, e limhi abi ẹtẹ-awẹ ishe.\f + \fr 14:20 \ft Li zẹ \fq Aza 63.3; iLamẹ 1.15; Irọ 19.15\f* 
\c 15  
\s1 Igẹni oshilua ni e tsua anasẹmhẹ ishilua 
\p  
\v 1 Ighọ, mhi mẹ irọkhasẹ oniẹmhi ni o mu ẹloe olese ukhomhi idane, ikhi igẹni oshilua ni e mhọli anasẹmhẹ ishilua ni e khi eni e kpukhokho, irari khi wẹwẹ Ẹshinẹgba ọ rọ ya gbe ofu oyọli ukhomhi.  
\v 2 Mhi mẹ emini o li abi okẹ ighegbe oniẹmhi ni erali e sọlọ shi, o migha epfẹ okẹ oniẹmhi. Ẹgbọ ni e mu ọni inyagbemhi ali oni ikhumhi oyọli ali inọba oyi eva oyọli ọ le, e mu ẹfa ni Ẹshinẹgba ọ rọ na wẹ mhuẹ abọ.  
\v 3 E to uwolo oyi iMosisi ọni ọọ ga oyi Ẹshinẹgba ali uwolo oyi ọni Omi Osumha, e liẹ, 
\q1 “Ufumhi ali ọshabọ 
\q2 e khi ikanya eyẹ, 
\q2 Ẹshinẹgba Ọnọmhuẹ Nọfunẹ nya. 
\q1 Ipfuasẹ ali igẹsikia 
\q2 odẹ eyẹ e khi, 
\q2 oghie ni ọ mhọli ishishi nya!\f + \fr 15:3 \ft Li zẹ \fq Okiali 15.1\f* 
\q1  
\v 4 Ọghuo ọa ya na 
\q2 ulishi oyẹ Ọnọmhuẹ, 
\q1 ni ọa ya ri ufumhi 
\q2 bhale ghi eva oyẹ? 
\q1 Irari khi yẹyẹghuo kpele 
\q2 u khi ọni ọ pfuasẹ. 
\q1 Ishishi nya e ya bhale 
\q1 ya kuẹghiẹ ẹ, irari khi 
\q2 ikanya ipfuasẹ eyẹ 
\q2 e she ri egbe khasẹ.”\f + \fr 15:4 \ft Li zẹ \fq iJere 10.7; Iwolo 86.9\f* 
\p  
\v 5 Onana o dọsẹ se, mhi bino, mhi mẹ Owa oyi Ẹshinẹgba na iloghie, ni o khi Igholo oyi ọtsẹlẹ khi o khueghie-a.\f + \fr 15:5 \ft Li zẹ \fq Okiali 38.21\f* 
\v 6 Rọte oni owa ugamhi, eni igẹni oshilua ni e mhọli anasẹmhẹ ishilua e te lasele. E sọnọ itsua ni e pfuasẹ ni ẹẹ gẹ nyanyanya, e ri ọgbẹnẹ igolu mu aye.  
\v 7 Ighọ ọtuọghuo eni elamhakọ aane ni e mhọli ayẹmhẹ eghọ, e ri italabi igolu ishilua ni ofu oyi Ẹshinẹgba e la, na eni igẹni oshilua. Ikhi Ẹshinẹgba, ni ọ laọ lẹ agbọagbọ.  
\v 8 Oni owa ugamhi o vọ ewọli oyi ufumhi ali ekpabọ oyi Ẹshinẹgba. Ọgbọ ọkhọghuo ọa la ọ ni ọ dobẹ lo oni owa ugamhi ya ramhi ni eni anasẹmhẹ ishilua e rọ gba pfo.\f + \fr 15:8 \ft Li zẹ \fq Okiali 40.34; 1 Ighie 8.10-11; 2 Okhẹ 5.13-14; Aza 6.4\f* 
\c 16  
\s1 Italabi ishilua ofu eyi Ẹshinẹgba 
\p  
\v 1 Ighọ mhi suọ khi uruli na leghe o rọte oni Owa ugamhi oyi Ẹshinẹgba gueyẹ eni igẹni oshilua, “A ka ku eni italabi ishilua eyi ofu oyi Ẹshinẹgba shi ekẹ agbọ.”  
\v 2 Agẹni ọnododẹ ọ vu ya ku atalabi oyọli shi ekẹ agbọ. Iwali igboko ebe ni e lolo ẹ to, e gẹ ẹgbọ ni e mhọli ọlẹlẹ oyi ọni inyagbemhi, ni e ga ọni inyagbemhi ni a khali.\f + \fr 16:2 \ft Li zẹ \fq Okiali 9.10\f* 
\p  
\v 3 Agẹni ọnuzava ọ ya ku atalabi oyọli lo okẹ oniẹmhi, oni okẹ oniẹmhi o mele ọlia eyi ẹgbọ ni e ghua-a. Emhikpa ni e mhọli ayẹmhẹ ni e la elemhi oni okẹ oniẹmhi e ghuloa. 
\p  
\v 4 Agẹni ọnuzi-aasẹ, ọ ku atalabi oyọli lo okẹ ali ichọchọ amẹ, e mele ọlia-a.\f + \fr 16:4 \ft Li zẹ \fq Okiali 7.17-21; Iwolo 78.44\f* 
\v 5 Mhi suọ khi agẹni ni a ri amẹ nga obọ khi ọọ li, 
\q1 “Ọguẹsọ-ẹzọ ni ọ pfuasẹ 
\q1 u khi, irari khi 
\q2 u guẹ sọ ingme ena, 
\q1 Yẹyẹ u khi Ẹshinẹgba Nọ pfuasẹ, 
\q1 Yẹyẹ u la ọ memena, 
\q2 ni u kpẹ la ọ, ni u gbo ya la ọ, 
\q2 itobọ khi igẹsikia u rọ ọ sọ ẹzọ eyẹ. 
\q1  
\v 6 Irari khi ẹgbọ e she gbolo 
\q2 eni a pfa na-a 
\q2 ali emekẹguele, 
\q1 u she ri ọlia na wẹ da, 
\q2 abi o ti shi!” 
\m  
\v 7 Mhi suọ khi atẹtẹ o tsẹsẹ, ọọ, 
\q1 “Guẹguẹguẹ, 
\q2 Ẹshinẹgba Ọnọmhuẹ Nọfunẹ nya, 
\q1 iguẹzọ eyẹ, eyi igẹsikia 
\q2 ali eni e te odẹ e khi!” 
\p  
\v 8 Agẹni ọnuzi-aane ọ ku atalabi oyọli ku ovọ, a ri ekpabọ na ovọ o ri erali ke tosẹ ẹgbọ-a.  
\v 9 Ẹgbọ e daghiẹ-a irari utomhi oyi erali, e zẹ ẹmuẹbe na eva oyi Ẹshinẹgba ni ọ mhọli ekpabọ rọ mhẹsẹ na anasẹmhẹ enana, ama ẹa lama mupfi ni e ri ufumhi na eva oyọli. 
\p  
\v 10 Agẹni ọnuzi-oshe ọ ku atalabi oyọli kushi ukpẹkhomhi oghie oyi ọni inyagbemhi, eghiele oyọli o la obili. Ẹgbọ e ngomhi ẹlẹmhi unu, shi oya.\f + \fr 16:10 \ft Li zẹ \fq Okiali 10.21\f* 
\v 11 E ku itsẹ na Ẹshinẹgba na iloghie irari utomhi ali igboko eyẹwẹ, ama ẹa lama mupfi lase odẹ ọkhọlọ oyẹwẹ le. 
\p  
\v 12 Agẹni ọnuzi-osasa o ku atalabi oyọli lo okẹ iYufiretisi ni o fu, o khakha amẹ-a ni ighie na obini ovọ o te ẹ ngale e mẹ asha rọte dọsẹ.\f + \fr 16:12 \ft Li zẹ \fq Aza 11.15\f* 
\v 13 Ighọ mhi mẹ khi ikhiakhiamhi iyẹmhẹ aasẹ ni e li abi ikele e rọte unu oyi ọni oligio ọniẹmhi ali unu oyi inyagbemhi ali unu oyi ọmekẹguele ọyi ẹgbhọli, lasele.  
\v 14 Wẹwẹ e khi iyẹmhẹ ọkphaghiẹ ni ẹẹ gbe ikanya ọshabọ, ni e fiẹ deba ighie ni e la ekẹ agbọ nya, ni e ya ti wẹ gbili shi okhọli ogbẹlẹ oyi Ẹshinẹgba Nọ funẹ nya. 
\p  
\v 15 “A ghe i, mhi ya bhale abi oghiatọ! Ikhivọsẹ o khi na ọgbọ ni ọ ya guale, ni ọ ya ri ẹloe khu ide eyọli ini ọ khi banọ-a ni a mẹ ọli irumheba!”\f + \fr 16:15 \ft Li zẹ \fq iMat 24.43-44; iLuk 12.39-40; Irọ 3.3\f* 
\p  
\v 16 Ighọ eni iyẹmhẹ ọkphaghiẹ e ti wẹ gbili ashini a ri ẹlẹmhi Iburu ẹ lui Amagẹdọ.\f + \fr 16:16 \ft Li zẹ \fq 2 Ighie 23.29; iZaka 12.11\f* 
\p  
\v 17 Agẹni ọnuzi-oshilua o ku atalabi oyọli nga idane, ighọ uruli na leghe o rọte Owa ugamhi oyi Ẹshinẹgba rọte ukpẹkhomhi eghiele ngme lasele, ọọ li, “A she riẹlẹ ọli!”  
\v 18 Ighọ, inyamhisalo amẹ, ali ukpimhi ali ingmolo oyi ikphala ali inighise ekẹ ee bhale. Inighise nabi ọgbọ-a kpẹ mẹ ghue abi a te ma ọgbọ shi ekẹ agbọ. Oni inighise o ga khi oniẹmhi!\f + \fr 16:18 \ft Li zẹ \fq Irọ 8.5; 11.13,19\f* 
\v 19 Oni ẹoli oniẹmhi o kemhi asha esẹ, ẹoli oyi eni ishishi nya e de kua. Ẹshinẹgba ọ sato ẹoli iBabilọ no fu egbe. Ọ mhẹsẹ uko ni onyọ ofu oyọli o vọ nali.\f + \fr 16:19 \ft Li zẹ \fq Aza 51.17\f* 
\v 20 Ekẹ ni e la iteva elemhi okẹ nya e kelea, aa ke mẹ ite ekhọghuo.\f + \fr 16:20 \ft Li zẹ \fq Irọ 6.14\f* 
\v 21 Echẹ amẹ na idane eniẹmhi e rọte idane de mu ẹgbọ. Ee ngmanọ ku Ẹshinẹgba irari eni opfuse oyi eni echẹ amẹ, irari khi oni opfuse o khọlọ gba.\f + \fr 16:21 \ft Li zẹ \fq Okiali 9.23; Irọ 11.19\f* 
\c 17  
\s1 Adegbe nọfunẹ 
\p  
\v 1 Ighọ agẹni ọghuo ni ọ mhọli italabi ishilua ọ bhale, ọọ mhẹ, “Bhale khi mhi ya ri abi a li ya nasẹ ọni adegbe ọnọfunẹ khasẹ, ikhi ẹoli oniẹmhi ni o la epfẹ okẹ ni e bu.\f + \fr 17:1 \ft Li zẹ \fq iJere 51.13\f* 
\v 2 Lọli ighie na ekẹ agbọ e nu kia okia, onyọ okia eyọli e gbe ẹgbọ ni e la ekẹ agbọ.”\f + \fr 17:2 \ft Li zẹ \fq Aza 23.17; iJere 51.7\f* 
\p  
\v 3 Ighọ ọni agẹni ọ rue mhẹ je ọdagbe ifufu elemhi Ayẹmhẹ. Ighọ mhi mẹ ọkpotso ni ọ shitọ nga inyagbemhi ọyilẹ, ni ọ le iwali eva ipfiunu-a, ọ ze ikhomhi ishilua ali ekphali igbe.\f + \fr 17:3 \ft Li zẹ \fq Irọ 13.1\f* 
\v 4 Ọni ọkpotso ọ sọnọ itsua eyilẹ, a ga mema ri igolu ali ifẹfẹ ali ema rọ khuẹsẹ ọli-a. Ọ mu uko igolu mhọli obọ ni o vọ emhi ighuighuẹ ali ikanya ichimhi eyi itsẹbọ eyọli.\f + \fr 17:4 \ft Li zẹ \fq iJere 51.7\f* 
\v 5 Emhi osheli na kẹkẹ shi ọli alukpo khi. 
\pc Osheli. 
\pc IBabilọ Oniẹmhi. 
\pc Inyọ idegbe nya. 
\pc Ali inyọ itsẹbọ nya.  
\v 6 Mhi mẹ khi ọni ọkpotso, ọ da ọlia eyi ẹgbọ ni a pfa na, ọlia eyi eni a gbe-a irari khi e mie iJesu suọ. 
\p Abi mhi rọ mẹ ọli, mhi yila. 
\p  
\v 7 Ighọ ọni agẹni ọọ mhẹ, “Elọ o zẹ ni u rọ yila? Mhi ya gueyẹ osheli oyi ọni ọkpotso ali oyi ọni inyagbemhi ni ọọ nga, ni ọ zẹ ikhomhi ishilua ali ekphali igbe.  
\v 8 Ọni inyagbemhi ni u mẹ ni ọ kpẹ khi, mena ni ọa ke khi lọli, ọ ya rọte ilimhi na ningọlọ ngale ya je epfua oyọli. Abọ e ya sha ẹgbọ ni e la agbọ ni aa kẹkẹ eva oyẹwẹ shi ebe ni a kẹkẹ eva oyi eni e ya mhọli agbọ na agbọagbọ shi, rọte igbaekẹle agbọ, ini e mẹ ọni inyagbemhi irari khi, ọ kpe khi, mena ọa ke khi, ni ọa ya bhale.\f + \fr 17:8 \ft Li zẹ \fq iDan 7.7; Irọ 11.7; Iwolo 69.28\f* 
\p  
\v 9 “Onana o khi emini ọgbọ te ẹ sa usamhi ilẹsingme. Eni ikhomhi ishilua eghọ, e khi ikhomhi ite ishilua ni ọni ọkpotso ọọ shitọ.  
\v 10 Ighie oshilua e li gbo khi. Etuoshe ọ, e she ghua, ọghuo ọọ kiele ẹ mhẹsẹ, ọni ọ kpọle ọa bhale ne. Ini ọ da bhale, ọ mema ya laọ ukuku ẹghẹghẹ.  
\v 11 Ọni inyagbemhi ni ọ kpẹ laọ ni ọa ke laọ eghọ, ọ khi oghie ọnuzi-olale, abeghuo lọli ali oshilua enekpọle e li, ọ ya li je epfua oyọli. 
\p  
\v 12 “Eni ekphali igbe ni u mẹ eghọ, e khi ighie ogbe ni aa ri eghiele na ne, ama a ya ri afu na wẹ elemhi iwakati oghuo tsẹ ni e rọ mhẹsẹ abi ighie, li shi ọni inyagbemhi.\f + \fr 17:12 \ft Li zẹ \fq iDan 7.24\f* 
\v 13 Enana emhi oghuo ẹ khi, e ya ri ekpabọ ali afu oyẹwẹ na ọni inyagbemhi.  
\v 14 E ya nu ọni Omi Osumha khọli. Ọni Omi Osumha ọ ya gbe wẹ oni okhọli, irari khi Ọnọmhuẹ ọyi enemhuẹ ọ khi, ali Oghie ni o mhọli ighie ọ khi. Irari khi e nu ọli la, wẹwẹ ọ lu ni ọ zẹ, ali ni e khi eni e ri igẹsikia deba li.” 
\p  
\v 15 Ighọ ọni agẹni ọọ mhẹ, “Eni okẹ eniẹmhi ni u mẹ, ni ọni adegbe ọ shitọ, ẹgbọ ali ebubu ẹgbọ ali ishishi ali ẹmuẹ ọdọda e la aghọ.  
\v 16 Ọni inyagbemhi ali ekphali igbe ni u mẹ eghọ e ya biselemhi ọni adegbe. E pfuse ọli-a, e banọ ọli-a, e nyanọ li elamhi egbe rọ le, e ri erali tosẹ ọli-a.  
\v 17 Irari khi Ẹshinẹgba ọ rọli shi wẹ udu e riẹlẹ emini ọ gba, lọli e rọ lama kugbe ri ekpabọ eyẹwẹ na ọni inyagbemhi ni ọ mhẹsẹ, ya ramhi ni ungmemhi oyi Ẹshinẹgba o rọ bhale ya tsẹ.  
\v 18 Ọni ọkpotso ni u mẹ lọli ọ khi oni ẹoli oniẹmhi ni ọọ mhẹsẹ na ighie na agbọ.” 
\c 18  
\s1 Udemhi oyi iBabilọ 
\p  
\v 1 Onana ọ dọsẹ se, mhi mẹ agẹni olese khi ọ rọte iloghie ẹ tiemhile. Ọ mhọli afu nofunẹ, ugẹmhi oyọli o ri ekẹ agbọ ọ gẹ nyanyanya.  
\v 2 Ọ ri uruli oniẹmhi tsẹsẹ leghe, ọ li. 
\q1 “Ẹoli iBabilọ Oniẹmhi, 
\q2 o she de. 
\q1 O she mele ugbebo 
\q2 oyi iyẹmhẹ eyi 
\q2 ọkphaghiẹ-a, 
\q1 ali ashini iyẹmhẹ 
\q2 ọkphaghiẹ e la lese, 
\q1 ashini ipfeli ali elamhakọ 
\q2 ni aa pfuasẹ ni aa ghuẹ, 
\q2 ẹẹ la.\f + \fr 18:2 \ft Li zẹ \fq Aza 13.21; 21.9; iJere 50.39; 51.8; Irọ 14.8\f* 
\q1  
\v 3 Irari khi ishishi nya, 
\q2 e she kpọkpọ onyọ, 
\q1 ni o ri ujili ẹ kpha, 
\q2 ikhi onyọ okia oyọli. 
\q1 Ighie na ekẹ agbọ 
\q2 e she kia okia deba li. 
\q1 Eduoki na ekẹ agbọ, 
\q1 e she rọte 
\q1 iliagbọ-tsuakua oyọli 
\q2 mhuẹ ẹpfue.”\f + \fr 18:3 \ft Li zẹ \fq Aza 23.17; iJere 51.7\f* 
\p  
\v 4 Ighọ mhi suọ uruli olese ni o rọte idane liẹ, 
\q1 “Ẹgbọ eyẹmhẹ, a na li egbe kua, 
\q2 ini a khi mhuẹ okemhi 
\q2 shi olamhẹ eyọli, 
\q1 ini a khi mhuẹ okemhi 
\q2 shi osoli anasẹmhẹ oyọli.\f + \fr 18:4 \ft Li zẹ \fq Aza 48.20; iJere 50.8; 51.6,45\f* 
\q1  
\v 5 Irari khi olamhẹ eyọli 
\q2 e she tigbili yagha ramhi idane, 
\q1 Ẹshinẹgba ọ she sato 
\q2 umha-guẹli eyọli.\f + \fr 18:5 \ft Li zẹ \fq Igbae 18.20-21; iJere 51.9\f* 
\q1  
\v 6 Ā li ọli, abi ọ li ẹ, 
\q2 ā fali ọli ota asha eva 
\q2 shi ikanya ni ọ gbe. 
\q1 Onyọ ni o toto ni ọ rọ na ẹ da, 
\q2 a sọ oghọghọ nali da asha eva.\f + \fr 18:6 \ft Li zẹ \fq Iwolo 137.8; iJere 50.29\f* 
\q1  
\v 7 A ri osoli ali oyala nali 
\q2 ni o guẹ to ufumhi ali ẹpfue 
\q2 ni ọ rọna egbọli. 
\q1 Irari khi eri Ọni Ọkpotso 
\q2 ọ la ekelemhi tono obọ udu liẹ, 
\q1 ‘Mhẹmhẹ mhi khi ọni ọlele! 
\q2 Mhi aa tigbe ya khi 
\q2 ọsamhi-olimhi, 
\q1 mhi aa tigbe ya 
\q2 mẹ oya egbe ghue.’ 
\q1  
\v 8 Irarighọ, ogbẹlẹghuo 
\q1 anasẹmhẹ oyọli 
\q2 o rọ ya sha rughu ọli, 
\q1 shi eghuli ali eviẹ 
\q2 ali okiamhi. 
\q1 A ya ri erali tosẹ ọli-a. 
\q1 Irari khi Ẹshinẹgba Ọnọmhuẹ 
\q2 ni ọ ya gue ọli ẹzọ, 
\q2 ọnọfunẹ nya ọ khi.”\f + \fr 18:8 \ft Li zẹ \fq Aza 47.7-9\f* 
\p  
\v 9 “Ini ighie na agbọ ni e kia okia deba li, ni e nu ọli li agbọ tsua kua, e ya viẹ, e viẹ eviẹ oya na li, ini e mẹ ewọli erali ni ẹẹ tosẹ ọli-a.  
\v 10 E ya tapfia migha ke viẹ irari ulishi osoli ni a na li, ẹẹ liẹ, 
\q1 “ ‘Eekhue o Eekhue o 
\q2 yẹyẹ ẹoli nofunẹ, 
\q2 iBabilọ ẹoli no mhuẹ ekpabọ! 
\q1 Elemhi iwakati oghuo tsẹ 
\q2 epfua oyẹ o she bhale!’\f + \fr 18:10 \ft Li zẹ \fq Ezik 26.16-17\f* 
\p  
\v 11 “Eduoki na agbọ e ya viẹ ọli e viẹ oya irari khi ọgbọkhọghuo ọa ke nu wẹ ya dẹ itsua.\f + \fr 18:11 \ft Li zẹ \fq Ezik 27.31,36\f* 
\v 12 Itsua igolu ali ẹlomho, imiechẹ ni e somhotse ni e ghalẹ, ifẹfẹ ali ema, ide epfopfo na kpishi, ali eni ẹ yilẹ, ghe ena wọnọ, ali ilọlọ eni eyilẹ ali itsua ọdọda ni a ri ọọra ni ẹ pfie khali, ali itsua ọdọda ni a ri ekphali eni khali, ali ẹẹra ni e ghalẹ, idẹ ali ikhuli ali echẹ imabo.  
\v 13 Ali alagho na lu ikinamọni ali ọshamhi ali ituale afu ẹẹra ali ituale ni a ku ẹ shi olimhi egbe, ali atike ni ọọ pfie ni o ghalẹ ali onyọ ali oili ali ifulawa ali ikpamhi emhi ni a lu ado, ena ali isumha ali ichi ali amọku ni ichi ẹẹ tsua, li shi ẹgbọ ni e khi ighumha.\f + \fr 18:13 \ft Li zẹ \fq Ezik 27.12,13,22\f* 
\p  
\v 14 “Eni eduoki e ya liẹ ọli, ‘Imọmhi ni u ri ukpẹloe shi ekẹ ẹ khẹ, o she mẹ na. Ẹpfue ali ọsuemhẹ eyẹ nya e she kele-a, ni a ke dobẹ gbolo mẹ ya mie.’  
\v 15 Eduoki ni e ri emhi enana dẹ ni e mẹ elele ẹpfue rọte obọ oyi ọni ọkpotso, e ya migha tapfia, ulishi osoli ni ọ mẹ ọọ mu wẹ. E ya viẹ e viẹ oya,\f + \fr 18:15 \ft Li zẹ \fq Ezik 27.31,36\f* 
\v 16 e viẹ nyogho, ee liẹ, 
\q1 “ ‘Eekhue-o! Eekhue-o, 
\q2 ẹoli Onofunẹ, 
\q1 ni a ri iwulu ichẹ eneyilẹ, 
\q2 ni a ri igolu ali echẹ 
\q1 ni e ghalẹ ali ifẹfẹ 
\q2 khuẹ akhuẹ! 
\q1  
\v 17 Aboriẹkhi ighọ, 
\q2 elemhi iwakati oghuo tsẹ, 
\q1 eni ẹpfue eniẹmhi eghọ 
\q2 e li opfu-a.’\f + \fr 18:17 \ft Li zẹ \fq Aza 23.14; Ezik 27.26-30\f* 
\p “Eni e khi ega ọkọ-okẹ oniẹmhi nya ali eni ẹ lo ọkọ-okẹ oniẹmhi ya asha ali eni ẹ gua li ali eni e rọte okẹ oniẹmhi ẹ mie ifata, e ya tapfia migha.  
\v 18 Ini e mẹ ewọli eyi utomhi oyọli, e ya liẹ, ‘Ẹoli okhọghuo o la ọ ni o li abi oni ẹoli oniẹmhi?’\f + \fr 18:18 \ft Li zẹ \fq Ezik 27.32\f* 
\v 19 E yalọ ifufu ku ukhomhi, e ri eviẹ ali oya viẹ leghe, ee liẹ,\f + \fr 18:19 \ft Li zẹ \fq Ezik 27.30-34\f* 
\q1 “ ‘Eekhue-o! Eekhue-o, 
\q2 yẹyẹ ẹoli oniẹmhi, 
\q1 ni eni e mhọli 
\q2 ọkọ-okẹ oniẹmhi nya, 
\q1 e te mhọli ẹpfue eyẹwẹ 
\q2 rọte ọsuemhẹ oyi oni ẹoli! 
\q1 Elemhi iwakati oghuo tsẹ 
\q2 a rọ pfuse ọli-a.\f + \fr 18:19 \ft Li zẹ \fq Ezik 27.30-34\f* 
\q1  
\v 20 A ri itobọ li 
\q2 ke ghẹlẹ, iloghie, 
\q1 A ke ghẹlẹ, 
\q2 ẹẹ eni a pfa na 
\q2 ali ighiusomhi na kẹẹ ali emekẹguele! 
\q1 Irari khi Ẹshinẹgba 
\q2 ọ she gue ọli ẹzọ 
\q2 shi abi ọ li nasẹ ẹ.’ ”\f + \fr 18:20 \ft Li zẹ \fq iDẹut 32.43; iJere 51.48\f* 
\p  
\v 21 Ighọ agẹni nọfunẹ o rue udumhi ẹchẹ ni o li abi ẹchẹ iko pfilo oni okẹ oniẹmhi, ọọ li, 
\q1 “Ekpabọ na guo 
\q2 a rọ ya guọghọ 
\q2 ẹoli iBabilọ oniẹmhi-a, 
\q1 aa ke gbo ya 
\q2 mẹ ẹ ẹloe ghue.\f + \fr 18:21 \ft Li zẹ \fq iJere 51.63-64; Ezik 26.21\f* 
\q1  
\v 22 Ọgbọ ọa ke gbo ya suọ 
\q1 uruli ẹfa 
\q1 wẹkhi oyi emini áá kpheli 
\q1 wẹkhi oyi ofele, 
\q1 wẹkhi oyi akala 
\q2 elemhi yẹyẹ oni ẹoli ona ghue. 
\q1 Ọgbọ ọa ke ya mẹ 
\q2 ọgbakanya ọkhọghuo 
\q2 elemhi ẹ ghue. 
\q1 Ọgbọ ọa ke ya suọ 
\q2 okeke emini a mhẹli iko, 
\q2 elemhi ẹ ghue.\f + \fr 18:22 \ft Li zẹ \fq Ezik 26.13; Aza 24.8\f* 
\q1  
\v 23 Erali ákpá ọa ke gbo ya gẹ 
\q2 elemhi ẹ ghue, 
\q1 wẹkhi eri a ya gbo suọ 
\q2 uruli eni ẹ zu ode 
\q2 elemhi ẹ ghue. 
\q1 Eduoki eyẹ e khi 
\q2 ẹgbọ eni e funẹ na ekẹ agbọ, 
\q1 u ri ogbhọ oyẹ 
\q2 di ishishi nya wasẹ-a.\f + \fr 18:23 \ft Li zẹ \fq iJere 7.34; 25.10\f* 
\q1  
\v 24 Elemhi oni ẹoli a mẹ 
\q2 ọlia eyi emekẹguele 
\q2 ali eyi eni a pfa na, 
\q2 ali eni a gboloa shi ekẹ agbọ nya.”\f + \fr 18:24 \ft Li zẹ \fq iJere 51.49\f* 
\c 19  
\s1 Okuekhoogo! 
\p  
\v 1 Onana o dọsẹ se, mhi suọ uruli ni o li abi okeke oniẹmhi oyi ebubu ẹgbọ obini iloghie khi oo tsẹsẹ, oo liẹ, 
\q1 “Okuekhoogo, 
\q1 Imiepfuese ali ufumhi 
\q2 ali ekpabọ khi 
\q2 eyi Ẹshinẹgba ọyawa. 
\q1  
\v 2 Irari khi iguẹzọ oyọli 
\q2 eyi igẹsikia ali 
\q2 eni e sheshe e khi. 
\q1 Ọ she pfa ẹzọ mu 
\q2 adegbe ọnọfunẹ, 
\q1 ọni ọ she ri okia eyọli 
\q2 yese ekẹ agbọ-a. 
\q1 Ẹshinẹgba ọ she ye okhọli 
\q2 to ọlia eyi eni ẹẹ ga eyọli.”\f + \fr 19:2 \ft Li zẹ \fq iDẹut 32.43; 2 Ighie 9.7\f* 
\m  
\v 3 Ighọ e gbo tsẹsẹ, e liẹ, 
\q1 “Okuekhoogo! 
\q1 Ewọli eyọli e she ẹ nga 
\q2 idane agbọagbọ.”\f + \fr 19:3 \ft Li zẹ \fq Aza 34.10\f* 
\p  
\v 4 Ighọ egbhali uye ali aane ali elamhakọ aane, e de yẹshi, e ga Ẹshinẹgba ni ọ shitọ oni ukpẹkhomhi oghie, e liẹ, 
\q1 “Atsẹ! Okuekhoogo!” 
\p  
\v 5 Uruli o rọte oni ukpẹkhomhi oghie ngme ọọ liẹ, 
\q1 “A kuẹghiẹ 
\q2 Ẹshinẹgba ọyawa, 
\q1 ẹẹ ni ẹẹ ga eyọli nya, 
\q1 ẹẹ ni a na ulishi oyọli, 
\q2 ghe ẹgbọ ni e fu 
\q2 ali eni e shẹ!”\f + \fr 19:5 \ft Li zẹ \fq Iwolo 115.13\f* 
\p  
\v 6 Ighọ mhi suọ uruli ni o li abi uruli oniẹmhi oyi ebubu ẹgbọ ni o li abi ingmolo oyi okẹ ni ọọ tu, ni o gbo li abi ingmolo oyi akphala. Ee liẹ, 
\q1 “Okuekhoogo! 
\q1 Irari khi Ẹshinẹgba 
\q1 Ọnọmhuẹ oyawa Nọfunẹ nya, 
\q2 lọli ọ le oghie!\f + \fr 19:6 \ft Li zẹ \fq Ezik 1.24; Iwolo 93.1; 97.1; 99.1\f* 
\q1  
\v 7 Awa ke ghẹlẹ, 
\q2 egbe ke mu awa, 
\q2 awa ri ufumhi nali! 
\q1 Irari khi izu-ode oyi 
\q2 ọni Omi Osumha 
\q2 o she ramhi, 
\q1 ọmueshi ọ she mu egbe shi ekẹ. 
\q1  
\v 8 Ode opfopfo 
\q1 ni o dala ni o pfuasẹ, 
\q2 a rọ nali sọ.” 
\m (Oni Ode opfopfo, iguẹ ngeli oyi eni a pfa na o migha shi.) 
\p  
\v 9 Ọni agẹni ọọ mhẹ, “Kẹkẹ khi. ‘Ikhivọsẹ o khi na ẹgbọ ni a lu shi oni ukue aruele oyi izu-ode oyi ọni Omi Osumha.’ ” Ọ gbolo ẹ mhẹ, “Ingmemhi enana, egbegbi ingmemhi eyi Ẹshinẹgba e khi.”\f + \fr 19:9 \ft Li zẹ \fq iMat 22.2-3\f* 
\p  
\v 10 Ighọ mhi de ya wugha li awẹ ni mhi ga li. Ama ọọ mhẹ, “Khi li ghọ! Ọni ọọ ga nabi yẹyẹ ali ọnabi inyọghuo ẹ enekpọle mhi khi ni e mu ọtsẹlẹ oyi iJesu mhuẹ. Ga Ẹshinẹgba! Irari khi ọtsẹlẹ oyi iJesu o khi ayẹmhẹ imekẹguele.” 
\s1 Ọni ọ nga achi ọpfopfo 
\p  
\v 11 Ighọ mhi mẹ khi iloghie o khueghie-a mhi mẹ achi ọpfopfo. Ọni ọ nga li a lu ọzẹ-regbenga ali ọni ọ khi igẹsikia. Odẹ ni ọa mhuẹ azẹba ọ te ẹ sọ ẹzọ, ni ọ te ẹ khọli.\f + \fr 19:11 \ft Li zẹ \fq Ezik 1.1; Iwolo 96.13; Aza 11.4\f* 
\v 12 Ikpamhi alo eyọli e li abi ẹlẹmhi erẹ. Ọ rughu irula oghie ni e bu. Ọ mhọli eva ni a kẹkẹ shi ọli egbe ni ọgbọ ọlese ọa lẹsẹ, se ni lọli ghuo kpele.\f + \fr 19:12 \ft Li zẹ \fq iDan 10.6\f* 
\v 13 Ọ sọ awulu ni a sọ ọlia. Eva ni a lu ọli khi, “Ungmemhi oyi Ẹshinẹgba.”  
\v 14 Ekhọli-okhuẹ ni e la iloghie e deba li kia, e sọnọ itsua epfopfo ni e dala ni e pfuasẹ, e nga ichi epfopfo.  
\v 15 Itakobi ni ọọ mu o rọte unu oyọli lasele, ni ọ rọ ya khọli eni ishishi. Ọtsuọdu akhuli ọ rọ ya ke mhẹsẹ na eni ishishi. Ọ ya rọte ashini a te ẹ mino-onyọ mino onyọ lasele, Ikhi onyọ no khi ofu oniẹmhi oyi Ẹshinẹgba Nọfunẹ nya.\f + \fr 19:15 \ft Li zẹ \fq Iwolo 2.9; Aza 63.3; iJọẹ 3.13; Irọ 14.20\f* 
\v 16 A kẹkẹ eva, “Oghie Ni ọ Mhọli Ighie, Ali Ọnọmhuẹ Ni ọ Mhọli Ekhẹmhuẹ,” shi awulu na dogo oyọli ali ukhiowẹ oyọli.  
\v 17 Ighọ mhi mẹ agẹni khi ọ migha ovọ, ni ọ viẹ lasele leghe lui ipfeli ni e la irarogbe ẹ fiala, “A bhale a ka legba shi aruele ogbọmhi oniẹmhi oyi Ẹshinẹgba.  
\v 18 Ẹghẹghẹ aghọ ni a le elamhi idiegbe oyi ighie ali ega ekhọli-okhuẹ ni e ri ekhọli-okhuẹ ẹ ye okhuẹ, ali elamhi idiegbe eyi ẹgbọ nefunẹ, shi elamhi ichi ali eni e nga wẹ, ali elamhi idiegbe ẹgbọ nya, shi ighumha ali eni ẹa khi ighumha ghe ẹgbọ enikeke ali ẹgbọ eniẹmhi.”\f + \fr 19:18 \ft Li zẹ \fq Ezik 39.17-20\f* 
\p  
\v 19 Ighọ mhi mẹ ọni inyagbemhi ali ighie na ekẹ agbọ ali ekhọli-okhuẹ eyọli khi e lona kugbe, ni e rọ nu ọni ọ nga ọni achi ali ekhọli-okhuẹ eyọli khọli.  
\v 20 Ama a mu ọni inyagbemhi ma ọmekẹguele ọyi ẹgbhọli ọyọli, ọni ọ ri eva oyọli gbe irọkhasẹ ọnyaloa. Eni irọkhasẹ ena ọ rọ di ẹgbọ ni e mie eni ọlẹlẹ eyi ọni inyagbemhi shi egbe, ni e ga irọkhọkhọ oyọli ni a khali. Ọni inyagbemhi ali ọni ọmekẹguele ọyi ẹgbhọli, a mu wẹ pfilo uyele erali ni ofulu o la to kua yala.\f + \fr 19:20 \ft Li zẹ \fq Irọ 13.1-18\f* 
\v 21 Eni e kpọle, a ri itakobi oni o rọte unu oyi ọni ọ nga ọni achi gbolo wẹ-a. Eni ipfeli nya e ri elamhi idiegbe eyẹwẹ le. 
\c 20  
\s1 Ikpe Agbẹlẹ 
\p  
\v 1 Ighọ mhi mẹ khi agẹni ọ rọte idane e tiemhile ọ mu okpẹ ilimhi na ningọlọ mhọli obọ, ọ tsua ukpokpomhi uwẹghẹ.  
\v 2 Ọ gamhi ọni oligio ọniẹmhi rue, ikhi ẹnyẹ ọnẹdẹ ọghọ ni ọ khi etse ali Ọkphaghiẹ, ọ gẹ ọli ikpe agbẹlẹ oghuo.\f + \fr 20:2 \ft Li zẹ \fq Igbae 3.1\f* 
\v 3 Ọ pfi ọli lo oni ilimhi na ningọlọ, ọ pfi okpẹ ọ. Ọ pfi oni ilimhi na ningọlọ unu ma, ini ọ khi ke gbo mẹ asha di ishishi ẹgbọ, ya ramhi ni eni ikpe agbẹlẹ e rọ ya gba. Ini ona o dọsẹ se, a mema ya rue ọli obọ-a ukuku ẹghẹghẹ. 
\p  
\v 4 Ighọ mhi mẹ ikpẹkhomhi ighie. Eni e shitọ ọ, e khi eni a ri afu na ni e ri ẹgbọ gue ẹzọ. Ighọ mhi gbo li mẹ iyẹmhẹ eyi ẹgbọ ni a kholo ikhomhi ọ, irari ọtsẹlẹ ni e pfi na iJesu ali ungmemhi oyi Ẹshinẹgba. Eni ẹgbọ ena ẹa ga ọni inyagbemhi wẹkhi irọkhọkhọ eyọli, wẹkhi eri e mie ọlẹlẹ oyọli shi atẹtẹ ukhomhi, wẹkhi obọ. E ya te eghuli guale, e ya nu iKirisiti mhẹsẹ ikpe agbẹlẹ.\f + \fr 20:4 \ft Li zẹ \fq iDan 7.9,22\f* 
\v 5 Ẹgbọ ni e kpọle ni e ghuloa ẹa ke rọte eghuli guale, ramhi ni ikpe agbẹlẹ eghọ e rọ gba. Onana o khi irọte eghuli guale onododẹ.  
\v 6 Ikhivọsẹ ali ipfuasẹ e khi eyi eni e mhọli obọ shi iguale onododẹ onana. Eghuli onuzi-eva ọa mhọli ekpabọ shi ẹgbọ eghọghọ egbe, ama e ya khi ekpodalo-ugamhi eyi Ẹshinẹgba ali eyi iKirisiti. E ya nu ọli mhẹsẹ ikpe agbẹlẹ. 
\p  
\v 7 Ini eni ikpe agbẹlẹ e gba se, a ya taghiẹ Ọkphaghiẹ owa ighumha oyọli-a.  
\v 8 Ọ ya fiẹ lasele ya di ẹgbọ ni e la ishishi nya na ekẹ agbọ, ikhi ẹgbọ ni a lu iGọgi ali iMagọgi, ni ọ rọ ti wẹ gbili shi okhọli. Eri e bu abi ekhashẹ ni e la egele okẹ oniẹmhi.\f + \fr 20:8 \ft Li zẹ \fq Ezik 7.2; 38.2,9,15\f* 
\v 9 Ighọ e to ọghọli ya gbe ekẹ agbọ khia, e pfi gasẹ apfẹ eyi ẹgbọ eyi Ẹshinẹgba, ẹoli ni ọ nono egbegbọ. Ama erali e rọte idane tiemhile ya tosẹ wẹ-a.  
\v 10 Ọni etse ni ọ di wẹ, a mu ọli pfilo erali ilimhi iriẹriẹ ni ofulu o la to kua yala. Ikhi ashini a pfi ọni inyagbemhi ali ọmekẹguele ọyi ẹgbhọli lo. A ya la aghọ na wẹ osoli agbọagbọ, no gbe no bi. 
\s1 A ri eni e ghu-a gue ẹzọ 
\p  
\v 11 Ighọ mhi mẹ ukpokpomhi ukpẹkhomhi oghie opfopfo ali ọni ọ shitọ ọ. Abi ọ shitọ eghọ, ekẹ ali ukhui e kele-a, ẹa ke mẹ ashikhọghuo la.  
\v 12 Ighọ mhi mẹ ẹgbọ ni e ghuloa, ghe eniẹmhi, ali enikeke, e migha odalo oni ukpẹkhomhi oghie. Ighọ a khueghie ebe ni e bu-a. A gbo khueghie ebe olese-a ni o khi ebe ni a kẹkẹ eva oyi eni e ya mhọli agbọ na agbọagbọ shi. A gue eni e ghu-a ẹzọ abi ikanya ni e gbe e li, abi a li kẹkẹ wẹ shi eni ebe.\f + \fr 20:12 \ft Li zẹ \fq iDan 7.9-10\f* 
\v 13 Okẹ o kpa ẹgbọ ni e ghuloa shi ọ ku lasele. Eghuli, ali ilimhi, e khueghie unu-a kpa ẹgbọ ni e la elemhi wẹ ku lasele. A gue ọgbọgbọ nya ẹzọ abi ọ li gbe.  
\v 14 Ighọ a pfi Eghuli, ali ilimhi lo uyele erali. Erali ilimhi iriẹriẹ onana o khi eghuli onuzi-eva.  
\v 15 Ọnini eva oyọli ọa da la oni ebe ni a kẹkẹ eva oyi eni e ya mhọli agbọ na agbọagbọ shi ne, eri a ya pfi ọli pfilo oni erali ilimhi iriẹriẹ. 
\c 21  
\s1 IJerusalẹmu Onogbọ 
\p  
\v 1 Ighọ mhi li mẹ iloghie onogbọ ali ekẹ agbọ onogbọ. Iloghie onododẹ ali ekẹ agbọ onododẹ e she kala-a, ighọ li khi okẹ oniẹmhi.\f + \fr 21:1 \ft Li zẹ \fq Aza 65.17; 66.22; 2 iPit 3.13\f* 
\v 2 Mhi mẹ oni ẹoli ni o pfuasẹ ikhi oni iJerusalẹmu onogbọ khi o rọte idane e tiemhile rọte obọ oyi Ẹshinẹgba, abi ọmueshi ni a khuẹsẹ somhotse ẹ ghi ọdọ li.\f + \fr 21:2 \ft Li zẹ \fq Aza 52.1; 61.10; Irọ 3.12\f* 
\v 3 Ighọ mhi suọ ukpokpomhi uruli khi o rọte oni eghiele e liẹ, “A ghe khẹ! Ẹshinẹgba ọ ri apfẹ oyọli tiemhile deba ẹgbọ, eri ọ ke ya nu ẹgbọ ngeli kugbe, eni ẹgbọ e ya khi ẹgbọ eyọli, Ẹshinẹgba ọ ya nu wẹ la kugbe.\f + \fr 21:3 \ft Li zẹ \fq Ezik 37.27; iLẹv 26.11,12\f* 
\v 4 Ọ ya shishi wẹ ameviẹ alo-a, eghuli ọa ke ya laọ, wẹkhi eri a kẹ ke viẹ wẹkhi asha o ke ya ke to ọgbọ, irari khi emini ediọ e she dọsẹ.”\f + \fr 21:4 \ft Li zẹ \fq Aza 25.8; 35.10; 65.19\f* 
\p  
\v 5 Ọni ọ shitọ oni ukpẹkhomhi oghie ọọ li, “Ghe khẹ, Mhi ri emhikpa a mele enegbọ-a!” Ighọ ọọ, “Kẹkẹ emhi enana shi ekẹ irari khi ingmemhi ni a ri egbe ẹ da ni e khi igẹsikia e khi.” 
\p  
\v 6 Ọọ mhẹ, “A she li ọli. Mhẹmhẹ mhi Aafa ali Omega, mhẹmhẹ mhi khi igbaekẹle ni mhi khi ọzukhomhi. Ọni okiamẹ ọọ gbe, mhi ya rọte okẹ ni ọọ chọchọ amẹ, ni o ri agbọ a na ọgbọ na li da afuẹ.\f + \fr 21:6 \ft Li zẹ \fq Aza 55.1\f* 
\v 7 Ọni ọ da mu ọ le ne, ọ ya mhọli ikhivọsẹ ona, ni, Mhẹmhẹ mhi ya khi Ẹshinẹgba oyọli, lọli o khi omimhẹ.\f + \fr 21:7 \ft Li zẹ \fq 2 iSam 7.14; Iwolo 89.26-27\f* 
\v 8 Ama ẹgbọ ni e khi enulishi ali eni ẹa ya lama miesuọ, ena angeli ichimhi ali egbugbeli, ali ena itsẹbọ eni e mu imhẹsẹ ogbhọ ali eni ega ikhumhi, ali e lo ẹgbhọli nya, okiẹmhi oyẹwẹ o ya khi erali ilimhi iriẹriẹ ni ofulu la to kua yala. Onana khi eghuli onuzi-eva.” 
\p  
\v 9 Agẹni ọghuo eni oshilua ni ọ mhọli italabi ishilua ni e vọ anasẹmhẹ ishilua ni e kpe ukhokho, ọ bhale ya liẹ mhẹ, “Bhale, mhi ya ri ọni ọmueshi ọnọgbọ khasẹ, ni ọ khi ughuẹ ọni Omi Osumha.”  
\v 10 Elemhi oni ayẹmhẹ, ọni agẹni ọ tsua mhẹ nga ukhomhi ute oniẹmhi ni o yagha, ọ rẹmhẹ khasẹ oni Ẹoli-No-pfuasẹ ikhi iJerusalẹmu, khi o rọte idane te obọ oyi Ẹshinẹgba a tiemhile.\f + \fr 21:10 \ft Li zẹ \fq Ezik 40.2\f* 
\v 11 O ri ufumhi oyi Ẹshinẹgba gẹ nyanyanya. Ugẹmhi oyọli o li abi ẹchẹli ni o somhi otse ni a lu iJasipa ni o li abi ughegbe.  
\v 12 O mhọli ukpokpomhi ugbe ni o yagha ni o mhọli odẹ inuẹkpẹ igbẹva. Eni odẹ inuẹkpẹ, igẹni ogbava e la ọ. Eni odẹ inuẹkpẹ igbẹva ena a kẹkẹ eva eyi ẹdẹli igbẹva eyi iZirẹni shi ọ.  
\v 13 Odẹ inuẹkpẹ esesẹ e la obọ-ugbe enenene oyi oni ugbe. Esẹ e la ukiẹkiẹ obini ovọ o te ẹ ngale oyọli, esẹ e la ukiẹkiẹ obita, esẹ e la ukiẹkiẹ ọgobọ, esẹ e li la ukiẹkiẹ obini ovọ o te ẹ lo eko.\f + \fr 21:13 \ft Li zẹ \fq Ezik 48.30-35\f* 
\v 14 Oni ugbe ni o gasẹ oni ẹoli o mhọli echẹ irọgbekẹ igbẹva. Eni echẹ irọgbekẹ ena, a kẹkẹ eva eyi ighiusomhi na kẹẹ ogbava eyi ọni Omi Osumha shi ọ. 
\p  
\v 15 Ọni ọ nu mhẹ ẹ ngme, o mhọli ukpokpo ni a rọọ mhẹsẹ emhi ni o khi igolu ni ọ rọ ya mhẹsẹ oni ẹoli ali eni odẹ inuẹkpẹ ali igbe eyọli.\f + \fr 21:15 \ft Li zẹ \fq Ezik 40.3\f* 
\v 16 Oni ẹoli o zẹ abọ igbe ene, ni iyagha ali inuata ali uẹmhi eyọli e li abizize. Ọ mhẹsẹ oni ẹoli, o ya khi ikuku emhi ẹa la imali agbẹlẹ ali egbhuẹshe ashi ishe (1,500), unuẹmhi ali uẹmhi eyi eni abọ igbe ali iyagha eyọli e khi abizize.  
\v 17 Ọni agẹni ọ li mhẹsẹ ugbe oyọli, e ya khi ẹtẹ-awẹ egbhuẹgbe. Abi awa liẹ mhẹsẹ ekẹ.  
\v 18 Ugbe oyọli, echẹ ijasipa a rọ ma li, oni ẹoli o khi egbegbi igolu ni a te ẹ mẹ ekẹ abi ughegbe.  
\v 19 Irọgbekẹ oyi igbe ni a ma gasẹ oni ẹoli e ya khi echẹ ni e ghalẹ ọdọda. Onododẹ o khi ijasipa, onuzi-eva o khi isafaya, onuzi-esẹ o khi ikalisẹdoni, onuzi-ene o khi ẹmẹradi,  
\v 20 onuzi-ishe o khi isadonizi, onuzi-esesa o khi ikanẹliani, onuzi-ishilua o khi ikirisolati, onuzi-elele o khi ibẹrili, onuzi-itili o khi itopazi, onuzi-igbe o khi ikirisopirazi, onuzi-igbaghuo o khi ijasiti, onuzi-igbẹva o khi ametisiti.  
\v 21 Eni odẹ inuẹkpẹ igbẹva e ya khi ifẹfẹ. Odẹ unuẹkpẹ ọgbọgbọ a ri ufẹfẹ oyọli riẹlẹ ọli. Odẹ agbala ni o la oni ẹoli, egbegbi igolu ni a te ẹ mẹ ekẹ abi ughegbe a rọ ku ọli.\f + \fr 21:21 \ft Li zẹ \fq Aza 54.11-12\f* 
\p  
\v 22 Mhi aa mẹ Owa ugamhi okhọghuo oni ẹoli, irari khi Ẹshinẹgba Ọnọmhuẹ Nọfunẹ nya ali Ọni Omi Osumha wẹwẹ e khi Owa Ugamhi ni e la aghọ.  
\v 23 Oni ẹoli ọa ke mhọli emini o ri ugẹmhi oyi ovọ wẹkhi oyi uki ya li. Irari khi ugẹmhi oyi Ẹshinẹgba lọli o khi ákpá ni o la aghọ, ọni Omi Osumha ọ khi ákpá ni o la aghọ.\f + \fr 21:23 \ft Li zẹ \fq Aza 60.19-20\f* 
\v 24 Ẹgbọ na agbọ nya e ya ri oni ákpá ke kia, ighie ni e la agbọ e ya tsua ẹpfue eyẹwẹ bhale aghọ.\f + \fr 21:24 \ft Li zẹ \fq Aza 60.3\f* 
\v 25 Ọgbọ ọa ya tigbe khukhu odẹ inuẹkpẹ ni e lo oni ẹoli le ghue, itobọ khi ọgbọ ọa ya mẹ ẹliyọsẹ aghọ.  
\v 26 A ya tsua ẹpfue ali ufumhi eyi ishishi lo oni ẹoli le.\f + \fr 21:26 \ft Li zẹ \fq Aza 60.11\f* 
\v 27 Ama, emini e ri ichimhi ẹ mu ọa ya tigbe lo aghọ le, wẹkhi ọgbọ ni ọọ gbe ikanya omama ali ni ọ riẹlẹ emhi ẹgbhuẹ, sẹ khi ẹgbọ ni eva oyẹwẹ o la ebe ni a kẹkẹ eva oyi eni e ya mhọli agbọ na agbọagbọ shi oyi ọni Omi Osumha.\f + \fr 21:27 \ft Li zẹ \fq Aza 52.1; Ezik 44.9\f* 
\c 22  
\s1 Okẹ Amẹ Agbọ 
\p  
\v 1 Ighọ ọ ri okẹ amẹ ni o ri agbọ ọ na ọgbọ khasẹ mhẹ, okẹ ni o pfuasẹ abi ughegbe, ni o rọte ukpẹkhomhi Eghiele oyi Ẹshinẹgba ali oyi Omi Osumha tu u lasele.\f + \fr 22:1 \ft Li zẹ \fq Ezik 47.1; iZaka 14.8\f* 
\v 2 Oni okẹ o rọte iteva oyi oni odẹ agbala ni o la oni ẹoli. Ukiẹkiẹ eve-eva oyi oni okẹ, ọọra ni o ri agbọ ọ na ọgbọ e migha, ni o mọ idumhi igbẹva ọdọda, ni ọọ mọ idumhi uki kpa. Ebe oyi oni ọọra a rọ ri ishishi ẹẹ ze.\f + \fr 22:2 \ft Li zẹ \fq Igbae 2.9; Ezik 47.12\f* 
\v 3 Emhikhọghuo ni Ẹshinẹgba ọ pfi unu na ọa ke ya la aghọ. Ama ukpẹkhomhi oghie oyi Ẹshinẹgba ali oyi Omi Osumha ọyọli e ya la aghọ, eni ẹẹ ga eyọli e ya ke ga.\f + \fr 22:3 \ft Li zẹ \fq iZaka 14.11\f* 
\v 4 E ya mẹ alo eyọli, ali eva oyọli o la wẹ alukpo.  
\v 5 Ẹliyọsẹ ọa ke ya laọ. Ẹa mhọli emini e ri ugẹmhi oyi ákpá ali ugẹmhi oyi ovọ ya li, irari khi Ẹshinẹgba Ọnọmhuẹ lọlighuo ọ ya khi ákpá ọyẹwẹ, e ya ke mhẹsẹ abi ighie agbọagbọ.\f + \fr 22:5 \ft Li zẹ \fq Aza 60.19; iDan 7.18\f* 
\v 6 Ọni agẹni ọọ mhẹ, “Eni ingmemhi enana, eni a ri egbe ẹ da e khi, e gbo khi igẹsikia. Ẹshinẹgba Ọnọmhuẹ ni ọ ri ayẹmhẹ oyọli na emekẹguele, lọli ọ ghie agẹni ọyọli ọ ka rọkhasẹ eni ẹẹ ga eyọli, emini a ya mẹ ni ọa ke ya tẹsẹ.” 
\s1 IJesu ọ ya bhale 
\p  
\v 7 “A ghe ii, mhi kẹlẹ ya bhale! Ikhivọsẹ o khi na ọgbọ ni o ri ingmemhi imẹguele ni e la ebe onana gbe akanya.” 
\p  
\v 8 Mhẹmhẹ iJọni mhi suọ, ni mhi gbo mẹ emhi enana. Abi mhi rọ suọ, ni mhi rọ gbo mẹ na, mhi de ya wugha ọni agẹni ni ọ ri eni emhi enana khasẹ mhẹ awẹ ni mhi ga li.  
\v 9 Ama ọ gueyẹ mhẹ, “Khi li ighọ, ọni ọọ ga nabi yẹyẹ ali ọnabi inyọghuo ẹ emekẹguele, ali eni e ri ingme ni a kẹkẹ shi ebe onana gbe akanya mhi li khi. Ga Ẹshinẹgba!” 
\p  
\v 10 Ọọ mhẹ, “Khi khukhu ingmemhi imẹguele ni e la ebe ona, irari khi oni ẹghẹghẹ ọ she ti ramhi.  
\v 11 Ọni ọọ riẹlẹ onobe, ọ ke riẹlẹ tsẹẹ, ọni ọọ gbe ikanya ichimhi, ọ ke gbe tsẹẹ, ọni ọ guẹ a ngeli, ọ guẹ ke ngeli tsẹẹ, ọni ọ pfuasẹ, ọ pfuasẹ ke lẹ tsẹẹ.”\f + \fr 22:11 \ft Li zẹ \fq iDan 12.10\f* 
\v 12 “A ghe ii, mhi kẹlẹ ya bhale, mhi tsua ifata eyẹmhẹ, mhi ya fali ọgbọgbọ ota abi ọ li gbe.\f + \fr 22:12 \ft Li zẹ \fq Aza 40.10; 62.11; Iwolo 28.4; iJere 17.10\f* 
\v 13 Mhẹmhẹ mhi khi Aafa ali Omega, Mhẹmhẹ mhi khi ọni Ododẹ ali Ọkpukhokho, ni mhi khi Igbaekẹle ali Ukpẹsẹ.\f + \fr 22:13 \ft Li zẹ \fq Irọ 1.8,17; 2.8; Aza 44.6; 48.12\f* 
\p  
\v 14 “Ikhivọsẹ o khi na ẹgbọ ni e pfuẹ iwulu eyẹwẹ-a pfuasẹ, ni e mhuẹ obọ shi ọọra ni o ri agbọ a na ọgbọ, ali ini e ba mẹ asha rọte odẹ unuẹkpẹ ni o lo oni ẹoli, le lole.\f + \fr 22:14 \ft Li zẹ \fq Igbae 2.9; 3.22\f* 
\v 15 Ewa e la oolase oni ẹoli, ali eni ẹ mu imhẹsẹ ogbhọ ali eni ẹ li itsẹbọ ali ẹgbọ ugbeli ali eni ẹ ga ikhumhi ali eni e da nono ingme ẹgbhọli, ni ẹ di ẹgbọ. 
\p  
\v 16 “Mhẹmhẹ iJesu mhi she ghie agẹni ọyẹmhẹ o ri ọtsẹlẹ ona ghi ẹ eni igbaa nya eyi eni e mie iJesu iKirisiti suọ. Mhẹmhẹ mhi khi Umhili ali Omiomi iDefidi, Mhẹmhẹ mhi khi Ukpẹtata ni ọ gẹ ẹluzogbe.”\f + \fr 22:16 \ft Li zẹ \fq Aza 11.1,10\f* 
\p  
\v 17 Ọni Ayẹmhẹ ali ọmueshi ọnọgbọ ọọ li, “Bhale!” Ọni ọ suọ ona ọ li liẹ, “Bhale!” Ọni okiamẹ ọọ gbe ọ bhale, ali ọnini o ghọle o bhale ka da amẹ ni o ri agbọ a na ọgbọ, afuẹ afuẹ.\f + \fr 22:17 \ft Li zẹ \fq Aza 55.1\f* 
\p  
\v 18 Mhi tse agua ye ọgbọ ni ọ suọ imẹguele ni e la ebe ona. Ini ọgbọkhọghuo ọ khi ma ọ, Ẹshinẹgba ọ ya khi anasẹmhẹ ni a kẹkẹ shi ebe ona ma li agbọ.  
\v 19 Ini ọgbọkhọghuo ọ rọte ingmemhi imẹguele ni a kẹkẹ shi ebe onana rue pfi-a, Ẹshinẹgba ọ ya mie ọli okemhi ni ọ mhọli shi ọọra ni o ri agbọ a na ọgbọ, ali ashini a khi na li shi ẹoli ni o pfuasẹ, ni a ngme ingme oyọli shi oni ebe onana.\f + \fr 22:19 \ft Li zẹ \fq iDẹut 4.2; 12.32\f* 
\p  
\v 20 Ọni ọ pfi ọtsẹlẹ shi ebe onana, ọọ, “Igẹsikia lọ, mhi kẹlẹ ya bhale.” 
\p Atsẹ. IJesu Ọnọmhuẹ bhale. 
\p  
\v 21 Okhale oyi iJesu Ọnọmhuẹ o ka nu eni miesuọ nya la, Atsẹ.