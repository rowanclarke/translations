\id 1CO - IKWERRE 
\h 1 Ele Kọrinti 
\toc1 Ọkwukwo izi ke Mbọm Pọlu gbaznennu Ele Kọrinti 
\toc2 1 Ele Kọrinti 
\toc3 1 Kọr 
\mt2 Ọkwukwo izi 
\mt2 ke Mbọm 
\mt2 Pọlu gbaznennu 
\mt1 Ele Kọrinti 
\imt1 Nhne gbasịri ọkwukwo izi ka 
\im \bk Ọkwukwo izi Pọlu gbaznennu ele Kọrinti ke mbọm\bk* neelebna anya nụ bụdnu nụ ọkwnata mkpọma ke nye Karaịsi. O nookwu ọka gbasịri mkpa ke zị nụ ọgbako Chiokike ke zị nụ Kọrinti ke Pọlu miteru. Nụ ige wam, Kọrinti bụ ẹli-ọhna ke zị mkpa n'ẹli Girisi, ke bụ risi ọchichi ẹli Rom n'ọdoru-ẹli wam. Ele ẹli ka bụ ele be marnụ rẹwhna be n'ahịa, ele mkpako, nụ ele agwa ọjo, ele nọokponu chi zị ichne ichne risi ẹli. 
\ip Pọlu nookwu gbasịri okewa nụ agwa ọjo ke zị nụ rime ọgbako Chiokike pịi. O kwuru nhne gbasịri bụdnu ọgbako Chiokike nụ okpukpe, olizọ n'ẹnwu, ọlulu nzi nụ nnwerne. O kwuru nụ Izi Ọma nwernu ọsisa kpakara ajịji ele ka. 
\ip Nụ risi 13, Pọlu gesiri nụ ọwhnun'anya bụ ngọzi ke kakwo mma Chiokike nyernu ele badnụ. 
\iot Nhne zị n'ọkwukwo izi ka 
\io1 Ọpanizo \ior (1:1-9) \ior* 
\io1 Okewa nụ rime ọgbako \ior (1:10---4:21) \ior* 
\io1 Agwa ọma nụ bụdnu ezi-nụ-ọro \ior (5:1---7:40) \ior* 
\io1 Ele Karaịsi nụ ele naakwa rẹnwu \ior (8:1---11:1) \ior* 
\io1 Bụdnu ọgbako nụ okpukpe Chiokike \ior (11:2---14:40) \ior* 
\io1 Olizọ n'ẹnwu Karaịsi nụ ke ele kweru ekwe \ior (15:1-58) \ior* 
\io1 Nkesi ele Karaịsi nye ele zị nụ Judiya \ior (16:1-4)\ior* 
\io1 Mmụma Pọlu nụ okwukwo \ior (16:5-24) \ior* 
\c 1  
\p  
\v 1 Mawa, Pọlu, nye Chiokike sukwuru hite n'echiche ma ọ bụru nye izi Karaịsi Jizọsi nụ nnwọ nda aị Sọsitenisi,  
\v 2 naagbaznenu anụ, ọgbako Chiokike ke zị nụ Kọrinti ọkwukwo. Anụ bụ ele Chiokike sukwuru ma anụ be bụru ele ke a zị nsọ nụ Karaịsi Jizọsi, anụ nụ kpakara ele zị nụ hne ọbula be nọokpokwu rẹwhna Nyenwe aị Jizọsi Karaịsi, Nyenwe be nụ Nyenwe aị. 
\p  
\v 3 Oru nụ udno ke Chiokike Nda aị nụ Nyenwe aị Jizọsi Karaịsi dazịnu anụ. 
\s1 Ọtu mmamma 
\p  
\v 4 M nọotunu Chiokike m mmamma ige ọbula nụ risi anụ, o nyernu anụ oru hite nụ Karaịsi Jizọsi.  
\v 5 O mernu anụ ba aba nụ rime Karaịsi nụ kpakara nhne, ma nụ ikwu-ọnu nụ nhne ọmuma anụ.  
\v 6 Izi gbasịri Karaịsi gwuzosiri rikne nụ rime anụ.  
\v 7 Kam kpayarụ, ọ zá nkesi ke enine kọgwu anụ kpa anụ neese ige be jookpume Nyenwe aị Jizọsi Karaịsi.  
\v 8 O jeeme anụ gwuzoru kwem dụ ọsoto, ma anụ bụru ele nwée ọru n'ọbochi Nyenwe aị Jizọsi Karaịsi.  
\v 9 Chiokike, nye sukwuru anụ ma anụ nụ Nnwọ a Jizọsi Karaịsi Nyenwe aị nwekọta nhne, bụ nye kwesiri ọkwnata ovu. 
\s1 Okewa nụ rime  //  ọgbako Chiokike 
\p  
\v 10 Rụmu nda m, m ji m rẹwhna Nyenwe aị Jizọsi Karaịsi naarịasno anụ, anụ bikno, anụ kwekọrita n'otu nhne anụ nookwu, okewa zọma n'esilawụru anụ. Anụ zịri n'otu n'echiche ma nụ nhne anụ neeme.  
\v 11 Rụmu nda m, agwna ele hi n'ezi-nụ-ọro Kilo kannụ m kpa o dnornu m anya, nụ okno ọka zị n'esilawụru anụ.  
\v 12 Ka bụ nhne me naakaa, otu badnụ naakaa, “M bụ m ke Pọlu,” nye berere kaa, “M bụ m ke Apọlosi,” nye berere kwno kaa, “M bụ m ke Pita,” nye berere masị kaa, “M bụ m ke Karaịsi.” 
\p  
\v 13 Be kewarụ Karaịsi sa? Be kpọgidnernu Pọlu n'olu ọgba kwnornu anụ? Be wụru anụ mini nụ rẹwhna Pọlu sa?  
\v 14 M nọotunu Chiokike mmamma nụ ọ zá nye me wụru mini kwekọlam Kirisipọsi nụ Gayọsi.  
\v 15 Ọ zá nye jaakaa sị nụ me wụru a mini nụ rẹwhna m.  
\v 16 (Owe, m wụru m ezi-nụ-ọro Stefanasi mini, be gweme kpam, m máam ma m wụru m nye berere mini.)  
\v 17 Karaịsi zíyage m me wụ mini, kọvu o zni izi ọma. Ọ bụ́o hite n'ikwu-ọnu ke akọniche badnụ, ọ zị ẹnwu Karaịsi n'olu ọgba bụru nhne etekne. 
\s1 Karaịsi bụ akọniche  //  nụ iknernema Chiokike 
\p  
\v 18 Kwnornu nụ izi gbasịri ọgba bụ nhne etekne hne ele nọonwu ọnwu zị, kọvu hne ele be nọoznohia zị, ọ bụ iknernema Chiokike.  
\v 19 Be gbarụ a n'ọkwukwo nsọ, kaa, 
\q1 “M joolulu akọniche ke ele akọ, 
\q2 tuwhu ọghohia ke ele marnụ nhne.” 
\p  
\v 20 Ndaa hne nye akọ zị? Ndaa hne nye okne ọkwukwo zị? Ndaa hne nye agịrigo ke ọwa ka zị? Chiokike mernu akọniche ke ọwa bụru nhne iwhnirniwhno.  
\v 21 Kwnornu nụ hite n'akọniche Chiokike o kwéle ọwa mahịa nye ọ bụ hite n'akọniche ke ọwa. Ọ sọru Chiokike n'ọnu o hite n'iwhnirniwhno ke ọkpo okwo izi ọma znọhia ele kweru ekwe.  
\v 22 Ele Ju noopio nhne elekema, ele Giriki noopio akọniche.  
\v 23 Kọvu a nọokpo okwo nụ be kpọgidnernu Karaịsi n'olu ọgba, ke bụnu ele Ju rugwu ọkpobi ọchi, hne ele bụ́o ele Ju zị, ọ bụ nhne iwhnirniwhno.  
\v 24 Kọvu hne ele Chiokike sukwuru zị, ele Ju ma ele bụ́o ele Ju, Karaịsi bụ iknernema Chiokike nụ akọniche Chiokike.  
\v 25 Kwnornu nụ iwhnirniwhno Chiokike kakwo akọniche ke badnụ, rikne ọgwugwu Chiokike kakwo iknernema ke badnụ. 
\p  
\v 26 Rụmu nda m, anụ chenwanya nhne anụ bụ sụ Chiokike sukwuru anụ. Agịda anụ bụ ele ọwa karụ nụ be nwée akọniche, agịda anụ bụ ele ọwa máa, agịda anụ bụ ele híge ezi-nụ-ọro eze whụya.  
\v 27 Kọvu Chiokike họhiaru nhne iwhnirniwhno ke ọwa ma iwhnerne tụ ele akọ. Chiokike họhiaru nhne ele ọwa karụ nụ ọ zị́la rikne ma iwhnerne tụ ele zị rikne.  
\v 28 Chiokike họhiaru nhne ele ọwa lednarnụ anya nụ nhne zá nhne ọ bụ, mee nhne ke be kwuru nhne bụru nhne etekne.  
\v 29 O mernu ka ma badnụ ọbula gharụ o mee oknomokno nụ ruwhnu Chiokike.  
\v 30 Chiokike mernu anụ nụ Karaịsi Jizọsi bụru otu, nye bụrunu aị akọniche nụ rime Chiokike. Ya bụ ome mma aị nụ ọzi nsọ aị nụ ọgbahia aị.  
\v 31 Lele kpa be gbarụ a n'ọkwukwo nsọ, “Nye ọbula ke jeeme oknomokno, o mee oknomokno nụ nhne Nyenwe aị rnụrnu.” 
\c 2  
\s1 Izi ọma gbasịri Karaịsi  //  nụ ọgba a 
\p  
\v 1 Rụmu nda m, nga me vakwnusiri anụ, m jíle m okne ọka mọbu akọniche ke badnụ va kpọ okwo nhne tugwaru otugwa ke Chiokike.  
\v 2 Kwnornu nụ m píole m ọ marnụ nhne ọbula kpa me nụ anụ zị, kwekọlam nhne gbasịri Jizọsi Karaịsi, nye be kpọgidnernu n'ọgba.  
\v 3 M ji m ọ́za rikne nụ ogwnu nụ ẹhni ọznu biri biri va.  
\v 4 Nhne me znirni nụ izi m bụ́o hite nụ nkarị ọka ke akọniche ke badnụ, kọvu o gesi Enine nụ iknernema a n'esilawụru anụ,  
\v 5 ma anụ bụru ele kweru ekwe, ọ bụ́o kwnornu nụ akọniche ke badnụ, kọvu n'iknernema Chiokike. 
\s1 Akọniche Chiokike 
\p  
\v 6 Kọvu n'esilawụru ele sozuru osozu bụ hne a nookwu ọka akọniche, ọ bụ́o akọniche ke ọwa ka, mọbu ke ele nẹechi ọwa ka. Ige matị, ọ zá nhne be jọobu.  
\v 7 A nookwu nhne gbasịri akọniche Chiokike ke tugwaru otugwa, ke Chiokike họhiaru kwnornu igwugwu aị tụtu sụ ọwa panịzoru.  
\v 8 Ele ọchichi ke ọwa ka máa akọniche ka. Kwnornu nụ ọ bụru nụ be marnụ a, be bọ́ kpọgidene Nyenwe igwugwu n'olu ọgba.  
\v 9 Kọvu kpa be gbarụ a n'ọkwukwo nsọ, 
\q1 “Anya whnụ́lele, 
\q2 nsnị nụ́lele, 
\q1 ọ bnána n'ovu badnụ rịa rịa, 
\q2 nhne Chiokike bịtannu ele whnụrnu a n'anya.” 
\p  
\v 10 Kọvu Chiokike hiri n'Enine a kpumenu aị nhne o tugwaru otugwa, kwnornu nụ Enine noonyosna kpakara nhne, ma nhne miri emi ke Chiokike.  
\v 11 Ọ zá nye magwụ echiche ke mkpọma badnụ, o kwolem enine ke zị nụ rime badnụ. Kpam masị, ọ zá badnụ ke magwụ echiche Chiokike, okwolem Enine Chiokike magwụ kpakara nhne gbasịri Chiokike.  
\v 12 A náhịage enine ke ọwa ka, kọvu a nahịaru Enine Chiokike ziyaru ma a mahịa kpakara nhne Chiokike hiri n'ovu ọma a kesi aị.  
\v 13 Ka bụ nhne a nookwu, ọ bụ́o hite nụ nhne ke badnụ znirni aị nụ akọniche ke badnụ, kọvu nhne Enine znirni aị. A nọokowa ezi ọka ke enine hne ele nwernu Enine Chiokike zị.  
\v 14 Badnụ ke nwée Enine Chiokike nwée rikne kweru nhne hi n'Enine Chiokike va, kwnornu nụ be bụnu a nhne iwhnirniwhno, o nwée rikne nahịa be kwnornu nụ Enine Chiokike nọokowanu ele nwernu Enine.  
\v 15 Badnụ ke nwernu Enine Chiokike neekpe kpakara nhne ikpe, kọvu ọ zá nye jeekpe a ikpe.  
\v 16 Lele kpa be gbarụ a n'ọkwukwo nsọ, 
\q1 “Nyele magwụ echiche Nyenwe aị, 
\q2 ma nye wam zni a ezni?” 
\m Kọvu a nwernu echiche ke Karaịsi. 
\c 3  
\s1 Ele ẹrnu Chiokike 
\p  
\v 1 Rụmu nda m, m nwée m rikne kwunu anụ ọka lele ele nwernu Enine, kọvu m nookwunu anụ ọka lele badnụ etekne, lele rụmu takịri nụ rime Karaịsi.  
\v 2 M jeeji mini-rẹma nọoznu anụ, ọ bụ́o wiri siri rikne, kwnornu nụ anụ jéenwe rikne ri be. Tem dụ kịtna, anụ nwée rikne ri wiri siri rikne.  
\v 3 Anụ zị kọriri n'anọ-ẹhni, kwnornu nụ okwno-awụwa nụ okno ọka zị n'esilawụru anụ, ka ọ zá neegesi nụ anụ zị n'anọ-ẹhni? Anụ neeme lele badnụ etekne.  
\v 4 Otu badnụ naakaa, “M bụ m ke Pọlu.” Nye berere kaa, “M bụ m ke Apọlosi.” Anụ zá neeme lele badnụ etekne? 
\p  
\v 5 Nyele bụ Pọlu? Nyele bụ Apọlosi? A bụ ele ẹrnu, ele anụ hiri n'aka be kweru. Nye ọbula nọornu ẹrnu ke Nyenwe aị nyernu a.  
\v 6 Mawa kpasịri mkpụru, Apọlosi wụsi a mini. Kọvu Chiokike mernu mkpụru wam so oso.  
\v 7 Nye wam kpasịri mkpụru nụ nye wam wụsiri a mini bụ nhne etekne. Chiokike zị mkpa kwnornu nụ ọ bụ ya mernu mkpụru wam so oso.  
\v 8 Nye wam kpasịri mkpụru nụ nye wam wụsiri a mini bụ otu. Nye ọbula jaanarnụ ọgwo ẹrnu a lele kpa ẹrnu a hna.  
\v 9 Kwnornu nụ aị nụ Chiokike nọornuko ẹrnu n'otu, anụ bụ ẹkwu Chiokike. Anụ bụ ọro Chiokike noowu. 
\p  
\v 10 Hite nụ oru Chiokike nyernu m, m nọornu ẹrnu lele nye nka-owu ọro. M tụru m ntụ-ẹli ọro, nye berere noowukwasị ọro n'olu a. Kọvu anya dụ nye noowu ọro n'olu a ẹli.  
\v 11 Kwnornu nụ ọ zá ntụ-ẹli berere badnụ jeenwe rikne tụ, kakwo ke Chiokike tụru, ke bụ Jizọsi Karaịsi.  
\v 12 Ọ bụru nụ badnụ ọbula jeeji golu, mọbu siliva, mọbu akaworugwu zị okne ọnu ahịa, mọbu isisi, mọbu rụhiara, mọbu isisi ịkpa wukwasị ọro n'olu ntụ-ẹli ka,  
\v 13 ẹrnu a jọowhuya iwhne, kwnornu nụ ọbochi Karaịsi jookpume a. Be jeeji bẹkwnu kpa ẹrnu nye ọbula iru, bẹkwnu jeegesi nhne nye ọbula jiri wu ọro a.  
\v 14 Ọ bụru nhne badnụ jiri wu ọro n'olu ntụ-ẹli wam gwuzogidne bẹkwnu, ọ jaanahịa ọgwo ẹrnu.  
\v 15 Kọvu ọ bụru nụ bẹkwnu rne ẹrnu a, nhne whuru a, kọvu be jọoznohia a, kọvu lele nye hi nụ bẹkwnu whụya.  
\v 16 Anụ máa nụ anụ bụ Ọro Nsọ Chiokike, nụ Enine Chiokike wu nụ rime anụ?  
\v 17 Ọ bụru nye ọbula lulu Ọro Nsọ Chiokike, Chiokike joolulu a. Ọro Nsọ Chiokike zị nsọ, anụ bụ Ọro Nsọ a. 
\p  
\v 18 Ọ zá nye duhie ẹhni a, ọ bụru nụ nye ọbula neeche nụ o nwernu akọ nụ nhne ke ọwa ka, ọ ghọ nye iwhnirniwhno ma ọ bụru nye nwernu akọniche.  
\v 19 Kwnornu nụ akọniche ke ọwa ka bụ nhne iwhnirniwhno n'anya Chiokike. Lele kpa be gbarụ a n'ọkwukwo nsọ, “O jidnernu ele akọ n'aghịgho be.”  
\v 20 Be gba kwno a n'ọkwukwo nsọ, kaa, “Nyenwe aị magwụ echiche ele akọ nụ ọ bụ nhne etekne.”  
\v 21 Ọ zị́ badnụ ke ji nhne badnụ etekne nwernu rikne mee nyaa risi. Kwnornu nụ kpakara nhne bụ ke anụ,  
\v 22 Pọlu mọbu Apọlosi, mọbu Pita, ọwa ka, bụdnu nụ ẹnwu, nhne zị kịtna mọbu ke zị nụ ruwhnu, kpakara be bụ ke anụ,  
\v 23 anụ bụ ke Karaịsi, Karaịsi bụ ke Chiokike. 
\c 4  
\s1 Ele izi Karaịsi 
\p  
\v 1 Ele badnụ kwesiri ọ gwnụ aị lele ele izi Karaịsi, ele Chiokike nyernu nhne tugwaru otugwa ke ezi ọka a n'aka.  
\v 2 Nhne be pioru n'aka nye neelegidne nhne ọbula bụ be whnụ a nụ ọ bụ nye kwesiri ọkwnata ovu.  
\v 3 Nhne anụ nookwu gbasịri m zá m mkpa, mọbu ikpe nye berere neekpe m, m jéekpe ẹhni m ikpe.  
\v 4 Ovu m zị snam, kọvu ka zá neegesi nụ m bụ m nye ikpe mána. Nyenwe aị bụ nye neekpe m ikpe.  
\v 5 Kam kpayarụ, anụ kpé nhne ọbula ikpe hne ige yóoduge, seru tem Nyenwe aị va, o jeeme kpakara nhne tugwaru otugwa n'ọchichiri whụya iwhne. Ọ jaakahịa kpakara nhne zị n'ovu badnụ. Ige wam nye ọbula jaanahịa ọznarni a n'aka Chiokike. 
\p  
\v 6 Rụmu nda m, m gweru m kpakara nhne ka tụsinu ẹhni m nụ ẹhni Apọlosi kwnornu anụ, ma anụ jiri aị mụhia nhne ele badnụ nookwu, “Ọ zá nye mee nhne be gbáge n'ọkwukwo.” Ọ zá nye ji otu badnụ nyaa risi megidne ibne a.  
\v 7 Nyele mernu i, ị zịri ichne hne ele berere zị? Kịni bụ nhne i nwernu ke be késige i? Ọ bụru nụ nhne i nwernu bụ nkesi, ndaa kpa i jeeji a nyaa risi lele nụ ọ bụ́o nkesi? 
\p  
\v 8 Kịtna, rụwho jihịaru anụ. Anụ balam aba. Anụ ghọlam eze, ọ bụ n'ezi a bụ́o ele eze. Ọ jaama mma ọ bụru nụ anụ bụ ele eze, ma a snornu anụ bụru masị eze.  
\v 9 M che m nụ Chiokike beteru aị ele izi aznụ, lele ele be joogbu ogbu, nhne olekiri nyee ọwa, ma hne ele enine izi nụ hne ele badnụ zị.  
\v 10 A bụ ele iwhnirniwhno kwnornu Karaịsi, kọvu anụ bụ ele nwernu akọ nụ Karaịsi. A nwée rikne, kọvu anụ nwernu rikne. Be lednarnụ aị anya, kọvu anụ nwernu igwugwu.  
\v 11 Tem dụ kịtna, wiri nọogwnu aị, akpịri nọokpo aị bẹkwnu, a gba ẹto, be mejọru aị, a nwée hne a bịta risi.  
\v 12 A nọodogbu ẹhni aị n'ẹrnu, a ji aka aị nọornu nhne a neeri. Be nọovu aị ọnu, a nọogozi, nga be kpagburu aị, a snụta ovu.  
\v 13 Nga be kpajarụ aị, a ji ovu ọma sa ọka. A nụ lele nhne mkpomkpo ke ọwa ka, tem dụ kịtna, ele ọwa kwúge aị nhne ọbula. 
\p  
\v 14 M zá m naagba ọkwukwo ka ma iwhnerne tụ anụ, kọvu ma m zni m anụ ezni lele rụmu ke m me whnụrnu n'anya.  
\v 15 Kwnornu nụ ọ bụru nụ anụ nwernu nri pokwu ele noodu anụ nụ rime Karaịsi, anụ nwernu otu nda. M bụ m nda anụ nụ rime Karaịsi Jizọsi kwnornu nụ m gweyanụ m anụ izi ọma.  
\v 16 M naarịasno anụ snornu rẹnu ọchi m.  
\v 17 Kam kpayarụ, me neeziyanu anụ Timoti. Ọ bụ nnwọ m me whnụrnu n'anya ke kwesiri be kwnata a ovu nụ rime Nyenwe aị. Ọ jeechenwanyanu anụ kpa me noowu bụdnu m nụ rime Karaịsi Jizọsi, kpa me neezni nụ rime kpakara ọgbako Chiokike ke zị nụ hne ọbula. 
\p  
\v 18 Agwna anụ bụ ele oknomokno, anụ neeche nụ m jáava lekwa anụ.  
\v 19 Ọ bụru nụ Nyenwe aị kweru, m jaava kwnusi anụ wara wara, m jaamahịa nhne ele oknomokno wam jeeme. Ọ bụ́o nhne be jookwu kpọi, ma rikne be nwernu masị.  
\v 20 Kwnornu nụ ẹli-eze Chiokike bụ́o n'agịda ikwu-ọnu kpọi, kọvu iknernema.  
\v 21 Ndaa nhne anụ pioru? Me gweru mbịnibini va, sụ ọ bụ ovu ọwhnun'anya nụ enine zị wọhnernerne? 
\c 5  
\s1 Anụ gweme nnwọ nda  //  ke zị́la rịchna 
\p  
\v 1 M nọonu nụ ome ọyi zị n'esilawụru anụ, ke zị́la n'esilawụru ele máa Chiokike, nụ badnụ nookwuru nnwerne nda a.  
\v 2 Ndaa kpa anụ neeme oknomokno nụ kpa? Anụ kwesiri ọ kwna ẹkwna, nwe ovu ọjo, anụ kwesiri ọ chịhala nyerukna ke mernu nhne ka n'esilawụru anụ.  
\v 3 Ọ bụ n'ezi m zị m ikere hne anụ zị n'anọ-ẹhni, kọvu me nụ anụ zị n'enine, m marnụ m nye mernu nhne ọjo ka ikpe lele nụ me nụ anụ zị.  
\v 4 Kpa anụ gbakọru nụ rẹwhna Nyenwe aị Jizọsi, m joosno anụ gbakọ n'enine, rikne Nyenwe aị Jizọsi jaadazịnu aị masị.  
\v 5 Anụ gweru nye wam yisi n'aka Ekwensu ma o lulu anọ-ẹhni a, ma be znọhia enine a n'ọbochi Nyenwe aị. 
\p  
\v 6 Anụ méma oknomokno, kwnornu nụ nhne whụ brẹdi matị neeme kpakara brẹdi whụ ọwhu.  
\v 7 Anụ gweme mmehie ke nụ lele nhne whụ brẹdi ọknani ma anụ zịri rịchna. Nga wam, anụ jọonu lele brẹdi ikne ke nwée nhne whụ brẹdi, lele kpa anụ kwesiri. Kwnornu nụ be jiri Karaịsi Nnwọ Atnụrnu Ọgawhe aị kwanụ aị arịohna.  
\v 8 Ngwa ma a bịta Iriri ka, ọ bụ́o hite nụ nhne whụ brẹdi ke mmehie ọknani nụ risi rikne, kọvu brẹdi ke nwée nhne whụ brẹdi nụ rime a, brẹdi ke zị rịchna ke nwernu ezi ọka nụ rime a. 
\p  
\v 9 M gbannụ m anụ ọkwukwo, anụ nụ ele neeme ọyi mékọta nhne.  
\v 10 M zá m nookwu gbasịri ele neeme ọyi k'ọwa, ele ọwho-anya nụ ele buznu nụ ele naakwa rẹnwu. Ọ bụru kpam, anụ jọowhoga n'ọwa.  
\v 11 Kọvu m naagbanụ anụ kịtna, naakaa, anụ nụ nye ọbula ke kwuru ẹhni a nnwọ nda, kọvu o neeme ọyi, ke nwernu ọwho-anya, nye naakwa rẹnwu, mọbu nye naakaja badnụ, nye okne manya, mọbu nye buznu mékọta nhne. Anụ nụ nye wam dázịkota ẹli ri wiri. 
\p  
\v 12 Ọ zá m mkpa me kpe ele zị n'ederezi ikpe. Ọ bụ́o anụ kwesiri o kpe ele zị n'esilawụru anụ ikpe?  
\v 13 Chiokike jeekpe ele zị n'ederezi ikpe. Lele kpa ọkwukwo nsọ kwuru, “Anụ chịhala badnụ ọjo wam n'esilawụru anụ.” 
\c 6  
\s1 O kwuru badnụ zne  //  ọro ikpe 
\p  
\v 1 Ọ bụru nụ otu badnụ nwernu nhne megidne nnwọ nda, ị ga ọla gba nnwọ nda ị ọkwukwo n'ọro ikpe, ele máa Chiokike kpe be ikpe, tnụnuma, o jookwuru a zne n'esilawụru rụmu Chiokike?  
\v 2 Anụ máa nụ rụmu Chiokike jeekpe ọwa ikpe sa? Ọ bụru nụ anụ jeekpe ọwa ikpe, anụ nwée rikne kpe ikpe ọka matị n'esilawụru anụ?  
\v 3 Ọ bụ nụ anụ máa nụ a jeekpe ele enine izi ikpe? Ọ kọ bụru nhne ke bụdnu ka.  
\v 4 Ọ bụru nụ ọka dnarnụ ke gbasịri bụdnu ka, kịni mernu anụ neekwe ele zị n'ederezi kpe anụ ikpe? Ele ikpe ka bụ ele nwée ọso anya n'ọgbako Chiokike.  
\v 5 Iwhnerne tụ anụ. M kweru m nụ otu badnụ ke nwernu akọniche zị n'esilawụru anụ, nye jeenwe rikne kpe ikpe n'esilawụru rụmu nda.  
\v 6 Tnụnuma, otu nnwọ nda jookwuru nnwọ nda berere zne n'ọro ikpe ma ele kwé ekwe kpe be ikpe. 
\p  
\v 7 Anụ naagbarịta ẹhni anụ ọkwukwo n'ọro ikpe, ka neegesi nụ anụ dnarnụ adna. O jáaka mma nụ i bụ nye be mejọru? Ọ jáaka mma nụ nhne whunahọru ị?  
\v 8 Tnụnuma, anụ neeme ibne nhne ọjo, anụ znụnahoru nnwọ nda anụ nhne.  
\v 9 Ọ bụ nụ anụ máa nụ ele ọjo jéekehịa ẹli-eze Chiokike? Anụ dúwhu ẹhni anụ, ele naagba ewhere, mọbu ele naakwa rẹnwu, mọbu ele neeme ọyi, ele rukna naadnanyị ele rukna ibne be,  
\v 10 mọbu ele buznu, mọbu ele ọwho-anya, mọbu ele okne manya, mọbu ele naakaja badnụ, mọbu ele nọoghogbu ele badnụ jéekehịa ẹli-eze Chiokike.  
\v 11 Agwna anụ nụ kpam nụ mbọm. Kọvu be snụmarnu mmehie anụ, be gweru anụ nyewhete n'aka Chiokike. Be mernu anụ nụ Chiokike zịri n'udno hite nụ rẹwhna Nyenwe aị Jizọsi Karaịsi nụ Enine ke Chiokike aị. 
\s1 Kwasịnu Chiokike  //  igwugwu 
\p  
\v 12 “M nwernu m rikne mee kpakara nhne.” Kọvu ọ bụ́o kpakara nhne naabna mbnarna. “M nwernu m rikne mee kpakara nhne.” Kọvu m jọ́obu ọhi nhne ọbula.  
\v 13 “Wiri zịnu rụwho, rụwho zị masịnu wiri.” Kọvu Chiokike joolulu kpakara be. Be jéeji ẹhni badnụ neeme ọyi, kọvu kpenu Nyenwe aị, Nyenwe aị jeeme ẹhni badnụ nwehịa nhne zị mkpa.  
\v 14 Chiokike nye mernu Nyenwe aị hi n'ẹnwu lizọ, o jeeme masị anọ-ẹhni aị hi n'ẹnwu lizọ hite n'iknernema a.  
\v 15 Ọ bụ nụ anụ máa nụ ẹhni anụ bụ nhne zị n'ẹhni Karaịsi? M jeegweru nhne zị n'ẹhni Karaịsi mee be bụru nhne zị n'ẹhni nyerinya ewhere? Ọ́za rịa rịa.  
\v 16 Ọ bụ nụ anụ máa nụ nye gweru ẹhni a yisi n'ẹhni nye ewhere, ya nụ a ghọlam otu anọ-ẹhni? Kwnornu nụ ọkwukwo nsọ kwuru, “Be lawụru jọoburu otu anọ-ẹhni.”  
\v 17 Kọvu nye gweru ẹhni a yisi nụ Nyenwe aị, ya nụ Nyenwe aị ghọlam otu n'enine. 
\p  
\v 18 Anụ gbanahọru ome ọyi. Kpakara mmehie berere badnụ mernu zị n'olu ẹhni, kọvu nye neeme ọyi megidnernu ẹhni a mmehie.  
\v 19 Ọ bụ nụ anụ máa nụ ẹhni anụ bụ Ọro Nsọ ke Enine Nsọ, nye wu nụ rime anụ, ke Chiokike nyernu anụ? Anụ nwée ẹhni anụ, Chiokike nwe anụ.  
\v 20 O jiri ọnu ahịa gbahịa anụ. Anụ gweru ẹhni anụ kwasịnu Chiokike igwugwu. 
\c 7  
\s1 Ajịji gbasịri ọlulu  //  nzi nụ nnwerne 
\p  
\v 1 Nhne gbasịri nhne anụ gbarụ n'ọkwukwo, “Ọ bụru ọma nụ nyerukna nụ nyerinya dnányi lele nzi nụ nnwerne.”  
\v 2 Kọvu kwnornu nụ agịda ele neeme ọyi zị n'esilawụru anụ, ọ bụru ọma nyerukna ọbula lụru nnwerne ke aka a, nụ nyerinya gbọru nzi ke aka a.  
\v 3 Nyerukna ọbula mee nhne kwesiri a lele nzi hne nnwerne a zị, nyerinya ọbula mee nhne kwesiri a lele nnwerne hne nzi a zị.  
\v 4 Nnwerne nwée rikne hne ẹhni a zị, kọvu nzi nwernu, kpam masị nzi nwée rikne hne ẹhni a zị, kọvu nnwerne a nwernu.  
\v 5 Anụ gọ́nahoru ẹhni anụ ẹhni anụ, okwolem ma ọ bụ ige matị kpa anụ kwekọtaru, ma anụ vu ọnu nụ kpe okpukpe. Omekwo, anụ zịri n'otu berere ma Ekwensu gharụ ọ rna anụ ọrnurna, kwnornu nụ anụ nwée rikne jikwaru ẹhni anụ.  
\v 6 Ka bụ rikne me neenye anụ, ọ bụ́o iwu.  
\v 7 N'ezi ọka, ọ jaamasị m nụ kpakara badnụ jaadazị lele me. Kọvu nye ọbula nwernu nkesi ke Chiokike kesiri, otu nyenum kpa, nye berere nkesi berere. 
\p  
\v 8 Kịtna, m naakanụ ele lụ́ge nnwerne mọbu ele gbọ́ge nzi, mọbu ele rinya nzi be nwụrnu, ọ jaaka mma anụ dazịri etekne, lele kpa me dazịri.  
\v 9 Kọvu ọ bụru nụ anụ jéenwe rikne jikwaru ẹhni anụ, anụ lụru nnwerne mọbu gbọru nzi. Ọ ka mma ọ lụru nnwerne mọbu gbọru nzi, tnụnuma ẹhni anụ jeerne bẹkwnu. 
\p  
\v 10 Ele nwernu nzi mọbu nnwerne, m neenye anụ iwu Nyenwe aị, ọ bụ́o ke m. Nnwerne gbákwadia nzi a nnam.  
\v 11 Kọvu, o mee kpam, ọ jaadazịri etekne mọbu ọ lahna ke nzi a, nzi gbákwadia nnwerne a nnam. 
\p  
\v 12 M naakanụ ele ke gwnarnụ, ọ bụ́o Nyenwe aị, ọ bụru nụ nye Karaịsi ọbula nwernu nnwerne ke kwé ekwe, kọvu o kweru ya nụ a wugidne, ọ gbála a nnam.  
\v 13 Ọ bụru nụ nyerinya Karaịsi ọbula nwernu nzi ke kwé ekwe, kọvu nzi a kweru ma be wugidne n'otu, ọ gbála a nnam.  
\v 14 Kwnornu nụ Chiokike nabnanyarnụ nzi ke kwé ekwe kwnornu nnwerne a ke kweru ekwe. Chiokike naabanyarnụ nnwerne ke kwé ekwe kwnornu nzi a ke kweru ekwe. Ọ bụru nụ ọ bụ́o kpam, rụmu takịri anụ jọoburu ele zị́la rịchna, kọvu be zị nsọ kịtna. 
\p  
\v 15 Kọvu ọ bụru nụ ọ masịri nye ke kwé ekwe ọ gba nnam, o mee kpam. Ọ zá iwu ke ji nye Karaịsi, nzi mọbu nnwerne, n'ọnodi nụ kpa. Chiokike sukwuru aị ma a wuru n'udno.  
\v 16 Ndaa kpa i jiri mahịa, jị nnwerne ke kweru ekwe, nụ ị jọ́oznohia nzi i? Mọbu jị nzi ke kweru ekwe, ndaa kpa i jiri mahịa nụ ị jọ́oznohia nnwerne ị? 
\s1 Dazịri n'ọnodi  //  Chiokike sukwuru i 
\p  
\v 17 Kọvu nye ọbula dazịri n'ọnodi ọ zị nga Chiokike sukwuru a, bụ ke Chiokike nyernu a. Ka bụ nhne me neezni nụ rime kpakara ọgbako Chiokike.  
\v 18 Ọ bụru nụ nye be kparụ nka nụrnu ikwu Chiokike, o gwépụko nhne atụ ọkpa nka a. Ọ bụru masị nụ nye be kpáge nka nụrnu ikwu Chiokike, be kpála a nka.  
\v 19 Ọkpa nka nụ be kpáge nka zá nhne ọ bụ, nhne zị mkpa bụ ọbita iwu Chiokike.  
\v 20 Badnụ ọbula dazịri n'ọnodi ọ zị nga Chiokike sukwuru a.  
\v 21 Ị zị n'ọhi nga Chiokike sukwuru i? O mékpa ị ẹhni, kọvu ọ bụru nụ ị nwernu oghere ọ whọga n'ọhi, mee kpam.  
\v 22 Kwnornu nụ nye bụ ọhi nga Nyenwe aị sukwuru a bụ nye nwernu ẹhni a nụ rime Nyenwe aị. Kpam masị, badnụ ke nwernu ẹhni a nga Nyenwe aị sukwuru bụ ọhi Karaịsi.  
\v 23 Chiokike ji ọnu ahịa gbahịa anụ, anụ ghọ́ko ọhi ke badnụ.  
\v 24 Rụmu nda m, badnụ ọbula dazịri n'anya Chiokike n'ọnodi ọ zị nga Chiokike sukwuru a. 
\s1 Ele nwée nzi  //  mọbu nnwerne 
\p  
\v 25 Nhne gbasịri ele rinya máa nyerukna, mọbu ele rukna máa nyerinya, m nwée m nhne Nyenwe aị nyernu n'iwu, kọvu m neenye anụ nhne bụ echiche m, nye hite n'obirizi ke Nyenwe aị m kwesiri m ọtukwasi ovu.  
\v 26 Mkpa karịlam n'ọwa kịtna, m che m nụ ọ bụru ọma ọ bụru nụ badnụ dazịri kpa ọ zị.  
\v 27 Ọ bụru nụ ị nwernu nnwerne? Ị ghásala a. I nwée nnwerne sa? Ị lụ́ko nnwerne.  
\v 28 Ọ bụru nụ ị lụru nnwerne ọ zá mmehie i mernu. Ọ bụru nyerinya máa nyerukna gbọ nzi, ọ zá nhne ọjo ọ bụ. Kọvu ele nwernu nnwerne mọbu nzi jeenwe agịda mkpa n'ọwa ka, m noopio ọ dọhia anụ nụ nhne ka. 
\p  
\v 29 Rụmu nda m, nhne me nookwu bụ ka, ige wam zị ndụndu, hite kịtna ele nwernu nnwerne zịri lele nụ be nwée nnwerne,  
\v 30 ele naakwna ẹkwna lele nụ be zá n'anya-mini, ele nọomu rụmu lele nụ ovu zá nọoso be n'ọnu, ele nọozu ahịa lele nụ ọ zá nhne be zụhiaru,  
\v 31 ele ji nhne ọwa ka lele nụ ọ zá be mkpa. Kwnornu nụ ọwa ka n'ọnodi a jaagawhe. 
\p  
\v 32 M noopio ma nhne ọbula gharụ ọ kpakna anụ ẹhni. Nyerukna ọbula ke nwée nnwerne neeche echiche gbasịri ẹrnu Nyenwe aị, kwnornu nụ o pioru o mee nhne jaamasị Nyenwe aị.  
\v 33 Kọvu nyerukna ke nwernu nnwerne neeche echiche gbasịri nhne ke ọwa ka, kwnornu nụ o pioru o mee nhne jaamasị nnwerne a,  
\v 34 ke nọodoghari a n'apna lawụru. Nyerinya ke nwée nzi mọbu ke máa nyerukna neeche echiche gbasịri ẹrnu Nyenwe aị, kwnornu nụ o pioru o gweru ẹhni a nụ enine a nyee Nyenwe aị. Kọvu nyerinya ke nwernu nzi neeche echiche gbasịri nhne ke ọwa ka, kpa o jeeme nhne jaamasị nzi a.  
\v 35 M nookwu nhne ka ma ọ bnanụ anụ iru. M zá m noobnosni anụ. Kọvu m pioru m ma anụ mee nhne bụru ọma nụ ke kwesiri ekwesi, ma anụ gweru kpakara ẹhni anụ yisi n'ẹrnu Nyenwe aị, gharụ o le anya n'aznụ. 
\p  
\v 36 Nhne ke gbasịri ele kwekọtaru ọlulu, ọ bụru nụ badnụ ọbula whnụrnu nụ ọ zá naakpakwa agwa nkarị hne nyerinya o kweru ọ lụ zị, ọ bụru n'awha neezne, ọ lụru a, be mége mmehie.  
\v 37 Kọvu hne badnụ kpebiri n'ovu a, ọ zá nye naamagidne a nụ ọ jọ́olu nnwerne, o nwernu rikne gharụ ọ lụ nnwerne wam, o mernu nhne kwesiri.  
\v 38 Nye ke lụru nnwerne mernu nhne ọma, kọvu nye ke lụ́ge rịa rịa mekakworu nụ nhne ọma. 
\p  
\v 39 Nyerinya gbọru nzi zị n'iwu kpa nzi a zị bụdnu, kọvu hne nzi a nwụrnu, ọ zá iwu ji a ma ọ gbọru nzi berere. Kọvu ọ jọobu nye magwụ Nyenwe aị.  
\v 40 Kọvu n'echiche m, ovu jọoso a n'ọnu ọ bụru ọ dazịri etekne. M che m nụ m nwernu m Enine Chiokike. 
\c 8  
\s1 Wiri be jiri kwanụ  //  rẹnwu arịohna 
\p  
\v 1 Nhne ke gbasịri wiri be jiri kwanụ rẹnwu arịohna, ọ bụ n'ezi nụ, “Kpakara aị nwernu nhne ọmuma.” Kọvu nhne ọmuma neegweya badnụ vulizọ ẹhni a olu. Ọwhnun'anya noowulizọ badnụ olu lele ọro.  
\v 2 Ọ bụru nụ badnụ ọbula neeche nụ ọ magwụ nhne, ọ máa kpa o kwesiri ọ mahịa.  
\v 3 Kọvu Chiokike magwụ ele whnụrnu a n'anya. 
\p  
\v 4 Nhne gbasịri wiri be jiri kwanụ rẹnwu arịohna, a magwụ nụ ọ zá nhne rẹnwu ke ọwa ka bụ, kwnornu nụ chi berere zá, okwolem Chiokike kpọi.  
\v 5 Ọ bụbedi nụ agịda nhne be nookwu “chi” zị n'oligwe mọbu n'ọwa, ọ bụ n'ezi nụ be zị agịda “chi” nụ “nyenwe,”  
\v 6 kọvu hne a zị, otu Chiokike kpọi nye bụ Nda. O keru kpakara nhne, a zịnu a bụdnu. Otu Nyenwe aị Jizọsi Karaịsi zị, nye be hiri n'aka a ke kpakara nhne, nye a zị bụdnu n'aka a. 
\p  
\v 7 Kọvu ọ bụ́o kpakara badnụ magwụ ezi ọka ka. Agwna badnụ yiri risi nụ rẹnwu dụ kịtna, nga be riri wiri kị, be neeche nụ be ji a kwanụ rẹnwu arịohna. Echiche ovu be zá rikne, wiri be riri kparụ be.  
\v 8 Kọvu wiri jéeme aị nụ Chiokike zịri ndụndu. A ríle wiri, ọ zá nhne o neegweme n'ẹhni aị, a ri wiri ọ zá nhne o neeyisi ẹhni aị. 
\p  
\v 9 Kam kpayarụ, anya dụ anụ ẹli, i kwékwadia oghere i nwernu nụ ome kpa ọ masịri ị mee ele zá rikne n'ọkwnata ovu dnabna nụ mmehie.  
\v 10 Ọ bụru nụ otu badnụ ke mkpọma síle rikne whnụrnu i hne ị dazị ẹli neeri wiri n'ọro rẹnwu, kwnornu nụ i nwernu “nhne ọmuma,” o jéenye a mkpọma siri rikne o ri nhne be jiri kwanụ rẹnwu arịohna?  
\v 11 Nnwọ nda wam zá rikne, nye Karaịsi kwnornu nụ a nwụma, joowhu etekne kwnornu nụ nhne ọmuma ị.  
\v 12 Kpam, anụ mehieru nnwọ nda anụ wam zá rikne, lulu ovu a, anụ mehielem Karaịsi masị.  
\v 13 Ọ bụru nụ wiri me jeeri jeeme nnwọ nda m mmehie, m jéeri ọkpna rịa rịa kpa me zị bụdnu, ọ zị me mee nnwọ nda m dnabna nụ rime mmehie. 
\c 9  
\s1 Rikne nụ ẹrnu ke nye izi 
\p  
\v 1 Ọ bụ nụ m nwée m ẹhni sa? Me bụ́o nye izi sa? Me whnụ́ge Jizọsi Nyenwe aị anya? Anụ bụ́o nhne me rnụhiaru n'ẹrnu Nyenwe aị?  
\v 2 Ọ bụru nụ ele berere whnụ́ge m lele nye izi, anụ magwụ nụ m bụ m nye izi. Anụ bụ nhne atụ ke neegesi nụ m bụ m nye izi Nyenwe aị. 
\p  
\v 3 Nhne me naakanụ ele nookwulu m bụ ka,  
\v 4 a nwée rikne ri wiri mọbu nwọ mini n'ẹrnu aị sa?  
\v 5 A nwée rikne mee nhne ele izi berere neeme? A nwée rikne lụru otu nnwọ rinya Karaịsi lele nnwerne, o snornu aị zne izi lele ele izi ele berere nụ rụmu nne Nyenwe aị nụ Pita?  
\v 6 Okwokọla me nụ Banabasị kwesiri ọ rnụ ẹrnu sị a ri wiri? 
\p  
\v 7 Ndaa nye ọgwnu ke nọolu ọgwnu hite n'ịwai ke hi nụ rẹkpa a whụya? Ndaa nye jọornu ẹkwu, ma o jéeri mkpụru hi nụ rime ẹkwu a? Ndaa nye nọoznu atnụrnu ma ọ zá nọonwo mini-rẹma atnụrnu a?  
\v 8 Me nookwu lele badnụ etekne sa? Ọ bụ́o nhne Iwu aị kwuru sa?  
\v 9 Kwnornu nụ be gbarụ n'ọkwukwo Iwu Mozizi, “I knésni ọnu ehni ke nọozosna ịkpa.” Chiokike o nookwu nhne gbasịri ehni kpọi?  
\v 10 O kwuru nhne ka kwnornu aị. Be gbarụ a n'ọkwukwo kwnornu aị, nụ nye nọotu ọnu-ẹli nụ nye nọozosna mkpụru nwernu ọkwnata ovu nụ be jeeri mkpụru hiri n'ẹkwu.  
\v 11 A kpasịri mkpụru ke enine nụ rime anụ, ọ bụ́o nhne kwesiri nụ a jọoghoru mkpụru etekne n'ẹhni anụ?  
\v 12 Ọ bụru nụ ele berere nwernu rikne kpa hne anụ zị, ọ bụ ayịla jéenwe rikne karụkwo hne anụ zị? 
\p Kọvu a mége kpam, a nwernu ndidi nụ kpakara nhne, ọ zị a bịta nhne ọkpobi ọchi n'apna izi ọma Karaịsi.  
\v 13 Ọ bụ nụ anụ máa nụ ele nọornu ẹrnu n'Ọro Nsọ neeri nhne hi n'Ọro Nsọ whụya? Ọ bụ nụ anụ máa masị nụ ele nọornu ẹrnu n'ojo arịohna neeri agwna nhne be jiri kwa arịohna?  
\v 14 Kpam masị, Chiokike nyernu iwu nụ ele neezni izi ọma be ri wiri hiri n'izi ọma whụya. 
\p  
\v 15 Kọvu m mége m kpam. M zá m naagba ọkwukwo ka ma m nwernu rikne mee kpam. Kwnornu nụ ọ jaakanụ m mma me beru ọsno nwụma ẹnwu tna, ọ zá nye mee igwugwu m nhne etekne.  
\v 16 M nwée m rikne nyaa risi nụ m neezni izi ọma. Mkpa naakpa m bụ o zni izi ọma. Owe! Ọvu ọnu zịnu m ọ bụru nụ m zníge m izi ọma.  
\v 17 Ọ bụ me gweru mkpọma m zni izi ọma ka, m nwernu m ọgwo ẹrnu, kọvu ọ bụru nụ jíge m mkpọma m zni izi ọma, m nọornu ẹrnu Chiokike yisiri m n'aka.  
\v 18 Ọ bụru kpam, kịni bụ ọgwo ẹrnu m? Ọ bụ oghere o zni izi ọma gharụ ọ whnụ ọnu ahịa, gharụ o gweru rikne me nwernu n'izi ọma mee nhne. 
\p  
\v 19 Ọ bụ n'ezi nụ m bụ́o m ọhi nye ọbula, m nwernu m ẹhni, kọvu m mernu m ẹhni ọhi kpakara badnụ ma m rihịa m agịda badnụ n'iru.  
\v 20 Hne ele Ju zị, m bụ m nye Ju ma m rihịa m ele Ju. Hne ele zị nụ mkpururu iwu zị, m zịri lele nụ m zị m nụ mkpururu iwu (ọ bụ n'ezi nụ m zá m nụ mkpururu iwu), ma m rihịa m be n'iru.  
\v 21 Hne ele zá nụ mkpururu iwu, m zịri lele nye zá nụ mkpururu iwu (ọ bụ n'ezi nụ m léwhule m iwu Chiokike anya, m zị nụ mkpururu iwu Karaịsi), ma m rihịa m be n'iru.  
\v 22 N'esilawụru ele zá rikne n'ọkwnata ovu, m nụ m lele be, ma m rihịa m be n'iru. M bụ m kpakara nhne hne ele badnụ zị, m neeme kpa me nwernu rikne, ma m rihịa m agwna be n'iru.  
\v 23 M neeme kpakara nhne ka kwnornu izi ọma, ma m kehịa m igwe nụ ngọzi a. 
\p  
\v 24 N'ezi ọka, anụ magwụ nụ ele naagba ẹso naagba ẹso n'otu, kọvu otu badnụ kpọi naagbahịa nhne ẹso. Anụ gba ẹso, ma anụ gbahịa nhne n'ẹso. 
\p  
\v 25 Nye ọbula ke naagba ẹso jooknekwaru ẹhni a nkarị, ma be kpusi a okpu ọ gbahịaru n'ẹso ke jáazị ọkwnukokwnu, kọvu a naagba ẹso ma a nwehịa okpu-eze ke jaazị ọkwnukokwnu.  
\v 26 Ka kpahịaru m zá m naagba ẹso lele nye ọ zá nhne o vu nụ mkpọma, m zá m nọolo ịgbakwu lele nye nọolo ruwhere ịgbakwu.  
\v 27 M naata ẹhni m awhnụwhnu ma m nwernu m rikne nẹechi a, ọ zị me znikpa ele berere izi ọma, m bụru nye kwésile okpu-eze wam. 
\c 10  
\s1 Ọ dọ aka nụ nsnị gbasịri  //  ọkwa rẹnwu 
\p  
\v 1 Rụmu nda m, m pioru m anụ mahịa, nhne mernu ele nda aị ọknani ele snornu Mozizi kpa be zị nụ mkpururu erumeru, kpakara be gawheru Osimini Ihie.  
\v 2 Be wụru be mini nụ rime erumeru nụ osimini ke neegesi nụ be sno Mozizi.  
\v 3 Kpakara be riri otu wiri enine wam.  
\v 4 Kpakara be nwọrnu otu mini enine wam, kwnornu nụ be nwọrnu mini enine ke hiri nụ rugwu wam snornu be, rugwu wam bụ Karaịsi.  
\v 5 Kọvu nhne gbasịri agwna be sọ́ge Chiokike ovu n'ọnu, iznu be wụsaru n'ẹli-ịkpa wam. 
\p  
\v 6 Kpakara nhne ka bụnnu aị nhne atụ ke nọodo aị aka nụ nsnị. Nhne ọjo gwnụ́ko aị lele kpa ọ gwnụrnu be.  
\v 7 Anụ kwákọ rẹnwu lele kpa agwna be kwarụ, lele kpa ọkwukwo nsọ kwuru, “Ele wam dazịri ẹli ri nhne, nwọ nhne ọnwunwo, be lizọ tne eri.”  
\v 8 A mékọ ọyi, lele kpa agwna be mernu, nri pokwu lawụru nụ pokwu ẹto nwụ otu ọbochi.  
\v 9 A kpákọ Nyenwe aị iru, lele kpa agwna be mernu, agwọ tagbu be.  
\v 10 Anụ támu, lele kpa agwna be tamụrnu, enine izi ke ẹnwu gbu be. 
\p  
\v 11 Kpakara nhne ka mernu be nụ lele nhne atụ, be gba be n'ọkwukwo nsọ, ma be bụru nhne jeezni aị ezni, aị ele zị bụdnu n'okwukwo ọwa ka.  
\v 12 Nye ọbula ke neeche nụ o gwuzogwu kwem, ledu anya, ọ zị ọ dna.  
\v 13 Ọ zá ọrnurna ke vakwnusiri anụ ke vákwnusilele badnụ. Kọvu Chiokike kwesiri be kwnata a ovu, o jéekwe ọrnurna ke anụ nwée rikne gwuzoli vakwnusi anụ. Kọvu nga be naarna anụ ọrnurna, Chiokike jeenye anụ rikne o gwuzo, gbamanụ anụ apna anụ jeeji whụya nụ rime a. 
\p  
\v 14 Nhne atụ ele ka neegesi, ele me whnụrnu n'anya, ma anụ ghanahọru ọkwa rẹnwu.  
\v 15 M nookwunu anụ ọka lele ele nwernu akọniche, anụ tulekọm nhne me nookwu.  
\v 16 Okiko Iriri Nsọ wam ke a nọotunu Chiokike mmamma, ọ bụ́o ọvnarna Karaịsi nhne a neekeri nga a nọonwo nhne hi n'okiko wam? Brẹdi wam a naanyawa, a zá neekeri anọ-ẹhni Karaịsi nga a neeri brẹdi wam?  
\v 17 Kwnornu nụ otu brẹdi zịnu kpakara aị. Ọ bụ n'ezi nụ a zị agịda, kọvu a bụ otu anọ-ẹhni, a neeri otu brẹdi wam. 
\p  
\v 18 Anụ tule ele Izirẹli, ele neeri nhne be jiri kwa arịohna, neekerikọta nhne n'otu n'ojo arịohna Chiokike.  
\v 19 Ndaa nhne me nookwu? Ọ bụ nụ rẹnwu mọbu wiri be kwanụ rẹnwu arịohna bụ nhne ọbula?  
\v 20 Ọ́za! Nhne me naakaa bụ nụ nhne ele naakwanụ rẹnwu kwarụ arịohna bụ nhne be kwannụ ele rẹnwu ọjo. Ọ bụ́o Chiokike. M chị́oge m anụ nụ ele rẹnwu ọjo neekeri nhne n'otu.  
\v 21 Anụ jéenwe rikne nwọ okiko Nyenwe aị, nwọ kwno okiko ele rẹnwu ọjo. Anụ jéenwe rikne ri wiri n'ikpechi Nyenwe aị, ri kwno n'ikpechi rẹnwu ọjo.  
\v 22 Anụ noopio o mee Nyenwe aị kwno awụwa? A nwernu iknernema karụ a sa? 
\p  
\v 23 “A nwernu rikne mee kpakara nhne,” kọvu ọ bụ́o kpakara nhne bụru ọma. “A nwernu rikne mee kpakara nhne,” kọvu ọ bụ́o kpakara nhne nọowulizo badnụ olu lele ọro.  
\v 24 Ọ zá nye lebna anya nụ nhne ke a, kọvu nụ nhne ọma ke jeenyinu ele berere aka. 
\p  
\v 25 Anụ ri nhne ọbula be neere n'ahịa, anụ sị́kwa ajịji kwnornu mkpụru ovu anụ.  
\v 26 Ọkwukwo nsọ kwuru, “Chiokike nwe ọwa nụ kpakara nhne zị nụ rime a.” 
\p  
\v 27 Ọ bụru nụ nye kwé ekwe sukwuru anụ ma anụ ri wiri, ọ masị anụ o zne, anụ ri nhne ọbula ọ bịtaru nụ ruwhnu anụ, anụ sị́kwa ajịji ọbula kwnornu mkpụru ovu anụ.  
\v 28 Kọvu ọ bụru nụ otu badnụ kanụ anụ, “Be jiri wiri ka kwanụ rẹnwu arịohna,” anụ ríkọ wiri wam kwnornu nụ nye wam kannụ anụ kpam, ma kwnornu masị mkpụru ovu.  
\v 29 Ọ bụ́o kwnornu mkpụru ovu anụ, kọvu mkpụru ovu nye berere wam. Ndaa kpa rikne me nwernu o mee nhne jiri gbasị mkpụru ovu nye berere?  
\v 30 Ọ bụru nụ me ri wiri tụnu Chiokike mmamma, kịni mernu nye berere jaama m ikpe nụ wiri me tụru mmamma? 
\p  
\v 31 Kọvu, nhne ọbula anụ neeme, anụ neeri wiri mọbu anụ nọonwo mini, anụ mee kpakara nhne kwnornu igwugwu Chiokike.  
\v 32 Anụ mékọ nye ọbula dna, mọbu nye Ju mọbu nye bụ́o nye Ju, mọbu ọgbako Chiokike,  
\v 33 lele kpa me naagbalị o mee kpakara nhne jaamasị kpakara badnụ. M zá m neeche nhne gbasịri nhne ọma ke m, kọvu nhne ọma agịda badnụ ma be znọhia be. 
\c 11  
\p  
\v 1 Anụ snornu m lele kpa me noosno Karaịsi. 
\s1 Okpukpe nụ ọgbako  //  Chiokike 
\p  
\v 2 M naaja anụ mma kwnornu nụ anụ neechenwanya m, naabịta kpakara nhne me znirni anụ.  
\v 3 Kịtna, m pioru m anụ ghọhia nụ Karaịsi bụ risi nyerukna ọbula, nzi bụ risi nnwerne, Chiokike bụ risi Karaịsi.  
\v 4 Nyerukna ọbula ke neekpe okpukpe mọbu nọokpo okwo izi ọma Chiokike kpusnime risi a, bụ nhne iwhnerne nyee Karaịsi.  
\v 5 Nyerinya ọbula ke neekpe okpukpe mọbu nọokpo okwo izi ọma Chiokike, gbesa risi a anya, neeme risi a nhne iwhnerne, ọ nụ lele ọ kọpuru rukeri-ize risi a.  
\v 6 Ọ bụru nụ nyerinya kpúsnige risi a, ọ kọma rukeri-ize a. Kọvu ọ bụ nhne iwhnerne nụ nyerinya jọoko rukeri-ize a, o kpusi risi a.  
\v 7 Nyerukna kpúsni risi a kwnornu nụ ọ bụ oyiyi ke neegesi igwugwu Chiokike. Kọvu nyerinya neegesi igwugwu ke nyerukna.  
\v 8 Kwnornu nụ Chiokike híge nụ nyerinya kpụ nyerukna, kọvu hiri nụ nyerukna kpụ nyerinya.  
\v 9 Ọ kpụ́ge nyerukna kwnornu nyerinya, kọvu ọ kpụru nyerinya kwnornu nyerukna.  
\v 10 Kam kpayarụ, kwnornu ele enine izi, nyerinya kwesiri o kpusni risi a, ke neegesi ọ zị nụ mkpururu nzi a. 
\p  
\v 11 Lele kpa bụdnu nụ rime Nyenwe aị zị, nyerinya zị nyerukna mkpa, nyerukna zị masị nyerinya mkpa.  
\v 12 Kwnornu kpa be kpụru nyerinya hite nụ nyerukna, kpam masị, nyerinya mụrnu nyerukna. Kpakara nhne hi n'aka Chiokike va.  
\v 13 Anụ kpekọm ma ọ bụru ọma nụ nyerinya jeekpe okpukpe gbesa risi a anya.  
\v 14 Iwu okike kwuru nụ nyerukna ke nwernu ogologo rukeri-ize bụnu a nhne iwhnerne.  
\v 15 Kọvu ọ bụru nụ nyerinya ke nwernu ogologo rukeri-ize, ọ bụ igwugwu a, kwnornu nụ rukeri-ize a bụ nhne Chiokike nyernu, o jeeji nookpusni risi a.  
\v 16 Kọvu ọ bụru nụ nye ọbula kwége kpam, nhne me jaakaa bụ, aị mọbu ọgbako Chiokike nwée omen'ẹli berere karụ kpam. 
\s1 Wiri Anyasnu Nyenwe aị 
\s1 (Mat 26:26-29; Mak 14:22-25; Luk 22:14-20) 
\p  
\v 17 Gbasịri nhne ke a nookwu kịtna, m jáaja anụ mma. Nhne anụ neeme nụ rime ọgbako anụ bụ nhne ọjo, ọ bụ́o ọma rịa rịa.  
\v 18 Ke mbọm, be kannụ m nụ agịda okewa zị n'esilawụru anụ, m neekweru agwna a.  
\v 19 O dnornu m anya nụ okewa jaazịri n'esilawụru anụ ma nye zị snam whụya iwhne.  
\v 20 Nga anụ vakọtaru n'otu, anụ váge o ri Wiri Anyasnu Nyenwe aị.  
\v 21 Kpa anụ neeri, nye ọbula neeri, ọ zá nye neese ibne a. Kam kpayarụ wiri nọogwnu agwna badnụ nga manya noogbu ele berere.  
\v 22 Anụ nwée ọro, hne anụ jeeri wiri, nwọ manya? Anụ neeledna ọgbako Chiokike anya, kpasị ele nwée nhne iwhnerne? Ndaa nhne anụ pioru me kwu gbasịri nhne ka? Me ja anụ mma sa? Ọ́za! M jáaja anụ mma rịa rịa. 
\p  
\v 23 M nahịaru m nhne me znirni anụ n'aka Nyenwe aị Jizọsi. N'abalị wam be reru a, Nyenwe aị Jizọsi gweruru brẹdi,  
\v 24 tụnu Chiokike mmamma, nyawa a, kaa, “Ka bụ anọ-ẹhni m ke zịnu anụ, anụ neeme ka neechenwanya m.”  
\v 25 Kpam masị, nga wiri anyasnu whemernu, o gweru okiko, kaa, “Ka bụ okiko ọgba-njọ-ẹhni ikne ke ọvnarna m. Nga ọbula anụ nọonwo a, anụ neeme ka neechenwanya m.”  
\v 26 Kpa anụ neeri brẹdi ka, nọonwo okiko ka, anụ nookwusa ẹnwu Nyenwe aị tem ọ va. 
\p  
\v 27 Ka neegesi nụ ọ bụru nụ nye ọbula ri brẹdi Nyenwe aị mọbu nwọ nhne hi n'okiko, kpa o kwésige, ikpe anọ-ẹhni Nyenwe aị nụ ọvnarna a naama a.  
\v 28 Nye ọbula beru ọsno nyosnama ẹhni a sụ o ri brẹdi wam mọbu nwọ nhne hi n'okiko wam.  
\v 29 Kwnornu nụ nye ọbula ke jeeri mọbu nwọ nhne hi n'okiko wam hne ọ máa anọ-ẹhni Nyenwe aị, neeri, nọonwo ikpe nụ risi a.  
\v 30 Kam kpayarụ, agịda anụ zị nụ nrịria, agịda anụ zá rikne, ele berere nwụnam.  
\v 31 Ọ bụru a beru ọsno nyosnama ẹhni aị, Chiokike jéekpe aị ikpe.  
\v 32 Kọvu Nyenwe aị neekpe aị ikpe, naata aị awhnụwhnu, ma a gharụ o sno ele zị n'ọwa bụru ele ikpe marnụ. 
\p  
\v 33 Rụmu nda m, nga anụ gbakọru n'otu neeri wiri Nyenwe aị, anụ sete ibne anụ.  
\v 34 Ọ bụru nụ wiri nọogwnu nye ọbula, o ri wiri n'ọro a, ọ zị ikpe Chiokike ma anụ kpa anụ gbakọru n'otu. 
\p M jeemekwata nhne ke berere nga me varụ. 
\c 12  
\s1 Nkesi ke Enine Nsọ 
\p  
\v 1 Rụmu nda m, nhne gbasịri nkesi zị ọdo n'ọdo ke Enine Nsọ, m pioru m anụ mahịa nhne gbasịri be.  
\v 2 Anụ magwụ nụ nga anụ bụ ele naakwa rẹnwu ke dnarnụ mgbu, be duru anụ hie apna.  
\v 3 M neeme ma anụ mahịa nụ ọ zá nye Enine Nsọ Chiokike noodu jeenwe rikne kaa, “Kọsna Jizọsi.” Ọ zá nye jeenwe rikne kaa nụ, “Jizọsi bụ Nyenwe aị,” okwokọlam ma Enine Nsọ hiri n'ọnu a kwu kpam. 
\p  
\v 4 Agịda nkesi enine zị ọdo n'ọdo, kọvu otu Enine Nsọ.  
\v 5 Agịda apna be jeezne izi, kọvu otu Nyenwe aị.  
\v 6 Agịda ẹrnu zị ọdo n'ọdo, kọvu otu Chiokike wam neenye rikne be jeeji nọornu ẹrnu. 
\p  
\v 7 Enine Nsọ nyernu badnụ ọbula nkesi ma ọ bụru mbnarna kpakara badnụ.  
\v 8 O nyernu otu badnụ izi akọniche, nyee nye berere izi ọghohia nhne hite n'otu Enine wam.  
\v 9 Otu Enine wam nyee nye berere ọkwnata ovu, o nyee nye berere rikne ọ gwọ nrịria.  
\v 10 Enine wam masị nyee otu badnụ rikne ọ rnụ ẹrnu ndu-ẹhni, nyee nye berere rikne ọ kpọ okwo izi ọma, nyee nye berere rikne ọ mahịa nhne zị ichne nụ hne enine zị ichne ichne, nyee nye berere rikne o kwu ọka nụ riro zị ichne ichne, nyee nye berere rikne ọ tụhnasna ikwu-ọnu.  
\v 11 Kọvu ọ bụ otu Enine wam nọornu kpakara nhne, o neenye badnụ ọbula nkesi zị ọdo n'ọdo lele kpa o jiri masị a. 
\p  
\v 12 Ẹhni badnụ bụ otu. Kọvu o nwernu agịda nhne zị ọdo n'ọdo ke knekọtaru a n'otu. Ọ bụ masị kpa ọ zị n'anọ-ẹhni Karaịsi.  
\v 13 Kwnornu nụ be jiri otu Enine wụ aị mini bna n'otu anọ-ẹhni. A bụ ele Ju, ma a bụ ele bụ́o ele Ju, ọhi mọbu nye bụ́o ọhi, be mernu a nwọ otu Enine wam. 
\p  
\v 14 Ọ bụ́o otu nhne zị n'ẹhni badnụ, be zị agịda.  
\v 15 Ọ bụru nụ ọchi jaakaa, “Kwnornu nụ m bụ́la m aka, m bụ́la m nhne zị n'ẹhni,” kị jéeme a ọ gharụ ọ bụru nhne zị n'ẹhni badnụ.  
\v 16 Ọ bụru nụ nsnị kaa, “Kwnornu nụ m bụ́la m anya, m bụ́la m nhne zị n'ẹhni,” kị jéeme a ọ gharụ ọ bụru nhne zị n'ẹhni badnụ.  
\v 17 Ọ bụru nụ kpakara ẹhni bụ anya anya, ndaa kpa ọ jọonu nhne? Ọ bụru nụ kpakara ẹhni bụ nsnị nsnị, ndaa kpa ọ jọonu ẹknarna nhne?  
\v 18 Kọvu Chiokike yisiri kpakara nhne zị n'ẹhni badnụ lele kpa o jiri masị a.  
\v 19 Ọ bụru nụ kpakara be bụ otu nhne, ndaa hne ẹhni jaazị?  
\v 20 Kịtna, agịda nhne zị n'otu ẹhni badnụ. 
\p  
\v 21 Kam kpayarụ, anya jáakanụ aka, “Ị zá m mkpa.” Mọbu risi kanụ ọchi, “Ị zá m mkpa.”  
\v 22 N'ezi, a jéenwe rikne gwuzoli ọ bụru nụ nhne ke zị n'ẹhni ke a neeche nụ be zá rikne zị́la.  
\v 23 Nhne ke zị n'ẹhni aị ke a neeche nụ be nwée igwugwu, bụ ke a neeledu anya gbasịri be, ele ke tụ iwhnerne bụ ele ke a ji iwo nookpusni.  
\v 24 Ngeri ẹhni aị ke marnụ mma a zá neeledu a anya. Chiokike n'iwhuru a yisiri ẹhni aị n'otu, o nyernu nhne zị n'ẹhni ke nwée igwugwu, igwugwu ke kakwo.  
\v 25 Okewa kwésile ọ zị n'ẹhni, kọvu kpakara nhne zị ọdo n'ọdo n'ẹhni magwụ nhne gbasịri ibne be.  
\v 26 Ọ bụru n'otu nhne zị n'ẹhni nọowhnu awhnụwhnu, kpakara ele ke berere sno a whnụ awhnụwhnu. Ọ bụru be znarnị otu, kpakara be sno a nwe ovu ọso n'ọnu. 
\p  
\v 27 Kpakara anụ bụ ẹhni Karaịsi, anụ n'otu n'otu bụ nhne zị n'ẹhni Karaịsi.  
\v 28 Chiokike bịtaru kpakara nhne kpa o kwesiri n'ọgbako a. Ọ bịtaru ke mbọm, ele izi, ke ẹbo, ele nọokpo okwo, ke ẹto, ele zni nhne, ele nọornu ẹrnu ndu-ẹhni sno be, nụ ele nwernu nkesi ọgwo nrịria, mọbu ele neeyinu ele berere aka, ele nẹechi ẹchi, nụ ele nookwu ọka nụ riro zị ọdo n'ọdo.  
\v 29 Kpakara be bụ́o ele izi, kpakara be bụ́o ele nọokpo okwo, mọbu ele neezni nhne. Ọ bụ́o kpakara be nwernu rikne rnụ ẹrnu ndu-ẹhni,  
\v 30 mọbu gwọ nrịria zị ọdo n'ọdo, mọbu kwu ọka nụ riro zị ọdo n'ọdo, mọbu ọ tụhnasna ikwu-ọnu.  
\v 31 Kọvu nkesi ke kakwo mma gwnụ anụ lele wiri. 
\p Kọvu me gesi anụ apna ke kakwo mma. 
\c 13  
\s1 Ọwhnun'anya 
\p  
\v 1 Ọ bụru m nwernu m rikne kwu ọka nụ riro ele badnụ nụ ke enine izi, kọvu m nwée m ọwhnun'anya, ọka m jọoburu ọgbugbo etekne mọbu igele warụ-awa.  
\v 2 Ọ bụru m nwernu m nkesi ke ọkpo okwo izi ọma, nụ ọghohia kpakara nhne zị omimi, nụ kpakara nhne ọmuma, ọ bụru nụ m nwernu m kpakara ọkwnata ovu ke joovume rugwu, kọvu m nwée m ọwhnun'anya, ọ zá nhne me bụ.  
\v 3 Ọ bụru me nyee ele mboni kpakara nhne me nwernu, mọbu nyee ẹhni m be gba bẹkwnu, kọvu m nwée m ọwhnun'anya, ọ zá ọgwo ẹrnu me jeekehịa. 
\p  
\v 4 Ọwhnun'anya nwernu ọsnuta ovu, nụ ovu ọma. Ọwhnun'anya kwnó awụwa, o mée oknomokno, ọ kpá nganga.  
\v 5 Ọwhnun'anya mée nhne bụ́o ọma n'anya. O pío nhne ke aka ke a, o nwée ovu owe ẹhni. Ọwhnun'anya zá nọogwnu nhne ọjo be mernu a.  
\v 6 Ọwhnun'anya zá nọonwudna nụ nhne ọjo, kọvu ezi ọka neeme ovu ọso a n'ọnu.  
\v 7 Inwe zá nọogwu ọwhnun'anya. O neekweru kpakara nhne, o nwernu olile anya nụ kpakara nhne, o needi kpakara nhne. 
\p  
\v 8 Ọwhnun'anya zị ọkwnukokwnu. Ọkpo okwo jeebi, riro zị ọdo n'ọdo jọokwusi. Ọ bụru ọghohia, be jaagawhe.  
\v 9 Ọghohia aị nụ ọkpo okwo aị zú ozu.  
\v 10 Nga nhne ke zuru ozu varụ, nhne ke zúge ozu jaagawhe.  
\v 11 Nga me bụ watakịri, m nookwu ọka lele watakịri, m naarị ọriri lele watakịri, m ghọhiaru m nhne lele watakịri, kọvu nga me sozuru nụ badnụ, m gweme kpakara agwa watakịri n'ẹhni m.  
\v 12 Kwnornu nụ kịtna, a nọowhnu nhne nụ nyno ke nọotu ewheke, kọvu nga wam a jọowhnu ruwhnu nụ ruwhnu. Kịtna, m maam agwna nhne, nga wam m jaamakwo kpakara nhne lele kpa Chiokike magwụ m. 
\p  
\v 13 Kịtna, nhne ẹto ka zị, ọkwnata ovu, olile anya, nụ ọwhnun'anya. Kọvu ọwhnun'anya kakwo kpakara be. 
\c 14  
\s1 Ọkpo okwo nụ riro ikne 
\p  
\v 1 Anụ snornu apna ọwhnun'anya, nkesi ke Enine nọogwnu anụ lele wiri, ke kakwo ibne a, nkesi ke ọkpo okwo izi ọma.  
\v 2 Nye nookwu ọka nụ riro zị ichne ichne zá nookwunu badnụ, kọvu Chiokike. Kwnornu nụ ọ zá nye nọoghohia nhne o nookwu, nhne o nookwu bụ nhne tugwaru otugwa hite nụ rikne Enine.  
\v 3 Kọvu nye nọokpo okwo izi ọma nookwunu ele badnụ ọka, noowulizọ ele badnụ olu lele ọro, neezni nhne, naakasi mkpọma.  
\v 4 Badnụ ke nookwu ọka nụ riro zị ichne ichne noowulizọ ẹhni a olu lele ọro, kọvu nye nọokpo okwo izi ọma noowulizọ ọgbako Chiokike olu lele ọro. 
\p  
\v 5 Ọ jaamasị m ọ bụru nụ kpakara anụ jookwu ọka nụ riro zị ichne ichne. Kọvu ọ ka mma, ọ bụru nụ kpakara anụ kpọ okwo izi ọma Chiokike. Kwnornu nụ nye nọokpo okwo izi ọma Chiokike zị okne ọnu ahịa kakwo nye nookwu ọka nụ riro ichne ichne, okwolem ma ọ zị nye jọotuhnasnanu ọgbako Chiokike nhne o nookwu, ma be wulizọ ọgbako Chiokike olu lele ọro.  
\v 6 Ọ bụru me vakwnusi anụ nookwu ọka nụ riro ichne ichne, mbnarna kịni nhne anụ jeenwe n'aka m, okwolem ma m nookwu nhne Chiokike kpumennu m mọbu nhne ọmuma mọbu ọkpo okwo izi ọma mọbu zni nhne? 
\p  
\v 7 Nhne ke nwée bụdnu lele opi mọbu ọbo, ọ zá nye jaamahịa nhne ọ nọogwnu n'eri ọ bụru nụ be gbụ́gele a kpa ọ bụru ọma.  
\v 8 Ọ bụru nụ nye nọogbu ọkwodu gbụ́gele a nkarị, ọ zá nye jeejiknernu o zne ọgwnu.  
\v 9 Kpam masị, ọ bụru nụ i kwúkwala ọka nkarị, ọ zá nye jọoghohia nhne i nookwu, ọ bụru nụ i kwu ọka nụ riro zị ichne ichne. Ruwhere joovu ọka ị.  
\v 10 Ọ bụ n'ezi n'agịda ikwu-ọnu zị n'ọwa. Ọ zá ke nwée nhne ọ naakasi.  
\v 11 Ọ bụru nụ m ghọ́hiage m nhne badnụ nookwu, m bụnu m nye wam nye ẹli berere, nye wam masị bụnu m nye ẹli berere.  
\v 12 Ọ bụ masị kpa ọ zịnu anụ. Hne nkesi ke Enine nọogwnu anụ, anụ gbalị nwehịa masị nkesi ke jeewulizọ ọgbako Chiokike olu lele ọro. 
\p  
\v 13 Nye nookwu ọka nụ riro zị ichne ichne, kpe okpukpe ma ọ tụhnasna ikwu-ọnu a.  
\v 14 Ọ bụru me kpe okpukpe kpa nụ riro zị ichne ichne, enine m neekpe, kọvu echiche m nwée igwe nụ rime a.  
\v 15 Ndaa nhne me jeeme? M jeeji enine m nụ echiche m kpe okpukpe, m jeeji masị enine m nụ echiche m gwnụ eri.  
\v 16 Kpa ị naaznarnị Chiokike nụ rime enine, nye izne ke zị nụ rime ọgbako jéenwe rikne kwe Amịm, kwnornu nụ o máa nhne i nookwu.  
\v 17 Ị nọotunu Chiokike mmamma nkarị nkarị, kọvu nhne i neeme zá noowulizọ nye wam olu lele ọro. 
\p  
\v 18 M nọotunu Chiokike mmamma kwnornu nụ m nookwu ọka nụ riro zị ichne ichne kakwo kpakara anụ.  
\v 19 Kọvu nụ rime ọgbako Chiokike, ọ bụru ọma me kwu mkpụru ọka isne ke ele badnụ jọoghohia, zni be nhne, karụ o kwu nri pokwu ọka ọ zá nye jọoghohia. 
\p  
\v 20 Rụmu nda m, anụ ghọ́ rụmu takịri nụ n'ọriri anụ, kọvu anụ bụru rụmu takịri nụ hne mmehie zị, anụ bụru dimkpa nụ ọghohia anụ.  
\v 21 Be gbarụ a n'ọkwukwo nsọ, kaa, 
\q1 “M jeeji ikwu-ọnu ele ẹli berere, 
\q2 kwunu ele ka ọka, 
\q1 m jeeji masị mgbele-ọnu ele ẹli berere 
\q2 kwunu ele ka ọka, 
\q1 kọvu be kwéle o bnonu m nsnị.” 
\m Ka bụ nhne Nyenwe aị kwuru. 
\p  
\v 22 Riro zị ichne ichne bụ nhne elekema ele kwé ekwe, ọ bụ́o ke ele kweru ekwe. Ọkpo okwo izi ọma Chiokike bụ ke ele kweru ekwe, ọ bụ́o ke ele kwé ekwe.  
\v 23 Ọ bụru nụ kpakara ọgbako Chiokike gbakọ n'otu, kpakara anụ nookwu ọka nụ riro zị ichne ichne, ọ bụru ele izne mọbu ele kwé ekwe va n'esilawụru anụ, be jáakaa nụ kpakara anụ bụ ele ẹra?  
\v 24 Kọvu ọ bụru kpakara anụ nọokpo okwo izi ọma Chiokike, nye kwé ekwe mọbu nye izne va n'esilawụru anụ, be jọotu a mmehie a n'anya, kpakara nhne ọ nụrnu jaama a ikpe.  
\v 25 Nhne tugwaru otugwa ke zị n'ovu a jọowhnuya iwhne. Ọ jaadna kpọ risi ẹli nyee Chiokike, kwuhịa, “N'ezi ọka nụ Chiokike zị n'esilawụru anụ.” 
\s1 Okpenu Chiokike  //  n'ahịri n'ahịri 
\p  
\v 26 Rụmu nda m, nhne me nookwu bụ ka, nga anụ gbakọru n'otu, anụ ji ọgwnu eri, anụ ji iznizni, nye berere jigwu nhne be kpumennu a, nye berere ji riro zị ichne ichne, nye berere nọotuhnasna nhne be nookwu. Kpakara nhne bụ ma be wụlizo ọgbako Chiokike olu lele ọro.  
\v 27 Ọ bụru nye ọbula kwu ọka nụ riro zị ichne ichne, be jaazị badnụ lawụru, mọbu ke kakwo ẹto. Otu kwukwo, ibne a kwu, otu badnụ tụhnasna nhne be nookwu.  
\v 28 Ọ bụru nụ ọ zá nye jọotuhnasna nhne be nookwu, nye wam nookwu nụ riro zị ichne ichne dazịri bii, nye wam kwunu ẹhni a ọka, kwu masịnu Chiokike ọka.  
\v 29 Badnụ lawụru mọbu ẹto kpọ okwo izi ọma Chiokike, ele berere tule nhne be neezni.  
\v 30 Kọvu ọ bụru nụ otu dazịgwu ẹli nụ rime ọgbako nwehịaru izi n'aka Chiokike, nye nookwu ọka dazịri bii.  
\v 31 Kpakara anụ jeenwe rikne kpọ okwo izi ọma Chiokike otu n'otu, ma kpakara anụ mụhia nhne, kpakara anụ nwehịa nkasi ovu.  
\v 32 Enine nye nọokpo okwo noobnonu nye nọokpo okwo nsnị.  
\v 33 Kwnornu nụ Chiokike bụ́o nye ẹyiriya, kọvu nye udno. 
\p Lele kpa ọ zị nụ kpakara ọgbako Chiokike,  
\v 34 ele rinya dazịri bii nụ rime ọgbako Chiokike. Be kwú ọka, be bụ́o ele risi lele kpa Iwu kwuru.  
\v 35 Ọ bụru nụ be pioru ọ mahịa nhne ọbula, be sịkwa nzi be n'ọro. Ọ bụ nhne iwhnerne nụ nyerinya jookwu ọka nụ rime ọgbako Chiokike. 
\p  
\v 36 Kịni masị? Ikwu-ọnu Chiokike ọpanizoru nhne anụ zị sa? Mọbu ọ bụ anụ kpọi bụ ele ọ vakwnusiri?  
\v 37 Ọ bụru nụ nye ọbula neeche nụ ọ bụ nye nọokpo okwo izi ọma, mọbu nye nwernu nkesi enine, nye wam marnụ nụ nhne me naagbanụ anụ n'okwukwo bụ nhne Nyenwe aị nyernu n'iwu.  
\v 38 Nye bnóge nsnị nụ nhne ka, anụ bnónu a nsnị. 
\p  
\v 39 Rụmu nda m, kam kpayarụ, ọkpo okwo izi ọma Chiokike nọogwnu anụ lele wiri, anụ bnósni ele nookwu ọka nụ riro ichne ichne.  
\v 40 Anụ gweru ovu dụru ẹli mee kpakara nhne kwesiri n'apna bụru ọma, ma n'ahịri n'ahịri. 
\c 15  
\s1 Olizọ n'ẹnwu Karaịsi 
\p  
\v 1 Kịtna, rụmu nda m, m neechenwanyanụ anụ izi ọma wam me znirni anụ, ke anụ nahịaru, bụ ke anụ gwuzogwu n'olu a.  
\v 2 Chiokike znọhiaru anụ hite n'izi ọma ka, ọ bụru nụ anụ bịta nhne me znirni anụ, okwolem ma anụ kweru n'etekne. 
\p  
\v 3 M nyernu m anụ nhne me nahịaru, ke zị okne mkpa, nụ Karaịsi nwụrnu kwnornu mmehie aị, lele kpa be gbarụ a n'ọkwukwo nsọ.  
\v 4 Be liri a, Chiokike mernu o hi n'ẹnwu lizọ n'ọbochi ke ẹto, lele kpa be gbarụ a n'ọkwukwo nsọ.  
\v 5 O mernu Pita whnụ a anya, omekwo, ele izi nri nụ ẹbo wam whnụ a anya.  
\v 6 Omekwo, o mernu nhne nụ lele ele kakwo riwhu badnụ isne whnụ a anya otu mgba, ele bụ rụmu nda aị. Agwna be zị bụdnu dụ tna, kọvu agwna be dnarnụ n'anyarna ẹnwu.  
\v 7 Omekwo, Jemisi whnụ a anya, nụ kpakara ele izi. 
\p  
\v 8 N'ipne-aznụ, o mernu m m whnụ a anya, me nye be mụrnu lele nnwọ ká aka.  
\v 9 M bụ m nye zịkakworu matị n'esilawụru ele izi, m kwésile m be sukwu m nye izi, kwnornu nụ m mekparụ m ọgbako Chiokike ẹhni.  
\v 10 Kọvu hite n'oru Chiokike, m bụ m nhne me bụ. Oru o nyernu m bụ́o n'etekne. Kọvu m dọligburu m ẹhni m n'ẹrnu kakwo kpakara ele izi, ọ bụ n'ezi nụ ọ bụ́o me nọornu, kọvu oru Chiokike nọornu ẹrnu nụ rime m.  
\v 11 Kam kpayarụ, ọ bụ me, mọbu be, a znirni izi ọma, kam bụ nhne anụ kweru. 
\s1 Olizọ n'ẹnwu ele  //  nwụrnu ẹnwu 
\p  
\v 12 Ọ bụru nụ izi ọma aị bụ nụ Karaịsi hiri n'ẹnwu lizọ, ndaa kpa agwna anụ naakaa nụ ele nwụrnu ọnwu zá neelizọ n'ẹnwu?  
\v 13 Ọ bụru nụ ele nwụrnu ọnwu zá neelizọ n'ẹnwu, o neegesi nụ Karaịsi híge n'ẹnwu lizọ.  
\v 14 Ọ bụru nụ Karaịsi híge n'ẹnwu lizọ, izi ọma a znirni anụ bụ nhne etekne, ọkwnata ovu anụ bụ masị nhne etekne.  
\v 15 Tụkwasi n'olu a, a bụ ele akebne aghalaghala megidne Chiokike, a naagba akebne megidne Chiokike nụ o mernu Karaịsi hi n'ẹnwu lizọ, nye o méne o hi n'ẹnwu lizọ, ọ bụru nụ ele nwụrnu ọnwu jéelizọ n'ẹnwu.  
\v 16 Kwnornu nụ ọ bụru nụ ele nwụrnu ọnwu jéelizọ n'ẹnwu, Karaịsi híge n'ẹnwu lizọ.  
\v 17 Ọ bụru nụ Karaịsi híge n'ẹnwu lizọ, ọkwnata ovu anụ bụ nhne etekne, anụ zị kọriri nụ mmehie anụ.  
\v 18 Kam neegesi nụ ele dnarnụ n'anyarna ẹnwu bụ ele kweru nụ Karaịsi whuru etekne.  
\v 19 Ọ bụru nụ okwokọlam nụ bụdnu ka a zị bụ hne a nwernu ọkwnata ovu nụ Karaịsi, a bụ ele be kwesiri ọ dọnu obirizi kakwo kpakara ele wu n'ọwa. 
\p  
\v 20 N'ezi ọka, Chiokike mernu Karaịsi hi n'ẹnwu lizọ, bụ mkpụru mbọm ke ele nwụrnu ọnwu.  
\v 21 Kpa ẹnwu hiri n'aka badnụ va, kpam masị, olizọ n'ẹnwu hiri n'aka badnụ va.  
\v 22 Kwnornu nụ kpakara badnụ nwụrnu ẹnwu nụ rime Adam, kpam masị, Chiokike jeeme kpakara badnụ zịri bụdnu nụ rime Karaịsi.  
\v 23 Kọvu nye ọbula n'ige ke a, Karaịsi bụ mkpụru mbọm, omekwo, kpakara ele kweru nụ Karaịsi nga ọ jaava.  
\v 24 Omekwo, okwukwo kpakara nhne jaava, nga Karaịsi lụgburu kpakara rikne, nụ ele nẹechi ẹchi, nụ kpakara iknernema, o jeenyewhete Chiokike Nda ẹli-eze a.  
\v 25 Kwnornu o jaachị tem ọ bịta kpakara ele irno nụ mkpururu ọchi a.  
\v 26 Nye irno ipne-aznụ o joolulu bụ ẹnwu.  
\v 27 Kwnornu nụ ọkwukwo nsọ kwuru, “Chiokike bịtaru kpakara nhne nụ mkpururu ọchi a.” A magwụ nụ Chiokike zá n'esilawụru kpakara nhne ka, nye bịtaru kpakara nhne nụ mkpururu Karaịsi.  
\v 28 Nga kpakara nhne dazịri nụ mkpururu Karaịsi, Karaịsi jaadazị nụ mkpururu nye wam bịtaru kpakara nhne nụ mkpururu a, ma Chiokike bụru nye nẹechi kpakara nhne. 
\p  
\v 29 Ọ bụru nụ ele nwụrnu ọnwu zá neelizọ n'ẹnwu, mbnarna kịni bụ nhne ele be nọowu mini kwnornu ele nwụrnu ọnwu jeenwe? Kịni kpayarụ be nọowu be mini kwnornu ele nwụrnu ọnwu?  
\v 30 Ndaa nhne mernu a neeze bụdnu ige ọbula?  
\v 31 M zị m n'ọnu ẹnwu kpakara ọbochi. Rụmu nda m, m nookwu ka kwnornu nụ m jị m anụ naanya risi, anụ zị nụ rime Karaịsi Jizọsi Nyenwe aị.  
\v 32 Ọ bụru lele badnụ etekne me nụ anọhia ọjo lụru ọgwnu nụ Efesọsi, ndaa nhne me jeenwehịa? Ọ bụru nụ ele nwụrnu ọnwu zá neelizọ n'ẹnwu, 
\q1 “Ngwa ma a ri, nwọ tna, 
\q2 kwnornu ekile a jọonwu.” 
\m  
\v 33 Anụ kwé be duwhu anụ. “Ele enyi ọjo noolulu agwa ọma.”  
\v 34 Anya dno anụ nụ risi, anụ mée mmehie. Agwna anụ máa Chiokike. M nookwu ka ma iwhnerne tụ anụ. 
\s1 Anọ-ẹhni a jeenwe 
\p  
\v 35 Kọvu agwna anụ jaakaa, “Ndaa kpa ele nwụrnu ọnwu jeelizọ? Ndaa anọ-ẹhni be jeenwe?”  
\v 36 Jị nye iwhnirniwhno. Nga ị kpasịri mkpụru n'ẹli, o jóofu okwolem ma ọ beru ọsno nwụ.  
\v 37 Nhne ị kpasịri n'ẹli bụ mkpụru etekne, mkpụru ịkpa, mọbu mkpụru berere, ọ bụ́o isisi.  
\v 38 Chiokike jeenye mkpụru wam ẹhni ke masịri a. O neenye mkpụru ọbula ẹhni ke a.  
\v 39 Kpakara anọ-ẹhni bụ́o otu, badnụ nwernu anọ-ẹhni, anọhia nwernu anọ-ẹhni ke berere, ọnunu nwernu anọ-ẹhni ke berere, aznụ anọ-ẹhni berere.  
\v 40 Anọ-ẹhni ke oligwe zị, anọ-ẹhni ke ọwa zị masị, ọma mma ke oligwe zị, ọma mma ke ọwa zị masị.  
\v 41 Mma ke ẹhnam zị ichne, ẹnwa nwernu ọma mma ke a, mma ke mbọ zị ichne, mma ke mbọ zị ọdo n'ọdo. 
\p  
\v 42 Kpam masị bụ kpa olizọ n'ẹnwu zị, anọ-ẹhni ke be kpasịri n'ẹnwu nwernu rikne ro oro, nga Chiokike gwelizọru a, o jóoro oro.  
\v 43 Be kpasịri a n'iwhnerne, Chiokike gwelizọ a n'igwugwu, be kpasịri a n'inwe ọgwugwu, Chiokike gwelizọ a n'iknernema.  
\v 44 Be kpasịri a anọ-ẹhni etekne, Chiokike gwelizọ a n'anọ-ẹhni ke enine. Anọ-ẹhni ke etekne zị, anọ-ẹhni ke enine zị masị.  
\v 45 Kwnornu be gbarụ n'ọkwukwo nsọ, “Adam badnụ mbọm bụ badnụ ke zị bụdnu.” Kọvu Adam ke ipne-aznụ bụ Enine ke neenye bụdnu.  
\v 46 Anọ-ẹhni ke enine bége ọsno, kọvu anọ-ẹhni etekne, omekwo, ke enine sno a.  
\v 47 Adam ke mbọm bụ rịzna ke ọwa, Adam ke ẹbo hi n'oligwe va.  
\v 48 Lele badnụ be jiri rịzna kpụ, bụ kpa ele ke rịzna bụ, ele ke oligwe nụ lele nye wam hi n'oligwe va.  
\v 49 Lele kpa a vuru oyiyi ke badnụ ke rịzna, kpam masị bụ kpa a joovuru ke oligwe lele badnụ wam hi n'oligwe va. 
\p  
\v 50 Rụmu nda m, ka bụ nhne me nookwu, kwnornu anọ-ẹhni nụ ọvnarna jéekehịa ẹli-eze Chiokike. Nhne jọonwu ọnwu jéekehịa nhne jọ́onwu ọnwu.  
\v 51 Le, me kanụ anụ nhne miri emi, ọ bụ́o kpakara aị jọonwu ẹnwu, kọvu be jaagbanwo kpakara aị,  
\v 52 n'ige matị, n'otu nsnabi anya, nga ọkwodu ipne-aznụ dnarnụ. Kwnornu nụ be jọogbu ọkwodu, ele nwụrnu ọnwu jeelizọ róge oro, be jaagbanwo aị.  
\v 53 Kwnornu nụ anọ-ẹhni ke jooro oro jooworu anọ-ẹhni ke jóoro oro, anọ-ẹhni ke jọonwu ẹnwu jooworu anọ-ẹhni ke jọ́onwu ẹnwu.  
\v 54 Nga anọ-ẹhni ke jooro oro wokparu anọ-ẹhni ke jóoro oro, anọ-ẹhni ke jọonwu ọnwu woru anọ-ẹhni ke jọ́onwu ọnwu, nhne be gbarụ n'ọkwukwo nsọ jeemezu, “Be megburu ẹnwu.” 
\q1  
\v 55 “Ẹnwu, ndaa hne mmeri ị zị? 
\q2 Ẹnwu, ndaa hne nhne ọgbugba ị zị?” 
\p  
\v 56 Nhne ọgbugba ẹnwu bụ mmehie, iknernema mmehie bụ iwu.  
\v 57 Kọvu a nọotunu Chiokike mmamma nye neenye aị mmeri hite nụ Nyenwe aị Jizọsi Karaịsi. 
\p  
\v 58 Rụmu nda m, ele me whnụrnu n'anya, anụ gwuzosi rikne, anụ kwékọ be whome anụ, anụ gweru kpakara mkpọma anụ nọornu ẹrnu Nyenwe aị ige ọbula, hne anụ magwụ nụ ẹrnu anụ nụ rime Nyenwe aị jóowhu etekne. 
\c 16  
\s1 Ọtu ịwai ke  //  rụmu Chiokike 
\p  
\v 1 Gbasịri ịwai be jọotunu rụmu Chiokike ke zị nụ Judiya, anụ mee kpa me kannụ ọgbako Chiokike ke zị nụ Galasia.  
\v 2 N'ọbochi mbọm ke ikwezu, nye ọbula bịta ịwai ichne lele kpa o nwernu, ọ bịtakwata a nkarị ma anụ zọ́ma ọ tụ ịwai nga me jaava.  
\v 3 Nga me varụ m jaagba ọkwukwo izi nyee ele anụ họhiaru, m zizne be gwezne nkesi anụ nụ Jerusẹlem.  
\v 4 Ọ bụru nụ ọ bụru ọma, me nụ be joosno zne. 
\s1 Ọriasno Pọlu 
\p  
\v 5 Nga me zne zuru Masidonia, m jaavakwnusi anụ, kwnornu m jeezne Masidonia.  
\v 6 Me nụ anụ jaadazị ige matị mọbu tem okirika whe, ma anụ yinu m aka m zne hne ọbula me jeezne.  
\v 7 M píole m ọ whnụ anụ ige matị, kọvu m pioru m me nụ anụ dazịri gbu ọkwnu, ọ bụru nụ Chiokike kwe.  
\v 8 Kọvu m jaadazị hna nụ Efesọsi dụ ọbochi Pẹntikosi.  
\v 9 Kwnornu nụ be gbamannụ m okne ọnuhna ẹrnu izi ọma hna, kọvu agịda ele neemegidne m zị masị. 
\p  
\v 10 Ọ bụru nụ Timoti va, anụ kwékọ ogwnu tụ a kpa ọ zị n'esilawụru anụ, kwnornu nụ ọ nọornu ẹrnu Nyenwe aị lele me.  
\v 11 Ọ zá nye ledna a anya, anụ yinu a aka ma o lizọ izne a n'udno, vakwnusi m. M neele anya ya nụ rụmu nda aị. 
\p  
\v 12 Nhne gbasịri nwene aị rukna Apọlosi, m rịasnornu m a agịda ige ma ya nụ rụmu nda aị va lekasi anụ, kọvu o jíknene ọ va kịtna. Ọ jaava nga o nwehịaru oghere. 
\p  
\v 13 Anụ sama anya anụ, anụ gwuzosi rikne n'ọkwnata ovu, ovu si anụ rikne, anụ ghọ ele dikne.  
\v 14 Anụ gweru ọwhnun'anya rnụ kpakara ẹrnu anụ. 
\p  
\v 15 Anụ magwụ nụ ele ọro Stefanasi bụ ele mbọm ghọru ele Karaịsi nụ Akaya. Be ji kpakara nhne be nwernu nọornu ele Chiokike ẹrnu. M naarịasno anụ,  
\v 16 anụ bịta ẹhni anụ nụ mkpururu ele nụ kpa nụ nye ọbula ke ji mkpọma be snornu be nọornu ẹrnu.  
\v 17 Ovu sọru m n'ọnu nga Stefanasi nụ Fọtunatosi nụ Akaịkosi varụ, be mesirni owu anụ ke kọru m.  
\v 18 Be vulizọru ovu m nụ ovu anụ masị. Ele nụ kpa kwesiri be hnata be ama. 
\p  
\v 19 Ọgbako Chiokike ke zị nụ Esia neebekwu anụ. Akwịla nụ Prisila nụ ọgbako Chiokike zị n'ọro be ji rẹwhna Nyenwe aị neebekwu anụ k'agịda.  
\v 20 Kpakara rụmu nda ele zị hna neebekwu anụ. Anụ bekwurita ibne anụ lele rụmu nda. 
\p  
\v 21 Mawa, Pọlu, ji aka m naagba obekwu ikwu ka. 
\p  
\v 22 Be vụ nye ọbula ke whnụ́ge Nyenwe aị n'anya ọnu. Nyenwe aị, vaa. 
\p  
\v 23 Oru ke Nyenwe aị Jizọsi dazịnu anụ. 
\p  
\v 24 Ọwhnun'anya m nụ rime Karaịsi Jizọsi dazịnu kpakara anụ.