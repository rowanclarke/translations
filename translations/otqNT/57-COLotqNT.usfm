\id COL
\h AR KOLOSENSE
\toc1 AR KOLOSENSE Ar he̱ꞌmi bi ꞌyotꞌa ar Pablo bi me̱mpa ya me Kolosa
\toc2 AR KOLOSENSE
\toc3 Col.
\mt1 AR KOLOSENSE
\mt2 Ar he̱ꞌmi bi ꞌyotꞌa ar Pablo bi me̱mpa ya me Kolosa
\c 1
\s1 Ar nze̱ngwa
\p 
\v 1 Nuga dar Pablo, ár mpo̱tegi ar tsi Hmu Hesukristo ngetho njapꞌu̱ xi ne Jö. Di ze̱ngwaꞌihe, nuga ne ar ku Timoteo.
\p 
\v 2 Di pe̱ñꞌahe nunar he̱ꞌminu̱ nuꞌahu̱ gar gamfihu̱ me Kolosa, gi te̱ñhu̱ ar tsi Hmu Hesukristo. Jö ma Dadahu̱ ne ma tsi Hmuhu̱ Hesukristo da ꞌraꞌahu̱ nꞌar hogamꞌu̱i ne da hwëkꞌahu̱ yá ñho.
\s1 Ar Pablo a̱pa Jö da umba ya gamfi nꞌar hoga mfödi di ꞌñe mhetsꞌi
\p 
\v 3 Hyaxꞌmu̱ di a̱fe da ma̱xꞌahu̱ Jö ár Dada ma tsi Hmuhu̱ Hesukristo, ne hindi tsa̱ya̱he di umfe njamödi.
\p 
\v 4 Xta o̱he tengu ri jamfihu̱ gi pe̱ꞌspabihu̱ ar tsi Hmu Hesukristo, ne ar mhöte gi pe̱ꞌsfu̱ nꞌa ngu nꞌa ya gamfi,
\p 
\v 5 ngetho gi ndo̱ꞌmhu̱ ma gi hñöñhu̱ nöꞌö xi tꞌe̱kꞌahu̱nu̱ mhetsꞌi, habu̱ xpa hokꞌahu̱ Jö, gatho nuꞌahu̱ xka ꞌyo̱hu̱ no̱ngar hoga mhö majöni.
\p 
\v 6 Nunar hoga mhö xka ꞌyo̱hu̱ xi nu̱nga gatho ár nxidi ar ximha̱i, ñhe̱hwi nꞌar ꞌba̱iza te ne unga ar sofo. Xka njahu̱pꞌu̱ núꞌmu̱ mi zo ri guhu̱ ne ga pötwabihu̱ nöꞌö majöni ár hoga nhwëki Jö,
\p 
\v 7 ngu xi utꞌahu̱ ma hmöka kuhu̱ ar Epafra, ma miꞌbe̱gohe. Gehnu̱ nꞌár hoga ꞌbe̱go ar tsi Hmu Hesukristo ꞌbu̱i da ma̱xꞌahu̱.
\p 
\v 8 Xi xikagihe nꞌehe, nuna ri döta mhöte gi pe̱ꞌsu̱ xi ꞌraꞌahu̱ ár Hñö Jö.
\p 
\v 9 Nu nda jwadi da o̱he, hindi tsa̱ya̱he di a̱fe Jö da yotꞌa ri mfenihu̱ gi pöhu̱ te neꞌö, ne da ꞌraꞌahu̱ ar hoga mfeni ne ar hoga mfödi di ꞌñe mhetsꞌi.
\p 
\v 10 Di a̱ꞌahu̱ gi ꞌbu̱hu̱ ngu di ꞌñepi da mꞌu̱ nꞌár bötsi Jö, ne xa da numañhoꞌihu̱. Da nheki ri hogamꞌu̱ihu̱, ne hyaxꞌmu̱ ꞌyo gi pöhu̱ togo Jö.
\p 
\v 11 Ne di a̱pabihe Jö da ze̱tꞌa ri mu̱ihu̱ ngu ár ntꞌe̱ni bi e hár nsunda. Njapꞌu̱ gi tse̱thu̱ gatho nöꞌö gi thohu̱, ne gi pe̱ꞌsu̱ ar tsꞌe̱ti nꞌa ngu nꞌa.
\p 
\v 12 Ga njohyahu̱ ga umfu̱ njamödi Jö, ngetho bi ꞌraju̱ ar se̱ki ne ar tsꞌe̱di ga höñhu̱ ya ñho ma da hyengagihu̱, nuju̱ ne gatho nu maꞌra yá bötsi.
\p 
\v 13 Jö xi zimgagihu̱ hár tsꞌe̱di ar ꞌbe̱xui ndi ꞌbu̱hu̱, ne bi thógagihu̱ di ꞌbu̱hu̱pya hár tsꞌu̱tꞌwi ár hmöka Tꞌu̱.
\p 
\v 14 Gehnu̱ bi nöꞌma ár ji bi zimgagihu̱ har tsꞌoki, ne bi pumgagihu̱.
\s1 Nunár ndöte ar tsi Hmu Hesukristo bi jakagihu̱ da ñhogamu̱iwihu̱ ar Dada
\p 
\v 15 Ma tsi Hmuhu̱ Hesu togo di hñöxa Jö hingi nheki, mi ꞌbu̱ꞌö núꞌmu̱ hinxki thoktho gatho nöꞌö te japya, ne xa töpa ár nsu gathoyu̱.
\p 
\v 16 Jö bi ꞌye̱ntꞌwa hár ꞌye̱ bi hyoka gatho nöꞌö te janu̱ mañö mhetsꞌi, gatho nöꞌö te jawa har ximha̱i, gatho nöꞌö nheki ne nöꞌö hingi nheki, gatho nuꞌu̱ ya ndö, nuya tsꞌu̱tꞌwi, nuꞌu̱ ja yá tsꞌe̱di ne nuꞌu̱ ja yá nsu. Gatho go bi hyokꞌö nda nsundabi.
\p 
\v 17 Núꞌmu̱ hinxki thoktho gatho nöꞌö teme japya, mi ꞌbu̱ꞌö, ne gatho o hár ꞌye̱ꞌö.
\p 
\v 18 Gehnu̱ ár ñöxhmu ar nijö, togo ár ndu̱i gatho te ja, ne ar ꞌbe̱tꞌo gatho nöꞌö te ꞌbu̱i. Mꞌe̱tꞌo bi mengi bi nteꞌö xki du, ne njapꞌu̱ gatho di ꞌbe̱tꞌoꞌö.
\p 
\v 19 Jö ar Dada go bi neꞌö nda hñömpa ár Tꞌu̱ gatho ár nsunda.
\p 
\v 20 Ne nunár ndöte ár Tꞌu̱ꞌö, bi japi bi ñhogamu̱iwi gatho nuꞌu̱ ꞌbu̱hnu̱ mhetsꞌi ne nuꞌu̱ ꞌbu̱kwa har ximha̱i. Ne núꞌmu̱ mi nöꞌma ár ji ár Tꞌu̱ har pontꞌi, bi jakagihu̱ da ntsixkwihu̱.
\p 
\v 21 Nuꞌahu̱ mamꞌe̱tꞌo ngi ꞌbu̱hu̱ yapꞌu̱, hinge ngi mpöhwihu̱ Jö. Ngi u̱tsahu̱ ha ri mfenihu̱, ngi o̱thu̱ nöꞌö hingi ho. Ha nupya ár Tꞌu̱ꞌö xi jaꞌahu̱ xka ñhogamu̱iwihu̱.
\p 
\v 22 Bi njapꞌu̱ núꞌmu̱ mi njöꞌi ne bi unga ár te har pontꞌi. Njapꞌu̱ nda tsa̱ nda ꞌba̱pꞌahu̱ xintꞌaxi hár nthandi Jö, hinte ma tsꞌoki ngi pe̱ꞌsu̱ ne hinto nda kꞌasꞌahu̱.
\p 
\v 23 Jange mahyoni hingi hye̱hu̱ ar ñꞌemu̱i, ne xa gi ze̱ta ri mu̱ihu̱ gi to̱ꞌmhu̱ hyaxꞌmu̱ nunar ndo̱ꞌmi xka ꞌyo̱xu̱ har hoga mhö. Ne nunar mhönu̱ xi mhömba gatho ár nxidi ar ximha̱i, ha nuga ar Pablo xi thuxkagi ga xani.
\s1 Ar Pablo pe̱pa nuꞌu̱ hingya xodyo
\p 
\v 24 Xa di johya ngetho di tho ya thogi, di honga ri ñhohu̱. Ne njapꞌu̱ ꞌyo di jwatwa yá u̱gi ma tsi Hmuhu̱ Hesukristo, di homba ár ñho ar nijö nꞌehe, gehnu̱ ár ndoꞌyose̱.
\p 
\v 25 Ne nuga bi thuxkagi ngu ár ꞌbe̱go hár nijö. Jö xi ꞌraka nunar ꞌbe̱finu̱ honga ri ñhohu̱. Xi thuxkagi ga xiꞌahu̱ gatho ngu mönga hár mhöꞌö.
\p 
\v 26 Nunar mhönu̱ xki tꞌögi, ho̱nse̱ mi pöse̱ Jö. Bi njapꞌu̱ gatho nuya je̱ye̱ bi thogi, ha nupya hö, xi utwa yá bötsi Jö.
\p 
\v 27 Jö go bi ne njapꞌu̱, nda utꞌahu̱ hingya xodyohu̱ nöꞌö hinxki fö mamꞌe̱tꞌo: nunar tsi Hmu Hesukristo tsa̱ da mꞌu̱ ha ri mu̱ihu̱. Gehnu̱ ar ndo̱ꞌmi ma gi ꞌbu̱hwihu̱ hár nsunda.
\p 
\v 28 Nuje yá ꞌbe̱gogihe Jö, habu̱ gatho di mömfe ár thuhu, di höhe ar hoga mfödi. Di uthe ne di huꞌmbabihe yá mu̱i gatho ya jöꞌi, di hoñhe ga ꞌba̱ꞌmhe nꞌa ngu nꞌa hár nthandi Jö, di nxo̱ge ngetho ꞌbu̱hwi ar tsi Hmu Hesukristo.
\p 
\v 29 Jange gehnu̱ di umba ma mu̱i di pe̱fi, di hömpa ár tsꞌe̱di mpe̱ ha ma mu̱i.
\c 2
\p 
\v 1 Di ne gi pöhu̱, nuga xa di umba ma mu̱i di a̱pa Jö da ma̱xꞌahu̱, da ma̱xa nuꞌu̱ ya me Laodisea ne gatho nuꞌu̱ hinxta mpöꞌbe.
\p 
\v 2 Di a̱pa Jö da hupꞌa ri mu̱ihu̱ gi pe̱ꞌsu̱ nꞌadar mhöte. Ne da ꞌraꞌahu̱ nꞌar hoga mfeni gi pöhu̱ nöꞌö hinxki fötwahmö mamꞌe̱tꞌo, tema mi benga Jö ma Dadahu̱ ne ar tsi Hmu Hesukristo.
\p 
\v 3 Ngetho ha ma tsi Hmuhu̱ Hesukristo, ka ꞌbe̱shnu̱ gatho ar hoga mfödi ne ar hoga mfeni.
\p 
\v 4 Di xiꞌahu̱ njapꞌu̱, hinto gi hofu̱ da kaꞌahu̱ di honga ya nza̱tho ne.
\p 
\v 5 Mödi hindi ꞌbu̱hwihu̱, wande di ꞌbu̱pꞌu̱, ngetho hyaxꞌmu̱ di beñꞌahu̱. Di johya ngetho xta o̱de xa gi o̱thu̱ xiñho, ne döta ri ñꞌemu̱ihu̱ gi pe̱ꞌsfu̱ ar tsi Hmu Hesukristo.
\p 
\v 6 Jange ꞌbu̱hu̱ xiñho ngu di ꞌñepi da mꞌu̱ nuꞌu̱ yá me̱ti ar tsi Hmu Hesukristo. Te̱ñhu̱ nöꞌö bi tꞌutꞌahu̱ núꞌmu̱ nga ñꞌemu̱ihu̱.
\p 
\v 7 Jahu̱ ngu ya ꞌyu̱za foxa har ha̱i, ngu nꞌar ngu huxa har medo, dá ñöxa ri ñꞌemu̱ihu̱ ngu xi tꞌutꞌahu̱, ne hingi tsa̱ya̱hu̱ gi umfu̱ njamödi Jö.
\s1 Di pe̱ꞌsu̱ nꞌar hoga te ngetho di ꞌbu̱hwihu̱ ar tsi Hmu Hesukristo
\p 
\v 8 Ntsuñhu̱, yo ma gi ñhe̱hu̱ togo da hya̱ꞌahu̱. Nuꞌu̱ ya nemhñö jöꞌi ꞌyopꞌu̱ xiꞌahu̱ nöꞌö bense̱, ne ngu nöꞌö xi mönga yá mijöꞌiwi te̱ntꞌu̱, hinge ngu xi mönga ar tsi Hmu Hesukristo.
\p 
\v 9 Ngetho hár mꞌu̱i ma tsi Hmuhu̱ Hesukristo, ka nhekipꞌu̱ ár mꞌu̱i Jö.
\p 
\v 10 Ne nuꞌahu̱ xka nxo̱gehu̱, ngetho gi nꞌatꞌwihu̱ ar tsi Hmu Hesukristo, togo ár ñöxhmu gatho nuꞌu̱ pe̱ꞌsa ar tsꞌe̱di ne ar tsꞌu̱tꞌwi.
\p 
\v 11 Núꞌmu̱ nga ehu̱ ga tsu̱hu̱ ar tsi Hmu Hesukristo, bi thökꞌahu̱ nöꞌö mar ntsꞌotho ha ri mu̱ihu̱, po̱ntho bi nse̱kꞌahu̱; hinge ngu ar nse̱ni hoka ya jöꞌi. Nunar nse̱ninu̱ bi ꞌraꞌahu̱ ar tsi Hmu Hesukristo.
\p 
\v 12 Nunar xixthe xka hñöhu̱, po̱ntho bi tꞌa̱kꞌahu̱ mahye̱giwi ar tsi Hmu Hesukristo. Ne ga penju̱ ga ntehu̱ manꞌagi núꞌmu̱ ga ñꞌemu̱ihu̱ ár tsꞌe̱di Jö, togo bi koꞌspa ár te ar tsi Hmu.
\p 
\v 13 Mamꞌe̱tꞌo xki hyoꞌahu̱ ar tsꞌoki, ne hinge ngi pe̱ꞌsu̱ ar nse̱ni thuxa har ndoꞌyo. Bi tꞌaꞌahu̱ ar te mahye̱giwi ar tsi Hmu, ne njapꞌu̱ bi pumpꞌahu̱ ri tsꞌokihu̱.
\p 
\v 14 Bi nhwata nuya ꞌbe̱pate mi ho̱xꞌahu̱ ngar tsꞌoktehu̱, ne bi jötsꞌi bi foꞌsa hár pontꞌi ar tsi Hmu Hesukristo.
\p 
\v 15 Geꞌmu̱ bi hñömba gatho yá tsꞌe̱di yá ñöxhmu ya tsꞌondöhi, ne bi ꞌbe̱twa ár tsa̱ ha yá nthandi ya jöꞌi. Ka bi döhnu̱ núꞌmu̱ mi tsꞌu̱ta har pontꞌi.
\p 
\v 16 Jange hinto da deñꞌahu̱ nuꞌmu̱ hingi o̱thu̱ ngu yá ntꞌumbiꞌu̱, wa hingi tsifu̱ yá ñhuni ne yá tsꞌithe, hingi o̱thwu̱ ár da̱ngo ar ꞌraꞌyo zönö ne maꞌra ya da̱ngo, wa hingi tsufu̱ ya pa ntsa̱ya̱.
\p 
\v 17 Ngetho gatho nuꞌu̱ mi tꞌo̱tꞌa mamꞌe̱tꞌo, ngu ár xuditho nöꞌö togo ma nda e mꞌe̱fa, ne nupya di pöhu̱ gehnu̱ ar tsi Hmu Hesukristo.
\p 
\v 18 Yo gi hofu̱ togo da xiꞌahu̱ hinte ma nthöhö gi to̱ꞌmhu̱ ngetho hingi o̱thu̱ ngu o̱tꞌu̱. Nuꞌu̱ o̱tꞌe xa ya hogajöꞌi, ne ndönga ya e̱nxe̱. Hinte ju̱kꞌu̱ pe̱pa nuꞌu̱ hingi pödi, ne da ꞌñexyá nsu te̱nga nöꞌö bense̱ꞌu̱.
\p 
\v 19 Nuꞌu̱ hingi miꞌye̱wi ma tsi Hmuhu̱ Hesukristo togo ár ñöxhmu ar nijö. Nunar nijö ngu nꞌar ndoꞌyo hönga ár ñhuni ne nju̱ngwi ya ntotꞌi ne ya de̱xi, ꞌyo di te hömba ár tsꞌe̱di Jö.
\p 
\v 20 Nuꞌmu̱ majöni ga tuwihu̱ mahye̱gi ar tsi Hmu Hesukristo, ne ga tsohu̱pꞌu̱ yá ntꞌumbi ya meximha̱i, yoꞌö gi te̱mbathohu̱ yá mfeni ya jöꞌi ꞌmu̱, to da ꞌñenö gi pe̱pathohu̱ ar ximha̱i.
\p 
\v 21 Jangu nuꞌu̱ eñꞌu̱: Yo gi xaxthu̱ nuna, yo gi tsihu̱ nöꞌö, yo ma gi tha̱ñhu̱.
\p 
\v 22 Gatho nuya ntꞌutiyu̱ xi bense̱ ya jöꞌi, no̱nga nöꞌö te da thege xta ꞌyo̱tꞌe, hinter me̱ꞌu̱.
\p 
\v 23 Nuya ntꞌutiyu̱ xa majöni nheki xiñho, wande xi thoka ha nꞌar döta mfödi ne hinxi thoki har ñꞌetsꞌi. Ngetho ne da zönthmö ar ndoꞌyo, mödi hingi tsa̱ da hñöka ya tsꞌomfeni ne ar tsꞌoki ha ma mu̱ihu̱.
\c 3
\p 
\v 1 Nuꞌmu̱ majöni ga penju̱ ga ntehu̱ mahye̱giwi ar tsi Hmu Hesukristo, hyoñhu̱ mꞌe̱tꞌo nuya ñho bi ja mañö mhetsꞌi, habu̱ bi huxa ar tsi Hmu hár ñꞌe̱i ár Dada.
\p 
\v 2 Hñuxu̱ ri mfenihu̱ nuya ñho bi ja mhetsꞌi, hinge nuꞌu̱ jawa har ximha̱i.
\p 
\v 3 Ngetho xka tuwihu̱ mahye̱gi ar tsi Hmu Hesukristo, ne ri tehu̱ juta Jö, ngetho gi ꞌbu̱hwihu̱ ar tsi Hmu.
\p 
\v 4 Ne núꞌmu̱ xta penga manꞌagi, ma da thantꞌahu̱ mahye̱giwi hár nsunda, ngetho gi nꞌatꞌwihu̱ ri tehu̱.
\s1 Nunar mꞌu̱i da he̱hu̱pꞌu̱ ne nunar ꞌraꞌyo di pe̱ꞌsu̱pya
\p 
\v 5 Jange hye̱hu̱ gatho nuya tsꞌoki jawa har ximha̱i: yo gi tsimfu̱ yá nthöti maꞌra, yo gi o̱thu̱ ya tsꞌoki xi ntsꞌotho, yo gi o̱thu̱ nuya tsꞌoki ne ri ndoꞌyohu̱, hingi ñhe̱hu̱ da döꞌahu̱ ar tsꞌomfeni. Yo xa gi möhu̱ ar bojö, ngetho nuꞌmu̱ gi jahu̱pꞌu̱, po̱ntho gi ndöñhu̱ ar bojö, hingi ndöñhu̱ Jö.
\p 
\v 6 Ngetho nuya tsꞌoꞌbe̱fiyu̱ tsixa ya me̱ꞌsku da zu̱twa ár kwe̱ Jö.
\p 
\v 7 Nuꞌahu̱ mahamꞌu̱ ngi ꞌbu̱hu̱nu̱ ha ya tsꞌoꞌbe̱fiyu̱ nꞌehe.
\p 
\v 8 Hinge ho̱nse̱ꞌu̱, di xiꞌahu̱ gi hye̱hu̱ gatho nu maꞌra ya tsꞌoki nꞌehe, ngu ar ntꞌu̱tsa, ar kwe̱, ar tsꞌomꞌu̱i, ar tsꞌate ne maꞌra ya tsꞌone.
\p 
\v 9 Yo gi mpehu̱ ar nhemhñö nꞌa ngu nꞌa, ngetho nöꞌö ar mꞌe̱tꞌo mꞌu̱i ngi pe̱ꞌsu̱ mahamꞌu̱, xka ꞌye̱ñhu̱pꞌu̱ ngu nꞌar ze̱ dutu.
\p 
\v 10 Ha nupya ngu nꞌar ꞌraꞌyo he, gi pe̱ꞌsu̱ nꞌar ꞌraꞌyo te di hñöxa nöꞌö togo bi hyoki. Hyaxꞌmu̱ di hogi da ñhe̱hwi xiñho ár mꞌu̱iꞌö.
\p 
\v 11 Ne har ꞌraꞌyo mꞌu̱i gi ꞌbu̱hu̱, hindi nhekinu̱ togo ar xodyo togo hingar xodyo, togo xi nse̱mba ár ndoꞌyo togo hinꞌö, togo hinte pödi ne togo xa jár mfödi, togo mꞌe̱go ne togo hinte ꞌñe ar hmu. Ngetho gatho gi ohu̱ hár ꞌye̱ ar tsi Hmu Hesukristo, ne nöꞌö mahye̱githo ꞌbu̱hwi gatho.
\p 
\v 12 Dá nheki ri ꞌraꞌyo mꞌu̱ihu̱ ngu nꞌar ꞌraꞌyo he, ngetho Jö xi möꞌahu̱ ne xi hwañꞌahu̱ ngu ár me̱tiꞌö. Jange nupya ꞌbu̱hu̱ gi pe̱ꞌsu̱ nꞌar döta nhwëki, ne ar ñhogajöꞌi, hingi ñꞌexu̱, pe̱ꞌsu̱ nꞌar hogamu̱i ne ar tsꞌe̱ti.
\p 
\v 13 Pe̱ꞌsfu̱ ar tsꞌe̱ti nꞌa ngu nꞌa ri ñꞌohu̱, mpuñhu̱ nꞌa ngu nꞌa, ha nuꞌmu̱ nꞌar ku xi tso̱tꞌa ri mu̱ihu̱, pumbabihu̱. Mahye̱gi ngu xi pumpꞌahu̱ ar tsi Hmu Hesukristo, jahu̱pꞌu̱ nꞌehe.
\p 
\v 14 Jange mahyoni da gopꞌathoꞌihu̱ ar mhöte. Njapꞌu̱ gi nꞌathohu̱, ne da tsa̱ gi ꞌbu̱hu̱ nꞌadar mfeni gi pe̱ꞌsu̱.
\p 
\v 15 Ar hogamꞌu̱i ꞌraꞌahu̱ ar tsi Hmu Hesukristo da zisꞌa ri mu̱ihu̱, ngetho xi zoñꞌahu̱ gi nꞌadar ndoꞌyohu̱ gi ꞌbu̱hwihu̱ xiñho maꞌra ya ku. Ne hyaxꞌmu̱ umfu̱ njamödi Jö.
\p 
\v 16 Di oda ri mfenihu̱ ár mhö ar tsi Hmu Hesukristo. Ngetho xka hñöñhu̱ ar hoga mfödi, ñꞌuthu̱ ne huꞌma ri mu̱ihu̱ nꞌa ngu nꞌa. Ndöñhu̱ ar tsi Dada gi tuthu̱ ya nsa̱di ne ya thuhu no̱nga Jö. Umfu̱ njamödi ha ri mu̱ihu̱.
\p 
\v 17 Gatho nöꞌö gi ꞌyo̱thu̱ wa gi möñhu̱, ꞌyo̱thu̱ gi nsundahu̱ ar tsi Hmu Hesukristo, ne hár thuhuꞌö umfu̱ njamödi Jö ar Dada.
\s1 Nöꞌö mahyoni da ꞌyo̱tꞌa ya gamfi ne njapꞌu̱ da gohwi xiñho nu maꞌra
\p 
\v 18 ꞌBe̱hñöhu̱, ꞌyo̱thu̱ ri dömehu̱ ngu di ꞌñepi da ꞌyo̱tꞌa nuꞌu̱ xi jamfi ar tsi Hmu.
\p 
\v 19 Ñꞌo̱ho̱hu̱, möhu̱ ri ꞌbe̱hñöhu̱, ne yo gi o̱thu̱ ndöta.
\p 
\v 20 Bötsihu̱, ꞌyo̱thu̱ gatho nöꞌö da xiꞌahu̱ ri dadahu̱, ngetho ar tsi Hmu go ne njapꞌu̱.
\p 
\v 21 Dadahu̱, yo gi tsu̱hu̱ ntsꞌe̱di ri bötsihu̱, xiꞌmu̱ da zo̱tꞌa yá mu̱i.
\p 
\v 22 ꞌBe̱gohu̱, pe̱fu̱ gatho nöꞌö da ꞌbe̱pꞌahu̱ ri hmuhu̱. Hinge ho̱nse̱ núꞌmu̱ hantꞌahu̱ gi ne gi kohwihu̱ xiñho. Pe̱fu̱ xiñho di po̱nga ri mu̱ihu̱, ngetho gi tsufu̱ Jö.
\p 
\v 23 Ne gatho nöꞌö gi pe̱hu̱, umba ri mu̱ihu̱ gi ꞌyo̱thu̱, wande gi o̱tꞌwabihu̱ ar tsi Hmu, hinge gi o̱thwu̱ ya jöꞌi.
\p 
\v 24 Gi pöhu̱, nunar tsi Hmu Hesukristo go ma da ꞌraꞌahu̱ ar nthöhö, ngetho gi pe̱pabihu̱ꞌö.
\p 
\v 25 Ha nöꞌö togo o̱tꞌa ar tsꞌomꞌu̱i, ar tsi Dada ma da gutꞌwa ngu xi ꞌyo̱tꞌe, ngetho nöꞌö hingi hwanta ya jöꞌi.
\c 4
\p 
\v 1 Hmuhu̱, pe̱ꞌsu̱ nꞌar hogamu̱i gi ꞌbe̱fu̱ ri ꞌbe̱gohu̱. Beñhu̱ gi ꞌñehu̱ nꞌa ri Hmuhu̱ nꞌehe bi ꞌbu̱ mañö mhetsꞌi.
\p 
\v 2 Umba ri mu̱ihu̱ gi ꞌya̱fu̱ Jö, ne hingi tsa̱ya̱hu̱ gi umfu̱ njamödi nöꞌö ꞌraꞌahu̱.
\p 
\v 3 ꞌYa̱pabihu̱ Jö da ma̱xje da xoka ya goxthi ga mömfe ár mhö, ne maꞌra da bö nöꞌö himi fötwa mamꞌe̱tꞌo ar tsi Hmu Hesukristo. Ngetho di pe̱ nunar ꞌbe̱finu̱, jange xi joka har fa̱di.
\p 
\v 4 ꞌYa̱fu̱ Jö da tsa̱ ga mönga xiñho nöꞌö mahyoni ga mö.
\p 
\v 5 Jamasuhu̱ hanja gi ꞌyohu̱. ꞌYohu̱ gi pe̱ꞌsu̱ nꞌar döta mfödi ha yá nthandi nuꞌu̱ hingya gamfi. Yo gi tsa̱ya̱hu̱ mömfu̱ ár mhö Jö.
\p 
\v 6 Núꞌmu̱ gi ñöhu̱, möñhu̱ ya hoga mhö ne di ꞌbe̱nga ntꞌekꞌei. Beñhu̱ xiñho nöꞌö ma gi thöthu̱ togo gi ñöwihu̱.
\s1 Ya ngöxanze̱ngwa
\p 
\v 7 Nuna ma hmöka ku Tikiko, gehnu̱ nꞌár hoga ꞌbe̱go Jö xta mpe̱he mahye̱gi. Nu xta zo̱mpꞌu̱nu̱, da xiꞌahu̱ hanja di ꞌbu̱kwa.
\p 
\v 8 Jange di pe̱ñꞌaꞌihu̱pꞌu̱ da xiꞌahu̱ tema di thohe, ne da hñupꞌa ri mu̱ihu̱.
\p 
\v 9 Xi me̱wi nꞌehe ma tsi hmöka hoga ku Onesimo, ngu gi pöhu̱ ar mengupꞌu̱. Xta zo̱mpꞌu̱yu̱ ma da xiꞌahu̱ gatho nöꞌö di thokwa.
\p 
\v 10 Pe̱ñꞌaꞌihu̱ nze̱ngwa ar ku Aristarko di oꞌbewa har fa̱di. Ze̱ngwaꞌihu̱ ar ku Mörko ár mëni ar ku Berhnabe. Gehnu̱ xi nsiꞌahu̱; núꞌmu̱ xta zo̱mpꞌu̱, nuhu̱ xiñho.
\p 
\v 11 Pe̱ñꞌaꞌihu̱ nze̱ngwa ar ku Hesu tꞌembabi ar Hogajöꞌi. Gatho ya xodyo xi jamfi, ho̱nse̱yu̱ xi ma̱xkagi xta mömfe ár hoga tsꞌu̱tꞌwi Jö, ne njapꞌu̱ xi hubga ma mu̱i.
\p 
\v 12 Ze̱ngwaꞌihu̱ ar ku Epafra nꞌár ꞌbe̱go ar tsi Hmu Hesukristo. Gehnu̱ nꞌar mengupꞌu̱ nꞌehe. Hyaxꞌmu̱ umba ár mu̱i a̱pa Jö da ze̱tꞌa ri jamfihu̱, gi ꞌbu̱hu̱ xiñho, ne hinte da ꞌbe̱di gi ꞌyo̱thu̱ gatho nöꞌö ne Jö.
\p 
\v 13 Nuga di da̱majöni ꞌbu̱tho da du hompꞌa ri ñhohu̱. Hinge ho̱nse̱ꞌihu̱, benga ya ku me Laodisea ne ya me Yerapolis nꞌehe.
\p 
\v 14 Pe̱ñꞌaꞌihu̱ nze̱ngwa ar hmöka ku Luka togo ar unga ñꞌethi, ne ar ku Dema.
\p 
\v 15 Ze̱ngwagihu̱pꞌu̱ ya ku ꞌbu̱hnu̱ Laodisea, ne ar ku Nimfa ne gatho ya ku mhunsa hár ngu.
\p 
\v 16 Núꞌmu̱ xki jwahu̱ gi nehu̱ nunar he̱ꞌminu̱, thokwabihu̱ ar nijö ꞌbu̱hnu̱ Laodisea, ne nunár he̱ꞌmiꞌu̱ ꞌya̱fu̱ gi nehu̱.
\p 
\v 17 ꞌÑembabihu̱ ar ku Arkipo: Jwata xiñho nunar ꞌbe̱fi xi ꞌraꞌa ar tsi Hmu.
\p 
\v 18 Nuga dar Pablo, xta ja ma ꞌye̱ xta otꞌase̱ nunar nze̱ngwanu̱. Yo ma gi pumhnihu̱ di owa har fa̱di. Jö da hwëkꞌahu̱ yá ñho. Dá njapꞌu̱.
