\id ISA - Kuna, San Blas - Bible -Panama 2014 (DBL -2014)
\h Isaías
\toc1 Isaías-Garda
\toc2 Isaías
\toc3 Is
\mt1 ISAÍAS-GARDA
\mt2 ISAÍAS
\imt2 GEBE-SOGLENAID
\imt1 Garda-nug
\ip \it Isaías-Garda.\it* Amoz-machi-Isaías, Bab-Dummad-gayaburba-barsogedid. \it Jehová dule-abonogedye,\it* Isaías-nug obarileged.
\is1 Isaías-Gardagi weyob sunmaklenaid
\ip We-garda, Bab-Dummad-e-ganguedgi sunmaked, degi, bela neg-ganimaidgi sunmakbalid. Isaías, Judá-e-Reymar-megismalad-ibagangi sunmakdii gusad: Uzías, Jotam, Acaz, Ezequías.
\ip Bab-Dummad, Isaíasʼse magarononikid, Israel-dulemarga e-gayaburbagi sunmakegar. Ar Israel-dulemar galagwensuli nanabukwamalad, Bab-Dummad-sogedba nanabuksurmalad.
\ip We-gardagine, weyob ilemakar sunmaklenaid:
\io1 1. Sabsur-odurdaklegoed (1:1–35:10).
\io2 1a. Jerusalén-dulemargi, degi, Judá-dulemargi sunmaklenaid (1:1–5:30).
\io2 1b. Emanuelʼgi sunmaklenaid (6:1–12:6).
\io2 1c. Yar-baid-baidgi-bukmaladga sunmaklenaid (13:1–23:18).
\io2 1d. Ibmar-guoed Isaíasʼga-burbar-oyolesad (24:1–27:13).
\io2 1e. Judá-dulemar, degi, Israel-dulemar-sabsur-odurdaklegoed (28:1–35:10).
\io1 2. Rey-Ezequíasʼga neggusad (36:1–39:8).
\io1 3. Israel-dulemar-gwage-armaklegoed (40:1–48:22).
\io1 4. Yoedse-gandikidba neg-oyolegoed (49:1–66:24).
\io2 4a. Yoedse-dule-abonoged-danikoed (49:1–59:21).
\io2 4b. Yoedse Jerusalén gandikidba yeer-daklegoed (60:1–66:24).
\ip Be itogua.
\c 1
\ms1 1. SABSUR-ODURDAKLEGOED
\mr (1:1–35:10)
\ms2 1a. Jerusalén-dulemargi, degi, Judá-dulemargi sunmaklenaid
\mr (1:1–5:30)
\s1 Judá-dulemar Bab-Dummadgi nue isgus-bukwad
\p 
\v 1 Judá-e-reymar: Uzías, Jotam, Acaz, degi, Ezequías, amar-negdakmamaidgine, Amoz-machi-Isaías, Judá-yargi, degi, Jerusalén-neggweburgi neg-guoed daksad.
\q1 
\v 2 ¡Nibneggi-bukmalad, an-itomalo!
\q2 ¡Napneggi-bukmalad, an-itomalo!
\q1 Bab-Jehová weyob soged: “Ani an an-mimmigan akwisad, an na odummosad,
\q2 degi-inigwele, angi gwisgudmalad.
\q1 
\v 3 Moli-bebe-nikad-alugwasualed, e-ibed magar daked.
\q2 Moli-uayasuid, moli-urbed-galu-e-ibedgad magar daked.
\q1 Degite, Israel-dulemardi, akusunna itomalad,
\q2 an-dulamardi, aku ibmar dakmalad.
\b
\q1 
\v 4 ”Dulemar-nue-isgus-bukwamalad, ¡ibitosmar!
\q2 Dule-nue-isguedgi-bipirmaksa-bukwamalad, ¡ibitosmar!
\q1 Dule-ibmar-isgana-imakmalad-e-wagan-bukwad, ¡ibitosmar!
\q2 Dule-gwage-isgus-gudimalad-e-mimmigan-bukwad, ¡ibitosmar!”
\q1 Ar bemar, ¡Bab-Jehováʼgi bangudmalad!
\q2 ¡Israel-e-Bab-Dummad-Isligwaled isdar dakdemalad!
\q2 ¡Gannar sorsik aibiridmalad!
\b
\q1 
\v 5 ¿Ibiga amba sabsur-odurdakledii gubimarsunna?
\q2 ¿Ibiga uayasuli-gudii gubimarsunna?
\q1 Bela e-nono, ise-nailikguar siid,
\q2 bela e-gwage nued naisulid.
\q1 
\v 6 Bela e-nag-duku-akale, nonosega, e-san-nued wis naisulid,
\q2 bela oitolesadbi nanaed.
\q1 E-san, gudure-gudure nanaid.
\q2 E-yaamar-bukwadi, nunu-yapanne nanaed,
\q1 ar gwen nugussuli nanaed,
\q2 morgi-obipirmakar naisurbalid,
\q2 olivo-gwallugi maglegarsurbalid.
\b
\q1 
\v 7 E-yala, nue-bergus naid.
\q2 E-neggweburmar, bato soogi-ogumakles bubukwad.
\q1 Emar-sunnagwad na dakmaloed,
\q2 igi-dule-baigan e-ibmar-digar-nanaid gutemaloe.
\q1 E-yala, olloo naioed,
\q2 dule-bamaladse e-yala obelolesadyob naguoed.
\q1 
\v 8 Sión-yala, uva-nainugi binsa dukued-neg olloo-siidaedyobi daklenaded.
\q2 Melón-digar-naidgi, binsa neg-ollobi-siidyobi daklenaded,
\q2 neggwebur, dule-isdarmaladse ebirilessiidyob gued.
\q1 
\v 9 Ar Bab-Jehová-Bela-Gangued-Nikad anmar-gwenna-gwenna-odulossulina,
\q2 Sodoma-dulemaryob anmar gumogoenad,
\q2 Gomorra-dulemaryob anmar obelolemogoenad.
\s1 Napiragwadgi e-isguedga-bukib-binsamarye ega soglenaid
\q1 
\v 10 Sodoma-e-dummagan, Bab-Jehová-ibmar-soged be itomar.
\q2 Gomorra-neggwebur, anmar-Bab-Dummad-Igar-Maid be itomar.
\p 
\v 11 Bab-Jehová soged:
\q1 “Be-ibmar-ukleged-bukidaradi, ¿ibi-nuedga anga wis gue?
\q2 Ar gwen an abemaisulid.
\q1 Ar sibad-wawaad-machergan-ogumakar-anga-ukleged an budar dakgusad.
\q2 Ar ibdurgan-wardummagan-e-gwallu-anga-ukleged an budar dakgusad.
\q1 Moli-bebe-nikad-machergan-e-ablis an abesulid,
\q2 sibad-wawaadmar-e-ablis an abesulid,
\q1 sibad-machergan-e-ablis an abesulid,
\q2 we-ibmarmar, gwen bai an daksulid.
\q1 
\v 12 ¿Ibiga be an-asabin danimala?
\q2 ¿Doa bega ibdurgan-sedamaloye sogsa?
\q2 Unnila anse-goled-neg-imba-oichogega be nonidamalad.
\q1 
\v 13 Melle bar be anga ibmar-ukleged-gwen-igarga-gusulid sedamalo.
\q2 Ar ina-wawadikid anga ibmar-isganaga gued.
\q1 Nii-binidgi, iba-onoleged an budar dakgusad,
\q2 obunnoged-ibagi, iba-onoleged an budar dakgusad,
\q1 dulemar-bular-onmaknonidamalad an budar dakgusad,
\q2 be-an-nug-odummomalad, aka bur an-ourwe damalad, bar an itobisulid.
\q1 
\v 14 Bemar nii-binid-gwisguedgi iba-onogedi, an budar itogusad.
\q2 Itoakwaa-iba-onolegedi, an budar itogusad.
\q1 Ibmar-nuedga gwen anga gusulid,
\q2 abali, an budar itogusad.
\q1 
\v 15 Bemar anse-goledgi argan-onakwialile, an bemar-dakosulid,
\q2 wagar-biir an bemar-idu imakoed.
\q1 Ar gandikidgi bemar anse gornanaile, an bemar-itogosulid.
\q2 Ar bemar dulemar-ibe ablis eosmalad.
\b
\q1 
\v 16 ”¡Isguedgi be bangumar, swilidik be gumar!
\q2 ¡An-asabin ibmar-isgana-imakedgi be bangumar!
\q2 ¡Melle bar ibmar-isgana be imakmar!
\q1 
\v 17 ¡Igar-nuegan-imaked be durdakmar!
\q2 ¡Igar-napiragwad be imakmar!
\q1 ¡Dule-mesagwar-imaklediid be bendakmar!
\q2 ¡Dule-sergan-satedga be igar nabomar!
\q2 ¡Siamar-ei-sui-burgwismalad-ular, be gwisgumar!”
\p 
\v 18 Bab-Jehová soged:
\q1 “Be dagmar, anmar igar nudakmargwelo.
\q2 Bemar-isgued, ginnitibiyob-gue-inigwele, boo-sibudikidyob-dakle naoed.
\q1 Bemar-isgued, mor-ginnidyob-gue-inigwele,
\q2 sibad-wawaad-e-absar-dagudikid-daklegedyob naoed.
\q1 
\v 19 Ar bemar an-sogedba nanamaloye sogele,
\q2 be-yargi ibmar-nuegan-sanmakoedi be gunmaloed.
\q1 
\v 20 Ar bemar amba an-itosulile, angi be gwisgudmalale, es-suidgi be ogilolemaloed.”
\q2 Ar Bab-Jehová, e-sunnagwad deyob soged.
\s1 Jerusalén-neggweburga igar-nabolesad
\q1 
\v 21 Neggwebur-innikigwad, ¿ibiyobi gambanuchusaedga be gusa?
\q2 Gebe-iduar, igar-napiragwadbi be imakdidaenad.
\q1 Igar-innikigwadbi begi nai gusanad.
\q2 Emide, unnila dule-gindakmaladbi begi gudigusmarsunnad.
\q1 
\v 22 Gebeunni be maniyob-gumalanad,
\q2 emidi, durganga-binnideyob be gudnanaed.
\q1 Vino-nuedyob be gumalanad,
\q2 emidi, vino dii-sunnabi-goblegeyob be gudnanaed.
\q1 
\v 23 Be-dummagan-neg-dakmamaid dulegi-gwisgumaladid.
\q2 Amarde, dule-ibmar-atursamalad-e-sordamalad.
\q1 Manigi-dule-binsaed-gaedgi bela na yeer itodamalad,
\q2 dulemar-ega-ibmar-uked unnila abedamalad,
\q1 dule-sergan-sated-ular sunmakdasurmalad,
\q2 siamar-ei-sui-burgwismalad-e-igar gwen bai dakdasurmalad.
\p 
\v 24 A-ulale, Israel-dulemar-e-Bab-Jehová-Bela-Gangued-Nikad, weyob soged:
\q1 “¡Wese ugaksun!
\q2 An-isdarmaladga an igar nudakoed,
\q2 an-isdarmalad an buged imakoed.
\q1 
\v 25 Gannar an-argan an bemarse oyogoed,
\q2 bela be-isgued an elioed,
\q2 degi, bela begi ibmar-isgana-naid an osulogoed.
\q1 
\v 26 Bega dule-igar-nabomalad gebe-iduar-bukusadyob an oambikuoed,
\q2 dule-be-unamalad gebe-iduar-ambikusadyob an oambikuoed.
\q1 Degisoggu, Neggwebur-Innikigwadye be-nugsamaloed,
\q2 Neggwebur-Sogedba-Daedye be-nugsamaloed.”
\b
\q1 
\v 27 Sión-yala, igar-innikigwadba bela-belad bendaklegoed,
\q2 dulemar e-isguedga-bukib-binsamalad igar-napiragwadba, bela-belad bendaklegoed.
\q1 
\v 28 Degi-inigwele, dule-uayasulidamaladdi, isguedgi-gudimaladdi, obelolegoed.
\q2 Ar dule-Bab-Jehová-obandimaladdi, oburgwilegoed.
\q1 
\v 29 Bemar we-sapimarbina nue-sogdimaladgi bemar nue-bingedar itomaloed,
\q2 we-dutugalubina be nue-sogdimaladgi bemar nue-undar bingegumaloed.
\q1 
\v 30 Bemar, sapi-e-gagan-dinguddaeyob gudmaloed,
\q2 dutu-digaled dii-sate-gugwichidyob gudmaloed.
\q1 
\v 31 Dule-gala-ibedi, gagan-durgan-milegeyob naoed,
\q2 e-arbaedi, ilagwen-bergus naoed,
\q1 ebobela soogi-ogalegoed,
\q2 dule gwen soo oginnosulid.
\c 2
\s1 Bab-Jehová bela napneg-naid semaid
\r (Miqueas 4:1-5)
\p 
\v 1 Amoz-machi-Isaías, Judá-yargi, degi, Jerusalén-neggweburgi neg-guoed-daksad, sogsad:
\q1 
\v 2 “Ibagan-bergued-mosale, Bab-Jehováʼse-goled-neg-yala bur yala-sunsogedga sii guoed,
\q2 yala-mulluganba bur nug-dummarba sii guoed,
\q2 dulemar-yar-baid-baidgi-bukmalad bela we-yalase duurmaknonikoed.
\q1 
\v 3 Bukidar neggwebur-bamalad nonimaloed, sognonimaloed: ‘Dagmar, anmar Bab-Jehová-yalase nakwenamar,
\q2 Jacob-e-Bab-Dummadse-goled-negse nakwenamar.
\q1 Ar Bab-Jehová, e-Igar-Maidgi anmar-odurdakoed,
\q2 adi, anmar e-igargi nanadii guegar.’
\q1 Ar ade, Sión-yalagi Bab-Jehová-igar-maid-odurdakleged nodagoed,
\q2 Jerusalénʼgi Bab-Jehová-gayaburba ainidagoed.
\q1 
\v 4 Bab-Jehová, dulemar-yar-baid-baidsik-bukmaladga igar-nabogoed,
\q2 neggwebur-bukibgi-nakulegega guoed.
\q1 Dulemar, e-es-suidmar napa-imuedga obinyemaloed,
\q2 eswar-swiswidikmalad gagan-sikedga gudoed.
\q1 Yar-gwensak, yar-baidbo bar na abin-abin urwosurmalad.
\q2 Bila-onogega bar odurdaklenai guosurmalad.
\q1 
\v 5 Jacob-wagan be dagmar,
\q2 Bab-Jehová-anmar-nidiguega, anmar imakmar.”
\s1 Bab-Jehová dule-san-dummarba-imakmaladga igar-itoged
\q1 
\v 6 Bab-Dummad, be-dulamar be obachad,
\q2 be Jacob-e-wagan obachad.
\q1 Ar be-dulamar-yargi, dad-nakwed-dorgan-niisgwagi-nerguarmaladi, bukidar bukwad.
\q2 Filistea-dulemaryob, yoo-ibmar-guoedgi-sunmakmalad-bukidar nikamalad,
\q2 Be-dulamar, ar dule-bamaladbo igar mesdamalad.
\q2 
\v 7 E-yalagi, mani-sunnabi engus bukwad,
\q2 olo-sunnabi engus bukwad,
\q2 e-ibmar-nuegan gege ebisleged.
\q2 E-yalagine, moli-bukidar nikad,
\q2 e-moli-ur-bila-onomalad gege ebisleged.
\q1 
\v 8 A-ukinbali, e-yala ibmar-bab-dummadyob-imaklemalad-sunnabi engus bukwad,
\q2 ar dulemar, e-argangi-ibmar-sobsamalad-asabin sindigale, sigdimalad,
\q2 e-googi-ibmar-obinnismalad-asabin sindigale sigdimalad.
\q1 
\v 9 Ar weyob, dulemar, e-asabin sindigar-sigedba na nug-wiodimalad,
\q2 ar dulemar, e-asabin na nug-bipii imakdimalad.
\q2 Begi-isgusadi, melle ega be elio.
\b
\q1 
\v 10 ¡Israel-dulemar! Bab-Jehová-e-gangued-sabsur-oyoged-idu be dukumar,
\q2 e-gangued-dobesaila-dakleged-idu be dukumar,
\q1 akwasailagan-ollogan-yaba be dogmar,
\q2 e-idu be napa-yaba dukumar.
\q1 
\v 11 Dule-san-dummarba-imakmalad, sabsur-obingegsalemaloed,
\q2 dule-san-dummarba-imakmalad, san-bipii imaklemaloed.
\q1 A-ibagangi, unnila Bab-Jehová-e-nugbi odummolegoed.
\b
\q1 
\v 12 Bab-Jehová-Bela-Gangued-Nikad ibagwengi nonikoed,
\q2 bela-dulemar-na-san-dummarba-imakmaladgi, dulegi-mesagwar-sunmakmaladgi, gwichigunonikoed,
\q1 dule-na-san-bule-bule-samaladgi, gwichigunonikoed.
\q2 A-e-nugmar bipii imaknonikoed.
\q1 
\v 13 Bela dulemar Líbano-yalagi-urwar-suigan-gwichiyob-san-imakmaladgi, gwichigunonikoed,
\q2 bela urwar-matusurmalad-bukwadyob-san-imakmaladgi, gwichigunonikoed.
\q2 Bela Basán-nebagangi sapi-dummaganyob-san-imakmaladgi, gwichigunonikoed.
\q1 
\v 14 Bela dulemar yala-dummagan-matusurmaladyob-san-imakmaladgi,
\q2 bela yala-mullu-mullugan-nuga-nikamaladyob-san-samaladgi, gwichigunonikoed.
\q1 
\v 15 Bela dulemar neg-suigan-bukwadyob-san-imakmaladgi,
\q2 bela galu-matusur-akwabiidmalad-gandikidba-bukwadyob-san-imakmaladgi, gwichigunonikoed.
\q1 
\v 16 Bela dulemar Tarsis-ulu-dummaganyob-san-imakmaladgi,
\q2 bela ulu-dummagan-yeerdaklemaladyob-san-imakmaladgi, gwichigunonikoed.
\q1 
\v 17 Dule-san-dummarba-imakmalad, nug-bipii gudoed,
\q2 dule-dogdar-obicha-san-imakmalad san-bipii gudoed.
\q1 A-ibagangi, unnila Bab-Jehová-e-nugbi odummolegoed.
\q2 
\v 18 Bab-dummadyob-ibmar-imaklemalad bela-naitinaga obelolegoed.
\b
\q1 
\v 19 Bab-Dummad dulemar-sabsur-odurdaksokalile,
\q2 dulemar Bab-Jehová-e-gangued-sabsur-oyoged-idu,
\q2 e-gangued-dobesaila-dakleged-idu,
\q1 akwasailagan-ollogan-yaba ubodmaloed,
\q2 idu napa-ollogana-yaba dogdemaloed.
\q1 
\v 20 A-ibagine, dulemar e-bab-dummagan-nug-odummogega-orgi-sobsamaladi, manigi-sobsamaladi,
\q2 sapur-nusaga, degi, uksirga midmaloed.
\q1 
\v 21 Bab-Dummad dulemar-sabsur-odurdaksokalile,
\q2 dulemar, Bab-Jehová-e-gangued-sabsur-oyoged-idu,
\q2 e-gangued-dobesaila-dakleged-idu,
\q1 dulemar akwasailagan-ollogana-imbaba ubodmaloed,
\q2 akwasailagan-ollormalad-yaba dogdemaloed.
\q1 
\v 22 Degisoggu, melle be dulegi bensuli-gudii guo.
\q2 Ar duledi, unnila sikwas dula gudiid.
\q2 E-dula-gudiidi, unnila buu naddaed.
\c 3
\s1 Bab-Jehová Judá-dulemar, degi, Jerusalén-dulemar nue-wiogoed
\p 
\v 1 Isaías Jerusalén-dulemarga, degi, Judá-dulemarga sogded:
\q1 “¡Nue bogi be an itomalo!
\q2 Bab-Jehová-Bela-Gangued-Nikadi Jerusalén-neggweburgi, degi, Judá-yargi, bela ibmar-nabir-gullemalad obelogoed:
\q2 Bela masgullemalad, bela gobedmarse-bakale, obelogoed.
\q1 
\v 2 Bab-Jehová, bela we-dulemala, Jerusalén-neggweburgi, degi, Judá-yargi, osulogoed:
\q2 Bela dule-gandikmalad,
\q2 bela dule-bila-onomalad,
\q2 dule-igar-nabomalad,
\q2 e-gayaburba-barsogmalad,
\q2 dule-ibmar-guoedgi-iduakwaa-sunmakmalad,
\q2 girmar-dummagan,
\q2 
\v 3 sorda-bila-onomalad-e-idumalad,
\q2 dule-nug-nikamalad,
\q2 dule-binsaed-dakmalad,
\q2 galagwensuli-ibmar-sobmalad,
\q2 degine, dule-burgwismaladse-gabgin-ibmar-egismalad,
\q3 wemar, bela obelogoed.”
\p 
\v 4 Bab-Jehová soged:
\q1 “An negsemalaga, sapingana urboed.
\q2 Dule-dummaganga-gumalaga, masmala-ibmar-abes-abesdamalad urboed.
\q1 
\v 5 Dulemar na muchub-muchub sabsur-imakdemaloed:
\q2 Dule e-neg-dikarba-maidbo, na abin-abin nagudmaloed.
\q1 Sapingwa, dador-sarsodoed.
\q2 Dule-binsaled, dule-nug-nikadbo na sabsur-imakdemaloed.
\b
\q1 
\v 6 ”Dule-gwensak e-bab-neggi e-gwenadga sogdagoed:
\q2 ‘Ar bedi mor-nued-ise-nudakar be yoisoggu, we-neg-gagalenaid nudake,
\q2 be anmar-dummadga gue.’
\q1 
\v 7 Geb e-gwenaddi e-abin sogdagoed:
\q2 ‘An nersuli.
\q1 Ar an-neggi mas sated, morbela satebalid.
\q2 Melle neggwebur-dummadga-guega be an-imake.’ ”
\b
\q1 
\v 8 Ar Jerusalén-neggwebur nue-bergus mellesiid,
\q2 Judá-yar nue-oitoles naid.
\q1 Ar e-sunmakedi, e-ibmar-imakedi, Bab-Jehováʼgi ise-yolegaled.
\q2 Amarde, Bab-Dummad-e-gangued-yeerdakleged bai daksulid.
\q1 
\v 9 E-ichakwadamaladgi na dukin e-daed barsoged.
\q2 Sodoma-dulemar-isgusadyobi, e-isguedgi bule-bule-gudiid odukusurmalad.
\q1 ¡Emar na dummad-wilesmar!
\q2 Na dukin sabsur-odurdaklegega gunanaid.
\q1 
\v 10 Dule-napira-nanadiidga be sogmalo, “bega ibmar nueganbi guoye.”
\q2 Ar na e-arbadiidgi nue-ibmar nikuoed.
\q1 
\v 11 ¡Dule-isgana, be nue-wiles!
\q2 Ar bega ibmar-nuegan guosulid,
\q2 ar be-arbasadgi na be odurdaklegoed.
\p 
\v 12 Bab-Jehová sogbalid:
\q1 “¡An-dulamar, be nue-wilesmar!
\q2 Sapinganse mesagwar-gudimalad,
\q2 Omegan ega dummadga-negdakmamaid.
\q1 ¡An-dulamar, be nue-wilesmar!
\q2 Ar dule-be-idumaladi begi dododimalad,
\q2 ar igar-isganaba be-nidimalad.”
\b
\q1 
\v 13 Bab-Jehová, e-dulemarga-igar-nabogega, gwichigudasokalid.
\q2 Dulemar-sabsur-odurdakega, gwichigudasokalid.
\q1 
\v 14 Bab-Jehová, girmar-dummagangi,
\q2 degi, dummagan-negsemamaidgi, gwichigudasokalid.
\q1 Bab-Dummad ega weyob sognonikoed: “Ar bemar uva-nainu-naid bela obelosmalad.
\q2 Be-negyagi dule-wilemalad-ibe-be-ibmar-atursasmalad bukwad.
\q1 
\v 15 ¿Doa bega sogsa, an-dulamar mesagwar imakmaloye?
\q2 ¿Doa bega sogsa, dule-wilesagwar-gudimalad be wiomaloye?”
\s1 Bab-Dummad, omegan-Sión-yalaginmalad sabsur-odurdakoed
\p 
\v 16 Bab-Jehová weyob sogbalid:
\q1 “Omegan-Sión-yalaginmalad san-bule-bule-imakmaladi, emargi-obine-itogedba bule-bule nanamalad.
\q2 A-omegan dule-mesagwale dakdaed.
\q1 San-bule-bule-imakedba, e-maligi ibmar-nanaid-ogolegala, yamo nag-bana-bana nadapdamalad,
\q2 adi, e-ibmar-maligi-naid-goled itomalagar.
\q1 
\v 17 A-ulale, ani, omegan-Sión-yalaginmalad-e-nonogi, boni-yaa-dummagan yaisur-nikuega imakoed,
\q2 an bela amar-nono swana imakoed.”
\p 
\v 18 A-ibagine, Bab-Jehová, we-ibmarmar osulogoed:
\q2 Maligi-ibmar-nagumalad,
\q2 bebegi-ibmar-nasiklemalad,
\q2 morgi-ibmar-nasiklemalad.
\q2 
\v 19 Bela dukargi-ibmar-nasiklemalad,
\q2 sakwagi-ibmar-nasiklemalad,
\q2 muswe-wagar-odukumalad.
\q2 
\v 20 Dunwemar,
\q2 maligi-ordubyob-ibmar-nasiklemalad,
\q2 saderba-mordub-atillemalad.
\q2 Ina-wawagan-nuegan,
\q2 olargan-matar-dummagan,
\q2 
\v 21 olarganmar,
\q2 olasumar.
\q2 
\v 22 Ibagi-mor-yoleged-gargerbamalad,
\q2 mor-dummagan,
\q2 mor-suigan,
\q2 mor-sakwa-metegana.
\q2 
\v 23 Isbe-wagar-dakmalad,
\q2 lino-mor-nued,
\q2 mor-obipirmakar-nonogi-silemalad,
\q2 degi, dukarba-biar-mor-nasiklemalad.
\q3 Bela e-ibe we-ibmarmar osulolegoed.
\b
\q1 
\v 24 A-ibagine, ina-wawadikidbi-yapannedi, nunu-yapanne naoed.
\q2 Saderba-mordub-atillemalad-muchubbi, saderba gasdub nasikdemaloed.
\q1 Ise-gwialed-muchubbi, sailagia-sate gumaloed.
\q2 Ibagi-mor-gargerbamalad-yoleged-muchubbi, wilegedba mor-yaara-dakle yodmaloed.
\q2 Wagar-yeerdakleged-muchubbi, bingedar-dakle itodmaloed.
\q1 
\v 25 Be-machergan es-suidgi oburgwiledmaloed.
\q2 Be-dule-bulegan bila-onolenaidgi oburgwiledmaloed.
\q1 
\v 26 Bela dulemar ogormakdemaloed,
\q2 burgwed-ibagi-mor-yoleged yodmaloed.
\q2 Neggwebur bela olloo dakle nadoed.
\c 4
\q1 
\v 1 A-ibagangine, omegan-walagugle (7) machered-wargwengi alamakdamaloed,
\q2 ega sogdamaloed: “Anmar anbo-nikue,
\q1 ar be an-nikguele, anmar na dukin mas amioed,
\q2 anmar na dukin mor bakbaloed,
\q1 unnila anbo-nikubi anmar be-abeged.
\q2 Adi, anmar melle bingegudii gumalagar.”
\s1 Jerusalén-neggwebur yoedse ganguedba-yeerdaklege guoed
\p 
\v 2 A-ibagangine, Bab-Jehová, sapi-siklesad gannar ainiega imakoed. We-sapi-gannar-ainioedi, yeerdaklegedga guoed, degi, gandikidba-yeerdaklegedga gubaloed. Ibmar-durbamar-welemaloedi, Israel-dulemar-besmalad-e-nug-odummogega guoed, degi, e-nug-ogannogega gubaloed.
\p 
\v 3 Degine, Sión-yalagi napi-dula-bemaloedi, Jerusalén-neggweburgi napi-dula-bukumaloedi, bilegoed: Dule-islidikidmarye, degi, bela Jerusalénʼgi-gudimalad-e-nug-narmakar-mamaidse-bakar, deyob bilegoed.
\p 
\v 4 Bab-Dummad, sabsur-odurdakleged-igar mesnonikile, degi, geb sabsur-odurdakdele, omegan-Sión-yalaginmalad-e-isgued osulogoed, degi, Jerusalén-dulemar-ablis-eosmalad-e-isgued elioed.
\p 
\v 5 Geb degine, Bab-Jehová, ibgine, Sión-yalagi, dulemar-ambikuoedgi mogir-gudure nasikoed. Mutikdi, ibegwar soo-gwabunye-gwichi imaknonikoed. Bab-Jehová-e-gangued-yeerdaklegedi atued-dummadyob-dakle bela neg-gasa naguoed.
\v 6 Adi, ibgine, dad-ibeler-uedikgued-idu negsichii-imakedyob naguoed. Dii-wiedgi, degi, burwa-dummad-noedgi ega dukuedga naguoed.
\c 5
\s1 Uva-nainugi burbar-namakleged
\q1 
\v 1 An-ai-nued-nuggi an namakoed,
\q2 e-uva-nainugi an namakoed.
\q1 An-ai-nued-e-uva napa-nuedgi digar naigusad.
\q2 
\v 2 Na napa nudaksagusad, akwa-murugan obelosgusad.
\q2 Uva-dub-sailagan-nuegan digsagusad.
\q1 Nainu-abargine neg-suid sobsagusad,
\q2 uva-egured-galu sobsagusbalid.
\q1 Uva-san-nuegan-ega-sanmaked abedii gusanad,
\q2 aka ega uva-soledbi sanmaksad.
\p 
\v 3 Bab-Jehová soged:
\q1 “Judá-dulemar, Jerusalén-dulemar, be anga sogmardo.
\q2 Emide, uva-soledbi-sanmaksadi, ¿wede doagine?
\q2 ¿Angine? ¿Uva-nainugine?
\q1 
\v 4 ¿Ar ibu-ibmar an-uva-nainuga an imaksasuli?
\q2 ¿Ibu-ibmar bar an ega imakosunna?
\q1 Ar uva-san-nuegan-anga-sanmaked an abesanad.
\q2 Ar degite, ¿ibiga uva-san-soled sanmaksasunna?
\q1 
\v 5 An bega sogmalodo, igi an-uva-nainu an imakoe:
\q2 An e-ibe galu-emakaled earoed, adi, bela berguegar.
\q1 An e-galu-matusulid e-ibe earbaloed,
\q2 adi, bela egi annalegegar.
\q1 
\v 6 Bela swanga-nai an imakoed,
\q2 bar uva-dub diglegosulid,
\q2 bar nuekwaa emilegosulid.
\q1 Ikomarbi, degi, gagan-ikobimaladbi ainidagoed,
\q2 bar mogirmar egi dii-owiega an imakosulid.”
\q1 
\v 7 Israel-dulemar Bab-Jehová-Bela-Gangued-Nikad-e-uva-nainu gued.
\q2 Judá-machergandi ega uva-yeerdakle-digaledga gued.
\q1 Bab-Jehová Israel-dulemar ega igar-innikigwad-imaked edarbediinad,
\q2 emide dakalid, unnila dule-ablis-eodimaladbi gudimala.
\q1 Bab-Jehová, ega igar-napiragwadba-nanaed edarbediinad,
\q2 emide dakalid, unnila suli-suli-itogedba binnasuli gormakdimala.\fig Uva-nainuga napa-nudaksad, ega neg-suid sobsad, uva-egured-galu sobsabalid. (Isaías 5:1-2) |src="LB00103B.TIF" size="col" ref="Isaías 5:7"\fig*
\s1 Dule-wiodimalad ukabsalesad
\q1 
\v 8 Dulemar emar-idu neg-sobe-sobe-gudimalad, ¡dule-wilesmar!
\q2 Emar-ibe nainu-sue-sue-gudimalad, ¡be duledar-wilesmar!
\q1 Dule-bamaladga wis napaneg-ollogwad nasiksulid.
\q2 Na wargwen we-neggweburgi-gudimaladyob itoged.
\q1 
\v 9 Bab-Jehová-Bela-Gangued-Nikad weyob an-uayagwar anga ibmar-sogsad:
\q2 “Negamar-bukidara obelolegoed.
\q2 Neg-dummagangi, neg-yeerdaklegedgi, dule gwen megosulid.
\q1 
\v 10 Uva-nainu-dummagan sogapaa naidi,
\q2 unnila bari-gwagwen wis vino egi amilegoed.
\q1 Ibmar-gwag galón-gwaambe-diglegoedgi (10),
\q2 unnila galón-gwagwen wis egi welegoed.”
\b
\q1 
\v 11 Dulemar wakudaryalaba-mumguega-gwisguardamaladi, ¡duledar-wilesmar!
\q2 Mumgusii mutikguddamaladi, ¡be duledar-wilesmar!
\q1 
\v 12 Be-iba-onomaladgi vino-bukidar nikadamalad,
\q2 gar-arpaʼmar ogorleddaed,
\q2 degi, gar-liraʼmar, damborʼmar,
\q2 degine, gar-flautaʼmar ogorleddaed.
\q1 Degi-inigwele, bemar Bab-Jehová-ibmar-imaksadgindi, binsadasurmalad,
\q2 e-ibmar-saedginbela bar binsadasurbalid.
\q1 
\v 13 An-dulamar an-itobisurmalad-ulale, gales seledmaloed.
\q2 E-dule-nuga-nikamalad mas-gunsulidba burgwidmaloed,
\q2 dule-bukidar gobsulidba burgwidmaloed.
\q1 
\v 14 A-ulale, burgwarmalad-meged-galu-e-yaa sabsur-argas maid.
\q2 Agine, dule-nuga-nikamalad, e-mumguedgi-yeer-itodimalad, neg-uanse doledmaloed.
\q2 Dule-binsarmalad, e-isguedgi-wergudimaladba neg-uanse doledmaloed.
\q1 
\v 15 Dulemar sabsur-ibitomaloed, emarse ibmarbina-wiledii gudmaloed.
\q2 Dule-san-dummarba-imakdimalad, binge itodmaloed.
\q1 
\v 16 Ar Bab-Jehová-Bela-Gangued-Nikadi igar-innikigwadba e-nug ogannolegoed,
\q2 Bab-Dummad-Isligwaled igar-napiragwadba na san-swilidikid oyogoed.
\q1 
\v 17 Sibad-wawaad-senigana, e-nainu-sunnadyobi, egi gagan-ara-aramalad-madii gudmaloed.
\q2 Sibad-omemardi, dule-mani-ibmala-e-neg-ollo-ollo-bukmaladgi gagan-madii gudmaloed.
\b
\q1 
\v 18 Dule isguedse-ebipiledimalad, ¡duledar-wilesmarsun!
\q2 Dule urdubgi-isgued-ebipidimalayob-gudidiid, ¡be dule-wilesmar!
\q1 
\v 19 Na sogdimalad: “Bab-Dummad gwae dagye.
\q2 Gwae ibmar imakdaye, adi, anmar e-ibmar-imakoed dakegarye.
\q1 Israel-dulemar-e-Bab-Isligwaled e-ibmar-imakbied gwae imakdaye,
\q2 adi, anmar e-ibmar-imakoed wisguegarye.”
\q1 Deyob-sogdidiid, ¡duledar-wilesmarsun!
\b
\q1 
\v 20 Dulemar, igar-isgana igar-nueganga-imakdidiidi, ¡duledar-wilesmar!
\q2 Dulemar, igar-nuegan igar-isganaga-imakdimaladi, ¡dule-wilesmar!
\q1 Dulemar, negsichid neg-meegwadga-imakdimaladi, ¡duledar-wilesmar!
\q2 Neg-meegwaddi, negsichidga-imakdimaladi, ¡dule-wilesmar!
\q1 Dulemar, ibmar-gagbireged ochigwadga-imakdimaladi, ¡duledar-wilesmar!
\q2 Dulemar, ibmar-ochigwad gagbiregedga-imakdimaladi, ¡dule-wilesmar!
\b
\q1 
\v 21 Dule, binsaed-ibedga na san-sadimaladi, ¡duledar-wilesmar!
\q2 Dule, nue-ibmar-wisidga na san-imakdimaladi, ¡dule-wilesmar!
\b
\q1 
\v 22 Bemar vino-gobedsik-bulegan-gudimaladi, ¡be duledar-wilesmar!
\q2 Bemar inna-gagbid-sobedsik-bulegan-sogdimaladi, ¡dule-wilesmar!
\q1 
\v 23 Bemar dule-baiganse-manigi-baklegar, dule-ibmar-isgana-imaksad-galessiid-onodamaladi, ¡duledar-wilesmar!
\q2 Bemar dule-ibmar-oakalossulid-obanagwar-imakdimaladi, ¡dule-wilesmar!
\q1 
\v 24 A-ulale, igi-soo-ditismaked gagan-ogumakdedae,
\q2 igi-gagan-dinnagwad soo-abin gummakdedae,
\q2 deyobi, bemar gummakmaloed.
\q1 Igi sapi-mali napa-urba-nunguddae,
\q2 igi e-dutu, ukub-miledeyob-mileddae,
\q2 deyob bemar berguoed.
\b
\q1 Ar bemar, Bab-Jehová-Bela-Gangued-Nikad-Maid-e-Igar obatemalad,
\q2 Israel-e-Bab-Jehová-Isligwaled-e-gayaburba isdar-itodmalad.
\q1 
\v 25 A-ulale, Bab-Jehová e-dulemarse sabsur-urwed,
\q2 a-ulale, sabsur-odurdaked, yalagan ese giglimaked.
\q2 Muigan, durgan-milegeyob, galimbaba omileded.
\b
\q1 Deyob-imaksa-inigwele, Bab-Jehová, amba sae-itomaid,
\q2 amba dulemar-sabsur-odurdakmaid.
\b
\q1 
\v 26 Bab-Jehováʼdi, dulemar-yar-baid-baidgi-dikasur-bukwadse-golegala, bander onakoed.
\q2 Bela yar-naidgi-bukwamaladse wigooed,
\q2 we-dulemar gwae-gwae abarmakar-abarmakar nonimaloed.
\q1 
\v 27 We-dulemar, dutusurmalad, gwen yeguosurmalad.
\q2 Unnila, guagwar gudii gumaloed, gwen gabbie itogosurmalad.
\q1 E-musirba-mor-atinnaimalad gwen ei achikosulid.
\q2 Nag-uka-e-dubmar e-ibe gwen itirosurbalid.
\q1 
\v 28 E-sigumar ise-swiswidikidbioed,
\q2 e-warsimar bela gachii ganikidbimaloed.
\q1 E-molimar-e-sapat akwayobi dutusulidbioed,
\q2 e-moli-ur-bila-onomalad-e-yandamar burwa-bipirmakaledyobi guoed.
\q1 
\v 29 Sorda-bila-onomalad-e-goledi, achumigur-nono-wawaadyob goledbioed.
\q2 Achumigur-nono-wawaad-e-mimmigan-uurmakeyobmaloed,
\q1 e-nugar ogotemaloed.
\q2 Dule ese-galesale, dule gwen egi suosulid.
\q1 
\v 30 A-ibagangine, we-dulemar Israel-dulemargi demar-dummad-arwemaiyobi gwichigunonikoed.
\q2 Dule, Israel-yar-naid-dakalile, bela negsichidbi-nai dakdagoed,
\q2 dad-ibeler-idu mogir-sichid nai guoed.
\c 6
\ms2 1b. Emanuelʼgi sunmaklenaid
\mr (6:1–12:6)
\s1 Isaías, Bab-Dummad-ologanagi-sii daksad
\p 
\v 1 Rey-Uzías-burgwisad-birgagine, ani Isaías, Bab-Dummad ologana-biriginedgi-sii an daksad. E-mola-duku ese-goled-neggi bela batenai an daksad.
\v 2 E-birgine, dule-nibnegginmalad-Serafínʼye-nugmalad gukunanai an daksad. A-dulemar sakan-nergwa (6) nikamaladbiid: Sakan-warbogwadgi e-wagar odukunanaid, sakan-warbogwad-baidgine, e-malimar odukunanaibalid, degine, sakan-warbogwad-baidgindi, gukunanaid.
\v 3 Muchub-muchubbi, binnasuli sognanaid:
\q1 “Bab-Jehová-Bela-Gangued-Nikadi, Bab-Jehová-Isligwaledid, Isligwaledid, Isligwaledid.
\q2 Bela napneggi e-gangued-yeerdaklegedi neg-gasa naid.”
\p 
\v 4 Serafínʼmar-binnasur-gornanaidbali, Bab-Dummadse-goled-neg-yawagak-bargamalad e-sailamarse-bakale, giglimakded, geb Bab-Dummadse-goled-neg bela waa daasa sigisad.
\v 5 Geb an binnasuli goted:
\q1 “¡An duledar-wiles! ¡An bergussun!
\q2 Ar ande ibmar-isganabi-sogdiid-duled,
\q2 dulemar-ibmar-isganabi-sogdimalad-abargi an gudiid.
\q1 Emide, an Rey-daksad,
\q2 Bab-Jehová-Bela-Gangued-Nikad an daksad.”
\s1 Isaíasʼse-gorlesad
\p 
\v 6 Degidgine, Serafín-gwensak ansik gukualid. Bab-Dummadga-ibmar-ogumakar-ukleged-ailagi soo-gasiidgi soo-weed-esgorogi sogun-ara-arad-wesadi sedanikid.
\v 7 Geb a-sogungine, an-gakuli ebunonikid, agi anga sogded:
\q1 “Be dake, we-sogun-ara-arad be-gakuli-ebusadi, bega isgued elinonisunnad.
\q2 Bab-Dummadgi be isgudiidi, emide isgussulidyobi be daklenadsunnad.”
\p 
\v 8 Geb degidgine, Bab-Jehová-e-sunmaked an itosad. Weyob soge an itosad:
\q1 —¿An doa-dule barmidoe?
\q2 ¿Doa anmar-anar naoe?
\p Geb abin an sogded:
\q1 —Ani be an-barmide,
\q2 ani an naoe.
\p 
\v 9 Geb Bab-Jehová anga sogded:
\q1 —Be nae, we-dulemarga be sogna:
\b
\q1 ” ‘Be ibmar nue-itomalo-inigwele, akusunna be itomaloed.
\q2 Be ibmar nue-dakmalo-inigwele, akusunna be dakmaloed.’
\q1 
\v 10 We-dulemar-e-gwage dutusuli be imako,
\q2 akusunna ibmar-itogega be imako,
\q2 akusunna ibmar-dakega be imako.
\q1 Degisulile, e-ibyagwale ibmar-dakdoed,
\q2 e-uayagwale ibmar-itodoed,
\q1 degi, e-gwagegi magar-ibmar-itodoed,
\q2 e-isguedga bukib binsadmaloed.
\q2 Degidbali, nudake an dakledagoed.”
\p 
\v 11 Geb an ese egichided:
\q1 —Bab-Jehová, ¿sanagwadse an be-nuggi sunmakdii gusunnoe?
\p Bab-Jehová anga sogded:
\q1 —Bela neggweburmar-obelolegedse be an-nuggi sunmakdii guoed.
\q2 Bela negmar-ollo-ollo-ambikuedse be angi sunmakdii guoed.
\q1 Dulemar a-neggweburmargi-bar-gudii-guosulidse be an-nuggi sunmakdii guoed.
\q2 Nainumarbela-swiri-naguedse be angi sunmakdii guoed.
\q1 
\v 12 An bela-dulemar-e-yalagi dikasuli ononnogoedse be angi sunmakdii guoed.
\q2 Bela e-yala-olloo-naguedse be an-nuggi sunmakdii guoed.
\q1 
\v 13 Ar dulemar e-dulataledgi (100) amba e-ambe (10) besale,
\q2 bela amba amar berguoed.
\q1 Ar sapi-emisgwa-siklesad-e-sailabi gannaa-siidaedyobi wis bemaloed.
\q2 Geb we-dulemar-bemaloedi neggwebur-islidikidga guoed.
\c 7
\s1 Emanuel-danikoed-e-wilubgangi sunmaklenaid
\p 
\v 1 Deunni, Rey-Acaz Judá-yargi negsemaid. Acazʼde Jotam-e-machid, degi, Uzías-e-wagwabalid. A-we-reymar-warbogwad Jerusalén-neggwebur sussurgusmalad.
\p 
\v 2 Weyob Rey-David-negga-gusadse gayaburba nonikid: Siria-dulemar Efraín-dulemarbo atosmarye.
\p Degi, Rey-Acaz nue-dobe itonaded. E-neggweburginmalad bela dobedba wawanmakdemalad. Igi-sapimar burwaba banamakgwisdae, ayobi wawanmakdemalad.
\p 
\v 3 Geb degi, Bab-Jehová Isaíasʼga sogded: “Be-machi-Sear-Jasubʼbo, Acaz-abinguega be nae. Bia dii-gammu-maid dii-wilad-dummad-siid-akar dii-sedanidae, a-bergunaid-nagaba be abinguoed. We-dii-gammude, mor-odidued-neg-igar-nalemaidsik maid.
\v 4 Acazʼga be sogo:
\p ” ‘¡Nue salakalo! ¡Melle be dobguo! Siria-rey-Rezín-sabsur-urwed-abin, melle be gwayo. Remalías-machi-Peka-abin, melle be gwayebalo. We-dulemar-warbogwad-abin melle be gwage-nunmak-itogo. We-reymar-warbogwad unnila, igi soogi-waa-ainakwialir yog berguar-naddae, ayobi gumalad.’
\p 
\v 5 ”Acazʼga be sogbalo: ‘Efraín-dulemar Remalías-machi-Pekaʼmala, Siria-dulemarbo, bemar-wiogega na atosmalad.
\v 6 Ar ade, sogsamalad: Anmar Judá-yalagi gwisgunae, anmar e-dulemar ogwayenae, anmar we-yala e-ibe suoed, geb anmar agi Tabeel-machi reyga omesoed.’
\p 
\v 7 ”A-ukinbali, Acazʼga be sogbalo: ‘Ani Bab-Jehová-Bela-Gangued-Nikad weyob sogbarye:
\q1 We-ibmar-deyob-sogmaladi, bipisaale guosurye.
\q2 
\v 8 Ar Damasco-neggweburbi Siria-yala-e-nonoga wis siid,
\q2 ar Rezínʼye-nugadi Damasco-neggwebur-e-reyga wis maid.
\q1 Birga-dulapaa-gakatarsega (65), Efraín-yala berguoed,
\q2 bar neggweburga sii guosulid.
\q1 
\v 9 Samaria-neggweburbi Efraín-yala-e-nonoga wis-simogad,
\q2 Remalías-machidi, Samaria-neggwebur-e-reyga wis-maimogad.
\q1 Ar bemar angi benmalale, bemar wegi ambikuosurmalad.’ ”
\s1 Mesías-gwalulegoed-e-wilub
\p 
\v 10 Bab-Jehová, Acazʼga sogdebalid:
\p 
\v 11 —An be-Bab-Dummad-Jehová-gued. Anse wilubga-guega ibmar-gegerdakleged-imaked be egise. Sunna bega ibmar-gegerdakleged nibneg-birigi imakodibe, bela-bela napa-uluse imakodibe.
\p 
\v 12 Acaz abin-sogded:
\p —Bab-Jehová, an be-wilubdakosulid. An bese bipisaale ibmar egisosulid.
\p 
\v 13 Geb degi, Isaías sogded: “Emisgine, bemar, David-wagan, nue be an-itomalo. ¿Ar be dulemar-ourwed nubin be itosursi? Ar emide be, deyob an-Bab-Dummad-ourwebimarmogad.
\v 14 A-ulale, Bab-Jehová-sunnagwad ibmar-guoed-e-wilub oyogoed: Yagwa-wargwen gurgin-nika guoed, degi, goe nikunonikoed. Emanuelʼye onugsaoed.
\v 15 Goe achanisbi madii guoed, moli-nunis-ollikwagwadbi madii gubaloed. Mag-neg-itogusadse we-ibmarmar indakoed.
\v 16 Ar mimmi-mag-neg-itoged-iduale, igid ibmar-nuedi, igid-ibmar-ichakwabali, reymar-warbogwad-ese-be-gwayediidi, e-yalamar bela ibitomaloed.”
\s1 Judá-yargi sabsur-ubononikoedgi sunmaklenaid
\p 
\v 17 Isaías, Acazʼga sogbalid: “Bab-Jehová, Judá-yargine Asiria-e-rey barmidagoed. Begine, be-dulemargine, degi, be-wagangine, ibagan-bulegan barmidagoed. Efraín-yala, Judá-yalagi-bangusad-akale, a-ibmarmar-gwen-dakledsulidi, begi barmidagoed.”
\p 
\v 18 A-ibagangine, Bab-Jehová, Egipto-sorda-diwar-dukuba-dikasur-bukmaladse wigooed. Amala gukurmaryobi bemarse barmidagoed. Degi, Asiria-yalagi-bukmaladse wigobaloed. Bemarse burmaryobi barmidagoed.
\v 19 Amar bela nonimaloed, ibe-dummagan-imbaganba ambikunonimaloed, akwasaila-ollogana-yaba ubononimaloed, gagan-moodo-ikoyaisur-naidgi bukunonimaloed, molimar-dii-gobmalad-nagaba ambikunonimaloed.
\p 
\v 20 A-ibagangine, Bab-Jehová, Asiria-e-reyga Éufrates-diwar-obakar-Israel-dulemar-bukmalad-sabsur-odurdakega urmakoed. Bela e-sailagia swanga imaklegoed, bela e-sigamala, ei immilegoed, alu-sigase-bakale ei immilegoed. Bela-bela-wilemalaga imaklegoed.
\p 
\v 21 A-ibagangine, dule-wargwen moli-bebe-nikad-bunolo-wargwen wis akwedii guoed, sibad-ome-warbo wis akwedii gubaloed.
\v 22 We-ibmar-durgan ega nunis-bukidar nika guoed, e-nunis-ollikwagwad-madii guoed. Dule-we-yargi-bemaloedi, unnitiba moli-nunis-ollikwagwad achanisba madii gumaloed.
\p 
\v 23 A-ibaganginbali, uva-nainugi uva-miligwen-digar-naigusadi (1,000), mani-sibu-miligwen-gargegus-gusadi, emidi ikomar-nainuga guoed, degi, gagan-ikobimalad-nainuga guoed.
\v 24 Bela yala iko-sunnabi naguoed. A-sapurgi, warsibi-annika nanadii gumaloed, sigubi-annika nanadii gumaloed.
\v 25 Gebe-iduale, a-yala-mullugangi memed-weregedgi ibmar-nabir digledaenad. Emisgindi, ikomar-dobedba, gagan-ikomar-dobedba, bar dule ese warmakosulid. Unnila, we-gaganmar, moli-bebe-nikad-e-masga, sibad-wawaadmar-e-masga guoed.
\c 8
\s1 Bab-Jehová-dobekwaa be nanamar
\p 
\v 1 Bab-Jehová anga sogsad: “Urgo-matar-dummad be sue, agine be nug-narmako, nuekwaa magar-daklege be narmako. ‘Maher-Salal-Hasbazʼye be narmako.’
\v 2 Degine, dule-irwa-anse-goled-Urías, degi, Jeberequías-machi-Zacarías, be-barsoged-innikigwadga-gumalaga an bega amioed.”
\p 
\v 3 Geb agine, an Bab-gayaburba-barsoged-bundorse an gochad, geb gurgin-nika gunonikid, geb susugwa ega uklenonikid. Geb degi, Bab-Jehová anga sogded: “Maher-Salal-Hasbazʼye be onugsae.
\v 4 Ar mimmi nanaye-gordagoed-iduale, babaye-gordagoed-iduale, bela Damasco-neggwebur-e-ibmar-nuegan-nikadi Asiria-e-reyse sulegoed. Degi, Samaria-neggwebur-ibe ibmar-nuegan seledbaloed.”
\p 
\v 5 Bab-Jehová gannar anga sogdebalid:
\q1 
\v 6 “We-Judá-neggwebur, Siloé-dii-binnalee-aryomaidgi bangudmalad,
\q2 bur Rezín-dobee nanadmalad,
\q2 bur Remalías-machi-dobee gudmalad.
\q1 
\v 7 A-ulale, Bab-Dummadi, we-dulemargi Éufrates-diwala-dummad onosokalid:
\q2 Ar Asiria-e-rey, bela e-garganguedba, Judá-yalagi-yolegega barmidagoed.
\q1 Bela e-diangan-mamaid odogoed,
\q2 bela e-dii-gakamar akudaklege imakoed.
\q1 
\v 8 Judá-yalase, bela swada-dogoed,
\q2 dii dukarba-engus naguoed.
\q1 ¡Emanuel! Be-yala-naidgi, Asiria-sordamar dognonikoed.
\q2 We-Asiria-rey sulubagi-sakan-nalla-napase-aidedanidaedyobi, begi dognonikoed.”
\b
\q1 
\v 9 Dulemar-yar-baid-baidgi-bukmalad, bela-yar-baid-baidgi-dikasur-bukmalad,
\q2 we-ibmar-an-sogoedi nue be itomalo:
\q1 Aisaar bemar bila-onodamaloenad,
\q2 degi-inigwele, be bergumaloed.
\q1 Aisaar be guagwar bila-onoged-iduar bukumaloenad,
\q2 degi-inigwele, bemar girgumaloed.
\q1 Aisaar be guagwar bila-onoged-iduar bukumaloenad,
\q2 Degi-inigwele, bemar nue-ibitomaloed.
\q1 
\v 10 Be igarmar-amimalo-inigwele, bega igarga guosurmalad.
\q2 Aisaar be ibmargi sunmakmalo-inigwele, bega igarga guosurmalad.
\q2 Ar ade, Bab-Dummad anmarba gudiid.
\s1 Be Bab-Dummad-dobegwa nanae
\p 
\v 11 Bab-Jehová weyobi anga sabsur ibmar sogsad, iduakwaa anga sogsad, melle we-dulemar-daedba be nanaoye. Weyob anga sogsad:
\q1 
\v 12 “Melle bemar we-dulemar-sogedyob be sogmalo, we angi gwisgunaye.
\q2 Ar bela ibmarmar-guedi, egi gwisgunaiye sogdamalad.
\q1 Melle be we-dulemar-ibmar-dobedi, dobgumalo,
\q2 melle be gwayebalo.
\q1 
\v 13 Unnila be ani Bab-Jehová-Bela-Gangued-Nikadbi dobguo,
\q2 bur be anga islidik nanamalo.
\q1 Unnila an-nugbi be odummomalo,
\q2 unnila anbi be dobgumalo.
\q1 
\v 14 Ani an bemar-neg-islidikidga guoed.
\q2 Degi-inigwele, Israel-dulemar-sogabogwadga akwasailaga an guoed,
\q1 adi, agi goo-warmakmalagar.
\q2 A-akwa-dummad, dule-omukuedga guoed.
\q1 Jerusalén-dulemar-idu sakinaiyobi an naguoed,
\q2 amar-idu galu-ibmar-gaed-siidyob an guoed.
\q1 
\v 15 Bukidar goo-warmakmaloed,
\q2 bukidar aimukumaloed,
\q1 bukidar wilemaloed.
\q2 Sakigi-galesayobi, ibmar-gaed-galugi-galesayobi, gales nagumaloed.”
\p 
\v 16 Geb degi, Isaías, eba-nanaimaladga sogded:
\q1 “An bemarga ibmar-sogsamaladi, gwagegi be sedii imakmalo.
\q2 An be-odurdaksamalad, melle be sogmalo.
\b
\q1 
\v 17 ”Ar Bab-Jehová, urwedba Jacob-wagan-idu wagar-aibiris sigisad.
\q2 Bab-Jehováʼgi an benguosulid,
\q2 ar an wisid, an egi bendaklegoe.”
\p 
\v 18 Be an-dakmalana, emisgindi wegi an Bab-Jehová-anga-mimmigan-uksadmala an gudiid. Anmar, Israel-yargi, Bab-Jehová-Bela-Gangued-Nikad-Sión-yalagi-maidga ibmar-guoed-e-wilubga gumalad, iduakwaa-ibagan-guoed-sogedga anmar ega gumalad.
\p 
\v 19 Dule bemarga sokarmalale: “Dule-ibmar-e-burbagan-wismaladse be ibmar-wilubagan egisnamarye, yoedse-ibmar-guoed-barsogmaladse be ibmar-wilubagan egisnamarye.” Weyob be sogo: “¿Ar dulemar e-bab-dummaganse geg idakmarsogeye? ¿Ar dulemar dule-burgwarmaladse geg idakmarsogeye?”
\p 
\v 20 An bemarga sogdo: “Bab-Dummad-Igar-Mesisadgi bur be nanamalo, e-ibmar-sogsadgi bur be binsamalo.” Ar dule, we-igarmargi-nanasulile, igar-napiragwad amiosulid.
\p 
\v 21 Bemar, napneggi suli-suli-itoarmalale, ukudmaada-itoarmalale, be uludamaloed. Niba atakgwichi, be-reygi be gwisgudmaloed, Bab-Dummadgi be ukabsaar sunmakdemaloed.
\v 22 Be napneg-dakdagogua, unnila boniganbi-nai be dakdemaloed, negsichidbi-nai be dakdemaloed. Bemar negasichidginbi-gudii gumaloed.
\c 9
\s1 Mimmi-gwensak anmarga gwalules
\p 
\v 1 We-ibmarmar-guoed-sorbali, dule-suli-suli-itodigusadga bar negsichid naguosulid. Epennegwa, Bab-Dummad, Zabulón-dulemar-yala sabsur-odurdaksa gusad, Neftalí-dulemar-yala sabsur-odurdaksa gusbalid. We-yarmar Galilea-yargi bukwamalad. Yoedsega, Galilea-yargi nued binsanonikoed, e-nug-dummarbaa imakoed. Galilea-yala, Jordán-diwarsik, degi, demarse-nalemaidsik naid. A-yalagi, dule-Bab-wissurmalad bukwad.
\q1 
\v 2 Dulemar-negsichidgi-gudigusmaladi, neg-meegwad daksamalad.
\q2 Negsichidgi-bukwagusmaladga, neg mee gunonikid.
\q1 
\v 3 Bab-Jehová, bee be, dulemar-omelosad,
\q2 bee be, bela-bela-weligwar-itogega imaksad.
\q1 Igi dule ibmar-gwag-weenaile, weligwar itodae,
\q2 deyobi, be-asabinni weligwale na itomaloed.
\q1 Igi dule ibmar-nuegan-miminaile, weligwar itodae,
\q2 deyobi, be-asabinni weligwale na itomaloed.
\q1 
\v 4 Bee be, dulemar-wilebukwagusad ollor-imaksad,
\q2 sabsur-imaklebukwadgi be bendaksad,
\q2 mesagwar-imaklebukwadgi be ollor-imaksad.
\q1 Ar igi be, Madián-dulemar-obelosgusa,
\q2 deyobi, be e-isdarmalad imaksad.
\q1 
\v 5 Bila-onolegedgi-sapat-yolesmaladi, degi, bela mor-ablisbi-gusmaladi, soo-yagi ogumaklegoed,
\q2 sooga bela binyoed.
\q1 
\v 6 Ar susugwa-gwensak anmarga gwalulesad,
\q2 mimmi-gwensak anmarga uklesad.
\q1 A-machi gandikidba negseoed,
\q2 weyob nugguoed:
\q2 Binsaed-Daked-Wilub-Obichadye,
\q2 Bab-Dummad-Bela-Gangued-Nikadye,
\q2 Bab-Degisadeguadye,
\q2 Neg-Bogidikid-E-Dummadye, nugguoed.
\q1 
\v 7 E-gangued bela nasguoed,
\q2 e-neg-bogidik-seoed bela nasguoed, gwen berguosulid.
\q1 David-ologangi dummadga sigoed.
\q2 E-yalagi dummadga negseoed.
\q1 E-negseoedi, igar-napiragwadba yar-seoed,
\q2 innikigwadba negseoed,
\q1 emi-ibase, degisadegu negseoed.
\q2 Bab-Jehová-Bela-Gangued-Nikad we-ibmar-imakoedi, e-sabgued-oyomaidba, deyob imakoed.
\s1 Bab-Jehová Israel-dulemarse urwemaid
\p 
\v 8 Isaías, Israel-dulemarga sogdebalid:
\q1 “Bab-Jehová Jacob-waganse e-gayaburba barmialid,
\q2 Israel-dulemarse e-gayaburba nonikid.
\q1 
\v 9 We-ibmar bela dulemar wisgumaloed,
\q2 Efraín-dulemar bela wisgumaloed,
\q2 Samaria-dulemar bela wisgumaloed.
\q1 Ar we-dulemar-san-dummarba-imakdimalad,
\q2 yeer-sogdimalad,
\q1 weyob sogdimalad:
\q1 
\v 10 ‘Ar negmar ayarele, akarsulid.
\q2 Ar anmar gannar akwagi-nuesaar sobmaloed.
\q1 Ar higuera-sapiwar-nagubirga-mamaid babatidele, baisulid.
\q2 Ar anmar a-muchub urwar mesoed.’
\b
\q1 
\v 11 ”Degi-inigwele, Bab-Jehová, Rezín-sordamargi e-isdarmalad barmidagoed
\q2 Bab-Dummad e-sunnad Rezín-sordamargi e-isdarmalad-gwisguega imakoed.
\q1 
\v 12 Siria-dulemar dad-nakwedsik-bukwadi, degi, Filistea-dulemar dad-argwanedsik-bukwadi,
\q2 ilagwen-obeloga Israel-dulemar-imaksamalad.
\b
\q1 ”Weyob-gus-inigwele, Bab-Dummad-urwedi amba bogigumaisulid.
\q2 Amba Israel-dulemargi urwemaid.
\b
\q1 
\v 13 ”Degi-inigwele, dulemar Bab-Dummad-sabsur-e-odurdaksad amba aku daksamalad.
\q2 Bab-Jehová-Bela-Gangued-Nikad e-bendakega gwen amissurmalad.
\q1 
\v 14 A-ulale, Bab-Jehová, ibagwen-nuedi Israel-dulemar-obelogoed.
\q2 Ibmar-dula-e-nono-egwanneyobi imakoed,
\q2 ibmar-dula-e-bunnu-immieyobi imakoed.
\q1 Sapi-ana-sikeyobi imakoed,
\q2 sapi-e-war-immieyobi imakoed.
\q1 
\v 15 Ar ibmar-dula-e-nono, girmar-dummagan-e-wilubganad, dule-nuga-nikamalad-e-wilubganad.
\q2 Ibmar-dula-e-bunnu, Bab-Dummad-gayaburba-barsogmalad-gakansaar-odurdakmaladid.
\q1 
\v 16 We-neggwebur-idumaladi, igar-noaledba dulemar-sesmalad.
\q2 Dule-eba-selesmaladi, aku neg-itodmalad, yoggudmalad.
\q1 
\v 17 A-ulale, Bab-Jehová, sapingan-gwen-yeer dakosulid,
\q2 dule-sergan-satemalad-gwen-yeer dakosulid.
\q2 Siamar-ei-sui-burgwismalad-gwen-yeer dakosulid.
\q1 Ar bela wemala, isgumaladbiid,
\q2 ibmar-isgana-imakmaladbiid,
\q2 galagwensuli sunmakmaladbiid.
\b
\q1 ”Weyob dulemar imakles-inigwele, Bab-Dummad-urwedi amba bogigumaisulid.
\q2 Amba anmargi urwemaid.
\b
\q1 
\v 18 ”Ibmar-isgana sooyobi gued.
\q2 Igi-soo-gadele, gagan-ikobiid bela biin-imake,
\q1 ikomar bela biin-imake,
\q2 deyobi, ibmar-isgana-imaklegedi gued.
\q1 Igi soo-gaedi sapurgi sapi-bukwadi bela obeloge,
\q2 degi, geb burwa-bipirmakaledyob, waa ainakwiddae,
\q2 deyobi, ibmar-isgana-imakedi gued.
\q1 
\v 19 Ar Bab-Jehová-Bela-Gangued-Nikad-urwedbali yala duu gadoed.
\q2 Dulemar e-sapanga guoed.
\q2 Dulemar na e-gwenadgan wiledakosulid.
\q1 
\v 20 Gwen-gwen, mas-satedba e-argan-nuedsik ibmar-bukwad gutemaloed.
\q2 Degi-inigwele, amba ukudmaada itomaloed.
\q1 Baigana, e-argan-sapiledsik ibmar-bukwad gutemarbaloed.
\q2 Degi-inigwele, amba immelegosurmarbalid.
\q1 Dulemar e-mimmigangi aibitemaloed,
\q2 e-mimmigan-gutemaloed.
\q1 
\v 21 Manasés, sabsur-Efraín-imakoed,
\q1 Efraín, sabsur-Manasés-imakmogoed.
\q2 Geb ebobela Judá-yalagi sabsur-gwichigudmaloed.
\b
\q1 ”Weyob dulemar imakles-inigwele, Bab-Dummad-urwedi amba bogigumaisulid.
\q2 Amba anmargi urwemaid.”
\c 10
\s1 Israel-dummaganga ibmar-soglenaid
\q1 
\v 1 Dule, igar-isgana-omesmalad, be duledar-wilesmar.
\q2 Dule, dulemar-idu igar-yeer-gangu-omesmalad, be duledar-wilesmar.
\q1 
\v 2 Bemar, dule-wilemalad-ibmar-nikuega be imaksurmalad,
\q2 an-dula-wilesagwa-gudimaladga be igar nudaksurmalad.
\q1 Siamar-ei-sui-burgwisadi, be wiodimalad,
\q2 dule-sergan-sated-ibe be ibmar atursadimalad.
\q1 
\v 3 Bemar sabsur-odurdaklealile, ¿bemar igi imakoe?
\q2 Boni-dummad bannaba-nosa begi-dani be dakalile, be-bendakega, ¿doase be goloe?
\q2 ¿Bia be-ibmar-nuegan be odukumaloe?
\q1 
\v 4 Ar be bar oakalogosurmalad.
\q2 Ar bemar gales seledmaloed.
\q1 Emar-gales-bukwad-abargi be mesagwar gumarmogoed.
\q2 Sulile, burgwarmalad-imbagi be oburgwilemarmogoed.
\b
\q1 Weyob bemar imaklego-inigwele, Bab-Dummad-urwedi, amba bogigumaiosulid,
\q2 Bab-Dummad amba amargi urwemaioed.
\s1 Bab-Dummad Israel-dulemargi Asiria-sordamar barmidagoed
\p 
\v 5 Bab-Jehová weyob soged:
\q1 “An bela-bela sae-itoged,
\q2 Asiria-e-Rey anga sabsur-odurdaked-suaryobi guoed.
\q1 A-suargine, an sabsur-dulemar-odurdakoed.
\q2 An isdar-itogedbali, a-suar an ebugoed.
\q1 
\v 6 Yala-nue-isgus-naidse an barmidoed,
\q2 dulemar an-ourwega-imakbukwadse an barmidoed,
\q2 adi, ibmar ei atursanaega, e-ibmar ei bela weenaegar.
\q1 Igi-dule dii-dii napa-imake,
\q2 deyob-emar-imaklegega an barmidoed.
\q1 
\v 7 Ar Asiria-e-reydi deyob-imakodeeye gwen binsassulid,
\q2 deyob-imakedgi gwen binsassulid.
\q1 Unnila dulemar-obelogedginbi binsaed,
\q2 unnila bukidar yar-baigan-osulogedginbi binsaed.”
\p 
\v 8 Bab-Jehová weyob soged:
\q1 “Ar ade, Asiria-e-rey weyob soged:
\q2 ‘¿Ar reymarde anga dummaganga-arbabukwadbisursi?
\q1 
\v 9 ¿Ar Calno-neggwebur, Carquemis-neggweburyob gussursi?
\q2 ¿Hamat-neggwebur, Arfad-neggweburyob gussursi?
\q2 ¿Ar Samaria-neggwebur, Damasco-neggweburyob gusmosursi?
\q1 
\v 10 An ibmar-bab-dummadyob-imakleged-yalamar obelos gusad.
\q2 A-yalamar, Jerusalén-neggweburba, degi, Samaria-neggweburba,
\q1 bur bule melu ibmar-bab-dummadyob-imaklemalad nikagusana,
\q2 degite, an obelosad.
\q1 
\v 11 An igi Samaria-neggwebur-imaksa,
\q2 degi, igi e-ibmar-bab-dummadyob-imaklemaladse-bakale, an obelosa,
\q1 deyob an Jerusalén-neggwebur imakoed.
\q2 E-ibmar-bab-dummadyob-imaklemaladse-bakale, an obelomogoed.’ ”
\p 
\v 12 Bab-Jehová, Sión-yalagi-ibmar-imakoed bela-obelosale, degi, Jerusalén-neggweburgi-ibmar-imakoed bela-obelosale, sogdagoed: “Asiria-e-rey-san-dummarba-itogedba an sabsur-odurdakoed, emar-saedakedba an sabsur-odurdakoed.”
\v 13 Ar ade, Asiria-e-rey weyob soged:
\q1 “We-ibmar an-ganguedba an imaksad,
\q2 an-binsaed-nikaa-daedba an imaksad,
\q2 ar ande, nue-ibmar-wisid-duled.
\q1 Ani an neggweburmar-e-abingunanaid ogwasad,
\q2 ani an e-ibe ibmar-nuegan atursasad,
\q1 ani an sorda-bila-onoged-buled-guedsoggu,
\q2 an e-reymar-obelosad.
\q1 
\v 14 E-yalamar bela e-ibe an susad.
\q2 Igi dule sikwi-e-akwa-bukwad weedae,
\q2 deyobi, an e-ibe e-yalamar susad.
\q1 Igi dule sikwi-uu sudae,
\q2 deyobi, dule-e-ibmar-nuegan-nikad an susad.
\q1 An-abinni, dule-wargwensaale gochasulid,
\q2 dule gwen akar sogsasulid.”
\p 
\v 15 Isaías weyob soged:
\q1 “¿Ar akande sunna dule-e-ebunaidba bur san-gannarbaa na imaksi?
\q2 ¿Ar sunna esnali-sapisikedde dule-e-ebunaidba bur bule-bule na san-imaksi?
\q1 ¿Gaapoledde, dule-e-ganikidgi obinosi?
\q2 ¿E-nabiedba naosi?
\q1 ¿Bia be daksa, suar-garagwadi, sapiwar-dummad-nakwaa imake?
\q2 Deyob be dakdisulid.
\b
\q1 
\v 16 ”A-ulale, Bab-Jehová, Bab-Jehová-Bela-Gangued-Nikadi, Asiria-e-rey-sorda-bila-onomalad-bulegangi boni-dummad barmidagoed.
\q2 Amar-e-nug-odummoleged-muchubbi, uelleged-dummad ega ukoed,
\q2 uellegedi sooyobi uegu egi nasikoed.
\q1 
\v 17 Bab-Dummad-wargwenna-guedi, Israel-dulemarga-neg-meegwadyobi-guedi, soo-gaeyobi gudoed.
\q2 Bab-Jehová-Isligwaled soo-gwichigumaidyob gudoed.
\q1 Ibagwen-nuedi, Asiria-sordamar-obelogoed,
\q2 ikomaryobi, gagan-ikomaryobi, soogi bela obelogoed.
\q1 
\v 18 Bab-Dummad, bela Asiria-e-sapur-yeerdakle-nanaidi, e-nainu-nanaidi, obelogoed.
\q2 Dule-geg-bar-gugus-gegumaiyobi bela ibmar nasikoed.
\q1 
\v 19 Sapur-naidgi sapimar napi-ichee ambikuoed.
\q2 Ichegwadbali, burwigana sunna ebisge guoed.”
\s1 Israel-dulemar-napi-bemaloed
\q1 
\v 20 A-ibagangine, Israel-dulemar-napi-bemaloedi, Jacob-wagan-napi-gudimaloedi, dule-e-obelosmaladba bar naguosurmalad.
\q2 We-napi-bemaloedi, Israel-e-Bab-Dummad-Jehová-Isligwaledba, nue innikigwadba nagumaloed.
\q1 
\v 21 Israel-dulemar-napi-bemaloedi, gannar Bab-Dummadba nagudmaloed,
\q2 Jacob-wagan-dula-napi-gudimaloedi, Bab-Dummad-Bela-Gangued-Nikadba gannar nagudmaloed.
\q1 
\v 22 Israel-dulemar, bemar ukub-demar-gakaba-mergueyob-guen-inigwele,
\q2 unnila bemar napi-ichee gannar nonimaloed.
\q1 Israel-dulemar-obelolegoye bato soglesmaid.
\q2 Bela ega igar nabolegoed.
\q1 
\v 23 Ar Bab-Dummad-Jehová-Bela-Gangued-Nikad, Israel-dulemar-obelolegoye bato sogsad.
\q2 Ar deyob yargi-gudimaladgi imakoed.
\p 
\v 24 A-ulale, Bab-Dummad-Jehová-Bela-Gangued-Nika-Maid weyob soged:
\q1 “An-dulamar, be Sión-yalagi-bukwamalad,
\q2 melle be Asiria-dulemar dobee itomalo.
\q1 Asiria-sordamar gaapoledgi be-sarsomalo-inigwele,
\q2 begi suar-oyodamalo-inigwele, melle dobgumalo.
\q1 Igi-Egipto-dulemar bemar-imaksagusa,
\q2 deyob bemar-imakdago-inigwele, melle be dobgumalo.
\q1 
\v 25 Emisgwasaale, bemargi an-nue-sae-itogedi berguoed.
\q2 An-urwedi, be-isdarmaladgi yoledoed.”
\b
\q1 
\v 26 Bab-Jehová-Bela-Gangued-Nikad, Asiria-dulemar-sabsur-odurdakoed.
\q2 Bab-Jehová, igi-akwasaila-Orebʼye-nugadgi Madián-dulemar-imaksagusa,
\q2 deyob Asiria-dulemar-imakoed.
\q1 Bab-Dummad, igi-Egipto-dulemar-igarba-nadapgu e-gaapoled-oyosgu, egi demar-arwega-imaksagusa,
\q2 deyob Asiria-dulemar-sabsur-imakoed.
\q1 
\v 27 A-ibagangine, bemar we-boniganba-galitodiidi bela bega berguoed,
\q2 bemar gangudoedba, sabsur-wilediidgi be ollorgudmaloed.
\b
\q1 
\v 28 Be-isdarmalad-Asiria-sordamar Ajatʼye-neg-nugadgingus naid,
\q2 Migrónʼye-neg-nugadgi nadapid,
\q2 Micmasʼye-neg-nugadgi e-ibmarmar obesad.
\q1 
\v 29 Diwar-dinnagwadgi obakmamaid,
\q2 degi weyob sogmalad: “Gebaʼye-neg-nugadgi anmar obunnomaloye.”
\q1 Ramá-dulemar dobedba wawanmakdemalad,
\q2 Saúl-neggwebur-Gabaaʼginmalad duurmakdemalad.
\q1 
\v 30 ¡Omegan-Galim-neggweburginmalad binnasur be oimakmala!
\q2 ¡Omegan-Lais-neggweburginmalad be itomala!
\q2 ¡Anatot-neggwebur be abinsamarmoga!
\q1 
\v 31 Madmena-dulemar wakitemalad,
\q2 Gebim-dulemar dukudmalad.
\q1 
\v 32 Emi-ibagi, Asiria-sordamar Nobʼye-neg-nugadse ambikunonimaloed.
\q2 Sión-yalagi gwichiguega, guagwar ambikumaloed.
\q2 Siónʼde, Jerusalén-e-yalad.
\b
\q1 
\v 33 ¡Nue be dake!
\q2 Bab-Dummad-Jehová-Bela-Gangued-Nikad-abin, sapi-anagan doos-doos naded.
\q1 Sapi-suigan bibichis nanaed, sapi-dummagan e-abin ailade nanaed.
\q1 
\v 34 Sapi-moodo-naidi, akangi immided,
\q2 Líbano-yargi sapimar-yeerdakle-bukwad bela berguded.
\c 11
\s1 Mesías Igar-innikigwadba yar-seoed
\q1 
\v 1 Sapi-siklesad-gannar-ainieyobi, dule-Isaíʼye-nugadgi dule-gwensak nodagoed.
\q2 E-wagangine, a-dule danikoed.
\q1 
\v 2 A-dulegi Bab-Jehová-E-Burba megoed:
\q2 Nue-binsaed-nikagued ega ukoed,
\q2 nue-ibmar-magar-itoged ega ukoed,
\q1 binsaed-nued-uke imakoed, degi, gangued-nika imakoed,
\q2 gurgin-nikarba imakoed, degi, Bab-Jehová-dobee-nanadii imakoed.
\q1 
\v 3 We-dule, Bab-Jehová-dobee-nanaoedba yeer-itodii guoed,
\q2 dulemar-daklegedba dulemarga igar nabogosulid,
\q2 dulemar-ibmar-sogedba igar nudakosulid.
\q1 
\v 4 Dule-wilemaladga igar-napiragwadba igar nabogoed,
\q2 degi, igar-innikigwadba dule-belagwadaedga igar nudakoed.
\q1 E-sunmakedba dule-bukwad-obelogoed,
\q2 e-ibmar-sogedba dule-isgana-oburgoed.
\q1 
\v 5 Igar-napiragwadi, molidub-saderba-naiyobi, oyodii guoed.
\q2 Innikidaedi, e-musir-edinnedyobi, oyodii guoed.
\b
\q1 
\v 6 Achu-burburud, sibad-wawaad-senigwad-ebo gudii guoed.
\q2 Achu-barbad, sibad-bipi-ebo dodomai guoed.
\q1 Moli-bebe-nikad-sapingwagwad, achumigur-nono-wawaad-bipigwadmala garmakdii gumaloed.
\q2 Machi-bipigwa a-ibmar-durgan-idudii guoed.
\q1 
\v 7 Moli-bebe-nikad-ome, wiob-omemala garmadii guoed,
\q2 e-mimmigana bulakwaa gudii gumogoed.
\q1 Achumigur-nono-wawaad, moli-bebe-nikad-alugwasualedyob gagan-madii gumogoed.
\q1 
\v 8 Goe-susugwa-amba yoo-mam-iargued, naibe-buled-galu-dikarba dodonai guoed.
\q2 Mimmi-gebe-mam-iargusadi, naibe-nued-e-yaa-yaba e-argan ododii guoed.
\q1 
\v 9 An-Yala-Islidikid-Naidgi gwen dulemar neg-oichodii guosurmalad,
\q2 gwen oakalogosurmalad,
\q1 ar ade, bela yar-naidgi, Bab-Jehová-magar-dake nanadii gumaloed.
\q2 Muu-billi-dii-bela-engus-naiyobi, bela Bab-Dummad-magar-dake gumaloed.
\b
\q1 
\v 10 A-ibagangine, Isaí-e-wagangi-dule-danikoedi, dulemar-iduedga guoed.
\q2 Bela dulemar-yar-baid-baidgi-bukwamalad ese duurmaknonimaloed.
\q2 E-neg-megoedi gandikidba-yeerdaklege guoed.
\q1 
\v 11 A-ibagangine, Bab-Jehová bela e-dulamar-amba-yar-baid-baidgi-mimiles-bubukwad
\q2 gannar-sedagega imakoed.
\q1 We-yarmargi mimiles bubukwad:
\q2 Asiria-yalagi, Egipto-yalagi,
\q2 Patros-yalagi, Cus-yalagi,
\q2 Elam-yalagi, Sinar-yalagi, degi, Hamat-yalagi,
\q2 degine, demar-gakagi-besmalad.
\q3 Wemar gannar senonikoed.
\q1 
\v 12 We-dule-danikoedi, dule-ebiega bandergwichiyobi guoed,
\q2 bela-dulemar-yar-baid-baidgi-bukmalad ese duurmaknonimaloed.
\q1 Deginbali, bela Israel-dulemar, degi, Judá-dulemar, galesadba-akar-akar-aisakis-bukwamalad
\q2 gannarse danakwaa urboed.
\q1 
\v 13 Efraín-dulemar nobed surgudoed,
\q2 Judá-dulemar-e-isdarmalad bela obelolegoed.
\q1 Efraín-dulemar, Judá-dulemargi bar nobguosulid,
\q2 Judá-dulemarmoga Efraín-dulemar-mesagwar bar imakosurmogad.
\q1 
\v 14 Aka, emar ebogwa, Filistea-dulemargi dad-argwanedsik-bukmaladgi gwisgudmaloed.
\q2 Emar ebogwa, dulemar-dad-nakwedsik-bukmalad-ibe ibmar atursadmaloed.
\q1 Edom-dulemar, Moab-dulemar, degi, Amón-wagan, amarse sabsur-wilemarmogoed.
\q2 Amar-sogedba ibmar imakmaloed.
\q1 
\v 15 Bab-Jehová, Egipto-demar-sukun-naid bela dinna nasikoed.
\q2 Éufrates-diwargi e-argan oyogoed,
\q1 egi burwa-uereged barmidagoed,
\q2 geb we-diwargi dian-sogagugle (7) mesoed,
\q2 adi, nabir nagab obakmalagar.
\q1 
\v 16 Igi-Israel-dulemar Egipto-yargi-nosmargu, ega nanaed-igar maigusa,
\q2 deyobi, Israel-dulemar-Asiria-yargi-napi-besmaladga nanaed-igar mai gumogoed.
\c 12
\s1 Bab-Dummad-nug-odummogedgi namakleged
\p 
\v 1 A-ibagangine, weyob be sogdoed:
\q1 “Bab-Jehová, be anse ulus-inigwele,
\q2 an bega namakoed.
\q1 Be-urwediid bergunonikid,
\q2 be an-gwage baisur-itogega imaknonikid.
\q1 
\v 2 Bab-Dummad, an-abonogedid.
\q2 An egi benguosulid, an dobee itogosulid.
\q1 Bab-Jehová, be an-ogannogedid,
\q2 Bab-Jehová, anga namakedga gued,
\q2 be an-abonogedga gued.”
\q1 
\v 3 Deginbali, bemar abonolegedgi weligwar itomaloed,
\q2 bela-bela be Bab-Dummad-e-abonolegedgi yeer itomaloed.
\p 
\v 4 A-ibagangine, weyob sogledoed:
\q1 “Bab-Jehováʼga be namakmar,
\q2 e-nug be odummomar,
\q1 bela-dulemar-napneggi-bukmaladga e-ibmar-imakedgi be sunmakmar,
\q2 e-nug-dummarba-guedgi be sunmakmar.
\q1 
\v 5 Bab-Jehováʼga ega-namaklemaladgi be namakmar,
\q2 ar ade, ibmar-gegerdaklemalad imaksad.
\q2 We-ibmar-gegerdaklemalad bela we-napneggi dulemar-wisguega be imakmar.
\q1 
\v 6 Sión-yalagi-bukmalad, weligwaledba be namakmar, weligwaledba be gormakmar.
\q2 Israel-dulemar-e-Bab-Dummad-Isligwaled, bemar-abargine Dule-Gandikidid.”
\c 13
\ms2 1c. Yar-baid-baidgi-bukmaladga sunmaklenaid
\mr (13:1–23:18)
\s1 Isaías, Babilonia-yala-yoedse-berguoedgi sunmaksad
\p 
\v 1 Bab-Dummad Amoz-machi-Isaíasʼga Babilonia-dulemar-berguoedgi sunmaksad:
\q1 
\v 2 Yala-swire-naidgi bander be mer-mer imakmar,
\q2 sorda-bila-onomaladse be binnasuli gormar.
\q1 Argan ese be oyomar,
\q2 adi, dule-nuga-nikamalad-yawagakba ubomalagar.
\q1 
\v 3 Anga-nug-salegarmaladga bato an igar-uksad.
\q2 Anga-dule-bulegan-gumaladi, an-nakwedgi-na-yeer-itodimaladi, an guakwaa urbisad,
\q2 adi, anga sabsur-dulemar-odurdakegar.
\b
\q1 
\v 4 ¡Be itomar! Yalaganba neg-oimake itoleged,
\q2 dulemar-ichesur-oimakedyob itoleged.
\q1 ¡Be itomar! Neggwebur-dummagan-atosmalad-oimaked, be itomar,
\q2 mala-gollomakedyob e-oimaked itoleged.
\q1 Bab-Jehová-Bela-Gangued-Nikad, bila-onogega,
\q2 sorda-bila-onomalad-guagwar urbenaid.
\q1 
\v 5 Neggwebur-dikasulidba danimalad,
\q2 yarmar-bergunaid-akale danimalad.
\q1 Bab-Jehová, e-urwedba-ibmar-ebulemalad sedanikid,
\q2 adi, bela napneg obelogegar.
\q1 
\v 6 ¡Be bomarsun! Bab-Jehová-urwemaid-iba omosad,
\q2 Bab-Dummad-Bela-Gangued-Nikad bemar sabsur-odurdakoed-e-iba danikid.
\q1 
\v 7 A-ulale, bela argan nollomakdoed,
\q2 bela dulemar niga-argwatemaloed.
\q1 
\v 8 Bela-belad dobe-itodmaloed,
\q2 suli-suli-itomaloed, nunmaked-dummadi egi nagudmaloed.
\q1 Igi-sior-muu-neggi-ugakgunair nunmaked-itodae,
\q2 deyobi, egi nunmaked nagunonikoed.
\q1 Dukin-dukin geger na dakdemaloed,
\q2 e-wagarmar-daklegoedi, bela-bela dobed-nika daklemaloed.
\q1 
\v 9 ¡Be dakmar! Bab-Jehová-urwed-e-iba danikid:
\q2 Iba-buled dani, yeer-gangued-iba, bela-belad-urwed-iba dani,
\q1 napneg ollobi daarmakar nasikoed,
\q2 agine, bela dule-isgubukmalad obelogoed.
\p Bab-Jehová soged:
\q1 
\v 10 “Niisgwamar mogir-biriba-nanaidi bar gaosulid,
\q2 niisgwamar-danar-danar nanaidi, bar ibegwar gaosulid.
\q1 Dad-ibeler-noalile, sichii naguoed,
\q2 bar nii ibegwar gaosulid.
\q1 
\v 11 Napneggi-dulemar-bukwad e-isgudiid-nukad an sabsur-odurdakoed,
\q2 dule-isganamar e-ibmar-isgana-imakdiidba an sabsur-imakoed.
\q1 Dule-na-san-dummarba-imakmaladi, na san-dummarba-imakega bar guosurmalad.
\q2 Dule-bulegan-na-san-dummarba-imakmaladi, na san-dummarba-san-saega bar guosurmalad
\q2 bela nug-bipi-gumalaga an imakoed.
\q1 
\v 12 Dulemar, olo-sunsoged-icheguedba bur ichee-bukuega an imakoed.
\q2 Dulemar, Ofir-or-nued-icheguedba ichee-bukuega an imakoed.
\q1 
\v 13 A-ulale, ani Bab-Jehová-Bela-Gangued-Nikad, an-urwemaid-ibagangi an-urwedba nibneg giglimakega an imakoed.
\q2 Napneg e-naidgi ainirega an imakoed.
\q1 
\v 14 Dulemar igi-goe-sapur balegillemaidae,
\q2 deyob, balegillegoed, e-neggweburse duurmakdemaloed.
\q1 Igi-sibad-wawaad e-idugedsuli duurmakmadaedyobi gumaloed,
\q2 wala-walagwen e-yarse wakitemaloed.
\q1 
\v 15 Doa-dule galenonikile, ewarar oburgwilegoed,
\q2 dule yogasaar-galesale, es-suidgi oburgwilegoed.
\q1 
\v 16 Dulemar-wagaba e-mimmigan omukudmaloed,
\q2 e-negmar-ibe ibmarmar atursadmaloed,
\q2 e-omegan e-ibe gagadmaloed.
\q1 
\v 17 Babilonia-dulemargi Media-dulemar gwichiguega an imakoed.
\q2 We-dulemar mani bai dakdasurmalad,
\q2 orgi gwen weligwar itodasurmalad.
\q1 
\v 18 E-sigugi ese sapingana, yagana, oburgwilegoed,
\q2 goe-gwarugana gwen wile dakosurmalad,
\q2 burwigana gwen bai dakosurmalad.
\q1 
\v 19 Babilonia-neggwebur, be yeerdakleged, gandikidba be yeer-dakleged,
\q2 Caldea-dulemarga be san-dummarbaa gusiid.
\q1 Emidi, Sodoma-neggweburyob be guoed,
\q2 Gomorra-neggweburyob be guoed.
\q1 Ani an Bab-Dummad gued.
\q1 Igi an we-neggweburmar obelosa,
\q2 deyob an be-imakmaloed.
\q1 
\v 20 Bipisaale, bar dulemar egi ambikuosulid,
\q2 dulemar-sorba-danimaloedi bar egi ambikuosurmalad.
\q1 Árabe-dulemar we-yargi bar megosulid.
\q2 Sibad-wawaad-edarbedi, bar egi e-sibad-wawaadmar oambikuosulid.
\q1 
\v 21 Unnila nega-dulesulidganba ibmar-durgan-ursilimaladbi bukuoed.
\q2 E-negmargine, irmonbi ena ambikuoed,
\q1 nuu-dummad-malisuiganbi a-yargi ambikuoed,
\q2 sibad-omegan-sapurbarmaladbi gudidioed.
\q1 
\v 22 E-neg-gandikmaladgi achu-sapurmarbi gordioed,
\q2 e-reynegmargi achu-sapur-uaya-gannareged-bunnu-wawaadmarbi gordioed.
\q1 Babilonia-neggwebur, Bab-Dummadse be sabsur-odurdakleged-igar omodanigusad,
\q2 bar bega ibamar obannolegosulid.”
\c 14
\s1 Babilonia-e-reygi dodolegar sunmaklesad
\p 
\v 1 Ar Bab-Jehová wile Jacob-wagan-daknonikoed, gannale Israel-dulemar-sunonikoed. E-yala-sunnadgi-bukuega imaknonikoed. Dule-yar-baiganginmalad ese megnonimaloed, Jacob-waganba garmakdii gumaloed.
\v 2 Dulemar-bukidar Israel-dulemar-bendakmaloed, Israel-yarse sedmaloed. Geb degi, Israel-dulemar, e-galesgusmalayobi Bab-Jehová-yargi e-maiganga amar-imaknonimaloed. Degi, Israel-dulemar, dulemar-mesagwar-e-imaksamaladgi dummadga gumaloed.
\p 
\v 3 Israel-dulemar, Bab-Jehová be-bukib-binsadigusadgi baisur-itoge be-imaknonikile, degi, be-nunmak-itodigusadgi, be-ise-mesagwar-imaklesadgi, Bab-Jehová bemar-ollor-imaknonikile,
\v 4 Babilonia-e-reygi we-sabsur-emar-obingesaar-namaklegedgi be weyob namakmaloed:
\q1 “Dule-emar-mesagwar-sadiid, igi-gusa be dakmarsunna.
\q2 E-urwedi, igi-bergus be daksunna.
\q1 
\v 5 Bab-Jehová dule-isganamar-e-suar bibichisad,
\q2 dulemar-yeer-neg-gangu-semamaid-e-gaapoled bibichisad.
\q1 
\v 6 We-gaapoled dulemar-sabsuli-wiodii gusad,
\q2 urwedgi dulemargi-obindii, degi, balengindii gusad.
\q1 
\v 7 Emidi, bela napneg bogigus naid,
\q2 weligwaledba binnasuli namakmalad.
\q1 
\v 8 Baryawarse-bakale, degi, Líbano-urwarse-bakale, Babilonia-e-rey, be-bergusadga wergumalad,
\q2 weyob sogmalad: ‘Be-bergusad-akale, bar dulemar anmar-omukudisurmalad.’
\q1 
\v 9 Be-ibmar-imaksad-ular, neg-urba burgwarmalad-galu bebina itosmaid,
\q2 be-abindakagwar maid.
\q1 Be-ibmar-imaksad-ular, dule-burgwarmalad odaklealid.
\q2 Amala dule-dummaganga megismaladid.
\q1 Ar bela reymar-yar-bamaladgi-megisgusmaladi be-abin ainidagega,
\q2 e-ologanagi-bubukwadgi ogwislealid.
\q1 
\v 10 Bela wemar ibmar sogdamaloed, bega weyob sogdagoed:
\q2 ‘Anmaryobi be ganguedsuli gunonisunde.
\q2 Be anmaryobi gunonimosunde.’
\q1 
\v 11 Be-san-dummarba-na-be-imakdiid napa-uluba melledsun,
\q2 be-gar-arpa-goled bergunonimosun.
\q1 Emisgindi, nusu-imbagi be megmosunnoed,
\q2 nusubi ber biini be megmosunnoed.
\b
\q1 
\v 12 ”Niisgwa-dummad-bolegoedba-gaardaed, ibiyobi be niba-nai argwannoniki.
\q2 Bee be, bela-bela dulemar-wiodiidid,
\q2 napnegse be e-gwallenonisunnad.
\q1 
\v 13 Be-gwagegi weyob be sogsa gusanad: ‘Nibnegse an naoye.
\q2 Bab-Dummad-e-niisgwamar-birigi an-ologana an sioye.
\q1 Dad-nakwed-argan-sapiled-akar bab-dummad-baigan-e-yalagi,
\q2 dummadga an negsemai guoye.
\q1 
\v 14 Mogirmar-bur-birise an nakoye,
\q2 Bab-Dummad-Bur-Biriginedyob an guoye.’
\q1 
\v 15 Emide, burgwarmalad-galuse be balimellealid,
\q2 bela neg-ulubalidse be egwallesad.
\q1 
\v 16 Dulemar-be-dakmaladi, nue-nuu be-dakmaloed,
\q2 ar ade, geger be-dakmaloed, weyob binsadmaloed:
\q2 ‘¿Wee we, napneg-wiodigusadi?
\q2 ¿Wee we, yalamar-ogwayedii gusadi?
\q1 
\v 17 ¿We-dule we, napneg nega-dulesulidga imaksadi?
\q2 ¿We-dule we, yalamar obelodii gusadi?
\q2 ¿We-dule we, esgaryagi-dulemar-gales-bukwad gannar e-negse-naega gwen imakdasulidi?’
\q1 
\v 18 Dulemar-yar-baid-baidgi-bukmalad-e-reymardi,
\q2 nug-nikadba nuegwadgi e-neg-uangi digar-digar mamaid.
\q1 
\v 19 Ar bedi napa-ulugi-maidgi be-onosmalad,
\q2 igi durgan-nunud mileddae, deyob be-imaklesad.
\q1 Dule-es-suidgi-oburgwilegar-burgwismaladi, neg-uluba-melledmaladi,
\q1 bela be-omurus mamaid.
\q2 Dule, muigi dii-dii-annasadyobi be dakleged.
\q1 
\v 20 Bedi gwen reymar-diglegeyobi nuedgi be diglegosulid,
\q2 ar be-yala be obelosad,
\q2 be-dulamar be ogilosad.
\b
\q1 ”Bipisaale dule-isganamar-e-wagan bar obarlegosulid.
\q2 
\v 21 Babgan-isgusad-ulale, e-mimmigan ogilolegega, ibmar-oburgwileged-neg guagwar imakmalo.
\q1 Adi, wemar melle yar-seedgi bar binsamalagar,
\q2 adi, melle bar napneggi neggweburmar-urbegar.”
\p 
\v 22 Bab-Jehová-Bela-Gangued-Nikad weyob soged:
\q2 “We-dulemargi ani an gwichiguoed,
\q1 ani an Babilonia-yala osulogoed, e-nuga an obelogoed,
\q2 dulemar-dulagudimaladi ani an obelogoed,
\q1 e-masmala, e-wagana ani an obelogoed.
\q2 Weyobi, ani an Bab-Jehová-guedi soged.
\q1 
\v 23 Neg-matabi-naguega an imakoed
\q2 akwanuku-negga an obinyoed.
\q1 Gwalagi-negdurwieyob Babilonia-yala an imakoed,
\q2 bar gudii an imakosulid.
\q1 Weyobi ani an Bab-Jehová-guedi soged.”
\s1 Isaías, Asiria-yargi-yoedse-ibmar-guoedgi sunmaksad
\p 
\v 24 Bab-Jehová-Bela-Gangued-Nikad weyob ise-sogar imaksad:
\q1 “Igi an igar-mesisa, deyob sogedba guodo.
\q2 Igi an sogsa, deyob sogedba imaklegodo.
\q1 
\v 25 An-yalagi, an Asiria-dulemar obelogoed,
\q2 an-yarmar-birgi, an amar-ogilogoed.
\q1 An-neggwebur bar ese mailedii guosulid,
\q2 ibmar-buleganba bar galitodii guosulid.
\q1 
\v 26 We-igarde, ani an weyob bela yalamarga igar-mesisad.
\q2 We-igarde, ani an weyob bela yalamarse an oyosad.”
\q1 
\v 27 Ar Bab-Jehová-Bela-Gangued-Nikad weyob sogsasoggu,
\q2 ¿doa e-igar gaosunna?
\q1 Ar e na igar mesisad, degite, ¿doa e-igar gaosunna?
\q2 ¡Suli, dule gwen e-igar gaosuli!
\s1 Isaías, Filistea-dulemar-berguoedgi iduakwaa sunmaksad
\p 
\v 28 Rey-Acaz-burgwisad-birgagine, Isaíasʼse we-gayaburba nonikid:
\q1 
\v 29 “Bemar bela-Filistea-dulemar, yala-be-wiodigusad-bergusadba,
\q2 melle be weligwar itomalo.
\q1 Ar yala-baid bela-bela be-isdaradga guoed,
\q2 naibe-nued-gukualedba bur bule isganaga guoed.
\q1 
\v 30 Ar dule-wileganadi, nue-mas-gundii gumaloed.
\q2 Ar dulemar ibmar-abesa-gudimaladi, ibmar nue-nikagudii gumaloed.
\q1 Degi-inigwele, Filistea-dulemar, an be-wagandi ukudba oburguoed,
\q2 be-dule-dula-napi-bukwadi bela an obelogoed.
\q1 
\v 31 Filistea-dulemar, gwage-nunmak-itogedba be binnasuli bomarsun.
\q2 ¡Bela bemar dobe-itogedba be wawanmakmarsun!
\q1 Ar ade, sorda-bila-onomalad dad-nakwed-argan-sapiledsik waa-ainakweyob melledanikid,
\q2 dule bela danagwena duurmakdanikid.
\q1 
\v 32 ¿Igi-be we-yalaga-dule-garda-berbemalad-abin be sogoe?
\q2 Weyob be sogoed:
\q1 ‘Ar Bab-Jehová Sión-yala sisad,
\q2 ar agi dule-wile-itodimalad dukued-neg amioed.’ ”
\c 15
\s1 Moab-dulemar-yoedse-berguoedgi sunmaklesad
\r (Isaías 16:6-12; Jeremías 48:29-36)
\p 
\v 1 Isaías, Moab-neggwebur-berguoedgi iduakwaa sunmaksad.
\q1 Moab-neggwebur-Arʼye-nugad bela ayarisad,
\q2 mutiki bergusad.
\q1 Moab-neggwebur-Kirʼye-nugad bela ayarisad,
\q2 mutiki bergusad.
\q1 
\v 2 Dibón-neggweburginmalad, e-bab-dummadse-goled-negse nadmalad,
\q2 adi, e-bab-dummadga-ibmar-ogumakar-ukleged-ailase bonamalagar.
\q1 Moab-dulemar Nebo-neggwebur-bergusadga,
\q2 degi, Medeba-neggwebur-bergusadga, ogormakbukwad.
\q1 Bela sailagia-swiri-swiri imaksamalad,
\q2 aku-sigamarse-bakale, bela enismalad.
\q1 
\v 3 Bela-dulemar boedbimalad,
\q2 galimbabali wile-itoged-mor yoyoidbimalad.
\q1 Neg-ubebbali ogormakdemalad,
\q2 dulemar-bukidar-ambikuedgi dulemar boedbimalad.
\q1 
\v 4 Hesbón-dulemar, degi, Eleale-dulemar, wile-itogedba binnasuli e-bendakmarye gordidimalad,
\q2 e-binnasur-gordiidi Jahaza-neggweburse magar itoleged.
\q1 A-ulale, Moab-sorda-bila-onomalad dobedba-binnasuli gorbukwad,
\q2 bela-bela egi dobed nagunonikid.
\b
\q1 
\v 5 Moab-yar-ulale, an nue-bukib binsaed,
\q2 E-dulemar, Zoar-neggweburse duurmakmamaid,
\q2 Eglat-Selesiyáʼye-neg-nugadse duurmakmamaid.
\q1 Luhitʼye-neg-nugadba ise-boar-boar nakwemamaid.
\q2 Horonaim-neggwebur-igarba ise-boar-boar nadapmalad.
\q1 
\v 6 Nimrim-dianmar bela dingusad,
\q2 gagan-ara-aramalad bela dingusad.
\q1 Bar gagan-ara-aramalad nikagussulid,
\q2 bela gagan-ara-aramalad bergusad.
\q1 
\v 7 A-ulale, dulemar-bukidar e-ibmar-nuegan-nikamaladi
\q2 Sauce-sapimar-dian-maid-obakar sesmalad.
\q1 
\v 8 Dulemar-binnasuli-bodiidi, bela Moab-yalagi itolesad.
\q2 Dulemar-akigindiidi, bela Eglaim-neggweburse warmaksad,
\q2 degi, Beer-Elimʼye-neg-nugadse warmaksad.
\q1 
\v 9 Dimón-dian bela ablisbi-naid, bonigan napi-egi an barmidagoed:
\q2 Moab-dulemar-duurmakmaidgi achumigur-nono-wawaad an barmidagoed.
\q2 Amba dulemar-napneggi-bukwadgi achumigur-nono-wawaad an barmidagoed.
\c 16
\s1 Moab-dulemar, Judá-yalagi dukusmalad
\p 
\v 1 Isaías sogdebalid:
\q1 “Sela-neggwebur-nega-dulesulidgi-siid-akale,
\q2 Sión-yalase, Israel-yala-dakmaidga be sibad-wawaad-senigana barmidmar.
\q1 
\v 2 Moab-dulemar-omegan, nuu-e-uugi-ise-gwayar-noddaedyobi,
\q2 Arnón-diwargi obakmamai guoed.
\b
\q1 
\v 3 ”Moab-dulemar, Sión-dulemarga weyob sogdanimalad:
\q2 ‘Be igar-amimala, be sogmalo igi be imakmaloe.
\q1 Neg-ibginedgine mutikidyobi negsichidbi be anmarga nasike.
\q2 Dule-gwakiar-duurmakarmaladi be odukue,
\q2 melle dule-dukudimalad be urmako.
\q1 
\v 4 Itoba Moab-dulemar-gwakiar-duurmakarmalad be bemar-walik dukudii imako,
\q2 dule-e-obelobigudiidgi be wis bendako.’
\b
\q1 ”Mesagwar-imakleged-ibagan bergusale,
\q2 sabsur-odurdakleged-ibagan bergusale,
\q2 napneggi dule-obeloged bergudoed.
\q1 
\v 5 Geb Rey-David-wagwa-gwensak, Israel-reyga megnonikoed.
\q2 E-yar-seoedi, innikigwadba yar seoed,
\q1 binsaed-nikaa yar seoed,
\q2 nueganbi dulemar-idugoed,
\q2 dulemarga igar-naboged ega gwae imaknonikoed.
\b
\q1 
\v 6 ”Anmar itodiid, Moab-dulemar doggus na san-dummarba-imakmarye.
\q2 Wemar na bule-bule-na-san-imakdimalad.
\q1 Dule-buledye na sogdimalad.
\q2 Doggus-e-sunmakedgi emar-mesagwar imakdimalad.
\q2 Ar binsarsunna deyob-damalad anmar nue-wisid.
\q1 
\v 7 Degisoggu, Moab-dulemar ogormakdemaloed,
\q2 bela e-yalaga boedbimaloed.
\q1 Kir-Hareset-uva-maduga bomaloed
\q2 ega bukib-binsamaloed,
\q2 bukib-binsaedba ega wile itomaloed.
\q1 
\v 8 Ar Hesbón-dulemar-nainu bela dingusad,
\q2 Sibma-neggwebur-e-uva-nainu deyob naimogad.
\q1 Dulemar-yar-baid-baidgi-bukmalad-negsemamaid, uva-nainu-nuegan obelosmalad.
\q2 E-dubagan-Jazer-yalase-warmaknanainadgi,
\q1 nega-dulesulidganse-warmaknanainadgi,
\q2 e-dubagan-demarse-batenanainadgi, bela dii-dii imaksamalad.
\q1 
\v 9 A-ulale, an Jazer-yala-e-uva-nainubina booed,
\q2 an Sibma-neggwebur-e-nainuga bomogoed.
\q1 An Hesbón-dulemarga, Eleale-dulemarga an-ibyanis aryogoed.
\q2 Ar dule-weligwar-imakega bar e-nainugi ibmar-gwagmar nikuosulid,
\q2 ibmar-gwagmar gwen bar weelegosulid.
\q1 
\v 10 Nainugi bar wergulegosulid.
\q2 Uva-nainugi dulemar bar namake itolegosulid,
\q2 binnasuli dulemar-goled bar itolegosulid,
\q1 uva-egurelegedgi dulemar bar uva egured daklegosulid,
\q2 uva-welegedgi binnasur-gorledaedi ani an osulosad.
\q1 
\v 11 Degisoggu, an-gwage, Moab-dulemar-ular,
\q2 Kir-Hareset-neggwebur-ular, gar-arpa-dub-nakwamaknaiyobi, wile-itonaid.
\q1 
\v 12 Ar Moab-dulemar aisaar na e-bab-dummaganga-ibmar-ogumakar-ukleged-ailase-namalo-inigwele,
\q2 bendakleged amiosurmalad, yegudamaloed.
\q1 E-bab-dummadse-goled-neg-islidikidse e-bab-dummadse gornamalo-inigwele,
\q2 gwen ega igarga guosulid, bela bergus naoed.”
\p 
\v 13 Bab-Jehová weyob epenne Moab-dulemargi ibmar-guoedi sogsagusad.
\v 14 Emidi, Bab-Jehová weyob soged: “Igi-dule unnila birgapaa arbadae, deyobi, birgapaasega Moab-yala-e-yeerdaklegedi, berguoed. E-dulemala burgwemaloed. E-dula, unnila napi-ichee bemaloed, garganguedsuli gumaloed.”
\c 17
\s1 Damascoʼgi-yoedse-ibmar-guoedgi sunmaklesad
\p 
\v 1 Isaías, Damasco-neggweburgi iduakwaa sunmaksad: Bab-Jehová-Bela-Gangued-Nikad weyob sogdo.
\q1 “¡Damasco-neggwebur-siid be nue-dakmar!
\q2 ¡Bar neggweburga sii guosulid!
\q2 ¡Nue bibichis sigoed!
\q1 
\v 2 Aroer-neggweburmar ollobi melledoed,
\q2 gagan-ara-aramaladbi naguoed.
\q2 Agine, sibad-wawaadmar dobed-nikasuli gagan-madii gumaloed.
\q1 
\v 3 Efraín-dulemar-e-neggwebur-gandikid-siid berguoed,
\q2 Damasco-neggwebur-Siriaʼgi-siid bergumogoed.
\q2 Aram-dulemar-napi-durgumaloedi, e-ibmar-nuegana Israel-dulemargadga guoed.”
\s1 Israel-dulemar sabsur-odurdaklegoed
\p 
\v 4 Bab-Dummad sogdebalid:
\q1 “Siria-yala-gandik-siid bela bergusale,
\q2 Israel-dulemar-e-gangued bela nollomakdemogoed.
\q1 
\v 5 Dule-ibmar-gwag-weed ibmar-gwag-welesadyobi,
\q2 Israel-dulemar-e-gangued guoed.
\q1 Dule na e-argangi ibmar-gwag-weesayobi,
\q2 Israel-dulemar-e-gangued berguoed.
\q1 Refaim-nebagi ibmar-gwag-welesad-besmaladyobi,
\q2 Israel-dulemar ichee bemaloed.
\q1 
\v 6 Degine, igi-dule olivo-san-osiamaksale, e-anagan-matusulid-dukugi napi gwabo, gwapaadibe, nagusdae,
\q2 deyobi, Israel-dulemar napi-ichee bemaloed.
\q1 Ar igi olivo-san bela e-sapi-anagangi
\q2 gwabake, gwaatardibe napi-nagusdae, deyobi, napi-bemaloed.”
\p Deyobi, Bab-Jehová-Bela-Gangued-Nikad sogdo.
\q1 
\v 7 A-ibagine, Israel-dulemar, e-Obinnisad amidagoed.
\q2 Israel-dulemar, e-Bab-Dummad-Isligwaledse gannar atakdemaloed.
\q1 
\v 8 Bar bab-dummad-Baalʼga-ibmar-ogumakar-ukleged-aila-sobsamaladgi binsadosurmalad.
\q2 Bar bab-bundor-Asera-sobarmalad-dakdosurmalad,
\q1 ina-wawad-ogumaked-ailase naosurmalad.
\q2 Ar we-bab-dummagan-ibmarmar e-argangi sobsagusmaladid.
\p 
\v 9 A-ibagine, Israel-e-neggwebur-gandikmaladi, ollobi mellede gumaloed, sapurbi-moodo, negmar-ollobi-mellenaiyobi naguoed. Igi Israel-dulemar Canaán-e-neggweburmargi dognonigusmargu, neg-imaksamala, deyob bela-neg-ollo naguoed.
\q1 
\v 10 Ar bemarde Bab-Dummad-bemar-abonoged be iesmalad,
\q2 Bab-Dummad bemarga-akwasailayob-gued be iedmalad.
\q1 A-ulale, bemar amba ibmar-durba-nuegan digmalo-inigwele,
\q2 amba neggwebur-baidsik-uva-danikid digmalo-inigwele,
\q2 bela boniganba ibmar-gwag isgudoed.
\q1 
\v 11 Amba bemar-uva-digsad bega dungumalo-inigwele, banegi e-durba ainidago-inigwele, bonigan egi nonikoed.
\q2 Ar bemar ibmar-gwag-weemaloedi, bela boniganba ibmar-gwag isgudoed.
\b
\q1 
\v 12 Bukidar dule-yar-baid-baidgi-bukmalad-uurmakbukwadi, ¡duledar-wilesmar!
\q2 Demar-uurmakmaiyobi dulemar uurmakbukwad.
\q1 Dulemar-binnasuli-oimakbukwadi, ¡duledar-wilesmar!
\q2 Dii-wilasailad uurmakmaidyobi dulemar oimakbukwad.
\q1 
\v 13 We-dulemar, demar-uurmakmaid-dagumakmaidyob-damar-inigwele,
\q2 Bab-Dummad ese-binnasur-uludele, duurmakdedamalad.
\q1 Igi yarbali gagan-dinnagana burwa-abin seleddae,
\q2 deyobi, dulemar duurmakdedamalad.
\q1 Igi ukub burwa-binnasur-goledba mileddae,
\q2 deyobi, dulemar duurmakdedamalad.
\q1 
\v 14 ¡Sedogusale, dobed-dummad egi nagusdamalad!
\q2 Oibosale, dule-isganamar bar dakleddasulid.
\q1 Weyob dulemar-anmar-wiodimalad guodo.
\q2 Anmar-ibe dule-ibmar-atursadimaladga, weyob ega igar idu maid.
\c 18
\s1 Etiopía-yargi-yoedse-ibmar-guoedgi sunmaklesad
\p 
\v 1 Isaías sogdebalid:
\q1 “Gwimar-uurmaked-yala, ¡nue-wilessun!
\q2 Cus-diwarba-bukmalad, ¡be duledar-wilesmar!
\q1 
\v 2 Ur-nagwaryob-daklegedgi-sobaledba Nilo-diwarba
\q2 dule-garda-berbemalad-barmimalad, ¡be duledar-wilesmar!
\b
\q1 ”Dule-garda-berbemalad-gandik-nanamalad be gwae-namar,
\q2 dule-mullusurmaladse be namar,
\q1 uka-sichigwadba-uka-dakaar-gamaladse be namar,
\q2 we-dulemar-bela-dobesar-daklemaladse be namar,
\q1 dulemar-gargandikmaladse be namar,
\q2 dulegi-obin-san-sadimaladse be namar,
\q1 yala-emargi-obinsiidse be namar.
\q2 A-yala, diwarmar-iirmakmaid-yalad.
\b
\q1 
\v 3 ”Bemar, bela we-napneggi-bukmalad, yar-imbaba bander-nakwiali be dakalile,
\q2 degi, gar-trompeta-gollali be itoarmalale,
\q1 asiki be atakbukwa imakmalo,
\q2 Napneggi-bela-bukmalad, nue be dakmalo, nue be itomalo.”
\p 
\v 4 Bab-Jehová weyob anga sogsad:
\q1 “Isaías, an-neg-maid-akale, dulemar-nue-dakmai an imakoed.
\q2 An golosulid, bogi-mai an dulemar-dakmai imakoed.
\q1 Dad-ibeler yorgi-duurmaknadaeyobi,
\q2 bogidik-mai an dulemar-dakmai guoed.
\q1 Ibmar-welenaidgi dad-ibeler duurmaknaile, boo-mileardaeyobi,
\q2 bogidik-mai an dulemar-dakmai guoed.
\q1 
\v 5 Ar uva-weleged-iduale, e-dutu batialir, degi, nue-uva-san-nagualir, e-anagan an sike-sike imaknonikoed.
\q2 E-anagan-binigan an sike-sike imakoed.
\q1 
\v 6 Deyobi, bela we-dulemar gumogoed.
\q2 Ibdurgan-sapurbarmaladga miledoed.
\q1 Yorgi, nuu-ibmar-burgwarmalad-gunmalad-masga guoed.
\q2 Dii-wied-ibagangine, bela ibdurgan-sapurbarmalad-masga guoed.”
\p 
\v 7 A-ibagangine, we-dulemar Bab-Jehová-Bela-Gangued-Nikadga ibmar-ukleged sedmaloed. We-dulemarde, dule-mullusurmaladid, uka-sichigwadba uka-dakaar-gamaladid. We-dulemar, bela-dobesar-daklemaladid, dulemar-gargandikmaladid, dulegi-obin-san-sadimaladid. A-yala, diwarmar-iirmakmaid-yalad.
\p A-dulemarde, Bab-Jehová-Bela-Gangued-Nikadga ibmar-ukleged sedmaloed. Sión-yalase ega sedmaloed, bia Bab-Jehová-Bela-Gangued-Nikad-e-nug-obarilege, ase Bab-Jehováʼga ibmar-ukleged sedmaloed.
\c 19
\s1 Egiptoʼgi-yoedse-ibmar-guoedgi sunmaklesad
\p 
\v 1 Egipto-yar-guoedgi iduakwaa sunmaklesad:
\q1 Bab-Jehová be dakmala.
\q2 Mogir-gwae-gwae-iirmakmaid-birgi-sii, Egipto-yalase danikid.
\q1 Egipto-e-bab-dummagan e-abin wawanmakbukwad.
\q2 Egipto-dulemar nue dobe-itomalad.
\p 
\v 2 Bab-Jehová soged:
\q1 “Egipto-dulemar na abin-abin-urwemalaga an imakoed,
\q2 na e-gwenad-e-gwenad-egi-gwisgumalaga an imakoed,
\q1 dulemar-na-e-aimarbo-urwega an imakoed,
\q2 neggweburmar-na-abin-abin-urwemalaga an imakoed,
\q2 yalamar-na abin-abin-urwemalaga an imakoed.
\q1 
\v 3 Egipto-dulemar suli-suli itodamaloed,
\q2 bab-dummadyob-imaklemaladse idakdemaloed.
\q1 Dule-burgwarmalad-e-burbase idakdemaloed,
\q2 bab-dummad-gayaburba-barsoged-bundorse idakdemaloed.
\q1 Yoo-ibmar-guoed-soged-dulese idakdemaloed, anmar ibu imakoye.
\q2 Degi-inigwele, e-igarmar igarga-guega an imakosulid.
\q1 
\v 4 Egipto-dulemargi dule-bulegan yar-seega an imakoed.
\q2 Rey-isgana yar-seega an imakoed.
\q1 Ani Bab-Jehová-Bela-Gangued-Nikad soged.
\b
\q1 
\v 5 ”Demar-naid dingudoed,
\q2 Nilo-diwar-maid bela dinna naoed.
\q1 
\v 6 Dian-akwiar-mamaid sunnasuli yapanne gudoed,
\q2 Nilo-diimar-iirmakmaidi, iremai gudoed, bela dinna naoed.
\q2 Nallayob-daklemaladi, degi, nagwaryob-daklemaladi, bela burgwidoed.
\q1 
\v 7 Nilo-diwar-gakaba ibmar-digarmaladi, bela burgwidoed,
\q2 Nilo-diwar-gakaba ibmar-nanaidi, bela bergudoed,
\q2 bela swiri naoed, bar daklegosulid.
\q1 
\v 8 Bela dule Nilo-diwargi-ua-somaladi, degi, bela saki-miar-ua-gamaladi, bukib binsadmaloed,
\q2 bela bodmaloed.
\q1 
\v 9 Bela dule lino-mor-nued-sobedgi-arbamaladi, degi, saki-sobedgi-arbamaladi,
\q2 suli-suli itodamaloed.
\q1 
\v 10 Ua-galugi-arbamaladi, nue-wiles itodamaloed,
\q2 ar bela e-sakimar itiridoed.
\b
\q1 
\v 11 ”Zoán-neggwebur-e-dummagan, dule-binsaed-ibedye be sogdimalad,
\q2 bemar dule-gegeganad.
\q1 Ar bemar Faraónʼga binsaed-isgana ukdimalad.
\q2 Ar igi yogasaar bemar sogmalosunna:
\q2 ‘Anmar binsaed-ibedye, epenne-reymar-binsaed-ibegan-megismaladse binsaed amismaladye.’
\b
\q1 
\v 12 ”Egipto-rey, ¿be-dule-binsaed-ibegande bega igigudmarsunna?
\q2 Emide, be-dule-binsaed-ibegan bega sogmardo,
\q1 ibu Bab-Jehová-Bela-Gangued-Nikadi, Egipto-dulemargi imaksokali,
\q2 igi-Egipto-dulemar-idu igar-amismaidi, bega sogmarbardo.
\q1 
\v 13 Zoán-neggwebur-e-dummagan dule-binsaedsulidga nadmalad,
\q2 Menfis-neggwebur-e-dummagan ese yamolesmalad.
\q1 We-neggwebur-e-dummagan, Egipto-yala noar sesmalad.
\q2 
\v 14 Ani an Bab-Jehová dule-binsaed-dakmaladgine, suli-suli-neg-itoged-burba egi nasiksad.
\q1 Bela Egipto-dulemar-ibmar-imakedi, noarsaila imakdemalad.
\q2 Igi-dule-mummudi, agar-agar banamakdii,
\q2 debayobi, Egipto-yala banamaksiid.
\q1 
\v 15 Gege bar Egipto-yar-ulale, ibmar imakleged.
\q2 Ar dule-dummagana, dule-ibmar-wismaladi,
\q1 dulamar-bukwadi, degi, sordamala,
\q2 gege bar Egipto-yar-bendakega ibmar imakmalad.”
\p 
\v 16 A-ibagangine, Egipto-dulemar, Bab-Jehová-Bela-Gangued-Nikad sabsur-e-odurdakega egi gwisgualile, omeganyobi dobe itodmaloed.
\v 17 Egipto-dulemar Judá-dulemar-dobe itodamaloed. Ar Judá-dulemargi wis binsadmalale, bato dobed egi nagudmaloed. Ar ade, Bab-Jehová-Bela-Gangued-Nikadi Egipto-dulemar-idu igar-bulegan amisad.
\p 
\v 18 A-ibagangine, Egiptoʼgi neggwebur-gwaatale Canaán-dulemar-gayaba sunmakdemaloed, degi, ise-sogar Bab-Jehová-Bela-Gangued-Nikadga sogdemaloed: Anmar be-sogedba damaloye. A-neggwebur-gwagwenad nugguoed, Herez-neggweburye.
\p 
\v 19 A-ibagangine, Egipto-yalagi Bab-Jehováʼga ibmar-ogumakar-ukleged-aila sigoed. Geb degine, yar-abingunaid-nagaba Bab-Jehováʼga akwa-dummad ogwismarbaloed.
\v 20 Ar a-akwa-dummadi Egipto-dulemarga e-wilubga guoed. Adi, oyogega, Egipto-dulemar Bab-Jehová-Bela-Gangued-Nikad-e-nug odummomarmoye. Ar Egipto-dulemar Bab-Jehováʼse mesagwar-dule-e-imakmaladgi e-ollor-imakega gotemaloed. Bab-Jehová ega dule-e-abonoged, degi, dule-e-ular-gwisgued barmidagoed, adi, mesagwar-dule-e-imakmaladgi ollor-imakegar.
\v 21 A-ibagangine, Bab-Jehová Egipto-dulemar magar-e-dakega imakoed, ede, nue-Bab-Dummad guye. Geb Egipto-dulemar magar daknonimaloed, wede, Bab-Jehová nue-Bab-Dummad guye. Degi, Bab-Jehováʼga ibmar-oburgwar ukdemaloed, ibmar-gwagmar ega ukdemaloed. Bab-Jehováʼga ise-ibmar-imakoye-sogmaloedi, na sogedba ega imakmaloed.
\v 22 Bab-Jehová bonigi Egipto-dulemar-naibi-imaknonikoed, geb a-sorbali, onugubaloed. Geb degi, Egipto-dulemar Bab-Jehováʼba gannar nagudmaloed, degine, Bab-Dummad wile amar-dakoed, degi, onuguoed.
\p 
\v 23 A-ibagangine, Egipto-akale, Asiria-yalase igar-dummad megoed. Geb Asiria-dulemar Egiptoʼse nanabukwa gumaloed, degi, Egipto-dulemar Asiriaʼse nanabukwa gumarmogoed. Egipto-dulemar, Asiria-dulemarbo Bab-Jehová-nug odummobukwa gumaloed.
\v 24 A-ibagangine, yala-sogapaa ambikumaloed: Egipto, Asiria, Israel. Degi, wemar-yalagi neggwebur-bamaladba egi nued binsalegoed.
\v 25 Ar ade, Bab-Jehová-Bela-Gangued-Nikad bela we-yalamargi ise-nued binsaoed, weyob sogdoed: “Egipto an-dulamarga gued. Egi nued binsalesun. Asiria-dulemargi nued binsalesun, ani an urbisad. Degi, Israel-dulemargi nued binsalesun, wedi angadid. Ani an we-dulemar susad.”
\c 20
\s1 Asiria-dulemar Egipto-yala, degi, Etiopía-yala suoed
\p 
\v 1 Ibagwengine, Asiria-e-rey-Sargón, e-sordamar-bila-onoged-e-dummad, e-sorda-bila-onomaladmala, Asdod-neggweburse barmisgusad. Geb agine, Asdod-dulemargi bila-onosgusad, geb egi nakwisadba Asdod-neggwebur-sunonigusad.
\v 2 A-ibagangine, Bab-Jehová Amoz-machi-Isaíasʼga sunmaksad. Weyob ega sogsad: “Wile-itoged-mor-yoid be esue, nag-uka-yoid be ungebali.” Isaías deyob imaksad, uka-swili gudigusad, degi, nag-swili gudigusbalid.
\p 
\v 3 Degine, Bab-Jehová weyob sogded: “Igi an-mai-Isaías birgapaa uka-swili e-abganbi-odukudii gusa, degi, nag-swili gudii gusa, Egipto-yalagi ibmar-guoed-e-wilub oyoged, Etiopía-yalagi neg-guoed-e-wilub oyobalid.
\v 4 Deyobi, Asiria-e-rey, Egipto-dulemar-uka-swili, unnila e-abganbi-odukuale, nag-swili, degi, ber bela sor-daledi, gales sedmaloed. Amba deyobi, Etiopía-dulemar-e-sapingana, degi, e-dulemar-sergan gales seledmarmogoed. A-ulale, bingedar itomaloed.
\v 5 Dulemar Etiopía-dulemargi bensurmaladi, degi, Egipto-dulemarba-san-dummarbaa-imakdimaladi, nue bingedar itodmaloed, nue bela-bela dobe itodmaloed.
\v 6 A-ibagangine, dulemar demar-gakagi-bukmalad sogdemaloed: ‘Be dake, we-dulemar anmar-bendakega gudimalansursi. Ar wemarse anmar, Asiria-e-reygi-anmar-ollor-imakega bendakleged amidimalansursi. Emidi, be dake: ¿Igi anmar bar bendaklegosunna? Anmar bar wakinned, sate.’ ”
\c 21
\s1 Nega-dulesulidgan-demar-dikarba-naidgi yoedse-ibmar-guoed
\p 
\v 1 Bab-Dummad Isaíasʼga nega-dulesulidgan-demar-dikarba-naidgi-neg-guoedi oyosad:
\q1 Neguevʼba burwa-bipirmakaled-nanaedyobi,
\q2 dule-yar-sumalad nega-dulesulidganba-danikidi, bato modanikid.
\q1 
\v 2 Anga yeer-gangue negburgan oyolesad:
\q2 Dule-emar-yardakedi, dule-yardaked.
\q1 Dule-wiogedi, dule-wioged.
\q2 Elam-dulemar, ¡gwichigunae!
\q1 Media-dulemar, ¡oitonae!
\q2 Dule-wile-itogedba-bodimalad bar boega imaklegosulid.
\b
\q1 
\v 3 A-ulale, an-abagan nunmakedba wawanmaked,
\q2 an nunmaked-dummad itoged.
\q1 Sior muu-neggi-ugakgunair abagan nunmakdaeyobi,
\q2 an nunmak itoged.
\q1 An dule-sunmaked-itogedi, suli-suli-ito an-imaked.
\q2 An ibmar-dakedi, dobed-dummad anga uked.
\q1 
\v 4 An aku-itogusad.
\q2 Dobedba an wanwan-itoged.
\q1 Sedogusale, negdambegwad an yeer-itodaenad.
\q2 Emide, aka gwayed anga uked.
\b
\q1 
\v 5 Sorda-dummagan iba-ononanaid,
\q2 mas-bukidar gullenaid.
\q1 ¡Sorda-dummagan, be guagwarmalo!
\q2 ¡Be-sigu-abgamalad be nudakmala!
\p 
\v 6 Ar Bab-Jehová anga weyob sogsad:
\q1 “Dule-nakuleged be ogwicho.
\q2 Bela-ibmar-dakoedi, bega-sogega be imako.
\q1 
\v 7 Moli-ur-bila-onomaladgi dulemar ebo-ebo moli-uayasuigan-birgi-sii-dani be dakalile,
\q2 igi dulemar ebo-ebo moli-yargan-muremalad-birgi-sii-dani be dakalile, yog-gollar be imako.”
\p 
\v 8 Degi, dule-nakuleged binnasuli goted:
\q1 “Dummad, bane-bane nakuleged-neg-suid-niba an nakulegwisguad.
\q2 Mutikidbali, an nakulegwisguad. An bangusisulid.
\q1 
\v 9 ¡Be dake! Dulemar moli-ur-bila-onomaladgi danimalad,
\q2 ebo-ebo danimalad.”
\p Geb dule-gwensak binnasuli goted:
\q1 “¡Babilonia-neggwebur bergus!
\q2 ¡Babilonia-neggwebur bela oitoles!
\q1 Bela ibmar-wilub-sobarmalad e-bab-dummadga-imakmalad napagi omileded.”
\p 
\v 10 Geb Isaías sogded:
\q1 “Sordagan, ibmar-gwagyob napagi-omilede be gusmaladid.
\q2 Israel-e-Bab-Dummad-Jehová-Bela-Gangued-Nikad an-uayagwar anga we-ibmar-sogsadi, an bemarga sognaid.”
\s1 Edom-yala-yoedse-berguoedgi sunmaklesad
\p 
\v 11 Isaías, Duma-yalagi neg-guoedgi iduakwaa sunmaksad:
\q1 Dule anse binnasuli Seir-neggwebur-akale goled:
\q2 “Nakuleged-dule, ¿sana neg-mutikid berguoe?
\q2 Nakuleged-dule, ¿sana neg-ibguoe?”
\b
\q1 
\v 12 Geb an-abin sogded:
\q2 “Neg-ibgued omodani, neg-mutikgued omodanibar.
\q1 Ar be gannar anse egisbiele, gannar egisbalodo.
\q2 Gannar be anse egisbiele, gannar be anse dagodo.”
\s1 Arabiaʼgi-yoedse-neg-guoedgi sunmaklesad
\p 
\v 13 Arabia-dulemargi iduakwaa sunmaklesad:
\q1 Dedánʼginmalad, danar-danar duurmakmadaed,
\q2 nega-dulesulidganba sapur-moodonaidgi ambikumalad.
\q1 
\v 14 Uku-uku-itodimalad-abin be ainimarsun,
\q2 ega be dii ukmarsun.
\q2 Tema-yarginmalad, dule-wakinmamaidga be mas ukmarsun.
\q1 
\v 15 Ar ade, es-suidgi-gwakialidba duurmakmamaid,
\q2 es-suid-daarmakaledgi-gwakialidba duurmakmamaid.
\q1 Ar ade, e-idu warsi yaa-gwichidgi-gwakialidba duurmakmamaid,
\q2 bila-onolegedgi-gwakialidba duurmakmamaid.
\p 
\v 16 Ar Bab-Jehová weyob anga soged: “Birgagwensega, Cedar-yala-e-yeerdakleged an obelogoed. Igi dule-manigi-arbaed birgagi e-arbaed ega bergunonidae, deyobi an imakoed.
\v 17 Dule-sigugi-urwemalad-bulegan-Cedarʼginmalad, napi-ichee durgumaloed.” Ar ade, Israel-dulemar-e-Bab-Dummad-Jehová deyob soged.
\c 22
\s1 Negburgan-Daked-Nebagi yoedse-ibmar-guoed
\p 
\v 1 Isaías, Negburgan-Daked-Nebagi yoedse-ibmar-guoedgi sunmaksad:
\q1 ¿Igi be itomala? Emide, bela bemar neg-uas-birgi be nakwemamaigu.
\q2 
\v 2 Bemar, dulemar-e-itoleged-damalad-neggweburad,
\q1 bemar, oimakedginbi-gudidamaladid,
\q2 ibagibi be negdakdimalad.
\q1 Ar be-dule-burgwismaladi, es-suidgi gwen burgwissurmalad,
\q2 bila-ononanaidgi gwen burgwissurmalad.
\q1 
\v 3 Bela be-dummagandi, danar duurmakdemalanad,
\q2 degi-inigwele, gwen egi warsi-miledsuli galedapmalad.
\q1 Bela be-dulemar-galesmaladi, aisaar wakinye sokarmalanad,
\q2 bela galedapmalad.
\p 
\v 4 A-ulale, Bab-Jehová weyob sogsad:
\q1 “Be angi bangumar.
\q2 Mer be anse gormar.
\q1 Melle an-gwage baisur-itoge be imakmar.
\q2 An-dulamar-bela-bergusad-ular, an boesii imakgwelo.”
\b
\q1 
\v 5 Ar Bab-Dummad-Jehová-Bela-Gangued-Nikad, Negburgan-Daked-Nebaga gwayed-dummad-iba nasiksad,
\q2 suli-suli-itoged-iba nasiksad,
\q1 nug-bipi-gued-iba nasiksad.
\q2 Galu-matusulid-earleged-iba nasiksad,
\q2 yalaganba binnasuli-gordigued-iba nasiksad.
\q1 
\v 6 Elam-yar-sorda-bila-onomalad moli-birgi-sii e-warsi oniarmalad.
\q2 Kir-yar-sorda-bila-onomalad e-sigu-abgamalad oniarmalad.
\q1 
\v 7 Be-neba-yeerdaklemaladgi ur-bila-onomaladi, engus nanaid.
\q2 Sorda-bila-onomaladi, degi, e-molimala, bela neggwebur-yawagak-doged-ebilis bukwad.
\q2 
\v 8 Judá-dulemar bendakleged-sate gudmalad.
\b
\q1 A-ibagine, bemala Sapurba-Neg-Dummad-siidgine,
\q2 bila-onogedgi-gingimar-ebulemalad-bukwadi, be daksagusmalad.
\q1 
\v 9 David-neggwebur-e-galu-matusulid bukidar marar-marale be daksa gusmarbalid.
\q2 Degine, dii-saboleged-urbalid-siidgine, dii be wesmarbalid.
\q1 
\v 10 Jerusalén-negmar-bukwad be ebichismarbalid.
\q2 Galu-matusulid-mararmalad-nudakmalaga, abala, a-negmar-bukwad be earismarbalid.
\q1 
\v 11 Galu-matusulid-abinnidgi, be dia sobsamalad,
\q2 adi, dii dia-epennegwadgi-sabolesiid, dia-soblesadse ogwaegar.
\q1 Degi-inigwele, we-dule-ibmarmar-imaksadgi be binsaed-nikaa gwen gussurmalad.
\q2 Degine, we-dule dikasurgus-we-ibmar-guoed-mesisadi, aku be daksamalad.
\p 
\v 12 Isaías sogdebalid:
\q1 “A-ibagangine, Bab-Dummad-Jehová-Bela-Gangued-Nikadi, boega bemarse gochanad,
\q2 bukib-binsaega bemarse gochanad.
\q1 Sailagia-swiri-saega bemarse gochanad,
\q2 mor-sommed-yoega bemarse gochanad.
\q1 
\v 13 Degi-inigwele, aka bemar weligwar itodmalad.
\q2 Yeer-itogedba be iba onodmalad.
\q1 Moli-bebe-nikad be oburgwidmalad,
\q2 sibad-wawaad be oburgwidmalad.
\q1 Moli-sana be gutemalad,
\q2 vino be gobdemalad.”
\p Degine, be weyob sogdemalad:
\q1 “Anmar mas-gunmala, anmar gobed-gobmala,
\q2 ar anmar banedse burgwemalosursi.”
\p 
\v 14 A-ulale, Bab-Jehová-Bela-Gangued-Nikad an-uayagwar anga weyob sogsad: “We-isguedi an bemarga osulogosulid. Ani, Bab-Dummad-Jehová-Bela-Gangued-Nika-Maid, an soged.”
\s1 Eliaquim, Sebna-muchub dummadga onaklesad
\p 
\v 15 Bab-Jehová-Bela-Gangued-Nikad weyob Isaíasʼga soged: “Sebna be aminae, ar ade, reyneg-daked-dummadid. Ega be weyob sogo:
\q1 
\v 16 ‘¿Ibu be wegi sanai?
\q2 ¿Doa bega igar-uksa neg-uangi be yaa-gwisega?
\q1 ¿Ibiga be nibali ise-sobale be yaa gwisnai?
\q2 ¿Ibiga be akwasailagi nuesaale-megega be yaa gwisnai?
\b
\q1 
\v 17 ” ’Ar Bab-Jehová dikasuli be-barmetoed.
\q2 Dule-gandikid-emar-gaeyobi, Bab-Jehová be-gaoed,
\q2 ise-sabsur be-metoed.
\q1 
\v 18 Ogob-baparmakeyob be-imakoed,
\q2 yar-dummadgi be-balimetoed.
\q1 Agi, be burgoed.
\q2 Agi be-ur-bila-onomalad-yeerdaklemalad bedapoed.
\q2 Be-dummadga binged-dummad be guoed.
\q1 
\v 19 Be-gangi be siidgine, an be-onogoed.
\q2 Be dummadga-maidi, an be-oberguoed.’
\p 
\v 20 ”A-ibagine, an-mai-Hilcías-machi-Eliaquimʼse an goloed.
\v 21 Be-mor-dummad-suid an ega yooed. Be-molidub an ega nasikoed, degine, be-negseed-igar an ega ukoed. Jerusalén-dulemarga, degi, Judá-dulemarga, e-babayob guoed.
\v 22 Rey-David-waganga-ibmar-sogega an ega igar ukoed. Eliaquim igar-ukele, dule igar-gaosulid, gwen dule egi akar sunmakosulid. Eliaquim igar-uksulile, ibmar guosulid.
\v 23 Igi esgoro ise-bioklegar-gwisdae, deyob an Eliaquim dummadga-megega imakoed. Egine, e-neg-yaginmalad nug-gannarba itomaloed.
\v 24 Bela e-neg-yaginmalad egi weligwar-itomaloed, degi, bendakdemarmogoed: E-masmala, e-wagan, bela-e-gwenadgan-bamalad, degine, e-aimarse-bakale, bendakdemaloed.”
\p 
\v 25 Bab-Jehová-Bela-Gangued-Nikad weyob sogbali: “A-ibagine, ani an, Eliaquim, bela-e-gwenadgan, bela dulemar-egi-bengussurmalad obelononikoed. Ani an Bab-Jehová-guedgi, deyob an soged.”
\c 23
\s1 Tiroʼgi-yoedse-neg-guoedgi sunmaklesad
\p 
\v 1 Bab-Jehová Isaíasʼga Tiro-neggwebur-guoedi oyosad:
\q1 Quitim-yar-akale, Tarsis-ur-selaganse gayaburbamar nonikid.
\q2 Tiro-neggwebur bergussiid,
\q1 e-negmar, degi, e-ur-nagumalad, bela ei bibichisad.
\q2 Abali, amar bukib-binsabukwad.
\b
\q1 
\v 2 Tiro-dorgan, boo be ambikumar.
\q2 Sidón-dulemar-ibmar-ukedgi-arbamalad, boo be ambikumar.
\q1 Be-selamar bega ibmar-nuegan-bukidar berbesmalad.
\q2 
\v 3 E-masgullemaladi, Nilo-diwar-e-ana-gwensakgi danikid.
\q1 Tiro-neggwebur, dulemar-yar-baid-baid-bukwadbo, mani-onobukwa gusad.
\q2 Nilo-diwargi-ibmar-gwag-welegedgi mani-amibukwa gusmalad.
\b
\q1 
\v 4 Sidón-dulemar, be bingedar itomarsun,
\q2 bemar, muu-billi-ibedga gumalad.
\q1 Emidi, muu-billi weyob sogsad:
\q2 “An bipisaale gwen abganba an galitodisulid,
\q1 an gwen mimmi bakdisulid.
\q2 An gwen mimmigan odummodisulid,
\q2 an gwen bunamala ibmargi odurdakdisulid.”
\q1 
\v 5 Egipto-yalase, Tiro-neggwebur-bergusad-gayaburba warmaksale,
\q2 Egipto-dulemar Tiro-neggweburga bukib-binsadmaloed.
\b
\q1 
\v 6 Tarsis-neggweburse be namar,
\q2 demar-gakagi-bukwamalad, be bukib-binsamar.
\q1 
\v 7 Tiro-neggweburde, ¿neggwebur-weligwaledinsursi?
\q2 We-neggweburde, ¿bur dikasurgus siidinsursi?
\q2 We-dulemarde, ¿dikasur-aineba bur nanadimaladinsursi?
\q1 
\v 8 ¿Doa Tiro-neggwebur-weyob-guega igar amisa?
\q2 We-neggwebur nuga-nika siidinad.
\q1 E-dulemar-ibmar-ukedgi-arbamaladi, dule-nuga-nikamaladinad.
\q2 Dulemar-ese-ibmar-bakmaladi, bela mag-dakedbimalanad.
\b
\q1 
\v 9 Bab-Jehová-Bela-Gangued-Nikad we-igar mesisad,
\q2 adi, dulemar-nug-gannarba-nikad ei obelogega,
\q2 bela dule-napneggi-nuga-nikamalad-e-nug bipii imakegar.
\q1 
\v 10 Tarsis-dulemar, sapurgi be arbamarsun,
\q2 ar ur-nagumaladde, bela be-ibe bergusad.
\q2 Ar bar bemarse Tiro-urmar dognonikosulid.
\q1 
\v 11 Ar Bab-Jehová muu-billigi e-gangued oyosad,
\q2 dulemar-yar-baid-baidgi-bukmalad-ogwayega imaksad.
\q2 Bab-Jehová, Canaán-neggwebur-gandikmalad-obelogega imaksad.
\p 
\v 12 Degi, Bab-Jehová, Sidón-dulemarga weyob sogsad:
\q1 “Sidón-dulemar, be wese bergunonisun.
\q2 Be-neggwebur-dummad bela bergussun,
\q2 bar be weligwar itogosurmalad.
\b
\q1 ”Ar be Quitim-neggweburse obakmalo-inigwele,
\q2 amba bogidiki gwen be itogosurmalad.
\b
\q1 
\v 13 ”¡Caldea-neggweburgusadi be dakmala!
\q2 ¡Bar we-neggwebur sisulid!
\q1 Ar Asiria-sordamar we-neggwebur bela obelosad.
\q2 Ibmar-durgan-ursilimalad nega-dulesulidganba-gudimalad-e-negga imaksad.
\q1 Neg-matusulid-gandikmalad sobsa gusmalad.
\q2 Reyneg-gandikmalad bela ei earis gusmalad,
\q2 akwamarbi ganna-ganna napi-obesmalad.
\b
\q1 
\v 14 ”Tarsis-ur-selagan bukib-binsabukwamalad,
\q2 ar e-ur-nagumalad bela bergusad.
\p 
\v 15 ”A-ibagangine, Tiro-neggwebur ieles-guoed, bar egi binsalegosulid. Rey-birga-dulapaa-gakambe (70) dula-gudiguedyobi, e-ieleged-iba guoed. Geb birga-dulapaa-gakambegwad-sorba (70), Tiro-neggweburgi, gambasamalad-e-namaklegedyobi egi namaklegoed:
\q1 
\v 16 ‘Gambasaed-ieles-gudiid,
\q2 gar-arpa be sue, neggwebur be ebirnae.
\q1 Namaked-bur-nued be ogolo,
\q2 namaklemalad-bukidar be namako,
\q2 adi, dulemar bee-ebinsamalagar.’ ”
\p 
\v 17 Birga-dulapaa-gakambegwad (70) bergunonikile, Bab-Jehová Tiro-dulemar gannar e-ibmar-ukedgi-arbamalaga imakdebaloed. Degine, bela-neggwebur-baiganbo gannar ibmar-ukedgi arbadmaloed.
\v 18 Ar e-mani-onogoeddina, degi, e-ibmar-ukoeddina, Bab-Jehováʼga ukdemaloed. E-manimar, degi, e-ibmarmar gwen sabolesii guosulid. Ar e-mani-onomaladi, dule-Bab-Jehová-nug-odummomaladga uklegoed, adi, nue-immedik-gudii gumalagar, degi, mor-nuegan-yoi-gudii gumalagar.
\c 24
\ms2 1d. Ibmar-guoed Isaíasʼga-burbar-oyolesad
\mr (24:1–27:13)
\s1 Bab-Jehová napneg-sabsur-odurdakoed
\q1 
\v 1 Dakmalana, Bab-Jehová napneg-swaana imaksad,
\q2 bela napneg obelonaid.
\q2 Bab-Dummad e-dulamar-ononnonaid.
\q1 
\v 2 Bela deyobi we-dulemala gumarmogoed:
\q2 Dule-irwa-Bab-Dummadse-gormalad, degi, bela dulamar.
\q2 Mai-e-dummadga-gudimalad, degi, e-maimar.
\q2 Dummagan-omeganmar, degi, mai-omeganmar.
\q2 Ibmar-ukedgi-arbamalad, degi, ibmar-bakedgi-arbamalad.
\q2 Mani-gaar-ukmalad, degi, dulegi-mani-gamalad.
\q2 Mani-ibegan, degi, dule-wileganamar.
\q3 Wemala, bela deyob gumarmogoed.
\q1 
\v 3 Napanega bela swaanga naguoed,
\q2 bela e-ibmarmar sulegoed.
\q2 Ar Bab-Jehová deyob sogsad.
\q1 
\v 4 Napneg ibitosad, napneg bela-bela oitolesad.
\q2 Dule-gala-ibegan, bela e-gangued bergusad,
\q2 dule-napneggi-nuga-nikamaladi, bela yogguded.
\q1 
\v 5 Napneggi, bela isgued neg-gagasnaid,
\q2 ar ade, e-dulemar, Bab-Dummad-Igar-Maidba gwen nanassurmalad.
\q1 Igar-Maidgi annasmalad.
\q2 Dule bipisaale Bab-Dummad-Ebo-Degisadegu-Igar-Mesisadba gwen nanassurmalad.
\q1 
\v 6 A-ulale, napnega ukabsales naid,
\q2 ar e-dulamar-nukad deyob gusad.
\q1 Agala, soo napneggi aidesad,
\q2 unnila dulemar napi-ichee bukusmalad.
\b
\q1 
\v 7 Uva-nainumar isgus naid,
\q2 vino-binid bar daklesulid.
\q1 Dulemar-yeer-itogedba-namakdidamaladi,
\q2 emidi, bukib-binsaedba ogormakdimalad.
\q1 
\v 8 Damborʼmar-goledi, bergus-nanaed,
\q2 gar-arpaʼmar-goledi, bergus-nanaed,
\q2 dulemar-oimakedi, bela bergusad.
\q1 
\v 9 Namakbukmalale, bar vino gobsurmalad.
\q2 Dule-mummuganga inna-gagbid isguded.
\q1 
\v 10 Neggwebur nue-bergus siid, olloo selenaid.
\q2 Bela neg-yawagakmar, atiar-atiar bubukwad.
\q1 
\v 11 Galimbabali, dulemar vinoʼbina binnasuli oimakdimalad,
\q2 wergulegedi bela bergusad,
\q2 yeer-itolegedi bela yogguded.
\q1 
\v 12 Neggwebur bela-bela nue-bergus sigisad,
\q2 neggwebur-yawagak-dummad bela daas-daas gusad.
\q1 
\v 13 Weyob napneggi dulemar-yar-baid-baidgi-bukmalad imaklemaloed.
\q2 Igi olivo-sapi-san gwallealir, e-san obatega, binnasuli-osiamaklege, deyobi gumaloed.
\q2 Uva-batisbukwayob gumaloed.
\b
\q1 
\v 14 Dulemar napi-ichee-besmaladi, weligwaledbali binnasuli oimakdemaloed.
\q2 Dad-ibeler-argwanedsiki, Bab-Jehová-e-gangued-yeerdakleged weligwaledba oimakmaloed.
\q1 
\v 15 Degisoggu, nebaganba Bab-Jehová-nug be odummomar.
\q2 Demar-gakaba, Bab-Jehová-Israel-dulemar-e-Bab-Dummad-nug be ogannomar.
\q1 
\v 16 Bela napneg-naidgine, anmar namakleged itoged. Weyob soged:
\q2 “Dule-innikigwad odummolesun.”
\q1 Ar andi an sogdo, an duledar-wilesye.
\q2 Bela-bela an nunmak-itogedba, an burgwebied.
\q1 Dule-yardakmaladi, unnila dule-yardakdimalad.
\q2 Dule-yardakmaladi, emar-yardakedginbi binsadimalad.
\q1 
\v 17 Dulemar-napneggi-bukmalad, gwayed-dummad be-edarbebukmalad,
\q2 be-iduar neg-bulegan naid,
\q2 yardakleged-igar be-idu naid.
\q1 
\v 18 Dule gwayed-dummadgi unni-nosale, igar-buleganse galedapoed.
\q2 Dule igar-bulegangi unni-nosbalile, amba yardakleged-igarse galedapbaloed.
\q1 Ar ade, dii-dummad wioed.
\q2 Dii-dummadi napneg-sailagan owawanmakoed.
\b
\q1 
\v 19 Negabandur-dummadi napneg mamaroed,
\q2 napa-daas-daas-imakedse saoed,
\q2 bela napa goa-goa guoed.
\q1 
\v 20 Dule-mummu-banamakdiiyobi, napneg naguoed.
\q2 Neg-uas-baisursunna-ayaredyobi, napneg ayaridoed.
\q1 Dulemar-isguedbali napneg bergudoed,
\q2 napneg gannarse bar guosulid.
\b
\q1 
\v 21 A-ibagangine, Bab-Jehová nibagi-negsemamaid sabsur-odurdakoed,
\q2 napneggi, reymar-yar-semamaid sabsur-odurdakbaloed.
\q1 
\v 22 Esgaryaba odolemaloed,
\q2 agine, mellesii gumaloed.
\q2 Geb sorbali, sabsur-odurdaklemaloed.
\q1 
\v 23 Bab-Jehová-Bela-Gangued-Nikadi, Sión-yalagi, Jerusalén-neggweburgi, gandikid-yeerdaklegedba yala seoed.
\q2 Degiidbali, dad-ibeler sichii nadoed,
\q1 nii sichii nadmogoed.
\q2 E-girmar-dummagan bela Bab-Dummad-e-gangued dakmaloed.
\c 25
\s1 Bab-Jehová-nug-ogannogedgi namaked
\q1 
\v 1 Bab-Jehová, be an-Bab-Dummadid.
\q2 An bega namakoed, an be-nug odummogoed,
\q1 ar be ibmar-gegerdaklemalad imaksad.
\q2 Be-Igarmar epennegwad-akale bela napiragwadbiid, degi, inniki maiguad.
\q1 
\v 2 Neggwebur akwamarbi ganna-ganna be urbisad,
\q2 neggwebur-gandikid, bela oitolesad.
\q1 Dule-bamalad-e-neggwebur bela oitolesad,
\q2 neggweburga bar sigissulid.
\q1 
\v 3 A-ulale, dule-gandikmalad be-nug odummoged,
\q2 a-ulale, neggweburgi dule-gandikmalad be-dobee itomalad.
\q1 
\v 4 Ar be dule-wileged-suli-suli-itodiidga be niga ogannosad.
\q2 Dule-ibmar-abesa-gudiid, be bendaksa gusad.
\q1 Igar-bulegan-idu be, e-bendakedga gusad,
\q2 dad-ibeler-gaed-irwa ibmar-nagueyob ega be gusad.
\q1 Dule-isganamar-e-bunnoedi, burwa-dummad-noeyobi, galu-matusulidgi-gwichigueyobi gued,
\q2 nega-dulesulidganba neg-diopisur-itolegeyobi gued.
\q1 
\v 5 Igi nega-dulesulidganba neg-diopisuli itoledae,
\q2 deyobi, be dule-yar-baidginmalad-oimakedi, bogidik imaked.
\q1 Igi mogir dad-ibeler-idu negsichii imakdae,
\q2 deyobi, dule-bulegan be obeloged.
\p 
\v 6 Bab-Jehová-Bela-Gangued-Nikadi sogded:
\q1 “Sión-yalagine, bela dulemar-yar-baid-baidgi-bukmaladga, an mas-nuegan-yeer-gullemalad bukidar imakoed.
\q2 Vino-nuegan-sunsogmalad an bukidar imakoed.
\q2 Mas-bur-yeer-gullemalad-nuegan, degi, bur vino-sunsogmalad-sulearmalad an imakobaloed.
\q1 
\v 7 Ani we-yalagine, mor-dummad dulemar-odukunaidi, esirmakoed.
\q2 Mor-dummad-dulemar-yar-baid-baidgi-bukmalad-odukunaidi, esirmakoed.
\q1 
\v 8 Ani Bab-Jehová, burgwed-igar degisadegu obelogoed.
\q2 Degi, bela dulemarga ibyanis elioed,
\q1 bela napneggi, e-dulamar-mesagwar-gudiid onogoed.”
\p Ar Bab-Jehová, e-sunnad deyob sogsad.
\v 9 A-ibagangine, weyob sogledagoed:
\q1 “Eye, ar we, anmar-Bab-Dummadid.
\q2 Anmar egi bensulid, ar we, anmar-abonosad.
\q1 We, Bab-Jehová gued, egi anmar bengussulid.
\q2 Anmar wergumarsun,
\q2 Bab-Jehová-anmar-abonosadgi anmar weligwar itomarsun.”
\p 
\v 10 Isaías sogdebalid:
\q1 “Bab-Jehová we-yala akoed,
\q2 Moab-yaladi sabsur-odurdaklegoed,
\q1 igi durgangi annaledii dae,
\q2 deyob Moab-yala imaklegoed.
\q1 
\v 11 Igi dule-dapumaknadapir, sakwa-onakwiddae,
\q2 degine, aka dii-urba dogdedae,
\q1 deyobi, Moab-dulemar e-san-dummarba-itogedbali,
\q2 aisaar sakwa-onakwesii gumaloenad.
\q1 Degi-inigwele, Bab-Jehová, we-dulemar e-san-dummarba-imakmalad ei obelogoed.
\q2 Gannarse we-dulemar barguosulid.
\q1 
\v 12 Bab-Jehová ei galu-matusurmalad, degi, neg-gandikmalad bibisgoed,
\q2 bela napaga obinyoed.”
\c 26
\s1 Isdarmaladgi-nakwedgi-namakleged
\p 
\v 1 A-ibagine, dulemar Judá-yargi we-namaked namakdemaloed:
\q1 “Anmardi neggwebur-gandikid nikamalad.
\q2 Bab-Jehová, neggwebur-gandikidi,
\q2 galu-matusulidyobi, degi, neg-abingaed-gandikidyobi anmar-bendakega imaksad.
\q1 
\v 2 Jerusalén-neggwebur-e-yawagak egamar,
\q2 adi, dule-nuegan innikii-Bab-igargi-nanamalad ubomalagar.
\q1 
\v 3 Dule-beginbi-binsaedi, bogidikidgi-gudisaega be imakoed,
\q2 ar begi bensulid.
\q1 
\v 4 Bab-Jehováʼgi-bensuli be gudii gumar,
\q2 ar Bab-Jehováʼbi akwasailayobi degisadegu gued.
\q1 
\v 5 Bab-Jehová, dule-gannarba-san-sadimaladi sabsur-imaked,
\q2 neggwebur-san-dummarba-imakedi, ogalakued.
\q1 Napase-balimetega imaked,
\q2 napabi-nai imaked.
\q1 
\v 6 Dule-wilegana, degi, dule-nollogana,
\q2 we-neggweburgi dii-dii annamaloed.
\b
\q1 
\v 7 ”Dule-innikimalad-e-igar innikigwadbiid,
\q2 Bab-Jehová, bedi dule-innikigwad gued,
\q2 bee be, dule-innikigwadga igar inniki imaked.
\q1 
\v 8 Bab-Jehová, anmar begi bensurmalad.
\q2 Be-igar-nabolemalad-innikimaladgi bensurmarbalid.
\q1 Anmar begi-binsadii gubied,
\q2 be-nuggi-binsadii gubied.
\q1 
\v 9 Mutikidbali, degi, ibginedbali, an be-amidaed.
\q2 Be igar-innikigwad napneggi ukdele,
\q2 bela dule-napnegginmalad durdakdedamalad, ibi igar-innikigwadi.
\q1 
\v 10 Bab-Jehová, be dule-isganamar wiledakda-inigwele,
\q2 degite, amba igar-innikigwad durdaksurmalad.
\q1 Napneggi dule-nuegan-abargi-gudimar-inigwele, galagwensuli gudimalad,
\q2 Bab-Jehová-Bela-Gangued-Nikadsuliyob be-dakdamalad.
\b
\q1 
\v 11 ”Bab-Jehová, be sabsur-odurdaked-igar guagwar ega be nasiksad,
\q2 ar emardi degite aku dakmalad.
\q1 Be anmar-bela-bela-sabed we-dulemarse be oyoge,
\q2 adi, bingedar itomalagar.
\q2 Dule-isganamar-idu be soo-sisadgi obeloge.
\b
\q1 
\v 12 ”Bab-Jehová, be anmarga bogidikid uked,
\q2 ar bela anmar-ibmar-imakedi, be-ganguedba anmar imaked.
\q1 
\v 13 Bab-Jehová, be anmar-Bab-Dummadid.
\q2 Dummagan-baigan anmar-dummaganga gusmalanad,
\q2 degi-inigwele, anmar bur be-nugbi odummoged.
\q1 
\v 14 We-dummagan bato burgwismalad, bar durguosurmalad.
\q2 Bato napaga gusmalad, bar gwisguosurmalad.
\q1 Ar be we-dummagan sabsur-odurdaksad, bela be obelosad.
\q2 Dulemar melle egi bar binsaega be imaksad.
\q1 
\v 15 Bab-Jehová, be anmar-yala onasguega imaksad,
\q2 be anmar-yala onasgusad, dule-gandikidga be gusad.
\q2 Bela yarmar-abingunanaid-onasguega be imaksad.
\q1 
\v 16 Bab-Jehová, anmar suli-suli-itodigua, anmar bese gochagusad.
\q2 Be anmar-sabsur-odurdaknaigua, anmar ulubgi-nunmaked-abalagi bese gochagusad.
\q1 
\v 17 Igi sior-gurgin-nikad e-boni-itoalile, nunmakedba binnasuli gollardae,
\q2 deyob, Bab-Jehová, anmar be-asabinni nunmakedba binnasuli gorsii gusad.
\q1 
\v 18 Anmar binnasuli bese gochamar-inigwele, degi, nunmakedgi bese gocha-inigwele,
\q2 unnila boniganbi anmar abingasad.
\q1 Gwen anmar napnegse emar-bendaked senonisulid,
\q2 napneggi-dulemar-bukib-bukuega gwen gwalulessurmalad.
\b
\q1 
\v 19 ”Degi-inigwele, Bab-Jehová, be-dula-burgwarmalad gannar dula gudii gumaloed.
\q2 E-muimar gannarse dula gumaloed.
\q1 ¡Dulemar-burgwar-mamaidi, be gwisgumar!
\q2 ¡Weligwaledgi binnasuli be gormar!
\q1 Bab-Jehová, igi be bolegoedba, be-boo-miedi, gaganmar odungudae,
\q2 deyobi, be-dula-burgwarmalad gannar be odulogoed.
\b
\q1 
\v 20 ”¡An-dulamar! Be-negyaba be ubomar.
\q2 Yawagak be edumalo.
\q1 Wis ichee be dukumalo,
\q2 Bab-Jehová e-urwed-berguedse be dukumalo.
\q1 
\v 21 Itoakwaa be bukumalo,
\q2 ar Bab-Jehová e-maidgi noesokalid.
\q1 Dulamar we-napneggi-bukmalad egi isgusadba sabsur-odurdakdasokalid.
\q2 Napnega ablis-aryosadi, oyogoed,
\q2 napnega dulemar-burgwismaladi, bar odukumai guosulid.”
\c 27
\s1 Israel-dulemar-ollor-guoed
\p 
\v 1 Isaías sogded:
\q1 “A-ibagangine, Bab-Jehová, naibe-dummad-Leviatánʼye-nugad sabsur-odurdakoed.
\q2 Naibe-sinni-sinnid-Leviatánʼye-nugad sabsur-odurdakoed.
\q1 Bab-Jehová e-es-suid-gandikidgi,
\q2 degi, e-es-suid-dummadgi achu-simudubaled muu-billi-yagi-maidi oburgoed.
\q1 
\v 2 A-ibagangine, Bab-Jehová weyob sogdoed:
\q2 ‘Uva-nainu-nued-sulealedga be namakmar:
\q1 
\v 3 Ani, an Bab-Jehová, uva-nainu-edarbedga an gued.
\q2 Bali-bali an-uva-nainu an oged.
\q2 Melle dule ani oakalogega, mutikidbali, ibginedbali, an-nainu an edarbed.
\q1 
\v 4 An ese bar urwesulid.
\q2 Ar amba ikomar uva-nainugi nikana,
\q1 gagan-ikobimalad amba uva-nainugi nikana,
\q2 an ebo ulusaled, an bela ogumaksaled.
\q1 
\v 5 Ar Israel-dulemar e-irwar gwisgubi an-abegele,
\q2 anbo igar nudakergebed.
\q2 Anbo igar nabogergebed.’
\b
\q1 
\v 6 ”Yoo ibagan nonikoed, Jacob-wagan ambikunonikoed,
\q2 Israel-dulemar gannar ainidagoed,
\q1 nue-nasgumai gudagoed.
\q2 E-ibmar-nuegan napneg-dirbirmakar-naidgi iirmakmai gudoed.
\q1 
\v 7 Ar igi Bab-Jehová dule-baigan-sabsur-imaksa,
\q2 ¿deyobi Bab-Jehová Israel-dulemar-sabsur-imaksasi? Suli.
\q1 Ar igi Bab-Jehová dule-baigan-ogilosgusa,
\q2 ¿deyobi Bab-Jehová Israel-dulemar-ogilossi? Suli.
\q1 
\v 8 Ar Bab-Jehová e-dula-sabsur-odurdaksad, e-yalagi-bukwadgi onosad.
\q2 Igi burwa-ued nega-dulesulidganba-gordae,
\q2 deyobi, Bab-Jehová, Israel-dulemar-neggwebur-dikasurmaladse-odurdaklegega barmeted.
\q1 
\v 9 Jacob-wagan-e-isgued, weyob osulolenonikoed,
\q2 e-isgued-osulolegegala, weyob imakmalargebed:
\q1 Bela bab-dummagan-e-ailamar-bukwad obelomalargebed,
\q2 we-ailamar, akwasib-ebillegeyob imakmalargebed.
\q1 Deginbali, Jacob-wagan, bab-bundor-Asera-e-wilub bipisaale bar ogwissulirgebed,
\q2 degine, bali ina-wawadikmalad-aila obukusulirgebed.
\q2 Geb degidbali, Bab-Jehová, Jacob-wagan-e-isgued osulogoed.
\b
\q1 
\v 10 ”Ar neggwebur-gandikid-siid bela oitoles siid,
\q2 neg olloo mellesiid.
\q1 Igi-nega-dulesulidganba dule sate, deyobi siid.
\q2 Moli-bebe-nikad-senigwad-gagan-maed-negga guded,
\q1 moli-bebe-nikad-senigwad-obunnoged-negga guded.
\q2 Sapi-gaganmar bela ese bergued.
\q1 
\v 11 Geb sapi dingudele, e-anagan bibichiddaed.
\q2 Geb omegan, sapanga aminonidamalad.
\q1 Ar Israel-dulemar neg-gunaid nue-akusunna itomalad.
\q2 A-ulale, e-Bab-Dummad-e-obinnisadi, we-dulemar-wiledaksulid,
\q2 a-ulale, e-Bab-Dummad-e-obinnisadi, we-dulemarga igi-barsaye sogosulid.”
\p 
\v 12 A-ibagangine, Bab-Jehová, Éufrates-diwar-suke-aryomaid-akale, degi, Egipto-dian-maidse dulemar-egwaoed. Ar bemar Israel-dule-gumaladdi, igi-dule-sapurgi-arbaed ibmar-gwag gagagwen weedae, deyob bemar war-wargwen welemaloed.
\p 
\v 13 A-ibagangine, gar-trompeta-dummad gordagoed. Asiria-yalase, degi, Egipto-yalase, dulemar-galesa-selesgusadi, Jerusalén-Yala-Islidikidse Bab-Jehová-nug odummononimaloed.
\c 28
\ms2 1e. Judá-dulemar, degi, Israel-dulemar-sabsur-odurdaklegoed
\mr (28:1–35:10)
\s1 Efraín-yala sabsur-odurdaklegoed
\q1 
\v 1 Efraín-dule-mummugan san-dummarba-imakdimalad, ¡duledar-wilesmar!
\q2 E-dummagan neba-nued-mullu-birgi dutu-dinnagana-bukwayobi gumalad.
\q2 Dulemar-vinoʼse-ebipiledimalad, ¡be duledar-wilesmar!
\q1 
\v 2 Bab-Jehová dule-gwensak-yeer-gangued, be-idu amisad,
\q2 dule-dutusulid be-idu amisad:
\q1 We-dule, bela ise-urwedgi sabsur-be-imaknonikoed,
\q2 we-dule, dii-gwamakar-wieyobi gangued,
\q1 burwa-dummad-dule-obelogedyobi gangued,
\q2 dii-burwaba-mesa-wiedyobi gangued,
\q2 diwar-dummad-noedyobi gangued.
\q1 
\v 3 Efraín-dule-mummugan san-dummarba-imakdimalad, ¡duledar-wilesmar!
\q2 Egi dii-dii annalegoed.
\q1 
\v 4 We-dutu e-gangued-yeerdaklegedi, neba-nued-mullugwagi-gwichidi, dingudoed.
\q2 Igi higo-san-gorogwad gwallegoed-iduar dule bato daksayalaba, gwandae,
\q1 degi, geb gundae,
\q2 deyobi gumaloed.
\b
\q1 
\v 5 A-ibagangine, Bab-Jehová-Bela-Gangued-Nikadi, e-dula-napi-ichee-bemaloedgala, ologurgin-yeerdaklegedga guoed,
\q2 ibmar-yeerdakleged-bebegi-nagued-gandikidga guoed.
\q1 
\v 6 Bab-Dummadi, dule-igar-nabogedga igar-innikii-imaked-burba ukoed.
\q2 Neggwebur-yawagakgi-nakulemaladga niga-ogannogoed.
\b
\q1 
\v 7 Amba dule-irwa-Bab-Dummadse-gormaladi,
\q2 degi, Bab-Dummad-gayaburba-barsogmaladi,
\q1 vinoʼba bipirmakdemarmogad,
\q2 inna-gagbid ebipiledimarmogad.
\q1 Vinoʼba binsaedsuli nadmalad
\q2 Inna-gagbid-gobedba yoledimalad.
\q1 Negburgan-dakalile, wawanmakdedamalad,
\q2 ibmar-sokarmalale, suli-suli-ito naddamalad.
\q1 
\v 8 Bela mesemar aged-sunnabi bukwad,
\q2 gwen neg daarmakar naisulid, bela isgusnaid.
\q1 
\v 9 Deginbali, an-annik weyob sogmalad:
\q2 “¿Ar wis doamar-odurdaknai itoge?
\q1 ¿Doamarga Bab-Dummad-gayaburba-barsognai itoge?
\q2 ¿Burwigan-gebe-mam-iargusayobi anmargi binsae?
\q1 
\v 10 ¿Burwigan-gebe-garda-absoged-durdaknaidyobi anmargi binsae?
\q2 Gannar-gannar anmarga igar-mamaid sognaid,
\q1 ise-sogar-ise-sogar we-igargi anmar-odurdaknaid.
\q2 Nugmargi gwagwagwen-gwagwagwen anmar-odurdaknaid.”
\b
\q1 
\v 11 Emigindi nabir, ar bemar Bab-Dummadba ibsasulile, Bab-Dummad bemarga gaya-baidba sunmakoed,
\q2 a-gaya bemar aku itomaloed.
\q1 
\v 12 Bab-Dummad bemarga bato weyob sogsa gusad: “Wegine, neg-bogidikid-negad.
\q2 Dule-yegusgudiid wegi obunnogoed.”
\q1 Degi, sogsabalid: “We-neg, obunnoged-negad.”
\q2 Degi-inigwele, bemar gwen itossurmalad.
\q1 
\v 13 Degisoggu, Bab-Jehová, burwigana-gebe-garda-absoalidga-sunmakedyob ega sunmakoed.
\q2 Gannar-gannar ega igar-mamaid sognai guoed,
\q2 ise-sogar-ise-sogar we-igargi amar-odurdaknai guoed.
\q1 Nugmargi gwagwagwen-gwagwagwen amar-odurdaknai guoed.
\q2 Amar nanadmalale, gebe-burwigan-nag-obialidyob gumaloed:
\q1 Yarganba ailadmaloed, nailikgumaloed,
\q2 gege bar gwisgue gumaloed.
\s1 Jerusalén-dulemarse-nuedgi-gorlesad
\q1 
\v 14 Jerusalén-neggwebur-e-dummagan-bingedsulidamalad,
\q2 Bab-Jehová-gayaburba be itomar.
\b
\q1 
\v 15 Ar bemar weyob sogmalad: “Anmar burgwed-igarbo igar amisad,
\q2 anmar burgwed-galubo igar amismalad.
\q1 Boni-dummagan anmargi danikile, anmarse warmakosulid,
\q2 ar ade, anmar-gakansaedi anmar napiragwadyobi daksad,
\q2 anmar-emar-yardakedi anmar igar-nuediyobi daksad.”
\p 
\v 16 A-ulale, Bab-Jehová-Bela-Gangued-Nika-Maid weyob soged:
\q1 “¡Be dakmala! Ani an Sión-yalagi akwa-bur-nued-sulealed negsailaga mesisad.
\q2 Akwa neg-gaega, akwa-nued an ebusad,
\q2 adi, neg gandik sii guegar.
\q1 Ar dule agi bensulile, suli-suli itogosulid.
\q1 
\v 17 Ar ade, we-neg-soblegoedi igar-napiragwad-wilubsaega an imakoed,
\q2 igar-innikigwad-wilub-imakega an imakoed.
\q1 Dii-gwamakar-wimaladi bela bemar-gakansaed-igar-napiragwadyob-imakdimalad obelogoed,
\q2 diimala, bela bemar-neg-dukued odogoed.
\q1 
\v 18 Degidbali, bemar burgwed-igarbo-igar-mesisadi bar igarga-guosulid.
\q2 Burgwed-galubo-igar-amismaladi bar gangued-nika guosulid.
\q1 Boni-dummagan bemargi danikile,
\q2 bela bemargi gwichigunonikoed.
\q1 
\v 19 Be-isdarmalad bemargi-gwichigued-ilibali, ese be bergudii guoed.
\q2 Bane-bane, mutikidbali, ibginedbali, bemargi nanagwichi guoed.”
\b
\q1 Bonigan-daniye itoarmalale,
\q2 bela-belad nue-dobe itodmaloed.
\q1 
\v 20 Gas-bipigwadgi-megeyob gumaloed,
\q2 atued-bipigwadgi-atueyob gumaloed.
\q1 
\v 21 Bab-Jehová, Perazim-yalagi-ulusadyob, uludagoed.
\q2 Gabaón-nebagi e-urwed-oyosadyob, oyodagoed.
\q1 Bab-Dummad bato guagwarmaid,
\q2 ukiarmakale, weyob-ibmar-imakdisulid imakoed.
\q1 
\v 22 Emigindi, bemar melle bar Bab-Jehováʼgi dodomalo,
\q2 adi, melle bur bule be sabsur-odurdaklemalagar.
\q2 Ar Dummad-Bab-Jehová-Bela-Gangued-Nikadi, bela neggweburmar-obelolegoedgi-sunmaksa an itosad.
\b
\q1 
\v 23 Be itomar, nue be an-gayaburba itomar.
\q2 Nue be bogi an-itomar,
\q2 an-ibmar-soged be itomar:
\q1 
\v 24 Sapurgi-arbaed-dule, ibmar-digega napa imued.
\q2 A-dule, ¿obunnosuli napa-imuedginbi alamakdii guode? Suli.
\q2 ¿Unnila bane-bane napa-swaana, degi, gwisar-gwisar imaknai guode? Suli.
\q1 
\v 25 Ar bela napa guakwaa imaksale, ¿gagan-wawagan-gwag-eneldoʼye-nugad mie-mie imakdasursi?
\q2 ¿Ibmar-gwag-cominoʼye-nugad digdasursi?
\q1 Geb a-sorba, ¿ilekwaa-orosgi-dakleged-trigo digdasursi?
\q2 ¿Orosgisaar-dakleged-cebada digdasursi?
\q1 ¿Nainu-gakabali orosgi-saardakleged-centenoʼye-nugad digdasursi?
\q2 Eye, deyob imakdado.
\q1 
\v 26 Ar ade, Bab-Dummad weyob ibmar-imakega dule-odurdaked,
\q2 igi dule ibmar imakoe, aba odurdaked.
\b
\q1 
\v 27 Ar gagan-wawagan-eneldo-gwag, orosyob omukulesulid.
\q2 Ibmar-gwag-cominoʼye-nugad-birgine, e-gwag-oniega ibmar-ukusulid obipirmaklesulid.
\q1 Ar ade, gagan-wawagan-eneldo-e-gwagmar suar-bipigwadgi obateledaed,
\q2 Ibmar-gwag-cominoʼye-nugad suar-nollogwadgi obateledaed.
\q1 
\v 28 Oros-gwagmar omukulenaile, sabsur-ubikwaa imaklesulid.
\q2 Deginbali, ibmar-gwag naglenaidbi geg gued.
\q1 E-birgine, ibmar-ukusulid-nanaega imakleged,
\q2 ar molimardi, ibmar-gwagmar ubimaksulid.
\q1 
\v 29 We-binsaedi, bela Bab-Jehová-Bela-Gangued-Nikadgi danibalid.
\q2 E-binsaed-dakedi, innikigwadid,
\q2 e-binsaed-nikadaedi, sunsogedid.
\c 29
\s1 David-neggwebur-ibitogoed
\p 
\v 1 Bab-Jehová sogdebalid:
\q1 “Ariel-neggwebur, be nue-wilegoed.
\q2 We-neggwebur, David-sorda-ambikusad-negad.
\q2 Gatik birga-irba iba-onodii be nanamar.
\q1 
\v 2 Degi-inigwele, Ariel-dorgan, an begala bonigan onogoed.
\q2 Ar ogormaksii be guoed, bukib-binsasii be guoed.
\q1 Bela neggwebur soose ogumaklegoed,
\q2 ibmar-ogumakar-ukleged-ailagi ibmar-ogumaklegeyob guoed.
\q1 
\v 3 An-sorda-bila-onomalad bela be-ebilis an urboed.
\q2 Bela neggwebur-dikarbali, bila-onoged-galumar an emakoed,
\q2 bila-onoged-aila an be-iduar soboed.
\q1 
\v 4 Mesagwar be imaklegoed,
\q2 napagi mellemai be guoed.
\q1 Be-ibmar-biedi wis-bollee-itolege guoed.
\q2 Be-gayaburba galudor-sunmakedyob itolege guoed.
\q2 Napayala be sunmakmaile, unnila wis bipi-bollee itolege guoed.”
\b
\q1 
\v 5 Be-isdarmalad-ichesulidi, ukub-buruyob guoed.
\q2 Dule-gandikmalad-bukidaradi, gagan-durgan-dinnagana burwaba seleddaedyobi, imaklegoed.
\q2 Ukiarmakagwale, ilagwen-saale imaklegoed.
\q1 
\v 6 Bab-Jehová-Bela-Gangued-Nikadi, bese nonikoed.
\q2 Mala-abalagi, negabandur-abalagi nonikoed.
\q2 Neg-oimakagwaled-abalagi nonikoed,
\q1 burwa-ololed-abalagi, burwa-dummad-abalagi nonikoed.
\q2 Degine, soo-duurmakwichid-abalagi nonikoed.
\q1 
\v 7 Dula-bukidar-yar-baid-baidgi-bukmalad Ariel-neggweburgi-gwisgumaladi, bela e-neg-gandikmalad-ei-earbimaladi, bela neggwebur-ebirdimaladi, bela bergudmaloed.
\q2 Boo-dadabin-berguddaeyobi, bergudmaloed.
\q1 
\v 8 Dula-bukidar-yar-baid-baidgi-bukmaladi, Sión-yalagi-bila-onomaladi, ukudba burgwidmaloed.
\q2 Dule gabidele, na mas-gunsiiye gabdakdamaloed,
\q2 gobsiiye gabdakdamaloed.
\q1 Degi-inigwele, ataas-nadele, ukudmaada itodamaloed.
\q2 Gammu dinare itodamaloed.
\s1 Israel-dulemar burbar aku-atakmalad, degi, wagar-darbo damalad
\q1 
\v 9 Bemar Bab-Dummad-gayaburba-barsogmalad, dule-binsaedsulidyob be gudii gumarsun.
\q2 Dule-aku-atakedyob, ibmar-akudake be gudii gumarsun.
\q1 Mummuyobi be aibandii gumarsun
\q2 Inna-gagbid gobsabayobi be aibandii gumarsun.
\q1 
\v 10 Bab-Jehová bela-belad bar-ibmar-daksuli be-imaksad.
\q2 Bab-Dummad-gayaburba-barsogmalad-ibe burbar-geg-ibmar-dake imaksad.
\q2 Negburgan-dakmalad bar negburgan-daksuli imaksad.
\p 
\v 11 Negburgan-bemarga-oyolegedi, garda-bipirmakaled-sakdigaleyobi guoed, be aku itomaloed. Ar dule-garda-wisidga, we-garda-bipirmakar-maid be uksale, ega be sogele: “Wis be anga absoye.” We-dule, be-abin weyob sokaliled: “An bega absogosurye. Ar ade, sakdigar maiddeeye.”
\v 12 Ar dule-garda-wissulidga, we-garda-bipirmakar-maid be ukye sogele, ega be sogele: “Wis be anga absoye.” We-dule, be-abin weyob sokaliled: “An garda wissur-absoye.”
\p 
\v 13 Bab-Jehová weyob Isaíasʼga sogded:
\q1 “We-dulemar an-nug-odummoye soged.
\q2 E-sunmakedgi an-nug-ogannoye soged.
\q1 Degi-inigwele, unnila asginbi an-nug odummomalad.
\q2 E-gwage-ulubgindi angi gwen binsasurmalad.
\q1 An-dobee-nanaye-sogmaladi, ar gwen an-igar-maidba nanasurmalad.
\q2 Unnila dulemar-igar-mamaidba nanamalad.
\q1 
\v 14 A-ulale, we-dulemar gannar ibmar-gegerdaklemalad-dakega an imakoed,
\q2 geb geger dakdemaloed.
\q1 E-dule-binsaed-ibegan e-binsaed-nikadi, an ei osulogoed,
\q2 degi, e-dule-nue-ibmar-wismalad ibmar-wissulidga an imakoed.”
\b
\q1 
\v 15 Dulemar Bab-Jehová-idu-dukumaloye-na-bimaladi, ¡be duledar-wilesmar!
\q2 E-igar-dukuar-imakdimaladi, negsichigi igar-isgana-imakdimaladi, ¡be dule-wilesmar!
\q1 Ar we-dulemar na binsadimalad:
\q2 “¿Ar doa anmar-dakoe? ¿Doa anmar-wisguoe?
\q1 Gwen dule anmar-dakosuli.
\q2 Gwen dule anmar-wisguosuli.”
\q1 
\v 16 ¡Ibiyob be gakansadamala!
\q2 ¿Ar dule-napsagi-arbaed, napsabo emarsi?
\q1 Ar ibmar-soblesadde, dule-e-sobsadga sogosi:
\q2 “Be an-sobsasuli.”
\q1 Napsa-sobaled, sunna dule-napsagi-arbaedga sogosi:
\q2 “Amba be ibmar wissuli.”
\q2 Suli, gege deyob soged.
\s1 Israel-dulemar abonolegoed
\q1 
\v 17 Líbano-yala emisgwasaale, napa-nuedga guoed, gadi-ibmar-sanmakedga guoed.
\q2 Napa-gadi-ibmar-sanmakedi, sapurga naguoed.
\q1 
\v 18 A-ibagangine, uaya-satemaladi, dule ega garda-bipirmakar-maid absoalile, magar itodmaloed.
\q2 Dule-ibyasurmaladi, magar atakdemaloed,
\q2 negasichid bar ega naguosulid.
\q1 
\v 19 Dule-wilemaladi, gannar Bab-Jehováʼgi yeer-itodmaloed,
\q2 dule-ibmar-abesa-gudimalad Israel-e-Bab-Jehová-Isligwaledgi weligwar-itodmaloed.
\q1 
\v 20 A-ibagangine, sabsur-dule-imakmaladi, dule-isgudimaladi, bela yoggudoed.
\q2 Ibmar-isgana-saedginbi-binsadidamaladi, bela obelolegoed.
\q1 
\v 21 Yogabinne-dulegi-gakansaar-gwisgumaladi, dule-igar-nabomalad-yamoged-dulemala,
\q2 degi, dule-e-bendaked-satedgi yamo-gakansaale-sunmakmaladi, bela obelolegoed.
\p 
\v 22 A-ulale, Bab-Jehová Abraham-bendaksadi, weyob Jacob-waganga soged:
\q1 “Emi-iba-onodoedgi, bemar Jacob-wagan bar bingedar itogosulid,
\q2 dobedba bar niga-argwanosulid.
\q1 
\v 23 Israel-e-mimmigan bela e-dulemargi an-ibmar-imaksad magar daksamalale, bela an-nug-odummodmaloed,
\q2 degi, bela Israel-dulemar Jacob-e-Bab-Dummad-Isligwaled-nug odummodmaloed.
\q2 Israel-e-Bab-Dummadgine binsaed-nikaa gudmaloed.
\q1 
\v 24 Dulemar aku-neg-itodimalad, magar neg-itoge namaloed.
\q2 Dule-geg-boo-gudidamaladi, an-igar-maid itodmaloed.”
\c 30
\s1 Dule-uayasatemalad, duledar-wilesmar
\p 
\v 1 Bab-Jehová weyob sogsad:
\q1 “Bemar-uayasuli-damaladi, ¡be duledar-wilesmar!
\q2 An-wissuli-igar-imakmaladi, an-ega-ibmar-sogsulidba ibmar-imakdimaladi, isguedginbi-nanadimaladi, ¡dule-wilesmar!
\q1 
\v 2 Anse-idaksuli Egipto-yalase igar amibukmalad.
\q2 Faraónʼgi bendakleged-amiega ese naddamalad.
\q2 Egipto-dulemargi bendakleged amibukmalad.
\q1 
\v 3 We-Faraón-be-bendakedi, be-bingeguega guoed
\q2 Egipto-dulemargi be dukued-amiedi, nug-bipii be-imakoed.
\q1 
\v 4 Zoán-neggweburgi e-dummagan ega mamai-inigwele,
\q2 Hanes-neggweburse e-garda-berbemalad mosa-inigwele, gwen bendakosurmalad.
\q1 
\v 5 Bela Israel-dulemala, neggwebur ega ibmar-nued-imaksulidba bingedar itodmaloed.
\q2 Ar Egipto-dulemar wis gwen ega ibmar-nued imakosulid.
\q1 Unnila we-dulemala, emar-obingegsaedginbi binsadimalad,
\q2 dulemar-isdar-obelogedgi binsadimalad.”
\p 
\v 6 Isaías sogdebalid: “Bab-Jehová weyob Neguev-e-ibmar-durgan-guoedgi sunmaksad:
\q1 ‘Israel-dulemar, Egipto-yalase bela e-ibmar-nuegan, moli-uayasuidgi semamaid,
\q2 bela e-manimar moli-yargan-muregedgi semamaid.
\q1 Nega-dulesulidganba obakmamaid,
\q2 ar ade, nega-bulegan naed,
\q1 ar a-nega, achumigur-bulegan nika-naed,
\q2 naibe-bulegan nika-naed,
\q2 degi, naibe-gukuar-gukuar-nanamalad nika-naed.
\q1 
\v 7 Egipto-neggwebur gwen emar-bendakosulid.
\q2 A-ulale, weyob an bied:
\q2 Ibdula-ursiliye, gwen dule-oakalosulidye.’ ”
\p 
\v 8 Bab-Dummad weyob Isaíasʼga sogdebalid:
\q1 “Emisgwa be, we-ibmar dulemar-wagab narmak.
\q2 Urgogi be narmakar-omeso,
\q2 adi, ibagan-danikoed-idu degisadegu narmakar-oyomai guegar.”
\p 
\v 9 Geb Isaías sogdebalid:
\q1 “Ar we-dulemar uayasulidamalad, dule-isgana gumalad,
\q2 Bab-Jehová-Igar-Maid itobisurmalad.
\q1 
\v 10 Emide, dulemar-yoedse-ibmar-guoed-sogedga sogdamalad:
\q2 ‘Melle bar be negburgan-daked sogmarye.’
\q1 Bab-gayaburba-barsogmaladga sogdamarbalid:
\q2 ‘Melle bar be anmarga Bab-Dummad-gayaburba-napiragwad sogmarye.
\q1 Binsa nabir ibmar-nuegangi be anmarga sunmakmarye,
\q2 binsa gakangi be anmarga sunmakmarye.’
\q1 
\v 11 Muchub-muchub sokarmalad:
\q1 ‘Bab-Igargi be bangumar,
\q2 melle Bab-Dummadba be ibsamar.
\q2 Melle bar be anmarga Israel-dulemar-e-Bab-Dummad-Isligwaledgi sunmake.’ ”
\p 
\v 12 A-ulale, Israel-dulemar-e-Bab-Dummad-Isligwaled weyob soged:
\q1 “An-bemarga-ibmar-soged be itobisurmalad,
\q2 mesagwar-gued bur be abemalad.
\q1 Igar-isgana bur be itodmalad.
\q2 Bur be we-igar-isganaba be akasmalad.
\q1 
\v 13 A-ulale, we-isguedi, bemargi gwichiguoed.
\q2 Igi-galu-matusulid marar-gwichile, ukiagwar ailaddae,
\q1 deyob bemargi isgued gwichigudagoed.
\q2 Ukiagwale, ilagwensaale bemargi babatedagoed.
\q1 
\v 14 We-isguedi, napsa-bormo ise bela-belad goa-goa-mareyob guoed.
\q2 Igi napsa-bormo bipisaale, gwen e-goa bar sogun-weega abelesurdae,
\q1 igi bar diagi dii-weedga ebulesurdae,
\q2 deyob we-isgued guoed.”
\p 
\v 15 Ar weyob Bab-Jehová-Israel-dulemar-e-Bab-Dummad-Isligwaled soged:
\q1 “Dule e-isguedga-bukib-binsaedgi bendaklegoed,
\q2 nued-nanaedgi, bendaklegoed.
\q1 Bargaagwar-gudiidgine, degi, angi-bensuli-nanaedgine, gannaleged siid.
\q2 Ar degi-inigwele, bemar an-abesulid.
\q1 
\v 16 Ar bemardi weyob sogmalad: ‘Anmar moligi wakinmaloe.’
\q2 Degisoggu, deyob bemar wakinmalargebdo.
\q1 Bemar weyob sogmarbalid: ‘Moli-gwae-gwae-abarmakedgi anmar wakinmaloe.’
\q2 Degi-inigwele, dule-be-baleginmaloedi, beba bur bule abarmake gumaloed.
\q1 
\v 17 Dule-gwensak-bemar-oburgwebied-asabinni, bemar-milibalidi (1,000), dobedba duurmakdemaloed.
\q2 Dule-e-ataled-bemar-oburgwebied-asabinni, bela bemar, dobedba duurmakdemaloed.
\q1 Igi yar-birgi suarbi ganna-gwisdae,
\q2 deyobi be gumaloed.
\q1 Igi-yar-mullugi ibmar-wilub gwisdae,
\q2 deyobi bemar napi-bemaloed.
\q2 Deyobi bela neg-olloo nadoed.”
\s1 Bab-Dummad Israel-dulemarga wiledaked-igar mesisad
\p 
\v 18 Isaías sogdebalid:
\q1 “Degi-inigwele, Bab-Jehová, wile-bemar-dakegala, bemar-abitomaid.
\q2 Bemarga e-sabgued-nikadi, oyobied.
\q1 Ar Bab-Dummad-Jehová, igar-innikigwad imakedid.
\q2 Dule-Bab-Dummadgi-bensuli-gudimaladgi, nued binsalesad.”
\p 
\v 19 Sión-dulemar Jerusalén-neggweburgi-mamaid, bipisaale, bar be boosurmalad. Bab-Dummad be-bendakega ese binnasuli be gornanaile, Bab-Dummad-dule-wiledakedi, wile be-dakoed. Be-itosayalabali, be-abinsaoed.
\v 20 Ar Bab-Jehová igar-bulegan bemarga barmidago-inigwele, degi, wile-itoged-ibagan bemarga barmidago-inigwele, be-odurdaked-saila bar bemargi dukuosulid, bemar-sunnagwad be dakmaloed.
\v 21 Ar be igar-noar aibatedibele, be-yarganbali dule bese-gole be itogoed, weyob bega soge be itogoed: “Noar be aibatemala, wesik igar-mai. Wesik be namala.”
\v 22 Degisoggu, be-ibmar-sobarmalad-bab-dummadyob-imaklemalad-manibiidi, be-ibmar-wilubgan-orbimaladi, bela ibmar-isedyob be metemaloed. Be sogdemaloed: “Wegi-bukwad be nae.”
\p 
\v 23 Degisoggu, be ibmar-gwag digele, Bab-Jehová bemarga dii barmidagoed. Ibmar sanmakdagogu, nue-sanmakoed, degi, yeer-gullemaladbi guoed. A-ibagangine, be moli-bebe-nikamalad nainu-dummagangine, gagan-madii gudoed.
\v 24 Moli-bebe-nikad-alugwasuarmalad, degi, moli-uayasuigan be-nainugi-arbamaladi, gagan-nuegan bato egwaar-guagwar-bukwad-madii gumaloed.
\v 25 Bab-Dummad be-isdarmalad-obeloged-ibagine, e-neg-suigan ayaridele, yala-matusurmaladbali, degi, bela yala-mulluganbali dianmar megidoed, diimar iirmakdoed.
\v 26 A-ibagangine, Bab-Jehová bemar-nailikgusmalad bemarga nudakoed, ar bemar e-dulaga gumalad. Nii-gaedi, dad-ibeler-gaeyob mee gadoed, degi, dad-ibeler-e-gaedi, ilagugle-wilub bur bule mee-gaeyob (7) gadoed. Dad-ibeler-gwagugle-mee-ganaiyob (7) dad-ibeler gaoed.
\s1 Bab-Jehová Asiria-dulemargi gwichigusad
\p 
\v 27 Isaías sogdebalid:
\q1 “Be dakmar, Bab-Jehová-sunnagwad bannaba-dikasuli danikid.
\q2 E-urwedi, soo-gwabunye-gwichidyobi, waa-bupurmakgwichiyob danikid.
\q2 E-gaya, degi, e-gwabin-duku, soo-ginnitibi-gwichiyobi dakleged.
\q1 
\v 28 Bab-Dummad-e-ibmar-sogedi, diwar-nollosur-uurmakmaid-neg-odogeyob gued.
\q2 Bab-Dummadi, dulemar-yar-baid-baidgi-bukmalad-oros-omukueyobi-imakega danikid,
\q2 adi, bela obelogega danikid.
\q1 Moli-gaya-bargaed-yoiyobi dulemar imaksad,
\q2 adi, igar-baidsig sedegar, adi, yoggumalagar.
\q1 
\v 29 Ar bemardi, Islidikid-Iba-onolegedgi-namaklegedyob namakdemaloed,
\q2 gwage-ulubgi, be weligwar-itodmaloed.
\q1 Igi dule, Bab-Jehová-yalase-nadapile, Bab-Jehová-Israelʼga-akwasailayobi-guedse-nadapile,
\q2 gar-gammu ogornadapdae, deyobi bemar itomaloed.
\b
\q1 
\v 30 ”Bab-Jehová, e-gayaburba-gandikid-itomalaga dulemar-imakoed.
\q2 Bemarga e-gangued weyob oyogoed:
\q1 Soo-ginnitibi gwichigudoed,
\q2 malamar aidedoed,
\q1 diimar suamakdoed,
\q2 dii-gwamakarmaladi babatidagoed.
\q1 
\v 31 Bab-Jehová e-gayaburbaba, Asiria-yala obelogoed.
\q2 E-ganguedba obelogoed.
\q1 
\v 32 Bab-Jehová we-dulemar-sabsur-odurdaked-ilibali, gar-panderoʼmar gotoed,
\q2 degi, gar-arpaʼmar gotoed.
\q1 Bab-Jehová Asiria-dulemarbo-urwenaile,
\q2 e-sakwa minaidbioed.
\q1 
\v 33 Ar Bab-Jehová, Asiria-dulemarga, degi, e-reyga, sabsur-odurdakleged-neg bato dikasurgus guagwar sisad.
\q2 Yaa-dummad-matusulid-yabali soo-duurmaked sobsad,
\q1 degi, sapanmar-ichesuli urbisad.
\q2 Bab-Jehová soogi buu imakdogu, soo-azufre-gwabunye-gwichiyobi, gadoed.”
\c 31
\s1 Egipto-dulemargi-bensurmaladi, duledar-wiles
\p 
\v 1 Isaías weyob sogded:
\q1 “Egipto-dulemarse-bendakleged-amibukmaladi, ¡duledar-wilesmar!
\q2 Egipto-molimargi-bensurmaladi, degi, e-moli-ur-bila-onomalad-bukidar-nikadgi-bensurmaladi, ¡duledar-wilesmar!
\q1 E-sorda-bila-onomalad-ganguedgi bensurmaladi, ¡duledar-wilesmar!
\q2 Ar Israel-dulemar-e-Bab-Dummad-Isligwaleddi baisur-dakmalad,
\q2 ar Bab-Jehová-amiedgindi gwen binsasurmalad.
\q1 
\v 2 Degi-inigwele, dule Bab-Dummad yamogosulid,
\q2 ar ade, dule-binsaed-ibed maid.
\q1 Boni-dummagan barmidagoed,
\q2 ar ibmar-sogsale, sogedba imakedsedaed.
\q1 Bab-Dummadi, dule-isganamar-e-neguyagi gwichiguoed,
\q2 dule-ibmar-isgana-imakmalad-bendakdamaladgi gwichiguoed.
\q1 
\v 3 Ar Egipto-dulemardi, unnila dule gumalad, Bab-Dummadsurmalad.
\q2 E-molimala, sanakwaa gumalad, burbarsurmalad.
\q1 Ar Bab-Jehová, e-ganguedba dulemar-sabsur-odurdakdele,
\q2 dule-isgana-bendakmalad-obelogoed,
\q1 ese-bendaklesmarmogad-obelobaloed,
\q2 bela ebobela bergumaloed.”
\p 
\v 4 Bab-Jehová weyob anga sogsad:
\q1 “Igi achumigur-nono-wawaad sibad-wawaad-gasa-uurmaknaile,
\q2 dule-sibad-edarbemalad ese urwed itodasuli,
\q1 degi, igi-achumigur-nono-wawaad-senigwad mas-gasa-uurmaknaile,
\q2 dulemar ogwayenaile, gwen dobdasuli,
\q1 deyobi, ani an-Bela-Gangued-Nikadi, Sión-yalabina-urwega,
\q2 e-yar-mulluganbina-urwega, an aidenonikoed.
\q1 
\v 5 Igi-nuumar e-mimmigan uugi-bukwale, edarbesidae,
\q2 deyobi, ani Bab-Jehová-Bela-Gangued-Nikadi, Jerusalén-dulemar-edarbemogoed,
\q1 dule-isganamargi ollorsaoed,
\q2 e-ular gwisguoed, bendakoed.”
\p 
\v 6 Israel-dulemar, ar doagi bemar dummad-nosmala, ase be gannar namarsun.
\v 7 A-ibagangine, bemar war-wargwen, bab-dummadyob-imaklemalad-manigi-sobaled, degine, orbi-sobaled, be metemaloed. Bab-Dummadgi-yolediidba bemar-sunnagwad be sobsagusmalad.
\p 
\v 8 Bab-Jehová weyob soged:
\q1 “A-ibagine, Asiria-dulemar es-suidgi burgwemaloed,
\q2 degi-inigwele, dulemar imakosulid.
\q1 Es-suidgi-wakinnegala, duurmakdemaloed.
\q2 E-sapingan-bila-onomaladdi, maiga imaklemaloed.
\q1 
\v 9 E-rey bela-belad nue-dobe itodoed,
\q2 e-dummagana e-bander-ies wakitemaloed.”
\q1 Bato guagwar Sión-yalagi Bab-Jehová-e-soo gasiid,
\q2 Jerusalén-neggweburgi soo-yaa-matusulid bato dule-isdarmalad-idu guagwar siid.
\c 32
\s1 Rey-innikigwad yar-seoed
\q1 
\v 1 Be dakmar. Rey-wargwen innikigwadba yar-seoed,
\q2 degi, dummagan-neggwebur-semaladi, napiragwadba negsemaloed.
\q1 
\v 2 Dummagan-neggwebur-semaladi, burwa-irwa dulemar-odukueyobi, dulemarga gumaloed.
\q2 Burwa-dummagan-noed-irwa dulemar-odukueyobi, ega gumaloed.
\q1 Neg-dinnagwadba dian-maidaeyobi, ega gumaloed.
\q2 Nega-dulesulidganba akwa-dummad-negsichi-imaksidaeyobi, ega gumaloed.
\b
\q1 
\v 3 Bela-belad nue-nakuledii gumaloed,
\q2 nue-bogimakar dulemar-sunmaked-itodii gumaloed.
\q1 
\v 4 Nue-itoakwaa ibmar-imake gumaloed.
\q2 Nuekwa-sunmake, magar-nue-neg-itoge gumaloed.
\q1 
\v 5 Dulemala, dule-binsaedsulidaed dule-nuga-nikadye bar biosurmalad.
\q2 Gadi-dule-yamogedi, sae-dakledoed.
\q1 
\v 6 Ar dule-binsaedsulidaedi, binsaedsuli sunmaked, yogasaar sunmaked.
\q2 Igar-isganaginbi binsadidaed,
\q2 igar-isganabi imakdidaed.
\q1 Bab-Jehováʼgi gakansaar sunmakdidaed.
\q2 Dule-masgunbigudiid ogunbidasulid,
\q2 dule-ukudmaada-itodiid ogobbidasulid.
\q1 
\v 7 Gadi-dule-yamogedi, dule-yamogedgi alamakdidaed,
\q2 igar-isgana-imakedgi alamakdidaed,
\q1 e-gakansaedgi dule-wilemalad-wiodidaed.
\q2 Dule-gakansaedi, dule-ibmarbina-sogdiid ega igar-naboye-gordidamaladga, gakansadidaed.
\q1 
\v 8 Ar dule-nuga-nikaddi, degisulid.
\q2 Igar-nueganbi imakdidaed,
\q2 e-igar-nuegan-imakedba e-nug dunguoed.
\s1 Jerusalén-omeganga iduakwaa ibmar soglesad
\q1 
\v 9 Omegan-gwen-bai-itosurmalad, ¡be nue an-itomar!
\q2 Bunamala-gwen-bai-binsadisurmalad, an bemarga-ibmar-sogoedi nue bogimakar be an-itomalo.
\q1 
\v 10 Emide, bemar bela nueganbi-bukwa daklemalad,
\q2 birgagwensega bemar, dobedba-wawanmakdemaloed.
\q1 Ar ade, uva-sanmar bar welegosulid,
\q2 ibmar-gwagmar bar welegosulid.
\q1 
\v 11 Omegan-gwen-bai-itosurmalad, ¡be nue dobee itomarsun!
\q2 Bemar-baisur-itodimalad, ¡dobedba be wawanmakmarsun!
\q1 We-mor be yoimalad esumarsun,
\q2 wile-itoged-mor be yomarsun.
\q1 
\v 12 Nainu-yeerdaklege-naidga, degi, uva-nainu-nuegan-naidga,
\q2 be bukib-itogedba binasgar be bibyomarsun.
\q1 
\v 13 Degine, an-dulamar-e-yar ikomar-yaisulidga gudoed,
\q2 gagan-ikobimalad-yaisulidga gudoed.
\q1 Deginbali, bela neg-yagi weligwar-gudimaladga,
\q2 neggweburgi ibabi-dakdimaladga be wile-itomarsun.
\q1 
\v 14 Ar reynegmar olloo melledoed,
\q2 dulemar-neggwebur bela olloo sigoed.
\q1 Reyneg, degi, neg-gandikmalad, akwa-dummagan-ollogan-bukwayobi degisadegu bukuoed.
\q2 Sapur-moli-uayasuid-obunnoged-negga guoed,
\q2 sibadmar-mas-maed-negga guoed.
\q1 
\v 15 Geb Bab-Dummad-Burba anmargi aidenonikoed,
\q2 nega-dulesulidi, napa-nuedga gudoed,
\q2 napa-nuedi, nainu-nued-daklege nadoed.
\q1 
\v 16 Degisoggu, bela neggweburmar-ilibali,
\q2 igar-napiramalad, degi, igar-innikimalad oyolemai guoed.
\q1 
\v 17 Igar-napiragwadi, bega gwage-bogidikid ukoed.
\q2 Baisur-itoge be-imakoed,
\q2 degisadegu dobsuli-nanadii be-imakoed.
\q1 
\v 18 An-dulamar neg-bogidikidgi-gudii gumaloed,
\q2 nega-nuedgi-mamai gumaloed,
\q2 neg-boo-itolegedgi-obunnomamai gumaloed.
\q1 
\v 19 Ar amba sapurdi egi dii-gwamakaled babatidoed-inigwele,
\q2 bela neggwebur ibitogoed-inigwele, bemargindi nued binsalemarsun.
\q1 
\v 20 Bemar, dii-gakanaba-ibmar-digmaladi, moli-bebe-nikad-alugwasualed-esikar-imakdimaladi,
\q2 degi, moli-uayasuid-esikar-imakdimaladi, bemargindi nued binsalemarsun.
\c 33
\s1 Bab-Jehováʼgi abonoleged danikid
\q1 
\v 1 Asiria-dulemar-dule-wiodimalad, gwen be wioledisulidi, ¡be duledar-wilesmar!
\q2 Asiria-dulemar-dule-yamodimaladi, gwen be yamoledisulidi, ¡be dule-wilesmar!
\q1 Be dulemar-obelosale, be bergumarmogoed.
\q2 Be dulemar-yamosale, be yamolemarmogoed.
\b
\q1 
\v 2 Bab-Jehováʼye, wile be anmar-dake.
\q2 Ar anmar begi bendakleged edarbediid.
\q1 Bane-bane wakudaryalabali, anmarga be niga-ogannoged.
\q2 Suli-suli-itoged-ibagine, anmar-abonogega be gued.
\q1 
\v 3 Be-gayaburba mala-goledyob-goledbali,
\q2 dulemar gwakiar duurmakdedamalad.
\q1 Be-gangued be oyodele,
\q2 dulemar-yar-baid-baidgi-bukmalad aisakiddamalad.
\q1 
\v 4 We-dulemar-e-ibmar-nikadgi, e-isdarmalad ses-burwigana-bateyobi egi nonimaloed.
\q2 E-ibe bela ibmar-nuegan sunonimaloed.
\b
\q1 
\v 5 Bab-Jehová-e-nug odummolegoed,
\q2 ar nibneggi negdakmaid.
\q1 Bab-Jehová, igar-innikigwad-imakega Sión-yala-imakmaid,
\q2 emarga-ibmar-nabir-guega imakmaid.
\q1 
\v 6 Bab-Dummadi, dobsuli-gudiguega anmar-imaked.
\q2 E-binsaed-nikadaed, degi, bela e-ibmar-wisid,
\q1 bela-bela bendakleged anmarga uksad.
\q2 Bab-Jehová-dobee-nanaedi, anmarga ibmar-nuedga gued.
\b
\q1 
\v 7 Be nue dule-gandikmalad-gordidiid itomar,
\q2 ibiyobi neg-galimbaba binnasuli oimakdemala.
\q1 Neg-bogidik-saedgi-sunmakdimaladi,
\q2 bela-belad ogormakdemalad.
\q1 
\v 8 Dulemar bar igarba daklesulid, igar-ollo maid,
\q2 dulemar bar igarba iirmaksulid.
\q1 Na-ebo-igar-mesismaladi bichismalad.
\q2 Dulemar, dule-we-igar-maid-wismalad isdar dakdemalad.
\q2 Dulemargi bar binsaed-nika dasurmalad.
\q1 
\v 9 Bela dulemar bukib-binsaedbimalad,
\q2 Líbano-yala bela dinguded, e-dakleged bela yogguded.
\q1 Sarón-neba bela nega-dulesulidga naded.
\q2 Basán-yala, degi, Carmelo-yala, e-yeer-ara-ara-dakleged yogguded.
\p 
\v 10 Bab-Jehová weyob soged:
\q1 “Emisgindi, an ibmar imakgwersunno.
\q2 Emisgindi, an-nug odummolesunnoed,
\q2 emisgindi, an-nug ogannolesunnoed.
\q1 
\v 11 Asiria-dulemar igar-amimaladi, unnila e-igarmar binsaledga gued,
\q2 igarmar-isganaga gued.
\q2 Ar an buu imakdogua, bergudoed.
\q1 
\v 12 E-sorda-bila-onomaladi, ikomar-sooyagi-gummaknaidyobi, gumaloed.
\q2 Bela burubi gumaloed.
\b
\q1 
\v 13 ”Bemar, dikasuli-bukwamalad, an ibmar-imaksad, be nue itomar.
\q2 Bemar, itaka-bukmalad, an-gangued be dakmar.
\q1 
\v 14 Dule-isgumalad Sión-yalagi dobe itobukmalad.
\q2 Dule-isganamar dobedba wawanmakbukmalad.
\q1 Weyob sogbukwamalad: ‘¿Doa-anmar, soo-dule-obeloged-nagaba megoe?
\q2 ¿Doa-anmar, soo-dummad-gege-bergued-duurmaksiid-nagaba megoe?’
\q1 
\v 15 Unnila dule-igar-innikigwadba-nanadiidbi, degi, napiragwadba-sunmakdiidbi, nibneggi mai guoed.
\q2 Dule ibmar-isganagi-mani-onodisulidbi, dule emarse-manigi-bakledisulidbi, nibneggi mai guoed.
\q1 Dule emar-gindakmaladba ibsadisulidbi, ibmar-isgana-imakleged dakbidasulidbi,
\q2 
\v 16 dule-weyob-daedi, nibneggi mai guoed.
\q1 Akwasaila-gandikmalad e-dukued-negga guoed,
\q2 masgullemalad ega uklegoed,
\q2 gobed ega gwen surguosulid.”
\p 
\v 17 Isaías, Israel-dulemarga sogdebalid:
\q1 “Bemar-sunnagwad, rey-e-gangued-yeerdaklegoed be dakmaloed,
\q2 bemar-yala dungumai be dakmarbaloed.
\q1 
\v 18 Bemar dobee-itosadgi-binsadmardibe, na be sogdemaloed:
\q2 ‘¿Bia wede mani-ebisged nade?
\q1 ¿Bia wede mani-daked nade?
\q2 ¿Bia wede nakuleged-neg-matusurmalad-dakdiid nade?’
\q1 
\v 19 Bar be we-dulemar-isgana dakosurmalad.
\q2 We-dulemar, e-gwabinduku-aku-itolemaladid,
\q1 e-sunmakedi, magar-itolesurmaladid,
\q2 ber oburagwar sunmakmaladid.
\b
\q1 
\v 20 ”Sión-yala be dakmar,
\q2 ar a, anmar-ibamar-onoged-neggweburad.
\q1 Bemar-sunnagwad Jerusalén-neggwebur be dakmaloed.
\q2 A-neggwebur, bogi-meged-negad, nuesaale sobar siid.
\q1 Bipisaale e-abgamalad-suar ungosulid,
\q2 e-abgamalad-dubmar itirosurbalid.
\q1 
\v 21 Jerusalénʼgi, Bab-Jehová anmarga e-gangued oyogoed.
\q2 Diwar-dummagan-maiyob, degi, diimar-iirmakmaiyob guoed.
\q1 Ar a-diwargine, ur-gammi-nikamalad iirmakosulid,
\q2 degine, ur-gandikmalad egine iirmakosulid.
\q1 
\v 22 Ar ade, Bab-Jehová, anmar-idugedid.
\q2 Ar Bab-Jehová, anmarga dummadga negdakmaidid.
\q1 Ar Bab-Jehová, anmar-e-reyd.
\q2 ¡E na anmar-abonogoedid!
\b
\q1 
\v 23 ”Asiria-ulumar-e-dub nollomakded.
\q2 E-urmor-buar geg-nue-gwisgue egemakwichid,
\q1 degine, e-urmormar geg argaed.
\q2 E-isdarmaladi, degi, dule-muya-muyamaladse-bakale, ei ibmar atursamaloed.
\q1 
\v 24 Ar Bab-Dummad bela dulemar-Siónʼgi-mamaid-e-isgued osulogoed,
\q2 degine, bipisaale dule-gwensak sogosulid: ‘An uelleye.’ ”
\c 34
\s1 Dulemar-yar-baid-baidgi-bukmalad sabsur-odurdaklegoed
\q1 
\v 1 Dulemar-yar-baid-baidgi-bukmalad, gayaburba-itogega wese be walikgudamar.
\q2 Dulamar, nue-bogimakar be itomar.
\q1 Napneg-naid, nue itogo.
\q2 Bela-egi-ibmar-bukwamalad, nue-itomarmogo.
\q1 Napneg-bipirmaknaidgi-bukmalad, bela itomogo.
\q2 Bela-napneggi-ibmar-sanmakedi, nue-itomarmogo.
\q1 
\v 2 Bab-Jehová, dulemar-yar-baid-baidgi-bukmaladse bela urwemaid.
\q2 Amar-sorda-bila-onomaladse bela urwemaid.
\q1 Bab-Dummad, bela bemar-obeloged sogmaid,
\q2 bela bemar-ogiloged sogmaid.
\q1 
\v 3 Dule-girgumaloedi, bela omiledoed,
\q2 e-muimar nunusaila yapatoed,
\q2 e-ablismar yalaganba suurmakdoed.
\q1 
\v 4 Niismar-mogir-imbaba-nanaid bar daklegosulid,
\q2 bela mogir atudoed.
\q1 Igi garda obipirmakledae, mogir deyob guoed.
\q2 Bela niismar-e-dakarmakmalad berguoed.
\q1 Uva-sapi-gagan-dinguddaedyobi, dakle naoed.
\q2 Higuera-sapigi e-san-dingusnai-daedyobi, dakle naoed.
\b
\q1 
\v 5 Bab-Jehová weyob sogye:
\q2 “Bato mogir-imbaba, an-es-suid guagwar naid.
\q1 Be dakmalana, Edom-dulemargi es-suid igi-gwichigudani be dake,
\q2 ar an we-dulemar bela ogilogoye sogsad.”
\b
\q1 
\v 6 Bab-Jehová-e-es-suid bela ablisbi naid,
\q2 sibad-omemar-ablisgi obagwar naid,
\q1 sibad-wawaad-senigana-ablisgi obagwar naid.
\q2 Bela e-es-suidgi e-gwallu darwagwar magaled.
\q1 Sibad-wawaad-machered-mirwa-gwallugi darwagwar magaled.
\q2 Ar Bab-Jehová, Edom-yargi Bosra-neggweburgi ibmar-durgan oburgwenaid.
\q2 Edom-yalagi ibmar-durgan yeer ogilonaid.
\q1 
\v 7 Moli-bebe-nikad-ursirmalad egi gwichigudmaloed.
\q2 Moli-bebe-nikad-sapingana, degi, moli-bebe-nikad-machergan egi gwichigudmaloed.
\q1 Edom-yalagi ablisbi bipirmaknai guoed,
\q2 e-napagi, e-gwallumarbi neg-ganai guoed.
\b
\q1 
\v 8 Ar ade, Bab-Jehováʼga buged-imaked-iba gued,
\q2 buged-saed-birga gued, adi, Sión-yala bendaklegegar.
\q1 
\v 9 Edom-yar-e-dianmala baryaga binnidoed,
\q2 e-ukub, azufreʼyob uediki naguoed,
\q2 barya-uedikidyobi diopisuli napa naguoed.
\q1 
\v 10 Bane-bane barya uediki-ganaidbi guoed, gwen akinnosulid,
\q2 e-waa bupurmagwichidbi guoed.
\q1 E-yala degisadegu ollobi-nai guoed,
\q2 bipisaale, bar dulemar egi iirmakosurmalad.
\q1 
\v 11 Noomargii-daklemalad egi neg-egwannoed,
\q2 akwanuku-negga gudoed.
\q1 Egine, irmonmar e-uu sobdoed,
\q2 degi, sikwisichimar e-uu urbidoed.
\q1 Bab-Dummadi we-yala bela gagaoed,
\q2 degi, walagwen-ollobi-selenai imakoed.
\q1 
\v 12 Dule-nuga-nikamalad-sate guoed, yalaye bar bilegosulid.
\q2 Bela dule-gandikmalad bar daklegosulid.
\q1 
\v 13 E-reynegmargine ikomarbi bipirmakdoed,
\q2 e-neg-gandikmaladgi dakemar-sunnabi bipirmakdoed,
\q2 degi, gagan-iko-ikomaladbi engudoed.
\q1 Achu-sapur-uaya-gannagana-e-negga gudoed,
\q2 nuu-dummad-malisuigan-megega gudoed.
\q1 
\v 14 Nega-dulesulidganba ibmar-durgan-ursilimalad-bukwadi, achu-sapurmarbo atodoed.
\q2 Sibad-sapurmar, e-sordaganse gotemaloed.
\q1 Irmon agi ambikumarmogoed,
\q2 a-neggine signonimaloed.
\q1 
\v 15 A-neggine, irmonmar e-uu soboed,
\q2 degi, e-akwamar urbidoed.
\q1 E-sakan-urbali, nuekwa e-akwamar urboed,
\q2 nuekwa e-mimmigan akoed.
\q1 Agine, mulamar ambikumogoed,
\q2 abirgunar-abirgunar ambikumogoed.
\p 
\v 16 Bab-Jehová-gardase be idako, agi be nue-absogo:
\q1 “Bipisaale we-ibmar-durgan gwen beosulid,
\q2 abirgin-abirgin egad-egad nikamaloed.
\q1 Ar Bab-Jehová-sunnagwad igar weyob uksad,
\q2 Bab-Dummad-Burba weyob oambikusad.
\q1 
\v 17 Ar Bab-Dummad ega negmar amisad, ega yala uksad.
\q2 Degisadegu, wemar we-yalagi bukwa gumaloed,
\q2 degisadegu, egi gudii gumaloed.”
\c 35
\s1 Dule-bendaklesmalad weligwar itosmalad
\q1 
\v 1 Nega-dulesulid weligwale itodoed,
\q2 napa-dinnagwad weligwale itodoed,
\q1 nega-dulesulidgi gagan ainidoed,
\q2 dutu-achunnedyob dakledoed.
\q1 
\v 2 Bela nega-dulesulid weligwar itodoed.
\q2 Ar Bab-Dummadi nega-dulesulidga Líbano-yalayobi neg-dakle imakoed.
\q1 Degi, igi Carmelo-yala daklege, deyobi, neg-dakle ega imakoed.
\q2 Igi Sarón-neba yeerdaklege, deyobi, neg-dakle ega nasikoed.
\q1 Ar Bab-Jehová-e-gangued-yeerdakleged dakmaloed.
\q2 Anmar-Bab-Dummad-e-gangued bela dakmaloed.
\b
\q1 
\v 3 Dule-argan-nollo-itomalad, be ogannomarsun.
\q2 Yokor-wanwanmalad, be ogannomarsun.
\q1 
\v 4 Dule-dobeganaga weyob be sogmar:
\q1 “Gandik be samala, melle be dobgumar.
\q2 Be-Bab-Dummad danikoed,
\q1 bemarga buged-imakega danikoed.
\q2 Bab-Dummad-sunnagwad bemar-bendaknonikoed.”
\b
\q1 
\v 5 Geb degine, dulemar-aku-atakmalad magar atakdemaloed,
\q2 dule-uaya-yallirmalad magar dule-itoge gumaloed.
\q1 
\v 6 Geb deginbali, dule-muya-muyamalad, goe-sapuryob ichomake gumaloed.
\q2 Dule-geg-sunmakmalad, weligwaledba binnasuli gotemaloed.
\q1 Ar nega-dulesulidganba diimar suurmakdoed,
\q2 nega-dinnaganba diimar aryodagoed.
\q1 
\v 7 Napa-dinnagana dii egi sigega an imakoed.
\q2 Neg-dinnagana-naigusadgi, ibe makumakar aryogwichioed.
\q1 Achu-sapur-uaya-gannagan e-negga-gusadgi, nargammugi-daklemaladbi guoed,
\q2 degi, naiwargi-daklemalad-negga guoed.
\b
\q1 
\v 8 Agine, igar-dummadsaar mai guoed.
\q2 A-igar, Igar-Islidikidye bilegoed.
\q1 Dule-isgudimalad egi gwen nanaosulid.
\q2 Dulemar-uaya-satedamalad egi gwen iirmakosurmogad.
\q1 Unnila dulemar we-Igarbarbi-nanadimaladbi egi nanamaloed.
\q1 
\v 9 Bipisaale, agi achumigur-nono-wawaad gwen nika-guosulid,
\q2 ibmar-durgan-dulegi-aibined ese gwen nonikosurmogad.
\q1 Ibmar-degimalad gwen daklegosulid,
\q2 unnila dulemar-bendaklesmaladbi iirmakmai guoed.
\q1 
\v 10 Bab-Jehováʼgi dulemar-bendaklesmaladbi, gannar Sión-yalase yeer-itogedgi dognonimaloed.
\q2 Weligwale itodmaloed, yeer itodmaloed.
\q1 Bukib-binsaedi egi yoggudoed,
\q2 wiles-itogedi egi yoggudbaloed.
\q2 Bela weligwaledbi itodmaloed.
\c 36
\ms1 2. REY-EZEQUÍASʼGA NEGGUSAD
\mr (36:1–39:8)
\s1 Rey-Senaquerib, Judá-yargi dogsad
\r (2 Reyes 18:13-37; 2 Crónicas 32:1-19)
\p 
\v 1 Rey-Ezequías birgambe-gakabakegus (14) Judá-yalagi negsemaidgi, Asiria-e-rey-Senaquerib bela Judá-neggweburmar-sakdigar-bukmaladgi gwisgunonikid. Geb bela, Senaquerib, a-neggweburmar sunonikid.
\p 
\v 2 Asiria-e-rey-Senaquerib, Laquis-neggwebur-akale, sordamar-e-dummadi, sorda-bukidaradmala, Jerusalén-neggweburse Rey-Ezequíasʼbo sunmaknaega, barmisad. Jerusalén-neggwebur-mosmargu, Morsan-Odoleged-Neg-siid-igarba Nakwale-Dian-Maid-e-gammu-yoid-nagaba ambikudapmalad.
\v 3 Agine, Rey-Ezequías-neg-dakdiid-Eliaquim, Asiria-sorda-bukmaladse nonigusad. Degi, neg-gusmalad-narmaked-Sebna, degine, rey-sikwi-Joa, eba nonigusmarmogad. Eliaquimʼde, Hilcías-machid. Rey-sikwi-Joaʼdi, Asaf-machid.
\p 
\v 4 Degi, Asiria-sordamar-e-dummad amarga sogded:
\p —Rey-Ezequíasʼga be sogmalo, weyob Asiria-dulemar-e-rey-gandik-maid sogye: ‘¿Ar doagi be nue-bensurye be soge?
\v 5 Bede soged, binsaed an nue-nikaye, sorda-bila-onomalad an nue-nikabarye. Ar unnila binsa gayaginbi be ee gordiid. ¿Ar be doagi-bensurye be soge, emide be anba ibmar imakbisulid?
\v 6 An be-dakedi, Egipto-yar gaapoled-masar-darga-darga-daklegedyobidgi be bensuli an be-dakdo. Ar dule, aba-naile, sunna e-argangi e-darga-dargadgi makleged. Ar we-masar, Egipto-dulemar-e-rey-Faraón gued. Bela-dulemar-egi-bensurmaladga deyob ega gued.
\v 7 Be anga sogele: An-Bab-Dummad-Jehováʼgi an bensurye. Ar degitega, e-neg-matusurmalad, e-ibmar-ogumakar-ukleged-ailamar, Ezequíasʼde obelossursi. Judáʼginmaladga, degi, Jerusalénʼginmaladga sogsasursi: ¿Unnila we-neg-matusulid-Jerusalén-neggweburgi-siidginbi Bab-Dummad-Jehová-nug-odummomaloye?’
\p 
\v 8 ”Emisgwa, an bega sogo, an-dummad-Asiria-e-rey-ebo be igar-omes: Dule-moligi-nanamalad be amiele, an bega molimar milibo (2,000) ukoed.
\v 9 Degi-inigwele, an-sorda-dummadsulid be osikirmakosulid. Ar bede, Egipto bega, e-moli-urmar, degi, bega e-sorda-moligi-sii-urwemalad, ukoye be soged.
\v 10 Ar andega wese, ¿Bab-Jehová-sogedba bemar-obelogega danisur be an-dake? Eye, Ar Bab-Jehová anga sogsad: ‘We-yarse be naoye, be we-yar obelogoye.’ ”
\p 
\v 11 Degine, Eliaquim, Sebna, degi, Joa, weyob Asiria-sordamar-e-dummad-abin sogdemalad:
\p —Be-maimarga wis Arameo-gayaba be sunmake, ar anmar mag-itomalad. Mer anmarga Hebreo-gayaba be sunmake, ar dulemar galu-matusulidgi-bukmalad anmar-itobukwad.
\p 
\v 12 Asiria-sordamar-e-dummad ega sogded:
\p —Ar an-dummadde, ¿unnila bemargarbi ibmar-sogega an-barmiarsi? ¿Be-dummadgarbi ibmar-sogega an-barmiarbarsi? ¿Ar dulemar-galu-matusulidgi-bukmaladga-sogega an-barmiarbarsursi? Ar bemaryobi, we-dulemarde dukin e-ibmar-isgana na gunmaloed, dukin e-winsus na gobmaloed.
\p 
\v 13 Geb degine, sordamar-e-dummad gwichibin-imaksad, geb binnasuli Hebreo-gayaba goted:
\p —Asiria-e-rey-gandik-maid-e-gayaburba be itomar.
\v 14 Weyob rey soged: ‘Melle Ezequíasʼse yamolemalo. Ezequías amba angi naosulid, anse oitolegoed.
\v 15 Ezequías bemarga sokardibe: Bab-Jehováʼgi mer be bengumarye, Bab-Jehová anmar-bendakoye. Asiria-e-rey we-neggwebur obelogosurye. Melle be Ezequías-itomalo.’
\p 
\v 16 ”Ar weyob Asiria-e-rey soged: ‘Anbo igar nabomar, anse be dagmar. Geb bemar gannar be-nainumargi uva-naid be gundii gumaloed, higuera-sapi-e-san be gundii gumarbaloed. Degine, bemar be-diagi na be dii-gobdii gumaloed.
\v 17 Geb sorba, bemargadyob-yar-daklegedse an bemar-nidoed, orosgi-dakleged-yalase an bemar-nidoed, vino-yalase, madu-yalase, degi, uvaʼmar-nainu-yalase, an bemar-nidoed.
\p 
\v 18 ” ’Melle be Ezequías-itomalo, ar yamo bemar-yamogoed, bemarga sogdagoed: Bab-Jehová anmar-bendakoye. ¿Ar yar-bamalad-e-bab-dummagande, Asiria-e-rey-annik bemarga yar-susa be daksi?
\v 19 Ar Hamat-e-bab-dummadi, Arfad-e-bab-dummadi, Sefarvaim-e-bab-dummadi, Hena-e-bab-dummadi, gwen Samaria-neggwebur angi sussurmalad.
\v 20 Degite, ¿bitid-yar-bamalad-e-bab-dummagan bemar-yar-angi-suega angi obicha be dake? Ar degitega, ¿igi-Bab-Jehováʼde Jerusalén-neggwebur-bendakoye be binsasunna? Bendakosuli.’ ”
\p 
\v 21 Degine, dulemar, abin boo bukusad, bipisaale gwen-abin-imaksasurmalad, ar ade, Rey-Ezequías ega weyob igar-uksad: “Melle abin-imakmaloye.”
\p 
\v 22 Geb degine, reyneg-dakdiid-Eliaquim Hilcías-e-machi, degi, ibmar-gusmalad-narmaked-Sebna, degine, reyga-garda-narmaked-Asaf-machi-Joa mor-dubamakagwale Rey-Ezequíasʼse nadmalad, adi, oyogega, ede bukib-binsamarye. Geb bela Asiria-sordamar-e-dummad-ega-ibmar-sogsad, Rey-Ezequíasʼga sogdapmalad.
\c 37
\s1 Jerusalén-neggwebur-bendaklesad
\r (2 Reyes 19:1-13; 2 Crónicas 32:20-23)
\p 
\v 1 Rey-Ezequías deyob ibmar-itosgua, e-mor-yoid siir-siir imaksad. Geb wile-itoged-mor yosad. Geb Bab-Jehováʼse-goled-negse naded.
\v 2 Degi geb Rey-Ezequías, dummad-reyneg-dakdiid-Eliaquim, degi, ibmar-gusad-narmaked-Sebna, degine, dule-irwa-Bab-Dummadse-gormalad-sergan wile-itoged-mor-yoyoi, Amoz-machi-Isaías-daknamalaga barmisad. Isaíasʼde, Bab-Dummad-gayaburba-barsogedid.
\p 
\v 3 Isaíasʼga sognonimalad: “Weyob Rey-Ezequías soged: ‘Emi-iba-naidi, suli-suli-itoged-iba naid, sabsur-odurdakleged-iba naid, degine, bingegued-dummad-iba naid. Igi ome muu-neggi-nagudele, na abagan-nollo-naddae, deyob emi-iba naid.
\p 
\v 4 ” ’Bitigine, be-Bab-Dummad-Jehová, Asiria-sordamar-e-dummad-ibmar-sogsadi, bela itosana gadin. Ar ade, Asiria-e-rey, e-sorda-dummad, Bab-Dummad-Dula-Maidgi-dodoar-sunmakega barmiar gusad.
\p ” ’Bitigine, be-Bab-Dummad-Jehová, we-dule-gayaburba-itosadba sabsur-odurdaksunnana gadin. Bab-Dummadse Israel-dulemar-napi-gudimaladga be gorsun.’ ”
\p 
\v 5 Rey-Ezequías-e-dummagan Isaíasʼse nadmargu,
\v 6 Isaías ega sokalid: “Weyob be-dummadga be sogmalo: ‘Bab-Jehová weyob sogye: Be we-dule-ibmar-soge-itosadgine, Asiria-e-rey-e-dummagan angi ise-yolegar-sunmaksadgine, mer be gwayo.
\v 7 ¡Be dako! Senaquerib gayaburba-isgana-itogega an imakoed. Geb gannar e-yarse naoed. Geb e-yargi, es-suidgi oburgwemalaga an imakoed.’ ”
\p 
\v 8 Asiria-sordamar-e-dummadi, Asiria-e-rey, Laquis-neggweburgi-mai-nadye-wisguargu, balimakde gusad. Libna-neggwebur-ebo bila-ononai Asiria-e-rey-dakdapid.
\p 
\v 9 Geb agine, Rey-Senaquerib wisgualid, Etiopía-dulemar-e-rey-Tirhaca, ebo bila-onogega egi daniye. Deyob-wisguargua, gannar Rey-Ezequíasʼse dule-gayaburba-berbemalad barmisad,
\v 10 ega sogegar: “Judá-e-rey-Ezequías, be-Bab-Dummad-egi-be-bensurgudiid bega-sogedi: ‘Asiria-e-rey Jerusalén-neggwebur suosurye.’ Mer be-Bab-Jehováʼse be yardaklego.
\v 11 Ar Asiria-e-rey bela yarmar-obelos-gusadde be wisgussursi. Ar degite be, ¿san-onogo be itoge?
\v 12 Ar an-babgan Gozán-neggwebur-obelosgusadi, Harán-neggwebur-obelosgusadi, Resef-neggwebur-obelosgusadi, Edén-wagan-Telasar-neggweburgi-bukwad-obelosgusbalidi, degitega, ¿e-bab-dummagan bendaksa be daksi?
\v 13 Degite, ¿bia Hamat-dulemar-e-reyde, Arfad-dulemar-e-reyde, nadmarsunna? ¿Bia Sefarvaim-dulemar-e-reyde, Hena-dulemar-e-reyde, Iva-dulemar-e-reyde, nadmarsunna?”
\s1 Ezequías Bab-Dummadse-gochad
\r (2 Reyes 19:14-19)
\p 
\v 14 Degine, Rey-Ezequías, dule-gayaburba-berbemalad-abin garda susad, geb absosad. Geb a-sorbali, Bab-Jehováʼse-goled-negse naded. Geb Bab-Jehová-asabin garda nallaa imaksad.
\v 15 Geb degi, Ezequías weyopira Bab-Jehováʼse goted:
\p 
\v 16 “Bab-Jehová-Bela-Gangued-Nika-Maid, Israel-dulemar-e-Bab-Dummad, baliwiturmar-wagar-darbakegwad-abargi be negsemaid. Unnila bebi we-napneg-naid-e-Bab-Dummadga be gued. Be nibnega nasiksad, napnega be obinnisbalid.
\v 17 Bab-Jehová-Dula-Maidye, nue be an-itoye, nue be anmar-gunaid be dakye. Igi Senaquerib begi ise-yolegar anga gayaburba-barmiali, nue be itoge.
\p 
\v 18 ”Bab-Jehová, ar nue napiragwa, Asiria-e-reymar we-neggweburmar, e-yarmar, obelosad.
\v 19 E-bab-dummadyob-imaklemalad bela soogi-ogumaksabalid. Ar wemar Bab-Dummadsurmalad, suarmar-sobaled nanaed, akwa-sobarmalad nanaed. Dulemar sobsananaedid.
\v 20 Emidi, Bab-Jehová, be-anmar-Bab-Dummadid, wis be we-dulegi anmar-bendake, adi, dulemar bela we-napneggi-bukmalad be-wisgumalaga, unnila beebi, Bab-Jehová wargwenna maiye.”
\s1 Rey-Senaquerib-burgwisad
\r (2 Reyes 19:20-37; 2 Crónicas 32:20-21)
\p 
\v 21 Geb degi, Amoz-machi-Isaías, Rey-Ezequíasʼse weyob gayaburba barmisad: “Bab-Jehová Israel-dulemar-e-Bab-Dummad, weyob soged: ‘Be anga Asiria-e-rey-Senaqueribʼgi ibmar-sogsadi, bela an be-itosye.
\v 22 Ani an Bab-Jehová, weyob Rey-Senaqueribʼnik an soged:
\q1 Senaquerib, Siónʼginmalad sae be-dakmalad, begi dodomalad.
\q2 Jerusalénʼginmalad wakite-be-dakmargu, bega nono-ege-ege imakmalad.
\q1 
\v 23 Senaquerib, ¿doanik be isdar-sunmaksa?
\q2 ¿Doagi be ise-dodoar-sunmaksa?
\q1 ¿Doaga urwedgi be ibmar sogsa?
\q2 ¿Doa-abin san-dummarba be itosa?
\q2 Ar be Israel-e-Bab-Dummad-Isligwalednik be isdar sunmaksad.
\q1 
\v 24 Bega-gayaburba-berbemaladba be Bab-Jehováʼgi ise-yolegar sunmaksad.
\q1 Weyob be sogsad: An-moli-ur-bila-onomaladgi Líbano-yar-dummagan-birigi an nakwisye.
\q2 E-urwarmar-dummagan-bubukwad, ani an ei siksa naiye.
\q2 E-baryawarmar-yeerdaklegwismaladi bela an ei immisye.
\q1 E-yar-birse an nakwisye,
\q2 e-neg-sergan-nanaid bela an ei wisgusbarye.
\q1 
\v 25 Dule-baigan-yargi, ani an dii-yaamar urbisye,
\q2 we-diimar an gobsaye.
\q1 An-nanaedba, bela Egipto-diwarmar an odinnosye.
\b
\q1 
\v 26 ” ’Senaquerib, ¿ar be wissursi?
\q2 Ar bato an dikasurgus we-ibmarmar-guoed an ega igar mesisad.
\q1 Bato yola-birgabargus weyob-imakega an igar amisad.
\q2 Emisgwa, geb an we-ibmarmar oyoalid.
\q1 Aga be nabir neggwebur-sakdigar-bukmalad be obelos nanaed.
\q2 
\v 27 E-dulemar gaganmar-naiyob be-abin naded,
\q2 gwen be-abin imaksasulid,
\q1 be-abin nollo nadmalad.
\q2 Be-abin bingegudmalad.
\q1 Amarde nainugi gagan-dutugana-naiyob, be-abin nadmalad.
\q2 Neg-uas-birgi-gagan-ainialir dinguddaeyob, be-abin nadegusmalad.
\b
\q1 
\v 28 ” ’An nue bela-belad be-wisid, sanase be signonidae,
\q2 sanagwadse be aineba naddabali.
\q1 Sanagwadse be dognonidabali.
\q2 Deginbali, sanadgine be angi isdar-sunmakardabali,
\q2 bela an nue be-wisid.
\q1 
\v 29 Ar be, an-annik sunmaksadi,
\q2 be-angi-apor-sunmaksadi, an bela itosad.
\q1 Degisoggu, be-asugi esgoro-wardummad an yooed,
\q2 mer bar be sunmakega be-gaya an edinnoed.
\q2 Degine, bia be danigusa, gannar a-igarba an be-barmidoed.’ ”
\p 
\v 30 Isaías, Rey-Ezequíasʼga weyob soged:
\q1 “Rey-Ezequías, we-ibmarmar bega e-wilubga guoed:
\q2 We-birgagine, ibmar-gwag-gwen-diglessuli-ainiardaed be gunmaloed.
\q1 Baid-birgasega, ibmar-gwag-diglessulid-sanmakoedi amba be gunmarbaloed.
\q2 Geb birgapaasedina, sunna ibmar-gwaggi be arbamaloed,
\q2 degi, nabir be weemarbaloed.
\q1 Sunna uvaʼgi be arbamaloed,
\q2 degi, geb nabir e-san be gunmaloed.
\q1 
\v 31 Judá-wagan-abala-san-onosmaladi sapi-malimar-ainiardaedyobi, gannar ainidagoed,
\q2 e-anagan gannar nikudoed.
\q1 
\v 32 Ar Jerusalén-neggweburgi wis ichee dulemar bedapoed,
\q2 amba Sión-yargi bukumaloed.
\q2 Ar Bab-Jehová-Bela-Gangued-Nikad e-dulamargi-bela-bela-sabgued-nikadba, we-ibmar imakoed.”
\p 
\v 33 Degisoggu, Bab-Jehová, Asiria-e-reynik weyob soged:
\q1 “Senaquerib we-neggweburse gwen dogosurguoed.
\q2 We-neggweburgi sigu-wargwensaar miosulid.
\q1 We-dule, bila-onogega we-neggweburse sigu-abgaedyalaba gwen urwosulid.
\q2 Deginbali, neggwebur-galu-matusulid-dikarba, gwen napa-nakwemaid imakosulid.
\q1 
\v 34 Ani an Bab-Jehová-guedgi, an soged:
\q2 We-dule, gebe-danigusadba gannar naoed.
\q2 We-neggweburgi gwen dogosurguoed.
\b
\q1 
\v 35 ”An we-neggweburgi nued-binsasoggu, an-mai-Davidʼgi nued-binsabarsoggu,
\q2 we-neggwebur an bendakoed, we-neggwebur an obelogosulid.”
\p 
\v 36 A-mutikidgine, Bab-Jehová-e-baliwitur, Asiria-sorda-bukwadgine, mili-dulabakebak-gakatar (185,000) dulemar-ogilosad. Degine, neg-oiboargu, bela dulemar burgwar-mamaitibi oiboalid.
\v 37 Degidgine, geb Asiria-rey-Senaquerib nadegusad, gannar Nínive-neggweburse nonigusad, agine megidapid.
\p 
\v 38 Ibagwengi, Rey-Senaquerib bab-dummad-Nisrocʼse-goled-neggi, e-bab-dummadse-gorsiidgi, e-masmala Adramelec, degi, Sarezer, es-suidgi Senaquerib-oburgwismalad. Geb agine, Ararat-yalase wakitegusmalad. Senaquerib-sorbali, e-machi-Esar-Hadón yar-sesad.
\c 38
\s1 Ezequías-boni-nikad
\r (2 Reyes 20:1-11; 2 Crónicas 32:24-26)
\p 
\v 1 A-ibagangine, Ezequías bela-bela nailikgumai burgwednaga gusad. Geb Bab-Dummad-gayaburba-barsoged-Isaías Amoz-e-machi, Ezequías-dakega ese nade gusad. Degi, ega sogdapid: “Bab-Jehová weyob soged: ‘Be bar-gwisguosurye, be burgoye. Degisoggu, be-neg-yaginmaladga igargan napi-nue be ukoye.’ ”
\p 
\v 2 Geb degine, Ezequías, galusik aibilisa imaksad. Weyob, Bab-Jehováʼse isedar-gollar imaksad:
\v 3 “Bab-Jehováʼye, be an-ebinsao. Andi be-sogedba bega arbasad. Napiragwadba an beba nanasad. Be-ibmar-abegedba andi bega ibmar imaksad.” Degi Ezequías bela-belad isedar-boale meremai gusad.
\p 
\v 4 Geb degine, Isaíasʼse Bab-Jehová-gayaburba nonikid, ega weyob sognonikid:
\v 5 “Ezequíasʼse be nae, ega be sogo: ‘Bab-Jehová, be-dad-dummad-David-e-Bab-Dummad weyob sogye: Anse be gochadi, bela an be-itosye, be-ibyanis-aryosadi an daksabarye. Degiirdi, birgambe-gakatar (15) napi-gudii-guega an be-imakoye.
\v 6 Asiria-e-reygi an be-ollorsaoed, we-Asiria-neggwebur-e-reygi an be-bendakoed. Ani an, we-neggwebur-irwa gwisguoed.’ ”
\p 
\v 7 Geb Isaías, Ezequíasʼga sogded:
\p “Bab-Jehová-bega-ibmar-sogsad mag be dakegala, we-ibmar-wilub Bab-Jehová bega oyogoed:
\v 8 Acaz-wachi an gannar sorsik wachi-irgwen-wilub osikirmakoed.” Geb agine, dad-ibeler-naidi gannar wachi-irgwen-wilub sorsik sikirmaksad.
\s1 Ezequías-ibmar-narmaksad
\p 
\v 9 Judá-e-rey-Ezequías, nailikgumaigusad-sorbali, gwisgusgua, weyob garda narmaksad:
\q1 
\v 10 “An weyob sogmai gusad: ‘¿An nabir-gudiid-ibagangi nue-an-burgwesunnode?
\q2 ¿Burgwed-galuse an megnaedgadsunde?
\q2 ¿Bar an wegi daklegosuli gusunnode?’
\q1 
\v 11 An sogsabalid: ‘We-napneggi bar an Bab-Jehová-dakosulid.
\q1 We-napneggi-dulemar-bukwad bar an dakosurbalid.’
\q1 
\v 12 An-annik an-neg susmalad,
\q2 urwedigi an-annik susmalad.
\q1 Sibad-wawaad-edarbed-e-dordoneg-obipirmaklegeyobi an-neg imaksamalad.
\q2 Dule-mormaked, mor-maknaiyobi be an-san imaksad.
\q1 Emide, Bab-Dummad, mor-maknaid-bergusadgi-e-dikarmar-sike-sike-imaklegeyobi an-imaksad.
\q2 An-ibagan baisursunna be obelononikid.
\q1 
\v 13 Ogormaksii an neg-oiboalid.
\q2 Achumigur-nono-wawaad-garmar-bibisgeyobi an-imaknonikid.
\q2 Irgwennaar be an-obelononikid.
\q1 
\v 14 Wirsob-boedyobi an bosad,
\q2 nuu-dabgalayob-dakleged-boedyobi an bosad,
\q2 nuu-sibu-uurmakedyobi an bosad.
\q1 An-ibya niba-atakedbali, yegusad.
\q2 Bab-Jehová an suli-suli-itogusad, be an-bendakdage.
\b
\q1 
\v 15 ”Ar ¿igi bar an sogosunna?
\q2 Ar e-sunnagwad anga sogsad.
\q1 Ar deyob imaksado.
\q2 Ulubgi an-isdar-itogedi, bar gabbisuli an-imaksad.
\q1 
\v 16 Bab-Jehová, be-sogedbali dulemar dula gudidimalad.
\q2 An deyobi be-sogedba an dula-gudii gumogoed.
\q1 Bee be, anga san nudaksad,
\q2 bee be, anga burba uksad.
\q1 
\v 17 An suli-suli-itosad,
\q2 emidi, an bogidik itoged.
\q1 Be an-sabedbali yaa-dummad-dule-obelogedgi be an-bendaksad,
\q2 begi isgussuliyob be an-daksad.
\q1 
\v 18 Neg-uan-mamaidi, gwen be-nug ogannogosulid.
\q2 Dule-burgwarmaladi, gwen be-nug odummosulid.
\q1 Dule-yaa-dummadse-batemamaidi, be-innikigwadba-daedgi gwen sunmakosurmalad.
\q2 
\v 19 Unnila dula-gudimaladi, be-nug-ogannoged,
\q1 igi an emi-ibagi be-ogannoge, deyob be-ogannomarmogad.
\q2 Bela babgan na e-mimmiganga be-innikidaedgi sunmakmaloed.
\b
\q1 
\v 20 ”Bab-Jehová an-abonogoed.
\q2 Degisoggu, anmar bane-bane Bab-Jehováʼse-goled-neggi, igar-dub-nikamaladba namakmaloed.”
\p 
\v 21 Geb degi, Isaías sogded:
\q1 —Higo-san ollimakmalo,
\q2 geb rey-abagangi yaa-siidgi be mage-mage imakmalo.
\q2 Agine nabir nugudoed.
\p 
\v 22 Geb degi, Ezequías, Isaíasʼga sokalid:
\q1 —An nabir Bab-Jehováʼse-goled-negse naknaega,
\q2 ¿ibi-wilubgi nabir magar an daksale?
\c 39
\s1 Ezequías, Babiloniaʼginmalad-abindaksad
\r (2 Reyes 20:12-19; 2 Crónicas 32:27-31)
\p 
\v 1 A-ibagangine, Babilonia-e-rey-Merodac-Baladán, Rey-Ezequíasʼse dule-gayaburba-berbemalad barmisad. Amarba Ezequíasʼga garda barmisad, degi, ibmar-binsa-ega-ukleged ega barmisbalid. Merodac-Baladánʼde, Baladán-e-machid. Ar Merodac-Baladánʼde wisgusgusad, Ezequías bela-bela-nailikgumaidi, emidi, nue-nugunoniye.
\v 2 Ezequías weligwaledgi we-dulemar-abindaksad, degine, dule-gayaburba-berbemaladga, bela e-ibmar-nuegan-gargerbamalad-bukwad oyosad:
\q2 Manimar, ormar,
\q2 ina-wawadikmalad, olivo-gwallu-wawadikmalad,
\q2 degi, bila-onogedgi-ibmar-ebulemalad-sabolebukwad bela oyosbalid.
\q2 Degine, bela ibmar-nuegan-sabolebukwad-neggi ega ibmarmar oyosbalid.
\q3 Ezequías, e-negsemaidgi bela e-neggi-ibmarmar-bukwad, oyosad.
\p 
\v 3 Geb degine, Bab-Dummad-gayaburba-barsoged-Isaías, Rey-Ezequías-daknaded. Geb ega sogdapid:
\p —¿Bia we-dulemar daniki? ¿Ar igi bega we-dulemar soge?
\p Geb Ezequías ega sogded:
\p —We-dulemar dikasur danimalad. Babilonia-neggwebur-akale an-dakega danimalad.
\p 
\v 4 Geb gannar Isaías, Ezequíasʼga sogded:
\p —¿Ibu be-negyagi daksamala?
\p Ezequías abin-sogded:
\p —Bela an-negyagi ibmar-bukwad daksamala. Bela ibmarmar-bukwad an ega oyosad.
\p 
\v 5 Geb degi, Isaías, Ezequíasʼga sogdesunnad:
\p —Nue Bab-Jehová-Bela-Gangued-Nikad-e-gayaburba be itogo:
\v 6 ‘Ibagan danikoed, bela be-neggi-ibmarmar-bukwadi, bela be-dadgan-emi-ibase-ibmar-urbisadi, Babilonia-yarse seledoed. Bipisaale ibmar gwen beosulid.
\v 7 Be-mimmigan-abala, be-wagan-abala, Babilonia-e-reyneggi maiga-guega seledmaloed.’ Deyobi Bab-Jehová soged.
\p 
\v 8 Geb Ezequías, Isaíasʼga sogded:
\p —Nueddo. Bab-Jehová-gayaburba be anga sognonikidi, yeer an itodo.
\p Ar Ezequías e-ulubgindi binsasad: “Amba an-maidgine, neg nueganbi, degi, bogidik-nai guoed.”
\c 40
\ms1 3. ISRAEL-DULEMAR-GWAGE-ARMAKLEGOED
\mr (40:1–48:22)
\s1 Bab-Jehová, Israel-dulemarga gwage-armaked
\p 
\v 1 Anmar-Bab-Dummad soged:
\q1 “An-dulamar-e-gwage ogannomar,
\q2 baisur-ito be imakmar.
\q1 
\v 2 Jerusalén-dulemarga nue-sabedgi be sunmakmar,
\q2 ega be sogmar:
\q1 ‘Be maiga-arbadigusmalad-ibagan wese bergunoniye,
\q2 be-isgusmalad bato bega bennuklesye.
\q1 Bemar isgusad-nukad unniguar bato ilabo-wilub sabsur-odurdaklesye.
\q2 Bab-Jehová bemarga isgued elisye.’ ”
\b
\q1 
\v 3 Gayaburba binnasuli goled, weyob soged:
\q2 “Bab-Jehováʼga nega-dulesulidganba igar mayemar,
\q1 anmar-Bab-Dummadga nega-dinnaganba igar swilidik mesmar.
\q2 
\v 4 Bela nebagan swilidik imakmarsun,
\q1 yalamar, degi, neg-mullugana omatolesun.
\q2 Degine, napa-muru-muru-mamaid innikii imakmarsun,
\q2 igar-bire-bire-mamaid innikii imakmarsun.
\q1 
\v 5 Agine geb Bab-Jehová-e-gandikid-yeerdakleged bela dulemarga oyolegoed.”
\q2 Ar Bab-Jehová-sunnagwad deyob sogsad.
\p 
\v 6 Gayaburba weyob soged:
\q1 “Binnasuli be soge.”
\p An ega weyob soged:
\q1 “¿Ibu an binnasuli sogosunna?”
\p Geb anga soged:
\q1 “Bela dulemarga be soge: ‘Dulemar gaganyobi gued.
\q2 E-yeerdaklegedi, nainugi-dutu-achunneyobi gued.
\q1 
\v 7 Bab-Jehová-e-buu-imaked egi nasale, gagan baisur-dinguddaed,
\q2 dutumala, baisur-dinguddamogad.
\q2 Ar dulemar gagan-ara-aramaladyobi gued.
\q1 
\v 8 Gaganmala baisur-dinguddaed,
\q2 dutumala, baisur-dinguddamogad.
\q2 Ar anmar-Bab-Dummad-Gayaburbadi, degisadegu maiguad, berguosulid.’ ”
\p 
\v 9 Bab-Dummad sogded:
\q1 “Sión-yalagi be nakwenae,
\q2 gayaburba-nuegangi be sunmaknae.
\q1 Yala-matusulidse be nakwenae,
\q2 Jerusalén-neggweburga, gayaburba-nuegangi be sunmaknae.
\q1 Ise-gandikidba be sunmaknae,
\q2 binnasuli be sunmako,
\q2 melle be dobe itogo.
\q1 Judá-neggweburmarga be soge: ‘Be nue-dakmar.
\q2 Wegi anmar-Bab-Dummad-danikid be dakmar.’
\b
\q1 
\v 10 ”Bab-Jehová-gandikidba-danikid, be dakmar.
\q2 Bab-Jehová e na negsemaid.
\q1 E-dulamar-ollor-imaksadi, ebali nidanikid.
\q2 Ibidar-nued-amisadi eba sedanikid.
\q1 
\v 11 Bab-Jehová e-dulamar-bendakdanikid.
\q2 Igi sibad-wawaad-edarbedi, e-sibad-wawaad-mimmi nakwaa imakdae, geb e-binasgargi semaidae,
\q1 degi, sibad-wawaad-milesmalad nue nimaidae.
\q2 Deyobi, Bab-Jehová e-dulamar bendakdanikid.”
\s1 Dule, Israel-e-Bab-Dummadyobid sulid
\q1 
\v 12 ¿Doa dii-naid e-argangi wilubsasa?
\q2 ¿Doa mogir-naid e-goomargi wilub-imaksa?
\q1 ¿Doa ibmar-wilubsaedgi ukub-naid urbisa?
\q2 ¿Doa ibmar-wilubsaedgi yar-dummagan wilubsasa?
\q2 ¿Doa ibmar-wilubsaedgi yar-mullugana wilub-imaksa?
\q1 
\v 13 ¿Doa Bab-Jehová-E-Burba bela balamioe?
\q2 ¿Doa ega binsaed-ukedga guoe?
\q1 
\v 14 ¿Ar doase Bab-Jehová ibmar-magar-itogega binsaed-amissunna?
\q2 ¿Ar doa igar-inniki-imaked-igarba Bab-Jehová-odurdaksasunna?
\q1 ¿Doa ega ibmar-nue-wisigued uksasunna?
\q2 ¿Doa binsaed-nikaa-daed-igarba Bab-Jehová-odurdaksasunna?
\q2 Suli, dule bipisaale wegiid-igarba Bab-Jehová-odurdaksasulid.
\b
\q1 
\v 15 Ar dulemar-yar-baid-baidgi-bukmaladi, Bab-Jehová-asabinni unnila bormoyagi dii-gwagwen-argwachayobi gumalad.
\q2 Degi, ibmar-wilubsalegedgi ukub-ichesaar wilubsalegedyob gumalad.
\q2 Ar Bab-Jehová dupgan-nanaidi, ukub-buru-aidikueyobi daked.
\q1 
\v 16 Líbano-yargi-sapanmar-nikadi, Babga-ibmar-ogumaklegedgi-ebulegega unnisulid.
\q2 Líbano-e-ibmar-durgan-nikadi, Bab-Dummadga-ogumaklegega, unnisurbalid.
\q1 
\v 17 Bab-Jehová-asabinni, bela dulemar-yar-baid-baidgi-bukmaladi, ibigwensuli gumalad.
\q2 Egala, gwen ibmar-nuedga gusulid.
\b
\q1 
\v 18 ¿Doa-ebo be Bab-Dummad-wilubdakoe?
\q2 ¿Ibu-ibmar-sobaledbo be wilub-imakoe?
\q1 
\v 19 Dule-ibmar-sobmaladi, esgorogi ibmar-bab-dummadyob-imakleged sobmalad.
\q2 A-sorba, dule-or-sobedi, a-ibmar-birgi or-nasikmalad,
\q2 geb ega manidubmar sobbalid.
\q1 
\v 20 Ar dule-wilegeddi, e-bab-dummad-sobega suar-gege-nunguedi amied.
\q2 A-sorbali, dule-wileged, dule-ibmar-nued-sobed amied.
\q2 Adi, ega nuekwaa suar-bab-dummadyob sobega, melle ege-ege gwisguegar.
\b
\q1 
\v 21 ¿Ar ade, bemar wissurmarsi?
\q2 ¿Bemar itossurmarsi?
\q1 ¿Bato gebesailagine bemarga soglessursi?
\q2 ¿Napneg-nagusad-akar bemar odurdaklessurmarsi?
\q1 
\v 22 Ar Bab-Jehováʼdi napneg-dirbir-naidbirgi negdaksiid,
\q2 dulemar-bukwadi sesmaryobi ega gued, bai daksulid.
\q1 Bab-Jehová mor-dummad-nallaa-imaklegedyobi mogir-imaked.
\q2 Bab-Jehová mor-neg-egalegedyobi, mogir-billi egadaed,
\q2 adi, egi megegar.
\q1 
\v 23 Bab-Jehová, dule-gandikmalad obelodaed.
\q2 Dule napneggi-dummadga-negsemamaidi, ibmar-isganayobi obeloged.
\q1 
\v 24 A-dummagan sapiwar-nue-diglessuliyobi gumalad,
\q2 ibmar-gwag-nue-diglessuliyobi gumalad,
\q1 sapi-saila napa-yaba e-malimar-nue-ainissulidyobi gumalad.
\q2 Ar Bab-Jehová egi buu-imakdele, dingudmaloed,
\q2 ar gagan-dinnaganayobi burwa-dummadba seledoed.
\p 
\v 25 Bab-Jehová-Isligwaled weyob soged:
\q1 “Degite, ¿doabo bemar an-wilubdakmalosunna?
\q2 ¿Doa anyobi-daklege gusunna?”
\b
\q1 
\v 26 Niba be nue atakmar,
\q2 ¿doa bela we-ibmarmar obinnisa?
\q1 Bab-Jehová e na niisgwamar-onied,
\q2 sog-soggwen ilemaked,
\q2 e-nugbali ese goled.
\q1 Bab-Jehová-e-ganguedi, ibiyobi dummarba gue.
\q2 E-garganguedi, ibiyobi gandiki negsemai.
\b
\q1 
\v 27 Jacob-wagan, ¿ibiga be Bab-Jehová-dikarba sunmake?
\q2 Israel-dulemar, ¿ibiga be urwakwaa Bab-Jehová-dakmala?
\q1 Be sogmalad: “An-igarmar Bab-Jehováʼgi dukumaiye.
\q2 An-Bab-Dummad an-ibmar-imaked baisurdakye.”
\q1 
\v 28 ¿Ar ade, be wissursi?
\q2 ¿Be wisgussursi?
\q1 Ar Bab-Jehová Bab-Dummad-degisadeguadid,
\q2 napneg-bipirmaknaid bela obinnisadid,
\q1 budar-itoged nikasulid, gege geggubalid,
\q2 e-nue-ibmar-wisidi, gege balamileged.
\q1 
\v 29 Bab-Jehová dule-yegusmaladga gangued uked,
\q2 E na dule-nollo-itomaladga gandikidba gangued uked.
\q1 
\v 30 Sapingana dutusur-inigwele, geggusdamalad, budar-itogusdamalad.
\q2 Masmala yoleddamalad, aimukuddamalad.
\q1 
\v 31 Degi-inigwele, dule-Bab-Jehováʼgi-bensurmaladdi, gannarse gangued nikumaloed,
\q2 sulubagi-gukueyobi gumaloed:
\q1 Abarmakdii gumaloed,
\q2 gwen gegguosurmalad,
\q1 igala-suid-nanadii gumaloed,
\q2 gwen gegguosurmalad.
\c 41
\s1 Bab-Dummad Israel-dulemar-edarboed
\p 
\v 1 Bab-Dummad weyob soged:
\q1 “Neggwebur-demar-gakaba-bukmalad, bogi an-abin ambikumalo.
\q2 Dulemar-yar-baid-baidgi-bukmalad, gandik be imakmar.
\q1 Walikaa be dagmar,
\q2 be sunmakmar.
\q2 Anmar igar-nabogega ambikumar.
\b
\q1 
\v 2 ”¿Doa dad-nakwedsik, dule-gusgu-emargi-obinmaid wese-dagega imaksa?
\q2 ¿Doa we-dulega dulemar-yar-baid-baidgi-bukmalad urmaksa?
\q1 ¿Doa reymar-seega imaksa?
\q2 ¿Doa ukub-milegeyobi es-suidgi dulemar-obelogega imaksa?
\q1 ¿Doa e-warsi-abin-ibmar-durgan-mileddaedyob dulemar-imaksa?
\q2 
\v 3 Gwen nanadisulid-igarba, binnasuli dule-balegindanikid.
\q1 
\v 4 ¿Doa weyob imaksa? ¿Doa nabir we-ibmar bursuli-guega imaksa?
\q2 ¿Doa gebesailaunni dulamar-ainakwedanikidse gocha?
\q1 Ani an Bab-Jehová guedi, bela we-ibmarmar imaksad.
\q2 Ani an gebesailaginedid,
\q2 ani an berguedse gudii gubaloed.
\b
\q1 
\v 5 ”Neggwebur-demar-gakaba-bukmaladi, dani-daksamalad,
\q2 dobe-itodmalad.
\q1 Napneg-naid-ugakaase abin giglimakded.
\q2 Bato egi danimalad, bato walikgusmalad.
\q1 
\v 6 Muchub-muchub e-aimar-bendakdemalad,
\q2 muchub-muchub burba-ogannodmalad.
\q1 
\v 7 Dule-ibmar-sobedi, dule-orgi-arbaed ogannoged.
\q2 Dule-mardogi-ibmar-sobedi, dule-esgorogi-arbaed-ogannoged, ega weyob soged: ‘Arbaed-nued be imaksa.’
\q1 Geb sorba, ibmar-sobaled-bab-dummadyob-imakleged nue-esgorogi bioked,
\q2 adi, melle ege-ege gwisguegar.”
\p 
\v 8 Bab-Jehová sogdebalid:
\q1 “Israel, bedi an-maiga gued.
\q2 Be, Jacob-wagan, an bemar-susadid,
\q2 An-ai-Abraham-wagan be gumalad.
\q1 
\v 9 Ar napneg-naid-ugakaase an be-susad,
\q2 nega-sukungan-dikasulidba an bese gochad.
\q1 An bega sogsad: ‘Be an-maiga gued.’
\q2 Ani an be-susad, an be-obachasulid.
\q1 
\v 10 Melle be gwayo.
\q2 An beba gudiguad.
\q1 Melle be suli-suli-itogo.
\q1 Ani an be-Bab-Dummadid.
\q2 An be-ogannogoed,
\q1 an be-bendakoed,
\q2 an-sakwa-gandikid-nuedsikidgi an be-ganikioed.
\b
\q1 
\v 11 ”Dule-isdar-be-dakmaladi, bingegudmaloed,
\q2 nug-mesagwar gudmaloed.
\q1 Dule-begi-gwisgudimaladi, bela bergudoed,
\q2 gudisurmaladyobi naoed.
\q1 
\v 12 Be be-isdarmalad-amidiguo-inigwele, gwen be amiosulid.
\q2 Bebo-bila-onomaladi, bela bergudoed,
\q2 gudisurmaladyobi naoed.
\q1 
\v 13 Ar ani an be-Bab-Dummad-Jehová gued.
\q2 An be-argan-nuedsikid-ganikidid.
\q1 Ani an bega soged: ‘Melle be gwayo,
\q2 ani an be-bendakoed.’ ”
\p 
\v 14 Bab-Jehová soged:
\q1 “Bemar-Israel-dulemar ichee-gue-inigwele,
\q2 melle be gwayemalo.
\q1 Bemar-Jacob-wagan-gandik-gusur-inigwele,
\q2 melle be gwayemalo.
\q2 Ar an-sunnagwad an be-bendakoed.
\q1 Ani an Israel-dulemar-e-Bab-Dummad-Isligwaled gued.
\q2 Ar an be-Bendakedid.
\b
\q1 
\v 15 ”Ibmar-gwag-egwaed-binidyobi an be-imakmaloed,
\q2 e-nugar-abinbela-datarmakar-nikayobi an be-imakmaloed.
\q1 Yarmar be obelogoed, swana be imakoed.
\q2 Yar-mullugana gaganbi naguega be imakoed.
\q1 
\v 16 Oros-gwag-burwaba-mileddaedyobi be imakoed.
\q2 Burwa-noedba aisakidmaloed.
\q1 Ar bedi, angi weligwar itogoed.
\q2 Bedi, angi Israel-dulemar-e-Bab-Dummad-Isligwaledgi nug-gannarba itomaloed.”
\p 
\v 17 Bab-Dummad sogdebalid:
\q1 “Dule-wilemalad, degi, dule-ibmar-abesa-gudimalad, gobega dii amididamalad,
\q2 degi-inigwele, amidasurmalad.
\q1 Uku-uku-itogedba gwabin-dinna itogusdamalad.
\q2 Degi-inigwele, ani Bab-Jehová-guedgi an amar-itogoed.
\q1 Ani an Israel-dulemar-e-Bab-Dummad-guedgi,
\q2 an amar walagwen metosulid.
\q1 
\v 18 Yalamar-biribali, diwarmar-iirmakega an imakoed,
\q2 nebaganba ibemargi-dii-aryogega an imakoed,
\q1 nega-dulesulidganba dii-ambikuega an imakoed.
\q2 Neg-dinnaganba ibemar-aryomai an imakoed.
\q1 
\v 19 Nega-dulesulidganbali, urwarmar, acacia-sapimar, an digoed.
\q2 Baryawarmar, degine, olivo-sapimar an digoed.
\q1 Napa-isganagi, ciprés-sapimar an digoed,
\q2 pino-warmar, degi, abeto-sapimar an digoed.
\q1 
\v 20 Adi, dulemar dakega, degi, wisgumalaga,
\q2 egi binsamalaga, degi, magar-itomalagar,
\q1 Bab-Jehová we-ibmarmar-imaksaye,
\q2 Israel-dulemar-e-Bab-Dummad-Isligwaledi, we-ibmarmar obinnisye.”
\s1 Bab-Dummadi, bab-dummagan-baigangi obined
\p 
\v 21 Bab-Jehová Jacob-dulemar-e-Rey, ibmar-sobaled-bab-dummadyobi-imaklemaladga sogded:
\q1 “Be-igar be sogmardo.
\q2 E-wilubmar be oyomardo.
\q1 
\v 22 Wese be dagmar, ibmar-guoed be sogmar.
\q2 Gebesailagi ibmarmar-gusnanaedi, anmarga be soge,
\q1 anmar egi binsaegar, degi, ibmar-gusadi, anmar magar-itomalagar.
\q2 Igi-neg-guoe anmarga be sogmar.
\q1 
\v 23 Yoedse-negguoed be anmarga sogmar,
\q2 adi, anmar wisgumalagar, bemar bab-dummagan gumarye.
\q1 Bemar ibmar imakmala, nueddibe, ichakwadibe,
\q2 adi, anmar dakega, degi, anmar ese gwayegar.
\q1 
\v 24 Ar bemar binsarmaladid,
\q2 ar be-ibmar-imakmaladi, binsa ibmar-imaklemaladid.
\q2 Ar dule-begi-bensurmaladga ibmar-nuedga be gusurmalad.”
\p 
\v 25 Bab-Dummad sogdebalid:
\q1 “Dad-nakwed-argan-sapiledsik, dule-gwensak-dagega an imaksad.
\q2 An-ese-gochad, an-itosad.
\q1 We-dule, dad-nakwedsik an-nug odummogoed.
\q2 We-dule, dule-dummagan-negsemamaid-birgi dule-napsa-sobed-napsagi-dii-dii-annanaiyob imakoed.
\q1 
\v 26 ¿Ar doa we-ibmar-guoed gebesailaunni anmar-owisosa?
\q2 ¿Ar doa abgayala we-ibmar-guoed anmar-owisosa?
\q1 Adi, anmar sogega, eye, nabir sogye.
\q2 Ar dule gwen we-ibmar-guoed sogsasulid,
\q1 dule gwen owisossurbalid.
\q2 Dule-we-ibmar-guoed-soged, gwen dule itossurbalid.
\q1 
\v 27 Ar ani an abgasaila Sión-dulemarga bato an sogsad: ‘Be dakmarye, bato wegi bukmarye.’
\q2 Ani an Jerusalén-neggweburse dule-gayaburba-berbeged-nued barmisad.
\q1 
\v 28 An-dikarbali an atakded,
\q2 dule gwen an daksulid.
\q1 Emar-imbagi dule-ega-binsaed-daked gwen an daksulid.
\q2 An ibmar-ese-egichidgu, gwen an-abinsassurmalad.
\q1 
\v 29 Ar bela we-bab-dummagan-baigana binsa-ibmar-imaklemaladyobi gued.
\q2 E-ibmar-imakmaladi, gwen nabirsulid.
\q1 E-ibmar-sobarmalad-bab-dummadyob-imaklemaladi, unnila uka-olloo daklemaladid.
\q2 Binsa-ibmar-daklemalad gued.”
\c 42
\s1 Bab-Jehová-e-mai
\p 
\v 1 Bab-Jehová soged:
\q1 “We, an-mai-gued.
\q2 Ani an we-dule-sediid.
\q1 Ani na susad.
\q2 An egi yeer itoged.
\q1 An-burba an ega uksad.
\q2 Ani Bab-Jehová, dulemar-yar-baid-baidgi-bukmaladga igar-innikigwad imakoed.
\q1 
\v 2 We-dule, binnasuli golosulid, sabsuli sunmakosulid.
\q2 Galimbaba binnasuli sunmakdii itolegosulid.
\q1 
\v 3 Nargammu-bisgedanigwichidi bar bisgosurmalad.
\q2 Gwallu-gwillo-binnagamaidi gwen oginnosulid.
\q2 Igar-napiragwadbali igar nabogoed.
\q1 
\v 4 We-dule, napneggi igar-napiragwad-omesedse gwen wieguosulid, gwen galakuosulid.
\q2 Demar-gakaba-neggwebur-bukmalad, we-dule-e-odurdaked abdakbukwad.”
\p 
\v 5 Bab-Dummad-Jehová mogir-billi obinnisadid, mogir-billi nasiksadid, napneg onasosadid, bela egi-ibmar-sanmaked onasosadid, dulemar-bukwadga niga-ogannogedid, dulemarga burba-dulad-ukedid. We-Bab-Dummad-Jehová weyopira soged:
\q1 
\v 6 “Ani an Bab-Jehová gued.
\q2 Ani an bese gochad,
\q1 igar-innikigwad-imakega an be-semai gusad.
\q2 Ani an be-odenonikid,
\q1 an-dulamarga an dulemarbo-igar-mesisad-e-wilubga-guega an be-imaksad.
\q2 Dule-yar-baid-baidgi-bukmalad-magar-neg-itomalaga, gwallu-meegwadyobi an be-ogwisgunonikid.
\q1 
\v 7 Adi, be dulemar-aku-atakmaladga ibya egaegar,
\q2 be dule-esgaryagi-bukmalad onogegar,
\q2 degi, be dule-esgaryaba-negsichidgi-bukmalad onogegar.
\b
\q1 
\v 8 ”¡Ani an Jehová gued!
\q2 ¡Deyob an nugad!
\q1 An-nug-odummolegedi, dule-baidgadga guosulid.
\q2 An-nug-odummolegedi, ibmar-sobaled-bab-dummadyob-imaklemaladga an ukosurbalid.
\q1 
\v 9 Ibmar-iduar-an-sogsagusmalad bela gusad.
\q2 Emisgindi, ibmar-gwapidmarbi an sogbalid.
\q2 Iduakwaa ibmar-guoed an bemar-owisoged.”
\s1 Bab-Jehová-nug-odummogedgi namakleged
\q1 
\v 10 Bab-Jehováʼga namakleged-gwapidgi be namakmar.
\q2 Bemar-muu-billigi-iirmakbukwad, ega be namakmar.
\q1 Demar-yagi-ibmar-dula-bukmalad, Bab-Jehová-nug odummomar.
\q2 Napneg-ugakagi-bukmalad, Bab-Jehová-nug ogannomar.
\q1 Bemar demar-gakaba-bukmalad, Bab-Jehová-nug be odummomar.
\q2 
\v 11 Nega-dulesulidganba-bukwamalad, bemar binnasuli gormar.
\q1 Cedar-dulemar neggwebur-burwigangi-bukmalad, bemar binnasuli gormar.
\q2 Sela-dorgan, yeer-itogedba be namakmar,
\q2 yeer-itogedba yala-birgi binnasuli be gormar.
\q1 
\v 12 Gandikidba be Bab-Jehová-nug odummomar,
\q2 neggwebur-demar-gakaba-bukmaladgi binnasuli Bab-Jehová-nug be odummomar.
\q1 
\v 13 Bab-Jehová dule-bila-onogedyob nodagoed.
\q2 Dule-bila-onoged-urweyobi uludagoed.
\q1 Binnasuli urwedgi bila-onodagoed,
\q2 e-isdarmaladgi obinoed.
\p 
\v 14 Bab-Jehová soged:
\q1 “An dikasurgusa bogidik gudigusad,
\q2 an gwen sunmaksasulid, an gwen ibmar sogsasulid.
\q1 Emisgindi, an binnasuli goloed.
\q2 Ome-ugakgunair binnasuli-bunnonaiyobi, akus-akus-bunnonaiyobi, binnasuli gornai an guoed.
\q1 
\v 15 Yalamar, degi, yar-mullugana, an obelogoed.
\q2 E-gaganmar bela an odinnogoed.
\q1 Diwarmar neg-dinnaganaga an imakoed,
\q2 dii-wilagana an odinnogoed.
\q1 
\v 16 Dule-aku-atakmalad, igar-dakdisurmaladba an nidoed,
\q2 nanaledisulid-igarba an nidoed.
\q1 Amar-asabinni, negsichidi neg-meegwadga an imakoed.
\q2 Amar-idu, neg-muru-murumalad an innikii imakoed.
\q2 Deyob an imakoed, an gwen amar-obanosulid.
\q1 
\v 17 Dulemar ibmar-sobaled-bab-dummadyob-imaklemaladgi bengudisurmaladi,
\q2 nue-bingegus bangudmaloed.
\q1 Akwa-sobarmaladga-sokardamaladi, ‘be anmar-bab-dummaganaye,’
\q2 a-dulemala, nue-bingegus bangudmaloed.”
\s1 Israel-dulemar amba gwen-durdaksurmalad
\p 
\v 18 Bab-Dummad weyob soged:
\q1 “¡Dule-uaya-yallirmalad! Nue be itomarsun.
\q2 ¡Dule-aku-atakmalad! Nue be atakmarsun.
\q1 
\v 19 ¿Doa an-maiba bur bule akusunna ataksunna?
\q2 ¿Doa an-gayaburba-berbergedba bur bule uaya-yallirsunna?
\q1 ¿Doa an-nuggi-barmilesadba bur bule akusunna ataksunna?
\q2 ¿Doa Bab-Jehová-e-maiba bur bule akusunna ataksunna?
\q1 
\v 20 Be ibmar-bukidar-daksa-inigwele, degite, be amba aku daked.
\q2 Uaya be olloo-sii-inigwele, be ibmar-itosulid.”
\b
\q1 
\v 21 Bab-Jehová, e-igar-innikigwad-sabedbali, yeer-itosad.
\q2 E-igar-maid-dummarba-guedbali, degi, gandikid-guedbali, yeer-itosad.
\q1 
\v 22 Ar we-dulemarde atursaledidimalad,
\q2 sabsur odurdakledidimalad.
\q1 Bela akwa-dummagan-yaba gales-bukwamaladid,
\q2 esgaryaba mellesmaladid.
\q1 Ei-ibmar atursales gudidimalad, dule gwen bendakdisurmalad.
\q2 Ei ibmar sules gudidimalad.
\q2 Gwen dulemar gannar-ega-ibmar-ukmarye sogdisurmalad.
\b
\q1 
\v 23 ¿Doa bemar we-ibmar itogoe?
\q2 ¿Doa bemar yoedse-we-ibmar-guoed nue-itogoe?
\q1 
\v 24 ¿Doa ibmar-sulesmaladyobi Jacob-wagan-uksa?
\q2 ¿Doa ibmar-atursalealedyobi Israel-dulemar-uksa?
\q1 ¿Ar Bab-Jehová e-dulamar egi isgusgusad urmaksasursi? Eye, urmaksa.
\q2 Ar ade, Bab-Jehová-igarba nanassurmalad,
\q2 e-Igar-Maid-sogedba ibsassurmalad.
\q1 
\v 25 A-ulale, Bab-Jehová egine ulusad,
\q2 bila egi onosad.
\q1 Soogine sabsur-odurdaksad, degi-inigwele, amba aku-itosmalad.
\q2 Sabsur-odurdakles-inigwele, amba eba ibsassurmalad.
\c 43
\s1 Bab-Jehováʼbi unnila Israel-Dule-Abonogedid
\p 
\v 1 Jacob-wagan, Bab-Jehová-be-obinnisadi soged, Israel-dulemar, Bab-Dummad-be-urbisadi, weyob soged:
\q1 “Melle be dobguo,
\q2 ar ani an be-nudaksad.
\q1 Be-nugba an bese gochad.
\q2 Be an-mimmi gued.
\q1 
\v 2 Be dii-obaknaile, an beba nadapmogoed.
\q2 Be diwar-obaknaile, be gundilegosulid.
\q1 Soo-birgi be nadapile, gwen be gummakosulid.
\q2 Soo-duurmakedi gwen begi naguosulid.
\q1 
\v 3 Ar ade, ani an be-Bab-Dummad-Jehová gued,
\q2 an Israel-dulamar-e-Bab-Dummad-Isligwaledid,
\q2 an be-Abonogedid.
\q1 Ani an, be-onogega, Egipto-dulemar-urmaksad.
\q2 Be-muchub Etiopía-yar, degi, Seba-yar an urmaksad.
\q1 
\v 4 An be-muchubbi dulemar-urmakoed,
\q2 an be-san-burba-muchubbi, dule-bamalad an urmakoed.
\q1 Ar an bela-belad bemar-sabed.
\q2 Be an-asabinni, ibiyob be yeerdaklege, be duledar-nued gued.
\q1 
\v 5 Melle be dobguo.
\q2 Ar an beba gudiid.
\q1 Dad-nakwed-akale, an be-anagan sedagoed.
\q2 Dad-argwaned-akale, an be-urboed.
\q1 
\v 6 Dulemar-dad-nakwed-argan-sapiledsik yar-baid-baidgi-bukmaladga an sogoed:
\q2 ‘¡An-dulamar anga udage!’
\q1 Dulemar-dad-nakwed-argan-nuedsik yar-baid-baidgi-bukmaladga an sogoed:
\q2 ‘¡Melle an-dulamar gamalo!’
\q1 Be anga an-masmala-dikasuli-bukwad sedage,
\q2 be anga an-bunamala-napneg-ugakaase-bukwad sedage.
\q1 
\v 7 An-nugba-ese-gollemaladi, be anga bela seda.
\q2 An-nug-odummogega an obinnisadi, be anga seda.
\q1 Ani an obinnisad,
\q2 ani an urbisad.”
\s1 Israel-dulemar, Bab-Dummad-barsogega gued
\p 
\v 8 Bab-Dummad soged:
\q1 “Dule-aku-atakmalad, amba ibya-nika-inigwele, be anga onimar.
\q2 Dule-uaya-yallirmalad, amba uaya-nika-inigwele, be anga onimar.
\q1 
\v 9 Dule-yar-baid-baidgi-bukmalad bela be oambikumar.
\q2 Bela dulemar danar ambikumar.
\q1 ¿Doa we-dulemar-abargi we-ibmar-guoedgi iduakwaa anmarga sunmaksa?
\q2 ¿Doa ibmar-gusmalad anmarga sogsa gusa?
\q1 E-daksamalad be oyomardo,
\q2 nabir-sogmarye be sogmardo,
\q1 adi, dule-baigan itomalagar,
\q2 degi, sogmalagar: ‘Napiraye.’ ”
\p 
\v 10 Bab-Jehová Israel-dulemarga soged:
\q1 “Bemar an-barsogega be gumar,
\q2 anga-arbaega an bemar-susad,
\q1 adi, bemar magar-an-dakmalagar,
\q2 melle angi bengumalagar.
\q1 Adi, be magar-itomalagar, an doa gue.
\q2 An-iduale, bab-dummad-baid gwen megissulid,
\q2 gwen an-sorba bab-dummad-baid megosurbalid.
\q1 
\v 11 Ani an Bab-Jehová gued.
\q2 An-imbagi, dule-abonoged-baid sated.
\q1 
\v 12 Ani an bemar-owisosad,
\q2 ani an bemar-bendaksad.
\q1 Ani an bemarga sunmaksad.
\q2 Bemar-abargi, gwen bab-dummad-baid gudii gussulid.
\q1 Ani an gudii gusad.
\q2 Ani an Bab-Jehová-guedgi soged:
\q1 ‘Bemar an-barsogega be gumarye,
\q2 Ani an Bab-Dummad guye.’
\q1 
\v 13 Ani an gebe-negasaila-akale Bab-Dummad gued.
\q2 Dule gwen angi wakinnosulid.
\q2 An-ibmar-imakedi, dule gwen obelogosulid.”
\s1 Bab-Dummad Israel-dulemar-ise-wile daksad
\p 
\v 14 Israel-dulemar-e-Bab-Dummad-Jehová-Isligwaled bemar-bendakmaidi, weyob soged:
\q1 “Bemar-ulale, Babilonia-neggweburse sorda-bamalad an barmidoed.
\q2 Dulemar-wakindiiyobi an bela Babilonia-dulemar-imakoed.
\q1 Caldea-dulemar urmar-nikadba na nug-dummarba-itodimalad,
\q2 bela an obelomogoed.
\q1 
\v 15 Ani an Bab-Dummad-Jehová-Isligwaledid.
\q2 Ani an bemar-e-rey gued, Israel-dulemar-obinnisad gued.”
\p 
\v 16 Bab-Jehová sogdebalid:
\q1 “Ani an demargi igar-mesisgusad,
\q2 dii-wilasailadgi igar-egasgusad.
\q1 
\v 17 Egipto-sordamar, moli-birgi, degi, moli-ur-bila-onomaladgi, Israel-dulemar-bargananai-gusmargua,
\q2 Bab-Jehová, Egipto-sordamar-bela-obelosgusad.
\q2 Gwallu-gwillo-akichayob amar-imaksagusad.”
\p 
\v 18 Bab-Jehová weyob soged:
\q1 “Ibmar-nasmalad be iemar,
\q2 melle bar ibmar-gusmaladgi be binsadii gumar.
\q1 
\v 19 Ibmar gwapidmar an imakoed.
\q2 ¿Ar bato ibmar-imaklenaid aku be dakmarsi?
\q1 Ar nega-dulesulidganba an igar mesnaid,
\q2 neg-dinnaganba an diwarmar mesnaid.
\q1 
\v 20 Ibmar-durgan-sapurbarmalad-ursilimalad, an-nug ogannomalad.
\q2 Achu-sapur-uaya-gannagana, nuu-dummad-dukar-suid-avestruzʼye-nugmalad, an-nug odummomalad.
\q1 An an-dulamar-susad-ogobega, nega-dulesulidganba dii-suurmakega an imaked,
\q2 neg-dinnaganba diwarmar-megega an imaked.
\q1 
\v 21 We-dulemar angadga-guega an urbisad,
\q2 an-nug ogannomalaga an urbisad.
\b
\q1 
\v 22 ”Degi-inigwele, bemar, Jacob-wagan, gwen an-nug odummossurmalad.
\q2 Israel-dulemar, bemar angi wiegudmalad.
\q1 
\v 23 Anga bemar sibad-wawaad-sapingana-ogumakar uksasurmalad,
\q2 ibmar-durgan-anga-ukedgi gwen be an-nug ogannosurmalad.
\q1 An bese-ibmar-gwag-ukleged-egichedgi-wieguega, an bemar-imaksasulid.
\q2 Ina-wawagan-oburmakedgi-budar-itogega, an bemar-imaksasulid.
\q1 
\v 24 Be anga gwen masar-wawadikmalad baksasulid.
\q2 Gwen be ibmar-durgan-oburgwileged-e-gwallugi an-yeer-itogega, be an-imaksasulid.
\q1 Aka bur be be-isgumaladgi isdarsunna-itogega be an-imaksamalad.
\q2 Be-isgumaladi, budarsunna-be-dakega an-imaksad.
\b
\q1 
\v 25 ”Degi-inigwele, ani, an nue-be-sabsoggu, a-ulale, an bega isgued elied.
\q2 An be-isguedgi bar binsaosulid.
\q1 
\v 26 Be angi ibmar-soged-nikale, igar-nabogedneggi be anga sogdado.
\q2 Be ibmar sogdo, adi, magar-daklegega, bule-nabir be ibmar imaksasuli.
\q1 
\v 27 Ar be-dad-sailaginedi isgusad.
\q2 Be-odurdakmaladi, angi dummad-nosmalad.
\q1 
\v 28 A-ulale, anse-goled-neg-dakmalad-dummagan nug-bipii an imaksad.
\q2 Jacob-wagan-bela-obelolegega an imaksad.
\q2 Israel-dulemar-mesagwar-imaklegega an imaksad.”
\c 44
\s1 Bab-Jehováʼbi, Bab-Dummadid
\p 
\v 1 Bab-Jehová soged:
\q1 “An-mai-Jacob-dulamar, Israel-dulamar-an-na-susad.
\q2 ¡Emigi, nue be an-itogo!”
\q1 
\v 2 Weyob Bab-Jehová-be-obinnisadi, sapibeneggi be-omesisadi,
\q2 be-bendakmaidi, soged:
\q1 “Jacob-dulamar, melle be dobgu,
\q2 be an-mai gued,
\q2 Jesurún, ani an be-susad.
\q1 
\v 3 Napa-dinnaganaba dii-suurmakega an imakoed,
\q2 nega-dinnaganaba dianmar an omesoed.
\q1 Be-wagangine, An-Burba an odegoed,
\q2 be-anagangine, ise-nued an binsaoed.
\q1 
\v 4 Gagan-oglegwichiyobi gumaloed,
\q2 dianmar-gaka-nagaba sapi-senigana-gwigwichi-daeyobi gumaloed.
\q1 
\v 5 Dule-gwensak sogdagoed: ‘An Bab-Jehováʼgad gued.’
\q2 Dule-baiddi ‘Jacobʼye’ nugguoed.
\q1 Dule-baidmoga e-argangi weyob narmakoed:
\q2 ‘Ani an, Bab-Jehováʼgadi.’
\q2 Geb Israel-nug e-nugga imakoed.”
\s1 Bab-Jehová, degi, bab-dummagan
\p 
\v 6 Weyobi, Bab-Jehová, Israel-dulemar-e-Rey, Israel-dulemar-Bendakmaidi, degi, Bela-Gangued-Nikadi, soged:
\q1 “Ani an gebesailadid, anse bergunaibalid,
\q2 Bab-Dummad-baidi sulid.
\q1 
\v 7 ¿Doa anyob gusunna?
\q2 ¡Dule anyobile, sunmakdo!
\q1 An an-dulamar-urbisad-akale, ibmarmar-gusad sogdo.
\q2 ¡An-asabin, yoo-ibagan-guoedgi sunmakdo!
\q1 
\v 8 ¡Melle be gwayemar,
\q2 gandik be imakmar!
\q1 ¿Ar bato an bega sogsasursi?
\q2 ¿Dikasurgus an be-owisossursi?
\q1 Ar bemar an-barsogega gumalad.
\q2 ¿Ar Bab-Dummad-baid maisi? Suli.
\q1 ¿Bab-Dummad-baid bebina-sogedi maisi? Suli.
\q2 Gwen Bab-Dummad-baid-gudii an dakdisulid.”
\s1 Bab-dummaganyob-soblesmalad-binsarmalad
\q1 
\v 9 Dule ibmar-bab-dummadyob-imakleged-sobmaladi, ibmar-nuedga gusulid.
\q2 E-ibmar-bur-yeerdakle-sobarmaladi, gwen ibmar-nuedga gusulid.
\q1 E-sobmaladi, na wismalanad,
\q2 we-ibmar-bab-dummadyob-imaklegedde, aku atakmalad, uaya yallirmalad.
\q1 
\v 10 Dule-bab-dummad-baid-sobedi, we-ibmar ega ibmar-nuedga gusulid.
\q2 Degi, esgoro-diregwadgi bab-dummadyob-imakleged-sobedi, we-ibmar ega ibmar-nuedga gusulid.
\q1 
\v 11 Bela dule-ega-san-uksamaladi, bingedar itomaloed,
\q2 we-ibmar-sobedgi-arbamaladi, unnila dulemar gumalad.
\q1 Bela bular ambikudamarsun, bela dagmarsun.
\q2 Ar bela ise-gwayar bukudmaloed, nue-bingedar itodmaloed.
\b
\q1 
\v 12 Dule-esgoro-sobed, esgoro amied.
\q2 Geb soo-ginnitibidgine, esgoro mesed.
\q1 Geb mardogi sarsogar bab-dummadyob-imakleged sobed.
\q2 Ise nuesaar imaked.
\q2 Ar dule-esgoro-sobedi, mas-gunsuli-arbanaile, gobsurbalile, nolloleddaed.
\q1 
\v 13 Dule-ibmar-sobedi, suargi-ibmar-soboed dubgi wilub-imaked.
\q2 Geb esgoro-garagwadgi ibmar sobed, ibmar-orokwaa-saedgi wagar-wilub-onoged.
\q1 Geb a-sorbali, akwa duleyob-daklege, degi, yeerdaklege sobed,
\q2 adi, neg-bipigwad-yaba ogwisegar.
\b
\q1 
\v 14 Dule-baigan nikabalid, urwar-digmalad.
\q2 Geb dii-wiedi a-urwarmar odummoged.
\q1 Geb urwar siklegega bukidar nika gunonikoed.
\q2 Ciprés-warmardibe, barya-warmardibe, sapurba digdamalad,
\q2 nue-odummogedse imakdamalad.
\q1 
\v 15 Geb dulemar e-anagan soo-ogaega imakdamalad.
\q2 Dule waegala, sapan-negabala ogadamalad.
\q2 Egi soo-ogasale, madu yodamarbalid.
\b
\q1 Deginbali, egi suar-nuchu sobdamarbalid.
\q2 Geb e-nug-odummoddamalad.
\q1 Ibmar-sobaled-bab-dummadyob-imakleged sobdamarbalid.
\q2 Geb asabin yokorgi-sindigar sigdamalad.
\q1 
\v 16 Abala, a-suar, sapanga imakdamalad.
\q2 Egine, geb na mas dudamalad,
\q1 degi, san nariddamarbalid,
\q2 geb nue-immelesdamalad.
\q1 Geb deginbali, egi wadamarbalid.
\q2 Sogdedamalad: “Soo-gasgu, wis uka-uegus-itole.”
\q1 
\v 17 Geb suar-gwabgusadgi, suar-nuchu sobdamalad,
\q2 e-bab-dummadga imakdamalad.
\q1 Geb asabinni yokorgi-sindigar sigdamalad,
\q2 e-nug odummoddamalad.
\q1 Geb ise-wilegar ega sogdedamalad: “Be an-bendake,
\q2 ar bee be, an-bab-dummadid.”
\b
\q1 
\v 18 Ar we-dulemar ibmar wissurmalad.
\q2 Akusunna ibmar itomalad.
\q1 Ar nue-atakmar-inigwele, akusunna ibmar dakmalad.
\q2 Neg-aku-itomaladid, akusunna ibmar-itomaladid.
\q1 
\v 19 Amba ibmar-wisgued napid.
\q2 Amba magar-ibmar-itoged abeged.
\q1 Ar gwen weyob binsasurmalad,
\q2 weyob sogsurmalad: “Suar, abala madu-yoega an ebusad,
\q1 abala an egi san-narisbalid, a-san an guchad.
\q2 ¿A-suar-gwabgusadgi, an ibmar-isgana sobode?
\q2 ¿Ar we-suar-asabin ande yokorgi-sindigar sigode?”
\q1 
\v 20 Ar we-dulemar sooburu-maeyobi gumalad.
\q2 Dukin e-binsaedbali yamoledimalad.
\q1 Geg na-dukin agi onomalad,
\q2 degi, geg sogbalid: “¡We an-argan-nuedsik-ibmar-ganikidi, ibmar-binsaledid!”
\p 
\v 21 Bab-Dummad weyob sogded:
\q1 “Jacob-wagan, we-ibmar be insao.
\q2 Ani an be-obinnisad, be an-maiga-gued,
\q1 Israel-dulemar, an gwen be-iegosulid.
\q2 Israel-wagan, ar be an-maiga gued.
\q1 
\v 22 Burwa-sibugana-yogguddaedyobi, an bega be-ibmar-isgana-imaked, osulosad.
\q2 Degi, boo-aisakiddaedyobi, an bega be-isgued osulosad.
\q1 Gannar be anse dage,
\q2 ani an be-nudaksad.”
\p 
\v 23 Isaías weyob sogded:
\q1 “Mogir-billi, Bab-Jehová-ibmar-imaksadgi weligwaledgi be namak.
\q2 Napa-yaa-matusurmalad, gandikidba be gormakmar.
\q1 Yalamar, sapurmar, degi, bela e-sapimar, binnasuli be namakmar.
\q2 Ar ade, Bab-Jehová Jacob-dulemar-bendaksad,
\q2 Bab-Dummadi e-gandikid-yeerdakleged Israel-yalagi oyosad.”
\s1 Jerusalénʼgi dulemar gannar ambikuoed
\q1 
\v 24 Weyob Bab-Jehová-be-bendakedi, sapibeneggi-be-omesisadi soged:
\q2 “Ani an Bab-Jehová gued, bela ibmar-obinnisadid.
\q1 Ani an wargwen mogir-billi egasadid.
\q2 Ani an dukin napneg onasosadid.
\q2 Dule gwen an-bendaksasulid.
\b
\q1 
\v 25 ”Ani an Bab-Dummad-gayaburba-barsogedyob-san-imakdamalad-e-ibmar-sogedi, ega guega an imakdasulid.
\q2 Nergan an obingesadaed.
\q1 Dule-binsaed-ibegana sikirmakega an imakdaed.
\q2 E-binsaed-nikaa-daedi, gannar-gannar-ibmar-obaredga an imakdaed.
\q1 
\v 26 Ani an an-maimar-gayaburba ogannodaed.
\q2 Degi, anga-gayaburba-berbemalad anse-ibmar-egisedi, sogedba-guega an imakdaed.
\b
\q1 ”Ani an soged, ‘Jerusalén-neggwebur gannar sigoye,
\q2 Judá-neggweburmar gannar bukuoye,
\q2 e-neg-bibichismalad, gannar an nudakoye.’
\q1 
\v 27 Ani an demar-wilasailad odinnoged.
\q2 Degi, diwar-odinnogega an igar ukbalid.
\q1 
\v 28 Ani an Rey-Ciroʼgi soged: ‘Anga sibad-wawaad-edarbed guye.
\q2 An-ibmar-abegedi anga sogedba imakoye.
\q1 Jerusalén-neggwebur gannar sigoye.
\q2 Anse-goled-neg-e-saila gannar megoye.’ ”
\c 45
\s1 Bab-Dummad Ciroʼga igar-uked
\p 
\v 1 Isaías soged:
\q1 “Bab-Jehová, dulemar-yar-baid-baidgi-bukwamalad Ciro-urbalikwaa-nanaega imaksad.
\q2 Ciroʼde, Bab-Jehová-nuggi-reyga-nugsalesadid.
\q2 Degi, Bab-Jehová, Ciro reymar-e-gangued-obelogega imaksadid,
\q1 Ciro-abinni, yawagakmar-argaega-imaksadid,
\q2 yawagakmar-mer-bar-atuega-imaksabalidid.”
\p 
\v 2 Bab-Jehová weyob Ciroʼga soged:
\q1 “Ani an be-idunadapi guoed,
\q2 ani an yalamar-omatogoed.
\q1 Ani an bega esgoro-gordikid-yawagakmar mamaroed,
\q2 ani an bega yawagak-eduged-esgorobiid bibisgoed.
\q1 
\v 3 Ibmar-nuegan-gargerbamalad-dukuar-bukwad an bega ukoed.
\q2 Ibmar-nuegan-dukuar-bukwad an bega ukoed.
\q1 Adi, be wisguegar, ani an Bab-Jehová gued.
\q2 Ani an Israel-dulamar-e-Bab-Dummadid.
\q1 An be-nugba bese goledid.
\q2 
\v 4 An, an-mai-Jacob-sabedbali, degi, an Israel-dulamar-susadbali, an bese be-nugba goled.
\q1 Be aku an-dak-inigwele, an bega nug-gandikid uked.
\q2 
\v 5 Anbi an Bab-Jehová gued, dule-baid sulid.
\q1 An-imbagi, Bab-Dummad-baid sulid.
\q2 Be aku an-dak-inigwele, an be-ogannogoed,
\q1 
\v 6 adi, dulemar dad-nakwedsik-bukmalad, degi, dad-argwanedsik-bukmalad wisgumalagar, an-imbagi Bab-Dummad-baid sulid.
\q2 Anbi an Bab-Jehová gued, dule-baid sulid.
\q1 
\v 7 Ani an neg-meegwad nasiksad,
\q2 ani an negsichid nasikbalid.
\q1 Ani an dulemar-nued-gudiguega imakbalid,
\q2 ani an boni-dummagan ukbalid,
\q2 ani an Bab-Jehová-guedi, bela we-ibmarmar imakmaid.”
\s1 Bab-Jehová ibmar-obinnisadid
\p 
\v 8 Bab-Jehová soged:
\q1 “¡Nibali, dii-boomiedyobi igar-innikigwad an barmidsun!
\q2 ¡Mogir-imbaba dii-wiedyobi igar-napiragwad an barmidsun!
\q1 ¡Napneggi igar-innikigwad maiguguega an imaksun!
\q2 ¡Abonoleged an barmidsun!
\q2 An Bab-Jehová-guedgi an we-ibmarmar obinnisad.”
\p 
\v 9 Bab-Dummad sogbalid:
\q1 “Dule na e-obinnisadbo urwele, ¡duledar-wiles-dakle!
\q2 Ar dule napsa-nog-goayobi, napsa-nog-goamar-abargi-milediidyob gued.
\q1 Ar napsa dule-e-sobedga weyob sogosi: ‘¿Ibu be imaknai?
\q2 Be-ibmar-imaknaid nue be imaknaisulid.’
\b
\q1 
\v 10 ”Dule e-babga sogele: ‘Ibiga be an-baksa.’
\q2 Dule-deyob-sogedi, ¡duledar-wiles-dakle!
\q1 Dule e-nanga sogele: ‘Ibiga be napnegse an-odesa.’
\q2 Dule-deyob-sogedi, ¡duledar-wiles-dakle!”
\p 
\v 11 Bab-Jehová Israel-dulemar-e-Bab-Dummad-Isligwaled, Israel-dulemar-urbisad, weyob soged:
\q1 “¿Ar igi-an-mimmigan-yoedse-guoed be anse egichosi?
\q2 ¿An-ibmar-obinnisadgi bemar anga igar-ukosi? Suli.
\q1 
\v 12 Ar ani an napneg nasiksad.
\q2 Ani an dulemar urbisad.
\q1 An-argangine, mogir-billi an nasiksad.
\q2 E-niisgwamarga ani an igar uksad.
\q1 
\v 13 Ani an gandikidba Rey-Ciro-ogwichisad,
\q2 an ega igarmar nudakoed.
\q1 Ciro anga an-neggwebur gannar urboed,
\q2 an-dulamar-gales-bukwad anga onogoed.
\q1 Ciro, an-dulamar-onogoedi, manigi-baklegar onogosulid.
\q2 Ani an Bab-Jehová-Bela-Gangued-Nikad deyob soged.”
\p 
\v 14 Weyob Bab-Jehová soged:
\q1 “Egipto-e-ibmar-nuegan, degi, Etiopía-e-ibmar-nuegan, begadga gumaloed.
\q2 Sabeo-dule-burwisurmaladi, be-sorba esgoro-dubgi ebipilemai gumaloed.
\q1 Bemar-asabinni yokorgi-sindigar bukumaloed,
\q2 ise-wilesakwaa bemarga sogdamaloed:
\q1 ‘Unnila Bab-Dummad wargwenna-mai, Bab-Dummad-baid suli.
\q2 We-Bab-Dummadi, bemarba naid.’ ”
\b
\q1 
\v 15 Bab-Dummad, be, Israel-dulemar-Abonogedid,
\q2 be Bab-Dummad-akudaklegedid.
\q1 
\v 16 Bela dulemar ibmar-bab-dummadyob-imaklemalad-sobmaladi, bingedar-itoge gumaloed,
\q2 degi, san-bipii gumaloed.
\q2 Bela bular na san-bipi gumaloed.
\q1 
\v 17 Israel-dulemar Bab-Jehováʼgi-nue-bendaklesmalad, bendakles sadegumaloed.
\q2 Bali-bipisaale, bingedar-itogosurmalad, bali-san-bipi imaklegosurmalad.
\p 
\v 18 Ar ade, weyob Bab-Jehová soged:
\q1 “Ani an Bab-Jehová gued,
\q2 Bab-Dummad-baid sulid.
\q1 Ani an mogir-billi-obinnisadid.
\q2 Ani an napneg-nasiksadid.
\q1 Ani an napneg-ilemakar nasiksadid,
\q2 binsa-ollobi-nasikega an imaksasulid,
\q2 dulemar egi ambikuega an imaksad.
\q1 
\v 19 Gwen an bemarga we-napneg-naidgi negsichidgi-dukuar an sunmaksasulid.
\q2 Degi, gwen an Jacob-waganga weyob sogsasulid: ‘Neg-olloledgi be an-amimalo.’
\q1 Ani an Bab-Jehová-guedgi igar-napiragwadbi an soged,
\q2 degi, an igar-innikigwadbi soged.”
\s1 Bab-Jehová, degi, ibmar-sobarmalad-bab-dummadyob-imaklemalad
\p 
\v 20 Bab-Jehová sogbalid:
\q1 “Dule-yar-baid-baidginmalad bemar-wakindimalad be atomar,
\q2 be anse dagmar.
\q1 Akusunna-ibmar-itomaladi, ibmar-sobarmalad-bab-dummadyob-imakleged sedimalad.
\q2 Degine, bab-dummagan-gwen-e-abonogosulidse gordimalad.
\q1 
\v 21 Be sunmakmar, ibmar-imaksad be sogmar,
\q2 na be muchub-muchub egisnanai be samalo.
\q1 ¿Doa bato dikasurgus iduakwaa we sogsa?
\q2 ¿Doa epenne bato we-ibmar sogsa?
\q1 ¿Ar ade, ani an Bab-Jehová we-ibmar sogsasursi?
\q2 Baid Bab-Dummad sulid.
\q1 Ani an Bab-Dummad-Innikidaedid.
\q2 Ani an Dule-Abonogedid.
\q2 Baid Bab-Dummad sated.
\b
\q1 
\v 22 ”Bela napneg-ugakagi-bukmalad be abonolemalagala, anse be gannar dagmar.
\q2 Ar ade, ani an Bab-Dummadid, Bab-Dummad-baid sated.
\q1 
\v 23 An-nuggi an ise-sogar-imaksad,
\q2 an napiragwadba ibmar-sogsad,
\q2 ibmar gusuli-guosulid guedsegad.
\q1 Bela-dulemar an-asabin yokorgi-sindigar sigmaloed,
\q2 bela-dulemar anga ise-sogar imakmaloed.
\b
\q1 
\v 24 ”Wemar angi sogmaloed: ‘Unnila Bab-Jehováʼgi igar-innikigwad danikid,
\q2 degi, gargangued eginbi danibalid.’ ”
\q1 Dulemar isdar Bab-Dummad-daksamaladi, Bab-Dummad-asabin nonimaloed,
\q2 bingedar itomaloed.
\q1 
\v 25 Bela Israel-e-wagan bendaklegoed,
\q2 degi, bela Bab-Jehová-nuggi gannarba gumaloed.
\c 46
\s1 Babilonia-dulemar-e-bab-dummagan
\q1 
\v 1 Babilonia-dulemar e-bab-dummad-Belʼye-nugad dugdir naded,
\q2 bab-dummad-Neboʼye-nugad balimelleded.
\q1 Wemar-e-wilubgan-sobarmalad, ibmar-durgan-nabir-ibmar-semaladgi sesmalad.
\q2 Ar ade, wemar-e-wilubgan yeer-aidikued,
\q1 bela ibmar-durgan-nabir-ibmar-semalad-ebilis nasikdamalad,
\q2 ibmar-durgan nue-yegus itodamalad.
\q1 
\v 2 Bab-dummadyob-imaklemalad dugdir nadmalad,
\q2 napagi babatided,
\q1 gwen dukin na bendaksasurmalad,
\q2 degidba gales selesmalad.
\p 
\v 3 Bab-Dummad weyob soged:
\q1 “Jacob-wagan, be an-itomar,
\q2 bela Israel-dulemar be an-itomar.
\q1 Sapibeneggi be maigu, an nue-be-akwisad,
\q2 an nue-be-nidii gusad.
\q1 
\v 4 Amba bemar seredgusale,
\q2 bato bemar nono-dagudikgusale,
\q1 amba an nue-be-nidii guoed.
\q2 Amba an-sunnagwad an be-sedioed.
\q1 Ani an bemar-obinnisad,
\q2 ani an bemar-bendakdii guoed.
\q1 Ani an be-sedioed.
\q2 Ani an igar-bulegangi be-ollorsaoed.
\b
\q1 
\v 5 ”¿Doa-ebo be an-wilubdakoe?
\q2 ¿Doa-ebo emar-daklege be an-imakoe?
\q1 ¿Doa-yopira an-daklege be an-imakoe?
\q2 Suli. Gege be emaryob be an-imaked.
\q1 
\v 6 Ar dulemar gwenna-gwenna, binsa e-or sagumargi-bukwadi, obelodamalad,
\q2 e-manidi, nibirgi wilubsadamalad.
\q1 Geb dule-ibmar-sobed amidamalad,
\q2 adi, bab-dummadyob-imakleged sobegar.
\q2 A-bab-dummadyob-imakleged-nug-odummogega, e-asabinni yokorgi-sindigar sigdamalad.
\q1 
\v 7 Geb a-sorbali, a-bab-dummadyob-imakleged, gukingi-mai seddamalad.
\q2 Geb e-gwisguedgi ogwisgudapdamalad, bar onirdasurmalad.
\q1 Ar dule amba we-ibmar-sobaledse binnasuli-gornaile, amba e-abinsaosulid.
\q2 Degine, amba dule-bukib-binsadiid egi gwen bendaklegosulid.
\b
\q1 
\v 8 ”Bemar, uyasulidamalad. We-ibmar be ebinsamalo.
\q2 ¡Nue na be binsamalo, nue be itomalo!
\q1 
\v 9 Epenne ibmar-dikasurgus-gusmalad be ebinsamalo.
\q2 Ani an Bab-Dummadid, dule-baid sated,
\q2 Ani an Bab-Dummadid, dule-anyobid sulid.
\q1 
\v 10 Ani an sailanagi yoedse-ibmar-guoed owisoged.
\q2 Ibmar yoedse-guoedi amba dikasuli-gued-idu an soged.
\q1 An soged: An-ibmar-abegedi sogedba guoed,
\q2 an-ibmar-abegedba an imakoed.
\q1 
\v 11 Dule-gwensakse dikasuli dad-nakwedsik an gochad,
\q2 sulubagiyob dikasuli danikoed,
\q1 a-dule, anga an-ibmar-abeged-imakoed.
\q2 An-ibmar-sogsadi, sogedba-guega an imakoed.
\q2 An-igar-amisadi, an imakoed.
\q1 
\v 12 Gwage-dutusurmalad, be an-itomar.
\q2 Igar-napiragwadgi-dikasurgudimalad, be an-itomar.
\q1 
\v 13 An-igar-napiragwadi dikasur maisulid,
\q2 an-abonogedi bato warmaksad.
\q1 Sión-yala-abonoleged an imakoed,
\q2 Israel-dulemarga an-gandikid an ukoed.”
\c 47
\s1 Babilonia-yala berguoed
\p 
\v 1 Bab-Jehová sogbalid:
\q1 “Babilonia-yala yagwa-yoo-sui-nikuedyobi be guedi,
\q2 be aidege, napagi be sige.
\q1 Caldea-dulemar-e-sisgwayobi be guedi,
\q2 napagi be sige, ar be-ologana bergusad.
\q1 Bar bese ome-nued-dakleye gorlegosulid,
\q2 degi, ome-bakagwaledye gorlegosulid.
\q1 
\v 2 Obnaged-akwa be sue,
\q2 ibmar-gwag egi be nage.
\q1 Muswe be unge,
\q2 sabure-bayaa be sae,
\q1 dua swiri be imake,
\q2 diwargi be obake.
\q1 
\v 3 Be-uka-swiligwadi bela daklegoed,
\q2 bela be-abganse-bakale, daklegoed.
\q1 Be dummad-bingeguoed.
\q2 An buged be-imakoed.
\q1 Bela dulemar isgusadbi an dakoed,
\q2 an ega e-isgued gwen eliosulid.”
\b
\q1 
\v 4 Anmar-Bendakedi, Israel-dulemar-e-Bab-Dummad-Isligwaledid.
\q2 Bab-Jehová-Bela-Gangued-Nikadye nugad.
\p 
\v 5 Bab-Dummad weyob soged:
\q1 “Caldea-dulemar-sisgwa bogi be sige.
\q2 Neg-gubyagwaled-yaba be doge.
\q1 Ar dule bar be-biosulid:
\q2 ‘Rey-bundor yar-baid-baid-nanaid semaidye.’
\q1 
\v 6 An-dulamala an-oulus gusad.
\q2 A-ulale, a-dulemar an obachagusad.
\q1 Be-argan-yaurgi an uksagusad.
\q2 Degi-inigwele, gwen be wiledaksasulid.
\q2 Dule-sergangala arbaed-dummad be uksagusad.
\q1 
\v 7 Weyob be sogsa gusad:
\q2 ‘¡Gusgu bela yar-semaigu an guoye!’
\q1 Degi-inigwele, gwen be binsassulid, an berguodeeye,
\q2 gwen weyob-guodeeye be binsassulid.
\b
\q1 
\v 8 ”Emigindi, Rey-bundor-ibmarbina-surbinsa-itoged, be nue-itogo:
\q2 Emide, na be nued-gudii itoged,
\q1 na be dukin-weyob sogdiid:
\q2 ‘Anbi an weyob guye, dule-baid anyobid surye.
\q1 Bipisaale, an gwen machered-sate guosurye,
\q2 an gwen mimmigansuli guosurbarye.’
\q1 
\v 9 Ar ibagwennaa ukiarmakale, ibmar-sogbobela bega guoed:
\q2 Mimmigansuli be gunonikoed,
\q2 degi, machered-sate be gunonikoed.
\q1 Ar be bukidar ina-isgana-imako-inigwele, degi, bela ibmar-burbamar be oyogo-inigwele,
\q2 we-ibmar be-bendakosulid.
\q1 
\v 10 Ar be be-ibmar-isgana-imakedgi be bengussulid.
\q2 Ar be sogsagusad: ‘We-ibmar-isgana-imakedgi dule an-dakdisuli.’
\q1 Be-binsaed-nikadaedi, be-ibmar-wisidaedi, dukin be-yardaksad.
\q2 Ulubgine na be weyob sogsad: ‘Anbi an weyob guye, dule-baid anyobid surye.’
\q1 
\v 11 Begine, boni-dummad nonikoed,
\q2 mer begi-yolegega be imakoenad,
\q2 degi-inigwele, we-boni begi yolegedsegad.
\q1 Begine, boni-dummad-nagunonikoed, gwen be gaosulid.
\q2 Boni-dummad begi danikoye gwen be binsadisulidgi, ukiarmakale begi gwisgunonikoed.
\b
\q1 
\v 12 ”Ibmar-burbamar-wisid-oyogedgi be alamakdii gudo.
\q2 Ina-isgana-imakedgi be alamakdii gudo.
\q1 Ar nuchukwagwad-akale, egi be arbadiid.
\q2 Abakar wis be-ibmar be-bendakalile,
\q2 abakar wis be nabir bonigan-ogwayealile.
\q1 
\v 13 Bukidar-bega-binsaed-uklesadba, be budar-itogusad.
\q2 Emisgi, dule-niisgwaba-bega-ibmar-dakar-sogmalad dagmarsun:
\q1 We-dulemar mogirmargi-ibmar-nanaidba-nergumaladid,
\q2 niisgwa-dakedba-ibmar-sogmaladid, degi, nii-irba iduakwaa-ibmar-guoed-sogmaladid.
\q2 We-dulemar boni-dummagan begi-danikoedgi be-bendakmarsun.
\q1 
\v 14 Be-dake, we-dulemar gagan-durganyob-gumalad,
\q2 bela soo obelogoed.
\q1 Na-dukin soo-gwabunyedgi san-onogosurmalad.
\q2 Ar we-soo, neg-uee-imakedyobsulid, geg be walik siged.
\q2 Geg be we-soo-asabin siged.
\q1 
\v 15 Weyob dulemar-bebo-alamakdigusad gumaloed.
\q2 Ar be nuchukwagwad-akale, bebo-ina-isganagi-arbasmalad weyob gumaloed.
\q1 Na wala-walagwen e-itolegedba nademaloed,
\q2 ar dule-wargwensaale be-bendakosulid.”
\c 48
\s1 Israel-dulemar-uayasulidaed
\q1 
\v 1 Jacob-wagan, we-igar-an-bega-sogoedi, nue be itomalo.
\q2 Judá-wagan Israel-dulemarye-biledimalad, nue an-itomalo.
\q1 Bemar Bab-Jehová-nuggi be ise-sogar-ibmar-sogdimaladi, Israel-e-Bab-Dummadse be gordimaladi, napiragwadgi be imakdisurmalad.
\q2 Igar-innikigwadgi be imakdisurmalad.
\q1 
\v 2 Bemar neggwebur-islidikidginmaladye na be sogdimalad,
\q2 degine, Israel-e-Bab-Dummadgi-bensurmalad,
\q1 Bab-Dummad-Bela-Gangued-Nikadye-nugadgi be bensurmalad,
\q2 nue be itomalo.
\p 
\v 3 Bab-Dummad weyob soged:
\q1 “Ibmar-gusmaladi, bato an dikasurgus egi an sunmaksad.
\q2 Yoo-ibmar-guoed-iduale, bato an egi iduakwaa sunmaksad.
\q1 An-sunnagwad dulemarga an oyosad.
\q2 Ukiarmakale, an imaksad.
\q2 Bela deyob gunonikid.
\q1 
\v 4 Ar ade, bato an wisid, bede nue gwage-dutusulid,
\q2 be-dukar-war esgoro-gannaregedyobid,
\q2 be-bebe-gar esgoro-gordikidyobid.
\q1 
\v 5 A-ulale, an bega dikasurgus we-ibmar sogsad.
\q2 Iduakwaa we-ibmar-guoed an bega oyosad,
\q1 adi, melle be sogegar: ‘An-ibmar-bab-dummadyob-sobaled, we-ibmar imaksaye.
\q2 An-ibmar-wilub-sobaled, degi, an-suar-sobaled we-ibmar-guoed sogsaye.’
\q1 
\v 6 Bela we-ibmarmar-gusad be itosad, bela be daksad.
\q2 Degite, ¿bemar we-ibmarmar-gusad sogosursi?
\b
\q1 ”Emisgi, an ibmar-binigan bemarga an sogoed.
\q2 Be-idu ibmar-dukuar-mamaidi, akudaklemaladi, an bemarga sogoed.
\q1 
\v 7 We-ibmarmar emiskwaa imaklesmaladid,
\q2 dikasurgus imaklesurmaladid.
\q1 Emi-ibagine, amba egi-sunmakleged be itodisulid,
\q2 adi, melle be sogegar: ‘Eye, dika bato an wisbinye.’
\q1 
\v 8 Bipisaale, gwen we-ibmar be itodisulid,
\q2 gwen be wissurbalid.
\q1 We-ibmar gwen be iduar itodisulid,
\q2 gwen bega iduar be-uaya, magasar-itogega argassulid.
\q1 Ar an nue be-wisid, be emar-yardakmaladid,
\q2 be gwalulesad-akale, uayasulidaedye be-bimalad.
\b
\q1 
\v 9 ”An, an-nug-sabed-ulale, an-urwed an bargaed.
\q2 An-nug-odummoleged-ulale, an na san-bargaed,
\q2 adi, melle be-obelogegar.
\q1 
\v 10 ¡Be dakena! An swilidik be-imaksad.
\q2 Degi-inigwele, mani-swilidik-imaklegedyob an be-imaksasulid,
\q2 sabsur-wile-itolegedgi an be-wilubdaksad.
\q1 
\v 11 An we-ibmar-imaksadi, an-ulale an imaksad,
\q2 an na dukin-sabed-ulale, an deyob imaksad.
\q1 ¿Sunna an-nug obanagwar-imakmalaga an imakosi? Suli.
\q2 An-nug-odummolegedi, dule-baidgadga an ukosulid.”
\s1 Israel-dulemar-ollorgunonikid
\p 
\v 12 Bab-Jehová weyob sogbalid:
\q1 “Jacob-wagan, be an-itoge,
\q2 Israel-wagan, ani an bese gochad.
\q1 Ani an Bab-Dummadid.
\q2 Ani an gebesailaginedid, anse bergunaibalid.
\q1 
\v 13 An-argangine, napneg an nasiksad,
\q2 an-argan-nuedsiki, mogir-billi an egasad.
\q2 Ani an e-nugba ese gochagu, bela nagunonikid.
\b
\q1 
\v 14 ”Bela bemar ambikumar, be an-itomar:
\q2 ¿Doa we-ibmar-guoed iduakwaa sogsa?
\q1 Ani Bab-Jehová, an dule-gwensak-susad Babilonia-yalagi an-ibmar-imakbied imakoed,
\q2 Caldea-dulemargi gwichiguoed.
\q1 
\v 15 Ani an we-ibmarmar sogsad.
\q2 Unnila ani an we-dulese gochad.
\q1 Dagega, an imakoed,
\q2 e-ibmar-imakoedgi emargi obinoed.
\b
\q1 
\v 16 ”Anse be walikgudamar,
\q2 an ibmar-sogoedi, nue itomalo:
\q1 Gebesailaunni an gwen dukuar sunmaksasulid,
\q2 ibmarmar gualile, bato an gunaidaed.”
\p Emide, Bab-Jehová-Bela-Gangued-Nikad, E-Burba-gandikidba an-barmialid.
\v 17 Weyobi Bab-Jehová be-Bendakedi, degi, Israel-dulemar-e-Bab-Dummad-Isligwaled, soged:
\q1 “Ani an Bab-Jehová gued,
\q2 bemar-Bab-Dummadid.
\q1 Ibmar-nueganba be-odurdakedid,
\q2 ibu-igarba be nanaoe, a-igarba be-iduedid.
\q1 
\v 18 An-igarmar-mamaidba be uaya-nika gudigusana,
\q2 diwar-aryomadaedyobi ulubgi bogidikid be nikuoenad,
\q2 demar-mullumakmadaedyobi be baisur-itodii guoenad.
\q1 
\v 19 Be-wagan ukub-naidyob-mergu guoenad,
\q2 be-mimmigan ukub-merguedyob-mergu guoenad.
\q1 E-nuga gwen-alliosulinad,
\q2 an-asabinni, gwen weyob guosulinad.”
\b
\q1 
\v 20 ¡Babilonia-yalagi be ainimar!
\q2 ¡Caldea-dulemargi be wakinmar!
\q1 Bemar Babilonia-yalagi-noedgi binnasuli weligwaledba be we-igargi sunmakmalo.
\q2 We-ibmar dulemar-wisguega be imakmalo,
\q2 bela yala-naid-ugakaase gayaburba be mimimalo.
\q1 Weyob be sogmalo:
\q2 “Bab-Jehová, e-mai-Jacob-wagan bendaksaye.”
\q1 
\v 21 Nega-dulesulidganba-seargua, gwen ukud mechasurmalad.
\q2 Bab-Jehová emargala, akwasailagi dii-aryogega imaksad.
\q2 Akwa-marisgusadgi dii-binnasur ega aryogega imaksad.
\p 
\v 22 Bab-Jehová soged:
\q1 “Dule-isganagardi gwage-bogidikid sateye.”
\c 49
\ms1 4. YOEDSE-GANDIKIDBA NEG-OYOLEGOED
\mr (49:1–66:24)
\ms2 4a. Yoedse-dule-abonoged-danikoed
\mr (49:1–59:21)
\s1 Bab-Jehová-e-mai
\q1 
\v 1 Dikasur-demar-gakaba-bukmaladi, be an-itomar.
\q2 Neggwebur-bannaba-bukmaladi, an-ibmar-sogoed itomalo:
\q1 Gwaluleged-iduale, Bab-Jehová bato anse gochad.
\q2 Sapibeneggi-mai, bato an-nug bisad.
\q1 
\v 2 Es-suid-swiswidikidyobi an-gayaburba imaksad.
\q2 E-argan-yaurgine an-odukusad.
\q1 Sigu-daarmakaledyob an-imaksad,
\q2 e-sigumar-saboged-yaba an-odukusad.
\p 
\v 3 Bab-Dummad anga weyob sogsad:
\q1 “Israel-wagan, be an-maiga gued.
\q2 Begine, an-nug odummolegoed.”
\p 
\v 4 Geb an abinsaded:
\q1 “Binsarsunna an arbasad.
\q2 Binsarsunna an gar-itosad,
\q2 gwen ibmar-nued an nikgussulid.
\q1 Degi-inigwele, an-ibmar-imakedi, Bab-Jehováʼgi siid.
\q2 Bab-Dummad anga-ibmar-nuegan-ukoed bato guagwar sisad.”
\p 
\v 5 Emide, Bab-Jehová soged:
\q1 “An e-maiga-guegala,
\q2 sapibeneggi-mai anga burba uksad.
\q1 Adi, Jacob-wagan gannar eba nanaegar,
\q2 Israel-dulemar gannar ese ambikudagegar.
\q1 Ar ande Bab-Jehová-asabin an-nug gannarba gued.
\q2 Agala, an-Bab-Dummad anga niga-ogannoged.”
\p 
\v 6 Bab-Dummad weyob e-maiga soged:
\q1 “Be an-maiga-guedgi, unnila be anga Jacob-waganbi gannarse nudakosulid.
\q2 Unnila be anga Israel-dulemarbi gannar-e-yarse sedagosurbalid.
\q1 Dulemar-yar-baid-baidgi-bukmaladga, neg-meegwadga-guega an be-imakbalid,
\q2 degi, bela napaneg-naid-ugakaasega, an-abonoleged-igar-sedega an be-imakbalid.”
\b
\q1 
\v 7 Bab-Jehová, Israel-dulemar-ollor-imakedi, Bab-Dummad-Isligwaledi, weyob soged,
\q2 dulemar-yar-baid-baidgi-bukmaladse mesagwar-gulediidga, isdar-daklediidga,
\q2 degine, dummagan-negdakmamaid-e-maiganga, weyob soged:
\q1 “Reymar be-dakdamalogu, gwisgudmaloed.
\q2 Dule-dummagan-nuga-nikamalad be-dakdamalogu, be-abin dulluu imakmaloed.
\q1 Israel-dulemar-e-Bab-Jehová-Isligwaled-ular, be-nug odummodmaloed.
\q2 Ar ade, Bab-Dummad, dule-napiragwadid,
\q2 degi, na e be-susadid.”
\s1 Bab-Dummad Israel-dulemar gannarse urbisad
\p 
\v 8 Bab-Jehová weyob soged:
\q1 “Iba-nuegangi an be-itosad,
\q2 degi, abonoleged-ibagangi an be-bendaksad.
\q1 Emigindi, an nue-be-akoed,
\q2 degi, an begine dulemarga igar mesoed,
\q1 adi, be gannarse neggwebur-urbegar,
\q2 degine, nainumar-olloo-nanaid be mimiegar.
\q1 
\v 9 Adi, dule-galesmaladga weyob be sogegarba: ‘Be ainimarye.’
\q2 Degi, dulemar-negsichidgi-bukmaladga weyob be sogegarba: ‘Bemar ollorgusmarye.’
\b
\q1 ”Bemar, igarbali, be-ibdurganga gagan-ara-aramalad amimaloed,
\q2 bela nega-dulesulid-yar-mullugangi gagan-ara-aramalad be amimaloed.
\q1 
\v 10 Bemar ukudmaada itogosurmalad.
\q2 Dad-ibeler-gaedi, degi, neg-ueguedi, budar-itoge be-imakosurmalad.
\q1 Ar dule-wile-be-daked, be-nioed,
\q2 dian-aryomamaidba be-sedoed.
\q1 
\v 11 Bela an-sapurmar-nanaidgi igar-mamai an imakoed,
\q2 an-igarmar an omesoed.
\q1 
\v 12 ¡Be dakmalana!
\q2 Wemarde dikasuli danimaloed.
\q1 Gwen-gwen dad-nakwed-argan-sapiledsik danimaloed,
\q2 baigandi, dad-argwanedsik danimarmogoed,
\q2 degi, baigandina, Sinim-yar-akar danimaloed.”
\b
\q1 
\v 13 Nibneg-naid, be weligwaledba, ¡binnasuli gole!
\q2 Napneg-naid, ¡be wergusun!
\q1 Sapurmar, ¡gandikidba be namakmar!
\q2 Ar Bab-Jehová e-dulemar-gwage armaked,
\q2 e-dulemar-wilesagwa-gudimalad wiledaked.
\p 
\v 14 Degi-inigwele, Sión-yalagi-bukmalad weyob sogsad:
\q1 “Bab-Jehová walagwen an-meted,
\q2 Bab-Jehová an-iesad.”
\p 
\v 15 Bab-Jehová sogdebalid:
\q1 “¿Ar sunna nan-gwensakde e-mimmi-iesi?
\q2 ¿Ar sunna e-mimmi-baksad sabgusuli gusi?
\q1 Ar we-nande, e-mimmi-nue-ieye-sogele,
\q2 andi an gwen be-iegosulid.
\q1 
\v 16 An-argangi-sobar-naiyobi an be-sediid.
\q2 Be-galu-matusurmaladi, an iedisulid.
\q1 
\v 17 Bega-neg-sobmaladi, begi gwae-gwae danimalad.
\q2 Be-obelomaladdi, begi bangudmalad,
\q2 bei neg-ollomaksamalad begi bangudmalad.
\q1 
\v 18 Nue be-atake, be-dikarba nue be neg-dake.
\q2 Bela bulakwaa ambikunonimalad, bese danimalad.”
\p Bab-Jehová soged:
\q1 “An dula-maisoggu, bela wemar, ibmar-nuegan-ebulegedyobi gumaloed,
\q2 abirgin-nikued-mor-yolegedyobi gumaloed.
\b
\q1 
\v 19 ”Be-yala obelosmar-inigwele,
\q2 akwamarbi ganna-ganna obesmar-inigwele,
\q1 degi, olloo nasiksamar-inigwele, be-yala be-dulemarga unniguosulid.
\q2 Dule-be-wiosmaladdi, dikasuli bemargi bukwa gumaloed.
\q1 
\v 20 Be-mimmigan-bei-yoggusye-na-be-bisadi, bega sogdamaloed:
\q2 ‘Dogdar we-yala anga bipii noye.
\q1 Anga be neg-amiye,
\q2 agi nabir an gudisaegarye.’
\q1 
\v 21 Geb degi, be binsadoed:
\q2 ‘¿Doa we-mimmigande anga baksasunna?
\q1 An mimmi satenad,
\q2 ar an geg mimmi bakenad.
\q1 An ononnoles gudiinad,
\q2 emarse-obanagwar an gudiinad.
\q1 Ar we-mimmigande, ¿doa anga odummossunna?
\q2 Ar an walagwen gudiinad,
\q2 emide, ¿ar bia wemarde danimarsunna?’ ”
\p 
\v 22 Bab-Jehová-Bur-Biriginedi weyob soged:
\q1 “Dulemar-yar-baid-baidgi-bukmaladga an igar ukoed,
\q2 neggwebur-bukmaladsik an-bander an onakoed,
\q1 adi, wemar, e-sakwagi-mai bega be-mimmigan-sedamalagar,
\q2 degi, e-gukingi-mai bega be-bunamala-sedamarbaligar.
\q1 
\v 23 Reymar e-mimmiganga be-imakmaloed,
\q2 degi, rey-omegan be-nanga gumaloed.
\q1 Be-asabinni, dulluu napase imakmaloed.
\q2 Degi, maligi ukub-naile, bega elimaloed.
\q1 Geb agi, be wisgumaloed, ani an Bab-Jehová gued.
\q2 Dule-angi-bensurmaladi, bingedar itogosurmalad.”
\b
\q1 
\v 24 Dule-bila-onomalad bila-onogedgi-ibmar-susadi, ¿sunna e-ibe be susi? Geg gue.
\q2 Dule-galesadi, ¿sunna dule-isgana-e-gasadgi wakinnosi? Suli.
\p 
\v 25 Degi-inigwele, Bab-Jehová weyob soged:
\q1 “Dule-bila-onoged bila-onogedgi-ibmar-susadi, e-ibe sulegoed.
\q2 Deginbali, dule-isgana dule-gasa-sesadi, gannar e-annik sulegoed.
\q1 Ar andi, dule-begi-urwedimaladgi an be-bendakoed.
\q2 An-sunnagwadi, an be-mimmigan bendakoed.
\q1 
\v 26 Be-isdarmalad na dukin e-san-gunmalaga an imakoed.
\q2 Vino-gobeyobi, na dukin e-ablisgi-mumgumalaga an imakbaloed.
\q1 Degisoggu, bela dulemar wisgumaloed, ani an Bab-Jehová gued.
\q2 Ani an be-Abonogedid.
\q1 Ani an Jacob-waganga dule-gandikid gued.
\q2 Ani an be-bendakedid.”
\c 50
\s1 Bab-Jehová dulemar-egi-bensulid bendaked
\p 
\v 1 Bab-Jehová weyob soged:
\q1 “Israel-dulemar, ¿an bemar-nan obachasi?
\q2 Degite, ¿bia abirgin-meted-gardade nadsunna? Anga be oyodo.
\q1 ¿An doa-dulemarga bemar-egi-mani-ganikidyobi an be-uksamarsunna?
\q2 An deyob be-uksasurmalad.
\q1 Ar be-isgued-ular, na be dukin uksamalad.
\q2 Bemar uaya-sate-gusad-ulale, be-nan oballedsunnad.
\q1 
\v 2 An nonigua, ¿ibiga dule-sate an daknonisunna?
\q2 An gotegua, ¿ibiga dule gwen an-abin-imaksasursunna?
\q1 ¿Ar bemar-bendakosurye, be angi binsamala?
\q2 ¿An bemar-onogega, garganguedsuli be an-dakmala?
\q1 Ar an sunna, demar, ilagwensaale dinna saed.
\q2 Ar an sunna, diwarmar, nega-dulesulidga-nai imaked.
\q1 Uamar e-mas-satedba burgwideled.
\q2 Dii-dingudedba uamar bela nungudeled.
\q1 
\v 3 An sunna mogir-billi nega-gubyagwaledbi-nai an imaked,
\q2 mor-sichid-naidyobi an imaked.”
\b
\q1 
\v 4 Bab-Jehová binsaed-ibegan-sunmaked-gwabinduku anga uksad,
\q2 adi, dulemar-geggus-gudimalad-e-gwage gadi-gadi-imakegar.
\q1 Bab-Dummad bane-bane wakudaryalabali an-odaked,
\q2 ibmar-itogega an-imaked,
\q2 adi, dule-ibmar-durdaknaidyobi an ibmar durdakegar.
\q1 
\v 5 Bab-Jehová ibmar-magar-itogega an-imaksad,
\q2 an eba uayasuli gussulid,
\q2 an eba ibsassuli gwen gussulid.
\q1 
\v 6 Dulemar-an-bibyonanaidga an-yargan an oyosad.
\q2 Dulemar-an-siga-sabsur-ungemaladgi, an-aku an gwen odukussulid.
\q2 Degine, dule-angi-dodomaladgi, degi, angi-wiakmaladgi, an-wagar an gwen odukussulid.
\q1 
\v 7 Ar Bab-Jehová-Bur-Birigined an-bendaked,
\q2 degisoggu, mesagwar-imaklenaidgi an bai itossulid.
\q1 A-ulale, akwasailayob an na gandik imaksad.
\q2 Ar an wisid, an bingeguosulid.
\q1 
\v 8 Dule-an-irwa-gwisguedi, an-nagaba gudiid.
\q2 ¿Degisoggu, doa anbo gala-itobie?
\q1 Dule anbo-gala-itobiele, ¡anse dagdo!
\q2 Dule angi gwisgubiele, ¡anga ibmar sogdado!
\q1 
\v 9 ¡Ar Bab-Jehová-Bur-Birigined an-bendakdaed!
\q2 ¿Doa sabsur-odurdakleged-igar anga mesosunna?
\q1 Ar an-isdarmaladdi, ilagwen-berguar gudoed,
\q2 igi mor suuse-gulledae, deyobi namaloed.
\b
\q1 
\v 10 ¿Doa bemar-abargi Bab-Jehová-dobee gudii?
\q2 ¿Doa Bab-e-mai-sogedba nanadii? Dule sated.
\q1 Dule-negasichidba-nanadiidi, neg-meegwadba-nanadisulidi, a-dule, Bab-Jehováʼgi bensuli guoed,
\q2 e-Bab-Dummadgi alakwaa naguoed.
\q1 
\v 11 Ar bemar na soo ogadamalad,
\q2 na be gwinnur ogadamarbalid.
\q1 Bemar na be soo-ogadamaladgi be nanabukmalad,
\q2 na be gwinnur-ogadamaladgi be nanabukmalad.
\q1 Degi-inigwele, an we-ibmarmargi sabsur-bemar-odurdakoed:
\q2 Igar-bulegangi be sabsur-odurdaklemaloed.
\c 51
\s1 Sión-yala-abonolegoed
\p 
\v 1 Bab-Dummad weyob soged:
\q1 “Bemar, igar-innikigwadba-nanadimalad, be an-amidimalad, be an-itomar:
\q2 Bemar, dad-Abraham-wagan gumalad.
\q1 
\v 2 Be nue-dakmar,
\q2 ar dad-Abraham bemar dad-dummadid,
\q2 degi, muu-Sara bemar-urbisadid.
\q1 An Abrahamʼse gochagua, na sana-walagwen gudiinad.
\q2 Degi-inigwele, an egi nued binsasad,
\q2 an ega dula omelosad.
\q1 
\v 3 Ani Bab-Jehová, Sión-yala wiledakedsegad.
\q2 Bela e-neg-bibichismaladi, wiledakoed.
\q1 E-nega-dulesulidgan Edénʼgi-nainu-nued-naigusayobi, imakoed.
\q2 E-nainu-geg-ibmar-egi-sanmakedi, an-nainuga guoed.
\q1 A-nainugine weligwar-itomaloed, egi wergumaloed.
\q2 Anga namaklegedgi namakmaloed,
\q2 dog-nuedye anga sogmaloed.
\b
\q1 
\v 4 ”An-dulamar, nue be an-itomar.
\q2 An-neggweburmar, nue be an-itomar:
\q1 Ar ani an ibmargi-odurdakleged-igar onioed,
\q2 an-igar-napiragwadi, dulemar-yar-baid-baidgi-bukmaladga neg-meegwadga guoed.
\q1 
\v 5 An-igar-naboged, bato walik-gusad.
\q2 An-abonoleged-igar bato igarba abarmakdanikid.
\q1 An-ganguedi, dule-yar-baid-baidgi-bukmaladga igar nabogoed.
\q2 Dule-demar-gakaba-bukmaladi, angi bensurmalad,
\q2 an-ganguedgi, bendakleged abdakmalad.
\q1 
\v 6 Niba be atakmar,
\q2 napneggi be atakmarbar.
\q1 Waa-berguddaedyobi, mogir-billi bergudoed,
\q2 mor-nunguddaedyobi napneg nungudoed.
\q1 Gukur-burgweyobi, e-dulemar burgwidoed.
\q2 Degi-inigwele, an-abonogeddi, degisadegu maiguoed.
\q2 Degi, an-igar-napiragwaddi, noargumai gwen guosulid.
\b
\q1 
\v 7 ”Bemar, igar-napiragwad-wismalad, be an-itomar.
\q2 Gwagegi-an-igar-sedidimalad, be an-itomar.
\q1 Dulemar-begi-ichakwa-sunmakedi, melle be dobgumalo,
\q2 sabsur-e-ibmar-sogedgi, melle be niga argwanmalo.
\q1 
\v 8 Ar we-dulemar unnila mor suuse-gulledaedyob gumaloed,
\q2 mor-wawaad nusmarse-gulledaedyob gumaloed.
\q1 Ar an-igar-napiragwaddi, degisadegu maiguoed,
\q2 an-abonoged-igardi, maigu guoed.”
\b
\q1 
\v 9 Bab-Jehová, ¡be atake! ¡Be atake!
\q2 ¡Gandikid-mola be yoe!
\q1 Epenne be-gangued be-dulamarga-be-oyosayob be oyoge.
\q2 ¿Ar bee be, Rahab-obelossursi?
\q2 ¿Ar bee be, ibdula-demargined obelossursi?
\q1 
\v 10 ¿Ar bee be, demar-odinnosgussursi?
\q2 ¿Ar bee be, a-dii-wilasailad odinnossursi?
\q2 ¿Ar bee be, dule-bendaklesmalad-obakega demar-wilasailadgi igar-omesisgussursi?
\q1 
\v 11 Bab-Jehováʼgi-bendaklesmalad gannar nonimaloed,
\q2 weligwaledgi namakagwale Sión-yalase dognonimaloed.
\q1 Weligwar-itodiidi, magasar na e-wagargi oyomaloed.
\q2 Wergudii gumaloed,
\q1 na yeer itomaloed.
\q2 Bukib-binsadiidi, gwage-nunmak-itodiidi, bela bergudoed.
\p 
\v 12 Bab-Jehová weyob soged:
\q1 “Ani an bemar-gwage baisur-itoge imakedid.
\q2 ¿Ar ibiga be dulemar-dobe?
\q2 Ar wemardi, unnila gagan-durganyob gumalad.
\q1 
\v 13 ¿Bab-Jehová-be-obinnisad be iesde?
\q2 ¿Bab-Jehová-mogir-billi-nasiksad bato be iesde?
\q1 ¿Bab-Dummad-napneg-nasiksad bato be iesde?
\q2 ¿Bane-bane be-isdarad-be-obelobi-gudiidgi be gwayedii guode? ¡Adi surbali!
\q2 ¿Sabsur-dule-odurdakdiid-e-urwedde, bia nadsunna?
\q1 
\v 14 Dulemar-esgaryagi-gales-bukmaladi, emiskwaa onolemaloed.
\q2 Esgaryagi burgosurmalad, gwen ega mas galakuosurmalad.
\q1 
\v 15 Ani an be-Bab-Dummad-Jehová gued.
\q2 Ani an demar-osukamakedid,
\q1 ani an demar-uurmakega imakedid.
\q2 Bab-Jehová-Bela-Gangued-Nikadye an nugad.
\q1 
\v 16 Be-gwabindukugine, an-gayaburba an nasiksad.
\q2 An-ganguedbali an be-anar gwisgusad.
\q1 Ani an mogir-billi nasiksad,
\q2 ani an napneg nasiksad.
\q1 Degine, Sión-yalagi-bukmaladga an weyob sogsad:
\q2 ‘Be an-dulamar guye.’ ”
\s1 Bab-Dummad-e-urwed
\q1 
\v 17 ¡Jerusalén-dulemar! Be gwisgumar, be gwisgumar.
\q2 Bab-Dummad-e-urwed be itosad.
\q1 Be bela-belad ulubse surbinsa-itoge be gusad,
\q2 geg bar be gwisgu gusad.
\q1 
\v 18 Bela be mimmigan-nikusadi, gwen wargwensaale, be-idugega gussulid.
\q2 Bela be mimmigan-odummosadi, bipisaale, gwen argangi be-gassulid.
\q1 
\v 19 We-bonigan-sogbogwad begi nonigusad:
\q2 Be-neggwebur bibichisgusad,
\q2 degi, be-neggwebur obelolesgusad.
\q1 Ukudba be gala-itosgusad,
\q2 es-suidgi oburgwilesgusad.
\q1 ¿Doa wile be-dakoe?
\q2 ¿Doa be-gwage baisur-itoge imakoe?
\q1 
\v 20 Be-mimmigan galakusmalad.
\q2 Goe-sapur-bebe-suid sakigi-galesnaidaeyob gusmalad,
\q2 galimba-dikarba mellemamaid.
\q1 Egine, bela Bab-Jehová-e-urwedi gwichigusad,
\q2 bela be-Bab-Dummad-urwedi egi gwichigusad.
\b
\q1 
\v 21 Emisgindi, dule-bukib-binsadiid, vino-gobedginsuli be mummu-gudiid.
\q2 An-bega-ibmar-sogoed be ito.
\q1 
\v 22 Be-Bab-Dummad-Jehová-Bur-Birigined, e-dulemar-ular-sunmakedi, weyobi soged:
\q2 “An-urwedgi an sabsur-bemar-odurdaksad an obelosad.
\q2 We-an-urwedi bipisaale bar be itogosulid.
\q1 
\v 23 Dulemar-sabsur-be-odurdakdimalad an odurdakoed.
\q2 Ar we-dulemar bega weyob sogsa gusmalad:
\q1 ‘Napagi balimellemai be imakmarye,
\q2 adi, anmar begi annamalagarye.’
\q1 Ar deyob be imaksa gusmalad,
\q2 ega napagi mellemai be gusmalad,
\q2 bela dulemar be-birgi annas gusmalad.”
\c 52
\s1 Bab-Dummad Sión-dulemar-ollor-imaksad
\q1 
\v 1 Sión-dorgan, ¡be atake! ¡Be atake!
\q2 ¡Gandikid-mola be yoe!
\q1 Neggwebur-islidikid-Jerusalén, be-mor-gargerbamalad be yoe.
\q2 Ar dule-abgan-uka-duku-sikarsurmaladi, degi, dule-Bab-Dummad-wissurmaladi, bar bemarse dogosurmalad.
\q1 
\v 2 ¡Jerusalén-neggwebur, be gwichigue!
\q2 ¡Olli be obate!
\q1 ¡Gannar ologanagi be sige!
\q2 Sión-yala-sisgwa, be galesgua, dukargi-esgoro-dub-nasiklesad be unge.
\p 
\v 3 Ar Bab-Jehová weyob soged:
\q1 “Bemar manigi be uklessulid,
\q2 bemar manigi be onolegosurbalid.
\q2 Bemar binsa-onolegoed.”
\p 
\v 4 Ar Bab-Dummad-Bur-Birigined-Jehová weyob soged:
\q1 “Epenne an-dulamar, Egipto-yalase nadegusad.
\q2 Agine, na megisgusmalad.
\q2 Emide, Asiria-sordamar binsarsunna an-dulemar-mesagwar imakalid.”
\p 
\v 5 Emide, Bab-Jehová soged:
\q1 “¿Ibi an wegi imakdii?
\q2 Ar binsarsunna, an-ibe an-dulamar-gasa sesmalad.
\q1 E-negsemamaid an-dulamargi dodomalad.
\q2 Bane-bane an-nuggi dododigudamalad, bogigudisurmalad.
\q1 
\v 6 Degisoggu, a-ulale, a-ibagangine, an-dulamar an-nug wisgunonikoed.
\q2 A-ibagangine, ani an ega sunmaknaidi, an e-walik gwisgunonikoed.”
\b
\q1 
\v 7 Dule yar-imbaba-gayaburba-nued-sedanikidi, dule-gayaburba-bogidikid-berbegedi, ibiyobi yeer daklemala.
\q2 Dule gayaburba-nuegan-barsogedi, degine, dule abonoleged-igargi-sunmakedi, ibiyobi yeer daklemala.
\q1 Dule, Sión-dulemarga weyob-sogedi: “Be-Bab-Dummad negdakmaiye.”
\q2 Dule-deyob-sunmakmaladi, ibiyobi yeer daklemala.
\b
\q1 
\v 8 ¡Be itoge! Be-dule-nakulemalad binnasuli-gorbukmalad,
\q2 weligwaledbali gandikidba gorbukmalad.
\q1 Ar ade, na e-ibyagwale dakbukmalad,
\q2 Bab-Jehová gannar Sión-yalase daniki.
\q1 
\v 9 Jerusalén-dulemar, na be bular-weligwar-namaklegedgi be namakmar.
\q2 Ar ade, Bab-Jehová e-dulemar-baisur-itogega imaksad,
\q2 degi, Jerusalén-neggwebur bendaksad.
\q1 
\v 10 Bab-Jehová, bela dulemar-yar-baid-baidgi-bukmaladga e-gangued oyogoed.
\q2 Bela napneg-naid-ugakaase-bukmaladi, anmar-Bab-Dummad-e-abonoged dakmaloed.
\b
\q1 
\v 11 Bemar, Babse-goled-neggi-ibmar-ebulemalad-semaladi, be nomar,
\q2 be agi ainimar.
\q1 ¡E-dulemar-abargi-gudiidgi be nomar!
\q2 ¡Be san-urukmar!
\q2 ¡Melle ibmar-swilidiksulid be ebumalo!
\q1 
\v 12 Degi-inigwele, mer be gwae-gwae itomalo.
\q2 Mer be gwae-gwae-abarmakdemarbalo.
\q1 Ar Bab-Jehová bemar-idumai guoed.
\q2 Israel-e-Bab-Dummad be-sorba-nai guoed.
\s1 Bab-Jehová-e-mai-wilegoed
\p 
\v 13 Bab-Jehová soged:
\q1 “An-mai emargi nakoed.
\q2 E-nug odummolegoed, dule-dummadga guoed,
\q2 degi, ologanagi sigoed.
\q1 
\v 14 Dulemar dakdamalogu, bukidar geger-dakmaloed,
\q2 ar e-wagar-daklegedi bar aa daklegosulid,
\q2 ar e-daklegedi, bar dule-daklegosulid.
\q1 
\v 15 Amba deyob dulemar-yar-baid-baidgi-bukmaladi, geger dakmarmogoed.
\q2 E-asabinni, reymar gwen-sunmakosurmalad,
\q1 ar weyob-ega-ibmar-soglessulid dakdamaloed,
\q2 degi, weyob-ibmar-itossurmalad na magar itononimaloed.”
\c 53
\q1 
\v 1 ¿Doa anmar-ibmar-sogsad bengussuli?
\q2 ¿Doase Bab-Jehová na e-gangued oyosa?
\q1 
\v 2 Bab-Jehová, e-mai sapi-e-nii-dutugwad-dungueyobi odummosad.
\q2 Sapi-e-mali napa-isganagi dogdedaeyobi, e-mai-odummosad.
\q1 E-mai yeer daklesulid,
\q2 gandik daklesurbalid.
\q1 E-daklegedi, wilubba dakleged.
\q2 Dulemar baisur-dakmalad.
\q1 
\v 3 Dulemarse obanagwale gusad.
\q2 Mesagwale gusad.
\q1 Gwage-nunmaked-itodii gusad.
\q2 Undar-odurdakledii gusad.
\q1 Dulemar gwen-dakbisuli gusmalad.
\q2 Dulemarse obanagwale gusad.
\q2 Gwen anmar bai daksasurmalad.
\b
\q1 
\v 4 Degi-inigwele, anmarga anmar-bonigan sesad,
\q2 anmar-anar, anmar-nunmaked itosad.
\q1 Anmardi egi binsaed,
\q2 Bab-Dummad we-dule-naibi-imaksaye,
\q1 sabsur-imaksaye,
\q2 degi, mesagwar-imaksaye.
\q1 
\v 5 E na, anmar-uaya-sated-ular, naibigusad.
\q2 E na, anmar-isgued-ular, bela-bela sabsur-bibyolesgusad.
\q1 Anmarga gwage-bogidikid-ukegala, anmar-ular, bela-bela sabsur-odurdaklesad.
\q2 Anmar e-naibigusadgi nugunonimalad.
\q1 
\v 6 Anmar bela sibad-wawaad-yoggusgudidaedyobi, yoggus gudimalanad.
\q2 Na wala-walagwen e-itolegedba gudidimalanad.
\q2 Degi-inigwele, Bab-Jehová bela e-maigi anmar-isgued nasiksad.
\q1 
\v 7 Sabsur-imaklenaigu, mesagwar-imaklenaigu, gwen e-gaya itolessulid.
\q2 Igi-sibad-wawaad-senigwad e-oburgwilegedse selesdae, deyobi, gaya-itosuldgi selemai gusad.
\q1 Igi-sibad-wawaad ega-e-absar-siked-abin, gordasuli, deyobi, dulemar-asabin Bab-Jehová-e-mai gaya nikussulid,
\q2 degi, dulemar-asabin gwen gochasurbalid.
\q1 
\v 8 Gasmargua, ega igar-amismargua, oburgwismalad.
\q2 Gwen bai daksasurmalad,
\q1 e-bina sogsasurmalad.
\q2 E-wagan-danikoedgi gwen binsassurmalad.
\q1 Dulemar-bukwad-abargi gandikidgi onolesad,
\q2 an-dulamar-isgued-anar, oburgwilesad.
\q1 
\v 9 Gwen e-sunmakedgi emar-yardaksasur-inigwele,
\q2 gwen ibmar-isgana-imaksasur-inigwele,
\q1 dule-ibmar-isgana-imakmalad-abargi burgwisad,
\q2 degi-inigwele, mani-ibgan-abargi diglesad.
\q1 
\v 10 Ar Bab-Jehová, mesagwar-guega imaksad,
\q2 sabsur-wilegega imaksad.
\q1 E na dulemar-isgued-anar san-uksasoggu, a-ulale, na suitiba gudii guoed,
\q2 bela e-waganmar-dakoed,
\q2 Bab-Jehová-sogedba bela ibmar imakoed.
\q1 
\v 11 Sabsur-wilegoed-sorbali, magar-daknonikoed,
\q2 e-sabsur-wilesadi, binsa wilessuli, degidbali na yeer-itononikoed.
\p Bab-Jehová soged:
\q1 “An-mai-innikigwadi, e-ibmar-wisidbali, dulemarga igarmar nabogoed.
\q2 E na dule-ibmar-isgana-imaked sedoed.
\q1 
\v 12 A-ulale, dule-dummagan-abargi an osimogoed,
\q2 e-ibmar-suoedi dule-gandikmaladbo mimioed.
\q1 Ar ade, na burgwegala, e-san uksad.
\q2 Dulemar-isgumaladyob imaklesmogad.
\q1 Dule-bukidarad-e-isgumalad na sesad,
\q2 dule-isgumalad-irwa gwisgusad.”
\c 54
\s1 Bab-Jehová Israel-dulemar-sabgumaiguad
\p 
\v 1 Bab-Jehová sogded:
\q1 “Be, omegwa-geg-baked, gwen be mimmi-nikudisulid, weligwaledba be binnasuli-gole.
\q2 Be, gwen-muu-neggi-boniba-galitodisulid, binnasuli be namake.
\q1 ¡Weligwaledba be binnasuli-gole!
\q2 Ar ani Bab-Jehová soged: Ome-wilesagudiid, bur bule ome-sui-nikadba mimmigan nikuoye.
\b
\q1 
\v 2 ”Be-dordoneg-siidi, be odummo,
\q2 be-dordoneg-siidgi atued-dummagan-nanaid be egae.
\q1 ¡Melle dobe-dobe be imako!
\q2 Dordoneg-e-dubamar be osugue,
\q2 e-dordoneg-bargamalad be ogannoge.
\q1 
\v 3 Ar be-argan-nuedsiki, degi, be-argan-sapiledsiki be nasgudoed.
\q2 Be-wagana yar-baigan suoed,
\q2 be-wagana neggweburmar-olloganagi ambikudoed.
\b
\q1 
\v 4 ”Melle be dobe-itogo,
\q2 ar be bingeguosulid.
\q1 Melle be gwayo,
\q2 ar be-nug mesagwar guosulid.
\q1 Be yagwaunni bingegusadi be iegoed.
\q2 Bei-machered-burgwisgu, bingedar be itosadgi bar be binsaosulid.”
\b
\q1 
\v 5 Ar Bab-be-obinnisadi, be-suiga gued.
\q2 A nugad: “Bab-Jehová-Bela-Gangued-Nikadye.”
\q1 Be-bendakedi, Israel-dulamar-e-Bab-Dummad-Isligwaledid.
\q2 A bilegoed: “Bela-napneg-naid-e-Bab-Dummadye.”
\q1 
\v 6 Be ome-wilesakwagudiidyob Bab-Jehová bese gornonikoed.
\q2 Ome-suli-suli-itodiidyob Bab-Jehová bese gornonikoed.
\q1 Igi ome dogdar yagwa-guedgi machered-nikusale, machered gannar metedae,
\q2 deyob gudiidgi Bab-Dummad bese gornonikoed.
\p 
\v 7 Bab-Jehová-be-ollor-imakedi soged:
\q1 “Unnila sikwas an be-obachad.
\q2 Degi-inigwele, na bela-belad ulubgi wile-be-dakedgi gannar an be-abingaoed.
\q1 
\v 8 Unnila sikwas-sae-itogedgine, an be-idu bangusad.
\q2 Degi-inigwele, sabgued-degisadeguad-nikadgine, an wile be-dakoed.”
\p 
\v 9 Bab-Dummad sogdebalid:
\q1 “Angardi Noé-ibaganyobi gued,
\q2 igi an Noéʼga ise-sogar sogsa gusa, muu-dummad bar napneggi murosurye.
\q1 Deyobi, an bega ise-sogar soged, bar an bebo urwosulid,
\q2 bar an iisedi bega ibmar sogosulid.”
\p 
\v 10 Bab-Jehová-wile-be-dakedi soged:
\q1 “Amba yalamar-bukwad baidsik ainirye-sogele, degi, yar-mullugana giglimakdele, andi amba an be-sabedi gwen gwagosulid.
\q2 Anbo be igar-bogidikid-omesisadi, andi obelogosulid.”
\p 
\v 11 Bab-Jehová-soged:
\q1 “¡Be dake! Neggwebur-nue-wilesagwa, burwa-dummadba oitolesad.
\q2 Dule a-neggwebur baisur-itogega-imaked sated.
\q1 ¡Akwa-nuegan-yeerdaklemaladgi an be-soboed!
\q2 Akwamar-zafiros-birgi an be-sioed.
\q1 
\v 12 Be-galu-matusulid-birgine, an akwa-rubí-nuegan e-bargaedga mesoed.
\q2 Be-yawagakmar akwa-gargemalad-gaemaladgi an soboed.
\q2 Degi, bela be-galu-matusurmalad, akwa-gargemaladgi an soboed.
\q1 
\v 13 Ani Bab-Jehová, bela be-mimmigan odurdakoed,
\q2 be-mimmigan gwage-bogidikid nika gudii guoed.
\q1 
\v 14 Igar-napiragwadi gannarbaa an be-imakoed.
\q2 Mesagwar-gudii bar be itogosulid.
\q1 Bali dobee be itogosulid.
\q2 Begine, gwayed-dummadi bangudoed, gwen be-walikaa guosulid.
\q1 
\v 15 Dule begi gwichigualile, an eba-nai guosulid,
\q2 dulemar-yogasaar begi gwichiguarmalale, bese galakudmaloed.
\b
\q1 
\v 16 ”Ani an dule-esgoro-sobed-soo-oduurmakedi obinnisad.
\q2 We-dule, na bilagi-ibmar-ebulemalad sobed.
\q1 Ani an dule-emar-obeloged obinnisbalid,
\q2 adi, bela dule-obelogegar.
\q1 
\v 17 Dule begi-nakwega, bila-onogedgi-ibmar-ebuleged-yeer-ganguedi, gwen begi obinosulid.
\q2 Dulemar begi yogasaar-sunmakmaladi, boo-sigega be imakoed.
\q1 We-ibmarmala anga-arbadimaladga an ukoed.
\q2 Angine, igar-innikigwad danikid.”
\p Deyobi, Bab-Jehová soged.
\c 55
\s1 Bab-Dummad wiledaked ukmaid
\p 
\v 1 Bab-Jehová sogbalid:
\q1 “¡Dule-uku-uku-itodimaladi, dii gobdamar!
\q2 Dule-mani-surmaladi, ibmar-sudamar,
\q1 vino be sudamar,
\q2 moli-nunis be sudamar.
\q1 Gwen be bennukosulid,
\q2 binsa bega uklegoed.
\q1 
\v 2 ¿Ar ibiga be binsarsunna mas-nuedsulidgi be mani-oesunna?
\q2 ¿Ar ibiga binsarsunna be ibmar-yeer-ito-be-imaksulidgi mani-misunna?
\q1 Be nue an-itomar,
\q2 bur be mas-nued gunmar,
\q2 ar be mas-nuegan-gullegedgi na be yeer itomaloed.
\q1 
\v 3 Nue be bogi itomar,
\q2 be anse dagmar.
\q1 Be nue an-itomar,
\q2 adi, be dula gudii gumaloed.
\q1 An bemar-ebo degisadegu igar mesoed,
\q2 adi, an-mai-David-sabedba an-ega-ibmar-sogsa-gusadba guegar.
\q1 
\v 4 Dulemargala, we-David, an-barsogega an nug-imaksad,
\q2 degi, dule-yar-bamaladga-e-odurdaked-sailaga-guega an nug-imaksad,
\q2 degine, dummadga an nug-imaksad.
\q1 
\v 5 Israel-dulemar, dulemar-dakdisurmaladbina be goloed,
\q2 degi, dule-aku-be-dakdimarmogadi, bese abarmakdanimaloed.
\q2 Ar ani an be-Bab-Dummad-Jehová Israel-dulemar-e-Bab-Dummad-Isligwaled, be-nug odummosad.”
\b
\q1 
\v 6 Bab-Jehová be amimar,
\q2 ar emisgwa, Bab-Dummad amilegedgined,
\q1 Bab-Dummadse be gormar,
\q2 ar ade, be-walikaa gudiid.
\q1 
\v 7 Dule-ibmar-isgana-imaked, e-igar-isgana-imakedgi bangusun,
\q2 dule-isgana, e-binsaed-isganagi bangusun.
\q1 Bab-Jehová amisun,
\q2 ar ade, Bab-Jehová dule-nuedid, isgued-eliedid.
\q2 Ar anmar-Bab-Dummad wile be-dakoed.
\p 
\v 8 Bab-Jehová soged:
\q1 “An-binsaedi, bemar-binsaedyobsulid,
\q2 an-daedi, bemar-daedyobsulid.
\q1 
\v 9 Igi mogir, napneggi dikasur nai,
\q2 deyobi, an-daedi, bemar-daedba bur-dikasur-akalad.
\q2 Deginbali, deyobi an-binsaedi, bemar-binsaedba bur-dikasur-akarbalid.
\q1 
\v 10 Ar dii-wiedi, degi, dambed-sibudikid-batedi, ibmar-imaksasuli geg gannar ainakwedaed.
\q2 Bina we-ibmar imakgwelergebed:
\q1 Napa-owardikuergebed,
\q2 napagi-ibmar-oniergebed,
\q1 ibmar-gwag-osanmakergebed,
\q2 adi, dule-ibmar-digedga, ibmar-gwag-ukega,
\q2 degine, dulega masgunned ukegarbar,
\q1 
\v 11 deyobi, gayaburba an-gayagi nodele:
\q2 Anse ollobi nonikosulid,
\q1 an-ibmar-abegedba ibmar saoed,
\q2 an-ibmar-sogedba ibmar imakoed.
\q1 
\v 12 Bemar weligwaledba ainidmaloed,
\q2 bogidikidgi gannar be-yalase be momaloed.
\q1 Be-nadapidbali yalamar, degi, yar-mullugan, binnasuli-weligwaledba namakdemaloed.
\q2 Degi, bela sapimar-bukwadi, argan ogotemaloed.
\q1 
\v 13 Gagan-ikobimalad-muchubbi, ciprés-sapimar ainidagoed.
\q2 Dakemar-muchubbi, mirto-sapimar dungudagoed.
\q1 We-ibmarmala, ani an-Bab-Jehová-nug ogannogoed,
\q2 we-ibmarmala, degisadegu e-wilubga naiguoed.”
\c 56
\s1 Dule-baigan-abonoleged-igar
\p 
\v 1 Bab-Jehová weyob soged:
\q1 “Igar-innikigwad be imakmar,
\q2 igar-nued be oyomar.
\q1 Ar an-abonolegedi, warmakdanigusad,
\q2 an-igar-innikigwadi, sanar-guoed.
\q1 
\v 2 Dule, an-igarmarba nanadiile, degi, sogedba eba gudiile,
\q2 we-dule, dule-weligwaledid.
\q1 Dule, obunnoged-ibagi obunnodiile, gwen egi nodisulile,
\q2 degi, dule ibmar-isgana-imakdisulile, we-dule dule-weligwaledid.”
\b
\q1 
\v 3 Dule-ainebalidi e-binsaedba Bab-Jehová-nug-odummodiile, geg weyob binsaed:
\q2 “Bab-Jehová e-dulemar-imbagi an-obanguoye.”
\q1 Dule-alugwasualed geg weyob sogmogad:
\q2 “Sapi-dingus-gwichidyob, an dakleye.”
\p 
\v 4 Ar Bab-Jehová weyob soged:
\q1 “Ar dule-alugwasuarmalad obunnoged-ibagi obunnodimalale,
\q2 an-ibmar-abegedba ibmar-imakdimalale, an-igar-mesisadba nue-nanadimalale,
\q1 
\v 5 an-neggweburgi, anse-goled-negyaba, galugi an ega e-nuga ise-narmakar nasikoed.
\q2 We-ibmala ega mimmigan-nikuedba bur bule guoed,
\q1 degine, an ega nug-degisadeguad ukbaloed,
\q2 bipisaale gwen e-nuga ielegosulid.
\q1 
\v 6 Dule-ainebarmalad anga-arbaega anba-akasmaladi,
\q2 an-nug-ogannogega anba-akasmaladi,
\q1 an-nug-odummogega anba-akasmaladi,
\q2 an-yalase an nidoed.
\q1 Bela obunnoged-ibagi-obunnodimalad gwen angi-nodisurmaladi,
\q2 degi, anbo-igar-mesisad-sogedba-gudimaladi,
\q2 
\v 7 an-yala-islidikidse an nidoed.
\q1 Anse-goled-neggi an weligwar-imakoed.
\q2 Anga ibmar-ogumakar-ukleged-ailagi ibmar-ukmaloedi an abingaoed.
\q1 Degi, anga-ibmar-ogumakar-ukmaloedi, an abingabaloed,
\q2 ar an-nega, bela dulemarga anse-goled-negye nugguoed.”
\p 
\v 8 Bab-Dummad-Bur-Birigined-Jehová weyob soged:
\q1 “Israel-dulemar e-yargi-gudisurmaladi, gannar e-yargi-ambikuega imaked.
\q2 An-dulamar dagega an imakoed,
\q2 bato an Israel-dulemar-baigan-urbisadbo, an oatogoed.”
\s1 Bab-Dummad dule-isganagi sunmaknaid
\p 
\v 9 Bab-Jehová weyob soged:
\q1 “Bela ibmar-durgan-sapurgi-gudimaladi, degi, bela ibmar-durgan-ursirmaladi,
\q2 be dagmar, an-dulamar be obelodamar.
\q1 
\v 10 Bela Israel-dulemar-nakulemaladi aku-atakmalad, ar wargwensaale, ibmar-daksurmalad.
\q2 Ar bela achu-gwabinsulidyob gumalad,
\q2 ar geg urwemalad.
\q1 Gadi-gabmalad, wiegalamalad,
\q2 yeer gabed itodamalad.
\q1 
\v 11 Bemar achumar-gadi-mas-gunnedyobmalad, immeleged itodasurmalad.
\q2 Bemar sibad-wawaad-edarbemalad, ibmar akusunna itomalad.
\q1 Na war-wargwen e-itolegedba gudidii nanaed,
\q2 bela na e-ibmar-abegedba wala-walagwengi gudidiid.
\q1 
\v 12 Binnasuli be gormar,
\q2 bemar sogmala: ‘¡Dagmar,
\q1 anmar vino sunamar!
\q2 ¡Anmar mumgue, inna-gagbid gobe!
\q1 Anmar banedse emiyobi ibmar imakbaloed,
\q2 emiba anmar bur bule imakmaloed.’ ”
\c 57
\s1 Israel-dulemar ibmar-sobarmaladse gormalad
\q1 
\v 1 Dule-innikidaedi burgwemamaigusad,
\q2 dule gwen bai daksurmalad,
\q1 dule-bega-arbamalad-nuegan, burgwemamaigusad.
\q2 Ar dule aku itodamalad, ibiga dule-nuegan isgued-ular burgwiddamala.
\q1 
\v 2 Ar dule-igar-nuedba-nanaedi, nuedgi burgwemalad,
\q2 neg-uangi obunnomegisdamalad.
\p 
\v 3 Bab-Jehová sogded:
\q1 “Bemar, ome-ina-isgana-imaked-mimmigan,
\q2 negsichigi-galagwensuli-gambanuchuganba-nanamalad-e-wagan, be anse walikgudamar.
\q1 
\v 4 ¿Doagi be dodoye sogmala?
\q2 ¿Doaga be binnasur gaya-maa-maa-imake?
\q1 ¿Doaga be gwabin buud-buud-imake?
\q2 ¿Ar bemar isgued-mimmigansursi?
\q2 ¿Ar bemar gakansamalad-wagansursi?
\q1 
\v 5 Bemar wag-ulu-sapi-urba, degi, bela sapi-dummagan-urba, galagwensuli guddamalad.
\q2 Bab-dummadsurmalad-e-nug-odummogega diangangi, degi, akwa-yaa-ollogangi burwigana be oburgwiddamalad.
\q1 
\v 6 Dian-akwa-swirimalad, begadga gumaloed.
\q2 We-akwa-swirigangi be bergudmaloed.
\q1 We-ibmar-asabinni, vino be eosmalad,
\q2 degi, ega be ibmar-gwag-uklemalad uksamalad.
\q2 Degite, ande we-ibmarmar-abinni, ¿bogi sigode? ¡Adi surbali!
\q1 
\v 7 Yar-matusulid-birigine, be-meged be omesisad,
\q2 yar-matusulidse be nakwisad,
\q2 agi bab-dummadsulidga ibmar-ogumakar-ukega be nakwisad.
\q1 
\v 8 Be-yawagak-daksiki, degi, e-suarmargine, bab-dummadyob-imaklemalad be nasiksad.
\q2 Be angi bangusad,
\q1 dule-baid-asabinni uka-swili be gwisgusad.
\q2 Be-meged-dummad-omesisadgine, be megisad.
\q1 Doamarbo be megbigusa, amarbo be igar nabosad.
\q2 Amarbo be megisgua, e-abgan be daksad.
\q1 
\v 9 Bab-dummad-Molocʼse be nanasad.
\q2 Ega be olivo-gwallu berbedii gusad,
\q2 be-ina-wawagan ega be omelosad.
\q1 Be be-nuggi-sunmakmalad dikasuli barmisad.
\q2 Amala, dule-burgwarmalad-burbase binsaed-amiega, be barmisad.
\q1 
\v 10 Bali-bali-nanaedba be yegus-inigwele,
\q2 degite, gwen be sogsasulid: ‘An wesegoye.’
\q1 Aka bur be gangusad.
\q2 A-ulale, gwen be galakussulid.
\b
\q1 
\v 11 ”¿Doa be-ogwayisa?
\q2 ¿Doa dobguega be-imaksa?
\q1 Emide, be an-yardakdiid.
\q2 Gwen be angi bar binsassurmalad.
\q2 Gwen bai be an-daksasurmalad.
\q1 ¿Ar be an-dobsurmarsunde?
\q2 ¿Ar an undar bogi-gudigusadba be deyob damarsunde?
\q1 
\v 12 Emisgi, an be-ibmar-imakedi an barsogoed,
\q2 gwen bega ibmar-nuedga guosulid.
\q1 
\v 13 Ar dule-be-bendakega be binnasuli gollalile,
\q2 we-ibmar-sobarmalad-bab-dummadyob-imaklemalad gwen be-bendakosulid.
\q1 Bela we-ibmarmala burwaba seledoed,
\q2 unnila buu-imakedgi yoggudoed.
\q1 Ar dule angi-bensuli guele, napaneg egadga guoed,
\q2 an-yala-islidikid na egadga suoed.”
\s1 Bukib-binsadimalad baisur-itoge imaked
\p 
\v 14 Bab-Jehová sogded:
\q1 “Weyob sogdamaloed: ‘Igar-nudakmar, igar-nudakmar, igar-mesmar,
\q2 an-dulamar-idu igar-isgana nudakmar.’
\q1 
\v 15 Ar ade, ani an Bab-Dummad-degisadegu-maidid, an-nuga Isligwaledid, weyob an soged:
\q2 Ani an niba-maid, neg-isligwaledgi an maid,
\q1 degi, dulemar-bukib-binsadimaladgi, degi, gwage-eikwaa-imakmaladgi an burbar maibalid.
\q2 Adi, dulemar-gwage-eikwaa-imakmaladga niga-ogannogegar,
\q2 degi, dule-bukib-binsadimalad baisur-ito imakegar.
\q1 
\v 16 An degisadegu an-dulamargi gwisgudii guosulid,
\q2 degisadegu an amarse urwedii guosurbalid.
\q2 Ar degisulile, bela an dulemar-obinnisadi an-abin bergudo-itole.
\q1 
\v 17 Emar-isgued-ular, an ese ulusad.
\q2 An-urwedgine, an sabsur-imaksad.
\q1 An egi bangusgusad,
\q2 degi-inigwele, aka igar-isganaba bur nanadmalad.
\q1 
\v 18 E-damaladi, an daksad,
\q2 degi-inigwele, an ega nudakoed.
\q1 Idudii an guoed,
\q2 baisur-itoge an imakoed.
\q1 Degine, dule-ega-bukib-binsadimalad,
\v 19 weligwaledgi weyob namakmalaga an imakoed:
\q2 ‘Dikasuli-bukmaladga gwage-bogidik gusun,
\q2 degi, walikaa-bukmaladga gwage-bogidik gusun.’
\q1 An-dulamar an isgussulidyob-dakoed.
\q2 Ani, an Bab-Jehová-guedgi, deyob soged.
\q1 
\v 20 Ar dule-ibmar-isgana-imakmaladi, demar-arwemaiyob gued,
\q2 geg bogi meged.
\q1 Igi demar-arwemair, ibmar-isgana mie,
\q2 degi, ollimar-miardae,
\q2 deyob dule-isganamar gued.
\q1 
\v 21 An Bab-Dummadi soged:
\q2 ‘Dule-isganamargala gwage-bogidikid sulid.’ ”
\c 58
\s1 Mas-gunsuli-gudigued-Bab-Dummad-yeerdaked
\p 
\v 1 Bab-Dummadi Isaíasʼga sogded:
\q1 “Gandikidba be binnasuli gole,
\q2 melle be bogguo,
\q2 gar-trompetaʼyob be binnasuli gole.
\q1 An-dulamarga e-nodiid be soge,
\q2 Jacob-waganga e-isgudiid be soge.
\q1 
\v 2 Ar bane-bane anse gordimalad,
\q2 dulemar igar-innikigwad-imakdiiyobi,
\q1 degi, An-Igar-Mesisadgi bangussurmalayobi,
\q2 An-Igar-Mamaid wisgubimalad.
\q1 Igar-inniki-imakleged anse egismalad,
\q2 ar anse walikgudabimalad.
\q1 
\v 3 Degi, ar anga weyob sogmalad: ‘¿Ar ibiga anmar mas-gunsuli bese-golega gudiguoe?
\q2 Ar bede aku-anmar-daked.
\q1 ¿Ar ibiga anmar be-ular san-wiomarsunna?
\q2 Ar bede baisur anmar-dakbalid.’
\b
\q1 ”Bemar mas-gunsuli-gudigued-ibagi, mani-onogedgi be arbadamalad,
\q2 degi, dule-bega-arbamalad be sabsur-imakdedamalad.
\q1 
\v 4 Ar unnila bemar urwegala, degi, abin-abin-imakmalagala,
\q2 na sarsomalagala, be mas-gunsuli gudii damalad.
\q1 Ar be-itobi be an-abemalale, be mas-gunsuli-gudigued imakmardo.
\q2 Degi-inigwele, melle emi-imakedyobi be imako.
\q1 
\v 5 Weyob mas-gunsuli-gudiguedgi, ¿dule na dukin san-wiodii imakoye an sogsasi?
\q2 Nargammu-dopee-daklegedyobi, ¿nono-dullu-gudiguoye an sogsasi?
\q1 Gwage-naibid-oyogega, ¿wile-itoged-mor-yoi gudiguoye an sogsasi?
\q2 ¿We be bimarsunde, mas-gunsuli-gudigued an yeer dakye?
\q2 Degi, ¿Bab-Jehová-iba-nued guye?
\b
\q1 
\v 6 ”An-ular-mas-gunsuli-gudigued-iba an susadi, ¿igar-isgana obelogegarsursi?
\q2 ¿Dule-sabsur-arbaega-imakleged onogegarsursi?
\q1 ¿Dule-mesagwar-saledimalad bendakegarsursi?
\q2 Degine, ¿bela igar-isganaba-ebipiledimalad onogegarsursi?
\q1 
\v 7 Ar mas-gunsuli-gudiguedi, ¿dule-ukudmaada-gudiidga be-mas be ukegarsursi?
\q2 ¿Dule-negsuli-gudimalad akwegarsursi?
\q1 ¿Dule-morsatemaladga mor-ukegarsursi?
\q2 Degine, ¿melle be-gwenadgan-obanegarsursi?
\q1 
\v 8 Ar be weyob mas-gunsuli-gudigued imakele, igi-wakudar-dad-ibeler noardae, deyobi be guoed.
\q2 Boni-be-nikadi, yog-bega nugudoed.
\q1 Be-igar-inniki-imakedi bega igar egaoed,
\q2 gandikidba-an-yeerdaklegedi beba gudioed.
\q1 
\v 9 Be anse golele, an be-abinsaoed.
\q2 Be anse-bendakleged-egisele, an bega sogoed: ‘¡Wegi an gwichiye!’
\b
\q1 ”Dule-mesagwar-imaked-igargi be banguele,
\q2 dulegi-gwisgued-igargi be noele,
\q1 degi, yogasaar-emargi-gakansaedgi be banguele,
\q2 igi-negsichidgi neg-ibegwar-naddae, deyobi be-daedi naoed.
\q1 
\v 10 Dule-ukudmaada-gudimalad be bendakdele, degi, dule-ibmar-abesa-gudiidga be ibmar-ukdele,
\q2 igi-yoruku-neg-mee-dakledae, deyobi be-daedi guoed.
\q1 
\v 11 Ani an Bab-Jehová gusgu be-idudii guoed.
\q2 Nega-dinnaganba an bega mas-ukdii guoed,
\q2 an bega be-garmar ogannogoed.
\q1 Igi-dutugalu ogles-naidae, deyobi be guoed,
\q2 igi-ibe-aryomaidaedi, geg dii-bergue, deyobi be guoed.
\q1 
\v 12 Dikasurgus-neg-bibichismaladi gannar bemar soboed.
\q2 E-sailamar dikasurgus-mamaidi, ogannomaloed.
\q1 Be weyob bilemaloed: ‘Galu-matusurmalad-bibichisad-nudakmaladye,
\q2 negmar-bibichisad-gannar-sobmaladye.’ ”
\s1 Obunnoged-ibagi, obunnoged-igar
\p 
\v 13 Bab-Jehová weyob soged:
\q1 “Obunnoged-ibagi be obunnodimalale,
\q2 gwen egi be nodisurmalale,
\q1 an-iba-islidikidgi be-itolegedba be ibmar-baigan-imaksulile,
\q2 be ani Jehováʼgine wergued amimaloed.
\q1 Weyob be obunnoged-iba-bimalale:
\q2 ‘Weligwaled-ibaye.’
\q1 Degi, weyob be iba-islidikid-bimarbalile:
\q2 ‘Bab-Jehová-nug-odummoged-ibaye.’
\q2 Be angine, wergued amimaloed.
\q1 Obunnoged-ibaga be bagagwar-gumalale,
\q2 mani-onogedgi-arbasulidgi be an-nug-odummomalale,
\q1 degine, walagwengi be-itolegedba-yogasaar-sunmaksulidgi be an-nug-odummomalale,
\q2 
\v 14 be angine, wergued amimaloed.
\q1 Neggwebur-e-dummaganga an be-imakmaloed,
\q2 degi, be-dad-Jacobʼba be ibmar-nikuoedgi be yeer itomaloed.”
\c 59
\s1 Israel-dulemar e-isgued barsogsad
\q1 
\v 1 Bab-Jehová anmar-abonogega, ganguedsurye soglesulid.
\q2 Degi, aku-anmar-itoye soglesurbalid,
\q2 ar bela magar anmar-itoged.
\q1 
\v 2 Ar bemar-isguedi, Bab-Dummadgi-banguega bemar-imaked.
\q2 Ar be-isgumaladi, Bab-Dummad bemar-idu wagar-aibirar-megega imaked,
\q2 adi, melle bemar-itogegar.
\q1 
\v 3 Ar bemar ablisbi argan sedimalad,
\q2 degi, goonumar isguedbi na be sedimalad.
\q1 Be-gwabin-duku unnila gakansaedgi sunmaked,
\q2 be-gaya unnila igar-isganaginbi sunmaked.
\q1 
\v 4 Dule igar-innikigwadgi-sunmaked sulid,
\q2 dule napiragwadgi-igar-naboged sulid.
\q1 Gakansalegedgi bensurmalad,
\q2 na muchub-muchub gakansamalad.
\q1 Binsaed-isganagi binsadamalad,
\q2 degi, igar-isgana imakdedamalad.
\q1 
\v 5 Dulemar, naibe-nuegan-e-akwa-bukwayobi binsaed-isgana sedimalad,
\q2 diba-nagueyob, igar-isgana amimalad.
\q1 Dule, binsaed-isgana we-naibe-akwayob gunnele, burgoed.
\q2 Ar dule, we-naibe-akwa marele, ega naibeyob binsaed-isgana ainidagoed.
\q1 
\v 6 Dibagi geg mor sobleged,
\q2 dule diba-soblealed geg e-morga imaked.
\q1 Dule-ibmar-imakedi ibmar-isganabi-imakmalad,
\q2 e-ibmar-samaladi, unnila sabsur-neg-gagaed.
\q1 
\v 7 A-dulemar ibmar-isgana bur-imakmalad,
\q2 bur dule-ibmar-akalodisulid-ibe ablis eomalad.
\q1 E-binsaedi, galagwensur-igar-isganagi binsamalad.
\q2 E-ibmar-imakedi bela neg-oichoged.
\q1 
\v 8 Gwage-bogidikid-igar gwen wissurmalad.
\q2 E-ibmar-imakedgi igar-innikimalad naisulid,
\q2 unnila igar-noarmaladbi onoardaed.
\q1 Ar dule we-igar-isganamarba nanadiile,
\q2 gwage-bogidikid-igar wisguosulid.
\p 
\v 9 Isaías sogded:
\q1 “A-ulale, igar-napira-maid anmargi banguded.
\q2 Degi, igar-innikigwadi anmargi aibated.
\q1 Neg-meegwadi anmar abdakdii gusanad.
\q2 Degi-inigwele, neg-gubyagwaledgi anmar bukudapid.
\q1 Neg-ibegwaledi anmar abdakdii gusanad.
\q2 Degi-inigwele, anmar negsichidgi bukudapid.
\q1 
\v 10 Dule-aku-atakmaladyobi, anmar galu-ebu-ebu gudimalad.
\q2 Dule-ibyasurmaladyobi, anmar negsichidgi acha-acha gudimalad.
\q1 Neg-mutikidyobi, anmar neg-ibgine yoleddamalad.
\q2 Anmar bonisuli-inigwele, burgwaleyob na gudimalad.
\q1 
\v 11 Bela anmar wiob-uurmakedyob, uurmakbukwad.
\q2 Nuu-sibu akiginnedyob, anmar akiginbukwad.
\q1 Aisaar igar-innikigwad-imaked anmar na abdakbukwanad, gwen imaklessulid.
\q2 Ollorgued-igala anmargi amba dikasulid.
\b
\q1 
\v 12 ”Be wisid, anmar-isguedi bukidarad.
\q2 Anmar-isguedi, anmargi aibined.
\q1 Anmar-ibmar-isgana-imaked anmarba gudiguad.
\q2 Anmar isguedgi-gudiidi, na magar itomalad.
\q1 
\v 13 Anmar, uayasuli gusad.
\q2 Anmar, Bab-Jehová-obachamalad.
\q1 Anmar, Bab-Dummad-iedmalad.
\q2 Anmar, dogdar dule-mesagwar imakmalad,
\q1 degi, dogdar dule-yardaksamalad.
\q2 Anmar-binsaedgi-gakansaed-ainiedi, anmar dulemarga sogsamalad.
\q1 
\v 14 Igar-napira-maidi isdar-daklege gusad,
\q2 degi, igar-napiragwadi amba anmargi dikasulid.
\q1 Dulemar-ambikuedgi igar-nabirid-oyoleged bergusad.
\q2 Binsaed-nikadaedi, bar anmar oyosurgusad.
\q1 
\v 15 Dule ibmar-nabir-imaked, bar daklesulid.
\q2 Ar dule isguedgi bangudele, bela e-ibmar-nikadi ei obelodamalad.
\b
\q1 ”Bab-Jehová bela igar-innikimalad-bergusa-dakargu, nabir-itossulid.
\q2 
\v 16 Bab-Dummadi, dule igar-nuegangi bar-binsasuli dakargu, geger dakalid.
\q1 A-ulale, Bab-Dummad na e-gangued oyogoye binsaalid.
\q2 Adi, anmar-abonogegar, e-igar-innikigwadba anmar-abingaegar.
\q1 
\v 17 Bab-Dummadi e-igar-innikigwadi, sigu-abgaedyobi yooed,
\q2 degi, bormo-gurginyobi abonoleged-igar sioed,
\q1 buged-imaked-mola yooed,
\q2 urwed-mola yooed.
\q1 
\v 18 Dule-ibmar-imaksamaladba sabsur-odurdakoed.
\q2 Neggwebur-demar-gakaba-bukmaladga buged-imakoed:
\q1 E-isdarmaladse urwoed,
\q2 degi, e-isdarmaladgi buged-imakoed.
\b
\q1 
\v 19 ”Dad-argwanedsikmalad Bab-Jehová-nug dobgudmaloed.
\q2 Dad-nakwedsikmalad Bab-Jehováʼgi binsaed-nikaa gudmaloed.
\q1 Ar ade, diwar-gwichigudanidaedyobi Bab-Jehová na e-buu-imakedba danikoed.”
\p 
\v 20 Bab-Jehová weyob soged:
\q1 “Dule-bendakedi, Sión-yalase danikoed,
\q2 Jacob-wagan-e-isguedga-bukib-binsaega imaknonikoed.
\b
\q1 
\v 21 ”An bemarbo igar mesed,
\q2 An-Burba bemargi maigu guoed.
\q1 Be-gwabindukugine, an bega an-gayaburba-nasiksadi, bar begine alliosulid.
\q2 Degi, be-mimmigangine, be-wagangine, bar an-gayaburba alliosulid,
\q2 emi-ibadse degisadegu guoed.”
\c 60
\ms2 4b. Yoedse Jerusalén gandikidba yeer-daklegoed
\mr (60:1–66:24)
\s1 Jerusalén neggwebur-gwapidga guoed
\p 
\v 1 Bab-Jehová soged:
\q1 “¡Jerusalén-dulemar, be gwichigu!
\q2 ¡Bela ibegwale be gumar!
\q1 ¡Be-neg-ibegwaledi bese warmaknonikid!
\q2 Ani Bab-Jehová-gued.
\q2 An-gangued-yeerdaklegedi begi ibegwar naid.
\q1 
\v 2 Be dake, neg-gubyagwaledi napneg-gasanaid.
\q2 Degi, negsichidi, dulemargi naid.
\q1 Degi-inigwele, an-ibegwaledi begi mee-gaoed.
\q2 ¡Begine, an-gangued-yeerdaklegedi oyolegoed!
\q1 
\v 3 Dule-yar-baid-baidgi-bukmaladi, be-neg-meegwadba gudii gumaloed,
\q2 degi, reymar be-neg-ibegwaledba nanadii gumaloed.
\b
\q1 
\v 4 ”Nue be atake, be-dikarba be nue neg-dake:
\q2 Bela danar-ambikusmalad, bese danimalad.
\q1 Be-mimmigana dikasuli bese danimaloed.
\q2 Be-bunamala argangi-annikaa nidanimaloed.
\q1 
\v 5 Weyob be dakoed,
\q2 degi, weligwaledba be yeer itodoed,
\q1 ise-weligwaledba be-gwage dik-dik naguoed.
\q2 Degi, be-gwage ise-yeer itonaoed.
\q1 Ar begala neggwebur-demar-gakagi-bukmalad-e-ibmar-nuegan senonimaloed.
\q2 Degi, dulemar-yar-baid-baidgi-bukmalad-e-ibmar-nuegan bese warmaknonikoed.
\q1 
\v 6 Be-walik moli-yargan-muremalad engudoed.
\q2 Madián-dulemar-e-moli-yargan-muremalad, Efa-dulemar-moli-yargan-muremalad engudoed.
\q1 Bela Sabá-neggweburginmaladi bese nonimaloed,
\q2 bega ina-wawagana, degi, ormar senonimaloed.
\q2 Degine, an-nug-odummogagwale danimaloed.
\q1 
\v 7 Bega, Cedar-neggwebur-e-sibad-wawaadmar ambikunonikoed.
\q2 Degi, Nebaiot-neggwebur-e-sibad-wawaad-machergan bega ibnuedga guoed.
\q1 Adi, an-ailagi anga ibmar-nued-uklegedga guegar.
\q2 Degi, ani an, an-nug-odummoleged-neg yeerdaklege an imakoed.
\b
\q1 
\v 8 ”Mogiryob-nasdamalad, ¿wede doamala?
\q2 Nuu-sibuyob e-uuse nadapdamalad, ¿wede doamala?
\q1 
\v 9 Neggwebur-demar-gakaba-bukmaladi angi benguosurmalad.
\q2 Tarsis-ur-dummagan, ur-dummagan-idudanikid.
\q1 We-urmar, dikasuli be-mimmigan-sedanikid,
\q2 degi, e-ormar, e-manimar sedanikid,
\q2 adi, an-nug-odummolegegar.
\q1 Ar ani an Israel-dulemar-e-Bab-Dummad-Isligwaledid,
\q2 ar ani an gandikidga be-imaksad.
\b
\q1 
\v 10 ”Dule-ainebarmalad bega gannar galu-matusurmalad soboed,
\q2 degi, e-reymar bega arbamaloed.
\q1 An-urwedgi an sabsur-be-odurdaksa-inigwele,
\q2 an-sabguedgi an ise-wile be-dakoed.
\q1 
\v 11 Be-yawagak argasigu guoed,
\q2 mutikidbali, degi, ibginedbali gwen atiosulid.
\q1 Bega dulemar-yar-baid-baidgi-bukmalad-e-ibmar-nuegan seledanikoed,
\q2 e-reymar bese ilekwaa seledanikoed.
\q1 
\v 12 Dulemar-yar-baid-baidgi-bukmaladi, degi, yalamar-nanaidi,
\q2 beba ibmar-imaksulile, bela obelolegoed.
\b
\q1 
\v 13 ”Líbano-yala-e-ibmar-nuegan-nikadi, bese warmakoed,
\q2 ciprés-sapi-warmar, baryawarmar, degi, abeto-sapi-warmar bese warmakoed.
\q1 Adi, an-neg-islidikid yeerdakle imakega,
\q2 an-mali-onakwed-gana-neg-siid-e-nug ogannogegar.
\q1 
\v 14 Dulemar-mesagwar-be-imakmalad-e-mimmigan, bese dulluu-ambikunonimaloed.
\q2 Bela dulemar isdar-be-dakmaladi, be-asabin sindigar-signonimaloed,
\q1 degi, weyob be-bimaloed, ‘Bab-Jehová-neggweburye,
\q2 Sión-yala, Israel-dulamar-e-Bab-Dummad-Isligwaledgadye.’
\b
\q1 
\v 15 ”Be walagwen-melledgus-inigwele,
\q2 degi, be isdardakles-inigwele,
\q1 dule gwen be-igarba nanassur-inigwele,
\q2 degisadegu nug-dummarba-guega an be-imakoed,
\q2 degi, dulemar weligwar be-imakega an imakoed.
\q1 
\v 16 Dule-yar-baid-baidgi-bukmalad-e-mas be gunnoed,
\q2 reymar-e-ibmar-nuegan bega uklegoed.
\q1 Degisoggu, na be wisguoed, ani an Bab-Jehová be-Abonogedid.
\q2 Ani an Jacob-wagan-e-Bab-Dummad-gandikid be-bendakedid.
\b
\q1 
\v 17 ”Esgoro-gordikid-muchubbi an bega olo sedagoed,
\q2 esgoro-muchubbi an bega mani sedagoed.
\q1 Urgo-muchubbi an bega esgoro-gordikid sedagoed,
\q2 degi, akwamar-muchubbi an bega esgoro sedagoed.
\q1 Neg-bogidikid-naguega an imakoed.
\q2 Degi, igar-innikigwadi negseega an imakoed.
\q1 
\v 18 Bipisaale bar be-yargi sabsur-imaklegedi, be itogosulid.
\q2 Bar be-yalagi neg-bibichedgi, degi, neg-obelogedgi sunmaklegosulid.
\q1 Ar ade, weyob be-galu-matusurmaladgi soglegoed:
\q2 ‘Abonolegedye.’
\q1 Degi, be-yawagakmardi weyob bimarbaloed:
\q2 ‘Bab-Dummad-nuggi-namaklegedye.’
\q1 
\v 19 Bar dad-ibeler bega neg-ibgi, neg-meegwadga guosulid,
\q2 degi, nii bar bega mee gaosurbalid.
\q1 Ar Bab-Jehová bega gwallu-meegwad-degisadeguadga guoed.
\q2 Be-Bab-Dummad be-gangued-yeerdaklegedga guoed.
\q1 
\v 20 Dad-ibeler bar bega argwanosulid,
\q2 degi, nii-gaedi gwen mommolegosurbalid.
\q1 Ar ani Bab-Jehová be-gwallu-meegwadga degisadegu guoed.
\q2 Geb agi be-wile-itodiidi bergunonikoed.
\b
\q1 
\v 21 ”Degisoggu, bela innikigwadga be-dulemar guoed,
\q2 degi, bela be-dulemar napneg gaoed.
\q1 Sapi-ainiedyob ainidamaloed.
\q2 Ani an deyob imakoed.
\q1 An-sunnagwad an imakoed,
\q2 an-nug odummolegoed.
\q1 
\v 22 Dula-ichegwadi bur miliba (1,000) mergudoed,
\q2 bur-neggwebur-bipigwadi, neggwebur-gandikidga guoed.
\q1 Ani an Bab-Jehová gued.
\q2 We-ibmarmar-guoed-e-ibagan warmaknonikile, gwae-gwae-guega an imakoed.”
\c 61
\s1 Israel-yarga bendaklegedgi sunmaklenaid
\q1 
\v 1 “Bab-Dummad-Jehová-Bur-Birigined-E-Burba angi maid.
\q2 Ar ade, dule-wilemaladga gayaburba-nuegangi-sunmakega, Bab-Dummad an-susad.
\q1 Bab-Dummad an-barmialid,
\q2 dule-gwage-nunmak-itodimaladga gwage-armakegar.
\q1 An-barmialid, dule-galesbukmalad-onogedgi sunmakega,
\q2 degi, dule-esgaryagi-galesbukmalad onogegar.
\q1 
\v 2 Bab-Dummad an-barmiarbalid, Bab-Jehová-birga-nuedgi sunmakega,
\q2 degi, anmar-Bab-Dummad-buged-mai-imakoed-e-ibagi sunmakegar.
\q1 An-barmiarbalid, bela dule-wile-itodimalad-e-gwage armakega,
\q2 
\v 3 degi, Sión-dulemar-gwage-nunmak-itodimalad-niga ogannoegar.
\q1 An-barmialid, nonogi-buru-biin-gudiid-muchub, ega ologurgin ukegar.
\q2 An-barmialid, wile-itoged-muchub, weligwaledba ega gwallu-wawad ukegar.
\q2 An-barmialid, bukib-binsadiid-muchub, ega weligwar-itoged ukegar.
\q1 Geb degine, wemar weyob biledmaloed: ‘Igar-innikigwad-urwar-sapimarye.’
\q2 Bab-Jehová na e-gangued-oyogega digsad.
\b
\q1 
\v 4 ”Negmar-epennemalad-bibichis-bukwadi, gannar sobmaloed.
\q2 Negmar-birgabargus-akwamarbi-omilededi, gannar nudakmaloed.
\q1 Neggweburmar-bibichis-bukwadi, gannar obinomaloed.
\q2 Dikasurgus akwamarbi-neggwebur-omilededi, gannar nudakmaloed.
\q1 
\v 5 Dule-ainebarmaladi, be-sibad-wawaadmar akwemaloed.
\q2 Dule-neggwebur-baidsikmaladi, be-nainumargi, degi, be-uva-nainumargi, bega arbamaloed.
\q1 
\v 6 Ar bemardi weyob biledmaloed: ‘Dule-irwa-Bab-Dummadse-goled Bab-Jehováʼgadye.’
\q2 Bemarga sogdemaloed: ‘Anmar-Bab-Dummadga ibmar-imakmaladye.’
\q1 Dulemar-yar-baid-baidgi-bukmalad-e-ibmar-nuegangi, be yeer itomaloed.
\q2 E-ormar-sunsogmaladi, be yomaloed.
\b
\q1 
\v 7 ”An-dulamar, e-binged-dummad-itosmalad-muchub, ibmar-nuegan ilabo-wilub abingamaloed.
\q2 An-dulamar, e-nug-isgusad-muchub, ibmar-ega-uklegoedgi yeer itomaloed.
\q1 Deyobi, na e-napagine ibmar-ega-uklegoedi, ilabo-wilub abingamaloed,
\q2 degisadegu weligwale gudii gumaloed.
\b
\q1 
\v 8 ”Ani an Bab-Jehová, igar-innikigwad-sabedid,
\q2 ar ibmar-atursaeddi, degi, igar-isgana-imaklegeddi, an isdar-daked.
\q1 An-inniki-daedgi an bemarga ibmar-buged-ukleged ukoed.
\q2 An bemarbo igar-degisadeguad mesoed.
\q1 
\v 9 Be-wagana, dulemar-yar-baid-baidgi-bukmalad-imbagi, nug-nika gumaloed.
\q2 Be-mimmigan neggweburmar-imbagi nug-nika gumaloed.
\q1 Dulemar dakarmalale, magar dakmaloed, sogmaloed:
\q2 ‘We-dulemar, Bab-Jehová dulemargi-nued-binsasmalad e-waganad.’ ”
\b
\q1 
\v 10 “Bab-Jehováʼgi an bela-bela yeer itoged,
\q2 an-Bab-Dummadgi an weligwar itoged.
\q1 Ar ade, abonoleged-mormar anga yosad,
\q2 degi, igar-innikigwad-imaked-morgi an-edusad.
\q1 Machered ome-nikunair, igi ibmar-yeerdakleged bebegi-yoidae, deyobi an gued.
\q2 Ome sui-nikunair, igi ormar-nasikdae, deyobi an gued.
\q1 
\v 11 Ar igi napa ibmar-muugan-oniega imake, degi, igi nainu ibmar-gwag-niega imake,
\q2 deyobi, Bab-Jehová-Bur-Birigined, bela dulemar-yar-baid-baidgi-bukmalad-abargi, igar-innikigwad, degi, namakleged, ainidagega imakoed.”
\c 62
\s1 Sión-neggwebur-nug-gwapid
\q1 
\v 1 An Sión-neggwebur-sabed-ulale, an bogiguosulid.
\q2 An Jerusalén-neggwebur-sabed-ulale, an obunnogosulid.
\q1 Geb Bab-Dummad-e-Igar-innikigwad-imaked magar-daklegedse, an bogiguoed.
\q2 Geb Bab-Dummad-bendakleged, gwinnur-gaedyob-guedse, an obunnogoed.
\q1 
\v 2 Dulemar-yar-baid-baidgi-bukmaladi, be-igar-innikigwad-imaked dakmaloed.
\q2 Bela reymala be-gangued-be-yeerdakleged dakmaloed.
\q1 Nug-gwapid be nikuoed,
\q2 Bab-Jehová-sunnad bega nug ukoed.
\q1 
\v 3 Bab-Jehová-e-argangine, ologurgin-yeer-gaedyob, be guoed.
\q2 Be-Bab-Dummad-e-argan-yaurgine, ibmar-yeerdakleged-reymar-bebegi-nasiklegedyob, be guoed.
\q1 
\v 4 Wargwen-mellededye, bar be-biosurmalad.
\q2 Napabi-naidye, be-yala biosurmarbalid.
\q1 An egi-yeer-itogedye, be bilegoed.
\q2 An-sanwaye, be-yala bilegoed.
\q1 Ar Bab-Jehová begi yeer itogoed,
\q2 be-yala sui nikuoed.
\q1 
\v 5 Ar sapingwa na e-yagwabo-nikunaiyobi, gannar-be-urbed,
\q2 deyobi bebo nikuoed.
\q1 Ar igi-sapingwa yagwa-ebo-nikuoedgi weligwar-itodae,
\q2 deyobi, be-Bab-Dummad, begi yeer itogoed.
\b
\q1 
\v 6 Jerusalén-neggwebur, be-galu-matusurmaladgi, sorda-nakulemalad an urbisad.
\q2 Wemala, bipisaale gwen mutikidbali, ibginedbali, gaya bogiguosurmalad.
\q2 Bemar, Bab-Jehováʼse-gormalad melle be obunnomalo.
\q1 
\v 7 Ar Jerusalén-neggwebur gannar urbedse, degi, Jerusalén-neggwebur-nug-nika imakedse,
\q2 melle be, Bab-Dummad obunnogega imakmalo.
\b
\q1 
\v 8 Bab-Jehová na e-argan-gangued-nikadba, weyob ise-sogar imaksad:
\q2 “Bipisaale be-ibmar-gwag be-isdarmalad-e-masga-guega bar an ukosulid,
\q2 degi, vinoʼgi be nue-arbasgusadi, dule-ainebarmaladi be-ibe gobosurmalad.
\q1 
\v 9 Dule ibmar-gwag-wesmaladi, an nug odummobukwa ibmar-gwag gunmaloed.
\q2 Dule uva-san-wesmaladi, anse-goled-neg-islidikid-neg-imbagi, vino gobmaloed.”
\b
\q1 
\v 10 ¡Jerusalénʼginmalad, be ainimar!
\q2 ¡Yawagak-bukwadgi, be ainimar!
\q1 ¡Dulemar-idu igar nudakmar!
\q2 ¡Igar-dummad be mesmar!
\q1 ¡Bela akwamar be onirmar!
\q2 ¡Dulemar igar-maid-magar-dakega be bander onakwe!
\p 
\v 11 Bab-Jehová bela-dulemar-napneggi-bukwadga, weyob sogsad:
\q1 “Jerusalén-dorganga be sogmar:
\q2 ‘¡Bato be-abonoged danikid!
\q1 Na e-nakwisad-ibmar eba sedanikid,
\q2 na e-ibmar-buged-ukleged eba danikid.’
\q1 
\v 12 Dulemar-islidikidye, be bilemaloed.
\q2 Bab-Jehováʼse bendaklesmaladye, be bilemaloed.
\q1 Neggwebur-abelegedye, be-neggwebur bilegoed.
\q2 Neggwebur bipisaar wargwen-melledsulidye, be-neggwebur bilegoed.”
\c 63
\s1 Bab-Jehová Edom-dulemargi nakwisad
\q1 
\v 1 Edom-yar-akar danikid, ¿wede doawa?
\q2 Bosra-neggwebur-akar mor-ginnidbi-yoi danikid, ¿wede doawa?
\q1 Mor-nudakar-yoi danikid, ¿wede doawa?
\q2 Gandikidba binna-binnagwad danisulid, ¿wede doawa?
\b
\q1 “Ani an danikid. An igar-innikigwadba-sunmakedid,
\q2 an dule-abonogega-gangued-nikadid.”
\b
\q1 
\v 2 ¿Ar ibiga be-mor ginnitibi daklege?
\q2 Ar be-mor, uva-egured-galugi dule-uva-egured-e-moryob dakleged.
\b
\q1 
\v 3 “An walagwen uva-egured-galugi uva-egurusad,
\q2 dule-bamalad gwen anba gunai gussulid.
\q1 An-sae-itogedgi an egi annasad.
\q2 An-urwedgi an maataa imaksad.
\q1 E-ablis an-morgine milesad,
\q2 degi, bela an-mor ese isgusad.
\q1 
\v 4 Buged-mai-imaked-iba bato an mesisad.
\q2 An-dulamar-bendakleged-iba bato warmaksad.
\q1 
\v 5 Dule-an-bendaked an edarbisanad, degi-inigwele, dule gwen an-bendaksasulid,
\q2 dule-wargwensaar-an-bendakbi-gussulid geg an itoged.
\q1 Dukin an-ganguedgine an emargi obichad.
\q2 An-urwedi sikirmakega an-imaksasulid.
\q1 
\v 6 An-sae-itogedgi, dulemar-yar-baid-baidgi-bukmalad-birgi an annasad,
\q2 an-urwedgi an amar-obelosad.
\q2 E-ablis napagi-milegega an imaksad.”
\s1 Bab-Jehová Israel-dulemargi nued-binsaed
\q1 
\v 7 Bab-Jehová-e-sabgued-dummad an ebinsaoed,
\q2 e-ibmar-dummagan-imaksadgi an namakoed.
\q1 Bab-Jehová bela anmarga ibmar-imaksad-ular, an ega namakoed.
\q2 Wile-anmar-daked-ular, degi, dummad-anmar-sabed-ular, an ega namakoed.
\q1 Bab-Jehová Israel-dulemarga ibmar-nuegan-bukidar-imaksad-ular, an ega namakoed.
\q2 
\v 8 Ar Bab-Dummad weyob sogsad:
\q1 “Ar napiragwa, wemar an-dulamalad, mimmigan-an-yardakmalosulidid.”
\q2 Deyobi, e-suli-suli-itogedgine, Bab-Dummad bendaknonikid.
\q1 
\v 9 Bab-Dummad dule-abonogega, dule-e-nuggi-sunmaked, degi, baliwitur, barmiarsulid,
\q2 na e-sunnad dule-abonosad.
\q1 E-sabedgine, degi, e-wile-dule-dakedgine, bendaknonikid.
\q2 Gannarse ogwichisad, na e-ganguedba sesad.
\q2 Epennegwadyobi deyob imaksad.
\q1 
\v 10 Degi-inigwele, Israel-dulemar Bab-Jehováʼba ibsassurmalad,
\q2 E-Burba-Isligwaled-wile-itogega imaksamalad.
\q1 A-ulale, Bab-Jehová Israel-dulemar-e-isdaradga gunonikid,
\q2 Bab-Dummad e-sunnad egi bila-onosad.
\b
\q1 
\v 11 E-dulamar, epenne neg-gusmalad-ebinsadmalad,
\q2 degi, Moisés-ibagangi neggusad-ebinsadmalad, weyob sogdemalad:
\q1 “Dule demar-obakega anmar-idunadap-gusadi, emide, ¿bia gudii?
\q2 Dule Israel-dulemar-e-iduedi, ¿bia nade?
\q1 Bab, E-Burba-Isligwaled-Moisésʼgi-mesisad, ¿wede bia nade?
\q2 
\v 12 Dule e-gangued-nikadba Moisés-argan-nuedsik, Moisésʼba nadapigusad, emide, ¿bia nade?
\q1 Bab, dulemar-asabin demar-egasad,
\q2 adi, degisadegu e-nug-dummarba-guega, ¿wede bia nade?
\q1 
\v 13 Igi-moli nega-dulesulidganba gwen ibmargi-yolesuli nadapdae,
\q2 deyobi, muu-billi-odinnosadba dulemar-obakega-imaksadi, ¿wede bia nade?”
\q1 
\v 14 Igi-moli-bebe-nikamalad nebase gagan-manonidamala, deyobi,
\q2 Bab-Jehová-E-Burba, Israel-dulemarga obunnoged uksad.
\q2 Bab-Jehová, be-nug-dummarba-guega, weyobi, be-dulamar-idumai be gusad.
\s1 Bendaklegega Bab-Dummadse goled
\q1 
\v 15 Bab-Dummadye, mogir-billi-akale, be nue atake.
\q2 Be-neggandikid-islidikid-yeerdakleged-akale, be nue negdake.
\q1 ¿Bia be-sabed-dummarbad, degi, be-gangued nade?
\q2 Be-wile-dule-daked, degi, be-sabgued anmar daksulid.
\q1 
\v 16 Degi-inigwele, be, anmar-Babad,
\q2 ar Abraham amba aku-anmar-dakele, degi, dad-Israel amba aku-anmar-dakbalile,
\q1 be, Bab-Jehová, be anmar-Babad.
\q2 Gusgu be Anmar-Ollor-Imakedye nugad.
\q1 
\v 17 Bab-Jehová, ¿ibiga be-igargi banguega be anmar-imake?
\q2 Bab-Jehová, ¿ibiga be, mer be-dobgumalaga, anmar-gwage-dutusur imake?
\q1 Be-maigan-sabed-ulale, be gannar dage.
\q2 Be-dulamar-danar-danar-bukwad-sabed-ulale, be gannar dage.
\q1 
\v 18 Be-dulamar ichesaale be-neg-islidikid akwisad.
\q2 Emidi, anmar-isdarmalad bela be-neg-islidikidyaba ubosad.
\q1 
\v 19 Emidi, anmala, be-anmar-dummad-iduedga-megissulidyob bukwad.
\q2 Anmala, begadga-gussulidyob bukwad.
\c 64
\q1 
\v 1 Anmar-Bab-Dummadye, bitigi be nibneg egasana gadin,
\q2 bitigi be aidealina gadin.
\q2 Ar be-abin yarmar giglimakdeled.
\q1 
\v 2 Be-isdarmalad-abargi be-nug be oyodele,
\q2 igi soo sapan-ogader dii-ogwakgwarmakdae,
\q1 deyobi, be-abin dulemar-yar-baid-baidgi-bukmaladi gudmalaled,
\q2 be-abin wawanmakdemalaled.
\q1 
\v 3 Be aidenonigu, ibmar-geger-itolemalad, ibmar-gegerdaklemalad, anmar abdakbuksulid be imaksad,
\q2 be-asabin yarmar giglimakded.
\q1 
\v 4 Negasaila-akale, dule-egi-bensurmaladga ibmar-dummagan-imaked dakledisulid,
\q2 dule-baid-beyobid gwen itoledisurbalid.
\q1 
\v 5 Dule-weligwaledgi-igar-innikigwad-imakdiid be abingaed,
\q2 be-igarba-nanadimalad be abingabalid.
\q1 Ar anmar isgussoggu, be sae-itoded.
\q2 Ar anmar dikasurgus isguedginbi gudidimalad.
\q1 ¿Ar wede anmar sunna abonolede?
\q2 
\v 6 Ar anmarde bela ibmar-isganayob gumalad.
\q1 Bela anmar-igar-inniki-imakedi, siamar-yokor-bisgemalad-e-mor-ebusadyob gued.
\q2 Bela anmar gagan-dinguedyob gumalad.
\q2 Anmar-isguedi, burwayobi anmar-oseleged.
\q1 
\v 7 Dule-wargwensaale, be-nug obarsulid,
\q2 begi-bendakleged-amiegala gwen gandik-imaksurmarbalid.
\q1 A-ulale, be-wagar be anmar-idu odukusad,
\q2 degi, anmar-isguedba-berguega be anmar-imaksad.
\b
\q1 
\v 8 Degi-inigwele, Bab-Jehová, bee be anmar-Babad.
\q2 Anmar napsa gumalad.
\q1 Bedi napsa-sobedga gued,
\q2 bela be anmar-obinnisad.
\q1 
\v 9 Bab-Jehová, melle be bela-bela sae-itoge.
\q2 Melle be degisadegu anmar-isgued ebinsadii gue.
\q1 Wis be wile-anmar-dake,
\q2 ar anmar bela be-dula gumalad.
\q1 
\v 10 Be-neggweburmar-islidikmalad nega-dulesulidganga gunonikid.
\q2 Siónʼse-bakale, nega-dulesulidganga gunonikid,
\q2 Jerusalén-neggwebur ollobi-daarmakarnai gunonikid.
\q1 
\v 11 Anmar-bese-goled-neg-yeerdakleged-islidikid, bia an-babgan bega namakbukdamala, bela soose gummaksa siid.
\q2 Bela anmar-ibmar-bur-nuegan-nikadi, bergusad.
\q1 
\v 12 Bab-Jehová, weyob-ibmarmar-gusadgine, bede, ¿gwen ibmar akar imakosuli?
\q2 Bede, ¿ibmar sogosurde? ¿Binsarsunna be bukib-binsaega anmar-imakode?
\c 65
\s1 Uayasulidamalad-odurdaklegoed
\p 
\v 1 Bab-Jehová soged:
\q1 “Dule-an-egisdisurmaladse an magarosad, an doa-dule gue.
\q2 Dule-an-amidisurmalad an-amiega an imaksad.
\q1 Dule-baigan-an-nug-odummodisurmaladga, an sogsad,
\q2 wegi an gwichiye.
\q1 
\v 2 Dule-uayasulidamaladse, igar-isganaba-nadapmaladse, e-binsaedba-nanadimaladse,
\q2 bane-bane, an-argan an oyomai gusanad.
\q1 
\v 3 We-dulemar, bali-bali an-ourwega an-imakmalad.
\q2 Dutugalumargine, bab-dummadyob-ibmar-imaklemaladga ibmar ukmalad.
\q2 Ibmar-ogumakar-ukleged-ailamargi, ina-wawadikmalad ogumakmalad.
\q1 
\v 4 We-dulemar, neg-uangi sigmalad,
\q2 mutikidbali, dukuar oibosii damalad.
\q1 Sin-san gundamalad,
\q2 e-esmedmargi ibmar-nis-isgana dudamalad.
\q1 
\v 5 We-dulemar sogmalad: ‘¡Be anmargi bannabagudii samalo!
\q2 ¡Melle be anmarse walikaa gumalo!’
\q2 An bemarba bela-bela dule-islidikid gued.
\b
\q1 ”We-dulemar, waayobi gwen-nabir-ito an-asu-imaksulid,
\q2 bane-bane soo-duurmaksiiyob gued.
\q1 
\v 6 An-asabin bela e-ibmar-imaked narmakar naid, an sunmaksuli guosulid.
\q2 An sabsur-odurdakoed, na nunmak itomaloed.”
\p 
\v 7 Bab-Jehová soged:
\q1 “Bemar-isgued-ulale, degi, be-babgan isgusad-ulale, an sabsur-be-odurdakoed.
\q2 Ar we-dulemar yar-birgi ina-wawadikmalad-ogumakdii gusmalad,
\q1 yar-mullugangi angi-gwisgudii gusmalad.
\q2 Epenne e-ibmar imaksamaladba, na dukin sabsur-odurdaklemalaga an imakoed.”
\p 
\v 8 Bab-Jehová weyob soged:
\q1 “Dule-wargwen uva-san-dukgwen-nued-amisale, sogdaed:
\q2 ‘An oichogosurye, ar ade, amba nis nikaye.’
\q1 Deyopira, an an-maimar-sabed-ulale,
\q2 belamakale, an-maimar an obelogosulid.
\q1 
\v 9 Jacob waganmar-nikuega an imakoed,
\q2 Judáʼgi, dulemar-an-yarmar-gamaloedi, an onidagoed.
\q1 Anse-sulegarmaladi we-napaneg gamaloed,
\q2 a-napagine, an-maimar megmaloed.
\q1 
\v 10 An-dulamar-an-amidimaladga, Sarón-neba sibad-wawaad-galuga guoed,
\q2 Acor-neba-naidi, moli-bebe-nikamalad-galuga guoed.
\b
\q1 
\v 11 ”Ar bemar angi-banguddamaladdi, bemar an-yala-islidikid-ieddamaladdi,
\q2 es-suidgi-oburgwilegega an be-imakmaloed.
\q1 Bemar bab-dummad-ibmar-bukidar-ukedgala, degine, bab-dummad-deyob-guoye-sogmaidgala,
\q2 guagwar mas, degi, vino ukdamaladdi,
\q1 
\v 12 es-suidgi-oburgwilegega an be-imakbaloed.
\q2 Bela bemar dukar-egwallegega sindigar sigmaloed.
\q1 Ar an bemarse gochamalanad,
\q2 bemardi gwen an-abin-imaksasurmalad.
\q1 An bemarga sunmaksanad,
\q2 bemardi, gwen an-itossurmalad.
\q1 Aka bur an-asabin ibmar-isgana imaksamalad,
\q2 degi, an-ibmar-abesulidi bemar imaksabalid.”
\p 
\v 13 A-ulale, Bab-Jehová-Bur-Gangued-Nikad weyob soged:
\q1 “An-maimar mas-gunmaloed,
\q2 bemardi, ukudmaad gudigumaloed.
\q1 An-maimar gobed-nika gudimaloed,
\q2 bemardi, gobedsuli gudigumaloed.
\q1 An-maimardi, weligwar-itodii gumaloed,
\q2 bemardi, bingedar-itodii gumaloed.
\q1 
\v 14 An-maimar weligwaledgi namakmaloed,
\q2 bemardi, suli-suli-itogedgi binnasuli gormaloed,
\q2 nue wiles-itogedba akiginmaloed.
\q1 
\v 15 Anse-sulegarmaladi, emar-ukabsamalaga bemar-nug ebumaloed.
\q2 Ani Bab-Dummad-Jehová-Bur-Birigined bemar-oburgoed,
\q2 ar an-maimargardi, nug-baid an ukoed.
\q1 
\v 16 Dule, neggweburgi ise-nued-binsaleged egichialile, an-innikigwad-gued-nuggi egisoed.
\q2 Dule, neggweburgi ise-sogar-ibmar-imakalile, an-innikigwad-gued-nuggi imakoed.
\q1 Suli-suli-itolesadi, bela ielesad,
\q2 an-asabin an bela elisad.”
\s1 Nibneg-binid, napneg-binid
\p 
\v 17 Bab-Jehová weyob soged:
\q1 “Nue an-itomalo.
\q2 An nibneg-binid, napneg-binid, an obinyesokalid.
\q1 Ibmar-nasmalad bar obarilegosulid,
\q2 bar egi binsalegosurbalid.
\q1 
\v 18 An-ibmar-obinyesokalidba bur be weligwar-itomala,
\q2 degisadegu be yeer-itomala.
\q1 An Jerusalén-neggweburga yeer-itoged nasiksokalid,
\q2 an e-dulemarga weligwar-itoged uksokalid.
\q1 
\v 19 An Jerusalén-neggweburba, weligwar itogoed,
\q2 an-dulamarbo an yeer itogoed.
\q1 Jerusalénʼgi bar boed itolegosulid,
\q2 deginbali, suli-suli-itogedba-gormaked bar itolegosurbalid.
\b
\q1 
\v 20 ”Jerusalénʼgi mimmigan gwalulesale, bipigwadgi bar burgosurmalad,
\q2 deginbali, dadormar bar sapingwaa burgosulid, selebaa megmaloed.
\q1 Ar dule birga-dulatar-nika (100) burgwele, amba nuchukwaa burgwisye soglegoed.
\q2 Ar dule birga-dulatarse (100) warmaksasulirdi, dule-isganaye egi soglegoed.
\q1 
\v 21 An-dulamar, negmar sobmaloed, egi megmaloed.
\q2 Uva-dubmar digmaloed, e-san gunmaloed.
\q1 
\v 22 Dule-baid-megega neg bar sobosurmalad.
\q2 Deginbali, dule-bamalad uva-san-gunnega, uva-dubmar bar digosurmarbalid.
\q1 Ar an-dulamar-e-ibagan, sapimar-ibaganyob guoed.
\q2 Anse-sulegarmaladi, na e-ibmar-imakmaladgi yeer itomaloed.
\q1 
\v 23 Binsarsunna arbanai guosurmalad,
\q2 deginbali, mimmigan-wiogega, mimmigan nikuosurmalad.
\q1 An-dulamar na e-sunnagwad, degi, e-waganmoga,
\q2 Bab-Jehová egi ise-nued-binsasad-dulemarga guoed.
\q1 
\v 24 Anse-goled-iduale, ani an abinsaoed.
\q2 Amba sunmaknanaidgine, bato an itogoed.
\q1 
\v 25 Achu-sapur, sibad-wawaad-senigwadbo mas-gundii gumaloed.
\q2 Achumigur-nono-wawaad, moli-bebe-nikad-alugwasualedyob gagan-madii guoed,
\q2 degi, naibe unnila ukub-burubi madii guoed.
\q1 Bela an-yar-islidikidgine, dule, dule-baid-onailiksadii guosulid,
\q2 degi, ibmar-obelodii guosurbalid.
\q2 Ani an Bab-Jehová-guedi deyob soged.”
\c 66
\s1 Bab-Jehová-e-igar-naboged, degi, Sión-yala-gannar-sigoed
\p 
\v 1 Bab-Jehová weyob soged:
\q1 “Nibnega an-ologana gued,
\q2 napneg an-nag-onakwed gued.
\q1 ¿Ibi-neg be anga sunna sobsamarsunnale?
\q2 An-obunnoged-neg, ¿bia be anga sobmalosunna?
\q1 
\v 2 Ani Bab-Jehová soged: Ar belagwable we-ibmarmar ani an obinnisad,
\q2 deyobi nagunonikid.
\b
\q1 ”Ani an dule-wilemalad, dule-suli-suli-itodimalad,
\q2 degi, an-gayaburbaba binsaed-nika-nanadimalad, an yeer-daked.
\q1 
\v 3 Ar dulemar anga moli-bebe-nikad-machered ogumakar ukedi,
\q2 dule-gindakmaladyob gumalad.
\q1 Ar dulemar anga sibad-wawaad-senigana-oburgwedamaladi,
\q2 bab-dummadyob-imaklemaladga achu-nono-bisgar-ukmaladyob gumalad.
\q1 Ar dulemar anga ibmar-gwag ukdamaladi,
\q2 bab-dummadyob-imaklemaladga sin-ablis-ukdamaladyob gumalad.
\q1 Ar dulemar an-nug odummogega anga ina-wawadikid obupurmakdamaladi,
\q2 bab-dummadyob-imaklemalad-e-nug-odummomaladyob gumalad.
\q1 We-dulemar na dukin e-itolegedba igar susmalad,
\q2 e-ibmar-isgana-imakedgi na yeer itodimalad.
\q1 
\v 4 An ega sabsur-odurdakleged ukmogoed,
\q2 bela-belad-ibmar-dobmalad an egi barmidoed.
\q1 Ar an gochagua, gwen dule an-abin-imaksasulid.
\q2 Ar an sunmaksagua, gwen dule an-itossulid.
\q1 Aka bur an-asabin ibmar-isgana imaksamalad,
\q2 an-ibmar-abesulid imaksamarbalid.”
\b
\q1 
\v 5 Bemar Bab-Jehová-gayaburba-dobee-nanadimalad, Bab-Jehová-gayaburba be itomala:
\q2 “Be-gwenadgan-sae-be-dakdimaladi, degi, an-nug-ular-be-obandimaladi, dodoakwaa weyob sogmalad:
\q1 ‘Bab-Jehová, e-gargangued oyoge,
\q2 adi, anmar bemar-weligwar-itoged dakegar.’
\q2 Ar isdar-be-dakmaladdi bingegumaloed.”
\b
\q1 
\v 6 Neggwebur-akale, gayaburba binnasuli goled,
\q2 Bab-Dummadse-goled-neggi gayaburba goled:
\q1 “We-gaya, Bab-Jehová-gayaburba gued,
\q2 e-isdarmaladga sabsur-ibmar sognaid.”
\p 
\v 7 Bab-Jehová soged:
\q1 “Jerusalén, boni-itodaged-iduale, bato mimmi nikusad.
\q2 Jerusalén, yoo-bonigan-itodaged-iduale, goe-susugwa baksad.
\q1 
\v 8 ¿Doa weyob ibmar-soglege itodii?
\q2 ¿Doa weyob ibmar-oyolege dakdii?
\q1 ¿Ar dulemar-yargi-bukued ilagwen-bukuar bukusi?
\q2 ¿Ar neggwebur-gwagwen ukiagwale gwalulesi?
\q2 Degi-inigwele, Sión-yardi abga-bonigan-itoaliyalaba mimmigan nikusad.”
\p 
\v 9 Bab-Jehová soged:
\q1 “Ar ani an sikwi-aidegega imaked,
\q2 degite, ¿an geg sikwi-odegega imakde?
\q1 Ar ani an dula-nikuega-imaked,
\q2 degite, ¿an sikwimar-aideged-igar gaode?
\b
\q1 
\v 10 ”Bemar, Jerusalén-neggwebur-sabmaladi, Jerusalénʼba be weligwar-itomala,
\q2 e-ular, be yeer-itomala.
\q1 Bemar, Jerusalénʼba bukib-binsadimaladi, be weligwaledgi ichomakmala.
\q2 
\v 11 Ar Jerusalén-neggwebur nanyobi e-mamgi be-onumaloed, immerbaa be gumaloed.
\q1 E-nunis-ena-ena-nanaid immelegedse bemar gobmaloed,
\q2 egi be nue-yeer itomaloed.”
\p 
\v 12 Ar Bab-Jehová weyob soged:
\q1 “An Jerusalén-neggweburgi dii-nollosur-aryomaidyobi gwage-bogidikid nasikoed.
\q2 Dulemar-yar-baigangi-bukmalad-e-ibmar-nuegan diwar-engumaidyobi, Jerusalénʼga-ukega an imakoed.
\q1 Jerusalén, goemaryobi mamgi be-onumaloed,
\q2 e-sakwagi angaagwar be-semai guoed,
\q2 e-nukugi be-mesmaloed.
\q1 
\v 13 Nan igi na e-mimmi-gwage armake, deyobi an bemar-gwage armakoed.
\q2 Bemar Jerusalén-neggweburgi gwage armaklemaloed.”
\b
\q1 
\v 14 Bemar weyob ibmar-dakalile, gwagegi bemar weligwar itodmaloed,
\q2 gagan-aramakdedyobi bemar gannar gannaledmaloed.
\q1 Bab-Jehová e-maimar-abargi e-gangued oyogoed,
\q2 e-isdarmalad-abargi e-urwed oyogoed.
\q1 
\v 15 Bab-Jehová bato soo-abargi danikid.
\q2 E-bila-onoged-ur-napagined burwa-ooredyob dakleged.
\q1 Bab-Dummad, e-sae-itoged urwedgi oyononikoed,
\q2 e-sabsur-odurdaked soo-aramakwichiyob guoed.
\q1 
\v 16 Bab-Jehová, bela dulemarga soogi, degi, es-suidgi igar-nabogoed.
\q2 Bukidar Bab-Jehováʼse burgwemaloed.
\p 
\v 17 Bab-Jehová soged: “Dulemar-san-islidik-imakmaladi, degi, san-swilidik-imakmaladi, dule-negabargi-nadapidba nadapmalad, adi, bab-dummadyob-imaklemalad-dudumar-galuse-dogega. Bela-wemar na mesa burgwemaloed. Dulemar-sin-gunmalad, nusa-gunmalad, degi, ibmar-baigan-isemalad-gunmalad, bela-mesa bergumaloed.
\p 
\v 18 ”Ani, an e-ibmar-imaked-ulale, degi, e-binsaed-ulale, bela dulemar-yar-baid-baidgi-bukmalad, degi, gaya-akar-akar-sunmakmaladi oatosokalid. We-dulemar danimaloed. An-gangued-yeerdakleged dakmaloed.
\p 
\v 19 ”An ega wilub-oyogoed, abala dule dula-bemaloedi, we-yarmarse an barmidoed:
\q2 Tarsisʼse, Futʼse,
\q2 Ludʼse (we-dulemarde sigu-mied-dulemalad),
\q2 Tubalʼse, Javánʼse,
\q2 dikasur demar-gakaba-neggwebur-bukmalad an-nug-itodisurmaladse,
\q2 degi, an-gangued-yeerdakleged-dakdisurmaladse an barmidoed.
\p ”Wemala, dulemar-yar-baid-baidgi-bukmaladga, an-gangued-yeerdaklegedgi sunmakmaloed.
\v 20 Dulemar be-gwenadgan-yar-baid-baidgi-gudidimalad, an-yala-islidikid-Jerusalénʼse, anga ibmar-uklegedyobi seledagega imakmaloed:
\q2 Abala, molimargi be-gwenadgan-sedamaloed.
\q2 Bamaladdi, moli-ur-napagined-bila-onomaladgi,
\q2 e-gabmaladgi,
\q2 moli-uaya-senigwadmargi,
\q2 degi, moli-yargan-muremaladgi sedamaloed.
\p ”Ar igi-Israel-dulemar anse-goled-negse bormo-swilidikidgi anga ibmar-gwag-ukleged sedanidamala, deyobi, be-gwenadgan-sedamaloed. Ani Bab-Jehová deyob soged.
\p 
\v 21 ”We-be-gwenadgan-seledamaloedi, abala dule-irwa-anse-golemaladga, degi, Levita-dulemarga an suoed.
\v 22 Ar igi an-asabinni nibneg-gwapid, degi, napneg-gwapid degisadegu-nai-guoe, deyobi, be-waganmar degisadegu-bukwa an imakoed. Degi, bemar-nug degisadegumogoed. Ani Bab-Jehová deyob soged.”
\p 
\v 23 Bab-Jehová soged:
\q1 “Nii-binid-gwisgued-ilibali, degi, obunnoged-ibagan-ilibali, bela dulemar an-nug-odummodii gumaloed.
\q2 
\v 24 Ainidmaloed, geb dule-angi-gwisgusmalad-e-muigan omilede dakmaloed.
\b
\q1 ”Ar nus-e-san-gunnedi gwen burgosulid,
\q2 deginbali, soo-e-san-ogumaknaidi gwen ginnosurbalid.
\q2 Bela dulemarga ibmar-imadga guoed.”
