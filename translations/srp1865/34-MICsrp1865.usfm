\id MIC
\h Knjiga proroka Miheja
\toc1 Knjiga proroka Miheja
\toc2 Mihej
\toc3 Mih
\mt1 Knjiga proroka Miheja
\c 1
\s1 Opustošenje Jude i Izrailja zbog idolopoklonstva.
\p 
\v 1 Reč Gospodnja koja dođe Miheju Moresećaninu za vremena Joatama, Ahaza i Jezekije, careva Judinih, što vide za Samariju i za Jerusalim.
\b
\q1 
\v 2 Čujte, svi narodi,
\q2 slušaj, zemljo i šta je na njoj,
\q1 i Gospod Bog da vam je svedok,
\q2 Gospod iz svete crkve svoje.
\q1 
\v 3 Jer, gle, Gospod izlazi iz mesta svog,
\q2 i sići će, i hodiće po visinama zemaljskim.
\q1 
\v 4 I gore će se rastopiti pred Njim,
\q2 i doline će se rasesti,
\q1 kao vosak od ognja
\q2 i kao voda što teče niz strmen.
\q1 
\v 5 Sve je to za zločinstvo Jakovljevo
\q2 i za grehe doma Izrailjevog.
\q1 Koje je zločinstvo Jakovljevo?
\q2 Nije li Samarija?
\q1 Koje su visine Judine?
\q2 Nije li Jerusalim?
\q1 
\v 6 Zato ću učiniti od Samarije gomilu u polju
\q2 da se sade vinogradi,
\q1 i pobacaću kamenje njeno u dolinu
\q2 i otkriću joj temelje.
\q1 
\v 7 I svi rezani likovi njeni razbiće se,
\q2 i svi će se darovi njeni sažeći ognjem,
\q2 i sve ću idole njene potrti,
\q1 jer od plate kurvarske nakupi,
\q2 i opet će biti plata kurvarska.
\b
\q1 
\v 8 Zato ću plakati i ridati;
\q2 hodiću svučen i go,
\q1 plakaću kao zmajevi
\q2 i tužiću kao sove.
\q1 
\v 9 Jer joj se rane ne mogu isceliti,
\q2 dođoše do Jude,
\q1 dopreše do vrata mog naroda,
\q2 do Jerusalima.
\b
\q1 
\v 10 Ne javljajte u Gatu, ne plačite;
\q2 u Vit-Afri valjaj se po prahu.
\q1 
\v 11 Izađi, stanovnice safirska, s golom sramotom;
\q2 stanovnica sananska neće izaći;
\q2 žalost vet-ezilska neće vam dati stanka.
\q1 
\v 12 Jer stanovnica marotska tuži za svojim dobrom.
\q2 Jer siđe zlo od Gospoda do vrata jerusalimskih.
\q1 
\v 13 Upregni brze konje u kola, stanovnice lahiska,
\q2 koja si početak grehu kćeri sionskoj,
\q2 jer se u tebi nađoše zločinstva Izrailjeva.
\q1 
\v 14 Zato pošalji darove Moresetu gatskom;
\q2 domovi ahsivski prevariće careve Izrailjeve.
\q1 
\v 15 Još ću ti dovesti naslednika, stanovnice mariska;
\q2 doći će do Odolama, slave Izrailjeve.
\q1 
\v 16 Načini se ćelava i ostriži se za milom decom svojom;
\q2 raširi ćelu svoju kao orao,
\q2 jer se vode od tebe u ropstvo.
\c 2
\s1 Bol zbog bezbožnika koji u laži nalazi radost. Obricanje vremena milosti.
\q1 
\v 1 Teško onima koji smišljaju bezakonje
\q2 i o zlu se trude na posteljama svojim,
\q1 i kad svane izvršuju,
\q2 jer im je sila u ruci.
\q1 
\v 2 Žele njive, i otimaju ih;
\q2 žele kuće, i uzimaju;
\q1 čine silu čoveku i kući njegovoj,
\q2 čoveku i nasledstvu njegovom.
\q1 
\v 3 Zato ovako veli Gospod:
\q1 Evo, ja mislim zlo tom rodu,
\q2 iz kog nećete izvući vratove svoje,
\q1 niti ćete hoditi ponosito,
\q2 jer će biti zlo vreme.
\q1 
\v 4 U ono vreme govoriće se priča o vama,
\q2 i naricaće se žalosno govoreći:
\q1 Propadosmo;
\q2 promeni deo naroda mog.
\q1 Kako mi uze!
\q2 Uzevši njive naše razdeli.
\q1 
\v 5 Zato nećeš imati nikoga
\q2 ko bi ti povukao uže za žreb u zboru Gospodnjem.
\b
\q1 
\v 6 Nemojte prorokovati,
\q2 neka oni prorokuju;
\q1 ako im ne prorokuju,
\q2 neće odstupiti sramota.
\q1 
\v 7 O ti, koji se zoveš dom Jakovljev,
\q2 je li se umalio Duh Gospodnji?
\q1 Jesu li to dela Njegova?
\q2 Eda li moje reči nisu dobre onome koji hodi pravo?
\q1 
\v 8 A narod se moj pre podiže kao neprijatelj;
\q2 preko haljine skidate plašt s onih koji prolaze ne bojeći se,
\q2 koji se vraćaju iz boja.
\q1 
\v 9 Žene naroda mog izgonite iz milih kuća njihovih,
\q2 od dece njihove otimate slavu moju navek.
\q1 
\v 10 Ustanite i idite,
\q2 jer ovo nije počivalište;
\q1 što se oskvrni,
\q2 pogubiće vas pogiblju velikom.
\q1 
\v 11 Ako ko hodi za vetrom i kazuje laži govoreći:
\q2 Prorokovaću ti za vino i za silovito piće,
\q2 taj će biti prorok ovom narodu.
\q1 
\v 12 Doista ću te sabrati svog, Jakove,
\q2 doista ću skupiti ostatak Izrailjev;
\q1 postaviću ih zajedno kao ovce vosorske,
\q2 kao stado usred tora njihovog,
\q2 biće vreva od ljudstva.
\q1 
\v 13 Pred njima će ići koji razbija;
\q2 oni će razbiti i proći kroz vrata,
\q2 i izaći će;
\q1 i car će njihov ići pred njima,
\q2 i Gospod će biti pred njima.
\c 3
\s1 Kažnjavanje poglavica svetovnih i duhovnih. Proricanje o razorenju Jerusalima.
\q1 
\v 1 Zato rekoh:
\q2 Čujte, poglavice Jakovljeve
\q2 i knezovi doma Izrailjevog,
\q1 ne treba li vam znati šta je pravo?
\q2 
\v 2 Koji mrzite na dobro, a ljubite zlo,
\q1 sadirete kožu s njih i meso s kosti njihovih;
\q2 
\v 3 I jedete meso naroda mog
\q1 i sadirete kožu s njih i kosti im prebijate,
\q2 i sasecate kao u lonac i kao meso u kotao.
\b
\q1 
\v 4 Tada će vikati ka Gospodu,
\q2 ali ih neće uslišiti,
\q1 nego će sakriti lice svoje od njih u ono vreme,
\q2 kako oni zlo radiše.
\b
\q1 
\v 5 Ovako veli Gospod za proroke koji zavode moj narod,
\q2 koji grizu zubima svojim i viču: Mir;
\q2 i ako im ko ne da ništa u usta, dižu rat na nj.
\q1 
\v 6 Zato će vam utvara biti noć
\q2 i proricanje vaše tama;
\q1 i sunce će zaći tim prorocima
\q2 i dan će im se smračiti.
\q1 
\v 7 Tada će se postideti videoci,
\q2 i vračari će se posramiti,
\q1 i svi će zastrti usne svoje,
\q2 jer neće biti odgovora Božjeg.
\q1 
\v 8 Ali ja sam pun sile od Duha Gospodnjeg,
\q2 i suda i hrabrosti
\q1 da kažem Jakovu zločinstvo njegovo
\q2 i Izrailju greh njegov.
\b
\q1 
\v 9 Čujte ovo,
\q2 poglavice doma Jakovljevog
\q2 i knezovi doma Izrailjevog,
\q1 koji se gadite na pravdu,
\q2 i sve što je pravo izvrćete;
\q1 
\v 10 Koji gradite Sion krvlju
\q2 i Jerusalim bezakonjem.
\q1 
\v 11 Poglavari njegovi sude po mitu,
\q2 i sveštenici njegovi uče za platu,
\q2 i proroci njegovi gataju za novce,
\q1 a na Gospoda se oslanjaju govoreći:
\q2 Nije li Gospod usred nas?
\q2 Neće doći zlo na nas.
\q1 
\v 12 Zato će se s vas Sion preorati kao njiva,
\q2 i Jerusalim će postati gomila,
\q2 i gora od doma visoka šuma.
\c 4
\s1 O carstvu Mesijinom, povratak i izbavljenje Izrailja posle velike patnje.
\q1 
\v 1 Ali će u poslednja vremena biti utvrđena gora doma Gospodnjeg navrh gora
\q2 i uzvišena iznad humova,
\q2 i narodi će se sticati k njoj.
\q1 
\v 2 I ići će mnogi narodi govoreći:
\q1 Hodite, da idemo na goru Gospodnju
\q2 i u dom Boga Jakovljevog,
\q1 i učiće nas svojim putevima
\q2 i hodićemo Njegovim stazama;
\q1 jer će iz Siona izaći zakon
\q2 i reč Gospodnja iz Jerusalima.
\q1 
\v 3 I sudiće među mnogim narodima,
\q2 i pokaraće jake narode nadaleko,
\q1 i oni će raskovati mačeve svoje na raonike,
\q2 i koplja svoja na srpove;
\q1 neće dizati mača narod na narod,
\q2 niti će se više učiti ratu.
\q1 
\v 4 Nego će sedeti svaki pod svojom vinovom lozom i pod smokvom,
\q2 i neće biti nikoga da ih plaši;
\q2 jer usta Gospoda nad vojskama rekoše.
\q1 
\v 5 Jer će svi narodi hoditi svaki u ime boga svog;
\q2 a mi ćemo hoditi u ime Gospoda Boga svog
\q2 uvek i doveka.
\b
\q1 
\v 6 U to vreme, govori Gospod, sabraću hrome,
\q2 i skupiću odagnane i kojima zlo učinih.
\q1 
\v 7 I učiniću od hromih ostatak
\q2 i od odagnanih silan narod;
\q1 i Gospod će carovati nad njima na gori Sionu
\q2 odsada i doveka.
\b
\q1 
\v 8 I ti, kulo stadu, steno kćeri sionskoj,
\q2 tebi će doći,
\q1 doći će prva vlast,
\q2 carstvo kćeri jerusalimske.
\b
\q1 
\v 9 Zašto vičeš tako jako?
\q2 Nema li cara u tebi?
\q1 Eda li izgiboše tvoji savetnici,
\q2 te te obuzeše bolovi kao porodilju?
\q1 
\v 10 Muči se i viči, kćeri sionska,
\q2 kao porodilja,
\q1 jer ćeš izaći iz grada i stanovaćeš u polju,
\q2 i otići ćeš u Vavilon;
\q1 onde ćeš se osloboditi,
\q2 onde će te iskupiti Gospod iz ruku neprijatelja tvojih.
\b
\q1 
\v 11 A sada se sabraše na te mnogi narodi govoreći:
\q2 Da se oskvrni,
\q2 i da se oči naše nagledaju Siona.
\q1 
\v 12 Ali ne znaju misli Gospodnje,
\q2 niti razumeju namere Njegove,
\q2 jer ih je skupio kao snoplje na gumno.
\q1 
\v 13 Ustani i vrši, kćeri sionska,
\q2 jer ću ti načiniti rog gvozden,
\q2 i kopita ću ti načiniti bronzana,
\q1 te ćeš satrti mnoge narode,
\q2 i posvetiću Gospodu blago njihovo
\q2 i imanje njihovo Gospodu sve zemlje.
\c 5
\s1 O Hristovom mestu rođenja i carstvu milosti. Slava Izrailjeva i obraćanje.
\q1 
\v 1 Saberi se sada u čete, četnice,
\q2 opsedni nas,
\q2 neka biju prutom po obrazu sudiju Izrailjevog.
\q1 
\v 2 A ti, Vitlejeme Efrato,
\q2 ako i jesi najmanji među hiljadama Judinim,
\q2 iz tebe će mi izaći koji će biti Gospodar u Izrailju,
\q1 kome su izlasci od početka,
\q2 od večnih vremena.
\q1 
\v 3 Zato će ih ostaviti dokle ne rodi ona koja će roditi;
\q2 tada će se ostatak braće Njegove vratiti sa sinovima Izrailjevim.
\q1 
\v 4 I stajaće i pašće ih silom Gospodnjom,
\q2 veličanstvom imena Gospoda Boga svog;
\q1 i oni će nastavati,
\q2 jer će On tada biti velik do krajeva zemlje.
\q1 
\v 5 I On će biti mir;
\q2 kad dođe Asirac u našu zemlju,
\q2 i kad stupi u dvore naše,
\q1 tada ćemo podignuti na nj
\q2 sedam pastira i osam knezova iz naroda.
\b
\q1 
\v 6 I oni će opasti zemlju asirsku mačem
\q2 i zemlju Nevrodovu na vratima njegovim;
\q1 i On će nas izbaviti od Asirca
\q2 kad dođe u našu zemlju
\q2 i kad stupi na među našu.
\b
\q1 
\v 7 I ostatak će Jakovljev biti usred mnogih naroda
\q2 kao rosa od Gospoda i kao sitan dažd po travi,
\q2 koja ne čeka čoveka niti se uzda u sinove čovečje.
\q1 
\v 8 I ostatak će Jakovljev biti među narodima,
\q2 usred mnogih naroda,
\q1 kao lav među zverima šumskim,
\q2 kao lavić među stadima ovaca,
\q1 koji kad ide tlači i rastrže,
\q2 i nema nikoga da izbavi.
\q1 
\v 9 Ruka će ti se uzvisiti nad protivnicima tvojim
\q2 i svi će se neprijatelji tvoji istrebiti.
\b
\q1 
\v 10 I u ono ću vreme, govori Gospod,
\q2 istrebiti konje isred tebe i potrću kola tvoja.
\q1 
\v 11 I zatrću gradove u tvojoj zemlji,
\q2 i razvaliću sva tvrda mesta tvoja;
\q1 
\v 12 I istrebiću vračanje iz ruku tvojih,
\q2 i nećeš imati gatare;
\q1 
\v 13 I istrebiću likove tvoje rezane
\q2 i stupove tvoje isred tebe,
\q2 i nećeš se više klanjati delu ruku svojih;
\q1 
\v 14 I iskoreniću gajeve tvoje isred tebe,
\q2 i raskopaću gradove tvoje,
\q1 
\v 15 I izvršiću osvetu s gnevom i ljutinom
\q2 na narodima koji ne slušaše.
\c 6
\s1 Narodna nezahvalnost. Žrtva koja se svidi Gospodu. Žetva zle setve.
\q1 
\v 1 Slušajte šta govori Gospod:
\q2 Ustani, sudi se s gorama,
\q2 i neka čuju humovi glas tvoj.
\q1 
\v 2 Slušajte, gore i tvrdi temelji zemaljski,
\q2 parbu Gospodnju,
\q1 jer Gospod ima parbu s narodom svojim,
\q2 i s Izrailjem se sudi.
\b
\q1 
\v 3 Narode moj, šta sam ti učinio?
\q2 I čim sam ti dosadio?
\q2 Odgovori mi.
\q1 
\v 4 Jer te izvedoh iz zemlje misirske
\q2 i iskupih iz kuće ropske
\q2 i poslah pred tobom Mojsija, Arona i Mariju.
\q1 
\v 5 Narode moj, opomeni se šta naumi Valak car moavski
\q2 i šta mu odgovori Valam, sin Veorov,
\q1 od Sitima do Galgala šta bi,
\q2 da poznaš pravdu Gospodnju.
\b
\q1 
\v 6 Sa čim ću doći pred Gospoda
\q2 da se poklonim Bogu Višnjem?
\q1 Hoću li doći preda Nj sa žrtvama paljenicama?
\q2 S teocima od godine?
\q1 
\v 7 Hoće li Gospodu biti mile hiljade ovnova?
\q2 Desetine hiljada potoka ulja?
\q1 Hoću li dati prvenca svog za prestup svoj?
\q2 Plod utrobe svoje za greh duše svoje?
\q1 
\v 8 Pokazao ti je, čoveče, šta je dobro;
\q2 i šta Gospod ište od tebe
\q1 osim da činiš što je pravo
\q2 i da ljubiš milost
\q2 i da hodiš smerno s Bogom svojim?
\b
\q1 
\v 9 Glas Gospodnji viče gradu,
\q2 i ko je mudar vidi ime tvoje;
\q1 slušajte prut i Onog koji ga je odredio.
\q1 
\v 10 Nije li jošte u kući bezbožnikovoj blago nepravo?
\q2 I efa krnja, gadna?
\q1 
\v 11 Hoće li mi biti čist u koga su merila lažna
\q2 i u tobocu prevarno kamenje?
\q1 
\v 12 Jer su bogatuni njegovi puni nepravde,
\q2 i stanovnici govore laž,
\q2 i u ustima im je jezik prevaran.
\q1 
\v 13 Zato ću te i ja biti da oboliš,
\q2 pustošiću te za grehe tvoje.
\q1 
\v 14 Ti ćeš jesti, ali se nećeš nasititi,
\q2 i padanje tvoje biće usred tebe;
\q1 i sklanjaćeš, ali nećeš izbaviti,
\q2 i što izbaviš predaću maču.
\q1 
\v 15 Ti ćeš sejati, ali nećeš žeti;
\q2 ti ćeš cediti masline, ali se nećeš namazati uljem,
\q2 i mast, ali nećeš piti vino.
\q1 
\v 16 Jer se drže uredbe Amrijeve
\q2 i sva dela doma Ahavovog,
\q2 i hodite po savetima njihovim,
\q1 da te predam u pogibao,
\q2 i stanovnike njegove u podsmeh,
\q2 i nosićete sramotu naroda mog.
\c 7
\s1 Malo je pobožnih. Obricanje bogate božanske milosti posle kazne.
\q1 
\v 1 Teško meni!
\q2 Jer sam kao kad se obere letina,
\q2 kao kad se pabirči posle branja vinogradskog;
\q1 nema grozda za jelo,
\q2 ranog voća želi duša moja.
\q1 
\v 2 Nesta pobožnog sa zemlje
\q2 i nema pravog među ljudima,
\q1 svi vrebaju krv,
\q2 svaki lovi brata svog mrežom.
\q1 
\v 3 Da čine zlo obema rukama što više mogu,
\q2 ište knez;
\q1 i sudija sudi za platu,
\q2 i ko je velik govori opačinu duše svoje,
\q2 i spleću je.
\q1 
\v 4 Najbolji je između njih kao trn,
\q2 najpraviji je gori od trnjaka;
\q1 dan stražara tvojih,
\q2 pohođenje tvoje dođe,
\q2 sada će se smesti.
\q1 
\v 5 Ne verujte prijatelju,
\q2 ne oslanjajte se na vođu;
\q1 od one koja ti na krilu leži,
\q2 čuvaj vrata usta svojih.
\q1 
\v 6 Jer sin grdi oca,
\q2 kći ustaje na mater svoju,
\q1 snaha na svekrvu svoju,
\q2 neprijatelji su čoveku domaći njegovi.
\q1 
\v 7 Ali ja ću Gospoda pogledati,
\q2 čekaću Boga spasenja svog;
\q2 uslišiće me Bog moj.
\b
\q1 
\v 8 Nemoj mi se radovati, neprijateljice moja;
\q2 ako padoh, ustaću;
\q1 ako sedim u mraku,
\q2 Gospod će mi biti videlo.
\q1 
\v 9 Podnosiću gnev Gospodnji,
\q2 jer Mu zgreših,
\q1 dok ne raspravi parbu moju
\q2 i da mi pravicu;
\q1 izvešće me na videlo,
\q2 videću pravdu Njegovu.
\q1 
\v 10 Neprijateljica će moja videti,
\q2 i sram će je pokriti,
\q1 koja mi govori:
\q2 Gde je Gospod Bog tvoj?
\q1 Oči će je moje videti;
\q2 sada će se ona pogaziti kao blato na ulicama.
\b
\q1 
\v 11 U koje se vreme sazidaju zidovi tvoji,
\q2 u to će vreme otići zapovest nadaleko;
\q1 
\v 12 U to će vreme dolaziti k tebi
\q2 od asirske do tvrdih gradova,
\q1 i od tvrdih gradova do reke,
\q2 i od mora do mora,
\q2 i od gore do gore.
\q1 
\v 13 A zemlja će biti pusta sa stanovnika svojih,
\q2 za plod dela njihovih.
\b
\q1 
\v 14 Pasi narod svoj s palicom svojom,
\q2 stado nasledstva svog,
\q1 koje živi osamljeno u šumi,
\q2 usred Karmila;
\q1 neka pasu po Vasanu i po Galadu,
\q2 kao u staro vreme.
\q1 
\v 15 Kao u vreme kad si izašao iz zemlje misirske
\q2 pokazaću mu čudesa.
\q1 
\v 16 Narodi će videti
\q2 i postideće se od sve sile svoje;
\q1 metnuće ruku na usta,
\q2 uši će im zaglušiti.
\q1 
\v 17 Lizaće prah kao zmija;
\q2 kao bubine zemaljske drhćući izlaziće iz rupa svojih;
\q1 pritrčaće uplašeni ka Gospodu Bogu našem,
\q2 i Tebe će se bojati.
\b
\q1 
\v 18 Ko je Bog kao Ti?
\q2 Koji prašta bezakonje
\q2 i prolazi prestupe ostatku od nasledstva svog,
\q1 ne drži do veka gnev svoj,
\q2 jer Mu je mila milost.
\q1 
\v 19 Opet će se smilovati na nas;
\q2 pogaziće naša bezakonja;
\q2 bacićeš u dubine morske sve grehe njihove.
\q1 
\v 20 Pokazaćeš istinu Jakovu, milost Avramu,
\q2 kako si se zakleo ocima našim u staro vreme. 
