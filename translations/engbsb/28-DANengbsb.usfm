\m 
\v 4 \w Thus|strong="H1836"\w* \w the|strong="H3606"\w* administrators \w and|strong="H4430"\w* satraps \w sought|strong="H1934"\w* \w a|strong="H3068"\w* charge \w against|strong="H5922"\w* \w Daniel|strong="H1841"\w* \w concerning|strong="H5922"\w* \w the|strong="H3606"\w* \w kingdom|strong="H4437"\w*, \w but|strong="H6903"\w* \w they|strong="H1768"\w* \w could|strong="H1768"\w* find \w no|strong="H3606"\w* charge \w or|strong="H4430"\w* corruption, \w because|strong="H6903"\w* \w he|strong="H1768"\w* \w was|strong="H1934"\w* trustworthy, \w and|strong="H4430"\w* \w no|strong="H3606"\w* negligence \w or|strong="H4430"\w* corruption \w was|strong="H1934"\w* found \w in|strong="H5922"\w* \w him|strong="H5922"\w*.
\v 5 Finally these \w men|strong="H4437"\w* said, “\w We|strong="H1768"\w* \w will|strong="H1768"\w* never \w find|strong="H7912"\w* \w any|strong="H3606"\w* charge \w against|strong="H5922"\w* \w this|strong="H1932"\w* \w Daniel|strong="H1841"\w*, unless \w we|strong="H3068"\w* \w find|strong="H7912"\w* something \w against|strong="H5922"\w* \w him|strong="H5922"\w* \w concerning|strong="H5922"\w* \w the|strong="H3606"\w* law \w of|strong="H4437"\w* \w his|strong="H5922"\w* God.”
\b
\m 
\v 6 \w So|strong="H1768"\w* \w the|strong="H3606"\w* administrators \w and|strong="H1841"\w* satraps \w went|strong="H1841"\w* together \w to|strong="H5922"\w* \w the|strong="H3606"\w* king \w and|strong="H1841"\w* said, “\w O|strong="H3068"\w* King Darius, may \w you|strong="H1768"\w* live forever!
\v 7 \w All|strong="H5957"\w* \w the|strong="H5922"\w* \w royal|strong="H4430"\w* administrators, prefects, satraps, advisers, \w and|strong="H4430"\w* governors \w have|strong="H1868"\w* agreed \w that|strong="H5922"\w* \w the|strong="H5922"\w* \w king|strong="H4430"\w* \w should|strong="H4430"\w* establish \w an|strong="H4430"\w* ordinance \w and|strong="H4430"\w* enforce \w a|strong="H3068"\w* decree \w that|strong="H5922"\w* \w for|strong="H5922"\w* thirty days anyone who petitions any god \w or|strong="H4430"\w* man except \w you|strong="H5922"\w*, \w O|strong="H3068"\w* \w king|strong="H4430"\w*, \w will|strong="H4430"\w* \w be|strong="H5957"\w* thrown into \w the|strong="H5922"\w* den \w of|strong="H4430"\w* lions.
\v 8 \w Therefore|strong="H3606"\w*, \w O|strong="H3068"\w* \w king|strong="H4430"\w*, \w establish|strong="H6966"\w* \w the|strong="H3606"\w* decree \w and|strong="H4430"\w* sign \w the|strong="H3606"\w* document \w so|strong="H1768"\w* \w that|strong="H1768"\w* \w it|strong="H4481"\w* cannot be changed—\w in|strong="H6966"\w* accordance with \w the|strong="H3606"\w* law \w of|strong="H4481"\w* \w the|strong="H3606"\w* Medes \w and|strong="H4430"\w* Persians, \w which|strong="H1768"\w* cannot be repealed.”
\b
