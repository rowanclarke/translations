\id SNG - Gofa Full Bible Latin Version Final
\h Solomone Mazmure Maxaafa
\toc1 Solomone Mazmure Maxaafa
\toc3 Solo
\toc2 Solomone
\mt1 Solomone Mazmure Maxaafa
\imt1 Gaatha Qofa
\ip “Solomone Mazmure Maxaafa” geetetiya maxaafay siiqo ginxon xaafetida maxaafa. Ha ginxotape daro baggay mazmure maaran xaafetis. Ha ginxoti xaafetishe, addey maccasas, qassi maccasi addes xaafida ginxo. Ha maxaafay issi issi birshethatan “Siiqo Saba” woyko “Mazmuretape Aadhiya Mazmure” geetetees. Hara birshethan qassi “Solomone Mazmure” geetetidi eretees.
\ip Ha mazmurey dumma dumma ogen birshetishe gam7is. Issi issi asay, Kiristoosasinne woosa keethas giddon de7iya siiqo bessiya leemiso gidi qopoosona. Ayhudeti qassi, “Xoossasinne Isra7eele asaas giddon de7iya siiqo leemisota oykida maxaafa” goosona.
\ip Gidoshin, ha mazmurey adde giddoninne macca giddon de7iya siiqo mazmure. Issi mehe heemmiya panthay issi mehe heemmiya geela7iw demmanaw koyees (1:7-8). Enti banta mazmuriya wode wonto enti eketi geletiya wode enta ufaysay kumethi gidanaysa qoncisosona.
\iot Maxaafa Ayfe Qofata
\io1 Koyro Mazmure \ior (1:1—2:7)\ior*
\io1 Nam7antho Mazmure \ior (2:8—3:5)\ior*
\io1 Heedzantho Mazmure \ior (3:6—5:1)\ior*
\io1 Oyddantho Mazmure \ior (5:2—6:3)\ior*
\io1 Ichashantho Mazmure \ior (6:4—8:4)\ior*
\io1 Usupuntho Mazmure \ior (8:5-14)\ior*
\c 1
\p 
\v 1 Mazmure ubbaafe aadhiya Solomone mazmurey haysa.
\b
\s1 Geela7iw
\q1 
\v 2 Ne siiqoy woynepe aadhidi ufaysiya gisho
\q2 tana zaara zaara yeera.
\q1 
\v 3 Ne tiyetiya shittoy waanidi sawii!
\q2 Ne sunthay goggiya shitto mela;
\q2 Geela7oti nena siiqey hessasa.
\q1 
\v 4 Tana neera ekada ba; ane issife woxoos!
\q2 Kawaw, tana ne quruxuwan gelsa.
\b
\s1 Yerusalaame maccasata
\q1 Nenan nu ufaytoos;
\q2 ne siiquwa woyne ushshafe aathidi nashshoos.
\q2 Maccasi ubbay nena siiqeysa bessa.
\b
\s1 Geela7iw
\q1 
\v 5 Hinteno, Yerusalaame maccasato si7ite;
\q2 taani kareethi gidikoka mala lo77o.
\q1 Ta kareethatethay Qedaare dunkaane mela;
\q2 shin ta malay Solomone magarajota mela.
\q1 
\v 6 Ta malaa kareethiday awa;
\q2 taani kareethi gidida gisho tana boropite.
\q1 Ta ishati, ta aaye nayti taara ooyetidi,
\q2 tana woyne gade naagisidosona;
\q2 hessa gisho ta woyniya naagabike.
\q1 
\v 7 Ta siiquwaw, ane taw oda;
\q2 ne dorsaa wudiya awun heemmay?
\q2 Seeta gallas enta awun shempisay?
\q1 Nena demmanaw ne laggeta wudiya kaallada,
\q2 ayis guuluntada biya maccas gido?
\b
\s1 Panthaa
\q1 
\v 8 Maccasa ubbaafe lo77iyare,
\q2 Bessaa eronna ixiko dorsata geedo kaalla.
\q1 Ne deesha marata henthanchota
\q2 dunkaaniya matan heemma.
\b
\p 
\v 9 Ta siiqe! Gibxe kawo para gaareta goochiya,
\q2 parata giddon de7iya magaayeda lo77aasa.
\q1 
\v 10 Ne haythan de7iya alleequwara shiiqidi,
\q2 ne shakalay waanidi lo77i!
\q2 Ne qoodhey al7o shuchan alleeqetis.
\q1 
\v 11 Nuuni new biran cadetida,
\q2 worqa alleequwa oosisana.
\b
\s1 Geela7iw
\q1 
\v 12 Kawoy gayta bolla uttidashin,
\q2 ta shittuwa sawoy keethan tonku gis.
\q1 
\v 13 Ta siiqoy ta dhanthata giddon de7iya,
\q2 xuntetida sawiya karbe daanees.
\q1 
\v 14 Ta siiqoy, Engaada woyne gaden,
\q2 dolida heena ciishsha mela.
\b
\s1 Panthaa
\p 
\v 15 Ta siiqe, neeni waana lo77ay!
\q2 Neeni waana lo77ay!
\q2 Ne ayfeti holle ayfeda lo77oosona.
\b
\s1 Geela7iw
\q1 
\v 16 Ta siiquwaw, neeni waanna lo77ay!
\q2 Ayba ufaysay;
\q2 nu arsay cil7o maata mela ufaysees.
\q1 
\v 17 Nu keethaa tuussay ziga;
\q2 nu kaaray xiiddan oyketis.
\c 2
\s1 Geela7iw
\q1 
\v 1 Taani Saaronan doliya ciishshanne
\q2 zangaaran doliya suufe ciishsha mela.
\b
\s1 Panthaa
\q1 
\v 2 Ta siiqiya maccasa giddon be7iya wode,
\q2 aguntha giddon bentiya suufe ciishsha mela.
\b
\s1 Geela7iw
\q1 
\v 3 Ta siiqoy hara panthata giddon xeelliya wode
\q2 woran de7iya apile mithaa mela.
\q1 Tana daro ufaysin, iya kuyaa giddon uttas;
\q2 iya ayfey min tana mal7ees.
\q1 
\v 4 I tana gibira miya keethi gelsis;
\q2 ba siiquwa bandirada ta bolla dhoqu dhoqu oothis.
\v 5 Taani iya siiquwan oyketada hargida gisho,
\q2 zabibe ayfe muzidi tana gashtisite;
\q2 apile muzidi ta wolqaa minthite.
\q1 
\v 6 Ba haddirsa kushiya tana borkotisis;
\q2 ba ushacha kushiyan tana qoommis.
\q1 
\v 7 Hinteno, Yerusalaame yalaga maccasaw,
\q2 siiqoy baw dosidi dendana gakanaw,
\q2 iya hinte barkethonna mela,
\q2 ta hintena gen7eninne wora woshi7en ammatayis.
\p 
\v 8 Ta siiquwa girsay deriya bollara gupishenne,
\q2 zumaa bollara xongetishe yeysi si7etees.
\q1 
\v 9 Ta siiqoy woshi7e woyko gen7e mari daanees;
\q2 Heko, nu keethaa matan eqis;
\q2 maskootera soo xeellees;
\q2 magarajuwa giddora xeellees.
\q1 
\v 10 Ta siiqoy, haysada yaagees;
\q2 “Ta siiqe, denda!
\q2 Ta yegelsse, haaya, issife ane boos.
\q1 
\v 11 Heko, balgoy aadhis;
\q2 irayka eqis.
\q1 
\v 12 Biittan ciishshi ciiyis;
\q2 yethi yexiya ageenay gakis;
\q2 holle yethi nu biittan si7etis.
\q1 
\v 13 Balase mithay ayfe doomis;
\q2 woyney ciiyis;
\q2 ciishsha sawoy biittan tonku gees.
\q1 Ta siiqe, denda; ta yegelsse,
\q2 haaya; ane issife boos.”
\b
\s1 Panthaa
\q1 
\v 14 Aafo doonan zaalla qophon,
\q2 qosetida holle daaniyare;
\q2 ane issi toho tana ne som7uwa bessa;
\q2 ne girsa sissa.
\q1 Ne qaalay tana mal7ees;
\q2 ne som7oy daro lo77ees.
\b
\s1 Yerusalaame Geela7ota
\q1 
\v 15 Nu woyney ciiyis;
\q2 nu woyne gadiya iissiya workanata,
\q2 he guutha butaleta xihen oykite.
\b
\s1 Geela7iw
\q1 
\v 16 Ta siiqoy tabaa; taanika iyabaa;
\q2 ciishshata giddon I ba wudiya heemmees.
\q1 
\v 17 Sa7i geeyana gakanaw,
\q2 kuyay dhayana gakanaw,
\q2 ta siiquwaw, gen7eda woyko woshi7e marada,
\q2 aafotiya deriyara woxashe haa simma.
\c 3
\s1 Geela7iw
\q1 
\v 1 Qamma kumethi hiixan zin7ada,
\q2 ta siiquwa demmanaw amottas;
\q2 minthada koyas; shin demmabike.
\q1 
\v 2 Katamaa giddon de7iya dalganne
\q2 xuntha ogeta ubban yuuyas.
\q2 Ta siiquwa demmanaw koyas;
\q2 minthada koyas; shin demmanaw danda7abike.
\q1 
\v 3 Katamaa yuuyidi naageysati tana demmidosona;
\q2 taani, “Ta siiquwa be7idetii?” yaagada oychas.
\q1 
\v 4 Enta aggada aadhida mela ta siiquwa demmas;
\q2 I taape kessi ekonnaada minthada oykas.
\q1 Ta aaye soo efas;
\q2 ta yeletida kifiliya gelsas.
\q1 
\v 5 Hinteno Yerusalaame macca nayto,
\q2 siiqoy baw dosidi dendana gakanaw,
\q2 iya hinte barkisonna mela
\q2 taani hintena gen7eninne woshi7en ammatayis.
\b
\s1 Yerusalaame Geela7ota
\q1 
\v 6 Zal7ancho ixaanedanne karbeda sawiyara,
\q2 cuya tuussu daaniyara,
\q2 hanna mela biittafe yaara iya oonee?
\q1 
\v 7 Heko, Solomone para gaariya yawusu;
\q2 he para gaariw Isra7eelepe dooretida,
\q2 usupun tammu wolqaama tooranchoti ajabidosona.
\q1 
\v 8 Enti ubbay mashsha oythan meezetidosona;
\q2 olanka paacetidosona.
\q1 Qamma gakiya metuwa teqanaw,
\q2 enti mashshe dancidi giigidosona.
\q1 
\v 9 Kawa Solomoney para gaare giddon,
\q2 baw uttiya araata giigisis;
\q2 iya araatay Libaanosepe yida mithan oosetis.
\q1 
\v 10 Araata tuussay biran lanxetis;
\q2 zempoy worqan alleeqetis.
\q1 Oydey ocha teera daaniya qacinan kametis;
\q2 gaathay Yerusalaame geela7ota siiqon alleeqetis.
\b
\s1 Geela7iw
\q1 
\v 11 Hinteno, Xiyoone geela7oto,
\q2 kawa Solomone be7anaw haayite.
\q1 I daro ufaytida iya yaaganuwa gallas
\q2 iya aayiya iya huuphen wothida kallacha wothis.
\c 4
\s1 Panthaa
\p 
\v 1 Ta siiqe, neeni waana lo77ay!
\q2 Neeni waanida yegelsse!
\q1 Ne ayfeti guulunthaa giddora be7iya wode,
\q2 holleda lo77oosona.
\q1 Ne binaanay Galada zumaape
\q2 wodhiya deesha wude daanees.
\q1 
\v 2 Ne achay meedetidi haathan meecetida,
\q2 ubbay mente yeliya,
\q2 enta giddon awucayey bayna dorsa wude mela.
\q1 
\v 3 Ne mettershay zo7o qacina daanees;
\q2 ne haasaya wode daro ufaysoosona.
\q1 Ne nam7u shakalay guulunthaa giddora xeelliya wode,
\q2 nam7a kessidi phalqida oromaane daanosona.
\q1 
\v 4 Ne qoodhey loythi oothida,
\q2 iya bolla olanchota gondalley de7iya,
\q2 mukulu mino olanchota gondalley kaqetida,
\q2 Dawita adussa gimbiya daanees.
\q1 
\v 5 Ne nam7u dhanthati mente yeletida,
\q2 lo77o ciishshata giddon
\q2 miya woshi7e marata daanosona.
\q1 
\v 6 Sa7i geeyanaape sinthe,
\q2 dhumay kichanaape sinthe,
\q2 karbe deriyanne ixaane zuma bada shempana.
\q1 
\v 7 Ta siiqe, ne asatethay kumethi lo77o;
\q2 nenan boretiyabay baawa.
\q1 
\v 8 Ta mushurate, Libaanosepe haaya;
\q2 Gaammoy pee7iya, maahey aqiya,
\q1 Amaana zumaape, Sanira liiphepe
\q2 Armoona huuphiyape wodha.
\q1 
\v 9 Ta siiqe, micho gidida ta mushurate;
\q2 ne ayfiya xeeloynne ne qoodhiya alleeqoy,
\q2 ta wozanaa ufaysan gooshshis.
\q1 
\v 10 Ta siiqo micho gidida ta mushurate!
\q2 Ne siiqoy tana waani ufaysi!
\q1 Ne siiqoy woyne ushshafe aadhidi ufaysees;
\q2 ne shittoy ubbaafe aadhidi sawees.
\q1 
\v 11 Ta mushurate, ne mettershafe ililo eessi xokees;
\q2 Ne doonape eessinne maathi pultees;
\q2 ne ma7oy Libaanose shittoda sawees.
\q1 
\v 12 Ta siiqo micho gidida ta mushurate,
\q2 ne yuushoy diretidi naagetiya atakilte bessa mela;
\q2 ne haratas gordetida, taw dooyetida pulto mela.
\q1 
\v 13 Neeni atakilte giddon,
\q2 oromaaney, dooretida atakilte ayfeti,
\q2 nardoose geetetiya ayfeti de7iya bessa mela.
\q1 
\v 14 Nardoosey, laadey, sawiya maati, qarafin,
\q2 ixaanada sawiyabati de7oosona.
\q1 Karbey, godare uutha ciishshinne
\q2 dumma dumma qimame atakilteti doloosona.
\q1 
\v 15 Neeni atakilte bessa ushshiya pulto mela;
\q2 de7o haathi bentiya olla mela;
\q2 Libaanose zumaape goggiya shaafa mela.
\b
\s1 Geela7iw
\q1 
\v 16 Pudeha bagga carkuwaw, denda!
\q2 dugeha bagga carkuwaw, haaya!
\q1 Ta atakiltiya bolla carka!
\q2 iya sawoy tonku go.
\q1 Ta siiqoy ba atakiltiya giddo yo;
\q2 daro mal7iya ayfeta mo.
\c 5
\s1 Panthaa
\q1 
\v 1 Ta miche, ta mushurate,
\q2 taani ta atakiltiya giddo gelas.
\q1 Ta karbiyanne ta shitto ciishsha qoras;
\q2 taani eessa uythi mas;
\q2 ta woyniyanne ta maatha uyas.
\b
\s1 Yerusalaame Geela7ota
\b
\q1 Iya laggeto, miite uyite;
\q2 siiqo alana gakanaw uyite.
\b
\s1 Geela7iw
\b
\q1 
\v 2 Taani dhiskas; shin ta wozanay barkis;
\q2 ta siiqoy haysada yaagidi pengiya qonkishin si7as.
\q1 “Ta miche, ta siiqe, ta yegelsse;
\q2 borey bayna ta holle,
\q2 taw pengiya dooya.
\q1 Ta huuphey akan laakis;
\q2 ta binaanay qamma puusen irxis.”
\q1 
\v 3 Ta ma7uwa qaaras, zaarada ma7oyee?
\q2 Ta tohuwa meecetas, zaarada qitayoyee?
\q1 
\v 4 Ta siiqoy ibitha xoo7era ba kushiya soo yeddis;
\q2 ta wozanay iya gisho seellees.
\q1 
\v 5 Ta siiquwas dooyanaw dendas;
\q2 pengiya dooyanaw kobiya oykiya wode,
\q2 ta kushiyape karbey,
\q2 ta biradhiyafe shittoy xokees.
\q1 
\v 6 Ta siiquwas kariya dooyas, shin I deenna;
\q2 iya qaala si7anaw daro amottas.
\q1 Minthada koyas, shin iya demmabike;
\q2 xeegas, shin taw koybeenna.
\q1 
\v 7 Katamaa naageysati tana demmidi,
\q2 wadhidosona; madunxisidosona.
\q1 Katamaa dirsaa naageysati,
\q2 ta laxana qaari ekidosona.
\q1 
\v 8 Hinteno, Yerusalaame geela7oto,
\q2 ta siiquwa demmiko,
\q2 taani iya siiquwan hargidaysa,
\q2 hadara iyaw odite.
\s1 Yerusalaame Geela7ota
\q1 
\v 9 Neno, maccasa ubbaafe lo77iyara,
\q2 ne laggey haratape waanidi dummatii?
\q1 Neeni nuna hadara gey,
\q2 I haratape aybin dummatii?
\s1 Geela7iw
\q1 
\v 10 Ta siiqoy mala lo77onne ayanta;
\q2 tammu mukulu addeta giddon iya meli baawa.
\q1 
\v 11 Iya huuphey al7o worqa daanees;
\q2 iya binaanay lo77onne quuro mela kareethi.
\q1 
\v 12 Iya ayfey shaafa matan eqida,
\q2 maathan meecetida holleta daanees.
\q1 
\v 13 Iya shakalay sawiya qimamey toketida madabeda lo77ees;
\q2 iya mettershay karbe shittoy xokiya wora ciishshada lo77ees.
\q1 
\v 14 Iya qesey al7o shuchan alleeqetida worqa xam7ada lo77ees;
\q2 iya asatethay sanpare al7o shuchan alleeqetida dangarsa zaale mela.
\q1 
\v 15 Iya tohoti worqa baason eqida salo shucha tuussi daanosona;
\q2 iya malay zigan alleeqetida Libaanose zuma mela.
\q1 
\v 16 Iya doonay eessada mal7ees;
\q2 iya kumetha asatethay lo77ees.
\q1 Hinteno Yerusalaame geela7oto,
\q2 ta siiqoynne ta laggey haysa daannes.
\c 6
\s1 Yerusalaame Geela7ota
\q1 
\v 1 Maccasa ubbaafe lo77iyare, ne laggey awu bidee?
\q2 Nu neera koyana mela I bida gina nuus oda.
\b
\s1 Geela7iw
\q1 
\v 2 Ta siiqoy dorsa wude heemmanaw,
\q2 lo77o ciishsha shiishanaw,
\q2 shitto maatay de7iya atakiltiya giddo bis.
\q1 
\v 3 Taani ta siiquwaba; ta siiqoy tabaa;
\q2 I ciishsha giddon wude heemmees.
\b
\s1 Panthaa
\q1 
\v 4 Ta siiqe, ne Tirsa katameeda lo77aasa;
\q2 Yerusalaameda daro lo77aasa.
\q1 Bandira oykidi salpiya,
\q2 olanchoda yashshaasa.
\q1 
\v 5 Enti tana un7ethida gisho,
\q2 hayyana ne ayfiya taape dentha.
\q1 Ne binaanay Galada zumaape wodhiya,
\q2 deesha wude daanees.
\q1 
\v 6 Ne achay meecetidi keyiya,
\q2 ubbay mente yeliya,
\q2 enta giddon awucayey bayna dorsa wude mela.
\q1 
\v 7 Ne nam7u shakalay guulunthaa giddora xeelliya wode,
\q2 nam7u kessidi phalqida oromaane daanosona.
\q1 
\v 8 Usupun tammu macca kawoti,
\q2 hospun tammu laggethoti,
\q2 tayboy bayna geela7oti de7oosona.
\q1 
\v 9 Shin borey bayna ta holliya taw dumma;
\q2 iya ba aayes issinno.
\q1 Iyo yelida aayiya ubbaafe aathada iyo dosawusu;
\q2 Geela7oti iyo be7idi, “Hanna anjetidaaro” yaagosona;
\q2 macca kawotinne laggethoti iyo sabboosona.
\b
\s1 Yerusalaame Geela7ota
\q1 
\v 10 Hanna wonta xalqeda doliyara,
\q2 ageenada poo7iyara, xalqeda caddiyara,
\q2 bandira oykidi salpe keyida,
\q2 olanchoda yashshiyara hanna oonee?
\b
\s1 Panthaa
\q1 
\v 11 Taani zangaaran toketida mithata be7anaw,
\q2 woyney aacidako oromaaney ayfidaako xeellanaw,
\q2 duge ocholone gade wodhas.
\q1 
\v 12 Ta qoponna de7ishin ta amoy tana efidi,
\q2 kawa asaa para gaareta giddon tana utisis.
\b
\s1 Yerusalaame Geela7ota
\q1 
\v 13 Neno Sulaamape yidaare, haaya; haa simma;
\q2 Nu nena loythidi xeellana mela haa simma.
\b
\s1 Geela7iw
\q1 Daro asaa sinthan yexiya asada,
\q2 tana ayis xeelleetii?
\c 7
\s1 Panthaa
\q1 
\v 1 Kawo na7ada lo77iyare,
\q2 Laxana caamma aathida ne tohoti waani lo77i!
\q1 Ne sheechey hiillanchoy qoxidi,
\q2 alleeqisida al7o shuchu daanees.
\q1 
\v 2 Ne gul7ay woyney kumida birille daanees;
\q2 ne xeessa yuushoy ciishshan qashetida giste mirqe daanees.
\q1 
\v 3 Ne dhanthati mente yeletida,
\q2 gen7e mari daanosona.
\q1 
\v 4 Ne qoodhey dangarsa zaalen
\q2 alleeqetida adussa shako mela.
\q1 Ne ayfey gita Haseboona katama pengiya matan,
\q2 de7iya zeero haatha daanees.
\q1 Ne siidhey Damasqoko zaaridi gimbida,
\q2 Libaanose gimbiya daanees.
\q1 
\v 5 Ne huuphey Qarmeloosa zuma daanees;
\q2 ne binaanay qacina xaathi daanees;
\q2 ne huuphiya dathay kawa ufaysees.
\q1 
\v 6 Ta siiqe, ne waanna lo77ay!
\q2 Ne waanida yegelsse!
\q2 Ne siiqoy tana waani ufaysi!
\q1 
\v 7 Ne geesay zamba daanees;
\q2 ne dhanthay zamba mor77e daanees.
\q1 
\v 8 Taani, “Zamba bolla keyana;
\q2 iya ayfiya maxana” yaagas.
\q1 Ne dhanthay woyne mor7e mela;
\q2 ne siidhiyara keya peenoy apileda sawees.
\q1 
\v 9 Ne doonape keyiya peenoy
\q2 lo77o woyne mela.
\b
\s1 Geela7iw
\q1 Hiza lo77iya woyne ushshay,
\q2 ne siiqe mettershafenne achafe giddora,
\q2 lepi gidi goggo.
\b
\s1 Geela7iw
\q1 
\v 10 Taani ta siiquwaba; ika tana amottees.
\q1 
\v 11 Ta siiquwaw, haaya;
\q2 katamaape keyidi gaxare boos;
\q2 nam7ay qamma yan aathana.
\q1 
\v 12 Wonta guura woyne atakiltiya giddo boos;
\q2 woyney ciiyidaako, ayfe aathidako,
\q2 oromaaney ayfidaako ane be7oos.
\q1 Taani ta siiquwa nena yan bessaana.
\q1 
\v 13 Inkoye ayfe sawoynne
\q2 dumma dumma ufaysiya atakilte ayfey
\q2 nu karen kumis.
\q1 Ta siiquwaw! Ha ayfetape teeridaysanne
\q2 oorathi maxidaysa new wothas.
\c 8
\p 
\v 1 Ne taw ta aaye dhanthi dhammida
\q2 ta isha gididaako aybe!
\q1 Ta nena ogen demmada yeeridaako,
\q2 tana oonika borennashin.
\q1 
\v 2 Taani nena kaalethada,
\q2 tana tamaarsida ta aaye soo gelsarkinashin.
\q1 Mal7iya Oromaane gum7ethaanne
\q2 lo77iya woyne ushsha ta nena yan ushsharkina.
\q1 
\v 3 Tana ne haddirsa kushey borkotisees,
\q2 ne ushacha kushey tana qoommes.
\q1 
\v 4 Hinteno, Yerusalaame geela7oto,
\q2 ta siiqoy ba wode dendana gakanaw,
\q2 koyrottidi hinte iya denthonaada hadara gayis.
\b
\s1 Yerusalaame Geela7ota
\q1 
\v 5 Ba siiquwa hashen zempada,
\q2 mela biittafe yaara hanna oonee?
\b
\s1 Geela7iw
\b
\q1 Beni ne aayiya nena iqetada yelida,
\q2 apile mithaa garsan ne zin7idashin,
\q2 nena ta barkisas.
\q1 
\v 6 Merina siiquwan tana ne wozanan attama;
\q2 ne qesiyan maatameda ta xalaala oyka.
\q1 Siiqoy hayqo mela mino;
\q2 qanaatey si7oole mela iita;
\q2 iya lacoy Xoossaa tama laco mela.
\q1 
\v 7 Daro haathi siiqo tama toysanaw danda7enna;
\q2 di7oyka meeccidi efanaw danda7enna.
\q1 Asi siiqo shammanaw baw de7iya ubbaa immikoka,
\q2 siiqoy miishen shametonna gisho, asi iya kadhees.
\b
\s1 Geela7e Ishata
\q1 
\v 8 Dhanthi tiran uttiboona micha nuus de7awusu;
\q2 azini iyo oychiko, nu iw ay oothanee?
\q1 
\v 9 Iya gimbe dirsi gidiyako,
\q2 nuuni I bolla adussa bira gimbe gimbana;
\q2 iya dirsa penge gidiyako ziga ibithe medhana.
\b
\s1 Geela7iw
\p 
\v 10 Taani dirsa gimbe;
\q2 ta dhanthay gimbe bolla de7iya shako mela;
\q2 taani ta siiquwara de7iya wode I tanan ufaytees.
\q1 
\v 11 Solomones Ba7aal-Hamoonan woyne gadey de7ees;
\q2 he woyne gadiya une ootheysatas immis.
\q1 Kera ekidaysati ayfiya gisho,
\q2 issoy issoy mukulu bira iyaw ehoosona.
\q1 
\v 12 Shin taw ta buzo woyne gadey de7ees;
\q2 Solomone, neeni mukulu bira eka;
\q2 une ekidi ootheysati nam7u xeetu bira eko.
\b
\s1 Panthaa
\q1 
\v 13 Neno, atakiltiya giddon de7iya ta siiqe,
\q2 ne laggeti ne qaala si7anaw koyoosona;
\q2 ne qaala tanaka sissa.
\b
\s1 Geela7iw
\q1 
\v 14 Ta siiquwaw, taako elle ya!
\q2 shitto maatay doliya dereta bollara,
\q2 gupiya gen7e woyko woshi7e marada hana.
