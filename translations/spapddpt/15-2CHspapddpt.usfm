\v 23 Uzías descansó \w con|strong="H5973"\w* \w sus|strong="H1931"\w* antepasados, \w y|strong="H3588"\w* \w lo|strong="H1931"\w* \w sepultaron|strong="H6912"\w* \w en|strong="H5973"\w* un \w campo|strong="H7704"\w* \w de|strong="H3588"\w* \w sepultura|strong="H6900"\w* \w de|strong="H3588"\w* \w reyes|strong="H4428"\w*, \add no en los sepulcros reales\add*, \w porque|strong="H3588"\w* dijeron: \w Es|strong="H1931"\w* \w leproso|strong="H6879"\w*. \w En|strong="H5973"\w* \w su|strong="H1931"\w* \w lugar|strong="H8478"\w* \w reinó|strong="H4427"\w* \w su|strong="H1931"\w* \w hijo|strong="H1121"\w* Jotam.   
\c 27  
\s1 Reinado de Jotam en Judá  
\p
\v 1 Jotam tenía 25 \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* en Jerusalén 16 \w años|strong="H8141"\w*. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H2568"\w* su madre fue Jerusa, \w hija|strong="H1323"\w* \w de|strong="H2568"\w* \w Sadoc|strong="H6659"\w*.  
\v 2 \w Hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w recto|strong="H3477"\w* ante \nd \+w Yavé|strong="H3068"\+w*\nd*, según \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w hizo|strong="H6213"\w* su padre Uzías, \w excepto|strong="H7535"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* entró \w en|strong="H5750"\w* \w el|strong="H3605"\w* Santuario \w de|strong="H5750"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \w Sin|strong="H3808"\w* embargo, \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* seguía su acción \w hacia|strong="H6213"\w* \w la|strong="H3605"\w* corrupción.   
\p
\v 3 \w Él|strong="H1931"\w* \w edificó|strong="H1129"\w* \w la|strong="H1931"\w* \w puerta|strong="H8179"\w* superior de \w la|strong="H1931"\w* \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*, y construyó extensamente \w el|strong="H1931"\w* \w muro|strong="H2346"\w* de Ofel.  
\v 4 También \w edificó|strong="H1129"\w* \w ciudades|strong="H5892"\w* en la región montañosa de \w Judá|strong="H3063"\w* y construyó \w fortalezas|strong="H1003"\w* y \w torres|strong="H4026"\w* en los bosques.   
\p
\v 5 También tuvo \w guerra|strong="H3898"\w* \w contra|strong="H5921"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón, \w a|strong="H3068"\w* quienes derrotó. \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w año|strong="H8141"\w* \w los|strong="H1121"\w* amonitas \w le|strong="H1931"\w* \w dieron|strong="H5414"\w* 3,3 toneladas \w de|strong="H5921"\w* \w plata|strong="H3701"\w*, 2.200.000 litros \w de|strong="H5921"\w* \w trigo|strong="H2406"\w* \w y|strong="H5921"\w* 2.200.000 litros \w de|strong="H5921"\w* \w cebada|strong="H8184"\w*. \w Los|strong="H1121"\w* amonitas \w le|strong="H1931"\w* \w pagaron|strong="H7725"\w* también \w esto|strong="H2063"\w* \w en|strong="H5921"\w* \w el|strong="H1931"\w* \w segundo|strong="H8145"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H1931"\w* tercer \w año|strong="H8141"\w*.   
\p
\v 6 Jotam se fortaleció, \w porque|strong="H3588"\w* dispuso sus procedimientos \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w su|strong="H3588"\w* \nd ʼElohim\nd*.   
\p
\v 7 \w Los|strong="H5921"\w* demás \w hechos|strong="H1697"\w* \w de|strong="H5921"\w* Jotam, \w todas|strong="H3605"\w* sus \w guerras|strong="H4421"\w* \w y|strong="H5921"\w* sus procedimientos, \w ciertamente|strong="H2005"\w* están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.  
\v 8 \w Tenía|strong="H1961"\w* 25 \w años|strong="H8141"\w* \w cuando|strong="H1961"\w* comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* 16 \w años|strong="H8141"\w* en Jerusalén.  
\v 9 Jotam reposó \w con|strong="H5973"\w* sus antepasados, y lo \w sepultaron|strong="H6912"\w* \w en|strong="H5973"\w* la \w Ciudad|strong="H5892"\w* \w de|strong="H8478"\w* \w David|strong="H1732"\w*. \w Reinó|strong="H4427"\w* \w en|strong="H5973"\w* su \w lugar|strong="H8478"\w* su \w hijo|strong="H1121"\w* Acaz.   
\c 28  
\s1 Reinado de Acaz en Judá  
\p
\v 1 Acaz tenía 20 \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* 16 \w años|strong="H8141"\w* en Jerusalén, pero \w no|strong="H3808"\w* \w hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w recto|strong="H3477"\w* ante \nd \+w Yavé|strong="H3068"\+w*\nd* como \w David|strong="H1732"\w* su antepasado.  
\v 2 \w Anduvo|strong="H3212"\w* \w en|strong="H3212"\w* los \w caminos|strong="H1870"\w* de los \w reyes|strong="H4428"\w* de \w Israel|strong="H3478"\w* \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* \w imágenes|strong="H4541"\w* de \w fundición|strong="H4541"\w* de los baales.  
\v 3 Quemó incienso en \w el|strong="H1931"\w* \w valle|strong="H1516"\w* del \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Hinom \w y|strong="H1197"\w* pasó \w a|strong="H3068"\w* \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w* \w por|strong="H6440"\w* fuego, según las repugnancias \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w pueblos|strong="H1471"\w* \w que|strong="H1931"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* expulsó \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*.  
\v 4 También \w sacrificó|strong="H2076"\w* \w y|strong="H5921"\w* quemó incienso \w en|strong="H5921"\w* \w los|strong="H5921"\w* lugares \w altos|strong="H1116"\w*, \w en|strong="H5921"\w* \w las|strong="H5921"\w* colinas \w y|strong="H5921"\w* \w debajo|strong="H8478"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w árbol|strong="H6086"\w* \w frondoso|strong="H7488"\w*.   
\p
\v 5 \w Por|strong="H4480"\w* tanto, \nd \+w Yavé|strong="H3068"\+w*\nd* su \nd ʼElohim\nd* lo \w entregó|strong="H5414"\w* \w en|strong="H4480"\w* \w manos|strong="H3027"\w* \w del|strong="H4480"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* los sirios, quienes lo derrotaron \w y|strong="H1571"\w* le tomaron \w gran|strong="H1419"\w* número \w de|strong="H4480"\w* prisioneros \w que|strong="H4480"\w* llevaron \w a|strong="H3068"\w* \w Damasco|strong="H1834"\w*.  
\p \w Fue|strong="H1571"\w* \w también|strong="H1571"\w* \w entregado|strong="H5414"\w* \w en|strong="H4480"\w* \w manos|strong="H3027"\w* \w del|strong="H4480"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, quien lo derrotó \w con|strong="H4480"\w* \w gran|strong="H1419"\w* matanza.  
\v 6 Porque Peca, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Remalías \w mató|strong="H2026"\w* \w a|strong="H3068"\w* 120.000 \w hombres|strong="H1121"\w* en un solo \w día|strong="H3117"\w* en \w Judá|strong="H3063"\w*, \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w hombres|strong="H1121"\w* \w valientes|strong="H2428"\w*, por cuanto abandonaron \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w el|strong="H3605"\w* \nd ʼElohim\nd* \w de|strong="H1121"\w* sus antepasados.  
\v 7 También Zicri, un \w valiente|strong="H1368"\w* \w de|strong="H1121"\w* Efraín, \w mató|strong="H2026"\w* \w a|strong="H3068"\w* \w Maasías|strong="H4641"\w*, \w hijo|strong="H1121"\w* del \w rey|strong="H4428"\w*, \w a|strong="H3068"\w* \w Azricam|strong="H5840"\w*, \w mayordomo|strong="H1004"\w* del palacio, y \w a|strong="H3068"\w* Elcana, \w segundo|strong="H4932"\w* después del \w rey|strong="H4428"\w*.   
\p
\v 8 \w Los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* tomaron cautivos \w a|strong="H3068"\w* 200.000 \w de|strong="H1121"\w* \w sus|strong="H1992"\w* hermanos, \w mujeres|strong="H1323"\w*, \w hijo|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*. \w También|strong="H1571"\w* tomaron \w de|strong="H1121"\w* \w ellos|strong="H1992"\w* un \w gran|strong="H7227"\w* botín \w y|strong="H1571"\w* \w se|strong="H1992"\w* \w lo|strong="H1992"\w* llevaron \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w*.   
\p
