\v 29 Pues \w ellos|strong="H1992"\w* son tu \w pueblo|strong="H5971"\w* y tu \w heredad|strong="H5159"\w* \w que|strong="H5971"\w* \w sacaste|strong="H3318"\w* con tu \w gran|strong="H1419"\w* \w poder|strong="H3581"\w* y con tu \w brazo|strong="H2220"\w* \w extendido|strong="H5186"\w*.
\c 10
\s1 Las segundas tablas de la Ley
\p 
\v 1 En \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \nd \w Yavé|strong="H3068"\w*\nd* me dijo: \wj \w Lábrate|strong="H6458"\w* \w dos|strong="H8147"\w* \w tablas|strong="H3871"\w* \w de|strong="H6256"\w* piedra \w como|strong="H1931"\w* las \w primeras|strong="H7223"\w* y \w sube|strong="H5927"\w* \w a|strong="H3068"\w* Mí \w a|strong="H3068"\w* \w la|strong="H1931"\w* Montaña. \w Y|strong="H3068"\w* \w hazte|strong="H6213"\w* un arca \w de|strong="H6256"\w* \w madera|strong="H6086"\w*.\wj*
\v 2 \wj Yo escribiré \w sobre|strong="H5921"\w* esas \w tablas|strong="H3871"\w* \w las|strong="H5921"\w* \w Palabras|strong="H1697"\w* \w que|strong="H5921"\w* \w había|strong="H1961"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w primeras|strong="H7223"\w* \w tablas|strong="H3871"\w* \w que|strong="H5921"\w* \w quebraste|strong="H7665"\w*, \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w pondrás|strong="H7760"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* arca.\wj*
\p 
\v 3 Entonces \w hice|strong="H6213"\w* un arca de \w madera|strong="H6086"\w* de acacia. Labré \w dos|strong="H8147"\w* \w tablas|strong="H3871"\w* de piedra como las \w primeras|strong="H7223"\w* y subí \w a|strong="H3068"\w* la Montaña con las \w dos|strong="H8147"\w* \w tablas|strong="H3871"\w* en mi \w mano|strong="H3027"\w*.
\v 4 \w Él|strong="H5921"\w* \w escribió|strong="H3789"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w tablas|strong="H3871"\w*, \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w primera|strong="H7223"\w* \w escritura|strong="H4385"\w*, \w los|strong="H5921"\w* \w Diez|strong="H6235"\w* Mandamientos \w que|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w les|strong="H5921"\w* \w habló|strong="H1696"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* Montaña, \w desde|strong="H5921"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w del|strong="H5921"\w* fuego, \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* asamblea. \w Y|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H5921"\w* \w las|strong="H5921"\w* \w entregó|strong="H5414"\w*.
\v 5 Di vuelta, bajé \w de|strong="H4480"\w* la Montaña y \w puse|strong="H7760"\w* las \w tablas|strong="H3871"\w* \w que|strong="H4480"\w* \w hizo|strong="H6213"\w* \w en|strong="H4480"\w* \w el|strong="H6213"\w* arca. \w Y|strong="H3068"\w* \w allí|strong="H8033"\w* \w están|strong="H1961"\w*, \w como|strong="H1961"\w* \w me|strong="H4480"\w* \w ordenó|strong="H7760"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 6 Después \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H8478"\w* \w Israel|strong="H3478"\w* \w salieron|strong="H5265"\w* desde \w los|strong="H1121"\w* pozos \w de|strong="H8478"\w* Bené Jaacán \w hacia|strong="H8033"\w* Moserá. \w Allí|strong="H8033"\w* \w murió|strong="H4191"\w* Aarón y \w allí|strong="H8033"\w* \w fue|strong="H5265"\w* \w sepultado|strong="H6912"\w*. Eleazar su \w hijo|strong="H1121"\w* \w fue|strong="H5265"\w* constituido sumo sacerdote \w en|strong="H6912"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* \w él|strong="H1121"\w*.
\v 7 \w De|strong="H4480"\w* \w allí|strong="H8033"\w* \w salieron|strong="H5265"\w* \w a|strong="H3068"\w* Gudgoda, y \w de|strong="H4480"\w* Gudgoda \w a|strong="H3068"\w* Jotbatá, tierra \w de|strong="H4480"\w* torrentes \w de|strong="H4480"\w* \w agua|strong="H4325"\w*.
\v 8 \w En|strong="H5704"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \nd \w Yavé|strong="H3068"\w*\nd* separó \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w tribu|strong="H7626"\w* \w de|strong="H6440"\w* \w Leví|strong="H3878"\w* \w para|strong="H5704"\w* transportar \w el|strong="H1931"\w* Arca del \w Pacto|strong="H1285"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w a|strong="H3068"\w* fin \w de|strong="H6440"\w* \w que|strong="H1931"\w* estuviera \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w para|strong="H5704"\w* \w ministrarle|strong="H8334"\w* \w y|strong="H5704"\w* bendecir \w en|strong="H5704"\w* \w su|strong="H1931"\w* \w Nombre|strong="H8034"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*,
\v 9 \w por|strong="H5921"\w* \w lo|strong="H1931"\w* \w cual|strong="H1931"\w* \w Leví|strong="H3881"\w* \w no|strong="H3808"\w* \w tuvo|strong="H1961"\w* \w parte|strong="H2506"\w* \w ni|strong="H3808"\w* \w herencia|strong="H5159"\w* \w con|strong="H5973"\w* \w sus|strong="H1931"\w* hermanos. \nd \w Yavé|strong="H3068"\w*\nd* \w es|strong="H1931"\w* \w su|strong="H1931"\w* \w herencia|strong="H5159"\w*, \w como|strong="H5973"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w le|strong="H1931"\w* prometió.
\p 
\v 10 \w En|strong="H5975"\w* cuanto \w a|strong="H3068"\w* mí, permanecí \w en|strong="H5975"\w* \w la|strong="H1931"\w* Montaña 40 \w días|strong="H3117"\w* \w y|strong="H1571"\w* 40 \w noches|strong="H3915"\w* \w como|strong="H1571"\w* \w los|strong="H1931"\w* \w primeros|strong="H7223"\w* \w días|strong="H3117"\w*. \w También|strong="H1571"\w* \w esta|strong="H1931"\w* \w vez|strong="H6471"\w* \nd \w Yavé|strong="H3068"\w*\nd* me \w escuchó|strong="H8085"\w* \w y|strong="H1571"\w* desistió de \w destruirte|strong="H7843"\w*.
\v 11 \w Y|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* me dijo: \wj ¡\w Levántate|strong="H6965"\w*! \w Anda|strong="H3212"\w*, \w para|strong="H5414"\w* \w que|strong="H5971"\w* marches \w delante|strong="H6440"\w* del \w pueblo|strong="H5971"\w* con el fin \w de|strong="H6440"\w* \w que|strong="H5971"\w* entren y \w posean|strong="H3423"\w* la tierra \w de|strong="H6440"\w* la cual \w juré|strong="H7650"\w* \w dársela|strong="H5414"\w* \w a|strong="H3068"\w* sus antepasados.\wj*
\p 
\v 12 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w*, \w Israel|strong="H3478"\w*, ¿\w qué|strong="H3588"\w* \w te|strong="H3588"\w* \w pide|strong="H7592"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*? Solo \w que|strong="H3588"\w* \w temas|strong="H3372"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, \w que|strong="H3588"\w* \w andes|strong="H3212"\w* \w en|strong="H5973"\w* \w todos|strong="H3605"\w* sus \w caminos|strong="H1870"\w*, \w que|strong="H3588"\w* \w lo|strong="H4100"\w* ames \w y|strong="H3588"\w* sirvas \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w con|strong="H5973"\w* \w todo|strong="H3605"\w* tu \w corazón|strong="H3824"\w* \w y|strong="H3588"\w* \w toda|strong="H3605"\w* tu \w alma|strong="H5315"\w*,
