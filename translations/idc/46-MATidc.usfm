\id MAT - Ajigha
\toc1 Ila ididuma ka avọ IMatta
\toc2 IMatta
\toc3 IMat
\mt2 ILA IDIDUMA KA AVỌ
\mt1 IMATTA
\c 1
\s1 Ute IYesu
\r (ILuk 3.23-38)
\p 
\v 1 Awọ iwọọ iMusa ute iYesu iKristi, anọ iDauda, anga ute Ibrahim.
\li1 
\v 2 Ibrahim jee Ishaku,
\li2 Ishaku jee iYakubu,
\li2 IYakubu jee iYahuza kina anayuru nga,
\li2 
\v 3 IYahuza ate iFeresa kina iZera ayuru bọ nga shi iTama,
\li2 IFeresa nga shi ate iHesruna,
\li2 IHesruna nga shi ate Aram,
\li2 
\v 4 Aram nga shi ate Amminadab,
\li2 Amminadab nga shi ate iNashon,
\li2 INashon nga shi ate iSalmọn,
\li2 
\v 5 ISalmọn nga shi ate IBọ’aza, ayuru jee nga anga shi iRahab,
\li2 IBowaz nga shi ate Obida, ayuru nga anga shi iRut,
\li2 Obida nga shi ate iYesse,
\li2 
\v 6 IYesse nga shi ate agọm iDauda,
\li1 IDauda nga shi ate iSulemanu ayuru nga anga sa shi ayiri Uriya,
\li2 
\v 7 ISulemanu nga shi ate iRehobowam,
\li2 IRehobowam nga shi ate Abiya,
\li2 Abiya nga shi ate Asa,
\li2 
\v 8 Asa nga shi ate iYehoshafat,
\li2 IYehoshafat nga shi ate iYoram,
\li2 IYoram nga shi ate Azariya,
\li2 
\v 9 Azariya nga shi ate iYotam,
\li2 IYotam nga shi ate Ahaz,
\li2 Ahaz nga shi ate iHezekiya,
\li2 
\v 10 iHezekiya nga shi ate iManassa,
\li2 IManassa nga shi ate Amọn,
\li2 Amọn nga shi ate iYosiya,
\li2 
\v 11 IYosiya nga shi ate iYekoniya kina anayuru nga akyua mani ayẹri bu ki kya bu aBabila wu.
\li1 
\v 12 Aya kya bọ aBabila ni,
\li2 IYekoniya va jee iSheyaltiyel,
\li2 ISheyaltiyel nga shi ate iZarubabel,
\li2 
\v 13 IZarubabel nga shi ate Abihudu,
\li2 Abihudu nga shi ate Eliyakim,
\li2 Eliyakim nga shi ate Azuro,
\li2 
\v 14 Azuro nga shi ate iSaduku,
\li2 ISaduku nga shi ate Akimu,
\li2 Akimu nga shi ate Aliyudu,
\li2 
\v 15 Aliyudu nga shi ate Eliyazara,
\li2 Eliyazara nga shi ate iMatana,
\li2 IMatana nga shi ate iYakubu,
\li2 
\v 16 IYakubu nga shi ate iYusufu aghẹmẹ iMaryamu aghọmani ajee iYesu mani ayọrọ nga si iKristi.
\v 17 Ko kpaa kọ ute Ibrahim ki ta ka iDawuda, ite usho na inari yọ, kọ kpaa ka iDauda ki ta kọ uyẹri bọ ki kyaa aBabila ite usho ni inari yọ, kọ kpaa ki uyẹri bọ ka aBabila ki ta ka iKristi ite usho ni inari yọ.
\s1 Ujee iYesu iKristi
\r (ILuk 2.1-7)
\p 
\v 18 Umani ujee iYesu iKristi sa shi, ayuru nga iMaryamu akọ cira nga ki ma iYusufu, ata kọ takwyuẹ ni avasa nu nga na afo anga aghing Ọnọng.
\v 19 Ni aghẹmẹ nga iYusufu, aghọmani aka ju ima ushi na kikya, ata wang ọsa nga ighọng ba, na ava wang usheri nga ya naikẹr.
\p 
\v 20 Ashi kidẹ uwang uju kindọ ni, ba irishu, atuma Ọnọng va yeni ẹrẹkwyuẹ nga kidẹ amọgọ, ki tẹri si, “IYusufu, anọ iDauda, ma kọng ẹrẹbata ukpaa iMaryamu sa ayiri ngọ ba, ki imumani ishi kidẹ afo nga ni iba kukushi aghing Ọnọng ko.
\v 21 Aki jee anọ, ni ingọ ki ma nga uca si iYesu, ka aki foo ajiya kọ vulu bọ.”
\p 
\v 22 Uma ri ba kọ ma hwura umumani Ate aYaya tẹri ka anyu Atina nga,
\v 23 “Uwẹ ni, anayiri mani aye nga aghẹmẹ ba ki kpaa afo ka jee anọ anaghẹmẹ, na aki yọrọ nga si Immanuwel.” (Uwu shi si, Ọnọng shi ni yi).
\p 
\v 24 IYusufu ya shira kọ mor ni, ava ju kọnọ mani Atuma Ọnọng tẹri nga ni, A kpaa ayiri nga,
\v 25 ara ye ẹrẹnọma nga ba ki ta ko jee anọ. Ava ma nga uca si iYesu.
\c 2
\s1 Ọba Akyeng ki shii Iripiya
\p 
\v 1 Ajee iYesu ki ifọng aBaitalami ka aYahudiya, ka akyua agọm iHiridus, na ace aghọ uye ẹyẹrẹ ba ki shii iripiya ki ba Urushelima
\v 2 na aba wulu si, “Abi wọ ni anọ mani ajee ki tee agọm aYahudawa shi wọ? Iyi nu ẹyẹrẹ nga mani ikunu ka iripiya, ni iyi ba ki ma jọọ nga.”
\v 3 Agọm iHiridus ya kọng kindọ ni, ikwyi nga va bra yọ, kindọ wọ nọ ushẹ ajiya Urushelima.
\v 4 Aba curu nadidu agha kakọng afirist kina aghọmẹẹ umẹẹ iMusa ki wulu bọ, “Abi wọ ni aki jee aghọfoo wọ?”
\v 5 “Ki ifọng aBaitalami ki ẹrẹbọng aYahudiya,” Aba yira nga. “Ka umani aghọ pii kọ ọtọ Ọnọng wọọ wudu.
\v 6 ‘Ni ingọ aBaitalami kidẹ ẹrẹbọng aYahudiya, ki ba si ingọ shi aghọcẹẹ nọ ọjii ka ẹrẹgọm aYahuza ba, ka kidẹ ngọ yọ ni akwyite mani aki kyeng na ajiya Israila ki kunu wọ.’”
\v 7 Ni iHiridus ba yọrọ akyeng ọba ki shii iripiya kọ uyuyi ka kọng ka anyu bọ agọlọ mani ẹyẹrẹ nyeni wọ.
\v 8 Aba tuma bọ ka aBaitalami kina udi uwaga atọng “Ọkya kọ uya wang ọka mani anọ shi wọ nabibọrọ, insi inu peni ngaa ni, inu ba ki inu ba tẹri mi, ki imẹ ya kọ jọọ nga.”
\v 9 Aya kpẹẹ ọkọng upii agọm ni, ava wolu. Ẹyẹrẹ umani anu ki shii iripiya ra ni shi kite bọ, ni ibọ sọ yii yọ ki ta kọ umani iya tara kọ ọka mani anọ shi wọ.
\v 10 Aya nu ẹyẹrẹ ni, ava kọng ikwyifu nagigang.
\v 11 Aya ghila ọna ni, aba ya nu anọ kina ayuru nga iMaryamu, aba ta aghong ki jọọ nga. Aba wuli uma bọ, utii uyeri, kina ima uta ugha ọvọng, kina anyẹ ọvọng ki ma nga.
\v 12 Na ava vuu bọ ẹrẹbọng bọ ka uce utra, ka Ọnọng tẹri bọ ka amọgọ si ama vuu ukushi iHiridus ba.\fig Uba akyeng|alt="coming of the visitors" src="CN01641b.tif" size="col" loc="2:12" copy="cn" ref="2.12"\fig*
\s1 Uti ki kyaa aMasar
\p 
\v 13 Aya kọ uya ukadu ni, atuma Ọnọng ba kunu kidẹ amọgọ kushi iYusufu ki tẹri si, “IHiridus ki wang anọ ka pii wọ. Sisang, kpaa anọ kina ayuru nga kọ ti kọ kya nọ aMasar, kọ ya ci kọ ukadu si imẹ tẹri ngọ si ingọ sher.”
\v 14 IYusufu va sisang, ki kpa anọ kina ayuru nga, ki kya bu aMasar kina ating,
\v 15 kiya ci ki ta kọ ukpo iHiridus. Aju kindọ ka ahura imumani Ate tẹri ka anyu atina nga, “I yọrọ anọ mi wu ka aMasar.”
\s1 IHiridus sa si apili Ananọ Ọfisi kọ
\p 
\v 16 IHiridus ya kpẹlẹ si akyeng ra tee ni nga abo ni, ava sang anang. Ava sa si aya pili anọ aniraghẹmẹ aBaitalami kina irihoo anyi apai ki ta ka ataa ka akyua mani akpili kukushi akyeng ẹyẹrẹ kunu.
\v 17 Ọwe wu sa ni imumani aghọ pii kọ ọtọ Ọnọng Irimiya tẹri hwura,
\v 18 “A kọng ice ẹrẹwyuẹ ka aRama, ẹrẹwyuẹ ukukas kina ayiri. IRahila nga su nira ayiri kaya anọ nga. Ara kọng udoru ba, ka aku kpuru bu.”
\s1 Aghọjee iYesu vuu bọ aNazaret
\p 
\v 19 Utumu ukpo iHiridus, atuma Ate kunu iYusufu kidẹ amọ ka aMasar
\v 20 ki tẹri si, “Sisang, kpaa anọ kina ayuru nga ku kya nu ẹrẹbọng Israila, ka aghọmani awang pii anọ sọ shi bọ nọ ọkyuọ ba.”
\v 21 IYusufu va sisang ki kpa anọ kina ayuru nga ki vuu bọ ẹrẹbọng Israila.
\v 22 Ni iYusufu ya kọng si Akilayus tee agọm ka utumu ukpo ate nga iHiridus ka aYahudiya, ava kọng ẹrẹbata ọkyaa. Akọ waa iYusufu nga atọng ka amọ ava gẹni ki kyaa ẹrẹbọng aGalili,
\v 23 kiya vra ọna nga ki ice ifọng si aNazaret, ka ahwura upii aghọ pii kọ ọtọ Ọnọng si, “Aki yọrọ nga si agha aNazaret.”
\c 3
\s1 Umẹẹ IYahaya Aghila Iminimini
\r (IMar 1.1-8; ILuk 3.1-9; IYah 1.19-28)
\p 
\v 1 Ka akyua ra ni iYahaya aghila iminimini ba ọkọ taa ashi ka aYahudiya na atẹri upii Ọnọng.
\v 2 “Inu lọkpaa,” atẹri si, “Ka ẹrẹgọm ayaya ishi ayayo!”
\v 3 IYahaya nga shi ajiya mani Ishaya aghọ pii kọ ọtọ Ọnọng pii si, “Ace aghọ sọ taa akpa kidẹ ọkọ taa ashi, ‘Kyeri utra Ate ayaya; nawa nga itra ka kyeng!’”
\v 4 Uma iYahaya ni aju kina idang ọrahimi; aloru abugu nga kina edang, imila nga ni agiya yọ kina ẹrẹtọng.
\v 5 Ajiya Urushelima, kina anga aYahudiya, kina anga ahwo ẹrẹyẹma Urdun, aba ukushi nga.
\v 6 A tẹri avulu bọ, ava ju bọ iminimini bu na amusum ẹrẹyẹma Urdun.
\v 7 IYahaya ya nu ikir aFarisiyawa kina aSadukiyawa, aba si ama ju bọ iminimini, aba tẹri bọ si, “Inu iyọọ na kang! inga tẹri nu si ọki ti anang mani Ọnọng ki tuma?
\v 8 Uju uma mani uki nyeni ọlọkpaa nu.
\v 9 Uma kpaa ka inu tẹri si Ibrahim nga shi ate nu ba. Isọ tẹri nọ Ọnọng ki bra ukpa atighi ri ka tee anọ nga!
\v 10 Akperi nga sha ka a kẹri ashẹ ka akang; ọshẹ mani ura ma wu ikọlọ ba ni aki kpa wu ka taa kidẹ ugha.
\v 11 Iju nu iminimini kina amusum ki nyeni si inu lọkpaa, aghọmani aki ba ko utumu mi ni aki sumu nu kina aghing Ọnọng kina ugha. Aceri mi; ira maa mi ni ikpa akpọ nga ba.
\v 12 Ọfọọ upẹr nga shi ka avọ nga, aki pẹr ikir imila. Aki curu alkama nga ka sa ka afọ, ni ẹrẹwọọ ni aki ta ugha wọ ọnga mani ọki kpẹri wọ ba.”
\s1 Iminimini IYesu
\r (IMar 1.9-11; ILuk 3.21-22)
\p 
\v 13 Akyua ra ni iYesu ba ka aGalili ki ba ukushi iYahaya ka vọng Urdun ka ju nga iminimini.
\v 14 Ni iYahaya sheri ka tee ikwyi nga. “Imẹ shi mani uju mi iminimini,” IYahaya tẹri, “Uwe ni ingọ ba ukushimi ki iba ju nu iminimini!”
\v 15 Ni iYesu ba yira nga si, “Tara ni ushi kindi ka akyua ri. Kindi wọ ni iyi ki ju uma ọdọdọma mani Ọnọng wang kọ.” IYahaya va yira.
\v 16 Aya ju iYesu iminimini ni, aba kunu kidẹ amusum. Ayẹrẹmọọ va yemi nga, ava nu aghing Ọnọng na asọ shulu kina ikhimi ni na uta uyeri kaya nga.
\v 17 Ni ẹrẹyuẹ va tẹri ka ayaya, “Anọ mi wẹ, aghọmani ikwyi mi ka tọmọ wọ.”
\c 4
\s1 Ishẹẹ Mra IYesu
\r (IMar 1.12-13; ILuk 4.1-13)
\p 
\v 1 Aghing kyeng ni iYesu ki kyaa ni nga kọ ka ọta shi ki Ishẹẹ mra nga.
\v 2 IYesu la awii ishi nari ating na atinọng na asọ kpẹnẹ anyu, na ba kọng idafo.
\v 3 Ni Ishẹẹ va ba ukushi nga ki tẹri nga si, “Insi ingọ shi Anọ Ọnọng ni, tẹri atii ri ka tee ubiredi.”
\v 4 Ni iYesu va yira nga si, “Upii Ọnọng si, ‘Ba ọla imila yọ kiyuyu na ajiya ki lang kọ ba, si nu upii mani ukunu ukushi Ọnọng.’”
\v 5 Ni Ishẹẹ va kpaa iYesu ki kyaa ni nga Urshalima, ifọng upipar, akyo nga ka yaya ọna Ọnọng,
\v 6 ki tẹri nga si, Insi ingọ shi Anọ Ọnọng ni, funu ẹrẹbọng, ka upii Ọnọng si, ‘Ọnọng ki tẹri atuma nga kaya ngọ; aki go ngọ ni ivọ bọ, ki ifra ngọ ki kọng yọ ọlọ kaya atii ba.’”
\v 7 IYesu va yira nga si, “Upii Ọnọng tẹri si, ‘Ma mra Ate Ọnọng ngọ ba.’”
\v 8 Ni Ishẹẹ va kpaa nga ki kyaa ayaya ọpang utitugu ki nyeni nga nadidu ẹrẹgọm asing kina ujọọ bọ.
\v 9 “Nadidu ni iki ma ngọ,” Ishẹẹ tẹri nga si, “Insi uta aghong ki jọọ mi ni.”
\v 10 IYesu va tẹri nga si, “Sang ngọ, Ishẹẹ! Upii Ọnọng si, jọọ Ate Ọnọng ngọ ni yii nga kayu nga!’”
\v 11 Ni Ishẹẹ ba ya iYesu; atuma Ọnọng ba ki ma shẹ nga wọ.
\s1 IYesu kpẹnẹ Utina nga ka aGalili
\r (IMar 1.14-15; 15; ILuk 4.14; 15)
\p 
\v 12 IYesu kọng si iYahaya na asa nga kọ ubọọ iting ni, ava sang nga ki kyaa aGalili.
\v 13 Aya aNazaret, aya ci ka aKafarnahum, ifọng uhwo ẹrẹyẹma aGalili, ka ẹrẹbọng aZabaluna kina aNaftali.
\v 14 Aju kindi ka a hwura upii Ishaya aghọ pii kọ ọtọ Ọnọng tẹri,
\v 15 “Ẹrẹbọng aZabaluna kina ẹrẹbọng aNaftali, kọ utra ẹrẹyẹma ka uda ugha Urdun, aGalili ẹrẹbọng aghọmani ashi bọ aYahudawa ba!
\v 16 Ajiya mani ashi kidẹ iting ki nu uyeri ọghọghẹ. Aghọmani ashi ki ẹrẹbọng aghọ kpuru uyeri ki taa bọ.”
\v 17 Ko kpaa ka kyua ra ni iYesu lite nọ tẹri upii Ọnọng, “Inu lọkpaa, ka ẹrẹgọm ayaya tọ ayayo!”
\s1 IYesu Kyọ Yọrọ Atina Nga
\r (IMar 1.16-20; ILuk 5.1-11)
\p 
\v 18 IYesu sọ kyeng ka anyu ẹrẹyẹma aGalili, ava nu anayuru apai na asọ sa isha bọ, iSaminu mani ayọrọ nga si iBitrus kina anayuru nga Andarawus asọ fẹri isha bọ.
\v 19 IYesu va tẹri bọ si, “Inu yii mi, iki mẹẹ nu uhuri ajiya.”
\v 20 Kidẹ akyua, aba ya isha bọ ya ki yii nga.
\v 21 Ava kyeng ki ya nu ace anayuru apai, iYakubu kina iYahaya, anọ iZabadi. Ashi kidẹ ọgbọlọ kina ate bọ iZabadi, asọ kyeri isha bọ. IYesu va yọrọ bọ,
\v 22 kidẹ akyua ra, aya ọgbọlọ bọ kina ate bọ ki yii iYesu.
\s1 IYesu Lẹni na Adumu
\r (ILuk 6.17-19)
\p 
\v 23 IYesu ghila idẹ ọfọng aGalili, na mẹẹ kidẹ ọkọ takwyuẹ aYahudawa, na tẹri ila ididuma uka ẹrẹgọm Ọnọng, na lẹni ni idumu kina adumu.
\v 24 Ila nga kpa kwabi ki ẹrẹgọm aSuriya, ava ba nga kina adumu, asọ kọng ẹrẹnọma ni idumu ighi-ghọ, kina aghọ shi nọ Ushẹẹ, ni itehu, ni ushumu avọ, iYesu lẹni ni bọ.
\v 25 Ikir yii nga kọ kpaa ka aGalili kina ufọng ọshọ, ko kpaa ka Urushelima, aYahudiya, kina ushi bulu ẹrẹyẹma Urdun.
\c 5
\s1 Upii Ọnọng kaya ọpang
\p 
\v 1 IYesu ya nu ikir bajiya ni, ava kila nga aya ọpang, ki cica, atina nga curu ki ghẹmẹ nga,
\v 2 nava tee aghọmẹẹ bọ si.
\s1 Anyu Adaduma
\r (ILuk 6.20-23)
\q1 
\v 3 “Anyu adaduma ka aghọmani aye utaa bọ ọnga aghing upipar;
\q2 Ka ẹrẹgọm ayaya ni inga bọ wọ!
\q1 
\v 4 “Anyu adaduma ka aghọmani ashi kidẹ ikwyi ibibi;
\q2 Ọnọng ki sa bọ amusum ashuu!
\q1 
\v 5 “Anyu adaduma ka aghọ ọtọọng;
\q2 Aki peni asing!
\q1 
\v 6 “Anyu adaduma ka aghọmani ikwyi bọ shi
\q2 Ko ju uma mani Ọnọng wang,
\q2 Ọnọng ki ma bọ uwang ikwyi bọ!
\q1 
\v 7 “Anyu adaduma ka aghọmani ashi na ahwoo ajiya;
\q2 Ọnọng ki kọng ahwoo bọ!
\q1 
\v 8 “Anyu adaduma ka aghọmani ashi na ikwyi upipar;
\q2 Aki nu Ọnọng!
\q1 
\v 9 “Anyu adaduma ka aghọmani awang uci ọkyuọ;
\q2 Ọnọng ki yọrọ bọ si anọ nga!
\q1 
\v 10 “Anyu adaduma ka aghọmani asọ kọng
\q2 Ọlọ kaya ju aipang;
\q2 Ẹrẹgọm ayaya ni inga bọ wọ!
\p 
\v 11 “Anyu adaduma ka inu aghọmani acira nọ ki ma nọ ọlọ kiva tẹri atẹri kaya akwyi nu ka inu yii mi.
\v 12 Inu kọng ikwyifu kina utọmọ ikwyi, ka akyo nu ọka nọ ka ayaya. Kini kọ ni aghọ pii kọ ọtọ Ọnọng mani aba kite kọng ọlọ kọ.
\s1 Atọ kina Uyeri
\r (IMar 9.50; ILuk 14.34-35)
\p 
\v 13 “Inu bọ shi atọ asing. Insi atọ taa ididugọ wọ ni, ba utra mani aki vuu na ididugọ wọ ba. Ba ice ima ra aki bra uju ba sa nawu ka ajiya tinga.
\v 14 “Inu bọ shi uyeri asing. Ifọng mani avra kaya ọpang kara shọru wọ ba.
\v 15 Ba aghọmani aki ta ugha agbilimọ ka fuga ya ni ikọọ ba; sa na kyo ka ya ima uting, ka ma uyeri ki ko nga nu kidẹ ọna.
\v 16 Kindi wọ ni uyeri ngọ ta ka ajiya nu, ka nu uma udọdọma mani uju ka jọọ Ate ayaya.
\s1 Umẹẹ kaya Umẹẹ IMusa
\p 
\v 17 “Inu baa kpaa si imẹ ba ki ba cira umẹẹ iMusa wọ kina umẹẹ aghọ pii kọ ọtọ Ọnọng ba. Ita bami ki ma ucira wọ ba, sa ni isa ka umẹẹ bọ tee aipang.
\v 18 Aipang ni imẹ sọ tẹri nu, kọ ni ayaya kina asing ki sang wọ ni, ba ighang iyeng ko ẹzẹzẹ inga umẹẹ iMusa na ki cira wu ba sa akwikẹ hwura.
\v 19 Ni nadidu aghọmani ara yii umẹẹ ko ni ima ẹzẹzẹ umẹẹ iMusa ka va mẹẹ ace aghọ ka ju ba ni, aki tee aghọ ji kidẹ ẹrẹgọm ayaya. Ka da vọ ni, aghọmani ayii umẹẹ kiva mẹẹ ace aghọ ka ju ni, aki shi ni ẹrẹgọrọ ka ẹrẹgọm ayaya.
\v 20 Isọ tẹri nu, si, uta ko ghila ẹrẹgọm ayaya ni si aipang nu cẹri anga aghọmẹẹ umẹẹ iMusa kina aFarisiyawa uju uma mani Ọnọng wang.
\s1 Umẹẹ kaya Anang
\p 
\v 21 “Inu kọ kọng si atẹri ajiya ada kyua, ‘Inu ba pii ọkyuọ ba; aghọmani aju ni aki ju nga ashuwa
\v 22 Ni aikyuari ni imẹ tẹri nu, insi ushi kidẹ anang kina anayuru ngọ ni aki ju ashuwa, insi ingọ yọrọ anayuru ngọ si ‘Imu taa imumani aki ju wọ!’ aki kyaa ni ngọ ọka ashuwa, insi ingọ yọrọ anayuru abo uta ice ima, ọki ya ghila ngọ ugha.
\v 23 Insi uwang ma Ọnọng ighima kaya agoo ni usa shuni si anayuru ngọ go ngọ ki kwyi ni,
\v 24 Sheri uma ya kọ ya agoo, kya ko ya wang uci ọkyuọ na anayuru ngọ, ni ingọ tọ vuu kọ uba ma uma.
\v 25 “Insi ace aghọ yọrọ ngọ kọ ọka ashuwa ni, inu kpẹlẹ ace na akyua sọ shi wọ, kini uta fuma uka ashuwa. Insi uku fuma uka ni aki ma agha ashuwa, aghọmani aki ma agha la tẹng, ka ta ngọ ko ubọọ iting.
\v 26 Ukadu wu ni uki ci wu, aipang ni imẹ sọ tẹri nu, so ma imumani atẹri si uma nadidu.
\s1 Umẹẹ kaya Unyẹri na Ayiri Kọ Aghimi Aghọ
\p 
\v 27 “Inu ko kọng na tẹri si, ‘ma nyẹri na ayiri kọ aghimi aghọ ba.’
\v 28 Na aikuari ni tẹri nu, nadidu aghọmani akyọgọ ayiri na wang pẹni nga ni akọ nyẹri ni nga kidẹ ikwyi.
\v 29 Insi ica isighi avọ ilang sa ukpaa ni, woyu ko nawu! Uceri nu ta uka ẹrẹnọma uyeng ngọ kini mani nadidu ẹrẹnọma ngọ ghila ugha.
\v 30 Insi avọ ila ngọ sa ukpaa ni, kyua kọ naa wọ! Uceri nu taa avọ ayeng ni mani ẹrẹnọma ngọ ghila ugha.
\s1 Umẹẹ kaya Upighi Ubọgha
\r (IMat 19.9; IMar 10.11-12; ILuk 16.18)
\p 
\v 31 “Asa va tẹri si, ‘Aghọmani akla ayiri nga ni asọ wọ ka ma nga.’
\v 32 Ni aikuari ni tẹri nu, insi aghimi kla ayiri nga ni basi ko nyẹri na ace aghimi ba ni, ashi na avulu usa nga uvulu insi akya uce ubọgha ni; aghimi mani aya bọgha ni aju avulu.
\s1 Umẹẹ kaya Isuu
\p 
\v 33 “Inu ko kọng na tẹri agha ada akyua si, ‘Uma wura usuu nu ba, ni hura uta anyu imumani utẹri uki ju Ate ayaya.’
\v 34 Ni aikuari ni tẹri nu, ma suu kina ayaya ba insi uta anyu, ka uka ẹrẹgọm Ọnọng wu;
\v 35 ko asing, ka uka wuru ifra nga wu; ko Urushelima, ka ukushi ifọng agọm aghaghẹ.
\v 36 Ma suu kina ẹrẹkwẹ ngọ ba, ka uki bra ngọ tee ifilikwyi iyeng ki tee ififu ko isisu ba.
\v 37 Tẹri si ‘A’ ko ‘Kayi’; ushe uma ka hala ukushi Ishẹẹ wu.
\s1 Umẹẹ kaya ju Imumani Aju ngọ
\r (ILuk 6.29-30)
\p 
\v 38 “Inu ko kọng na tẹri si, ‘Insi agyo ngọ ki ica ni, ica yu nu ki to gyo, insi ayir yu ni, ayir nu ki to gyo.’
\v 39 Na aikuari ni tẹri nu, ma ju ajiya imumani aju ngọ ba. Insi ace aghọ gyo ngọ ka utuma ila ni, ma nga ọnga ipuruma ka kimi gyo.
\v 40 Insi ace aghọ kya ashuwa ngọ ka yira ngọ igbang ko ni, ma nga ima fuga ngọ.
\v 41 Insi aghọ shi ni ẹrẹkyuọ tẹri ngọ ukyeng imil iyeng ni, usọ kyeng upai.
\v 42 Insi ace aghọ wang ice ma ukushi ngọ ni, ma nga; insi ace aghọ wang ọta ice ma ni, ma nga.
\s1 Yoo Aghọ Tọrọ Ngọ
\r (ILuk 6.27-28; ILuk 6.32-36)
\p 
\v 43 “Inu ko kọng na tẹri si, ‘Yoo aghọ yoo ngọ, tọrọ aghọ tọrọ ngọ.’
\v 44 Ni aikuari ni tẹri nu si, yoo aghọ tọrọ ngọ nu shọr Ọnọng kaya aghọ ma ngọ ọlọ,
\v 45 ki ingọ tee anọ Ate ayaya. Aka sa ọnọng uta kaya agha ababi na adaduma ima ayeng, ki ma avuga ka aghọmani aka ju ima ididuma kina aghọ ka ju ima ibibi.
\v 46 Aki ju na nyi Ọnọng ki ma ngọ ọka ngọ insi yoo aghọ yoo ngọ wu ni? Ko aghọ yira agonu ka ju kindọ!
\v 47 Insi ingọ ka pii kina aghikyo ngọ ko ni, ikẹmbọ inu ju ki cẹri ace aghọ ko? Ko aghọmani ashi bọ aYahudawa ba ka ju kindọ!
\v 48 Kindọ ni inu tee aghọ kyeng na ki kya, kini mani Ate ayaya shi na kikya.
\c 6
\s1 Umẹẹ kaya Uma
\p 
\v 1 “Ma ju uma ọdọdọma ngọ kayaye ka ajiya nu ima nọ so ju ba. Insi uju uma ri kayaye ni, ba ngọ nu ọka kushi Ate ayaya ba.
\v 2 “Insi uma aghọ taa ice ma, ma yẹmi kayaye, kini aghọ ju ọngọ unu ica kidẹ ọkọ takwyuẹ aYahudawa kina aya itra. Aka ju ka ajiya jọọ bọ. Imẹ sọ tẹri nu aipang, akọ peni ọka bu nadidu wudu.
\v 3 Insi uma aghọ taa ice ma ni, ju ko tra mani aghọ avọ ila ngọ ki nọ ba.
\v 4 Ni uki shi ko uyuyi. Ni Ate ngọ, mani aka nu kuyuyi, ki ma ngọ ọka ngọ.
\s1 Umẹẹ kaya Upii nọ Ọnọng
\r (ILuk 11.2-4)
\p 
\v 5 “Insi upii nọ Ọnọng, ma ju kini aghọ ju unu ica ba! Aka sisang upii nu Ọnọng kidẹ ọkọ takwyuẹ aYahudawa kina itra, ka ajiya nu bọ. Imẹ sọ tẹri nu aipang, akọ ma bọ ọka bọ nadidu.
\v 6 Insi uki pii nọ Ọnọng ni, kya nu idẹ bọọ, fuga anyu bọọ ya, nu pii na Ate nu mani aka nu bọ nga ba, Ate aghọmani aka nu ima ju nu kuyuyi, aki ma ngọ ọka ngọ.
\v 7 “Insi uki pii nọ Ọnọng ni, ma tẹri ighang ta ẹrẹkwẹ nagigang ba, kini mani aghọ ju ipaa ka ju, A kpa si ọnọng bọ ki kọng bọ ka upii bọ nagigang.
\v 8 Ma ju kini bọ. Ate nu ye imumani inu wang nu so nu to yemi anyu ba.
\v 9 Ni, mani, ubu ka pii nọ Ọnọng we, ‘Ate yi ka ayaya, Ta ni ajọọ uca ngọ;
\v 10 ta ni ẹrẹgọm ngọ ba; ta ni imuwang ngọ na ju ka asing ri kini mani ishi ka ayaya.
\v 11 Mayi aidi imila mani iyi wang.
\v 12 Cira uvulu yi kọ, kini mani iyi kpa aghọmani avulu ni yi.
\v 13 Ma kyaa ni yi ọka mani aki mra yi ọnga shi umọọ, ni kyo yi ọka mani aghọ shi na aghing ababi shi bọ ya ba.’
\v 14 “Insi ingọ yira ọlọkpaa ajiya umani a vulu ngọ ni, Ate ngọ ka ayaya ki kọ yira ọlọkpaa.
\v 15 Insi uta yira ọlọkpaa ajiya ba ni, ni Ate ngọ ki cira ngọ uvulu mani uju nga ko ba.
\s1 Umẹẹ kaya Ugo Anyu
\p 
\v 16 “Insi inu sọ kpẹnẹ anyu, ma shigi ibate kini aghọ ju ọnga aghọ ju unu ica ka ba. Aka shigi ibate ka ajiya nu ni abọ sọ kpẹnẹ anyu. Imẹ sọ tẹri nu aipang, akọ yira ọka bọ nadidu.
\v 17 Insi inu sọ kpẹnẹ anyu ni, hwuru ubate nu ni coo anyẹ ka ẹrẹkwẹ nu,
\v 18 ka ajiya ma ye si inu sọ kpẹnẹ anyu ba sa Ate kayu nga, aghọmani aka nu bu nga ba, ki ye. Ate ngọ, aghọ ka nu uma mani uju kuyuyi, ki ma ngọ ọka ngọ.
\s1 Upeni ka Ayaya
\r (ILuk 12.33-34)
\p 
\v 19 “Ma kyọ upeni ngọ ka asing ri ba, ọka mani iriyi kina iriler ka bra wu, ayi ka giya ki yi.
\v 20 Ni, ucuru ace nu upeni ka ayaya, uka mani iriyi kina iriler ki bra wu ba, uka mani ba ayi mani aki giya kayi ba.
\v 21 Ka ikwyi ngọ ki sa shi uka mani upeni ngọ shi wu.
\s1 Uyeri Irinuma
\r (ILuk 11.34-36)
\p 
\v 22 “Ica yọ shi uyeri ẹrẹnọma. Insi ica ngọ shi ikyuọ ni, ẹrẹnọma ngọ nadidu ki shi yeri;
\v 23 insi ica ngọ ishi yu ikyọ ba ni, ẹrẹnọma ngọ ki shi kidẹ iting. Insi uyeri mani ushi kidẹ ngọ ni iting yu ni, ikwyi ngọ ki shi kidẹ iting nagigang!
\s1 Ọnọng ko Upeni
\r (ILuk 16.13; 12.22-31)
\p 
\v 24 “Ingọ ki shi ngọ agira ate ọna apai ba; ingọ ki tọrọ ngọ ace nu yoo ace; ingọ ki yii ace nu tili ace. Ingọ ki yii Ọnọng kina ọfe ba.
\v 25 “Ọko sa ni tẹri ngọ si, ma sa ikwyi kini imumani ingọ ki la ko nu sa ko ci akyuọ ba, ko imumani ingọ ki sọmọ ki ẹrẹnọma ngọ ba. Ka udu mani, ọkyuọ ra cẹri wu imila ba? Ẹrẹnọma ra cẹri wu imumani ọki sumu ba?
\v 26 Nu unung ka ayaya, aka ra pila bu ighọ ba, acuru bọ imila aka sa ka afọ ba; Ate nu ka ayaya ka ma bọ! Inu ra cẹri nu unung ni ẹrẹgọrọ ba?
\v 27 Inga kidẹ nu ki bra ukhimi awii ayeng kidẹ awii nga ka sọ duma wu nu umari?
\v 28 “Ni ikẹmbọ sa ni inu sọ duma wu nu uma ọsọmọ? Nu mani ufuru aghumu ka fonu, aka ju bu utina ba ko na akeri uma ọsọmọ ba.
\v 29 Ni tẹri nu ko agọm iSulemanu ma nu upeni nga ashi ni ima ọsọmọ ididuma kina ufuru iyeng ba.
\v 30 Ọnọng nga ka fuga ọbọng idẹ aghumu ima sumu ọbọng mani ushi kaidi ni ikyua nu huga bu, na ta ugha ko. Aki bra ọsọmọ nu uma ba? Inu aghọ uma aipang na zẹẹ!
\v 31 “Uma dama wu ba, ‘Abi wu ni imila mi ki ba wu? ko imu sa mi? Ko imu sumu mi?
\v 32 (Uma mani aghọ ju ipaa ba ka dama wu nu bu.) Ate nu ka ayaya ye si inu wang uma ri.
\v 33 Ni, inu wang uma mani ushi ọnga ẹrẹgọm Ọnọng ni imumani awang ni nu, aki ma nu ushe nu uma nadidu.
\v 34 Inu ma sa ikwyi ni kyua ba; ishi kini ọnga nga usa ikwyi. Ushi wu mani akhimi ace awii ọnga nga usa ikwyi ba ka shi ni ọnga nga usa ikwyi.
\c 7
\s1 Ba Ju Ace Aghọ Ashuwa ba
\r (ILuk 6.37-38; ILuk 6.41-42)
\p 
\v 1 Ba ju ace aghọ ashuwa ba, ka aba ju ngọ ba,
\v 2 ka ashuwa mani ọka ju ajiya ni, akọ ni aki ju nu. Ima umara mani inu mara wu ni, iyọ na aki mara nu kọ.
\v 3 Ikẹmbọ sa ni, ọka nu anibọng mani shi kidẹ ica anayuru ngọ ni ọka ra nu ngọ ukumu ọshẹ mani ushi kidẹ ica ngọ ba?
\v 4 Ya ni ingọ ki tẹri anayuru ngọ si ‘Tara, ni wo ngọ anibọng mani shi kidẹ ica ngọ,’ ingọ shi kina ukumu ọshẹ ughọghẹ kidẹ ica ngọ?
\v 5 Inu aghọ ju unu ica! Kpaa ukumu ọshẹ mani ushi kidẹ ica ngọ, ọsọ ta nu nabibọrọ anibọng shi kidẹ ica anayuru ngọ.
\v 6 “Ba ma ava imumani shi na pipar ba aki tee ni ngọ. Ba fẹni ikyọng ididuma nu ka alade ba ka aki tinga ka giya kọ.
\s1 Inu Wulu, Inu Wang, Inu Họra
\r (ILuk 11.9-13)
\p 
\v 7 “Wulu, ni inu ki yira; wang, inu ki peni; hura, na anyu bọọ ki yemi.
\v 8 Nadidu aghọmani awulu ki yira, aghọmani awang ki peni, anyu bọọ ki yemi aghọmani ahura.
\v 9 Ace aghọ ngọ mani ashi ate ki ma anọ nga utii insi awulu ubiredi?
\v 10 Ta ọki ma nga iyọọ insi awulu ngọ itagbo?
\v 11 Kini akakiya nu, uye ma anọ nu ima ididuma. Na sa tẹri si, Ate ayaya ki ma uma udọdọma ka aghọmani awulu nga!
\v 12 “Ju ajiya uma mani uwang si aju ngọ, udiwu nyeni umẹẹ iMusa kina ọnga aghọ pii kọ ọtọ Ọnọng.
\s1 Anyu Bọọ Ujii Na Aghaghẹ
\r (ILuk 13.24)
\p 
\v 13 “Ghila ka anyu bọọ azazẹ, ka anyu kyaa idẹ ugha shi ayayang utra shi na gbẹẹ, ajiya nagigang ka kyeng ya.
\v 14 Ni anyu kyaa ọkyuọ shi na jii ukyeng utra lọ, ajiya uwang wu shi na jii.
\s1 Ushi kini Ikọlọ nga
\r (ILuk 6.43-44)
\p 
\v 15 “Inu ci na zizal ka aghọ pii kọ ọtọ Ọnọng atẹri; aki ba nu kini atẹm bọ ni ka sing, kidẹ ni ava aghumu bọ.
\v 16 Inu ki ye bọ ka ighọ umumani aka ju. Akara kara ma yọ ikọlọ inabi ka ẹrẹnọma nga ba, ko ni uwe ma yọ ikọlọ ka ẹrẹnọma akara ba.
\v 17 Ko iligba ushi ọdọdọma ka ma ikọlọ ididuma, ọshẹ ububi ka to ma ikọlọ ibibi.
\v 18 Ushi ọdọdọma ki ma wu ikọlọ ibibi ba, ni ọshẹ ububi ki ma wu ikọlọ ididuma ba.
\v 19 Ọshẹ mani ọka ma wọ ikọlọ ididuma ba aki kpa wọ ka ta kidẹ ugha.
\v 20 Kindọ, inu ki ye aghọ pii kọ ọtọ Ọnọng atẹri ko uma uju bọ.
\s1 IYesu ta ye nu ba
\r (ILuk 13.25-27)
\p 
\v 21 “Ba nadidu aghọmani ayọrọ mi si, ‘Ate ọna, Ate ọna’ ki ghila ẹrẹgọm ayaya ba, sa aghọmani aju uma mani Ate ayaya wang bọ sa ju.
\v 22 Insi awii ashuwa ya ba ni, ajiya nagigang ki tẹri mi si, ‘Ate ọna, Ate ọna! Kidẹ nọ uca ngọ iyi tẹri upii Ọnọng, kidẹ nọ uca ngọ iyi wuli idir ushẹẹ kiva ju idir uma uwuli ica!’
\v 23 Ni imẹ ki tẹri bọ si, ‘Imẹ ta ye nu nga ba. Sang nu ukushi mi, inu ajiya akakiya!’
\s1 Agha Amira kina abo uvra
\r (ILuk 6.47-49)
\p 
\v 24 “Ni, aghọmani a kọng ighang upii mi ki yii yu ni ashi kini agha amara mani avra ọna nga kaya ọpang.
\v 25 Aviya nira ya, avọng tiya, uwuru ti ni ẹrẹkyuọ ko ọna. Ni ura pulu wu ba, ka avra kaya ọpang.
\v 26 “Nadidu aghọmani a kọng ighang upii mi na ra yii ba ni ashi kini abọ ajiya mani avra ọna nga kaya ikikee.
\v 27 Aviya nira ya, avọng ti ya, uwuru ti ni ẹrẹkyuọ ko ọna, uva pulu wu. Upulu wọ na gbrop!”
\s1 Ẹrẹgọrọ IYesu
\p 
\v 28 IYesu ya kpẹẹ utẹri uma ri ni, ikir majiya wọ ica ki ighọ umẹẹ nga.
\v 29 Ashii kini aghọmẹẹ umẹẹ iMusa ba; ni, amẹẹ kini ẹrẹgọrọ.
\c 8
\s1 IYesu Lẹni na Ajiya ushi nọ Ubili
\r (IMar 1.40-45; ILuk 5.12-16)
\p 
\v 1 IYesu ya shulu kaya ọpang ni, ikir bajiya yii nga.
\v 2 Ni, ace aghọ shi nọ ubili ba ukushi nga, ki ta agho kite nga, na tẹri si, “Ate, insi ingọ yira ni, ingọ ki bra usa mi ki imẹ ba na pipar.”
\v 3 IYesu ba nawa avọ ki piya nga, ki tẹri si, “Imẹ yira, ba na pipar.” Ba ubura akyua udumu ubili lẹni.
\v 4 IYesu ba tẹri nga si, “Nu! ba tẹri ace aghọ ba, nu kya, ko ya yeni ẹrẹkwẹ ngọ ukushi ifirist ka aya ma uma kọnọ umani umẹẹ iMusa yeni ni, ka ajiya kpẹlẹ si a lẹni ni nga.”
\s1 Uma Aipang ace Agara Aghina Akpọ
\r (ILuk 7.1-10)
\p 
\v 5 IYesu ya ghila aKafarnahum, ace agha aghaghẹ aghina akpọ peni nga ki shọr nga,
\v 6 “Aghọ ọna, agira mi yẹẹ ka aca nọ udumu shọmọ ika, asọ kọng ẹrẹnọma nagigang.”
\v 7 IYesu va tẹri nga si, “Imẹ ki ba ki ma lẹni ni nga.”
\v 8 Ni agha aghaghẹ aghina akpọ nga va yira iYesu si, “Ate ọna, Imẹ ta ma mi ni ingọ ba ọna mi ba, tọrọ kọ tẹri upii, agira mi ki lẹni.
\v 9 Ka imẹ ni avọ kina ẹrẹgọrọ ace aghọ wu ni imẹ shi wu, kina aghina akpọ kidẹ ivọ mi, imẹ wang tẹri adi aghọ si, ‘Kikyang’, Asọ kyaa, ace aghọni imẹ tẹri nga si, ‘Ba,’ Asọ ba, imẹ tẹri agira mi si, ‘Aju ima,’ Asọ ju.”
\v 10 IYesu kọng kindọ ni, ava wo ica ava tẹri aghọyii nga si, “Aipang, imẹ sọ tẹri nu, imẹ sọnọ kọ peni mi ighọ uma aipang ka Israila kindii ba.
\v 11 Imẹ sọ tẹri nu, ajiya na pam ki ba kọ kpaa kọ ushii uta ọnọng ki ta kọ ushii ukpaa ọnọng ka acica ọla imila kina Ibrahim, ni Ishaku, kina iYakubu ka ẹrẹgọm ayaya,
\v 12 aghọmani ashi anọ ẹrẹgọm ni aki fẹni bọ kidẹ iting. Kukadu wu ni aki ci kọnọ ghula ayir.”
\v 13 IYesu va tẹri agha aghaghẹ aghina akpọ si, “Wor, uki ba kọnọ uma aipang ngọ ni.” Agira nga va ba ọkyuọ kidẹ ana kyua.
\s1 IYesu Lẹni na Ajiya na pam
\r (IMar 1.29-34; ILuk 4.38-41)
\p 
\v 14 IYesu ya ghila ọna iBitrus ni, ava nu akẹri iBitrus na ayẹẹ, ẹrẹnọma nga furu wu.
\v 15 A piya avọ nga, ufuru Ẹrẹnọma kpẹẹ wu, ava sisang ki ma bọ imila.
\v 16 Kọnọ ughẹ ni, aba nga kina ajiya na pam aghọ shi nọ ushẹẹ, ava wuli aghing ababi kọ upii. Kiva lẹni na adumu nadidu.
\v 17 Uma ri ba ka ahwura upii Ishaya aghọ pii kọ ọtọ Ọnọng si, “A kpaa uta ọkyuọ kina idumu bayọ.”
\s1 Aghọ Wang Uyii IYesu
\r (ILuk 9.57-62)
\p 
\v 18 IYesu ya nu ajiya na pam ukushi nga ni, aba tẹri atina nga si abọ ba buu udaa ugẹẹ ighọ.
\v 19 Ni aghọmẹẹ umẹẹ iMusa ba ukushi nga ki tẹri nga si, “Aghọmẹẹ, imẹ ki yii ngọ kwabi ni ingọ kyaa.”
\v 20 IYesu va tẹri nga si, “Ava aghumu shi kina afọng, anurunu ayaya shi kina asọọ, uwe ni Anọ Ajiya shi kọnọ uka nyẹ ba.”
\v 21 Ace aghọ kidẹ atina nga va tẹri nga si, “Aghọ ọna, tara ni imẹ ya naa ate mi wu.”
\v 22 IYesu va tẹri nga si, “Yii mi, ya aghọ kpuru ka nira aghọ kpuru bọ kọ.”
\s1 IYesu Gẹr Uwuru
\r (IMar 4.35-41; ILuk 8.22-25)
\p 
\v 23 IYesu ya ghila idẹ ọgbọlọ ni, atina va yii nga.
\v 24 Ashi kidẹ ukyeng ni, uyuu avuwa nọ uwuru na ẹrẹkyuọ sang kidẹ ighọ, amusumu kọ ghila idẹ ọgbọlọ bọ ni uwang ghila wu idẹ na amusum, iYesu sọ umọọ.
\v 25 Aba kyaa kiya sang nga, ki tẹri si, “Foo ayọ, ate ọna; ayọ ki kpuru bọ.”
\v 26 Aba tẹri bọ si, “Ikẹmbọ sa ni inu hwiri ẹrẹbata, inu aghọ uma aipang na jẹẹ” Ava sisang ki gẹr uwuru kina ighọ, uka va kọmọ na kikir.
\v 27 Ajiya nga va wo ica, na tẹri si, “Iligba ighọ ajiya yẹ, ni uwuru kina ighọ kọng upii nga?” \fig IYesu dara uwuru|alt="Jesus calm the storm" src="cn02044B.tif" size="col" loc="8:27" copy="cn" ref="8.27"\fig*
\s1 IYesu Lẹni na Agha Apai Ushẹẹ
\r (IMar 5.1-20; ILuk 8.26-39)
\p 
\v 28 Aya fuma udaa ugẹẹ ẹrẹbọ aGarasinawa ni, agha apai aghọ shi nọ ushẹẹ ba peni nga, akunu kidẹ na alọr, igigra bọ sa ni ajiya ka bra bọ ukyeng kọ utra ba.
\v 29 Ba irishu, aba gyo akpa, asi, “Ikẹmbọ duma ngọ ni ayọ, Anọ Ọnọng? Ingọ ba kọ ba ma ayọ ọlọ na kyua kọ ju wu ba?”
\v 30 Kina anikang na ji idir alade sọ cee.
\v 31 Ushẹẹ nga va shọr nga, si, “Insi ingọ woo ayọ ni, sa ayọ kidẹ idir alade ri.”
\v 32 Ava tẹri bọ si, “Inu kya nu.” Aba kunu kiya ghila bọ idẹ idir alade, ni, idir alade va ti ki shulu idẹ ighọ ki kpuru bọ kidẹ na amusum.
\v 33 Aghọcee alade va ti bọ, ki ghila idẹ ifọng kiya tẹri kwikẹ imumani iba kina ajiya ushi nọ ushẹẹ.
\v 34 Ajiya ifọng nadidu va kunu ki ma peni iYesu, aya nu nga ni, aba shọr nga si aya bọ ifọng bọ.
\c 9
\s1 IYesu kpa Uvulu ki Lẹni na Aghọ Shọmọ Avọ
\r (IMar 2.1-12; ILuk 5.17-26)
\p 
\v 1 IYesu ghila idẹ ọgbọlọ ki buu kyaa udaa ugẹẹ ighọ ka kyaa ifọng nga,
\v 2 ukadu ni, ace ajiya ba nga kina aghọmani akọ shọmọ nga, ayẹẹ kaya icuru. IYesu ya nu uma aipang bọ ni, aba tẹri aghọ shọmọ ika si, “Kpẹnẹ ikwyi ngọ, anọ mi; A cira uvulu ngọ kọ.”
\v 3 Ukadu ni, ace aghọmẹẹ tẹri ace bọ si, “Ajiya ri kpaa ẹrẹkwyuẹ nga kini Ọnọng nga ni!”
\v 4 Ni iYesu ye imumani ishi kidẹ ikwyi bọ, aba tẹri bọ si, “Ikẹmbọ sa ni inu sọ shuni nọ uma ububi kidẹ ikwyi nu?
\v 5 Uligba wu cẹẹ nọ uyuyo, na tẹri si, ‘A cira uvulu ngọ ko,’ ta atẹri si, ‘Sisang kọ kyeng’?
\v 6 Ka inu ye si Anọ Ajiya shi ni ẹrẹgọrọ ka asing ri ka a cira uvulu kọ.” Aba sa tẹri aghọ shọmọ ika si, “Sisang, kpaa icuru ngọ kọ kya ngọ aca.”
\v 7 Ava sisang ki kpa icuru nga ki kyaa aca.
\v 8 Ikir bajiya ya nu kindọ ni, aba kọng ẹrẹbata, aba jọọ Ọnọng, aghọmani ama ajiya idi ẹrẹgọrọ.
\s1 IYesu Yọrọ IMatiyu
\r (IMar 2.13-17; ILuk 5.27-32)
\p 
\v 9 IYesu ya ukadu ki kyaa ite, aba nu ace ajiya ayọrọ nga si iMatiyu na ci kidẹ bọọ yira agonu, aba tẹri nga si, “Yii mi.” Aba sisang ki yii nga.
\v 10 Akyua umani iYesu sọ la imila ka aca iMatiyu, ukadu ni aghọ yira agonu kina aghọ vulu napam ba na asọ la imila kini iYesu kina aghọyii nga.
\v 11 AFarisiyawa ya nu kindọ ni, aba tẹri atina nga si, “Ikẹmbọ sa ni aghọmẹẹ nu sọ la imila kina aghọ yira agonu kina aghọ vulu?”
\v 12 Aya kọng kindọ ni, aba tẹri si, “Agha akyuọ ka wang bọ aghọ kang ba, sa aghọmani ashi adumu.
\v 13 Kya kọ ya wang imumani udi sọ yeni, ‘Imẹ wang ahwoo, ba uma ẹrẹkwẹ ba.’ Ka imẹ ba mi kaya agha aipang ba, sa aghọ vulu.”
\s1 Aghulu IYesu kaya Kpẹnẹ Anyu
\r (IMar 2.18-22; ILuk 5.33-39)
\p 
\v 14 Aghọyii iYahaya ba ukushi nga, ki tẹri nga si, “Ikẹmbọ sa ni ayọ kina aFarisiyawa ka kpẹnẹ anyu, na anga ngọ atina ka kpẹnẹ bọ anyu ba?”
\v 15 IYesu va yira bọ si, “Ayikyo aghimi asasa ki ju ikwyi ibibi ka awii usra agya uloru ubuwa na aghimi ashi kini bọ? Awii ki ba angọ umani aki kpaa aghimi asasa wu kukushi bọ, ukadu wu ni aki kpẹnẹ anyu kọ.
\v 16 Ba aghọmani aki ta igbang ititang kina ugyauto ọsọsa ba, ka uta ki gaya wu, ugaya ughọghẹ.
\v 17 Ba aghọmani aki sa amusum ikọlọ na ashi asasa ki ubom ututang. Insi asa ya ni iki siga wu, amusum ikọlọ na shi ki naa bọ ni ubom bira bọ. Amusumu ikọlọ na shi asasa si ubom ọsọsa, nadidu ki ci iduma.”
\s1 IYesu Lẹni na Ayiri mani ashi Adumu ki Shang Anayiri mani Akpoo
\r (IMar 5.21-43; ILuk 8.40-56)
\p 
\v 18 IYesu shi kidẹ utẹri uma ri ni, na ace akwyite ọkọ takwyuẹ aYahudawa ba ukushi nga ki ta agho kite nga, na tẹri si, “Anọ mi anayiri kọ kpoo, ba ko ma tiya nga avọ ngọ, ka sisang.”
\v 19 IYesu va sisang ki yii nga, kina atina nga.
\v 20 Ace ayiri mani akọ lọ nọ ushiri ayi anyi ọshọ na pai ba kọ tumu nga ki piya anyu igbang nga,
\v 21 atẹri ẹrẹkwẹ nga si, “Insi imẹ piya igbang nga ni, imẹ ki peni ọkyuọ.”
\v 22 IYesu tee, anu nga ni aba tẹri si, “Kpẹnẹ ikwyi ngọ, anọ mi! uma aipang ngọ ma ngọ ọkyuọ.” Kidẹ anakyua ni ayiri ba ọkyuọ.
\v 23 IYesu ya kyaa ọna akwyite ọna Ọnọng ni ava nu aghọ pọ igbẹri kina ajiya na asọ duma ọka wu,
\v 24 ava tẹri bọ si, “Usang nu, ka anayiri ta kọ kpoo nga ba, asọ moo wu.” Aba sira nga unga ujeri amara.
\v 25 Aya kla ajiya nga ni, ava ghila idẹ ki kpẹnẹ nga ka avọ, anọ va sisang.
\v 26 Ila ima uju nga kpaa ki ẹrẹbọ nadidu.
\s1 IYesu Lẹni na Afoo Apai
\p 
\v 27 IYesu ya ukadu ni, ace afoo apai yii nga, aci ni ẹrẹwyuẹ ighighẹ, “Kọng ahwoo yi, Anọ iDauda.”
\v 28 Aya ghila aca ni, afoo ba ukushi nga, iYesu va tẹri bọ si, “Inu ma aipang si imẹ ki bra uju udi?” Aba yira nga si, “Ẹẹ, ate ọna.”
\v 29 Ava piya ica bọ ki tẹri si, “Kọnọ uma aipang nu ni ọba nọ kindọ.”
\v 30 Ica bọ va yẹmi. IYesu waa bọ atọng, “Inu ba tẹri ace aghọ ba.”
\v 31 Aba kunu bọ kiya yẹmi ila iYesu ka udu ugẹẹ ẹrẹbọ.
\v 32 Asọ kunu bọ ni, ace ajiya ba iYesu kina aghọ shi nọ ushẹẹ ungọ umani ọsa ni aka pii nga ba.
\v 33 Aya woo ushẹẹ nga wu ni, ajiya nga va tee aghọ upii. Ikir bajiya wọ ica, na tẹri si, “Asọ nọ kọ ju bọ ighọ ima ri kidẹ Israila ba.”
\v 34 AFarisiyawa tẹri si, “Awuli Ushẹẹ kina ẹrẹkyuọ agọm nọ ushẹẹ.”
\s1 Aghọ Tina Shi na Jii
\p 
\v 35 IYesu ghimi ọfọng kina anọrifọng ọka nadidu, na mẹẹ kidẹ uka takwyuẹ aYahudawa na tẹri ila ididuma ọka ẹrẹgọm Ọnọng na lẹni kina ko iligba ighọ udumu kina uta ọkyuọ.
\v 36 Aya nu ajiya na acuru ni, aba kọng ahwoo bọ, ka akọ kọng ọlọ ba aghọ shẹ bọ kọ ba, kini atẹm bọ ba aghọcee ni.
\v 37 Aba tẹri atina nga si, “Ucuru shi nagigang, ni aghọ utina shi na jii,
\v 38 Inu ushọr ate ọna ucuru, ka tuma na aghọ utina ka aba ucuru.”
\c 10
\s1 IYesu Hwiya Atina nga Ushọ na Apai
\r (IMar 3.13-19; ILuk 6.12-16)
\p 
\v 1 IYesu yọrọ atina nga ushọ na apai ki ma bọ ẹrẹkyuọ wuli ushẹẹ ka va lẹni ni idumu kina aghọmani ashi bọ akyuọ ba.
\v 2 Uca atina bọ shi, Kọ kpaa ki, iSiman, aghọmani ayuru nga si iBitrus, kina Andarawus anayuru nga, kina iYakubu anọ iZabadi, kina iYahaya anayuru nga;
\v 3 kina iFilibus, kina iBartalomi, kina iToma, kina iMatiyu aghọ yira agonu, iYakubu anọ iHalfa, kina iTadiyos,
\v 4 kina iSiman agha aKan’ana, kina iYahuda Iskariyoti aghọmani agbọra iYesu.
\s1 IYesu Tuma Atina nga Ushọ na Apai
\r (IMar 6.7-13; ILuk 9.1-6)
\p 
\v 5 Ushọ na apai ri ni iYesu tuma bọ, ki waa bọ atọng si, “Inu ba ghila ice ifọng kidẹ ufọng aghọmani ashi bọ aYahudawa ba, ba ghila ifọng agha aSamariya ba,
\v 6 kindọ ni, inu tee kya nu ọka ni atẹm vulu bọ kidẹ ajiya Israila.
\v 7 Ukyeng nu sa tẹri upii Ọnọng si, ‘Ọka ẹrẹgọm ayaya ya ba.’
\v 8 Lẹni na adumu, ashang aghọ kpuru, hwuru aghọnọ ubili, uwuli ajiya ushẹẹ. A mi ma nu basi ọghẹ ba, inu ma ni uma ba uyira icima.
\v 9 Inu ma kpaa utii uyeri ko uguza ko ufẹ kidẹ ipa nu ba,
\v 10 ba ipa kọ ukyeng nu, ba ko ugba upai ko akpọ, ko ashi, ka aghọ tina shi umani ama nga imila nga.
\v 11 Insi inu ghila ifọng ko anifọng ni, inu wang aghọmani akyeng na bibọrọ ko ukadu ni inu ci kini nga sa inu ya sang nọ.
\v 12 Insi inu ghila ọna ni, inu tẹri si ayọ ba na ikwyifu.
\v 13 Insi ọna maa kọ ni, ikwyifu shuu kaya akwyi bọ, insi ata maa bọ kọ ba ni, ikwyifu vuwa yọ ukushi nu.
\v 14 Aghọ mani ayira nu nga ma ni, da tọrọ bọ kọng upii nu ni inu pura acọ ifra nu kọ insi inu kunu kọ ọna ko ifọng.
\v 15 Aipang imẹ do taa nu, adọ cẹẹ nọ kọng ahwoo ẹrẹbọ aSodom kina aGomora di cẹẹ bọ kọ ka awii utẹri ashuwa.
\s1 Ọlọ Mani Uta ba
\r (IMar 13.9-13; ILuk 12.11-12; 21.12-19)
\p 
\v 16 “Uwẹ ni, imẹ dọ tuma nu lilẹẹ atẹm kidẹ ma ava aghumu, kindọ ni inu ba na amara lilẹẹ iyọọ, nu daa va shi na aipang lilẹẹ ikhimi.
\v 17 Inu kyeng na zizal na ajiya, na adọ kpaa nu na kya kọ pii aca ashuwa na ca nu kidẹ ọkọ takwyuẹ aYahudawa,
\v 18 aki kyaa ni nu kite aghọ ko ẹrẹbọ kina agọm kaya mi, ka inu tẹri aipang kite bọ kina aghọmani ashi bọ aYahudawa ba.
\v 19 Akyua mani a kpẹnẹ nu ni inu ba duma kini imumani inu dọ taa ma, na adọ ma nu ima utaa ka akyua.
\v 20 Ka inu bọ dọ shi aghọ pii ma, Aghing Ate nu nga do shi aghọmẹẹ nọ.
\v 21 Anayuru dọ ma anayuru bọ ka apii nga, Ate dọ ma anọ, anọ dọ yeni Ate bọ utaa hwiri atọng ka asa ka a pili bọ kọ.
\v 22 Kwinga dọ tọrọ nu nga kaya nọ uca mi, aghọmani amọr ki ta ka amaa ni, ado lẹ.
\v 23 Insi asọ tili ni inu kọ ububi ki ice ifọng ni, inu ti kya nu ka ice. Imẹ dọ taa nu aipang, inu dọ kpẹẹ nu uki kẹli ifọng Israila ma ni, Anọ Ajiya dọ vuwa.
\v 24 “Aghọyii ka cẹẹ nga aghọmẹẹ nga ba, agira ka cẹẹ nga ate ọna nga ba.
\v 25 Uma umani aghọyii lilẹẹ aghọmẹẹ nga, agira lilẹẹ ate ọna nga. Insi a yọlọ ate ọna si uBalzabul ni, ikẹmbọ na adọ taa na ajiya ọna?”
\s1 Aghọmani adọ Kọng Ẹrẹbata nga
\r (ILuk 12.2-7)
\p 
\v 26 Inu ma kọng ẹrẹbata bọ ma, ki ba imumani a yuru ya ni aki fumu bọ ba, ni ba imumani adọ ju kọ ọshishọ ni adọ ye bọ ma.
\v 27 Imumani imẹ taa nu kidẹ itii ni, inu dọ taa yọ kidẹ uyeri, imumani atẹri nu kọ ọtọng ni, inu dọ tẹri yọ ka ayaya ọna.
\v 28 Inu ma kọng ẹrẹbata aghọmani adọ pii ẹrẹnọma na aki pii nga aghing kọ ba, inu tẹ ẹlẹbata aghọmani ado pulu ẹrẹnọma kina aghing ngọ ka fẹni kidẹ ọna ugha.
\v 29 Aka gbura bọ anurudẹri a pai kaya ọnei uyeng ba? Agha yeng dọ kpaa nga ki ẹrẹbọ ma basi ate nu ye ma.
\v 30 Ko ni ufung ẹrẹkwẹ nu ni, akọ pila bọ.
\v 31 Kindọ ni, inu ma kọng ẹrẹbata ma. Ni inu cẹẹ anurudẹri na pam.
\s1 Mani Uyii IYesu ki Ba ni Ukau Bajiya
\r (ILuk 12.8-9)
\p 
\v 32 Agho mani a yeni Ajiya si ashi anga mẹ ni, imẹ ki kọ yeni nga kite Ate mi aghọmani ashi ka ayaya.
\v 33 Ni aghọmani a shila uye mi ki ite bajiya ni, imẹ dọ kọ shila uye nga kọ ite Ate mi ka ayaya.
\p 
\v 34 Inu ma kyoo ni imẹ ba ni ikwyifu ka asing ma. ikwyifu yọ ba ni mẹ ma, imẹ ba ni ikuma ọkọrọ.
\v 35 Imẹ ba ọsa Ate irisho kina anọ nga, anọ anaghẹmẹ, anayiri kina a yuru nga, ayiri kina akẹri nga.
\v 36 Aghọ ọna ajiya bọ dọ tee asho nga.
\v 37 Aghọmani a yoo ate nga ko ayuru nga, ki cee mi kọ ni, aghọ maa nga umani ataa si a anga mẹ ba, aghọmani a yoo anọ ko anọ nga anayiri ki cee mi kọ ni, aghọ maa nga umani ataa si a anga mẹ ba.
\v 38 Aghọmani akpaa nga ukumu ushi nga di yii mi ma ni, aghọ maa nga mani ataa si anga mẹ ba.
\v 39 Aghọmani a wang foo ọkyuọ nga ni, aghọ dọ taa wọ, aghọmani a ataa ọkyuọ nga ni a dọ peni wọ kaya mi.
\s1 Utina Upeni Ọka ngọ
\r (IMar 9.41)
\p 
\v 40 Aghọmani ayira nu ni agho yira mi, aghọmani a yira mi ni aghọ yira aghọmani a tuma mi.
\v 41 Aghọmani a yira aghọ pii kọ ọtọ Ọnọng ni adọ yira ọka nga kukushi aghọ pii kọ ọtọ Ọnọng, aghọmani a yira aghọ shi na pipar ni si ashi na pipar ni aghọ do yira ọka nga kukushi aghọ pipar.
\v 42 In kini ace aghọ ma agha yeng kidẹ ananọ li isọ na musumu kaya mi si asa aghọyii mi ni, imẹ dọ taa nu aipang aghọ dọ taa nga ọka nga ma.
\c 11
\s1 IYesu kini IYahaya Aghọnọ Iminimini
\r (ILuk 7.18-35)
\p 
\v 1 IYesu ya kpẹẹ uma atina nga ushọ na apai upii ni, aba sang nga kọ ukadu ki ya mẹẹ na tẹri upii Ọnọng ka ufọng bọ.
\v 2 Akyua ra ni iYahaya shi kidẹ ubọọ iting. Aya kọọ uma umani ukristi sọ ju ni, aba tuma atina nga kukushi nga
\v 3 ki ya ju nga si, “Ingọ shi aghọmani aki ba, ta ayọ kọ ica na ace aghọ ni?”
\v 4 IYesu ba yira bọ si, “Inu kya kọ ya tẹri iYahaya imumani inu nu ki ba kọọ,
\v 5 afoo peni ukyoo uka, aghọmani aka kyeng bọ ba kyeng, a hwuru aghọnọ ubili na ba na pipar, agbatọng kọọ atọng, ni aghọ ukpo sang, ni aghina amir kọọ ila ididuma.
\v 6 Anyu adaduma ni aghọmani ata kọọ nga ẹrẹbata uma aipang kaya mi ba.”
\v 7 Aya sang bọ ni, iYesu ba dẹẹ aghọ upii ni ikir bajiya kaya iYahaya, “Ikẹmbọ ni inu kyaa unu ka aghumu? Ọbọng ọbgọlọgbang umani uwuu sọ ca bọ?
\v 8 Ikẹmbọ ni inu kyaa unu? Ajiya umani asọmọ uma ọdọdọma? Aghọ shi kidẹ ugẹẹ agọm bọ ka sọmọ uma ọdọdọma.
\v 9 Ikẹmbọ ni inu kyaa unu? Atina Ọnọng? Ẹẹ, imẹ tẹri nọ, acẹẹ aghọ pii kọ ọtọ Ọnọng.
\v 10 Aghọmani awọọ kaya nga wẹ si, ‘Uwẹ ni, imẹ tuma atuma mi ka la ngọ ite wọ, aghọmani aki keri ngọ utra ni ingọ tọ ba.’
\v 11 “Aipang, imẹ si, ayiri sọ nọ kọ jee bọ ace anọ aghọ mani acẹẹ iYahaya aghọ uju iminimini nọ ọghọghẹ ba. Kindọ ni, aghọ cẹẹ nọ ọzọzi ki ẹrẹgọm Ọnọng ayaya cẹẹ nga.
\v 12 Kọ kpaa ka akyua iYahaya aghọ uju iminimini ki ba ta ka akyua ri ni, ẹrẹgọm Ọnọng ayaya kọ la ite ni agha sing wang yira na akyuọ.
\v 13 Ka aghọ pii kọ ọtọ Ọnọng kina umẹẹ iMusa kọ tẹri upii kaya ẹrẹgọm ni iYahaya kọ ba nga ba,
\v 14 ni insi inu yira upii ni, anga shi Iliya umani aki ba ra.
\v 15 Ta ni aghọ shi na atọng kọng, kọng.
\v 16 “Ni ikẹmbọ ni imẹ ki mra ajiya akyua ri kọ? Ushi kini anọ bọ shi ka uka gheli na gbura ni na sọ yọrọ ayikyo bọ si,
\v 17 ‘Ayọ pẹni igbẹẹ ni inu ta ya nọ ba! Ayọ taa nọ atẹ ukpo, inu ta ci nọ ba!’
\v 18 “Ka iYahaya ba ni aka bira ngọ la na sa nagigang ba, ‘ni asi ashi na ushẹẹ.’
\v 19 Anọ ajiya ba na sọ la na sa, ni asi, ‘Nu nga! aghọ bira ula kọnọ usa, aghikyo aghọ yira agonu kina aghọ uvulu!’ Kindọ ni, aka kpẹlẹ uye ukyuu Ọnọng ka uma uju nga.”
\s1 Ọlọ Kaya Ufọng mani Ara la bọ Ukpaa ba
\r (ILuk 10.13-15)
\p 
\v 20 A dẹẹ kọ gẹr ufọng umani aju uma usa uwo ica wọ nagigang, ka ata ju bọ ọlọkpaa ba.
\v 21 Ọlọ ngọ, aKorasinu!, ọlọ ngọ, aBetsaida! Awasi uma usa uwo ica ri ni aju ka aTaya kina aSidon ni, ata kọ lọkpaa aiwuu ka sọmọ agẹẹ nọ uma kina utọ ki ẹrẹnọma bọ.
\v 22 Ni imẹ sọ tẹri nọ, aki cẹẹ nọ kọọ ahwo aTaya kina aSidon kaya nọ ka awii ashuwa.
\v 23 Ingọ ni aKafarnahum, ingọ kpaa si aki jọọ ngọ ka aya fuma ayaya? Kayi, aki waa ngọ ka akya bọ uka ci aghọ ukpo wọ. Awasi uma usa uwo ica ri ni aju bọ ka aSodom ni, uta kọ shi wọ kaidii.
\v 24 Ni imẹ sọ ba tẹri nọ si, awii ashuwa ni aki cẹẹ nọ kọọ ahwo ẹrẹbọ aSodom kaya ngọ.”
\s1 Inu Ba Wuru kukushi Mi
\r (ILuk 10.21-22)
\p 
\v 25 Akyua ra ni iYesu tẹri si, “Imẹ sa ngọ izaa, Ate, Ate aYaya kina ashi, nọ umani ingọ shọ uma ri ka aghọ uye ukyuu kina aghọ shi nọ ukpili, ni ingọ sa yeni anọ azazi.
\v 26 Kindii wu Ate, imumani ishi ngọ ididuma yidii ni ingọ ju.
\v 27 Ate mi ma mi uma nadidu, ni ba aghọmani aye Anọ sa Ate, ni ba aghọmani aye Ate sa Anọ, kina aghọmani Anọ yoo ni, aka yeni nga.
\v 28 Inu ba ukushi mi aghọmani akọ kiya na aba ko akpara ọtọsọ, ni imẹ ki ma nu uwuru.
\v 29 Inu kpaa akpara mi, inu mẹẹ kukushi mi, ka imẹ ni aghọ suu ni ẹrẹkwẹ nga, aghọ taa ẹrẹkwẹ ẹhwẹhwuọ, ka inu ki kọ peni uwuu ka ikwyi nọ.
\v 30 Ka uju mi ẹrẹgẹra lọ wọ ba, akpara mi shi na hau.
\c 12
\s1 IYesu Nga Shi Ate Awii Uwuru AYahudawa
\r (IMar 2.23-28; ILuk 6.1-5)
\p 
\v 1 Akyua ra ni, iYesu wor kọ ọka ija alkama ka Awii uwuru aYahudawa. Atina nga kọọ idafo, na aba dẹẹ kọ kẹr akwyi alkama na la.
\v 2 AFarisiyawa ya nu kindọ ni, aba tẹri nga si, “Nu, atina ngọ su ju imumani umẹẹ iMusa kiya wọ ka Awii uwuru aYahudawa.”
\v 3 Aba ju bọ si, “Inu ta kọ pila nọ imumani iDauda ju ka akyua na akọọ idafo, kina aghọmani ashi kini nga,
\v 4 umani aghila idẹ ọna Ọnọng ki ya la ubiredi na akyo si, ba aghọmani aki la ba, inga kina ayikyo ukyeng nga, si ifirist ka yu nga.
\v 5 Ta inu kọ pila nọ umẹẹ iMusa, umani afirist kidẹ ọna ọnọng ka ju uma ijirija ka Awii uwuru aYahudawa ni uta shi wu uvulu kukushi bọ ba?
\v 6 Imẹ sọ tẹri nu, imumani icẹẹ ọna ọnọng yẹ kọ kẹẹ.
\v 7 Inu ta kọ ye imumani udii sọ yeni ni, ‘Ahwoo kọ ni iwang, ba uma ẹrẹkwyuẹ ba,’ inu ta kọ nu nọ aghọ taa uvulu nu vulu ba.
\v 8 Ka Anọ Ajiya nga shi Ate Awii uwuru aYahudawa.”
\s1 Aghọ Uwẹni Avọ
\r (IMar 3.1-6; ILuk 6.6-11)
\p 
\v 9 IYesu ba ya ukadu ki kyaa ọkọ takwyuẹ aYahudawa bọ.
\v 10 Ace ajiya shi ya kọ ukadu aghọ uwẹ ni avọ. Aba ghulu nga si, “Ushi ọdọma mani ama ọkyuọ ka Awii uwuru aYahudawa?” Ibọ wang umani apeni nga nọ uvulu.
\v 11 Aba ju bọ si, “Inga kidẹ nọ nga shi na atẹm ni akpaa kidẹ uhwo ka Awii uwuru aYahudawa ni ata ki woo nga ngaa ba?
\v 12 Utina ajiya ta cẹẹ wu unga atẹm nagigang ba? Kindọ ni, ọsọ ọdọdọma na ju ima ididuma ka Awii uwuru aYahudawa.”
\v 13 Aba tẹri ajiya nga si, “Nawa avọng.” Aba nawa, ka akyua ra ni avọ nga ba ọkyuọ kini adaa avọ ni.
\v 14 Ni aFarisiyawa ba kunu bọ ki ya pii umani aki pii iYesu kọ.
\s1 IYesu Nga shi aghọmani Ọnọng Hwiya
\p 
\v 15 IYesu ya kpẹlẹ kindii ni, aba sang nga kọ ukadu. Ajiya na pam ba yii nga, na aba ma bọ ọkyuọ nadidu bọ.
\v 16 Aba waa atọng bọ si aba tẹri aghọ ila nga ba.
\v 17 Aju udii ka ahwura upii na atẹri ka anyu aghọ pii kọ ọtọ Ọnọng Ishaya si,
\v 18 “Agira ni imẹ hwiya wẹ, aghọmani imẹ yoo ni imẹ ka kọọ uhwai nga nagigang. Imẹ ki sa nga na aghing mi, aki tẹri aghọmani ashi bọ aYahudawa ba ashuwa aipang.
\v 19 Aki la nga inang ba, ko na pii ni ẹrẹkyuọ ba, aki ba kọọ bọ ẹrẹwyuẹ nga ka utra ba.
\v 20 Aki wra nga ushi iriguu umani uya sang wra wọ ba, ugha ọgbẹlẹmọ ni uya sang ukpo wọ ni, aki pii nga kọ ba, asọ sa aipang ka lite;
\v 21 aghọmani ashi bọ aYahudawa ba ki sa ikwyi kidẹ nọ uca nga.”
\s1 IYesu kina UBalzabul
\r (IMar 3.20-30; ILuk 11.14-23)
\p 
\v 22 Aba nga na afoo umani aka pii nga ba aghọ shi nọ ushẹẹ, ni aba ma nga ọkyuọ na ajiya nga pii ki ba nu.
\v 23 Ni ajiya nadidu ba wo ica na asi, “Anọ iDauda wẹ ri ba?”
\v 24 Ni aFarisiyawa ya kọọ kindii ni aba ju si, “Akyuọ uBalzabul agọm nọ ushẹẹ kọ ni ajiya ri si wuli ushẹẹ kọ.”
\v 25 IYesu ye uma ushi kidẹ ikwyi, na aba ju bọ si, “Nadidu ẹrẹgọm ni ikau uka upai nọ sọ irisho kina ace ni, ita ki tara wu ba. Ba ifọng nọ ọna umani ajiya nga kau uka upai nọ sọ ju irisho kina ace ni iki tara.
\v 26 Insi ishẹẹ woo ishẹẹ, asọ kọrọ kina ẹrẹkwẹ nga wudu. Nagyi kọ ni ẹrẹgọm nga ki tara wu?
\v 27 Insi imẹ ka wuli ushẹẹ na ẹrẹgọrọ uBalzabul ni, aghọyii nọ ni? ẹrẹgọrọ inga wọ na sọ wuli wọ? Aghọyii nu bọ ki wa nu ashuwa kaya uma ri.
\v 28 Insi ẹrẹgọrọ Aghing Ọnọng kọ ni imẹ wuli ushẹẹ kọ ni, ẹrẹgọm Ọnọng ba nu wudu.
\v 29 Ta nagyi wọ ni aghọ ki ghila ọna agha ẹrẹkyuọ kaya yẹri uma nga, inbasi azọnọ lor agha ẹrẹkyuọ ba? Na tọ biya yẹri uma ọna ba.
\v 30 Nadidu aghọmani ashi kini mẹ ba ni, ashi asho mi, ni aghọmani a curu nga kini mẹ ba ni, asọ furu wu.
\v 31 Kindii ni imẹ sọ tẹri nọ, aki cira uvulu nu kọ kwiligba ighọ kina ajiya umani apii ububi, aghọmani apii ububi kaya Aghing Ọnọng ni, aki yira bọ ọlọkpaa nga ba.
\v 32 Ni aghọmani apii ububi kaya Anọ Ajiya ni, aki yira ọlọkpaa nga, aghọmani apii ububi kaya Aghing Ọnọng ni, aki yira bọ ọlọkpaa nga ba, ko akyua ri ko akyua uki ba.”
\s1 Ushi kini Ikọlọ nga
\r (ILuk 6.43-45)
\p 
\v 33 “Ushi ọdọdọma ka ma ikọlọ ididuma, ọshẹ ububi ka ma ikọlọ ibibi ka aka kpẹlẹ ọshẹ ki ikọlọ nga.
\v 34 Inu iyọọ na kang! Nagyi wọ ni inu ki biya utẹri upii ọdọdọma ni inu si shi agha akakiya? Ima ushii kidẹ ikwyi yọ ni anyu ka tẹri.
\v 35 Ajiya adaduma ni, ọka ukyo uma ọdọdọma wọ na aka woo ima ididuma wọ. Ajiya akakiya ni, uka ukyo uma akakiya wọ ni aka woo akakiya wọ.
\v 36 Imẹ sọ tẹri nọ, nadidu uma ijirija na ajiya pii ni, aki pila bọ ka awii ashuwa,
\v 37 ka uma utẹri ngọ bọ na aki wa ashuwa ngọ wọ, ni uma utẹri ngọ bọ na aki ma ngọ uvulu ngọ wọ.”
\s1 Uwang Amaa
\r (IMar 8.11-12; ILuk 11.29-32)
\p 
\v 38 Ni ace aghọmẹẹ umẹẹ iMusa kina aFarisiyawa ba yira nga si, “Aghọmẹẹ, ayọ wang nu amaa kukushi ngọ.”
\v 39 Aba yira bọ si, “Agha akakiya kina aghọ ju uma ẹrẹnọma ka wang nu amaa, ni ba amaa umani aki ma inbasi anga aghọ pii kọ ọtọ Ọnọng iYunusa ba ni.
\v 40 Kọnọ umani iYunusa la awii atai kina atii atai kidẹ afo itagbo ighighẹ ni, kindii wu ni Anọ Ajiya ki la awii atai wọ kina atii atai kidẹ ikwyi asing ri.
\v 41 Ajiya Anineba ki sang ka awii ashuwa kina agha akyakyua ra ka ama bọ uvulu, ka alọkpaa nọ upii Ọnọng iYunusa, kindii ni, imumani cẹẹ iYunusa shi kọ kẹẹ.
\v 42 Ayiri agọm, iSheba ki sang ka awii ashuwa kina agha akyakyua ra ka ama agha aikyuari uvulu, ka aba ka ushẹẹ aya ka aba kọọ umẹẹ uye ukwuu iSulemanu, kindii ni, imumani cẹẹ iSulemanu shi kọ kẹẹ.
\v 43 “Insi aghing ababi kunu kidẹ ajiya ni, aka wor kyaa uka umani ba amusumu ya ba ka aya wuru, insi apeni nga ba ni,
\v 44 aki ju si, ‘Imẹ ki vuwa mi ọna ni imẹ kunu wọ.’ Insi aya ba ni, aki ba peni ọna ni ka aghọ ya ba, akọ yẹr wọ ki ker wọ,
\v 45 aki ba vuwa ka aya ba na aghing atinsara umani acẹẹ nga na akakiya, ni aki ghila ka aci kọ ukadu, ni ushii ajiya nga ki cẹẹ unga akyua nọ ububi. Kindii wu ni uki shii wu ka ajiya kakiya akyua ri.”
\s1 Ayuru Iyesu na Anayuru Nga
\r (IMar 3.31-35; ILuk 8.19-21)
\p 
\v 46 Asọ pii kina ajiya nga ni, ayuru nga kina anayuru nga va ba tara kọ seshi, awang pii kini nga.
\v 47 Ace aghọ ba tẹri nga si, “Ayuru ngọ kina anayuru shi kọ seshi, awang pii kini ngọ.”
\v 48 Aba yira ajiya na atẹri nga si, “Inga shi ayuru mi, inga bọ shi anayuru mi?”
\v 49 Aba nawa avọ ka atina nga ki ju si, “Ayuru mi wẹ kina anayuru mi!
\v 50 Nadidu aghọmani aju imumani ate mi ka aYaya sa uju ni, anga shi anayuru mi, kina afọọ mi, kina ayuru mi.”
\c 13
\s1 Ighang Upii Aghọ Wuu
\r (IMat 4.1-9; ILuk 8.4-8)
\p 
\v 1 Ka awii ra ni iYesu kunu nga kidẹ ọna ki cica ka anyu ọghọng.
\v 2 Ikir bajiya ba curu ki ghimi nga, ki sa na ghila nga idẹ ọgbọlọ ki cica. Ikir bajiya nga ba tara ka anyu ọghọng.
\v 3 Aba tẹri bọ uma na pam ni ighang upii, si, “Aghọ wuu kyaa kọ pila.
\v 4 Asọ ta ighọ ni, ice kpaa kọ utra, ni anurunu ba ki ba la yọ kọ.
\v 5 Ice ighọ kpaa kọ ọka atii ni ba ẹrẹbọ ya nagigang, iva mii kaisa ka ẹrẹbọ shiwu ikyuu ba,
\v 6 ọnọng ya ta ni, aba ghau yọ ki hwiya yọ ka akang bọ shi yọ akyuu ba.
\v 7 Ice kpaa ka ọka umani akara shiya, akara ba fọnọ ki la ẹrẹkyuọ bọ.
\v 8 Ice ighọ kpaa ka ẹrẹbọ ididuma ki sa ikii ajilaji, ishishi itin, ishishi itai ki cẹri imumani apila.
\v 9 Ta ni aghọ shi na atọ kọọ.” \fig Ighang upii upila|alt="parable of the sower" src="DN00470b.tif" size="col" loc="13:1" copy="cn" ref="13.9"\fig*
\s1 Imumani Ighang Upii sọ Nyeni
\r (IMar 4.10-12; ILuk 8.9-10)
\p 
\v 10 Atina iYesu va ba ki ba ghulu nga si, “Ikẹmbọ sa ni inga sọ pii ni bọ ni ighang upii?”
\v 11 Aba yira bọ si, “Inu ni, ama nọ uye ẹghẹrẹghẹmẹ inga ẹrẹgọm aYaya, ibọ ni, ata ma bọ wọ ba.
\v 12 Ka aghọ shi ni ima ni, aka khimi nga kọ, ka apeni na pam, ni aghọmani ashi ni yọ ba ni, aki kara anọ imumani ashi ni yọ kọ.
\v 13 Imumani isa ni imẹ sọ pii ni bọ ni ighang upii yẹ. “‘Aka kọọ, na aka kpẹlẹ bọ ba, aka kyoo, na aka nu bọ ba na akpili bọ ba.’
\v 14 Kindii ni, amọ aghaghẹ aghọ pii kọ ọtọ Ọnọng Ishaya hwura kaya akwyuẹ bọ si, “‘Inu ki ka kọọ, ni inu ta ki kpẹlẹ nọ ba, inu ki ka kyoo, ni inu ta ki kpẹlẹ nọ ba.
\v 15 Ka ajiya nga shi na ikwyi umom, ni atọ bọ ka ta akọọ yọ ba, akọ yuru ica bọ ya, iba kindii ba ni, ata kọ nu ni ica bọ, ka aba kọọ na atọ bọ, ka aba kpẹlẹ kidẹ ikwyi bọ, ka vuu ba ukushi mi ki imẹ ma bọ ọkyuọ.’
\v 16 Ica nu shi na anyu adaduma ki ika nu, kina atọ nu, ka aka kọọ.
\v 17 Aipang ni isọ tẹri nu, aghọ pii kọ ọtọ Ọnọng kina agha uju aipang na pam wang nu imumani inu sọ kyoo, ni ata nu bọ ba, ka aba kọọ imumani inu hwiri, ni ata kọọ bọ ba.”
\s1 Imumani Ighang Upii Aghọ Wuu sọ Nyeni
\r (IMar 4.13-20; ILuk 8.11-15)
\p 
\v 18 “Inu kọ imumani ighang upii aghọ wuu sọ nyeni
\v 19 Insi ajiya kọọ ila ẹrẹgọm na ata kpẹlẹ nga ba ni, Ishẹẹ ka ba ki ba kara imumani apila kidẹ ikwyi nga. Ighọ na apila kọ utra yẹ.
\v 20 Ighọ ni ikpaa ka ọka atii ni, iyọ kọọ upii ki yira kidẹ akyua ni ikwyifu,
\v 21 ni ishi yọ ni akang ba, ika mọr kidẹ anọ akyua, insi umẹni kina ọlọ ba kaya upii ni, kaisa aka waa nọ utumu.
\v 22 Ighọ ni apila kidẹ akara ni, iyọ shi aghọ ni akọọ upii, ni uduma asing kọnọ uyoo upeni tulu nga ki kla nga ọfọnọ wọ ka ama ikọlọ.
\v 23 Ighọ mani ikpaa ka ẹrẹbọ ididuma ni, anga shi aghọmani akọọ upii ki kpẹlẹ wu. A ju utina wu ki ma ikọlọ, ice ajilaji, ice ishi-shitin, ice ishi-shitai.”
\s1 Ighang Upii Ọbọ kidẹ Ija Alkama
\p 
\v 24 Aba ma bọ ice ighang upii si, “Aki mra ẹrẹgọm ayaya na ajiya umani apila ighọ ididuma kidẹ ija nga,
\v 25 akyua ni ajiya sọ moo ni asho nga ba ki ba pila ọbọ kidẹ ija alkama na asa sang nga.
\v 26 Imila ya sang na pipar ni, ọbọ ba kọ sang.
\v 27 Ni agira ate ọna ba ki ba tẹri nga si, ‘Aghọ ọna, ba ighọ ididuma yọ ni ingọ pila kidẹ ija ngọ ba?’ A ju na nyi ni ọbọ mii ya kidẹ?’
\v 28 Aba ju bọ si, ‘Aghọ ju irisho ni imẹ nga ju udii!’ Agira nga ba ju si, “Ingọ wang si ayọ ya yẹẹ ọbọ kọ?
\v 29 Ni aba ju si, ‘Kayi, ki inu bọ wang uwuru ọbọ ni inu ki wuru kina alkama.
\v 30 Ya bọ ya ka afọnọ nadidu ka afuma akyua ucuru, akyua ucuru ni, imẹ ki tẹri aghọ ucuru ka acuru ọbọ ka alolu bọ, ka ta ugha wu, ni asa curu alkama ka asa kidẹ na afọ mi.’”
\s1 Ighang Upii Ikir Ikpo
\r (IMar 4.30-32; ILuk 13.18-19)
\p 
\v 31 Aba ma bọ ice ighang upii si, “Ẹrẹgọm ayaya shi kini ikir ikpo umani ace ajiya pila kidẹ ija nga.
\v 32 Iyọ cẹẹ nọ ọzọzi kidẹ ighọ nadidu, insi ifọnu ni, ika cẹẹ uma umani apila kidẹ ija ki ba ọshẹ ọghọghẹ, ni anurunu ayaya ka ta asọọ bọ ya kaya aga nga.”
\v 33 Aba tẹri bọ ice ighang upii. “Ẹrẹgọm ayaya shi kini uyisti umani ace ayiri ki zọọ na ima umra ugọ alkama iritai ki ta kọ umani ugọ kpẹnẹ uyisti ni.”
\v 34 Nadidu uma ri ni, iYesu tẹri ikir bajiya ni ighang upii; Ata tẹri bọ ice ima ba ighang upii ba.
\v 35 Udii ni, ka ahwura upii ni aghọ pii kọ ọtọ Ọnọng tẹri wọ, “Imẹ ki yẹmi anyu mi ni ighang upii; Imẹ ki tẹri imumani ashọ wọ kọ kpaa ka akyua na akeri asing kọ.”
\s1 A Nyeni Ighang Upii nọ Ọbọ kidẹ Ija Alkama
\p 
\v 36 IYesu ba sang nga kidẹ ikir bajiya ki kyaa aca. Ni atina nga ba ukushi nga, ni asi, “Tẹri ayọ imumani ighang upii ọbọ kidẹ ija sọ nyeni.”
\v 37 Aba yira bọ si, “Aghọmani apila ighọ ididuma nga shi Anọ Ajiya.
\v 38 Ija kọ shi asing, ni ighọ ididuma yọ shi ẹrẹgọm Onọng. Ọbọ bọ shi anọ ishẹẹ,
\v 39 ni asho mani apila nga shi ishẹẹ. Ucuru imila wọ sọ usang asing, aghọ ucuru bọ shi atuma Ọnọng.
\v 40 Kọnọ umani aka curu ọbọ ki ta ugha wọ ni, kindii wọ ni uki shi wọ kọ usang asing.
\v 41 Anọ Ajiya ki tuma atuma Ọnọng, ni aki curu nadidu uma umani uka sa uvulu, kina aghọ ju uma ububi, ka a woo bọ kini ọbọng bọ ni ki ẹrẹgọm nga,
\v 42 ka fẹni bọ kidẹ ugha ọlọ nagigang. Kọ ukadu wu ni aki ci na ghula ayiri.
\v 43 Ni agha aipang ki ma uyeri kini ọnọng utaa ni kidẹ ẹrẹgọm Ate bọ. Taani aghọ shi na atọ kọọ kọ.
\s1 Ighang Upii kaya Upeni Mani Ashọ
\p 
\v 44 “Ẹrẹgọm Ayaya shi kini upeni na ashọ kidẹ ija ni, unga umani ace ajiya peni ki ba khimi ushọ wọ. Ni ikwyifu na aba ya gbara uma umani ashi ni bọ nadidu ki ya ghẹẹ ija wọ.”
\v 45 “Kakyakyua ri, ẹrẹgọm ayaya shi kini aghọ gheli na agbara kina aghọ wang atii adaduma ni.
\v 46 Aya peni utii udọdọma uye ni, aba ya gbara nadidu imumani ashi ni yọ ki ya ghẹẹ wọ.”
\s1 Ighang Upii Isha Ọhwiri Itagbo
\p 
\v 47 “Kakyakyua ri, ẹrẹgọm ayaya shi kini isha ọhwiri itagbo na a fẹni kidẹ ọghọng ki hwiri kwiligba ighọ itagbo ni.
\v 48 Iya tii ni, ajiya waa ki shii kaya asing ki hwiya ididuma ki sa kidẹ ọkọọ na ashi naa ibibi wọ.
\v 49 Kindii wu ni uki shi wu kọ usang asing. Atuma Ọnọng ki kunu ka aba kau agha akakiya kidẹ agha aipang.
\v 50 Ni asa fẹni agha akakiya kidẹ ugha ọlọ nagigang umani aki ci na aghula ayiri.
\s1 IYesu Tẹri Ighang Upii kaya Akọru Ọna
\p 
\v 51 “Inu kpẹlẹ Uma ri nadidu?” Aba yira nga si, “Ẹẹ.”
\v 52 Aba ju bọ si, “Nadidu aghọmẹẹ umẹẹ iMusa umani apeni umẹẹ kaya ẹrẹgọm ayaya ni, ashi kini akọr ọna nga ni, aghọ umani aba na upeni ọsọsa nga kina ọtọtang nga ka uka ukyuru uma nga.”
\s1 A Tọrọ bọ IYesu ka ANazaret
\r (IMar 6.1-6; ILuk 4.16-30)
\p 
\v 53 IYesu ya kpẹẹ nadidu ighang upii ni, aba sang nga kọ ukadu.
\v 54 Na aya ba ifọng bọ ni aba mẹẹ bọ kidẹ ọkọ takwyuẹ aYahudawa, aba wo ica, na tẹri si, “Abi wu ni ajiya ri peni uye ukyuu ri wọ kina akyuọ uju uma usa uwo ica?
\v 55 Anọ ikafinta ra nga ba? Ayuru nga ngaa ni aka yọrọ si iMaryamu ba? Anayuru nga bọ shi iYakubu, kina iYusufu, kina iSiman, kina iYahuda ba?
\v 56 Afọọ nga nadidu bọ shi kina ayọ ri ba? Abi wọ ni ajiya ri peni nadidu uma ri kọ?”
\v 57 Aba kọọ anaa ni ngaa. IYesu ba ju bọ si, “Aka tọrọ bọ aghọ pii kọ ọtọ Ọnọng ba inbasi ki ifọng nga kina aca nga ba ni.”
\v 58 Ata ba ju nga uma usa uwo ica kọ ukadu ba ka ata ma bọ aipang ba.
\c 14
\s1 Ukpo IYahaya Aghọ ju Iminimini
\r (IMar 6.14-29; ILuk 9.7-9)
\p 
\v 1 Akyua ra ni iHiridus Antifas kọọ ila iYesu,
\v 2 na aba tẹri agira nga si, “IYahaya aghọ uju iminimini wẹ ri. Akọ sang kọ ukpo; uwu sa ni ashi na akyuọ ju uma usa uwo ica ri.”
\v 3 Ka iHiridus kọ kpẹnẹ iYahaya ki lor, ki sọmọ nga kọ ubọọ itii kaya iHiridiya, ayiri anayuru nga iFilibus
\v 4 ka iYahaya ka tẹri nga si, “Umẹẹ iMusa ta ma wu ni ingọ vo nga ba.”
\v 5 Akyua ni, iHiridus wang kọ pii iYahaya kọ, ni asọ tẹ ẹrẹbata bajiya, ka a kpaa nga si aghọ pii kọ ọtọ Ọnọng nga.
\v 6 Ni awii na ajee iHiridus ya ba ni, anọ anayiri iHiridiya ya bọ ni ate nga iHiridus kọọ uhwai nagigang,
\v 7 na aba ta anyu kini ngaa, ki ba suu si aki ma nadidu imumani ashọr.
\v 8 Ayuru nga ngaa sa nga kọ, asi, “Ma mi ẹrẹkwẹ iYahaya aghọ uju iminimini kidẹ ipẹ ka aikyuari.”
\v 9 Agọm ba duma, usuu nga kina akyeng ra sa ni asa si ama nga.
\v 10 Atuma na aya kyua iYahaya ẹrẹkwẹ wọ kidẹ ubọọ itii,
\v 11 na aba ni ẹrẹkwẹ kidẹ ipẹ ki ba ma anayiri, ni aya ma ayuru nga.
\v 12 Aghọyii nga ba kpaa ọkọ ki ya naa kọ, ni aba kyaa kiya tẹri iYesu.
\s1 IYesu Cee Ajiya Araji Ushọ Atọ
\r (IMar 6.30-44; ILuk 9.10-17; IYah 6.1-14)
\p 
\v 13 IYesu ya kọọ kindii ni, aba sang ki ghila nga idẹ ọgbọlọ kọ uyuyi ki kyaa ọka umani ace aghọ shiya ba. Ni ikir bajiya ya kọọ kindọ ni, aba ki yii nga ni ifra kọ kpaa kọ ufọng.
\v 14 Aya kunu kidẹ ọgbọlọ ni aba nu ikir bajiya, aba kọọ ahwoo bọ, ni aba ma adumu kidẹ bọ ọkyuọ.
\v 15 Ọka ya ba ughẹ ni, aghọyii nga ba ki ju si, “Ba aghọ ya kọ kẹẹ ba, ni ọka wẹ ni uya sang ba ughẹ; shira ikir bajiya nga ka akyaa bọ anọrọfọng ushi kọ ukadu kaya gheli akwyi bọ imila.”
\v 16 IYesu ba ju bọ si, “Ba sa bọ ka kyaa uce ka ba, inu ka kyakwyuẹ nọ ma bọ ice ima ka ala.”
\v 17 Aba yira nga si, “Ayọ shina ubiredi utọ kina itagbo ipai.”
\v 18 Aba ju si, “Inu ba mi ni yọ.”
\v 19 Aba sa ikir bajiya nga si, acica kaya nọ ọbọ, aba kpaa ubiredi utọ kina itagbo ipai, aba zẹẹ ibate nga ka ayaya ki sa Ọnọng izaa. Asa wura ubiredi nga ki ma atina nga, atina nga ba ma ikir bajiya nga.
\v 20 Aba la nadidu bọ ki shuu. Aba curu awo na ashẹ ki sa ọkọọ ushọ nọ upai.
\v 21 Ajiya umani ala ni afuma aghimi araji usọ atọ, bam na ayiri kina anọ.
\s1 IYesu Kyeng Kaya na Amusum
\r (IMar 6.45-52; IYah 6.15-21)
\p 
\v 22 Akyua ra ni atina nga ya ghila bọ idẹ ọgbọlọ ki lite nga ki kyaa bọ udaa ugẹẹ, na asa laa nga kọ shira ikir bajiya nga.
\v 23 Aya kpẹẹ shira ikir bajiya ni, aba kila nga aya ọpang kayu nga kaya pii nọ Ọnọng. Ashi kayu nga kọ ukadu ki fuma ughẹ.
\v 24 akyua ra ni ọgbọlọ nga shi ka abiyatẹ ighọ kina ẹrẹbọ, ugya sọ ca wọ, ka uwuu sọ ju irisho kini wọ.
\v 25 Kini ikwikweting ni ava ba ukushi bọ na asọ kyeng kaya na amusum.
\v 26 Ni atina nga ya nu nga na akyeng kaya na amusum ni, aba kọọ ẹrẹbata, ki ju si, “Ahwu nga!” Aba taa kpa ni ẹrẹbata.
\v 27 Kidẹ akyua ni iYesu pii ni bọ, si, “Inu ba duma ba! Imẹẹ. Ba kọọ ẹrẹbata ba.”
\v 28 IBitrus ba yira si, “Ate, insi ingọ ni, sa mi ki imẹ ba ukushi ngọ kaya na amusum.”
\v 29 IYesu ba ju si, “Ba.” IBitrus ba kunu kidẹ ọgbọlọ nga na asọ kyeng kaya na amusum na aki ba ukushi iYesu.
\v 30 Ni aya nu uwuu nọ usang ni ẹrẹkyuọ ni, aba kọọ ẹrẹbata wọ na asa dẹẹ kọ ghila idẹ. Aba gyo akpa si, “Ate, foo mi!”
\v 31 Kidẹ akyua ni iYesu nawa avọ nga ki kpẹnẹ nga, ki ju nga si, “Ingọ agha uma aipang na jẹẹ, ikẹmbọ sa ni ingọ shina ikwyi ipai?”
\v 32 Aya fuma idẹ ọgbọlọ ni, uwuu ba tara.
\v 33 Aghọ shi kidẹ ọgbọlọ ba ta agho kite iYesu, ki ju si, “Aipang ni ingọ na Anọ Ọnọng nga.”
\v 34 Aya buu udaa ugẹẹ ni, aba kya bọ ẹrẹbọ aJanisarat.
\v 35 Ni ajiya ukadu ya kpẹlẹ nga ni, aba tuma na ajiya ishi ọka nadidu ka aba nga na adumu.
\v 36 Aba shọr nga ka ibọ piya anyu igbang nga. Nadidu aghọ umani apiya ni apeni ọkyuọ.
\c 15
\s1 Uma Umani Ọka Sa Irighe ki Ica Ọnọng
\r (IMat 7.1-13)
\p 
\v 1 AFarisiyawa kina aghọmẹẹ umẹẹ iMusa ba ukushi iYesu ka Urushelima ki ba ghulu nga,
\v 2 “Ikẹmbọ sa ni atina ngọ wura italẹ inga anirakpẹẹ? Aka hwuru bọ ivọ bọ na atọ la imila ba.”
\v 3 IYesu ba yira bọ si, “Ikẹmbọ sa ni inu ka wura imumani Ọnọng tẹri kaya italẹ nọ?
\v 4 Ka Ọnọng si, ‘Nu ọkpọtọrọ ate ngọ kina ayuu ngọ.’ Ni, ‘Aghọmani acira ate nga kina ayuru nga ni, aki kpoo iyiya.’
\v 5 Ni inu ka tẹri si, ‘Imumani aki ma ate nọ kina ayuru nọ ni, inu ka ma Ọnọng.’
\v 6 Ata maa na ate nga ba.’ Kindọ ni inu ta manọ upii Ọnọng ba kaya italẹ nọ.
\v 7 “Inu, aghọ ju unu ica! Kindii wu ni Ishaya ghila amọ aghaghẹ kaya nu wọ, si,
\v 8 “Ajiya ri ni ibẹlẹ bọ yọ na ka jọọ mi kọ, ni ikwyi bọ shi atọọ kini imẹ,
\v 9 ijirija wọ na asọ jọọ mi wọ, aka mẹẹ umẹẹ bajiya kọ taa upii Ọnọng.’”
\v 10 IYesu va yọrọ ajiya nga kukushi nga ki tẹri bọ si, “Inu kọng ki inu kpẹlẹ,
\v 11 Ba imumani ika ghila anyu ajiya yọ ka sa nga irighe ba, si imumani ikunu ka anyu nga yọ ka sa nga ‘irighe’”
\v 12 Atina nga va ba ki ghulu nga si, “Ingọ ye si aFarisiyawa kọọ anaa kọ nọ upii ri?”
\v 13 IYesu va yira ki ju si, “Nadidu upila mani ba ate mi ka aYaya nga pila ba ni, aki yẹẹ kọ ka akang.
\v 14 Ya bọ ya; afoo bọ aghọ uyeni afoo itra. Insi afoo kpẹnẹ ace afoo ka ashi ni, nadidu bọ ni, aki kpaa kidẹ uhwo.”
\v 15 Ni iBitrus ba ju nga si, “Nyeni ayọ idi ighang upii.”
\v 16 IYesu ba ju nga si, “Ki ta ka aikyua ri ni inu ta kọ kpẹlẹ nọ ba?
\v 17 Inu ta nu nọ ni nadidu imumani ighila idẹ anyu ka wor kyaa yọ idẹ afo ki va kunu yọ kidẹ ẹrẹnọma ba?
\v 18 Ni imumani ikunu kidẹ anyu ba kidẹ ikwyi wọ, iyọ ka sa ajiya irighe.
\v 19 Ki idẹ ikwyi yọ ni uwang uju akakiya, kina upili ajiya, uwang ayiri kọ aghimi bajiya, uju uma ẹrẹnọma, uyi, uma upii atẹri kaya ace aghọ kọnọ ubra uca aghọ.
\v 20 Umumani uka sa ajiya irighe budibi. Ula ni avọ umani ahwuru bọ ba ka sa wọ aghọ irighe ba.”
\s1 Uma Aipang Ayiri AKan’ana
\r (IMar 7.24-30)
\p 
\v 21 IYesu va sang nga kukadu ki kyaa ishii aTaya kina aSidon.
\v 22 Ashi kukadu ni, ace ayiri agha aKan’ana ba ukushi nga na asọ ci, “Kọng ahwoo mi, Ate, Anọ iDauda; ushẹẹ ghila anọ mi anayiri na asọ kọng ọlọ nagigang.”
\v 23 IYesu ta pẹni ni ngaa ba. Ni atina nga ba ki ba sọrọ nga si, “Kla nga! Ka asọ ci na duma ayọ kọ.”
\v 24 Aba yira si, “A tọrọ tuma mi si iya wang atẹm na avulu bọ kidẹ ọna Israila kọ.”
\v 25 Ni ava ba ki ba ta agho kite nga, si, “Ate, sẹ mi kọ.”
\v 26 Na ava yira si, “Ushi wọ nọ uyeri na akpaa imila anọ ka ama ava ba.”
\v 27 Ayiri ba ju si, “Ẹẹ, Ate, ava ma ka la awo umani akpara ki ẹrẹbọ ka imila ate ọna.”
\v 28 IYesu ba yira nga si, “Ayiri, uma aipang ngọ shina ẹrẹkyuọ! Taani uba kọnọ uwang ngọ ni.” Anọ nga anayiri ba akyuọ ka akyua ra.
\s1 IYesu Lẹni na Ajiya na Pam
\p 
\v 29 IYesu sang nga kukadu ki ko nga abẹni ẹrẹyẹma aGalili. Aba kila nga aya ọpang kiya cica.
\v 30 Ikir bajiya va ba ukushi nga, aba nga na agunu, afoo, aghọ uwẹni ifra, agbatọng na abẹbẹ, kina aghọ shẹẹ, ki ba kyo bọ kite nga, aba ma bọ ọkyuọ,
\v 31 ki ta kọ umani ikir bajiya nga wo ica nọ umani agbatọng sọ pii, aghọ uwẹni ifra ni, ika bọ ba na ẹrẹkyuọ, agunu kyeng, afoo sọ kyoo uka. Ni aba jọọ Ọnọng Israila.
\s1 Ucee Ajiya Araji Usọ Anari
\r (IMar 8.1-10)
\p 
\v 32 IYesu ba yọrọ atina nga ki ju bọ si, “Imẹ hwiri ahwoo bajiya ri ka akọ la awii atai kini imẹ, ata kọ la bọ ighima ba. Imẹ wang mi nu vuu kini bọ ni idafo bọ ba, ka abọ ta na ya kpaa kọ utra.”
\v 33 Atina nga ba ju nga si, “Ọkọ ta ajiya ri, abi wu ni ayọ ki peni ubiredi umani ayọ ki cee ajiya ri wọ?”
\v 34 Ni iYesu ba ju bọ si, “Ubiredi umi wu ni inu sọnọ wu?” Asi, “Utinsara, kina anọ itagbo na zẹẹ.”
\v 35 Aba sa ajiya nga na acica ki ẹrẹbọ,
\v 36 aba kpaa ubiredi utinsara kina itagbo, aya kpẹẹ usa Ọnọng izaa ni, aba wra ki ma atina nga, atina nga ba ma ajiya.
\v 37 Kwinga la ki suu, atina nga ba tira awo mani ashẹ ki sa kọ ọkọọ utinsara ki tii wọ.
\v 38 Aghọmani ala ni ashi aghimi araji usọ anari ki tọ kpaa ayiri kina ananọ.
\v 39 Aya shira ajiya nga ni, aba ghila idẹ ọgbọlọ ki kyaa ishẹẹ aMagadan.
\c 16
\s1 Uwang Amaa
\r (IMar 8.11-13; ILuk 12.54-56)
\p 
\v 1 AFarisiyawa kina aSadukiyawa ba ukushi iYesu ka aba mra nga, aju nga si anyeni bọ amaa ka ayaya.
\v 2 Aba yira bọ si, “Insi uka ba ughẹ ni, inu ka ju si, “Uka ki shi uduma, ka ayẹrẹmọọ shi na kyọng.’
\v 3 Ni ikyuatii ni, “Aviya ki kpaa kaidii, ka ayẹrẹmọọ shina kyọng kọnọ uyuu.’ Inu ka kpẹlẹ ushii ayẹrẹmọọ, ni inu ta ki bọra nọ ukpẹlẹ amaa akyua ba.
\v 4 Agha akakiya kini aghọ yẹẹ na ayiri kọ aghimi mani ashi angọ ba bọ ka wang amaa, ba amaa na aki nyeni nu iba si anga iYunusa ba ni.” Aba ya bọ ya ki sang nga.
\s1 Uyisti AFarisiyawa kina aSadukiyawa
\r (IMar 8.14-21)
\p 
\v 5 Atina iYesu ya fuma udaa ugẹẹ ọghọng ni, aba kpẹlẹ si ibọ yuu ubiredi wọ.
\v 6 IYesu ba ju bọ si, “Inu sa ica nu ci nazizal ki inu ye na uyisti aFarisiyawa kina aSadukiyawa.”
\v 7 Aba tee aghọ pii kina acee bọ, si, “ta mani ayọ ta ba yi nọ uce ubiredi wọ ba.”
\v 8 Ni iYesu, ye imumani asọ pii ni, iYesu va tẹri bọ si, “Inu aghọ uma aipang na zẹẹ, ikẹmbọ sa ni inu sọ pii kina acee nu kọ ta ubiredi?
\v 9 Inu kọ kpẹlẹ nu ba? Inu ta shuni nu mani imẹ cee ajiya araji usọ atọ kini ubiredi utọ ba, kọnọ umani ọkọọ ume tii na acuru?
\v 10 Kina ubiredi utinsara ka ajiya araji usọ anari, kina ọkọọ ume tii na acuru?
\v 11 Ikẹmbọ sa ni inu ta kpẹlẹ nu si ita pii mi kaya ubiredi ba? Inu sa ica ka uyisti aFarisiyawa kina aSadukiyawa.”
\v 12 Asa kpẹlẹ si ata tẹri bọ si asa ica na uyisti idẹ ubiredi wọ ba, ni asa ica ka umẹẹ aFarisiyawa kina aSadukiyawa wu.
\s1 IBitrus Nyeni si IYesu nga shi UKristi
\r (IMat 8.27-30; ILuk 9.18-21)
\p 
\v 13 Akyua ni iYesu ya fuma ishii aKaisariya aFilibi ni, aba ghulu atina nga si, “Inga ni ajiya sọ tẹri si Anọ Ajiya shi?”
\v 14 Aba ju si, “Ace aghọ bọ si iYahaya aghọ uju iminimini, ace aghọ bọ si, Iliya, ace aghọ bọ si Irimiya ko agha yeng kidẹ aghọ pii kọ ọtọ Ọnọng.”
\v 15 Aba ju bọ si, “Inu ni, inga ni inu si imẹ ashi?”
\v 16 IBitrus ba yira si, “Ingọ si uKristi, Anọ Ọnọng agha akyuọ.”
\v 17 IYesu ba yira nga si, “Ingọ ni agha anyu adaduma ngaa iSiman anọ iYunana! Ki ba ajiya na ayi nga nyeni ngọ udii ba, ate mi ka ayaya nga nyeni ngọ.
\v 18 Imẹ sọ va tẹri ngọ, ingọ si iBitrus, ka ya upa ri wọ ni imẹ ki vura ọna mi kọ, ni akyuọ ukpo ki shi wu na akyuọ kaya nga ba.
\v 19 Imẹ ki ma ngọ aca ẹrẹgọm ayaya, nadidu imumani inu lor ka ya asing ni, kindii wu ni alor kọ ka ayaya, nadidu imumani ashii ka ya asing ri ni, aki shii yọ ka ayaya.”
\v 20 Aba waa atina nga atọng nagigang si aba tẹri aghọ si anga si uKristi ba.
\s1 IYesu Tẹri Ighọ Ukpo Nga
\r (IMar 8.38; 9.1; ILuk 9.22-27)
\p 
\v 21 Kọ kpaa ka akyua ra ni, iYesu tee aghọ nyeni atina nga si iyiya ni inga ki kyaa Urushelima, ka aya kọọ ọlọ kukushi akwite kina afirist akakọng kina aghọmẹẹ umẹẹ iMusa, ka aba pii nga kọ, awii itai ni, aki sisang.
\v 22 IBitrus ba kpaa nga ki kyaa uhwo wọ ki ya gẹr nga si, “Ọnọng kpaa kọ, Ate! Udii ki ba ngọ nga ba.”
\v 23 Ni aba tee ki tẹri iBitrus si, “Sang ngọ kukushi mi, Ishẹẹ! Ingọ ni ima usa ukpaa yọ kukushi mi. Ingọ ka ghulu ikwyi ngọ kina ajiya nga ni, basi Ọnọng ba.”
\v 24 IYesu ba tẹri atina nga si, “Nadidu aghọmani awang yii mi ni, sa azọnọ tọrọ nga irikwyi nga ka kpaa ugara ushi nga ka yii mi.
\v 25 Ka aghọmani awang foo ọkyuọ nga ki taa wọ, ni aghọmani ataa ọkyuọ nga kaya mi ni, aki peni wọ.
\v 26 Ikẹmbọ sọ uduma umani ajiya ki peni ashi nadidu kọ taa ọkyuọ nga? Ta ikẹmbọ ni ajiya ki ma kọ ta ọkyuọ nga?
\v 27 Ka Anọ ajiya ki ba kina atuma nga kidẹ ujọọ Ate nga, ukadu wu ni aki piya kwinga utina mani aju kọ.
\v 28 Aipang ni isọ tẹri nu, ace aghọ bọ ting ya kọ kẹẹ ni ata ki kpo bọ nga ba sa anu uba Anọ ajiya kidẹ ẹrẹgọm nga.”
\c 17
\s1 Utee Ushi IYesu
\r (IMar 9.2-13; ILuk 9.28-36)
\p 
\v 1 Awii atin ya wor bọ ni iYesu va kpaa iBitrus kina iYakubu kina iYahaya, anayuru nga, ki kyaa ni bọ kaya ọpang utitugu kayu bọ.
\v 2 Ushi nga ba tee kite bọ, ibate nga sọ ma uyeri kini ọnọng taa ni, ugbang uko nga ba kọ ufufuu na tas.
\v 3 Kidẹ akyua ni iMusa kina Iliya kunu kite bọ na asọ pii kini iYesu.
\v 4 IBitrus ba tẹri iYesu si, “Ate, ọsọ uduma nọ umani ayọ shi kukadii, insi ingọ yira ni, imẹ ki ta uzọọ utai. Iye inga ngọ, iye inga iMusa, iye ni, inga Iliya.”
\v 5 Ashi kidẹ upii ni ace amọ na pipar ba yuru bọ ya, ni aba kọọ ice ẹrẹwyuẹ kidẹ amọ si, “Anọ mi wẹ angọ umani imẹ yoo, ika kọọ uhwai nga nagigang; inu kọng ngaa!”
\v 6 Atina ya kọọ kindii ni, aba kpaa ki fuga ubate bọ ki ẹrẹbọ ni ẹrẹbata.
\v 7 IYesu va ba ki ba piya bọ si, “Sisang, ba kọọ ẹrẹbata ba.”
\v 8 Aya zẹẹ ubate bọ ka yaya ni, ata nu bọ ace aghọ ba si iYesu kayu nga.
\v 9 Asọ shulu kaya ọpang ni, iYesu ba waa bọ atọ si, “Ba tẹri ace aghọ imumani inu nu ba, sa Anọ Ajiya sang kọ ukpo.”
\v 10 Atina ba ghulu nga si, “Ikẹmbọ sa ni aghọmẹẹ iMusa si sa Iliya kyọ ba?”
\v 11 IYesu ba yira si, “Iyiya ni sa Iliya ba, aki ba ker kwikẹ.
\v 12 Ni imẹ sọ tẹri nu si Iliya kọ ba, ni ata kpẹlẹ bọ nga ba, aju nga ima uwang bọ. Kindọ wu ni Anọ Ajiya ki kọọ ọlọ wu ki ivọ bọ.”
\v 13 Atina sa kpẹlẹ si asọ pii ni bọ kaya iYahaya aghọ uju iminimini.
\s1 IYesu Ma Anọ shi nọ Ushẹẹ ọkyuọ
\r (IMar 9.14-29; ILuk 9.37-43a)
\p 
\v 14 Aya fuma uka ikir bajiya ni, ace ajiya va ba ukushi nga ki ba ta agho kite nga,
\v 15 ki ju si, “Ate, kọ ahwoo anọ mi, asọ kpira itahwu na aka kọọ ọlọ nagigang. Akyua nagigang ni aka kpra kidẹ ugha kina amusum.
\v 16 Imẹ ba ni nga kukushi atina ngọ ni ata bọra bọ uma nga ọkyuọ ba.”
\v 17 IYesu ba yira si, “Inu ajiya akyakyua ri, aghọ umani aka ma bọ aipang ba kina agha akakiya, agba akyua wu ni imẹ ki ci kini inu wu? Agba akyua ni imẹ ki mọr ni inu? Ba ni anọ kukushi mi.”
\v 18 IYesu ba gẹr ushẹẹ nga, aba kunu ki ẹrẹnọma nga, anọ va ba akyuọ kidẹ akyua.
\v 19 Atina iYesu va ba ukushi nga ku yuyi, ki ba tẹri nga si, “Ikẹmbọ sa ni ayọ ta biya bọ uwoo ushẹẹ ba?”
\v 20 Aba ju bọ si, “Uma aipang nọ shi na zẹẹ. Aipang, imẹ sọ tẹri nọ, insi inu shi na uma aipang na zẹẹ kini ikir ikpo ni, inu ki tẹri upang ri si, ‘Yini kọ kẹẹ kọ kya ngọ ukaa,’ ni uki yini, ba imumani inu ki biya nu ju ba.
\v 21 Idi ighọ ri ka kunu yọ ba sa apii nọ Ọnọng kina ukpẹnẹ anyu.”
\s1 IYesu Khimi Upii kaya Ukpo Nga
\r (IMar 9.30-32; ILuk 9.43b-45)
\p 
\v 22 Aghọyii iYesu ya curu ka aGalili ni, aba ju bọ si, “Aya sọ ma Anọ Ajiya kidẹ ivọ bajiya,
\v 23 aki pii nga kọ, awii itai ni, aki sisang.” Ni aghọyii nga ba duma nagigang.
\s1 Ubiya Agonu ka Ọna Ọnọng
\p 
\v 24 Aya ba aKafarnahum ni, aghọ yira agonu ọna Ọnọng ba peni iBitrus ki ju si, “Aghọmẹẹ nu ka biya agonu ọna Ọnọng?”
\v 25 Aba ju si, “Ẹẹ.” IBitrus ya ba idẹ ọna ni, iYesu ba kyọ pii ni nga, si, “Ikẹmbọ shi unu ngọ, iSiman? Kukushi inga wu ni agọm asing ka yira agonu wu? Kukushi anọ bọ ta ace aghọ bọ?”
\v 26 Aya ju si, “Ace aghọ bọ,” ni, iYesu ba tẹri bọ si, “Unyeni si, anọ bọ ka biya bọ ba.
\v 27 Kindii ni, ka ajiya ri ba kọọ anaa wọ ba ni, kya ngọ ẹrẹyẹma kọ ya fẹni ima uhwiri itagbo, kọ fumu anyu itagbo nọ ingọ kyọ kpẹnẹ, insi ingọ fumu anyu ni, ingọ ki nu ufe mani ọki maa ubiya, kpaa ufe kọ ya biya agonu mi kini ngọ.”
\c 18
\s1 Inga Cẹri nọ Ughọghe ki Ẹrẹgọm Ọnọng?
\r (IMar 9.33-37; ILuk 9.46-48)
\p 
\v 1 Ka kyua ra ni Atina Ọnọng ba ukushi IYesu na sọ wulu nga si, “Inga nga gina nọ ughọghe kidẹ ẹrẹgọm ayaya?
\v 2 Avasa yọrọ ace ananọ, ki kyọ nga ka biyating bọ,
\v 3 Atẹri bọ si, “Iyiya ni isọ tẹri nọ, sọ nu tee ki ba kina ananọ bọ ni, inu ki ghila nọ ẹrẹgọm ayaya ba.
\v 4 Kindọ ni, aghọ mani akpaa irikwyi nga na kikya kini ananọ ri ni, anga cẹri kọnọ ughọghe ki ẹrẹgọm ayaya.
\v 5 Aghọ mani ayira Ananọ kini adi kidẹ nọ ca mi ni, aghọ yira mi.”
\s1 Uma Usra Ukpaa
\r (IMar 9.42-48; ILuk 17.1-2)
\p 
\v 6 Kindọ ni aghọmani asa agha yeng kidẹ anọri na yira mi ukpa afra ni, ọki gina aghọmani ata aning kọ umọghọ nga kini utii uhwọ, ka fẹni nga kidẹ ọghọng ukyukyugu.
\v 7 Ọlọ nu agha aya asing kọnọ umumani ọki sa nu ukpa! Iyiya yọ ni uma usa ukpa ki ba, Ọlọ nu aghọmani anga ki sa ukpaa.
\v 8 Insi avọng kọ afrang ki sa ngọ ukpaa ni, usọ waa kọ nau. Ọki gina ngọ nọ mani ughila ọkyuọ kina afra ta avọ ayeng, ta ushi agunu kọnọ mani afeni ngọ kidẹ ugha mani ọka kpou ba kini ivọ ipai ta ifra ipai.
\v 9 Ipeni ica ngọ ki sa ngọ ukpaa ni, nọsọ wo yọ kọ na kọ. Ọki gina ngọ nọ mani upeni ọkyuọ taa amaa kini ica iyeng, nọ mani afeni kọ ọna ugha ni ica ipai.”
\s1 Aghing Upii Atẹm umani a Vulu kọ
\r (ILuk 15.3-7)
\p 
\v 10 Unu sa amaa kọ, unu ma jer ace aghọ kidẹ ananọ ri ba, ka isọ tẹri nọ, Atuma nga ka yaya akyo aghu ibẹtẹ Ate mi mani ashi ka yaya.
\v 11 Ka anọ ajiya ba ka ma foru agho mani avulu bọ.
\v 12 Ikẹmbọ nunu kidẹ ikwyi, ipeni aghọcee ashi kina atẹm aji, ayeng kidẹ bọ vasa vulu, akiya ushe ishui larọshọ na larọshọ kayi itili asha larla asọ ya wang ayeng mani avulu ba?.”
\v 13 Ipeni apeni nga ni, aipang ni sọ ter nọ, ikwyi fuu mani aju kaya ẹrẹkwẹ nga ni, ọgina ngọ ishui larọshọ na larọshọ mani ata vulu ba.
\v 14 kindi wu ni, bọ uwang Ate yi aghọ mani ashi ka yaya ba na agheyeng kidẹ ananọ ri na vulu wu ba.”
\s1 Ipeni Anayurung ju ngọ avulu ni
\r (ILuk 17.3)
\p 
\v 15 In peni anayuru ngọ vulu ngọ ni, kya ọkọ shi nga kọ ya nye ni nga si avulu, ngọ kini inga ka pai nọ. In peni akọng ngọ ni, ọva vughu ni ngau du.
\v 16 Ipeni atọrọ ni, usọ va kya ukushi nga kina ajiya ayeng ta agha apai ka ma aipang nọ upii ka anyu agha apai ta agha atai.
\v 17 Ipeni anayuru ngọ tọrọ kọng bọ ni, ọsọ tẹri Ajiya ọnọng, insi atọrọ kọng ni asọ kyọghu nga kina aghọ mani aghọmani ashi bọ aYahudawa ba ni, kọ aghọ yira agonu.
\v 18 “Iyiya ni sọ ter nọ, du inga mọ mani unu lor kaya sing ni, alor yọ ka yaya. Du imumani unu shighi kaya asing ri ni, a shighi yọ ka yaya.
\v 19 Isọ tẹri nu aipang si, ipeni agha pai kidẹ nọ yira si abọ ki shọr icima ni, Ate mi mani ashi ka yaya aki ju nu.
\v 20 Ki du ọkọ mani agha apai ta agha atai acuru kọ ki dubọ uca mi, ishi kini bọ.
\s1 Atuma mani akara yira ọlo kpaa ba
\p 
\v 21 Ashi kidẹ udu ni iBitrus vasa ba ki ter IYesu si, “Ate ayaya, iri mẹ kọ na anayuru bọ vulu mi kọ ni sọ ya nga ya? Iri ti ni sara?”
\v 22 IYesu vasa ter nga si, “Ba iri ti ni sara wu ba, iri ti ni sara si ishuitini sara.
\v 23 Kindọ ni, aki mara ẹrẹgọm ayaya kini ace agọm mani awang pila upẹni nga mani ushi kidẹ vọ agira nga.
\v 24 Agọm ya lite nọ pila ni, avasa ba nga kina ace ajiya mani ayii nga uta azurfa asọ mani aghọ ki bra ubiya ba naidu ọkyọ ghọ nga.
\v 25 Ara bra vughu nu ufe ba ni, Agọm vasa ju si agbira ngau kina ayiri nga kina anọ nga kini imu mani ashi kini yọ ka ma nga ufẹ.
\v 26 Agira nga vasa ta agho kite nga ki te si, ‘Aju nga akuri, inga ki ma nga akwikẹ.’
\v 27 Agọm vasa kọng ahwo agira nga, avasa sheri nga, aya nga uta ya.
\v 28 “Na agira nga ni kọ kunu nga kọ kadu ni, avasa ta ẹrẹkwyuẹ na ace aghikyo utina nga mani ayii nga uta adinari naji ni, avasa kpẹnẹ kọ umọghọ ki ter nga si, ‘Ma mi ufe mi.’
\v 29 Aghikyo utina nga kpikpo ki shọr nga si aju nga ahwoo, inga nga ki ma nga.’
\v 30 Ni agira nga vasa tọrọ, avasa ya hwuru nga kọ ubọọ iting, sa ma nga uta nga.
\v 31 Aghikyo utina nga ya kọng imumani ibani ni, ara kọng bọ ọduduma ba. Avasa ya tẹri Agọm ya naidu imomani iba.
\v 32 Agọm vasa yọrọ agira nga ki tẹri si, ‘Ingọ agira ighọ ibibi yọ. Iya ngọ uta ya ki Ọshọr mi.
\v 33 Ọngọ ki kọng ngọ ahwo aghikyo utina ngọ kọnọ mani ikọng ahwo ngọ ba?’
\v 34 Agọm kọng anang naigang, aju si ama nga ọlọ sa biya uta nadidu.
\v 35 Kindi wu ni Ate mani ashi ka ayaya ni aki ju akwinga kọ mani atọrọ ukpaa avulu anayuru nga kọ kini ikwyi yeng.”
\c 19
\s1 Umẹẹ IYesu kaya Upii Ubiya
\r (IMar 10.1-12)
\p 
\v 1 IYesu ya kpẹr tẹri udubi umani, avasa ya ifọng aGalili ki ghila ishii aYahudiya, ki ugẹẹ ẹrẹyẹma Urdun.
\v 2 Ajiya nagigang vasa yii nga, avasa lẹni na adumu kọ kadu.
\v 3 Ukadu ni, ace aFarisiyawa vasa ba ukushi nga ka mra nga, aghulu si, “Ọshi na kikya ni Ajiya shẹri ayiri nga ka kwaligba ighọ avulu?”
\v 4 Avasa yira bọ si, “Unu sọnọ pila nu kidẹ upii Ọnọng si, aghọ mani aju yi kọ kpa ka kyua ‘aju bu aghimi kini ayiri’ avasa tẹri si,
\v 5 ‘Kindọ ni, Ajiya kiya ate nga kina ayuru nga ka dẹẹ ayiri nga, ka pai bọ ni aki tẹẹ agha yeng ra.’
\v 6 Aki sọ tẹẹ bọ agha pai ba, sa tẹẹ kini agha yeng ra bọ. Kindọ ni, ima mani Ọnọng dara kọka uyeng ni ajiya ma bara ba.”
\v 7 Avasa tẹri nga si, “Ikẹmbọ sa ni aghọ mẹẹ iMusa si aghimi ma ayiri nga awọ upii ubiya, ka va kla ayiri?”
\v 8 IYesu vasa tẹri bọ si, iMusa tẹri nu si ukla ayiri nu kindu ki Ikwyi ugboho yọ ni ushi ni yọ. Kọ kpaa ka kyua ni bọ shi wu du ba.
\v 9 Imẹ sọ tẹri nọ, nadidu aghọ mani asher ayiri nga ni, insi ara Peni bọ nga kina avulu nyẹri na aghimi ace aghọ ba ni, insi avo ace ayiri ni aju avulu ayeng ra.”
\v 10 Atina nga vasa tẹri nga si, “Insi ushi wu du kukushi aghimi kina ayiri nga ni, uci ba uvo ayiri cẹri.”
\v 11 Avasa tẹri bọ si, “Ba kwyi nga-nga ki bọra kpaa upii ri ba, sa agho mani Ọnọng ma bọ udu.
\v 12 Ace aghọ shiwu ni a jee bọ na ki bọra bọ voru ayiri ba. Ace aghọ ni Ajiya bọ ju bu ududu. Ace agho ni abọ yira si aki voru bu ayiri ba ka yọghu upii ẹrẹgọm ayaya. Nadidu aghọmani abọra ukpa upii ri na kpa.”
\s1 IYesu Sa Ananọ Ọfisi Anyu Adaduma
\r (IMat 10.13-16; ILuk 18.15-17)
\p 
\v 13 Ukadu ni avasa ba IYesu na ananọ ọfisi ka sa bọ anyu adaduma, kiva shọr Ọnọng kaya akwyi bọ, ni aghọyii nga vasa gẹr aghọmani aba na anọ kọ.
\v 14 IYesu vasa tẹri bọ si, “Inu ya ananọ ka ba ukushi mi. Uma kla bọ ba, ki ẹrẹgọm ayaya ni inga ighọ bọ kọ.”
\v 15 Avasa sa bọ anyu adaduma, avasa wolu.
\s1 Anọfọnọ nọ Upeni
\r (IMat 10.17-31; ILuk 18.18-30)
\p 
\v 16 Ashi kọ kadu ni ace aghọ vasa ba ukushi IYesu ki ghulu si, “Aghọ mẹẹ, igba ima ididuma yọ ni imẹ ki ju ki peni ọkyuọ taa amaa?”
\v 17 IYesu vasa tẹri nga si, “Ikẹmbọ sa ni ingọ wulu mi imumani ishi ididuma. Insi uwang peni ọkyuọ taa amaa, isọ ju uma tẹri mi.”
\v 18 Avasa ghulu IYesu si, “Iligba itali yọ?” IYesu vasa tẹri si, “Ba pii ajiya ba, ba wang ayiri ajiya ba, ba yi akpara ajiya ba, baa gyo ateri kaya ẹrẹkwyuẹ ajiya ba,
\v 19 Kọng ate ngọ kina ayuru ngọ atọng. Ọsọ yoo aghikyo ucing kọnọ mani yoo irikwyi ngọ ni.”
\v 20 Anọfọnọ vasa tẹri nga si, “Imẹ kọ ju umari nadidu, ikẹmbọ shi kọ lara mi kọ?”
\v 21 IYesu vasa tẹri si, “Insi uwang tee aghọ taa avulu ni, usọ ya gbra nadidu upeni nngọ wọ, kọ ma aghila amir, ọki peni ọka ngọ ka yaya. Ni ọsọ ta ba kọ ma yii mi.”
\v 22 Anọfọnọ ya kọng kindọ ni, vasa wolu kinọ bọra ikwyi, ka shi nọ upeni nagigang.
\v 23 IYesu vasa tẹri Atina nga si, “Iyiya ni isọ tẹri nọ, Ọki shi nọ lọ mani aghọlọ upeni ghila ẹrẹgọm ayaya.
\v 24 Isọ va tẹri nọ, uki shi uyuyo ni ọrahimi ghila anyu anyura nọ mani a aghọlọ upeni ghila ẹrẹgọm Ọnọng.”
\v 25 Atina nga ya kọng kindọ ni, avasa kọng ẹrẹbata, ki ju si, “Inga na aki foo nga?”
\v 26 IYesu vasa kyoo bu na vasa tẹri si, “Ka ajiya ni udi ki ju wu ba, ni ukushi Ọnọng ni kọ iligba ima ọngọ yu yọ.”
\v 27 iBitrus vasa tẹri si, “Uwẹ ni iyi ya akwikẹ ya ki yii ngọ, ikẹmbọ shi ya ni iyi ki peni?”
\v 28 IYesu vasa tẹri bọ si, “Aipang ni imẹ sọ tẹri nọ, asing ki ba ni, akyua mani anọ ajiya ki cica ki igọ ujọọ nga, inu aghọ mani inu yii mi ni, inu ki cica ki igọ ẹrẹgọm shọ ni iri pai, kọ ju ite shọ nọ upai ra ngọ Israila ashuwa.
\v 29 Ni aghọmani aya ẹrẹna ta anayuru aghẹmẹ, ta anayuru ayiri, ta ate, ta ayuru, ta anọ, ta uja, ka jọọ uca mi, aki peni ka gina kindọ sa aji, ka va peni ọkyuọ ọgbang ọngọ taa amaa.
\v 30 Ka ajiya nagigang aghọ mani ashi kite, aki tee aghọ tumu, aghọ tumu ki tee aghi ite.
\c 20
\s1 Ighang Upii Aghọ Tina kọ Ute Inabi
\p 
\v 1 Ẹrẹgọm ayaya shi kina aghọ ọna nga mani akunu ka tee ting, ka ya wang aghọ utina kaya ju nga utina ki ija nga inga ikọlọ na shi inabi.
\v 2 Aya tẹri izẹ nọ ufẹ kọnọ mani aka ma aghọ ju utina ka awii ni, avasa ya kyọ bu ki ija nga.
\v 3 Ọshi a kyua larọshọ avasa kunu, ki nu ace aghọ na sọ ci ijirija ka nyu ọkọ ju izẹ,
\v 4 Avasa tẹri bọ si, ‘Inu kya ija mi, iki manọ ima mani ishi ikikya.’ avasa wolu.
\v 5 Avasa va kunu kina atinọng, kọnọ ọsii a kyua atai, avasa kpa aghọ utina.
\v 6 Kọta aikyuari a kyua atọng ava kunu ki nu ace aghọ na ci bọ ju icima, avasa tẹri bọ si, ‘Ikẹmbọ sa nọ ci ijirija kọ ghọwa ni?
\v 7 Avasa tẹri nga si, ‘Ace aghọ ta mayi utina ju ba.’
\p “Avasa tẹri bọ si, ‘Unu ma kya ija mi kọ ya ju utina.’
\p 
\v 8 “Ọghe ya ju ni, aghọ ute vasa tẹri aghọ shẹ ngau si ọsi ica nọ utina ija, ‘Yọrọ aghọ utina kọ ma bọ ufẹ bọ, kpa ka aghọ tumu kọ ba ngọ ite kọ.’
\v 9 Aghọmani aba akyua atọng ọghe vasa ba, kọ inga bọ yira ima mani iju na ma nga kọ wiya ni.
\v 10 Ni, aghọ mani akyọ ba ni ahuri kini aki mani ka gina ushe kọ ni, kọ inga bọ yira kini mani akpa nga utina ni.
\v 11 Aya yira ni, avasa dee kọ tẹri aghọ ọna anọrọma,
\v 12 Na sọ tẹri si, ‘Aghọ mani ba kọ tutumu, utina akyua ayeng kọ na ju, nọ ma bọ iki-kya kini yi, iyi aghọ mani awiya kọ ju utina kini ọla ọnọng.’
\v 13 “Avasa yira agha yeng kidẹ bọ si, ‘Ayikyo mi, ira lami akpara ngọ ba. Iyi ta ju yi si iki ma ngọ ufẹ ka wii ba?
\v 14 Yira ima mani ishi nga ngọ nọsọ wolu. Imẹ yoo ma aghọ mani aba kọ tutumu iki-kya kina ima mani ima ngọ.
\v 15 Ishi mi ni akyuọ ju imumani iwang ju nọ ufẹ mi ba? Tọ ingọ hwiri anang kọ niu mani ika ma ajiya uma nagigang?
\v 16 “Kindi wo ni aghi utọ tumu ki tẹ aghọ ite, aghọ ite ki tẹ aghọ tumu.”
\s1 IYesu va Tẹri Ighọ Ukpo Nga
\p 
\v 17 IYesu ya sọ kya Urushelima ni, avasa yuru atina nga kọ uho ki tẹri bọ si,
\v 18 “Ọwe ni, iyi ki kya yi Urushelima. Aki ma anọ Ajiya ki vọ ifirist ighighẹ kina aghọmẹẹ iMusa, aki va wa nga ashuwa ukpo
\v 19 akyua rau aki ma nga ki vọ aghọmani ashi bọ aYahudawa ba, kaa kali nga, kaa ca nga, kaa agra nga ka yọ ukumu ọshẹ, awii itai ni aki sang nga ka akyuọ.”
\s1 Ọshọr Ayuru IYakubu Kini IYahaya
\r (IMar 10.35-45)
\p 
\v 20 Akyua rau ni Ayuru anọ iZabadi vasa ba ukushi IYesu kina anọ nga ki ba ta agho kite nga, ki shọr nga icima.
\v 21 Avasa tẹri nga si, “Ikẹmbọ nọ wang?” avasa tẹri nga si, “Ngọ sa anọ mi ri apai ka cica, ayeng kavọ ilang, ayeng kavọ iprọma ngọ, ki ẹrẹgọm ngọ.”
\v 22 “Uyeng ima mani ọsọ ghulu ba,” IYesu tẹri bọ. “Inu ki bọra sa kọ asọng mani imẹ ki sa kọ? Ava yira si, “Iyi ki bọra.”
\v 23 IYesu tẹri bọ si, “Inu ki sa kọ asọng mi, ni ucica kavọ ila mi ni kọ iprọma mi ni ba imẹ ki ma ba. Ate ayaya kyo ukadu ka aghọ mani ahwiya.”
\v 24 Ushe atina ọshọ ya kọng kindọ ni, avasa kọng anang anayuru apai.
\v 25 IYesu vasa yọrọ bọ nadidu bọ ki tẹri si, “Inu ye mani agọm mani ashi bọ aYahudawa ba ka nyeni ẹrẹgọm kukushi ajiya bọ ni, agha kakọng bọ ka nyeni ẹrẹgọrọ kukushi bọ.
\v 26 Ọki shi wu kindọ ukushi nu ba. Udu ni aghọ mani tee agha ghaghẹ kidẹ nọ ni, iyiya yọ ni atee agira kidẹ bọ.
\v 27 Ni aghọ mani awang tee akwite kidẹ nọ ni, iyi ya ni aki shi agira nọ
\v 28 Kindọ Anọ Ajiya aki ba ka ma ju nga irigira ba, si nga ki ju Ajiya irigira, Ka va ma ọkyuọ nga kaya ajiya napam.”
\s1 Afoo Apai Peni Kyoo Ọka
\r (IMar 10.46-52; ILuk 18.35-43)
\p 
\v 29 IYesu kina atina nga ki ya aYeriko ni, ajiya nagigang vasa yighi nga.
\v 30 Ace afo apai na ci ka nyu tira, Aya kọng ni IYesu wọlu ni, avasa shang ẹrẹwyuẹ ki tẹri si, Ate ọna, Anọ iDauda! kọng ahwoo yi!”
\v 31 Ajiya vasa gẹr bọ avasa kọmọ nai kiri. avasa shang ẹrẹwyuẹ na tẹri si, “Ate ọna, Anọ iDauda! Kọng aho yi!”
\v 32 IYesu vasa titara ki yuru bọ, ikẹmbọ nọ wang si ju nu?”
\v 33 Avasa tẹri si Ate, iyi peni ukyoo uka.”
\v 34 IYesu va kọng ahwo bọ, IYesu vasa piya ica bọ. Ana kyua ra ni avasa tee aghọ kyoo, avasa yii nga.
\c 21
\s1 IYesu Ghila Urushelima Kaya Izaki
\r (IMar 11.1-11; ILuk 19.28-40; IYah 12.12-19)
\p 
\v 1 Aya ba ayayo kọnọ Urushelima ka aBetafaji ka ya izizẹ ashi uZaitun ni, iYesu ba tuma atina nga apai,
\v 2 atẹri bọ si, “Inu kya anọ ifọng na ashi kite nu, kọ kyaa nu ni, uki ya nu na alor izaki kina anọ nga. Shii bọ kọ ba ma mi kọ ukawẹ.
\v 3 Insi aghọ ghulu ni, inu tẹri nga si Ate nga wang bọ, aki vuu ni bọ kọ na song.
\v 4 Udii ba kọ hwura upii aghọ pii kọ ọtọ Ọnọng si,
\v 5 “Inu tẹri anirayiri aSihiyona, ‘Nu, agọm nu wẹ na aki ba ukushi nu, nọ usuu irikwyi kaya izaki, kaya anọ izaki wu na akyeng kọ.’”
\v 6 Atina wor ki ya ju imumani iYesu sa bọ uju.
\v 7 Aba nga na izaki kina anọ, aba yaa ugbang bọ kaya, iYesu va kiya ki cica.
\v 8 Ajiya na pam yaa ugbang bọ kọ utra, ace aghọ bọ ni akẹr afa aga ashẹ ki yaa kọ utra.
\v 9 Ajiya upam na kyeng kite nga kina aghọmani asọ yii nga kọ utumu sang ẹrẹkwyuẹ na asọ ju si, “Ufoo kukushi Anọ iDauda! Agha anyu adaduma nga aghọmani aba kidẹ nọ uca Ate aYaya! Ufoo kukushi aghọcẹẹ nọ ujọọ!”
\v 10 Aya ghila Urushelima ni, nadidu ajiya ifọng zọọ bọ, na asọ ghulu si, “Inga wudii ri?”
\v 11 Ikir bajiya ba yira si, “IYesu nga, aghọ pii kọ ọtọ Ọnọng ka aNazaret anga aGalili.”
\s1 IYesu kọ Ọna Ọnọng
\r (IMar 11.15-19; ILuk 19.45-48; IYah 2.13-22)
\p 
\v 12 IYesu ya ghila idẹ ọna Ọnọng aba ya kla aghọ gheli na agbara kidẹ. Aba yiri uma umani aghọ tee ufe kina ugọọ uci aghọ gbara ukhimi.
\v 13 A tẹri bọ si, “Awọọ si, ‘Ọna mi ki shi ọna upii nọ Ọnọng, ni inu kọ tee ni wu ọka sọlu ayi.’”
\v 14 Afoo kina aghọmani aka bra bọ ukyeng ba va ba ukushi nga kọ ọna Ọnọng na ava ma bọ ọkyuọ.
\v 15 Ni afirist akakọng kina aghọmẹẹ umẹẹ iMusa ya nu uma ọdọdọma umani aju ni anọ kidẹ ọna Ọnọng su ca akpa si, “Ufoo kukushi Anọ iDauda,” Ni ava kọọ anang kọ.
\v 16 “Ingọ kọọ imumani anọ ri sọ tẹri?” Aghulu nga. IYesu va yira si “Ẹẹ, inu ta kọ pila nu kidẹ upii Ọnọng ba si, ‘Ka anyu ba ananọ kina apali ba anọ ni ingọ sa ubrẹ kunu wu?’”
\v 17 Aba sang nga ki ya bọ ki kyaa idẹ ifọng aBetani, ki ya nyẹ kukadu.
\s1 Ọshi Uwe umani ọka ma wọ Ikọlọ ba
\r (IMar 11.12-14; 11.20-24)
\p 
\v 18 Kini kikyuating na asọ vuu ni aba kọọ idafo.
\v 19 Aya nu uce ọshi uwe kọ uhwo utra ni, aba kyaa na ata peni nga ima ya ba bam na ayaa. Aba ju wu si, “Ba sọ ma ikọlọ ba ki ta kọ sang asing!” Kidẹ anakyua ni ọshi hwiya kọ.
\v 20 Atina nga ya nu kindii ni, aba wo ica. Asi, “Na nyi wu ni ọshi uwe ri hwiya kọ kidẹ akyua?”
\v 21 IYesu ba yira si, “Imẹ sọ tẹri nu aipang, insi inu ka ma aipang ni, inu ka woo nọ ikwyi wọ ba ni, basi imumani imẹ ju ọshi ri yoo ni inu ki bira uju ki yọ yu ba, ‘Ni inu va bira uju ọpang ri si kya kọ ya kpaa kidẹ ẹrẹyẹma,’ Ni uki ju kindọ.
\v 22 Insi inu ma aipang ni, inu ki yira kọ iligba imumani inu shọr Ọnọng.”
\s1 Ajiya ghulu kaya Ẹrẹgọrọ IYesu
\r (IMar 11.27-33; ILuk 20.1-8)
\p 
\v 23 IYesu ya ghila idẹ ọna Ọnọng, na ashi kidẹ umẹẹ ni, afirist akakọng kina anirakpẹẹ bajiya va ba ukushi nga ki ba ju si, “Iligba ẹrẹgọrọ wu ni ingọ sọ ju uma ri kọ, inga ma ngọ ẹrẹgọrọ ri?”
\v 24 Ni iYesu ba yira si, “Imẹ ki kọ ghulu nu uce ughulu uyẹ. Insi inu yira mi ni, imẹ ki tẹri nu ta iligba ẹrẹgọrọ wu ni imẹ sọ ju uma ri kọ.
\v 25 Abi wọ ni iminimini iYahaya kunu wọ? Ikunu ka ayaya wọ ta ukushi ajiya wọ?” Apii kina ace bọ ki tẹri si, “Insi ayọ ju si, ‘Ka ayaya wọ ni,’ aki ju si, ‘Ikẹmbọ sa ni inu ta ma nu aipang ni nga ba?’
\v 26 Insi ayọ ju si, ‘Kukushi ajiya ni,’ ayọ sọ tẹ ẹrẹbata ba ajiya, ka kpaa si iYahaya na aghọ pii kọ ọtọ Ọnọng nga.”
\v 27 Aba yira iYesu si, “Iyi ta ye yi ba.” Ni ava ju si, “Imẹ ki kọ tẹri nu nga ta igba ẹrẹgọrọ wu ni imẹ sọ ju uma ri kọ ba.”
\s1 Ighang Upii kaya Aniraghimi Apai
\p 
\v 28 “Ikẹmbọ ni inu nu? Ace ajiya shiwu na ashi na aniraghimi apai. Akyaa ukushi aghaye ki ju nga si, ‘Anọ mi, kya kọ ya ju utina kidẹ ija.’
\v 29 Anọ ba yira nga si, ‘Ita ki kya mi ba,’ na song ni aba tee ikwyi nga ki wor.
\v 30 Ni ate ba kyaa ukushi aghi ipai ki ya tẹri nga imumani atẹri adaa aghọ. Aba yira si, ‘Iki kyaa ate mi,’ ni ava kyaa ba.
\v 31 “Kidẹ bọ ka pai bọ ni inga ju imumani ate wang?” Aba yira si, ‘‘Aghọ iye.” IYesu ba ju bọ si, “Isọ tẹri nu aipang, aghọ yira agonu kina ayiri uwang aghimi ki ghila ẹrẹgọm Ọnọng ka aya nu.
\v 32 Ka iYahaya ba ukushi nu ka aba nyeni nu utra aipang, ni inu ta yira nọ nga ba, aghọ yira agonu kina ayiri uwang aghimi ma aipang ni nga. Kọ utumu udu ni inu ta la nọ ukpaa ki ma aipang ni nga ba.
\s1 Ighang Upii Aghọ Yira Uta Ija
\r (IMar 12.1-12; ILuk 20.9-19)
\p 
\v 33 Kọng ice ighang upii, Ace ajiya pila ija nga, aghimi kọ na irivii ki tumu uka mẹẹ amusumu ikọlọ na ashi kina uka ubọọ usa. Aba ma ace ajiya uta ija na asisang ukyeng.
\v 34 Akyua ucuru ya ba ni, aba tuma agira nga kukushi aghọmani ayira ija nga ka aya yira nga uka nga ki imila.
\v 35 Aghọtina ba kpẹnẹ agira nga; aca aghaye ki pii aghaye na asi taa aghaye na atii.
\v 36 Ni aba tuma ace agira angọ umani acẹẹ adaa akyua, ni aghọtina ba ju bọ ima iye ra.
\v 37 Kọ tutumu ni, aba tuma anọ nga kukushi bọ, Asi, ‘Aki kọng anọ nga.’
\v 38 Ni aya nu nga ni, aba tẹri ace bọ si, ‘Anọ umani aki la uma nga wẹ. Ayọ ba pii nga kọ ka uma tee unga bayọ!’
\v 39 Aba kpẹnẹ nga ki fẹni ka utumu ija nga ki pii nga kọ.
\v 40 “Insi aghọ ija ya ba ni, ikẹmbọ na aki ju aghọtina ra?”
\v 41 Aba yira nga si, “Aki pili agha akakiya ra, ka ama ace aghọ bọ ija nga, aghọmani aki ka ma nga uka nga ki imila.”
\v 42 IYesu tẹri bọ si, “Inu ta kọ pila nu upii Ọnọng ba, ‘Utii umani aghọ viya tọọ bọ si ushi bọ ọdọdọma ba ni, ọbọ tee cẹẹ nọ utina. Udii ni Ate ayaya nga ju, ima uwo ica yọ kukushi mayọ.’”
\v 43 “Kindọ ni isọ tẹri nu si aki yira ẹrẹgọm Ọnọng wọ kukushi nu, ka ama ajiya umani aki ju uma ọdọdọma unga ẹrẹgọm.
\v 44 Aghọmani a kpaa kaya utii ri ni, aki kpoo, aghọmani utii kpaa kaya nga ni, aki pulu nga ka awawo.
\v 45 Afirist akakọng kina aFarisiyawa ya kọọ ighang upii ni, aba kpili si asọ pii kaya akwyi bọ
\v 46 Aba wang utra umani aki kpini nga, ni asọ tẹ ẹrẹbata ikir bajiya ka ajiya kpaa si inga ni, aghọ pii kọ ọtọ Ọnọng nga.
\c 22
\s1 Ighang Upii Usra Agya Ubiya
\r (ILuk 14.15-24)
\p 
\v 1 IYesu va pii ni bọ ni ighang upii si,
\v 2 “Amra ẹrẹgọm ayaya na ace agọm umani aju anọ nga agya ubiya.
\v 3 A tuma agira nga si aya yọrọ aghọmani asa yọrọ bọ agya, ni ajiya nga ta ba bọ ba.
\v 4 Ava tuma ace agira si, ‘Tẹri aghọmani ayọrọ si, imẹ kọ ker imila, awaa inaa ni mara, akọ kyo kwikẹ. Inu tọ ba usra agya.’
\v 5 Ni ata duma bọ kọ ba, ava wor ila bọ, ace aghọ wor kyaa ija nga, ace aghọ wor kyaa oka gheli na gbara.
\v 6 Ace aghọ bọ va kpẹnẹ agira nga ki ca bọ ki pii bọ kọ.
\v 7 Agọm va kọọ anaa kọ, ava tuma na aghọnakpọ nga na aya pili aghọ pili ajiya wọ ki ta ugha ni ifọng bọ.
\v 8 “Ava tẹri agira nga si, ‘Akọ kpẹẹ ukyo uma usra agya, ni aghọmani ayọrọ ta maa bọ ba.
\v 9 Kindọ ni inu kya nọ itra ki inu ya tẹri nadidu aghọmani inu peni ka aba usra agya.’
\v 10 Agira ra va kyaa itra ki ya curu nadidu aghọmani apeni, agha adaduma kina agha ababi, ki ta kọ umani ọka usra agya tii na akyeng.
\v 11 “Agọm ya ba ma nu akyeng ni, ava nu ace ajiya umani ata sọmọ nga uma agya ba.
\v 12 Aba ghulu ajiya si, ‘Na nyi wọ ni ingọ ghila ukawẹ wọ ba uma agya,’ ‘Ayikyo?’ Ajiya ta biya nga upẹni ba.
\v 13 Agọm ba ju agira si, ‘Inu lor nga ivọ kina ifra, ka inu fẹni nga ka sing kidẹ itii, ọka umani aki ci na aghula ayiri.’
\v 14 “Ka ayọrọ ajiya na pam, ni aghọ ni ahwiya shi na zẹẹ.”
\s1 Ughulu kaya Ujira Agonu kukushi IKaisar
\r (IMar 12.13-17; ILuk 20.20-26)
\p 
\v 15 Ashiya kindọ ni aFarisiyawa kyaa ki ya pii kina ace bọ umani aki kpẹnẹ iYesu kidẹ upii nga.
\v 16 Aba tuma aghọyii bọ kina ajiya iHiridus, asi, “Aghọmẹẹ, ayọ ye si ingọ ni agha aipang nga, ingọ ka va mẹẹ utra Ọnọng kidẹ aipang, ka ajiya nadidu ni agha aye ra bọ kukushi ngọ, ingọ ka ba nyeni ngọ uyo ẹrẹkwẹ ka ajiya ba.
\v 17 Tẹri ayọ, unu ngọ shi na nyi? Ọsọ ọdọma ni ayọ ja agonu kukushi iKaisar agọm aghaghẹ ta ayọ ba ja ba?”
\v 18 Ni iYesu, ye akakiya ushi kidẹ ikwyi bọ, aba tẹri si, “Inu aghọ ju unu ica, ikẹmbọ sa ni inu wang mra mi?
\v 19 Nyeni mi ufẹ umani aka ja agonu wọ,” Aba ba nga na udinari,
\v 20 aba ju bọ si, “Iwuu inga yẹ? Kina uca inga bẹ?”
\v 21 Aba yira ki tẹri si, “Ọnga iKaisar.” IYesu ba ju bọ si, “Inu ma iKaisar imumani ishi inga iKaisar, ni inu ma Ọnọng imumani ishi inga Ọnọng.”
\v 22 Aya kọọ kindii ni, aba kpẹnẹ anyu bọ na asa wo ica, aba ya nga na asa wor.
\s1 Ughulu kaya Ubiya ka Awii Usang Ashi
\r (IMar 12.18-27; ILuk 20.27-40)
\p 
\v 23 Ka awii ra ni, ace aSadukiyawa ba ukushi iYesu. Abọ ka tẹri si ba usang ashi. Aghulu nga si,
\v 24 “Aghọmẹẹ, iMusa si, ‘Insi ajiya kpoo na ashi na anọ ba ni, anayuru nga ki vo ayiri ka ajeli anayuru anọ.’
\v 25 Ni ace anayuru atinsara shi kọ kidẹ bayọ. Agha iye vo ayiri, akpoo na akọ jee nga ba, asa shee anayuru nga ayiri.
\v 26 Kindii wọ ni uba wọ na agha ipai, kina agha itai, ki ya ta ka agha itinsara.
\v 27 Aya kpẹẹ ni, ayiri va kpoo.
\v 28 Kọ usang ashi ni, ayiri ki tee anga inga kidẹ bọ ka nadidu bọ kọ vo nga?”
\v 29 IYesu ba yira bọ si, “Uma ikwyi nu shi bọ na kikya ba, ka inu ta ye nu nọ upii Ọnọng na awọọ ba, inu ta ba ye nu ẹrẹkyuọ Ọnọng ba.
\v 30 Kọ usang ashi ni, aghimi ki voru bọ ayiri ba, ayiri ni, aki ma bu bọ ubiya ba, aki ba kina atuma Ọnọng bọ ni ka yaya.
\v 31 Kọ usang ashi ni, inu ta kọ pila nọ imumani Ọnọng tẹri nu ba? Awọọ si,
\v 32 ‘Imẹ sọ Ọnọng Ibrahim, Ọnọng Ishaku kina Ọnọng iYakubu.’ Ashi Ọnọng aghọ kpuru ba, anga akyuọ nga.”
\v 33 Ajiya ya kọọ kindii ni, asa wo ica nọ umẹẹ nga.
\s1 Imumani Ọnọng Tẹri Ingọ cẹẹ nọ Ughọghẹ
\r (IMar 12.28-34; ILuk 10.25-28)
\p 
\v 34 AFarisiyawa ya kọọ ni iYesu fuga aSadukiyawa anyu ya ni, ava ba curu.
\v 35 Ace aghọmẹẹ umẹẹ iMusa kidẹ bọ, ba ghulu iYesu ka amra nga.
\v 36 Asi, “Aghọmẹẹ, aligba ima tẹri Ọnọng yọ cẹẹ nọ ughọghẹ kidẹ uma tẹri nga?
\v 37 IYesu yira nga si, “‘Yoo ate Ọnọng ngọ kina ikwyi ngọ nadidu, kina ọkyuọ ngọ nadidu, kina iyẹẹ ngọ nadidu.’
\v 38 Udii wọ shi ima tẹri Ọnọng iye, angọ cẹẹ nọ ughọghẹ.
\v 39 Anga ipai shi kindọ, ‘Yoo agha ayayo ngọ kini ẹrẹkwẹ ngọ ni.’
\v 40 Nadidu umẹẹ iMusa kina aghọ pii kọ ọtọ Ọnọng shina uma tẹri Ọnọng apai ri.”
\s1 Anọ Inga ngaa shi IKristi?
\r (IMar 12.35-37; ILuk 20.41-44)
\p 
\v 41 AFarisiyawa ya curu kọ uka uye ni, iYesu ba ghulu bọ si,
\v 42 “Ikẹmbọ ni inu nu kaya iKristi? Ashi anọ inga?” Aba ju si, “Anọ iDauda nga.”
\v 43 IYesu ba ju bọ si, “Na nyi wọ ni iDauda na asọ pii na akyuọ Aghing sọ yọrọ nga si, ‘Ate’? Ka iDauda si,
\v 44 “‘Ate si Ate mi, “Cica kọ ukawẹ ka avọ ila mi sa imẹ sa asho ngọ kidẹ ifra ngọ,’’’
\v 45 Insi iDauda sọ yọrọ iKristi si ‘Ate,’ ni, na nyi wu ni iKristi tee anọ nga wọ?”
\v 46 Ba aghọmani a bra uyira nga ba. Kọ kpaa ka awii ra ni ba aghọmani asọ ju ikwyi ki ghulu nga uce upii ba.
\c 23
\s1 IYesu Waa Atọng Kaya Aghọmẹẹ IMusa kina AFarisiyawa
\r (IMar 12.38-39; ILuk 11.43-46; 20.45-47)
\p 
\v 1 Ni iYesu ba tẹri ikir bajiya kina aghọyii nga si,
\v 2 “Aghọmẹẹ umẹẹ iMusa kina aFarisiyawa bọ na ama bọ akyuọ mẹẹ umẹẹ iMusa.
\v 3 Kindii ni inu ju imumani amẹẹ nu, ka inu yii yọ nadidu, inu ba ju kọnọ umani ibọ ka ju ba, ka aka ju bọ imumani ibọ ka mẹẹ ba.
\v 4 Aka lor ajiya akpara ọkpọtọrọ, anga ushi na awiya ukpaa, ki tiya bọ kaya avọ ni aka duma bọ nọ uta bọ avọ wu ba ko anivọ.
\v 5 \f + \fr 23.5 \ft Agha Israila ka khimi igbang nọ ugba bọ kọ kpaa ka anyu ka ushi amaa umani abọ kyo akwyi bọ kọ uju utina Ọnọng.\ft (IMat 6.1)\f* Aka ju kwikẹ ka ajiya nu, aka lor upii Ọnọng ka ubate bọ kina ivọ bọ, aka lor irining igbiligbang ka anyu nọ ugbang bọ.
\v 6 Aka yoo ọkọ ci ọdọdọma kọ ọkọ usra agya kina ọkọ ci ọdọdọma ka ọkọ takwyuẹ aYahudawa;
\v 7 ayoo umani aka bili bọ na ẹrẹgọrọ ka uka gheli na gbara, aka wang si ajiya yọrọ bọ si, ‘Aghọmẹẹ.’
\v 8 Aki yọrọ ngọ nga si, ‘Aghọmẹẹ ba,’ ka inu ni aghọmẹẹ ayeng nga ni ushi ni nga, ka inu ni anayuru aye ra bọ.
\v 9 Ni inu ba yọrọ ace aghọ kaya ashi ri si, ‘Ate ba,’ ka Ate nu ni aye nga ka yaya.
\v 10 Aba va yọrọ nọ si, ‘aghọmẹẹ,’ ba ka aghọmẹẹ nu ni ayeng nga, uKristi.
\v 11 Aghọ cẹẹ nọ ughọghẹ kidẹ nu ki shi agira nọ.
\v 12 Ka aghọmani azẹẹ ẹrẹkwẹ nga ni, aki suu ni nga, aghọmani asuu ni ẹrẹkwẹ nga ni, aki zẹẹ nga.
\v 13 Ọlọ nu, inu aghọmẹẹ umẹẹ iMusa kina aFarisiyawa! Inu aghọ ju unu ica! Inu yuru anyu ubọọ ẹrẹgọm a yaya ya ka ubate bajiya. Inu ka akyakwyi nu ta ghila nu ba, inu ta ba ya nu aghọ wang ghila ka ghila ba.
\v 14 Ọlọ nu aghọmẹẹ umẹẹ iMusa kina aFarisiyawa, aghọ ju unu ica! Inu ka la uma bayiri umani aghẹmẹ bọ kọ kpuru bọ, inu va pii nọ Ọnọng kọ ọgbọọgbang ka anu nu. Kindọ ni, aki ju nu ashuwa ucẹẹ nọ ububi.\f + \ft Ice iwọọ ka akyua ra shi yọ na ago ri ba. \fr 23.14 \f*
\v 15 Ọlọ nu, aghọmẹẹ umẹẹ iMusa kina aFarisiyawa, aghọ ju unu ica! Inu ka buu udaa ugẹẹ ẹrẹyẹma, inu ka kya nu ice ẹrẹbọ ka atatọọ ka inu ya wang aghọ lọkpaa aye. Insi inu peni ni, inu ka tee ni nga aghọ idẹ ugha nọ ọnga cẹẹ ọngọ nu sọ ẹrẹpai.
\v 16 Ọlọ nu, afoo nyeni afoo utra! Inu ka tẹri si, ‘Insi acee aghọ suu na ọna Ọnọng ni, uyeni wọ ighima ba; ni insi acee aghọ suu na utii uyeri idẹ ọna Ọnọng ni, iyiya yọ ni aju imumani asuu kọ.
\v 17 Inu abo afoo! Uligba wọ cẹẹ nọ ughọghẹ, atii uyeri ta ọna Ọnọng umani uhwuru atii uyeri?
\v 18 Inu ka ba tẹri si, ‘Insi acee aghọ suu na ọka uyeri agoo ni, unyeni wọ ighima ba, ni insi acee aghọ suu ni imumani ama ka agoo ni, iyiya yọ na aju imumani asuu wọ kaya.’
\v 19 Inu afoo! Uligba wọ cẹẹ nọ ughọghẹ, uma wọ ta agoo umani aka hwuru uma ni?
\v 20 Kindọ ni, nadidu aghọmani asuu kaya agoo ni, asuu ni wọ kina uma ni ushi kaya nadidu.
\v 21 Ni aghọmani asuu kaya ọna Ọnọng ni, asuu ni wọ kina Ọnọng umani aci kidẹ wọ.
\v 22 Ni aghọmani asuu ni ayaya ni, asuu ni igọọ ẹrẹgọm Ọnọng kina aghọmani aci kaya.
\v 23 “Ọlọ nu, aghọmẹẹ umẹẹ iMusa kina aFarisiyawa, aghọ ju unu ica! Uwe ni, uka ma Ọnọng ima iye kidẹ ushọ, ọkyulọ, aya kina uma ẹrẹnang. Inu ta duma nọ na uju uma ọdọdọma kidẹ umẹẹ iMusa ba, aipang, ahwoo kina uju uma uyira. Uma ri bọ si ọnga umani inu sọ ju, basi ashee uce ya ba.
\v 24 Inu afoo unyeni utra, inu ka wọ anaijii ki ima ọsa nu, ni inu si ngọnọ Ọrahimi!.
\v 25 Ọlọ nu, aghọmẹẹ umẹẹ iMusa kina aFarisiyawa, aghọ ju unu ica! Inu ka hwuru utumu isọ kina ipẹ, idẹ ni, ishi na uma uderi ajiya kina uyoo ẹrẹkwẹ.
\v 26 Afoo aFarisiyawa, zọnọ hwuru idẹ isọ kina ipẹ, utumu ki kọ ba na pipar.
\v 27 Ọlọ nu, aghọmẹẹ umẹẹ iMusa kina aFarisiyawa aghọ ju unu ica! Inu shi kini alọr umani a coo bọ anyi afafuu ni, ashi adaduma unu kọ seshi, idẹ ni, agboho aghọkpuru kina ko iligba ighọ irighe shiya.
\v 28 Kindii wọ ni inu shi wọ, kọ seshi ni, ajiya ka nu nọ kini agha aipang bọ ni, idẹ nọ ni agha akakiya bọ, aghọ ju unu ica kina uma ububi.
\v 29 Ọlọ nu, aghọmẹẹ umẹẹ iMusa kina aFarisiyawa, aghọ ju unu ica! Ka inu ka vra alọr adaduma anga aghọ pii kọ ọtọ Ọnọng, ki va ju alọr agha aipang ufọnọ.
\v 30 Inu ka ju si, ‘Ayọ ta kọ shi wọ ka akyua anirakpẹẹ ba bayọ ni, ayọ ta kọ ta yi bọ avọ wọ ka ashii ayi aghọ pii kọ ọtọ Ọnọng ba.’
\v 31 Kindii wọ ni inu nyeni si inu bọ shi anọ aghọmani apili aghọ pii kọ ọtọ Ọnọng.
\v 32 Inu ya pra ju imumani anirakpẹẹ nu ju!
\v 33 Inu iyọọ, inu iyọọ na kang! Nagyi wọ ni inu ki tẹ anang idẹ ugha?
\v 34 Kindii ni imẹ sọ tuma nu na aghọ pii kọ ọtọ Ọnọng kina aghọ uye ukyuu kina aghọmẹẹ. Inu ki pili ace aghọ bọ, ace aghọ bọ ni, inu sọ gra bọ, inu sọ ca ace aghọ bọ kọ ọkọ takwyuẹ aYahudawa nu, inu sọ yii bọ ufọng nọ ufọng ni inu sọ sa bọ ọlọ.
\v 35 Ni kaya nu ni, nadidu ayi agha aipang umani apili ki suu kaya akwyi nọ ka asing ri, kọ kpaa ka Abila ki ta ka ayii iZakariya anọ iBerekiya, aghọmani inu pii ka abiyatẹ ọna Ọnọng kina agoo.
\v 36 Aipang, imẹ sọ tẹri nu, nadidu uma ri ki ba kaya ajiya akyua ri.”
\v 37 “Urushelima, Urushelima! Aghọ upili aghọ pii kọ ọtọ Ọnọng, aghọ fẹẹ aghọmani atuma kukushi nu na atii! Ẹrẹmẹ wọ ni imẹ ka wang ucuru nu kidẹ ivọ mi kina umani anuu ka curu anọ nga ka asọọ nga, inu tọọ nu.
\v 38 Uwẹ ka akyakyua ri ni, aya nu ọna nu idẹ avọ!
\v 39 Ka imẹ sọ tẹri nu, inu ta ki sọ nu mi nga ba, sa awii umani inu tẹri si, “Agha anyu adaduma ngaa, aghọmani aba kidẹ nọ uca Ate.’”
\c 24
\s1 IYesu Pii Kaya Upulu Ọna Ọnọng
\r (IMar 13.1-2; ILuk 21.5-6)
\p 
\v 1 IYesu ya kunu kidẹ ọna Ọnọng na akyeng ni, atina nga va yeni nga ivila ọna Ọnọng.
\v 2 Ava ghulu bọ si, “Inu nu ivila ri nadidu? Aipang ni imẹ sọ tẹri nu, aki ya bọ utii uyeng ya kaya uce ba. Aki pulu yọ kọ nadidu.”
\s1 Ọkyọ Ukọng Ọlọ
\r (IMar 13.3-13; ILuk 21.7-19)
\p 
\v 3 IYesu ci kaya ugbana ni ishi nọ uzaitun ni atina nga va ba ukushi nga ka yayu bọ ki tẹri si, “Tẹri yi, aligba awii kọ ni udu di ki ba kọ? Ni ikẹmbọ shi amaa mani iki nu kọ ki ba ngọ kina usang asing?”
\v 4 IYesu va yira bọ si, “Inu sa amaa kọ, ka ace aghọ ba ghẹmẹ nọ ba.
\v 5 Ka ajiya nagigang ki ba kidẹ nọ uca mi, aki tẹri si, ‘Imẹ ni anga iKristi ngaa’, ka va ghẹmẹ ajiya nagigang.
\v 6 Aki kọng ila ikọrọ kini irishu uma ọtitẹri. Inu ba kọng ẹrẹbata ba, kọ udidu uma ki tọ ba, ka amaa sọnọ baa ba.
\v 7 Ifọng ki kọrọ kini Ifọng, ẹrẹgọm ki kọrọ kini ẹrẹgọm. Aki ju idafo kini uzuru ẹrẹbọng ki ikini ika.
\v 8 Udii shi kini ọkọng ẹrẹnọma ayiri sọ jẹẹ kọ ni.
\v 9 Kindọ ni asọ tọ ma nọ ọlọ, ka va pili nọ. Ajiya sing nadidu ki tọrọ nọ kidẹ nọ uca mi.
\v 10 Akyua rau ni Ajiya nagigang ki kpaa nọ utumu kọ pii Ọnọng, aki gbra ace ka va tọrọ bọ ace.
\v 11 Atina Ọnọng atẹri ki sang na pam ka aghẹmẹ ajiya na pam.
\v 12 Uju akakiya nagigang, uyoo umani ajiya nagigang ju ace ki kpaa nọ utumu.
\v 13 Aghọmani a bra umọr ni aki peni ufoo.
\v 14 Aki va ma ila ididuma inga ẹrẹgọm Ọnọng ka sa amaa kọ shi ma ajiya, na amaa asing sọ ta ba.
\s1 Ọlọ Ububi
\r (IMar 13.14-23; ILuk 21.20-24)
\p 
\v 15 “Inu ki nu ima ibibi ingọ sa ukpaa, ọngọ mani aghọ pii kọ ọtọ Ọnọng iDaniyel tẹri ni, ating kọ ọkọ uyer. Taa ni aghọ pila iwọọ kpẹlẹ.
\v 16 Ni, aghọmani ashi kidẹ isighi aYahudiya ti bọ ka kya bọ idẹ apang.
\v 17 Aghọmani ashi ka aya ọkọ ufiya ba shulu si inga ki ya kpaa ima mani ishi kidẹ aca ba.
\v 18 Aghọmani ashi ka aghumu ni aba vuu sa anga ki ya kpaa ima ufiya ba.
\v 19 Ọlọ ayiri ushi na afo, kina aghọ kọ anọ kaidu akyua!
\v 20 Inu shọr Ọnọng kọ uti kọnọ ma ba nọ ka akyua iriwe kọ awii uwuru aYahudawa ba.
\v 21 Ka akyua ra ni aki kọng ọlọ nagigang, ighọmani asọnọ ju bu ba kọ kpaa kọ ju asing ki ta ka di akyua ri, aki sọ ju bọ ighọ ba.
\v 22 Ada wasi awa awii najii ba ni, ace aghọ ta lang ngaa ba, ni aghọmani ahwiya sani aki wọ ace na awii kọ
\v 23 “Akyua ra kọ ni, aghọmani atẹri nọ si, ‘Inu nu, aghọfoo we! ta awa ni, inu ma yira ba.
\v 24 Ka atina ọnọng atẹri ki kunu, ka ju uma ọkọkọng kọnọ uma sa uwo ica ka zọọ ajiya kọ, kina aghọmani ahwiya insi uju ni.
\v 25 Ni, isọ tẹri nọ kidẹ akyua.
\v 26 Kindọ ni insi atẹri nọ si, ‘Awudu ka aghumu,’ Inu ba kunu ba. Insi atẹri nọ si, ‘Ashi kidẹ ubọọ na ashọr,’ inu ma yira ba.
\v 27 Kọnọ umani inyigha ka ta uyer ki iripiya ki ma ta ka awura ni, kindọ ni ọba Anọ Ajiya ki shi kọ.
\v 28 “Ọkọ mani ọkọng shi kọ ni ọka wọ na aghavung ka curu kọ.
\s1 Uvuu Anọ Ajiya
\r (IMar 13.24-27; ILuk 21.25-28)
\p 
\v 29 “Kai du akyua ni, ko utumu awii ọlọ ra ni,
\q1 “‘Ọka vasa kpii iting,
\q2 Ọpir uta ta wọ uyer ba.
\q1 Ẹyẹrẹ ki kpira ka yaya,
\q2 Ayẹrẹmọ ki zuru.’”
\p 
\v 30 “Aidu akyua ra kọ ni amaa ba Anọ Ajiya ki ta nyeni kọ ka ayẹrẹmọọ. Naidu ite asing ri ki ci. Aki nu Anọ Ajiya na kyeng ba kidẹ amọ kini ẹrẹgọrọ na akyo nọ ujọọ ọgigang.
\v 31 Aki tọma kina atuma nga ka pẹni ẹrẹtọma ngọ shini ishimi nagigang, ka ma curu aghọmani ahwiya ki ishii ukunu ọnọng kọnọ ukpaa ọnọng kina ushii ata nọ ushi aya, kọ kpaa ka ayẹrẹmọọ kiya ta ka udaa.”
\s1 Umẹẹ kọ Ọshẹ uwẹng
\r (IMar 13.28-31; ILuk 21.29-33)
\p 
\v 32 Inu mẹẹ ice ima kukushi ọshẹ uweng. Insi ọvong nga sọju fọnọ ni, ọka kunu kini afa asasa, inu kpẹlẹ si ẹrẹkpẹrẹ yasọ ba wudu.
\v 33 Kindọ wu ni insi inu nu ima umani imẹ tẹri nọ ni, inu ye si akyua ya sọ ba ayayo, ashi ka anyu ubọọ.
\v 34 Iyiya ni sọ tẹri nọ, ajiya aya sing ri ki kpuru bọ ba, sọ uma ri nadidu ba.
\v 35 Ayaya kina asing ki kpẹri wọ, upii mi ki kpẹr wọ ko na zẹẹ ba.”
\s1 Ba aghọ ye awii uki ba IYesu ba
\r (IMar 13.32-37; ILuk 17.26-30; ILuk 17.34-36)
\p 
\v 36 Ba aghọ ye awii ta akyua ni ima ri ki ba kọ, kina atuma Ọnọng ka ayaya mani ta anọ Ọnọng, Ate nga ka yayu nga.
\v 37 Kọnọ mani aju ka awii iNuhu ni, kindọ ni ọki ba wọ kọ uki vuu Anọ Ajiya.
\v 38 Kọ kpaa ka kyua ra ni ugya na amusum ọghọghẹ, asọ la, na sa, aghẹmẹ sọ voru ayiri, na amẹẹ ayiri ki ibila, ki ta ka awii umani iNuhu ghila nga ọgbọlọ.
\v 39 Ata kọ tọ ye ima mani ishi kidẹ ni, ugya ọghọghẹ ọkọ kpa bọ nadidu bọ. Kindọ ni uvuu Anọ Ajiya ki shi kọ.
\v 40 Akyua ra ni, agha pai ki shi ka aghumu, aki kpaa agha yeng kọ na ya agha yeng ya.
\v 41 Ayiri apai ki shi kọ hwọ kọ utii uhwọ, aki kpaa agha yeng kọ, na aya agha yẹng ya.
\v 42 “Kindọ ni inu ci nọ ye, kọ nu ye nu awii mani Ọnọng ki vuu kọ ba.
\v 43 Inu ye si, aghọ ọna ta ye si agba akyua kọ na ayi ki ba na ating, ara bra umọr ba, aki ya ka ghila ọna nga ba.
\v 44 Kindọ ni unu ci nọ ye, akyua mani ọta ye nu ba ni, akọ ni Anọ Ajiya ki ba wọ.”
\s1 Inga shi Agira ushi na aipang ko angọ taa aipang?
\p 
\v 45 “Inga shi agira aipang, agho shini ukpẹlẹ, angọ mani aghọ ọna nga sa nga ukyoo ọna nga, ki va ma ushẹ agira nga imila bọ kidẹ akyua lẹ?
\v 46 Agha anyu adaduma agira mani aghọ ọna nga ki ba ka ma peni nga na sọ ju utina nga.
\v 47 Iyiya ni isọ tẹri nọ, aki ma adidu agira ka kyoo uma nadidu.
\v 48 kindọ aghọ ki ju agira ni aghọ ibibi yọ, aki va tẹri ẹrẹkwẹ nga, ‘aghọ ọna mi ki ta ba kai shang ba,’
\v 49 ọka wudu ni, a vasa tee aghọ ca aghikyo utina nga, asọ la na sa kina aghọ vura.
\v 50 ipeni aju kindọ ni, aghọ ọna nga ki ba ka awii umani agira ye ba, ka kyua mani aye ba,
\v 51 Aghọ ọna ki ca nga nagigang, ka va wa nga ashuwa kina aghọ uju unu ica. Ọkadọ wu ni aki ci kọnọ ọwọla ayiri.
\c 25
\s1 Ighang upii Anirayiri Ushọ
\p 
\v 1 “Aidu akyua ra kọ ni aki mra ẹrẹgọm ayaya kina anirayiri ushọ aghọmani akpaa uma uta ugha bọ na akya bọ ọkọ yira aghẹmẹ asasa ni.
\v 2 Atọng kidẹ bọ ni abo bọ, atọng ni aghọ uye ukyuu bọ.
\v 3 Akyua umani abo ra ya kpaa uma uta ugha bọ ni ara go bọ anyẹ ka ma sang ni akimi kọ ba.
\v 4 Aghọ uye ukyuu ni ago iribom na anyẹ kina uma uta ugha bọ.
\v 5 Aghẹmẹ asasa ta ba kaishang ba, nadidu bọ ni ava kọng ki ililu, ọmọọ va kpaa bọ wọ.
\v 6 “Ating nagigang ni, ava kọng uyọrọ na sọ tẹri si, ‘Aghẹmẹ asasa wudu! Inu kunu kọ yira nga.’
\v 7 Anirayiri ushọ va sisang ki keri uma uta ugha bọ.
\v 8 Abo ra va tẹri aghọ uye ukyuu ra si, ‘Inu ma yi anyẹ nu kọ najii, uma uta ugha yi sọ kpo bọ.’
\v 9 Aghọ uye ukyuu va tẹri bọ si, Kayi, aki maa bọ yi kina inu ba. Inu kya ọkọ shi aghọ gbra kọ ya ghẹ anga nu.’
\v 10 Aya walu ki kyabọ ọkọ ughẹ anyẹ ni, ata kọ vuu ni aghẹmẹ asasa kọ ba. Anirayiri umani aci na zizal na asha ni ava ghila ọka ulor ubiya kini inga, ava yuru anyu ubọọ ya.
\v 11 “Kọ tumu ni, ushẹ anirayiri va ba, ava tẹri si, ‘Agha aghaghẹ, Agha aghaghẹ, fọmọ yi anyu ubọọ!’
\v 12 Aghẹmẹ asasa va yira bọ si, ‘Aipang ni sọ tẹri nu si, ita ye nu ba.
\v 13 “Kindọ ni, inu ci nọ ye si, inu yẹ nu awii ko ta aligba akyua kọ ni ba.”
\s1 Umẹẹ kaya uju Aipang
\r (ILuk 19.11-27)
\p 
\v 14 Ẹrẹgọm ayaya shi kini ajiya umani aki sang ukyeng nga ni, ava yọrọ agira nga, ka ma upeni nga ki ivọ bọ.
\v 15 Ama agha yeng ipa nọ ufẹ itọng, ada aghọ ni ipai, ava ma ada aghọ uye, kwinga na kikya ni ẹrẹkyuọ nga. Ukadu wọ ni ava wolu.
\v 16 Aghọmani ayira ipa nọ ufẹ itọng ra ni, kaishang na akya kiya tili nọ ufẹ, ki peni ipa itọng kaya.
\v 17 Kindi ni aghọmani ayira ipa ipai ra, apeni ipai kaya.
\v 18 Aghọmani ayira ipa iye, ni aya tumu ufọng ki ẹrẹbọ ki shọ ufe aghọ ọna nga kọ.
\v 19 “Aya kpaa akyua ni, aghọ ọna agira nga va vuu ka aya keri imumani aju nọ ufe.
\v 20 Aghọmani ayira ipa nọ ufẹ itọng va ba ite ki ba kina ice ipa nọ ufẹ itọng ava tẹri si, ‘Aghọ ọna, ingọ ma mi ipa nọ ufẹ itọng. Uwẹ ni imẹ peni itọng kaya.’
\v 21 “Aghọ ọna va tẹri si, ‘Asho nọ utina, agira adaduma, aghọ ju aipang! uju aipang ki ma uji. Imẹ ki ma ngọ utina umani ọgina udi.’ Ba kọ uma ju ikwyifu kini imẹ aghọ ọna ngọ.
\v 22 “Aghọmani ayira ipa nọ ufẹ ipai va ba, ki ba tẹri si, ‘Aghọ ọna, ingọ ma mi ipa nọ ufẹ ipai. Uwẹ ni imẹ peni ipai kaya.’
\v 23 Aghọ ọna nga va tẹri si, ‘Asho nọ utina, agira adaduma aghọ ju aipang! Ingọ ju aipang ki ima ujii. Imẹ ki ma ngọ utina umani ọgina udii. Ba kọ uma ju ikwyifu kini imẹ aghọ ọna ngọ.’
\v 24 “Ọka wudu ni aghọmani ayira ipa nọ ufẹ iye ra ni, ava ba ite ki tẹri si, ‘Aghọ ọna, imẹ ye si ungọ shini igigira, ingọ ka curu kọ ọkọ umani ingọ ra pila ngọ kọ ba kina ucuru ka ọkọ umani inga ra ta ngọ ighọ ba.
\v 25 Ọwọ sa ni imẹ kọng ẹrẹbata ni imẹ ya tumu ẹrẹbọ kiya shọ ipa nọ ufẹ ngọ kọ. Yira idu ngọ.’
\v 26 Aghọ ọna va yira nga si, ‘Ingọ agira ighọ ibibi aghina agbara! Ita ingọ ye si ika curu kọ ọkọ umani ira pila mi ba, ika va curu kọ ọkọ umani ira ta mi ighọ wọ ba.
\v 27 Ingọ ra kọ sa ufẹ mi kọ ọkọ kyuru ufẹ, insi iya vuu ni isọ yira udu mi kina ẹrẹtiya!
\v 28 Kindọ ni inu yira ipa nọ ufẹ iye kukushi nga kọ uma aghọ shina ushọ ra.
\v 29 kindọ ni nadidu aghọ shina ima ni, aki khimi nga kọ, ka va peni nagigang, aghọmani ashi ni ima ba ni, kọ na jii mani ashi ni yọ ni, aki yira wọ kukushi nga.
\v 30 Inu sọ fẹni agira ijirija ra kidẹ iting. Ukadu wọ ni aki ci kina ọwọla ayiri.
\s1 Ashuwa usang Asing
\p 
\v 31 “Akyua umani Anọ Ajiya ki ba kina ujọọ nga kina atuma nga nadidu, akyua ra kọ ni aki cicaa ki igọ ẹrẹgọm ayaya nga.
\v 32 Aki curu ajiya asing ri kite nga, aki kau bọ ka yila yeng, kina mani aghọ cẹẹ ka kau atẹm kina anọma.
\v 33 Aki sa atẹm ka vọ ila nga, anọma kọma ka avọ iprọma nga.
\v 34 Akyua ra kọ ni agọm ki tẹri aghọ shi kavọ ila nga si, ‘Inu ba, inu aghọmani ate mi ta nọ anyu adaduma! Inu yira ẹrẹgọm mani ate mi kyo si inga nu ku kọ kpaa ka akyua na akeri asing kọ.
\v 35 Ka akyua mani imẹ hwiri idafo ni ingọ ma mi imila. Ikọng idafo na amusum ni uma mi ni sa. Ishi akyeng ni, ingọ yira mi.
\v 36 Ishi mi ni igbang ba nọ umami igbang. Ishi mi akyuọ ba, nọ ọkọng ni imẹ. Ishi kọ ubọọ iting, ọba ki ma bili mi.
\v 37 Akyua ra kọ ni aghọ shina aipang aki yira nga si, ‘Ate yi, aligba awii ni iyi nu ngọ kọ nọ kọng idafo ni ima ngọ imila? ta ingọ kọng idafo na amusum ni ima ngọ amusum sa?
\v 38 Na aligba awii kọ ni iyi nu ngọ sọ ọshi akyeng ni iyi yira ngọ? ta ingọ shi ni igbang ba ni ima ngọ igbang?
\v 39 Ta aligba awii kọ nọ shina akyuọ ba tọ shi kọ ubọọ iting ni ya bili ngọ kọ?
\v 40 Agọm ki yira bọ ka tẹri si, ‘Iyiya ni sọ tẹri nọ si, kọnọ umani uju ajiya ayeng kidẹ anayuru mi mani ashi najii ni, imẹ nu ju mi.’
\v 41 “Aki tẹri aghọ shi ka avọ iprọma nga si, inu sang nọ kukushi mi aghọ ijirija, inu ghila nọ idẹ ugha umani ọki kpo wọ nga ba kọ ta ka amaa asing, Ọngọ umani akyo ishẹẹ kina atuma nga.
\v 42 Ka akyua mani ihwiri idafo ni, ba aghọmani ba. Ikọng sa amusum, unu ta ma mi amusumu ọsa ba.
\v 43 Ishi akyeng, inu ta yira mi nga ba. Imẹ shi mi ni igbang ba, ingọ ta ma mi nga igbang ba. Imẹ shi adumu, ni va shi kọ ubọọ iting nọ ta ba nu mi nga ba.’
\v 44 Akyua ra kọ ni abọ ki tẹri si, ‘Ate agba awii kọ ni yi nu ngọ kọ ni uhwiri idafo, kọ idafo na amusum, kọ irikyeng, ta ingọ shi ngọ ni igbang ba, ta ingọ shi adumu, ta ingọ shi kọ ubọọ iting, ni iyi ta shọ nu nga kọ ba?’
\v 45 Akyua ra kọ ni aki yira bọ si, ‘Aipang ni isọ tẹri nọ si, kọnọ umani inu ra ju nu agha ayeng ki da agha ajaji ri ba ni, inu ra ju mi ba wudu.’
\v 46 Aidu aghọ ki ghila bọ ọkọng ọlọ ọngọ taa amaa, agha aipang sọ peni ọkyuọ taa amaa.”
\c 26
\s1 Aghite Dọmọ Upii IYesu
\r (IMar 14.12; ILuk 22.12; IYah 11.45-53)
\p 
\v 1 IYesu ya kpẹẹ utẹri uma ri nadidu ni, ava tẹri aghọyii nga si,
\v 2 “Kọnọ umani inu ye ni, awii usra agya ubulu kọ shẹ awii apai, aki ma Anọ Ajiya ka gra nga kọ ukumu ọshẹ.”
\v 3 Ni afirist akakọng kina aghite bajiya curu kidẹ ọna ifirist ucẹẹ nọ ọghọghẹ, aghọ umani aka yọrọ si iKayafa.
\v 4 Asa dọmọ si ibọ kpẹnẹ nga kọ uyuyi ka pii nga kọ.
\v 5 Ava tẹri si “Ba kidẹ na awii usra agya ri ba, ka ajiya ba tọlu kina ace bọ ba.”
\s1 ACoo IYesu na Anyẹ ọvong ka ABetani
\r (IMar 14.2-9; IYah 12.1-8)
\p 
\v 6 Ka akyua umani iYesu shi ka aBetani kidẹ ọna iSaminu aghọnọ ubili ni,
\v 7 ace ayiri sa ba ukushi nga kina anibom ẹrẹtọng ajaji kina anyẹ ọvọng ushi ni izẹ nagigang, ki shii nga kọ ki ẹrẹkwyuẹ, ka ca mani a do la imila.
\v 8 Aghọyii nga ya nu kindọ ni, ava sa kọng anang ki tẹri ace bọ si, ‘‘Udii ni, ubra wọ.
\v 9 Ata kọ gbara anyẹ ọvọng ni izẹ nagigang ki ma aghina amir ufẹ.”
\v 10 IYesu va kpẹlẹ, asa tẹri bọ si, “Ikẹmbọ sa ni inu sọ dọma kina ayiri ri? Ima ididuma yọ ni aju mi.
\v 11 Inu shi kina aghina amir ko agba akyua, imẹ ka shi mi kini inu kọ agba akyua ba.
\v 12 Ushii anyẹ ọvọng umani ayiri ri shi ki ẹrẹnọma mi ri ni, akeri mi ọna mi wọ.
\v 13 “Aipang imẹ sọ tẹri nu, oka mani upii Ọnọng ri kya kidẹ asing ri ni asọ shuni na ayiri ri.”
\s1 IYahuza Yira Uma IYesu
\r (IMar 14.10-11; ILuk 22.3-6)
\p 
\v 14 Ni aghọ aye kidẹ aghọ ushọ na apai, umani aka yọrọ si iYahuza Iskariyoti kyaa ukushi afirist akakọng
\v 15 ki tẹri bọ si, “Ikẹmbọ ni inu sọ ma mi insi imẹ ma nu nga ni? Asa pila atii ayer ishitai ki ma nga.
\v 16 Kọ sang ka akyua ra kọ ni asọ wang utra umani asọ ma nga.
\s1 IYesu la imila amaa kina Aghọyii nga
\r (IMar 14.12-21; ILuk 22.7-13; ILuk 7.21-23; IYah 13.21-30)
\p 
\v 17 Kidẹ awii iye usra agya ubulu umani ishi yọ nọ uyisti ba ya ba ni, aghọyii iYesu kyaa ukushi nga ki ghulu nga ni, “Abi wọ ni ayọ so kyeri ọka la imila usra agya ubulu ko?”
\v 18 Ava yira si, “Inu ghila idẹ ifọng inu kyaa ukushi ace ghọ inu tẹri nga si,” “Aghọmẹẹ tẹri si akyua nga kọ ba ayayo, awang la imila usra agya ubulu kina aghọyii nga kidẹ ọna ngọ.”
\v 19 Aghọyii nga sa ju kọnọ mani a tẹri bọ ni, asa kyeri usra agya ubulu.
\v 20 Ughẹ ya ba ni, iYesu sa cica ula imila kina aghọyii nga ọshọ na pai
\v 21 Ashi kidẹ ula imila ni ava tẹri si, “Aipang ni imẹ sọ tẹri nọ aghaye kidẹ nọ ki ma mi.”
\v 22 Ava kọng ikwyi ibibi nagigang ki lite nọ tẹri nga ka yayi bọ ni, “Imẹẹ Ate?”
\v 23 IYesu sa yira si, “Aghọmani asọ ta avọ nga kidẹ isọ kini mẹ ri nga ki ma mi.
\v 24 Anọ Ajiya sọ woru kọnọ umani awọọ ila nga ni. Ọlọ kukushi aghọmani ama Anọ ajiya! ọda kọ cẹẹ umani ajee bọ nga ba.”
\v 25 Ni iYahuza umani ama nga va tẹri si, “Aghọmẹẹ, imẹẹ? “IYesu va tẹri nga si, “Uwẹ ni ingọ tẹri.”
\s1 Ọla ujibi na iYesu
\r (IMar 14.22-26; ILuk 22.15-20)
\p 
\v 26 Ashi kidẹ ula imila ni, iYesu va kpaa ubiredi ki sa izaa kukushi Ọnọng, asa zuru ki ma aghọyii nga ki tẹri si “Inu yira kọ ula, ẹrẹnọma mi kọ.”
\v 27 Asa va kpaa ima ọsa ki va sa izaa, ki va ma bọ si “Inu sa nadidu nu.”
\v 28 Uwẹ ni ayi mi mani aloo ki kyo umani asọ na kọ na ajiya peni ukpaa avulu bọ.
\v 29 Imẹ so tẹri nọ, imẹ sọ va sa mi kidẹ na amusumu ikọlọ na ashẹ ri ba, sa awii umani aghọ sọ sa isisa kidẹ ẹrẹgọm Ate.”
\v 30 Aya ta atẹ ubrẹ Ọnọng ni, aba kunu ki woru kya bọ izizẹ uzaitun.
\s1 IBitrus ki la inang uye IYesu
\r (IMar 14.27-31; ILuk 22.31-34; IYah 13.36-38)
\p 
\v 31 Ni iYesu va tẹri bọ si, “Na adi ating ri ni inu sọ sra kaya mi kọnọ umani awọọ ni, “Imẹ sọ gyo aghọcee, Atẹm sọ furu bọ.
\v 32 Insi imẹ sisang ni, imẹ sọ shi ite uworu kya mi ifọng aGalili.”
\v 33 IBitrus va yira nga si, “Insi asang bọ nadidu bọ kaya ngọ ni, imẹ ki sang mi nga ba.
\v 34 IYesu yira nga si, “Aipang imẹ sọ tẹri ngọ akọr ta kọ ta ẹrẹwyuẹ na ating ri ni ingọ so sra uye mi ẹrẹtai.”
\v 35 IBitrus va yira nga si, “Insi asọ pii mi ni ngọ wọ ni, na apii mi, imẹ ki sra mi uye ngọ ba.” Aghọyii nga nadidu tẹri kindọ.
\s1 IYesu pii nọ Ọnọng ka aGetsemani
\r (IMar 14.32-42; ILuk 22.39-46)
\p 
\v 36 IYesu va sang kya nga ka uce ọka aka yọrọ si aGetsemani, ava tẹri aghọyii nga si, “Inu cica kọ ukẹẹ, ni imẹ kyaa ki ya pii nọ Ọnọng.”
\v 37 Akpaa iBitrus kina anọ iZabadi apai kina inga, asa dẹẹ kọ duma kina ikwyi ibibi.
\v 38 Ava tẹri bọ si, “Ikwyi mi sọ lọ nagigang kini isọ kpo mi ni. Inu tara kọ ukẹẹ ka inu kra mi,”
\v 39 Aya woru na zẹẹ ni, aba kpaa ki ẹrẹbọ kina ibate ki pii nọ Ọnọng si, “Ate mi, insi uki ju ni, kpaa mi idi isọ ọlọ ri kọ. Basi uyoo mi ba, uyoo ngọ wọ ni asọ ju.”
\v 40 Aya vuu kyaa nga ukushi aghọyii nga ni, aya peni bọ na asọ moo. Aba ghulu iBitrus si inu ta bra nọ ukra mi ba kidẹ ana akyua na aye ba?”
\v 41 Inu kra ka inu upii nọ Ọnọng ka inu ba kpaa kidẹ umra ba. Aghing wang ni ẹrẹnọma shi wọ ni ẹrẹkyuọ ba.
\v 42 Ava vuu kyaa nga kọ unga ipai ki ya pii nọ Ọnọng si, “Ate mi, insi idi isọ ọlọ ki woru wọ ba sa imẹ sa wọ ni, taa ni aju kọnọ uwang ngọ ni.”
\v 43 Aya ba vuu ki ba peni bọ na asọ moo, ka ọmọọ sọ lọ bọ nagigang.
\v 44 Ava vuu kyaa ki ya bọ ya ki ya va pii nọ Ọnọng unga itai, ki va tẹri bọ ima iyiye ra.
\v 45 Aya vuu kyaa ukushi aghọyii nga ni asa tẹri bọ si “Inu sọ shi kọ moo ni inu uwuru? Inu nu akyua ya fọma umani asọ ma Anọ Ajiya kidẹ ivọ aghọ uvulu.
\v 46 Inu sisang ka ayọ ba kyai. Aghọ ki ma mi wẹ na aki ba!”
\s1 Akpẹnẹ IYesu
\r (IMar 14.43-50; ILuk 22.47-53; IYah 18.3-12)
\p 
\v 47 Asọ shi kọ upii ni, iYahuza aghaye kidẹ ushọ na pai, ghila kina ajiya na pam kina ukuma ọkọrọ kina ashẹ. Afirist akakọng kina aghite bọ tuma bọ.
\v 48 Aghọ umani ama nga kọ ma bọ amaa si, “Aghọmani imẹ kẹni nga ni, aghọ ngaa, inu kpẹnẹ ngaa.”
\v 49 Kọ ukyaa ni, aba wor kyaa ukushi iYesu ki ya ju si, Isọ bili ngọ, aghọmẹẹ!” Aba kẹni nga.
\v 50 IYesu tẹri nga si, “Ayikyo, ju imumani ingọ ba uju.” Ajiya va ba ki ba kpẹnẹ iYesu.
\v 51 Aghaye kidẹ aghọ shi kina iYesu nawa avọ ki woo ikuma ọkọrọ nga, ki kpa ọtọng agira ifirist ighighẹ wọ.
\v 52 IYesu va tẹri nga si “Vuu ni ikuma ngọ, “Aghọmani awoo ikuma ni ikuma kọ ki pii nga.
\v 53 Inu kyoo kini ni imẹ ta ki bra mi ushọr Ate mi na ashẹ mi kọ ba, kidẹ ana akyua na jii ni ata tuma na atuma nga napam ba?
\v 54 Asọ hwura iwọọ umani awọọ kidẹ awọ na nyi unga umani utẹri si uki ba kindi?”
\v 55 Kidẹ akyua ni iYesu tẹri ajiya si, “Inu kunu kina ukuma kina ashẹ inu wang kpẹnẹ mi kina aghọ upili ajiya ni? Kọ agba awii imẹ shi kidẹ ọna Ọnọng kọ umẹẹ, inu ta kpẹnẹ mi nga ba.
\v 56 Ni udii ba kọ uhwura imumani awọọ kidẹ awọ aghọ pii kọ ọtọ Ọnọng.” Aya kọọ kindi ni, aghọyii nga va ya nga ki tẹ bọ.
\s1 IYesu kite aghọ tẹri Ashuwa
\r (IMar 14.53-65; ILuk 22.54-55; IYah 18.13-14; IYah 18.19-24)
\p 
\v 57 Aghọmani akpẹnẹ iYesu kya bọ kina nga kukushi iKayafa ifirist ucẹẹ nọ ọghọghẹ, ọka umani aghọmẹẹ umẹẹ iMusa kina aghite curu wọ.
\v 58 IBitrus va ki yii nga ka atatọọ, ki ghila idẹ ọna ifirist ucẹẹ nọ ọghọghẹ. Asa ghila ki cica kina aghọ sha irisha, awang nu imumani isọ ba.
\v 59 Afirist akakọng kina aghọ utẹri ashuwa apai wang kpẹnẹ iYesu nọ uvulu na atọ peni imumani asọ pii nga wọ.
\v 60 Ata peni bọ ba ni, ace aghọ ta atẹr va kunu. Aya kpẹẹ ni ace agha apai ba kunu.
\v 61 Asi, “Adii ajiya ri si inga ki bra upulu ọna Ọnọng kọ ka avra kidẹ awii atai.”
\v 62 Ifirist ucẹẹ nọ ọghọghẹ sa sisang ki tẹri iYesu si “Ingọ ki gẹẹ ngọ ba? Upii umani asọ tẹri ka aya ri ni?”
\v 63 Ni iYesu shu nga na kikir. Ifirist ucẹẹ nọ ọghọghẹ ba tẹri nga si, “Imẹ dra ngọ nọ Ọnọng aghọ akyuọ, tẹri ayọ ta ingọ shi iKristi, Anọ Onọng.”
\v 64 IYesu yira si ingọ tẹri, imẹ sọ tẹri nu kite ni Anọ ajiya sọ cicaa ka avọ ila aghọ shi na ẹrẹkyuọ, aki ba ka ayẹrẹmọọ.”
\v 65 Ni ifirist ucẹẹ nọ ọghọghẹ sa gaa igba nga ki tẹri si, “Asọ pii agbagbara nọ Ọnọng! Agba amaa nga ni awang. Inu kọng umani asọ pii agbagbara nọ Ọnọng.
\v 66 Ikẹmbọ ni inu nu? “Asa yira si amaa ukpo!”
\v 67 Asa taa nga akpe ki ibate, ki ca nga, ace aghọ bọ sa sra nga avọ.
\v 68 Ki tẹri nga si “Tẹri ayọ, inga gyo ngọ aghọfoo.”
\s1 IBitrus La Inang uye IYesu
\r (IMar 14.66-72; ILuk 22.56-62; IYah 18.15-19; IYah 18.25-27)
\p 
\v 69 Akyua ni iBitrus sa ya cicaa ka ayayẹ ọna ni, ace agira anayiri ba ukushi nga ki tẹri nga si. “Ingọ kọ shi kidẹ aghọyii iYesu agha aGalili.”
\v 70 Asa va la inang kọ kite bọ si. “Imẹ ta ye mi imumani inu sọ tẹri ba.”
\v 71 Aya kunu anyu ugẹẹ ni ace agira anayiri va sa nu nga ki tẹri ajiya ọka si, “Adii aghọ ri shi kina iYesu anga aNazaret!”
\v 72 Asa va sra kina usuu si “Imẹ ta ye mi nga ba!”
\v 73 Anakyua na zẹẹ ni aghọ umani atara kina iBitrus va tẹri si “Aipang, ingọ shi aghaye kidẹ bọ, ighọ upii ngọ yeni ngọ.”
\v 74 Asa kpẹnẹ usra ẹrẹkwyuẹ nga anyu ababi kina usuu si, “Imẹ ta ye mi nga ba!” kidẹ ana akyua ni akọr va ta ẹrẹwyuẹ.
\v 75 IBitrus va shuni upii iYesu umani asa tẹri nga, “Akọr ta kọ ta ẹrẹwyuẹ ni ingọ sọ la inang uye mi ẹrẹtai.” Asa kunu nga ki ya ta akpa uci nagigang.
\c 27
\s1 IYahuda ta Ajee
\r (IMar 15.1; ILuk 23.1-2; IYah 18.28-32)
\p 
\v 1 Ikyua ya yẹẹ ni, nadidu afirist akakọng kina aghite bajiya va tẹri ace bọ si abọ ba pii iYesu wọ.
\v 2 Ava lor nga, ki wolu ni nga, ki ma nga kukushi iBilatus aghọ ko ẹrẹbọ.
\p 
\v 3 IYahuda umani agbra iYesu nu ni awa iYesu ashuwa ukpo ni, ikwyi nga va bra yo, ava vuu ukushi afirist akakọng, kina aghite, ki ma bọ ufẹ aguza ishi itai ra.
\v 4 Ava tẹri si, “Imẹ ju avulu nọ umani imẹ ma ayi aghọ utaa avulu ka apii nga kọ.” Aba yira nga si, “Ikẹmbọ sọ unga yi? Udii ni, ọdọma ngọ kọ.”
\v 5 Ava naa ufẹ aguza ra kọ kidẹ ọna Ọnọng, akunu ki ya ta ajee ki kpoo.
\v 6 Kindọ ni afirist akakọng va yẹri ufẹ ko ki tẹri si, “Ushi wọ ikikya na akyo ufẹ kọ ọkọ ukyuru ufẹ ọna Ọnọng ba, kọ ufẹ na ayi bọ.”
\v 7 Ava pii ki kyo si, aghẹẹ ọka nira ajiya umani abiba, insi akpuru bọ ni, ọka wọ shi ayayẹ aghọ uvra uwoo.
\v 8 Kindọ ki ta kaidii ni ayọrọ oka si, ayayẹ na ayi.
\v 9 Kindọ ni ahwura imumani aghọ pii kọ ọtọ Ọnọng Irimiya tẹri si, “Akpa ufẹ aguza ishi itai, ufẹ umani ajiya Israila yira si ama ki ẹrẹkwyuẹ nga wudu.
\v 10 Ava ghẹẹ ayayẹ aghọ uvra uwoo nọ ufẹ, kọnọ umani Ate tẹri mi ni.”
\s1 IYesu kite IBilatus
\r (IMar 15.2-5; ILuk 23.3-5; IYah 18.33-38)
\p 
\v 11 IYesu titara kite aghọ ko ẹrẹbọ, ava ghulu nga si, “Ingọọ shi Agọm aYahudawa?” IYesu va tẹri nga si,
\p “Ingọ tẹri kindọ.”
\v 12 Afirist akakọng kina aghite keli nga, ata tẹri nga ice ima ba.
\v 13 IBilatus va ghulu nga si, “Ingọ ta kọng ngọ uma umani asọ tẹri kaya ẹrẹkwyuẹ ngọ ba?”
\p 
\v 14 Ni iYesu ta tẹri nga ice ima ba, ki ta kọ umani aghọ uko ẹrẹbọ wo ica nagigang.
\s1 Awa IYesu Ashuwa ukpo
\r (IMar 15.6-15; ILuk 23.13-25; IYah 18.39; IYah 19.16)
\p 
\v 15 Ko agba akyua usra agya ubulu ni, aghọ kọ ẹrẹbọ ka sa ni awo ajiya ayeng aghọ shina na avulu umani awang.
\v 16 Akyua ni ace aghọ umom shi kọ ubọọ iting na ayọrọ nga si iBarabas.
\v 17 AYahudawa ya curu ni, iBilatus va tẹri bọ si, “Ingaa nọ wang si isher nu? iBarabas ta iYesu mani ayọrọ iKristi ni?”
\v 18 Ka aye si irisho kọ sa na agbra iYesu kọ.
\v 19 Akyua umani iBilatus ci kọka ubọọ utẹri ashuwa ni, ayiri nga va tuma sa atẹri nga si, “Woo avọ ngọ wọ kọ upii aghọ taa avulu ra, ka aidi ni ikọng ọlọ nagigang ka amọ kaya ẹrẹkwyuẹ nga.”
\v 20 Ni, afirist akakọng va sẹr ajiya si ashọr ka asher iBarabas, na sọ pii iYesu kọ.
\v 21 Aghọ kọ ẹrẹbọ va kimi utẹri bọ si, “Ingaa kidẹ agha pai ri nọ wang si isher nu?” Ava tẹri si, “IBarabas.”
\v 22 IBilatus va tẹri bọ si, “Ni ikẹmbọ ni iki ju ni iYesu umani ayọrọ si iKristi?” Nadidu bọ va ju si, “Agra nga!”
\v 23 IBilatus va ju si ki ikẹ? Iligba ima ibibi yọ na ju?” ni ajiya va shang ayuẹ bọ ki tẹri si, “Agra nga!”
\v 24 IBilatus ya nu ni aki bra nga uju ima ba ni, na ajiya nga wang sang ikwyi bajiya ni, ava vo amusumu ki hwuru ivọ nga kọ kite ba ajiya, ki tẹri si, “Imẹ ni, ba iminẹ mi na ayi aghọ taa avulu ri. Udi ni iminẹ nọ yọọ.”
\v 25 Ajiya nadidu va yira ki tẹri si, “Taa ni ayi nga ki lara kaya akwyuẹ yi, iyi kina anọ yi!”
\v 26 Ukadu ni ava sher bọ iBarabas kọ umani azọnọ sa na ju iYesu aiwili, ava ma nga si agra nga.
\s1 Aghina akpọ Kali IYesu
\r (IMar 15.16-20; IYah 19.2-3)
\p 
\v 27 Ukadu ni aghina akpọ aghọ kọ ẹrẹbọ va kyaa ni iYesu ka idẹ ugunu nga, acuru ikir aghina akpọ ki ẹrẹbọ,
\v 28 Ava wuli nga uma kọ, ava fiya nga ice igbang isiseng.
\v 29 Ava tii ifarkwyuẹ ẹrẹgọm inga akara, ki sọmọ nga ki ẹrẹkwyuẹ, ki sa nga uko ashi kavọ ila nga, ava ta aghong kite nga na sọ kali nga na tẹri si, “Ọkyuọ ngọ tẹrẹ kọ, Agọm aYahudawa!”
\v 30 Ava taa nga na akpe, ava yira ashi ki ca nga kọ ki ẹrẹkwyuẹ.
\v 31 Aya kpẹr ukali nga ni, ava woo nga igbang isiseng kọ, ki sọmọ nga inga ngaa, ni asi woru ni nga kaya gra nga ka ya ukumu ọshẹ.
\s1 Agra IYesu kaya Ukumu ọshẹ
\r (IMar 15.21-32; ILuk 23.26-43; IYah 19.17-27)
\p 
\v 32 Asọ kyeng wudu ni, ava ta ẹrẹkwyuẹ na ace ajiya aSayirin, ayọrọ nga si iSiman, ava mẹni nga sa akpaa ukumu ọshẹ.
\v 33 Aya fọma ọkọ umani ayọrọ si aGolgota ni, ọkọ umani aka va ayọrọ si ọka agboho ẹrẹkwyuẹ.
\v 34 Ava ma nga amusumu ikọlọ na ashẹ kini ice ma ọkọkasi si asa, aya ghẹli ni ava tọọ nga usa.
\v 35 Aya gra nga ni, ava kau ugba nga kọ uwuru itoo.
\v 36 Aya kpẹr ni ava cica na sọ sha nga.
\v 37 Ka aya ẹrẹkwyuẹ nga ni awọọ avulu nga si, \sc ANGA SHI IYESU, AGỌM aYAHUDAWA. \sc*
\v 38 Agra ace ayi aghọ dara itra agha apai kini inga, adaa kavọ ila adaa kavọ iprọma nga.
\v 39 Ajiya mani awolu ni asọ jer nga amira na sha zuru akwyuẹ bọ,
\v 40 Na sha tẹri si, “Ingọ aghọ umani ingọ tẹri si ingọ ki pulu Ọna ọnọng, kọ vra ki da awii atai ni, foo ẹrẹkwyuẹ ngọ ni! Insi ingọ ni Anọ Ọnọng nga ni, shulu kaya ukumu ọshẹ ni!”
\v 41 Kindọ ni afirist akakọng, kina aghọmẹẹ umẹẹ iMusa, kina akwyite sha sra nga, na tẹri si,
\v 42 Afoo ace aghọ bọ, ata bra nga ufoo ẹrẹkwyuẹ nga ba, inga ni Agọm Israila nga, tara na shulu ka ya ukumu ọshẹ, akyua ra kọ ni iyi ki ma aipang ni ngaa wọ.
\v 43 Atọrọ nọ Ọnọng. Tara na Ọnọng kara nga ka kyuakyuari, ipeni awang ni, ka atẹri si inga ni anọ Ọnọng ngaa.”
\v 44 Kindọ ni aghọ dara itra mani agra bọ kọ, abọ tọ tẹr nga upii ububi.
\s1 Ukpo iYesu
\r (IMar 15.33-41; ILuk 23.44-49; IYah 19.28-30)
\p 
\v 45 Kọ kpaa na atinọng, iting yuru ẹrẹbọng ya naidu, ki ta ka karfe atai angọ ọghẹ.
\v 46 Akarfe atai ni iYesu va shang ẹrẹwyuẹ naigang ki tẹri si, “Eloi, Eloi, lama sabaktani?” si, “Ọnọng mi, Ọnọng mi, Ikẹmbọ sa nọ ọta mi utumu?”
\v 47 Akyua umani ace aghọ uting kọ kadu ya kọng kindọ ni, ava tẹri si, “Ajiya ri sọ yọrọ Iliya kọ.”
\v 48 Kaishang ace aghọ va titi ki ya kpaa asọsọ, ki sọ ka amusum ukpọkpam ki ikọlọ na ashẹ, ki sọmọ kashi, ki nawa nga sa asa.
\v 49 Ni ushẹ aghọ bọ va tẹri si, “Inu ya yaa ki inu, ta Iliya ki ba ka ba foo nga ni.”
\v 50 IYesu va ci naigang, ava shee aghing nga.
\v 51 Ugyauto umani ushi kọ ọna Ọnọng giya wo ika ipai, kọ kpaa kaya ki ba wọ ata. Ẹrẹbọng zuru, atii va sara yọ.
\v 52 Ava yeri alọr, anọma aghọ shi ayer naigang mani akọ kpuru bọ sang ka akyuọ.
\v 53 Asang ka alọr bọ, iYesu ya sisang ka lọr ni, ava ghila bọ ifọng aghọ upipar, ajiya napam nu bọ.
\v 54 Akyua umani agha aghaghẹ aghina akpọ aRoma kina ọshẹ aghọmani ashi kọ ọna iYesu na nu zur ẹrẹbọng kini imumani ibani, ava kọng ẹrẹbata nagigang, ava tẹri si, “Aipang na ajiya ri ni Anọ Ọnọng nga!”
\v 55 Ace ayiri shiwu napam mani ayii iYesu kọ kpaa ka aGalili asọ she nga ni itina. Ati tara ka atọọ na sọ kyoo imumani isọ ba.
\v 56 kidẹ bọ ni iMaryamu iMagadaliya, kina iMaryamu ayuru iYakubu kina iYusufu, kina ayuru anọ iZabadi.
\s1 Ọnaa IYesu ka Alọr
\r (IMar 15.42-47; ILuk 23.50-56; IYah 19.38-42)
\p 
\v 57 Ughẹ ya ju ni, ace aghọlọ upeni, agha ifọng Arimatiya, aghọnọ uca si iYusufu ba, inga ni aghọyii iYesu ngaa.
\v 58 Akyaa ukushi iBilatus kiya shọr si ama nga ọkọng iYesu. IBilatus va ma anyu si ama nga.
\v 59 IYusufu va kpaa ọkọng iYesu ki wuru kọ ugyauto alilin ọngọ upipar.
\v 60 Ata nga kidẹ alọr asasa nga, angọ mani atumu kidẹ upang. Ava yini utii ọghọghẹ ka anyu alọr, ava woru.
\v 61 IMaryamu iMagadaliya, kini idaa iMaryamu ci ki ta ibate na alọr nga.
\s1 Aghọ usha ka Alọr
\p 
\v 62 Awini ikyua ni, awii uloru ki kyo, afirist akakọng kina aFarisiyawa curu kite iBilatus,
\v 63 Na tẹri si, “Aghọ ọna! Imẹ shuni kini imumani aghọ ghẹmi ajiya ra tẹri na sọ shi akyuọ, si kidẹ awii atai ni aki sisang ka alọr.
\v 64 Kindọ ni sa ka asha alọr nagigang kaya ta awii atai, ka aghọyii iYesu kọnọ maya yi ọkọng ngau ba, na sọ yi ngau na tẹri ajiya si, asisang ka alọr. ọghẹmi ti tẹ ki gina ọngọ tumu ubibi.”
\v 65 IBilatus va tẹri bọ si, “Inu nu aghina akpọ, inu kya kọ ya sha nga nọ mani ọki bra.”
\v 66 Ava kya kiya sha alọr, ki gyo ẹrẹkwyuẹ agọm ya kọ utii alọr, ava sa aghina akpọ kọ ọkaa.
\c 28
\s1 Usisang IYesu ko ukpo
\r (IMar 16.1-8; ILuk 24.1-12; IYah 20.1-10)
\p 
\v 1 Awii uwuru aYahudawa ya woru kọ, awii iLadi, na abidikyua ni, iMaryamu iMagadaliya kyeng na daa iMaryamu, ki kyaa ukra alọọ.
\v 2 Ẹrẹbọ ukaa ba zuru ni ẹrẹkyuọ, atuma Ọnọng kunu ka ayaya, ki yini utii umani a fiya alọọ kọ, ki cicaa ya ka yaa.
\v 3 Ukunu nga shi kina ọsọma aviya wọ ni, uma nga si ufufuu na tas.
\v 4 Aghọ sha ẹrẹsha sa kọng ẹrẹbata nagigang, na asọ titaa, ki kpaa ki ẹrẹbọ kina akpuru bọ ni.
\v 5 Ni atuma Ọnọng tẹri ayiri si, “Inu ba kọng ẹrẹbata ba, imẹ ye ni inu sọ kra iYesu, aghọmani agra nga ka ukumu ọshẹ ra.
\v 6 Ashi nga ya ba, akọ sisang kọnọ umani atẹri ni. Inu ba ka inu ba nu ọkọ umani ayaa nga kọ.
\v 7 Inu wẹmọọ uvuu kọ uya tẹri aghọyii nga si, ‘Akọ sisang kidẹ aghọ ni akọ kpuru bọ na akọ lite ki kyaa aGalili. Ukadu wọ ni inu ki ya nu nga kọ.’ Uwọ ni imẹ utẹri nu.”
\v 8 Ayiri ba wẹmọọ usang bọ ka alọọ ni ẹrẹbata kina ikwyifu, ki wor nọ uti ki ya tẹri aghọyii nga.
\v 9 Ka akyua ra ni iYesu kunu ki peni bọ ki tẹri bọ si “Imẹ sọ bili nu.” Asa yini kya ayayo nga ki kpẹnẹ afra nga ki jọọ nga.
\v 10 Ni iYesu va tẹri bọ si, “Inu ba kọng ẹrẹbata ba. Inu kya kọ ya tẹri anayuru mi si akya bọ aGalili, ukadu wọ ni aki nu mi ko.
\s1 Ila aghọ sha ẹrẹsha alọọ
\p 
\v 11 Ayiri shi kọ utra ni, ace aghọ sha ẹrẹsha ki wor kya bọ idẹ ifọng ka aya tẹri afirist akakọng ta imumani iba.
\v 12 Afirist akakọng takwyuẹ kina aghite ki dọmọ, ava ma aghina akpọ ufẹ napam,
\v 13 ki tẹri bọ si, “Inu tẹri si aghọyii nga bọ ba yi nga kọ na ating akyua umani ayọ sọ moo kọ.
\v 14 Insi ila kyaa atọ aghọ ko ẹrẹbọ ni, ayọ ki pẹni ni nga inu ba ghila nu ọlọ la.
\v 15 Aghina akpọ ba kpaa ufẹ ki ju kọnọ umani atẹri bọ ni. Ni ila ri sa kpaa kidẹ aYahudawa ki ta kaidii.
\s1 Utina ni iYesu ma Aghọyii nga
\r (IMar 16.14-18; ILuk 24.36-49; IYah 20.19-23)
\p 
\v 16 Aghọyii nga ọshọ na aye sa wor kya bọ ka aGalili, kọ ọpang umani iYesu tẹri bọ si aya takwyuẹ kọ.
\v 17 Aya nu nga ni asa jọọ nga, ace aghọ bọ ta yira bọ ba.
\v 18 IYesu sa yini kyaa ayayo bọ ki tẹri bọ si, “Ama mi ẹrẹgọrọ ayaya kina ashi ri nadidu.
\v 19 Kindọ ni inu kya kọ uya tẹri ajiya ashi ka ayii mi, usa bọ ka aba aghọyii mi, nu ju bọ iminimini kidẹ nọ uca Ate kini ugna Anọ kini unga Aghing Ọnọng.
\v 20 Inu mẹẹ bọ ka aju imumani imẹ sa nu uju. Imẹ wẹ ni ishi kini inu ko aligba akyua ki ya ta kọ usang ashi.
