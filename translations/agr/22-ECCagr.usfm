\id ECC
\h Eclesiastés
\toc1 Juninai pujutak
\toc2 (Eclesiastés)
\toc3 Ec.
\mt2 Juninai pujutak
\mt1 Eclesiastés
\c 3
\s1 Ashí waji nagkaema nunak maki makichik tsawanji ajuinawai
\p 
\v 1 Juju nugkanum ashí waji aidau nagkaemaina duka tsawanji mamiktuamu ainawai:
\b
\q1 
\v 2 Tsawan jegawai akiinbau,
\q1 tuja jamu, ajak ajakmamu,
\q1 nunú ajakmamu nejekmatai juwaamu.
\q1 
\v 3 Tsawan jegawai aents maamu,
\q1 tuja aents jakui tsuwamu,
\q1 yaakat tsayamu,
\q1 tuja yaakat tsaikbau ataktu yaaktabau jegawai.
\q1 
\v 4 Tuja buuttinush tsawan jegawai,
\q1 tuja shiig aneaku dushiamush,
\q1 jakamunum buutku wake besemag pujamush,
\q1 tuja jiistamatnush tsawan jegawai.
\q1 
\v 5 Tsawan jegawai kaya yajuaka utsamu,
\q1 kaya utsagbau yajuaka ijubau;
\q1 shiig anendaiku pagkuniamu,
\q1 tuja kanaamu.
\q1 
\v 6 Tsawan jegawai kuichik juwamu,
\q1 tuja takatsuk wainka pujamu,
\q1 ii takasa jukimu anetamu,
\q1 tuja ii anettsamu utsamu.
\q1 
\v 7 Tsawan jegawai jáanch ichiamu,
\q1 nunú ichigbau apigbau,
\q1 chichatsuk pujamu,
\q1 tuja tsawan jegawai chichaamu.
\q1 
\v 8 Tsawan jegawai aneeniamu,
\q1 kajegdayamu, maaniamu,
\q1 maanitsuk agkan shiig pujamu.
\b
\p 
\v 9 Aents senchi takak waitia dusha ¿waji pegkegna juwawa?
\v 10 Tuja Apajuí aents aidaunak takainak batsamsatnume tusa, kuashat takatan susauwa nuna anentaimsan ejemaijai.
\v 11 Tuja Apajuí juju nugkan najanauwa duwi nagkamas, aentsnak shiig pegkejan najanauwai. Dutika unuimatan susauwai, atakea duish wajig nagkaemajagtinaita nuna dekatnume tusa. Tujash dutikamaitak, aents aidauk Apajuí yama nagkamchak najankauwa nunak shiig dekamainchau dekapenawai.
\p 
\v 12 Nuadui wika dekajai dekas aentsuk eke iwaku puja duik, pegkejan takak shiig aneas pujumainai.
\v 13 Tuja ii yutai aidau yuwaku, umutai umag duka ii takasa jukimunmaya dutikaji, wagki Apajuí nunak amasu asamtai.
\v 14 Tuja nuigtushkam dekajai ashí Apajuí najankamu aina duka tuke asatna nunak:
\q1 Nii najankamua duka
\q1 nuwi ekekaik makichkish najanmaitsui,
\q1 tuja emegkautkesh emegkaumaitsui.
\q1 Nunak Apajuí dutikauwai,
\q1 wagki niina senchijin dekaatnume tau asa.
\q1 
\v 15 Ashí yamai ayá duka yaunchuk aijakua nunuwai,
\q1 tuja atakea duwi agtina dushakam
\q1 yamai ayá nunuwai.
\q1 Tuja yaunchuk nagkaemajua nunak
\q1 Apajuí ataktu nunikti tusa tima ataktu wantinui.
\s1 Aents jakug nugka yukukuntu najaneawai.
\q1 
\v 16 Juju nugkanmak apu aidauwap shiig takasagtatua
\q1 tusa eme anentamaitak,
\q1 ima pegkegchaunak takainak
\q1 aentsun waitkaina nuna
\q1 anentaimsan ejemaijai.
\p 
\v 17 Nuadui Apajuí aents aidaunak tsawan jegatna duwi pegkejan takasunash pegkegchaun takasujai mai apatuk dekajuatnai.
\p 
\v 18 Tuja nuigtushkam aentsu pujutjig kuntinu pujutijaig betekmamtina nuna Apajuí ditan dekamtikaun anentaimsan ejemaijai.
\v 19 Shiig anentaimsa diyamak, aents aidaush, tuja kuntin aidaush mayattaiji betek ajamu asag, tsawanji jakatin jegagmak betek jainawai. Wagki juju nugka juwi pujutak aajayai.
\q1 
\v 20 Ashí iwaku aina duka betek jainawai.
\q1 Nunikag nugka yukukuntui najanamu asag,
\q1 nunisag ataktu nugka yukukuntu wajasagtinai.
\p 
\v 21 ¿Ya tumainaita, aentsu wakanig yakí nayaimpinum weawai, nuniai untsu kuntinu wakani nugka initken akaewai tusash?
\p 
\v 22 Untsu jaka ajin inantamki, atakea duish wajig nagkaemakinta nuna iwaintugmamainuk makichkish atsawai. Nuadui ii takasa juwamua duwi ii wakegamu takaku shiig aneasa pujumainun anentaimsan ejemaijai, wagki iik nuni takas pujusti tibau ainaji.
\c 9
\s1 Iwaku pujamu jaka megkaebaujai anentaimtusa diyamu
\p 
\v 7 ¡Wainka anentaimkum waitu pujutsuk, Apajuí amina takatjumin shiig anenjamsau asamtai, yutai yuwam, umutai vino uwajam shiig aneasam pujusta!
\v 8 Amek jáanch puju tuké nugkuta, nuniakum kugkuin buukmin tuké nijamta.
\p 
\v 9 Juju nugka juwi pujutak wainkaya nuna Apajuí amasua nuwi pujusam, amina nuwem aneetaigmea nujai kashi kashinig shiig anendaisam pujusta. Nunuwai ame kuashat takaku waitiam duwi pegkeg juwamua duka.
\v 10 Ashí ame takamain ajutjamkuig, duka ame dekapmamsam takasta; wagki ame jakam wetatam nuwig takamainuk, tuja dekatan jukitjai tusa waitmainchakam makichkish atsutnai.
\p 
\v 11 Tuja tupikamunum depetma duka ya ima senchi tupikawa nunú depetmatsui, tuja maaniamunum depetma dushakam nunú ima wajiu asagkesh nuniatsui; tuja yacha aina nuna yumainjig tuké ajuinatsui, wamak unuibau aina dusha wiakchak ainatsui. Tuja papiin unuimaju aina dusha shiig anenmak ainatsui; ditanushkam shiig pujamu shiig pujachbaush jegajuinawai.
\p 
\v 12 Tuja dekatsji wajutik ii jakatnush tsawantash jegagtamti duka, nuadui red nená ukukbaunum namak nemama numamtuk, tuja pishak achitai nená ukukbaunmashkam pishak nemama numamtuk pachiachbau ii waittsatnunum jegaku waitiaji.
\c 11
\q1 
\v 1 Aents yapajau wainkumek, yutai susata yuwati.
\q1 Nunú dutikau asam,
\q1 makichik tsawantai ameshkam dutiksaik iikuam atatme.
\b
\q1 
\v 2 Aminu ajutjama duka anetu pujutsuk ajamasta,
\q1 wagki amek dekatsme
\q1 waji utugchatak juju nugka
\q1 juwish nagkaemakti duka.
\q1 
\v 3 Yujagkim bukusea weakug yumi yutak nuniawai.
\q1 Numi katugak nujinum, tuja nuniachkush
\q1 tsumunmagkesh iyakug tuwi iyaje, nuwig tepestinai.
\q1 
\v 4 Ajakmatasa wakegakmek dase dii pujuipa;
\q1 tuja ajak ajakmamu juuktag takumek
\q1 nayaim dii pujuipa.
\b
\p 
\v 5 Dase dasenkash itug weawaki nunú dekatsum numamtuk, tuja uchish wajuk najaneawaki dusha dekatsum numamtuk, Apajuí ashí najankauwa nunash wajuk dutikaukita duka dekatsme.
\p 
\v 6 Kashikmasam ajakmata, tuja agkushkam ajakmata, wagki yama nagkamchaku ajaamua nunuwash ima shiig nejekat, atsa, ukuunum ajamua nunuwash ima shiig nejekat, aatsa nuniachkush mai betekash nejekat duka dekamainchau asamtai.
\c 12
\q1 
\v 1 Eke múuntuch wetsuk yamai datsauchitam duik
\q1 Apajuí amina najapauwa nunú aneaku ata.
\q1 Tuja tsawan waitiamu jegamtai,
\q1 ame chichaakum:
\q1 “Kuashat tsawan waitu pujutak shiig awajtatsui”,
\q1 titinaitme.
\q1 
\v 2 Eke etsa, nantu, yaya aidau
\q1 etsanbaujin kajinainatsaig,
\q1 amina najapauwa nunú adeagta.
\q1 Tuja yumi yutug nagkankamunum
\q1 yujagkim wajas awa duik adeagta.
\q1 
\v 3 Tuja tsawan jegattawai
\q1 apu pujusa inamtain kuitamin aidau
\q1 ishamkagtuinak kujainamu.
\q1 Tuja aents wajiu aidaush
\q1 ishamkagtuinak tikishmasua waigkagtatui;
\q1 tuja trigo dekeen aidaushkam ujumchik asag
\q1 dekeetnak idaisagtatui.
\q1 Tuja jeganum niimtai ujaimunum niimin aidaushkam
\q1 wainmamainchau wajasagtatui.
\q1 
\v 4 Nunú tsawan jegamtaig,
\q1 waiti aidauk ashí epenjamu atatui.
\q1 Tuja trigon dekeenak
\q1 tatagmitkamushkam itatjagtinai.
\q1 Nuninai untsu pishak shinuinamu senchi antuetinai.
\q1 Untsu ame kantabaugmek
\q1 shiig antumainchau initak kujakjatu antuetinai.
\q1 
\v 5 Nunú tsawan jegakuig
\q1 nainnum wamu ishamtinaitme.
\q1 Tuja iyajaig tusamshakam ishamtinaitme.
\q1 Tuja almendro yagkujamu nagkamnattawai,
\q1 tuja amina iyashmek makichkish
\q1 atsumchattame, ayatak manchi pakaemag
\q1 nanapjug nanaak wegama numamtuk
\q1 atasam duke dakattame.
\q1 Nunú jegakuig amek ataktu wakitki
\q1 tashtinnum wetinaitme,
\q1 nunikamin aents aidau ame jakamin
\q1 buutuinak agá tuwagtamkagtinai.
\q1 
\v 6 Nuadui amina pujutjum
\q1 plata najanamui anaa emetuamua
\q1 numamtina nunú eke tsujintsaig,
\q1 tuja ichinak oro najanamu tsaintsu duik,
\q1 tuja nuigtushkam ichinak yumi shikitaiya
\q1 nunú eke tsainak ajapnatsaig,
\q1 yamaya juwik Apajuí amina najapauwa nunú
\q1 kajimattsuk umigkata.
\q1 
\v 7 Nunú tsawan jegamtaig,
\q1 amina iyashmek nugka yukukuntu wajastinai,
\q1 wagki amek nugka yukukuntu juki najanamu asam.
\q1 Untsu wakanik Apajuíyai wakitkittawai,
\q1 wagki nii amasbau asa.
\b
\q1 
\v 8 Wi Apajuí chichamen etsegnun juna ataktu tajai:
\q1 “¡Juju pujuta juwig iman pegkejak
\q1 makichkish atsawai!
\q1 ¡Ashí wainak ainawai!”
