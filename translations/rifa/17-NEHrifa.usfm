\id NEH
\h نَاحَامْيَا 
\toc1 نَاحَامْيَا 
\toc2 نَاحَامْيَا 
\toc3 نَاح. 
\mt1 نَاحَامْيَا  
\c 1
\s1 ثَازَادْجِيثْ ن نَاحَامْيَا إِ ڒْڭنْسْ ن إِسْرَائِيل  
\m
\v 1 \bd أَوَاڒنْ ن نَاحَامْيَا، مِّيسْ ن حَاكَالْيَا.\bd*  
\m إِمْسَارْ ذڭْ ؤُيُورْ ن كِيسْلُووْ، ذڭْ ؤُسڭّْوَاسْ وِيسّْ عِيشْرِينْ، ؤُمِي ذ أَيِي ثُوغَا ذِي ڒقْصَارْ ذِي شُوشَانْ،  
\v 2 أَقَا يُوسَا-د حَانَانِي، إِجّنْ زڭْ أَيْثْمَا، \add جْمِيعْ\add* أَكْ-ذ شَا ن يرْيَازنْ زِي يَاهُوذَا، ؤُشَا سّقْسِيغْ ثنْ خْ وُوذَاينْ نِّي إِنّجْمنْ، إِنِّي إِقِّيمنْ زِي ثْمحْبَاسْثْ، ؤُ خْ ؤُرْشَالِيمْ.  
\v 3 نِيثْنِي نَّانْ أَيِي: ”إِنِّي إِقِّيمنْ، إِنِّي ذِينْ إِقِّيمنْ ذِي لْعَامَالَا زِي ثْمحْبَاسْثْ، أَقَا أَثنْ ذِي ڒغْبنْ ذ أَمقّْرَانْ ؤُ ذِي ڒفْضِيحثْ ؤُ ڒْحِيضْ ن ؤُرْشَالِيمْ إِتّْوَارْژْ ؤُ ثِيوُّورَا نّسْ تّْوَاسّْشمْضنْثْ.“   
\m
\v 4 ؤُمِي سْڒِيغْ أَوَاڒنْ-أَ، إِمْسَارْ، أَقَا قِّيمغْ \add غَارْ ثمُّورْثْ\add*، رُوغْ ؤُ شضْنغْ شَا ن وُوسَّانْ، ژُومّغْ ؤُ ژُودْجغْ زَّاثْ إِ وُوذمْ ن أَربِّي ن إِجنْوَانْ.  
\v 5 نِّيغْ: ”أَ سِيذِي، أَربِّي ن إِجنْوَانْ، شكْ ذ أَربِّي ذ أَمقّْرَانْ إِسَّاڭّْوَاذنْ، ونِّي إِطّْفنْ ذِي ڒْعَاهْذْ ذ ثْمخْسِيوْثْ إِشوَّارنْ ذِي طّْوعْ ن يِينِّي شكْ إِتّخْسنْ ؤُ ن يِينِّي إِطّْفنْ ذِي ثْوصَّا نّشْ، \x ◘ \xo 1:‏5 \xt  ؤُف. 20‏:‏6؛ 34‏:‏7؛ ڒخْڒ. 14‏:‏18؛ أَعَوذ. 5‏:‏10؛ إِزهد. 86‏:‏15؛ 103‏:‏8؛ 145‏:‏8؛ دَان. 9‏:‏4 \x*  
\v 6 أجّْ أَذْ يِيڒِي ؤُمزُّوغْ نّشْ إِفْثنْ ؤُ ثِيطَّاوِينْ نّشْ أَرْزْمنْثْ، حِيمَا أَذْ ثسْڒذْ إِ ثْژَادْجِيثْ ن ؤُمْسخَّارْ نّشْ نِّي ژُودْجغْ أَسّْ-أَ زَّاثْ إِ وُوذمْ نّشْ، أَسّْ ذ دْجِيڒثْ، ذِي طّْوعْ ن أَيْثْ ن إِسْرَائِيل، إِمْسخَّارنْ نّشْ. نعْمغْ \add عَاوذْ\add* س دّْنُوبْ ن أَيْثْ ن إِسْرَائِيل إِ زِي خَاكْ خْضَانْ. نشّْ ذ ثَادَّارْثْ ن بَابَا، أَقَا نخْضَا \add أَكِيذكْ\add*.  
\v 7 نڭَّا أَكِيذكْ س وَاطَّاسْ ن ڒغْذَارْ ؤُ وَارْ نطِّيفْ شَا ذِي ڒُومُورَاثْ ذ ثْوصَّا ذ لْفَارَايِيضْ إِ زِي ثُومُورذْ إِ ؤُمْسخَّارْ نّشْ مُوسَا.  
\v 8 إِذَارْ أَوَاڒْ إِ ثُومُورذْ إِ ؤُمْسخَّارْ نّشْ مُوسَا ؤُمِي ثنِّيذْ: ”مَاڒَا كنِّيوْ ذ إِغدَّارنْ، أَقَا أَذْ كنِّيوْ سّْزدْجْعغْ جَارْ ڒڭْنُوسْ، \x ◘ \xo 1:‏8 \xt أَعَوذ. 4‏:‏25، 26، 27؛ 30‏:‏2، 3، 4\x*  
\v 9 \add مَاشَا مَاڒَا\add* ثْذوْڒمْ-د غَارِي، أَذْ طّْفمْ ذِي ڒُومُورَاثْ إِنُو ؤُ أَذْ ثنْثْ ثڭّمْ، وَاخَّا ذِينْ زَّايْومْ إِنِّي خْ يُوژّْڒنْ غَارْ طَّارْفْ أَنڭَّارْ ن ؤُجنَّا، نشّْ أَذْ ثنْ سّْمُونغْ سّنِّي، أَذْ ثنْ أَوْيغْ غَارْ ومْشَانْ إِ إِخْضَارغْ نشّْ حِيمَا أَذْ ذِينِّي سّزْذْغغْ إِسمْ إِنُو.  
\v 10 نِيثْنِي \add وَاهْ،\add* ذ إِمْسخَّارنْ نّشْ ذ ڒْڭنْسْ نّشْ نِّي ثْفكّذْ س جّهْذْ نّشْ أَمقّْرَانْ ؤُ س ؤُفُوسْ نّشْ إِجهْذنْ.  
\v 11 أَ، سِيذِي إِنُو، أجّْ أَذْ إِفْثنْ ؤُمزُّوغْ نّشْ غَارْ ثْژَادْجِيثْ ن ؤُمْسخَّارْ نّشْ ؤُ غَارْ ثْژَادْجِيثْ ن إِمْسخَّارنْ نِّي إِتّخْسنْ أَذْ تّڭّْوذنْ زڭْ يِيسمْ نّشْ. أجّْ أَمْسخَّارْ نّشْ أَذْ يَاوضْ أَسّْ-أَ ؤُ أوْشْ أَسْ أَرّحْمثْ زَّاثْ إِ وُوذمْ ن ورْيَازْ-أَ.“ نشّْ ثُوغَا أَيِي ذ أَوَارَّاذْ ن ؤُجدْجِيذْ.   
\b  
\b  
\m  
\c 2
\s1 أَجدْجِيذْ أَرْثَاحْشَاسْثَا ن لْفُورْسْ إِسّكّْ نَاحَامْيَا إِ ؤُرْشَالِيمْ  
\m
\v 1 ذڭْ ؤُيُورْ ن نِيسَانْ، ذڭْ ؤُسڭّْوَاسْ وِيسّْ عِيشْرِينْ ن ؤُجدْجِيذْ أَرْثَاحْشَاسْثَا، \add ؤُمِي\add* ثُوغَا ذِينْ بِينُو زَّاثْ إِ وُوذمْ نّسْ، إِمْسَارْ، أَقَا كْسِيغْ بِينُو ؤُشَا وْشِيغْ ث إِ ؤُجدْجِيذْ.عمَّارْصْ وَارْ نْزمّغْ زَّاثْ إِ وُوذمْ نّسْ.  
\v 2 \add خنِّي\add* إِنَّا أَيِي ؤُجدْجِيذْ: ”مَايمِّي إِنْزمّْ وُوذمْ نّشْ، ؤُ شكْ وَارْ ثحْڒِيشذْ شَا؟ أَقَا مَانْ أَيَا وَارْ إِدْجِي مْغِيرْ ذ إِجّْ ن ڒْحَاڒْ ن وُوڒْ إِبَارّْشْننْ.“ \add خنِّي\add* ذوْڒغْ نّْخڒْعغْ أَطَّاسْ.  
\v 3 نِّيغْ إِ ؤُجدْجِيذْ: ”ثُوذَارْثْ إِ ؤُجدْجِيذْ إِ ڒبْذَا. مَامّشْ وَارْ إِتِّيڒِي وُوذمْ إِنُو إِنْزمّْ، أَقَا ثَانْذِينْثْ، أَمْشَانْ ن إِمضْڒَانْ ن ڒجْذُوذْ إِنُو، ذ ڒْخَارْبثْ ذ ثوُّورَا نّسْ ثشَّا إِ-ثنْثْ ثْمسِّي؟“  
\v 4 إِنَّا أَيِي ؤُجدْجِيذْ: ”مَانْ \add خنِّي\add* مِينْ ثتَّارذْ شكْ؟“ \add خنِّي\add* ژُودْجغْ إِ أَربِّي ن إِجنْوَانْ  
\v 5 ؤُشَا نِّيغْ إِ ؤُجدْجِيذْ: ”مَاڒَا ثُوسَا أَسْ-د إِ ؤُجدْجِيذْ خْ ڒْخَاضَارْ ؤُ يُوفَا أَمْسخَّارْ نّشْ أَرْضَا زَّاثْ إِ وُوذمْ نّشْ، سكّْ أَيِي-د خنِّي غَارْ يَاهُوذَا، غَارْ ثنْذِينْثْ ن إِمضْڒَانْ ن ڒجْذُوذْ إِنُو، حِيمَا أَذْ ت بْنِيغْ عَاوذْ.“  
\v 6 \add خَاسْ ؤُشَا\add* إِنَّا أَيِي ؤُجدْجِيذْ، ؤُمِي ثقِّيمْ ثْجدْجِيذْثْ خْ ؤُغزْذِيسْ نّسْ: ”مشْحَاڒْ إِ غَا ثكّْ ثْوَاحِيثْ نّشْ ؤُ مڒْمِي إِ د غَا ثْعقْبذْ؟“ ؤُمِي ذ أَسْ نِّيغْ \add ڒْقدّْ ن\add* إِجّْ ن ڒْمِيجَاڒْ، إِتّْغِيڒْ أَسْ مَانْ أَيَا مْلِيحْ إِ ؤُجدْجِيذْ، ؤُشَا إِسّكّْ أَيِي \add ذِينِّي\add*.   
\m
\v 7 أَرْنِيغْ نِّيغْ أَسْ إِ ؤُجدْجِيذْ: ”مَاڒَا ثُوسَا أَسْ-د إِ ؤُجدْجِيذْ خْ ڒْخَاضَارْ، \add خنِّي\add* أَذْ أَيِي مّوْشنْثْ ثبْرَاثِينْ إِ لْوُولَاثْ \add ن ثمُّورْثْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add*، مَاحنْذْ أَذْ أَيِي يَارْزْمنْ ثَاوَّارْثْ مَاحنْذْ أَذْ أَوْضغْ غَارْ يَاهُوذَا،  
\v 8 ؤُڒَا ذ إِشْثْ ن ثبْرَاثْ إِ أَسَافْ، أَعسَّاسْ ن وفْثِيسْ ن ؤُجدْجِيذْ نِّي إِدْجَانْ أَمْ جّنّثْ، حِيمَا أَذْ أَيِي يوْشْ أَكشُّوضْ حِيمَا أَذْ \add زَّايسْ\add* نڭّْ ثِيحنْيَا إِ ثْزقَّا سنّجْ إِ ثوُّورَا ن ڒقْصَارْ نِّي \add إِدْجَانْ\add* زَّاثْ إِ ثَادَّارْثْ، ؤُ إِ ڒْحِيضْ ن ثنْذِينْثْ، ؤُ إِ ثَادَّارْثْ مَانِي غَا زذْغغْ.“ ؤُشَا إِوْشَا أَيِي ثنْثْ ؤُجدْجِيذْ مِينْزِي أَفُوسْ أَصبْحَانْ ن أَربِّي ثُوغَا ث خَافِي.  
\v 9 \add خنِّي\add* إِوْضغْ غَارْ لْوُولَاثْ \add ذِي ثمُّورْثْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add* ؤُ وْشِيغْ أَسنْ ثِيبْرَاثِينْ ن ؤُجدْجِيذْ. أَجدْجِيذْ إِسّكّْ أَكِيذِي ؤُڒَا ذ إِمقّْرَاننْ ن ڒْعسْكَارْ ذ إِمْنَاينْ ن إِيْسَانْ. \f ◼ \fr 2:‏9 \ft \+bd ’إِمْنَاينْ ن إِيْسَانْ‘\+bd* - نِيغْ ’إِنِّي إِندّْهنْ إِيْسَانْ‘.\f*   
\m
\v 10 \add ؤُمِي\add* سَانْبَالَّاطْ زِي حُورُونْ، ذ ثُوبِييَا، أَمْسخَّارْ أَعَامُّونِي، سْڒِينْ أَيَا، ثُوغَا أَيَا غَارْسنْ ذ إِشْثْ ن ثْمسْڒَاشْثْ ذ ثَاعفَّانْثْ أَطَّاسْ، أَقَا يُوسَا-د إِجّْ بْنَاذمْ حِيمَا أَذْ يَارْزُو ڒْخَارْ إِ أَيْثْ ن إِسْرَائِيل.   
\b  
\m  
\s1 نَاحَامْيَا إِبْذَا ڒْخذْمثْ نّسْ ذِي ؤُرْشَالِيمْ  
\m
\v 11 أَمُّو ؤُسِيغْ-د غَارْ ؤُرْشَالِيمْ ؤُشَا ذِينِّي قِّيمغْ ثْڒَاثَا ن وُوسَّانْ.  
\v 12 \add خنِّي\add* كَّارغْ ذِي دْجِيڒثْ، نشّْ ذ شَا ن يرْيَازنْ أَكِيذِي، ؤُشَا نشّْ ثُوغَا وَارْ سَّارْڭْبغْ ؤُڒَا ذ إِجّْ ن بْنَاذمْ خْ مِينْ ثُوغَا ذ أَيِي إِڭَّا سِيذِي ذڭْ وُوڒْ حِيمَا أَذْ ث ڭّغْ إِ ؤُرْشَالِيمْ، ؤُشَا وَارْ كِيذِي كْسِيغْ ڒْمَاڒْ مْغِيرْ ڒْمَاڒْ مِينْ خفْ إِ نْيِيغْ.  
\v 13 فّْغغْ س دْجِيڒثْ زِي ثوَّارْثْ ن ثغْزُورْثْ أَڒْ ؤُذمْ ن ثَاڒَا ن ڒْهَايْشثْ ؤُ \add سّنِّي\add* غَارْ ثوَّارْثْ ن ڒغْبَارْ. نشّْ خمّغْ ڒحْيُوضْ إِتّْوَارْژِينْ ن ؤُرْشَالِيمْ إِ زِي ثِيوُّورَا نّسْ ثشَّا إِ-ثنْثْ ثْمسِّي.  
\v 14 نشّْ نذْهغْ \add خنِّي\add* غَارْ ثوَّارْثْ ن ثَاڒَا ؤُ غَارْ ؤُيڒْمَامْ ن ؤُجدْجِيذْ، \add مَاشَا\add* وَارْ \add ثُوغِي\add* ذِينْ تَّاسِيعْ إِ ڒْمَاڒْ سَاذُو إِنُو حِيمَا أَذْ أَرْنِيغْ غَارْ زَّاثْ.  
\v 15 \add خنِّي\add* ڭعّْذغْ س دْجِيڒثْ خْ ثْسدْجْيَا ؤُشَا خمّغْ ڒْحِيضْ ؤُشَاعقْبغْ-د، ؤُشَا ؤُذْفغْ عَاوذْ غَارْ ثوَّارْثْ ن ثغْزُورْثْ. \add أَمُّو\add* إِ-د -عقْبغْ.   
\m
\v 16 وَارْ سِّيننْ إِمْضبَّارنْ مَانِي ثُوغَا رُوحغْ ذ مِينْ ثُوغَا خْسغْ أَذْ ڭّغْ. مَاغَارْ أَڒْ ذِينْ وَارْ سَّارْڭْبغْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ إِ وُوذَاينْ ذ إِكهَّاننْ ذ ثَارْوَا ن ثَاصِيڒثْ ذ إِمْضبَّارنْ ؤُڒَا إِ إِنّغْنِي إِنِّي إِقِّيمنْ إِ ڒْخذْمثْ.  
\v 17 \add خنِّي\add* نِّيغْ أَسنْ: ”كنِّيوْ ثتّْوَاڒَامْ ڒغْبنْ إِ ذِي ندْجْ، أَقَا ؤُرْشَالِيمْ ثتّْوَارذدْجْ ؤُ ثِيوُّورَا نّسْ ثشَّا إِ-ثنْثْ ثْمسِّي. أَسمْ-د، أَذْ نبْنَا ڒْحِيضْ ن ؤُرْشَالِيمْ، حِيمَا وَارْ نتّْوَاسّحْقَارْ عَاذْ كْثَارْ.“  
\v 18 نشّْ حَاجِيغْ أَسنْ مَامّشْ أَفُوسْ ن سِيذِي إِنُو ثُوغَا ذ أَصبْحَانْ خَافِي ؤُڒَا ذ أَوَاڒنْ إِ ذ أَيِي إِنَّا ؤُجدْجِيذْ. \add خنِّي\add* نَّانْ: ”نشِّينْ أَذْ نكَّارْ أَذْ نبْنَا.“ ؤُشَا نِيثْنِي سّْجهْذنْ إِفَاسّنْ نْسنْ إِ \add ڒْْخذْمثْ-أَ\add* ثَاصبْحَانْثْ   
\m
\v 19 \add ؤُمِي\add* سْڒِينْ ث سَانْبَالَّاطْ، زِي حُورُونْ، ذ طُوبِييَا، أَمْسخَّارْ زڭْ أَيْثْ ن عَامُّونْ، ذ وعْرَابْ جَاشَامْ، سّْثْهزَّانْ زَّايْنغْ ؤُ سّحْقَارنْ أَنغْ. نِيثْنِي نَّانْ: ”مَانَاوْيَا مِينْ إِ ذَا ثتّڭّمْ؟ مَا ثخْسمْ أَذْ ثْغوّْغمْ خْ ؤُجدْجِيذْ؟“  
\v 20 نشّْ أَرِّيغْ-د خَاسنْ، نِّيغْ أَسنْ: ”أَربِّي ن إِجنْوَانْ أَذْ أَنغْ إِوْشْ أَفُوسْ، ؤُ نشِّينْ، إِمْسخَّارنْ نّسْ، أَذْ نكَّارْ أَذْ نبْنَا. كنِّيوْ \add مَاشَا\add* وَارْ غَارْومْ بُو ثسْغَارْثْ ؤُڒَا ذ ڒْحقّْ نِيغْ ڒِيذَارثْ ذِي ؤُرْشَالِيمْ.“   
\b  
\b  
\m  
\c 3
\s1 ڒبْنِي ن ڒحْيُوضْ ن ؤُرْشَالِيمْ  
\m
\v 1 أَرَّايْسْ ن إِكهَّاننْ، إِلْيَاشِيبْ، إِكَّارْ، ؤُڒَا ذ أَيْثْمَاسْ، إِكهَّاننْ، ؤُشَا نِيثْنِيعدّْڒنْ بْنَانْ ثَاوَّارْثْ ن وُودْجِي، قدّْسنْ ت ؤُشَا سّْبدّنْ ذَايسْ ثِيوُّورَا نّسْ. نِيثْنِي قدّْسنْ ؤُڒَا ثِيشْثِي أَڒْ لْبُورْجْ ن مْيَا ؤُ أَڒْ لْبُورْجْ ن حَانَانِييِيلْ.   
\m
\v 2 غَارْ ؤُغزْذِيسْ نّسْ بْنَانْ يرْيَازنْ ن أَرِيحَا ؤُشَا غَارْ ؤُغزْذِيسْ نّسْ إِبْنَا زَاكُّورْ، مِّيسْ ن إِمْرِي.   
\m
\v 3 ثَاوَّارْثْ ن وسْڒمْ بْنَانْ ت أَيْثْ ن سَانَائا. نِيثْنِي أَركّْبنْ ثِيحنْيَا ن ثْزقَّا ؤُ سّْبدّنْ ذَايسْ ثِيوُّورَا نّسْ أَكْ-ذ زّكْرُونَاثْ نّسْ ذ إِعُومَاذْ نّسْ إِ ؤُبلّعْ.   
\m
\v 4 خْ ؤُغزْذِيسْ نْسنْ إِبْنَا مَارِيمُوثْ، مِّيسْ ن ؤُرِي-يَاهْ، مِّيسْ ن هَاقُّوصْ، ؤُ غَارْ ؤُغزْذِيسْ نْسنْ ثُوغَا إِعدّڒْ مَاشُولَّامْ، مِّيسْ ن بَارَاخْيَا، مِّيسْ ن مَاشِيزَابْيِيلْ ؤُ غَارْ ؤُغزْذِيسْ نْسنْ إِعدّڒْ صَاذُوقْ، مِّيسْ ن بَاعْنَا.   
\m
\v 5 غَارْ ؤُغزْذِيسْ نْسنْ ثُوغَاعدّْڒنْ إِمزْذَاغْ ن ثَاقُّوعَا، مَاشَا إِنِّي غَارْ ثدْجَا صُّولْطَا جَارْ أَسنْ وَارْ سّقْوِيسنْ شَا إِرِي إِ ڒْخذْمثْ ن سِيذِي نْسنْ.   
\m
\v 6 إِعدّڒْ يُويَاذَاعْ، مِّيسْ ن فَاسِيحْ، أَكْ-ذ مَاشُولَّامْ، مِّيسْ ن بَاسُوذْيَا، ثَاوَّارْثْ ثَاقْذِيمْثْ. نِيثْنِي أَركّْبنْ ثِيحنْيَا ن ثْزقَّا ؤُ سّْبدّنْ ذَايسْ ثِيوُّورَا نّسْ أَكْ-ذ زّكْرُونَاثْ نّسْ ذ إِعُومَاذْ نّسْ إِ ؤُبلّعْ.   
\m
\v 7 غَارْ ؤُغزْذِيسْ نْسنْ ثُوغَا إِعدّڒْ مَالَاطْيَا زِي جِيبْعُونْ، ذ يَاذُونْ، أَمِييَارُونُوثِي، ذ يرْيَازنْ زِي جِيبْعُونْ ؤُ زِي مِيصْفَا أَڒْ مَانِي ثُوغَا ثَادَّارْثْ ن ڒْكُورْسِي ن لْوَالِي \add ن ثمُّورْثْ\add* أَغِيرِينْ إِ إِغْزَارْ \add ن لْفُورَاطْ\add*.   
\m
\v 8 غَارْ ؤُغزْذِيسْ نّسْ ثُوغَا إِعدّڒْ عُوزِّييِيلْ، مِّيسْ ن حَارْهَايَا، إِجّنْ زڭْ إِحدَّاذنْ ن وُورغْ، ؤُ غَارْ ؤُغزْذِيسْ نّسْ إِعدّڒْ حَانَانْيَا، مِّيسْ ن إِجّْ زڭْ إِنِّي إِسّْوجْذنْ ڒعْطُوڒْ. نِيثْنِي جِّينْ ؤُرْشَالِيمْ أَڒْ ڒْحِيضْ ذ مِيرِيوْ \add أَمْ ث ثُوغَا\add*.   
\m
\v 9 غَارْ ؤُغزْذِيسْ نْسنْ ثُوغَا إِعدّڒْ رَافَايَا، مِّيسْ ن حُورْ، أَمقّْرَانْ خْ وزْينْ ن ؤُذوَّارْ ن ؤُرْشَالِيمْ.  
\v 10 غَارْ ؤُغزْذِيسْ نْسنْ ثُوغَا إِعدّڒْ يَاذَاعَا، مِّيسْ ن حَارُومَافْ، أَجمَّاضْ ن ثَادَّارْثْ نّسْ. ؤُ غَارْ ؤُغزْذِيسْ نّسْ ثُوغَا إِعدّڒْ حَاتُّوشْ، مِّيسْ ن حَاشَابْنِييَا.   
\b  
\m
\v 11 مَالْكِييَا، مِّيسْ ن حَارِيمْ ذ حَاشُّوبْ، مِّيسْ ن فَاحَاثْ-مُوآبَعذْڒنْ ثَاسْغَارْثْ وِيسّْ ثْنَاينْ ؤُڒَا ذ لْبُورْجْ ن ثفْقُونْثْ.   
\m
\v 12 غَارْ ؤُغزْذِيسْ نّسْ ثُوغَا إِعدّڒْ شَالُّومْ، مِّيسْ ن لُوحِيشْ، أَمقّْرَانْ خْ وزْينْ نّغْنِي ن ؤُذوَّارْ ن ؤُرْشَالِيمْ، نتَّا ذ يسِّيسْ.   
\m
\v 13 حَانُونْ ذ إِمزْذَاغْ ن زَانُوحْعذْڒنْ ثَاوَّارْثْ ن ثغْزُورْثْ. نِيثْنِي أَركّْبنْ ثِيحنْيَا ؤُ سّْبدّنْ ذَايسْ ثِيوُّورَا نّسْ أَكْ-ذ زّكْرُونَاثْ نّسْ ذ إِعُومَاذْ نّسْ إِ ؤُبلّعْ ؤُشَا \add عذْڒنْ عَاوذْ\add* أَڒفْ ن إِغَادْجنْ ن ڒْحِيضْ أَڒْ ثوَّارْثْ ن ڒغْبَارْ.   
\m
\v 14 مَالْكِييَا، مِّيسْ ن رَاكَابْ، أَمقّْرَانْ ن ؤُذوَّارْ ن بَايْثْ-كَارِيمْ، ثُوغَا إِعدّڒْ ثَاوَّارْثْ ن ڒغْبَارْ. نتَّا يَاركّبْ ثِيحنْيَا ؤُ إِسّْبدّْ ذَايسْ ثِيوُّورَا نّسْ أَكْ-ذ زّكْرُونَاثْ نّسْ ذ إِعُومَاذْ نّسْ إِ ؤُبلّعْ.   
\b  
\m
\v 15 شَالُّومْ، مِّيسْ ن كُولْهُوزْ، أَمقّْرَانْ ن ؤُذوَّارْ مِيصْفَا، ثُوغَا إِعدّڒْ ثَاوَّارْثْ ن ثَاڒَا. إِبْنَا إِ-ت ؤُ نِيثْنِي أَركّْبنْ ثِيحنْيَا ن ثْزقَّا ؤُشَا سّْبدّنْ ذَايسْ ثِيوُّورَا نّسْ أَكْ-ذ زّكْرُونَاثْ نّسْ ذ إِعُومَاذْ نّسْ إِ ؤُبلّعْ. \add نتَّا إِعْذڒْ عَاوذْ\add* ڒْحِيضْ زڭْ ؤُيڒْمَامْ ن شِيلَاحْ غَارْ وحْوِيشْ ن ؤُجدْجِيذْ أَڒْ دّْرُوجْ نِّي إِهكّْوَانْ زِي ثنْذِينْثْ ن ذَاوُوذْ غَارْ سْوَادَّايْ. \f ◼ \fr 3:‏15 \ft \+bd ’أَيڒْمَامْ ن شِيلَاهْ‘\+bd* - أَيڒْمَامْ-أَ أَذْ ثَاغْ ذ سِيمَانْثْ ن ؤُيڒْمَامْ أَمْ ؤُيڒْمَامْ ن سِيلْوَامْ ونِّي أَمَانْ نّسْ فّْغنْ زڭْ ڒْعُونْصَارْ ن جِيهُونْ ؤُشَا إِوْضنْ غَارْ ؤُيڒْمَامْ ن سِيلْوَامْ س قَانَاثْ ن حِيزْقِييَا ثنِّي نقْشنْ سْوَادَّايْ إِ ثمُّورْثْ عْڒَاحَاڒْ ذڭْ ؤُسڭّْوَاسْ 701 قْبڒْ لْمَاسِيحْ (خْزَارْ عَاوذْ إِشا. 8‏:6).\f*   
\m
\v 16 أَوَارْنِي أَسْ ثُوغَا إِعدّڒْ نَاحَامْيَا، مِّيسْ ن عَازْبُوقْ، أَمقّْرَانْ ن وزْينْ ن ؤُذوَّارْ ن بَايْثْ-صُورْ، أَڒْ أَجمَّاضْ إِ إِمضْڒَانْ ن ذَاوُوذْ ؤُ أَڒْ جُّوبّْ إِتّْوَاڭّنْ ؤُ أَڒْ ثَادَّارْثْ ن أَيْثْ بُو-ثغْرُوضْثْ.   
\m
\v 17 أَوَارْنِي أَسْ ثُوغَاعدّْڒنْ إِلَاوِييّنْ. رَاحُومْ، مِّيسْ ن بَانِي، \add ؤُ\add* غَارْ ؤُغزْذِيسْ نّسْ حَاشَابْيَا، أَمقّْرَانْ ن وزْينْ ن ؤُذوَّارْ ن قَاعِيلَا، ذڭْ ؤُذوَّارْ نّسْ.   
\m
\v 18 أَوَارْنِي أَسْ ثُوغَاعدّْڒنْ أَيْثْمَاثْسنْ، بَاوَايْ، مِّيسْ ن حِينَاذَاذْ، أَمقّْرَانْ خْ وزْينْ نّغْنِي ن ؤُذوَّارْ ن قَاعِيلَا.   
\m
\v 19 غَارْ ؤُغزْذِيسْ نّسْ ثُوغَا عَازِيرْ، مِّيسْ ن يشُوعَا، أَمقّْرَانْ ن مِيصْفَا، إِعدّڒْ إِشْثْ ن طَّارْفْ نّغْنِي أَجمَّاضْ إِ ثْسَاونْثْ غَارْ \add ثَادَّارْثْ ن\add* ڒسْنَاحْ، غَارْ مَانِي إِذوَّارْ \add ڒْْحِيضْ\add*.   
\m
\v 20 أَوَارْنِي أَسْ ثُوغَا بَارُوخْ، مِّيسْ ن زَابَّايْ، إِعدّڒْ س شْضَارثْ إِجّْ ن طَّارْفْ نّغْنِي، زِي مَانِي غَا إِذوَّارْ \add ڒْْحِيضْ\add* أَڒْ ثوَّارْثْ ن ثَادَّارْثْ ن إِلْيَاشِيبْ، أَرَّايْسْ ن إِكهَّاننْ.   
\m
\v 21 أَوَارْنِي أَسْ ثُوغَا مَارِيمُوثْ، مِّيسْ ن ؤُرِييَا، مِّيسْ ن هَاقُّوصْ، إِعدّڒْ إِجّْ ن طَّارْفْ نّغْنِي، زِي ثوَّارْثْ ن ثَادَّارْثْ ن إِلْيَاشِيبْ أَڒْ أَنڭَّارُو ن ثَادَّارْثْ ن إِلْيَاشِيبْ.   
\m
\v 22 أَوَارْنِي أَسْ ثُوغَاعدّْڒنْ إِكهَّاننْ. نِيثْنِي ذ إِرْيَازنْ زڭْ ؤُذوَّارْ \add ن لْ-ؤُرْذُونْ\add*.   
\m
\v 23 أَوَارْنِي أَسنْ ثُوغَا إِعدّڒْ بِينْيَامِينْ ذ حَاشُّوبْ، أَجمَّاضْ إِ ثَادَّارْثْ نْسنْ. أَوَارْنِي أَسنْ ثُوغَا إِعدّڒْ عَازَارْيَا، مِّيسْ ن مَاعَاسِييَا، مِّيسْ ن عَانَانِييَا، زَّاثْ إِ ثَادَّارْثْ نّسْ.   
\m
\v 24 أَوَارْنِي أَسْ ثُوغَا بِينُّويْ، مِّيسْ ن حِينَاذَاذْ، إِعدّڒْ إِجّْ ن طَّارْفْ نّغْنِي، زِي ثَادَّارْثْ ن عَازَارْيَا أَڒْ مَانِي غَا إِذوَّارْ \add ڒْْحِيضْ\add* أَڒْ ثَاغْمَارْثْ.   
\m
\v 25 فَالَالْ، مِّيسْ ن ؤُزَايْ، \add ثُوغَا إِعدّڒْ\add* أَجمَّاضْ مَانِي غَا إِذوَّارْ \add ڒْْحِيضْ\add* ذ \add ؤُجمَّاضْ ن\add* لْبُورْجْ يُوعْڒَانْ ونِّي إِرفْعنْ خْ ثْزذِّيغْثْ ن سنّجْ ن ؤُجدْجِيذْ، ثنِّي غَارْ زَّاثْ ن ڒمْرَاحْ ن ڒحْبسْ. أَوَارْنِي أَسْ \add ثُوغَا إِعدّڒْ\add* فَاذَايَا، مِّيسْ ن فَارْعُوشْ.   
\m
\v 26 إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ، إِنِّي ثُوغَا زدّْغنْ ذِي عُوفِيلْ، \add ثُوغَاعدّْڒنْ\add* أَجمَّاضْ إِ ثوَّارْثْ ن وَامَانْ غَارْ شَّارْقْ ؤُ \add غَارْ\add* لْبُورْجْ إِسّوْشنْ غَارْ بَارَّا.   
\m
\v 27 أَوَارْنِي أَسْ ثُوغَا إِمزْذَاغْ ن ثَاقُّوعَاعدّْڒنْ إِجّْ ن طَّارْفْ نّغْنِي أَجمَّاضْ إِ لْبُورْجْ أَمقّْرَانْ إِسّوْشنْ غَارْ بَارَّا أَڒْ ڒْحِيضْ ن عُوفِيلْ.   
\m
\v 28 ثُوغَا إِكهَّاننْعدّْڒنْ ثَاوَّارْثْ ن إِيْسَانْ، كُوڒْ إِجّْ أَجمَّاضْ إِ ثَادَّارْثْ نّسْ.   
\m
\v 29 أَوَارْنِي أَسنْ ثُوغَا إِعدّڒْ صَاذُوقْ، مِّيسْ ن إِمِّيرْ، أَجمَّاضْ إِ ثَادَّارْثْ نّسْ. ؤُ أَوَارْنِي أَسْ ثُوغَا إِعدّڒْ شَامْعِييَا، مِّيسْ ن شَاكَانْيَا، أَعسَّاسْ ن ثوَّارْثْ ن شَّارْقْ.   
\m
\v 30 أَوَارْنِي أَسْ ثُوغَا حَانَانْيَا، مِّيسْ ن شَالَامْيَا، ذ حَانُونْ، مِّيسْ ن صَالَافْ وِيسّْ ستَّا،عدّْڒنْ إِجّْ ن طَّارْفْ نّغْنِي. أَوَارْنِي أَسْ ثُوغَا إِعدّڒْ مَاشُولَّامْ، مِّيسْ ن بَارَاخْيَا، أَجمَّاضْ إِ ثخَّامْثْ نّسْ.   
\m
\v 31 أَوَارْنِي أَسْ ثُوغَا إِعدّڒْ مَالْكِييَا، مِّيسْ ن إِجّْ ن ومْزِيڒْ ن وُورغْ، أَڒْ ثَادَّارْثْ ن إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ ذ إِسبَّابنْ، أَجمَّاضْ إِ ثوَّارْثْ ن ڒحْسَابْ ؤُ أَڒْ أَخَّامْ ن سنّجْ غَارْ ثغْمَارْثْ.   
\m
\v 32 جَارْ وخَّامْ ن سنّجْ غَارْ ثغْمَارْثْ ذ ثوَّارْثْ ن وُودْجِي، ثُوغَاعدّْڒنْ إِمْزِيڒنْ ن وُورغْ ذ إِسبَّابنْ.   
\b  
\m  
\s1 ڒْعذْيَانْ وَارْ زمَّارنْ أَذْ سّْبدّنْ ڒْخذْمثْ  
\m
\v 33 ؤُمِي سَانْبَالَّاطْ إِسْڒَا، أَقَا نْبنَّا ڒْحِيضْ، إِمْسَارْ أَقَا إِهَاجْ، إِسْعَارْ أَطَّاسْ ؤُشَا إِسّْبهْذڒْ ؤُذَاينْ.   
\m
\v 34 ثُوغَا إِسَّاوَاڒْ جَارْ أَيْثْمَاسْ ذ ڒْعسْكَارْ ن سَامَارْيَا، إِنَّا: ”مِينْ تّڭّنْ وُوذَاينْ-أَ إِضعْفنْ؟ مَا أَذْ ثنْ نجّْ؟ مَا أَذْ قذْمّنْ ثِيغَارْصَا؟ مَا أَذْ \add ث\add* كمّْڒنْ ذڭْ إِجّْ ن وَاسّْ؟ مَا أَذْ سّكَّارنْ \add عَاوذْ\add* إِژْرَا زِي أَرْوِينَاثْ إِنِّي إِتّْوَاشمْضنْ؟“  
\v 35 \add ثُوغَا\add* طُوبِييَا، زڭْ أَيْثْ ن عَامُّونْ، أَكِيذسْ، إِنَّا: ”عَاذْ مَاڒَا بْنَانْ ث عَاوذْ، خْمِي غَا إِفّغْ إِجّْ ن وشْعبْ \add وَاهَا\add*، خنِّي أَذْ إِهْذمْ ڒْحِيضْ نْسنْ ن وژْرُو.“   
\b  
\m
\v 36 ”سڒْ، أَ أَربِّي نّغْ، مَامّشْ إِ نذْوڒْ نتّْوَاسّحْقَارْ ؤُشَا أَرّْ أَسحْقَارْ نْسنْ خْ ؤُزدْجِيفْ نْسنْ ؤُشَا سلّمْ إِ-ثنْ ذ ثَاكشَّاضْثْ غَارْ إِشْثْ ن ثمُّورْثْ ن ؤُحبّسْ.  
\v 37 وَارْ سْذُورِييْ ڒْمُوعْصِييّثْ نْسنْ ؤُ وَارْ تّجِّي أَذْ إِتّْوَامْحَا دّْنُوبْ نْسنْ زَّاثْ إِ وُوذمْ نّشْ، مِينْزِي نِيثْنِي سْعَارنْ شكْ قِيبَاتْشْ إِ إِبنَّاينْ.“   
\m
\v 38 نبْنَا ڒْحِيضْ، أَڒَامِي إِذْوڒْ ڒْحِيضْ إِقّنْ أَڒْ أَزْينْ، مِينْزِي ڒْڭنْسْ إِڭَّا ؤُڒْ نْسنْ أَذْ ث ڭّنْ. *   
\b  
\b  
\m  
\c 4
\m
\v 1 ؤُمِي \add مَاشَا\add* سَانْبَالَّاطْ ذ طُوبِييَا ذ وعْرَابنْ ذ أَيْثْ ن عَامُّونْ ذ إِشْذُوذِييّنْ سْڒَانْ، أَقَا أَعْذَاڒْ ن ڒحْيُوضْ ن ؤُرْشَالِيمْ إِتّْرَاحْ غَارْ زَّاثْ، ثِيزّيِّينْ بْذَانْثْ أَذْ قّْننْثْ، إِمْسَارْ، أَقَا خيّْقنْ أَطَّاسْ.  
\v 2 نِيثْنِي مَارَّا ڭِّينْ ثَامعْمُوتْشْ مَاحنْذْ أَذْ د-أَسنْ أَذْ مّنْغنْ أَكْ-ذ ؤُرْشَالِيمْ، أَذْ ذِينِّي سّكَّارنْ ڒحْوڒْ. \x ◘ \xo 4:‏2 \xt إِزهد. 2\x*  
\v 3 نشِّينْ \add مَاشَا\add* نْژُودْجْ غَارْ أَربِّي نّغْ ؤُ ذِي سِّيبّثْ نْسنْ نسّْبدّْ إِشْثْ ن ثْعسَّاسْثْ خَاسنْ أَسّْ ذ دْجِيڒثْ.   
\m
\v 4 \add خنِّي\add* إِنَّا يَاهُوذَا: ”جّْهذْ ن يِينِّي يَاربُّونْ يُوحڒْ، مَاغَارْ ذِينْ أَطَّاسْ ن ڒْخَارْبثْ. وَارْ نْزمَّارْ خْ ڒبْنِي ن ڒْحِيضْ.“  
\v 5 إِغْرِيمنْ نّغْ أَقَا نَّانْ: ”نِيثْنِي وَارْ تِّيشِينْ ؤُ وَارْ تّْوِيڒِينْ وَالُو أَڒْ د غَا نَاسْ ذِي ڒْوسْطْ نْسنْ ؤُ أَذْ ثنْ ننغْ. \add أَمُّو\add* إِ غَا نسّْبدّْ ڒْخذْمثْ.   
\m
\v 6 ڒَامِي د-ؤُسِينْ وُوذَاينْ، إِنِّي غَارْسنْ إِزدّْغنْ، نَّانْ أَنغْعشْرَا ن ثْوَاڒَاوِينْ: ”إِتّْخصَّا كنِّيوْ أَذْ غَارْنغْ د-ثْعقْبمْ!“،   
\m
\v 7 سّْبدّغْ نشّْ ڒْڭنْسْ أَوَارْنِي إِ ڒْحِيضْ غَارْ إِمُوشَانْ إِوَاطَانْ ؤُ غَارْ ثْسقَّارْ إِفْرُورنْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، أَكْ-ذ ڒسْيُوفْ نْسنْ ذ إِحْرِيشنْ نْسنْ ذ ڒقْوَاسْ نْسنْ. \f ◼ \fr 4:‏7 \ft \+bd ’ڒسْيُوفْ‘\+bd* - نِيغْ ’إِجنْيَانْ‘.\f*  
\v 8 خْزَارغْ، \add خنِّي\add* كَّارغْ، نِّيغْ إِ ثَارْوَا ن ثَاصِيڒثْ ؤُ إِ إِمْضبَّارنْ ؤُ إِ مِينْ إِقِّيمنْ ن ڒْڭنْسْ: ”وَارْ زَّايْسنْ تّڭّْوذمْ شَا! سِيذِي إِنُو ذ أَمقّْرَانْ ؤُ إِسَّاڭّْوَاذْ. فكَّارمْ ذَايسْ، مّنْغمْ إِ أَيْثْمَاثْومْ، إِحنْجِيرنْ نْومْ ذ ثْحنْجِيرِينْ نْومْ ذ ثمْغَارِينْ نْومْ ذ ثُوذْرِينْ نْومْ.“   
\m
\v 9 ؤُمِي سْڒَانْ ڒْعذْيَانْ نّغْ، أَقَا \add نشِّينْ\add* نَارْڭبْ خَاسْ ؤُ أَقَا أَربِّي إِبْضڒْ أَنْوَايْ نْسنْ، إِمْسَارْ خنِّي نشِّينْ مَارَّا إِذْنغْ نعْقبْ غَارْ ڒْحِيضْ، كُوڒْ إِجّْ غَارْ ومْشَانْ \add نّسْ\add*.  
\v 10 زڭْ وَاسّْ نِّي إِمْسَارْ، أَقَا أَزْينْ ن إِمْسخَّارنْ إِنُو ثُوغَا خدّْمنْ ؤُ أَزْينْ نّغْنِي زَّايْسنْ طّْفنْ إِحْرِيشنْ ذ ثْسدَّارِييِينْ \add ن ؤُعسْكَارِي\add* ذ ڒقْوَاسْ ذ وَارُّوضْ ن وُوزَّاڒْ، ؤُشَا ڒْحُوكَّامْ \add بدّنْ\add* أَوَارْنِي إِ كُوڒْ ثَادَّارْثْ ن يَاهُوذَا.  
\v 11 إِنِّي ثُوغَا إِتّْبنَّانْ ڒْحِيضْ ؤُشَا يَاربُّونْ دّْقُوڒَاثْ ؤُشَا سَّاربُّونْ ثنْثْ، خدّْمنْ س يِيجّْ ن ؤُفُوسْ ؤُ س \add ؤُفُوسْ\add* نّغْنِي طّْفنْ لَانْسَا.  
\v 12 \add مَارَّا\add* إِنِّي ثُوغَا إِبنَّانْ أَقَا غَارْسنْ سِّيفْ إِقّنْ خْ ثجْعِينَّا نّسْ أَمْ ثُوغَا إِبنَّا. ونِّي إِتّْسُوضنْ ذڭْ ؤُيِيشّْ ن إِشَارِّي، ثُوغَا-ث أَكِيذِي.   
\m
\v 13 نِّيغْ إِ ثَارْوَا ن ثَاصِيڒثْ ؤُ إِ إِمْضبَّارنْ ؤُ إِ مِينْ إِقِّيمنْ ن ڒْڭنْسْ: ”ڒْخذْمثْ ثمْغَارْ ؤُ ثيْرُو. نشِّينْ نتّْوَابزّعْ خْ ڒْحِيضْ، إِجّنْ إِڭّْوجْ خْ ونّغْنِي.  
\v 14 ذڭْ ومْشَانْ مَانِي غَا ثسْڒمْ أَسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي، مُونمْ-د ذِينِّي خَانغْ. أَربِّي نّغْ أَذْ إِمّْنغْ ذِي طّْوعْ نّغْ. \x ◘ \xo 4:‏14 \xt ؤُف. 14‏:‏25؛ أَعَوذ. 1‏:‏30؛ 28‏:‏7\x*   
\m
\v 15 أَمُّو إِ نخْذمْ ؤُشَا أَزْينْ زَّايْسنْ طّْفنْ إِحْرِيشنْ زِي ثُوفُّوثْ أَڒْ د غَا فّْغنْ إِثْرَانْ.  
\v 16 ذِي ڒْوقْثْ نِّي نِّيغْ إِ ڒْڭنْسْ: ”كُوڒْ إِجّْ أَذْ إِسّنْسْ ذَاخڒْ ذِي ؤُرْشَالِيمْ أَكْ-ذ ؤُمْسخَّارْ نّسْ ؤُشَا أَمُّو إِ غَارْنغْ إِ غَا يِيڒِينْ ذ إِعسَّاسنْ ذِي دْجِيڒثْ ؤُ ذڭْ وَاسّْ \add أَذْ إِڒِينْ إِ\add* ڒْخذْمثْ.“  
\v 17 ؤُڒَا ذ إِجّْ زَّايْنغْ وَارْ إِكِّيسْ أَرُّوضْ، وَارْ إِدْجِي نشّْ ڒَا ذ أَيْثْمَا ڒَا ذ إِمْسخَّارنْ إِنُو ؤُڒَا ذ يرْيَازنْ ن ثْعسَّاسْثْ. كُوڒْ إِجّْ \add إِرُوحْ غَارْ\add* وَامَانْ أَكْ-ذ لَانْسَا نّسْ.   
\b  
\b  
\m  
\c 5
\s1 نَاحَامْيَا إِوْشَا أَفُوسْ إِ إِمژْڒَاضْ  
\m
\v 1 إِكَّارْ إِجّْ ن ؤُغُويِّي إِمْغَارْ ن ڒْڭنْسْ ؤُ ن ثمْغَارِينْ نْسنْ، \add شثْشَانْ نِيثْنِي\add* خْ أَيْثْمَاثْسنْثْ، ؤُذَاينْ.  
\v 2 أَقَا ذِينْ إِنِّي إِنَّانْ: ”إِحنْجِيرنْ نّغْ ذ ثْحنْجِيرِينْ نّغْ ذ نشِّينْ ذ أَطَّاسْ. إِتّْخصَّا أَذْ نْسغْ إِمنْذِي حِيمَا أَذْ نشّْ أَذْ ندَّارْ.“  
\v 3 إِنّغْنِي نَّانْ: ”نشِّينْ نَارْهنْ إِيَّارنْ نّغْ ذ إِمَارْجَاعنْ نّغْ ن ؤُضِيڒْ ذ ثُوذْرِينْ نّغْ ذ أَضْمَانْ، حِيمَا أَذْ نَاوِي ڒْحبّْ \add ن يِيرْذنْ\add* ذڭْ \add وُوسَّانْ ن\add* ڒَاژْ.“  
\v 4 \add إِنّغْنِي\add* نَّانْ: ”نشِّينْ نَارْضڒْ نُّوقَارْثْ إِ لْجِيزْيَا إِ ؤُجدْجِيذْ خْ إِيَّارنْ نّغْ ؤُ خْ إِمَارْجَاعنْ نّغْ ن ؤُضِيڒْ.“  
\v 5 ”خنِّي ڒخُّو، أَيْسُومْ نّغْ ذ أَيْسُومْ ن أَيْثْمَاثْنغْ، إِحنْجِيرنْ نّغْ أَمْ إِحنْجِيرنْ نْسنْ، ؤُ خْزَارْ، إِحنْجِيرنْ نّغْ ذ ثْحنْجِيرِينْ نّغْ إِتّْخصَّا أَنغْ أَذْ ثنْ نَارّْ ذ إِسمْغَانْ. أَقَا ذِينْ زِي يسِّيثْنغْ ثِينِّي إِذوْڒنْ أَمْ ثْسغْمِينْ، ؤُشَا أَفُوسْ نّغْ وَارْ إِزمَّارْ \add أَذْ إِڭّْ شَا\add* ؤُ إِيَّارنْ نّغْ ذ إِمَارْجَاعنْ نّغْ ن ؤُضِيڒْ أَقَا ذڭْ ؤُفُوسْ ن إِنّغْنِي.“   
\m
\v 6 ؤُمِي سْڒِيغْ إِغُويَّانْ نْسنْ ذ وَاوَاڒنْ-أَ، ذوْڒغْ خيّْقغْ أَطَّاسْ.  
\v 7 نشّْ خَارّْصغْ ذڭْ وُوڒْ إِنُو ؤُ \add خنِّي\add* شثْشِيغْ خْ ثَارْوَا ن ثَاصِيڒثْ ؤُ خْ إِمْضبَّارنْ، نِّيغْ أَسنْ: ”كُوڒْ إِجّْ زَّايْومْ ذَايسْ ڒْعِيبْ ؤُمِي إِڭَّا أَمَارْوَاسْ ذڭْ ؤُمَاسْ.“ نشّْ ڭِّيغْ إِجّْ ن وڭْرَاوْ ذ أَمقّْرَانْ ضِيدّْ نْسنْ. \x ◘ \xo 5:‏7 \xt ؤُف. 22‏:‏24\x*  
\v 8 نشّْ نِّيغْ أَسنْ: ”نشِّينْ نسْغَا أَيْثْمَاثْنغْ، ؤُذَاينْ، إِنِّي ثُوغَا إِتّْوَازّنْزنْ إِ ڒڭْنُوسْ، عْلَاحْسَابْ ثِيزمَّارْ نّغْ. مَا ثخْسمْ أَذْ ثزّنْزمْ \add عَاوذْ\add* ثَاوْمَاثْومْ ؤُ تّْوَامّسْغنْ نِيثْنِي زَّايْنغْ \add عَاوذْ\add*؟“ ؤُشَا سّغْذنْ وَارْ ؤُفِينْ مِينْ غَا إِنِينْ.  
\v 9 \add خَاسْ ؤُشَا\add* نِّيغْ: ”مِينْ ثتّڭّمْ كنِّيوْ، وَارْ إِدْجِي نِيشَانْ. مَا وَارْ إِتّْخصِّي أَذْ ثُويُورمْ زَّاثْ إِ أَربِّي نّغْ س ؤُوقَّارْ زِي سِّيبّثْ ن ؤُسحْقَارْ ن ڒڭْنُوسْ، ڒْعذْيَانْ نّغْ؟  
\v 10 ؤُڒَا ذ نشّْ، أَيْثْمَا ذ إِمْسخَّارنْ إِنُو، أَقَا نَارْضرْ أَسنْ نُّوقَارْثْ ذ إِمنْذِي. جّمْ أَنغْ أَذْ نسْمحْ مَاشَا ذڭْ ؤُمَارْوَاسْ-أَ.  
\v 11 أَرّمْ أَسنْ أَسّْ-أَ إِيَّارنْ نْسنْ، إِمَارْجَاعنْ نْسنْ ن ؤُضِيڒْ، ڒعْرَاصِيثْ نْسنْ ن زِّيثُونْ ذ ثُوذْرِينْ نْسنْ ؤُشَا سمْحنْ أَسنْ ذِي ثَاسْغَارْثْ وِيسّْ مْيَا ن نُّوقَارْثْ ذ إِمنْذِي ذ بِينُو ن جْذِيذْ ذ زّشْثْ نِّي إِ زَّايْسنْ ثتّتَّارمْ \add عَاذْ\add*.“  
\v 12 \add خَاسْ ؤُشَا\add* نَّانْ: ”أَذْ أَسنْ ث نَارّْ مَارَّا ؤُ وَارْ زَّايْسنْ ث نتّتَّارْ \add عَاذْ\add*. نشِّينْ أَذْ نڭّْ، أَمْ مَامّشْ ثنِّيذْ شكْ.“ ؤُشَا ڒَاغِيغْ إِ إِكهَّاننْ ؤُ جِّيغْ ثنْ أَذْ جَّادْجنْ، أَقَا نِيثْنِي أَذْ ڭّنْ عْلَاحْسَابْ أَوَاڒْ-أَ.  
\v 13 خنِّي زّرْزغْ وحْسِينْ ن وَارُّوضْ إِنُو، نِّيغْ: ”أَمُّو إِ غَا إِزّرْزْ أَربِّي كُوڒْ أَرْيَازْ نِّي وَارْ إِطِّيفنْ ذڭْ وَاوَاڒْ-أَ، زِي ثَادَّارْثْ نّسْ ؤُ زڭْ وَاڭْڒَا نّسْ، \add وَاهْ،\add* إِڒِي أَذْ ث زّرْزنْ أَڒَامِي إِ غَا إِخْوَا.“ أَڭْرَاوْ \add ن ڒْڭنْسْ\add* مَارَّا إِنَّا: ”أَمِينْ!“ نِيثْنِي سّمْغَارنْ سِيذِي ذ ڒْڭنْسْ إِ إِڭِّينْ عْلَاحْسَابْ أَوَاڒْ-أَ. \f ◼ \fr 5:‏13 \ft \+bd ’أَحْسِينْ‘\+bd* - نِيغْ ’أَبحْرُورْ‘.\f*   
\b  
\m  
\s1 أَمذْيَا ن نَاحَامْيَا  
\m
\v 14 ؤُڒَا ذ نشّْ ذ يَايْثْمَا وَارْ نشِّي شَا مَاشَّا ن إِجّْ ن لْوَالِي زڭْ وَاسّْ نِّي ذِي إِ ذ أَيِي إِڭَّا ذ لْوَالِي نْسنْ ذِي ثمُّورْثْ ن يَاهُوذَا، زڭْ ؤُسڭّْوَاسْ وِيسّْ عِيشْرِينْ أَڒْ أَسڭّْوَاسْ وِيسّْ ثْنَاينْ ؤُ-ثْڒَاثِينْ ن ؤُجدْجِيذْ أَرْثَاحْشَاسْثَا، \add ثقَّارْ\add* ثنْعَاشْ ن إِسڭّْوُوسَا.  
\v 15 لْوُولَاثْ نِّي ذِينْ إِدْجَانْ قْبڒْ إِ نشّْ، ثُوغَا ڭِّينْ دّْقڒْ خْ ڒْڭنْسْ ؤُ ثُوغَا كْسِينْ زَّايسْ أَغْرُومْ ذ بِينُو ؤُ عَاوذْ أَربْعِينْ شِيقْلُو ن نُّوقَارْثْ. ؤُڒَا ذ إِمْسخَّارنْ نْسنْ سدْجْضنْ خْ ڒْڭنْسْ. نشّْ مَاشَا وَارْ ڭِّيغْ أَيَا زِي ثِيڭّْوُوذِي ن أَربِّي.  
\v 16 أَقَا وْشِيغْ جّهْذْ إِنُو إِ ڒْخذْمثْ غَارْ ڒْحِيضْ ؤُ نشِّينْ وَارْ نسْغِي شَا أَحْوِيشْ ؤُ مَارَّا إِمْسخَّارنْ مُوننْ ذِينْ خْ ڒْخذْمثْ.  
\v 17 غَارْ طَّابْڒَا إِنُو \add قِّيمنْ\add* مْيَا ؤُ-خمْسِينْ ن يرْيَازنْ زڭْ وُوذَاينْ ؤُ زڭْ إِمْضبَّارنْ ؤُڒَا ذ إِنِّي إِ غَارْنغْ د-يُوسِينْ زِي ڒڭْنُوسْ إِ ذ أَنغْ د-إِنّْضنْ.  
\v 18 مِينْ إِتّْوَاسّْوجْذنْ أَيِي إِ يِيجّْ ن وَاسّْ، أَقَا ذ إِجّْ ن ؤُفُونَاسْ، ستَّا ن ثخْسِيوِينْ إِتّْوَافَارْزنْ زڭْ وُودْجِي ؤُڒَا ذ إِجْضَاضْ، ؤُ ذِي كُوڒْعشْرَا ن وُوسَّانْ عْڒَامْ كُوڒْ بِينُو س ؤُفيّضْ. س مَارَّا أَيَا وَارْ تَّارغْ مَاشَّا ن لْوَالِي، مَاغَارْ ثَاسخَّارْثْ ثسّذْقڒْ أَطَّاسْ خْ ڒْڭنْسْ-أَ.  
\v 19 إِذَارْ أَيِي س ڒْخَارْ، \add أَ\add* أَربِّي إِنُو، س مَارَّا مِينْ ڭِّيغْ إِ ڒْڭنْسْ-أَ. \x ◘ \xo 5:‏19 \xt نَاح. 13‏:‏22\x*   
\b  
\b  
\m  
\c 6
\s1 أَكمّڒْ ن ڒْحِيضْ  
\m
\v 1 ؤُمِي خبَّارنْ إِ سَانْبَالَّاطْ ذ طُوبِييَا ذ وعْرَابْ جَاشَامْ ذ ڒْعذْيَانْ نّغْنِي، أَقَا نشّْ بْنِيغْ ڒْحِيضْ عَاوذْ ؤُ وَارْ ثُوغِي ذَايسْ ثقِّيمْ ثَازِّيثْ \add عَاذْ\add*، أَقَا زعْمَا نشّْ ثُوغَا أَيِي عَاذْ وَارْ أَركّْبغْ ثِيوُّورَا، \add خنِّي\add* إِمْسَارْ،  
\v 2 أَقَا سَانْبَالَّاطْ ذ جَاشَامْ سّكّنْ-د غَارِي \add ڒخْبَارْ\add*، نَّانْ: ”أَسْ-د، أَذْ نمّْژَارْ ذِي ذْشُورَاثْ ذِي ڒوْضَا ن ؤُنُو.“ نِيثْنِي مَاشَا ثُوغَا نْوَانْ أَذْ ڭّنْ ثَاعفَّانْثْ أَكِيذِي.  
\v 3 نشّْ سّكّغْ غَارْسنْ إِرقَّاسنْ أَذْ إِنِينْ: ”نشّْ خدّْمغْ ڒخُّو ذِي ڒْخذْمثْ ذ ثَامقّْرَانْثْ، خْ ؤُيَا وَارْ زمَّارغْ أَذْ د-أَسغْ. مَايمِّي غَا ثْبدّْ ڒْخذْمثْ-أَ مَاڒَا جِّيغْ ت، هْوِيغْ-د غَارْومْ؟“  
\v 4 نِيثْنِي سّكّنْ أَيِي-د ثَابْرَاثْ-أَ أَربْعَا ن ثْوَاڒَاوِينْ ؤُ نشّْ أَرِّيغْ-د خَاسنْ \add ڒبْذَا\add* س وبْرِيذْ ذ إِجّنْ.  
\v 5 \add خنِّي\add* إِسّكّْ-د غَارِي سَانْبَالَّاطْ ڒخْبَارْ-أَ إِ ثْوَاڒَا وِيسّْ خمْسَا. أَمْسخَّارْ نّسْ \add ثُوغَا غَارسْ\add* إِشْثْ ن ثبْرَاثْ ثَارْزْمنْ س ؤُفُوسْ نّسْ،  
\v 6 يُورَا ذَايسْ: ”أَقَا إِذْوڒْ إِتّْوَاسّنْ جَارْ ڒڭْنُوسْ ؤُ جَاشْمُو إِقَّارْ: ’شكْ ذ وُوذَاينْ ثخْسمْ أَذْ ثْغوّْغمْ. خْ ؤُيَا ثسّْبدّمْ ڒْحِيضْ!‘، ؤُ شكْ ثخْسذْ أَذْ ثْذوْڒذْ ذ أَجدْجِيذْ نْسنْ خْ ڒحْسَابْ أَوَاڒنْ-أَ.“ \f ◼ \fr 6:‏6 \ft \+bd ’جَاشْمُو‘\+bd* - نِيغْ جَاشَامْ (خْزَارْ نُّومْرَا 2).\f*  
\v 7 شكْ عَاوذْ ثَاڒقْمذْ إِنَابِييّنْ، مَاحنْذْ أَذْ خَاكْ د-بَارّْحنْ ذِي ؤُرْشَالِيمْ، أَذْ إِنِينْ: ’نتَّا ذ أَجدْجِيذْ ذِي يَاهُوذَا!‘ أَوَاڒنْ-أَ أَذْ أَوْضنْ مَاشَا إِ ؤُجدْجِيذْ. س ؤُيَا أَسْ-د ڒخُّو، أَذْ نمْشَاوَارْ.“  
\v 8 نشّْ \add مَاشَا\add* سّكّغْ أَسْ \add ثَابْرَاثْ\add* مَاحنْذْ أَذْ أَسْ إِنِيغْ: ”ثِيمسْڒَايِينْ-أَ إِ ثنِّيذْ، وَارْ دْجِينْثْ شَا ذ ثِيذتّْ، مَاشَا شكْ ثڭِّيذْ ثنْثْ ذڭْ وُوڒْ نّشْ.“  
\v 9 مِينْزِي نِيثْنِي مَارَّا خْسنْ أَذْ أَنغْ سِّيڭّْوْذنْ، نَّانْ: ”نِيثْنِي أَذْ كّْسنْ إِفَاسّنْ نْسنْ زِي ڒْخذْمثْ، مَاحنْذْ وَارْ ت تّڭّنْ.“ خنِّي ڒخُّو، سجْهذْ إِفَاسّنْ إِنُو!   
\m
\v 10 نشّْ ؤُذْفغْ غَارْ ثَادَّارْثْ ن شَامْعِييَا، مِّيسْ ن ذَالَايَا، مِّيسْ ن مَاهِيطَابْ‘إِلْ. نتَّا ثُوغَا إِبلّعْ خْ إِخفْ نّسْ ذِينِّي، إِنَّا: ”أجّْ أَنغْ أَذْ نْمُونْ ذِي ثَادَّارْثْ ن أَربِّي، ذِي ڒْوسْطْ ن زَّاوشْثْ، أَذْ نْبلّعْ ثِيوُّورَا ن زَّاوشْثْ ثَامقّْرَانْثْ، مَاغَارْ أَذْ د-أَسنْ نِيثْنِي، حِيمَا أَذْ شكْ نْغنْ، \add وَاهْ،\add* أَذْ د-أَسنْ ذِي دْجِيڒثْ حِيمَا أَذْ شكْ نْغنْ.“  
\v 11 \add مَاشَا\add* نشّْ نِّيغْ: ”مَا نشّْ ذ إِجّْ ن ورْيَازْ إِ ثَاروْڒَا؟ مَا إِجّنْ أَمْ نشّْ أَذْ يَاذفْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ ؤُشَا أَذْ إِقِّيمْ إِدَّارْ؟ وَارْ ت تَّاذْفغْ.“  
\v 12 \add مِينْزِي\add* أَرْڭْبغْ ؤُ ژْرِيغْ، أَقَا وَارْ إِدْجِي ذ أَربِّي إِ ثُوغَا ث-إِ-د-إِسّكّنْ، مَاشَا نتَّا إِسِّيوڒْ أَكْ-ذ نُّوبُووَا-يَا خَافِي، مِينْزِي طُوبِييَا ذ سَانْبَالَّاطْ ثُوغَا شْرَانْ ث.  
\v 13 ثُوغَا شْرَانْ ث، مَاحنْذْ أَذْ ڭّْوذغْ أَذْ ڭّغْ أَمنِّي ؤُشَا أَذْ خْضِيغْ، مَاحنْذْ أَذْ غَارْسنْ يِيڒِي شَا إِ زِي ذَايِي إِ غَا ڭّنْ إِسمْ ذ أَعفَّانْ، حِيمَا أَذْ أَيِيعيَّارنْ.  
\v 14 \add أَ\add* سِيذِي إِنُو، إِذَارْ إِ طُوبِييَا ذ سَانْبَالَّاطْ، مِينْ ڭِّينْ، ؤُڒَا ذ ثَانَابِيثْ نُوعَاذْيَا ذ إِنَابِييّنْ نّغْنِي إِنِّي ثُوغَا يَارزُّونْ أَذْ أَيِي سِّيڭّْوْذنْ.  
\v 15 إِتّْوَاكمّڒْ ڒْحِيضْ أَوَارْنِي إِ ثْنَاينْ ؤُ-خمْسِينْ ن وُوسَّانْ، ذڭْ \add وَاسّْ\add* وِيسّْ خمْسَا ؤُ-عِيشْرِينْ ن \add ؤُيُورْ ن\add* إِلُولْ.  
\v 16 ؤُمِي سْڒِينْ مَارَّا ڒْعذْيَانْ نّغْ مَانْ أَيَا، ؤُشَا ؤُڒَا ذ مَارَّا ڒڭْنُوسْ إِ ذ أَنغْ د-إِنّْضنْ ژْرِينْ ث، ذوْڒنْ نِيثْنِي ذ إِمُوقْڒِيڒنْ ذِي ثِيطَّاوِينْ ن يِيخفْ نْسنْ، ؤُشِينْ أَقَا ذ أَربِّي إِ ثُوغَا إِڭِّينْ ڒْخذْمثْ-أَ.   
\m
\v 17 ذڭْ وُوسَّانْ نِّي ؤُرِينْ ثَارْوَا ن ثَاصِيڒثْ ن يَاهُوذَا أَطَّاسْ ن ثبْرَاثِينْ، سكّنْ ثنْثْ إِ طُوبِييَا ؤُشَا أَقَا ذِينْ ؤُڒَا ذ ثِينِّي إِفّْغنْ زِي طُوبِييَا غَارْسنْ.  
\v 18 مَاغَارْ أَطَّاسْ ذِي يَاهُوذَا ثُوغَا جُّودْجنْ أَسْ، مَاغَارْ نتَّا ثُوغَا ذ أَضڭّْوَاڒْ ن شَاخَانْيَا، مِّيسْ ن أَرَاحْ، ؤُ مِّيسْ \add نّسْ\add* يُوحَانَانْ ثُوغَا يِيوِي يدْجِيسْ ن مَاشُولَّامْ، مِّيسْ ن بَارَاخْيَا، ذ ثَامْغَارْثْ.  
\v 19 عَاوذْ سِّيوْڒنْ زَّاثْ إِ وُوذمْ إِنُو خْ ثْمڭَّا نّسْ ثِيصبْحَانِينْ ؤُ سِّيوْضنْ أَوَاڒنْ إِنُو غَارسْ. ؤُ طُوبِييَا ثُوغَا إِ ذ أَيِي د-إِسّكَّانْ ثِيبْرَاثِينْ حِيمَا أَذْ أَيِي إِسِّيڭّْوذْ.   
\b  
\b  
\m  
\c 7
\s1 ثَاعسَّاسْثْ ن ثنْذِينْثْ  
\m
\v 1 ؤُمِي إِتّْوَاسّْبدّْ ڒْحِيضْ عَاوذْ ؤُ ڭِّيغْ ثِيوُّورَا أَذْ تّْوَاركّْبنْثْ، أَقَا ڒقّْمغْ إِعسَّاسنْ ن ثوُّورَا ذ إِمذْيَازنْ ذ إِلَاوِييّنْ. \f ◼ \fr 7:‏1 \ft \+bd ’إِمذْيَازنْ‘\+bd* - نِيغْ ’إِمغْنُوجنْ‘.\f*  
\v 2 نشّْ ؤُمُورغْ إِ ؤُمَا حَانَانِي ؤُ إِ حَانَانْيَا، أَمقّْرَانْ ن لْقلْعَا ذِي ؤُرْشَالِيمْ، مِينْزِي نتَّا ذ إِجّْ ن ورْيَازْ ذ أَمْثِيقِّي، إِتّڭّْوذْ أَربِّي كْثَارْ خْ وَاطَّاسْ \add إِنّغْنِي\add*.  
\v 3 نشّْ نِّيغْ أَسنْ: ”وَارْ تّْنُورْزِيمنْثْ ثوُّورَا ن ؤُرْشَالِيمْ أَڒْ غَا ثزْوغْ ثْفُوشْثْ ؤُشَا جّمْ أَذْ بلّْعنْ ثِيوُّورَا ؤُ أَذْ أَرّنْ إِزكْرُوننْ ؤُمِي نِيثْنِي بدّنْ عَاذْ \add إِ ثْعسَّاسْثْ\add*. إِتّْخصَّا أَذْ ڭّنْ إِعسَّاسنْ زڭْ إِمزْذَاغْ ن ؤُرْشَالِيمْ، كُوڒْ إِجّْ ذڭْ ومْشَانْ ن ثْعسَّاسْثْ نّسْ ؤُ كُوڒْ إِجّْ قِيبَاتْشْ إِ ثَادَّارْثْ نّسْ.  
\v 4 ثُوغَا ثَانْذِينْثْ ثنّجْبذْ ؤُ ثمْغَارْ، \add مَاشَا\add* ثُوغَا ذَايسْ ڒْڭنْسْ ذْرُوسْ ؤُ ثُوذْرِينْ ثُوغَا وَارْ بْنِينْثْ \add عَاذْ\add*.   
\b  
\m  
\s1 لِيسْثَا ن ينِّي إِعقْبنْ زِي ثْمحْبَاسْثْ أَكْ-ذ زَارُوبَّابِيلْ  
\m
\v 5 إِڭَّا أَربِّي ذڭْ وُوڒْ إِنُو أَذْ ڒَاغِيغْ إِ ثَارْوَا ن ثَاصِيڒثْ ذ إِمْضبَّارنْ حِيمَا أَذْ يِيڒِي إِجّْ ن ؤُزمّمْ ن \add ڒْْڭنْسْ\add* ؤُشَا ؤُفِيغْ لِيسْثَا ن جَّاذِيرَا ن يِينِّي د-إِڭعّْذنْ ذ أَمزْوَارُو، ؤُفِيغْ يُورَا ذَايسْ \add مَانْ أَيَا\add*:   
\b  
\m
\v 6 ”أَقَا ذ إِنَا ذ أَيْثْ ن لْعَامَالَا نِّي د-إِڭعّْذنْ زِي ثْمحْبَاسْثْ - إِمنْفِييّنْ نِّي د-إِوْيِي نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، ذِي لْمنْفَا - ؤُشَاعقْبنْ غَارْ ؤُرْشَالِيمْ ذ يَاهُوذَا، كُوڒْ إِجّْ غَارْ ثنْذِينْثْ نّسْ، \x ◘ \xo 7:‏6 \xt عِز. 2\x*  
\v 7 إِنِّي د-يُوسِينْ أَكْ-ذ زَارُوبَّابِيلْ، يَاهُوشَاعْ، نَاحَامْيَا، عَازَارْيَا، رَاعَامْيَا، نَاحَامَانِي، مُورْذَاخَايْ، بِيلْشَانْ، مِيسْفَارَاثْ، بِيغْوَايْ، نَاحُومْ ذ بَاعْنَا.  
\m وَا ذ \bd ڒْقدّْ ن يرْيَازنْ ن ڒْڭنْسْ ن إِسْرَائِيل.\bd* \f ◼ \fr 7:‏7 \ft \+bd ’ڒْقدّْ‘\+bd* - نِيغْ ’لْعَاذَاذْ‘ نِيغْ ’أَمْذَانْ‘.\f*   
\b  
\m
\v 8 أَيْثْ ن فَارْعُوشْ: أَڒْفَاينْ ؤُ-مْيَا ؤُ-ثْنَاينْ ؤُ-سبْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 9 أَيْثْ ن شَافَاطْيَا: ثڒْثْ-مْيَا ؤُ-ثْنَاينْ ؤُ-سبْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 10 أَيْثْ ن أَرَاحْ: ستَّا-مْيَا ؤُ-ثْنَاينْ ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.   
\m
\v 11 أَيْثْ ن فَاهَاثْ-مُوآبَ، زڭْ أَيْثْ ن يشُوعَا ذ يُووَابْ: أَڒْفَاينْ ؤُ-ثْمنْيَا-مْيَا ؤُ-ثْمنْيَا -عشْرَا \add ن يرْيَازنْ\add*.   
\m
\v 12 أَيْثْ ن عِيلَامْ: أَڒفْ ؤُ-مِيثَايْنْ ؤُ-أَربْعَا ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.   
\m
\v 13 أَيْثْ ن زَاتُّو: ثمْنْ-مْيَا ؤُ-خمْسَا ؤُ-ربْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 14 أَيْثْ ن زَاكَّايْ: سبْعَا-مْيَا ؤُ-ستِّينْ \add ن يرْيَازنْ\add*.   
\m
\v 15 أَيْثْ ن بِينَّايْ: ستَّا-مْيَا ؤُ-ثْمنْيَا ؤُ-ربْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 16 أَيْثْ ن بَابَايْ: ستَّا-مْيَا ؤُ-ثْمنْيَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 17 أَيْثْ ن عَارْجَاذْ: أَڒْفَاينْ ؤُ-طرْثْ-مْيَا ؤُ-ثْنَاينْ ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 18 أَيْثْ ن أَذُونِيقَامْ: ستَّا-مْيَا ؤُ-سبْعَا ؤُ-ستِّينْ \add ن يرْيَازنْ\add*.   
\m
\v 19 أَيْثْ ن بِيغْوَايْ: أَڒْفَاينْ ؤُ-سبْعَا ؤُ-ستِّينْ \add ن يرْيَازنْ\add*.   
\m
\v 20 أَيْثْ ن عَاذِينْ: ستَّا-مْيَا ؤُ-خمْسَا ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.   
\m
\v 21 أَيْثْ ن أَطِيرْ زِي حِيزْقِييَا: ثْمنْيَا ؤُ-ثسْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 22 أَيْثْ ن حَاشُومْ: ثڒْثْ-مْيَا ؤُ-ثْمنْيَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 23 أَيْثْ ن بِيصَايْ: ثڒْثْ-مْيَا ؤُ-أَربْعَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 24 أَيْثْ ن حَارِيفْ: مْيَا ؤُ-ثنْعَاشْ \add ن يرْيَازنْ\add*.   
\m
\v 25 أَيْثْ ن جِيبْعُونْ: خمْسَا ؤُ-ثسْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 26 إِرْيَازنْ ن بَايْثْ-لَاحْمْ ذ نَاطُوفَا: مْيَا ؤُ-ثْمنْيَا ؤُ-ثْمَانْيِينْ \add ن يرْيَازنْ\add*.   
\m
\v 27 إِرْيَازنْ ن عَانَاثُوثْ: مْيَا ؤُ-ثْمنْيَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 28 إِرْيَازنْ ن بَايْثْ-عَازْمُوثْ: ثْنَاينْ ؤُ-ربْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 29 إِرْيَازنْ ن قَارْيَاثْ-يَاعَارِيمْ، كَافِيرَا ذ بِيعْرُوثْ: سبْعَا-مْيَا ؤُ-ثْڒَاثَا ؤُ-ربْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 30 إِرْيَازنْ ن رَامَا ذ جَابَاعْ: ستَّا-مْيَا ؤُ-وَاحذْ ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 31 إِرْيَازنْ ن مِيخْمَاسْ: مْيَا ؤُ-ثْنَاينْ ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 32 إِرْيَازنْ ن بَايْثْ-إِلْ ذ عَايْ: مْيَا ؤُ-ثْڒَاثَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 33 إِرْيَازنْ ن نابُو نّغْنِي: ثْنَاينْ ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.   
\m
\v 34 أَيْثْ ن إِجّْ ن عِيلَامْ نّغْنِي، أَڒفْ ؤُ-مِيثَايْنْ ؤُ-أَربْعَا ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.   
\m
\v 35 أَيْثْ ن حَارِيمْ: ثڒْثْ-مْيَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 36 أَيْثْ ن أَرِيحَا: ثڒْثْ-مْيَا ؤُ-خمْسَا ؤُ-ربْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 37 أَيْثْ ن لُوذْ، حَاذِيذْ ذ ؤُنُو: سبْعَا-مْيَا ؤُ-وَاحذْ ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 38 أَيْثْ ن سَانَائا: ثڒْثْ-أَڒَافْ ؤُ-ثسْعَا-مْيَا ؤُ-ثْڒَاثِينْ \add ن يرْيَازنْ\add*.   
\b  
\m
\v 39 \bd إِكهَّاننْ.\bd*  
\m أَيْثْ ن يَاذَاعْيَا، زِي ثَادَّارْثْ ن يشُوعَا: ثسْعَا-مْيَا ؤُ-ثْڒَاثَا ؤُ-سبْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 40 أَيْثْ ن إِمِّيرْ: أَڒفْ ؤُ-ثْنَاينْ ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.   
\m
\v 41 أَيْثْ ن فَاشْحُورْ: أَڒفْ ؤُ-مِيثَايْنْ ؤُ-سبْعَا ؤُ-ربْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 42 أَيْثْ ن حَارِيمْ: أَڒفْ ؤُ-سْبعْطَاشْ \add ن يرْيَازنْ\add*.   
\b  
\m
\v 43 \bd إِلَاوِييّنْ.\bd*  
\m أَيْثْ ن يشُوعَا، أَيْثْ ن قَاذْمِييِيلْ، زڭْ أَيْثْ ن هُوذُووْيَا: أَربْعَا ؤُ-سبْعِينْ \add ن يرْيَازنْ\add*.   
\b  
\m
\v 44 \bd إِمذْيَازنْ.\bd*  
\m أَيْثْ ن أَسَافْ: مْيَا ؤُ-ثْمنْيَا ؤُ-ربْعِينْ \add ن يرْيَازنْ\add*.   
\b  
\m
\v 45 \bd أَيْثْ ن إِعسَّاسنْ ن ثوُّورَا.\bd*  
\m أَيْثْ ن شَالُّومْ، أَيْثْ ن أَطِيرْ، أَيْثْ ن طَالْمُونْ، أَيْثْ ن عَاقُّوبْ، أَيْثْ ن حَاطِيطَا، أَيْثْ ن شُوبَايْ، أَقَا أَثنْ \add جْمِيعْ\add*: مْيَا ؤُ-ثْمنْيَا ؤُ-ثْڒَاثِينْ \add ن يرْيَازنْ\add*.   
\b  
\m
\v 46 \bd إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ.\bd*  
\m أَيْثْ ن صِيحَا، أَيْثْ ن حَاسُوفَا، أَيْثْ ن طَابَاعُوثْ،   
\m
\v 47 أَيْثْ ن قِيرُوشْ، أَيْثْ ن شِيعَا، أَيْثْ ن فَاذُونْ،   
\m
\v 48 أَيْثْ ن لَابَانَا، أَيْثْ ن حَاجَابَا، أَيْثْ ن سَالْمَايْ،   
\m
\v 49 أَيْثْ ن حَانَانْ، أَيْثْ ن جَاذِيلْ، أَيْثْ ن حَاجَارْ،   
\m
\v 50 أَيْثْ ن رَآيَا، أَيْثْ ن رَاصِينْ، أَيْثْ ن نَاقُّوذَا،   
\m
\v 51 أَيْثْ ن جَازَّامْ، أَيْثْ ن عَازَّا، أَيْثْ ن فَاسِيحْ،   
\m
\v 52 أَيْثْ ن بِيسَايْ، أَيْثْ ن مَاعُونِيمْ، أَيْثْ ن نَافِيشَاسِيمْ،   
\m
\v 53 أَيْثْ ن بَاقْبُوقْ، أَيْثْ ن حَاقُوفَا، أَيْثْ ن حَارْحُورْ،   
\m
\v 54 أَيْثْ ن بَاصْلِيثْ، أَيْثْ ن مَاحِيذَا، أَيْثْ ن حَارْشَا،   
\m
\v 55 أَيْثْ ن بَارْقُوسْ، أَيْثْ ن سِيسَارَا، أَيْثْ ن ثَامَاحْ،   
\m
\v 56 أَيْثْ ن نَاصِيحْ، أَيْثْ ن حَاطِيفَا،   
\b  
\m
\v 57 \bd أَيْثْ ن إِمْسخَّارنْ ن سُولِيمَانْ.\bd*  
\m أَيْثْ ن سُوطَايْ، أَيْثْ ن سُوفَارَاثْ، أَيْثْ ن فَارِيذَا،   
\m
\v 58 أَيْثْ ن يَاعْلَا، أَيْثْ ن ذَارْقُونْ، أَيْثْ ن جِيذِّيلْ،   
\m
\v 59 أَيْثْ ن شَافَاطْيَا، أَيْثْ ن حَاتِّيلْ، أَيْثْ ن فُوخَارَاثْ-هَا-ضَابَايِيمْ ذ أَيْثْ ن أَمُونْ.   
\b  
\m
\v 60 مَارَّا إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ ذ أَيْثْ ن إِمْسخَّارنْ ن سُولِيمَانْ، أَقَا أَثنْ \add جْمِيعْ\add* ثڒْثْ-مْيَا ؤُ-ثْنَاينْ ؤُ-ثسْعِينْ \add ن يرْيَازنْ\add*.   
\b  
\m
\v 61 إِنَا ذ إِنِّي إِڭعّْذنْ زِي ثَالْ-مِيلْحْ، ثَالْ-حَارْشَا، كَارُوبْ، أَدَّانْ ذ إِمِّيرْ، \add مَاشَا\add* نِيثْنِي وَارْ زمَّارنْ أَذْ سّشْننْ زِي جِّيهثْ ن ثَادَّارْثْ ن ڒجْذُوذْ نْسنْ نِيغْ زِي جِّيهثْ ن زَّارِيعثْ نْسنْ، أَقَا نِيثْنِي \add فّْغنْ\add* زِي إِسْرَائِيل:  
\v 62 أَيْثْ ن ذَالَايَا، أَيْثْ ن طُوبِييَا، أَيْثْ ن نَاقُّوذَا: ستَّا-مْيَا ؤُ-ثْنَاينْ ؤُ-ربْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 63 ؤُشَا زڭْ إِكهَّاننْ: أَيْثْ ن حَابَايَا، أَيْثْ ن هَاقُّوصْ، أَيْثْ ن بَارْزِيلَّايْ، \add أَقَا زَّايْسنْ ونِّي\add* إِوْينْ إِشْثْ ن ثمْغَارْثْ زِي يسِّيسْ ن ؤُجِيلْعَاذِي بَارْزِيلَّايْ ؤُ إِتّْوَاڒَاغَا س يِيسمْ نْسنْ.   
\m
\v 64 نِيثْنِي أَرْزُونْ خْ ثوْرِيقْثْ ن ؤُزمّمْ نْسنْ \add ذِي لِيسْثَا ن جَّاذِيرَا\add*، مَاشَا وَارْ ت ؤُفِينْ. س ؤُينِّي تّْوَاسُّوفّْغنْ نِيثْنِي زِي ثُوكهَّانْثْ.  
\v 65 لْوَالِي أَمقّْرَانْ إِنَّا أَسنْ، وَارْ تّتّنْ زِي ثْمسْڒَايِينْ إِقدّْسنْ قَاعْ أَڒْ غَا إِكَّارْ إِجّْ ن ؤُكهَّانْ أَكْ-ذ ؤُرِيمْ ذ ثُومِّيمْ.   
\b  
\m
\v 66 مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* \add ثُوغَا ذِي\add* ثْنَاينْ ؤُ-ربْعِينْ-أَڒفْ ؤُ-ثڒْثْ-مْيَا ؤُ-ستِّينْ \add ن يرْيَازنْ\add*،   
\m
\v 67 نْهْڒَا إِسمْغَانْ نْسنْ ذ ثِييَّا نْسنْ، \add مَاغَارْ\add* إِنَا ثُوغَا أَثنْ مَارَّا سبْعَا-أَڒَافْ ؤُ-ثڒْثْ-مْيَا ؤُ-سبْعَا ؤُ-ثْڒَاثِينْ، ؤُشَا غَارْسنْ مِيثَاينْ ؤُ-خمْسَا ؤُ-ربْعِينْ ن إِمذْيَازنْ ذ ثْمذْيَازِينْ.   
\m
\v 68 إِڒغْمَانْ نْسنْ \add ثُوغَا أَثنْ ذِي\add* أَربْعَا-مْيَا ؤُ-خمْسَا ؤُ-ثْڒَاثِينْ \add ؤُ\add* إِغْيَاڒْ نْسنْ \add ثُوغَا أَثنْ ذِي\add* ستَّا-أَڒَافْ ؤُ-سبْعَا-مْيَا ؤُ-عِيشْرِينْ.   
\m
\v 69 شَا زڭْ إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* وْشِينْ إِ ڒْخذْمثْ. لْوَالِي أَمقّْرَانْ إِوْشَا إِ سّنْذُوقْ ن ثْخُوبَايْ \add ن ڒْخذْمثْ\add* أَڒفْ ن ذْرَاخْمَاثْ ن وُورغْ ذ خمْسِينْ ن طَّاوْيَاثْ إِ ؤُرُوشِّي ذ خمْسَا-مْيَا ؤُ-ثْڒَاثِينْ ن ثْشَامِيرَاثْ إِ إِكهَّاننْ. \f ◼ \fr 7:‏69 \ft \+bd ’ثِيخُوبَايْ‘\+bd* - نِيغْ ’ڒكْنُوزْ‘.\f*   
\m
\v 70 شَا نّغْنِي زڭْ إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* وْشِينْ إِ سّنْذُوقْ ن ثْخُوبَايْ إِ ڒْخذْمثْ عِيشْرِينْ-أَڒفْ ن ذْرَاخْمَاثْ ن وُورغْ ذ أَڒْفَاينْ ن مِينَايَاثْ ن نُّوقَارْثْ.   
\m
\v 71 ؤُشَا مِينْ إِقِّيمنْ زِي ڒْڭنْسْ إِوْشَا عِيشْرِينْ-أَڒفْ ن ذْرَاخْمَاثْ ن وُورغْ ذ أَڒْفَاينْ ن مِينَايَاثْ ن نُّوقَارْثْ ذ سبْعَا ؤُ-ستِّينْ ن ثْشَامِيرَاثْ إِ إِكهَّاننْ.   
\m
\v 72 إِكهَّاننْ ذ إِلَاوِييّنْ ذ إِعسَّاسنْ ن ثوَّارْثْ ذ إِمذْيَازنْ ذ شَا زِي ڒْڭنْسْ ذ إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ ؤُڒَا ذ مَارَّا إِسْرَائِيل، \add مَارَّا نِيثْنِي\add* ڭِّينْ أَذْ زذْغنْ ذِي ثْندَّامْ نْسنْ.   
\b  
\b  
\m  
\c 8
\s1 ثَاغُورِي إِ ڒْڭنْسْ زِي شَّارِيعَا ن مُوسَا  
\m
\v 1 \add ؤُمِي\add* إِبْذَا ؤُيُورْ وِيسّْ سبْعَا ؤُشَا ثُوغَا أَيْثْ ن إِسْرَائِيل ذِي ثْندَّامْ نْسنْ، إِمُونْ مَارَّا ڒْڭنْسْ أَمْ يِيجّْ ن ورْيَازْ ذڭْ وَازَّايْ ن ثوَّارْثْ ن وَامَانْ، نَّانْ إِ عِيزْرَا، أَمْسڒْمذْ ن شَّارِيعَا، أَذْ يَاوِي أَذْلِيسْ ن شَّارِيعَا ن مُوسَا، ثنِّي يُومُورْ سِيذِي إِ إِسْرَائِيل.  
\v 2 ذڭْ وَاسّْ أَمزْوَارُو ن ؤُيُورْ وِيسّْ سبْعَا يِيوِي-د ؤُكهَّانْ عِيزْرَا شَّارِيعَا زَّاثْ إِ وُوذمْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add* ونِّي \add إِدْجَانْ\add* زڭْ يرْيَازنْ ذ ثمْغَارِينْ ذ مَارَّا إِنِّي إِزمَّارنْ أَذْ أَسْ فهْممْ خْمِي إِ ذ أَسْ إِ غَا سْڒنْ.  
\v 3 نتَّا إِغْرَا زَّايسْ غَارْ وُوذمْ ن وَازَّايْ \add إِ إِدْجَانْ\add* زَّاثْ إِ ثوَّارْثْ ن وَامَانْ، زِي ثُوفُّوثْ أَڒْ أَزْينْ ن وَاسّْ، إِ يرْيَازنْ ذ ثمْغَارِينْ ذ إِنِّي إِزمَّارنْ أَذْ أَسْ فهْممْ. ثُوغَا إِمزُّوغنْ ن مَارَّا ڒْڭنْسْ غَارْ وذْلِيسْ إِتّْوَانّْضنْ ن شَّارِيعَا.  
\v 4 ؤُشَا عِيزْرَا، أَمْسڒْمَاذْ ن إِذْلِيسنْ، إِبدّْ خْ إِجّْ ن دّْرُوجْ ن ؤُكشُّوضْ نِّي ڭِّينْ نِيثْنِي إِ ؤُيَا، ؤُ خْ ؤُغزْذِيسْ نّسْ أَفُوسِي بدّنْ مَاتِّيثْيَا ذ شَامَاعْ ذ عَانَايَا ذ ؤُرِييَا ذ حِيلْقِييَا ذ مَاعَاسِييَا ؤُ خْ ؤُزڒْمَاضْ نّسْ \add بدّنْ\add* فَاذَايَا ذ مِيشَايِيلْ ذ مَالْكِييَا ذ حَاشُومْ ذ حَاشْبَادَّانَا، زَاكَارِييَّا ذ مَاشُولَّامْ.  
\v 5 يَارْزمْ عِيزْرَا أَذْلِيسْ زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا ڒْڭنْسْ، مَاغَارْ إِبدّْ سنّجْ إِ مَارَّا ڒْڭنْسْ ؤُشَا ؤُمِي ث يَارْزمْ، إِكَّارْ-د ڒْڭنْسْ مَارَّا.   
\m
\v 6 عِيزْرَا إِسّمْغَارْ سِيذِي، أَربِّي ذ أَمقّْرَانْ، ؤُشَا ڒْڭنْسْ يَارَّا-د س إِفَاسّنْ نْسنْ غَارْ ؤُجنَّا: ”أَمِينْ، أَمِينْ!“ ؤُشَا نِيثْنِي يُوضَارنْ، بنْذْقنْ إِ سِيذِي س ؤُغمْبُوبْ \add نْسنْ\add* غَارْ ثمُّورْثْ.  
\v 7 سّْڒمْذنْ يشُوعَا، بَانِي، شَارَابْيَا، يَامِينْ، عَاقُّوبْ، شَابَّاثَايْ، هُوذِييَا، مَاعَاسِييَا، قَالِيطَا، عَازَارْيَا، يُوزَابَاذْ، حَانَانْ، فَالَايَا ذ إِلَاوِييّنْ ڒْڭنْسْ ذِي شَّارِيعَا ؤُ ڒْڭنْسْ \add إِقِّيمْ\add* ذڭْ ومْشَانْ نّسْ.  
\v 8 غْرِينْ نِيثْنِي زڭْ وذْلِيسْ إِتّْوَانّْضنْ، زِي شَّارِيعَا ن أَربِّي، شَارّْحنْ ؤُ سّشْننْ ڒْمعْنَا إِ ذَايْسنْ ؤُشَا أَمُّو إِ سّْفهْمنْ مِينْ إِتّْوَاغْرِينْ.  
\v 9 ؤُشَا نَاحَامْيَا، ونِّي ذ لْوَالِي أَمقّْرَانْ، ذ ؤُكهَّانْ عِيزْرَا، أَمْسڒْمَاذْ، ذ إِلَاوِييّنْ إِنِّي إِسّْڒمْذنْ ڒْڭنْسْ، نَّانْ إِ مَارَّا ڒْڭنْسْ: ”أَسّْ-أَ ذ أَمْقدّسْ إِ سِيذِي، أَربِّي نْومْ. وَارْ شَّاثمْ أَڭجْذُورْ، وَارْ تّْرُومْ.“ مِينْزِي مَارَّا ڒْڭنْسْ ثُوغَا إِرُو ؤُمِي سْڒَانْ أَوَاڒنْ ن شَّارِيعَا.  
\v 10 إِنَّا أَسنْ \add عَاوذْ\add*: ”ؤُيُورمْ ؤُ ثشّمْ \add مَاشَّا إِسّْوجْذنْ\add* س وَاطَّاسْ ن زّشْثْ، سّْومْ بِينُو أَمِيژِيذْ ؤُشَا وْشمْ مَاشَّا إِ ونِّي وَارْ ذ أَسْ سّْوجْذنْ وَالُو، مَاغَارْ أَسّْ-أَ ذ إِجّْ ن وَاسّْ ذ أَمْقدّسْ إِ سِيذِيثْنغْ. وَارْ سْحِيسِّيفمْ، مَاغَارْ ڒفْرَاحثْ ن سِيذِي ذ لْقلْعَا نْومْ.  
\v 11 إِلَاوِييّنْ سّْفوّْجنْ مَارَّا ڒْڭنْسْ، نَّانْ: ”سْقَارمْ، مَاغَارْ أَسّْ-أَ ذ أَمْقدّسْ \add إِ إِدْجَا\add*. وَارْ سْحِيسِّيفمْ شَا!“  
\v 12 \add خنِّي\add* يُويُورْ مَارَّا ڒْڭنْسْ حِيمَا أَذْ شّنْ أَذْ سْونْ ؤُ أَذْ صذْقنْ ؤُ حِيمَا أَذْ فَارْحنْ س وَاطَّاسْ، مِينْزِي نِيثْنِي فهْمنْ إِ وَاوَاڒنْ إِ ذ أَسنْ إِتّْوَانَّانْ.  
\v 13 ثِيوشَّا نّسْ مُوننْ إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* ن مَارَّا ڒْڭنْسْ ذ إِكهَّاننْ ذ إِلَاوِييّنْ غَارْ عِيزْرَا، أَمْسڒْمَاذْ ن إِذْلِيسنْ، حِيمَا أَذْ أَرْزُونْ ڒفْهَامثْ ذڭْ وَاوَاڒنْ ن شَّارِيعَا.   
\b  
\m  
\s1 أَعيّذْ ن ڒْعِيذْ ن إِعُوشُّوثنْ  
\m
\v 14 نِيثْنِي ؤُفِينْ بلِّي ثُورَا ذِي شَّارِيعَا، أَقَا سِيذِي يُومُورْ س ثْسخَّارْثْ ن مُوسَا، إِتّْخصَّا إِ أَيْثْ ن إِسْرَائِيل أَذْ زذْغنْ ذڭْ إِعُوشُّوثنْ ذِي ڒْعِيذْ ذڭْ ؤُيُورْ وِيسّْ سبْعَا، \x ◘ \xo 8:‏14 \xt ؤُف. 23‏:‏16؛ لَاوِي 23‏:‏34؛ ڒخْڒ. 29‏:‏12‏-‏39؛ أَعَوذ. 16‏:‏13، 14، 15\x*  
\v 15 ؤُ إِتّْخصَّا أَسنْ أَذْ زَّايسْ بَارّْحنْ ؤُشَا أَذْ سّعْذُونْ إِجّْ ن ؤُڒَاغِي ذِي مَارَّا ثِيندَّامْ نْسنْ ؤُڒَا ذِي ؤُرْشَالِيمْ حِيمَا أَذْ إِنِينْ: ”فْغمْ غَارْ إِذُورَارْ ؤُ أَوْيمْ-د إِفثْوَانْ ن ثْشجُّورَا ن زِّيثُونْ ذ إِفثْوَانْ ن إِزمُّورنْ ذ إِفثْوَانْ ن ثَارِيحَانْثْ ذ إِفثْوَانْ ن ثْشجَّارْثْ ن ثِينِي ذ إِفثْوَانْ ن مَارَّا ثِيشجُّورَا غَارْسنْثْ ثِيفْرَايْ، مَاحنْذْ أَذْ زَّايْسنْ ثڭّمْ إِعُوشُّوثنْ، أَمْ مَامّشْ \add ت\add* ثُورَا.“  
\v 16 \add خنِّي\add* إِفّغْ-د ڒْڭنْسْ غَارْ بَارَّا، إِوْينْ-د \add إِفثْوَانْ\add* ؤُشَا ڭِّينْ إِ يِيخفْ نْسنْ إِعُوشُّوثنْ، كُوڒْ إِجّْ خْ ثْزقَّا نّسْ ؤُ ذِي ڒمْرَاحَاثْ نْسنْ ؤُ ذِي ڒمْرَاحَاثْ ن ثَادَّارْثْ ن أَربِّي ؤُ ذڭْ وَازَّايْ ن ثوَّارْثْ ن وَامَانْ ؤُ ذڭْ وَازَّايْ ن ثوَّارْثْ ن إِفْرَايِيمْ.   
\m
\v 17 مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* ن يِينِّي د-إِعقْبنْ زِي ثْمحْبَاسْثْ، ڭِّينْ إِعُوشُّوثنْ ؤُ زدّْغنْ ذڭْ إِعُوشُّوثنْ مِينْزِي أَيْثْ ن إِسْرَائِيل وَارْ ڭِّينْ أَيَا زڭْ وُوسَّانْ ن يَاشُووَا، مِّيسْ ن نُونْ، أَڒْ أَسّْ-أَ ؤُشَا ڒفْرَاحثْ ثُوغَا-ت ذ ثَامقّْرَانْثْ أَطَّاسْ.  
\v 18 أَسّْ إِضْفَارْ ؤُمَاسْ إِتّْوَاغْرَا \add خَاسنْ\add* زڭْ وذْلِيسْ إِتّْوَانّْضنْ ن شَّارِيعَا ن أَربِّي، زڭْ وَاسّْ أَمزْوَارُو أَڒْ أَسّْ أَنڭَّارُو. أَمُّو إِعيّْذنْ ڒْمِيجَاڒْ ن سبْعَا ن وُوسَّانْ ؤُ ذڭْ وَاسّْ وِيسّْ ثْمنْيَا \add ثُوغَا ذِينْ\add* إِجّْ ن ؤُمُونِي إِفَارْزنْ أَمْ مَامّشْ إِ ثدْجَا ذِي لْفَارِيضَا.   
\b  
\b  
\m  
\c 9
\s1 أَسّْ ن تُّوبثْ ذ ثْژَادْجِيثْ  
\m
\v 1 ذڭْ وَاسّْ وِيسّْ أَربْعَا ؤُ-عِيشْرِينْ ن ؤُيُورْ-أَ مُوننْ أَيْثْ ن إِسْرَائِيل س ؤُژُومِّي ؤُ \add ڒحّْفنْ\add* ذڭْ وَارُّوضْ ن ثْخُونْشَايْ \add ن وشْضَانْ\add* ؤُ س ثْعجَّاجْثْ \add خْ ؤُزدْجِيفْ\add*. \f ◼ \fr 9:‏1 \ft \+bd ’ذڭْ وَارُّوضْ ن وشْضَانْ‘\+bd* - س ثْعِيبْرَانِيثْ ’س ثْخَانْشثْ‘. \+bd ’ثَاعجَّاشْثْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ؤُشَاڒْ‘.\f*  
\v 2 بْضَانْ زَّارِيعثْ ن إِسْرَائِيل إِخفْ نْسنْ زِي مَارَّا إِبَارَّانِييّنْ، ؤُشَا أَمْ قِّيمنْ كَّارنْ، نعْمنْ زِي دّْنُوبْ نْسنْ ذ ڒْمُوعْصِييّثْ ن ڒجْذُوذْ نْسنْ.  
\v 3 \add خَاسْ ؤُشَا\add* ذوْڒنْ بدّنْ ذڭْ ومْشَانْ نْسنْ \add عَاوذْ\add* ؤُشَا غْرِينْ أَسنْ إِشْثْ ن ثرْبَاعْثْ ن وَاسّْ زڭْ وذْلِيسْ إِتّْوَانّْضنْ ن شَّارِيعَا ن سِيذِي، أَربِّي نْسنْ، ؤُشَا إِشْثْ ن ثرْبَاعْثْ نّغْنِي نعْمنْ نِيثْنِي \add س دّْنُوبْ نْسنْ\add* ؤُشَا سجْذنْ إِ سِيذِي، أَربِّي نْسنْ.  
\v 4 خْ دّْرُوجْ ن إِلَاوِييّنْ إِبدّْ يشُوعَا ذ بَانِي، قَاذْمِييِيلْ، شَابَانْيَا، بُونِّي، شَارَابْيَا، بَانِي ذ كَانَانِي، ڒَاغَانْ س ثْمِيجَّا إِجهْذنْ غَارْ سِيذِي، أَربِّي نْسنْ.  
\v 5 ؤُشَا إِلَاوِييّنْ، يشُوعَا، قَاذْمِييِيلْ، بَانِي، حَاشَابْنِييَا، شَارَابْيَا، هُوذِييَا، شَابَانْيَا \add ذ\add* فَاثَاحْيَا، نَّانْ: ”كَّارمْ، ثْبَارْكمْ سِيذِي، أَربِّي نْومْ، زِي ڒبْذَا أَڒْ ڒبْذَا! إِڒِي أَذْ إِتّْوَابَاركْ إِسمْ ن ؤُعُودْجِي نّشْ، ونِّي يُوعْڒَانْ خْ مَارَّا لْبَارَاكَا ذ ؤُسمْغَارْ!“   
\b  
\m
\v 6 ”شكْ ذ سِيذِي، مْغِيرْ شكْ. شكْ ثڭِّيذْ أَجنَّا ؤُڒَا ذ أَجنَّا ن إِجنْوَانْ ذ مَارَّا ثِيزمَّارْ نْسنْ، ثَامُّورْثْ ذ مَارَّا مِينْ خَاسْ \add إِدْجَانْ\add*، ڒبْحُورْ ذ مَارَّا مِينْ ذَايسْ \add إِدْجَانْ\add* ؤُ شكْ ثوْشِيذْ أَسنْ ثُوذَارْثْ ؤُشَا ڒْعسْكَارَاثْ ن ؤُجنَّا تّْبنْذَاقنْثْ إِ شكْ. \x ◘ \xo 9:‏6 \xt أَمز. 1؛ إِزهد. 146‏:‏6؛ ڒخ. 14‏:‏15؛ 17‏:‏24؛ أَسَا. 14‏:‏7\x*   
\m
\v 7 شكْ ذ سِيذِي، أَربِّي، ونِّي إِفَارْزنْ أَبْرَامْ. شكْ ثسُّوفّْغذْ ث-إِ-د زِي ؤُرْ ن إِكَالْذَانِييّنْ ؤُشَا ثڭِّيذْ أَسْ إِبْرَاهِيمْ. \x ◘ \xo 9:‏7 \xt أَمز. 11‏:‏31، 32؛ 12‏:‏1\x*   
\m
\v 8 شكْ ثُوفِيذْ ؤُڒْ نّسْ ذَايسْ ڒَامَانْ زَّاثْ إِ وُوذمْ نّشْ ؤُ ثڭِّيذْ أَكِيذسْ ڒْعَاهْذْ بلِّي شكْ أَذْ ثوْشذْ إِ زَّارِيعثْ نّسْ ثَامُّورْثْ ن أَيْثْ ن كنْعَانْ، ن إِحِيتِّييّنْ، ن إِمُورِييّنْ، ن إِفَارِيزِييّنْ، ن إِيابُوسِييّنْ ؤُ ن إِجِيرْجَاسِييّنْ، ؤُشَا ثڭِّيذْ عْلَاحْسَابْ أَوَاڒنْ نّشْ، مِينْزِي شكْ ذ أَمْسڭّذْ إِ ثدْجِيذْ. \x ◘ \xo 9:‏8 \xt أَمز. 12‏:‏7؛ 13‏:‏15؛ 15‏:‏6، 18؛ 17‏:‏8؛ 26‏:‏4\x*   
\m
\v 9 شكْ ثژْرِيضْ ثَامَارَا ن ڒجْذُوذْ نّغْ ذِي مِيصْرَا ؤُ ثسْڒِيذْ إِغُويَّانْ نْسنْ زِي غَارْ ڒبْحَارْ ن ثلْڭَا. \x ◘ \xo 9:‏9 \xt ؤُف. 3‏:‏7؛ 14‏:‏10\x*   
\m
\v 10 شكْ ثڭِّيذْ ڒعْڒَامَاثْ ذ لْمُوعْجِيزَاثْ غَارْ فِيرْعُونْ ؤُ غَارْ مَارَّا إِمْسخَّارنْ نّسْ ؤُ جَارْ ڒْڭنْسْ ن ثمُّورْثْ، مِينْزِي شكْ ثسّْنذْ، أَقَا نِيثْنِي ڭِّينْ ضِيدّْ نْسنْ س ثُوفّثْ ؤُشَا شكْ ثڭِّيذْ إِ يِيخفْ نّشْ إِجّْ ن إِسمْ، أَمْ \add ثدْجَا\add* أَسّْ-أَ. \x ◘ \xo 9:‏10 \xt ؤُف. 7؛ 8؛ 9؛ 10؛ 11؛ 12؛ 14\x*   
\m
\v 11 شكْ ثبْضِيذْ ڒبْحَارْ زَّاثْ إِ وُوذمْ نْسنْ أَڒَامِي نِيثْنِي عْذُونْ خْ \add ثمُّورْثْ\add* يُوژْغنْ ذِي ڒْوسْطْ ن ڒبْحَارْ، ؤُشَا إِنِّي خَاسنْ إِتَّاژّْڒنْ ثنْضَارذْ ثنْ ذِي ڒَادْجَاغْ أَمْ يِيجّْ ن وژْرُو ذڭْ وَامَانْ إِجهْذنْ. \x ◘ \xo 9:‏11 \xt ؤُف. 14‏:‏22‏-‏31\x*   
\m
\v 12 زڭْ إِجّْ ن ؤُقلِّيجْ ن ؤُسيْنُو ثْڭوّْذذْ ثنْ س وَاسّْ ؤُ س يِيجّْ ن ؤُقلِّيجْ ن ثْمسِّي س دْجِيڒثْ، حِيمَا أَذْ أَسنْ ثوْشذْ ثَافَاوْثْ خْ وبْرِيذْ إِ خْ إِ غَا ؤُيُورنْ. \x ◘ \xo 9:‏12 \xt ؤُف. 13‏:‏21؛ 14‏:‏19؛ 40‏:‏38؛ إِزهد. 105‏:‏39\x*   
\m
\v 13 شكْ ثهْوِيذْ-د خْ وذْرَارْ ن سِينَا ؤُ ثسِّيوْڒذْ أَكِيذْسنْ زڭْ ؤُجنَّا ؤُشَا ثوْشِيذْ أَسنْ لْفَارَايِيضْ إِسڭّْذنْ ذ إِزرْفَانْ إِ ذِي إِدْجَا ڒَامَانْ ذ ثْوصَّا ذ ڒُومُورَاثْ إِصبْحنْ. \x ◘ \xo 9:‏13 \xt ؤُف. 19‏:‏20؛ 20‏:‏1‏-‏21\x*   
\m
\v 14 ثسّشْنذْ أَسنْ سّبْثْ نّشْ إِقدّْسنْ ؤُشَا ثڭِّيذْ خَاسنْ ڒُومُورَاثْ ذ ثْوصَّا ذ شَّارِيعَا س ثْسخَّارْثْ ن مُوسَا، أَمْسخَّارْ نّشْ.   
\m
\v 15 شكْ ثوْشِيذْ أَسنْ أَغْرُومْ زڭْ ؤُجنَّا إِ ڒَاژْ نْسنْ ؤُشَا ثسُّوفّْغذْ أَسنْ-د أَمَانْ زِي ثصْضَارْثْ إِ ؤُفَاذِي نْسنْ ؤُشَا ثنِّيذْ أَسنْ أَذْ أَذْفنْ غَارْ ثمُّورْثْ، ثنِّي إِ ثسّْڭعّْذذْ أَفُوسْ نّشْ \add حِيمَا أَذْ ثجَّادْجذْ\add* أَذْ ثنْ ت-إِ-د-ثوْشذْ، حِيمَا أَذْ ت طّْفنْ ذ ڒْوَارْثْ.“ \x ◘ \xo 9:‏15 \xt ؤُف. 16‏:‏14؛ 17‏:‏6؛ ڒخْڒ. 20‏:‏9\x*   
\b  
\m
\v 16 ”أَقَا نِيثْنِي أَكْ-ذ ڒجْذُوذْ نّغْ ڭِّينْ س ثُوفّثْ ذ ثْغنَّانْثْ ؤُ وَارْ سْڒِينْ شَا غَارْ ڒُومُورَاثْ نّشْ.   
\m
\v 17 نِيثْنِي ؤُڭِينْ أَذْ غَارسْ سْڒنْ، وَارْ فكَّارنْ ذِي لْمُوعْجِيزَاثْ نّشْ إِ غَارْسنْ ثڭِّيذْ ؤُ نِيثْنِيغنَّانْ ؤُ ذڭْ ؤُغوّغْ نْسنْ ڭِّينْ إِجّْ ذ ؤُزدْجِيفْ \add خْ يِيخفْ نْسنْ\add* حِيمَا أَذْعقْبنْ غَارْ ثسْمُوغِي نْسنْ. \add مَاشَا\add* شكْ ذ إِجّْ ن أَربِّي إِغفَّارنْ، ذَايكْ ڒْخَاضَارْ ذ أَرّحْمثْ، غَاركْ تَّاسِيعْ ن ڒْخَاضَارْ ذ ثَامخْسِيوْثْ إِشوَّارنْ س وَاطَّاسْ، ؤُ شكْ وَارْ ذَايْسنْ ثسْمِيحذْ شَا. \x ◘ \xo 9:‏17 \xt ؤُف. 34‏:‏7؛ ڒخْڒ. 14‏:‏4، 18؛ إِزهد. 86‏:‏5\x*   
\m
\v 18 عَاذْ، ؤُمِي ڭِّينْ نِيثْنِي إِجّْ ن ؤُعجْمِي إِفسْينْ إِ يِيخفْ نْسنْ، نَّانْ: ’وَا ذ أَربِّي نّشْ إِ شكْ إِ د-إِسُّوفّْغنْ زِي مِيصْرَا‘، ؤُشَا شقّْفنْ أَطَّاسْ، \f ◼ \fr 9:‏18 \ft \+bd ’أَمْوَا‘\+bd* - نِيغْ ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘.\f*  \x ◘ \xo 9:‏18 \xt ؤُف. 32\x*  
\v 19 أَقَا شكْ ذِي أَرّحْمثْ نّشْ ثَامقّْرَانْثْ وَارْ ثنْ ثجِّيذْ شَا ذِي ڒخْڒَا. أَقلِّيجْ ن ؤُسيْنُو \add إِ إِدْجَانْ\add* حِيمَا أَذْ ثنْ إِڭوّذْ س وَاسّْ، وَارْ خَاسنْ إِڭّْوِيجْ شَا، ؤُڒَا ذ أَقلِّيجْ ن ثْمسِّي \add إِ إِدْجَانْ\add* حِيمَا أَذْ أَسنْ إِوْشْ ثَافَاوْثْ ذڭْ وبْرِيذْ إِ خْ إِ غَا ؤُيُورنْ، وَارْ خَاسنْ إِڭّْوِيجْ شَا س دْجِيڒثْ. \x ◘ \xo 9:‏19 \xt ؤُف. 13‏:‏22؛ 40‏:‏38\x*   
\m
\v 20 شكْ ثوْشِيذْ أَرُّوحْ نّشْ أَصبْحَانْ، حِيمَا أَذْ ثنْ إِسّڒْمذْ، ؤُ شكْ وَارْ ذ أَسنْ ثكِّيسذْ شَا ’مَانَّا‘ نّكْ زڭْ ؤُقمُّومْ نْسنْ ؤُشَا ثوْشِيذْ أَسنْ أَمَانْ إِ ؤُفَاذِي نْسنْ. \x ◘ \xo 9:‏20 \xt ڒخْڒ. 11‏:‏17؛ ياش. 5‏:‏12\x*   
\m
\v 21 أَربْعِينْ ن إِسڭّْوُوسَا شكْ ثتّْهلِّيذْ ذَايْسنْ ذِي ڒخْڒَا. وَارْ غَارْسنْ إِتّْخِيصَّا ؤُڒَا ذ شَا ن ڒْحَاجّثْ، أَرُّوضْ نْسنْ وَارْ يَارْشِي شَا ؤُشَا إِضَارنْ نْسنْ وَارْ ؤُفّنْ. \x ◘ \xo 9:‏21 \xt أَعَوذ. 2‏:‏7؛ 8‏:‏4؛ 29‏:‏5\x*   
\m
\v 22 شكْ ثوْشِيذْ أَسنْ مَارَّا ثِيڭلْذِيوِينْ ذ ڒڭْنُوسْ ؤُشَا ثبْضِيذْ أَسنْ ثنْ ذ ثَاسْغَارْثْ س إِجّْ ن ويْمِيرْ. نِيثْنِي طّْفنْ ثَامُّورْثْ ن سِيحُونْ ذ ڒْوَارْثْ، أَقَا-ت ذ ثَامُّورْثْ ن ؤُجدْجِيذْ ن حَاشْبُونْ، ذ ثمُّورْثْ ن عُوجْ، أَجدْجِيذْ ن بَاشَانْ. \x ◘ \xo 9:‏22 \xt ڒخْڒ. 21‏:‏21، 33\x*   
\m
\v 23 شكْ ثَارِّيذْ إِحنْجِيرنْ نْسنْ أَطَّاسْ أَمْ يِيثْرَانْ ذڭْ ؤُجنَّا ؤُ ثسِّيذْفذْ ثنْ غَارْ ثمُّورْثْ إِ خْ ثُوغَا ثنِّيذْ إِ ڒجْذُوذْ نْسنْ، أَذْ غَارسْ د-أَذْفنْ حِيمَا أَذْ ت طّْفنْ ذ ڒْوَارْثْ. \x ◘ \xo 9:‏23 \xt أَمز. 22‏:‏17\x*   
\m
\v 24 يُوذفْ غَارسْ وَارَّاوْ ؤُشَا طّْفنْ ت ذ ڒْوَارْثْ ؤُ زَّاثْ إِ وُوذمْ نْسنْ أَقَا ثڭِّيذْ إِمزْذَاغْ ن ثمُّورْثْ سَاذُو أَفُوسْ نْسنْ، ؤُڒَا ذ إِجدْجِيذنْ نْسنْ ذ ڒڭْنُوسْ ن ثمُّورْثْ، حِيمَا أَذْ زَّايْسنْ ڭّنْ مِينْ إِ ذ أَسنْ إِتّْغِيڒْ مْلِيحْ.   
\m
\v 25 نِيثْنِي حوّْسنْ ثِيندَّامْ إِفَارْينْ ذ إِشْثْ ن ثمُّورْثْ إِسّغْمَاينْ ؤُ نِيثْنِي طّْفنْ عَاوذْ ثُوذْرِينْ ذ ڒْوَارْثْ شُّورنْثْ س مَارَّا ڒْخَارْ، أَنُوثنْ إِتّْوَاغْزنْ، إِمَارْجَاعنْ ن ؤُضِيڒْ ذ ڒعْرَاصِيثْ ن زِّيثُونْ ذ ثْشجُّورَا ن فْرُوثَا س ؤُفيّضْ، ؤُشَا نِيثْنِي شِّينْ، جِّيوْننْ، ذوْڒنْ صحّنْ ؤُشَا أَرِّينْ-د مژْرِي س ثْشُونِي نّشْ ثَامقّْرَانْثْ.   
\m
\v 26 \add مَاشَا نِيثْنِي\add* ذوْڒنْ وَارْ طِّيعنْ ؤُشَاغوّْغنْ خَاكْ ؤُشَا نْضَارنْ شَّارِيعَا نّشْ ؤُ نْغِينْ إِنَابِييّنْ نّشْ إِنِّي ثُوغَا إِشهّْذنْ جَارْ أَسنْ مَاحنْذْ أَذْ ثنْ د-أَرّنْ غَاركْ. أَقَا شقّْفنْ ذَايكْ س يِيجّْ ن ؤُشقّفْ إِمْغَارْ. \x ◘ \xo 9:‏26 \xt 1 إِج. 18‏:‏4؛ 19‏:‏10؛ 2 إِم. 24‏:‏20، 21\x*   
\m
\v 27 س ؤُيَا ثَارِّيذْ ثنْ ذڭْ ؤُفُوسْ ن إِغْرِيمنْ نْسنْ إِنِّي إِ ثنْ إِحْصَارنْ، \add مَاشَا\add* مَاڒَا ڒَاغَانْ-د خَاكْ ذِي ڒْوقْثْ ن ڒحْصَارثْ نْسنْ، \add خنِّي\add* ثسْڒِيذْ غَارْسنْ زڭْ ؤُجنَّا ؤُشَا ذِي أَرّحْمثْ نّشْ ثَامقّْرَانْثْ ثوْشِيذْ أَسنْ إِمْسنْجَامنْ نِّي إِ ثنْ إِفكّنْ زڭْ ؤُفُوسْ ن إِغْرِيمنْ نْسنْ. \x ◘ \xo 9:‏27 \xt ڒقض. 2‏:‏14‏-‏23\x*   
\m
\v 28 مَاڒَا ؤُفِينْ ڒْهُوذْنثْ، ڭِّينْ عَاوذْ ڒْغَارْ زَّاثْ إِ وُوذمْ نّشْ ؤُشَا ثڭِّيذْ ثنْ ذڭْ ؤُفُوسْ ن ڒْعذْيَانْ نْسنْ ؤُشَا نِيثْنِي سدْجْضنْ خَاسنْ. ؤُمِي ثُوبنْ، ڒَاغَانْ-د خَاكْ، أَقَا ثسْڒِيذْ أَسنْ زڭْ ؤُجنَّا ؤُ \add أَمُّو إِ\add* ثْفكّذْ إِ-ثنْ س أَرّحْمثْ نّشْ أَطَّاسْ ن ثْوَاڒَاوِينْ.   
\m
\v 29 شكْ ثْشهْذذْ ضِيدّْ نْسنْ حِيمَا أَذْ د -عقْبنْ غَارْ شَّارِيعَا نّشْ، مَاشَا نِيثْنِي ڭِّينْ س ثُوفّثْ ؤُ وَارْ سْڒِينْ شَا غَارْ ثْوصَّا نّشْ. أَقَا خْضَانْ زِي جِّيهثْ ن لْفَارَايِيضْ نّشْ، ؤُمِي بْنَاذمْ ونِّي إِ زَّايْسنْ إِ غَا يڭّْ أَذْ زَّايْسنْثْ إِدَّارْ، ؤُشَا نِيثْنِي أَرِّينْ-د غَارْسنْ أَعْرُورْ، ثُوغَا سّْقسْحنْ إِرِي نْسنْ، وَارْ غَاركْ د-سْڒِينْ. \x ◘ \xo 9:‏29 \xt لَاوِي 18‏:‏5؛ حِز. 20‏:‏11؛ رُوم. 10‏:‏5؛ ڭال. 3‏:‏12\x*   
\m
\v 30 أَطَّاسْ ن إِسڭّْوُوسَا ثْحمّْڒذْ أَكِيذْسنْ، ثْشهْذذْ ضِيدّْ إِ نْسنْ س أَرُّوحْ نّشْ، س ثْسخَّارْثْ ن إِنَابِييّنْ، مَاشَا نِيثْنِي وَارْ سْڒِينْ. \add س ؤُينِّي\add* ثوْشِيذْ ثنْ ذڭْ ؤُفُوسْ ن ڒڭْنُوسْ ن ثمُّورَا. \x ◘ \xo 9:‏30 \xt 2 إِج. 17‏:‏13؛ 2 إِم. 36‏:‏15\x*   
\m
\v 31 \add مَاشَا\add* ذِي أَرّحْمثْ نّشْ ثَامقّْرَانْثْ وَارْ ثنْ ثَارذْدْجذْ شَا ؤُ وَارْ ذَايْسنْ ثسْمِيحذْ شَا، مَاغَارْ شكْ ذ إِجّْ ن أَربِّي ذ أَحْنِينْ ذ أَرْحِيمْ.   
\b  
\m
\v 32 ”خنِّي ڒخُّو، أَربِّي نّغْ، أَقَا شكْ، أَربِّي ذ أَمقّْرَانْ، إِزمَّارنْ، إِسَّاڭّْوَاذنْ، ونِّي إِتّطّْفنْ ذِي ڒْعَاهْذْ ؤُ ذِي ثْمخْسِيوْثْ إِشوَّارنْ، وَارْ حسّبْ شَا ذْرُوسْ مَارَّا ڒغْبنْ إِ خَانغْ د-إِكِّينْ، خْ إِجدْجِيذنْ نّغْ، خْ ڒْحُوكَّامْ نّغْ ؤُ خْ إِكهَّاننْ نّغْ ؤُ خْ إِنَابِييّنْ نّغْ ؤُ خْ ڒجْذُوذْ نّغْ ؤُ خْ مَارَّا ڒْڭنْسْ نّغْ زڭْ وُوسَّانْ ن إِجدْجِيذنْ ن أَشُّورْ أَڒْ أَسّْ-أَ.   
\m
\v 33 \add ثُوغَا\add* شكْ ذ أَمْسڭّذْ ذِي مَارَّا مِينْ خَانغْ إِكِّينْ، مَاغَارْ شكْ ثڭِّيذْ أَنغْ س ڒَامَانْ، \add مَاشَا\add* نشِّينْ نڭَّا س ڒقْجَاحثْ. \x ◘ \xo 9:‏33 \xt أَعَوذ. 32‏:‏4؛ دَان. 9‏:‏14\x*   
\m
\v 34 إِجدْجِيذنْ نّغْ، ڒْحُوكَّامْ نّغْ، إِكهَّاننْ نّغْ ذ ڒجْذُوذْ نّغْ وَارْ ضفَّارنْ شَّارِيعَا نّشْ ؤُشَا وَارْ سْڒِينْ غَارْ ڒُومُورَاثْ نّشْ ؤُڒَا غَارْ شّْهَاذَاثْ نّشْ نِّي ثْشهْذذْ ضِيدّْ إِ نْسنْ.   
\m
\v 35 س ثْڭلْذِيثْ نْسنْ ؤُ س ڒْخَارْ نْسنْ أَطَّاسْ إِ ذ أَسنْ ثوْشِيذْ ؤُ س ثمُّورْثْ ثَامقّْرَانْثْ إِسّغْمَاينْ إِ ذ أَسنْ ثوْشِيذْ، وَارْ شكْ سخَّارنْ شَا ؤُشَا وَارْ ثُوبنْ زِي ثْمڭَّا نْسنْ ثِيعفَّانِينْ.   
\m
\v 36 خْزَارْ أَسّْ-أَ أَقَا نشِّينْ ذ إِمْسمْغَانْ ؤُ ثَامُّورْثْ إِ ثوْشِيذْ إِ ڒجْذُوذْ نّغْ مَاحنْذْ أَذْ زَّايسْ نشّْ ڒْغِيدْجثْ ذ ڒْخَارْ، خْزَارْ أَقَا نشِّينْ ذ إِمْسمْغَانْ إِ ذَايسْ \add ندْجْ\add*.   
\m
\v 37 ڒْغِيدْجثْ ثَامقّْرَانْثْ نّسْ \add أَذْ ثْرَاحْ\add* غَارْ إِجدْجِيذنْ، إِنِّي إِ خَانغْ ثڭِّيذْ ذِي سِّيبّثْ ن دّْنُوبْ نّغْ، ؤُشَا نِيثْنِي تّْصدْجَاضنْ خْ أَرَّايمْ نّغْ ؤُ خْ ڒْمَاڒْ نّغْ أَمْ مَامّشْ ذ أَسنْ إِتّْغِيڒْ مْلِيحْ، ؤُ نشِّينْ أَقَا أَنغْ ذِي ڒحْصَارثْ ذ ثَامقّْرَانْثْ.“   
\b  
\b  
\m  
\c 10
\s1 ڒْعَاهْذْ ذ ثْمَارْسِيوْثْ ن ؤُشمّعْ  
\m
\v 1 ”خْ قَاعْ مَانْ أَيَا أَذْ نڭّْ إِجّْ ن ڒْعَاهْذْ إِمْثنْ ؤُشَا أَذْ ث نْزمّمْ ذِي ثِيرَا ؤُشَا ڒْحُوكَّامْ نّغْ، إِلَاوِييّنْ نّغْ ذ إِكهَّاننْ نّغْ أَذْ خَاسْ ڭّنْ أَشمِّيعْ.“  
\v 2 إِنِّي خَاسْ إِڭِّينْ أَشمِّيعْ ذ إِنَا:  
\m \bd نَاحَامْيَا، ونِّي ذ لْوَالِي أَمقّْرَانْ، مِّيسْ ن حَاكَالْيَا،\bd* ذ صِيذْقِييَا،  
\v 3 سَارَايَا، عَازَارْيَا، إِرْمِييَا،  
\v 4 فَاشْحُورْ، أَمَارْيَا، مَالْكِييَا،  
\v 5 حَاتُّوشْ، شَابَانْيَا، مَالُّوخْ،  
\v 6 حَارِيمْ، مَارِيمُوثْ، عُوبَاذْيَا،  
\v 7 ذَانِييَالْ، جِينِّيثُونْ، بَارُوخْ،  
\v 8 مَاشُولَّامْ، أَبِييَا، مِييَامِينْ،  
\v 9 مَاعَازْيَا، بِيلْجَايْ ذ شَامْعِييَا. \bd إِنَا ثُوغَا أَثنْ ذ إِكهَّاننْ\bd*.   
\m
\v 10 ؤُشَا \bd إِلَاوِييّنْ\bd*: يشُوعَا، مِّيسْ ن أَزَانْيَا، ذ بِينَّايْ. زڭْ أَيْثْ ن حِينَاذَاذْ، قَاذْمِييِيلْ.  
\v 11 ؤُڒَا ذ أَيْثْمَاثْسنْ: شَابَانْيَا، هُوذِييَا، قَالِيطَا، قَالَايَا، حَانَانْ،  
\v 12 مِيخَا، رَاحُوبْ، حَاشَابْيَا،  
\v 13 زَاكُّورْ، شَارَابْيَا، شَابَانْيَا،  
\v 14 هُوذِييَا، بَانِي ذ بَانِينُو.   
\m
\v 15 \bd إِزدْجِيفنْ ن ڒْڭنْسْ\bd*: فَارْعُوشْ، فَاحَاثْ-مُوآبَ، عِيلَامْ، زَاتُّو، بَانِي،  
\v 16 بُونِّي، عَازْجَاذْ، بِيبَايْ،  
\v 17 أَذُونِييَا، بِيغْوَايْ، عَاذِينْ،  
\v 18 أَطِيرْ، حِيزْقِييَا، عَازُّورْ،  
\v 19 هُوذِييَا، حَاشُومْ، بِيصَايْ،  
\v 20 حَارِيفْ، عَانَاثُوثْ، نِيبَايْ،  
\v 21 مَاجْفِيعَاشْ، مَاشُولَّامْ، حَازِيرْ،  
\v 22 مَاشِيزَابْيِيلْ، صَاذُوقْ، يَادُّوعْ،  
\v 23 فَالَاطْيَا، حَانَانْ، عَانَايَا،  
\v 24 هُوشِيعَا، حَانَانْيَا، حَاشُوبْ،  
\v 25 هَالُّوحِيشْ، فِيلْجَا، شُوبِيقْ،  
\v 26 رَاحُومْ، حَاشَابْنَا، مَاعَاسِييَا،  
\v 27 أَخِييَا، حَانَانْ، عَانَانْ،  
\v 28 مَالُّوخْ، حَارِيمْ ذ بَاعْنَا.   
\b  
\m
\v 29 إِنِّي إِقِّيمنْ زِي ڒْڭنْسْ، إِكهَّاننْ، إِلَاوِييّنْ، إِعسَّاسنْ ن ثوُّورَا، إِمذْيَازنْ، إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ ذ مَارَّا إِنِّي ذ إِعزّْڒنْ إِخفْ نْسنْ خْ ڒڭْنُوسْ ن ثمُّورَا غَارْ شَّارِيعَا ن أَربِّي، ثِيمْغَارِينْ نْسنْ، إِحنْجِيرنْ نْسنْ ذ يسِّيثْسنْ، كُوڒْ إِجّْ ونِّي غَارْ ثدْجَا ثُوسّْنَا ذ ڒفْهَامثْ، \f ◼ \fr 10:‏29 \ft \+bd ’إِمذْيَازنْ‘\+bd* - نِيغْ ’إِمغْنُوجنْ‘.\f*  
\v 30 نِيثْنِي \add مَارَّا\add* ڒصْقنْ غَارْ أَيْثْمَاثْسنْ، أَيْثْ ن بُو-صُّولْطَا نْسنْ، ؤُشَا شَّارْشنْ ذِي نّعْڒثْ ذ ثْجَادْجِيثْ مَاحنْذْ أَذْ دَّارنْ عْلَاحْسَابْ شَّارِيعَا ن أَربِّي، ثنِّي إِمّوْشنْ خْ ؤُفُوسْ ن مُوسَا، أَمْسخَّارْ ن أَربِّي، ؤُشَا \add مَاهنْذْ\add* أَذْ حْضَانْ مَارَّا ڒُومُورَاثْ ن سِيذِي، سِيذِيثْنغْ، ؤُشَا أَذْ طّْفنْ ذِي لْفَارَايِيضْ نّسْ ذ ثْوصَّا نّسْ.  
\v 31 \add عَاوذْ نڭَّا خَانغْ\add* مَاحنْذْ وَارْ نتِّيشْ يسِّيثْنغْ إِ ڒڭْنُوسْ ن ثمُّورْثْ ؤُ وَارْ نتِّيوِي يسِّيثْسنْ إِ إِحنْجِيرنْ نّغْ \add ذ ثَامْغَارْثْ\add*. \x ◘ \xo 10:‏31 \xt ؤُف. 34‏:‏16؛ أَعَوذ. 7‏:‏3\x*   
\m
\v 32 ؤُشَا مَاڒَا ڒڭْنُوسْ ن ثمُّورْثْ ؤُسِينْ-د ذڭْ وَاسّْ ن سّبْثْ، إِوْينْ صّڒْعثْ ذ عْڒَامْ كُوڒْ إِمنْذِي حِيمَا أَذْ زّنْزنْ أَيَا، أَقَا نشِّينْ ذِي سّبْثْ نِيغْ ذڭْ إِجّْ ن وَاسّْ إِقدّْسنْ نّغْنِي وَارْ خَاسنْ نتِّيوِي وَالُو. ؤُشَا \add أَمُّو عَاوذْ نڭَّا خَانغْ\add*، أَقَا نشِّينْ أَذْ نجّْ \add ثَامُّورْثْ\add* ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا ؤُ وَارْ نْكسِّي أَرِّيبَا زڭْ ؤُڒَا ذ يِيجّنْ. \x ◘ \xo 10:‏32 \xt ؤُف. 20‏:‏10؛ 23‏:‏10؛ 34‏:‏21؛ لَاوِي 23‏:‏2؛ 25‏:‏2؛ أَعَوذ. 5‏:‏1‏-‏15\x*   
\m
\v 33 نڭَّا خَانغْ ڒُومُورَاثْ مَاحنْذْ أَذْ نوْشْ إِشْثْ ن تُّوڒُوثْ ن شِيقْلُو ذڭْ ؤُسڭّْوَاسْ إِ ثْسخَّارْثْ ن ثَادَّارْثْ ن أَربِّي نّغْ،  
\v 34 إِ وغْرُومْ ن وسْشَانْ ؤُ إِ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* نْ ڒبْذَا ؤُ إِ ثْغَارْصْثْ ن وشْمَاضْ ن ڒبْذَا ذڭْ وُوسَّانْ ن سّبْثْ ؤُ ذڭْ وُوسَّانْ ن ؤُيُورْ ن جْذِيذْ، إِ ڒعْيُوذَاثْ إِتّْوَاڭّنْ، إِ ثْمسْڒَايِينْ إِقدّْسنْ ؤُ إِ ثْغَارْصَا ن دّنْبْ مَاحنْذْ أَذْ \add زَّايْسنْثْ\add* إِتّْوَاڭّْ أَصْڒَاحْ خْ إِسْرَائِيل ؤُ خْ مَارَّا ثَاسخَّارْثْ ن ثَادَّارْثْ ن أَربِّي نّغْ. \x ◘ \xo 10:‏34 \xt ڒخْڒ. 28‏:‏29\x*   
\m
\v 35 نشِّينْ، إِكهَّاننْ، إِلَاوِييّنْ ذ ڒْڭنْسْ، \add أَمْ نتّْوَاستّفْ\add* عْلَاحْسَابْ ڒَادْجَاثْ ن إِبَابَاثنْ نّغْ، ڭِّينْ ثَاقدُّوحْثْ إِ ثوْهِيبْثْ ن ؤُكشُّوضْ ثنِّي ثُوغَا إِتّْخصَّا أَذْ ثتّْوَاسِّيذفْ غَارْ ثَادَّارْثْ ن أَربِّي نّغْ ذڭْ وُوسَّانْ إِتّْوَاڭّنْ، أَسڭّْوَاسْ أَوَارْنِي إِ ؤُسڭّْوَاسْ، مَاحنْذْ أَذْ ثتّْوَاسّشْمضْ خْ ؤُعَالْطَارْ ن سِيذِي، أَربِّي نّغْ، أَمْ مَامّشْ إِ ثُورَا ذِي شَّارِيعَا. \f ◼ \fr 10:‏35 \ft \+bd ’ؤُسَّانْ‘\+bd* - س ثْعِيبْرَانِيثْ ’إِكُوذنْ‘.\f*   
\m
\v 36 ؤُشَا \add نڭَّا خَانغْ عَاوذْ\add* مَاحنْذْ أَذْ نَاوِي ثَامنْزُوثْ ن ثمُّورْثْ نّغْ ذ ثْمنْزُوثْ ن ڒْغِيدْجثْ ن مَارَّا ثِيشجُّورَا غَارْ ثَادَّارْثْ ن سِيذِي، أَسڭّْوَاسْ خْ ؤُمَاسْ، \x ◘ \xo 10:‏36 \xt ؤُف. 23‏:‏19؛ لَاوِي 19‏:‏23\x*  
\v 37 ؤُڒَا ذ إِمنْزَا ن إِحنْجِيرنْ نّغْ ذ ڒبْهَايمْ نّغْ أَمْ مَامّشْ إِ ثُورَا ذِي شَّارِيعَا، ؤُشَا أَذْ نَاوِي إِمنْزَا ن إِفُونَاسنْ نّغْ ذ وُودْجِي نّغْ ذِي ثَادَّارْثْ ن أَربِّي، غَارْ إِكهَّاننْ نِّي إِتّْسخَّارنْ ذِي ثَادَّارْثْ ن أَربِّي. \x ◘ \xo 10:‏37 \xt ؤُف. 13‏:‏2؛ ڒخْڒ. 3‏:‏13؛ 8‏:‏17\x*   
\m
\v 38 ؤُشَا \add نڭَّا خَانغْ عَاوذْ\add* مَاحنْذْ أَذْ نتَّاوِي ثَامزْوَارُوثْ \add ن مِينْ إِتّْوَاڭّنْ\add* زڭْ وَارشْثِي نّغْ ؤُ زِي ثوْهِيبِينْ ن ؤُسْڭعّذْ نّغْ ؤُ زِي فْرُوثَا ن مَارَّا ثِيشجُّورَا ؤُ زِي بِينُو ن جْذِيذْ ذ زّشْثْ غَارْ إِكهَّاننْ ذڭْ إِخَّامنْ \add إِ ڒخْزنْ\add* ن ثَادَّارْثْ ن أَربِّي نّغْ، ؤُڒَا ذ ڒعْشُورْ ن ثمُّورْثْ نّغْ غَارْ إِلَاوِييّنْ. ؤُشَا إِلَاوِييّنْ \add سِيمَانْثْ نْسنْ\add* أَذْ طّْفنْ ڒعْشُورْ ذِي مَارَّا ثِيندَّامْ مَانِي ثُوغَا نْخدّمْ نشِّينْ خْ ثمُّورْثْ، \x ◘ \xo 10:‏38 \xt لَاوِي 23‏:‏17؛ ڒخْڒ. 15‏:‏19؛ 18‏:‏12، 24، 25؛ أَعَوذ. 18‏:‏4\x*  
\v 39 ؤُشَا أَذْ يِيڒِي ؤُكهَّانْ، إِجّْ ن مِّيسْ ن هَارُونْ، غَارْ إِلَاوِييّنْ خْمِي غَا طّْفنِيلَاوِييّنْ ڒعْشُورْ. ؤُشَا إِلَاوِييّنْ \add سِيمَانْثْ نْسنْ\add* أَذْ أَوْينْ إِشْثْ ن ثعْشَارْثْ ن ڒعْشُورْ غَارْ ثَادَّارْثْ ن أَربِّي، غَارْ إِخَّامنْ ن ثَادَّارْثْ ن ثْخُوبَايْ، \f ◼ \fr 10:‏39 \ft \+bd ’ثِيخُوبَايْ‘\+bd* - نِيغْ ’ڒكْنُوزْ‘.\f*  \x ◘ \xo 10:‏39 \xt ڒخْڒ. 18‏:‏26\x*  
\v 40 مِينْزِي أَيْثْ ن إِسْرَائِيل ذ أَيْثْ ن لَاوِي أَذْ أَوْينْ ثَاوْهِيبْثْ ن ؤُسْڭعّذْ ن ڒْحبّْ \add ن يِيرْذنْ\add*، ڒَا ن بِينُو ن جْذِيذْ ؤُڒَا ن زّشْثْ ذڭْ إِخَّامنْ \add إِ ڒخْزنْ\add*. مَاغَارْ ڒقْشُوعْ ن زَّاوشْثْ إِقدّْسنْ أَقَا أَثنْ ذِينْ، ؤُڒَا ذ إِكهَّاننْ نِّي إِتّْسخَّارنْ ذ إِعسَّاسنْ ن ثوُّورَا ذ إِمذْيَازنْ. إِتّْخصَّا أَنغْ وَارْ نْسمّحْ شَا ذِي ثَادَّارْثْ ن أَربِّي نّغْ.   
\b  
\b  
\m  
\c 11
\s1 إِمزْذَاغْ ن جْذِيذْ ن ؤُرْشَالِيمْ ؤُ ن ثْندَّامْ إِقِّيمنْ  
\m
\v 1 ڒْحُوكَّامْ ن ڒْڭنْسْ قِّيمنْ زدّْغنْ ذِي ؤُرْشَالِيمْ، \add ؤُمِي\add* ڒْڭنْسْ إِقِّيمنْ إِڭَّا ثَاقدُّوحْثْ مَاحنْذْ إِجّْ زِيعشْرَا أَذْ إِزْذغْ ذِي ؤُرْشَالِيمْ، ثَانْذِينْثْ إِقدّْسنْ، ؤُ ثسْعَا ذِي ثْندَّامْ نّغْنِي.  
\v 2 إِبَاركْ ڒْڭنْسْ مَارَّا إِرْيَازنْ نِّي إِقدّْمنْ إِخفْ نْسنْ س ڒْخَاضَارْ مَاحنْذْ أَذْ زذْغنْ ذِي ؤُرْشَالِيمْ.   
\m
\v 3 \bd إِنَا ذ إِزدْجِيفنْ ن لْعَامَالَا، إِنِّي ثُوغَا إِزدّْغنْ ذِي ؤُرْشَالِيمْ.\bd* ثُوغَا زدّْغنْ \add أَيْثْ ن\add* إِسْرَائِيل، إِكهَّاننْ ذ إِلَاوِييّنْ ذ إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ ذ أَيْثْ ن إِسمْغَانْ ن سُولِيمَانْ ذِي ثْندَّامْ ن يَاهُوذَا، كُوڒْ إِجّْ ذڭْ وَاڭْڒَا نّسْ، ذِي ثْندَّامْ نْسنْ.  
\v 4 ذِي ؤُرْشَالِيمْ ثُوغَا زدّْغنْ شَا زڭْ أَيْثْ ن يَاهُوذَا ؤُ زڭْ أَيْثْ ن بِينْيَامِينْ.  
\m \bd زڭْ أَيْثْ ن يَاهُوذَا\bd*: عَاثَايَا، مِّيسْ ن عُوزِّييَا، مِّيسْ ن زَاكَارِييَّا، مِّيسْ ن أَمَارْيَا، مِّيسْ ن شَافَاطْيَا، مِّيسْ ن مَاهَالَالْ-إِلْ، زڭْ أَيْثْ ن فَارِيصْ،  
\v 5 ؤُڒَا ذ مَاعَاسِييَا، مِّيسْ ن بَارُوخْ، مِّيسْ ن كُولْحُوزَا، مِّيسْ ن حَازَايَا، مِّيسْ ن عَاذَايَا، مِّيسْ ن يُويَارِيبْ، مِّيسْ ن زَاكَارِييَّا، مِّيسْ ن ؤُشِيلُونِي. \f ◼ \fr 11:‏5 \ft \+bd ’أَشِيلُونِي‘\+bd* - إِجّْ ن ورْيَازْ زِي ثنْذِينْثْ ن شِيلُو.\f*  
\v 6 مَارَّا أَيْثْ ن فَارِيصْ إِنِّي إِزدّْغنْ ذِي ؤُرْشَالِيمْ، \add أَقَا أَثنْ\add* أَربْعَا-مْيَا ؤُ-ثْمنْيَا ؤُ-ستِّينْ ن إِعسْكَارِييّنْ.   
\m
\v 7 إِنَا ذ \bd أَيْثْ ن بِينْيَامِينْ\bd*: سَالُّو، مِّيسْ ن مَاشُولَّامْ، مِّيسْ ن يُوعِيذْ، مِّيسْ ن فَاذَايَا، مِّيسْ ن قُولَايَا، مِّيسْ ن مَاعَاسِييَا، مِّيسْ ن إِثِييِيلْ، مِّيسْ ن إِشَاعْيَا  
\v 8 ؤُ أَوَارْنِي أَسْ جَابَّايْ، سَالَّايْ: ثسْعَا-مْيَا ؤُ-ثْمنْيَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 9 ثُوغَا يُووِيلْ، مِّيسْ ن زِيكْرِي، ذ أَوقَّافْ خَاسنْ ؤُ يَاهُوذَا، مِّيسْ ن هَاسْنُووَا ثُوغَا ذ \add أَمحْضَايْ\add* وِيسّْ ثْنَاينْ خْ ثنْذِينْثْ.   
\b  
\m
\v 10 \bd زڭْ إِكهَّاننْ\bd*: يَاذَاعْيَا، مِّيسْ ن يُويَارِيبْ، يَاكِينْ،  
\v 11 سَارَايَا، مِّيسْ ن حِيلْقِييَا، مِّيسْ ن مَاشُولَّامْ، مِّيسْ ن صَاذُوقْ، مِّيسْ ن مَارَايُوثْ، مِّيسْ ن أَخِيطُوبْ، أَمحْضَايْ ن ثَادَّارْثْ ن أَربِّي،  
\v 12 ؤُشَا أَيْثْمَاثْسنْ، إِنِّي إِخدّْمنْ ذِي ثَادَّارْثْ، \add مَارَّا إِذْسنْ\add* ثمْنْ-مْيَا ؤُ-ثْنَاينْ ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*. \add خنِّي\add* عَاذَايَا، مِّيسْ ن يَارُوحَامْ، مِّيسْ ن فَالَالْيَا، مِّيسْ ن أَمْصِي، مِّيسْ ن زَاكَارِييَّا، مِّيسْ ن فَاشْحُورْ، مِّيسْ ن مَالْكِييَا،  
\v 13 ذ أَيْثْمَاسْ، إِزدْجِيفنْ ن ڒَادْجَاثْ، مَارَّا إِذْسنْ مِيثَاينْ ؤُ-ثْنَاينْ ؤُ-ربْعِينْ \add ن يرْيَازنْ\add*. \add خنِّي\add* أَمْشِيسَايْ، مِّيسْ ن عَازَارْيِيلْ، مِّيسْ ن أَخْزَايْ، مِّيسْ ن مَاشْلِيمُوثْ، مِّيسْ ن إِمِّيرْ  
\v 14 ذ أَيْثْمَاثْسنْ، أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ، مَارَّا إِذْسنْ مْيَا ؤُ-ثْمنْيَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*. ثُوغَا زَابْذِييِيلْ، مِّيسْ ن هَاجْذُولِيمْ، ذ أَوقَّافْ خَاسنْ.   
\m
\v 15 \bd زڭْ إِلَاوِييّنْ\bd*: شَامْعِييَا، مِّيسْ ن حَاشُّوبْ، مِّيسْ ن عَازْرِيقَامْ، مِّيسْ ن حَاشَابْيَا، مِّيسْ ن بُونِّي.  
\v 16 شَابَّاثَايْ ذ يُوزَابَاذْ، أَقَا نِيثْنِي بدّنْ أَكْ-ذ ڒْخذْمثْ ذِي بَارَّا ن ثَادَّارْثْ ن أَربِّي. نِيثْنِي زڭْ إِزدْجِيفنْ ن إِلَاوِييّنْ.  
\v 17 ؤُشَا \add خنِّي\add* مَاتَّانْيَا، مِّيسْ ن مِيخَا، مِّيسْ ن زَابْذِي، مِّيسْ ن أَسَافْ، أَزدْجِيفْ إِ يَارزْمنْ ثَاژَادْجِيثْ س إِشْثْ ن ثْژَادْجِيثْ ن ؤُقَاذِي، ذ بَاقْبُوقْيَا ونِّي ثُوغَا ذ وِيسّْ ثْنَاينْ زڭْ أَيْثْمَاسْ، ؤُ عَابْذَا، مِّيسْ ن شَامُّوعَا، مِّيسْ ن جَالَالْ، مِّيسْ ن يَاذَاثُونْ.  
\v 18 مَارَّا إِلَاوِييّنْ إِ إِدْجَانْ ذِي ثنْذِينْثْ إِقدّْسنْ، \add مَارَّا إِذْسنْ\add*: مِيثَاينْ ؤُ-أَربْعَا ؤُ-ثْمَانِينْ.   
\m
\v 19 \bd إِعسَّاسنْ ن ثوُّورَا\bd*: عَاقُّوبْ، طَالْمُونْ أَكْ-ذ أَيْثْمَاثْسنْ، إِنِّي إِطّْفنْ أَحطُّو ذِي ثوُّورَا \add ن ثنْذِينْثْ\add*، \add مَارَّا إِذْسنْ\add* مْيَا ؤُ-ثْنَاينْ ؤُ-سبْعِينْ.   
\m
\v 20 إِنِّي إِقِّيمنْ ن أَيْثْ إِسْرَائِيل، إِكهَّاننْ ذ إِلَاوِييّنْ، زذْغنْ ذِي ثْندَّامْ ن يَاهُوذَا، كُوڒْ إِجّْ ذِي ثسْغَارْثْ نّسْ.   
\m
\v 21 \bd إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ\bd* زذْغنْ ذِي عُوفِيلْ. ثُوغَا صِيحَا ذ جِيشْفَا خْ إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ.   
\m
\v 22 ثُوغَا عُوزِّي، مِّيسْ ن بَانِي، مِّيسْ ن حَاشَابْيَا، مِّيسْ ن مَاتَّانْيَا، مِّيسْ ن مِيخَا ذ أَوقَّافْ ن إِلَاوِييّنْ ذِي ؤُرْشَالِيمْ.  
\m زڭْ أَيْثْ ن أَسَافْ ثُوغَا إِمذْيَازنْ خْ ڒْخذْمثْ ذِي ثَادَّارْثْ ن أَربِّي. \f ◼ \fr 11:‏22 \ft \+bd ’إِمذْيَازنْ‘\+bd* - نِيغْ ’إِمغْنُوجنْ‘.\f*  
\v 23 مَاغَارْ ثُوغَا ذِينْ خَاسنْ إِشْثْ ن ثوْصيّثْ ن ؤُجدْجِيذْ ؤُ خْ إِمذْيَازنْ \add ثُوغَا ذِينْ\add* إِجّْ ن وقَّانْ، كُوڒْ أَسّْ إِشْثْ ن ثوْصيّثْ \add إِ إِتّْڒِيقنْ\add* إِ وَاسّْ نِّي. \f ◼ \fr 11:‏23 \ft \+bd ’إِشْثْ ن ثوْصِييّثْ‘\+bd* - س ثِيعْبْرَانِيثْ ’إِجّْ ن وَاوَاڒْ‘.\f*   
\m
\v 24 ثُوغَا فَاطَاحْيَا، مِّيسْ ن مَاشِيزَابْيِيلْ، زڭْ أَيْثْ ن زَارَاحْ، مِّيسْ ن يَاهُوذَا، ذ أَفُوسْ أَفُوسِي ن ؤُجدْجِيذْ ذِي مَارَّا مِينْ إِڒقّْفنْ ڒْڭنْسْ.   
\b  
\m
\v 25 \bd ذِي ذْشُورَاثْ\bd* غَارْ إِيَّارنْ نْسنْ ثُوغَا ذِينْ شَا \bd زڭْ أَيْثْ ن يَاهُوذَا\bd* إِنِّي ثُوغَا إِزدّْغنْ ذِي قَارْيَاثْ-أَربْعَا ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ ؤُ ذِي ذِيبُّونْ ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ ؤُ ذِي يَاقَابْصِييِيلْ ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ  
\v 26 ؤُ ذِي يشُوعَا ؤُ ذِي مُولَاذَا ؤُ ذِي بَايْثْ-فَالَاطْ  
\v 27 ؤُ ذِي هَاصَارْ-شُوعَالْ ؤُ ذِي بِئرْ-سبْعَا ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ،  
\v 28 ؤُ ذِي صِيقْلَاغْ ؤُ ذِي مَاكُونَا ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ  
\v 29 ؤُ ذِي عَايْنْ-رِيمُّونْ ؤُ ذِي صَارْعَا ؤُ ذِي يَارْمُوثْ،  
\v 30 زَانُوحَا، أَذُولَّامْ ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ، لَاخِيشْ ذ إِيَّارنْ نّسْ، عَازِيقَّا ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ. نِيثْنِي وْثِينْ إِقِيضَانْ نْسنْ زِي بِئرْ-سبْعَا أَڒْ ثَاغْزُورْثْ ن هِينُّومْ.   
\m
\v 31 ثُوغَا \bd أَيْثْ ن بِينْيَامِينْ\bd* زدّْغنْ زِي جَابَاعْ ذِي مِيخْمَاسْ ذ عَايَا ذ بَايْثْ-إِلْ ذ ثْندَّامْ إِ غَارْسنْ د-إِقّْننْ،  
\v 32 عَانَاثُوثْ، نُوبْ، عَانَانْيَا،  
\v 33 هَاصُورْ، رَامَا، جِيتَّايِيمْ،  
\v 34 حَاذِيذْ، صابُوعِيمْ، نَابَالَّاطْ،  
\v 35 لُوذْ ذ ؤُنُو \add ذ\add* ثغْزُورْثْ ن ثغْزُورْثْ ن إِحْرَايْفِييّنْ.   
\m
\v 36 \bd زڭْ إِلَاوِييّنْ\bd* \add زذْغنْ ذِينْ\add* ثرْبِيحِينْ زِي يَاهُوذَا غَارْ بِينْيَامِينْ.   
\b  
\b  
\m  
\c 12
\s1 لِيسْثَا ن إِكهَّاننْ ذ إِلَاوِييّنْ  
\m
\v 1 إِنَا ذ إِكهَّاننْ ذ إِلَاوِييّنْ إِنِّي د-إِڭعّْذنْ أَكْ-ذ زَارُوبَابِّيلْ، مِّيسْ ن شَاعَالْثِييِيلْ، ذ يَاهُوشَاعْ: سَارَايَا، إِرْمِييَا، عِيزْرَا،  
\v 2 أَمَارْيَا، مَالُّوخْ، حَاطُّوشْ،  
\v 3 شَاكَانْيَا، رَاحُومْ، مَارِيمُوثْ،  
\v 4 عِيدُّو، جِينِّيثُويْ، أَبِييَا،  
\v 5 مِييَامِينْ، مَاعَاذْيَا، بِيلْجَا،  
\v 6 شَامْعِييَا، يُويَارِيبْ، يَاذَاعْيَا،  
\v 7 سَالُّو، عَامُوقْ، حِيلْقِييَا ذ يَاذْعَايَا. إِنَا ذ إِزدْجِيفنْ ن إِكهَّاننْ ذ أَيْثْمَاسْ ذڭْ وُوسَّانْ ن يَاهُوشَاعْ.   
\m
\v 8 ؤُشَا إِلَاوِييّنْ \add ذ إِنَا\add*: يشُوعَا، بِينُّويْ، قَاذْمِييِيلْ، شَارَابْيَا، يَاهُوذَا ذ مَاتَّانْيَا، \add ونِّي\add* إِدْجَانْ خْ إِزْڒَانْ ن ؤُقَاذِي، \add جْمِيعْ\add* أَكْ-ذ أَيْثْمَاسْ.  
\v 9 بَاقْبُوقْيَا ذ عُونِّي، أَيْثْمَاثْسنْ، ثُوغَا حطَّانْ أَرنْذَاذْ نْسنْ.   
\b  
\m
\v 10 يشُوعَا إِجَّا-د يُويَاقِيمْ، ؤُ يُويَاقِيمْ إِجَّا-د إِلْيَاشِيبْ، ؤُ إِلْيَاشِيبْ إِجَّا-د يُويَاذَاعْ،  
\v 11 ؤُ يُويَاذَاعْ إِجَّا-د يُونَاثَانْ، ؤُ يُونَاثَانْ إِجَّا-د يَادُّوعْ.   
\b  
\m
\v 12 ذڭْ وُوسَّانْ ن يُويَاقِيمْ ثُوغَا ذ إِزدْجِيفنْ-أَ ن \add ڒَْادْجَاثْ ن\add* إِبَابَاثنْ ذ إِكهَّاننْ:  
\m إِ \add ڒَْادْجَاثْ ن\add* سَارَايَا: مَارَايَا،  
\m إِ \add ڒَْادْجَاثْ ن\add* إِرْمِييَا: حَانَانْيَا،   
\m
\v 13 إِ \add ڒَْادْجَاثْ ن\add* عِيزْرَا: مَاشُولَّامْ،  
\m إِ \add ڒَْادْجَاثْ ن\add* أَمَارْيَا: يُوحَانَانْ،   
\m
\v 14 إِ \add ڒَْادْجَاثْ ن\add* مَالِيكُو: يُونَاثَانْ،  
\m إِ \add ڒَْادْجَاثْ ن\add* شَابِينْيَا: يُوسُوفْ،   
\m
\v 15 إِ \add ڒَْادْجَاثْ ن\add* حَارِيمْ: عَاذْنَا،  
\m إِ \add ڒَْادْجَاثْ ن\add* مَارَايُوثْ: حِيلْقَايْ،   
\m
\v 16 إِ \add ڒَْادْجَاثْ ن\add* عِيدُّو: زَاكَارِييَّا،  
\m إِ \add ڒَْادْجَاثْ ن\add* جِينِّيثُونْ: مَاشُولَّامْ،   
\m
\v 17 إِ \add ڒَْادْجَاثْ ن\add* أَبِييَا: زِيكْرِي،  
\m إِ \add ڒَْادْجَاثْ ن\add* مِينْيَامِينْ ذ مُوعَاذْيَا: فِيلْطَايْ،   
\m
\v 18 إِ \add ڒَْادْجَاثْ ن\add* بِيلْجَا: شَامُّوعَا،  
\m إِ \add ڒَْادْجَاثْ ن\add* شَامْعِييَا: يُونَاثَانْ،   
\m
\v 19 إِ \add ڒَْادْجَاثْ ن\add* يُويَارِيبْ: مَاتَّانَايْ،  
\m إِ \add ڒَْادْجَاثْ ن\add* عُوزِّي: يَاذَاعْيَا،   
\m
\v 20 إِ \add ڒَْادْجَاثْ ن\add* سَالَّايْ: قَالَّايْ،  
\m إِ \add ڒَْادْجَاثْ ن\add* عَامُوقْ: عَابِيرْ،   
\m
\v 21 إِ \add ڒَْادْجَاثْ ن\add* حِيلْقِييَا: حَاشَابْيَا  
\m ؤُ إِ \add ڒَْادْجَاثْ ن\add* يَاذَاعْيَا: نَاثَانَايِيلْ.   
\m
\v 22 ذڭْ وُوسَّانْ ن إِلْيَاسِيبْ، يُويَاذَاعْ، يُوحَانَانْ ذ يَادُّوعْ، تّْوَازمّمنْ إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* ن إِلَاوِييّنْ ؤُڒَا ذ إِكهَّاننْ أَڒْ ثَاڭلْذَا ن ذَارِييُوسْ، أَفَارْسِي.  
\v 23 تّْوَازمّمنْ أَيْثْ ن لَاوِي، إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add*، ذڭْ وذْلِيسْ ن إِمزْرُوينْ أَڒْ ؤُسَّانْ ن يُوحَانَانْ، مِّيسْ ن إِلْيَاشِيبْ. \x ◘ \xo 12:‏23 \xt 1 إِم. 9‏:‏10‏-‏34\x*   
\m
\v 24 إِزدْجِيفنْ ن إِلَاوِييّنْ ثُوغَا حَاشَابْيَا، شَارَابْيَا ذ يشُوعَا، مِّيسْ ن قَاذْمِييِيلْ، ؤُ أَيْثْمَاثْسنْ \add بدّنْ\add* أَجمَّاضِينْ نْسنْ حِيمَا أَذْ سّمْغَارنْ ؤُ أَذْ قَاذَانْ، أَمْ مَامّشْ ثُوغَا ثدْجَا ثوْصيّثْ ن ذَاوُوذْ، أَرْيَازْ ن أَربِّي. إِجّْ ثُوغَا إِحطَّانْ أَرنْذَاذْ ن ونّغْنِي إِ ثُوغَا إِحطَّانْ.   
\m
\v 25 ثُوغَا مَاتَّانْيَا، بَاقْبُوقْيَا، عُوبَاذْيَا، مَاشُولَّامْ، طَالْمُومْ ذ عَاقُّوبْ إِعسَّاسنْ ن ثوَّارْثْ إِنِّي إِعسّنْ خْ إِخَّامنْ ن ڒخْزنْ ن ثوُّورَا \add ن ثنْذِينْثْ\add*. \f ◼ \fr 12:‏25 \ft \+bd ’ڒهْرِيثْ‘\+bd* - نِيغْ ’إِخَّامنْ ن ؤُخمّڒْ‘.\f*  
\v 26 إِنَا ثُوغَا أَثنْ ذڭْ وُوسَّانْ ن يُويَاقِيمْ، مِّيسْ ن يَاهُوشَاعْ مِّيسْ ن يُوصَاذَاقْ، ؤُڒَا ذڭْ وُوسَّانْ ن نَاحَامْيَا، لْوَالِي، ؤُ ن ؤُكهَّانْ عِيزْرَا، أَمْسڒْمذْ ن إِذْلِيسنْ.   
\b  
\m  
\s1 أَذشّنْ ن ڒْحِيضْ ن ؤُرْشَالِيمْ  
\m
\v 27 غَارْ ؤُذشّنْ ن ڒْحِيضْ ن ؤُرْشَالِيمْ أَرْزُونْ نِيثْنِي خْ إِلَاوِييّنْ ذِي مَارَّا إِمُوشَانْ نْسنْ مَاحنْذْ أَذْ ثنْ أَوْينْ غَارْ ؤُرْشَالِيمْ حِيمَا نِيثْنِي أَذْ سّْقفْڒنْ أَذشّنْ، أَذْ ڭّنْ ڒفْرَاحثْ س ؤُقَاذِي ؤُ س يزْڒَانْ، س ثدْجُونِينْ ن وُوزَّاڒْ، س لهَارْپَاثْ ذ ڒْڭَامْبْرِييَاثْ.  
\v 28 نِيثْنِي سّْمُوننْ خْ أَيْثْ ن إِمذْيَازنْ زڭْ ؤُذوَّارْ ن ؤُرْشَالِيمْ ؤُ زِي ذْشُورَاثْ ن ؤُنَاطُوفَاثِي،  
\v 29 ؤُ زِي بَايْثْ-جِيلْجَالْ ؤُڒَا زڭْ إِيَّارنْ ن جِيبَا ذ عَازْمَاوثْ، مِينْزِي إِمذْيَازنْ بْنَانْ إِ يِيخفْ نْسنْ ذْشُورَاثْ إِ د-إِنّْضنْ إِ ؤُرْشَالِيمْ.  
\v 30 سِّيزذْڭنْ إِكهَّاننْ ذ إِلَاوِييّنْ إِخفْ نْسنْ ؤُشَا أَوَارْنِي إِ ؤُيَا سِّيزذْڭنْ نِيثْنِي ؤُڒَا ذ ڒْڭنْسْ ذ ثوُّورَا ذ ڒْحِيضْ.   
\m
\v 31 \add خنِّي\add* ڭِّيغْ ڒْحُوكَّامْ ن يَاهُوذَا أَذْ نْينْ خْ ڒْحِيضْ ؤُ سّْبدّغْ ثْنَاينْ ن ثرْبِيعِينْ ن ؤُغنّجْ إِ ؤُقَاذِي. ثُويُورْ إِشْثْ \add ن ثرْبِيعْثْ\add* غَارْ يفُوسْ سنّجْ خْ ڒْحِيضْ غَارْ ثوَّارْثْ ن ڒغْبَارْ.  
\v 32 يَاردّفْ إِ-ت هُوشَاعْيَا س يِيجّْ ن وزْينْ ن ڒْحُوكَّامْ ن يَاهُوذَا،  
\v 33 عَازَارْيَا، عِيزْرَا، مَاشُولَّامْ،  
\v 34 يَاهُوذَا، بِينْيَامِينْ، شَامْعِييَا ذ إِرْمِييَا،  
\v 35 ؤُ زڭْ أَيْثْ ن إِكهَّاننْ إِنِّي غَارْسنْ ڒبْوَاقْ: زَاكَارِييَّا، مِّيسْ ن يُونَاثَانْ، مِّيسْ ن شَامْعِييَا، مِّيسْ ن مَاتَّانْيَا، مِّيسْ ن مِيخَا-يَاهْ، مِّيسْ ن زَاكُّورْ، مِّيسْ ن أَسَافْ،  
\v 36 ذ أَيْثْمَاسْ شَامْعِييَا ذ عَازَارْيِيلْ، مِيلَالَايْ، جِيلَالَايْ، مَاعَايْ، نَاثَانَايِيلْ ذ يَاهُوذَا، حَانَانِي أَكْ-دُّوزَانْ ن ڒْمُوسِيقَا ن ذَاوُوذْ، أَرْيَازْ ن أَربِّي، ؤُشَا زَّاثْ إِ وُوذمْ نْسنْ ثُوغَا إِڭُّورْ عِيزْرَا، أَمْسڒْمذْ ن إِذْلِيسنْ.  
\v 37 غَارْ ثوَّارْثْ ن ثَاڒَا ؤُشَا \add خنِّي نِيشَانْ\add* قِيبَاتْشْ نْسنْ نْينْ دّْرُوجَّاثْ ن ثنْذِينْثْ ن ذَاوُوذْ مَانِي د-إِڭعّذْ ڒْحِيضْ، تّكّنْ خْ ثَادَّارْثْ ن ذَاوُوذْ أَڒْ ثَاوَّارْثْ ن وَامَانْ، غَارْ شَّارْقْ.   
\m
\v 38 ثَارْبِيحْثْ ن ؤُقَاذِي وِيسّْ ثْنَاينْ ثُويُورْ غَارْ جِّيهثْ نّغْنِيثْ ؤُشَا نشّْ أَردّْفغْ ت أَكْ-ذ وزْينْ \add نّغْنِي\add* ن ڒْڭنْسْ، \add نكَّا\add* خْ ڒْحِيضْ غَارْ ؤُغزْذِيسْ ن لْبُورْجْ ن ثفْقُونْثْ أَڒْ ڒْحِيضْ أَمِيرِيوْ،  
\v 39 ؤُشَا خنِّي \add نكَّا\add* خْ ثوَّارْثْ ن إِفْرَايِيمْ ؤُ خْ ثوَّارْثْ ثَاقْذِيمْثْ ؤُ خْ ثوَّارْثْ ن إِسڒْمَانْ ذ لْبُورْجْ ن حَانَانِييِيلْ ذ لْبُورْجْ ن مْيَا أَڒْ ثَاوَّارْثْ ن وُودْجِي ؤُشَا نِيثْنِي قِّيمنْ بدّنْ غَارْ ثوَّارْثْ ن ڒحْبسْ.   
\m
\v 40 \add خنِّي\add* بدّنْثْ ثْنَاينْ ن ثرْبِيحِينْ ن ؤُقَاذِي ذِي ثَادَّارْثْ ن أَربِّي، ؤُڒَا ذ نشّْ أَكْ-ذ وزْينْ ن إِمْضبَّارنْ أَكِيذِي.  
\v 41 \add ؤُڒَا\add* ذ إِكهَّاننْ أَلْيَاقِيمْ، مَاعَاسِييَا، مِينْيَامِينْ، مِيخَا-يَاهْ، إِلْيُوعِينَايْ، زَاكَارِييَّا، حَانَانْيَا، إِنِّي غَارْسنْ ڒبْوَاقْ،  
\v 42 ؤُشَا \add خنِّي\add* مَاعَاسِييَا ذ شَامْعِييَا ذ أَلِيعَازَارْ ذ عُوزِّي ذ يُوحَانَانْ ذ مَالْكِييَا ذ عِيلَامْ ذ عَازَارْ. إِمذْيَازنْ ڭِّينْ أَذْ تّْوَاسْڒنْ ؤُ ثُوغَا يِيزْرَاحَا ذ أَوقَّافْ.   
\m
\v 43 ذڭْ وَاسّْ نِّي وهّْبنْ نِيثْنِي أَطَّاسْ ن ثْغَارْصَا ذ ثِيمقّْرَانِينْ. مَارَّا فَارْحنْ، مَاغَارْ أَربِّي إِڭَّا أَسنْ إِشْثْ ن ڒفْرَاحثْ ذ ثَامقّْرَانْثْ. فَارْحنْ ؤُڒَا ذ ثِيمْغَارِينْ ذ إِحنْجِيرنْ إِمژْيَاننْ أَڒَامِي ڒفْرَاحثْ \add ن ڒْعِيذْ\add* ن ؤُرْشَالِيمْ ثُوغَا تّسْڒَانْ أَسْ زِي ڒَاڭّْوَاجْ.   
\b  
\m  
\s1 ثَايْنِيثْ ذِي طّْوعْ ن ثوْهِيبِينْ عْلَاحْسَابْ شَّارِيعَا ن مُوسَا  
\m
\v 44 ذڭْ وُوسَّانْ نِّي ڭِّينْ إِرْيَازنْ أَذْ إِڒِينْ خْ إِخَّامنْ \add إِ إِدْجَانْ\add* إِ ثْخُوبَايْ، إِ ثوْهِيبِينْ ن ؤُسْڭعّذْ، إِ ؤُسُوفُّوغْ ثَامزْوَارُوثْ \add ن صَّابثْ\add* ؤُ إِ ڒعْشُورْ، حِيمَا أَذْ ذَايْسنْثْ يَارْونْ ثِيسقَّارْ إِ د-إِكَّارنْ إِ إِكهَّاننْ ذ إِلَاوِييّنْ زڭْ إِيَّارنْ ن ثْندَّامْ عْلَاحْسَابْ شَّارِيعَا، مَاغَارْ فَارْحنْ \add أَيْثْ ن\add* يَاهُوذَا زڭْ إِكهَّاننْ ذ إِلَاوِييّنْ نِّي إِ ذِينْ إِبدّنْ \f ◼ \fr 12:‏44 \ft \+bd ’ثِيخُوبَايْ‘\+bd* - نِيغْ ’ڒكْنُوزْ‘.\f*  
\v 45 ؤُ حْضَانْ خْ ثْسخَّارْثْ ن أَربِّي نْسنْ ؤُ خْ ثْسخَّارْثْ ن ؤُسِيزْذڭْ، \add جْمِيعْ\add* أَكْ-ذ إِمذْيَازنْ ذ إِعسَّاسنْ ن ثوُّورَا، عْلَاحْسَابْ ثَاوْصيّثْ ن ذَاوُوذْ ذ مِّيسْ سُولِيمَانْ. \x ◘ \xo 12:‏45 \xt 1 إِم. 25\x*  
\v 46 مَاغَارْ زِيشْ، ذڭْ وُوسَّانْ ن ذَاوُوذْ ذ أَذَافْ، \add ثُوغَا\add* ذِينْ إِجّْ ن إِزدْجِيفنْ ن إِمذْيَازنْ إِ إِزْڒَانْ ن ؤُصبّحْ ؤُڒَا إِ ؤُقَاذِي إِ أَربِّي.  
\v 47 \add س ؤُيَا\add* إِوْشَا مَارَّا إِسْرَائِيل ذِي مَارَّا ؤُسَّانْ ن زَارُوبَّابِيلْ ؤُ ذڭْ وُوسَّانْ ن نَاحَامْيَا ثِيسقَّارْ ن إِمذْيَازنْ ذ إِعسَّاسنْ ن ثوُّورَا، كُوڒْ ثَاسْغَارْثْ ن إِجّْ ن وَاسّْ ذڭْ وَاسّْ نّسْ، ؤُشَا سّْقدّْسنْ ت إِ إِلَاوِييّنْ ؤُشَا إِلَاوِييّنْ سّْقدّْسنْ ت إِ وَارَّاوْ ن هَارُونْ.   
\b  
\b  
\m  
\c 13
\s1 أَشْضَارْ ن نَاحَامْيَا ذِي طّْوعْ ن شَّارِيعَا  
\m
\v 1 ذڭْ وَاسّْ نِّي غْرِينْ ذڭْ إِمزُّوغنْ ن ڒْڭنْسْ زڭْ وذْلِيسْ ن مُوسَا ؤُشَا إِتّْوَافْ أَقَا ثُورَا ذَايسْ بلِّي إِجّْ ن ؤُعَامُّونِي ذ إِجّْ ن ؤُمُو‘أَبِييْعمَّارْصْ وَارْ زمَّارنْ أَذْ أَذْفنْ غَارْ وڭْرَاوْ \add ن ڒْڭنْسْ\add* ن أَربِّي إِ ڒبْذَا، \x ◘ \xo 13:‏1 \xt أَعَوذ. 23‏:‏2، 4، 5\x*  
\v 2 مَاغَارْ نِيثْنِي وَارْ فِّيغنْ غَارْ أَيْثْ ن إِسْرَائِيل س وغْرُومْ ذ وَامَانْ، \add مَاشَا\add* شْرَانْ بِيلْعَامْ ضِيدّْ نْسنْ مَاحنْذْ أَذْ ثنْ إِنْعڒْ ؤُشَا \add خنِّي\add* يَارَّا أَربِّي نّغْ نّعْڒثْ ذ لْبَارَاكَا.\x ◘ \xo 13:‏2 \xt ڒخْڒ. 22‏:‏5؛ ياش. 24‏:‏9\x*  
\v 3 ؤُمِي سْڒِينْ شَّارِيعَا-أَيَا، إِمْسَارْ، أَقَا بْضَانْ خْ إِسْرَائِيل مَارَّا إِنِّي إِخدْجْضنْ زِي ثَاصِيڒثْ.   
\m
\v 4 قْبڒْ إِسّوْجذْ إِلْيَاشِيبْ، أَكهَّانْ، ونِّي ثُوغَا خْ إِخَّامنْ \add إِ ڒخْزنْ\add* ن ثَادَّارْثْ ن أَربِّي نّغْ، ذ ونِّي إِ إِتّعْنَانْ إِ طُوبِييَا،  
\v 5 إِجّْ ن وخَّامْ ذ أَمقّْرَانْ إِ \add ثُوبِييَا\add* مَانِي ثُوغَا \add خمّْڒنْ\add* قْبڒْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*، جَّاوِي ذ ڒقْشُوعْ، ڒعْشُورْ ن ڒْحبّْ \add ن يِيرْذنْ\add*، ذ بِينُو ن جْذِيذْ ذ زّشْثْ نِّي تّْوَاڭّنْ إِ إِلَاوِييّنْ، إِ إِمذْيَازنْ ؤُ إِ إِعسَّاسنْ ن ثوُّورَا، ؤُڒَا ذ ثْغَارْصْثْ ن ؤُسْڭعّذْ ن إِكهَّاننْ.   
\m
\v 6 ذِي مَارَّا مَانْ أَيَا وَارْ ذ أَيِي ثُوغِي شَا ذِي ؤُرْشَالِيمْ، مَاغَارْ ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ ؤُ-ثْڒَاثِينْ ن أَرْثَاحْشَاسْثَا، أَجدْجِيذْ ن بَابِيلْ، ثُوغَاعقْبغْ غَارْ ؤُجدْجِيذْ. أَوَارْنِي \add إِجّْ ن ڒْمِيجَاڒْ ن\add* وُوسَّانْ تَّارغْ زڭْ ؤُجدْجِيذْ تّسْرِيحْ \add مَاحنْذْ أَذْ د -عقْبغْ\add*.  
\v 7 \add ؤُمِي\add* إِوْضغْ غَارْ ؤُرْشَالِيمْ، إِبَانْ-د أَيِي ڒْغَارْ نِّي إِڭَّا إِلْيَاشِيبْ ذِي طّْوعْ ن طُوبِييَا ؤُمِي ذ أَسْ إِسّوْجذْ إِجّْ ن وخَّامْ ذِي ڒمْرَاحَاثْ ن ثَادَّارْثْ ن أَربِّي.  
\v 8 ثُوغَا أَيَا ذ إِشْثْ ن ثْمسْڒَاشْثْ ذ ثَاعفَّانْثْ أَطَّاسْ ذِي ثِيطَّاوِينْ إِنُو ؤُشَا نْضَارغْ مَارَّا ڒقْشُوعْ ن طُوبِييَا زڭْ وخَّامْ غَارْ بَارَّا.  
\v 9 نِّيغْ أَقَا إِتّْخصَّا أَسنْ أَذْ سِّيزذْڭنْ إِخَّامنْ. \add أَوَارْنِي أَسْ\add* أَرِّيغْ ذَايْسنْ ڒقْشُوعْ ن ثَادَّارْثْ ن أَربِّي، ؤُڒَا ذ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذ جَّاوِي.   
\m
\v 10 تّْوَاسَّارْڭْبغْ \add عَاوذْ\add*، أَقَا ثِيسقَّارْ \add إِ د-إِتَّاسنْ\add* إِ إِلَاوِييّنْ وَارْ ذ أَسنْ مّوْشنْثْ أَڒَامِي إِلَاوِييّنْ ذ إِمذْيَازنْ نِّي إِڭِّينْ ڒْخذْمثْ، أَروْڒنْ، كُوڒْ إِجّْ غَارْ ييَّارْ نّسْ.  
\v 11 مّْشُوبّْشغْ أَكْ-ذ إِمْضبَّارنْ، نِّيغْ: ”مَايمِّي ثتّْوَاسْمحْ ثَادَّارْثْ ن أَربِّي؟“ ؤُ نشّْ سّْمُونغْ ثنْ ؤُشَا أَرّغْ ثنْ-إِ-د ذڭْ ومْشَانْ نْسنْ.  
\v 12 \add خنِّي\add* يِيوِي-د مَارَّا يَاهُوذَا ڒعْشُورْ ن ڒْحبّْ \add ن يِيرْذنْ\add* ڒَا ن بِينُو ن جْذِيذْ ؤُڒَا ن زّشْثْ ذڭْ إِخَّامنْ ن ثْخُوبَايْ. \f ◼ \fr 13:‏12 \ft \+bd ’ثِيخُوبَايْ‘\+bd* - نِيغْ ڒكْنُوزْ‘.\f*  
\v 13 ڭِّيغْ إِمقّْرَاننْ خْ إِخَّامنْ ن ثْخُوبَايْ: أَكهَّانْ شَالَامْيَا ذ ؤُمَارِيرْ صَاذُوقْ ذ فَاذَايَا زڭْ إِلَاوِييّنْ ؤُشَا ڭِّيغْ أَسنْ غَارْ ؤُغزْذِيسْ حَانَانْ، مِّيسْ ن زَاكُّورْ، مِّيسْ ن مَاتَّانْيَا، مَاغَارْ ثُوغَا تّْوَاحسْبنْ ذ إِمْثِيقَّانْ. نِيثْنِي خَاسنْ مَاحنْذْ أَذْ بْضَانْ أَيَا إِ أَيْثْمَاثْسنْ.   
\m
\v 14 إِذَارْ أَيِي إِ مَانْ أَيَا، \add أَ\add* أَربِّي إِنُو، ؤُ وَارْ ثْمحِّيذْ ثَامخْسِيوْثْ إِنُو إِشوَّارنْ نِّي سّشْنغْ إِ ثَادَّارْثْ ن أَربِّي إِنُو ؤُ إِ ثْسخَّارْثْ إِ ذَايسْ \add إِدْجَانْ\add*.   
\b  
\m
\v 15 ذڭْ وُوسَّانْ نِّي ژْرِيغْ أَقَا ذِينْ ذِي يَاهُوذَا إِنِّي إِتّْشُوقَانْ ذِي ثْسِيرْثْ ذڭْ \add وَاسّْ ن\add* سّبْثْ ؤُڒَا ذ إِنِّي د-إِوْينْ إِشوَّافنْ ن إِمنْذِي، أَرْبُونْ ثنْ خْ يغْيَاڒْ، ؤُڒَا ذ بِينُو، أَضِيڒْ، ثَازَارْثْ ذ عْڒَامْ كُوڒْ ڒحْمُوڒْ نِّي إِوْينْ ذڭْ وَاسّْ ن سّبْثْ ذِي ؤُرْشَالِيمْ. نشّْعڒْمغْ ثنْ ذڭْ وَاسّْ \add نِّي\add* ؤُمِي ثُوغَا زّْنُوزَانْ مَاشَّا ذڭْ وَاسّْ ن سّبْثْ.  
\v 16 ثُوغَا أَيْثْ ن صُورْ زدّْغنْ ذِينِّي، إِوْينْ-د إِسڒْمَانْ ذ مَارَّا سّڒْعثْ، زّْنُوزَانْ أَيَا ذِي سّبْثْ إِ أَيْثْ ن يَاهُوذَا ؤُ ذِي ؤُرْشَالِيمْ.  
\v 17 عيَّارغْ ثَارْوَا ن ثَاصِيڒثْ ن يَاهُوذَا، نِّيغْ أَسنْ: ”مَانْ ثُوعفّْنَا إِ ثتّڭّمْ إِ زِي ثسّْعِيدْجْثمْ أَسّْ ن سّبْثْ! \x ◘ \xo 13:‏17 \xt ؤُف. 20‏:‏8؛ لَاوِي 19‏:‏30\x*  
\v 18 مَا وَارْ ڭِّينْ ڒجْذُوذْ نْومْ أَمنِّي ؤُشَا \add خنِّي\add* مَا وَارْ د-إِسِّيوضْ أَربِّي نّغْ مَارَّا ڒْغَارْ-أَ خَانغْ ؤُ خْ ثنْذِينْثْ-أَ؟ ؤُ كنِّيوْ ثَارنِّيمْ \add عَاذْ\add* ذِي ڒْحَاذُوقْ \add ن وغْضَابْ نّسْ\add* خْ إِسْرَائِيل ؤُمِي ثسّْعِيدْجْثمْ سّبْثْ.“   
\m
\v 19 ؤُشَا إِمْسَارْ خْمِي د غَا ثوْضَا ثَادْجسْثْ ذِي ثوُّورَا ن ؤُرْشَالِيمْ، قْبڒْ مَا أَذْ د-يَاوضْ سّبْثْ، أَقَا نِّيغْ أَذْ تّْوَابلّْعنْثْ ثوُّورَا ؤُشَا أَرْنِيغْ نِّيغْ أَذْ ثنْثْ أَرْزْمنْ أَوَارْنِي إِ سّبْثْ وَاهَا. ؤُشَا سّْبدّغْ إِمْسخَّارنْ إِنُو غَارْ ثوُّورَا، مَاحنْذْ وَارْ سِّيذِيفنْ ؤُڒَا ذ إِجّْ ن ڒحْمڒْ ذڭْ وَاسّْ ن سّبْثْ.  
\v 20 ؤُشَا أَمُّو إِسّنْسنْ إِسبَّابنْ ذ إِمْزنْزَانْ ن عْڒَامْ كُوڒْ سّڒْعثْ \add عَاذْ\add* إِشْثْ نِيغْ ثْنَاينْ ن ثْوَاڒَاوِينْ بَارَّا زَّاثْ إِ \add ڒحْيُوضْ ن\add* ؤُرْشَالِيمْ.  
\v 21 ؤُشَا شهْذغْ خَاسنْ، نِّيغْ أَسنْ: ”مَايمِّي ثتّْنُوسَامْ كنِّيوْ خْ ؤُغزْذِيسْ ن ڒْحِيضْ؟ مَاڒَا كنِّيوْ ثڭِّيمْ ث ثْوَاڒَا نّغْنِيثْ، أَذْ خَاومْ وْثغْ أَفُوسْ.“ سّنِّي وَارْ د-ؤُسِينْ عَاذْ ذِي سّبْثْ.   
\m
\v 22 نِّيغْ \add عَاوذْ\add* إِ إِلَاوِييّنْ أَذْ سِّيزْذڭنْ إِخفْ نْسنْ، أَذْ بدّنْ ذ إِعسَّاسنْ غَارْ ثوُّورَا \add ن ثنْذِينْثْ\add*، مَاحنْذْ أَذْ قدّْسنْ أَسّْ ن سّبْثْ.  
\b  
\m ؤُڒَا إِ ؤُيَا إِذَارْ أَيِي، أَربِّي إِنُو،  
\m ؤُ حِينّْ خَافِي  
\m عْلَاحْسَابْ ڒمْغَارثْ ن ثْمخْسِيوْثْ نّشْ إِشوَّارنْ.   
\b  
\m
\v 23 ذڭْ وُوسَّانْ نِّي ژْرِيغْ عَاوذْ ؤُذَاينْ نِّي إِوْينْ ثِيمْغَارِينْ ن أَشْذُوذْ ذ عَامُّونْ ذ مُوآبَ ؤُشَا سّزْذْغنْ ثنْثْ غَارْسنْ.  
\v 24 أَزْينْ ن إِحنْجِيرنْ نْسنْ سَّاوَاڒنْ س إِڒسْ ن أَشْذُوذْ، وَارْ زمَّارنْ أَذْ سِّيوْڒنْ إِڒسْ ن ثْيَاهُوذشْثْ، مَاشَا كُوڒْ إِجّْ \add ثُوغَا إِسَّاوَاڒْ\add* عْلَاحْسَابْ إِڒسْ نْ كُوڒْ ڒْڭنْسْ. \f ◼ \fr 13:‏24 \ft \+bd ’إِڒسْ‘\+bd* - نِيغْ ’ثُوثْلَايْثْ‘.\f*  
\v 25 عيَّارغْ ثنْ ؤُ نعْڒغْ ثنْ ؤُ وْثِيغْ \add شَا ن\add* يرْيَازنْ زَّايْسنْ، قڒْعغْ أَشُوَّافْ نْسنْ ؤُ جِّيغْ ثنْ أَذْ جَّادْجنْ غَارْ أَربِّي: ”غَارْومْ أَذْ ثوْشمْ ثِيحنْجِيرِينْ نْومْ إِ إِحنْجِيرنْ نْسنْ ؤُ غَارْومْ أَذْ ثَاوْيمْ ثِيحنْجِيرِينْ نْسنْ إِ إِحنْجِيرنْ نْومْ نِيغْ إِ إِخفْ نْومْ \add ذ ثَامْغَارْثْ\add*!“  
\v 26 مَا وَارْ إِخْضِي سُولِيمَانْ، أَجدْجِيذْ ن إِسْرَائِيل، ذِي ثْمسْڒَاشْثْ-أَ؟ ذ مَانْ أَيَا ثُوغَا ؤُمِي وَارْ ذِينْ إِدْجِي ذ أَجدْجِيذْ أَمْ نتَّا جَارْ وَاطَّاسْ ن ڒڭْنُوسْ ؤُشَا ثُوغَا إِتّخْسْ إِ-ث أَربِّي ؤُ أَربِّي إِڭَّا إِ-ث ذ أَجدْجِيذْ خْ مَارَّا إِسْرَائِيل؟ \add وَاخَّا أَمنِّي\add* غَارّنْثْ ث ثمْغَارِينْ ثِيبَارَّانِييِّينْ مَاحنْذْ أَذْ إِخْضَا ؤُڒَا ذ نتَّا. \x ◘ \xo 13:‏26 \xt 1 إِج. 11‏:‏1‏-‏4؛ 1 إِج. 3‏:‏13؛ 2 إِم. 1‏:‏12\x*  
\v 27 مَا خنِّي أَذْ غَارْومْ نْسڒْ \add عَاذْ كْثَارْ\add* ؤُمِي ثتّڭّمْ مَارَّا ڒْغَارْ-أَ أَمقّْرَانْ ؤُ ثْغدَّارمْ أَربِّي ؤُشَا ثِيوْيمْ ثِيمْغَارِينْ ثِيبَارَّانِييِّينْ مَاحنْذْ أَذْ كِيذْومْ زدّْغنْثْ؟   
\m
\v 28 إِجّنْ زڭْ إِحنْجِيرنْ ن يُويَاذَاعْ، مِّيسْ ن إِلْيَاشِيبْ، أَرَّايْسْ ن إِكهَّاننْ ثُوغَا ذ أَضڭّْوَاڒْ ن سَانْبَالَّاطْ زِي حُورُونْ. س ؤُيَا ؤُژّْڒغْ خَاسْ زِي غَارِي   
\m
\v 29 إِذَارْ أَسنْ، أَ أَربِّي إِنُو، مِينْزِي نِيثْنِي سّْخمْجنْ ثُوكهَّانْثْ، \add ڒْخذْمثْ ن إِكهَّاننْ\add*، ذ ڒْعَاهْذْ ن ثُوكهَّانْثْ ؤُ ن إِلَاوِييّنْ.   
\m
\v 30 ؤُ نشّْ سِّيزذْڭغْ ثنْ زِي مَارَّا مِينْ ثُوغَا ذ ڒْغِيبْ، ؤُشَا أَرشّْحغْ أَحطُّو ن إِكهَّاننْ ؤُ ن إِلَاوِييّنْ، كُوڒْ إِجّْ ذِي ثْسخَّارْثْ نّسْ.  
\v 31 \add أَمُّو إِ ڭِّيغْ\add* ؤُڒَا إِ ثوْهِيبْثْ ن ؤُكشُّوضْ، ذِي ڒْوقْثْ نّسْ إِتّْوَاڭّنْ، ؤُ إِ ثْمنْزُوثْ \add ن صَّابثْ\add*. إِذَارْ أَيِي، \add أَ\add* أَربِّي إِنُو، إِ ڒْخَارْ.   