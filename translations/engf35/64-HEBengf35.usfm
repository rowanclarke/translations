\v 12 \w therefore|strong="G1352"\w* \w Jesus|strong="G2424"\w* \w also|strong="G2532"\w*, \w so|strong="G2443"\w* \w that|strong="G2443"\w* \w He|strong="G2532"\w* \w might|strong="G2532"\w* sanctify \w the|strong="G2532"\w* \w people|strong="G2992"\w* \w by|strong="G1223"\w* \w His|strong="G1223"\w* \w own|strong="G2398"\w* blood, \w suffered|strong="G3958"\w* \w outside|strong="G1854"\w* \w the|strong="G2532"\w* city \w gate|strong="G4439"\w*.
\v 13 \w So|strong="G4314"\w* \w then|strong="G5106"\w*, let us \w go|strong="G1831"\w* \w out|strong="G1831"\w* \w to|strong="G4314"\w* \w Him|strong="G3588"\w*, \w outside|strong="G1854"\w* \w the|strong="G4314"\w* \w camp|strong="G3925"\w*, \w bearing|strong="G5342"\w* \w His|strong="G4314"\w* \w disgrace|strong="G3680"\w*;\f + \fr 13:13 \ft Persecuted Christians in China and elsewhere know all about this, but many in North America have had such an easy time of it that they have ‘forgotten’ this aspect of the Gospel. But their turn is coming—in Canada, if you speak out against homosexuality you go to jail, for instance.\f*
\v 14 \w because|strong="G1063"\w* \nd \w here|strong="G5602"\w*\nd* \w we|strong="G1063"\w* \w do|strong="G2192"\w* \w not|strong="G3756"\w* \w have|strong="G2192"\w* \w a|strong="G2192"\w* permanent \w city|strong="G4172"\w*, \w but|strong="G1063"\w* \w we|strong="G1063"\w* \w seek|strong="G1934"\w* \w the|strong="G3588"\w* \w coming|strong="G3195"\w* \w one|strong="G3588"\w*.
\p 
\v 15 \w Through|strong="G1223"\w* \w Him|strong="G3588"\w* \w therefore|strong="G3767"\w*, \w at|strong="G1223"\w* \w all|strong="G3956"\w* times, \w let|strong="G1510"\w* us offer up \w a|strong="G1510"\w* \w sacrifice|strong="G2378"\w* \w of|strong="G1223"\w* praise \w to|strong="G2316"\w* \w God|strong="G2316"\w*\f + \fr 13:15 \ft To praise God when everything is fine is no “sacrifice”, so I suppose that the reference is to doing so when we are hurting, perplexed, not understanding.\f*—\w the|strong="G3956"\w* \w fruit|strong="G2590"\w* \w of|strong="G1223"\w* \w lips|strong="G5491"\w* \w that|strong="G3588"\w* identify \w with|strong="G1223"\w* \w His|strong="G3956"\w* \w name|strong="G3686"\w*.
\v 16 (\w But|strong="G1161"\w* \w do|strong="G2532"\w* \w not|strong="G3361"\w* \w forget|strong="G1950"\w* \w to|strong="G2532"\w* \w do|strong="G2532"\w* \w good|strong="G2140"\w* \w and|strong="G2532"\w* \w to|strong="G2532"\w* \w share|strong="G2842"\w*, \w for|strong="G1063"\w* \w with|strong="G2532"\w* \w such|strong="G5108"\w* \w sacrifices|strong="G2378"\w* \w God|strong="G2316"\w* \w is|strong="G3588"\w* \w pleased|strong="G2100"\w*.)
\s1 Concluding remarks
\p 
\v 17 \w Obey|strong="G3982"\w* \w your|strong="G2532"\w* \w leaders|strong="G2233"\w* \w and|strong="G2532"\w* \w submit|strong="G5226"\w*, \w for|strong="G1063"\w* \w they|strong="G2532"\w* \w keep|strong="G4160"\w* watch \w over|strong="G5228"\w* \w your|strong="G2532"\w* \w souls|strong="G5590"\w*, \w as|strong="G5613"\w* \w those|strong="G3588"\w* \w who|strong="G3588"\w* \w must|strong="G4160"\w* \w give|strong="G4160"\w* \w account|strong="G3056"\w*, \w so|strong="G2443"\w* \w that|strong="G2443"\w* \w they|strong="G2532"\w* \w may|strong="G2532"\w* \w do|strong="G4160"\w* \w it|strong="G2532"\w* \w with|strong="G3326"\w* \w joy|strong="G5479"\w* \w and|strong="G2532"\w* \w not|strong="G3361"\w* sighing (\w which|strong="G3588"\w* \w would|strong="G2532"\w* \w be|strong="G2532"\w* unprofitable \w for|strong="G1063"\w* \w you|strong="G5210"\w*).
\p 
\v 18 \w Pray|strong="G4336"\w* \w for|strong="G1063"\w* \w us|strong="G2249"\w*; \w for|strong="G1063"\w* \w we|strong="G2249"\w* \w are|strong="G3956"\w* \w confident|strong="G3982"\w* \w that|strong="G3754"\w* \w we|strong="G2249"\w* \w have|strong="G2192"\w* \w a|strong="G2192"\w* \w good|strong="G2570"\w* \w conscience|strong="G4893"\w*, \w desiring|strong="G2309"\w* \w to|strong="G2309"\w* \w live|strong="G2192"\w* \w commendably|strong="G2573"\w* \w in|strong="G1722"\w* \w all|strong="G3956"\w* \w things|strong="G3956"\w*;
\v 19 \w I|strong="G1161"\w* \w especially|strong="G4056"\w* \w urge|strong="G3870"\w* \w you|strong="G5210"\w* \w to|strong="G2443"\w* \w do|strong="G4160"\w* \w this|strong="G3778"\w* \w so|strong="G2443"\w* \w that|strong="G2443"\w* \w I|strong="G1161"\w* \w may|strong="G2443"\w* \w be|strong="G2443"\w* restored \w to|strong="G2443"\w* \w you|strong="G5210"\w* \w more|strong="G4056"\w* \w quickly|strong="G5032"\w*.\f + \fr 13:19 \ft This suggests that the author is in jail, in Italy (verse 24 below), so Paul is a possible candidate.\f*
\s1 Benediction
\p 
\v 20 \w Now|strong="G1161"\w* \w may|strong="G2316"\w* \w the|strong="G1722"\w* \w God|strong="G2316"\w* \w of|strong="G1537"\w* \w peace|strong="G1515"\w*—\w who|strong="G3588"\w* \w through|strong="G1722"\w* \w the|strong="G1722"\w* blood \w of|strong="G1537"\w* \w the|strong="G1722"\w* eternal \w covenant|strong="G1242"\w*\f + \fr 13:20 \ft “The blood of the eternal covenant” can only refer to the blood of God's Lamb, that was ‘foreknown before the foundation of the world’ (1 Peter 1:19-20). From our point of view, anything that existed before our planet was created, and that will continue to exist after it is destroyed, may properly be called ‘eternal’.\f* \w brought|strong="G1161"\w* back \w from|strong="G1537"\w* \w the|strong="G1722"\w* \w dead|strong="G3498"\w* \w our|strong="G2316"\w* \w Lord|strong="G2962"\w* \w Jesus|strong="G2424"\w*, \w that|strong="G3588"\w* \w great|strong="G3173"\w* \w Shepherd|strong="G4166"\w* \w of|strong="G1537"\w* \w the|strong="G1722"\w* \w sheep|strong="G4263"\w*—
\v 21 \w equip|strong="G2675"\w* \w you|strong="G5210"\w* \w for|strong="G1519"\w* \w every|strong="G3956"\w* \w good|strong="G3956"\w* \w work|strong="G3956"\w* \w to|strong="G1519"\w* \w do|strong="G4160"\w* \w His|strong="G3956"\w* \w will|strong="G2307"\w*,\f + \fr 13:21 \ft In John 5:19 the Lord Jesus said that He only did what He saw the Father doing. All the power, enabling, equipping that the Text says is available to us is there for us to do the Father's will, not our own.\f* \w working|strong="G4160"\w* \w in|strong="G1722"\w* \w you|strong="G5210"\w* \w what|strong="G3739"\w* \w is|strong="G3588"\w* \w well|strong="G1722"\w* \w pleasing|strong="G2101"\w* \w in|strong="G1722"\w* \w His|strong="G3956"\w* \w sight|strong="G1799"\w*, \w through|strong="G1223"\w* \w Jesus|strong="G2424"\w* \w Christ|strong="G5547"\w*, \w to|strong="G1519"\w* \w whom|strong="G3739"\w* \w be|strong="G3956"\w* \w the|strong="G1722"\w* \w glory|strong="G1391"\w* \w forever|strong="G1519"\w* \w and|strong="G1391"\w* \w ever|strong="G1519"\w*. Amen.
\s1 Sign-off
\p 
\v 22 \w Now|strong="G1161"\w* \w I|strong="G2532"\w* \w appeal|strong="G3870"\w* \w to|strong="G2532"\w* \w you|strong="G5210"\w*, brothers, \w bear|strong="G2532"\w* \w with|strong="G1223"\w* \w this|strong="G3588"\w* \w word|strong="G3056"\w* \w of|strong="G3056"\w* \w exhortation|strong="G3874"\w*, \w for|strong="G1063"\w* \w I|strong="G2532"\w* \w have|strong="G2532"\w* \w written|strong="G1989"\w* \w to|strong="G2532"\w* \w you|strong="G5210"\w* \w in|strong="G2532"\w* \w few|strong="G1223"\w* \w words|strong="G3056"\w*.\f + \fr 13:22 \ft As the Apostle to the Gentiles, Paul's letters to them are liberally sprinkled with commands—he could be quite ‘heavy’ at times. There he was on his own ‘turf’. But the Jews were Peter's turf (Galatians 2:7-8), so in writing to them Paul (as I assume) does not come on as an apostle, and here ‘appeals’ rather than commands. The reference to Timothy in the next verse also suggests Paul as the author.\f*
\v 23 \w Know|strong="G1097"\w* \w that|strong="G3739"\w* brother \w Timothy|strong="G5095"\w* \w has|strong="G3739"\w* been released, \w with|strong="G3326"\w* \w whom|strong="G3739"\w* \w I|strong="G1473"\w* \w will|strong="G3739"\w* \w see|strong="G3708"\w* \w you|strong="G5210"\w*, \w if|strong="G1437"\w* \w he|strong="G3739"\w* \w comes|strong="G2064"\w* \w quickly|strong="G5032"\w*.
\p 
\v 24 Greet \w all|strong="G3956"\w* \w your|strong="G2532"\w* \w leaders|strong="G2233"\w* \w and|strong="G2532"\w* \w all|strong="G3956"\w* \w the|strong="G2532"\w* saints. \w Those|strong="G3588"\w* \w from|strong="G2532"\w* \w Italy|strong="G2482"\w* greet \w you|strong="G5210"\w*.
\p 
\v 25 \w The|strong="G3956"\w* \w Grace|strong="G5485"\w* \w be|strong="G3956"\w* \w with|strong="G3326"\w* \w you|strong="G5210"\w* \w all|strong="G3956"\w*. Amen. 
