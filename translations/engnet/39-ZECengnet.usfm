\v 13 \w Be|strong="H1961"\w* silent \w in|strong="H5921"\w* \w the|strong="H5921"\w* \nd \w Lord|strong="H3068"\w*\nd*’s \w presence|strong="H5921"\w*, \w all|strong="H3045"\w* \w people|strong="H3045"\w* \w everywhere|strong="H5921"\w*, \w for|strong="H3588"\w* \w he|strong="H3588"\w* \w is|strong="H3068"\w* \w being|strong="H1961"\w* moved \w to|strong="H3068"\w* \w action|strong="H7971"\w* \w in|strong="H5921"\w* \w his|strong="H3068"\w* holy dwelling \w place|strong="H3027"\w*.
\c 3
\p 
\v 1 \w Next|strong="H5921"\w* \w I|strong="H5921"\w* \w saw|strong="H7200"\w* \w Joshua|strong="H3091"\w* \w the|strong="H6440"\w* \w high|strong="H1419"\w* \w priest|strong="H3548"\w* \w standing|strong="H5975"\w* \w before|strong="H6440"\w* \w the|strong="H6440"\w* \w angel|strong="H4397"\w* \w of|strong="H3068"\w* \w the|strong="H6440"\w* \nd \w Lord|strong="H3068"\w*\nd*, \w with|strong="H3068"\w* \w Satan|strong="H7854"\w* \w standing|strong="H5975"\w* \w at|strong="H5921"\w* \w his|strong="H3068"\w* \w right|strong="H3225"\w* \w hand|strong="H3225"\w* \w to|strong="H3068"\w* \w accuse|strong="H7853"\w* \w him|strong="H6440"\w*.
