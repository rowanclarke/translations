\c 15
\s1 El año de remisión
\p 
\v 1 Al \w fin|strong="H7093"\w* de \w cada|strong="H8141"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w* \w harás|strong="H6213"\w* una \w remisión|strong="H8059"\w*.
\v 2 \w Este|strong="H2088"\w* \w es|strong="H2088"\w* \w el|strong="H3588"\w* modo \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w remisión|strong="H8059"\w*: \w Todo|strong="H3605"\w* acreedor condonará \w lo|strong="H1697"\w* \w que|strong="H3588"\w* haya prestado \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w prójimo|strong="H7453"\w*. \w No|strong="H3808"\w* \w se|strong="H3808"\w* \w lo|strong="H1697"\w* exigirá \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w prójimo|strong="H7453"\w* \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* hermano, \w porque|strong="H3588"\w* \w se|strong="H3808"\w* proclama \w la|strong="H3588"\w* \w remisión|strong="H8059"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 3 Al \w extranjero|strong="H5237"\w* lo puedes cobrar, pero \w a|strong="H3068"\w* tu hermano perdonarás todo lo \w que|strong="H1961"\w* \w tenga|strong="H1961"\w* de ti,
\v 4 \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w así|strong="H3588"\w* \w no|strong="H3808"\w* \w haya|strong="H1961"\w* mendigo \w en|strong="H3588"\w* medio \w de|strong="H3588"\w* ti. \w Porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w te|strong="H3588"\w* \w bendecirá|strong="H1288"\w* \w con|strong="H3588"\w* abundancia \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H3588"\w* \w da|strong="H5414"\w* \w como|strong="H3588"\w* \w herencia|strong="H5159"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* poseas,
\v 5 si \w solo|strong="H7535"\w* escuchas \w atentamente|strong="H8085"\w* \w la|strong="H8104"\w* \w voz|strong="H6963"\w* de \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd*, \w para|strong="H7535"\w* observar \w cuidadosamente|strong="H8104"\w* \w todos|strong="H3605"\w* \w estos|strong="H2063"\w* \w Mandamientos|strong="H4687"\w* \w que|strong="H3117"\w* \w yo|strong="H6680"\w* te \w ordeno|strong="H6680"\w* \w hoy|strong="H3117"\w*.
\p 
\v 6 \w Porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H3588"\w* \w bendecirá|strong="H1288"\w* \w como|strong="H3588"\w* \w te|strong="H3588"\w* prometió: \wj \w Prestarás|strong="H5670"\w* \w a|strong="H3068"\w* \w muchas|strong="H7227"\w* \w naciones|strong="H1471"\w*, \w pero|strong="H3588"\w* tú \w no|strong="H3808"\w* tomarás prestado. Dominarás \w a|strong="H3068"\w* \w muchas|strong="H7227"\w* \w naciones|strong="H1471"\w*, \w pero|strong="H3588"\w* \w a|strong="H3068"\w* ti \w no|strong="H3808"\w* \w te|strong="H3588"\w* dominarán.\wj*
\p 
\v 7 \w Cuando|strong="H3588"\w* \w haya|strong="H1961"\w* \w en|strong="H3588"\w* \w medio|strong="H3027"\w* \w de|strong="H3588"\w* ti un necesitado \w de|strong="H3588"\w* alguno \w de|strong="H3588"\w* tus hermanos \w en|strong="H3588"\w* alguna \w de|strong="H3588"\w* tus \w ciudades|strong="H8179"\w*, \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H3588"\w* \w da|strong="H5414"\w*, \w no|strong="H3808"\w* endurecerás tu \w corazón|strong="H3824"\w* \w ni|strong="H3808"\w* \w cerrarás|strong="H7092"\w* tu \w mano|strong="H3027"\w* \w a|strong="H3068"\w* tu hermano pobre,
\v 8 \w sino|strong="H3588"\w* le \w abrirás|strong="H6605"\w* tu \w mano|strong="H3027"\w* \w liberalmente|strong="H6605"\w* \w y|strong="H3588"\w* le \w prestarás|strong="H5670"\w* \w con|strong="H3588"\w* generosidad suficiente \w para|strong="H3588"\w* \w su|strong="H3588"\w* necesidad.
\p 
\v 9 \w Guárdate|strong="H8104"\w* \w de|strong="H5921"\w* \w no|strong="H3808"\w* \w tener|strong="H1961"\w* \w en|strong="H5921"\w* tu \w corazón|strong="H3824"\w* alguna intención perversa, \w y|strong="H5921"\w* \w te|strong="H5869"\w* digas: \w Se|strong="H1961"\w* \w acerca|strong="H5921"\w* \w el|strong="H5921"\w* \w año|strong="H8141"\w* \w séptimo|strong="H7651"\w*, \w el|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w remisión|strong="H8059"\w*, \w y|strong="H5921"\w* tus \w ojos|strong="H5869"\w* \w sean|strong="H1961"\w* hostiles \w hacia|strong="H5921"\w* tu hermano pobre \w y|strong="H5921"\w* \w nada|strong="H3808"\w* \w le|strong="H5921"\w* \w des|strong="H5414"\w*, \w y|strong="H5921"\w* \w clame|strong="H7121"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w y|strong="H5921"\w* resulte \w en|strong="H5921"\w* \w ti|strong="H5921"\w* \w pecado|strong="H2399"\w*.
\v 10 \w Sin|strong="H3808"\w* falta le \w darás|strong="H5414"\w*, \w y|strong="H3588"\w* tu \w corazón|strong="H3824"\w* \w no|strong="H3808"\w* \w será|strong="H3808"\w* mezquino \w cuando|strong="H3588"\w* le \w des|strong="H5414"\w*, \w porque|strong="H3588"\w* \w a|strong="H3068"\w* \w causa|strong="H1697"\w* \w de|strong="H3588"\w* \w esto|strong="H2088"\w*, \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H3588"\w* \w bendecirá|strong="H1288"\w* \w en|strong="H3588"\w* \w todas|strong="H3605"\w* tus \w obras|strong="H4639"\w* \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H3588"\w* emprendas.
\p 
\v 11 \w Porque|strong="H3588"\w* \w no|strong="H3808"\w* dejarán \w de|strong="H5921"\w* estar presente \w los|strong="H5921"\w* necesitados \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w yo|strong="H3588"\w* \w te|strong="H5921"\w* \w ordeno|strong="H6680"\w*: \w Abrirás|strong="H6605"\w* \w con|strong="H5921"\w* generosidad tu \w mano|strong="H3027"\w* \w a|strong="H3068"\w* tu hermano, \w al|strong="H5921"\w* necesitado \w y|strong="H3588"\w* \w pobre|strong="H6041"\w* \w en|strong="H5921"\w* tu tierra.
\p 
\v 12 \w Si|strong="H3588"\w* tu hermano, \w hebreo|strong="H5680"\w* \w o|strong="H3068"\w* \w hebrea|strong="H5680"\w*, se \w vende|strong="H4376"\w* \w a|strong="H3068"\w* \w ti|strong="H5973"\w*, \w te|strong="H3588"\w* \w servirá|strong="H5647"\w* \w seis|strong="H8337"\w* \w años|strong="H8141"\w*, \w pero|strong="H3588"\w* al \w séptimo|strong="H7637"\w* \w año|strong="H8141"\w* lo \w dejarás|strong="H7971"\w* \w ir|strong="H7971"\w* \w libre|strong="H2670"\w*.
\v 13 \w Cuando|strong="H3588"\w* \w lo|strong="H3808"\w* dejes \w ir|strong="H7971"\w* \w libre|strong="H2670"\w*, \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w enviarás|strong="H7971"\w* \w con|strong="H5973"\w* las manos \w vacías|strong="H7387"\w*,
\v 14 sino lo abastecerás generosamente \w de|strong="H5414"\w* tu \w rebaño|strong="H6629"\w*, \w de|strong="H5414"\w* tu era y tu \w lagar|strong="H3342"\w*. Le \w darás|strong="H5414"\w* \w de|strong="H5414"\w* aquello con lo cual \nd \w Yavé|strong="H3068"\w*\nd* te \w bendijo|strong="H1288"\w*.
\v 15 \w Te|strong="H5921"\w* acordarás \w que|strong="H3588"\w* \w fuiste|strong="H1961"\w* esclavo \w en|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H5921"\w* rescató. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w yo|strong="H3588"\w* \w te|strong="H5921"\w* \w ordeno|strong="H6680"\w* \w esto|strong="H2088"\w* \w hoy|strong="H3117"\w*.
\p 
\v 16 \w Pero|strong="H3588"\w* \w si|strong="H3588"\w*, \w porque|strong="H3588"\w* \w te|strong="H3588"\w* ama \w a|strong="H3068"\w* \w ti|strong="H5973"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* tu \w familia|strong="H1004"\w*, \w y|strong="H3588"\w* \w le|strong="H5973"\w* \w va|strong="H3068"\w* \w bien|strong="H2895"\w* \w contigo|strong="H5973"\w*, \w él|strong="H5973"\w* \w te|strong="H3588"\w* dice: \w No|strong="H3808"\w* \w te|strong="H3588"\w* dejaré,
\v 17 \w entonces|strong="H3651"\w* \w tomarás|strong="H3947"\w* un punzón, horadarás su oreja \w contra|strong="H1961"\w* la \w puerta|strong="H1817"\w* y \w será|strong="H1961"\w* \w tu|strong="H6213"\w* esclavo \w para|strong="H5414"\w* \w siempre|strong="H5769"\w*. Del mismo modo \w harás|strong="H6213"\w* con \w tu|strong="H6213"\w* esclava.
\v 18 \w No|strong="H3808"\w* \w te|strong="H5869"\w* parezca duro dejarlo \w libre|strong="H2670"\w*, \w porque|strong="H3588"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* mitad \w del|strong="H5973"\w* \w salario|strong="H7939"\w* \w de|strong="H3588"\w* un jornalero \w te|strong="H5869"\w* \w sirvió|strong="H5647"\w* \w seis|strong="H8337"\w* \w años|strong="H8141"\w*. \w Así|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd* \w te|strong="H5869"\w* \w bendecirá|strong="H1288"\w* \w en|strong="H5973"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* \w hagas|strong="H6213"\w*.
\p 
\v 19 Consagrarás \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w todo|strong="H3605"\w* \w primogénito|strong="H1060"\w* \w macho|strong="H2145"\w* \w nacido|strong="H3205"\w* de tu manada de \w ganado|strong="H6629"\w* \w vacuno|strong="H1241"\w* \w y|strong="H7794"\w* de tu \w rebaño|strong="H6629"\w*. \w No|strong="H3808"\w* te sirvas del \w primogénito|strong="H1060"\w* de tu manada de \w ganado|strong="H6629"\w* \w vacuno|strong="H1241"\w*, \w ni|strong="H3808"\w* \w trasquiles|strong="H1494"\w* \w el|strong="H3605"\w* \w primogénito|strong="H1060"\w* de tu \w rebaño|strong="H6629"\w*.
\v 20 Te los comerás \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, \w de|strong="H6440"\w* \w año|strong="H8141"\w* en \w año|strong="H8141"\w*, tú y tu \w familia|strong="H1004"\w*, en el \w lugar|strong="H4725"\w* que \nd \w Yavé|strong="H3068"\w*\nd* escoja.
\p 
\v 21 \w Si|strong="H3588"\w* \w hay|strong="H1961"\w* \w en|strong="H3588"\w* \w él|strong="H3588"\w* algún defecto, \w si|strong="H3588"\w* \w es|strong="H1961"\w* \w ciego|strong="H5787"\w* \w o|strong="H3068"\w* \w cojo|strong="H6455"\w*, \w o|strong="H3068"\w* \w tiene|strong="H1961"\w* \w cualquier|strong="H3605"\w* defecto, \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w sacrificarás|strong="H2076"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*.
\v 22 Te lo comerás en tus \w ciudades|strong="H8179"\w*. Podrán comer de él tanto el impuro como el purificado, como si fuera gacela \w o|strong="H3068"\w* venado.
\v 23 \w Solo|strong="H7535"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* comerás su \w sangre|strong="H1818"\w*. \w La|strong="H5921"\w* derramarás \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w como|strong="H5921"\w* \w agua|strong="H4325"\w*.
\c 16
\s1 Principales fiestas
\p 
\v 1 \w Guarda|strong="H8104"\w* \w el|strong="H3588"\w* \w mes|strong="H2320"\w* \w de|strong="H3588"\w* Abib \w y|strong="H3588"\w* celebra \w la|strong="H8104"\w* \w Pascua|strong="H6453"\w* \w para|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd*, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w mes|strong="H2320"\w* \w de|strong="H3588"\w* Abib, \w de|strong="H3588"\w* \w noche|strong="H3915"\w*, \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd* \w te|strong="H3588"\w* \w sacó|strong="H3318"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*.
\v 2 \w Sacrificarás|strong="H2076"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* la \w pascua|strong="H6453"\w* de tus \w ovejas|strong="H6629"\w* \w y|strong="H1241"\w* de tu \w ganado|strong="H6629"\w* \w vacuno|strong="H1241"\w* en el \w lugar|strong="H4725"\w* que \nd \w Yavé|strong="H3068"\w*\nd* escoja para que more \w allí|strong="H8033"\w* su \w Nombre|strong="H8034"\w*.
\p 
\v 3 \w Nada|strong="H3808"\w* \w leudado|strong="H2557"\w* comerás \w con|strong="H5921"\w* \w ella|strong="H5921"\w*. \w Siete|strong="H7651"\w* \w días|strong="H3117"\w* comerás \w con|strong="H5921"\w* \w ella|strong="H5921"\w* \w pan|strong="H3899"\w* \w sin|strong="H3808"\w* levadura, \w el|strong="H5921"\w* \w pan|strong="H3899"\w* \w de|strong="H5921"\w* \w aflicción|strong="H6040"\w*, \w porque|strong="H3588"\w* \w saliste|strong="H3318"\w* \w a|strong="H3068"\w* prisa \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w para|strong="H4616"\w* \w que|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* tu \w vida|strong="H2416"\w* \w recuerdes|strong="H2142"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w cuando|strong="H3588"\w* \w saliste|strong="H3318"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*.
\v 4 Durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w* \w no|strong="H3808"\w* \w se|strong="H4480"\w* hallará \w levadura|strong="H7603"\w* \w en|strong="H4480"\w* tu casa, \w en|strong="H4480"\w* \w ningún|strong="H3605"\w* lugar \w de|strong="H4480"\w* tu territorio. \w De|strong="H4480"\w* \w la|strong="H3605"\w* \w carne|strong="H1320"\w* \w que|strong="H4480"\w* sacrifiques \w al|strong="H4480"\w* llegar \w la|strong="H3605"\w* noche \w del|strong="H4480"\w* \w primer|strong="H7223"\w* \w día|strong="H3117"\w* \w nada|strong="H3808"\w* quedará \w para|strong="H4480"\w* \w la|strong="H3605"\w* \w mañana|strong="H1242"\w*.
