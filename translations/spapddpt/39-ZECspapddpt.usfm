\v 10 \wj \+w Derramaré|strong="H8210"\+w* \+w Espíritu|strong="H7307"\+w* \+w de|strong="H5921"\+w* \+w gracia|strong="H2580"\+w* \+w y|strong="H5921"\+w* \+w de|strong="H5921"\+w* súplica \+w sobre|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w casa|strong="H1004"\+w* \+w de|strong="H5921"\+w* \+w David|strong="H1732"\+w* \+w y|strong="H5921"\+w* \+w sobre|strong="H5921"\+w* \+w los|strong="H3427"\+w* \+w habitantes|strong="H3427"\+w* \+w de|strong="H5921"\+w* Jerusalén. Mirarán \+w a|strong="H3068"\+w* \+w Mí|strong="H5921"\+w*, \+w a|strong="H3068"\+w* Quien \+w traspasaron|strong="H1856"\+w*. Llorarán \+w como|strong="H5921"\+w* \+w se|strong="H5921"\+w* llora \+w por|strong="H5921"\+w* Hijo \+w Unigénito|strong="H3173"\+w*, \+w y|strong="H5921"\+w* \+w se|strong="H5921"\+w* afligirán \+w por|strong="H5921"\+w* \+w Él|strong="H5921"\+w* \+w como|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w que|strong="H5921"\+w* \+w se|strong="H5921"\+w* aflige \+w por|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w primogénito|strong="H1060"\+w*.\wj*   
