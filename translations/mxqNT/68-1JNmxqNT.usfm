\id 1JN
\h 1 FWANK
\toc1 Myʉtuꞌukpʉ Neky Diꞌibʉ Fwank Jyaay
\toc2 1 FWANK
\toc3 1 Jn.
\mt1 Myʉtuꞌukpʉ Neky Diꞌibʉ Fwank Jyaay
\c 1
\s1 Jesús yajkypy ja jikyꞌa̱jtʉn
\p 
\v 1 Jaꞌats miits nduknija̱ꞌa̱yʉdʉp pʉ́nʉ naty jaayʉm ijtp ko kyajnʉmʉ naty ja naxwíñʉdʉ tsyondaꞌaky, diꞌibʉ myooy ja jikyꞌa̱jtʉn nidʉgekyʉ diꞌibʉ jikyꞌa̱jtp. Jaꞌats ʉʉdsʉty tʉ nꞌix tʉ nmʉdowdʉ es tʉ ndoñ tʉ nmátstʉts mʉdʉdsʉ ngʉꞌʉjʉty.
\v 2 Tʉ yajnijáwʉ yʉ jikyꞌa̱jtʉn, es ʉʉdsʉty tʉ nꞌixtʉ diꞌibʉ yʉ jikyꞌa̱jtʉn yajkypy, es tyam miits nduknijáwʉdʉ es jaꞌa dʉꞌʉn ja jikyꞌa̱jtʉn winʉ xʉʉ winʉ tiempʉ. Yʉꞌʉ naty ijtp mʉdʉ Dios Teety es tʉ kyʉxeꞌeky mʉt ʉʉdsʉty.
\v 3 Pa̱a̱dyʉts miits ndukmʉmadya̱ꞌa̱ga̱ꞌa̱ndʉ diꞌibʉts tʉ nꞌixy es tʉ nmʉdóyʉts, es nandʉꞌʉn miits mdiꞌigyʉdyaꞌaydyʉt mʉt ʉʉdsʉty es mʉt ja Dios Teety es mʉt ja ꞌyUꞌunk Jesukristʉ.
\v 4 Dʉꞌʉn nnijáyʉdʉ es ʉdsa̱jtʉm nxondákʉm nidʉgekyʉ tiꞌigyʉ es jotkʉdaꞌaky.
\s1 Diosʉ dʉꞌʉn ja Ja̱jʉn
\p 
\v 5 Tya̱a̱dʉ dʉꞌʉn ja ayuk diꞌibʉts ja Jesukristʉ xytyukꞌʉxpʉjk es nga̱jxwaꞌxyʉts ma̱ miidsʉty ko yʉ Dios yʉꞌʉ dʉꞌʉn ja Ja̱jʉn, es ma̱ yʉꞌʉ kyaj ti agootsꞌa̱jtʉn.
\v 6 Pʉn jʉna̱ꞌa̱nʉm ko tiꞌigyʉ nꞌijtʉm mʉt yʉ Dios, es nduꞌuyoꞌoyʉm agoots, andákʉm es kyaj nduꞌunʉm ja tʉyꞌa̱jtʉn.
\v 7 Per pʉn tuꞌuyoꞌoyʉm ma̱ ja ja̱jʉn, nmʉda̱jtʉm ja tiꞌigyʉꞌát nixim niyam esʉ ꞌyUꞌunk Jesukristʉ ñeꞌpyñ xyajwátsʉm mʉt tʉgekyʉ nbojpʉꞌa̱jtʉm.
\p 
\v 8 Pʉn njʉna̱ꞌa̱nʉm ko kyaj nbojpʉja̱ꞌa̱yꞌa̱jtʉm, naywyinꞌʉꞌʉnʉm kʉꞌʉm es ni ti tʉyꞌa̱jtʉn ngamʉda̱jtʉm.
\v 9 Per pʉn maya̱jtsʉm ko nbekytyuꞌunʉm, Dios diꞌibʉ tyiimpy ja tʉyꞌa̱jtʉn, xypyojpʉmaꞌxa̱ꞌa̱nʉm es xyajwátsʉm tʉgekyʉ nbojpʉꞌa̱jtʉm.
\v 10 Per pʉn jʉna̱ꞌa̱nʉm ko ngapekytyuꞌunʉm, mʉt yʉꞌʉ ngakupʉjkʉm ja Diosʉ ꞌyayuk es ndíjʉm ko andakp ja Dios ko jyʉnaꞌañ: “Yʉ ja̱ꞌa̱yʉty pojpʉtuundʉbʉ tʉgekyʉ.”
\c 2
\s1 Kristʉ ʉdsa̱jtʉm xyñika̱jxtútʉm
\p 
\v 1 Nitítʉty, tyámʉts miits nnijáyʉdʉ kʉdiibʉ mbekytyúndʉt. Per pʉn jaa pʉ́n pyekytyúñ, nmʉda̱jtʉm tuꞌuk diꞌibʉ xyñika̱jxtútʉm Dios windum. Yʉꞌʉ dʉꞌʉn ja Jesukristʉ diꞌibʉ tyiimpy ja tʉyꞌa̱jtʉn.
\v 2 Pes yʉꞌʉ kʉꞌʉm naydyukwindsʉꞌkʉ kruuzkʉjxy es dʉꞌʉn tkumʉdooy ja nbojpʉꞌa̱jtʉm. Es kyaj ꞌyʉdsa̱jtʉmʉty jeꞌeyʉ, nandʉꞌʉn tkumʉdooy nidʉgekyʉ ja naxwíñʉdʉ ja̱ꞌa̱yʉdyʉ pyojpʉ.
\p 
\v 3 ¿Wiꞌix mba̱a̱t nmʉda̱jtʉm tʉyꞌa̱jtʉn ko nꞌixyꞌa̱jtʉm ja Dios? Pes mʉdʉ tya̱a̱dʉ ko nguydyuꞌunʉm ja ꞌyanaꞌamʉn.
\v 4 Mʉt ko diꞌibʉ jʉna̱a̱mp: “Ʉj nꞌixyꞌa̱jtypyʉts ja Dios”, es kyaj tkuydyúñ ja Diosʉ ꞌyanaꞌamʉn, tya̱dʉ ja̱ꞌa̱y andakp es ni ti tʉyꞌa̱jtʉn tkamʉdaty.
\v 5 Per ja ja̱ꞌa̱y diꞌibʉ kyuydyiimpy ja Diosʉ ꞌyanaꞌamʉn, kexy kaꞌpxy tmʉdaty ja Diosʉ tsyojkʉn, es dʉꞌʉn nnija̱ꞌa̱m ko tiꞌigyʉ nꞌijtʉm mʉdʉ Dios.
\v 6 Mʉt ko pʉn njʉna̱ꞌa̱nʉm ko nbanʉjxʉm ja Jesukristʉ, xypyátʉm es njikyꞌa̱jtʉm éxtʉmʉ Jesukristʉ jyikyꞌajty.
\s1 Jembyʉ anaꞌamʉn
\p 
\v 7 Mʉguꞌugítʉty, kyajts miits nduknijáyʉdʉ anaꞌamʉnʉ jembyʉ. Diꞌibʉ nduknija̱ꞌa̱yʉdʉp, jaꞌayʉm mmʉda̱jtʉp diꞌibʉ jawyíñʉp myaꞌꞌanma̱a̱ydyʉ. Tya̱dʉ jeky anaꞌamʉn, jaꞌayʉm ja ayuk diꞌibʉ tʉ xymyʉdowdʉ.
\v 8 Oyʉ dʉꞌʉn, tya̱a̱dʉ diꞌibʉ nduknija̱ꞌa̱yʉdʉp, yʉꞌʉ tuꞌugʉ jembyʉ anaꞌamʉn, es yaꞌijxʉp ko tʉyꞌa̱jtʉnʉꞌʉ ma̱ Kristʉ es nandʉꞌʉn ma̱ miidsʉty, mʉt ko na̱jxp ja kugootsꞌát es ja̱j tʉꞌxnʉp ja tʉyꞌa̱jtʉn.
\p 
\v 9 Diꞌibʉ jʉna̱a̱mp ko ꞌyity ma̱ ja ja̱jʉn es kyaj ttseky ja myʉguꞌuk, taadʉ ijtpʉm kugoots.
\v 10 Diꞌibʉ tsyejpy ja myʉguꞌuk, jikyꞌa̱jtp ma̱ ja ja̱jʉn, es ni ti kyayajpekykyaꞌayʉty.
\v 11 Per diꞌibʉ myʉdsipꞌa̱jtypy ja myʉguꞌuk, jikyꞌa̱jtp es jyʉdity ma̱ wyingoodsʉty, es kyaj tnijawʉ ma̱ ñejxy, mʉt ko ja kootsꞌát tʉ yajjʉmbítyʉty wiints.
\p 
\v 12 Nitítʉty, nnijáyʉdʉts miidsʉty mʉt ko Dios tʉ tmeꞌxy ja mbojpʉty mʉt yʉꞌʉgyʉjxmʉ Jesukristʉ.
\v 13 Uꞌunkteedyʉty, nnijáyʉdʉts miits mʉt ko tʉ xyꞌixyꞌattʉ Jesukristʉ diꞌibʉ taayʉm ko naxwíñʉdʉ tsyondaky. Ʉna̱ꞌkʉty, nnijáyʉdʉts miits mʉt ko tʉ xymyʉmada̱ꞌa̱ktʉ ja mʉjkuꞌugópk.
\p Nitítʉty, nnijáyʉdʉts miidsʉty mʉt ko tʉ xyꞌixyꞌattʉ Dios.
\v 14 Uꞌunkteedyʉty, nnijáyʉdʉts miits mʉt ko tʉ xyꞌixyꞌattʉ Jesukristʉ diꞌibʉ taayʉm ko naxwíñʉdʉ tsyondaky. Ʉna̱ꞌkʉty, nnijáyʉdʉts miits mʉt ko yajxón tʉ xyꞌaxá̱jʉdʉ ja Diosʉ ꞌyayuk mʉt winʉ mjot. Pa̱a̱ty xymyʉdattʉ mʉkꞌa̱jtʉn es tʉ xymyʉmada̱ꞌa̱ktʉ ja mʉjkuꞌugópk.
\p 
\v 15 Katʉ xytsyoktʉ ja naxwíñʉdʉ winma̱ꞌa̱ñ, mʉt ko yʉ ja̱ꞌa̱y diꞌibʉ tsyojktʉp ja naxwíñʉdʉ winma̱ꞌa̱ñ, kyaj ttsoktʉ ja Dios Teety.
\v 16 Mʉt ko tʉgekyʉ diꞌibʉ jaaꞌa̱jtp naxwiiñ, ko ja̱ꞌa̱y tꞌʉxta̱ꞌa̱ydyʉ diꞌibʉ niniꞌx kʉba̱jk tsyejpy, ko tꞌadsoktʉ ko tii tꞌixtʉ es ko myʉj pya̱a̱dʉdʉ ko tii tmʉdat tjaygyaptʉ, tʉgekyʉ tya̱dʉ winma̱ꞌa̱ñ esʉ dʉꞌʉmbʉ jikyꞌa̱jtʉn jaa myiñ ma̱ yʉ naxwíñʉdʉ, es kyaj myiñ ma̱ Dios.
\v 17 Perʉ Dios yajkutʉgoyaampy ja naxwíñʉdʉ winma̱ꞌa̱ñ mʉt tʉgekyʉ diꞌibʉ ja̱ꞌa̱y adsojktʉp naxwíñʉdʉ winma̱ꞌa̱ñgyʉjxm, per ja ja̱ꞌa̱y diꞌibʉ kyuydyiimpy ja Diosʉ tsyojkʉn, jikyꞌa̱jtp winʉ xʉʉ winʉ tiempʉ.
\s1 Tʉyꞌa̱jtʉn esʉ andakʉn
\p 
\v 18 Nitítʉty, tʉ jyaꞌty ma̱ tyam tuꞌuk óknʉm ja oorʉ. Tʉ xymyʉdowdʉ ko myina̱ꞌa̱ñ diꞌibʉ myʉdsipꞌa̱jtypy ja Kristʉ. Pes nʉgoo ꞌyokmayꞌa̱jnʉ diꞌibʉ myʉdsipꞌa̱jttʉp ja Kristʉ. Pa̱a̱dyʉts nnijawʉ ko tʉ net jyaꞌty ja tiempʉ diꞌibʉ tim ok.
\v 19 Tamʉ ja̱ꞌa̱y diꞌibʉ pʉdsʉʉmdʉ ma̱ ʉʉdsʉty, per kyaj yʉꞌʉ tꞌaxá̱jʉdʉ Kristʉ éxtʉmʉ Yajnitsókpʉ. Mʉt kots xyñikaktʉ, pa̱a̱ty yaꞌixy ko kyaj tꞌaxá̱jʉdʉ Kristʉ es nan kyaj yʉꞌʉdyʉ nmʉmʉbʉjkpʉꞌa̱jtʉm.
\p 
\v 20 Per miidsʉty kyaj mdʉꞌʉnꞌáttʉ, mʉt ko Kristʉ mmooyʉdʉ ja Espíritʉ Santʉ es miidsʉty nidʉgekyʉ mnija̱ꞌa̱dʉp ja tʉyꞌa̱jtʉn.
\v 21 Nnijáyʉdʉts miits mʉt ko yajxón xyñijáwʉdʉ ja tʉyꞌa̱jtʉn, kyaj nnijáyʉdʉ éxtʉm diꞌibʉ kyaj tnijawʉ. Miidsʉty yajxón xyñijáwʉdʉ ko ma̱ yʉ tʉyꞌa̱jtʉn, kyaj myiñ ja andakʉn.
\p 
\v 22 Yʉꞌʉ dʉꞌʉn andakp diꞌibʉ jʉna̱a̱mp ko yʉ Jesús kyaj yʉꞌʉdyʉ Kristʉ. Esʉ taadʉ yʉꞌʉ dʉꞌʉn diꞌibʉ myʉdsipꞌa̱jtypy ja Kristʉ, pes ꞌyʉxtijpy ja Dios Teety es ja ꞌyUꞌunk.
\v 23 Es diꞌibʉ ꞌyʉxtijpy ja Diosʉ ꞌyUꞌunk, nan kyaj ꞌyity tiꞌigyʉ mʉʉt ja Dios Teety. Per pʉ́n ꞌyaxá̱jʉp ja Diosʉ ꞌyUꞌunk, nan ijtp tiꞌigyʉ mʉt ja Dios Teety.
\p 
\v 24 Miidsʉty, pes jikyꞌattʉ éxtʉmʉ Jesukristʉ ꞌyʉxpʉjkʉn diꞌibʉ mꞌaxá̱jʉdʉ extʉ jawyíñʉp. Es ko dʉꞌʉn xytyúnʉt, mꞌíttʉp tiꞌigyʉ mʉt ja Dios Teety es mʉt ja ꞌyUꞌunk.
\v 25 Es tya̱a̱dʉ dʉꞌʉn diꞌibʉ Jesukristʉ tʉ xytyukwa̱ndákʉm, ja jikyꞌa̱jtʉn winʉ xʉʉ winʉ tiempʉ.
\p 
\v 26 Tʉts miits nnijáyʉdʉ es mnaygywentʉꞌátʉdʉt mʉdʉ tadʉ diꞌibʉty mwinꞌʉʉnánʉdʉp.
\v 27 Per miidsʉty kyaj mdʉgoyꞌa̱jtxʉdʉ pʉ́n mdukꞌʉxpʉ́kʉdʉp, jaꞌa ko Jesukristʉ tʉ mmoꞌoyʉdʉ yʉ Espíritʉ Santʉ, es yʉꞌʉ mdukꞌʉxpʉjkʉdʉp tʉgekyʉ. Es yʉꞌʉ dʉꞌʉn ja tʉyꞌa̱jtʉn es kyaj tmʉdaty ja andakʉn. Pa̱a̱ty ittʉ tiꞌigyʉ mʉt ja Kristʉ, éxtʉm yʉ Espíritʉ Santʉ tʉ myaꞌʉxpʉ́kʉdʉ.
\p 
\v 28 Pes tyamʉ net nitítʉty, ittʉ tiꞌigyʉ mʉt ja Kristʉ es mnayjotmʉkmoꞌoyʉdʉt ko yʉꞌʉ kyʉxʉꞌʉgʉt jatʉgok, es kyaj xymyʉdsoydyúndʉt ko myínʉt.
\v 29 Mnija̱ꞌa̱dʉp miidsʉty ko Jesukristʉ tyiimpy ja tʉyꞌa̱jtʉn. Pes nijáwʉdʉ nandʉꞌʉn ko diꞌibʉ tyuundʉp ja tʉyꞌa̱jtʉn, yʉꞌʉ dʉꞌʉn uꞌunkꞌa̱jttʉp ja Dios.
\c 3
\s1 Diosʉ ꞌyuꞌungʉty
\p 
\v 1 Jaygyúkʉdʉ éxtʉm ja Dios Teety xyjantsytsyojkʉm es xyꞌuꞌunkniwa̱ꞌa̱nʉm. Es tʉyꞌa̱jtʉnʉꞌʉ xyꞌuꞌunkꞌa̱jtʉm. Pa̱a̱ty kyaj xyꞌixyꞌa̱jtʉm pʉ́nʉdyʉ naxwíñʉdʉ winma̱ꞌa̱ñ jaꞌaꞌa̱jtʉdʉp, jaꞌa ko kyaj tꞌixyꞌattʉ ja Dios.
\p 
\v 2 Mʉguꞌugítʉty, ʉdsa̱jtʉm xyꞌuꞌunkꞌa̱jtʉm ja Dios. Es kyajnʉm xytyukꞌijxʉm wiꞌix nꞌakꞌijtʉm, per ko Jesukristʉ kyʉxʉꞌʉgʉt, dʉꞌʉn nꞌijtʉm éxtʉm ja Kristʉ, mʉt ko nꞌixa̱ꞌa̱nʉm wiꞌixʉ dʉꞌʉn yʉꞌʉ.
\v 3 Es nidʉgekyʉ diꞌibʉ dʉꞌʉn ꞌyaxá̱jʉdʉp ja Kristʉ éxtʉmʉ Yajnitsókpʉ, yʉꞌʉjʉty nayyajwátsʉp kʉꞌʉm éxtʉmʉ Jesukristʉ wya̱ꞌa̱dsʉty.
\p 
\v 4 Per diꞌibʉ pekytyuump myʉdʉgeepy ja Diosʉ ꞌyanaꞌamʉn. Yʉꞌʉ ja peky ko kyajʉ Dios ja ꞌyanaꞌamʉn yajpadúñ.
\v 5 Es mnija̱ꞌa̱dʉp ko Jesukristʉ myiiñ ya̱ naxwiiñ yajpojpʉnitʉgeebyʉ, es kyaj yʉꞌʉ tmʉdaty ni ti peky.
\v 6 Es nidʉgekyʉ diꞌibʉ ijttʉp tiꞌigyʉ mʉt yʉꞌʉ, kyaj jyʉdity mʉt ja pojpʉ. Per nidʉgekyʉ diꞌibʉ pekytyuundʉp, kyaj tꞌixyꞌaty ja Kristʉ, es nan kyaj yʉꞌʉ jyaꞌaꞌátyʉty.
\v 7 Nitítʉty, éxkʉm mwinꞌʉʉnʉdʉ pʉ́n. Pʉ́nʉ Kristʉ jaꞌaꞌa̱jtʉp, jaꞌa tyiimpy ja tʉyꞌa̱jtʉn éxtʉm ja Kristʉ kʉꞌʉm.
\v 8 Per diꞌibʉ pekytyuump, yʉꞌʉ jaꞌaꞌa̱jtʉp ja mʉjkuꞌugópk, jaꞌa ko yʉ mʉjkuꞌugópk pyekytyiimpy jawyíñʉp extʉ tyamba̱a̱t. Yʉ Diosʉ ꞌyUꞌunk tʉ myiñ naxwiiñ es dyajkutʉgoyaꞌañ diꞌibʉ ja mʉjkuꞌugópk tyiimpy.
\p 
\v 9 Ni tuꞌuk ʉdsa̱jtʉm diꞌibʉ Dios xyꞌuꞌunkꞌa̱jtʉm njikyꞌa̱jtʉm éxtʉmʉ pojpʉ tuumbʉ, mʉt ko nmʉda̱jtʉm ja jikyꞌa̱jtʉn diꞌibʉ Dios tʉ xymyoꞌoyʉm es kyaj mba̱a̱t niꞌigʉ nduꞌunʉm ja pojpʉ, mʉt ko xyꞌuꞌunkꞌa̱jtʉm ja Dios.
\v 10 Es mʉdʉ tya̱a̱dʉ ñigʉxeꞌeky pʉ́nʉdyʉ Dios uꞌunkꞌa̱jttʉp es pʉ́nʉty ja mʉjkuꞌugópk uꞌunkꞌa̱jttʉp. Mʉt ko diꞌibʉ jikyꞌa̱jtp axʉʉk es kyaj ttseky ja myʉguꞌuk, kyaj jyaꞌaꞌátyʉty ja Dios.
\s1 Naydsyojkʉm nixim niyam
\p 
\v 11 Pes diꞌibʉ Jesukristʉ xytyukꞌanaꞌamʉm extʉ jawyíñʉp, tya̱a̱dʉ dʉꞌʉn ko nnaydsyojkʉm nixim niyam,
\v 12 es kyaj nduꞌunʉm éxtʉm ja Kaín diꞌibʉ jaꞌaꞌa̱jtʉp ja mʉjkuꞌugópk es dyaꞌeꞌky ja myʉgaꞌax Abel. ¿Es ti ko dyaꞌeꞌky? Mʉt ko Abel jyikyꞌaty tʉyꞌa̱jtʉn mʉʉt es ja Kaín kyaj.
\p 
\v 13 Mʉguꞌugítʉty, katʉ dʉꞌʉñʉ mwʉꞌʉmʉdʉ pʉn mdukꞌakꞌa̱jtʉdʉp pʉ́nʉdyʉ naxwíñʉdʉ winma̱ꞌa̱ñ jaꞌaꞌa̱jtʉdʉp.
\v 14 Mʉt ko ndsojkʉm ja nmʉguꞌukꞌa̱jtʉm, nnija̱ꞌa̱m ko yʉ Dios tʉ xyajjʉgákʉm ma̱ yʉ oꞌkʉn es tʉ xyajmiꞌinʉm ma̱ yʉ jikyꞌa̱jtʉn. Diꞌibʉ kyaj ttseky yʉ myʉguꞌuk, wʉꞌʉmp yʉꞌʉ ma̱ ja oꞌkʉn.
\v 15 Diꞌibʉ kyaj ttseky ja myʉguꞌuk, yʉꞌʉ dʉꞌʉn yajja̱ꞌa̱yꞌoꞌkpʉ. Es miits mnija̱ꞌa̱dʉp ko ja yajja̱ꞌa̱yꞌoꞌkpʉ kyaj tmʉdaty ja jikyꞌa̱jtʉn winʉ xʉʉ winʉ tiempʉ.
\v 16 Nnija̱ꞌa̱m diꞌibʉ dʉn tsojkʉnꞌa̱jtp, mʉt ko Jesukristʉ dyaꞌijxʉ ko jyikyꞌa̱jtʉn dyajky mʉt ʉdsa̱jtʉmgyʉjxm. Es dʉꞌʉn xypyátʉm ʉdsa̱jtʉm es nya̱jkʉm ja njikyꞌa̱jtʉnꞌa̱jtʉm mʉt jaꞌagyʉjxm ja nmʉguꞌukꞌa̱jtʉm.
\v 17 Pʉn ja pʉ́n tmʉdaty tjaygyepy diꞌibʉ ndukjikyꞌa̱jtʉm, es tꞌixy ja myʉguꞌuk tyʉgoyꞌa̱jtxʉty, es kyaj tpaꞌꞌayoy, ¿wiꞌix mba̱a̱t tmʉdaty ja Diosʉ tsyojkʉn?
\s1 Amumduꞌuk jot naybyʉjtákʉm ma̱ Dios
\p 
\v 18 Nitítʉty, kyaj nnaydsyojkʉm jeꞌeyʉ wingʉꞌʉy agʉꞌʉy, naydsyojkʉm éxtʉm mba̱a̱t yaꞌixy diꞌibʉ nduꞌunʉm mʉt ja tʉyꞌa̱jtʉn.
\v 19 Dʉꞌʉn nnija̱ꞌa̱m ko xyjaꞌaꞌa̱jtʉm ja Dios es nꞌijtʉm jotkujk Dios windum
\v 20 ko nbekyjya̱ꞌa̱m, Dios niꞌigʉ myʉ́jʉty es kʉdiinʉm ʉdsa̱jtʉmʉ njotꞌa̱jt nwinma̱ꞌa̱ñꞌa̱jtʉm, ñija̱ꞌa̱p yʉꞌʉ tʉgekyʉ.
\v 21 Mʉguꞌugítʉty, pʉn kyaj ti nbekyjya̱ꞌa̱m, nwinguwa̱ꞌkʉm jotkujk ja Dios,
\v 22 es yʉꞌʉ xymyoꞌoyʉm diꞌibʉ ʉdsa̱jtʉm nꞌamdoꞌom, mʉt ko nguydyuꞌunʉm ja ꞌyanaꞌamʉn es nduꞌunʉm diꞌibʉ yʉꞌʉ tsyejpy.
\v 23 Es ja Dios tniꞌanaꞌamʉ es nmʉbʉjkʉm ja ꞌyUꞌunk Jesukristʉ es nnaydsyojkʉm nixim niyam, éxtʉm ja Kristʉ xytyukꞌanaꞌamʉm.
\v 24 Pʉn nguydyuꞌunʉm ja Diosʉ ꞌyanaꞌamʉn, jikyꞌa̱jtʉm mʉt yʉꞌʉ, es yʉꞌʉ jyikyꞌaty mʉt ʉdsa̱jtʉm. Nnija̱ꞌa̱m ko yʉꞌʉ jyikyꞌaty ma̱ ʉdsa̱jtʉm, mʉt ko tʉ xymyoꞌoyʉm ja Espíritʉ Santʉ.
\c 4
\s1 Espíritʉ Santʉ esʉ kaꞌoybyʉ
\p 
\v 1 Mʉguꞌugítʉty, jaa may ja ja̱ꞌa̱y diꞌibʉ nayñiga̱jxʉdʉp ko yʉꞌʉ yaꞌʉxpʉktʉ es ko xytyuknimiꞌinʉm ja Diosʉ ꞌyayuk. Katʉ miits xymyʉbʉktʉ, jaꞌa ko taa may diꞌibʉ andáktʉp, jeꞌeyʉ xywyinꞌʉʉna̱ꞌa̱nʉm. Ixtʉ yajxónʉ tadʉ ꞌyʉxpʉjkʉn es net xymyʉbʉ́ktʉt pʉn tʉyꞌa̱jtʉn ko yʉꞌʉ Dios tjaꞌaꞌáty.
\p 
\v 2 Dʉꞌʉn xyñijáwʉdʉt ko yʉꞌʉ Diosʉ Jya̱ꞌa̱jʉn tjaꞌaꞌáty: nidʉgekyʉ pʉ́nʉty jʉnándʉp ko yʉ Jesús yʉꞌʉdyʉ dʉꞌʉn ja Kristʉ, Diosʉ ꞌyUꞌunk diꞌibʉ miin ya̱ naxwiiñ éxtʉmʉ naxwíñʉdʉ ja̱ꞌa̱y, jaꞌa myʉda̱jttʉp ja Diosʉ Jya̱ꞌa̱jʉn.
\v 3 Ja diꞌibʉ jʉna̱a̱mp ko Kristʉ kyaj dʉꞌʉn oj myiñ, kyaj ja Espíritʉ Santʉ tmʉdaty, jaꞌa taadʉ myʉdsipꞌa̱jtypy ja Kristʉ. Es tʉ xymyʉdowdʉ miidsʉty ko myina̱ꞌa̱ñ diꞌibʉ myʉdsipꞌa̱jtypy ja Kristʉ. Pes ta net ya̱ naxwiiñ.
\p 
\v 4 Nitítʉty, miidsʉty Dios mjaꞌaꞌa̱jtʉdʉp. Tʉ xymyʉmada̱ꞌa̱ktʉ tadʉ andakpʉty, mʉt ko yʉ Espíritʉ Santʉ diꞌibʉ miidsʉty mʉʉt mꞌittʉ, niꞌigʉ yʉꞌʉ myʉ́jʉty es kʉdiinʉmʉ kaꞌoybyʉ diꞌibʉ ja ya̱ naxwiiñ.
\v 5 Tadʉ andakpʉ yʉꞌʉ jaꞌaꞌa̱jtʉdʉp ja naxwíñʉdʉ winma̱ꞌa̱ñ, pa̱a̱ty tka̱jxwa̱ꞌxtʉ ja naxwíñʉdʉ winma̱ꞌa̱ñ, es myʉdooꞌijtʉdʉ ja ja̱ꞌa̱y diꞌibʉ naxwíñʉdʉ winma̱ꞌa̱ñ jaꞌaꞌa̱jtʉdʉp.
\v 6 Per ʉdsa̱jtʉm Dios xyjaꞌaꞌa̱jtʉm. Diꞌibʉ Dios ꞌyijxyꞌajtypy, myʉdooꞌijtypy ja ayuk diꞌibʉ nga̱jxwa̱ꞌxʉm. Per diꞌibʉ kyaj Dios jyaꞌaꞌátyʉty, kyaj xymyʉdooꞌijtʉm. Es dʉꞌʉn mba̱a̱t nꞌʉxka̱jpʉm pʉ́n myʉda̱jtypy ja Espíritʉ Santʉ diꞌibʉ tʉyꞌa̱jtʉn yajkypy, es pʉ́n myʉda̱jtypy ja kaꞌoybyʉ diꞌibʉ winꞌʉꞌʉmp.
\s1 Dios yʉꞌʉ dʉꞌʉn ja tsojkʉn
\p 
\v 7 Mʉguꞌugítʉty, nꞌoknaydsyojkʉm nixim niyam, mʉt ko yʉ tadʉ tsojkʉn myiñ ma̱ Dios. Nidʉgekyʉ diꞌibʉ myʉda̱jttʉp ja tsojkʉn, yʉꞌʉ Dios uꞌunkꞌa̱jtʉdʉp, es ꞌyixyꞌa̱jttʉp ja Dios.
\v 8 Diꞌibʉ kyaj tmʉdaty ja tsojkʉn, kyaj yʉꞌʉjʉty tꞌixyꞌattʉ Dios, mʉt ko Dios yʉꞌʉ dʉꞌʉn ja tsojkʉn.
\v 9 Dios xytyukꞌijxʉm ja tsyojkʉn ʉdsa̱jtʉm ko tkejxy ja tyuꞌuk Uꞌunk ya̱ naxwiiñ es nmʉda̱jtʉm ja njikyꞌa̱jtʉnꞌa̱jtʉm mʉt yʉꞌʉgyʉjxmʉ ꞌyUꞌunk.
\v 10 Kyaj ꞌyʉdsa̱jtʉmʉty jawyiin ndsojkʉm ja Dios, jawyiinꞌa̱jtp yʉꞌʉ oj xytsyojkʉm es xytyukꞌijxʉm mʉt ko xytyuknigajxʉm ja ꞌyUꞌunk es xyajpojpʉnitʉgoꞌoyʉm.
\p 
\v 11 Mʉguꞌugítʉty, mʉt ko dʉꞌʉn ja Dios tʉ xytsyojkʉm, nandʉꞌʉn nnaydsyojkʉm nixim niyam.
\v 12 Ni na̱ꞌa̱ pʉ́nʉ Dios tkaꞌixy. Per pʉn nnaydsyojkʉm nixim niyam, Dios ijtp ma̱ ʉdsa̱jtʉm es nmʉda̱jtʉm ja tsyojkʉn.
\v 13 Es mʉt ko Dios tʉ xymyoꞌoyʉm yʉ Espíritʉ Santʉ, tʉ xytyukꞌijxʉm ko yʉꞌʉ ꞌyity mʉt ʉdsa̱jtʉm, es ʉdsa̱jtʉm nꞌijtʉm mʉt yʉꞌʉ.
\v 14 Es tʉts nꞌíxyʉts kʉꞌʉm es nga̱jxteꞌxyʉts ko Dios Teety tkejxy ja ꞌyUꞌunk ya̱ naxwiiñ éxtʉmʉ Yajnitsókpʉ.
\v 15 Oytyim pʉ́nʉty diꞌibʉ ꞌyijxkajpy ko Jesús yʉꞌʉ Dios ꞌyUꞌunkꞌátyʉty, jikyꞌa̱jtp mʉt ja Dios es ja Dios jyikyꞌaty mʉt yʉꞌʉ.
\p 
\v 16 Es dʉꞌʉn nnija̱ꞌa̱m es nmʉbʉjkʉm ko Dios xytsyojkʉm. Dios yʉꞌʉ dʉꞌʉn ja tsojkʉn, es pʉn nnaydsyojkʉm nixim niyam, Dios jikyꞌa̱jtp mʉt ʉdsa̱jtʉm, es ʉdsa̱jtʉm njikyꞌa̱jtʉm mʉt ja Dios.
\v 17 Es ko njikyꞌa̱jtʉm mʉt ja Dios, mʉj máyʉp es kexy kaꞌpxy ꞌyítʉt ja ndsojkʉnꞌa̱jtʉm es ndukmʉꞌawda̱jtʉm ko Dios xypyayoꞌoyʉm, jaꞌa ko nꞌijtʉm ya̱ naxwiiñ éxtʉmʉ Kristʉ.
\v 18 Ma̱ jyámʉty ja tsojkʉn, kyaj jyámʉty ja tsʉꞌkʉn. Diꞌibʉ myʉda̱jtypy kexy kaꞌpxy ja tsojkʉn, yajkekypy ja tsʉꞌʉgʉ. Jaꞌa ko pʉn ndsʉꞌkʉm tii, njʉjptsʉꞌkʉm ko xytyukkumʉdowa̱ꞌa̱nʉm diꞌibʉ tʉ nduꞌundʉgoꞌoyʉm. Ko ti ndsʉꞌkʉm, kyaj kexy kaꞌpxy nmʉda̱jtʉm ja tsojkʉn.
\p 
\v 19 Dios jawyiin xytsyojkʉm ʉdsa̱jtʉm. Pa̱a̱ty ʉdsa̱jtʉm ndsojkʉm ja Dios.
\v 20 Pʉn ja pʉ́n jyʉnaꞌañ: “Ʉj ndsejpyʉts ja Dios”, es kyaj ttseky ja myʉguꞌuk, andakpʉ taadʉ. Pʉn diꞌibʉ kyaj ttseky ja myʉguꞌuk diꞌibʉ ya̱a̱ ꞌyijxypy, nan kyaj mba̱a̱t ttseky ja Dios diꞌibʉ kyaj tꞌixy.
\v 21 Mʉt ko Dios tʉ xytyukꞌanaꞌamʉm ko diꞌibʉ tsyejpy ja Dios, nandʉꞌʉn ttsókʉt ja myʉguꞌuk.
\c 5
\s1 Wiꞌix ja kaꞌoybyʉ nmʉmadákʉm
\p 
\v 1 Nidʉgekyʉ diꞌibʉ ꞌyaxá̱jʉp ja Jesús éxtʉmʉ Kristʉ, yʉꞌʉ dʉꞌʉn ja Dios uꞌunkꞌa̱jtʉdʉp. Ja ja̱ꞌa̱y diꞌibʉ tsyejpy tuꞌugʉ uꞌunkteety, nandʉꞌʉn ttseky yʉ uꞌunkteedyʉ ꞌyuꞌungʉty.
\v 2 Ko ndsojkʉm ja Dios es nguydyuꞌunʉm ja ꞌyanaꞌamʉn, ndsojkʉmʉ naty nandʉꞌʉnʉ ꞌyuꞌungʉty.
\v 3 Es ko ndsojkʉm ja Dios, nguydyuꞌunʉmʉ naty yʉ ꞌyanaꞌamʉn. Es kom xyꞌuꞌunkꞌa̱jtʉm ja Dios es ndsojkʉm, kyaj mʉk nja̱ꞌa̱m es nguydyuꞌunʉm diꞌibʉ yʉꞌʉ xytyukꞌanaꞌamʉm,
\v 4 mʉt ko nidʉgekyʉ ʉdsa̱jtʉm diꞌibʉ xyꞌuꞌunkꞌa̱jtʉm ja Dios, nmʉmadákʉm es kyaj nduꞌunʉm ja naxwíñʉdʉ winma̱ꞌa̱ñ. Nmʉmadákʉm mʉt ko nmʉbʉjkʉm ko ja Jesús yʉꞌʉ Kristʉ, Diosʉ ꞌyUꞌunk.
\v 5 Pʉ́nʉty myʉbʉjktʉp ko Jesús yʉꞌʉ Diosʉ ꞌyUꞌunk, myʉmadáktʉp es kyaj ttúndʉt ja naxwíñʉdʉ winma̱ꞌa̱ñ.
\s1 Jesús yajnigajxy ko Dios ꞌyuꞌunkꞌátyʉty
\p 
\v 6 Ko Jesús myiiñ ya̱ naxwiiñ, oj yaꞌijxweꞌemy mʉt ja nʉʉ es ja neꞌpyñ, kyaj jyeꞌeyʉty ja nʉʉ, jaꞌa mʉt ja nʉʉ es ja neꞌpyñ. Es ja Espíritʉ Santʉ kʉꞌʉm dyajtʉydyʉ́kʉ, es ni na̱ꞌa̱ kyaꞌꞌandaꞌaky.
\v 7 Tʉgʉʉk jyamꞌaty tsa̱jpótm diꞌibʉ yajtʉydyʉjkʉbʉ tya̱a̱dʉ: ja Dios Teety, ja Diosʉ ꞌyUꞌunk esʉ Espíritʉ Santʉ. Es tiꞌigyʉ ja tʉyꞌa̱jtʉn diꞌibʉ ya̱jktʉp.
\v 8 Es tʉgʉʉk jyaaꞌáty naxwiiñ diꞌibʉ yajtʉydyʉjkʉdʉbʉ tya̱a̱dʉ: ja Espíritʉ Santʉ, ja nʉʉ es ja neꞌpyñ. Es tiꞌigyʉ ja tʉyꞌa̱jtʉn diꞌibʉ ya̱jktʉp.
\v 9 Nmʉbʉjkʉm ko tnika̱jxpáttʉ ja̱ꞌa̱yʉty. Per yʉ Diosʉ ñika̱jxpajtʉn kana̱k nipat ꞌyóyʉty. Yʉ Dios tʉ jyʉnaꞌañ ko Jesús yʉꞌʉ ꞌyUꞌunkꞌa̱jtypy.
\v 10 Diꞌibʉ myʉbejkypy ja Diosʉ ꞌyUꞌunk, myʉda̱jtypy jyodoty wyinma̱ꞌa̱ñóty diꞌibʉ ñika̱jxpejtypy ko tyʉyꞌa̱jtʉnʉty. Per diꞌibʉ kyaj tmʉbeky ja Dios, dʉꞌʉn tꞌixy éxtʉm ꞌyandaꞌaky ja Dios, mʉt ko kyaj tmʉbeky ja Diosʉ ñika̱jxpajtʉn ko jyajʉnáñ: “Jesús ʉj nꞌUꞌunkꞌa̱jtypy.”
\v 11 Tya̱dʉ nika̱jxpajtʉn yʉꞌʉ dʉꞌʉn: ja Dios tʉ xymyoꞌoyʉm ja jikyꞌa̱jtʉn winʉ xʉʉ winʉ tiempʉ, esʉ tya̱dʉ jikyꞌa̱jtʉn ꞌyity mʉt ja ꞌyUꞌunkkyʉjxm.
\v 12 Diꞌibʉ ꞌyaxá̱jʉp ja Jesús éxtʉm ja Diosʉ ꞌyUꞌunk, myʉda̱jtypyʉ tya̱dʉ jikyꞌa̱jtʉn. Per diꞌibʉ kyaj tꞌaxa̱jʉ Jesús éxtʉm ja Diosʉ ꞌyUꞌunk, kyaj tmʉdatyʉ tya̱dʉ jikyꞌa̱jtʉn.
\s1 Ka̱jxwíjʉn esʉ ka̱jxpoꞌxʉn
\p 
\v 13 Nnija̱ꞌa̱yʉdʉpts miits diꞌibʉ myʉbʉjktʉp ja Diosʉ ꞌyUꞌunk, es xyñijáwʉdʉt ko xymyʉdattʉ ja jikyꞌa̱jtʉn winʉ xʉʉ winʉ tiempʉ.
\p 
\v 14 Kyaj ndsʉꞌk nja̱ꞌa̱m ko nꞌamdoꞌom tii ja Dios, mʉt ko nnija̱ꞌa̱m ko ti nꞌamdoꞌom diꞌibʉ ijtp tiꞌigyʉ diꞌibʉ yʉꞌʉ tsyejpy, yʉꞌʉ xymyʉdoꞌom.
\v 15 Es mʉt yʉꞌʉyʉ ko xymyʉdoꞌom, nnija̱ꞌa̱m ko xymyoꞌoyʉmʉ naty diꞌibʉ nꞌamdoꞌom.
\p 
\v 16 Pʉn ꞌyijxypy ko tuꞌugʉ myʉguꞌuk ttuñ ja peky diꞌibʉ kyaj myʉnejxyʉty ma̱ ja oꞌkʉn, waꞌan tka̱jxtaꞌaky ma̱ Dios kʉdiibʉ ꞌyoogʉt. Jaꞌa ko taa yʉ peky diꞌibʉ mʉnʉjxp ma̱ ja oꞌkʉn, es mʉdʉ tya̱dʉ peky kyajts njʉna̱ꞌa̱ñ es kya̱jxta̱ꞌa̱gʉt yʉꞌʉgyʉjxm.
\v 17 Tʉgekyʉ axʉʉkpʉ yʉꞌʉ dʉn peky. Es taa yʉ peky diꞌibʉ kyaj myʉnejxy ma̱ ja oꞌkʉn.
\p 
\v 18 Nnija̱ꞌa̱m ko diꞌibʉ myʉda̱jtypy ja Dios éxtʉmʉ Tyeety, kyaj pyekytyuunꞌadʉꞌʉtsy, mʉt ko Diosʉ ꞌyUꞌunk tkwentʉꞌaty diꞌibʉ Dios jyaꞌaꞌa̱jtypy, es kyaj ja mʉjkuꞌugópk wiꞌix tyúñʉty.
\p 
\v 19 Nnija̱ꞌa̱m ʉdsa̱jtʉm ko Dios xyjaꞌaꞌa̱jtʉm esʉ mʉjkuꞌugópk yʉꞌʉ jaꞌaꞌa̱jtʉdʉp tʉgekyʉ diꞌibátyʉ naxwíñʉdʉ winma̱ꞌa̱ñ jaꞌaꞌa̱jtʉdʉp.
\p 
\v 20 Es nnija̱ꞌa̱m nandʉꞌʉn ko ja Diosʉ ꞌyUꞌunk tʉ myiñ es tʉ xymyoꞌoyʉm yʉ nwinma̱ꞌa̱ñꞌa̱jtʉm es nꞌixyꞌa̱jtʉm ja Dios. Nꞌijtʉm tiꞌigyʉ mʉt ja Dios es mʉt ja ꞌyUꞌunk Jesukristʉ. Tyʉyꞌa̱jtʉnʉty ko yʉꞌʉdyʉ Dios, es yʉꞌʉ dʉꞌʉn yajkypy ja jikyꞌa̱jtʉn winʉ xʉʉ winʉ tiempʉ.
\v 21 Nitítʉty, éxkʉm ko xywyindsʉꞌʉgʉdʉt diꞌibʉ kyaj Dyiosꞌaty.
