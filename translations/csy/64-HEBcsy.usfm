\id HEB - SYN- Siyin Bible 
\h HEBREW 
\toc1 HEBREW 
\toc2 Hebrews 
\toc3 Heb 
\mt1 HEBREWS TE  
\mt1 Laithak  
\mt2 Hebrews  
\c 1  
\s1 Jesus Sia Kamsang te Sang in Tungnung Zaw  
\p
\v 1 A bosa hun tatuam sung, kamsang te tungtawn in pu le pa te tungah paupuina tatuam taw thu a hil Pathian in,   
\p
\v 2 Hi ni tawpkhak sungah a Tapa tungtawn in eite tungah thu hong hil hi, Ama sia na theampo ngamhlua tu in a kikoi hi a, Ama tungtawn in leitung zong vawt hi;   
\p
\v 3 Ama sia Pathian minthanna i khuavak le Ama hina lim a kilangsak pa a hihi, vangletna taw a kidim a kammal taw na theampo khotak in len a, eite mawna theampo sia Ama tatak in hong thianthosak zawkciang, a sang na mun, Vanglian pipa ziatsang ah to hi;   
\s1 Jesus Vantungmi te sang in Sang Zaw  
\p
\v 4 Vantung mite sang in a sangzaw min ngamh lua ahikom in, vantungmi te sang in tampitak a phazaw in vawt hi.   
\p
\v 5 \x - \xo 1:5 \xt Ps 2:7; \xt 2Sam 7:14; 1Khang 17:13.\x*Banghangziam cile, nangma sia ka Tapa na hihi, tu ni in kong nei zo hi, ci ahizong, keima sia Ama i Pa ka hi tu hi, taciang Ama sia ka Tapa hi tu hi, ci in vantungmi te tungah banghun in ci ngei ziam?   
\p
\v 6 \x - \xo 1:6 \xt Thuhlk 32:43\x*Taciang tapa lianbel sia hi leitung ah a tumpui ciang in, Pathian i vantungmi theampo in Ama bia tahen, ci kik hi.   
\p
\v 7 \x - \xo 1:7 \xt Ps 104:4\x*Taciang vantungmi te thu sia, Ama in vantungmi te sia thaa in vawt hi, ci le, Ama naseam te sia meikuang in vawt hi, ci hi.   
\p
\v 8 \x - \xo 1:8 \xt Ps 45:6, 7.\x*Ahihang Tapa tung ah, maw Pathian awng, na kumpi tokhum sia kumtawn hi a: na ukna ciangkhut sia thutang suana ciangkhut a hihi, ci hi.   
\p
\v 9 Nangma in thutang suana na dei a, siatna na ensan hi; tua ahikom Pathian awng, na Pathian in na lawmte sang tungnung zaw lungdamna sathau hong buak zo hi.   
\p
\v 10 \x - \xo 1:10 \xt Ps 102:25-27\x*Taciang, Topa awng, nangma in a kipatcil in leitung zungpi na koi hi; taciang van te zong na khut i vawt te a hihi:   
\p
\v 11 Amate mangthang tu hi; ahizong nang na om tawntung hi; taciang amate puan bang in lui siat tu hi;   
\p
\v 12 Taciang nangma in puan bang in na zial tu a, amate ki lai tu hi: ahihang nang sia nangma ngei bangma na hihi, taciang na kum te bo hun nei ngawl hi.   
\p
\v 13 \x - \xo 1:13 \xt Ps 110:1\x*Taciang, na ngal te na peang koina in ka vawt mateng ka ziatsang ah to in, ci in vantungmi te tungah banghun ci ngei ziam?   
\p
\v 14 Vantungmi te sia ngupna ngamhlua tu te i na sepsak tu in sawltak naseam thaa te hi ngawl ziam?   
\c 2  
\s1 A Vanglian Ngupna  
\p
\v 1 Tua ahikom i zaksa thu te i bosua kik nawn ngawl natu hanciam in i kidawm seseam tu hi.   
\p
\v 2 Banghangziam cile vantung mite i pau kammal te kho a, thukham paltan le thu nit ngawl nate in a thutang thukkikna i thaman sang hi;   
\p
\v 3 A kipatcil lai in Topa in son zo a, a za te i a kipsak hibangza a lian ngupna thu thusimngawl in i om le, bangbang in suakta thei tu hi ziam;   
\p
\v 4 Pathian in zong musakna te le nalamdang tampi, nalamdang tatuam le Tha Thiangtho letsong te taw Ama deina bang in tettipang hi.   
\s1 Jesus, Ngupna Sungah Hong Lampui  
\p
\v 5 Banghangziam cile i sonsa hongpai pheang tu leitung uk tu in vantungmi te koi ngawl hi.   
\p
\v 6 \x - \xo 2:6 \xt Ps 8:4-6\x*Ahihang mi khat in munkhat ah, nong phaw natu in mihing sia bang hi thong ziam? a hibale, mihing tapa sia nangma in banghang ve nuam ni ziam?   
\p
\v 7 Nangma in vantung mite sang in tawm a niam zaw hiat in na vawt a; minthanna le zatakna na khusak hi, taciang na khut i nasep nate tungah na koi hi:   
\p
\v 8 Na theampo a peang nuai ah na koi hi, ci in tettipang hi. Banghangziam cile, na theampo a peang nuai ah koi hi a ci ciang, a peang nuai ah a koi ngawl khat zong om ngawl hi. Ahihang, a peang nuai ah na theampo koi hi, ci sia tu in i mu balai hi.   
\p
\v 9 Ahihang Pathian thuthiamna tungtawn in, mihing theampo atu thina tep tu in, vantungmi te sang in tawm a niamzaw in vawt a, thina a thuak hu in minthanna le zatakna a khuhsak Jesus i mu hi;   
\p
\v 10 Banghangziam cile Ama atu le Ama hang in na theampo om a, tapa tampi minthanna sungah tumpui tu ahizong, amate ngupna sia thuakna tungtawn in a khuangkhim thei natu ahizong, Ama sia makai a hi hamtang kul hi.   
\p
\v 11 Banghangziam cile a thiangthosak pa le a thianthosak te sia pum khat a hihi: tua ahikom ama in suapui te awng, ci in sap tu sia a mai a zum bua hi,   
\p
\v 12 \x - \xo 2:12 \xt Ps 22:22\x*Ka suapui te tungah na min ka pualak tu hi, mipi te sungah nangma pokna la ka sa tu hi, ci hi.   
\p
\v 13 \x - \xo 2:13 \xt Isa 8:17; \xt Isa 8:18\x*Taciang, ama sungah ka muanna ka koi tu hi, ci kik hi. Taciang, en vun, keima le Pathian i hongpiak tate, zong cikik lai hi.   
\p
\v 14 Tua tate in cilesa le thisan kibanpui a hibangma in, Ama zong thina tungtawn in thina i vangletna, doaimangpa a suksiat thei natu ahizong;   
\p
\v 15 Taciang nuntak sung theampo thina lau in sal taang te ngum tu in ahizong, cilesa le thisan neipui te ma a hihi.   
\p
\v 16 \x - \xo 2:16 \xt Isa 41:8, 9\x*Banghangziam cile a tatak ciciang Ama in vantung mite panpui ngawl a; Abraham i suan te panpui zaw hi.   
\p
\v 17 Tua ahikom mihing te mawna atu thin-uk thaina vawt tu in Pathian taw kisai nate sungah, hesuak thei le a muantak thiampi sang a hi thei natu in, na theampo sungah suapui te bang in vawt kul hi.   
\p
\v 18 Banghangziam cile Ama tatak in ze-etna a thuak hu in, ze-etna a thuak te hu thei hi.   
\c 3  
\s1 Jesus Moses Sang in Lian Zaw  
\p
\v 1 Tua ahikom, vantung sapna a nei a thiangtho suapui te awng, sawltak le ka pualak uh Thiampi Sang Christ Jesus thu ngaisun vun;   
\p
\v 2 \x - \xo 3:2 \xt Ngam 12:7\x*Moses sia Pathian i innkuan theampo tungah thuman in a om bangma in, Jesus zong ama nasep a pia pa tungah thuman in om hi.   
\p
\v 3 Banghangziam cile inn sate sia inn sang in upatna a tamzawk bangma in, Jesus zong Moses sang in minthanna tamzaw a nga tu kilawm hi, ci ngaisut tu a hihi.   
\p
\v 4 Banghangziam cile inn theampo sia mi khatpo i a sak a hihi; a hihang Pathian sia na theampo a sa pa a hihi.   
\p
\v 5 Moses sia maisang ah a ki son kik tu nate atu tetti hi tu in, Pathian innkuan theampo tungah thuman takpi hi;   
\p
\v 6 A hihang Christ sia tapa bang in Ama innkuan i tungah thuman hi; eite zong ki muanna le lametna hang in lungdamna sia a tawp dong khotak in i len le tua innkuan i hihi.   
\s1 Na Thinpuisak Heak Vun  
\p
\v 7 \x - \xo 3:7 \xt Ps 95:7-11\x*Tua ahikom Thaa Thiangtho in, tu ni in Ama aw na za uh ahile,   
\p
\v 8 Senneal ngam sung ze-etna ni sungah Pathian thin-ukna bang in, na thin uh sahsak heak vun:   
\p
\v 9 Na pu le pa te in kum sawmli sung ka nasep te mu a, hong ze-et in, hong sin uh hi.   
\p
\v 10 Tua ahikom tua suan te tungah ka thin na hi, amate in ka lampi te he ngawl a; a thinsung uh ah a tawntung in khial tawntung uh hi, ci hi.   
\p
\v 11 Tua ahikom amate sia ka tawlngakna sungah tum ngawl tu hi, ci in ka thin-ukna taw ka kiciam hi.   
\p
\v 12 Suapui te awng, note zong a nungta Pathian kung pan na tai uh a, up ngawlna thinsung phangawl na nei thei ngawl natu uh in kidawm vun.   
\p
\v 13 Ahihang mawna i theamna tungtawn in na thinsung uh a sah ngawl natu in, tu ni, a kici hun sungah nisim khat le khat ki hanthawn tavun.   
\p
\v 14 Banghangziam cile eite ki muanna ah a kipat pan kipan a tawp dong i kho ahile, Christ taw a neikhawm tu in a kivawt te i hihi;   
\p
\v 15 \x - \xo 3:15 \xt Ps 95:7, 8\x*Tuni in Ama aw na za uh le, Pathian i thin-ukna tu na ngamtat lai uh bang in, na thin uh sahsak heak vun, ci hi.   
\p
\v 16 \x - \xo 3:16 \xt Ngam 14:1-35\x*Banghangziam cile amate in a zak zawk uh ciang zong, a thin-uksak te sia Moses tungtawn in Egypt ngam pan a pusuak te theampo ma hi ngawl ziam.   
\p
\v 17 Ahihang kum sawmli sung kuate tung a thinna ziam? mawna vawt a, senneal ngam ah puk in a thi te hi ngawl ziam?   
\p
\v 18 Taciang a kuate tungah ka tawlngakna sungah tum ngawl tu nu hi, ci in kiciam ziam, a um ngawl te tungah hi ngawl ziam?   
\p
\v 19 Tua ahikom, amate sia up ngawlna hang in tum thei ngawl hi, ci i mu hi.   
\c 4  
\p
\v 1 Tua ahikom Ama tawlngakna sungah tum tu in hong kamciam om nginge napi, note sung pan a theng ngawl khatpo na om thak ngawl natu uh kidawm tek tawng.   
\p
\v 2 Banghangziam cile eite tungah lungdamna thu hong ki hil sa bangma in, amate tungah zong ki hil zo hi: a hihang a zak thu uh upna taw a ngawm ngawl uh hu in Pathian thu pualakna sia amate atu in phattuamna om ngawl hi.   
\p
\v 3 \x - \xo 4:3 \xt Ps 95:11\x*Banghangziam cile ei a umte sia tawlngakna sungah i tum hi, tua tawlngakna taw kisai in leitung i zungpi a phu pan kipan nasep man thiang zo napi, ka thin-ukna taw ka kiciam bang in amate ka tawlngakna sungah tum ngawl tu hi, ci sonkhol hi.   
\p
\v 4 \x - \xo 4:4 \xt Pian 2:2\x*Banghangziam cile ni sali ni taw kisai in munkhat ah hibang in son hi, Pathian sia a nasep theampo pan in ni sali ni in tawlnga hi.   
\p
\v 5 Taciang hi mun ah, amate ka tawlngakna sungah tum ngawl tu hi, ci kik hi.   
\p
\v 6 Tua ahikom mi pawlkhat te tua sungah tum thei tu in tawlngakna om nginge lai hi, taciang lungdamna thupha hilna a za masabel te sia up ngawl na hu in tum ngawl hi:   
\p
\v 7 \x - \xo 4:7 \xt Ps 95:7, 8\x*Tu ni in Ama aw na za uh le, na thin uh sahsak heak vun, a ci bangma in, hun saupi zawkciang, Tu ni, ci in David tungtawn in a son nikhat koi in ciamte hi, zong ci kik lai hi.   
\p
\v 8 \x - \xo 4:8 \xt Thuhilk 31:7; Jos 22:4\x*Banghangziam cile, Joshua in amate sia tawlngakna pia zo ahile, tua zawkciang in, ni dang thu son kik nawn ngawl tu hi.   
\p
\v 9 Tua ahikom Pathian i mihing te atu in tawlngakna sia omlai hi.   
\p
\v 10 \x - \xo 4:10 \xt Pian 2:2\x*Banghangziam cile Ama tawlngakna sungah a tum peuma, Pathian sia a nasep pan a tawlngak bangma in, ama zong ama nasep te pan in tawlnga hi.   
\p
\v 11 Tua ahikom up ngawl na hang in a pukte ette in i puk batu a, tawlngakna sungah i tum thei natu in hanciam tek tawng.   
\p
\v 12 Banghangziam cile Pathian thu sia nungta hi, taciang vangletna taw kidim a, lang ni hiam namsau sang in hiam zaw hi, nuntakna le thaa, ngu le taang le ngungeak te zong sunlet in ki khensak hi, taciang thinsung i ngaisutna le ngealna te zong a he pa a hihi.   
\p
\v 13 Ama mai ah a bitphua sate a kilang ngawl khat zong om nagwl hi: ahihang eite thu hong khen pa i mu na ah na theampo sia pum nguak le a ki hongsa hi siat hi.   
\s1 Jesus Thiampi Sang  
\p
\v 14 Vantung ah a pai zo, a lian thiampi sang, Pathian Tapa Jesus nei i hikom, i hil sa thu te khotak in len tawng.   
\p
\v 15 Banghangziam cile i nei thiampi sang sia i thaneamna te hong thuakpui thei ngawl hi ngawl hi; eite bangma in ze-etna tatuam thuak napi, maw ngawl hi.   
\p
\v 16 Tua ahikom hesuakna i nga thei natu le, i kisap hun in thuthiamna i nga thei natu in, thuthiamna kumpi tokhum mai ah hangsantak in zuan tawng.   
\c 5  
\p
\v 1 Banghangziam cile thiampi sang te sia mihing sung pan in a kiteal hi a, letsong te le mawna atu biakpiakna te Pathian tungah mihing te atu a pia tu in nasep a ki pia te a hihi.   
\p
\v 2 Ama in a mealmawl te le lampial te tungah hesuak theina nei hi; banghangziam cile ama tatak zong thaneamna in kiimum hi.   
\p
\v 3 \x - \xo 5:3 \xt Thiam 9:7\x*Hi thu hang in ngual mawna atu biakpiakna piaksak a kul bangma in, ama mawna atu zong biakpiakna piak tu kisam veve hi.   
\p
\v 4 \x - \xo 5:4 \xt Ex 28:1\x*Aaron bang in Pathian sapna a sang te simngawl, kuama in hi upatna sia ama atu in la ngawl hi.   
\p
\v 5 \x - \xo 5:5 \xt Ps 2:7\x*Tasia bangma in Christ zong thiampi sang a suak tu in ama le ama ki minthangsak ngawl hi; ahihang ama tung ah, Nangma sia ka Tapa na hihi, tu ni in kong nei zo hi, ci hi.   
\p
\v 6 \x - \xo 5:6 \xt Ps 110:4\x*Mundang khat sung zong ah, nangma sia Melchizedek bang in tawntung thiampi na hihi, ci hi.   
\p
\v 7 \x - \xo 5:7 \xt Matt 26:36-46; Mk 14:32-42; Lk 22:39-46.\x*Ama sia cilesa taw a omlai in, thina pan ama a ngum thei pa tungah nasiatak au in thitui taw a thungetna le ama atu thungetna te a vawt ciang in, Pathian a zatak hu in a thungetna za hi;   
\p
\v 8 Ama sia Tapa hi napi, a thuakna te pan in thunitna sin hi;   
\p
\v 9 Taciang Ama a cialcin zawkciang in, thu ni te theampo atu in tawntung ngupna i kipatna hong suak a;   
\p
\v 10 Pathian in ama sia Melchizedek pan a kilua susuk thiampi in saang hi.   
\s1 Tha Lam Picinna  
\p
\v 11 Melchizedek thu note kong son nop tam mama om napi, note sia thu hehak mama na hi uh hu in thu son tu haksa mama hi.   
\p
\v 12 \x - \xo 5:12 \xt 1 Cor 3:2\x*Banghangziam cile hun te zong ngei zo ahi bangma sya na sep tu uh kilawm zo napi, Pathian kammal te sia a kipat pan in hil na kul lai uh a, antak ne zo ngawl lai in noai bek a dawn te na hi uh hi.   
\p
\v 13 Banghangziam cile noai bek a nete sia nausen ahikom in, thutang suana thu sungah bangma thiamna nei ngawl lai hi.   
\p
\v 14 Ahihang antak sia a picing te atu hi a, amate sia a thu ngaisutna te le a heakna te a zak uh hu in a pha le phangawl zong khentel thei uh hi.   
\c 6  
\p
\v 1 Tua ahikom Christ thuhilna a kipatna te nusia in, a thi nasep te pan in maw ki sikkikna, taciang Pathian sangah upna,   
\p
\v 2 Tui kiphumna taw kisai hilna te le khut ngakna thu, taciang mithi te thawkikna le tawntung thukhenna, hi bitphuana thu te kan kik nawn ngawl in, picinna sangah mainawt seseam tawng.   
\p
\v 3 Pathian in hong oai ahile hi thu te i seam tu hi.   
\p
\v 4 Banghangziam cile khuavak sungah khatvei a theng te, vantung letsong zong tep zo a, Tha Thiangtho zong neikhawm in a ki vawt te,   
\p
\v 5 Taciang Pathian thupha le hongpai pheang tu leitung i vangletna te tep zo hi napi,   
\p
\v 6 Amate a puk le, Pathian Tapa sia thinglamte tungah khai kik a, a kilangtak in maizumsak kik a hi uh hu in, maw kisikkikna taw thaksua kik tu suak thei ngawl hi.   
\p
\v 7 Banghangziam cile leitung in a tungah a zu nguatui dong a, lotho te atu in ante tatuam a piangsak leitung sia Pathian kung pan in thupha sang hi:   
\p
\v 8 \x - \xo 6:8 \xt Pian 3:17, 18\x*Ahihang lingkung a tatuam a piangsak leitang sia thaw thamman ngawl hi, taciang hamsiat nataw ki nai mama a, meisung halna taw tawp tu hi.   
\p
\v 9 Ahizong, ka it te awng, tabang in son ka hihang, note sia ngupna thu taw kisai a phazaw nate na seam tu uh hi, ci in kong um hi.   
\p
\v 10 Banghangziam cile note in Pathian min taw mithiangtho te na khoi ngei uh a, tu zong na khoi na uh hang ahizong, na sep na uh le itna taw na sep na uh te ahizong, a mangil thong tu in Pathian sia mi thutang ngawl hi ngawl hi.   
\p
\v 11 Taciang note khatsim in thinkhona a dim lametna taw a tawp dong hanciamna a kilangsak hi tu in kong deisak uh hi:   
\p
\v 12 Tabang in note sia thaneam ngawl in, upna le thinsauna tungtawn in kamciam sang te nungzui te na hi tu uh ka dei uh hi.   
\s1 A Thuman Pathian Kamciam  
\p
\v 13 Banghangziam cile Pathian in Abraham tungah kamciam a vawt lai in, Ama sang a lianzaw om ngawl ahikom, Ama le Ama taw kiciam a,   
\p
\v 14 \x - \xo 6:14 \xt Pian 22:16, 17\x*Thupha kong pia tu hi, taciang kong pungsak takpi tu hi, ci hi.   
\p
\v 15 Taciang thinsautak in a thuak zawkciang in, tua kamciam sang hi.   
\p
\v 16 Banghangziam cile mihing te in, a tatak in amate sang a lianzaw te zang in kiciam hi: taciang a ki kipsak kiciamna sia amate tungah kinialna theampo i tawpna a hihi.   
\p
\v 17 Hi mun ah Pathian in a ngaisutna a lai thei ngawl na thu sia, a kamciam sang te tungah a dimlet in kilangsak seseam nuam ahikom, a kiciamna taw kipsak a:   
\p
\v 18 Tua thu sia a ki kheal thei ngawl nam ni, Pathian sia leilot thu son tu in suak thei ngawl a hina le, eite mai ah a koi lametna len tu in bel natu mun lamsang a tai te in a thahat henepna i nei thei natu a hihi:   
\p
\v 19 \x - \xo 6:19 \xt Thiam 16:2\x*Tua i nei lametna sia i nuntakna i thikkapui bang in a muanhuai le a kip hi a, tasia sia ki dalna puanpi sungah tum hi;   
\p
\v 20 \x - \xo 6:20 \xt Ps 110:4\x*Tua mun ah lamlak Jesus sia eite atu in tum hi, Ama sia Melchizedek bang in tawntung thiampi sang in vawt hi.   
\c 7  
\s1 Thiampi Melchizedek  
\p
\v 1 \x - \xo 7:1 \xt Pian 14:17-20\x*Banghangziam cile hi Melchizedek sia, Salem kumpi, a sangbel Pathian i thiampi hi a, ama in kumpi te a thalupna pan in hong cia kik Abraham muak in, thupha pia hi;   
\p
\v 2 Ama tungah Abraham in se sawm sua se khat zong pia hi; a masabel in a min khiatna sia thutang suana Kumpi kici a, tua zawkciang in Salem Kumpi, a khiakna sia thinnopna Kumpi a hihi;   
\p
\v 3 Ama sia pa nei ngawl, nu nei ngawl, pu le pa khang nei ngawl, kipatna ni le nuntakna a tawpna zong nei ngawl hi; ahihang Pathian Tapa bang in a ki vawt hi a; tawntung thiampi in om nginge hi.   
\p
\v 4 Tu in hisia pa sia bangza in thupi, ci sia ngaisun vun, minam kipatna i pu Abraham na ngawn ngal te van a laksak te sung pan in se sawm sua se khat pia hi.   
\p
\v 5 \x - \xo 7:5 \xt Ngam 18:21\x*Thiampi hina a nga Levi tapa te in mipi te tung pan in se sawm sua se khat nga thei natu in thupiak nei takpi hi, amate i suapui te sia Abraham sung pan a suak te a hihi:   
\p
\v 6 Ahihang Levi minam sung a kisimngawl Melchizedek in Abraham tung pan in se sawm sua se khat sang a, kamciam te a nei Abraham thupha pia hi.   
\p
\v 7 A nozaw sia a lianzaw in thupha a piak sia nial natu bangma om ngawl hi.   
\p
\v 8 Taciang hi mun ah a thi thei mihing te in se sawm sua se khat sang hi; ahihang tua mun ah a nungta hi, ci in tettipanna pa in se sawm sua se khat sang hi.   
\p
\v 9 Taciang se sawm sua se khat a sang Levi zong Abraham sung pan in se sawm sua se khat pia hi, i ci thei hi.   
\p
\v 10 Banghangziam cile Melchizedek in Abraham a mu lai in Levi sia a pa sungah omlai hi.   
\s1 Jesus Aaron Sang in Thupizaw  
\p
\v 11 Tua ahikom Levi i a thiampi hina taw kisai mihing te in thukham sang uh ahikom, tua minam tungtawn in picinna ah theng thei hile, Aaron bang thiampi dang sam ngawl in Melchizedek bang a dang thiampi banghang kul tu ziam?   
\p
\v 12 Banghangziam cile thiampi hina lai zo ahikom in, thukham zong lai kul hamtang hi.   
\p
\v 13 Banghangziam cile hi a son uh sia phungdang pan hi a, tua phung sungah kuama in biaktau ah naseam ngei ngawl hi.   
\p
\v 14 Banghangziam cile i Topa sia Judah sung pan in hong piang hi, ci kilang hi; tua phung sia Moses in thiampi a hina taw kizui in bangma son ngawl hi.   
\p
\v 15 Banghangziam cile Melchizedek bang a dang thiampi hong piang ahikom thiampi minam kilai zo hi, ci hong kilang seseam hi,   
\p
\v 16 Tua thiampi sia cilesa thupiakna bang in a kivawt hi ngawl a, a mong nei ngawl nuntakna i vangletna bang in a kivawt a hihi.   
\p
\v 17 \x - \xo 7:17 \xt Ps 110:4\x*Banghangziam cile, nangma sia Melchizedek bang in tawntung thiampi na hihi, ci in ama in tettipang hi.   
\p
\v 18 Banghangziam cile nidang lai a ki pia thupiak sia thaneam le phatuam ngawl ahikom, kivawk takpi hi.   
\p
\v 19 Banghangziam cile thukham in bangma kicingsak ngawl hi, ahihang a phazaw lametna hong paipui a; tua lametna taw Pathian kungah i neak thei hi.   
\p
\v 20 Taciang ama sia thukham om ngawl in thiampi a ki suaksak hi ngawl hi:   
\p
\v 21 \x - \xo 7:21 \xt Ps 110”4\x*Banghangziam cile tua thiampi te sia thukham om ngawl in thiampi a ki suaksak te a hihi; ahihang Jesus sia thukham taw ahikom in, Topa in kiciam a, ki sikkik ngawl tu hi, nangma sia Melchizedek bang in tawntung thiampi na hihi, ci hi:   
\p
\v 22 Tabang in Jesus sia a phazaw kamciam kipsak pa hong suak hi.   
\p
\v 23 Taciang amate thiampi tampi om takpi hi, banghangziam cile thina hang in thiampi seam paisuak thei ngawl hi:   
\p
\v 24 Ahihang Jesus sia nungta paisuak ahikom a ki lai thei ngawl thiampi hina nei hi.   
\p
\v 25 Tua ahikom Ama tungtawn in Pathian kung a pai te sia a tawpdong in ngum thei a, amate atu thungetsak tu in a tawntung in nungta hi.   
\p
\v 26 Banghangziam cile, tabang in a thiangtho, mawna nei ngawl, a niin ngawl, mawnei te taw omkhawm ngawl le van sang a sang zaw in a vawt thiampi sang sia eite atu hong suak hi;   
\p
\v 27 \x - \xo 7:27 \xt Thiam 9:7\x*Ama sia, tua thiampi sang te in, amate mawna atu biakpiakna pia masa a, tua zawkciang in mipi atu a pia te bang in nisim piak kul ngawl hi: banghangziam cile Ama le Ama biakpiakna a kipiak ciang in khatvei taw man hi.   
\p
\v 28 Banghangziam cile thukham in thaneamna a nei mihing te thiampi sang in vawt hi; ahihang thukham pan kipan in a kiciamna thu in tawntung kicinna Tapa sia thiampi sang in vawt hi.   
\c 8  
\s1 Jesus Thuciamthak Thiampi Sang  
\p
\v 1 \x - \xo 8:1 \xt Ps 110:1\x*Tu in i son sa thu te sungah a thupibel sia: vantung ah Vangletna kumpi tokhum ziatsang ah a to thiampi sang i nei hi;   
\p
\v 2 Mihing i sak hi ngawl Topa i sak a maan biakbuk le mun thiangtho sungah naseam pa a hihi.   
\p
\v 3 Banghangziam cile thiampi sang peuma sia letsong te le biakpiakna te pia tu in nasep piak te a hihi: tua ahikom hisia pa in zong a piak tu khatpo a piak tu a nei hamtang kul hi.   
\p
\v 4 Ama sia leitung ah om hile, thiampi hi ngawl tu hi, banghangziam cile thukham taw kizui in letsong pia tu thiampi te om hi:   
\p
\v 5 \x - \xo 8:5 \xt Ex 25:40\x*Amate in vantung nate i a ette tu le lim atu in naseam hi, banghangziam cile, Moses in biakbuk a sak tu ciang in, mualtung ah kong lak sa lim bang in na theampo vawt in, ci in hil hi.   
\p
\v 6 Ahihang tu in Ama sia a phazaw kamciam te tungah dinmun phazaw kamciam i palai ahi hu in a phazaw Pathian nasep nga zo hi.   
\p
\v 7 Banghangziam cile a masa thuciam sia bangma khialna om ngawl ahile, a ni na zon kul natu thu om ngawl hi.   
\p
\v 8 \x - \xo 8:8 \xt Jer 31:31-34\x*Banghangziam cile a hilna a mu na uh ah Topa in, en vun, Israel innkuan le Judah innkuan taw thuciam thak ka vawt tu ni hong theng zo hi:   
\p
\v 9 Egypt ngamsung pan in amate ka khut taw kai in ka paipui a, a pu le pa te taw ka vawt thuciam bang in hi ngawl hi; banghangziam cile ka thuciam sungah a om paisuak ngawl uh hu in, amate bangma thusimngawl khi hi, Topa in ci hi.   
\p
\v 10 Banghangziam cile tua ni te zawkciang, Israel innkuan taw thuciam vawt tu khi hi, ka thukham te sia amate thinsung ah ka koi tu a, taciang amate lungtang tungah ka at tu hi: taciang keima sia amate Pathian ka hi tu a, amate sia ka mihing te hi tu hi, Topa in ci hi:   
\p
\v 11 Taciang amate in a innpam le a suapui te sia, Topa he tavun, ci in hil ngawl tu hi: banghangziam cile a nobel pan a lianbel dong in keima hong he tu uh hi.   
\p
\v 12 Banghangziam cile keima in amate thutan ngawl na sungah ka hesuak tu hi, taciang amate mawna te le phatngawlna te ka phawkkik nawn batu hi.   
\p
\v 13 Thuciam thak, a ci ciang in a masa thuciam sia a lui suaksak hi. Tu in a tul le a lui va-ial sia sia hai ngawl in bo tu in ki thoai zo hi.   
\c 9  
\s1 Thuciam Lui Biakbuk  
\p
\v 1 Tuazawkciang thuciam masa zong Pathian nasepna ah biakna ngeina te le leitung mun thiangtho nei hamtang hi.   
\p
\v 2 \x - \xo 9:2 \xt Ex 26:1-30; \xt Ex 25:31-40; \xt Ex 25:23-30.\x*Banghangziam cile a masa in biakbuk sa a, a sungah khuaimei, sabuai le anluum thiangtho te om hi; tasia sia mun thiangtho kici hi.   
\p
\v 3 \x - \xo 9:3 \xt Ex 26:31-33\x*Taciang kidalna puan ni na i nungsang ah a thiangthobel a kici biakbuk om hi;   
\p
\v 4 \x - \xo 9:4 \xt Ex 30:1-6; \xt Ex25:10-16; \xt Ex 16:33; \xt Misim17:8-10; \xt Ex 25:16; Thuhlkk 10:3-5.\x*Tua sungah ngim namtui halna kham kuangdal, kham taw a kizut thukham thingkuang, tua sungah manna koina kham beal, a dawnmoi a meang Aaron ciangkhut le thukham suangpheak te om hi;   
\p
\v 5 \x - \xo 9:5 \xt Ex 25:1-22\x*Taciang a tungah hesuakna tokhum vangletna taw a liapsak cherubim te om a, tua thu sia tu in a tuan in i son thei bua hi.   
\p
\v 6 \x - \xo 9:6 \xt Misim 18:2-6\x*Tu in hi nate a ki thoai siat zawkciang, thiampi te sia a tawntung in a masabel biakbuk sungah tum a, Pathian nasep seam uh hi.   
\p
\v 7 \x - \xo 9:7 \xt Thiam 16:2-24\x*Ahihang a ni na sungah thiampi sang khat bek kumkhat in khatvei tum a, thisan ngawl taw hi ngawl in, tasia sia ama atu le mipi te mawna atu taw pia hi:   
\p
\v 8 A khatna biakbuk a kip sung theampo mun thiangthobel sung tumna lampi sia kilangsak ngawl hi, ci in Tha Thiangtho in phawksak hi:   
\p
\v 9 Tasia sia tu hun atu in lim a hihi, tua sungah letsong te le biakpiakna a piak nate in, a pia te i khentel theina sia cialcingsak thei ngawl hi, ci musak hi;   
\p
\v 10 Tua neak le dawn, ki thiansuana ngeina a tatuam le cilesa taw kisai biakna dan te sia puaphat hun ciangdong bek kip hi.   
\s1 Christ Thisan  
\p
\v 11 Ahihang Christ sia hong theng pheang tu na pha te i thiampi sang dinmun in hongpai a, khut tawsak ngawl a lianzaw le a kicing zaw biakbuk taw hongpai hi, tasia sia hi inn hi ngawl hi;   
\p
\v 12 Taciang keal le khuino thisan taw zong hi ngawl hi, ahihang Ama thisan tatak taw mun thiangtho sungah khat vei tum a, eite atu in tawntung tatna hong ngasak hi.   
\p
\v 13 \x - \xo 9:13 \xt Thiam 16:15,16; \xt Misim19:9,17-19.\x*Banghangziam cile khuital te le keal te thisan ahizong, khui ki hal te i meivam ahizong, a thiangtho ngawl te a the ciang in cilesa a thiangtho ngawl te thiangthosak thei ahile:   
\p
\v 14 Tawntung Thaa tungtawn in Ama le Ama Pathian mai ah a nin bang ngawl in a ki pia, Christ thisan in a nungta Pathian atu naseam tu in, note i khentel theina sia a thi naseam te pan in bangza in thiangthosak seseam tu ziam?   
\p
\v 15 Tua ahikom a masa thuciam nuai ah thukham paltan nate tatna atu in Christ hong thi a, a sap te in tawntung ngamh kamciam a lua thei natu in, Ama sia thuciam thak i palai a hihi.   
\p
\v 16 Banghangziam cile ngamh lua thei natu thuciam a omna mun ah, ngamhlua thei natu thuciam a pia sia a thi kul hamtang hi.   
\p
\v 17 Banghangziam cile ngamhlua natu thuciam sia thuciam a pia mihing te a thi zawkciang bek in thu nei hi: thu a ciam pa a nuntaksung thu nei ngawl hi.   
\p
\v 18 Tua ahikom amasa thuciam zong thisan om ngawl in thiangthosak ngawl hi.   
\p
\v 19 \x - \xo 9:19 \xt Ex 24:6-8\x*Banghangziam cile Moses in mi theampo tungah thukham bang in thupiak a son zawkciang in, tui taw a ki hel khuino le keal thisan sia tuumul sannum le hyssop taw la hi, taciang laibu le mi theampo tungah the a,   
\p
\v 20 Hisia in Pathian in note vawt tu in hong sawl thisan thuciam a hihi, ci hi.   
\p
\v 21 \x - \xo 9:21 \xt Thiam 8:15\x*Tuabek domngawl in biakbuk le Pathian nasepna atu in a kizang beal theampo thisan the siat hi.   
\p
\v 22 \x - \xo 9:22 \xt Thiam 17:11\x*Taciang na theampo phial thukham bang in thisan taw thiangthosak hi; thisan luang ngawl in maw maina om ngawl hi.   
\s1 Jesus Biakpiakna sia Thuciam Lui Biakpiakna te Sang in Vanglian Zaw  
\p
\v 23 Tua ahikom ette tu lim te sia hite taw thiangthosak tu kisam ahi bangma in; vantung na tatak te sia hi te sang in a phazaw biakpiakna te taw amate le amate thiangthosak hi.   
\p
\v 24 Banghangziam cile Christ sia a tatak te musakna, khut taw a kisa mun thiangtho te sungah tum ngawl hi; ahihang tu in Pathian mai ah eite atu in a kilang vantung tatak ah tum hi:   
\p
\v 25 Thiampi sang sia mun thiangtho sungah a dang thisan taw kumsim a tum bang hi ngawl in, Christ sia ama le ama ki pia tu in tum tawntung ngawl hi;   
\p
\v 26 Tabang hibale, leitung piancil pan kipan in a thuak tawntung kul tu hi: ahihang tu in, hun bo na ah Ama le ama biakpiakna a kipiakna tungtawn in, mawna vawk tu in Ama sia khatvei kilang zo hi.   
\p
\v 27 Mihing sia khatvei thi tu in a ki ciangtan hi a, tua zawkciang in thukhenna thuak tu hi:   
\p
\v 28 \x - \xo 9:28 \xt Isa 53:12\x*Tua ahikom Christ sia mi tampi te mawna pua tu in khatvei biakna i piakna thuak hi; taciang Ama a en te mawna om ngawl ngupna atu in ni vei na kilang kik tu hi.   
\c 10  
\p
\v 1 Banghangziam cile thukham sia hongpai pheang tu na pha te i lim hi a, tua nate pianzia tatak hi ngawl ahikom, a kizom in kum khat zawk kumkhat piak tawntung biakpiakna te in hongpai te sia cialcingsak thei ngei ngawl tu hi.   
\p
\v 2 Tabang hibale biakpiakna te tawlngal siat tu hi ngawl ziam? banghangziam cile a bia te khat vei a ki thiansua zawkciang, amate i khentel theina thinsung ah mawna nei nawn ngawl tu hi.   
\p
\v 3 Ahihang kum sim sangaw biakpiakna te in, mihingte mawna phawksak hi.   
\p
\v 4 Banghangziam cile khuital te le keal te thisan in mawna te a vawksiat tu suak thei ngawl hi.   
\p
\v 5 \x - \xo 10:5 \xt Ps 40:6-8\x*Tua ahikom Christ sia leitung ah hongpai ciang in, biakpiakna le piakna te na dei bua hi, ahihang keima atu in pumpi nong vawtsak khol hi:   
\p
\v 6 Meihal biakna le mawna atu biakpiakna te na lung a kim bua hi, ci hi.   
\p
\v 7 Tuazawkciang in, laibu sungah laizial khat sung keima thu a ki atna mun khat ah, en in, maw Pathian na deina seam tu in kongpai hi, ci hi.   
\p
\v 8 A tungah a kisonsa bang in, thukham bang in a ki vawt te taw kisai Christ in, biakpiakna le piakna, meihal biakpiakna te le mawna atu piakna te tungah lungkimna na nei bua hi, ci hi;   
\p
\v 9 Tuazawkciang in, en vun, maw Pathian awng, na deina seam tu in kongpai hi, ci hi. Ama in a ni na a kipsak thei natu in a khat na sia vawk hi.   
\p
\v 10 Tua deina bang in Jesus Christ in a pumpi sia tawntung atu khatvei a piakna tungtawn in hong thiangthosak zo hi.   
\p
\v 11 \x - \xo 10:11 \xt Ex 29:38\x*Taciang thiampi khatsim in nisim in ding a, a sep ngei biakpiakna te pia in Pathian na seam hi: tua biakpiakna te in mawna vawksak thei ngawl hi:   
\p
\v 12 \x - \xo 10:12 \xt Ps 110:1\x*Ahihang Christ sia mawna te atu in biakpiakna khat kumtawn atu a piak zawkciang in, Pathian ziatsang ah to hi;   
\p
\v 13 Tua pan kipan in a ngal te a peang koina in a vawt mateng, ngak in om hi.   
\p
\v 14 Banghangziam cile a thianthosak te sia Ama in piakna khat tungtawn in a tawntung atu kicingsak zo hi.   
\p
\v 15 Tuabek domngawl in, Tha Thiangtho zong eite tungah tetti a hihi: banghangziam cile Ama in,   
\p
\v 16 \x - \xo 10:16 \xt Jer 31:33\x*Hi thuciam sia tua ni te zawkciang in, amate taw ka vawt tu hi, Topa in ci hi, amate thinsung ah ka thukham te ka koi tu hi, taciang amate lungtang tungah ka at tu hi;   
\p
\v 17 \x - \xo 10:17 \xt Jer 31:34\x*Taciang amate mawna te le phatngawlna te ka phawkkik nawn ba tu hi, ci hi.   
\p
\v 18 Tu in mawmaina a omna mun ah, mawna atu in piakna om nawn ngawl hi.   
\s1 Thu Um te A Thiangthobel Mun ah  
\p
\v 19 Tua ahikom suapui te awng, Jesus thisan tungtawn in a thiangthobel mun ah tum tu in hangsanna i nei hi,   
\p
\v 20 Tua thu sia kidalna puan a kici Jesus pumpi tungtawn in nuntakna lampi thak sia eite atu in hong vawtsak zo a;   
\p
\v 21 Pathian inn sungah thiampi sang i nei hu in;   
\p
\v 22 \x - \xo 10:22 \xt Thiam 8:30; Ezk 36:25\x*I thinsung te sia sia le pha khentel theina phangawl pan in thianthosakna le i pumpi te zong tui thiangtho taw sil thiang zo ahi hu in, thamuanna a dim upna le thinsung mantak taw Ama zuan tek tawng.   
\p
\v 23 I pualak upna kilok ngawl in, khotak in len tawng; banghangziam cile a kamciam sa sungah Ama sia thuman hi;   
\p
\v 24 Taciang itna le nasep pha te seam tu in hanthotna lam ah khat le khat ki ngaisutsak tawng:   
\p
\v 25 Mi pawlkhat te ngeina bang in i kikhopna tawlnga thong ba tawng; khat le khat ki hanthawn tawng: taciang a ni hong nai seseam zo hi, ci na heak uh hu in, nasiatak in ki hanthawn seseam tavun.   
\p
\v 26 Banghangziam cile thuman heakna i nga zawkciang in i maw kaltang ahile, mawna atu biakpiakna om kik ngawl hi,   
\p
\v 27 \x - \xo 10:27 \xt Isa 26:11\x*Ahihang a lauhuai thukhenna le a langpan te a kangtum thin-ukna meikuang et tu bek om lai hi.   
\p
\v 28 \x - \xo 10:28 \xt Thuhlk 17:6; 19:5\x*Moses thukham a thusimngawl te sia tetti ni le thum a om ahile hesuakna om ngawl in thi hi:   
\p
\v 29 \x - \xo 10:29 \xt Ex 24:8\x*Tuabek domngawl in, Pathian Tapa a peang nuai ah a sik te, ama a thiangthosak thisan thuciam sia a thiangtho ngawl in a ngaisun te le thuthiamna Thaa a thusimngawl te bangza a nasia zaw dan thuak tu kilawm in ngaisun nu ziam?   
\p
\v 30 \x - \xo 10:30 \xt Thuhlk 32:35; \xt Thuhlk 32:36\x*Banghangziam cile, phulamna sia keima a hi, keima in thukkik tu khi hi, Topa i a ci sia eite in i he tek hi. Taciang Topa in Ama mihing te thukhen tu hi, ci kik lai hi.   
\p
\v 31 A nungta Pathian khutsung ah taksuk tu lauhuai mama hi.   
\p
\v 32 Ahihang khuavak na nga zawk uh ciang, nasiatak in haksatna na thuak ngei uh, a bosa hun te phawkkik tavun.   
\p
\v 33 Note sia ngual muna ah vawtsiatna le haksatna na thuak uh hun om a, midang te taw na thuak khop uh hun zong om hi.   
\p
\v 34 Banghangziam cile ka koltan ciang in ka tungah hesuakna nong nei uh hi, taciang vantung ah a phazaw le a ngei kikhomsuan zaw te zong na nei uh hi, ci na heak uh hu in, na neisa uh hong ki suam lai zong na lung uh dam hi.   
\p
\v 35 Tua a hikom na nei uh thaman lian mama le tha muan na sia nusia heak vun.   
\p
\v 36 Banghangziam cile Pathian deina na sep zawk uh ciang, kamciam na nga thei natu uh in, thuakzawkna na kisam uh hi.   
\p
\v 37 \x - \xo 10:37 \xt Heb 2:3, 4\x*Banghangziam cile hongpai tu pa sia haisang ngawl in a hai ngawl in hongpai tu hi.   
\p
\v 38 Taciang mithutang te sia upna taw nungta tu hi: ahihang mi khatpo a nungtolkik ahile ama tungah ka nuntakna taw lungkimna ka nei batu hi.   
\p
\v 39 Ahihang eite sia a mangthang tu in a nungtol te i hi bua hi; ahihang i nuntakna ngum tu in a umte i hihi.   
\c 11  
\s1 Upna  
\p
\v 1 Tu in upna sia i lamet khat papo atu in tha muanna a hihi, i mu ngawl nate om takpi hi, ci ki telsakna a hihi.   
\p
\v 2 Banghangziam cile upna tungtawn in tanglai upa te in minpha nga uh hi.   
\p
\v 3 \x - \xo 11:3 \xt Pian 1:1; Ps 33:6,9; Jn 1:3.\x*Leitung sia Pathian thu taw a ki bitphua a hihi, tua ahikom a ki mu thei nate sia a ki mu thei nate pan in a ki vawt hi ngawl hi, ci sia upna tungtawn in i he thei hi.   
\p
\v 4 \x - \xo 11:4 \xt Pian 4:3-10\x*Abel in Cain sang in a phazaw biakpiakna sia upna tungtawn in pia hi, tua upna tungtawn in ama sia thutang hi, ci na tetti nga a, tua hu in thi napi, thu hong hil lai hi.   
\p
\v 5 \x - \xo 11:5 \xt Pian 5:21-24\x*Upna tungtawn in Enoch sia thina tep ngawl tu in lumlet hi; taciang kuama in ama mu ngawl hi, banghangziam cile Pathian in ama sia lumlet zo a: a ki lumle ma in, Pathian lungkimsak hi, ci in tetti panna nei hi.   
\p
\v 6 Ahihang upna ngawl taw Pathian lungkimsak tu sia suak thei ngawl hi: banghangziam cile Pathian kung a pai peuma in Pathian om hi, ci le hanciam in Ama a zong peuma thaman pia pa a hihi, ci sia a up kul hi.   
\p
\v 7 \x - \xo 11:7 \xt Pian 6:13-22\x*Upna tungtawn in, Noah in a mu ngawl lai thu te sungah, Pathian in kinginna a piak ciang in, Pathian lau a, a innkuan ngupna tu in tembaw sa hi; tua a upna hu in leitung mite mawsak a, upna tungtawn in thutang suana ngamhlua hong suak hi.   
\p
\v 8 \x - \xo 11:8 \xt Pian 12:1-5\x*Upna tungtawn in Abraham sia a ngamlua tu mun ah pai tu in, Pathian in a sap ciang in, a pai natu mun he ngawl napi; thu ni in pai hi.   
\p
\v 9 \x - \xo 11:9 \xt Pian 35:27\x* Upna tungtawn in kamciam ngam sungah peamta in om a, ngamdang ah om bang in puanbuk sungah kamciam ki bangtek a nga Isaac le Jacob te taw teangkhawm uh hi:   
\p
\v 10 Banghangziam cile ama in Pathian i patsa, a saksa le a vawtsa khuapi kip lamen in ngak hi.   
\p
\v 11 \x - \xo 11:11 \xt Pian 18:11-14; 21:2\x*Sarah zong upna tungtawn in a kum val zawkciang, naupai tu in thahatna nga a, nau nei hi, banghangziam cile kamciam a pia pa sia thuman hi, ci ngaisun hi.   
\p
\v 12 \x - \xo 11:12 \xt Pian 15:4; 22:17; 32:12\x*Tua ahikom ama sia mithi bang hi napi, khat sung pan in aksi za le tuipi vaal ah senneal za, a ki sim zo ngawl mihonpi te suaksak hi.   
\p
\v 13 \x - \xo 11:13 \xt Pian 23:4; 1 Khang 29:15; Ps 39:12\x*Hi mite sia kamciam te sang tha ngawl in a vekpi in upna taw thi uh hi, ahihang a khualapi pan in mu uh a, tua te in amate a kaizot uh hu in, khotak in pom a, hileitung ah peamta te le khualhaw te a hina pualak hi.   
\p
\v 14 Banghangziam cile tabang thu a hil te in amate sia ngam khat zong hi, ci sia thiangtak in kilang hi.   
\p
\v 15 Amate pusuana ngam sia thangai uh hile, heakkik theina hunpha nei hi.   
\p
\v 16 Ahihang amate in a phazaw vantung ngam lungngul zaw a hi hu in, Pathian in, amate i Pathian, a kici tu a maizum bua hi: banghangziam cile Pathian in amate atu in khuapi vawtkholsak hi.   
\p
\v 17 \x - \xo 11:17 \xt Pian 22:1-14\x*Upna tungtawn in Abraham sia, Isaac pia tu in kamciam a nga lai in, kamciam a nga na a neisun tapa pia hi,   
\p
\v 18 \x - \xo 11:18 \xt Pian 21:12\x*Tua a tapa thu sia, Isaac sungah na suan le pal min kip tu hi, ci hi:   
\p
\v 19 Pathian in thina pan in thokiksak thei hi, ci ngaisun hi; tua mun pan in a tapa sia thina pan in a nga, ci telsakna a hihi.   
\p
\v 20 \x - \xo 11:20 \xt Pian 27:27-29, 39, 40\x*Hong pai pheang tu nate taw kisai in Isaac in Jacob le Esau te thupha pia hi.   
\p
\v 21 \x - \xo 11:21 \xt Pian 48:1-20; \xt Pian 47:31\x*Upna tungtawn in Jacob in a thi tu ciang in Joseph tapa ni te thupha pia a; a ciangkhut dawn neal kawm in, Pathian bia hi.   
\p
\v 22 \x - \xo 11:22 \xt Pian 50:24; Ex 13:19\x*Upna tungtawn in Joseph in a thi kuan ciang in Israel tate a sua natu thu son hi; a ngu taw kisai in thu pia hi.   
\p
\v 23 \x - \xo 11:23 \xt Ex 2:2; \xt Ex 1:22.\x*Upna in Moses sia, a sua ciang in, a nu le a pa te in tha thum sung phual hi, banghangziam cile amate in nausen sia hoi mama hi, ci a mu uh hi; taciang kumpi thupiak zong lau ngawl hi.   
\p
\v 24 \x - \xo 11:24 \xt Ex 2:10:12\x*Upna tungtawn in Moses in, a khanthin ciang in, Pharaoh tanu i tapa, a kici tu sia nial a;   
\p
\v 25 Tawmvei atu mawna sungah lungkimna le nopsakna te sang in Pathian mite taw haksatna thuak tu teal zaw hi;   
\p
\v 26 Egypt ngam i hauna sang in Christ hang in vawtsiatna sia thupi zaw hauna in ngaisun hi: banghangziam cile thaman a nga tu a mitsuan hang a hihi.   
\p
\v 27 Upna tungtawn in ama in Egypt ngam nusia a, kumpipa thin-ukna zong lau ngawl hi: banghangziam cile a ki mu thei ngawl Pathian a mu hang in thuakzo hi.   
\p
\v 28 \x - \xo 11:28 \xt Ex 12:21-30\x*Tapa upabel siatsua pa in amate thutha ngawl tu in upna tungtawn in paisanpoai le thisan theena vawt uh hi.   
\p
\v 29 \x - \xo 11:29 \xt Ex 14:21-31.\x*Upna tungtawn in amate in lei ko tung tawn in san tuipi kantan uh hi: tasia Egypt te in zong a kan sawm uh ciang in tui in khum cip hi.   
\p
\v 30 \x - \xo 11:30 \xt Jos 6:12-21\x*Upna tungtawn in Jericho luphung sia ni sali a kimveal zawkciang in cimtham hi.   
\p
\v 31 \x - \xo 11:31 \xt Jos 6:22-25; \xt Jos 2:1-21.\x*Upna tungtawn in pumpi kizuak Rahab in ngalvil te kilemna taw a san hu in thu um ngawl te taw mangthang khawm ngawl hi.   
\p
\v 32 \x - \xo 11:32 \xt Thukn 6:11—8:32; \xt Thukn 4:6—5:31; \xt Thukn 13:2—16:31; \xt Thukn 11:1—12:7; \xt 1Sam 16:1—1Ki 2:11; \xt 1Sam 1:1—25:1.\x*Taciang bang son thua tu khi ziam? banghangziam cile Gideon, Barak, Samson, Jephthah, David, Samuel le kamsang te thu son natu hun kicing ngawl hi:   
\p
\v 33 \x - \xo 11:33 \xt Dan 6:1-27\x*Amate in upna tungtawn in kumpingam te zo uh a, thutang suana te vawt in kamciam te zong sang a, humpi nealkai te kam te zong humcip siat hi,   
\p
\v 34 \x - \xo 11:34 \xt Dan 3:1-30\x*Meikuang lauhuai mamate zong mitsak a, namsau hiam pan zong suaktasak hi, thaneamna sung pan thahatsak a, ngal simna mun ah hangsansak in, ngamdang ngalkap te tai in ki thethangsak hi.   
\p
\v 35 \x - \xo 11:35 \xt 1Kumpi 17:17-24; 2Kumpi 4:25-37.\x*Nupi te in a mithi te nuntakna sungah thawkik sakna nga uh hi: taciang a dang te in a phazaw thawkikna a san thei natu in suatakna sia sang nuam ngawl uh a vawtsiatna thuak uh hi:   
\p
\v 36 \x - \xo 11:36 \xt 1Kumpi 22:26,27; 2Khang 18:25,26; Jer 20:2; 37:15; 38:6.\x*Taciang a dang te in zawnsakna le velna, tua bek domngawl koltang in thongtak nate taw ze-etna te:   
\p
\v 37 \x - \xo 11:37 \xt 2 Khang 24:21\x*Suangtum taw denna, lua taw at in tanna, ze-etna, namsau taw thalup nate thuak uh a: zawngkhal tak in, vawtsiatna namcin thuak in, tuu vun le keal vun te sil uh a, ki le kakoai uh hi;   
\p
\v 38 Amate atu in leitung sia omtak ngawl hi: amate leitung ah senneal ngam te, mual te, lei hawng le suang hawng sungah kile kakoai in om uh hi.   
\p
\v 39 Hite theampo in upna hang in minpha sang uh hi napi, kamciam ahile sang tha ngawl hi:   
\p
\v 40 Eite ki hel ngawl in, amate ki khuangkhim sak ngawl tu in, Pathian in eite atu in a phazaw te hong pia hi.   
\c 12  
\s1 Tai Kidemna  
\p
\v 1 Tua ahikom hizata a lian meingo bang tetti te in hong kimum liang ahikom in, vanngit theampo le a oltak in hong nawngkaisak mawna sia nusia in, i mai ah a kikoi tai kidemna ah thinsau tak in tai tek tawng,   
\p
\v 2 Eite i upna kipatna le a picingsak Jesus en tawng; Ama sia a mai ah a kikoi lungdamna atu in thinglamte thuak a, maizumna phamaw sa ngawl in, Pathian i kumpi tokhum ziatsang ah to hi.   
\s1 Pathian in A Tate Tek  
\p
\v 3 Banghangziam cile thinngim le thaneam in na om ngawl natu uh in, Ama sia hizata in mawnei te i langpanna a thuakna ngaisun vun.   
\p
\v 4 Note mawna langpan in thisan suak dong na do balai uh hi.   
\p
\v 5 \x - \xo 12:5 \xt Job 5:17; Pau 3:11,12.\x*Taciang note in tate tungah hanthotna bang in hilna, ka tapa awng, Topa i tekna te thusimngawl in om heak in, hong tei ciang zong thaneam heak in, ci thu mangil zo nu hi:   
\p
\v 6 Banghangziam cile Topa in a it te tek a, a saan tate te sat hi.   
\p
\v 7 Tekna na thuak le Pathian in note sia tapa te bang in hong tek hi; banghangziam cile pa in a tek ngawl ta a kua om ziam?   
\p
\v 8 Ahihang note sia, ta hina a neipui te theampo bang in, hong ki tek bale, tapa hi ngawl in lamlakta na hi uh hi.   
\p
\v 9 Tuabek domngawl in, cilesa lam ah hong tek tu pa te i nei hi, taciang amate zatakna i pia hi: tuate sang in, thaa theampo i Pa tungah nasia zaw in, a thu ni in nungta zaw ngawl tu hi ziam?   
\p
\v 10 Banghangziam cile pate in ni tawmno sung amate lungkimna bang in hong tek hi; ahihang Pathian in eite phattuamna tu le Ama thianthona neipui te i hi thei natu in hong tek hi.   
\p
\v 11 Ki tekna sia i thuak laitak lungdamna hi ngawl in khuangaina taw kibang hi: ahihang a zawkciang in a thuak te in thinnopna taw a dim thutang suana i nga kik tu hi.   
\p
\v 12 \x - \xo 12:12 \xt Isa 35:3\x*Tua ahikom thaneam in a taksuk na khut te lamto vun a, na khup te khosak vun;   
\p
\v 13 \x - \xo 12:13 \xt Pau 4:26\x*Taciang peangbai te lampial ngawl tu le, damsak zaw tu in, na peang atu in lampi te tangsak vun.   
\p
\v 14 Mi theampo taw kilem le thianthona zui tavun, thianthona ngawl taw kuama in Topa mu ngawl tu hi:   
\p
\v 15 \x - \xo 12:15 \xt Thuhlk 29:18\x*Hanciamtak in encik vun, tabang hi bale Pathian thuthiamna pan in mi khatpo taksuk tha tu hi; a po khia zungkha in hong buaisak tu a, mi tampi hong niinsak tu hi.   
\p
\v 16 \x - \xo 12:16 \xt Pian 25:29-34\x*A paktat te ahizong, a hibale ta upabel ngamh sia an neak khat taw a zuak Esau bang in Pathian thusimngawl te na om tha tu uh hi.   
\p
\v 17 \x - \xo 12:17 \xt Pian 27:30-40.\x*Banghangziam cile tua zawkciang in thupha ngamh a lua kik nop ciang in ki nolh hi: thitui taw nasiatak in a zon kik hang, ki sikkikna lampi mu ngawl hi, ci na he uh hi.   
\p
\v 18 \x - \xo 12:18 \xt Ex 19:16-22; 20:18-21; Thuhlk 4:11,12; 5:22-27.\x*Banghangziam cile note i tham thei mual le mei i kak, a vom cip, khuazing le huipi suangval kungah a hizong,   
\p
\v 19 Taciang lemle aw le thuhilna aw te kung ah a hizong, a zuan na hi bua uh hi; amate thuhil nawn ngawl tu in ngetna aw za uh hi:   
\p
\v 20 \x - \xo 12:20 \xt Ex 19:12,13\x*Banghangziam cile, nganhing khatpo in mual a thutha le, suangtum taw deang tu hi, a hibale tei taw ki dawt tu hi, ci thupiakna sia amate in a thuak zo bua uh hi:   
\p
\v 21 \x - \xo 12:21 \xt Thuhlk 9:19\x*Tua a mu uh sia lauhuai lei ahikom, Moses zong, ka lau mama a, ka ling vadil hi, ci hi:   
\p
\v 22 Ahihang note sia Zion mual le a nungta Pathian i khuapi, van Jerusalem le a kisim zo ngawl vantungmi honpi te kungah ahizong,   
\p
\v 23 Mihonpi kikhopna mun le vantung ah min ki at ta upabel i pawlpi, mi theampo thu a khen Pathian kungah ahizong, a thutang te picingsak thaa te kungah ahizong,   
\p
\v 24 \x - \xo 12:24 \xt Pian 4:10\x*Thuciam thak i palai a hi Jesus tungah ahizong, Abel sang in a phazaw thu te a hil a ki the thisan kungah ahizong, na pai uh hi.   
\p
\v 25 \x - \xo 12:25 \xt Ex 20:22\x*Note thu hong hil te thuhilna nial ngawl tu in kidawm vun. Leitung ah thuhil te i hilna a nial te suakta ngawl ahile, vantung pan thuhilna a nungngat le, tua sang in i suakta ba seseam tu hi:   
\p
\v 26 \x - \xo 12:26 \xt Hag 2:6\x*Leitung a lingsak aw in, leitung bek hi ngawl in vantung zong khatvei lingsak kik tu hi, ci kiciamna nei hi.   
\p
\v 27 Tuazawk khatvei, a ci thua lai thu i a khiakna sia a liing thei ngawl te kip suak tu in ahizong, a liinsak leitung nate sia ki khin tu hi, ci kilangsak hi.   
\p
\v 28 Tua ahiciang, a ki khin thei ngawl kumpingam i san hu in, thuthiamna nei tek tawng, tabang in a san thamman in upatna le zatakna taw Pathian na i seam thei tu hi:   
\p
\v 29 \x - \xo 12:29 \xt Thuhlk 4:24\x*Banghangziam cile i Pathian sia a kuang vazak mei a hihi.   
\c 13  
\s1 Akhakbel Vaithakna  
\p
\v 1 U le nau ki itna kizom paisuak tahen.   
\p
\v 2 \x - \xo 13:2 \xt Pian 18:1-8; 19:1-3\x*Leangna te phatak in zindo tu mangil heak vun: banghangziam cile pawlkhat in upmawk ngawlbul in vantung mite zin do uh hi.   
\p
\v 3 Koltang te taw a tang khawm bang in amate phawk tawntung vun; note zong cilesa sungah omlai na hi uhkom in, vawtsiatna a thuak te phawk tawntung vun.   
\p
\v 4 Lupna niinsak ngawl in kitenna sia thupisak tu kilawm hi: ahihang pasal kizuak te le paktat mawna a vawt te Pathian in thukhen tu hi.   
\p
\v 5 \x - \xo 13:5 \xt Thuhlk 31:6, 8; Jos 1:5\x*Na nuntakzia uh sia duhopna om ngawl hi hen a; noma neisa te taw lungkim tavun: banghangziam cile keima in hong paisan in kong nusia ngei batu hi.   
\p
\v 6 \x - \xo 13:6 \xt Ps 118:6\x*Tua ahikom, Topa sia keima hong hu pa hi, taciang mihing in ka tungah bangpo hong vawt zong ka lau bua hi, ci in hangsantak in i pau ngam tu hi.   
\p
\v 7 Note Pathian thu hong hil te le note tungah hong uk te phawk tawntung vun a: amate nuntakzia a tawpna ngaisun kawm in, amate upna zui vun.   
\p
\v 8 Jesus Christ sia zei ni, tu ni, le a tawntung in kibang hi.   
\p
\v 9 Upna tatuam le thu thak te um in ki khin kakoai heak vun. Banghangziam cile thinsung sia an taw hi ngawl in, thuthiamna taw kipsak tu pha hi; tua an i zawthawk te in phattuamna nei ngawl hi.   
\p
\v 10 Biakbuk sungah naseam te i a neak thei ngawl biaktau i nei hi.   
\p
\v 11 \x - \xo 13:11 \xt Thiam 16:27\x*Banghangziam cile thiampi sang in mawna atu in thisan sia mun thiangtho sungah a paipui zawkciang, biakpiakna ngan te i luang sia ngiaphual puasang ah hal hi.   
\p
\v 12 Tua ahikom Jesus zong Ama thisan taw mihing te thiangthosak tu in kongpi puasang ah thuak hi.   
\p
\v 13 Tua ahikom eite zong Ama zawnsakna a thuak bang thuak tu in ngiaphual puasang Ama kungah pai tawng.   
\p
\v 14 Banghangziam cile hi mun ah eite a tawntung a kip khuapi i nei bua hi, ahihang hongpai pheang tu sia i zong zaw hi.   
\p
\v 15 Tua ahikom Ama tungtawn in Pathian kungah a tawntung in pokna biakpiakna pia tawng, tua in eite kam pan a suak a min pokna i nga a hihi.   
\p
\v 16 Ahihang na pha vawt tu le neisa hawmkhawm tu mangil heak vun: banghangziam cile tabang biakpiakna te in Pathian lungkimsak mama hi.   
\p
\v 17 Note tungah ukna za nei te thu ngai vun a, noma le noma ki ap vun; banghangziam cile amate in na nuntakna a kepcingna sia Pathian mai ah pualak kik tu ahikom in, thinnatna taw hi ngawl in, lungdamna taw a sep tu uh a hihi: banghangziam cile amate a thin uh a na le, note atu in bangma phattuamna om ngawl hi.   
\p
\v 18 Kote atu thu hong ngetsak tavun: banghangziam cile, na theampo sungah thuman tak in nuntak tu ka uk uh hi, taciang khentel theina ka nei uh hi.   
\p
\v 19 Ahihang note kungah manlangtak in kong pai thei natu in nong vaihawmsak tu uh kong thum hi.   
\s1 Akhakbel Paupuina  
\p
\v 20 Tawntung kamciam i thisan tungtawn in tuu hon a cing Tuucing lian, i Topa Jesus sia thina pan a lakhia thinnopna Pathian in,   
\p
\v 21 Ama deina a pha theampo na vawt thei natu uh in hong cialcingsak tahen, Jesus Christ tungtawn in note sungah a nasepna sia Ama mai ah lungkimna tatak a hihi; tua Jesus tungah a tawntung in minthanna om tawntung tahen. Amen.   
\p
\v 22 Suapui te awng, hanthotna lai tawm kong thak sia thinsau in na ngai vun, ci kong thum hi.   
\p
\v 23 I suapui pa Timothy sia suatakna pia zo hi, ci he tavun; a hai ngawl in hongpai ahile ama taw kong mu tu uh hi.   
\p
\v 24 Mi thiangtho te le note hong uk te nukset vun. Italy a omte in zong hong paupui hi.   
\p
\v 25 Note theampo tungah thuthiamna hong om tahen. Amen.   