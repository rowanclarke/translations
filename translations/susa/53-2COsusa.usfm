\id 2CO
\h كٌرِنتِ عِِ
\toc1 عَلَ شَ مَسٍنيِ قِرِن ندٍ عَننَبِ ثْلُ نَشَن سّبّ كٌرِنتِ دَنشَنِيَتْي حَمَ مَ
\toc2 كٌرِنتِ عِِ
\mt1 عَلَ شَ مَسٍنيِ قِرِن ندٍ
\mt1 عَننَبِ ثْلُ نَشَن سّبّ
\mt1 كٌرِنتِ دَنشَنِيَتْي حَمَ مَ
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ
\ip يِ كِتَابُي قِندِشِ عَننَبِ ثْلُ شَ بَتَاشّ قِرِن ندٍ نَن نَ دَنشَنِيَتْي حَمَ بّ، نَشَن نُ نَ كٌرِنتِ تَا كُي فِرّكِ بْشِ مَ. عَ نُ بَرَ كَوَندِ تِ نَا عَ شَ بِيَاسِ قِرِن ندٍ كُي. مِشِ فبٍفبٍ نَشَ دَنشَنِيَ عِسَ مَ، كْنْ عٍ حّرّ كِ مُ نُ فّشِ قَندٍ. ندٍيٍ مُ نُ لَنشِ عٍ بٌورٍيٍ مَ، ندٍيٍ نُ قٍ حَاشِيٍ رَبَمَ فِنّيٍ رَ، ندٍيٍ نُ وَ مَ عٍ يّتّ عِفبٌقٍ دَنشَنِيَتْي بٌورٍيٍ يَ مَ. نَ بِرِن قِندِشِ يَافِ نَن نَ دِينّلَيٍ تَفِ. نَ نَن عَ تٌشِ عَننَبِ ثْلُ نَشَ عَ شَ بَتَاشّ سِنفٍ سّبّ عٍ مَ.
\ip كٌرِنتِكَيٍ تٌ نَ بَتَاشّ سِنفٍ شَرَن، ندٍيٍ نَشَ عَننَبِ ثْلُ شُي سُشُ، عٍ قَ فبِلٍن يُنُبِيٍ قْشْ رَ. ندٍيٍ مُ تِن نَ رَ. عٍ نَشَ قِندِ ثْلُ يَشُييٍ رَ، عٍ قٍ بِرِن نَبَ عَ شِلِ كَنَقٍ رَ. عٍ نَشَ عٍ يّتّ قِندِ شّيرَ قِسَمَنتٍيٍ رَ، كْنْ يّتّ عِفبٌي نَن تُن نُ عٍ رَ. نَ كُي، عَننَبِ ثْلُ نَشَ عَ شَ بَتَاشّ قِرِن ندٍ سّبّ كٌرِنتِ دَنشَنِيَتْي حَمَ مَ.
\ip يِ بَتَاشّ عَ مَسٍنشِ نّ عَ عَننَبِ ثْلُ نَن قِندِشِ عَلَ شَ مِشِ سُفَندِشِ عِسَ شَ شّيرَ رَ. عَ نَشَ قٍ فبٍفبٍ مَسٍن دَنشَنِيَتْييٍ بّ، عَلَكٌ نَ وُلٍ قَلّيٍ نَشَ عٍ مَدَشُ عَ قَلَقٍ رَ عٍ نَشَ عٍ تُلِ مَتِ ثْلُ رَ سْنْن.
\ip بَقٍ نَ رَ، يِ بَتَاشّ مَرَ سِ قَنيِ قِمَ كٌرِنتِكَيٍ مَ وَلِ ندٍيٍ شَ قٍ رَ عٍ نُ بَرَ نَشَن قْلْ دَرِ سَلَمُكَيٍ بّ. دَنشَنِيَتْي ندٍيٍ نُ نَ تْورّ كُي كَامّ شَ قٍ رَ عِسِرَيِلَ بْشِ مَ. نَ كُي، دَنشَنِيَتْي حَمَ نَشٍيٍ نُ نَ يِرٍ فبّتّيٍ، عٍ نَشَ كْبِرِ مَلَن عٍ نفَشَكٍرٍنيِيٍ مَلِقٍ رَ. كٌرِنتِكَيٍ سِنفٍ نَن نَ قْلْ، كْنْ ثْلُ عٍ رَ سِمَ يِ بَتَاشّ رَ عٍ شَ نَ وَلِ رَحْن.
\ip يِ بَتَاشّ قِندِشِ كِتَابُي نَن نَ نَشَن سّرِيّ قَنيِ مَسٍنمَ تٌ دَنشَنِيَتْييٍ بّ. عَ لَنمَ وٌن شَ وٌن تُلِ مَتِ عَلَ شَ شّيرَيٍ رَ نَشٍيٍ نْندِ مَسٍنمَ. شَ عَ سَ لِ مِشِ ندٍ قَ عَ قَلَ عَ عَلَ شَ مِشِ نَ عَ رَ، كْنْ عَ شَ مَسٍنيِ مُ لَنشِ عِسَ شَ شّيرَيٍ شَ مَسٍنيِ سِنفٍيٍ مَ، عَ مُ لَنمَ مِشِ شَ بِرَ نَ كَنيِ قْشْ رَ. عَلَ شَ وٌن نَتَنفَ نَ سَابُي حَاشِ مْولِ مَ. عَ مَن لَنمَ وٌن شَ قٍ بِرِن نَبَ دَنشَنِيَتْي بٌورٍيٍ مَلِقٍ رَ عٍ شَ تْورّ كُي. عَلَ شَ شَنُنتٍيَ مْولِ شَ لُ وٌن بْحّ كُي.
\ip عَلَ شَ وٌن مَلِ عَلَكٌ وٌن شَ لُ عَ وَشْنكِ. عَمِنَ.
\mt1 عَلَ شَ مَسٍنيِ قِرِن ندٍ
\mt1 عَننَبِ ثْلُ نَشَن سّبّ
\mt1 كٌرِنتِ دَنشَنِيَتْي حَمَ مَ
\cl سٌرَ
\c 1
\s1 دَنشَنِيَتْي شَ لِمَنِيَ
\p 
\v 1 ﭑ تَن ثْلُ، عَلَ بَرَ تِن نَشَن شَ قِندِ عَ شَ شّيرَ رَ، ﭑ نُن ﭑ نفَشَكٍرٍنيِ تِمٌتٍ، مُشُ بَرَ وٌ شّيبُ، وٌ تَن عَلَ شَ دَنشَنِيَتْي نَشٍيٍ نَ كٌرِنتِ، عَ نُن سّنِيّنتْي بِرِن نَشٍيٍ نَ عَكَيِ.
\v 2 وٌن بَبَ عَلَ نُن وٌن مَرِفِ، عَلَ شَ مِشِ سُفَندِشِ عِسَ، عٍ شَ هِننّ نُن بْحّسَ قِ وٌ مَ.
\p 
\v 3 تَنتُي نَ عَلَ بّ، نَشَن قِندِشِ وٌن مَرِفِ عِسَ بَبَ رَ، عَ شَ مِشِ سُفَندِشِ. بَبَ كِنِكِنِنتٍ نَ عَ رَ، نَشَن مِشِيٍ رَلِمَنِيَمَ عٍ شَ قٍ بِرِن كُي.
\v 4 عَلَ وٌن نَلِمَنِيَمَ وٌن مَ تْورّ كُي، عَلَكٌ وٌن قَن شَ نْ تْورْ مِشِ فبّتّيٍ رَلِمَنِيَدٍ نَ كِ.
\v 5 وٌن مَ تْورّ شُن مَسَمَ عَلَ شَ مِشِ سُفَندِشِ شَ قٍ رَ كِ نَشّ، وٌن مَ لِمَنِيَ قَن شُن مَسَمَ عَ سَابُي رَ نَ كِ نّ.
\p 
\v 6 مُشُ نَ تْورْقٍ عَلَكٌ وٌ تَن شَ لِمَنِيَ نُن كِسِ سْتْ. مُشُ شَ لِمَنِيَ عَ نِيَمَ نّ وٌ قَن شَ لِمَنِيَ سْتْ عَلَكٌ وٌ قَن شَ نْ وٌ شَ تْورّ رَ. وٌن بِرِن نَ تْورْقٍ كِ كٍرٍن.
\v 7 مُشُ عَ كٌلٌن عَ قَنيِ رَ وٌ شَ دَنشَنِيَ سْونّيَمَ نّ، بَرِ مَ وٌ لِمَنِيَ سْتْمَ وٌ شَ تْورّ نَن كُي.
\p 
\v 8 ﭑ نفَشَكٍرٍنيِيٍ، مُشُ وَ مَ وٌ شَ عَ كٌلٌن مُشُ حَشَنكَتّ نَشَن سْتْ عَسِ. عَ نُ فبٌ دَنفِ مُشُ سّنبّ رَ، مُشُ قَ عَ مَحْشُن مُشُ نَ قَشَقٍ نّ.
\v 9 نَ مَحْشُنيِ بَرَ لُ مُشُ شُنيِ عَلَكٌ مُشُ نَشَ مُشُ شَشِلِ تِ مُشُ يّتّ رَ، مُشُ شَ مُشُ شَشِلِ تِ عَلَ نَن نَ نَشَن قَشَمِشِيٍ رَكٍلِمَ.
\v 10 عَ تَن نَن فبَنسَن مُشُ رَتَنفَشِ نَ قَشّ حَاشِ مَ. عَ مَن قَمَ نَ رَبَدٍ مُشُ بّ. مُشُ بَرَ لَ عَ رَ عَ مَن قَمَ نّ مُشُ رَتَنفَدٍ.
\v 11 وٌ قَن نْمَ مُشُ مَلِدٍ نَ كُي وٌ شَ عَلَ مَشَندِ رَ. مِشِ فبٍفبٍ نَ عَلَ مَشَندِ مُشُ بّ، مِشِ فبٍفبٍ قَمَ نّ عَلَ تَنتُدٍ عَ شَ هِننّ شَ قٍ رَ عَ نَشَن قِمَ مُشُ مَ.
\p 
\v 12 مُشُ سّيوَشِ يِ نَن مَ. مُشُ عَ كٌلٌن مُشُ بْحّ كُي عَ مُشُ بَرَ حّرّ دُنِحَ كُي وٌ يَ مَ سّنِيّنيِ نُن بْحّ قِيشّ كُي، نَشَن قَتَنشِ عَلَ رَ. مُشُ حّرّشِ نَ كِ نّ وٌ يَ مَ دَنفِقٍ يِرٍ بِرِن نَ. نَ حّرّ مْولِ مُ كٍلِشِ عَدَ مَدِ شَ لْننِ شَ مَ. عَ كٍلِشِ عَلَ شَ هِننّ نَن مَ.
\v 13 مُشُ مُ سٍسٍ سّبّ وٌ مَ وٌ مُ نْمَ نَشَن تٌدٍ نُن عَ كٌلٌندٍ عَ قِيشّ رَ. عَ شْلِ ﭑ مَ وٌ شَ قَهَامُي شَ كَمَلِ نَ شَ قٍ رَ.
\v 14 وٌ حَن بَرَ ندٍ كٌلٌن، كْنْ وٌ شَ قَهَامُي قَمَ نّ كَمَلِدٍ عَ كٌلٌنقٍ رَ عَ وٌن بِرِن بِنيّ سْتْمَ نّ وٌن مَرِفِ عِسَ قَ تّمُي وٌن بٌرٍ شَ قٍ رَ.
\p 
\v 15 ﭑ تٌ نَ كٌلٌن، ﭑ نَشَ وَ سِفَقٍ وٌ يِرٍ عَلَكٌ وٌ مَن شَ هِننّ سْتْ.
\v 16 ﭑ نَشَ وَ دَنفِقٍ وٌ يِرٍ ﭑ سِفَمَ مَسٍدٌن تّمُي نَشّ، ﭑ مَن شَ دَنفِ وٌ يِرٍ ﭑ كٍلِمَ مَسٍدٌن تّمُي نَشّ. نَ كِ وٌ نْمَ ﭑ مَلِدٍ ﭑ مَ بِيَاسِ كُي سِفَقٍ رَ يُدَيَ.
\v 17 وٌ حْشْ عَ مَ نَتّ تٌنفٌشِ نَ عَ رَ عَدَ مَدِ كِ مَ، نَشَن وْيّن قِرِن قَلَمَ؟
\v 18 ﭑ بَرَ عَ قَلَ وٌ بّ عَلَ تِنشِنشِ شِلِ رَ، ﭑ مُ وُلٍ قَلَمَ ﭑ مَ مَسٍنيِ كُي.
\v 19 عَلَ شَ مِشِ سُفَندِشِ عِسَ، نَشَن قِندِشِ عَلَ شَ دِ رَ، مُشُ نَشَن مَسٍنشِ وٌ بّ، عَ قَن مُ عَ يّتّ مَتَندِ مَ. ﭑ تَن، سِلَسِ، نُن تِمٌتٍ، مُشُ نَشَن كَوَندِشِ وٌ بّ، نَ بِرِن قِندِشِ نْندِ نَن نَ.
\p 
\v 20 عَلَ قَمَ عَ شَ لَايِدِ بِرِن نَكَمَلِدٍ عِسَ سَابُي رَ. نَ نَن عَ رَ وٌن «عَمِنَ» رَتِنمَ عِسَ شِلِ رَ عَلَ شَ نْرّ شَ قٍ رَ.
\v 21 عَلَ نَن وٌن بِرِن مَ دَنشَنِيَ رَ سَبَتِشِ عَ شَ مِشِ سُفَندِشِ سَابُي رَ. عَ بَرَ وٌن سُفَندِ،
\v 22 عَ قَ عَ شَ تْنشُمَ سَ وٌن مَ، نَشَن عَ مَسٍنشِ عَ وٌن قِندِشِ عَ فبٍ نَن نَ. عَ بَرَ عَ يّتّ شَشِلِ رَ سٌ وٌن بْحّ عِ نَشَن عَ مَسٍنمَ عَ قَمَ نّ وٌن كِدٍ عَرِيَننَ رَ.
\p 
\v 23 عَلَ نَ ﭑ سٍيدٍ رَ. ﭑ مُ فبِلٍنشِ كٌرِنتِ، عَلَكٌ عَ نَشَ قِندِ تْورّ رَ وٌ بّ.
\v 24 مُشُ مُ وَ مَ دَنشَنِيَتْييٍ يَمَرِقٍ، كْنْ مُشُ وَ مَ كَقُقٍ نّ وٌ مَ عَلَكٌ وٌ شَ سّيوَ بَرِ مَ وٌ سَبَتِشِ دَنشَنِيَ كُي.
\c 2
\s1 ثْلُ شَ بِيَاسِيٍ
\p 
\v 1 نَ كُي، ﭑ نُ بَرَ نَتّ تٌنفٌ عَ مُ لَنمَ ﭑ شَ سِفَ وٌ يِرٍ سُننُنيِ كُي.
\v 2 شَ ﭑ بَرَ وٌ تَن تْورْ، ندٍ نْمَ ﭑ نَسّيوَدٍ سْنْن؟ ﭑ وٌ تَن نَشٍيٍ رَ سُننُنشِ، وٌ تَن نَن قَ نْمَ نَ رَ؟
\v 3 ﭑ نُ بَرَ نَ بَتَاشّ سّبّ عَلَكٌ وٌ حّرّ كِ، ﭑ نَشَن لِمَ وٌ يِ رَ، عَ نَشَ قِندِ سُننُنيِ رَ ﭑ بّ. عَ لَنمَ وٌ شَ قِندِ سّيوّ نَن نَ ﭑ بّ. ﭑ عَ كٌلٌن نَشَن نَ قِندِ سّيوّ رَ ﭑ بّ، عَ قِندِ مَ نّ سّيوّ رَ وٌ قَن بّ.
\v 4 ﭑ تٌ نَ بَتَاشّ سّبّ وٌ مَ، ﭑ بْحّ نُ ﭑ تْورْشِ، ﭑ يَيٍ نُ مِنِمَ. ﭑ مُ نَ سّبّشِ شّ عَلَكٌ ﭑ شَ وٌ تْورْ. ﭑ عَ سّبّشِ نّ عَلَكٌ وٌ شَ عَ كٌلٌن ﭑ وٌ شَنُشِ نّ يَتِ.
\p 
\v 5 ﭑ شَ عَ قَلَ وٌ بّ، مِشِ نَشَن قِندِشِ يِ تْورّ سَابُي رَ، عَ مُ ﭑ تَن شَ تْورْشِ. عَ وٌ تَن نَن تْورْشِ، شَ نَ مُ عَ رَ عَ بَرَ ندٍيٍ تْورْ وٌ يَ مَ.
\v 6 مِشِ فبٍفبٍ وٌ يَ مَ عٍ حَن بَرَ نَ كَنيِ حَشَنكَتَ. نَ بَرَ وَ سَكّ.
\v 7 وٌ دِحّ عَ مَ، وٌ شَ عَ رَلِمَنِيَ، عَلَكٌ نَ تْورّ نَشَ فبٌ يّ، عَ قَ نْ عَ رَ.
\v 8 وٌ نَشَن نَبَمَ، وٌ شَ شَنُنتٍيَ مَسٍن عَ بّ.
\p 
\v 9 ﭑ بَرَ نَ بَتَاشّ سّبّ وٌ مَ، عَلَكٌ ﭑ شَ عَ كٌلٌن شَ وٌ تِنمَ ﭑ مَ يَامَرِ بِرِن سُشُدٍ.
\v 10 شَ وٌ بَرَ دِحّ مِشِ ندٍ مَ، ﭑ قَن بَرَ دِحّ نَ كَنيِ مَ. شَ قٍ ندٍ بَرَ لُ وٌ تَفِ، ﭑ بَرَ دِحّ نَ بِرِن مَ وٌ شَ قٍ رَ عَلَ شَ مِشِ سُفَندِشِ يَ شْرِ
\v 11 عَلَكٌ سٍنتَنّ نَشَ نْ وٌن نَ. وٌن بَرَ عَ وَلِ كِ كٌلٌن.
\p 
\v 12 ﭑ تٌ سِفَ تِرٌيَسِ عَلَ شَ مِشِ سُفَندِشِ شَ شِبَارُ قَنيِ كَوَندِدٍ، ﭑ نَشَ عَ تٌ مَرِفِ نُ بَرَ سْونّيَ رَبَ ﭑ بّ.
\v 13 كْنْ ﭑ بْحّ مُ نُ سَشِ، بَرِ مَ ﭑ مُ ﭑ نفَشَكٍرٍنيِ تِتٌ لِشِ نَا. نَ نَن عَ تٌشِ ﭑ نَشَ حُنفُ رَبِرَ عٍ مَ، ﭑ قَ سِفَ مَسٍدٌن.
\p 
\v 14 تَنتُي نَ عَلَ بّ، نَشَن وٌن شُن نَكٍلِمَ عَ شَ مِشِ سُفَندِشِ سَابُي رَ. عِسَ كٌلٌنقٍ قَن عَلْ لَبُندّ شِرِ قَنيِ. عَلَ وٌن تَن نَن شّيشِ عَلَكٌ يِرٍ بِرِن شَ رَكٌلٌن نَ مَسٍنيِ رَ.
\v 15 وٌن لُشِ نّ عَلْ لَبُندّ شِرِ قَنيِ عَلَ نَشَن نَيٍنسٍنمَ كِسِ مِشِيٍ نُن كِسِتَرٍيٍ تَفِ.
\v 16 وٌن قِندِشِ مِشِ شِرِ حَاشِ نَن نَ كِسِتَرٍيٍ بّ نَشٍيٍ نَ يَهَننَمَ كِرَ شْن مَ. وٌن قِندِشِ مِشِ شِرِ حْشُنمّ نَن نَ كِسِ مِشِيٍ بّ نَشٍيٍ نَ عَرِيَننَ كِرَ شْن مَ. كْنْ عَدَ مَدِ مُندُن نْمَ نَ وَلِ مْولِ رَبَدٍ؟
\v 17 مُشُ تَن مُ عَلَ شَ مَسٍنيِ مَسٍنمَ كْبِرِ شَ قٍ رَ عَلْ كَوَندِتِ ندٍيٍ. مُشُ كَوَندِ تِمَ بْحّ قِيشّ نَن نَ عَلَ يَ شْرِ نَشَن مُشُ شّيشِ. مُشُ نَ رَبَمَ عَلَ شَ مِشِ سُفَندِشِ نَن سَابُي رَ.
\c 3
\s1 عَلَ شَ وَلِكّيٍ
\p 
\v 1 عَ لَنمَ مُشُ مَن شَ مُشُ يّتّ شُنمَقَلَ؟ عَدٍ. مُشُ هَيِ نَ بَتَاشّيٍ نَن مَ نَشٍيٍ مُشُ شُنمَقَلَمَ وٌ بّ؟ عَدٍ. مُشُ هَيِ نَ وٌ شَ بَتَاشّيٍ نَن مَ نَشٍيٍ مُشُ شُنمَقَلَمَ مِشِ فبّتّيٍ بّ؟ عَدٍ.
\v 2 وٌ نَشَن نَبَمَ وٌ شَ دُنِحّءِفِرِ كُي عَ لُشِ نّ عَلْ بَتَاشّ نَشَن مُشُ شُنمَقَلَمَ مِشِ بِرِن بّ. نَ مَسٍنيِ رَفَتَشِ مُشُ بْحّ كُي، عَلْ مَسٍنيِ سّبّشِ بَتَاشّ كُي كِ نَشّ عَلَكٌ مِشِ بِرِن شَ عَ كٌلٌن.
\v 3 وٌ تَن قِندِشِ عَلَ شَ مِشِ سُفَندِشِ شَ بَتَاشّ نَن نَ. مُشُ شَ وَلِ بَرَ عَ نِيَ نَ بَتَاشّ شَ سّبّ وٌ بْحّ مَ. عَ مُ سّبّشِ دُبّ شَ رَ، عَ سّبّشِ عَلَ شَشِلِ نَن نَ، نَشَن نَ نَ. عَ مُ سّبّشِ فّمّ وَلَشّ شَ مَ، عَ سّبّشِ وٌ بْحّ نَن مَ.
\p 
\v 4 لَنلَنتٍيَ نَ مُشُ بّ عَلَ يَ عِ، عَ شَ مِشِ سُفَندِشِ سَابُي رَ.
\v 5 وٌن مُ قَتَ قٍقٍ رَ وٌن يّتّ سّنبّ رَ. وٌن مَ قَتّ قَتَنشِ عَلَ نَن نَ.
\v 6 عَلَ نَن عَ نِيَشِ وٌن شَ نْ عَ شَ سَاتّ نّينّ كَوَندِدٍ. نَ سَاتّ مُ قَتَنشِ عَلَ شَ يَامَرِيٍ شَ رَ نَشٍيٍ سّبّشِ. عَ قَتَنشِ عَلَ شَشِلِ نَن نَ، نَشَن مِشِ رَكِسِمَ. عَلَ شَ يَامَرِ سّبّشِيٍ مُ مِشِ رَكِسِمَ.
\p 
\v 7 عَلَ شَ يَامَرِيٍ تٌ سّبّ فّمّ وَلَشّيٍ مَ، عَننَبِ مُنسَ يَتَفِ نَشَ نْرْ هَن عِسِرَيِلَكَيٍ مُ نْ عٍ يَ تِدٍ عَ رَ. هَلِ نَ يَامَرِيٍ تٌ قَ قِندِشِ قَشّ نَن نَ مِشِيٍ بّ، عٍ شَ نْرّ نُ فبٌ. كْنْ ندٍ نُ لُمَ بَ رَ نَ نْرّ رَ.
\v 8 عَلَ شَشِلِ نَشَن نَبَشِ، نَ وَلِ نْرْ مَ دَنفِقٍ نَ نْرّ سِنفٍ رَ نَشَن قَتَنشِ نَ يَامَرِ سّبّشِيٍ رَ.
\v 9 نَ يَامَرِيٍ سّبّشِ فّمّ وَلَشّيٍ نَن مَ، نَشٍيٍ نُ نْرْشِ، كْنْ عٍ قِندِ قَشّ نَن نَ مِشِيٍ بّ. عَلَ شَشِلِ نَشَن نَبَشِ، نَشَن عَ نِيَمَ مِشِيٍ شَ تِنشِنيِ سْتْ، نَ نْرّ فبٌ نَ نْرّ سِنفٍ بّ.
\v 10 نَشَن سِنفٍ نُ نْرْشِ، عَ شَ نْرّ بَرَ حْن نْرّ قِسَمَنتٍ سّيتِ مَ.
\v 11 نَ قٍ سِنفٍ نُ نْرْشِ، كْنْ عَ مُ بُ. عَلَ شَشِلِ نَشَن نَبَشِ، نَ بُمَ نّ عَبَدَن. نَ نْرّ فبٌ نَ نْرّ سِنفٍ بّ ثٌن!
\p 
\v 12 وٌن تٌ وٌن شَشِلِ تِشِ نَ رَ، وٌن بَرَ لِمَنِيَ سْتْ عَ قَنيِ رَ.
\v 13 وٌن مُ لُشِ عَلْ عَننَبِ مُنسَ نَشَن عَ يَتَفِ مَكٌتٌ مَقٍلٍنيِ رَ عَلَكٌ عِسِرَيِلَكَيٍ نَشَ عٍ يَ تِ نَ نْرّ رَ، نَشَن نُ لُمَ بَ رَ.
\v 14 كْنْ عٍ شَشِلِ شْرْشْ. هَن تٌ عٍ مُ قٍ قَهَامُمَ عَ قَنيِ رَ، عٍ سَاتّ قٌرِ شَرَنمَ تّمُي نَشّ. عَ لُشِ نّ عَلْ نَ مَقٍلٍنيِ، نَشَن نُ عَننَبِ مُنسَ يَتَفِ مَكٌتٌشِ، عَ مَن نَ عٍ يَتَفِ مَ، عٍ مُ قٍقٍ عِفبّمَ. نَ قَهَامُتَرٍحَ مُ نْمَ بَدٍ، قٌ مِشِ نَ لَ عَلَ شَ مِشِ سُفَندِشِ رَ.
\v 15 هَن تٌ عٍ لُشِ عَلْ نَ مَقٍلٍنيِ نَ عٍ يَتَفِ مَكٌتٌقٍ، عٍ مُ قَهَامُي سْتْ عٍ بْحّ كُي، عٍ تَوُرٍتَ مُنسَ شَرَنمَ تّمُي نَشّ.
\p 
\v 16 كْنْ مِشِ نَ عَ يَ رَقِندِ مَرِفِ مَ، نَ لُشِ نّ عَلْ نَ مَقٍلٍنيِ بَرَ بَ نَ كَنيِ يَتَفِ مَ، عَ قَ قَهَامُي سْتْ.
\v 17 وٌن مَرِفِ قِندِشِ عَلَ شَشِلِ سّنِيّنشِ نَن نَ. مَرِفِ شَشِلِ نَن شْرّيَ قِمَ مِشِ مَ.
\v 18 شَ نَ مَقٍلٍنيِ بَشِ وٌن يَتَفِ مَ، مَرِفِ شَ نْرّ نَشَن يَنبَمَ وٌن مَ، وٌن قَمَ نّ نَ نْرّ مَسٍندٍ مِشِ فبّتّيٍ بّ. وٌن مَرِفِ شَشِلِ وٌن مَسَرَ مَ نّ عَ مِسَالِ رَ، وٌن مَ نْرّ شُن نُ مَسَ.
\c 4
\s1 كَوَندِلَ وَلِ كِ
\p 
\v 1 عَلَ تٌ عَ شَ وَلِ سٌشِ مُشُ يِ رَ عَ شَ هِننّ سَابُي رَ، لِمَنِيَ مُ بَمَ مُشُ يِ رَ.
\v 2 مُشُ وَلِ كِ مُ نْشُنشِ، يَافِ يٌ مُ نَ عَ كُي. مُشُ مُ مِشِ مَدَشُمَ، مُشُ مُ عَلَ شَ مَسٍنيِ مَقِندِ مَ. مُشُ نْندِ نَن مَسٍنمَ مِشِ بِرِن بّ، عَلَكٌ عٍ شَ لَ مُشُ رَ عَلَ يَ عِ.
\v 3 مُشُ شَ شِبَارُ قَنيِ قِيشّ مِشِ بِرِن بّ، قٌ كِسِتَرٍيٍ،
\v 4 بَرِ مَ عٍ مُ دَنشَنِيَشِ. يِ وَشَتِ مِشِيٍ مَرِفِ بَرَ عَ رَفِرِ عٍ شَشِلِ نَشَ قَهَامُي سْتْ شِبَارُ قَنيِ مَ عَلَ شَ مِشِ سُفَندِشِ نْرْشِ شَ قٍ رَ، نَشَن قِندِشِ عَلَ مِسَالِ رَ.
\p 
\v 5 مُشُ مُ مُشُ يّتّ كَن شَ قٍ شَ كَوَندِ مَ. مُشُ شَ كَوَندِ عَ مَسٍنمَ نّ عَ عَلَ شَ مِشِ سُفَندِشِ عِسَ نَن قِندِشِ مُشُ مَرِفِ رَ، عَ نُن مُشُ قَن قِندِشِ وٌ شَ كٌنيِيٍ نَن نَ عِسَ شَ قٍ رَ.
\v 6 عَلَ نَشَن عَ مَسٍنشِ، «نَءِيَلَنيِ شَ يَنبَ دِ مِ كُي،» عَ تَن بَرَ عَ شَ نْرّ مَسٍن مُشُ بّ عَ شَ مِشِ سُفَندِشِ سَابُي رَ.
\v 7 كْنْ نَ نْرّ هَفِفّ سَشِ مُشُ بْحّ مَ، بْحّ نَشَن سّنبّ شُرُن عَلْ قّحّ، عَلَكٌ مِشِيٍ شَ عَ كٌلٌن نَ سّنبّ شُنفبٍ قَتَنشِ عَلَ نَن نَ، عَ مُ قَتَنشِ مُشُ تَن شَ رَ.
\p 
\v 8 كْنتْقِلِ بَرَ مُشُ شّتّن، كْنْ مُشُ مُ بُتُشُنشِ. عَ بَرَ مُشُ شَشِلِ عِقُ، كْنْ لِمَنِيَ مُ بَشِ مُشُ يِ رَ.
\v 9 مُشُ بَرَ حَشَنكَتّ سْتْ، كْنْ عَلَ مُ مُشُ رَبٌلٌشِ. قٍ شْرْشْي بَرَ مُشُ رَبِرَ، كْنْ عَ مُ نْشِ مُشُ رَ.
\v 10 مُشُ شَ تْورّ مُشُ شَ دُنِحّءِفِرِ كُي، عَ مَنِيَشِ عِسَ فبٍ نَن نَ نَشَن قَشَ وُرِ مَفَلَنبُشِ مَ. مُشُ نَ تْورّ سْتْشِ نّ عَلَكٌ مُشُ شَ عِسَ شَ شُننَكٍلِ قَن مَسٍن مُشُ شَ دُنِحّءِفِرِ كُي.
\v 11 مُشُ نَ تْورْقٍ عِسَ شَ قٍ نَن نَ مُشُ شَ دُنِحّءِفِرِ كُي، عَلَكٌ عِسَ شَ شُننَكٍلِ قَن شَ مَكّنّن مُشُ شَ سِمَيَ كُي.
\p 
\v 12 نَ نَن نَ كِ مُشُ نَ سَيَ كِرَ نَن شْن مَ، عَلَكٌ وٌ تَن شَ كِسِ سْتْ.
\v 13 عَ سّبّشِ كِتَابُي كُي، «ﭑ تٌ دَنشَنِيَ، نَ نَن عَ تٌ ﭑ نَشَ وْيّن.» مُشُ قَن تٌ دَنشَنِيَشِ، مُشُ وْيّنشِ نَ نَن مَ.
\v 14 مُشُ نَ رَبَشِ نّ، بَرِ مَ مُشُ بَرَ عَ كٌلٌن نَشَن مَرِفِ عِسَ رَكٍلِشِ قَشّ مَ، عَ قَمَ نّ مُشُ قَن نَكٍلِدٍ قَشّ مَ عِسَ شَ قٍ رَ، عَ وٌن بِرِن شَنِن عَ يِرٍ.
\v 15 مُشُ تِنشِ نَ تْورّ بِرِن نَ وٌ شَ قٍ رَ. مُشُ تْورْ مَ نّ عَلَكٌ مِشِ فبٍفبٍ شَ عَلَ شَ هِننّ كٌلٌن، عٍ قَ تَنتُي نُن مَتْشْي رَ سِفَ عَ مَ.
\p 
\v 16 نَ كُي، لِمَنِيَ مُ بَمَ مُشُ يِ رَ. هَلِ مُشُ قَتٍ تٌ نَ كَنَقٍ، مُشُ بْحّ نَ قَنقٍ لْشْ يٌ لْشْ،
\v 17 بَرِ مَ مُشُ شَ تْورّ شُنشُرِ نَشَن مُ بُمَ، عَ نَ شُننَكٍلِ شُنفبٍ رَ مِنِقٍ مُشُ بّ، شُننَكٍلِ نَشَن مَنِيّ مُ نَ، نَشَن مُ حْنمَ عَبَدَن.
\v 18 مُشُ شَشِلِ مُ تِشِ قٍ تٌشِ شَ رَ. مُشُ شَشِلِ تِشِ قٍ نَن نَ نَشَن مُ تٌمَ. قٍ تٌشِ مُ بُمَ، كْنْ قٍ نَشَن مُ تٌمَ نَ تَن بُمَ نّ عَبَدَن.
\c 5
\s1 عَرِيَننَ كِرَ
\p 
\v 1 وٌن عَ كٌلٌن، وٌن قَتٍ لُشِ نّ عَلْ بَفٍ، وٌن نِي سَبَتِشِ دّننَشّ. نَ بَفٍ نَ كَنَ، وٌن بَنشِ فبّتّ سْتْمَ نّ عَرِيَننَ، وٌن لُمَ دّننَشّ عَبَدَن. عَلَ نَن نَ بَنشِ يَءِلَنشِ وٌن بّ، عَدَ مَدِ مُ نَشَن تِشِ.
\v 2 وٌن وَ شُي مِنِمَ يِ بَفٍ كُي، بَرِ مَ وٌن سَبَتِدٍ نَشَن نَ كٌورٍ، نَ شْلِ نَ وٌن مَ، تَا قَنيِ نَشَن نَ عَرِيَننَ.
\v 3 نَ بَنشِ نّينّ مِسَالِشِ دٌنمَ نَن نَ. وٌن وَ مَ دٌنمَ نّينّ رَفٌرٌقٍ وٌن مَ، عَلَكٌ وٌن نَشَ لُ وٌن مَفٍلِ رَ.
\v 4 دَنمِ وٌن نَ يِ بَفٍ كُي، وٌن وَ شُي رَ مِنِمَ، بَرِ مَ وٌن مُ وَ مَ دٌنمَ شَ بَ وٌن مَ. وٌن وَ مَ نّ دٌنمَ نّينّ شَ رَفٌرٌ وٌن مَ، عَلَكٌ كِسِ شَ نْ قَشّ رَ.
\v 5 عَلَ وٌن دَاشِ نَ كِسِ نَن مَ قٍ رَ. عَ بَرَ عَ يّتّ شَشِلِ رَفٌرٌ وٌن مَ نَشَن عَ مَسٍنمَ عَ قَمَ نّ وٌن كِدٍ عَرِيَننَ رَ.
\p 
\v 6 نَ نَن عَ تٌشِ وٌن لِمَنِيَشِ. وٌن عَ كٌلٌن، دَنمِ وٌن نِي سَبَتِشِ يِ قَتٍ عِ، وٌن مَكُيَ مَرِفِ رَ.
\v 7 وٌن مَ حّرّ كُي وٌن شَشِلِ تِشِ قٍ نَن نَ وٌن مُ نَشَن تٌشِ سِندٍن.
\v 8 وٌن مَ لِمَنِيَ شَ قٍ رَ، وٌن وَ مَ كٍلِقٍ يِ قَتٍ كُي، وٌن شَ سَبَتِ مَرِفِ شْنيِ.
\v 9 نَ كُي، شَ وٌن نِي نَ وٌن قَتٍ كُي، شَ نَ مُ عَ رَ وٌن نِي بَرَ كٍلِ وٌن قَتٍ كُي، وٌن قٍ بِرِن نَبَمَ عَلَ سَفٌ رَكَمَلِقٍ نَن نَ.
\v 10 وٌن نَ رَبَمَ نّ بَرِ مَ عَلَ شَ مِشِ سُفَندِشِ قَمَ نّ وٌن بِرِن مَكِيتِدٍ، عَلَكٌ كَنكَن شَ عَ سَرٍ سْتْ عَ شَ قٍ قَنيِيٍ نُن عَ شَ قٍ حَاشِيٍ مَ، عَ نَشٍيٍ رَبَشِ عَ شَ دُنِحّءِفِرِ كُي.
\p 
\v 11 مُشُ تٌ مَرِفِ شَ يَرَفَاشُي كٌلٌن، مُشُ كَتَمَ مِشِيٍ نَن نَقَدٍ عَلَ مَ. عَلَ مُشُ حّرّ كِ كٌلٌن. ﭑ وَ مَ لَقٍ عَ رَ، وٌ قَن مُشُ حّرّ كِ كٌلٌن وٌ بْحّ كُي.
\v 12 مُشُ مُ وَ مَ فبِلٍنقٍ مُشُ شُنمَقَلَقٍ رَ وٌ بّ. مُشُ وَ مَ نّ تُن وٌ شَ حّلّشِن مُشُ شَ قٍ رَ، عَلَكٌ وٌ شَ نْ مِشِيٍ يَابِدٍ نَشٍيٍ عٍ يّتّ عِفبٌمَ قٍيٍ قُقَقُ رَ، نَشٍيٍ مُ كٍلِمَ عٍ بْحّ كُي.
\v 13 شَ مُشُ بَرَ سٌ قٍ ندٍيٍ كُي نَشَن لُشِ عَلْ دَشُحَ دُنِحَ مِشِيٍ بّ، مُشُ نَ رَبَشِ عَلَ نَن بّ. كْنْ شَ مُشُ بَرَ حّرّ شَشِلِ قَنيِ بّرّ رَ، مُشُ نَ رَبَشِ وٌ تَن نَن بّ.
\p 
\v 14 عَلَ شَ مِشِ سُفَندِشِ شَ شَنُنتٍيَ نَن مُشُ تُتُنمَ. مُشُ بَرَ عَ كٌلٌن مِشِ كٍرٍن بَرَ قَشَ عَدَ مَ بِرِن بّ. نَ كُي، مِشِ بِرِن بَرَ قَشَ.
\v 15 عَ بَرَ قَشَمِشِ بِرِن بّ، عَلَكٌ نَشٍيٍ حِحّ عَ رَ عٍ شَ عٍ يّتّ وَشْنقٍ لُ نَ، عٍ شَ وَلِ عِسَ بّ نَشَن قَشَ عٍ بّ، نَشَن مَن كٍلِ قَشّ مَ عٍ بّ.
\v 16 نَ نَن عَ تٌشِ، كٍلِقٍ يَكْسِ، وٌن مُ مِشِ تٌمَ عَلْ دُنِحَ مِشِيٍ عٍ تٌمَ كِ نَشّ. سِنفٍ وٌن نُ عَلَ شَ مِشِ سُفَندِشِ تٌمَ نّ عَلْ دُنِحَ مِشِيٍ عَ تٌشِ كِ نَشّ، كْنْ يَكْسِ وٌن مُ عَ كٌلٌنشِ نَ كِ سْنْن.
\p 
\v 17 مِشِ نُن عَلَ شَ مِشِ سُفَندِشِ نَ لُ قٍ كٍرٍن كُي، عَ قِندِ مَ مِشِ نّينّ نَن نَ. عَ شَ قٍ قٌرِ بَرَ مَسَرَ قٍ نّينّ رَ.
\v 18 نَ بِرِن قَتَنشِ عَلَ نَن نَ، نَشَن وٌن نَفبِلٍنشِ عَ يّتّ مَ عَ شَ مِشِ سُفَندِشِ سَابُي رَ. عَ مَن بَرَ وَلِ تَشُ وٌن نَ عَدَ مَدِيٍ رَفبِلٍنقٍ رَ عَ مَ.
\v 19 عَلَ بَرَ دُنِحَ رَفبِلٍن عَ مَ عَ شَ مِشِ سُفَندِشِ سَابُي رَ، عَ دِحّ عَدَ مَدِيٍ شَ يُنُبِيٍ مَ. عَ مَن بَرَ نَ مَسٍنيِ سٌ وٌن يِ رَ نَشَن عَ نِيَمَ مِشِيٍ شَ فبِلٍن عَ مَ.
\v 20 نَ كُي، وٌن بَرَ قِندِ عَلَ شَ مِشِ سُفَندِشِ شَ شّيرَيٍ رَ. عَ لُشِ نّ عَلْ عَلَ نَ كَوَندِ تِقٍ وٌن تَن نَن سَابُي رَ. مُشُ بَرَ وٌ مَيَندِ عَلَ شَ مِشِ سُفَندِشِ شِلِ رَ، وٌ شَ فبِلٍن عَلَ مَ.
\v 21 عِسَ نَشَن مُ يُنُبِ يٌ رَبَشِ، عَلَ بَرَ عَ قِندِ وٌن مَ يُنُبِ سَرٍ رَ. نَ نَن عَ تٌشِ وٌن قِندِشِ تِنشِن مِشِيٍ رَ عَلَ يَ تٌدٍ رَ عِسَ سَابُي رَ.
\c 6
\s1 عَلَ شَ وَلِكّيٍ شَ مَرَ سِ
\p 
\v 1 مُشُ تَن، عَلَ شَ وَلِكّيٍ، مُشُ بَرَ وٌ رَ سِ وٌ نَشَ عَلَ شَ هِننّ سْتْ قُ رَ.
\v 2 عَلَ بَرَ عَ مَسٍن كِتَابُي كُي، «ﭑ بَرَ وٌ شَ دُبَ سُشُ ﭑ مَ هِننّ وَشَتِ، ﭑ بَرَ وٌ مَلِ وٌ شَ كِسِ لْشْي.» وٌ شَ عَ كٌلٌن عَلَ شَ هِننّ وَشَتِ بَرَ عَ لِ. تٌ نَن قِندِشِ كِسِ لْشْي رَ وٌ بّ.
\p 
\v 3 مُشُ تَن مُ سٍسٍ رَبَمَ نَشَن نْمَ مِشِ رَتَنتَندٍ، مِشِيٍ قَ عَ قَلَ عَ مُشُ وَلِ كٌبِ نَن نَبَشِ.
\v 4 مُشُ بَرَ قٍ بِرِن نَبَ شِلِ قَنيِ سْتْقٍ رَ عَلَ شَ وَلِكّ لَنمَ عَ شَ نَشَن نَبَ. مُشُ بَرَ تُننَبّشِيَ رَبَ حَشَنكَتّ، سٍتَرٍحَ، نُن كْنتْقِلِ كُي.
\v 5 عٍ بَرَ مُشُ بْنبْ، عٍ مُشُ رَ سٌ فٍيلِ كُي، عٍ فَلِ بْحّ رَتٍ مُشُ شِلِ مَ. مُشُ بَرَ وَلِ شْرْشْي رَبَ، مُشُ مُ شِ، مُشُ بَرَ كَامّ.
\v 6 مُشُ بَرَ مُشُ تُننَبّشِ سّنِيّنيِ، قَهَامُي، دِحّ، قٍ قَنيِ، شَشِلِ سّنِيّنشِ، نُن شَنُنتٍيَ قِيشّ كُي.
\v 7 مُشُ مُ بَ نْندِ قَلَقٍ، مُشُ قٍ بِرِن نَبَمَ عَلَ سّنبّ سَابُي نَن نَ. مُشُ بَرَ عَلَ شَ فٍرٍ قَنيِ سُشُ تِنشِنيِ كُي مُشُ بّلّشّ قِرِن نَ.
\v 8 مُشُ وَلِمَ بِنيّ نُن يٍلٍبُي سْتْي نَن كُي. مُشُ بَرَ شِلِ قَنيِ نُن شِلِ كَنّ سْتْ. ندٍيٍ بَرَ مُشُ قِندِ وُلٍ قَلّيٍ رَ، كْنْ مُشُ نْندِ فبَنسَن نَن قَلَمَ.
\v 9 هَلِ عٍ مُشُ كٌلٌن، عٍ قٍ رَبَمَ مُشُ رَ عَلْ عٍ مُ مِشِ نَشَن كٌلٌن. مُشُ مَنِيَمَ مِشِ رَ نَشَن نَ سَيَ كِرَ شْن مَ، كْنْ مُشُ مُ قَشَشِ. مُشُ بَرَ حَشَنكَتَ، كْنْ مُشُ مُ قَشَشِ.
\v 10 سُننُن مِشِيٍ نَن مُشُ رَ، كْنْ سّيوّ نَ مُشُ بْحّ كُي. سٍتَرٍيٍ نَن مُشُ رَ، كْنْ بَننَيَ نَ مُشُ يِ رَ. مِسِكِينّيٍ نَن مُشُ رَ، كْنْ قٍ بِرِن نَ مُشُ يِ رَ.
\p 
\v 11 مُشُ مُ مَسٍنيِ يٌ نْشُنشِ وٌ مَ. وٌ شَ قٍ بَرَ لُ مُشُ سٌندٌنيِ مَ.
\v 12 مُشُ بْحّ مُ بَلَنشِ وٌ مَ، كْنْ وٌ تَن بَرَ وٌ بْحّ بَلَن مُشُ مَبِرِ.
\v 13 ﭑ مَ دِيٍ، يَندِ، وٌ قَن شَ شَنُنتٍيَ شُن شَ مَسَ مُشُ مَبِرِ.
\p 
\v 14 لَنيِ نَشَ لُ وٌ نُن دَنشَنِيَتَرٍيٍ تَفِ. مُنسٍ نَ تِنشِنيِ نُن تِنشِنتَرٍيَ تَفِ؟ نَءِيَلَنيِ نُن دِ مِ نْمَ لُدٍ يِرٍ كٍرٍن؟
\v 15 عَلَ شَ مِشِ سُفَندِشِ نُن سٍنتَنّ لَنمَ قٍ كٍرٍن مَ؟ دَنشَنِيَتْي نُن دَنشَنِيَتَرٍ لَنمَ مُنسٍ مَ؟
\v 16 كُيٍ تٌمَ عَلَ شَ هْرْ مْبَنشِ كُي؟ وٌن تَن نَن قِندِشِ عَلَ حِحّ شَ هْرْ مْبَنشِ رَ. عَلَ يَتِ عَ قَلَ نّ، «ﭑ حّرّ مَ نّ وٌ يَ مَ. وٌ مَرِفِ عَلَ نَن ﭑ نَ، وٌ قَن قِندِ مَ نّ ﭑ مَ حَمَ رَ.»
\v 17 نَ نَن عَ تٌشِ مَرِفِ نَشَ عَ قَلَ، «وٌ شَ مِنِ عٍ يَ مَ، وٌ شَ لُ وٌ شَتِ مَ. وٌ نَشَ دِن قٍ سّنِيّنتَرٍ رَ، عَلَكٌ ﭑ شَ وٌ رَ سّنّ.»
\v 18 عَلَ شِلِ شُنفبٍ كَنيِ شَ مَسٍنيِ نَن يَ، «ﭑ قِندِ مَ وٌ بَبَ نَن نَ، وٌ تَن قَن قِندِ ﭑ مَ دِيٍ رَ.»
\c 7
\s1 ثْلُ شَ شَنُنتٍيَ كٌرِنتِكَيٍ بّ
\p 
\v 1 ﭑ شَنُنتٍنيِيٍ، عَلَ تٌ نَ لَايِدِ مْولِيٍ تٌنفٌ وٌن بّ، وٌن قَتٍ نُن وٌن بْحّ شَ لُ سّنِيّنيِ كُي. وٌن مَ سّنِيّنيِ شَ كَمَلِ عَلَ شَ يَرَفَاشُي كُي.
\p 
\v 2 وٌ شَ تِن مُشُ شَ قٍ رَ. مُشُ مُ قٍ حَاشِ يٌ رَبَشِ وٌ رَ، مُشُ مُ وٌ شُن نَكَنَ، مُشُ مُ وٌ رَوَلِ.
\v 3 ﭑ مُ وَ مَ كِيتِ حَاشِ سَقٍ وٌ مَ. ﭑ حَن بَرَ عَ قَلَ وٌ بّ شَنُنتٍيَ نَ وٌن تَفِ هَن مُشُ بَرَ تِن قٍ بِرِن نَبَدٍ وٌ بّ، هَلِ نَ قِندِ مَ قَشّ نَن نَ.
\v 4 لَنلَنتٍيَ قَنيِ نَ وٌن تَفِ. ﭑ بَرَ حّلّشِن وٌ شَ قٍ رَ، نَ قَن بَرَ قِندِ لِمَنِيَ رَ ﭑ بّ. هَلِ ﭑ نَ تْورّ كُي، وٌ بَرَ عَ نِيَ ﭑ مَ سّيوّ شَ كَمَلِ.
\p 
\v 5 مُشُ تٌ قَ مَسٍدٌن، مُشُ مُ مَلَبُي سْتْ، مُشُ تْورّ مْولِ بِرِن نَن لِ نَا؛ فٍرٍ نَ مُشُ رَبِلِنيِ، فَاشُي قَن نَ مُشُ بْحّ مَ.
\v 6 كْنْ عَلَ، نَشَن مِشِ لِمَنِيَتَرٍ رَلِمَنِيَمَ، عَ بَرَ مُشُ قَن نَلِمَنِيَ تِتٌ قَقٍ سَابُي رَ.
\v 7 عَ قَقٍ فبَنسَن شَ مُ عَ رَ. وٌ مّينِشِ عَ مَ كِ نَشّ، نَ قَن بَرَ قِندِ لِمَنِيَ رَ مُشُ بّ. عَ بَرَ عَ قَلَ مُشُ بّ ﭑ شْلِ بَرَ وٌ سُشُ، هَن نَ بَرَ قِندِ يَيٍ رَ وٌ بّ. عَ بَرَ وٌ شَ مَرَقَنيِ شَ قٍ قَلَ مُشُ بّ ﭑ تَن مَبِرِ. نَ بَرَ ﭑ نَسّيوَ عَ قَنيِ رَ.
\p 
\v 8 ﭑ عَ كٌلٌن ﭑ مَ بَتَاشّ بَرَ وٌ رَ سُننُن، كْنْ عَ مُ حَاشُ ﭑ بّ. هَلِ ﭑ تٌ مُ نُ وَ مَ ﭑ مَ بَتَاشّ شَ وٌ رَ سُننُن، ﭑ عَ كٌلٌن نَ سُننُنيِ شْن مُ كُيَ قَ.
\v 9 يَكْسِ ﭑ بَرَ حّلّشِن نَ شَ قٍ رَ. ﭑ مُ حّلّشِن وٌ شَ سُننُنيِ شَ رَ، كْنْ ﭑ حّلّشِنشِ نّ بَرِ مَ نَ سُننُنيِ بَرَ عَ نِيَ وٌ شَ تُوبِ. نَ كُي، ﭑ عَ كٌلٌن نَ سُننُنيِ قَتَنشِ عَلَ نَن نَ، عَ مُ قَتَنشِ مُشُ تَن شَ رَ.
\v 10 عَلَ مِشِيٍ رَ سُننُنمَ نّ عَلَكٌ عٍ شَ تُوبِ، عٍ قَ كِسِ. نَ سُننُنيِ مْولِ مُ قِندِ مَ مْنّ رَ، كْنْ سُننُنيِ نَشَن قَتَنشِ دُنِحَ رَ، نَ قِندِ مَ قَشّ نَن نَ.
\p 
\v 11 عَلَ بَرَ نَ سُننُنيِ رَوَلِ وٌ شَ قٍ رَ، عَلَكٌ وٌ شَ وٌ تُننَبّشِ، وٌ شَ وٌ يّتّ شُنمَقَلَ، وٌ شَ شْنْ قٍ حَاشِ مَ، وٌ شَ فَاشُ عَلَ يَ رَ، وٌ شَ قٍ قَنيِ سُشُ سّنبّ رَ، وٌ شَ قٍ حَاشِ مَكِيتِ. وٌ بَرَ عَ مَسٍن وٌ بْحّ قِيشّ رَ قٍ دَنفِشِ كُي.
\v 12 ﭑ تٌ بَتَاشّ سّبّ وٌ مَ، ﭑ مُ عَ سّبّشِ نَ قٍ حَاشِ رَبَيٍ شَ قٍ شَ رَ، ﭑ مُ عَ سّبّ نَ مِشِ شَ قٍ رَ نَشَن بَرَ قٍ حَاشِ سْتْ. ﭑ عَ سّبّ نّ عَلَكٌ مُشُ شَ مَرَقَنيِ نَشَن نَ وٌ بّ عَ شَ مِنِ كّنّ مَ عَلَ بّ.
\v 13 نَ بِرِن بَرَ مُشُ رَلِمَنِيَ. مُشُ مَن بَرَ حّلّشِن تِتٌ شَ سّيوّ شَ قٍ رَ، وٌ نَشَن بْحّ رَلِمَنِيَشِ عَ قَنيِ رَ.
\v 14 ﭑ نُ بَرَ قٍ قَنيِ قَلَ عَ بّ وٌ شَ قٍ رَ. وٌ مُ ﭑ نَيَافِشِ نَ كُي. مُشُ نَشَن قَلَشِ وٌ بّ، عَ بِرِن قِندِشِ نْندِ نَن نَ. مُشُ نَشَن قَلَشِ تِتٌ بّ وٌ شَ قٍ رَ، نَ قَن بِرِن قِندِشِ نْندِ نَن نَ.
\v 15 وٌ شَ مَرَقَنيِ عَ بّ، عَ شُن بَرَ مَسَ، بَرِ مَ وٌ تٌ عَ رَ سّنّ، عَ بَرَ وٌ شَ بَتُي نُن وٌ شَ يَرَفَاشُي تٌ.
\v 16 ﭑ بَرَ حّلّشِن نَ لَنلَنتٍيَ رَ نَشَن نَ وٌن تَفِ، عَ مُ كَنَمَ قٍقٍ مَ.
\c 8
\s1 دَنشَنِيَتْي حَمَ شَ مَلِ
\p 
\v 1 ﭑ نفَشَكٍرٍنيِيٍ، ﭑ شَ عَ قَلَ وٌ بّ عَلَ هِننّشِ مَسٍدٌن دَنشَنِيَتْي حَمَيٍ رَ كِ نَشّ.
\v 2 هَلِ عٍ تٌ نُ نَ حَشَنكَتّ شْرْشْي كُي، عٍ شَ سّيوّ شُنفبٍ نُن عٍ شَ سٍتَرٍحَ شْرْشْي عَ نِيَشِ نّ عٍ شَ كِ تِ عَ قَنيِ رَ.
\v 3 ﭑ بَرَ قِندِ عٍ شَ سٍيدٍ رَ. عٍ بَرَ مِشِ كِ عَلْ عٍ نُ نْمَ نَشَن نَ، عٍ مَن دَنفِ نَ رَ.
\v 4 عٍ نَشَ مُشُ مَيَندِ عٍ يّتّ حَنِفٍ رَ، عَ عٍ قَن شَ سّنِيّنتْييٍ مَلِ عَلْ بٌورٍيٍ عَ رَبَمَ كِ نَشّ.
\v 5 نَ بَرَ دَنفِ مُشُ وَشْنقٍ رَ. عَ سِنفٍ عٍ نَشَ عٍ يّتّ قِ مَرِفِ مَ. نَ دَنفِ شَنبِ، عٍ مَن نَشَ عٍ يّتّ قِ مُشُ مَ عَلْ عَلَ نُ وَ مَ عَ شْن مَ كِ نَشّ.
\p 
\v 6 مُشُ بَرَ تِتٌ رَ سِ، عَ شَ نَ وَلِ قَنيِ رَكَمَلِ وٌ بّ عَ نَشَن قْلْشِ.
\v 7 وٌ بَرَ شُننَكٍلِ سْتْ قٍ بِرِن كُي، عَلْ وٌ شَ دَنشَنِيَ، وٌ شَ مَسٍنيِيٍ، وٌ شَ لْننِ، وٌ شَ تُننَبّشِ، نُن وٌ شَ شَنُنتٍيَ مُشُ شَ قٍ رَ. وٌ شَ شُننَكٍلِ سْتْ يِ وَلِ قَنيِ قَن شَ قٍ رَ.
\v 8 ﭑ مُ وٌ يَمَرِقٍ شّ. ﭑ وَ مَ عَ كٌلٌنقٍ نّ شَ وٌ شَ شَنُنتٍيَ قِيشّ عَلْ بٌورٍيٍ فبٍ قِيشّشِ كِ نَشّ.
\p 
\v 9 وٌ عَ كٌلٌن وٌن مَرِفِ عِسَ، عَلَ شَ مِشِ سُفَندِشِ، عَ هِننّشِ وٌن نَ كِ نَشّ. قٍ بِرِن نُ نَ عَ يِ رَ، كْنْ عَ نَشَ دِحّ نَ بِرِن مَ وٌ تَن بّ، عَلَكٌ وٌ شَ بَننَ عَ شَ سٍتَرٍحَ سَابُي رَ.
\v 10 ﭑ بَرَ وٌ رَ سِ نَ مَ عَلَكٌ عَ شَ قِندِ قٍ قَنيِ رَ وٌ بّ. يَالَ وٌ تَن نَن سِنفٍ نَ نَتّ تٌنفٌ، وٌ تَن نَن سِنفٍ كْبِرِ مَلَن قْلْ.
\v 11 يَكْسِ قَ، وٌ شَ نَ رَحْن، عَلَكٌ وٌ حَنِفٍ قَنيِ شَ كَمَلِ وٌ شَ قّيرّ بّرّ رَ.
\v 12 شَ وٌ مِشِيٍ كِمَ حَنِفٍ قَنيِ رَ، وٌ عٍ مَلِ وٌ نْمَ نَشَن نَ، نَ قِندِ مَ قٍ قَنيِ رَ. شَ نَ قّيرّ مُ نَ وٌ يِ رَ، قٍقٍ مُ عَ رَ.
\p 
\v 13 مُشُ مُ وَ مَ وٌ تَن شَ تْورْ عَلَكٌ بٌورٍيٍ شَ سٍ سْتْ. وٌ بِرِن شَ لَن.
\v 14 يِ وَشَتِ، وٌ هَرِفٍ قَنيِ نْمَ نّ عٍ مَلِدٍ عٍ شَ سٍتَرٍحَ كُي. وَشَتِ فبّتّ، عٍ تَن قَن هَرِفٍ قَنيِ نْمَ نّ وٌ قَن مَلِدٍ وٌ شَ سٍتَرٍحَ كُي. نَ كُي، وٌ بِرِن بَرَ لَن،
\v 15 عَلْ عَ سّبّشِ كِتَابُي كُي كِ نَشّ، «نَشَن عَ فبٍفبٍ مَلَنشِ، عَ مُ دَنفِ عَ عِ. نَشَن دٌندٌرٌنتِ مَلَنشِ، عَ عَ هَيِ لِشِ نّ.»
\p 
\v 16 عَلَ تَنتُ، بَرِ مَ عَلَ بَرَ عَ نِيَ وٌ شَ قٍ شَ لُ تِتٌ بْحّ كُي، عَلْ مُشُ تَن.
\v 17 عَ بَرَ مُشُ شَ مَرَ سِ سُشُ. عَ مَن بَرَ نَتّ تٌنفٌ عَ يّتّ رَ حّلّشِنيِ كُي، عَ شَ سِفَ وٌ يِرٍ.
\v 18 مُشُ نَ مُشُ نفَشَكٍرٍنيِ ندٍ شّيقٍ عَ مَتِدٍ، دَنشَنِيَتْي حَمَ نَشَن بِرِن مَتْشْمَ عَ شَ كَوَندِ شَ قٍ رَ.
\v 19 دَنشَنِيَتْي حَمَيٍ بَرَ عَ سُفَندِ عَ شَ مُشُ قَن مَتِ نَ كْبِرِ شَنِندٍ. مُشُ نَ بِرِن نَبَمَ نّ عَلَكٌ عَلَ شَ مَتْشْي سْتْ، عَ نُن مَن مُشُ شَ حَنِفٍ قَنيِ شَ رَبَ.
\v 20 مُشُ مُ وَ مَ مِشِ يٌ شَ قٍ حَاشِ تٌ مُشُ وَلِ كِ مَ، مُشُ نَ كْبِرِ يَ رَقَنيِ رَوَلِمَ كِ نَشّ.
\v 21 مُشُ قٍ قَنيِ نَن تُن قٍنمَ نَ وَلِ كُي مَرِفِ نُن عَدَ مَدِيٍ يَ شْرِ.
\p 
\v 22 مُشُ نَ وٌن نفَشَكٍرٍنيِ فبّتّ قَن شّيقٍ بٌورٍيٍ مَتِدٍ. مُشُ بَرَ عَ تٌ سَنيَ وُيَشِ، مُشُ شَ قٍ نَ عَ بْحّ مَ سّنبّ رَ. يَكْسِ، ندٍ بَرَ سَ نَ سّنبّ قَرِ، بَرِ مَ عَ مَن بَرَ لَ وٌ تَن نَ.
\v 23 ﭑ وَلِبٌورٍ تِتٌ قِندِشِ ﭑ تَن نَن مَ شّيرَ رَ وٌ بّ. عَ مَتِمَيٍ قِندِشِ دَنشَنِيَتْي حَمَيٍ نَن مَ شّيرَيٍ رَ عَلَ شَ مِشِ سُفَندِشِ شَ بِنيّ شَ قٍ رَ.
\v 24 نَ كُي، وٌ شَ وٌ شَ شَنُنتٍيَ مَسٍن يِ مِشِيٍ بّ عَلَكٌ دَنشَنِيَتْي حَمَ بِرِن شَ عَ كٌلٌن مُشُ قٍ قَنيِ نَشٍيٍ قَلَشِ وٌ شَ قٍ رَ، عَ نْندِ نَ عَ رَ.
\c 9
\s1 دَنشَنِيَتْييٍ مِشِ مَلِمَ كِ نَشّ
\p 
\v 1 هَلِ ﭑ مُ بَتَاشّ سّبّ وٌ مَ سّنِيّنتْييٍ مَلِقٍ شَ قٍ رَ.
\v 2 ﭑ حَن بَرَ وٌ حَنِفٍ قَنيِ كٌلٌن. ﭑ بَرَ وٌ مَتْشْ مَسٍدٌنكَيٍ بّ، عَ قَلَقٍ رَ وٌ تَن عَكَيِكَيٍ رّدِشِ نَ كْبِرِ مَلَنقٍ رَ كَبِ يَالَ. وٌ تٌ نَ نَتّ سُشُ سّنبّ رَ، عٍ قَن بَرَ وَ سٌقٍ نَ كُي.
\v 3 يَكْسِ ﭑ نَ ﭑ نفَشَكٍرٍنيِيٍ شّيقٍ وٌ يِرٍ، عَلَكٌ ﭑ مَتْشْي نَشَن نَبَشِ وٌ شَ قٍ رَ، عَ نَشَ قِندِ وُلٍ رَ. وٌ شَ كْبِرِ مَلَن سِننَنيِ مَ، عَلَكٌ عٍ شَ عَ لِ نَا عَلْ ﭑ وٌ شَ قٍ قَلَ عٍ بّ كِ نَشّ.
\v 4 شَ عَ سَ لِ ﭑ نُن مَسٍدٌنكَيٍ مُ وٌ شَ لَايِدِ تٌنفٌشِ رَكَمَلِشِ لِمَ نَا، نَ قِندِ مَ يَافِ نَن نَ ﭑ بّ، عَ قِندِ مَ يَافِ بٍلٍبٍلٍ نَن نَ وٌ قَن بّ.
\v 5 نَ كُي، ﭑ بَرَ ﭑ نفَشَكٍرٍنيِيٍ شّي وٌ يِرٍ سِننَنيِ مَ، عَلَكٌ وٌ شَ لَايِدِ شَ كَمَلِ. نَ كِ وٌ نْمَ نَ رَبَدٍ وٌ وَشْنكِ، عَلَكٌ عَ نَشَ قِندِ قٍ شْرْشْي رَ وٌ بّ.
\p 
\v 6 وٌ شَ رَتُ عَ مَ، عَ نَشَن سَنسِ شْرِ شُرِ رَوَلِمَ، عَ قَن سَنسِ شُرِ دِ نَن سْتْمَ. نَشَن سَنسِ شْرِ فبٍفبٍ رَوَلِمَ، عَ قَن سَنسِ فبٍفبٍ سْتْمَ نّ.
\v 7 كَنكَن شَ مِشِ كِ عَ يّتّ حَنِفٍ رَ. تٍكُ مُ عَ رَ. عَ نَشَ مِشِ كِ نِمِسّ كُي. نَشَن مِشِ كِمَ سّيوّ كُي، نَ نَن نَقَن عَلَ مَ.
\v 8 عَلَ نْمَ بَرَكّ مْولِ بِرِن نَفٌرٌدٍ وٌ مَ. نٍيٍ وٌ هَيِ لِمَ نّ، عٍ مَن دَنفِ عَ رَ، عَلَكٌ وٌ شَ نْ وَلِ قَنيِ مْولِ بِرِن نَبَدٍ.
\v 9 عَ سّبّشِ كِتَابُي كُي، «عَ بَرَ سٍتَرٍيٍ كِ عَ قَنيِ رَ. عَ شَ تِنشِنيِ بُمَ عَبَدَن.»
\v 10 عَلَ نَشَن سَنسِ شْرِ قِمَ سَنسِسِ مَ، عَ عَ رَبَلٌ تَامِ رَ، عَ مَن وٌ تَن مَ قّيرّ رَوُيَمَ نّ، عَلَكٌ وٌ شَ وَلِ تِنشِنشِيٍ قَن شَ وُيَ.
\v 11 عَلَ وٌ كِمَ قّيرّ فبٍفبٍ نَن نَ، عَلَكٌ وٌ قَن شَ مِشِيٍ كِ عَ قَنيِ رَ. مِشِيٍ قَمَ نّ عَلَ تَنتُدٍ وٌ شَ مَلِ شَ قٍ رَ، مُشُ نَشَن سٌمَ عٍ يِ رَ وٌ شِلِ رَ.
\v 12 وٌ نَشَن قِمَ سّنِيّنتْييٍ مَ، عَ عٍ هَيِ لِمَ نّ، عَ مَن قِندِ تَنتُي فبٍفبٍ رَ عَلَ بّ.
\v 13 مِشِيٍ نَ وٌ شَ وَلِ تٌ، عٍ عَلَ تَنتُمَ نّ، بَرِ مَ وٌ شَ دَنشَنِيَ عَلَ شَ مِشِ سُفَندِشِ مَ، عَ بَرَ قِندِ بَتُي رَ. عٍ عَلَ تَنتُمَ نّ وٌ شَ مَلِ شَ قٍ رَ، وٌ هِننّشِ عٍ رَ نَشَن نَ، عَ نُن مِشِ بِرِن.
\v 14 عٍ قَمَ نّ عَلَ مَشَندِدٍ وٌ بّ شَنُنتٍيَ رَ، بَرِ مَ عٍ عَ كٌلٌن عَلَ بَرَ هِننّ وٌ رَ عَ قَنيِ رَ.
\v 15 عَلَ تَنتُ عَ شَ هِننّ شَ قٍ رَ نَشَن دَنفِ قٍ بِرِن نَ.
\c 10
\s1 ثْلُ وْيّن كِ
\p 
\v 1 ﭑ تَن ثْلُ، ﭑ وَ مَ وٌ رَ سِقٍ عَلَ شَ مِشِ سُفَندِشِ شَ دِحّ نُن عَ شَ قَنيِ نَن سَابُي رَ. وٌ نَشّ عَ ﭑ سّنبّ مُ فبٌ ﭑ نَ وٌ يَ مَ تّمُي نَشّ، قٌ ﭑ نَ مَكُيَ وٌ رَ، ﭑ قَ وْيّن شْرْشْي قَلَ وٌ بّ.
\v 2 ﭑ بَرَ وٌ مَيَندِ، وٌ نَشَ عَ نِيَ ﭑ مَ وْيّنيِ شَ شْرْشْ ﭑ قَ تّمُي وٌ يِرٍ. ندٍيٍ حْشْ عَ مَ مُشُ نَ حّرّقٍ عَدَ مَ كِ نَن تُن مَ. ﭑ وْيّنمَ عَ شْرْشْي رَ نَ مِشِيٍ نَن بّ.
\p 
\v 3 عَدَ مَدِ نَن مُشُ رَ، كْنْ مُشُ مُ فٍرٍ سٌمَ عَدَ مَ كِ شَ مَ.
\v 4 مُشُ مُ فٍرٍ سٌمَ عَدَ مَدِ شَ فٍرٍ سٌسٍيٍ شَ رَ. مُشُ فٍرٍ سٌمَ عَلَ شَ فٍرٍ سٌسٍيٍ نَن نَ نَشٍيٍ نْمَ سٍنتَنّ سّنبّيٍ كَنَدٍ. مُشُ مَحْشُنيِ بِرِن شُن نَكَنَمَ نّ
\v 5 نَشَن عَلَ شَ قٍ كٌلٌنيِ مَتَندِ مَ يّتّ عِفبٌحَ كُي. مَحْشُنيِ بِرِن شَ لُ عَلَ شَ مِشِ سُفَندِشِ شَ يَامَرِ بُن مَ.
\v 6 وٌ نَ وٌ شَ بَتُي رَكَمَلِ، نَشَن نَ تٌندِ نَ رَ، مُشُ قَمَ نّ نَ كَنيِ حَشَنكَتَدٍ.
\p 
\v 7 وٌ شَ نَ قٍ مَتٌ عَ قَنيِ رَ. شَ مِشِ لَ عَ رَ عَ قِندِشِ عَلَ شَ مِشِ سُفَندِشِ نَن فبٍ رَ، عَ شَ عَ كٌلٌن مُشُ تَن قَن نَ نَ كِ نّ.
\v 8 ﭑ مُ يَافِمَ وْيّنيِ شُنفبٍ قَلَقٍ رَ وٌ بّ مَرِفِ شَ يَامَرِ شَ قٍ رَ، عَ نَشَن قِشِ ﭑ مَ عَلَكٌ ﭑ شَ وٌ مَلِ سّنبّ سْتْدٍ. عَ مُ ﭑ شّيشِ وٌ شُن نَكَنَدٍ شّ.
\v 9 ﭑ مُ قِندِشِ مِشِ شَ رَ نَشَن نْمَ وٌ مَفَاشُدٍ ﭑ مَ سّبّلِ رَ، عَلْ وٌ عَ مَحْشُنشِ كِ نَشّ.
\v 10 ندٍيٍ عَ قَلَمَ، «عَ شَ بَتَاشّيٍ سّنبّ فبٌ، عٍ شْرْشْ، كْنْ عَ فُندِ يَتِ نَ قَ، عَ سّنبّ مُ فبٌ، عَ شَ مَسٍنيِ يُسِ يٌ مُ نَ.»
\v 11 نَ كَنيِيٍ شَ عَ كٌلٌن مُشُ نَشَن قَلَمَ مُشُ شَ بَتَاشّيٍ كُي، مُشُ قَمَ نّ نَ بِرِن نَكَمَلِدٍ مُشُ قَ تّمُي.
\p 
\v 12 مُشُ مُ سُو سَمَ مُشُ يّتّ مِسَالِدٍ يّتّ عِفبٌي رَ. مُشُ مُ وَ مَ مُشُ يّتّ مَنِيَقٍ عٍ رَ. عٍ نَ عٍ يّتّ عِفبٌ عٍ يّتّ شَ مَحْشُنيِ رَ، عٍ بَرَ فّ عٍ شَ لْننِتَرٍحَ مَسٍندٍ.
\v 13 مُشُ مُ وَ مَ مُشُ يّتّ شَ قٍ قَلَقٍ هَن ثٌن! عَلَ يَامَرِ نَشَن قِشِ مُشُ مَ مِشِيٍ بّ مُشُ نَشٍيٍ شَرَنمَ، مُشُ نَ نَن قَلَمَ وٌ بّ.
\v 14 عَ مُ لُشِ عَلْ مُشُ مُ سِفَ وٌ يِرٍ. مُشُ سِنفٍ نَن وٌ لِشِ عَلَ شَ مِشِ سُفَندِشِ شَ شِبَارُ قَنيِ رَ.
\v 15 مُشُ مُ مَتْشْي قٍنمَ هَن عَ دَنفِ عَ عِ مِشِ فبّتّيٍ شَ وَلِيٍ شَ قٍ رَ، قٌ وَلِ نَشَن سٌشِ مُشُ تَن يِ رَ. مُشُ وَ مَ نَشَن شْن، وٌ شَ دَنشَنِيَ شُن شَ مَسَ، مُشُ شَ وَلِ شَ فبٌ وٌ يَ مَ.
\v 16 نَ كِ مُشُ نْمَ نّ عَلَ شَ شِبَارُ قَنيِ مَسٍندٍ يِرٍ فبّتّ نَشٍيٍ دَنفِ وٌ رَ. مُشُ مُ مَتْشْي قٍنمَ مِشِ فبّتّيٍ شَ وَلِ قْشِيٍ رَ.
\v 17 شَ مِشِ وَ عَ يّتّ مَتْشْقٍ، مَرِفِ وَلِ نَشَن نَبَشِ عَ شَ دُنِحّءِفِرِ كُي، عَ شَ عَ يّتّ مَتْشْ مَرِفِ شَ قٍ نّ عِ.
\v 18 بَرِ مَ يّتّ مَتْشْي شَ مُ رَقَن مَرِفِ مَ، قٌ مَرِفِ يّتّ نَشَن مَتْشْمَ.
\c 11
\s1 ثْلُ شَ وَلِ
\p 
\v 1 وٌ شَ وٌ هَاكّ تٌ ﭑ بّ، عَلْ وٌ حَن نَ عَ رَبَقٍ كِ نَشّ، ﭑ شَ ﭑ مَ دَشُحَ ندٍ قَلَ وٌ بّ.
\v 2 وٌ رَقَن ﭑ مَ عَلَ شَ شَنُنتٍيَ رَ، نَشَن مُ وَ مَ عَ قِرِن ندٍ شْن. ﭑ وٌ سٌشِ عَلَ شَ مِشِ سُفَندِشِ فبَنسَن نَن يِ رَ، عَلْ فِنّ نَشَن قِشِ شّمّ مَ عَ دِ مّدِ.
\v 3 كْنْ ﭑ فَاشُشِ نّ مِشِ ندٍيٍ قَ وٌ مَدَشُقٍ، عٍ قَ وٌ شَشِلِ مَكُيَ عَلَ شَ مِشِ سُفَندِشِ شَ قٍ رَ، وٌ بِرَشِ نَشَن قْشْ رَ بْحّ قِيشّ رَ. نَ كُي، وٌ لُمَ نّ عَلْ نّينّ مَهَوَ بْشِمَسٍ نَشَن مَدَشُ يُنُبِ شَ قٍ رَ.
\v 4 ﭑ عَ قَلَمَ نَ قٍ نَن مَ، وٌ وٌ تُلِ مَتِمَ مِشِ نَن نَ، نَشَن عِسَ شَ قٍ مَسٍنمَ وٌ بّ كِ فبّتّ، بَقٍ مُشُ فبٍ كِ رَ. وٌ مَن تِنمَ شَشِلِ فبّتّ سُشُدٍ، بَقٍ عَلَ شَشِلِ سّنِيّنشِ رَ وٌ نَشَن سْتْشِ. وٌ مَسٍنيِ ندٍ رَبَتُمَ نَشَن مُ لَنشِ مُشُ شَ مَسٍنيِ مَ، وٌ لَشِ نَشَن سِنفٍ رَ.
\p 
\v 5 كْنْ ﭑ عَ كٌلٌن ﭑ مُ شُرُن نَ مِشِيٍ بّ، نَشٍيٍ عٍ يّتّ قِندِشِ وٌ بّ شّيرَ قِسَمَنتٍيٍ رَ.
\v 6 هَلِ ﭑ وْيّن كِ مُ تٌقَن عَ فبٍ رَ، كْنْ ﭑ شَشِلِ تَن فبٌ. مُشُ بَرَ نَ مَسٍن وٌ بّ عَ قَنيِ رَ.
\v 7 ﭑ تٌ ﭑ يّتّ مَفٌرٌ عَلَ شَ شِبَارُ قَنيِ مَسٍنقٍ رَ وٌ بّ سَرٍ شَنبِ، عَلَكٌ وٌ تَن شَ قٍ شَ مَتٍ، نَ قِندِشِ تَنتَنيِ نَن نَ وٌ بّ؟
\v 8 ﭑ بَرَ دَنشَنِيَتْي حَمَ فبّتّيٍ مَكُلَ، عَلَكٌ ﭑ شَ نْ وَلِدٍ وٌ بّ سَرٍ شَنبِ. ﭑ مُ ﭑ مَ كْنتْقِلِ دْشْشِ مِشِ يٌ شُن مَ وٌ يَ مَ.
\v 9 مَسٍدٌن دَنشَنِيَتْييٍ نَن قَ ﭑ مَلِدٍ ﭑ مَ تْورّ كُي. ﭑ نَ بِرِن نَبَ نّ عَلَكٌ ﭑ نَشَ قِندِ كٌتٍ رَ وٌ بّ. هَن يَ نَ شَشِلِ نَ ﭑ يِ رَ.
\v 10 ﭑ شَ نْندِ قَلَ وٌ بّ عَلَ شَ مِشِ سُفَندِشِ شِلِ رَ، ﭑ وَلِشِ وٌ بّ سَرٍ شَنبِ كِ نَشّ، ﭑ مَن وَلِمَ نَ كِ نّ عَكَيِ بْشِ بِرِن مَ، بَرِ مَ نَ قِندِشِ شُننَكٍلِ نَن نَ ﭑ بّ.
\v 11 مُنقٍ رَ؟ ﭑ مُ نَ رَبَشِ وٌ تَن بّ شَنُنتٍيَ شَ رَ؟ عَلَ عَ كٌلٌن.
\v 12 ﭑ نَشَن نَبَشِ، ﭑ مَن فبِلٍنمَ نّ نَ رَبَ رَ، عَلَكٌ مِشِ يٌ نَشَ نْ عٍ مِسَالِدٍ مُشُ رَ. ندٍيٍ وَ مَ نَ بِنيّ نَن شْن.
\v 13 نَ مِشِيٍ عٍ يّتّ قِندِشِ وٌ بّ شّيرَ قِسَمَنتٍيٍ رَ، كْنْ وُلٍ قَلّيٍ نَن عٍ رَ، نَشٍيٍ مِشِ مَدَشُمَ، عَ قَلَقٍ رَ عٍ تَن نَن قِندِشِ عَلَ شَ مِشِ سُفَندِشِ شَ شّيرَيٍ رَ.
\v 14 كْنْ نَ مُ قِندِ مَ دّ عِشَرّ رَ، بَرِ مَ هَلِ سٍنتَنّ عَ مِشِ مَدَشُمَ، عَ عَ يّتّ كَن مِسَالِ مَلٍكّ نْرْشِ رَ.
\v 15 سٍنتَنّ شَ وَلِكّيٍ قَن بِرَ مَ نَ مِسَالِ نَن قْشْ رَ، عٍ قَ عٍ يّتّ مَسٍن وَلِكّ تِنشِنشِيٍ رَ. عٍ قَمَ نّ عٍ سَرٍ سْتْدٍ.
\p 
\v 16 وٌ شَ وٌ هَاكّ تٌ ﭑ بّ، ﭑ قَن شَ ﭑ يّتّ مَتْشْ دٌندٌرٌنتِ، كْنْ وٌ نَشَ عَ مَحْشُن دَشُحَ رَ دٍ! هَلِ وٌ عَ مَحْشُن دَشُي نَ ﭑ نَ، وٌ شَ دِحّ عَلَكٌ ﭑ شَ ﭑ فبٍ قَلَ وٌ بّ.
\v 17 نَ كُي، ﭑ مُ وْيّنمَ مَرِفِ وَشْنكِ مَ. ﭑ وْيّنمَ دَشُي كِ نَن مَ نَشَن وَ مَ عَ يّتّ مَتْشْقٍ.
\v 18 مِشِ فبٍفبٍ تٌ سٌ يّتّ عِفبٌحَ كُي عَدَ مَدِ كِ مَ، ﭑ قَن شَ ﭑ كَن مَتْشْ.
\v 19 وٌ تَن شَشِلِمَيٍ، وٌ تِنمَ شَشِلِتَرٍيٍ رَ تّمُي بِرِن.
\v 20 وٌ تَن تِنمَ وٌ شَ قِندِ كٌنيِيٍ رَ، مِشِيٍ شَ وٌ رَوَلِ عَ حَاشِ رَ، عٍ شَ سٍ بِرِن بَ وٌ يِ رَ، عٍ شَ عٍ يَ رَفٌرٌ وٌ مَ، عٍ مَن شَ وٌ دّ رَفَرِن.
\p 
\v 21 ﭑ بَرَ عَ قَلَ وٌ بّ يَافِ رَ، مُشُ تَن مُ نَ سّنبّ مْولِ مَسٍنشِ وٌ بّ. كْنْ عٍ سُو سَشِ عٍ يّتّ كَن مَتْشْي نَشَن نَ، قٌ ﭑ قَن شَ سُو سَ نَ رَ، هَلِ عَ قِندِ شَشِلِتَرٍحَ رَ ﭑ بّ.
\v 22 عٍبُرُ مِشِيٍ نَن عٍ رَ؟ ﭑ تَن قَن قِندِشِ عٍبُرُ مِشِ نَن نَ. عِسِرَيِلَكَيٍ نَن عٍ رَ؟ ﭑ تَن قَن قِندِشِ عِسِرَيِلَكَ نَن نَ. عِبُرَهِمَ بْنسْي نَن عٍ رَ؟ ﭑ تَن قَن عِبُرَهِمَ بْنسْي نَن ﭑ نَ.
\v 23 عَلَ شَ مِشِ سُفَندِشِ شَ وَلِكّيٍ نَن عٍ رَ؟ وٌ وٌ هَاكّ تٌ ﭑ بّ دٍ، ﭑ تَن دَنفِ عٍ رَ. ﭑ بَرَ وَلِ دَنفِ عٍ رَ، ﭑ بَرَ سَ فٍيلِ دَنفِقٍ عٍ رَ، ﭑ بَرَ بْنبْي سْتْ دَنفِقٍ عٍ رَ، ﭑ بَرَ مَكْرّ قَشّ دّ رَ دَنفِقٍ عٍ رَ.
\p 
\v 24 سَنمَيَ سُولِ يُوِقِيٍ ﭑ بْنبْمَ سّبّرّ يَ تٌنفٌ سَشَن نُن سٌلٌمَنَانِ رَ.
\v 25 سَنمَيَ سَشَن عٍ ﭑ بْنبْمَ فبٍنفبٍتَ رَ. سَنمَيَ كٍرٍن عٍ بَرَ ﭑ مَفْنْ فّمّيٍ رَ. سَنمَيَ سَشَن ﭑ مَ كُنكُي دُلَمَ بَا مَ. سَنمَيَ كٍرٍن ﭑ بَرَ شِ كٍرٍن نُن كْي كٍرٍن نَدَنفِ يٍ شْورَ بَا مَ.
\v 26 ﭑ مَ بِيَاسِ وُيَشِ كُي، ﭑ بَرَ تْورْ شُرٍ عِفِرِقٍ رَ، ﭑ بَرَ تْورْ مُحّتِيٍ شَ قٍ رَ، ﭑ يّتّ كَن بْنسْي مِشِيٍ بَرَ ﭑ تْورْ، كَاقِرِيٍ قَن نُ بَرَ ﭑ تْورْ. ﭑ بَرَ تْورْ تَايٍ، فبٍنفبٍرٍنيِ، نُن بَا مَ. دَنشَنِيَتْي وُلٍ قَلّيٍ قَن بَرَ ﭑ تْورْ.
\v 27 ﭑ بَرَ تْورْ وَلِ شْرْشْييٍ شَ قٍ رَ. سَنمَيَ وُيَشِ ﭑ مُ شِ، ﭑ مُ بَلٌي سْتْ، ﭑ مُ يٍ مِن، ﭑ لُ كَامّ رَ، ﭑ مُ سٌسٍ سْتْ حّمّ رَ.
\v 28 نَشَن سَشِ نَ بِرِن قَرِ، لْشْ يٌ لْشْ ﭑ كْنتْقِلِمَ دَنشَنِيَتْي حَمَيٍ شَ قٍ رَ.
\v 29 سّنبّ نَ بَ مِشِ ندٍ، عَ بَرَ بَ ﭑ قَن نَ. دَنشَنِيَتْي نَ يُنُبِ قٍ رَبَ، عَ ﭑ سٌندٌنيِ تْورْ مَ نّ عَلْ تّ نَ سَ عَ مَ.
\p 
\v 30 عِيٌ، شَ عَ لَنمَ ﭑ شَ ﭑ يّتّ مَتْشْ قٍ ندٍ رَ، ﭑ نَن ﭑ يّتّ مَتْشْمَ ﭑ مَ سّنبّتَرٍيَ نَن نَ.
\v 31 عَلَ، نَشَن قِندِشِ مَرِفِ عِسَ بَبَ رَ، نَشَن مَتْشْمَ عَبَدَن، عَ عَ كٌلٌن ﭑ مُ وُلٍ قَلَمَ.
\p 
\v 32 دَ مَسِ فٌمِنَ، نَشَن نُ نَ مَنفّ عَرٍتَسِ شَ يَامَرِ بُن مَ، عَ نَشَ تَا نَادّيٍ بَلَن عَلَكٌ عَ شَ ﭑ سُشُ،
\v 33 كْنْ دَنشَنِيَتْييٍ نَشَ ﭑ نَفٌرٌ تَا تّتّ وُندّرِ رَ دٍبٍ كُي، ﭑ قَ ﭑ بَ عَ يِ رَ.
\c 12
\s1 ثْلُ شَ مَتْشْي
\p 
\v 1 ﭑ لَنمَ ﭑ شَ ندٍ سَ نَ مَتْشْي قَرِ؟ نَ يُسِ مُ نَ، كْنْ ﭑ مَن شَ لَامَتُنيِيٍ نُن مَسٍنيِيٍ شَ قٍ قَلَ وٌ بّ مَرِفِ نَشٍيٍ قِشِ ﭑ مَ.
\v 2 عِسَيَنكَ ندٍ نُ نَ، نَشَن شَنِن كٌورٍ وَلَشّ سَشَن ندٍ. نَ حّ قُ نُن نَانِ نَن يِ كِ. ﭑ مُ عَ كٌلٌن شَ عَ قَتٍ يَتِ نَن سِفَ، شَ نَ مُ عَ شَشِلِ فبَنسَن. عَلَ عَ كٌلٌن.
\v 3 هَلِ عَلَ فبَنسَن نَن تٌ عَ كٌلٌن، شَ عَ قَتٍ يَتِ نَن سِفَ، شَ نَ مُ عَ رَ عَ شَشِلِ فبَنسَن، ﭑ قٍ كٍرٍن نَن كٌلٌن،
\v 4 نَ شّمّ شَنِنشِ نّ عَرِيَننَ. مّننِ عَ نَشَ قٍيٍ مّ، نَشٍيٍ مُ دَشَ عَدَ مَ شَ عٍ مَسٍن عَ بٌورٍ بّ.
\v 5 ﭑ بَرَ نَ شّمّ مَتْشْ. ﭑ تَن نَن لَنشِ نَ شّمّ مَ، كْنْ ﭑ مُ وَ مَ ﭑ يّتّ مَتْشْقٍ. ﭑ نَن ﭑ مَ سّنبّتَرٍيَ فبَنسَن نَن مَتْشْمَ.
\p 
\v 6 كْنْ شَ ﭑ بَرَ وَ ﭑ يّتّ مَتْشْقٍ، نَ مُ قِندِ مَ شَشِلِتَرٍحَ رَ، بَرِ مَ ﭑ نَشَن بِرِن قَلَمَ عَ قِندِشِ نْندِ نَن نَ. ﭑ مُ نَ بِرِن قَلَمَ شّ، عَلَكٌ مِشِيٍ نَشَ ﭑ مَ قٍ عِتٍ دَنفِقٍ عٍ نَشَن تٌمَ عَ نُن عٍ نَشَن مّمَ ﭑ شُن مَ.
\v 7 نَ لَامَتُنيِيٍ تٌ مَفَاشُ، ﭑ نَشَ دُندُ.
\p عَلَ نَشَ تْورّ ندٍ دْشْ ﭑ مَ، نَشَن قَتَنشِ سٍنتَنّ شَ مَلٍكّ رَ، عَلَكٌ ﭑ نَشَ ﭑ يّتّ عِفبٌ نَ لَامَتُنيِ مَفَاشُشِيٍ شَ قٍ رَ.
\v 8 ﭑ نَشَ عَلَ مَشَندِ سَنمَيَ سَشَن عَ شَ نَ تْورّ بَ ﭑ مَ،
\v 9 كْنْ عَ نَشَ عَ مَسٍن ﭑ بّ، «ﭑ مَ هِننّ بَرَ عِ رَلِ. عِ ﭑ مَ سّنبّ كَمَلِشِ كٌلٌنمَ عِ شَ سّنبّتَرٍيَ نَن كُي.» نَ نَن عَ تٌشِ ﭑ نَن ﭑ مَ سّنبّتَرٍيَ مَتْشْمَ، عَلَكٌ عَلَ شَ مِشِ سُفَندِشِ سّنبّ شَ لُ ﭑ بّ.
\v 10 نَ نَن عَ تٌشِ سّنبّتَرٍيَ رَقَنشِ ﭑ مَ. هَلِ نَ قِندِ كٌنبِ رَ، هَلِ نَ قِندِ قٍ شْرْشْي رَ، هَلِ نَ قِندِ حَشَنكَتّ نُن تْورّ رَ ﭑ بّ عَلَ شَ مِشِ سُفَندِشِ شَ قٍ رَ، نَ بِرِن نَقَن ﭑ مَ، بَرِ مَ ﭑ عَ كٌلٌن ﭑ سّنبّ سْتْمَ ﭑ مَ سّنبّتَرٍيَ نَن كُي.
\p 
\v 11 وٌ بَرَ عَ نِيَ ﭑ شَ وْيّن عَلْ دَشُي. عَ نُ لَنمَ نّ وٌ تَن يَتِ شَ قٍ قَنيِ قَلَ ﭑ مَ قٍ رَ. هَلِ ﭑ مَ قٍ تٌ فٌرٌشِ، ﭑ مُ شُرُن نَ شّيرَ قِسَمَنتٍيٍ يَ عِ.
\v 12 ﭑ بَرَ ﭑ مَ شّيرَيَ قْشِيٍ مَسٍن وٌ بّ، ﭑ تٌ تْنشُمَيٍ، قٍ مَفَاشُشِيٍ، نُن كَابَنَكٌي رَبَ وٌ تَفِ دُلُشْتْي شُنفبٍ كُي.
\v 13 قٍ كٍرٍن فبَنسَن نَن نَ، ﭑ مُ نَشَن نَبَشِ وٌ رَ عَلْ ﭑ عَ رَبَ دَنشَنِيَتْي حَمَ فبّتّيٍ رَ كِ نَشّ. ﭑ مُ تِن قِندِدٍ كٌتٍ رَ وٌ تَن بّ. شَ نَ مُ رَقَن وٌ مَ، وٌ شَ دِحّ.
\p 
\v 14 ﭑ رّدِشِ ﭑ مَ بِيَاسِ سَشَن ندٍ رَبَقٍ رَ وٌ شْنيِ. ﭑ مُ قِندِ مَ كٌتٍ رَ وٌ بّ دٍ، بَرِ مَ ﭑ مُ وَ مَ وٌ هَرِفٍ شْن مَ. ﭑ وَ مَ وٌ تَن يَتِ نَن شْن مَ. عَ مُ لَنمَ دِيٍ شَ قّيرّ قٍن عٍ بَرِ مِشِيٍ بّ. عَ لَنمَ بَرِ مِشِيٍ نَن شَ قّيرّ قٍن عٍ شَ دِيٍ بّ.
\v 15 ﭑ تَن بَرَ تِن قّيرّ قٍندٍ وٌ بّ. ﭑ بَرَ تِن ﭑ يّتّ قِدٍ وٌ بّ. ﭑ تٌ وٌ شَنُشِ عَ فبٍ رَ، وٌ تَن ندٍ بَمَ نَ شَنُنتٍيَ نَن نَ ﭑ تَن بّ؟
\p 
\v 16 عَوَ يِرٍ، كْنْ ﭑ مُ قِندِشِ كٌتٍ رَ وٌ بّ. ندٍ عَ قَلَمَ عَ كْوتَ مِشِ نَن ﭑ نَ، عَ ﭑ بَرَ وٌ مَسْتْ كْوتَ وَلِ رَ.
\v 17 كْنْ ﭑ شَ وٌ مَشْرِن، ﭑ بَرَ وٌ رَوَلِ ﭑ مَ شّيرَيٍ سَابُي رَ؟
\v 18 ﭑ نَشَ تِتٌ مَيَندِ عَ شَ سِفَ وٌ يِرٍ. ﭑ مَن نَشَ ﭑ نفَشَكٍرٍنيِ فبّتّ شّي نَشَن عَ مَتِمَ. تِتٌ وٌ رَوَلِ نّ؟ ﭑ نُن تِتٌ مُ حّرّ شَشِلِ كٍرٍن شَ قَرِ؟ عَ مُ ﭑ تَن شَ قْشِ رَبَ؟
\v 19 ﭑ شَنُنتٍنيِيٍ، كَبِ تّمُي شْننَكُيٍ وٌ حْشْ عَ مَ مُشُ نَ مُشُ يّتّ نَن شُنمَقَلَقٍ، كْنْ مُشُ نَ عَلَ شَ مِشِ سُفَندِشِ شَ مَسٍنيِ نَن تِقٍ وٌ بّ عَلَ يَ شْرِ عَلَكٌ وٌ شَ دَنشَنِيَ شَ سَبَتِ.
\p 
\v 20 كْنْ ﭑ بَرَ فَاشُ ﭑ وٌ حّرّ كِ ندٍ لِقٍ نَا نَشَن مُ رَقَن ﭑ مَ. تّمُندٍ ﭑ قَن حّرّ كِ مُ قَمَ رَقَندٍ وٌ مَ. ﭑ بَرَ فَاشُ ﭑ نَ سِفَ وٌ شْنيِ ﭑ يِ قٍيٍ نَن لِمَ نَا؛ لَنتَرٍيَ، تْونّ، شْننَنتٍيَ، بٌورٍ مَتَندِ، وْيّن حَاشِ، نَاقِشِيَ، يّتّ عِفبٌحَ، نُن حَشَسِ.
\v 21 يِ بِيَاسِ ﭑ بَرَ فَاشُ عَلَ قَمَ نّ ﭑ مَ قٍ رَفٌرٌدٍ وٌ سَابُي رَ، ﭑ قَ نِمِسَ وٌ شَ يُنُبِيٍ شَ قٍ رَ، مِشِ ندٍيٍ مُ فبِلٍن نَشٍيٍ قْشْ رَ، عَلْ سّنِيّنتَرٍحَ، يّنّ، نُن لَنفٌيحَ.
\c 13
\s1 ثْلُ شَ بِيَاسِ سَشَن ندٍ
\p 
\v 1 ﭑ مَ بِيَاسِ سَشَن ندٍ نَن يِ كِ وٌ شْنيِ. «قٍ بِرِن مَكِيتِمَ سٍيدٍ قِرِن، شَ نَ مُ، سٍيدٍ سَشَن نَن شُي مَ.»
\v 2 ﭑ تٌ ﭑ مَ بِيَاسِ قِرِن ندٍ رَبَ وٌ شْنيِ، ﭑ نَشَ عَ قَلَ وٌ بّ، «ﭑ نَ قَ، ﭑ مُ دِحّمَ مِشِ يٌ مَ.» يَكْسِ، هَلِ ﭑ نَ يِرٍ مَكُيٍ، ﭑ مَن بَرَ فبِلٍن نَ وْيّنيِ مَ مِشِيٍ بّ، نَشٍيٍ نُ بَرَ يُنُبِ رَبَ، عَ نُن مِشِ فبّتّيٍ.
\v 3 وٌ وَ مَ عَ كٌلٌنقٍ شَ عَلَ شَ مِشِ سُفَندِشِ نَ وْيّنقٍ ﭑ سَابُي نَن نَ. وٌ قَمَ نَ كٌلٌندٍ، بَرِ مَ عَ سّنبّ مُ شُرُن وٌ بّ. عَ سّنبّ فبٌ وٌ يَ مَ.
\v 4 مِشِيٍ نَشَ عَ مَبَنبَن وُرِ مَفَلَنبُشِ مَ عَ شَ سّنبّتَرٍيَ كُي، كْنْ عَلَ نَشَ عَ رَكٍلِ قَشّ مَ سّنبّ رَ. مُشُ تَن قَن، مُشُ سّنبّ مُ فبٌ، كْنْ مُشُ قَمَ نّ لُدٍ عَ سّيتِ مَ وٌ مَلِقٍ رَ عَلَ سّنبّ سَابُي رَ.
\p 
\v 5 وٌ شَ وٌ يّتّ مَتٌ عَ كٌلٌنقٍ رَ شَ وٌ دَنشَنِيَشِ. وٌ شَ نَ مَتٌ عَ قَنيِ رَ. وٌ مُ عَ كٌلٌن عَلَ شَ مِشِ سُفَندِشِ عِسَ نَ وٌ بْحّ عِ؟ كْنْ شَ وٌ بَرَ عَ تٌ وٌ مُ دَنشَنِيَشِ، عِسَ مُ نَ وٌ بْحّ عِ دٍ!
\v 6 وٌ شَ عَ كٌلٌن مُشُ تَن دَنشَنِيَشِ.
\v 7 مُشُ عَلَ مَشَندِ مَ وٌ بّ عَلَكٌ وٌ نَشَ قٍ حَاشِ يٌ رَبَ. مُشُ مُ وَ مَ وٌ شَ لُ تِنشِنيِ كُي عَلَكٌ مُشُ شَ شِلِ قَنيِ سْتْ. مُشُ وَ مَ نَ نَن شْن وٌ تَن بّ، عَلَكٌ وٌ شَ لُ كِرَ قَنيِ شْن، هَلِ مِشِ ندٍ كِيتِ حَاشِ دْشْمَ مُشُ مَ.
\v 8 مُشُ تَن مُ نْمَ نْندِ مَتَندِدٍ، قٌ مُشُ شَ بِرَ عَ قْشْ رَ.
\v 9 شَ مُشُ سّنبّ شُرُن، كْنْ وٌ فبٍ نَشَ فبٌ، مُشُ بَرَ حّلّشِن. مُشُ عَلَ مَشَندِ مَ نّ عَلَكٌ وٌ شَ دَنشَنِيَ شَ كَمَلِ.
\v 10 ﭑ نَ بَتَاشّ سّبّقٍ وٌ مَ يِرٍ مَكُيٍ بَرِ مَ ﭑ مُ وَ مَ قٍ شْرْشْي قَلَقٍ وٌ بّ وٌ يَ شْرِ. مَرِفِ بَرَ ﭑ شّي عَ شِلِ رَ عَلَكٌ ﭑ شَ وٌ مَلِ، وٌ شُن نَكَنَقٍ مُ نَ نَشَن نَ.
\p 
\v 11 ﭑ نفَشَكٍرٍنيِيٍ، عَ دْنشْي رَ، عَلَ، شَنُنتٍيَ نُن بْحّسَ كَنيِ شَ لُ وٌ سّيتِ مَ، وٌ شَ سّيوَ، وٌ شَ كَمَلِ، وٌ شَ وٌ بٌرٍ رَلِمَنِيَ، وٌ شَ لَن وٌ بٌرٍ مَ، وٌ شَ لُ بْحّسَ كُي.
\v 12 وٌ شَ وٌ بٌرٍ شّيبُ سُنبُي سّنِيّنشِ رَ. سّنِيّنتْي بِرِن بَرَ وٌ شّيبُ.
\v 13 عَلَ شَ مِشِ سُفَندِشِ مَرِفِ عِسَ شَ هِننّ وٌ رَ، عَلَ شَ وٌ شَنُ، عَلَ شَشِلِ سّنِيّنشِ شَ لُ وٌ بْحّ عِ.
