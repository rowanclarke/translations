\s1 The Memorial  
\p
\v 10  \w The|strong="H6440"\w* \nd Lord\nd* said \w to|strong="H5921"\w* Moses, “\w Bring|strong="H5307"\w* Aaron’s staff back \w before|strong="H6440"\w* \w the|strong="H6440"\w* testimony \w to|strong="H5921"\w* \w be|strong="H6440"\w* preserved \w for|strong="H5921"\w* \w a|strong="H3068"\w* sign \w to|strong="H5921"\w* \w the|strong="H6440"\w* rebels, \w so|strong="H2063"\w* \w that|strong="H5307"\w* \w you|strong="H6440"\w* \w may|strong="H5307"\w* \w bring|strong="H5307"\w* \w their|strong="H6440"\w* murmurings \w to|strong="H5921"\w* \w an|strong="H6440"\w* \w end|strong="H3615"\w* \w before|strong="H6440"\w* \w me|strong="H6440"\w*, \w that|strong="H5307"\w* \w they|strong="H5921"\w* \w will|strong="H5307"\w* \w not|strong="H5307"\w* \w die|strong="H5307"\w*.”  
\v 11  \w So|strong="H3947"\w* \w Moses|strong="H4872"\w* \w did|strong="H3068"\w* \w as|strong="H3068"\w* \w the|strong="H6440"\w* \nd \+w Lord|strong="H3068"\+w*\nd* commanded \w him|strong="H5414"\w* – \w this|strong="H5414"\w* \w is|strong="H3068"\w* \w what|strong="H5921"\w* \w he|strong="H3588"\w* \w did|strong="H3068"\w*.   
\p
\v 12  \w The|strong="H5921"\w* Israelites \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*, “\w We|strong="H2009"\w* \w are|strong="H5971"\w* bound \w to|strong="H1696"\w* die! \w We|strong="H2009"\w* perish, \w we|strong="H3068"\w* \w all|strong="H5414"\w* perish!  
