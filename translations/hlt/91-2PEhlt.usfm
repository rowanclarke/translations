\v 7 \x - \xo 2.7 \xt Sue 19. 1-16.\x*Te \w vaengah|strong="G2532"\w* \w omthenbawnnah|strong="G0766"\w* \w omih|strong="G0391"\w* \w dongah|strong="G1722"\w* aka \w cungpoeh|strong="G0113"\w* halang rhoek \w lamloh|strong="G5259"\w* a \w vueinan|strong="G2669"\w* hlang \w dueng|strong="G1342"\w* \w Lot|strong="G3091"\w* te a \w hlawt|strong="G4506"\w*.  
\v 8 Hlang \w dueng|strong="G1342"\w* \w loh|strong="G3588"\w* \w amih|strong="G0846"\w* \w taengah|strong="G1722"\w* \w hmuhnah|strong="G0990"\w* \w hnavue|strong="G0189"\w* neh kho a \w sak|strong="G1460"\w*. Tedae hlang \w dueng|strong="G1342"\w* kah a \w hinglu|strong="G5590"\w* te \w lailak|strong="G0459"\w* rhoek kah \w khoboe|strong="G2041"\w* loh a \w hnin|strong="G2250"\w*, a \w hnin|strong="G2250"\w* a \w ngawn|strong="G0928"\w* pah.  
\v 9 Aka \w cuep|strong="G2152"\w* te \w noemcainah|strong="G3986"\w* \w lamkah|strong="G1537"\w* a \w hlawt|strong="G4506"\w* ham \w neh|strong="G1161"\w* \w halang|strong="G0094"\w* rhoek te a \w khoh|strong="G5083"\w* vetih \w laitloeknah|strong="G2920"\w* \w khohnin|strong="G2250"\w* ah a \w cawh|strong="G2849"\w* \w ham|strong="G1519"\w* khaw \w Boeipa|strong="G2963"\w* loh a \w ming|strong="G1492"\w*.  
