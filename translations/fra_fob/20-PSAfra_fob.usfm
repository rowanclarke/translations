\v 8 Éloignez-vous \w de|strong="H5869"\w* moi, \w vous|strong="H5869"\w* \w tous|strong="H3605"\w*, ouvriers d'\w iniquité|strong="H5869"\w*! Car l'Éternel \w a|strong="H3068"\w* entendu \w la|strong="H5869"\w* voix \w de|strong="H5869"\w* \w mes|strong="H5869"\w* pleurs.
\v 9 \w L|strong="H3068"\w*'\w Éternel|strong="H3068"\w* \w a|strong="H3068"\w* \w entendu|strong="H8085"\w* \w ma|strong="H8085"\w* supplication, l'\w Éternel|strong="H3068"\w* reçoit \w ma|strong="H8085"\w* \w prière|strong="H6963"\w*.
\v 10 \w Tous|strong="H3947"\w* \w mes|strong="H8085"\w* \w ennemis|strong="H3068"\w* \w seront|strong="H3068"\w* confus \w et|strong="H3068"\w* saisis d'effroi; \w ils|strong="H3068"\w* reculeront, \w ils|strong="H3068"\w* \w seront|strong="H3068"\w* soudain \w couverts|strong="H3068"\w* \w de|strong="H3068"\w* honte.
