\id LAM - Gofa Full Bible Latin Version Final
\h Ermiyaasa Milalsa
\toc1 Ermiyaasa Milalsa
\toc3 Mila
\toc2 Milalsa
\mt1 Ermiyaasa Milalsa
\imt1 Gaatha Qofa
\ip Ermiyaasa Milalsay, K.Y.S. 600 laytha heeran, Yerusalaame laaletethanne asaa di7etetha gaason, ginxon giigida ichashu azzano milalsata oykis. Ha maxaafa daro baggay yeehobaanne zelelsaba odikoka, Xoossan ammanetethabanne ufaysan duussaba odiya kifileti de7oosona.
\ip Ha ginxota Ayhude asay banta biitta bolla gakida dhayuwa hassayanaw laythan laythan xooman azzano goyinno wogata poliya gallasatan go7etoosona.
\iot Maxaafa Ayfe Qofata
\io1 Yerusalaame waayiya \ior (1:1-22)\ior*
\io1 Xoossa hanqonne Yerusalaame pirdetethi \ior (2:1-22)\ior*
\io1 Xoossa deriyas Ufaysi de7ees \ior (3:1-66)\ior*
\io1 Yerusalaamey zine, hachinne wonto \ior (4:1-22)\ior*
\io1 Maarota woossa \ior (5:1-22)\ior*
\c 1
\s1 Yerusalaame Waaye
\q1 
\v 1 Kase asi kumida katamiya
\q2 ha77i waanada asi bayna bessi gidadee?
\q1 Kase kawotethata giddon gita gididaara
\q2 ha77i waanada am7o gidadee?
\q1 Katamata giddon kawo gididaara
\q2 ha77i waanada aylle gidadee?
\q1 
\v 2 Qamma yibbata yeeho yeekashe aqawusu;
\q2 afuthi I ayfe karera duge wodhees.
\q1 Kase iyo doseysatape
\q2 ha77i iyo minthethiya issoyka baawa.
\q1 I laggeti iyo aathidi immidosona;
\q2 iw morke gididosona.
\q1 
\v 3 Yihudi naaqetada; aylletada di7etasu;
\q2 ha77i kawotethata giddon de7awusu;
\q2 shin shempo bessi demmabuku.
\q1 Iya metootada de7ishin,
\q2 yedetheysati iyo demmidosona.
\q1 
\v 4 Laytha ba7aale bonchanaw yaa asi bayna gisho,
\q2 Xiyoone ogeti yeekosona.
\q1 I dirsa pengeti baysatidosona;
\q2 I kahineti oolosona.
\q1 Yan de7iya geela7o nayti un7etidosona;
\q2 iyaka un7etada yeekawusu.
\q1 
\v 5 I morketi iw godaa gididosona;
\q2 entaw injetin de7idosona.
\q1 I, nagaraa gaason Goday iyo un7ethis;
\q2 I nayti morketan di7etidi bidosona.
\q1 
\v 6 Xiyooni bonchoy iipe qaaretis;
\q2 I, halaqatika miya bessi dhayida gaarada hanidosona;
\q1 Enti wolqa dhayidi
\q2 bantana yedetheyisata sinthafe baqatidosona.
\q1 
\v 7 Yerusalaamey ba metuwanne ba un7a gallasan,
\q2 beni ba boncho shaluwa hassayawusu.
\q1 I, asay morketa kushen aadhidi imetida wode,
\q2 iyo maaddiya issoyka bentibeenna.
\q1 I morketi iyo xeellidi,
\q2 I dhayuwan miicidosona.
\q1 
\v 8 Yerusalaamey gita nagara oothida gisho tunasu;
\q2 iyo bonchida ubbay I kalluwa be7ida gisho kadhees;
\q2 iya oolashe guye simmasu.
\q1 
\v 9 Tunatethi I afilaa bolla bentis;
\q2 sinthafe ba bolla yaanaba qopabuuku.
\q1 I kundethay daganthiyaba gidis;
\q2 iyo minthethiya oonika baawa.
\q1 Iya, “Abeeti Godaw, ta un7etetha be7a!
\q2 ta morketi tana xoonidosona” yaagasu.
\q1 
\v 10 Morketi I boncho shaluwa bonqidosona;
\q2 kase ne maabara giddo gelonna mela,
\q2 neeni diggida asati, I keethaa gelishin be7asu.
\q1 
\v 11 I asati koshatidi kathi demmanaw oolosona;
\q2 enti de7on daanaw banta shaluwa kathan laammoosona.
\q1 Yerusalaamey haysada yaagasu;
\q2 Abeeti Godaw, tana xeella;
\q2 ta kawushatethaa be7a!
\q1 
\v 12 Hinteno, haysara aadheysato,
\q2 haysi hintew aykoka daanennee?
\q1 Ane be7ite; akeekite;
\q2 ba eexiya hanqo gallasan,
\q1 Xoossay ta bolla ehida
\q2 metuwa mela metoy de7ii?
\q1 
\v 13 Bollafe tama duge yeddis;
\q2 he tamay ta meqethaa giddo gelis.
\q1 Ta tohoy xihen oyketis; tana guye zaaris;
\q2 tana gallas ubbaa labbanthidi yeggi aggis.
\q1 
\v 14 Ta oothida nagara ubbaa shiishi qachidi,
\q2 qambarada ta gannan wothis;
\q2 yaatidi ta wolqaa wursis.
\q1 Ta eqetanaw danda7onna asaas,
\q2 tana aathidi immis.
\q1 
\v 15 Goday ta giddon de7iya
\q2 wolqaama olanchota ubbaa diggis.
\q1 Ta yalagata dhaysanaw wode qachis;
\q2 woyne yedheysada,
\q2 Goday Yihuda geela7ota yedhis.
\q1 
\v 16 Taani yeekashe ta afuthaa gussey hessasa;
\q2 tana minthetheynne katisiya oonika baawa;
\q2 morkey goobin, ta nayti un7etidosona.
\p 
\v 17 Xiyooney ba kushiya miccasu;
\q2 shin iyo minthethiya oonika baawa.
\q1 I yuushuwan de7eysati
\q2 iyo morkanaada Goday oothis.
\q2 Yerusalaamey enta giddon tuna gidasu.
\q1 
\v 18 Iya haysada yaagasu; “Goday xillo;
\q2 iya kiitetonna ixiday tana.
\q1 Hinteno, asato ubbay si7ite; ta metuwaka be7ite;
\q2 ta panthatinne ta geela7oti di7etidosona.
\q1 
\v 19 Ta laggeta xeegas; shin enti tana cimmidosona;
\q2 kahinetinne cimati banta shempuwa ashshanaw,
\q2 kathi koyishe katama giddon hayqidosona.
\q1 
\v 20 Abeeti Godaw, ta waayiya be7a!
\q2 ta garsay dagammis.
\q1 Taani daro makallida gisho, ta wozanay meqis;
\q2 karen mashshi wursees; son hayqoy de7ees.
\q1 
\v 21 Asay ta zelelsa si7idosona;
\q2 shin tana minthethiya issi asika baawa.
\q1 Ta morketi ta metuwa si7idosona;
\q2 ne ta bolla oothidaban ufaytidosona.
\q1 Enti taada hanana mela,
\q2 enta bolla ne awaajida gallasaa eha!
\q1 
\v 22 Enta iitatetha ubbay ne sinthe gako;
\q2 ta nagaraa gisho tana seeridaysada entaka seera;
\q2 ta zelelsay daris; ta wozanayka meqis.”
\c 2
\s1 Qadhey Bayna Seera
\q1 
\v 1 Goday ba hanqo shaarape garsan,
\q2 Xiyoone na7iw, waatidi wothide!
\q1 Isra7eele bonchuwa salope sa7a holis;
\q2 ba hanquwa gallas,
\q2 iya tohoy yedhiya bessaa qopibeenna.
\q1 
\v 2 Goday Yihudan keethata ubbaa qadhetonna dhaysis;
\q2 ba hanquwan Yihuda biitta miixaa ubbaa laallis;
\q2 he kawotethaanne halaqata sa7an duge yeggidi kawushis.
\q1 
\v 3 Ba wolqaama hanquwan Isra7eele wolqaa mentherethis;
\q2 morkey iya olanaw yaa wode
\q2 Goday ba ushacha kushiya enta bollafe diggis.
\q1 Ba yuushuwan de7iyaba ubbaa miya tamada,
\q2 Yayqooba bolla tama lacoy eexis.
\q1 
\v 4 Morkeda I ba dongiya enta bolla dafis;
\q2 un7ethiya iya ushacha kushey giigis.
\q1 Ayfees lo77iya asa ubbaa wodhis;
\q2 Xiyoone bolla ba sheniya tamada qolis.
\q1 
\v 5 Goday morkeda hanidi, Isra7eele dhaysis;
\q2 kawo gadhotanne miixa ubbaa laallis
\q2 yihuda asaas yeehonne kayo gujis.
\q1 
\v 6 Ba keetha atakilte gaden de7iya shaqarada shoddidi holis;
\q2 laytha ba7aaletinne Sambaatati dogetanaada oothis;
\q2 ba gita hanquwan kawanne kahiniya kawushis.
\q1 
\v 7 Goday ba yarsho bessa kadhis; ba keethaa aggaagis;
\q2 kawo gadhota gimbiya morketa kushen yeggis.
\q1 Laytha ba7aale bonchiya gallasa wocamada,
\q2 morketi Xoossa keethan wocamidosona.
\q1 
\v 8 Goday Xiyooni na7e dirsa gimbiya,
\q2 laallanaw qachis; I bolla wadha wodoro yeggis.
\q1 Iyo dhaysona de7ishe ba kushiya zaarenna;
\q2 gimbeynne miixay issife kundanaada oothis.
\q1 
\v 9 Yerusalaame penge sanqati biittan moogetidosona;
\q2 enta gorde mithata mentherethidi dhaysis.
\q1 Kawoynne moorinnati di7etidi kawotethata giddo bidosona;
\q2 higge tamaarsey baawa;
\q2 nabetika hizape guye qoncethi be7okona.
\q1 
\v 10 Xiyoone cimati si77i gidi biittan uttidosona;
\q2 banta huuphen baana qolidi kayo ma7o ma7idosona;
\q2 Yerusalaame geela7oti sa7an duge hokidosona.
\q1 
\v 11 Ta asay dhayida gisho,
\q2 guutha nayti katamaa ogiya bolla
\q2 daaburidi kundida gisho,
\q2 ta ayfey afuthan tulcatis;
\q2 ta wozanay azzanon dagammis.
\q1 
\v 12 Enti banta aayetako,
\q2 “Kathi imma! haathe imma”
\m yaagidi waassoosona;
\q2 katamaa ogiyan madunxidi labbaniya asada,
\q2 enti daaburin enta shempoy enta aayeta ki7on keyees.
\p 
\v 13 Yerusalaame naatte, taani nebaa ay gaanee?
\q2 ne qohuwa ta aybira ginayo?
\q1 Dosetida Xiyoone geela7e, ta nena waatada minthetho?
\q2 Ne madunthay abba mela ciimmo;
\q2 nena ooni pathanaw danda7ii?
\q1 
\v 14 Ne nabeti wordonne pathonna qoncethi be7idosona;
\q2 ne di7etonna mela ne nagaraa qoncisidi odibookona;
\q2 enti balethiya wordo qoncethi new be7idosona.
\q1 
\v 15 Ne matara aadhiya ubbay ba kushiya baqees;
\q2 “Biittan ubbaafe aadhada lo77iya katamiya hanno?
\q1 Biitta ubbaas ufaysi geetetida katamiya hanno?”
\q2 yaagidi nena qelqisishe banta huuphiya qaathidosona.
\q1 
\v 16 Ne morketi ubbay banta doona
\q2 ne bolla dooyidosona;
\q2 ne bolla qelqisidosona.
\q1 Banta achaa qarcishe haysada yaagosona;
\q2 nu enta dhaysida, nu amotiday hessa
\q2 wursethan be7ida.
\q1 
\v 17 Goday ba qopidaba oothis;
\q2 kase odida ba qaala polis.
\q1 Yerusalaames qadhetonna iyo laallis
\q1 I morketi ufaytana mela,
\q2 morketa wolqaa minthis.
\q1 
\v 18 Xiyoone, ne dirsa gimbey Godaako waasso!
\q2 ne afuthay qammanne gallas shaafada goggo!
\q1 Newuka shempofa;
\q2 ne ayfiyas shempo immofa!
\q1 
\v 19 Qamma dendada waassa;
\q2 Godaa sinthan ne wozanaa haathada gussa.
\q1 Koshatidi oge doonan kundida ne nayta shempuwas
\q2 ne kushiya iyako pude denthada woossa!
\q1 
\v 20 Abeeti Godaw, be7a!
\q2 kase haysada neeni oodde bolla oothadii?
\q1 Aayeti banta ki7on ko77isidi
\q2 dichida banta nayta mo gay?
\q2 kahinetinne nabeti Xoossa keethan hayqo gay?
\q1 
\v 21 Ciminne na7atethi oge bolla kundidosona;
\q2 geela7otinne panthati mashshan wuridosona.
\q1 Neeni ne hanquwa gallas enta wodhadasa;
\q2 entaw qadhetonna enta buthadasa.
\q1 
\v 22 Gibira gallas ase xeegeysada,
\q2 daganthiya ta morketa ubba bessafe xeegadasa.
\q1 Godaa hanqo gallasan
\q2 oonika kessi ekibeenna woyko attibeenna.
\q1 Taani ta ki7on ko77isada dichida
\q2 nayta ubbaa morkey wodhidi dhaysis.
\c 3
\s1 Xoossay Ammanthees
\p 
\v 1 Godaa shene xam7an
\q2 meto be7ida asi tana.
\q1 
\v 2 Tana ba sinthafe kessidi,
\q2 poo7oy bayna dhuman wothis.
\q1 
\v 3 Gallas kumethi tana shocanaw
\q2 zaari zaari ba kushiya denthis.
\q1 
\v 4 I, ta galbaanne ta ashuwa cimisis;
\q2 ta meqethaa menthis.
\q1 
\v 5 I, ta yuushuwa metoninne
\q2 daaburan diris.
\q1 
\v 6 Beni hayqida asada
\q2 tana dhuman wothis.
\q1 
\v 7 Ta kessa ekonna mela,
\q2 ta yuushuwa diris;
\q2 deexo duthan tana duxis.
\q1 
\v 8 Taani maade koyada iya xeegin,
\q2 iyako waassin, tana si7onna ixis.
\q1 
\v 9 Ta ogiya wolqaama shuchan gordis;
\q2 ta ogiya geellayis.
\q1 
\v 10 I, taw zugidi naagiya babantha mela,
\q2 qosetidi naagiya gaammo mela gidis.
\q1 
\v 11 I, tana ta ogiyape kessidi duuserethis;
\q2 tana asi bayna bessan yeggi aggis.
\q1 
\v 12 Ba dongiya dafidi,
\q2 tana dukanaw mallis.
\q1 
\v 13 Ba dongiya dafidi,
\q2 ta wozana ayfen caddis.
\q1 
\v 14 Taani asa ubbaas miichas attas;
\q2 gallas kumethi bore yethas gidas.
\q1 
\v 15 I, tana meton camisis;
\q2 camo godare uuthi tana ushshidi kalsis.
\q1 
\v 16 I, ta achaa acen menthis;
\q2 tana baanan yedhis.
\q1 
\v 17 Saroy taape haakis;
\q2 taani inje duussu dogas.
\q1 
\v 18 Hessa gisho,
\q2 “Ta wolqay taape eketis;
\q2 taani Godan wothida ufaysa ubbay dhayis”
\m yaagas.
\q1 
\v 19 Ta metuwanne ta un7aa hassayin de7oy tana cammis.
\q1 
\v 20 Ta hessa kumethi dogike; ta shempoy azzanees.
\p 
\v 21 Gidoshin, ta issiba ta wozanan qopiya wode ta ufaysan kumayis.
\q1 
\v 22 Hessika, nuuni dhayboonay
\q2 Godaa siiquwape dendoysana;
\q2 iya qadhey wuri erenna.
\q1 
\v 23 Enti wonta wonta oorathi;
\q2 ne daro ammanthasa.
\q1 
\v 24 Goday ta saama;
\q2 hessa gisho, ta iyan ufaysi wothana.
\q1 
\v 25 Iyan banta ufaysa wotheysatasinne
\q2 iya koyeysatas Goday lo77o.
\q1 
\v 26 Asi si77i gidi Godaa atotethan naagiko lo77o.
\q1 
\v 27 As ba na7atethan meto danda7a tamaariko lo77o.
\q1 
\v 28 Goday meto ehiya wode si77i gidi utto.
\q1 
\v 29 Iyaw sinthafe ufaysi daanaw danda7iya gisho bana ziqi ootho.
\q1 
\v 30 I ba shakala baqeysas immo; cashshe kallo.
\q1 
\v 31 Goday ase merinaw yeggenna.
\q1 
\v 32 I asa bolla meto ehikoka,
\q2 ba merina siiquwa darotethan zaaridi qadhetees.
\q1 
\v 33 I asa bolla meto woyko un7a ehidi ufaytenna.
\q1 
\v 34 Bittan de7iya qasho asa banta tohuwpe garsan yedhiya wode,
\q1 
\v 35 Ubbaafe Wolqaama Xoossaa sinthan asa maati yedhetiya wode,
\q1 
\v 36 Xillo pirdi dhayiya wode Goday hessa ubbaa be7eneyee?
\q1 
\v 37 Goday kiittonashin odidi polisanaw danda7ey oonee?
\q1 
\v 38 Iitaba gidin lo77oba odi poley Ubbaafe Dhoqa Xoossa gidenneyee?
\q1 
\v 39 Yaatin, asi de7on de7ishe ba nagaraa gisho seeretiya wode ayis zuuzumii?
\q1 
\v 40 Ane nu ogiya paacoos; Godaako simmoos.
\q1 
\v 41 Nu wozanaa nu kushiyara salon de7iya Xoossaako denthidi haysada yaagos:
\q1 
\v 42 Nu nena naaqida; new makallida;
\q2 neka nuus atto gabaaka.
\q1 
\v 43 Ne hanquwan kametada nuna yedethada;
\q2 ne nuus qadhetonna nuna wodhadasa.
\q1 
\v 44 Nu woosay neeko gakonnaada, nenatethaa shaaran kammadasa.
\q1 
\v 45 Asaa giddon nuna pitonne buure oothadasa.
\q1 
\v 46 Nu morketi ubbay nu bolla banta doona dooyidosona.
\q1 
\v 47 Nu dagamaninne giten gelida; metoninne un7an laaletida.
\q1 
\v 48 Ta asaa gakida waayiya gaason ta ayfepe afuthu shaafada goggees.
\q1 
\v 49 Ta ayfey aggonna afuxees.
\q1 
\v 50 Goday salope duge be7ana gakanaw hessi hanees.
\q1 
\v 51 Ta kataman de7iya maccasata bolla gakidaba ta ayfey be7ida wode ta wozanay azzanis.
\q1 
\v 52 Coo tana morkeysati kafo shankatiyada tana shankatidosona.
\q1 
\v 53 Ta paxa de7ishin tana ollan yeggidi,
\q2 ollaa doona shuchan gordidosona.
\q1 
\v 54 Haathi kumidi ta huuphera goggiya wode ta dhayas gada qopas.
\q1 
\v 55 Abeeti Godaw, ta ciimmo ollan de7ashe ne sunthaa xeegas.
\q1 
\v 56 Ta waasuwa si7anaada ta nena woossiya wode tana si7adasa.
\q1 
\v 57 Taani nena xeegida wode taako shiiqada, “Babofa” yaagadasa.
\q1 
\v 58 Abeeti Godaw ne ta mootuwa mootetada tana wozadasa.
\q1 
\v 59 Abeeti Godaw, ne ta un7aa be7adasa;
\q2 hessa gisho, ne taw pirda.
\q1 
\v 60 Enti halo keyanaw ta bolla maqetiya maquwa ubbaa be7adasa.
\q1 
\v 61 Abeeti Godaw, enti tana cayiya cashshaanne
\q2 ta bolla maqetiya maquwa ubbaa si7adasa.
\q1 
\v 62 Ta morketi gallas kumethi
\q2 ta bolla zuuzumeysanne kalkasheysa si7adasa.
\q1 
\v 63 Enti uttishenne eqishe tana boridi yexoosona.
\q1 
\v 64 Abeeti Godaw, enti oothida oosuwas bessiya zaaruwa entaw qanxa!
\q1 
\v 65 Enta wozanaa eysa; ne baadethay enta gako.
\q1 
\v 66 Abeeti Godaw, ne enta ne hanquwan yedetha;
\q2 salope garsan enta dhaysa.
\c 4
\s1 Geeshsha Shuchati Laaletidosona
\p 
\v 1 Worqey phooleysa waanidi aggidee?
\q2 geeshsha worqay waanidi dammidee? Xoossa keethay gimbetida shuchay oge doonan laaletis.
\q1 
\v 2 Kase al7o worqa mela bonchetida Xiyoone nayti
\q2 ha77i biittafe medhetida oto gididosona.
\q1 
\v 3 Hari attoshin worakani ba mari dhanthawusu;
\q2 shin ta asay bazzon de7iya yanchoda, ba naytas iita gidis.
\q1 
\v 4 Saamo gaason yooga nayta inxarsay kottonora oyketis;
\q2 nayti kathi woossosona;
\q2 shin entaw immiya oonika baawa.
\q1 
\v 5 Kase mal7o katha xalaala meysati
\q2 ha77i oge doonan koshan wuridosona.
\q1 Kase liino ma7idi diccidaysati
\q2 ha77i bido bolla zin7idosona.
\q1 
\v 6 Ta asaa nagaray,
\q2 oodde kusheyka iyo bochonna,
\q2 qoponna shiretidi wodhida Soodome asa nagarape daro.
\q1 
\v 7 Yihuda halaqati shachafe aadhida geeshshi,
\q2 maathafe aadhida boothu.
\q1 Enta asatethay zo7o inqofe aadhida aarise;
\q2 enta medhoy sanpare al7o shucha mela.
\q1 
\v 8 Shin ha77i enta som7oy shaalape aadhidi kareexis;
\q2 asasi ogen enta be7idi erenna;
\q2 enta gogay meqethaara oyketidi mithada melis.
\q1 
\v 9 Miyaba dhayidi, koshan hayqidaysatape
\q2 olan hayqidaysati lo77o.
\q1 
\v 10 Ta asaa bolla yida dhayuwa gaason,
\q2 qadhetiya aayeti banta nayta doysidi midosona.
\q1 
\v 11 Godaa hanqo xuu7ay kumis; I ba suulliya sheniya tigis.
\q2 Yerusalaame baasuwa tama oythis.
\q1 
\v 12 Ha sa7a kawotape woyko kawotethatan de7iya asaape oonika
\q2 morkey Yerusalaame pengiyara gelana gidi ammanibena.
\q1 
\v 13 Shin haysi haniday iya nabetinne nagarasinne iya kahineti oothida naaquwasa,
\q2 xillota suuthaa iya giddon gussida gishosa.
\q1 
\v 14 Enti qooqe asada, oge tattafoosona;
\q2 enti suuthan tunida gisho
\q2 enta ma7uwa oonika bochanaw koyenna.
\q1 
\v 15 Hessa gisho, asay, “Kichite! hinte tuna gidiya gisho,
\q2 nuna bochofite!” yaagidi enta bolla waassidosona.
\q1 Enti baqatidi toylatiya wode,
\q2 kawotethatan de7iya asay,
\q2 “Hinte nuura haysan daanaw danda7eketa” yaagidosona.
\q1 
\v 16 Goday enta laallis; I entaba zaaridi qopenna;
\q2 enta kahineti bonchetokona;
\q2 enta cimati nashetookona.
\q1 
\v 17 Nu ayfey maado demmanaw xeellishe coo daaburis;
\q2 nuna ashshanaw danda7onna
\q2 kawotethatape maado naagida.
\q1 
\v 18 Asay nu gedaa kaalliya gisho,
\q2 nu katama ogera hemetanaw danda7ibooko.
\q1 Nu wursethay matis; nu laythay wuris;
\q2 nuus dhayo wodeyka gakis.
\q1 
\v 19 Nuna yedetheysati piradhiya arganthafe aadhidi eesotoosona;
\q2 enti nuna dere huuphera yedethidosona;
\q2 bazzon hokidi nuna naagidosona.
\q1 
\v 20 Goday tiyida kawoy, nu de7uwas shempoy,
\q2 enta xihiyan oyketis.
\q1 Nu iya kuya garsan uttidi,
\q2 kawotethata giddon daana gidi qopida.
\q1 
\v 21 Hinteno, Uxa biittan de7iya Edoome asaw,
\q2 ufaytite; hashshu giite.
\q1 Shin xuu7ay hinte bolla yaana;
\q2 hinte mathotidi kallo attana.
\q1 
\v 22 Hinteno, Xiyoone asaw, hinte seeray gidana;
\q2 I hizape hintena di7o biittan wothenna.
\q1 Shin Edoome asaw, hinte seeretana;
\q2 hinte nagarayka qoncana.
\c 5
\s1 Godaw, Nuna Neeko Zaara
\p 
\v 1 Abeeti Godaw, nuna gakidaba ubbaa qopa;
\q2 nu kawushatethaa be7a!
\q1 
\v 2 Nu laatay allagatas,
\q2 nu keethayka imatha asaas imetis.
\q1 
\v 3 Nuuni aawi hayqida na7a gidida;
\q2 nu aayetika am7o gididosona.
\q1 
\v 4 Nuuni ushsha haatha shammidi ekoos;
\q2 eethiya mithas gate qanxoos.
\q1 
\v 5 Nuna yedetheysati nu gindiya garsana;
\q2 nu daaburida shin shempanaw danda7ibooko.
\q1 
\v 6 Nuuni kathi kallana gidi,
\q2 Gibxetasinne Asooretas kushe immida.
\q1 
\v 7 Nagara oothiday nu mayzata,
\q2 shin enti ha77i dookona;
\q2 enti ekanaw bessiya seera ekiday nuna.
\q1 
\v 8 Nuna aylleti haaroosona;
\q2 enta kushepe nuna ashshiya oonika baawa.
\q1 
\v 9 Mashshan wodheysati bazzon de7iya gisho,
\q2 nu shempuwa bayzidi kathi demmida.
\q1 
\v 10 Iita kosha gaason,
\q2 nu gogay tama cooceda michees.
\q1 
\v 11 Maccasata Xiyoonen
\q2 geela7ota Yihuda katamatan
\q2 wolqan oykidi tunisidosona.
\q1 
\v 12 Halaqata efidi kaqidosona;
\q2 cimati bonchetibookona.
\q1 
\v 13 Yalaga addeti woxan gaaccidosona;
\q2 adde nayti deexo mithi tookidi gandigaridosona.
\q1 
\v 14 Cimati katama pengen pirdanaw utteysa aggidosona;
\q2 yalaga addeti nayti yethi dogidosona.
\q1 
\v 15 Nu wozanaape ufaysi kichis;
\q2 nu dursay yeehon laametis.
\q1 
\v 16 Nu huuphiyape kallachay kundis;
\q2 nu nagara oothida gisho nuna ayye!
\q1 
\v 17 Hessa gisho, nu wozanay daaburis;
\q2 nu ayfey teljumis.
\q1 
\v 18 Xiyoone Derey baysa gidida gisho,
\q2 workanati yan gupoosona.
\q1 
\v 19 Abeeti Godaw, ne merinaw haarasa;
\q2 ne araatay yeletaape yeletaa gakanaasa.
\q1 
\v 20 Neeni nuna ayis ubba wode dogay?
\q2 haysa mela adussa wode nuna ayis aggay?
\q1 
\v 21 Abeeti Godaw, nuna neeko zaara; nu simmana;
\q2 nu wodiya beniysatho zaarada ooratha.
\q1 
\v 22 Neeni nuna polo aggadiyee?
\q2 Ne hanquwas zawi baaweyee?
