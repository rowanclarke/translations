\v 49 \w Aaron|strong="H1121"\w* \w et|strong="H1121"\w* \w ses|strong="H5414"\w* \w fils|strong="H1121"\w* \w faisaient|strong="H5414"\w* fumer \w les|strong="H5414"\w* oblations \w sur|strong="H5414"\w* \w l|strong="H5892"\w*'autel \w des|strong="H1121"\w* \w holocaustes|strong="H5414"\w* \w et|strong="H1121"\w* \w sur|strong="H5414"\w* \w l|strong="H5892"\w*'autel \w des|strong="H1121"\w* parfums, vaquant \w à|strong="H5414"\w* \w toute|strong="H5414"\w* \w l|strong="H5892"\w*'œuvre \w du|strong="H1121"\w* \w lieu|strong="H1121"\w* très-saint, \w et|strong="H1121"\w* \w faisant|strong="H3478"\w* \w l|strong="H5892"\w*'expiation \w pour|strong="H5414"\w* \w Israël|strong="H3478"\w*, \w selon|strong="H1121"\w* \w tout|strong="H5414"\w* \w ce|strong="H5414"\w* qu'\w avait|strong="H1121"\w* \w commandé|strong="H1121"\w* Moïse, serviteur \w de|strong="H1121"\w* \w Dieu|strong="H1121"\w*.  
