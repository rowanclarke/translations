\id AMO
\h Knjiga proroka Amosa
\toc1 Knjiga proroka Amosa
\toc2 Amos
\toc3 Am
\mt1 Knjiga proroka Amosa
\c 1
\s1 O kazni suseda Izrailjevih.
\p 
\v 1 Reči Amosa koji beše između pastira iz Tekuje, što vide za Izrailja za vremena Ozije cara Judinog i za vremena Jerovoama sina Joasovog cara Izrailjevog, dve godine pre trusa.
\b
\p 
\v 2 Reče dakle:
\b
\q1 Gospod će riknuti sa Siona,
\q2 i iz Jerusalima će pustiti glas svoj,
\q1 i tužiće stanovi pastirski
\q2 i posušiće se vrh Karmilu.
\b
\p 
\v 3 Ovako veli Gospod:
\b
\q1 Za tri zla i za četiri što učini Damask,
\q2 neću mu oprostiti,
\q2 jer vrhoše Galad gvozdenom branom.
\q1 
\v 4 Nego ću pustiti oganj u dom Azailov,
\q2 te će proždreti dvorove Ven-Adadove.
\q1 
\v 5 I polomiću prevornice Damasku,
\q2 i istrebiću stanovnike iz polja Avena,
\q2 i onog koji drži palicu iz doma Edenovog,
\q1 i otići će u ropstvo narod sirski u Kir,
\q2 veli Gospod.
\b
\p 
\v 6 Ovako veli Gospod:
\b
\q1 Za tri zla i za četiri što učini Gaza,
\q2 neću joj oprostiti,
\q1 jer ih zarobiše sasvim
\q2 i predadoše Edomcima.
\q1 
\v 7 Nego ću pustiti oganj u zidove Gazi,
\q2 te će joj proždreti dvorove.
\q1 
\v 8 I istrebiću stanovnike iz Azota
\q2 i onog koji drži palicu iz Askalona,
\q2 i okrenuću ruku svoju na Akaron,
\q1 i izginuće ostatak filistejski,
\q2 veli Gospod Gospod.
\b
\p 
\v 9 Ovako veli Gospod:
\b
\q1 Za tri zla i za četiri što učini Tir,
\q2 neću mu oprostiti,
\q1 jer sasvim dadoše u ropstvo Edomcima
\q2 i ne sećaše se bratske vere.
\q1 
\v 10 Nego ću pustiti oganj u zidove Tiru,
\q2 te će proždreti dvorove njegove.
\b
\p 
\v 11 Ovako veli Gospod:
\b
\q1 Za tri zla i za četiri što učini Edom,
\q2 neću mu oprostiti,
\q1 jer goni brata svog mačem
\q2 potrvši u sebi sve žaljenje,
\q1 i gnev njegov razdire jednako,
\q2 i srdnju svoju drži uvek.
\q1 
\v 12 Nego ću pustiti oganj u Teman,
\q2 i proždreće dvore u Vosori.
\b
\p 
\v 13 Ovako veli Gospod:
\b
\q1 Za tri zla i za četiri što učiniše sinovi Amonovi,
\q2 neću im oprostiti,
\q1 jer paraše trudne žene u Galadu
\q2 da rašire među svoju.
\q1 
\v 14 Nego ću zapaliti oganj u zidovima Ravi,
\q2 te će joj proždreti dvorove
\q1 s vikom u dan boja
\q2 i s burom u dan vihora.
\q1 
\v 15 I car će njihov otići u ropstvo,
\q2 on i knezovi njegovi s njim,
\q2 veli Gospod.
\c 2
\s1 O kazni Moava, Jude i Izrailja.
\p 
\v 1 Ovako veli Gospod:
\b
\q1 Za tri zla i za četiri što učini Moav,
\q2 neću mu oprostiti,
\q2 jer sažeže kosti cara edomskog u kreč.
\q1 
\v 2 Nego ću pustiti oganj na Moava,
\q2 te će proždreti dvorove u Kariotu,
\q1 i Moav će poginuti
\q2 s vrevom, s vikom i s glasom trubnim.
\q1 
\v 3 I istrebiću sudiju iz njega
\q2 i sve knezove njegove pobiću s njim,
\q2 veli Gospod.
\b
\p 
\v 4 Ovako veli Gospod:
\b
\q1 Za tri zla i za četiri što učini Juda,
\q2 neću mu oprostiti,
\q1 jer prezreše zakon Gospodnji
\q2 i uredbe Njegove ne držaše,
\q1 i prevariše se lažima svojim,
\q2 za kojima hodiše oci njihovi.
\q1 
\v 5 Nego ću pustiti oganj u Judu,
\q2 te će proždreti dvore jerusalimske.
\b
\p 
\v 6 Ovako veli Gospod:
\b
\q1 Za tri zla i za četiri što učini Izrailj,
\q2 neću mu oprostiti,
\q1 jer prodavaše pravednika za novce
\q2 i ubogog za jedne opanke.
\q1 
\v 7 Čeznu za prahom zemaljskim na glavi siromasima,
\q2 i prevraćaju put smernima;
\q1 i sin i otac odlaze k jednoj devojci
\q2 da skvrne sveto ime moje.
\q1 
\v 8 I na haljinama u zalogu uzetim leže kod svakog oltara,
\q2 i vino oglobljenih piju u kući bogova svojih.
\b
\q1 
\v 9 A ja istrebih ispred njih Amoreje,
\q2 koji behu visoki kao kedri
\q2 i jaki kao hrastovi,
\q1 i potrh rod njihov ozgo
\q2 i žile njihove ozdo.
\q1 
\v 10 I ja vas izvedoh iz zemlje misirske,
\q2 i vodih vas po pustinji četrdeset godina
\q2 da biste nasledili zemlju amorejsku.
\q1 
\v 11 I podizah između sinova vaših proroke
\q2 i između mladića vaših nazireje.
\q1 Nije li tako? Sinovi Izrailjevi,
\q2 govori Gospod.
\b
\q1 
\v 12 A vi pojiste nazireje vinom,
\q2 i prorocima zabranjivaste govoreći: Ne prorokujte.
\b
\q1 
\v 13 Evo, ja ću vas pritisnuti na mestu vašem
\q2 kao što se pritiskaju kola puna snoplja.
\q1 
\v 14 I neće biti bega brzome,
\q2 i jaki neće utvrditi kreposti svoje,
\q2 i hrabri neće spasti dušu svoje.
\q1 
\v 15 I strelac neće se održati,
\q2 i laki na nogu neće se izbaviti,
\q2 niti će konjanik spasti duše svoje.
\q1 
\v 16 Nego će najhrabriji među junacima
\q2 go pobeći u onaj dan,
\q2 govori Gospod.
\c 3
\s1 Po prorokovoj reči dolazi kazna Izrailju od Gospoda.
\p 
\v 1 Čujte reč koju govori Gospod za vas, sinovi Izrailjevi, za sve pleme koje sam izveo iz zemlje misirske, govoreći:
\b
\q1 
\v 2 Samo vas poznah
\q2 između svih plemena zemaljskih,
\q1 zato ću vas pohoditi
\q2 za sva bezakonja vaša.
\b
\q1 
\v 3 Hoće li dvojica ići zajedno,
\q2 ako se ne sastanu?
\q1 
\v 4 Hoće li riknuti lav u šumi,
\q2 ako nema lova?
\q1 Hoće li lavić pustiti glas svoj iz pećine svoje,
\q2 ako ne uhvati šta?
\q1 
\v 5 Hoće li ptica pasti u mrežu na zemlju,
\q2 ako nema zamke?
\q1 Hoće li se dignuti mreža sa zemlje,
\q2 ako se ništa ne uhvati?
\q1 
\v 6 Hoće li truba trubiti po gradu,
\q2 a narod da ne dotrči uplašen?
\q1 Hoće li biti nesreća u gradu,
\q2 a Gospod da je ne učini?
\b
\q1 
\v 7 Jer Gospod Gospod ne čini ništa
\q2 ne otkrivši tajne svoje
\q2 slugama svojim prorocima.
\q1 
\v 8 Kad lav rikne,
\q2 ko se neće bojati?
\q1 Kad Gospod reče,
\q2 ko neće prorokovati?
\b
\q1 
\v 9 Oglasite po dvorovima azotskim
\q2 i po dvorovima u zemlji misirskoj,
\q2 i recite:
\q1 Skupite se na gore samarijske
\q2 i vidite velike nerede u njoj,
\q2 i nasilje u njoj.
\q1 
\v 10 Ne znaju činiti pravo,
\q2 govori Gospod,
\q1 sabiraju blago nasiljem i grabežom
\q2 u dvorima svojim.
\b
\p 
\v 11 Zato ovako veli Gospod Gospod:
\b
\q1 Neprijatelj je oko zemlje
\q2 i oboriće ti silu tvoju,
\q2 i opleniće se dvorovi tvoji.
\b
\p 
\v 12 Ovako veli Gospod:
\b
\q1 Kao kad pastir istrgne iz usta lavu dve noge ili kraj od uha,
\q2 tako će se istrgnuti sinovi Izrailjevi
\q2 koji sede u Samariji na uglu od odra i nakraj postelje.
\q1 
\v 13 Čujte i zasvedočite u domu Jakovljevom,
\q2 govori Gospod Gospod Bog nad vojskama.
\q1 
\v 14 Kad pohodim Izrailja za grehe njegove,
\q2 tada ću pohoditi i oltare vetiljske,
\q2 i odbiće se rogovi oltaru i pašće na zemlju.
\q1 
\v 15 I udariću kuću zimnu i letnju kuću,
\q2 i propašće kuće od slonove kosti,
\q1 i nestaće velikih kuća,
\q2 govori Gospod.
\c 4
\s1 Pretnja poglavarima u Izrailju.
\q1 
\v 1 Čujte ovu reč, krave vasanske,
\q2 koje ste u gori samarijskoj,
\q1 koje krivo činite ubogima
\q2 i satirete siromahe,
\q1 koje govorite gospodarima svojim:
\q2 Donesite da pijemo.
\q1 
\v 2 Zakle se Gospod Gospod svetošću svojom
\q2 da će vam evo doći dani,
\q1 te će vas izvlačiti kukama,
\q2 i ostatak vaš udicama ribarskim.
\q1 
\v 3 I kroz prolome ćete izaći,
\q2 svaka na prema se,
\q1 i pobacaćete šta bude u dvorovima,
\q2 govori Gospod.
\b
\q1 
\v 4 Idite u Vetilj, i činite bezakonje,
\q2 u Galgalu množite bezakonje svoje,
\q1 i prinosite svako jutro žrtve svoje,
\q2 treće godine desetke svoje;
\q1 
\v 5 I palite žrtvu zahvalnu od hleba kiselog,
\q2 i oglasite žrtve dragovoljne i razglasite,
\q1 jer vam je tako milo, sinovi Izrailjevi,
\q2 govori Gospod Gospod.
\b
\q1 
\v 6 I zato vam ja dadoh da su vam čisti zubi
\q2 po svim gradovima vašim
\q1 i da nema hleba nigde
\q2 po svim mestima vašim;
\q1 ali se ne obratiste k meni,
\q2 govori Gospod.
\b
\q1 
\v 7 A ja vam ustegoh dažd,
\q2 kad još tri meseca behu do žetve,
\q1 i pustih dažd na jedan grad,
\q2 a na drugi grad ne pustih dažda,
\q1 jedan se kraj nakvasi,
\q2 a drugi kraj, na koji ne dažde, posuši se.
\q1 
\v 8 Tako dva i tri grada iđahu u jedan grad da piju vode,
\q2 i ne mogahu se napiti;
\q1 ipak se ne obratiste k meni,
\q2 govori Gospod.
\b
\q1 
\v 9 Bih vas sušom i medljikom;
\q2 gusenice izjedoše obilje u vrtovima vašim i u vinogradima vašim
\q2 i na smokvama vašim i na maslinama vašim;
\q1 ipak se ne obratiste k meni,
\q2 govori Gospod.
\b
\q1 
\v 10 Poslah u vas pomor kao u Misir,
\q2 pobih mačem mladiće vaše
\q2 i odvedoh konje vaše,
\q1 i učinih te se podizaše smrad iz logora vašeg
\q2 i u nozdrve vaše;
\q1 ipak se ne obratiste k meni,
\q2 govori Gospod.
\b
\q1 
\v 11 Zatirah vas kao što Gospod zatre Sodom i Gomor,
\q2 i bejaste kao glavnja istrgnuta iz ognja;
\q1 ipak se ne obratiste k meni,
\q2 govori Gospod.
\b
\q1 
\v 12 Zato ću ti tako učiniti, Izrailju;
\q2 i što ću ti tako učiniti,
\q1 pripravi se, Izrailju,
\q2 da sretneš Boga svog.
\b
\q1 
\v 13 Jer eto Onog koji je sazidao gore
\q2 i koji je stvorio vetar
\q1 i javlja čoveku šta misli,
\q2 čini od zore tamu,
\q1 i hodi po visinama zemaljskim;
\q2 ime Mu je Gospod Bog nad vojskama.
\c 5
\s1 Naricanje i pozivanje na pokajanje. Ništa ne pomaže samo spoljašnje služenje Bogu.
\p 
\v 1 Čujte ovu reč, naricanje koje podižem za vama, dome Izrailjev.
\b
\q1 
\v 2 Pade, neće više ustati devojka Izrailjeva;
\q2 bačena je na zemlju svoju,
\q2 nema nikoga da je podigne.
\b
\p 
\v 3 Jer ovako veli Gospod Gospod:
\b
\q1 U gradu iz kog je izlazila hiljada ostaće stotina,
\q2 a iz kog je izlazila stotina u njemu će ostati deset domu Izrailjevom.
\b
\p 
\v 4 Jer ovako veli Gospod domu Izrailjevom:
\b
\q1 Tražite me, i bićete živi.
\q2 
\v 5 A ne tražite Vetilja,
\q1 i ne idite u Galgal,
\q2 i ne prolazite u Virsaveju,
\q1 jer će Galgal otići u ropstvo,
\q2 a Vetilj će se obratiti u ništa.
\b
\q1 
\v 6 Tražite Gospoda i bićete živi,
\q2 da ne obuzme dom Josifov kao oganj i spali
\q2 i ne bude nikoga da gasi Vetilj.
\q1 
\v 7 Koji obraćate sud u pelen,
\q2 i pravdu na zemlji obarate.
\b
\q1 
\v 8 Onog tražite koji je stvorio zvezde, kola i štape,
\q2 i koji pretvara sen smrtni u jutro,
\q2 a dan u tamnu noć,
\q1 koji doziva vode morske
\q2 i proliva ih po zemlji;
\q2 ime Mu je Gospod.
\q1 
\v 9 Koji podiže pogibao na jakoga,
\q2 te pogibao dođe na grad.
\b
\q1 
\v 10 Mrze na onog koji kara na vratima,
\q2 i gade se na onog koji govori pravo.
\q1 
\v 11 Zato što gazite siromaha
\q2 i uzimate od njega žito u danak,
\q1 sagradiste kuće od tesanog kamena,
\q2 ali nećete sedeti u njima;
\q1 nasadiste lepe vinograde,
\q2 ali nećete piti vino iz njih.
\q1 
\v 12 Jer znam bezakonja vaša, kojih je mnogo,
\q2 i grehe vaše, koji su veliki,
\q1 koji mučite pravednika,
\q2 primate poklone
\q2 i izvrćete pravdu ubogima na vratima.
\q1 
\v 13 Zato će pravedni ćutati u ovo vreme,
\q2 jer je zlo vreme.
\b
\q1 
\v 14 Tražite dobro a ne zlo,
\q2 da biste bili živi;
\q1 i tako će Gospod Bog nad vojskama biti s vama,
\q2 kako rekoste.
\q1 
\v 15 Mrzite na zlo i ljubite dobro,
\q2 i postavite na vratima sud,
\q2 ne bi li se Gospod Bog nad vojskama smilovao na ostatak Josifov.
\b
\p 
\v 16 Zato ovako veli Gospod Bog nad vojskama, Gospod:
\b
\q1 Biće tužnjava po svim ulicama,
\q2 i po svim putevima govoriće: Jaoh! Jaoh!
\q1 I zvaće ratare na žalost
\q2 i na tužnjavu one koji umeju naricati.
\q1 
\v 17 I po svim će vinogradima biti tužnjava,
\q2 jer ću proći posred tebe,
\q2 govori Gospod.
\b
\q1 
\v 18 Teško onima koji žele dan Gospodnji!
\q2 Šta će vam dan Gospodnji?
\q2 Tada je mrak a ne videlo.
\q1 
\v 19 Kao da bi ko bežao od lava
\q2 pa bi ga sreo medved;
\q1 ili kao da bi ko došao u kuću i naslonio se rukom na zid,
\q2 pa bi ga zmija ujela.
\q1 
\v 20 Nije li dan Gospodnji mrak, a ne videlo?
\q2 I tama, bez svetlosti?
\b
\q1 
\v 21 Mrzim na vaše praznike,
\q2 odbacio sam ih,
\q2 i neću da mirišem svetkovina vaših.
\q1 
\v 22 Ako mi prinesete žrtve paljenice i prinose svoje,
\q2 neću ih primiti,
\q2 i neću pogledati na zahvalne žrtve od ugojene stoke vaše.
\q1 
\v 23 Ukloni od mene buku pesama svojih,
\q2 i sviranja psaltira tvojih,
\q2 neću da čujem.
\q1 
\v 24 Nego sud neka teče kao voda
\q2 i pravda kao silan potok.
\b
\p 
\v 25 Jeste li meni prinosili žrtve i dare u pustinji četrdeset godina, dome Izrailjev?
\v 26 Nego ste nosili šator Moloha svog, i Hijuna, likove svoje, zvezdu boga svog, koje sami sebi načiniste.
\v 27 Zato ću vas preseliti iza Damaska, govori Gospod, kome je ime Bog nad vojskama.
\c 6
\s1 Pretnja raspuštenim i obesnim poglavarima u Judi i Izrailju.
\q1 
\v 1 Teško bezbrižnima u Sionu
\q2 i onima koji su bez straha u gori samarijskoj,
\q1 koji su na glasu između poglavica narodima,
\q2 ka kojima dolazi dom Izrailjev.
\q1 
\v 2 Prođite u Halnu i vidite,
\q2 i odande idite u veliki Emat,
\q2 posle siđite u Gat filistejski;
\q1 je li koje carstvo bolje od ovih?
\q2 Jesu li im međe prostranije od vaših međa?
\q1 
\v 3 Teško vama koji mislite da je daleko zli dan,
\q2 a primičete stolicu na kojoj je nasilje;
\b
\q1 
\v 4 Koji ležete na odrima od slonove kosti
\q2 i pružate se na posteljama svojim,
\q1 i jedete jaganjce iz stada
\q2 i teoce ugojene;
\q1 
\v 5 Koji pevate uza psaltire,
\q2 i izmišljate sprave muzičke kao David;
\q1 
\v 6 Koji pijete vino velikim čašama,
\q2 i mažete se skupocenim mirisima,
\q2 a ne marite za polom Josifov.
\q1 
\v 7 Zato će sada otići u ropstvo među prvima koji će otići u ropstvo,
\q2 i prestaće radost onih koji se goste.
\b
\p 
\v 8 Zakle se Gospod Gospod sobom, govori Gospod Bog nad vojskama:
\b
\q1 Ja se gadim na ponos Jakovljev
\q2 i mrzim na dvorove njegove;
\q1 zato ću predati grad
\q2 i sve što je u njemu.
\b
\p 
\v 9 I ako deset ljudi ostane u jednoj kući, umreće.
\v 10 I kad uzme koga stric mu ili koji će ga spaliti da iznese kosti njegove iz kuće, reći će onome koji bude u kutu u kući: Ima li jošte ko kod tebe? A on će reći: Nema nikoga. A on će reći: Ćuti; jer ne pominjaše ime Gospodnje.
\b
\q1 
\v 11 Jer evo, Gospod zapoveda
\q2 i udariće dom veliki da se razvali
\q2 i mali dom da popuca.
\q1 
\v 12 Trče li konji po steni
\q2 i ore li se volovima?
\q1 Jer vi pretvoriste sud u žuč,
\q2 i plod od pravde u pelen.
\q1 
\v 13 Vi se radujete onome što nije ništa,
\q2 i govorite:
\q2 Nismo li svojom snagom dobili rogove?
\q1 
\v 14 Jer, gle, ja ću podignuti na vas dome Izrailjev,
\q2 govori Gospod Bog nad vojskama,
\q2 narod, koji će vas pritesniti od ulaska u Emat do potoka u pustinji.
\c 7
\s1 Priviđanje kazni nad Izrailjem i Jerovoamovim domom. Amos Amasiju, koji ga optužuje, proriče propast.
\p 
\v 1 Ovo mi pokaza Gospod Gospod: Gle, sazdavaše skakavce, kad počinjaše nicati otava, i gle, beše otava po carevoj kosidbi.
\v 2 A kad pojedoše travu zemaljsku, tada rekoh:
\b
\q1 Gospode, Gospode, smiluj se;
\q2 kako će se podignuti Jakov?
\q2 Jer je mali.
\q1 
\v 3 Gospod se raskaja zato:
\q2 Neće biti, reče Gospod.
\b
\p 
\v 4 Tada mi pokaza Gospod Gospod, i gle, Gospod Gospod povika da će suditi ognjem; i oganj proždre veliku bezdanu i proždre deo zemlje.
\v 5 A ja rekoh:
\b
\q1 Gospode, Gospode, prestani;
\q2 kako će se podignuti Jakov?
\q2 Jer je mali.
\q1 
\v 6 Gospod se raskaja zato:
\q2 Ni to neće biti, reče Gospod Gospod.
\b
\p 
\v 7 Tada mi pokaza, i gle, Gospod stajaše na zidu sazidanom po merilima, i u ruci Mu behu merila.
\v 8 I reče mi Gospod: Šta vidiš, Amose? I rekoh: Merila. A Gospod mi reče:
\b
\q1 Evo, ja ću metnuti merila posred naroda svog Izrailja,
\q2 neću ga više prolaziti.
\q1 
\v 9 Jer će se razoriti visine Isakove,
\q2 i svetinje će Izrailjeve opusteti,
\q2 i ustaću na dom Jerovoamov s mačem.
\b
\p 
\v 10 Tada Amasija sveštenik vetiljski posla k Jerovoamu caru Izrailjevom i poruči mu: Amos diže bunu na te usred doma Izrailjevog, zemlja ne može podneti sve reči njegove.
\v 11 Jer ovako govori Amos:
\b
\q1 Jerovoam će poginuti od mača,
\q2 a Izrailj će se odvesti iz zemlje svoje u ropstvo.
\b
\p 
\v 12 Potom reče Amasija Amosu: Videoče, idi, beži u zemlju Judinu, i onde jedi hleb i onde prorokuj;
\v 13 a u Vetilju više ne prorokuj, jer je svetinja careva i dom je carski.
\p 
\v 14 A Amos odgovori i reče Amasiji: Ne bejah prorok ni proročki sin, nego beh govedar i brah dudove;
\v 15 a Gospod me uze od stada i reče mi Gospod: Idi, prorokuj narodu mom Izrailju.
\v 16 Sada dakle čuj reč Gospodnju.
\b
\q1 Ti kažeš: Ne prorokuj u Izrailju,
\q2 i ne kropi po domu Isakovom.
\b
\p 
\v 17 Zato ovako veli Gospod:
\b
\q1 Žena će ti se kurvati u gradu,
\q2 i sinovi će tvoji i kćeri tvoje pasti od mača,
\q1 i zemlja će se tvoja razdeliti užem,
\q2 i ti ćeš umreti u nečistoj zemlji,
\q2 a Izrailj će se odvesti iz svoje zemlje u ropstvo.
\c 8
\s1 U zelenaškom Izrailju zbog kazne će doći uzaludna žeđ reči Božije.
\p 
\v 1 Ovo mi pokaza Gospod: Gle, kotarica letnjeg voća.
\v 2 I reče: Šta vidiš, Amose? A ja rekoh: Kotaricu letnjeg voća. A Gospod mi reče:
\b
\q1 Dođe kraj narodu mom Izrailju,
\q2 neću ga više prolaziti.
\q1 
\v 3 I pesme će crkvene biti ridanje u onaj dan,
\q2 govori Gospod;
\q1 biće mnoštvo mrtvih telesa,
\q2 koja će se svuda pobacati ćuteći.
\b
\q1 
\v 4 Čujte ovo, koji proždirete uboge i satirete siromahe u zemlji,
\q1 
\v 5 Govoreći: Kad će proći mladina da prodajemo žito?
\q2 I subota da otvorimo pšenicu?
\q2 Umanjujući efu i povećavajući sikal i varajući lažnim merilima;
\q1 
\v 6 Da kupujemo siromahe za novce i ubogog za jedne opanke,
\q2 i da prodajemo očinke od pšenice.
\b
\q1 
\v 7 Zakle se Gospod slavom Jakovljevom:
\q2 Neću nikada zaboraviti nijedno delo njihovo.
\q1 
\v 8 Neće li se zemlja potresti od toga,
\q2 i protužiti svaki koji živi na njoj?
\q1 I neće li se sva razliti kao reka?
\q2 I neće li se odneti i potopiti kao od reke misirske?
\b
\q1 
\v 9 I u onaj dan, govori Gospod Gospod,
\q2 učiniću da sunce zađe u podne,
\q2 i pomračiću zemlju za belog dana.
\q1 
\v 10 I pretvoriću praznike vaše u žalost
\q2 i sve pesme vaše u plač,
\q2 i metnuću kostret oko svih bedara,
\q1 i učiniću da svaka glava oćelavi
\q2 i da bude žalost kao za jedincem,
\q2 i kraj će joj biti kao gorak dan.
\b
\q1 
\v 11 Gle, idu dani, govori Gospod Gospod,
\q2 kad ću pustiti glad na zemlju,
\q1 ne glad hleba ni žeđ vode,
\q2 nego slušanja reči Gospodnjih.
\q1 
\v 12 I potucaće se od mora do mora,
\q2 i od severa do istoka
\q1 trčaće tražeći reč Gospodnju,
\q2 i neće je naći.
\b
\q1 
\v 13 U to će vreme obamirati lepe devojke i mladići od žeđi,
\q1 
\v 14 Koji se kunu krivicom samarijskom i govore:
\q2 Tako da je živ Bog tvoj, Dane,
\q2 i tako da je živ put u Virsaveju.
\q1 I pašće, i neće više ustati.
\c 9
\s1 Strašan sud Izrailju. Obricanje srećne budućnosti.
\p 
\v 1 Videh Gospoda, a On stajaše na oltaru, i reče:
\b
\q1 Udari u gornji prag od vrata da se zatresu dovratnici,
\q2 i rascepi ih sve od vrha njihova;
\q1 a šta ostane iza njih pobiću mačem;
\q2 neće uteći između njih nijedan,
\q2 niti će se koji spasti.
\q1 
\v 2 Da se zakopaju u najdonji kraj zemlje,
\q2 odande će ih uzeti ruka moja;
\q1 i da izađu na nebo,
\q2 odande ću ih skinuti;
\q1 
\v 3 I da se sakriju na vrh Karmila,
\q2 naći ću ih i uzeću ih odande;
\q1 i da se sakriju ispred mojih očiju na dno morsko,
\q2 onde ću zapovedati zmiji da ih ujede;
\q1 
\v 4 Da odu u ropstvo pred neprijateljima svojim,
\q2 i onde ću zapovedati maču da ih pobije,
\q2 i obratiću oči svoje njima na zlo a ne na dobro.
\b
\q1 
\v 5 Jer Gospod Gospod nad vojskama kad se dotakne zemlje,
\q2 ona se rastapa
\q2 i tuže svi koji žive na njoj,
\q1 i razliva se sva kao reka
\q2 i potapa se kao od reke misirske.
\q1 
\v 6 On je sagradio sebi kleti na nebu
\q2 i svod svoj osnovao na zemlji;
\q1 zove vode morske
\q2 i izliva ih po zemlji;
\q1 ime Mu je Gospod.
\b
\q1 
\v 7 Niste li mi, sinovi Izrailjevi,
\q2 kao sinovi etiopski?
\q2 Govori Gospod;
\q1 ne izvedoh li Izrailja iz zemlje misirske,
\q2 a Filisteje iz Kaftora
\q2 i Sirce iz Kira?
\q1 
\v 8 Gle, oči su Gospodnje upravljene na ovo grešno carstvo
\q2 da ga zatresem sa zemlje;
\q1 ali neću sasvim zatrti dom Jakovljev,
\q2 govori Gospod.
\b
\q1 
\v 9 Jer, evo, ja ću zapovediti
\q2 i razmetaću među svim narodima dom Izrailjev
\q1 kao što se razmeće žito u rešetu
\q2 da ni zrno ne padne na zemlju.
\q1 
\v 10 Od mača će poginuti svi grešnici
\q2 između mog naroda, koji govore:
\q2 Neće doći, niti će nas zadesiti zlo.
\b
\q1 
\v 11 U to ću vreme podignuti opali šator Davidov,
\q2 i zatvoriću mu pukotine,
\q1 i opraviću mu šta je razvaljeno,
\q2 i opet ću ga sagraditi kao što je bio pre,
\q1 
\v 12 Da bi nasledili ostatak edomski
\q2 i sve narode na koje se priziva ime moje,
\q2 govori Gospod, koji čini ovo.
\b
\q1 
\v 13 Evo, idu dani,
\q2 govori Gospod,
\q1 kad će orač stizati žeteoca,
\q2 i koji gazi grožđe sejača,
\q1 i gore će kapati slatkim vinom,
\q2 a svi će se humovi rastapati.
\q1 
\v 14 I povratiću roblje naroda svog Izrailja,
\q2 i opet će sagraditi puste gradove i naseliće se,
\q1 i nasadiće vinograde i piti vino iz njih,
\q2 i načiniće vrtove i jesti rod iz njih.
\q1 
\v 15 I posadiću ih u zemlji njihovoj,
\q2 i neće se više iščupati iz zemlje svoje, koju im dadoh,
\q2 govori Gospod Bog tvoj. 
