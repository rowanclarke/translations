\c 1
\m 
\v 1 LA \w palabra|strong="H1697"\w* del \w SEÑOR|strong="H3068"\w* \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Oseas|strong="H1954"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Beeri, en \w días|strong="H3117"\w* \w de|strong="H1121"\w* Ozías, Jahatán, Acaz, y Ezequías, \w reyes|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, y en \w días|strong="H3117"\w* \w de|strong="H1121"\w* \w Jeroboam|strong="H3379"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joas|strong="H3101"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.
\m 
\v 2 \w El|strong="H3588"\w* principio \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w palabra|strong="H1696"\w* del \w SEÑOR|strong="H3068"\w* \w con|strong="H3588"\w* \w Oseas|strong="H1954"\w*. \w Y|strong="H3068"\w* \w dijo|strong="H1696"\w* \w el|strong="H3588"\w* \w SEÑOR|strong="H3068"\w* \w a|strong="H3068"\w* \w Oseas|strong="H1954"\w*: \w Ve|strong="H3212"\w*, \w tómate|strong="H3947"\w* una esposa \w fornicaria|strong="H2183"\w*, \w e|strong="H3068"\w* \w hijos|strong="H3206"\w* \w de|strong="H3588"\w* forni­caciones: \w porque|strong="H3588"\w* \w la|strong="H3588"\w* tierra se dará \w a|strong="H3068"\w* fornicar apartándose del \w SEÑOR|strong="H3068"\w*.
\m 
\v 3 \w Fue|strong="H3212"\w* pues, y \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w Gomer|strong="H1586"\w* \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Diblaim, la cual \w concibió|strong="H2029"\w* y le \w parió|strong="H3205"\w* un \w hijo|strong="H1121"\w*.
\m 
\v 4 \w Y|strong="H3068"\w* díjole \w el|strong="H5921"\w* \w SEÑOR|strong="H3068"\w*: \w Ponle|strong="H7121"\w* \w por|strong="H5921"\w* \w nombre|strong="H8034"\w* \w Jezreel|strong="H3157"\w*; \w porque|strong="H3588"\w* \w de|strong="H5921"\w* aquí \w a|strong="H3068"\w* \w poco|strong="H4592"\w* \w yo|strong="H3588"\w* \w visitaré|strong="H6485"\w* \w las|strong="H5921"\w* \w sangres|strong="H1818"\w* \w de|strong="H5921"\w* \w Jezreel|strong="H3157"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Jehú|strong="H3058"\w*, \w y|strong="H3588"\w* haré cesar \w el|strong="H5921"\w* reino \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.
\m 
\v 5 \w Y|strong="H3068"\w* acaecerá \w que|strong="H1931"\w* en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w quebraré|strong="H7665"\w* yo \w el|strong="H1931"\w* \w arco|strong="H7198"\w* de \w Israel|strong="H3478"\w* en \w el|strong="H1931"\w* \w valle|strong="H6010"\w* de \w Jezreel|strong="H3157"\w*.
\m 
\v 6 \w Y|strong="H3068"\w* \w concibió|strong="H2029"\w* \w aún|strong="H5750"\w*, \w y|strong="H3588"\w* \w parió|strong="H3205"\w* una \w hija|strong="H1323"\w*. \w Y|strong="H3068"\w* díjole \add Dios:\add* \w Ponle|strong="H7121"\w* \w por|strong="H3588"\w* \w nombre|strong="H8034"\w* \w Lo-ruhama|strong="H3808"\w*: \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w más|strong="H5750"\w* tendré \w misericordia|strong="H7355"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w los|strong="H3588"\w* \w quita|strong="H5375"\w*­ré del todo.
\m 
\v 7 \w Mas|strong="H3808"\w* de la \w casa|strong="H1004"\w* de \w Judá|strong="H3063"\w* tendré \w misericordia|strong="H7355"\w*, y salvarélos por el \w SEÑOR|strong="H3068"\w* su \w Dios|strong="H3068"\w*: y \w no|strong="H3808"\w* los \w salva|strong="H3467"\w*­ré por \w arco|strong="H7198"\w*, \w ni|strong="H3808"\w* por \w espada|strong="H2719"\w*, \w ni|strong="H3808"\w* por \w batalla|strong="H4421"\w*, \w ni|strong="H3808"\w* por \w caballos|strong="H5483"\w* \w ni|strong="H3808"\w* por \w caballeros|strong="H6571"\w*.
\m 
\v 8 \w Y|strong="H3068"\w* después \w de|strong="H1121"\w* haber destetado \w a|strong="H3068"\w* Lo-ruhama, \w concibió|strong="H2029"\w* y \w parió|strong="H3205"\w* un \w hijo|strong="H1121"\w*.
\m 
\v 9 \w Y|strong="H3068"\w* dijo \add Dios\add*: \w Ponle|strong="H7121"\w* \w por|strong="H3588"\w* \w nombre|strong="H8034"\w* \w Lo-ammi|strong="H3808"\w*: \w porque|strong="H3588"\w* vosotros \w no|strong="H3808"\w* \w sois|strong="H1961"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w*, \w ni|strong="H3808"\w* \w yo|strong="H3588"\w* \w seré|strong="H1961"\w* vuestro \add Dios\add*.
\m 
\v 10 Con todo será el número de los hijos de Israel como la arena del mar, que ni se puede medir ni contar. \w Y|strong="H3068"\w* será, que donde se les ha dicho: Vosotros no sois mi pueblo, les será dicho: Sois hijos del Dios viviente.
\m 
\v 11 \w Y|strong="H3068"\w* los hijos de Judá y de Israel serán congregados en uno, y levantarán para sí una cabeza, y subirán de la tierra: porque el día de Jezreel será grande.
\c 2
\m 
\v 1 DECID \w a|strong="H3068"\w* vuestros hermanos, \w Ammi|strong="H5971"\w*, y \w a|strong="H3068"\w* vuestras hermanas, Ruhama:
\m 
\v 2 Pleitead \w con|strong="H4480"\w* vuestra madre, pleitead; \w porque|strong="H3588"\w* \w ella|strong="H4480"\w* \w no|strong="H3588"\w* \w es|strong="H3588"\w* mi esposa, ni \w yo|strong="H4480"\w* \w su|strong="H3588"\w* marido; quite \w pues|strong="H3588"\w* sus fornicaciones \w de|strong="H4480"\w* \w su|strong="H3588"\w* ros­tro, \w y|strong="H3588"\w* sus adulterios \w de|strong="H4480"\w* \w entre|strong="H3588"\w* sus pechos;
\m 
\v 3 No sea \w que|strong="H5971"\w* yo la despoje des­nuda, y la haga tornar como el día en \w que|strong="H5971"\w* nació, y la ponga como un desierto, y la deje como tierra seca, y la mate \w de|strong="H5971"\w* sed.
\m 
\v 4 \w Ni|strong="H3808"\w* tendré misericordia \w de|strong="H3588"\w* \w sus|strong="H1931"\w* hijos: \w porque|strong="H3588"\w* \w son|strong="H3588"\w* hijos \w de|strong="H3588"\w* forni­caciones.
\m 
\v 5 \w Porque|strong="H6435"\w* su madre fornicó; la \w que|strong="H6435"\w* los \w engendró|strong="H3205"\w* fue avergonza­\w da|strong="H7760"\w*; \w porque|strong="H6435"\w* dijo: Iré tras mis amantes, \w que|strong="H6435"\w* me dan mi pan y mi agua, mi lana y mi lino, mi aceite y mi bebida.
\m 
\v 6 \w Por|strong="H3588"\w* tanto, he aquí \w yo|strong="H3588"\w* cerco tu camino \w con|strong="H3588"\w* espinas, \w y|strong="H3588"\w* \w la|strong="H3588"\w* cercaré \w con|strong="H3588"\w* seto, \w y|strong="H3588"\w* \w no|strong="H3808"\w* hallará \w sus|strong="H1992"\w* cami­nos.
\m 
\v 7 \w Y|strong="H3068"\w* seguirá sus amantes, \w y|strong="H3588"\w* \w no|strong="H3588"\w* \w los|strong="H3588"\w* alcanzará; buscarálos, \w y|strong="H3588"\w* \w no|strong="H3588"\w* \w los|strong="H3588"\w* hallará. \w Entonces|strong="H3588"\w* dirá: \w Iré|strong="H3212"\w*, \w y|strong="H3588"\w* vol­véreme \w a|strong="H3068"\w* mi primer marido; \w por|strong="H3588"\w*­\w que|strong="H3588"\w* mejor \w me|strong="H3588"\w* \w iba|strong="H3212"\w* \w entonces|strong="H3588"\w* \w que|strong="H3588"\w* ahora.
\m 
\v 8 \w Y|strong="H3068"\w* ella \w no|strong="H3808"\w* reconoció \w que|strong="H3808"\w* yo le daba el trigo, y el \w vino|strong="H1870"\w*, y el acei­te, y \w que|strong="H3808"\w* les multipliqué la plata y el oro con \w que|strong="H3808"\w* hicieron \w a|strong="H3068"\w* Baal.
\m 
\v 9 \w Por|strong="H3588"\w* tanto \w yo|strong="H3588"\w* \w tornaré|strong="H7725"\w*, \w y|strong="H3588"\w* tomaré \w mi|strong="H1245"\w* trigo \w a|strong="H3068"\w* \w su|strong="H3588"\w* tiempo, \w y|strong="H3588"\w* \w mi|strong="H1245"\w* \w vino|strong="H3212"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* sazón, \w y|strong="H3588"\w* quitaré \w mi|strong="H1245"\w* lana \w y|strong="H3588"\w* \w mi|strong="H1245"\w* lino \add que había dado\add* \w para|strong="H3588"\w* cubrir \w su|strong="H3588"\w* desnudez.
\m 
\v 10 \w Y|strong="H3068"\w* ahora descubriré \w yo|strong="H3588"\w* \w su|strong="H1931"\w* locu­ra \w delante|strong="H1931"\w* \w de|strong="H3588"\w* \w los|strong="H1931"\w* ojos \w de|strong="H3588"\w* \w sus|strong="H1931"\w* aman­tes, \w y|strong="H3588"\w* \w nadie|strong="H3808"\w* \w la|strong="H1931"\w* librará \w de|strong="H3588"\w* mi \w mano|strong="H1931"\w*.
\m 
\v 11 \w Y|strong="H3068"\w* haré cesar todo su gozo, sus fiestas, sus nuevas lunas y sus sábados, y todas sus festividades.
\m 
\v 12 \w Y|strong="H3068"\w* haré talar sus vides y sus higueras, \w de|strong="H5869"\w* \w que|strong="H3808"\w* \w ha|strong="H3808"\w* dicho: Mi salario me \w son|strong="H3808"\w*, \w que|strong="H3808"\w* me han dado mis amantes. \w Y|strong="H3068"\w* reducirélas \w a|strong="H3068"\w* un matorral, y las comerán las bes­tias del campo.
\m 
\v 13 \w Y|strong="H3068"\w* visitaré sobre \w ella|strong="H3605"\w* \w los|strong="H3605"\w* tiem­pos de \w los|strong="H3605"\w* Baales, \w a|strong="H3068"\w* \w los|strong="H3605"\w* cuales incensaba, y adornábase de sus zarcillos y de sus joyeles, \w e|strong="H3068"\w* íbase tras sus amantes olvidada de mí, dice \w el|strong="H3605"\w* SEÑOR.
\m 
\v 14 \w Por|strong="H5414"\w* tanto, he aquí, yo la induci­ré, y la llevaré al desierto, y hablaré \w a|strong="H3068"\w* \w su|strong="H1992"\w* corazón.
\m 
\v 15 \w Y|strong="H3068"\w* daréle \w sus|strong="H1992"\w* viñas \w desde|strong="H5921"\w* allí, \w y|strong="H5921"\w* \w el|strong="H5921"\w* valle \w de|strong="H5921"\w* Acor \w por|strong="H5921"\w* puerta \w de|strong="H5921"\w* esperanza; \w y|strong="H5921"\w* allí cantará \w como|strong="H5921"\w* \w en|strong="H5921"\w* \w los|strong="H1992"\w* \w tiempos|strong="H3117"\w* \w de|strong="H5921"\w* \w su|strong="H1992"\w* juventud, \w y|strong="H5921"\w* \w como|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w su|strong="H1992"\w* subida \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Egipto.
\m 
\v 16 \w Y|strong="H3068"\w* será \w que|strong="H5921"\w* \w en|strong="H5921"\w* aquel tiempo, \w dice|strong="H1696"\w* \w el|strong="H5921"\w* SEÑOR, \w me|strong="H5921"\w* llamarás Marido \w mío|strong="H5921"\w*, \w y|strong="H5921"\w* nunca \w más|strong="H5921"\w* \w me|strong="H5921"\w* lla­marás Baali.
\m 
\v 17 \w Porque|strong="H8033"\w* quitaré \w de|strong="H5414"\w* su boca los nombres \w de|strong="H5414"\w* los Baales, y nunca \w más|strong="H6030"\w* serán mentados \w por|strong="H5414"\w* sus nombres.
\m 
\v 18 \w Y|strong="H3068"\w* haré \w por|strong="H5750"\w* \w ellos|strong="H1931"\w* concierto \w en|strong="H5750"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H3117"\w* con las bestias del campo, y con las aves del cielo, y con las serpientes \w de|strong="H5750"\w* \w la|strong="H1931"\w* tierra: y quebraré arco, y espada, y batalla \w de|strong="H5750"\w* \w la|strong="H1931"\w* tierra, y harélos dormir seguros.
\m 
\v 19 \w Y|strong="H3068"\w* te desposaré conmigo \w para|strong="H5493"\w* siempre; desposarte he conmigo \w en|strong="H5493"\w* justicia, y juicio, y misericor­dia, y miseraciones.
\m 
\v 20 \w Y|strong="H3068"\w* \w te|strong="H4480"\w* desposaré \w conmigo|strong="H5973"\w* \w en|strong="H4480"\w* fe, y conocerás \w al|strong="H4480"\w* SEÑOR.
\m 
\v 21 \w Y|strong="H3068"\w* será que en aquel tiempo responderé, dice el SEÑOR, yo responderé \w a|strong="H3068"\w* los cielos, y ellos responderán \w a|strong="H3068"\w* la tierra;
\m 
\v 22 \w Y|strong="H3068"\w* la tierra responderá al trigo, y al vino, y al aceite, y ellos res­ponderán \w a|strong="H3068"\w* Jezreel.
\m 
\v 23 \w Y|strong="H3068"\w* \w la|strong="H1931"\w* sembraré \w para|strong="H1961"\w* \w mí|strong="H1961"\w* en \w la|strong="H1931"\w* tierra; y \w tendré|strong="H1961"\w* misericordia de \w la|strong="H1931"\w* \w que|strong="H1931"\w* \w no|strong="H1961"\w* obtuvo misericordia; y diré al \add que\add* \w no|strong="H1961"\w* \add era\add* \w mi|strong="H1961"\w* \w pueblo|strong="H1992"\w*: Tú \add eres\add* \w mi|strong="H1961"\w* \w pueblo|strong="H1992"\w*, y \w él|strong="H1931"\w* dirá: \add Tú eres\add* \w mi|strong="H1961"\w* \w Dios|strong="H3068"\w*.
\c 3
\m 
\v 1 \w Y|strong="H3068"\w* DÍJOME \w otra|strong="H5750"\w* vez \w el|strong="H1121"\w* \w SEÑOR|strong="H3068"\w*: \w Ve|strong="H3212"\w*, ama una mujer amada \w de|strong="H5750"\w* \add su\add* \w compañero|strong="H7453"\w*, aunque \w adúltera|strong="H5003"\w*, \w como|strong="H5750"\w* \w el|strong="H1121"\w* amor del \w SEÑOR|strong="H3068"\w* para con \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5750"\w* \w Israel|strong="H3478"\w*; \w los|strong="H1992"\w* cuales \w miran|strong="H6437"\w* \w a|strong="H3068"\w* dioses ajenos, y aman frascos \w de|strong="H5750"\w* \w vino|strong="H3212"\w*.
\m 
\v 2 \w Compréla|strong="H3739"\w* entonces para mí por \w quince|strong="H2568"\w* \add dineros\add* \w de|strong="H2568"\w* \w plata|strong="H3701"\w*, y un homer y medio \w de|strong="H2568"\w* \w cebada|strong="H8184"\w*;
\m 
\v 3 \w Y|strong="H3068"\w* díjele: Tú \w estarás|strong="H1961"\w* por mía \w muchos|strong="H7227"\w* \w días|strong="H3117"\w*: \w no|strong="H3808"\w* \w fornicarás|strong="H2181"\w*, \w ni|strong="H3808"\w* \w tomarás|strong="H1961"\w* \add otro\add* varón; \w así|strong="H1571"\w* yo \w también|strong="H1571"\w* estaré por ti.
\m 
\v 4 \w Porque|strong="H3588"\w* \w muchos|strong="H7227"\w* \w días|strong="H3117"\w* \w estarán|strong="H3427"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* sin \w rey|strong="H4428"\w*, \w y|strong="H3588"\w* sin \w príncipe|strong="H8269"\w*, \w y|strong="H3588"\w* sin \w sacrificio|strong="H2077"\w*, \w y|strong="H3588"\w* sin \w esta|strong="H3427"\w*­tua, \w y|strong="H3588"\w* sin efod, \w y|strong="H3588"\w* sin terafim.
\m 
\v 5 Después \w volverán|strong="H7725"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, y \w buscarán|strong="H1245"\w* \w al|strong="H4428"\w* \w SEÑOR|strong="H3068"\w* su \w Dios|strong="H3068"\w*, y \w a|strong="H3068"\w* \w David|strong="H1732"\w* su \w rey|strong="H4428"\w*; y temerán \w al|strong="H4428"\w* \w SEÑOR|strong="H3068"\w* y \w a|strong="H3068"\w* su \w bondad|strong="H2898"\w* en \w el|strong="H1121"\w* fin \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w*.
\c 4
\m 
\v 1 \w OÍD|strong="H8085"\w* \w palabra|strong="H1697"\w* \w del|strong="H5973"\w* \w SEÑOR|strong="H3068"\w*, \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w porque|strong="H3588"\w* \w el|strong="H5973"\w* \w SEÑOR|strong="H3068"\w* pleitea \w con|strong="H5973"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra; \w porque|strong="H3588"\w* \w no|strong="H3588"\w* hay verdad, \w ni|strong="H5973"\w* \w misericordia|strong="H2617"\w*, \w ni|strong="H5973"\w* \w conocimiento|strong="H1847"\w* \w de|strong="H3588"\w* \w Dios|strong="H3068"\w* \w en|strong="H5973"\w* \w la|strong="H3588"\w* tierra.
\m 
\v 2 Perjurar, y mentir, y matar, y hurtar y adulterar \w prevalecieron|strong="H6555"\w*, y \w sangres|strong="H1818"\w* se tocaron \w con|strong="H5060"\w* \w sangres|strong="H1818"\w*.
\m 
\v 3 \w Por|strong="H5921"\w* \w lo|strong="H5921"\w* cual, \w se|strong="H5921"\w* enlutará \w la|strong="H5921"\w* tierra, \w y|strong="H1571"\w* extenuaráse \w todo|strong="H3605"\w* \w morador|strong="H3427"\w* \w de|strong="H5921"\w* \w ella|strong="H5921"\w*, \w con|strong="H5921"\w* \w las|strong="H5921"\w* \w bestias|strong="H2416"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w*, \w y|strong="H1571"\w* \w las|strong="H5921"\w* \w aves|strong="H5775"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*: \w y|strong="H1571"\w* \w aun|strong="H1571"\w* \w los|strong="H3427"\w* peces \w del|strong="H5921"\w* \w mar|strong="H3220"\w* fallecerán.
\m 
\v 4 Ciertamente hombre no con­tienda ni \w reprenda|strong="H3198"\w* \w a|strong="H3068"\w* hombre, por­\w que|strong="H5971"\w* tu \w pueblo|strong="H5971"\w* es como los \w que|strong="H5971"\w* resisten al \w sacerdote|strong="H3548"\w*.
\m 
\v 5 \w Caerás|strong="H3782"\w* por tanto \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w día|strong="H3117"\w*, \w y|strong="H1571"\w* \w caerá|strong="H3782"\w* \w también|strong="H1571"\w* \w contigo|strong="H5973"\w* \w el|strong="H5973"\w* \w profeta|strong="H5030"\w* \w de|strong="H5973"\w* \w noche|strong="H3915"\w*; \w y|strong="H1571"\w* \w a|strong="H3068"\w* tu madre \w talaré|strong="H1820"\w*.
