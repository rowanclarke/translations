\id PHM - Yagua NT -Peru 2008 (web -2013)
\h Videmó̱
\toc1 Videmo̱ju̱sara Catera
\toc2 Videmó̱
\toc3 Vid
\mt1 Videmo̱ju̱sara Catera
\c 1
\s1 Pávurubay mu̱chuveda
\p 
\v 1 Ray Pávuru jiryatiy ravyichasara tanuvu̱nusi̱ Jesucrístu jiyadaju̱, Timutévuta na̱ñu̱rya catera yimuju̱ Videmó̱, jiryatiy rajemyicyu risa̱ jvaañu daryaju̱ day ji.
\v 2 Na̱ñu̱y rijyu̱ntiy vuryi̱tyamutu̱y Crístumu Ápiyaju̱y, na̱dyisa̱ jvaañu Arquípu jarye, ti̱ta̱ju̱ jiryatiy rintye̱ryaniy Ju̱denu siityari̱vay jiryorimyuyu.
\v 3 Samiy vichasa̱da jiryejyu̱ Vu̱jye̱ Ju̱denumusiryá, Vu̱yntyityu̱ Jesucrístumusirya jarye. Jirye̱cha samivye jijechimyu.
\s1 Videmó̱bay va̱ta̱da jityuva̱chodamusiy
\p 
\v 4-5 Ri̱chana̱tyajaya̱sarateni̱ Rajye̱ Ri̱ndenu japichiy, ratyu̱chunumatiy sisa̱, rajechipityajaya̱ variy ji, jiryatiy ratyuva̱chu jinchiy: Jivya̱tasara jaryiñi̱ Vu̱yntyityu̱ Jesús, sasiityari̱vajyuu jarye yisa̱ju̱, ne piturya yivaayadamu dajyi, jiryatiy yivaayada Vu̱yntyityu̱ju̱, sasiityari̱vajyuu cabyimu jarye.
\v 6 Rajechiñu̱y siva Ju̱denura, jiryatiy vu̱tyuva̱chu vatajuu simu, vurya̱datya jaryivya̱ju̱ra ti̱ta̱ju̱ jiryatiy vuryi̱mutya̱ra samirya jmu̱tya̱da Crístumu.
\v 7 Ri̱chana̱y ji̱ta, ravyanu̱tyanityentirye, Pi̱, jivya̱ta̱damusiy, jiryatiy yichana̱chodara rijechiy Ju̱denu siityari̱vajyuu.
\s1 Pávurubay jachiñu̱yada siva Videmó̱bay, Onésimyubay jiyadaju̱
\p 
\v 8 Ramuni̱day ne rachuvu̱ryu̱y riva yipa̱sa̱da, ya̱tidye jvaarya daryatiy rasu̱tye yivaayada day.
\v 9 Dañuma jiryatiy ravya̱ta jaryi ji, mitya rajechiñu̱y yiva nu̱tyu Pávuru, Jesucrístuju̱ tu̱chu̱, jiryatiy tanuvu̱nusi̱ sayadaju̱ diye ray.
\v 10 Rajechiñu̱y yiva Onésimyu jiyadaju̱, ni̱tiy radyenu Crístumu, jiryatiy satuva̱chu Crístumu ratyanuvu̱nusajomuntiy.
\v 11 Tarundamu ne savichanu̱yada muchechiy siityera jiijyu̱, diye ji̱ta sa̱cha siityera jiijyu̱ntiy, nu̱tyu savichatiy darya rajyu̱ntidye.
\v 12 Ri̱pa̱ diye yimuju̱ntiñi̱, daryanuma ti̱ta̱ju̱ntidyeñi̱ nu̱tyu ray daryantidye.
\v 13 Rañi jachipiya̱nu̱chiy sa̱ma̱cho̱ jiyu risa̱ju̱, sa̱tidye jmu̱tya yibivaju̱ ray, jiryatiy ravyicha tanuvu̱nusi̱ jiyu samitu̱chodiva.
\v 14 Dañumamu̱y ne rañi jvaatyaniryu̱y jiirya jiryatimyu̱ ne jiñi jvaaryu̱dyerya. Ravya̱ta ji̱ta ya̱jvaay jidyirya ni̱ru̱yadamusirya jiryatiy samirya jvaayada darya.
\v 15-16 Temusiy savicha Onésimyu taji yajisiy taraquiju̱, sa̱tidye ta̱rya ta̱rijyu̱ vicha̱daju̱ yisa̱ju̱ntiy, ne nu̱tyu vinu muchechiñu̱day, diye ji̱ta savicha vu̱tyeryi̱ jaryi va̱tasi̱ Crístumu. Jaryi rañi̱ru̱chi̱numa day, jaryi rayadaju̱ ni̱ru̱chi̱va̱ju̱ sa̱cha jiijyu̱, nu̱tyu muchechiy, daryanuma nu̱tyu jityeryi̱ savicha Crístumuntidye.
\p 
\v 17 Ramusiy, jiryityi diy nu̱tyu yisa̱ siityari̱nu riva, ya̱dirye samirya vicha̱data yimuju̱ntiñi̱, nu̱tyu ray ntanuma jidyirye variñi̱.
\v 18 Sa̱rupadodatiy taramu ji, varimyata sadivyiyada tara ji, ya̱bay racuentamura.
\v 19 Ray Pávuru rañú̱y si̱tenu rajyomututara jirya niquejada ra̱tidye murichenu ji. Ne jivya̱ta ra̱jachipityataniy ji jiryatiy jidyivyichara yinu̱jeya̱jadata Crístumu ray.
\v 20 Ramuni̱day, Pi̱, ya̱jvaay Vu̱yntyityu̱mu rajyu̱ra jiryatiy ra̱jchana̱chara rajechiy Crístumu.
\p 
\v 21 Radyetya ji̱ta ya̱tuva̱chu rimu, jiryatiy ya̱jvaarya ravya̱tara jiyadaju̱.
\v 22 Jadchintyi ya̱jdutyara rorichiy ra̱jiju̱, rayntuy ra̱jiju̱ daryaju̱ sa̱ndyetya ta̱ryataniy Ju̱denu jiryimuju̱ntirye, jiryejechiñu̱yadiva.
\s1 Samu̱chuveda Pávurubay samiryatani̱ Videmó̱bay
\p 
\v 23 Samu̱chuvay Epájurasiy ji, jiryatiy risa̱ tanuvu̱nusi̱ Jesucrístu jiyadaju̱ni̱.
\v 24 Daryaday rimyu̱chuvay Márcuvedantiy ji, Aristyárucu sisa̱, Démasiy jarye, Dúcasiy jaryentiy. Rivyichasara risa̱ jvaavyemyi ti̱ta̱ju̱.
\v 25 Sa̱vichaniy Vu̱yntyityu̱ Jesucrístu samiryani̱ jiryi̱ntu.
\cls Sayanuma Pávuru
