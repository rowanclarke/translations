\v 13 \wj Tensaré \+w a|strong="H3068"\+w* \+w Judá|strong="H3063"\+w* \+w como|strong="H3588"\+w* \+w mi|strong="H5921"\+w* \+w arco|strong="H7198"\+w* \+w y|strong="H3588"\+w* cargaré \+w mi|strong="H5921"\+w* \+w arco|strong="H7198"\+w* \+w con|strong="H5921"\+w* Efraín. \+w Haré|strong="H7760"\+w* \+w de|strong="H5921"\+w* \+w ti|strong="H5921"\+w*, \+w oh|strong="H1121"\+w* \+w Sion|strong="H6726"\+w*, una \+w espada|strong="H2719"\+w* \+w de|strong="H5921"\+w* \+w valiente|strong="H1368"\+w*. Incitaré \+w a|strong="H3068"\+w* tus \+w hijos|strong="H1121"\+w*, \+w oh|strong="H1121"\+w* \+w Sion|strong="H6726"\+w*, \+w contra|strong="H5921"\+w* tus \+w hijos|strong="H1121"\+w*, \+w oh|strong="H1121"\+w* \+w Grecia|strong="H3120"\+w*. Convertiré \+w a|strong="H3068"\+w* \+w Sion|strong="H6726"\+w* \+w como|strong="H3588"\+w* una \+w espada|strong="H2719"\+w* \+w de|strong="H5921"\+w* guerrero.\wj*   
