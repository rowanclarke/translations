\q2 O \w King|strong="G3588"\w* \w of|strong="G2316"\w* \w the|strong="G2532"\w* \w nations|strong="G1484"\w*!\f + \fr 15:3 \ft KJV and NKJV read ‘saints’ instead of “nations”, following the TR which is here based on only two very late manuscripts.\f*   
\q1
\v 4 \w Who|strong="G5101"\w* \w could|strong="G3361"\w* \w not|strong="G3756"\w* \w fear|strong="G5399"\w* \w You|strong="G4771"\w*, O \w Lord|strong="G2962"\w*,  
