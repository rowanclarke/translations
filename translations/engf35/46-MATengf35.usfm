\v 21 \w Then|strong="G2532"\w* \w a|strong="G2532"\w* \w different|strong="G2087"\w* \w one|strong="G3588"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w disciples|strong="G3101"\w* \w said|strong="G3004"\w* \w to|strong="G2532"\w* \w Him|strong="G3588"\w*, “\w Lord|strong="G2962"\w*, \w permit|strong="G2010"\w* \w me|strong="G1473"\w* \w first|strong="G4413"\w* \w to|strong="G2532"\w* \w go|strong="G2010"\w* \w and|strong="G2532"\w* \w bury|strong="G2290"\w* \w my|strong="G1473"\w* \w father|strong="G3962"\w*.”  
