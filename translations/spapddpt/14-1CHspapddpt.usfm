\v 34 Éstos eran \w jefes|strong="H7218"\w* de casas paternas de \w los|strong="H3427"\w* \w levitas|strong="H3881"\w* según sus familias, \w jefes|strong="H7218"\w* que \w vivían|strong="H3427"\w* en Jerusalén.   
\p
\v 35 En \w Gabaón|strong="H1391"\w* \w vivía|strong="H3427"\w* \w Jehiel|strong="H3273"\w*, padre de \w Gabaón|strong="H1391"\w*. \w El|strong="H3427"\w* \w nombre|strong="H8034"\w* de la esposa de \w él|strong="H3427"\w* era Maaca,  
\v 36 y \w Abdón|strong="H5658"\w*, su \w hijo|strong="H1121"\w* \w primogénito|strong="H1060"\w*, luego Zur, \w Cis|strong="H7027"\w*, \w Baal|strong="H1168"\w*, \w Ner|strong="H5369"\w*, \w Nadab|strong="H5070"\w*,  
\v 37 \w Gedor|strong="H1446"\w*, Ahío, \w Zacarías|strong="H2148"\w* y Miclot.  
\v 38 Miclot \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Simeam. \w Éstos|strong="H1992"\w* \w vivían|strong="H3427"\w* también \w en|strong="H5973"\w* Jerusalén \w enfrente|strong="H5048"\w* \w de|strong="H5048"\w* \w sus|strong="H1992"\w* hermanos.  
\v 39 \w Ner|strong="H5369"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Cis|strong="H7027"\w*, \w Cis|strong="H7027"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*, y \w Saúl|strong="H7586"\w* \w a|strong="H3068"\w* Jonatán, Malquisúa, Abinadab y Es-baal.  
\v 40 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jonatán fue Merib-baal, y Merib-baal \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Micaía.  
\v 41 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Micaía fueron Pitón, Melec, Tarea y Acaz.  
\v 42 Acaz \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Jara, y Jara \w a|strong="H3068"\w* Alemet, Azmavet y \w Zimri|strong="H2174"\w*, y \w Zimri|strong="H2174"\w* \w a|strong="H3068"\w* Mosa,  
\v 43 Mosa \w a|strong="H3068"\w* Bina, cuyo \w hijo|strong="H1121"\w* fue Refaías, del cual fue \w hijo|strong="H1121"\w* Elasa, del cual Azel fue \w hijo|strong="H1121"\w*.  
\v 44 Azel tuvo \w seis|strong="H8337"\w* \w hijos|strong="H1121"\w*, cuyos \w nombres|strong="H8034"\w* son: \w Azricam|strong="H5840"\w*, Bocru, \w Ismael|strong="H3458"\w*, \w Searías|strong="H8187"\w*, \w Obadías|strong="H5662"\w* y \w Hanán|strong="H2605"\w*.   
\c 10  
\s1 Muerte de Saúl  
\p
\v 1 Los \w filisteos|strong="H6430"\w* combatieron \w contra|strong="H6440"\w* \w Israel|strong="H3478"\w*. Los hombres \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w huyeron|strong="H5127"\w* \w de|strong="H6440"\w* los \w filisteos|strong="H6430"\w* y \w cayeron|strong="H5307"\w* \w muertos|strong="H2491"\w* en la montaña Gilboa.  
\v 2 \w Los|strong="H1121"\w* \w filisteos|strong="H6430"\w* \w siguieron|strong="H1692"\w* \w de|strong="H1121"\w* cerca \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* y \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w*. \w Mataron|strong="H5221"\w* \w a|strong="H3068"\w* Jonatán, \w a|strong="H3068"\w* Abinadab y \w a|strong="H3068"\w* Malquisúa, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w*.  
\v 3 Arreció \w la|strong="H5921"\w* \w batalla|strong="H4421"\w* \w contra|strong="H5921"\w* \w Saúl|strong="H7586"\w*. \w Los|strong="H5921"\w* \w flecheros|strong="H7198"\w* \w lo|strong="H5921"\w* alcanzaron \w y|strong="H5921"\w* fue \w herido|strong="H2342"\w* \w por|strong="H5921"\w* \w ellos|strong="H5921"\w*.   
\p
\v 4 \w Entonces|strong="H3588"\w* \w Saúl|strong="H7586"\w* dijo \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w escudero|strong="H5375"\w*: \w Saca|strong="H8025"\w* tu \w espada|strong="H2719"\w* \w y|strong="H3588"\w* traspásame \w con|strong="H5921"\w* \w ella|strong="H5921"\w*, \w no|strong="H3808"\w* \w sea|strong="H6435"\w* \w que|strong="H3588"\w* estos \w incircuncisos|strong="H6189"\w* vengan \w y|strong="H3588"\w* \w me|strong="H5921"\w* escarnezcan. \w Pero|strong="H3588"\w* \w su|strong="H3588"\w* \w escudero|strong="H5375"\w* \w no|strong="H3808"\w* quiso, \w porque|strong="H3588"\w* tenía \w gran|strong="H3966"\w* \w temor|strong="H3372"\w*. \w Entonces|strong="H3588"\w* \w Saúl|strong="H7586"\w* \w tomó|strong="H3947"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w* \w y|strong="H3588"\w* \w se|strong="H5921"\w* \w echó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w*.  
\v 5 \w Al|strong="H5921"\w* \w ver|strong="H7200"\w* \w que|strong="H3588"\w* \w Saúl|strong="H7586"\w* moría, \w su|strong="H1931"\w* \w escudero|strong="H5375"\w* \w también|strong="H1571"\w* \w se|strong="H1931"\w* \w echó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w la|strong="H1931"\w* \w suya|strong="H1931"\w* \w y|strong="H1571"\w* \w murió|strong="H4191"\w*.   
\p
\v 6 Así \w murió|strong="H4191"\w* \w Saúl|strong="H7586"\w* con sus \w tres|strong="H7969"\w* \w hijos|strong="H1121"\w*. \w Todos|strong="H3605"\w* \w los|strong="H1121"\w* \w de|strong="H1121"\w* su \w casa|strong="H1004"\w* \w murieron|strong="H4191"\w* \w juntamente|strong="H3162"\w* con \w él|strong="H3605"\w*.   
\p
\v 7 \w Cuando|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w hombres|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w que|strong="H3588"\w* \w estaban|strong="H3427"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w valle|strong="H6010"\w* \w vieron|strong="H7200"\w* \w que|strong="H3588"\w* \w Saúl|strong="H7586"\w* \w y|strong="H3588"\w* sus \w hijos|strong="H1121"\w* \w murieron|strong="H4191"\w*, abandonaron sus \w ciudades|strong="H5892"\w* \w y|strong="H3588"\w* \w huyeron|strong="H5127"\w*. \w Entonces|strong="H3588"\w* \w los|strong="H3427"\w* \w filisteos|strong="H6430"\w* vinieron \w y|strong="H3588"\w* vivieron \w en|strong="H3588"\w* ellas.   
\p
\v 8 \w El|strong="H5307"\w* \w día|strong="H1121"\w* \w siguiente|strong="H4283"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1121"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* \w fueron|strong="H1961"\w* \w a|strong="H3068"\w* despojar \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w muertos|strong="H2491"\w* y \w hallaron|strong="H4672"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* y \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w tendidos|strong="H5307"\w* en la montaña Gilboa.  
\v 9 Lo despojaron y \w tomaron|strong="H5375"\w* su \w cabeza|strong="H7218"\w* y sus \w armas|strong="H3627"\w*. \w Enviaron|strong="H7971"\w* mensajeros por toda la tierra \w de|strong="H5971"\w* los \w filisteos|strong="H6430"\w* \w para|strong="H5971"\w* dar las noticias \w a|strong="H3068"\w* sus \w ídolos|strong="H6091"\w* y al \w pueblo|strong="H5971"\w*.  
\v 10 Colgaron sus \w armas|strong="H3627"\w* en el \w templo|strong="H1004"\w* de sus \tl ʼelohim\tl* y clavaron su cabeza en el \w templo|strong="H1004"\w* de \w Dagón|strong="H1712"\w*.   
\p
\v 11 Cuando \w todos|strong="H3605"\w* \w los|strong="H3605"\w* de \w Jabes|strong="H3003"\w* de \w Galaad|strong="H1568"\w* \w oyeron|strong="H8085"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w* \w hicieron|strong="H6213"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*,  
\v 12 se \w levantaron|strong="H6965"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w valientes|strong="H2428"\w*, \w tomaron|strong="H5375"\w* \w los|strong="H1121"\w* cadáveres \w de|strong="H8478"\w* \w Saúl|strong="H7586"\w* y sus \w hijos|strong="H1121"\w* y \w los|strong="H1121"\w* \w llevaron|strong="H5375"\w* \w a|strong="H3068"\w* \w Jabes|strong="H3003"\w*. \w Sepultaron|strong="H6912"\w* sus restos \w debajo|strong="H8478"\w* del roble \w de|strong="H8478"\w* \w Jabes|strong="H3003"\w* y ayunaron \w siete|strong="H7651"\w* \w días|strong="H3117"\w*.   
\p
\v 13 \w Así|strong="H1571"\w* \w murió|strong="H4191"\w* \w Saúl|strong="H7586"\w* \w a|strong="H3068"\w* \w causa|strong="H1697"\w* \w de|strong="H5921"\w* su infidelidad \w que|strong="H3808"\w* \w cometió|strong="H4604"\w* \w contra|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w contra|strong="H5921"\w* \w la|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w la|strong="H5921"\w* cual \w no|strong="H3808"\w* \w guardó|strong="H8104"\w*. \w Aun|strong="H1571"\w* \w consultó|strong="H7592"\w* \w a|strong="H3068"\w* una evocadora \w de|strong="H5921"\w* espíritus \w de|strong="H5921"\w* \w muertos|strong="H4191"\w*,  
\v 14 y \w no|strong="H3808"\w* \w consultó|strong="H1875"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. Por esa causa \w lo|strong="H3808"\w* \w mató|strong="H4191"\w* y traspasó \w el|strong="H1121"\w* \w reino|strong="H4410"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Isaí|strong="H3448"\w*.   
\c 11  
\s1 Reinado de David en todo Israel  
\p
\v 1 Entonces \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* se congregó ante \w David|strong="H1732"\w* en \w Hebrón|strong="H2275"\w* y dijeron: \w Aquí|strong="H2009"\w* estamos, somos \w hueso|strong="H6106"\w* tuyo y \w carne|strong="H1320"\w* tuya.  
\v 2 \w Porque|strong="H5921"\w* \w en|strong="H5921"\w* días anteriores, \w cuando|strong="H1571"\w* \w aún|strong="H1571"\w* \w Saúl|strong="H7586"\w* \w era|strong="H1961"\w* \w rey|strong="H4428"\w*, tú sacabas \w y|strong="H1571"\w* devolvías \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w y|strong="H1571"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* tu \nd ʼElohim\nd* \w te|strong="H5921"\w* dijo: \wj Tú \+w apacentarás|strong="H7462"\+w* \+w a|strong="H3068"\+w* \+w mi|strong="H5921"\+w* \+w pueblo|strong="H5971"\+w* \+w Israel|strong="H3478"\+w* \+w y|strong="H1571"\+w* \+w serás|strong="H1961"\+w* \+w el|strong="H5921"\+w* soberano \+w de|strong="H5921"\+w* \+w mi|strong="H5921"\+w* \+w pueblo|strong="H5971"\+w* \+w Israel|strong="H3478"\+w*.\wj*   
\p
\v 3 Cuando \w los|strong="H5921"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w fueron|strong="H1732"\w* \w ante|strong="H6440"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w en|strong="H5921"\w* \w Hebrón|strong="H2275"\w*, \w David|strong="H1732"\w* \w hizo|strong="H3772"\w* un \w pacto|strong="H1285"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. Entonces \w ungieron|strong="H4886"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w como|strong="H5921"\w* \w rey|strong="H4428"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w según|strong="H5921"\w* \w la|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w que|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* dio \w por|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* \w Samuel|strong="H8050"\w*.   
\s1 La conquista de Jerusalén  
\p
\v 4 Entonces \w David|strong="H1732"\w* \w fue|strong="H3212"\w* con \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* Jerusalén, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* \w Jebús|strong="H2983"\w*. \w Los|strong="H3427"\w* \w jebuseos|strong="H2983"\w* \w vivían|strong="H3427"\w* \w en|strong="H3212"\w* \w aquella|strong="H1931"\w* tierra.  
\v 5 \w Los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de Jebús dijeron \w a|strong="H3068"\w* \w David|strong="H1732"\w*: \w No|strong="H3808"\w* entrarás \w aquí|strong="H2008"\w*. Pero \w David|strong="H1732"\w* capturó \w la|strong="H1931"\w* fortaleza de \w Sion|strong="H6726"\w*, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w Ciudad|strong="H5892"\w* de \w David|strong="H1732"\w*.   
\p
\v 6 \w David|strong="H1732"\w* dijo: \w El|strong="H3605"\w* \w que|strong="H1121"\w* \w primero|strong="H7223"\w* ataque \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w jebuseos|strong="H2983"\w* \w será|strong="H1961"\w* \w jefe|strong="H7218"\w* y \w comandante|strong="H8269"\w*. Entonces \w Joab|strong="H3097"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sarvia, \w subió|strong="H5927"\w* \w primero|strong="H7223"\w* y \w fue|strong="H1961"\w* designado \w comandante|strong="H8269"\w*.   
\p
\v 7 \w David|strong="H1732"\w* vivió \w en|strong="H5921"\w* \w la|strong="H5921"\w* fortaleza. \w Por|strong="H5921"\w* \w esto|strong="H3651"\w* \w la|strong="H5921"\w* \w llamaron|strong="H7121"\w* \w Ciudad|strong="H5892"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*.  
\v 8 \w Edificó|strong="H1129"\w* la \w ciudad|strong="H5892"\w* \w alrededor|strong="H5439"\w*, \w desde|strong="H4480"\w* el terraplén \w hasta|strong="H5704"\w* el muro. \w Joab|strong="H3097"\w* \w restauró|strong="H1129"\w* el resto \w de|strong="H4480"\w* la \w ciudad|strong="H5892"\w*.  
\v 9 \w David|strong="H1732"\w* se engrandecía cada vez más, \w porque|strong="H1732"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H5973"\w* las huestes estaba \w con|strong="H5973"\w* \w él|strong="H5973"\w*.   
\s1 Los valientes guerreros de David  
\p
\v 10 \w Éstos|strong="H3605"\w* son \w los|strong="H5921"\w* \w principales|strong="H7218"\w* \w valientes|strong="H1368"\w* \w que|strong="H5921"\w* respaldaron fuertemente \w a|strong="H3068"\w* \w David|strong="H1732"\w*. \w Lo|strong="H1697"\w* \w ayudaron|strong="H2388"\w* \w para|strong="H5921"\w* designarlo \w rey|strong="H4427"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w según|strong="H5921"\w* \w la|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 11 \w Éste|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w número|strong="H4557"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w valientes|strong="H1368"\w* \w que|strong="H1931"\w* tuvo \w David|strong="H1732"\w*: Jasobeam, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Hacmoni, \w jefe|strong="H7218"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* 30, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w blandió|strong="H5782"\w* \w su|strong="H1931"\w* \w lanza|strong="H2595"\w* \w contra|strong="H5921"\w* 300, \w a|strong="H3068"\w* \w los|strong="H1121"\w* cuales mató \w de|strong="H5921"\w* \w una|strong="H6471"\w* sola \w vez|strong="H6471"\w*.   
\p
\v 12 Después \w de|strong="H1121"\w* \w él|strong="H1931"\w* estaba Eleazar, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Dodo, \w el|strong="H1931"\w* ahohíta. \w Él|strong="H1931"\w* \w era|strong="H1121"\w* uno \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w tres|strong="H7969"\w* \w valientes|strong="H1368"\w*.  
\v 13 \w Éste|strong="H1931"\w* \w estuvo|strong="H1961"\w* \w con|strong="H5973"\w* \w David|strong="H1732"\w* \w en|strong="H5973"\w* Pas-damim \w cuando|strong="H1961"\w* \w los|strong="H5973"\w* \w filisteos|strong="H6430"\w* \w se|strong="H1961"\w* reunieron \w allí|strong="H8033"\w* \w para|strong="H1961"\w* \w la|strong="H1931"\w* \w batalla|strong="H4421"\w*. \w Había|strong="H1961"\w* una parcela \w de|strong="H6440"\w* \w tierra|strong="H2513"\w* \w llena|strong="H4392"\w* \w de|strong="H6440"\w* \w cebada|strong="H8184"\w*. Al huir \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w de|strong="H6440"\w* \w los|strong="H5973"\w* \w filisteos|strong="H6430"\w*,  
\v 14 él se colocó firme \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de la parcela y la \w defendió|strong="H5337"\w*. Derrotó \w a|strong="H3068"\w* los \w filisteos|strong="H6430"\w* y \nd \+w Yavé|strong="H3068"\+w*\nd* le dio una \w gran|strong="H1419"\w* victoria.   
\p
\v 15 \w Tres|strong="H7969"\w* \w de|strong="H4480"\w* \w los|strong="H5921"\w* 30 \w principales|strong="H7218"\w* \w bajaron|strong="H3381"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w roca|strong="H6697"\w* \add donde estaba\add* \w David|strong="H1732"\w*, \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w cueva|strong="H4631"\w* \w de|strong="H4480"\w* Adulam, mientras \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* acampaban \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w valle|strong="H6010"\w* \w de|strong="H4480"\w* Refaim.  
\v 16 \w David|strong="H1732"\w* estaba entonces en la fortaleza y una \w guarnición|strong="H5333"\w* de los \w filisteos|strong="H6430"\w* estaba en Belén.   
\p
\v 17 Entonces \w David|strong="H1732"\w* sintió un vivo deseo: ¡\w Quién|strong="H4310"\w* \w me|strong="H4310"\w* diera \w a|strong="H3068"\w* \w beber|strong="H8248"\w* \w agua|strong="H4325"\w* del pozo \w de|strong="H4325"\w* Belén, \w que|strong="H4310"\w* está en la \w puerta|strong="H8179"\w*!  
\v 18 Entonces los \w tres|strong="H7969"\w* irrumpieron en \w el|strong="H4264"\w* \w campamento|strong="H4264"\w* \w de|strong="H4325"\w* los \w filisteos|strong="H6430"\w*, \w sacaron|strong="H7579"\w* \w agua|strong="H4325"\w* \w del|strong="H8354"\w* pozo \w de|strong="H4325"\w* Belén \w que|strong="H3808"\w* está junto \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w* y \w se|strong="H3808"\w* la \w llevaron|strong="H5375"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*.  
\p Pero \w David|strong="H1732"\w* \w no|strong="H3808"\w* la quiso \w beber|strong="H8354"\w*, \w sino|strong="H3808"\w* la derramó ante \nd \+w Yavé|strong="H3068"\+w*\nd* y dijo:  
\v 19 ¡\w Lejos|strong="H2486"\w* \w esté|strong="H2063"\w* \w de|strong="H3588"\w* \w mí|strong="H5315"\w*, oh \w mi|strong="H5315"\w* \nd ʼElohim\nd*, \w hacer|strong="H6213"\w* \w esto|strong="H2063"\w*! ¿\w Beberé|strong="H8354"\w* \w la|strong="H3588"\w* \w sangre|strong="H1818"\w* \w de|strong="H3588"\w* \w estos|strong="H2063"\w* \w hombres|strong="H1368"\w* \w que|strong="H3588"\w* \w con|strong="H3588"\w* riesgo \w de|strong="H3588"\w* sus \w vidas|strong="H5315"\w* \w la|strong="H3588"\w* \w trajeron|strong="H6213"\w*? \w Y|strong="H3068"\w* \w no|strong="H3808"\w* quiso \w beberla|strong="H8354"\w*.  
\p Aquellos \w tres|strong="H7969"\w* \w valientes|strong="H1368"\w* \w hicieron|strong="H6213"\w* \w esto|strong="H2063"\w*.   
\p
\v 20 \w Abisai|strong="H7969"\w*, hermano \w de|strong="H5921"\w* \w Joab|strong="H3097"\w*, \w era|strong="H1961"\w* \w el|strong="H1931"\w* \w principal|strong="H7218"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* 30, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w blandió|strong="H5782"\w* \w su|strong="H1931"\w* \w lanza|strong="H2595"\w* \w contra|strong="H5921"\w* 300 \w y|strong="H5921"\w* \w los|strong="H5921"\w* mató, \w y|strong="H5921"\w* \w tuvo|strong="H1961"\w* renombre \w entre|strong="H5921"\w* \w los|strong="H5921"\w* \w tres|strong="H7969"\w*.  
\v 21 \w Fue|strong="H1961"\w* el \w más|strong="H4480"\w* ilustre \w de|strong="H4480"\w* \w los|strong="H1961"\w* 30 \w y|strong="H5704"\w* \w fue|strong="H1961"\w* su \w jefe|strong="H8269"\w*, pero \w no|strong="H3808"\w* igualó \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w tres|strong="H7969"\w* primeros.   
\p
\v 22 \w Benaía|strong="H1141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Joiada|strong="H3077"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* un \w hombre|strong="H1121"\w* \w valiente|strong="H2428"\w* \w de|strong="H4480"\w* \w grandes|strong="H7227"\w* hazañas, \w de|strong="H4480"\w* \w Cabseel|strong="H6909"\w*, \w venció|strong="H5221"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Ariel \w de|strong="H4480"\w* \w Moab|strong="H4124"\w*. Un \w día|strong="H3117"\w* \w de|strong="H4480"\w* nieve, bajó y \w mató|strong="H5221"\w* \w a|strong="H3068"\w* un león \w dentro|strong="H8432"\w* \w de|strong="H4480"\w* un foso.  
\v 23 También \w mató|strong="H2026"\w* \w a|strong="H3068"\w* un \w egipcio|strong="H4713"\w*, hombre \w de|strong="H2568"\w* 2,25 metros \w de|strong="H2568"\w* estatura. \w El|strong="H1931"\w* \w egipcio|strong="H4713"\w* llevaba una \w lanza|strong="H2595"\w* \w como|strong="H1931"\w* un rodillo \w de|strong="H2568"\w* tejedor. Pero \add Benaía\add* bajó con un cayado, \w le|strong="H1931"\w* arrebató \w la|strong="H1931"\w* \w lanza|strong="H2595"\w* \w de|strong="H2568"\w* \w la|strong="H1931"\w* \w mano|strong="H3027"\w* al \w egipcio|strong="H4713"\w* y \w lo|strong="H1931"\w* \w mató|strong="H2026"\w* con \w la|strong="H1931"\w* \w lanza|strong="H2595"\w* \w de|strong="H2568"\w* \w éste|strong="H1931"\w*.  
\v 24 \w Esto|strong="H6213"\w* \w hizo|strong="H6213"\w* \w Benaía|strong="H1141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joiada|strong="H3077"\w*, y \w tuvo|strong="H6213"\w* tanto renombre como \w los|strong="H1121"\w* \w tres|strong="H7969"\w* \w valientes|strong="H1368"\w*.  
\v 25 \w Ciertamente|strong="H2005"\w* \w fue|strong="H1931"\w* \w el|strong="H1931"\w* \w más|strong="H4480"\w* distinguido \w de|strong="H4480"\w* \w los|strong="H5921"\w* 30, pero \w no|strong="H3808"\w* igualó \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w tres|strong="H7969"\w* primeros. \w David|strong="H1732"\w* \w lo|strong="H1931"\w* designó jefe \w de|strong="H4480"\w* \w su|strong="H1931"\w* guardia personal.  
\v 26 \w Los|strong="H1121"\w* \w valientes|strong="H1368"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w ejércitos|strong="H2428"\w* eran: \w Asael|strong="H6214"\w*, hermano \w de|strong="H1121"\w* \w Joab|strong="H3097"\w*, Elhanán, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Dodo, \w de|strong="H1121"\w* Belén,  
