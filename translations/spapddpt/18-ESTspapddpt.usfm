\v 17 \w En|strong="H5921"\w* \w cada|strong="H3605"\w* \w provincia|strong="H4082"\w* \w y|strong="H3588"\w* \w ciudad|strong="H5892"\w*, \w a|strong="H3068"\w* \w donde|strong="H5921"\w* \w llegaba|strong="H5060"\w* \w la|strong="H5921"\w* orden \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w y|strong="H3588"\w* \w su|strong="H3588"\w* edicto, \w los|strong="H5921"\w* \w judíos|strong="H3064"\w* tenían regocijo \w y|strong="H3588"\w* \w alegría|strong="H8057"\w*, \w banquetes|strong="H4960"\w* \w y|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* fiesta. \w Y|strong="H3068"\w* \w muchos|strong="H7227"\w* \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w se|strong="H5921"\w* cambiaron \w para|strong="H5921"\w* ser \w judíos|strong="H3064"\w*, \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w temor|strong="H6343"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w judíos|strong="H3064"\w* \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*.
\c 9
