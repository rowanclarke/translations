\v 9  \w So|strong="H7971"\w* if \w a|strong="H3068"\w* \w prophet|strong="H5030"\w* \w prophesied|strong="H5012"\w* \w peace|strong="H7965"\w* \w and|strong="H3068"\w* \w prosperity|strong="H7965"\w*, \w it|strong="H3045"\w* \w was|strong="H3068"\w* \w only|strong="H7965"\w* \w known|strong="H3045"\w* \w that|strong="H3045"\w* \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* truly \w sent|strong="H7971"\w* \w him|strong="H7971"\w* \w when|strong="H7971"\w* \w what|strong="H1697"\w* \w he|strong="H3068"\w* \w prophesied|strong="H5012"\w* \w came|strong="H3068"\w* \w true|strong="H3068"\w*.”   
\p
\v 10  \w The|strong="H5921"\w* \w prophet|strong="H5030"\w* \w Hananiah|strong="H2608"\w* \w then|strong="H3947"\w* \w took|strong="H3947"\w* \w the|strong="H5921"\w* \w yoke|strong="H4133"\w* \w off|strong="H5921"\w* \w the|strong="H5921"\w* \w prophet|strong="H5030"\w* \w Jeremiah|strong="H3414"\w*’s \w neck|strong="H6677"\w* \w and|strong="H3947"\w* \w broke|strong="H7665"\w* \w it|strong="H5921"\w*.  
\v 11  \w Then|strong="H4428"\w* \w he|strong="H3117"\w* spoke \w up|strong="H5921"\w* \w in|strong="H8141"\w* \w the|strong="H3605"\w* \w presence|strong="H5869"\w* \w of|strong="H4428"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w*. “\w The|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w says|strong="H3541"\w*, ‘\w In|strong="H8141"\w* \w the|strong="H3605"\w* \w same|strong="H3541"\w* \w way|strong="H1870"\w* \w I|strong="H3117"\w* \w will|strong="H3068"\w* \w break|strong="H7665"\w* \w the|strong="H3605"\w* \w yoke|strong="H5923"\w* \w of|strong="H4428"\w* servitude \w of|strong="H4428"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w nations|strong="H1471"\w* \w to|strong="H3068"\w* \w King|strong="H4428"\w* \w Nebuchadnezzar|strong="H5019"\w* \w of|strong="H4428"\w* Babylon \w before|strong="H5869"\w* two \w years|strong="H8141"\w* \w are|strong="H3117"\w* \w over|strong="H5921"\w*.’” \w After|strong="H5921"\w* \w he|strong="H3117"\w* heard \w this|strong="H3541"\w*, \w the|strong="H3605"\w* \w prophet|strong="H5030"\w* \w Jeremiah|strong="H3414"\w* \w departed|strong="H3212"\w* \w and|strong="H3068"\w* \w went|strong="H3212"\w* \w on|strong="H5921"\w* \w his|strong="H3605"\w* \w way|strong="H1870"\w*.   
\p
