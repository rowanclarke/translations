\id SNG
\h Hiva  Ľa Solomone
\toc1 Ko E Hiva  Ľa Solomone
\toc2 Hiva  Ľa Solomone
\toc3 Hiv
\mt2 KO E HIVA
\mt3  ĽA
\mt1 SOLOMONE
\cl KO E VAHE
\c 1
\cd \it 1 Ko e  Ľofa  Ľae siasi kia Kalaisi. 5  ĽOku fakahńĀ  Ľe he siasi  Ľene ta Ľematamatalelei, 7 Pea  Ľoku ne kole ke fakahinohino ia ki he potu  Ľoku  Ľi ai  Ľa  Ľene fanga sipi. 8  ĽOku tala  Ľe Kalaisi ke ne  Ľalu ki he ngaahi fale  Ľoe kau tauhimanu: 9 Pea  Ľoku ne fakahńĀ  Ľene  Ľofa kiate ia, 11 Mo  Ľene ngaahi tala Ľofa lelei. 12  ĽOku fefakaongolelei Ľaki  Ľa Kalaisi mo hono siasi.\it*
\p 
\v 1 Ko e fungani  Ľoe hiva  Ľa Solomone.
\q1 
\v 2 Tuku ke ne  Ľuma Ľaki kiate au  Ľae ngaahi  Ľuma  Ľa hono ngutu:
\q2 he  Ľoku lelei hake ho Ľo  Ľofa  Ľi he uaine.
\q1 
\v 3 ‚ÄĆ ĽOku tatau ho huafa mo e lilingi atu  Ľae lolo kakala,
\q2 koe Ľuhi ko e namu lelei  Ľo ho Ľo ngaahi me Ľa tńĀkai,
\q2 pea ko ia  Ľoku  Ľofa ai  Ľae kau tńĀupo Ľou kiate koe.
\q1 
\v 4 Toho au, pea te mau lele atu kiate koe:
\q2 kuo  Ľomi au  Ľe he tu Ľi ki hono ngaahi potu fale:
\q2 te mau fiefia mo nekeneka  Ľiate koe,
\q1 pea te mau tokanga lahi hake kiate koe  Ľi he uaine:
\q2  Ľoku  Ľofa kiate koe  Ľae angatonu.
\q1 
\v 5 ‚ÄĆ ĽE ngaahi  Ľofefine  Ľo SelŇęsalema,
\q2  Ľoku ou  Ľuli Ľuli  Ľo hangńď ko e ngaahi fale fehikitaki  Ľo Keta,
\q2 kae matamatalelei  Ľo hangńď ko e ngaahi puipui  Ľi he fale  Ľo Solomone.
\q1 
\v 6 ‚ÄĆ ĽOua na Ľa sio mai kiate au koe Ľuhi  Ľoku ou  Ľuli Ľuli,
\q2 koe Ľuhi kuo sio hifo  Ľae la ĽńĀ kiate au:
\q1 na Ľe  Ľita kiate au  Ľae fńĀnau  Ľa  Ľeku fa Ľńď;
\q2 na Ľa nau ngaohi au ko e tauhi ki he ngaahi ngoue vaine;
\q2 ka ko  Ľeku ngoue vaine  Ľa Ľaku kuo  Ľikai te u tauhi ia.
\q1 
\v 7 ‚ÄĆ ĽA koe,  Ľoku  Ľofa ki ai hoku laumńĀlie,
\q2 fakahńĀ mai kiate au  Ľae potu  Ľoku ke fafanga ai,
\q2  Ľae potu  Ľoku ke pule ke malolŇć ai  Ľa ho Ľo fanga manu  Ľi he ho ĽatńĀmńĀlie:
\q2 he ko e hńĀ te u hoko ai ke u tatau mo ha taha  Ľoku afe ki he fanga manu  Ľa ho kaungńĀ Ľapi?
\q1 
\v 8 Kapau  Ľoku  Ľikai te ke  Ľilo,  Ľa koe  Ľoku hoihoifua lahi  Ľi he kau fefine kotoa pńď,
\q2  Ľalu pe  Ľi ho hala,  Ľi he  Ľalunga  Ľoe fanga manu,
\q2 pea ke fafanga ho Ľo ngaahi  Ľuhiki Ľi kosi  Ľi he fale fehikitaki  Ľoe kau tauhimanu.
\q1 
\v 9 ‚ÄĆ ĽA hoku  Ľofa Ľanga,
\q2 kuo u fakatatau koe ki he fanga hoosi  Ľi he ngaahi saliote  Ľo Felo.
\q1 
\v 10 Kuo fakamatamatalelei ho kou Ľahe  Ľaki  Ľae tuinga \add mata Ľitofe\add*,
\q2 mo ho kia  Ľaki  Ľae ngaahi kahoa \add koula\add*.
\q2 
\v 11 Te mau ngaohi  Ľaki  Ľae koula ho ngaahi kapa Ľi kofu,
\q2 mo pule Ľi  Ľaki ia  Ľae siliva.
\q1 
\v 12 Lolotonga  Ľae nofo  Ľae tu Ľi  Ľi hono keinanga Ľanga  Ľoku namu kakala atu  Ľeku naatosi.
\q1 
\v 13 ‚ÄĆ ĽOku hangńď ko e  Ľu kakala  Ľa hoku  Ľofa Ľanga kiate au,
\q2 pea  Ľe tokoto ia ki hoku fatafata  Ľi he pŇć  Ľo  Ľaho.
\q1 
\v 14 ‚ÄĆ ĽOku tatau kiate au  Ľa hoku  Ľofa Ľanga mo e fuhi saipalesi  Ľi he ngaahi ngoue vaine  Ľi Eniketi.
\q1 
\v 15 Vakai,  Ľoku ke hoihoifua  Ľa koe  Ľoku ou  Ľofa ai;
\q2 vakai,  Ľoku ke hoihoifua  Ľoku ke ma Ľu  Ľae mata  Ľoe lupe.
\q1 
\v 16 Vakai,  Ľoku ke toulekeleka,  ĽE hoku  Ľofa Ľanga,  Ľio, mo faka Ľofo Ľofa;
\q2 pea  Ľoku lauma Ľui Ľui foki hota tokoto Ľanga.
\q1 
\v 17 Ko e ngaahi  Ľalanga  Ľo hota fale ko e sita,
\q2 pea  Ľoku  Ľato  Ľaki  Ľae saipalesi.
\c 2
\cd \it 1 Ko e fe Ľofa Ľaki  Ľa Kalaisi mo hono siasi. 8 Ko e  Ľamanaki, 10 Mo e uiui Ľi  Ľoe siasi. 14 Ko e tauhi  Ľa Kalaisi ki he siasi. 16 Ko e fakahńĀ  Ľe he siasi  Ľa  Ľene tui mo  Ľene  Ľamanaki lelei.\it*
\p 
\v 1 Ko au ko e lose  Ľo Saloni,
\q2 ko e lile  Ľoe ngaahi tele Ľa.
\q1 
\v 2 ‚ÄĆ ĽO hangńď ko e lile  Ľi he lotolotonga  Ľoe ngaahi  Ľakau talatala,
\q2  Ľoku pehńď  Ľa hoku  Ľofa Ľanga  Ľi he ngaahi  Ľofefine.
\q1 
\v 3 Pea hangńď ko e  Ľakau ko e moli ki he ngaahi  Ľakau  Ľoe vao,
\q2  Ľoku pehńď  Ľa hoku  Ľofa Ľanga  Ľi he  Ľao  Ľoe ngaahi foha.
\q1 Ne u nofo hifo ki lalo  Ľi hono malumalu,
\q2 pea u fiefia lahi,
\q2 pea na Ľe hu Ľamelie  Ľa hono fua ki hoku ngutu.
\q1 
\v 4 Na Ľa ne  Ľomi au ki he fale keinanga Ľanga,
\q2 pea na Ľe fakamalu  Ľaki au  Ľae fuka  Ľae  Ľofa.
\q1 
\v 5 Tokoni au  Ľaki  Ľae uaine,
\q2 pea fakafiemńĀlie Ľi au  Ľaki  Ľae ngaahi moli:
\q2 he  Ľoku ou pongia  Ľi he  Ľofa.
\q1 
\v 6 ‚ÄĆ ĽOku  Ľi lalo  Ľi hoku  Ľulu  Ľa hono nima to Ľohema,
\q2 pea  Ľoku fńĀ Ľufua au  Ľe hono nima to Ľomata Ľu.
\q1 
\v 7 ‚ÄĆ ĽE ngaahi  Ľofefine  Ľo SelŇęsalema,
\q2  Ľoku ou fekau kiate kimoutolu,  Ľi ho Ľomou  Ľofa ki he fanga kńĀseli mo e fanga hainite  Ľoe vao,
\q2 ke  Ľoua na Ľa mou ue Ľi pe fafangu  Ľa hoku  Ľofa Ľanga,
\q2 kae Ľoua ke fa Ľiteliha pe ia.
\q1 
\v 8 Ko e le Ľo  Ľo hoku  Ľofa Ľanga! Vakai,
\q2  Ľoku ha Ľu ia mo puna  Ľi he ngaahi mo Ľunga,
\q2 pea hopohopo  Ľi he ngaahi potu mńĀ Ľolunga.
\q1 
\v 9 ‚ÄĆ ĽOku tatau  Ľa hoku  Ľofa Ľanga mo e kńĀseli pe ko e hainite mui:
\q2 vakai,  Ľoku tu Ľu mai ia mei he tua ĽńĀ,
\q2  Ľoku ne fakasio mai mei he ngaahi matapńĀ,
\q2  Ľo ne fakahńĀ ia mei he ngaahi kńĀtupa.
\q1 
\v 10 Na Ľe lea mai  Ľa hoku  Ľofa Ľanga,  Ľo ne pehńď kiate au,
\q2 Tu Ľu hake  Ľa hoku  Ľofa Ľanga, ko  Ľeku tokotaha  Ľoku hoihoifua, pea ke ha Ľu.
\q1 
\v 11 Vakai, kuo hili  Ľae fa Ľahita Ľu momoko,
\q2 pea kuo  Ľosi  Ľae  Ľuha mo mole atu;
\q1 
\v 12 Kuo tupu hake  Ľae ngaahi fisi Ľi  Ľakau  Ľi he funga kelekele,
\q2 kuo hoko  Ľae ngaahi  Ľaho  Ľoku hiva ai  Ľae fanga manupuna,
\q2 pea  Ľoku ongo Ľi  Ľi hota fonua  Ľae le Ľo  Ľoe kulukulu:
\q1 
\v 13 ‚ÄĆ ĽOku kamata tupu  Ľi he  Ľakau ko e fiki  Ľa hono fua,
\q2 pea  Ľoku namu lelei mai  Ľae fua mui  Ľi he ngaahi vaine.
\q2  ĽńĀ koe ko hoku  Ľofa Ľanga, mo  Ľeku hoihoifua, ke ke tu Ľu hake,
\q2 pea ke ha Ľu.
\q1 
\v 14 ‚ÄĆ ĽA koe ko  Ľeku lupe,  Ľoku nofo  Ľi he ngaahi  Ľana Ľi maka,
\q2 mo e ngaahi potu lilolilo  Ľoe lilifa,
\q2 ke ke fakahńĀ mai ho mata kiate au,
\q2 pea tuku ke u fanongo ki ho le Ľo;
\q2 he  Ľoku ke le Ľo mńĀlie, pea  Ľoku faka Ľofo Ľofa ho mata.
\q1 
\v 15 Ke ma Ľu mai  Ľae fanga fokisi,
\q2  Ľae fanga fokisi iiki,  Ľaia  Ľoku maumau Ľi  Ľae vaine:
\q2 he  Ľoku kei mui  Ľae fua  Ľoe vaine.
\q1 
\v 16 ‚ÄĆ ĽOku  Ľo Ľoku  Ľa hoku  Ľofa Ľanga, pea  Ľoku ou  Ľo Ľona au:
\q2  Ľoku kai  Ľe ia  Ľi he potu  Ľoe ngaahi lile.
\q1 
\v 17 Tafoki mai  Ľa hoku  Ľofa Ľanga,
\q2 kae Ľoua ke ma Ľa hake  Ľae  Ľaho,
\q2 pea mole atu  Ľae fakapo Ľuli,
\q2 pea ke tatau koe mo e kńĀseli pe ko e hainite mui  Ľi he ngaahi mo Ľunga  Ľo Peta.
\c 3
\cd \it 1 Ko e tau  Ľae siasi mo e ngaahi me Ľa  Ľahi Ľahi, mo  Ľene iku Ľi ia. 6 Ko e vikiviki  Ľae siasi koe Ľuhi ko Kalaisi.\it*
\p 
\v 1 ‚ÄĆ ĽI he  Ľeku  Ľi hoku mohenga  Ľi he pŇć,
\q2 na Ľaku kumi kiate ia  Ľoku  Ľofa ki ai hoku laumńĀlie:
\q2 ne u kumi, ka na Ľe  Ľikai ke  Ľilo Ľi ia,
\q1 
\v 2 Pea ko eni, te u tu Ľu hake  Ľo  Ľalu fano  Ľi he ngaahi hala
\q2  Ľoe kolo mo e ngaahi hala motu Ľa,
\q2 pea te u kumi ia  Ľaia  Ľoku  Ľofa ki ai hoku laumńĀlie:
\q2 ne u kumi kiate ia, ka na Ľe  Ľikai te u  Ľilo Ľi ia.
\q1 
\v 3 Na Ľe  Ľilo Ľi au  Ľe he kau le Ľo  Ľoku fe Ľalu Ľaki  Ľi he kolo;
\q2 \add pea na Ľaku fehu Ľi ki ai  Ľo pehńď\add*,
\q2 ‚ÄúKuo mou mamata kiate ia  Ľoku  Ľofa ki ai hoku laumńĀlie?‚ÄĚ
\q1 
\v 4 Pea kuo tuku si Ľi atu  Ľakinautolu,
\q2 pea u  Ľilo ia  Ľoku  Ľofa ki ai hoku laumńĀlie:
\q1 pea na Ľaku puke ia, pea na Ľe  Ľikai te u toe tukuange ia,
\q2 kae Ľoua ke u  Ľomi ia ki he fale  Ľo  Ľeku fa Ľńď,
\q2 mo e potu fale  Ľo Ľona na Ľa ne fanau Ľi ai au.
\b
\q1 
\v 5 ‚ÄĆ ĽE ngaahi  Ľofefine  Ľo SelŇęsalema,  Ľoku ou fekau kiate kimoutolu,
\q2  Ľi ho Ľomou  Ľofa ki he fanga kńĀseli mo e hainite  Ľoe vao,
\q2 ke  Ľoua na Ľa mou ue Ľi pe fafangu  Ľa hoku  Ľofa Ľanga,
\q2 kae Ľoua ke fa Ľiteliha pe ia.
\q1 
\v 6 Ko hai eni  Ľoku ha Ľu mei he toafa,  Ľoku hangńď ko e pou ko e kohu  Ľoe afi,
\q2 pea kuo fakanamu lelei  Ľaki  Ľae mula mo e laipeno,
\q2 mo e ngaahi kakala kotoa pńď mei he kau fakatau?
\q1 
\v 7 Vakai ki he mohenga  Ľo Solomone,
\q2  Ľoku kńĀpui ia  Ľe he kau tangata to Ľa  Ľe toko onongofulu,
\q2 mei he kau tangata to Ľa  Ľo  ĽIsileli.
\q1 
\v 8 ‚ÄĆ ĽOku nau taki taha to Ľo  Ľae heletńĀ, he  Ľoku nau maheni ai mo e tau:
\q2  Ľoku taki taha ai  Ľene heletńĀ ki hono tu Ľa tenga,
\q2 na Ľa ai ha manavahńď  Ľi he po Ľuli.
\q1 
\v 9 Na Ľe ngaohi  Ľe he tu Ľi ko Solomone ha mohenga mo Ľona,
\q2 mei he ngaahi  Ľakau  Ľo Lepanoni.
\q1 
\v 10 Na Ľa ne ngaohi  Ľaki  Ľae siliva  Ľa hono pou,
\q2 pea ko hono faliki ko e koula,
\q2 ko hono  Ľufi Ľufi ko e kulokula,
\q2 pea faliki  Ľaki  Ľi loto  Ľae  Ľofa ki he ngaahi  Ľofefine  Ľo SelŇęsalema.
\q1 
\v 11 ‚ÄĆ ĽE ngaahi  Ľofefine  Ľo Saione, mou  Ľalu atu,  Ľo vakai kia Solomone, ko e tu Ľi,
\q2 mo e tatńĀ fakatu Ľi na Ľe tatńĀ  Ľaki ia  Ľe he Ľene fa Ľńď
\q2  Ľi he  Ľaho  Ľo  Ľene fakama Ľu mali,
\q2  Ľi he  Ľaho  Ľoe fiefia  Ľa hono loto.
\c 4
\cd \it 1  ĽOku fakahńĀ  Ľe Kalaisi  Ľae hoihoifua  Ľoe siasi. 8  ĽOku ne fakahńĀ  Ľa  Ľene  Ľofa ki ai. 16  ĽOku kole  Ľae siasi ke ne teuteu ki hono  Ľao.\it*
\p 
\v 1 Vakai,  Ľoku ke hoihoifua,  ĽE hoku  Ľofa Ľanga;
\q2 vakai,  Ľoku ke hoihoifua;
\q2  Ľoku tatau ho mata mo e mata  Ľoe lupe  Ľoku fakalilo  Ľaki ho lou Ľulu:
\q1 pea ko ho lou Ľulu  Ľoku hangńď ko e lou Ľulu  Ľoe fanga kosi,
\q2  Ľoku fafanga  Ľi he mo Ľunga ko Kiliati.
\q1 
\v 2 ‚ÄĆ ĽOku tatau ho kaunifo mo e fanga sipi kuo kosikosi,
\q2 pea  Ľoku  Ľalu hake mei he kaukau Ľi;
\q2 he  Ľoku taki  Ľuhiua  Ľa honau  Ľuhiki,
\q2 pea  Ľoku  Ľikai ke pa Ľa ha taha  Ľi ai.
\q1 
\v 3 ‚ÄĆ ĽOku tatau mo e afo kulokula ho loungutu;
\q2 pea  Ľoku mńĀlie ho le Ľo;
\q2 pea  Ľoku tatau mo e konga pomikanite  Ľa ho manifinifihanga  Ľoku fakalilo  Ľaki ho lou Ľulu.
\q1 
\v 4 ‚ÄĆ ĽOku tatau ho kia mo e fale mńĀ Ľolunga na Ľe langa  Ľe Tevita ko e tuku Ľanga  Ľoe mahafutau,
\q2  Ľaia  Ľoku tautau ai  Ľae fakaŇę  Ľe afe,
\q2  Ľae pńĀ kotoa pńď  Ľoe kau tangata to Ľa.
\q1 
\v 5 ‚ÄĆ ĽOku tatau ho ongo huhu mo e ongo kńĀseli mui  Ľoku na tatau,
\q2  Ľaia  Ľoku kai  Ľi he potu  Ľoe ngaahi lile.
\q1 
\v 6 Te u  Ľalu au ki he mo Ľunga  Ľoe mula,
\q2 mo e mo Ľunga  Ľoe laipeno,
\q2 pea te u  Ľi ai  Ľo a Ľu ki he ma Ľa hake  Ľae  Ľaho,
\q2 mo e puna atu  Ľoe fakapo Ľuli.
\b
\q1 
\v 7 ‚ÄĆ ĽE hoku  Ľofa Ľanga,  Ľoku ke hoihoifua haohaoa;
\q2  Ľoku  Ľikai ha mele  Ľiate koe.
\q1 
\v 8 Ha Ľu mo au mei Lepanoni,  ĽE hoku uaifi,
\q2 ha Ľu mo au mei Lepanoni;
\q2 sio hifo mei he tumutumu  Ľo  ĽAmana,
\q2 mei he tumutumu  Ľo Senila mo Heamoni,
\q2 mei he  Ľana  Ľoe fanga laione,
\q2 mei he ngaahi mo Ľunga  Ľoe fanga lńďpati.
\q1 
\v 9 ‚ÄĆ ĽE hoku tuofefine mo hoku uaifi,
\q2 kuo kavea hoku loto kiate koe; kuo mole hoku loto  Ľi he sio mai tu Ľo taha pe  Ľa ho mata,
\q2 mo e kahoa pe taha  Ľi ho kia.
\q1 
\v 10 Hono  Ľikai matamatalelei  Ľa ho Ľo  Ľofa,  ĽE hoku tuofefine mo hoku uaifi!
\q2 Hono  Ľikai lelei hake ho Ľo  Ľofa  Ľi he uaine,
\q2 mo e nanamu  Ľo ho Ľo ngaahi me Ľa tńĀkai  Ľi he me Ľa namu kakala kotoa pńď.
\q1 
\v 11 ‚ÄĆ ĽE hoku uaifi,  Ľoku to Ľi ho loungutu  Ľo hangńď ko e hone mei hono nge Ľesi:
\q2  Ľoku  Ľi lalo  Ľi ho  Ľelelo  Ľae hone mo e hu Ľahuhu;
\q2 pea ko e nanamu  Ľo ho ngaahi kofu  Ľoku tatau mo e nanamu  Ľo Lepanoni.
\q1 
\v 12 ‚ÄĆ ĽOku tatau mo e ngoue kuo  ĽńĀ Ľi,  Ľa hoku tuofefine mo hoku uaifi;
\q2 ko e vai mapunopuna ia kuo ta Ľofia,
\q2 ko e matavai ia kuo tńĀpuni ke ma Ľu.
\q1 
\v 13 Ko ia  Ľoku tupu  Ľiate koe  Ľoku tatau mo e ngoue pomikanite mo hono ngaahi fua lelei;
\q2 ko e saipalesi mo e naatosi,
\q2 
\v 14 Ko e naatosi mo e kakosi;
\q2 ko e kalamusi mo e sinamoni, mo e  Ľakau kotoa pńď  Ľoku namu lelei;
\q2 ko e mula mo e  Ľalosi, mo e fungani hake  Ľoe ngaahi kakala kotoa pńď:
\q1 
\v 15 Ko e matavai  Ľi he ngaahi ngoue,
\q2 ko e matavai  Ľoe ngaahi vai mo Ľui,
\q2 mo e ngaahi vaitafe mei Lepanoni.
\q1 
\v 16 ‚ÄĆ ĽE matangi tokelau, ke ke  Ľaa pea ha Ľu mo e tonga;
\q2  Ľo havilivili ki he Ľeku ngoue, koe Ľuhi ke ngangatu mei ai  Ľae ngaahi namu kakala.
\q1 Tuku ke ha Ľu  Ľa hoku  Ľofa Ľanga ki he Ľene ngoue,
\q2 mo ne kai ai hono ngaahi fua lelei.
\c 5
\cd \it 1  ĽOku fafangu  Ľe Kalaisi  Ľa hono siasi  Ľi he Ľene ui. 2  ĽI he kamata  Ľilo  Ľe he siasi  Ľae  Ľofa  Ľa Kalaisi  Ľoku ne vaivai ai. 9 Ko e fakahńĀ mai  Ľae ngaahi  ĽulungńĀanga lelei  Ľa Kalaisi.\it*
\p 
\v 1 ‚ÄĆ ĽE hoku tuofefine mo hoku uaifi, kuo u ha Ľu ki he Ľeku ngoue:
\q2 kuo u tńĀnaki  Ľa  Ľeku mula, mo  Ľeku kakala;
\q2 kuo u kai  Ľa  Ľeku hone pea mo hono nge Ľesi;
\q2 kuo u inu  Ľi he Ľeku uaine mo  Ľeku hu Ľahuhu:
\q2  ĽE hoku kńĀinga,
\q2 ke tau kai,
\q2 pea inu,  Ľio, ke inu lahi  Ľakimoutolu  Ľoku ou  Ľofa ai.
\q1 
\v 2 ‚ÄĆ ĽOku ou mohe, ka  Ľoku  ĽńĀ hoku loto:
\q2 ko e le Ľo ia  Ľo hoku  Ľofa Ľanga,  Ľoku ne tukituki,
\q2  Ľo ne pehńď, ‚Äú ĽE hoku tuofefine, mo hoku  Ľofa Ľanga, ko  Ľeku lupe,
\q2 ko  Ľeku haohaoa, to Ľo kiate au:
\q2 he kuo pito hoku  Ľulu  Ľi he hahau,
\q2 mo hoku lou Ľulu  Ľi he viviku  Ľoe po Ľuli.
\q1 
\v 3 Kuo u to Ľo hoku kofutu Ľa; pea  Ľe fńďfńď ha Ľaku toe  Ľai ia?
\q2 Kuo u fufulu hoku va Ľe, pea  Ľe fńďfńď ha Ľaku toe  Ľuli Ľi ia?
\q1 
\v 4 Na Ľe  Ľai mai  Ľae nima  Ľo hoku  Ľofa Ľanga  Ľi he kńĀtupa,
\q2 pea na Ľe ngaue hoku loto kiate ia.
\q1 
\v 5 Ne u tu Ľu hake ke to Ľo ki hoku  Ľofa Ľanga;
\q2 pea na Ľe to Ľi mei hoku nima  Ľae mula,
\q2 pea mei hoku louhi Ľi nima  Ľae mula namu lelei,
\q2 pea tafe hifo ia ki he to Ľo Ľanga matapńĀ.
\q1 
\v 6 Na Ľaku to Ľo ki hoku  Ľofa Ľanga;
\q2 ka kuo tafoki atu  Ľa hoku  Ľofa Ľanga,  Ľo ne  Ľalu:
\q1 na Ľe vaivai  Ľa hoku loto  Ľi he Ľene lea mai:
\q2 ne u kumi kiate ia, ka na Ľe  Ľikai te u ma Ľu ia;
\q2 ne u ui ki ai, ka na Ľe  Ľikai te ne tali au.
\q1 
\v 7 Pea na Ľe  Ľilo Ľi au  Ľe he kau le Ľo na Ľe fe Ľalu Ľaki  Ľi he kolo,  Ľonau taa Ľi au,
\q2 pea u lavea ai;
\q2 pea na Ľe to Ľo  Ľa hoku pŇęlou  Ľe he kau le Ľohi  Ľoe  ĽńĀ.
\q1 
\v 8 ‚ÄĆ ĽE ngaahi  Ľofefine  Ľo SelŇęsalema,  Ľoku ou fekau kiate kimoutolu,
\q2  Ľoka mou ka  Ľilo  Ľa hoku  Ľofa Ľanga,
\q2 ke mou tala ki ai  Ľoku ou pongia  Ľi he  Ľofa.
\q1 
\v 9 Ko e hńĀ hono lelei hake  Ľo ho  Ľofa Ľanga  Ľi he  Ľofa Ľanga  Ľo ha taha kehe,
\q2  Ľa koe  Ľoku fungani hoihoifua  Ľi he kakai fefine?
\q1 ko e hńĀ hono lelei hake  Ľo ho  Ľofa Ľanga  Ľi he  Ľofa Ľanga  Ľo ha taha kehe,
\q1 koe Ľuhi kuo ke fekau pehńď ai kiate kimautolu.
\q1 
\v 10 ‚ÄĆ ĽOku hinehina mo nganongano  Ľa hoku  Ľofa Ľanga,
\q2 ko e fungani toulekeleka ia  Ľi ha toko mano.
\q1 
\v 11 ‚ÄĆ ĽOku tatau mo e fungani koula lelei  Ľa hono  Ľulu,
\q2  Ľoku fafatu hono lou Ľulu, pea  Ľuli Ľuli  Ľo hangńď ko e leveni.
\q1 
\v 12 ‚ÄĆ ĽOku lelei  Ľae  Ľai Ľanga  Ľo hono kano Ľi mata,
\q2 pea  Ľoku hangńď ko e mata  Ľoe lupe  Ľi he ve Ľe vaitafe kuo fufulu  Ľaki  Ľae hu Ľahuhu.
\q2 
\v 13 ‚ÄĆ ĽOku tatau hono kou Ľahe mo e tokanga ngoue  Ľoe ngaahi kakala;
\q2  Ľo hangńď ko e ngaahi matala Ľi kakala:
\q2  Ľoku hangńď ko e lile  Ľa hono loungutu,
\q2  Ľoku to Ľi mei ai  Ľae mula namu kakala.
\q2 
\v 14 ‚ÄĆ ĽOku tatau hono nima mo e ngaahi mama koula kuo  Ľai ki ai  Ľae pelili,
\q2 mo hono sino  Ľoku hangńď ko e lei ngingila kuo  Ľaofi  Ľaki  Ľae safaia.
\q1 
\v 15 ‚ÄĆ ĽOku tatau hono va Ľe mo e pou maka lelei, kuo fokotu Ľu ki he tu Ľunga koula:
\q2  Ľoku hangńď ko Lepanoni  Ľa hono fofonga,  Ľo tatau mo e ngaahi sita  Ľa hono lelei.
\q1 
\v 16 ‚ÄĆ ĽOku melie lahi hono ngutu:
\q2  Ľio,  Ľoku toulekeleka kotoa pńď ia.
\q2 Ko hoku  Ľofa Ľanga eni,
\q2 pea ko hoku kńĀinga ia,
\q2  ĽE ngaahi  Ľofefine  Ľo SelŇęsalema.
\c 6
\cd \it 1  ĽOku fakahńĀ  Ľe he siasi  Ľa  Ľene tui kia Kalaisi. 4  ĽOku fakamatala  Ľe Kalaisi  Ľae lelei  Ľo hono siasi,  Ľio pea mo  Ľene  Ľofa ki ai.\it*
\p 
\v 1 Kuo  Ľalu ki fńď ho  Ľofa Ľanga,  Ľa koe  Ľoku hoihoifua  Ľi he kau fefine kotoa pńď?
\q2 Kuo  Ľalu ki fńď  Ľaia  Ľoku ke  Ľofa ai? Koe Ľuhi ke tau kumi ia mo koe.
\q1 
\v 2 Kuo  Ľalu hifo  Ľa hoku  Ľofa Ľanga ki he Ľene ngoue,
\q2 ki he potu ngoue  Ľoe ngaahi kakala,
\q2 ke ne kai  Ľi he ngoue, mo ne toli  Ľae ngaahi lile.
\q1 
\v 3 ‚ÄĆ ĽOku  Ľo hoku  Ľofa Ľanga  Ľa au, pea  Ľoku  Ľo Ľoku  Ľa hoku  Ľofa Ľanga:
\q2  Ľoku ne kai  Ľi he lotolotonga  Ľoe ngaahi lile.
\p 
\v 4 ¬∂  ĽOku ke hoihoifua,  Ľa koe  Ľoku ou  Ľofa ai,  Ľo hangńď ko Telisa,
\q2 pea matamatalelei  Ľo hangńď ko SelŇęsalema,
\q2 pea manavahńď Ľia  Ľo hangńď ko e matatau mo  Ľenau ngaahi fuka.
\q1 
\v 5 Ke  Ľoua na Ľa sio mai ho mata kiate au he  Ľoku ou vaivai ai:
\q2  Ľoku tatau ho lou Ľulu mo e fanga kosi  Ľoku fafanga  Ľi Kiliati.
\q1 
\v 6 ‚ÄĆ ĽOku tatau ho kaunifo mo e fanga sipi  Ľoku  Ľalu hake mei he kaukau Ľi,
\q2 he  Ľoku taki  Ľuhiua  Ľa honau  Ľuhiki,
\q2 pea  Ľoku  Ľikai ke pa Ľa ha taha  Ľi ai.
\q1 
\v 7 ‚ÄĆ ĽOku tatau ho manifinifihanga mo e konga pomikanite  Ľoku fakalilo  Ľaki ho lou Ľulu.
\q1 
\v 8 ‚ÄĆ ĽOku ai  Ľae tu Ľi fefine  Ľe toko onongofulu, mo e sinifu  Ľe toko valungofulu,
\q2 mo e kau tńĀupo Ľou ta Ľefa Ľalaua.
\q1 
\v 9 Ka  Ľoku taha pe  Ľa  Ľeku lupe,  Ľa  Ľeku haohaoa,
\q2 ko e ta Ľahine pe taha ia  Ľa  Ľene fa Ľńď,
\q2 pea ko e pele  Ľa Ľana na Ľa ne fanau Ľi ia.
\q1 Na Ľe mamata ki ai  Ľae ngaahi  Ľofefine  Ľonau fakaongolelei ia,
\q2 pea na Ľa mo e ngaahi tu Ľi fefine mo e sinifu foki kuo nau lea fakamńĀlŇć ki ai.
\b
\q1 
\v 10 Ko hai eni  Ľoku hńĀ mai  Ľo hangńď ko e pongipongi,
\q2  Ľoku faka Ľofo Ľofa  Ľo hangńď ko e mńĀhina,
\q2  Ľoku ulo  Ľo hangńď ko e la ĽńĀ,
\q2 pea manavahńď Ľia  Ľo hangńď ko e matatau mo  Ľenau ngaahi fuka.
\b
\q1 
\v 11 Ne u  Ľalu hifo ki he ngoue natimeki
\q2 ke u mamata ki he ngaahi fua  Ľoe  Ľakau  Ľi he tele Ľa,
\q2 koe Ľuhi ke u  Ľilo pe  Ľoku tupu lelei  Ľae vaine,
\q2 pea fatakau  Ľae ngaahi pomikanite.
\q1 
\v 12 Pea  Ľiloange kuo fakafokifńĀ na Ľe puna hoku laumńĀlie,
\q2  Ľo hangńď ha taha kuo heka ki he ngaahi saliote  Ľo  ĽAminatipa.
\q1 
\v 13 Ke ke tafoki mai, tafoki mai,  ĽE fefine Sulami;
\q2 tafoki mai, tafoki mai, ka mau mamata kiate koe.
\q1 Ko e hńĀ  Ľoku mou fie mamata ai ki he fefine Sulami?
\q2 Ke mau mamata  Ľo hangńď ko e kau taha  Ľae matatau  Ľe ua.
\c 7
\cd \it 1 Ko e toe fakamatala,  Ľae hoihoifua  Ľoe siasi. 10  ĽOku fakahńĀ  Ľe he siasi  Ľa  Ľene tui mo  Ľene holi.\it*
\p 
\v 1 ‚ÄĆ ĽE  Ľofefine  Ľoe tu Ľi! Hono  Ľikai faka Ľofo Ľofa ho va Ľe mo ho topuva Ľe:
\q2  Ľoku teu Ľi lahi ho kofu va Ľe,
\q2 ko e ngńĀue  Ľae nima  Ľoe tufunga poto.
\q1 
\v 2 Ko e fakama Ľu  Ľo ho no Ľotanga kofu  Ľoku hangńď ha ipu,
\q2  Ľoku  Ľikai masiva uaine:
\q2 pea  Ľoku tatau ho sino mo e u uite,
\q2 kuo nono Ľo  Ľaki  Ľae ngaahi lile.
\q1 
\v 3 ‚ÄĆ ĽOku tatau ho ongo huhu mo e ongo kńĀseli,
\q2 mui  Ľoku na tatau.
\q1 
\v 4 ‚ÄĆ ĽOku tatau ho kia mo ha fale lei  Ľoku mńĀ Ľolunga:
\q2 pea tatau ho mata mo e anovai ika  Ľi Hesiponi,  Ľi he ve Ľe matapńĀ  Ľo Patalapini:
\q2  Ľoku tatau ho ihu mo e fale le Ľo  Ľi Lepanoni  Ľoku hanga ki Tamasikusi.
\q1 
\v 5 ‚ÄĆ ĽOku tatau ho  Ľulu mo Kameli,
\q2 mo e lou Ľulu  Ľo ho  Ľulu  Ľoku hangńď ko e kulokula;
\q2 kuo mo Ľua  Ľae tu Ľi  Ľi he ngaahi potu  Ľi fale.
\q1 
\v 6 Oiau, hono  Ľikai hoihoifua mo faka Ľofo Ľofa koe,
\q2  Ľa koe ko hoku  Ľofa Ľanga koe Ľuhi ke u fiemńĀlie ai!
\v 7 ‚ÄĆ ĽOku tatau ho mńĀ Ľolunga mo e  Ľakau ko e paame,
\q2 pea hangńď ho ongo huhu ko e ngaahi fuhi vaine.
\q1 
\v 8 Na Ľaku pehńď, ‚ÄúTe u kaka  Ľi he  Ľakau ko e paame,
\q1 pea u puke ki hono ngaahi va Ľa:‚ÄĚ
\q1 pea ko eni foki,  Ľoku tatau ho huhu mo e ngaahi fuhi vaine,
\q2 mo e ngangatu  Ľo ho mńĀnava  Ľo hangńď ko e moli;
\q1 
\v 9 ‚ÄĆ ĽOku tatau  Ľae ngaahi lea mei ho ngutu mo e uaine lelei  Ľoku hu Ľamelie:
\q2 he na Ľa mo kinautolu  Ľoku mohe  Ľoku fakalea ai.
\q1 
\v 10 ‚ÄĆ ĽOku  Ľo hoku  Ľofa Ľanga au, pea  Ľoku ne holi pe kiate au.
\q1 
\v 11 Ha Ľu,  ĽńĀ hoku  Ľofa Ľanga, ke ta Ňć atu ki he ngoue;
\q2 ke ta nofo  Ľi he ngaahi potu kakai.
\q1 
\v 12 Ke ta Ňć hengihengi ki he ngaahi ngoue vaine;
\q2 ke ta mamata ki he vaine  Ľi he Ľene tupu lelei,
\q2 mo e tupu  Ľo hono fua mui,
\q2 pea mo e fatakau  Ľoe pomikanite:
\q2 pea te u foaki  Ľi ai  Ľa  Ľeku  Ľofa kiate koe.
\q1 
\v 13 ‚ÄĆ ĽOku nanamu  Ľae tutai,
\q2 pea  Ľoku ai  Ľae ngaahi fua lelei  Ľi hota ve Ľe matapńĀ,
\q2 kuo u tńĀnaki koe Ľuhi ko koe,  ĽE hoku  Ľofa Ľanga.
\c 8
\cd \it 1 Ko e  Ľofa  Ľae siasi kia Kalaisi. 6 Ko e fakamńĀtoato  Ľoe  Ľofa. 8 Ko e ui  Ľoe kakai Senitaile. 14  ĽOku kole  Ľae siasi ke hńĀ Ľele mai  Ľa Kalaisi.\it*
\p 
\v 1 ‚ÄĆ ĽAmusiaange  Ľeau kuo ke tatau mo ha tuonga Ľane kiate au,
\q2  Ľaia na Ľe fakahuhu  Ľi he ongo huhu  Ľo  Ľeku fa Ľńď! Koe Ľuhi  Ľo kau ka  Ľilo koe  Ľitu Ľa.
\q2 ke u  Ľuma kiate koe,  Ľo  Ľikai mńĀ ai.
\q1 
\v 2 Ka ne pehńď, te u tataki koe mo  Ľomi koe ki he fale  Ľo  Ľeku fa Ľńď,
\q2 pea te ne ako kiate au:
\q2 te u fakainu koe  Ľi he uaine namu lelei,
\q2 kuo hu Ľi  Ľaki  Ľeau  Ľae huhu Ľa melie  Ľoe pomikanite.
\q1 
\v 3 Pea  Ľe  Ľi lalo  Ľi hoku  Ľulu  Ľa hono nima to Ľohema,
\q2 pea fńĀ Ľufua au  Ľe hono nima to Ľomata Ľu.
\q1 
\v 4 ‚ÄĆ ĽE ngaahi  Ľofefine  Ľo SelŇęsalema,
\q2  Ľoku ou fekau kiate kimoutolu, ke  Ľoua na Ľa mou ue Ľi pe fafangu  Ľa hoku  Ľofa Ľanga,
\q2 kae Ľoua ke fa Ľiteliha pe ia.
\q1 
\v 5 Ko hai eni  Ľoku ha Ľu mei he toafa,
\q2  Ľoku fa Ľaki kiate ia  Ľoku ne  Ľofa ai?
\b
\q2 Na Ľaku hiki hake koe  Ľi he lolo moli:
\q2 na Ľe fanau Ľi koe  Ľi ai  Ľe ho Ľo fa Ľńď,
\q2 na Ľe fanau Ľi  Ľi ai koe  Ľe ia na Ľa ne fńĀ Ľele Ľi koe.
\b
\q1 
\v 6 ‚ÄĆ ĽAi au ki ho loto  Ľo hangńď ko e fakama Ľu  Ľo ha tohi,
\q2 pea hangńď ko e mama ki ho nima;
\q2 he  Ľoku mńĀlohi  Ľae  Ľofa  Ľo tatau mo e mate;
\q2  Ľoku ongongata Ľa  Ľae fua Ľa  Ľo hangńď ko e fa Ľitoka:
\q2 ko hono malala  Ľoku hangńď ko e malala Ľi afi,
\q2  Ľaia  Ľoku ulo kakaha.
\q1 
\v 7 ‚ÄĆ ĽOku  Ľikai fa Ľa tńĀmate Ľi  Ľae  Ľofa  Ľaki  Ľae vai lahi,
\q2 pea  Ľe  Ľikai mate ia  Ľi he ngaahi vaitafe  Ľoku lahi:
\q1 pea kapau  Ľe foaki  Ľe ha tangata  Ľae koloa kotoa pńď  Ľi hono fale ka ne ma Ľu ai  Ľae  Ľofa,
\q2  Ľe lau pe ia ko e me Ľa va Ľinga.
\q1 
\v 8 ‚ÄĆ ĽOku ai homau tehina,
\q2 pea  Ľoku te Ľeki hunuki hono huhu:
\q1 pea ko e hńĀ te mau fai
\q2  Ľoka hoko  Ľae  Ľaho ke alea ki ai?
\q1 
\v 9 Kapau ko e  ĽńĀ ia,
\q2 te mau fokotu Ľu ki ai ha fale siliva:
\q2 pea kapau ko e matapńĀ ia,
\q2 te mau teuteu  Ľaki ia  Ľae laupapa ko e sita.
\q1 
\v 10 Ko au ko e  ĽńĀ, pea tatau mo e fale mńĀ Ľolunga  Ľa hoku huhu:
\q2 ko ia ia na Ľaku tatau ai  Ľi hono  Ľao mo ha taha kuo ma Ľu  Ľae fiemńĀlie.
\q1 
\v 11 Na Ľe ia Solomone  Ľae ngoue vaine  Ľi Peali-Hamone:
\q2 pea na Ľa ne tuku  Ľene ngoue vaine ki he kau tauhi:
\q2 pea na Ľe fekau ke  Ľomi taki taha  Ľae konga siliva  Ľe afe,
\q2 ko e totongi ki hono ngaahi fua.
\q1 
\v 12 ‚ÄĆ ĽOku  Ľi hoku  Ľao  Ľa  Ľeku ngoue vaine  Ľa Ľaku:
\q2 pea ko koe  Ľe Solomone, te ke ma Ľu mei ai  Ľae konga siliva  Ľe afe,
\q2 kae tuku kiate kinautolu  Ľoku tauhi hono fua  Ľae uangeau.
\q1 
\v 13 ‚ÄĆ ĽA koe  Ľoku nofo  Ľi he ngaahi ngoue,
\q2 pea  Ľoku ongo Ľi ho le Ľo  Ľe ho kńĀinga:
\q2 tuku au foki ke u fanongo ai.
\q1 
\v 14 Fai vave  Ľa hoku  Ľofa Ľanga,
\q2 pea ke tatau koe mo e kńĀseli pe ko e hainite mui he ngaahi mo Ľunga  Ľoe kakala. 
