\id JOB
\h Ioba
\toc1 Ioba
\toc2 Ioba
\toc3 Ioba
\mt1 Ioba
\c 1
\s1 KA BUKE
\q1 
\v 1 HE kanaka ma ka aina o Uza, o Ioba kona inoa, ua pono, ua pololei hoi ua kanaka la, a ua makau no ia i ke Akua, a hoopale i ka hewa.
\q1 
\v 2 Ua hanauia nana ehiku mau keikikane, a me na kaikamahine ekolu.
\q1 
\v 3 O kana waiwai, ehiku tausani hipa me na kao, ekolu tausani kamelo, elima haneri bipikaulua a elima haneri hoki wahine, a he nui loa kona poe ohua; nolaila, ua oi aku ke koikoi o keia kanaka mamua o na kanaka a pau o ka hikina.
\q1 
\v 4 A hele aku la kana mau keikikane, a ahaaina iho la ma ka hale, o kela mea keia mea o lakou i kona la; a hoouna aku la, a hea aku i ko lakou mau kaikuwahine ekolu, e ai pu a e inu pu me lakou.
\q1 
\v 5 A i ka manawa i hala ae ai na la o ka ahaaina ana, hoouna aku la o Ioba a hoomaemae ia lakou, a ala ae la i kakahiaka nui, a kaumaha aku la i na mohaikuni e like me ka nui o lakou a pau; no ka mea, i iho la o Ioba, Malia paha ua hana hewa ka'u mau keikikane, a ua olelo hoino i ke Akua ma ko lakou naau. Pela o Ioba i hana'i i na la a Pau.
\b
\q1 
\v 6 A i kekahi la, i ka manawa i hele ai na keiki a ke Akua e hoike aku ia lakou iho imua o Iehova, i hele mai hoi o Satana iwaena o lakou.
\q1 
\v 7 A i mai la o Iehova ia Satana, Nohea oe i hele mai nei? olelo aku la o Satana ia Iehova, Mai ka auwana ana ma ka honua, a mai ka hele ana io ia nei malaila.
\q1 
\v 8 I mai la o Iehova ia Satana, Ua noonoo pono anei oe i ka'u kauwa ia Ioba, aohe mea like me ia ma ka honua, he kanaka pono me ka pololei, ua makau i ke Akua, a ua hookaaokoa i ka hewa.
\q1 
\v 9 Alaila olelo aku la o Satana ia Iehova, i aku la, Ke makau kumu ole la anei o Ioba i ke Akua?
\q1 
\v 10 Aole anei oe i hoopuni ia ia, a me kona hale a me kona mea a pau i ka pa ma na aoao a pau? Ua hoopomaikai oe i ka hana a kona mau lima, a mahuahua kona waiwai ma ka aina.
\q1 
\v 11 Aka, e kikoo aku ano i kou lima, a hoopa i kana mau mea a pau, a e hoino no kela ia oe imua o kou maka.
\q1 
\v 12 Olelo mai la o Iehova ia Satana, Aia hoi, iloko o kou lima kana mau mea a pau; aka, maluna ona mai kau aku oe i kou lima. A hele aku la o Satana mai ke alo aku o Iehova.
\b
\q1 
\v 13 A i kekahi la, i ka manawa o kana mau keikikane a me kana mau kaikamahine e ahaaina ana, a e inu waina ana iloko o ka hale o ko lakou hanau mua;
\q1 
\v 14 Hele mai kekahi elele io Ioba la, i mai la, O na bipikauo e hoopalau ana, a o na hoki wahine e ai ana ma ko lakou aoao;
\q1 
\v 15 A popoi mai la ka poe Seba maluna o lakou, a lawe pio aku la i ia lakou; a pepehi iho la lakou i na kanaka opiopio me ka maka o ka pahikaua; a owau wale no ka i pakele e hai aku ia oe.
\q1 
\v 16 A i kana kamailio ana, hele mai kekahi, i mai la, Ua lele mai ke ahi a ke Akua mai ka lani mai, a ua ai iho i na hipa a me na kahu, a ua hoopau ia lakou; a owau wale no ka i pakele e hai aku ia oe.
\q1 
\v 17 A i kana kamailio ana, hele mai kekahi e ae, i mai la, Hoonohonoho iho la ka poe Kaledea i ekolu poe kaua, a lele mai lakou maluna o na kamelo, a lawe pio aku ia lakou, a pepehi iho la i na kauwa opiopio me ka maka o ka pahikaua; a owau wale no ka i pakele e hai aku ia oe.
\q1 
\v 18 I kana kamailio ana, hele mai kekahi e ae, i mai la, O kau mau keikikane, a me kau mau kaikamahine, e ai ana a e inu waina ana iloko o ka hale o ko lakou hanau mua:
\q1 
\v 19 Aia hoi, hiki mai la ka makani ikaika mai ka aoao o ka waonahele mai, a nou mai ma na kihi eha o ka hale, a hina iho la ia maluna o na kanaka opiopio, a ua make lakou; a owau wale no ka i pakele e hai aku ia oe.
\b
\q1 
\v 20 Alaila ku ae la o Ioba, a baehae iho la i kona aahu, a ako i kona poo, a hina ilalo i ka honua, a hoomana aku la,
\q1 
\v 21 I iho la, I hele kohana mai no au mai ka opu mai o ko'u makuwahine, a e hoi kohana aku au ilaila: na Iehova i haawi mai, na Iehova hoi i lawe aku; e hoomaikaiia ka inoa o Iehova.
\q1 
\v 22 Ma keia mea a pau, aole o Ioba i hana hewa, aole hoi ia i hooili wale aku i ka hewa i ke Akua.
\c 2
\b
\q1 
\v 1 A I kekahi la hoi i hele na keiki a ke Akua e hoike ia lakou iho imua o Iehova, o Satana hoi kekahi i hele mai iwaena o lakou e hoike ia ia iho imua o Iehova.
\q1 
\v 2 Olelo mai la o Iehova ia Satana, Nohea oe i hele mai nei? Olelo aku la o Satana ia Iehova, i aku la, Mai ka auwana ana ma ka honua, a mai ka hele ana io ia nei malaila.
\q1 
\v 3 Olelo mai la o Iehova ia Satana, Ua noonoo pono anei oe i ka'u kauwa ia Ioba, aohe ona like ma ka honua, he kanaka pono a me ka pololei, ua makau i ke Akua, a ua hookaaokoa i ka hewa? A i keia wa ke hoopaa iho nei ma kona pono, aka, ua koi mai oe ia'u e ku e ia ia, e pepehi hala ole ia ia.
\q1 
\v 4 A olelo aku ia o Satana ia Iehova, i aka ia, He ili no ka ili, o ka mea a pau a ke kanaka, oia kana e haawi aku ai no kona ola.
\q1 
\v 5 Aka, e kikoo aku oe i kou lima ano, a e hoopa aku i kona iwi a me kona io, a e hoino no oia ia oe imua o kou maka.
\q1 
\v 6 Olelo mai la o Iehova ia Satana, Aia no ia iloko o kou lima; e malama no nae oe i kona ola.
\b
\q1 
\v 7 A hele aku la o Satana mai ke alo aku o Iehova, a hahau aku la oia ia Ioba i na mai hehee ehaeha, mai ka poho o kona wawae a kona piko poo.
\q1 
\v 8 A lawe aku la ia i ka apana ipu lepo, a wauwau ia ia iho me ia; a noho iho la ia iloko o ka Iehuahi.
\b
\q1 
\v 9 Alaila olelo mai la kana wahine ia ia, Ke hoopaa nei anei oe ano ma kou pono? E hoino aku i ke Akua a make iho.
\q1 
\v 10 Aka, i aku la oia ia ia, Ke olelo mai nei oe e like me ka olelo a kekahi o na wahine naaupo. Eia, e loaa anei ia kakou ka maikai mai ke Akua mai, aole anei e loaa ia kakou ka ino kekahi? Ma keia mea a pao, aole o Ioba i hewa me kona mau lehelehe.
\b
\q1 
\v 11 A Iohe na makamaka ekolu o Ioba i keia ino i hiki mai maluna ona, hele mai kela mea keia mea mai kona wahi mai; o Elipaza no Temana, a o Biledada no Suha, a o Zopara no Naama: no ka mea, ua kuka pu lakou e halawai e uwe pu me ia a e hooluolu ia ia.
\q1 
\v 12 A nana ao la ko lakou mau maka iluna mai kahi mamao aku, aole hikou i ike ia ia, a hookiekie ae la lakou i ko lakou leo iluna, a auwe iho la; a haehae lakou o kela mea keia mea i kona aahu, a lulu i ka lepo maluna o ko lakou poo ma ka lani.
\q1 
\v 13 A noho pu iho lakou me ia ma ka lepo i na la ehiku a me na po ehiko, aole hoi i olelo iki aku kekahi o lakou ia ia: no ka mea, ike no lakou, ua nui loa kona ehaeha.
\c 3
\b
\q1 
\v 1 MAHOPE iho o keia, pane ae la ko Ioba waha, a hoino aku la ia i kona la.
\q1 
\v 2 Olelo mai la o Ioba, i mai la,
\q1 
\v 3 E poho wale iho ka la a'u i hanau ai,
\q1 A me ka po i oleloia, ua hapaiia he keikikane.
\q1 
\v 4 E lilo ua la la i pouli;
\q1 Mai manao ke Akua ia mai luna mai,
\q1 Aole hoi e alohi mai ka malamalama maluna ona.
\q1 
\v 5 E haukae ka pouli a me ka malu make ia la;
\q1 E kau ka naulu maluna ona;
\q1 E hooweliweli na wela o ka la ia ia.
\q1 
\v 6 A o ua po la, e lawe aku ka pouli ia ia;
\q1 Aole e hui pu ia oia me na la o ka makahiki;
\q1 Mai hookomoia oia iloko o ka helu ana o na malama.
\q1 
\v 7 Aia hoi, o ua po la, e hooneoneoia oia;
\q1 Aole e hookomoia ka leo olioli iloko ona.
\q1 
\v 8 Na lakou ia e hoino, na ka poe e hoino ana i ua la la,
\q1 Ka poe makaukau no ke kanikau ana.
\q1 
\v 9 E hoopouliia na hoku o kona wa molehulehu:
\q1 E kali aku ia i ka malamalama, a loaa ole;
\q1 Aole hoi ia e ike i ka wehe ana o ke alaula.
\q1 
\v 10 No ka mea, aole ia i hoopaa i na puka o ka opu o kuu makuwahine,
\q1 Aole hoi ia i huna i ka popilikia mai ko'u maka aku.
\b
\q1 
\v 11 No ke aha la i make ole ai au mai ka opu mai?
\q1 No ke aha la i kaili ole ia kuu ea i kuu puka ana mai ka opu mai?
\q1 
\v 12 No ke aha la i kokua ai na kuli ia'u?
\q1 No ke aha hoi na u, i omo aku ai au?
\q1 
\v 13 Alaila, ua moe iho au ano, a ua maluhia iho,
\q1 Ua hiamoe iho la au, alaila ua maha iho la au,
\q1 
\v 14 Me na'lii, a me na kuhina o ka honua,
\q1 Ka poe i kukulu i na wahi neoneo no lakou:
\q1 
\v 15 Me na keiki alii paha, ka poe mea gula,
\q1 Me ka poe i hoopiha i ko lakou mau hale i ke kala:
\q1 
\v 16 A, me he mea la i hanau i ka wa, ua ole au;
\q1 Me na keiki ike ole i ka malamalama.
\q1 
\v 17 Malaila e hooki ai ka poe hewa i ka hana kolohe ana;
\q1 Malaila hoi e hoomahaia'i ka poe i luhi o ka ikaika.
\q1 
\v 18 A e hoomaha pu ia'i hoi ka poe pio;
\q1 Aole lakou i lohe i ka leo o ka mea hooluhi.
\q1 
\v 19 O ka mea uuku, a me ka mea nui, aia no malaila;
\q1 A o ke kauwa, ua kaawale ia mai kona haku aku.
\b
\q1 
\v 20 No ke aha la i haawiia mai ai ka malamalama i ka mea popilikia,
\q1 A me ke ola i ka mea eha ma ka naau?
\q1 
\v 21 Ka poe e kali ana i ka make, aole i hiki mai,
\q1 A ua oi ko lakou eli ana ia mea, mamua o na waiwai i hunaia;
\q1 
\v 22 I ka poe hauoli nui me ka olioli,
\q1 I ka wa i loaa'i ia lakou ka luakupapau?
\q1 
\v 23 I ke kanaka i hunaia kona aoao,
\q1 I ka mea a ke Akua i hoopuni ai?
\q1 
\v 24 No ka mea, ua hiki pu mai ko'u kaniuhu ana me kuu ai ana,
\q1 A ua nininiia'ku ko'u uwe ana e like me na wai.
\q1 
\v 25 No ka mea, ua makau au i ka mea makau, a ua hiki mai ia maluna o'u,
\q1 A o ka mea a'u i weliweli ai ua hele mai ia io'u nei.
\q1 
\v 26 Aole au i pomaikai, aole hoi i oluolu,
\q1 Aole hoi i maha; aka, hiki mai ka popilikia.
\c 4
\b
\q1 
\v 1 A LAILA pane mai la o Elipaza no Temana, i mai la,
\q1 
\v 2 A i hoao makou e kamailio pu me oe, e uluhua anei oe? Aka, owai la ka mea hiki ke uumi i ka olelo?
\q1 
\v 3 Aia hoi; ua ao aku oe i na mea he nui, A ua hooikaika oe i na lima nawaliwali.
\q1 
\v 4 Ua kukulu iluna kau olelo i ka mea e hina ana, A ua hookupaa oe i na kuli e hemo ana.
\q1 
\v 5 Ano hoi, ua hiki mai ia maluna ou, a ua maule oe, Ua hoopa mai ia ia oe, a ua popilikia oe.
\q1 
\v 6 Aole anei keia kou makau, a me kou manaolana, O kou mea i kuko ai, a me ka pololei o kou mau aoao?
\b
\q1 
\v 7 Ke noi aku nei au, e hoomanao oe, owai ka mea hala ole i make wale? Auhea hoi ka poe pono i hookiia'ku?
\q1 
\v 8 E like me ka'u i ike ai, O na mea i waele ino, a mahi hewa, ohi no lakou ia mea hookahi.
\q1 
\v 9 Ma ka ha ana o ke Akua ua make lakou, A ma ka hanu o kona mau puka ihu ua hoopauia lakou.
\q1 
\v 10 O ka uwo ana o ka liona, o ka leo o ka liona hae, A o na niho o na liona hou, ua haki.
\q1 
\v 11 O ka liona, ua make ia no ka nele o ka mea pio, A o na keiki o ka liona wahine, ua hele liilii lakou.
\b
\q1 
\v 12 Ua lawe malu ia mai kekahi olelo ia'u, A ua loaa i kuu pepeiao ka lohe iki o ia mea.
\q1 
\v 13 Iloko o na manao ma na moeuhane i ka po, I ka manawa i pauhia ai na kanaka i ka hiamoe,
\q1 
\v 14 Hiki mai ka makau ia'u a me ka haalulu, A hoohaalulu mai ia i ka nui o ko'u mau iwi.
\q1 
\v 15 Alaila maale ae la he uhane imua o ko'u maka; Ku iho la iluna ka hulu o ko'u io:
\q1 
\v 16 Ku malie iho la ia, aole au i ike i kona ano; He kii imua o kou mau maka, He makani uuku, a he leo ka'u i lohe:
\q1 
\v 17 E oi anei ka pono o ke kanaka mamua o ko ke Akua? He oi anei ka maemae o ke kanaka mamua o ka Mea nana ia i hana?
\q1 
\v 18 Aia hoi, aole ia i hilinai i kana poe kauwa, A hooili no ia i ka hewa maluna o kona poe anela:
\q1 
\v 19 Heaha la hoi ka poe e noho ana i na hale lepo, Ha ka lepo ko lakou hookumu ana, ua ulupaia lakou imua o ka mu?
\q1 
\v 20 Ua lukuia lakou mai kakahiaka a ke ahiahi: Ua make loa lakou, aohe mea nana i manao.
\q1 
\v 21 Aole anei e nalo wale aku ko lakou maikai ana? Make no lakou me ka naauao ole.
\c 5
\b
\q1 
\v 1 E KAHEA ano, ina paha e pane mai kekahi ia oe; Io wai la o na mea laa e huli ai oe?
\q1 
\v 2 No ka mea, ke pepehi nei ka inaina i ka mea naaupo, A ke hoomake nei ka huhu i ka mea hawawa.
\q1 
\v 3 Ua ike au i ka mea naaupo e ulu ana; A hoino koke aku au i kona noho ana.
\q1 
\v 4 Ua mamao aku kana poe keiki i ka maluhia, Ua ulupaia lakou ma ka pukapa, Aohe mea nana e hoopakele.
\q1 
\v 5 O kana ai i ohiia ua pau i ka mea pololi, A ua lawe aku ia mea mailoko mai o na laau kuku, A kaili na powa i ko lakou waiwai.
\q1 
\v 6 No ka mea, aole e puka mai ka popilikia mai ka lepo mai, Aole hoi e kupu mai ka ehaeha mailoko mai o ka honua.
\q1 
\v 7 Aka, ua hanau ke kanaka no ka ehaeha, E like me na hunaahi i lele ae iluna.
\b
\q1 
\v 8 Aka e imi au i ke Akua, A i ke Akua e waiho aku i kuu olelo;
\q1 
\v 9 Oia ke hana i na mea nui, a hiki ole ke hoomaopopoia; I na mea kupaianaha, a hiki ole ke heluia:
\q1 
\v 10 Ka mea e haawi ana i ka ua maluna o ka honua, A e hoouna mai ana i na wai maluna o na kula.
\q1 
\v 11 E hookiekie iluna i ka poe i hoowahawahaia; I kaikaiia'i iluna i kahi malu ka poe e uwe ana.
\q1 
\v 12 Ke hookahuli nei oia i na manao o ka poe maalea, A hiki ole i ko lakou lima ke hooko i ko lakou mea i manao ai.
\q1 
\v 13 Ke hei aku nei oia i ka poe akamai iloko o ko lakou maalea; A ua hoohioloia ka manao o ka poe paakiki.
\q1 
\v 14 I ke ao halawai lakou me ka pouli, A ke hana nei lakou i ka wa awakea, e like me ia i ka po.
\q1 
\v 15 Aka, ke hoopakele no ia i ka poe ilihune mai ka pahikaua mai, mai ko lakou waha mai, A mai ka lima mai o ka mea ikaika.
\q1 
\v 16 Nolaila, ua loaa i ka mea hune ka manaolana, A ua hoopaa ka hewa i kona waha.
\b
\q1 
\v 17 Aia hoi, pomaikai ke kanaka a ke Akua i hoeha mai; Nolaila, mai hoowahawaha oe i ka hahau ana mai o ka Mea mana:
\q1 
\v 18 No ka mea, ke hoeha mai nei ia, a e lapaau mai hoi: Ke hahau mai nei oia, a e hoola mai hoi kona mau lima.
\q1 
\v 19 Iloko o na pilikia eono e hoopakele mai oia ia oe: A iloko o ka hiku hoi, aole e hoopa mai ka ino ia oe.
\q1 
\v 20 Iloko o ka wi e hoopakele mai oia ia oe i ka make; A iloko o ke kaua, mai ka lima o ka pahikaua mai.
\q1 
\v 21 E hunaia oe mai ke alelo hoino mai: Aole hoi oe e makau i ka luku, ke hiki mai.
\q1 
\v 22 I ka luku a i ka pololi e akaaka no oe: Aole hoi oe e makau i na holoholona hihiu o ka honua.
\q1 
\v 23 No ka mea, e noho kuikahi oe me na pohaku o ke kula; A e maluhia na holoholona hihiu o ke kula me oe.
\q1 
\v 24 A e ike no oe, he maluhia kou halelewa: A e nana no oe i kou hale, aohe mea nalo.
\q1 
\v 25 A e ike no oe, he nui kou hua, A o kau poe keiki, e like me ka weuweu o ka honua.
\q1 
\v 26 E hele auanei oe i ka luakupapau me ka ikaika nui, E like me na puu hua palaoa i kona manawa.
\q1 
\v 27 Aia hoi o keia ka makou i manao ai, pela io no; E hoolohe oe, a e ike oe ia mea pono nou.
\c 6
\b
\q1 
\v 1 OLELO mai la o Ioba, i mai la,
\q1 
\v 2 Ina paha e kaupaona pono ia kuu luuluu, A e kauia ma ka mea kaupaona kuu ehaeha!
\q1 
\v 3 No ka mea, ano, ua oi kona kaumaha mamua o ke one o ke kai: Nolaila, ua ilihia ka'u mau huaolelo.
\q1 
\v 4 No ka mea, o na pua pana o ka Mea mana, eia iloko o'u, A ke inu nei ka wela o ia mau mea i kuu uhane; O na mea weliweli o ke Akua, ke ku e mai nei ia'u.
\q1 
\v 5 E uwe anei ka hoki hihiu imua o ka weuweu? A ke uwo anei ka bipi maluna o kana mea ai?
\q1 
\v 6 E hiki anei ke aiia ka mea mananalo, ke ole ka paakai. He mea ono anei ke ewe o ka hua moa?
\q1 
\v 7 Aole au e hiki ke hoopa aku, Ua like ia me ka hoopailua o ko'u ai.
\b
\q1 
\v 8 Ina paha e haawiia mai kuu mea e noi aku ai, Ina paha e haawi mai ke Akua i kuu mea i kuko aku ai!
\q1 
\v 9 A ina paha e oluolu ke Akua e ulupa mai ia'u, Ina e hookuu mai ia i kona lima, a e oki mai ia'u!
\q1 
\v 10 Alaila e oluolu hou iho no wau, A e hauoli aku au i ka eha: Mai aua mai ia; no ka mea, aole au i hoole i na olelo a ka Mea Hemolele.
\q1 
\v 11 Heaha kuu ikaika, i kakali aku ai au? Heaha hoi kuu hope, i hooloihi aku ai au i kuu ola?
\q1 
\v 12 He ikaika anei ko'u e like me ka ikaika o na pohaku? He keleawe anei ko'u io?
\q1 
\v 13 Aole anei ka'u kokua iloko o'u? A ua holo aku anei ka mea e pakele ai mai o'u aku la?
\b
\q1 
\v 14 O ka mea ehaeha e alohaia oia e kona hoalauna; Aka, ua haalele aku ia i ka makau i ka Mea mana.
\b
\q1 
\v 15 Ua hana hoopunipuni mai ko'u mau hoahanau, e like me ke kahawai; Ua nalowale aku lakou, e like me ka wai kahe o na awawa;
\q1 
\v 16 I uliuli i ka waipaa, Malaila i hunaia'i ka hau.
\q1 
\v 17 I ka wa e ololi ai lakou, ua hoopauia lakou; I ke kau wela, ua maloo aku la mai ko lakou wahi aku.
\q1 
\v 18 Ua huli ae na huakai ma ko lakou ala ilaila; Hele lakou a nalowale, a pau.
\q1 
\v 19 Nana aku la, na huakai hele o Tema, A o na poe hele o Seba, i kakali aku ia lakou.
\q1 
\v 20 Ua hoka lakou, no ka mea, ua lana wale ka manao: Hele lakou ilaila, a hoohilahilaia lakou.
\q1 
\v 21 No ka mea, ua like oukou me ka mea ole; Ua ike oukou i ka popilikia, a makau iho la.
\q1 
\v 22 Ua olelo anei au, E lawe mai no'u? A e haawi mai i makana no'u mailoko mai o ko oukou waiwai?
\q1 
\v 23 A e hoopakele paha oukou ia'u mai ka lima mai o ka enemi? A e hoola ia'u, mai ka lima mai o ka poe ikaika?
\b
\q1 
\v 24 E ao mai oukou ia'u, a e noho malie iho au: E hoike mai oukou ia'u i kuu mea i lalau ai.
\q1 
\v 25 Nani ka ikaika o na olelo oiaio! Aka, heaha la ka ka oukou olelo hoino e hooiaio ai?
\q1 
\v 26 Ke manao nei anei oukou e hoohewa i na hua olelo? A o na olelo a ka mea paupauaho, Ua like me ka makani?
\q1 
\v 27 Oiaio, ke hoohina nei oukou i ka mea makua ole, A ke eli iho oukou i lua no ko oukou hoalauna.
\q1 
\v 28 Ano hoi, e noho malie oukou, e nana mai ia'u; No ka mea, ua akaka ia oukou, ke hoopunipuni au.
\q1 
\v 29 E hoi hou, ke noi aku nei au ia oukou, mai hoolilo ia i hewa; Oia e hoi hou hoi, A o ko'u pono aia iloko o ia mea.
\q1 
\v 30 He hewa anei iloko o kuu alelo? Aole anei au e ike i na mea hewa?
\c 7
\b
\q1 
\v 1 A OLE anei he kaua no ke kanaka ma ka honua? A like kona mau la me na la o ka mea hoolimalima?
\q1 
\v 2 E like me ke kauwa i makemake nui i ka malu, A me ka hoolimalima i nana i ka uku o kana hana;
\q1 
\v 3 Pela no e lilo mai ai ia'u na malama luuluu, A e loaa ia'u na po kaumaha.
\q1 
\v 4 A i ka wa i moe ai au ilalo, i iho no au, Ahea la au e ala'e iluna? Ahea la e hala'e ka po? Ua piha au i ka hiaa ana a hiki i ka wanaao.
\q1 
\v 5 Ua paapu ko'u kino i ka ilo a me ka papaa lepo; Ke ola mai nei kuu ili, alaila puha hou ae la.
\q1 
\v 6 Ua oi ka mama o kuu mau la mamua o ka laau ulana lole, A holo aku me ke manaolana ole.
\b
\q1 
\v 7 E hoomanao oe, he makani kuu ola: Aole e ike hou ko'u maka i ka maikai.
\q1 
\v 8 O ka maka o ka mea i ike ia'u, aole ia e ike hou ia'u: Maluna o'u kou mau maka, a e ole auanei au.
\q1 
\v 9 E like me ke ao e nalowale ana a e hele aku ana; Pela ka mea e iho ana i ka luakupapau, aole ia e ea hou ae iluna.
\q1 
\v 10 Aole ia e hoi hou i kona hale, Aole hoi e ike hou kona wahi ia ia.
\b
\q1 
\v 11 Nolaila aole au e hoopaa i kuu waha; E olelo aku au ma ka pilikia o kuu uhane; E ulono ana au no ka awaawa o kuu naau.
\q1 
\v 12 He kai anei au, a he ia nui, I hoonoho mai ai oe i ke kiai maluna o'u?
\q1 
\v 13 A i iho au, E hooluolu kuu wahi moe ia'u, E lawe aku kuu moe i ko'u ulono ana:
\q1 
\v 14 Alaila hoomakau mai oe ia'u ma na moeuhane, A hooweliweli mai oe ia'u i na mea hihio.
\q1 
\v 15 Nolaila ke koho nei kuu naau i ke kaawe, A me ka make mamua o kuu ola ana.
\q1 
\v 16 Ke hoopailua nei au ia mea; aole au makemake e ola loa; E waiho mai ia'u; no ka mea, he hanu wale no kuu mau la.
\q1 
\v 17 Heaha la ke kanaka, i hoonui mai ai oe ia ia? A i kau mai ai oe i kou manao ia ia?
\q1 
\v 18 A i ike mai ai oe ia ia i kela kakahiaka keia kakahiaka, A i hoao mau mai ai oe ia ia?
\q1 
\v 19 Pehea ka loihi o kou nana ole ana mai io'u aku nei, A kuu ole mai ia'u, a moni iho au i kuu kuha?
\q1 
\v 20 Ua hana hewa au; heaha ka'u e hana aku ai ia oe, E ka Meakiai i na kanaka? No keaha la oe e hooku ae ia'u, i mea e hopu ai nou, I lilo ai hoi au i mea kaumaha no'u iho?
\q1 
\v 21 No keaha la oe i kala ole mai ai i kuu hala, A i lawe aku hoi i ko'u hewa? No ka mea, ano e moe auanei au i ka lepo; A e imi mai oe ia'u, aole hoi wau.
\c 8
\b
\q1 
\v 1 A LAILA olelo mai la o Biledada, no Suha, i mai la,
\q1 
\v 2 Pehea la ka loihi o kau olelo ana i keia mau mea? A he makani ikaika na huaolelo o kou waha?
\q1 
\v 3 E hookahuli anei ke Akua i ka pololei? A e hookekee anei ka Mea mana i ka pono?
\q1 
\v 4 Ina paha ua hana hewa kau poe keiki ia ia, Alaila kiola aku la ia ia lakou, no ko lakou lawehala ana;
\q1 
\v 5 Ina e imi oe i ke Akua, A e nonoi aku oe i ka Mea mana;
\q1 
\v 6 Ina ua maemae oe a pono hoi; He oiaio no, ina ua ala mai no ia ano nou, A ua hoomalu mai ia i ka hale o kou pono ana.
\q1 
\v 7 Ina ua uuku kou hoomaka ana i kinohou, O kou hopena, e mahuahua loa ana no ia.
\b
\q1 
\v 8 No ka mea, ke noi aku nei au ia oe, e ninau aku oe i ka hanauna mamua, A e hoomakaukau oe e noonoo i ko lakou poe makua:
\q1 
\v 9 (No ka mea, inehinei wale no kakou, aohe ike, A o ko kakou mau la ma ka honua, he aka no ia:)
\q1 
\v 10 Aole anei lakou e ao mai ia oe, a e hai mai ia oe, A e hoike mai i na olelo mailoko mai o ko lakou naau?
\b
\q1 
\v 11 E ulu anei ke papuro ke ole ka lepo poho? E ulu anei ka akaakai ke ole ka wai?
\q1 
\v 12 I kona manawa uliuli, aole i okiia, Ua mae no ia mamua o na mauu e ae a pau.
\q1 
\v 13 Pela no ka hope o ka poe a pau e hoopoina ana i ke Akua; A pela no ka manaolana o ka aia e make ai.
\q1 
\v 14 O kona manaolana e okiia'ku ia, A o kona mea hilinai, he punawelewele no ia.
\q1 
\v 15 E hilinai iho oia maluna o kona hale, aka, aole ia e paa: E hoopaa aku oia ia mea, aole nae ia e kupono.
\q1 
\v 16 Ua uliuli oia imua o ka la, A kupu ae kona mau lala ma kona kihapai.
\q1 
\v 17 Ua awiliia kona mau aa ma ka waikahe, A ike iho la ia i kahi o na pohaku.
\q1 
\v 18 Aka, e hoopauia aku ia mea mai kona wahi aku, Alaila e hoole mai oia ia ia, aole au i ike ia oe.
\q1 
\v 19 Aia hoi, oia ka olioli o kona aoao, A mailoko mai o ka lepo e kupu ae na mea e.
\q1 
\v 20 Aia hoi, aole ke Akua e hoowahawaha i ka mea pono, Aole hoi ia e kokua aku i ka poe hana hewa:
\q1 
\v 21 A hoopiha mai ia i kou waha i ka akaaka, A i kou lehelehe i ka hooho olioli.
\q1 
\v 22 O ka poe inaina ia oe e hoaahuia lakou i ka hilahila: A e lilo ka hale o ka poe hewa i mea ole.
\c 9
\b
\q1 
\v 1 A LAILA olelo mai la o Ioba, i mai la,
\q1 
\v 2 Ua ike no au, he oiaio no: A, pehea la e hoaponoia'i ke kanaka imua o ke Akua?
\q1 
\v 3 Ina makemake oia e hoopaapaa me ia, Aole e hiki ke hoapono imua ona i kekahi hapa tausani.
\q1 
\v 4 He akamai ia ma ka naau, a ua nui ka ikaika: Owai la ka mea hoopaakiki ku e ia ia, a ua pomaikai?
\q1 
\v 5 Oia ka mea hoonee aku i na mauna, aole lakou i ike; Ka mea hoohiolo ia lakou ma kona inaina;
\q1 
\v 6 Ka mea hoonaue i ka honua mai kona wahi aku, A haalulu kona mau kukulu;
\q1 
\v 7 Ka mea olelo aku i ka la, aole ia i puka mai, A hoopaa aku hoi ia i na hoku;
\q1 
\v 8 O ka mea wale no nana i hohola na lani, A hele hoi maluna o na ale kiekie o ke kai;
\q1 
\v 9 O ka mea nana i hana o Uresa nui, me Oriona, A me Peleiade, a me ke kukuluhema loa aku;
\q1 
\v 10 O ka mea i hana i na mea nui hiki ole ke huliia; A me na mea kupanaha hiki ole ke heluia.
\q1 
\v 11 Aia hoi, maalo ae ia ma o'u nei, aole au i ike: Hele mai hoi oia, aka, aole au i hoomaopopo ia ia.
\q1 
\v 12 Aia hoi, lawe wale aku no ia, owai la ke pale aku ia ia? Owai la ka mea e olelo aku ia ia, Heaha kau e hana nei?
\b
\q1 
\v 13 I hoopau ole ae ke Akua i kona inaina, Kulou iho na kokua haaheo malalo ona.
\q1 
\v 14 Pehea la hoi wau e olelo aku ai ia ia, A e wae ae i na huaolelo imua ona?
\q1 
\v 15 Ina he pono ko'u, aole au e olelo aku ia ia, E nonoi aku no wau i kuu lunakanawai.
\b
\q1 
\v 16 Ina ua kahea aku au, a ua lohe mai kela; Aole au e hooiaio, na hoolohe mai ia i ko'u leo.
\q1 
\v 17 O ka mea e ulupa mai ia'u me ka ino, A hoonui wale mai ia i ko'u mau palapu.
\q1 
\v 18 Aole ia e ae mai ia'u e hanu i kuu hanu, Aka, hoopiha mai no ia ia'u i na mea awaawa.
\q1 
\v 19 Ina [e olelo iho au] no ka ikaika, aia hoi, oia ka ikaika: A ina no ka hooponopono ana, Owai la ke hai mai i ka manawa?
\q1 
\v 20 Ina owau e hoapono ia'u iho, hoohewa mai kuu waha ia'u; Ina [olelo iho au,] Ua hala ole, ina ua hookahuli mai ia ia'u.
\q1 
\v 21 Ina ua hala ole au, aole hoi au e ike i kuu uhane: E hoowahawaha no au i kuu ola.
\q1 
\v 22 Ua hookahi no ia, nolaila e olelo aku au, Ke luku nei no ia i ka mea hala ole a me ka mea hewa.
\q1 
\v 23 Ina e pepehi koke mai ka mea uhau, E akaaka mai no ia i ka eha ana o ka poe hala ole.
\q1 
\v 24 Ua haawiia'ku ka honua iloko o ka lima o ka poe hewa: Ua uhi mai ia i na maka o kona mau lunakanawai; A i ole ia, auhea la, owai la hoi oia?
\b
\q1 
\v 25 Ua oi ka mama o kuu mau la mamua o ka mea holo: Ke holo ae nei lakou, Ke ike ole nei lakou i ka maikai.
\q1 
\v 26 Ua hala aku la lakou e like me na moku holo: E like me ka aeto e lele ana i ka mea ai.
\q1 
\v 27 Ina olelo iho au, e hoopoina no wau i kuu kanikau ana, E waiho aku au i kuu maka kaumaha, a e hooluolu ia'u iho;
\q1 
\v 28 Makau iho la au i kuu mea ehaeha a pau, Ua ike au, aole oe e hoapono mai ia'u, he hala ole.
\q1 
\v 29 Ina ua hewa au, No ke aha la hoi wau e luhi make hewa nei?
\q1 
\v 30 Ina e holoi au ia'u iho i ka wai hau, A e hoomaemae au i kuu mau lima i ka sopa;
\q1 
\v 31 Alaila, e kiola iho oe ia'u iloko o ka lua lepo, A e hoopailua ko'u mau kapa ia'u.
\q1 
\v 32 No ka mea, aole ia he kanaka e like me au, e paio aku ai au ia ia, A halawai maua i ka hookolokolo ana.
\q1 
\v 33 Aole hoi he mea nana e uwao iwaena o maua, I kau mai ai ia i kona lima maluna o maua elua.
\q1 
\v 34 E lawe aku ia i kona kookoo mai o'u aku nei, A mai hooweliweli mai kona makau ia'u.
\q1 
\v 35 Alaila e olelo aku au, aole hoi wau e makau ia ia, Aka, aole pela wau ia'u iho.
\c 10
\b
\q1 
\v 1 U A uluhua ko'u naau i kuu ola ana; E waiho iho au i kuu ulono ana ia'u iho; E olelo aku au maloko o ka ehaeha o kuu naau.
\q1 
\v 2 E i aku au i ke Akua, Mai hoohewa mai oe ia'u; E hoike mai oe i ka mea au e hakaka mai nei me au.
\q1 
\v 3 He mea maikai anei ia oe, e hookaumaha, A e hoowahawaha i ka hana a kou lima, A e hoomalamalama ae maluna o ka manao o ka poe hewa?
\q1 
\v 4 O ko ke kino mau maka anei kou? Ua ike anei oe e like me ka ike ana a ke kanaka?
\q1 
\v 5 Ua like anei kou mau la me na la o ke kanaka? Ua like anei kou mau makahiki me na la o ke kanaka,
\q1 
\v 6 I ninau mai ai oe i kuu hala, A imi mai ai hoi i ko'u hewa?
\q1 
\v 7 Ma kou ike aohe o'u hewa; Aohe mea nana e hoopakele mai kou lima aku.
\b
\q1 
\v 8 Ua hana kou mau lima ia'u, A ua hoopaa mai oe ia'u a puni; Aka, ke luku mai nei oe ia'u.
\q1 
\v 9 Ke noi aku nei au ia oe e hoomanao, Ua hana mai oe ia'u, e like me ka lepo; A e hoihoi anei oe ia'u i ka lepo?
\q1 
\v 10 Aole anei oe i ninini iho ia'u me he waiu la, A i hoopaakiki mai hoi ia'u, me he waiupaa la?
\q1 
\v 11 Ua uhi mai oe ia'u i ka ili a me ka io, A ua hoopaa mai oe ia'u i na iwi a me na olona.
\q1 
\v 12 Ua hana mai oe iloko i ke ola a me ka pomaikai, A ua malama mai kou kiai ana i kuu uhane.
\q1 
\v 13 O keia mau mea kau i huna'i iloko o kou naau: Ua ike no wau, aia no me oe keia mea.
\q1 
\v 14 Ina e hana hewa au, alaila hoomanao mai no oe ia'u, Aole oe e kela mai ia'u, mai ko'u hewa aku.
\q1 
\v 15 Ina ua hewa au, auwe hoi wau; Ina ua pono au, aole wau e hookiekie i ko'u poo. Ua piha au i ka hilahila; A ua ike au i kuu poino;
\q1 
\v 16 Ina e hookiekieia auanei ia, Ke hoohalua nei oe ia'u, me he liona la: A hoike hou mai oe ia oe iho he mana maluna o'u.
\q1 
\v 17 Ke hoala hou nei oe i kou mau hoike ku e ia'u, A ke hoonui nei i kou inaina ia'u; A ke hoomahuahua mau nei na puali kaua ia'u.
\b
\q1 
\v 18 No ke aha la hoi oe i lawe mai ai ia'u, mai ka opu mai: Ina ua make au ilaila, A ua ike ole ka maka ia'u!
\q1 
\v 19 Ina ua like au me he mea ola ole la, Ina ua laweia'ku au mai ka opu aku, a ka luakupapau.
\q1 
\v 20 Aole anei he uuku ko'u mau la? U'oki pela, a e waiho ia'u, i oluolu iki iho ai au,
\q1 
\v 21 Mamua o kuu hele ana'ku i kahi aole au e hoi hou mai, I ka aina pouli, a me ka malu make;
\q1 
\v 22 He aina poeleele e like me ka pouli; He malu make, aohe mea i hooponoponoia, A o ka malamalama, ua like ia me ka pouli.
\c 11
\b
\q1 
\v 1 A LAILA olelo aku la o Zopara ka Naamata, i aku la,
\q1 
\v 2 Aole anei e pono ke pane aku i na huaolelo he nui la? E hoaponoia anei ke kanaka lehelehe wale?
\q1 
\v 3 E paa anei ka waha o kanaka i kou kaena wale ana? A hoomaewaewa mai oe, aole anei he mea nana oe e hoohilahila aku?
\q1 
\v 4 A ua olelo mai oe, he maemae kuu olelo, A ua hala ole au i kou mau maka.
\q1 
\v 5 Ina paha e olelo mai ke Akua, A e wehe ae i kona lehelehe ia oe;
\q1 
\v 6 A e hoike mai oia ia oe i na mea huna o ka naauao, Ua papalua ka maiau! Alaila e ike auanei oe, E hoopoina mai no ke Akua i na hewa ou.
\b
\q1 
\v 7 E loaa anei ia oe ka ke Akua mau mea hohonu? E loaa pololei loa anei ia oe ka Mea mana?
\q1 
\v 8 Ua kiekie ia e like me ka lani; heaha kau e hana ai? Ua oi kona hohonu i ko ka po; heaha kau e ike ai?
\q1 
\v 9 Ua oi kona loa mamua o ko ka honua, A o ka laula imua o ko ke kai.
\q1 
\v 10 Ina e hopu mai ia, a hoopaa iho, a hookolokolo, Alaila owai la ka mea e keakea ia ia?
\q1 
\v 11 No ka mea, ua ike no ia i ka poe hewa, Ua nana mai hoi ia i ka hala; Aole anei ia e ike mai?
\q1 
\v 12 E ake ke kanaka naaupo i akamai, O ke kanaka i hanau nae me he keiki la a ka hoki hihiu.
\b
\q1 
\v 13 Ina e hoomakaukau oe i kou naau, A e kikoo aku i kou mau lima io na la;
\q1 
\v 14 Ina he hewa iloko o kou lima, e hoolei loa aku ia; A mai ae e noho ka hewa ma kou mau halelewa.
\q1 
\v 15 Alaila e hoala ae oe i kou maka me ke kina ole; A e ku paa no oe, aole hoi e makau:
\q1 
\v 16 No ka mea, e hoopoina no oe i ka ehaeha, A e hoomanao ia mea, e like me ka wai i kahe aku:
\q1 
\v 17 A e kupaa kou ola loa ana, e like me ke awakea; Ano ua pouli oe, alaila e like no oe me ke kakahiaka.
\q1 
\v 18 A e maluhia oe, no ka mea, he mea no e laua ai ka manao; Ano ua poho ka manao, aka, alaila, e noho maluhia oe.
\q1 
\v 19 A e moe iho oe ilalo, aohe mea nana oe e hoomakau mai; A nui na mea e hoalohaloha imua ou.
\q1 
\v 20 Aka, e pio na maka o ka poe hewa, A ua nele lakou i ka puuhonua, A o ko lakou manaolana, o ke kuu ana no ia o ka uhane.
\c 12
\b
\q1 
\v 1 OLELO mai ia o Ioba, i mai la,
\q1 
\v 2 He oiaio, o oukou ka poe kanaka, A e make pu ka noiau me oukou.
\q1 
\v 3 Aka, he naauao ko'u e like me oukou; Aole au i emi malalo iho o oukou: A owai la ka mea ike ole i na mea like me keia mau mea?
\q1 
\v 4 Ua lilo au i mea heneheneia e kona hoalauna, E kahea ana i ke Akua, a hoolohe mai oia ia ia; O ka mea pono a me ka hala ole, ua akaakaia oia.
\q1 
\v 5 Me ka ipukukui i hoowahawahaia i ka manao o ka mea e noho nanea ana, Pela ka mea ua kokoke pahee kona mau wawae.
\b
\q1 
\v 6 Ua pomaikai na halelewa o ka poe luku wale, A ua noho maluhia ka poe hoonaukiuki aku i ke Akua; Iloko o ko lakou lima na ke Akua i haawi mai.
\b
\q1 
\v 7 Aka, ano e ninau i na holoholona, a e ao mai lakou ia oe; A me na manu o ka lewa, a e hoike mai lakou ia oe;
\q1 
\v 8 E olelo aku paha i ka honua, a e ao mai no ia ia oe: A o na ia o ke kai e hoakaka mai no lakou ia oe,
\q1 
\v 9 Owai la ka mea ike ole i keia mau mea a pau, Na ka lima o Iehova i hana keia?
\q1 
\v 10 Iloko o kona lima ka uhane o na mea ola a pau, A me ka hanu o na kanaka a pau.
\q1 
\v 11 Aole anei e hoao ke pepeiao i na olelo? A e hoao ka waha i ka ai nona iho?
\q1 
\v 12 Me ka poe kahiko ka maiau, A me ke ola loihi ka naauao.
\b
\q1 
\v 13 Ia ia ka naauao, a me ka ikaika; Nona ka oleloao, a me ke akamai.
\q1 
\v 14 Aia hoi, ke wawahi nei oia, aole e kukulu hou ia; Ke hahao aku ia i ke kanaka iloko, aole e hookuuia'ku.
\q1 
\v 15 Aia hoi, ke hoopaa nei oia i na wai, a ua maloo lakou: A hookuu aku oia ia lakou, a luku lakou i ko ka honua.
\q1 
\v 16 Me ia ka ikaika, a me ka naauao: Nona ka mea i hoopuniia, a me ka mea hoopuni.
\q1 
\v 17 Ua lawe pio aku ia i na kakaolelo, A hoolilo i na lunakanawai i poe hawawa.
\q1 
\v 18 Kala aku no ia i ka mea paa o na'lii, A kaei aku ia i ko lakou puhaka i ke kaei.
\q1 
\v 19 Alakai pio aku ia i na kahuna, A hookahuli i ka poe ikaika.
\q1 
\v 20 Hoopau aku ia i ka olelo a ka poe oiaio, A lawe aku ia i ka naauao, mai ka poe kahiko aku.
\q1 
\v 21 Ninini iho ia i ka hoino maluna o na'lii, A kala ae no ia i ke kaei o ka poe ikaika.
\q1 
\v 22 Hoike mai ia i na mea hohonu mailoko mai o ka pouli, A hoopuka no ia i ka malamalama mai ka malu make mai.
\q1 
\v 23 Hoomahuahua no ia i na lahuikanaka, a luku aku no hoi ia lakou: Hoonui aku no ia i na lahuikanaka, a hoemi hou iho ia lakou.
\q1 
\v 24 Lawe aku ia i ka naauao o na luna o kanaka ma ka honua; A hooauwana ia lakou ma ka waonahele, aohe alauui.
\q1 
\v 25 Haha lakou iloko o ka pouli aohe malamalama, A e hoohikaka aku oia ia lakou, me he mea ona la.
\c 13
\b
\q1 
\v 1 A IA hoi, ua ike ko'u maka i keia mea a pau, Ua lohe kuu pepeiao, a ua hoomaopopo hoi ia mea.
\q1 
\v 2 E like me ka oukou ike, pela no hoi ka'u e ike nei; Aole wau i emi iho malalo o oukou.
\b
\q1 
\v 3 Aka, e olelo aku no au i ka Mea mana, A ke ake nei au e olelo hoakaka pu me ke Akua.
\q1 
\v 4 A o oukou nae, he poe noonoo i ka wahahee, He poe kahuna lapuwale oukou a pau.
\q1 
\v 5 Ina paha e noho malie loa oukou! E lilo auanei ia i naauao no oukou.
\q1 
\v 6 E hoolohe oukou ano i kuu hoakaka ana, A e haliu mai i na paapaa ana o kuu mau lehelehe.
\q1 
\v 7 E olelo hewa anei oukou no ke Akua? A e kamailio wahahee anei oukou nona?
\q1 
\v 8 E nana anei oukou ma kona helehelena? E hakaka anei oukou no ke Akua?
\q1 
\v 9 He mea maikai anei e hulihuli mai oia ia oukou? A e like me ka ke kanaka e hoopunipuni ai i kekahi, Pela anei oukou e hoopunipuni ai ia ia?
\q1 
\v 10 E ao io mai no kela ia oukou, Ke nana malu oukou ma na helehelena.
\q1 
\v 11 Aole anei e hoomakau mai kona kiekie ia oukou? A e kau mai kona makau maluna o oukou?
\q1 
\v 12 Ua like ka oukou olelo akamai me ka lehu, A o ko oukou puukaua me ka puukaua lepo.
\b
\q1 
\v 13 E hamau oukou imua o'u, a e olelo aku au, A o ka mea e hele mai ana maluna o'u e hele mai no ia.
\q1 
\v 14 No ke aha la i lawe ai au i kuu io ma ko'u niho, A e waiho i kuu ola ma kuu lima?
\q1 
\v 15 Ina e pepehi mai oia ia'u, e hilinai no au ia ia, Aka, e hoapono aku au i kuu aoao imua ona.
\q1 
\v 16 E lilo hoi ia i ola no'u; No ka mea, aole e hele mai ka aia imua ona.
\q1 
\v 17 E hoolohe pono oukou i kuu wahi olelo, A me kuu hai ana'ku i ko oukou pepeiao.
\q1 
\v 18 Aia hoi ano, ua hoomakaukau au i kuu aoao; Ua ike au, e hoaponoia mai au.
\q1 
\v 19 Owai la ka mea e hoopaapaa pu me au? No ka mea, ano, e noho malie wau, a e make no.
\b
\q1 
\v 20 Aka, mai hana mai oe i na mea elua ia'u; Alaila aole au e huna ia'u iho mai ou aku la.
\q1 
\v 21 E hemo aku i kou lima mai o'u aku la: A mai hooweliweli mai kou makau ia'u.
\q1 
\v 22 Alaila e kahea mai oe, a eo aku au; A o olelo aku paha wau, a e olelo hou mai oe ia'u.
\q1 
\v 23 Ehia na hala o u a me na hewa? E hoike mai oe ia'u i kuu lawehala ana a me kuu hewa.
\q1 
\v 24 No ke aha la oe e huna ae ai i kou maka, A e manao mai ai ia'u he ememi nou?
\q1 
\v 25 E hooweliweli mai anei oe i ka lau i puhiia io ia nei? E alualu anei oe i ka opala maloo?
\q1 
\v 26 No ka mea, ke kakau nei oe i na mea awaawa ia'u, A ke hoopai mai nei oe ia'u i na hewa o kuu wa opio.
\q1 
\v 27 Ke hookomo nei oe i ko'u mau waewae ma ka laau kupee, A ke makai nei i ko'u mau aoao a pau: Ke kahakaha nei no oe a puni na kapawai o'u.
\q1 
\v 28 A ua hoopauia oia me ho mea popopo la, A me he lole la i aiia e ka mu.
\c 14
\b
\q1 
\v 1 O KE kanaka i hanauia e ka wahine. He hapa kona mau la, a ua piha i ka popilikia.
\q1 
\v 2 Puka mai no ia me he pua la, a ua okiia aku; A holo aku no ia me he aka la, aole ia e mau.
\q1 
\v 3 A ke kau anei oe i kou mau maka maluna o ka mea like me ia, A e lawe mai ia'u i ka hookolokoloia ana e oe?
\q1 
\v 4 Owai ka mea e unuhi ae i ka mea maemae mai o ka mea haumia? aole kekahi.
\q1 
\v 5 No ka mea, ua heluia kona mau la, A ia oe no ka huina o kona mau malama, Ua hoonoho oe i kona mau mokuna, i hiki ole ai ia ke ae aku;
\q1 
\v 6 E nana ae oe mai ona aku la, i hoomaha iho ai ia, A hauoli ia i kona ia, me he mea hoolimalima la.
\b
\q1 
\v 7 No ka mea, a i kuaia ka laau, He manao no nona, e ulu hou auanei, Aole hoi e pau na lala hou.
\q1 
\v 8 Ina ua elemakule kona aa ma ka honua, A ua make hoi kona kumu ma ka lepo;
\q1 
\v 9 Aka, no ka honi ana i ka wai e kupu ae ia, A e hookupu aku i na lala, me he laau kanu la,
\q1 
\v 10 Aka, o ke kanaka, e make no ia, a e nalowale aku; Oia, e make ana no ke kanaka, auhea la oia?
\q1 
\v 11 E like me ka maloo ana o na wai, mai ke kai aku, A me ka emi ana o ka muliwai, a maloo iho;
\q1 
\v 12 Pela e moe iho ai ke kanaka, aole ku hou ae; Aole lakou e ala hou mai, a pau aku na lani, Aole hoi e hooku hou ia, mai ko lakou hiamoe ana.
\b
\q1 
\v 13 E pono e waiho iho oe ia'u iloko o ka luakupapau, A e huna oe ia'u, a hala aku kou huhu, A e hoakaka mai no'u i ka manawa pono, a e hoomanao mai ia'u!
\q1 
\v 14 Ina e make ke kanaka, e ola hou anei oia? O na la a pau o ko'u kaua ana ka'u e kali ai, A hiki mai ko'u manawa.
\q1 
\v 15 E kahea mai oe ia'u, a e hoolohe aku no au ia oe: A e aloha mai no oe i ka hana a kou mau lima.
\q1 
\v 16 No ka mea, ano ke helu nei oe i kuu mau kapuwai; Aole anei oe e kiai mai nei i ko'u hewa?
\q1 
\v 17 Ua hoopaaia kuu hewa iloko o ka aa, Ua imi hala oe i kuu hewa.
\b
\q1 
\v 18 A he oiaio, o ka mauna e hiolo ana, moe mau no ia, A ua hooneeia ka pohaku mai kona wahi aku.
\q1 
\v 19 Ke anai nei na wai i na pohaku; O kona wai nui, ua hoopau aku ia i ka lepo o ka aina; Pela oe e hoomake nei i ka manaolana o ke kanaka.
\q1 
\v 20 Ke lanakila mau nei oe maluna ona, a hele aku no ia: Ke boopahaohao nei oe i kona maka, a hoouna aku ia ia.
\q1 
\v 21 Ua hoohanohanoia kana keiki, aole oia i ike: A ua hoohaahaaia lakou, aole ia i noonoo no lakou.
\q1 
\v 22 Aka, e hui kona io maluna ona, A e uwe kona naau iloko ona.
\c 15
\b
\q1 
\v 1 A LAILA olelo aku o Elipaza, no Temana, i mai la,
\q1 
\v 2 E hai aku anei ka mea naauao i ka manao makani? A e hoopiha i kona opu i ka makani hikina?
\q1 
\v 3 E ao aku anei ia me ka olelo pono ole? A me na olelo kokua ole mai?
\q1 
\v 4 Aka, ua hoole oe i ka makau, A ua hooemi iho oe i ka pule imua o ke Akua,
\q1 
\v 5 No ka mea, ke ao nei kou waha i kou hewa, A ke koho nei oe i ke alelo o ka poe maalea.
\q1 
\v 6 Ke hoohewa nei kou waha ia oe, aole owau; A ke hoike nei kou lehelehe ia oe.
\b
\q1 
\v 7 O oe anei ke kanaka makamua i hanau ai? Ua hanauia anei oe mamua o na puu?
\q1 
\v 8 Ua lohe anei oe ma ka ahaolelo a ke Akua? A ke hoopaa nei anei oe i ka naauao ia oe iho?
\q1 
\v 9 Heaha kau e ike nei, a ike ole makou ia? Heaha ka mea maopopo ia oe, aole hoi maloko o makou ia?
\q1 
\v 10 Me makou ke poohina a me ka mea kahiko, Ua oi aku ko lakou mau la mamua o ko kou makuakane.
\q1 
\v 11 He mea uuku anei ia oe na hooluolu o ke Akua? He mea huna anei kekahi ia oe?
\q1 
\v 12 No ke aha la e lawe aku nei kou naau ia oe? A i ke aha hoi kou mau maka e imoimo mai nei,
\q1 
\v 13 I hoohuli ae ai oe i kou naau e ku e i ke Akua, A e hoopuka ae ia mau huaolelo mai kou waha mai?
\q1 
\v 14 Heaha ke kanaka, i maemae ai oia? A o ka mea i hanauia e ka wahine, i pono ai oia?
\q1 
\v 15 Aia hoi, aole ia e hilinai i kona poe hemolele; Aole hoi i maemae na lani i kona mau maka.
\q1 
\v 16 He oiaio hoi, ua hoopailuaia, a ua haumia hoi ke kanaka, Ka mea e inu ana i ka hewa me he wai la?
\b
\q1 
\v 17 E hai aku au ia oe, o hoolohe mai ia'u; A o ka mea a'u i ike ai, oia ka'u e hoike aku ana;
\q1 
\v 18 Ka mea a ka poe naauao i hai mai, Aole hoi i huna, mai ko lakou poe makua mai:
\q1 
\v 19 No lakou wale no i haawiia ka honua, Aole i hele ka malihini iwaena o lakou.
\q1 
\v 20 I na la a pau, ua ehaeha ke kanaka hewa, A o ka huina o na makahiki, ua hunaia i ka mea hookaumaha.
\q1 
\v 21 He leo hooweliweli maloko o kona pepeiao; Iloko ia o ka pomaikai, A e hele mai ka mea luku maluna ona.
\q1 
\v 22 Aole ona manao e hoi hou mai, mailoko mai o ka pouli, A ua kakali oia i ka pahikaua.
\q1 
\v 23 E auwana no ia i ka imi ai, Auhea ia? A ke ike nei no ia, ua makaukau ka la o ka pouli, ua kokoke.
\q1 
\v 24 E hoomakau ke kaumaha, a me ka popilikia ia ia; E lanakila laua maluna ona, me he alii la i makaukau no ke kaua.
\q1 
\v 25 No ka mea, ua o ku e aku ia i kona lima i ke Akua, Ua hookiekie aku ia ia iho i ka Mea mana.
\q1 
\v 26 Wahi aku no ia maluna ona me ka a-i aa, Me ka manoa o na niho o kaua palekaua:
\q1 
\v 27 No ka mea, ua hoouhi oia i kona maka me ka momona, A kau no ia i ka momona maluna o na puupaa.
\q1 
\v 28 A noho iho no ia i na kulanakauhale neoneo, Iloko o na hale, aohe mea noho ilaila, Na mea i makaukau e lilo i mau puu.
\q1 
\v 29 Aole e hoolakoia oia, Aole hoi e mau kana waiwai, Aole hoi e hoopalahalaha i ka lakou loaa ma ka honua,
\q1 
\v 30 Aole ia e pakele mailoko mai o ka pouli; E hoomaloo ka lapalapa i kona mau lala, A e laweia'ku oia ma ka ha o kona waha.
\q1 
\v 31 O ka mea i puni, mai hilinai oia i ka mea lapuwale: No ka mea, e lilo ka lapuwale i uku nona.
\q1 
\v 32 Mamua o kona manawa, e okiia'ku ia, Aole e uliuli kona lala.
\q1 
\v 33 E like me ke kumu waina, e hoohelelei ia i kona huawaina pala ole, A e like me ka laau oliva, e hoohaule ia i kona pua.
\q1 
\v 34 No ka mea, e hua ole ka ohana a ka aia, A e hoopau ke ahi i na halelewa a ke kipe.
\q1 
\v 35 Hapai lakou, he kolohe, a hanau mai, he hewa; A noonoo ko lakou opu i ka wahahee.
\c 16
\b
\q1 
\v 1 A LAILA olelo mai la o Ioba, i mai la,
\q1 
\v 2 He nui na mea like a'u i lohe ai: He poe hooluolu hoopilikia oukou a pau.
\q1 
\v 3 He hope anei no na huaolelo makani? Heaha ka mea hoala mai nei ia oe, i olelo mai ai oe?
\q1 
\v 4 E hiki no ia'u ke olelo aku e like me ka oukou; Ina paha ua noho oukou ma ko'u wahi. E hiki no ia'u ke hookui i ka olelo ku e ia oukou; A e hooluliluli aku i ko'u poo ia oukou.
\q1 
\v 5 Aka, e hookupaa no au ia oukou me kuu waha, A o ka hooluolu ana o kuu lehelehe, e hoopaa aku no ia.
\b
\q1 
\v 6 Ina e olelo aku au, aole e oluolu kuu eha; Ina e noho malie hoi au, pehea ia e haalele ai ia'u?
\b
\q1 
\v 7 Aka, ano ua hooluhi mai ia ia'u; Ua luku mai oe i ko'u ohana a pau.
\q1 
\v 8 Ua hoopaa mai oe ia'u, i mea hoike; O kuu wiwi, ke ku mai no ia ia'u, A e hoike mai imua o kuu maka.
\q1 
\v 9 Ke haehae mai nei kona huhu, a ua inaina mai ia ia'u; Ke nau mai nei ia ia'u me kona mau niho; O kuu enemi, ke hookala nei ia i kona mau maka maluna o'u.
\q1 
\v 10 Ua hamama lakou maluna o'u me ko lakou waha; Ua papai lakou ia'u ma ka papalina me ka hoino: Ua hoakoakoaia lakou ma kahi hookahi e ku e ia'u.
\q1 
\v 11 Ua hoolilo ke Akua ia'u i ka poe hewa, A ua haawi ia'u iloko o ka lima o ka poe aia.
\q1 
\v 12 I noho maluhia la no wan, aka, ua ulupa mai nei ia ia'u; Ua lalau mai ia ma kuu a-i, a ulupa mai no ia ia'u, Ua hooku mai ia'u i hoailona nona.
\q1 
\v 13 Ua hoopuni kona poe panapua ia'u, Ua wahi mai ia i na puupaa o'u, aole e hookuu ae; Ua ninini iho ia i kuu au ma ka honua.
\q1 
\v 14 Ua wawahi roai ia ia'u, me ka wahi ana mahope o ka wahi ana, Ua lele mai ia maluna o'u me he mea ikaika la.
\q1 
\v 15 Ua humuhumu au i ke kapa ino maluna o kuu ili, Ua hoohaumia au i kuu pepeiaohao iloko o ka lepo.
\q1 
\v 16 Ua ulaula kuu maka i ka uwe ana, A maluna o ko'u mau lihilihi maka ke aka o ka make.
\q1 
\v 17 Aole no ka mea pono ole iloko o ko'u lima; A o ka'u pule, ua maemae hoi ia.
\b
\q1 
\v 18 E ka honua, mai uhi oe i ko'u koko, Aole hoi e haawi i wahi no kuu uwe ana.
\q1 
\v 19 Ano hoi, aia ma ka lani kuu mea ike maka, A o kuu mea hoike ma na wahi kiekie.
\q1 
\v 20 O kuu poe hoino, o ko'u mau makamaka no ia: Ke hu aku nei kuu maka i ke Akua.
\q1 
\v 21 Ina he mea e uwao me ke Akua no ke kanaka, E like me ke kanaka no kona hoalauna!
\q1 
\v 22 A hala he hapa na makahiki, Alaila e hele aku au i ke ala aole au e hoi hou mai.
\c 17
\b
\q1 
\v 1 U A paupauaho au, ua hookiia kuu mau la, Ua makaukau na halelua no'u.
\q1 
\v 2 Aole anei he poe olelo hoino me au? A ke kau nei kuu maka ma ko lakou hoonaukiuki ana?
\b
\q1 
\v 3 E waiho iho ano, e hana mai ia'u i malu me oe; Owai ka mea e pai i na lima me au.
\q1 
\v 4 No ka mea, ua hoohuna oe i ka naauao mai ko lakou naau aku; Nolaila, aole oe e hookiekie ia lakou.
\q1 
\v 5 O ka mea e kumakaia i kona mau hoalauna no ka waiwai pio, E hoopauia na maka o kaua poe keiki.
\b
\q1 
\v 6 Ua hooku mai oia ia'u i mea e olelo nane ia e na kanaka; A ua lilo au i mea hoopailua imua o lakou.
\q1 
\v 7 Ua ponalonalo kuu maka no ka uwe ana, A o kuu helehelena a pau ua like ia me ke aka.
\q1 
\v 8 E kahaha ka poe pono i keia, A e hooku e la mea hala ole i ka aia.
\q1 
\v 9 E hoomau no ka mea pono i kona aoao, A o ka mea lima maemae, e hoomahuahua aku ia i ka ikaika.
\q1 
\v 10 Aka, o oukou a pau, e hoi mai no, No ka mea, aole e loaa ia'u iwaena o oukou ka mea naauao.
\q1 
\v 11 Ua hala kuu mau la, ua okiia'ku kuu mau noonoo, O na manaolana o kuu naau.
\q1 
\v 12 Ua hoololi lakou i ka po i ao, O ka malamalama, ua pokole ia no ka pouli.
\q1 
\v 13 Ina e kakali aku au, O ka luakupapau ko'u hale: Ua hohola aku au i kuu wahi moe ma ka pouli.
\q1 
\v 14 Ua kapa aku au i ka palaho, O oe ko'u makuakane, A i ka ilo, O oe ko'u makuwahine, a me ko'u kaikuwahine.
\q1 
\v 15 Auhea hoi kuu manaolana? A o ko'u manaolana, owai la ka mea e ike aku ia?
\q1 
\v 16 E iho lakou i ua kaola o ka po, I ka wa e maha pu ana i ka lepo.
\c 18
\b
\q1 
\v 1 A LAILA olelo aku o Biledada, no Suha, i mai la,
\q1 
\v 2 Ahea la e hoopau oe i na huaolelo? E noonoo, a mahope iho e olelo aku makou.
\q1 
\v 3 No ke aha la e mauaoia makou, e like me ua holoholona, A ua haumia imua o kou mau maka?
\q1 
\v 4 Haehae no oia ia ia iho ma kona huhu: E haaleleia anei ka honua nou? A e hooneeia aku anei ka pohaku mai kona wahi aku?
\b
\q1 
\v 5 O ka malamalama o ka poe hewa e pio ana no ia, Aole hoi e hoomalamalama mai ka lapalapa o kona ahi.
\q1 
\v 6 O ka malamalama he pouli ia iloko o kona halelewa, A o kona kukui me ia, e pio no ia.
\q1 
\v 7 E hoopilikiaia kona hele ikaika, A e hookulaina kona noonoo ana ia ia.
\q1 
\v 8 No ka mea, ua hooheiia oia i ka upena ma kona wawae, A e hele ana no ia maluna o ka pahele.
\q1 
\v 9 E hoopaa ke kipuka ia ia ma ke kuekuewawae, E hanapaa hoi ke pahele ia ia.
\q1 
\v 10 Ua hunaia ma ka lepo ke pahele nona, A me ka upiki nona ma ke ala.
\q1 
\v 11 Ua hooweliweli na mea makau ia ia a puni, A e alualu ia ia ma kona wawae.
\q1 
\v 12 E nawaliwali kona ikaika no ka pololi, A e makaukau ka make ma kona aoao.
\q1 
\v 13 E ai no ia i na apana o kona ili, O ka hanau mua o ka make, e hoopau no ia i kona mau lala.
\q1 
\v 14 E kailiia kona mea i paa ai, mai kona halelewa aku, A e lawe aku no ia ia ia i ke alii weliweli.
\q1 
\v 15 E noho no ia mea iloko o kona halelewa, no ka mea, aohe nona ia; E luluia ka luaipele maluna o kona hale.
\q1 
\v 16 Malalo e maloo kona mau aa, A maluna e okiia'ku kona lala.
\q1 
\v 17 E nalowale kona hoomanaoia mai ka honua aku, Aole inoa nona ma ke alanui.
\q1 
\v 18 E hookuke aku lakou ia ia mai ka malamalama a i ka pouli, A e alualu ia ia mai ka honua aku.
\q1 
\v 19 Aohe ana keiki, aohe hoi mamo mawaena o kona poe kanaka, Aole hoi he mea i koe iloko o kona mau hale.
\q1 
\v 20 O na hanauna mahope e kahaha lakou no kona manawa, A loaa i na kupuna ka makau.
\q1 
\v 21 He oiaio, oia na wahi noho o ka poe hewa, A oia kahi o ka mea ike ole i ke Akua.
\c 19
\b
\q1 
\v 1 A LAILA olelo mai o Ioba, i mai la,
\q1 
\v 2 Pehea la ka loihi e hoeha mai ai oukou i kuu uhane, A e haihai mai ia'u ma na olelo?
\q1 
\v 3 Eia ka umi o ka oukou olelo ino mai ia'u; Aole oukou i hilahila, ke hookulikuli oukou ia'u;
\q1 
\v 4 Ina he oiaio, he lalau ko'u, Ke waiho nei me au kuu lalau ana.
\q1 
\v 5 Ina he oiaio, e hookiekie oukou e ku e ia'u, A e ao mai ia'u i kuu hoinoia:
\q1 
\v 6 E ike oukou ano, ua hookahuli mai ke Akua ia'u, A ua hoopuni mai ia'u i kana upena.
\b
\q1 
\v 7 Aia hoi, ke kahea aku nei au no ka hana ino ia, aole au i hooloheia mai; Ke hea nui aku nei an, aohe hooponopono.
\q1 
\v 8 Ua alalai mai ia i ko'u ala, aole au e hiki ke hele aku, A ua kau no ia i ka pouli ma kuu mau alanui.
\q1 
\v 9 Ua hao mai ia ia'u i kuu nani, Ua lawe hoi i ka leialii mai kuu poo aku.
\q1 
\v 10 Ua luku mai ia ia'u a puni, a ua pau hoi au; A ua uhuki ae ia i kuu manaolana, me he laau la,
\q1 
\v 11 Ua hoaa no ia i kona inaina ia'u, A ua manao no ia'u me kona poe enemi.
\q1 
\v 12 Hoakoakoaia kona poe koa, A hoouka ae lakou i ko lakou kuamoo ia'u, A hoomoana lakou a puni ko'u halelewa.
\b
\q1 
\v 13 Ua hoomamao aku ia i ko'u mau hoahanau mai o'u aku la, A o ko'u mau hoalauna, ua hoomaka e lakou ia'u.
\q1 
\v 14 Ua haalele kuu mau hoa pili ia'u, A o kuu poe makamaka, ua hoopoina lakou ia'u.
\q1 
\v 15 O ka poe e noho ana ma kuu hale, a me na kauwawahine a'u, manao mai lakou ia'u he malihini: He kanaka e no wau i ko lakou mau maka.
\q1 
\v 16 Kahea aku au i ka'u kauwa, aole ia e o mai; Nonoi aku au ia ia me kuu waha.
\q1 
\v 17 Ua ano e kuu hanu i ka'u wahine, A me kuu uwe ana i na keiki o kuu kino.
\q1 
\v 18 O na keiki liilii, hoowahawaha lakou ia'u; Ku no wau iluna, a olelo ku e mai lakou ia'u.
\q1 
\v 19 O na hoa kuka o'u a pau, ua hoopailua lakou ia'u; A o ka poe a'u i aloha i, ua huli lakou e ku e ia'u.
\q1 
\v 20 Ke pili nei kuu iwi i ko'u ili a me ko'u io, A ua pakele au me ka ili o ko'u mau niho.
\q1 
\v 21 E aloha mai ia'u, e aloha mai ia'u, e oukou ko'u poe makamaka; No ka mea, ua hahau mai ka lima o ke Akua ia'u!
\q1 
\v 22 No ko aha la oukou e hahai mai ai ia'u, me he Akua la, Aole hoi oukou i maona i kuu io?
\b
\q1 
\v 23 Ina paha ano e kakauia ka'u mau olelo! Ina e palapalaia lakou iloko o ka buke!
\q1 
\v 24 Me ka peni hao a me ke kepau, E kahakaha mau ia lakou iloko o ka pohaku!
\q1 
\v 25 No ka mea, ua ike au e ola ana kuu Mea hoola, A i ka wa mahope e ku no ia maluna o ka honua.
\q1 
\v 26 A mahope o kuu ili, e hoopau na ilo i keia kino, Aka, ma kuu io e ike aku au i ke Akua.
\q1 
\v 27 Oia ka'u e ike aku no'u iho, A e ike ko'u mau maka, aole ko hai; Ua kaniuhu kuu naau iloko o'u.
\q1 
\v 28 Aka, e olelo oukou, No ke aha kakou e hoomaau ia ia, No ka mea, ua loaa ko kumu o ka mea iloko o'u?
\q1 
\v 29 E makau oukou i ka pahikaua; No ka mea, o ka huhu, oia ka hewa no ka pahikaua, I ike oukou, he hoopai ana no.
\c 20
\b
\q1 
\v 1 A LAILA olelo aku la o Zopara, no Naama, i aku la,
\q1 
\v 2 O kuu mau manao ka mea e olelo aku ai au, A no kuu ikaika iloko o'u.
\q1 
\v 3 O ke ao ana o kuu hoinoia ka'u i lohe, A o ka uhane o kuu naauao, oia ka'u mea e pane aku nei.
\q1 
\v 4 Ua ike anei oe i keia, mai ka wa kahiko mai, Mai ka manawa i hoonohoia'i ke kanaka maluna o ka honua,
\q1 
\v 5 O ka olioli o ka poe hewa, he pokole ia, A o ka lealea o ka aia, no ka minute ia?
\q1 
\v 6 Ina e pii ae kona kiekie i na lani, A e hiki kona poo i na ao;
\q1 
\v 7 E nalo loa oia e like me kona lepo: E olelo nuanei ka poe i ike ia ia, Auhea oia?
\q1 
\v 8 E like me ka moeuhane e lele aku ia, aole e loaa oia: A e holo aku oia e like me ka hihio o ka po.
\q1 
\v 9 O ka maka i ike ia ia, aole ia e ike hou ia ia; Aole hoi e ike hou kona wahi ia ia.
\q1 
\v 10 E hoolaulea kana mau keiki i ka poe ilihune, A e hoihoi aku kona mau lima i ko lakou waiwai.
\q1 
\v 11 Ua piha kona mau iwi i kona opiopio, A e moe pu ia me ia ma ka lepo.
\b
\q1 
\v 12 Ina e ono ka hewa ma kona wana, A e huna ia mea malalo o kona alelo;
\q1 
\v 13 Ina e aua ia mea, a haalele ole ia, A e malama hoi ia mawaena konu o kona waha;
\q1 
\v 14 O ka ai iloko o kona naau e hoololiia, Oia ka mea make o na moonihoawa iloko ona.
\q1 
\v 15 Ua moni no ia i ka waiwai, A e luai hou aku no ia mea; Na ke Akua e hoohemo ia mea mai kona opu aku.
\q1 
\v 16 E omo no oia i ka mea make o na moonihoawa: O ke elelo o ka moomake e pepehi ia ia.
\q1 
\v 17 Aole ia e ike i ua kahawai, I na muliwai, me na kahawai o ka meli, a me ka waiu.
\q1 
\v 18 E hoihoi aku no ia i ka mea ana i luhi ai, aole ia e moni iho ia; E like me ka waiwai e hoihoiia'aku, aole ia e olioli ilaila.
\q1 
\v 19 No ka mea, na hookaumaha, ua haalele i ka poe ilihune; Ua lawe wale aku ia i ka hale ana i kukulu ole ai.
\b
\q1 
\v 20 No ia hoi, aole ia e ike i ka oluolu maloko o kona opu, Aole ia e hookoe i kana mea i makemake ai.
\q1 
\v 21 Aohe mea e koe no kana ai; Nolaila, aole he manaolana no kona pomaikai.
\q1 
\v 22 Ma ka nui ana o kona waiwai, e hiki ka popilikia ia ia; O kela lima keia lima o ka poino e hiki mai ia maluna ona.
\q1 
\v 23 I ka wa e hoopiha ai ia i kona opu, E hoolei mai no ko Akua i kona inaina maluna ona, A e hooua mai no ia maluna ona i kana ai ana.
\q1 
\v 24 E holo aku ia mai ka mea kana hao aku, E houia oia i ke kakaka keleawe.
\q1 
\v 25 Hukiia mai la ia a puka ae mai ke kino mai; A puka ae hoi ka pahikaua huali mai kona au mai; Maluna ona na mea weliweli.
\q1 
\v 26 Ua hoahuia ka poino a pau no kona waiwai; O ke ahi i hoa ole ia e hoopau ia ia; E popilikia ka mea o koe iloko o kona halelewa.
\q1 
\v 27 E hoike mai ka lani i kona hewa; E ku e mai ka honua ia ia.
\q1 
\v 28 O ka waiwai o kona hale, e nalowale ia, E uininiia aku ia i ka la o kona inaina.
\q1 
\v 29 Oia ka uku o ke kanaka hewa mai ke Akua mai, Oia kona hoilina i oleloia mai e ke Akua.
\c 21
\b
\q1 
\v 1 A OLELO mai la o loba, i mai la,
\q1 
\v 2 E hoolohe pono oukou i ka'u olelo, A o keia ko oukou hooluolu ana.
\q1 
\v 3 E ae mai oukou ia'u e olelo aku ai au, A mahope o kuu olelo, e hoomaewaewa oukou.
\q1 
\v 4 Owau hoi, i ke kanaka anei kuu ulono ana? A ina pela, no ke aha la ka huhu ole o kuu uhane?
\q1 
\v 5 E nana oukou ia'u a e pihoihoi, A e kau oukou i ka lima maluna o ka waha.
\q1 
\v 6 A ina e hoomanao wau, ua weliweli au, A loohia kuu io e ka haalulu.
\b
\q1 
\v 7 No ke aha la e ola ana ka poe hewa, E elemakule ana, e nui ana hoi i ka waiwai?
\q1 
\v 8 O ko lakou hua, ua hookupaaia me lakou imua o ko lakou alo, A o ka lakou poe keiki imua o ko lakou maka.
\q1 
\v 9 Ua maluhia ko lakou mau hale, aohe makau, Aole hoi ka laau hahau o ke Akua maluna o lakou.
\q1 
\v 10 Hapai no ka lakou bipi, aole hoi i hemahema; Hua mai no ka lakou bipiohi, aole i hanau hapa.
\q1 
\v 11 Kuu aku lakou i ka lakou poe kamalii me he kumu hipa la, A lelele no ka lakou poe keiki.
\q1 
\v 12 Hoomaka lakou me ka pahu kani a me ka lira, A olioli lakou i ke kani ana o ka hokiokio.
\q1 
\v 13 Noho lakou i ko lakou mau la me ka pomaikai, A iho koke lakou i ka po.
\q1 
\v 14 A olelo iho lakou i ke Akua, E hele oe mai o makou aku; A o ka ike i kou mau aoao, aohe makou makemake.
\q1 
\v 15 Owai ka Mea mana, i malama ai kakou ia ia? Heaha ka mea e loaa ai, ke nonoi kakou ia ia?
\q1 
\v 16 Aia hoi, aole ma ko lakou lima ko lakou pomaikai: O ke kuka ana o ka poe hewa, ua mamao aku ia ia'u.
\b
\q1 
\v 17 He pinepine i pio ai ke kukui o ka poe hewa, A e hiki koke mai hoi ko lakou make maluna o lakou, A ua hooili mai ia i na eha ma kona inaina.
\q1 
\v 18 Ua like lakou me ka mauu maloo imua o ka makani, E like hoi me ka opala a ka puahiohio i lawe aku.
\q1 
\v 19 Ua hoomau ke Akua i kona hewa no kana poe keiki: Ua uku mai ia ia ia, a e ike auanei oia.
\q1 
\v 20 E ike no kona maka i kona popilikia. E inu no ia i ka huhu o ka Mea mana.
\q1 
\v 21 No ka mea, heaha la kana hana iloko o kona hale mahope ona, I ka manawa e okiia'i mawaena ka huina o kona mau malama?
\q1 
\v 22 K ao mai anei kekahi i ke Akua i ka ike, I ka mea hooponopono i ka poe kiekie?
\q1 
\v 23 Make no kekahi iwaena o kona pomaikai, E noho nanea ana a me ka oluolu.
\q1 
\v 24 Ua piha kona mau aoao i ka momona, Ua mau kona mau iwi i ka lolo.
\q1 
\v 25 A make no kekahi me ka naau ehaeha, Aole ia i hoao i ka lealea.
\q1 
\v 26 E moe pu laua i ka lepo, A e paapu na ilo maluna o laua.
\b
\q1 
\v 27 Aia hoi, ua ike no wau i ko oukou mau noonoo ana, A me ko oukou mau manao a oukou i hoino ai ia'u.
\q1 
\v 28 No ka mea, ke olelo nei oukou, Auhea ka hale o ke alii? Auhea hoi ka uhi o na halelewa o ka poe hewa?
\q1 
\v 29 Aole anei oukou i ninau i ka poe e maalo ae ana ma ke ala? A ike ole anei oukou i ko lakou mau hoailona?
\q1 
\v 30 No ka mea, ua waihoia ka poe hewa no ka la popilikia, A e laweia mai lakou no ka la e inaina ai.
\q1 
\v 31 Owai ka mea e hoike aku i kona aoao imua ona? A owai ka mea e uku aku ia ia i kana mea i hana'i?
\q1 
\v 32 A e laweia aku oia i ka luakupapau, A e kiaiia oia ma ka hale kupapau.
\q1 
\v 33 E kau oluolu maluna ona na papaa lepo o ke awawa, A mahope ona e hahai aku na kanaka a pau, E like me ka poe mamua ona he lehulehu no.
\q1 
\v 34 A pehea la ko oukou hooluolu make hewa ana mai ia'u, A ua hewa ka oukou olelo ana mai?
\c 22
\b
\q1 
\v 1 A LAILA olelo aku o Elipaza, i aku la,
\q1 
\v 2 E hiki anei i ke kanaka, ke hoopomaikai i ke Akua, E like me ka mea naauao, e hoopomaikai ia ia iho?
\q1 
\v 3 He mea oluolu anei ke pono oe i ka Mea mana? A e waiwai anei oia ke hoohemolele oe i kou mau aoao?
\q1 
\v 4 No ka makau ia oe, e hoopaapaa mai anei ia ia oe? E hele mai anei ia me oe ma ka hooponopono ana?
\b
\q1 
\v 5 Aole anei he nui kou hewa? A ua hope ole kou mau hala?
\q1 
\v 6 No ka mea, ua hoopanai wale oe i kou hoahanau, A ua lawe oe i na aahu o ka poe kapa ole.
\q1 
\v 7 Aole oe i haawi i ka wai i ka mea nawaliwali, A ua ana oe i ka berena i ka mea pololi.
\q1 
\v 8 Aka, o ke kanaka ikaika, nona ka honua; A noho iho la ka mea koikoi ilaila.
\q1 
\v 9 Ua hoihoi nele aku oe i na wahinekanemake, A ua paopaoia na lima o na mea makua ole.
\q1 
\v 10 Nolaila ua puni oe i na pahele, A o ka makau wale ke hooweliweli mai nei ia oe;
\q1 
\v 11 A o ka pouli paha au i ike ole ai; A he nui loa ka wai e halana ana maluna ou.
\b
\q1 
\v 12 Aole anei ke Akua ma ka lani kiekie? Aia hoi, ke poo o na hoku, ua kiekie lakou.
\q1 
\v 13 A i mai la oe, Pehea la ke Akua e ike ai? E hiki anei ia ke hooponopono mawaena mai o ke ao pouli?
\q1 
\v 14 O na ao naulu ka uhi nona, i ike ole ai ia, A hele no ia ma ka poai o ka lani.
\q1 
\v 15 Ua noonoo pono anei oe i ka aoao kahiko, Kahi a ka poe hewa i hele ai?
\q1 
\v 16 Ka poe i noopauia mamua o ka manawa, Ua nininiia ke kaiakahinalii maluna o ko lakou kahua;
\q1 
\v 17 Ka poe i olelo aku i ke Akua, E hele mai o makou aku; A heaha ka ka Mea mana e hana mai ai no lakou?
\q1 
\v 18 Ua hoopiha no nae ia i ko lakou mau hale i ka waiwai; Aka. o ka manao o ka poe hewa ua mamao loa aku ia ia'u.
\q1 
\v 19 Ua ike no ka poe pono ia, a olioli, A akaaka ka poe hala ole ia lakou.
\q1 
\v 20 Ina paha ua lukuia ko makou poe enemi, A ua hoopauia ka waiwai nui o lakou i ke ahi.
\b
\q1 
\v 21 E hookuikahi ae me ia ano, a e pomaikai; Pela no e hiki mai ai ka pomaikai ia oe.
\q1 
\v 22 Ke koi aku nei au ia oe, E lawe oe i ke kanawai mai kona waha mai, A e waiho oe i kana mau olelo iloko o kou naau.
\q1 
\v 23 Ina e hoi hou oe i ka Mea mana, e kukuluia oe, E hoomamao loa aku oe i ka hewa mai kou mau halelewa aku.
\q1 
\v 24 A e hoolei aku oe i kou houlunlu ana i ke gula i ka lepo, A i ke gula Opira hoi i na pohaku o na kahawai
\q1 
\v 25 A o ka Mea mana kou gula, A me ke kala o na waiwai nou.
\q1 
\v 26 No ka mea, alaila e hauoli oe i ka Mea mana, A e hoala ae i kou maka i ke Akua.
\q1 
\v 27 E pule aku no oe ia ia, a e hoolohe mai ia ia oe, A e hooko aku oe i na mea au i hoohiki ai.
\q1 
\v 28 A e noonoo oe i kahi mea, a e hoopaaia oia nou; A e alohi mai ka malamalama maluna o kou mau ala.
\q1 
\v 29 A e hoohaahaaia lakou, alaila e olelo oe, He kiekie; A e hoola mai no ia i ka mea i kulou na maka.
\q1 
\v 30 E hoopakele no ia i ka mea lawe hala; A e hoopakeleia oia ma ka maemae o kou mau lima.
\c 23
\b
\q1 
\v 1 A LAILA olelo mai la o loba, i mai la,
\q1 
\v 2 I keia la hoi ua awaawa kuu ulono ana; Ua oi ke kaumaha o ka lima maluna o'u mamua o kuu kanikau ana.
\q1 
\v 3 Ina paha e ike au i kahi e loaa'i ia'u ia, E hele aku auanei au a kona wahi!
\q1 
\v 4 E hooponopono aku au imua ona i ko'u, A e hoopiha i ko'u waha i ka olelo hoakaka,
\q1 
\v 5 E ike au i na olelo ana e pane mai ai ia'u, A e manao i ka mea ana e olelo mai ai ia'u.
\q1 
\v 6 E paio anei ia me au me kona mana nui? Aole, aka, e manao mai no ia ia'u.
\q1 
\v 7 Malaila e paio ka mea pono me ia; A e hoopakele loa ia au mai kuu lunakanawai aku,
\b
\q1 
\v 8 Aia hoi, hele aku au ma ka hikina, aole ia malaila; A ma ke komohana, aole au e ike ia ia:
\q1 
\v 9 Ma ke kukuluakau, kahi ana i hana ai, aole au e nana ia ia; Ua hunaia oia ma ke kukuluhema, aka, aole au e ike ia ia:
\q1 
\v 10 No ka mea, ua ike no ia i ka aoao iloko o'u; Ke hoao nei ia ia'u, a e puka aku auanei au, me he gula la.
\q1 
\v 11 Ua hoopaa ko'u wawae i kona hele ana, Ua malama au i kona aoao, aole au i haalele.
\q1 
\v 12 Mai ke kauoha o kona mau lehelehe aku, aole au i hele; Ua malama au i na olelo a kona waha mamua o kuu haawina ai.
\q1 
\v 13 Aka, oia ka mea hookahi, a owai ke hoohuli ia ia? A o ka mea a kona naau e makemake ai, oia kana e hana'i
\q1 
\v 14 No ka mea, ua hana mai ia i ka mea i hoopaaia no'u: A nui na mea ia ia e like me ia.
\q1 
\v 15 Nolaila, ua haalulu au imua o kona alo; Noonoo iho la au, a makau ia ia.
\q1 
\v 16 Ke hoomakau mai nei ke Akua i kuu naau, A ke hooweliweli mai nei ka Mea mana ia'u;
\q1 
\v 17 No ka mea, aole i okiia aku au imua o ka pouli, Aole hoi i huna mai ia i ka pouli mai kuu maka aku.
\c 24
\b
\q1 
\v 1 NO ka mea, aole i hoonaloia na manawa mai ka Mea mana aku, No ke aha la aole ka poe ike ia ia e noonoo i kona mau la?
\q1 
\v 2 Hoonee aku lakou i na palena aina, A lawe wale aku lakou i ka poe hipa, a hanai aku ia lakou.
\q1 
\v 3 Alakai aku lakou i ka hokikane o ka poe makua ole; A lawe lakou i ka bipi a ka wahinekanemake i uku panai.
\q1 
\v 4 Ua kipaku lakou i ka poe nele mai ke ala aku; Pee pu aku la na ilihune o ka honua.
\q1 
\v 5 Aia hoi, me na hoki hihiu ma ka waonahele, hele aku lakou i ka lakou hana; E imi ana i ka mea pio; O ka waonahele oia ka ai na lakou, a na ka lakou poe keiki.
\q1 
\v 6 Ma ka mahinaai, oki kela mea keia mea i kana ai; A hoiliili lakou ma ka pawaina o ka mea hewa,
\q1 
\v 7 Waiho lakou i ka poe olohelohe i moe lakou me ka kapa ole, Aohe mea uhi iloko o ke anu.
\q1 
\v 8 Ua pulu lakou i ka ua nui o oa mauna, A no ka hale ole, ua pili lakou i ka pohaku.
\q1 
\v 9 Kaili lakou i ka mea makua ole mai ka u aku, A lawe lakou i ka aahu o ka ilihune i uku panei
\q1 
\v 10 Hoohele lakou i ka mea olohelohe me ke kapa ole, A lawe aku lakou i ka poa palaoa mai ka pololi;
\q1 
\v 11 Kaomi lakou i ka aila mawaena o ko lakou meu papohaku, Hahi lakou i na wahi kaomi waina, a makewai lakou.
\q1 
\v 12 Kunukunu na kanaka mai ke kulanakauhale aku, A o ka naau i houia ke kahea aku; Aole ke Akua i manao mai i ka mea lapuwale,
\b
\q1 
\v 13 O lakou ka poe e kipi ana i ka malamalama, Aole lakou i ike i kona mau kuamoo, Aole lakou i nobo ma kona mau alanui.
\q1 
\v 14 I ka malamalama ala mai ka pepehi kanaka, A pepehi aku i ka poe ilihune a me ka poe nele, A i ka po ua like ia me ka aihue.
\q1 
\v 15 Ke kali ae la ka make o ka mea moe kolohe i ke ahiahi poeleele, I iho la, Aole e ike mai ka make ia'u; A kau i ka pale ma ka make.
\q1 
\v 16 I ka pouli wawahi lakou i na hale, I ke ao hoopaa lakou ia lakou iho iloko: Aole lakou i ike i ka malamalama.
\q1 
\v 17 No ka mea, o kakahiaka, ua like pu ia no lakou me ka malu make; Ina ikeia, ua kau mai na mea weliweli o ka malu make.
\b
\q1 
\v 18 Ua like lakou me ka mea mama maluna o ka wai; Ua hoinoia ko lakou kuleana ma ka honua; Aole lakou e huli ae ma ke ala o na pawaina,
\q1 
\v 19 Na ka maloo a me ka wela e hoopau aku i na wai o ka hau; Pela no ka po i ka poe hana hewa.
\q1 
\v 20 E hoopoina ka opu ia ia; E ai wale ka ilo ia ia; Aole loa e hoomanaoia oia; A e haki ka mea hewa me he laau la.
\q1 
\v 21 Hookaumaha oia i ka mea pa hanau ole, Aole ia i hana maikai aku i ka wahinekanemake,
\q1 
\v 22 Lawe aku no ia i ka poe alii ma kona ikaika; A ka mai oia, aohe malu ke ola o kekahi.
\q1 
\v 23 Ina e haawiia none e maluhia, a e hilinai; Aka, o kona mau make aia maluna o ko lakou mau aoao.
\q1 
\v 24 Ua hookiekieia lakou i ka wa pokole, Aka, oa ole lakou, a ua hoonalowaleia lakou; E like me na mea a pau, ua hoiia lakou, Ua okiia lakou e like me na piko huhui palaoa.
\q1 
\v 25 Ina i ole pela ano, Owai la ka mea e hoike mai, he hoopunipuni ka'u, A e hoolilo i ka'u olelo i mea ole?
\c 25
\b
\q1 
\v 1 A LAILA olelo aku la o Biledada, no Suha, i aku la,
\q1 
\v 2 Ia ia no ke alii ana a me ka makaulia, A hana no ia i ke kuikahi ma kona mau wahi kiekie.
\q1 
\v 3 Ua heluia anei kona mau poe koa? A maluna owai la i puka ole mai ai kona malamalama?
\q1 
\v 4 A pehea la e hoaponoia'i ke kanaka imua o ke Akua? A pehea la e maemae ai ka mea i hanauia e ka wahine?
\q1 
\v 5 E nana i ka mahina, aole ia e aiai; A o na hoku aole e maemae imua o kona maka:
\q1 
\v 6 Pehea la hoi ke kanaka, he enuhe; A me ke keiki a ke kanaka, he ilo?
\c 26
\b
\q1 
\v 1 A LAILA olelo mai la o Ioba, i mai la,
\q1 
\v 2 Pehea la oe i kokua mai ai i ka mea nawaliwali? A hooikaika mai hoi oe i ka lima ikaika ole?
\q1 
\v 3 Pehea la oe i ao mai ai i ka mea ike ole? A hoike nui mai hoi oe i ka noeau?
\q1 
\v 4 Ia wai anei oe i hai aku i na olelo? Nowai ka hanu i puka ae mai ou mai la?
\b
\q1 
\v 5 O na mea i make, ua haalulu lakou mai lalo mai, O na wai a me kolaila poe e noho ana.
\q1 
\v 6 Ua ahuwale ka ka po imua ona, Aohe uhi no kahi o ka poe i make.
\q1 
\v 7 Ua hohola aku ia i ke kukuluakau maluna o ka neoneo, Ua kau aku i ka honua maluna o ka mea ole.
\q1 
\v 8 Ua hoopaa oia i na wai maloko o na ao ona, Aole i nahae ke ao malalo o lakou.
\q1 
\v 9 Ua uhi no ia i ke alo o kona nohoalii, Ua hohola aku i kona ao maluna ona.
\q1 
\v 10 Ua hoopuni oia i na wai i ka palena, A hiki i kahi e pau ai ka malamalama iloko o ka pouli.
\q1 
\v 11 O na kia o ka lani ua haalulu, A weliweli hoi i kona papa ana mai.
\q1 
\v 12 Ua hoomalielie oia i ke kai ma kona mana, A ma kona naauao, hahau iho ia i kona kiekie.
\q1 
\v 13 Ma kona Uhane ua hoonani oia i na lani; Na kona lima i hana i ka nahesa e lele ana.
\q1 
\v 14 Aia hoi, oia kekahi mau mea o kona mau aoao; Nani hoi ka uuku o ka mea i loheia nona! A o ka hekili o kona mana owai la ka mea e ike pono?
\c 27
\b
\q1 
\v 1 A OLELO hou mai la o Ioba i kana olelonane, i mai la,
\q1 
\v 2 Ma ke ola o ke Akua, nana i lawe aku kuu pono; A ma ka Mea mana, nana i hooawahia kuu uhane;
\q1 
\v 3 I ka manawa a pau o kuu hanu iloko o'u, A o ke ola o ke Akua iloko o kuu mau puka ihu;
\q1 
\v 4 Aole e olelo kuu lehelehe i ka hewa, A o kuu elelo aole e hoike aku i ka wahahee.
\q1 
\v 5 Aole loa wau e hoapono aku ia oukou, a make au; Aole owau e lawe aku i kuu pono mai o'u aku la.
\q1 
\v 6 Ma kuu pono ke hoopaa nei au, aole au e hookuu aku; Aole e hoino mai ia'u kuu naau i kekahi o kuu mau la.
\b
\q1 
\v 7 E hoohalikeia kuu enemi me ka mea hewa, A o ka mea ku e mai ia'u me he mea pono ole la.
\q1 
\v 8 No ka mea, heaha ka manaelana o ka aia, i ka wa e hoopau ai ia ia, I ku wa e kaili aku ai ke Akua i kona uhane?
\q1 
\v 9 E hoolohe mai anei ke Akua i kona auwe ana, I ka manawa e hiki mai ai ka popilikia maluna ona?
\q1 
\v 10 E hauoli anei ia i ka Mea mana? E kahea mau loa anei ia i ke Akua?
\b
\q1 
\v 11 E ao aku au ia oukou ma ka lima o ke Akua: Aole au e huna i ka mea me ka Mea mana.
\q1 
\v 12 Aia hoi, o oukou a pau, ua hoomaopopo oukou ia; No ke aha la oukou i manao lapuwale ai pela?
\b
\q1 
\v 13 Eia ka uku no ke kanaka hewa imua o ke Akua, O ka hooilina a ka poe hookaumaha e loaa'i, mai ka Mea mana mai.
\q1 
\v 14 Ina e hoonuiia kana poe keiki, no ka pahikaua no; A o kana poe mamo, aole e maona i ka berena.
\q1 
\v 15 O kona poe e koe ana, e kanuia i ka make: Aole hoi e kanikau kana mau wahinekanemake.
\q1 
\v 16 Ina e hoiliili oia i ke kala e like me ka lepo, A e hoomakaukau i ka lolekomo e like me ka palolo;
\q1 
\v 17 E hoomakaukau no, aka, na ka mea pono e hookomo, A o ke kala, na ka mea hala ole e puunaue.
\q1 
\v 18 Kukulu no ia i kona hale me he mu la, A e like me ke kamala a ke kiai i hana'i.
\q1 
\v 19 Moe iho ilalo ka mea waiwai, aole e kanuia; Wehe ae ia i kona maka, aole iho la ia.
\q1 
\v 20 Kau mai la na weliweli ia ia, e like me na wai, I ka po, lawe aku ka puahiohio ia ia.
\q1 
\v 21 Na ka makani hikina ia e lawe aku, a hele aku ia, A o ka ino e lawe ia ia mai kona wahi aku.
\q1 
\v 22 E hoolei aku [ke Akua] ia ia, aole ia e minamina: I ka holo ana, e holo no ia mai kona lima aku.
\q1 
\v 23 E pai lakou i ko lakou lima ia ia, A e kipaku ia ia mai kona wahi aku.
\c 28
\b
\q1 
\v 1 HE oiaio, he wahi ahu no ke kala, A he wahi no ke gula, kahi a lakou e hoomaemae ai.
\q1 
\v 2 Ua laweia ka hao mailoko mai o ka lepo, A ua hooheheeia ke keleawe mailoko mai o ka pohaku.
\q1 
\v 3 Hoonoho no ia i ka hope no ka pouli, A imi no ia ma na wahi hohonu a pau; I ka pohaku o ka pouli a me ka malu make.
\q1 
\v 4 Eli ae ia i lua mao aku mai kahi e noho ai na kanaka; Iho lakou ilalo aole ma ka wawae, A lewa lakou mai kanaka aku.
\q1 
\v 5 O ka honua, kahi i puka mai ai ka berena, Ua hoohuaiia oia malalo iho ona e like me ke ahi.
\q1 
\v 6 O kona mau pohaku, kahi o ka sapira; A he lepo gula kona.
\q1 
\v 7 O ke alanui aole i ikeia e ka manu, Aole i ikeia e ka maka o ka vuletura;
\q1 
\v 8 Aole i hehi iho na holoholona hihiu ia ia, Aole ka liona i maalo ae ilaila.
\q1 
\v 9 Kau aku no ia i kona lima maluna o ka pohakupaa; Hookahuli ae ia i na mauna mai ke kumu aku.
\q1 
\v 10 Hoopoha no ia i ke kahawai mawaena o na pohaku; A ike no kona maka i na mea waiwai nui a pau.
\q1 
\v 11 Pani aku no ia i na wai i ke kahe ana iho, A o na mea i hunaia kana i lawe mai ai i ka malamalama.
\b
\q1 
\v 12 Aka, mahea la e loaa'i ka noeau? Mahea hoi kahi o ka naauao?
\q1 
\v 13 Aohe kanaka i ike i kona kumukuai; Aole hoi e loaa ia ma ka aina o ka poe e ola ana.
\q1 
\v 14 I mai ka hohonu, Aole ia iloko o'u: I mai la hoi ke kai, Aole ia me au.
\q1 
\v 15 Aole e haawiia ke gula maikai i kumu e loaa mai ai, Aole hoi e kaupaona ke kala i kumukuai nona.
\q1 
\v 16 Aole e kau pu ia oia me ke gula o Opira, Me ka pohaku onika maikai a me ka sapira.
\q1 
\v 17 Aole e hoolikeia ke gula a me ka pohaku aniani me ia: Aole e hooliloia ia mea no na ipu gula maikai.
\q1 
\v 18 Aole e manaoia ke akoakoa, a me ka pohaku maikai: No ka mea, o ka waiwai o ka noeau ua oi aku ia mamua o na momi.
\q1 
\v 19 Aole e hoolikeia ke topaza o Aitiopa me ia, Aole hoi ia e kau pu ia me ke gula maikai.
\q1 
\v 20 Mai hea mai hoi ka noeau? A mahea hoi kahi o ka naauao?
\q1 
\v 21 No ka mea, ua hunaia oia mai na maka aku o ka poe a pau e ola ana, A ua nalo oia mai na manu o ka lewa aku.
\q1 
\v 22 I mai la ka po a me ka make, Ua lohe no maua me ko maua pepeiao i kona lono.
\b
\q1 
\v 23 Ua maopopo no i ke Akua kona aoao, A oia ka i ike i kona wahi.
\q1 
\v 24 No ka mea, oia ka i nana aku i na welau o ka honua, Ua ike no ia malalo o ka lani a pau;
\q1 
\v 25 E hana i ka mea kaupaona no ka makani, A ua ana no ia i na wai maloko o ka mea ana.
\q1 
\v 26 I kana hana ana i ke kanawai no ka ua, A me ke ala no ka uwila o ka hekili;
\q1 
\v 27 Alaila ike no oia ia mea, a hoike mai hoi ia; Hoomakaukau oia ia mea, a imi aku hoi ia mea.
\q1 
\v 28 A ua i mai no ia i ke kanaka, Aia hoi, o ka makau i ka Haku, oia ka noeau; A o ka haalele i ka hewa, oia ka naauao.
\c 29
\b
\q1 
\v 1 OLELO hou mai la o Ioba i kana olelonane, i mai la,
\q1 
\v 2 Ina e like au me na malama mamua, I na la a ke Akua i malama mai ai ia'u!
\q1 
\v 3 I ka wa i lilelile ai kona kukui maluna o kuu poo, A ma kona malamalama hele no au mawaena o ka pouli!
\q1 
\v 4 E like me au i na la o kuu oo ana, I ka wa i kuka pu ai me ke Akua ma kuu halelewa!
\q1 
\v 5 I ka wa o ka Mea mana me au, I ka wa e hoopuni ana kuu poe keiki ia'u!
\q1 
\v 6 I ka wa a'u i holoi ai i kuu mau wawae i ka waiu, A hookahe mai ka pohaku no'u i na kahawai aila!
\q1 
\v 7 I kuu hele ana'ku ma ka pukapa i ke kulanakauhale, Ma ke alanui hoomakaukau iho au i kuu wahi noho!
\q1 
\v 8 Ike mai ka poe kanaka opio ia'u, a pee iho la; A o ka poe kahiko, ala mai lakou a ku iluna.
\q1 
\v 9 Noho malie na luna i ka olelo aku, A kau lakou i ka lima maluna o ko lakou waha.
\q1 
\v 10 O ka leo o na'lii ua hunaia, Pipili ko lakou alelo me ko lakou kileo.
\q1 
\v 11 A lohe ka pepeiao, hoomaikai no ia ia'u; A ike ka maka, hoike mai ia no'u:
\q1 
\v 12 No ka mea, ua hoopakele au i ka poe hune e uwe ana, A me ka mea makua ole, aole ana mea kokua.
\q1 
\v 13 O ka hoomaikai o ka mea ane make i kau mai maluna o'u: A hoohauoli no au i ka naau o ka wahinekanemake.
\q1 
\v 14 Aahu iho no au i ka pono, a ua uhi mai ia ia'u; E like me ka aahu a me ke kaei poo, pela kuu olelohoopono.
\q1 
\v 15 Ua lilo au i maka no ka makapo, I wawae hoi no ka oopa.
\q1 
\v 16 He makua hoi au no ka poe ilihune; A o ka mea hakaka a'u i ike ole ai, ua huli aku au ia.
\q1 
\v 17 Ua haki ia'u na kui o ka mea hewa, A ua kaili aku au i ka waiwai hao mai kona mau niho aku.
\q1 
\v 18 Alaila i iho la au, e make auanei au iloko o kuu punana, A me he one la e hoonui auanei au i na la.
\q1 
\v 19 Manamana ae la kuu aa ma na wai, A kau iho la ka hau, a ao ka po, maluna o kuu lala.
\q1 
\v 20 Ua hou ko'u nani iloko o'u, A o ka'u kakaka, ua hooulu hou ia ma kuu lima.
\b
\q1 
\v 21 Hoolohe lakou ia'u a kakali hoi, A noho malie lakou i kau oleloao.
\q1 
\v 22 Mahope o ka'u olelo ana, aole lakou i olelo hou, A kulu iho ka'u olelo maluna iho o lakou.
\q1 
\v 23 Kakali lakou ia'u e like me ka ua; A hamama loa lakou i ko lakou waha, no ke kuaua hope.
\q1 
\v 24 A akaaka au ia lakou, aole lakou i manao he oiaio; A o ka malamalama o kuu maka aole lakou i hookulou ilalo ia.
\q1 
\v 25 Ua wae aku au i ko lakou aoao, a noho me he luna la, A noho au me he alii la maluna o ka poe kaua, E like me ka mea hooluolu i ka poe e uwe ana.
\c 30
\b
\q1 
\v 1 A NO hoi, ua henehene mai ia'u ka poe opiopio ia'u, Ka poe nona na makuakane a'u i hoowahawaha ai, Aole e hoonoho pu me na ilio o ka'u poe hipi.
\q1 
\v 2 Oia hoi, o ka ikaika o ko lakou lima heaha ia ia'u, Ka mea i pau ka ikaika?
\q1 
\v 3 No ka ilihune a no ka pololi ua wiwi lakou; Holo lakou i ka waonahele, I ka po he mehameha a neoneo.
\q1 
\v 4 Uhuki lakou i ka maluha ma ka nahelehele, A me ke aa o ka laau iunipera i ai na lakou.
\q1 
\v 5 Maiwaena mai o kanaka ua hookukeia'ku lakou; Kahea nui aku mahope o lakou e like me lakou i ka aihue;
\q1 
\v 6 Maloko o na awawa weliweli e noho ai lakou, Maloko o na lua o ka honua a me na pohaku.
\q1 
\v 7 Mawaena o ka nahelehele, me he hoki la lakou i uwe ai, Malalo o ka laau kuku lakou i hoakoakoa ai.
\q1 
\v 8 He poe keiki a kanaka lapuwale, He poe keiki a kanaka inoa ole; Ua hookukeia lakou mai ka aina aku.
\b
\q1 
\v 9 Ano hoi, ua lilo au i mea e mele ai lakou; A ua lilo hoi au no lakou i mea e olelo nane ai.
\q1 
\v 10 Ua hoopailua lakou ia'u, a holo mamao lakou mai o'u aku la, Aole lakou i uumi i ke kuha mai i kuu maka.
\q1 
\v 11 No ka mea, ua kuu aku ia i kona kaulawaha, a ua hookaumaha mai ia'u; Ua kuu aku hoi lakou i ke kaulawaha imua o'u.
\q1 
\v 12 Ma ka akau ku mai ka poe opio, a hoonee aku i kuu wawae, Hoouka ae lakou i na alanui no kuu make.
\q1 
\v 13 Ua hana ino lakou i kuu ala, Ua kokua lakou i kuu hina ana; Aohe o lakou kokua.
\q1 
\v 14 Hele mai lakou me he poha nui mai la: Ma kahi nahae, hookaa mai la lakou maluna o'u.
\b
\q1 
\v 15 Ua hiki mai na mea hooweliweli maluna o'u: Hoomaau lakou i kuu lokomaikai e like me ka makani; A me he ao la, ke hele aku nei kuu pomaikai.
\b
\q1 
\v 16 Ano hoi ua nininiia kuu uhane iloko o'u, Ua lalau mai na la kaumaha ia'u.
\q1 
\v 17 I ka po ua oia kuu mau iwi iloko o'u; Aole i maha kuu mau eha aai.
\q1 
\v 18 No ka ikaika loa o kuu mai, ua ano e kuu aahu; Ua puliki mai ia'u e like me ka a-i o kuu kapakomo.
\q1 
\v 19 Ua hoolei mai oia ia'u iloko o ka nenelu, A ua like au me ka lepo a me ka lehu.
\q1 
\v 20 Ua uwe aku au ia oe, aole oe i hoolohe mai ia'u; A ku au iluna, aole oe i manao mai ia'u.
\q1 
\v 21 Ua lilo oe i enemi no'u, Me ka ikaika o kou lima i hahai mai oe ia'u.
\q1 
\v 22 Ua kaikai oe ia'u, A hooholo no oe ia'u maluna o ka makani; Ua hooheehee mai hoi ia'u a hoomakau mai.
\q1 
\v 23 No ka mea, ua ike no au e hoihoi aku oe ia'u i ka make, A i ka hale e akoakoa ai ka poe a pau e ola ana.
\b
\q1 
\v 24 Aka, he mea ole ka pule, ke kikoo mai ia i kona lima, Ina e uwe lakou iloko o kona luku ana.
\q1 
\v 25 Aole anei au i uwe i kona la pilikia? Aole anei i kaumaha ko'u naau no ka poe ilihune?
\q1 
\v 26 I ka wa i kakali ai au i ka maikai, alaila hiki mai ka hewa; A ukali au i ka malamalama, alaila hiki mai ka pouli.
\q1 
\v 27 Ua kupikio kuu opu, aohe malie iho; Ua hiki e mai ia'u na la popilikia.
\q1 
\v 28 Ke hele eleele nei au, aole nae i ka la: Ku no au iluna maloko o ka ahakanaka, a uwe aku au.
\q1 
\v 29 Ua lilo au i hoahanau no na iliohae, A i hoalauna no na iana.
\q1 
\v 30 Ua eleele kuu ili maluna o'u, A ua hoaia kuu mau iwi i ka wela.
\q1 
\v 31 A ua lilo kuu lira no ke kanikau, A o kuu mea hookiokio no ka leo o ka poe e uwe ana.
\c 31
\b
\q1 
\v 1 U A hana au i berita me kuu mau maka; A no ke aha la au e nana aku ai i ke kaikamahine?
\q1 
\v 2 A heaha ka haawina a ke Akua mai luna mai? Heaha hoi ka hooilina a ka Mea mana mai kahi kiekie mai?
\q1 
\v 3 Aole anei he make no ka poe pono ole? A me ka luku no ka poe hana hewa?
\q1 
\v 4 Aole anei ia i ike i ko'u mau aoao, A i helu hoi i kuu mau kapuwai a pau?
\b
\q1 
\v 5 Ina ua hele au ma ka wahahee, Ina ua lalelale kuu wawae i ka hoopunipuni;
\q1 
\v 6 E kaupaonaia au ma ke kaupaona pono, I ike ai ke Akua i kuu oiaio.
\q1 
\v 7 Ina ua kapae kuu hele ana mai ke ala aku, A ua hele kuu naau mamuli o ko'u mau maka, Ina ua pili ke kina i kuu mau lima;
\q1 
\v 8 Alaila e lulu no au, a na hai e ai; A e uhukiia kuu mea ulu.
\b
\q1 
\v 9 Ina ua hoowalewaleia ko'u naau e ka wahine, Ina ua hoohalua au ma ka puka o ko'u hoalauna;
\q1 
\v 10 Alaila e kaapalaoa ka'u wahine na hai, A e kulou na mea e maluna ona.
\q1 
\v 11 No ka mea, he hewa nui no ia, A he lawehala no ia imua o na lunakanawai.
\q1 
\v 12 No ka mea, he ahi ia e hoopau ana, a i ka make, A e uhuki no ia i ka'u mea loaa a pau.
\b
\q1 
\v 13 Ina ua hoowahawaha au i ka hoopono ana i ka'u kauwakane a me ka'u kauwawahine, Ia lakou i hoopaapaa pu ai me au;
\q1 
\v 14 Heaha ka'u e hana aku ai ke ku mai ke Akua? A ke hookolokolo mai ia, heaha ka'u e olelo aku ai ia ia?
\q1 
\v 15 Aole anei ka mea nana au i hana iloko o ka opu i hana hoi ia ia? I hana hoi oia ia maua iloko o ka opu hookahi?
\b
\q1 
\v 16 Ina ua hoole au i ka makemake o ka poe ilihune, A ua hoonawaliwali i na maka o ka wahinekanemake;
\q1 
\v 17 A ina ua ai au i ka'u wahi ai iki, owau wale no, A i ai ole hoi ka mea makua ole ia mea;
\q1 
\v 18 (No ka mea, mai kuu wa opio mai, ua ulu pu ia me au me he makuakane la, A mai ka opu mai o ko'u makuwahine ua alakai au ia ia:)
\q1 
\v 19 Ina ua ike au i ka mea e make ana i ke kapa ole, A i ka mea ilihune me ka mea uhi ole;
\q1 
\v 20 Ina ua hoomaikai ole kona puhaka ia'u, A ua pumahana ole ia i ka hulu o ka'u poe hipa;
\q1 
\v 21 Ina ua kau aku au i kuu lima maluna o ka mea makua ole, I ka manawa a'u i ike ai i kuu kokua ma ka ipuka:
\q1 
\v 22 Alaila e haule iho kuu lima mai ka poohiwi aku, A e haki kuu lima mai ka iwi poohiwi aku.
\q1 
\v 23 No ka mea, he mea weliweli ia'u ka hoopai ana o ke Akua, A no kona kiekie aole loa au i hoomanawanui.
\b
\q1 
\v 24 Ina ua hoonoho au i ke gula i mea e lana'i kuu manao, Ina olelo aku au i ke gula maikai, Oia kuu mea e palele ai;
\q1 
\v 25 Ina ua olioli au no ka nui o kuu waiwai, A no ka mea nui a kuu lima i loaa'i;
\q1 
\v 26 Ina ua ike au i ka la i kona lilelile ana, A i ka mahina i kona hele aiai ana;
\q1 
\v 27 A ua hoowalewale malu ia ko'u naau, I honi ai kuu lima i kuu waha;
\q1 
\v 28 He hewa no hoi ia i ka lunakanawai; No ka mea, ua hoole aku au i ke Akua maluna.
\b
\q1 
\v 29 Ina ua olioli au i ka make ana o ka mea inaina mai ia'u, A ua hauoli au i ka loaa ana o ka hewa ia ia:
\q1 
\v 30 Aole! aole au i ae aku i kuu waha e hana hewa, Ma ke noi aku i ka hooino maluna o kona uhane.
\q1 
\v 31 Ina i olelo ole mai na kanaka o kuu halelewa, Ina e loaa ia makou kona io! aole makou e maona.
\q1 
\v 32 Aole i moe mawaho ka malihini, Ua wehe ae no au i ko'u puka no ka mea hele.
\q1 
\v 33 Ina ua uhi au i kuu hala e like me ka ke kanaka, I ka huna ana i kuu hewa iloko o kuu poli;
\q1 
\v 34 Alaila e hoohilahilaia au imua o ka aha nui, A na ka wahawaha o na ohana e hooweliweli ia'u, A noho malie no au, a hele ole iwaho o ka puka.
\q1 
\v 35 Ina hoi e hoolohe mai kela ia'u! Eia hoi kuu hoailona, e ekemu mai ka Mea mana ia'u! A e kakau kuu enemi i ka palapala hoopii!
\q1 
\v 36 He oiaio e kau aku au ia mea maluna o ko'u poohiwi, E nakii au ia me he leialii la maluna o'u.
\q1 
\v 37 E hai aku hoi au ia ia i ka heluna o kuu mau kapuwai; Me he alii la, e hookokoke aku au ia ia.
\b
\q1 
\v 38 Ina e uwe kuu aina no'u, A o na auwaha hoi ona e kanikau mai;
\q1 
\v 39 Ina ua ai au i kona hua me ke kala ole, A ua hoomake paha i na haku ona;
\q1 
\v 40 E hoouluia ka laau oioi no ka palaoa, A o ka zizania no ka bale. Ua pau ka olelo a Ioba.
\c 32
\b
\q1 
\v 1 HOOKI iho la keia mau kanaka ekolu i ka olelo aku ia Ioba, no ka mea, ua pono ia i kona maka iho.
\q1 
\v 2 Alaila hoaia ka inaina o Elihu ke keiki a Barakela o ka Buza, no ka ohana a Rama; ia Ioba i hoaia'i kona inaina, no kona hoapono ia ia iho mamua o ke Akua.
\q1 
\v 3 I kona mau hoalauna ekolu hoi ua hoaia'i kona inaina, no ka mea, aole i loaa ia lakou ka mea e ekemu aku ai, ua hoahewa no nae lakou ia Ioba.
\q1 
\v 4 A ua kali aku o Elihu ia Ioba i na olelo, no ka mea, ua oi aku ko lakou mau makahiki mamua ona.
\q1 
\v 5 A ike aku la o Elihu, aohe mea ma ka waha o keia mau kanaka ekolu e ekemu aku ai, alaila hoaia kona inaina.
\q1 
\v 6 Olelo aku la o Elihu, ke keiki a Barakela ka Buza, i aku la,
\q1 He hapa ko'u mau la, a he poe kahiko oukou;
\q1 Nolaila hopohopo no wau, a makau hoi i ka hoike aku i ko'u manao ia oukou.
\q1 
\v 7 I iho la au, E olelo mai ka poe kahiko e pono ai,
\q1 A e hoike ka poe nona na makahiki he nui i ka naauao.
\q1 
\v 8 He oiaio, o ka Uhane no iloko o ke kanaka:
\q1 A o ka hanu o ka Mea mana ua hoonaauao ia ia.
\q1 
\v 9 Aole naauao na elemakule;
\q1 Aole hoi e ike ka poe kahiko i ka hooponopono ana.
\q1 
\v 10 Nolaila i iho la au, E hoolohe mai ia'u;
\q1 E hoike aku no hoi au i ko'u manao.
\b
\q1 
\v 11 Aia hoi, ua kali aku au i ka oukou mau olelo,
\q1 A hoolohe au i ko oukou hoomoakaka ana,
\q1 I ka manawa i imi ai oukou i na olelo.
\q1 
\v 12 A ua noonoo au i ka oukou,
\q1 Aia hoi, aole kekahi o oukou i pane pono aku ia Ioba,
\q1 A i hoohee aku i kana olelo;
\q1 
\v 13 O olelo auanei oukou,
\q1 Ua loaa ia makou ke akamai:
\q1 Na ke Akua i hooauhee ia ia, aole na ke kanaka.
\q1 
\v 14 Aole ia i olelo ku e mai ia'u;
\q1 Aole no hoi au e olelo aku ia ia me ka oukou mau olelo.
\b
\q1 
\v 15 Ua pilipu lakou, aole lakou i ekemu hou mai:
\q1 A hooki iho lakou i ka olelo ana.
\q1 
\v 16 A ua kakali aku au, (no ka mea, aole lakou i olelo mai, aka, ku malie iho la, aole i ekemu hou mai;)
\q1 
\v 17 Owau no kekahi e olelo aku i ka'u wahi,
\q1 E hoike aku hoi au i ko'u manao.
\q1 
\v 18 No ka mea, ua piha au i na olelo,
\q1 Ke koi mai nei ia'u ka uhane iloko o'u.
\q1 
\v 19 Aia hoi, o ko'u opu ua like ia me ka waina i wehe ole ia;
\q1 E nahae auanei ia e like me na hue ili hou.
\q1 
\v 20 E olelo aku no au, i oluolu iho ai au;
\q1 E wehe ae au i kuu lehelehe, a e ekemu aku.
\q1 
\v 21 Ke noi aku nei au, mai ae mai oukou i kuu nana ana ma ko ke kanaka helehelena,
\q1 Aole hoi au e malimali aku i ke kanaka.
\q1 
\v 22 No ka mea, aole au i ike e malimali wale aku;
\q1 E lawe koke aku ia'u ko'u Mea nana i hana.
\c 33
\b
\q1 
\v 1 NOLAILA ke noi aku nei au ia oe, e Ioba, e hoolohe mai i ka'u mau olelo, A e haliu mai i ka'u mau huaolelo a pau.
\q1 
\v 2 Aia hoi, ano, ke wehe nei au i kuu waha, Ke olelo aku nei kuu elelo ma kuu waha.
\q1 
\v 3 Ma ka pono o kuu naau ka'u olelo; A e olelo akaka kuu lehelehe i ka naauao.
\q1 
\v 4 Na ka Uhane o ke Akua owau i hana, Na ka hanu hoi o ka Mea mana owau i hoola.
\q1 
\v 5 Ina e hiki ia oe ke ekemu mai ia'u, E hooponopono oe imua o'u, e kupaa.
\q1 
\v 6 Aia hoi, no ke Akua no wau e like me oe; Ua hanaia hoi au mai ka lepo mai.
\q1 
\v 7 Aia hoi, aole ko'u makau e hooweliweli ia oe, Aole e hookaumahaia ko'u lima maluna ou.
\b
\q1 
\v 8 He oiaio, ua olelo mai oe maloko o kuu pepeiao, A ua lohe au i ka leo o kau mau olelo;
\q1 
\v 9 Ua maemae wau, me ka hala ole, Ua maemae wau, aohe hewa iloko o'u.
\q1 
\v 10 Aia hoi, ua imi no ia i na mea ku e ia'u, Ua manao mai ia ia'u he enemi nona;
\q1 
\v 11 Ua hookomo no ia i kuu mau wawae ma ka laau kupee, Ua hoohalua no ia i ko'u mau aoao a pau.
\q1 
\v 12 Aia hoi, ma keia ua pono ole oe; E olelo aku au ia oe, no ka mea, ua oi ke Akua mamua o ke kanaka.
\b
\q1 
\v 13 No ke aha la oe i hakaka pu ai me ia? No ka mea, aole ia i hoike mai i kana mau mea a pau.
\b
\q1 
\v 14 No ka mea, hookahi ka ke Akua olelo ana mai, A elua hoi, aole nae i manaoia oia.
\q1 
\v 15 Ma ka moeuhane, ma ka hihio i ka po, I ke kau ana o ka hiamoe nui maluna o kanaka, I ka hiamoe ana maluna o kahi moe;
\q1 
\v 16 Alaila wehe ae la ia i na pepeiao o kanaka, A hoopaa mai ia i ke ao ana o lakou,
\q1 
\v 17 I hoololi ai ia i ka ke kanaka hana, A e hookaa i ke kiekie mai ke kanaka aku.
\q1 
\v 18 Ua hoopakele no ia i kona uhane mai ka luakupapau mai, A i kona ola hoi mai ka make ana i ka pahikaua.
\b
\q1 
\v 19 Ua hoopaiia oia i ka eha maluna o kona wahi moe, A o ka haukeke o kona mau iwi, ua ikaika ia.
\q1 
\v 20 Ua hoopailua kona naau i ka berena, A o kona uhane i ka ai maikai.
\q1 
\v 21 Ua hoopauia kona io mai ka maka aku, A ua ahuwale mai kona mau iwi i ike ole ia.
\q1 
\v 22 A ua hookokokeia kona uhane i ka luakupapau, A o kona ola i na mea hoopau.
\b
\q1 
\v 23 Ina me ia he anela, he hoikeolelo, Hookahi noloko mai o ke tausani, E hoike aku i ke kanaka i kona pono;
\q1 
\v 24 A aloha mai oia ia ia, a i iho la, E hoopakele ia ia mai ka iho ana i ka lua; Ua loaa ia'u ka uku hoola.
\q1 
\v 25 E hana hou ia kona io me ia i ka wa kamalii, E hoi hou no ia i na la o kona wa opio:
\q1 
\v 26 E pule aku no ia i ke Akua, a e oluolu no oia ia ia: A e ike aku ia i kona maka me ka hauoli; A e hoihoi aku no ia no ke kanaka i kona pono.
\q1 
\v 27 E nana mai no ia i na kanaka, A e olelo iho kekahi, Ua hewa au, A ua hookahuli au i ka pono, aole nae i hooukuia mai au;
\q1 
\v 28 E hoopakele no ia i kona uhane mai ka hele ana i ka lua, A e ike kona mau maka i ka malamalama.
\b
\q1 
\v 29 Aia hoi, o keia mau mea a pau i hana pinepine ai ke Akua me ke kanaka,
\q1 
\v 30 E hoihoi mai i kona uhane mai ka lua mai, E hoomalamalamaia i ka malamalama o ka poe e ola ana.
\q1 
\v 31 E haliu mai oe, e Ioba, e hoolohe mai ia'u: E noho malie, a na'u e olelo aku.
\q1 
\v 32 Ina he wahi mea, e ekemu mai oe ia'u, E olelo mai, no ka mea ke makemake nei au i kou hoaponoia.
\q1 
\v 33 A i ole hoi, e hoolohe mai oe ia'u, E noho malie, a e ao aku au ia oe i ka noeau.
\c 34
\b
\q1 
\v 1 A OLELO aku o Elihu, i aku la,
\q1 
\v 2 E hoolohe mai oukou ia'u, e ka poe akamai, E haliu mai i ka pepeiao ia'u, e ka poe ike:
\q1 
\v 3 No ka mea, ke hoao nei ka pepeiao i na olelo, E like me ke kileo i hoao i ka ai.
\q1 
\v 4 E hoao kakou i ka hooponopono no kakou iho; E ike kakou iwaena o kakou i ka mea maikai.
\q1 
\v 5 No ka mea, ua i mai o Ioba, Ua pono wau: A ua lawe aku ke Akua i kuu hoaponoia.
\q1 
\v 6 E hoopunipuni anei au i kuu pono? O kuu eha me ka hala ole, aole e hoolaia.
\q1 
\v 7 Owai ke kanaka e like me Ioba; Ka mea inu i ka olelo hoino me he wai la,
\q1 
\v 8 Ka mea e hele pu ana me ka poe e hana ana i ka hewa, E hele ana hoi me na kanaka aia?
\q1 
\v 9 No ka mea, ua i mai ia, Aohe o ke kanaka mea e pono ai, I kona launa pu ana me ke Akua.
\b
\q1 
\v 10 Nolaila e hoolohe ia'u, e na kanaka naauao; Aole ke Akua e hana i ka hewa; Aole hoi ka Mea mana i ka pono ole:
\q1 
\v 11 No ka mea, ma ka hana a ke kanaka e ukuia mai ai oia, A e loaa i kela kanaka keia kanaka e like me kona aoao.
\q1 
\v 12 He oiaio no, aole ke Akua e hana i ka hewa, Aole hoi ka Mea mana e hookahuli i ka pono.
\q1 
\v 13 Owai ka i haawi ia ia i ka honua? A owai ka i hoonoho i ko ke ao nei a pau?
\q1 
\v 14 Ina e kau ia i kona naau maluna o ke kanaka, A e lawe aku ia i kona uhane a me kona ea io na la;
\q1 
\v 15 E make pu auanei na io a pau, A e hoi hou aku ke kanaka i ka lepo.
\b
\q1 
\v 16 A ina he naauao kou, e hoolohe mai i keia; E haliu mai i ka leo o ka'u olelo.
\q1 
\v 17 E alii anei ka mea hoowahawaha i ka pono? A e hoahewa anei oe i ka mea pono loa?
\q1 
\v 18 He pono anei e olelo i ke alii, He hewa kou? A i na'lii, He pono ole oukou?
\q1 
\v 19 Pehea hoi ka mea maliu ole mai i ko na'lii, Aole hoi ia i manao i ka mea waiwai mamua o ka ilihune? No ka mea, o lakou, a pau ka hana a kona lima.
\q1 
\v 20 E make koke no lakou, Iwaena o ka po e haalulu na kanaka, a e nalo aku; A e laweia'ku ka poe ikaika, me ka lima ole.
\b
\q1 
\v 21 No ka mea, aia no kona mau maka maluna o na aoao o ke kanaka, A ua nana no i kona mau kapuwai a pau.
\q1 
\v 22 Aohe pouli, aohe malu make, Kahi e pee ai ka poe e hana ana i ka hewa.
\q1 
\v 23 No ka mea, aole ia e noonoo nui i ka ke kanaka, E kai aku ia ia imua o ke Akua ma ka hookolokolo ana.
\q1 
\v 24 E ulupa oia i na'lii me ka noonoo ole, A e hooku i na mea e ae ma ko lakou hakahaka.
\q1 
\v 25 Nolaila, ua ike no ia i ka lakou mau hana, A e hookahuli oia ia lakou i ka po, a e hehiia lakou ilalo.
\q1 
\v 26 Hoopai no ia ia lakou, no ka mea, ua hewa lakou, Ma kahi o ka poe e nana mai ana;
\q1 
\v 27 No ka mea, ua huli ae lakou mai ona aku la, Aole lakou i noonoo i kona mau aoao a pau.
\q1 
\v 28 Nolaila, e hele ka uwe ana o ka mea hune io na la, A ua hoolohe ia i ka uwe ana o ka poe i hooluhiia.
\q1 
\v 29 A haawi mai ia i ka maha, owai hoi ke hoopilikia mai? A huna oia i kona maka, owai ke ike aku ia ia? Pela no ka lahuikanaka a me ke kanaka hookahi:
\q1 
\v 30 I alii ole ai ke kanaka aia, O hihia auanei na kanaka.
\b
\q1 
\v 31 He pono no e olelo aku oe i ke Akua, Ua hoopaiia wau, aole au e hana hewa hou aku.
\q1 
\v 32 O ka mea a'u i ike ole ai kau e ao mai ai ia'u; Ina ua hana au i ka hewa, aole au e hana hou.
\q1 
\v 33 Ma kou manao anei kana e uku mai ai, no kou hoole ana, Nau no e koho, aole na'u? Nolaila o ka mea au i ike ai, e olelo mai oe.
\q1 
\v 34 O na kanaka naauao e olelo mai ia'u, A me ke kanaka akamai e hoolohe mai ia'u.
\q1 
\v 35 Ua olelo mai o Ioba me ka ike ole, A o kana mau olelo, aole me ka naauao.
\q1 
\v 36 O kuu makemake, e hoaoia o Ioba a i ka hopena, No kana mau olelo e like me ka na kanaka hewa.
\q1 
\v 37 No ka mea, ua hookui aku ia i ka lawehala me kona hewa, Iwaena o kakou ua pai i kona lima, A ua hoonui i kana mau olelo ku e i ke Akua.
\c 35
\b
\q1 
\v 1 OLELO aku la hoi o Elihu, i aku la,
\q1 
\v 2 Ke manao nei oe he pono keia, O kau i olelo mai, O ko'u pono, ua oi mamua o ko ke Akua?
\q1 
\v 3 No ka mea, ua ninau mai oe, Heaha ka pono no'u? Heaha hoi ko'u pomaikai no kuu hewa ole ana?
\q1 
\v 4 Owau ke hoihoi aku ia olelo iou la, A i kou mau hoalauna me oe.
\q1 
\v 5 E nana ae oe i ka lani, a ike; A e nana i na ao, ua kiekie lakou mamua ou.
\q1 
\v 6 Ina e hana hewa oe, heaha kau hana ia ia? Ina e hoonuiia kou mau hala, heaha kau e hana'i nana?
\q1 
\v 7 Ina ua pono oe, heaha kau e haawi aku ai ia ia? Heaha kana e loaa'i mai kou lima aku?
\q1 
\v 8 No ke kanaka e like me oe kou hala, A no ke keiki a ke kanaka kou pono.
\b
\q1 
\v 9 Ke uwe ae nei ka poe kaumaha no ka hooluhiia; I uwe lakou no ka lima o na mea koikoi.
\q1 
\v 10 Aka, aole e i mai kekahi, Auhea ke Akua nana au i hana, Ka mea i haawi mai i na mele olioli i ka po;
\q1 
\v 11 O ka mea i ao mai ia kakou mamua o na holoholona o ka honua, A ua hoonaauao oia ia kakou mamua o na manu o ka lewa?
\q1 
\v 12 Malaila lakou e uwe ai, aole mea i ekemu mai, No ka haaheo o ka poe hewa.
\q1 
\v 13 He oiaio, aole ke Akua e hoolohe mai i ka mea wahahee, Aole ka Mea mana e maliu mai ia.
\q1 
\v 14 Ina paha e olelo oe, aole oe i ike ia ia, Imua ona ka hooponopono, nolaila e kali aku oe ia ia.
\q1 
\v 15 Ano hoi, he mea ole ka hoopai ana o kona inaina, Aole ia e haka pono mai i na hewa;
\q1 
\v 16 Nolaila i oaka hewa mai ai ko Ioba waha, He hoonui olelo kana me ko ike ole.
\c 36
\b
\q1 
\v 1 OLELO hou aku la o Elihu, i aku la,
\q1 
\v 2 E ahonui iki mai ia'u, a e hoike aku au ia oe, No ka mea, he wahi olelo ka'u i koe no ke Akua.
\q1 
\v 3 E lawe mai no au i kuu ike mai kahi loihi mai, A e hoapono aku au i kuu mea nana i hana.
\q1 
\v 4 No ka mea, aole e wahahee ka'u olelo; O ka mea hemolele i ka ike, oia me oe.
\q1 
\v 5 Aia hoi, he mana ke Akua, aole ia e hoowahawaha: He mana kona, he ikaika ka naauao.
\q1 
\v 6 Aole ia e hoopomaikai i ka aia: Aka, e haawi no ia i ka pono no na ilihune.
\q1 
\v 7 Aole ia e lawe ae i kona mau maka mai ka poe pono aku; Aia no ia me na'lii maluna o ka nohoalii; A e hoonoho paa no oia ia lakou, i kiekie ai lakou.
\q1 
\v 8 A ina e hoopaaia lakou i na kaulahao, A e hoopaaia lakou i ke kaula o ka popilikia;
\q1 
\v 9 Alaila hoike no ia ia lakou i ka lakou hana, A me ko lakou hewa, no ka mea, ua hana kiekie lakou.
\q1 
\v 10 Wehe ae no ia i ko lakou pepeiao no ke ao ana, A olelo aku e huli mai lakou mai ka hewa mai.
\q1 
\v 11 Ina hoolohe lakou, a malama ia ia, E noho lakou i ko lakou mau la me ka pomaikai, A i ko lakou mau makahiki me ka oluolu.
\q1 
\v 12 Aka, i hoolohe ole lakou, e make lakou i ka pahikaua, A e make lakou iloko o ka naaupo.
\q1 
\v 13 A o ka poe aia ma ka naau, hoiliili lakou i ka inaina: Aole lakou e kahea aku, i ka wa e hoopaa aku ai oia ia lakou.
\q1 
\v 14 E make no lakou i ka wa ui, A ua pau ko lakou ola ana iwaena o ka poe haumia.
\q1 
\v 15 Hoopakele no ia i ka mea hune i kona popilikia, A wehe ae ia i ko lakou pepeiao i ka wa kaumaha.
\q1 
\v 16 A lawe auanei hoi oia ia oe mai kahi pilikia a kahi akea, Ma kahi aohe ona pilikia: A o ka mea e kauia ma kou papaaina, e piha ia i ka momona.
\b
\q1 
\v 17 Aka, i lawe paha oe i ka hewa o ka mea aia, O ka hoohewa, a me ka hoopai e hahai mai.
\q1 
\v 18 No ka mea, no ka huhu, [E ao,] o lawe aku oia ia oe me ka hahau ana; Alaila aole e hiki i ka panai nui ke hoopakele ia oe.
\q1 
\v 19 E manao anei oia i kou waiwai? Aole! aole ke gula, aole hoi na mea waiwai a pau.
\q1 
\v 20 Mai iini oe i ka po, I ka wa i okiia'i na kanaka mai ko lakou wahi.
\q1 
\v 21 E makaala, mai malama oe i ka hewa: No ka mea, ua koho aku oe i keia mamua o ka popilikia.
\q1 
\v 22 Aia hoi, o ke Akua ke hookiekie ma kona mana, Owai ke ao aku e like me ia?
\q1 
\v 23 Owai la i kuhikuhi aku ia ia i kona aoao? Owai la ke olelo aku, Ua hana oe i ka hewa?
\b
\q1 
\v 24 E hoomanao, e hoonui aku oe i kana hana, Ka mea a na kanaka i ike ai.
\q1 
\v 25 E ike na kanaka a pau ia; E nana ke kanaka mai kahi loihi.
\q1 
\v 26 Aia hoi, he nui ke Akua, aole kakou i ike, A o ka heluna o na makahiki ona, aole e huliia.
\q1 
\v 27 No ka mea, ua hoopii aku ia i na kulu wai; Ninini iho lakou he ua, noloko o kona ohu,
\q1 
\v 28 Ka mea a na naulu i hookulukulu iho ai, A ninini nui maluna o ke kanaka.
\q1 
\v 29 E hoomaopopo anei kekahi i ka hohola ana o na ao? A me ka halulu ana o kona halelewa?
\q1 
\v 30 Aia hoi, hohola aku no ia i kona malamalama maluna ona, A uhi no ia i ka hohonu o ke kai.
\q1 
\v 31 No ka mea, ma o lakou la ke hooponopono nei ia i na kanaka; Ke haawi nei ia i ka ai a nui loa.
\q1 
\v 32 Me na poho lima ke uhi no ia i ka uila, A kauoha aku ia ia i kona wahi e kau ai:
\q1 
\v 33 I kuhikuhi aku ia ia ia i kona mau makamaka; Aia ka ahu ana o ka huhu maluna o ka mea hewa.
\c 37
\b
\q1 
\v 1 NO keia mea hoi haalulu kuu naau, A nauwe ae mai kona wahi aku.
\q1 
\v 2 E hoolohe pono i ka poha ana o kona leo, A me ka halulu e puka ana mai kona waha mai.
\q1 
\v 3 Malalo o ka lani a pau nana no ia i nou aku, A o kona malamalama i na welau o ka honua.
\q1 
\v 4 Mahope o ia mea, poha mai ka leo; Hoohekili mai ia me kona leo mana; Aole ia e hoopaa ia lakou i loheia'i kona leo.
\q1 
\v 5 Hoohekili kupanaha mai la ke Akua me kona leo; Hana no ia i na mea nui, aole e ike maopopo ia.
\q1 
\v 6 No ka mea, ua i aku ia i ka hau, E kau ma ka honua, A i ka ua liilii, a me ka ua nui o kona ikaika.
\q1 
\v 7 Hoopaa aku ia i ka lima o na kanaka a pau, I ike na kanaka a pau i kana haua.
\q1 
\v 8 A komo na holoholona iloko o na lua, A noho ma ko lakou mau wahi.
\q1 
\v 9 Mai ke kukulu hema i hele mai ka puahiohio, A mai ke kukulu akau ke anu.
\q1 
\v 10 Mai ka hanu o ke Akua i haawiia mai ka wai paa: A o ka palahalaha o na wai, ua hoopaaia.
\q1 
\v 11 O ka wa malie hoi, ua kipaku ia i ke ao: Ua hoohehee kona malamalama i ka ohu:
\q1 
\v 12 A ua hoohuliia'ku ia a puni ma kona manao; I hana aku ai lakou i na mea a pau ana i kauoha mai ai, Ma ke alo o ka honua a puni.
\q1 
\v 13 Ina no ka laau hahau, ina no kona aina, Ina no ke aloha, nana no ia i hoopuka mai.
\b
\q1 
\v 14 E hoolohe mai oe, e Ioba, i keia; E ku malie, a e noonoo i na hana kupanaha a ke Akua.
\q1 
\v 15 Ua ike anei oe i ka hooponopono ana o ke Akua ia lakou, A hoopuka mai i ka malamalama o kona ao?
\q1 
\v 16 Ua ike anei i na kaupaona ana o na ao, I na hana kupanaha o ka mea hemolele i ka ike?
\q1 
\v 17 A pehea hoi i mahana ai kou kapa, I ka wa i hoomalie mai ai oia i ka aina i ka makani kukulu hema?
\q1 
\v 18 E hiki anei ia oe me ia ke hohola aku i ke aouli, He ikaika, e like me ke aniani i hooheheeia?
\q1 
\v 19 E hoike mai oe ia makou i ka mea a makou e olelo aku ai ia ia; Aole makou e olelo aku, no ka pouli.
\q1 
\v 20 E haiia aku anei ia ia, ke olelo aku au? Ina e olelo aku ke kanaka, e aleia auanei oia.
\b
\q1 
\v 21 Ano aole lakou i ike i ka malamalama alohilohi iloko o na ao; A hele ae la ka makani a hoomaemae ia lakou.
\q1 
\v 22 Mai ke kukulu akau ke alohilohi gula i hele mai ai; Aia i ke Akua ka nani weliweli.
\q1 
\v 23 O ka Mea mana, aole e loaa ia kakou ia; Ua hoonui i ka ikaika, a i ka pono, a ua nui hoi i ka lokomaikai; Aole ia e hookaumaha.
\q1 
\v 24 A makau na kanaka ia ia; Aole ia e maliu mai i ka poe naauao a pau.
\c 38
\b
\q1 
\v 1 A LAILA olelo mai o Iehova ia Ioba mailoko mai o ka puahiohio, i mai la,
\q1 
\v 2 Owai keia e hoopouli ana i ka oleloao, Ma na huaolelo me ka ike ole?
\q1 
\v 3 E kakoo ano i kou puhaka me he kanaka la; No ka mea, e ninau aku au ia oe, a e hoike mai oe ia'u.
\q1 
\v 4 Mahea oe i ko'u hookumu ana i ka honua? E hai mai, ina ua ike oe i ka naauao.
\q1 
\v 5 Na wai la i kau kona mau ana? ua ike ka oe! A owai hoi i kau aku i ke kaula-ana maluna ona?
\q1 
\v 6 Maluna o ke aha i hoonohoia'i kona mau kumu? Na wai la i hoonoho kona pohaku kihi;
\q1 
\v 7 I ka wa i mele pu ai na hoku ao, I hooho olioli ae hoi na keiki a pau a ke Akua?
\b
\q1 
\v 8 Nawai i hoopuni i ke kai me na pani? I kona huaiia mai la e like me ka puka ana ae mailoko mai o ka opu;
\q1 
\v 9 I kuu kau ana i ke ao i kapa nona; A i ka pouli aaki i wahi nona;
\q1 
\v 10 A ua hoopuni aku au nona i kuu mau palena, A ua hoonoho aku i na kaola a me na pani,
\q1 
\v 11 A ua i aku, Maanei oe e hele mai ai, aole aku; Maanei hoi e hoopaleia kou mau nalu kiekie.
\b
\q1 
\v 12 I kou mau la, ua kauoha anei oe i ke kakahiaka, Ua hoike aku oe i ka wanaao i kona wahi;
\q1 
\v 13 I lalau aku ai ia i na welau o ka honua, I hookukeia'i ka poe hewa mai ona aku?
\q1 
\v 14 Hoololi ia ia iho e like me ka wepa no ka hoailona; A ku ae ia mau mea iluna e like me ka lole aahu maikai.
\q1 
\v 15 A ua hooleia ko lakou malamalama mai ka poe hewa aku, A o ka lima o ka mea ikaika ua haki.
\b
\q1 
\v 16 Ua komo anei oe i na kumu o ke kai? A ua hele ae i ka imi ana i ka hohonu?
\q1 
\v 17 Ua weheia anei ia oe na puka o ka make? A ua ike anei oe i na puka o ka malu make?
\q1 
\v 18 Ua hoomaopopo anei oe i ka palahalaha o ka honua? E hai mai, ina ua ike oe ia mea a pau.
\b
\q1 
\v 19 Mahea ke ala kahi e noho ai ka malamalama? A o ka pouli mahea kona wahi?
\q1 
\v 20 I kaikai aku oe ia ia ma kona palena, A i ike aku oe i na ala o kona hale.
\q1 
\v 21 Ua ike anei oe ia, no ka mea, ua hanau oe ia manawa? A no ka mea, ua nui loa kou mau la?
\b
\q1 
\v 22 Ua komo anei oe i na hale ahu o ka hau? A ua ike anei oe i ke ahu ana o ka huahekili,
\q1 
\v 23 Ka mea a'u i malama'i no ka manawa popilikia, No ka la hoouka a me ke kaua?
\q1 
\v 24 Ma ke ala hea i mahele ai ka malamalama? A i huai mai ka makani hikina maluna o ka honua?
\b
\q1 
\v 25 Owai la i mahele i ka auwai no ka huai ana o ka wai, A i ke ala no ka uwila o ka hekili;
\q1 
\v 26 E hooua mai maluna o ka aina kanaka ole; Ma ka waonahele kahi kanaka ole;
\q1 
\v 27 E hoopiha i kahi neoneo, a me kahi nahele hooneoneo ia, E hooulu mai i ka mauu e puka mai ana?
\q1 
\v 28 He makuakane anei ko ka ua? Owai hoi i hoohanau i na kulu hau?
\q1 
\v 29 Noloko mai o ka opu owai i puka mai ai ka waipaa? A o ka haupaa o ka lani, nawai i hoohanau?
\q1 
\v 30 Ua hunaia na wai me he mea la malalo o ka pohaku, A o ka ili o ka hohonu ua hoopaaia.
\b
\q1 
\v 31 E hiki anei ia oe ke hoopaa i na mea paa o na Huhui, A e kala ae paha i na mea paa o Oriona?
\q1 
\v 32 E hiki anei ia oe ke hoopuka mai i Masarota i kona manawa? A e alakai paha i ka Bea nui me kana mau keiki?
\q1 
\v 33 Ua ike anei oe i na kanawai o ka lani? E hiki anei ia oe ke hoopaa i kona alii ana maluna o ka honua?
\b
\q1 
\v 34 E hiki anei ia oe ke hookiekie i kou leo iluna i ke ao, I uhi mai ai na wai nui ia oe?
\q1 
\v 35 E hiki anei ia oe ke hoouna aku i na uwila, a hele aku lakou, A e olelo mai lakou, Eia makou?
\q1 
\v 36 Owai la ka i hoo i ke akamai i ko loko, Owai hoi i haawi i ka naauao no ka naau?
\q1 
\v 37 Owai la ka mea hiki ke helu i na ao ma kona akamai? A o na hue o ka lani, owai ka mea i ninini?
\q1 
\v 38 I ka wa i lilo ai ka lepo i mea paa, A pipili na papaa lepo?
\b
\q1 
\v 39 E hoohalua anei oe i ka mea ai na ka liona? A hoomaona i ka pololi ana o na liona opio,
\q1 
\v 40 I ka wa i moemoe ai lakou iloko o ko lakou mau lua, A noho lakou ma kahi huna, no ka hoohalua ana?
\q1 
\v 41 Owai la ka i hoomakaukau na ke koraka i kana ai, I ka wa i uwe ai kana mau keiki i ke Akua, A ua auwana no ka nele i ka ai?
\c 39
\b
\q1 
\v 1 U A ike anei oe i ka wa e hanau ai na kao hihiu o ka pali? Ua malama anei oe i ka hanau ana o na dia?
\q1 
\v 2 E hiki anei ia oe ke helu i na malama o ko lakou koko ana? A ua ike anei oe i ka wa e hanau ai lakou?
\q1 
\v 3 Kulou iho no lakou, hanau mai i ka lakou mau keiki, I ka wa i pau ai ko lakou nahunahu ana.
\q1 
\v 4 Ua ikaika ka lakou poe keiki, Nui ae la lakou, ma ka waonahele; Hele aku lakou aole e hoi hou mai io lakou la.
\b
\q1 
\v 5 Owai la ka i hookuu wale aku i ka hoki hihiu? Owai hoi ka i kala ae i na mea paa o ka hoki hihiu?
\q1 
\v 6 O kona hale ka waonahele a'u i hana'i, A o kahi panoa kona noho ana.
\q1 
\v 7 Akaaka no ia i ka haunaele o ke kulanakauhale, Aole ia e hoolohe i ka wawa o ke kahu holoholona.
\q1 
\v 8 O ka mea i loaa o na mauna, oia kana ai, A imi no ia i na mea uliuli a pau.
\b
\q1 
\v 9 E ae mai anei ka reema e hookauwa nau, E noho no ia ma kou wahi hanai?
\q1 
\v 10 E hiki ia oe ke hoopaa i ka reema ma ke auwaha me kona kaula? E hana anei ia i na awawa me ka oopalau mahope ou?
\q1 
\v 11 E hilinai anei oe ia ia no ka nui o kona ikaika? E waiho anei oe i kau hana ia ia?
\q1 
\v 12 E manao anei oe ia ia i hoihoi mai ia i kau ai. A e hoiliili i kau hua palaoa?
\b
\q1 
\v 13 O ka eheu o ka iana ke hele wikiwiki; He eheu anei a he hulu kona e like me ko ka setoreka?
\q1 
\v 14 No ka mea, waiho no ia i kona hua iloko o ka honua, A hoopumehana ia lakou ma ka lepo,
\q1 
\v 15 A hoopoina no ia e hoopepe auanei ka wawae ia lakou, A o ka holoholona hihiu o ke kula e hehi iho ia lakou.
\q1 
\v 16 Ua hana paakiki aku ia i kana mau keiki, me he mea la aole nana; He make hewa kona luhi, a he makau ole nae.
\q1 
\v 17 Na ke Akua no ia i hoonele i ke akamai, Aole hoi ia i haawi ia ia i ka naauao.
\q1 
\v 18 Aka, i ka wa i hooholo ai oia ia ia iho, Ua akaaka no ia i ka lio a me kona mea hooholo.
\b
\q1 
\v 19 Ua haawi anei oe i ka ikaika no ka lio? Ua hoaahu anei oe i kona a-i i ka hulu haalulu?
\q1 
\v 20 E hiki anei ia oe ke hoolele ia ia e like me ka uhini? A kona hau nui ana, he mea weliweli ia.
\q1 
\v 21 Helu no oia ma ke awawa, a olioli ikaika: Hele aku e halawai me ka mea kaua.
\q1 
\v 22 Ua akaaka no ia i ka makau, aole haalulu; Aole ia e huli ae mai ka pahikaua aku.
\q1 
\v 23 Nakeke ke aapua ia ia, O ka maka o ka ihe a me ka pahi.
\q1 
\v 24 Me ka hau ana a me ka huhu, ua ale no ia i ka aina: Aole ia e ku malie i ka wa e kani ai ka pu.
\q1 
\v 25 I waena o na pu kani, i iho la ia, Ha, ha! A honi aku la ia i ke kaua ma kahi loihi, I ka uwa ana o na luna, a me ka hooho kaua.
\b
\q1 
\v 26 Na kou naauao anei e lele aku ka nisu, Hohola aku no ia i kona mau eheu ma ke kukulu hema?
\q1 
\v 27 Na kau kauoha anei i lele ae iluna ka aeto, A e kau i kona punana ma kahi kiekie?
\q1 
\v 28 Ma ka pali no ia i noho ai a hoomau ai, Maluna o kahi oioi o ka pohaku, a ma kahi paa.
\q1 
\v 29 Malaila mai no ia i imi ai i ka mea pio, A nana ae kona maka i kahi loihi.
\q1 
\v 30 O kana poe keiki, inu lakou i ke koko; A ma kahi o na heana, malaila no oia.
\c 40
\b
\q1 
\v 1 OLELO mai hoi o Iehova ia Ioba, i mai la,
\q1 
\v 2 O ka mea hoopaapaa i ka Mea mana, e ao mai anei ia ia ia? O ka mea e ao mai i ke Akua, nana no e ekemu mai.
\b
\q1 
\v 3 Alaila, olelo aku o Ioba ia Iehova, i aku la,
\q1 
\v 4 Aia hoi, ua inoino wau; Heaha ka'u e ekemu aku ai ia oe? E kau aku au i kuu lima maluna o kuu waha.
\q1 
\v 5 Hookahi ka'u olelo ana, aka, aole au e ekemu hou; A elua hoi, aka, aole au e olelo hou aku.
\b
\q1 
\v 6 Alaila olelo mai o Iehova ia Ioba mailoko mai o ka puahiohio, i mai la,
\q1 
\v 7 E kakoo oe ano, me he kanaka la, i kou puhaka: E ninau aku au ia oe, a hoike mai oe ia'u.
\q1 
\v 8 E hoole anei hoi oe i ko'u pono? E hoahewa anei oe ia'u, i hoaponoia'i oe?
\q1 
\v 9 He lima anei kou e like me ko ke Akua? E hiki anei ia oe ke hoohekili me ka leo e like me kona?
\b
\q1 
\v 10 E hoonani oe ano ia oe iho me ka hanohano a me ko kiekie; E hoaalu hoi ia oe iho i ka nani a me ka mahalo.
\q1 
\v 11 E hookuu aku oe i kou huhu ikaika: A nana aku i ka mea kiekie a pau, a hoohaahaa ia ia.
\q1 
\v 12 E nana aku i ka mea haaheo a pau, a e hookulou ia ia; A e hehi iho ilalo i ka poe hewa ma ko lakou wahi.
\q1 
\v 13 E hoonalo pu ia lakou iloko o ka lepo; E uhi i ko lakou maka i ka pouli.
\q1 
\v 14 Alaila e hooia aku au ia oe, E hiki no i kou lima akau ke hoola ia oe iho.
\b
\q1 
\v 15 E nana ano i ka behemo, ka mea a'u i hana'i me oe; Ua ai no ia i ka weuweu e like me ka bipi.
\q1 
\v 16 Aia hoi, ano, o kona ikaika ma kona puhaka, O kona mana hoi ma na wahi paa o kona opu.
\q1 
\v 17 Ua kunini no ia i kona huelo me he laau kedera la, O na olona o kona uha ua ulana pu ia.
\q1 
\v 18 O kona mau iwi me na auka keleawe, O kona mau iwi, ua like me na auka hao.
\b
\q1 
\v 19 Oia ke pookela o na hana a ke Akua! O ka mea nana ia i hana, haawi no ia i pahikaua nana.
\q1 
\v 20 Ua hoohua mai na mauna i ka ai nana, A malaila na holoholona a pau o ke kula i paani ai.
\q1 
\v 21 Moe iho no ia malalo o na laau malu, Maloko o kahi nalo o ka ohe a me ke kiolepo.
\q1 
\v 22 Uhi iho la na laau malu ia ia me ko lakou malu; A puni mai ia ia na wilou o ke kahawai.
\q1 
\v 23 Aia hoi, huai mai ka muliwai, aole ia i holo aku, Noho malie no ia i ka wa i huai mai ai o Ioredane i kona waha.
\q1 
\v 24 Imua o kona mau maka e hopu anei kekahi ia ia? A e hoopuka aku i kona ihu i ka lou?
\c 41
\b
\q1 
\v 1 E HOOPAA anei oe i ka leviatana me ka makau? A e kaomi i kona alelo me ke aho?
\q1 
\v 2 E hiki anei ia oe ke hookomo i ke kaula kaluha i kona ihu? A me ka makau e hoolou i kona iwia?
\q1 
\v 3 E hoomahuahua anei ia i ka nonoi ana ia oe? E olelo anei ia i na mea hooluolu ia oe?
\q1 
\v 4 A hoopaa anei ia i ka berita me oe? E lawe anei oe ia ia i kauwa mau loa?
\q1 
\v 5 E paani pu anei oe me ia me he manu la? E hoopaa anei oe ia ia no kou poe wahine opio?
\q1 
\v 6 E hana anei na makamaka ia ia i mea ahaaina? E mahele anei lakou ia ia iwaena o ka poe kuai?
\q1 
\v 7 E hiki anei ia oe ke hoopiha i kona ili i na mea oi? I kona poo hoi i na o-ia?
\q1 
\v 8 E kau oe i kou lima maluna ona, E hoomanao i ke kaua, a e hooki iho.
\q1 
\v 9 Aia hoi, o ka manao e paa aku ia ia ua make hewa: Aole anei e hina ilalo ka mea e nana aku ana ia ia?
\q1 
\v 10 Aohe mea aa e hoala ia ia: A owai la hoi ka mea e hiki ke ka imua o'u?
\q1 
\v 11 Owai ka i hana mua mai na'u, a e uku aku au? O na mea a pau malalo o ka lani, no'u ia.
\b
\q1 
\v 12 Aole au e huna i kona mau lala, Aole hoi i ka ikaika a me ka nani o kana mea kaua.
\q1 
\v 13 Owai ka mea e wehe ae i ke alo o kona kapa? Owai ka mea e komo iloko o kona mau a palua?
\q1 
\v 14 Owai ka mea e wehe ae i na pani o kona maka? O kona mau niho a puni he mea weliweli ia.
\q1 
\v 15 O kona haaheo, o kona mau palekaua paa no ia, I hoopiliia i ka mea kapili paa.
\q1 
\v 16 Ua pili kekahi i kekahi, Aole e komo ka makani iwaena o lakou.
\q1 
\v 17 Ua pili pu kekahi me kekahi, Ua hui pu ia lakou, aole e hiki ke hookaawaleia'e.
\q1 
\v 18 Ma kona kiha ana alohi mai la ka malamalama, O kona mau maka ua like me na lihilihi o ke kakahiaka.
\q1 
\v 19 Mailoko mai o kona waha hele aku na lapalapa, A lele aku na huna ahi.
\q1 
\v 20 Mailoko mai o kona mau pukaihu puka aku ka mahu, E like me ko ka ipuhao wela, a me ka ipuhao lapalapa.
\q1 
\v 21 Hoa aku kona hanu i na lanahu, A mai kona waha puka aku ka lapalapa.
\q1 
\v 22 Maloko o kona a-i ke noho la ka ikaika, A lelele ka weliweli imua ona.
\q1 
\v 23 O na wahi lewalewa o kona io ua pilipaaia, Ua paa ia ia, aole e hoonaueia.
\q1 
\v 24 O kona naau ua paa, me he pohaku la, A ua paakiki e like me ka pohaku lalo o ka wili.
\q1 
\v 25 I kona ea ana iluna, makau ka poe ikaika; No ka weliweli pihoihoi lakou.
\q1 
\v 26 O ke kau ana o ka pahikaua ia ia aole ia e paa: O ka pahi o, o ka ihe, a me ka pololu.
\q1 
\v 27 Ua manao no ia i ka hao he like ia me ka mauu maloo, A i ke keleawe me he laau popopo la.
\q1 
\v 28 Aole e hiki i ka pua pana ke hooauhee ia ia: O na pohaku o ka maa, ua like ia me ka opala.
\q1 
\v 29 Ua manaoia ka newa e like me ka opala; Ua akaaka no ia i ka naue ana o ka ihe.
\q1 
\v 30 Malalo ona na apana ipu lepo: Hohola aku ia i ka mea oi maluna o ka lepo.
\q1 
\v 31 Hoopohapoha no ia i ka hohonu, me he ipuhao la: Hana no ia i ke kai me he ipu mea hamo la.
\q1 
\v 32 Waiho no ia i ala malamalama mahope ona; Ua manaoia ka hohonu, he poohina.
\q1 
\v 33 Aohe mea like maluna o ka honua, Ka mea i hanaia me ka makau ole.
\q1 
\v 34 Nana mai no ia i na mea kiekie a pau; Oia ke alii maluna o ka poe haaheo a pau.
\c 42
\b
\q1 
\v 1 A LAILA olelo o Ioba ia Iehova, i aku la,
\q1 
\v 2 Ua ike no au, e hiki no ia oe na mea a pau; Aohe manao ou e pono ke keakeaia.
\q1 
\v 3 Owai ka mea e hoopouli ana i ka olelo ao me ka ike ole? Nolaila, ua hai aku au, aole au i noonoo pono; Na mea kupanaha, aole au i ike.
\q1 
\v 4 Ke noi aku nei au ia oe e hoolohe mai, a na'u e olelo aku; E ninau aku au ia oe, a e hoike mai oe ia'u.
\q1 
\v 5 Ua lohe au ia oe ma ka lohe pepeiao, Aka, ano, ke ike nei ko'u maka ia oe.
\q1 
\v 6 Nolaila ke hoowahawaha nei au ia'u iho, Ke mihi hoi au iloko o ka lepo a me ka lehu.
\b
\q1 
\v 7 A mahope o ka Iehova olelo ana'ku i keia mau olelo ia Ioba, olelo mai la o Iehova ia Elipaza, no Temana, Ua hoaia ko'u huhu ia oe, a i kau mau hoalauna elua: no ka mea, aole oukou i olelo mai no'u i ka mea pono, e like me ka'u kauwa, o Ioba.
\q1 
\v 8 Ano hoi, e lawe oukou no oukou iho i ehiku bipikane, a i ehiku hipakane, a e hele aku i ka'u kauwa ia Ioba, a e kaumaha i mohaikuni no oukou; a e pule aku o Ioba ka'u kauwa no oukou; no ka mea, oia ka'u e maliu ai, o hana aku au ia oukou e like me ka oukou lapuwale; no ka mea, aole oukou i olelo mai no'u i ka mea pono e like me ka'u kauwa, o Ioba.
\q1 
\v 9 A o Elipaza no Temana, o Biledada no Suha, a me Zopara no Naama, hele aku la lakou, a hana aku e like me ka Iehova i kauoha mai ai ia lakou: a maliu mai o Iehova ia Ioba.
\b
\q1 
\v 10 A hoololi ae la o Iehova i ke pio ana o Ioba, i ka manawa i pule aku ai ia no kona mau hoalauna: a haawi palua aku la o Iehova i ka Ioba mau mea a pau.
\q1 
\v 11 Alaila hele mai io Ioba la kona mau hoahanau a pau, a me kona mau kaikuwahine a pau, a me kona poe ike a pau mamua, a ai pu iho la lakou me ia i ka ai ma kona hale; a uwe lakou ia ia, a hooluolu aku ia ia no na mea ino a pau a Iehova i lawe mai ai maluna ona; a haawi aku kela kanaka keia kanaka ia ia i wahi kala, a o kela kanaka keia kanaka i wahi apo gula.
\q1 
\v 12 A hoomaikai o Iehova i ka hope o Ioba, mamua o kona mua: no ka mea, he umikumamaha ana tausani hipa, he aono tausani kamelo, a hookahi tausani kaulua bipi, a hookahi tausani hoki wahine.
\q1 
\v 13 Ehiku hoi ana mau keikikane, a ekolu kaikamahine.
\q1 
\v 14 A kapa aku la ia i ka inoa o ka mua, o Iemima; a i ka inoa o ka lua, o Kezia; a i ka inoa o ke kolu, o Kerenehapuka.
\q1 
\v 15 Aole i loaa na wahine maikai e like me na kaikamahine a Ioba ma ka aina a pau; a haawi aku ko lakou makuakane i hooilina mawaena o ko lakou mau hoahanau.
\q1 
\v 16 A mahope o keia, ola iho la o Ioba i na makahiki hookahi haneri a me ke kanaha, a ike aku la ia i kana mau keiki, a me na keiki a kana mau keiki, i eha mau hanauna.
\q1 
\v 17 A make iho la o Ioba, he elemakule, a he nui kona mau la. 
