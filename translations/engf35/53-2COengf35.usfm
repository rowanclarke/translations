\v 13 \w Now|strong="G1510"\w* \w in|strong="G1577"\w* \w just|strong="G3739"\w* \w what|strong="G5101"\w* \w were|strong="G1510"\w* \w you|strong="G5210"\w* \w treated|strong="G2274"\w* \w as|strong="G3739"\w* \w inferior|strong="G2274"\w*, \w compared|strong="G1510"\w* \w to|strong="G3756"\w* \w the|strong="G3588"\w* \w other|strong="G3062"\w* congregations, \w except|strong="G1487"\w* \w that|strong="G3754"\w* \w I|strong="G1473"\w* \w myself|strong="G1473"\w* \w did|strong="G5101"\w* \w not|strong="G3756"\w* \w burden|strong="G2655"\w* \w you|strong="G5210"\w*? \w Forgive|strong="G5483"\w* \w me|strong="G1473"\w* \w this|strong="G3778"\w* wrong.\f + \fr 12:13 \ft Yes, it probably was a ‘wrong’, because they were not taught how God's economy works. If Paul had taught them the content of chapter nine of this letter early on, a considerable portion of this letter would not have been necessary.\f*
\s2 Still not burdening
\p 
\v 14 \w Well|strong="G2532"\w* \w now|strong="G2532"\w*, \w I|strong="G2532"\w* \w am|strong="G2532"\w* \w ready|strong="G2093"\w* \w to|strong="G4314"\w* \w come|strong="G2064"\w* \w to|strong="G4314"\w* \w you|strong="G5210"\w* \w a|strong="G2192"\w* \w third|strong="G5154"\w* \w time|strong="G5154"\w*, \w and|strong="G2532"\w* \w I|strong="G2532"\w* \w will|strong="G2532"\w* \it still\it* \w not|strong="G3756"\w* \w burden|strong="G2655"\w* \w you|strong="G5210"\w*, \w because|strong="G1063"\w* \w I|strong="G2532"\w* \w want|strong="G2212"\w* \w you|strong="G5210"\w*, \w not|strong="G3756"\w* \w your|strong="G2192"\w* \w things|strong="G3778"\w*—\w children|strong="G5043"\w* \w should|strong="G3784"\w* \w not|strong="G3756"\w* \w have|strong="G2192"\w* \w to|strong="G4314"\w* \w save|strong="G2343"\w* \w up|strong="G2343"\w* \w for|strong="G1063"\w* \w parents|strong="G1118"\w*, \w but|strong="G2532"\w* \w parents|strong="G1118"\w* \w for|strong="G1063"\w* \w children|strong="G5043"\w*.
