\c 29  
\s1 Reinado de Ezequías en Judá  
\p
\v 1 Ezequías tenía 25 \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* 29 \w años|strong="H8141"\w* en Jerusalén. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H2568"\w* su madre fue Abías, \w hija|strong="H1323"\w* \w de|strong="H2568"\w* \w Zacarías|strong="H2148"\w*.  
\v 2 \w Hizo|strong="H6213"\w* \w lo|strong="H6213"\w* \w recto|strong="H3477"\w* ante \nd \+w Yavé|strong="H3068"\+w*\nd*, según \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* \w hizo|strong="H6213"\w* su antepasado \w David|strong="H1732"\w*.   
\p
\v 3 \w El|strong="H1931"\w* \w primer|strong="H7223"\w* \w año|strong="H8141"\w* de \w su|strong="H1931"\w* \w reinado|strong="H4427"\w*, \w el|strong="H1931"\w* \w mes|strong="H2320"\w* \w primero|strong="H7223"\w*, \w él|strong="H1931"\w* \w abrió|strong="H6605"\w* las \w puertas|strong="H1817"\w* de \w la|strong="H1931"\w* \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd* y las reparó.  
\v 4 Acercó \w a|strong="H3068"\w* los \w sacerdotes|strong="H3548"\w* y \w levitas|strong="H3881"\w*, los reunió en la plaza \w oriental|strong="H4217"\w*  
\v 5 y les dijo: Escúchenme, \w levitas|strong="H3881"\w*. Santifíquense, santifiquen la \w Casa|strong="H1004"\w* \w de|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* el \nd ʼElohim\nd* \w de|strong="H4480"\w* sus antepasados y quiten la impureza \w del|strong="H4480"\w* \w Santuario|strong="H6944"\w*.  
\v 6 \w Porque|strong="H3588"\w* nuestros antepasados \w fueron|strong="H5869"\w* infieles \w e|strong="H3068"\w* \w hicieron|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* \w ante|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd*. \w Lo|strong="H6213"\w* abandonaron, voltearon sus caras del \w Tabernáculo|strong="H4908"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w y|strong="H3588"\w* \w le|strong="H5869"\w* \w dieron|strong="H5414"\w* \w la|strong="H3588"\w* espalda.  
\v 7 \w También|strong="H1571"\w* \w cerraron|strong="H5462"\w* las \w puertas|strong="H1817"\w* del patio, apagaron las \w lámparas|strong="H5216"\w* \w y|strong="H1571"\w* \w no|strong="H3808"\w* quemaron incienso \w ni|strong="H3808"\w* ofrecieron \w holocaustos|strong="H5930"\w* en \w el|strong="H1571"\w* \w Santuario|strong="H6944"\w* \w al|strong="H5930"\w* \nd ʼElohim\nd* de \w Israel|strong="H3478"\w*.  
\v 8 \w Por|strong="H5921"\w* eso \w la|strong="H5921"\w* \w ira|strong="H7110"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* cayó \w sobre|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* Jerusalén. \w Él|strong="H5921"\w* \w los|strong="H5921"\w* convirtió \w en|strong="H5921"\w* un objeto \w de|strong="H5921"\w* terror, horror \w y|strong="H5921"\w* escarnio \w como|strong="H1961"\w* \w lo|strong="H5921"\w* \w ven|strong="H7200"\w* sus propios \w ojos|strong="H5869"\w*.  
\v 9 \w Ciertamente|strong="H2009"\w* \w por|strong="H5921"\w* \w esto|strong="H2063"\w* nuestros antepasados \w cayeron|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w y|strong="H5921"\w* nuestros \w hijos|strong="H1121"\w*, \w hijas|strong="H1323"\w* \w y|strong="H5921"\w* \w mujeres|strong="H1323"\w* \w están|strong="H2009"\w* \w cautivos|strong="H7628"\w*.   
\p
\v 10 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, decidí \w hacer|strong="H3772"\w* un \w pacto|strong="H1285"\w* \w con|strong="H5973"\w* \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w para|strong="H4480"\w* \w que|strong="H4480"\w* \w el|strong="H5973"\w* ardor \w de|strong="H4480"\w* su \w ira|strong="H2740"\w* \w se|strong="H4480"\w* \w aparte|strong="H5973"\w* \w de|strong="H4480"\w* \w nosotros|strong="H5973"\w*.  
\v 11 \w Por|strong="H3588"\w* tanto, \w hijos|strong="H1121"\w* míos, \w no|strong="H3588"\w* \w sean|strong="H1961"\w* negligentes, \w porque|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w los|strong="H1121"\w* escogió \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w estén|strong="H1961"\w* \w ante|strong="H6440"\w* \w Él|strong="H3588"\w* \w y|strong="H3588"\w* le sirvan, \w a|strong="H3068"\w* fin \w de|strong="H3588"\w* \w que|strong="H3588"\w* le ministren \w y|strong="H3588"\w* le \w quemen|strong="H6999"\w* incienso.   
\p
\v 12 Entonces \w se|strong="H4480"\w* \w levantaron|strong="H6965"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*: Mahat, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Amasai|strong="H6022"\w*, y \w Joel|strong="H3100"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Azarías|strong="H5838"\w*, \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Coat; y \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Merari|strong="H4847"\w*, \w Cis|strong="H7027"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Abdi, y \w Azarías|strong="H5838"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Jehalelel; y \w de|strong="H4480"\w* \w los|strong="H1121"\w* gersonitas, Joa, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Zima, y Edén, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Joa;  
