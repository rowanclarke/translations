\v 16 \w Por|strong="G1223"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w* \w en|strong="G1909"\w* \w el|strong="G3588"\w* \w Nombre|strong="G3686"\w* \w de|strong="G1909"\w* \w Él|strong="G3588"\w*, \add el Señor \add*fortaleció \w a|strong="G1909"\w* \w éste|strong="G3778"\w* \w que|strong="G3588"\w* \w ven|strong="G2334"\w* \w y|strong="G2532"\w* \w conocieron|strong="G1492"\w*. \w La|strong="G3588"\w* \w fe|strong="G4102"\w* \w en|strong="G1909"\w* \w el|strong="G3588"\w* \w Nombre|strong="G3686"\w* \w de|strong="G1909"\w* \w Él|strong="G3588"\w*, \w le|strong="G1909"\w* \w dio|strong="G1325"\w* \w esta|strong="G3778"\w* completa sanidad \w delante|strong="G1909"\w* \w de|strong="G1909"\w* \w todos|strong="G3956"\w* ustedes.   
