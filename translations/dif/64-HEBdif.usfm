\id HEB  
\ide UTF8
\h Hebräalani 
\toc1 Dakani jaura Hebräer milini 
\toc2 Hebräalani 
\toc3 Heb 
\mt1 Dakani jaura Hebräer milini.  
\c 1  
\lit (Dakani jaura Jesuja dankani ditjini parkulani.)  
\p
\v 1 Godali warula pota marapu ja nguja pilki ja pilkini matja kaukaubana ngaperi worani Prophetani,   
\p
\v 2 Nulia nunkangupini ditjini mudanani ngaianangu kaukaubana wonti Ngatamurani, ninaia Nulia kurana wonti maratunka maninietjani warupotuni, nunkanali Nulia bakana mita maru pantjimana wonti,   
\p
\v 3 Nulupini, Nauja nunkanaia pirnalaia kintjalkuru nganai, ja nunkanaia ngujaia mudla kulno, ja Nulupini, Nulia warupoto mandrai nunkanaia ngurulaia jaurali, kulirkani ngankana wonti madlentjandru nunkanali muntali, ja ngamana ngarina wonti pirnalaia ngunarani mirini,   
\p
\v 4 Ja jeruntja morla pirna pantjina wonti angelani, worderuntja morla pirna tala nunkani nganai tanangu, ninaia Nulia maratunka manina wonti.   
\p
\v 5 Ngangau worangu angelani Nauja kara ngopera jatana wonti: „Jidni Ngatamura ngakani nganai, karari ngato jidna kantji patana warai.“ Ja nakaldra: „Ngani nunkangu Ngaperi nganala nganai, ja nauja ngakangu Ngatamura.“   
\p
\v 6 Nulia poto mandrulani Panturu mitani matja wirilkana, Nauja jatai: „Godaia angela warupoto nunkangu ngatjinanto.“   
\p
\v 7 Angela worandru Nauja jatai: „Nulia angela nunkani watara ngankai, ja mili nunkani turujaola.“   
\p
\v 8 Ja Ngatamurani: „Godajai, pirnalaia piri jinkani ngurali parai; jinkani mililaia jirijiribani talku nganai;   
\p
\v 9 Jundru talkula ngantjana wonti, ja talkula panini jidni kalakalarina wonti; jendrangundruja jidna, Godajai, Goda jinkani mankini gildieli wiribana wonti, morla pirna ngampu marani jinkanani.“   
\p
\v 10 Ja: „Jundru, Kaparajai, mita maru kurana wonti, ja pariwilpa wora jinkani maraia ngankani nganai,   
\p
\v 11 Tana mudala nganai, ja jidni ngurali ngamala nganai, ja tana warurila nganai kati jeribaka.   
\p
\v 12 Ja kati jeribaka jundru tanana walpi ngankala nganai ja bakakaritjila nganai; ja jidni jenilu, ja kilpawoldra jinkani wata mudala nganai.“   
\p
\v 13 Worangu angelani Nauja ngopera jatana wonti kara: „Ngakangu ngunarani ngamana ngariau, ngato talpala jinkani jinkangu tidnani kuranantulu, tidnaparani piri jeribaka?“   
\p
\v 14 Wata tana pratjana mili jaola nganai, tanana matja jinpana tanangundru, tanali tepi ngurali maratunka maninanto?   
\c 2  
\p
\v 1 Jendrangundruja ngaiana jenia morla ngamalkananto, mina ngaiana ngarana wonti, ngangau ngaiana kekiljeriati.   
\p
\v 2 Ngangau naupini jaura, angelali matja kaukaubana, ngurunguru ngananani, ja dankarana ja delkina pratjanali kalala talku maninani,   
\p
\v 3 Worderu ngaiana mindrinanto, ngaiana jenipara murla pirna wata ngundranani? Ninapini ngopera Kapara muntali kaukaubana wonti, ja ngadani tanali, nunkangundru matja ngarana, ngaianangu morlalu kurana wonti.   
\p
\v 4 Ja Godali tanangu jela tinkari ngankana wonti malkali, ja pirnalali, ja ngurula pilki ja pilkieli, ja Jaola kulikirila puntibanali, nunkani jertapaterinandru.   
\p
\v 5 Ngangau wata angelani Nulia wodatarana kurana wonti ninapini mita, nau wokarananto, nunkangundru ngaiana jatai.   
\p
\v 6 A‐ai, kulnujeli piri kulnuni tinkari ngankana wonti jeruja: „Mina naupini Kana nganai, ngangau jundru ninaia ngundrai, Kanaia Ngatamura kara, ngangau jundru ninaia ngurutalpana najiai?   
\p
\v 7 Miljaru wordu jundru ninaia angelani ngarinalu kurana wonti, pirnalali ja ngurulali jundru nunkangu pirapira kurana wonti, ja jundru ninaia Kapara kurana wonti jinkanaia maraia ngankanani;   
\p
\v 8 Warupoto jundru nunkangu tidna ngalpani kurana wonti.“ Ngangau Nulia nunkangu tidna ngalpani warupoto kurana wonti, Nulia panila worani patana wonti; karari ngaiana wata najiai, warupoto nunkangu ngalpani matja parai.   
\p
\v 9 Windri karari ngaiana najiai ninaia, Nauja wordu angelani ngarinalu nganana wonti, Jesus, nunkangu Nulia nunkani naria ketjaketjanandru pirnalali ja ngurulali pirapira kurana wonti, ngangau Nulia Godaia manjulandru nari wontjana wonti warupotuja.   
\p
\v 10 Nunkangu talku nganana wonti, nunkangundru ja nunkanali warupoto nganai, ngangau Nulia ngatamura marapu wapalkananto pirnalaia, tanani murlaia wapalkanietja ketjaketjanali manamiri ngankala.   
\p
\v 11 Ngangau warupoto kulnundru nganai, kulikiri ngankanietja ja taua kulikiri pantjiai; jendrangundruja Nauja wata nintali nganai tanana ngatata dikala.   
\p
\v 12 Ngangau Nauja jatai: „Ngato tala jinkani ngatatani ngakanani kaukaubala nganai, ja mili wolarani terti ngato jidna jurakokani wimali jurakokala nganai.“   
\p
\v 13 Ja nakaldra: „Ngato nunkangu morlalu ngundrala nganai.“ Ja nakaldra: „Najiau, ngani ja ngatamura ngakani, tanana Godali ngakangu jinkina wonti.“   
\p
\v 14 Ngangau kupali palku ja kumari jela ngamalkai, Nulia ninaia tanangu jeribaka manina wonti, ngangau Nulia narieli ninaia palimananto, nulia naria ngurula ngamalkai, jenia nganai kutji,   
\p
\v 15 Ja tanana kurakana wonti, tana naria japandru tepiwirdi mili dupudupu nganananto.   
\p
\v 16 Wata angela Nulia patai, a‐ai, Abrahamani ngatamura Nulia patai.   
\p
\v 17 Jendrangundruja Nulia warupotuni ngatatani jeribaka pantjinanto, ngangau Nulia kalumiltjamiltjarini ja talku Priesta pirna pantjinanto Godangu, kana wolaraia madlenjandru kalala jinkila.   
\p
\v 18 Worderu Nauja ketjaketjana wonti, ja kutjieli ninaia wontjana wonti, jeruja Nauja ngurunguru nganai tanangu marangokala, tanana nulu wontjai.   
\c 3  
\p
\v 1 Jendrangundruja, ngatata kulikiriai, pariwilpaia karkani ngampu mara worajai, najinajibanau ngaiananaia dikani jauraia Apostel, ja Priesta pirna, Jesus,   
\p
\v 2 Nauja talku nganai nunkangu, Nulia ninaia kurana wonti, worderu bakana Moses nunkani pungani warupotuni.   
\p
\v 3 Ngangau morla pirnala Nulupini manina wonti Mosingu, worderu nulu morla pirnala ngamalkai pungani, nulu ninaia matja ngankingana.   
\p
\v 4 Ngangau punga pilki ja pilki kanali ngankingai, Nulia warupoto ngankingana wonti Goda nganai.   
\p
\v 5 Ja Moses talku nganana wonti nunkani pungani warupotuni, mili jeribaka malka morlalu nunkangu, mina kaukaubananto,   
\p
\v 6 Ja Christus Ngatamura jeribaka pungani nunkanani; nunkanaia punga ngaiana nganai, ngaiana kalkani morlalu ngundrana ja pirnala mudanajeli ngurunguru ngamalkanani.   
\p
\v 7 Jendrangundruja, worderu Jaola kulikiri jatai: „Karari, jura ngaiala nunkani ngaranani,   
\p
\v 8 Jeruja ngara juranina wata ngurunguru ngankanau, worderu kaldrini wontjanilaia ditjini pitarani;   
\p
\v 9 Jendranguta ngaperali juranali ngana wontjana wonti, ja ngana najinajibana wonti, ja ngankana ngakani najina wonti kilpawodra pota mandrumandru marapratjana.   
\p
\v 10 Jendrangundruja ngani tanangupini ngujani kaldririna wonti, ja jatana wonti: Milingeru tanalia ngarali tjautjau ngundrai ja tanalia palto ngakani wata ngujamana warai,   
\p
\v 11 Jeruja ngato bakana tirini ngakanani morlalu kurana wonti: Tanaia wata wirinanto ngara ngamanaia ngakanaia.“   
\p
\v 12 Ngamalkaterianau, ngatata worajai, kulnuni jurangundru morlalu ngundrani pania ngara madlentji nganaiati, nau puriati Goda tepindru;   
\p
\v 13 A‐ai, kurukurubijiribamalianimai ditjini warupotuni, jeruntjaia tanali karari dikai, madlentjaia jedibanali kulnuni jurangundru ngurunguru ngankaiati.   
\p
\v 14 Ngangau ngaiana Christuni ngampumara pantjina wonti, ngaiana morlalu ngundranaia wonini mudanajelu ngurunguru ngamalkanani.   
\p
\v 15 Matja jatanani: „Karari, jura ngaiala nunkani ngaranani, jeruja ngara juranina wata ngurunguru ngankanau,“ worderu kaldrini,   
\p
\v 16 Warletana ngaranietja nganana wonti, tana kaldri ngankaterina wonti? Wata tana pratjana, tana Egypta mitandru dunkana wonti Mosili?   
\p
\v 17 Warletana nganai, tanangu Nauja kaldririna wonti kilpawoldra pota mandrumandru marapratjana? Wata tanali, tana madlentji ngankana wonti, tanani palku pitarani parantina wonti?   
\p
\v 18 Worangu Nulia morlalu kurana wonti, tana wata nunkani ngara ngamanaia wirinanto? Windri tanangu, tana delkina wonti?   
\p
\v 19 Ja ngaiana najiai, tana ngandandarina wonti wirila morlalu ngundrana panindru.   
\c 4  
\p
\v 1 Jeruja ngaiana japali nganananto, wata kulno jurangundru ngadani ngamani wokaraiati, ngangau talpadakani jaura kulno, nunkani ngara ngamanaia wirila, morla parai.   
\p
\v 2 Ngangau bakana ngaianangu ngantjani jaura wokarana wonti, tanangu jeribaka; windri kaukaubani jaura tanangu baku nganana wonti, ngangau nauja ngaranietjani wata tuldruwana wonti.   
\p
\v 3 Ngaiana, ngaiana matja morlalu ngundrana, ngara ngamanani wirila nganai, worderu Nauja jatana wonti: „Jeruja ngato tirini ngakanani kurana wonti, tana wata ngara ngamanaia ngakanaia wirinanto;“ windrila ngankana mitaia kuranandru matja mudanala.   
\p
\v 4 Ngangau Nauja piri kulnuni ditji mara wora ja mandrundru jeruja jatana wonti: „Ja Goda ditji mara wora ja mandrulani ngara ngamana wonti nunkani ngankana pratjanandru.“   
\p
\v 5 Ja nunkangupini pirini nakaldra: „Ja tana wata ngara ngamanaia ngakanaia wirinanto.“   
\p
\v 6 Jeruja matja parai, palpa nunkangu wirila nganai; ja tanali, tana ngopera ngantjani jaura ngaranala, wata wirina wonti delkinandru,   
\p
\v 7 Jeruja Nulia nakaldra ditji kulno kurai, „karari kulno,“ ja Davidangu miljaru wirdini jatai, worderu ngopera jatana warai: „Karari, jura ngaiala nunkani ngaranani, juranina ngara wata ngurunguru ngankaterianau.“   
\p
\v 8 Josuali tanana ngara ngamanaia matja wirilkanani, jeruja Nulia wata ditji ngurundru nunkangu ngadani jatanani.   
\p
\v 9 Jeruja Sabbath ngara ngamana Godaia kana wolarani morla parai:   
\p
\v 10 Ngangau warle ngara ngamanaia nunkanaia matja wirina, nau bakana ngara ngamai nunkani ngankanandru, worderu Goda nunkanandru.   
\p
\v 11 Jeruja ngaiana nururinanto nunkangupini ngara ngamanani wirila, wata kulno nunkanipini delkinaia malkani jeri purinanto.   
\p
\v 12 Ngangau Godaia jaura tepi ja ngurunguru nganai, ja morla tjerkara nganai mardakirrani tjerkara mandrunto, ja nauja palkingai mungara ja jaola diltja ja mokugildi puntibalalu, ja ngara tjuruja ja ngundranaia kalala kuranietja nganai,   
\p
\v 13 Ja wata pantjimani poto kulno kurukuru nganai nunkangu, a‐ai, warupoto nunkangu milkini balu ja tinkari parai, ninaia ngaiana ngundrai.   
\p
\v 14 Ngangau ngaiana Priesta pirna pirna ngamalkai, nauja pariwilpa worangu palkingana wonti, Jesus, Godaia Ngatamura, jeruja ngaiana dikani jaura ngurungurujeli ngamalkananto.   
\p
\v 15 Ngangau ngaiana wata Priesta pirna ngamalkai, Nauja ngandandariai kara waltowaltuni ngaiananani ngujangujala ngundrala, a‐ai, jenipara, Nauja ngaianangu jeribaka nguja pratjanani wontjanilani wirina wonti, windri madlentji pani.   
\p
\v 16 Jeruja ngaiana murlali manjulaia ngamani pirini wokarananto, ngaiana kalumiltjamiltjarina maninanto ja manjula mankamankananto marangokani ditjini talkuni.   
\c 5  
\p
\v 1 Priesta pirna worali, kanandru matja manina, ja kurana Godangu kanaia, nulu kalumiltjamiltjarini poto ja poto ngumu jinkinanto madlentjaia.   
\p
\v 2 Kulno jeribaka, nau burkali nganai kana koni ja mangapunkuni, ngangau bakana nunkangu waltowalto parana karitjiai,   
\p
\v 3 Ja nunkangundru nau wilpa nganai, worderu kana wolaraia, jeruja bakana nunkangundru muntali poto ngumu jinkila madlentjandru.   
\p
\v 4 Ja wata kulnujeli ninapini pirnala muntali maniai, a‐ai, worangu Godali karkai, Aaron jeribaka.   
\p
\v 5 Jeruja bakana Christus wata munta pirna ngankaterina wonti Priesta pirna nganala, a‐ai, Nulia, Nauja nunkangu jatana wonti: „Jidni Ngatamura ngakani nganai, karari ngato jidna kantji patana warai.“   
\p
\v 6 Worderu Nauja bakana piri kulnuni jatai: „Jidni Priesta ngurali nganai Melchisedek manginani.“   
\p
\v 7 Nulia nunkani palkuja ditjini ngatjini ja karkani maritjini pirnali ja milkigildieli jinkina wonti nunkangu. Nauja ngurunguru nganai, ninaia narindru kulkala; ja Nulia ninaia bakana ngarana wonti nunkani japandru,   
\p
\v 8 Nauja kantji Ngatamura nganana wonti, ja Nulia kiririna wonti pankila nunkani ketjaketjanani,   
\p
\v 9 Ja Nulia matja mudana warai, Nauja tanangu pratjanani, tana nunkangu pankiai, murlaia tepi Jinkinipirna pantjina wonti,   
\p
\v 10 Ninaia Godali dikana wonti Priesta pirna Melchisedek manginani.   
\p
\v 11 Nunkangundru ngaiana marapu ngamalkai jatala, windri jenia mati nganai mildiri ngankala, ngangau jura njani pantjina warai ngaranani.   
\p
\v 12 Miljaru wirdindru jura morlalu ngujangujara jinkinietja nganananto, ja karari jura ngujangujara maninanto Godaia tinkari ngankani ngoperandru, ja jurangu ngumu nganai windri milki manina ja wata tajina ngurunguru.   
\p
\v 13 Ngangau worangu milki jinkinanto, nau patipati nganai talkulaia ngujangujarani; nau kupa waka nganai.   
\p
\v 14 Kana pirnani tajini ngurunguru parai, tanangu, tana tjuru talku ngamalkai ngumu ja madlentji puntibala, ngangau tana tjuru matja ngankingana warai.   
\c 6  
\p
\v 1 Jendrangundruja ngaiana worarananto wonini jaura Christungundru, ja jaura pirnani wapananto; ja wata nakaldra woninanto ngankani nari karitjinandru, ja morlalu ngundranandru Godani,   
\p
\v 2 Multibanaia ngujangujarandru, mara kuranandru, nari jiritjinandru, ja kalala ngadanindru.   
\p
\v 3 Jenia ngaiana ngankala nganai, Godali jenia manuni kuranani.   
\p
\v 4 Ngangau jenia ngandandariai, tanapini, tanali pota kulno tjenmararinala, ja pariwilpaia poto wontjanala, ja Jaola kulikiri maninala,   
\p
\v 5 Ja Godaia jaura ngumu, ja mita marraia ngurula wontjanala,   
\p
\v 6 Ja ngadani purinala, tanana nakaldra marraribala madlentjandru karitjinaia, ngangau tanali nakaldra Godaia Ngatamura kunarkuni katibai, ja ninaia ngirkibani ngankai.   
\p
\v 7 Ngangau mitali, nulia talara matja tapanani, nau pota marapu nunkangu godana warai, ja kanta dunkalkanani tanangu, tanali ninaia ngankingai, nulupini Godaia poto maniai;   
\p
\v 8 Nulu dilka ja malto dunkalkanani, jeruja nau madlentji nganai ja dikidikibanani karakara, ja mudani nunkani jerkini nganai.   
\p
\v 9 Ngaiani morlalu ngundrai, ngatata ngantjalu, jura morla ngumu nganai ja tepi ngamalkai, ngaiani bakana jeruja jatanani.   
\p
\v 10 Ngangau Goda wata talku pani nganai, Nulia wata kuritarai jurani ngankana ja ngantjana, ninaia jura nunkani talani wondranala, ngangau jura kana kulikirini mili ngamanala, ja mili ngamai.   
\p
\v 11 Ngaiani ngantjai, jura pratjanali ninapini jigleri wondrananto, kalkani morlalu ngamalkananto mudanajelu,   
\p
\v 12 Jura wata njani pantjinanto, a‐ai, tanangu karipaterinanto, tanali morlalu ngundranali ja manjujeli talpadakani maratunka maniai.   
\p
\v 13 Ngangau Godali Abrahamangu talpadakani jaura matja jinkina, Nulia muntali morlalu kuraterina wonti, ngangau Nauja ngandandarina wonti Kapara morla pirnani morlalu kurala,   
\p
\v 14 Ja jatana wonti: „Ngato jidna ngurungutala nganai ja maruribala nganai.“   
\p
\v 15 Ja ngangau nulu manujeli kalkana wonti, nulu talpadakani manina wonti.   
\p
\v 16 Kanali morlalu kurai kulno morla pirnani, ja tjakakani pratjana mudai, ja ngurunguru parai morlalu kuranali.   
\p
\v 17 Jeruja Godali, ngangau Nulia talpadakani maratunka maninietjani ngantjana wonti nunkani ngopera kurani morlalu jinkinanto, jaura morlalu kurana wonti,   
\p
\v 18 Ngaiana pota ngurunguru mandrujeli (ngangau Goda ngandandariai jedi jaura kurala) ngankalkani pirna ngamalkai, ngangau ngaiana ninapini kalkani ngamalkai, nauja parai nunkangu mindrila;   
\p
\v 19 Ngaiana mungaraia manakirra ngurunguru ja morlalu ngamalkananto, nauja wiriai kati pirnani mandrani,   
\p
\v 20 Jera Jesus, ngopera mindrinietja, ngaianangu wirina wonti; ngangau Nauja Priesta pirna pantjina wonti Melchisedek manginani ngurali.   
\c 7  
\p
\v 1 Naupini Melchisedek, Salemini mitaia kapara, Godaia pirnaia Priesta, nau Abrahamangu mandurina wonti, nau mitaia kaparaia tirimalinandru tikanani, ja nina ngurungutana wonti;   
\p
\v 2 Nunkangu bakana Abrahamali marapratjanandru buru kulno jinkina wonti pratjanandru, nina tanali ngopera dikana wonti „Talkulaia Kapara,“ ja ngadani bakana kapara Salemingundru, jenia nganai: „Murlaia Kapara;“   
\p
\v 3 Ngaperi pani, ngandri pani, mardu pani, nunkani ditji wata woninala, ja nunkani tepi wata mudala nganai, a‐ai, nau Godaia Ngatamurani jeribaka pantjina wonti, nau Priesta nganai ngurali.   
\p
\v 4 Najianau, mina kana pirna naupini nganai, nunkangu bakana Abrahamali Patriarchali marapratjanandru buru kulno jinkina wonti manini poto ngumundru.   
\p
\v 5 Bakana Levita ngatamura ngadala, tanali Priesta ngamalkijiribani maninala, jirijiribani jaura ngamalkai, marapratjanandru buru kulno jirijiribani jaurandru kana wolarandru manila, tana bakana Abrahamani kapandru dankana wonti,   
\p
\v 6 Nulupini, nau wata tanani mardundru nganana wonti, Abrahamangundru marapratjanandru buru kulno manina wonti; ja nulu nina ngurungutana wonti, nulu talpadakani jaura ngamalkana wonti.   
\p
\v 7 Tjakakani jaura panini pirnantali wakanila ngurungutai.   
\p
\v 8 Ninkida naria kanali marapratjanandru buru kulno maniai, jerra kulnujeli, nunkangundru jaura morlalu parai, Nauja tepi nganai.   
\p
\v 9 Ja ngani jeruja jatananto, Abrahamangundru bakana Levili, nulu marapratjanandru buru kulno maniai, marapratjanandru buru kulno jinkina wonti;   
\p
\v 10 Ngangau nau jendranguta ngaperani nunkanani kapani nganana wonti, nunkangu Melchisedek mandurinani.   
\p
\v 11 Levita Priesta ngamalkijiribani manamirila jinkinani, (ngangau jendrangundruja kana wolarali jirijiribani jaura manina wonti) minandru ngadani Priesta pilki, Melchisedekani manginani terkakananto, ja wata Aaronani manginani?   
\p
\v 12 Ngangau Priesta ngamalkijiribani pilki pantjinani, bakana jirijiribani jaura pilki pantjinanto.   
\p
\v 13 Naupini, nunkangundru jenia matja jatana, mardu pilki nganai, nunkangundru wata kulno Altaraia mili ngananala.   
\p
\v 14 Ngangau tinkari nganai, Judandru Kapara ngaianani kuririna tarana wonti, nunkangupini marduni Mosili wata Priesta ngamalkijiribanandru kaukaubana wonti.   
\p
\v 15 Ja morla kantji nganai, Melchisedek manginani Priesta pilki terkakanani,   
\p
\v 16 Nauja wata palkuja jirijiribani jauraia jirijiribanandru jenia pantjina wonti, a‐ai, tepi nguralia ngurulandru.   
\p
\v 17 Ngangau Nulia morlalu kurai: „Jidni Priesta nganai ngurali Melchisedek manginani.“   
\p
\v 18 Jeruja jirijiribani jaura ngopera mudai nunkani waltuwaltundru ja bakundru,   
\p
\v 19 Jirijiribani jaura panila talku ngankana wonti; windri kalkani morla pirna wirilkana wonti, nunkanali ngaiana Godani karakarariai.   
\p
\v 20 Ja jenia wata pantjina wonti morlalu kurani panini, — ngangau tana Priesta pantjina wonti morlalu kurani panini,   
\p
\v 21 Naupini morlalu kuranali nunkangundru, Nauja nunkangu jatana wonti: „Kaparali morlalu kurana wonti, ja Nauja wata burkaljerila nganai: «Jidni Priesta nganai ngurali Melchisedekani manginani.»“ —   
\p
\v 22 Jeruja Jesus bakana Testamenta morla ngumuja Kapara pantjina wonti.   
\p
\v 23 Ja jerra marapu Priesta pantjina wonti, ngangau narieli tanana ngandrawalkana wonti milingeru ngamananto;   
\p
\v 24 Nulupini, Nauja ngurali ngamai, Priesta ngamalkijiribani ngurali ngamalkai.   
\p
\v 25 Jendrangundruja Nauja ngurunguru nganai tanana kulkala, tana nunkanali Godani karakarariai, ngangau Nauja ngurali tepi, ja tanangu jurajuralkai.   
\p
\v 26 Ja jenipara Priesta pirna ngaiana ngamalkananto, Nauja kulikiri nganai, madlentji pani, murumuru pani, madlentji ngankanietjani pilki, ja morla miri pariwilpani.   
\p
\v 27 Nulupini wata ditji pratjanani Priesta pirna jeribaka, ngopera nunkani madlentjandru poto ngumu jinkinanto, ja ngadani kana wolaraia madlentjandru, ngangau jenia Nulia pota kulno ngankana wonti, Nauja munta poto ngumu jinkiterinani.   
\p
\v 28 Jirijiribani jaurali kana Priesta pirna kurai, tana waltowalto nganai; morlalu kuranaia jaurali jirijiribani jaurandru Ngatamura Kulno kurai, Nauja ngurali talku nganai.   
\c 8  
\p
\v 1 Naupini jaura kapara nganai, nunkangundru ngaiana jatai: Jenipara Priesta pirna ngaiana ngamalkai, Nauja pirnalaia pirini ngunarani pariwilpani ngamana ngarina wonti,   
\p
\v 2 Nauja Ngamalkijiribanipirna nganai poto kulikiria ja punga morlaluja, ninaia Godali ngankingana wonti, ja wata kanali.   
\p
\v 3 Tanali Priesta pirna kurai, nulu jinkini poto ja poto ngumu jinkinanto; jendrangundruja bakana Nulupini minakulno ngamalkananto jinkila.   
\p
\v 4 Nauja mitani ngamanani, Nauja wata Priesta ngananani, ngangau poto jinkinietja jirijiribani jaurali kurai,   
\p
\v 5 Tana pariwilpaia mudlamalka ja pungala jeri ngamalkijiribani ngankai, worderu Mosili jirijiribani jaura manina wonti, jendranguta nulu punga ngankingananto: „Najiau, Nauja jatai: Warupoto nunkangupini malkani jeribaka ngankamai, worderu ngato jinkangu mardawonpani wondrana warai.“   
\p
\v 6 Jeruja Nulia ngamalkijiribani morla pirna manina wonti, ngangau Nauja Testamenta morla ngumuja Tertietja nganai, Nauja talpadakani jaura morla ngumu ngamalkai.   
\p
\v 7 Ngangau naupini Testamenta ngopera madlentji pani ngananani, jeruja Nulia wata kulno nguruni piri wontinani.   
\p
\v 8 Ja Nulia tanana kalakalana wonti ja jatana wonti: „Mai, ditji wokarala nganai, Kapara jatai, ngato Israelani pungani ja Judani pungani Testamenta marra talku terkibana tarala nganai,   
\p
\v 9 Wata jenipara Testamentani jeribaka, ninaia ngato tanani ngaperani kurana wonti, nunkangupini ditjini, ngato tanana marali patana wonti, tanana Egypta mitandru dunkalkala; ngangau tana wata ngakani Testamentani ngamana wonti, jeruja ngato tanana worani patana wonti, Kapara jatai.   
\p
\v 10 Ngangau naupini nauja Testamenta nganai, ninaia ngato Israel pungani tanangupini ditjini ngadani kurala nganai, Kapara jatai: Ngato jirijiribani jaura ngakani tanani tjuruni jinkila nganai, ja tanangu ngarani dakala nganai, ja ngani tanani Goda nganala nganai, ja tana ngakani kana wolara.   
\p
\v 11 Ja tanali wata ngujangujara jinkinanto kulnujeli nunkani kamanelini, ja kulnujeli nunkani ngatatani, jeruja jatana: Kapara ngujamanau; ngangau kana pratjanali ngana ngujamala nganai kupandru pirnajelu.   
\p
\v 12 Ngangau ngani manju nganala nganai tanani talkula panini, ja tanani madlentji ngato wata morla ngundrala nganai,“   
\p
\v 13 Nauja jatai: „Kulno marra,“ jeruja Nulia ninaia ngopera womala matja ngundrana; ja mina womala ja pinaru nganai, jenia mudani karakara nganai.   
\c 9  
\p
\v 1 Bakana Testamenta ngoperala Godaia ngamalkijiribani talkula ngamalkana wonti, ja nunkanipini mitaia kulikirila.   
\p
\v 2 Ngangau punga kulno terkana wonti, ngoperala, nunkangu mandrani praitji poto ja kurli ja wondrani buka parana wonti, nina tanali dikai: Kulikiri.   
\p
\v 3 Kati mandru pirnani ngadani punga kulno, nina tanali dikai: Kulikiri pirna;   
\p
\v 4 Nunkangupini parana wonti turutupu Altara marda maraljendru, ja Testamentaia pirra kulikiri, paruparu marda maraljeli walpani, nunkangupini parana wonti koko kulno Mananto marda maraljendru, ja Aaronani pita, nau kuljakuljarina wonti, ja Testamentaia marda pirra wulu;   
\p
\v 5 Nunkangu miri pirnalaia Cherubim, pudlali manjulaia ngamani piri walpadakana wonti. Tanangupini potundru ngaiana karari wata kulnulu kulnulu kaukaubananto.   
\p
\v 6 Jenipara pratjana matja jeruja kurana; punga ngoperalani Priesta worali milingeru wiriai, tanali tanani ngamalkijiribani ngankanani.   
\p
\v 7 Punga mandruni windri Priesta pirna pota kulno kilpawoldrawirdi wiriai, ja wata kumari panieli, nina nulu jinkiai nunkanaia ja kana wolaraia madlentjandru.   
\p
\v 8 Jendralia Jaola kulikirieli wondrai, palto kulikiri pirnaia wata tinkari pantjina warai, jeruntjaia punga ngopera terkai,   
\p
\v 9 Naupini malka nganai karari miljarani, nunkangu tanali jinkini poto ja poto ngumu jinkiai, tana ngandandariai nina, nulu ngamalkijiribai, manamiri ngankala burkani,   
\p
\v 10 A‐ai, tana bukanto ja tapananto ja kulirkani pilki ja pilkinto windri palkuja mangini talku nganai, tana parai miljaru talkujelu.   
\lit (Dakani jaura Judica ditjini.)  
\p
\v 11 Christus wokarana wonti tanangupini potuja Priesta nganala, tana wokarananto, morla pirna ja morla ngumuja pungalali, nina wata marali ngankanala, jenia wondrai, wata nunkangupini pantjimani potundru,   
\p
\v 12 Bakana wata naninani ngaperaia ja nganti kuparaia kumarali, a‐ai, nunkanali kumarali Nauja pota kulno warupotuja piri kulikirini wirina wonti, ja kulkani ngurali mankamankana wonti.   
\p
\v 13 Ngangau nganti kaluntali ja naninani ngaperaia kumarali, ja nganti ngandria turuputali, tanana murumuru matja multibana, kulikiri ngankanani palkuja kulirkanaia,   
\p
\v 14 Worderu morla Christuni kumarali, Nauja munta Jaolali nguralieli madlentji pani Godani jinkiterina wonti, burka ngaianani kulirkala nganai naria ngankanandru Goda tepini mili ngamala?   
\p
\v 15 Ja jendrangundruja Nauja bakana Testamenta marra kulnuja Tertietja nganai, ngangau narindru, nau pantjina wonti kulkanaia madlentjandru, tanana Testamenta ngoperalani ngalpani, tanana Nulia karkana wonti nguralia maratunka manila, ninaia Nulia talpadakana wonti.  
\b  
\p
\v 16 Ngangau woderi Testamenta parai, nauja Testamenta kuranietja ngopera nari nganananto.   
\p
\v 17 Ngangau Testamenta windri ngurunguru nganai narindru, ja wata ngurula ngamalkai, wintaranaia Testamenta kuranietja tepi ngamanani.   
\p
\v 18 Jendrangundruja bakana Testamenta ngopera wata kumari panieli kulikiri pantjina wonti.   
\p
\v 19 Mosili jirijiribani jaura pratjana jirijiribani jaurandru kana wolarani matja kaukaubana, nulu nganti kuparaia ja naninani ngaperaia kumari ngapantali ja njurdu maraljentali ja Isop manina wonti, ja dakani jaura ja kana wolara turibana wonti,   
\p
\v 20 Ja jatana wonti: „Naupini Testamentaia kumari nganai, ninaia Godali jurangu kurana warai.“   
\p
\v 21 Ja nulu bakana punga ja ngamalkijiribani poto pratjana kumarali turibana wonti.   
\p
\v 22 Ja ngampu warupoto kumarali kulikiri pantjiai jirijiribani jaurandru; ja kumari nangani panini, wata kalingani pantjiai.   
\p
\v 23 Jeruja morlalu pariwilpaia mudlamalka jendralipara kulikiri pantjinanto; ja pariwilpaia poto munta poto ngumu morla pirnali kulikiri pantjinanto nunkangupini.   
\p
\v 24 Ngangau punga kulikiri pirnani, marali matja ngankana, Christus wata wirina wonti, morlaluja mudla malkani, a ai, pariwilpa muntani, Godaia mudlani wondraterila ngaianangu.   
\p
\v 25 Bakana wata jeruja, pota marapu jinkiterila poto ngumuja worderu Priesta pirna kilpawoldra pratjanani kumari pilkinto wiriai;   
\p
\v 26 Ngangau jeruja Nauja pota marapu mitaia woninandru ketjaketjananto. Ja karari Nauja windri pota kulno miljaru ngadalani wondraterina wonti nunkani poto ngumujeli madlentji kalinganaia.   
\p
\v 27 Ja worderu kanani morlalu parai pota kulno palila, ja ngadani kalala;   
\p
\v 28 Jeruja bakana Christus, Nauja pota kulno matja jinkiterina madlentji marapundru kalala manila, pota mandrulani madlentji panini wondraterila nganai tanangu, tanali nunkangu kalkai murlaia.   
\c 10  
\p
\v 1 Ngangau jirijiribani jaurali tanani potuja pungala ngamalkai, tana wokarananto, ja wata malka mudla morlalu munta nganai, jeruja nauja ngandandariai tanalipini poto ngumujeli, tanana kanali kilpawoldra kulno kulpawoldra kulno kulno jinkiai, tana wokarani ngandandariai ngurali mudala;   
\p
\v 2 Jenia kantji kara, tanali wata mudananto poto ngumu jinkila, ngangau tanali, tana poto ngumu ngankijiribai, pota kulno matja kulirkana, burka madlentji pani ngamalkanani?   
\p
\v 3 A‐ai, tanali madlentji ngundrai kilpawoldra kulnuni kilpawoldra kulnuni.   
\p
\v 4 Ngangau nganti kaluntaia ja naninani ngaperaia kumari ngandandariai madlentji kalingala.   
\p
\v 5 Jendrangundruja Nauja jatai, Nauja mitani wokaranani: „Poto ngumu ja jinkini poto jundru wata ngantjana warai, palku kulno jundru ngakangu ngankingana warai.   
\p
\v 6 Jerkini poto ngumuni ja madlentjandru poto ngumuni jundru wata murlali nganana warai.   
\p
\v 7 Jendranguta ngani jatana wonti: Mai, ngani wokarai, dakani jaurani parai ngakangundru, jinkani jertapaterina, Godajai, ngankala.“   
\p
\v 8 Ngopera Nauja jatana warai: „Poto ngumu ja jinkini poto ngumu ja madlentjandru poto ngumu jidni wata jertapaterina warai, ja tanangu wata murlali nganana warai“ (worderu tanali tanana jirijiribani jaurandru matja jinkiai),   
\p
\v 9 Ja karari Nauja jatai: „Mai, ngani wokarai, jertapaterina jinkani, Godajai, ngankala.“ Jeruja Nulia ngoperala worarai, ja mandrula terkibana tarai;   
\p
\v 10 Nunkanipini jertapaterinani ngaiana kulikiri pantjina wonti Jesuni Christuni palku jinkiterinali pota kulno pota warupotuja.   
\p
\v 11 Ja Priesta pratjana ditji kulno ditji kulno ngamalkijiribala terkai pota marapu jenilu poto ngumu jinkila, tana ngurali ngandandariai madlentji teribala.   
\p
\v 12 Nulupini windri poto ngumu kulno madlentjandru jinkina wonti, ja ngadani ngurali Godaia ngunarani ngamana ngarina wonti;   
\p
\v 13 Ja milingeru kalkai, nunkani talpala nunkangu tidnani tidnaparani piri jeribaka parai.   
\p
\v 14 Ngangau poto ngumu kulnujeli Nulia ngurali talku pirna ngankana wonti, tana kulikiri pantjila nganai.   
\p
\v 15 Jeruja Jaola kulikirieli ngaianangu bakana jenia morlalu kurai; Nauja matja ngopera jatana warai:   
\p
\v 16 „Naupini Testamenta nganai, ninaia ngato tanangu kurala nganai, tanangupini ditjini ngadani, Kapara jatai: Ngato jirijiribani jaura ngakani tanangu ngarani jinkila nganai, ja bakana tanani tjuruni dakala nganai,   
\p
\v 17 Ja tanani madlentji ja tjikatjika ngato wata morla ngundrala nganai.“   
\p
\v 18 Woderi tanani kalingani nganai, naka bakana wata morla poto ngumu madlentjandru.   
\p
\v 19 Ngangau ngaiana, ngatata worajai, mankini ngamalkai kulikiri pirnani wirila Jesuni kumarali,   
\p
\v 20 Ninaia Nulia ngaianangu ngankingana wonti, palto marra ja jepi, kati pirnani palkingala, jenia nganai, palkujeli nunkanali,   
\p
\v 21 Ja Priesta pirna Godaia pungani;   
\p
\v 22 Jeruja ngaiana karakararinanto ngara morlalujeli, ja morlalu ngundranaia morlalu ngundranali, ngaraia turibanali burka madlentji panini, ja palkuni matja kulirkana ngapa kulikirieli,   
\p
\v 23 Ja ngaiana kalkanaia dikani jaura wonki ngamalkananto wata duljuni, ngangau Nauja talku nganai, Nulia talpadakani jaura jinkina wonti.   
\p
\v 24 Ja ngaiana bakana najinajibijiribamalinanto ja nurungiribamalinanto ngantjanaia ja ngankana ngumuja,   
\p
\v 25 Ja ngaiana wata jurborini ngaianani worarananto, palpali jeribaka, a‐ai, kurukurubijiribamalinanto, ja jenia morla, ngangau jura ditji karakararinani najiai.   
\p
\v 26 Ngangau ngaiana jertapaterinali madlentji ngankanani, ngaiana morlaluja ngujamana matja manina, jeruja wata morla poto ngumu madlentjaia parai,   
\p
\v 27 A‐ai, kalala pirna ja turuja turu ngajingajingana japa pirnali kalkana, nulu tatanietja julkala nganai.   
\p
\v 28 Kulnujeli Mosini jirijiribani jaura wokaribanani, nau kalumiltjamiltjarina panini palinanto, tinkari ngankanietja mandruni kara parkulani kara.   
\p
\v 29 Mina kalala morla pirna, jura ngundrai, nulu manila nganai, nulu Godaia Ngatamura tidnali nankai, ja Testamentaia kumari bakujeli ngundrai, nunkanali nau kulikiri pantjina wonti, ja nulu manjulaia Jaola ngirkibanani?   
\p
\v 30 Ngangau ngaiana ninaia ngujamai, Nauja jatai: „Kalala ngakani poto nganai, ngato kalala jinkila nganai, Kapara jatai.“ Ja nakaldra: „Kaparali nunkani kana wolarani kalala jinkila nganai.“   
\p
\v 31 Jenia japa pirna nganai tepia Goda marani purila.   
\p
\v 32 Ditji ngoperalani ngundranau, tanangu jura, jura matja tjenmamarina, ketjaketjanaia tirimalinani tataurarina wonti,   
\p
\v 33 Buru kulnuni, jura ngirkibanali ja jeninali wondrani malka pantjina wonti; buru kulnuni, jura tanani ngampumara pantjina wonti, tana bakana jeruja ketjaketjana wonti.   
\p
\v 34 Jura dupudupulani jela ketjaketjana wonti, ja jurani potuja watawatali manini jura mankinali patana wonti, ngangau jura ngujamai, jura poto morla ngumu ja wonki ngamalkai pariwilpani.   
\p
\v 35 Jurani morlalu ngundrani wata woraranau, ngangau nulu kalala pirna ngamalkai.   
\p
\v 36 Jura wonki ngamananto, ngangau jura Godaia jertapaterinaia ngankanali talpadakani padakananto.   
\p
\v 37 Windri wordu, wordu waka morla, ngadani wokarai, Nauja wokarananto, ja wata banbala nganai.   
\p
\v 38 Kana talku morlalu ngundranandru tepi ngamala nganai; nau ngadatikanani, mungara ngakani wata murlali nganala nganai nunkangu.   
\p
\v 39 Ngaiana wata tana jeri, tana ngadatikai tintaterinaia, a‐ai, tanangu jeri, tanali morlalu ngundrai mungara kulkanaia.   
\c 11  
\p
\v 1 Morlalu ngundrana jenipara potuja morlalu ngujamani, tanangu ngaiana kalkai, ja jenia milkila, mina ngaiana wata najiai.   
\p
\v 2 Nunkanali pinaru worali (Godaia) tinkari ngankani manina wonti.   
\p
\v 3 Morlalu ngundranali ngaiana ngujamai, mita maru Godaia jaurali pantjina wonti, ja warupoto, mina ngaiana najiai, panilandru pantjina wonti.   
\p
\v 4 Morlalu ngundranali Abelali Godani poto ngumu morla pirna jinkina wonti Kainangu, nunkanali Nulia nunkangu tinkari ngankana wonti, nau kana talku nganai, ngangau Godali nunkani potuni tinkari ngankana wonti, ja nunkanali Nauja karari jatai, nunkani narini ngadani.   
\p
\v 5 Morlalu ngundranali Enoch tjiringana tarana wonti, nulu nari wata najinanto, ja tanali nina wata mankamankana wonti, ngangau Godali nina tjirimalkana wonti; ngangau nunkani tjiringanani ngopera Nulia tinkari nganana wonti, nulu murla mankamankana wonti Godangu;   
\p
\v 6 Jenia ngandandariai, morlalu ngundrana panini nunkangu murlali nganala; ngangau naupini, nau Godani karakarariai, morlalu ngundrananto, Nauja kantji nganai, ja tanangu, tanali ninaia wontiai, kalala jinkinietja nganala nganai.   
\p
\v 7 Morlalu ngundranali Noaheli jirijiribani jaura manina wonti, nunkangundru, mina nulu wata najina wonti, ja japa ngumujeli bota pirna wotina wonti pungani nunkanani kulkala; nunkanali nulu mitani kalala jinkina wonti, ja morlalu ngundrani talkulaia maratunka maninietja pantjina wonti.   
\p
\v 8 Morlalu ngundranali Abraham pankina wonti, Godali nina matja karkanani, nau dunkananto piri kulnuja, nina nulu maratunkaia maninanto; ja nau dunkana wonti ko wodajerinaia.   
\p
\v 9 Morlalu ngundranali nau tidnapalara ngamana wonti talpadakani mitani, ngandrani jeribaka, ja kati pungani ngamana wonti Isaakangunto ja Jakobangunto, ninaldramata talpadakani maratunka maninietjanto;   
\p
\v 10 Ngangau nulu nunkangupini ngurani kalkana wonti, nulu mardakapara ngamalkai, nunkani wotinietja ja ngankinganietja Goda nganai.   
\p
\v 11 Morlalu ngundranali bakana Sarandru ngurula manina wonti mandrantju pantjila kalinani widlapirna, ngangau nandru ninaia talku ngundrana wonti, Nulia jenia talpadakana wonti.   
\p
\v 12 Jendrangundruja bakana palku kulnundru, nau matja pitarina, wolara dankana wonti, ditji wakawakani pariwilpalani jeribaka, ja diritji panto dirkalani jeribaka, nina ngandandarina wintamala,   
\p
\v 13 Morlalu ngundranani tana pratjana palina wonti, ja tanali wata talpadakani manina wonti, a‐ai, windri woritandru tanali nina najina wonti, ja tanangu kalkana wonti, ja dikaterina wonti, tana tula ja ngandrani nganai mitani.   
\p
\v 14 Tanali jenia jatanani, wondrai, tanali ngaperaia mita wontiai.   
\p
\v 15 Ja tanali nina ngundranani, nunkangundru tana dunkanala, tanangu miljaru parana wonti tikana kurananto.   
\p
\v 16 Karari tanali mita morla ngumu wontiai, jenia nganai: Pariwilpaia. Jeruja bakana Goda wata nintali nganai tanangu, tanali nina Goda tanani dikananto, ngangau Nulia tanangu ngura ngankingana wonti.   
\p
\v 17 Morlalu ngundranali Abrahamali Isaak poto ngumuja jinkina wonti, Nulia ninaia wontjanani; ja nulu ngatamura kunakulno nunkani jinkina wonti, nulu talpadakani jaura maninala.   
\p
\v 18 Nunkangu Nauja jatana wonti: „Isaakani tanali ngatamura jinkani dikala nganai.“   
\p
\v 19 Ngangau nulu ngundrana wonti, Goda bakana ngurunguru nganai, narindru jiritjibana tarala, wodajerindru nulu nina jeribaka malka jeribaka nakaldra manina wonti.   
\p
\v 20 Morlalu ngundranali Isaakali Jakob ja Esau ngurungutana wonti nunkangundru, mina wokarananto.   
\p
\v 21 Morlalu ngundranali Jakobali narini kupiri Josephani ngatamura wulana ngurungutana wonti, ja buruna ngarina wonti nunkanani pita mangatandrani.   
\p
\v 22 Morlalu ngundranali Josephali nari kupirali Israel ngatamura wolarani dunkanandru kaukaubana wonti, ja jirijiribani jaura jinkina wonti nunkani mokundru.   
\p
\v 23 Morlalu ngundranali Mosini ngaperali ja ngandrieli, nina, nau matja dankana, pira parkulu kurukurumalkana wonti, ngangau pudla najina wonti, nau kupa ngumu nganai, ja wata japali nganana wonti mitaia kaparaia jirijiribani jaurandru.   
\p
\v 24 Morlalu ngundranali Mosili, nau matja pirnarina, wata ngantjana wonti, tanali nina Pharaonani mankaraia ngatani dikananto;   
\p
\v 25 A‐ai, nulu Godaia kana wolarani jela ketjaketjala ngundrana wonti, ja wata ngantjana wonti madlentjaia milkirina morla ngamalkala;   
\p
\v 26 Ngangau nulu Christuni ninta morla pirna ngundrana wonti Egyptaia poto pirna pratjanani, ngangau kalalaia nulu ngurutalpana najina wonti.   
\p
\v 27 Morlalu ngundranali nau Egypta mitandru puntina wonti, ja wata japali nganana wonti mitaia kaparaia tirindru, ja nau wonki nganana wonti nunkangu, ninaia nulu wata najina wonti kantji najina jeribaka.   
\p
\v 28 Morlalu ngundranali nulu Passa ja kumari nangani ngankingana wonti, panturu warupotuja nari nandranietjali tanana wata patananto.   
\p
\v 29 Morlalu ngundranali tana panto maraljeni palkingana tarana wonti mita mujani jeribaka, ja Egyptalali, tanali jenia wontjanani, tanali burujulkana wonti.   
\p
\v 30 Morlalu ngundranali Jericho wotini wondiri tampurina wonti, tanali ditji mara wora ja mandrujeli matja karitjina wontikanani.   
\p
\v 31 Morlalu ngundranali palakantji widla Rahab wata palina wonti delkinietjani jela, ngangau nandru najinajibanietja murlali patana wonti.   
\p
\v 32 Ja mina ngani morla jatananto? Ditji ngakangu wordu pantjiati, ngato kaukaubanani Gideoningundru, Barakangundru, Simsongundru, Jephthangundru, Davidangundru ja Samuelingundru ja Propheta worangundru;   
\p
\v 33 Tanali morlalu ngundranali mitaia kaparaia worana milila kalalu ngankana wonti, talkula ngankingana wonti, talpadakani manina wonti, pandipandi mana ngandrawalkana wonti,   
\p
\v 34 Turuja ngurula palimana wonti, mardakirraia tjerkarandru japarina wonti, waltowaltundru ngurunguru pantjina wonti, tirimalinani ngurunguru pantjina wonti, talpala wolara dangana wonti.   
\p
\v 35 Widlali tanani narila nari jiritjinandru nakaldra manina wonti. Palpali tanali narielu jupana wonti, ja tanali kulkani worarana wonti, ngangau tanali nari jiritjinandru morla ngumu manina wonti.   
\p
\v 36 Palpa tanali ngirkibana wonti ja wirrieli nandrana wonti, bakana dupudupu ngankana wonti ja kanjangari pungani widmana wonti;   
\p
\v 37 Palpa tanali mardali dakana wonti, wontjana wonti, diaturujeli wokaribana wonti, pirna jupana wonti, mardakirrali nandrana wonti, tana tjipi talani ja naninani talani wirarina wonti, palpa poto pani ngamana wonti, palpa tanali jenina wonti, ja palpani madlentji ngankana wonti,   
\p
\v 38 (Mitali tanangu wata talku nganana wonti,) tana pitarani ja mardawonpani ja minkani ja taldani tintaterini jeri wirarina wonti.   
\p
\v 39 Ja tanalipini pratjanali, tana morlalu ngundranali jaura morlalu ngumu manina wonti, ja talpadakani wata patana wonti,   
\p
\v 40 Ngangau Godali ngaianangu poto morla ngumu ngopera kurana wonti, tana wata ngaianangu panini kulikiri pantjinanto.   
\c 12  
\p
\v 1 Jendrangundruja bakana ngaiana, ngangau ngaiana jenipara talara palku tinkari ngankanietjandru ngamalkai, ngaiana ngandrawalkani pratjana, ja madlentji, nau wonki parai, worarananto, ja ngaiana nurumindrinanto tirimalinaia, nauja ngaianangu parai,   
\p
\v 2 Ja ngaiana najina tarananto Jesungu, morlalu ngundranaia Wapalkani pirna ja Mudani pirna, Nauja kunarkuni ketjaketjana wonti mankinandru, nauja nunkangu ngopera parana wonti, ja ninta wata ngundrana wonti, ja Nauja ngamana ngarina wonti Godaia ngamani pirini ngunarani.   
\p
\v 3 Ninaia najinajibana najianau, Nulia jenipara tatakani pirna madlentji ngankanietjandru ketjaketjana wonti, ngangau jura wata waltowalto pantjinanto ja jindinanto jurani mungarani.   
\p
\v 4 Jura wata kumarajelu tataura terkana wonti madlentjaia tirimalinani,   
\p
\v 5 Ja jura ninaia ngankalkani jaura kuritarana warai, nauja jurangu ngatamurani jeribaka jatai: Ngakani ngatamurajai, Kaparaia nandrani wata waka ngundramai, ja wata walturiau, Nulia jidna kurukurubanani;   
\p
\v 6 Ngangau worana Kaparali ngantjai, nina Nulia nandrai, ja ngatamura pratjana Nulia wirrieli nandrai, nina Nulia patai.   
\p
\v 7 Jura nandrani maninani, Godali jurangu ngatamurani jeri wondraterinani; ngangau woderi ngatamura nganai, nina ngaperali wata nandrai?   
\p
\v 8 Jura nandrani pani ngamanani, nina pratjanali maninala, jeruja jura palakantjia kupa ja wata ngatamura nganai.   
\p
\v 9 Morla, ngaiana palkuja ngaperi nandranietja ngamalkana wonti, ja tanangundru japali nganana wonti, ngaiana wata morla wodatarana ngamananto ngaiananaia jaolaia Ngaperani, ja tepirinanto?   
\p
\v 10 Tanali ditji ngalje nandrana wonti, worderu tanali ngundrana wonti, Nauja ngaiananaia ngumuja, ngaiana nunkani kulikirila maninanto.   
\p
\v 11 Ngaiana ngundrai, nandrani pratjana karari ngaianangu wata mankinaia nganai, a‐ai, ngaurongauroja; ngadani nulia talkuja murlaia tandra mandrai tanangu, tana wata dundunu nganai.   
\p
\v 12 Jendrangundruja, mara waltowalto ja ngarrani pantja terkibana tarau,   
\p
\v 13 Ja palto talku ngankanau jurani tidnani, ngangau tjunduru wata purinanto, a‐ai, tepi pantjinanto.   
\p
\v 14 Pratjanani jela murlani karipaterianau ja kulikirilani, nunkangupini panini wata kulnujeli Kapara najila nganai;   
\p
\v 15 Ngamalkaterianau, wata kulno Godaia manjulandru ngadaia ngamantinanto, ngangau kapara kaldri punkaiati, ja patijiritjibani ngankingaiati, ja marapu murumuru ngankaiati.   
\p
\v 16 Wata kulno palakantji kara murumuru kara ngamananto Esau jeribaka, nulu tajini kulnundru panturu dankani nunkani jinkina wonti;   
\p
\v 17 Ngangau jura milkila, nulu ngadani ngantjana wonti ngurungutani maratunka manila, Nulia nina worarana wonti, ngangau nulu piri pani mankamankana wonti karitjinaia, nulu nina milkigildieli wontinani.   
\p
\v 18 Ngangau jura wata karakararina warai mardawonpa kulnuni, nina tanali karakarai, ja jerkini turuni, ja talara palkuja maruni, ja ngalpuru pirnani, ja wondruni,   
\p
\v 19 Ja wima kokuja ngaialani, ja jaura kanpuni, ngaranietjali nina ngaranani, tanali dikidikibana wonti, wata jaura kulno morla tanangu pantjinanto.   
\p
\v 20 Ngangau tanali dikidikibani jaura bulu patana wonti. Bakana windri nganti mardawonpani karakaranani, nina tanali mardali dakananto,   
\p
\v 21 Ja naupini mudla jeruja japa pirna jinkina wonti, Moses jatana wonti: „Ngani japali pirna nganai ja pirna ngarrai.“   
\p
\v 22 A‐ai, jura wokarana wonti Zion mordawonpani, ja tepia Goda ngurani, pariwilpaia Jerusalemingu, ja angela wolara wolarani,   
\p
\v 23 Ditji pirnaia jurborinani, ja panturaia mili wolarani, tanani tala pariwilpani dakana parai, ja kalala jinkinietjani, warupotuja Godani, ja kana talku kulikiria jaolani,   
\p
\v 24 Ja Testamenta marraia tertietjani, ja turibanaia kumarani, nauja morla ngumu jatai Abelani.   
\p
\v 25 Ngamalkaterianau, jura ninaia wata kaldri ngankananto, Nulia jurangu kaukaubai, ngangau wata tanapini japa mindrinani, tanali ninaia, Nulia tinkari ngankani jaura kaukaubana wonti mitani, daudauana wonti; worderu morla pani ngaiana, ngaiana nunkangundru puntinani, Nulia pariwilpandru ngaianangu kaukaubai;   
\p
\v 26 Nunkanipini ngaialali jendranguta mita wiltjiwiltjibana wonti; ja karari Nulia talpadakana wonti ja jatana wonti: „Pota kulno morla ngato wata windri mita, a‐ai, bakana pariwilpa wiltjiwiltjibala nganai.“   
\p
\v 27 Jenia: „Pota kulno morla“ wondrai, Nulia wiltjiwiltjibani karitjimalkala nganai, ngangau jenia pantjimani nganai, ja jenia parananto mina wata wiltjiwiltjila nganai.   
\p
\v 28 Ngangau ngaiana milila wiltjiwiltjini pani maniai, ngaiana manjula ngamalkananto, ja jeruja wodatarana ngamananto Godani, ngantjalu jeri, nintali ja japali.   
\p
\v 29 Ngangau Goda ngaianani wiriwiribani turu nganai.   
\c 13  
\p
\v 1 Ngatata ngantjana paraiatimai!   
\p
\v 2 Tidnapalara patana wata kuritaranau; jeruja palpali mangapunkujeli angela patana wonti.   
\p
\v 3 Dupudupula ngundranau jeladupudupulali jeribaka, ja tanana, tana madlentji ketjaketjai, ngangau jundru munta paltuni nganai.   
\p
\v 4 Jura pratjana pinta pirna ngundranau, ja pintaia turarani piri murumuru pani; palakantjini ja pinta wokaribanietjani Godali kalala jinkila nganai.   
\p
\v 5 Mardatandra ngantjana pani jura ngamananto, ja jura murlali nganananto nunkangu, mina parai, ngangau Nauja munta jatana wonti: „Ngato jidna wata worarala nganai, ja jidna wata kuritarala nganai;“   
\p
\v 6 Jeruja ngaiana murlali jatananto: „Kapara ngakani marangokanietja nganai, ja ngani wata japali ngamala nganai. Mina ngakangu kanali ngankananto?“   
\p
\v 7 Ngujangujara jinkinietja jurani ngundranau, tanali jurangu Godaia jaura kaukaubana wonti; ja tanani morlalu ngundranani karipaterianau.   
\p
\v 8 Jesus Christus karari ja woldrawirdi, ja Naupini bakana ngurali.   
\p
\v 9 Ngujangujara pilkieli ja tulali jurana wata karkananto; ngangau jenia poto ngumu nganai, Godaia manjulali ngara ngurunguru pantjinanto, wata tajinali, nau tanangu baku nganai, tanali jenia ngundrai.   
\p
\v 10 Ngaiana Altara ngamalkai, nunkangundru tajila tanalipini wata ngurula ngamalkai, tana pungaia mili nganai.   
\p
\v 11 Ngangau tanani nganti palku, tanani kumari Priesta pirnali madlentjandru punga kulikiri pirnaia padakai, tanali ngurani palarani tarai.   
\p
\v 12 Jendrangundruja bakana Jesus, ngangau Nulia kumarali nunkanali kana wolara kulikiri ngankananto, manani palarani ketjaketjana wonti.  
\b  
\p
\v 13 Jendrangundruja ngaiana nunkangu wapananto nguraia palaraia, ja ninta nunkani waltananto.   
\p
\v 14 Ngangau ngaiana ninkida mitani wata ngura ngurali ngamalkai, a‐ai, marra ngaiana wontiai.   
\p
\v 15 Jeruja ngaiana nunkangundru jurakokani poto ngumu Godani milingeru jinkinanto, jenia nganai: „Manamimia tandra“, tanali tala nunkani dikai.   
\p
\v 16 Kalumiltjamiltjarina ja munta pirna wata kuritaranau; ngangau Godali jenipara poto ngumu ngantjai.   
\p
\v 17 Ngujangujara jinkinietja jurani talpakaldrujeli ngaranau, ja tanangu pankianau; ngangau tanali mungara juranina najinajibai; ja tanali Godani jurangundru kalabani jaura jinkila nganai, mankinali tanali jenia ngankananto ja wata burkaburkali, ngangau jenipara jurangu wata ngumu nganai.   
\p
\v 18 Ngaianingundru ngatjianau; ngangau ngaiani morlalu ngundrai, ngaiani ngara ngaiala ngumu ngamalkai, ngangau ngaiani potuni warupotuni talku ngundrai wirarila.   
\p
\v 19 Ngato jurana kurukurubai, jura jenia morla pirna ngankananto, ngangau tanali ngana jurangu morla nurujeli jinkinanto.   
\p
\v 20 Murlaia Godali, Nulia narindru tjipia ngamalkanietja pirna dunkalkana wonti Testamenta nguralia kumarali, Kapara ngaianani Jesus,   
\p
\v 21 Nulia jurana ngankingaiatimai ngankana ngumu pratjanani jertapaterina nunkani ngankala, Nulia ngaianangu ngankai, mina Nulia ngantjai Jesu Christujeli, nunkangu pirnala nguralindru nguralia nganaiatimai. Amen.   
\p
\v 22 Ngato jurana kurukurubai, ngatata worajai, kurukurubani jaura patanimai, windri jaura wordujeli ngato jurangu dakana warai.   
\p
\v 23 Ngujamanau, tanali ngatata ngaianani Timotheus kurakana warai, ja nunkangunto, nau nurujeli wokaranani, ngato jurana najila nganai.   
\p
\v 24 Mandurini jaura jinkianau kapara pratjanani ja kana kulikiri pratjanani. Mandurini jaura jurangu jinkiai tanali Italiandru.   
\p
\v 25 Manjula jurangu pratjanani nganaiatimai.   