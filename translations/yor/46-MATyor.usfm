\id MAT - Biblica® Open Yoruba Contemporary Bible 2017 
\h Matiu 
\toc1 Ìwé Ìyìnrere Matiu 
\toc2 Matiu 
\toc3 Mt 
\mt1 Ìwé Ìyìnrere Matiu 
\c 1  
\s1 Àkọsílẹ̀ ìwé ìran Jesu Kristi 
\li4  
\v 1 Ìwé ìran Jesu Kristi, ẹni tí í ṣe ọmọ Dafidi, ọmọ Abrahamu: 
\b  
\li1  
\v 2 Abrahamu ni baba Isaaki; 
\li1 Isaaki ni baba Jakọbu; 
\li1 Jakọbu ni baba Juda àti àwọn arákùnrin rẹ̀, 
\li1  
\v 3 Juda ni baba Peresi àti Sera, 
\li1 Tamari sì ni ìyá rẹ̀, 
\li1 Peresi ni baba Hesroni: 
\li1 Hesroni ni baba Ramu; 
\li1  
\v 4 Ramu ni baba Amminadabu; 
\li1 Amminadabu ni baba Nahiṣoni; 
\li1 Nahiṣoni ni baba Salmoni; 
\li1  
\v 5 Salmoni ni baba Boasi, Rahabu sí ni ìyá rẹ̀; 
\li1 Boasi ni baba Obedi, Rutu sí ni ìyá rẹ̀; 
\li1 Obedi sì ni baba Jese; 
\li1  
\v 6 Jese ni baba Dafidi ọba. 
\b  
\li1 Dafidi ni baba Solomoni, ẹni tí ìyá rẹ̀ jẹ́ aya Uriah tẹ́lẹ̀ rí. 
\li1  
\v 7 Solomoni ni baba Rehoboamu, 
\li1 Rehoboamu ni baba Abijah, 
\li1 Abijah ni baba Asa, 
\li1  
\v 8 Asa ni baba Jehoṣafati; 
\li1 Jehoṣafati ni baba Jehoramu; 
\li1 Jehoramu ni baba Ussiah; 
\li1  
\v 9 Ussiah ni baba Jotamu; 
\li1 Jotamu ni baba Ahaṣi; 
\li1 Ahaṣi ni baba Hesekiah; 
\li1  
\v 10 Hesekiah ni baba Manase; 
\li1 Manase ni baba Amoni; 
\li1 Amoni ni baba Josiah; 
\li1  
\v 11       Josiah sì ni baba Jekoniah àti àwọn arákùnrin rẹ̀ ní àkókò ìkólọ sí Babeli. 
\b  
\li4  
\v 12 Lẹ́yìn ìkólọ sí Babeli: 
\li1 Jekoniah ni baba Ṣealitieli; 
\li1 Ṣealitieli ni baba Serubbabeli; 
\li1  
\v 13 Serubbabeli ni baba Abihudi; 
\li1 Abihudi ni baba Eliakimu; 
\li1 Eliakimu ni baba Asori; 
\li1  
\v 14 Asori ni baba Sadoku; 
\li1 Sadoku ni baba Akimu; 
\li1 Akimu ni baba Elihudi; 
\li1  
\v 15 Elihudi ni baba Eleasari; 
\li1 Eleasari ni baba Mattani; 
\li1 Mattani ni baba Jakọbu; 
\li1  
\v 16 Jakọbu ni baba Josẹfu, ẹni tí ń ṣe ọkọ Maria, ìyá Jesu, ẹni tí í ṣe Kristi. 
\b  
\li4  
\v 17 Bẹ́ẹ̀ ni gbogbo wọ́n jẹ́ ìran mẹ́rìnlá láti orí Abrahamu dé orí Dafidi, ìran mẹ́rìnlá á láti orí Dafidi títí dé ìkólọ sí Babeli, àti ìran mẹ́rìnlá láti ìkólọ títí dé orí Kristi. 
\s1 Ìtàn ibí Jesu Kristi 
\p  
\v 18       Bí a ṣe bí Jesu Kristi nìyí, ní àkókò ti àdéhùn ìgbéyàwó ti parí láàrín Maria ìyá rẹ̀ àti Josẹfu, ṣùgbọ́n kí wọn tó pàdé, a rí i ó lóyún láti ọwọ́ Ẹ̀mí Mímọ́.  
\v 19 Nítorí Josẹfu ọkọ rẹ̀ tí í ṣe olóòtítọ́ ènìyàn kò fẹ́ dójútì í ní gbangba, ó ní èrò láti kọ̀ ọ́ sílẹ̀ ní ìkọ̀kọ̀. 
\p  
\v 20 Ṣùgbọ́n nígbà tí ó ro èrò yìí tán, angẹli Olúwa yọ sí i ní ojú àlá, ó wí pé, “Josẹfu, ọmọ Dafidi, má fòyà láti fi Maria ṣe aya rẹ, nítorí oyún tí ó wà nínú rẹ̀ láti ọwọ́ Ẹ̀mí Mímọ́ ni.  
\v 21  Òun yóò sì bí ọmọkùnrin, ìwọ yóò sì pe orúkọ rẹ̀ ní Jesu, nítorí òun ni yóò gba àwọn ènìyàn rẹ̀ là kúrò nínú ẹ̀ṣẹ̀ wọn.” 
\p  
\v 22 Gbogbo nǹkan wọ̀nyí sì ṣẹ láti mú ọ̀rọ̀ Olúwa ṣẹ èyí tí a sọ láti ẹnu wòlíì rẹ̀ wá pé:  
\v 23  “Wúńdíá kan yóò lóyún, yóò sì bí ọmọkùnrin kan, yóò sì pe orúkọ rẹ̀ ní Emmanueli,” (èyí tí ó túmọ̀ sí “Ọlọ́run wà pẹ̀lú wa”). 
\p  
\v 24 Nígbà tí Josẹfu jí lójú oorun rẹ̀, òun ṣe gẹ́gẹ́ bí angẹli Olúwa ti pàṣẹ fún un. Ó mú Maria wá sílé rẹ̀ ní aya.  
\v 25 Ṣùgbọ́n òun kò mọ̀ ọ́n títí tí ó fi bí ọmọkùnrin, òun sì sọ orúkọ rẹ̀ ní Jesu. 
\c 2  
\s1 Ìbẹ̀wò àwọn amòye 
\p  
\v 1       Lẹ́yìn ìgbà tí a bí Jesu ní Bẹtilẹhẹmu ti Judea, ni àkókò ọba Herodu, àwọn amòye ti ìlà-oòrùn wá sí Jerusalẹmu.  
\v 2  Wọ́n si béèrè pé, “Níbo ni ẹni náà tí a bí tí í ṣe ọba àwọn Júù wà? Àwa ti rí ìràwọ̀ rẹ̀ ní ìlà-oòrùn, a sì wá láti foríbalẹ̀ fún un.” 
\p  
\v 3 Nígbà tí ọba Herodu sì gbọ́ èyí, ìdààmú bá a àti gbogbo àwọn ara Jerusalẹmu pẹ̀lú rẹ̀.  
\v 4 Nígbà tí ó sì pe àwọn olórí àlùfáà àti àwọn olùkọ́ òfin jọ, ó bi wọ́n léèrè níbi ti a ó gbé bí Kristi?  
\v 5  Wọ́n sì wí pé, “Ní Bẹtilẹhẹmu ti Judea, èyí ni ohun tí wòlíì ti kọ ìwé rẹ̀ pé, 
\q1  
\v 6       “ ‘Ṣùgbọ́n ìwọ Bẹtilẹhẹmu, ní ilẹ̀ Judea, 
\q2 ìwọ kò kéré jù láàrín àwọn ọmọ-aládé Juda; 
\q1 nítorí láti inú rẹ ni Baálẹ̀ kan yóò ti jáde, 
\q2 ẹni ti yóò ṣe ìtọ́jú Israẹli, àwọn ènìyàn mi.’ ” 
\p  
\v 7 Nígbà náà ni Herodu ọba pe àwọn amòye náà sí ìkọ̀kọ̀, ó sì wádìí ni ọwọ́ wọn, àkókò náà gan an tí wọ́n kọ́kọ́ rí ìràwọ̀.  
\v 8 Ó sì rán wọn lọ sí Bẹtilẹhẹmu, ó sì wí pé, “Ẹ lọ ṣe ìwádìí fínní fínní ní ti ọmọ náà tí a bí. Lẹ́yìn tí ẹ bá sì rí i, ẹ padà wá sọ fún mi, kí èmi náà le lọ foríbalẹ̀ fún un.” 
\p  
\v 9 Nígbà tí wọ́n sì gbọ́ ọ̀rọ̀ ọba, wọ́n mú ọ̀nà wọn pọ̀n, sì wò ó, ìràwọ̀ tí wọ́n ti rí láti ìhà ìlà-oòrùn wá, ó ṣáájú wọn, títí tí ó fi dúró lókè ibi tí ọmọ náà gbé wà.  
\v 10 Nígbà tí wọ́n sì rí ìràwọ̀ náà, ayọ̀ kún ọkàn wọn.  
\v 11  Bí wọ́n tí wọ inú ilé náà, wọn rí ọmọ ọwọ́ náà pẹ̀lú Maria ìyá rẹ̀, wọ́n wólẹ̀, wọ́n foríbalẹ̀ fún un. Nígbà náà ni wọ́n tú ìṣúra wọn, wọ́n sì ta Jesu lọ́rẹ: wúrà, tùràrí àti òjìá.  
\v 12  Nítorí pé Ọlọ́run ti kìlọ̀ fún wọn ní ojú àlá pé kí wọ́n má ṣe padà tọ Herodu lọ mọ́, wọ́n gba ọ̀nà mìíràn lọ sí ìlú wọn. 
\s1 A gbé Jesu sálọ sì Ejibiti 
\p  
\v 13 Nígbà tí wọn ti lọ, angẹli Olúwa fi ara hàn Josẹfu ní ojú àlá pé, “Dìde, gbé ọmọ ọwọ́ náà àti ìyá rẹ̀, kí ó sì sálọ sí Ejibiti. Dúró níbẹ̀ títí tí èmi yóò fi sọ fún ọ, nítorí Herodu yóò wá ọ̀nà láti pa ọmọ ọwọ́ náà.” 
\p  
\v 14 Nígbà náà ni ó sì dìde, ó mú ọmọ ọwọ́ náà àti ìyá rẹ̀ ní òru, ó sì lọ sí Ejibiti,  
\v 15  ó sì wà níbẹ̀ títí tí Herodu fi kú. Èyí jẹ́ ìmúṣẹ àsọtẹ́lẹ̀ ohun tí Olúwa sọ láti ẹnu wòlíì pé, “Mo pe ọmọ mi jáde láti Ejibiti wá.” 
\p  
\v 16 Nígbà tí Herodu rí í pé àwọn amòye náà ti tan òun jẹ, ó bínú gidigidi, ó sì pàṣẹ kí a pa gbogbo àwọn ọmọkùnrin tí ó wà ní Bẹtilẹhẹmu àti ní ẹkùn rẹ̀ láti àwọn ọmọ ọdún méjì sílẹ̀ gẹ́gẹ́ bi àkókò tí ó ti fi ẹ̀sọ̀ ẹ̀sọ̀ béèrè lọ́wọ́ àwọn amòye náà.  
\v 17 Nígbà náà ni èyí tí a ti sọtẹ́lẹ̀ láti ẹnu wòlíì Jeremiah wá ṣẹ pé: 
\q1  
\v 18       “A gbọ́ ohùn kan ní Rama, 
\q2 ohùn réré ẹkún àti ọ̀fọ̀ ńlá, 
\q1 Rakeli ń sọkún àwọn ọmọ rẹ̀. 
\q2 Ó kọ̀ láti gbìpẹ̀ 
\q1 nítorí àwọn ọmọ rẹ̀ kò sí mọ́.” 
\s1 Ìpadà sí Nasareti 
\p  
\v 19       Lẹ́yìn ikú Herodu, angẹli Olúwa fi ara hàn Josẹfu lójú àlá ní Ejibiti  
\v 20 Ó sì wí fún un pé, “Dìde gbé ọmọ ọwọ́ náà àti ìyá rẹ̀ padà sí ilẹ̀ Israẹli, nítorí àwọn tí ń wá ẹ̀mí ọmọ ọwọ́ náà láti pa ti kú.” 
\p  
\v 21 Nítorí náà, o sì dìde, ó gbé ọmọ ọwọ́ náà àti ìyá rẹ̀ ó sì wá sí ilẹ̀ Israẹli.  
\v 22 Ṣùgbọ́n nígbà tí ó gbọ́ pé Akelausi ni ó ń jẹ ọba ní Judea ní ipò Herodu baba rẹ̀, ó bẹ̀rù láti lọ sí ì bẹ̀. Nítorí tí Ọlọ́run ti kìlọ̀ fún un ní ojú àlá, ó yí padà, ó sì gba ẹkùn Galili lọ,  
\v 23  ó sì lọ í gbé ní ìlú tí a pè ní Nasareti. Nígbà náà ni èyí tí a sọtẹ́lẹ̀ láti ẹnu àwọn wòlíì wá sí ìmúṣẹ: “A ó pè é ní ará Nasareti.” 
\c 3  
\s1 Johanu onítẹ̀bọmi tún ọnà náà ṣe 
\p  
\v 1       Ní ọjọ́ wọ̀n-ọn-nì, Johanu onítẹ̀bọmi wá, ó ń wàásù ní aginjù Judea.  
\v 2  Ó ń wí pé, “Ẹ ronúpìwàdà, nítorí ìjọba ọ̀run kù sí dẹ̀dẹ̀.”  
\v 3 Èyí ni ẹni náà ti wòlíì Isaiah sọ̀rọ̀ nípa rẹ̀ pé, 
\q1 “Ohùn ẹni ti ń kígbe ní ijù, 
\q1 ‘Ẹ tún ọ̀nà Olúwa ṣe, 
\q2 ẹ ṣe ojú ọ̀nà rẹ̀ kí ó tọ́.’ ” 
\p  
\v 4       Aṣọ Johanu náà sì jẹ́ ti irun ìbákasẹ, ó sì di àmùrè awọ sí ẹ̀gbẹ́ rẹ̀. Eṣú àti oyin ìgàn sì ni oúnjẹ rẹ̀.  
\v 5 Àwọn ènìyàn jáde lọ sọ́dọ̀ rẹ̀ láti Jerusalẹmu àti gbogbo Judea àti àwọn ènìyàn láti gbogbo ìhà Jordani.  
\v 6 Wọ́n ń jẹ́wọ́ ẹ̀ṣẹ̀ wọn, a sì ń bamitiisi wọn ní ọ̀dọ̀ rẹ̀ ní odò Jordani. 
\p  
\v 7       Ṣùgbọ́n nígbà tí ó rí ọ̀pọ̀ àwọn Farisi àti Sadusi tí wọ́n ń wá ṣe ìtẹ̀bọmi, ó wí fún wọn pé, “Ẹ̀yin ọmọ paramọ́lẹ̀! Ta ni ó kìlọ̀ fún yín pé kí ẹ́ sá kúrò nínú ìbínú tí ń bọ̀?  
\v 8 Ẹ so èso tí ó yẹ fún ìrònúpìwàdà.  
\v 9  Kí ẹ má sì ṣe rò nínú ara yin pé, ‘Àwa ní Abrahamu ní baba.’ Èmi wí fún yín, Ọlọ́run lè mu àwọn ọmọ jáde láti inú àwọn òkúta wọ̀nyí wá fún Abrahamu.  
\v 10  Nísinsin yìí, a ti fi àáké lè gbòǹgbò igi, àti pé gbogbo igi tí kò bá so èso rere ni a óò ge lulẹ̀ ti a ó sì wọ jù sínú iná. 
\p  
\v 11 “Èmi fi omi bamitiisi yín fún ìrònúpìwàdà. Ṣùgbọ́n lẹ́yìn mi ẹnìkan tí ó pọ̀jù mí lọ ń bọ̀, bàtà ẹni tí èmi kò tó gbé. Òun ni yóò fi Ẹ̀mí Mímọ́ àti iná bamitiisi yín.  
\v 12  Ẹni ti àmúga ìpakà rẹ̀ ń bẹ ní ọwọ́ rẹ̀, yóò gbá ilẹ̀ ìpakà rẹ̀, yóò kó alikama rẹ̀ sínú àká, ṣùgbọ́n ìyàngbò ni yóò fi iná àjóòkú sun.” 
\s1 Ìtẹ̀bọmi Jesu 
\p  
\v 13       Nígbà náà ni Jesu ti Galili wá sí odò Jordani kí Johanu bá à lè ṣe ìtẹ̀bọmi fún un.  
\v 14 Ṣùgbọ́n Johanu kò fẹ́ ṣe ìtẹ̀bọmi fún un, ó wí pé, “Ìwọ ni ìbá bamitiisi fún mi, ìwọ sì tọ̀ mí wá?” 
\p  
\v 15 Jesu sì dáhùn pé, \wj “Jọ̀wọ́ rẹ̀ bẹ́ẹ̀ náà, nítorí bẹ́ẹ̀ ni ó yẹ fún wa láti mú gbogbo òdodo ṣẹ.”\wj* Bẹ́ẹ̀ ni Johanu gbà, ó sì ṣe ìtẹ̀bọmi fún un. 
\p  
\v 16 Bí ó si tí ṣe ìtẹ̀bọmi fún Jesu tán, Ó jáde láti inú omi. Ní àkókò náà ọ̀run ṣí sílẹ̀ fún un, Ó sì rí Ẹ̀mí Ọlọ́run ń sọ̀kalẹ̀ bí àdàbà, ó sì bà lé e.  
\v 17  Ohùn kan láti ọ̀run wá sì wí pé, “Èyí sì ni àyànfẹ́ ọmọ mi, ẹni tí inú mi dùn sí gidigidi.” 
\c 4  
\s1 Ìdánwò Jesu 
\p  
\v 1       Nígbà náà ni Ẹ̀mí Mímọ́ darí Jesu sí ijù láti dán an wò láti ọwọ́ èṣù.  
\v 2  Lẹ́yìn tí Òun ti gbààwẹ̀ ní ogójì ọ̀sán àti ogójì òru, ebi sì ń pa á.  
\v 3 Nígbà náà ni olùdánwò tọ̀ ọ́ wá, ó wí pé, “Bí ìwọ bá ṣe Ọmọ Ọlọ́run, pàṣẹ kí òkúta wọ̀nyí di àkàrà.” 
\p  
\v 4       Ṣùgbọ́n Jesu dáhùn pé, \wj “A ti kọ ìwé rẹ̀ pé: ‘Ènìyàn kì yóò wà láààyè nípa àkàrà nìkan, bí kò ṣe nípa gbogbo ọ̀rọ̀ ti ó ti ẹnu Ọlọ́run jáde wá.’ ”\wj* 
\p  
\v 5       Lẹ́yìn èyí ni èṣù gbé e lọ sí ìlú mímọ́ náà; ó gbé e lé ibi ṣóńṣó tẹmpili.  
\v 6  Ó wí pé, “Bí ìwọ̀ bá jẹ́ Ọmọ Ọlọ́run, bẹ́ sílẹ̀ fún ara rẹ. A sá à ti kọ̀wé rẹ̀ pé, 
\q1 “ ‘Yóò pàṣẹ fún àwọn angẹli rẹ̀ nítorí tìrẹ 
\q2 wọn yóò sì gbé ọ sókè ni ọwọ́ wọn 
\q1 kí ìwọ kí ó má ba à fi ẹsẹ̀ rẹ gbún òkúta.’ ” 
\p  
\v 7       Jesu sì dalóhùn, \wj “A sá à ti kọ ọ́ pé, ‘Ìwọ kò gbọdọ̀ dán Olúwa Ọlọ́run rẹ wò.’ ”\wj* 
\p  
\v 8 Lẹ́ẹ̀kan sí i, èṣù gbé e lọ sórí òkè gíga, ó sì fi gbogbo ilẹ̀ ọba ayé àti gbogbo ògo wọn hàn án.  
\v 9 Ó sì wí fún un pé, “Gbogbo nǹkan wọ̀nyí ni èmi yóò fi fún ọ, bí ìwọ bá foríbalẹ̀ tí o sì sìn mi.” 
\p  
\v 10       Jesu wí fún un pé, \wj “Padà kúrò lẹ́yìn mi, Satani! Nítorí a ti kọ ọ́ pé, ‘Olúwa Ọlọ́run rẹ ni kí ìwọ kí ó fi orí balẹ̀ fún, òun nìkan ṣoṣo ni kí ìwọ máa sìn.’ ”\wj* 
\p  
\v 11       Nígbà náà ni èṣù fi í sílẹ̀ lọ, àwọn angẹli sì tọ̀ ọ́ wá, wọ́n sì ṣe ìránṣẹ́ fún un. 
\s1 Jesu bẹ̀rẹ̀ sí wàásù 
\p  
\v 12       Nígbà tí Jesu gbọ́ wí pé a ti fi Johanu sínú túbú ó padà sí Galili.  
\v 13  Ó kúrò ní Nasareti, ó sì lọ í gbé Kapernaumu, èyí tí ó wà létí Òkun Sebuluni àti Naftali.  
\v 14 Kí èyí tí a ti sọtẹ́lẹ̀ láti ẹnu wòlíì Isaiah lè ṣẹ pé, 
\q1  
\v 15       “Ìwọ Sebuluni àti ilẹ̀ Naftali 
\q2 ọ̀nà tó lọ sí Òkun, ní ọ̀nà Jordani, 
\q2 Galili ti àwọn kèfèrí. 
\q1  
\v 16 Àwọn ènìyàn tí ń gbé ni òkùnkùn 
\q2 tí ri ìmọ́lẹ̀ ńlá, 
\q1 àti àwọn tó ń gbé nínú ilẹ̀ òjijì ikú 
\q2 ni ìmọ́lẹ̀ tan fún.” 
\p  
\v 17       Láti ìgbà náà lọ ni Jesu ti bẹ̀rẹ̀ sí wàásù: \wj “Ẹ ronúpìwàdà, nítorí tí ìjọba ọ̀run kù sí dẹ̀dẹ̀.”\wj* 
\s1 Pípe àwọn ọmọ-ẹ̀yìn àkọ́kọ́ 
\p  
\v 18       Bí Jesu ti ń rìn létí Òkun Galili, ó rí àwọn arákùnrin méjì, Simoni, ti à ń pè ní Peteru, àti Anderu arákùnrin rẹ̀. Wọ́n ń sọ àwọ̀n wọn sínú Òkun nítorí apẹja ni wọ́n.  
\v 19 Jesu wí fún wọn pé, \wj “Ẹ wá, ẹ máa tọ̀ mí lẹ́yìn èmi yóò sì sọ yín di apẹja ènìyàn.”\wj* 
\v 20 Lójúkan náà, wọ́n fi àwọ̀n wọn sílẹ̀, wọ́n sì tọ̀ ọ́ lẹ́yìn. 
\p  
\v 21 Bí ó sì ti kúrò ní ibẹ̀, ò rí àwọn arákùnrin méjì mìíràn, Jakọbu ọmọ Sebede àti Johanu, arákùnrin rẹ̀. Wọ́n wà nínú ọkọ̀ ojú omi pẹ̀lú Sebede baba wọn, wọ́n ń di àwọ̀n wọn, Jesu sì pè àwọn náà pẹ̀lú.  
\v 22 Lójúkan náà, wọ́n fi ọkọ̀ ojú omi àti baba wọn sílẹ̀, wọ́n sì tọ̀ ọ́ lẹ́yìn. 
\s1 Jesu ṣe ìwòsàn 
\p  
\v 23       Jesu sì rin káàkiri gbogbo Galili, ó ń kọ́ni ní Sinagọgu, ó ń wàásù ìyìnrere ti ìjọba ọ̀run, ó sì ń ṣe ìwòsàn ààrùn gbogbo àti àìsàn láàrín gbogbo ènìyàn.  
\v 24 Òkìkí rẹ̀ sì kàn yí gbogbo Siria ká; wọ́n sì gbé àwọn aláìsàn tí ó ní onírúurú ààrùn, àwọn tí ó ní ìnira ẹ̀mí èṣù, àti àwọn ti o ní wárápá àti àwọn tí ó ní ẹ̀gbà; ó sì wò wọ́n sàn.  
\v 25 Ọ̀pọ̀lọpọ̀ ènìyàn láti Galili, Dekapoli, Jerusalẹmu, Judea, àti láti òkè odò Jordani sì tọ̀ ọ́ lẹ́yìn. 
\c 5  
\s1 Ìwàásù orí òkè 
\p  
\v 1       Nígbà tí ó rí ọ̀pọ̀ ènìyàn, ó gun orí òkè lọ ó sì jókòó. Àwọn ọmọ-ẹ̀yìn rẹ̀ si tọ̀ ọ́ wá.  
\v 2 Ó sì bẹ̀rẹ̀ sí kọ́ wọn. 
\m Ó wí pé, 
\q1  
\v 3 \wj “Alábùkún fún ni àwọn òtòṣì ní ẹ̀mí,\wj* 
\q2 \wj nítorí tiwọn ni ìjọba ọ̀run.\wj* 
\q1  
\v 4 \wj Alábùkún fún ni àwọn tí ń ṣọ̀fọ̀,\wj* 
\q2 \wj nítorí a ó tù wọ́n nínú.\wj* 
\q1  
\v 5 \wj Alábùkún fún ni àwọn ọlọ́kàn tútù,\wj* 
\q2 \wj nítorí wọn yóò jogún ayé.\wj* 
\q1  
\v 6 \wj Alábùkún fún ni àwọn tí ebi ń pa\wj* 
\q2 \wj tí òǹgbẹ ń gbẹ́ nítorí òdodo, nítorí wọn yóò yó.\wj* 
\q1  
\v 7 \wj Alábùkún fún ni àwọn aláàánú,\wj* 
\q2 \wj nítorí wọn yóò rí àánú gbà.\wj* 
\q1  
\v 8 \wj Alábùkún fún ni àwọn ọlọ́kàn mímọ́,\wj* 
\q2 \wj nítorí wọn yóò rí Ọlọ́run.\wj* 
\q1  
\v 9 \wj Alábùkún fún ni àwọn onílàjà,\wj* 
\q2 \wj nítorí ọmọ Ọlọ́run ni a ó máa pè wọ́n.\wj* 
\q1  
\v 10 \wj Alábùkún fún ni àwọn ẹni tí a ṣe inúnibíni sí,\wj* 
\q2 \wj nítorí tí wọ́n jẹ́ olódodo\wj* 
\q2 \wj nítorí tiwọn ní ìjọba ọ̀run.\wj* 
\p  
\v 11 \wj “Alábùkún fún ni ẹ̀yin nígbà tí àwọn ènìyàn bá fi àbùkù kàn yín tí wọn bá ṣe inúnibíni sí yín, tiwọn fi ètè èké sọ̀rọ̀ búburú gbogbo sí yín nítorí mi.\wj* 
\v 12 \wj Ẹ yọ̀, kí ẹ̀yin sì fò fún ayọ̀, nítorí ńlá ni èrè yín ní ọ̀run, nítorí bẹ́ẹ̀ ni wọ́n ṣe ṣe inúnibíni sí àwọn wòlíì tí ń bẹ ṣáájú yín.\wj* 
\s1 Iyọ̀ àti ìmọ́lẹ̀ 
\p  
\v 13 \wj “Ẹ̀yin ni iyọ̀ ayé. Ṣùgbọ́n bí iyọ̀ bá di òbu kí ni a ó fi mú un dùn? Kò tún wúlò fún ohunkóhun mọ́, bí kò ṣe pé kí a dàánù, kí ó sì di ohun tí ènìyàn ń fi ẹsẹ̀ tẹ̀ mọ́lẹ̀.\wj* 
\p  
\v 14 \wj “Ẹyin ni ìmọ́lẹ̀ ayé. Ìlú tí a tẹ̀dó sórí òkè kò lè fi ara sin\wj*.  
\v 15 \wj Bẹ́ẹ̀ ni a kì í tan fìtílà tán, kí a sì gbé e sí abẹ́ òsùwọ̀n; bí kò ṣe sí orí ọ̀pá fìtílà, a sì tan ìmọ́lẹ̀ fún gbogbo ẹni tí ń bẹ nínú ilé.\wj* 
\v 16 \wj Bákan náà, ẹ jẹ́ kí ìmọ́lẹ̀ yín kí ó mọ́lẹ̀ níwájú ènìyàn, kí wọ́n lè máa rí iṣẹ́ rere yín, kí wọn lè máa yin baba yín tí ń bẹ ní ọ̀run lógo.\wj* 
\s1 Ìmúṣẹ òfin 
\p  
\v 17 \wj “Ẹ má ṣe rò pé, èmí wá láti pa òfin àwọn wòlíì run, èmi kò wá láti pa wọn rẹ́, bí kò ṣe láti mú wọn ṣẹ\wj*.  
\v 18 \wj Lóòótọ́ ni mo wí fún un yín, títí ọ̀run òun ayé yóò fi kọjá, àmì kínkínní tí a fi gègé ṣe kan kì yóò parẹ́ kúrò nínú gbogbo òfin tó wà nínú ìwé òfin títí gbogbo rẹ̀ yóò fi wá sí ìmúṣẹ.\wj* 
\v 19 \wj Ẹnikẹ́ni ti ó bá rú òfin tí ó tilẹ̀ kéré jùlọ, tí ó sì kọ́ ẹlòmíràn láti ṣe bẹ́ẹ̀, òun ni yóò kéré jùlọ ní ìjọba ọ̀run, ṣùgbọ́n ẹni tí ó bá ń ṣe wọ́n, tí ó sì ń kọ́ wọn, ni yóò jẹ́ ẹni ńlá ní ìjọba ọ̀run.\wj* 
\v 20 \wj Nítorí náà ni mo ti wí fún yín pé àfi bí òdodo yín bá ju ti àwọn Farisi àti ti àwọn olùkọ́ òfin lọ, dájúdájú ẹ̀yin kì yóò le wọ ìjọba ọ̀run.\wj* 
\s1 Ìpànìyàn 
\p  
\v 21 \wj “Ẹ̀yin ti gbọ́ bí a ti wí fún àwọn ará ìgbàanì pé, ‘Ìwọ kò gbọdọ̀ pànìyàn, ẹnikẹ́ni tí ó bá pànìyàn yóò wà nínú ewu ìdájọ́.’\wj* 
\v 22 \wj Ṣùgbọ́n èmi wí fún un yín pé, ẹnikẹ́ni tí ó bínú sí arákùnrin rẹ̀ yóò wà nínú ewu ìdájọ́. Ẹnikẹ́ni ti ó ba wí fun arákùnrin rẹ̀ pé, ‘\+tl Ráákà\+tl*,’ yóò fi ara hàn níwájú ìgbìmọ̀ àwọn àgbà Júù; ṣùgbọ́n ẹni tí ó bá wí pé, ‘Ìwọ wèrè!’ yóò wà nínú ewu iná ọ̀run àpáàdì.\wj* 
\p  
\v 23 \wj “Nítorí náà, nígbà tí ìwọ bá ń mú ẹ̀bùn rẹ wá síwájú pẹpẹ, bí ìwọ bá sì rántí níbẹ̀ pé arákùnrin rẹ̀ ni ohùn kan nínú sí ọ\wj*.  
\v 24 \wj Fi ẹ̀bùn rẹ sílẹ̀ níwájú pẹpẹ. Ìwọ kọ́kọ́ lọ ṣe ìlàjà láàrín ìwọ àti arákùnrin rẹ̀ na. Lẹ́yìn náà, wá kí ó sì fi ẹ̀bùn rẹ sílẹ̀.\wj* 
\p  
\v 25 \wj “Bá ọ̀tá rẹ làjà kánkán, ẹni tí ó ń gbé ọ lọ sílé ẹjọ́. Ṣe é nígbà ti ó wà ní ọ̀nà pẹ̀lú rẹ, bí bẹ́ẹ̀ kọ́ yóò fà ọ́ lé onídàájọ́ lọ́wọ́, onídàájọ́ yóò sí fá ọ lé àwọn ẹ̀ṣọ́ lọ́wọ́, wọ́n a sì sọ ọ́ sínú túbú.\wj* 
\v 26 \wj Lóòótọ́ ni mo wí fún ọ, ìwọ kì yóò jáde kúrò níbẹ̀ títí tí ìwọ yóò fi san ẹyọ owó kan tí ó kù.\wj* 
\s1 Panṣágà 
\p  
\v 27 \wj “Ẹ̀yin ti gbọ́ bí òfin ti wí pé, ‘Ìwọ kò gbọdọ̀ ṣe panṣágà.’\wj* 
\v 28 \wj Ṣùgbọ́n mo wí fún yín pé, ẹnikẹ́ni tí ó bá wo obìnrin kan ní ìwòkuwò, ti bà ṣe panṣágà nínú ọkàn rẹ̀.\wj* 
\v 29 \wj Bí ojú ọ̀tún rẹ bá mú ọ kọsẹ̀, yọ ọ́ jáde, kí ó sì sọ ọ́ nù. Ó sá à ní èrè fún ọ kí ẹ̀yà ara rẹ kan ṣègbé, ju kí a gbé gbogbo ara rẹ jù sí iná ọ̀run àpáàdì.\wj* 
\v 30 \wj Bí ọwọ́ ọ̀tún rẹ bá mú ọ kọsẹ̀, gé e kúrò, kí ó sì sọ ọ́ nù. Ó sá à ní èrè kí ẹ̀yà ara rẹ kan ṣègbé ju kí a gbé gbogbo ara rẹ jù sí iná ọ̀run àpáàdì.\wj* 
\s1 Ìkọ̀sílẹ̀ 
\p  
\v 31 \wj “A ti wí pẹ̀lú pé, ‘Ẹnikẹ́ni tí ó bá kọ aya rẹ̀ sílẹ̀, jẹ́ kí ó fi ìwé ìkọ̀sílẹ̀ lé e lọ́wọ́.’\wj* 
\v 32 \wj Ṣùgbọ́n èmi sọ èyí fún yín pé, ẹnikẹ́ni tí ó bá kọ aya rẹ̀ sílẹ̀, láìṣe pé nítorí àgbèrè, ó mú un ṣe àgbèrè, ẹnikẹ́ni tí ó bá sì gbé ẹni tí a kọ̀ ní ìyàwó, ó ṣe panṣágà.\wj* 
\s1 Ìbúra 
\p  
\v 33 \wj “Ẹ̀yin ti gbọ́ bí a ti wí fún àwọn ará ìgbàanì pé, ‘Ìwọ kò gbọdọ̀ búra èké bí kò ṣe pé kí ìwọ kí ó mú ìbúra rẹ̀ fún Olúwa ṣẹ.’\wj* 
\v 34 \wj Ṣùgbọ́n èmi wí fún yín, ẹ má ṣe búra rárá: ìbá à ṣe fífi ọ̀run búra, nítorí ìtẹ́ Ọlọ́run ni.\wj* 
\v 35 \wj Tàbí fi ayé búra, nítorí àpótí ìtìsẹ̀ Ọlọ́run ni; tàbí Jerusalẹmu, nítorí olórí ìlú ọba ńlá ni.\wj* 
\v 36 \wj Má ṣe fi orí rẹ búra, nítorí ìwọ kò lè sọ irun ẹyọ kan di funfun tàbí di dúdú.\wj* 
\v 37 \wj Ẹ jẹ́ kí bẹ́ẹ̀ ni yín jẹ́ bẹ́ẹ̀ ni àti bẹ́ẹ̀ kọ́ yín jẹ́ bẹ́ẹ̀ kọ́, ohunkóhun tí ó ba ju ìwọ̀nyí lọ, wá láti ọ̀dọ̀ ẹni ibi.\wj* 
\s1 Ojú fún ojú 
\p  
\v 38 \wj “Ẹ̀yin tí gbọ́ bí òfin tí wí pé, ‘Ojú fún ojú àti eyín fún eyín.’\wj* 
\v 39 \wj Ṣùgbọ́n èmi wí fún yín pé, ẹ má ṣe tako ẹni ibi. Bí ẹnìkan bá gbá ọ lẹ́rẹ̀kẹ́ ọ̀tún, yí ẹ̀rẹ̀kẹ́ òsì sí olúwa rẹ̀ pẹ̀lú.\wj* 
\v 40 \wj Bí ẹnìkan bá fẹ́ gbé ọ lọ sílé ẹjọ́, tí ó sì fẹ́ gba ẹ̀wù àwọ̀tẹ́lẹ̀, jọ̀wọ́ agbádá rẹ fún un pẹ̀lú.\wj* 
\v 41 \wj Bí ẹni kan bá fẹ́ fi agbára mú ọ rìn ibùsọ̀ kan, bá a lọ ní ibùsọ̀ méjì.\wj* 
\v 42 \wj Fi fún ẹni tí ó béèrè lọ́wọ́ rẹ, láti ọ̀dọ̀ ẹni tí ó ń fẹ́ wín lọ́wọ́ rẹ, má ṣe mú ojú kúrò.\wj* 
\s1 Fẹ́ràn ọ̀tá rẹ 
\p  
\v 43 \wj “Ẹ̀yin ti gbọ́ bí òfin ti wí pé, ‘Ìwọ fẹ́ ọmọnìkejì rẹ, kí ìwọ sì kórìíra ọ̀tá rẹ̀.’\wj* 
\v 44 \wj Ṣùgbọ́n èmi wí fún yín pé, ẹ fẹ́ràn àwọn ọ̀tá yín kí ẹ sì gbàdúrà fún àwọn tí ń ṣe inúnibíni sí yín.\wj* 
\v 45 \wj Kí ẹ̀yin lè jẹ́ ọmọ Baba yín ti ń bẹ ní ọ̀run. Ó mú kí oòrùn rẹ̀ ràn sára ènìyàn búburú àti ènìyàn rere, ó rọ̀jò fún àwọn olódodo àti fún àwọn aláìṣòdodo.\wj* 
\v 46 \wj Bí ẹ̀yin bá fẹ́ràn àwọn tí ó fẹ́ràn yín nìkan, èrè kí ni ẹ̀yin ní? Àwọn agbowó òde kò ha ń ṣe bẹ́ẹ̀ gẹ́gẹ́?\wj* 
\v 47 \wj Àti bí ó bá sì jẹ́ pé kìkì àwọn arákùnrin yín nìkan ni ẹ̀yin ń kí, kín ni ẹ̀yin ń ṣe ju àwọn mìíràn lọ? Àwọn kèfèrí kò ha ń ṣe bẹ́ẹ̀ bí?\wj* 
\v 48 \wj Nítorí náà, ẹ jẹ́ pípé, gẹ́gẹ́ bí Baba yín tí ń bẹ ní ọ̀run ṣe jẹ́ pípé.\wj* 
\c 6  
\s1 Ìtọrẹ àánú 
\p  
\v 1 \wj “Ẹ kíyèsára kí ẹ má ṣe iṣẹ́ rere yín níwájú àwọn ènìyàn nítorí kí a le rí yín, Bí ẹ bá ṣe bẹ́ẹ̀, ẹ̀yin kò ni èrè kankan lọ́dọ̀ Baba yín ní ọ̀run.\wj* 
\p  
\v 2 \wj “Nítorí náà, nígbà ti ẹ́ bá ti ń fún aláìní, ẹ má ṣe fi fèrè kéde rẹ̀, gẹ́gẹ́ bí àwọn àgàbàgebè ti í ṣe ní Sinagọgu àti ní ìta gbangba; kí àwọn ènìyàn le yìn wọ́n. Lóòótọ́ ni mo wí fún yín, wọ́n ti gba èrè tí wọn ní kíkún.\wj* 
\v 3 \wj Ṣùgbọ́n bí ìwọ bá ń fi fún aláìní, má ṣe jẹ́ kí ọwọ́ òsì rẹ mọ ohun tí ọwọ́ ọ̀tún rẹ ń ṣe,\wj* 
\v 4 \wj kí ìfúnni rẹ má ṣe jẹ́ mí mọ̀. Nígbà náà ni Baba rẹ̀, tí ó sì mọ ohun ìkọ̀kọ̀ gbogbo, yóò san án fún ọ.\wj* 
\s1 Àdúrà 
\p  
\v 5 \wj “Nígbà tí ìwọ bá ń gbàdúrà, má ṣe ṣe bí àwọn àgàbàgebè, nítorí wọn fẹ́ràn láti máa dúró gbàdúrà ní Sinagọgu àti ní ẹ̀gbẹ́ ọ̀nà tí ènìyàn ti lè rí wọ́n. Lóòótọ́ ni mo wí fún yín, wọ́n ti gba èrè wọn ní kíkún.\wj* 
\v 6 \wj Ṣùgbọ́n nígbà tí ìwọ bá ń gbàdúrà, wọ inú iyàrá rẹ lọ, sé ìlẹ̀kùn mọ́ ara rẹ, gbàdúrà sí Baba rẹ ẹni tí ìwọ kò rí. Nígbà náà ni Baba rẹ tí ó mọ gbogbo ohun ìkọ̀kọ̀ rẹ, yóò san án fún ọ.\wj* 
\v 7 \wj Ṣùgbọ́n nígbà ti ẹ̀yin bá ń gbàdúrà, ẹ má ṣe àtúnwí asán bí àwọn aláìkọlà, nítorí wọn rò pé a ó tìtorí ọ̀pọ̀ ọ̀rọ̀ gbọ́ tiwọn.\wj* 
\v 8 \wj Ẹ má ṣe dàbí i wọn, nítorí Baba yín tí ń bẹ ní ọ̀run mọ ohun tí ẹ ṣe aláìní, kí ẹ tilẹ̀ tó béèrè lọ́wọ́ rẹ̀.\wj* 
\p  
\v 9 \wj “Nítorí náà, báyìí ni kí ẹ ṣe máa gbàdúrà:\wj* 
\q1 \wj “ ‘Baba wa tí ń bẹ ní ọ̀run,\wj* 
\q1 \wj ọ̀wọ̀ fún orúkọ yín,\wj* 
\q1  
\v 10 \wj kí ìjọba yín dé,\wj* 
\q1 \wj ìfẹ́ tiyín ni kí a ṣe\wj* 
\q2 \wj ní ayé bí ti ọ̀run.\wj* 
\q1  
\v 11 \wj Ẹ fún wa ní oúnjẹ òòjọ́ wa lónìí.\wj* 
\q1  
\v 12 \wj Ẹ dárí gbèsè wa jì wá,\wj* 
\q2 \wj Bí àwa ti ń dáríji àwọn ajigbèsè wa,\wj* 
\q1  
\v 13 \wj Ẹ má ṣe fà wá sínú ìdánwò,\wj* 
\q2 \wj ṣùgbọ́n ẹ gbà wá lọ́wọ́ ibi.\wj* 
\q2 \wj Nítorí ìjọba ni tiyín, àti agbára àti ògo, láéláé, Àmín.’\wj* 
\m  
\v 14 \wj Nítorí náà, bí ẹ̀yin bá dárí jí àwọn tó ṣẹ̀ yín, baba yín ọ̀run náà yóò dáríjì yín.\wj* 
\v 15 \wj Ṣùgbọ́n bí ẹ̀yin bá kọ̀ láti dárí ẹ̀ṣẹ̀ àwọn ènìyàn jì wọ́n, baba yín kò ní í dárí ẹ̀ṣẹ̀ yín jì yín.\wj* 
\s1 Àwẹ̀ 
\p  
\v 16 \wj “Nígbà tí ẹ̀yin bá gbààwẹ̀, ẹ má ṣe fa ojú ro bí àwọn àgàbàgebè ṣe máa ń ṣe nítorí wọn máa ń fa ojú ro láti fihàn àwọn ènìyàn pé àwọn ń gbààwẹ̀. Lóòótọ́ ni mo wí fún yín wọn ti gba èrè wọn ní kíkún.\wj* 
\v 17 \wj Ṣùgbọ́n nígbà tí ìwọ bá gbààwẹ̀, bu òróró sí orí rẹ, kí ó sì tún ojú rẹ ṣe dáradára.\wj* 
\v 18 \wj Kí ó má ṣe hàn sí ènìyàn pé ìwọ ń gbààwẹ̀, bí kò ṣe sì í Baba rẹ, ẹni tí ìwọ kò rí, àti pé, Baba rẹ tí ó rí ohun tí o ṣe ni ìkọ̀kọ̀, yóò san án fún ọ.\wj* 
\s1 Títo ìṣúra jọ sí Ọ̀run 
\p  
\v 19 \wj “Má ṣe to àwọn ìṣúra jọ fún ara rẹ ní ayé yìí, níbi tí kòkòrò ti le jẹ ẹ́, tí ó sì ti le bàjẹ́ àti ibi tí àwọn olè lè fọ́ tí wọ́n yóò sì jí i lọ.\wj* 
\v 20 \wj Dípò bẹ́ẹ̀ to ìṣúra rẹ jọ sí ọ̀run, níbi ti kòkòrò àti ìpáàrà kò ti lè bà á jẹ́, àti ní ibi tí àwọn olè kò le fọ́ wọlé láti jí í lọ.\wj* 
\v 21 \wj Nítorí ibi tí ìṣúra yín bá wà níbẹ̀ náà ni ọkàn yín yóò wà pẹ̀lú.\wj* 
\p  
\v 22 \wj “Ojú ni fìtílà ara. Bí ojú rẹ bá mọ́lẹ̀ kedere, gbogbo ara rẹ yóò jẹ́ kìkì ìmọ́lẹ̀.\wj* 
\v 23 \wj Ṣùgbọ́n bí ojú rẹ kò bá dára, gbogbo ara rẹ ni yóò kún fún òkùnkùn. Bí ìmọ́lẹ̀ ti ó wà nínú rẹ bá wá jẹ́ òkùnkùn, òkùnkùn náà yóò ti pọ̀ tó!\wj* 
\p  
\v 24 \wj “Kò sì í ẹnìkan tí ó lè sin ọ̀gá méjì. Òun yóò yà kórìíra ọ̀kan tí yóò fẹ́ràn èkejì, tàbí kí ó fi ara mọ́ ọ̀kan kí ó sì yan èkejì ní ìpọ̀sí. Ẹ̀yin kò lè sin Ọlọ́run àti owó papọ̀.\wj* 
\s1 Ẹ má ṣe àníyàn 
\p  
\v 25 \wj “Nítorí náà, mo wí fún yín, ẹ má ṣe ṣe àníyàn nípa ẹ̀mí yín, ohun tí ẹ ó jẹ àti èyí tí ẹ ó mu; tàbí nípa ara yín, ohun tí ẹ ó wọ̀. Ṣé ẹ̀mí kò ha ṣe pàtàkì ju oúnjẹ lọ tàbí ara ni kò ha ṣe pàtàkì ju aṣọ lọ?\wj* 
\v 26 \wj Ẹ wo àwọn ẹyẹ ojú ọrun; wọn kì í gbìn, bẹ́ẹ̀ ni wọn kì í kórè, bẹ́ẹ̀ ni wọn kì í kójọ sínú àká, síbẹ̀ Baba yín tí ń bẹ ní ọ̀run ń bọ́ wọn. Ẹ̀yin kò ha níye lórí jù wọ́n lọ bí?\wj* 
\v 27 \wj Ta ni nínú gbogbo yín nípa àníyàn ṣíṣe ti ó lè fi ìṣẹ́jú kan kún ọjọ́ ayé rẹ̀?\wj* 
\p  
\v 28 \wj “Kí ni ìdí ti ẹ fi ń ṣe àníyàn ní ti aṣọ? Ẹ wo bí àwọn lílì tí ń bẹ ní igbó ti ń dàgbà. Wọn kì í ṣiṣẹ́ bẹ́ẹ̀ ni wọn kì í rànwú.\wj* 
\v 29 \wj Bẹ́ẹ̀ ni mo wí fún yín pé, a kò ṣe Solomoni lọ́ṣọ̀ọ́ nínú gbogbo ògo rẹ̀ tó ọ̀kan nínú àwọn nǹkan wọ̀nyí.\wj* 
\v 30 \wj Ǹjẹ́ bí Ọlọ́run bá wọ koríko igbó ní aṣọ bẹ́ẹ̀, èyí tí ó wà níhìn-ín lónìí ti a sì gbà sínú iná lọ́la, kò ha ṣe ni ṣe yín lọ́ṣọ̀ọ́ tó bẹ́ẹ̀ àti jù bẹ́ẹ̀ lọ, ẹ̀yin tí ìgbàgbọ́ yín kéré?\wj* 
\v 31 \wj Nítorí náà, ẹ má ṣe ṣe àníyàn kí ẹ sì máa wí pé, ‘Kí ni àwa yóò jẹ?’ tàbí ‘Kí ni àwa yóò mu?’ tàbí ‘Irú aṣọ wo ni àwa yóò wọ̀?’\wj* 
\v 32 \wj Nítorí àwọn kèfèrí ń fi ìwọra wá àwọn nǹkan wọ̀nyí bẹ́ẹ̀ ni Baba yín ní ọ̀run mọ̀ dájúdájú pé ẹ ní ìlò àwọn nǹkan wọ̀nyí.\wj* 
\v 33 \wj Ṣùgbọ́n, ẹ kọ́kọ́ wá ìjọba Ọlọ́run ná àti òdodo rẹ̀, yóò sì fi gbogbo àwọn nǹkan wọ̀nyí kún un fún yín pẹ̀lú.\wj* 
\v 34 \wj Nítorí náà, ẹ má ṣe àníyàn ọ̀la, ọ̀la ni yóò ṣe àníyàn ara rẹ̀. Wàhálà ọjọ́ kọ̀ọ̀kan ti tó fún un.\wj* 
\c 7  
\s1 Ṣíṣe ìdájọ́ ẹnìkejì 
\p  
\v 1 \wj “Ẹ má ṣe dá ni lẹ́jọ́, kí a má bà dá yín lẹ́jọ́.\wj* 
\v 2 \wj Nítorí irú ìdájọ́ tí ẹ̀yin bá ṣe, òun ni a ó sì ṣe fún yín; irú òsùwọ̀n tí ẹ̀yin bá fi wọ́n, òun ni a ó sì fi wọ́n fún yín.\wj* 
\p  
\v 3 \wj “Èétiṣe tí ìwọ fi ń wo ẹ̀rún igi tí ń bẹ ní ojú arákùnrin rẹ, ṣùgbọ́n ìwọ kò kíyèsi ìtì igi tí ń bẹ ní ojú ara rẹ?\wj* 
\v 4 \wj Tàbí ìwọ ó ti ṣe wí fún arákùnrin rẹ pé, ‘Jẹ́ kí èmi yọ ẹ̀rún igi tí ń bẹ ni ojú rẹ,’ sì wò ó ìtì igi ń bẹ ní ojú ìwọ tìkára rẹ.\wj* 
\v 5 \wj Ìwọ àgàbàgebè, tètè kọ́ yọ ìtì igi jáde kúrò ní ojú ara rẹ ná, nígbà náà ni ìwọ yóò sì tó ríran kedere láti yọ ẹ̀rún igi tí ń bẹ ní ojú arákùnrin rẹ kúrò.\wj* 
\p  
\v 6 \wj “Ẹ má ṣe fi ohun mímọ́ fún ajá jẹ, ẹ má sì ṣe sọ ohun ọ̀ṣọ́ olówó iyebíye yín fún ẹlẹ́dẹ̀, bí ẹ̀yin bá ṣe bẹ́ẹ̀ kí wọ́n má bà fi ẹsẹ̀ tẹ̀ wọ́n mọ́lẹ̀, wọn a sì yí padà sí yín, wọn a sì bù yín jẹ.\wj* 
\s1 Béèrè, kànkùn, wá kiri 
\p  
\v 7 \wj “Béèrè, a ó sì fi fún yín; wá kiri, ẹ̀yin yóò sì rí; kànkùn, a ó sì ṣí i sílẹ̀ fún yín.\wj* 
\v 8 \wj Nítorí ẹnikẹ́ni tí ó béèrè ń rí gbà, ẹni tí ó bá sì wà kiri ń rí, ẹni bá sì kànkùn ni a yóò ṣi sílẹ̀ fún.\wj* 
\p  
\v 9 \wj “Ta ni ọkùnrin náà tí ń bẹ nínú yín, bí ọmọ rẹ̀ béèrè àkàrà, tí yóò jẹ́ fi òkúta fún un?\wj* 
\v 10 \wj Tàbí bí ó béèrè ẹja, tí yóò jẹ́ fún un ní ejò?\wj* 
\v 11 \wj Ǹjẹ́ bí ẹ̀yin tí í ṣe ènìyàn búburú bá mọ̀ bí a ti í fi ẹ̀bùn rere fún àwọn ọmọ yín, mélòó mélòó ni Baba yín tí ń bẹ ní ọ̀run yóò fi ohun rere fún àwọn tí ó béèrè lọ́wọ́ rẹ̀?\wj* 
\v 12 \wj Nítorí náà, nínú gbogbo ohunkóhun ti ẹ̀yin bá ń fẹ́ kí ènìyàn kí ó ṣe sí yín, bẹ́ẹ̀ ni kí ẹ̀yin kí ó ṣe sí wọn gẹ́gẹ́; nítorí èyí ni òfin àti àwọn wòlíì.\wj* 
\s1 Ọ̀nà tóóró àti ọnà gbòòrò 
\p  
\v 13 \wj “Ẹ ba ẹnu-ọ̀nà tóóró wọlé; gbòòrò ni ẹnu-ọ̀nà náà, àti oníbùú ni ojú ọ̀nà náà tí ó lọ sí ibi ìparun, ọ̀pọ̀lọpọ̀ ni àwọn ẹni tí ń bá ibẹ̀ wọlé.\wj* 
\v 14 \wj Nítorí kékeré ni ẹnu-ọ̀nà náà, tóóró sì ni ojú ọ̀nà náà, ti ó lọ sí ibi ìyè, díẹ̀ ni àwọn ẹni tí ó ń rìn ín.\wj* 
\s1 Igi àti èso rẹ̀ 
\p  
\v 15 \wj “Ẹ máa ṣọ́ra fún àwọn èké wòlíì tí wọ́n ń tọ̀ yín wá ní àwọ̀ àgùntàn, ṣùgbọ́n ní inú wọn apanijẹ ìkookò ni wọ́n.\wj* 
\v 16 \wj Nípa èso wọn ni ẹ̀yin ó fi mọ̀ wọn. Ǹjẹ́ ènìyàn ha lè ká èso àjàrà lára igi ọ̀gàn tàbí èso ọ̀pọ̀tọ́ lára ẹ̀gún òṣùṣú?\wj* 
\v 17 \wj Bẹ́ẹ̀ ni gbogbo igi rere a máa so èso rere ṣùgbọ́n igi búburú a máa so èso búburú.\wj* 
\v 18 \wj Igi rere kò le so èso búburú, bẹ́ẹ̀ ni igi búburú kò lè so èso rere.\wj* 
\v 19 \wj Gbogbo igi tí kò bá so èso rere, a gé e lulẹ̀, à wọ́ ọ jù sínú iná.\wj* 
\v 20 \wj Nítorí náà, nípa èso wọn ni ẹ̀yin yóò mọ̀ wọn.\wj* 
\p  
\v 21 \wj “Kì í ṣe gbogbo ẹni tó ń pè mí ní, ‘Olúwa, Olúwa,’ ni yóò wọ ìjọba ọ̀run, bí kò ṣe ẹni tó bá ń ṣe ìfẹ́ baba mi tí ń bẹ ní ọ̀run.\wj* 
\v 22 \wj Ọ̀pọ̀ ni yóò wí fún mi ní ọjọ́ náà pé, ‘Olúwa, Olúwa, àwa kò ha sọtẹ́lẹ̀ ní orúkọ rẹ, àti ní orúkọ rẹ kọ́ ni a fi lé ọ̀pọ̀ ẹ̀mí èṣù jáde, tí a sì ṣe ọ̀pọ̀ iṣẹ́ ìyanu?’\wj* 
\v 23 \wj Nígbà náà ni èmi yóò wí fún wọn pé, ‘Èmi kò mọ̀ yín rí, ẹ kúrò lọ́dọ̀ mi ẹ̀yin oníṣẹ́ ẹ̀ṣẹ̀.’\wj* 
\s1 Ọlọ́gbọ́n àti òmùgọ̀ ọ̀mọ̀lé 
\p  
\v 24 \wj “Nítorí ẹnikẹ́ni tí ó bá gbọ́ ọ̀rọ̀ tèmi wọ̀nyí, tí ó bá sì ṣe wọn, èmi ó fiwé ọlọ́gbọ́n ènìyàn kan, ti ó kọ́ ilé rẹ̀ sí orí àpáta.\wj* 
\v 25 \wj Òjò sì rọ̀, ìkún omi sì dé, afẹ́fẹ́ sì fẹ́, wọ́n sí bì lu ilé náà; síbẹ̀síbẹ̀ náà kò sì wó, nítorí tí a fi ìpìlẹ̀ rẹ̀ sọlẹ̀ lórí àpáta.\wj* 
\v 26 \wj Ẹnikẹ́ni tí ó bá sì gbọ́ ọ̀rọ̀ tèmi wọ̀nyí, tí kò bá sì ṣe wọ́n, òun ni èmi yóò fiwé aṣiwèrè ènìyàn kan tí ó kọ́ ilé rẹ̀ sí orí iyanrìn.\wj* 
\v 27 \wj Òjò sì rọ̀, ìkún omi sì dé, afẹ́fẹ́ sì fẹ́, wọ́n sì bì lu ilé náà, ilé náà sì wó; wíwó rẹ̀ sì pọ̀ jọjọ.”\wj* 
\p  
\v 28        Nígbà tí Jesu sì parí sísọ nǹkan wọ̀nyí, ẹnu ya àwọn ọ̀pọ̀ ènìyàn sí ẹ̀kọ́ rẹ̀,  
\v 29 nítorí ó ń kọ́ wọn bí ẹni tí ó ní àṣẹ, kì í ṣe bí i ti olùkọ́ òfin wọn. 
\c 8  
\s1 Ọkùnrin adẹ́tẹ̀ 
\p  
\v 1 Nígbà tí ó ti orí òkè sọ̀kalẹ̀, ọ̀pọ̀ ènìyàn ń tọ̀ ọ́ lẹ́yìn.  
\v 2   Sì wò ó, adẹ́tẹ̀ kan wà, ó wá ó sì wólẹ̀ níwájú rẹ̀ ó wí pé, “Olúwa, bí ìwọ bá fẹ́, ìwọ lè sọ mi di mímọ́.” 
\p  
\v 3 Jesu sì nà ọwọ́ rẹ̀, ó fi bà á, ó wí pé, \wj “Mo fẹ́, ìwọ di mímọ́.”\wj* Lójúkan náà, ẹ̀tẹ̀ rẹ̀ sì mọ́!  
\v 4  Jesu sì wí fún pé, \wj “Wò ó, má ṣe sọ fún ẹnìkan. Ṣùgbọ́n máa ba ọ̀nà rẹ̀ lọ, fi ara rẹ̀ hàn fún àlùfáà, kí o sì san ẹ̀bùn tí Mose pàṣẹ ní ẹ̀rí fún wọn.”\wj* 
\s1 Ìgbàgbọ́ balógun ọ̀rún 
\p  
\v 5       Nígbà tí Jesu sì wọ̀ Kapernaumu, balógun ọ̀rún kan tọ̀ ọ́ wá, ó bẹ̀bẹ̀ fún ìrànlọ́wọ́.  
\v 6 O sì wí pé, “Olúwa, ọmọ ọ̀dọ̀ mi dùbúlẹ̀ ààrùn ẹ̀gbà ni ilé, tòun ti ìrora ńlá.” 
\p  
\v 7 Jesu sì wí fún un pé, \wj “Èmi ń bọ̀ wá mú un láradá.”\wj* 
\p  
\v 8 Balógun ọ̀rún náà dáhùn, ó wí pé, “Olúwa, èmi kò yẹ ní ẹni tí ìwọ ń wọ̀ abẹ́ òrùlé rẹ̀, ṣùgbọ́n sọ kìkì ọ̀rọ̀ kan, a ó sì mú ọmọ ọ̀dọ̀ mi láradá.  
\v 9 Ẹni tí ó wà lábẹ́ àṣẹ sá ni èmi, èmi sí ní ọmọ-ogun lẹ́yìn mi. Bí mo wí fún ẹni kan pé, ‘Lọ,’ a sì lọ, àti fún ẹni kejì pé, ‘Wá,’ a sì wá, àti fún ọmọ ọ̀dọ̀ mi pé, ‘Ṣe èyí,’ a sì ṣe é.” 
\p  
\v 10 Nígbà tí Jesu gbọ́ èyí ẹnu yà á, ó sì wí fún àwọn tí ó ń tọ̀ ọ́ lẹ́yìn pé, \wj “Lóòótọ́ ni mo wí fún yín, èmi kò rí ẹnìkan ni Israẹli tó ní ìgbàgbọ́ ńlá bí irú èyí.\wj* 
\v 11 \wj Mo sì wí fún yín, ọ̀pọ̀lọpọ̀ ènìyàn ni yóò ti ìhà ìlà-oòrùn àti ìhà ìwọ̀-oòrùn wá, wọ́n á sì bá Abrahamu àti Isaaki àti Jakọbu jẹun ní ìjọba ọ̀run.\wj* 
\v 12 \wj Ṣùgbọ́n àwọn ọmọ ìjọba ni a ó sọ sínú òkùnkùn lóde, níbẹ̀ ni ẹkún àti ìpayínkeke yóò gbé wà.”\wj* 
\p  
\v 13 Nítorí náà Jesu sì wí fún balógun ọ̀run náà pé, \wj “Máa lọ ilé, ohun tí ìwọ gbàgbọ́ ti rí bẹ́ẹ̀.”\wj* A sì mú ọmọ ọ̀dọ̀ náà láradá ní wákàtí kan náà. 
\s1 Jesu wo ọ̀pọ̀ aláìsàn sàn 
\p  
\v 14       Nígbà tí Jesu sì dé ilé Peteru, ìyá ìyàwó Peteru dùbúlẹ̀ àìsàn ibà.  
\v 15 Ṣùgbọ́n nígbà tí Jesu fi ọwọ́ kan ọwọ́ rẹ̀, ibà náà fi í sílẹ̀, lẹ́sẹ̀kẹsẹ̀ ó sì dìde ó ń ṣe ìránṣẹ́ fún wọn. 
\p  
\v 16 Nígbà tí ó di àṣálẹ́, ọ̀pọ̀ ènìyàn tí ó ní ẹ̀mí èṣù ni a mú wá sọ́dọ̀ rẹ̀, ó sì fi ọ̀rọ̀ rẹ̀ lé àwọn ẹ̀mí èṣù náà jáde. A sì mú gbogbo àwọn ọlọ́kùnrùn láradá.  
\v 17  Kí èyí tí a ti sọ láti ẹnu wòlíì Isaiah lè ṣẹ pé, 
\q1 “Òun tìkára rẹ̀ gbà àìlera wa, 
\q2 ó sì ń ru ààrùn wa.” 
\s1 Ohun tí o gbà láti tẹ̀lé Jesu 
\p  
\v 18       Nígbà tí Jesu rí ọ̀pọ̀lọpọ̀ ènìyàn tó yí i ká, ó pàṣẹ pé kí wọ́n rékọjá sí òdìkejì adágún.  
\v 19 Olùkọ́ òfin kan sì tọ̀ ọ́ wá, ó wí fún un pé, “Olùkọ́, èmi ó má tọ̀ ọ́ lẹ́yìn níbikíbi tí ìwọ bá ń lọ.” 
\p  
\v 20 Jesu dá lóhùn pé, \wj “Àwọn kọ̀lọ̀kọ̀lọ̀ ní ihò, àwọn ẹyẹ ojú ọ̀run sì ni ìtẹ́; ṣùgbọ́n Ọmọ Ènìyàn kò ní ibi tí yóò fi orí rẹ̀ lé.”\wj* 
\p  
\v 21 Ọmọ-ẹ̀yìn rẹ̀ mìíràn sì wí fún un pé, “Olúwa, kọ́kọ́ jẹ́ kí èmi kí ó kọ́ lọ sìnkú baba mi ná.” 
\p  
\v 22       Ṣùgbọ́n Jesu wí fún un pé, \wj “Máa tọ̀ mí lẹ́yìn, sì jẹ́ kí àwọn òkú kí ó máa sin òkú ara wọn.”\wj* 
\s1 Jesu dá ìjì líle dúró 
\p  
\v 23       Nígbà náà ni ó bọ́ sínú ọkọ̀ ojú omi, àwọn ọmọ-ẹ̀yìn rẹ̀ tẹ̀lé e.  
\v 24 Ní àìròtẹ́lẹ̀, ìjì líle dìde lórí Òkun tó bẹ́ẹ̀ tí rírú omi fi bò ọkọ̀ náà mọ́lẹ̀; ṣùgbọ́n Jesu ń sùn.  
\v 25 Àwọn ọmọ-ẹ̀yìn rẹ̀ tọ̀ ọ́ wá, wọn jí i, wọ́n wí pe, “Olúwa, gbà wá! Àwa yóò rì!” 
\p  
\v 26       Ó sì wí fún wọn pé, \wj “Ẹ̀yin onígbàgbọ́ kékeré. Èéṣe ti ẹ̀yin fi ń bẹ̀rù?”\wj* Nígbà náà ní ó dìde dúró, ó sì bá ìjì àti rírú Òkun náà wí, gbogbo rẹ̀ sì parọ́rọ́. 
\p  
\v 27 Ṣùgbọ́n ẹnu yà àwọn ọkùnrin náà, wọ́n sì béèrè pé, “Irú ènìyàn wo ni èyí? Kódà ìjì líle àti rírú omi Òkun gbọ́ tirẹ̀?” 
\s1 Ìwòsàn ọkùnrin ẹlẹ́mìí èṣù méjì 
\p  
\v 28       Nígbà ti ó sì dé apá kejì ní ilẹ̀ àwọn ara Gadara, àwọn ọkùnrin méjì ẹlẹ́mìí èṣù ti inú ibojì wá pàdé rẹ̀. Wọn rorò gidigidi tó bẹ́ẹ̀ tí ẹnikẹ́ni kò le kọjá ní ọ̀nà ibẹ̀.  
\v 29  Wọ́n kígbe lóhùn rara wí pé, “Kí ní ṣe tàwa tìrẹ, Ìwọ Ọmọ Ọlọ́run? Ìwọ ha wá láti dá wa lóró ṣáájú ọjọ́ tí a yàn náà?” 
\p  
\v 30 Agbo ẹlẹ́dẹ̀ ńlá tí ń jẹ ń bẹ ní ọ̀nà jíjìn díẹ̀ sí wọn.  
\v 31 Àwọn ẹ̀mí èṣù náà bẹ̀ Jesu wí pé, “Bí ìwọ bá lé wa jáde, jẹ́ kí àwa kí ó lọ sínú agbo ẹlẹ́dẹ̀ yìí.” 
\p  
\v 32 Ó sì wí fún wọn pé, \wj “Ẹ máa lọ!”\wj* Nígbà tí wọn sì jáde, wọn lọ sínú agbo ẹlẹ́dẹ̀ náà; sì wò ó, gbogbo agbo ẹlẹ́dẹ̀ náà sì rọ́ gììrì sọ̀kalẹ̀ bèbè odò bọ́ sínú Òkun, wọ́n sì ṣègbé nínú omi.  
\v 33 Àwọn ẹni tí ń ṣọ wọn sì sá, wọ́n sì mú ọ̀nà wọn pọ̀n lọ sí ìlú, wọ́n ròyìn ohun gbogbo, àti ohun tí a ṣe fún àwọn ẹlẹ́mìí èṣù.  
\v 34 Nígbà náà ni gbogbo ará ìlú náà sì jáde wá í pàdé Jesu. Nígbà tí wọ́n sì rí i, wọ́n bẹ̀ ẹ́, kí ó lọ kúrò ní agbègbè wọn. 
\c 9  
\s1 Jesu mú arọ láradá 
\p  
\v 1       Jesu bọ́ sínú ọkọ̀, ó sì rékọjá odò lọ sí ìlú abínibí rẹ̀,  
\v 2  àwọn ọkùnrin kan gbé arọ kan tọ̀ ọ́ wá lórí àkéte rẹ̀. Nígbà tí Jesu rí ìgbàgbọ́ wọn, ó wí fún arọ náà pé, \wj “Ọmọ tújúká, a dárí ẹ̀ṣẹ̀ rẹ jì ọ́.”\wj* 
\p  
\v 3 Nígbà yìí ni àwọn olùkọ́ òfin wí fún ara wọn pé, “Ọkùnrin yìí ń sọ̀rọ̀-òdì!” 
\p  
\v 4 Jesu sì mọ̀ èrò inú wọn, ó wí pé, \wj “Nítorí kín ni ẹ̀yin ṣe ń ro búburú nínú yín?\wj* 
\v 5 \wj Èwo ni ó rọrùn jù: láti wí pé, ‘A dárí ẹ̀ṣẹ̀ rẹ jì ọ,’ tàbí wí pé, ‘Dìde, kí o sì máa rìn?’\wj* 
\v 6 \wj Ṣùgbọ́n kí ẹ̀yin kí ó lè mọ̀ pé Ọmọ Ènìyàn ní agbára ní ayé láti dárí ẹ̀ṣẹ̀ jì ni.”\wj* Ó sì wí fún arọ náà pé, \wj “Dìde, sì gbé àkéte rẹ, kí o sì máa lọ ilé rẹ.”\wj* 
\v 7 Ọkùnrin náà sì dìde, ó sì lọ ilé rẹ̀.  
\v 8 Nígbà tí ìjọ ènìyàn rí í ẹnu sì yà wọ́n, wọ́n yin Ọlọ́run lógo, ti ó fi irú agbára báyìí fún ènìyàn. 
\s1 Ìpè Matiu 
\p  
\v 9       Bí Jesu sì ti ń rékọjá láti ibẹ̀ lọ, o rí ọkùnrin kan ti à ń pè ní Matiu, ó jókòó ní ibùdó àwọn agbowó òde, ó sì wí fún un pé, \wj “Máa tọ̀ mí lẹ́yìn,”\wj* Matiu sì dìde, ó ń tọ̀ ọ́ lẹ́yìn. 
\p  
\v 10 Ó sì ṣe, bí Jesu tí jókòó ti ó ń jẹun nínú ilé Matiu, sì kíyèsi i, ọ̀pọ̀ àwọn agbowó òde àti ẹlẹ́ṣẹ̀ wá, wọ́n sì bá a jẹun pẹ̀lú àwọn ọmọ-ẹ̀yìn rẹ̀.  
\v 11 Nígbà tí àwọn Farisi sì rí i, wọ́n wí fún àwọn ọmọ-ẹ̀yìn rẹ̀ pé, “Èéṣe tí olùkọ́ yín fi ń bá àwọn agbowó òde àti àwọn ẹlẹ́ṣẹ̀ jẹun pọ̀?” 
\p  
\v 12 Ṣùgbọ́n nígbà tí Jesu gbọ́ èyí, ó wí fún wọn pé, \wj “Àwọn tí ara wọ́n le kò wá oníṣègùn bí kò ṣe àwọn tí ara wọn kò dá.\wj* 
\v 13 \wj Ṣùgbọ́n ẹ lọ kọ́ ohun ti èyí túmọ̀ sí: ‘Àánú ni èmi ń fẹ́, kì í ṣe ẹbọ,’ nítorí èmi kò wá láti pe àwọn olódodo, bí kò ṣe àwọn ẹlẹ́ṣẹ̀.”\wj* 
\s1 Ìbéèrè nípa àwẹ̀ lọ́wọ́ Jesu 
\p  
\v 14       Nígbà náà ni àwọn ọmọ-ẹ̀yìn Johanu tọ̀ ọ́ wá láti béèrè wí pé, “Èéṣe tí àwa àti àwọn Farisi fi ń gbààwẹ̀, ṣùgbọ́n tí àwọn ọmọ-ẹ̀yìn rẹ kò gbààwẹ̀?” 
\p  
\v 15 Jesu sì dáhùn pé, \wj “Àwọn ọmọ ilé ìyàwó ha le máa ṣọ̀fọ̀, nígbà tí ọkọ ìyàwó ń bẹ lọ́dọ̀ wọn? Ṣùgbọ́n ọjọ́ ń bọ̀ nígbà tí a ó gba ọkọ ìyàwó lọ́wọ́ wọn; nígbà náà ni wọn yóò gbààwẹ̀.\wj* 
\p  
\v 16 \wj “Kò sí ẹni tí ń fi ìrépé aṣọ tuntun lẹ ògbólógbòó ẹ̀wù; nítorí èyí tí a fi lẹ̀ ẹ́ yóò ya ní ojú lílẹ̀, aṣọ náà yóò sì ya púpọ̀ sì i ju ti ìṣáájú lọ.\wj* 
\v 17 \wj Bẹ́ẹ̀ ni kò sí ẹni tí fi ọtí tuntun sínú ògbólógbòó ìgò-awọ; bí a bá ṣe bẹ́ẹ̀, ìgò-awọ yóò bẹ́, ọtí á sì tú jáde, ìgò-awọ á sì ṣègbé. Ṣùgbọ́n ọtí tuntun ni wọn í fi sínú ìgò-awọ tuntun àwọn méjèèjì a sì ṣe déédé.”\wj* 
\s1 Ọmọbìnrin tó kú àti obìnrin onísun-ẹ̀jẹ̀ 
\p  
\v 18 Bí ó ti ń sọ nǹkan wọ̀nyí fún wọn, kíyèsi i, ìjòyè kan tọ̀ ọ́ wá, ó sì wólẹ̀ níwájú rẹ̀ wí pé, “Ọmọbìnrin mi kú nísinsin yìí, ṣùgbọ́n wá fi ọwọ́ rẹ̀ lé e, òun yóò sì yè.”  
\v 19 Jesu dìde ó sì bá a lọ àti àwọn ọmọ-ẹ̀yìn rẹ̀. 
\p  
\v 20 Sì kíyèsi i, obìnrin kan ti ó ní ìsun ẹ̀jẹ̀ ní ọdún méjìlá, ó wá lẹ́yìn rẹ̀, ó fi ọwọ́ kan ìṣẹ́tí aṣọ rẹ̀.  
\v 21 Nítorí ó wí nínú ara rẹ̀ pé, “Bí mo bá sá à le fi ọwọ́ kan ìṣẹ́tí aṣọ rẹ̀, ara mi yóò dá.” 
\p  
\v 22       Nígbà tí Jesu sì yí ara rẹ̀ padà tí ó rí i, ó wí pé, \wj “Ọmọbìnrin, tújúká, ìgbàgbọ́ rẹ mú ọ láradà.”\wj* A sì mú obìnrin náà láradá ni wákàtí kan náà. 
\p  
\v 23 Nígbà tí Jesu sí i dé ilé ìjòyè náà, ó bá àwọn afunfèrè àti ọ̀pọ̀ ènìyàn tí ó ń pariwo.  
\v 24 Ó wí fún wọn pé, \wj “Ẹ máa lọ; nítorí ọmọbìnrin náà kò kú, sísùn ni ó sùn.”\wj* Wọ́n sì fi i rín ẹ̀rín ẹlẹ́yà.  
\v 25 Ṣùgbọ́n nígbà tí a ti àwọn ènìyàn jáde, ó wọ ilé, ó sì fà ọmọbìnrin náà ní ọwọ́ sókè; bẹ́ẹ̀ ni ọmọbìnrin náà sì dìde.  
\v 26 Òkìkí èyí sì kàn ká gbogbo ilẹ̀ náà. 
\s1 Jesu wo afọ́jú àti odi sàn 
\p  
\v 27       Nígbà tí Jesu sì jáde níbẹ̀, àwọn ọkùnrin afọ́jú méjì tọ̀ ọ́ lẹ́yìn, wọ́n ń kígbe sókè wí pé, “Ṣàánú fún wa, ìwọ ọmọ Dafidi.” 
\p  
\v 28 Nígbà tí ó sì wọ̀ ilé, àwọn afọ́jú náà tọ̀ ọ́ wá, Jesu bi wọ́n pé, \wj “Ẹ̀yin gbàgbọ́ pé mo le ṣe èyí?”\wj* 
\p Wọn sì wí fún un pé, “Bẹ́ẹ̀ ni Olúwa, ìwọ lè ṣe é.” 
\p  
\v 29 Ó sì fi ọwọ́ bà wọ́n ní ojú, ó wí pé, \wj “Kí ó rí fún yín gẹ́gẹ́ bí ìgbàgbọ́ yín.”\wj* 
\v 30 Ojú wọn sì là; Jesu sì kìlọ̀ fún wọn gidigidi, wí pé, \wj “Kíyèsi i, kí ẹ má ṣe jẹ́ kí ẹnìkan kí ó mọ̀ nípa èyí.”\wj* 
\v 31 Ṣùgbọ́n nígbà tí wọ́n lọ, wọ́n ròyìn rẹ̀ yí gbogbo ìlú náà ká. 
\p  
\v 32       Bí wọ́n tí ń jáde lọ, wò ó wọ́n mú ọkùnrin odi kan tí ó ní ẹ̀mí èṣù tọ Jesu wá.  
\v 33 Nígbà tí a lé ẹ̀mí èṣù náà jáde, ọkùnrin tí ó ya odi sì fọhùn. Ẹnu sì ya àwọn ènìyàn, wọ́n wí pé, “A kò rí irú èyí rí ní Israẹli.” 
\p  
\v 34 Ṣùgbọ́n àwọn Farisi wí pé, “Agbára olórí àwọn ẹ̀mí èṣù ni ó fi ń lé àwọn ẹ̀mí èṣù jáde.” 
\s1 Àwọn Alágbàṣe Kéré 
\p  
\v 35       Jesu sì rìn yí gbogbo ìlú ńlá àti ìletò ká, ó ń kọ́ni nínú Sinagọgu wọn, ó sì ń wàásù ìyìnrere ìjọba ọrun, ó sì ń ṣe ìwòsàn ààrùn àti gbogbo àìsàn ní ara àwọn ènìyàn.  
\v 36  Nígbà tí ó rí ọ̀pọ̀ ènìyàn, àánú wọn ṣe é, nítorí àárẹ̀ mú wọn, wọn kò sì rí ìrànlọ́wọ́, bí àwọn àgùntàn tí kò ní olùṣọ́.  
\v 37  Nígbà náà ni ó wí fún àwọn ọmọ-ẹ̀yìn rẹ̀ pé, \wj “Lóòótọ́ ni ìkórè pọ̀ ṣùgbọ́n àwọn alágbàṣe kò tó nǹkan.\wj* 
\v 38 \wj Nítorí náà, ẹ gbàdúrà sí Olúwa ìkórè kí ó rán àwọn alágbàṣe sínú ìkórè rẹ̀.”\wj* 
\c 10  
\s1 Jesu rán àwọn méjìlá jáde 
\p  
\v 1       Jesu sì pe àwọn ọmọ-ẹ̀yìn rẹ̀ méjìlá sí ọ̀dọ̀; ó fún wọn ní àṣẹ láti lé ẹ̀mí àìmọ́ jáde àti láti ṣe ìwòsàn ààrùn àti àìsàn gbogbo. 
\b  
\li4  
\v 2 Orúkọ àwọn aposteli méjèèjìlá náà ni wọ̀nyí: 
\b  
\li1 ẹni àkọ́kọ́ ni Simoni ẹni ti a ń pè ni Peteru àti arákùnrin rẹ̀ Anderu; 
\li1 Jakọbu\f + \fr 10:2 \ft Jakọbu ẹni tí ó jẹ́ aposteli Kristi.\f* ọmọ Sebede àti arákùnrin rẹ̀ Johanu. 
\li1  
\v 3 Filipi àti Bartolomeu; 
\li1 Tomasi àti Matiu agbowó òde; 
\li1 Jakọbu ọmọ Alfeu àti Taddeu; 
\li1  
\v 4 Simoni ọmọ ẹgbẹ́ Sealoti, Judasi Iskariotu, ẹni tí ó da Jesu. 
\b  
\p  
\v 5       Àwọn méjèèjìlá wọ̀nyí ni Jesu ran, ó sì pàṣẹ fún wọn pé, \wj “Ẹ má ṣe lọ sì ọ̀nà àwọn kèfèrí, ẹ má ṣe wọ̀ ìlú àwọn ará Samaria.\wj* 
\v 6 \wj Ẹ kúkú tọ̀ àwọn àgùntàn ilé Israẹli tí ó nù lọ.\wj* 
\v 7 \wj Bí ẹ̀yin ti ń lọ, ẹ máa wàásù yìí wí pé, ‘Ìjọba ọ̀run kù sí dẹ̀dẹ̀.’\wj* 
\v 8 \wj Ẹ máa ṣe ìwòsàn fún àwọn aláìsàn, ẹ si jí àwọn òkú dìde, ẹ sọ àwọn adẹ́tẹ̀ di mímọ́, kí ẹ sì máa lé àwọn ẹ̀mí èṣù jáde. Ọ̀fẹ́ ni ẹ̀yin gbà á, ọ̀fẹ́ ni kí ẹ fi fún ni.\wj* 
\p  
\v 9 \wj “Ẹ má ṣe mú wúrà tàbí fàdákà tàbí idẹ sínú àpò ìgbànú yín,\wj* 
\v 10 \wj ẹ má ṣe mú àpò fún ìrìnàjò yín, kí ẹ má ṣe mú ẹ̀wù méjì, tàbí bàtà, tàbí ọ̀pá; oúnjẹ oníṣẹ́ yẹ fún un.\wj* 
\v 11 \wj Ìlúkílùú tàbí ìletòkíletò tí ẹ̀yin bá wọ̀, ẹ wá ẹni ti ó bá yẹ níbẹ̀ rí, níbẹ̀ ni kí ẹ sì gbé nínú ilé rẹ̀ títí tí ẹ̀yin yóò fi kúrò níbẹ̀.\wj* 
\v 12 \wj Nígbà tí ẹ̀yin bá sì wọ ilé kan, ẹ kí i wọn\wj*.  
\v 13 \wj Bí ilé náà bá sì yẹ, kí àlàáfíà yín kí ó bà sórí rẹ̀; ṣùgbọ́n bí kò bá yẹ, kí àlàáfíà yín kí ó padà sọ́dọ̀ yín.\wj* 
\v 14 \wj Bí ẹnikẹ́ni tí kò bá sì gbà yín, tàbí tí kò gba ọ̀rọ̀ yín, ẹ gbọn eruku ẹ̀ṣẹ̀ yín sílẹ̀ tí ẹ bá ń kúrò ní ilé tàbí ìlú náà.\wj* 
\v 15 \wj Lóòótọ́ ni mo wí fún yín, yóò sàn fún ìlú Sodomu àti Gomorra ní ọjọ́ ìdájọ́ ju àwọn ìlú náà lọ.\wj* 
\p  
\v 16 \wj “Mò ń rán yín lọ gẹ́gẹ́ bí àgùntàn sáàrín ìkookò. Nítorí náà, kí ẹ ní ìṣọ́ra bí ejò, kí ẹ sì ṣe onírẹ̀lẹ̀ bí àdàbà.\wj* 
\v 17 \wj Ẹ ṣọ́ra lọ́dọ̀ àwọn ènìyàn nítorí wọn yóò fi yín le àwọn ìgbìmọ̀ ìgbèríko lọ́wọ́ wọn yóò sì nà yín nínú Sinagọgu.\wj* 
\v 18 \wj Nítorí orúkọ mi, a ó mú yín lọ síwájú àwọn baálẹ̀ àti àwọn ọba, bí ẹlẹ́rìí sí wọn àti àwọn aláìkọlà.\wj* 
\v 19 \wj Nígbà tí wọ́n bá mú yín, ẹ má ṣe ṣàníyàn ohun tí ẹ ó sọ tàbí bí ẹ ó ṣe sọ ọ́. Ní ojú kan náà ni a ó fi ohun tí ẹ̀yin yóò sọ fún yín.\wj* 
\v 20 \wj Nítorí pé kì í ṣe ẹ̀yin ni ó sọ ọ́, bí kò ṣe Ẹ̀mí Baba yín tí ń sọ̀rọ̀ nípasẹ̀ yín.\wj* 
\p  
\v 21 \wj “Arákùnrin yóò sì fi arákùnrin fún pípa. Baba yóò fi àwọn ọmọ rẹ̀ fún ikú pa. Àwọn ọmọ yóò ṣọ̀tẹ̀ sí òbí wọn, wọn yóò sì mú kí a pa wọ́n.\wj* 
\v 22 \wj Gbogbo ènìyàn yóò sì kórìíra yín nítorí mi, ṣùgbọ́n gbogbo ẹni tí ó bá dúró ṣinṣin dé òpin ni a ó gbàlà\wj*.  
\v 23 \wj Nígbà tí wọn bá ṣe inúnibíni sì i yín ní ìlú kan, ẹ sálọ sì ìlú kejì. Lóòótọ́ ni mo wí fún yín, ẹ̀yin kò tì í le la gbogbo ìlú Israẹli já tán kí Ọmọ Ènìyàn tó dé.\wj* 
\p  
\v 24 \wj “Akẹ́kọ̀ọ́ kì í ju olùkọ́ rẹ̀ lọ, bẹ́ẹ̀ ni ọmọ ọ̀dọ̀ kì í ju ọ̀gá rẹ̀ lọ.\wj* 
\v 25 \wj Ó tọ́ fún akẹ́kọ̀ọ́ láti dàbí olùkọ́ rẹ̀ àti fún ọmọ ọ̀dọ̀ láti rí bí ọ̀gá rẹ̀. Nígbà tí wọ́n bá pe baálé ilé ní Beelsebulu, mélòó mélòó ni ti àwọn ènìyàn ilé rẹ̀!\wj* 
\p  
\v 26 \wj “Nítorí náà, ẹ má ṣe bẹ̀rù wọn, nítorí kò sí ohun tó ń bọ̀ tí kò ní í fi ara hàn, tàbí ohun tó wà ní ìkọ̀kọ̀ tí a kò ní mọ̀ ni gbangba.\wj* 
\v 27 \wj Ohun tí mo bá wí fún yín ní òkùnkùn, òun ni kí ẹ sọ ní ìmọ́lẹ̀. Èyí tí mo sọ kẹ́lẹ́kẹ́lẹ́ sì etí yín ni kí ẹ kéde rẹ́ lórí òrùlé.\wj* 
\v 28 \wj Ẹ má ṣe bẹ̀rù àwọn tí ó le pa ara nìkan; ṣùgbọ́n tí wọn kò lè pa ẹ̀mí. Ẹ bẹ̀rù Ẹni tí ó le pa ẹ̀mí àti ara run ní ọ̀run àpáàdì.\wj* 
\v 29 \wj Ológoṣẹ́ méjì kọ́ ni à ń tà ní owó idẹ wẹ́wẹ́ kan? Síbẹ̀ kò sí ọ̀kan nínú wọn tí yóò ṣubú lu ilẹ̀ lẹ́yìn Baba yin.\wj* 
\v 30 \wj Àti pé gbogbo irun orí yín ni a ti kà pé.\wj* 
\v 31 \wj Nítorí náà, ẹ má ṣe fòyà; ẹ̀yin ní iye lórí ju ọ̀pọ̀ ológoṣẹ́ lọ.\wj* 
\p  
\v 32 \wj “Ẹnikẹ́ni tí ó bá jẹ́wọ́ mi níwájú ènìyàn, òun náà ni èmi yóò jẹ́wọ́ rẹ̀ níwájú Baba mi ní ọ̀run.\wj* 
\v 33 \wj Ṣùgbọ́n ẹni tí ó bá sẹ́ mí níwájú àwọn ènìyàn, òun náà ni èmi náà yóò sọ wí pé n kò mọ̀ níwájú Baba mi ní ọ̀run.\wj* 
\p  
\v 34 \wj “Ẹ má ṣe rò pé mo mú àlàáfíà wá sí ayé, Èmi kò mú àlàáfíà wá bí kò ṣe idà.\wj* 
\v 35 \wj Nítorí èmi wá láti ya\wj* 
\q1 \wj “ ‘ọmọkùnrin ní ipa sí baba rẹ̀,\wj* 
\q2 \wj ọmọbìnrin ní ipa sí ìyá rẹ̀,\wj* 
\q1 \wj àti aya ọmọ sí ìyakọ rẹ.\wj* 
\q2  
\v 36 \wj Ará ilé ènìyàn ni yóò sì máa ṣe ọ̀tá rẹ̀.’\wj* 
\p  
\v 37 \wj “Ẹni tí ó bá fẹ́ baba rẹ̀ tàbí ìyá rẹ̀ jù mí lọ, kò yẹ ní tèmi, ẹni tí ó ba fẹ́ ọmọkùnrin tàbí ọmọbìnrin rẹ̀ jù mí lọ, kò yẹ ní tèmi.\wj* 
\v 38 \wj Ẹni tí kò bá gbé àgbélébùú rẹ̀ kí ó tẹ̀lé mi kò yẹ ní tèmi.\wj* 
\v 39 \wj Ẹni tí ó bá wa ẹ̀mí rẹ̀ yóò sọ ọ́ nù, ṣùgbọ́n ẹni tí ó bá sọ ẹ̀mí rẹ̀ nú nítorí tèmi ni yóò rí i.\wj* 
\p  
\v 40 \wj “Ẹni tí ó bá gbà yín, ó gbà mí, ẹni tí ó bá sì gbà mí gba ẹni tí ó rán mi.\wj* 
\v 41 \wj Ẹni tí ó ba gba wòlíì, nítorí pé ó jẹ́ wòlíì yóò jẹ èrè wòlíì, ẹni tí ó bá sì gba olódodo nítorí ti ó jẹ́ ènìyàn olódodo, yóò jẹ èrè olódodo.\wj* 
\v 42 \wj Ẹnikẹ́ni tí ó bá fi ago omi tútù fún ọ̀kan nínú àwọn onírẹ̀lẹ̀ wọ̀nyí mu nítorí tí ó jẹ́ ọmọ-ẹ̀yìn mi, lóòótọ́ ni mo wí fún yín, kò ní pàdánù èrè rẹ̀.”\wj* 
\c 11  
\s1 Jesu àti Johanu onítẹ̀bọmi 
\p  
\v 1       Lẹ́yìn ìgbà tí Jesu sì ti parí ọ̀rọ̀ tí ó ń sọ fún àwọn ọmọ-ẹ̀yìn rẹ̀ méjìlá, ó ti ibẹ̀ rékọjá láti máa kọ́ni àti láti máa wàásù ní àwọn ìlú Galili gbogbo. 
\p  
\v 2       Nígbà tí Johanu gbọ́ ohun tí Kristi ṣe nínú ẹ̀wọ̀n, ó rán àwọn ọmọ-ẹ̀yìn rẹ̀  
\v 3  láti béèrè lọ́wọ́ rẹ̀ pé, “Ṣe ìwọ ni ẹni tó ń bọ̀ wá tàbí kí a máa retí ẹlòmíràn?” 
\p  
\v 4 Jesu dáhùn ó wí pé, \wj “Ẹ padà lọ, ẹ sì sọ fún Johanu ohun tí ẹ̀yin gbọ́, àti èyí tí ẹ̀yin rí.\wj* 
\v 5 \wj Àwọn afọ́jú ń ríran, àwọn amúnkùn ún rìn, a ń wẹ àwọn adẹ́tẹ̀ mọ́ kúrò nínú ẹ̀tẹ̀ wọn, àwọn adití ń gbọ́rọ̀, a ń jí àwọn òkú dìde, a sì ń wàásù ìyìnrere fún àwọn òtòṣì.\wj* 
\v 6 \wj Alábùkún fún ni ẹni tí kò rí ohun ìkọ̀sẹ̀ nípa mi.”\wj* 
\p  
\v 7 Nígbà tí àwọn ọmọ-ẹ̀yìn Johanu ti lọ tán, Jesu bẹ̀rẹ̀ sí í sọ fún ọ̀pọ̀ ènìyàn nípa ti Johanu: \wj “Kí ni ẹ̀yin jáde lọ wò ní aginjù? Ewéko tí afẹ́fẹ́ ń mi?\wj* 
\v 8 \wj Bí kò bá ṣe bẹ́ẹ̀, kí ni ẹ̀yin lọ òde lọ í wò? Ọkùnrin tí a wọ̀ ni aṣọ dáradára? Rárá àwọn ti ó wọ aṣọ dáradára wà ní ààfin ọba.\wj* 
\v 9 \wj Àní kí ní ẹ jáde láti lọ wò? Wòlíì? Bẹ́ẹ̀ ni, mo wí fún yín, ó sì ju wòlíì lọ.”\wj* 
\v 10 \wj Èyí ni ẹni tí a ti kọ̀wé rẹ̀ pé:\wj* 
\q1 \wj “ ‘Èmi yóò rán ìránṣẹ́ mi síwájú rẹ,\wj* 
\q2 \wj ẹni tí yóò tún ọ̀nà rẹ ṣe níwájú rẹ.’\wj* 
\m  
\v 11 \wj Lóòótọ́ ni mó wí fún yín, nínú àwọn tí a bí nínú obìnrin, kò sí ẹni tí ó tí í dìde tí ó ga ju Johanu onítẹ̀bọmi lọ, síbẹ̀ ẹni tí ó kéré jù ní ìjọba ọ̀run ni ó pọ̀jù ú lọ.\wj* 
\v 12 \wj Láti ìgbà ọjọ́ Johanu onítẹ̀bọmi títí di àkókò yìí ni ìjọba ọ̀run ti di à fi agbára wọ̀, àwọn alágbára ló ń fi ipá gbà á.\wj* 
\v 13 \wj Nítorí náà gbogbo òfin àti wòlíì ni ó sọtẹ́lẹ̀ kí Johanu kí ó tó dé.\wj* 
\v 14 \wj Bí ẹ̀yin yóò bá gbà á, èyí ni Elijah tó ń bọ̀ wá.\wj* 
\v 15 \wj Ẹni tí ó bá ní etí, kí ó gbọ́.\wj* 
\p  
\v 16 \wj “Kí ni èmi ìbá fi ìran yìí wé? Ó dàbí àwọn ọmọ kékeré tí ń jókòó ní ọjà tí wọ́n sì ń ké pe àwọn ẹlẹgbẹ́ wọn:\wj* 
\q1  
\v 17 \wj “ ‘Àwa ń fun fèrè fún yín,\wj* 
\q2 \wj ẹ̀yin kò jó;\wj* 
\q1 \wj àwa kọrin ọ̀fọ̀\wj* 
\q2 \wj ẹ̀yin kò káàánú.’\wj* 
\m  
\v 18 \wj Nítorí Johanu wá kò bá a yín jẹ bẹ́ẹ̀ ni kò mu, ẹ̀yin sì wí pé, ‘Ó ní ẹ̀mí èṣù.’\wj* 
\v 19 \wj Ọmọ Ènìyàn wá bá a yín jẹun, ó sì bá yin mu, wọ́n wí pé, ‘Ọ̀jẹun àti ọ̀mùtí; ọ̀rẹ́ àwọn agbowó òde àti àwọn ẹlẹ́ṣẹ̀.’ Ṣùgbọ́n a dá ọgbọ́n láre nípa ìṣe rẹ̀.”\wj* 
\s1 Ègbé ni fún àwọn ìlú tí kò ronúpìwàdà 
\p  
\v 20       Nígbà náà ni Jesu bẹ̀rẹ̀ sí í bá ìlú tí ó ti ṣe ọ̀pọ̀ iṣẹ́ ìyanu rẹ̀ wí, nítorí wọn kò ronúpìwàdà.  
\v 21 Ó wí pé, \wj “Ègbé ni fún ìwọ Korasini, ègbé ni fún ìwọ Betisaida! Ìbá ṣe pé a ti ṣe àwọn iṣẹ́ ìyanu tí a ṣe nínú yín ní a ṣe ni Tire àti Sidoni, àwọn ènìyàn wọn ìbá ti ronúpìwàdà ti pẹ́ nínú aṣọ ọ̀fọ̀ àti eérú.\wj* 
\v 22 \wj Ṣùgbọ́n mo wí fún yín, yóò sàn fún Tire àti Sidoni ní ọjọ́ ìdájọ́ jù fún yín.\wj* 
\v 23 \wj Àti ìwọ Kapernaumu, a ó ha gbé ọ ga sókè ọ̀run? Rárá, a ó rẹ̀ ọ́ sílẹ̀ sí ipò òkú. Nítorí, ìbá ṣe pé a ti ṣe iṣẹ́ ìyanu tí a ṣe nínú rẹ ní Sodomu, òun ìbá wà títí di òní.\wj* 
\v 24 \wj Lóòótọ́ yóò sàn fún ilẹ̀ Sodomu ní ọjọ́ ìdájọ́ jù fún ìwọ lọ.”\wj* 
\s1 Ìsinmi fún aláàárẹ̀ 
\p  
\v 25       Nígbà náà ni Jesu wí pé, \wj “Mo yìn ọ Baba, Olúwa ọ̀run àti ayé, nítorí ìwọ ti fi òtítọ́ yìí pamọ́ fún àwọn tó jẹ́ ọlọ́gbọ́n àti amòye, Ìwọ sì ti fi wọ́n hàn fún àwọn ọmọ wẹ́wẹ́.\wj* 
\v 26 \wj Bẹ́ẹ̀ ni, Baba, nítorí ó wù ọ́ láti ṣe bẹ́ẹ̀.\wj* 
\p  
\v 27 \wj “Ohun gbogbo ni Baba mi ti fi sí ìkáwọ́ mi. Kò sí ẹni tí ó mọ ọmọ bí kò ṣe Baba, bẹ́ẹ̀ ni kò sí ẹnikẹ́ni tí ó mọ Baba, bí kò ṣe ọmọ, àti àwọn tí ọmọ yan láti fi ara hàn fún.\wj* 
\p  
\v 28 \wj “Ẹ wá sọ́dọ̀ mi gbogbo ẹ̀yin tí ń ṣiṣẹ́ tí a sì di ẹrù wíwúwo lé lórí, èmi yóò sì fún yín ní ìsinmi.\wj* 
\v 29 \wj Ẹ gbé àjàgà mi wọ̀. Ẹ kọ́ ẹ̀kọ́ lọ́dọ̀ mi nítorí onínútútù àti onírẹ̀lẹ̀ ọkàn ni èmi, ẹ̀yin yóò sì ri ìsinmi fún ọkàn yín.\wj* 
\v 30 \wj Nítorí àjàgà mi rọrùn ẹrù mi sì fúyẹ́.”\wj* 
\c 12  
\s1 Olúwa ọjọ́ ìsinmi 
\p  
\v 1       Ní àkókò náà ni Jesu ń la àárín oko ọkà kan lọ ní ọjọ́ ìsinmi, ebi sì ń pa àwọn ọmọ-ẹ̀yìn rẹ̀. Wọ́n sì bẹ̀rẹ̀ sí i ya orí ọkà, wọ́n sì ń jẹ ẹ́.  
\v 2 Nígbà tí àwọn Farisi rí èyí. Wọ́n wí fún pé, “Wò ó! Àwọn ọmọ-ẹ̀yìn rẹ ń ṣe ohun tí kò bá òfin mu ní ọjọ́ ìsinmi.” 
\p  
\v 3       Jesu dáhùn pé, \wj “Ẹ̀yin kò ha ka ohun tí Dafidi ṣe nígbà tí ebi ń pa á àti àwọn tí ó wà lọ́dọ̀ rẹ̀.\wj* 
\v 4 \wj Ó wọ inú ilé Ọlọ́run, òun àti àwọn ènìyàn rẹ̀ jẹ àkàrà tí a yà sọ́tọ̀, èyí tí kò yẹ fún wọn láti jẹ, bí kò ṣe fún àwọn àlùfáà nìkan.\wj* 
\v 5 \wj Tàbí ẹ̀yin kò ti kà á nínú òfin pé ní ọjọ́ ìsinmi, àwọn àlùfáà tí ó wà ní tẹmpili ń ba ọjọ́ ìsinmi jẹ́ tí wọ́n sì wà láìjẹ̀bi.\wj* 
\v 6 \wj Ṣùgbọ́n mo wí fún yín, ẹni tí ó pọ̀ ju tẹmpili lọ wà níhìn-ín.\wj* 
\v 7 \wj Bí ó bá jẹ́ pé ẹ mọ ìtumọ̀ ọ̀rọ̀ yìí, ‘Àánú ni èmi ń fẹ́ kì í ṣe ẹbọ,’ ẹ̀yin kì bá tí dá aláìlẹ́ṣẹ̀ lẹ́bi.\wj* 
\v 8 \wj Nítorí pé Ọmọ Ènìyàn jẹ́ Olúwa ọjọ́ ìsinmi.”\wj* 
\p  
\v 9       Nígbà tí Jesu kúrò níbẹ̀ ó lọ sí Sinagọgu wọn,  
\v 10 ọkùnrin kan tí ọwọ́ rẹ̀ kan rọ wà níbẹ̀. Wọ́n ń wá ọ̀nà láti fi ẹ̀sùn kan Jesu, wọ́n béèrè lọ́wọ́ rẹ̀ pé, “Ǹjẹ́ ó tọ́ láti mú ènìyàn láradá ní ọjọ́ ìsinmi?” 
\p  
\v 11       Ó dá wọn lóhùn pé, \wj “Bí ó bá jẹ́ wí pé bí ẹnikẹ́ni nínú yín bá ní àgùntàn kan ṣoṣo, tí ó sì bọ́ sínú kòtò ní ọjọ́ ìsinmi, ǹjẹ́ kì yóò dìímú, kí ó sì fà á jáde.\wj* 
\v 12 \wj Ǹjẹ́ mélòó mélòó ní ènìyàn ní iye lórí ju àgùntàn kan lọ! Nítorí náà ó yẹ láti ṣe rere ní ọjọ́ ìsinmi.”\wj* 
\p  
\v 13 Nígbà náà, ó sì wí fún ọkùnrin náà pé, \wj “Na ọwọ́ rẹ,”\wj* bí òun sì ti nà án, ọwọ́ rẹ̀ sì bọ̀ sí ipò rẹ̀ gẹ́gẹ́ bí ọwọ́ èkejì.  
\v 14  Síbẹ̀ àwọn Farisi jáde lọ pe ìpàdé láti dìtẹ̀ mú un àti bí wọn yóò ṣe pa Jesu. 
\s1 Ìránṣẹ́ tí Ọlọ́run yàn 
\p  
\v 15       Nígbà tí Jesu sì mọ̀, ó yẹra kúrò níbẹ̀. Ọ̀pọ̀ ìjọ ènìyàn sì ń tọ̀ ọ́ lẹ́yìn, ó sì mú gbogbo àwọn aláìsàn láradá.  
\v 16 Ṣùgbọ́n ó kìlọ̀ fún wọn pé kí wọ́n kí ó má ṣe fi òun hàn.  
\v 17 Èyí jẹ́ ìmúṣẹ àsọtẹ́lẹ̀ èyí tí wòlíì Isaiah sọ nípa rẹ̀ pé, 
\q1  
\v 18       “Ẹ wo ìránṣẹ́ mi ẹni tí mo yàn. 
\q2 Àyànfẹ́ mi ni ẹni tí inú mi dùn sí gidigidi; 
\q1 èmi yóò fi ẹ̀mí mi fún un. 
\q2 Òun yóò sì ṣe ìdájọ́ àwọn kèfèrí. 
\q1  
\v 19 Òun kì yóò jà, bẹ́ẹ̀ ni kì yóò kígbe; 
\q2 ẹnikẹ́ni kì yóò gbọ́ ohùn rẹ ní ìgboro. 
\q1  
\v 20 Koríko odò títẹ̀ kan ni òun kì yóò fọ́, 
\q2 àti òwú-fìtílà tí ń jó tan an lọ lòun kì yóò fẹ́ pa. 
\q1 Títí yóò fi mú ìdájọ́ dé ìṣẹ́gun. 
\q2  
\v 21 Ní orúkọ rẹ̀ ni gbogbo kèfèrí yóò fi ìrètí wọn sí.” 
\s1 Jesu àti Beelsebulu 
\p  
\v 22       Nígbà náà ni wọ́n mú ọkùnrin kan tó ni ẹ̀mí èṣù tọ̀ ọ́ wá, tí ó afọ́jú, tí ó tún ya odi. Jesu sì mú un láradá kí ó le sọ̀rọ̀, ó sì ríran.  
\v 23 Ẹnu sì ya gbogbo àwọn ènìyàn. Wọ́n wí pé, “Èyí ha lè jẹ́ Ọmọ Dafidi bí?” 
\p  
\v 24       Ṣùgbọ́n nígbà tí àwọn Farisi gbọ́ èyí, wọ́n wí pé, “Nípa Beelsebulu nìkan, tí í ṣe ọba ẹ̀mí èṣù ni ọkùnrin yìí fi lé àwọn ẹ̀mí èṣù jáde.” 
\p  
\v 25 Jesu tí ó mọ èrò wọn, ó wí fún wọn pé, \wj “Ìjọbakíjọba tí ó bá yapa sí ara rẹ̀ yóò parun, ìlúkílùú tàbí ilékílé tí ó bá yapa sí ara rẹ̀ kì yóò dúró.\wj* 
\v 26 \wj Bí èṣù bá sì ń lé èṣù jáde, a jẹ́ wí pé, ó ń yapa sí ara rẹ̀. Ìjọba rẹ yóò ha ṣe le dúró?\wj* 
\v 27 \wj Àti pé, bi èmi bá ń lé àwọn ẹ̀mí èṣù jáde nípa Beelsebulu, nípa ta ni àwọn ènìyàn yín fi ń lé wọn jáde? Nítorí náà ni wọn yóò ṣe má ṣe ìdájọ́ yín.\wj* 
\v 28 \wj Ṣùgbọ́n bí ó bá jẹ́ pé nípa Ẹ̀mí Ọlọ́run ni èmi fi ń lé àwọn ẹ̀mí èṣù jáde, a jẹ́ pé ìjọba Ọlọ́run ti dé bá yín.\wj* 
\p  
\v 29 \wj “Tàbí, báwo ni ẹnikẹ́ni ṣe lè wọ ilé alágbára lọ kí ó sì kó ẹrù rẹ̀, bí kò ṣe pé ó kọ́kọ́ di alágbára náà? Nígbà náà ni ó tó lè kó ẹrù rẹ̀ lọ.\wj* 
\p  
\v 30 \wj “Ẹni tí kò bá wà pẹ̀lú mi, òun lòdì sí mi, ẹni tí kò bá mi kójọpọ̀ ń fọ́nká.\wj* 
\v 31 \wj Nítorí èyí, mo wí fún yín, gbogbo ẹ̀ṣẹ̀ àti ọ̀rọ̀-òdì ni a yóò dárí rẹ̀ jí ènìyàn, ṣùgbọ́n ìsọ̀rọ̀-òdì sí Ẹ̀mí Mímọ́ kò ní ìdáríjì.\wj* 
\v 32 \wj Ẹnikẹ́ni tí ó bá sọ̀rọ̀-òdì sí Ọmọ Ènìyàn, a ó dáríjì í, ṣùgbọ́n ẹni tí ó bá sọ ọ̀rọ̀-òdì sí Ẹ̀mí Mímọ́, a kì yóò dáríjì í, ìbá à ṣe ní ayé yìí tàbí ní ayé tí ń bọ̀.\wj* 
\p  
\v 33 \wj “E sọ igi di rere, èso rẹ̀ a sì di rere tàbí kí ẹ sọ igi di búburú, èso rẹ a sì di búburú, nítorí nípa èso igi ni a ó fi mọ̀ igi.\wj* 
\v 34 \wj Ẹ̀yin ọmọ paramọ́lẹ̀, báwo ni ẹ̀yin tí ẹ jẹ búburú ṣe lè sọ̀rọ̀ rere? Ọkàn ènìyàn ni ó ń darí irú ọ̀rọ̀ tí ó lè jáde lẹ́nu rẹ̀.\wj* 
\v 35 \wj Ẹni rere láti inú yàrá ìṣúra rere ọkàn rẹ̀ ní mú ohun rere jáde wá, àti ẹni búburú láti inú ìṣúra búburú ni; mu ohun búburú jáde wá.\wj* 
\v 36 \wj Ṣùgbọ́n, mo sọ èyí fún yín, ẹ̀yin yóò jíyìn gbogbo ìsọkúsọ yín ní ọjọ́ ìdájọ́.\wj* 
\v 37 \wj Nítorí nípa ọ̀rọ̀ ẹnu yín ni a fi dá yin láre, nípa ọ̀rọ̀ ẹnu yín sì ni a ó fi dá yin lẹ́bi.”\wj* 
\s1 Àmì Jona 
\p  
\v 38       Nígbà náà ni, díẹ̀ nínú àwọn Farisi àti àwọn olùkọ́ òfin wí fún pé “Olùkọ́, àwa fẹ́ rí iṣẹ́ àmì kan lọ́dọ̀ rẹ̀”. 
\p  
\v 39 Ó sì dá wọn lóhùn wí pé, \wj “Ìran búburú àti ìran panṣágà ń béèrè àmì; ṣùgbọ́n kò sí àmì tí a ó fi fún un, bí kò ṣe àmì Jona wòlíì.\wj* 
\v 40 \wj Bí Jona ti gbé inú ẹja ńlá fún ọ̀sán mẹ́ta àti òru mẹ́ta, bẹ́ẹ̀ gẹ́gẹ́ ni ẹ̀mí Ọmọ Ènìyàn yóò gbé ní inú ilẹ̀ fún ọ̀sán mẹ́ta àti òru mẹ́ta.\wj* 
\v 41 \wj Àwọn ará Ninefe yóò dìde pẹ̀lú ìran yìí ní ọjọ́ ìdájọ́. Wọn yóò sì dá a lẹ́bi. Nítorí pé wọ́n ronúpìwàdà nípa ìwàásù Jona. Ṣùgbọ́n báyìí ẹni tí ó pọ̀jù Jona wà níhìn-ín yìí.\wj* 
\v 42 \wj Ọbabìnrin gúúsù yóò sì dìde ní ọjọ́ ìdájọ́ sí ìran yìí yóò sì dá a lẹ́bi; nítorí tí ó wá láti ilẹ̀ ìkangun ayé láti gbọ́ ọ̀rọ̀ ọgbọ́n láti ẹnu Solomoni. Ṣùgbọ́n báyìí ẹni tí ó pọ̀jù Solomoni ń bẹ níhìn-ín yìí.\wj* 
\p  
\v 43 \wj “Nígbà tí ẹ̀mí búburú kan bá jáde lára ènìyàn, a máa rìn ní ibi gbígbẹ́, a máa wá ibi ìsinmi, kò sì ní rí i.\wj* 
\v 44 \wj Nígbà náà ni ẹ̀mí náà yóò wí pé, ‘Èmi yóò padà sí ara ọkùnrin tí èmí ti wá.’ Bí ó bá sì padà, tí ó sì bá ọkàn ọkùnrin náà ni òfìfo, a gbà á mọ́, a sì ṣe é ní ọ̀ṣọ́.\wj* 
\v 45 \wj Nígbà náà ni yóò lọ, yóò sì mú ẹ̀mí méje mìíràn pẹ̀lú ara rẹ̀, tí ó burú ju òun fúnra rẹ̀ lọ. Gbogbo wọn yóò sì wá sí inú rẹ̀, wọn yóò máa gbé ibẹ̀. Ìgbẹ̀yìn ọkùnrin náà a sì burú ju ìṣáájú rẹ̀ lọ. Bẹ́ẹ̀ gẹ́gẹ́ ni yóò rí fún ìran búburú yìí pẹ̀lú.”\wj* 
\s1 Ìyá Jesu àti àwọn arákùnrin rẹ̀ 
\p  
\v 46       Nígbà tí ó ń sọ̀rọ̀ wọ̀nyí fún àwọn ènìyàn, wò ó, ìyá rẹ̀ àti àwọn arákùnrin rẹ̀ dúró lóde, wọ́n fẹ́ bá a sọ̀rọ̀.  
\v 47 Nígbà náà ni ẹnìkan wí fún un pé, “Ìyá rẹ àti àwọn arákùnrin rẹ ń dúró dè ọ́ lóde wọ́n ń fẹ́ bá ọ sọ̀rọ̀.” 
\p  
\v 48 Ó sì fún ni èsì pé, \wj “Ta ni ìyá mi? Ta ni àwọn arákùnrin mi?”\wj* 
\v 49 Ó nawọ́ sí àwọn ọmọ-ẹ̀yìn rẹ̀, ó wí pé, \wj “Wò ó, ìyá mi àti àwọn arákùnrin mi ni wọ̀nyí.”\wj* 
\v 50  Nítorí náà, \wj “Ẹnikẹ́ni tí ó bá ṣe ìfẹ́ Baba mi tí ń bẹ ní ọ̀run, ni arákùnrin mi àti arábìnrin mi àti ìyá mi.”\wj* 
\c 13  
\s1 Òwe afúnrúgbìn 
\p  
\v 1       Ní ọjọ́ kan náà, Jesu kúrò ní ilé, ó jókòó sí etí Òkun.  
\v 2 Ọ̀pọ̀lọpọ̀ ènìyàn péjọ sọ́dọ̀ rẹ̀, tó bẹ́ẹ̀ tí ó fi bọ́ sínú ọkọ̀ ojú omi, ó jókòó, gbogbo ènìyàn sì dúró létí Òkun.  
\v 3 Nígbà náà ni ó fi ọ̀pọ̀lọpọ̀ òwe bá wọn sọ̀rọ̀, wí pé, \wj “Àgbẹ̀ kan jáde lọ gbin irúgbìn sínú oko rẹ̀.\wj* 
\v 4 \wj Bí ó sì ti gbin irúgbìn náà, díẹ̀ bọ́ sí ẹ̀bá ọ̀nà, àwọn ẹyẹ sì wá, wọ́n sì jẹ ẹ́.\wj* 
\v 5 \wj Díẹ̀ bọ́ sórí ilẹ̀ orí àpáta, níbi ti kò sí erùpẹ̀ púpọ̀. Àwọn irúgbìn náà sì dàgbàsókè kíákíá, nítorí erùpẹ̀ kò pọ̀ lórí wọn.\wj* 
\v 6 \wj Ṣùgbọ́n nígbà tí oòrùn gòkè, oòrùn gbígbóná jó wọn, gbogbo wọn sì rọ, wọ́n kú nítorí wọn kò ni gbòǹgbò.\wj* 
\v 7 \wj Àwọn irúgbìn mìíràn bọ́ sí àárín ẹ̀gún, ẹ̀gún sì dàgbà, ó sì fún wọn pa.\wj* 
\v 8 \wj Ṣùgbọ́n díẹ̀ tó bọ́ sórí ilẹ̀ rere, ó sì so èso, òmíràn ọgọ́rùn-ún, òmíràn ọgọ́tọ̀ọ̀ta, òmíràn ọgbọọgbọ̀n, ni ìlọ́po èyí ti ó gbìn.\wj* 
\v 9 \wj Ẹni tí ó bá létí, kí ó gbọ́.”\wj* 
\p  
\v 10       Àwọn ọmọ-ẹ̀yìn rẹ̀ tọ̀ ọ́ wá, wọ́n bí i pé, “Èéṣe tí ìwọ ń fi òwe bá àwọn ènìyàn sọ̀rọ̀?” 
\p  
\v 11 Ó sì da wọn lóhùn pé, \wj “Ẹ̀yin ni a ti fi fún láti mọ ohun ìjìnlẹ̀ ìjọba ọ̀run, ṣùgbọ́n kì í ṣe fún wọn.\wj* 
\v 12 \wj Ẹnikẹ́ni tí ó ní, òun ni a ó fún sí i, yóò sì ní lọ́pọ̀lọ́pọ̀. Ṣùgbọ́n lọ́wọ́ ẹni tí kò ní, ni a ó ti gbà èyí kékeré tí ó ní náà.\wj* 
\v 13 \wj Ìdí nìyìí tí mo fi ń fi òwe bá wọn sọ̀rọ̀:\wj* 
\q1 \wj “Ní ti rí rí, wọn kò rí;\wj* 
\q2 \wj ní ti gbígbọ́ wọn kò gbọ́, bẹ́ẹ̀ ni kò sì yé wọn.\wj* 
\m  
\v 14 \wj Sí ara wọn ni a ti mú àsọtẹ́lẹ̀ wòlíì Isaiah ṣẹ:\wj* 
\q1 \wj “ ‘Ní gbígbọ́ ẹ̀yin yóò gbọ́ ṣùgbọ́n kì yóò sì yé yín;\wj* 
\q2 \wj ní rí rí ẹ̀yin yóò rí, ṣùgbọ́n ẹ̀yin kì yóò sì mòye.\wj* 
\q1  
\v 15 \wj Nítorí àyà àwọn ènìyàn yìí sébọ́\wj* 
\q2 \wj etí wọn sì wúwo láti gbọ́\wj* 
\q2 \wj ojú wọn ni wọ́n sì dì\wj* 
\q1 \wj nítorí kí àwọn má ba à fi ojú wọn rí\wj* 
\q2 \wj kí wọ́n má ba à fi etí wọn gbọ́\wj* 
\q2 \wj kí wọn má ba à fi àyà wọn mọ̀ òye,\wj* 
\q1 \wj kí wọn má ba à yípadà, kí èmi ba à le mú wọn láradá.’\wj* 
\m  
\v 16 \wj Ṣùgbọ́n ìbùkún ni fún ojú yín, nítorí wọ́n ríran, àti fún etí yín, nítorí ti wọ́n gbọ́.\wj* 
\v 17 \wj Lóòótọ́ ni mo wí fún yín, ọ̀pọ̀ àwọn wòlíì àti ènìyàn Ọlọ́run ti fẹ́ rí ohun tí ẹ̀yin ti rí, ki wọ́n sì gbọ́ ohun tí ẹ ti gbọ́, ṣùgbọ́n kò ṣe é ṣe fún wọn.\wj* 
\p  
\v 18 \wj “Nítorí náà, ẹ fi etí sí ohun tí òwe afúnrúgbìn túmọ̀ sí,\wj* 
\v 19 \wj nígbà tí ẹnikẹ́ni bá gbọ́ ọ̀rọ̀ nípa ìjọba ọ̀run ṣùgbọ́n tí kò yé e, lẹ́yìn náà èṣù á wá, a sì gba èyí tí a fún sí ọkàn rẹ̀ kúrò. Èyí ni irúgbìn ti a fún sí ẹ̀bá ọ̀nà.\wj* 
\v 20 \wj Ẹni tí ó sì gba irúgbìn tí ó bọ́ sí ilẹ̀ orí àpáta, ni ẹni tí ó gbọ́ ọ̀rọ̀ náà, lọ́gán, ó sì fi ayọ̀ gba ọ̀rọ̀ náà.\wj* 
\v 21 \wj Ṣùgbọ́n nítorí kò ní gbòǹgbò, ó wà fún ìgbà díẹ̀; nígbà tí wàhálà àti inúnibíni bá dìde nítorí ọ̀rọ̀ náà ní ojú kan náà yóò sì kọsẹ̀.\wj* 
\v 22 \wj Ẹni tí ó si gba irúgbìn tí ó bọ́ sí àárín ẹ̀gún ni ẹni tí ó gbọ́ ọ̀rọ̀ náà, ṣùgbọ́n àwọn àníyàn ayé yìí, ìtànjẹ, ọrọ̀ sì fún ọ̀rọ̀ náà pa, ọ̀rọ̀ náà kò so èso nínú rẹ̀.\wj* 
\v 23 \wj Ṣùgbọ́n ẹni tí ó gba irúgbìn tí ó bọ́ sí orí ilẹ̀ rere ni ẹni tí ó gbọ́ ọ̀rọ̀ náà, tí ó sì yé e; òun sì so èso òmíràn ọgọ́rọ̀ọ̀rùn, òmíràn ọgọ́tọ̀ọ̀ta, òmíràn ọgbọọgbọ̀n.”\wj* 
\s1 Òwe èpò àti alikama 
\p  
\v 24       Jesu tún pa òwe mìíràn fún wọn: \wj “Ìjọba ọ̀run dàbí àgbẹ̀ kan tí ó gbin irúgbìn rere sí oko rẹ̀,\wj* 
\v 25 \wj ṣùgbọ́n ní òru ọjọ́ kan, nígbà tí ó sùn, ọ̀tá rẹ̀ wá sí oko náà ó sì gbin èpò sáàrín alikama, ó sì bá tirẹ̀ lọ.\wj* 
\v 26 \wj Nígbà tí alikama náà bẹ̀rẹ̀ sí dàgbà, tí ó sì so èso, nígbà náà ni èpò náà fi ara hàn.\wj* 
\p  
\v 27 \wj “Àwọn ọmọ ọ̀dọ̀ àgbẹ̀ náà wá, wọ́n sọ fún un pé, ‘Ọ̀gá, irúgbìn rere kọ́ ni ìwọ ha gbìn sí oko rẹ nì? Báwo ni èpò ṣe wà níbẹ̀ nígbà náà?’\wj* 
\p  
\v 28 \wj “Ó sọ fún wọn pé, ‘Ọ̀tá ni ó ṣe èyí.’\wj* 
\p \wj “Àwọn ọmọ ọ̀dọ̀ rẹ̀ tún bí i pé, ‘Ǹjẹ́ ìwọ ha fẹ́ kí a fa èpò náà tu kúrò?’\wj* 
\p  
\v 29 \wj “Ó dá wọn lóhùn pé, ‘Rárá, nítorí bí ẹ̀yin bá ń tu èpò kúrò, ẹ ó tu alikama dànù pẹ̀lú rẹ̀.\wj* 
\v 30 \wj Ẹ jẹ́ kí àwọn méjèèjì máa dàgbà pọ̀, títí di àsìkò ìkórè. Èmi yóò sọ fún àwọn olùkórè náà láti kọ́kọ́ ṣa àwọn èpò kúrò kí wọ́n sì dìwọ́n ní ìtí, kí a sì sun wọn, kí wọ́n sì kó alikama sínú àká mi.’ ”\wj* 
\s1 Òwe hóró musitadi àti ìwúkàrà 
\p  
\v 31       Jesu tún pa òwe mìíràn fún wọn: \wj “Ìjọba ọ̀run dàbí èso hóró musitadi, èyí tí ọkùnrin kan mú tí ó gbìn sínú oko rẹ̀.\wj* 
\v 32 \wj Bí ó tilẹ̀ jẹ́ èso tí ó kéré púpọ̀ láàrín èso rẹ̀, síbẹ̀ ó wá di ohun ọ̀gbìn tí ó tóbi jọjọ. Ó sì wá di igi tó bẹ́ẹ̀ tí àwọn ẹyẹ ojú ọ̀run sì wá, wọ́n sì fi ẹ̀ka rẹ ṣe ibùgbé.”\wj* 
\p  
\v 33       Ó tún pa òwe mìíràn fún wọn: \wj “Ìjọba ọ̀run dàbí ìwúkàrà tí obìnrin kan mú tí ó pò mọ́ ìyẹ̀fun púpọ̀ títí tí gbogbo rẹ fi di wíwú.”\wj* 
\p  
\v 34       Òwe ni Jesu fi sọ nǹkan wọ̀nyí fún àwọn ènìyàn, òwe ni ó fi bá wọn sọ gbogbo ọ̀rọ̀ tó sọ.  
\v 35  Kí ọ̀rọ̀ tí a ti ẹnu àwọn wòlíì sọ lé wá sí ìmúṣẹ pé: 
\q1 “Èmi yóò ya ẹnu mi láti fi òwe sọ̀rọ̀. 
\q2 Èmi yóò sọ àwọn ohun tí ó fi ara sin láti ìpilẹ̀ṣẹ̀ ayé wá.” 
\s1 Àlàyé òwe èpò àti alikama 
\p  
\v 36 Lẹ́yìn náà ó sì fi ọ̀pọ̀ ènìyàn sílẹ̀ lóde, ó wọ ilé lọ. Àwọn ọmọ-ẹ̀yìn rẹ̀ tọ̀ ọ́ wá, wọn wí pé, “Ṣàlàyé òwe èpò inú oko fún wa.” 
\p  
\v 37 Ó sì dá wọn lóhùn pé, \wj “Ọmọ Ènìyàn ni ẹni tí ó ń fúnrúgbìn rere.\wj* 
\v 38 \wj Ayé ni oko náà; irúgbìn rere ni àwọn ènìyàn ti ìjọba ọ̀run. Èpò ni àwọn ènìyàn tí wọ́n jẹ́ ti èṣù,\wj* 
\v 39 \wj ọ̀tá tí ó gbin àwọn èpò sáàrín alikama ni èṣù. Ìkórè ni òpin ayé, àwọn olùkórè sì ní àwọn angẹli.\wj* 
\p  
\v 40 \wj “Gẹ́gẹ́ bí a ti kó èpò jọ, tí a sì sun ún nínú iná, bẹ́ẹ̀ gẹ́gẹ́ ni yóò rí ní ìgbẹ̀yìn ayé.\wj* 
\v 41 \wj Ọmọ Ènìyàn yóò ran àwọn angẹli rẹ̀, wọn yóò sì kó gbogbo ohun tó ń mú ni dẹ́ṣẹ̀ kúrò ní ìjọba rẹ̀ àti gbogbo ènìyàn búburú.\wj* 
\v 42 \wj Wọn yóò sì sọ wọ́n sí inú iná ìléru, níbi ti ẹkún òun ìpayínkeke yóò gbé wà.\wj* 
\v 43 \wj Nígbà náà ni àwọn olódodo yóò máa ràn bí oòrùn ní ìjọba Baba wọn. Ẹni tí ó bá létí, jẹ́ kí ó gbọ́.\wj* 
\s1 Òwe ìṣúra tí a fi pamọ́ sínú ilẹ̀ àti ohun ẹ̀ṣọ́ olówó iyebíye 
\p  
\v 44 \wj “Ìjọba ọ̀run sì dàbí ìṣúra kan tí a fi pamọ́ sínú oko. Nígbà tí ọkùnrin kan rí i ó tún fi í pamọ́. Nítorí ayọ̀ rẹ̀, ó ta gbogbo ohun ìní rẹ̀, ó ra oko náà.\wj* 
\p  
\v 45 \wj “Bákan náà ni ìjọba ọ̀run dàbí oníṣòwò kan tí ó ń wá òkúta olówó iyebíye láti rà.\wj* 
\v 46 \wj Nígbà tí ó rí ọ̀kan tí ó ni iye lórí, ó lọ láti ta gbogbo ohun ìní rẹ̀ láti le rà á.\wj* 
\s1 Òwe ti àwọ̀n ẹja 
\p  
\v 47 \wj “Bákan náà, a sì tún lè fi ìjọba ọ̀run wé àwọ̀n kan tí a jù sínú odò, ó sì kó onírúurú ẹja.\wj* 
\v 48 \wj Nígbà tí àwọ̀n náà sì kún, àwọn apẹja fà á sókè sí etí bèbè Òkun, wọ́n jókòó, wọ́n sì ṣa àwọn èyí tí ó dára sínú apẹ̀rẹ̀, ṣùgbọ́n wọ́n da àwọn tí kò dára nù.\wj* 
\v 49 \wj Bẹ́ẹ̀ gẹ́gẹ́ ni yóò rí ní ìgbẹ̀yìn ayé. Àwọn angẹli yóò wá láti ya àwọn ènìyàn búburú kúrò lára àwọn olódodo.\wj* 
\v 50 \wj Wọn ó sì ju àwọn ènìyàn búburú sínú iná ìléru náà, ní ibi ti ẹkún àti ìpayínkeke yóò gbé wà.”\wj* 
\p  
\v 51 Jesu bí wọn léèrè pé, \wj “Ǹjẹ́ gbogbo nǹkan wọ̀nyí yé yín.”\wj* 
\p Wọ́n dáhùn pé, “Bẹ́ẹ̀ ni, ó yé wa.” 
\p  
\v 52 Ó wí fún wọn pé, \wj “Nítorí náà ni olúkúlùkù olùkọ́ òfin tí ó ti di ọmọ-ẹ̀yìn ní ìjọba ọ̀run ṣe dàbí ọkùnrin kan tí í ṣe baálé ilé, tí ó mú ìṣúra tuntun àti èyí tí ó ti gbó jáde láti inú yàrá ìṣúra rẹ̀.”\wj* 
\s1 Wòlíì tí kò lọ́lá 
\p  
\v 53       Lẹ́yìn ti Jesu ti parí òwe wọ̀nyí, ó ti ibẹ̀ kúrò.  
\v 54  Ó wá sí ìlú òun tìkára rẹ̀, níbẹ̀ ni ó ti ń kọ́ àwọn ènìyàn nínú Sinagọgu, ẹnu sì yà wọ́n. Wọ́n béèrè pé, “Níbo ni ọkùnrin yìí ti mú ọgbọ́n yìí àti iṣẹ́ ìyanu wọ̀nyí wá?  
\v 55 Kì í ha ṣe ọmọ gbẹ́nàgbẹ́nà ni èyí bí? Ìyá rẹ̀ ha kọ́ ni à ń pè ní Maria bí? Arákùnrin rẹ̀ ha kọ́ ni Jakọbu, Josẹfu, Simoni àti Judasi bí?  
\v 56 Àwọn arábìnrin rẹ̀ gbogbo ha kọ́ ni ó ń bá wa gbé níhìn-ín yìí, nígbà náà níbo ni ọkùnrin yìí ti rí àwọn nǹkan wọ̀nyí?”  
\v 57 Inú bí wọn sí i. 
\p Ṣùgbọ́n Jesu wí fún wọn pé, \wj “Wòlíì a máa lọ́lá ní ibòmíràn, àfi ní ilé ara rẹ̀ àti ní ìlú ara rẹ̀ nìkan ni wòlíì kò ti lọ́lá.”\wj* 
\p  
\v 58 Nítorí náà kò ṣe iṣẹ́ ìyanu kankan níbẹ̀, nítorí àìnígbàgbọ́ wọn. 
\c 14  
\s1 A bẹ́ Johanu Onítẹ̀bọmi lórí 
\p  
\v 1       Ní àkókò náà ni Herodu ọba tetrarki gbọ́ nípa òkìkí Jesu,  
\v 2 ó wí fún àwọn ọmọ ọ̀dọ̀ rẹ̀ pé, “Dájúdájú Johanu onítẹ̀bọmi ni èyí, ó jíǹde kúrò nínú òkú. Ìdí nìyí tí ó fi ní agbára láti ṣiṣẹ́ ìyanu wọ̀nyí.” 
\p  
\v 3       Nísinsin yìí Herodu ti mú Johanu, ó fi ẹ̀wọ̀n dè é, ó sì fi sínú túbú, nítorí Herodia aya Filipi arákùnrin rẹ̀,  
\v 4 nítorí Johanu onítẹ̀bọmi ti sọ fún Herodu pé, “Kò yẹ fún ọ láti fẹ́ obìnrin náà.”  
\v 5  Herodu fẹ́ pa Johanu, ṣùgbọ́n ó bẹ̀rù àwọn ènìyàn nítorí gbogbo ènìyàn gbàgbọ́ pé wòlíì ni. 
\p  
\v 6 Ní ọjọ́ àsè ìrántí ọjọ́ ìbí Herodu, ọmọ Herodia obìnrin jó dáradára, ó sì tẹ́ Herodu lọ́run gidigidi.  
\v 7 Nítorí náà ni ó ṣe fi ìbúra ṣe ìlérí láti fún un ní ohunkóhun ti ó bá béèrè fún.  
\v 8 Pẹ̀lú ìmọ̀ràn láti ọ̀dọ̀ ìyá rẹ̀, ó béèrè pé, “Fún mi ni orí Johanu onítẹ̀bọmi nínú àwopọ̀kọ́”.  
\v 9 Inú ọba bàjẹ́ gidigidi, ṣùgbọ́n nítorí ìbúra rẹ̀ àti kí ojú má ba à tì í níwájú àwọn àlejò tó wà ba jẹ àsè, ó pàṣẹ pé kí wọ́n fún un gẹ́gẹ́ bí o ti fẹ́.  
\v 10 Nítorí náà, a bẹ́ orí Johanu onítẹ̀bọmi nínú ilé túbú.  
\v 11 A sì gbé orí rẹ̀ jáde láti fi fún ọmọbìnrin náà nínú àwopọ̀kọ́, òun sì gbà á, ó gbé e tọ ìyá rẹ̀ lọ.  
\v 12 Lẹ́yìn náà, àwọn ọmọ-ẹ̀yìn Johanu wá gba òkú rẹ̀, wọ́n sì sin ín. Wọ́n sì wá sọ ohun tí ó ṣẹlẹ̀ fún Jesu. 
\s1 Jesu bọ́ ẹgbẹ̀rún márùn-ún (5,000) ènìyàn 
\p  
\v 13       Nígbà tí Jesu gbọ́ ìròyìn ìṣẹ̀lẹ̀ náà, ó kúrò níbẹ̀, ó bá ọkọ̀ ojú omi lọ sí ibi kọ́lọ́fín kan ní èbúté láti dá wà níbẹ̀. Nígbà tí wọ́n gbọ́ èyí, ọ̀pọ̀ ènìyàn sì fi ẹsẹ̀ rìn tẹ̀lé e láti ọ̀pọ̀ ìlú wọn.  
\v 14 Nígbà ti Jesu gúnlẹ̀, tí ó sì rí ọ̀pọ̀lọpọ̀ ènìyàn, inú rẹ̀ yọ́ sí wọn, ó sì mú àwọn aláìsàn láradá. 
\p  
\v 15 Nígbà ti ilẹ̀ ń ṣú lọ, àwọn ọmọ-ẹ̀yìn rẹ̀ tọ̀ ọ́ wá, wọ́n sì wí pé, “Ibi yìí jìnnà sí ìlú ilẹ̀ sì ń ṣú lọ. Rán àwọn ènìyàn lọ sí àwọn ìletò kí wọ́n lè ra oúnjẹ jẹ.” 
\p  
\v 16 Ṣùgbọ́n Jesu fèsì pé, \wj “Kò nílò kí wọ́n lọ kúrò. Ẹ fún wọn ní oúnjẹ.”\wj* 
\p  
\v 17 Wọ́n sì dalóhùn pé, “Àwa kò ní ju ìṣù àkàrà márùn-ún àti ẹja méjì lọ níhìn-ín.” 
\p  
\v 18 Ó wí pé, \wj “Ẹ mú wọn wá fún mi níhìn-ín yìí.”\wj* 
\v 19  Lẹ́yìn náà, ó wí fún àwọn ènìyàn kí wọ́n jókòó lórí koríko. Lẹ́yìn náà, ó mú ìṣù àkàrà márùn-ún àti ẹja méjì. Ó gbé ojú rẹ̀ sí ọ̀run. Ó béèrè ìbùkún Ọlọ́run lórí oúnjẹ náà, Ó sì bù ú, ó sì fi àkàrà náà fún àwọn ọmọ-ẹ̀yìn láti pín in fún àwọn ènìyàn.  
\v 20 Gbogbo wọn sì jẹ àjẹyó. Lẹ́yìn náà àwọn ọmọ-ẹ̀yìn kó àjẹkù jọ, ó kún agbọ̀n méjìlá.  
\v 21 Iye àwọn ènìyàn ni ọjọ́ náà jẹ́ ẹgbẹ̀rún márùn-ún (5,000) ọkùnrin, láìka àwọn obìnrin àti àwọn ọmọdé. 
\s1 Jesu rìn lójú omi 
\p  
\v 22       Lẹ́sẹ̀kẹsẹ̀ lẹ́yìn èyí, Jesu wí fún àwọn ọmọ-ẹ̀yìn rẹ̀ kí wọ́n bọ sínú ọkọ̀ wọn, àti kí wọ́n máa kọjá lọ ṣáájú rẹ̀ sí òdìkejì. Òun náà dúró lẹ́yìn láti tú àwọn ènìyàn ká lọ sí ilé wọn.  
\v 23 Lẹ́yìn tí ó tú ìjọ ènìyàn ká tán, ó gun orí òkè lọ fúnra rẹ̀ láti lọ gba àdúrà. Nígbà tí ilẹ̀ ṣú, òun wà nìkan níbẹ̀,  
\v 24  ní àkókò yìí ọkọ̀ ojú omi náà ti rin jìnnà sí etí bèbè Òkun, tí ìjì omi ń tì í síwá sẹ́yìn, nítorí ìjì ṣe ọwọ́ òdì sí wọn. 
\p  
\v 25 Ní déédé ago mẹ́rin òwúrọ̀, Jesu tọ̀ wọ́n wá, ó ń rìn lórí omi.  
\v 26  Nígbà tí àwọn ọmọ-ẹ̀yìn rí i tí ó ń rìn lójú omi, ẹ̀rù ba wọn gidigidi, wọ́n rò pé “iwin ni,” wọ́n kígbe tìbẹ̀rù tìbẹ̀rù. 
\p  
\v 27 Lójúkan náà, Jesu wí fún wọn pé, \wj “Ẹ mú ọkàn le! Èmi ni ẹ má ṣe bẹ̀rù.”\wj* 
\p  
\v 28 Peteru sì ké sí i pé, “Olúwa, bí ó bá jẹ́ pé ìwọ ni nítòótọ́, sọ pé kí n tọ̀ ọ́ wà lórí omi.” 
\p  
\v 29       Jesu dá a lóhùn pé, \wj “Ó dára, máa bọ̀ wá.”\wj* 
\p Nígbà náà ni Peteru sọ̀kalẹ̀ láti inú ọkọ̀. Ó ń rìn lórí omi lọ sí ìhà ọ̀dọ̀ Jesu.  
\v 30 Nígbà tí ó rí afẹ́fẹ́ líle, ẹ̀rù bà á, ó sì bẹ̀rẹ̀ sí í rì. Ó kígbe lóhùn rara pé, “Gbà mí, Olúwa.” 
\p  
\v 31       Lójúkan náà, Jesu na ọwọ́ rẹ̀, ó dìímú, ó sì gbà á. Ó sì wí fún un pé, \wj “Èéṣe tí ìwọ fi ṣiyèméjì ìwọ onígbàgbọ́ kékeré?”\wj* 
\p  
\v 32 Àti pé, nígbà ti wọ́n sì gòkè sínú ọkọ̀, ìjì náà sì dúró jẹ́ẹ́.  
\v 33  Nígbà náà ni àwọn to wà nínú ọkọ̀ náà foríbalẹ̀ fún un wọ́n wí pé, “Nítòótọ́ Ọmọ Ọlọ́run ni ìwọ í ṣe.” 
\p  
\v 34       Nígbà tí wọn rékọjá sí apá kejì wọ́n gúnlẹ̀ sí Genesareti.  
\v 35 Nígbà tiwọn mọ̀ pé Jesu ni, wọn sì ránṣẹ́ sí gbogbo ìlú náà yíká. Wọ́n sì gbé gbogbo àwọn aláìsàn tọ̀ ọ́ wá.  
\v 36  Àwọn aláìsàn bẹ̀ ẹ́ pé kí ó gba àwọn láyè láti fi ọwọ́ kan ìṣẹ́tí aṣọ rẹ̀, gbogbo àwọn tí ó ṣe bẹ́ẹ̀ sì rí ìwòsàn. 
\c 15  
\s1 Ohun mímọ́ àti ohun àìmọ́ 
\p  
\v 1       Nígbà náà ní àwọn Farisi àti àwọn olùkọ́ òfin tọ Jesu wá láti Jerusalẹmu,  
\v 2 wọn béèrè pé, “Èéṣe tí àwọn ọmọ-ẹ̀yìn rẹ fi ń rú òfin àtayébáyé àwọn alàgbà? Nítorí tí wọn kò wẹ ọwọ́ wọn kí wọ́n tó jẹun!” 
\p  
\v 3 Jesu sì dá wọn lóhùn pé, \wj “Èéha ṣe tí ẹ̀yin fi rú òfin Ọlọ́run, nítorí àṣà yín?\wj* 
\v 4 \wj Nítorí Ọlọ́run wí pé, ‘Bọ̀wọ̀ fún Baba òun ìyá rẹ,’ àti pé, ‘Ẹnikẹ́ni tí ó bá sọ ọ̀rọ̀-òdì sí baba tàbí ìyá rẹ̀, ní láti kú.’\wj* 
\v 5 \wj Ṣùgbọ́n ẹ̀yin wí pé, ẹnikẹ́ni tí ó bá wí fún baba tàbí ìyá rẹ̀ pé, ‘Ẹ̀bùn fún Ọlọ́run ni ohunkóhun tí ìwọ ìbá fi jèrè lára mi,’\wj* 
\v 6 \wj tí Òun kò sì bọ̀wọ̀ fún baba tàbí ìyá rẹ̀, ó bọ́; bẹ́ẹ̀ ni ẹ̀yin sọ òfin Ọlọ́run di asán nípa àṣà yín.\wj* 
\v 7 \wj Ẹ̀yin àgàbàgebè, ní òtítọ́ ni Wòlíì Isaiah sọtẹ́lẹ̀ nípa yín wí pé:\wj* 
\q1  
\v 8 \wj “ ‘Àwọn ènìyàn wọ̀nyí ń fi ẹnu lásán bu ọlá fún mi,\wj* 
\q2 \wj ṣùgbọ́n ọkàn wọn jìnnà réré sí mi.\wj* 
\q1  
\v 9 \wj Lásán ni ìsìn wọn;\wj* 
\q2 \wj nítorí pé wọ́n ń fi òfin ènìyàn kọ́ ni ní ẹ̀kọ́.’ ”\wj* 
\p  
\v 10 Jesu pe ọ̀pọ̀ ènìyàn wá sí ọ̀dọ̀ rẹ, ó wí pé, \wj “Ẹ tẹ́tí, ẹ sì jẹ́ kí nǹkan tí mo sọ yé yín.\wj* 
\v 11 \wj Ènìyàn kò di aláìmọ́ nípa ohun tí ó wọ ẹnu ènìyàn, ṣùgbọ́n èyí tí ó ti ẹnu jáde wá ni ó sọ ní di aláìmọ́.”\wj* 
\p  
\v 12 Nígbà náà, àwọn ọmọ-ẹ̀yìn rẹ̀ tọ̀ ọ́ wá, wọ́n wí fún un pé, “Ǹjẹ́ ìwọ mọ̀ pé inú bí àwọn Farisi lẹ́yìn tí wọ́n gbọ́ ọ̀rọ̀ tí ó sọ yìí?” 
\p  
\v 13       Jesu dá wọn lóhùn pé, \wj “Gbogbo igi tí Baba mi ti ń bẹ ni ọ̀run kò bá gbìn ni á ó fàtu tigbòǹgbò tigbòǹgbò,\wj* 
\v 14 \wj ẹ fi wọ́n sílẹ̀; afọ́jú tí ń fi ọ̀nà han afọ́jú ni wọ́n. Bí afọ́jú bá sì ń fi ọ̀nà han afọ́jú, àwọn méjèèjì ni yóò jìn sí kòtò.”\wj* 
\p  
\v 15 Peteru wí, “Ṣe àlàyé òwe yìí fún wa.” 
\p  
\v 16 Jesu béèrè lọ́wọ́ wọn pé, \wj “Èéha ṣe tí ìwọ fi jẹ́ aláìmòye síbẹ̀”?\wj* 
\v 17 \wj “Ẹyin kò mọ̀ pé ohunkóhun tí ó gba ẹnu wọlé, yóò gba ti ọ̀nà oúnjẹ lọ, a yóò sì yà á jáde?\wj* 
\v 18 \wj Ṣùgbọ́n ohun tí a ń sọ jáde láti ẹnu, inú ọkàn ni ó ti ń wá, èyí sì ni ó ń sọ ènìyàn di aláìmọ́.\wj* 
\v 19 \wj Ṣùgbọ́n láti ọkàn ni èrò búburú ti wá, bí ìpànìyàn, panṣágà, àgbèrè, olè jíjà, irọ́ àti ọ̀rọ̀ ìbàjẹ́.\wj* 
\v 20 \wj Àwọn tí a dárúkọ wọ̀nyí ni ó ń sọ ènìyàn di aláìmọ́. Ṣùgbọ́n láti jẹun láì wẹ ọwọ́, kò lè sọ ènìyàn di aláìmọ́.”\wj* 
\p  
\v 21       Jesu sì ti ibẹ̀ kúrò lọ sí Tire àti Sidoni.  
\v 22 Obìnrin kan láti Kenaani, tí ó ń gbé ibẹ̀ wá sí ọ̀dọ̀ rẹ̀. Ó ń bẹ̀bẹ̀, ó sì kígbe pé, “Olúwa, ọmọ Dafidi, ṣàánú fún mi; ọmọbìnrin mi ní ẹ̀mí èṣù ti ń dá a lóró gidigidi.” 
\p  
\v 23 Ṣùgbọ́n Jesu kò fún un ní ìdáhùn, àwọn ọmọ-ẹ̀yìn rẹ̀ sì gbà á níyànjú pé, “Lé obìnrin náà lọ, nítorí ó ń kígbe tọ̀ wá lẹ́yìn.” 
\p  
\v 24       Ó dáhùn pé, \wj “Àgùntàn ilẹ̀ Israẹli tí ó nù nìkan ni a rán mi sí.”\wj* 
\p  
\v 25       Obìnrin náà wá, ó wólẹ̀ níwájú rẹ̀, ó bẹ̀bẹ̀ sí i pé, “Olúwa ṣàánú fún mi.” 
\p  
\v 26 Ó sì dáhùn wí pé, \wj “Kò tọ́ kí a gbé oúnjẹ àwọn ọmọ fún àwọn ajá.”\wj* 
\p  
\v 27 Obìnrin náà sì wí pé, “Bẹ́ẹ̀ ni, síbẹ̀síbẹ̀ àwọn ajá a máa jẹ èrúnrún tí ó ti orí tábìlì olówó wọn bọ́ sílẹ̀.” 
\p  
\v 28       Jesu sì sọ fún obìnrin náà pé, \wj “Ìgbàgbọ́ ńlá ni tìrẹ! A sì ti dáhùn ìbéèrè rẹ.”\wj* A sì mú ọmọbìnrin rẹ̀ láradá ní wákàtí kan náà. 
\s1 Jesu bọ́ ẹgbàajì (4,000) ènìyàn 
\p  
\v 29       Jesu ti ibẹ̀ lọ sí Òkun Galili. Ó gun orí òkè, o sì jókòó níbẹ̀.  
\v 30 Ọ̀pọ̀ àwọn ènìyàn sì tọ̀ ọ́ wá, àti àwọn arọ, afọ́jú, amúnkùn ún, odi àti ọ̀pọ̀ àwọn aláìsàn mìíràn. Wọ́n gbé wọn kalẹ̀ lẹ́sẹ̀ Jesu. Òun sì mú gbogbo wọn láradá.  
\v 31 Ẹnu ya ọ̀pọ̀ ènìyàn nígbà tí wọ́n rí àwọn odi tó ń sọ̀rọ̀, amúnkùn ún tó di alára pípé, arọ tí ó ń rìn àti àwọn afọ́jú tí ó ríran. Wọ́n sì ń fi ìyìn fún Ọlọ́run Israẹli. 
\p  
\v 32       Jesu pe àwọn ọmọ-ẹ̀yìn rẹ̀ sọ́dọ̀, ó wí pé, \wj “Àánú àwọn ènìyàn wọ̀nyí ṣe mí; nítorí wọ́n ti wà níhìn-ín pẹ̀lú mi fún ọjọ́ mẹ́ta gbáko báyìí. Wọn kò sì tún ní oúnjẹ mọ́. Èmi kò fẹ́ kí wọn padà lébi, nítorí òyì lè kọ́ wọn lójú ọ̀nà.”\wj* 
\p  
\v 33 Àwọn ọmọ-ẹ̀yìn sì dá a lóhùn pé, “Níbo ni àwa yóò ti rí oúnjẹ ní ijù níhìn-ín yìí láti fi bọ́ ọ̀pọ̀ ènìyàn yìí?” 
\p  
\v 34 Jesu sì béèrè pé, \wj “Ìṣù àkàrà mélòó ni ẹ̀yin ní?”\wj* 
\p Wọ́n sì dáhùn pé, “Àwa ní ìṣù àkàrà méje pẹ̀lú àwọn ẹja wẹ́wẹ́ díẹ̀.” 
\p  
\v 35 Jesu sì sọ fún gbogbo ènìyàn kí wọn jókòó lórí ilẹ̀.  
\v 36 Òun sì mú ìṣù àkàrà méje náà àti ẹja náà. Ó sì fi ọpẹ́ fún Ọlọ́run, ó bù wọ́n sì wẹ́wẹ́, ó sì fi wọ́n fún àwọn ọmọ-ẹ̀yìn rẹ̀. Wọ́n sì pín in fún àwọn ọ̀pọ̀ ènìyàn náà.  
\v 37 Gbogbo wọn jẹ, wọ́n sì yó. Lẹ́yìn náà, àwọn ọmọ-ẹ̀yìn sì ṣa èyí tókù, ẹ̀kún agbọ̀n méje ni èyí tó ṣẹ́kù jẹ́.  
\v 38 Gbogbo wọn sì jẹ́ ẹgbàajì (4,000) ọkùnrin láì kan àwọn obìnrin àti ọmọdé.  
\v 39 Lẹ́yìn náà, Jesu rán àwọn ènìyàn náà lọ sí ilé wọn, ó sì bọ́ sínú ọkọ̀, ó rékọjá lọ sí ẹkùn Magadani. 
\c 16  
\s1 Bíbéèrè Fún Àmì 
\p  
\v 1       Àwọn Farisi àti àwọn Sadusi wá láti dán Jesu wò. Wọ́n ní kí ó fi àmì ńlá kan hàn àwọn ní ojú ọ̀run. 
\p  
\v 2 Ó dá wọn lóhùn pé, \wj “Nígbà tí ó bá di àṣálẹ́, ẹ ó sọ pé, ‘Ìbá dára kí ojú ọ̀run pọ́n.’\wj* 
\v 3 \wj Ní òwúrọ̀, ‘Ẹ̀yin yóò wí pé ọjọ́ kì yóò dára lónìí, nítorí ti ojú ọ̀run pọ́n, ó sì ṣú dẹ̀dẹ̀,’ ẹ̀yin àgàbàgebè, ẹ̀yin le sọ àmì ojú ọ̀run, ṣùgbọ́n ẹ̀yin kò le mọ àmì àwọn àkókò wọ̀nyí.\wj* 
\v 4 \wj Ìran búburú aláìgbàgbọ́ yìí ń béèrè àmì àjèjì mélòó kàn ni ojú sánmọ̀, ṣùgbọ́n a kí yóò fún ẹnìkankan ní àmì bí kò ṣe àmì Jona.”\wj* Nígbà náà ni Jesu fi wọ́n sílẹ̀, ó sì bá tirẹ̀ lọ. 
\s1 Ìwúkàrà Farisi àti Sadusi 
\p  
\v 5       Nígbà tí wọ́n dé apá kejì adágún, àwọn ọmọ-ẹ̀yìn rẹ̀ ṣàkíyèsí pé wọ́n ti gbàgbé láti mú àkàrà kankan lọ́wọ́.  
\v 6  Jesu sì kìlọ̀ fún wọn pé, \wj “Ẹ kíyèsára, ẹ sì ṣọ́ra, ní ti ìwúkàrà àwọn Farisi àti àwọn Sadusi.”\wj* 
\p  
\v 7 Wọ́n ń sọ eléyìí ni àárín ara wọn wí pé, “Nítorí tí àwa kò mú àkàrà lọ́wọ́ ni.” 
\p  
\v 8       Nígbà tí ó gbọ́ ohun ti wọ́n ń sọ, Jesu béèrè lọ́wọ́ wọn pé, \wj “Ẹ̀yin onígbàgbọ́ kékeré, èéṣe tí ẹ̀yin ń dààmú ara yín pé ẹ̀yin kò mú oúnjẹ lọ́wọ́?\wj* 
\v 9 \wj Tàbí ọ̀rọ̀ kò yé yín di ìsinsin yìí? Ẹ̀yin kò rántí pé mo bọ́ ẹgbẹ̀rún márùn-ún (5,000) ènìyàn pẹ̀lú ìṣù àkàrà márùn-ún àti iye agbọ̀n tí ẹ kójọ bí àjẹkù?\wj* 
\v 10 \wj Ẹ kò sì tún rántí ìṣù méje tí mo fi bọ́ ẹgbàajì (4,000) ènìyàn àti iye agbọ̀n tí ẹ̀yín kójọ?\wj* 
\v 11 \wj Èéha ṣe tí kò fi yé yín pé èmi kò sọ̀rọ̀ nípa ti àkàrà? Lẹ́ẹ̀kan sí i, mo wí fún yín, ẹ ṣọ́ra fún ìwúkàrà àwọn Farisi àti ti Sadusi.”\wj* 
\v 12 Nígbà náà ni ó ṣẹ̀ṣẹ̀ wáyé wọn pé, kì í ṣe nípa ti ìwúkàrà ní ó sọ wí pé kí wọ́n kíyèsára, bí kò ṣe tí ẹ̀kọ́ àwọn Farisi àti Sadusi. 
\s1 Peteru jẹ́wọ́ Kristi 
\p  
\v 13       Nígbà tí Jesu sì dé Kesarea-Filipi, ó bi àwọn ọmọ-ẹ̀yìn rẹ̀ pé, \wj “Ta ni àwọn ènìyàn ń fi Ọmọ Ènìyàn pè?”\wj* 
\p  
\v 14       Wọ́n dá a lóhùn pé, “Àwọn kan ni Johanu onítẹ̀bọmi ni, àwọn mìíràn wí pé, Elijah ni, àwọn mìíràn wí pé, Jeremiah ni, tàbí ọ̀kan nínú àwọn wòlíì.” 
\p  
\v 15 \wj “Ṣùgbọ́n ẹyin ń kọ?”\wj* Ó bi í léèrè pé, \wj “Ta ni ẹ̀yin ń fi mi pè?”\wj* 
\p  
\v 16       Simoni Peteru dáhùn pé, “Ìwọ ni Kristi náà, Ọmọ Ọlọ́run alààyè.” 
\p  
\v 17       Jesu sì wí fún un pé, \wj “Alábùkún fún ni ìwọ Simoni ọmọ Jona, nítorí ẹran-ara àti ẹ̀jẹ̀ kọ́ ló fi èyí hàn bí kò ṣe Baba mi tí ó ń bẹ ní ọ̀run.\wj* 
\v 18 \wj Èmi wí fún ọ, ìwọ ni Peteru àti pé orí àpáta yìí ni èmi yóò kọ́ ìjọ mi lé, àti ẹnu-ọ̀nà ipò òkú kì yóò lè borí rẹ̀.\wj* 
\v 19 \wj Èmi yóò fún ní àwọn kọ́kọ́rọ́ ìjọba Ọ̀run; ohun tí ìwọ bá dè ní ayé, òun ni a ó dè ní ọ̀run. Ohunkóhun tí ìwọ bá sì tú ní ayé yìí, a ó sì tú ní ọ̀run.”\wj* 
\v 20  Nígbà náà ó kìlọ̀ fún àwọn ọmọ-ẹ̀yìn rẹ̀ pé wọn kò gbọdọ̀ sọ fún ẹnikẹ́ni pé Òun ni Kristi náà. 
\s1 Jesu sọ àsọtẹ́lẹ̀ nípa ikú ara rẹ̀ 
\p  
\v 21       Láti ìgbà yìí lọ, Jesu bẹ̀rẹ̀ sí ṣàlàyé fún àwọn ọmọ-ẹ̀yìn rẹ̀ kedere nípa lílọ sí Jerusalẹmu láti jẹ ọ̀pọ̀ ìyà lọ́wọ́ àwọn àgbàgbà, àwọn olórí àlùfáà àti àwọn akọ̀wé, kí a sì pa òun, àti ní ọjọ́ kẹta, kí ó sì jíǹde. 
\p  
\v 22 Peteru mú Jesu sí ẹ̀gbẹ́ kan, ó bẹ̀rẹ̀ sí í bá a wí pé, “Kí a má rí i Olúwa! Èyí kì yóò ṣẹlẹ̀ sí Ọ!” 
\p  
\v 23       Jesu pa ojú dà, ó sì wí fún Peteru pé, \wj “Kúrò lẹ́yìn mi, Satani! Ohun ìkọ̀sẹ̀ ni ìwọ jẹ́ fún mi; ìwọ kò ro ohun tí i ṣe ti Ọlọ́run, bí kò ṣe èyí ti ṣe ti ènìyàn.”\wj* 
\p  
\v 24       Nígbà náà ni Jesu wí fún àwọn ọmọ-ẹ̀yìn rẹ̀ pé, \wj “Bí ẹnikẹ́ni bá fẹ́ tọ̀ mí lẹ́yìn, kí ó sẹ́ ara rẹ̀, kí ó sì gbé àgbélébùú rẹ̀, kí ó sì máa tọ̀ mí lẹ́yìn.\wj* 
\v 25 \wj Nítorí ẹnikẹ́ni tí ó bá fẹ́ gba ẹ̀mí rẹ̀ là, yóò sọ ẹ̀mí rẹ̀ nù ṣùgbọ́n ẹnikẹ́ni tí ó bá sọ ẹ̀mí rẹ̀ nù nítorí mi, yóò rí i.\wj* 
\v 26 \wj Èrè kí ni ó jẹ́ fún ènìyàn bí ó bá jèrè gbogbo ayé yìí, tí ó sì sọ ẹ̀mí rẹ̀ nù? Tàbí kí ni ènìyàn yóò fi dípò ẹ̀mí rẹ̀?\wj* 
\v 27 \wj Nítorí Ọmọ Ènìyàn yóò wá nínú ògo baba rẹ pẹ̀lú àwọn angẹli rẹ̀, nígbà náà ni yóò sì san án fún olúkúlùkù gẹ́gẹ́ bí iṣẹ́ rẹ̀.\wj* 
\p  
\v 28 \wj “Lóòótọ́ ni mo wí fún yín. Ẹlòmíràn wà nínú àwọn tí ó wà níhìn-ín yìí, tí kì yóò ri ikú títí wọn ó fi rí Ọmọ Ènìyàn tí yóò máa bọ̀ ní ìjọba rẹ̀.”\wj* 
\c 17  
\s1 Orí òkè Ìparadà 
\p  
\v 1       Lẹ́yìn ọjọ́ mẹ́fà, Jesu mú Peteru, Jakọbu àti Johanu arákùnrin rẹ̀, ó mú wọn lọ sí orí òkè gíga kan tí ó dádúró.  
\v 2 Níbẹ̀ ara rẹ̀ yí padà níwájú wọn. Ojú rẹ̀ sì ràn bí oòrùn, aṣọ rẹ̀ sì funfun bí ìmọ́lẹ̀.  
\v 3 Lójijì, Mose àti Elijah fi ara hàn, wọ́n sì ń bá Jesu sọ̀rọ̀. 
\p  
\v 4 Peteru sọ fún Jesu pé, “Olúwa, jẹ́ kí a kúkú máa gbé níhìn-ín yìí. Bí ìwọ bá fẹ́, èmi yóò pa àgọ́ mẹ́ta, ọ̀kan fún ọ, ọ̀kan fún Mose, àti ọ̀kan fún Elijah.” 
\p  
\v 5       Bí Peteru ti sọ̀rọ̀ tán, àwọsánmọ̀ dídán síji bò wọ́n, láti inú rẹ̀ ohùn kan wí pé, “Èyí ni àyànfẹ́ ọmọ mi, ẹni ti inú mi dùn sí gidigidi. Ẹ máa gbọ́ tirẹ̀!” 
\p  
\v 6 Bí àwọn ọmọ-ẹ̀yìn ti gbọ́ èyí, wọ́n dojúbolẹ̀. Ẹ̀rù sì bà wọ́n gidigidi.  
\v 7 Ṣùgbọ́n Jesu sì tọ̀ wọ́n wá. Ó fi ọwọ́ kàn wọ́n, ó wí pé, \wj “Ẹ dìde, ẹ má ṣe bẹ̀rù.”\wj* 
\v 8 Nígbà tí wọ́n sì gbé ojú wọn sókè, tí wọ́n sì wò ó, Jesu nìkan ni wọn rí. 
\p  
\v 9       Bí wọ́n sì ti ń sọ̀kalẹ̀ láti orí òkè, Jesu pàṣẹ fún wọn pé, \wj “Ẹ kò gbọdọ̀ sọ fún ẹnikẹ́ni ohun tí ẹ rí, títí Ọmọ Ènìyàn yóò fi jí dìde kúrò nínú òkú.”\wj* 
\p  
\v 10       Àwọn ọmọ-ẹ̀yìn rẹ̀ béèrè lọ́wọ́ rẹ́ pé, “Kí ni ó fà á tí àwọn olùkọ́ òfin fi ń wí pé, Elijah ní láti kọ́ padà wá?” 
\p  
\v 11 Jesu sì dáhùn pé, \wj “Dájúdájú òtítọ́ ni wọ́n ń sọ. Elijah wá láti fi gbogbo nǹkan sí ipò.\wj* 
\v 12 \wj Ṣùgbọ́n èmi wí fún yín lóòótọ́; Elijah ti dé. Ṣùgbọ́n wọn kò mọ̀ ọ́n, ọ̀pọ̀ tilẹ̀ hu ìwà búburú sí i. Bákan náà, Ọmọ Ènìyàn náà yóò jìyà lọ́wọ́ wọn pẹ̀lú.”\wj* 
\v 13 Nígbà náà, àwọn ọmọ-ẹ̀yìn mọ̀ pé ó n sọ̀rọ̀ nípa Johanu onítẹ̀bọmi fún wọn ni. 
\s1 Ìwòsàn ọmọkùnrin ẹlẹ́mìí èṣù 
\p  
\v 14       Nígbà tí wọ́n sì dé ọ̀dọ̀ ìjọ ènìyàn, ọkùnrin kan tọ̀ Jesu wá, ó sì wólẹ̀ níwájú rẹ̀, ó wí pé,  
\v 15 “Olúwa, ṣàánú fún ọmọ mi, nítorí tí ó ní wárápá. Ó sì ń joró gidigidi, nígbà púpọ̀ ni ó máa ń ṣubú sínú iná tàbí sínú omi.  
\v 16 Mo sì ti mú un tọ àwọn ọmọ-ẹ̀yìn rẹ, ṣùgbọ́n wọn kò lè wò ó sàn.” 
\p  
\v 17 Jesu sì dáhùn wí pé, \wj “A! Ẹ̀yìn alágídí ọkàn àti aláìgbàgbọ́ ènìyàn, èmi yóò ti bá yín gbé pẹ́ tó? Èmi ó sì ti fi ara dà á fún yín tó? Ẹ mú un wá sọ́dọ̀ mi níhìn-ín yìí.”\wj* 
\v 18 Nígbà náà ni Jesu bá ẹ̀mí èṣù tí ó ń bẹ nínú ọmọkùnrin náà wí, ó sì fi í sílẹ̀, à mú ọmọkùnrin náà láradá láti ìgbà náà lọ. 
\p  
\v 19       Lẹ́yìn èyí, àwọn ọmọ-ẹ̀yìn rẹ̀ sì bi Jesu níkọ̀kọ̀ pé, “Èéṣe tí àwa kò lè lé ẹ̀mí èṣù náà jáde?” 
\p  
\v 20       Jesu sọ fún wọn pé, \wj “Nítorí ìgbàgbọ́ yín kéré. Lóòótọ́ ni mo wí fún yin, bí ẹ bá ni ìgbàgbọ́, bí ó tilẹ̀ kéré bí hóró musitadi, ẹ̀yin lè wí fún òkè yìí pé, ‘Sípò kúrò níhìn-ín yìí,’ òun yóò sì ṣí ipò. Kò sì ní sí ohun tí kò ní í ṣe é ṣe fún yín.”\wj*\f + \fr 17:20 \ft Àwọn àkọsílẹ̀ àtijọ́ kan se àfikún ọ̀rọ̀ yìí \fqa fún yín.\fv 21 \fv*\fqa Ṣùgbọ́n irú ẹ̀mí èṣù yìí kò ní lọ, bí kò ṣe nípa ààwẹ̀ àti àdúrà\ft .\f* 
\p  
\v 22       Nígbà tí wọ́n sì ti wà ní Galili, Jesu sọ fún wọn pé, \wj “Láìpẹ́ yìí a ó fi Ọmọ Ènìyàn lé àwọn ènìyàn lọ́wọ́.\wj* 
\v 23 \wj Wọn yóò sì pa á, ní ọjọ́ kẹta lẹ́yìn èyí, yóò sì jí dìde sí ìyè.”\wj* Ọkàn àwọn ọmọ-ẹ̀yìn rẹ̀ sì kún fún ìbànújẹ́ gidigidi. 
\s1 Owó tẹmpili 
\p  
\v 24       Nígbà tí Jesu àti àwọn ọmọ-ẹ̀yìn rẹ̀ sì dé Kapernaumu, àwọn agbowó òde tí ń gba owó idẹ méjì tó jẹ́ owó tẹmpili tọ Peteru wá wọ́n sì bí i pé, “Ǹjẹ́ olùkọ́ yín ń san owó tẹmpili?” 
\p  
\v 25       Peteru sì dáhùn pé, “Bẹ́ẹ̀ ni, ó ń san.” 
\p Nígbà tí Peteru wọ ilé láti bá Jesu sọ̀rọ̀ nípa rẹ̀, Jesu ni ó kọ́kọ́ sọ̀rọ̀, Jesu bí i pé, \wj “Kí ni ìwọ rò, Simoni? Ǹjẹ́ àwọn ọba ayé ń gba owó orí lọ́wọ́ àwọn ọmọ wọn tàbí lọ́wọ́ àwọn àlejò?”\wj* 
\p  
\v 26 Peteru dáhùn pé, “Lọ́wọ́ àwọn àlejò ni.” 
\p Jesu sì tún wí pé, \wj “Èyí jẹ́ wí pé àwọn ọmọ onílẹ̀ kì í san owó òde?\wj* 
\v 27 \wj Síbẹ̀síbẹ̀, àwa kò fẹ́ mú wọn bínú. Nítorí náà, ẹ lọ sí etí Òkun, kí ẹ sì sọ ìwọ̀ sí omi. Ẹ mú ẹja àkọ́kọ́ tí ẹ kọ́ fà sókè, ẹ ya ẹnu rẹ̀, ẹ̀yin yóò sì rí owó idẹ kan níbẹ̀, ki ẹ fi fún wọn fún owó orí tèmi àti tirẹ̀.”\wj* 
\c 18  
\s1 Ẹni tí ó tóbi jù ní ìjọba Ọ̀run 
\p  
\v 1       Ní àkókò náà ni àwọn ọmọ-ẹ̀yìn Jesu tọ̀ ọ́ wá, wọ́n bi í léèrè pé, “Ta ni ẹni ti ó pọ̀jù ní ìjọba ọ̀run?” 
\p  
\v 2 Jesu sì pe ọmọ kékeré kan sí ọ̀dọ̀ ara rẹ̀. Ó sì mú un dúró láàrín wọn.  
\v 3  Ó wí pé, \wj “Lóòótọ́ ni mo wí fún yín, àfi bí ẹ̀yin bá yí padà kí ẹ sì dàbí àwọn ọmọdé, ẹ̀yin kì yóò lè wọ ìjọba ọ̀run.\wj* 
\v 4 \wj Nítorí náà, ẹni tí ó bá rẹ ara rẹ̀ sílẹ̀ gẹ́gẹ́ bí ọmọdé yìí, ni yóò pọ̀ jùlọ ní ìjọba ọ̀run.\wj* 
\v 5 \wj Àti pé, ẹnikẹ́ni tí ó bá gba ọmọ kékeré bí èyí nítorí orúkọ mi, gbà mí.\wj* 
\p  
\v 6 \wj “Ṣùgbọ́n ẹnikẹ́ni nínú yín tí ó bá mú ọ̀kan nínú àwọn ọmọ kékeré wọ̀nyí tí ó gbà mí gbọ́ ṣìnà, yóò sàn fún un kí a so òkúta ńlá mọ́ ọn ní ọrùn, kí a sì rì í sí ìsàlẹ̀ ibú omi Òkun.\wj* 
\v 7 \wj Ègbé ni fún ayé nítorí gbogbo ohun ìkọ̀sẹ̀ rẹ̀! Ohun ìkọ̀sẹ̀ kò le ṣe kó má wà, ṣùgbọ́n ègbé ni fún ọkùnrin náà nípasẹ̀ ẹni tí ìkọ̀sẹ̀ náà ti wá!\wj* 
\v 8 \wj Nítorí náà, bí ọwọ́ tàbí ẹsẹ̀ rẹ yóò bá mú ọ dẹ́ṣẹ̀, gé e kúrò, kí o sì jù ú nù. Ó kúkú sàn fún ọ láti wọ ìjọba ọ̀run ní akéwọ́ tàbí akésẹ̀ ju pé kí o ni ọwọ́ méjì àti ẹsẹ̀ méjì ki a sì sọ ọ́ sínú iná ayérayé.\wj* 
\v 9 \wj Bí ojú rẹ yóò bá sì mú kí o dẹ́ṣẹ̀, yọ ọ́ kúrò kí ó sì sọ ọ́ nù. Ó kúkú sàn fún ọ láti lọ sínú ìyè pẹ̀lú ojú kan, ju pé kí o ní ojú méjì, kí a sì jù ọ́ sí iná ọ̀run àpáàdì.\wj* 
\s1 Òwe àgùntàn tó sọnù 
\p  
\v 10 \wj “Ẹ rí i pé ẹ kò fi ojú tẹ́ńbẹ́lú ọ̀kan nínú àwọn kéékèèké wọ̀nyí. Lóòótọ́ ni mo wí fún yin pé, nígbà gbogbo ni ọ̀run ni àwọn angẹli ń wo ojú Baba mi tí ń bẹ ní ọ̀run.\wj*\f + \fr 18:10 \ft Àwọn àkọsílẹ̀ àtijọ́ kan se àfikún ọ̀rọ̀ yìí \fqa ọ̀run.\fv 11 \fv*\fqa Nítorí náà, Ọmọ Ènìyàn wá láti gba àwọn tí ó nù là\ft .\f* 
\p  
\v 12 \wj “Kí ni ẹ̀yin rò? Bí ọkùnrin kan bá ni ọgọ́rùn-ún àgùntàn, tí ẹyọ kan nínú wọn sì sọnù, ṣé òun kì yóò fi mọ́kàndínlọ́gọ́rùn-ún ìyókù sílẹ̀ sórí òkè láti lọ wá ẹyọ kan tó nù náà bí?\wj* 
\v 13 \wj Ǹjẹ́ bí òun bá sì wá á rí i, lóòótọ́ ni mo wí fún yín, ǹjẹ́ ẹ̀yin kò mọ̀ pé inú rẹ̀ yóò dùn nítorí rẹ̀ ju àwọn mọ́kàndínlọ́gọ́rùn-ún tí kò nù lọ?\wj* 
\v 14 \wj Bẹ́ẹ̀ gẹ́gẹ́, ni kì í ṣe ìfẹ́ Baba yín tí ń bẹ ní ọ̀run, pé ọ̀kan nínú àwọn kékeré wọ̀nyí kí ó ṣègbé.\wj* 
\s1 Arákùnrin tí ó ṣẹ̀ sí ọ 
\p  
\v 15 \wj “Bí arákùnrin rẹ bá ṣẹ̀ ọ́, lọ ní ìkọ̀kọ̀ kí o sì sọ ẹ̀bi rẹ̀ fún un. Bí ó bá gbọ́ tìrẹ, ìwọ ti mú arákùnrin kan bọ̀ sí ipò.\wj* 
\v 16 \wj Ṣùgbọ́n bí òun kò bá tẹ́tí sí ọ, nígbà náà mú ẹnìkan tàbí ẹni méjì pẹ̀lú rẹ, kí ẹ sì tún padà sí ọ̀dọ̀ rẹ̀ lẹ́ẹ̀kan sí i, kí ọ̀rọ̀ náà bá le fi ìdí múlẹ̀ pẹ̀lú àwọn ẹlẹ́rìí méjì tàbí mẹ́ta náà.\wj* 
\v 17 \wj Bí òun bá sì tún kọ̀ láti tẹ́tí sí wọn, nígbà náà sọ fún ìjọ ènìyàn Ọlọ́run. Bí o bá kọ̀ láti gbọ́ ti ìjọ ènìyàn Ọlọ́run, jẹ́ kí ó dàbí kèfèrí sí ọ tàbí agbowó òde.\wj* 
\p  
\v 18 \wj “Lóòótọ́ ni mo wí fún yín, ohunkóhun tí ẹ̀yin bá dè ní ayé, ni a dè ní ọ̀run. Ohunkóhun ti ẹ̀yin bá sì ti tú ni ayé, á ò tú u ní ọ̀run.\wj* 
\p  
\v 19 \wj “Mo tún sọ èyí fún yín, bí ẹ̀yin méjì bá fi ohùn ṣọ̀kan ní ayé yìí, nípa ohunkóhun tí ẹ béèrè, Baba mi ti ń bẹ ní ọ̀run yóò sì ṣe é fún yín.\wj* 
\v 20 \wj Nítorí níbi ti ènìyàn méjì tàbí mẹ́ta bá kó ara jọ ni orúkọ mi, èmi yóò wà láàrín wọn níbẹ̀.”\wj* 
\s1 Òwe aláìláàánú ọmọ ọ̀dọ̀ 
\p  
\v 21       Nígbà náà ni Peteru wá sọ́dọ̀ Jesu, ó béèrè pé, “Olúwa, nígbà mélòó ni arákùnrin mi yóò ṣẹ̀ mi, tí èmi yóò sì dáríjì í? Tàbí ní ìgbà méje ni?” 
\p  
\v 22 Jesu dáhùn pé, \wj “Mo wí fún ọ, kì í ṣe ìgbà méje, ṣùgbọ́n ní ìgbà àádọ́rin méje.\wj* 
\p  
\v 23 \wj “Nítorí náà, ìjọba ọ̀run dàbí ọba kan tí ó fẹ́ ṣe ìṣirò pẹ̀lú àwọn ọmọ ọ̀dọ̀ rẹ̀.\wj* 
\v 24 \wj Bí ó ti ń ṣe èyí, a mú ajigbèsè kan wá sọ́dọ̀ rẹ̀ tí ó jẹ ẹ́ ní ẹgbẹ̀rún mẹ́wàá (10,000) tálẹ́ǹtì.\wj* 
\v 25 \wj Nígbà tí kò tì í ní agbára láti san án, nígbà náà ni olúwa rẹ̀ pàṣẹ pé kí a ta òun àti ìyàwó àti àwọn ọmọ rẹ̀ pẹ̀lú gbogbo ohun tí ó ní láti fi san gbèsè náà.\wj* 
\p  
\v 26 \wj “Nígbà náà ni ọmọ ọ̀dọ̀ náà wólẹ̀ lórí eékún níwájú rẹ. ‘Ó bẹ̀bẹ̀ pé, mú sùúrù fún mi, èmi yóò sì san gbogbo rẹ̀ fún ọ.’\wj* 
\v 27 \wj Nígbà náà, ni olúwa ọmọ ọ̀dọ̀ náà sì ṣàánú fún un. Ó tú u sílẹ̀, ó sì fi gbèsè náà jì í.\wj* 
\p  
\v 28 \wj “Ṣùgbọ́n bí ọmọ ọ̀dọ̀ náà ti jáde lọ, ó rí ọ̀kan nínú àwọn ọmọ ọ̀dọ̀ ẹgbẹ́ rẹ̀ tí ó jẹ ẹ́ ní ọgọ́rùn-ún owó idẹ, ó gbé ọwọ́ lé e, ó fún un ní ọrùn, ó wí pé, ‘San gbèsè tí o jẹ mí lójú ẹsẹ̀.’\wj* 
\p  
\v 29 \wj “Ọmọ ọ̀dọ̀ ẹlẹgbẹ́ rẹ̀ náà sì wólẹ̀ lórí eékún níwájú rẹ̀, ò ń bẹ̀ ẹ́ pé, ‘Mú sùúrù fún mi, èmi yóò sì san án fún ọ.’\wj* 
\p  
\v 30 \wj “Ṣùgbọ́n òun kọ̀ fún un. Ó pàṣẹ kí a mú ọkùnrin náà, kí a sì jù ú sínú túbú títí tí yóò fi san gbèsè náà tán pátápátá.\wj* 
\v 31 \wj Nígbà tí àwọn ìránṣẹ́ ẹlẹgbẹ́ rẹ̀ rí ohun tí ó ṣẹlẹ̀, inú bí wọn gidigidi, wọ́n lọ láti lọ sọ fún olúwa wọn, gbogbo ohun tí ó ṣẹlẹ̀.\wj* 
\p  
\v 32 \wj “Nígbà tí olúwa rẹ̀ pè ọmọ ọ̀dọ̀ náà wọlé, ó wí fún un pé, ‘Ìwọ ọmọ ọ̀dọ̀ búburú, níhìn-ín ni mo ti dárí gbogbo gbèsè rẹ jì ọ́ nítorí tí ìwọ bẹ̀ mi.\wj* 
\v 33 \wj Kò ha ṣe ẹ̀tọ́ fún ọ láti ṣàánú fún àwọn ẹlòmíràn, gẹ́gẹ́ bí èmi náà ti ṣàánú fún ọ?’\wj* 
\v 34 \wj Ní ìbínú, olówó rẹ̀ fi í lé àwọn onítúbú lọ́wọ́ láti fi ìyà jẹ ẹ́, títí tí yóò fi san gbogbo gbèsè èyí ti ó jẹ ẹ́.\wj* 
\p  
\v 35 \wj “Bẹ́ẹ̀ gẹ́gẹ́ sì ni Baba mi tí ń bẹ ní ọ̀run yóò sí ṣe sì ẹnìkọ̀ọ̀kan, bí ẹ̀yin kò bá fi tọkàntọkàn dárí ji àwọn arákùnrin yín.”\wj* 
\c 19  
\s1 Ìkọ̀sílẹ̀ 
\p  
\v 1       Lẹ́yìn tí Jesu ti parí ọ̀rọ̀ yìí, ó kúrò ní Galili. Ó sì yípo padà sí Judea, ó gba ìhà kejì odò Jordani.  
\v 2 Ọ̀pọ̀ ènìyàn sì ń tọ̀ ọ́ lẹ́yìn, ó sì mú wọn láradá níbẹ̀. 
\p  
\v 3 Àwọn Farisi wá sọ́dọ̀ rẹ̀ láti dán an wò. Wọ́n bi í pé, “Ǹjẹ́ ó tọ̀nà fún ọkùnrin láti kọ ìyàwó rẹ̀ sílẹ̀ nítorí ohunkóhun?” 
\p  
\v 4 Ó dáhùn ó sì wí fún wọn pé, \wj “Ẹyin kò ti kà á pé ‘ẹni tí ó dá wọn ní ìgbà àtètèkọ́ṣe, Ọlọ́run dá wọn ni ti akọ ti abo.’\wj* 
\v 5 \wj Ó sì wí fún un pé, ‘Nítorí ìdí èyí ọkùnrin yóò fi baba àti ìyá rẹ̀ sílẹ̀, òun yóò sì dàpọ̀ mọ́ aya rẹ̀, àwọn méjèèjì yóò sì di ara kan.’\wj* 
\v 6 \wj Wọn kì í túnṣe méjì mọ́, ṣùgbọ́n ara kan. Nítorí náà, ohun tí Ọlọ́run bá ti so ṣọ̀kan, kí ẹnikẹ́ni má ṣe yà wọ́n.”\wj* 
\p  
\v 7       Wọ́n bi í pé: “Kí ni ìdí tí Mose fi pàṣẹ pé, ọkùnrin kan lè kọ ìyàwó rẹ̀ sílẹ̀ nípa fífún un ní ìwé ìkọ̀sílẹ̀?” 
\p  
\v 8 Jesu dáhùn pé, \wj “Nítorí líle àyà yín ni Mose ṣe gbà fún yín láti máa kọ aya yín sílẹ̀. Ṣùgbọ́n láti ìgbà àtètèkọ́ṣe wá, kò rí bẹ́ẹ̀.\wj* 
\v 9 \wj Mo sọ èyí fún yín pé, ẹnikẹ́ni tí ó bá kọ aya rẹ̀ sílẹ̀, láìṣe pé nítorí àgbèrè, tí ó bá sì fẹ́ ẹlòmíràn, ó ṣe panṣágà.”\wj* 
\p  
\v 10 Àwọn ọmọ-ẹ̀yìn rẹ̀ wí fún un pé, “Bí ọ̀rọ̀ bá rí báyìí láàrín ọkọ àti aya, kó ṣàǹfààní fún wa láti gbé ìyàwó.” 
\p  
\v 11       Jesu dáhùn pé, \wj “Gbogbo ènìyàn kọ́ ló lé gba ọ̀rọ̀ yìí, bí kò ṣe iye àwọn tí a ti fún.\wj* 
\v 12 \wj Àwọn mìíràn jẹ́ akúra nítorí bẹ́ẹ̀ ní a bí wọn, àwọn mìíràn ń bẹ tí ènìyàn sọ wọn di bẹ́ẹ̀; àwọn mìíràn kọ̀ láti gbé ìyàwó nítorí ìjọba ọ̀run. Ẹni tí ó bá lè gbà á kí ó gbà á.”\wj* 
\s1 Àwọn ọmọdé àti Jesu 
\p  
\v 13       Lẹ́yìn náà a sì gbé àwọn ọmọ ọwọ́ wá sọ́dọ̀ Jesu, kí ó lè gbé ọwọ́ lé wọn, kí ó sì gbàdúrà fún wọn. Ṣùgbọ́n àwọn ọmọ-ẹ̀yìn rẹ̀ bá àwọn tí ó gbé wọn wá wí. 
\p  
\v 14 Ṣùgbọ́n Jesu dáhùn pé, \wj “Ẹ jẹ́ kí àwọn ọmọdé wá sọ́dọ̀ mi, ẹ má ṣe dá wọn lẹ́kun, nítorí irú wọn ni ìjọba ọ̀run.”\wj* 
\v 15 Lẹ́yìn náà, ó gbé ọwọ́ lé wọn, ó sì kúrò níbẹ̀. 
\s1 Ọ̀dọ́mọkùnrin ọlọ́rọ̀ 
\p  
\v 16       Ẹnìkan sì wá ó bí Jesu pé, “Olùkọ́, ohun rere kí ni èmi yóò ṣe, kí èmi kí ó lè ní ìyè àìnípẹ̀kun?” 
\p  
\v 17 Jesu dá a lóhùn pé, \wj “Èéṣe tí ìwọ fi ń béèrè nípa ohun rere lọ́wọ́ mi. Ẹni kan ṣoṣo ni ó wà tí í ṣe ẹni rere. Bí ìwọ bá fẹ́ dé ibi ìyè, pa àwọn òfin mọ́.”\wj* 
\p  
\v 18       Ọkùnrin náà béèrè pé, “Àwọn wo ni òfin wọ̀nyí?” 
\p Jesu dáhùn pé, \wj “ ‘Ìwọ kò gbọdọ̀ pànìyàn; ìwọ kò gbọdọ̀ ṣe panṣágà; ìwọ kò gbọdọ̀ jalè; ìwọ kò gbọdọ̀ jẹ́rìí èké’,\wj* 
\v 19 \wj bọ̀wọ̀ fún baba àti ìyá rẹ. ‘Kí o sì fẹ́ aládùúgbò rẹ gẹ́gẹ́ bí ara rẹ.’ ”\wj* 
\p  
\v 20 Ọmọdékùnrin náà tún wí pé, “Gbogbo òfin wọ̀nyí ni èmi ti ń pamọ́, kí ni nǹkan mìíràn tí èmi ní láti ṣe?” 
\p  
\v 21       Jesu wí fún un pé, \wj “Bí ìwọ bá fẹ́ di ẹni pípé, lọ ta ohun gbogbo tí ìwọ ní, kí o sì fi owó rẹ̀ tọrẹ fún àwọn aláìní. Ìwọ yóò ní ọrọ̀ ńlá ní ọ̀run. Lẹ́yìn náà, wá láti máa tọ̀ mi lẹ́yìn.”\wj* 
\p  
\v 22 Ṣùgbọ́n nígbà tí ọ̀dọ́mọkùnrin náà gbọ́ èyí, ó kúrò níbẹ̀ pẹ̀lú ìbànújẹ́, nítorí ó ní ọrọ̀ púpọ̀. 
\p  
\v 23       Nígbà náà, ní Jesu wí fún àwọn ọmọ-ẹ̀yìn rẹ̀ pé, \wj “Lóòótọ́ ni mo wí fún yín pé, ó ṣòro fún ọlọ́rọ̀ láti wọ ìjọba Ọ̀run.”\wj* 
\v 24 Mo tún wí fún yín pé, \wj “Ó rọrùn fún ìbákasẹ láti wọ ojú abẹ́rẹ́ jù fún ọlọ́rọ̀ láti wọ ìjọba Ọlọ́run.”\wj* 
\p  
\v 25 Nígbà tí àwọn ọmọ-ẹ̀yìn gbọ́ èyí, ẹnu sì yà wọn gidigidi, wọ́n béèrè pé, “Ǹjẹ́ ta ni ó ha le là?” 
\p  
\v 26       Ṣùgbọ́n Jesu wò wọ́n, ó sì wí fún wọn pé, \wj “Ènìyàn ni èyí ṣòro fún; ṣùgbọ́n fún Ọlọ́run ohun gbogbo ni ṣíṣe.”\wj* 
\p  
\v 27       Peteru sì wí fún un pé, “Àwa ti fi ohun gbogbo sílẹ̀, a sì tẹ̀lé ọ, kí ni yóò jẹ́ èrè wa?” 
\p  
\v 28       Jesu dáhùn pé, \wj “Lóòótọ́ ni mo wí fún yín pé, ‘Nígbà ìsọdọ̀tun ohun gbogbo, nígbà tí Ọmọ Ènìyàn yóò jókòó lórí ìtẹ́ tí ó lógo, dájúdájú, ẹ̀yin ọmọ-ẹ̀yìn mi yóò sì jókòó lórí ìtẹ́ méjìlá láti ṣe ìdájọ́ ẹ̀yà Israẹli méjìlá.\wj* 
\v 29 \wj Àti pé ẹnikẹ́ni tí ó bá fi ilé tàbí arákùnrin tàbí arábìnrin tàbí baba tàbí ìyá tàbí àwọn ọmọ, tàbí ohun ìní rẹ̀ sílẹ̀ nítorí orúkọ mí, yóò gba ọgọọgọ́rùn-ún èrè rẹ̀ láyé, wọn ó sì tún jogún ìyè àìnípẹ̀kun.\wj* 
\v 30 \wj Ṣùgbọ́n ọ̀pọ̀ àwọn tí ó síwájú nísinsin yìí ni yóò kẹ́yìn, àwọn tí ó kẹ́yìn ni yóò sì síwájú.’\wj* 
\c 20  
\s1 Òwe àwọn òṣìṣẹ́ nínú ọgbà àjàrà 
\p  
\v 1 \wj “Nítorí ìjọba ọ̀run dàbí ọkùnrin tí ó jẹ́ baálé kan, tí ó jíjáde lọ ní kùtùkùtù òwúrọ̀, tí ó gba àwọn alágbàṣe sínú ọgbà àjàrà rẹ̀.\wj* 
\v 2 \wj Òun pinnu láti san dínárì kan fún iṣẹ́ òòjọ́ kan. Lẹ́yìn èyí ó sì rán wọn lọ sínú ọgbà àjàrà rẹ̀.\wj* 
\p  
\v 3 \wj “Ní wákàtí kẹta ọjọ́ bí ó ti ń kọjá níwájú ilé ìgbanisíṣẹ́, ó rí díẹ̀ nínú àwọn aláìríṣẹ́ tí wọ́n dúró ní ọjà.\wj* 
\v 4 \wj Ó wí fún wọn pé, ‘Ẹ̀yin pàápàá, ẹ lọ ṣiṣẹ́ nínú ọgbà àjàrà mi, bí ó bá sì di òpin ọjọ́, èmi yóò san iye ti ó bá yẹ fún yín.’\wj* 
\v 5 \wj Wọ́n sì lọ.\wj* 
\p \wj “Ó tún jáde lọ́sàn án ní nǹkan bí wákàtí kẹfà àti wákàtí kẹsànán, ó túnṣe bákan náà.\wj* 
\v 6 \wj Lọ́jọ́ kan náà ní wákàtí kọkànlá ọjọ́, ó tún jáde sí àárín ìlú, ó sì rí àwọn aláìríṣẹ́ mìíràn tí wọ́n dúró. Ó bi wọ́n pé, ‘Èéṣe tí ẹ̀yin kì í ṣiṣẹ́ ní gbogbo ọjọ́?’\wj* 
\p  
\v 7 \wj “Wọ́n sì dáhùn pé, ‘Nítorí pé kò sí ẹni tí yóò fún wa ní iṣẹ́ ṣe.’\wj* 
\p \wj “Ó tún sọ fún wọn pé, ‘Ẹ̀yin náà ẹ jáde lọ ṣiṣẹ́ pẹ̀lú nínú ọgbà àjàrà mi.’\wj* 
\p  
\v 8 \wj “Nígbà tí ó di àṣálẹ́, ẹni tó ni ọgbà àjàrà sọ fún aṣojú rẹ̀ pé, ‘Pe àwọn òṣìṣẹ́ náà, kí ó san owó iṣẹ́ wọn fún wọn, bẹ̀rẹ̀ láti ẹni ìkẹyìn lọ sí ti ìṣáájú.’\wj* 
\p  
\v 9 \wj “Nígbà tí àwọn ti a pè ní wákàtí kọkànlá ọjọ́ dé, ẹnìkọ̀ọ̀kan gba owó dínárì kan.\wj* 
\v 10 \wj Nígbà tí àwọn tí a gbà ṣiṣẹ́ lákọ̀ọ́kọ́ fẹ́ gba owó tiwọn, èrò wọn ni pé àwọn yóò gba jù bẹ́ẹ̀ lọ, ṣùgbọ́n ẹnìkọ̀ọ̀kan wọn gba owó dínárì kan.\wj* 
\v 11 \wj Bí wọ́n ti ń gbà á, wọ́n ń kùn sí onílẹ̀ náà,\wj* 
\v 12 \wj pé, ‘Wákàtí kan péré ni àwọn tí a gbà kẹ́yìn fi ṣiṣẹ́, ìwọ sì san iye kan náà fún wọn àti àwa náà ti a fi gbogbo ọjọ́ ṣiṣẹ́ nínú oòrùn gangan.’\wj* 
\p  
\v 13 \wj “Ṣùgbọ́n ó dá ọ̀kan nínú wọn lóhùn pé, ‘Ọ̀rẹ́, kò sí aburú nínú nǹkan tí èmi ṣe sí yín. Kì í ha ṣe pé ẹ̀yin gbà láti ṣiṣẹ́ fún owó dínárì kan.\wj* 
\v 14 \wj Ó ní, gba èyí tí í ṣé tìrẹ, ki ó sì máa lọ. Èmi fẹ́ láti fún ẹni ìkẹyìn gẹ́gẹ́ bí mo ti fi fún ọ.\wj* 
\v 15 \wj Àbí ó lòdì sí òfin pé kí èmi fún ẹnikẹ́ni ní owó mi bí mo bá yàn láti ṣe bẹ́ẹ̀? Kí ni ìdí tí ìwọ ní láti bínú nítorí èmi ṣe ohun rere?’\wj* 
\p  
\v 16 \wj “Bẹ́ẹ̀ ni àwọn ẹni ìkẹyìn yóò di ẹni ìṣáájú, ẹni ìṣáájú yóò sì di ẹni ìkẹyìn.”\wj* 
\s1 Jesu tún sọ àsọtẹ́lẹ̀ nípa ikú rẹ̀ 
\p  
\v 17       Bí Jesu ti ń gòkè lọ sí Jerusalẹmu, ó pe àwọn ọmọ-ẹ̀yìn rẹ̀ méjìlá sí apá kan ó sì wí pé,  
\v 18 \wj “Wò ó, àwa ń gòkè lọ sí Jerusalẹmu. Ó sọ fún wọn pé, a ó fi Ọmọ Ènìyàn lé àwọn olórí àlùfáà àti àwọn olùkọ́ òfin lọ́wọ́, wọn yóò sì dá mi lẹ́bi ikú.\wj* 
\v 19 \wj Wọn yóò sì fà á lé àwọn kèfèrí lọ́wọ́ láti fi ṣe ẹlẹ́yà àti láti náà án, àti láti kàn mi mọ́ àgbélébùú, ní ọjọ́ kẹta, yóò jí dìde.”\wj* 
\s1 Ẹ̀bẹ̀ ìyá 
\p  
\v 20       Nígbà náà ni ìyá àwọn ọmọ Sebede bá àwọn ọmọ rẹ̀ wá sọ́dọ̀ Jesu, ó wólẹ̀ lórí eékún rẹ̀, o béèrè fún ojúrere rẹ̀. 
\p  
\v 21       Jesu béèrè pé, \wj “Kí ni ìwọ ń fẹ́?”\wj* 
\p Ó sì dáhùn pé, “Jẹ́ kí àwọn ọmọ mi méjèèjì jókòó ní apá ọ̀tún àti apá òsì lórí ìtẹ́ ìjọba rẹ?” 
\p  
\v 22       Ṣùgbọ́n Jesu dáhùn ó sì wí pé, \wj “Ẹ̀yin kò mọ ohun tí ẹ̀yin ń béèrè, ẹ̀yin ha le mu nínú ago tí èmi ó mu?”\wj* 
\p Wọ́n dáhùn pé, “Àwa lè mu ún.” 
\p  
\v 23       Jesu sì wí fún wọn pé, \wj “Dájúdájú, ẹ̀yin yóò mu nínú ago mi, ṣùgbọ́n èmi kò ní àṣẹ láti sọ irú ènìyàn tí yóò jókòó ní apá ọ̀tún tàbí apá òsì. Baba mi ti pèsè ààyè wọ̀n-ọn-nì sílẹ̀ fún kìkì àwọn tí ó yàn.”\wj* 
\p  
\v 24 Nígbà tí àwọn ọmọ-ẹ̀yìn mẹ́wàá ìyókù sì gbọ́ èyí, wọ́n bínú sí àwọn arákùnrin méjì yìí.  
\v 25  Ṣùgbọ́n Jesu pé wọ́n papọ̀, ó wí pé, \wj “Dájúdájú, ẹ̀yin mọ̀ pé àwọn ọba aláìkọlà a máa lo agbára lórí wọn, àwọn ẹni ńlá láàrín wọn a sì máa fi ọlá tẹrí àwọn tí ó wà lábẹ́ wọn ba.\wj* 
\v 26 \wj Ṣùgbọ́n èyí yàtọ̀ láàrín yín. Dípò bẹ́ẹ̀, ẹni tí ó bá ń fẹ́ ṣe olórí láàrín yín, ní láti ṣe bí ìránṣẹ́ fún yín ni,\wj* 
\v 27 \wj àti ẹni tí ó bá fẹ́ ṣe olórí nínú yín, ẹ jẹ́ kí ó máa ṣe ọmọ ọ̀dọ̀ yin.\wj* 
\v 28 \wj Gẹ́gẹ́ bí Ọmọ Ènìyàn kò ṣe wá sí ayé, kí ẹ lè ṣe ìránṣẹ́ fún un, ṣùgbọ́n láti ṣe ìránṣẹ́ fún yín, àti láti fi ẹ̀mí rẹ ṣe ìràpadà ọ̀pọ̀ ènìyàn.”\wj* 
\s1 Afọ́jú méjì ríran 
\p  
\v 29       Bí Jesu àti àwọn ọmọ-ẹ̀yìn rẹ̀ ti ń fi ìlú Jeriko sílẹ̀, ọ̀pọ̀ ènìyàn sì wọ́ tẹ̀lé e lẹ́yìn.  
\v 30 Àwọn ọkùnrin afọ́jú méjì sì jókòó lẹ́bàá ọ̀nà, nígbà tí wọ́n sí gbọ́ pé Jesu ń kọjá lọ, wọ́n bẹ̀rẹ̀ sí í kígbe pé, “Olúwa, Ọmọ Dafidi, ṣàánú fún wa!” 
\p  
\v 31 Àwọn ènìyàn sí bá wọn wí pé kí wọn dákẹ́, ṣùgbọ́n wọ́n kígbe sókè sí i. “Olúwa, ọmọ Dafidi, ṣàánú fún wa!” 
\p  
\v 32 Jesu dúró lójú ọ̀nà, ó sì pè wọ́n, Ó béèrè pé, \wj “Kí ni ẹ̀yin fẹ́ kí èmi ṣe fún yín?”\wj* 
\p  
\v 33 Wọ́n dáhùn pé, “Olúwa, àwa fẹ́ kí a ríran.” 
\p  
\v 34 Àánú wọn sì ṣe Jesu, ó fi ọwọ́ kan ojú wọn. Lójúkan náà, wọ́n sì ríran, wọ́n sì ń tọ̀ ọ́ lẹ́yìn. 
\c 21  
\s1 Fífi ayọ̀ wọlé 
\p  
\v 1       Bí wọ́n ti súnmọ́ Jerusalẹmu, tí wọ́n dé itòsí ìlú Betfage ní orí òkè Olifi, Jesu sì rán àwọn ọmọ-ẹ̀yìn méjì,  
\v 2 Ó wí fún wọn pé, \wj “Ẹ lọ sí ìletò tó wà ni tòsí yín, ẹ̀yin yóò rí kẹ́tẹ́kẹ́tẹ́ kan ti wọ́n so pẹ̀lú ọmọ rẹ̀ lẹ́gbẹ̀ẹ́ rẹ̀. Ẹ tú wọn, kí ẹ sì mú wọn wá fún mi.\wj* 
\v 3 \wj Bí ẹnikẹ́ni bá sì béèrè ìdí tí ẹ fi ń ṣe bẹ́ẹ̀, ẹ sá à wí pé, Olúwa fẹ́ lo wọn, òun yóò sì rán wọn lọ.”\wj* 
\p  
\v 4 Èyí ṣẹlẹ̀ láti mú àsọtẹ́lẹ̀ wòlíì ṣẹ pé: 
\q1  
\v 5       “Ẹ sọ fún ọmọbìnrin Sioni pé, 
\q2 ‘Wò ó, ọba rẹ ń bọ̀ wá sí ọ̀dọ̀ rẹ, 
\q1 ní ìrẹ̀lẹ̀, ó ń gun kẹ́tẹ́kẹ́tẹ́, 
\q2 àti lórí ọmọ kẹ́tẹ́kẹ́tẹ́.’ ” 
\p  
\v 6 Àwọn ọmọ-ẹ̀yìn náà sí lọ, wọ́n ṣe bí Jesu ti sọ fún wọn.  
\v 7 Wọ́n sì mú kẹ́tẹ́kẹ́tẹ́ náà pẹ̀lú ọmọ rẹ̀, wọ́n tẹ́ aṣọ lé e, Jesu si jókòó lórí rẹ̀.  
\v 8  Ọ̀pọ̀ ìjọ ènìyàn sì tẹ́ aṣọ wọn sí ojú ọ̀nà níwájú rẹ̀, ẹlòmíràn ṣẹ́ ẹ̀ka igi wẹ́wẹ́ wọ́n sì tẹ́ wọn sí ojú ọ̀nà.  
\v 9  Ọ̀pọ̀ ènìyàn ń lọ níwájú rẹ̀ àti lẹ́yìn rẹ̀ pẹ̀lú ń kígbe pé, 
\q1 “Hosana fún ọmọ Dafidi!” 
\b  
\q1 “Olùbùkún ni fún ẹni tí ó ń bọ̀ ní orúkọ Olúwa!” 
\b  
\q1 “Hosana ní ibi gíga jùlọ!” 
\p  
\v 10 Bí Jesu sì ti ń wọ Jerusalẹmu, gbogbo ìlú mì tìtì, àwọn ènìyàn bẹ̀rẹ̀ sí í bi ara wọn pé, “Ta nìyìí?” 
\p  
\v 11       Ọ̀pọ̀ ènìyàn sì dáhùn pé, “Èyí ni Jesu, wòlíì náà láti Nasareti ti Galili.” 
\s1 Jesu palẹ̀ Tẹmpili mọ́ 
\p  
\v 12 Jesu sì wọ inú tẹmpili, Ó sì lé àwọn ti ń tà àti àwọn tí ń rà níbẹ̀ jáde. Ó yí tábìlì àwọn onípàṣípàrọ̀ owó dànù, àti tábìlì àwọn tí ó ń ta ẹyẹlé.  
\v 13  Ó wí fún wọn pé, \wj “A sá à ti kọ ọ́ pé, ‘Ilé àdúrà ni a ó máa pe ilé mi,’ ṣùgbọ́n ẹ̀yin ti sọ ọ́ di ibùdó àwọn ọlọ́ṣà.”\wj* 
\p  
\v 14 A sì mú àwọn afọ́jú àti àwọn arọ wá sọ́dọ̀ rẹ̀ ní tẹmpili, ó sì mú wọ́n láradá.  
\v 15  Ṣùgbọ́n nígbà tí àwọn olórí àlùfáà àti àwọn olùkọ́ òfin rí àwọn iṣẹ́ ìyanu ńlá wọ̀nyí, ti wọ́n sì tún ń gbọ́ tí àwọn ọmọdé ń kígbe nínú tẹmpili pé, “Hosana fún ọmọ Dafidi,” inú bí wọn. 
\p  
\v 16       Wọ́n sì bí i pé, “Ǹjẹ́ ìwọ gbọ́ nǹkan tí àwọn ọmọdé wọ̀nyí ń sọ?” 
\p Jesu sí dáhùn pé, \wj “Bẹ́ẹ̀ ni, àbí ẹ̀yin kò kà á pé,\wj* 
\q1 \wj “ ‘Láti ẹnu àwọn ọmọdé àti àwọn ọmọ ọmú,\wj* 
\q2 \wj ni a ó ti máa yìn mí’?”\wj* 
\p  
\v 17       Ó sì fi wọ́n sílẹ̀, ó lọ sí Betani. Níbẹ̀ ni ó dúró ní òru náà. 
\s1 Igi ọ̀pọ̀tọ́ gbẹ 
\p  
\v 18 Ní òwúrọ̀ bí ó ṣe ń padà sí ìlú, ebi ń pa á.  
\v 19 Ó sì ṣàkíyèsí igi ọ̀pọ̀tọ́ kan lẹ́bàá ojú ọ̀nà, ó sì lọ wò ó bóyá àwọn èso wà lórí rẹ̀, ṣùgbọ́n kò sí ẹyọ kan, ewé nìkan ni ó wà lórí rẹ̀. Nígbà náà ni ó sì wí fún igi náà pé, \wj “Kí èso má tún so lórí rẹ mọ́ láti òní lọ àti títí láé.”\wj* Lójúkan náà igi ọ̀pọ̀tọ́ náà sì gbẹ. 
\p  
\v 20       Nígbà tí àwọn ọmọ-ẹ̀yìn rẹ̀ rí èyí, ẹnu yà wọn, wọ́n béèrè pé, “Báwo ni igi ọ̀pọ̀tọ́ náà ṣe gbẹ kíákíá?” 
\p  
\v 21       Jesu wí fún wọn pé, \wj “Lóòótọ́ ni mo wí fún yín, bí ẹ̀yin bá lè ní ìgbàgbọ́ láìṣiyèméjì, nígbà náà ẹ̀yin yóò lè ṣe irú ohun tí a ṣe sí igi ọ̀pọ̀tọ́, ẹ̀yin yóò lè sọ fún òkè yìí pé, ‘Yí ipò padà sínú Òkun,’ yóò sì rí bẹ́ẹ̀.\wj* 
\v 22 \wj Bí ẹ̀yin bá gbàgbọ́, ẹ̀yin lè rí ohunkóhun tí ẹ bá béèrè nínú àdúrà gbà.”\wj* 
\s1 A béèrè àṣẹ tí Jesu ń lò 
\p  
\v 23       Jesu wọ tẹmpili, nígbà tí ó ń kọ́ni, àwọn olórí àlùfáà àti àwọn àgbàgbà Júù tọ̀ ọ́ wá. Wọ́n béèrè pé “nípa àṣẹ wo ni o fi ń ṣe àwọn nǹkan wọ̀nyí? Ta ni ó sì fún ọ ni àṣẹ yìí?” 
\p  
\v 24 Jesu sì dáhùn ó sì wí fún wọn pé, \wj “Èmi yóò si bí yin léèrè ohun kan, bí ẹ̀yin bá lé sọ fún mi, nígbà náà èmi yóò sọ fún yín, àṣẹ tí Èmi fi ń ṣe àwọn nǹkan wọ̀nyí.\wj* 
\v 25 \wj Níbo ni ìtẹ̀bọmi Johanu ti wa? Láti ọ̀run wá ni, tàbí láti ọ̀dọ̀ ènìyàn.”\wj* 
\p Wọ́n sì bá ara wọn gbèrò pé, “Bí àwa bá wí pé láti ọ̀run wá ni, òun yóò wí fún wa pé, ‘Èéha ti ṣe tí ẹ̀yin kò fi gbà á gbọ́?’  
\v 26  Ní ìdàkejì, bí àwa bá sì sọ pé, ‘Láti ọ̀dọ̀ ènìyàn, àwa bẹ̀rù ìjọ ènìyàn, nítorí gbogbo wọ́n ka Johanu sí wòlíì.’ ” 
\p  
\v 27 Nítorí náà wọ́n sì dá Jesu lóhùn pé, “Àwa kò mọ̀.” 
\p Nígbà náà ni ó wí pé, \wj “Nítorí èyí, èmi kò ní sọ àṣẹ tí èmi fi ń ṣe nǹkan wọ̀nyí fún yín.\wj* 
\s1 Òwe àwọn ọmọ méjì 
\p  
\v 28 \wj “Kí ni ẹ rò nípa eléyìí? Ọkùnrin kan ti ó ní àwọn ọmọkùnrin méjì. Ó sọ fún èyí ẹ̀gbọ́n pé, ‘Ọmọ, lọ ṣiṣẹ́ nínú ọgbà àjàrà lónìí.’\wj* 
\p  
\v 29 \wj “Ó sì dá baba rẹ̀ lóhùn pé, ‘Èmi kò ní í lọ,’ ṣùgbọ́n níkẹyìn ó yí ọkàn padà, ó sì lọ.\wj* 
\p  
\v 30 \wj “Nígbà náà ni baba yìí tún sọ fún èyí àbúrò pé, ‘Lọ ṣiṣẹ́ ní oko.’ Ọmọ náà sì sọ pé, ‘Èmi yóò lọ, baba,’ ṣùgbọ́n kò lọ rárá.\wj* 
\p  
\v 31 \wj “Nínú àwọn méjèèjì yìí, èwo ni ó ṣe ìfẹ́ baba wọn?”\wj* 
\p Gbogbo wọn sì fohùn ṣọ̀kan pé, “Èyí ẹ̀gbọ́n ni.” 
\p Jesu wí fún wọn pé, \wj “Lóòótọ́ ni mo wí fún yín, àwọn agbowó òde àti àwọn panṣágà yóò wọ ìjọba ọ̀run síwájú yín.\wj* 
\v 32 \wj Nítorí Johanu tọ́ yin wá láti fi ọ̀nà òdodo hàn yín, ṣùgbọ́n ẹ̀yin kò gbà á gbọ́, ṣùgbọ́n àwọn agbowó òde àti àwọn panṣágà ronúpìwàdà, bí ó tilẹ̀ ṣe pé ẹ rí àwọn ohun tí ń ṣẹlẹ̀ wọ̀nyí, ẹ kọ̀ láti ronúpìwàdà, ẹ kò gbà á gbọ́.”\wj* 
\s1 Òwe àwọn ayálégbé 
\p  
\v 33 \wj “Ẹ gbọ́ òwe mìíràn, Baálé ilé kan tí ó gbin ọgbà àjàrà, ó ṣe ọgbà yìí ká, ó wá ibi ìfúntí sínú rẹ̀, ó kọ́ ilé ìṣọ́. Ó sì fi oko náà ṣe àgbàtọ́jú fún àwọn àgbẹ̀ kan, ó sì lọ sí ìrìnàjò.\wj* 
\v 34 \wj Nígbà ti àkókò ìkórè súnmọ́, ó rán àwọn ìránṣẹ́ rẹ̀ sí àwọn àgbẹ̀ náà láti gba èyí ti ó jẹ tirẹ̀ wá.\wj* 
\p  
\v 35 \wj “Ṣùgbọ́n àwọn alágbàtọ́jú sì mú àwọn ọmọ ọ̀dọ̀ rẹ̀, wọn lu ẹni kìn-ín-ní, wọn pa èkejì, wọ́n si sọ ẹ̀kẹta ní òkúta.\wj* 
\v 36 \wj Ó sì tún rán àwọn ọmọ ọ̀dọ̀ mìíràn àwọn tí ó ju ti ìṣáájú lọ. Wọ́n sì túnṣe bí ti àkọ́kọ́ sí àwọn wọ̀nyí pẹ̀lú.\wj* 
\v 37 \wj Níkẹyìn, baálé ilé yìí rán ọmọ rẹ̀ pàápàá sí wọn. Ó wí pé, ‘Wọn yóò bu ọlá fún ọmọ mi.’\wj* 
\p  
\v 38 \wj “Ṣùgbọ́n bí àwọn alágbàtọ́jú wọ̀nyí ti rí ọmọ náà lókèèrè, wọ́n wí fún ara wọn pé, ‘Èyí ni àrólé náà. Ẹ wá, ẹ jẹ́ kí a pa á, kí a sì jogún rẹ̀.’\wj* 
\v 39 \wj Wọ́n sì wọ́ ọ jáde kúrò nínú ọgbà àjàrà náà, wọ́n sì pa á.\wj* 
\p  
\v 40 \wj “Ǹjẹ́ nígbà tí olúwa ọgbà àjàrà bá dé, kí ni yóò ṣe sí àwọn olùṣọ́gbà wọ̀n-ọn-nì?”\wj* 
\p  
\v 41       Wọ́n wí pé, “Òun yóò pa àwọn ènìyàn búburú náà run, yóò sì fi ọgbà àjàrà rẹ̀ fún àwọn alágbàtọ́jú mìíràn tí yóò fún un ní èso tirẹ̀ lásìkò ìkórè.” 
\p  
\v 42       Jesu wí fún wọ́n pé, \wj “Àbí ẹ̀yin kò kà á nínú Ìwé Mímọ́ pé:\wj* 
\q1 \wj “ ‘Òkúta tí àwọn ọ̀mọ̀lé kọ̀sílẹ̀,\wj* 
\q2 \wj ni ó di pàtàkì igun ilé;\wj* 
\q1 \wj iṣẹ́ Olúwa ni èyí,\wj* 
\q2 \wj ó sì jẹ́ ìyanu ní ojú wa’?\wj* 
\p  
\v 43 \wj “Nítorí náà èmi wí fún yín, a ó gba ìjọba Ọlọ́run lọ́wọ́ yín, a ó sì fi fún àwọn orílẹ̀-èdè tí yóò máa mú èso rẹ̀ wá.\wj* 
\v 44 \wj Ẹni tí ó bá ṣubú lu òkúta yìí yóò di fífọ́, ṣùgbọ́n ẹni tí òun bá ṣubú lù yóò lọ̀ ọ́ lúúlúú.”\wj* 
\p  
\v 45 Nígbà tí àwọn olórí àlùfáà àti àwọn Farisi gbọ́ òwe Jesu, wọ́n mọ̀ wí pé ó ń sọ̀rọ̀ nípa àwọn.  
\v 46 Wọn wá ọ̀nà láti mú un, ṣùgbọ́n wọn bẹ̀rù ọ̀pọ̀ ènìyàn tí wọ́n gba Jesu gẹ́gẹ́ bí wòlíì. 
\c 22  
\s1 Òwe àsè ìgbéyàwó 
\p  
\v 1       Jesu tún fi òwe sọ̀rọ̀ fún wọn wí pé:  
\v 2 \wj “Ìjọba ọ̀run dàbí ọba kan ti ó múra àsè ìgbéyàwó ńlá fún ọmọ rẹ̀ ọkùnrin.\wj* 
\v 3 \wj Ó rán àwọn ọmọ ọ̀dọ̀ rẹ̀ lọ pe àwọn tí a ti pè tẹ́lẹ̀ sí ibi àsè ìgbéyàwó. Ṣùgbọ́n wọn kò fẹ́ wá.\wj* 
\p  
\v 4 \wj “Lẹ́yìn náà ó tún rán àwọn ọmọ ọ̀dọ̀ mìíràn pé, ‘Ẹ sọ fún àwọn tí mo ti pè wí pé, mo ti ṣe àsè náà tán. A pa màlúù àti ẹran àbọ́pa mi, a ti ṣe ohun gbogbo tán, ẹ wa sí ibi àsè ìgbéyàwó.’\wj* 
\p  
\v 5 \wj “Ṣùgbọ́n àwọn wọ̀n-ọn-nì tí ó ránṣẹ́ lọ pè kò kà á si. Wọ́n ń bá iṣẹ́ wọn lọ, ọ̀kan sí ọ̀nà oko rẹ̀, òmíràn sí ibi òwò rẹ̀.”\wj* 
\v 6 \wj Àwọn ìyókù sì mú àwọn ọmọ ọ̀dọ̀ rẹ̀, wọ́n ṣe àbùkù sí wọn, wọ́n lù wọ́n pa.\wj* 
\v 7 \wj Ọba yìí bínú gidigidi, ó sì rán àwọn ọmọ-ogun rẹ̀, ó sì pa àwọn apànìyàn náà run, ó sì jó ìlú wọn.\wj* 
\p  
\v 8 \wj “Nígbà náà ni ó wí fún àwọn ọmọ ọ̀dọ̀ rẹ̀ pé, ‘Àsè ìgbéyàwó ti ṣe tàn, ṣùgbọ́n àwọn tí a pè kò yẹ fún ọlá náà.\wj* 
\v 9 \wj Ẹ lọ sí ìgboro àti òpópónà kí ẹ sì pe ẹnikẹ́ni tí ẹ bá lè rí wá àsè ìgbéyàwó náà.’\wj* 
\v 10 \wj Nítorí náà, àwọn ọmọ ọ̀dọ̀ náà sì jáde lọ sí òpópónà. Wọ́n sì mú oríṣìíríṣìí ènìyàn tí wọ́n lè rí wá, àwọn tí ò dára àti àwọn tí kò dára, ilé àsè ìyàwó sì kún fún àlejò.\wj* 
\p  
\v 11 \wj “Ṣùgbọ́n nígbà tí ọba sì wọlé wá láti wo àwọn àlejò tí a pè, ó sì rí ọkùnrin kan nínú wọn tí kò wọ aṣọ ìgbéyàwó.\wj* 
\v 12 \wj Ọba sì bi í pé, ‘Ọ̀rẹ́, báwo ni ìwọ ṣe wà níhìn-ín yìí láìní aṣọ ìgbéyàwó?’ Ṣùgbọ́n ọkùnrin náà kò ní ìdáhùn kankan.\wj* 
\p  
\v 13 \wj “Nígbà náà ni ọba wí fún àwọn ìránṣẹ́ rẹ̀ pé, ‘Ẹ dì í tọwọ́ tẹsẹ̀, kí ẹ sì sọ ọ́ sínú òkùnkùn lóde níbi tí ẹkún àti ìpayínkeke wà.’\wj* 
\p  
\v 14 \wj “Nítorí ọ̀pọ̀ ni a pè ṣùgbọ́n díẹ̀ ni a yàn.”\wj* 
\s1 Sísan owó orí fún Kesari 
\p  
\v 15       Nígbà náà ni àwọn Farisi péjọpọ̀ láti ronú ọ̀nà tì wọn yóò gbà fi ọ̀rọ̀ ẹnu mú un.  
\v 16 Wọ́n sì rán àwọn ọmọ-ẹ̀yìn wọn pẹ̀lú àwọn ọmọ-ẹ̀yìn Herodu lọ sọ́dọ̀ rẹ̀ pé, “Olùkọ́, àwa mọ̀ pé olóòtítọ́ ni ìwọ, ìwọ sì ń kọ́ni ní ọ̀nà Ọlọ́run ní òtítọ́. Bẹ́ẹ̀ ni ìwọ kì í wo ojú ẹnikẹ́ni; nítorí tí ìwọ kì í ṣe ojúsàájú ènìyàn.  
\v 17 Nísinsin yìí sọ fún wa, kí ni èrò rẹ? Ǹjẹ́ ó tọ́ láti san owó orí fún Kesari tàbí kò tọ́?” 
\p  
\v 18 Ṣùgbọ́n Jesu ti mọ èrò búburú inú wọn, ó wí pé, \wj “Ẹ̀yin àgàbàgebè, èéṣe ti ẹ̀yin fi ń dán mi wò?\wj* 
\v 19 \wj Ẹ fi owó ẹyọ tí a fi ń san owó orí kan hàn mi.”\wj* Wọn mú dínárì kan wá fún un,  
\v 20 ó sì bi wọ́n pé, \wj “Àwòrán ta ni èyí? Àkọlé tà sì ní?”\wj* 
\p  
\v 21       Wọ́n sì dáhùn pé, “Ti Kesari ni.” 
\p \wj “Nígbà náà ni ó wí fún wọn pé,” “Ẹ fi èyí tí í ṣe ti Kesari fún Kesari, ẹ sì fi èyí ti ṣe ti Ọlọ́run fún Ọlọ́run.”\wj* 
\p  
\v 22 Nígbà tí wọ́n gbọ́ èyí, ẹnu yà wọ́n. Wọ́n fi í sílẹ̀, wọ́n sì bá tiwọn lọ. 
\s1 Ìgbéyàwó nígbà àjíǹde 
\p  
\v 23       Ṣùgbọ́n ní ọjọ́ kan náà, àwọn Sadusi tí wọ́n sọ pé kò si àjíǹde lẹ́yìn ikú tọ Jesu wá láti bi í ní ìbéèrè,  
\v 24  wọ́n wí pé, “Olùkọ́, Mose wí fún wa pé, bí ọkùnrin kan bá kú ní àìlọ́mọ, kí arákùnrin rẹ̀ ṣú aya rẹ̀ lópó, kí ó sì bí ọmọ fún un.  
\v 25 Bí ó bá jẹ́ bẹ́ẹ̀, láàrín wa níhìn-ín yìí, ìdílé kan wà tí ó ní arákùnrin méje. Èyí èkínní nínú wọn gbéyàwó, lẹ́yìn náà ó kú ní àìlọ́mọ. Nítorí náà ìyàwó rẹ̀ di ìyàwó arákùnrin kejì.  
\v 26 Bẹ́ẹ̀ gẹ́gẹ́ arákùnrin èkejì náà sì tún kú láìlọ́mọ. A sì fi ìyàwó rẹ̀ fún arákùnrin tí ó tún tẹ̀lé e. Bẹ́ẹ̀ sì ni títí tí òun fi di ìyàwó ẹni keje.  
\v 27 Níkẹyìn obìnrin náà pàápàá sì kú.  
\v 28 Nítorí tí ó ti ṣe ìyàwó àwọn arákùnrin méjèèje, ìyàwó ta ni yóò jẹ́ ní àjíǹde òkú?” 
\p  
\v 29 Ṣùgbọ́n Jesu dá wọn lóhùn pé, \wj “Àìmọ̀kan yín ni ó fa irú ìbéèrè báyìí. Nítorí ẹ̀yin kò mọ Ìwé Mímọ́ àti agbára Ọlọ́run.\wj* 
\v 30 \wj Nítorí ní àjíǹde kò ní sí ìgbéyàwó, a kò sì ní fi í fún ni ní ìyàwó. Gbogbo ènìyàn yóò sì dàbí àwọn angẹli ní ọ̀run.\wj* 
\v 31 \wj Ṣùgbọ́n nísinsin yìí, nípa ti àjíǹde òkú, tàbí ẹ̀yin kò mọ̀ pé Ọlọ́run ń bá yín sọ̀rọ̀ nígbà ti ó wí pé:\wj* 
\v 32 \wj ‘Èmi ni Ọlọ́run Abrahamu, Ọlọ́run Isaaki, àti Ọlọ́run Jakọbu.’ Ọlọ́run kì í ṣe Ọlọ́run òkú, ṣùgbọ́n tí àwọn alààyè.”\wj* 
\p  
\v 33       Nígbà ti àwọn ènìyàn gbọ́ èyí ẹnu yà wọ́n sí ẹ̀kọ́ rẹ. 
\s1 Òfin tí ó ga jùlọ 
\p  
\v 34       Nígbà ti wọ́n sì gbọ́ pé ó ti pa àwọn Sadusi lẹ́nu mọ́, àwọn Farisi pé ara wọn jọ.  
\v 35  Ọ̀kan nínú wọn tí ṣe amòfin dán an wò pẹ̀lú ìbéèrè yìí.  
\v 36 Ó wí pé, “Olùkọ́ èwo ni ó ga jùlọ nínú àwọn òfin?” 
\p  
\v 37       Jesu dáhùn pé, \wj “ ‘Fẹ́ Olúwa Ọlọ́run rẹ pẹ̀lú gbogbo ọkàn rẹ, gbogbo ẹ̀mí rẹ àti gbogbo inú rẹ.\wj*’  
\v 38 \wj Èyí ni òfin àkọ́kọ́ àti èyí tí ó tóbi jùlọ.\wj* 
\v 39 \wj Èkejì tí ó tún dàbí rẹ̀ ní pé, ‘Fẹ́ràn ọmọnìkejì rẹ gẹ́gẹ́ bí ara rẹ.’\wj* 
\v 40 \wj Lórí àwọn òfin méjèèjì yìí ni gbogbo òfin àti àwọn wòlíì rọ̀ mọ́.”\wj* 
\s1 Ọmọ ta ni Kristi? 
\p  
\v 41       Bí àwọn Farisi ti kó ara wọn jọ, Jesu béèrè lọ́wọ́ wọn pé,  
\v 42 \wj “Kí ni ẹ rò nípa Kristi? Ọmọ ta ni òun ń ṣe?”\wj* 
\p Wọ́n dáhùn pé, “Ọmọ Dafidi.” 
\p  
\v 43 Ó sì wí fún wọn pé, \wj “Kí lo dé tí Dafidi, tí ẹ̀mí ń darí, pè é ní ‘Olúwa’? Nítorí ó wí pé,\wj* 
\q1  
\v 44 \wj “ ‘Olúwa sọ fún Olúwa mi pé,\wj* 
\q2 \wj “Jókòó ní ọwọ́ ọ̀tún mi\wj* 
\q1 \wj títí tí èmi yóò fi fi àwọn ọ̀tá rẹ\wj* 
\q2 \wj sí abẹ́ ẹsẹ̀ rẹ.” ’\wj* 
\m  
\v 45 \wj Ǹjẹ́ bí Dafidi bá pè é ni ‘Olúwa,’ báwo ni òun ṣe lè jẹ́ ọmọ rẹ̀?”\wj* 
\v 46  Kò sí ẹnìkan tí ó lè sọ ọ̀rọ̀ kan ni ìdáhùn, kò tún sí ẹni tí ó tún bí i léèrè ohun kan mọ́ láti ọjọ́ náà mọ́. 
\c 23  
\s1 Ìdí méje fún ìdájọ́ 
\p  
\v 1 Nígbà náà ni Jesu wí fún ọ̀pọ̀ ènìyàn àti àwọn ọmọ-ẹ̀yìn rẹ̀ pé,  
\v 2 \wj “Àwọn olùkọ́ òfin àti àwọn Farisi jókòó ní ipò Mose,\wj* 
\v 3 \wj nítorí náà, ẹ gbọdọ̀ gbọ́ tiwọn, kí ẹ sì ṣe ohun gbogbo tí wọ́n bá sọ fún yín. Ṣùgbọ́n ẹ má ṣe ohun tí wọ́n ṣe, nítorí àwọn pàápàá kì í ṣe ohun tí wọn kọ́ yín láti ṣe.\wj* 
\v 4 \wj Wọ́n á di ẹrù wúwo tí ó sì ṣòro láti rù, wọ́n a sì gbé e le àwọn ènìyàn léjìká, ṣùgbọ́n àwọn tìkára wọn kò jẹ́ fi ìka wọn kan an.\wj* 
\p  
\v 5 \wj “Ohun gbogbo tí wọ́n ń ṣe, wọ́n ń ṣe é kí àwọn ènìyàn ba à lè rí wọn ni. Wọ́n ń sọ filakteri wọn di gbígbòòrò. Wọ́n tilẹ̀ ń bùkún ìṣẹ́tí aṣọ oyè wọn nígbà gbogbo kí ó ba à lè máa tóbi sí i.\wj* 
\v 6 \wj Wọ́n fẹ́ ipò ọlá ní ibi àsè, àti níbi ìjókòó ìyàsọ́tọ̀ ni Sinagọgu.\wj* 
\v 7 \wj Wọ́n fẹ́ kí ènìyàn máa kí wọn ní ọjà, kí àwọn ènìyàn máa pè wọ́n ní ‘Rabbi.’\wj* 
\p  
\v 8 \wj “Ṣùgbọ́n kí a má ṣe pè yín ni Rabbi, nítorí pé ẹnìkan ni Olùkọ́ yín, àní Kristi, ará sì ni gbogbo yín.\wj* 
\v 9 \wj Ẹ má ṣe pe ẹnikẹ́ni ní baba yín ni ayé yìí, nítorí baba kan náà ni ẹ ní tí ó ń bẹ ní ọ̀run.\wj* 
\v 10 \wj Kí a má sì ṣe pè yín ní Olùkọ́ nítorí Olùkọ́ kan ṣoṣo ni ẹ̀yin ní, òun náà ni Kristi.\wj* 
\v 11 \wj Ṣùgbọ́n ẹni tí ó bá pọ̀jù nínú yín, ni yóò jẹ́ ìránṣẹ́ yín.\wj* 
\v 12 \wj Ṣùgbọ́n ẹnikẹ́ni tí ó bá gbé ara rẹ̀ ga ni a ó sì rẹ̀ sílẹ̀, ẹnikẹ́ni tí ó bá sì rẹ ara wọn sílẹ̀ ni a ó gbéga.\wj* 
\p  
\v 13 \wj “Ègbé ni fún yín, ẹ̀yin olùkọ́ òfin àti Farisi, ẹ̀yin àgàbàgebè! Ẹ̀yin sé ìjọba ọ̀run mọ́ àwọn ènìyàn nítorí ẹ̀yin tìkára yín kò wọlé, bẹ́ẹ̀ ni ẹ̀yin kò jẹ́ kí àwọn tí ó fẹ́ wọlé ó wọlé.\wj*\f + \fr 23:13 \ft Àwọn àkọsílẹ̀ àtijọ́ kan se àfikún ọ̀rọ̀ yìí \fqa wọlé. \fv 14 \fv*\fqa Ègbé ni fún yín, ẹ̀yin olùkọ́ òfin àti Farisi, ẹ̀yin àgàbàgebè! Àwọn tí wọ́n jẹ ilé àwọn opó rún, tí wọ́n sì ń gbàdúrà gígùn fún àṣehàn, nítorí èyí, ìjìyà wọn yóò pọ̀ púpọ̀\ft .\f* 
\p  
\v 15 \wj “Ègbé ni fún yín, ẹ̀yin olùkọ́ òfin àti Farisi, ẹ̀yin àgàbàgebè! Nítorí ẹ̀yin rin yí ilẹ̀ àti òkun ká láti yí ẹnìkan lọ́kàn padà, ṣùgbọ́n ẹ̀yin ń sọ ọ́ di ọmọ ọ̀run àpáàdì ní ìlọ́po méjì ju ẹ̀yin pàápàá.\wj* 
\p  
\v 16 \wj “Ègbé ni fún yín, ẹ̀yin afọ́jú ti ń fi ọ̀nà han afọ́jú! Tí ó wí pé, ‘Ẹnikẹ́ni tí ó ba fi tẹmpili búra kò sí nǹkan kan, ṣùgbọ́n bí ẹnikẹ́ni bá fi wúrà inú tẹmpili búra, ó di ajigbèsè.’\wj* 
\v 17 \wj Ẹ̀yin aláìmòye afọ́jú: èwo ni ó ga jù, wúrà tàbí tẹmpili tí ó ń sọ wúrà di mímọ́?\wj* 
\v 18 \wj Àti pé, ẹnikẹ́ni tó bá fi pẹpẹ búra, kò jámọ́ nǹkan, ṣùgbọ́n bí ẹnikẹ́ni tí ó ba fi ẹ̀bùn tí ó wà lórí rẹ̀ búra, ó di ajigbèsè.\wj* 
\v 19 \wj Ẹ̀yin aláìmòye afọ́jú wọ̀nyí! Èwo ni ó pọ̀jù: ẹ̀bùn tí ó wà lórí pẹpẹ ni tàbí pẹpẹ fúnra rẹ̀ tí ó sọ ẹ̀bùn náà di mímọ́?\wj* 
\v 20 \wj Nítorí náà ẹnikẹ́ni tí ó bá ń fi pẹpẹ búra, ó fi í búra àti gbogbo ohun tí ó wà lórí rẹ̀.\wj* 
\v 21 \wj Àti pé, ẹni tí ó bá fi tẹmpili búra, ó fi í búra àti ẹni tí ń gbé inú rẹ̀.\wj* 
\v 22 \wj Àti pé, ẹni tí ó bá sì fi ọ̀run búra, ó fi ìtẹ́ Ọlọ́run àti ẹni tí ó jókòó lórí rẹ̀ búra.\wj* 
\p  
\v 23 \wj “Ègbé ni fún yín ẹ̀yin olùkọ́ òfin àti Farisi, ẹ̀yin àgàbàgebè! Nítorí ẹ̀yin ń gba ìdámẹ́wàá minti, dili àti kumini, ẹ̀yin sì ti fi ohun tí ó ṣe pàtàkì jùlọ nínú òfin sílẹ̀ láìṣe, ìdájọ́, àánú àti ìgbàgbọ́. Wọ̀nyí ni ó tọ́ tí ẹ̀yin ìbá ṣe, ẹ̀yin kò bá fi wọ̀n-ọn-nì sílẹ̀ láìṣe.\wj* 
\v 24 \wj Ẹ̀yin afọ́jú tó ń fi afọ́jú mọ̀nà! Ẹ tu kòkòrò-kantíkantí tó bọ́ sì yín lẹ́nu nù, ẹ gbé ìbákasẹ mì.\wj* 
\p  
\v 25 \wj “Ègbé ni fún yín ẹ̀yin Farisi àti ẹ̀yin olùkọ́ òfin, ẹ̀yin àgàbàgebè. Ẹ̀yin ń fọ òde ago àti àwo ṣùgbọ́n inú rẹ̀ kún fún ìrẹ́jẹ àti ẹ̀gbin gbogbo.\wj* 
\v 26 \wj Ìwọ afọ́jú Farisi, tètè kọ́ fọ inú ago àti àwo, gbogbo ago náà yóò sì di mímọ́.\wj* 
\p  
\v 27 \wj “Ègbé ni fún yín ẹ̀yin Farisi àti ẹ̀yin olùkọ́ òfin, ẹ̀yin àgàbàgebè. Ẹ dàbí ibojì funfun tí ó dára ní wíwò, ṣùgbọ́n tí ó kún fún egungun ènìyàn àti fún ẹ̀gbin àti ìbàjẹ́.\wj* 
\v 28 \wj Ẹ̀yin gbìyànjú láti farahàn bí ènìyàn mímọ́, olódodo, lábẹ́ aṣọ mímọ́ yín ni ọkàn tí ó kún fún ìbàjẹ́ pẹ̀lú oríṣìíríṣìí àgàbàgebè àti ẹ̀ṣẹ̀ wà.\wj* 
\p  
\v 29 \wj “Ègbé ni fún yín ẹ̀yin olùkọ́ òfin àti Farisi, ẹ̀yin àgàbàgebè, nítorí ẹ̀yin kọ́ ibojì àwọn wòlíì tí í ṣe ibojì àwọn olódodo ní ọ̀ṣọ́.\wj* 
\v 30 \wj Ẹ̀yin sì wí pé, ‘Àwa ìbá wà ní àsìkò àwọn baba wa, àwa kì bá ní ọwọ́ nínú ẹ̀jẹ̀ àwọn wòlíì’.\wj* 
\v 31 \wj Ǹjẹ́ ẹ̀yin ni ẹlẹ́rìí fún ara yín pé, ẹ̀yin ni ọmọ àwọn tí ó pa àwọn wòlíì.\wj* 
\v 32 \wj Àti pé, ẹ̀yin ń tẹ̀lé ìṣísẹ̀ àwọn baba yín. Ẹ̀yin ń kún òsùwọ̀n ìwà búburú wọn dé òkè.\wj* 
\p  
\v 33 \wj “Ẹ̀yin ejò! Ẹ̀yin paramọ́lẹ̀! Ẹ̀yin yóò ti ṣe yọ nínú ẹ̀bi ọ̀run àpáàdì?\wj* 
\v 34 \wj Nítorí náà èmi yóò rán àwọn wòlíì àti àwọn ọlọ́gbọ́n ọkùnrin tí ó kún fún ẹ̀mí mímọ́, àti àwọn akọ̀wé sí yín. Ẹ̀yin yóò pa àwọn kan nínú wọn nípa kíkàn wọ́n mọ́ àgbélébùú. Ẹ̀yin yóò fi pàṣán na àwọn ẹlòmíràn nínú Sinagọgu yín, tí ẹ̀yin yóò sì ṣe inúnibíni sí wọn láti ìlú dé ìlú.\wj* 
\v 35 \wj Kí ẹ̀yin lè jẹ̀bi gbogbo ẹ̀jẹ̀ àwọn olódodo tí ẹ ta sílẹ̀ ní ayé, láti ẹ̀jẹ̀ Abeli títí dé ẹ̀jẹ̀ Sekariah ọmọ Berekiah ẹni tí ẹ pa nínú tẹmpili láàrín ibi pẹpẹ àti ibi ti ẹ yà sí mímọ́ fún Ọlọ́run.\wj* 
\v 36 \wj Lóòótọ́ ni mo wí fún yín, gbogbo nǹkan wọ̀nyí yóò wà sórí ìran yìí.\wj* 
\p  
\v 37 \wj “Jerusalẹmu, Jerusalẹmu, ìlú tí ó pa àwọn wòlíì, tí ó sì sọ òkúta lu àwọn tí a rán sí i. Ọ̀pọ̀ ìgbà ni èmi tí ń fẹ́ kó àwọn ọmọ rẹ jọ pọ̀ gẹ́gẹ́ bí àgbébọ̀ adìyẹ ti í dáàbò bo àwọn ọmọ rẹ̀ lábẹ́ ìyẹ́ rẹ, ṣùgbọ́n ẹ̀yin kọ̀.\wj* 
\v 38 \wj Wò ó, a fi ilé yín sílẹ̀ fún yín ní ahoro.\wj* 
\v 39 \wj Nítorí èmi sọ èyí fún yín, ẹ̀yin kì yóò rí mi mọ́, títí ẹ̀yin yóò fi sọ pé, ‘Olùbùkún ni ẹni tó ń bọ̀ ní orúkọ Olúwa.’ ”\wj* 
\c 24  
\s1 Àwọn àmì òpin ayé 
\p  
\v 1       Bí Jesu ti ń kúrò ni tẹmpili, àwọn ọmọ-ẹ̀yìn rẹ̀ tọ̀ ọ́ wá, wọ́n fẹ́ fi ẹwà tẹmpili náà hàn án.  
\v 2  Ṣùgbọ́n ó wí fún wọn pé, \wj “Ẹ̀yin kò ha rí gbogbo nǹkan wọ̀nyí? Lóòótọ́ ni mo wí fún yín gbogbo ilé yìí ni a yóò wó lulẹ̀, kò ní sí òkúta kan tí a ó fi sílẹ̀ lórí òmíràn, tí a kì yóò wó lulẹ̀.”\wj* 
\p  
\v 3       Bí ó ti jókòó ní orí òkè Olifi, àwọn ọmọ-ẹ̀yìn tọ̀ ọ́ wá ní ìkọ̀kọ̀, wọ́n wí pé, “Sọ fún wa nígbà wo ni èyí yóò ṣẹlẹ̀? Kí ni yóò jẹ́ àmì ìpadà wá rẹ, àti ti òpin ayé?” 
\p  
\v 4 Jesu dá wọn lóhùn pé, \wj “Ẹ má ṣe jẹ́ kí ẹnikẹ́ni tàn yín jẹ.\wj* 
\v 5 \wj Nítorí ọ̀pọ̀ yóò wá ní orúkọ mi tí wọn yóò máa pe ara wọn ní Kristi náà. Wọn yóò ṣi ọ̀pọ̀lọpọ̀ lọ́nà.\wj* 
\v 6 \wj Ẹ ó máa gbọ́ ìró ogun àti ìdágìrì ogun, kí ẹ̀yin má ṣe jáyà nítorí nǹkan wọ̀nyí kò lè ṣe kí ó ma ṣẹlẹ̀, ṣùgbọ́n òpin kì í ṣe àkókò náà.\wj* 
\v 7 \wj Orílẹ̀-èdè yóò dìde sí orílẹ̀-èdè, àti ìjọba sí ìjọba. Ìyàn àti ilẹ̀ mímì yóò wà ní ibi púpọ̀.\wj* 
\v 8 \wj Ṣùgbọ́n gbogbo nǹkan wọ̀nyí sì jẹ́ ìbẹ̀rẹ̀ ìpọ́njú tí ó ń bọ̀.\wj* 
\p  
\v 9 \wj “Nígbà náà ni a ó sì dá a yín lóró. A ó pa yín, a ó sì kórìíra yín ni gbogbo orílẹ̀-èdè, nítorí pé ẹ̀yin jẹ́ tèmi.\wj* 
\v 10 \wj Àti pé, ọ̀pọ̀ nínú yín yóò kọsẹ̀, ẹ̀yin yóò ṣòfófó ara yín, ẹ̀yin yóò kórìíra ara yín pẹ̀lú,\wj* 
\v 11 \wj ọ̀pọ̀ àwọn èké wòlíì yóò farahàn, wọn yóò tan ọ̀pọ̀lọpọ̀ ènìyàn jẹ.\wj* 
\v 12 \wj Ẹ̀ṣẹ̀ yóò wà níbi gbogbo, yóò sì sọ ìfẹ́ ọ̀pọ̀ di tútù,\wj* 
\v 13 \wj ṣùgbọ́n ẹni tí ó bá forítì í dópin ni a ó gbàlà.\wj* 
\v 14 \wj A ó sì wàásù ìyìnrere nípa ìjọba náà yìí ní gbogbo ayé ká, láti ṣe ẹ̀rí fún gbogbo orílẹ̀-èdè, nígbà náà ni òpin yóò dé.\wj* 
\p  
\v 15 \wj “Nítorí náà, nígbà tí ẹ̀yin bá rí ìríra ‘ìsọdahoro, tí a ti ẹnu wòlíì Daniẹli sọ,’ tí ó bá dúró ní ibi mímọ́ (ẹnikẹ́ni tí ó bá kà á kí ó yé e),\wj* 
\v 16 \wj nígbà náà ni kí àwọn tí ń bẹ ni Judea sálọ sí orí òkè.\wj* 
\v 17 \wj Kí ẹni tí ó wà lórí ilé rẹ̀ má ṣe sọ̀kalẹ̀ wá mú ohunkóhun jáde nínú ilé rẹ̀.\wj* 
\v 18 \wj Kí àwọn tí ó sì wà lóko má ṣe darí wá sí ilé láti mú àwọn aṣọ wọn.\wj* 
\v 19 \wj Ṣùgbọ́n àánú ṣe mí fún àwọn obìnrin ti ó lóyún, àti fún àwọn tí ó ń fún ọmọ loyan ní ọjọ́ wọ̀n-ọn-nì!\wj* 
\v 20 \wj Ẹ sì máa gbàdúrà kí sísá yín má ṣe jẹ́ ìgbà òtútù, tàbí ọjọ́ ìsinmi.\wj* 
\v 21 \wj Nítorí ìpọ́njú ńlá yóò wà, irú èyí tí kò tí ì ṣẹlẹ̀ láti ìgbà ìbẹ̀rẹ̀ ọjọ́ ayé wá títí di ìsinsin yìí irú rẹ̀ kì yóò sì ṣí.\wj* 
\p  
\v 22 \wj “Lóòótọ́, àfi bí a ké ọjọ́ wọ̀n-ọn-nì kúrú, gbogbo ẹ̀dá alààyè yóò ṣègbé. Ṣùgbọ́n nítorí ti àwọn àyànfẹ́ ni a ó fi ké ọjọ́ wọ̀n-ọn-nì kúrú.\wj* 
\v 23 \wj Nígbà náà, bí ẹnikẹ́ni bá sọ fún yín pé, ‘Wo Kristi náà,’ tàbí pé ó ti farahàn níhìn-ín tàbí lọ́hùn ún, ẹ má ṣe gbà á gbọ́.\wj* 
\v 24 \wj Nítorí àwọn èké Kristi àti àwọn èké wòlíì yóò dìde. Wọn yóò sì ṣe ọ̀pọ̀ iṣẹ́ àmì àti ìyanu. Bí ó bá lè ṣe é ṣe wọn yóò tan àwọn àyànfẹ́ Ọlọ́run pàápàá jẹ.\wj* 
\v 25 \wj Wò ó, mo ti kìlọ̀ fún yín tẹ́lẹ̀.\wj* 
\p  
\v 26 \wj “Nítorí náà, bí ẹnìkan bá sọ fún yín pé, ‘Olùgbàlà ti dé,’ àti pé, ‘Ó wà ní aginjù,’ ẹ má ṣe wàhálà láti lọ wò ó, tàbí tí wọ́n bá ní, ó ń fi ara pamọ́ sí iyàrá,” ẹ má ṣe gbà wọn gbọ́.\wj* 
\v 27 \wj Nítorí bí mọ̀nàmọ́ná ti ń tàn láti ìlà-oòrùn títí dé ìwọ̀-oòrùn, bẹ́ẹ̀ ni wíwá Ọmọ Ènìyàn yóò jẹ́.\wj* 
\v 28 \wj Nítorí ibikíbi tí òkú bá gbé wà, ibẹ̀ ni àwọn ẹyẹ igún ń kójọpọ̀ sí.\wj* 
\p  
\v 29 \wj “Lójúkan náà, lẹ́yìn ìpọ́njú ọjọ́ wọ̀n-ọn-nì,\wj* 
\q1 \wj “ ‘ni oòrùn yóò ṣókùnkùn,\wj* 
\q2 \wj òṣùpá kì yóò sì fi ìmọ́lẹ̀ rẹ hàn;\wj* 
\q1 \wj àwọn ìràwọ̀ ojú ọ̀run yóò já sílẹ̀,\wj* 
\q2 \wj agbára ojú ọ̀run ni a ó mì tìtì.’\wj* 
\p  
\v 30 \wj “Nígbà náà ni àmì Ọmọ Ènìyàn yóò sì fi ara hàn ní ọ̀run, nígbà náà ni gbogbo ẹ̀yà ayé yóò káàánú, wọn yóò sì rí Ọmọ Ènìyàn tí yóò máa ti ojú ọ̀run bọ̀ ti òun ti ògo àti agbára ńlá.\wj* 
\v 31 \wj Yóò sì rán àwọn angẹli rẹ̀ jáde pẹ̀lú ohùn ìpè ńlá, wọn yóò sì kó gbogbo àwọn àyànfẹ́ rẹ̀ láti orígun mẹ́rẹ̀ẹ̀rin ayé àti ọ̀run jọ.\wj* 
\p  
\v 32 \wj “Nísinsin yìí, ẹ kọ́ òwe lára igi ọ̀pọ̀tọ́. Nígbà tí ẹ̀ka rẹ̀ bá ti ń yọ tuntun tí ó bá sì ń ru ewé, ẹ̀yin mọ̀ pé ìgbà ẹ̀ẹ̀rùn súnmọ́ tòsí.\wj* 
\v 33 \wj Bẹ́ẹ̀ gẹ́gẹ́, nígbà tí ẹ̀yin bá sì rí i tí gbogbo nǹkan wọ̀nyí bá ń ṣẹlẹ̀, kí ẹ mọ̀ pé ìpadàbọ̀ mi dé tán lẹ́yìn ìlẹ̀kùn.\wj* 
\v 34 \wj Lóòótọ́ ni mo wí fún yín, ìran yìí kì yóò kọjá títí tí gbogbo nǹkan wọ̀nyí yóò fi ṣẹ.\wj* 
\v 35 \wj Ọ̀run àti ayé yóò rékọjá, ṣùgbọ́n ọ̀rọ̀ mi kì yóò rékọjá.\wj* 
\s1 A kò mọ ọjọ́ tàbí wákàtí náà 
\p  
\v 36 \wj “Ṣùgbọ́n kò sí ẹnìkan ti ó mọ ọjọ́ àti wákàtí tí òpin náà yóò dé, àwọn angẹli ọ̀run pàápàá kò mọ̀ ọ́n. Àní, ọmọ kò mọ̀ ọ́n, bí kò ṣe Baba mi nìkan ṣoṣo ló mọ̀ ọ́n.\wj* 
\v 37 \wj Bí ó ṣe rí ní ìgbà ayé Noa, bẹ́ẹ̀ gẹ́gẹ́ ni wíwá Ọmọ Ènìyàn yóò sì rí.\wj* 
\v 38 \wj Nítorí bí àwọn ọjọ́ náà ti wà ṣáájú ìkún omi, tí wọ́n ń jẹ́ tí wọ́n ń mu, tí wọ́n ń gbéyàwó, tí wọ́n sì ń fa ìyàwó fún ni, títí tí ó fi di ọjọ́ tí Noa fi bọ́ sínú ọkọ̀.\wj* 
\v 39 \wj Ènìyàn kò gbàgbọ́ nípa ohun tí o ṣẹlẹ̀ títí tí ìkún omi fi dé nítòótọ́, tí ó sì kó wọn lọ. Bẹ́ẹ̀ gẹ́gẹ́ ni wíwá Ọmọ Ènìyàn.\wj* 
\v 40 \wj Àwọn ọkùnrin méjì yóò máa ṣiṣẹ́ nínú oko, a o mú ẹnìkan, a ó sì fi ẹni kejì sílẹ̀.\wj* 
\v 41 \wj Àwọn obìnrin méjì yóò jùmọ̀ máa lọ ọlọ pọ̀, a yóò mú ọ̀kan, a ó fi ẹni kejì sílẹ̀.\wj* 
\p  
\v 42 \wj “Nítorí náà, ẹ múra sílẹ̀, nítorí ẹ kò mọ ọjọ́ tí Olúwa yín yóò dé.\wj* 
\v 43 \wj Ṣùgbọ́n, kí ẹ mọ èyí pé, baálé ilé ìbá mọ wákàtí náà tí olè yóò wá, ìbá máa ṣọ́nà, òun kì bá ti jẹ́ kí a já wọ ilé rẹ̀.\wj* 
\v 44 \wj Nítorí náà, ẹ gbọdọ̀ wà ní ìmúrasílẹ̀, nítorí ní wákàtí àìròtẹ́lẹ̀ ni dídé Ọmọ Ènìyàn yóò jẹ́.\wj* 
\p  
\v 45 \wj “Ǹjẹ́ olóòtítọ́ àti ọlọ́gbọ́n ọmọ ọ̀dọ̀ wo ni olúwa rẹ̀ lè fi ṣe olùbojútó ilé rẹ̀ láti bọ́ àwọn ọmọ rẹ̀ lójoojúmọ́?\wj* 
\v 46 \wj Alábùkún fún ni ọmọ ọ̀dọ̀ ti olúwa rẹ̀ dé tí ó sì bá a lórí iṣẹ́ ṣíṣe.\wj* 
\v 47 \wj Lóòótọ́ ni mo wí fún yín, èmi yóò sì fi irú ẹni bẹ́ẹ̀ ṣe alákòóso gbogbo ohun tí mo ní.\wj* 
\v 48 \wj Ṣùgbọ́n bí ọmọ ọ̀dọ̀ náà bá jẹ́ ènìyàn búburú náà bá wí ní ọkàn rẹ̀ pé, ‘Olúwa mi kì yóò tètè dé.’\wj* 
\v 49 \wj Tí ó sì bẹ̀rẹ̀ si í fi ìyà jẹ́ àwọn ìránṣẹ́ ẹlẹgbẹ́ rẹ̀, tí ó ń jẹ, tí ó sì ń mu àmupara.\wj* 
\v 50 \wj Nígbà náà ni olúwa ọmọ ọ̀dọ̀ yóò wá ní ọjọ́ àti wákàtí tí kò retí.\wj* 
\v 51 \wj Yóò sì jẹ ẹ́ ní ìyà gidigidi, yóò sì rán an sí ibùgbé àwọn àgàbàgebè, níbẹ̀ ni ẹkún àti ìpayínkeke yóò wà.\wj* 
\c 25  
\s1 Òwe àwọn wúńdíá mẹ́wàá 
\p  
\v 1 \wj “Nígbà náà ni ó fi ìjọba ọ̀run wé àwọn wúńdíá mẹ́wàá. Ti wọ́n gbé fìtílà wọn láti lọ pàdé ọkọ ìyàwó.\wj* 
\v 2 \wj Márùn-ún nínú wọn jẹ́ ọlọ́gbọ́n, márùn-ún nínú wọn ni wọ́n jẹ́ aláìgbọ́n.\wj* 
\v 3 \wj Àwọn tí wọ́n jẹ́ aláìgbọ́n gbé fìtílà wọn ṣùgbọ́n wọn kò mú epo kankan lọ́wọ́.\wj* 
\v 4 \wj Àwọn ọlọ́gbọ́n mú epo sínú kólòbó lọ́wọ́ pẹ̀lú fìtílà wọn.\wj* 
\v 5 \wj Nígbà tí ọkọ ìyàwó pẹ́, gbogbo wọn tòògbé wọn sì sùn.\wj* 
\p  
\v 6 \wj “Nígbà tí ó di ọ̀gànjọ́, igbe ta sókè, ‘Wò ó, ọkọ ìyàwó ń bọ̀, ẹ jáde sóde láti pàdé rẹ̀.’\wj* 
\p  
\v 7 \wj “Nígbà náà ni àwọn wúńdíá sì tají, wọ́n tún fìtílà wọn ṣe.\wj* 
\v 8 \wj Àwọn aláìgbọ́n márùn-ún tí kò ní epo rárá bẹ àwọn ọlọ́gbọ́n pé kí wọn fún àwọn nínú èyí tí wọ́n ní nítorí fìtílà wọn ń kú lọ.\wj* 
\p  
\v 9 \wj “Ṣùgbọ́n àwọn ọlọ́gbọ́n márùn-ún dáhùn pé, bẹ́ẹ̀ kọ́; kí ó má ba à ṣe aláìtó fún àwa àti ẹ̀yin, ẹ kúkú tọ àwọn tí ń tà á lọ, kí ẹ sì rà fún ara yín.\wj* 
\p  
\v 10 \wj “Ní àsìkò tí wọ́n lọ ra epo tiwọn, ni ọkọ ìyàwó dé. Àwọn wúńdíá tí ó múra tán bá a wọlé sí ibi àsè ìgbéyàwó, lẹ́yìn náà, a sì ti ìlẹ̀kùn.\wj* 
\p  
\v 11 \wj “Ní ìkẹyìn ni àwọn wúńdíá márùn-ún ìyókù dé, wọ́n ń wí pé, ‘Olúwa, Olúwa, ṣílẹ̀kùn fún wa.’\wj* 
\p  
\v 12 \wj “Ṣùgbọ́n ọkọ ìyàwó dáhùn pé, ‘Lóòótọ́ ni mo wí fún yín èmi kò mọ̀ yín rí.’\wj* 
\p  
\v 13 \wj “Nítorí náà, ẹ máa ṣọ́nà. Nítorí pé ẹ̀yin kò mọ ọjọ́ tàbí wákàtí tí Ọmọ Ènìyàn yóò dé.\wj* 
\s1 Òwe tálẹ́ǹtì 
\p  
\v 14 \wj “A sì tún fi ìjọba ọ̀run wé ọkùnrin kan tí ó ń lọ sí ìrìnàjò. Ó pe àwọn ọmọ ọ̀dọ̀ rẹ̀, ó sì kó ohun ìní rẹ̀ fún wọn.\wj* 
\v 15 \wj Ó fún ọ̀kan ni tálẹ́ǹtì márùn-ún, ó fún èkejì ni tálẹ́ǹtì méjì, ó sì fún ẹ̀kẹta ni tálẹ́ǹtì kan, ó fún olúkúlùkù gẹ́gẹ́ bí agbára rẹ̀ ti mọ, ó sì lọ ìrìnàjò tirẹ̀.\wj* 
\v 16 \wj Ọkùnrin tí ó gba tálẹ́ǹtì márùn-ún bẹ̀rẹ̀ lẹ́sẹ̀kẹsẹ̀ láti fi owó náà ṣòwò. Láìpẹ́, ó sì jèrè márùn-ún mìíràn.\wj* 
\v 17 \wj Ọkùnrin tí ó gba tálẹ́ǹtì méjì náà fi tirẹ̀ ṣòwò. Láìpẹ́, ó sì jèrè tálẹ́ǹtì méjì mìíràn.\wj* 
\v 18 \wj Ṣùgbọ́n ọkùnrin tí ò gba tálẹ́ǹtì kan, ó wa ihò ní ilẹ̀, ó sì bo owó ọ̀gá mọ́ ibẹ̀.\wj* 
\p  
\v 19 \wj “Lẹ́yìn ọjọ́ pípẹ́, olúwa àwọn ọmọ ọ̀dọ̀ dé láti àjò rẹ̀. Ó pè wọ́n jọ láti bá wọn ṣírò owó rẹ̀.\wj* 
\v 20 \wj Ọkùnrin tí ó gba tálẹ́ǹtì márùn-ún, mú márùn-ún mìíràn padà wá, ó wí pé, ‘Olúwa, ìwọ ti fi tálẹ́ǹtì márùn-ún fún mi, mo sì ti jèrè márùn-ún mìíràn pẹ̀lú rẹ̀.’\wj* 
\p  
\v 21 \wj “Olúwa rẹ̀ wí fún un pé, ‘O ṣeun ìwọ ọmọ ọ̀dọ̀ rere àti olóòtítọ́: ìwọ ṣe olóòtítọ́ nínú ohun díẹ̀, èmi yóò fi ọ́ ṣe olórí ohun púpọ̀, bọ́ sínú ayọ̀ olúwa rẹ.’\wj* 
\p  
\v 22 \wj “Èyí tí ó gba tálẹ́ǹtì méjì wí pé ‘Olúwa, ìwọ fún mi ní tálẹ́ǹtì méjì láti lò, èmi sì ti jèrè tálẹ́ǹtì méjì mìíràn.’\wj* 
\p  
\v 23 \wj “Olúwa rẹ̀ sì wí fún un pé, ‘O ṣeun, ìwọ ọmọ ọ̀dọ̀ rere àti olóòtítọ́. Ìwọ ti jẹ́ olóòtítọ́ nínú ohun díẹ̀, èmi yóò fi ọ ṣe olórí ohun púpọ̀. Ìwọ bọ́ sínú ayọ̀ olúwa rẹ.’\wj* 
\p  
\v 24 \wj “Níkẹyìn, ọkùnrin tí a fún ní tálẹ́ǹtì kan wá, ó wí pé, ‘Olúwa, mo mọ̀ pé òǹrorò ènìyàn ni ìwọ ń ṣe ìwọ ń kórè níbi tí ìwọ kò gbìn sí, ìwọ ń kójọ níbi tí ìwọ kò ó ká sí.\wj* 
\v 25 \wj Èmi bẹ̀rù, mo sì lọ pa tálẹ́ǹtì rẹ mọ́ sínú ilẹ̀. Wò ó, nǹkan rẹ nìyìí.’\wj* 
\p  
\v 26 \wj “Ṣùgbọ́n olúwa rẹ̀ dáhùn pé, ‘Ìwọ ọmọ ọ̀dọ̀ búburú, ìwọ mọ̀ pé èmi ń kórè níbi tí èmi kò fúnrúgbìn sì, èmi sì ń kójọ níbi tí èmi kò fọ́nká ká sí.\wj* 
\v 27 \wj Nígbà náà ìwọ ìbá kúkú fi owó mi sí ilé ìfowópamọ́ tí èmi bá dé èmi ìbá le gba owó mi pẹ̀lú èrè.\wj* 
\p  
\v 28 \wj “ ‘Ó sì pàṣẹ kí a gba tálẹ́ǹtì náà lọ́wọ́ rẹ̀, kí a sì fún ọkùnrin tí ó ní tálẹ́ǹtì mẹ́wàá.\wj* 
\v 29 \wj Nítorí ẹnikẹ́ni tí ó bá ní a ó fún sí i, yóò sí tún ní sí lọ́pọ̀lọ́pọ̀. Ṣùgbọ́n láti ọwọ́ ẹni tí kò ní ni a ó ti gbà èyí tí ó ní.\wj* 
\v 30 \wj Nítorí ìdí èyí, gbé aláìlérè ọmọ ọ̀dọ̀, jù ú sínú òkùnkùn lóde, ibẹ̀ ni ẹ̀kún òun ìpayínkeke yóò gbé wà.’\wj* 
\s1 Àwọn àgùntàn àti ewúrẹ́ 
\p  
\v 31 \wj “Ṣùgbọ́n nígbà ti Ọmọ Ènìyàn yóò wá nínú ògo rẹ̀ pẹ̀lú gbogbo àwọn angẹli rẹ̀ nígbà náà ni yóò jókòó lórí ìtẹ́ ògo ní ọ̀run.\wj* 
\v 32 \wj Gbogbo orílẹ̀-èdè ni a ó kójọ níwájú rẹ̀, òun yóò sì ya àwọn ènìyàn ayé sí ọ̀tọ̀ gẹ́gẹ́ bí olùṣọ́-àgùntàn ṣe é ya àgùntàn kúrò lára àwọn ewúrẹ́.\wj* 
\v 33 \wj Òun yóò sì fi àgùntàn sí ọwọ́ ọ̀tún àti ewúrẹ́ sí ọwọ́ òsì.\wj* 
\p  
\v 34 \wj “Nígbà náà ni ọba yóò wí fún àwọn tí ó wà lọ́wọ́ ọ̀tún pé, ‘Ẹ wá, ẹ̀yin tí Baba mi ti bùkún fún, ẹ jogún ìjọba tí a ti pèsè fún yín láti ìpilẹ̀ṣẹ̀ ayé.\wj* 
\v 35 \wj Nítorí ebi pa mi, ẹ̀yin sì fún mi ní oúnjẹ, òǹgbẹ gbẹ mí, ẹ̀yin sì fún mi ní omi. Mo jẹ́ àlejò, ẹ̀yin sì pè mí sínú ilé yín.\wj* 
\v 36 \wj Mo wà ní ìhòhò, ẹ̀yin sì daṣọ bò mí. Nígbà tí mo ṣe àìsàn ẹ ṣe ìtójú mi, àti ìgbà tí mo wà ní ọgbà ẹ̀wọ̀n ẹ̀yin bẹ̀ mí wò.’\wj* 
\p  
\v 37 \wj “Nígbà náà ni àwọn olódodo yóò fèsì pé, ‘Olúwa, nígbà wo ni àwa rí ọ tí ebi ń pa ọ́, tí a sì fún ọ ní oúnjẹ? Tàbí tí òǹgbẹ ń gbẹ ọ́ tí a sì fún ọ ní ohun mímu?\wj* 
\v 38 \wj Tàbí tí o jẹ́ àlejò tí a gbà ó sínú ilé wa? Tàbí tí o wà ní ìhòhò, tí a sì daṣọ bò ọ́?\wj* 
\v 39 \wj Nígbà wo ni a tilẹ̀ rí i tí o ṣe àìsàn, tàbí tí o wà ní ọgbà ẹ̀wọ̀n, tí a bẹ̀ ọ́ wò?’\wj* 
\p  
\v 40 \wj “Ọba náà yóò sì dáhùn yóò sì wí fún wọn pé, ‘Lóòótọ́ ni mo wí fún yín pé níwọ̀n ìgbà tí ẹ̀yin ṣe nǹkan wọ̀nyí fún àwọn arákùnrin mi yìí tí o kéré jú lọ, ẹ̀ ń ṣe wọn fún mi ni.’\wj* 
\p  
\v 41 \wj “Nígbà náà ni yóò sọ fún àwọn tí ọwọ́ òsì pé, ‘Ẹ kúrò lọ́dọ̀ mi, ẹ̀yin ẹni ègún, sínú iná àìnípẹ̀kun tí a ti tọ́jú fún èṣù àti àwọn angẹli rẹ̀.\wj* 
\v 42 \wj Nítorí tí ebi pa mi, ẹ̀yin kò tilẹ̀ bọ́ mi, òrùngbẹ gbẹ mi, ẹ kò tilẹ̀ fún mi ní omi láti mu.\wj* 
\v 43 \wj Mo jẹ́ àlejò, ẹ̀yin kò tilẹ̀ gbà mi sílé. Mo wà ní ìhòhò, ẹ̀yin kò fi aṣọ bò mi. Mo ṣàìsàn, mo sì wà lọ́gbà ẹ̀wọ̀n, ẹ̀yin kò bẹ̀ mí wò.’\wj* 
\p  
\v 44 \wj “Nígbà náà àwọn pẹ̀lú yóò dáhùn pé, ‘Olúwa, nígbà wo ni àwa rí ọ, tí ebi ń pa ọ́ tàbí tí òǹgbẹ ń gbẹ ọ́, tàbí tí o ṣàìsàn, tàbí tí o wà lọ́gbà ẹ̀wọ̀n, tí a kò sí ràn ọ́ lọ́wọ́?’\wj* 
\p  
\v 45 \wj “Nígbà náà àwọn yóò dáhùn pé, ‘Lóòótọ́ ni mo wí fún pé, nígbà tí ẹ̀yin ti kọ̀ láti ran ọ̀kan nínú àwọn tí ó kéré jù lọ́wọ́ nínú arákùnrin mi, ẹ̀yin tí kọ̀ láti ṣe ìrànlọ́wọ́ fún mi ni.’\wj* 
\p  
\v 46 \wj “Nígbà náà wọn yóò sì kọjá lọ sínú ìyà àìnípẹ̀kun, ṣùgbọ́n àwọn olódodo yóò lọ sí ìyè àìnípẹ̀kun.”\wj* 
\c 26  
\s1 Ìdìtẹ̀ mọ́ Jesu 
\p  
\v 1       Nígbà tí Jesu ti parí ọ̀rọ̀ wọ̀nyí pẹ̀lú àwọn ọmọ-ẹ̀yìn rẹ̀, ó wí fún wọn pé,  
\v 2 \wj “Bí ẹ̀yin tí mọ̀ ní ọjọ́ méjì sí i, àjọ ìrékọjá yóò bẹ̀rẹ̀. Àti pé, a ó fi Ọmọ Ènìyàn lé wọn lọ́wọ́, a ó sì kàn mí mọ́ àgbélébùú.”\wj* 
\p  
\v 3 Ní àsìkò tí Jesu ń sọ̀rọ̀ yìí, àwọn olórí àlùfáà àti àwọn àgbàgbà kó ara wọn jọ ní ààfin olórí àlùfáà náà tí à ń pè ní Kaiafa.  
\v 4 Láti gbèrò àwọn ọ̀nà tí wọ́n yóò fi mú Jesu pẹ̀lú ẹ̀tàn, kí wọn sì pa á.  
\v 5 Ṣùgbọ́n wọ́n fohùn ṣọ̀kan pé, “Kì í ṣe lásìkò àsè àjọ ìrékọjá, nítorí rògbòdìyàn yóò ṣẹlẹ̀.” 
\s1 A fi òróró kun Jesu lára ní Betani 
\p  
\v 6       Nígbà tí Jesu wà ní Betani ní ilé ọkùnrin tí à ń pè ní Simoni adẹ́tẹ̀.  
\v 7 Bí ó ti ń jẹun, obìnrin kan wá sọ́dọ̀ rẹ̀ pẹ̀lú alabasita òróró ìkunra iyebíye, ó sì dà á sí i lórí. 
\p  
\v 8 Nígbà tí àwọn ọmọ-ẹ̀yìn rí i, inú bí wọn. Wọ́n wí pé, “Irú ìfowóṣòfò wo ni èyí?  
\v 9 Èéha ti ṣe, obìnrin yìí ìbá tà á ní owó púpọ̀, kí a sì fi owó náà fún àwọn aláìní.” 
\p  
\v 10 Jesu ti mọ èrò ọkàn wọn, ó wí pé, \wj “Èéṣe ti ẹ̀yin fi ń dá obìnrin yìí lẹ́bi? Ó ṣe ohun tí ó dára fún mi.\wj* 
\v 11 \wj Ẹ̀yin yóò ní àwọn aláìní láàrín yín nígbà gbogbo, ṣùgbọ́n, ẹ̀yin kò le rí mi nígbà gbogbo.\wj* 
\v 12 \wj Nípa dída òróró ìkunra yìí sí mi lára, òun ń ṣe èyí fún ìsìnkú mi ni.\wj* 
\v 13 \wj Lóòótọ́ ni mo wí fún yín, a ó sì máa ṣe ìrántí rẹ̀ nígbà gbogbo fún ìṣesí rẹ̀ yìí. Níbikíbi tí a bá ti wàásù ìyìnrere yìí ní gbogbo àgbáyé ni a ó ti sọ ìtàn ohun tí obìnrin yìí ṣe.”\wj* 
\s1 Judasi gbà láti fi Jesu hàn 
\p  
\v 14       Nígbà náà ni ọ̀kan nínú àwọn aposteli méjìlá ti à ń pè ní Judasi Iskariotu lọ sọ́dọ̀ àwọn olórí àlùfáà.  
\v 15  Òun sì béèrè pé, “Kí ni ẹ̀yin yóò san fún mi bí mo bá fi Jesu lé yín lọ́wọ́?” Wọ́n sì fún un ní ọgbọ́n owó fàdákà. Ó sì gbà á.  
\v 16 Láti ìgbà náà lọ ni Judasi ti bẹ̀rẹ̀ sí i wá ọ̀nà láti fà á lé wọn lọ́wọ́. 
\s1 Oúnjẹ alẹ́ ìkẹyìn 
\p  
\v 17       Ní ọjọ́ kìn-ín-ní àjọ àìwúkàrà, àwọn ọmọ-ẹ̀yìn tọ Jesu wá pé, “Níbo ni ìwọ fẹ́ kí a pèsè sílẹ̀ láti jẹ àsè ìrékọjá?” 
\p  
\v 18       Jesu sì dáhùn pé, \wj “Ẹ wọ ìlú lọ, ẹ̀yin yóò rí ọkùnrin kan, ẹ wí fún un pé, ‘Olùkọ́ wa wí pé, àkókò mi ti dé. Èmi yóò sì jẹ àsè ìrékọjá pẹ̀lú àwọn ọmọ-ẹ̀yìn mi ní ilé rẹ.’ ”\wj* 
\v 19  Nítorí náà, àwọn ọmọ-ẹ̀yìn náà ṣe gẹ́gẹ́ bí Jesu ti sọ fún wọn. Wọ́n sì tọ́jú oúnjẹ àsè ti ìrékọjá níbẹ̀. 
\p  
\v 20       Ní àṣálẹ́ ọjọ́ kan náà, bí Jesu ti jókòó pẹ̀lú àwọn méjìlá,  
\v 21 nígbà tí wọ́n sì ń jẹun, ó wí pé, \wj “Lóòótọ́ ni mo wí fún yín, ọ̀kan nínú yín yóò fi mí hàn.”\wj* 
\p  
\v 22 Ìbànújẹ́ sì bo ọkàn wọn nígbà tí wọ́n gbọ́ èyí. Wọ́n sì bẹ̀rẹ̀ sí bi í pé, “Olúwa, èmi ni bí?” 
\p  
\v 23 Jesu dáhùn pé, \wj “Ẹni ti ó bá mi tọwọ́ bọ inú àwo, ni yóò fi mi hàn.\wj* 
\v 24 \wj Ọmọ Ènìyàn ń lọ bí a ti kọ̀wé nípa rẹ̀: ṣùgbọ́n ègbé ni fún ọkùnrin náà lọ́wọ́ ẹni tí a ó ti fi Ọmọ Ènìyàn hàn! Ìbá kúkú sàn fún ẹni náà, bí a kò bá bí.”\wj* 
\p  
\v 25 Judasi, ẹni tí ó fi í hàn pẹ̀lú béèrè pé, “Rabbi, èmi ni bí?” 
\p Jesu sì dá a lóhùn pé, \wj “Ìwọ wí i.”\wj* 
\p  
\v 26       Bí wọ́n ti ń jẹun, Jesu sì mú ìwọ̀n àkàrà kékeré kan, lẹ́yìn tí ó ti gbàdúrà sí i, ó bù ú, Ó fún àwọn ọmọ-ẹ̀yìn rẹ̀, Ó wí pé, \wj “Gbà, jẹ; nítorí èyí ni ara mi.”\wj* 
\p  
\v 27 Bákan náà, ó sì mú ago wáìnì, ó dúpẹ́ fún un, ó sì gbé e fún wọn. Ó wí pé, \wj “Kí gbogbo yín mu nínú rẹ̀.\wj* 
\v 28 \wj Nítorí èyí ni ẹ̀jẹ̀ mi tí májẹ̀mú tuntun, tí a ta sílẹ̀ fún ìdáríjì ẹ̀ṣẹ̀ ọ̀pọ̀ ènìyàn.\wj* 
\v 29 \wj Sì kíyèsi àwọn ọ̀rọ̀ mi. Èmi kì yóò tún mu nínú ọtí wáìnì yìí mọ́ títí di ọjọ́ náà tí èmi yóò mu ún ní tuntun pẹ̀lú yín ní ìjọba Baba mi.”\wj* 
\p  
\v 30       Wọ́n sì kọ orin kan, lẹ́yìn náà wọ́n lọ sórí òkè Olifi. 
\s1 Jesu sọ pé Peteru yóò sẹ́ òun 
\p  
\v 31       Nígbà náà ni Jesu wí fún wọn pé, \wj “Gbogbo yín ni yóò kọsẹ̀ lára mi ní òru òní. Nítorí a ti kọ ọ́ pé:\wj* 
\q1 \wj “ ‘Èmi yóò kọlu olùṣọ́-àgùntàn\wj* 
\q2 \wj a ó sì tú agbo àgùntàn náà ká kiri.’\wj* 
\m  
\v 32 \wj Ṣùgbọ́n lẹ́yìn tí mo bá jí dìde, èmi yóò ṣáájú yín lọ sí Galili.”\wj* 
\p  
\v 33 Peteru sì dá a lóhùn pé, “Bí gbogbo ènìyàn tilẹ̀ kọ̀ ọ́ sílẹ̀, èmi kì yóò ṣe bẹ́ẹ̀.” 
\p  
\v 34 Jesu wí fún un pé, \wj “Lóòótọ́ ni mo wí fún ọ pé, ní òru yìí, kí àkùkọ kí ó tó kọ, ìwọ yóò sẹ́ mi nígbà mẹ́ta.”\wj* 
\p  
\v 35 Peteru wí fún un pé, “Bí ó tilẹ̀ jẹ́ láti kú pẹ̀lú, èmi kò jẹ́ sẹ́ ọ.” Gẹ́gẹ́ bẹ́ẹ̀ ni gbogbo àwọn ọmọ-ẹ̀yìn wí. 
\s1 Jesu ní Getsemane 
\p  
\v 36       Nígbà náà ni Jesu àti àwọn ọmọ-ẹ̀yìn rẹ̀ lọ sí ibi kan ti à ń pè ní ọgbà Getsemane, ó wí fún wọn pé, \wj “Ẹ jókòó níhìn-ín nígbà tí mo bá lọ gbàdúrà lọ́hùn ún ni.”\wj* 
\v 37 Ó sì mú Peteru àti àwọn ọmọ Sebede méjèèjì Jakọbu àti Johanu pẹ̀lú rẹ̀, ìrora àti ìbànújẹ́ bẹ̀rẹ̀ sí gba ọkàn rẹ̀.  
\v 38  Nígbà náà ni ó wí fún wọn pé, \wj “Ọkàn mi gbọgbẹ́ pẹ̀lú ìbànújẹ́ títí dé ojú ikú, ẹ dúró níhìn-ín yìí, kí ẹ máa ṣọ́nà pẹ̀lú mi.”\wj* 
\p  
\v 39       Òun lọ sí iwájú díẹ̀ sí i, ó sì dojúbolẹ̀, ó sì gbàdúrà pé, \wj “Baba mi, bí ó bá ṣe é ṣe, jẹ́ kí a mú ago yìí ré mi lórí kọjá, ṣùgbọ́n ìfẹ́ tìrẹ ni mo fẹ́ kí ó ṣẹ, kì í ṣe ìfẹ́ tèmi.”\wj* 
\p  
\v 40 Bí ó ti padà sọ́dọ̀ àwọn ọmọ-ẹ̀yìn rẹ̀ mẹ́tẹ̀ẹ̀ta, ó bá wọn, wọ́n ń sùn. Ó kígbe pé, \wj “Peteru, ẹ̀yin kò tilẹ̀ lè bá mi ṣọ́nà fún wákàtí kan?\wj* 
\v 41 \wj Ẹ máa ṣọ́ra, kí ẹ sì máa gbàdúrà kí ẹ̀yin má ba à bọ́ sínú ìdẹwò. Nítorí ẹ̀mí ń fẹ́ nítòótọ́, ṣùgbọ́n ó ṣe àìlera fún ara.”\wj* 
\p  
\v 42       Ó tún fi wọ́n sílẹ̀ nígbà kejì, ó sí gbàdúrà pé, \wj “Baba mi, bí ago yìí kò bá lè ré mi lórí kọjá bí kò ṣe pé mo bá mu ún, ìfẹ́ tìrẹ ni kí a ṣe.”\wj* 
\p  
\v 43 Nígbà tí ó tún padà dé sọ́dọ̀ wọn, Ó rí i pé wọn ń sùn, nítorí ojú wọn kún fún oorun.  
\v 44 Nítorí náà, ó fi wọn sílẹ̀ ó tún padà lọ láti gbàdúrà nígbà kẹta, ó ń wí ohun kan náà. 
\p  
\v 45       Nígbà náà ni ó tọ́ àwọn ọmọ-ẹ̀yìn rẹ̀ wá, ó wí pé, \wj “Àbí ẹ̀yin sì ń sùn síbẹ̀, ti ẹ sì ń sinmi? Wò ó wákàtí náà tí dé ti a ó fi Ọmọ Ènìyàn lé àwọn ẹlẹ́ṣẹ̀ lọ́wọ́\wj*.  
\v 46 \wj Ẹ dìde! Ẹ jẹ́ kí a máa lọ! Ẹ wò ó, ẹni tí yóò fi mi hàn ń bọ̀ wá!”\wj* 
\s1 A mú Jesu 
\p  
\v 47       Bí ó ti ń sọ̀rọ̀ lọ́wọ́, Judasi, ọ̀kan nínú àwọn méjìlá dé pẹ̀lú ọ̀pọ̀ ènìyàn pẹ̀lú idà àti kùmọ̀ lọ́wọ́ wọn, wọ́n ti ọ̀dọ̀ àwọn olórí àlùfáà àti àgbàgbà Júù wá.  
\v 48 Ẹni tí ó sì fi í hàn ti fi àmì fún wọn, pé, “Ẹnikẹ́ni tí mo bá fi ẹnu kò ní ẹnu, òun náà ni; ẹ mú un.”  
\v 49 Nísinsin yìí, Judasi wá tààrà sọ́dọ̀ Jesu, ó wí pé, “Àlàáfíà, Rabbi!” Ó fi ẹnu kò ó ní ẹnu. 
\p  
\v 50       Jesu wí pé, \wj “Ọ̀rẹ́, kí ni nǹkan tí ìwọ bá wá.”\wj* 
\p Àwọn ìyókù sì sún síwájú wọ́n sì mú Jesu.  
\v 51 Sì wò ó, ọ̀kan nínú àwọn tí ó wà pẹ̀lú Jesu na ọwọ́ rẹ̀, ó sì fa idà yọ, ó sì sá ọ̀kan tí i ṣe ọmọ ọ̀dọ̀ olórí àlùfáà, ó sì gé e ní etí sọnù. 
\p  
\v 52       Jesu wí fún un pé, \wj “Fi idà rẹ bọ àkọ̀ nítorí àwọn tí ó ń fi idà pa ni a ó fi idà pa.\wj* 
\v 53 \wj Ìwọ kò mọ̀ pé èmi lè béèrè lọ́wọ́ Baba mi kí ó fún mi ju légíónì angẹli méjìlá? Òun yóò sì fi wọ́n ránṣẹ́ lẹ́sẹ̀kẹsẹ̀.\wj* 
\v 54 \wj Ṣùgbọ́n bí mo bá ṣe eléyìí ọ̀nà wo ni a ó fi mú Ìwé Mímọ́ ṣẹ, èyí tí ó ti sọ ohun tí ó ṣẹlẹ̀ nísinsin yìí?”\wj* 
\p  
\v 55       Nígbà náà ni Jesu wí fún ìjọ ènìyàn náà pé, \wj “Ǹjẹ́ èmi ni ẹ kà sí ọ̀daràn ti ẹ múra pẹ̀lú idà àti kùmọ̀ kí ẹ tó lé mú mi? Ẹ rántí pé mo ti wà pẹ̀lú yín, tí mo ń kọ́ yín lójoojúmọ́ nínú tẹmpili, ẹ̀yin kò sì mú mi nígbà náà.\wj* 
\v 56 \wj Ṣùgbọ́n gbogbo wọ̀nyí ń ṣẹlẹ̀ kí ọ̀rọ̀ tí a tì ẹnu àwọn wòlíì sọ, tí a kọ sínú Ìwé Mímọ́ lè ṣẹ.”\wj* Nígbà yìí gan an ni gbogbo àwọn ọmọ-ẹ̀yìn rẹ̀ ti kúrò lọ́dọ̀ rẹ̀, wọ́n sì sálọ. 
\s1 Níwájú Sahẹndiri 
\p  
\v 57       Àwọn tí ó mú Jesu fà á lọ sí ilé Kaiafa, olórí àlùfáà, níbi ti àwọn olùkọ́ òfin àti gbogbo àwọn àgbàgbà Júù péjọ sí.  
\v 58 Ṣùgbọ́n Peteru ń tẹ̀lé e lókèèrè. Òun sì wá sí àgbàlá olórí àlùfáà. Ó wọlé, ó sì jókòó pẹ̀lú àwọn olùṣọ́. Ó ń dúró láti ri ohun tí yóò ṣẹlẹ̀ sí Jesu. 
\p  
\v 59 Nígbà náà ni àwọn olórí àlùfáà àti gbogbo ìgbìmọ̀ Júù ní ilé ẹjọ́ tí ó ga jùlọ ti Júù péjọ síbẹ̀, wọ́n wá àwọn ẹlẹ́rìí tí yóò purọ́ mọ́ Jesu, kí a ba à lè rí ẹjọ́ rò mọ́ ọn lẹ́sẹ̀, eléyìí tí yóò yọrí si ìdájọ́ ikú fún un.  
\v 60 Bí ó tilẹ̀ jẹ́ pé àwọn ẹlẹ́rìí èké dìde, ṣùgbọ́n wọn kò rí ohun kan. 
\p Níkẹyìn, àwọn ẹlẹ́rìí méjì dìde.  
\v 61  Wọn wí pé, “Ọkùnrin yìí sọ pé, ‘Èmi lágbára láti wó tẹmpili Ọlọ́run lulẹ̀, èmi yóò sì tún un mọ ní ọjọ́ mẹ́ta.’ ” 
\p  
\v 62 Nígbà náà ni olórí àlùfáà sì dìde, ó wí fún Jesu pé, “Ẹ̀rí yìí ń kọ́? Ìwọ sọ bẹ́ẹ̀ tàbí ìwọ kò sọ bẹ́ẹ̀?”  
\v 63  Ṣùgbọ́n Jesu dákẹ́ rọ́rọ́. 
\p Nígbà náà ni olórí àlùfáà wí fún un pé, “Mo fi ọ́ bú ní orúkọ Ọlọ́run alààyè, kí ó sọ fún wa, bí ìwọ bá í ṣe Kristi Ọmọ Ọlọ́run.” 
\p  
\v 64       Jesu sì dáhùn pé, \wj “Bẹ́ẹ̀ ni, ìwọ wí.”\wj* Ṣùgbọ́n mo wí fún gbogbo yín. \wj “Ẹ̀yin yóò rí Ọmọ Ènìyàn ti yóò jókòó lọ́wọ́ ọ̀tún alágbára, tí yóò sì máa bọ̀ wá láti inú ìkùùkuu.”\wj* 
\p  
\v 65       Nígbà náà ni olórí àlùfáà fa aṣọ òun tìkára rẹ̀ ya. Ó sì kígbe pé, “Ọ̀rọ̀-òdì! Kí ni a tún ń wá ẹlẹ́rìí fún? Gbogbo yín ti gbọ́ ọ̀rọ̀-òdì rẹ̀. Kí ni ìdájọ́ yín?”  
\v 66 Ki ni ẹ ti rò èyí sí. 
\p Gbogbo wọn sì kígbe lọ́hùn kan pé, “Ó jẹ̀bi ikú!” 
\p  
\v 67 Wọ́n tu itọ́ sí i ní ojú. Wọ́n kàn án lẹ́ṣẹ̀ẹ́. Àwọn ẹlòmíràn sì gbá a lójú.  
\v 68 Wọ́n wí pé, “Sọ àsọtẹ́lẹ̀ fún wa! Ìwọ Kristi, ta ni ẹni tí ó ń lù Ọ́?” 
\s1 Peteru sẹ́ Jesu 
\p  
\v 69 Lákòókò yìí, bí Peteru ti ń jókòó ní àgbàlá, ọmọbìnrin kan sì tọ̀ ọ́ wá, ó ní, “Ìwọ wà pẹ̀lú Jesu ti Galili.” 
\p  
\v 70 Ṣùgbọ́n Peteru sẹ̀ ní ojú gbogbo wọn pé, “Èmi kò tilẹ̀ mọ ohun tí ẹ ń sọ nípa rẹ̀.” 
\p  
\v 71 Lẹ́yìn èyí, ní ìta ní ẹnu-ọ̀nà, ọmọbìnrin mìíràn tún rí i, ó sì wí fún àwọn tí ó dúró yíká pé, “Ọkùnrin yìí wà pẹ̀lú Jesu ti Nasareti.” 
\p  
\v 72 Peteru sì tún sẹ́ lẹ́ẹ̀kejì pẹ̀lú ìbúra pé, “Èmi kò tilẹ̀ mọ ọkùnrin náà rárá.” 
\p  
\v 73 Nígbà tí ó pẹ́ díẹ̀, àwọn ọkùnrin tí ó ń dúró níbi ìran yìí tọ̀ ọ́ wá, wọ́n wí fún Peteru pé, “Lóòótọ́, ìwọ jẹ́ ọ̀kan nínú àwọn ọmọ-ẹ̀yìn, àwa mọ̀ ọ́n. Èyí sì dá wa lójú nípa àmì ohùn rẹ̀ tí ó ń ti ẹnu rẹ jáde.” 
\p  
\v 74 Peteru sì tún bẹ̀rẹ̀ sí í búra ó sì fi ara rẹ̀ ré wí pé, “Mo ní èmi kò mọ ọkùnrin yìí rárá.” 
\p Lójúkan náà àkùkọ sì kọ.  
\v 75  Nígbà náà ni Peteru rántí nǹkan tí Jesu ti sọ pé, \wj “Kí àkùkọ tó ó kọ, ìwọ yóò sẹ́ mi nígbà mẹ́ta.”\wj* Òun sì bọ́ sí òde, ó sọkún kíkorò. 
\c 27  
\s1 Judasi lọ pokùnso 
\p  
\v 1       Ní òwúrọ̀, gbogbo àwọn olórí àlùfáà àti àwọn àgbàgbà Júù tún padà láti gbìmọ̀ bí wọn yóò ti ṣe pa Jesu.  
\v 2 Lẹ́yìn èyí, wọ́n fi ẹ̀wọ̀n dè é, wọ́n sì jọ̀wọ́ rẹ̀ fún Pilatu tí i ṣe gómìnà. 
\p  
\v 3       Nígbà tí Judasi, ẹni tí ó fi í hàn, rí i wí pé a ti dá a lẹ́bi ikú, ó yí ọkàn rẹ̀ padà, ó sì káàánú nípa ohun tí ó ṣe. Ó sì mú ọgbọ̀n owó fàdákà tí ó gba náà wá fún àwọn olórí àlùfáà àti àwọn àgbàgbà Júù.  
\v 4 Ó wí pé, “Mo ti ṣẹ̀ nítorí tí mo ti ta ẹ̀jẹ̀ aláìlẹ́ṣẹ̀ sílẹ̀.” 
\p Wọ́n dá a lóhùn pẹ̀lú ìbínú pé, “Èyí kò kàn wá! Wàhálà tìrẹ ni!” 
\p  
\v 5 Nígbà náà ni Judasi da owó náà sílẹ̀ nínú tẹmpili. Ó jáde, ó sì lọ pokùnso. 
\p  
\v 6       Àwọn olórí àlùfáà sì mú owó náà. Wọ́n wí pé, “Àwa kò lè fi owó yìí sínú owó ìkójọpọ̀. Ní ìwọ̀n ìgbà tí ó lòdì sí òfin wa nítorí pé owó ẹ̀jẹ̀ ni.”  
\v 7 Wọ́n sì gbìmọ̀, wọ́n sì fi ra ilẹ̀ amọ̀kòkò, láti máa sin òkú àwọn àjèjì nínú rẹ̀.  
\v 8 Ìdí nìyìí tí à ń pe ibi ìsìnkú náà ní “Ilẹ̀ Ẹ̀jẹ̀” títí di òní.  
\v 9  Èyí sì jẹ́ ìmúṣẹ èyí tí a ti sọtẹ́lẹ̀ láti ẹnu wòlíì Jeremiah wí pé, “Wọ́n sì mú ọgbọ̀n owó fàdákà tí àwọn ènìyàn Israẹli díye lé e.  
\v 10 Wọ́n sì fi ra ilẹ̀ kan lọ́wọ́ àwọn amọ̀kòkò gẹ́gẹ́ bí Olúwa ti pàṣẹ.” 
\s1 Jesu níwájú Pilatu 
\p  
\v 11       Nígbà náà ni Jesu dúró níwájú baálẹ̀ láti gba ìdájọ́. Baálẹ̀ sì béèrè pé, “Ṣe ìwọ ni ọba àwọn Júù?” 
\p Jesu dáhùn pé, \wj “Bẹ́ẹ̀ ni, nítorí tí ìwọ wí i.”\wj* 
\p  
\v 12 Ṣùgbọ́n nígbà tí àwọn olórí àlùfáà àti àwọn àgbàgbà Júù fi gbogbo ẹ̀sùn wọn kàn án, Jesu kò dáhùn kan.  
\v 13 Nígbà náà ni Pilatu, béèrè lọ́wọ́ Jesu pé, “Àbí ìwọ kò gbọ́ ẹ̀rí tí wọn ń wí nípa rẹ ni?”  
\v 14  Jesu kò sì tún dáhùn kan. Èyí sì ya baálẹ̀ lẹ́nu. 
\p  
\v 15 Ó jẹ́ àṣà gómìnà láti dá ọ̀kan nínú àwọn ẹlẹ́wọ̀n Júù sílẹ̀ lọ́dọọdún, ní àsìkò àjọ̀dún ìrékọjá. Ẹnikẹ́ni tí àwọn ènìyàn bá ti fẹ́ ni.  
\v 16 Ní àsìkò náà ọ̀daràn paraku kan wà nínú ẹ̀wọ̀n tí à ń pè Jesu Baraba.  
\v 17 Bí ọ̀pọ̀ ènìyàn ti péjọ síwájú ilé Pilatu lówúrọ̀ ọjọ́ náà, ó béèrè lọ́wọ́ wọn pé, “Ta ni ẹ̀yin ń fẹ́ kí n dá sílẹ̀ fún yín, Baraba tàbí Jesu, ẹni tí ń jẹ́ Kristi?”  
\v 18 Òun ti mọ̀ pé nítorí ìlara ni wọn fi fà á lé òun lọ́wọ́. 
\p  
\v 19       Bí Pilatu sì ti ṣe jókòó lórí ìtẹ́ ìdájọ́ rẹ̀, ìyàwó rẹ̀ ránṣẹ́ sí i pé, “Má ṣe ní ohun kankan ṣe pẹ̀lú ọkùnrin aláìṣẹ̀ náà. Nítorí mo jìyà ohun púpọ̀ lójú àlá mi lónìí nítorí rẹ̀.” 
\p  
\v 20 Ṣùgbọ́n àwọn olórí àlùfáà àti àwọn àgbàgbà Júù rọ àwọn ènìyàn, láti béèrè kí a dá Baraba sílẹ̀, kí a sì béèrè ikú fún Jesu. 
\p  
\v 21       Nígbà tí Pilatu sì tún béèrè lọ́wọ́ wọn pé, “Èwo nínú àwọn méjèèjì yìí ni ẹ̀ ń fẹ́ kí n dá sílẹ̀ fún yín?” 
\p Àwọn ènìyàn sì kígbe padà pé, “Baraba!” 
\p  
\v 22 Pilatu béèrè pé, “Kí ni kí èmi ṣe sí Jesu ẹni ti a ń pè ní Kristi?” 
\p Gbogbo wọn sì tún kígbe pé, “Kàn án mọ́ àgbélébùú!” 
\p  
\v 23 Pilatu sì béèrè pé, “Nítorí kí ni? Kí ló ṣe tí ó burú?” 
\p Wọ́n kígbe sókè pé, “Kàn án mọ́ àgbélébùú! Kàn án mọ́ àgbélébùú!” 
\p  
\v 24       Nígbà tí Pilatu sì rí i pé òun kò tún rí nǹkan kan ṣe mọ́, àti wí pé rògbòdìyàn ti ń bẹ̀rẹ̀, ó béèrè omi, ó sì wẹ ọwọ́ rẹ̀ níwájú ọ̀pọ̀ ènìyàn, ó wí pé, “Ọrùn mí mọ́ nípa ẹ̀jẹ̀ ọkùnrin yìí. Ẹ̀yin fúnra yín, ẹ bojútó o!” 
\p  
\v 25       Gbogbo àgbájọ náà sì ké pé, “Kí ẹ̀jẹ̀ rẹ̀ wà lórí wa, àti ní orí àwọn ọmọ wa!” 
\p  
\v 26 Nígbà náà ni Pilatu dá Baraba sílẹ̀ fún wọn. Lẹ́yìn tí òun ti na Jesu tán, ó fi í lé wọn lọ́wọ́ láti mú un lọ kàn mọ́ àgbélébùú. 
\s1 Àwọn ọmọ-ogun na Jesu 
\p  
\v 27       Nígbà náà ni àwọn ọmọ-ogun gómìnà mú Jesu lọ sí gbọ̀ngàn ìdájọ́ wọ́n sì kó gbogbo ẹgbẹ́ ọmọ-ogun tì í.  
\v 28 Wọ́n tú Jesu sì ìhòhò, wọ́n sì wọ̀ ọ́ ní aṣọ òdòdó,  
\v 29 wọ́n sì hun adé ẹ̀gún. Wọ́n sì fi dé e lórí. Wọ́n sì fi ọ̀pá sí ọwọ́ ọ̀tún rẹ̀ gẹ́gẹ́ bí ọ̀pá ọba. Wọ́n sì wólẹ̀ níwájú rẹ̀, wọ́n fi í ṣe ẹlẹ́yà pé, “Kábíyèsí, ọba àwọn Júù!”  
\v 30 Wọ́n sì tu itọ́ sí i lójú àti ara, wọ́n gba ọ̀pá wọ́n sì nà án lórí.  
\v 31 Nígbà tí wọ́n fi ṣẹ̀sín tán, wọ́n bọ́ aṣọ ara rẹ̀. Wọ́n tún fi aṣọ tirẹ̀ wọ̀ ọ́. Wọ́n sì mú un jáde láti kàn án mọ́ àgbélébùú. 
\s1 A kan Jesu mọ́ àgbélébùú 
\p  
\v 32       Bí wọ́n sì ti ń jáde, wọ́n rí ọkùnrin kan ará Kirene tí à ń pè ní Simoni. Wọ́n sì mú ọkùnrin náà ní túláàsì láti ru àgbélébùú Jesu.  
\v 33  Wọ́n sì jáde lọ sí àdúgbò kan tí à ń pè ní Gọlgọta (èyí tí í ṣe “Ibi Agbárí”).  
\v 34 Níbẹ̀ ni wọn ti fún un ni ọtí wáìnì tí ó ní egbòogi nínú láti mu. Ṣùgbọ́n nígbà tí ó tọ́ ọ wò, ó kọ̀ láti mu ún.  
\v 35  Lẹ́yìn tí wọ́n sì ti kàn án mọ́ àgbélébùú, wọ́n dìbò láti pín aṣọ rẹ̀ láàrín ara wọn.  
\v 36 Nígbà náà ni wọ́n jókòó yí i ká. Wọ́n ń ṣọ́ ọ níbẹ̀.  
\v 37 Ní òkè orí rẹ̀, wọ́n kọ ohun kan tí ó kà báyìí pé: 
\pc “Èyí ni Jesu, Ọba àwọn Júù.” 
\m síbẹ̀.  
\v 38 Wọ́n kan àwọn olè méjì pẹ̀lú rẹ̀ ní òwúrọ̀ náà. Ọ̀kan ní ọwọ́ ọ̀tún, àti èkejì ní ọwọ́ òsì rẹ̀.  
\v 39  Àwọn tí ń kọjá lọ sì ń bú u. Wọ́n sì ń mi orí wọn pé:  
\v 40  “Ìwọ tí yóò wó tẹmpili, ìwọ tí yóò sì tún un mọ ní ọjọ́ kẹta. Bí ó bá jẹ́ pé Ọmọ Ọlọ́run ni ìwọ, sọ̀kalẹ̀ láti orí igi àgbélébùú, kí ó sì gba ara rẹ là!” 
\p  
\v 41 Bákan náà àwọn olórí àlùfáà pẹ̀lú àwọn akọ̀wé òfin àti àwọn àgbàgbà Júù sì fi í ṣe ẹlẹ́yà.  
\v 42 Wọ́n kẹ́gàn rẹ̀ pé, “Ó gba àwọn ẹlòmíràn là, kò sí lè gba ara rẹ̀. Ìwọ ọba àwọn Israẹli? Sọ̀kalẹ̀ láti orí àgbélébùú nísinsin yìí, àwa yóò sì gbà ọ́ gbọ́.  
\v 43 Ó gba Ọlọ́run gbọ́, jẹ́ kí Ọlọ́run gbà á là ní ìsinsin yìí tí òun bá fẹ́ ẹ. Ǹjẹ́ òun kò wí pé, èmi ni Ọmọ Ọlọ́run?”  
\v 44 Bákan náà, àwọn olè tí a kàn mọ́ àgbélébùú pẹ̀lú rẹ̀ fi í ṣe ẹlẹ́yà. 
\s1 Ikú Jesu 
\p  
\v 45       Láti wákàtí kẹfà ni òkùnkùn fi ṣú bo gbogbo ilẹ̀ títí dé wákàtí kẹsànán ọjọ́.  
\v 46  Níwọ̀n wákàtí kẹsànán ní Jesu sì kígbe ní ohùn rara wí pé, \wj “Eli, Eli, lama sabakitani”\wj* (ní èdè Heberu). Ìtumọ̀ èyí tí í ṣe, \wj “Ọlọ́run mi, Ọlọ́run mi, èéṣe tí ìwọ fi kọ̀ mí sílẹ̀?”\wj* 
\p  
\v 47 Ọ̀rọ̀ rẹ̀ kò yé díẹ̀ nínú àwọn ẹni tí ń wòran, nígbà tí wọ́n gbọ́ ọ̀rọ̀ rẹ̀, wọ́n wí pé ọkùnrin yìí ń pe Elijah. 
\p  
\v 48       Lẹ́sẹ̀kan náà, ọ̀kan nínú wọn sáré, ó mú kànìnkànìn, ó tẹ̀ ẹ́ bọ inú ọtí kíkan. Ó fi lé orí ọ̀pá, ó gbé e sókè láti fi fún un mu.  
\v 49 Ṣùgbọ́n àwọn ìyókù wí pé, “Ẹ fi í sílẹ̀. Ẹ jẹ́ kí a wò ó bóyá Elijah yóò sọ̀kalẹ̀ láti gbà á là.” 
\p  
\v 50 Nígbà tí Jesu sì kígbe ní ohùn rara lẹ́ẹ̀kan sí i, ó jọ̀wọ́ ẹ̀mí rẹ̀, ó sì kú. 
\p  
\v 51       Lójúkan náà aṣọ ìkélé tẹmpili fàya, láti òkè dé ìsàlẹ̀. Ilẹ̀ sì mì tìtì. Àwọn àpáta sì sán.  
\v 52 Àwọn isà òkú sì ṣí sílẹ̀. Ọ̀pọ̀ òkú àwọn ẹni mímọ́ tí ó ti sùn sì tún jíǹde.  
\v 53 Wọ́n jáde wá láti isà òkú lẹ́yìn àjíǹde Jesu, wọ́n sì lọ sí ìlú mímọ́. Níbẹ̀ ni wọ́n ti fi ara han ọ̀pọ̀ ènìyàn. 
\p  
\v 54       Nígbà tí balógun ọ̀run àti àwọn tí ó wà pẹ̀lú rẹ̀ tí wọ́n ń sọ Jesu rí bí ilẹ̀ ṣe mì tìtì àti ohun tí ó ṣẹlẹ̀, ẹ̀rù bà wọn gidigidi, wọ́n wí pé, “Lóòótọ́ Ọmọ Ọlọ́run ní í ṣe!” 
\p  
\v 55 Ọ̀pọ̀ obìnrin tí ó wá láti Galili pẹ̀lú Jesu láti tọ́jú rẹ̀ wọn ń wò ó láti òkèèrè.  
\v 56  Nínú àwọn obìnrin ti ó wà níbẹ̀ ni Maria Magdalene, àti Maria ìyá Jakọbu àti Josẹfu, àti ìyá àwọn ọmọ Sebede méjèèjì wà níbẹ̀ pẹ̀lú. 
\s1 A tẹ́ Jesu sínú ibojì 
\p  
\v 57       Nígbà tí alẹ́ sì lẹ́, ọkùnrin ọlọ́rọ̀ kan láti Arimatea, tí à ń pè ní Josẹfu, ọ̀kan nínú àwọn tí ó jẹ́ ọmọ-ẹ̀yìn Jesu,  
\v 58 lọ sọ́dọ̀ Pilatu, ó sì tọrọ òkú Jesu. Pilatu sì pàṣẹ kí a gbé é fún un.  
\v 59 Josẹfu sì gbé òkú náà. Ó fi aṣọ funfun mímọ́ dì í.  
\v 60 Ó sì tẹ́ ẹ sínú ibojì òkúta tí ó gbẹ́ nínú àpáta fúnra rẹ̀. Ó sì yí òkúta ńlá dí ẹnu-ọ̀nà ibojì náà, ó sì lọ.  
\v 61 Maria Magdalene àti Maria kejì wà níbẹ̀, wọn jókòó òdìkejì ibojì náà. 
\s1 Àwọn olùṣọ́ ní ibojì 
\p  
\v 62 Lọ́jọ́ kejì tí ó tẹ̀lé ọjọ́ ìpalẹ̀mọ́ àwọn olórí àlùfáà àti àwọn Farisi lọ sọ́dọ̀ Pilatu.  
\v 63  Wọ́n sọ fún un pé, “Alàgbà àwa rántí pé ẹlẹ́tàn n nì wí nígbà tí ó wà láyé pé, ‘Lẹ́yìn ọjọ́ kẹta èmi yóò tún jí dìde.’  
\v 64 Nítorí náà, pàṣẹ kí a ti ibojì rẹ̀ gbọningbọnin títí ọjọ́ kẹta, kí àwọn ọmọ-ẹ̀yìn rẹ̀ má ṣe wá jí gbé lọ, wọn a sì bẹ̀rẹ̀ sí í sọ fún gbogbo ènìyàn pé, ‘Òun ti jíǹde,’ bí èyí bá ní láti ṣẹlẹ̀, yóò burú fún wa púpọ̀ ju ti àkọ́kọ́ lọ.” 
\p  
\v 65 Pilatu sì pàṣẹ pé, “Ẹ lo àwọn olùṣọ́ yín kí wọn dáàbò bo ibojì náà bí ẹ bá ti fẹ́.”  
\v 66  Nítorí náà wọ́n lọ. Wọ́n sì ṣé òkúta ibojì náà dáradára. Wọ́n sì fi àwọn olùṣọ́ sí ibẹ̀ láti dáàbò bò ó. 
\c 28  
\s1 Àjíǹde rẹ̀ 
\p  
\v 1       Ní kùtùkùtù òwúrọ̀ ọjọ́ kìn-ín-ní ọ̀sẹ̀, bí ilẹ̀ ti ń mọ́, Maria Magdalene àti Maria kejì lọ sí ibojì. 
\p  
\v 2       Wọ́n rí i pé, ìṣẹ̀lẹ̀ ńlá ṣẹ̀ tí ó mú gbogbo ilẹ̀ mì tìtì. Nítorí angẹli Olúwa ti sọ̀kalẹ̀ láti ọ̀run. Ó ti yí òkúta ibojì kúrò. Ó sì jókòó lé e lórí.  
\v 3 Ojú rẹ̀ tàn bí mọ̀nàmọ́ná. Aṣọ rẹ̀ sì jẹ́ funfun bí ẹ̀gbọ̀n òwú.  
\v 4  Ẹ̀rù ba àwọn olùṣọ́, wọ́n sì wárìrì wọn sì dàbí òkú. 
\p  
\v 5 Nígbà náà ni angẹli náà wí fún àwọn obìnrin náà pé, “Ẹ má ṣe bẹ̀rù. Mo mọ̀ pé ẹ̀yin ń wá Jesu tí a kàn mọ́ àgbélébùú.  
\v 6 Ṣùgbọ́n kò sí níhìn-ín. Nítorí pé ó ti jíǹde, gẹ́gẹ́ bí òun ti wí. Ẹ wọlé wá wo ibi ti wọ́n tẹ́ ẹ sí.  
\v 7  Nísinsin yìí, ẹ lọ kíákíá láti sọ fún àwọn ọmọ-ẹ̀yìn rẹ̀ pé, ‘Ó ti jíǹde kúrò nínú òkú. Àti pé òun ń lọ sí Galili síwájú yín, níbẹ̀ ni ẹ̀yin yóò gbé rí i,’ wò ó, o ti sọ fún yin.” 
\p  
\v 8 Àwọn obìnrin náà sáré kúrò ní ibojì pẹ̀lú ìbẹ̀rù àti ayọ̀ ńlá. Wọ́n sáré láti sọ fún àwọn ọmọ-ẹ̀yìn nípa ìròyìn tí angẹli náà fi fún wọn.  
\v 9  Bí wọ́n ti ń sáré lọ lójijì Jesu pàdé wọn. Ó wí pé, \wj “Àlàáfíà”,\wj* wọ́n wólẹ̀ níwájú rẹ̀. Wọ́n gbá a ní ẹsẹ̀ mú. Wọ́n sì foríbalẹ̀ fún un.  
\v 10 Nígbà náà, Jesu wí fún wọn pé, \wj “Ẹ má ṣe bẹ̀rù. Ẹ lọ sọ fún àwọn arákùnrin mi pé, ‘Kí wọ́n lọ tààrà sí Galili níbẹ̀ ni wọn yóò gbé rí mi.’ ”\wj* 
\s1 Àwọn olùṣọ́ ròyìn 
\p  
\v 11       Bí àwọn obìnrin náà sì ti ń lọ sí ìlú, díẹ̀ nínú àwọn olùṣọ́ tí wọ́n ti ń ṣọ́ ibojì lọ sọ́dọ̀ àwọn olórí àlùfáà.  
\v 12 Wọ́n sì pe ìpàdé àwọn àgbàgbà Júù. Wọ́n sì fohùn ṣọ̀kan láti fi owó àbẹ̀tẹ́lẹ̀ fún àwọn olùṣọ́.  
\v 13 Wọ́n wí pé, “Ẹ sọ fún àwọn ènìyàn pé, ‘Gbogbo yín sùn nígbà tí àwọn ọmọ-ẹ̀yìn Jesu wá lóru láti jí òkú rẹ̀.’  
\v 14 Bí Pilatu bá sì mọ̀ nípa rẹ̀, àwa yóò ṣe àlàyé tí yóò tẹ́ ẹ lọ́rùn fún un, tí ọ̀rọ̀ náà kì yóò fi lè kó bá yín.”  
\v 15 Àwọn olùṣọ́ sì gba owó náà. Wọ́n sì ṣe gẹ́gẹ́ bí wọ́n ti darí wọn. Ìtàn yìí sì tàn ká kíákíá láàrín àwọn Júù. Wọ́n sì gba ìtàn náà gbọ́ títí di òní yìí. 
\s1 Jesu pín iṣẹ́ ńlá fún àwọn ọmọ-ẹ̀yìn rẹ̀ 
\p  
\v 16       Nígbà náà ni àwọn ọmọ-ẹ̀yìn mọ́kànlá náà lọ sí Galili ní orí òkè níbi tí Jesu sọ pé wọn yóò ti rí òun.  
\v 17 Nígbà tí wọ́n sì rí i, wọ́n foríbalẹ̀ fún un. Ṣùgbọ́n díẹ̀ nínú wọn ṣe iyèméjì bóyá Jesu ni tàbí òun kọ́.  
\v 18  Nígbà náà ni Jesu wí fún àwọn ọmọ-ẹ̀yìn rẹ̀ pé, \wj “Gbogbo agbára ni ọ̀run àti ní ayé ni a ti fi fún mi.\wj* 
\v 19 \wj Nítorí náà, ẹ lọ, ẹ sọ wọ́n di ọmọ-ẹ̀yìn orílẹ̀-èdè gbogbo, ẹ máa bamitiisi wọn ní orúkọ Baba àti ti Ọmọ àti ti Ẹ̀mí Mímọ́.\wj* 
\v 20 \wj Ẹ kọ́ wọn láti máa kíyèsi ohun gbogbo èyí tí mo ti pàṣẹ fún yín. Nítorí èmi wà pẹ̀lú yín ní ìgbà gbogbo títí tí ó fi dé òpin ayé.”\wj*