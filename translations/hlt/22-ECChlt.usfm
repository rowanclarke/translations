\p
\v 1 \w Pathen|strong="H0430"\w* \w im|strong="H1003"\w* \w la|strong="H0413"\w* na \w caeh|strong="H1980"\w* \w vaengkah|strong="H0834"\w* \w bangla|strong="H9995"\w* \w na|strong="H9905"\w* \w kho|strong="H7272"\w* neh \w na|strong="H9905"\w* \w khokan|strong="H7272"\w* te \w ngaithuen|strong="H8104"\w*. Te \w dongah|strong="H9999"\w* \w hnatun|strong="H8085"\w* \w hamla|strong="H9997"\w* n'\w tawn|strong="H7126"\w* uh he aka \w ang|strong="H3684"\w* kah \w hmueih|strong="H2077"\w* \w nawn|strong="H5414"\w* \w lakah|strong="H4480"\w* then. \w Amih|strong="H9908"\w* loh \w boethae|strong="H7451"\w* a \w saii|strong="H6213"\w* \w te|strong="H9997"\w* khaw \w ming|strong="H3045"\w* uh \w pawh|strong="H0369"\w*.  
