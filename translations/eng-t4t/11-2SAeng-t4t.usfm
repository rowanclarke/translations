\v 36 \w Keep|strong="H8085"\w* \w in|strong="H8085"\w* mind \w that|strong="H3605"\w* \w Zadok|strong="H6659"\w*’s \w son|strong="H1121"\w* Ahimaaz \w and|strong="H1121"\w* Abiathar’s \w son|strong="H1121"\w* \w Jonathan|strong="H3083"\w* \w are|strong="H1121"\w* \w also|strong="H3027"\w* \w there|strong="H8033"\w*. \w You|strong="H3605"\w* \w can|strong="H1121"\w* \w tell|strong="H8085"\w* \w them|strong="H7971"\w* \w whatever|strong="H3605"\w* \w you|strong="H3605"\w* find \w out|strong="H7971"\w*, \w and|strong="H1121"\w* \w send|strong="H7971"\w* \w them|strong="H7971"\w* \w to|strong="H7971"\w* \w report|strong="H1697"\w* \w it|strong="H8033"\w* \w to|strong="H7971"\w* \w me|strong="H7971"\w*.”
\p 
\v 37 So \w David|strong="H1732"\w*’s \w friend|strong="H7463"\w* \w Hushai|strong="H2365"\w* returned \w to|strong="H3389"\w* \w the|strong="H1732"\w* \w city|strong="H5892"\w*, \w at|strong="H1732"\w* \w the|strong="H1732"\w* same time \w that|strong="H5892"\w* Absalom \w was|strong="H1732"\w* entering \w Jerusalem|strong="H3389"\w*.
\c 16
\s1 Ziba gave food to David and the others
\p 
\v 1 \w When|strong="H5674"\w* \w David|strong="H1732"\w* \add and the others\add* \w had|strong="H1732"\w* \w gone|strong="H5674"\w* \w a|strong="H3068"\w* \w little|strong="H4592"\w* \w way|strong="H5674"\w* \w past|strong="H5674"\w* \w the|strong="H5921"\w* \w top|strong="H7218"\w* \w of|strong="H7218"\w* \w the|strong="H5921"\w* hill, \w Mephibosheth|strong="H4648"\w*’s \w servant|strong="H5288"\w* \w Ziba|strong="H6717"\w* \w met|strong="H7122"\w* \w him|strong="H5921"\w*. \w He|strong="H1732"\w* \w had|strong="H1732"\w* \w with|strong="H5921"\w* \w him|strong="H5921"\w* \w two|strong="H6776"\w* \w donkeys|strong="H2543"\w* \w that|strong="H5288"\w* \w were|strong="H1732"\w* carrying 200 \w loaves|strong="H3899"\w* \w of|strong="H7218"\w* \w bread|strong="H3899"\w*, 100 \w bunches|strong="H6778"\w*/\w clusters|strong="H6778"\w* \w of|strong="H7218"\w* \w raisins|strong="H6778"\w*, 100 \w bunches|strong="H6778"\w* \w of|strong="H7218"\w* fresh \w fruit|strong="H7019"\w*, \w and|strong="H3967"\w* \w a|strong="H3068"\w* leather bag \w full|strong="H7218"\w* \w of|strong="H7218"\w* \w wine|strong="H3196"\w*.
\p 
\v 2 \w The|strong="H8354"\w* \w king|strong="H4428"\w* said \w to|strong="H4428"\w* \w Ziba|strong="H6717"\w*, “\w What|strong="H4100"\w* \w are|strong="H4100"\w* \w these|strong="H4428"\w* \w for|strong="H1004"\w*?” \w Ziba|strong="H6717"\w* replied, “\w The|strong="H8354"\w* \w donkeys|strong="H2543"\w* \w are|strong="H4100"\w* \w for|strong="H1004"\w* \w your|strong="H8354"\w* \w family|strong="H1004"\w* \w to|strong="H4428"\w* \w ride|strong="H7392"\w* \w on|strong="H7392"\w*, \w the|strong="H8354"\w* \w bread|strong="H3899"\w* \w and|strong="H4428"\w* \w the|strong="H8354"\w* \w fruit|strong="H7019"\w* \w are|strong="H4100"\w* \w for|strong="H1004"\w* \w your|strong="H8354"\w* \w soldiers|strong="H5288"\w* \w to|strong="H4428"\w* \w eat|strong="H3899"\w*, \w and|strong="H4428"\w* \w the|strong="H8354"\w* \w wine|strong="H3196"\w* \w is|strong="H4100"\w* \w for|strong="H1004"\w* them \w to|strong="H4428"\w* \w drink|strong="H8354"\w* when \w they|strong="H4100"\w* become exhausted \w in|strong="H1004"\w* \w the|strong="H8354"\w* \w desert|strong="H4057"\w*.”
\p 
\v 3 \w The|strong="H3588"\w* \w king|strong="H4428"\w* said, “\w Where|strong="H1004"\w* \w is|strong="H3117"\w* Mephibosheth, \w the|strong="H3588"\w* \w grandson|strong="H1121"\w* \w of|strong="H1121"\w* \w your|strong="H7725"\w* \add former\add* \w master|strong="H3427"\w* \add Saul\add*?” \w Ziba|strong="H6717"\w* \add deceived David by\add* saying, “\w He|strong="H3588"\w* \w stayed|strong="H3427"\w* \w in|strong="H3427"\w* \w Jerusalem|strong="H3389"\w*, \w because|strong="H3588"\w* \w he|strong="H3588"\w* thinks \w that|strong="H3588"\w* \w now|strong="H3117"\w* \w the|strong="H3588"\w* Israeli \w people|strong="H1121"\w* \w will|strong="H4428"\w* allow \w him|strong="H7725"\w* \w to|strong="H7725"\w* \w rule|strong="H4428"\w* \w the|strong="H3588"\w* \w kingdom|strong="H4468"\w* \w that|strong="H3588"\w* \w his|strong="H7725"\w* grandfather Saul \w ruled|strong="H4428"\w*.”
\p 
\v 4 \w The|strong="H3605"\w* \w king|strong="H4428"\w* said \w to|strong="H4428"\w* \w Ziba|strong="H6717"\w*, “Okay, \w everything|strong="H3605"\w* \w that|strong="H3605"\w* belonged \w to|strong="H4428"\w* \w Mephibosheth|strong="H4648"\w* \w is|strong="H2009"\w* \w now|strong="H2009"\w* yours.” \w Ziba|strong="H6717"\w* replied, “\w Your|strong="H3605"\w* Majesty, \w I|strong="H2009"\w* \w will|strong="H4428"\w* \w humbly|strong="H7812"\w* serve \w you|strong="H3605"\w*; \w and|strong="H4428"\w* \w I|strong="H2009"\w* desire/hope \w that|strong="H3605"\w* \w you|strong="H3605"\w* \w will|strong="H4428"\w* \w always|strong="H3605"\w* \w be|strong="H5869"\w* \w pleased|strong="H5869"\w* \w with|strong="H4428"\w* \w me|strong="H4672"\w*.”
\s1 Shimei cursed David
\p 
\v 5 \w When|strong="H5704"\w* \w King|strong="H4428"\w* \w David|strong="H1732"\w* \add and those with him\add* arrived \w at|strong="H1004"\w* Bahurim \add town\add*, \w a|strong="H3068"\w* \w man|strong="H1121"\w* \w named|strong="H8034"\w* \w Shimei|strong="H8096"\w* met \w him|strong="H3318"\w*. \w Shimei|strong="H8096"\w*, \w whose|strong="H1121"\w* \w father|strong="H1121"\w* \w was|strong="H8034"\w* \w Gera|strong="H1617"\w*, \w was|strong="H8034"\w* \w one|strong="H1121"\w* \w of|strong="H1121"\w* \w Saul|strong="H7586"\w*’s \w relatives|strong="H4940"\w*. \w Shimei|strong="H8096"\w* \w was|strong="H8034"\w* \w cursing|strong="H7043"\w* \w David|strong="H1732"\w* \w as|strong="H5704"\w* \w he|strong="H5704"\w* approached.
\v 6 \w Then|strong="H4428"\w* \w he|strong="H3605"\w* \w threw|strong="H5619"\w* \w stones|strong="H5619"\w* \w at|strong="H1732"\w* \w David|strong="H1732"\w* \w and|strong="H4428"\w* \w his|strong="H3605"\w* \w officials|strong="H5650"\w*, even though \w the|strong="H3605"\w* \w officials|strong="H5650"\w* \w and|strong="H4428"\w* \w David|strong="H1732"\w*’s bodyguards surrounded \w David|strong="H1732"\w*.
\v 7 \w Shimei|strong="H8096"\w* \w cursed|strong="H7043"\w* David \w and|strong="H1818"\w* \w said|strong="H3318"\w* \w to|strong="H3318"\w* \w him|strong="H3318"\w*, “\w Get|strong="H3318"\w* \w out|strong="H3318"\w* \w of|strong="H1818"\w* \w here|strong="H3541"\w*, \w you|strong="H3318"\w* murderer, \w you|strong="H3318"\w* scoundrel!
\v 8 \w Yahweh|strong="H3068"\w* \w is|strong="H3068"\w* ◄getting revenge \w on|strong="H5921"\w*/\w punishing|strong="H7725"\w*► \w you|strong="H3588"\w* \w all|strong="H3605"\w* \w for|strong="H3588"\w* murdering [MTY] many \w people|strong="H1121"\w* \w in|strong="H5921"\w* \w Saul|strong="H7586"\w*’s \w family|strong="H1004"\w*. \w And|strong="H1121"\w* \w now|strong="H3588"\w* \w he|strong="H3588"\w* \w is|strong="H3068"\w* \w giving|strong="H5414"\w* \w Saul|strong="H7586"\w*’s \w kingdom|strong="H4410"\w* \w to|strong="H7725"\w* \w your|strong="H3068"\w* \w son|strong="H1121"\w* Absalom. \w You|strong="H3588"\w* murderer, \w you|strong="H3588"\w* \w are|strong="H1121"\w* \w being|strong="H4427"\w* \w paid|strong="H5414"\w* \w back|strong="H7725"\w* \w for|strong="H3588"\w* \w the|strong="H3605"\w* many \w people|strong="H1121"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w have|strong="H3068"\w* killed/murdered [MTY]!”
\p 
\v 9 \w Then|strong="H2088"\w* Abishai said \w to|strong="H4191"\w* \w the|strong="H5674"\w* \w king|strong="H4428"\w*, “\w Your|strong="H4994"\w* Majesty, \w this|strong="H2088"\w* \w man|strong="H1121"\w* \w is|strong="H2088"\w* \add as worthless as\add* [MET] \w a|strong="H3068"\w* \w dead|strong="H4191"\w* \w dog|strong="H3611"\w*! ◄\w Why|strong="H4100"\w* \w should|strong="H4100"\w* \w he|strong="H2088"\w* \w be|strong="H4191"\w* allowed \w to|strong="H4191"\w* \w curse|strong="H7043"\w* \w you|strong="H4100"\w*?/\w He|strong="H2088"\w* \w should|strong="H4100"\w* \w not|strong="H2088"\w* \w be|strong="H4191"\w* allowed \w to|strong="H4191"\w* \w curse|strong="H7043"\w* \w you|strong="H4100"\w*.► [RHQ] \w Allow|strong="H4994"\w* \w me|strong="H4994"\w* \w to|strong="H4191"\w* \w go|strong="H5674"\w* \w over|strong="H5674"\w* \w there|strong="H2088"\w* \w and|strong="H1121"\w* \w cut|strong="H5493"\w* \w off|strong="H5493"\w* \w his|strong="H5493"\w* \w head|strong="H7218"\w*!”
\p 
\v 10 \w But|strong="H3588"\w* \w the|strong="H3588"\w* \w king|strong="H4428"\w* replied, “\w You|strong="H3588"\w* \w two|strong="H6213"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Zeruiah|strong="H6870"\w*, ◄\w do|strong="H6213"\w* \w not|strong="H6213"\w* tell \w me|strong="H6213"\w* \w what|strong="H4100"\w* \w to|strong="H3068"\w* \w do|strong="H6213"\w*/\w this|strong="H3651"\w* \w does|strong="H6213"\w* \w not|strong="H6213"\w* concern \w you|strong="H3588"\w*► [RHQ]. \w If|strong="H3588"\w* \w he|strong="H3588"\w* \w is|strong="H3068"\w* \w cursing|strong="H7043"\w* \w me|strong="H6213"\w* \w because|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w told|strong="H6213"\w* \w him|strong="H6213"\w* \w to|strong="H3068"\w* \w do|strong="H6213"\w* \w that|strong="H3588"\w*, \w certainly|strong="H3588"\w* \w no|strong="H6213"\w* \w one|strong="H1121"\w* \w should|strong="H3068"\w* say ‘◄\w Why|strong="H4100"\w* \w are|strong="H1121"\w* \w you|strong="H3588"\w* \w doing|strong="H6213"\w* \w that|strong="H3588"\w*?/\w You|strong="H3588"\w* \w should|strong="H3068"\w* \w not|strong="H6213"\w* \w be|strong="H3068"\w* \w doing|strong="H6213"\w* \w that|strong="H3588"\w*.► [RHQ]’”
\p 
\v 11 \w Then|strong="H2009"\w* \w David|strong="H1732"\w* \w said|strong="H3318"\w* \w to|strong="H3318"\w* Abishai \w and|strong="H1121"\w* \w to|strong="H3318"\w* \w all|strong="H3605"\w* \w his|strong="H3605"\w* \w officials|strong="H5650"\w*, “\w You|strong="H3588"\w* know \w that|strong="H3588"\w* \w my|strong="H3605"\w* \w own|strong="H5315"\w* \w son|strong="H1121"\w* \w is|strong="H3068"\w* trying \w to|strong="H3318"\w* kill \w me|strong="H5315"\w*. \w So|strong="H3318"\w* \add it is not surprising that\add* \w this|strong="H6258"\w* \w man|strong="H1121"\w* \w from|strong="H3318"\w* \w the|strong="H3605"\w* tribe \w of|strong="H1121"\w* \w Benjamin|strong="H1145"\w* \w is|strong="H3068"\w* \w also|strong="H3068"\w* trying \w to|strong="H3318"\w* kill \w me|strong="H5315"\w*. \w So|strong="H3318"\w* ignore \w him|strong="H3318"\w*, \w and|strong="H1121"\w* \w allow|strong="H3240"\w* \w him|strong="H3318"\w* \w to|strong="H3318"\w* \w curse|strong="H7043"\w* \w me|strong="H5315"\w*, \w because|strong="H3588"\w* \add perhaps he thinks that\add* \w Yahweh|strong="H3068"\w* told \w him|strong="H3318"\w* \w to|strong="H3318"\w* \w do|strong="H3068"\w* \w that|strong="H3588"\w*.
\v 12 Perhaps \w Yahweh|strong="H3068"\w* \w will|strong="H3068"\w* \w see|strong="H7200"\w* \w that|strong="H7200"\w* \w I|strong="H3117"\w* \w am|strong="H3068"\w* having \w all|strong="H7200"\w* \w this|strong="H2088"\w* \w trouble|strong="H2088"\w*, \w and|strong="H3068"\w* \add some day he will repay me by\add* ◄blessing/doing \w good|strong="H2896"\w* \w things|strong="H2896"\w* \w for|strong="H8478"\w*► \w me|strong="H7725"\w* \w in|strong="H3068"\w* \w return|strong="H7725"\w* \w for|strong="H8478"\w* \w this|strong="H2088"\w* \w man|strong="H2896"\w* \w cursing|strong="H7045"\w* \w me|strong="H7725"\w* \w today|strong="H3117"\w*.”
\v 13 \w Then|strong="H1980"\w* \w David|strong="H1732"\w* \w and|strong="H1980"\w* \w those|strong="H1980"\w* \w who|strong="H1980"\w* \w were|strong="H2022"\w* \w with|strong="H1980"\w* \w him|strong="H5619"\w* \w walked|strong="H1980"\w* \w along|strong="H1980"\w* \w the|strong="H1870"\w* \w road|strong="H1870"\w*, \w and|strong="H1980"\w* \w Shimei|strong="H8096"\w* \w continued|strong="H1980"\w* \w walking|strong="H1980"\w* \w along|strong="H1980"\w* \w the|strong="H1870"\w* \w hillside|strong="H6763"\w* near \w him|strong="H5619"\w*. While \w he|strong="H1732"\w* \w walked|strong="H1980"\w* \w along|strong="H1980"\w*, \w he|strong="H1732"\w* \w cursed|strong="H7043"\w* \w David|strong="H1732"\w* \w and|strong="H1980"\w* \w threw|strong="H5619"\w* \w stones|strong="H5619"\w* \w and|strong="H1980"\w* \w dirt|strong="H6083"\w* \w at|strong="H1732"\w* \w him|strong="H5619"\w*.
\v 14 When \w David|strong="H5314"\w* \w and|strong="H4428"\w* \w those|strong="H3605"\w* \w who|strong="H3605"\w* \w were|strong="H5971"\w* \w with|strong="H5971"\w* \w him|strong="H3605"\w* arrived \w at|strong="H4428"\w* \w the|strong="H3605"\w* Jordan \add River\add*, \w they|strong="H8033"\w* \w were|strong="H5971"\w* very \w tired|strong="H5889"\w*. \w So|strong="H8033"\w* \w they|strong="H8033"\w* rested \w there|strong="H8033"\w*.
\s1 Ahithophel gave advice to Absalom
\p 
\v 15 While \w that|strong="H5971"\w* \w was|strong="H3478"\w* happening, Absalom \w and|strong="H3478"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* Israeli \w people|strong="H5971"\w* \w who|strong="H3605"\w* \w were|strong="H3478"\w* \w with|strong="H3389"\w* \w him|strong="H3605"\w* \w had|strong="H3478"\w* arrived \w in|strong="H3478"\w* \w Jerusalem|strong="H3389"\w*. Ahithophel \w had|strong="H3478"\w* \w also|strong="H3478"\w* arrived \w there|strong="H3605"\w*.
\v 16 \w When|strong="H1961"\w* \w David|strong="H1732"\w*’s \w friend|strong="H7463"\w* \w Hushai|strong="H2365"\w* \w came|strong="H1961"\w* \w to|strong="H1961"\w* Absalom, \w he|strong="H1732"\w* said \w to|strong="H1961"\w* Absalom, “\w I|strong="H1961"\w* desire/hope \w that|strong="H4428"\w* \w the|strong="H1961"\w* \w king|strong="H4428"\w* \w will|strong="H1961"\w* \w live|strong="H2421"\w* \w a|strong="H3068"\w* long \w time|strong="H1961"\w*! \w May|strong="H1961"\w* \w you|strong="H2421"\w* \w live|strong="H2421"\w* \w for|strong="H4428"\w* many years!”
\p 
\v 17 Absalom said \w to|strong="H1980"\w* \w Hushai|strong="H2365"\w*, “\w You|strong="H3808"\w* \w have|strong="H3808"\w* \w been|strong="H3808"\w* \w loyal|strong="H2617"\w* [RHQ] \w to|strong="H1980"\w* \w your|strong="H3808"\w* \w friend|strong="H7453"\w* \add David for a long time\add*. \w So|strong="H1980"\w* \w why|strong="H4100"\w* \w did|strong="H4100"\w* \w you|strong="H3808"\w* \w not|strong="H3808"\w* \w go|strong="H1980"\w* \w with|strong="H1980"\w* \w him|strong="H1980"\w* \add instead of coming to me\add*?”
\p 
\v 18 \w Hushai|strong="H2365"\w* replied, “\w I|strong="H3588"\w* \w will|strong="H3068"\w* \w serve|strong="H1961"\w* \w the|strong="H3605"\w* \w one|strong="H2088"\w* \w whom|strong="H5971"\w* \w Yahweh|strong="H3068"\w* \w and|strong="H3478"\w* \w these|strong="H2088"\w* \w people|strong="H5971"\w* \w and|strong="H3478"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w other|strong="H2088"\w* \w people|strong="H5971"\w* \w of|strong="H3068"\w* \w Israel|strong="H3478"\w* \w have|strong="H1961"\w* chosen \add to be their king\add*. \w So|strong="H1961"\w* \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w stay|strong="H3427"\w* \w with|strong="H3068"\w* \w you|strong="H3588"\w*.
\v 19 \w You|strong="H6440"\w* \w are|strong="H1121"\w* \w my|strong="H1961"\w* master \add King David’s\add* \w son|strong="H1121"\w*; \w if|strong="H1961"\w* \w I|strong="H3651"\w* \w do|strong="H5647"\w* \w not|strong="H3808"\w* \w serve|strong="H5647"\w* \w you|strong="H6440"\w*, \w what|strong="H4310"\w* \w other|strong="H8145"\w* \w man|strong="H1121"\w* \w should|strong="H4310"\w* \w I|strong="H3651"\w* \w serve|strong="H5647"\w* [RHQ]? \w I|strong="H3651"\w* \w will|strong="H4310"\w* \w serve|strong="H5647"\w* \w you|strong="H6440"\w* \w as|strong="H1961"\w* \w I|strong="H3651"\w* \w served|strong="H5647"\w* \w your|strong="H6440"\w* \w father|strong="H1121"\w*.”
\p 
\v 20 \w Then|strong="H6213"\w* Absalom said \w to|strong="H6213"\w* Ahithophel, “\w What|strong="H4100"\w* \w do|strong="H6213"\w* \w you|strong="H6213"\w* advise \w that|strong="H6213"\w* \w we|strong="H3068"\w* \w should|strong="H4100"\w* \w do|strong="H6213"\w*?”
