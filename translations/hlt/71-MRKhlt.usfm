\p \w Tedae|strong="G1161"\w* \w amih|strong="G3588"\w* loh a \w hil|strong="G4623"\w* a phah uh.  
\v 5 Te \w dongah|strong="G2532"\w* \w amih|strong="G0848"\w* te \w thintoek|strong="G3709"\w* \w neh|strong="G3326"\w* a \w sawt|strong="G4017"\w*. \w Amih|strong="G0846"\w* \w thinko|strong="G2588"\w* \w kah|strong="G3588"\w* \w thinthahnah|strong="G4457"\w* \w soah|strong="G1909"\w* a \w kothae|strong="G4818"\w*. Tekah \w hlang|strong="G0444"\w* \w te|strong="G3588"\w*, \wj “ Na \+w kut|strong="G5495"\+w* \+w te|strong="G3588"\+w* \+w yueng|strong="G1614"\+w* lah,” \wj* a \w ti|strong="G3004"\w* nah.  
\p A \w yueng|strong="G1614"\w* \w tangloeng|strong="G2532"\w* \w tih|strong="G2532"\w* \w a|strong="G0846"\w* \w kut|strong="G5495"\w* khaw \w hoeih|strong="G0600"\w*.  
\v 6 \w Tedae|strong="G2532"\w* \w Pharisee|strong="G5330"\w* rhoek \w tah|strong="G3588"\w* \w Herod|strong="G2265"\w* kah hlang rhoek \w taengla|strong="G3326"\w* \w tlek|strong="G2117"\w* \w cet|strong="G1831"\w* uh tih \w Jesuh|strong="G2424"\w* \w poci|strong="G0622"\w* \w ham|strong="G3704"\w* \w dawtletnah|strong="G4824"\w* a \w khueh|strong="G1325"\w* \w thil|strong="G2596"\w* uh.   
