\id PHP
\h Filipenses
\toc1 DIZRA' BZUAJ SAN PABLO CHEE̱ BI CHEE̱ CRISTO ZAJ ZRE̱'E̱ XE̱ZRE FILIPOS
\toc2 Filipenses
\toc3 Fil.
\mt1 DIZRA' BZUAJ SAN PABLO CHEE̱ BI CHEE̱ CRISTO ZAJ ZRE̱'E̱ XE̱ZRE FILIPOS
\c 1
\s1 Pablo dxugape̱' diuzre bi bíchedxu ca' zaj zre̱'e̱ xe̱zre Filipos
\p 
\v 1 Neda' Pablo, ne Timoteo nácantu' we̱n zrin chee̱ Jesucristo. Dxuzúaja' da nigá chee̱le le'e, bi bíchentu', ne chee̱le le'e, dxuxúele bi chee̱ Cristo, ne le'e, zaj xu'u lu na'le bi chee̱ Cristo, ne zrale xe̱zre Filipos. Nabábale chee̱ Dios, ne nácale tuze nen Jesucristo.
\v 2 Dxenábantu' lau Xradxu Dios, ne lau Xránadxu Jesucristo gune̱' chee̱le da xrlátaje, ne gunne̱' le'e xel-la dxebeza zri lazre'.
\s1 Da dxenaba Pablo gun Dios chee̱ bi ca' chee̱ Cristo
\p 
\v 3 Tu tu lasa dxajsá lazra' le'e dxapa' Dios chia': Xcalenu'.
\v 4 Gate dxuchálajle̱na' Dios, dute̱ xel-la dxebé dxenábaqueza' bi gun Le̱' chee̱ xúgute̱le le'e.
\v 5 Caní dxuna' lawe' da dxundxu zrin tu zren chee̱ dizra' chawe' chee̱ Cristo gate guzú lau núnbe̱'tu' na bzrinte̱ lu zra na'a zra.
\v 6 Dxuxrén lazra' Dios, Bénnea' guzú lawe̱' dxune̱' tu zrin chawe' lu xichaj lázrdaule le'e, gúnqueze̱' na ca zrinte̱ zra xelá' Jesucristo.
\v 7 Naca xrlátaje dxéqueda' neda' caní chee̱ xúgute̱le le'e, lawe' da nazrí'ile̱'e̱da' le'e, ne dxezidxu tu zren da chawe' ca' dxunna Dios dxi'u. Dxácate̱ ne xu'a lizre xia nigá, ne gate na' gudíl-lale̱na' bénneache ca' dizra', benne' ca' guledábague̱' dizra' chawe' chee̱ Cristo, ba ble'eda' benne' ca' naca na da li.
\v 8 Dios nézquezene̱' nazrí'ile̱'e̱da' le'e, lu dute̱ xel-la zri'i lazre' da dxunna Jesucristo neda'.
\v 9 Dxenaba' lau Dios gune̱' zrí'idxa ljwézrele, ne gápale̱'e̱quezle xel-la sina, ne xel-la dxéajni'i lu xúgute̱ da dxunle,
\v 10 chee̱ nézele cuele da cháwedxa, chee̱ gácale du lazre', ne quebe bi gata' da gagu na zria chee̱le lu zra na' xelá' Cristo.
\v 11 Caní gaca, da ca' dxunle xululé'e na da xrlátaje da dxun Jesucristo lu xichaj lázrdaule, chee̱ gaca ba lá'ana Dios, ne xegá'ana szrénqueze̱'.
\s1 Dxenná Pablo: Che naca bana', Cristo dxuchínene̱' neda'
\p 
\v 12 Le'e, bi bícha'dau', dxaca lazra' nézele ca da ca' guzraca' gulácale̱ na neda' chee̱ bchálaja' dizra' chawe' chee̱ Cristo.
\v 13 Caní guca, xúgute̱ benne' xra'aga xu'u lawe', ne xezícadxa benne' ca' zaj zre̱'e̱ xu'u lawe' na' zaj nézene̱' xu'a lizre xia lawe' da dxuna' zrin chee̱ Cristo.
\v 14 Lawe' da xu'a neda' lizre xia nigá, chaze xúgute̱ bi bíchedxu ca' dxuluxrén lázredxe̱' Xránadxu, na' dxuluchálaje̱' du lazre̱' dizra' chee̱ Dios, ne quebe dxelezrebe̱'.
\p 
\v 15 Da li bal-la benne' ca' dxuluchálaje̱' ca naca chee̱ Cristo lawe' da zaj naque̱' zre'e lazre', ne zaj naque̱' wil-la dizra'. Xezícadxa benne' caní dxuluchálaje̱' na dute̱ xel-la li lazre' chee̱'.
\v 16 Benne' nedxu ca' dxuluchálaje̱' da naca chee̱ Cristo chee̱ xulucá'ana szren cuine̱', ne quegá du lazre̱', lawe' da dxelaca lazre̱' súadxa da guzúa na neda' ste̱be dxácate̱ xu'a lizre xia nigá.
\v 17 Xezícadxa benne' ca' dxelune̱' na dute̱ xel-la zri'i lazre' chee̱', lawe' da zaj nézene̱' nuzúa cuina' guzéajni'ida' benne' ca' dxeledábague̱' dizra' chawe' chee̱ Cristo.
\v 18 ¿Bizra xca'? Ájate̱zla dxelune̱', che dxuluchálaje̱' du lazre̱', u quebe dxuluchálaje̱' du lazre̱', dxuluchálaje̱' chee̱ Cristo, na' dxebeda', ne wabéquezda'
\v 19 lawe' da nezda' lu xúgute̱ da caní wedxúaj na chawe' chia' neda', lawe' da dxenábale le'e lau Dios chia' neda', na' gácale̱ Be' Lá'azxa neda', Bénnea' gusel-le̱' Jesucristo chee̱dxu.
\v 20 Dxaca lazra', ne dxuxrén lazra' quebe xedué'eda' neda', séqueda' guchálaja' du lazra' chee̱ xelelé'e bénneache zúale̱dxa xel-la szren chee̱ Cristo neda' na'a, ca zúale̱queze na neda', che gaca bana', u che gatia'.
\v 21 Chia' neda', che naca bana', Cristo dxuchínene̱' neda', ne che gatia' wazrue'eda' da cháwedxa.
\v 22 Che xedxúaj na chawe' chee̱ zrin chee̱ Xránadxu che naca bana', quebe nezda' bila na ca'a.
\v 23 Naca na ste̱be chia' neda' bila da caní ca'a. Dxaca lazra' gatia' chee̱ cheajsúale̱na' Cristo, da gácadxa chawe' chia' neda',
\v 24 san che naca bana' nácadxa chawe' chee̱le le'e.
\v 25 Lawe' da nuxrén lazra' naca caní, nezda' wazúale̱dxa' le'e chee̱ se̱ cháchadxale lu da naca chee̱ Cristo, ne chee̱ béquezdxale.
\v 26 Chee̱ le̱ na' bédxale lu da naca chee̱ Cristo ne̱ chia' neda' gate súale̱na' le'e.
\p 
\v 27 Dxun na ba xen gunle da dxuzéajni'i dizra' chawe' chee̱ Cristo le'e, na' che xedajnná'a le'e, u che sua' zitu', wenda' ze̱ cháchale, ne nácale tuze, dxunle tu zren zrin chee̱ Cristo chee̱ xeleajlí lazre' bénneache dizra' chawe' chee̱'.
\v 28 Quebe zrébele benne' ca' dxeledábague̱' le'e. Ca dxunle gulé'e na le̱' xelebía xi'e̱, na' nalale le'e lawe' da bselá Dios le'e.
\v 29 Tu da zrente̱ naca da dxunna Dios le'e gate gunle zrin chee̱ Cristo, quegaze chéajle̱le chee̱', na' cá'anqueze che tele xel-la zi' ne̱ chee̱ Le̱'.
\v 30 Le'e dxunle neda' tu zren dxedíl-lale̱dxu da zaj naca da cale̱la. Blé'equezle gate nate ca gudíl-lale̱na' na, na' na'a dxenle ca dxedíl-lale̱na' na.
\c 2
\s1 Xel-la dxexruj lazre', ne xel-la szren chee̱ Cristo
\p 
\v 1 Cristo dxutipe̱' lázrele, na' xel-la zri'i lazre' chee̱' dxuzúa na le'e lu da ba neza, na' Be' Lá'azxa chee̱' zúale̱ne̱' le'e, na' nápale xel-la zri'i lazre', ne xel-la dxexache lazre' chee̱'.
\v 2 Chee̱ le̱ na' le gun ga béle̱'e̱da', gaca tuze ca da dxéquele, ne gácale tuze lu xel-la zri'i lazre' chee̱le, ne gunle tuze lu xichaj lázrdaule.
\v 3 Quebe bi gunle chee̱ xulucá'ana szren bénneache le'e, ne chee̱ gaca gucá'ana szren cuínale, san dute̱ xel-la dxexruj lazre' chee̱le dxal-la' guéquele nácadxa blau le sa' ljwézrele ca le'e.
\v 4 Netule le'e quebe dxal-la' gunle ca da gácale̱n le'eze. Le gun da gácale̱n na xezícadxa bénneache.
\p 
\v 5 Dxal-la' si' lu na'le da gaca na chee̱le ca be̱n Jesucristo.
\v 6 Lácala naque̱' ca nácaqueze Dios, quebe gúquene̱' dxal-la' gune̱' ba xuzre xegá'anaqueze̱' ca Dios.
\v 7 Bzue̱' chalá'ala da nápaqueze̱', ne be̱n cuine̱' ca tu benne' nada'u, guque̱' bénneache.
\v 8 Gate ba naque̱' bénneache, guque̱' dxexruj lazre', na' bzue̱' dizra' chee̱ Dios ca bzrinte̱ gutie̱', lácala gutie̱' ca tu benne' we̱n da cale̱la le̱'e̱ xaga béguaj.
\v 9 Chee̱ le̱ na' Dios bca'ana szrénle̱'e̱ Le̱', ne bzue̱' tu Le̱' da naca szrendxa ca xúgute̱ la xezícadxa,
\v 10 chee̱ gate xelenne̱' La Jesús, na' xuluzú zribe lau Le̱' xúgute̱ benne' zaj zre̱'e̱ xabáa, ne xe̱zr la xu nigá, ne zran xe̱zr la xu nigá,
\v 11 ne chee̱ xelexeche̱be xúgute̱' naca Jesucristo Xránadxu, chee̱ gaca ba lá'ana Xradxu Dios.
\s1 Bi chee̱ Cristo zaj nácabe' ca xi' da dxulusení na
\p 
\v 12 Chee̱ le̱ na', le'e, bi bicha' nazri'ite̱ lazra', ca na' be̱nle le'e, bzúaquezle dizra' chee̱ Dios gate na' zúale̱na' le'e, le guzúadxa dizra' chee̱ Dios na'a gate zua' zitu'. Dute̱ xel-la dxexruj lazre', ne dute̱ xel-la dxezrebe le gun zrin chee̱ zrué'ele dute̱ ca naca xel-la weselá chee̱le,
\v 13 lawe' da dxun Dios zrin lu xichaj lázrdaule chee̱ sa lázrele gunle da xrlátaje da dxaca lazre' Le̱', ne chee̱ séquele gunle na.
\p 
\v 14 Le gun xúgute̱ da dxunle, ne quebe gáchajele, ne quebe gutil-la dizra' ljwézrele
\v 15 chee̱ gácale li lazre', ne quebe nu nne̱ chee̱le. Gácale bi chee̱ Dios du lazre' ládujla bénneache zaj naque̱' benne' dxelún da cale̱la, ne gácale ca belaj ca' dxulusení na lu xe̱zr la xu naga nachul-la na,
\v 16 ne guchálajle̱le benne' ca' dizra' da nua na xel-la nabán. Che gunle caní, neda' wezaca ba lazra' chee̱le gate xelá' Cristo, lawe' da wanezda' quebe be̱n zi' lazra' dácheze, ne quebe be̱na' zrin níteze.
\v 17 Béle̱'e̱da' lácala gun na ba xen gatia' chee̱ gaca li lazre' xel-la dxeajlí lazre' chee̱le lau Dios. Bzua cuínale lu na' Dios ca tu guna' da gúnnale chee̱', na' chee̱ le̱ na' béle̱'e̱quezda' tu zren nen xúgute̱le le'e.
\v 18 Le béquezle le'e, ne le gun tuze neda' lu xel-la dxebé chia'.
\s1 Ca naca chee̱ Timoteo, ne Epafrodito
\p 
\v 19 Che naca da dxaca lazre' Xránadxu Jesús, dxebeza lazra' sél-laze̱queza' Timoteo xedajnná'abe' le'e, chee̱ beda' gate xelabe', ne guzenbe' neda' chee̱le le'e.
\v 20 Quebe nu chilá' xetú benne' guéquene̱' chee̱le ca da dxéqueda' neda'. Tuze Timoteo dxe'ebe' gunne xue chee̱ gaca chawe' chee̱le le'e.
\v 21 Xúgute̱ benne' ca' xezícala zaj dxe'e̱ gunne xue da zaj naca chee̱ze̱', ne quebe zaj dxe'e̱ gunne xue da naca chee̱ Jesucristo.
\v 22 Le'e nézquezle ca da xrlátaje dxun Timoteo, ne ca be̱nbe' zrin tu zren nen neda'. Dxuchálajntu' dizra' chawe' chee̱ Cristo, na' dxunbe' ca dxun tu bi dxácale̱be' xrabe'.
\v 23 Caní naca, dxebeza lazra' sel-la'-be' gate nezda' ca gaca chia'.
\v 24 Dxuxrén lazra' Xránadxu, néda'queza' xida' xedajnná'a le'e.
\p 
\v 25 Cá'anqueze dxéqueda' dxun na ba xen sel-la' Epafrodito, bi bíchedxu. Dxunbe' zrin tu zren nen neda', dxedíl-lale̱ntu' da cale̱la. Lé'equezle gusél-lale bi nigá chee̱ gácale̱nbe' neda', ne xu'a lizre xia nigá.
\v 26 Dxezá lázrele̱'e̱be' xedajnna'abe' le'e, ne zúale̱'e̱be' ste̱be lawe' da nézebe' bénele quebe chawe' guzúabe'.
\v 27 Da li quebe chawe' guzúabe', ne bache gátebe', san Dios bexache lazre̱' le̱be', ne quegá tuze le̱be', cá'anqueze neda' chee̱ quebe xewine lázredxa' ca da dxaca chia' na'a.
\v 28 Chee̱ le̱ na' dxezá lázredxa' sel-la' le̱be' chee̱ bele le'e gate xelé'ele le̱be', ne chee̱ québedxa xewine lazra' neda'.
\v 29 Le xezí' lu na'le le̱be' dute̱ xel-la dxebé, ca bi bíchele lu da naca chee̱ Xránadxu, ne le gápaqueze ba lá'ana benne' ca' zaj naque̱' ca le̱be',
\v 30 lawe' da guzúa gátebe' dxunbe' zrin chee̱ Cristo. Bzuabe' lu da ste̱be xel-la nabán chee̱be' chee̱ gunbe' zrin chia' da quebe guzéquele le'e gunle.
\c 3
\s1 Da naca chawe' da naca na du lazre'
\p 
\v 1 Na'a, bi bicha', le be lu da naca chee̱ Xránadxu. Quebe naca na ze̱de chia' neda' guzúaja' chee̱le xecha lasa ca da ba bzúajqueza', lawe' da dxun na ba xen guna' da nigá chee̱le.
\v 2 Le guxúe cuínale chee̱ benne' ca' dxelune̱' da cale̱la, ne zaj naque̱' ca becu', benne' ca' dxelechugue̱' lu be̱l-la' dxen da na' naca bea na benne' zaj naque̱' chee̱ Dios.
\v 3 Dxi'u nácadxu benne' nápaquezdxu da dxunna bea na nácadxu chee̱ Dios, ne dxue lá'anadxu Dios ne̱ chee̱ Be' Lá'azxa, ne dxebedxu lawe' da nácadxu bi chee̱ Jesucristo. Quebe dxuxrén lázredxu da dxundxu,
\v 4 lácala neda' wazéqueda' guxrén lazra' da ca' nuna'. Che nu benne' dxéquene̱' waca guxrén lazre̱' ca da ba nune̱', wazéquedxeda' neda'.
\v 5 Gate gúqueda' xrunu' zra gulechugue̱' lu be̱l-la' dxen chia' da na' dxulé'e na naca' chee̱ Dios lawe' da naca' benne' Israel, ne xrtia Benjamín. Naca' da li benne' hebreo. Guca' benne' fariseo ca buzájla'a da bdxixruj be'e Moisés.
\v 6 Gudxéle̱'a gunne xue da naca chee̱ Dios ca bzrinte̱ gudáu zi' xuzra' benne' ca' zaj nácabe̱' bi chee̱ Jesús. Ca naca da xlátaje̱ da napa tu benne' dxune̱' ca dxenná da nadxixruj bea na, quebe nu benne' guzéquene̱' bi nnie̱' chia'.
\v 7 Xúgute̱ da ca' gúqueda' gate nate zaj zácale̱'e̱ na, na'a dxéqueda' da ca' quebe bi zaj zaca na, lawe' da nazrí'idxeda' Cristo.
\v 8 Da li dxéqueda' xúgute̱ da ca' ca tu da nite lawe' da zácadxa Xrana' Jesucristo. Lawe' da nazrí'ida' Le̱' ba bzua' chalá'ala xúgute̱ da gudapa', ne dxéqueda' da ca' ca tu da níteze chee̱ si'a da ba neza da dxunna Cristo,
\v 9 chee̱ gaca' tuze nen Le̱', quegá lawe' da guca' xlátaje̱ ne̱ chee̱ da nadxixruj bea na na', san lawe' da ble'e Dios neda' xlátaje̱ lawe' da dxeajlí lazra' Cristo, na' Dios dxelé'ene̱' xlátaje̱ xúgute̱ benne' dxeleajlí lazre̱' Cristo.
\v 10 Da dxaca lazra' naca na gúnbeadxa' Cristo, ne súale̱ xel-la waca neda' da bsebán na Le̱', ne tea' xel-la zi' ca da gudée̱' Le̱', ne gudé cuina' lu na' Dios lácala dxal-la' gatia' ca gute Cristo,
\v 11 na' dxebeza lazra' xebana' ládujla benne' gate ca'.
\s1 Pablo dxun zi' lazre̱' gusexuzre̱' gune' zrin chee̱ Cristo
\p 
\v 12 Quebe dxennía' ba bzrué'eda' xúgute̱ da caní, u ba naca' dute̱ xlátaje̱, san dxun zi' lazra' chee̱ zrué'eda' da na' bláwizra Jesucristo neda' chee̱ zrué'eda'.
\v 13 Le'e, bi bicha', quebe dxennía' ba bzrué'eda' da nigá, san tuze da dxuna', dxuzúa' chalá'ala da ba gudé, ne dxun zi' lazra' chee̱ zrué'eda' da za za',
\v 14 chee̱ gusexuzra' guna' zrin da dxuna', chee̱ zrué'eda' da na' bláwizra Dios dxi'u sidxu lu xabáa chee̱' lawe' da nácadxu bi chee̱ Jesucristo.
\p 
\v 15 Caní dxal-la' guéquedxu dxi'u, ze̱ cháchadxu ca naca da dxeajlí lázredxu. Che quebe dxéquele caní chee̱ bítete̱ze da caní, Dios guzéajni'ine̱' le'e ca naca chee̱ na.
\v 16 Tuze ca dxal-la' guéquedxu, ne tuze ca dxal-la' gundxu lu da ca' ba bzrué'edxu.
\p 
\v 17 Le'e, bi bícha'dau', le gun ca dxuna' neda', ne le nna' ca dxelún benne' ca', dxelune̱' ca da blé'entu' le'e.
\v 18 Zane' lasa ba gucha' le'e, ne na'a dxebézrtea' dxapa' le'e, zrále̱'e̱ bi bíchedxu dxelune̱' ca dxelún benne' dxuluzúe̱' chalá'ala da be̱n Cristo le̱'e̱ xaga béguaj.
\v 19 Ca gaca chee̱ benne' ca' lu zra bze̱be, xelebía xi'e̱. Zaj nune̱' dios chee̱ da dxelé'aj dxelawe̱', ne dxulucá'ana szren cuine̱' chee̱ da na' dxal-la' xelapa stu'e̱. Zaj dxe'e̱ gunne xue da naca chee̱ xe̱zr la xu nigaze.
\v 20 Dxi'u nácadxu benne' zaj nababe̱' xabáa, ne dxebézadxu zra xelá' benne' weselá chee̱dxu, Xránadxu Jesucristo, ze̱'e̱ xabáa.
\v 21 Le̱' xegüe̱' be̱l-la' dxen chee̱dxu da dxeledé chee̱ na, ne gune̱' na ca naca be̱l-la' dxen xabáa chee̱', guchínene̱' xel-la waca chee̱' da nape̱' chee̱ nna bé'ene̱' xúgute̱ da zaj zua.
\c 4
\s1 Dxal-la' béquezdxu lu da naca chee̱ Xránadxu
\p 
\v 1 Chee̱ le̱ na' le'e, bi nazri'ite̱ lazra', le se̱ chacha lu da naca chee̱ Xránadxu. Le'e, bi bícha'dau' nazrí'ite lazra', dxezá lázrele̱'a le'eda' le'e, lawe' da dxebeda' ca nácale le'e, na' lawe' da be̱na' neda' nácale bi chee̱ Cristo dxal-la' si'a tu da gunna Dios neda'.
\p 
\v 2 Dxata' xueda' Evodia, ne Síntique xelaque̱' tuze, lawe' da zaj naque̱' bila ne̱ chee̱ Xránadxu.
\v 3 Na'a lue', bi ljwezra' li lazre', dxata' xueda' lue' gácale̱nu' nu'ula zandxu caní, nu'ula belúnle̱ne̱' neda' zrin chee̱ dizra' chawe' chee̱ Cristo. Belune̱' zrin na' tu zren nen Clemente, ne xezícadxa benne' ca' belúnle̱ne̱' neda' zrin. La benne' caní zaj naxúaj na lu xiche chee̱ xel-la nabán zeajlí canna.
\p 
\v 4 Le béqueze lu da naca chee̱ Xránadxu. Xecha lasa dxennía': Le be.
\v 5 Dxaca lazra' xeleque be'e xúgute̱ bénneache nácale zren lazre'. Ba zua bagu zra xelá' Xránadxu.
\p 
\v 6 Quebe bi cuele gunne xue, san le guchálajle̱queze Dios ca naca chee̱ da ca'. Le naba na lau Dios, na' le xe̱'e̱: Xcalenu'.
\v 7 Nadxa gunna Dios le'e xel-la dxebeza zri lazre', da naca na szrendxa ca da seque' gúnbea bénneache, na' guzúa chuchu na xichaj lázrdaule ne̱ chee̱ Jesucristo.
\s1 Le gulaba lazre' ca naca da xrlátaje
\p 
\v 8 Na'a, bi bicha', le gulaba lazre' ca naca
\q1 xúgute̱ da zaj naca li, ne
\q1 xúgute̱ da zaj napa na ba lá'ana, ne
\q1 xúgute̱ da zaj naca na li lazre', ne
\q1 xúgute̱ da zaj naca na du lazre', ne
\q1 xúgute̱ da dxezaca ba lazre' Dios, ne
\q1 xúgute̱ da dxulucá'ana na bénneache xrlátaje.
\m Che zua tu da naca xrlátaje, u da dxal-la' gucá'ana szrendxu, le gulaba lazre' da caní.
\p 
\v 9 Le gun ca naca da bsé̱deda' le'e, ne da bzéajni'ida' le'e, ne da bzenda' le'e, ne da ble'eda' le'e, na' súale̱ Dios le'e, Bénnea' dxunne̱' dxi'u xel-la dxebeza zri lazre'.
\s1 Da gulesel-la benne' Filipos ca' chee̱ Pablo
\p 
\v 10 Dxebéle̱'e̱da' ne̱ chee̱ Xránadxu, lawe' da dxajsá lázrele neda'. Quebe dxennía' ba gul-la lázrele neda', san quebe guta' lataj gácale̱le neda'.
\v 11 Quebe dxennía' da nigá lawe' da bi dxexázrjeda', lawe' da ba bse̱de Xránadxu neda' sua' xel-la dxebé ájate̱ze dxaca chia'.
\v 12 Ba gudéa' xel-la xache', ne cá'anqueze xel-la gunní'a. Nazé̱dia' dxuchaga lawa' xúgute̱ da dxaca chia', che néljada', u che dxeduna', che nápale̱'a, u che quebe bi napa'.
\v 13 Xúgute̱ wazéqueda' guchaga lawa' lawe' da dxuzé̱ tipa Cristo neda'.
\v 14 Be̱nle da xrlátaje, gúcale̱le neda' ne̱ chee̱ da gusél-lale chia'.
\p 
\v 15 Ba nézquezle le'e, benne' Filipos, ca guca gate guzú lawa' dxuchálaja' dizra' chawe' chee̱ Cristo nigá. Gate bezá'a xe̱zre ca' zaj nababa xe̱zr la xu Macedonia, le'eze gusél-lale chia' dumí chee̱ da guzí' lu na'le.
\v 16 Gate guzúa' xe̱zre Tesalónica, chupa chunna lasa gusél-lale dumí chia' chee̱ quebe bi xázrjeda'.
\v 17 Quebe dxennía' da nigá lawe' da dxaca lazra' bi gúnnale chia', san dxaca lazra' gácadxa da ba neza chee̱le le'e lau Dios.
\v 18 Ba guzi'a xúgute̱ da gusél-lale, na' de̱le̱'e̱ chia'. Ca naca da gusélal-le chia' lu na' Epafrodito, da zrendxa guca na ca da bexázrjeda'. Da na' gusél-lale naca na ca tu guna' da dxelá zixre na lau Dios, u tu da bzúale lau Dios da dxezaca ba lazre̱'.
\v 19 Dios chia' gunne̱' le'e xúgute̱ da dxexázrjele, chee̱ xel-la gunní'a chee̱ xabáa chee̱' ne̱ chee̱ Jesucristo.
\v 20 Gaca ba Xradxu Dios chadía chacanna. ¡Ca'an gaca na!
\s1 Pablo dxuzé̱ dizra' benne' Filipos ca'
\p 
\v 21 Waláz chia' neda' le gugapa diuzre lu La Jesucristo xúgute̱ benne' zaj nababe̱' chee̱ Dios. Bi bíchedxu ca' zaj zúale̱ neda' dxulugape̱' le'e diuzre.
\v 22 Xúgute̱ bi bíchedxu zaj zre'e nigá, benne' zaj nababe̱' chee̱ Dios, ne bi bíchedxu zaj zre̱'e̱ lizre bénnea' dxenná bé'ene̱' xe̱zr la xu Roma, dxulugape̱' le'e diuzre.
\p 
\v 23 Dxenaba' lau Xránadxu Jesucristo gune̱' da chawe' chee̱ xúgute̱le le'e. Ca'an gaca na.
