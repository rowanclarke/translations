\id RUT
\h رُتِ شَ تَرُشُي
\toc1 رُتِ شَ تَرُشُي
\toc2 رُتِ
\toc3 رُت
\mt1 رُتِ شَ تَرُشُي
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ
\ip يِ كِتَابُي قِندِشِ تَرُشُي دِ نَن نَ فِنّ قِرِن شَ قٍ رَ. فِنّ ندٍ نُن عَ شَ مْرِ نَن كٍلِ عٍ شْنيِ عِسِرَيِلَ بْشِ مَ، عٍ تُنُ مٌوَبَ بْشِ مَ. مّننِ، نَ شّمّ نُن عَ شَ دِ شّمّ قِرِنيِيٍ نَشَ قَشَ. نَ كَاحّ فِنّ نُن عَ شَ دِيٍ شَ فِنّيٍ نَشَ لُ نَا عٍ كٍرٍن سٍتَرٍحَ كُي. عَ رَحْنيِ، نَ كَاحّ فِنّ نَشَ نَتّ تٌنفٌ عَ شَ فبِلٍن عَ شْنيِ. عَ شَ مَمَدِ رُتِ نَشَ بِرَ عَ قْشْ رَ شَنُنتٍيَ شَ قٍ رَ. عٍ تٌ سٌ عِسِرَيِلَ بْشِ مَ عٍ شَ سُننُنيِ كُي، عَلَتَلَ نَشَ كَابَنَكٌي ندٍ رَبَ نَشَن عَ مَسٍنمَ عَ تْورْ مِشِيٍ شَنُمَ. عَ نَشَ مّينِ نَ فِنّ قِرِنيِيٍ مَ عَ قَنيِ رَ، عَلَكٌ عٍ نَشَ لُ سٍتَرٍحَ كُي عٍ كٍرٍنيِ مَ.
\ip يِ تَرُشُي نْمَ لِمَنِيَ قِدٍ تٌ مِشِيٍ مَ، نَشٍيٍ نْمَ عَ مَحْشُندٍ عَ عَلَ بَرَ نّيمُ عٍ مَ. شَ مِشِ بِرَ عَلَ قْشْ رَ، عٍ عَ سَفٌ رَبَمَ، عَلَ مُ نّيمُمَ عٍ مَ قٍقٍ مَ. تْورّ ندٍ نْمَ عٍ لِدٍ، كْنْ عَلَتَلَ نْمَ نَ تْورّ مَقِندِ قٍ قَنيِ رَ. يِ تَرُشُي قْلّ مَكِنِكِنِ، كْنْ عَ رَحْنيِ عَ عَلَ سّنبّ نُن عَ شَ شَنُنتٍيَ مَسٍنمَ وٌن بّ. عَلَ شَ وٌن مَلِ نَ كٌلٌندٍ وٌن مَ دُنِحّءِفِرِ كُي. عَمِنَ.
\mt1 رُتِ شَ تَرُشُي
\c 1
\s1 عٍلِمٍلٍكِ شَ دٍنبَيَ تُنُقٍ مٌوَبَ
\p 
\v 1 عَلَتَلَ شَ كِيتِسَيٍ شَ وَشَتِ، كَامّ دِن نّ عِسِرَيِلَ بْشِ رَ. شّمّ ندٍ نَشَ كٍلِ بّتّلّيمُ، نَشَن نُ نَ يُدَيَ بْشِ مَ. عَ نَشَ تُنُ مٌوَبَ بْشِ مَ، عَ تَن، عَ شَ فِنّ، نُن عَ شَ دِ قِرِنيِيٍ.
\v 2 نَ شّمّ شِلِ عٍلِمٍلٍكِ، عَ شَ فِنّ نٌوٍ مِ، عَ شَ دِيٍ، مَشَلْن نُن كِلِيٌن. عٍ قَتَن عٍقَرَتَ شَبِلّ نَن مَ. عٍ نَشَ سَ سَبَتِ مٌوَبَ بْشِ مَ.
\p 
\v 3 نَ تّمُي نٌوٍ مِ شَ مْرِ عٍلِمٍلٍكِ نَشَ قَشَ. نٌوٍ مِ نَشَ لُ نَا قَ، عَ نُن عَ شَ دِ قِرِنيِيٍ.
\v 4 نَ دِ قِرِنيِيٍ نَشَ مٌوَبَ فِنّيٍ دْشْ. فِنّ سِنفٍ شِلِ عٌرٌثَ، عَ قِرِن ندٍ رُتِ. عٍ نَشَ لُ مّننِ هَن حّ قُ.
\v 5 نَ شَنبِ مَشَلْن نُن كِلِيٌن قَن نَشَ قَشَ. نٌوٍ مِ نَشَ لُ نَا قَ عَ كٍرٍن. شّمّ مُ نَ، دِ مُ نَ.
\p 
\v 6 نٌوٍ مِ تٌ عَ مّ عَ عَلَتَلَ بَرَ عَ شَ حَمَ مَلِ بَلٌي قٍ رَ،
\v 7 نٌوٍ مِ نُن عَ شَ دِيٍ شَ فِنّ قِرِنيِيٍ نَشَ كٍلِ مٌوَبَ بْشِ مَ، عٍ نُ سَبَتِشِ دّننَشّ. عٍ تٌ كِرَ لِ نَشَن سِفَمَ يُدَيَ بْشِ مَ،
\v 8 نٌوٍ مِ نَشَ عَ قَلَ عَ شَ دِيٍ شَ فِنّيٍ بّ، «وٌ شَ فبِلٍن وٌ نفَيٍ شْنيِ. عَلَتَلَ شَ هِننّ وٌ رَ، عَلْ وٌ عَ رَبَشِ ﭑ تَن نُن ﭑ مَ دِيٍ بّ كِ نَشّ.
\v 9 عَلَتَلَ شَ شّمّ قِ وٌ مَ، وٌ سَبَتِمَ نَشَن شْن بْحّسَ كُي.» نٌوٍ مِ نَشَ قِندِفِلِن عٍ مَ، كِنِكِنِ نَشَ عٍ رَوَ.
\p 
\v 10 عٍ نَشَ عَ قَلَ عَ بّ، «عَدٍ، نَ مُ لَنمَ. وٌن بِرِن شَ سِفَ عِ بْنسْي يِرٍ.»
\v 11 نٌوٍ مِ نَشَ عٍ يَابِ، «ﭑ مَ مَمَدِيٍ، وٌ شَ فبِلٍن. مُنقٍ رَ وٌ وَ مَ بِرَقٍ ﭑ قْشْ رَ؟ ﭑ تَن نْمَ دِ فبّتّيٍ بَرِدٍ سْنْن وٌ دْشْمَ نَشٍيٍ شْن؟
\v 12 ﭑ مَ مَمَدِيٍ، قٌ وٌ شَ فبِلٍن وٌ شْنيِ. ﭑ بَرَ قٌرِ. ﭑ مُ نْمَ شّمّ فبّتّ سْتْدٍ سْنْن. هَلِ ﭑ سَ شّمّ فبّتّ سْتْ تٌ، ﭑ قَ دِ بَرِ تٌ كْي رَ،
\v 13 وٌ نْمَ نَ دِ مّمّدٍ هَن عَ مْ وٌ قَ دْشْ عَ شْن مَ؟ وٌ نْمَ نَ رَ؟ ﭑ مَ مَمَدِيٍ، وٌ مُ نْمَ نَ رَ. نَ شْرْشْ. وٌ نْمَ تٌندِدٍ شّمّ فبّتّ بّ، هَن ﭑ مَ دِيٍ مْ؟ عَلَتَلَ نَشَن نَفِرِشِ ﭑ مَ، عَ شْرْشْ دَنفِقٍ وٌ شَ تْورّ رَ. عَلَتَلَ بَرَ ﭑ تْورْ كِ قَنيِ.»
\p 
\v 14 نَ كُي عٌرٌثَ نُن رُتِ مَن نَشَ وَ قْلْ. عٌرٌثَ نَشَ قِندِفِلِن نٌوٍ مِ مَ، عَ قَ فبِلٍن عَ شْنيِ، كْنْ رُتِ تَن نَشَ كَنكَن نٌوٍ مِ مَ.
\v 15 نٌوٍ مِ نَشَ عَ قَلَ عَ بّ، «رُتِ، عٌرٌثَ بَرَ فبِلٍن عَ شَ مِشِيٍ شْنيِ. عَ بَرَ فبِلٍن عَ شَ دِينّ مَ. عِ تَن قَن، عِ شَ بِرَ عَ قْشْ رَ.»
\v 16 رُتِ نَشّ، «عِ نَشَ ﭑ كَرَشَن ﭑ شَ فبِلٍن عِ قْشْ رَ. عِ نَشَ ﭑ كٍرِ. عِ نُ سِفَ دّدّ، ﭑ قَن سِفَمَ مّننِ نّ. وٌن سَبَتِمَ نّ يِرٍ كٍرٍن. عِ شَ مِشِيٍ قِندِ مَ ﭑ مَ مِشِيٍ نَن نَ. عِ مَرِفِ عَلَ قِندِ مَ ﭑ قَن مَرِفِ نَن نَ.
\v 17 ﭑ لُمَ عِ سّيتِ مَ هَن عِ قَشَ، ﭑ قَ رَفَتَ عِ شَ فَبُرِ سّيتِ مَ. شَ ﭑ عِ بّحِن، عَلَتَلَ شَ عِ هَاكّ مِنِ ﭑ عِ. سَيَ فبَنسَن شَ وٌن نَقَتَن.»
\p 
\v 18 نٌوٍ مِ تٌ عَ كٌلٌن، رُتِ شَ نَتّ مُ مَسَرَ مَ، عَ نَشَ دُندُ.
\v 19 عٍ قِرِن نَشَ تِ كِرَ شْن مَ هَن بّتّلّيمُ. عٍ تٌ سٌ تَا كُي، حَمَ نَشَ تّرّننَ عٍ تٌقٍ رَ. فِنّيٍ نُ قَ مَشْرِنيِ تِ، «نٌوٍ مِ نَن يَ؟»
\v 20 نٌوٍ مِ نُ قَ عٍ يَابِ، «ﭑ مُ شِلِمَ نٌوٍ مِ سْنْن. وٌ شَ ﭑ شِلِ مَرَ، بَرِ مَ عَلَ سّنبّمَ بَرَ ﭑ مَ دُنِحّءِفِرِ رَشْرْشْ ﭑ مَ.» («نٌوٍ مِ» وَ مَ عَ قَلَقٍ نّ «عَ حْشُن.» «مَرَ» وَ مَ عَ قَلَقٍ نّ «عَ شْنْ.»)
\v 21 «ﭑ سِفَ سِفَمَ، ﭑ نُن قٍ قَنيِ نَن سِفَ، كْنْ عَلَتَلَ بَرَ ﭑ نَفبِلٍن ﭑ بّلّشّ عِفٍلِ رَ. مُنقٍ رَ وٌ ﭑ شِلِمَ نٌوٍ مِ؟ عَلَتَلَ سّنبّمَ بَرَ تِ ﭑ كَنكٍ، عَ بَرَ حَشَنكَتّ دْشْ ﭑ مَ.»
\p 
\v 22 نٌوٍ مِ فبِلٍن عَ شْنيِ نَ كِ نّ، عَ تَن نُن عَ شَ دِ شَ فِنّ رُتِ مٌوَبَكَ. عٍ سٌشِ بّتّلّيمُ قُندٍن مَنِيّ شَبَ تّمُي نّ.
\c 2
\s1 بٌو سُ رُتِ مَلِقٍ
\p 
\v 1 سّنبّمَ ندٍ نُ نَ عِسِرَيِلَ بْشِ مَ، نَشَن شِلِ بٌو سُ. عَ قَتَن عٍلِمٍلٍكِ شَبِلّ نَن نَ.
\v 2 رُتِ مٌوَبَكَ نَشَ عَ قَلَ نٌوٍ مِ بّ، «ﭑ وَ مَ سِفَقٍ شّ مَ قُندٍن مَنِيّ دْنشْييٍ مَتٌنفٌدٍ. تّمُندٍ ﭑ شّ كَنيِ ندٍ تٌمَ نَشَن هِننّمَ ﭑ نَ.» نٌوٍ مِ نَشّ، «عَوَ ﭑ مَ مَمَدِ، عِ ﭑ لِمَ بٍ.»
\p 
\v 3 رُتِ نَشَ سِفَ قُندٍن مَنِيّ دْنشْييٍ مَتٌنفٌدٍ شّ وَلِكّيٍ شَنبِ رَ. عَلَتَلَ نَشَ عَ رَفِرِ، عَ شَ عَ شُن تِ بٌو سُ، عٍلِمٍلٍكِ شَبِلّ مِشِ ندٍ شَ شّ رَ.
\v 4 نَ وَشَتِ بٌو سُ نُ بَشِ سٌدٍ كٍلِ بّتّلّيمُ. عَ نَشَ عَ شَ وَلِكّيٍ شّيبُ، «وٌ نُ وَلِ، عَلَتَلَ شَ وٌ رَتَنفَ.» عٍ نَشَ عَ رَتِن، «عَمِنَ، عَلَتَلَ شَ بَرَكّ قِ عِ قَن مَ.»
\v 5 بٌو سُ نَشَ مَشْرِنيِ تِ وَلِكّيٍ شُنيِ مَ، «ندٍ نَ نَ سُنفبُتُنيِ رَ؟»
\v 6 عَ نَشَ عَ يَابِ، «نَ سُنفبُتُنيِ مٌوَبَكَ نَ عَ رَ، نَشَن قَ نٌوٍ مِ مَتِدٍ كٍلِ مٌوَبَ بْشِ مَ.
\v 7 عَ مَيَندِ نَن تِ عَ شَ قُندٍن مَنِيّ دْنشْييٍ مَتٌنفٌ وَلِكّيٍ شَنبِ رَ. كَقِ عَ قَ فّيسّفّ، هَن يَكْسِ عَ نَ وَلِقٍ، قٌ عَ تٌ عَ مَلَبُقٍ يِ كِ بَفٍ بُن مَ.»
\p 
\v 8 نَ تّمُي بٌو سُ نَشَ عَ قَلَ رُتِ بّ، «ﭑ مَ دِ، عِ تُلِ مَتِ. عِ شَ لُ بٍ ﭑ مَ وَلِكّ فِنّيٍ شَنبِ رَ. هَلِ عِ مُ سِفَ شّ فبّتّ مَ قُندٍن مَنِيّ دْنشْييٍ مَتٌنفٌدٍ.
\v 9 عٍ نَ سِفَ شّ نَشَن مَ، عِ قَن شَ بِرَ عٍ قْشْ رَ. ﭑ بَرَ حُنفُي لُ ﭑ مَ شّمّيٍ مَ، عٍ نَشَ عِ تْورْ. شَ يٍ شْلِ عِ سُشُ، عِ شَ سِفَ يٍ مِندٍ، وَلِكّيٍ شَ يٍ نَشَن سَشِ قّحّ كُي.»
\p 
\v 10 رُتِ نَشَ عَ عِفٌرٌ بْشِ مَ حّلّشِنيِ سَابُي رَ، عَ قَ عَ قَلَ، «ﭑ تَن، بٍكَ مُ ﭑ نَ، كْنْ عِ بَرَ هِننّ ﭑ نَ. عِ هِننّشِ ﭑ نَ مُنقٍ رَ؟»
\v 11 بٌو سُ نَشَ عَ يَابِ، «مِشِيٍ بَرَ عَ قَلَ ﭑ بّ، عِ نَشَن نَبَشِ عِ مَمَ بّ كَقِ عِ شَ مْرِ نَشَ قَشَ. عٍ نَشّ، عِ بَرَ عِ بَبَ يٌ، عِ نفَ يٌ، نُن عِ بَرِدٍ، عِ بَرَ عَ بِرِن بّحِن، عِ قَ سِفَ مِشِيٍ شْنيِ عِ مُ دّننَشّ كٌلٌن.
\v 12 عَلَ شَ عِ بَرَايِ. عِسِرَيِلَ مَرِفِ عَلَ شَ عِ سَرٍ رَكَمَلِ، عِ شَشِلِ تِشِ مَرِفِ نَشَن نَ.»
\v 13 رُتِ نَشَ عَ قَلَ بٌو سُ بّ، «ﭑ مَ مَنفّ، عِ بَرَ هِننّ ﭑ نَ، عِ بَرَ ندٍ بَ ﭑ مَ تْورّ رَ. عِ شَ وْيّنيِ بَرَ سٌ ﭑ تَن عِ شَ كٌنيِ بْحّ كُي، نَ بِنيّ فبٌ ﭑ تَن بّ.»
\p 
\v 14 عٍ دّفٍ وَشَتِ بٌو سُ نَشَ عَ قَلَ رُتِ بّ، «قَ بٍ، عِ شَ تَامِ نُن بْرّ ندٍ دٌن.» رُتِ نَشَ دْشْ وَلِكّيٍ قّ مَ. بٌو سُ نَشَ قُندٍن مَنِيّ فِلِنشِ ندٍ سٌ عَ يِ رَ. عَ نَشَ نَ دٌن هَن عَ لُفَ، عَ قَ عَ دْنشْي رَفَتَ.
\v 15 عَ مَن تٌ سِفَ قُندٍن مَنِيّ مَتٌنفٌدٍ، بٌو سُ نَشَ يَامَرِ قِ عَ شَ وَلِكّيٍ مَ. عَ نَشّ، «هَلِ عَ سٌ عَ شَبَتَرٍ قَن شْورَ، وٌ نَشَ سْنشْ عَ مَ.
\v 16 وٌ نَ قُندٍن مَنِيّ رَشِرِ، وٌ شَ ندٍ لُ نَا، عَ شَ نَ قَن مَتٌنفٌ. هَلِ وٌ مُ سٍسٍ قَلَ عَ بّ.»
\p 
\v 17 رُتِ نَشَ وَلِ هَن نُنمَرٍ. عَ تٌ فّ وَلِدٍ، عَ نَشَ قُندٍن مَنِيّ بْنبْ، عَ كٌنبٌ يَ قِرِن نَن سْتْ.
\v 18 رُتِ تٌ سٌ نَ بِرِن نَ تَا كُي، عَ نَشَ عَ مَسٍن نٌوٍ مِ بّ. عَ دٌنسٍ نَشَن دٌن بٌو سُ يِرٍ، عَ نَشَ نَ دْنشْي قَن سٌ نٌوٍ مِ يِ رَ.
\v 19 نٌوٍ مِ نَشَ رُتِ مَشْرِن، «عِ وَلِشِ شّ مُندُن مَ تٌ؟ عِ يِ قُندٍن مَنِيّ مَتٌنفٌشِ مِندٍن؟ عَلَ شَ نَ مِشِ بَرَايِ نَشَن هِننّشِ عِ رَ.» رُتِ نَشَ عَ بِرِن يَ مَشَرَن عَ مَمَ بّ. عَ مَن نَشَ عَ قَلَ، «مِشِ نَشَن ﭑ مَلِشِ، عَ شِلِ نّ بٌو سُ.»
\v 20 نٌوٍ مِ نَشَ عَ قَلَ عَ شَ دِ شَ فِنّ بّ، «عَلَ شَ عَ بَرَايِ، عَلَ نَشَن مُ عَ شَ سَاتّ قَنيِ كَنَمَ، عَ قَ هِننّ عَ شَ مِشِيٍ رَ نَشٍيٍ نَ دُنِحَ عَ نُن نَشٍيٍ نَ عَلِفِيَمَ. يِ شّمّ لَنشِ وٌن شَبِلّ مِشِ ندٍ نَن مَ. وٌن شَبِلّ رَتَنفَمَ نَن عَ رَ.»
\p 
\v 21 رُتِ مٌوَبَكَ نَشَ عَ يَابِ، «نَ شّمّ نَشّ، عَ ﭑ شَ وَكِلِ عَ شَ وَلِكّيٍ قْشْ رَ هَن قُندٍن مَنِيّ شَبّ شَ بَ عَ رَ.»
\v 22 نٌوٍ مِ نَشَ عَ قَلَ عَ شَ دِ شَ فِنّ بّ، «ﭑ مَ دِ، عَ لَنمَ عِ شَ بِرَ عَ شَ وَلِكّ فِنّيٍ قْشْ رَ، عَلَكٌ مِشِ يٌ نَشَ عِ تْورْ شّ فبّتّيٍ مَ.»
\p 
\v 23 نَ كُي رُتِ نَشَ لُ بٌو سُ شَ وَلِكّ فِنّيٍ قْشْ رَ هَن قُندٍن مَنِيّ نُن مّنفِ مَنِيّ شَبّ نَشَ حْن. رُتِ سَبَتِ نٌوٍ مِ شْنيِ، نَ كِ نّ.
\c 3
\s1 رُتِ نُن بٌو سُ شَ لَنيِ
\p 
\v 1 نٌوٍ مِ نَشَ عَ قَلَ عَ شَ دِ شَ فِنّ بّ، عَ نَشّ، «رُتِ، ﭑ وَ مَ عِ شَ شّمّ تَا قَنيِ سْتْ.
\v 2 عِ عَ كٌلٌن، بٌو سُ، عِ سَ وَلِشِ نَشَن شْنيِ نُن عَ شَ وَلِكّ فِنّيٍ رَ، وٌن شَبِلّ نَن عَ رَ. تٌ نُنمَرٍ رَ، بٌو سُ سِفَمَ لٌنيِ مَ قُندٍن مَنِيّ بْنبْدٍ.
\v 3 عِ نَشَن نَبَمَ، عِ شَ عِ يَءِلَن عَ قَنيِ رَ. عِ شَ عِ مَشَ، عِ لَبُندّ سَ عِ مَ، عِ عِ مَشِرِ دُفِ قَنيِ رَ. نَ تّمُي عِ شَ سِفَ لٌنيِ يِرٍ. عِ عِ يَ مَنْشُن بٌو سُ مَ هَن عَ شَ فّ عَ دّفٍدٍ.
\v 4 عَ نَ سٌ عَ سَدٍ، عِ شَ عَ مَتٌ عَ سَشِ دّننَشّ. عَ نَ شِ، عِ شَ عَ شَ دُفِ بَ عَ سَنيِيٍ مَ، عِ عِ سَ عَ سَن لَبٍ رَ. عَ قَمَ عِ رَبَقٍ قَلَدٍ عِ بّ.»
\v 5 رُتِ نَشَ عَ يَابِ، «عَوَ، ﭑ عَ بِرِن نَبَمَ نّ عَلْ عِ عَ قَلَشِ كِ نَشّ.»
\p 
\v 6 نَ تّمُي رُتِ نَشَ سِفَ نَ لٌنيِ مَ. عَ مَمَ نَشَن قَلَشِ عَ بّ، عَ نَشَ نَ رَبَ.
\v 7 بٌو سُ تٌ فّ عَ دّفٍدٍ، عَ نَشَ عَ سَ قُندٍن مَنِيّ كُرُشِ قّ مَ حّلّشِنيِ كُي. رُتِ نَشَ عَ مَسٌ عَ رَ دْيِن دْيِن، عَ دُفِ بَ عَ سَنيِيٍ مَ، عَ قَ عَ سَ عَ سَن لَبٍ رَ.
\v 8 كْي تَفِ، بٌو سُ نَشَ شُنُ، عَ نَشَ فِنّ تٌ عَ سَن لَبٍ رَ.
\v 9 عَ نَشَ عَ مَشْرِن، «ندٍ عَ رَ؟» رُتِ نَشَ عَ يَابِ، «عِ شَ كٌنيِ نَن ﭑ نَ. ﭑ شِلِ رُتِ. ﭑ قَشِ نّ، شَ عِ نْمَ ﭑ قُتِدٍ، بَرِ مَ مُشُ شَبِلّ رَتَنفَمَ نَ عِ رَ.»
\p 
\v 10 بٌو سُ نَشَ عَ مَسٍن عَ بّ، «ﭑ مَ دِ، عَلَ شَ عِ بَرَايِ. يِ هِننّ قَن عِ شَ هِننّ سِنفٍ بّ، بَرِ مَ عِ مُ سِفَشِ سّفّتَلَ سٍ كَنيِ قْشْ رَ، عِ مُ سِفَشِ سّفّتَلَ سٍتَرٍ قْشْ رَ.
\v 11 ﭑ مَ دِ، شَنمّرِ يٌ نَشَ لُ عِ يِ رَ. ﭑ عَ بِرِن نَبَمَ نّ عِ بّ عِ نَشَن مَشْرِنشِ، بَرِ مَ حَمَ بِرِن عَ كٌلٌن فِنّ قَنيِ نَن عِ رَ.
\v 12 عِ بَرَ نْندِ قَلَ. ﭑ تَن، وٌ شَبِلّ رَتَنفَمَ نَن ﭑ نَ، كْنْ شَبِلّ رَتَنفَمَ فبّتّ نَ نَشَن مَكْرّ عِ رَ ﭑ تَن بّ.
\v 13 كْي رَدَنفِ بٍ تٌ. فّيسّفّ، شَ نَ مِشِ تِن عِ رَتَنفَدٍ، عَوَ. شَ عَ مُ تِن، ﭑ تَن عِ رَتَنفَمَ نّ. ﭑ بَرَ ﭑ كَلِ عَلَتَلَ رَ! عِ شَ شِ بٍ هَن كُيٍ شَ عِبَ.»
\p 
\v 14 رُتِ نَشَ عَ سَ بٌو سُ سَن لَبٍ رَ هَن سُبَشّ مَ. عَ نَشَ كٍلِ بٍينُن سٌفٍ شَ تٍ، بَرِ مَ بٌو سُ مُ نُ وَ مَ مِشِ شَ عَ كٌلٌن يِ فِنّ نُ نَ لٌنيِ مَ.
\v 15 عَ نَشَ عَ قَلَ عَ بّ، «عِ شَ مَقٍلٍنيِ تٌنفٌ، عَ دّ سُشُ.» رُتِ تٌ عَ شَ مَقٍلٍنيِ دّ سُشُ، بٌو سُ نَشَ قُندٍن مَنِيّ كٌنبٌ يَ كٍرٍن سَ عَ كُي. بٌو سُ نَشَ رُتِ رَتٍ نَ كٌتٍ مَ، رُتِ قَ سِفَ تَا كُي.
\p 
\v 16 عَ نَشَ فبِلٍن عَ مَمَ نٌوٍ مِ شْنيِ. نٌوٍ مِ نَشَ عَ مَشْرِن، «ﭑ مَ مَمَدِ، قٍ بَرَ دَنفِ عَ قَنيِ رَ؟» رُتِ نَشَ عَ يَ مَشَرَن بٌو سُ نَشَن بِرِن نَبَشِ عَ بّ.
\v 17 عَ نَشّ، «عَ بَرَ يِ قُندٍن مَنِيّ كٌنبٌ يَ كٍرٍن قِ ﭑ مَ. عَ نَشّ ﭑ بّ، ‹عِ مُ فبِلٍنمَ عِ مَمَ شْنيِ عِ بّلّشّ عِفٍلِ.›»
\v 18 نٌوٍ مِ نَشَ عَ قَلَ عَ بّ، «ﭑ مَ مَمَدِ، عِ شَ لُ بٍ هَن وٌن شَ عَ كٌلٌن يِ قٍ رَحْنمَ كِ نَشّ. نَ شّمّ مُ عَ رَشَرَ مَ، قٌ يِ قٍ شَ يَءِلَن تٌ يَتِ نّ.»
\c 4
\s1 بٌو سُ رُتِ قُتِقٍ
\p 
\v 1 بٌو سُ نَشَ سِفَ تَا نَادّ رَ، تَاكَيٍ مَلَنمَ دّننَشّ، عَ دْشْ. نَ شَبِلّ رَتَنفَمَ، بٌو سُ نُ نَشَن شَ قٍ قَلَمَ، نَ نَشَ قَ. بٌو سُ نَشَ عَ قَلَ عَ بّ، «ﭑ بَ، قَ عِ مَفٌرٌ بٍ.» عَ نَشَ قَ، عَ دْشْ.
\v 2 بٌو سُ مَن نَشَ عَ قَلَ تَا كُنتِفِ قُ بّ، «وٌ قَ، وٌ وٌ مَفٌرٌ بٍ.» عٍ تٌ دْشْ،
\v 3 بٌو سُ نَشَ عَ مَسٍن نَ شَبِلّ رَتَنفَمَ بّ، «نٌوٍ مِ، نَشَن كٍلِشِ مٌوَبَ، عَ وَ مَ عٍلِمٍلٍكِ شَ بْشِ مَتِقٍ. عِ عَ كٌلٌن، عٍلِمٍلٍكِ وٌن تَارَ نَ عَ رَ.
\v 4 ﭑ نُ وَ مَ عِ شَ كٌلٌن سْتْ نَ قٍ مَ، عِ شَ نَ بْشِ شُن سَرَ تَاكَيٍ نُن تَا كُنتِفِيٍ يَ شْرِ. شَ عِ نْمَ عَ شُن سَرَدٍ، عِ شَ عَ رَبَ. شَ عِ مُ نْمَ نَ رَ، عَ قَلَ ﭑ بّ، عَلَكٌ ﭑ شَ عَ كٌلٌن، بَرِ مَ مِشِ فبّتّ مُ نْمَ عَ شُن سَرَدٍ قٌ عِ شَ عِ شُي قِ. ﭑ تَن نَن عِ شَنبِ رَ.» نَ شّمّ نَشَ عَ يَابِ، «ﭑ عَ شُن سَرَ مَ نّ.»
\p 
\v 5 نَ تّمُي بٌو سُ نَشَ يِ وْيّنيِ سَ نَ قَرِ، عَ نَشّ، «عِ نّ يِ بْشِ سَرَ مَ لْشْي نَشّ نٌوٍ مِ نُن رُتِ مٌوَبَكَ مَ، عِ مَن شَ نَ كَاحّ فِنّ قَن دْشْ، عَلَكٌ قَشَمِشِ شِلِ نَشَ لْي نَ بْشِ شُن مَ.»
\v 6 نَ شَبِلّ رَتَنفَمَ نَشَ عَ يَابِ، «نَ كُي ﭑ مُ نْمَ عَ شُن سَرَدٍ، شَ نَ مُ عَ رَ ﭑ يّتّ كّ كَنَمَ نّ. عِ شَ عَ شُن سَرَ، ﭑ تَن مُ نْمَ.»
\v 7 سِنفٍ رَ عِسِرَيِلَ بْشِ مَ، شَ مِشِ ندٍ نُ وَ مَ لَنيِ شِرِقٍ، قٌ عَ شَ سَنكِرِ بَ، عَ شَ عَ سٌ عَ بٌورٍ يِ رَ. نَ نَن عَ مَسٍنمَ لَنيِ بَرَ فّ شِرِدٍ.
\v 8 نَ كُي، نَ شَبِلّ رَتَنفَمَ تٌ عَ قَلَ بٌو سُ بّ، «عِ شَ نَ بْشِ شُن سَرَ عِ يّتّ بّ،» عَ نَشَ عَ شَ سَنكِرِ بَ، عَ عَ سٌ بٌو سُ يِ رَ.
\p 
\v 9 نَ دَنفِ شَنبِ بٌو سُ نَشَ عَ مَسٍن تَا كُنتِفِيٍ نُن حَمَ بّ، «وٌ بَرَ قِندِ سٍيدٍيٍ رَ تٌ. عٍلِمٍلٍكِ، كِلْن، نُن مَشَلْن شَ سٍيٍ، ﭑ بَرَ عٍ بِرِن سَرَ نٌوٍ مِ مَ.
\v 10 مَشَلْن شَ فِنّ، رُتِ مٌوَبَكَ، ﭑ بَرَ نَ قَن دْشْ عَلَكٌ قَشَمِشِ شِلِ نَشَ لْي عَ شَ بْشِ شُن مَ، عَ شَبِلّ نُن عَ شَ تَا مِشِيٍ نَشَ نّيمُ عَ شَ قٍ مَ. تٌ وٌ بَرَ قِندِ يِ قٍ سٍيدٍيٍ رَ.»
\v 11 حَمَ نُن كُنتِفِيٍ نَشَ عَ يَابِ، «مُشُ بَرَ تِن قِندِدٍ سٍيدٍيٍ رَ! مُشُ بَرَ عَلَتَلَ مَشَندِ يِ فِنّ بّ نَشَن سٌقٍ عِ شْنيِ.
\q1 عَلَتَلَ شَ عَ لُ عَلْ رَشٍلٍ نُن لٍيَ نَشٍيٍ بَرَ دِيٍ سْتْ،
\q1 عٍ قِندِ عِسِرَيِلَ حَمَ رَ.
\q1 عَلَتَلَ شَ سّنبّ قِ عِ مَ عٍقَرَتَ شَبِلّ يَ مَ.
\q1 عَلَتَلَ شَ شِلِ شُنفبٍ قِ عِ مَ بّتّلّيمُ تَا كُي.
\q1 
\v 12 عَلَتَلَ شَ دِ فبٍفبٍ قِ عِ مَ يِ سُنفبُتُنيِ سَابُي رَ.
\q1 عَلَتَلَ شَ وٌ شَ دِيٍ قِندِ دٍنبَيَ رَ عَلْ ثٍرٍ سِ شَ دٍنبَيَ،
\q1 ثٍرٍ سِ نَشَن تَمَرِ بَرِشِ يُدَ بّ.»
\p 
\v 13 نَ تّمُي، بٌو سُ نَشَ رُتِ شَ قُتِ شِرِ. عٍ تٌ لُ يِرٍ كٍرٍن، عَلَتَلَ نَشَ عَ رَفِرِ رُتِ شَ تّفّ، عَ دِ سْتْ.
\v 14 نَ كُي فِنّيٍ نَشَ عَ قَلَ نٌوٍ مِ بّ، «عَلَ تَنتُ، بَرِ مَ عَلَتَلَ بَرَ شَبِلّ رَتَنفَمَ قِ عِ مَ. عِسِرَيِلَكَيٍ شَ تَنتُي رَ سِفَ عَلَ مَ!
\v 15 يِ دِ قَمَ مّينِدٍ عِ مَ، عَ عِ كَنتَمَ عِ شَ حّلّشّقٌرِحَ كُي. عِ شَ مَمَدِ رُتِ، نَشَن يِ دِ سْتْشِ عِ بّ، عَ قَن عِ شَنُمَ، عَ تِدٍ فبٌ عِ بّ دَنفِ دِ سٌلٌقٍرٍ رَ.»
\p 
\v 16 نٌوٍ مِ نَشَ نَ دِيْرّ تٌنفٌ، عَ عَ سَ عَ كَنكٍ مَ، عَ قِندِ عَ مّينِمَ رَ.
\v 17 نٌوٍ مِ دْشْبٌورٍ فِنّيٍ نَشَ شِلِ سَ يِ دِيْرّ شُن مَ، عَ قَلَقٍ رَ، «نٌوٍ مِ بَرَ دِ سْتْ، عَ شِلِ عٌبٍدٌ.» عٌبٍدٌ شَ دِ نَن يِسَيِ رَ. يِسَيِ شَ دِ نَن دَوُدَ رَ.
\p 
\v 18 ثٍرٍ سِ شَ تَرُشُي نَن يَ؛
\q1 ثٍرٍ سِ نَشَ هٍسٍرٌن سْتْ.
\q1 
\v 19 هٍسٍرٌن نَشَ رَ مِ سْتْ.
\q1 رَ مِ نَشَ عَمِنَدَبٌ سْتْ.
\q1 
\v 20 عَمِنَدَبٌ نَشَ نَشَسٌن سْتْ.
\q1 نَشَسٌن نَشَ سَلِمٌن سْتْ.
\q1 
\v 21 سَلِمٌن نَشَ بٌو سُ سْتْ.
\q1 بٌو سُ نَشَ عٌبٍدٌ سْتْ.
\q1 
\v 22 عٌبٍدٌ نَشَ يِسَيِ سْتْ.
\q1 يِسَيِ نَشَ دَوُدَ سْتْ.
