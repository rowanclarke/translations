\id 1TH - Ikwerre 
\h 1 Ele Tẹsalonika 
\toc1 Ọkwukwo izi ke Mbọm Pọlu gbaznennu Ele Tẹsalonika 
\toc2 1 Ele Tẹsalonika 
\toc3 1 Tẹs 
\mt2 Ọkwukwo izi 
\mt2 ke Mbọm 
\mt2 Pọlu gbaznennu 
\mt1 Ele Tẹsalonika 
\imt1 Nhne gbasịri ọkwukwo izi ka 
\im Pọlu panịzoru ọgbako Chiokike ke zị nụ Tẹsalonika (2:13,14) nga ọ nọornu ẹrnu o ji nọoznu ẹhni a. Nụ rime ẹli-ọhna ka zị mkpa nụ rime Girisi bụ hne agịda ele naakwa rẹnwu ghọru ele Karaịsi (1:9). Be bụ ele kwesiri ọkwnata mkpọma, ke mernu izi ọma Nyenwe aị gbasarụ nụ kpakara ẹli wam (1:8). Eleghi anya ọkwukwo izi ka jọoburu ọkwukwo izi mbọm Pọlu gbarụ, mọbu ọkwukwo mbọm be gbarụ nụ Tẹsitamenti Ikne. 
\ip Nga agịda ele badnụ lizọru megidne Pọlu, ọ gbazne Atẹnsi. Omekwo, o zizne Timoti zne lekwa kpa ele Karaịsi nooso (3:6-10). Nga Timoti hiehnarnu, o nyernu Pọlu ọtnutnu bụru ọma gbasịri ele Karaịsi zị nụ Tẹsalonika. 
\ip Kpa be zị neese ọvuva Nyenwe aị, agwna be zị́ma nọornu ẹrnu. Mkpọma naala ele berere mini kwnornu nụ agwna be nwụrnu, kọvu Nyenwe aị yávage. Pọlu gbalị o mee ma be mahịa nhne jeeme nga Nyenwe aị jaava (4:13-15), nụ kpa be kwesiri o wu bụdnu be (5:1-11). 
\iot Nhne zị n'ọkwukwo izi ka 
\io1 Obekwu ikwu \ior (1:1-3) \ior* 
\io1 Nhne atụ ke ọkwnata mkpọma ele Tẹsalonika \ior (1:4---3:13) \ior* 
\io1 Bụdnu ke nọoso Chiokike ovu n'ọnu \ior (4:1-12) \ior* 
\io1 Nhne be jeele anya a nga Nyenwe aị jaava \ior (4:13---5:11)\ior* 
\io1 Ezni ipne-aznụ nụ obekwu ikwu \ior (5:12-28) \ior* 
\c 1  
\p  
\v 1 Mawa, Pọlu nụ Saịlasi nụ Timoti naagba ọkwukwo gbaznenu ọgbako Chiokike ke zị nụ Tẹsalonika nụ rẹwhna ke Chiokike Nda nụ Nyenwe aị Jizọsi Karaịsi. 
\p Udno nụ oru dazịnu anụ.  
\v 2 A nọotunu Chiokike mmamma nụ risi kpakara anụ ige ọbula, neekpenu anụ okpukpe.  
\v 3 A neechenwanya ẹrnu anụ ige ọbula nụ ọkwnata ovu anụ nụ ruwhnu Chiokike Nda aị, nụ ẹrnu ọwhnun'anya anụ, nụ ọsuta mkpọma anụ ke hi nụ olile anya anụ nwernu nụ Jizọsi Karaịsi. 
\s1 Nhne atụ ke ọkwnata ovu 
\p  
\v 4 Ele me whnụrnu n'anya, Chiokike whnụrnu anụ n'anya, ka kpayarụ o jiri họru anụ bụru ele ke a.  
\v 5 Kwnornu nụ izi ọma a znirni anụ váge n'ikwu-ọnu etekne, kọvu o ji iknernema nụ ọkwnagidne ke Enine Nsọ mee anụ mahịa ezi ọka. Anụ magwụ kpa a wuru bụdnu aị n'esilawụru anụ.  
\v 6 Anụ ghọru ele mụhiaru nhne hite n'ole aị nụ Nyenwe aị anya. Ọ bụ n'ezi nụ anụ tarụ agịda awhnụwhnu, kọvu anụ jiri ovu ọso n'ọnu nabnanya izi a znirni anụ hite n'Enine Nsọ.  
\v 7 Kam kpayarụ, anụ jiri bụru ele be ji gbu atụ n'esilawụru ele kweru ekwe nụ kpakara Masidonia nụ Akaya.  
\v 8 Ikwu-ọnu Chiokike hiri n'ọnu anụ gazu kpakara ọhna, ọ bụ́o nụ Masidonia nụ Akaya kpọi. Ọkwnata ovu anụ nụ Chiokike zuru kpakara ọwa, ọ zá nhne berere a jookwu gbasịri a.  
\v 9 Be nookwu nụ anụ nabnanyarnụ aị nkarị, nụ kpa anụ sịgbasiri ọ kwanụ rẹnwu neekpenu Chiokike ke zị bụdnu nụ ezi ọka.  
\v 10 Anụ zị neese Nnwọ a ke hi n'oligwe, nye o mernu o hi n'ẹnwu lizọ, Jizọsi nye dọhiaru aị n'ovu owe ẹhni Chiokike ke naava. 
\c 2  
\s1 Ẹrnu Pọlu nụ Tẹsalonika 
\p  
\v 1 Rụmu nda aị, anụ magwụ nụ ige aị nụ anụ dazịkotaru n'otu bụ́o nhne etekne.  
\v 2 Ọ bụ n'ezi nụ a tarụ awhnụwhnu nụ nhne iwhnerne nụ Filipaị kpa anụ magwụ, kọvu Chiokike yinu aị aka o zni izi ọma a megidne okne ọkpagbu.  
\v 3 Nhne a nọorio anụ bụ́o hite nụ nhne ọjo mọbu echiche ọjo, a zá noopio ọ ghọnu anụ aghịgho.  
\v 4 Tnụnuma, a nookwu ọka lele ele Chiokike kwnatarụ ovu yisi izi ọma n'aka aị. A zá noopio o mee nhne jaamasị ele badnụ, kọvu a neeme nhne jọoso Chiokike ovu n'ọnu, nye magwụ nhne zị n'ovu aị.  
\v 5 Anụ magwụ nụ a jíle ikwu-ọnu ke jeeme badnụ tne eri, a kpúsnine ruwhnu aị n'aghịgho, ma a rigbu ele badnụ, Chiokike bụ nye akebne aị.  
\v 6 A zá noopio ele badnụ znarnị aị, mọbu anụwa mọbu ele berere. 
\p Ọ bụ n'ezi nụ a bụ ele izi Karaịsi, kọvu a kwéle ọ bụru ivu rịnya nyee anụ.  
\v 7 Kọvu a nụ lele nyerinya neechi nnwọ rẹma n'esilawụru anụ, nye anya dụru ẹli, ji wọhnernerne nọoznu rụmu a.  
\v 8 Ọwhnun'anya a nwernu hne anụ zị kpayarụ, ọ masịri aị anụ snornu aị kehịa igwe, ọ bụ́o n'izi ọma Chiokike kpọi, kọvu ọ bụru nụ o kwe omume, nụ bụdnu aị masị kwnornu nụ anụ zị aị mkpa.  
\v 9 Rụmu nda m, m magwụ m nụ anụ jeechenwanya, kpa a jiri aka aị lawụru rnụ ẹrnu iwhnehnie nụ abalị, ma a gharụ ọ bụru ivu rinya hne anụ zị kpa a nọokpo okwo izi ọma Chiokike n'esilawụru anụ. 
\p  
\v 10 Chiokike bụ nye akebne aị ma anụwa masị, kpa a wuru bụdnu zị nsọ, nụ ome mma ke nwée ọru n'esilawụru anụ ele kweru ekwe.  
\v 11 Anụ magwụ nụ a mesnornu anụ lele kpa nda neemesno rụmu a.  
\v 12 A zị naakwnagidne anụ, nọosnuta anụ ovu ma anụ noowu bụdnu lele kpa ele Chiokike sukwuru, ma anụ bna n'ẹli-eze a nụ igwugwu a. 
\p  
\v 13 Kam kpayarụ, a nọotunu Chiokike mmamma ige ọbula kwnornu nụ anụ nahọru ikwu-ọnu Chiokike ke anụ nụrnu n'ọnu aị. Anụ gwérule a lele nụ ọ bụ ikwu-ọnu ke badnụ, kọvu ọ bụ ikwu-ọnu Chiokike ke nọornu ẹrnu nụ rime anụ ele kweru ekwe.  
\v 14 Anụ bụru ele sno ọchi ọgbako Chiokike ke zị nụ Judiya, ele ke Karaịsi Jizọsi. Anụ tarụ awhnụwhnu n'aka ele ẹli anụ lele kpa ọgbako Chiokike tarụ awhnụwhnu n'aka ele Ju.  
\v 15 Ka bụ ele gburu Nyenwe aị Jizọsi nụ ele ọwhnurninya, chịhala aị. Be mejọru Chiokike mee masị ele badnụ nhne rikne.  
\v 16 Ka bụ ma a gharụ o kwunu ele bụ́o ele Ju ikwu-ọnu Chiokike, ma Chiokike znọhia be. Be zị nọotukwasi mmehie nụ risi be, tem ovu owe ẹhni Chiokike dnakwasị be. 
\s1 Ọ nọogwnu Pọlu  //  o zne Tẹsalonika 
\p  
\v 17 Kọvu rụmu nda aị, nga a whọgaru hne anụ zị ige matị n'anọ-ẹhni, ọ bụ́o nụ echiche, ọ nọogwnusi aị rikne ọ whnụ anụ anya.  
\v 18 Ọ masịri aị ọ vakwnusi anụ, agịda ige, mawa Pọlu pioru ọ va, kọvu Ekwensu bnosnirni aị.  
\v 19 Anụ bụ olile anya nụ igwugwu nụ ovu ọso n'ọnu a nwernu nga Nyenwe aị Jizọsi jaava,  
\v 20 N'ezi, anụ bụ igwugwu nụ ovu ọso n'ọnu aị. 
\c 3  
\p  
\v 1 Kpa a nwée rikne naagidne a berere, a kpebi ọ dazịri nụ Atẹnsi n'iwhuru aị.  
\v 2 Kam kpayarụ, a ziyaru Timoti nnwọ nda aị nụ nye sno aị nọornu ẹrnu Chiokike naagbasa izi ọma Karaịsi, ma ọ kwnagidne anụ, mee masị ma ọkwnata ovu anụ si rikne.  
\v 3 Anụ kwé nhne ọrnurna mee nye ọbula whọga n'ọnodi a. Anụ magwụ nhne ọrnurna jọodonu nye Karaịsi ọbula.  
\v 4 Nga aị nụ anụ zị, a kannụ anụ nụ be jaakpakna aị ẹhni. Anụ whnụrnu nụ ka mezuru.  
\v 5 Kam kpayarụ, kpa me nwée rikne gwuzoli nụ mkpọma m nụ nhne gbasịri anụ, m ziya Timoti ma m mahịa m kpa anụ nụ n'ọkwnata ovu. Ovu larụ m mini ma nye ọrnurna wam ọ kwnamana anụ n'ọkwnata ovu, ma ẹrnu aị nụ risi anụ bụru nhne etekne. 
\s1 Izi nkasi ovu Timoti  //  gweyarụ 
\p  
\v 6 Nga Timoti hi hne anụ zị hiehna, gweyannụ aị ọtnutnu ọma gbasịri ọkwnata ovu nụ ọwhnun'anya anụ, ọ kannụ aị nụ anụ neechenwanya nhne bụru ọma gbasịri aị ige ọbula, nụ ọ nọogwnu anụ ọ whnụ aị anya lele kpa ọ nọogwnu masị aị ọ whnụ anụ anya.  
\v 7 Kam kpayarụ, rụmu nda aị, a nwernu ọkasi ovu nụ rime awhnụwhnu aị kwnornu ọkwnata ovu anụ.  
\v 8 N'ezi ọka, a nwernu bụdnu ikne kwnornu nụ anụ gwuzo kwem nụ rime Nyenwe aị.  
\v 9 A jéenwe rikne tụnu Chiokike mmamma kpa o kwesiri kwnornu nụ ovu ọso n'ọnu a nwernu nụ ruwhnu Chiokike nụ risi anụ.  
\v 10 A zị neekpe okpukpe iwhnehnie nụ abalị ma a nwe rikne whnụ anụ anya ma a nyee anụ nhne ke zị anụ mkpa n'ọkwnata ovu. 
\p  
\v 11 Kịtna, a neekpe Chiokike Nda aị n'iwhuru a nụ Nyenwe aị Jizọsi gbamanụ aị apna ma a vakwnusi anụ.  
\v 12 Nyenwe aị mee ma ọwhnun'anya anụ ba aba k'agịda nụ risi nye ọbula, lele kpa ọwhnun'anya aị zị nụ risi anụ.  
\v 13 Chiokike gba anụ inwe ma anụ zịri snam, zịri masị nsọ nụ ruwhnu Chiokike Nda aị nga Nyenwe aị Jizọsi nụ ele nsọ a jaava. 
\c 4  
\s1 Bụdnu ke jọoso Chiokike  //  ovu n'ọnu 
\p  
\v 1 Ke ipne-aznụ, rụmu nda aị, a rịasno anụ wuru bụdnu ke jọoso Chiokike ovu n'ọnu, lele kpa a noowu. Bikno, anụ neeme kpam neezne nụ ruwhnu kwnornu Nyenwe aị Jizọsi.  
\v 2 Anụ magwụ nhne a znirni anụ bụ hite nụ rẹwhna Nyenwe aị Jizọsi. 
\p  
\v 3 Ka bụ nhne Nyenwe aị noopio ma ọ bịta anụ nsọ, ma anụ whọga nụ nhne ọbula ke zị́la rịchna lele ome ọyi,  
\v 4 ma nye ọbula mụhia kpa o jeejikwaru ẹhni a\f + \fr 4:4 \fq kpa o jeejikwaru ẹhni a \ft mọbu, \fq kpa ya nụ nnwerne a joowu\f* nụ apna ke zị nsọ nụ igwugwu,  
\v 5 ọ bụ́o ome nhne tụ iwhnerne ke nọogwnu be lele kpa ele máa Chiokike neeme.  
\v 6 Ọ zá nye mejọ nwene a nụ nhne nụ kpa mọbu ghọgbu a. Nyenwe aị jaata kpakara ele neeme nhne ọjo ka awhnụwhnu lele kpa a kannụ anụ, dọ masị anụ aka nụ nsnị.  
\v 7 Anụ magwụ nụ Chiokike súkwule aị ma a bụru ele zị́la rịchna, kọvu ma a wuru bụdnu zị nsọ.  
\v 8 Kam kpayarụ, nye ọbula ke jụru ọdo aka nụ nsnị ka jụ́la badnụ, kọvu Chiokike nye nyernu anụ Enine Nsọ a. 
\p  
\v 9 Nụ nhne gbasịri ọwhnun'anya ke rụmu nda, ọ zị́la mkpa a gbanụ anụ ọkwukwo, kwnornu nụ anụ magwụ nụ Chiokike znirni anụ whnụ ibne anụ n'anya.  
\v 10 N'ezi, anụ whnụrnu kpakara rụmu nda ele zị nụ Masidonia n'anya. A naarịasno anụ neemekọ kpam neezne nụ ruwhnu. 
\p  
\v 11 Anụ gbalị noowu bụdnu zị wọhnernerne, neeme nhne ke gbasịri anụ, anụ rnụsi ẹrnu rikne lele kpa a znirni anụ,  
\v 12 ma ele bụ́o ele ke Chiokike nọoso anụ anya, anụ gharụ ọ dnakwarụ n'ẹhni nye ọbula. 
\s1 Nyenwe aị vawa 
\p  
\v 13 Rụmu nda aị, ọ bụ́o ọma anụ zịri nụ ọ́ma ama nụ nhne gbasịri ele nwụrnu ọnwu, ma ọ gharụ gbu anụ igbugbu lele ele nwée olile anya.  
\v 14 A kweru nụ Jizọsi nwụrnu ẹnwu, hi masị n'ẹnwu lizọ, kpam masị, a kweru nụ Chiokike jeeme ele nwụrnu ọnwu nụ rime Jizọsi joosno a va.  
\v 15 Lele kpa ikwu-ọnu Nyenwe aị kwuru, nụ aị ele zị bụdnu, tem dụ ige Nyenwe aị jaava, jéenwe rikne beru ele nwụrnu ọnwu ọsno.  
\v 16 Kwnornu nụ Nyenwe aị n'iwhuru a jeegweru okne nkọli hi n'oligwe hiedna, nụ nkọli nye risi enine izi, nụ ọdidna ọkwodu Chiokike. Ele nwụrnu nụ rime Karaịsi jeebe ọso lizọ.  
\v 17 Omekwo, be jeegwelizọ aị ele zị bụdnu neese a nụ be nụ rime erumeru znekwnusi Nyenwe aị n'olu. Aị nụ Nyenwe aị jaazị kpam ọkwnukokwnu.  
\v 18 Kam kpayarụ, anụ gweru ikwu-ọnu ka naakasitaru ibne anụ mkpọma. 
\c 5  
\s1 Jiknernu kwnornu ọbochi  //  Nyenwe aị 
\p  
\v 1 Kịtna, rụmu nda aị, ọ zị́la mkpa ọ gbanụ anụ ọkwukwo gbasịri ige nụ ọbochi nga nhne ele ka jeeme,  
\v 2 kwnornu nụ anụ magwụ nkarị nkarị nụ ọbochi Nyenwe aị jaava lele nye buznu n'abalị.  
\v 3 Nga ele badnụ neeche “Udno nụ ẹli-ọji-iyi,” aghọm jaavakwnusi be n'ibiri, lele kpa rime neeme nnwerne zị rime, be jéenwe rikne gbanahọru a. 
\p  
\v 4 Kọvu anụ zị́la nụ rime ọchichiri rụmu nda aị, ke jeeme ọbochi wam vakwnusi anụ n'ibiri lele nye buznu.  
\v 5 Hne anụ bụ rụmu ke iwhne nụ rụmu ke ọbochi, a wú bụdnu ke abalị mọbu ke ọchichiri.  
\v 6 Kam kpayarụ, a nụ́ lele ele berere, ele neezni anyarna, kọvu a bụ ele tnegwụ etne nụ ele anya dụru ẹli.  
\v 7 Kwnornu nụ ele anyarna neezni anyarna n'abalị, ele manya, manya noogbu be n'abalị.  
\v 8 Kpa a bụ rụmu ke iwhne, a bụru ele anya dụru ẹli, ele wogwu ọkwnata ovu nụ ọwhnun'anya lele mbno mkpọma, a gweru olile anya ọznohia kpuru nụ risi lele okpu-ọgwnu.  
\v 9 Kwnornu Chiokike súkwule aị ma a ta awhnụwhnu ke ovu owe ẹhni a, kọvu ma a nwehịa ọznohia hite Nyenwe aị Jizọsi Karaịsi.  
\v 10 Jizọsi Karaịsi nwụrnu ẹnwu nụ risi aị, ma a snornu a zịri bụdnu, a tne etne mọbu a zị n'anyarna.  
\v 11 Kam kpayarụ, anụ naakasi ibne anụ ovu, noowu ibne anụ lele ọro lele kpa anụ neeme n'ezi. 
\s1 Ezni ipne-aznụ ke Pọlu 
\p  
\v 12 Kịtna rụmu nda aị, a naarịasno anụ, anụ sọbisinu kpakara ele nọornu ẹrnu n'esilawụru anụ, bụ ele nọoznu anụ nụ rime Nyenwe aị.  
\v 13 Anụ nyee be igwugwu ke agịda, anụ whnụ be n'anya kwnornu ẹrnu be. Anụ wuru n'udno n'esilawụru ẹhni anụ.  
\v 14 Rụmu nda aị, anụ gbalị dọ ele ime mgwụ aka nụ nsnị, anụ kwnagidne ele nọotu iwhnerne, anụ yinu ele nwée rikne aka, anụ gweru enwerne ovu mesno kpakara badnụ nhne.  
\v 15 Ọ zá nye ji nhne ọjo kwụhnata nhne ọjo. Kọvu anụ gbalị ma anụ nwe mkpọma ọma n'ẹhni ibne anụ ma kpakara ele badnụ ige ọbula. 
\p  
\v 16 Anụ nwụdna ige ọbula.  
\v 17 Anụ kpe okpukpe ige ọbula.  
\v 18 Anụ nọotu mmamma n'ọnodi ọbula, kwnornu nụ ka bụ nhne Chiokike noopio n'aka anụ nụ rime Karaịsi Jizọsi. 
\p  
\v 19 Anụ mésni bẹkwnu ke Enine Nsọ.  
\v 20 Anụ lédna izi ọwhnurninya anya.  
\v 21 Anụ tule kpakara nhne, anụ nwụkwaru nhne ke bụru ọma aka rikne,  
\v 22 kọvu zeru kpakara nhne ke bụ́o ọma. 
\p  
\v 23 Chiokike ke udno n'iwhuru a jaabịta anụ nsọ n'apna ke zuru ozu. Chiokike bịta enine anụ, nụ mkpụru ovu nụ anọ-ẹhni anụ n'apna nwée ọru tem dụ ige Nyenwe aị Jizọsi Karaịsi jaava.  
\v 24 Nye wam sukwuru anụ bụ nye kwesiri ọkwnata ovu, o jeeme nhne ka. 
\p  
\v 25 Rụmu nda aị, anụ bikno, kpenu aị okpukpe.  
\v 26 Anụ bekwutaru ẹhni anụ lele ele sno Karaịsi.  
\v 27 M ji m rẹwhna Nyenwe aị naakaa anụ gwnụ ọkwukwo izi ka nụ nsnị kpakara rụmu nda. 
\p  
\v 28 Oru ke Nyenwe aị Jizọsi Karaịsi dazịgidnenu anụ.