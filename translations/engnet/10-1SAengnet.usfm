\v 14  \w If|strong="H1961"\w* \w you|strong="H5921"\w* \w fear|strong="H3372"\w* \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd*, \w serving|strong="H5647"\w* \w him|strong="H5921"\w* \w and|strong="H3068"\w* \w obeying|strong="H8085"\w* \w him|strong="H5921"\w* \w and|strong="H3068"\w* \w not|strong="H3808"\w* \w rebelling|strong="H4784"\w* \w against|strong="H5921"\w* \w what|strong="H6963"\w* \w he|strong="H3068"\w* \w says|strong="H6310"\w*, \w and|strong="H3068"\w* \w if|strong="H1961"\w* \w both|strong="H1571"\w* \w you|strong="H5921"\w* \w and|strong="H3068"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w* \w who|strong="H3068"\w* \w rules|strong="H4427"\w* \w over|strong="H5921"\w* \w you|strong="H5921"\w* \w follow|strong="H1961"\w* \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w your|strong="H3068"\w* \w God|strong="H3068"\w*, \w all|strong="H5921"\w* \w will|strong="H3068"\w* \w be|strong="H1961"\w* \w well|strong="H1571"\w*.  
