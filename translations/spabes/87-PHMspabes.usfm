\v 5 \w porque|strong="G2532"\w* oigo \w del|strong="G3588"\w* amor \w y|strong="G2532"\w* \w de|strong="G1519"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w* \w que|strong="G3588"\w* \w tienes|strong="G2192"\w* \w hacia|strong="G4314"\w* \w el|strong="G3588"\w* \w Señor|strong="G2962"\w* \w Jesús|strong="G2424"\w* \w y|strong="G2532"\w* \w hacia|strong="G4314"\w* \w todos|strong="G3956"\w* \w los|strong="G3588"\w* santos.   
