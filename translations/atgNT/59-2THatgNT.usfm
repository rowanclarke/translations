\id 2TH - Okphela 
\h 2 iTẹsalonia 
\toc1 2 iTẹsalonia 
\toc2 2 iTẹsalonia 
\toc3 2 iTẹsa 
\mt2 Ebe onuzi-eva ni iPọlu ọ kẹkẹ ghi ẹgbọ 
\mt1 ITẹsalonia 
\mt2 Eni e miesuọ 
\c 1  
\p  
\v 1 Mhẹmhẹ iPọlu ali iSalasi ali iTimoti anye ri ebe ona ghi igbaa oyi eni e mie iJesu iKirisiti suọ ni o la ekẹ iTẹsalonika, ni e khi ẹgbọ eyi Ẹshinẹgba Ita awa ali iJesu iKirisiti Ọnọmhuẹ.\f + \fr 1:1 \ft Li zẹ \fq Ika 17.1\f* 
\p  
\v 2 Mhi lema Ẹshinẹgba Ita awa ali iJesu iKirisiti Ọnọmhuẹ e mhuẹ isomhelemhi na ẹ, e ri opfọmhẹ na ẹ. 
\s1 Ikphẹmhi ali Iromhi isọsọ 
\p  
\v 3 Inyọghuo, anye mema ya ke tsẹ Ẹshinẹgba uwegbe na ẹ ẹghẹghẹ kpa. O ti ni anye ke lighọ, irari khi irudunga oyẹẹ ọọ fu shọ ẹghẹghẹ kpa. Inono ni a mhuẹ na egbe ọọ fu shọ.  
\v 4 Lọli o zẹ ni anye rọ rẹ ẹ la iteva igbaa nya eyi eni e mie iJesu iKirisiti suọ eyi Ẹshinẹgba a neta ọmọse. Eri anye rẹ ẹ neta ọmọse itobọ abi a li dobẹ ri obọ mu udu migha irudunga oyẹẹ elemhi okhọli ali imufẹ nya ni a mu vule shi ẹ ọ. 
\p  
\v 5 Enana nya e rọkhasẹ khi ẹzọ oyi Ẹshinẹgba o migha shi ipfuasẹ. Itobọ ighọ Ẹshinẹgba ọ ya leli ẹ shi eni e tẹ ọ, ni e ya lo iloghie oyọli ni a mẹ osoli ẹ shi.  
\v 6 Ẹshinẹgba ọa ya gbe azẹba, ọ ya ri osoli fali eni e na ẹ osue ota.  
\v 7 Ọ ya ri iyẹmhẹa na ẹẹ ni a mẹ osue, ọ gbo li ri oni iyẹmhẹa na anye. Ọ ya riẹlẹ ona ini iJesu Ọnọmhuẹ ọ da feli lasele shi idane elemhi avuerẹ, lọli ali igẹni eniẹmhi eyọli.  
\v 8 Ọ ya na ẹgbọ ni ẹa lẹsẹ Ẹshinẹgba osue, ali eni ẹa ri usomhi onete oyi iJesu Ọnọmhuẹ gbe akanya.  
\v 9 E ya mẹ osue. E ghu tiemhi ilimhi iriẹriẹ. A rue wẹ odalo oyi Ọnọmhuẹ ali ufumhi oniẹmhi oyọli le.\f + \fr 1:9 \ft Li zẹ \fq Aza 2.10\f* 
\v 10 Ẹlẹ ni a ya mẹ ona khi, ogbẹlẹ ni Ọnọmhuẹ ọ ya bhale, ni eni e ri udu nga li e ri ikuẹghiẹ ali ekpẹ na li. Li shi ẹẹ lọ, itobọ khi a she mie ungmemhi ni anye gueyẹ ẹ suọ. 
\p  
\v 11 Lọli o zẹ ni anye rọọ sọ iromhi na ẹ, Ẹshinẹgba ọ zẹ ni a li khi eni e ya la agbọ ni ọọ ghọle ọli. Ali ọ ri ekpabọ eyọli ri ugbamhi onete ni a mhọli bhale ya tse na ẹ, li shi onete ni irudunga oyẹẹ o rẹ ẹ riẹlẹ.  
\v 12 Itobọ okhale oyi Ẹshinẹgba ọyawa ali oyi iJesu iKirisiti Ọnọmhuẹ ọyawa, a ya rue ufumhi ghi eva oyi iJesu Ọnọmhuẹ ọyawa, ọ li ri ufumhi ghi ẹ. 
\c 2  
\s1 Ọna ọkhọlọ 
\p  
\v 1 Inyọghuo, ingme ibhale oyi iJesu iKirisiti Ọnọmhuẹ ọyawa, ali abi awa li ya kuma li egbe,\f + \fr 2:1 \ft Li zẹ \fq 1 iTẹsa 4.15-17\f* 
\v 2 a khi zẹ ni usamhi oyẹẹ o nyanya ghagha ku ni a yila. Ini ọgbọkhọghuo ọ ririẹ khi imekẹ lọli mẹ, okekhi usomhi ona kẹ ọ guele, okekhi eri ọọ khi ebe ni anye kẹkẹ ghi lọli luẹ rọte zẹ ọli khi ogbẹlẹ oyi Ọnọmhuẹ o she bhale,  
\v 3 a khi zẹ ni ọgbọkhọghuo ọ te odẹ okhọghuo di ẹ. Irari khi oni ogbẹlẹ ọa ya bhale ini aa li mẹ ukpokpomhi imuokhuẹ-vule shi Ẹshinẹgba ọ ali ini ọna umhasuọ-esọ ni ọ khi ọgbọ ọbe ọa li feli lase gboo, ikhi ọni a mhẹsẹ owa erẹ na.  
\v 4 Ọ ya mu okhọli vule shi emhikpa ni ẹgbọ ẹ lu Ẹshinẹgba, ilitsa ali emhikpa ni ẹgbọ ẹẹ ga ọ, ọ ri egbọli fu dọsẹ wẹ nya. Ọ gbo ga vu ya shitọ Owa oyi Ẹshinẹgba oyi Ẹshinẹgba ọọ liẹ khi lọli ke khi Ẹshinẹgba.\f + \fr 2:4 \ft Li zẹ \fq iDan 11.36; Ezik 28.2\f* 
\p  
\v 5 Aa ke sato khi mhi gue ingme ena nya yẹ ẹ abi mhi rọ nu ẹ la?  
\v 6 Ẹẹ a lẹsẹ emini o zẹ khi aa rọli lasele khasẹ ne, ini ẹghẹghẹ oyi ọna ọkhọlọ ọna o da ramhi, a ya rọli lasele khasẹ.  
\v 7 Ama eni ikhiakhiamhi ekpabọ ọkhọlọ ena e she bẹlẹ ẹ gbe ikanya eyẹwẹ, ama ọni ọ mu ọli gbaga. Ama ọni ọna ọkhọlọ ọa ya feli lasele ini ọni ọ mu ọli gbaga ọa li lase odẹ-a.  
\v 8 Ẹghẹghẹ aghọ a ya ri ọna ọkhọlọ khasẹ, ọni iJesu Ọnọmhuẹ ọ ya ri ungmemhi ni o rọte ọli unu lasele pfuse-a. Ugẹmhi oyọli ini ọ nyenẹ egbe bhale o ya ga pfuse ọli-a nya.\f + \fr 2:8 \ft Li zẹ \fq Aza 11.4\f* 
\v 9 Ọna ọkhọlọ ọna, ọ ya ri ekpabọ oyi Ọkphaghiẹ bhale, ọọ gbe ọnyaloa ẹgbhuẹ ali ọshabọ ọdọda.\f + \fr 2:9 \ft Li zẹ \fq iMat 24.24\f* 
\v 10 Ọ ri udimhi ọdọda ni e khọlọ di ẹgbọ ni ẹẹ pfua. E ya pfua irari khi ẹa lama mie wẹkhi eri e nono igẹsikia, ni o kha mie wẹ pfuese.  
\v 11 Itobọ ighọ, Ẹshinẹgba ọ rọ ghie ayẹmhẹ ẹgbhọli ghi wẹ, ni ee rọ mie emini e khi ẹgbhọli suọ.  
\v 12 A ya pfa ẹzọ mu ọgbọ ni ọa da mie igẹsikia suọ ne, ni ọ da mhuẹ ọghuẹmhẹ shi olamhẹ. 
\s1 A migha gbagbagba 
\p  
\v 13 Anye mema ya ke tsẹ Ẹshinẹgba uwegbe ẹghẹghẹ kpa na ẹ, inyọghuo ni Ọnọmhuẹ ọ nono. Irari khi ẹẹ Ẹshinẹgba ọ kpe zẹ ni a ya mie pfuese. Ayẹmhẹ oyọli o rẹẹ khi eni e pfuasẹ, ali eni e mie igẹsikia suọ.  
\v 14 Rọte usomhi onete oyanye, Ẹshinẹgba ọ te lu ẹ shi ona. Eri ọ lu ẹ ni a rọ mhuẹ okemhi shi ufumhi oyi iJesu iKirisiti Ọnọmhuẹ oyawa.  
\v 15 Irarighọ, inyọghuo, a migha gbagbagba, a mu eni igẹsikia ni anye sẹsẹ ẹ mhuẹ abi anye rọte itsabọ ali elemhi ebe ni anye kẹkẹ gue ọli yẹ ẹ. 
\p  
\v 16 IJesu iKirisiti Ọnọmhuẹ ọyawa luẹghuo ali Ẹshinẹgba Itawa ni ọ nono ingme oyawa, ni ọ rọte okhale oyọli ri udu shi awa ọ, ni ọ gbo ri irudushi ni ọa ya nighise na awa,  
\v 17 e ka ri udu shi ẹ ọ, e gbo zese ẹ a shi ikanya ali ingmemhi enete. 
\c 3  
\s1 IPọlu ọọ, a sọ iromhi na wẹwẹ 
\p  
\v 1 Ni mhi rọ gbe ọli ukhomhi inyọghuo, a ke sọ iromhi na anye. A sọ iromhi ni ungmemhi oyi Ọnọmhuẹ o nyanya ke ga asha kpa, ni ẹgbọ e gbo mie ọli, ni e ri ufumhi ke ghi Ẹshinẹgba, abi a li mie ọli abi o rọ la ẹ iteva.  
\v 2 A gbo ke sọ iromhi Ẹshinẹgba ọ rue anye obọ oyi ẹgbọ ebe ali ena ọkhọlọ lasele, irari khi ọa khi ọgbọkpa ọ miesuọ. 
\p  
\v 3 Ama ọni a ri egbe ẹ nga Ọnọmhuẹ ọ khi. Ọ ya ri itoto na ẹ ọ khukhu ẹ obọ oyi ọna ọkhọlọ.  
\v 4 Anye regbenga Ọnọmhuẹ khi a riẹlẹ ali khi a kiele ẹ ke riẹlẹ emini anye sẹsẹ ẹ.  
\v 5 Mhi lema, Ọnọmhuẹ ọ ka udu oyẹẹ lẹsẹ inono ni o funẹ ni Ẹshinẹgba ọ mhuẹ ali ni iKirisiti ọ rẹẹ migha egbegbọ. 
\s1 Ọgbọgbọ ọ ke gbe akanya 
\p  
\v 6 Inyọghuo, anye ri eva oyi iJesu iKirisiti Ọnọmhuẹ ọyawa mhẹsẹ na ẹ, a ti kia na inyọghuo ọkhọghuo ni ọ la agbọ ọwaza ni ọa ya deba osẹsẹ ni anye ẹ sẹsẹ ẹ.  
\v 7 Ẹẹ ọyẹẹ a lẹsẹ khi o ti ni a ke li abi anye ẹ li. Anye ẹa li ọwaza abi anye rọ nu ẹ la,  
\v 8 wẹkhi eri anye mie ọgbọkhọghuo emhi le ni anye a fali ota shi. Eri anye ri ochoghọ gbe akanya, ọpfọ o ta anye ghe ẹlẹ ọguota ali ẹlẹ iyọsẹ, ini anye khi ya khi itsua na ọngẹẹ tsua.  
\v 9 Ọa khi itobọ khi anye ẹa tẹ eni ẹ mhila ẹ ikpaghiobọ, anye rọ lighọ ngeli. Eri anye lighọ, ni anye khi irọkhọkhọ ni áá ke deba.  
\v 10 Abi anye rọ nu ẹ la, anye gueyẹ ẹ khi, “Ọgbọ ni ọa lama gbe akanya ọ khi le eminale.” 
\p  
\v 11 Eri anye ngme ona itobọ khi anye suọ khi ẹgbọ eghuo e la ẹ iteva ni ẹa lama gbe akanya, ni ẹa ya li emhikhọghuo ama ikanya eyi ẹgbọ elese ẹẹ sọnọ unu ke pfuẹchẹ-a.  
\v 12 Anye ri eva oyi iJesu iKirisiti Ọnọmhuẹ mhẹsẹ na ẹgbọ eghọghọ, anye gbo tse agua yẹwẹ e ke ngeli angeli ni o te odẹ. E ke gbe akanya ni e te mẹ emhi ya ke le.  
\v 13 Ama ẹẹ inyọghuo a khi zẹ ni onete iriẹlẹ o susu ẹ. 
\p  
\v 14 Ini ọgbọkhọghuo ọ la ọ ni ọa ya ri omhẹsẹ ni a kẹkẹ shi ebe ona gbe akanya, a lolo tọ ọgbọ ọghọghọ ọkpẹ. A khi kugbe ọgbọ ọghọghọ ọ, ni omama o mu ọli.  
\v 15 Ama a khi ngeli deba li abi ọbe ẹ, ama a ri ochoghọ tse agua ye ọli abi inyọghuo. 
\s1 Ingmemhi ni e kpe ukhokho 
\p  
\v 16 Ọnọmhuẹ luẹghuo ni ọ khi odẹ opfọmhẹ oyawa ọ ka ri opfọmhẹ na ẹ ẹghẹghẹ kpa ali odẹ khi odẹ. Ọnọmhuẹ ọ ka nu ẹ la. 
\p  
\v 17 Mhẹmhẹ iPọlu mhi ri obọ oyẹmhẹ kẹkẹ ebe ona ghi ẹ. Mhi tsẹ ẹ. Ina mhi liẹ kẹkẹ eva oyẹmhẹ shi ebe ni mhi kẹkẹ kpa. Ina mhi liẹ kẹkẹ ebe. 
\p  
\v 18 Okhale oyi iJesu iKirisiti ọyawa o ka nu ẹ la nya.