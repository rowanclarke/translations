\v 19 \w Mandó|strong="G2753"\w* \w que|strong="G3588"\w* \w la|strong="G3588"\w* \w multitud|strong="G3793"\w* \w se|strong="G2532"\w* recostara \w sobre|strong="G1909"\w* \w la|strong="G3588"\w* \w hierba|strong="G5528"\w*. \w Tomó|strong="G2983"\w* \w los|strong="G3588"\w* \w cinco|strong="G4002"\w* panes \w y|strong="G2532"\w* \w los|strong="G3588"\w* \w dos|strong="G1417"\w* \w peces|strong="G2486"\w*, levantó \w los|strong="G3588"\w* ojos \w al|strong="G3588"\w* \w cielo|strong="G3772"\w* \w y|strong="G2532"\w* \w los|strong="G3588"\w* \w bendijo|strong="G2127"\w*. \w Los|strong="G3588"\w* \w partió|strong="G2806"\w* \w y|strong="G2532"\w* \w los|strong="G3588"\w* \w dio|strong="G1325"\w* \w a|strong="G1519"\w* \w los|strong="G3588"\w* \w discípulos|strong="G3101"\w*, \w y|strong="G2532"\w* \w los|strong="G3588"\w* \w discípulos|strong="G3101"\w* \w a|strong="G1519"\w* \w la|strong="G3588"\w* \w multitud|strong="G3793"\w*.   
\p
