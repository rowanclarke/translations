\id 2PE - Okphela 
\h 2 iPita 
\toc1 2 iPita 
\toc2 2 iPita 
\toc3 2 iPit 
\mt2 Ebe onuzi-eva ni 
\mt1 IPita 
\mt2 Ọ kẹkẹ 
\c 1  
\p  
\v 1 Mhẹmhẹ iSamọ iPita ni mhi khi oghumha ali aghiusomhi na kẹẹ ọyi iJesu iKirisiti, mhi kẹkẹ ebe ona ghi eni e mhọli irudunga nabi oyi anye ni o mu ẹloe, ni a rọte angeli onete oyi Ẹshinẹgba ali iJesu iKirisiti Ọmiepfuese rọ na wẹ. 
\p  
\v 2 Okhale ali opfọmhẹ o ka khi oyẹẹ rọte ilẹsẹ ni a lẹsẹ Ẹshinẹgba ali iJesu Ọnọmhuẹ oyawa. 
\s1 Ulumhi ali uzẹmhi oyi Ẹshinẹgba 
\p  
\v 3 Itoto oyi Ẹshinẹgba o she ri emhikpa ni o ri awa ya ke la agbọ irudunga na awa, irari khi awa lẹsẹ ọni ọ ri ufumhi ali onete oyọli ti awa mama egbe.  
\v 4 Eni ekpabọ eniẹmhi ena ọ rọ rue isomhopfa ni e mu ẹloe ni ọ shobọ na awa. Ini a bhale ya ẹ khi irari eni isomhopfa ena awa mẹ asha na pfue epfua ni o la ọghuẹmhẹ emhi agbọ, ni awa mhọli okemhi shi agbọ oyi Ẹshinẹgba. 
\p  
\v 5 Irarighọ, rọshẹka ri ingeli enete ma irudunga oyẹ, gbo ri ilẹsẹ ma ingeli enete.  
\v 6 Ri iguẹ-regbekia she egbe ma ilẹsẹ, ri iregbemie ma iguẹ-regbekia shi egbe, ri angeli irudunga ma iregbemie,  
\v 7 ri isomhelemhi-inyọghuo ma angeli irudunga, ri inono ma isomhelemhi inyọghuo.  
\v 8 Irari khi ini u mhọli eni ingeli enana egbegbọ, e ya rẹ ke zaza, wa gbe akanya elemhi ilẹsẹ ni u lẹsẹ Ọnọmhuẹ iJesu iKirisiti.  
\v 9 Ama ọni ọa da mhọli eni ingeli ena ne, ọa ya mẹ ekẹ nuata, eri ọ zẹ alo, ọ she yele-a khi Ẹshinẹgba ọ she kpẹ khuẹsẹ luẹ olamhẹ enediọ-a pfuasẹ. 
\p  
\v 10 Irarighọ, inyọghuo-mhẹ, rọshẹka ni uzẹmhi ali ulumhi oyẹ o migha egbegbọ. Ini u wa lighọ, waa ya tigbe dọ owẹ ekẹ-a wẹkhi eri u ya de.  
\v 11 Ẹghẹghẹ aghọ Ẹshinẹgba ọ ya khueghie odẹ Omhẹsẹ oyi Ọnọmhuẹ-a nẹ lo. Ikhi Ọnọmhuẹ na agbọagbọ Ọmiepfuese iJesu iKirisiti ọyawa. 
\s1 A ri esọ shi emini Ebe-no-pfuasẹ o ngme 
\p  
\v 12 Mhi ya ke yele ẹ le eni ingme ena nya ẹghẹghẹ kpa. Ini a ririẹ kpẹ lẹsẹ wẹ, ni a migha gba elemhi igẹsikia ni a mhọli ena.  
\v 13 Mhi lẹsẹ khi o ti ni mhi yele ẹ eni ingme ena nya le, ini mhi da kie la agbọ.  
\v 14 IJesu iKirisiti Ọnọmhuẹ oyawa ọ she rọ li khasẹ mhẹ khi ogbẹlẹ eyẹmhẹ ẹa ke bu, khi mhi kẹlẹ ya ghua.  
\v 15 Mhi ya rọshẹka ri ingme ena nya shi ẹ odalo ni a ke sato ọ, ini mhi sọ ukhokho gbe. 
\s1 Eni e ri ukpẹloe mẹ ufumhi oyi iKirisiti 
\p  
\v 16 Ọa khi okhẹ ẹgbhọli anye regbenga gue ingme inyenegbe bhale oniẹmhi oyi iJesu Ọnọmhuẹ yẹ ẹ. Alo eyanye anye rọ mẹ ufumhi oyọli.  
\v 17 Anye la aghọ ni Ẹshinẹgba ita ọ rọ ri ufumhi ali ekpẹ na li, ni uruli oyi Ẹshinẹgba ọ rọ rọte otughunu ni o gẹ nyanyanya ngme, ni ọọ, “Omimhẹ ni mhi nono ingme oyọli na, ọ ma ghọle mhẹ.”  
\v 18 Eri anye suọ khi oni ungmemhi o rọte idane ngme tiemhile, abi anye rọ nu ọli la ukhomhi ute no pfuasẹ.\f + \fr 1:18 \ft Li zẹ \fq iMat 17.1-5; iMak 9.2-7; iLuk 9.28-35\f* 
\p  
\v 19 Ighọ anye li mhọli iregbenga shi usomhi ni emekẹguele e guele, khi egbegbọ lọ. O ma a ti ẹ egbe ini a ri esọ shi oni ungmemhi, itobọ khi eri o li abi ákpá ni o la alo ebili ẹ gẹ nyagha, ramhi ni ogbe o rọ maghiẹ alo-a, ni imekẹ oyi ukpẹtata na obili-atso o rọ gẹ shi udu o yẹ.  
\v 20 Ọzukhomhi oni ungmemhi khi, a lẹsẹ khi ungmemhi amẹguele okhọghuo ọa rọte ilẹsẹ oyi ọmekẹguele ọkhọghuo bhale.  
\v 21 Irari khi ungmemhi amẹguele okhọghuo ọa ri imẹlemhi oyi ọgbọ bhale ghue, ama Ayẹmhẹ-nọ-pfuasẹ o la ẹgbọ egbe gbe akanya rẹwẹ gue usomhi oyi Ẹshinẹgba le. 
\c 2  
\s1 Ena Osẹsẹ ẹgbhọli ali epfua oyẹwẹ 
\p  
\v 1 Abi emekẹguele eyi ẹgbhọli e ke li la iteva eyi ẹgbọ iZirẹni, ighọ esẹsẹ ẹgbhọli e ya li la ẹ iteva. E ya tsua osẹsẹ ẹgbhọli ni ọọ yese ẹgbọ-a lasele ke sẹsẹ ẹgbọ, e ga kie Ọnọmhuẹ ni ọ dẹ wẹ, e ya ri epfua ni o kẹlẹ ghi egbewẹ.  
\v 2 Ighọ ebubu ẹ e li ya deba odẹ omama eyi itsẹbọ eyẹwẹ, e ri omama shishi oni odẹ igẹsikia oyi iKirisiti-a.  
\v 3 E ya ri emhi ituegbe rue okhẹ ẹgbhọli lasele gueyẹ ẹ, ni e rọ mẹ asha di ẹ mie ikpaghọ. Ẹshinẹgba ọ she sọ wẹ ẹzọ se agbọagbọ, epfua oyẹwẹ o migha khẹ wẹ odẹ. 
\p  
\v 4 Irari khi ini Ẹshinẹgba ọa kẹsẹ igẹni le abi e rọ lamhẹ deba Ẹshinẹgba, ama ọ ku wẹ lo ilimhi iriẹriẹ, ọ ri iwẹghẹ gẹ wẹ abọ pfino kulo alo ebili migha khẹ ogbẹlẹ isọ-ẹzọ.  
\v 5 Ini Ẹshinẹgba ọa pfuese agbọ onodiọ, ama ọ ri ochikpho oniẹmhi pfuse oni agbọ olamhẹ-a, sẹ ni iNoa ni ọọ tse abọ iguẹ ngeli ali apfọli oshilua.\f + \fr 2:5 \ft Li zẹ \fq Igbae 6.1--7.24\f* 
\v 6 Ini Ẹshinẹgba ọ pfa ẹzọ mu iSodomu ali iGomora, khi ọ ri erali tosẹ wẹ ni e de emuẹ-a, ni ọ rẹwẹ riẹlẹ irọkhọkhọ abi o ya li ẹgbọ ni ẹa mhọli Ẹshinẹgba egbe,\f + \fr 2:6 \ft Li zẹ \fq Igbae 19.24\f* 
\v 7 ni ọ rọ pfuese iLọti, ọmọse ni ọ guẹ ngeli, ni ẹgbọ ena umhasuọ-esọ e ri ingeli ebe nasẹ ayẹmhẹ.\f + \fr 2:7 \ft Li zẹ \fq Igbae 19.1-16\f* 
\v 8 Eri ọni ọmọse ọna ipfuasẹ ọnana ọ viẹ oya elemhi ayẹmhẹ oyọli ẹghẹghẹ kpa shi ingeli ọkhọlọ ni ọọ mẹ ali ni ọọ gbolo suọ.  
\v 9 Ini o khi ighọ, Ọnọmhuẹ ọ lẹsẹ abi ọ liẹ tsumhi ẹgbọ eyọli elemhi imhẹsẹbino, ali ọ gbo li lẹsẹ abi ọ li ya pfi ẹgbọ ọkhọlọ lo anasẹmhẹ ramhi ogbẹlẹ isọ ẹzọ.  
\v 10 Tete ẹgbọ ni e deba ọghuẹmhẹ idiegbe oyẹwẹ ni e ri ukpẹloe gbe omhẹsẹ oyi Ẹshinẹgba. 
\p E mhọli igbedu obe ali ititiegbe. Ulishi ọa ya mu wẹ ni e rọ ri unu ghi igẹni rọ yese wẹ-a.  
\v 11 Ama abotseku khia khi eni igẹni ena e mhọli ekpabọ dọsẹ eni esẹsẹ ẹgbhọli ena, ẹa ya yese wẹ-a khasẹ Ọnọmhuẹ.  
\v 12 Eri eni ẹgbọ ena ẹẹ pfi unu-a shi emini ẹa lẹsẹ udi ọli. Eri e li abi elamhakọ ni ẹa mhọli ẹgbhali ni a bia, ni a mu ẹ gbolo le tsẹ. Ighọ e li ya pfua abi elamhakọ.  
\v 13 Opfuse a rọ ya fali wẹ ota shi odẹ opfuse ni wẹwẹghuo e bẹ na egbewẹ. Idobiẹ ẹlẹ ọguota gboo, ẹẹ bino khi o khi agbọ ilili, ni o ya khuese idiegbe oyẹwẹ. Ẹgbọ ebe e khi itobọ khi ini e nu ẹ le eminale inono kugbe eghọ, eri e kiele ẹ ngeli angeli efiala.  
\v 14 Alo efiala eyi okia, e zẹ shi ukhomhi, ikpotso ni e ya yemhẹ shi wẹ ọ, e kia bino alo. Okiamhi olamhẹ ni ọọ gbe wẹ ọa tigbe ẹ mhọli ukpẹsẹ. Ẹgbọ ni udu oyẹwẹ ọa sheshe ẹẹ di kulo igha olamhẹ. E she wẹna emhi ituegbe shi udu. Elemhi itsẹ eyi Ẹshinẹgba e la kia.  
\v 15 E she da egbegbọ odẹ lase, e wasẹ odẹ oyẹwẹ-a. E she deba odẹ oyi iBelamu omi iBeọ vu ni ọ mhọli ukpọkọ shi ukpaghọ ni ọ ya mie shi onobe ilili.  
\v 16 Ni akphẹrẹ ọ dese shi angeli olamhẹ. Akphẹrẹ ni o khia khi ọa kpẹ mhọli ungmemhi ọgbọ shi unu, ni ọ ri uruli ọgbọ nu iBelamu ngme shi angeli ujili.\f + \fr 2:16 \ft Li zẹ \fq iNọba 22.4-35\f* 
\p  
\v 17 Eri ẹgbọ ena e li abi okẹ ni o khakha-a, ali uza ni o bi abi amẹ ni akpekpeli o pfiolo irarogbe kua. Ẹshinẹgba ọ she riẹlẹ ilimhi iriẹriẹ shi ekẹ ẹ khẹ wẹ ni e la mẹ osoli.  
\v 18 Eri ẹẹ ngme ingmemhi itono obọ udu, ali ingmemhi ni e viọlọ, rọ rẹ ẹgbọ sato ọghuẹmhẹ idiegbe oyẹwẹ, ni e ba di wẹ nyenẹ egbe je olamhẹ. Ikhi ẹgbọ ni e lẹsẹ rọte ifuabọ eyi ẹgbọ ni e la agbọ ẹgbhọli pfue.  
\v 19 E shobọ ẹpfua na wẹ, ama wẹwẹ ni e shi oni obọ onana, e khi ighumha angeli epfua. Irari khi oghumha ọgbọ ọ khi shi emini o da mhẹsẹ na ayẹmhẹ oyọli.  
\v 20 Irari khi, ini ẹgbọ e she da rọte oyese ni o la agbọ pfue ne itobọ khi e lẹsẹ iJesu iKirisiti Ọnọmhuẹ, ni e rọ gbo ri egbewẹ na emhi agbọ gẹnọ ne, ikpukhokho oyẹwẹ o kẹ khọlọ dọsẹ igbaekẹle oyẹwẹ.  
\v 21 O kha tinẹ ini ẹa bie kpẹ lẹsẹ odẹ ipfuasẹ oyi Ẹshinẹgba lọ, khi e lẹsẹ ọli se, e tigbe sọ ukhokho gbe ode ipfuasẹ oyi Ẹshinẹgba ni a rọ na wẹ.  
\v 22 Emini ọ li wẹ o rọkhasẹ khi ekpita ona khi igẹsikia lọ, ni ọọ, 
\q1 “Áwá ọ mu egbe nyenẹ 
\q2 gbo ya le ekpa 
\q2 ni ọ kpa shi ekẹ. 
\q1 Agulu ni a kpe khuẹsẹ-a se, 
\q2 ọ gbo mu egbe nyenẹ 
\q2 je igbọlọ ya pfuẹ.”\f + \fr 2:22 \ft Li zẹ \fq Ekpi 26.11\f* 
\c 3  
\s1 Ọnọmhuẹ ọ nyenẹ egbe ẹ bhale 
\p  
\v 1 Emọlemhẹ, ebe onuzi-eva ni mhi kẹkẹ ẹ ghi ẹ na, eri mhi ri ebe eva ena ya guise ẹ le ali ni a rọ mhọli isamhi eni e te odẹ.  
\v 2 A sato ingmemhi ni emekẹguele ni e pfuasẹ e ngme ni o she tẹsẹ, ali omhẹsẹ ni Ọnọmhuẹ Ọmiepfuese ọyawa ọ mhẹsẹ rọte obọ ighiusomhi na kẹẹ eyawa. 
\p  
\v 3 Onododẹ, a lẹsẹ khi ogbẹlẹ ni e kpukhokho, ẹgbọ ni e ri ungmemhi oyi Ẹshinẹgba a li egia e ya lasele. Ẹẹ li egia ẹẹ riẹlẹ ọghuẹmhẹ idiegbe oyẹwẹ.\f + \fr 3:3 \ft Li zẹ \fq iJu 18\f* 
\v 4 E ya ke liẹ, “Ighe ibhale ni ọ shobọ khi lọli ya bhale mena? Abi ititawa e te ghuloa, emhikpa e kiele ẹ je odalo abi e li rọte igbaekẹle agbọ la ọ.”  
\v 5 Eri e famhi rọli shi iẹ-esọ-a, khi rọte ungmemhi oyi Ẹshinẹgba a te ma idane, ni a rọ gbo rọte amẹ ri amẹ ma ekẹ agbọ.\f + \fr 3:5 \ft Li zẹ \fq Igbae 1.6-9\f* 
\v 6 Ama, eni amẹ ena a gbo rọ ri ochikpho pfuse ẹgbọ na agbọ onodiọ-a.\f + \fr 3:6 \ft Li zẹ \fq Igbae 7.11\f* 
\v 7 Ama agbọ ali idane ni e kie laọ ogbe-namo, Eghiele oyi Ẹshinẹgba a rọ rẹwẹ migha rẹwẹ ẹ khẹ opfuse oyi erali. Eri a zẹ wẹ obọ ọ khẹ ogbẹlẹ iguẹzọ ni a rọ ya pfuse ẹgbọ ọkhọlọ-a. 
\p  
\v 8 Emọlemhẹ, a khi yele emhi oghuo-a khi, eri ogbẹlẹghuo o li abi ogbẹlẹ agbẹlẹ, ogbẹlẹ agbẹlẹ o li abi ogbẹlẹghuo ukpẹloe oyi Ẹshinẹgba.\f + \fr 3:8 \ft Emini a ri onana ngme khi Ẹshinẹgba ọa deba ẹghẹghẹ gbe akanya.\f*\f + \fr 3:8 \ft Li zẹ \fq Iwolo 90.4\f* 
\v 9 Ọa khi eri Ẹshinẹgba ọ ti egbe ẹ je ukhokho shi emini ọ rọ shobọ, abi ẹgbọ eghuo e liẹ sa khi ini emhi ọọ ti ekẹ eri o wu ekẹ-a eghọ. Eri ọ mema mhọli irabọmudu na ẹ, itobọ khi ọa nono ni ọgbọkhọghuo ọ pfua, ama ni ọgbọkpa ọ te agbọ olamhẹ mu nyenẹ. 
\p  
\v 10 Ama eri ogbẹlẹ oyi Ọnọmhuẹ o ya bhale abi ibhale oyi oghiatọ. Oni ogbẹlẹ, eri idane o ya ri okeke oniẹmhi kele-a udemhija. Erali oniẹmhi o daghiẹ emini e la idane nya kua. Ekẹ ali emhikpa ni e laọ e kala-a.\f + \fr 3:10 \ft Li zẹ \fq iMat 24.43; iLuk 12.39; 1 iTẹsa 5.2; Irọ 16.15\f* 
\p  
\v 11 Aborọkhia khi a ya lina pfuse emhi nya ena, uwali ẹgbọ enabisẹ a kha ke fẹ khi? A kha ke la agbọ ipfuasẹ ali agbọ Ẹshinẹgba,  
\v 12 abi a li ri ẹloe shi ekẹ ẹ khẹ ogbẹlẹ oyi Ẹshinẹgba, ni awa ke riẹlẹ emini o ya rọli bhale pia, ali ogbẹlẹ ni a ya ri erali pfuse idane-a erali oniẹmhi o daghiẹ emini e la idane-a nyaa.  
\v 13 Ama emini Ẹshinẹgba ọ rọ shobọ, awa migha a khẹ, ikhi iloghie ali ekẹ agbọ onogbọ, ni o khi apfẹ iguẹ-ngeli.\f + \fr 3:13 \ft Li zẹ \fq Aza 65.17; 66.22; Irọ 21.1\f* 
\p  
\v 14 Irarighọ, ẹẹ emọle mhẹ, abi a li ri ẹloe shi ekẹ ẹ khẹ oni ogbẹlẹ ena, a zẹ ni a bhale ya ẹ ẹ shi ingeli ni ẹa mhọli ichimhi ali umhaguẹkia, ali a la opfọmhẹ.  
\v 15 Ri ọli shi udu khi irabọmudu ni Ọnọmhuẹ ọ mhọli na awa, khi, ni ọ ba ri ẹghẹghẹ na awa mhọli imiepfuese lọ, ẹzẹzẹ abi inyọghuo awa iPọlu ọ kpe li kẹkẹ ọli shi ebe ghi ẹ abi Ẹshinẹgba ọ li ri oni ilẹsingme na li.  
\v 16 Ina ọ kie liẹ kẹkẹ ọli shi ebe, ini ọ da a ngme eni ingmemhi ena ne. Ebe ni ọ kẹkẹ e tsua ingme eghuo ni e lolo ẹ munu irọlo-ọgbọ-esọ, ni ẹgbọ ni ẹa mhọli ilẹsẹ ali igẹsikia e kholo ẹ manọ, abi e liẹ khi ma ingmemhi elese ni e la Ebe-no-pfuasẹ ni o ya ri epfua ghi wẹ. 
\p  
\v 17 Irarighọ, emọlemhẹ, abi a ke rọ lẹsẹ onana eghọ, a mu egbe ẹ ini a khi ya deba odẹ ẹgbhọli oyi ẹgbọ ena umhasuọ-esọ, ini a khi rọte iguẹmigha oyẹ ẹ de.  
\v 18 Ama mena awa ke fu shi okhale ali ilẹsẹ ni awa lẹsẹ Ọnọmhuẹ Ọmiepfuese ọyawa ikhi iJesu iKirisiti. Lọli a ri Ufumhi a na agbọagbọ. Atsẹ!