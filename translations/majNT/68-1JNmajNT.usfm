\id 1JN Mazatec of Jalapa de Diaz
\h Xu̱ju̱n xi tjun kits'ínntu nda̱ postru̱ Jua
\toc1 Xu̱ju̱n xi tjun kits'ínntu nda̱ postru̱ Jua
\toc2 Xu̱ju̱n xi tjun kits'ínntu nda̱ postru̱ Jua
\toc3 1 Jn.
\mt1 Xu̱ju̱n xi tjun kits'ínntu nda̱ postru̱ Jua
\c 1
\s1 B'i̱ ts'ín tsakúya Jua yáha Ée̱n
\p 
\v 1 Tíb'eni̱jmíi̱hi̱ xi tu̱ b'a̱ ts'ín jahá tíjña santa nkúhu nga tuts'ihi̱n ni. Kinu'yái̱ nta̱ha̱ ko̱ tukui̱n kiyako̱ho̱ni̱. Kiyai̱ ko̱ ntsa̱i̱ kin'eko̱ho̱ni̱. Kui xi Én xi ts'ínk'íéntu tík'un xu̱ta̱.
\v 2 Y'ejña tík'un a̱jinni̱ ko̱ ji̱n kiyai̱. Tíbixínya kixi̱ ni xi kiyai̱ ko̱ tíb'eni̱jmíi̱ xi tíjña tík'un sín, xi y'ejñajihi̱n Nti̱a̱ Na̱'miu̱ ko̱ xi ji̱n kis'ejña chjini̱.
\p 
\v 3 Xi kiyai̱ ko̱ kinu'yái̱, kui xi ta̱ tíb'eni̱jmíi̱hi̱ ko̱ jun, tu̱ xi b'a̱ ts'ín ko̱ jun nkuhú ka̱mako̱ho̱ni̱. B'a̱ ts'ín nkuhú ka̱mangujinka̱á Nti̱a̱ Na̱'miu̱ ko̱ Jesucristo̱ xi Ntíhi̱ maha.
\v 4 Tíb'et'ai̱hi̱ ni xu'bi̱ tu̱ xi k'úé tsjo tsjoho̱nu̱u.
\s1 B'i̱ ts'ín tsakúya Jua nga ni xi n'eé bakúchji tsa kis'ejinná Nti̱a̱ná
\p 
\v 5 Tsakúyani̱ Jesucristo̱ nga Nti̱a̱ná, kui xi nd'í xi ts'ín ndzjen ko̱ ndaha̱chí najmi tjín má jyun a̱jihi̱n. Kui xi tíb'eni̱jmíi̱hi̱.
\v 6 Tsa b'a̱ ku̱i̱xíaán nga Nti̱a̱ná ts'e̱ná ko̱ tu̱ sa má jyuu̱hún tintsu̱ba̱ ngáá, tích'ana̱cha̱á ko̱ najmi tín'eé ni xi na̱xu̱ tjín.
\v 7 Tu̱nga tsa tintsu̱ba̱á má ndzjee̱n xi nkú ts'ín tíjña Nti̱a̱ná má ndzjee̱n, b'a̱ ts'ín nkuhú maka̱á xinki̱á ko̱ jníhi̱ Jesucristo̱ xi Ntíhi̱ Nti̱a̱ná ts'ín jená nga kjexínná ngayjee̱ ngatitsunná.
\p 
\v 8 Tsa najmi tjínná ngatitsun ku̱i̱xíaán, ta̱ ñáha tích'ana̱cha̱ha̱á yjoná ko̱ najmi tíjñajinná ni xi na̱xu̱ tjín.
\v 9 Tsa n'e̱kié yjoná nga tjínná ngatitsun, ts'i̱ínndyjat'aná ngatitsunná Nti̱a̱ná ko̱ ts'i̱ín jená nga kjéxinná ngayjee̱ ni xi tjíntujínná xi najmi na̱xu̱ nginku̱n. B'a̱ ts'i̱ín a̱t'aha̱ ja kitsjá éhe̱n nga b'a̱ ts'i̱ín ko̱ ts'ín ni xi na̱xu̱ tjín.
\v 10 Tsa najmi tjínná ngatitsun ku̱i̱xíaán, tíya tsank'áá Nti̱a̱ná ko̱ najmi tíjñajin ani̱ma̱ná éhe̱n.
\c 2
\p 
\v 1 Jun ntína̱, tíb'et'ánu̱u ni xu'bi̱ tu̱ xi najmi n'e̱henu ngatitsun. Tu̱nga tsa tjín xi ts'i̱ín tje̱n'yún ngatitsun, tíjñaná xi ku̱i̱nchja̱ntjainá nginku̱n Nti̱a̱ Na̱'miu̱, kui xi Jesucristo̱ xi na̱xu̱ ts'ín.
\v 2 Kui xi kitsjá yjoho̱ xi nkúhu chje̱ tu̱ xi n'e̱ndyjat'ahaná ngatitsunná ñá xi ja kis'ejinná. Ko̱ najmi tu̱ suba ngatitsunná kits'ínndyjat'a, ko̱ ní ngatitsuhu̱n ngayjee̱ xu̱ta̱ xi tjín a̱sunntee̱.
\p 
\v 3 Tsa tín'etjusaán ni xi y'éjña Nti̱a̱ná, b'a̱ ts'ín yahaná nga ja yaá Nti̱a̱ná.
\v 4 Tsa tjín xi: “An be” ku̱i̱tsu̱, tu̱nga tu̱ sa najmi ts'íntjusuhún ngá ni xi y'éjña, kui xi nda̱ tsank'á. Najmi tíjñajin ani̱ma̱ha̱ ni xi na̱xu̱ tjín.
\v 5 Tu̱nga xi ts'íntjusun éhe̱n, kju̱axi̱ nga kui xi ts'íntjo Nti̱a̱ná xi nkú nga ts'ín tjíhin nga ts'i̱íntjo. Nk'ie nga b'a̱ n'e bintsubaá, b'a̱ n'e yahaná nga tintsu̱ba̱jii̱hín.
\v 6 Xi tíjñajin ni xi ts'e̱ Nti̱a̱ná ku̱i̱tsu̱, kui xi xi nkú ts'ín y'ejña Jesucristo̱, b'a̱ ts'ín tjíhin nga k'úéjña.
\s1 B'i̱ ts'ín tíbatéxumaha̱ Jua xu̱ta̱ ni̱nku̱
\p 
\v 7 Já nts'ena̱, ni xi tíb'et'ánu̱u nd'a̱i̱, najmi a̱s'a̱i tíb'éjñahá Nti̱a̱ná. Kju̱a̱téxuma chá xi kin'ekjas'en nínu̱u santaha nga tuts'ihi̱n ni tíbet'ánu̱u. Kui kju̱a̱téxuma chá xu'bi̱, kui éhen xi ja kinu'yó nk'ie.
\v 8 Tu̱nga xi nkú ts'ín y'ejña Jesucristo̱ ko̱ xi nkú ts'ín tintsu̱bo̱o b'éjña chji nku ni tse̱tse̱ xi y'aha̱ ra̱ ni xi y'éjña Nti̱a̱ná. Kui ni xi tíb'et'ánu̱u e̱i̱ a̱t'aha̱ ja j'ai ts'ín ndzjen nd'í xi ndoo̱. Kui nga ja tífi ndyjaha má jyuu̱n.
\p 
\v 9 Xi b'a̱ ku̱i̱tsu̱ nga má ndzjee̱n síjña tu̱nga tu̱ sa unkiehé ngá nda̱ nts'e̱, kui xi má jyuu̱n síjñajin sa.
\v 10 Xi tjoho̱ nda̱ nts'e̱, kui xi má ndzjee̱n síjña tehe̱nte, má nga najmi tjín ni xi ts'i̱ínkijnejihi̱n ngatitsun.
\v 11 Tu̱nga xi unkie nda̱ nts'e̱, kui xi má jyuu̱n síjña ko̱ yo̱ tsú'ba ko̱ najmi be má xi tje̱hen tífi, a̱t'aha̱ ja kits'ínka̱ha̱ má jyuu̱n.
\p 
\v 12 Jun ntína̱, títs'inntúnu̱u a̱t'aha̱ tu̱ nga̱t'aha̱ ni xi kits'ín Jesucristo̱ kin'endyjat'aha̱nu̱u ngatitsunnu̱u.
\v 13 Ko̱ jun xi tí'minu̱u na̱'mi, títs'inntúnu̱u a̱t'aha̱ ja yo xi tu̱ b'a̱ ts'ín jahá tíjña santaha nga tuts'ihi̱n ni. Ko̱ jun xi tí'minu̱u já a̱sti, títs'inntúnu̱u a̱t'aha̱ kin'e ngano̱ho̱o nda̱nindoo̱.
\p 
\v 14 Jun ntína̱, ja kuats'inntúnu̱u a̱t'aha ja yo Nti̱a̱ Na̱'miu̱. Ko̱ jun xi tí'minu̱u na̱'mi, ja kuats'inntúnu̱u a̱t'aha ja yo xi tu̱ b'a̱ ts'ín jahá tíjña santaha nga tuts'ihi̱n ni. Ko̱ jun xi tí'minu̱u já a̱sti, ja kuats'inntúnu̱u a̱t'aha̱ tjínnu̱u nga'yún ko̱ tíjñajin tehe̱nte ani̱ma̱nu̱u éhe̱n Nti̱a̱ná ko̱ a̱t'aha̱ ja kin'e ngano̱ho̱o nda̱nindoo̱.
\p 
\v 15 Najmi tu̱ n'etjó a̱sunntee̱ ko̱ ta̱ ndaha ni xi tsjá a̱sunntee̱. Tsa tjín xi tjoho̱ a̱sunntee̱, kui xi najmi tjoho̱ Nti̱a̱ Na̱'miu̱.
\v 16 A̱t'aha̱ ngayjee̱ ni xi tsjá a̱sunntee̱ najmi má tíjña Nti̱a̱ Na̱'miu̱ nibáha̱ ra̱. A̱sunntee̱ ní nibáha̱ ra̱. Yo̱ nibáha̱ ra̱ nga nchja̱ha̱ ani̱ma̱ha̱ xu̱ta̱ ni xi tjín ko̱ nga mjehe̱ ts'i̱ínts'e̱ ni xi fásihi̱n ko̱ nga nk'a b'asje yjoho̱ nga̱t'aha̱ ni xi tjíhi̱n.
\v 17 Ja tífe ni̱stjihi̱n a̱sunntee̱ ko̱ ni xi nchja̱ha̱ ani̱ma̱ha̱ xu̱ta̱, tu̱nga máha xi títs'ín xi nkú ts'ín mjehe̱ Nti̱a̱ná, kui xi k'úéjña sín.
\s1 B'i̱ ts'ín tsakúya Jua nga chúhu̱ún yjoná já xi fi kontra̱ha̱ Jesucristo̱
\p 
\v 18 Jun ntína̱, ja ni̱stjin xi fekuu̱ tintsu̱ba̱á nd'a̱i̱. Ja kik'inyanu̱u nga tjíhin nga kj'u̱a̱í xi ngju̱a̱i̱ kontra̱ha̱ xi kits'ín nibá Nti̱a̱ná, ko̱ xi nkú kik'innu̱u b'a̱ ts'ín nd'a̱i̱ ja tíi̱ncha f'ai ṉkjún já kontra̱ha̱ Jesucristo̱. Kui nga mankjihinná nga ja tinchajián ni̱stjin xi fekuu̱.
\v 19 Kui xi i̱ncha tsitjujínni̱ e̱i̱, tu̱nga najmi já ts'a̱ji̱hín niu̱. A̱t'aha̱ tsa já ts'a̱ji̱n niu̱, najmi i̱ncha ngji t'axín ra̱ kai. Tu̱nga i̱ncha tsitjuhú tu̱ xi b'a̱ ts'ín kiya chji chjihi nga tjín xi najmi ji̱n mako̱ni̱.
\p 
\v 20 Máha jun, Jesucristo̱ kitsjánu̱u Espiri̱tu̱hu̱ Nti̱a̱ná ko̱ ngatentoo̱ mankjinnu̱u ni xi na̱xu̱ tjín.
\v 21 Tíb'et'á xu̱ju̱nnu̱u a̱t'aha̱ mankjinnu̱u ni xi na̱xu̱ tjín. Najmi nga̱t'aha̱ tsa najmi mankjinnu̱u, a̱t'aha̱ ní nga mankjinnu̱u, kui nga tíb'et'áha̱nu̱u. Ko̱ mankjinnu̱u nga ndaha nku kju̱a̱tsank'á najmi nibáha̱ ra̱ ni xi na̱xu̱ tjín.
\p 
\v 22 Xi najmi ts'ínkjáíhi̱n nga Jesu xi kits'ín nibá Nti̱a̱ná, kui xi nku nda̱ tsank'á. Kui xi nda̱ kontra̱ha̱ Jesucristo̱, a̱t'aha̱ najmi ts'ínkjáíhi̱n nga Nti̱a̱ Na̱'miná xi Nti̱a̱ ko̱ nga Jesucristo̱ xi Ntíhi̱.
\v 23 Tu̱ yáhá ni xi najmi ts'ínkjáíhi̱n nga Jesucristo̱ xi Ntíhi̱ Nti̱aṉá, kui xi ta̱ ndaha najmi tíjñajihi̱n Nti̱a̱ Na̱'miu̱. Tu̱nga xi ts'ínkjáíhi̱n nga Jesucristo̱ xi Ntíhi̱ Nti̱aṉá, kui xi ta̱ tíjñajihi̱n Nti̱a̱ Na̱'miu̱.
\p 
\v 24 Kui b'a̱ maha, t'ejñajin tehe̱ntehenu ani̱ma̱nu̱u én xi kinu'yó santa nkúhu nga tuts'ihi̱n ni. Tsa s'e̱jñajin tehe̱nte ani̱ma̱nu̱u én xi kinu'yó santa nkúhu nga tuts'ihi̱n ni, b'a̱ ts'ín ko̱ jun ta̱ ku̱i̱ntsu̱ba̱jin tehe̱ntoho̱o Ntíu̱ ko̱ Nti̱a̱ Na̱'miu̱.
\v 25 Nga ku̱i̱ntsu̱ba̱ tík'un síaán, kui nihi xi kitsúya títjunná Jesucristo̱ nga tsjáná.
\p 
\v 26 Tíb'et'ánu̱u ni xu'bi̱ a̱t'aha̱ tjín xi mjehe̱ k'u̱a̱na̱cha̱nu̱u.
\v 27 Tu̱nga máha jun, tíjñajin tehe̱ntenu̱u Espiri̱tu̱hu̱ Nti̱a̱ná xi kitsjánu̱u Jesucristo̱. Najmi machjéhe̱n tsa tjín xi ku̱a̱kúyanu̱u, a̱t'aha̱ ta̱ kuihi Espiri̱tu̱ bakúyayjenu̱u. Ni xi na̱xu̱ tjín bakúyanu̱u, najmi ni tsank'á. Kui nga xi nkú ts'ín tsakúyaha̱nu̱u Espiri̱tu̱, b'a̱ n'e̱ ti̱ntsu̱ba̱jin tehe̱ntehe̱ ru̱u Jesucristo̱.
\p 
\v 28 Kui b'a̱ maha nd'a̱i̱, ntína̱, ti̱ntsu̱ba̱jin tehe̱ntehe̱ ru̱u Jesucristo̱, tu̱ xi najmi jo jan ka̱mahaná nk'ie nga ku̱a̱kúchji yjoho̱ ko̱ najmi ka̱ma subaná nginku̱n nk'ie nga kj'u̱a̱í.
\v 29 Yo nga na̱xu̱ ts'ín Jesucristo̱. Kui nga ta̱ tjíhin nga cha̱hanu nga ngayjee̱ xu̱ta̱ xi ts'ín ni xi na̱xu̱, kui xi kitsjáha̱ Nti̱a̱ná nga ntíhi̱ ka̱ma.
\c 3
\s1 B'i̱ ts'ín tsakúya Jua nga ntíhi̱ Nti̱a̱ná kits'ín maná
\p 
\v 1 Cha̱so̱o xi nkú ts'ín tjo ts'atihi̱ ñá Nti̱a̱ Na̱'miná, nga santaha ntíhi̱ Nti̱a̱ná 'miná. Ko̱ kju̱axi̱ nga ntíhi̱ Nti̱a̱ná ñá. Kui kju̱a̱ha nga najmi behená xu̱ta̱ a̱sunntee̱, a̱t'aha̱ najmi be Nti̱a̱ná.
\v 2 Jun já nts'ena̱, ñá xi ntíhi̱ Nti̱a̱ná nd'a̱i̱. Ko̱ ndaha tsa najmi kje̱e yaá nkú k'úéntaá a̱skahan, tu̱nga yanáá nga b'a̱ k'úéntaá xi nkúhu Jesucristo̱ nk'ie nga kj'u̱a̱íkúchji yjoho̱, a̱t'aha̱ cha̱ sisián xi nkú tjín.
\v 3 Ko̱ ngatentee̱ xi b'a̱ ts'ín tíkuyáha̱ Jesucristo̱, kui xi títs'ín nga tín'e je nginku̱n Nti̱a̱ná. B'a̱ tí'be xi nkú ts'ín je Jesucristo̱.
\p 
\v 4 Tu̱ yáha ni xi títs'ín ngatitsun, kui xi tíbangane kju̱a̱téxumaha̱ Nti̱a̱ná. Nk'ie nga biyuné kju̱a̱téxumaha̱ Nti̱a̱ná, kui nii̱ xi ngatitsuu̱n.
\v 5 Ja yo nga j'aikúchji yjoho̱ Jesucristo̱ tu̱ xi j'aikjexíhin ngatitsunná. Ndaha nku ngatitsun najmi kis'ehe̱.
\v 6 Kui b'a̱ maha, ngayjee̱ xi tíjñajin tehe̱ntehe̱ ra̱ Jesucristo̱ najmi ts'ín ngatitsun. Tu̱nga ngayjee̱ xi títs'ín ngatitsun, najmi kje̱e be Jesucristo̱ ko̱ ta̱ ndaha najmi kje̱e mankjihi̱n yáha kui.
\p 
\v 7 Jun ntína̱, najmi tu̱ ch'a xi k'u̱a̱na̱cha̱nu̱u. Xi ts'ín ni xi na̱xu̱ tjín, kui xi na̱xu̱ nginku̱n Nti̱a̱ná xi nkú ts'ín na̱xu̱ Jesucristo̱.
\v 8 Tu̱nga xi ts'ín ngatitsun, kui xi nda̱nindoo̱ ts'e̱he̱, a̱t'aha̱ nda̱nindoo̱ kits'ín ngatitsun santaha nkúhu nga tuts'ihi̱n ni. Kui kju̱a̱ha nga j'aikúchjihi yjoho̱ Ntíhi̱ Nti̱a̱ná, tu̱ xi ts'i̱ínndyja xáha̱ nda̱nindoo̱.
\p 
\v 9 Ngayje̱e xi Nti̱a̱ná kitsjáha̱ nga ka̱ma ntíhi̱ najmi nkaha̱ ts'ín ngatitsun, a̱t'aha̱ kju̱a̱tík'uhu̱n Nti̱a̱ná tíjñajihi̱n. Najmi nkaha̱ ts'ín ngatitsun, a̱t'aha̱ Nti̱a̱ná kitsjáha̱ nga ka̱ma ntíhi̱.
\v 10 B'a̱ ts'ín s'ejña chjihi yá xi ntíhi̱ Nti̱a̱ná ko̱ yá xi ntíhi̱ nda̱nindoo̱. Tu̱ yáhá ni xi najmi na̱xu̱ ts'ín ko̱ a ra̱ najmi tjoho̱ nts'e̱, kui xi najmi Nti̱a̱ná ts'e̱he̱.
\s1 B'i̱ ts'ín tsakúya Jua nga n'e̱tjáá xinki̱á
\p 
\v 11 Nga tjíhin nga b'i̱ ngjáán n'e̱tjáá xinki̱á, b'a̱ tsu én xi kinu'yó santaha nkúhu nga tuts'ihi̱n ni.
\v 12 Najmi b'a̱ha tu̱ n'eé xi nkúhu Cain. Kui xi nda̱nindoo̱ ts'e̱he̱. Kui nga kits'ínk'iehen nda̱ nts'e̱. ¿Á kits'ínk'iehen? Kits'ínk'ien a̱t'aha̱ na̱xu̱ ni xi kits'ín nda̱ nts'e̱ ko̱ máha kui, ch'on kits'ín.
\p 
\v 13 Jun já nts'ena̱, najmi tu̱ ma nkjúnnu̱u tsa ts'i̱ín unkienu̱u xu̱ta̱ a̱sunntee̱.
\v 14 Ja yaá ñá nga tsitjujián a̱jihi̱n ngabayoo̱ ko̱ nga ku̱i̱ntsu̱ba̱ tík'aán nginku̱n Nti̱a̱ná. Yaá ni xu'bi̱ a̱t'aha̱ tjoná já nts'eé. Xi najmi tjíhi̱n kju̱a̱tjo, kui xi tíjñajin sa ngabayoo̱.
\v 15 Ngayjee̱ xi unkie nda̱ nts'e̱, nda̱ts'ínk'ien ani̱ma̱há xu'bo̱, ko̱ ja yo nga nku nda̱ts'ínk'ien ani̱ma̱ najmi tíjñajihi̱n kju̱a̱tík'un sín.
\p 
\v 16 Yaá ni xi 'mihi̱ kju̱a̱tjo a̱t'aha̱ Jesucristo̱ kits'ínkjas'en yjoho̱ ngandaná. B'a̱ ta̱ ts'ín ko̱ ñá tjíhin nga n'e̱kjas'eén yjoná ngandaha̱ já nts'eé.
\v 17 Tsa nku nda̱nchi̱ná tíbe nga ndyjat'aha̱ nda̱ nts'e̱ ni xi machjéhe̱n tu̱nga najmi ka̱ma ni̱ma̱há ra̱, ¿a tíjñajin kju̱a̱tjoho̱ Nti̱a̱ná ani̱ma̱ha̱?
\v 18 Jun ntína̱, najmi tu̱ suba énnu̱u xi b'a̱ ku̱i̱tsu̱ nga tjínnu̱u kju̱a̱tjo nga chu̱bo. Tu̱ sa ní ni xi katakúchji nga tjínnu̱u kju̱a̱tjo n'o̱o.
\p 
\v 19 Yaá nga a̱jihi̱n ni xi na̱xu̱ tintsu̱ba̱jián ko̱ najmi jo jan maná nk'ie nga tintsu̱ba̱á nginku̱n Nti̱a̱ná.
\v 20 Kui nga ndaha tsa ani̱ma̱ná b'a̱ títsu nga tjínná jé, tu̱nga 'yúhún chánka sa Nti̱a̱ná nga ani̱ma̱ná ko̱ kui xi beyjená.
\v 21 Jun já nts'ena̱, tsa najmi chumi nihi xi títs'ínnijéná ani̱ma̱ná, najmi jo jan maná nga tinchaá nginku̱n Nti̱a̱ná,
\v 22 ko̱ kui tsjáná ngayjee̱ ni xi ku̱i̱nchíhi̱í, a̱t'aha̱ tín'etjusaán ni xi y'éjña ko̱ tín'eé ni xi sasíhi̱n.
\p 
\v 23 Nga n'e̱ s'ejián Jesucristo̱ xi Ntíhi̱ maha ko̱ nga b'i̱ ngján n'e̱tjáá xinki̱á xi nkú ts'ín y'éjña, kui xi kju̱a̱téxumaha̱ Nti̱a̱ná.
\v 24 Xi títs'íntjusun xi nkú ts'ín y'éjña, kui xi tíjñajin tehe̱nte Nti̱a̱ná ko̱ Nti̱a̱ná tíjñajin tehe̱ntehe̱ xu̱ta̱ xu'bo̱. Ko̱ nga̱t'aha̱ Espiri̱tu̱ xi kitsjáná, b'a̱ ta̱ n'e yahaná nga kui tíjñajin tehe̱ntená.
\c 4
\s1 B'i̱ ts'ín tsakúya Jua má xi kui Espiri̱tu̱hu̱ Nti̱a̱ná
\p 
\v 1 Jun já nts'ena̱, najmi tu̱ n'e s'ejiun ngatentee̱ xi b'a̱ ku̱i̱tsu̱nu̱u nga Espiri̱tu̱hu̱ Nti̱a̱ná títs'ín nga tínchja̱. Tu̱ sa ní cha̱se̱ sisihu̱un xi nkú ku̱i̱tsu̱, tu̱ xi b'a̱ n'e̱ cha̱hanu tsa kju̱axi̱ nga Espiri̱tu̱hu̱ Nti̱a̱ná tíjñajihi̱n a ra̱ najmi. A̱t'aha̱ kitsejíhin a̱sunntee̱ já profeta̱ tsank'á.
\v 2 Xi b'a̱ tsu nga yjoninte kik'a Jesucristo̱ nga j'ai a̱sunntei̱, kui niu̱ xi ku̱a̱kúchjinu̱u nga kui xi tíjñajihi̱n Espiri̱tu̱ xi ts'e̱ Nti̱a̱ná.
\v 3 Ko̱ xi najmi b'a̱ tsu nga b'a̱ ts'ín j'ai Jesucristo̱, kui xi najmi tíjñajihi̱n Espiri̱tu̱hu̱ Nti̱a̱ná. Espiri̱tu̱ ch'onk'un xi ts'e̱ ní nda̱ kontra̱ha̱ Cristo̱ tíjñajihi̱n. Ja kinu'yó nga tjíhin nga kj'u̱a̱í xi ngju̱a̱i̱ kontra̱ha̱ xi kits'ín nibá Nti̱a̱ná. Kui ja tíjña a̱sunntee̱ nd'a̱i̱.
\p 
\v 4 Jun ntíntíntína̱, Nti̱a̱ná ts'e̱nu̱u ko̱ ja kin'e ngano̱ho̱o já profeta̱ tsank'á xu'bo̱, a̱t'aha̱ xi tíjñajinnu̱u 'yún tjín saha̱ nga'yún nga xi tíjñajihi̱n xu̱ta̱ a̱sunntee̱.
\v 5 Kui já xu'bo̱ xi xu̱ta̱ a̱sunnte. Kui nga ni xi ts'e̱ a̱sunntee̱ nchja̱ni̱jmíyaha ko̱ xu̱ta̱ a̱sunntee̱ basínñjuhu̱ ni xi nchja̱.
\v 6 Tu̱nga máha ji̱n, Nti̱a̱ná ts'e̱ni̱. Xu̱ta̱ xi ja be Nti̱a̱ná, kui xi basínñjuni̱. Xu̱ta̱ xi najmi Nti̱a̱ná ts'e̱he̱, kui xi najmi basínñjuni̱. B'a̱ n'e cha̱ha yá xi tíjñajihi̱n Espiri̱tu̱ xi tsuya ni xi na̱xu̱ tjín ko̱ yá xi tíjñajihi̱n jáninda xi b'ana̱cha̱.
\s1 B'i̱ ts'ín tsakúya Jua mí nihi xi y'aha̱ kju̱a̱tjoo̱
\p 
\v 7 Jun já nts'ena̱, b'i̱ ngján n'e̱tjáá xinki̱á, a̱t'aha̱ Nti̱a̱ná nibáha̱ ra̱ kju̱a̱tjoo̱ ko̱ ngayjee̱ xi tjíhi̱n kju̱a̱tjo, kui xi kitsjáha̱ Nti̱a̱ná nga ntíhi̱ ka̱ma ko̱ kui xi be Nti̱a̱ná.
\v 8 Xi najmi tjíhi̱n kju̱a̱tjo, najmi kje̱e be Nti̱a̱ná, a̱t'aha̱ kju̱a̱tjohó Nti̱a̱ná.
\p 
\v 9 B'i̱ ts'ín tsakúchjiná kju̱a̱tjoho̱ Nti̱a̱ná. Kits'ín nibá Ntí nku tutuhu̱ a̱sunntei̱, tu̱ xi nga̱t'aha̱ Ntíhi̱ sa̱kúhuná nga ku̱i̱ntsu̱ba̱ tík'aán.
\v 10 ¿Mí nihi xi 'mihi̱ kju̱a̱tjoo̱? Najmi tsa ñá xi kin'etjáá Nti̱a̱ná. Kui ní xi kits'íntjoná ko̱ kits'ín nibá Ntíhi̱ tu̱ xi ts'i̱ínndyjat'aha ngatitsunná nk'ie nga kitsjá yjoho̱ xi nkúhu chje̱. Kuihí ni xu'bi̱ xi tsakúchji kju̱a̱tjoo̱.
\p 
\v 11 Jun já nts'ena̱, tsa b'a̱ ts'ín kits'íntjoná Nti̱a̱ná, kui nga ko̱ ta̱ ñá ta̱ tjíhin nga b'i̱ ngján n'e̱tjohoná xinki̱á.
\v 12 Ndaha nku najmi kje̱e be nkú tjín Nti̱a̱ná, tu̱nga tsa b'i̱ ngján n'etjáá xinki̱á, Nti̱a̱ná tíjñajin tehe̱ntená ko̱ kju̱a̱tjoho̱ s'ejña chji kikjin a̱jinná.
\p 
\v 13 Yaá nga tintsu̱ba̱jin tehe̱ntehe̱é Nti̱a̱ná ko̱ nga kui tíjñajin tehe̱ntená, a̱t'aha̱ kitsjáná Espiri̱tu̱hu̱.
\v 14 Ko̱ ji̱n kiya kikjii̱n ko̱ tíbixínyakixi̱ nga Nti̱a̱ Na̱'miu̱ kits'ín nibá Ntíhi̱ tu̱ xi ts'i̱ínk'ankihi xu̱ta̱ xi tjín a̱sunntee̱.
\v 15 Tu̱ yáhá ni xi ts'i̱ínkjáíhi̱n nga Jesu xi Ntíhi̱ Nti̱a̱ná, kui xi tíjñajin tehe̱nte Nti̱a̱ná ko̱ Nti̱a̱ná tíjñajin tehe̱ntehe̱ xu̱ta̱ xu'bo̱.
\p 
\v 16 Mankjinná ko̱ s'ejinná nga tjoho̱ ñá Nti̱a̱ná. Nti̱a̱ná kui xi kju̱a̱tjo, ko̱ xi tíjñajin tehe̱nte kju̱a̱tjoo̱, kui xi tíjñajin tehe̱nte Nti̱a̱ná ko̱ Nti̱a̱ná tíjñajin tehe̱ntehe̱ xu̱ta̱ xu'bo̱.
\v 17 B'a̱ ts'ín s'ejña chji kikjihin kju̱a̱tjoo̱ a̱jinná, tu̱ xi najmi jo jan ka̱mahaná ni̱stjín nk'ie nga ku̱a̱se̱he̱ Nti̱a̱ná mí nihi xi kits'ín nga nkúnkú xu̱ta̱. A̱t'aha̱ xi nkú ts'ín y'ejña Jesucristo̱, b'a̱ ts'ín tintsu̱ba̱á a̱sunntei̱.
\v 18 Má nga tjín kju̱a̱tjo najmi tjín kju̱a̱binkjun. Kju̱a̱tjo xi kui kikjiu̱n, kui xi m'osje kju̱a̱binkjuu̱n, a̱t'aha̱ xi tje̱n kju̱a̱ha̱, kui xi tsankjún. Kui b'a̱ maha, xi tsankjúhun, kui xi najmi kje̱e tíjñajihi̱n kju̱a̱tjo xi kui kikjin.
\p 
\v 19 Ñá tjoná Nti̱a̱ná a̱t'aha̱ Nti̱a̱ná tjun kits'íntjoná.
\v 20 Tsa tjín xi: “Tjona Nti̱a̱ná”, ku̱i̱tsu̱ ko̱ tu̱ sa unkiehé ngá nda̱ nts'e̱, kui xi tíb'ana̱cha̱. A̱t'aha̱ xi najmi tjoho̱ nda̱ nts'e̱ xi tíma tíbase'a, ¿nkú ts'ín ts'i̱íntjoho Nti̱a̱ná nga najmi tíbe?
\v 21 Xi tjoho̱ Nti̱a̱ná tjíhin nga ta̱ ts'i̱íntjo nda̱ nts'e̱. Kuihí kju̱a̱téxuma xu'bi̱ xi kin'ekjái̱ín.
\c 5
\s1 B'i̱ ts'ín tsakúya Jua ni xi ts'ín xi ntíhi̱ Nti̱a̱ná
\p 
\v 1 Ngayjee̱ xi s'ejihi̱n nga Jesu xi kits'ín nibá Nti̱a̱ná, kui xi kitsjáha̱ Nti̱a̱ná nga ntíhi̱ ka̱ma. Ko̱ ngayjee̱ xi tjoho̱ Nti̱a̱ Na̱'miná, kui xi ta̱ tjoho̱ ngayjee̱ xi ntíhi̱ Nti̱a̱ná.
\v 2 Nk'ie nga tjoná Nti̱a̱ná ko̱ tín'etjusaán ni xi y'éjña, ya chji chjiá nga ta̱ tjoná ngayjee̱ xi ntíhi̱ Nti̱a̱ná.
\v 3 Nga n'e̱tjáá Nti̱a̱ná, kui xi tsuhu̱ ra̱ nga n'e̱tjusaán ni xi y'éjña. Ko̱ najmi ch'á xi áí ni xi y'éjña Nti̱a̱ná,
\v 4 a̱t'aha̱ ngayjee̱ xi ja ntíhi̱ Nti̱a̱ná ts'ín ngana̱ha̱ a̱sunntei̱. Ko̱ nga̱t'aha̱ nga s'ejinná Jesucristo̱, b'a̱ ts'ín kin'e ngana̱ha̱ ra̱á a̱sunntee̱.
\v 5 Xi s'ejihi̱n nga Jesu xi Ntíhi̱ Nti̱a̱ná, kui xi ts'ín ngana̱ha̱ a̱sunntee̱.
\s1 B'i̱ ts'ín tsakúya Jua xi nkú ts'ín Nti̱a̱ná y'éjña chji Jesu
\p 
\v 6 Ntánijua ko̱ jní j'ai s'ejña chjihi Jesucristo̱. Najmi tu̱ suba ntánijua, ntánijua ní ko̱ jní. Ko̱ Espiri̱tu̱hu̱ Nti̱a̱ná ta̱ tsuya kui nii̱, a̱t'aha̱ kju̱axi̱ ni xi nchja̱ Espiri̱tu̱.
\v 7 Jan maha xi b'éjña chji yáha Jesucristo̱:
\v 8 Espiri̱tu̱hu̱ Nti̱a̱ná, ntánijuo̱ ko̱ jníu̱. Nkuhú b'a̱ i̱ncha tsu nga joo̱n.
\p 
\v 9 Tsa n'ekjáíhi̱ín én xi nchja̱ xu̱ta̱ nga nchja̱ni̱jmíyaha nku ni, tu̱nga yúhún chjíhi̱ ra̱ én xi nchja̱ Nti̱a̱ná. Á 'yún chjíhi̱ ra̱, a̱t'aha̱ Nti̱a̱ná xi kinchja̱ nga y'éjña chji Ntíhi̱.
\v 10 Xi s'ejihi̱n Ntíhi̱ Nti̱a̱ná, kui xi ani̱ma̱ha̱ tíjñajihi̱n én xi kinchja̱ Nti̱a̱ná nga y'éjña chji Ntíhi̱. Tu̱nga xi najmi s'ejihi̱n Nti̱a̱ná, kui xi tíbe tsank'á, a̱t'aha̱ najmi s'ejihi̱n én xi kinchja̱ Nti̱a̱ná nga y'éjña chji Ntíhi̱.
\p 
\v 11 Nga kitsjáná nga ku̱i̱ntsu̱ba̱ tík'un síaán ko̱ nga Ntíhi̱ sakújinná kju̱a̱tík'un xu'bi̱, kui én xu'bi̱ xi kinchja̱ Nti̱a̱ná.
\v 12 Xi tíjñajihi̱n Ntíhi̱ Nti̱a̱ná, kui xi tíjñaha̱ kju̱a̱tík'uu̱n. Tu̱nga xi najmi tíjñajihi̱n Ntíhi̱ Nti̱a̱ná, kui xi najmi tíjñaha̱ kju̱a̱tík'uu̱n.
\s1 B'i̱ ts'ín kits'ínkje Jua xu̱ju̱i̱n
\p 
\v 13 Kuak'iet'ánu̱u ni xu'bi̱, jun xi s'ejinnu̱u Ntíhi̱ Nti̱a̱ná, tu̱ xi cha̱hanu nga tíjñanu̱u kju̱a̱tík'un xu'bi̱ ko̱ ku̱i̱ntsu̱ba̱ tík'un síún.
\p 
\v 14 Ma'yúnk'aán Nti̱a̱ná, a̱t'aha̱ yaá tsa ku̱i̱nchíhi̱í xi nkú ts'ín mjehe̱ nga ku̱i̱nchíhi̱í, ku̱a̱sínñjuná.
\v 15 Ko̱ xi nkú ts'ín yaá nga Nti̱a̱ná basínñjuhu̱ tu̱ mí nihí ni xi binchihi̱í, b'a̱ ta̱ ts'ín yaá nga ja n'e̱kjáíhi̱ín ni xi kuakinchihi̱í.
\p 
\v 16 Tsa tjín xi tíbe nga ngatitsun títs'ín nda̱ nts'e̱, ko̱ tsa ngatitsun xi títs'ín najmi ngabaya tje̱he̱n ra̱, nk'ie nga ku̱i̱nchja̱ko̱ Nti̱a̱ná kanchja̱ntjai ko̱ Nti̱a̱ná tsjá ngáha̱ ra̱ nda̱ nts'e̱ nga k'úéjña tík'un. Ngatitsun xi najmi tje̱he̱n ra̱ ngabaya tínchjani̱jmíyahana. A̱t'aha̱ tjín ngatitsun xi tje̱he̱n ra̱ ngabaya. Najmi tíbankia nga chu̱bantjo xi ts'i̱ín ngatitsun xu'bo̱.
\v 17 Ngayjee̱ ni xi najmi nda xi ts'ín xu̱ta̱, kui xi ngatitsun, tu̱nga tjíhín ngatitsun xi najmi tje̱he̱n ra̱ ngabaya.
\p 
\v 18 Yaá nga xi kitsjáha̱ Nti̱a̱ná nga ka̱ma ntíhi̱ najmi nkaha̱ nga ts'ín ngatitsun, a̱t'aha̱ Ntíhi̱ Nti̱a̱ná kuhu̱n xu̱ta̱ xu'bo̱ ko̱ najmi ts'ínko̱ho̱ nda̱nindoo̱.
\v 19 Ko̱ yaá nga Nti̱a̱ná ts'e̱ná ko̱ nga nda̱nindoo̱ batéxumaha̱ ngayjee̱ a̱sunntee̱.
\v 20 Ko̱ ta̱ yaá nga j'ai Ntíhi̱ Nti̱a̱ná ko̱ kitsjáná kju̱a̱nkjintak'un tu̱ xi cha̱haná Nti̱a̱ xi nku tutuu̱. Tintsu̱ba̱jihi̱ín xi nku tutuu̱, kui xi Jesucristo̱ Ntíhi̱ Nti̱a̱ná. Kuihí xi Nti̱a̱ xi nku tutuu̱ ko̱ kui xi tsjáha̱ nga k'úéntu tík'un sín xu̱ta̱.
\p 
\v 21 Jun ntína̱, ti̱yú t'axíhu̱un nti̱a̱ xi xu̱ta̱ ts'ínnda.
