\id HAB
\h حَابَاقُّوقْ
\toc1 حَابَاقُّوقْ
\toc2 حَابَاقُّوقْ
\toc3 حَاب.
\mt1 حَابَاقُّوقْ
\c 1
\s1 أَشثْشِي ن حَابَاقُّوقْ
\m 
\v 1 ڒْحُوكْمْ إِسَّاڭّْوَاذنْ نِّي إِژْرَا ؤُنَابِي حَابَاقُّوقْ.
\b
\m 
\v 2 ”\add أَ\add* سِيذِي، أَڒْ مڒْمِي إِ غَا قِّيمغْ تّْڒَاغِيغْ
\m ؤُ شكْ وَارْ ذ أَيِي ثتّسْڒِيذْ،
\m أَڒْ مڒْمِي إِ غَا قِّيمغْ تّْڒَاغِيغْ ’لْعُونْفْ!‘،
\m ؤُ شكْ وَارْ ذ أَيِي ثسّنْجَامذْ!
\m 
\v 3 مَايمِّي ذ أَيِي ثسّشْنذْ ڒْمُوعْصِييّثْ،
\m ؤُ ثتّْغِيمِيذْ ثْخزَّارذْ غَارْ ڒغْبنْ؟
\m مَاغَارْ أَردّدْجْ ذ لْعُونْفْ
\m أَقَا أَثنْ أَرنْذَاذْ إِنُو،
\m ؤُ إِمْسَارْ ؤُمْشُوبّشْ، إِكَّارْ-د ؤُرُودّزْ.
\m 
\v 4 خْ ؤُيَا ثذْوڒْ شَّارِيعَا بْڒَا جّهْذْ،
\m ؤُ وَارْ د-إِتّفّغْعمَّارْصْ ڒْحقّْ،
\m مَاغَارْ أَعفَّانْ إِتّنّضْ إِ ؤُمْسڭّذْ.
\m خْ ؤُيَا إِ د-إِتّفّغْ ڒْحقّْ إِفَارْغْ.
\b
\s1 ثَامْوَارِّيثْ ن سِيذِي خْ ثْژَادْجِيثْ
\m 
\v 5 خْزَارمْ جَارْ ڒڭْنُوسْ، خْزَارمْ،
\m إِنُّورْزمْ ؤُقمُّومْ س ؤُثبْهثْ،
\m مَاغَارْ نشّْ أَذْ ڭّغْ
\m إِشْثْ ن ڒْخذْمثْ ذڭْ وُوسَّانْ نْومْ
\m إِ وَارْ ثتِّيمْنمْ مَاڒَا ت حَاجَانْ. \x ◘ \xo 1:‏5 \xt ڒخ. 13‏:‏41\x*
\m 
\v 6 مَاغَارْ خْزَارمْ،
\m نشّْ سّكَّارغْ إِكَالْذَانِييّنْ،
\m ڒْْڭنْسْ إِقسْحنْ ؤُ إِمْقدْجْقنْ،
\m ونِّي إِڭُّورنْ ذِي ڒوْسعْ ن ثمُّورْثْ،
\m حِيمَا أَذْ إِطّفْ ثِيزذِّيغِينْ
\m نِّي وَارْ إِدْجِينْ نّسْ.
\m 
\v 7 إِسَّاڭّْوَاذنْ ؤُ إِسّْنخْڒَاعنْ إِدْجَانْ!
\m ڒْْحقّْ نّسْ ذ ؤُعُودْجِي نّسْ
\m تّفّْغنْ-د زَّايسْ.
\m 
\v 8 إِيْسَانْ نّسْ فْسُوسنْ خْ ؤُغِيڒَاسْ،
\m نِيثْنِي مُّوزَّارنْ
\m مَاهُو ؤُشَّاننْ ن دْجِيڒثْ،
\m إِمْنَاينْ نّسْ تّْرَابَاعنْ.
\m إِمْنَاينْ نّسْ تَّاسنْ-د زِي ڒَاڭّْوَاجْ،
\m نِيثْنِي طَّاونْ أَمْ ؤُڭِيذرْ
\m نِّي إِتّْقدْجْقنْ مَاحنْذْ أَذْ يشّْ.
\m 
\v 9 أَقَا نتَّا إِتَّاسْ-د، أَمنْ إِكْمڒْ، إِ لْعُونْفْ،
\m إِغمْبَابْ نْسنْ \add خزَّارنْ\add* غَارْ زَّاثْ،
\m ؤُ نتَّا إِسّْمُونَا إِمحْبَاسْ أَمْ يجْذِي.
\m 
\v 10 نتَّا إِتّْقصَّارْ خْ إِجدْجِيذنْ
\m ؤُ إِنِّي إِ غَارْ ثدْجَا صُّولْطَا
\m إِتّڭّْ إِ-ثنْ ذ ثَاضحَّاشْثْ.
\m \add وَاهْ،\add* نتَّا إِضحّشْ خْ كُوڒْ لْقلْعَا،
\m مِينْزِي نتَّا إِتّْعُورّشْ ؤُشَاڒْ
\m ؤُشَا أَذْ ثنْثْ إِطّفْ.
\m 
\v 11 خنِّي أَذْ إِنّعْثَارْ \add أَمْ\add* ؤُسمِّيضْ،
\m أَذْ إِعْذُو، أَذْ إِذْوڒْ ذ أَمذْنُوبْ،
\m \add مَاغَارْ\add* جّهْذْ نّسْ وَانِيثَا ذ أَربِّي نّسْ.
\b
\s1 أَشثْشِي وِيسّْ ثْنَاينْ ن حَابَاقُّوقْ
\m 
\v 12 زِي مشْحَاڒْ ؤُيَا
\m مَا شكْ وَارْ ثدْجِيذْ ذ سِيذِي،
\m أَربِّي إِنُو، أَمْقدَّاسْ إِنُو؟
\m نشِّينْ وَارْ نتّْمتِّي شَا!
\m \add أَ\add* سِيذِي، شكْ ثَارِّيذْ إِ-ث إِ ڒْحُوكْمْ،
\m \add أَ\add* ثَاصْضَارْثْ، شكْ ثْفَارْزذْ ث
\m مَاحنْذْ أَذْ يِيڒِي إِ لْعِيقَابْ.
\m 
\v 13 شكْ ذ أَمزْذَاڭْ أَطَّاسْ ن ثِيطَّاوِينْ
\m حِيمَا أَذْ ثْوَاڒَانْثْ ڒْغَارْ.
\m شكْ وَارْ ثْزمَّارذْ
\m أَذْ ثْصوْضذْ ذِي ڒْمُوعْصِييّثْ.
\m مَايمِّي ثْصوْضذْ \add وَاهَا\add*
\m ذڭْ يِينِّي إِتّڭّنْ س ڒغْذَارثْ؟
\m \add مَايمِّي\add* إِ ثسّغْضذْ
\m خْمِي إِصَارّضْ ؤُعفَّانْ
\m إِ ونِّي إِ خَاسْ إِسڭّْذنْ؟
\m 
\v 14 شكْ ثڭِّيذْ إِوْذَانْ
\m أَمْ يِيسڒْمَانْ ن ڒبْحَارْ،
\m أَمْ \add إِمُّوذَارْ\add* نِّي إِتّْبُوعنْ
\m \add خْ ثمُّورْثْ\add* إِ وَارْ غَارْ إِدْجِي ڒْحَاكمْ!
\b
\m 
\v 15 س ثْسنَّارْثْ إِسّْڭعَّاذْ إِ-ثنْ-د مَارَّا،
\m إِيَارُّو إِ-ثنْ س ثْرَاشَّا نّسْ،
\m ؤُشَا إِسّْمُونْ إِ-ثنْ ذِي ثْرَاشَّا نّسْ ن ؤُذلَّاعْ.
\m خْ ؤُيَا إِفَارّحْ ؤُ إِتّْفَاجَا.
\m 
\v 16 خْ ؤُيَا إِوهّبْ ثِيغَارْصَا إِ ثْرَاشَّا نّسْ،
\m ؤُشَا إِبخَّارْ ثِيوْهِيبِينْ ن ڒبْخُورْ
\m إِ ثْرَاشَّا ن ؤُذلَّاعْ نّسْ.
\m مِينْزِي زَّايْسنْثْ إِ ثذْوڒْ
\m ثسْغَارْثْ نّسْ ثمْغَارْ،
\m ؤُڒَا ذ مَاشَّا نّسْ أَقَا ثْڒدّْ.
\m 
\v 17 مَا إِعدّڒْ أَذْ إِقِّيمْ إِسّخْوَا
\m ثْرَاشَّا نّسْ خْ مَانْ أَيَا،
\m ؤُشَا أَذْ إِقِّيمْ ڒبْذَا إِنقّْ ڒڭْنُوسْ
\m بْڒَا مَا أَذْ يجّْ \add حذْ\add*؟
\b
\b
\c 2
\s1 سِيذِي أَذْ د-يَارّْ خْ حَابَاقُّوقْ إِ ثْوَاڒَا وِيسّْ ثْنَاينْ
\m 
\v 1 نشّْ أَذْ بدّغْ
\m ذڭْ ومْشَانْ ن ثْعسَّاسْثْ إِنُو
\m ؤُ أَذْ سّْبدّغْ إِخفْ إِنُو
\m خْ صُّومْعثْ ن ثْعسَّاسْثْ،
\m أَذْ صوْضغْ مَاحنْذْ أَذْ ژَترغْ
\m مِينْ إِ ذ أَيِي غَا يِينِي نتَّا،
\m ؤُ مِينْ إِ د غَا يَارّغْ خْ ؤُشثْشِي إِنُو. \x ◘ \xo 2:‏1 \xt إِشا. 21‏:‏8\x*
\b
\m 
\v 2 يَارَّا-د خَافِي سِيذِي، إِنَّا:
\m أَرِي ڒوْحِييْ
\m أَرِي ث إِفَارْزْ خْ ثڒْوِيحِينْ،
\m مَاحنْذْ ونِّي إِعدُّونْ
\m أَمْ د-إِتَّازّڒْ، إِزمَّارْ أَذْ ث إِغَارْ. \x ◘ \xo 2:‏2 \xt إِشا. 30‏:‏8\x*
\m 
\v 3 مَاغَارْ ڒوْحِييْ \add إِتّْرَاجَا\add* عَاذْ
\m أَڒْ ڒْوقْثْ نِّي يُورَانْ.
\m إِتّمْحِيزْوَارْ غَارْ ؤُقطُّو
\m ؤُ وَارْ إِسّْخَارِّيقْ شَا.
\m مَاڒَا إِقِّيمْ وَارْ د-إِتِّيسْ، قِّيمْ رَاجَا ث،
\m مَاغَارْ أَذْ د-يَاسْ س ثِيذتّْ،
\m وَارْ إِعطَّاڒْ.
\b
\m 
\v 4 خْزَارْ، أَقَا إِتُّوفّْ، \add وَاهْ،\add*
\m ڒعْمَارْ نّسْ وَارْ إِسڭّمْ ذَايسْ،
\m مَاشَا أَمْسڭّذْ س لْ-إِيمَانْ نّسْ أَذْ إِدَّارْ. \f ◼ \fr 2:‏4 \ft \bd ’س ڒْمَانثْ نّسْ‘\bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي ’س ڒْمَانثْ ن سِيذِي أَربِّي (رُوم. 1‏:17)\f*
\b
\m 
\v 5 س ثِيذتّْ، بِينُو أَقَا إِشمّثْ!
\m \add بِينُو أَقَا-ث أَمْ\add* يِيجّْ ن بُو-نّْفَاخثْ
\m ونِّي وَارْ إِتَّاريّْحنْ،
\m ونِّي إِسّمْغَارَانْ ڒعْمَارْ نّسْ
\m \add أَمڒْهَافْ\add* أَمْ ڒَاخَارْثْ.
\m نتَّا وَارْ إِتّْجِّيوِينْ أَمْ ڒْموْثْ
\m ؤُ إِيْرُو غَارسْ مَارَّا ڒڭْنُوسْ
\m ؤُ إِسّْمُونْ غَارسْ مَارَّا إِيْذُوذنْ. \f ◼ \fr 2:‏5 \ft \bd أَفسَّارْ\bd* - نسّنْ أَقَا إِكَالْذَانِييّنْ ذ ڒْحُوكَّامْ ن بَابِيلْ سْوِينْ أَطَّاسْ ن بِينُو (خْزَارْ ذَانِييَالْ 5). س ؤُينِّي يَارْوسنْ نِيثْنِي س يِيخفْ نْسنْ ذِي بِينُو، مِينْزِي أَمْ مَامّشْ أَرْزْمنْ نِيثْنِي أَقمُّومْ نْسنْ حِيمَا أَذْ سْونْ بِينُو، أَمُّو إِ يَارْزْمنْ نِيثْنِي أَقمُّومْ نْسنْ أَمْ إِجّْ ن بُو-نّْفَاخثْ ونِّي وَارْ إِتَّاريِّيحنْ ...‘\f*
\m 
\v 6 مَا وَارْ د خَاسْ تِّيوْينْ
\m إِجّْ ن وَاوَاڒْ إِوزْننْ
\m ؤُڒَا ذ إِجّْ ن يژْرِي
\m إِشُّورْ س ڒمْعَانِي إِنُّوفَارنْ، أَذْ إِنِينْ:
\m \bdit ؤُشْثْ\bdit* خْ ونِّي إِجَارّْونْ
\m مِينْ وَارْ إِدْجِينْ نّسْ!
\m أَڒْ مڒْمِي \add عَاذْ\add*؟
\m \bdit ؤُشْثْ\bdit* خْ ونِّي إِسّْذقَّاڒنْ
\m إِخفْ نّسْ س ورْهَانْ!
\m 
\v 7 مَا وَارْ د-تّكَّارنْ س ڒْغفْڒثْ
\m إِنِّي إِ شكْ غَا إِزعْفنْ،
\m ؤُ مَا وَارْ د-تّْفَاقَانْ شَا
\m إِنِّي شكْ غَا يَارّنْ ثتَّارْجِيجذْ،
\m ؤُ مَا وَارْ ذ أَسنْ ثتِّيڒِيذْ
\m ذ ثَاكشَّاضْثْ نْسنْ؟
\m 
\v 8 مَاغَارْ شكْ ثْكشّْضذْ أَطَّاسْ ن ڒڭْنُوسْ،
\m أَذْ شكْ كشّْضنْ مَارَّا ڒڭْنُوسْ إِقِّيمنْ
\m ذِي سِّيبّثْ ن إِذَامّنْ ن إِوْذَانْ
\m ذ لْعُونْفْ \add خْ\add* ثمُّورْثْ،
\m ؤُ \add خْ\add* ثنْذِينْثْ ؤُ \add خْ\add* مَارَّا
\m إِنِّي ذَايسْ إِزدّْغنْ.
\b
\m 
\v 9 \bdit ؤُشْثْ\bdit* خْ ونِّي إِكسّْبنْ س ڒْغشّْ
\m ثَاكشَّاضْثْ إِ ثَادَّارْثْ نّسْ،
\m مَاحنْذْ أَذْ إِبْنَا ڒْعُوشّْ نّسْ ذِي ڒُوعْڒَا،
\m حِيمَا أَذْ إِنْجمْ \add أَمُّو\add* زڭْ ؤُفُوسْ ن ڒْغَارْ.
\m 
\v 10 شكْ ثْشَاوَارذْ ڒفْضِيحثْ إِ ثَادَّارْثْ نّشْ،
\m حِيمَا أَذْ ثقْضِيذْ خْ ڒڭْنُوسْ،
\m ؤُشَا \add أَمُّو\add* إِ ثڭِّيذْ دّنْبْ
\m ذِي ڒعْمَارْ نّشْ.
\m 
\v 11 مِينْزِي أَژْرُو إِسْغُويُّو-د زِي ڒْحِيضْ،
\m ؤُ ثَاحْنَاشْثْ ثتَّارَّا-د \add خَاسْ\add*
\m زِي جَارْ ثفْڒَاوْثْ.
\b
\m 
\v 12 \bdit ؤُشْثْ\bdit* خْ ونِّي إِبنَّانْ
\m \add إِشْثْ ن\add* ثنْذِينْثْ س إِذَامّنْ
\m ؤُڒَا خْ ونِّي إِسّْرُوسَانْ ذْسَاسْ
\m \add ن يِيشْثْ ن\add* ثنْذِينْثْ س ڒْغشّْ!
\m 
\v 13 خْزَارْ، مَا وَارْ إِدْجِي زِي سِيذِي ن ڒْعسْكَارَاثْ،
\m أَقَا ڒڭْنُوسْ أَربّْرنْ إِخفْ نْسنْ إِ ثْمسِّي،
\m ؤُ شُّوعُوبْ تَّاحْڒنْ إِ وَالُو؟
\m 
\v 14 مَاغَارْ ثَامُّورْثْ أَذْ ثتّْوَاشُّورْ
\m س ثُوسّْنَا ن ؤُعُودْجِي ن سِيذِي،
\m أَمْ مَامّشْ تّْذَاڒنْ وَامَانْ ڒبْحَارْ.
\b
\m 
\v 15 \bdit ؤُشْثْ\bdit* خْ ونِّي إِ غَا إِسّسْونْ جَّارْ نّسْ،
\m ونِّي إِخدْجْضنْ \add بِينُو\add* س سّمْ نّشْ
\m ؤُ \add خنِّي\add* إِسّسْشَارْ إِ-ث،
\m مَاحنْذْ أَذْ إِژَارْ ثُوعَّارْيَانْثْ نْسنْ.
\m 
\v 16 أَذْ ثسّجِّوْنذْ إِخفْ نّشْ س ڒفْضِيحثْ
\m ذڭْ ومْشَانْ ن شَّانْ.
\m سُو شكْ \add ڒخُّو\add* عَاوذْ،
\m ؤُشَا أجّْ أَخْثَانْ نّشْ وَارْ إِدْجِينْ إِتّْبَانْ.
\m ڒْْكَاسْ زڭْ ؤُفُوسْ أَفُوسِي ن سِيذِي
\m أَذْ غَاركْ د-يَاسْ،
\m ؤُڒَا ذ ڒفْذِيحثْ خْ ؤُعُودْجِي نّشْ.
\m 
\v 17 مَاغَارْ ڒْعُونْفْ إِ ثڭِّيذْ ضِيدّْ إِ لُوبْنَانْ
\m أَذْ شكْ إِذڒْ
\m ؤُڒَا ذ أَردّدْجْ ن ڒْمَاڒْ إِ زِي \add ثنْ\add* ثسِّيڭّْوْذذْ،
\m ذِي سِّيبّثْ ن إِذَامّنْ ن إِوْذَانْ
\m ذ لْعُونْفْ \add خْ\add* ثمُّورْثْ،
\m ؤُ \add خْ\add* ثنْذِينْثْ ؤُ \add خْ\add* مَارَّا إِنِّي ذَايسْ إِزدّْغنْ.
\b
\m 
\v 18 مَا ثِيزِي ن إِجّْ ن ڒخْيَاڒْ إِنقْشنْ،
\m ؤُمِي ث إِنْقشْ ؤُنقَّاشْ \add س يِيخفْ نّسْ\add*،
\m \add مَانْ ثِيزِي ن\add* يِيجّْ ن ڒخْيَاڒْ إِفسْينْ
\m \add ؤُمِي أَنقَّاشْ نّسْ\add*
\m ذ إِجّْ ن ؤُمْسڒْمذْ ن إِخَارِّيقنْ،
\m ڒَْامِي ونِّي ث إِڭِّينْ إِتّْشڒْ خْ مِينْ إِڭَّا،
\m ؤُمِي إِتّڭّْ لْ-أَصْنَامْ إِڭْنَاونْ؟
\m 
\v 19 \bdit ؤُشْثْ\bdit* خْ ونِّي إِقَّارنْ إِ ؤُكشُّوضْ ’فَاقْ!‘
\m ؤُ إِ وژْرُو إِڭْنَاونْ: ’كَّارْ!‘.
\m مَا \add إِزمَّارْ\add* أَذْ إِسّڒْمذْ؟
\m خْزَارْ، أَقَا ڒحّْفنْ ث س وُورغْ ذ نُّوقَارْثْ
\m ؤُ وَارْ ذَايسْ قَاعْ بُوحْبڒْ.
\m 
\v 20 سِيذِي أَقَا-ث ذِي زَّاوشْثْ نّسْ إِقدّْسنْ.
\m سُوسمْ زَّاثْ إِ وُوذمْ نّسْ،
\m مَارَّا ثَامُّورْثْ!
\b
\b
\c 3
\s1 ثَاژَادْجِيثْ ن حَابَاقُّوقْ
\m 
\v 1 ثَاژَادْجِيثْ ن حَابَاقُّوقْ، أَنَابِي، ذڭْ وَاطَّاسْ ن ثْمِيجِّيوِينْ.
\b
\m 
\v 2 \add أَ\add* سِيذِي، \add ؤُمِي\add* سْڒِيغْ ڒخْبَارْ نّشْ،
\m ثُوغَا تّڭّْوذغْ.
\m \add أَ\add* سِيذِي، سْندَّارْ ڒْخذْمثْ نّشْ عَاوذْ
\m ذِي ڒْوسْطْ ن إِسڭّْوُوسَا،
\m سشّنْ إِ-ت ذِي ڒْوسْطْ ن إِسڭّْوُوسَا،
\m ذڭْ وغْضَابْ عْقڒْ خْ ڒحْنُونشْثْ نّشْ.
\m 
\v 3 أَربِّي يُوسَا-د زِي ثَايْمَانْ ؤُ أَمْقدَّاسْ
\m زڭْ وذْرَارْ ن فَارَانْ. سِيلَاهْ.
\m لْعَاضَامَا نّسْ ثذْڒَا إِجنْوَانْ
\m ؤُ أَصبّحْ نّسْ إِشُّورْ ثَامُّورْثْ.
\m 
\v 4 ثُوغَا ذِينْ إِشْثْ ن ثسِّيقْثْ أَمْ ثْفَاوْثْ،
\m \add فّْغنْثْ-إِ-د\add* فْڒِيثْشَاثْ ن وَاسَّامْ
\m زڭْ ؤُفُوسْ نّسْ،
\m أَقَا-ثنْثْ غَارسْ،
\m ؤُ ذَايْسنْثْ ثْنُوفَّارْ ثْزمَّارْ نّسْ.
\m 
\v 5 طَّاعُونْ إِتِّيزْوَارْ إِ وُوذمْ نّسْ،
\m ڒْْحَاذُوقْ ن ثْمسِّي إِفّغْ-د
\m زڭْ إِضَارنْ نّسْ.
\m 
\v 6 نتَّا إِكَّارْ ؤُشَا يَارَّا ثَامُّورْثْ ثتّنْهزَّا،
\m نتَّا إِژْرَا ؤُ إِڭَّا أَذْ أَرْجِيجنْ ڒڭْنُوسْ!
\m إِذُورَارْ ن زِيشْ تّْوَاڒبْزنْ
\m أَڒَامِي ذوْڒنْ ذ ثَاعجَّاجْثْ،
\m ثِيوْرِيرِينْ زِي مشْحَاڒْ ؤُيَاغنْسنْثْ!
\m إِبْرِيذنْ إِتّْذُومَانْ إِ ڒبْذَا أَقَا أَثنْ نّسْ.
\m 
\v 7 نشّْ ژْرِيغْ إِقِيضَانْ ن كُوشَانْ تّْوَاحْصَارنْ،
\m ثِيجَارْثِيڒِينْ ن إِقِيضَانْ ن ثمُّورْثْ ن مِيذْيَانْ
\m إِتَّاوِي ثنْثْ ؤُسمِّيضْ س جّهْذْ.
\m 
\v 8 مَا يَارْغَا \add وغْضَابْ\add* ن سِيذِي خْ إِغزْرَانْ؟
\m مَا ثُوغَا أَغْضَابْ نّشْ ضِيدّْ إِ إِغزْرَانْ؟
\m مَا ثُوغَا أَذُوقّزْ نّشْ \add ن ؤُفُوڭمْ\add*
\m ضِيدّْ إِ ڒبْحَارْ،
\m ڒَْامِي ثْنذْهذْ خْ ييْسَانْ نّشْ،
\m خْ إِكَارُّوثنْ نّشْ ن ؤُسنْجمْ؟
\m 
\v 9 ڒْقوْسْ نّشْ إِتّْوَاعَارَّا مَارَّا،
\m ثِيجَادْجِيثِينْ إِ ثسِّيوْڒذْ \add ثُوغَا أَثنْثْ\add*
\m ذ إِعُومَاذْ نشّْ \add إِ ؤُسقْسَاحْ\add*. سِيلَاهْ.
\m ثْفدْجْقذْ ثَامُّورْثْ س إِغزْرَانْ.
\m 
\v 10 ڒَامِي شكْ ژْرِينْ إِذُورَارْ، إِڒْقفْ إِ-ثنْ ڒوْجعْ،
\m ڒْْحمْڒثْ ن وَامَانْ ثُوغَا ثْعدُّو،
\m \add أَمَانْ\add* إِهوْڒنْ أَرِّينْ
\m ثْمِيجَّا نْسنْ ثتّْوَاسڒْ،
\m ڭعّْذنْ إِفَاسّنْ نْسنْ \add غَارْ ؤُجنَّا\add*.
\m 
\v 11 ثَافُوشْثْ، \add ؤُڒَا\add* ذ ؤُيُورْ،
\m قِّيمنْ بدّنْ ذِي ثْزذِّيغْثْ نْسنْ.
\m أَقَا رُوحنْ زِي سِّيبّثْ ن ثْفَاوْثْ
\m ن فْڒِيثْشَاثْ ن ڒْقوْسْ نّشْ،
\m زِي سِّيبّثْ ن ثِيسِّيقْثْ
\m ن لَانْسَا نّشْ إِتّحْذُوذُوقنْ.
\m 
\v 12 س وسْخضْ ثصُّورُوفذْ ثِيوَا إِ ثمُّورْثْ،
\m س وغْضَابْ نّشْ ثْعفْسذْ خْ ڒڭْنُوسْ.
\m 
\v 13 شكْ ثفّْغذْ إِ ؤُسنْجمْ ن ڒْڭنْسْ نّشْ،
\m إِ ؤُسنْجمْ ن ؤُمذْهُونْ نّشْ.
\m أَقَا شكْ ثْقدْجْعذْ
\m ثَازقَّا ن ثَادَّارْثْ ن ؤُعفَّانْ،
\m ثْعَارِّيذْ ذْسَاسْ أَڒْ إِرِي. سِيلَاهْ.
\b
\m 
\v 14 أَزدْجِيفْ ن إِعسْكَارِييّنْ نّسْ إِمزْوُورَا،
\m أَقَا ثسّْنُوقّْبذْ إِ-ث س لَانْسَاثْ نْسنْ.
\m نِيثْنِي ؤُسِينْ-دعڒْفنْ-د
\m مَاحنْذْ أَذْ أَيِي زدْجْعنْ.
\m أَقَا ذ مژْرِي نْسنْ
\m مَاڒَا \add زمَّارنْ\add*
\m أَذْ شّنْ ڒْمسْكِينْ س ثْنُوفّْرَا.
\m 
\v 15 أَكْ-ذ إِيْسَانْ نّشْ ثطّْفذْ أَبْرِيذْ ذِي ڒبْحَارْ،
\m أَكُوفُّو ن وَامَانْ إِمقّْرَاننْ.
\m 
\v 16 \add ڒَْامِي\add* سْڒِيغْ، يَارْجِيجْ ؤُعذِّيسْ إِنُو.
\m ؤُمِي \add سْڒِيغْ\add* ڒْحسّْ \add نِّي\add*، أَرْجِيجنْ إِينْشِيشنْ إِنُو،
\m أَخسَّارْ يُوذفْ غَارْ إِغْسَانْ إِنُو،
\m ؤُ نشّْ أَرْجِيجغْ ذڭْ ومْشَانْ إِنُو.
\m \add وَاخَّا أَمنِّي\add* أَذْ رَاجِيغْ ذِي ڒْخَاضَارْ
\m خْ وَاسّْ ن ڒحْصَارثْ،
\m خْمِي غَا إِسّْڭعّذْ خْ ڒْڭنْسْ،
\m \add ؤُ\add* أَذْ أَنغْ إِحْصَارْ أَكْ-ذ بَانْذِييَّاثْ \add نّسْ\add*.
\b
\s1 ڒفْرَاحثْ ن حَابَاقُّوقْ
\m 
\v 17 وَاخَّا وَارْ إِتّْنُووَّارْ وَارْثُو،
\m ؤُ وَارْ ذِينْ ثتِّيڒِي \add عَاذْ\add* ڒْغِيدْجثْ غَارْ ثْزَايَارْثْ،
\m \add وَاخَّا\add* ڒْغِيدْجثْ ن زِّيثُونْ أَذْ ثفْشڒْ
\m ؤُڒَا ذ إِيَّارنْ وَارْ تّْغِيمِينْ تِّيشنْ ڒْمَاشُوڒْ،
\m ؤُ أَذْ تّْوَاقضْعنْ وُودْجِي زِي ڒْكُوڒِي
\m ؤُ وَارْ تِّيڒِينْ \add عَاذْ\add* إِفُونَاسنْ
\m ذ ثْفُونَاسِينْ ذِي ڒْكُورِيثْ،
\m 
\v 18 \add عَاذْ أَمنِّي\add* نشّْ أَذْ سْڒِيوڒْوغْ إِ سِيذِي،
\m أَذْ فَارْحغْ زِي أَربِّي ن ؤُسنْجمْ إِنُو.
\m 
\v 19 سِيذِي، سِيذِي إِنُو، \add نتَّا\add* ذ جّْهذْ إِنُو.
\m نتَّا إِتّڭّْ إِضَارنْ إِنُو \add فْسُوسنْ\add*
\m أَمْ يِيضَارنْ ن ثُوذَاذِينْ،
\m نتَّا إِتّجَّا أَيِي صُّورُوفغْ خْ ڒڭْعُوذِي.
\b
\m إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ.
\m أَكْ-ذ ؤُزنْزُونْ إِنُو خْ إِفِيڒَانْ. \x ◘ \xo 3:‏19 \xt إِزهد. 18‏:‏34\x* 
