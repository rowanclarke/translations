\id PSA - Biblica® Open Kiyombe Contemporary New Testament and Psalms 2002
\h MINKUNGA
\toc1 Minkunga
\toc2 Minkunga
\toc3 Minkunga
\mt1 Minkunga
\c 1
\ms1 BUKU YI THETI
\cl Minkunga 1
\s1 Mina mi Yave midi tho yi mamboti
\q1 
\v 1 Lusakumunu kuidi mutu wowo wunkambu landakananga
\q1 zindongi zi batu bambimbi,
\q1 wunkambu telamanga mu nzila yi minsumuki,
\q1 ayi wunkambu vuandanga va kimosi ayi mimvuezi.
\q1 
\v 2 Vayi wummonanga khini mu mina mi Yave
\q1 ayi wunyindulanga miawu muini ayi builu.
\q1 
\v 3 Mutu beni widi banga nti wukunu va muenda nlangu ;
\q1 wowo wumbutanga makundi mu tsungi andi
\q1 ayi meza mandi mayumanga ko ;
\q1 weti mona mamboti mu mamo keti vanganga.
\q1 
\v 4 Vayi buawu ko buididi kuidi batu bambimbi,
\q1 badi banga biti bivevumunu kuidi phemo.
\q1 
\v 5 Diawu, batu bambimbi balendi telama ko mu lumbu ki tsambusu,
\q1 voti bankua masumu mu lukutukunu lu batu basonga.
\q1 
\v 6 Bila Yave zebi nzila yi batu basonga,
\q1 vayi nzila yi batu bambimbi yela biva.
\c 2
\cl Minkunga 2
\s1 Mbiekolo ntinu
\q1 
\v 1 Bila mbi makanda mafuemini e ?
\q1 Bila mbi batu balembo yindudila
\q1 mambu makambulu fuana e ?
\q1 
\v 2 Bila mbi mintinu mi ntoto mitelimini e ?
\q1 Bila mbi minyadi mikutikinini va kimosi mu nuanisa Yave
\q1 ayi mutu andi kavinda mafuta e ?
\q1 
\v 3 Balembo tubi : “tuzenganu minsinga miawu ;
\q1 tulozanu thama zisieni ziawu.”
\q1 
\v 4 Mutu wowo wunkalanga ku Diyilu wulembo sevi.
\q1 Pfumu wulembo basekinina.
\q1 
\v 5 Bosi wulembo bayolukila mu nganzi andi,
\q1 ayi wulembo kuba monisa tsisi mu miangu miandi mi ngolo.
\q1 
\v 6 Ayi wutuba : “Minu ndibieka ntinu ama ku Sioni,
\q1 mongo ama wunlongo.”
\q1 
\v 7 Ndiela yamikisa lukanu lu Pfumu :
\q1 Yave wukhamba : “Ngeyo widi muanꞌama.
\q1 Minu ndibutidi mu lumbu kiaki.”
\q1 
\v 8 Wundombi ayi mandivana makanda ;
\q1 ma maba kiuka kiaku
\q1 ayi mawu vua ntoto wumvimba nate mu sukisina ntoto beni.
\q1 
\v 9 Wela kuba yadilanga mu nkawa wu sengo ;
\q1 wela kuba bula banga bu mbudikilanga nzungu yi tuma.
\q1 
\v 10 Diawu, beno mintinu, bika luba nduenga.
\q1 Bosi beno mazuzi ma ntoto, bika lutambula ndongokolo ;
\q1 
\v 11 lusadila Yave mu lukinzu
\q1 ayi lumona khini mu lukhuku.
\q1 
\v 12 Lubumbakana muana mu diambu di kedi fuema ;
\q1 ayi luedi bungana mu nzilꞌeno.
\q1 Bila mu mbuetolo yi meso nganzi andi yilenda vika wulama.
\q1 Lusakumunu kuidi batu boso bobo bantombanga suamunu mu niandi.
\c 3
\cl Minkunga 3
\s1 Kuidi Yave kumbanga phulusu
\d Nkunga Davidi mu thangu katina muanꞌandi Abisaloni.
\q1 
\v 1 A Yave, tala buevi badidi woka bobo bandendidi ;
\q1 batu bawombo balembo ndiendila manenga.
\q1 
\v 2 Bawombo balembo tubi mu diambu diama :
\q1 “Nzambi kalendi kunkula ko.”
\q1 
\v 3 Vayi ngeyo, widi nkaku ama, a Yave.
\q1 Ngeyo nkemboꞌama, ngeyo wumvumbulanga ntu ama.
\q1 
\v 4 Ndinyamikinanga kuidi Yave.
\q1 Niandi wukuphutudilanga mvutu tona ku mongo andi wunlongo.
\q1 
\v 5 Ndinlambadala, ndinleka tulu ayi ndinkotukanga ;
\q1 bila Yave niandi wukukhebanga.
\q1 
\v 6 Nditinanga ko tsisi yi makabu mawombo-wombo
\q1 ma batu bobo banzungididi ndambu ayi ndambu.
\q1 
\v 7 Yave telama ; ngeyo Nzambi ama, wukhudi.
\q1 Bila ngeyo wubetidi bambeni baama baoso mu matama.
\q1 Wukoludi meno ma batu bambimbi.
\q1 
\v 8 Kuidi Yave kumbanga phulusu.
\q1 Bika lusakumunu luaku luba kuidi batu baku !
\c 4
\cl Minkunga 4
\s1 Yave wumvananga ndembama
\d Nkunga Davidi, kayimbidila mu bisiku bi zitsinga mu diambu di pfumu minyimbidi.
\q1 
\v 1 Wuphutudila mvutu bu ndilembo kutedi, a Nzambi ama yisonga
\q1 ayi wutsadisa bu ndidi mu phasi ;
\q1 wumboni kiadi, wa lusambulu luama.
\q1 
\v 2 Nate thangu mbi luela,
\q1 tatamana fuisa nkembo ama tsoni e ?
\q1 Nate thangu mbi luela tatamana zodilanga vanga mambu ma phamba
\q1 ayi tombanga zinzambi zi luvunu e ?
\q1 
\v 3 Luzaba mboti ti Yave wukisobudidi mutu wumosi
\q1 wunkinzikanga mambu mandi.
\q1 Yave wela wa mu thangu ndiela kuntela.
\q1 
\v 4 Ku tsi nganzi eno, kadi vola masumu.
\q1 Mu thangu luidi mu zimbuka zieno, lufiongunina mintima mieno
\q1 bosi luba dio sui.
\q1 
\v 5 Lutambika makaba ma busonga,
\q1 ayi lutula diana dieno mu Yave.
\q1 
\v 6 Bawombo balembo tubi :
\q1 “Nani wulenda kutumonisa mamboti e ?”
\q1 Bika kiezila ki zizi kiaku kitukienzula, a Yave !
\q1 
\v 7 Wuwesidi khini yiwombo mu ntimꞌama,
\q1 viokila yoyi yiba yawu mu thangu baba ble yiwombo
\q1 ayi vinu kiwombo
\q1 
\v 8 Ndiela lambadala ayi ndiela leka tulu mu ndembama
\q1 bila ngeyo veka kaka, a Yave
\q1 bila ngeyo veka kaka wukuphuandisanga mu luvovomo.
\c 5
\cl Minkunga 5
\s1 Wuthuadisa mu nzilꞌaku
\d Nkunga Davidi kuidi pfumu minyimbidi. Wuyimbidila wawu mu flute.
\q1 
\v 1 A Yave, tamba dikutu mu mambu mama ayi tala vumina kuama.
\q1 
\v 2 Dimba yamikina kuama bu ndilembo tombi lusadusu
\q1 A ntinu ama ayi Nzambi ama
\q1 bila ngeyo ndieti sambila.
\q1 
\v 3 A Yave, mu nsuka ngeyo weti wa mbembo ama.
\q1 Mu nsuka ndieti tula zindombolo ziama va ntualꞌaku
\q1 ayi ndieti vingila mvutu mu diana.
\q1 
\v 4 Bila ngeyo wisiko Nzambi wummonanga khini mu mambu mambimbi ;
\q1 mutu wumbimbi kalendi vuanda ko va kimosi ayi ngeyo.
\q1 
\v 5 Batu badi luniemo balendi telama ko va meso maku.
\q1 Ngeyo weti lenda batu boso bobo bamvanganga mambimbi.
\q1 
\v 6 Ngeyo wumbunganga batu bantubanga luvunu.
\q1 Batu bobo bantengulanga menga ayi bobo bamvunanga,
\q1 Yave weti kuba kakumukina.
\q1 
\v 7 Vayi minu ndiela kota mu nzoꞌaku mu diambu di kiadi kiaku kinneni
\q1 ndiela buongama mu lukinzu mu Nzoꞌaku Nzambi Yinlongo.
\q1 
\v 8 Wuthuadisa, a Yave mu busonga buaku
\q1 mu diambu di bambeni ziama.
\q1 Ludika nzilꞌaku ku ntualꞌama.
\q1 
\v 9 Bila kuisi ko mambu malenda siwulu diana mu miunu miawu ;
\q1 mu mintima miawu muwedi mambu mambivisanga.
\q1 Phovilakꞌawu yidi ziami kizibuka
\q1 ayi mu ludimi luawu bantubilanga luvunu.
\q1 
\v 10 Wuba monisa ti mu nzimbala badi, a Nzambi.
\q1 Bika mayindu mambimbi mawu ma babuisa.
\q1 Wuba kuki mu diambu di wombo di masumu mawu
\q1 Bila ngeyo bafuemini.
\q1 
\v 11 Vayi bika babo bantomba suamunu mu ngeyo bamona khini.
\q1 Wuba bika bayimbila mu khini mu zithangu zioso ayi bika wuba keba.
\q1 Muingi bobo beti zola dizina diaku,
\q1 bamona khini mu ngeyo.
\q1 
\v 12 Bila bukiedika ngeyo Yave wunsakumunanga mutu wusonga ;
\q1 Wubazungidila mu mamboti maku banga nkaku.
\c 6
\cl Minkunga 6
\s1 Yave wutsadisa
\d Nkunga Davidi kuidi pfumu minyimbidi, wuyimbidila wawu mu ngitala yi nana di zitsinga.
\q1 
\v 1 A Yave, kadi kuthemina ku tsi nganzi aku
\q1 ayi kadi kuphana thumbudulu bu widi ku tsi miangu miaku mi ngolo.
\q1 
\v 2 Wumbona kiadi a Yave bila ndidi wulebakana,
\q1 A Yave wumbelusa bila mimvesi miama mieka nduka fua.
\q1 
\v 3 Muelꞌama wulembo yami,
\q1 Nate thangu mbi, a Yave, nate thangu mbi e ?
\q1 
\v 4 Vutikisa ntima, a Yave, wukhudi,
\q1 wuphukisa mu diambu di luzolo luaku lu ngolo.
\q1 
\v 5 Mutu kalendi kutebukila moyo ko niandi fua.
\q1 Ayi nani wela kuzitisa ku tsi bafua e ?
\q1 
\v 6 Mbemana vonga kuna ku kunga ;
\q1 builu bu mvimba ndieti bodisa mbukꞌama mu bidilu,
\q1 ndieti bodisa buangu ki ndieti leka mu matsuela.
\q1 
\v 7 Meso mama mabividi mu diambu di kiadi,
\q1 ayi manunini mu diambu di bobo beti kundenda.
\q1 
\v 8 Botukanu va ntualꞌama
\q1 beno boso lumvanganga mambu mambimbi.
\q1 Bila Yave wuwilu bidilu biama.
\q1 
\v 9 Yave wuwilu yamikina kuama mu diambu di kiadi
\q1 Yave kikinini lusambulu luama.
\q1 
\v 10 Bambeni ziama zioso baela fua tsoni
\q1 ayi bela ba boma-boma.
\q1 Bela vutikisa ku manima ayi bela fua tsoni mu nsualu.
\c 7
\cl Minkunga 7
\s1 Yave wundungisa
\d Nkunga wu maniongo wu Davidi kayimbidila Yave mu diambu di KUSI, muisi dikanda di Benzami.
\q1 
\v 1 A Yave, Nzambi ama,
\q1 kuidi ngeyo ndintombilanga suamunu kiama.
\q1 Wuphukisa mu babo beti kundandakana ayi wukhula.
\q1 
\v 2 Muingi babika ku khanzuna banga khosi
\q1 ayi kunzenga mu bitini mu kambu mutu wulenda vukisa.
\q1 
\v 3 A Yave, Nzambi ama, enati ndivengi mawu
\q1 ayi enati nzimbala yidi mu mioko miama ;
\q1 
\v 4 enati ndivutudi mambimbi kuidi mutu
\q1 wubedi zinganga yama mu ndembama,
\q1 voti ndiziona, mu kambu bila, bima bi mutu wundenda,
\q1 
\v 5 buna bika mbeni ama kandandakana
\q1 ayi kambakidila ;
\q1 bika kadiatidila luzingu luama va tsi,
\q1 ayi kandekisa mu mbungi-mbungi.
\q1 
\v 6 A Yave, telama ku tsi nganzi aku,
\q1 Nuanisa miangu mi ngolo mi bambeni ziama.
\q1 A Nzambi ama, kotuka
\q1 bika wundungisa.
\q1 
\v 7 Bika lukutukunu lu batu bazungidila,
\q1 bika wuba yadila bu widi ku diyilu
\q1 
\v 8 Bika Yave wusambisa batu
\q1 A Yave, wutsambisa boso buididi busonga buama
\q1 ayi boso buididi fuanana kuama, a Nzambi yizangama
\q1 
\v 9 A Nzambi yi busonga,
\q1 ngeyo wumfionguninanga mintima
\q1 ayi mayindu ma batu, manisa makhemi ma mutu wumbimbi
\q1 ayi tula mutu wusonga mu luvovomo.
\q1 
\v 10 Nzambi yizangama niandi nkaku ama ;
\q1 niandi wumvukisanga batu babo badi mintima milulama.
\q1 
\v 11 Nzambi niandi zuzi disonga,
\q1 Nzambi wummonisanga miangu miandi mu kadika lumbu.
\q1 
\v 12 Enati kakadi balula mavanga,
\q1 wela lengula sabala kiandi,
\q1 wela leki mbasꞌandi ayi kuwukubika.
\q1 
\v 13 Wukubika binduanina biandi bi lufua
\q1 wulembo kitula madionga mandi madionga ma mbazu.
\q1 
\v 14 Niandi widi mu buemba bu mambimbi ;
\q1 widi mu kubika ziphasi
\q1 ayi butidi mambu ma luvunu.
\q1 
\v 15 Niandi wukaba dibulu ; wudikulula dimula
\q1 ayi wubua mu dibulu di kakaba niandi veka.
\q1 
\v 16 Ziphasi ziozi kakubika zimbuididi niandi veka
\q1 ayi tsitꞌandi yibuidi va dikosi diandi.
\q1 
\v 17 Ndiela vutudila Yave matondo mu diambu di busonga buandi.
\q1 Ayi ndiela yimbidila nzitusu wu dizina di Yave wuzangama.
\c 8
\cl Minkunga 8
\s1 Bunneni bu Nzambi ayi bunneni bu mutu
\d Nkunga Davidi kuidi pfumu minyimbidi mu ngitala yi basi Ngati.
\q1 
\v 1 Yave, Pfumu eto !
\q1 Tala buevi dizina diaku didi di nzitusu va ntoto wumvimba.
\q1 Ngeyo wutula nkemboꞌaku viokila diyilu.
\q1 
\v 2 Mu bididi bi bana balezi ayi bi bana batsombi,
\q1 ngeyo wutuma mu totukila nzitusu
\q1 mu diambu di bambeni ziaku ;
\q1 mu diambu di kanga miunu mi bobo beti ku lenda,
\q1 ayi mutu wowo wumvutulanga mambimbi mu mambimbi.
\q1 
\v 3 Bu ndieti tala diyilu diaku, kisalu ki minlembo miaku,
\q1 ngonda ayi zimbuetete ziozi wutula va buangu ;
\q1 
\v 4 buna mbi biobi mutu mu diambu wuntebukilanga moyo,
\q1 ayi muana mutu mu diambu wumbelanga mayindu e ?
\q1 
\v 5 Ngeyo wumvanga kaba fioti ku tsi bivangu bi diyilu\f + \fr 8.5 \ft Tsekodolo yinkaka : Nzambi.\f*
\q1 ayi ngeyo wumvuika nkembo ayi nzitusu,
\q1 
\v 6 Ngeyo wunkitula nyadi mu
\q1 bisalu bi mioko miaku,
\q1 ngeyo wutula bima bioso ku tsi malu mandi :
\q1 
\v 7 mamemi moso ayi zingombi zioso ;
\q1 bibulu bioso binsitu,
\q1 
\v 8 zinuni zi yilu ayi zimbizi zi mbu,
\q1 bibioso bindiatilanga mu minsolo mi mbu.
\q1 
\v 9 A Yave, Pfumu eto !
\q1 Tala buevi dizina diaku didi di nzitusu va ntoto wumvimba.
\c 9
\cl Minkunga 9
\s1 Nzambi wuzenga nkanu mu busonga
\d Nkunga Davidi kuidi pfumu minyimbidi mu lufua lu muana.
\q1 
\v 1 Ndiela kuzitisa, a Yave, mu ntimꞌama wumvimba.
\q1 Ndiela yamikisa matsiminanga maku moso.
\q1 
\v 2 Ndiela mona khini ayi ndiela sakadala mu ngeyo,
\q1 Ndiela yimbidila nzitusu mu diambu di dizina diaku,
\q1 ngeyo Nzambi wuzangama.
\q1 
\v 3 Bambeni ziama balembo vutukisa ku manima,
\q1 balembo bumina zithutu ayi balembo bungana
\q1 va ntualꞌaku.
\q1 
\v 4 Bila ngeyo wunzengidi nkanu mu busonga, wudedisidi mambu mama ;
\q1 ngeyo wuvuendi va kundu kiaku ki kipfumu mu sambisa mu busonga.
\q1 
\v 5 Ngeyo wutemina makanda,
\q1 wubunga mutu wumbimbi,
\q1 wukubula mvimba mazina mawu mu zithangu zioso.
\q1 
\v 6 Mbivusu yikambulu tsukulu yibuididi bambeni ;
\q1 wutiolumuna mavula mawu
\q1 ayi malendi buela tebukulu moyo ko.
\q1 
\v 7 Yave wunyalanga mu zithangu zioso ;
\q1 wukubika kundu kiandi ki kipfumu mu diambu di sambisa.
\q1 
\v 8 Wela sambisa nza mu busonga,
\q1 wela yadila batu mu bufuana.
\q1 
\v 9 Yave niandi suamunu ki mutu weti yamusu ;
\q1 suamunu kingolo mu thangu yi ziphasi.
\q1 
\v 10 Babo bazebi dizina diaku,
\q1 bela tula diana diawu mu ngeyo.
\q1 Bila ngeyo, Yave, wuyekulanga ko
\q1 bobo bakutombanga.
\q1 
\v 11 Luyimbidila Yave minzitusu mutu wowo wukala ku Sioni ;
\q1 yamikisanu mambu mandi kavanga muidi makanda.
\q1 
\v 12 Bila mutu wowo wumvutulanga landi mu diambu di menga matengolo
\q1 wuntebukanga moyo ;
\q1 kazimbakananga ko yamikina ku batu badi mu phasi.
\q1 
\v 13 A Yave, tala buevi bambeni ziama
\q1 balembo ndiamisa
\q1 wumboni kiadi
\q1 ayi wundanguna mu mielo mi lufua.
\q1 
\v 14 Muingi ndiyamikisa minzitusu miaku
\q1 mu mielo mi muana ndumba wu Sioni,
\q1 muingi ndimona khini mu phulusu aku.
\q1 
\v 15 Makanda mabuidi mu dibulu dinneni diodi bakaba ;
\q1 malu mawu mabakini mu dikondi diodi batamba.
\q1 
\v 16 Yave wukimonikisidi, mu busonga buandi ;
\q1 mutu wumbimbi wukangimini
\q1 mu mavanga ma mioko miandi.
\q1 
\v 17 Batu bambimbi balembo vutuki ku tsi bafua,
\q1 makanda moso momo mazimbakana Nzambi.
\q1 
\v 18 Vayi nsukami kalendi tumbu zimbukunu ko
\q1 ayi diana di batu badi mu phasi dilendi tumbu lalakana ko.
\q1 
\v 19 A Yave, telama !
\q1 Bika mutu kabika nunga !
\q1 Bika makanda masambusu va meso maku.
\q1 
\v 20 A Yave, wubabuisila tsisi !
\q1 Bika makanda mazaba ti badi kaka batu.
\c 10
\cl Minkunga 10
\s1 A Pfumu, bila mbi telimini thama
\q1 
\v 1 Bila mbi ngeyo Yave telimini thama e ?
\q1 Bila mbi wididi wusuama mu thangu ziphasi e ?
\q1 
\v 2 Mu lunangu luandi, mutu wumbimbi
\q1 wulembo landakana mutu wulebakana ;
\q1 bobo babuilamanga mu makani momo kakubikidi.
\q1 
\v 3 Bila mutu wumbimbi wulembo kiniemisa mu nzinunu zi ntima andi ;
\q1 ayi wulembo sakumuna nkua lukokoto,
\q1 wulembo lenzi Yave.
\q1 
\v 4 Mu luniemo luandi, mutu wumbimbi kantombanga ko.
\q1 Mu mayindu mandi, Nzambi kasi kadi buangu ko.
\q1 
\v 5 Mu zithangu zioso, zinzila ziandi zidi zimboti
\q1 widi nkua lunangu
\q1 ayi mina miaku midi mitatuka kuidi niandi ;
\q1 wunsekininanga bambeni bandi zioso.
\q1 
\v 6 Wuniungutanga mu ntimꞌandi :
\q1 “Kuisi ko diambu dilenda ku ndikuna ;
\q1 Ndidi mu khini mu zithangu zioso ayi ndilendi ba mu phasi ko.”
\q1 
\v 7 Munu andi wuwedi tsingulu,
\q1 luvunu ayi buivi.
\q1 Ku tsi ludimi luandi kuidi ziphasi ayi mambimbi.
\q1 
\v 8 Wumfielanga mu ndambu mala.
\q1 Wumvondanga mutu kambulu zaba diambu mu bibuangu bisuama,
\q1 meso mandi manfielanga mu kinsueki bobo katidi vanga mbimbi.
\q1 
\v 9 Wumfielanga banga bumfiedilanga khosi bu kadi mu nsuku
\q1 wumfielanga mu diambu di buila batu bakambulu lusadusu.
\q1 
\v 10 Weti kuba kosikisa, bawu beti tumbu vonga ;
\q1 beti bua ku tsi zingolo ziandi.
\q1 
\v 11 Wuniungutanga mu ntimꞌandi :
\q1 “Nzambi zimbikini, fukidi zizi kiandi
\q1 ayi kalendi mona ko.”
\q1 
\v 12 A Yave Nzambi, telama, vumuna koko kuaku ;
\q1 kadi zimbakana batu bakambulu lusadusu !
\q1 
\v 13 Bila mbi mutu wumbimbi keti lenzila Nzambi e ?
\q1 Bila mbi kalembo niungutina mu ntimꞌandi :
\q1 “Kalendi tomba ko ti ndimvumbudila kipholo”
\q1 
\v 14 Muaki ngeyo Nzambi,
\q1 wulembo moni ziphasi ayi mabienga ;
\q1 Wulembo tadi mawu muingi wumatula va koko kuaku.
\q1 Nkua mabienga wukukiyekulanga kuidi ngeyo ;
\q1 ngeyo nsadisi wu muana sana.
\q1 
\v 15 Kelula koko ku mutu wumbimbi
\q1 ayi ku mutu weti vanga mambimbi,
\q1 nkambi kavumbudila kipholo mu mambimbi mandi ;
\q1 nate wela kambu buela ku mamona.
\q1 
\v 16 Yave niandi ntinu mu zithangu zioso
\q1 ayi mu thangu yi kayimani
\q1 Makanda mela bungana mu tsi andi.
\q1 
\v 17 A Yave, ngeyo weti wa zitsatu zi batu badi mu phasi.
\q1 Weti kuba kindisa ;
\q1 ayi dimba yamikina kuawu.
\q1 
\v 18 Mu diambu di nuanisa muana sana
\q1 ayi mutu weti yamusu muingi mutu widi va ntoto
\q1 kabika monisa tsisi.
\c 11
\cl Minkunga 11
\s1 Suamunu ki kiedika
\d Nkunga Davidi kuidi pfumu minyimbidi.
\q1 
\v 1 Kuidi Yave ndintombilanga suamunu.
\q1 Buevi lulenda ku khambila :
\q1 “Tinina ku miongo miaku banga bu ntininanga nuni.”
\q1 
\v 2 Bila tala, batu bambimbi balembo leki mimbasa ;
\q1 ayi balembo ludika zitsoto va nsinga
\q1 mi mimbasa muingi babasula, bu badi mu tombi,
\q1 batu bobo badi mintima mi lulama.
\q1 
\v 3 Enati zifundasio zitiolumunu,
\q1 buna mutu wusonga, mbi kalenda vanga e ?
\q1 
\v 4 Yave widi mu nzoꞌandi yinlongo !
\q1 Yave, kundu kiandi ki luyalu kidi ku diyilu,
\q1 meso mandi malembo tadi ayi zindabu ziandi
\q1 zimfionguninanga bana ba batu.
\q1 
\v 5 Yave wumfionguninanga mutu wusonga
\q1 vayi muelꞌandi weti lenda mutu wumbimbi
\q1 ayi mutu wowo wunzolanga matsita.
\q1 
\v 6 Wunokisanga makala ayi sofolo yi mbazu.
\q1 Kuidi batu bambimbi,
\q1 Phemo yi mbazu yawu kopo yi ziphasi bela kabana.
\q1 
\v 7 Bila Yave widi wusonga, wunzolanga masonga.
\q1 Batu badi mintima mi lulama
\q1 bela talanga zizi kiandi.
\c 12
\cl Minkunga 12
\s1 Nzambi wundedikisanga zitsila ziandi
\d Nkunga Davidi kayimbidila mu ngitala yi nana di zitsinga kuidipfumu minyimbidi.
\q1 
\v 1 A Yave, yiza sadisa bila batu beti kinzika
\q1 mambu ma Nzambi basiedi ko.
\q1 Mikhuikizi mizimbidi va khatitsika yi bana ba batu.
\q1 
\v 2 Kadika mutu wulembo vuni fikimini yandi.
\q1 Mambu ma lueki madi mu bididi biawu
\q1 vayi mintima miodi badi sumbu bantuba.
\q1 
\v 3 Bika Yave kabunga bididi bioso
\q1 bintubanga mambu ma lueki
\q1 ayi ludimi luntubanga mambu mu luniemo.
\q1 
\v 4 Batu bobo bantubanga :
\q1 “Tuela nunga mu diambu di ludimi lueto,
\q1 bididi bieto bidi bieto veka ;
\q1 nani wulenda ba Pfumu eto ?”
\q1 
\v 5 Bila mu diambu di yamusu ku batu balebakana,
\q1 ayi kunga ku nsukami ;
\q1 diawu Yave kakembi buabu :
\q1 “Buabu ndieka ntelama,
\q1 ndieka kuba kaka mu diambu di mutu balembo kuba yamisa.”
\q1 
\v 6 Mambu ma Yave madi mavedila banga palata
\q1 kioki bavedisidi mu mbazu,
\q1 kivedosolo mu tsambuadi di zikhumbu.
\q1 
\v 7 Yave ngeyo wela kutu keba mu luvovomo
\q1 wela kutu kaka mu diambu di ntindu wu batu baba,
\q1 mu thangu yi kayimani.
\q1 
\v 8 Batu bambimbi beti vemanga muamo
\q1 mu thangu bifu bi mbimbi bieti yayusu
\q1 va khatitsika batu.
\c 13
\cl Minkunga 13
\s1 Tsisi ayi diana
\d Nkunga Davidi kuidi pfumu minyimbidi.
\q1 
\v 1 A Yave, nate thangu mbi wela tatamana kunzimbakana mu zithangu zioso e ?
\q1 Nate thangu mbi wela kutsuekilanga zizi kiaku e ?
\q1 
\v 2 Nate thangu mbi ndiela kukinuanisanga
\q1 mu mayingu mama e ?
\q1 Nate thangu mbi ndiela bela maniongo mu ntimꞌama mu kadika lumbu e ?
\q1 Nate thangu mbi mbeni ama kela ku ndunginanga e ?
\q1 
\v 3 A Yave, Nzambi ama, wuthadi ayi wuphana mvutu,
\q1 kienzula meso mama mu diambu ndibika
\q1 leka tulu tu lufua,
\q1 
\v 4 mu diambu mbeni ama kabika tuba :
\q1 “Ndinnungini” ayi muingi batu beti kundenda babika mona khini
\q1 minu bua.
\q1 
\v 5 Vayi minu tsidi diana mu luzolo luaku lungolo.
\q1 Ntimꞌama wulembo moni khini
\q1 mu phulusu aku.
\q1 Ndiela yimbidila Yave bila niandi wuphangidi mamboti.
\c 14
\cl Minkunga 14
\s1 Nza yidi yi biva
\d Nkunga Davidi kuidi pfumu minyimbidi.
\q1 
\v 1 Nkua buvulu wuntubanga mu ntimꞌandi ti :
\q1 Kuisiko Nzambi !
\q1 Baki bivisidi,
\q1 mavanga mawu madi mambimbi ;
\q1 kuisiko mutu wumvanganga mamboti.
\q1 
\v 2 Yave, ku yilu ku kadi, wulembo tadi bana
\q1 ba batu mu tala kani wulenda mona wumosi wunsundika,
\q1 kani wumosi wuntombanga Nzambi.
\q1 
\v 3 Baboso bavengama ayi bamana kibivisa va kimosi ;
\q1 kuisiko mutu wumvanganga mamboti,
\q1 kadi mutu wumosi.
\q1 
\v 4 Batu boso bamvanganga mambu mambimbi basi nzayilu ko e ?
\q1 Bobo balembo dia batu bama, banga batu bandia dipha
\q1 ayi bobo batelanga dizina di Yave ko.
\q1 
\v 5 Buna kuna bela tita mu diambu di tsisi
\q1 bila Nzambi widi va khatitsika
\q1 dikabu di batu basonga.
\q1 
\v 6 Beno mimvangi mi mambimbi,
\q1 lulenda vunza zikhanu zi nsukami.
\q1 Vayi Yave niandi suamunu kiandi.
\q1 
\v 7 A enati phulusu yi Iseli
\q1 yitotukila ku Sioni !
\q1 Mu thangu Yave kela vutula kiuka ki batu bandi
\q1 Bika Yakobi kamona khini ayi Iseli kayangadala.
\c 15
\cl Minkunga 15
\s1 Nani wulenda zinga ayi Nzambi
\d Nkunga Davidi.
\q1 
\v 1 A Yave, nani wulenda vuanda mu nzo aku yi ngoto e ?
\q1 Nani wulenda zinga ku mongo aku wunlongo e ?
\q1 
\v 2 Woso mutu wundiatanga mu kambu tsembolo,
\q1 wumvanganga mambu ma busonga
\q1 ayi wuntubanga mambu ma kiedika
\q1 mantotukanga mu ntimꞌandi.
\q1 
\v 3 Katubidilanga ko batu mu ludimi luandi ;
\q1 Kavangilanga ndiandi mambimbi ko
\q1 ayi kabivisanga nzitusu wu ndiandi ko.
\q1 
\v 4 Weti lenza mutu weti vanga mambimbi
\q1 Vayi wunzitisanga bobo bankinzikanga Yave.
\q1 Wunkebanga zindefi ziandi.
\q1 Ka diambu ko yela kummonisa phasi.
\q1 
\v 5 Katombanga ndandu ko va yilu zimbongo
\q1 ziozi kadevisa.
\q1 Ayi kakikininanga ko makaba mu diambu di
\q1 bedisa mutu kambulu zaba diambu.
\q1 Woso wumvanganga mambu momo
\q1 kalendi nikunu ko.
\c 16
\cl Minkunga 16
\s1 Nzila yi luzingu
\d Nkunga Davidi.
\q1 
\v 1 A Nzambi, wukheba mu luvovomo
\q1 bila kuidi ngeyo nditombila suamunu.
\q1 
\v 2 Kuidi Yave ndituba :
\q1 “Ngeyo Pfumu ama,
\q1 kuidi ngeyo kaka kueti banga mamboti mama.”
\q1 
\v 3 Mu diambu di banlongo bobo badi mu tsi ;
\q1 bawu batu banzitusu.
\q1 Khini yiwombo baku mbonisanga.
\q1 
\v 4 Bobo banlandakananga zinzambi zinkaka
\q1 kiadi kiawu kiela buelama,
\q1 voti ndilendi tambika makaba mawu ma menga ko,
\q1 Ndilendi tanga mazina mawu mu bididi biama ko.
\q1 
\v 5 Yave ngeyo wuphana ndambu yi kiuka kiama,
\q1 ayi mbungu ama,
\q1 ngeyo wunkebanga kuku kiama mu luvovomo.
\q1 
\v 6 Zindili zikubuku mu diambu diama mu buangu bidi kitoko ;
\q1 bukiedika, thambudi kiuka ki mboti.
\q1 
\v 7 Ndiela zitisa Yave ;
\q1 wukuphananga malongi
\q1 ntimꞌama wukundonganga mu builu,
\q1 
\v 8 Ndieti tula Yave ku ntualꞌama mu zithangu zioso
\q1 bila widi ku koko kuama ku lubakala,
\q1 ndilendi nikuka ko.
\q1 
\v 9 Diawu ntimꞌama wididi mu khini ;
\q1 ludimi luama lueti yangalala
\q1 ayi nitu ama yela vunda mu luvovomo ;
\q1 
\v 10 Bila ngeyo wulendi kundiekula ko
\q1 ku tsi bafua,
\q1 ayi wulendi tala ko mutu aku wunlongo kabola.
\q1 
\v 11 Ngeyo wumbonisa nsolo wu luzingu ;
\q1 zikhini ziwombo zidi va ntuala zizi kiaku.
\q1 Wela kumbonisa khini va meso maku
\q1 va kimosi ayi zikhini zika zisukanga ko zidi va koko kuaku ku lubakala.
\c 17
\cl Minkunga 17
\s1 Wulandukunu mu kambu bila
\d Lusambulu lu Davidi.
\q1 
\v 1 Yave wa mambu ma busonga bu ndieti samba ;
\q1 dimba yamikina kuama ;
\q1 tamba kutu mu lusambulu luama
\q1 lueti totukila mu bididi bikambulu luvunu.
\q1 
\v 2 Bika ndungunu ama yitotukila kuidi ngeyo
\q1 ayi bika meso maku mamona momo madi ma lulama.
\q1 
\v 3 Ka diambu ko tidi fiongunina ntimꞌama,
\q1 ayi kuthala va builu
\q1 ka diambu ko wumbekini, mu mbazu wulendi mona kadi kiasa ko.
\q1 Ndibaka lukanu ti munu ama
\q1 wulendi sumuka ko.
\q1 
\v 4 Mu diambu di mavanga ma batu ;
\q1 mu nzila yi mambu ma bididi biaku,
\q1 ndieti kukikeba mu nzila yi mutu widi matsita.
\q1 
\v 5 Bitambi biama bidi kaka bikinda
\q1 mu minsolo miaku,
\q1 malu mama malendi sialumuka ko.
\q1 
\v 6 A Nzambi, ndikutela bila ngeyo wela kuphana mvutu.
\q1 Yinika dikutu diaku ku ndidi
\q1 ayi wa lusambulu luama.
\q1 
\v 7 Monisa matsiminanga ma luzolo luaku lunneni,
\q1 ngeyo wuphukisanga mu koko kuaku ku lubakala
\q1 bobo bansuaminanga mu ngeyo,
\q1 mu bobo bakubalendanga.
\q1 
\v 8 Wukheba banga ngengele yi dieso diaku ;
\q1 wutsueki ku tsi kitsusula ki mavavi maku,
\q1 
\v 9 mu diambu di batu bambimbi beti kundiamisa,
\q1 mu diambu di bambeni ziama zieti kunzungidila ;
\q1 ziosi zintomba lufua luama.
\q1 
\v 10 Bakikangidi mintima miawu midi banga matadi ;
\q1 Miunu miawu mintubanga mambu ma lunanga.
\q1 
\v 11 Balembo ndandakana,
\q1 banzungididi buabu ; balembo tadi
\q1 mu diambu bambuisa va tsi.
\q1 
\v 12 Badedikini banga khosi yidi nzala kanzuna,
\q1 banga khosi yiyunduka yidi yilambididi va buangu kisuama.
\q1 
\v 13 Telama, Yave, wuba nuanisa
\q1 ayi bika wuba buisa,
\q1 wukhula mu sabala kiaku ;
\q1 mu mutu wumbimbi.
\q1 
\v 14 A Yave, bika wuphukisa mu koko kuaku mu batu ba phila yayi ;
\q1 batu ba ntoto wawu ; bobo mfutu awu widi mu luzingu lualu.
\q1 Weti lembika nzala yi bobo weti zola
\q1 bana bawu babeki biwombo,
\q1 ayi balundila bana bawu batsombi kimvuama.
\q1 
\v 15 Vayi minu, ndiela mona zizi kiaku mu busonga.
\q1 Bu ndiela kotuka ndiela yukuta mu talanga mfikulꞌaku.
\c 18
\cl Minkunga 18
\s1 Matondo bu wukhula
\d Nkunga Davidi, kisadi ki Yave, kuidi Pfumu minyimbidi. Wuyimbila nkunga wawu mu diambu di Yave mu thangu Yave kankula mu mioko mi bambeni bandi ayi mu mioko mi Sawuli.
\q1 
\v 1 Yave, ndikuzolanga, ngeyo zingolo ziama.
\q1 
\v 2 A Yave, niandi ditadi diama,
\q1 tinunu kiama ki ngolo,
\q1 ayi ngeyo nkudi ama.
\q1 Nzambi ama, niandi ditadi diama ;
\q1 mu niandi ndintombila suamunu,
\q1 niandi nkaku ama, ayi phoka yi phulusu ama,
\q1 ayi tinunu kiama ki zangama.
\q1 
\v 3 Ndiela tela Yave, niandi fueni mu zitusu
\q1 ayi ndiela vuka mu bambeni ziama.
\q1 
\v 4 Minsinga mi lufua mimfietikisa.
\q1 Bosi khuka nlangu yimbunganga yimbuila mu kinzimbukila.
\q1 
\v 5 Minsinga mi tsi bafua minzingalakana.
\q1 Mintambu mi lufua mi lekama ku ntualꞌama.
\q1 
\v 6 Mu ziphasi ziama, nditela Yave
\q1 Ndiyamikina kuidi Nzambi ama mu tomba lusadusu
\q1 wuwa mbemboꞌama tona kuna nzoꞌandi,
\q1 ayi yamikina kuama kutula va ntualꞌandi,
\q1 mu matu mandi.
\q1 
\v 7 Buna ntoto wunikuka ayi wutita.
\q1 Zifondasio zi miongo zinikunu
\q1 ayi zinikuka, bila wuba wufuema ngolo.
\q1 
\v 8 Muisi wutotuka mu mayilu mandi,
\q1 ayi mbazu yi nlalikisanga yitotuka mu munuꞌandi ;
\q1 muawu mu totukila makala ma mbazu.
\q1 
\v 9 Wukulula diyilu ayi wukuluka,
\q1 ayi matuti ma ndombe maba ku tsi malu mandi.
\q1 
\v 10 Wukuma va yilu kheluba ayi wudumuka.
\q1 Wuvevumuka va yilu mavavi ma phemo.
\q1 
\v 11 Wukitula tombi buangu kiandi kisuamina ;
\q1 kapu andi yiba kunzungidila,
\q1 tombi kinokisa mvula yi matuti ma diyilu.
\q1 
\v 12 Mu kiezila kiba va ntualꞌandi mutotukila matuti,
\q1 mvula yi matadi ayi zitsiemo.
\q1 
\v 13 Yave wuduma tona mu Diyilu ;
\q1 mbembo yi Nzambi yizangama yiwakakana\f + \fr 18.13 \ft Minkanda minkaka mibuela mvula yi matadi yinoka, makala ma mbazu madoduka.\f*.
\q1 
\v 14 Niandi wuloza madionga mandi
\q1 ayi wusasikisa bambeni ;
\q1 zitsiemo zinneni
\q1 ayi wuba zimbikisa nzila.
\q1 
\v 15 Tsi nlangu yi mbu yimonika,
\q1 ayi zifondasio zi ntoto zimonika
\q1 ngeyo Yave bu wutema mu phemo yitotukila mu mayilu maku.
\q1 
\v 16 Wunonuna koko kuandi tona ku yilu
\q1 ayi wutsimba,
\q1 wuthotula mu minlangu minneni midi thipula.
\q1 
\v 17 Niandi wukhula mu mbeni ama yingolo,
\q1 ayi mu batu bobo bandenda
\q1 bila bawu bandutila ngolo.
\q1 
\v 18 Bawu banduanisa mu lumbu ki ndiba mu mabienga,
\q1 vayi Yave niandi wuba singumunu kiama.
\q1 
\v 19 Niandi wuthotula ayi wuthula va buangu kikambulu tsisi ;
\q1 wukhula bila khini kaba monanga mu minu.
\q1 
\v 20 Yave wuphangidi bobo boso buididi busonga buama ;
\q1 wupheni mfutu boso buididi vedila ku mioko miama
\q1 
\v 21 Bila ndikebidi zinzila zi Yave
\q1 ayi ndisia tamba Nzambi ama mbusa ko
\q1 mu diambu di vanga mambimbi.
\q1 
\v 22 Mina miandi mioso midi va ntualꞌama
\q1 ayi ndisia vengama ko mu zithumunu ziandi.
\q1 
\v 23 Ndiba mutu wukambu tsembolo va ntualꞌandi
\q1 Ndikikeba mu diambu di masumu.
\q1 
\v 24 Yave wupheni mfutu boso buididi busonga buama,
\q1 boso buididi vedila ku mioko miama
\q1 va ntuala meso mandi.
\q1 
\v 25 Kuidi mutu widi wukuikama,
\q1 ngeyo wukukimonisanga wukuikama.
\q1 Kuidi mutu wukambulu tsembolo
\q1 ngeyo wukukimonisanga mutu wukambulu tsembolo.
\q1 
\v 26 Kuidi mutu wuvedila,
\q1 wukukimonisanga wuvedila.
\q1 Kuidi mutu wumbimbi,
\q1 wukukimonisanga wumbimbi.
\q1 
\v 27 Ngeyo wumvukisanga batu beti kukikula
\q1 ayi wunkululanga meso madi luyanu\f + \fr 18.27 \ft Minsekudi minkaka minsadila luniemo va buangu ki luyalu.\f*.
\q1 
\v 28 Ngeyo a Yave, keba muindꞌama wuba wulema
\q1 A Nzambiꞌama, kitula tombi kiama ;
\q1 kikituka kiezila.
\q1 
\v 29 Mu lusadusu luaku
\q1 ndilenda nuanisa nkangu masodi,
\q1 va kimosi ayi Nzambi ama,
\q1 ndilenda dumuka baka kikunzama.
\q1 
\v 30 Kuidi Nzambi, nzilꞌandi yidi yi fuana,
\q1 mambu ma Yave madi ma kiedika.
\q1 Niandi nkaku wu batu boso bobo
\q1 bansuaminanga mu niandi.
\q1 
\v 31 Bila nani Nzambi, enati ka Yave ko e ?
\q1 Ayi nani ditadi di ngolo,
\q1 enati ka Nzambi eto ko e ?
\q1 
\v 32 Nzambi, niandi wukuphananga ngolo
\q1 ayi wunkitulanga nzilꞌama yi fuana.
\q1 
\v 33 Wunkitulanga malu mama banga malu ma tsesi,
\q1 ayi wukuthelimisanga va bibuangu biama bizangama.
\q1 
\v 34 Wunlongisanga mioko miama mu nuana mvita,
\q1 mioko miama milenda leka mbasa wusengo.
\q1 
\v 35 Wuphana nkaku aku wu ndungunu,
\q1 ayi koko kuaku ku lubakala kukhindisa
\q1 ayi wukuluka mu diambu di kukhitula mutu wunneni.
\q1 
\v 36 Ngeyo wukubikidi nsolo wuyalumuka
\q1 ku tsi bitambi biama,
\q1 muingi bikodi biama bibika visuka.
\q1 
\v 37 Ndikuka bambeni ziama
\q1 ayi ndizibakidila.
\q1 Ndisia vutuka manima ko enati ndisia mana kuzivonda.
\q1 
\v 38 Ndiba kosikisa ayi basia buela baka bu telimina ko ;
\q1 babua ku tsi malu mama.
\q1 
\v 39 Ngeyo wuphana zingolo zi nuanina mvita ;
\q1 Ngeyo weti komvika batu beti kundenda
\q1 ku tsi malu mama.
\q1 
\v 40 Ngeyo wuntinisanga bambeni ziama
\q1 va ntualꞌama
\q1 ayi ndibunga bobo bakundendanga.
\q1 
\v 41 Bayamikina mu tomba lusadusu,
\q1 vayi kadi mutu mu kuba vukisa.
\q1 Bayamikina kuidi Yave
\q1 vayi kasia ku bavutudila mvutu ko.
\q1 
\v 42 Ndiba kosikisa banga mbungi-mbungi
\q1 yeti vevumunu kuidi phemo.
\q1 Ndiba loza thama banga nyamba wu zinzila.
\q1 
\v 43 Wukhula mu minzonza mi batu,
\q1 ayi wukhitula ntu wu makanda ;
\q1 batu bobo ndisia zaba ko, bawu ndiela yadila.
\q1 
\v 44 Bu batumbu kungua bathumukina ;
\q1 banzenza zikikulula va ntualꞌama.
\q1 
\v 45 Zinzenza zilembo vongi,
\q1 balembo titi sumbu bantotuka mu bibuangu biawu bisuama ngolo.
\q1 
\v 46 Yave wulembo zingi
\q1 Nzitusu wuba kuidi ditadi diama
\q1 yayusu kuba kuidi Nzambi Mvulusi ama.
\q1 
\v 47 Niandi Nzambi wukuphutudilanga landi ;
\q1 ayi wutula makanda ku tsi luyalu luama.
\q1 
\v 48 Wuphukisa mi bambeni ziama,
\q1 Ngeyo wundiayisa va yilu batu bobo bandenda.
\q1 Ngeyo wukhula mu batu ba matsita.
\q1 
\v 49 Diawu ngeyo Yave, ndiela ku zitisa
\q1 va khatitsika makanda.
\q1 Ndiela yimbila minzitusu mu diambu
\q1 di dizina diaku.
\q1 
\v 50 Niandi wuvana ndungunu yinneni
\q1 kuidi ntinu andi
\q1 ayi wummonisanga mamboti mandi ma ngolo kuidi mutu andi kavinda mafuta\f + \fr 18.50 \ft Mutu kavinda mafuta voti kusua ki Yave mu minkanda minkaka.\f*,
\q1 kuidi Davidi ayi nkuna andi mu zithangu zioso.
\c 19
\cl Minkunga 19
\s1 Zitsongolo zizole zi Nzambi
\d Nkunga Davidi kuidi pfumu minyimbidi.
\q1 
\v 1 Diyilu dieti samuna nkembo wu Nzambi
\q1 ayi matuti meti yamikisa kisalu ki mioko miandi.
\q1 
\v 2 Kadika Lumbu kinyamikisa mambu beni
\q1 kuidi lumbu kinkaka ;
\q1 ayi builu bumosi bueti ma zabikisa
\q1 kuidi builu bunkaka.
\q1 
\v 3 Kuisi ko mambu mayoluka voti mambu masadila ;
\q1 Kunkambu wakana zimbembo ziawu.
\q1 
\v 4 Zimbembo ziawu zieti wakana va ntoto wumvimba.
\q1 Mambu mawu beti yoluka
\q1 meti tula nate ku sukisina nza.
\q1 Ku diyilu katungila nzo yi ngoto
\q1 mu diambu di thangu :
\q1 
\v 5 Yawu yidi banga dibakala dikuela
\q1 dintotuka va ntuala vinga kiandi,
\q1 banga dikesa, dieti mona khini mu zawula thinu ;
\q1 
\v 6 Yintotukilanga ku tsongi yi Diyilu,
\q1 bosi ku tsongi yinkaka
\q1 kuawu kamanisinanga nzietolo andi.
\q1 Kuisiko kima kinsuamanga va ntuala diamu diandi.
\q1 
\v 7 Mina mi Yave midi mifuana,
\q1 mieti vananga diaka muela luzingu
\q1 Zinzengolo zi Yave zidi zi kiedika
\q1 Zinkitulanga mutu wu phamba mutu wu nduenga.
\q1 
\v 8 Minsiku mi Yave midi mi songa,
\q1 minyangidikanga ntima.
\q1 Zithumunu zi Yave zidi zivedila,
\q1 zinkienzulanga meso.
\q1 
\v 9 Kinzika Yave didi diambu di vedila,
\q1 dieti zingila mu zithangu zioso.
\q1 Zitsikudukusu zi Yave zilenda siwulu diana,
\q1 zizioso zidi zisonga va kimosi ;
\q1 
\v 10 Zilutidi thalu ayi nolo ;
\q1 ayi viokila zinolo ziwombo zivedila
\q1 zilutidi niosi mu lueki ;
\q1 zilutidi yoyi yinkumba mu bisila.
\q1 
\v 11 Mu ziawu mueti lubukila kisadi kiaku ;
\q1 mfutu wunneni widi mu kuzikebanga.
\q1 
\v 12 Nani wulenda sudika zinzimbala ziandi e ?
\q1 Lemvukila zinzimbala ziama zisuama.
\q1 
\v 13 Keba kisadi kiaku mu masumu mamvangimina mu luzolo ;
\q1 mabika ku ndiadila ;
\q1 buna ndiela ba wukambu tsembolo ;
\q1 wukambu zaba diambu mu masumu manneni.
\q1 
\v 14 Bika mambu ma munuꞌama ayi mayindu ma ntimꞌama
\q1 maba ma khini va ntualꞌaku
\q1 A Yave, ditadi diama ayi nkudi ama.
\c 20
\cl Minkunga 20
\s1 Yave nungisa ntinu eto
\d Nkunga Davidi kuidi pfumu minyimbidi.
\q1 
\v 1 Bika Yave kavana mvutu bu widi mu ziphasi,
\q1 bika dizina di Nzambi yi Yakobi dikeba.
\q1 
\v 2 Bika kafidisa lusadusu bu kadi ku buangu kinlongo
\q1 Bika kakindisa bu kadi ku Sioni.
\q1 
\v 3 Bika katebukila makaba maku moso moyo.
\q1 Ayi kakikinina makaba maku maviku.
\q1 
\v 4 Bika kavana bitidi ntimꞌaku.
\q1 Ayi bika kanungisa zikhubukulu ziaku zioso.
\q1 
\v 5 Tuela yamikina mu khini bu wela tambula ndungunu.
\q1 Tuela vumbula bidalapo bieto ku Yilu
\q1 mu dizina di Nzambi eto.
\q1 Bika Yave kadukisa zindombolo ziaku zioso.
\q1 
\v 6 Buabu nzebi ti Yave wumvukisanga
\q1 mutu andi wuka vinda mafuta,
\q1 weti kumvana mvutu bu kadi ku Diyilu,
\q1 diandi dinlongo mu lusadusu luandi lungolo,
\q1 lu koko kuandi ku lubakala.
\q1 
\v 7 Bankaka bantulanga diana mu matoma ma mvita,
\q1 bankaka mu ziphunda.
\q1 Vayi beto tuntulanga diana
\q1 mu dizina di Yave, Nzambi eto.
\q1 
\v 8 Bawu beti fukama mu makuma mawu ayi beti bua ;
\q1 Vayi beto tueti telama ayi tuidi kaka bakinda.
\q1 
\v 9 Yave vukisa ntinu
\q1 Bika wutuvana mvutu mu thangu tueti tela.
\c 21
\cl Minkunga 21
\s1 Matondo mu diambu di ndungunu
\d Nkunga Davidi kuidi pfumu minyimbidi.
\q1 
\v 1 A Yave, ntinu weti yangalala mu zingolo ziaku
\q1 ayi tala phila khini andi yididi yinene mu ndungunu yoyi weti vana.
\q1 
\v 2 Ngeyo wumvana bima bioso bitomba ntimꞌandi.
\q1 Ayi wusia kunyimina ko zindombolo ziozi kalomba mu bididi biandi.
\q1 
\v 3 Ngeyo wuntambula va kimosi
\q1 ayi lusakumunu lu luvalu lu ngolo.
\q1 Ngeyo wutula budu ki nolo yi vedila
\q1 va mbata ntuꞌandi.
\q1 
\v 4 Niandi wulomba luzingu kuidi ngeyo ayi wumvana luawu,
\q1 luzingu lu mula mu zithangu zioso
\q1 ayi lu kalumani.
\q1 
\v 5 Nkemboꞌandi widi wunneni mu diambu di ndungunu weti vana.
\q1 Ngeyo wumvuika kiezila
\q1 ayi nzitusu.
\q1 
\v 6 Bukiedika, ngeyo wumvana lusakumunu lu kalumani ;
\q1 wunkitula mutu wu yangadala mu diambu di khini yidi va meso maku
\q1 
\v 7 Bila Ntinu wuntulanga diana diandi mu Yave ;
\q1 Ayi mu diambu di luzolo lu ngolo Nzambi yizangama,
\q1 kalendi bulangana ko.
\q1 
\v 8 Koko kuaku kuela buila bambeni ziaku zioso.
\q1 Koko kuaku ku lubakala kuela buila
\q1 bobo beti ku lenda.
\q1 
\v 9 Wela kuba kitula banga mfulu makala ma mbazu,
\q1 mu thangu yoyi wela kukimonikisa.
\q1 Yave wela kuba sikisa mu nganzi andi.
\q1 Ayi mbazu yela kuba zinisa.
\q1 
\v 10 Wela bunga nkunꞌawu va ntoto
\q1 ayi bana bawu va khatitsika yi bana ba batu.
\q1 
\v 11 Ka diambu ko balenda kubika mambimbi mu diambu diaku
\q1 ayi yindula zikhanu zimbimbi, balendi nunga ko.
\q1 
\v 12 Bila ngeyo wela kuba tinisa
\q1 bu wela kuba basula mu mbasꞌaku.
\q1 
\v 13 A Yave, yayusu kuaku mu zingolo ziaku.
\q1 Tuela yimbidila ayi zitisa lulendo luaku.
\c 22
\cl Minkunga 22
\s1 A Nzambi ama, bila mbi wundiekudidi e ?
\d Nkunga Davidi kuidi pfumu minyimbidi, wuyimbidila wawu mu nningu wu beti tedilanga “Nsuma wu nsuka”.
\q1 
\v 1 Nzambi ama, Nzambi ama,
\q1 bila mbi wundiekuididi e ?
\q1 Ayi bila mbi wididi thama mu kambu ku phukisa e ?
\q1 Ayi bila mbi wididi thama mu kambu wa maniongo mama e ?
\q1 
\v 2 Nzambi ama, ndinyamikina va muini,
\q1 vayi wukadi vutula mvutu.
\q1 Va builu, ndivuandanga ko dio sui.
\q1 
\v 3 Vayi ngeyo wubieko banga wunlongo.
\q1 Ngeyo nzitusu wu Iseli.
\q1 
\v 4 Mu ngeyo bakulu beto batula diana diawu.
\q1 Batula diana diawu mu ngeyo ayi wuba kula.
\q1 
\v 5 Kuidi ngeyo bayamikina
\q1 ayi ngeyo wuba vukisa.
\q1 Mu ngeyo batula diana diawu
\q1 ayi basia fuisu tsoni ko.
\q1 
\v 6 Vayi minu, ndidi kiela vayi bika mutu.
\q1 Babakala balembo mvuezi,
\q1 batu balembo ndenzi.
\q1 
\v 7 Babo bobo beti kumbona beti ku tsekinina.
\q1 Beti finga.
\q1 Beti nikuna mintu :
\q1 
\v 8 “Kuidi Yave keti tula diana diandi
\q1 buna bika kamvukisa, bika kankula bila khini keti mona mu niandi.”
\q1 
\v 9 Vayi, ngeyo wuthotula mu vumu ;
\q1 wuvanga ti nditula diana diama mu ngeyo
\q1 banga va thulu yi ngudi ama.
\q1 
\v 10 Tona ndibutuka ndiyekulu kuidi ngeyo tona mu vumu ki ngudi ama.
\q1 Tona mu vumu ki ngudi ama,
\q1 ngeyo wuba Nzambi ama.
\q1 
\v 11 Kadi kuthatukila bila ziphasi zifikimini,
\q1 bila kuisi ko mutu wulenda sadisa.
\q1 
\v 12 Zingombi ziwombo zimbakala zinzungididi,
\q1 zingombi zi Basani zinzungididi.
\q1 
\v 13 Mu kunga ku khosi yeti kanzuna bulu
\q1 miunu miawu midi mizibuka ngolo mu diambu diama
\q1 
\v 14 Mbeni dukuka banga nlangu
\q1 ayi mimvesi miama mioso mivasukidi.
\q1 Ntimꞌama widi banga mafuta beti vindanga mu mabaya.
\q1 Wulembo siuti mu khati yi nitu ama.
\q1 
\v 15 Zingolo ziama zilembo yumi
\q1 banga tini ki nzungu tuma
\q1 ayi ludimi luama lunemi mu munu ama.
\q1 Ngeyo wuthula mu mbungi-mbungi yi lufua.
\q1 
\v 16 Zimbwa zinzungididi,
\q1 Nkangu wu batu bambimbi banzungididi.
\q1 Batobudi mioko miama ayi malu mama.
\q1 
\v 17 Ndilenda tanga mimvesi miama mioso.
\q1 Batu beti kutsungimina ayi balembo thadi.
\q1 
\v 18 Balembo kabana bawu na bawu minlele miama
\q1 ayi balembo budila yunga kiama tsombo.
\q1 
\v 19 Vayi ngeyo Yave, kadi ba thama.
\q1 Ngeyo zingolo ziama ayi yiza nsualu mu kutsadisa.
\q1 
\v 20 Kula luzingu luama mu sabala ;
\q1 luzingu luama lu thalu mu luyalu lu zimbua.
\q1 
\v 21 Wukhudi mu munu wu khosi
\q1 wuphukisa mu ziphoka zi ziphaka.
\q1 
\v 22 Ndiela yolukila dizina diaku
\q1 kuidi bakhomba baama ;
\q1 ndiela ku zitisa va khatitsika lukutukunu.
\q1 
\v 23 Beno lunkinzikanga Yave,
\q1 bika lunzitisa !
\q1 Beno babo luidi mu nkuna Yakobi,
\q1 bika lunkinzika !
\q1 Beno babo luidi mu nkuna wu Iseli,
\q1 bika lunzitisa.
\q1 
\v 24 Bila kasia lenza ko ayi kasia kakumukina ko
\q1 ziphasi zi mutu widi mu phasi ;
\q1 kasia kunsuekila zizi kiandi ko
\q1 vayi weti wa yamikina kuandi
\q1 bu keti tomba lusadusu.
\q1 
\v 25 Kuidi ngeyo kueti totukila minzitusu miama mu lukutukunu lunneni
\q1 va ntuala bobo beti ku kinzika,
\q1 ndiela dukisa zitsila ziama.
\q1 
\v 26 Minsukami miela dia ayi miela yukuta.
\q1 Bobo beti tomba Yave bela kumvana nzitusu.
\q1 Bika mintima mieno mizinga mu zithangu zioso !
\q1 
\v 27 Zitsuka zioso zi ntoto ziela tebuka moyo ;
\q1 Ziela baluka kuidi Yave.
\q1 Batu ba makanda moso bela buongama va ntualꞌaku.
\q1 
\v 28 Bila Kipfumu kidi kuidi Yave ;
\q1 niandi wunyadilanga makanda.
\q1 
\v 29 Batu boso badi kimvuama ba ntoto bela dia
\q1 ayi mamvawu bela buongama.
\q1 Babo bankulukanga mu mbungi-mbungi
\q1 bela komvama va ntualꞌandi ;
\q1 bobo bankambu baka
\q1 bu zingisila luzingu luandi bawu veka.
\q1 
\v 30 Nkuna wela ku nsadila.
\q1 Batu bela samuna mambu matedi Yave kuidi tsungi yinkuiza.
\q1 
\v 31 Bela yolukila busonga buandi
\q1 kuidi batu bobo babutukidi ko.
\q1 Bila niandi wuvanga mambu mama.
\c 23
\cl Minkunga 23
\s1 Pfumu niandi nsungi ama
\d Nkunga Davidi.
\q1 
\v 1 Yave niandi nsungi ama,
\q1 ndilendi kambu kadi kima ko.
\q1 
\v 2 Niandi wukuphundisanga muidi biti binlangu,
\q1 Wukundatanga kuidi minlangu milembama.
\q1 
\v 3 Niandi wunkindisanga muelꞌama.
\q1 Niandi wukundiatisanga mu minsolo misonga
\q1 mu diambu di dizina diandi.
\q1 
\v 4 Ka diambu ko ndilenda diata
\q1 mu ndimba tombi ki lufua,
\q1 buna ndilendi mona mbimbi tsisi ko
\q1 bila ngeyo widi yama.
\q1 Nkawa aku ayi nti aku,
\q1 biawu bi kumbombanga.
\q1 
\v 5 Ngeyo wukubika meza va ntualꞌama
\q1 va meso ma bambeni ziama.
\q1 Ngeyo wuvinda ntuꞌama mafuta
\q1 mbungu ama yilembo sapika.
\q1 
\v 6 Bukiedika, mamboti maku ayi luzolo
\q1 biela kundandakana mu bilumbu bioso bi luzingu luama.
\q1 Ayi ndiela vuanda mu nzo Yave
\q1 mu zithangu zioso.
\c 24
\cl Minkunga 24
\s1 Yave kotidi mu buangu kiandi kinlongo
\d Nkunga Davidi.
\q1 
\v 1 Ntoto widi wu Yave ayi bibioso bidi mu wawu ;
\q1 nza ayi babo banzinganga muawu.
\q1 
\v 2 Bila niandi wutunga ntoto va mbata mimbu
\q1 ayi wukindisa wawu va mbata minlangu.
\q1 
\v 3 Nani wulenda kuma ku mongo wu Yave ?
\q1 Nani wulenda telama va buangu kiandi kinlongo e ?
\q1 
\v 4 Woso mutu widi mioko misukulu
\q1 ayi ntima wuvedila ;
\q1 woso mutu wunkambu vumuna muelꞌandi kuidi bitumba,
\q1 Voti wunkambu levanga ndefi mu mambu ma luvunu.
\q1 
\v 5 Wela tambula lusakumunu luela ba kuidi Yave,
\q1 ayi ndungunu Nzambi yi Mvulusi andi.
\q1 
\v 6 Buawu bobo buididi tsungi yi batu bakuntombanga,
\q1 yi bawu bantombanga zizi kiaku,
\q1 a Nzambi yi Yakobi.
\q1 
\v 7 Luvumbula mintu mieno, beno mielo !
\q1 Luvumbuka beno mielo mikhulu !
\q1 Muingi ntinu wu nkembo kakota.
\q1 
\v 8 Nani ntinu wu nkembo e ?
\q1 Keti Yave, nkua ngolo ayi nkua lulendo !
\q1 Keti Yave, nkua lulendo mu zimvita !
\q1 
\v 9 Luvumbula mintu mieno, beno mielo !
\q1 Luvumbuka beno mielo mikhulu !
\q1 Muingi ntinu wu nkembo kakota.
\q1 
\v 10 Nani wowo ntinu beni wu nkembo e ?
\q1 Keti Yave, pfumu yi minkangu mi masodi.
\q1 Niandi ntinu wu nkembo.
\c 25
\cl Minkunga 25
\s1 Mbonisa nzila yoyi mfueti landakana
\q1 
\v 1 Kuidi ngeyo Yave ndintambika muelꞌama.
\q1 
\v 2 Mu ngeyo ndintulanga diana diama, a Nzambi ama.
\q1 Kadi tala ti ndifuisu tsoni.
\q1 Bika bambeni ziama zibika ku ndunga.
\q1 
\v 3 Kadi mutu wumosi kalendi fua tsoni ko.
\q1 Vayi bela fuisu tsoni,
\q1 bobo bamvakulanga badiawu mu kambu phengomokono,
\q1 
\v 4 Bika wumbonisa zinzila ziaku, a Yave
\q1 bika wundonga minsolo miaku,
\q1 
\v 5 wundiatisa mu kiedika kiaku ayi wundongi.
\q1 Bika ngeyo Nzambi Mvulusi ama.
\q1 Ayi diana diama didi mu ngeyo mu lumbu kimvimba.
\q1 
\v 6 A Yave, tebukila kiadi kiaku kingolo moyo
\q1 ayi luzolo luaku lu ngolo,
\q1 bila bidi mu zithangu zioso.
\q1 
\v 7 Kadi tebukila moyo masumu mama ma kimuana ;
\q1 ayi kadi tebukila moyo zinzila ziama zi matingu.
\q1 Mu diambu di luzolo luaku,
\q1 bika wuthebukila moyo ;
\q1 bila ngeyo widi wumboti, a Yave.
\q1 
\v 8 Yave, widi wumboti ayi wusonga ;
\q1 diawu kanlongisilanga bankua masumu
\q1 mu zinzila ziandi.
\q1 
\v 9 Niandi wudiatisanga batu bakukikululanga mu mambu masonga ;
\q1 ayi wunlonganga nzilꞌandi kuidi bakukikululanga.
\q1 
\v 10 Zinzila zioso zi Yave zidi zi luzolo ayi zikuikama,
\q1 kuidi bawu beti keba zindombolo zi nguizani andi.
\q1 
\v 11 Mu diambu di dizina diaku, a Yave
\q1 bika wundemvukila mu mambimbi mama
\q1 bila madi mawombo.
\q1 
\v 12 Buna nani mutu wunkinzikanga Yave ?
\q1 Yave wela kunlonga nzila yoyi basobula mu diambu diandi.
\q1 
\v 13 Wela viokisa bilumbu biandi mu mamboti ;
\q1 ayi nkunꞌandi wela tambula tsi.
\q1 
\v 14 Yave weti monikisa mansueki mandi kuidi bobo bakunkinzikanga,
\q1 ayi weti kuba zabikisa nguizani andi.
\q1 
\v 15 Thalu ama yidi kuidi Yave
\q1 mu zithangu zioso.
\q1 Bila niandi wela totula malu mama mu dikondi.
\q1 
\v 16 Baluka kuidi minu
\q1 ayi bika nlemvo aku wuba va minu
\q1 bila ndidi minu veka ayi ndidi mu phasi.
\q1 
\v 17 Ziphasi zi ntimꞌama zilembo buelama ;
\q1 bika wuthotula mu ziphasi ziama.
\q1 
\v 18 Tala ziphasi ziama ayi kiadi kiama
\q1 ayi botula masumu mama moso.
\q1 
\v 19 Tala phila bambeni ziama zilembo buelimina
\q1 ayi bandendidi mu kikhenene kimosi kingolo.
\q1 
\v 20 Keba luzingu luama ayi khudi !
\q1 Kadi tala ti ndifua tsoni bila mu ngeyo ndisuamina.
\q1 
\v 21 Bika fuanana ayi lulama bikheba,
\q1 bila mu ngeyo ntudidi diana diama.
\q1 
\v 22 O Nzambi, kula Iseli mu ziphasi ziandi zioso.
\c 26
\cl Minkunga 26
\s1 Bika wundungisa
\d Nkunga Davidi.
\q1 
\v 1 Wundungisa, a Yave, bila ndidiatila mu luzingu lukambulu tsembolo.
\q1 Nditula diana diama mu Yave mu kambu memata.
\q1 
\v 2 A Yave wumfiongunina, wumbeki,
\q1 fiongunina mayindu ma ntimꞌama ayi ntimꞌama.
\q1 
\v 3 Bila luzolo luaku luidi mu zithangu zioso ku ntualꞌama
\q1 ayi ndindiatanga mu zithangu zioso mu kiedika kiaku.
\q1 
\v 4 Ndivuandanga ko va kimosi ayi batu ba luvunu.
\q1 Ndifubakananga ko va kimosi ayi bankua mayuya.
\q1 
\v 5 Ndieti kakumukina lukutukunu lu batu bamvanganga mambimbi.
\q1 Ndivuandanga ko va kimosi ayi batu bambimbi.
\q1 
\v 6 Tsukudi mioko miama
\q1 mu monisa ti ndisi zaba diambu ko,
\q1 ayi ndiela zungidila ntalꞌaku, a Yave !
\q1 
\v 7 Mu yamikina minzitusu miaku mu mbembo yingolo
\q1 ayi mu diambu di yolukila mangitukulu maku moso.
\q1 
\v 8 Ndinzolanga nzo yoyi weti zingila ; a Yave
\q1 buangu kimvuandanga nkemboꞌaku.
\q1 
\v 9 Kadi botula muelꞌama va kimosi
\q1 ayi bankua masumu ayi luzingu luama va kimosi
\q1 ayi bantengulanga menga ma batu,
\q1 
\v 10 mu bobo badi mioko miyuku kubika zikhanu zimbimbi,
\q1 bobo mioko mi lubakala miwedi makaba ma kinsueki.
\q1 
\v 11 Vayi minu, ndieti diatila mu luzingu lukambu tsembolo ;
\q1 bika wukhula ayi wumbona kiadi.
\q1 
\v 12 Malu mama madi va ntoto wuyalumuka
\q1 mu lukhutukunu lunneni, ndiela zitisa Yave.
\c 27
\cl Minkunga 27
\s1 Ndidi mu ndembama vadi Nzambi
\d Nkunga Davidi.
\q1 
\v 1 Yave niandi kiezila kiama ayi phulusu ama.
\q1 Nani ndilenda mona tsisi e ?
\q1 Yave niandi suamunu kingolo mu luzingu luama.
\q1 Nani ndilenda mona boma e ?
\q1 
\v 2 Mu thangu batu bambimbi, bela kuiza ku ntualꞌama
\q1 mu diambu di dia nsuni ama ;
\q1 mu thangu bambeni ziama ayi bobo bandendi bela kuiza kunduanisa,
\q1 bela bumina thutu ayi bela bua.
\q1 
\v 3 Ka diambu ko nkangu wu masodi wunzungididi,
\q1 ntimꞌama wulendi mona tsisi ko ;
\q1 Ka diambu ko mvita yibuidi mu diambu diama,
\q1 ndilendi zimbisa diana ko.
\q1 
\v 4 Kima kimosi ndilomba kuidi Yave,
\q1 kiawu ndintomba :
\q1 Thidi vuanda mu bilumbu bioso bi luzingu luama mu nzo Yave,
\q1 mu diambu nditalanga kitoko ki Yave
\q1 ayi mu diambu ndintombannga mu nzo andi.
\q1 
\v 5 Bila mu lumbu ki ziphasi
\q1 wela ku kheba mu luvovomo mu buangu kiandi kamvuandanga ;
\q1 wela kutsueka ku tsi Nzoꞌandi yi ngoto ;
\q1 wela kuthedimisa va ditadi di ngolo.
\q1 
\v 6 Buna ntu ama wulenda vumuka va yilu bambeni ziama zinzungididi.
\q1 Mu nzoꞌandi yi ngoto, ndiela tambika makaba mu khini.
\q1 Ndiela yimbila ayi bula miziki mu diambu di Yave.
\q1 
\v 7 Wa mbemboꞌama bu ndilembo tedi, a Yave ;
\q1 wumboni kiadi ayi wuphana mvutu.
\q1 
\v 8 Ntimꞌama wutubidi mu diambu diaku :
\q1 “Tomba zizi kiandi.”
\q1 Zizi kiaku, a Yave, kiawu ndiela tomba.
\q1 
\v 9 Kadi kutsueka zizi kiaku.
\q1 Bika kuka kisadi kiaku mu nganzi.
\q1 Ngeyo wuba nsadisi ama
\q1 kadi kumbika, kadi kundiekula.
\q1 A Nzambi yi Mvulusi ama.
\q1 
\v 10 Ka diambu ko dise diama ayi ngudi ama bandiekudi ;
\q1 Yave wela kundiakula.
\q1 
\v 11 Wundonga nzilꞌaku, a Yave
\q1 ayi wundiatisa mu nsolo wu songa
\q1 mu diambu di batu bobo beti kundiamisa.
\q1 
\v 12 Kadi kundiekula mu luzolo lu batu bobo beti kundenda,
\q1 bila bambangi ba luvunu zitelimini
\q1 mu diambu diama,
\q1 ayi zieti yindula matsita.
\q1 
\v 13 Ndisia diana mu diambu diadi :
\q1 Ndiela mona mamboti ma Yave va ntoto wu batu badi moyo.
\q1 
\v 14 Tadidila Yave !
\q1 Wukikindisa ayi bika ntimꞌaku wukinda ;
\q1 ayi tadidila Yave.
\c 28
\cl Minkunga 28
\s1 Yave, vana mvutu
\d Nkunga Davidi.
\q1 
\v 1 Ngeyo ndintela ;
\q1 A Yave, ditadi diama di ngolo,
\q1 kadi kunzibikila dikutu diaku
\q1 Bila ngeyo ba dio sui ;
\q1 buna ndiela dedakana bobo bankulukanga mu dibulu dimula.
\q1 
\v 2 Wa yamikina kuami mu diambu di kiadi
\q1 banga bu ndikutela mu tomba lusadusu
\q1 banga bu ndieti vumuna mioko miama
\q1 ku ndambu buangu kiaku kilutidi kinlongo.
\q1 
\v 3 Kadi kuphitumuna va kimosi ayi batu bambimbi
\q1 ayi batu beti vanga mambimbi ;
\q1 bobo banyolukilanga mambu ma ndembama va kimosi ayi badiawu
\q1 vayi banyindulanga mambimbi mu mintima miawu.
\q1 
\v 4 Wuba vutudila boso buididi mavanga mawu,
\q1 ayi boso buididi mavanga mawu mambimbi.
\q1 Wuba vutudila boso buididi mavanga ma mioko miawu,
\q1 wuba vutudila boso buididi mambu momo bavanga.
\q1 
\v 5 Sumbu batalanga ko mavanga ma Yave,
\q1 ayi mavanga ma mioko miandi,
\q1 wela ku babunga ayi kalendi ku batunga diaka ko.
\q1 
\v 6 Nzitusu wuba kuidi Yave !
\q1 Bila wuwilu yamikina kuama mu diambu di kiadi.
\q1 
\v 7 Yave niandi zingolo ziama ayi nkakuꞌama.
\q1 Ntimꞌama wuntulanga diana mu niandi
\q1 ayi ndisadusu.
\q1 Ntimꞌama weti mona khini yi ngolo
\q1 ayi ndiela kumvutudila matondo mu nkungꞌama.
\q1 
\v 8 Yave niandi ngolo mu diambu di batu bandi.
\q1 Niandi buangu kingolo ki khudulu
\q1 yi mutu andi wowo kadukudila mafuta.
\q1 
\v 9 Vukisa batu baku ayi sakumuna kiuka kiaku.
\q1 Bika wuba nsungi awu ayi wuba nata mu zithangu zioso.
\c 29
\cl Minkunga 29
\s1 Mbembo Yave
\d Nkunga Davidi.
\q1 
\v 1 Luvana kuidi Yave, beno batu badi ngolo ;
\q1 Luvana nkembo kuidi Yave ayi zingolo.
\q1 
\v 2 Luvana nkembo kuidi Yave
\q1 wufuanikini mu dizina diandi.
\q1 Lubuongimina Yave mu kiezila ki kinlongo kiandi.
\q1 
\v 3 Mbembo Yave yidi va mbata minlangu.
\q1 Nzambi yi nkembo wulembo dumi.
\q1 Yave wulembo dumi va mbata minlangu minneni.
\q1 
\v 4 Mbembo Yave yidi yi lulendo,
\q1 mbembo Yave yidi yi nzitusu.
\q1 
\v 5 Mbembo Yave yinkelulanga minti mi sedeli ;
\q1 Yave wunkelulanga minti mi sedeli midi mu Libani mu bitini.
\q1 
\v 6 Wunzamisanga Libani banga muana wungombi ;
\q1 Silioni banga muana wu phakasa.
\q1 
\v 7 Mbembo Yave yilembo totula minlaki mi mbazu.
\q1 
\v 8 Mbembo Yave yintitisanga dikanga.
\q1 Yave wuntitisanga dikanga di Kadesi.
\q1 
\v 9 Mbembo Yave yimbutisanga minsuma ;
\q1 yeti vambisa minsitu.
\q1 Mu Nzoꞌandi, bima bioso bilembo yamikina :
\q1 “nkembo”.
\q1 
\v 10 Yave wumvuandanga va kundu ki kipfumu va mbata khuka minlangu ;
\q1 Yave weti vuanda banga ntinu mu zithangu zioso.
\q1 
\v 11 Yave weti vana batu bandi zingolo ;
\q1 Yave weti sakumuna batu bandi mu ndembama.
\c 30
\cl Minkunga 30
\s1 Ngeyo wuphutudila luzingu
\d Nkunga Davidi kayimbidila mu mbiekolo nzo Nzambi.
\q1 
\v 1 Ndiela kuyayisa, a Yave
\q1 bila ngeyo wuthotula mu dibulu didi thipula
\q1 Wusia tia ko ti bambeni ziama zimona khini
\q1 mu diambu diama.
\q1 
\v 2 A Yave, Nzambi ama, ngeyo nditela mu diambu di lusadusu
\q1 ayi ngeyo wumbelusa.
\q1 
\v 3 Yave, ngeyo wuthotula mu tsi bafua,
\q1 ngeyo wuthanina muingi ndibika tibuka mu dibulu.
\q1 
\v 4 Luyimbidila Yave beno banlongo bandi ;
\q1 Zitisanu dizina diandi di nlongo.
\q1 
\v 5 Bila nganzi andi yizingilanga mu ndambu thangu kaka.
\q1 Vayi nlemvo andi wunzinganga mu zithangu zioso ;
\q1 bidilu bilenda kuiza va builu ;
\q1 vayi khini yinkuizanga va nsuka.
\q1 
\v 6 Bu ndiba mu luvovomo, ndituba :
\q1 “Ndilendi nikunu ko”
\q1 
\v 7 A Yave, mu nlemvo aku,
\q1 ngeyo wukindisa mongoꞌama…
\q1 vayi bu wusueka zizi kiaku buna minu ndimona boma.
\q1 
\v 8 Kuidi ngeyo, a Yave, nditela mbila.
\q1 Kuidi Yave ndiyamikina mu diambu di lusadusu
\q1 
\v 9 “Ndandu mbi yidi mu mbivusu ama, minu kuluka mu dibulu e ?
\q1 Mbungi-mbungi yilenda kuzitisa e ?
\q1 Voti yilenda yamikina kikhuikizi kiaku e ?
\q1 
\v 10 A Yave wa, wumboni kiadi,
\q1 A yave, bika wuba lusadusu luama.”
\q1 
\v 11 Ngeyo wuviakisa bidilu biama makinu,
\q1 wunianguna tsaku ama ayi wuphuika khini.
\q1 
\v 12 Muingi ntimꞌama wuyimbidila minkunga
\q1 ayi wubika ba dio sui.
\q1 A Yave, Nzambi ama, ndiela ku vutudilanga mu zithangu zioso.
\c 31
\cl Minkunga 31
\s1 Nditula diana diama mu Yave
\d Nkunga Davidi kuidi pfumu minyimbidi.
\q1 
\v 1 Kuidi ngeyo, Yave ndintombila suamunu ;
\q1 kadi khumbu yimosi ndifua tsoni ;
\q1 wukhula mu busonga buaku.
\q1 
\v 2 Yinika dikutu diaku kuidi minu,
\q1 Yiza nsualu, mu kukhula !
\q1 Kuidi minu, bika wuba ditadi diama dingolo disuamina,
\q1 suamunu kingolo, mu diambu di kuphukisa.
\q1 
\v 3 Sumbu didi ti ngeyo ditadi diama dingolo
\q1 ayi suamunu kiama kingolo.
\q1 Mu diambu di dizina diaku
\q1 bika wuthuadisa ayi wundiatisa.
\q1 
\v 4 Bika wuthotula mu ntambu wu bathambila,
\q1 bila ngeyo suamunu kiama.
\q1 
\v 5 Mu mioko miaku ndintambika pheve ama ;
\q1 Wukhula, a Yave, ngeyo Nzambi yi kiedika.
\q1 
\v 6 Ndieti lenda bobo bansingiminanga mu bitumba biphamba.
\q1 Vayi minu diana diama didi mu Yave.
\q1 
\v 7 Ndiela mona khini ayi ndiela yangalala
\q1 mu diambu di luzolo luaku ;
\q1 bila wumona ziphasi ziama ;
\q1 wuzaba kiadi ki muelꞌama.
\q1 
\v 8 Ayi wusia ku ndiekula ko mu mioko mi mbeni.
\q1 Vayi ngeyo malu mama va buangu ki yalumuka.
\q1 
\v 9 Bika wumbona kiadi, a Yave,
\q1 bila mu ziphasi ndidi.
\q1 Meso mama ; mabividi mu diambu di maniongo
\q1 muelꞌama ayi nitu ama bibividi mu diambu di phasi
\q1 
\v 10 Luzingu luama lulembo suki mu kiadi
\q1 ayi mimvu miama milembo suki mu diambu di kunga.
\q1 Zingolo ziama zilembo suki mu diambu di ziphasi ziama,
\q1 ayi mimvesi miama milembo lebakana ngolo.
\q1 
\v 11 Mu diambu di bambeni ziama zioso,
\q1 ndiyikidi bila ki nlenzo kuidi bobo bafikimini yami
\q1 ayi bila ki tsisi yiwombo mu diambu di batu bobo bazabini yama.
\q1 Bobo bakumbona mu nzila balembo tini va ndidi.
\q1 
\v 12 Banzimbikini banga ti ndifua
\q1 Ndidi banga nzungu tuma yibudika.
\q1 
\v 13 Bila ndilembo wi balembo thubidila buwombo ku ndambu
\q1 ayi tsisi yingolo mu zindambu zioso
\q1 balembo kutakananga va kimosi mu diambu banduanisa ;
\q1 balembo yendila luzingu luama manenga.
\q1 
\v 14 Vayi minu, mu ngeyo ndintula diana diama, a Yave,
\q1 Ndieti tuba : “Ngeyo Nzambi ama.”
\q1 
\v 15 Bilumbu biama bioso bidi mu mioko miaku ;
\q1 wukhula mu mioko mi bambeni ziama
\q1 ayi mu mioko mi bobo balembo ndandakana.
\q1 
\v 16 Bika zizi kiaku kikienzukila kisadi kiaku ;
\q1 wuphukisa mu diambu di luzolo luaku lungolo.
\q1 
\v 17 Kadi tala ti ndifua tsoni, a Yave,
\q1 bila kuidi ngeyo ndiyamikina.
\q1 Vayi bika batu bambimbi bafua tsoni !
\q1 Bika baba dio sui ku tsi bafua !
\q1 
\v 18 Bika bididi bintotulanga luvunu biba dio sui ;
\q1 mu luniemo ayi mu mvuezolo beti yolukila
\q1 mu luyanu kuidi mutu wusonga.
\q1 
\v 19 A phila, mamboti maku madidi manneni ;
\q1 momo wulundila bobo beti kukinzika ;
\q1 momo wuvangila bobo beti tomba suamunu
\q1 kuidi ngeyo va ntuala batu.
\q1 
\v 20 Va ntuala meso maku, ngeyo weti kuba suekanga
\q1 mu diambu di mambimbi mayindulanga batu
\q1 ku buangu kioki wumvuandanga, ngeyo weti kuba keba mu luvovomo
\q1 mu ludimi lueti funda.
\q1 
\v 21 Nzitusu wuba kuidi Yave
\q1 Bila niandi wumbonisini luzolo luandi lungolo
\q1 mu thangu ndiba mu divula dizungulu kuidi masodi.
\q1 
\v 22 Mu boma buama minu ndituba : “Minu ndivengumunu thama va ntualꞌaku.”
\q1 Muaki ngeyo wuwa yamikina kuama mu diambu di kiadi
\q1 mu thangu nditela mu diambu di lusadusu.
\q1 
\v 23 Bika luzola Yave beno banlongo bandi boso.
\q1 Yave wunkebanga minkhuikizi
\q1 Vayi wumvutudilanga mu bufuana
\q1 bobo badi luniemo.
\q1 
\v 24 Lukikindisa ayi bika luba bukhafi mu mintima mieno ;
\q1 beno boso bobo luntulanga diana dieno mu Yave.
\c 32
\cl Minkunga 32
\s1 Khini yidi mu lemvokolo
\d Nkunga Davidi.
\q1 
\v 1 Lusakumunu kuidi mutu wowo wulemvokolo nzimbalꞌandi ;
\q1 masumu mandi mafukulu.
\q1 
\v 2 Lusakumunu kuidi mutu wowo Yave kankambu
\q1 ntangila disumu diandi,
\q1 ayi kambulu bukhita mu pheve andi.
\q1 
\v 3 Bu ndiba dio sui,
\q1 mimvesi miama milebakana mu kunga ku ndiba
\q1 nkunga mu lumbu kimvimba.
\q1 
\v 4 Bila muini ayi builu koko kuaku ziku kuba va minu.
\q1 Zingolo ziama zisukidi
\q1 banga mu thangu yi muini wu ngolo.
\q1 
\v 5 Buna ndizabikisa disumu diama,
\q1 ndisia fuka mambimbi mama ko.
\q1 Ndituba : “Ndiela lomba nlemvo mu zinzimbala ziama kuidi Yave.”
\q1 Buna ngeyo wulemvukila mambimbi ma disumu diama.
\q1 
\v 6 Buna diawu bika woso mutu wunkinzikanga mambu maku,
\q1 wela kusambila mu thangu yoyi kalenda kubakula.
\q1 Bukiedika mu thangu yi khuka nlangu yingolo
\q1 milendi kunlalumuna ko.
\q1 
\v 7 Ngeyo buangu kiama kieti kutsueka ;
\q1 ngeyo weti kukheba mu ziphasi.
\q1 Ngeyo wukunzungidilanga mu minkunga mi khudulu.
\q1 
\v 8 “Ndiela kumonisa ayi kulonga nzila yoyi fueti diatila,
\q1 ndiela kuvana ndongi ayi thaluꞌama
\q1 yela ba vadi ngeyo.
\q1 
\v 9 Kadi ba banga phunda
\q1 voti banga bulu kioki bantedilanga ‘mule’ ;
\q1 bibulu bikondolo diela,
\q1 vayi biobi binkangungu nsinga ayi sengo mu munu
\q1 bila nganu bilenda fikama va widi.”
\q1 
\v 10 Mabienga mawombo madi mu diambu di mutu wumbimbi ;
\q1 vayi luzolo lu ngolo lu ma Yave lunzungidilanga mutu wowo
\q1 wuntulanga diana diandi mu niandi.
\q1 
\v 11 Monanu khini
\q1 ayi luyangadala mu Yave beno basonga.
\q1 Luyimbila, beno boso luidi balulama mu mintima.
\c 33
\cl Minkunga 33
\s1 Nzambi niandi mvangi ayi Mvulusi
\q1 
\v 1 Luyimbila Yave mu khini beno basonga
\q1 Bufueni ti mutu widi ntima lulama kanzitisa.
\q1 
\v 2 Luzitisa Yave mu ngitala,
\q1 Lusika miziki mu diambu diandi
\q1 mu siku kidi dikumi di zitsinga.
\q1 
\v 3 Lunyimbidila nkunga wumona ;
\q1 Lusika bumboti ayi luyamikina mu diambu di khini.
\q1 
\v 4 Bila mambu ma Yave madi masonga ayi makiedika.
\q1 Niandi widi kikhuikizi mu mamoso keti vanga.
\q1 
\v 5 Yave wunzolanga bululama ayi busonga
\q1 Ntoto widi wuwala luzolo luandi lungolo.
\q1 
\v 6 Diyilu divangimina mu mambu ma Yave.
\q1 Nkangu andi woso wu bima,
\q1 bivangimina mu phemo yi munu andi.
\q1 
\v 7 Wunkupikisanga minlangu mi mbu mu khati mvungu,
\q1 ayi wuntulanga biza mu bilundulu.
\q1 
\v 8 Bika ntoto wumvimba wukinzika Yave.
\q1 Bika batu boso ba ntoto bantitila.
\q1 
\v 9 Bila bu katuba, buna diawu divangama,
\q1 bu katuma, buna diawu ditelama dio ngui.
\q1 
\v 10 Yave wumvunzanga zikhanu zi makanda
\q1 wumvondanga mayindu ma batu.
\q1 
\v 11 Vayi zikhanu zi Yave zinzingilanga mu zithangu zioso
\q1 mayindu ma ntimꞌandi manzingilanga
\q1 mu tsungi ka tsungi.
\q1 
\v 12 Lusakumunu luidi kuidi dikanda di batu
\q1 diodi Nzambi kadidi Yave,
\q1 batu bobo kasobula mu diambu di kiuka kiandi.
\q1 
\v 13 Tona ku diyilu, Yave wulembo tadi ;
\q1 wulembo moni bana boso ba batu.
\q1 
\v 14 Tona ku buangu kioki keti vuanda,
\q1 Yave wulembo tadi batu banzingilanga va ntoto.
\q1 
\v 15 Niandi wunkubikanga mintima mi batu boso,
\q1 Niandi wuntalanga mavanga mawu moso beti vanga.
\q1 
\v 16 Kuisi kadi ntinu wumosi ko wulenda vuka
\q1 mu diambu di nkangu andi wunneni wu masodi ;
\q1 kuisi kadi mutu wu lulendo ko wulenda tina
\q1 mu diambu di zingolo ziandi ziwombo ;
\q1 
\v 17 Phunda yidi diana di phamba mu diambu di khudulu ;
\q1 Ka diambu ko zingolo ziandi zinneni, yilendi vukisa ko.
\q1 
\v 18 Vayi meso ma Yave madi kuidi bawu beti kunkinzika ;
\q1 kuidi bawu bantulanga diana mu luzolo luandi lungolo,
\q1 
\v 19 mu diambu di kuba kula mu lufua
\q1 ayi mu diambu di kuba keba bamoyo
\q1 mu thangu yi kanda.
\q1 
\v 20 Tulembo vingila mu diana kuidi Yave.
\q1 Niandi nsadisi eto ayi nkaku eto.
\q1 
\v 21 Mu niandi mintima mieto mieti mona khini
\q1 bila tutula diana dieto mu dizina diandi di nlongo,
\q1 
\v 22 Bika luzolo luaku lu ngolo luba va beto boso, a Yave
\q1 bu tueti tula diana dieto mu ngeyo.
\c 34
\cl Minkunga 34
\s1 Pfumu wukhula
\d Nkunga Davidi mu thangu kavuna lawuka va meso ma Abimeleki bu kankuka ayi Davidi wuyenda.
\q1 
\v 1 Ndiela yayisa Yave mu zithangu zioso ;
\q1 Nzitusu andi wela ba mu bididi biama mu kadika thangu.
\q1 
\v 2 Muelꞌama wela kiniemisa mu Yave.
\q1 Bika badi mu phasi bawa ayi bamona khini.
\q1 
\v 3 Kembisanu Yave va kimosi ayi minu,
\q1 bika tuyayisanu dizina diandi va kimosi,
\q1 
\v 4 Nditomba Yave, niandi wuphana mvutu
\q1 ayi niandi wukhula mu zitsisi ziama zioso.
\q1 
\v 5 Batu bobo batala kuidi niandi bakienzulu
\q1 ayi bizizi biawu bilendi mona tsoni nkutu ko.
\q1 
\v 6 Nsukami wawu wutela ;
\q1 ayi Yave wunwa ayi wuphukisa mu ziphasi ziandi zioso.
\q1 
\v 7 Mbasi Yave yinzungidilanga bobo bankinzikanga Yave
\q1 ayi wukubakulanga.
\q1 
\v 8 Lubimba ayi lutala ti Yave widi wumboti ;
\q1 Lusakumunu luidi kuidi mutu wowo wuntombanga suamunu mu niandi.
\q1 
\v 9 Lukinzika Yave beno banlongo bandi.
\q1 Bila bobo beti kunkinzika, balendi kambu kima ko.
\q1 
\v 10 Zikhosi zimvonganga
\q1 ayi zimfuanga nzala vayi bobo bantombanga Yave
\q1 balendi kambu kima ko.
\q1 
\v 11 Yizanu bana bama, lungua.
\q1 Ndiela ku lulonga buevi bu kinzikilanga Yave.
\q1 
\v 12 Nani mutu mu beno wunzolanga luzingu,
\q1 ayi tidi mona bilumbu biwombo bi mboti
\q1 
\v 13 Vengumuna ludimi luaku mu mambu mambimbi,
\q1 ayi bididi biaku mu tuba mambu ma luvunu.
\q1 
\v 14 Botuka mu mambimbi vayi vanga mamboti.
\q1 Tomba ndembama ayi landakana yawu.
\q1 
\v 15 Meso ma Yave mantalanga basonga
\q1 ayi makutu mandi madi mazibuka bu beti yamikina.
\q1 
\v 16 Yave wunsuekanga zizi kiandi
\q1 kuidi batu bamvanganga mambimbi
\q1 mu diambu babika buela tebukulu moyo va ntoto.
\q1 
\v 17 Batu basonga banyamikinanga ayi
\q1 Yave weti kuba wanga ayi wukubakulanga mu ziphasi ziawu zioso.
\q1 
\v 18 Yave widi wufikama vadi batu bobo
\q1 badi mintima mi kofakana.
\q1 Ayi wumvukisanga bobo badi pheve yidi mu kiadi kingolo.
\q1 
\v 19 Mutu wusonga wumbuilungu ziphasi ziwombo
\q1 vayi Yave wunkukulanga mu zizioso.
\q1 
\v 20 Niandi wunkebanga mimvesi miandi mioso
\q1 kadi wumosi wulendi keluka ko.
\q1 
\v 21 Mambu mambimbi mela vonda mutu wumbimbi ;
\q1 bobo beti lenda nkua busonga
\q1 bela bedoso.
\q1 
\v 22 Yave wunkulanga bisadi biandi,
\q1 ayi kadi wumosi mu babo bobo bansuaminanga mu niandi
\q1 kalendi bedoso ko.
\c 35
\cl Minkunga 35
\s1 Pfumu wunnuaninanga batu balebakana
\d Nkunga Davidi.
\q1 
\v 1 Zonzisa, a Yave, bobo balembo nzonzisa.
\q1 Nuanisa bobo balembo nduanisa,
\q1 
\v 2 simba nkaku wu fioti ayi wunneni
\q1 telama ayi yiza wutsadisa.
\q1 
\v 3 Bonga dionga difioti ayi dinneni ayi kaka nzila yi bobo balembo ndandakana
\q1 kamba muelꞌama :
\q1 “Minu ndidi phulusu aku.”
\q1 
\v 4 Bika batu babo bantombanga luzingu luama
\q1 baba dio kombolo ayi bafua tsoni.
\q1 Bika bobo bantombanga mabienga mama
\q1 bavutuka ku mbusa ayi baba mu divuda ;
\q1 
\v 5 bika baba banga mavevolo mamvevomono kuidi phemo
\q1 va kimosi ayi mbasi yi Yave yi bakuka.
\q1 
\v 6 Bika nsolo awu wuba tombi ayi ndelo.
\q1 Va kimosi ayi mbasi Yave yi balandakana.
\q1 
\v 7 Bila bathambididi dikondi diawu mu kambu bila ;
\q1 mu kambu kadi bila bakabidi dibulu dinneni
\q1 mu diambu diama.
\q1 
\v 8 Bika mbivusulu yi babuila mu kinzimbukila
\q1 ayi bika dikondi diodi batamba bawu veka dibabuila ;
\q1 bika babua mu dibulu, mu diambu di mbivusulu awu.
\q1 
\v 9 Buna muelꞌama wela mona khini mu Yave
\q1 ayi wela yangalala mu phulusu andi.
\q1 
\v 10 Buna nitu ama yimvimba yela yamikina :
\q1 “nani widi banga ngeyo Yave ?
\q1 Ngeyo weti kula nsukami mu mioko mi mutu wunlutidi zingolo ;
\q1 nsukami ayi nkua mabienga mu mioko mi mutu wowo wulembo bayibi.”
\q1 
\v 11 Bambangi bakondolo kiadi zilembo telama ;
\q1 zilembo ndiuvula buivu mu mambu ma khambulu kuama zaba.
\q1 
\v 12 Bamvutudidi mambimbi mu mamboti.
\q1 Bayekudi muelꞌama wawu veka.
\q1 
\v 13 Vayi bu baba mu kimbevo ; minu ndivuata tsaku\f + \fr 35.13 \ft Vuata tsaku voti vuata kaniki.\f*.
\q1 Ndikikulula mu kukifuisa nzala mu diambu di lusambulu
\q1 Thangu zitsambulu ziama zivutuka kuidi minu mu kambu mvutu.
\q1 
\v 14 Ndibedi diatanga ku tsi kiadi
\q1 banga mu diambu di nkundi ama voti khomba ama.
\q1 Ndibedi komvikanga ntu ku tsi mu diambu di kiadi
\q1 banga minu ndindila ngudi ama.
\q1 
\v 15 Minu bu ndibumina thutu,
\q1 bakutakana va kimosi mu khini.
\q1 Batu bakutakana mu diambu di kunduanisa
\q1 minu mu kambu zaba diambu.
\q1 Bawu bamfinga mu kambu vonga.
\q1 
\v 16 Banga batu bobo bankinzikanga ko mambu ma Nzambi,
\q1 balembo tsekinina mu bu mbimbi
\q1 balembo khuetila meso.
\q1 
\v 17 A Yave, nate thangu mbi wela kumatadidilanga e ?
\q1 Kula luzingu luama mu mbivusu awu ;
\q1 kula luzingu luama luthalu mu zikhosi zioso.
\q1 
\v 18 Ndiela kuvutudila matondo mu lukutukunu lunneni ;
\q1 va khatitsika batu bawombo ndiela kuzitisa.
\q1 
\v 19 Kadi tala ti bamona khini mu diambu diama,
\q1 bobo badi bambeni ziama mu kambu bila ;
\q1 Kadi tala ti bobo bakundenganga mu kambu bila,
\q1 bandiengudila meso mu bumbimbi.
\q1 
\v 20 Bayolukilanga ndembama ko ;
\q1 vayi banyindulanga mambu ma luvunu
\q1 mu diambu di vunina bobo banzingilanga mu ndembama mu tsi.
\q1 
\v 21 Balembo nzibudila miunu
\q1 ayi balembo tubi :
\q1 “A, a… mu meso meto veka tumueni mawu.”
\q1 
\v 22 A Yave, ngeyo wumona mambu momo
\q1 bika ba dio sui,
\q1 kadi kuthatukila, a Yave,
\q1 
\v 23 kotuka ayi telama mu
\q1 zonzika, Nzambi ama ayi Yave ama.
\q1 
\v 24 Wundungisa boso buididi busonga buaku,
\q1 a Yave, Nzambi ama ;
\q1 ayi kadi tala ti bamona khini mu diambu diama.
\q1 
\v 25 Kadi kuba bika bayindula :
\q1 “A, a … buawu bobo tutididi.”
\q1 Voti babika tuba : “beto tumminini.”
\q1 
\v 26 Bika babo bammonanga khini mu ziphasi ziama,
\q1 bafua tsoni ayi baba dio kombolo
\q1 Bika bobo balembo kukiniemisanga bawu veka mu diambu diama
\q1 bafua tsoni ayi baba dio kombolo.
\q1 
\v 27 Bika bobo bamonanga khini mu ndungunu ama
\q1 bamonanga khini ayi bayangadala
\q1 bika batuba mu zithangu zioso :
\q1 “Bika Yave kayayusu, niandi wummonanga khini
\q1 mu mamboti ma kisadi kiandi.”
\q1 
\v 28 Buna ludimi luama luela yolukila busonga buaku ;
\q1 ayi minzitusu miaku mu lumbu kimvimba.
\c 36
\cl Minkunga 36
\s1 Mamboti ma Pfumu
\d Nkunga Davidi, kisadi ki Yave, kuidi pfumu minyimbidi.
\q1 
\v 1 Mambu ma Nzambi madi mu ntimꞌama
\q1 Mu mambu matedi disumu di mutu wumbimbi :
\q1 kuisi ko mambu ma kinzikila Nzambi va meso mandi.
\q1 
\v 2 Bila va meso mandi veka,
\q1 weti kukiniemisa buwombo mu bakula voti lenda masumu mandi.
\q1 
\v 3 Mambu ma munuꞌandi madi mambimbi ayi ma luvunu.
\q1 Wulembo kuandi buela ba nkua nduenga
\q1 ayi bueba vanga mamboti.
\q1 
\v 4 Bu kadi va mbukꞌandi,
\q1 wunyindulanga mambu mambimbi.
\q1 Weti kukiyekula niandi veka mu nzila yi masumu
\q1 kalozanga ko mambu mambimbi.
\q1 
\v 5 Luzolo luaku, a Yave, lueti tula nate ku diyilu
\q1 kikhuikizi kiaku nate mu matuti
\q1 
\v 6 Busonga buaku buidi banga miongo minda ;
\q1 zinzengolo ziaku zidi banga dibulu dinneni.
\q1 O Yave, ngeyo wunkebanga mutu ayi bulu.
\q1 
\v 7 Tala phila luzolo luaku lu ngolo lukambu thalu !
\q1 Luidi luzangulu ayi lukululu va khatitsika batu
\q1 bobo bansuaminanga ku tsi phozi yi mavevi maku.
\q1 
\v 8 Beti tula minyengo mu wombo di bima bi nzo aku
\q1 ayi ngeyo wukubanuikinanga mu nlangu
\q1 wu makhini maku.
\q1 
\v 9 Bila kuidi ngeyo kuidi tho yi luzingu.
\q1 Mu kiezila kiaku, tulembo moni kiezila.
\q1 
\v 10 Landakana vanga luzolo luaku kuidi bawu bazebi
\q1 ayi busonga buaku kuidi bawu badi mintima mi lulama.
\q1 
\v 11 Bika kulu ku nkua luniemo kubika kumbakidila ;
\q1 voti bika koko ku mutu wumbimbi kubika kuthinisa thama.
\q1 
\v 12 Tala phila yilembo buila bisadi bi mambu mambimbi ;
\q1 balumbulu va tsi ayi balendi buela telama ko.
\c 37
\cl Minkunga 37
\s1 Khindusulu yi mutu wusonga
\d Nkunga Davidi.
\q1 
\v 1 Kadi fuemina batu bamvanganga mambimbi.
\q1 Kadi monanga kikhenene bobo bamvanganga mambimbi.
\q1 
\v 2 Bila banga biti, bela yuma mu nsualu ;
\q1 banga biti bi nlangu bela lebuka mu nsualu.
\q1 
\v 3 Tula diana diaku mu Yave ayi vanga mamboti ;
\q1 buna wela vuanda mu tsi ayi wela zingila mu ndembama.
\q1 
\v 4 Mona khini mu Yave
\q1 buna wela kuvana mambu mantomba ntimꞌaku.
\q1 
\v 5 Yekula nzilꞌaku kuidi Yave,
\q1 Tula diana diaku mu niandi,
\q1 buna wela vanga diambu diadi :
\q1 
\v 6 Wela kienzula busonga buaku banga kiezila ki khiesa buisi
\q1 nzengolo yi diambu diaku banga thangu va midi.
\q1 
\v 7 Ba dio sui va ntuala Yave,
\q1 ayi wuntadidila mu mvibudulu
\q1 kadi fuemina batu bu balembo
\q1 moni mamboti mu nzilꞌandi ;
\q1 ayi kadi fuemina batu balembo sadila
\q1 makani mawu mambimbi.
\q1 
\v 8 Bika buela fuema ayi zimbakana nganzi ;
\q1 kadi fuema bila dieti nata kaka ku mambu mambimbi.
\q1 
\v 9 Bila bobo bamvanganga mambimbi bela lalukusu ;
\q1 vayi bobo bantulanga diana diawu mu Yave bela tambula tsi banga kiuka.
\q1 
\v 10 Fioti kuandi fisiedi, buna batu bambimbi balendi buela monika ko ;
\q1 buna wela tala buangu kibabedi vayi bela va ba ko.
\q1 
\v 11 Vayi minlembami miela tambula tsi banga kiuka
\q1 ayi miela monanga khini mu ndembama yiwombo.
\q1 
\v 12 Batu bambimbi bamfielanga batu basonga
\q1 ayi beti kuba kuetila meno.
\q1 
\v 13 Yave wunsevanga mutu wumbimbi ;
\q1 bila zebi ti lumbu kiandi kalembo yizi.
\q1 
\v 14 Batu bambimbi bavola bisabala
\q1 ayi baleka mimbasa mu diambu di vonda
\q1 nkua kiadi ayi mutu wusukama ;
\q1 mu diambu di zenga bobo
\q1 bandiatanga mu nzila yi lulama.
\q1 
\v 15 Bisabala biawu biela kota mu mintima miawu veka ;
\q1 ayi mimbasa miawu miela kelulu.
\q1 
\v 16 Baka ku fioti ku mutu wusonga kulutidi
\q1 ayi baka kuphuedi ku wombo di batu bambimbi.
\q1 
\v 17 Bila lulendo lu batu bambimbi luela kelulu,
\q1 vayi Yave wunsimbanga batu basonga.
\q1 
\v 18 Bilumbu bi batu bakambulu tsembolo bizabikini kuidi Yave
\q1 ayi kiuka kiawu kizingilanga
\q1 mu zithangu zioso.
\q1 
\v 19 Mu thangu yi ziphasi, balendi yuma ko
\q1 mu lumbu ki nzala, bawu bela mona khini yiwombo.
\q1 
\v 20 Vayi batu bambimbi bela bungana.
\q1 Bambeni zi Yave, badi banga kitoko ki zitsola,
\q1 ziela lalakana ; ziela lalakana banga muisi.
\q1 
\v 21 Mutu wumbimbi wundevanga vayi kavutulanga ko ;
\q1 Vayi mutu wusonga weti kabula mu luzolo lu ntima.
\q1 
\v 22 Bobo Yave kasakumuna
\q1 bela tambula tsi banga kiuka,
\q1 vayi bobo kasinga bela lalukusu.
\q1 
\v 23 Enati Yave mueni khini mu nzila yi mutu
\q1 buna wunkindisanga zithambi zi mutu beni.
\q1 
\v 24 Ka diambu ko bumini thutu ; kalendi bua ko ;
\q1 bila Yave wukunsimbidilanga mu koko kuandi.
\q1 
\v 25 Ndiba ditoko, buabu ndieka nunu ;
\q1 vayi ndisia mona ko mutu wusonga wuyekolo
\q1 voti ndisia mona ko bana bandi balomba dipha.
\q1 
\v 26 Mu zithangu zioso, beti kabula ayi vananga mu luzolo
\q1 Bana bawu bela sakumunu.
\q1 
\v 27 Tina mambimbi ; vanga mamboti
\q1 buna wela vuanda mu tsi mu zithangu zioso.
\q1 
\v 28 Bila Yave wunzolanga mambu masonga
\q1 ayi kalendi zimbakana ko mikhuikizi miandi.
\q1 Bela kebungu mu zithangu zioso
\q1 vayi nkuna wu batu bambimbi wela lalukusu.
\q1 
\v 29 Batu basonga bela tambula tsi banga kiuka
\q1 ayi bela mukalanga mu zithangu zioso.
\q1 
\v 30 Munu wu mutu wusonga wuntotulanga mambu ma nduenga
\q1 ayi ludimi luandi luntubanga mambu ma lulama.
\q1 
\v 31 Mina mi Nzambi andi midi mu ntimꞌandi ;
\q1 Malu mandi malendi sialumuka ko.
\q1 
\v 32 Mutu wumbimbi wumfielanga mutu wusonga
\q1 ayi wuntombanga kumvondisa.
\q1 
\v 33 Yave kalendi yekula ko basonga mu lulendo lu batu bambimbi
\q1 voti kuba bika babedoso bu balembo sambusu.
\q1 
\v 34 Tadidila Yave,
\q1 ayi keba nzilꞌandi.
\q1 Buna wela kuyayisa mu diambu wutambula tsi banga kiuka ;
\q1 thangu batu bambimbi bela lalukusu,
\q1 ngeyo wela bumona.
\q1 
\v 35 Ndimona mutu wumbimbi, ayi mutu kondolo kiadi,
\q1 wuyunduka bumboti banga nti wu nlangu
\q1 mu ntoto wowo kabutukila.
\q1 
\v 36 Niandi wuvioka, nsualu ayi kasiedi ko.
\q1 Ndintombidi ngolo vayi kasia monika ko.
\q1 
\v 37 Fiongunina mutu kambulu tsembolo
\q1 ayi tala tala mutu wu lulama buna wela mona ti tsukulu
\q1 yi mutu wowo yidi tsukulu yi ndembama.
\q1 
\v 38 Vayi bankua masumu boso bela vondo va kimosi
\q1 tsukulu yi batu bambimbi yela ba lalukusu.
\q1 
\v 39 Phulusu yi batu basonga kuidi Yave yeti ba.
\q1 Niandi zingolo ziawu mu thangu yi ziphasi.
\q1 
\v 40 Yave wukubasadisanga ayi wukubakulanga ;
\q1 wukubakulanga mu batu bambimbi
\q1 ayi wukubavukisanga bila mu niandi
\q1 beti suamina.
\c 38
\cl Minkunga 38
\s1 Wuyamusu kuidi kimbevo ayi masumu
\d Nkunga Davidi mu diambu di thebokolo moyo.
\q1 
\v 1 A Yave, kadi kuthemima ku tsi nganzi aku
\q1 voti kadi kuphana thumbudulu ku tsi nganzi aku yi kikhesa.
\q1 
\v 2 Bila madionga maku mathobudi
\q1 ayi koko kuaku kumbetidi.
\q1 
\v 3 Mu diambu di nganzi aku yi kikhesa, buvini buisi ko mu nitu ama.
\q1 Mimvesi miama misiedi ko buvini
\q1 mu diambu di masumu mama.
\q1 
\v 4 Zinzimbala ziama zimfietikisidi ngolo
\q1 banga mfuna widi zitu kiwombo ;
\q1 madidi ngolo zitu mu diambu diama
\q1 banga mfuna wu ngolo.
\q1 
\v 5 Ziphuta ziama zilembo bodi ngolo yiwombo
\q1 ayi zilembo yizi tsudi yiwombo
\q1 mu diambu di buvulu buama bu masumu.
\q1 
\v 6 Ndidi wukomvama ngolo ayi khulukidi nate va tsi ;
\q1 Lumbu ki mvimba mu kiadi ndieti diatila.
\q1 
\v 7 Bila ziphasi zingolo zidi mu luketo luama,
\q1 buvini buisi ko mu nitu ama.
\q1 
\v 8 Ndidi wuvonga ngolo ayi ndidi wukosakana mvimba.
\q1 Ndilembo kungi mu diambu di ziphasi zi ntima.
\q1 
\v 9 Zitsatu ziama zioso zidi dio yambi va ntualꞌaku, a Yave,
\q1 ayi vumina kuama kuisi ko kusuama kuidi ngeyo.
\q1 
\v 10 Ntimꞌama wulembo sadi ngolo
\q1 ayi zingolo ziama zimeni ;
\q1 kiezila kibotukidi mu meso mama.
\q1 
\v 11 Bakundi bama ayi bobo bankibanga yama
\q1 bathinini mu diambu di ziphuta ziama ;
\q1 bobo bafikasana yama thama batelimini.
\q1 
\v 12 Bobo bantomba luzingu luama balembo mintambu miawu
\q1 bobo bantomba kuphanga mbimbi
\q1 balembo yolukila mbivusu ama ;
\q1 Mu lumbu kimvimba balembo kubika mambu ma luvunu.
\q1 
\v 13 Minu, ndieka banga mutu wufua matu,
\q1 wunkambu wa ; banga dibaba dikambu zibula munu andi.
\q1 
\v 14 Ndieka banga mutu wowo wu nkambu wa
\q1 mutu wowo munu wunkambu baka bu vutudila mvutu.
\q1 
\v 15 Ngeyo ndieti tadidila, a Yave,
\q1 wela vutula mvutu, a Yave Nzambi ama.
\q1 
\v 16 Bila ndituba : “kadi tala ti bamona khini
\q1 voti bakiyayisa bawu veka mu diambu diama.
\q1 Kulu kuama bu kusialumukini.”
\q1 
\v 17 Bila nduka bua ndieka
\q1 ayi ziphasi ziama zidi kaka mu minu.
\q1 
\v 18 Ndimfunda mbimbi ama.
\q1 Ndilembo niongi mu diambu di disumu diama.
\q1 
\v 19 Bawombo badi bambeni ziama ; ziozi zibeki zingolo.
\q1 Bobo bakundendanga mu kambu bila badi bawombo.
\q1 
\v 20 Bobo bakuphutudilanga mambimbi mu mamboti mama
\q1 balembo thubidila ku ndambu
\q1 mu thangu ndinlandakana vanga mamboti.
\q1 
\v 21 A Yave, kadi kundiekula ; kadi kuthatukila Nzambi ama.
\q1 
\v 22 Yiza nsualu mu kutsadisa,
\q1 A Yave, Mvulusi ama.
\c 39
\cl Minkunga 39
\s1 Va ntuala lufua
\d Nkunga Davidi kuidi Yedutuni, pfumu minyimbidi.
\q1 
\v 1 Minu ndituba : “ndiela sunga zinzila ziama
\q1 ayi ndiela keba ludimi luama mu masumu.
\q1 Ndiela tula luvambu mu munuꞌama mu zithangu zioso
\q1 batu bambimbi bela banga ku ntuala meso mama.”
\q1 
\v 2 Bu ndiba dio sui ayi ndidingalala
\q1 ayi bu ndisia tuba kadi diambu ko.
\q1 Vayi ziphasi ziama buelama na buelama zilembo zibuelama.
\q1 
\v 3 Ntimꞌama wulema mu khati nitu ama ;
\q1 ayi bu ndiyindula, buna mbazu yilema.
\q1 Diawu nditumbu tubila mu ludimi luama :
\q1 
\v 4 “Wumbonisa, a Yave tsukulu yi luzingu luama ;
\q1 ayi thalu yi bilumbu biama
\q1 bika wunzabikisa ti luzingu luama vioka lu mvioka !
\q1 
\v 5 Ngeyo wuvanga bilumbu biama
\q1 siadila banga dikanda diama
\q1 Tezo ki mimvu miama kisi ko kadi mfunu va ntanlꞌaku.
\q1 Kadika luzingu lu mutu luidi kaka phemo.
\q1 
\v 6 Mutu widi khatika kimbindi
\q1 bu keti kuenda ayi vutuka weti banga mayindu, vayi mu phamba kuandi ;
\q1 weti kupika bima vayi kakadi zaba nani wela bitota.
\q1 
\v 7 Vayi buabu, Yave, mbi mfueti vingila e ?
\q1 Diana diama didi mu ngeyo.
\q1 
\v 8 Wuphukisa mu zinzimbala ziama zioso ;
\q1 kadi kundiekula ndikituka sekonono ki bivulu.
\q1 
\v 9 Ndiba dio sui ; ndisia zibula munu ama ko
\q1 bila ngeyo wuvanga buawu.
\q1 
\v 10 Wuphengumunina nsongo aku.
\q1 Ndieka suka mu diambu di bikoti bi mioko miaku.
\q1 
\v 11 Ngeyo weti tubidila ayi weti vana batu thumbudulu
\q1 mu diambu di masumu mawu.
\q1 Ngeyo weti zinisa kimvuama kiawu banga kiphepele
\q1 kadika mutu widi phemo.
\q1 
\v 12 Wa lusambulu luama ; a Yave !
\q1 Dimba yamikina kuama mu diambu di lusadusu.
\q1 Kadi lasakana mu bidilu biama ;
\q1 bila ndieti kalanga yaku va kimosi banga nzenza,
\q1 banga nkibi, banga bakulu bama boso.
\q1 
\v 13 Wuphengumunina thaluꞌaku
\q1 muingi ndimona diaka khini
\q1 tuamina ndunda ayi ndibika buela monika.”
\c 40
\cl Minkunga 40
\s1 Phulusu yi Nzambi yi kisadi kiandi
\d Nkunga Davidi kuidi pfumu minyimbidi.
\q1 
\v 1 Ndieti tadidila Yave mu mvibudulu.
\q1 Niandi wubaluka kuidi minu
\q1 ayi wuwa yamikina kuama.
\q1 
\v 2 Niandi wuthampula mu dibulu di tsisi,
\q1 mu khati nyamba wu ngolo.
\q1 Wutula malu mama va ditadi,
\q1 wuphana buangu kikinda kioki ndilenda telama.
\q1 
\v 3 Niandi wutula nkunga wumona va munu ama ;
\q1 nkunga wu zitisila Nzambi eto,
\q1 Batu bawombo bela mona ayi bela mona tsisi ;
\q1 ayi bela tula diana diawu mu Yave.
\q1 
\v 4 Lusakumunu kuidi mutu wunkitulanga Yave diana diandi ;
\q1 ayi wunkambu talanga bankua luniemo
\q1 kuidi bobo beti baluka kuidi zinzambi zi luvunu.
\q1 
\v 5 A Yave, Nzambi ama, ngeyo wuvanga matsiminanga mawombo ;
\q1 ayi bima biobi wukubika mu diambu dieto.
\q1 Kuisiko mutu wulenda kutangila biawu.
\q1 Enati thidi ku mayolukila ayi ku matubila ;
\q1 mawu mawokidi ngolo muingi ndimasamuna.
\q1 
\v 6 Makaba ma vonda ayi makaba matambuku ;
\q1 ngeyo wumanga mawu ;
\q1 Ngeyo wutobula matu mama.
\q1 Makaba mayoko ayi makaba mu diambu di masumu,
\q1 ngeyo wusia malomba ko.
\q1 
\v 7 Buna ndituba :
\q1 “ndilembo yizi ; didi disonama mu diambu diama
\q1 mu buku ti :
\q1 
\v 8 Minu thidi vanga luzolo luaku ; a Nzambi ama,
\q1 Mina miaku midi mu ntimꞌama.”
\q1 
\v 9 Ndinyamikisa busonga buaku mu lukutukunu lunneni.
\q1 Ndisia zibika bididi biama ko.
\q1 Banga kuandi buzebi, a Yave.
\q1 
\v 10 Ndisi sueka ko busonga buaku mu ntimꞌama.
\q1 Ndiyolukila kikhuikizi kiaku
\q1 ayi phulusu aku.
\q1 Ndisia sueka ko luzolo luaku
\q1 ayi kiedika kiaku mu lukutukunu lunneni.
\q1 
\v 11 Kadi zimbakana kumbonanga kiadi, a Yave.
\q1 Bika Luzolo luaku ayi kiedika kiaku
\q1 bikhebanga mu zithangu zioso.
\q1 
\v 12 Bila ziphasi ziwombo zikambu zabakana
\q1 thalu zinzungididi.
\q1 Masumu mama mambakidila,
\q1 ayi ndikadi mona.
\q1 Maviokidi zitsuki ziama zi ntu mu thalu.
\q1 Ayi ntimꞌama wulembo vongi mu minu.
\q1 
\v 13 Yangalala, a Yave, mu kuphukisa
\q1 A Yave, yiza nsualu mu kutsadisa.
\q1 
\v 14 Bika babo bobo bantomba baka luzingu luama ;
\q1 bafua tsoni ayi baba dio kombolo
\q1 bika babo bammonanga khini mu mbivusu ama baba dio kombolo.
\q1 
\v 15 Bika babo bobo bantubanga kuidi minu :
\q1 “A, a…” bamona tsisi mu diambu di zitsoni ziawu veka
\q1 
\v 16 Vayi bika babo bobo bakutombanga bayangalala,
\q1 ayi bamona khini mu ngeyo.
\q1 Bika babo banzolanga phulusu aku batuba mu zithangu zioso :
\q1 “Bika Yave kayayusu.”
\q1 
\v 17 Vayi minu, ndidi mu kiadi ayi nsukami,
\q1 bika Yave kambanzila.
\q1 Ngeyo nsadisi ama ayi nkudi ama.
\q1 Nzambi ama, kadi zingila.
\c 41
\cl Minkunga 41
\s1 Lusambulu lu mbevo
\d Nkunga Davidi kuidi pfumu minyimbidi.
\q1 
\v 1 Lusakumunu kuidi mutu wowo thaluꞌandi yidi kuidi mutu wulebakana,
\q1 Yave weti ku nkula mu thangu yi ziphasi.
\q1 
\v 2 Yave wela kunkeba ayi wela tanina luzingu luandi ;
\q1 wela kunsakumuna va ntoto
\q1 ayi kalendi kunyekula ko mu luzolo
\q1 lu bobo beti kunlenda ;
\q1 
\v 3 Yave wela kunkindisa va mfulu andi yi kimbevo.
\q1 Ngeyo wela kumbelusa va mfulu andi yi kimbevo.
\q1 
\v 4 Ndituba : “A Yave, wumboni kiadi.
\q1 Wumbelusa bila kuidi ngeyo ndivodidi masumu.”
\q1 
\v 5 Bambeni ziama zilembo tubi mambu mu diela dimbimbi
\q1 mu diambu diama : “Thangu mbi kela fua
\q1 ayi dizina diandi diela lalakana e ?”
\q1 
\v 6 yoso thangu mutu kizidi mu kuthala ;
\q1 mutu wowo wuntubanga luvunu.
\q1 Ntimꞌandi wufulukidi mambu ma mvuezolo ;
\q1 buna wuntotukanga ku nganda ayi wunyolukilanga mawu.
\q1 
\v 7 Bambeni ziama zioso zilembo niunguta va kimosi mu diambu diama.
\q1 Balembo yindula mambimbi mu diambu diama,
\q1 balembo tubi :
\q1 
\v 8 “Nsongo wumbimbi wumbuididi.
\q1 Kalendi buela vumbuka ko va buangu kioki kalambididi.”
\q1 
\v 9 Ka diambu ko nkundi ama wu luzolo,
\q1 wowo ndibedi silanga diana,
\q1 wubedi kabulanga dipha diama, wumbalumukini.
\q1 
\v 10 Vayi ngeyo Yave, wumboni kiadi
\q1 wuthedimisa.
\q1 Muingi ndiba vutudila landi.
\q1 
\v 11 Nzebi ti ngeyo wunyangalalanga mu minu ;
\q1 mu diambu di mbeni ama kabika kundunga.
\q1 
\v 12 Mu bufuana kuama, ngeyo wutsimba ;
\q1 wuthedimisa mu zithangu zioso va tuala meso maku.
\q1 
\v 13 Nzitusu wuba kuidi Yave, Nzambi yi Iseli,
\q1 mu thangu yi kayimani.
\qr Ameni ayi Ameni !
\c 42
\ms1 BUKU YIMMUADI
\cl Minkunga 42
\s1 Phuila yi Nzambi ndieti mona
\d Nkunga bana ba babakala ba Kole kuidi pfumu minyimbidi.
\q1 
\v 1 Boso bummoninanga disofi phuila yi nlangu,
\q1 buawu bobo muelꞌama wididi phuila yi ngeyo ;
\q1 Nzambi ama.
\q1 
\v 2 Muelꞌama wulembo moni phuila yi Nzambi,
\q1 Phuila yi Nzambi yi moyo.
\q1 Thangu mbi ndiela nkuenda ayi ndiela dengana Nzambi e ?
\q1 
\v 3 Matsuela mama mawu maba bidia biama
\q1 mu builu ayi muini bu babedi ku khambanga mu lumbu kimvimba :
\q1 “Kuevi kuidi Nzambi aku e ?”
\q1 
\v 4 Mambu momo ndieti tebukila moyo
\q1 banga minu ndintiamuna muelꞌama :
\q1 buevi ndibedi kuendilanga va kimosi
\q1 ayi nkangu wu batu, mu kuba diatisa mu ntanda
\q1 nate ku nzo Nzambi
\q1 mu biyoko bi khini ayi mu phutudulu yi matondo
\q1 va khatitsika batu bawombo badi mu nyengo.
\q1 
\v 5 Bila mbi vongidi bobo, a muelꞌama e ?
\q1 Bila mbi muelꞌama wulembo niongina
\q1 mu khati ama e ?
\q1 Tula diana diaku mu Nzambi bila ndiela kunzitisa diaka ;
\q1 Mvulusi ama ayi Nzambi ama.
\q1 
\v 6 Muelꞌama widi wuvonga mu khati nitu ama
\q1 Diawu ndiela kutebukilanga moyo
\q1 tona ku tsi yi Yolidani, ku zitsongi zi miongi
\q1 mi Elimoni ayi tona ku mongo wu Mizali.
\q1 
\v 7 Kiza kieta tela kiza kinkaka
\q1 mu khumbulu yi minlangu mu zithadi ziaku.
\q1 Mayo maku mamo mafioti ayi manneni ma mbukimini.
\q1 
\v 8 Mu muini, Yave wumfidisanga luzolo luandi
\q1 Mu builu nkungꞌandi widi va minu
\q1 lusambulu kuidi Nzambi yi luzingu luama.
\q1 
\v 9 Ndintuba kuidi Nzambi,
\q1 ditadi diama di ngolo :
\q1 “Bila mbi wunzimbikini e ?
\q1 Bila mbi mfueti diatilanga mu phasi,
\q1 yamusungu kuidi mbeni e ?”
\q1 
\v 10 Mimvesi miama milmbo moni phasi yi lufua ;
\q1 batu bobo bandendi bu balembo mfingi
\q1 bu beti ku khambanga mu lumbu kimvimba ti :
\q1 “Kuevi kuidi Nzambi aku e ?”
\q1 
\v 11 Bila mbi vongidi bobo, a muelꞌama e ?
\q1 Bila mbi wulembo niongina mu khati ama e ?
\q1 Tula diana diaku mu Nzambi
\q1 bila ndiela kunzitisa diaka ;
\q1 niandi Mvulusi ama ayi Nzambi ama.
\c 43
\cl Minkunga 43
\s1 Tula diana diaku mu Nzambi
\q1 
\v 1 Wundungisa, a Nzambi,
\q1 ayi wunzonzila mu mambu mama kuidi dikanda di batu dinkambu
\q1 kinzikanga mambu maku.
\q1 Wukhula mu batu ba luvunu ayi batu bambimbi.
\q1 
\v 2 Ngeyo Nzambi, ngeyo zingolo ziama.
\q1 Bila mbi wundozidi e ?
\q1 Bila mbi mfueti diatilanga mu phasi,
\q1 yamusungu kuidi mbeni e ?
\q1 
\v 3 Fidisa kiezila ayi Kiedika kiaku ;
\q1 bila bindiatisa,
\q1 bika bindata ku mongo aku wunlongo
\q1 ayi nate ku buangu kioki weti vuanda.
\q1 
\v 4 Buna ndiela kuenda ku ntala wu Nzambi ;
\q1 kuidi Nzambi khini ama
\q1 ayi yangalala kuama.
\q1 Buna ndiela kunzitisa mu ngitala,
\q1 A Nzambi, Nzambi ama.
\q1 
\v 5 Bila mbi vongidi bobo, a muelꞌala e ?
\q1 Bila mbi wulembo niongina mu khati ama e ?
\q1 Tula diana diaku mu Nzambi bila ndiela kunzitisa diaka,
\q1 Mvulusi ama ayi Nzambi ama.
\c 44
\cl Minkunga 44
\s1 Yave wutuloza
\d Nkunga bana ba babakala ba Kole kuidi pfumu minyimbidi.
\q1 
\v 1 Beto tuwilu mu matu meto, a Nzambi
\q1 madise meto batukamba mambu momo wuvanga mu bilumbu biawu ;
\q1 mu bilumbu bivioka
\q1 
\v 2 Mu koko kuaku, ngeyo wukuka makanda ;
\q1 ayi ngeyo wuvingisa madise meto ;
\q1 ngeyo wukosikisa batu ayi ngeyo wufunisa mase meto.
\q1 
\v 3 Kadi sia ti mu diambu di sabala kiawu
\q1 bazionina tsi ;
\q1 Voti kadi sia ti koko kuawu kuawu kuba natina ndungunu ;
\q1 koko kuaku ku lubakala,
\q1 koko kuaku ayi kiezila ki zizi kiaku
\q1 bila ngeyo wuba zola.
\q1 
\v 4 Ngeyo ntinu ama ayi Nzambi ama ;
\q1 ngeyo wuzenga ndungunu mu diambu di Yakobi.
\q1 
\v 5 Mu diambu diaku, tuela vutula bambeni zieto ku mbusa.
\q1 Mu diambu di dizina diaku, tuela diatikisa
\q1 bobo beti kutulenda.
\q1 
\v 6 Nditulanga ko diana diama mu mbasꞌama
\q1 ayi sabala kiama kilendi ku ndatina ndungunu ko.
\q1 
\v 7 Vayi ngeyo weti kutuvana ndungunu mu bambeni zieto ;
\q1 ngeyo wumfuisanga tsoni bobo bakutulendanga.
\q1 
\v 8 Mu Nzambi beto tueti kukiniemisanga
\q1 mu lumbu kimvimba
\q1 ayi tuela zitisa dizina diaku
\q1 mu zithangu zioso.
\q1 
\v 9 Vayi buabu ngeyo wutuloza ayi wutukuludi ;
\q1 ngeyo wutotukanga diaka ko
\q1 ayi nkangu eto wu masodi.
\q1 
\v 10 Ngeyo wutuvutula ku mbusa
\q1 va ntuala bambeni zieto ;
\q1 ayi bobo beti kutulenda bazionini bima bieto.
\q1 
\v 11 Ngeyo wutuyekula batudia banga mamemi.
\q1 Wutusasikisa va khatitsika makanda.
\q1 
\v 12 Ngeyo wusumbisa batu baku mu thalu yi phamba,
\q1 wukadi kuba bakila ndandu bu wuba sumbisa.
\q1 
\v 13 Ngeyo wutukitula kima ki tsoni
\q1 kuidi bafikimini yeto,
\q1 kisekununu ayi kitsevolo
\q1 kuidi bawu batuzungididi.
\q1 
\v 14 Ngeyo wutukitula zinongo va khatitsika makanda ;
\q1 batu balembo kutunikunina mintu miawu.
\q1 
\v 15 Mvuezolo ama widi ku ntualꞌama mu lumbu kimvimba ;
\q1 ayi tsoni yilembo monika va zizi kiama ;
\q1 
\v 16 mu diambu di bifingu bi bobo balembo
\q1 ndenzi ayi balembo mvuezi,
\q1 mu diambu di mbeni, mutu wumvutulanga landi.
\q1 
\v 17 Mamoso momo matubuila
\q1 vayi beto tusia kuzimbakana ;
\q1 Voti tusia ba luvunu mu Nguizani aku ko.
\q1 
\v 18 Mintima mieto misia baluka ko ;
\q1 Malu meto masia vengama ko mu nsolo aku,
\q1 
\v 19 vayi wutukosikisa ayi wutukitula suamunu ki memvo ;
\q1 ayi wutufuka ku tsi dibulu di tombi.
\q1 
\v 20 Enati beto tuzimbakana dizina di Nzambi eto,
\q1 voti tunonuna mioko mieto kuidi nzambi yi nzenza,
\q1 
\v 21 buna Nzambi kalendi bakula ko e ?
\q1 Bila niandi zebi mansueki ma ntima.
\q1 
\v 22 Vayi mu diambu diaku tueti dengana lufua
\q1 mu lumbu kimvimba,
\q1 ayi balembo tumoni banga mamemi
\q1 mafueti kuenda ku vondo.
\q1 
\v 23 Kotuka, a Yave !
\q1 Bila mbi wulembo lekila e ?
\q1 Kotuka kuaku kadi tumbu ku tuyekula mvimba !
\q1 
\v 24 Bila mbi wulembo suekila zizi kiaku e ?
\q1 Ayi bila mbi wulembo zimbikinina
\q1 ziphasi zieto ayi yamusu kueto e ?
\q1 
\v 25 Tunatu ku mbungi-mbungi
\q1 zinitu zieto zinama mu ntoto.
\q1 
\v 26 Telama, wutusadisa
\q1 wutukula mu diambu di luzolo luaku lu ngolo.
\c 45
\cl Minkunga 45
\s1 Nkunga wu dikuela di ntinu
\d Nkunga bana ba babakala ba Kole kuidi pfumu minyimbidi. Nkunga wu luzolo bayimbidila mu “LISI”.
\q1 
\v 1 Ntimꞌama wulembo fundumuka mu mambu ma kitoko.
\q1 Ndiela samuna mambu mama mu diambu di ntinu.
\q1 Ludimi luama luidi lapi yi nsoniki wukiedika.
\q1 
\v 2 Ngeyo viokidi batu mu kitoko ;
\q1 bididi biaku bidukudulu mafuta ma nlemvo ;
\q1 diawu Nzambi kasakumunina mu zithangu zioso.
\q1 
\v 3 Kanga sabala kiaku mu luketo luaku,
\q1 ngeyo kinuani ki ngolo,
\q1 vuata ngeyo veka kiezila ayi nzitusu.
\q1 
\v 4 Mu nzitusu aku, telama va ntuala
\q1 mu ndungunu mu diambu di kakidila kiedika,
\q1 kukikulula ayi busonga.
\q1 Bika koko kuaku ku lubakala kumonisa mavanga ma tsisi.
\q1 
\v 5 Bika zitsoto ziaku zidi meno,
\q1 zitobula mintima mi bambeni zi ntinu ;
\q1 bika makanda mabua ku tsi tambi biaku.
\q1 
\v 6 Kundu kiaku ki kitinu, a Nzambi
\q1 kiela zingila mu zithangu zioso
\q1 Nkawꞌaku wu busonga wela ba nkawa wu Kitinu kiaku.
\q1 
\v 7 Ngeyo wunzolanga busonga ayi wunlendanga mambimbi.
\q1 Diawu Nzambi, Nzambi aku, wutula va mbata batu bandiatanga yaku
\q1 bu kavinda mafuta ma khini.
\q1 
\v 8 Zilobi ziaku zioso zidi tsudi malasi ma mile,
\q1 ayi alowesi ayi kase ; mu nzo yoyi yitungulu mu meno ma nzawu
\q1 miziki mi zitsinga mikumonisa khini.
\q1 
\v 9 Bana ba baketo ba ntinu badi va khati baketo baku ba luvalu.
\q1 Va koko kuaku ku lubakala, vadi Ntinu wu nketo mu nolo yi Ofili.
\q1 
\v 10 Wa, o muana ndumba, tala ayi tamba dikutu :
\q1 zimbakana batu baku ayi nzo dise diaku.
\q1 
\v 11 Ntinu wulembo moni khini mu kitoko kiaku
\q1 kinzika bila niandi Pfumu aku ;
\q1 
\v 12 Muana ndumba wu Tile, wela nata dikaba ;
\q1 batu balutidi kimvuama bela tomba mona mamboti maku.
\q1 
\v 13 Nkembo woso widi kuidi muana ntinu wu nketo
\q1 mu khati vinga kiandi
\q1 lobi andi yitungulu mu nolo.
\q1 
\v 14 Mu minlele midi malenda ma kitoko ; bela kunnata kuidi ntinu.
\q1 Zindumba ziozi zizebi ko zinitu zi babakala
\q1 ziozi zindiatanga yandi zilembo kunlandakana.
\q1 Ayi bela natu kuidi ngeyo.
\q1 
\v 15 Bela natu mu khini ayi mu mayangani.
\q1 Bela kota mu nzo ntinu.
\q1 
\v 16 Bana baku ba babakala bela bonga buangu ki madise maku ;
\q1 ngeyo wela ku babieka bilandi bi ntinu
\q1 mu tsi yi mvimba.
\q1 
\v 17 Minu ndiela sia ti batebukilanga moyo
\q1 mu zitsungi zioso.
\q1 Diawu makanda mela kuzitisa mu zithangu zioso
\q1 ayi mu mvu ka mvu.
\c 46
\cl Minkunga 46
\s1 Nzambi widi suamunu kieto
\d Nkunga bana ba babakala ba Kole kuidi pfumu minyimbidi ; bayimbidila mu mbembo yi fioti yi bana babaketo.
\q1 
\v 1 Nzambi niandi suamunu kieto
\q1 ayi zingolo zieto ;
\q1 niandi nsadisi wu zithangu zioso mu ziphasi.
\q1 
\v 2 Diawu tulendi mona tsisi ko
\q1 ka diambu ko ntoto wulenda buka
\q1 ayi miongo milenda bulumuka ku tsi mbu,
\q1 
\v 3 ka diambu ko, minlangu beni milembo dumi,
\q1 milembo fundumuka ayi miongo miela nikuka
\q1 mu diambu di makhesi mawu.
\q1 
\v 4 Vayi vadi nlangu wumosi wunneni wubeki mimvuila
\q1 mieti monisa divula di Nzambi khini ;
\q1 buangu kiviatukidi nlongo vovo veti vuanda
\q1 Nzambi yizangama.
\q1 
\v 5 Nzambi widi va khatitsikꞌandi ;
\q1 kalendi bua ko.
\q1 Nzambi wela kusadisa tona mu khiesa yi nsuka.
\q1 
\v 6 Makanda malembo tudi divunzi,
\q1 bipfumu bilembo bua.
\q1 Wuwakikisa mbembo andi ; ntoto wusiuta.
\q1 
\v 7 Yave nkua ngolo yoso widi yeto ;
\q1 Nzambi yi Yakobi niandi suamunu kieto ki ngolo.
\q1 
\v 8 Yizanu ayi lutala mavanga ma Yave,
\q1 maniongo momo kanata va ntoto.
\q1 
\v 9 Niandi wumanisa zimvita nate ku sukisina ntoto
\q1 wukelula mimbasa ayi wubukuna madionga ;
\q1 wuyoka ku mbazu minkaku.
\q1 
\v 10 Luba dio sui ayi luzaba ti minu Nzambi.
\q1 Ndiela yayusu muidi makanda, ndiela yayisa va ntoto.
\q1 
\v 11 Yave nkua ngolo yoso widi yeto.
\q1 Nzambi yi Yakobi niandi suamunu kieto ki ngolo.
\c 47
\cl Minkunga 47
\s1 Lusikila Nzambi zitsiaki
\d Nkunga bana ba babakala ba Kole kuidi pfumu minyimbidi.
\q1 
\v 1 Lusika zitsiaki, beno makanda moso.
\q1 Luyamikina kuidi Nzambi mu khini,
\q1 
\v 2 Tala phila Yave yizangama kadidi tsisi !
\q1 Niandi ntinu wunneni va mbata ntoto wumvimba.
\q1 
\v 3 Wutula makanda ku tsi buvika bueto,
\q1 batu ku tsi malu meto.
\q1 
\v 4 Wutusobudila kiuka ;
\q1 luniemo lu Yakobi ; mutu wu kazola.
\q1 
\v 5 Nzambi wukuma va khatitsika yamikina ku khini
\q1 Yave wukuma va khatitsika biyoko bi tulumbeta.
\q1 
\v 6 Luyimbila minzitusu kuidi Nzambi
\q1 Luyimbila minzitusu ;
\q1 Luyimbila minzitusu kuidi Nzambi eto,
\q1 luyimbila minzitusu.
\q1 
\v 7 Bila Nzambi niandi ntinu wu ntoto wumvimba ;
\q1 Lunyimbidila nkunga wu nzitusu.
\q1 
\v 8 Nzambi weti yadila makanda moso.
\q1 Nzambi vuendi va kundu kiandi kinlongo.
\q1 
\v 9 Batu banneni ba makanda bakutikini
\q1 banga batu ba Nzambi yi Abalahami
\q1 bila Nzambi niandi vuidi mintinu mi ntoto.
\q1 Niandi wuyayusu ngolo.
\c 48
\cl Minkunga 48
\s1 Divula di Nzambi
\d Nkunga bana ba babakala ba Kole.
\q1 
\v 1 Yave widi wunneni.
\q1 Ayi lutidi fuana mu tambula minzitusu
\q1 mu divula di Nzambi eto, mongo andi wunlongo.
\q1 
\v 2 Widi wu kitoko mu nangama kuandi,
\q1 khini yi ntoto wumvimba.
\q1 Mongo wu Sioni widi banga zitsongi zilutisi nangama zi Zafoni,
\q1 divula di ntinu wunneni.
\q1 
\v 3 Nzambi widi mu zinzo zi divula beni
\q1 wukimonisa niandi veka mu ba suamunu kiandi ki ngolo.
\q1 
\v 4 Mu thangu mintinu mifubikisa zingolo,
\q1 mu thangu midiatila va kimosi.
\q1 
\v 5 Mimona ayi misimina ;
\q1 mitina mu tsisi.
\q1 
\v 6 Lukhuku luba buila vana
\q1 ziphasi ziba mona zidedikini banga mianga
\q1 mieti mona nketo weka buta.
\q1 
\v 7 Ngeyo wuba bunga banga masuwa ma Talisi
\q1 mabungu mu phemo yeti totukila ku Esite.
\q1 
\v 8 Banga bu tuwila,
\q1 buawu bobo tumuenini mu divula di Yave,
\q1 nkua ngolo yoso ;
\q1 mu divula di Nzambi eto :
\q1 Nzambi wela kuvana luvovomo mu zithangu zioso.
\q1 
\v 9 Mu khati nzo aku, a Nzambi,
\q1 tueti yindula mu diambu di luzolo luaku lu ngolo.
\q1 
\v 10 Banga dizina diaku, a Nzambi !
\q1 Nzitusu aku widi nate mu sukisina ntoto.
\q1 Koko kuaku ku lubakala kuwedi busonga.
\q1 
\v 11 Mongo wu Sioni wulembo moni khini ;
\q1 mala ma Yuda malembo yangalala
\q1 mu diambu di zinzengolo ziaku.
\q1 
\v 12 Ludiata muyenda Sioni ayi lunzungidila,
\q1 ayi lutanga zinzo ziandi zizangama.
\q1 
\v 13 Lutala bumboti ziphangu ziandi ;
\q1 Lufiongunina zinzo ziandi
\q1 muingi luba samunina kuidi tsungi yinkuiza.
\q1 
\v 14 Bila Nzambi yayi niandi Nzambi eto
\q1 mu thangu yi kayimani ayi mu zithangu zioso.
\q1 Niandi wela ba ntuadisi eto nate ku tsuka.
\c 49
\cl Minkunga 49
\s1 Tudila kimvuama diana buidi buvungisi
\d Nkunga bana ba babakala ba Kole kuidi pfumu minyimbidi.
\q1 
\v 1 Luwa diambu diadi beno batu boso :
\q1 Ludimba beno batu boso lunzinganga va nza yayi,
\q1 
\v 2 batu baphamba ayi batu banneni,
\q1 zimvuama ayi minsukami.
\q1 
\v 3 Munuꞌama wela tuba mambu ma nduenga,
\q1 mamo mantotukila mu ntimꞌama mela vana tsudukulu.
\q1 
\v 4 Ndiela balula dikutu diama mu diambu di wa zingana,
\q1 mu ngitala, ndiela sudikisila nongoꞌama.
\q1 
\v 5 Bila mbi mfueti monina tsisi
\q1 bilumbu bi mbimbi bu bizidi,
\q1 mu thangu mambimbi ma bobo beti vuna batu manzungididi e ?
\q1 
\v 6 Bantulanga diana diawu mu bima biawu
\q1 ayi beti kukiniemisa mu kimvuama kiawu kiwombo.
\q1 
\v 7 Mutu kalendi baka bu kuidila ko, luzingu lu mutu wunkaka,
\q1 voti futa thalu yi khudulu andi kuidi Nzambi.
\q1 
\v 8 Thalu yi khudulu yi luzingu yibeki luvalu lunneni,
\q1 kuisi ko kadi mfutu wulenda dedakana,
\q1 
\v 9 mu diambu kazinga mu zithangu zioso
\q1 ayi kabika bola.
\q1 
\v 10 Bila babo beti mona ti bankua nduenga balembo fua ;
\q1 bivungisi ayi bivulu balembo fua mamvawu,
\q1 ayi balembo biki bima biawu kuidi batu bankaka.
\q1 
\v 11 Biziami biawu biela banga zinzo ziawu mu zithangu zioso ;
\q1 bibuangu biawu biobi beta vuanda mu tsungi ka tsungi.
\q1 Beti vana mazina mawu mu mintoto miawu bu bafuidi.
\q1 
\v 12 Vayi mutu, ka diambu ko beki kimvuama kazinganga buwombo ko.
\q1 Dedikini banga bibulu bieti fua.
\q1 
\v 13 Mawu mama mambu meti buila batu bobo beti tula diana mu bawu veka
\q1 ayi bobo beti kuba landakana,
\q1 bobo beti kikina mambu beti tuba.
\q1 
\v 14 Banga nkangu wu mamemi, bakubuku mu diambu di tsi bafua ;
\q1 lufua luela kuba dia.
\q1 Mutu widi ntima wululama wela kuba yadila va nsuka
\q1 buphila buawu buela bola ku tsi bafua,
\q1 thama ayi zinzo ziawu zi kipfumu.
\q1 
\v 15 Vayi Nzambi wela kula luzingu luama mu lulendo lu tsi bafua,
\q1 bukiedika wela kuthambula mu diambu diandi veka.
\q1 
\v 16 Kadi mona tsisi mutu bu kalembo baki kimvuama
\q1 kiezila ki nzo andi bu kilembo buelama.
\q1 
\v 17 Bila kalendi nata kadi kima ko mu thangu kela fua.
\q1 Kiezila kiandi kilendi kuluka yandi ko.
\q1 
\v 18 Bu kabedi moyo wukimona mutu wu lusakumunu
\q1 ayi batu beti kuzitisa bu weti mona lusakumunu
\q1 bu kabedi monanga mamboti.
\q1 
\v 19 Wela kuenda bata tsungi yi madise mandi ;
\q1 bobo balendi buela mona kiezila ko ki luzingu.
\q1 
\v 20 Mutu widi kimvuama ayi kambulu diela
\q1 widi banga bulu kieti fua.
\c 50
\cl Minkunga 50
\s1 Nzambi wela sambisa batu bandi.
\d Nkunga Asafi.
\q1 
\v 1 Nkua lulendo ; Nzambi, Yave
\q1 tubidi ayi kutikisidi ntoto
\q1 tonina ku ntotukilanga thangu nate buangu keti diamina.
\q1 
\v 2 Tona ku Sioni, wufuana mu kitoko ;
\q1 Nzambi weti kienzuka.
\q1 
\v 3 Nzambi eto wulembo yizi,
\q1 ayi kalendi ba dio sui ko ;
\q1 mbazu yilembo zinisa ku ntualꞌandi
\q1 ayi vuka kingolo kinzungididi.
\q1 
\v 4 Niandi wunkutikisanga diyilu ku yilu
\q1 ayi ntoto mu diambu kasambisa batu bandi :
\q1 
\v 5 Lukhutikisila batu bama bobo ndibieka,
\q1 bobo bavanga yama Nguizani mu nzila yi makaba.
\q1 
\v 6 Ayi diyilu dilembo yamikisa busonga buandi,
\q1 bila Nzambi niandi veka zuzi.
\q1 
\v 7 Luwa, beno batu bama ;
\q1 Ndiela tuba :
\q1 A Iseli, ayi ndieka ntelama kimbangi mu diambu diaku :
\q1 Minu ndidi Nzambi ; Nzambi aku.
\q1 
\v 8 Ndilendi kutemina ko mu diambu di makaba maku
\q1 voti makaba maku mayoko ;
\q1 momo madi thangu ka thangu va ntualꞌama,
\q1 
\v 9 Ndisi mfunu wu ngombi yi mbakala yi luphangu luaku ko,
\q1 voti zikhombo zi ziphaka ziaku ko.
\q1 
\v 10 Bila minu phuidi bibulu bioso bi nsitu
\q1 ayi bibulu bioso binkalanga mu miongo.
\q1 
\v 11 Nzebi zinuni zioso zi miongo,
\q1 ayi minu phuidi bivangu bidi mu zitsola,
\q1 
\v 12 Enati nzala ndimona, buna ndilendi kukamba buawu ko
\q1 bila minu phuidi nza ayi bibioso bidi muawu.
\q1 
\v 13 Minu minsuni mi zingombi zimbakala ndiela dia
\q1 voti ndieka nua menga ma zikhombo e ?
\q1 
\v 14 Tambika makaba ma phutudulu matondo kuidi Nzambi
\q1 ayi dukisanga zitsila ziaku kuidi Nzambi yizangama.
\q1 
\v 15 Ayi wuthela mu lumbu ki ziphasi,
\q1 ndiela ku kula ayi ngeyo wela kunzitisa.
\q1 
\v 16 Vayi Nzambi wulembo kambi mutu wumbimbi :
\q1 “Mu minsua mbi wulembo tangilanga mina miama e ?
\q1 Voti bila mbi weti natina Nguizani yama mu bididi biaku e ?
\q1 
\v 17 Ngeyo wunlendanga zindongi ziama
\q1 ayi wuloza mambu mama ku manima maku.
\q1 
\v 18 Ngeyo bu mueni muivi,
\q1 buna weti bundana yandi.
\q1 Bosi ngeyo wumvuandanga va kimosi ayi mitsuza.
\q1 
\v 19 Wunsadilanga munuꞌaku mu diambu di mambimbi,
\q1 ayi wunsadilanga ludimi luaku mu diambu di luvunu.
\q1 
\v 20 Ngeyo wuntubidilanga khombꞌaku
\q1 ku ndambu mu zithangu zioso ;
\q1 Ngeyo wuvuezanga muana bakala wubuta ngudi aku.
\q1 
\v 21 Mambu mana mawu wuvanga
\q1 vayi ndiba dio sui.
\q1 Ngeyo wubanzila ti minu ndedikini banga ngeyo
\q1 Vayi minu ndiela kutubidila ayi kufunda va zizi kiaku
\q1 ku ntuala meso maku.
\q1 
\v 22 Luyindula diambu diadi : beno lunzimbakananga Nzambi ;
\q1 nganu ndilenda kulukanzuna mu bitini,
\q1 ayi mutu wulenda kula kalendi monika ko.
\q1 
\v 23 Woso wuntambikanga makaba ma phutudulu matondo
\q1 buna wukunzitisa, ayi weti kubika nzila
\q1 muingi ndimmonisa phulusu yi Nzambi.”
\c 51
\cl Minkunga 51
\s1 Kuidi ngeyo ndivodidi masumu
\d Nkunga Davidi kuidi pfumu minyimbidi ; mu thangu mbikuidi Natani kayiza kuidi Davidi mu kitsuza kiandi ayi Betaseba.
\q1 
\v 1 A Nzambi, wumboni kiadi
\q1 boso buididi luzolo luaku lu ngolo ;
\q1 boso buididi kiadi kiaku kinneni,
\q1 kubula zinzimbala ziama.
\q1 
\v 2 Sukula mambimbi mama moso.
\q1 Ayi wuphedisa mu disumu diama.
\q1 
\v 3 Bila nzebi zinzimbala ziama
\q1 ayi disumu diama didi ku ntualꞌama mu zithangu zioso.
\q1 
\v 4 Kuidi ngeyo, veka kaka ndivodidi masumu ;
\q1 ayi ndivengi mambimbi va meso maku ;
\q1 muingi wumonika wusonga mu thangu wutuba
\q1 ayi wukambulu zimbala mu thangu wunsambisa
\q1 
\v 5 Bukiedika, minu ndidi nkua masumu tona mu mbutukulu ;
\q1 nkua masumu tona thangu ngudi ama kabaka buemba buama.
\q1 
\v 6 Bukiedika ngeyo tidi ti kiedika kiba mu khati ku nitu.
\q1 Wundonga nduenga mu khati yi ntimꞌama
\q1 
\v 7 Wuphedisa mu isopi buna ma ndivedila ;
\q1 wutsukula buna ndiela ba wuphembi
\q1 viokila mvula yi matadi ma phembi ;
\q1 
\v 8 Bika ndimona khini ayi ndiyangalala
\q1 Bika mimvesi miomi wukosikisa mi yangalala.
\q1 
\v 9 Sueka zizi kiaku va ntuala masumu mama
\q1 ayi kubula mbimbi ama yoso.
\q1 
\v 10 Vanga mu minu ntima wuvedila, a Nzambi
\q1 ayi buela kitula mu minu pheve yimona ayi yikinda.
\q1 
\v 11 Kadi kukhuka va ntuala zizi kiaku ;
\q1 kadi botula pheve aku yinlongo mu minu.
\q1 
\v 12 Wuphutudila khini yi phulusu aku
\q1 ayi bika wuphana Pheve yi luzolo lu mboti muingi yikhindisa.
\q1 
\v 13 Buna ndiela longa zinzila ziaku
\q1 kuidi bobo beti vanga zinzimbala,
\q1 ayi bankua masumu bela vutuka kuidi ngeyo.
\q1 
\v 14 Wuphukisa mu nzimbala yi menga, a Nzambi
\q1 Nzambi yoyi yeti kuphukisa,
\q1 ayi ludimi luama luela yimbidila busonga buaku.
\q1 
\v 15 A Yave zibula bididi biama,
\q1 ayi munuꞌama wela yamikisa nzitusu aku.
\q1 
\v 16 Ngeyo wuzolanga ko makaba,
\q1 bila enati buawu ; nganu ndinatina mawu ;
\q1 ayi wumonanga khini ko mu makaba mayoko.
\q1 
\v 17 Makaba ma Nzambi madi pheve yi kosakana
\q1 ntima wukosakana ayi wu kiadi
\q1 a Nzambi, wulendi ku milenza ko.
\q1 
\v 18 Mu diambu di mamboti maku,
\q1 bika wuvangila Sioni mamboti,
\q1 tunga diaka bibaka bi Yelusalemi.
\q1 
\v 19 Kuna kuela ba makaba ma busonga,
\q1 makaba mayoko mamvimba meti kumonisa khini.
\q1 Buna zingombi zimbakala ziela tambuku va ntalꞌaku.
\c 52
\cl Minkunga 52
\s1 Tsukulu yi nkua kimvuama weti yamisa batu
\d Nkunga Davidi kuidi pfumu minyimbidi mu thangu Dowengi muisi Edomi, kayiza vumbudila Sawuli kipholo ti Davidi wuyenda ku nzo Ahimeleki.
\q1 
\v 1 Bila mbi wulembo kukiniemisina mu diambu di mambimbi, ngeyo nkua ngolo e ?
\q1 Bila mbi wulembo kukiniemisina mu lumbu kimvimba
\q1 ngeyo kambulu nzitusu va meso ma Nzambi e ?
\q1 
\v 2 Ludimi luaku lunyindulanga mambu ma mbivusu ;
\q1 ludedikini banga lezuale yidi meno ma ngolo.
\q1 Ngeyo wunsadilanga luvunu.
\q1 
\v 3 Ngeyo lutidi zola mambu mambimbi
\q1 viokila mamboti ;
\q1 luvunu viokila mambu ma kiedika.
\q1 
\v 4 Ngeyo lutidi zola mambu moso momo mambivisanga,
\q1 ngeyo ludimi lu luvunu.
\q1 
\v 5 Bukiedika Nzambi wela kubuisa mu mbivusu yika yilendi suka ko.
\q1 Wela kubuila ayi wela kukanzuna mu nzoꞌaku yi ngoto.
\q1 Wela kuvuza va ntoto wu batu badi moyo.
\q1 
\v 6 Batu basonga bela mona
\q1 ayi bela mona tsisi bela kunseva bu bela tuba :
\q1 
\v 7 “Vava vadi mutu wukambulu kitula Nzambi zingolo ziandi
\q1 Vayi wubedi tulanga diana diandi
\q1 mu kimvuama kiandi kiwombo
\q1 ayi wukitukidi mutu wu ngolo mu bunganga bankaka.”
\q1 
\v 8 Vayi minu ndidi
\q1 banga nti wu olive, wuwedi meza ma nlangu mu nzo yi Nzambi.
\q1 Ndintulanga diana diama mu luzolo mu ngolo lu Nzambi
\q1 mu zithangu zioso ayi mu mimvu mioso.
\q1 
\v 9 Ndiela kuzitisa mu zithangu zioso
\q1 mu diambu di momo wuvanga ;
\q1 mu dizina diaku ndiela tula diana bila didi dimboti,
\q1 ndiela kuzitisa va meso ma banlongo.
\c 53
\cl Minkunga 53
\s1 Beto boso tuidi bazimbala
\d Nkunga Davidi kuidi pfumu minyimbidi ; kayimbidila mu flute.
\q1 
\v 1 Nkua buvulu wuntubanga mu ntimꞌandi :
\q1 “kuisiko Nzambi.”
\q1 Bakibivisidi, zinzila ziawu zidi zimbimbi ;
\q1 kuisiko mutu wumvanganga mamboti.
\q1 
\v 2 Nzambi, wulembo tadi tona ku Diyilu bana ba batu
\q1 mu diambu di tala kani valenda ba batu balenda sudika ;
\q1 bobo bantomba Nzambi.
\q1 
\v 3 Batu boso bamana zimbala, bamana kibivisa va kimosi.
\q1 Kuisiko kadi wumosi wumvanganga mamboti,
\q1 kadi kuandi wumosi.
\q1 
\v 4 Bobo bamvanganga mambimbi, basudikanga ko e ?
\q1 Bawu balembo dia batu bama banga bu beti dila dipha ;
\q1 ayi batelanga Nzambi ko.
\q1 
\v 5 Kuna batitila mu diambu di tsisi
\q1 va buangu ki kondolo bila kimonina tsisi ;
\q1 Nzambi wukosikisa mimvesi mi batu bobo banuanisa ;
\q1 ngeyo wuba fuisa tsoni
\q1 bila Nzambi wuba lenza.
\q1 
\v 6 A, enati phulusu yi Iseli yitotukila ku Sioni !
\q1 Mu thangu Nzambi kela vutula kiuka ki batu bandi ;
\q1 bika Yakobi kamona khini ayi Iseli kayangalala.
\c 54
\cl Minkunga 54
\s1 Nzambi wukhula
\d Nkunga Davidi kuidi pfumu minyimbidi kayimbidila mu mu thangu basi Zifi bayiza kamba Sawuli ti : “Davidi kuidi beto” kasuamini.
\q1 
\v 1 Wuphukisa, Nzambi ama, mu dizina diaku ;
\q1 wundungisa mu lulendo luaku.
\q1 
\v 2 Wa lusambulu luama, a Nzambi.
\q1 Dimba mambu ma munuꞌama.
\q1 
\v 3 Zinzenza zilembo nduanisa
\q1 ayi batu ba tsita balembo tombi luzingu luama.
\q1 Batu bankambu kinzikanga Nzambi.
\q1 
\v 4 Bukiedika, Nzambi niandi nsadisi ama.
\q1 Yave niandi wukukhindisanga.
\q1 
\v 5 Bika mambimbi mabuila bobo beti kuphueza ;
\q1 Mu kikhuikizi kiaku, wuba bunga.
\q1 
\v 6 Ndiela kutambikanga makaba
\q1 mu ntima wu luzolo ;
\q1 ndiela zitisa dizina diaku, a Yave.
\q1 Bila didi dimboti.
\q1 
\v 7 Bila niandi wukhula mu ziphasi ziama zioso
\q1 ayi meso mama mamona mbedoso
\q1 yi bobo beti kundenda.
\c 55
\cl Minkunga 55
\s1 Ndidi mutu wuvakulu
\d Nkunga Davidi kuidi pfumu minyimbidi, kayimbidila.
\q1 
\v 1 Dimba lusambulu luama, a Nzambi ;
\q1 ayi kadi zimbakana mambu mama.
\q1 
\v 2 Wunguila ayi wuphani mvutu ;
\q1 mayindu mama malembo mbonisa phasi ayi ndilembo sambi ;
\q1 
\v 3 mu diambu di mbembo yi mbeni ;
\q1 mu diambu di yamusu ku mutu wumbimbi
\q1 bila minu beti yekikilanga ziphasi
\q1 bila balembo mfingi mu nganzi awu.
\q1 
\v 4 Ntimꞌama widi mu maniongo mu minu ;
\q1 ayi boma bu lufua lu mbuididi.
\q1 
\v 5 Tsisi ayi lukhuku bieka mu minu
\q1 ayi boma bu ngolo bumbuididi.
\q1 
\v 6 Buna ndituba : “Enati ndiba ayi mavavi ma dibembi
\q1 nganu ndieka tumbu dumuka
\q1 ayi ba mu luvundulu.
\q1 
\v 7 Nganu, ndiela tinina ku thama,
\q1 ayi vuanda ku dikanga.
\q1 
\v 8 Ndiela tina nsualu mu tomba suamunu
\q1 ku buangu kikambulu phemo yingolo
\q1 ayi vuka kingolo.”
\q1 
\v 9 Kotisa batu bambimbi mu divuda, A Yawe
\q1 ayi vunzikisa mambu mawu bantuba.
\q1 Bila ndilembo moni makhemi
\q1 ayi ziphaka mu divula.
\q1 
\v 10 Muini ayi builu,
\q1 makhemi ayi ziphaka bizungidila bibaka bi divula ;
\q1 diela dimbimbi ayi kambu dukisa zitsila bieka mu khati divula.
\q1 
\v 11 Mbivusu kiawu kisalu kieka mu khati divula ;
\q1 khuamusu ayi luvunu bikadi botuka mu zinzila zi divula.
\q1 
\v 12 Enati mbeni wumfingidi
\q1 nganu ndikimba moyo ;
\q1 enati mutu wukundendanga niandi weti
\q1 kukiniemisa va ntualꞌama
\q1 nganu ndisuama kuama va ntualꞌama.
\q1 
\v 13 Vayi ngeyo, mutu banga minu
\q1 wundiatanga yama va kimosi ;
\q1 nkundi ama wu kuikama ;
\q1 
\v 14 mutu wowo wubedi kalanga yama mu khini ;
\q1 wubedi kibanga va kimosi
\q1 ayi nkangu wu batu ku Nzo Nzambi !
\q1 
\v 15 Bika lufua lu bibuila bambeni ziama mu kinzimbukila
\q1 ayi bika bakuluka bamoyo ku tsi bafua !
\q1 Bila mambimbi mabakudi buangu va khatitsikꞌawa,
\q1 
\v 16 Mbadi minu, ndintela Nzambi,
\q1 ayi Yave wuphukisidi.
\q1 
\v 17 Yiba nsuka, midi ayi masika,
\q1 Ndieti yamikina mu ziphasi ;
\q1 ayi weti wa mbembo ama.
\q1 
\v 18 Wukukhulanga wumbimba, mu kambu sumbula
\q1 mu mvita yi banduanisa
\q1 ka diambu ko bawombo banduanisa.
\q1 
\v 19 Nzambi wunyadila va kundu kiandi ki luyalu mu zithangu zioso
\q1 wela kuba wa ayi wela kuba monisa phasi ;
\q1 batu bobo balendi balula zinzila ziawu ko
\q1 ayi bakinzikanga Nzambi ko.
\q1 
\v 20 Mutu wundiatanga yama wulembo
\q1 nuanisa bakundi bandi
\q1 wubundula Nguizani andi.
\q1 
\v 21 Mambu mandi ndelo madi
\q1 banga dibela\f + \fr 55.21 \fq Dibela\fqa  : \ft didi mafuta beti vindanga mu mapha.\f*
\q1 muaki mvita yidi mu ntimꞌandi ;
\q1 Mambu mandi madi malebila viokila mafuta
\q1 muaki madi banga bisabala bikubimini mu vonda.
\q1 
\v 22 Yekula bizitu biaku kuidi Yave,
\q1 niandi wela kukindisa ; kalendi tala ko
\q1 ti mutu wusonga kabua.
\q1 
\v 23 Vayi ngeyo Nzambi, wela buisa batu bambimbi ;
\q1 mintengudi mi menga ayi bankua livunu
\q1 bela dukisa ko ndambu yi bilumbu biawu ;
\q1 vayi minu diana diama didi mu ngeyo.
\c 56
\cl Minkunga 56
\s1 Kadi tsisi Nzambi bu kadi yeto
\d Nkunga Davidi kuidi pfumu minyimbidi ; kayimbidila mu “Dibembi di minti midi ku zitsi zi thama” mu thangu basi Filisti bankanga mu tsi Ngati.
\q1 
\v 1 Wumboni kiadi, A Nzambi
\q1 bila batu balembo ndandakana mu kingolo ;
\q1 mu lumbu kimvimba ; balembo luti buela kunduanisa
\q1 
\v 2 Mimvuezi miama milembo ndandakani mu lumbu kimvimba
\q1 Bawombo balembo nduanisa mu luniemo luawu.
\q1 
\v 3 Mu thangu ndimmona tsisi ;
\q1 ndiela tula diana diama mu ngeyo.
\q1 
\v 4 Mu Nzambi, mutu vuidi mambu ndieti zitisa
\q1 Mu Nzambi ndieti tula diana ;
\q1 ndilendi mona tsisi ko,
\q1 Mutu wowo wumfuanga, mbi kalenda kuphanga e ?
\q1 
\v 5 Mu lumbu kimvimba, beti balula mambu mama ;
\q1 balembo yindula mu zithangu zioso mu kumbonisa phasi.
\q1 
\v 6 Balembo kutakana ;
\q1 balembo suami
\q1 balembo fiongunina zithambi ziama,
\q1 mu nsualu-nsualu batidi bonga luzingu luama.
\q1 
\v 7 Balendi vukila kani mu kipholo kiawu kimosi ko e ?
\q1 Mu nganzi aku, a Nzambi, bedisa makanda
\q1 
\v 8 Sonika maniongo mama
\q1 Lunda matsuela mama mu khutu aku.
\q1 Masi ko mu lutangu luaku e ?
\q1 
\v 9 Buna bambeni ziela vutikisa ku mbusa
\q1 mu thangu ndiela tela mu tomba lusadusu.
\q1 Mu diadi diela zabila ti Nzambi widi ku ndambuꞌama.
\q1 
\v 10 Mu Nzambi mutu vuidi mambu ndieti zitisa
\q1 Mu Yave, mutu vuidi mambu ndieti zitisa.
\q1 
\v 11 Mu Nzambi nditula diana diama,
\q1 ndilendi mona tsisi ko ;
\q1 mutu mbi kalenda ku phanga e ?
\q1 
\v 12 Ndidi ku tsi zindefi ziaku, a Nzambi.
\q1 Ndiela tambika makaba ma phutudulu matondo kuidi ngeyo.
\q1 
\v 13 Bila ngeyo wukhula mu lufua,
\q1 ayi malu mama mu diambu mabika bumina thutu
\q1 muingi ndidiatilanga va ntuala Nzambi,
\q1 mu kiezila ki luzingu.
\c 57
\cl Minkunga 57
\s1 Ndidi mu ndembama va khatitsika bambeni
\d Nkunga Davidi kuidi pfumu minyimbidi “kadi vonda.” Mu thangu kasuamina mu nluka matadi Sawuli bu kaba kunkuka.
\q1 
\v 1 Wumboni kiadi, a Nzambi,
\q1 wumboni kiadi !
\q1 Bila muelꞌama wunsuaminanga mu ngeyo
\q1 ndiela suamina ku kitsusula ki mavavi maku,
\q1 nate mabienga mela mana vioka.
\q1 
\v 2 Ndiela yamikina kuidi Nzambi yizangama ;
\q1 kuidi Nzambi weti dukisa zikhanu ziandi kuidi minu.
\q1 
\v 3 Weti fidisa tona ku diyilu ayi weti kuphukisa ;
\q1 mu temina bobo beti kundandakana mu kingolo ;
\q1 Nzambi weti fidisa luzolo luandi
\q1 ayi kikhuikizi kiandi.
\q1 
\v 4 Ndidi va khatitsika zikhosi ;
\q1 ndidi wulambalala va khatitsika bibulu bindianga minsuni ;
\q1 batu bobo meno mawu madi banga madionga mafioti ayi maneni
\q1 ludimi luawu luidi sabala yisekoso ngolo.
\q1 
\v 5 Yayusu kuaku, a Nzambi, ku yilu diyilu
\q1 Bika nkembo aku wuba va ntoto wumvimba !
\q1 
\v 6 Batambila malu mama dikondi.
\q1 Ndiba wukomvama mu ziphasi ;
\q1 Bakaba dibulu dinnene mu nsolo ama :
\q1 vayi bawu veka ba buidi muawu.
\q1 
\v 7 Ntimꞌama widi wukinda a Nzambi ;
\q1 ntimꞌama widi wukinda.
\q1 Ndiela yimbila, ndiela bula miziki.
\q1 
\v 8 Kotuka, muelꞌama !
\q1 Kotukanu, ngeyo Luti ayi ngitala
\q1 ndiela kotula khiesa ki lumbu.
\q1 
\v 9 Ndiela kuzitisa, a Yave, va khatitsika makanda.
\q1 Ndiela kuyimbidila va khatitsika batu.
\q1 
\v 10 Bila luzolo luaku luidi lunneni, luntulanga nate kuna diyilu,
\q1 kikhuikizi kiaku kintulanga nate ku matuti.
\q1 
\v 11 Yayusu kuaku, a Nzambi, ku yilu Diyilu.
\q1 Bika nkemboꞌaku wuba va ntoto wumvimba !
\c 58
\cl Minkunga 58
\s1 Nzambi widi zuzi disonga
\d Nkunga Davidi kuidi pfumu minyimbidi “kadi vonda”.
\q1 
\v 1 A buevi, beno bapfumu, mu busonga lueti yolukilanga e ?
\q1 Mu bufuana lueti sambisilanga batu e ?
\q1 
\v 2 Nana ! Mu mintima mieno, lueti yindula makambulu masonga
\q1 ayi mioko mieno milembo muangisa makhemi va ntoto.
\q1 
\v 3 Tona mu mbutukulu, batu bambimbi beti zimbala ;
\q1 tona mu vumu, ntu ngolo badi ayi bantubanga luvunu.
\q1 
\v 4 Mitsa miawu midi banga mitsa mi nioka,
\q1 banga kusa kizibikidi matu mandi
\q1 
\v 5 kinkambu wa mbembo yi batu bansakisanga zinioka ;
\q1 mbembo yi ndoki yiyenda tsangu.
\q1 
\v 6 Kola meno mu miunu miawu, a Nzambi ;
\q1 vuza, a Yave, meno ma zikhosi.
\q1 
\v 7 Bika balalakana banga maza ma nkumba !
\q1 Mu thangu bambansula mimbasa miawu,
\q1 bika madionga mawu maba makambu tsongi
\q1 
\v 8 banga khodi yinsiuta bu yilembo diati ;
\q1 banga muana wusuluka bika kabika mona thangu.
\q1 
\v 9 Tuamina zinzungu zieno zimona diamu di zitsendi
\q1 ziba zinlangu voti ziyuma,
\q1 batu bambimbi bela kombulu.
\q1 
\v 10 Basonga bela mona khini
\q1 bu bela mona landi kioki bela kuba vutudila ;
\q1 bela sukula malu mawu mu menga ma batu bambimbi.
\q1 
\v 11 Batu bela tuba :
\q1 “Bukiedika ; basonga bantambulanga mfutu mu kadika thangu.
\q1 Bukiedika vadi Nzambi weti sambisa va ntoto.”
\c 59
\cl Minkunga 59
\s1 Nzambi ama, wukhudi.
\d Nkunga Davidi kuidi pfumu minyimbidi “Kadi vonda” mu thangu Sawuli kafidisa batu bazungidila nzo Davidi mu diambu bamvonda.
\q1 
\v 1 Wukhula mu bambeni ziama, a Nzambi ;
\q1 wukhebi mu diambu bobo bamfuemini !
\q1 
\v 2 Wukhudi mu mimvangi mi mambimbi
\q1 ayi wuphukisa mu mintengudi mi menga.
\q1 
\v 3 Tala phila balambididi mu kuphingila.
\q1 Batu badi ngolo bandiendidi manenga
\q1 bika sia ti mu diambu di
\q1 nzimbala yama voti mu diambu di disumu diama, a Nzambi.
\q1 
\v 4 Kadi mbimbi ndisia vanga ko
\q1 vayi bakubimini mu kunduanisa
\q1 kotuka mu kutsadisa
\q1 tala phila ndikila.
\q1 
\v 5 A Yave, Nzambi nkua ngolo yoso,
\q1 Nzambi yi Iseli, kotuka mu tumbudila makanda moso ;
\q1 kadi mona kadi kiadi
\q1 kuidi bobo beti vanga mambimbi.
\q1 
\v 6 Bamvutukanga va masika,
\q1 beti lola banga zimbua ;
\q1 ayi beti zungidila divula.
\q1 
\v 7 Tala, momo balembo luki mu miunu miawu.
\q1 Bisabala bidi mu bididi biawu.
\q1 Ayi balembo tubi :
\q1 “Nani wulenda kutu wa e ?”
\q1 
\v 8 Vayi ngeyo, a Yave, wulenda basevi ;
\q1 wulembo sekinina makanda moso momo.
\q1 
\v 9 E ngolo ziama, kuidi ngeyo ndintala,
\q1 ngeyo, e Nzambi, widi tinunu kiama ki ngolo.
\q1 
\v 10 Nzambi ama, wukuphangilanga mamboti Nzambi ama yi luzolo
\q1 wela kundengana ; Nzambi wela diata va ntuala ama
\q1 ayi wela kumbonisa khini vadi bobo bakuthubidilanga.
\q1 
\v 11 Vayi kadi kuba vonda, a Yave, nkaku eto,
\q1 bila muna batu bama bela zimbakana.
\q1 Mu lulendo luaku, baba mindiengidi ayi wuba buisi.
\q1 
\v 12 Mu diambu di masumu ma muinu miawu,
\q1 mu diambu di mambu ma bididi biawu,
\q1 bika babuilama mu luniemo luawu.
\q1 Mu diambu di zitsingulu ayi luvunu beti totula,
\q1 
\v 13 Wuba lalikisa mu nganzi aku yi kikhesa ;
\q1 wuba lalikisa muingi babika buela monika
\q1 buna diela zabakana mu zitsuka zi ntoto
\q1 ti Nzambi wunyadila Yakobi.
\q1 
\v 14 Bamvutukanga va masika,
\q1 beti lola banga zimbua,
\q1 ayi beti zungidila divula.
\q1 
\v 15 Bandiengilanga mu diambu di bidia,
\q1 ayi enati bakadi yukuta,
\q1 buna banyamikinanga.
\q1 
\v 16 Vayi minu, ndiela yimbidila zingolo ziaku ;
\q1 muna nsuka, ndiela yimbidila luzolo luaku
\q1 bila ngeyo tinunu kiama kingolo
\q1 ayi suamunu mu zithangu zi ziphasi.
\q1 
\v 17 A ngeyo zingolo ziama,
\q1 ndinyimbila nzitusu mu diambu diaku ;
\q1 ngeyo Nzambi, ngeyo tinunu kiama kingolo ;
\q1 Nzambi ama yi luzolo.
\c 60
\cl Minkunga 60
\s1 Khama mambu, tuela nunga.
\d Nkunga Davidi kuidi pfumu minyimbidi, kayimbidila mu “Lisi” mu diambu di longisa mu thangu kanuana mvita ayi basi Sili ba Mesopotami ayi basi Sili ba Tsoba, ayi mu thangu Yowabi kavutuka ayi kabedisa kumi mafunda muadi ma basi Edomi mu ndimba Mungu.
\q1 
\v 1 Ngeyo wutulozidi, a Nzambi
\q1 ayi wutusasikisidi ; wufuema
\q1 vayi bika buabu wutufuanisa !
\q1 
\v 2 Ngeyo wunikuni ntoto ayi ngeyo wuvasudi wawu ;
\q1 londa miamvu miandi bila wulembo nikuka.
\q1 
\v 3 Ngeyo wumonisini batu baku zithangu ziozi zikambulu diana
\q1 wutuvana vinu kindiengisanga ntu.
\q1 
\v 4 Vayi kuidi bobo beti kukinzika ngeyo wutelimisi dalapo
\q1 mu diambu di batina va ntuala mimbasa.
\q1 
\v 5 Wutuvukisa ayi wutusadisa mu koko kuaku ku lubakala
\q1 muingi bobo weti zola bakulu.
\q1 
\v 6 Nzambi wuyoluka tona ku buangu kiandi kinlongo :
\q1 “mu ndungunu, ndiela vasa Sikemi,
\q1 ndiela teza ndimba wu Sikoti ;
\q1 
\v 7 Minu phuidi Ngaladi, ayi minu phuidi Manase ;
\q1 Efalayimi yawu nkaku wu ntu ama,
\q1 ayi Yuda nkawꞌama wu kipfumu ;
\q1 
\v 8 Mowabi diawu dibola diodi ndieti yobidila ;
\q1 va yilu Edoni ndiloza zisandales ziama
\q1 ndiela yamikina mu diambu di ndungunu ama mu basi Filisti !”
\q1 
\v 9 Nani wela kundata ku divula di ngolo e ?
\q1 Nani wela kuthuadisa ku Edoni e ?
\q1 
\v 10 Keti ngeyo, e Nzambi, ngeyo wutuloza e ?
\q1 Ngeyo wutuloza ayi wunkambu buela totukanga
\q1 ayi minkangu mi masodi meto.
\q1 
\v 11 Wutuvana lusadusu va ntuala mbeni
\q1 bila lusadusu lu mutu luidi luphamba.
\q1 
\v 12 A Nzambi, tuela nunga
\q1 ayi wela kosikisa bambeni zieto.
\c 61
\cl Minkunga 61
\s1 Wutsueka ku tsi mavevi maku
\d Nkunga Davidi kuidi pfumu minyimbidi ; kayimbidila mu lusinga.
\q1 
\v 1 Wa yamikina kuama, e Nzambi
\q1 tamba dikutu mulusambulu luama
\q1 
\v 2 Tona kusukinina ntoto, ngeyo ndintela ;
\q1 nditela bu ntimꞌama wumevonga ngolo ;
\q1 wundati va mbata dibanga
\q1 diodi dindutidi mu nangama.
\q1 
\v 3 Bila ngeyo wuba suamunu kiama ;
\q1 ngeyo wuba nzo yizangama ayi yingolo
\q1 va ntuala mutu weti kundenda.
\q1 
\v 4 Ndiela zingila mu nzo aku yi ngoto ;
\q1 mu zithangu zioso ayi ndiela suamina
\q1 ku tsi mavavi maku.
\q1 
\v 5 Bila ngeyo, wuwa zikhanu ziama, e Nzambi ;
\q1 ngeyo wuphana kiuka ki batu bobo beti kinzika dizina diaku.
\q1 
\v 6 Buela bilumbu bi luzingu lu ntinu,
\q1 mimvu miandi mu diambu di zitsungu ziwombo.
\q1 
\v 7 Bika kavuanda va kundu ki kipfumu
\q1 va meso ma Nzambi mu zithangu zioso ;
\q1 tula luzolo luaku ayi kikhuikizi kiaku mu kunkeba.
\q1 
\v 8 Buna ndiela yimbidila nzitusu mu diambu di dizina diaku
\q1 mu zithangu zioso ayi ndiela dedikisa zikhanu ziama
\q1 lumbu ka lumbu.
\c 62
\cl Minkunga 62
\s1 Muelꞌama widi mu ndembama mu Nzambi
\d Nkunga Davidi kuidi Yedutuni, pfumu minyimbidi.
\q1 
\v 1 Muelꞌama umbakanga luvovomo mu Nzambi kaka.
\q1 Phulusu ama kuidi niandi yimbanga.
\q1 
\v 2 Niandi kaka ditadi diama
\q1 ayi phulusu ama ;
\q1 niandi suamunu kiama kingolo ;
\q1 Ndilendi bulangana ko.
\q1 
\v 3 Nate zithangu zikua lufueti nuanisina mutu e ?
\q1 Lutombidi beno boso bu kumbuisila e ?
\q1 Banga baka kioki kitengama
\q1 banga luphangu lolo lueka bua e ?
\q1 
\v 4 Balembo nyendila manenga
\q1 muingi bankundumuna va buangu kiandi ki zangama ;
\q1 khini beti mona mu mambu ma luvunu.
\q1 Mu muinu miawu, balembo sakumuna,
\q1 vayi mu khati ntima miawu, balembo singi.
\q1 
\v 5 Ba mu ndembama, a muelꞌama, mu Nzambi kaka !
\q1 Diana diama kuidi niandi dimbanga.
\q1 
\v 6 Niandi kaka ditadi diama ayi phulusu ama ;
\q1 niandi suamunu kiama ki ngolo ;
\q1 Ndilengi bua ko.
\q1 
\v 7 Phulusu ama ayi nzitusu ama kuidi Nzambi bidi ;
\q1 niandi ditadi diama dingolo, suamunu kiama.
\q1 
\v 8 Tulanganu diana dieno mu niandi
\q1 mu thangu zioso, a batu.
\q1 Luyalumuna mintima mieno kuidi niandi
\q1 bila Nzambi niandi suamunu kieto.
\q1 
\v 9 Batu baphamba badi kaka phemo,
\q1 batu banneni badi kaka luvunu ;
\q1 enati babasidi va basikilu, basi kadi kiasa.
\q1 Kubafuba va kimosi, badi kaka phemo.
\q1 
\v 10 Kadi tulanu diana mu vinza bima bingana ;
\q1 voti tula luniemo mu bima bibuivi.
\q1 Ka diambu ko kimvuama kiaku kilembo yilama,
\q1 kadi tula ntimꞌaku mu biawu.
\q1 
\v 11 Khumbu mosi Nzambi utuba,
\q1 zikhumbu zizole ndiwila :
\q1 ti ngeyo, a Nzambi, ngolo widi,
\q1 
\v 12 ayi ti ngeyo, a Yave, widi kiluzolo.
\q1 Bukiedika, wetafuta kadika mutu boso bukasadidi.
\c 63
\cl Minkunga 63
\s1 Mamboti maku maviatukidi luzingu
\d Nkunga Davidi mu thangu kaba mu dikanga di Yuda.
\q1 
\v 1 A Nzambi ! Ngeyo widi Nzambiꞌama,
\q1 mu kiedika ngeyo ndintomba ;
\q1 muelꞌama wulembo moni phuila yi ngeyo ;
\q1 nitu ama tsatu yidi mu kumona mu tsi yi yuma ;
\q1 yibiva ; yikondolo nlangu ;
\q1 
\v 2 Ndimmona mu buangu kinlongo
\q1 ndimona lulendo luaku ayi nkembo aku.
\q1 
\v 3 Bila luzolo luaku luviatukidi luzingu ;
\q1 bididi biama biela kukembisa.
\q1 
\v 4 Ndiela kuzitisa thangu yoso ndidi moyo.
\q1 Mu diambu di dizina diaku, ndiela vumuna mioko miama ku yilu.
\q1 
\v 5 Muelꞌama wela yukuta banga kimvuama kiwombo ki bidia
\q1 mu minkunga bididi bi munu ama biela kuzitisa.
\q1 
\v 6 Va mbukꞌama ndikutebukilanga moyo
\q1 ndieti kuyindula builu bu mvimba.
\q1 
\v 7 Bila ngeyo lusadusu luama,
\q1 ayi ndilembo yimbila ku tsi kitsusula ki mavavi maku.
\q1 
\v 8 Muelꞌama widi wukangama mu ngeyo ;
\q1 ayi koko kuaku kulubakala kueti kukhindisa.
\q1 
\v 9 Bobo beti tomba luzingu luama bela bungana ;
\q1 bela kota kuna tsi ntoto.
\q1 
\v 10 Bela kuba yekula mu lulendo lu sabala ;
\q1 bela kituka bidia bi zimbua zi nsitu.
\q1 
\v 11 Vayi Ntinu wela mona khini mu Nzambi ;
\q1 baboso bobo banleva ndefi mu dizina di Nzambi bela kunzitisa.
\q1 Bila miunu mi bankua luvunu miela kangama.
\c 64
\cl Minkunga 64
\s1 Wukheba
\d Nkunga Davidi kuidi pfumu minyimbidi.
\q1 
\v 1 Wungwa, a Nzambi, bu ndilembo wakikisa maniongo mama
\q1 keba luzingu luama va ntuala mbeni yoyi
\q1 ndieti mona tsisi !
\q1 
\v 2 Wutsueka mu zikhanu zintotukilanga
\q1 mu lukutukunu lu nsueki lu batu bambimbi
\q1 ayi mu lukutukunu lu nkangu wu batu bamvanganga mambimbi ;
\q1 bobo badi bulawu.
\q1 
\v 3 Balembo bengula ludimi luawu banga sabala ;
\q1 bantotulanga mambu mawu banga madionga meti vonda.
\q1 
\v 4 Beti lozila bu badi mu bibuangu bisuama
\q1 mutu kambulu zaba diambu
\q1 Beti kunlozila mu kinzimbukila, mu kambu mona tsisi.
\q1 
\v 5 Beti kukikindisa mu zikhanu zimbimbi ;
\q1 beti tubana mu diambu di batamba mintambu miawu,
\q1 Beti kamba : “A nani wela mimona e ?”
\q1 
\v 6 Beti yindula mambu makambulu masonga ayi beti tuba :
\q1 “Tukubikidi lukanu lu fuana.”
\q1 Bukiedika, mayindu ma tsi ntima
\q1 ayi ntima wu mutu thipula bidi.
\q1 
\v 7 Vayi Nzambi wela kuba lozila madionga mandi
\q1 mu kinzimbukila bela.
\q1 
\v 8 Wela balula ludimi luawu veka mu diambu diawu
\q1 ayi kuba nata ku mbivusu
\q1 babo bela kuba mona bela nikuna ntu.
\q1 
\v 9 Batu boso bela mona tsisi,
\q1 bela yamikisa mavanga ma Nzambi ;
\q1 ayi bela sudika momo kavanga.
\q1 
\v 10 Bika mutu wusonga kamona khini mu Yave
\q1 ayi katombila suamunu mu niandi
\q1 ayi babo badi mintima mi lulama banzitisa.
\c 65
\cl Minkunga 65
\s1 Ngeyo weti kutuwokisila bima
\d Nkunga Davidi kuidi pfumu minyimbidi.
\q1 
\v 1 A Nzambi, nzitusu wulembo ku vingidila mu Sioni
\q1 kuidi ngeyo tuela dukisa zindefi zieto.
\q1 
\v 2 Ngeyo weti wa lusambulu ;
\q1 batu boso bela kuiza kuidi ngeyo.
\q1 
\v 3 Mu thangu tufietukusu kuidi masumu ;
\q1 ngeyo wutulemvukila mu zinzimbala zieto.
\q1 
\v 4 Lusakumunu kuidi bobo wusobula
\q1 ayi bobo wunata mu ba va widi
\q1 muingi bazingila mu luphangu luaku.
\q1 Tuidi bayukuta mu bima bimboti bi nzo aku,
\q1 bi nzo aku yinlongo.
\q1 
\v 5 Ngeyo wutuveni mvutu ayi ndambu tsisi mu mavanga ma busonga.
\q1 A Nzambi, Mvulusi eto,
\q1 ngeyo diana di zitsukusunu zioso zi ntoto
\q1 ayi di mimbu milutidi tatuka.
\q1 
\v 6 Ngeyo wuvanga miongo mu lulendo luaku ;
\q1 ngeyo veka wukivuika zingolo.
\q1 
\v 7 Wunlembikanga biyoko bi mimbu,
\q1 biyoko bi mayo mandi ayi khindu yi makanda.
\q1 
\v 8 Batu bobo banzingilanga ku thama
\q1 bela mona tsisi matsiminanga maku,
\q1 kuna kueti totukila thangu ayi ku keti diamina,
\q1 ngeyo wutela kuawu minkunga mi khini.
\q1 
\v 9 Ngeyo wuyiza tala ntoto ayi wuwuvana nlangu ;
\q1 wuvana wawu bima buwombo.
\q1 Mila mi Nzambi midi miwala nlangu.
\q1 Ngeyo weti kubikila batu makundi
\q1 bila ngeyo wutumina buawu.
\q1 
\v 10 Weti lembila minkala miandi
\q1 ayi wulembo ladikisa makumutu mandi ma ntoto
\q1 ayi wulembo lebisa wawu mu masala ;
\q1 wulembo sakumuna bikunusu biandi.
\q1 
\v 11 Ngeyo weti manisina mvu mu mamboti maku ;
\q1 bima biwombo bilembo sapika mu zisaleti ziaku\f + \fr 65.11 \fq Zisaleti\fqa  : \ft bima bi matoma.\f*
\q1 
\v 12 Bibuangu bieti mena biti mi dikanga bilembo sapika
\q1 zikhundubula zilembo vuati khini.
\q1 
\v 13 Mamemi mafulukidi mu bibuangu bieti mena biti ;
\q1 mindimba mifulukidi mu makundi ;
\q1 milembo yamikina mu khini ayi yimbila.
\c 66
\cl Minkunga 66
\s1 Bika Nzambi wutukula kazitusu
\d Nkunga kuidi pfumu minyimbidi.
\q1 
\v 1 Ntoto wumvimba, yamikinanu mu khini kuidi Nzambi,
\q1 
\v 2 Yimbilanu nkembo wu dizina diandi.
\q1 Kitulanu nzitusu andi nzitusu wu nkembo !
\q1 
\v 3 Kambanu Nzambi : mavanga maku tsisi madi !
\q1 Lulendo luaku luidi lunneni
\q1 diawu bambeni ziaku zilembo kukikulula.
\q1 
\v 4 Ntoto wumvimba weti komvama va ntualꞌaku
\q1 ayi bela yimbila minzitusu kuidi ngeyo ;
\q1 bela yimbila minzitusu kuidi dizina diaku.
\q1 
\v 5 Yizanu, lutala momo Nzambi kavanga.
\q1 Mavanga madi tsisi madi kuidi batu.
\q1 
\v 6 Wukitula mbu ntoto wuyuma ;
\q1 basabukila nlangu wunneni mu malu :
\q1 Yizanu tumona khini mu niandi.
\q1 
\v 7 Wunyadilanga mu lulendo luandi
\q1 mu zithangu zioso ;
\q1 Meso mandi mantalanga makanda ;
\q1 bika bankua matingu babika kumfuemina.
\q1 
\v 8 Zitisanu Nzambi eto, a batu
\q1 bika biyoko bi nzitusu andi biwakana ngolo.
\q1 
\v 9 Niandi wutanini luzingu lueto
\q1 ayi wukeba malu meto mabika sialumuka.
\q1 
\v 10 Bila ngeyo, a Nzambi, wutumeka
\q1 ngeyo wutuvedisa banga palata.
\q1 
\v 11 Wutukotisa mu nloko,
\q1 ngeyo wutula mimfuna mu luketo lueto.
\q1 
\v 12 Ngeyo wutala ti batu batudiatidila mu mintu mieto ;
\q1 beto tukota ku mbazu ayi mu nlangu,
\q1 vayi wutunata ku buangu kidi bima biwombo.
\q1 
\v 13 Ndiela kuiza mu nzo aku ayi makaba mayoko ;
\q1 ayi dukisa zindefi ziama kuidi ngeyo.
\q1 
\v 14 Zindefi ziozi bididi biama bivanina tsila
\q1 ayi ziosi ziyolukila munu ama
\q1 mu thangu ndiba mu phasi.
\q1 
\v 15 Ndiela tambika bibulu bi mafuta kuidi ngeyo
\q1 ayi makaba ma mamemi ma mbakala ;
\q1 ndiela tambika zingombi ayi zikhombo zimbakala.
\q1 
\v 16 Yizanu, ayi ludimba beno boso lueti kinzika Nzambi
\q1 bika ndilukamba momo kavengi mu diambu diama.
\q1 
\v 17 Ndiyamikina kuidi niandi mu munu ama,
\q1 nzitusu andi wuba mu ludimi luama.
\q1 
\v 18 Enati ndiyayisa masumu mu ntimꞌama,
\q1 nganu Yave kasia diamba ko.
\q1 
\v 19 Vayi bukiedika Nzambi wudimba
\q1 ayi wuwa mbembo ama mu lusambulu.
\q1 
\v 20 Nzitusu wuba kuidi Nzambi,
\q1 niandi kasia loza ko lusambulu luama ;
\q1 voti kasia botula ko luzolo luandi mu minu.
\c 67
\cl Minkunga 67
\s1 Bika batu boso bazitisa Nzambi
\d Nkunga kuidi pfumu minyimbidi, kayimbidila mu ngitala.
\q1 
\v 1 Bika Nzambi katusila nlemvo ayi katusakumuna ;
\q1 ayi zizi kiandi kitukienzula ;
\q1 
\v 2 muingi zinzila ziaku zizabakana va ntoto,
\q1 phulusu aku yizabakana
\q1 muidi makanda moso !
\q1 
\v 3 Bika batu bazitisa, a Nzambi ;
\q1 bika batu boso bazitisa.
\q1 
\v 4 Bika makanda mayangalala
\q1 ayi mayimbila mu diambu di khini
\q1 bila ngeyo weti yadila batu mu busonga ;
\q1 ngeyo wela diatisa makanda ma ntoto.
\q1 
\v 5 Bika batu bazitisa, a Nzambi ;
\q1 bika batu boso bazitisa.
\q1 
\v 6 Buna ntoto wuela buta mimbutu miandi ;
\q1 Nzambi, Nzambi eto, wela kutusakumuna.
\q1 
\v 7 Nzambi wela kutusakumuna
\q1 ayi zitsuka zioso zi ntoto ziela kunkinzika.
\c 68
\cl Minkunga 68
\s1 Ndungunu yi Nzambi
\d Nkunga Davidi kuidi pfumu minyimbidi.
\q1 
\v 1 Bika Nzambi katelama ;
\q1 bika bambeni bandi zisasukusu ayi bobo beti kunlenda
\q1 bantina va ntualꞌandi.
\q1 
\v 2 Banga bueti lalikinina muisi mu phemo, bika wuba lalikisa ;
\q1 banga bueta siutila sile\f + \fr 68.2 \fq Sile\fqa  : \ft phila mafuta mansadulungu mu mafuta ma niosi ; meti vindungu mu mabaya.\f* ku mbazu
\q1 bika batu bambimbi babungana va meso ma Nzambi.
\q1 
\v 3 Vayi bika batu basonga bamona khini ;
\q1 ayi bayangalala va ntuala Nzambi,
\q1 bika bamona mayangi ayi khini yingolo.
\q1 
\v 4 Yimbidilanu Nzambi ; yimbidilanu minzitusu mu diambu di dizina diandi ;
\q1 yayisanu mutu wowo wundiatila va phunda mu matuti
\q1 Dizina diandi Yave ;
\q1 ayi lumona khini va ntualꞌandi.
\q1 
\v 5 Nzambi niandi widi dise di bisana ayi
\q1 niandi weti nuanina mafuola.
\q1 Mu buangu kiandi kinlongo kioki keti vuanda.
\q1 
\v 6 Nzambi wumvananga dikanda kuidi bobo
\q1 badi bawu veka ;
\q1 niandi weti tuadisa basi nloko mu ngimbudulu
\q1 vayi bankua matingu bawu banzingilanga mu ntoto wu yuma.
\q1 
\v 7 Mu thangu wutuaminina
\q1 batu baku ku ntuala, a Nzambi,
\q1 mu thangu mu dikanga,
\q1 
\v 8 ntoto wunikuka, diyilu dinokisa mvula va ntualꞌaku.
\q1 Va ntuala Nzambi, mutu wu Sinayi
\q1 va ntuala Nzambi, Nzambi yi Iseli.
\q1 
\v 9 Ngeyo wunokisa masala mawombo, a Nzambi ;
\q1 ngeyo wukindisa kiuka kiaku mu thangu kivonga.
\q1 
\v 10 Batu baku bavuanda muawu
\q1 A Nzambi, mu mamboti maku,
\q1 ngeyo wukubika bima mu diambu di nsukami.
\q1 
\v 11 Yave wutuba diambu dimosi :
\q1 batu bawombo bamonika mu yamikisa mawu.
\q1 
\v 12 Mintinu ayi minkangu mi masodi
\q1 milembo tini mu thinu nsualu,
\q1 mu bika bi batu, batu bakabula biobi baziona mu mvita.
\q1 
\v 13 Lukidi kueno leki va khatitsika bidikulu bi bibulu
\q1 mavavi ma dibembi diama mavindu palata,
\q1 zitsala ziandi zivindu nolo yilembo lezama.
\q1 
\v 14 Thangu Nzambi nkua ngolo yoso kasasikisa mintinu va ntoto,
\q1 yiba banga yi matadi ma phembi.
\q1 
\v 15 Miongo mi Basani midi miongo mi nzitusu ;
\q1 miongo mi Basani midi miongo midi zitsongi ziwombo.
\q1 
\v 16 A bila mbi luntadila mu kikhenene,
\q1 e beno miongo midi zitsongi ziwombo ;
\q1 mongo wowo kasobula mu yadila,
\q1 kuna niandi veka Yave kela vuandanga mu zithangu zioso.
\q1 
\v 17 Matoma ma mvita\f + \fr 68.17 \fq Matoma ma mvita\fqa  : \ft voti saleti.\f* ma Yave
\q1 madi dikumi di zimili ayi zimili yi zimili ;
\q1 Yave wutotukila ku Sinayi mu buangu kiandi kinlongo.
\q1 
\v 18 Thangu wukuma ku yilu,
\q1 wunata mu ntandꞌaku batu bakangama.
\q1 Wutambula makaba kuidi batu ayi kuidi bankua matingu
\q1 muingi ngeyo, a Yave Nzambi wuvuanda kuna.
\q1 
\v 19 Nzitusu kuidi Yave, kuidi Nzambi mvulusi eto.
\q1 Niandi weti kutunatina bizitu bieto lumbu ka lumbu.
\q1 Niandi Nzambi wukutuvananga phulusu.
\q1 
\v 20 Nzambi eto widi Nzambi weti vukisa.
\q1 Yave, mutu wumvanganga momo kazodidi, wumvukisanga mu lufua.
\q1 
\v 21 Bukiedika, Nzambi wela kosikisa mintu mi bambeni bandi ;
\q1 wela kosikisa mintu mi batu bobo badi zitsuki ziwombo,
\q1 bobo bandiatilanga mu masumu mawu.
\q1 
\v 22 Pfumu tubidi :
\q1 “Ndiela kuba totula mu Basani,
\q1 ndiela kuba totula ku tsina yi mbu,
\q1 
\v 23 Muingi wubuika malu maku mu menga
\q1 ma bobo beti kulenda ayi ludimi lu zimbua ziaku
\q1 lubaka kuku kiawu.”
\q1 
\v 24 Ndiatulu aku yimonika, a Nzambi.
\q1 Ndiatulu yi Nzambi ama,
\q1 ayi yi ntinu ama mu buangu kinlongo.
\q1 
\v 25 Minyimbidi miba ku ntuala ;
\q1 bosi minsiki mi miziki miba landakana,
\q1 miba va kimosi bana ba baketo bansika zindungu.
\q1 
\v 26 Bika luzitisa Nzambi mu lukutukunu lunneni,
\q1 Luzitisa Yave mu dikabu di Iseli !
\q1 
\v 27 Kuna kuidi dikanda di fioti di Benzami, wuba tuadisa,
\q1 kuna kuba batu bawombo banneni ba Yuda
\q1 ayi batu banneni ba Zabuloni ayi ba Nefitali.
\q1 
\v 28 Tumina lulendo luaku, a Nzambi.
\q1 Wutumonisa zingolo ziaku, a Nzambi
\q1 banga bobo wutuama vangila.
\q1 
\v 29 Mu diambu di nzo aku ku Yelusalemi ;
\q1 mintinu miela kunatina makaba.
\q1 
\v 30 Tubidila bulu va khatitsika masoso\f + \fr 68.30 \fq Bulu va khatitsika masoso\fqa  : \ft dinsundula Ezipite\f*
\q1 nkangu zingombi zi mbakala va khatitsika
\q1 bana zingombi\f + \fr 68.30 \fq Zingombi zi mbakala va khatitsika bana zingombi\fqa  : \ft dinsundula bapfumu ba Ezipite.\f* zi makanda.
\q1 Bu kakululu, wulenda nata bitini bi palata.
\q1 Sasikisa makanda mona khini mu
\q1 nuana mvita !
\q1 
\v 31 Batu bafidusu bela totukila mu Ezipite ;
\q1 Kusi wela kukiyekula niandi veka ku tsi minsua mi Nzambi.
\q1 
\v 32 Yimbidilanu Nzambi beno bipfumu bi ntoto ;
\q1 yimbilanu minzitusu kuidi Yave ;
\q1 
\v 33 Kuidi mutu wowo wundiatila banga va mbata phunda
\q1 mu diyilu, mu diyilu di khulu.
\q1 Mutu wowo wulembo dumu mu mbembo yi lulendo.
\q1 
\v 34 Luyamikisa lulendo lu Nzambi
\q1 nzitusu andi widi va mbata Iseli
\q1 lulendo luandi luidi mu matuti.
\q1 
\v 35 Tsisi widi, a Nzambi,
\q1 mu buangu kiaku kinlongo.
\q1 Nzambi yi Iseli niandi weti vana lulendo
\q1 ayi zingolo kuidi batu bandi.
\q1 Nzitusu wuba kuidi Nzambi.
\c 69
\cl Minkunga 69
\s1 A Nzambi wuphukisa
\d Nkunga Davidi kuidi pfumu minyimbidi kayimbidila mu “LISI”.
\q1 
\v 1 Wuphukisa, a Nzambi,
\q1 bila minlangu mitudidi nate mu dinga diama.
\q1 
\v 2 Ndilembo diami mu nyamba wungolo ;
\q1 kuna kukambulu buangu ki singikila kulu ;
\q1 khotidi nate ku tsi nlangu widi thipula
\q1 mayo mambinini.
\q1 
\v 3 Mbeni vonga mu diambu di telanga lusadusu
\q1 dinga diama dieka yuma,
\q1 meso mama malembo vongi mu talanga Nzambi ama.
\q1 
\v 4 Bobo bakundendanga mu kambu bila
\q1 badi bawombo viokila zitsuki zi ntuꞌama ;
\q1 bawombo badi bambeni ziama mu kambu bila
\q1 bobo bantomba kumbunga.
\q1 Ndilembo kuiku mu vutula biobi ndisia yiba ko.
\q1 
\v 5 Ngeyo zebi buvungisi buama, a Nzambi
\q1 zinzimbala ziama zisiko zisuama kuidi ngeyo.
\q1 
\v 6 Bika batu bobo bantulanga diana mu ngeyo babika fua tsoni
\q1 mu diambu diama ! A Yave, Yave nkua ngolo yoso
\q1 bika bobo bakutombanga
\q1 babika ba dio kombolo mu diambu diama, a Nzambi yi Iseli.
\q1 
\v 7 Bila mu diambu diaku ndinkininina lenzo
\q1 ayi tsoni yifukidi zizi kiama ;
\q1 
\v 8 Ndieka nzenza kuidi bakhomba ziama ;
\q1 ayi nkibi kuidi bana ba ngudi ama.
\q1 
\v 9 Bila luzolo mu diambu di nzo aku lulembo nzinisa.
\q1 Ayi bifingu bi batu bobo bakufinganga
\q1 bibuidi va minu.
\q1 
\v 10 Bu ndieti dila ayi ndieti kifuisa nzala
\q1 mu diambu di lusambulu.
\q1 Buna mfueti kikinina lenzo
\q1 
\v 11 Bu ndieti vuata tsaku,
\q1 batu beti kukhitula savu.
\q1 
\v 12 Bobo bavuendi va muelo, minu bansekinina
\q1 ayi ndieti nkunga wu bakolo-mbungu.
\q1 
\v 13 Vayi, kuidi ngeyo, ndieti sambila, a Yave ;
\q1 mu thangu yi nlemvo aku,
\q1 mu luzolo luaku lunneni, a Nzambi
\q1 bika wuphana mvutu mu phulusu aku yi kiedika !
\q1 
\v 14 Wuthotula mu nyamba, kadi tala ti ndidiama.
\q1 Bika wukhula mu batu bobo beti kundenda
\q1 mu minlangu midi thipula !
\q1 
\v 15 Kadi tala ti khuka yi nlangu yimbina
\q1 voti tsi yi minlangu yi ndalumuna
\q1 voti dibulu ndinzibila munu andi.
\q1 
\v 16 Bika wuphana mvutu Yave
\q1 boso buididi mamboti ma luzolo luaku ;
\q1 mu kiadi kiaku kinneni ;
\q1 bika wubaluka kuidi minu.
\q1 
\v 17 Kadi suekila kisadi kiaku zizi kiaku ;
\q1 wuphani mvutu mu nsualu nsualu bila mu phasi ndidi.
\q1 
\v 18 Fikama ayi wukhudi ;
\q1 Khudi mu diambu di bobo beti kundenda !
\q1 
\v 19 Ngeyo zebi buevi ndidi wulenzo,
\q1 ndidi dio kombolo ayi ndidi mu tsoni
\q1 Bambeni ziama zioso zidi va ntualꞌaku.
\q1 
\v 20 Nlenzo wukosikisidi ntimꞌama
\q1 ayi wumbika kadi lusadusu
\q1 nditomba bambona kiadi, vayi kusia monika kadi mutu ko ;
\q1 mu diambu di mimbombi, vayi ndisia bakula kadi mutu ko.
\q1 
\v 21 Batudidi biyimbu mu bidia biama,
\q1 ayi banduikisa vini ki ngami
\q1 mu phuila yiba yama.
\q1 
\v 22 Bika meza batula va ntualꞌawu yikituka dikondi
\q1 yikituka mfutu ayi ntambu.
\q1 
\v 23 Bika meso mawu maba mu tombi
\q1 ayi mabika buela mona ;
\q1 ayi manima mawu maba ma komvama mu zithangu zioso.
\q1 
\v 24 Wuba dukuidila miangu miaku mi ngolo
\q1 ayi bika nganzi aku yi ngolo yiba buila.
\q1 
\v 25 Bika buangu kiawu kikitunga dikanga
\q1 kubika buela monika mutu wumvuanda mu zinzo ziawu zi ngoto.
\q1 
\v 26 Bila balembo yamisa batu bobo wulueka ;
\q1 beti yolukila ziphasi zi batu bobo wumonisa phasi
\q1 
\v 27 Wuba yekudila mambimbi va yilu mambimbi
\q1 kadi tala ti babaka kuku mu phulusu aku.
\q1 
\v 28 Bika bakubulu mu buku yi luzingu,
\q1 ayi babika tangu va kimosi ayi batu basonga !
\q1 
\v 29 Ndidi mu phasi ayi mu mabienga
\q1 bika phulusu aku, a Nzambi yikheba
\q1 
\v 30 Ndiela zitisanga dizina di Nzambi mu nkunga,
\q1 ayi ndiela kunkembisa
\q1 mu phutudulu matondo.
\q1 
\v 31 Buna diodi diela luta monisa Yave khini
\q1 viokila ngombi yimbakala,
\q1 viokila ngombi yidi ziphoka ayi bikodi bivasuka.
\q1 
\v 32 Nsukami wela mona ayi wela yangalala ;
\q1 beno lueti tomba Nzambi,
\q1 bika mintima mieno mizinga.
\q1 
\v 33 Yave weti wila nsukami
\q1 ayi kalenzanga ko batu bandi bakangama.
\q1 
\v 34 Bika Diyilu ayi ntoto binzitisa,
\q1 mimbu ayi bibioso bieti
\q1 diatanga muawu.
\q1 
\v 35 Bila Nzambi wela vukisa Sioni,
\q1 ayi wela buela tunga mavula ma Yuda,
\q1 buna batu bela kala muawu ayi kuma vua
\q1 
\v 36 Mela ba kiuka ki bana ba bisadi biandi,
\q1 ayi bobo beti zolanga dizina diandi
\q1 bela vuandanga mawu.
\c 70
\cl Minkunga 70
\s1 Nzambi yiza wutsadisa
\d Nkunga Davidi kuidi pfumu minyimbidi mu diambu di thebokolo moyo.
\q1 
\v 1 Yiza nsualu, a Nzambi, mu kukhula !
\q1 Yave, yiza nsualu mu kutsadisa !
\q1 
\v 2 Bika bobo bantomba luzingu luama
\q1 bafua tsoni ayi baba dio kombolo !
\q1 Bika bobo bantomba mbivusu ama
\q1 bavutuka ku mbusa ayi bafua tsoni.
\q1 
\v 3 Bika bobo beti tuba kuidi minu : “A… A…”
\q1 bavutuka ku mbusa mu diambu di zitsoni ziawu.
\q1 
\v 4 Babo bakutombanga bamona khini
\q1 ayi bayangalala mu ngeyo ;
\q1 bika bobo banzolanga phulusu aku
\q1 batubanga mu zithangu zioso :
\q1 “Bika Nzambi kayayusu.”
\q1 
\v 5 Vayi minu ndidi nsukami ayi nkua kiadi
\q1 yiza nsualu kuidi minu, a Nzambi !
\q1 Ngeyo nsadisi ama ayi nkudi ama ;
\q1 A Yave kadi zingila !
\c 71
\cl Minkunga 71
\s1 Kadi kundiekula mu bununu buama
\q1 
\v 1 Mu ngeyo, a Yave, ndisuamina
\q1 kadi tala ti ndifua tsoni kadi khumbu yimosi !
\q1 
\v 2 Wukhudi ayi wuphukisa mu busonga buaku
\q1 balula dikutu diaku kuidi minu ayi phukisa.
\q1 
\v 3 Ba ditadi diama diodi di kutsuekanga ;
\q1 momo ndilenda kuenda mu zithangu zioso
\q1 vana lutumunu mu kuphukisa
\q1 bila widi ditadi diama
\q1 ayi tinunu kiama ki ngolo.
\q1 
\v 4 Wukhudi Nzambi ama mu mioko mi batu bambimbi ;
\q1 mu mioko mi batu bamvanganga mambimbi ayi mu batu badi tsita.
\q1 
\v 5 Bila ngeyo wuba diana diama, a Yave,
\q1 ngeyo wumvanganga moso wuzodidi.
\q1 Diana diama tona mu bumuana buama.
\q1 
\v 6 Tona ndibutuka, mu ngeyo ndieti singimina ;
\q1 ngeyo wuthotula tona mu vumu ki ngudi ama ;
\q1 Ngeyo ndiela zitisanga mu zithangu zioso.
\q1 
\v 7 Ndieka banga diambu di siminina kuidi bawombo,
\q1 vayi ngeyo suamunu kiama kingolo.
\q1 
\v 8 Munu ama widi wuwala mu nzitusu aku
\q1 wunyamikisa kiezila kiaku mu lumbu kimvimba.
\q1 
\v 9 Kadi kundoza mu thangu ndieka nunu ;
\q1 kadi kundiekula mu thangu zingolo ziama zilembu suki !
\q1 
\v 10 Bila bambeni ziama zilembo thubidila
\q1 bobo balembo tombi kuphonda, balembo wizana va kimosi,
\q1 
\v 11 balembo tubi : “Nzambi wunyekudi,
\q1 nlandakananu,
\q1 bila kuisi ko mutu wufueti ku nkula.”
\q1 
\v 12 Kadi ba thama ayi minu, a Nzambi,
\q1 yiza nsualu Nzambi ama mu kutsadisa !
\q1 
\v 13 Bika mimfundi miama mibungana mu tsoni ;
\q1 bika bobo bantomba kuphanga phasi baba ba lenzo ayi dio kombolo.
\q1 
\v 14 Vayi kuidi minu, ndiela tulanga kaka diana mu zithangu zioso
\q1 buela kuzitisanga ngolo.
\q1 
\v 15 Munu ama wela yolukila busonga buaku
\q1 ayi phulusu aku mu lumbu kimvimba,
\q1 bila ndikadi zaba tezo biawu.
\q1 
\v 16 Ndiela kuiza ayi yamikisa mavanga maku ma lulendo ;
\q1 a Yave, mutu wumvanganga makazodidi
\q1 ndiela yamikisa busonga buaku ; busonga buaku kaka.
\q1 
\v 17 Tona mu bumuana buama, a Nzambi, ngeyo wundonga
\q1 ayi ye lumbu kiaki yayi ndinyamikisanga matsiminanga maku.
\q1 
\v 18 Bobuawu, bu ndiela nuna ayi zitsuki ziphembi
\q1 kadi ku ndiekula, a Nzambi.
\q1 Muingi nditubila lulendo luaku kuidi tsungi yinkuiza,
\q1 zingolo ziaku kuidi babo bela kuiza.
\q1 
\v 19 Busonga buaku buntula nate ku diyilu, a Nzambi.
\q1 Ngeyo wuvanga mambu manneni ;
\q1 nani a Nzambi widi banga ngeyo e ?
\q1 
\v 20 Ngeyo wumbonisa ziphasi ziwombo ayi zindudi ;
\q1 wela buela kuphutudila luzingu ;
\q1 tona ku tsi ntoto, ngeyo wela buela kuthotula.
\q1 
\v 21 Wela buela wokisa nzitusu ama,
\q1 ayi buela ku khindisa diaka.
\q1 
\v 22 Ndiela kuzitisa mu ngitala
\q1 mu diambu di kikhuikizi kiaku, a Nzambi ama ;
\q1 ndiela kuyimbidila minzitusu mu Lila.
\q1 Ngeyo nlongo wu Iseli.
\q1 
\v 23 Bididi biama biela yimbila mu diambu di khini
\q1 mu thangu ndiela kuyimbidila minzitusu,
\q1 minu mutu wowo wukula.
\q1 
\v 24 Ludimi luama luela yolukila mavanga maku masonga
\q1 mu lumbu kimvimba,
\q1 Bila bobo bantomba kumbonisa phasi
\q1 bela fua tsoni ayi bela ba dio kombolo.
\c 72
\cl Minkunga 72
\s1 Lusambulu mu diambu di ntinu
\d Nkunga Salomo.
\q1 
\v 1 Vuika ntinu fuanana kuaku, a Nzambi
\q1 kuidi muana ntinu busonga buaku !
\q1 
\v 2 Niandi wela sambisa batu baku mu busonga
\q1 ayi batu baku badi mu phasi mu bufuana.
\q1 
\v 3 Miongo miela natina batu mamboti ;
\q1 ayi zikhundubula ziela nata mimbutu mi busonga.
\q1 
\v 4 Wela vavila batu mu phasi va khatitsika batu
\q1 ayi wela vukisa bana bansukami
\q1 wela kosikisa mutu wunyamisanga batu.
\q1 
\v 5 Bela kanga ntima thangu bu yikidi
\q1 ngondi bu yikidi mu zitsungi zioso.
\q1 
\v 6 Niangi wela ba banga mvula yinnokina mu tsola yisolo,
\q1 banga mabeti ma disala mambua mu ntoto.
\q1 
\v 7 Mu bilumbu biandi, mutu wusonga wela mona mamboti,
\q1 mamboti mela yilama
\q1 nate ngondi yela zimbala.
\q1 
\v 8 Wela yadilanga tona ku mbu nate ku mbu wunkaka ;
\q1 ayi tona ku nlangu wunneni nate kuna zitsuka zi ntoto.
\q1 
\v 9 Makanda ma dikanga mela
\q1 buongama va ntualꞌandi ayi bambeni bandi
\q1 ziela venda fundu-fundu.
\q1 
\v 10 Mintinu mi Talisi ayi mi bisanga bidi thama
\q1 miela kunnatina phaku
\q1 Mintinu mi Saba ayi mi Seba
\q1 miela kumvana makaba.
\q1 
\v 11 Mintinu mioso miela buongama va ntualꞌandi
\q1 ayi makanda moso mela kunsadilanga.
\q1 
\v 12 Bila wela kula nsukami wulembo yamikina ;
\q1 mutu widi mu phasi kambulu mutu wulenda sadisa.
\q1 
\v 13 Wela mona mutu wulebakana ayi nsukami kiadi
\q1 ayi wela vukisa minsukami mu lufua.
\q1 
\v 14 Wela kula kuba kula mu khuamusu ayi mu makhemi
\q1 ayi menga mawu thalu madi va meso mandi.
\q1 
\v 15 Bika kazinga !
\q1 Bika baba kumvana nolo yela ba ku Saba ;
\q1 Bika batu bansambila mu zithangu zioso,
\q1 ayi bela kunsakumuna mu lumbu kimvimba.
\q1 
\v 16 Bika makundi maba mawombo mu tsi
\q1 nate va mbata miongo
\q1 ayi bika mimbutu miandi mibuta banga Lebanoni
\q1 bika miba mimboti banga biti bi tsola.
\q1 
\v 17 Bika dizina diandi dizingila mu zithangu zioso ;
\q1 bika dizina diandi dizinga thangu bu yikidi lezama.
\q1 Makanda moso mela sakumunu mu niandi
\q1 ayi bela kuntedila mutu wu lusakumunu.
\q1 
\v 18 Nzitusu wuba kuidi Yave Nzambi
\q1 Nzambi yi Iseli,
\q1 Bila niandi veka kaka wumvanganga matsiminanga.
\q1 
\v 19 Nzitusu wuba kuidi dizina diandi
\q1 di nkembo mu zithangu zioso
\q1 Bika ntoto wumvimba wuwala nkembo andi !
\qr Amen ! Amen !
\q1 
\v 20 Vava vasukila zitsambulu zi Davidi, muana Yese.
\c 73
\ms1 BUKU YI NTATU
\cl Minkunga 73
\s1 Bila mbi batu bambimbi beti nungina e ?
\d Nkunga Asafi.
\q1 
\v 1 Bukiedika ; Nzambi widi wumboti kuidi Iseli ;
\q1 kuidi bobo badi mintima mi vedila.
\q1 
\v 2 Vayi kuidi minu, fioti fisiala nganu malu
\q1 mama masialumuka
\q1 fioti fisiala nganu ndizimbisa singumnu ki kulu kuama.
\q1 
\v 3 Bila ndizinina batu ba luniemo
\q1 bu ndimona mamboti ma batu bambimbi.
\q1 
\v 4 Kadi mabienga bamonanga ko
\q1 ayi zinitu ziawu zidi mu bivini ayi zibeki ngolo.
\q1 
\v 5 Bamonanga ko ziphasi ziozi batu boso beti mona ;
\q1 bayamusungu ko mu bimbevo bi mbuanga batu boso.
\q1 
\v 6 Diawu luniemo luidi sieni mu madinga mawu
\q1 baki vuikidi makhemi.
\q1 
\v 7 Mu mintima miawu mi matadi, muntotukila mambimbi
\q1 zikhanu zimbimbi zi mayindu mawu zisi zaba zindilu ko.
\q1 
\v 8 Bamvueza ; banyolukilanga mu bumbimbi ;
\q1 mu lunangu luawu, balembo kubika khuamusu.
\q1 
\v 9 Miunu miawu milembo nuanina diyilu
\q1 ludimi luawu lueti vua ntoto.
\q1 
\v 10 Diawu batu bawu beti baluka kuidi bawu ;
\q1 beti nuanga nlangu mu buwombo.
\q1 
\v 11 Beti tubanga : “Buevi Nzambi kela zabila e ?
\q1 Nzambi yizangama beki nzayilu e ?”
\q1 
\v 12 Tala buawu bobo buididi batu bambimbi :
\q1 mu kambu bela kadi diambu dimosi mayindu ko ;
\q1 beti yidikanga kimvuama.
\q1 
\v 13 Bukiedika, mu phamba kuandi ndikebidi ntimꞌama wuvedila
\q1 mu phamba kuandi ndisukudidi mioko miama
\q1 mu monisa kambu kuama ku bila.
\q1 
\v 14 Mu lumbu kimvimba minu nditutu khuba ;
\q1 nditambula thumbudulu kadika nsuka.
\q1 
\v 15 Enati ndituba : “Ndiela tuba banga bawu”,
\q1 Nganu ndivakula bana baku.
\q1 
\v 16 Bu nditomba bu sukudila mambu moso mama
\q1 buna diba khuamusu kuidi minu.
\q1 
\v 17 Nate ndikota mu khati buangu kinlongo
\q1 ki Nzambi,
\q1 buna bosi ndisudika tsukulu awu.
\q1 
\v 18 Bukiedika, ngeyo wukuba tulanga
\q1 mu ntoto widi ndelo ;
\q1 ngeyo weti kuba loza ku mbivusu.
\q1 
\v 19 Babungini mu kinzimbukila
\q1 batumbulu lalakana mu diambu di tsisi yingolo.
\q1 
\v 20 Banga ndozi, mutu bu kakotukidi ;
\q1 buawu bobo bu wela kotuka, a Yave,
\q1 wela kuba lenza banga bima bi phamba.
\q1 
\v 21 Mu thangu ntimꞌama wubedi kiaki
\q1 ayi pheve ama yibedi mu kingongo,
\q1 
\v 22 Minu ndiba vungisi ; ndisia ba nzayilu ko ;
\q1 Ndiba bulu kinsitu va ntualꞌaku.
\q1 
\v 23 Muaki ndidi kaka va kimosi ayi ngeyo mu zithangu zioso ;
\q1 wutsimbidila mu koko kuama ku lubakala ;
\q1 
\v 24 Ngeyo weti kundiatisa mu zindongi ziaku,
\q1 ayi bosi ngeyo wela kuthambula mu nkembo.
\q1 
\v 25 Nani wunkaka widi yama mu Diyilu
\q1 enati ngeyo ko e ?
\q1 Ntoto kasi kadi kima ko kioki ndieti mona phuila enati ngeyo ko e ?
\q1 
\v 26 Nsuni ama ayi ntimꞌama bibeki bu vongila
\q1 vayi Nzambi niandi zingolo zi ntimꞌama
\q1 ayi kuku kiama mu zithangu zioso.
\q1 
\v 27 Bobo badi thama ayi ngeyo bela biva
\q1 ngeyo wela bunga batu boso bobo bakambulu
\q1 bakuikama kuidi ngeyo.
\q1 
\v 28 Vayi kuidi minu, didi diambu di mboti mu fikama Nzambi.
\q1 Ndikitula Yave, mutu wumvanganga makazodidi suamunu kiama.
\q1 Ndiela yolukila mavanga maku moso.
\c 74
\cl Minkunga 74
\s1 Maniongo mu diambu di buangu kinlongo kitiolomono.
\d Nkunga Asafi.
\q1 
\v 1 Bila mbi wutulozidi mu zithangu zioso, a Nzambi e ?
\q1 Bila mbi wufuemini minkangu miaku mi mamemi miomi weti dikila e ?
\q1 
\v 2 Tebukila batu baku moyo ;
\q1 bobo wukibakila thama ;
\q1 dikanda di kiuka kiaku, diodi wukula.
\q1 Mongo wu Sioni, koko wuvuanda.
\q1 
\v 3 Balula zithambi ziaku ku ndambu bibuangu
\q1 bitiolumunu mu mvu ka mvu.
\q1 Zimbivusu zioso ziozi mbeni kavanga mu buangu kinlongo.
\q1 
\v 4 Batu balendidi balembo vomi
\q1 va buangu kioki wutudenginina ;
\q1 batula bidalapo biawu banga dimbu ki ndungunu.
\q1 
\v 5 Badi banga batu bannanguna
\q1 soka mu zenga minti ku nsitu widi khoba.
\q1 
\v 6 Bakosikisa mabaya moso momo bamana fikula
\q1 mu bisoka biawu ayi zi malito ziawu.
\q1 
\v 7 Bazinisa buangu kiaku kinlongo mu mbazu ;
\q1 basumuna buangu kieti vuandanga dizina diaku.
\q1 
\v 8 Babedi tubanga mu mintima miawu : “Tuela kuba kosikisa mvimba”
\q1 Bazinisa mu mbazu bibuangu bioso biobi beti buongimina Nzambi mu tsi.
\q1 
\v 9 Bakadi kutumonisa kadi kumu kimosi
\q1 kusiedi mimbikudi ko.
\q1 Kadi mutu wumosi mu beto zebi keni
\q1 nate thangu mbi mama mela tatamana bela e ?
\q1 
\v 10 Nate thangu mbi mbeni kela kusekinina, a Nzambi e ?
\q1 Nate thangu mbi mutu wundendidi kela lenzilanga
\q1 dizina diaku mu zithangu zioso e ?
\q1 
\v 11 Bila mbi kangidi koko kuaku,
\q1 koko kuaku ku lubakala e ?
\q1 Bonga kuawu mu mimfutu mi kukhutu kiaku ayi wuba bungi.
\q1 
\v 12 Vayi ngeyo Nzambi, ngeyo ntinu ama tona muna tona ;
\q1 ngeyo weti nata phulusu va ntoto.
\q1 
\v 13 Keti ngeyo wuvasa mbu mu lulendo luaku ;
\q1 wukosikisa mintu mi bisimbi bi minlangu ;
\q1 
\v 14 keti ngeyo wukosikisa mintu mi Leviatani\f + \fr 74.14 \fq Leviatani\fqa  : \ft Simbi ki nlangu kidi tsambuadi di mintu.\f*,
\q1 wumvana banga bidia kuidi bibulu bi dikanga
\q1 
\v 15 Keti ngeyo wuzibula zitho zi minlangu ayi mimvuila mi minlangu
\q1 Ngeyo wusikisa minlangu minneni
\q1 miomi mieti kumba mu zithangu zioso.
\q1 
\v 16 Ngeyo vuidi muini, ayi ngeyo vuidi builu ;
\q1 ngeyo wuvanga ngondi ayi thangu.
\q1 
\v 17 Keti ngeyo wumana vanga zindilu zioso zi ntoto,
\q1 ngeyo wuvanga tsungi yi muini wu ngolo
\q1 ayi yi kiozi kingolo.
\q1 
\v 18 Tebuka moyo buevi mbeni kalembo sekinina, a Yave,
\q1 buevi bivungisi balenzila dizina diaku !
\q1 
\v 19 Kadi yekula luzingu lu dibembi diaku kuidi bibulu bi nganzi
\q1 ayi kadi thumbu zimbakana luzingu lu batu
\q1 baku badi mu phasi.
\q1 
\v 20 Bengudila Nguizani aku thalu ;
\q1 bila bisuamunu biyindulungu makhemi bifulukidi
\q1 mu bibuangu bitombi bi ntoto.
\q1 
\v 21 Kadi tala ti mutu wuyamusu
\q1 kavutuka mu tsoni
\q1 Bika nkua kiadi ayi nsukami
\q1 bazitisa dizina diaku.
\q1 
\v 22 Telama a Nzambi ! Wukinungisa !
\q1 Tebukila moyo buevi bivungisi bilembo sekinina
\q1 mu bilumbu bioso.
\q1 
\v 23 Kadi zimbakana biyoko bi bambeni ziaku
\q1 divunzi di bambeni ziaku, diodi dilembo
\q1 buelamanga thangu ka thangu.
\c 75
\cl Minkunga 75
\s1 Nzambi wela sambisa ntoto
\d Nkunga Asafi kuidi pfumu minyimbidi “Kadi vonda”.
\q1 
\v 1 Tueti kuvutudila matondo, a Nzambi.
\q1 Tueli vutula matondo bila dizina diaku didi difikama
\q1 batu balembo yolukila matsiminanga maku.
\q1 
\v 2 Ngeyo tubidi : “tsobudi thangu yifuana
\q1 Keti minu ndieti sambisa mu bufuana.
\q1 
\v 3 Ntoto bu wulembo nikuka va kimosi ayi batu bandi boso
\q1 Keti minu ndisimbidila makunzi mandi.
\q1 
\v 4 Kuidi nkua luniemo, ndintuba : ‘Kadi kukiniemisanga ngolo’
\q1 Kuidi batu bambimbi : ‘lubika vumbula ziphoka zieno.’
\q1 
\v 5 Lubika vumuna ziphoka zieno mu diambu di diyilu ;
\q1 bikanu tubila mu nonumuna madinga !”
\q1 
\v 6 Kadi mutu wumosi tona ku Esite voti ku Wesite
\q1 voti tona ku dikanga wulenda yayisa mutu.
\q1 
\v 7 Vayi Nzambi niandi weti sambisa ;
\q1 niandi weti kulula wunkaka, niandi weti yayisa wunkaka.
\q1 
\v 8 Mu koko ku Yave muidi mbungu yiwala vinu kingolo
\q1 ayi yisobokoso.
\q1 Wulembo dukula kiawu ayi batu boso bambimbi
\q1 badi va ntoto bela nua kiawu
\q1 nate kuna dibomvi.
\q1 
\v 9 Vayi minu, ndiela samunanga mawu
\q1 mu thangu zioso.
\q1 Ndiela yimbidila nzitusu
\q1 kuidi Nzambi yi Yakobi.
\q1 
\v 10 Ndiela zenga ziphoka zi batu boso bambimbi,
\q1 vayi ziphoka zi batu basonga
\q1 luela nanguku.
\c 76
\cl Minkunga 76
\s1 Nzambi niandi vuidi ndungunu
\d Nkunga Asafi kuidi pfumu minyimbidi kayimbidila mu ngitala.
\q1 
\v 1 Mu Yuda, Nzambi zabikini
\q1 Dizina diandi didi dinneni mu Iseli.
\q1 
\v 2 Nzo andi yi ngoto yidi ku Salemi,
\q1 buangu kiandi kidi ku Sioni.
\q1 
\v 3 Kuna kakeludila madionga malembo lemi,
\q1 nkaku ayi sabala, mbedi ayi binuanunu bi mvita.
\q1 
\v 4 Ngeyo lembo lezama mu kiezila,
\q1 lutidi kinzuku viokila miongo miwedi bibulu.
\q1 
\v 5 Makhesa mamana ku baziona bima,
\q1 balembo leki tulu tuawu tutsuka,
\q1 kadi wumosi mu binuani lenda tombula mioko miandi.
\q1 
\v 6 Mu themunuꞌaku, a Nzambi yi Yakobi,
\q1 ziphunda ayi matoma ma mvita\f + \fr 76.6 \fq matoma ma mvita\fqa  : \ft voti matoma ma mvita ma bisengo.\f* bibibiodi biledi tulu tuvindu.
\q1 Bileka tulu tuvindu.
\q1 
\v 7 Ngeyo veka, lembo monisa tsisi !
\q1 Nani wulenda telama va meso maku ngeyo fuema e ?
\q1 
\v 8 Tona kuna Diyilu wuwakikisa nzengolo ;
\q1 ntoto wumona tsisi ayi wutumbu dingalala ;
\q1 
\v 9 Thangu ngeyo, a Nzambi, wutelama mu diambu di sambisa
\q1 ayi mu diambu di vukisa bankwa ziphasi va ntoto.
\q1 
\v 10 Bukiedika nganzi aku kuidi batu yinnatini nzitusu ;
\q1 ayi bobo bavukidi mu nganzi aku, badi basimbudulu.
\q1 
\v 11 Tambikanu zikhanu kuidi Yave Nzambi eno
\q1 ayi dedikisanu ziawu !
\q1 Bika baboso badi mu nzunga ki mintoto,
\q1 banata bakaba kuidi mutu wowo widi tsisi.
\q1 
\v 12 Niandi weti bula phevi minyadi,
\q1 niandi tsisi beta kummona kuidi mintinu mi ntoto.
\c 77
\cl Minkunga 77
\s1 Nzambi wulenda kuandi baluka e ?
\d Nkunga Asafi kuidi Yedutuni, pfumu wu minyimbidi.
\q1 
\v 1 Ndiyamikina kuidi Nzambi mu diambu di lusadusu
\q1 ndiyamikina kuidi Nzambi mu kunguila.
\q1 
\v 2 Thangu ndiba mu ziphasi, nditomba Yave ;
\q1 va builu ndinonuna mioko miama
\q1 mu kambu vonga ;
\q1 ayi muelꞌama wumanga bombo.
\q1 
\v 3 Ndietebukila moyo, a Nzambi, ayi ndikunga ;
\q1 ndiyindula mu tsi ntima ayi pheve ama yivonga ngolo.
\q1 
\v 4 Wekeba meso mama ma bika zibama,
\q1 ndiba diaka mu phasi mu tuba.
\q1 
\v 5 Ndiyindula bilumbu bivioka, mimvu mi thama.
\q1 
\v 6 Ndieti tebukila minkunga miama moyo va builu,
\q1 Ntima ama uyindula ku tsi ntima
\q1 ayi pheve ama yikiyuvula :
\q1 
\v 7 Pfumu wela tumbu loza kuandi mvimba e ?
\q1 Kalendi buela monisa nlemvo andi ko e ?
\q1 
\v 8 Luzolo luandi lungolo lusukidi kuandi mvimba e ?
\q1 Zitsila ziandi mu zithangu zioso
\q1 zikitukidi zi phamba e ?
\q1 
\v 9 Nzambi wuzimbikini kuandi buela monisa nlemvo e ?
\q1 Wuyimini kiadi kiandi mu diambu di nganzi e ?
\q1 
\v 10 Buna ndiyindula “mu diambu diadi ndiela singimina :
\q1 mimvu mi koko ku lubakala ku Nzambi yizangama.”
\q1 
\v 11 Ndiela tebukila moyo mavanga ma Yave,
\q1 bukiedika ndiela tebukila moyo
\q1 bikumu biaku bi thama.
\q1 
\v 12 Ndiela yindulanga mu tsi ntima bisalu biaku bioso ;
\q1 ayi ndiela banzilanga mavanga maku moso ma lulendo.
\q1 
\v 13 Zinzila ziaku, a Nzambi, zidi zinlongo ;
\q1 nzambi mbi widi wunneni banga Nzambi eto e ?
\q1 
\v 14 Ngeyo widi Nzambi yimvanganga bikumu ;
\q1 Ngeyo weti monisa lulendo luaku muidi batu.
\q1 
\v 15 Mu koko kuaku ku lulendo wukuidila batu baku,
\q1 nkuna wu Yakobi ayi wu Zozefi.
\q1 
\v 16 Minlangu mimmona, ngeyo a Nzambi !
\q1 Minlangu mimona ngeyo, ayi mikotadala
\q1 zitsina zi minlangu zi nikuka.
\q1 
\v 17 Matuti madukula minlangu ;
\q1 diyilu diduma mu nzazi
\q1 madionga maku matotuka ku ntuala ayi ku mbusa.
\q1 
\v 18 Zinzazi ziaku ziwakana mu kimbongila ;
\q1 zitsiemo zikienzula ntoto ;
\q1 ntoto wunikuka ayi wutita.
\q1 
\v 19 Nsolo aku wuviokila va khatitsika mbu,
\q1 nzilꞌaku mu minlangu midi nguma,
\q1 muna zithambi ziaku zisia monika ko.
\q1 
\v 20 Wudiatisa batu baku banga nkangu wu mamemi,
\q1 mu koko ku Moyize ayi Aloni.
\c 78
\cl Minkunga 78
\s1 Mambu mavanga Nzambi
\d Nkunga Asafi.
\q1 
\v 1 A batu bama, wanu malongi mama !
\q1 Dimbanu mambu ma munu ama.
\q1 
\v 2 Ndiela zibula munu ama mu tuba zingana
\q1 ayi ndiela samuna mambu ma suama, mambu makhulu ;
\q1 
\v 3 momo tuwa ayi momo tuzaba
\q1 ayi momo bakulu beto batukamba ;
\q1 
\v 4 Tulendi masuekila ko bana bawu ;
\q1 tuela samuna kuidi tsungi yinkuiza
\q1 mavanga ma Yave mafueti zitusu,
\q1 lulendo luandi ayi matsiminanga momo kavanga.
\q1 
\v 5 Wuvana zithumunu mu diambu di Yakobi.
\q1 Wukubika Mina mu Iseli,
\q1 ayi wutumina bakulu beto
\q1 muingi bamilonga kuidi bana bawu ;
\q1 
\v 6 buna tsungi yinkuiza, yela zaba mawu
\q1 buela bana bobo babutuki ko
\q1 ayi bawu mamvawu mu thangu awu
\q1 bela yolukila bana bawu ;
\q1 
\v 7 buna bela tula diana diawu mu Nzambi,
\q1 ayi balendi zimbakana mavanga mandi ko,
\q1 vayi bela keba zithumunu ziandi ;
\q1 
\v 8 Balendi ba banga bakulu bawu ko ;
\q1 tsungi yikambulu bulemvo, ayi tsungi yi matingu ;
\q1 bobo mintima misia ba mifuana ko kuidi Nzambi
\q1 bobo pheve yisia yikuikama kuidi Nzambi ko.
\q1 
\v 9 Batu ba Efalayimi bobo baba ayi mimbasa,
\q1 bavutuka ku mbusa mu lumbu ki mvita.
\q1 
\v 10 Basi keba ko Nguizani yi Nzambi,
\q1 ayi bamanga zingila boso buididi Mina miandi.
\q1 
\v 11 Bazimbakana momo kavanga ;
\q1 matsiminanga momo kabamonisa.
\q1 
\v 12 Wuvanga bikumu va ntuala bakulu bawu
\q1 mu tsi yi Ezipite ; mu zunga ki Tsowani.
\q1 
\v 13 Wuvasa mbu ayi wuba viokila muawu ;
\q1 wutelimisa nlangu dio ngui banga baka.
\q1 
\v 14 Wuba diatisa mu dituti va muini,
\q1 ayi mu kiezila ki mbazu va builu bu mvimba.
\q1 
\v 15 Wubasa matadi mu dikanga,
\q1 ayi wuba vana nlangu wuwombo banga mbu ;
\q1 
\v 16 Wutotula mimvuila minlangu mu ditadi
\q1 ayi wukumbisa minlangu banga minlangu minneni.
\q1 
\v 17 Vayi babuela tatamana sumuka diaka va ntualꞌandi ;
\q1 batinguna Nzambi Yizangama mu dikanga.
\q1 
\v 18 Batota Nzambi mu luzolo lungolo,
\q1 mu lombanga mu kingolo bidia biobi batomba.
\q1 
\v 19 Batubidila Nzambi batuba :
\q1 “Nzambi beki kuandi bu kubikila meza mu dikanga e ?
\q1 
\v 20 Bu kabula ditadi dingolo, mbadi nlangu wutotuka
\q1 ayi mimvuila mikumba mu buwombo
\q1 vayi buna wulendi kuandi kutuvana bidia e ?
\q1 Wulendi kuandi kubika zimbizi mu diambu di batu bandi e ?”
\q1 
\v 21 Yave bu kaba wa, wufuema ngolo,
\q1 mbazu andi yilema mu diambu di Yakobi
\q1 ayi miangu miandi mibuila Iseli.
\q1 
\v 22 Bila basia wilukila Nzambi ko,
\q1 voti basia tula diana diawu mu khudulu andi ko.
\q1 
\v 23 Muaki wuvana lutumunu kuidi matuti ma yilu
\q1 ayi wuzibula mielo mi diyilu ;
\q1 
\v 24 Wunokisa mana mu diambu di batu muingi badia ;
\q1 wuba vana zitheti zi diyilu.
\q1 
\v 25 Batu badia dipha di zimbasi ;
\q1 wuba fidisila bidia bioso biobi balenda dia.
\q1 
\v 26 Wuvevumuna phemo yi Esite mu diyilu.
\q1 Wudiata ku ntuala phemo yi Sude mu lulendo luandi.
\q1 
\v 27 Wuba nokisila zimbizi banga mbungi-mbungi ;
\q1 zinuni zieti dumuka banga nzielo yi mbu.
\q1 
\v 28 Wuba buisila biawu va khatitsika ka kiawu ;
\q1 muyenda zinzo ziawu zioso zingoto.
\q1 
\v 29 Badia nate bayukuta kuwombo ;
\q1 ayi wuba vana biobi baleba mu kingolo.
\q1 
\v 30 Tuamina batamba bidia biobi baleba mu kingolo mbusa,
\q1 buela bikidi mu miunu miawu.
\q1 
\v 31 Nganzi yi Nzambi yi babuila ;
\q1 wuvonda bobo baluta ba zinitu zingolo mu bawu ;
\q1 wuvonda bana ba matoko ma Iseli.
\q1 
\v 32 Ka diambu ko mambu moso momo, batatamana vola masumu
\q1 ka diambu ko matsiminanga mandi, basia wilukila ko.
\q1 
\v 33 Buna wumanisa bilumbu biawu mu phamba
\q1 ayi mimvu miawu mu tsisi.
\q1 
\v 34 Kadika khumbu kaba kuba vondanga, tombanga baba kuntombanga,
\q1 balukanga nsualu-nsualu diaka kuidi niandi.
\q1 
\v 35 Batebuka moyo ti Nzambi niandi wuba dibanga diawu
\q1 ayi Nzambi Yizangama niandi nkudi awu.
\q1 
\v 36 Vayi buna bankamba mambu ma lueki mu miunu miawu
\q1 bamvuna mu ludimi luawu.
\q1 
\v 37 Mintima miawu misia ba mifuana kuidi niandi ko
\q1 basia ba bakuikama ko mu Nguizani andi.
\q1 
\v 38 Vayi niandi wuba nkua kiadi
\q1 wuba lemvukila mambimbi mawu
\q1 kasia babunga ko
\q1 thangu ka thangu wudekula nganzi andi
\q1 ayi kasia totula ko miangu miandi mioso.
\q1 
\v 39 Wutebuka moyo ti baba minsuni kaka ;
\q1 phemo yeti vioka yoyi yilendi vutuka ko.
\q1 Ayi wulendi buela vutuka ko.
\q1 
\v 40 Zikhumbu ziwombo bantingunina mu dikanga,
\q1 ayi bansoka mu bibuangu bikambulu batu.
\q1 
\v 41 Khumbu ka khumbu baba vutukilanga diaka tota Nzambi ;
\q1 bafuemisa mutu wunlongo wu Iseli kiadi.
\q1 
\v 42 Basia tebukila ko moyo lulendo luandi
\q1 mu lumbu kioki kaba kula mu mioko
\q1 mi mutu wuba yamisa ;
\q1 
\v 43 mu lumbu kamonisa bidimbu bi bikumu biandi mu Ezipite,
\q1 mambu mandi matsiminanga mu ndambu tsi yi Tsowani
\q1 
\v 44 wukitula minlangu miawu menga ;
\q1 basia buela baka bumina mu mimvuila mi minlangu miawu.
\q1 
\v 45 Wufidisa nkangu zinzinzi ziozi zibadia
\q1 ayi zinguanga ziozi zi babunga.
\q1 
\v 46 Wavana mimbutu miawu mu zitsola kuidi binzienzi
\q1 biobi basala kuidi makhoko.
\q1 
\v 47 Wumana bunga zindima ziawu zi vinu
\q1 mu mvula yi matadi
\q1 ayi minti miawu mi sikomole mu kiozi ki ngolo,
\q1 
\v 48 wuyekula bibulu biawu kuidi mvula yi matadi
\q1 ayi minkangu mi mamemi mawu kuidi lusiemo.
\q1 
\v 49 Wuba fidisila nganzi andi yi mbazu, miangu miandi mi ngolo
\q1 khakumusu, kimbeni weti bunga
\q1 
\v 50 Wukubika nsolo mu diambu di nganzi andi
\q1 kasia kuba tanina ko mu lufua ;
\q1 vayi wuba yekula mu minsongo ;
\q1 
\v 51 Wuvonda bana boso batheti bababakala ba Ezipiti
\q1 mimbutu mitheti mi zingolo mu zinzo zi ngoto zi Hami.
\q1 
\v 52 Vayi wutotula batu bandi banga mamemi ;
\q1 wuba tuadisa banga nkangu wu bibulu mu dikanga.
\q1 
\v 53 Wuba diatisila mu luvovomo ;
\q1 diawu basia mona tsisi ko
\q1 ayi mbu wumina bambeni ziawu.
\q1 
\v 54 Buna wuba kotisa mu yenda tsi andi yinlongo ;
\q1 ku tsi yi mongo wowo koko kuandi ku lubakala kukibakila.
\q1 
\v 55 Wukuka makanda ku ntualꞌawu ;
\q1 ayi wuba kabudila mintoto miawu banga kiuka
\q1 wuvuandisa makanda ma Iseli mu zinzo ziawu.
\q1 
\v 56 Vayi batota Nzambi ayi batinguna Nzambi Yizangama ;
\q1 basia keba zinzengolo ziandi ko.
\q1 
\v 57 Banga madisa mawu
\q1 basia ba bafuana ko ayi basia ba minu ko
\q1 balendi tudulu diana ko banga wuvenga.
\q1 
\v 58 Bamfuemisa mu bibuangu biawu bizangama
\q1 balemisa kiphala kiandi mu bitumba biawu
\q1 
\v 59 Nzambi bu kawa, buna wufuema ngolo
\q1 wutumbu loza mvimba Iseli.
\q1 
\v 60 Wuyekula, nzo ngoto mbuabununu yi Silo ;
\q1 nzo yoyo mu kakivuandisa ;
\q1 
\v 61 Wufidisa kesi yi lulendo luandi mu buvika,
\q1 ayi kiezila kiandi mu mioko mi mbeni.
\q1 
\v 62 Wuyekula batu bandi mu sabala,
\q1 wufuemina ngolo kiuka kiandi.
\q1 
\v 63 Mbazu yi zinisa bamatoko mawu,
\q1 ayi bandumba ziawu ziozi
\q1 zisia zaba babakala ko zisia baka ko minkunga
\q1 mi makuela ko.
\q1 
\v 64 Zinganga ziawu zinzambi zimana fuila mu sabala
\q1 ayi mafuola mawu masia baka bu didila ko.
\q1 
\v 65 Buna Yave wukotuka banga mutu wuba wuleka,
\q1 banga mutu kotukidi mu diambu di vinu kakololo.
\q1 
\v 66 Wuvutula bambeni bandi ku manima ;
\q1 wuzifuisa zitsoni ka zisukanga ko.
\q1 
\v 67 Buna wuloza zinzo zi ngoto zi Zozefi,
\q1 kasia sobula ko dikanda di Efalayimi ;
\q1 
\v 68 Vayi wusobula dikanda di Yuda,
\q1 mongo wu Sioni, wowo kazola.
\q1 
\v 69 Wutunga buangu kiandi kinlongo banga bibuangu bizangama,
\q1 banga ntoto wowo kakubika mu zithangu zioso zi kazimani.
\q1 
\v 70 Wusobula Davidi kisadi kiandi
\q1 ayi wumbonga mu ziphangu zi mamemi,
\q1 
\v 71 Wumbongila vana vaba mamemi momo kaba sunga
\q1 mu diambu di kaba nsungi wu batu bandi Yakobi,
\q1 wu Iseli kiuka kiandi.
\q1 
\v 72 Buna Davidi wuba nsungi awu
\q1 mu ntima wufuana ayi wuba diatisila
\q1 mu koko ku diela.
\c 79
\cl Minkunga 79
\s1 Yelusalemi ditiolumukini
\d Nkunga Asafi.
\q1 
\v 1 A Nzambi ! Makanda mabulumukini kuika kiaku,
\q1 Masumuna nzoꞌaku yinlongo,
\q1 makitula Yelusalemi kunza ki matadi.
\q1 
\v 2 Bavana zinitu zifua zi bisadi biaku
\q1 banga bidia kuidi zinuni zi diyilu
\q1 minsuni mi banlongo baku
\q1 kuidi bibulu bi ntoto ;
\q1 
\v 3 Batengudi menga banga nlangu
\q1 mu yendila Yelusalemi ayi kusia monika ko
\q1 mutu mu zika.
\q1 
\v 4 Tuyikidi bila ki lusembo kuidi bafikimini yeto ;
\q1 mvuezolo ayi kisekonono
\q1 kuidi bobo batuzungididi.
\q1 
\v 5 Nate thangu mbi, a Yave ? Wela fueminanga mu zithangu zioso e ?
\q1 Nate thangu mbi kiphala kiaku kiela
\q1 leminanga banga mbazu e ?
\q1 
\v 6 Dukula miangu miaku kuidi makanda momo masia kuzaba ko,
\q1 kuidi bipfumu biobi kabi telanga ko dizina diaku.
\q1 
\v 7 Bila bameni dia Yakobi,
\q1 ayi bamana tiolumuna tsi andi yikabutukila.
\q1 
\v 8 Kadi kututangila masumu ma bakulu !
\q1 Bika kiadi kiaku kiza nsualu kuidi beto
\q1 bila tueka mu mabienga makambulu diana.
\q1 
\v 9 Wutusadila, a Nzambi Mvulusi eto
\q1 mu diambu di nkembo wu dizina diaku !
\q1 Wutukuidi ayi wutulemvukila masumu meto
\q1 mu diambu di dizina diaku !
\q1 
\v 10 Bila mbi makanda meti tubila :
\q1 “Kuevi kuidi Nzambi e ?”
\q1 va ntuala meso meto, zabikisa va khatitsika makanda
\q1 ti ngeyo weti vutula landi mu menga matenguka ma bisadi biaku,
\q1 
\v 11 Bika kunga ku batu badi mu nloko kutula va ntualꞌaku.
\q1 Mu zingolo zi koko kuaku,
\q1 tanina bobo bazengolo nkanu wu lufua.
\q1 
\v 12 Vutudila mu zikhumbu tsambuadi bifingu bi bobo batufikimini ;
\q1 tsembolo yoyi bawobudila ngeyo Yave.
\q1 
\v 13 Buna beto batu baku, nkangu aku wu mamemi weti dikila ;
\q1 tuela kuzitisa mu zithangu zioso ;
\q1 mu tsungi ka tsungi, tuela yolukila minzitusu miaku.
\c 80
\cl Minkunga 80
\s1 A Pfumu, nate thangu mbi e ?
\d Nkunga Asafi kuidi pfumu minyimbidi ; kayimbidila mu “Lisi”.
\q1 
\v 1 Bika wutuwila, a Nsungi Iseli,
\q1 ngeyo wundiatisanga Zozefi banga nkangu wu mamemi ;
\q1 Ngeyo wumvuandanga va khatitsika ba Bakeluba, kienzula kuaku.
\q1 
\v 2 Va ntuala Efalayimi, Benzami ayi Manase !
\q1 Telimisa zingolo ziaku yiza ayi wutuvukisa.
\q1 
\v 3 Wutuvutula banga bututuama bela, a Nzambi
\q1 bika zizi kiaku kitukienzula muingi tuvuka.
\q1 
\v 4 Yave, Nzambi nkua ngolo yoso,
\q1 nate thangu mbi nganzi aku yela leminanga ?
\q1 Mu diambu di zitsambulu zi batu baku e ?
\q1 
\v 5 Ngeyo wuba dikila mu dipha di matsuela
\q1 ayi ngeyo wuba nuikina matsuela mu mbungu yiwala.
\q1 
\v 6 Wutukitula tho yi minzonza
\q1 kuidi bobo bafikimini yeto
\q1 ayi bambeni zieto zilembo kutusekinina.
\q1 
\v 7 Wutuvutula banga bututuama bela, a Nzambi nkua ngolo yoso
\q1 Bika zizi kiaku kitukienzula muingi tuvuka.
\q1 
\v 8 Ngeyo wutumuna nti wu vinu ku Ezipite,
\q1 wukuka makanda ma Bapakanu bosi wukuna wawu.
\q1 
\v 9 Ngeyo wukubikila wawu ntoto
\q1 ayi wawu wumenisa mianzi ayi wudukila tsi.
\q1 
\v 10 Miongo mifuku kuidi phonzi andi,
\q1 sedeli mi lulendo kuidi matafi mandi.
\q1 
\v 11 Wufidisa mawu nate ku mbu
\q1 ayi mintuidila miandi nate ku minlangu minneni.
\q1 
\v 12 Bila mbi wutiolumunini bibaka biandi e ?
\q1 Muingi batu boso bamviokila vana bavela makundi mandi.
\q1 
\v 13 Ngulu yi nsitu yeti kuyikesikisa ;
\q1 ayi bivangu bi zitsola bilembo dia biawu.
\q1 
\v 14 Wutuvutukila, a Nzambi nkua ngolo yoso
\q1 ayi ku tsi tona ku diyilu ayi mona
\q1 keba nti wawu wu vinu ;
\q1 
\v 15 Muanzi wowo koko kuaku ku lubakala ku kuna,
\q1 Muana wu bakala wowo wuyundula mu diambu diaku veka.
\q1 
\v 16 Nti aku wu vinu wuzengulu, wuyokolo ku mbazu
\q1 mu tsembolo aku, batu baku balembo bivi.
\q1 
\v 17 Bika koko kuaku kuba vadi mutu wowo widi koko kuaku ku lubakala
\q1 muana wubakala wu mutu wowo wuyundula mu diambu diaku veka.
\q1 
\v 18 Buna tulendi buela kutatukila ko.
\q1 Wutuzingisa diaka
\q1 buna tuela tela dizina diaku.
\q1 
\v 19 Wutuvutula banga bu tutuama bela, a Yave Nzambi.
\q1 Bika zizi kiaku kitukienzula muingi tuvuka.
\c 81
\cl Minkunga 81
\s1 Enati batu bama banguila
\d Nkunga Asafi kuidi pfumu minyimbidi ; kayimbidila mu ngitala yi basi Ngati.
\q1 
\v 1 Yimbidilanu Nzambi mu khini ;
\q1 niandi zingolo zieto !
\q1 Yamikinanu kuidi Nzambi yi Yakobi !
\q1 
\v 2 Tonanu miziki, sikanu zindungu ;
\q1 Bulanu minningu mu Ngitala ayi lu Lila.
\q1 
\v 3 Sikanu phoka yi dimemi va ntotukila ngondi yi mona ;
\q1 ayi Ngondi bu yidi yiduka ayi mu lumbu ki nyengo eto !
\q1 
\v 4 Yayi yidi nzengolo mu diambu di Iseli,
\q1 ayi tsikudukusu yi Nzambi yi Yakobi,
\q1 
\v 5 Wukindisa yawu banga nsiku mu diambu di Zozefi
\q1 mu thangu kanuanisa tsi yi Ezipite…
\q1 Kuna tuwa mbembo yoyi tusia sudika ko.
\q1 
\v 6 Tubidi : “Ndibotudi mfuna wubedi va mavangiti mawu.
\q1 Ayi babotudi pani kibedi mu mioko miandi.
\q1 
\v 7 Mu ziphasi ziaku, ngeyo wutela ayi ndikula
\q1 ndivana mvutu ku tsi dumu ki matuti
\q1 nditota ku minlangu mi Meliba.
\q1 
\v 8 Wanu beno batu bama, ayi ndiela kululubula :
\q1 enati beno luzola ku ndimba, a Iseli.
\q1 
\v 9 Kulendi ba kadi nzambi yi nzenza ko va khatitsikꞌaku.
\q1 Kulendi buongimina nzambi yi nzenza ko !
\q1 
\v 10 Minu ndidi Yave, Nzambi,
\q1 yoyi yilutotula mu tsi Ezipite ;
\q1 zibula bumboti munu aku ayi ndiela ku wuwesa.
\q1 
\v 11 Vayi batu bama basia zola ku ndimba ko ;
\q1 Iseli kasia kuthumukina ko.
\q1 
\v 12 Buna ndiba yekula mu mintima miawu mingolo ;
\q1 mu landakana zikhanu ziawu veka.
\q1 
\v 13 Enati batu bama bandima kuama,
\q1 enati Iseli wuzola landakana zinzila ziama !
\q1 
\v 14 Nganu mu nsualu ndieka tumbu kuba yekudila bambeni ziawu
\q1 ayi balula koko kuama kuidi bobo beti kuba lenda.
\q1 
\v 15 Bobo beti lenda Yave balenda
\q1 kukikulula va ntualꞌandi ayi nganu thumbudulu awu yela
\q1 zingilanga mu zithangu zioso ;
\q1 
\v 16 Vayi nganu ngeyo wudikulu mu ble yilutidi kitoko,
\q1 mu niosi yintotukila mu ditadi, ndiela kuyukutisila.”
\c 82
\cl Minkunga 82
\s1 Nzambi wulembo sambisa bapfumu ba makanda.
\d Nkunga Asafi.
\q1 
\v 1 Nzambi telimini va lukutukunu lunneni.
\q1 Wulembo vani nzengolo va khatitsika “zinzambi”.
\q1 
\v 2 Nate thangu mbi luela nuaninanga mutu kambulu wusonga
\q1 ayi luela monisinanga thalu yi zizi
\q1 kuidi batu bambimbi e ?
\q1 
\v 3 Nuanina mutu wulebakana ayi muana wusana.
\q1 Luvanga malulama kuidi nsukami ayi kuidi mutu weti yamusu.
\q1 
\v 4 Kulanu mutu wulebakana ayi nsukami ;
\q1 bika luba vukisa mu mioko mi batu bambimbi.
\q1 
\v 5 Basi zaba kadi diambu ko ayi basudikanga kadi diambu ko ;
\q1 Mu tombi beti diatila ;
\q1 zifundasio zioso zi ntoto zilembo nikuka.
\q1 
\v 6 Minu ndituba :
\q1 “luidi zinzambi ayi beno boso luidi
\q1 bana ba Nzambi yizangama.”
\q1 
\v 7 Vayi luela fua banga batu boso,
\q1 luela bua banga woso kuandi nyadi.
\q1 
\v 8 Telama, a Nzambi, sambisa ntoto !
\q1 Bila makanda moso madi kiuka kiaku.
\c 83
\cl Minkunga 83
\s1 Kadi tala ti bambeni ziaku zinunga
\d Nkunga Asafi.
\q1 
\v 1 A Nzambi, kadi ba dio sui !
\q1 Kadi kanga munu, a Nzambi ayi kadi dingalala !
\q1 
\v 2 Tala, phila bambeni ziaku zilembo tudila divunzi ;
\q1 bobo beti kulenda balembo vumuna mintu miawu.
\q1 
\v 3 Mu diela dimbimbi, balembo yendila batu baku manenga ;
\q1 balembo fiedi batu baku
\q1 bobo weti belanga mayindu.
\q1 
\v 4 Batuba : “yizanu, bika tuba bunga banga dikanda,
\q1 mu diambu di dizina di Iseli dibika buela
\q1 tebukulungu moyo”.
\q1 
\v 5 Mu mabanza mamosi, bakutakana mu fiela,
\q1 bavangi nguizani mu diambu di kunuanisa ;
\q1 
\v 6 Zinzo zi ngoto zi Edoni ayi zi basi Isimayeli,
\q1 zi Mowabi ayi zi basi Hangali,
\q1 
\v 7 Nguebali ; Amoni, Amaleki
\q1 basi Filisitini va kimosi ayi basi Tila ;
\q1 
\v 8 ka diambu ko Asili mamvawu bafubakana yawu,
\q1 mu buela zingolo kuidi nkuna wu Loti.
\q1 
\v 9 Wuba vangila banga bu wuvangila Madiani,
\q1 banga bu wuvangila Sisela, ayi Yabini ku nlangu wu Kisoni ;
\q1 
\v 10 bobo babiva ku Andoli ;
\q1 bobo bakituka banga mbozi va ntoto.
\q1 
\v 11 Kituka batu bawu banneni
\q1 banga Olebi ayi Zeyebi,
\q1 bana bawu boso ba mintinu banga Zeba ayi Tsalumuna,
\q1 
\v 12 Bobo batuba :
\q1 “bika tuziona mintoto mi Nzambi mindikulungu bibulu !”
\q1 
\v 13 Wuba kitula banga kinzungidila ; A Nzambi ama,
\q1 banga biti va ntuala phemo ;
\q1 
\v 14 banga mbazu yinzinisanga nsitu ;
\q1 banga nlaki wu mbazu wunyoka miongo !
\q1 
\v 15 Buna wuba kukila mu vuka kiaku ki phemo ;
\q1 wuba monisa tsisi mu vuka kiaku ki ngolo.
\q1 
\v 16 Fuka bizizi biawu mu tsoni.
\q1 Muingi batu batomba dizina diaku, a Yave !
\q1 
\v 17 Bika bafua tsoni ayi bamona tsisi mu zithangu zioso ;
\q1 bika babiva mu kambu nzitusu.
\q1 
\v 18 Bika wuba zabikisa ti ngeyo vuidi dizina di Yave ;
\q1 ti ngeyo kaka Nzambi yizangama
\q1 va ntoto wumvimba.
\c 84
\cl Minkunga 84
\s1 Phuila yi nzo aku ndidi
\d Nkunga wu bana ba Kole kuidi pfumu minyimbidi ; bayimbidila mu ngitale yi basi Ngati.
\q1 
\v 1 A phila lueki luidi mu buangu kiaku kioki weti vuanda !
\q1 A Nzambi, nkua ngolo yoso.
\q1 
\v 2 Muelꞌama phuila widi ayi wulembo suki-suki
\q1 mu diambu di luphangu lu Yave.
\q1 Ntimꞌama ayi nsuni ama bilembo yamikina
\q1 mu diambu di Nzambi yi moyo.
\q1 
\v 3 Ka diambu ko dikuanga beki nzoꞌandi,
\q1 ayi tsiodila mamvandi beki dianza diandi
\q1 koko keti lundila bana bandi…
\q1 buangu kifikimini ntalꞌaku
\q1 A Yave nkua ngolo yoso, Ntinu ama ayi Nzambi ama !
\q1 
\v 4 Lusakumunu kuidi bobo beti vuanda mu Nzo aku !
\q1 Beti kuzitisa mu zithangu zioso.
\q1 
\v 5 Lusakumunu kuidi batu bobo zingolo ziawu zidi mu ngeyo ;
\q1 bobo bakubika mintima
\q1 miawu mu kuenda sambila ku Yelusalemi.
\q1 
\v 6 Bu bamviokanga mu ndimba wu Baka,
\q1 buna beti kuwukitula buangu ki zitho zi minlangu ;
\q1 mvula mamvandi wufukidila wawu mu bibuindi.
\q1 
\v 7 Zingolo ziawu zieti buelama
\q1 nate kadika mutu kammonika
\q1 va ntuala Nzambi yi sioni.
\q1 
\v 8 Wa lusambulu luama, a Yave, Nzambi nkua ngolo yoso,
\q1 wundimba Nzambi yi Yakobi.
\q1 
\v 9 Tala nkaku eto, a Nzambi
\q1 Tadila mu nlemvo mutu aku wuvinda mafuta.
\q1 
\v 10 Lumbu kimosi mu luphangu luaku
\q1 kiviokidi mili di bilumbu kunkaka.
\q1 Thidi kuama ba nsungi wu muelo mu nzo yi Nzambi ama
\q1 ayi mu vuandanga mu zinzo zi ngoto zi batu bambimbi.
\q1 
\v 11 Bila Yave Nzambi niandi thangu ayi nkaku,
\q1 Yave wela vana nlemvo ayi nzitusu,
\q1 kadi kima kimosi kimboti kalendi yimina ko
\q1 bobo bandiatilanga mu kambu tsembolo.
\q1 
\v 12 A Yave nkua ngolo yoso !
\q1 Lusakumunu kuidi mutu wowo weti tula
\q1 diana diandi mu ngeyo !
\c 85
\cl Minkunga 85
\s1 Yave weti kutuvangila mamboti
\d Nkunga bana ba Kole kuidi pfumu minyimbidi.
\q1 
\v 1 Wumonisa nlemvo kuidi ntoto aku ; a Yave,
\q1 wuvutula kiuka ki Yakobi.
\q1 
\v 2 Wulemvukila mambimbi ma batu baku ;
\q1 ayi wufuka masumu mawu moso.
\q1 
\v 3 Wutula miangu miaku mioso va ndambu
\q1 ayi wuvutikisa ntima mu nganzi aku.
\q1 
\v 4 Wutuvutula banga bo tutuama bela, a Nzambi Mvulusi eto,
\q1 wutumoni diaka khini.
\q1 
\v 5 Mawuba mu nganzi kuidi beto mu zithangu zioso e ?
\q1 Mawulambisa nganzi aku tsungi ka tsungi e ?
\q1 
\v 6 Wukadi buela tuvutudila luzingu
\q1 muingi batu baku bamona khini mu ngeyo e ?
\q1 
\v 7 Wutumonisa luzolo luaku lu ngolo, a Yave,
\q1 ayi wutuvani phulusu aku.
\q1 
\v 8 Ndiela wa momo, Nzambi Yave kela tuba ;
\q1 veni zitsila zi ndembama kuidi batu bandi,
\q1 kuidi banlongo bandi
\q1 vayi buna babika vutukila kilawu.
\q1 
\v 9 Kiedika, phulusu andi yifikimini
\q1 babo beti kunkinzikanga
\q1 mu diambu di nkembo andi wuzingila mu ntoto eto.
\q1 
\v 10 Luzolo ayi kikhuikizi bidengini ;
\q1 busonga ayi ndembama bibumbisini.
\q1 
\v 11 Kikhuikizi kitotukidi va ntoto
\q1 ayi busonga buntala ku tsi tona ku diyilu.
\q1 
\v 12 Buna Yave mamvandi wela vana biobio bidi bimboti
\q1 ayi ntoto eto wela buta mimbutu miandi.
\q1 
\v 13 Busonga buela kuntuaminina ku ntuala
\q1 ayi buela kubika nzila mu diambu di bitambi biandi.
\c 86
\cl Minkunga 86
\s1 Yiza wuphukisa
\d Lusambulu lu Davidi.
\q1 
\v 1 Wa, a Yave, ayi wuphani mvutu
\q1 bila ndidi nkua kiadi ayi ndidi nsukami.
\q1 
\v 2 Keba luzingu luama bila ndikiyekula kuidi ngeyo.
\q1 Ngeyo Nzambi ama, vukisa kisadi kiaku
\q1 kikusilanga diana.
\q1 
\v 3 Bika wumbona kiadi, a Yave,
\q1 Bila ngeyo ndieti tela mu lumbu kimvimba.
\q1 
\v 4 Nata khini kuidi kisadi kiaku.
\q1 Bila kuidi ngeyo, a Yave
\q1 ndieti vumuna muelꞌama.
\q1 
\v 5 Ngeyo widi wumboti ayi weti lemvukilanga ;
\q1 ayi widi wufuluka mu mamboti
\q1 kuidi bobo beti kutela.
\q1 
\v 6 Wa lusambulu luama, a Yave ;
\q1 wa bumboti yamikina kuama mu diambu di kiadi.
\q1 
\v 7 Mu lumbu ki ziphasi ziama ngeyo ndiela tela,
\q1 bila ngeyo wela kuphana mvutu.
\q1 
\v 8 A Va khatitsika zinzambi,
\q1 kuisi ko yoyi yidedikini banga ngeyo, a Yave
\q1 ayi kuisi ko mavanga madedakani banga maku.
\q1 
\v 9 Makanda moso momo wuvanga
\q1 mela kuiza ayi mela buongama va ntualꞌaku, a Yave,
\q1 ayi mela nata nkembo kuidi dizina diaku.
\q1 
\v 10 Bila ngeyo widi wunneni ayi ngeyo wumvanganga
\q1 mavanga matsiminanga ;
\q1 ngeyo kaka Nzambi.
\q1 
\v 11 Wundongi nzilꞌaku, a Yave
\q1 ayi ndiela diatila mu bukiedika buaku ;
\q1 bika wuphana ntima wukambu vasuka
\q1 muingi ndikinzikanga dizina diaku.
\q1 
\v 12 Ndiela kuzitisa, a Yave Nzambi ama,
\q1 mu ntimꞌama wumvimba
\q1 ayi ndiela kembisanga dizina diaku
\q1 mu zithangu zioso.
\q1 
\v 13 Bila luzolo luaku luidi lunneni kuidi minu
\q1 ngeyo wukhula mu zithipula zi tsi bafua.
\q1 
\v 14 Batu baluniemo balembo nduanisa, a Nzambi ;
\q1 ayi nkangu wu batu ba makhemi
\q1 balembo tombi luzingu luama ;
\q1 batu bakambulu thalu mu ngeyo.
\q1 
\v 15 Vayi ngeyo, a Yave, weti mona kiadi ;
\q1 yimonisanga nlemvo,
\q1 wuvika fuemanga ko ; fulukidi mu luzolo ayi mu kikhuikizi.
\q1 
\v 16 Baluka kuidi minu ayi wumboni kiadi ;
\q1 vana zingolo ziaku kuidi kisadi kiaku
\q1 ayi vukisa muana kisadi kiaku ki nketo.
\q1 
\v 17 Bika wuphana dimbu ki mamboti maku
\q1 muingi bambeni ziama zimona kiawu
\q1 ayi bafua tsoni
\q1 bila ngeyo Yave wutsadisidi ayi wumbombidi.
\c 87
\cl Minkunga 87
\s1 Batu boso ku Sioni babutukila
\d Nkunga bana ba Kole.
\q1 
\v 1 Wutula fondasio andi ku mongo wunlongo.
\q1 
\v 2 Yave weti zola mielo mi Sioni
\q1 viokila bibuangu bioso bimvuandanga Yakobi.
\q1 
\v 3 Mambu ma nkembo matubu mu diambu diaku ;
\q1 a divula di Nzambi.
\q1 
\v 4 “Ndiela yolukila Lahabi ayi Babiloni
\q1 muidi bobo banzebi ;
\q1 tsi yi Filisiti ayi Tila va kimosi ayi Kutsi :
\q1 ayi tuba : mutu wawu ku Sioni kabutukila”.
\q1 
\v 5 Buna mu diambu di Sioni ; bela tuba :
\q1 “Mutu wawu ayi mutu wuna, mu niandi babutukila”
\q1 ayi Nzambi yizangama, niandi wela kumbieka.
\q1 
\v 6 Yave wela sonika batu mu buku :
\q1 “mutu wawu ku Sioni kabutukila.”
\q1 
\v 7 Bu balembo budi miziki, bela yimbila :
\q1 “zitho ziama zioso zidi mu ngeyo.”
\c 88
\cl Minkunga 88
\s1 Lusambulu lu mutu weka nduka fua
\d Nkunga bana ba Kole kuidi pfumu minyimbidi ; bayimbidila mu flute. Nkunga Hemani muisi Ezilakite.
\q1 
\v 1 A Yave, Nzambi yoyi yeti kuphukisa,
\q1 muini ayi builu ndieti yamikina va ntualꞌaku.
\q1 
\v 2 Bika lusambulu luama lutula va ntualꞌaku ;
\q1 balula dikutu diaku bu ndilembo yamikina.
\q1 
\v 3 Bila muelꞌama wufulukidi mu ziphasi
\q1 ayi luzingu luama lufikimini tsi yi bafua.
\q1 
\v 4 Ndidi mu ntanda wu batu bobo bankuenda ku diyilu
\q1 ndieka banga mutu kambulu zingolo.
\q1 
\v 5 Ndidi wuvuanda va ndambu lufua,
\q1 banga batu bavondo ; bobo badi baleka mu ku tsi bafua ;
\q1 bobo wunkambu buela tebukilanga moyo,
\q1 bobo wusia buela bela mayindu ko.
\q1 
\v 6 Ngeyo wuthula mu dibulu dinneni,
\q1 mu tombi kinkobo.
\q1 
\v 7 Miangu miaku mimbuila ayi zitu midi
\q1 Minu ndidiamusu kuidi ngeyo mu mayo maku moso.
\q1 
\v 8 Ngeyo wuphambisa mu bakundi bama bakiluzolo
\q1 ngeyo wukhitula kima ki khemi kuidi bawu.
\q1 Ndidi wukangama ayi ndilendi baka bu tinina ko.
\q1 
\v 9 Meso mama meka mbumbuluka
\q1 mu diambu di ziphasi ;
\q1 ngeyo ndintela ; a Yave, kadika lumbu
\q1 kuidi ngeyo ndinonuna mioko miama.
\q1 
\v 10 Wulenda kuaku monisa matsiminanga maku kuidi mutu wufua e ?
\q1 Bafua balenda fuluka ayi kuzitisa e ?
\q1 
\v 11 Balenda yolukila luzolo luaku mu tsi bafua
\q1 ayi kikhuikizi kiaku mu mbivusu e ?
\q1 
\v 12 Matsiminanga maku malenda zabakanga mu bibuangu bidi tombi
\q1 voti mavanga maku masonga mu ntoto wowo batu bazimbakana
\q1 mambu moso e ?
\q1 
\v 13 Vayi minu kuidi ngeyo ndinyamikina mu tomba lusadusu,
\q1 mu nsuka lusambulu luama lunkuiza va ntualꞌaku.
\q1 
\v 14 Bila mbi ngeyo Yave wundozidi e ?
\q1 Ayi bila mbi wulembo tsuekila zizi kiaku e ?
\q1 
\v 15 Tona mu bumuana buama minu ndidi mu phasi
\q1 ndidi wukangama mu lufua
\q1 Ndimona ziphasi mu tsisi aku
\q1 ayi ndieka wukambu diana.
\q1 
\v 16 Miangu miaku mingolo mimbuididi
\q1 tsisi aku yimbunga.
\q1 
\v 17 Mu lumbu kimvimba yawu yinzungidila banga khuka nlangu
\q1 yawu yitungu kumbina mvimba.
\q1 
\v 18 Ngeyo mu bandiatanga yama ayi mu bakiluzolo bama
\q1 tombi kiawu nkundi ama wukuikama.
\c 89
\cl Minkunga 89
\s1 Kuevi kuidi mamboti makhulu e ?
\d Nkunga Etani muisi Ezilakite.
\q1 
\v 1 Ndiela yimbidila mamboti manneni ma Yave
\q1 mu zithangu zioso.
\q1 Mu munu ama ndiela zabikisila kikuikizi kiaku
\q1 muidi zitsungi zioso.
\q1 
\v 2 Ndiela samuna ti luzolo luaku luidi lutelama dio ngui mu zithangu zioso.
\q1 Ti ngeyo wutula kikhuikizi kiaku mu diyilu.
\q1 
\v 3 Ngeyo wutuba :
\q1 “nditula Nguizani ama ayi mutu ama wowo ndivinda mafuta ;
\q1 Ndidia ndefi kuidi Davidi, kisadi kiama :
\q1 
\v 4 Ndiela bieka nkunꞌaku mu zithangu zioso ;
\q1 ayi ndiela kitula kundu kiaku ki kipfumu kikinda mu zitsungi zioso.”
\q1 
\v 5 Diyilu dinzitisa matsiminanga maku, a Yave
\q1 kikhuikizi kiaku mu lukutukunu lu banlongo.
\q1 
\v 6 Bila nani mu matuti wulenda dedokoso banga Yave ?
\q1 Widi banga Yave mu bivangu bi diyilu e ?
\q1 
\v 7 Mu lukutukunu lu banlongo, Nzambi wulembo kinzuku ngolo
\q1 tsisi kadi yiviokidi batu bobo banzungididi.
\q1 
\v 8 A Yave, Nzambi nkua ngolo yoso, nani widi banga ngeyo e ?
\q1 Widi nkua ngolo, a Yave,
\q1 ayi kikhuikizi kiaku kizungididi.
\q1 
\v 9 Ngeyo weti yadila mbu wufuemini,
\q1 Mayo mandi mawu telama ngeyo weti lembika mawu.
\q1 
\v 10 Ngeyo wukosikisa Lahabi banga mutu wuvondo
\q1 mu koko kuawu ku lulendo ngeyo wusasikisa bambeni ziaku.
\q1 
\v 11 Ngeyo vuidi diyilu ayi ntoto diaka ngeyo vuidi wawu.
\q1 Ngeyo wuvanga nza ayi bibio bidi muawu.
\q1 
\v 12 Ngeyo wuvanga Nodi ayi Sude ;
\q1 Taboli ayi Helimoni
\q1 bieti yimbila mu khini mu diambu di dizina diaku.
\q1 
\v 13 Koko kuaku kufulukidi mu lulendo ;
\q1 koko kuaku ngolo kuidi
\q1 koko kuaku ku lubakala kuyayusu ngolo.
\q1 
\v 14 Busonga ayi bufuana biawu fundasio
\q1 yi kundu kiaku ki kipfumu.
\q1 Luzolo ayi kikhuikizi bindiata ku ntuala.
\q1 
\v 15 Lusakumunu kuidi batu bobo banlonguka kubudila zitsiaki ;
\q1 bobo bandiatilanga mu kiezila ki meso maku, a Yave.
\q1 
\v 16 Beti mona khini mu dizina diaku mu lumbu kimvimba
\q1 beti yangalala mu busonga buaku.
\q1 
\v 17 Bila ngeyo nkembo awu ayi zingolo ziawu
\q1 ayi mu nlemvo aku, ngeyo wuyayisa phokꞌeto.
\q1 
\v 18 Bukiedika, nkaku eto wuviulu kuidi Yave
\q1 ntinu eto kuidi mutu wunlongo wu Iseli.
\q1 
\v 19 Khumbu yimosi ngeyo wuyolukila mu tsongolo
\q1 kuidi batu baku bakuikama ngeyo wutuba :
\q1 “Ndivana zingolo kuidi mutu wu ngolo.
\q1 Ndiyayisa muana ditoko va khatitsika batu.
\q1 
\v 20 Ndibakula Davidi kisadi kiama,
\q1 mu mafuta mama manlongo, minu ndimvindila.
\q1 
\v 21 Koko kuama kuela kunsimba ;
\q1 bukiedika koko kuama kuela kumvana zingolo.
\q1 
\v 22 Kadi mbeni yimosi yilendi kutula ku tsi minsua miandi ko.
\q1 Mu diambu di futa phaku.
\q1 Kadi mutu wumosi wumbimbi kalendi kunyamisa ko.
\q1 
\v 23 Ndiela kosikisa va meso mandi batu bobo beti kunlenda
\q1 ayi ndiela buisa bobo beti kunlenda.
\q1 
\v 24 Luzolo luama lukuikama luela ba yandi
\q1 mpe mu dizina diama phoka ziandi ziela tombolo.
\q1 
\v 25 Ndiela tula koko kuandi va mbata mbu
\q1 ayi koko kuandi ku lubakala va mbata minlangu.
\q1 
\v 26 Niandi wela kuthela :
\q1 ‘Ngeyo widi dise diama, Nzambi ama
\q1 ditadi dingolo Mvulusi ama.’
\q1 
\v 27 Ndiela kunsobula diaka muanꞌama wutheti
\q1 wowo lutidi zangama
\q1 mu mintinu mioso midi va ntoto.
\q1 
\v 28 Ndiela simbidila luzolo luama va niandi
\q1 mu zithangu ziozo
\q1 ayi Nguizani ama va niandi yilendi ba babeba ko.
\q1 
\v 29 Ndiela telimisa dio ngui nkunꞌandi mu zithangu zioso
\q1 kundu kiandi ki kipfumu kiela zingila
\q1 banga bilumbu bi diyilu.
\q1 
\v 30 Enati bana bandi balozidi Mina miama
\q1 ayi enati bakadi landakana zinzengolo ziama ;
\q1 
\v 31 enati babundudi zinzengolo ziama
\q1 enati bakadi keba zithumunu ziama,
\q1 
\v 32 ndiela tumbudila masumu mawu mu lusuadi,
\q1 mambimbi mawu mu bikoti ;
\q1 
\v 33 vayi ndilendi ba botula ko luzolo luama mu niandi
\q1 ayi ndilendi tunuka kikhuikizi kiama ko.
\q1 
\v 34 Ndilendi ba bundula Nguizani ama ko
\q1 voti ndilendi balula ko
\q1 mambu momo bididi biama matotula.
\q1 
\v 35 Mu khumbu yimosi,
\q1 ndidia ndefi mu bunlongo buama
\q1 ayi ndilendi ba vuna Davidi ko.
\q1 
\v 36 Buna nkunꞌandi wela zingilanga mu zithangu zioso
\q1 ayi kundu kiandi ki kipfumu kiela zingila va ntualꞌama
\q1 banga thangu.
\q1 
\v 37 Kiela ba kitelama dio ngui mu zithangu zioso
\q1 banga ngondi,
\q1 mbangi yikuikama mu matuti.”
\q1 
\v 38 Vayi ngeyo wunloza, wunlenza ;
\q1 wuba wufuema beni kuidi mutu aku wudukudila mafuta.
\q1 
\v 39 Ngeyo wuvonda Nguizani ayi kisadi kiaku ;
\q1 ayi ngeyo wubundula budu ki kipfumu kiandi
\q1 nate wuloza kiawu va difundu-fundu.
\q1 
\v 40 Ngeyo wumana tiolumuna bibaka biandi bioso
\q1 ayi wutula bisuamunu biandi bingolo mu mbivusu.
\q1 
\v 41 Babo baviokila vana, banziona bima ;
\q1 wuyika diambu di mvuezolo kuidi bafikimini yandi.
\q1 
\v 42 Ngeyo wuzangula koko ku lubakala
\q1 ku bobo bakunlendanga,
\q1 wumonisa bambeni bandi zioso khini.
\q1 
\v 43 Ngeyo wuvengumuna meno ma sabala kiandi
\q1 ayi wusia kunsadisa ko mu mvita.
\q1 
\v 44 Ngeyo wumanisa kiezila kiandi
\q1 ayi wuloza kundu kiandi ki kipfumu va tsi.
\q1 
\v 45 Ngeyo wukufisa bilumbu bi bumuana buandi ;
\q1 wumfuka yunga ki tsoni.
\q1 
\v 46 Nate thangu mbi a Yave wela suamina e ?
\q1 Nate thangu mbi miangu miaku miela
\q1 lemina banga mbazu e ?
\q1 
\v 47 Tebuka moyo boso luzingu luama luididi lukhufi.
\q1 A buevi, buna mu phamba kuandi wuvangila batu boso e ?
\q1 
\v 48 Mutu mbi wowo lenda zinga ayi wela kambu mona lufua e ?
\q1 Voti kukivukisa
\q1 mu lulendo lu tsi yi bafua e ?
\q1 
\v 49 A Yave, kuevi kuidi luzolo luaku lunene lukhulu,
\q1 mu lolo wuzengila ndefi mu kikhuikizi kiaku
\q1 mu diambu di Davidi e ?
\q1 
\v 50 Tebukila moyo a Pfumu, buevi kisadi kiaku bakisekinina ;
\q1 buevi ndilembo natina mu ntimꞌama bifingu bi makanda moso.
\q1 
\v 51 Bifingu biobi bambeni ziaku basekinina,
\q1 biobi basekinina kadika thama yi mutu aku
\q1 wowo wudukudila mafuta.
\q1 
\v 52 Nzitusu kuidi Yave mu zithangu zioso.
\qr Amen, ayi Amen.
\c 90
\ms1 BUKU YI NYA
\cl Minkunga 90
\s1 Wutulonga mu tanga bilumbu bieto
\d Lusambulu lu Moyize, mutu Nzambi.
\q1 
\v 1 Yave, ngeyo wuba buangu kieto kivuanda
\q1 mu tsungi ka tsungi.
\q1 
\v 2 Tuamina miongo mibutuka
\q1 voti tuamina wuvanga ntoto ayi nza ;
\q1 tona mu thangu ka thangu, ngeyo widi Nzambi.
\q1 
\v 3 Ngeyo wumvutulanga batu mu fundu-fundu
\q1 bu weti tuba :
\q1 “Vutuka mu fundu-fundu, e e bana ba batu.”
\q1 
\v 4 Bila va meso maku mili di mimvu midedikini
\q1 banga lumbu kimosi kiviokidi zono ;
\q1 voti banga thangu yimosi va builu,
\q1 
\v 5 ngeyo weti botula batu mu tulu tu lufua,
\q1 badi banga biti bimona va nsuka.
\q1 
\v 6 Va nsuka bimenini bimona,
\q1 va masika bilebukidi ayi biyumini.
\q1 
\v 7 Tulembo lalakana mu diambu di nganzi aku
\q1 ayi tsisi tulembo moni
\q1 mu diambu di miangu miaku.
\q1 
\v 8 Ngeyo wutudidi mambimbi meto va ntualꞌaku,
\q1 masumu meto masuama
\q1 va ntuala kiezila ki zizi kiaku.
\q1 
\v 9 Bilumbu bieto bioso bilembo mani
\q1 ku tsi nganzi aku ;
\q1 tulembo manisa mimvu mieto ayi luniongo.
\q1 
\v 10 Tezo ki bilumbu bieto kidi ki lusambudi lumimvu
\q1 voti lunana enati ngolo zidi yeto.
\q1 Sina kiawu kidi kaki kiphasi ayi kimianga.
\q1 Bila luzingu lueti lulembo vioki nsualu
\q1 ayi tulembo yendi.
\q1 
\v 11 Nani zebi lulendo lu nganzi aku e ?
\q1 Muingi miangu miaku miba tola banga lukinzu lolo fueni tambula.
\q1 
\v 12 Wutulongisa tanga bilumbu bieto mu bufuana
\q1 muingi tubaka ntima wu duenga.
\q1 
\v 13 Bika buela fuema, a Yave.
\q1 Nate thangu mbi mela bela e ?
\q1 Bika wumona bisadi biaku kiadi.
\q1 
\v 14 Mu nsuka, bika wutuyukutisa mu luzolo luaku lu ngolo ;
\q1 buna tuela yimbilanga mu khini ayi buna tuela yangalala
\q1 mu bilumbu bioso.
\q1 
\v 15 Wutuyangidikanga boso buididi bilumbu biobi wutumonisina phasi
\q1 boso buididi mimvu miomi tuyamusunu.
\q1 
\v 16 Bika mavanga maku mamonoso kuidi bisadi biaku ;
\q1 kiezila kiaku kuidi bana bawu.
\q1 
\v 17 Bika nlemvo wu Yave, Nzambi eto wubanga va beto,
\q1 bika mu diambu dieto, wukindisa kisalu ki mioko mieto.
\q1 Nyinga, kindisa kisalu ki mioko mieto.
\c 91
\cl Minkunga 91
\s1 Suamunu ki kiedika
\q1 
\v 1 Mutu wowo wumvuandanga ku tsi suamunu ki Nzambi yizangama,
\q1 wela vundila ku tsi kitsusula ki Nzambi
\q1 ngolo yoso.
\q1 
\v 2 Ndiela tuba mu diambu di Yave :
\q1 Niandi suamunu kiama ayi suamunu kiami kingolo.
\q1 Nzambi ama, mu niandi ndintula diana.
\q1 
\v 3 Bukiedika niandi wela ku vukisa mu ntambu
\q1 ntambi wu zinuni,
\q1 ayi mu nsongo weti vonda.
\q1 
\v 4 Wela ku fukidila mu zitsala ziandi
\q1 ayi ku tsi mavavi mandi, wela bakula suamunu.
\q1 Kikhuikizi kiandi kiela ba nkaku aku
\q1 ayi baka kiaku kizangama.
\q1 
\v 5 Wulendi ko mona tsisi mu builu
\q1 voti dionga dieti dumuka va muini ;
\q1 
\v 6 voti nsongo weti vonda,
\q1 wumviokila mu tombi,
\q1 voti vunga kieti bunga va muini ngembele.
\q1 
\v 7 Mili yimosi yilenda bua va ndambu aku
\q1 voti dikumi di mili va koko kuaku ku lubakala,
\q1 vayi kadi diambu dimosi dilendi fikama ko va widi.
\q1 
\v 8 Wela tala kaka mu meso maku
\q1 ayi wela mona thumbudulu yi batu bambimbi.
\q1 
\v 9 Enati kitudi Nzambi yizangama buangu kiaku weti vuanda
\q1 bosi Yave, suamunu kiama.
\q1 
\v 10 Buna kadi mbimbi yimosi yilendi kubuila ko
\q1 ayi kadi vuku kimosi kilendi fikama va nzoꞌaku yi ngoto ko.
\q1 
\v 11 Bila, mu diambu diaku, wela tumina zimbasi ziandi
\q1 muingi zikeba mu zinzila ziaku zioso.
\q1 
\v 12 Ziawu ziela kuvumuna mu mioko miawu
\q1 mu diambu di kulu kuaku kuedi bumina
\q1 thutu mu ditadi.
\q1 
\v 13 Ngeyo wela diatidila khosi ayi kusa ;
\q1 wela kosikisa khosi yiyunduka ayi nioka,
\q1 
\v 14 Yave kembi : “sumbu keta kunzola ndiela ku nkula,
\q1 ayi ndiela ku nkeba
\q1 bila zebi dizina diama.
\q1 
\v 15 Wela kuthela ayi ndiela kumvana mvutu.
\q1 Ndiela banga yandi mu ziphasi
\q1 ndiela ku nkula ayi ku nkinzika.
\q1 
\v 16 Ndiela kunyukutisa mu luzingu lu mula
\q1 ayi ndiela kummonisa phulusu ama.”
\c 92
\cl Minkunga 92
\s1 Didi diambu di mboti mu zitisa Yave
\d Nkunga wu lumbu ki saba.
\q1 
\v 1 Didi diambu dimboti mu zitisa Yave
\q1 ayi bula miziki mu diambu di dizina diaku, a Nzambi yizangama,
\q1 
\v 2 mu yamikisa luzolo luaku mu nsuka
\q1 ayi kikhuikizi kiaku va builu,
\q1 
\v 3 mu miziki dikumi di minsinga, di siku beti tedila Lila
\q1 ayi mu nningu wu ngitala.
\q1 
\v 4 Bila ngeyo wumbonisa khini mu mavanga maku, a Yave.
\q1 Ndiela yimbila mu khini
\q1 mu diambu di mavanga ma mioko miaku.
\q1 
\v 5 A phila tola mavanga maku madi, a Yave,
\q1 a phila thipula mabanza maku madi !
\q1 
\v 6 Wukambulu diela kasi zaba ko
\q1 vungisi kalendi sudika ko,
\q1 
\v 7 muingi ka diambu ko batu bambimbi banyunduka banga biti,
\q1 ayi batu boso bamvanganga mambimbi bammonanga mamboti ;
\q1 bela bungu mu zithangu zioso.
\q1 
\v 8 Vayi ngeyo Yave widi wuyayusu mu zithangu zioso.
\q1 
\v 9 Bukiedika bambeni ziaku, a Yave,
\q1 bukiedika bambeni ziaku ziela biva
\q1 bisadi bioso bieti vanga mambimbi
\q1 biela sasukusu.
\q1 
\v 10 Vayi ngeyo wela yayisa phokꞌama
\q1 banga phoka phakasa.
\q1 Mafuta mamosi ma kitoko mandukudulu.
\q1 
\v 11 Buna meso mama mamona mbedosolo yi
\q1 batu bobo beti kundenda ;
\q1 makutu mama mawa biyoko bi batu bambimbi bantina,
\q1 bobo beti kundenda.
\q1 
\v 12 Batu basonga bela mona mamboti banga diba,
\q1 bela yunduka banga sedeli wu Libani ;
\q1 
\v 13 bakunu mu nzo Yave,
\q1 bela mona mamboti mu ziphangu zi Nzambi eto ;
\q1 
\v 14 bela buta mimbutu banza mu bununu buawu bu ngolo ;
\q1 badi kaka banlangu ayi meza ma nlangu madi yawu.
\q1 
\v 15 Mu yamikisanga Yave widi wululama
\q1 Niandi ditadi diama ayi mambimbi masi ko mu niandi.
\c 93
\cl Minkunga 93
\s1 Yave weti yala tona thama ayi mu zithangu zioso.
\q1 
\v 1 Yave weti yala, vueti nzitusu,
\q1 Yave vueti nzitusu ayi wukivuatisidi zingolo.
\q1 Nza yidi yikindusu dio ngui ;
\q1 yilendi nikuka ko.
\q1 
\v 2 Kundu kiaku ki Kipfumu kikibiekolo tona thama ;
\q1 ngeyo widi tona mu zithangu zioso.
\q1 
\v 3 Mimbu mifuemini, a Yave ;
\q1 mimbu miwakisidi zimbembo ziawu,
\q1 mimbu miwakikisidi mayo mawu mankumba.
\q1 
\v 4 Lulendo viokila dumu ki minlangu minneni
\q1 lulendo viokila bobo beti basa mimbi
\q1 Yave lulendo kadi mu diyilu.
\q1 
\v 5 Zinzengolo ziaku zidi zitelama dio ngui.
\q1 Bunlongo bueti monisanga kitoko mu nzo aku, a Yave,
\q1 mu bilumbu bikambulu tsukulu, a Yave.
\c 94
\cl Minkunga 94
\s1 Nate thangu mbi batu bambimbi bela nunginanga e ?
\q1 
\v 1 A Yave, Nzambi wumvutulanga landi.
\q1 A Nzambi, wumvutulanga landi ;
\q1 bika wukimonisa !
\q1 
\v 2 Telama kuaku ngeyo zuzi di ntoto ;
\q1 bika wuvutudila batu badi luniemo
\q1 momo bafueni tambula.
\q1 
\v 3 Nate thangu mbi batu bambimbi, a Yave ?
\q1 Nate thangu mbi batu bambimbi bela monanga khini e ?
\q1 
\v 4 Bawu balembo muangisa mambu ma luniemo.
\q1 Batu boso bobo beti vanga mambimbi
\q1 bafulukidi mu luyanu.
\q1 
\v 5 Bawu balembo diatidila batu baku, a Yave,
\q1 balembo yamisa kiuka kiaku.
\q1 
\v 6 Balembo vondi difuola ayi nkebi ;
\q1 balembo vondi bana ba sana.
\q1 
\v 7 Balembo tubi : “Yave kakadi mona
\q1 ayi Nzambi yi Yakobi kakadi matala.”
\q1 
\v 8 Lukeba beno bakambulu diela luidi va khatitsika batu !
\q1 Bosi beno bivungisi thangu mbi luela bela nzayilu e ?
\q1 
\v 9 Niandi wutula dikutu kalendi wa ko e ?
\q1 Niandi wukubika dieso kalendo mona ko e ?
\q1 
\v 10 Niandi weti vana makanda thumbudulu makanda
\q1 kalendi vana thumbudulu ko e ?
\q1 Niandi ko weti longa mutu kambulu nzayilu e ?
\q1 
\v 11 Yave zebi mayindu ma mutu ;
\q1 zebi ti mawu madi kaka maphamba.
\q1 
\v 12 Lusakumunu kuidi mutu wowo weti vana thumbudulu, a Yave,
\q1 mutu wowo weti longila mu Mina miaku.
\q1 
\v 13 Weti kumvana lusadusu mu bilumbu bi phasi
\q1 nate dibulu dinneni diela mana kabu mu diambu di batu bambimbi.
\q1 
\v 14 Bila Yave kalendi yekula batu bandi ko
\q1 kalendi loza kiuka kiandi ko.
\q1 
\v 15 Tsambusu yela buela ba diaka yisonga
\q1 ayi baboso bobo badi mintima milulama
\q1 bela landakana yawu.
\q1 
\v 16 Nani wela kuthelumina va ntuala batu bambimbi e ?
\q1 Nani wela telama mu diambu diama
\q1 mu nuanisa bobo bamvanganga mambimbi e ?
\q1 
\v 17 Enati Yave kasia kuphana lusadusu ko
\q1 nganu mu thinu nsualu ndivuandila dio sui mu lufua.
\q1 
\v 18 Mu thangu ndituba ; “kulu kuama kueka sialumuka” ;
\q1 luzolo luaku, a Yave, lutsimba.
\q1 
\v 19 Mu thangu mayindu maba mawombo mu minu ;
\q1 mbombolo aku yinata khini mu muelꞌama.
\q1 
\v 20 Kundu ki luyalu ki batu bamvanganga mambimbi
\q1 kilenda ba kithuadi ayi ngeyo ko e ?
\q1 Kioki kinatanga khuamusu mu zinzengolo ziandi e ?
\q1 
\v 21 Bankutakananga mu nuanisa batu basonga
\q1 ayi zengila mutu kambu bila
\q1 nkanu wu lufua.
\q1 
\v 22 Vayi Yave wuyika suamunu kiama kingolo ;
\q1 ayi Nzambi ama niandi ditadi dingolo diodi ndieti suamina.
\q1 
\v 23 Wela kuba vutudila mu diambu di masumu mawu,
\q1 ayi wela kuba bunga mu diambu di mambimbi mawu.
\q1 Yave, Nzambi eto, wela kuba bunga.
\c 95
\cl Minkunga 95
\s1 Niandi simbidi nza mu mioko miandi.
\q1 
\v 1 Yizanu, bika tuyimbidila Yave mu khini.
\q1 Bika tuyamikina kuidi ditadi di phulusu eto.
\q1 
\v 2 Bika tuizanu ku ntualꞌandi mu vana matondo
\q1 tunyayisa mu miziki ayi mu minkunga.
\q1 
\v 3 Bila Yave widi Nzambi yinneni,
\q1 ntinu wunneni va yilu zinzambi zioso.
\q1 
\v 4 Va koko kuandi muidi vadi phinda zi ntoto
\q1 zitsongi zi miongo zivuiwulu kuidi niandi.
\q1 
\v 5 Mbu wandi bila niandi veka wuvanga wawu
\q1 ayi mioko miandi mivanga ntoto wu yuma.
\q1 
\v 6 Yizanu bika tukikulula mu buongama,
\q1 bika tufukamanu va ntuala Yave mvangi eto.
\q1 
\v 7 Bila niandi Nzambi eto
\q1 ayi beto tuidi batu bandi keta dikila,
\q1 nkangu mamemi mu ku tsi lukebolo luandi.
\q1 Enati lumbu kiaku luwilu mbembo andi,
\q1 
\v 8 lubika kitula mintima mieno ngolo
\q1 banga bu luvangila Meliba,
\q1 banga bu luvangila mu lumbu ki Masa mu dikanga ;
\q1 
\v 9 Kuna madise beno bathotila ayi batsokila ;
\q1 ka diambu ko bamona momo ndivanga.
\q1 
\v 10 Mu makumaya ma mimvu, ndiba mu nganzi
\q1 kuidi tsungi yina ; ndituba :
\q1 “badi batu badi mintima mizimbila
\q1 ayi basia zaba zinzila ziama ko.”
\q1 
\v 11 Diawu ndizengila ndefi ku tsi nganzi ama :
\q1 “balendi kota ko mu luvundulu luama.”
\c 96
\cl Minkunga 96
\s1 Bika nza yimvimba yisanisina Yave, ntinu andi.
\q1 
\v 1 Luyimbidila Yave nkunga wumona.
\q1 Luyimbidila Yave, ntoto wumbimba.
\q1 
\v 2 Luyimbidila Yave,
\q1 zitisanu dizina diandi ;
\q1 yamikisanu phulusu andi
\q1 lumbu ka lumbu.
\q1 
\v 3 Yolukilanu nkembo andi muidi makanda
\q1 mambu mandi matsiminanga
\q1 muidi batu boso.
\q1 
\v 4 Bila Yave widi wunneni
\q1 ayi lutidi mu zitusu ;
\q1 tsisi kadi va yilu zinzambi zioso.
\q1 
\v 5 Bila zinzambi zi makanda zidi bitumba ;
\q1 vayi Yave niandi wuvanga diyilu.
\q1 
\v 6 Kiezila ayi nzitusu bidi va ntualꞌandi
\q1 zingolo ayi nkembo bidi mu buangu kiandi ki nlongo.
\q1 
\v 7 Luvana kuidi Yave,
\q1 e mabuta ma makanda ;
\q1 luvana kuidi Yave nkembo ayi ngolo.
\q1 
\v 8 Luvana nkembo kuidi Yave wufueni mu dizina diandi.
\q1 Lunata dikaba ayi lukota mu ziphangu ziandi.
\q1 
\v 9 Lubuongimina Yave mu kiezila ki bunlongo buandi.
\q1 Tita va ntualꞌandi, ntoto wumvimba.
\q1 
\v 10 Tuba muidi makanda :
\q1 “Yave weti yala.”
\q1 Nza yidi yikinda dio ngui ;
\q1 yilendi nikuka ko
\q1 bila Yave wela sambisa batu mu bufuana.
\q1 
\v 11 Bika diyilu dimona khini,
\q1 bika ntoto wuyangalala.
\q1 Bika mbu wutula biyoko ayi bibio bidi muna.
\q1 
\v 12 Bika zitsola zimona khini
\q1 ayi bibio bidi muna ;
\q1 buna minti mioso mi nsitu miyimbila
\q1 mu diambu di khini.
\q1 
\v 13 Miela yimbila va ntuala Yave, bila wulembo yizi,
\q1 wulembo yizi mu sambisa ntoto.
\q1 Wela sambisa nza mu busonga
\q1 ayi batu mu Kedika kiandi.
\c 97
\cl Minkunga 97
\s1 Nzambi yinneni yi nza.
\q1 
\v 1 Yave weti yala, bika ntoto wuyangalala.
\q1 Bika bisanga biobi bidi thama bimona nkini.
\q1 
\v 2 Matuti ayi tombi kinkobo binzungididi.
\q1 Busonga ayi bufuana biawu
\q1 fundasio yi kundu kiandi ki kipfumu.
\q1 
\v 3 Mbazu yeti kuenda ku ntualꞌandi
\q1 ayi yeti zinisa batu bobo beti kunlenda ku kadika ndambu
\q1 
\v 4 Zitsiemo ziandi zieti kienzula nza,
\q1 ntoto weti mona ayi weti tita.
\q1 
\v 5 Miongo misiuta banga mafuta momo beti vinda mu bikundu va ntuala Yave,
\q1 va ntuala Yave wu ntoto wumvimba.
\q1 
\v 6 Diyilu dieti yamikina busonga buandi
\q1 ayi batu boso beti mona nkembo andi.
\q1 
\v 7 Babo bobo bambuongiminanga zimfikula beti fua tsoni ;
\q1 bobo beti kukiniemisa mu diambu di bitumba.
\q1 Lumbuongimina, beno zinzambi zioso.
\q1 
\v 8 Sioni weti wa ayi weti mona khini
\q1 ayi bana ba baketo ba Yuda beti yangalala
\q1 mu diambu di zinzengolo ziaku, a Yave.
\q1 
\v 9 Bila ngeyo Yave, widi Nzambi yizangama va ntoto wumvimba.
\q1 Ngeyo widi wuyayusu ngolo
\q1 va yilu zinzambi zioso.
\q1 
\v 10 Bika babo beti zola Yave, balenda mambimbi.
\q1 Bila weti keba luzingu lu banlongo bandi.
\q1 Niandi wukubakulanga mu mioko mi batu bambimbi.
\q1 
\v 11 Kiezila kieti totuka mu diambu di batu basonga
\q1 ayi khini mu diambu di bobo
\q1 badi lulama mu mintima.
\q1 
\v 12 Bika lumona khini mu Yave, beno luidi basonga
\q1 ayi luzitisa dizina diandi di nlongo.
\c 98
\cl Minkunga 98
\s1 Nzambi wizidi mu sambisa nza
\d Nkunga.
\q1 
\v 1 Yimbidilanu Yave nkunga wumona
\q1 bila wuvengi mambu ma kitoko.
\q1 Koko kuandi ku lubakala ayi koko kuandi kunlongo
\q1 mivengi phulusu mu diambu diandi.
\q1 
\v 2 Yave wuzabikisa phulusu andi ;
\q1 ayi wumonisa busonga buandi kuidi makanda.
\q1 
\v 3 Wutebukila luzolo luandi moyo
\q1 ayi kikhuikizi kiandi kuidi nzo yi Iseli.
\q1 Zitsukusunu zioso zi ntoto
\q1 zimona phulusu yi Nzambi eto.
\q1 
\v 4 Yamikina mu khini kuidi Yave, ntoto wumvimba ;
\q1 ludila mu nkunga mi mayangi va kimosi ayi miziki.
\q1 
\v 5 Lubula miziki kuidi Yave mu ngitala,
\q1 mu ngitala ayi mu biyoko bi nyimbidi ;
\q1 
\v 6 mu zitulumbeta ayi mu biyoko bi phoka yi dimemi,
\q1 yamikinanu mu khini va ntuala Yave, ntinu.
\q1 
\v 7 Bika mbu wuwakikisa biyoko va kimosi
\q1 ayi kadika kima kidi muna ;
\q1 bika nza ayi babo bobo banzingilanga muawu bayamikina.
\q1 
\v 8 Bika minlangu minneni mibula mioko miawu.
\q1 Bika miongo miyimbila va kimosi mu khini ;
\q1 
\v 9 bika bayimbila va ntuala Yave
\q1 bila wulembo yizi mu diambu di sambisa ntoto.
\q1 Niandi wela sambisa nza mu busonga
\q1 ayi batu mu bufuana.
\c 99
\cl Minkunga 99
\s1 Lubuongimina Yave bila widi wunlongo
\q1 
\v 1 Yave weti yala,
\q1 bika makanda matita
\q1 vuandisidi kundu kiandi ki kipfumu va khatitsika Bakeluba.
\q1 Bika ntoto wunikuka.
\q1 
\v 2 Yave widi wunneni mu Sioni
\q1 widi wuyayusu va yilu makanda moso.
\q1 
\v 3 Bika bazitisa dizina diaku dinneni ayi ditsisi.
\q1 Niandi widi wunlongo.
\q1 
\v 4 Ntinu widi wu lulendo wunzolanga busonga.
\q1 Ngeyo wukindisa mambu mafuana
\q1 Mu Yakobi, wuvanga momo madi masonga ayi malulama.
\q1 
\v 5 Luyayisa Yave, Nzambi eto.
\q1 Lubuongama va ntuala buangu kioki
\q1 keti tetikanga malu mandi.
\q1 Niandi widi wunlongo.
\q1 
\v 6 Moyize ayi Aloni baba va khatitsika
\q1 zinganga ziandi zi Nzambi ;
\q1 Samueli wuba va khatitsika bobo bantelanga
\q1 dizina diandi,
\q1 batela Yave
\q1 ayi niandi wuba vana mvutu.
\q1 
\v 7 Niandi wuba yolukila mu dikunzi di dituti.
\q1 Bawu bakeba zinzengolo ziandi
\q1 ayi zithumunu ziosi kaba vana.
\q1 
\v 8 A Yave, Nzambi eto, ngeyo wuba vana mvutu.
\q1 Ngeyo wuba kuidi Iseli, ngeyo wuba Nzambi
\q1 yoyi yiba kuba lemvukilanga ;
\q1 ka diambu ko ngeyo wuba kuba vananga
\q1 thumbudulu mu mavanga mawu mambimbi.
\q1 
\v 9 Yayisanu Yave, Nzambi eto.
\q1 Lubuongama va ntuala mongo andi wunlongo
\q1 bila Yave, Nzambi eto, widi wunlongo.
\c 100
\cl Minkunga 100
\s1 Yave wulembo zitusu kuidi batu bandi
\d Nkunga wu phutudulu matondo.
\q1 
\v 1 Yamikinanu mu khini kuidi Yave, ntoto wumvimba.
\q1 
\v 2 Lubuongimina Yave mu khini ;
\q1 yizanu va ntualꞌandi mu minkunga mi khini.
\q1 
\v 3 Luzaba ti Yave niandi Nzambi.
\q1 Niandi wutuvanga ayi niandi wutuvuidi.
\q1 Tuidi batu bandi ; nkangu andi, wu mamemi
\q1 wowo kedi dikila.
\q1 
\v 4 Kotanu mu mielo miandi mu phutudulu matondo
\q1 ayi mu ziphangu ziandi va kimosi ayi minzitusu.
\q1 Lumvutudila matondo ayi luzitisa dizina diandi.
\q1 
\v 5 Bila Yave widi wumboti
\q1 ayi luzolo luandi lunzingila mu zithangu zioso.
\q1 Ayi kikhuikizi kiandi kidi mu zitsungi zioso.
\c 101
\cl Minkunga 101
\s1 Kukiyekula mu nuanisa mambimbi
\d Nkunga Davidi.
\q1 
\v 1 Ndiela yimbidila luzolo luaku ayi busonga ;
\q1 Kuidi ngeyo ndiela yimbidila minzitusu.
\q1 
\v 2 Ndiela lubaka mu diatila mu luzingu lukambulu tsembolo.
\q1 Thangu mbi wela kuiza kuidi minu e ?
\q1 Ndiela diatila mu nzo ama
\q1 mu ntima wukambulu tsembolo.
\q1 
\v 3 Ndilendi tula ko va ntuala meso mama
\q1 kadi kima kimosi ko kimbimbi.
\q1 Ndieti lenda mavanga ma bobo
\q1 bakambulu bakuikama
\q1 malendi kundama ko.
\q1 
\v 4 Batu badi mintima mi mbimbi thama bela kuthatukila
\q1 ndilendi vanga kadi diambu dimosi va kimosi ayi mambimbi
\q1 
\v 5 Woso wuntubidila mutu fikimini yandi mu kinsueki,
\q1 ndiela ku ntula dio sui.
\q1 Woso widi meso ma lunangu
\q1 ayi widi ntima wu luniemo ;
\q1 ndilendi ku nzingisa kuwombo ko.
\q1 
\v 6 Meso mama mela ba va mikhuikizi
\q1 mi tsi muingi bakalanga yama ;
\q1 woso wundiatila mu kambu tsembolo, wela kutsadila.
\q1 
\v 7 Kadi mutu wunsadilanga bukhita
\q1 lenda vuanda mu nzo ama.
\q1 Kadi mutu wuntubanga luvunu lenda telama
\q1 va meso mama.
\q1 
\v 8 Kadika nsuka, ndiela tula dio sui
\q1 batu boso bambimbi badi va ntoto ;
\q1 ndiela lalikisa kisadi kioso ki mbimbi
\q1 mu divula di Yave.
\c 102
\cl Minkunga 102
\s1 Lusambulu lu nkua mabienga
\d Lusambulu lu nkua mabienga weka vonga ayi wulembo kambi ziphasi ziandi kuidi Yave.
\q1 
\v 1 Wa lusambulu luama, a Yave,
\q1 bika yamikina kuama mu diambu di lusadusu kutula kuidi ngeyo
\q1 
\v 2 Kadi kutsuekila zizi kiaku thangu ndidi mu phasi,
\q1 tamba dikutu diaku kuidi minu ;
\q1 thangu ndikutela, sia nsualu ; wuphana mvutu !
\q1 
\v 3 Bila bilumbu biama bilembo lalakana banga muisi,
\q1 mimvesi miama milembo yokana
\q1 banga makaba ma ku mbazu.
\q1 
\v 4 Ntimꞌama wukosikini ayi wuyumini banga biti ;
\q1 ndizimbikini dia bidia biama.
\q1 
\v 5 Mu diambu di kunga kuama
\q1 nkanda nitu kaka ayi mimvesi misiala.
\q1 
\v 6 Ndidi banga kimfutu kidi mu dikanga ;
\q1 banga kimfutu va khatitsika
\q1 bibuangu bikambulu batu ;
\q1 
\v 7 Ndilembo leki nkielo,
\q1 ndieka banga nuni
\q1 yidi yawu veka ku yilu nzo.
\q1 
\v 8 Mu lumbu kimvimba,
\q1 bambeni ziama zilembo mfingi ;
\q1 bobo bamekumfuemina,
\q1 balembo sadila dizina diama banga tsingulu.
\q1 
\v 9 Bila ndilembo dia dibombi banga bidia
\q1 ayi ndisobikisidi ndiunu ama ayi matsuela
\q1 
\v 10 mu diambu di miangu miaku minneni
\q1 bila ngeyo wunzangula ngolo
\q1 ayi wundozidi va lutengo.
\q1 
\v 11 Bilumbu biama bidi banga kitsusula ki masika
\q1 ndime yuma banga biti.
\q1 
\v 12 Vayi ngeyo, a Yave, wuvuanda va kundu ki kitinu mu zithangu zioso ;
\q1 tsangu aku yilembo zingila mu tsungi ka tsungi.
\q1 
\v 13 Ngeyo wela telama, wela monina Sioni kiadi.
\q1 Bila yawu yoyi thangu yimonisa nlemvo kuidi niandi ;
\q1 thangu yoyi wukubika yfueni.
\q1 
\v 14 Bila bisadi biaku binzolanga matadi mandi,
\q1 ayi bieti mona kiadi
\q1 mbungi-mbungi andi yela kubanata mu tezo kimona kiadi.
\q1 
\v 15 Makanda mela kinzika dizina di Yave ;
\q1 mintinu mioso mi ntoto
\q1 miela kinzika nkembo aku.
\q1 
\v 16 Bila Yave wela buela tunga diaka Sioni
\q1 ayi wela monika mu nkembo andi.
\q1 
\v 17 Wela vana mvutu mu lusambulu lu batu basukama,
\q1 kalendi lenza maniongo mawu ko.
\q1 
\v 18 Bika mambu mama masonama mu diambu di tsungi yinkuiza
\q1 muingi batu bobo kabavangimini ko babaka buzitisila Yave.
\q1 
\v 19 Yave wutala ku tsi tona ku buangu kiandi kinlongo kidi ku yilu
\q1 tona ku diyilu niandi wuntala ntoto,
\q1 
\v 20 mu diambu di wa kunga ku batu badi mu nloko ;
\q1 ayi mu diambu di kula bobo bazengolo nkanu wu lufua ;
\q1 
\v 21 buna dizina di Yave diela yolukulu mu Sioni
\q1 ayi minzitusu miandi mu Yelusalemi
\q1 
\v 22 mu thangu batu bela kutangana va kimosi ayi bipfumu
\q1 mu diambu di buongimina Yave.
\q1 
\v 23 Mu luzingu luama, wumanisa zingolo ziama ;
\q1 wukufika bilumbu biama.
\q1 
\v 24 Buna ndituba :
\q1 “kadi kumbotula, a Nzambi ama, va khatitsika yi bilumbu biama ;
\q1 mimvu miaku miela zingilanga mu tsungi ka tsungi.
\q1 
\v 25 Va thonono, ngeyo wutula zifondasio zi ntoto
\q1 ayi diyilu didi kisalu ki mioko miaku.
\q1 
\v 26 Biela biva vayi ngeyo wela zinganga,
\q1 bibioso biela mana vembudila banga nledi,
\q1 ngeyo wela bibalula banga kikhutu ayi biawu biela vengumunu.
\q1 
\v 27 Vayi ngeyo wubalukanga ko,
\q1 ayi mimvu miaku milendi suka ko.
\q1 
\v 28 Bana ba bisadi biaku bela zingilanga va meso maku
\q1 minkuna miawu miela ba mitelama dio ngui va ntualꞌaku.”
\c 103
\cl Minkunga 103
\s1 Bika nituꞌama yimvimba yizitisa Yave
\d Nkunga Davidi.
\q1 
\v 1 Zitisa Yave, a muelꞌama ;
\q1 bibioso bidi mu minu bizitisa dizina diandi dinlongo.
\q1 
\v 2 Zitisa Yave, a muelꞌama, ayi kadi zimbakana mamboti mandi moso kavanga.
\q1 
\v 3 Niandi weti lemvukila masumu maku moso
\q1 ayi weti belusa minsongo miaku bioso.
\q1 
\v 4 Niandi weti kula luzingu luaku mu dibulu ;
\q1 ayi niandi weti kuvuika luzolo ayi kiadi.
\q1 
\v 5 Niandi weti yukutisa zitsatu ziaku mu bima bimboti
\q1 muingi bumuana buaku bukituka diaka bumona
\q1 banga buididi bu mbemba.
\q1 
\v 6 Yave wumvanganga busonga
\q1 ayi bufuana mu diambu di batu boso beti yamusu.
\q1 
\v 7 Wuzabikisa zinzila ziandi kuidi Moyize
\q1 mavanga mandi kuidi batu ba Iseli.
\q1 
\v 8 Yave widi nkua kiadi ayi nkua nlemvo ;
\q1 kavika fuemanga ko, fulukidi mu luzolo.
\q1 
\v 9 Niandi kafundanga ko mu zithangu zioso
\q1 ayi kalundanga ko nganzi andi mu zithangu zioso.
\q1 
\v 10 Katu vangilanga ko boso buididi masumu meto,
\q1 katuvananga ko thumbudulu boso buididi mambimbi meto.
\q1 
\v 11 Bila boso diyilu didi dizangama va yilu ntoto ;
\q1 buawu bobo luzolo luandi luidi lunneni
\q1 kuidi bobo beti kunkinzikanga.
\q1 
\v 12 Boso esite katatukididi ayi wesite,
\q1 buawu bobo katutatudila zinzimbala zieto.
\q1 
\v 13 Banga dise bu kamoninga bana bandi kiadi,
\q1 buawu bobo Yave kamoninga kiadi bobo beti kunkinzika.
\q1 
\v 14 Bila zebi buevi tuvangulu
\q1 weti tebuka moyo ti tuidi mbungi-mbungi.
\q1 
\v 15 Bila kuidi mutu, bilumbu biandi bidi banga biti ;
\q1 weti mona mamboti banga biteka bi tsola.
\q1 
\v 16 Phemo yawu viokila va bidi, buna bisiedi ko
\q1 ayi buangu kibibedi kikadi buela kubitebukila moyo.
\q1 
\v 17 Vayi mu kadika thangu ayi mu zithangu zioso
\q1 luzolo lu Yave luidi kuidi bobo beti kunkinzika
\q1 ayi busonga buandi kuidi bana ba bana bawu ;
\q1 
\v 18 kuidi bobo beti keba Nguizani andi
\q1 ayi kuidi bobo bantebukilanga tumukina minsiku miandi.
\q1 
\v 19 Yave wutula kundu kiandi ki kipfumu ku diyilu
\q1 ayi kipfumu kiandi kinyadila bima bioso.
\q1 
\v 20 Luzitisa Yave beno zimbasi ziandi ;
\q1 beno makesa lueti vanga zithumunu ziandi,
\q1 lueti tumukina mambu mandi.
\q1 
\v 21 Luzitisa Yave beno minkangu mi masodi mandi ma diyilu ;
\q1 beno bisadi biandi lueti vanganga luzolo luandi.
\q1 
\v 22 Luzitisa Yave beno mavanga mandi moso,
\q1 mu bibuangu bioso biobi keti yadila.
\q1 Zitisa Yave, a muelꞌama.
\c 104
\cl Minkunga 104
\s1 Nzitusu kuidi mvangi
\q1 
\v 1 Zitisa Yave, a muelꞌama.
\q1 A Yave, Nzambi ama, ngeyo widi wunneni ngolo.
\q1 Ngeyo vueti kiezila ayi nzitusu.
\q1 
\v 2 Niandi wukifukidi muinda banga nledi ;
\q1 weti yalumuna diyilu banga nzo yi ngoto,
\q1 
\v 3 ayi wutunga makunzi ma bivinga biandi bizangama va minlangu miawu.
\q1 Niandi weti kitula matuti ditoma diandi di sengo
\q1 ayi weti diatila mu mavavi ma phemo.
\q1 
\v 4 Wunkitulanga phemo bamvuala bandi,
\q1 minlaki mi mbazu bisadi biandi.
\q1 
\v 5 Wuvuandisa ntoto va zifondasio ziandi ;
\q1 wulendi nikuka ko kadi fifioti.
\q1 
\v 6 Ngeyo wufukidila wawu mu thipula banga ngeyo wumfukididi nledi,
\q1 Minlangu mitelama nate ku mbata miongo.
\q1 
\v 7 Vayi bu wutema, minlangu mitina,
\q1 mu biyoko bi dumu kiaku, miawu mitina.
\q1 
\v 8 Mikumbila va mbata miongo,
\q1 mibua nate mu mindimba ku buangu kioki wukubikila miawu.
\q1 
\v 9 Ngeyo wumitudila zindilu ziozi ka milendi sabuka ko ;
\q1 milendi buela diamisa ntoto ko.
\q1 
\v 10 Niandi wukubika zitho zi minlangu
\q1 mu zikhola zinkumbanga va khatitsika miongo.
\q1 
\v 11 Zilembo vani nlangu kuidi bibulu bioso bi tsola,
\q1 ziphunda zi nsitu zimanisinanga phuilꞌawu.
\q1 
\v 12 Zinuni zi yilu zintunganga dianla mu yenda minlangu,
\q1 zieti yimbila va khatitsika matafi.
\q1 
\v 13 Wulembo lembila miongo tona ku bivinga biandi bizangama ;
\q1 ntoto wuyukutidi mu mbutu wu kisalu kiandi.
\q1 
\v 14 Niandi weti menisa biti mu diambu di bibulu,
\q1 ayi bikunusu mu diambu di batu bakuna,
\q1 ayi totulanga bidia mu ntoto :
\q1 
\v 15 vinu kieti yangidika ntima wu mutu,
\q1 mafuta meta kienzula zizi kiandi
\q1 ayi dipha dieti kindisa ntimꞌandi.
\q1 
\v 16 Minti mi Yave midi milembolo bumboti ;
\q1 minti mi sedeli mi tsi Libani miomi kakuna.
\q1 
\v 17 Muawu zinuni zieti tungila zindiala ziawu ;
\q1 nuni beti tedila ngongo yitungila nzo andi mu minti mimbutanga zimbala zi phutu.
\q1 
\v 18 Miongo mi nangama mivuiwulu kuidi zikhombo zi nsitu ;
\q1 zithadi zidi suamunu mu diambu di bibulu bieti tedolo damani\f + \fr 104.18 \fq Damani\fqa  : \ft bulu kidi banga kikueya.\f*.
\q1 
\v 19 Ngondi yeti vasa zitsungi,
\q1 ayi thangu zebi thangu mbi kafueti diamina.
\q1 
\v 20 Ngeyo weti nata tombi, buisi bueti yila
\q1 ayi buna bibulu bioso bi nsitu bilembo diengila-diengila.
\q1 
\v 21 Zikhosi zillembo kungi mu diambu di biobi zifueti buila
\q1 ayi zieti tomba bidia biawu kuidi Nzambi.
\q1 
\v 22 Thangu yawu totuka, buna zivengumukini ;
\q1 zivutukidi ayi zilekidi mu minsuku miawu.
\q1 
\v 23 Buna mutu weti kuenda ku kisalu kiandi,
\q1 ku kisalu kiandi nate buisi bu nyila.
\q1 
\v 24 Phila bisalu biaku bididi woka, a Yave ;
\q1 mu nduenga wuvangila bibioso
\q1 ntoto wufulukidi mu bivangu biaku.
\q1 
\v 25 Vadi mbu wumosi, wunneni ayi wuyalumuka ;
\q1 muwedi bivangu ka bilendi baka bu tangulu ko ;
\q1 bima bimoyo bifioti ayi binneni.
\q1 
\v 26 Muawu mu nkuendilanga ayi vutukilanga masuwa ;
\q1 ayi Leviatani, bulu kioki wuvanga, muawu kieti sakinina.
\q1 
\v 27 Bibioso bikutalanga muingi wuba vananga bidia biawu mu thangu yifuana.
\q1 
\v 28 Thangu weti kubivana bidia, bieti bonga biawu ;
\q1 ngeyo zibula koko kuaku, bieti yukuta mu bima bimboti.
\q1 
\v 29 Ngeyo sueka zizi kiaku, buna bieka mona tsisi.
\q1 Ngeyo biziona vumunu kiawu, buna bieti fua ayi bieti vutuka mu mbungi-mbungi.
\q1 
\v 30 Ngeyo fidisa vumunu kiaku, buna bivangimini
\q1 ayi ngeyo weti kitula diaka zizi ki ntoto kimona.
\q1 
\v 31 Bika Nkembo wu Nzambi wuzingila mu zithangu zioso ;
\q1 bika Yave kayangalala mu bisalu biandi !
\q1 
\v 32 Niandi wuntalanga ku ntoto, ayi ntoto wulembo titi.
\q1 Niandi wulembo simba miongo ayi milembo totula muisi.
\q1 
\v 33 Ndiela yimbidilanga Yave mu luzingu luama loso.
\q1 Ndiela yimbidilanga Nzambi ama minzitusu thangu yoso yi luzingu luama.
\q1 
\v 34 Bika mambu mama ndinyindula mammonisa khini
\q1 banga phila ndilembo muena khini mu Yave.
\q1 
\v 35 Vayi bika bankua masumu balalukusu va ntoto,
\q1 ayi bika batu bambimbi babika buela monika !
\q1 Zitisa Yave, a muelꞌama !
\q1 Bika Yave kazitusu !
\c 105
\cl Minkunga 105
\s1 Nzambi widi wukuikama
\q1 
\v 1 Luvutudila Yave matondo, lutela dizina diandi !
\q1 Luzabikisa momo kavanga muidi makanda.
\q1 
\v 2 Lunyimbidila ; lunyimbidila minzitusu.
\q1 Luyolukila mavanga mandi moso matsiminanga.
\q1 
\v 3 Nkembo kuidi dizina diandi dinlongo ;
\q1 Bika mintima mi bobo bantombanga Yave mimona khini.
\q1 
\v 4 Talanu kuidi Yave ayi kuidi zingolo ziandi ;
\q1 Tombanganu mu zithangu zioso zizi kiandi.
\q1 
\v 5 Lutebukilanga moyo matsiminanga momo kavanga ;
\q1 bikumu biandi ayi zinzengolo ziozi kayamikisa ;
\q1 
\v 6 beno nkuna Abalahami, kisadi kiandi,
\q1 beno bana ba Yakobi, batu bandi kasobula !
\q1 
\v 7 Yave niandi Nzambi eto ;
\q1 zinzengolo ziandi zidi va ntoto wumvimba.
\q1 
\v 8 Wuntebukilanga moyo nguizani andi mu zithangu zioso,
\q1 mambu momo katumina mu mili di zitsungi.
\q1 
\v 9 Nguizani yoyi yi kawizana ayi Abalahami ;
\q1 ndefi yoyi kadila Izaki.
\q1 
\v 10 Wukindisa yawu kuidi Yakobi banga nzengolo ;
\q1 kuidi Iseli banga nguizani mu zithangu zioso ;
\q1 
\v 11 “Kuidi ngeyo ndiela vana ntoto wu Kana
\q1 banga kuku ki kiuka kioki wela tambula.”
\q1 
\v 12 Buna bakidi thalu yi fioti kaka,
\q1 bafioti kuandi, banzenza mu tsi beni ;
\q1 
\v 13 vayi baba kuenda diengilanga mu makanda-makanda
\q1 tona mu kipfumu kimosi nate ku kipfumu kinkaka.
\q1 
\v 14 Kasia vana ko minsua kuidi kadi mutu wumosi mu kuba yamisa
\q1 mu diambu diawu wutemina mintinu.
\q1 
\v 15 “Kadi simba batu bama bobo ndivinda mafuta ;
\q1 kadi vangila mimbikuidi miama mambu mambimbi.”
\q1 
\v 16 Wutumisa kanda kingolo va ntoto
\q1 ayi wubunga bidia biawu bioso balunda.
\q1 
\v 17 Buna wufidisa mutu wumosi ku ntualꞌawu :
\q1 Zozefi wutekoso banga mvika.
\q1 
\v 18 Bakanga malu mandi mu zisieni ;
\q1 batula dinga diandi mu bisengo
\q1 
\v 19 nate mambu makatuba mavioka ;
\q1 nate mambu ma Yave mamonisa ti makiedika katuba.
\q1 
\v 20 Ntinu wufidisa ayi bannianguna ;
\q1 nyadi wu batu wunyekula mu kiphuanza.
\q1 
\v 21 Wumbieka pfumu mu nzo andi
\q1 nyadi wu bima bioso biobi kavua,
\q1 
\v 22 mu longa bana ba mintinu boso bu kazodidi
\q1 ayi vana nduenga kuidi bakulutu bandi.
\q1 
\v 23 Buna Iseli wukota ku Ezipite ;
\q1 Yakobi wuzingila banga nzenza mu tsi yi Hami.
\q1 
\v 24 Yave wuvanga ti batu bandi babutuka kuwombo
\q1 ayi wuba kitula batu bawombo viokila bobo baba lenda ;
\q1 
\v 25 bobo kabalula mintima mu lenda batu bandi,
\q1 mu kuendila bisadi biandi manenga.
\q1 
\v 26 Wufidisa Moyize, kisadi kiandi,
\q1 ayi Aloni mutu wowo kasobula.
\q1 
\v 27 Bavanga bidimbu biandi va khatitsikꞌawu,
\q1 matsiminanga mandi mu tsi Hami.
\q1 
\v 28 Wufidisa tombi ayi wutula tombi mu ntoto
\q1 bila basia tinguna ko mambu mandi e ?
\q1 
\v 29 Wukitula minlangu miawu menga ;
\q1 wumana sikisa vonda zimbizi ziawu.
\q1 
\v 30 Mintoto miawu miwala bisioto ;
\q1 biobi bikota nate mu bivinga bi minyadi miawu.
\q1 
\v 31 Wutuba ayi kuyiza zinzinzi ziba mitsa
\q1 ayi zingungu mu tsi awu yoso.
\q1 
\v 32 Niandi wubalula mvula mu mvula yi matadi
\q1 nzazi mu ntoto wumvimba.
\q1 
\v 33 Wumana buisa minti miawu mi vinu ayi minti miawu mi figi,
\q1 ayi kelula minti mi tsi awu.
\q1 
\v 34 Wutuba ayi makhoko mayiza ;
\q1 binzienzi bikambulu thalu.
\q1 
\v 35 Bidia kadika kunusu kinlangu mu tsi awu ;
\q1 bidia mimbutu mi ntoto awu.
\q1 
\v 36 Buna wumana vonda bana boso batheti mu tsi awu,
\q1 mimbutu mioso mitheti mi zingolo ziawu.
\q1 
\v 37 Wutotula Iseli va kimosi ayi mfuna wu palata ayi nolo ;
\q1 ayi kusia monika ko mutu wumemata mu zimvila ziawu.
\q1 
\v 38 Ezipite yimona khini bubayenda
\q1 bila tsisi yi Iseli yiba buila.
\q1 
\v 39 Wuyalumuna matuti mu diambu di kuba fuka
\q1 ayi mbazu mu kuba kienzula va builu.
\q1 
\v 40 Balomba ayi wuba fidisila zinuni
\q1 ayi wuba yukutisa mu mapha ma diyilu.
\q1 
\v 41 Wuzibula ditadi ayi nlangu wutotuka ;
\q1 banga nlangu wunneni wukumba mu dikanga.
\q1 
\v 42 Bila wutebukila moyo tsilꞌandi yinlongo
\q1 yoyi kavana kuidi Abalahami, kisadi kiandi.
\q1 
\v 43 Wutotudila batu bandi mu khini
\q1 batu bandi bobo kasobula mu biyoko bi mayangi.
\q1 
\v 44 Wuba vana mintoto mi makanda,
\q1 ayi batambula kiuka kisala batu bankaka.
\q1 
\v 45 Muingi balunda minsiku miandi
\q1 ayi bakinzika Mina miandi.
\q1 Luzitisa Yave.
\c 106
\cl Minkunga 106
\s1 Enati tuisi bakuikama ko, vayi Nzambi widi kaka wukuikama.
\q1 
\v 1 Luzitisa Yave,
\q1 luvutudila Yave matondo bila widi wumboti,
\q1 luzolo luandi lunzingila mu zithangu zioso.
\q1 
\v 2 Nani wulenda yamikisa mavanga ma lulendo ma Yave ?
\q1 Voti samuna nzitusu andi woso e ?
\q1 
\v 3 Lusakumunu kuidi bobo basimbididi busonga ;
\q1 bobo beti vanga mambu ma lulama mu zithangu zioso.
\q1 
\v 4 Wuthebukila moyo, a Yave, mu thangu wumvangila batu baku mamboti
\q1 wiza wutsadisa mu thangu wela kubavukisa,
\q1 
\v 5 muingi ndibaka bu muena khini mu mamboti ma batu baku bobo wusobula ;
\q1 muingi ndibaka bukabudila khini ayi batu baku ;
\q1 ayi muingi ndifubakana va kimosi ayi kiuka kiaku mu kuvananga nzitusu.
\q1 
\v 6 Tuvola masumu banga buvodila madise meto ;
\q1 beto tuvanga mambimbi ayi mavanga mambimbi.
\q1 
\v 7 Thangu madise meto baba ku Ezipite,
\q1 basia ba ko kadi mayindu mu bikumu biaku ;
\q1 basia tebukila ko moyo woka ku mamboti maku
\q1 vayi baba bankua matingu va ndambu mbu,
\q1 va ndambu mbu wu mbuaki.
\q1 
\v 8 Vayi wuba vukisa mu diambu di nkembo wu dizina diandi
\q1 mu monisa lulendo luandi.
\q1 
\v 9 Wutemina mbu wu mbuaki, buna wawu wuyuma ;
\q1 wuba diatisa mu dibulu dinneni banga mu dikanga.
\q1 
\v 10 Wuba vukisa mu koko ku mutu wowo wu balenda ;
\q1 wuba kula mu koko ku bambeni.
\q1 
\v 11 Minlangu midiamisa bambeni ziawu ;
\q1 kadi wumosi kasia siala wumoyo ko.
\q1 
\v 12 Buna bawilukila zitsila ziandi
\q1 ayi bayimbila minzitusu miandi.
\q1 
\v 13 Vayi mu nsualu bavika zimbakana momo kavanga,
\q1 ayi basia tadidila zindongi ziandi ko.
\q1 
\v 14 Mu dikanga, bakiyekula mu zinzinunu ziawu ;
\q1 va buangu kikambulu batu, batota Nzambi.
\q1 
\v 15 Buna wuba vana biobi balomba ;
\q1 ayi wubafidisila ziphasi.
\q1 
\v 16 Bavangila Moyize kiphala ayi Aloni ku ka,
\q1 mutu wowo Yave kabieka nlongo.
\q1 
\v 17 Ntoto wuzibuka ayi wumina Datani ;
\q1 ayi wufuka dikabu di batu ba Abilami
\q1 
\v 18 Mbazu yilema va khatitsika batu baba kubakuka,
\q1 nlaki wu mbazu wuzinisa batu bambimbi.
\q1 
\v 19 Ku Holebi, bavanga muana ngombi ;
\q1 ayi babuongimina tumba kivangulu mu suitisa sengo.
\q1 
\v 20 Baviakisa nkembo awu mu mfikula yi ngombi yeti dia biti
\q1 
\v 21 Bazimbakana Nzambi, mutu wubavukisa,
\q1 mutu wuvanga mambu manneni mu Ezipite,
\q1 
\v 22 bikumu mu tsi Hami
\q1 ayi mambu ma tsisi va ndambu mbu wu mbuaki.
\q1 
\v 23 Buna wutuba ti wukana ku babunga ;
\q1 enati kambu Moyize, mutu andi wukasobula,
\q1 wutelama mu diambu di kuba sambildila va ntualꞌandi
\q1 mu diambu di kakidila miangu miandi mi ngolo muingi kabika ku babunga.
\q1 
\v 24 Buna balenza tsi yi makhini,
\q1 basia wilukila ko tsilꞌandi.
\q1 
\v 25 Baniunguta mu zinzo ziawu zi ngoto ;
\q1 ayi basia tumukina ko Yave.
\q1 
\v 26 Buna wuvumuna koko kuandi mu leva ndefi mu diambu diawu
\q1 ti wela kuba buisa mu dikanga ;
\q1 
\v 27 ti wela buisa nkunꞌawu va khatitsika makanda ;
\q1 ayi wela kuba sasikisa mu yenda ntoto.
\q1 
\v 28 Bakiyekula bawu veka kuidi Bali-Pewoli
\q1 ayi badia makaba matambuku kuidi zinzambi zikambulu moyo.
\q1 
\v 29 Basoka Yave muingi kafuema mu diambu di mavanga mawu mambimbi,
\q1 ayi nsongo wutotuka va khatitsikꞌawu.
\q1 
\v 30 Buna Pineyasi wutelama ayi wuvuata nsamu ;
\q1 buna nsongo wutumbu manisa.
\q1 
\v 31 Buna bantangila diawu banga busonga
\q1 mu zitsungi zinkuiza zikambulu tsukulu.
\q1 
\v 32 Ku minlangu mi Meliba, bafuemisa Yave ;
\q1 buna ziphasi zibuila Moyize mu diambu diawu.
\q1 
\v 33 Bila batinguna Pheve yi Nzambi
\q1 ayi mambu makambulu fuana matotukila mu bididi bi Moyize.
\q1 
\v 34 Basi bunga ko batu
\q1 boso bubela lutumunu lu Yave.
\q1 
\v 35 Vayi bafubakana ayi makanda mankaka
\q1 ayi balonguka kikhulu ki makanda beni.
\q1 
\v 36 Babuongimina bitumba biawu,
\q1 biawu bikituka ntambu kuidi bawu.
\q1 
\v 37 Batambika bana bawu bababakala
\q1 ayi babaketo kuidi ziphevi zimbimbi.
\q1 
\v 38 Batengula menga ma batu bakambulu zaba diambu ;
\q1 menga ma bana bawu bababakala ayi babaketo
\q1 mawu batambika kuidi bitumba bi Kana.
\q1 Buna ntoto wusumuka mu diambu di menga mawu.
\q1 
\v 39 Bakisumuna bawu veka mu momo bavanga,
\q1 mu mavanga mawu, ba ta kitsuza bawu veka.
\q1 
\v 40 Muaki Yave wufuemina batu bandi
\q1 ayi wukakumukina kiuka kiandi.
\q1 
\v 41 Wuba yekula kuidi makanda
\q1 ayi bobo baba lenda babayadila.
\q1 
\v 42 Bambeni bawu ziba yamisa
\q1 ayi batulu ku tsi lulendo luawu.
\q1 
\v 43 Zikhumbu ziwombo kaba kudila
\q1 vayi baba kaka bankua matingu
\q1 ayi bakibivisa mu masumu mawu.
\q1 
\v 44 Vayi wubela ziphasi ziawu mayindu
\q1 thangu kawa yamikina kuawu.
\q1 
\v 45 Mu bila kiawu, wutebukila nguizani andi moyo ;
\q1 ayi mu luzolo luandi lunneni wubalula lukanu.
\q1 
\v 46 Niandi wuvanga ti bamueno kiadi
\q1 kuidi bobo baba nata mu kivika.
\q1 
\v 47 Wutuvukisa, a Yave, Nzambi eto ;
\q1 ayi wutukutikisa tona ku makanda
\q1 muingi tubaka buvutudila dizina diaku dinlongo matondo
\q1 ayi nkembo mu nzitusu aku.
\q1 
\v 48 Yave kazitusu, Nzambi yi Iseli !
\q1 Mu zithangu zioso ayi mu mvu ka mvu.
\q1 Bika batu boso batuba : “Amen.”
\q1 Luzitisa Yave.
\c 107
\ms1 BUKU YI NTANU
\cl Minkunga 107
\s1 Nkunga wu batu bakulu
\q1 
\v 1 Luvutudila Yave matondo bila niandi widi wumboti ;
\q1 Luzolo luandi lunzingila mu zithangu zioso.
\q1 
\v 2 Bika bobo bakulu kuidi Yave batuba buawu ;
\q1 bobo kakula mu koko ku batu bobo babalenda,
\q1 
\v 3 bobo kakutikisa tona ku mintoto,
\q1 tona ku esite ayi ku wesite ; tona ku node ayi ku sude.
\q1 
\v 4 Bankaka baba diengilanga mu dikanga, buangu bikambulu batu ;
\q1 basia baka ko nzila yikotila mu divula diodi balenda vuandila.
\q1 
\v 5 Bamona nzala ayi phuila ;
\q1 ayi luzingu luawu luba nduka mu suka.
\q1 
\v 6 Buna bayamikina kuidi Yave mu ziphasi ziawu
\q1 ayi niandi wuba kula mu kiadi kiawu.
\q1 
\v 7 Niandi wuba diatisa mu nzila yisonga
\q1 mu diambu di kuenda ku divula diodi balenda baka bu vuandila.
\q1 
\v 8 Bika bavutudila Yave matondo mu diambu di luzolo luandi lu ngolo
\q1 ayi mu diambu di mavanga mandi matsiminanga momo kavangila batu.
\q1 
\v 9 Bila wumanisa phuila
\q1 ayi wuyukutisa mutu wuba nzala mu bima bi mboti.
\q1 
\v 10 Bankaka baba vuandanga mu tombi ayi ku tsi tombi ki nkobo ;
\q1 baba bakangama mu ziphasi zisieni zi sengo.
\q1 
\v 11 Bila batinguna mambu ma Nzambi,
\q1 ayi balenza zindongi zi Nzambi Yizangama.
\q1 
\v 12 Diawu kaba yekudila ku tsi kisalu ki ngolo ;
\q1 babumina thutu ayi kuisi ba ko kadi mutu mu ku basadisa.
\q1 
\v 13 Buna bayamikina kuidi Yave mu ziphasi ziawu
\q1 ayi niandi wuba vukisa mu kiadi kiawu.
\q1 
\v 14 Wuba totula mu tombi ayi ku tsi tombi ki nkobo
\q1 ayi wukelula zisieni ziawu.
\q1 
\v 15 Bika bavutudila Yave matondo mu diambu di luzolo luandi lu ngolo
\q1 ayi mu diambu di mavanga mandi matsiminanga momo kavangila batu
\q1 
\v 16 Bila wutiolumuna mielo mi palata
\q1 ayi wukesumuna bisengo binzibukulungu mielo.
\q1 
\v 17 Bankaka bakituka bivungisi mu zinzila ziawu zi matingu
\q1 ayi ziphasi mu diambu di mambimbi mawu.
\q1 
\v 18 Bakakumukina bidia bioso
\q1 ayi bafikama mielo mi lufua.
\q1 
\v 19 Buna bayamikina kuidi Yave mu ziphasi ziawu
\q1 ayi niandi wuba vukisa mu kiadi kiawu.
\q1 
\v 20 Wufidisa mambu mandi ayi wuba belusa,
\q1 wuba kula mu tsi bafua.
\q1 
\v 21 Bika bavutudila Yave matondo mu diambu di luzolo luandi lu ngolo
\q1 ayi mu diambu di mavanga mandi matsiminanga momo kavangila batu.
\q1 
\v 22 Bika batambika makaba ma phutudulu matondo
\q1 ayi bayolukila bisalu biandi mu minkunga mi khini.
\q1 
\v 23 Bankaka bayendila va mbu mu masuwa,
\q1 baba minkiti mu minlangu minneni,
\q1 
\v 24 bamona bisalu bi Yave,
\q1 mavanga mandi matsiminanga va ngingi nlangu.
\q1 
\v 25 Bila wuyoluka ayi wutotula vuka kingolo,
\q1 kioki kivumuna mayo.
\q1 
\v 26 Bakuma ku yilu ayi bakuluka ti kuna tsi ;
\q1 mu mabienga mawu, bukhafi buawu buzimbala.
\q1 
\v 27 Balembo balumuka ayi bulangana mu diata banga batu bakololo malavu
\q1 diela diawu dimanisa.
\q1 
\v 28 Buna bayamikina kuidi Yave mu ziphasi ziawu
\q1 ayi niandi wuba vukisa mu kiadi kiawu.
\q1 
\v 29 Wudigimisa vuka kingolo mu manuinguta,
\q1 mayo ma mbu madingalala.
\q1 
\v 30 Bamona khini thangu ndembama yivutuka
\q1 ayi Yave wuba nata ku disimu dibazola kuenda.
\q1 
\v 31 Bika bavutudila Yave matondo mu diambu di luzolo luandi lu ngolo
\q1 ayi mu diambu di mavanga mandi matsiminanga momo kavangila batu.
\q1 
\v 32 Bika banyayisa mu lukutukunu lu batu
\q1 ayi bika banzitisa mu dikabu di bakulutu.
\q1 
\v 33 Wukitula minlangu minneni makanga
\q1 ayi zitho zinkumba mintoto mi yuma ;
\q1 
\v 34 ayi ntoto widi mbozi mu ntoto widi tsalu
\q1 mu diambu di mambimbi ma bobo bazingila muna.
\q1 
\v 35 Wukitula dikanga mu bibuindi bi nlangu
\q1 ayi ntoto wuyuma mu zitho zinkumba ;
\q1 
\v 36 Kuna kanata nzala muingi yizingila
\q1 ayi batunga divula diodi balenda vuanda ;
\q1 
\v 37 Bakuna zitsola ayi zindima zi vinu
\q1 ziozi zieti buta mimbutu mimbozi.
\q1 
\v 38 Wuba sakumuna ayi thalu awu yiwombo yi buelama
\q1 ayi kasia tala ko ti bibulu biawu bidekuka.
\q1 
\v 39 Buna thalu awu yidekuka ayi bafua tsoni
\q1 mu diambu di khuamusu, mabienga ayi maniongo.
\q1 
\v 40 Niandi wulembo lenzi batu banneni,
\q1 wulembo badiengisa mu dikanga mu kambulu nzila.
\q1 
\v 41 Vayi weti totula nsukami mu ziphasi ziandi
\q1 ayi weti wokisa makanda mawu banga minkangu mi mamemi.
\q1 
\v 42 Batu balulama mu mintima balembo moni ayi balembo yangalala
\q1 vayi batu boso bambimbi bazibikidi miunu miawu.
\q1 
\v 43 Woso mutu widi nduenga bika kakeba mambu mama
\q1 ayi kasudika luzolo lunneni lu Yave.
\c 108
\cl Minkunga 108
\s1 Ndiela nunga
\d Nkunga Davidi.
\q1 
\v 1 Ntimꞌama widi wukinda, a Nzambi.
\q1 Ndiela yimbila ayi ndiela bula miziki mu muelꞌama woso.
\q1 
\v 2 Kotukanu beno ngitala ayi Lila ;
\q1 ndiela kotula khiesa buisa.
\q1 
\v 3 Ndiela kuzitisa, a Yave, va khatitsika makanda,
\q1 ndiela kuyimbidila va khatitsika batu
\q1 
\v 4 Bila luzolo luaku luidi lunneni, luidi luzangama viokila diyilu
\q1 kikhuikizi kiaku kieti tula nate ku matuti.
\q1 
\v 5 Yayusu kuaku, a Nzambi, ku yilu diyilu
\q1 ayi bika nkembo aku wuba va ntoto wumvimba ;
\q1 
\v 6 Wutuvukisa ayi wutusadisa mu koko kuaku ku lubakala
\q1 muingi bobo weti zola bakulu.
\q1 
\v 7 Nzambi wutuba tona ku buangu kiandi kinlongo :
\q1 “mu ndungunu, ndiela vasa Sikemi
\q1 ayi ndiela teza ndimba wu Sikoti.
\q1 
\v 8 Minu phuidi Galadi, minu phuidi Manase ;
\q1 Efalayimi wawu nkaku wu ntu ama
\q1 Yuda nkawꞌama wu kipfumu.
\q1 
\v 9 Mowabi diawu dibola diodi ndieti yobidila.
\q1 Va yilu Edomi ndiloza zisandale ziama,
\q1 ndiela yamikina mu diambu di ndungunu ama mu basi Filisiti.”
\q1 
\v 10 Nani wela kundata ku divula dikindusu ngolo e ?
\q1 Nani wela kuthuadisa ku Edomi e ?
\q1 
\v 11 Keti ngeyo, a Nzambi, ngeyo wutuloza,
\q1 ngeyo wunkambu buela totukanga ayi minkangu mi masodi meto e ?
\q1 
\v 12 Wutuvana lusadusu va ntuala mbeni
\q1 bila lusadusu lu mutu luidi lu phamba.
\q1 
\v 13 Va kimosi ayi Nzambi, tuela tunga
\q1 ayi wela kosikisa bambeni zieto.
\c 109
\cl Minkunga 109
\s1 A Nzambi, kadi buela dingalala.
\d Nkunga Davidi kuidi pfumu minyimbidi.
\q1 
\v 1 A Nzambi, mutu wowo ndieti zitisa
\q1 bika dingalala.
\q1 
\v 2 Bila batu bambimbi ayi batu bansadilanga bukhita
\q1 bazibudi miunu miawu mu diambu diama.
\q1 Balembo tubi mu diambu diama mu ludimi lu luvunu.
\q1 
\v 3 Mu mambu ma kikhenene, banzungididi
\q1 ayi balembo nduanisa mu kambu bila.
\q1 
\v 4 Mu kikundi kiama, balembo mfundi
\q1 vayi minu ndidi mutu wu lusambulu.
\q1 
\v 5 Baphutudidi mambimbi mu mamboti
\q1 ayi bandendidi mu diambu di kikundi kiama.
\q1 
\v 6 Sobula mutu wumbimbi mu diambu kakba mbeni andi ;
\q1 bika mfundi katelama va koko kuandi ku lubakala.
\q1 
\v 7 Mu thangu kela samba, bika kaba monika mu nzimbala
\q1 ayi bika lusambulu luandi lumbedisa.
\q1 
\v 8 Bika bilumbu biandi bikituka bifioti.
\q1 Bika mutu wunkaka kabonga buangu kiandi ki kintuadisi.
\q1 
\v 9 Bika bana bandi baba bana basana ;
\q1 ayi nketo andi difuola.
\q1 
\v 10 Bika bana bandi baba mindiengidi mikuenda lombingi ;
\q1 bika baba kuka mu zinzo ziawu zitiolumuka.
\q1 
\v 11 Bika mutu wowo weti devisa kabonga bima bioso biobi kavuidi ;
\q1 bika banzenza baziona mu kingolo mimbutu mi kisalu kiandi.
\q1 
\v 12 Bika kubika ba mutu wulenda kumvangila mamboti
\q1 voti monina bana bandi basana kiadi.
\q1 
\v 13 Bika nkunꞌandi wulalakana ;
\q1 mazina mawu makubulu mu tsungi yinkuiza.
\q1 
\v 14 Bika mambimbi ma bakulu bandi matebukulungu moyo va ntuala Yave,
\q1 bika disumu di ngudi andi dibika kubulu.
\q1 
\v 15 Bika masumu mawu mazingila mu zithangu zioso va ntuala Yave
\q1 muingi kalalikisa thebukulu awu moyo va ntoto.
\q1 
\v 16 Bila kalendi yindula mu vanga mamboti ko,
\q1 vayi wuyamisa nsukami nate ku lufua ;
\q1 ayi nkua kiadi ayi mutu wuba ntima wukosakana.
\q1 
\v 17 Niandi wuzola singa ; bika yimbuila,
\q1 kamonanga khini ko mu lusakumunu
\q1 bika luawu luba thama ayi niandi
\q1 
\v 18 Wuvuata tsingulu banga nledi andi ;
\q1 yawu yikota mu khati nitu andi banga nlangu,
\q1 mu mimvesi miandi banga mafuta.
\q1 
\v 19 Bika yawu yikituka banga yunga kioki kakukifukila ;
\q1 banga nsinga luketo wowo keti vuata mu zithangu zioso.
\q1 
\v 20 Bika buawu bobo bubela mfutu wu Yave kuidi mimfundi miama ;
\q1 kuidi bobo bantubanga mambu mambimbi mu diambu diama.
\q1 
\v 21 Vayi ngeyo Yave, mutu wumvanganga mawu zodidi,
\q1 wuphangila mamboti mu diambu di dizina diaku ;
\q1 ka diambu ko mamboti ma luzolo luaku madi, bika wukhula.
\q1 
\v 22 Ndidi nkua kiadi ayi nsukami
\q1 ayi ntimꞌama widi wuluala mu minu.
\q1 
\v 23 Ndieka lalakana banga kitsusula va masika ;
\q1 bakhukidi banga makhoko.
\q1 
\v 24 Makuma mama malembo bulangama
\q1 mu kukifuisanga nzala mu diambu di lusambulu ;
\q1 nitu ama yidi yifioti ayi yikonda.
\q1 
\v 25 Minu ndieka diambu di mvuezolo kuidi mimfundi miama ;
\q1 bawu kumbona, balembo nikuna mintu miawu.
\q1 
\v 26 Wutsadisa, a Yave, Nzambi ama ;
\q1 wuphukisa boso buididi luzolo luaku.
\q1 
\v 27 Bika bazaba ti koko kuaku ;
\q1 ti ngeyo Yave wuvanga buawu.
\q1 
\v 28 Bawu balembo singi vayi ngeyo wela sakumuna.
\q1 Bu batelimini mu diambu di nuanisa, bela fua tsoni
\q1 vayi kisadi kiaku kiela mona khini.
\q1 
\v 29 Mimfundi miama milendi vuata nzitusu ko
\q1 ayi miela fukudulu tsoni banga yunga.
\q1 
\v 30 Mu munu ama, ndiela yayisa ngolo Yave ;
\q1 Mu nkangu wunneni wu batu, ndiela kunzitisa.
\q1 
\v 31 Bila niandi wuntelamanga va koko ku lubakala lu nsukami
\q1 mu diambu di vukisa luzingu luandi mu mioko mi bobo bakunzengilanga nkanu.
\c 110
\cl Minkunga 110
\s1 Niandi widi va kimosi ntinu ayi nganga Nzambi
\d Nkunga Davidi.
\q1 
\v 1 Yave wutuba kuidi Pfumu ama :
\q1 “Vuanda va koko kuama ku lubakala
\q1 nate ndikitula bambeni ziaku kima kioki
\q1 beti tetika malu mu diambu di malu maku.”
\q1 
\v 2 Yave wela nonuna nkawa aku wu lulendo wu kipfumu tona ku Sioni ;
\q1 wela yadila va khatitsika bambeni ziaku.
\q1 
\v 3 Minkangu miaku mi masodi miela ba luzolo lumboti ;
\q1 mu lumbu kiaku ki mvita
\q1 bavuata nzitusu wunlongo
\q1 tona mu khiesa buisi
\q1 wela tambula bimi bi bumuana buaku.
\q1 
\v 4 Yave wuzenga ndefi, kalendi viakisa mayindu mandi ko :
\q1 “ngeyo widi nganga Nzambi mu zithangu zioso
\q1 mu ntanda wu Meleshisedeki.”
\q1 
\v 5 Yave widi va koko kuaku ku lubakala ;
\q1 wela kosikisa mintinu mu lumbu ki miangu miandi mi ngolo.
\q1 
\v 6 Wela sambisa makanda, kupikisa bafua
\q1 Niandi wela kosikisa minyadi va ntoto wumvimba.
\q1 
\v 7 Niandi wela nua nlangu wu mvuila mu ndambu nzila,
\q1 diawu kela vumbudila ngolo ntu andi.
\c 111
\cl Minkunga 111
\s1 Wuvanga matsiminanga
\q1 
\v 1 Luzitisa Yave !
\q1 Ndiela yayisa Yave mu ntimꞌama wumvimba,
\q1 mu dikabu di batu balulama ayi mu lukutukunu lu batu.
\q1 
\v 2 Mavanga ma Yave madi manneni,
\q1 meti yindulu kuidi bobo beti kumazola.
\q1 
\v 3 Mavanga mandi madi ma nkembo ayi ma nzitusu
\q1 ayi busonga buandi bunzingilanga mu zithangu zioso.
\q1 
\v 4 Niandi wuvanga ti matsiminanga mandi matebukulukungu moyo.
\q1 Yave widi nkua nlemvo ayi nkua kiadi.
\q1 
\v 5 Niandi weti vana bidia kuidi bobo beti kunkinzika ;
\q1 wuntebukilanga moyo Nguizani andi mu zithangu zioso.
\q1 
\v 6 Wumonisa batu bandi lulendo lu bisalu biandi ;
\q1 bu kaba vana mintoto mi makanda mankaka.
\q1 
\v 7 Bisalu bi mioko miandi bidi kikhuikizi ayi busonga ;
\q1 minsiku miandi mioso mifueni mu tudulu diana,
\q1 
\v 8 mikindusu mu zithangu zioso ayi mu kadika mvu ;
\q1 mivangulu mu kikhuikizi ayi mu bufuana.
\q1 
\v 9 Niandi wuvana khudulu kuidi batu bandi ;
\q1 niandi wutumina nguizani andi mu zithangu zioso.
\q1 Dizina diandi didi dinlongo ayi tsisi didi.
\q1 
\v 10 Kinzika Yave yawu thonono yi nduenga,
\q1 Babo bobo beti landakana minsiku miandi babeki diela dimboti.
\q1 Niandi vuidi nzitusu mu zithangu zioso.
\c 112
\cl Minkunga 112
\s1 Mamboti ma mikhuikizi
\q1 
\v 1 Luzitisa Yave !
\q1 Lusakumunu kuidi mutu wowo weti kinzika Yave ;
\q1 wowo weti mona khini mu zithumunu ziandi.
\q1 
\v 2 Bana bandi bela ba lulendo va ntoto ;
\q1 Tsungi yi batu balulama yela sakumunu.
\q1 
\v 3 Bima biwombo ayi kimvuama bidi mu nzo andi
\q1 ayi busonga buandi bunzingilanga mu zithangu zioso.
\q1 
\v 4 Ka diambu ko mu tombi, kiezila kieti kienzuka mu diambu di batu balulama mu mintima ;
\q1 mu diambu di nkua nlemvo ayi nkua kiadi ayi mutu wusonga.
\q1 
\v 5 Mamboti mela kuiza kuidi mutu wowo wunkabulanga mu luzolo
\q1 ayi wundevisanga mu kambu kuiku ;
\q1 ayi wundiatisanga bisalu biandi mu busonga.
\q1 
\v 6 Bukiedika kalendi nikuka ko ;
\q1 mutu wusonga wela tebukulungu moyo mu zithangu zioso.
\q1 
\v 7 Kalendi mona zitsangu zimbimbi tsisi ko.
\q1 Ntimꞌandi widi wukinda, wuntulanga diana mu Yave.
\q1 
\v 8 Ntimꞌandi widi mu luvovomo, kalendi mona tsisi ko
\q1 ku tsuka wela nunga mu tala batu bobo beti kunlenda.
\q1 
\v 9 Wunkabulanga mu zindambu zioso makaba mu diambu di nsukami ;
\q1 busonga buandi bunzingilanga mu zithangu zioso ;
\q1 phokꞌandi yela vumbulu ngolo mu nzitusu.
\q1 
\v 10 Mutu wumbimbi wela bumona ayi wela fuema ;
\q1 wela kueta meno ayi wela lalakana.
\q1 Zikhanu zi mutu wumbimbi ziela kituka ziphamba.
\c 113
\cl Minkunga 113
\s1 Nzambi yoyi yilendi dedokoso ko
\q1 
\v 1 Nkembo kuidi Yave !
\q1 Luzitisa Yave
\q1 luzitisa beno bisadi bi Yave ;
\q1 luzitisa dizina di Yave.
\q1 
\v 2 Bika dizina di Yave dizitusu
\q1 tona buabu nate mu zithangu zioso ;
\q1 
\v 3 Bika dizina di Yave dizitusu
\q1 tona kuntotukilanga thangu nate ku buangu yeti diamina.
\q1 
\v 4 Yave widi wuyayusu ku yilu makanda moso,
\q1 nkembo andi ku mbata diyilu.
\q1 
\v 5 Nani dedikini banga Yave, Nzambi, eto
\q1 niandi wutula kundu kiandi ki kipfumu ku yilu
\q1 
\v 6 mutu wowo weti yinama mu tala diyilu ayi ntoto e ?
\q1 
\v 7 Weti totula nsukami mu mbungi-mbungi ;
\q1 ayi niandi weti vumbula nkua kiadi mu dikuka di dibombi.
\q1 
\v 8 Weti kuba vuandisa va kimosi ayi bana ba mintinu
\q1 va kimosi ayi bana ba mintinu mi batu bawu.
\q1 
\v 9 Niandi wuvuandisa sita ki nketo mu nzo ;
\q1 banga ngudi yi bana yilembo moni khini
\q1 Luzitisa Yave.
\c 114
\cl Minkunga 114
\s1 Mu thangu Iseli katotuka mu Ezipite
\q1 
\v 1 Mu thangu Iseli katotuka mu Ezipite,
\q1 nzo yi Yakobi mu batu beti tuba mbembo yi nzenza ;
\q1 
\v 2 Yuda dikituka buangu kinlongo ki Nzambi,
\q1 Iseli tsi andi.
\q1 
\v 3 Mbu wumona ayi wutina ;
\q1 Yolidani yivutuka ku manima.
\q1 
\v 4 Miongo midumuka banga mamemi mambakala ;
\q1 miongo mifioti banga bana ba mamemi.
\q1 
\v 5 A mbi bivangama, ngeyo mbu, muingi wutina
\q1 ngeyo Yolidani, muingi wuvutuka ku manina e ?
\q1 
\v 6 Ngeyo miongo, muingi wudumuka banga mamemi ma mbakala,
\q1 miongo mifioti banga bana ba mememi e ?
\q1 
\v 7 Tita, a ntoto, va meso ma Yave
\q1 va meso ma Nzambi yi Yakobi.
\q1 
\v 8 Niandi wunkitulanga ditadi buindi ki nlangu,
\q1 ditadi dingolo zitho zi nlangu.
\c 115
\cl Minkunga 115
\s1 Nzambi, niandi kaka vuidi nkembo
\q1 
\v 1 Bika kuidi beto, a Yave, bika kuidi beto ;
\q1 vayi kuidi dizina diaku kuba nkembo,
\q1 mu diambu di luzolo luaku ayi kikhuikizi kiaku.
\q1 
\v 2 Bila mbi makanda malembo tubila ti :
\q1 “Kuevi kuidi Nzambi awu e ?”
\q1 
\v 3 Nzambi eto widi ku Diyilu,
\q1 niandi weti vanga moso katidi.
\q1 
\v 4 Vayi bitumba biawu bidi palata ayi nolo ;
\q1 bivangulu mu mioko mi batu.
\q1 
\v 5 Bibeki miunu vayi bilendi yoluka ko ;
\q1 meso vayi bilendi mona ko.
\q1 
\v 6 Bibeki matu vayi bilendi wa ko ;
\q1 mayilu vayi bilendi wa tsudi ko.
\q1 
\v 7 Bibeki mioko vayi bilendi simba ko,
\q1 malu vayi bilendi diata ko.
\q1 Voti bilendi totula ko biyoko mu phovi-yi-dilaka diawu.
\q1 
\v 8 Batu bobo bavanga biawu bela ba banga biawu,
\q1 ayi buawu bobo buela bela batu boso bobo bantulanga diana mu biawu.
\q1 
\v 9 A nzo yi Iseli, tula diana mu Yave.
\q1 Niandi nsadisi awu ayi nkaku awu.
\q1 
\v 10 A Nzo yi Aloni, tula diana mu Yave.
\q1 Niandi nsadisi awu ayi nkaku awu.
\q1 
\v 11 Beno lueti kunkinzika, lutula diana mu Yave.
\q1 Niandi nsadisi awu ayi nkaku awu.
\q1 
\v 12 Yave weti kututebukila moyo ayi wela kutusakumuna.
\q1 Wela sakumuna nzo yi Iseli,
\q1 wela sakumuna nzo yi Aloni.
\q1 
\v 13 Wela sakumuna bobo beti kinzika Yave,
\q1 batu baphamba va kimosi ayi batu banneni.
\q1 
\v 14 Bika Yave kaluwokisa,
\q1 beno ayi bana beno va kimosi.
\q1 
\v 15 Bika Yave kalusakuna,
\q1 mvangi wu diyilu ayi ntoto.
\q1 
\v 16 Yave niandi vuidi Diyilu dizangama
\q1 vayi ntoto wuvanu kuidi mutu.
\q1 
\v 17 Kadi sia ti bafua bawu beti zitisa Yave ;
\q1 bobo bankuendanga ku tsi yidi dio sui.
\q1 
\v 18 Vayi beto tueti yayisa Yave
\q1 tona buabu nate mu zithangu zioso.
\q1 Luzitisa Yave.
\c 116
\cl Minkunga 116
\s1 Pfumu weti wa mbembo ama.
\q1 
\v 1 Ndieti zola Yave bila niandi weti wa mbemboꞌama
\q1 weti wa yamikina kuama mu diambu di kiadi.
\q1 
\v 2 Bila niandi wutamba dikutu diandi kuidi minu,
\q1 ndiela kuntela sumbu ndilembo zingi.
\q1 
\v 3 Minsinga mi lufua mimfietikisa ;
\q1 tsisi yi tsi yi bafua yibua va minu ;
\q1 ndibedoso kuidi ziphasi ayi maniongo.
\q1 
\v 4 Buna nditedila dizina di Yave ;
\q1 “A Yave, wuphukisa !”
\q1 
\v 5 Yave widi nkua nlemvo ayi widi wusonga ;
\q1 Nzambi eto widi nkua kiadi.
\q1 
\v 6 Yave wunkebanga batu badi bakuluka mu mintima ;
\q1 bu ndiba mu nkinza wu ngolo niandi wuphukisa.
\q1 
\v 7 Ba mu luvundulu mu zithangu ziwombo, a muelꞌama
\q1 bila Yave wuba wumboti kuidi ngeyo.
\q1 
\v 8 Bila ngeyo, a Yave, wukula muelꞌama mu lufua ;
\q1 meso mama mu matsuela,
\q1 malu mama mu bumina thutu
\q1 
\v 9 muingi ndibaka bu diatila va ntuala Yave,
\q1 va mbata ntoto wu batu badi moyo.
\q1 
\v 10 Ndiwilukila, diawu nditubila :
\q1 “mu ziphasi zingolo ndidi.”
\q1 
\v 11 Ku tsi maniongo mama ndituba :
\q1 “batu boso badi bankua luvunu.”
\q1 
\v 12 Buevi ndilendi futila Yave
\q1 mu mamboti mandi moso kuidi minu e ?
\q1 
\v 13 Ndiela vumuna mbungu yi phulusu
\q1 ayi ndiela tela dizina di Yave.
\q1 
\v 14 Ndiela dukisa zindefi ziama zioso kuidi Yave ;
\q1 va meso ma batu bandi boso.
\q1 
\v 15 Lufua lu banlongo ba Yave
\q1 thalu luidi va meso mandi.
\q1 
\v 16 A Yave, bukiedika ndidi kisadi kiaku ;
\q1 ndidi kisadi kiaku, muana wu kisadi kiaku ki nketo.
\q1 Ngeyo wukhula mu zisieni ziama.
\q1 
\v 17 Ndiela kutambika makaba ma phutudulu matondo
\q1 ayi ndiela tela dizina di Yave.
\q1 
\v 18 Ndiela dukisa zindefi ziama zioso kuidi Yave ;
\q1 va meso ma batu bandi boso,
\q1 
\v 19 mu zimpangu zi Nzo Yave,
\q1 va khatitsikꞌaku ngeyo Yelusalemi.
\q1 Luzitisa Yave.
\c 117
\cl Minkunga 117
\s1 Batu boso bazitisa Yave
\q1 
\v 1 Luzitisa Yave, beno makanda moso.
\q1 Lunyayisa beno batu boso.
\q1 
\v 2 Bila luzolo luandi luidi lunneni kuidi beto,
\q1 ayi kikhuikizi kiandi kinzingilanga mu zithangu zioso.
\q1 Luzitisa Yave.
\c 118
\cl Minkunga 118
\s1 Mamboti mandi madi mu zithangu zioso
\q1 
\v 1 Luvutudila Yave matondo bila niandi widi wumboti ;
\q1 luzolo luandi lunzingilanga mu zithangu zioso.
\q1 
\v 2 Bika Iseli katuba :
\q1 luzolo luandi lunzingilanga mu zithangu zioso.
\q1 
\v 3 Bika nzo yi Aloni yituba :
\q1 luzolo luandi lunzingilanga mu zithangu zioso.
\q1 
\v 4 Bika bobo beti kinzika Yave batuba ;
\q1 luzolo luandi lunzingilanga mu zithangu zioso.
\q1 
\v 5 Ku tsi ziphasi ziama, ndiyamikina kuidi Yave,
\q1 ayi wuphana mvutu bu kaphuandisa mu kiphuanza.
\q1 
\v 6 Yave widi ku ndambuꞌama, ndilendi mona tsisi ko.
\q1 Buna mutu mbi kalenda ku phanga e ?
\q1 
\v 7 Yave widi ku ndambuꞌama, niandi nsadisi ama ;
\q1 buna ndiela nunga mu tala bambeni ziama.
\q1 
\v 8 Bulutidi mboti mu suaminanga mu Yave
\q1 viokila mu tula diana mu mutu.
\q1 
\v 9 Bulutidi mboti mu suaminanga mu Yave
\q1 viokila mu tula diana mu bana ba mintinu.
\q1 
\v 10 Makanda moso manzungidila
\q1 vayi mu dizina di Yave, ndilembo babungi.
\q1 
\v 11 Mawu manzungidila, ku ndambu ka ndambu
\q1 vayi mu dizina di Yave, ndilembo babungi.
\q1 
\v 12 Mawu manzungidila banga ziniosi,
\q1 vayi zifuidi mu nsualu banga zitsendi zinlema mbazu ;
\q1 mu dizina di Yave, ndilembo babungi
\q1 
\v 13 Bandunguna ku mbusa muingi ndibua
\q1 vayi Yave wutsadisa.
\q1 
\v 14 Yave niandi zingolo ziama ayi nkungꞌama ;
\q1 niandi wuyika phulusu ama.
\q1 
\v 15 Yamikina ku khini ayi ku ndungunu kulembo wakana
\q1 mu zinzo zi ngoto zi batu basonga :
\q1 koko ku lubakala ku Yave kuvanga mambu ma lulendo.
\q1 
\v 16 Koko ku lubakala ku Yave kuidi ku zangama ngolo ;
\q1 koko ku lubakala ku Yave kuvanga mambu ma lulendo.
\q1 
\v 17 Ndilendi fua ko vayi ndiela zinga
\q1 ayi ndiela yamikisa momo Yave kavanga.
\q1 
\v 18 Yave wuphana thumbudulu mu kingolo ;
\q1 vayi kasia kundiekula ko mu lufua.
\q1 
\v 19 Nzibudila mielo mi busonga,
\q1 ndiela kota ayi ndiela vutudila Yave matondo.
\q1 
\v 20 Wawu, wawu muelo wu Yave,
\q1 vawu basonga bafueti kotila.
\q1 
\v 21 Ndiela kuvutudila matondo
\q1 bila ngeyo wuphana mvutu wuyika phulusu ama.
\q1 
\v 22 Ditadi diloza mintungi diyika
\q1 ditadi dilutidi mfunu va fuma ki nzo.
\q1 
\v 23 Yave wuvanga diambu diodi
\q1 ayi didi diambu ditsiminanga va meso meto.
\q1 
\v 24 Kiaki kiawu lumbu kivanga Yave,
\q1 bika tumona khini ayi tuyangalala mu lumbu beni.
\q1 
\v 25 A Yave, wutuvukisa !
\q1 A Yave, wutusadisa tuluta kuenda ku ntuala.
\q1 
\v 26 Bika kasakumunu mutu wowo wunkuizila mu dizina di Yave ;
\q1 tona ku nzo Yave, tulembo kulusakumuna.
\q1 
\v 27 Yave niandi Nzambi ayi niandi wutukienzula ;
\q1 ayi mangiemvo mu mioko, lukota mu ntanda ;
\q1 nate ku ziphoka zi diziku dimvikulungu makabu.
\q1 
\v 28 Ngeyo Nzambi ama ayi ndiela kuvutudila matondo.
\q1 Ngeyo Nzambi ama ayi ndiela kuyayisa.
\q1 
\v 29 Luvutudila Yave matondo bila niandi widi wumboti,
\q1 bila luzolo luandi lunzingilanga mu zithangu zioso.
\c 119
\cl Minkunga 119
\s1 Mina mi Yave midi mifuana
\q1 
\v 1 Lusakumunu kuidi bobo bandiatilanga mu zinzila ziawu zikambulu tsembolo,
\q1 bobo bandiatilanga boso buididi mina mi Yave.
\q1 
\v 2 Lusakumunu kuidi bobo bankebanga zinzengolo ziandi ;
\q1 ayi bakutombanga mu mintima miawu mimvimb ;
\q1 
\v 3 bavanganga ko kadi diambu di mbimbi,
\q1 bandiatilanga mu zinzila ziandi.
\q1 
\v 4 Ngeyo wuvana minsiku mu diambu
\q1 mikinzuku bumboti.
\q1 
\v 5 A bika zinzila ziama ziba zitelama dio ngui
\q1 mu diambu ndikizika zinzengolo ziaku ;
\q1 
\v 6 Buna ndilendi fua tsoni ko
\q1 bu ndiela keba zithumunu ziaku zioso.
\q1 
\v 7 Ndiela kuzitisa mu ntima wululama ;
\q1 banga minu ndilonguka mina miaku misonga.
\q1 
\v 8 Ndiela kinzika zinzengolo ziaku,
\q1 kadi tumbu ku ndiekula.
\q1 
\v 9 Buevi ditoko kalenda kebila nzilꞌandi yi vedila e ?
\q1 Mu zinganga boso buidi mambu maku.
\q1 
\v 10 Ndikutomba mu ntimꞌama wumvimba,
\q1 kadi tala ti ndivengama mu zithumunu ziaku.
\q1 
\v 11 Ndisimbidila mambu maku mu ntimꞌama
\q1 mu diambu ndibika vola masumu kuidi ngeyo.
\q1 
\v 12 Nzitusu kuidi ngeyo, a Yave
\q1 wundonga zinzengolo ziaku.
\q1 
\v 13 Mu bididi biama,
\q1 ndilembo tangi mina mioso mintotukanga mu munu aku.
\q1 
\v 14 Ndieti mona khini mu landakana zinzengolo ziaku
\q1 banga mutu wowo wumona khini mu kimvuama kiwombo.
\q1 
\v 15 Ndieti yindula minsiku miaku
\q1 ayi ndieti kinzika zinzila ziaku.
\q1 
\v 16 Ndieti mona khini mu zinzengolo ziaku,
\q1 ndilendi lenza ko mambu maku.
\q1 
\v 17 Vangila kisadi kiaku mamboti ayi mu ndiela zinga ;
\q1 ndiela tumukina mambu maku.
\q1 
\v 18 Zibula meso mama mu diambu mona
\q1 mambu matsiminanga mu mina miaku.
\q1 
\v 19 Ndidi nzenza vava mbata ntoto ;
\q1 kadi kutsuekila zithumunu ziaku.
\q1 
\v 20 Muelꞌama widi dilemina di ngolo ;
\q1 mu diambu di mina miaku mu zithangu zioso.
\q1 
\v 21 Ngeyo wunteminanga batu badi luniemo,
\q1 bobo basingu ayi bobo bavengama mu zithumunu ziaku.
\q1 
\v 22 Thatudila tsoni ayi dienzi
\q1 bila ndieti keba zinzengolo ziaku.
\q1 
\v 23 Ka diambu ko minyandi mivuendi va kimosi ayi mikuthubidila ;
\q1 kisadi kiaku kiela yindula zinzengolo ziaku.
\q1 
\v 24 Zinzengolo ziaku zinkumbonisanga khini,
\q1 zikuphananga zindongi.
\q1 
\v 25 Ndivuanda mu mbungi-mbungi ;
\q1 keba luzingu luama boso buididi mambu maku.
\q1 
\v 26 Nditangila zinzila ziama ayi ngeyo wuphana mvutu ;
\q1 wundonga zinzengolo ziaku.
\q1 
\v 27 Bika ndisudika malongi ma minsiku miaku ;
\q1 buna ndiela yindula matsiminanga maku.
\q1 
\v 28 Muelꞌama widi wuvonga mu kiadi,
\q1 wukhindisa boso buididi mambu maku.
\q1 
\v 29 Bika wuphengumuna mu zinzila zi luvunu ;
\q1 wumbonisa nlemvo mu mina miaku.
\q1 
\v 30 Ndisobula nzila yi Kiedika ;
\q1 nditula ntimꞌama mu mina miaku.
\q1 
\v 31 Ndidi wukangama mu zinzengolo ziaku, a Yave ;
\q1 kadi kumbika ndifua tsoni.
\q1 
\v 32 Ndilembo zawula mu nsolo wu zithumunu ziaku
\q1 bila ngeyo wuvuandisa ntimꞌama mu kiphuanza.
\q1 
\v 33 Wundongisa, a Yave, mu landakana zinzengolo ziaku
\q1 buna ndiela kuzikeba nate ku tsukulu.
\q1 
\v 34 Wuphana diela ayi ndiela keba mina miaku
\q1 ayi ndiela ku mikinzika mu ntimꞌama wumvimba.
\q1 
\v 35 Wuthuadisa mu nsolo wu zithumunu ziaku
\q1 bila muawu ndieti moninanga khini.
\q1 
\v 36 Balula ntimꞌama kuidi zinzengolo ziaku ;
\q1 vayi bika kuidi ndandu yi luvunu.
\q1 
\v 37 Botula meso mama mu bima biphamba ;
\q1 keba luzingu luama boso buididi mambu maku.
\q1 
\v 38 Dukisila kisadi kiaku tsilꞌaku,
\q1 muingi babaka bukukinzikila.
\q1 
\v 39 Vengumuna mvuezolo wowo ndilemou moni tsisi
\q1 bila mina miaku midi mimboti.
\q1 
\v 40 Phila phuila ndidi yi minsiku miaku ;
\q1 keba luzingu luama mu busonga buaku.
\q1 
\v 41 Bika luzolo luaku lungolo lutula kuidi minu, a Yave,
\q1 phulusu aku boso buididi tsilꞌaku,
\q1 
\v 42 buna ndiela baka bu vanina mvutu
\q1 kuidi mutu wowo wulembo kumfingi
\q1 bila nditula diana diama mu mambu maku.
\q1 
\v 43 Kadi tumbu botula mvimba mambu ma kiedika mu munuꞌama
\q1 bila ndintulanga diana diama mu mina miaku.
\q1 
\v 44 Ndiela tumukinanga Mina miaku kadika thangu
\q1 mu zithangu zioso ayi mu kadika mvu.
\q1 
\v 45 Ndiela diatilanga mu kiphuanza
\q1 bila nditomba minsiku miaku.
\q1 
\v 46 Ndiela yolukila zinzengolo ziaku va ntuala mintinu
\q1 ayi ndilendi fua tsoni ko.
\q1 
\v 47 Bila khini ndieti mona mu zithumunu ziaku,
\q1 bila ndieti ku zizola.
\q1 
\v 48 Ndimvumuna mioko miama kuidi zithumunu ziaku,
\q1 ziozi ndieti zola
\q1 ayi ndiela yindulanga zinzengolo ziaku.
\q1 
\v 49 Tebukila moyo mambu maku kuidi kisadi kiaku ;
\q1 bila ngeyo wuphana diana.
\q1 
\v 50 Mbombolo ama mu ziphasi ziama yawu yayi :
\q1 tsilꞌaku yeti kitula luzingu luama lumona.
\q1 
\v 51 Batu ba luniemo batsekinina ngolo boso buididi luzolo luawu
\q1 vayi ndisia vengama ko mu Mina miaku.
\q1 
\v 52 Nditebukila moyo mina miaku mikhulu, a Yave
\q1 ayi ndintambula mbombolo mu miawu.
\q1 
\v 53 Kiadi kimbuila mu diambu di batu bambimbi ;
\q1 bobo beti loza Mina miaku.
\q1 
\v 54 Zinzengolo ziaku ziawu zingudi zi mambu ma minkunga miama
\q1 ku kadika buangu kioki ndieti leka.
\q1 
\v 55 Nditebukilanga moyo dizina diaku va builu, a Yave,
\q1 ayi ndiela keba Mina miaku.
\q1 
\v 56 Diadi diba diambu ndisadila :
\q1 ndintumukina minsiku miaku.
\q1 
\v 57 Ngeyo kuku kiama, a Yave.
\q1 Ndivana tsila ti ndiela tumukina mambu maku.
\q1 
\v 58 Nditomba zizi kiaku mu ntimꞌama wumvimba,
\q1 wutsila nlemvo boso buididi tsilꞌaku.
\q1 
\v 59 Ndiyindula zinzila ziama
\q1 ayi nditadisa malu mama kuidi zinzengolo ziaku.
\q1 
\v 60 Ndiela tula nsualu ayi ndilendi zingila ko ;
\q1 mu diambu di keba zithumunu ziaku.
\q1 
\v 61 Ka diambu ko batu bambimbi bakhengi mu minsinga
\q1 vayi ndisia zimbakana ko Mina miaku.
\q1 
\v 62 Ndieti kotuka va midi miphipa mu kuvutudila matondo
\q1 mu diambu di Mina miaku misonga.
\q1 
\v 63 Ndidi nkundi wu batu boso bobo beti kukinzika
\q1 ayi wu bobo beti landakana minsiku miaku.
\q1 
\v 64 Ntoto wufulukidi mu luzolo luaku, a Yave ;
\q1 bika wundonga zinzengolo ziaku.
\q1 
\v 65 Vangila kisadi kiaku mamboti
\q1 boso buididi mambu maku, a Yave.
\q1 
\v 66 Bika wundongisa nzayilu ayi tsudukulu yimboti
\q1 bila ndiwilukila zithumunu ziaku.
\q1 
\v 67 Tuamina ndiba mu phasi, minu ndiba ndiengidi
\q1 vayi buabu ndieti tumimina mambu maku.
\q1 
\v 68 Ngeyo widi wumboti ayi momo weti vanga madi mamboti ;
\q1 bika wundongisa zinzengolo ziaku.
\q1 
\v 69 Ka diambu ko batu ba luniemo balembo bivisa nzitusu ama
\q1 mu mambu ma luvunu mu diambu diama
\q1 minu ndiela kebanga minsiku miaku mu ntimꞌama wumvimba.
\q1 
\v 70 Mintima miawu midi mi matadi ayi miwanga ko
\q1 vayi minu khini ndieti mona mu mina miaku.
\q1 
\v 71 Didi diambu di mboti kuidi minu mu monoso phasi
\q1 muingi ndilonguka zinzengolo ziaku.
\q1 
\v 72 Mina mitotukila mu munu aku milutidi mfunu kuidi minu
\q1 viokila zimili zimili zi bivanzi bi nolo ayi bi palata.
\q1 
\v 73 Mioko miaku miawu mikhubika ayi miphanga.
\q1 Bika wuphana tsudukulu yi longukila zithumunu ziaku.
\q1 
\v 74 Bika bobo beti ku kinzika bamona khini bu beti kumbona,
\q1 bila nditula diana diama mu mambu maku.
\q1 
\v 75 Nzebi, a Yave, ti mina miaku midi misonga
\q1 mu kikhuikizi ngeyo wumbonisa phasi.
\q1 
\v 76 Bika luzolo luaku lu ngolo luba mbombolo ama
\q1 boso buididi tsila yoyi wusila kisadi kiaku.
\q1 
\v 77 Bika kiadi kiaku kiba va minu mu diambu ndizinga
\q1 bila khini ndieti mona Mina miaku.
\q1 
\v 78 Bika batu ba luniemo bafua tsoni,
\q1 mu mambimbi beti kuphangila mu kambu bila
\q1 vayi minu ndiela yindulanga minsiku miaku.
\q1 
\v 79 Bika bobo beti ku kinzikanga babaluka kuidi minu ;
\q1 bobo beti sudika zinzengolo ziaku.
\q1 
\v 80 Bika ntimꞌama wuba wukambu tsembolo va ntuala zinzengolo ziaku
\q1 mu diambu ndibika fuisu tsoni.
\q1 
\v 81 Muelꞌama wuvongidi mu diambu di phuila yi phulusu aku ;
\q1 vayi ndintula diana diama mu mambu maku.
\q1 
\v 82 Meso mama mavongidi ; malembo tadidila tsilꞌaku ;
\q1 ndituba : “thangu mbi wela kuiza ku mbomba e ?”
\q1 
\v 83 Ka diambu ko ndidi banga kamununu ki vinu kitudulu va muisi ;
\q1 vayi ndisia zimbakana ko zinzengolo ziaku.
\q1 
\v 84 Nate thangu mbi kisadi kiaku kafueti vingidila e ?
\q1 Thangu mbi wela vanina thumbudulu kuidi batu bobo beti ku ndiamisa e ?
\q1 
\v 85 Batu ba luniemo bakebi mabulu ma mintambu mu diambu diama ;
\q1 buawu ko bobo buididi Mina miaku.
\q1 
\v 86 Zithumunu ziaku zioso zifueni mu tudulu diana ;
\q1 bika wutsadisa bila batu balembo ndiamisa mu kambu bila.
\q1 
\v 87 Keti fioti kuandi fisiala nganu bambotudi va ntoto ;
\q1 vayi minu ndisia loza ko minsiku miaku.
\q1 
\v 88 Keba luzingu luama boso buididi luzolo luaku
\q1 ayi ndiela tumukina zinzengolo zi munu aku.
\q1 
\v 89 Mambu maku, a Yave, manzingilanga mu zithangu zioso ;
\q1 madi matelama dio ngui mu diyilu.
\q1 
\v 90 Kikhuikizi kiaku kinzingilanga mu zitsungi zioso.
\q1 Ngeyo wukindisa ntoto ayi wawu wulembo zingila.
\q1 
\v 91 Mina miaku minzingilanga nate lumbu kiaku :
\q1 bila bima bioso bieti kusadila.
\q1 
\v 92 Enati Mina miaku misia kumbonisa khini ko
\q1 nganu ndibiva mu ziphasi ziama.
\q1 
\v 93 Ndilendi zimbakana ko minsiku miaku
\q1 bila mu miawu weti kebila luzingu luama.
\q1 
\v 94 Wuphukisa bila ndidi waku ;
\q1 nditomba minsiku miaku.
\q1 
\v 95 Batu bambimbi balembo mfiedi mu diambu bambunga ;
\q1 vayi ndiela yindula zinzengolo ziaku.
\q1 
\v 96 Mu kadika diambu di fuana, ndilembo moni ndilu ;
\q1 vayi zithumunu ziaku zisiko kadi ndilu.
\q1 
\v 97 A phila ndieti zodila mina miaku !
\q1 Miawu ndieti yindula mu lumbu kimvimba.
\q1 
\v 98 Zithumunu ziaku zikhitula mutu wu nduenga viokila bambeni ziama
\q1 bila ziawu zidi kaka yama mu zithangu zioso.
\q1 
\v 99 Minu ndieti luta sudika viokila minyiyisi miama mioso
\q1 bila ndinyindulanga zinzengolo ziaku.
\q1 
\v 100 Minu ndieti luta sudika viokila bakulutu
\q1 bila ndinkebanga minsiku miaku.
\q1 
\v 101 Ndikeba malu mama mu diatila mu woso-woso nsolo wu mbimbi
\q1 mu diambu dikeba mambu maku.
\q1 
\v 102 Ndisia vengama ko mu mina miaku
\q1 bila ngeyo veka wundonga.
\q1 
\v 103 A phila lueki mambu maku madi mu munu ama
\q1 viokila niosi mu munu ama.
\q1 
\v 104 Mbeki diela mu diambu di minsiku miaku ;
\q1 diawu ndinlendilanga woso-woso nsolo wu mbimbi.
\q1 
\v 105 Mambu maku madi muinda mu malu mama
\q1 ayi kiezila mu nsoloꞌama.
\q1 
\v 106 Ndinzenga ndefi ayi ndiyikindisa :
\q1 ti ndiela landakana mina miaku mi busonga.
\q1 
\v 107 Ndimona ziphasi ziwombo ;
\q1 keba luzingu luama, a Yave, boso buididi mambu maku.
\q1 
\v 108 Kikinina, a Yave, minsitusu mi luzolo mi munu ama
\q1 ayi wundongisa mina miaku.
\q1 
\v 109 Ka diambu ko kadika thangu ndieti nata luzingu luama mu mioko miama,
\q1 ndikadi zimbakana Mina miaku.
\q1 
\v 110 Batu bambimbi balekidi ntambu mu diambu diama,
\q1 vayi ndisia vengama ko mu minsiku miaku.
\q1 
\v 111 Zinzengolo ziaku zidi kiuka kiama mu zithangu zioso ;
\q1 ziawu zidi khini yi ntimꞌama.
\q1 
\v 112 Ntimꞌama wuvuendi mu kebanga zinzengolo ziaku
\q1 nate kuna tsuka.
\q1 
\v 113 Ndieti lenda batu badi mintima miodi,
\q1 vayi ndieti zola Mina miaku.
\q1 
\v 114 Ngeyo suamunu kiama ayi nkakuꞌama ;
\q1 nditula diana diama mu mambu maku.
\q1 
\v 115 Bika luthatukila beno batu lueti vanga mambu mambimbi ;
\q1 muingi ndikeba zithumunu zi Nzambi ama.
\q1 
\v 116 Bika wukhindisa boso buididi tsilꞌaku buna ndiela zinga ;
\q1 kadi tala ti diana diama dilalukusu.
\q1 
\v 117 Bika ngeyo wuba singumunu kiama ayi ndiela kulu ;
\q1 buna ndiela talanga zinzengolo ziaku mu zithangu zioso.
\q1 
\v 118 Ngeyo wuloza batu boso bobo beti zimbala mu zinzengolo ziaku
\q1 bila luvunu luawu luidi lu phamba.
\q1 
\v 119 Batu boso bambimbi ba ntoto,
\q1 ngeyo weti kuba vengumuna banga tsobo
\q1 diawu minu ndieti zodila zinzengolo ziaku.
\q1 
\v 120 Nsuni ama wulembo titi mu diambu di tsisi aku ;
\q1 thelimini mu boma bu mina miaku.
\q1 
\v 121 Ndivanga mambu masonga ayi mafuana
\q1 kadi kundiekula kuidi minyamisi miama.
\q1 
\v 122 Kubikila kisadi kiaku mamboti ;
\q1 kadi tala ti batu ba luniemo bandiamisa.
\q1 
\v 123 Meso mama mavongidi, malembo tadidila phulusu aku,
\q1 malembo tadidila tsilꞌaku yisonga.
\q1 
\v 124 Vangila kisadi kiaku mamboti boso buididi luzolo luaku
\q1 ayi wundonga zinzengolo ziaku.
\q1 
\v 125 Ndidi kisadi kiaku ; wuphana diela,
\q1 muingi ndisudika zinzengolo ziaku.
\q1 
\v 126 Thangu yifueni kuidi ngeyo mu sala, a Yave ;
\q1 mina miaku mibundukidi.
\q1 
\v 127 Bila ndieti zola zithumunu ziaku
\q1 viokila nolo, viokila kutu nolo yithalu ;
\q1 
\v 128 ayi bila ndilembo kinzika minsiku miaku mioso milulama
\q1 Ndinlendanga woso-woso nsolo wu mbimbi.
\q1 
\v 129 Zinzengolo ziaku zidi zi matsiminanga
\q1 diawu ndieti kuzitumukina.
\q1 
\v 130 Zaba ti mambu maku meti vana kiezila ;
\q1 meti vana diela kuidi batu baphamba.
\q1 
\v 131 Ndinzibula munu ama ayi ndivumuna
\q1 mu phuila yi ngolo yi zithumunu ziaku.
\q1 
\v 132 Baluka kuidi minu ayi wumbona kiadi,
\q1 banga bobo weti vangila mu zithangu zioso
\q1 kuidi bobo banzolanga dizina diaku.
\q1 
\v 133 Tuadisa zithambi zi malu mama boso buididi mambu maku,
\q1 kadi tala kadi disumu di ndiadila.
\q1 
\v 134 Wukhula mu kuamusu wu batu
\q1 mu diambu ndibaka bu tumukina minsiku miaku.
\q1 
\v 135 Kienzudila kisadi kiaku zizi
\q1 ayi wundongisa zinzengolo ziaku.
\q1 
\v 136 Matsuela mawombo malembo kumbi mu meso mama banga mila mi nlangu
\q1 mu diambu Mina miaku mikadi kinzuku.
\q1 
\v 137 Ngeyo widi wusonga, a Yave
\q1 ayi mina miaku midi milulama.
\q1 
\v 138 Zinzengolo wutula zidi zisonga,
\q1 zidi zifuana mboti mu siwulu diana.
\q1 
\v 139 Bufula buama mu kusadila bulembo tsukisa ntima,
\q1 bila bambeni ziama zisi zaba ko mambu maku.
\q1 
\v 140 Zitsila ziaku zimonika ti zidi zikiedika,
\q1 ayi kisadi kiaku wukuzizolanga.
\q1 
\v 141 Ka diambu ko ndidi mutu wuvumbama ayi wulenzu,
\q1 ndikadi zimbakana minsiku miaku.
\q1 
\v 142 Busonga buaku buidi mu zithangu zioso
\q1 ayi mina miaku midi mikiedika.
\q1 
\v 143 Ziphasi ayi maniongo bimbuididi,
\q1 vayi zithumunu ziaku zikumbonisanga khini.
\q1 
\v 144 Zinzengolo ziaku zidi zilulama mu zithangu zioso ;
\q1 wuphana diela muingi ndizinga.
\q1 
\v 145 Nditela mu ntimꞌama wumvimba ; wuphana mvutu, a Yave
\q1 ayi ndiela kinzika zinzengolo ziaku.
\q1 
\v 146 Ndikutela, wuphukisa
\q1 ayi ndiela keba zinzengolo ziaku.
\q1 
\v 147 Ndieti kotuka tuamina nkielo buisi wuba
\q1 ayi ndinyamikinanga muingi wutsadisa ;
\q1 minu nditula diana diama mu mambu maku.
\q1 
\v 148 Meso mama meti ba mazibuka tuamina khiesa yi builu,
\q1 mu diambu ndiyindula zitsila ziaku.
\q1 
\v 149 Wa mbemboꞌama boso buididi luzolo luaku
\q1 keba luzingu luama, a Yave, boso buididi mina miaku
\q1 
\v 150 Bobo beti kubika zikhanu zimbimbi bafikimini,
\q1 vayi thama badi ayi Mina miaku.
\q1 
\v 151 Muaki, ngeyo widi wufikama, a Yave
\q1 ayi zithumunu ziaku zioso zidi zikiedika.
\q1 
\v 152 Tona thama ndizaba, ndilongukala zinzengolo ziaku
\q1 ti ngeyo wumana zibieka mu zithangu zioso.
\q1 
\v 153 Bika wutala ziphasi ziama ayi bika wukhula
\q1 bila ndisia zimbakana ko Mina miaku.
\q1 
\v 154 Bika wunduanina ayi bika wukhula,
\q1 keba luzingu luama boso buididi zitsila ziaku.
\q1 
\v 155 Phulusu thama yidi mu diambu di batu bambimbi
\q1 bila batombanga ko zinzengolo ziaku.
\q1 
\v 156 Kiadi kiaku kidi kinneni, a Yave ;
\q1 keba luzingu luama boso buididi mina miaku.
\q1 
\v 157 Batu bobo beti kundenda badi bawombo ayi beti kundiamisa ;
\q1 vayi ndikadi vengama mu zinzengolo ziaku.
\q1 
\v 158 Ndieti kakumukina batu bobo bakambulu minu
\q1 bila batumukinanga ko mambu maku
\q1 
\v 159 Tala phila ndieti zodila minsiku miaku,
\q1 keba luzingu luama, a Yave, boso buididi luzolo luaku.
\q1 
\v 160 Mambu maku moso madi makiedika ;
\q1 Mina miaku mioso misonga midi mu zithangu zioso.
\q1 
\v 161 Minyadi mindiamisini mu kambu bila
\q1 vayi ntimꞌama wulembo titi va ntuala mambu maku.
\q1 
\v 162 Khini ndieti mona mu tsilꞌaku
\q1 banga mutu beki kiuka kinneni mu mvita.
\q1 
\v 163 Ndieti lenda ayi ndieti kakumukina luvunu
\q1 vayi ndieti zola Mina miaku.
\q1 
\v 164 Ndieti kuzitisa mu tsambuadi di zikhumbu mu lumbu
\q1 mu diambu di Mina miaku misonga.
\q1 
\v 165 Ndembama yiwombo yidi kuidi bobo banzolanga Mina miaku ;
\q1 kuisi ko diambu dimosi diba lenda buminina thutu
\q1 
\v 166 Ndilembo vingila phulusu aku, a Yave
\q1 ayi ndieti landakana zithumunu ziaku.
\q1 
\v 167 Ndieti tumimina zinzengolo ziaku
\q1 bila ndieti kuzizola ngolo
\q1 
\v 168 Ndieti tumimina minsiku miaku ayi zinzengolo ziaku
\q1 bila ngeyo zebi zinzila ziama zioso.
\q1 
\v 169 Bika yamikina kuama kutula va ntualꞌaku, a Yave
\q1 wuphana diela boso buididi mambu maku.
\q1 
\v 170 Bika ndombolo ama yitula va ntualꞌaku ;
\q1 wukhula boso buididi tsilꞌaku.
\q1 
\v 171 Bika bididi biama bisapika mu nzitusu aku
\q1 bila weti kundonga zinzengolo ziaku
\q1 
\v 172 Bika ludimi luama luyimbila mambu maku
\q1 bila zithumunu ziaku zioso zidi zisonga.
\q1 
\v 173 Bika koko kuaku kuba kukubama mu kutsadisa
\q1 bila ndisobula minsiku miaku.
\q1 
\v 174 Phuila yingolo ndiba mu mona phulusu aku, a Yave
\q1 ayi Mina miaku mikumbonisanga khini.
\q1 
\v 175 Bika ndizinga muingi ndizitisa
\q1 ayi bika mina miaku mitsimba
\q1 
\v 176 Ndidiengila banga nkangu wu mamemi mazimbala,
\q1 tomba kisadi kiaku,
\q1 bila ndisia zimbakana ko zithumunu ziaku.
\c 120
\cl Minkunga 120
\s1 Bika wukhula
\d Nkunga wuyimbudulu mu nzila yikuendila ku nzo Yave.
\q1 
\v 1 Nditela Yave mu ziphasi ziama
\q1 ayi niandi wupheni mvutu.
\q1 
\v 2 Wuphukisa, a Yave, mu bididi bi luvunu
\q1 ayi mu ludimi luidi mayuya.
\q1 
\v 3 Mbi kalenda kuvangila
\q1 ayi mbi kalenda buela, ludimi luidi mayuya e ?
\q1 
\v 4 Wela kuvana thumbudulu mu madionga ma kinuani malengulu bumboti ;
\q1 mu makala ma mbazu, ma nungu-tsendi,
\q1 
\v 5 mabienga kuidi minu bu ndilembo vuandi ku Metsiseki ;
\q1 bu ndieti zingila mu zinzo zi ngoto zi Kedali.
\q1 
\v 6 Mu bilumbu biwombo ndizingila
\q1 va khatitsika batu bobo banlendanga ndembama.
\q1 
\v 7 Minu ndidi mutu wu ndembama ;
\q1 vayi minu yoluka, buna bawu beka yindula mvita.
\c 121
\cl Minkunga 121
\s1 Lusadusu luama kuidi Yave lueta ba
\d Nkunga wuyimbudulu mu nzila yikuendila ku nzo Yave.
\q1 
\v 1 Ndimvumbulanga meso mama ku miongo,
\q1 kuevi kuela totukila lusadusu luama e ?
\q1 
\v 2 Lusadusu luama luntotukila kuidi Yave ;
\q1 mvangi wu diyilu ayi ntoto.
\q1 
\v 3 Kalendi bika ko kulu kuaku kusialumuka ;
\q1 mutu wowo weti kukebanga kalendi niungina ko.
\q1 
\v 4 Bukiedika, mutu wowo weti sunga Iseli,
\q1 kalendi niungina ko voti leka tulu ko
\q1 
\v 5 Yave niandi wukusunganga,
\q1 niandi kitsusula kiaku va koko kuaku ku lubakala.
\q1 
\v 6 Thangu yilendi ku vanga ko mbimbi va muini
\q1 voti ngondi va builu.
\q1 
\v 7 Yave wela kukebanga mu mambimbi moso,
\q1 niandi wela sunganga luzingu luaku.
\q1 
\v 8 Yave wela kusunga mu kuiza kuaku ayi mu kuenda kuaku
\q1 tona buabu nate mu zithangu zioso.
\c 122
\cl Minkunga 122
\s1 Lusambila mu diambu di ndembama yi Yelusalemi
\d Nkunga Davidi wuyimbudulu mu nzila yikuendila ku nzo Yave.
\q1 
\v 1 Khini ndimona bu bakhamba ti :
\q1 “Bika tuendanu ku nzo Yave”.
\q1 
\v 2 Malu meto matelimini mu mielo miaku, a Yelusalemi.
\q1 
\v 3 Yelusalemi ditungu banga divula.
\q1 Diodi dikangama ngolo va kimosi
\q1 
\v 4 Kuna kueti kuiza zimvila, zimvila Yave
\q1 mu diambu di zitisa dizina di Yave
\q1 boso buididi zinzengolo zivanu kuidi Iseli.
\q1 
\v 5 Bila kuna kutelimini bikundu bi kipfumu bi tsambusulu ;
\q1 bikundu bi kipfumu bi nzo yi Davidi.
\q1 
\v 6 Lusambila mu diambu di ndembama yi Yelusalemi.
\q1 Bika bobo beti kuzola bamona luvovomo.
\q1 
\v 7 Bika ndembama yiba mu bibaka biaku
\q1 ayi luvovomo mu zinzo ziaku zinneni.
\q1 
\v 8 Mu diambu di bakhomba ziama ayi bakundi bama
\q1 ndiela tuba “bika ndembama yiba yaku”.
\q1 
\v 9 Mu diambu di nzo Yave, Nzambi eto, ndiela tomba mamboti maku.
\c 123
\cl Minkunga 123
\s1 Mu phingudulu yi nlemvo andi
\d Nkunga wunyimbudulu mu nzila yikuendila ku nzo Yave.
\q1 
\v 1 Ndimvumbula meso mama kuidi ngeyo Yave
\q1 ngeyo beki kundu kiaku ki Kipfumu mu diyilu.
\q1 
\v 2 Banga meso ma bavika meti tala mioko mi bapfumu bawu ;
\q1 banga meso ma kisadi kinketo mantalanga mioko mi pfumu andi wu nketo ;
\q1 buawu bobo meso meto mantadilanga kuidi Yave, Nzambi eto,
\q1 nate kela kutumona kiadi.
\q1 
\v 3 Wutumoni kiadi, a Yave, wutumoni kiadi
\q1 bila nlenzo wuwombo tutambudi.
\q1 
\v 4 Mvuezolo wuwombo tutambula kuidi bankua luniemo ;
\q1 nlenzo wuwombo kuidi bankua lunangu.
\c 124
\cl Minkunga 124
\s1 Lusadusu lueto kuidi Yave lueta ba
\d Nkunga Davidi wunyimbudulu mu nzila yikuendila ku nzo Yave.
\q1 
\v 1 Bika Iseli katuba : Enati Yave kasia ba ku ndambuꞌeto ko ;
\q1 
\v 2 Enati Yave kasia ba ku ndambu eto ko
\q1 mu thangu batu batelama mu kutunuanisa ;
\q1 
\v 3 mu thangu nganzi awu yitubuila,
\q1 keti nganu mina batumina bamoyo ;
\q1 
\v 4 khuka nlangu yitumbu kutuvitumuna
\q1 ayi nguma yi nlangu yitudiamisa,
\q1 
\v 5 minlangu mi nguma mitulalumuna.
\q1 
\v 6 Nzitusu wuba kuidi Yave
\q1 mutu wowo wukambu kutuyekula batukanzuna mu meno ma miunu miawu.
\q1 
\v 7 Tutina banga nuni bu keti tinina mu dikondi di ntambi wu zinuni.
\q1 Dikondi dikanzuka ayi beto tutina.
\q1 
\v 8 Lusadusu lueto luidi mu dizina di Yave,
\q1 mvangi wu diyilu ayi ntoto.
\c 125
\cl Minkunga 125
\s1 Ndembama yi kiedika
\d Nkunga wunyimbudulu mu nzila yikuendila ku nzo Yave.
\q1 
\v 1 Bobo bantulanga diana diawu mu Yave badi banga mongo wu Sioni,
\q1 wowo wulendi nikuka ko vayi wunzingilanga mu zithangu zioso.
\q1 
\v 2 Banga miongo bu mizungididi Yelusalemi,
\q1 buawu bobo Yave kazungididi batu bandi
\q1 tona buabu nate mu zithangu zioso.
\q1 
\v 3 Nkawa wu kipfumu wu batu bambimbi wulendi vuandanga ko
\q1 va mbata ntoto wukubukulu batu basonga ;
\q1 bila nganu batu basonga bela sadila mioko miawu mu vanga mambimbi.
\q1 
\v 4 Vanga mamboti, a Yave, kuidi batu bamboti,
\q1 kuidi bobo badi balulama mu mintima.
\q1 
\v 5 Vayi bobo beti vengama mu diatila mu zinzila zivenga,
\q1 Yave wela kuba lalikisa va kimosi ayi bobo bamvanganga mambimbi.
\q1 Ndembama yibanga vadi Iseli.
\c 126
\cl Minkunga 126
\s1 Thangu yi kuna ayi yi vela
\d Nkunga wunyimbudulu mu nzila yi kuendila ku nzo Yave.
\q1 
\v 1 Mu thangu Yave kavutula batu bakangama ku Sioni,
\q1 tuba banga batu banlota zindozi.
\q1 
\v 2 Miunu mieto miba miwala masevo ; ludimi lueto minkunga mi khini.
\q1 Buna batuba muidi makanda ti :
\q1 “Yave wuba vangidi mambu manneni.”
\q1 
\v 3 Yave wutuvangidi mambu manneni ;
\q1 ayi khini yitufulukidi.
\q1 
\v 4 Vutula diaka kimvuama kieto, a Yave ;
\q1 banga bina bimila bi minlangu ku Nengevi.
\q1 
\v 5 Bobo beti kuna ayi matsuela mu meso,
\q1 bela vedila mu minkunga mi khini.
\q1 
\v 6 Wuntotukanga ku nganda ayi matsuela mu meso ;
\q1 wunatanga mbongo mu kuna ;
\q1 weti vutuka ayi minkunga mi khini mu natanga mimvumba mi biti.
\c 127
\cl Minkunga 127
\s1 Niandi weti vanga mambu moso
\d Nkunga Salomo wunyimbudulu mu nzila yikuendila ku nzo Yave.
\q1 
\v 1 Enati Yave kakadi tunga nzo,
\q1 buna batu bobo balembo tungi mu phamba kuandi balembu sadila.
\q1 Enati Yave kakadi sunga divula
\q1 buna batu bobo balembo disungi mu phamba kuandi balembo disungila.
\q1 
\v 2 Mu phamba kuandi lueti kotukila nsuka-nsuka
\q1 ayi lueti kambu vika lekilanga,
\q1 lueti sadilanga ngolo mu diambu di bidia bi dia ;
\q1 bila bobuawu keti vanina kuidi bobo keti zola bu badi ku tulu.
\q1 
\v 3 Bana badi kiuka kimbanga kuidi Yave,
\q1 bosi mbutu wu bana widi mfutu wumbanga kuidi niandi.
\q1 
\v 4 Banga madionga mu mioko mi kinuani ki lulendo,
\q1 buawu bobo buididi bana mutu kabutidi mu kimuana kiandi.
\q1 
\v 5 Lusakumunu kuidi mutu wowo wuwesa bawu mu khutu andi.
\q1 Balendi fua tsoni ko mu thangu bela tubana ayi bambeni ziawu ku muelo.
\c 128
\cl Minkunga 128
\s1 Bika Yave kasakumuna
\d Nkunga wunyimbudulu mu nzila yikuendila ku nzo Yave.
\q1 
\v 1 Lusakumunu kuidi batu boso bobo bobo beti kinzika Yave,
\q1 bandiatilanga mu zinzila ziandi.
\q1 
\v 2 Ngeyo wela dia mbutu wu kisalu kiaku.
\q1 Lusakumunu ayi mamboti biela ba biaku.
\q1 
\v 3 Nketo aku wela ba banga vinu yidi mbozi yiwombo mu khati nzo aku ;
\q1 bana baku banga mintiudila mi olive muyendila mezꞌaku.
\q1 
\v 4 Buawu bobo buididi mutu wusakumunu,
\q1 wowo weti kinzika Yave.
\q1 
\v 5 Bika Yave kalusakumuna, tona ku Sioni mu bilumbu bioso bi luzingu lueno ;
\q1 bika lumona mamboti ma Yelusalemi
\q1 
\v 6 ayi bika lumona bana ba bana beno.
\q1 Bika ndembama yiba vadi Iseli.
\c 129
\cl Minkunga 129
\s1 Mu phasi ndiba vayi ndisia vonga ko
\d Nkunga wunyimbudulu mu nzila yikuendila ku nzo Yave.
\q1 
\v 1 Bandiamisa ngolo tona mu bumuana buama,
\q1 bika Iseli katuba.
\q1 
\v 2 Bandiamisa ngolo tona mu bumuana buama
\q1 vayi basia ku ndunga ko.
\q1 
\v 3 Minkuni midima manima mama ;
\q1 batula muawu minkala miawu mimula.
\q1 
\v 4 Vayi Yave widi wusonga ;
\q1 niandi wuzenga minsinga mi batu bambimbi muingi ndiba mu kiphuanza.
\q1 
\v 5 Bika babo beti lenda Sioni bavutuka fua tsoni.
\q1 
\v 6 Bika baba banga biti bi mbata muanzu,
\q1 biobi bieti yuma tuamina biyunduka ;
\q1 
\v 7 biobi mvedi kalendi wesa mu mioko miandi ko ;
\q1 voti mutu wowo wunkanga mvumba kalendi wesi mu mioko miandi ko.
\q1 
\v 8 Bika bobo bamviokila vana babika tuba :
\q1 “lusakumunu lu Yave lubanga yeno !
\q1 Tueti kulusakumuna mu dizina di Yave !”
\c 130
\cl Minkunga 130
\s1 Ku tsi ziphasi nditela Yave.
\d Nkunga wunyimbudulu mu nzila yinkuendila ku nzo Yave.
\q1 
\v 1 Bu nditotuka mu mabulu madi thipula,
\q1 ndiyamikina kuidi ngeyo, a Yave.
\q1 
\v 2 A Yave, wa mbemboꞌama ;
\q1 bika wutamba matu maku mu yamikina kuama mu diambu di lusadusu.
\q1 
\v 3 Enati ngeyo, a Yave, weti tangisa masumu
\q1 A Yave buna nani wulenda telama e ?
\q1 
\v 4 Vayi kuidi ngeyo kuidi ndemvukulu yi masumu ;
\q1 diawu fueni kinzuku.
\q1 
\v 5 Ndimvingila Yave, muelꞌama wulembo vingila ;
\q1 ayi mu mambu mandi, ndintula diana diama.
\q1 
\v 6 Muelꞌama wumvingila Yave viokila minsungi mimvingila nsuka.
\q1 Nyinga viokila minsungi mimvingila nsuka.
\q1 
\v 7 A Iseli, tula diana diaku mu Yave
\q1 Bila mu niandi muidi luzolo lu ngolo
\q1 ayi mu niandi muidi khudulu yiduka.
\q1 
\v 8 Niandi veka wela kula Iseli mu masumu mawu moso.
\c 131
\cl Minkunga 131
\s1 Ndembama yi kiedika
\d Nkunga Davidi wunyimbudulu mu nzila yikuendila ku nzo Yave.
\q1 
\v 1 Ntimꞌama wisi luniemo ko, a Yave, meso mama masi lunangu ko.
\q1 Ndiyindulanga ko mambu malutidi manneni
\q1 voti momo madi matsiminanga kuidi minu.
\q1 
\v 2 Vayi ndivumbika muelꞌama ayi ndidingimisa wawu ;
\q1 banga muana wutsombi wulemboso mabeni widi va kimosi ayi ngudi andi ;
\q1 banga muana wutsombi wulemboso mabeni
\q1 buawu buididi muelꞌama mu minu.
\q1 
\v 3 A Iseli, tula diana diaku mu Yave
\q1 tona buabu nate mu zithangu zioso.
\c 132
\cl Minkunga 132
\s1 Divula di Ntinu
\d Nkunga wunyimbudulu mu nzila yikuendila ku nzo Yave.
\q1 
\v 1 A Yave, tebukila Davidi moyo
\q1 ayi ziphasi ziandi zioso kamona ;
\q1 
\v 2 wuzenga ndefi kuidi Yave
\q1 ayi wuvanga lukanu kuidi nkua lulendo wu Yakobi :
\q1 
\v 3 “Ndilendi kota ko mu nzo ama ;
\q1 voti kuenda va mbukꞌama.
\q1 
\v 4 Ndilendi vana ko meso mama minsua mu bua ku tulu ;
\q1 zindabu ziama mu laba,
\q1 
\v 5 nate ndimbakula buangu mu diambu di Yave,
\q1 buangu kivuanda mu diambu di nkua lulendo wu Yakobi.”
\q1 
\v 6 Tuwa tsangu beni ku Efalata, tuwila yawu mu zitsola zi Yali.
\q1 
\v 7 Bika tuenda ku buangu kiandi kioki keti vuanda ;
\q1 bika tubuongama va ntuala kima kioki keti tetika malu mandi.
\q1 
\v 8 Telama, a Yave, ayi kota ku buangu kiaku kivundila
\q1 ngeyo va kimosi ayi kesi yi zingolo ziaku.
\q1 
\v 9 Bika zinganga ziaku zi Nzambi zivuata busonga ;
\q1 bika banlongo baku bayimbila mu khini.
\q1 
\v 10 Mu diambu di Davidi kisadi kiaku,
\q1 kadi loza mutu aku wowo wuvinda mafuta.
\q1 
\v 11 Yave wuzenga ndefi kuidi Davidi ;
\q1 ndefi yikiedika yoyi kalendi viakisa ko :
\q1 “wumosi mu nkunꞌaku ndiela tula va kundu kiaku ki Kipfumu.
\q1 
\v 12 Enati bana baku bakebidi Nguizani ama
\q1 ayi zinzengolo ziozi ndiela ku balonga,
\q1 buna bana bawu bela vuanda va kundu kiaku ki kipfumu.”
\q1 
\v 13 Bila Yave wusobula Sioni ;
\q1 wuzola Sioni ngolo mu ba buangu kiandi kika fueti vuandanga :
\q1 
\v 14 “Vava vadi buangu kiama kivundila mu zithangu zioso.
\q1 Vava ndiela tula kundu kiama ki kipfumu bila ndizola vawu.
\q1 
\v 15 Ndiela kunsakumuna mu bima biwombo ;
\q1 minsukami miandi, ndiela kuba yukutisa mu bidia.
\q1 
\v 16 Ndiela vuika zinganga ziandi phulusu
\q1 ayi kadika thangu banlongo bandi bela yimbilanga mu khini.
\q1 
\v 17 Vava ndiela vanga phoka yi yunduka mu diambu Davidi
\q1 ayi kubika muinda mu diambu di mutu ama ndivinda mafuta.
\q1 
\v 18 Ndiela vuika bambeni ziandi tsoni
\q1 vayi budu ki kipfumu kiela lezamanga. Va mbata ntu andi.”
\c 133
\cl Minkunga 133
\s1 Zikhomba bu badi mu kithuadi
\d Nkunga Davidi wunyimbudulu mu nzila yikuendila ku nzo Yave.
\q1 
\v 1 Phila mboti ayi kitoko kuidi bakhomba mu thangu zinzingilanga va
\q1 kimosi mu kithuadi.
\q1 
\v 2 Diambu beni didi banga mafuta ma thalu madukulu ku ntu,
\q1 mankumba nate mu mayedo,
\q1 mankumba nate mu mayedo ma Aloni,
\q1 mankumba nate mu zitsongi zi zilobi ziandi.
\q1 
\v 3 Didi banga bimi bi Helimoni bieti kumba mu miongo mi Sioni,
\q1 bila kuna Yave keti vanina lusakumunu luandi,
\q1 luzingu mu zithangu zioso.
\c 134
\cl Minkunga 134
\s1 Luzitisa Pfumu
\d Nkunga wunyimbudulu mu nzila yikuendila ku nzo Yave.
\q1 
\v 1 Luzitisa Yave beno bisadi bioso bi Yave ;
\q1 beno lunsalanga mu builu mu nzo Yave.
\q1 
\v 2 Vumbulanu mioko mieno mu buangu kinlongo
\q1 ayi luzitisa Yave.
\q1 
\v 3 Bika Yave mvangi wu diyilu ayi ntoto ;
\q1 kalusakumuna tona ku Sioni.
\c 135
\cl Minkunga 135
\s1 Pfumu widi wumboti
\q1 
\v 1 Luzitisa Yave,
\q1 luzitisa dizina di Yave,
\q1 lunzitisa beno bisadi bi Yave ;
\q1 
\v 2 beno lunsalanga mu Nzo Yave,
\q1 mu ziphangu zi Nzo yi Nzambi eto.
\q1 
\v 3 Luzitisa Yave bila Yave widi wumboti ;
\q1 luyimbila minzitusu mu diambu di dizina diandi,
\q1 bila didi diambu di kitoko.
\q1 
\v 4 Bila Yave wukisobudila Yakobi mu ba wandi veka,
\q1 Iseli, mu diambu kaba kiuka kioki kavuidi niandi veka.
\q1 
\v 5 Nzebi ti Yave widi wunneni,
\q1 ti Yave eto widi wunneni viokila zinzambi zioso.
\q1 
\v 6 Muaki Yave weti vanga moso kazodidi,
\q1 mu diyilu ayi vava ntoto,
\q1 mu mimbu ayi mu mabulu mawu moso madi thipula.
\q1 
\v 7 Niandi wuntotulanga matuti mu zitsongi zi ntoto ;
\q1 niandi wumfidisanga zitsiemo va kimosi ayi mvula
\q1 ayi wuntotulanga phemo mu bibuangu biandi biobi kalundila wawu.
\q1 
\v 8 Niandi wuvonda bana batheti mu Ezipite,
\q1 bana batheti ba batu ayi ba bibulu.
\q1 
\v 9 Wufidisa bidimbu biandi ayi matsiminanga
\q1 va khatitsikꞌaku, a Ezipite
\q1 mu diambu di nuanisa Falawo ayi bisadi biandi bioso.
\q1 
\v 10 Niandi wuvonda makanda mawombo
\q1 ayi wuvonda mintinu mi lulendo.
\q1 
\v 11 Sihoni ntinu basi Amoli ;
\q1 Ongi ntinu basi Basani
\q1 ayi mintinu mioso mi Kana.
\q1 
\v 12 Ayi wuvana zitsi ziawu banga kiuka ;
\q1 kiuka kuidi Iseli, batu bandi.
\q1 
\v 13 Dizina diaku, a Yave, dinzingilanga mu zithangu zioso,
\q1 zitsangu ziaku, a Yave, mu zitsungi zioso.
\q1 
\v 14 Bila Yave wela nungisa batu bandi
\q1 ayi wela mona bisadi biandi kiadi.
\q1 
\v 15 Bitumba bi makanda bidi bi palata ayi bi nolo ;
\q1 bivangulu mu mioko mi batu ;
\q1 
\v 16 bibeki miunu vayi bilendi tuba ko ;
\q1 meso vayi bilendi mona ko ;
\q1 
\v 17 Bibeki matu vayi bilendi wa ko
\q1 bisi kadi phemo ko mu miunu miawu.
\q1 
\v 18 Batu bobo beti vanga biawu bela ba banga biawu
\q1 ayi buawu bobo buela bela bobo bantulanga diana mu biawu.
\q1 
\v 19 A nzo yi Iseli, luzitisa Yave.
\q1 A nzo yi Aloni, luzitisa Yave.
\q1 
\v 20 A nzo yi Levi, luzitisa Yave.
\q1 Beno lueti kunkinzika, luzitisa Yave.
\q1 
\v 21 Bika nzitusu wuba kuidi Yave tona mu Sioni
\q1 kuidi niandi weti vuanda ku Yelusalemi.
\q1 Luzitisa Yave.
\c 136
\cl Minkunga 136
\s1 Luzolo luandi luidi mu zithangu zioso
\q1 
\v 1 Luvutudila Yave matondo bila niandi widi wumboti,
\qr luzolo luandi lunzingilanga mu zithangu zioso.
\q1 
\v 2 Luvutudila Nzambi yi zinzambi matondo,
\qr luzolo luandi lunzingilanga mu zithangu zioso.
\q1 
\v 3 Luvutudila Pfumu yi bapfumu matondo,
\qr luzolo luandi lunzingilanga mu zithangu zioso,
\q1 
\v 4 niandi kaka, wumvanganga matsiminanga,
\qr luzolo luandi lunzingilanga mu zithangu zioso
\q1 
\v 5 niandi wuvanga diyilu mu diela diandi
\qr luzolo luandi lunzingilanga mu zithangu zioso
\q1 
\v 6 Niandi wuyalumuna ntoto va mbata minlangu ;
\qr luzolo luandi lunzingilanga mu zithangu zioso
\q1 
\v 7 Niandi wuvanga kiezila kingolo
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 8 thangu mu diambu di yadila muini,
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 9 ngondi ayi zimbuetete mu diambu di yadila builu,
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 10 kuidi niandi bila niandi wuvvonda bana batheti mu Ezipite,
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 11 ayi wutotula bana ba Iseli va khatitsika basi Ezipite
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 12 mu koko ku ngolo ayi ku yalumuka,
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 13 Kuidi niandi bila niandi wuvasa mbu wu mbuaki mu zindambu zizole,
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 14 ayi wuviokisila Iseli va khatitsika mbu wu mbuaki,
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 15 vayi wulalumusa Falawo ayi masodi mandi mu mbu wu mbuaki,
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 16 kuidi niandi bila niandi wudiatisa batu bandi mu dikanga ;
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 17 Niandi wuvonda mintinu minneni,
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 18 ayi wuvonda mintinu mi lulendo,
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 19 Sihoni, ntinu basi Amoli,
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 20 ayi Ongi, ntinu basi Basani,
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 21 ayi wuvana zitsi ziawu banga kiuka,
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 22 kiuka kuidi kisadi kiandi, Iseli,
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 23 kuidi niandi, mutu wowo wututebukila moyo mu kambu kueto ku luvalu,
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 24 ayi wutuvana kiphuanza mu bambeni zieto,
\qr luzolo luandi lunzingilanga mu zithangu zioso ;
\q1 
\v 25 ayi niandi wumvananga bidia kuidi kioso-kioso vangu,
\qr luzolo luandi lunzingilanga mu zithangu zioso.
\q1 
\v 26 Luvutudila Nzambi yi diyilu matondo
\qr luzolo luandi lunzingilanga mu zithangu zioso.
\c 137
\cl Minkunga 137
\s1 Va muenda minlangu minneni mi Babiloni
\q1 
\v 1 Va muenda minlangu minneni mi Babiloni ;
\q1 tuvuanda ayi tudila bu tutebukila Sioni moyo.
\q1 
\v 2 Kuna tudengidika zingitala zieto mu minti.
\q1 
\v 3 Bila kuna, batu bobo batukanga mu kivika
\q1 batulomba tuyimbila minkunga ;
\q1 minyamisi mieto mituyuvula minkunga mi khini ;
\q1 batuba : “lutuyimbidila nkunga wumosi mu minkunga mi Sioni.”
\q1 
\v 4 A buevi tulenda yimbidila minkunga mi Yave
\q1 mu ntoto wu kinzenza e ?
\q1 
\v 5 Enati ndizimbikini, a Yelusalemi ;
\q1 bika koko kuama ku lubakala kuzimbakana zitsembo ziandi.
\q1 
\v 6 Bika ludimi luama lunama mu mianzi mi munu ama
\q1 enati ndikadi kutebukila moyo,
\q1 enati ndikadi ba mayindu mu Yelusalemi,
\q1 khini ama yoyo yilutidi zangama.
\q1 
\v 7 Tebuka moyo, a Yave, momo basi Edomi
\q1 bavanga mu lumbu kibua Yelusalemi,
\q1 Bayamikina : “lutiolumuna, lutiolumuna nate muna zifundasio ziandi.”
\q1 
\v 8 A muana ndumba wu Babiloni, ngeyo wukubuku mu bungu ;
\q1 khini kuidi mutu wowo wukuvutudila mambu momo wutuvangila.
\q1 
\v 9 Khini kuidi mutu wumbuila bana baku batsombi
\q1 ayi wela kuba banda va matadi.
\c 138
\cl Minkunga 138
\s1 Thidi yimbidila kikhuikizi kiaku
\d Nkunga Davidi.
\q1 
\v 1 Ndiela kuzitisa, a Yave, mu ntimꞌama wumvimba ;
\q1 ndiela yimbila minzitusu miaku va ntuala zinzambi.
\q1 
\v 2 Ndiela buongama ku ndambu nzo aku yinlongo ;
\q1 ayi ndiela zitisa dizina diaku mu diambu di luzolu luaku
\q1 ayi mu diambu di kikhuikizi kiaku
\q1 bila ngeyo wuyayisidi dizina diaku ayi mambu maku va yilu bima bioso.
\q1 
\v 3 Thangu nditela, ngeyo wuphana mvutu.
\q1 Wukhitula nkua ngangu ayi nkua bukhafi bu ngolo.
\q1 
\v 4 Bika mintinu mioso mintoto mizitisa, a Yave
\q1 bu miwilu mambu ma munu aku.
\q1 
\v 5 Bika miyimbila zinzila zi Yave
\q1 bila nkembo wu Yave widi wunneni.
\q1 
\v 6 Ka diambu ko Yave widi wuzangama,
\q1 niandi weti tala bobo beti kukikulula
\q1 ayi zebi bumboti batu badi luniemo bu badi ku thama.
\q1 
\v 7 Ka diambu ko ndilembo diatila va khatitsika ziphasi,
\q1 ngeyo weti tanina luzingu luama ;
\q1 ngeyo weti nonuna koko kuaku
\q1 mu kakidila zinganzi zi bobo beti kundenda ;
\q1 mu koko kuaku ku lubakala weti kuphukisila.
\q1 
\v 8 Yave wela dukisa mambu momo keti tomba mu minu.
\q1 Luzolo luaku, a Yave, lunzingilanga mu zithangu zioso.
\q1 Kadi yekula bisalu bi mioko miaku.
\c 139
\cl Minkunga 139
\s1 Pfumu, ngeyo zebi mambu mama moso
\d Nkunga Davidi kuidi Pfumu minyimbidi.
\q1 
\v 1 A Yave ngeyo wuthomba ayi ngeyo wunzebi.
\q1 
\v 2 Ngeyo zebi thangu ndidi wuvuanda
\q1 ayi thangu ndidi wutelama ;
\q1 ngeyo weti bakula bumboti mayindu mama bu makidi thama.
\q1 
\v 3 Ngeyo zebi thangu ndieti totuka
\q1 ayi thangu ndieti lambalala ;
\q1 Ngeyo zebi bumboti zinzila ziama zioso.
\q1 
\v 4 Tuamina mambu maba va ludimi luama,
\q1 ngeyo zebi mawu moso, a Yave.
\q1 
\v 5 Ngeyo wunzungididi ku manima ayi ku ntuala
\q1 Ngeyo wutetika koko kuaku va minu.
\q1 
\v 6 Nzayilu yi phila yoyi, yididi ngolo
\q1 yitsiminanga kuidi minu ;
\q1 yididi ngolo yinangama muingi ndiyibakidila.
\q1 
\v 7 Kuevi ndilenda kuenda suamina phevi aku e ?
\q1 A kuevi ndilenda kuenda tinina meso maku e ?
\q1 
\v 8 Enati khumini ku Diyilu, ngeyo widi kuna ;
\q1 enati minu thudidi mbukꞌama ku tsina ntoto,
\q1 ngeyo widi kuna.
\q1 
\v 9 Enati khumini mu mavavi ma nkielo buisi ;
\q1 enati phuendi ku lubakala lu mbu,
\q1 
\v 10 buna kuna diaka, koko kuaku kuela kundiatisa ;
\q1 koko kuaku ku lubakala kuela kutsimbidila ngolo.
\q1 
\v 11 Enati khembi : “Bukiedika tombi kiela kutsueka”
\q1 vayi buna kiezila kikitukidi tombi va ndidi.
\q1 
\v 12 Muaki tombi kilendi ba tombi kuidi ngeyo ko ;
\q1 builu buela kienzuka banga muini
\q1 bila tombi kidi banga kiezila kuidi ngeyo.
\q1 
\v 13 Ngeyo wuvanga binama biama bi khati nitu ;
\q1 ngeyo wuthunga va kimosi mu vumu ki ngudi ama.
\q1 
\v 14 Ndikuzitisa bila ndidi vangu ki tsisi ayi kitsiminanga ;
\q1 mavanga maku madi matsiminanga ayi nzebi buawu bumboti.
\q1 
\v 15 Khubukulu ama yi mimvesi yisia suama va ntualꞌaku ko
\q1 mu thangu ndikubuku mu buangu kisuama ;
\q1 mu thangu ndivangu va kimosi ku tsina ntoto.
\q1 
\v 16 Meso maku mamona nitu ama yikambu kubuku.
\q1 Bilumbu bioso biobi wukhubikila biba bisonama mu bukuꞌaku,
\q1 tuamina lumbu kimosi mu biawu kiba.
\q1 
\v 17 A phila thalu mayindu maku kuidi minu, a Nzambi !
\q1 A phila woka madi !
\q1 
\v 18 Enati thidi ku matanga ;
\q1 buna maviokidi nzielo mu thalu ;
\q1 Bu khotukidi, minu ndidi kaka yaku.
\q1 
\v 19 Enati ngeyo wuzola kaka vonda mutu wumbimbi, a Nzambi !
\q1 Bika luthatukila beno luntengulanga menga !
\q1 
\v 20 Beti kuyolukila mu zikhanu zimbimbi ;
\q1 bobo beti kulenda beti sadila dizina diaku mu kambu fuana.
\q1 
\v 21 Buevi, ndilendi lenda ko bobo beti kulenda, a Yave ?
\q1 A buevi, ndilendi kakumukina ko bobo beti kufuemi e ?
\q1 
\v 22 Ndisi kadi diambu ko vayi kikhenene kaka ndidi kuidi bawu ;
\q1 ndieti ba tanga bambeni ziama.
\q1 
\v 23 Wumfiongunina, a Nzambi, ayi zaba ndimꞌama ;
\q1 wuthota ayi zaba mayindu mama.
\q1 
\v 24 Tala kani nzila yimbimbi yidi mu minu
\q1 ayi wundiatisa mu nzila yi mvu ka mvu.
\c 140
\cl Minkunga 140
\s1 Bika wukhula mu mimvuezi
\d Nkunga Davidi kuidi pfumu minyimbidi.
\q1 
\v 1 Wukhudi, a Yave, mu mutu wumbimbi ;
\q1 wukheba mu mutu wu makhemi ;
\q1 
\v 2 bobo banyindulanga zikhanu zimbimbi mu mintima miawu
\q1 ayi bantombanga lumbu ka lumbu nuana mvita.
\q1 
\v 3 Beti kitula ludimi luawu meno banga lu nioka ;
\q1 mitsa mi bikusa midi mu bididi biawu.
\q1 
\v 4 Wukheba, a Yave, mu mutu wumbimbi.
\q1 Wuthanina mu batu badi makhemi ;
\q1 bobo beti kubika zikhanu mu buisa malu mama.
\q1 
\v 5 Batu ba luniemo bathambila makondi ;
\q1 bayalumuna minsinga mi makondi mawu
\q1 ayi bathambila mintambu muyenda nsolo ama.
\q1 
\v 6 A Yave, ndituba kuidi ngeyo :
\q1 “ngeyo Nzambi ama.”
\q1 Wa, a Yave, yamikina kuama bu ndintomba monono kiadi.
\q1 
\v 7 A Yave, mutu wumvanganga makazodidi
\q1 ngeyo nkudi ama wu ngolo
\q1 ngeyo weti kaka ntuꞌama mu lumbu ki mvita.
\q1 
\v 8 Kadi tala zitsatu zi batu bambimbi zivangama, a Yave.
\q1 Kadi tala ti zikhanu ziawu zinunga
\q1 nganu bela ba luniemo.
\q1 
\v 9 Bika mintu mi bobo banzungididi
\q1 mifuku kuidi ziphasi ziozi bididi biawu bitotula.
\q1 
\v 10 Bika makala ma mbazu mabua va bawu.
\q1 Bika balozo ku mbazu, ku tsi mabulu madi nyamba ;
\q1 babika buela telama.
\q1 
\v 11 Bika mimvuezi mibika zingila mu tsi ;
\q1 bika mabienga malandakana mu kambu vonga batu badi makhemi.
\q1 
\v 12 Nzebi ti Yave weti vana luvovomo lusonga kuidi nsukami
\q1 ayi wela nuanina minsukami.
\q1 
\v 13 Bukiedika, basonga bela zitisa dizina diaku
\q1 ayi batu badi mintima milulama bela zingila va ntualꞌaku.
\c 141
\cl Minkunga 141
\s1 Bika wutsimba mu koko kuaku
\d Nkunga Davidi.
\q1 
\v 1 A Yave, ngeyo nditela ; yiza nsualu kuidi minu.
\q1 Wa mbemboꞌama mu thangu ndilembo kutedi.
\q1 
\v 2 Bika lusambulu luama luba va ntualꞌaku banga ansa\f + \fr 141.2 \fq ansa\fqa  : \ft Tala Matayi 1.11.\f*
\q1 bika mvumbudulu yi mioko miama yiba banga dikaba di masika.
\q1 
\v 3 Tula nsungi va munu ama, a Yave ;
\q1 keba bumboti muelo wu bididi biama.
\q1 
\v 4 Kadi yinika ntimꞌama ku mambimbi,
\q1 mu baka kuku mu mavanga mambimbi
\q1 va kimosi ayi bamvanganga mambimbi ;
\q1 kadi tala ti ndidia bidia biawu bidi lueki.
\q1 
\v 5 Bika mutu wusonga kambeta, diodi didi dimboti ;
\q1 bika kathemina, diodi didi mafuta va ntuꞌama ;
\q1 ayi ntuꞌama wulendi manga mawu ko.
\q1 Muaki lusambulu luama luela nuanisanga mu zithangu zioso
\q1 mavanga ma batu bamvanganga mambimbi.
\q1 
\v 6 Minyadi miawu miela lozo ku tsi tona ku yilu ngumbu
\q1 ayi batu bambimbi bela longuka ti mambu mama ndituba,
\q1 matubu bumboti.
\q1 
\v 7 Bela tuba : “mutu bu keti kabila ntoto ayi vasila ntoto
\q1 buawu bobo mimvesi mieto mididi misasakana
\q1 va muelo tsi bafua”.
\q1 
\v 8 Vayi meso mama madi kaka kuidi ngeyo Yave,
\q1 mutu wumvanganga makazodidi
\q1 Kuidi ngeyo ndintombila suamunu,
\q1 kadi kundiekula mu lufua.
\q1 
\v 9 Wukheba mu makondi bathambila
\q1 ayi mu mintambu mitula batu bamvanganga mambimbi.
\q1 
\v 10 Bika batu bambimbi, babua mu makondi mawu veka
\q1 vayi minu ndiviokila vawu mu luvovomo.
\c 142
\cl Minkunga 142
\s1 Ngeyo kaka suamunu kiama
\d Nkunga Davidi kayimbidila banga lusambulu mu thangu kaba mu nsuku.
\q1 
\v 1 Ndinyamikina ngolo kuidi Yave
\q1 Ndimvumbula mbembo ama kuidi Yave mu diambu di kiadi.
\q1 
\v 2 Ndilembo dukula luniongo luama va ntualꞌandi ;
\q1 va ntualꞌandi, ndinyolukila ziphasi ziama.
\q1 
\v 3 Mu thangu phevi ama yilembo suki-suki mu khati ama,
\q1 keti ngeyo wuzaba nzilꞌama.
\q1 Mu nsolo wowo ndidiatila, muawu batu bathambila ntambu.
\q1 
\v 4 Tala ku lubakala luama ayi tala,
\q1 kadi mutu widi mayindu mu minu.
\q1 Ndisi kadi suamunu ko
\q1 kuisi ko mutu wumbanzila luzingu luama.
\q1 
\v 5 Kuidi ngeyo ndinyamikina, a Yave.
\q1 Ndilembo tubi : “ngeyo suamunu kiama ;
\q1 Ngeyo kuku kiama va ntoto wu batu badi moyo.”
\q1 
\v 6 Dimba yamikina kuama
\q1 bila ndidi nsukami wu ngolo, wukambulu diana ;
\q1 wukhula mu bobo balembo ndandakana bila bawu bandutidi ngolo.
\q1 
\v 7 Bika wuthotula nloko ama muingi ndizitisa dizina diaku ;
\q1 buna basonga bela kuiza kutakana va ndidi
\q1 mu diambu di mamboti maku kuidi minu.
\c 143
\cl Minkunga 143
\s1 Wundiatisa mu zinzila ziaku
\d Nkunga Davidi.
\q1 
\v 1 A Yave, wa lusambulu luama,
\q1 dimba yamikina kuama mu diambu di kiadi
\q1 mu kikhuikizi kiaku ayi mu busonga buaku,
\q1 yiza wutsadisa.
\q1 
\v 2 Kadi nata kisadi kiaku ku tsambusu ;
\q1 bila kadi mutu wumosi widi moyo widi wusonga va ntualꞌaku.
\q1 
\v 3 Bila mbeni wulembo ndandakana,
\q1 wulembo ndiatidila va tsi ;
\q1 niandi wukuphuandisanga mu bibuangu bidi tombi
\q1 banga batu bobo bafua thama.
\q1 
\v 4 Buna pheve ama yeka suka-suka mu khati ama ;
\q1 ntimꞌama weka mona tsisi mu khati ama.
\q1 
\v 5 Ndilembo tebukila moyo bilumbu bivioka.
\q1 Ndinyindulanga mavanga maku moso
\q1 ayi fiongunina mavanga ma mioko miaku.
\q1 
\v 6 Ndinonuna mioko miama kuidi ngeyo.
\q1 Muelꞌama widi phuila mu kumona
\q1 banga ntoto wu yuma, bu wididi phuila nlangu.
\q1 
\v 7 Wuphani mvutu mu nsualu, a Yave
\q1 pheve ama yilembo yami.
\q1 Kadi kutsuekila zizi kiaku
\q1 bila ndieka dedakana banga bobo bankuendanga ku dibulu.
\q1 
\v 8 Bika nsuka wundatina mambu ma luzolo luaku lu ngolo ;
\q1 bila nditula diana diama mu ngeyo.
\q1 Wumbonisa nzila yoyi mfueti kuendila
\q1 bila kuidi ngeyo ndimvumbula muelꞌama.
\q1 
\v 9 Wukhula mu bambeni ziama, a Yave ;
\q1 bila ndikukisuekanga mu ngeyo.
\q1 
\v 10 Wundonga mu vanga luzolo luaku
\q1 bila ngeyo Nzambi ama.
\q1 Bika pheve aku yimboti yindiatisa mu ntoto wulendumuka.
\q1 
\v 11 Mu diambu di dizina diaku, a Yave, tamina luzingu luama ;
\q1 mu busonga buaku, bika wuthotula mu ziphasi.
\q1 
\v 12 Mu luzolo luaku lu ngolo, kanga bambeni ziama ;
\q1 bunga babo bobo beti kundenda, bila ndidi kisadi kiaku.
\c 144
\cl Minkunga 144
\s1 Batu baku badi mu khini
\d Nkunga Davidi.
\q1 
\v 1 Bika, nzitusu wuba kuidi Yave, ditadi diama ;
\q1 weti longa mioko miama mu nuana mvita
\q1 ayi minlembo miama mu nuana khindu.
\q1 
\v 2 Niandi Nzambi ama yi luzolo ayi tinunu kiama
\q1 niandi suamunu kiama kingolo ayi niandi nkuidi ama,
\q1 niandi nkaku ama ;
\q1 mu niandi ndieti suamina
\q1 ayi niandi wuntulanga batu ku tsi luyalu luama.
\q1 
\v 3 A Yave, buna mutu niandi nani muingi wumbelanga mayindu ;
\q1 muana mutu muingi wunyindulanga e ?
\q1 
\v 4 Mutu dedakani banga phemo ;
\q1 bilumbu biandi bidi banga kitsusula kimvioka.
\q1 
\v 5 Vasa diyilu diaku, a Yave, ayi kuluka ;
\q1 simba miongo muingi mitotula muisi.
\q1 
\v 6 Fidisa zitsiemo ku ntuala ayi sasikisa bambeni ziama.
\q1 Loza madionga maku ayi wuba zimbikisa.
\q1 
\v 7 Yalumuna koko kuaku bu widi ku yilu ;
\q1 wuphukisa ayi wukhula mu minlangu mi nguma
\q1 ayi mu mioko mi banzenza,
\q1 
\v 8 bobo miunu miwedi luvunu ;
\q1 bobo mioko mi lubakala mibeki mayuya.
\q1 
\v 9 Ndiela kuyimbidila nkunga wumona, a Nzambi.
\q1 Mu siku ki kumi di minsinga, kioki beti tedila Lila, ndiela bula miziki,
\q1 
\v 10 Kuidi mutu wowo wumvananga kuidi mintinu ndungunu,
\q1 mutu wowo wunkulanga kisadi kiaku Davidi mu sabala kimvondanga.
\q1 
\v 11 Wuphukisa ayi wukhula mu mioko mi banzenza ;
\q1 bobo miunu miwedi luvunu
\q1 bobo mioko mi lubakala mibeki mayuya.
\q1 
\v 12 Buna bana beto babakala,
\q1 mu bumuana buawu bela ba banga bikunusu binyundukanga bumboti.
\q1 Bana beto babaketo
\q1 bela ba banga makunzi mafikulu ;
\q1 mammonisanga kitoko ki buangu.
\q1 
\v 13 Bilundulu bieto biela ba biwala mu kadika ntindu wu bidia ;
\q1 minkangu mieto mi mamemi miela buelama ayi buelama mu zimili zi
\q1 zimili mu makumi ma zimili mu zitsola zieto.
\q1 
\v 14 Zingombi zieto zikheto ziela nata mfuna wungolo,
\q1 mavudu malendi ba ko mu bibaka bieto
\q1 kadi buela kuenda mu kivika,
\q1 yamikina ku ziphasi kulendi ba diaka ko mu zinzila zieto.
\q1 
\v 15 Lusakumunu kuidi batu bobo mambu mama meti vangama.
\q1 Lusakumunu kuidi batu bobo Yave kadidi Nzambi.
\c 145
\cl Minkunga 145
\s1 Kipfumu kiaku kidi mu zithangu zioso
\d Nkunga wu nzitusu wu Davidi.
\q1 
\v 1 Ndiela kuyayisa Ntinu, Nzambi ama.
\q1 Ndiela zitisa dizina diaku
\q1 mu zithangu zioso ayi mu mvu ka mvu.
\q1 
\v 2 Ndiela kuzitisa mu kadika lumbu
\q1 ayi ndiela yayisa dizina diaku
\q1 mu zithangu zioso ayi mu mvu ka mvu.
\q1 
\v 3 Yave widi wunneni ayi niandi lutidi fuana mu zitusu
\q1 ayi bunneni buandi bulendi fiongonono ko kuidi mutu.
\q1 
\v 4 Tsungi yimosi yela niemisa bisalu biaku
\q1 kuidi tsungi yinkaka
\q1 ayi bela yolukila mavanga maku ma lulendo.
\q1 
\v 5 Bela tubila kiezila ki nkembo wu nzitusu aku ;
\q1 ayi minu ndiela yindulanga bisalu biaku bitsiminanga.
\q1 
\v 6 Bela yolukila lulendo lu bisalu biaku bi tsisi ;
\q1 ayi ndiela yamikisa mavanga maku manneni.
\q1 
\v 7 Bela sanisina mamboti maku mawombo-wombo
\q1 ayi bela yimbidila busonga buaku mu khini.
\q1 
\v 8 Yave widi nkua nlemvo ayi wumonanga kiadi ;
\q1 kavika fuemanga ko ayi fulukidi mu luzolo.
\q1 
\v 9 Yave widi wumboti kuidi batu boso ;
\q1 kiadi kiandi kidi kuidi batu boso kavanga.
\q1 
\v 10 Bibioso bi wuvanga biela kuzitisa, a Yave ;
\q1 banlongo baku bela kuyayisa.
\q1 
\v 11 Bela yolukila nkembo wu kipfumu kiaku
\q1 ayi bela tubila lulendo luaku,
\q1 
\v 12 mu diambu di batu boso bazaba mavanga maku ma lulendo ;
\q1 kiezila ki nkembo ki kipfumu kiaku.
\q1 
\v 13 Kipfumu kiaku kidi kipfumu mu thangu yi kayimani
\q1 ayi luyalu luaku lunzingilanga mu zitsungi zioso.
\q1 Yave widi wukuikama mu zitsila ziandi zioso
\q1 ayi nkua luzolo kuidi batu boso kavanga.
\q1 
\v 14 Yave wunsimbanga babo bobo beti bua
\q1 ayi weti vumbula bobo badi bakomvama.
\q1 
\v 15 Meso ma babo makutalanga
\q1 ayi ngeyo weti bavana bidia mu thangu yifuana.
\q1 
\v 16 Ngeyo wunzibulanga koko kuaku
\q1 ayi wunyukutisanga zitsatu zi kadika kima kidi moyo.
\q1 
\v 17 Yave widi wusonga mu zinzila ziandi zioso
\q1 ayi widi nkua luzolo kuidi batu boso kavanga.
\q1 
\v 18 Yave widi wufikama kuidi babo bobo bankutelanga,
\q1 kuidi babo bobo bankutelanga mu kiedika.
\q1 
\v 19 Niandi weti dedikisa zitsatu zi bobo beti ku kinzika ;
\q1 weti wa yamikina kuawu ayi weti ku bavukisa.
\q1 
\v 20 Yave weti sunga babo bobo beti kunzola
\q1 vayi wela bunga batu boso bambimbi.
\q1 
\v 21 Munuꞌama wela yolukila nzitusu wu Yave,
\q1 bika kadika vangu kizitisa dizina diandi dinlongo
\q1 mu zithangu zioso ayi nate mu mvu ka mvu.
\c 146
\cl Minkunga 146
\s1 Yave weti nungisa batu bayamusu
\q1 
\v 1 Luzitisa Yave ;
\q1 Zitisa Yave, a muelꞌama.
\q1 
\v 2 Ndiela zitisanga Yave mu luzingu luama loso ;
\q1 ndiela yimbidilanga Nzambi ama minzitusu
\q1 thangu yoso ndizingila.
\q1 
\v 3 Kadi tula diana dieno mu bana ba mintinu,
\q1 mu batu bobo beti fua, bobo balendi vukisa ko.
\q1 
\v 4 Pheve awu yawu kuenda buna beti vutuka mu ntoto ;
\q1 zikhanu ziawu zilalikini.
\q1 
\v 5 Lusakumunu kuidi mutu wowo widi ti Nzambi yi Yakobi
\q1 niandi nsadisi andi ;
\q1 wuntulanga diana diandi mu Yave, Nzambi andi,
\q1 
\v 6 mvangi wu diyilu, ntoto, mbu ayi bibio bidi muna ;
\q1 widi wukuikama mu zithangu zioso.
\q1 
\v 7 Niandi weti vavila mambu ma bobo beti yamusu,
\q1 ayi wumvananga bidia kuidi bobo badi nzala ;
\q1 Yave niandi weti totula batu bobo badi mu nloko.
\q1 
\v 8 Yave weti vana kiezila kuidi phofo,
\q1 Yave weti vumbula bobo badi bakomvama.
\q1 Yave weti zola batu basonga.
\q1 
\v 9 Yave weti sunga nzenza,
\q1 niandi wunkindisanga muana sana ayi difuola
\q1 vayi weti kakumukina zinzila zi batu bambimbi.
\q1 
\v 10 Yave wunyalanga mu zithangu zioso.
\q1 Nzambi aku, a Sioni, mu zitsungi zioso.
\q1 Luzitisa Yave.
\c 147
\cl Minkunga 147
\s1 Nzambi mu nza ayi mu zithangu zioso
\q1 
\v 1 Luzitisa Yave !
\q1 A phila mboti yidi mu yimbila minzitusu kuidi Nzambi eto.
\q1 A phila khini ayi fuana kuidi mu kunzitisa.
\q1 
\v 2 Yave weti tunga Yelusalemi,
\q1 weti kutikisa bana ba Iseli bayenda mu kivika.
\q1 
\v 3 Niandi weti belusa mintima mi kosakana
\q1 ayi wunkanganga ziphasima mu ziphuta ziawu.
\q1 
\v 4 Niandi weti zenga thalu yi zimbuetete
\q1 ayi weti kuzitedila kadika mbuetete mu dizina diandi.
\q1 
\v 5 Pfumu eto widi wunneni
\q1 ayi lulendo luandi luidi lunneni ;
\q1 diela diandi disi kadi ndilu ko.
\q1 
\v 6 Yave weti kindisa woso mutu weti kukikululanga
\q1 ayi weti lumba batu bambimbi va tsi.
\q1 
\v 7 Luyimbidila Yave mu kumvutudilanga matondo ;
\q1 Lusikila Nzambi eto miziki mu ngitala.
\q1 
\v 8 Niandi wufukidilanga diyilu mu matuti ;
\q1 wunkubikanga mvula mu diambu di ntoto
\q1 ayi niandi wummenisanga biti va mbata miongo mi fioti.
\q1 
\v 9 Niandi wumvananga bidia kuidi bibulu bi fioti
\q1 ayi kuidi bana ba ngonyi-ngonyi bu beti tela.
\q1 
\v 10 Khini andi yisi ko mu zingolo zi phunda
\q1 ayi yangalala kuandi kuisi ko mu malu ma mutu.
\q1 
\v 11 Yave weti yangalala mu batu bobo beti kunkinzika,
\q1 bobo bantulanga diana diawu mu luzolo luandi lungolo.
\q1 
\v 12 Yayisa Yave, a Yelusalemi ;
\q1 zitisa Nzambi aku, a Sioni ;
\q1 
\v 13 bila niandi wunkindisanga zitunga zi mielo miaku ;
\q1 ayi weti sakumuna batu baku badi mu ngeyo.
\q1 
\v 14 Niandi wuntulanga ndembama mu zindilu ziaku
\q1 ayi wukuyukutisanga mu ble yilutidi kitoko.
\q1 
\v 15 Niandi wumfidisanga zithumunu ziandi ku ntoto ;
\q1 mambu mandi meti tembakana mu thinu nsualu.
\q1 
\v 16 Niandi wumvananga mvula yi matadi banga mika mi dimemi ;
\q1 ayi wuntembikisanga disala banga dibombi.
\q1 
\v 17 Niandi wunlonzanga mvulꞌandi yi matadi banga matadi ma fioti
\q1 Nani wulenda telama va ntuala phemo andi yi kiozi e ?
\q1 
\v 18 Weti fidisa mambu mandi ayi weti kumasiutisa ;
\q1 weti vemuna phemo yi ngolo andi
\q1 ayi minlangu mieti kumba.
\q1 
\v 19 Niandi wuzabikisa mambu mandi kuidi Yakobi ;
\q1 mina miandi ayi zinzengolo ziandi kuidi Iseli.
\q1 
\v 20 Kasia bu vangila kadi kuidi dikanda dinkaka ko
\q1 basia zaba ko mina miandi.
\q1 Luzitisa Yave.
\c 148
\cl Minkunga 148
\s1 Mu diyilu ayi va ntoto
\q1 
\v 1 Luzitisa Yave ;
\q1 luzitisa Yave tona mu diyilu.
\q1 Lunzitisa mu bibuangu bizangama ngolo.
\q1 
\v 2 Lunzitisa, beno zimbasi ziandi zioso ;
\q1 lunzitisa beno minkangu miandi mioso mi masodi ma diyilu.
\q1 
\v 3 Lunzitisa beno thangu ayi ngondi,
\q1 lunzitisa beno zimbuetete zioso zidi kiezila.
\q1 
\v 4 Lunzitisa ngeyo diyilu dizangama ngolo
\q1 ayi beno minlangu midi ku mbata diyilu,
\q1 
\v 5 bika bizitisa dizina di Yave ;
\q1 bila niandi wuvana lutumunu ayi biawu bivangama.
\q1 
\v 6 Wubivuandisa va buangu
\q1 mu zithangu zioso ayi mu thangu yi kayimani.
\q1 Niandi wuvana nzengolo yayi, yikayilendi vioka ko.
\q1 
\v 7 Luzitisa Yave tona va ntoto,
\q1 beno bivangu binneni bi mbu ayi beno zithipula zioso zi mbu ;
\q1 
\v 8 mbazu ayi mvula yi matadi, mvula yi phembi ayi matuti ;
\q1 vuka ki phemo kieti sadila zithumunu ziandi.
\q1 
\v 9 Beno miongo ayi miongo mioso mi fioti ;
\q1 minti mimbutanga makundi ayi minti mioso mi Sedeli ;
\q1 
\v 10 bibulu bi nsitu ayi bibulu bibioso bi fioti,
\q1 bivangu bi fioti ayi zinuni zieti dumuka ;
\q1 
\v 11 mintinu mi ntoto ayi makanda moso ;
\q1 beno bana ba mintinu ayi minyadi mioso mi ntoto ;
\q1 
\v 12 bamatoko ayi bandumba, binunu ayi bana balezi
\q1 
\v 13 bika bazitisa dizina di Yave
\q1 bila dizina diandi diawu kaka difueni mu yayusu ;
\q1 kiezila kiandi kidi va yilu ntoto ayi ku yilu diyilu.
\q1 
\v 14 Niandi wutotudila batu bandi phoka,
\q1 nzitusu wu banlongo bandi boso ;
\q1 wu Iseli, batu bobo badi bakangama mu ntimꞌandi.
\q1 Luzitisa Yave.
\c 149
\cl Minkunga 149
\s1 Pfumu wunzolanga batu bandi
\q1 
\v 1 Luzitisa Yave ;
\q1 luyimbidila Yave nkunga wumona ;
\q1 nzitusu andi mu lukutukunu lu banlongo.
\q1 
\v 2 Bika Iseli kamona khini mu diambu di mvangi awu
\q1 Bika batu ba Sioni bayangalala mu diambu di ntinu awu.
\q1 
\v 3 Bika bazitisa dizina diandi mu makinu ;
\q1 ayi bansikila miziki mu ndungu ayi mu ngitala,
\q1 
\v 4 bila Yave weti yangalala mu batu bandi,
\q1 weti vuatisa phulusu kuidi batu beti kukikula.
\q1 
\v 5 Bika banlongo bamoma khan mu diambu di nzitusu wawu ;
\q1 ayi bayimbila mu khan mu zimbuka ziawu.
\q1 
\v 6 Bika minzitusu mi Nzambi miba mu miunu miawu
\q1 ayi sabala kidi meno mu zindambu zioso mu mioko miawu ;
\q1 
\v 7 mu diambu di vutula landi kuidi makanda
\q1 ayi mu vana batu thumbudulu ;
\q1 
\v 8 mu diambu di kanga mintinu miawu mu zisieni
\q1 ayi batu bawu banneni mu bisengo ;
\q1 
\v 9 mu diambu di dukisa nzengolo yoyi yisonama mu diambu diawu ;
\q1 wawu wawu nkembo wu banlongo bandi boso.
\q1 Luzitisa Yave.
\c 150
\cl Minkunga 150
\s1 Luzitisa Nzambi mu miziki
\q1 
\v 1 Luzitisa Yave,
\q1 Luzitisa Nzambi mu buangu kiandi kinlongo.
\q1 Lunzitisa mu diyilu diandi di lulendo.
\q1 
\v 2 Lunzitisa mu diambu di mavanga mandi ma lulendo ;
\q1 lunzitisa mu diambu di bunneni buandi bu kambulu ndilu.
\q1 
\v 3 Lunzitisa mu biyoko bi ntotukila mu tulumbeta,
\q1 Lunzitisa mu ngitala ayi mu Lila.
\q1 
\v 4 Lunzitisa mu ndungu ayi mu makinu ;
\q1 Lunzitisa mu bisiku bi minsinga ayi mu flute ;
\q1 
\v 5 Lunzitisa mu bisiku bidi banga zitapa ;
\q1 biobi bieti totula mbembo yingolo ;
\q1 Lunzitisa mu bisiku bidi banga zitapa,
\q1 biobi bilembo ningi.
\q1 
\v 6 Bika bibioso bilembo vumuna bizitisa Yave.
\q1 Luzitisa Yave.
