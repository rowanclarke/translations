\id BAK - Madak Bible [mmx] -Papua New Guinea 2011 (DBL 2015) 
\h Sam I Paase Mumu Ne Iesu 
\toc2 Sam I Paase Mumu Ne Iesu 
\toc1 Sam I Paase Mumu Ne Iesu 
\mt2 Levelinga Keneng At Lubuk Sam I Paase Mumu Ne Iesu  
\li1  \k Sam 2:6-9 Lixitkis orong naba nemen amisik. \xt Gu 13:33; Ib 1:5\xt*  
\li1  \k Sam 8:2,4-6 Laxamdak di emi asu mi ne Iesu. \xt Mt 21:15-16\xt* Iesu i ruuna lixitkis silok la lisisixam nunuan, la ni Lamgomgo at lempanga axap. \xt Ib 2:6-11\xt*  
\li1  \k Sam 16:8-10 Laxakatu kaxat amlong at Lanarong. \xt Gu 2:25-31; 13:25; 15:12-17\xt*  
\li1  \k Sam 22 Lanmet at laxaba. \xt Mt 27:35,39,46; Mk 15:20-24; Jo 19:23-24,28; Ib 2:12 \xt*  
\li1  \k Sam 24:1-4 Iesu ga rudum li lavatbung menemen. \xt Li 14:7\xt*  
\li1  \k Sam 34:20 At lanmet at ne Iesu, kopmen toxosi ren ga repit. \xt Jo 19:31-37\xt*  
\li1  \k Sam 35:11 Digak sok taba ne Iesu mi leveloklok kakapmek. \xt Mk 14:57\xt*  
\li1  \k Sam 40:6-10 Iesu ga raba lorooro ren ngan laplavang. \xt Ib 10:5-7\xt*  
\li1  \k Sam 41:9 Lentangas tino bok, (Judas) la neni bok ga raba rulu ne Iesu. \xt Lu 22:48\xt*  
\li1  \k Sam 45:2,6,7,17 Loklok manmanton la lixitkis orong teren noxo xap. \xt Ib 1:8-9\xt*  
\li1  \k Sam 68:18 Iesu gat pas uto vana at laxalibet. \xt Ep 4:8\xt*  
\li1  \k Sam 69:4,9,21 Goxopmen tavasuun at lebele ngatngas atdi saparap ne Iesu. \xt Mt 27:34,48; Jo 2:17; 15:25; Ro 15:3\xt*  
\li1  \k Sam 72:11,18 Iesu gak lok mo levempanga maraanu. \xt Mt 9:33.\xt* Neni nabam gomgonga ri limixin at legesa abin sangsangaun kobot (1000) levenmaares. \xt Li 11:15; 20:6\xt*  
\li1  \k Sam 89:4 Lixitkis orong teren naba nemen amisik...la noxo xap. \xt Lu 1:32-33,69; Gu 13:23,35-37\xt*  
\li1  \k Sam 91:11-12 Loklok tong pen at ne Iesu. \xt Mt 4:1-11; Lu 4:1-11\xt*  
\li1  \k Sam 102:25-27 Iesu ga rudum li lavatbung menemen mi laxalibet. Neni xopmen na lox ekun. \xt Ib 1:10-12\xt*  
\li1  \k Sam 110 Neni Leeme Silok la Loorong la Lamaasa Avolo la Laradi Rongtonga Linga. \xt Mt 22:44; Gu 2:33-35; Ib 5:6; 6:19–7:28\xt*  
\li1  \k Sam 118:22-23 Neni Luuat Kis. \xt Mt 21:42; Mk 12:10; Gu 4:11; 1 Pi 2:7\xt*  