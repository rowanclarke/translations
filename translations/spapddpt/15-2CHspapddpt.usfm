\c 21  
\s1 Reinado de Joram en Judá  
\p
\v 1 Josafat descansó \w con|strong="H5973"\w* sus antepasados y fue \w sepultado|strong="H6912"\w* \w en|strong="H5973"\w* la \w Ciudad|strong="H5892"\w* \w de|strong="H8478"\w* \w David|strong="H1732"\w*.  
\p \w Reinó|strong="H4427"\w* \w en|strong="H5973"\w* su \w lugar|strong="H8478"\w* su \w hijo|strong="H1121"\w* \w Joram|strong="H3088"\w*.  
\v 2 Tuvo como hermanos \w a|strong="H3068"\w* \w Azarías|strong="H5838"\w*, Jeiel, \w Zacarías|strong="H2148"\w*, \w Azarías|strong="H5838"\w*, Micael y Sefatías. \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Josafat, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*,  
\v 3 \w a|strong="H3068"\w* quienes \w su|strong="H1931"\w* padre \w dio|strong="H5414"\w* \w grandes|strong="H7227"\w* regalos \w de|strong="H3588"\w* \w plata|strong="H3701"\w*, \w oro|strong="H2091"\w* \w y|strong="H3588"\w* \w cosas|strong="H1992"\w* preciosas, \w así|strong="H3588"\w* \w como|strong="H3588"\w* \w ciudades|strong="H5892"\w* fortificadas \w en|strong="H5973"\w* \w Judá|strong="H3063"\w*. \w Pero|strong="H3588"\w* \w el|strong="H1931"\w* \w reino|strong="H4467"\w* \w se|strong="H1931"\w* \w lo|strong="H1931"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w Joram|strong="H3088"\w*, \w porque|strong="H3588"\w* \w él|strong="H1931"\w* \w era|strong="H1931"\w* \w su|strong="H1931"\w* \w primogénito|strong="H1060"\w*.  
\v 4 \w Joram|strong="H3088"\w* \w fue|strong="H1571"\w* elevado \w al|strong="H5921"\w* \w reino|strong="H4467"\w* \w de|strong="H5921"\w* su padre. \w Cuando|strong="H1571"\w* \w fue|strong="H1571"\w* fuerte, \w mató|strong="H2026"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus hermanos, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* algunos \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
