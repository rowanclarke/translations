\id 1CH - Biblica® Open Ndebele Contemporary Bible 
\h 1 ImiLando 
\toc1 Ugwalo Lwakuqala LwemiLando 
\toc2 1 ImiLando 
\toc3 1Lan 
\mt2 Ugwalo Lwakuqala 
\mt1 LwemiLando 
\c 1  
\s1 Kulondwa Imbali Kusukela Ku-Adamu Kusiya Ku-Abhrahama 
\s2 Emadodaneni KaNowa 
\li1  
\v 1 U-Adamu, uSethi, u-Enoshi, 
\li1  
\v 2 uKhenani, uMahalaleli, uJaredi, 
\li1  
\v 3 u-Enoki, uMethuzela, uLameki, 
\li1 uNowa. 
\b  
\li4  
\v 4 Amadodana kaNowa ayeyila: uShemu, uHamu loJafethi. 
\s2 AbakaJafethi 
\li1  
\v 5 Amadodana kaJafethi ayeyila: 
\li2 uGomeri, uMagogi, uMadayi, uJavani, uThubhali, uMesheki loThirasi. 
\li1  
\v 6 Amadodana kaGomeri ayeyila: 
\li2 u-Ashikhenazi, uRifathi kanye loThogarima. 
\li1  
\v 7 Amadodana kaJavani ayeyila: 
\li2 u-Elisha, uThashishi, uKhithimi loRodanimu. 
\s2 AbakaHamu: 
\li1  
\v 8 Amadodana kaHamu ayeyila: 
\li2 uKhushi, uMizirayimi, uPhuthi loKhenani. 
\li1  
\v 9 Amadodana kaKhushi ayeyila: 
\li2 uSebha, uHavila, uSabhitha, uRahama loSabhitheka. 
\li1 Amadodana kaRahama ayeyila: 
\li2 uShebha loDedani. 
\li1  
\v 10 UKhushi wayenguyise 
\li2 kaNimrodi, owakhula waba liqhawe elilamandla emhlabeni. 
\li1  
\v 11 UMizirayimi wayenguyise 
\li2 wamaLudi, ama-Anami, amaLehabhi, amaNafithuhi,  
\v 12 amaPhathrosi, lamaKhasiluhi (okwadabuka khona amaFilistiya) lamaKhafithori. 
\li1  
\v 13 UKhenani wayenguyise 
\li2 kaSidoni izibulo lakhe, amaHithi,  
\v 14 amaJebusi, ama-Amori, amaGigashi,  
\v 15 amaHivi, ama-Arikhi, amaSini,  
\v 16 ama-Avadi, amaZemari kanye lamaHamathi. 
\s2 AbakaSemi 
\li1  
\v 17 Amadodana kaShemu ayeyila: 
\li2 u-Elamu, u-Ashuri, u-Afazadi, uLudi lo-Aramu. 
\li1 Amadodana ka-Aramu ayeyila: 
\li2 u-Uzi, uHuli, uGetha loMesheki. 
\li1  
\v 18 U-Afazadi wayenguyise kaShela, 
\li2 uShela wazala u-Ebha. 
\li1  
\v 19 Amadodana amabili ayezalwa ngu-Ebha ayeyila: 
\li2 Omunye wayenguPhelegi, ngoba ngezinsuku zakhe umhlaba wawudabuke phakathi; umfowabo kwakuthiwa nguJokithani. 
\li1  
\v 20 UJokithani wayenguyise 
\li2 ka-Alimodadi, uShelefi, uHazarimavethi, uJera,  
\v 21 uHadoramu, u-Uzali, uDikila,  
\v 22 u-Obhali, u-Abhimayeli, uShebha,  
\v 23 u-Ofiri, uHavila kanye loJobhabhi. Bonke laba babengamadodana kaJokithani. 
\b  
\li1  
\v 24 UShemu, u-Afazadi uShela, 
\li1  
\v 25 u-Ebha, uPhelegi, uRewu 
\li1  
\v 26 uSerugi, uNahori, uThera 
\li1  
\v 27 lo-Abhrama (u-Abhrahama). 
\s1 Imuli Ka-Abhrahama 
\li4  
\v 28 Amadodana ka-Abhrahama ayeyila: u-Isaka lo-Ishumayeli. 
\s2 Abenzalo KaHagari 
\li1  
\v 29 Laba babeyinzalo yabo: 
\li2 uNebhayothi izibulo lika-Ishumayeli, uKhedari, u-Adibheli, uMibhisamu,  
\v 30 uMishima, uDuma, uMasa, uHadadi, uThema,  
\v 31 uJethuri, uNafishi kanye loKhedema. 
\li4 La yiwo ayengamadodana ka-Ishumayeli. 
\s2 Abenzalo KaKhethura 
\li1  
\v 32 Amadodana azalwa nguKhethura, umfazi ka-Abhrahama oweceleni, ayeyila: 
\li2 uZimirani, uJokishani, uMedani, uMidiyani, u-Ishibhaki loShuwa. 
\li1 Amadodana kaJokishani ayeyila: 
\li2 uShebha loDedani. 
\li1  
\v 33 Amadodana kaMidiyani ayeyila: 
\li2 u-Efa, u-Eferi, uHanokhi, u-Abhida lo-Elida. 
\li4 Bonke laba babeyizizukulwane zikaKhethura. 
\s2 Abenzalo KaSara 
\li4  
\v 34 U-Abhrahama wayenguyise ka-Isaka. 
\li1 Amadodana ka-Isaka ayeyila: 
\li2 u-Esawu lo-Israyeli. 
\s1 Amadodana Ka-Esawu 
\li1  
\v 35 Amadodana ka-Esawu ayeyila: 
\li2 u-Elifazi, uRuweli, uJewushi, uJalamu loKhora. 
\li1  
\v 36 Amadodana ka-Elifazi ayeyila: 
\li2 uThemani, u-Omari, uZefi, uGathamu loKhenazi; 
\li2 ekaThimina kungu-Amaleki. 
\li1  
\v 37 Amadodana kaRuweli ayeyila: 
\li2 uNahathi, uZera, uShama loMiza. 
\s2 Abantu BeSeyiri E-Edomi 
\li1  
\v 38 Amadodana kaSeyiri ayeyila: 
\li2 uLothani, uShobhali, uZibhiyoni, u-Ana, uDishoni, u-Ezeri loDishani. 
\li1  
\v 39 Amadodana kaLothani ayeyila: 
\li2 uHori loHomami. UThimina wayengudadewabo kaLothani. 
\li1  
\v 40 Amadodana kaShobhali ayeyila: 
\li2 u-Alivani, uManahathi, u-Ebhali, uShefo lo-Onami. 
\li1 Amadodana kaZibhiyoni ayeyila: 
\li2 u-Ayiya lo-Ana. 
\li1  
\v 41 Indodana ka-Ana yayingu: 
\li2 uDishoni. 
\li1 Amadodana kaDishoni ayeyila: 
\li2 uHemirani, u-Eshibhani, u-Ithirani loKherani. 
\li1  
\v 42 Amadodana ka-Ezeri ayeyila: 
\li2 uBhilihani, uZavani lo-Akhani. 
\li1 Amadodana kaDishoni ayeyila: 
\li2 u-Uzi lo-Arani. 
\s2 Ababusi Be-Edomi 
\li4  
\v 43 La ayengamakhosi abusa e-Edomi kungakabusi inkosi yako-Israyeli: 
\li1 uBhela indodana kaBheyori, idolobho lakhe lalibizwa ngokuthi yiDinihabha. 
\li1  
\v 44 UBhela esefile, uJobhabhi indodana kaZera waseBhozira wathatha umbuso waba yinkosi. 
\li1  
\v 45 UJobhabhi esefile, uHushamu waselizweni lamaThemani wathatha umbuso waba yinkosi. 
\li1  
\v 46 UHushamu esefile, uHadadi indodana kaBhedadi owanqoba uMidiyani elizweni laseMowabi, wathatha umbuso waba yinkosi. Idolobho lakhe lalibizwa ngokuthi yi-Avithi. 
\li1  
\v 47 UHadadi esefile, uSamila waseMasirekha wathatha umbuso waba yinkosi. 
\li1  
\v 48 USamila esefile, uShawuli waseRehobhothi phezu komfula wathatha umbuso waba yinkosi. 
\li1  
\v 49 UShawuli esefile, uBhali-Hanani indodana ka-Akhibhori wathatha umbuso waba yinkosi. 
\li1  
\v 50 UBhali-Hanani esefile, uHadadi wathatha umbuso waba yinkosi. Idolobho lakhe labizwa ngokuthi yiPawu, njalo ibizo lomkakhe lalinguMehethabheli indodakazi kaMathiredi, indodakazi kaMe-Zahabhi.  
\v 51 UHadadi laye wafa. 
\b  
\li4 Izinduna zase-Edomi kwakuyilezi: 
\li1 uThimina, u-Aliva, uJethethi,  
\v 52 u-Oholibhama, u-Ela, uPhinoni,  
\v 53 uKhenazi, uThemani, uMibhizari,  
\v 54 uMagidiyeli lo-Iramu. 
\li4 Lezi kwakuzinduna ze-Edomi. 
\c 2  
\s1 Amadodana Ka-Israyeli 
\li4  
\v 1 Amadodana ka-Israyeli ayeyila: uRubheni, uSimiyoni, uLevi, uJuda, u-Isakhari, uZebhuluni,  
\v 2 uDani, uJosefa, uBhenjamini, uNafithali, uGadi lo-Asheri. 
\s1 AbakaJuda 
\s2 Emadodaneni KaHezironi 
\li1  
\v 3 Amadodana kaJuda yila: 
\li2 ngu-Eri, lo-Onani kanye loShela. Laba bobathathu wabazala lowesifazane ongumKhenani, indodakazi kaShuwa. 
\li2 U-Eri, izibulo likaJuda, wayeyisigangi phambi \nd kukaThixo\nd*, ngalokho \nd uThixo\nd* wambulala. 
\li2  
\v 4 UThamari, umalukazana kaJuda wamzalela uPherezi loZera. 
\li4 UJuda wayelamadodana amahlanu. 
\b  
\li1  
\v 5 Amadodana kaPherezi yila: 
\li2 nguHezironi loHamuli. 
\li1  
\v 6 Amadodana kaZera yila: 
\li2 nguZimri, lo-Ethani, loHemani, loKhalikholi kanye loDarida. Bonke babebahlanu. 
\li1  
\v 7 Indodana kaKhami yile: 
\li2 ngu-Akhari, owaletha inhlupheko ko-Israyeli ngesiphambeko asenza ngalokho okungcwelisiweyo. 
\li1  
\v 8 Indodana ka-Ethani yile: 
\li2 ngu-Azariya. 
\li1  
\v 9 Amadodana azalwa nguHezironi yila: 
\li2 nguJerameli, loRamu kanye loKhalebi. 
\s2 Kusukela KuRama Indodana KaHezironi 
\li1  
\v 10 URamu wayenguyise ka-Aminadabi, 
\li1 njalo u-Aminadabi enguyise kaNahashoni, umkhokheli wabantu bakoJuda. 
\li1  
\v 11 UNahashoni wayenguyise kaSalimoni, 
\li1 uSalimoni enguyise kaBhowazi. 
\li1  
\v 12 UBhowazi enguyise ka-Obhedi, 
\li1 u-Obhedi enguyise kaJese. 
\b  
\li1  
\v 13 UJese wayenguyise 
\li2 ka-Eliyabi izibulo lakhe; indodana yesibili kungu-Abhinadabi, 
\li2 eyesithathu kunguShimeya,  
\v 14 eyesine kunguNethaneli, 
\li2 eyesihlanu kunguRadayi,  
\v 15 eyesithupha kungu-Ozemu, 
\li2 eyesikhombisa kunguDavida. 
\li2  
\v 16 Odadewabo kwakunguZeruya lo-Abhigeli. 
\li3 Amadodana amathathu kaZeruya kwakungu-Abhishayi, loJowabi kanye lo-Asaheli. 
\li3  
\v 17 U-Abhigeli wayengunina ka-Amasa, oloyise okwakuthiwa nguJetha umʼIshumayeli. 
\s2 UKhalebi Indodana KaHezironi 
\li1  
\v 18 UKhalebi indodana kaHezironi wayelabantwana abazala kumkakhe u-Azubha (lakuJeriyothi). Amadodana ka-Azubha ayeyila: 
\li2 nguJesheri, loShobhabi, kanye lo-Adoni. 
\li1  
\v 19 Ekufeni kuka-Azubha, uKhalebi wathatha u-Efrathi, owamzalela uHuri. 
\li2  
\v 20 UHuri wayenguyise ka-Uri, njalo u-Uri enguyise kaBhezaleli. 
\b  
\li1  
\v 21 Muva, uHezironi wembatha lendodakazi kaMakhiri uyise kaGiliyadi (ayemthethe eseleminyaka engamatshumi ayisithupha ubudala bakhe), yena wamzalela uSegubi. 
\li2  
\v 22 USegubi wayenguyise kaJayiri, owayephethe imizi engamatshumi amabili lantathu eGiliyadi. 
\li2  
\v 23 (Kodwa uGeshuri lo-Aramu bathumba iHavothi-Jayiri, kanye leKhenathi lezindawana eziyimizana eseduzane, imizi engamatshumi ayisithupha.) 
\li4 Bonke laba babeyisizukulwane sikaMakhiri uyise kaGiliyadi. 
\li1  
\v 24 Ngemva kokufa kukaHezironi eKhalebi-Efratha, u-Abhija umkaHezironi wamzalela u-Ashuri uyise kaThekhowa. 
\s2 UJerameli Indodana KaHezironi 
\li1  
\v 25 Amadodana kaJerameli izibulo likaHezironi yila: 
\li2 nguRamu izibulo lakhe, loBhuna, lo-Oreni, lo-Ozemu kanye lo-Ahija.  
\v 26 UJerameli wayelomunye umfazi owayethiwa ngu-Athara unina ka-Onami. 
\li1  
\v 27 Amadodana kaRamu izibulo likaJerameli yila: 
\li2 nguMazi, loJamini kanye lo-Ekheri. 
\li1  
\v 28 Amadodana ka-Onami yila: 
\li2 nguShamayi loJada. 
\li1 Amadodana kaShamayi yila: 
\li2 nguNadabi lo-Abhishuri.  
\v 29 Umka-Abhishuri kwakungu-Abhihayili, owamzalela u-Ahibhani loMolidi. 
\li1  
\v 30 Amadodana kaNadabi yila: 
\li2 nguSeledi lo-Aphayimi. USeledi wafa engelabantwana. 
\li1  
\v 31 Indodana ka-Aphayimi yile: 
\li2 ngu-Ishi, uyise kaSheshani. USheshani wayenguyise ka-Ahilayi. 
\li1  
\v 32 Amadodana kaJada, umfowabo kaShamayi yila: 
\li2 nguJetha loJonathani. UJetha wafa engelabantwana. 
\li1  
\v 33 Amadodana kaJonathani yila: 
\li2 nguPhelethi loZaza. 
\li4 Laba babeyinzalo kaJerameli. 
\b  
\li1  
\v 34 USheshani wayengelawo amadodana, wayelamadodakazi wodwa. 
\li2 Wayelesisebenzi saseGibhithe esasithiwa nguJariha.  
\v 35 USheshani wendisela isisebenzi sakhe lesi esinguJariha, indodakazi yakhe eyamzalela u-Athayi. 
\li1  
\v 36 U-Athayi wayenguyise kaNathani, 
\li1 uNathani enguyise kaZabhadi, 
\li1  
\v 37 uZabhadi enguyise ka-Efilali, 
\li1 u-Efilali enguyise ka-Obhedi, 
\li1  
\v 38 u-Obhedi enguyise kaJehu, 
\li1 uJehu enguyise ka-Azariya, 
\li1  
\v 39 u-Azariya enguyise kaHelezi, 
\li1 uHelezi enguyise ka-Eleyasa, 
\li1  
\v 40 u-Eleyasa enguyise kaSisimayi, 
\li1 uSisimayi enguyise kaShalumi, 
\li1  
\v 41 uShalumi enguyise kaJekhamiya, 
\li1 uJekhamiya enguyise ka-Elishama. 
\s2 Abosendo LukaKhalebi 
\li1  
\v 42 Amadodana kaKhalebi umfowabo kaJerameli yila: 
\li2 uMesha izibulo lakhe, onguyise kaZifi, 
\li2 lendodana yakhe uMaresha, uyise kaHebhroni. 
\li1  
\v 43 Amadodana kaHebhroni yila: 
\li2 nguKhora, loThaphuwa, loRekhemu loShema. 
\li1  
\v 44 UShema wayenguyise kaRahama, 
\li2 uRahama yena enguyise kaJokheyama. 
\li1 URekhemu wayenguyise kaShamayi. 
\li1  
\v 45 Indodana kaShamayi kunguMawoni, 
\li2 uMawoni wayenguyise kaBhethi Zuri. 
\li1  
\v 46 Umfazi weceleni kaKhalebi u-Efa wayengunina 
\li2 kaHarani, loMoza kanye loGazezi. 
\li2 UHarani wayenguyise kaGazezi. 
\li1  
\v 47 Amadodana kaJahidayi yila: 
\li2 nguRegemi, loJothamu, loGeshani, loPhelethi, lo-Efa kanye loShafi. 
\li1  
\v 48 UMahakha umfazi weceleni kaKhalebi wayengunina 
\li2 kaShebheri loThirihana. 
\li2  
\v 49 Nguye njalo owazala uShafi uyise kaMadimana kanye 
\li2 loSheva uyise kaMakhibhena loGibhiya. 
\li1 Indodakazi kaKhalebi kwakungu-Akhisa. 
\li4  
\v 50 Yibo laba abenzalo kaKhalebi. 
\b  
\li1 Amadodana kaHuri izibulo lika-Efrathi yila: 
\li2 nguShobhali uyise kaKhiriyathi-Jeyarimi,  
\v 51 loSalima uyise kaBhethilehema, loHarefi uyise kaBhethi-Gaderi. 
\li1  
\v 52 Inzalo kaShobhali uyise kaKhiriyathi-Jeyarimi yile: 
\li2 nguHaro, ingxenye yamaManahathi,  
\v 53 labosendo lukaKhiriyathi-Jeyarimi kungama-Ithira lamaPhuthi lamaShumathi lamaMishirayi. Kulapho okwakudabuka khona amaZorathi lama-Eshithawoli. 
\li1  
\v 54 Abenzalo kaSalima yilaba: 
\li2 nguBhethilehema, umNethofa, u-Athirothi-Bhethi-Jowabi, ingxenye yamaManahathi, amaZori,  
\v 55 losendo lwabalobi ababehlala eJabhezi: AmaThirathi lamaShimeya lamaSukhathi. Laba babengamaKheni beyinzalo kaHamathi ukhokho wamaRekhabi. 
\c 3  
\s2 Amadodana KaDavida 
\li4  
\v 1 Nanka amadodana kaDavida awazala eHebhroni: 
\b  
\li1 Izibulo lakhe lalingu-Amnoni indodana ka-Ahinowama owaseJezerili; 
\li1 owesibili, uDanyeli indodana ka-Abhigeli waseKhameli; 
\li1  
\v 2 owesithathu, ngu-Abhisalomu indodana kaMahakha indodakazi kaThalimayi inkosi yaseGeshuri; 
\li1 owesine, u-Adonija indodana kaHagithi; 
\li1  
\v 3 owesihlanu, uShefathiya indodana ka-Abhithali; 
\li1 owesithupha, u-Ithireyamu amzuza ku-Egila, umkakhe. 
\b  
\li4  
\v 4 Abayisithupha laba uDavida wabazalela eHebhroni, lapho abusa khona okweminyaka eyisikhombisa lezinyanga eziyisithupha. 
\b  
\b  
\li4 UDavida wabusa eJerusalema okweminyaka engamatshumi amathathu lemithathu,  
\v 5 njalo la yiwo amadodana awazalela khona: 
\b  
\li1 uShamuwa, uShobabi, uNathani loSolomoni. Amadodana amane la wawazala loBhathishebha indodakazi ka-Amiyeli. 
\li1  
\v 6 Njalo kwaba lo-Ibhari, u-Elishama, u-Elifelethi,  
\v 7 uNoga, uNefegi, uJafiya,  
\v 8 u-Elishama, u-Eliyada kanye lo-Elifelethi, beyisificamunwemunye bonke. 
\b  
\li4  
\v 9 Bonke laba babengamadodana kaDavida, ngaphandle kwamadodana akhe awazala labafazi bakhe beceleni. Udadewabo wamadodana la wayenguThamari. 
\s2 Amakhosi AkoJuda 
\li1  
\v 10 Indodana kaSolomoni kwakunguRehobhowami, 
\li1 indodana yakhe kungu-Abhija, 
\li1 indodana yakhe kungu-Asa, 
\li1 indodana yakhe kunguJehoshafathi, 
\li1  
\v 11 indodana yakhe kunguJehoramu, 
\li1 indodana yakhe kungu-Ahaziya, 
\li1 indodana yakhe kunguJowashi, 
\li1  
\v 12 indodana yakhe kungu-Amaziya, 
\li1 indodana yakhe kungu-Azariya, 
\li1 indodana yakhe kunguJothamu, 
\li1  
\v 13 indodana yakhe kungu-Ahazi, 
\li1 indodana yakhe kunguHezekhiya, 
\li1 indodana yakhe kunguManase, 
\li1  
\v 14 indodana yakhe kungu-Amoni, 
\li1 indodana yakhe kunguJosiya. 
\li1  
\v 15 Amadodana kaJosiya yila: 
\li2 nguJohanani izibulo, 
\li2 uJehoyakhimi indodana yesibili, 
\li2 uZedekhiya eyesithathu, 
\li2 uShalumi eyesine. 
\li1  
\v 16 Abasala behlala esikhundleni sikaJehoyakhimi yilaba: 
\li2 nguJekhoniya indodana yakhe 
\li2 loZedekhiya. 
\s2 Usendo Lwesikhosini Emva Kokuthunjwa 
\li1  
\v 17 Abosendo lukaJekhoniya owayethunjiwe yilaba: 
\li2 uSheyalithiyeli indodana yakhe,  
\v 18 uMalikhiramu, loPhedaya, loShenazari, loJekhamiya, loHoshama, kanye loNedabhiya. 
\li1  
\v 19 Amadodana kaPhedaya yila: 
\li2 nguZerubhabheli loShimeyi. 
\li1 Amadodana kaZerubhabheli yila: 
\li2 nguMeshulami loHananiya. UShelomithi engudadewabo.  
\v 20 Babekhona njalo abanye abahlanu: uHashubha, u-Oheli, uBherekhiya, uHasadiya, loJushabi-Hesedi. 
\li1  
\v 21 Abosendo lukaHananiya yilaba: 
\li2 nguPhelathiya loJeshaya, kanye lamadodana kaRefaya, ka-Anani, ka-Obhadaya kanye lokaShekhaniya. 
\li1  
\v 22 Abosendo lukaShekhaniya yilaba: 
\li2 nguShemaya lamadodana akhe: uHathushi, lo-Igali, loBhariya, loNeyariya kanye loShafathi, beyisithupha. 
\li1  
\v 23 Amadodana kaNeyariya yila: 
\li2 ngu-Eliyonayi, loHezekhiya, lo-Azirikhamu, bebathathu. 
\li1  
\v 24 Amadodana ka-Eliyonayi yila: 
\li2 nguHodaviya, lo-Eliyashibi, loPhelaya, lo-Akhubi, loJohanani, loDelaya kanye lo-Anani, beyisikhombisa. 
\c 4  
\s2 Abanye Abosendo LukaJuda 
\li1  
\v 1 Abosendo lukaJuda kuyilaba: 
\li2 NguPherezi, loHezironi, loKhami, loHuri loShobhali. 
\li1  
\v 2 UReyaya indodana kaShobhali wayenguyise kaJahathi, uJahathi onguyise ka-Ahumayi kanye loLahadi. Laba babengabosendo lwamaZorathi. 
\li1  
\v 3 La ayengamadodana ka-Ethamu: 
\li2 uJezerili, lo-Ishima kanye lo-Idibhashi. Udadewabo kwakuthiwa nguHazeleliphoni.  
\v 4 UPhenuweli wayenguyise kaGedori, lo-Ezeri uyise kaHusha. 
\li1 Laba kungabosendo lukaHuri, izibulo lika-Efrathi uyise kaBhethilehema. 
\li1  
\v 5 U-Ashuri uyise kaThekhowa wayelabafazi ababili, uHela loNara. 
\li1  
\v 6 UNahara wamzalela u-Ahuzami, loHeferi, loThemeni kanye loHahashithari. Laba kwakungabosendo lukaNara. 
\li1  
\v 7 Amadodana kaHela yila: 
\li2 nguZerethi, loZohari, lo-Ethinani,  
\v 8 loKhozi owayenguyise ka-Anubi loHazobhebha kanye labosendo luka-Ahareheli indodana kaHarumi. 
\b  
\p  
\v 9 UJabhezi wayelodumo kulabafowabo. Unina wayemuphe lelibizo lokuthi Jabhezi, ngoba esithi “Ngamzala kabuhlungu.”  
\v 10 UJabhezi wakhuleka kuNkulunkulu ka-Israyeli wathi: “Sengathi ungangibusisa uqhelise ilizwe lami! Isandla sakho kasibe lami, ungivikele ebubini, ngingehlelwa yibuhlungu.” UNkulunkulu wamnika lokho ayekucela. 
\b  
\li1  
\v 11 UKhelubi, umfowabo kaShuha, wayenguyise kaMehiri, owayenguyise ka-Eshithoni.  
\v 12 U-Eshithoni wayenguyise kaBhethi-Rafa, loPhaseya kanye loThehina uyise ka-Iri Nahashi. Laba babengabantu bakaRekha. 
\b  
\li1  
\v 13 Amadodana kaKhenazi yila: 
\li2 ngu-Othiniyeli loSeraya. 
\li1 Amadodana ka-Othiniyeli yila: 
\li2 nguHathathi loMeyonothayi.  
\v 14 UMeyonathayi wayenguyise ka-Ofira. 
\li1 USeraya wayenguyise kaJowabi, 
\li2 owayengukhokho wesizwe samaGe-Harashimi. Babizwa ngalelibizo ngoba babezingcitshi. 
\li1  
\v 15 Amadodana kaKhalebi indodana kaJefune yila: 
\li2 ngu-Iru, lo-Ela kanye loNamu. 
\li1 Indodana ka-Ela yile: 
\li2 nguKhenazi. 
\li1  
\v 16 Amadodana kaJehaleleli yila: 
\li2 nguZifi, loZifa, loThiriya kanye lo-Asareli. 
\li1  
\v 17 Amadodana ka-Ezra yila: 
\li2 nguJetha, loMeredi, lo-Eferi kanye loJaloni. 
\li1 Omunye wabafazi bakaMeredi wazala uMiriyemu, loShamayi kanye lo-Ishibha uyise ka-Eshithemowa.  
\v 18 Laba kwakungabantwana bakaBhithiya indodakazi kaFaro, eyayendele kuMeredi. 
\li1 Umkakhe ongumJudakazi wamzalela uJeredi uyise kaGedori, uHebheri uyise kaSokho, loJekuthiweli uyise kaZanowa. 
\li1  
\v 19 Amadodana omkaHodiya, udadewabo kaNahama, 
\li2 uyise kaKheyila owaseGami, lo-Eshithemowa waseMahakhathi. 
\li1  
\v 20 Amadodana kaShimoni yila: 
\li2 ngu-Amnoni, loRina, loBheni-Hanani kanye loThiloni. 
\li1 Abosendo luka-Ishi yilaba: 
\li2 nguZohethi loBheni-Zohethi. 
\li1  
\v 21 Amadodana kaShela indodana kaJuda yila: 
\li2 ngu-Eri uyise kaLekha, loLada uyise kaMaresha labantwana babeluki bamalembu amahle eBhethi-Ashibheya. 
\li2  
\v 22 UJokhimu, lamadoda aseKhozeba, uJowashi loSarafi, owabusa amaMowabi loJashubi Lehemu. (Lokhu kutholakala emibhalweni yasendulo).  
\v 23 Laba kwakungababumbi ababehlala eNethayimi leGedera; behlala khona besebenzela inkosi. 
\s1 USimiyoni 
\li1  
\v 24 Abosendo lukaSimiyoni yilaba: 
\li2 nguNemuweli, loJamini, loJaribhi, loZera kanye loShawuli; 
\li2  
\v 25 uShalumi wayeyindodana kaShawuli, uMibhisamu indodana yakhe loMishima indodana yakhe. 
\li1  
\v 26 Abosendo lukaMishima yilaba: 
\li2 nguHamuweli indodana yakhe, loZakhuri indodana yakhe loShimeyi indodana yakhe. 
\b  
\p  
\v 27 UShimeyi wayelamadodana alitshumi lesithupha lamadodakazi ayisithupha, kodwa abafowabo babengelabantwana abanengi, ngakho usendo lwabo lonke aluzanga lwande njengabantu bakaJuda.  
\v 28 Babehlala eBherishebha, eMolada, eHazari-Shuwali,  
\v 29 eBhiliha, e-Ezema, eTholadi,  
\v 30 eBhethuweli, eHoma, eZikhilagi,  
\v 31 eBhethi-Makhabhothi, eHazari Susimi, eBhethi-Bhiri laseShaharayimu. Yiyo eyayiyimizi yabo kwaze kwabusa uDavida.  
\v 32 Imizana eyayilapho kwakuyi-Ethamu, i-Ayini, iRimoni, iThokheni le-Ashani, imizi emihlanu  
\v 33 layo yonke imizana eyayiseduzane lalimizi kuze kuyefika eBhalathi. Lezi yizo izindawo abahlaliswa khona. 
\b  
\li4 Bagcina imibhalo yosendo lwabo. 
\b  
\li1  
\v 34 UMeshobabi loJamuleki, 
\li1 loJosha indodana ka-Amaziya  
\v 35 loJoweli, 
\li1 loJehu indodana kaJoshibhiya, indodana kaSeraya, indodana ka-Asiyeli 
\li1  
\v 36 kanye lo-Eliyonayi, loJakhobha, loJeshohaya, 
\li1 lo-Asaya, lo-Adiyeli, loJesimiyeli, loBhenaya, 
\li1  
\v 37 kanye loZiza indodana kaShifi, indodana ka-Aloni, indodana kaJedaya, indodana kaShimiri, indodana kaShemaya. 
\b  
\li4  
\v 38 Amadoda aqanjiweyo ngamabizo ngaphezulu ayengabakhokheli bosendo lwakwabo. 
\b  
\p Izimuli zabo zanda kakhulu,  
\v 39 zaqhela zayakwakha langaphandle kweGedori okuya ngempumalanga yesihotsha bedinga amadlelo emihlambi yabo.  
\v 40 Bathola umhlaba ovundileyo olamadlelo amahle, obanzi ophilileyo njalo uthule. Kwakuke kwahlala amanye amaHamu khonapho. 
\p  
\v 41 Amadoda alamabizo abhaliweyo afika ngezinsuku zikaHezekhiya inkosi yakoJuda. Bahlasela amaHamu emizini yawo kanye lamaMewuni ayelapho bawabhuqa du, njengoba kubonakala lalamuhla. Basebezihlalela besakha khonapho, ngoba kwakulamadlelo emihlambi yabo.  
\v 42 Abangamakhulu amahlanu alaba abakaSimiyoni, bekhokhelwa nguPhelathiya, uNeyariya loRefaya lo-Uziyeli amadodana ka-Ishi, bahlasela ilizwe lamaqaqa laseSeyiri.  
\v 43 Babulala ama-Amaleki ayephunyukile asala, njalo sebehlale kulindawo kuze kube lamuhla. 
\c 5  
\s1 URubheni 
\li4  
\v 1 Amadodana kaRubheni izibulo lika-Israyeli (wayelizibulo, kodwa kwathi esengcolise umbheda kayise owomtshado, amalungelo akhe njengezibulo aphiwa amadodana kaJosefa indodana ka-Israyeli, ngakho kasalotshwanga emibhalweni yosendo njengelungelo lokuzalwa kwakhe,  
\v 2 lanxa uJuda wayelamandla amakhulu kulabo bonke abafowabo njalo enguye owazala umbusi, ilungelo lobuzibulo laya kuJosefa).  
\v 3 Amadodana kaRubheni izibulo lika-Israyeli ayeyila: 
\b  
\li2 nguHanokhi, loPhalu, loHezironi kanye loKhami. 
\li1  
\v 4 Abenzalo kaJoweli yilaba: 
\li2 nguShemaya indodana yakhe, loGogi indodana yakhe, 
\li2 loShimeyi indodana yakhe,  
\v 5 loMikha indodana yakhe, 
\li2 loReyaya indodana yakhe, loBhali indodana yakhe, 
\li2  
\v 6 kanye loBhera indodana yakhe, lowo uThigilathi-Philesa inkosi yase-Asiriya eyamthumba yamusa ezizweni. UBhera wayengumkhokheli wabakoRubheni. 
\li1  
\v 7 Izihlobo zabo ngosendo lwabo, njengokulotshwe emibhalweni yosendo yilezi: 
\li2 nguJeyiyeli induna, loZakhariya, kanye  
\v 8 loBhela indodana ka-Azazi, indodana kaShema, indodana kaJoweli. 
\b  
\p Bakha bahlala emangweni osuka e-Aroweri kusiya eNebho laseBhali-Meyoni.  
\v 9 Empumalanga babehlezi emangweni ofika emaphethelweni enkangala etshaya khonale eMfuleni uYufrathe, ngoba izifuyo zabo zasezandile eGiliyadi. 
\p  
\v 10 Ngezinsuku zokubusa kukaSawuli balwa impi lamaHagari; bawanqoba basebehlala emizaneni yawo emangweni wonke ongempumalanga yeGiliyadi. 
\s1 UGadi 
\li4  
\v 11 AbakaGadi babehlala phansi kwabo eBhashani, kuze kuyefika eSalekha: 
\b  
\li1  
\v 12 UJoweli wayeyinduna, uShafamu emlandela, besekusiza uJanayi loShafathi, ngaseBhashani. 
\li1  
\v 13 Izihlobo zabo, ngokuzalana kwabo, yilezi: 
\li2 nguMikhayeli, loMeshulami, loShebha, loJorayi, loJakhani, loZiya kanye lo-Ebha, beyisikhombisa sebendawonye. 
\li2  
\v 14 Laba babengamadodana ka-Abhihayili indodana kaHuri, indodana kaJarowa, indodana kaGiliyadi, indodana kaMikhayeli, indodana kaJeshishayi, indodana kaJahido, indodana kaBhuzi. 
\li2  
\v 15 U-Ahi indodana ka-Abhidiyeli, indodana kaGuni, wayeyinhloko yemuli yakwabo. 
\b  
\p  
\v 16 AbakaGadi babehlala eGiliyadi, eBhashani lemizaneni yakhona, kanye lasemadlelweni aseSharoni kuze kuyefika emaphethelweni awo. 
\p  
\v 17 Bonke laba balotshwa emibhalweni yosendo ngezinsuku zokubusa kukaJothamu inkosi yakoJuda loJerobhowamu inkosi yako-Israyeli. 
\b  
\p  
\v 18 AbakoRubheni, labakoGadi lengxenye yesizwana sakoManase babelamadoda ayeselungele ukubuthwa azinkulungwane ezingamatshumi amane lane lamakhulu ayisikhombisa lamatshumi ayisithupha (44,760) amadoda ayeseqwahele esenelisa ukuphatha ihawu ahlome ngenkemba, atshoke ngemitshoko, ayesevele afundela ukulwa empini.  
\v 19 Bahlasela uHagari loJethuri loNafishi loNodabi.  
\v 20 Bahlonyulelwa ekulweni kwabo labo, njalo uNkulunkulu wanikela uHagari labanye bakhe ezandleni zabo, ngoba bakhuleka kuNkulunkulu empini. Wayiphendula imikhuleko yabo, ngoba bamethemba.  
\v 21 Bathumba izifuyo zakoHagiri ezibalisa amakamela azinkulungwane ezingamatshumi amahlanu, izimvu eziyizinkulungwane ezingamakhulu amabili lamatshumi amahlanu labobabhemi abazinkulungwane ezimbili. Bathumba njalo abantu abazinkulungwane ezilikhulu,  
\v 22 abanye abanengi babulawa, ngoba le kwakuyimpi kaNkulunkulu. Bona bahlala kulelolizwe kwaze kwaba yisikhathi bethunjwa. 
\s1 Ingxenye Yesizwana SikaManase 
\p  
\v 23 Abantu ababeyingxenye yesizwana sikaManase babebanengi; bahlala elizweni kusukela eBhashani kusiya eBhali-Hemoni, kusitsho iSeniri (iNtaba yaseHemoni). 
\p  
\v 24 Laba yibo ababezinhloko zezimuli: u-Eferi, lo-Ishi, lo-Eliyeli, lo-Aziriyeli, loJeremiya, loHodaviya, kanye loJahidiyeli. Babengamadoda empi alezibindi, amadoda adumileyo, njalo bezinhloko zezimuli zabo.  
\v 25 Kodwa bona babengathembekanga kuNkulunkulu waboyise basebekhonza onkulunkulu bezizwe uNkulunkulu wabo ababhubhisa kulawomazwe bengakahlali khona.  
\v 26 Ngakho uNkulunkulu ka-Israyeli wadunga umoya kaPhuli inkosi yase-Asiriya (okuyikuthi, Thigilathi-Philesa inkosi yase-Asiriya), owathumba abakoRubheni, labakoGadi kanye lengxenye yesizwana sikaManase. Wabathatha wabasa eHala, leHabhori, leHara lasemfuleni uGozani, lapho abakhona lalamuhla. 
\c 6  
\s1 ULevi 
\li1  
\v 1 Amadodana kaLevi yila: 
\li2 nguGeshoni, loKhohathi, kanye loMerari. 
\li1  
\v 2 Amadodana kaKhohathi yila: 
\li2 ngu-Amramu, lo-Izihari, loHebhroni kanye lo-Uziyeli. 
\li1  
\v 3 Abantwana baka-Amramu yilaba: 
\li2 ngu-Aroni, loMosi kanye loMiriyemu. 
\li1 Amadodana ka-Aroni yila: 
\li2 nguNadabi, lo-Abhihu lo-Eliyazari lo-Ithamari. 
\li2  
\v 4 U-Eliyazari wayenguyise kaFinehasi, 
\li2 uFinehasi enguyise ka-Abhishuwa, 
\li2  
\v 5 u-Abhishuwa enguyise kaBhukhi, 
\li2 uBhukhi enguyise ka-Uzi, 
\li2  
\v 6 u-Uzi enguyise kaZerahiya, 
\li2 uZerahiya enguyise kaMerayothi, 
\li2  
\v 7 uMerayothi enguyise ka-Amariya, 
\li2 u-Amariya enguyise ka-Ahithubi, 
\li2  
\v 8 u-Ahithubi enguyise kaZadokhi, 
\li2 uZadokhi enguyise ka-Ahimazi, 
\li2  
\v 9 u-Ahimazi enguyise ka-Azariya, 
\li2 u-Azariya enguyise kaJohanani, 
\li2  
\v 10 uJohanani enguyise ka-Azariya; 
\li2 nguye lo owayengumphristi ethempelini elakhiwa nguSolomoni eJerusalema. 
\li2  
\v 11 U-Azariya enguyise ka-Amariya, 
\li2 u-Amariya enguyise ka-Ahithubi, 
\li2  
\v 12 u-Ahithubi enguyise kaZadokhi, 
\li2 uZadokhi enguyise kaShalumi, 
\li2  
\v 13 uShalumi enguyise kaHilikhiya, 
\li2 uHilikhiya enguyise ka-Azariya, 
\li2  
\v 14 u-Azariya enguyise kaSeraya, 
\li2 uSeraya enguyise kaJozadaki. 
\li2  
\v 15 UJozadaki wathunjwa lapho \nd uThixo\nd* athumba abakoJuda labaseJerusalema ngesandla sikaNebhukhadineza. 
\b  
\li1  
\v 16 Amadodana kaLevi yila: 
\li2 nguGeshoni, loKhohathi kanye loMerari. 
\li1  
\v 17 Nanka amabizo amadodana kaGeshoni: 
\li2 nguLibhini loShimeyi. 
\li1  
\v 18 Amadodana kaKhohathi yila: 
\li2 ngu-Amramu, lo-Izihari, loHebhroni kanye lo-Uziyeli. 
\li1  
\v 19 Amadodana kaMerari yila: 
\li2 nguMahili loMushi. 
\b  
\li4 Laba babelusendo lwabaLevi behlelwe ngoluhlu lwaboyise: 
\li1  
\v 20 AbakaGeshoni yilaba: 
\li2 nguLibhini indodana yakhe, loJahathi indodana yakhe, 
\li2 loZima indodana yakhe,  
\v 21 loJowa indodana yakhe, 
\li2 lo-Ido indodana yakhe, loZera indodana yakhe kanye 
\li2 loJeyatherayi indodana yakhe. 
\li1  
\v 22 Abosendo lukaKhohathi yilaba: 
\li2 ngu-Aminadabi indodana yakhe, loKhora indodana yakhe, 
\li2 lo-Asiri indodana yakhe,  
\v 23 lo-Elikhana 
\li2 lo-Ebhiyasafi indodana yakhe lo-Asiri indodana yakhe, 
\li2  
\v 24 loThahathi indodana yakhe, lo-Uriyeli indodana yakhe, 
\li2 lo-Uziya indodana yakhe kanye loShawuli indodana yakhe. 
\li1  
\v 25 Abosendo luka-Elikhana yilaba: 
\li2 ngu-Amasayi, lo-Ahimothi, 
\li2  
\v 26 lo-Elikhana indodana yakhe, loZofayi indodana yakhe, 
\li2 loNahathi indodana yakhe,  
\v 27 lo-Eliyabi indodana yakhe, 
\li2 loJerohamu indodana yakhe, lo-Elikhana indodana yakhe kanye 
\li2 loSamuyeli indodana yakhe. 
\li1  
\v 28 Amadodana kaSamuyeli ayeyila: 
\li2 uVashini izibulo 
\li2 lo-Abhija indodana yesibili. 
\li1  
\v 29 Abosendo lukaMerari yilaba: 
\li2 nguMahili, loLibhini indodana yakhe, 
\li2 loShimeyi indodana yakhe, lo-Uza indodana yakhe, 
\li2  
\v 30 loShimeya indodana yakhe, loHagiya indodana yakhe kanye 
\li2 lo-Asaya indodana yakhe. 
\s2 Abahlabeleli BaseThempelini 
\p  
\v 31 Laba yibo abakhethwa nguDavida ukuphatha ukuhlabelela endlini \nd kaThixo\nd* ngemva kokubekwa kwebhokisi lesivumelwano khona.  
\v 32 Bakhonza ngokuhlabelela phambi kwebhokisi lesivumelwano, iThente lokuHlanganela, uSolomoni waze wakha ithempeli \nd likaThixo\nd* eJerusalema. Benza inkonzo yabo ngendlela okwakuqoqwe ngayo. 
\b  
\li4  
\v 33 Bona ababekhethelwe lowomsebenzi kanye lamadodana abo yilaba: 
\b  
\li1 Kwabendlu kaKhohathi yilaba: 
\li2 nguHemani umhlabeleli, 
\li2 indodana kaJoweli, indodana kaSamuyeli 
\li2  
\v 34 indodana ka-Elikhana, indodana kaJerohamu, 
\li2 indodana ka-Eliyeli, indodana kaThowa, 
\li2  
\v 35 indodana kaZufi, indodana ka-Elikhana, 
\li2 indodana kaMahathi, indodana ka-Amasayi, 
\li2  
\v 36 indodana ka-Elikhana, indodana kaJoweli, 
\li2 indodana ka-Azariya, indodana kaZefaniya 
\li2  
\v 37 indodana kaThahathi, indodana ka-Asiri, 
\li2 indodana ka-Ebhiyasafi, indodana kaKhora, 
\li2  
\v 38 indodana ka-Izihari, indodana kaKhohathi, 
\li2 indodana kaLevi, indodana ka-Israyeli. 
\li1  
\v 39 U-Asafi umkhula kaHemani owasebenza laye ngasesandleni sakhe sokudla: 
\li2 U-Asafi indodana kaBherekhiya, indodana kaShimeya, 
\li2  
\v 40 indodana kaMikhayeli, indodana kaBhaseya, 
\li2 indodana kaMalikhija,  
\v 41 indodana ka-Ethini, 
\li2 indodana kaZera, indodana ka-Adaya, 
\li2  
\v 42 indodana ka-Ethani, indodana kaZima, 
\li2 indodana kaShimeyi,  
\v 43 indodana kaJahathi, 
\li2 indodana kaGeshoni, indodana kaLevi; 
\li1  
\v 44 kanti njalo kubakhula babo amaMerari kwesenxele isandla sakhe yilaba: 
\li2 ngu-Ethani indodana kaKhishi, indodana ka-Abhidi, 
\li2 indodana kaMaluki,  
\v 45 indodana kaHashabhiya, 
\li2 indodana ka-Amaziya, indodana kaHilikhiya, 
\li2  
\v 46 indodana ka-Amizi, indodana kaBhani, 
\li2 indodana kaShemeri,  
\v 47 indodana kaMahili, 
\li2 indodana kaMushi, indodana kaMerari, 
\li2 indodana kaLevi. 
\b  
\p  
\v 48 Abafowabo kubaLevi babephiwe yonke eminye imisebenzi ethabanikeleni, endlini kaNkulunkulu.  
\v 49 Kodwa u-Aroni labosendo lwakhe yibo ababesethula iminikelo yokutshiswa e-alithareni kanye lase-alithareni lempepha lakho konke okwakusenziwa eNdaweni eNgcwele kakhulu, becelela u-Israyeli umusa, njengalokhu uMosi inceku kaNkulunkulu yayitshilo. 
\b  
\li1  
\v 50 Laba ngabosendo luka-Aroni: 
\li2 ngu-Eliyazari indodana yakhe, loFinehasi indodana yakhe, 
\li2 lo-Abhishuwa indodana yakhe,  
\v 51 loBhukhi indodana yakhe, 
\li2 lo-Uzi indodana yakhe, loZerahiya indodana yakhe, 
\li2  
\v 52 loMerayothi indodana yakhe, lo-Amariya indodana yakhe, 
\li2 lo-Ahithubi indodana yakhe,  
\v 53 loZadokhi indodana yakhe kanye 
\li2 lo-Ahimazi indodana yakhe. 
\b  
\li4  
\v 54 Imizi ababehlezi kiyo kuselizweni ababeliphiwe (yimizi eyayiphiwe abosendo luka-Aroni beyinzalo kaKhohathi, ngoba isabelo sakuqala sasingesabo) yile: 
\li1  
\v 55 Babephiwe iHebhroni koJuda lamadlelo akhona.  
\v 56 Kodwa amasimu lemizana eyayiseduzane ledolobho kwaphiwa uKhalebi indodana kaJefune.  
\v 57 Ngakho abosendo luka-Aroni baphiwa iHebhroni (umuzi wokuphephela), leLibhina, leJathiri, le-Eshithemowa,  
\v 58 leHileni, leDebhiri,  
\v 59 le-Ashani, leJuta leBhethi-Shemeshi, ndawonye lamadlelo akhona. 
\li1  
\v 60 Esizwaneni sikaBhenjamini baphiwa iGibhiyoni, leGebha, le-Alemethi le-Anathothi, kanye lamadlelo akhona. 
\li4 Imizi eyaphiwa amaKhohathi yayilitshumi lantathu. 
\b  
\li1  
\v 61 Abaseleyo bamaKhohathi baphiwa imizi elitshumi beyingxenye yendlu yesizwana sikaManase. 
\li1  
\v 62 Abosendo lukaGeshoni, indlu ngendlu, baphiwa imizi elitshumi lemithathu ezizwaneni zako-Isakhari, ko-Asheri lakoNafithali, kanye lengxenye yesizwana sikaManase esiseBhashani. 
\li1  
\v 63 Abosendo lukaMerari, indlu ngendlu, baphiwa imizi elitshumi lambili esizwaneni sikaRubheni, lesikaGadi lesikaZebhuluni. 
\b  
\li4  
\v 64 Ngakho yiyo imizi lamadlelo ayo eyaphiwa abaLevi ngama-Israyeli. 
\b  
\li1  
\v 65 Esizwaneni sakoJuda, lesakoSimiyoni loBhenjamini baphiwa imizi esike yaqanjwa. 
\b  
\li4  
\v 66 Amanye amaKhohathi aphiwa imizi elizweni lesizwana sika-Efrayimi. 
\li1  
\v 67 Elizweni lamaqaqa lika-Efrayimi baphiwa iShekhemu (umuzi wokuphephela) leGezeri,  
\v 68 leJokhimeyamu, leBhethi-Horoni,  
\v 69 le-Ayijaloni leGathi-Rimoni, kanye lamadlelo akhona. 
\li1  
\v 70 Engxenyeni yesizwana sikaManase abako-Israyeli, banika insalela yamaKhohathi, i-Aneri leBhileyamu kanye lamadlelo akhona. 
\b  
\li4  
\v 71 AmaGeshoni azuza lezindawo: 
\li1 Kwabosendo lwengxenye yesizwana sikaManase bazuza iGolani eBhashani kanye le-Ashitharothi, ndawonye lamadlelo akhona; 
\li1  
\v 72 esizwaneni sika-Isakhari bazuza iKhedeshi, leDabherathi,  
\v 73 leRamothi le-Anema lamadlelo akhona; 
\li1  
\v 74 esizwaneni sika-Asheri bazuza iMashali, le-Abhidoni,  
\v 75 leHukhokhi leRehobhi, kanye lamadlelo akhona; 
\li1  
\v 76 esizwaneni sikaNafithali bazuza iKhedeshi eGalile, leHamoni, leKhiriyathayimi kanye lamadlelo akhona. 
\b  
\li4  
\v 77 AmaMerari (insalela yabaLevi) aphiwa kanje: 
\li1 esizwaneni sikaZebhuluni azuza iJokhiniyamu, iKhatha, iRimoni leThabhori, kanye lamadlelo akhona; 
\li1  
\v 78 esizwaneni sikaRubheni ngaphetsheya kweJodani ngempumalanga yeJerikho azuza iBhezeri enkangala, leJahazi,  
\v 79 leKhedemothi kanye leMefahathi lamadlelo akhona; 
\li1  
\v 80 lasesizwaneni sikaGadi azuza iRamothi eGiliyadi, leMahanayimi,  
\v 81 leHeshibhoni, leJazeri, kanye lamadlelo akhona. 
\c 7  
\s1 U-Isakhari 
\li1  
\v 1 Amadodana ka-Isakhari yila: 
\li2 nguThola, loPhuwa, loJashubi loShimroni, bonke babebane. 
\li1  
\v 2 Amadodana kaThola yila: 
\li2 ngu-Uzi, loRefaya, loJeriyeli, loJahamali, lo-Ibhisamu loSamuyeli, bonke bezinhloko zezindlu zabo. Ngezinsuku uDavida esabusa, abosendo lukaThola abangamadoda aselindele impi ngoluhlu lokuzalana kwabo, babengamadoda ayezinkulungwane ezingamatshumi amabili lambili lamakhulu ayisithupha (22,600). 
\li1  
\v 3 Indodana ka-Uzi kungu: 
\li2 Izrahiya. 
\li1 Amadodana ka-Izrahiya yila: 
\li2 nguMikhayeli, lo-Obhadaya, loJoweli lo-Ishiya. Ngobuhlanu babo babezinduna.  
\v 4 Ngoluhlu lokuzalana kwabo, babelamadoda azinkulungwane ezingamatshumi amathathu lesithupha (36,000) ayeselungele ukuthi angaphuma ayekulwa impi, ngoba babelabafazi labantwana abanengi. 
\li4  
\v 5 Abayizihlobo abesilisa abasebefanele ukuthi bangaya empini bengabosendo luka-Isakhari, ngoluhlu lokuzalana kwabo, sebendawonye babezinkulungwane ezingamatshumi ayisificaminwembili lesikhombisa (87,000). 
\s1 UBhenjamini 
\li1  
\v 6 Amadodana kaBhenjamini amathathu yila: 
\li2 nguBhela, loBhekheri loJediyeli. 
\li1  
\v 7 Amadodana kaBhela yila: 
\li2 ngu-Ezibhoni, lo-Uzi, lo-Uziyeli, loJerimothi lo-Iri, babebahlanu bonke, bezinhloko zezindlu zabo. Bona-ke ngoluhlu losendo lwabo babelamadoda ayelungele ukulwa empini azinkulungwane ezingamatshumi amabili lambili lamatshumi amathathu lane (22,034). 
\li1  
\v 8 Amadodana kaBhekheri yila: 
\li2 nguZemira, loJowashi, lo-Eliyezeri, lo-Eliyonayi, lo-Omri, loJeremothi, lo-Abhija, lo-Anathothi kanye lo-Alemethi. Wonke la kwakungamadodana kaBhekheri.  
\v 9 Imbali yoluhlu lwezimuli zababezinhloko zemindeni ibalisa ukuthi babengabantu abazinkulungwane ezingamatshumi amabili lamakhulu amabili amadoda empi (20,200). 
\li1  
\v 10 Indodana kaJediyeli 
\li2 kwakunguBhilihani. 
\li1 Amadodana kaBhilihani yila: 
\li2 nguJewushi, loBhenjamini, lo-Ehudi, loKhenana, loZethani, loThashishi kanye lo-Ahishahari.  
\v 11 Wonke lamadodana kaJediyeli ayeyizinhloko zezindlu zawo. Kwakulamadoda ayesefanele ukubuthwa ayekulwa empini azinkulungwane ezilitshumi lesikhombisa, lamakhulu amabili (17,200). 
\li1  
\v 12 AmaShuphimu lamaHuphimu ayengawosendo luka-Iri, lamaHushimu engawosendo luka-Aheri. 
\s1 UNafithali 
\li1  
\v 13 Amadodana kaNafithali yila: 
\li2 nguJaziyeli, loGuni, loJezeri kanye loShalumi, abosendo lukaBhiliha. 
\s1 UManase 
\li1  
\v 14 Abosendo lukaManase yilaba: 
\li2 ngu-Asiriyeli amzala lomfazi weceleni ongumʼAramu. Wazala uMakhiri uyise kaGiliyadi.  
\v 15 UMakhiri wathatha umfazi ozalwa ngamaHuphimu lamaShuphimu. Udadewabo kwakunguMahakha. Omunye owosendo kwakunguZelofehadi owazala amankazana kuphela.  
\v 16 UmkaMakhiri uMahakha wazala indodana yathiwa nguPhereshi. Umfowabo yena wethiwa ibizo elithi Shereshi, njalo amadodana akhe kwakungu-Ulamu loRakhemu. 
\li1  
\v 17 Indodana ka-Ulamu kungu: 
\li2 Bhedani. 
\li1 La ngamadodana kaGiliyadi, indodana kaMakhiri, indodana kaManase. 
\li1  
\v 18 Udadewabo uHamolekhethi wazala u-Ishodi, lo-Abhiyezeri loMahila. 
\li1  
\v 19 Amadodana kaShemida yila: 
\li2 ngu-Ahiyani, loShekhemu, loLikhi kanye lo-Aniyami. 
\s1 U-Efrayimi 
\li1  
\v 20 Abosendo luka-Efrayimi yilaba: 
\li2 nguShuthela, loBheredi indodana yakhe, 
\li2 loThahathi indodana yakhe, lo-Eleyada indodana yakhe, 
\li2 loThahathi indodana yakhe,  
\v 21 loZabhadi indodana yakhe kanye 
\li2 loShuthela indodana yakhe. 
\li2 (U-Ezeri lo-Eliyadi babulawa ngababezalwa eGathi, baze bayethumba izifuyo zabo.  
\v 22 Uyise u-Efrayimi wabalilela okwensuku ezinengi, izihlobo zakhe zabuya ukuzomduduza.  
\v 23 Walala njalo lomkakhe wakhulelwa, wazala indodana ayitha ibizo elithi Bheriya, kuyikutshengisa ukuthi kwakonakele phakathi kwemuli.  
\v 24 Indodakazi yakhe kwakunguShera owakha iBhethi-Horoni yaPhansi leyaPhezulu kanye le-Uzeni-Shera.) 
\li2  
\v 25 URefa wayeyindodana yakhe, loReshefi indodana yakhe, 
\li2 loThela indodana yakhe, loThahani indodana yakhe, 
\li2  
\v 26 loLadani indodana yakhe, lo-Amihudi indodana yakhe, 
\li2 lo-Elishama indodana yakhe,  
\v 27 loNuni indodana yakhe 
\li2 kanye loJoshuwa indodana yakhe. 
\li4  
\v 28 Amazwe lemizi yabo yayihlanganisa iBhetheli lemizana eseduzane, iNaharani empumalanga, iGezeri lemizana yayo kusiya entshonalanga, iShekhemu lemizana yayo kusiyafika e-Aya lemizana yayo.  
\v 29 Emingceleni yakwelakoManase kuleBhethi-Shani, leThanakhi, leMegido, kanye leDori lemizana yakhona. Ababehlala kulimizi ngabosendo lukaJosefa indodana ka-Israyeli. 
\s1 U-Asheri 
\li1  
\v 30 Amadodana ka-Asheri yila: 
\li2 ngu-Imna, lo-Ishiva, lo-Ishivi kanye loBheriya. Udadewabo kunguSera. 
\li1  
\v 31 Amadodana kaBheriya yila: 
\li2 nguHebheri loMalikhiyeli uyise kaBhirizayithi. 
\li1  
\v 32 UHebheri wayenguyise kaJafilethi, loShomeri loHothamu kanye lodadewabo uShuwa. 
\li1  
\v 33 Amadodana kaJafilethi yila: 
\li2 nguPasaki, loBhimihali kanye lo-Ashivathi. 
\li4 Laba kwakungamadodana kaJafilethi. 
\li1  
\v 34 Amadodana kaShomeri yila: 
\li2 ngu-Ahi, loRohiga, loHubha kanye lo-Aramu. 
\li1  
\v 35 Amadodana omfowabo uHelemu yila: 
\li2 nguZofa, lo-Imna, loSheleshi kanye lo-Amali. 
\li1  
\v 36 Amadodana kaZofa yila: 
\li2 nguSuwa, loHarineferi, loShuwali, loBheri, lo-Imra,  
\v 37 loBhezeri, loHodi, loShama, loShilisha, lo-Ithirani kanye loBhera. 
\li1  
\v 38 Amadodana kaJetha yila: 
\li2 nguJefune, loPhisipha kanye lo-Ara. 
\li1  
\v 39 Amadodana ka-Ula yila: 
\li2 ngu-Ara, loHaniyeli kanye loRiziya. 
\li4  
\v 40 Bonke laba babengabosendo luka-Asheri bezinhloko zendlu ngendlu, amadoda akhethiweyo, amabutho alesibindi njalo bengabakhokheli abalokuhlakanipha. Inani lamadoda ayesefanele ukubuthwa aye empini, kusiya ngoluhlu losendo lwakwabo, kwakuzinkulungwane ezingamatshumi amabili lesithupha (26,000). 
\c 8  
\s1 Usendo LukaSawuli UmBhenjamini 
\li1  
\v 1 UBhenjamini wayenguyise 
\li2 kaBhela izibulo lakhe, 
\li2 lo-Ashibheli indodana yesibili, lo-Ahara eyesithathu, 
\li2  
\v 2 loNoha eyesine loRafa indodana yesihlanu. 
\li1  
\v 3 Amadodana kaBhela ayeyila: 
\li2 u-Adari, uGera, u-Abhihudi,  
\v 4 u-Abhishuwa, uNamani, u-Ahowa,  
\v 5 uGera, uShefufani kanye loHuramu. 
\li1  
\v 6 Laba ngabosendo luka-Ehudi, ababezinhloko zezindlu zalabo ababehlala eGebha abaxotshelwa eManahathi: 
\li2  
\v 7 KunguNamani, lo-Ahija, kanye loGera owabaxotshayo njalo enguyise ka-Uza, lo-Ahihudi. 
\li1  
\v 8 Kulamadodana azalwa nguShaharayimi eMowabi ngemva kokwehlukana labafazi bakhe oHushimi loBhara.  
\v 9 Emfazini wakhe uHodeshi wayelabantwana laba: uJobhabhi, loZibhiya, loMesha, loMalikhami,  
\v 10 loJewuzi, loSakhiya kanye loMirima. Yiwo amadodana akhe, ayeyizinhloko zezindlu zawo.  
\v 11 KuHushimi wazala u-Abhithubi lo-Eliphali. 
\li1  
\v 12 Amadodana ka-Eliphali ayeyila: 
\li2 u-Ebheri, uMishami, uShemedi (nguye owakha i-Ono leLodi lemizana eseduzane layo),  
\v 13 kanye loBheriya loShema, bona bezinhloko zezindlu zalabo ababehlala e-Ayijaloni abayibo njalo abaxotsha ababehlala eGathi. 
\li1  
\v 14 U-Ahiyo, uShashaki, uJeremothi,  
\v 15 uZebhadiya, u-Aradi, u-Ederi,  
\v 16 uMikhayeli, u-Ishipha kanye loJoha bengamadodana kaBheriya. 
\li1  
\v 17 UZebhadiya, uMeshulami, uHizikhi, uHebheri,  
\v 18 u-Ishimerayi, u-Iziliya, loJobhabhi kungamadodana ka-Eliphali. 
\li1  
\v 19 UJakhimi, uZikhiri, uZabhidi,  
\v 20 u-Eliyenayi, uZilethayi, u-Eliyeli,  
\v 21 u-Adaya, uBheraya kanye loShimirathi kungamadodana kaShimeyi. 
\li1  
\v 22 U-Ishiphani, u-Ebheri, u-Eliyeli,  
\v 23 u-Abhidoni, uZikhiri uHanani,  
\v 24 uHananiya, u-Elamu, u-Anithothija,  
\v 25 u-Ifideya loPhenuweli bengamadodana kaShashaki. 
\li1  
\v 26 UShamisherayi, uShehariya, u-Athaliya,  
\v 27 uJareshiya, u-Elija, kanye loZikhiri kungamadodana kaJerohamu. 
\li4  
\v 28 Bonke laba babezinhloko zezindlu, izinduna kusiya ngoluhlu losendo lwabo, njalo babehlala eJerusalema. 
\b  
\li1  
\v 29 UJeyiyeli uyise kaGibhiyoni wayehlala eGibhiyoni. 
\li2 Ibizo lomkakhe lalinguMahakha,  
\v 30 njalo indodana yakhe elizibulo kwakungu-Abhidoni, eselanywa nguZuri, loKhishi, loBhali, loNeri, loNadabi,  
\v 31 loGedori, lo-Ahiyo, loZekheri  
\v 32 kanye loMikhilothi, owayenguyise kaShimeya. Laba labo babehlala eJerusalema eduze lezihlobo zabo. 
\li1  
\v 33 UNeri wayenguyise kaKhishi, uKhishi enguyise kaSawuli, uSawuli enguyise kaJonathani, loMalikhi-Shuwa, lo-Abhinadabi kanye lo-Eshi-Bhali. 
\li1  
\v 34 Indodana kaJonathani: 
\li2 kwakunguMeri-Bhali yena enguyise kaMikha. 
\li1  
\v 35 Amadodana kaMikha ayeyila: 
\li2 uPhithoni, uMeleki, uThareya kanye lo-Ahazi. 
\li2  
\v 36 U-Ahazi wayenguyise kaJehoyada, uJehoyada enguyise ka-Alemethi, lo-Azimavethi loZimri, njalo uZimri enguyise kaMoza.  
\v 37 UMoza wayenguyise kaBhineya, loRafa eyindodana yakhe, lo-Eleyasa indodana yakhe kanye lo-Azeli indodana yakhe. 
\li1  
\v 38 U-Azeli wayelamadodana ayisithupha, amabizo awo eyila: 
\li2 u-Azirikhamu, loBhokheru, lo-Ishumayeli, loSheyariya, lo-Obhadaya kanye loHanani. Wonke la ayengamadodana ka-Azeli. 
\li1  
\v 39 Amadodana omfowabo u-Eshekhi ayeyila: 
\li2 u-Ulamu izibulo lakhe, uJewushi indodana yesibili kanye lo-Elifelethi eyesithathu.  
\v 40 Amadodana ka-Ulamu ayengamaqhawe alezibindi ayezintshantshu zemitshoko. Babelamadodana amanengi lamadodana amadodana abo, babelikhulu elilamatshumi amahlanu sebendawonye (150). 
\li1 Bonke laba babeyinzalo kaBhenjamini. 
\b  
\c 9  
\p  
\v 1 Bonke abako-Israyeli babelotshiwe eluhlwini logwalo lokuzalana kwabo lwamakhosi ako-Israyeli. AbakoJuda bathunjwa basiwa eBhabhiloni ngenxa yokungathembeki kwabo. 
\s1 Abantu EJerusalema 
\li4  
\v 2 Abokuqala ukwakha kutsha elizweni labo bahlala emizini yabo babengabantu bako-Israyeli, abaphristi, abaLevi lezinceku zethempelini. 
\b  
\li4  
\v 3 AbakoJuda, abakoBhenjamini kanye labako-Efrayimi loManase ababehlala eJerusalema yilaba: 
\li1  
\v 4 Ngu-Uthayi indodana ka-Amihudi, indodana ka-Omri, indodana ka-Imri, indodana kaBhani, owosendo lukaPherezi indodana kaJuda. 
\li1  
\v 5 KwabakoShilo 
\li2 ngu-Asaya izibulo lamadodana akhe. 
\li1  
\v 6 KwabakoZera: 
\li2 nguJuweli. 
\li4 Abantu bakoJuda babengamakhulu ayisithupha alamatshumi ayisificamunwemunye (690). 
\b  
\li4  
\v 7 KwabakoBhenjamini: 
\li1 nguSalu indodana kaMeshulami, indodana kaHodaviya, indodana kaHasenuwa; 
\li1  
\v 8 lo-Ibhineya indodana kaJerohamu; 
\li1 lo-Ela indodana ka-Uzi, indodana kaMikhiri; 
\li1 loMeshulami indodana kaShefathiya, indodana kaRuweli, indodana ka-Ibhinija. 
\li4  
\v 9 Abantu bakoBhenjamini, ngoluhlu lokuzalana kwabo njengokulotshiweyo, babengamakhulu ayisificamunwemunye lamatshumi amahlanu lesithupha (956). Bonke laba kwakungamadoda ayizinhloko zezindlu zawo. 
\b  
\li4  
\v 10 Abaphristi yilaba: 
\li1 nguJedaya; loJehoyaribhi; kanye loJakhini; 
\li1  
\v 11 lo-Azariya indodana kaHilikhiya, indodana kaMeshulami, indodana kaZadokhi, indodana kaMerayothi, indodana ka-Ahithubi, isikhulu esasiphethe indlu kaNkulunkulu; 
\li1  
\v 12 lo-Adaya indodana kaJerohamu, indodana kaPhashuri, indodana kaMalikhija; 
\li1 loMasayi indodana ka-Adiyeli, indodana kaJahizera, indodana kaMeshulami, indodana kaMeshilemithi, indodana ka-Imeri. 
\li4  
\v 13 Abaphristi ababezinhloko zezindlu zabo babeyinkulungwane eyodwa elamakhulu ayisikhombisa lamatshumi ayisithupha (1,760). Babengamadoda alolwazi, belomlandu wokuphatha umsebenzi endlini kaNkulunkulu. 
\b  
\li4  
\v 14 AbaLevi yilaba: 
\li1 nguShemaya indodana kaHashubhi, indodana ka-Azirikhamu, indodana kaHashabhiya, ongumʼMerari; 
\li1  
\v 15 loBhakhibhakhari, loHereshi, loGalali kanye loMathaniya indodana kaMikha, indodana kaZikhiri, indodana ka-Asafi; 
\li1  
\v 16 lo-Obhadaya indodana kaShemaya, indodana kaGalali, indodana kaJeduthuni, 
\li1 kanye loBherekhiya indodana ka-Asa, indodana ka-Elikhana, owayehlala emizini yamaNethofa. 
\b  
\li4  
\v 17 Abalindi bamasango yilaba: 
\li1 nguShalumi, lo-Akhubi, loThalimoni, lo-Ahimani labafowabo loShalumi induna yabo,  
\v 18 eyayilinda iSango leNkosi empumalanga, kuze kube lamuhla. Abalindi bamasango bakoLevi yilaba: 
\li1  
\v 19 nguShalumi indodana kaKhore, indodana ka-Ebhiyasafi, indodana kaKhora, lababelinda amasango ndawonye bengabendlunye (amaKhora) beyibo ababefanele bananzelele iminyango yeThempeli njengoba oyise babevele belinda iminyango yendlu \nd kaThixo\nd*. 
\li1  
\v 20 Ekadeni owayephethe abalindi bamasango kwakunguFinehasi indodana ka-Eliyazari njalo \nd uThixo\nd* wayelaye. 
\li1  
\v 21 UZakhariya indodana kaMeshelemiya wayengumlindisango lokungena eThenteni lokuHlanganela. 
\li4  
\v 22 Sebebonke labo ababekhethiwe ukuba ngabalindimasango ezindaweni eziqakathekileyo babengamakhulu amabili aletshumi lambili (212). Babelotshwe ngoluhlu lokuzalana kwabo emizini yabo. 
\b  
\p Abalindi bamasango babefakwe kulezizindawo zokwethembeka nguDavida loSamuyeli umboni.  
\v 23 Bona kanye lenzalo yabo babephethe ukugcinakala kwamasango endlu \nd kaThixo\nd* indlu ethiwa iThente.  
\v 24 Abalindimasango laba babesenhlangothini zozine: empumalanga, entshonalanga, enyakatho laseningizimu.  
\v 25 Abafowabo ababehlezi labo emizini yabo babefanele babebelinda labo bezophisana okwensuku eziyisikhombisa ihlandla ngalinye.  
\v 26 Abalindimasango abakhulu, abangabaLevi, ngobune babo babefanele bagcine izindlu lenotho esendlini kaNkulunkulu.  
\v 27 Babelala belindile ubusuku bonke besendlini kaNkulunkulu, ngoba babefanele bayilinde; njalo yibo ababelezihluthulelo beyivula ngokusa insuku zonke. 
\p  
\v 28 Abanye babo babegcina izitsha zenkonzo ezazisetshenziswa ethempelini; babezibala zingena babuye bazibale njalo seziphuma.  
\v 29 Abanye njalo babegcine impahla yendlini lakho konke okwakusendlini engcwele, kanye lokugcina ifulawa lewayini, lamafutha, impepha leziyoliso.  
\v 30 Kodwa abanye abaphristi babesebenza ukuhlanganisa iziyoliso.  
\v 31 UmLevi obizwa ngokuthi nguMathithiya, indodana elizibulo likaShalumi umKhora, wayephiwe umlandu wokubumba isinkwa somnikelo.  
\v 32 Abanye abazalwane bamaKhohathi babephethe umsebenzi ngamaSabatha wonke owokubumba isinkwa esokubekwa etafuleni. 
\p  
\v 33 Labo ababengabahlabeleli, bezinhloko zezindlu zabaLevi, babehlala ezindlini phakathi kwethempeli bengaphiwanga eminye imisebenzi ngoba babephathekile kowabo emini lebusuku. 
\p  
\v 34 Bonke laba babezinhloko zezindlu zenzalo kaLevi, izinduna njengokulotshiweyo eluhlwini losendo lwabo, njalo babehlala eJerusalema. 
\s1 Okulotshiweyo NgoLuhlu Lwendlu KaSawuli 
\li1  
\v 35 uJeyiyeli uyise kaGibhiyoni wayehlala eGibhiyoni. 
\li2 Ibizo lomkakhe lalinguMahakha,  
\v 36 njalo indodana yakhe elizibulo kwakungu-Abhidoni eselanywa nguZuri, loKhishi, loBhali, loNeri, loNadabi,  
\v 37 loGedori, lo-Ahiyo, loZakhariya kanye loMikhilothi.  
\v 38 UMikhilothi wayenguyise kaShimeyamu. Laba labo babehlala eJerusalema eduze lezihlobo zabo. 
\li1  
\v 39 UNeri wayenguyise kaKhishi, uKhishi enguyise kaSawuli, uSawuli enguyise kaJonathani, loMalikhi-Shuwa, lo-Abhinadabi kanye lo-Eshi-Bhali. 
\li1  
\v 40 Indodana kaJonathani kwakunguMeri-Bhali, 
\li2 yena enguyise kaMikha. 
\li1  
\v 41 Amadodana kaMikha ayeyila: 
\li2 uPhithoni, uMeleki, uThareya kanye lo-Ahazi. 
\li2  
\v 42 U-Ahazi wayenguyise kaJada, uJada enguyise ka-Alemethi, lo-Azimavethi loZimri, yena uZimri enguyise kaMoza.  
\v 43 UMoza wayenguyise kaBhineya; uRefaya eyindodana yakhe, lo-Eleyasa indodana yakhe kanye lo-Azeli indodana yakhe. 
\li1  
\v 44 U-Azeli wayelamadodana ayisithupha, amabizo awo eyila: 
\li2 u-Azirikhamu, loBhokheru, lo-Ishumayeli. LoSheyariya, lo-Obhadaya kanye loHanani. Laba babengamadodana ka-Azeli. 
\c 10  
\s1 Ukuzibulala KukaSawuli 
\p  
\v 1 AmaFilistiya alwa lo-Israyeli; abako-Israyeli babaleka, njalo abanengi bafela eNtabeni yase Gilibhowa.  
\v 2 AmaFilistiya axotshana kanzima loSawuli kanye lamadodana akhe, abulala amadodana akhe uJonathani, lo-Abhinadabi kanye loMalikhi-Shuwa.  
\v 3 Impi yatshisa macele wonke kuSawuli, njalo kwathi abatshoki bemitshoko sebemxhumile, bamlimaza. 
\p  
\v 4 USawuli wathi kumthwali wezikhali zakhe, “Hwatsha inkemba yakho ungigwaze, hlezi abantu laba abangasokanga bafike bangigwaze bangenze ihlazo.” 
\p Kodwa umphathi wezikhali zakhe wesaba, akaze akwenza lokho, ngakho uSawuli wathatha inkemba yakhe waziwisela phezu kwayo.  
\v 5 Kwathi umphathi wezikhali ebona ukuthi uSawuli wayesefile, laye waziwisela phezu kwenkemba yakhe, wafa.  
\v 6 Ngakho uSawuli lamadodana akhe amathathu bafa, labo bonke abendlu yakhe bafa ndawonye. 
\p  
\v 7 Kwathi bonke abako-Israyeli ababesesigodini bebona ukuthi ibutho lalibalekile lokuthi uSawuli kanye lamadodana akhe basebefile, batshiya imizi yabo babaleka. AmaFilistiya afika ahlala kuyo. 
\p  
\v 8 Ngelanga elalandelayo, amaFilistiya esefikile ukuba akhuthuze abafileyo, afica uSawuli lamadodana akhe befile eNtabeni yase Gilibhowa.  
\v 9 Bamkhuthuza baze bamquma ikhanda lakhe balithatha kanye lezikhali zakhe, basebethuma izithunywa kulolonke ilizwe lamaFilistiya ukuthi zimemezele lindaba ezithombeni zabo lebantwini bakibo.  
\v 10 Abeka izikhali zakhe ethempelini labonkulunkulu babo kwathi ikhanda lakhe balibeka ethempelini likaDagoni. 
\p  
\v 11 Abantu bonke baseJabheshi Giliyadi sebezwile ngokwakwenziwe ngamaFilistiya kuSawuli,  
\v 12 wonke amaqhawe alezibindi ahamba ayathatha isidumbu sikaSawuli lezamadodana akhe aya lazo eJabheshi. Basebengcwaba amathambo abo ngaphansi kwesihlahla esikhulu eJabheshi, bazila insuku eziyisikhombisa. 
\p  
\v 13 USawuli wafa ngoba wayengathembekanga \nd kuThixo\nd*; kaligcinanga ilizwi \nd likaThixo\nd* wakhe waze wayadinga ukuqondiswa yizangoma,  
\v 14 esikhundleni sokukhuleka \nd kuThixo\nd*. Ngakho \nd uThixo\nd* wamenza wafa wathatha ubukhosi wabunika uDavida indodana kaJese. 
\c 11  
\s1 UDavida Uba Yinkosi Yako-Israyeli 
\p  
\v 1 Bonke abako-Israyeli baya kuDavida eHebhroni bafika bathi: “Thina siyinyama yakho legazi lakho.  
\v 2 Esikhathini esedlulayo, lanxa uSawuli eseseyinkosi, wena nguwe owawukhokhela u-Israyeli emkhankasweni wezimpi. Njalo \nd uThixo\nd* uNkulunkulu wakho wathi kuwe, ‘Wena uzakuba ngumelusi wabantu bami u-Israyeli, njalo uzakuba ngumbusi wabo.’ ” 
\p  
\v 3 Kwathi abadala bonke bako-Israyeli sebefikile enkosini uDavida eHebhroni, wenza isivumelwano labo eHebhroni phambi \nd kukaThixo\nd*, basebegcoba uDavida ukuba abe yinkosi ko-Israyeli, njengesithembiso \nd sikaThixo\nd* asenza ngoSamuyeli. 
\s1 UDavida Unqoba IJerusalema 
\p  
\v 4 UDavida labo bonke abako-Israyeli baya eJerusalema (kusitsho iJebusi). AmaJebusi ayehlala khona  
\v 5 athi kuDavida, “Kawuyikungena lapha.” Kodwa lanxa kunjalo, uDavida wayithumba inqaba yaseZiyoni, uMuzi kaDavida. 
\p  
\v 6 UDavida wayethe, “Ozakhokhela ekuhlaseleni amaJebusi uzakuba nguMlawuli omkhulu wempi.” UJowabi indodana kaZeruya nguye owaqala ukuya khona, ngakho wazuza ubukhokheli. 
\p  
\v 7 UDavida wasehlala enqabeni, yikho yathiwa ibizo lokuthi nguMuzi kaDavida.  
\v 8 Wakha idolobho inxa zonke kusukela emadundulwini kuze kuyefinyelela emidulini ehonqolozeleyo, ngalesosikhathi uJowabi esakha evuselela umuzi.  
\v 9 UDavida waqhubeka njalo esiba lamandla, ngoba \nd uThixo\nd* uSomandla wayelaye. 
\s1 Amaqhawe KaDavida 
\p  
\v 10 Lezi zinduna zamaqhawe kaDavida ezazimsekele ngokuqinileyo embusweni kanye laye wonke u-Israyeli, ukuba abe yinkosi, njengokuthembisa \nd kukaThixo\nd*.  
\v 11 Lolu yiluhlu lwalawo maqhawe kaDavida: 
\p UJashobheyamu, umHakhimoni, wayengumlawuli wezikhulu; waphakamisela amadoda angamakhulu amathathu umkhonto wakhe, ababulalayo ekuhlaseleni kunye. 
\p  
\v 12 Yena elandelwa ngu-Eliyazari indodana kaDodo umʼAhohi omunye wamaqhawe amathathu.  
\v 13 WayeloDavida ePhasi Damimi, ekuhlomeni kwamaFilistiya elungiselela ukudibana empini. Endaweni ethile kwakulensimu yebhali, amabutho abaleka ebalekela amaFilistiya.  
\v 14 Kodwa bona bema bajama phakathi kwensimu. Bayivikela bawabulala amaFilistiya, \nd uThixo\nd* wabapha ukunqoba okukhulu. 
\p  
\v 15 Izinduna ezintathu kwezingamatshumi amathathu zaya edwaleni kuDavida ebhalwini lwase-Adulami, ngalesosikhathi amanye amaFilistiya ayebuthene eSigodini saseRefayi.  
\v 16 Ngalesosikhathi uDavida wayesenqabeni, iviyo lamabutho amaFilistiya laliseBhethilehema.  
\v 17 UDavida womela amanzi wasesithi, “Oh, sengathi kungaba lomuntu ongangikhela amanzi okunatha emthonjeni oseduze lesango laseBhethilehema!”  
\v 18 Ngakho abathathu laba badabula phakathi kweviyo lamaFilistiya bayakukha amanzi eduzane lesango laseBhethilehema bayawanika uDavida. Kodwa wala ukuwanatha, wakhetha ukuwathululela phambi \nd kukaThixo\nd*.  
\v 19 Wasesithi, “UNkulunkulu kangangivumeli ukukwenza lokhu! Kufanele yini ukuthi nginathe igazi lalababantu abanikele impilo yabo engozini bewaletha?” Ngoba babeka impilo zabo engozini bewaletha, uDavida kawanathanga. 
\p Lezi zaziyizenzo zobuqhawe zalawomabutho womathathu. 
\p  
\v 20 U-Abhishayi umfowabo kaJowabi wayeyinduna yabaThathu labo. Waphakamisela umkhonto wakhe phezu kwabangamakhulu amathathu, ababulalayo, ngakho waba lodumo njengabaThathu.  
\v 21 Waba lodumo oluphindwe kabili phezu kwalaba abaThathu waze waba ngumlawuli wabo, loba engazange abe phakathi kwabo. 
\p  
\v 22 UBhenaya indodana kaJehoyada wayeliqhawe elilesibindi laseKhabhizeli, elenza izenzo zobuqhawe obukhulu. Wabulala amaqhawe amaMowabi amabili ayezintshantshu ekulweni. Wake wangena emgodini wabulala isilwane mhla kulongqwaqwane.  
\v 23 Wabulala umGibhithe owayemude okwezingalo eyisikhombisa njalo eqatha. Lanxa umGibhithe wayephethe umkhonto esandleni kwakungani uphethe umkhonto onjengogodo lomaluki, uBhenayiya waqondana laye ngenduku. Wahluthuna umkhonto esandleni somGibhithe wambulala ngawo umkhonto wakhe.  
\v 24 Lezi zaziyizenzo zobuqhawe zikaBhenaya indodana kaJehoyada, laye futhi wayedume njengamaqhawe amathathu.  
\v 25 Wayehlonitshwa kakhulu ukwedlula bonke abangamatshumi amathathu, kodwa wayengabalwa kanye labaThathu. UDavida wambeka ukuba abe ngumphathi wabalindi bakhe. 
\b  
\li4  
\v 26 Amaqhawe ayelamandla ayeyila: 
\b  
\li1 u-Asaheli umfowabo kaJowabi, 
\li1 u-Elihanani indodana kaDodo waseBhethilehema, 
\li1  
\v 27 uShamothi umHarori, 
\li1 uHelezi umPheloni, 
\li1  
\v 28 u-Ira indodana ka-Ikheshi waseThekhowa, 
\li1 u-Abhiyezeri wase-Anathothi, 
\li1  
\v 29 uSibhekhayi umHushathi, 
\li1 u-Ilayi umʼAhohi, 
\li1  
\v 30 uMaharayi umNethofathi, 
\li1 uHeledi indodana kaBhana umNethofa, 
\li1  
\v 31 u-Ithayi indodana kaRibhayi owaseGibhiya koBhenjamini, 
\li1 uBhenaya umPhirathoni, 
\li1  
\v 32 uHurayi wasezindongeni zaseGashi, 
\li1 u-Abhiyeli umʼAribhathi, 
\li1  
\v 33 u-Azimavethi umBhaharumi, 
\li1 u-Eliyaba umShalibhoni, 
\li1  
\v 34 amadodana kaHashemi umGizoni, 
\li1 uJonathani indodana kaShageye umHarari, 
\li1  
\v 35 u-Ahiyamu indodana kaSakhari umHarari, 
\li1 u-Elifali indodana ka-Uri, 
\li1  
\v 36 uHeferi indodana kaMekherathi, 
\li1 u-Ahija umPheloni, 
\li1  
\v 37 uHeziro umKhameli, 
\li1 uNarayi indodana ka-Ezibhayi, 
\li1  
\v 38 uJoweli umfowabo kaNathani, 
\li1 uMibhari indodana kaHagiri, 
\li1  
\v 39 uZelekhi umʼAmoni, 
\li1 uNaharayi umBherothi, owayethwala izikhali zikaJowabi indodana kaZeruya, 
\li1  
\v 40 u-Ira umʼIthira, 
\li1 uGarebhi umʼIthiri, 
\li1  
\v 41 u-Uriya umHithi, 
\li1 uZabhadi indodana ka-Ahilayi, 
\li1  
\v 42 lo-Adina indodana kaShiza owakoRubheni, owayeyinduna yakoRubheni, kanye labangamatshumi amathathu ababelaye, 
\li1  
\v 43 loHanani indodana kaMahakha, 
\li1 loJoshafathi umʼMithini, 
\li1  
\v 44 lo-Uziya umʼAshitherathi, 
\li1 loShama loJeyiyeli amadodana kaHothamu umʼAroweri, 
\li1  
\v 45 loJediyeli indodana kaShimiri, 
\li1 umfowabo uJoha umThizi, 
\li1  
\v 46 lo-Eliyeli umʼMahavi, 
\li1 loJeribhayi loJoshaviya amadodana ka-Elinamu, 
\li1 lo-Ithima waseMowabi, 
\li1  
\v 47 lo-Eliyeli, lo-Obhedi kanye loJasiyeli waseMezobha. 
\c 12  
\s1 Amabutho Alandela UDavida Egangeni 
\li4  
\v 1 La ngamabutho ayeloDavida eZikhilagi, ngesikhathi engavunyelwa ukubonakala kuSawuli indodana kaKhishi (kwakungamaqhawe ayemhlomulele empini;  
\v 2 ayehlome ngemitshoko, ezingcitshi ekutshokeni lokutshaya ngezavutha loba ejikijela ngesokudla loba ngesenxele; ayeyizihlobo zikaSawuli engawesizwe sikaBhenjamini): 
\b  
\li1  
\v 3 U-Ahiyezeri induna yawo loJowashi amadodana kaShemaha owaseGibhiya; 
\li1 loJeziyeli loPhelethi amadodana ka-Azimavethi; 
\li1 loBherakha, loJehu umʼAnathothi,  
\v 4 kanye lo-Ishimaya umGibhiyoni, indoda eyayilamandla amakhulu kwabangamatshumi amathathu, engumkhokheli wabangamatshumi amathathu, 
\li1 loJeremiya, loJahaziyeli, loJohanani, loJozabhadi umGederathi,  
\v 5 lo-Eluzayi, loJerimothi, loBheliya, loShemariya kanye loShefathiya umHarufi, 
\li1  
\v 6 lo-Elikhana, lo-Ishiya, lo-Azareli, loJowezeri loJashobheyamu amaKhora; 
\li1  
\v 7 kanye loJowela loZebhadiya amadodana kaJerohamu waseGedori. 
\b  
\p  
\v 8 Abanye abakoGadi babalekela kuDavida enqabeni yakhe enkangala. Babengamabutho alezibindi, belungele ukulwa njalo bekwazi ukuphatha ihawu lomkhonto. Ubuso babo babungobezilwane, njalo belesiqubu njengamagogo ezintabeni. 
\b  
\li1  
\v 9 U-Ezeri wayeyinduna, 
\li1 u-Obhadaya engumsekeli womlawuli, u-Eliyabi engowesithathu, 
\li1  
\v 10 uMishimana engowesine, uJeremiya engowesihlanu, 
\li1  
\v 11 u-Athayi engowesithupha, u-Eliyeli engowesikhombisa, 
\li1  
\v 12 uJohanani engowesificaminwembili, u-Elizabhadi engowesificamunwemunye, 
\li1  
\v 13 uJeremiya engumsekeli wetshumi kanye loMakhabhanayi owayengowetshumi lanye. 
\b  
\p  
\v 14 Amadoda akoGadi ayengabalawuli bamabutho, kuthi omncinyane wabo wayengamelana labalikhulu kodwa omkhulu wabo engamelana labayinkulungwane.  
\v 15 Yiwo la amadoda achapha uJodani ngenyanga yakuqala umfula ugcwele uphuphuma emakhunjini awo wonke, yibo njalo abaxotsha bonke ababehlala ezihotsheni, empumalanga kanye lasentshonalanga. 
\p  
\v 16 Amanye amadoda akoBhenjamini lamanye ayevela koJuda lawo alandela uDavida khonale enqabeni yakhe.  
\v 17 UDavida waphuma ukuba ayewahlangabeza wathi kuwo: “Nxa lingilandela ngokuthula, lizongiphathisa njengabangane, ngizimisele ukuhlanganyela kanye lani. Kodwa nxa lidinga ukunginikela ezitheni zami, mina ngimsulwa, uNkulunkulu wabokhokho kakubone lokho, alijezise.” 
\p  
\v 18 Ngakho uMoya wasesehlela ku-Amasayi, umlawuli wabangamatshumi amaThathu, wathi: 
\q1 “Singabakho thina, wena Davida! 
\q2 Sikanye lawe wena ndodana kaJese! 
\q1 Impumelelo, impumelelo kuwe, 
\q2 njalo impumelelo kulabo abaphathisana lawe! 
\q3 Ngoba uNkulunkulu wakho uzakusiza.” 
\p Ngakho uDavida wabamukela wabenza abakhokheli bamaviyo amabutho ayehlasela. 
\p  
\v 19 Amanye amadoda akoManase abalekela kuDavida ekuhambeni kwakhe lamaFilistiya esiyahlasela uSawuli. (Yena kanye lamabutho akhe kasazange ancedise amaFilistiya, ngoba ngemva kokubuzisisana, ababusi bawo bathi kaxotshwe. Bathi bona: “Uyingozi kithi, ngoba angasiphendukela abuyele enkosini yakhe uSawuli.”)  
\v 20 UDavida wathi esiya eZikhilagi, nanka amadoda abaleka koManase amlandela: ngu-Adina, loJozabhadi, loJediyeli, loMikhayeli, loJozabhadi, lo-Elihu kanye loZilethayi ababengabalawuli benkulungwane koManase.  
\v 21 Bancedisa uDavida ekulweni lamaviyo abahlaseli, ngoba bonke babengamabutho alezibindi, njalo basebengabalawuli phakathi kwamabutho akhe.  
\v 22 Insuku zonke, ukusa kwamalanga, kwakutheleka abantu bezoncedisa uDavida, waze waba lebutho elikhulu, njengebutho likaNkulunkulu. 
\s1 Abanye Balandela UDavida EHebhroni 
\li4  
\v 23 Nanka amanani amadoda ayehlomele impi eza kuDavida eHebhroni ezomncedisa ukuthatha umbuso kaSawuli, njengokutsho \nd kukaThixo\nd*: 
\b  
\li1  
\v 24 amadoda ayevela koJuda ehlome ngamahawu lemikhonto ayezinkulungwane eziyisithupha lamakhulu ayisificaminwembili (6,800) ehlomele ukulwa impi; 
\li1  
\v 25 abakaSimiyoni, amabutho ayelungele ukuhlasela babezinkulungwane eziyisikhombisa lekhulu (7,100), 
\li1  
\v 26 amadoda akoLevi ayezinkulungwane ezine lamakhulu ayisithupha (4,600),  
\v 27 kubalwa loJehoyada, umkhokheli wabendlu ka-Aroni babezinkulungwane ezintathu lamakhulu ayisikhombisa (3,700) zamadoda  
\v 28 kanye loZadokhi, ibutho elaliseselijaha lilesibindi, lilezikhulu zendlu yakwabo ezingamatshumi amabili lambili (22); 
\li1  
\v 29 amadoda akoBhenjamini, labakibo kaSawuli babezinkulungwane ezintathu (3,000), ababesele bethembekile kuSawuli kuze kufike lesisikhathi yibo ababebanengi kulelonani; 
\li1  
\v 30 amadoda ako-Efrayimi, amadoda ayelezibindi, edumile ezizwaneni zawo, ayezinkulungwane ezingamatshumi amabili lamakhulu ayisificaminwembili (20,800), 
\li1  
\v 31 amadoda ayevela kungxenye yesizwana sikaManase, ekhethwe ngamabizo awo ukuba azobeka uDavida ukuthi abe yinkosi, ayezinkulungwane ezilitshumi lesificaminwembili (18,000); 
\li1  
\v 32 amadoda ayevela ko-Isakhari, ayezwisisa umumo walesosikhathi njalo esazi ukuthi u-Israyeli kumele enzeni. Kwakuzinduna ezingamakhulu amabili (200) kanye lezihlobo zazo ezazingaphansi kwazo; 
\li1  
\v 33 amadoda ayevela koZebhuluni, amabutho ayezingwazi empini, ngezikhali zemihlobo etshiyeneyo, eza ukuzancedisa uDavida ngokuzinikela okungalakuthandabuza, ayezinkulungwane ezingamatshumi amahlanu (50,000); 
\li1  
\v 34 amadoda ayevela koNafithali kwakuyizikhulu eziyinkulungwane eyodwa (1,000), kanye lamadoda ayephethe amahawu lemikhonto ayezinkulungwane ezingamatshumi amathathu lesikhombisa (37,000); 
\li1  
\v 35 amadoda ayevela koDani, ezimisele ukulwa empini, ayezinkulungwane ezingamatshumi amabili lesificaminwembili lamakhulu ayisithupha (28,600); 
\li1  
\v 36 amadoda ayevela ko-Asheri, amabutho ayevele ekwejayele ukulwa empini njalo ezimisele ukulwa, ayezinkulungwane ezingamatshumi amane (40,000); 
\li1  
\v 37 njalo ngempumalanga yeJodani, amadoda akoRubheni, koGadi lakungxenye yesizwana sikaManase, ayehlome ngemihlobohlobo yezikhali, ayezinkulungwane ezilikhulu lamatshumi amabili (120,000). 
\b  
\li4  
\v 38 Bonke laba babengamabutho azinikeleyo ukungena laloba yisiphi isigaba. 
\b  
\p Ngamabutho aya eHebhroni ezimisele ukufika abeke uDavida esihlalweni sobukhosi abe yinkosi ka-Israyeli. Abanye bonke abako-Israyeli babengqondonye befisa ukwethesa uDavida ubukhosi.  
\v 39 Wonke lamadoda athatha insuku ezintathu eloDavida, esidla njalo enatha, njengoba izimuli zawo zaziwalungisele umphako.  
\v 40 Konke labomakhelwane babo, ababevela kude khonale ku-Isakhari, loZebhuluni lakuNafithali beza bethwele ukudla ngabobabhemi, amakamela, imbongolo langenkabi. Kwakulefulawa enengi, amakhekhe omkhiwane, amakhekhe erezini, iwayini, amafutha, inkomo lezimvu, ngoba kwakulokujabula ko-Israyeli. 
\c 13  
\s1 Ukubuyiselwa Kwebhokisi Lesivumelwano 
\p  
\v 1 UDavida wacebisana lezikhulu zakhe zonke, abalawuli bezinkulungwane labalawuli bamakhulu.  
\v 2 Wasesithi kuwo wonke umbuthano wako-Israyeli: “Nxa likubona kulungile njalo nxa kuyintando \nd kaThixo\nd* uNkulunkulu wethu, asithumeleni ilizwi eduze lakhatshana kubo bonke abafowethu kuwo wonke amazwe ako-Israyeli, kanye lakubaphristi labaLevi abalabo khonale emadolobheni abo lasemadlelweni abo, sibanxusa ukuthi beze bazohlanganyela kanye lathi.  
\v 3 Asibuyiseni ibhokisi lesivumelwano sikaNkulunkulu wethu kithi, ngoba asizange sibuze kulo ngesikhathi sokubusa kukaSawuli.”  
\v 4 Bonke ababebuthene bavumelana ukukwenza lokho, ngoba bonke abantu bakubona kufanele ukukwenza lokho. 
\p  
\v 5 Ngakho uDavida wahlanganisa ama-Israyeli wonke, kusukela eMfuleni uShihori eGibhithe kusiya eLebho Hamathi, ukuyathatha ibhokisi lesivumelwano sikaNkulunkulu eKhiriyathi-Jeyarimi.  
\v 6 UDavida labo bonke abako-Israyeli ababelaye baya eBhala yakoJuda (iKhiriyathi-Jeyarimi) ukuthi baye khonale bayebuya lebhokisi lesivumelwano \nd sikaThixo\nd* uNkulunkulu, osesihlalweni sobukhosi ephahlwe ngamaKherubhi, ibhokisi lesivumelwano \nd sikaThixo\nd* elibizwa ngaleloBizo. 
\p  
\v 7 Balisusa ibhokisi lesivumelwano sikaNkulunkulu endlini ka-Abhinadabi ngenqola entsha, eyayiqondiswa ngu-Uza lo-Ahiyo.  
\v 8 UDavida labo bonke abako-Israyeli babejabula bezithokozisa ngamandla abo wonke phambi kukaNkulunkulu, ngezingoma betshaya lamachacho, lezingungu, lezigubhu, lamacilongo. 
\p  
\v 9 Bathi befika esizeni sokubhulela eKhidoni, u-Uza welula isandla sakhe ezama ukuzinzisa ibhokisi lesivumelwano sikaThixo, ngoba inkabi zazikhubekile.  
\v 10 Ulaka \nd lukaThixo\nd* lwavutha ku-Uza, wamtshaya wafa ngoba wayebeke isandla sakhe phezu kwebhokisi lesivumelwano \nd sikaThixo\nd*. Ngakho wahle wafa khonapho phambi \nd kukaThixo\nd*. 
\p  
\v 11 Ngakho uDavida wathukuthela ngoba ulaka \nd lukaThixo\nd* lwavutha ku-Uza, njalo kuze kube lalamuhla indawo leyo ibizwa ngokuthi yiPherezi Uza. 
\p  
\v 12 UDavida wamesaba uNkulunkulu ngalolosuku waze wabuza wathi: “Pho ngingaliletha njani kimi ibhokisi lesivumelwano sikaNkulunkulu?”  
\v 13 Kasazange alithathe ibhokisi lesivumelwano ukuze libe kuye eMzini kaDavida. Kodwa-ke walisa eceleni endlini ka-Obhedi-Edomi umGithi.  
\v 14 Ibhokisi lesivumelwano sikaNkulunkulu lahlala kwabendlu ka-Obhedi-Edomi endlini yakhe okwezinyanga ezintathu, yikho \nd uThixo\nd* wabusisa indlu yakhe lakho konke okwakungokwakhe. 
\c 14  
\s1 UDavida Labendlu Yakhe 
\p  
\v 1 Ngalesosikhathi uHiramu inkosi yaseThire wathumela izithunywa kuDavida, ndawonye lezigodo zomsedari, ababazi bamatshe kanye lababazi ukuthi bayemakhela isigodlo.  
\v 2 UDavida wahle wakwazi ukuthi \nd uThixo\nd* usembekile ukuba abe yinkosi ka-Israyeli lokuthi umbuso wakhe uphakanyisiwe kakhulu ngenxa yabantu bakhe bako-Israyeli. 
\p  
\v 3 EJerusalema uDavida wathatha abanye abafazi wazala amanye amadodana lamadodakazi.  
\v 4 Nanka amabizo abantwana abazalelwa khona: uShamuwa, uShobabi, uNathani, uSolomoni,  
\v 5 u-Ibhari, u-Elishuwa, u-Eliphelethi,  
\v 6 uNoga, uNefegi, uJafiya,  
\v 7 u-Elishama, uBheyeliyada kanye lo-Elifelethi. 
\s1 UDavida Unqoba AmaFilistiya 
\p  
\v 8 AmaFilistiya athi esizwa ukuthi uDavida usegcotshwe ukuba yinkosi yalo lonke elako-Israyeli, aphuma wonke ehlome ephelele esiyamzingela, kodwa uDavida wakuzwa lokho wahle waphuma yena ukuyawahlangabeza.  
\v 9 AmaFilistiya ayesefikile njalo ukuyahlasela eSigodini saseRefayi;  
\v 10 ngakho uDavida wabuza kuNkulunkulu wathi: “Ngihambe ngiyewahlasela amaFilistiya na? Uzawanikela kimi na?” 
\p \nd UThixo\nd* wamphendula wathi, “Hamba, ngizawanikela kuwe.” 
\p  
\v 11 Ngakho uDavida lamabutho akhe aya eBhali Pherazimi lapho awehlula khona. Wathi: “Njengamanzi efohla, uNkulunkulu ufohlele ezitheni zami ngesandla sami.” Ngakho leyondawo yasibizwa ngokuthi yiBhali Pherazimi.  
\v 12 AmaFilistiya ayebaleke atshiya onkulunkulu bawo khonale, uDavida wathi kabatshiswe ngomlilo. 
\p  
\v 13 AmaFilistiya aphinda njalo ukuhlasela isigodi,  
\v 14 ngakho uDavida wabuza kuNkulunkulu njalo, uNkulunkulu wamphendula wathi, “Ungasuki uqonde phambili kodwa bazingeleze ubusubahlasela uvelela ezihlahleni zebhalisamu.  
\v 15 Kuzakuthi lapho usizwa izisinde zabahambayo ezihlahleni zebhalisamu, uphume uhlasele, ngoba lokho kuzabe kusitsho ukuthi uNkulunkulu usehambe phambi kwakho ukuyanqoba amabutho amaFilistiya.”  
\v 16 Ngakho uDavida wenza njengokulaywa kwakhe nguNkulunkulu, njalo bawacakazela phansi amaFilistiya umango wonke kusukela eGibhiyoni kusiya eGezeri. 
\p  
\v 17 Yikho udumo lukaDavida lwanda lwafinyelela kuwo wonke amazwe, \nd uThixo\nd* wenza izizwe zonke zimesabe. 
\c 15  
\s1 Ukulethwa Kwebhokisi Lesivumelwano EJerusalema 
\p  
\v 1 Ngemva kokuba uDavida esakhile ezakhe izindlu eMzini kaDavida, wakha indawo yebhokisi lesivumelwano sikaNkulunkulu, walimisela ithente kuleyondawo.  
\v 2 UDavida wasesithi: “Kakho ozathwala ibhokisi lesivumelwano sikaNkulunkulu ngaphandle kwabaLevi ngoba \nd uThixo\nd* wabakhethela ukuthwala ibhokisi lesivumelwano \nd sikaThixo\nd* lokumkhonza kuze kube nininini.” 
\p  
\v 3 UDavida wasehlanganisa bonke abako-Israyeli eJerusalema ukuze balethe ibhokisi lesivumelwano \nd sikaThixo\nd* endaweni ayeyilungisele lona. 
\b  
\li4  
\v 4 Wahlanganisa abosendo luka-Aroni labaLevi ngezindlu zabo: 
\b  
\li1  
\v 5 Kwabendlu kaKhohathi, 
\li2 kwakungu-Uriyeli umkhokheli lezihlobo ezilikhulu lamatshumi amabili (120); 
\li1  
\v 6 kwabendlu kaMerari, 
\li2 kwakungu-Asaya umkhokheli lezihlobo ezingamakhulu amabili lamatshumi amabili (220); 
\li1  
\v 7 kwabendlu kaGeshoni, 
\li2 kwakunguJoweli umkhokheli lezihlobo ezilikhulu labantu abangamatshumi amathathu (130); 
\li1  
\v 8 kwabendlu ka-Elizafani, 
\li2 kwakunguShemaya umkhokheli lezihlobo ezingamakhulu amabili (200); 
\li1  
\v 9 kwabendlu kaHebhroni, 
\li2 kwakungu-Eliyeli umkhokheli lezihlobo ezingamatshumi ayisificaminwembili (80); 
\li1  
\v 10 kwabendlu ka-Uziyeli, 
\li2 kwakungu-Aminadabi umkhokheli lezihlobo ezilikhulu labantu abalitshumi lambili (112). 
\b  
\p  
\v 11 UDavida wasenxusa abaphristi uZadokhi lo-Abhiyathari kanye lo-Uriyeli, lo-Asaya, loJoweli, loShemaya, lo-Eliyeli lo-Abhinadabi abaLevi.  
\v 12 Wasesithi kubo, “Lina lizinhloko zezindlu zabaLevi, zihlambululeni lina kanye lezihlobo zenu ukuze liyethatha ibhokisi lesivumelwano \nd sikaThixo\nd*, uNkulunkulu ka-Israyeli, lililethe endaweni engiyilungisele lona.  
\v 13 \nd UThixo\nd* uNkulunkulu wethu wasithukuthelela ngenxa yokuthi lina abaLevi, ayisini elathwala ibhokisi lesivumelwano \nd sikaThixo\nd* kuqala. Asizanga sibuze \nd kuThixo\nd* ukuthi kwakumele senzeni njengokulaya kwakhe.”  
\v 14 Ngakho abaphristi labaLevi bazihlambulula ukuze bathwale ibhokisi lesivumelwano \nd sikaThixo\nd*, uNkulunkulu ka-Israyeli.  
\v 15 Yikho abaLevi bathwala ibhokisi lesivumelwano \nd sikaThixo\nd* ngezibambo zezigodo emahlombe abo, njengokulaya kukaMosi kulandelwa ilizwi \nd likaThixo\nd*. 
\p  
\v 16 UDavida watshela abakhokheli babaLevi ukuthi bakhethe abafowabo ukuthi babe ngabahlabeleli ukuze bahlabelele izingoma ezimnandi, betshaya amachacho lezigubhu lemihubhe. 
\p  
\v 17 AbaLevi bakhetha uHemani indodana kaJoweli; kubafowabo, u-Asafi indodana kaBherekhiya; lakubafowabo amaMerari, u-Ethani indodana kaKhushaya;  
\v 18 kanye labafowabo ngokulandelana ngezikhundla: uZakhariya, loJahaziyeli, loShemiramothi, loJeyiyeli, lo-Uni, lo-Eliyabi, loBhenaya, loMaseya, loMathithiya, lo-Elifelehu, loMikhineya, lo-Obhedi-Edomi kanye loJehiyeli abalindi bamasango. 
\p  
\v 19 Abahlabeleli uHemani lo-Asafi kanye lo-Ethani babezatshaya izigubhu zethusi;  
\v 20 loZakhariya, lo-Aziyeli, loShemiramothi, loJehiyeli, lo-Uni, lo-Eliyabi, loMaseya kanye loBhenaya babezatshaya imihubhe, ngokuhambelana \tl le-alamothi\tl* 
\v 21 loMathithiya, lo-Elifelehu, loMikhineya, lo-Obhedi-Edomi, loJeyiyeli kanye lo-Azaziya babezatshaya imiqangala, njengokuqondiswa kwabo \tl yishiminithi,\tl* 
\v 22 uKhenaniya umkhokheli kubaLevi wayengumhlabelisi; wayephethe lapha ngoba wayeligabazi. 
\p  
\v 23 UBherekhiya lo-Elikhana babengabalindi bamasango ebhokisi lesivumelwano,  
\v 24 loShebhaniya, loJoshafathi loNethaneli, lo-Amasayi, loZakhariya, loBhenaya kanye lo-Eliyezari bengabaphristi bokuvuthela icilongo phambi kwebhokisi lesivumelwano sikaNkulunkulu. U-Obhedi-Edomi loJehiya labo babengabalindi beminyango yebhokisi lesivumelwano. 
\p  
\v 25 Ngakho uDavida labadala bako-Israyeli labalawuli bamaxuku enkulungwane bahamba ukuyathatha ibhokisi lesivumelwano \nd sikaThixo\nd* endlini ka-Obhedi-Edomi, bahamba ngokujabula.  
\v 26 Ngoba uNkulunkulu wayebasizile abakoLevi ababethwele ibhokisi lesivumelwano \nd sikaThixo\nd*, benza umhlatshelo wenkunzi eziyisikhombisa lenqama eziyisikhombisa.  
\v 27 UDavida labo bonke abaLevi ababethwele ibhokisi lesivumelwano \nd sikaThixo\nd* labahlabeleli loKhenaniya umkhokheli wabahlabeleli babegqoke izigqoko zelembu lelineni elihle, uDavida wayegqoke lesigqoko semahlombe selineni elihle.  
\v 28 Ngakho abako-Israyeli ngobunengi babo baletha ibhokisi lesivumelwano \nd sikaThixo\nd* ngomdumo omkhulu, bevuthela impondo zenqama betshaya lamacilongo, lezigubhu lamachacho lemihubhe. 
\p  
\v 29 Ekungeneni kwebhokisi lesivumelwano \nd sikaThixo\nd* eMzini kaDavida, uMikhali indodakazi kaSawuli wayebukele elunguze ngefasitela. Wathi ebona inkosi uDavida izithokozisa igida, wayeyisa ngenhliziyo yakhe. 
\c 16  
\s1 Ibhokisi Lesivumelwano SikaThixo Libekwa Ethenteni 
\p  
\v 1 Balithwala ibhokisi lesivumelwano sikaNkulunkulu bayalingenisa ethenteni uDavida ayelilungiselele lona, banikela ngeminikelo yokutshiswa leyobudlelwano phambi kukaNkulunkulu.  
\v 2 UDavida eseqedile ukunikela ngeminikelo yokutshiswa langeyobudlelwano, wabusisa abantu ngebizo \nd likaThixo\nd*.  
\v 3 Wababela bonke abako-Israyeli, abesilisa labesifazane, yilowo lalowo isinkwa, lekhekhe lezithelo kanye lekhekhe lamavini awonyisiweyo. 
\p  
\v 4 Wakhetha abanye abaLevi ukukhonza phambi kwebhokisi lesivumelwano \nd sikaThixo\nd* bedumisa \nd uThixo\nd*, bebonga uNkulunkulu ka-Israyeli:  
\v 5 Induna kwakungu-Asafi, uZakhariya engumsekeli, kulandela uJeyeli, loShemiramothi, loJehiyeli, loMathithiya, lo-Eliyabi, loBhenaya, lo-Obhedi-Edomi kanye loJeyiyeli. Babezatshaya amachacho lemihubhe, u-Asafi etshaya izigubhu,  
\v 6 abaphristi uBhenaya loJahaziyeli bengabokuvuthela amacilongo phambi kwebhokisi lesivumelwano sikaNkulunkulu. 
\s1 Ihubo Lokubonga KukaDavida 
\p  
\v 7 Ngalolosuku uDavida wamisa ukuba u-Asafi labanye bakhe bahlabelele lelihubo bebonga \nd uThixo\nd*: 
\q1  
\v 8 Bongani \nd uThixo\nd*, memezani ibizo lakhe, 
\q2 lizazise phakathi kwabantu izenzo zakhe. 
\q1  
\v 9 Hlabelelani kuye, hlabelelani indumiso kuye; 
\q2 likhulume ngezenzo zakhe zonke ezimangalisayo. 
\q1  
\v 10 Jabulani ebizweni lakhe elingcwele; 
\q2 kazithokoze inhliziyo zabo abamdingayo \nd uThixo\nd*. 
\q1  
\v 11 Dingani \nd uThixo\nd* lamandla akhe, 
\q2 limdinge yena njalonjalo. 
\b  
\q1  
\v 12 Khumbulani izenzo zakhe ezimangalisayo azenzayo, 
\q2 izimangaliso azenzayo, lezahlulelo azikhulumayo, 
\q1  
\v 13 lina zizukulwane zika-Israyeli inceku yakhe, 
\q2 lina madodana kaJakhobe, abakhethiweyo bakhe. 
\q1  
\v 14 Yena \nd unguThixo\nd* uNkulunkulu wethu; 
\q2 izahlulelo zakhe zigcwele wonke umhlaba. 
\b  
\q1  
\v 15 Uyakhumbula isivumelwano sakhe nini lanini, 
\q2 ilizwi lomlayo wakhe, okwezizukulwane ezizinkulungwane, 
\q1  
\v 16 isivumelwano asenza lo-Abhrahama, 
\q2 isifungo asenza lo-Isaka, 
\q1  
\v 17 wasiqinisa kuJakhobe saba yisimiso, 
\q2 laku-Israyeli saba yisivumelwano esingapheliyo, 
\q1  
\v 18 wathi “Ngizalinika ilizwe laseKhenani 
\q2 njengesabelo selifa lenu.” 
\b  
\q1  
\v 19 Kwathi lisesebalutshwana, 
\q2 bebalutshwana kakhulu, beyizihambi kulo, 
\q1  
\v 20 bezula kuzizwe ngezizwe 
\q2 besuka komunye umbuso besiya komunye. 
\q1  
\v 21 Kavumelanga loba ngubani ukubancindezela; 
\q2 wawakhuza amakhosi ngenxa yabo, 
\q1  
\v 22 “Lingabathinti abagcotshiweyo bami; 
\q2 lingahlukuluzi abaphrofethi bami.” 
\b  
\q1  
\v 23 Hlabelani \nd kuThixo\nd* lina, mhlaba wonke, 
\q2 limemezele insindiso yakhe insuku ngezinsuku. 
\q1  
\v 24 Fakazani ngobukhosi bakhe ezizweni zonke, 
\q2 lemisebenzi yakhe emangalisayo phakathi kwabantu bonke. 
\b  
\q1  
\v 25 Ngoba umkhulu \nd uThixo\nd*, ufanele ukudunyiswa ngokuphindiweyo; 
\q2 kumele esatshwe ngaphezu kwabonkulunkulu bonke. 
\q1  
\v 26 Ngoba bonke onkulunkulu bezizwe bayizithombe; 
\q2 kodwa \nd uThixo\nd* wadala amazulu. 
\q1  
\v 27 Inkazimulo lobukhosi kuphambi Kwakhe 
\q2 Amandla lentokozo kusendaweni yakhe yokuhlala. 
\b  
\q1  
\v 28 Mnikeni \nd uThixo\nd*, lina zizukulwane zezizwe. 
\q2 Mnikeni \nd uThixo\nd* ubukhosi lamandla. 
\q1  
\v 29 Mnikeni \nd uThixo\nd* udumo olufanele ibizo lakhe. 
\q2 Lethani umnikelo libuye phambi kwakhe. 
\q1 Mkhonzeni \nd uThixo\nd* enkazimulweni yobungcwele bakhe; 
\q2  
\v 30 thuthumelani phambi kwakhe mhlaba wonke! 
\q2 Umhlaba ugxilile, ngeke ugudluzwe. 
\b  
\q1  
\v 31 Amazulu kawathokoze, lomhlaba ujabule, 
\q2 kabathi phakathi kwabezizwe, “\nd UThixo\nd* uyabusa.” 
\q1  
\v 32 Ulwandle kaluhlokome lakho konke okukulo, 
\q2 amasimu kawathakazelele lakho konke okukuwo. 
\q1  
\v 33 Lapho-ke izihlahla zonke zeganga zizahlabela 
\q2 ngentokozo phambi \nd kukaThixo\nd*, 
\q2 ngoba uyeza ukuzakwahlulela umhlaba. 
\b  
\q1  
\v 34 Bongani \nd uThixo\nd* ngoba ulungile. 
\q2 Uthando lwakhe olungapheliyo lumi kokuphela. 
\q1  
\v 35 Celani lithi: “Sisindise, Oh Nkulunkulu Mkhululi wethu, 
\q2 usiqoqe usikhulule phakathi kwezizwe, 
\q1 ukuze silibonge ibizo lakho elingcwele, 
\q2 sijabule ekukudumiseni.” 
\q1  
\v 36 Kabongwe \nd uThixo\nd*, uNkulunkulu ka-Israyeli, 
\q2 kusukela endulo kuze kube nininini. 
\m Bonke abantu bathi: “Ameni. Kabongwe \nd uThixo\nd*!” 
\b  
\p  
\v 37 UDavida wasetshiya o-Asafi labakhula bakhe ukuba bagcine ibhokisi lesivumelwano \nd sikaThixo\nd*, bakhonze njalo benze konke okufanele kwenziwe lapho ngezinsuku zonke.  
\v 38 Abanye abatshiya lapho ukuze bakhonze labo ngo-Obhedi-Edomi labakhula bakhe, ababengamatshumi ayisithupha lasificaminwembili. U-Obhedi-Edomi indodana kaJeduthuni, kanye loHosa babengabalindi bamasango. 
\p  
\v 39 UDavida watshiya uZadokhi umphristi kanye labanye abaphristi phambi kwethabanikeli \nd likaThixo\nd* endaweni ephakemeyo yokukhonzela eGibhiyoni  
\v 40 ukunikela \nd kuThixo\nd* iminikelo yokutshiswa e-alithareni ngezikhathi zonke, ekuseni lantambama, njengokulotshiweyo eMthethweni \nd kaThixo\nd*, awupha abako-Israyeli.  
\v 41 Abanye abasala labo babengoHemani loJeduthuni labanye bonke balabo ababekhethiwe beqanjwa ngamabizo ukuba badumise \nd uThixo\nd*, “ngoba uthando lwakhe lumi kuze kube nininini.”  
\v 42 UHemani loJeduthuni babengabokuvuthela amacilongo lokutshaya izigubhu lamanye amachacho ezingoma ezingcwele. Amadodana kaJeduthuni ayehlala esangweni. 
\p  
\v 43 Abanye bonke basuka, ngulowo lalowo waqonda emzini wakhe, uDavida wabuyela emzini wakhe ukuyabusisa abendlu yakhe. 
\c 17  
\s1 Isithembiso SikaNkulunkulu KuDavida 
\p  
\v 1 UDavida esehlezi esigodlweni sakhe wasesithi kuNathani umphrofethi, “Uyabona, mina ngihlezi esigodlweni esakhiwa ngomsedari, kodwa ibhokisi lesivumelwano \nd sikaThixo\nd* lingaphansi kwethente.” 
\p  
\v 2 UNathani wathi kuDavida, “Konke okusengqondweni yakho, kwenze, ngoba uNkulunkulu ulawe.” 
\p  
\v 3 Ngalobobusuku ilizwi likaNkulunkulu leza kuNathani, lisithi: 
\pm  
\v 4 “Hamba uyetshela inceku yami uDavida uthi, ‘Nanku okutshiwo \nd nguThixo\nd*: Ayisuwe ozangakhela indlu yokuhlala kuyo.  
\v 5 Angikahlali endlini kusukela mhla ngakhulula abako-Israyeli eGibhithe kuze kube lamuhla. Sengibhode ngisuka kulelithente ngaya kuleliyana, ngisuka endaweni ethile yokuhlala ngisiya kweyinye.  
\v 6 Konke lapho engihambe khona labako-Israyeli, kambe kukhona lapho engike ngathi kubakhokheli babo engabalaya ukuthi beluse abantu bami, “Kungani lingangakhelanga indlu yemisedari na?” ’ 
\pm  
\v 7 Ngakho tshela inceku yami uDavida ukuthi, ‘Nanku okutshiwo \nd nguThixo\nd* uSomandla: Ngakuthatha emadlelweni ekweluseni izimvu, ukuze ube ngumbusi wabantu bami abako-Israyeli.  
\v 8 Ngibe ngilawe lapho obuhamba khona, ngizinqobile zonke izitha zakho phambi kwakho. Ngalokho ibizo lakho ngizalenza libe lodumo olufana lamabizo amadoda adume kakhulu emhlabeni.  
\v 9 Njalo ngizalungisela abantu bami bako-Israyeli indawo engeyabo ngibafake khona labo babe lekhaya labo lapho abangayikuhlutshwa khona. Abantu abagangileyo abasayikubancindezela futhi, njengalokhu abakwenza kuqala  
\v 10 lalokhu asebephikelele ukukwenza kusukela esikhathini engamisa ngaso abakhokheli ebantwini bami u-Israyeli. Ngizazinqoba zonke izitha zakho. 
\pm Ngiyaqinisa kuwe ukuthi \nd uThixo\nd* uzakwakhela indlu:  
\v 11 Kuzakuthi nxa insuku zakho seziphelile ususiya kubokhokho bakho, ngizakwenza inzalo yakho ithathe isikhundla sakho, omunye wamadodana akho, njalo ngizawuqinisa umbuso wakhe.  
\v 12 Lowo nguye ozangakhela indlu yami, ngakho ngizamisa isihlalo sombuso wakhe kuze kube nininini.  
\v 13 Ngizakuba nguyise, yena abe yindodana yami. Angiyikususa uthando lwami kuye, njengalokhu engakwenza kulowo owakwandulelayo.  
\v 14 Ngizambeka yena endlini yami lasembusweni wami kuze kube nininini, lombuso wakhe uzakuma kokuphela.’ ” 
\p  
\v 15 UNathani wabikela uDavida amazwi wonke esambulelo. 
\s1 Umkhuleko KaDavida 
\p  
\v 16 Ngakho inkosi uDavida wangena wahlala phambi \nd kukaThixo\nd*, wasesithi, 
\pm “Ngingubani mina, awu \nd Thixo\nd* Nkulunkulu wami, bayini abendlu yami, lokho okwenze waze wangibeka kulesi isimo?  
\v 17 Kanti njalonje lakho kubuye kukhanye kungathi kakwenelanga emehlweni akho, Oh Nkulunkulu, usukhulume ngelizayo ngendlu yenceku yakho. Ungiphethe Nkulunkulu wami, awu \nd Thixo\nd* Nkulunkulu wami, kungathi ngingomunye wabaphakemeyo kakhulu. 
\pm  
\v 18 Kambe kuyini okunye uDavida angakutsho kuwe ngokuhlonipha okwenze encekwini yakho? Ngoba wena uyayazi inceku yakho,  
\v 19 Oh \nd Thixo\nd*. Ngenxa yenceku yakho, njalo langentando yakho, uyenzile into le enkulu, waziveza obala lezizithembiso ezinkulu kangaka. 
\pm  
\v 20 Kakho ofanana lawe, Oh \nd Thixo\nd*, njalo kakho omunye uNkulunkulu kodwa nguwe kuphela, njengoba sesizwile ngezethu indlebe.  
\v 21 Njalo ngubani ongafanana labantu bakho bako-Israyeli esiyiso sodwa isizwe emhlabeni esiloNkulunkulu owayazikhululela abantu, lokuzenzela ibizo, lokwenza imimangaliso enzima ngokuxotsha izizwe phambi kwabantu bakho, owabakhulula eGibhithe?  
\v 22 Wabenza abantu bakho u-Israyeli baba ngabantu bakho kuze kube nini lanini, njalo wena, \nd Thixo\nd*, usunguNkulunkulu wabo. 
\pm  
\v 23 Lakhathesi, \nd Thixo\nd* akuthi lesosithembiso owasenza encekwini yakho labendlu yayo sigcwaliseke kuze kube nininini. Yenza njengokuthembisa kwakho,  
\v 24 kuze kubonakale ukuthi ibizo lakho lizaphakanyiswa kuze kube nininini. Ngakho abantu bazakuthi, ‘\nd UThixo\nd* uSomandla, uNkulunkulu ka-Israyeli, ngoka-Israyeli uNkulunkulu!’ Kuthi indlu yenceku yakho imiswe phambi kwakho. 
\pm  
\v 25 Wena Nkulunkulu wami ukuveze obala encekwini yakho ukuthi uzayakhela indlu. Ngalokho inceku yakho isithole isibindi sokukhuleka kuwe.  
\v 26 Oh \nd Thixo\nd*, unguNkulunkulu wena! Usuthembise lezizinto ezinhle encekwini yakho.  
\v 27 Ngakho kukuthokozisile ukubusisa indlu yenceku yakho, ukuthi ibe khona phambi kwakho kuze kube nininini ebusweni bakho; ngoba wena, Oh \nd Thixo\nd*, uyibusisile, njalo izabusiswa nini lanini.” 
\c 18  
\s1 Ukunqoba KukaDavida 
\p  
\v 1 Ngokuqhubeka kwesikhathi uDavida wahlasela amaFilistiya wawanqoba, wathumba iGathi lemizana eseduzane layo eyayiphethwe ngamaFilistiya. 
\p  
\v 2 UDavida wanqoba njalo amaMowabi aba ngaphansi kwakhe athela kuye. 
\p  
\v 3 Kanti njalo, uDavida walwa loHadadezeri inkosi yaseZobha, kwaze kwafika eHamathi, esiyamisa umbuso wakhe emangweni olandela uMfula iYufrathe.  
\v 4 UDavida wathumba izinqola zakhe zokulwa eziyinkulungwane, abatshayeli bazo abazinkulungwane eziyisikhombisa lamabutho ahamba phansi azinkulungwane ezingamatshumi amabili. Wawaquma imisila wonke amabhiza ezinqola zokulwa kwasala alikhulu kuphela. 
\p  
\v 5 Kwathi ama-Aramu aseDamaseko ezoncedisa uHadadezeri inkosi yaseZobha, uDavida wawatshaya wawabhuqa ama-Aramu kwafa azinkulungwane ezingamakhulu amabili lambili.  
\v 6 Wenza izinqaba e-Aramu embusweni waseDamaseko, ama-Aramu aba ngaphansi kombuso wakhe athela kuye. \nd UThixo\nd* wanika uDavida ukunqoba kuzozonke izindawo ayezihlasela. 
\p  
\v 7 UDavida wathatha amahawu egolide ayephethwe yizikhulu zikaHadadezeri wawathwalela eJerusalema.  
\v 8 Kusukela eThebha laseKhuni, imizi eyayingekaHadadezeri, uDavida wathatha khona ithusi elinengi kakhulu, lelo uSolomoni enza ngalo uLwandle lwethusi, izinsika lezinye impahla ezabunjwa ngethusi. 
\p  
\v 9 Kuthe lapho Towu inkosi yaseHamathi isizwe ukuthi uDavida usenqobe lonke ibutho likaHadadezeri inkosi yaseZobha,  
\v 10 wathumela indodana yakhe uHadoramu enkosini uDavida ukuthi iyembingelela emenzela amhlophe ngokunqoba uHadadezeri owayekade esilwa impi loTowu. UHadoramu wayethwele imihlobohlobo yezimpahla zegolide lesiliva kanye lezethusi. 
\p  
\v 11 Inkosi uDavida yazahlukanisela \nd kuThixo\nd*, lezo zinto njengalokho eyayikwenze impahla zegolide lesiliva ezazithunjwe kulezozizwe zama-Edomi lamaMowabi, lama-Amoni, lamaFilistiya lama-Amaleki. 
\p  
\v 12 U-Abhishayi indodana kaZeruya watshaya wabhuqa ama-Edomi azinkulungwane ezilitshumi lasificaminwembili eSigodini seTswayi.  
\v 13 Wabeka inkamba zamabutho okulinda e-Edomi, bonke abase-Edomi babangaphansi kombuso kaDavida. \nd UThixo\nd* wapha uDavida ukunqoba kuzozonke izindawo ayesiya kuzo. 
\s1 Iziphathamandla ZikaDavida 
\p  
\v 14 UDavida wabusa kulolonke elako-Israyeli, esenza okuqondileyo lokulungele abantu bakhe bonke. 
\b  
\li1  
\v 15 UJowabi indodana kaZeruya wayephethe amabutho; 
\li1 uJehoshafathi indodana ka-Ahiludi engumlobi, 
\li1  
\v 16 uZadokhi indodana ka-Ahithubi lo-Ahimeleki indodana ka-Abhiyathari babengabaphristi; 
\li1 uShavisha wayengumabhalane; 
\li1  
\v 17 uBhenaya indodana kaJehoyada wayephethe amaKherethi lamaPhelethi, 
\li1 lamadodana kaDavida ayeyizikhulu ayeseduzane lenkosi embusweni. 
\c 19  
\s1 Ukunqotshwa Kwama-Amoni Lama-Aramu 
\p  
\v 1 Kwathi emva kwesikhathi, uNahashi inkosi yama-Amoni wafa, ngakho indodana yakhe yathatha isikhundla yaba yinkosi.  
\v 2 UDavida wacabanga wathi, “Ngizakuba lomusa kuHanuni indodana kaNahashi ngoba uyise wayelomusa kimi.” Ngakho uDavida wathuma izithunywa ukuyakhalela uHanuni ngoyise. 
\p Izithunywa zikaDavida zithe zifika kuHanuni ukuthi zimkhalele elizweni lama-Amoni,  
\v 3 izikhulu zama-Amoni zathi kuHanuni, “Wena nkosi unakana ukuthi uDavida uhlonipha uyihlo ngokuthuma izithunywa zokukukhalela na? Amadoda akhe la kawasizinhloli ezithunywe ukuzahlola umumo welizwe ukuze ahluthune umbuso na?”  
\v 4 Ngenxa yalokho uHanuni wabamba izithunywa zikaDavida, waziphuca, waquma izigqoko zazo zafika ezibunu, wasezixotsha. 
\p  
\v 5 Kwathi uDavida esekuzwile lokho wathuma izithunywa ukuba zihlangabeze izithunywa, njengoba zazihlukuluzwe zayangiswa kakhulu. Inkosi yathi, “Lina hlalani eJerikho indevu zenu zize zikhule, libe selisiza ngapha.” 
\p  
\v 6 Kwathi ama-Amoni esebonile ukuthi asenuka emakhaleni kaDavida, uHanuni lama-Amoni bathumela amathalenta esiliva ayinkulungwane okuqhatsha izinqola zokulwa labatshayeli bazo e-Aramu Naharayimu, le-Aramu-Mahakha laseZobha.  
\v 7 Baqhatsha izinqola zokulwa labatshayeli bazo abazinkulungwane ezingamatshumi amathathu lambili, banxusa lenkosi uMahakha lamabutho akhe, yona eyeza yazakanisa eMedebha labantu bayo, ama-Amoni lawo eqoqana emadolobheni awo aphuma ukuya empini. 
\p  
\v 8 Uthe ekuzwa lokho uDavida, wathumela uJowabi kanye lamabutho akhe wonke.  
\v 9 Ama-Amoni asondela esehlome aphelela emangenelweni edolobho lakibo, kanti amakhosi ayenxusiwe ayejamile lawo wodwa egangeni. 
\p  
\v 10 UJowabi wabona ukuthi kwakulamaviyo amabutho phambi kwakhe langemva kwakhe, ngakho wakhetha amanye amaqhawe athenjiweyo ko-Israyeli wabahlela ukuba bamelane lama-Aramu.  
\v 11 Amanye amabutho ayesele wathi kawalawulwe ngu-Abhishayi umfowabo, wona-ke ajamelana lama-Amoni.  
\v 12 UJowabi wasesithi, “Nxa ama-Aramu ezangikhulela, wena uzangihlomulela; kanti-ke nxa ama-Amoni ezakukhulela lami ngizakuhlomulela.  
\v 13 Qina, kasilwe ngesibindi silwela abantu bakithi lemizi kaNkulunkulu wethu. \nd UThixo\nd* uzakwenza lokho okufaneleyo njengokubona kwakhe.” 
\p  
\v 14 Ngakho uJowabi lamabutho ayelawo wasuka ukuyakulwa lama-Aramu, wona ahle abaleka phambi kwakhe.  
\v 15 Kuthe ama-Amoni ebona ukuthi ama-Aramu ayabaleka, abaleka lawo phambi kuka-Abhishayi umfowabo kaJowabi, abuyela phakathi kwedolobho. Ngakho uJowabi wasebuyela eJerusalema. 
\p  
\v 16 Kwathi ama-Aramu esebonile ukuthi ehlulwe ngama-Israyeli, athuma izithunywa zayaphendula ama-Aramu ayengaphetsheya koMfula, kanye loShofaki umlawuli wamabutho kaHadadezeri lamabutho ayekhokhele. 
\p  
\v 17 Kwathi uDavida esekutsheliwe lokhu, waqoqa bonke abako-Israyeli, wachapha uJodani, wajamelana labo ngamaviyo ayeqondene laye. UDavida walungiselela amaviyo akhe ukudibana lama-Aramu empini, lakanye alwa lawo.  
\v 18 Abaleka ebona u-Israyeli, ngakho uDavida wabulala abatshayeli bezinqola zokulwa abazinkulungwane eziyisikhombisa lamabutho ahamba ngezinyawo azinkulungwane ezingamakhulu amane. Waze wabulala loShofaki umlawuli wamabutho akhona. 
\p  
\v 19 Kwathi izinceku zikaHadadezeri zibona ukuthi zehlulwe ngabako-Israyeli, zaxolisana loDavida, zathela kuye. 
\p Ngakho ama-Aramu awathandanga ukunceda ama-Amoni kusukela lapho. 
\c 20  
\s1 Ukuthunjwa KweRabha 
\p  
\v 1 Kwathi entwasa, ngesikhathi sokuphuma kwezimpi zamakhosi ukuyakulwa, uJowabi wakhokhela amabutho ayehlomile. Watshaya wabhuqa ilizwe lama-Amoni waze wayavimbezela ilizwe laseRabha, kodwa uDavida wasala eJerusalema. UJowabi wahlasela iRabha wayitshiya ingamanxiwa.  
\v 2 UDavida wathatha umqhele owawusekhanda lenkosi yabo isisindo sawo sasilithalenta legolide, uceciswe ngamatshe aligugu, umqhele wasufakwa ekhanda likaDavida. Wathatha impango enengi kakhulu kulelodolobho,  
\v 3 njalo abantu ababelapho wabasusa wabasa lapho ababezasebenza khona gadalala ngamasaha, ngamapiki ensimbi kanye lamahloka. Lokhu uDavida wakwenza kuwo wonke amadolobho ama-Amoni. Kwathi uDavida ngokwakhe kanye lamabutho akhe wonke babuyela eJerusalema. 
\s1 Impi LamaFilistiya 
\p  
\v 4 Ngokuqhubeka kwesikhathi, kwaqhamuka impi yamaFilistiya, eGezeri. Ngalesosikhathi uSibhekhayi umHushathi wabulala uSiphayi, omunye wabosendo lwamaRefayi kwaba yikwehlulwa kwamaFilistiya. 
\p  
\v 5 Kweyinye impi lamaFilistiya, u-Elihanani indodana kaJayiri wabulala uLahimi umfowabo kaGoliyathi umGithi, owayelomkhonto ololuthi olunjengolomeluki. 
\p  
\v 6 Kanti njalo kwenye impi, eyalwelwa eGathi, kwakulendoda enkulu kakhulu ileminwe eyisithupha esandleni ngasinye, lamazwane ayisithupha enyaweni ngalunye, sekubalwa konke ndawonye kungamatshumi amabili lane. Laye wayengowosendo lukaRafa.  
\v 7 Ngokuchothoza kwakhe abako-Israyeli, uJonathani indodana kaShimeya, umfowabo kaDavida, wambulala. 
\p  
\v 8 Laba ngabosendo lukaRafa eGathi, njalo bafela ezandleni zikaDavida lamabutho akhe. 
\c 21  
\s1 UDavida Ubala Amabutho Empi 
\p  
\v 1 USathane wasemelana labako-Israyeli njalo wafuqela uDavida ukuba abale abantu bako-Israyeli.  
\v 2 Ngakho uDavida wathi kuJowabi kanye labalawuli bamabutho, “Hambani liyebala u-Israyeli kusukela eBherishebha kusiya koDani. Beseliphenduka lizongitshela ukuze ngazi ukuthi bangaki khonale.” 
\p  
\v 3 Kodwa uJowabi waphendula wathi, “Sengathi \nd uThixo\nd* angandisa amabutho akhe ngokuphindwe okwedlula ikhulu. Mhlekazi wami nkosi, kambe kabasibantu benkosi yami bonke laba? Inkosi yami ifunelani ukukwenza lokhu? Kungani ithanda ukwehlisela icala phezu kwabako-Israyeli?” 
\p  
\v 4 Loba kwakunjalo, uJowabi wakhulelwa yilizwi lenkosi, ngakho uJowabi walibhoda lonke elako-Israyeli wasebuyela eJerusalema.  
\v 5 UJowabi wafika wabikela uDavida inani lamadoda ayengalwa empini: Kulolonke elako-Israyeli kwakulamadoda ayisigidi lezinkulungwane ezilikhulu ayelakho ukuthi angayiphatha inkemba, kubalwa labazinkulungwane ezingamakhulu amane alamatshumi ayisikhombisa koJuda. 
\p  
\v 6 Kodwa ekubaleni kwakhe uJowabi kazange ahlanganise abaLevi labakaBhenjamini, ngoba umlayo wenkosi wawumnenga.  
\v 7 Kanti njalo lowomlayo wawuyisono phambi kukaNkulunkulu, lakanye wamjezisa u-Israyeli. 
\p  
\v 8 Ngakho uDavida wasesithi kuNkulunkulu, “Ngonile kakhulu phambi kwakho ngokwenza lokhu. Ngakho, ngiyakuncenga, susa umlandu lo encekwini yakho. Ngenze ubuwula obukhulu kakhulu.” 
\p  
\v 9 \nd UThixo\nd* wakhuluma loGadi, umboni kaDavida, wathi:  
\v 10 “Hamba uyetshela uDavida ukuthi, ‘Nanku okutshiwo \nd nguThixo\nd*: Ngikunika ukuthi ukhethe phakathi kokuthathu. Khetha okukodwa okumele ngikwehlisele khona mina.’ ” 
\p  
\v 11 Ngakho uGadi waya kuDavida wathi kuye, “Nanku okutshiwo \nd nguThixo\nd*: ‘Zikhethele wena okufunayo:  
\v 12 iminyaka emithathu yendlala, loba izinyanga ezintathu zokududulwa uxotshwa yizitha zakho, ngenkemba zazo zikukhulela, loba insuku ezintathu zokumelana lenkemba \nd kaThixo\nd*, kuyikuthi kuyabe kuyisifo elizweni, ingilosi \nd kaThixo\nd* iletha incithakalo kulolonke elako-Israyeli.’ Ngakho, khathesi khetha ukuthi ngifike ngithini kulo ongithumileyo.” 
\p  
\v 13 UDavida wathi kuGadi, “Ngisosizini olukhulu kakhulu; kungangcono ngizinikele ezandleni \nd zikaThixo\nd*, ngoba umusa wakhe mkhulu kakhulu; kodwa unganginikeli ezandleni zabantu.” 
\p  
\v 14 Ngakho \nd uThixo\nd* wathumela isifo ko-Israyeli, kwafa amadoda azinkulungwane ezingamatshumi ayisikhombisa ko-Israyeli.  
\v 15 Njalo uNkulunkulu wasethumela ingilosi ukuba iyechitha iJerusalema. Kodwa ingilosi ithe isakwenza lokho, \nd uThixo\nd* wazisola ngencithakalo eyayizakwenzakala wahle wakhuza ingilosi eyayizabhubhisa abantu wathi, “Kwanele! Susa isandla sakho.” Ingilosi \nd kaThixo\nd* ngalesosikhathi yayisimi esizeni sika-Onani umJebusi. 
\p  
\v 16 UDavida wakhangela phezulu wabona ingilosi \nd kaThixo\nd* imi phakathi kwezulu lomhlaba, iphethe inkemba esandleni sayo phezu kweJerusalema. Ngakho uDavida labadala, begqoke amasaka, bawa phansi ngobuso. 
\p  
\v 17 UDavida wathi kuNkulunkulu, “Angithi yimi engithe akubalwe amadoda okulwa na? Yimi engonileyo ngadala isono. Laba abasilutho yizimvu ezilandelayo. Benzeni? Oh \nd Thixo\nd* Nkulunkulu wami, isandla sakho asiwele phezu kwami labendlu yami, kodwa akuthi isifo singasali ebantwini bakho.” 
\s1 UDavida Wakha I-Alithari 
\p  
\v 18 Ngakho ingilosi \nd kaThixo\nd* yathuma uGadi ukuthi ayetshela uDavida ukuthi ayekwakha i-alithari \nd likaThixo\nd* esizeni sika-Onani umJebusi.  
\v 19 Lakanye uDavida walalela ilizwi elakhitshwa nguGadi ngebizo \nd likaThixo\nd*. 
\p  
\v 20 U-Onani esabhula ingqoloyi, wanyemukula wabona ingilosi; amadodana akhe amane ayelaye acatsha.  
\v 21 Kwasekufika uDavida, kuthe u-Onani embona, watshiya ukubhula wayakhothamela uDavida elokhu ebuso bukhothamele phansi. 
\p  
\v 22 UDavida wathi kuye, “Ake ungivumele ngibone isiza sakho sokubhulela amabele ukuze ngakhe i-alithari \nd likaThixo\nd*, ukuze isifo esisebantwini simiswe. Ngithengisela sona ngentengo yaso egcweleyo.” 
\p  
\v 23 U-Onani wathi kuDavida, “Sithathe! Inkosi yami kayenze lokho ebona kuyithokozisa. Khangela, mina ngizaletha inkabi zomnikelo wokutshiswa, lemibhulo yokubhula izakuba zinkuni, ingqoloyi izakuba ngumnikelo wamabele. Konke lokhu ngiyakunika.” 
\p  
\v 24 Kodwa inkosi uDavida yathi ku-Onani, “Hayi, ngifuna ukuthenga ngentengo egcweleyo. Angiyikuthatha okuya \nd kuThixo\nd* okungokwakho, angiyikunikela umnikelo wokutshiswa engingawuthenganga.” 
\p  
\v 25 Ngakho uDavida wanika u-Onani amashekeli egolide angamakhulu ayisithupha ethenga leyondawo.  
\v 26 UDavida wakhela \nd uThixo\nd* i-alithari kuleyondawo wanikela iminikelo yokutshiswa leminikelo yobudlelwano. Wakhuleka \nd kuThixo\nd*, \nd uThixo\nd* wamphendula ngomlilo uvela ezulwini phezu kwe-alithari lomnikelo wokutshiswa. 
\p  
\v 27 Ngakho \nd uThixo\nd* wakhuluma lengilosi, yona yasibuyisela inkemba yayo esikhwameni sayo.  
\v 28 Ngalesosikhathi, uDavida esebonile ukuthi \nd uThixo\nd* wayemphendule esizeni sika-Onani umJebusi, wanikela iminikelo kuleyondawo.  
\v 29 Ithabanikeli \nd likaThixo\nd*, elalakhiwe nguMosi enkangala, kanye le-alithari leminikelo yokutshiswa ngalesosikhathi kwakusendaweni ephakemeyo eGibhiyoni.  
\v 30 Kodwa uDavida wehluleka ukuya khona ukuze abuze kuNkulunkulu ngoba wayesesaba inkemba yengilosi \nd kaThixo\nd*. 
\c 22  
\p  
\v 1 UDavida wasesithi, “Indlu \nd kaThixo\nd* uNkulunkulu izakuba khonapha, kanye le-alithari lomnikelo wokutshiswa ka-Israyeli.” 
\s1 Amalungiselelo Okwakha IThempeli 
\p  
\v 2 Ngakho uDavida wakhupha ilizwi lokuthi bonke abezizweni abahlala ko-Israyeli babuthaniswe, kwathi phakathi kwabo wakhetha ababazi bamatshe ukuze balungise babaze amatshe okwakha indlu kaNkulunkulu.  
\v 3 Wabuthanisa insimbi enengi kakhulu yokwenza izipikili zezivalo lezinsimbi zokuhlanganisa, wabuthanisa lethusi elinengi elingelakulinganiswa.  
\v 4 Wadinga lezigodo zomsedari ezinengi ezingelakubalwa, ngoba amaSidoni labaseThire baletha inani lazo elikhulu kakhulu kuDavida. 
\p  
\v 5 UDavida wasesithi, “Indodana yami uSolomoni isengumntwana njalo ayikabi lolwazi, ngoba phela indlu ezakwakhelwa \nd uThixo\nd* kumele ibe yindlu ebukekayo kakhulu ibe lodumo lesithunzi emehlweni ezizwe zonke. Ngakho ngizalungiselela ukwakhiwa kwayo.” Yikho uDavida walungiselela ngokujulileyo esaphila. 
\p  
\v 6 Wasebiza uSolomoni indodana yakhe, wamlaya ukuthi akhele \nd uThixo\nd*, uNkulunkulu ka-Israyeli indlu.  
\v 7 UDavida wathi kuSolomoni: “Ndodana yami, ngangizimisele ukwakhela iBizo \nd likaThixo\nd*, uNkulunkulu wami indlu.  
\v 8 Kodwa ilizwi \nd likaThixo\nd* lafika kimi lisithi: ‘Wena uchithe igazi elinengi, walwa izimpi ezinengi. Kawuyikwakhela iBizo lami indlu, ngoba uchithe igazi elinengi kakhulu emhlabeni.  
\v 9 Kodwa, uzazala indodana ezakuba ngumuntu othanda ukuthula; ngizayiphumuza ezitheni zayo inxa zonke. Izathiwa nguSolomoni, njalo ngizanika u-Israyeli ukuthula ensukwini zokubusa kwakhe.  
\v 10 Nguye ozakwakhela iBizo lami indlu. Uzakuba yindodana yami, mina ngizakuba nguyise. Njalo ngizaqinisa ubukhosi bakhe ko-Israyeli kuze kube nininini.’ 
\p  
\v 11 Ndodana yami, \nd uThixo\nd* kabe lawe ukuze uphumelele ukwakha indlu \nd kaThixo\nd* uNkulunkulu wakho, njengokutsho kwakhe ngawe.  
\v 12 Sengathi \nd uThixo\nd* angakunika ukuhlakanipha lokuqedisisa, ukuze kuthi lapho ekunika amandla ko-Israyeli, uwulondoloze umlayo \nd kaThixo\nd* uNkulunkulu wakho.  
\v 13 Uzaphumelela nxa unanzelela ukugcina izimiso lemithetho \nd uThixo\nd* ayinika u-Israyeli ngoMosi. Qina, ube lesibindi. Ungesabi utshaywe luvalo. 
\p  
\v 14 Ngayo yonke imizamo yami ngilungisele indlu \nd kaThixo\nd* amathalenta egolide azinkulungwane ezilikhulu, lamathalenta esiliva ayisigidi, lethusi kanye lensimbi okulesisindo esingelakubalwa, lezigodo kanye lamatshe. Lawe ungengezelela kulokho.  
\v 15 Ulezisebenzi ezinengi, ababazi bamatshe, labakha ngamatshe, lababazi, lezingcitshi zemisebenzi yonke,  
\v 16 eyegolide, isiliva, ithusi kanye lensimbi, izingcitshi ezingelakubalwa. Qalisa-ke umsebenzi, \nd uThixo\nd* abe lawe.” 
\p  
\v 17 UDavida waselaya bonke abakhokheli bako-Israyeli ukuba basize uSolomoni indodana yakhe.  
\v 18 Wathi kubo, “\nd uThixo\nd* uNkulunkulu wenu kakho kini na? Kalinikanga ukuthula inxa zonke na? Ngoba unikele abantu belizwe esandleni sami, lelizwe libuswa \nd nguThixo\nd* labantu bakhe.  
\v 19 Ngakho nikelani inhliziyo zenu ekufuneni \nd uThixo\nd* uNkulunkulu wenu. Qalisani ukwakha indlu \nd kaThixo\nd* uNkulunkulu, ukuze ibhokisi lesivumelwano \nd sikaThixo\nd* lezitsha \nd zikaThixo\nd* ezingcwele kungeniswe ethempelini elizakwakhelwa iBizo \nd likaThixo\nd*.” 
\c 23  
\s1 AbaLevi 
\p  
\v 1 Kwathi uDavida esemdala eseluphele, wabeka uSolomoni indodana yakhe ukuba abe yinkosi ko-Israyeli. 
\p  
\v 2 Wasehlanganisa bonke abakhokheli bako-Israyeli, labaphristi kanye labaLevi.  
\v 3 AbaLevi abaleminyaka esukela kwengamatshumi amathathu kusiya phezulu babalwa, inani lamadoda laba zinkulungwane ezingamatshumi amathathu lasificaminwembili.  
\v 4 UDavida wasesithi: “Phakathi kwalaba, abazinkulungwane ezingamatshumi amabili lane bazakhangela ukuqhutshwa komsebenzi wethempeli \nd likaThixo\nd* kuthi abazinkulungwane eziyisithupha bazakuba yizikhulu labahluleli.  
\v 5 Abazinkulungwane ezine bazakuba ngabalindi bamasango kuthi abazinkulungwane ezine badumise \nd uThixo\nd* ngamachacho lezigubhu engizigcinele lowomsebenzi.” 
\b  
\li4  
\v 6 UDavida wehlukanisa abaLevi ngamaxuku kusiya ngamadodana kaLevi: uGeshoni, loKhohathi kanye loMerari. 
\s1 AbakaGeshoni 
\li1  
\v 7 Exukwini labakaGeshoni yilaba: 
\li2 uLadani loShimeyi. 
\li1  
\v 8 Amadodana kaLadani yila: 
\li2 nguJehiyeli owokuqala, loZethami kanye loJoweli, bonke bebathathu. 
\li1  
\v 9 Amadodana kaShimeyi yila: 
\li2 nguShelomothi, loHaziyeli kanye loHarani, bonke bebathathu. 
\li2 Laba babezinhloko zezindlu zenzalo kaLadani. 
\li1  
\v 10 Lamadodana kaShimeyi yila: 
\li2 nguJahathi, loZiza, loJewushi kanye loBheriya. 
\li2 Laba kwakungamadodana kaShimeyi, bonke babebane. 
\li2  
\v 11 UJahathi engowakuqala loZiza engowesibili, kodwa uJewushi loBheriya abazange babelamadodana amanengi, ngakho babalwa njengemuli yinye bahle baphiwa umsebenzi bendawonye. 
\s1 AmaKhohathi 
\li1  
\v 12 Amadodana kaKhohathi yila: 
\li2 ngu-Amramu, lo-Izihari, loHebhroni kanye lo-Uziyeli, bonke babebane. 
\li1  
\v 13 Amadodana ka-Amramu yila: 
\li2 ngu-Aroni loMosi. 
\li2 U-Aroni wehlukaniselwa ukunikela izinto ezingcwele kakhulu \nd kuThixo\nd*, ukuze yena lamadodana akhe batshise impepha phambi \nd kukaThixo\nd* lokumkhonza lokubusisa ngebizo lakhe kuze kube nininini.  
\v 14 Amadodana kaMosi inceku kaNkulunkulu abalwa ndawonye labesizwana sikaLevi. 
\li1  
\v 15 Amadodana kaMosi yila: 
\li2 nguGeshomu lo-Eliyezari. 
\li1  
\v 16 Abosendo lukaGeshomu: 
\li2 nguShubhayeli engowakuqala. 
\li1  
\v 17 Abosendo luka-Eliyezari: 
\li2 nguRehabhiya engowakuqala. 
\li2 U-Eliyezari kazange abe lamanye amadodana kodwa amadodana kaRehabhiya ayemanengi kakhulu. 
\li1  
\v 18 Amadodana ka-Izihari yila: 
\li2 nguShelomithi engowokuqala. 
\li1  
\v 19 Amadodana kaHebhroni yila: 
\li2 nguJeriya engowokuqala, lo-Amariya engowesibili, 
\li2 loJahaziyeli engowesithathu kanye loJekhameyamu owesine. 
\li1  
\v 20 Amadodana ka-Uziyeli yila: 
\li2 nguMikha engowakuqala lo-Ishiya owesibili. 
\s1 AmaMerari 
\li1  
\v 21 Amadodana kaMerari yila: 
\li2 nguMahili loMushi. 
\li1 Amadodana kaMahili yila: 
\li2 ngu-Eliyezari loKhishi. 
\li2  
\v 22 U-Eliyezari wafa engelamadodana: wayelamadodakazi wodwa. Amadodakazi endela kubafowabo, amadodana kaKhishi. 
\li1  
\v 23 Amadodana kaMushi yila: 
\li2 nguMahili, lo-Ederi kanye loJerimothi, bonke bebathathu. 
\b  
\li4  
\v 24 Laba kwakungabosendo lukaLevi ngezindlu zabo, abazinhloko zezindlu njengokulotshwa kwamabizo lokubalwa kwabo ngamunye, okutsho ukuthi, abasebenzayo abaleminyaka engamatshumi amabili kusiya phezulu ababesebenza ethempelini \nd likaThixo\nd*.  
\v 25 Ngoba uDavida wathi: “Njengoba \nd uThixo\nd*, uNkulunkulu ka-Israyeli, enike abantu bakhe ukuthula lokuthi bazahlala eJerusalema kuze kube nininini,  
\v 26 abaLevi akusafanele bathwale ithabanikeli loba kuyini okusetshenziswa ezinkonzweni zalo.”  
\v 27 Njengeziyalezelo zikaDavida zokucina, abaLevi babalwa kusukela kwabaleminyaka engamatshumi amabili kusiya phezulu. 
\b  
\p  
\v 28 Umsebenzi wabaLevi wawungowokuncedisa inzalo ka-Aroni emsebenzini wethempeli \nd likaThixo\nd*: ukugcina amaguma akhona; izindlu ezisemaceleni, ukuhlambulula zonke izinto ezingcwele lokwenza yonke imisebenzi endlini kaNkulunkulu.  
\v 29 Babephethe umsebenzi wesinkwa sokwahlukanisela ethaleni, ifulawa yomnikelo wamabele, lesinkwa esingelamvubelo, ukuxuba lokupheka isinkwa, lezilinganiso zonke zezisindo lobukhulu bakhona.  
\v 30 Njalo babemele beme ngezinyawo ekuseni nsuku zonke ukubonga lokudumisa \nd uThixo\nd*. Kwakufanele benzenjalo lantambama,  
\v 31 lalapho kunikelwa iminikelo yokutshiswa \nd kuThixo\nd* ngamaSabatha, emadilini okuThwasa kweNyanga, lakuyo yonke imikhosi emisiweyo. Babefanele bamsebenzele \nd uThixo\nd* ngazozonke izikhathi ngenani elilingeneyo langendlela ababeyimiselwe. 
\p  
\v 32 Ngakho abaLevi bawenza umsebenzi wabo weThenteni lokuHlanganela, laseNdaweni eNgcwele, ngaphansi kwabafowabo abayisizukulwana sika-Aroni, emsebenzini wethempeli \nd likaThixo\nd*. 
\c 24  
\s1 Izigaba ZabaPhristi 
\p  
\v 1 Lezi yizo izigaba zamadodana ka-Aroni: 
\p Amadodana ka-Aroni nguNadabi, lo-Abhihu, lo-Eliyazari kanye lo-Ithamari.  
\v 2 Kodwa uNadabi lo-Abhihu bafa uyise engakafi, njalo babengelamadodana; ngakho u-Eliyazari lo-Ithamari yibo ababa ngabaphristi.  
\v 3 Ngokuphathisana loZadokhi owosendo luka-Eliyazari kanye lo-Ahimeleki owosendo luka-Ithamari, uDavida wabehlukanisa ngezigaba kusiya ngemisebenzi ababemele bayenze.  
\v 4 Babebanengi abosendo luka-Eliyazari abakhokheli kulabosendo luka-Ithamari ngakho behlukaniswa bamiswa njengalokhu: kwakusiba ngabalitshumi lesithupha kwabosendo luka-Eliyazari abazinhloko labayisificaminwembili kusendo luka-Ithamari.  
\v 5 Babakhetha kungelakubandlulula ngokuphosa inkatho, ngoba zazikhona izikhulu zendawo yokuphephela lezikhulu zikaNkulunkulu phakathi kwabosendo luka-Eliyazari laphakathi koluka-Ithamari. 
\p  
\v 6 Umlobi uShemaya indodana kaNethaneli, umLevi, waloba amabizo abo phambi kwenkosi kanye lezikhulu: uZadokhi umphristi, lo-Ahimeleki indodana ka-Abhiyathari kanye lenhloko zezimuli zabaphristi labaLevi, kuthathwa imuli eyodwa ku-Eliyazari kuphinde kuthathwe imuli eyodwa ku-Ithamari. 
\b  
\li1  
\v 7 Inkatho yakuqala yadla uJehoyaribhi, 
\li1 eyesibili yadla uJedaya, 
\li1  
\v 8 eyesithathu yadla uHarimu, 
\li1 eyesine yadla uSeworimi, 
\li1  
\v 9 eyesihlanu yadla uMalikhija, 
\li1 eyesithupha yadla uMijamini, 
\li1  
\v 10 eyesikhombisa yadla uHakhozi, 
\li1 eyesificaminwembili yadla u-Abhija, 
\li1  
\v 11 eyesificamunwemunye yadla uJeshuwa, 
\li1 eyetshumi yadla uShekhaniya, 
\li1  
\v 12 eyetshumi lanye yadla u-Eliyashibi, 
\li1 eyetshumi lambili yadla uJakhimi, 
\li1  
\v 13 eyetshumi lantathu yadla uHupha, 
\li1 eyetshumi lane yadla uJeshebheyabi, 
\li1  
\v 14 eyetshumi lanhlanu yadla uBhiliga, 
\li1 eyetshumi lesithupha yadla u-Imeri, 
\li1  
\v 15 eyetshumi lesikhombisa yadla uHeziri, 
\li1 eyetshumi lasificaminwembili mibili yadla uHapizezi, 
\li1  
\v 16 eyetshumi lesificamunwemunye yadla uPhethahiya, 
\li1 eyamatshumi amabili yadla uHezekhiyeli, 
\li1  
\v 17 eyamatshumi amabili lanye yadla uJakhini, 
\li1 eyamatshumi amabili lambili yadla uGamuli, 
\li1  
\v 18 eyamatshumi amabili lantathu yadla uDelaya, 
\li1 eyamatshumi amabili lane yadla uMaziya. 
\b  
\p  
\v 19 Yizo lezi izigaba ababehlukaniswe ngazo ukuze benze umsebenzi wokukhonza ekungeneni kwabo ethempelini \nd likaThixo\nd*, ngezimiso ezenzelwa ukhokho wabo u-Aroni, njengokulaywa kwakhe \nd nguThixo\nd*, uNkulunkulu ka-Israyeli. 
\s1 Abanye AbaLevi 
\li4  
\v 20 Kwathi-ke ababesele abosendo lukaLevi: 
\b  
\li1 emadodaneni ka-Amramu: uShubhayeli; 
\li2 emadodaneni kaShubhayeli: nguJehideya. 
\li1  
\v 21 Kuvela kuRehabhiya, amadodana akhe yila: ngu-Ishiya engowokuqala. 
\li1  
\v 22 Kuma-Izihari: nguShelomothi; 
\li2 emadodaneni kaShelomothi; nguJahathi. 
\li1  
\v 23 Amadodana kaHebhroni yila: 
\li2 nguJeriya owokuqala lo-Amariya owesibili, loJahaziyeli owesithathu loJekhameyamu owesine. 
\li1  
\v 24 Indodana ka-Uziyeli: nguMikha; 
\li2 emadodaneni kaMikha nguShamiri. 
\li1  
\v 25 Umfowabo kaMikha: ngu-Ishiya; 
\li2 emadodaneni ka-Ishiya: nguZakhariya. 
\li1  
\v 26 Amadodana kaMerari: nguMahili loMushi. 
\li2 Indodana kaJahaziya: nguBheno. 
\li1  
\v 27 Amadodana kaMerari: 
\li2 Kusuka kuJahaziya: nguBheno, loShohamu, loZakhuri kanye lo-Ibhiri. 
\li1  
\v 28 Kusuka kuMahili: ngu-Eliyezari, ongazange abe lamadodana. 
\li1  
\v 29 Kusukela kuKhishi: indodana kaKhishi: nguJerameli. 
\li1  
\v 30 Njalo lakumadodana kaMushi: nguMahili, lo-Ederi kanye loJerimothi. 
\b  
\li4 Laba kwakungabaLevi, ngezimuli zabo. 
\b  
\p  
\v 31 Labo baphosa inkatho, njengalokhu okwenziwa ngabafowabo abosendo luka-Aroni, phambi kweNkosi uDavida loZadokhi, u-Ahimeleki, labayizinhloko zezimuli zabaphristi kanye lezabaLevi. Imuli yomfowabo omdala yaphathwa njengemuli yomfowabo omncinyane kulabo bonke. 
\c 25  
\s1 Abahlabeleli 
\p  
\v 1 UDavida, elabalawuli bamabutho, wakhetha abanye bamadodana ka-Asafi, uHemani loJeduthuni emsebenzini wokuphrofetha, baphelekezelwa yimihubhe lamachacho lezigubhu. Nantu uluhlu lwamadoda ayesenza lowomsebenzi: 
\b  
\li1  
\v 2 Emadodaneni ka-Asafi: 
\li2 nguZakhuri, loJosefa, loNethaniya kanye lo-Asarela. Amadodana ka-Asafi ayesesandleni sika-Asafi, yena owayephrofetha esesandleni senkosi. 
\li1  
\v 3 NgakuJeduthuni, amadodana akhe yila: 
\li2 nguGedaliya, loZeri, loJeshaya loShimeyi, loHashabhiya kanye loMathithiya, beyisithupha ndawonye, besesandleni sikayise uJeduthuni, owayephrofetha esebenzisa umhubhe ukubonga lokudumisa \nd uThixo\nd*. 
\li1  
\v 4 NgakuHemani, amadodana akhe yila: 
\li2 nguBhukhiya, loMathaniya, lo-Uziyeli, loShubhayeli kanye loJerimothi; uHananiya, loHanani, lo-Eliyatha, loGidalithi loRomamthi-Ezeri; loJoshibhekhasha, loMalothi, loHothiri kanye loMahaziyothi.  
\v 5 Bonke laba kwakungamadodana kaHemani umboni wenkosi. Bona ebaphiwe ngesithembiso sikaNkulunkulu sokumphakamisa. UNkulunkulu wapha uHemani amadodana alitshumi lane lamadodakazi amathathu. 
\b  
\p  
\v 6 Wonke lamadoda ayephethwe ngoyise emsebenzini wokuhlabela ethempelini \nd likaThixo\nd*, ngezigubhu, amachacho lemihubhe enkonzweni endlini kaNkulunkulu. 
\p U-Asafi, loJeduthuni kanye loHemani babengaphansi kwenkosi.  
\v 7 Bona kanye lezihlobo zabo zonke babewufundele umsebenzi wokuhlabelela njalo bengamagabazi okuhlabelela \nd uThixo\nd*, babengamakhulu amabili lamatshumi ayisificaminwembili labantu abayisificaminwembili (288).  
\v 8 Abatsha labadala ngokufanayo, abafundisayo lababefunda, baphosa inkatho. 
\b  
\li1  
\v 9 Inkatho yakuqala eyayingeka-Asafi yawela kuJosefa lamadodana akhe kanye lezihlobo zakhe, belitshumi lambili; 
\li1 eyesibili yawela kuGedaliya, yena kanye lezihlobo lamadodana akhe belitshumi lambili; 
\li1  
\v 10 eyesithathu yawela kuZakhuri, lakumadodana akhe lezihlobo zakhe, belitshumi lambili; 
\li1  
\v 11 eyesine yawela ku-Iziri, lakumadodana akhe lezihlobo zakhe belitshumi lambili; 
\li1  
\v 12 eyesihlanu yawela kuNethaniya, lakumadodana akhe lezihlobo zakhe belitshumi lambili; 
\li1  
\v 13 eyesithupha yawela kuBhukhiya, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 14 eyesikhombisa yawela kuJesarela, lamadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 15 eyesificaminwembili yawela kuJeshayiya, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 16 eyesificamunwemunye yawela kuMathaniya, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 17 eyetshumi yawela kuShimeyi, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 18 eyetshumi lanye yawela ku-Azareli, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 19 eyetshumi lambili yawela kuHashabhiya, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 20 eyetshumi lantathu yawela kuShubhayeli, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 21 eyetshumi lane yawela kuMathithiya, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 22 eyetshumi lanhlanu yawela kuJerimothi, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 23 eyetshumi lesithupha yawela kuHananiya, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 24 eyetshumi lesikhombisa yawela kuJoshibhekhasha, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 25 eyetshumi lasificaminwembili yawela kuHanani, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 26 eyetshumi lesificamunwemunye yawela kuMalothi, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 27 eyamatshumi amabili yawela ku-Eliyatha, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 28 eyamatshumi amabili lanye yawela kuHothiri, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 29 eyamatshumi amabili lambili yawela kuGidalithi, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 30 eyamatshumi amabili lantathu yawela kuMahaziyothi, lakumadodana akhe lezihlobo, belitshumi lambili; 
\li1  
\v 31 eyamatshumi amabili lane yawela kuRomamthi-Ezeri lakumadodana akhe lezihlobo, belitshumi lambili. 
\c 26  
\s1 Abalindi BamaSango 
\li4  
\v 1 Izigaba zabalindi bamasango: 
\b  
\li4 KwabakoKhora: 
\li1 kunguMeshelemiya indodana kaKhora, omunye wamadodana ka-Asafi.  
\v 2 UMeshelemiya wayelamadodana ahlanganisa 
\li2 uZakhariya eyakuqala loJediyeli eyesibili, 
\li2 loZebhadiya eyesithathu, loJathiniyeli eyesine, 
\li2  
\v 3 lo-Elamu eyesihlanu, loJehohanani eyesithupha kanye 
\li2 lo-Eliyehonayi eyesikhombisa. 
\li1  
\v 4 U-Obhedi-Edomi laye wayelamadodana: 
\li2 kunguShemaya eyakuqala, loJehozabhadi eyesibili, 
\li2 loJowa eyesithathu, loSakhari eyesine, 
\li2 loNethaneli eyesihlanu,  
\v 5 lo-Amiyeli eyesithupha, 
\li2 lo-Isakhari eyesikhombisa, kanye loPhewulethayi eyesificaminwembili. 
\li2 (Ngoba uNkulunkulu wayembusisile u-Obhedi-Edomi.) 
\li1  
\v 6 Indodana yakhe uShemaya layo yayilamadodana, ayengabakhokheli kwabendlu kayise ngoba babengamadoda enelisayo.  
\v 7 Amadodana kaShemaya wona yila: 
\li2 ngu-Othini, loRafayeli, lo-Obhedi kanye lo-Elizabhadi; 
\li2 izihlobo zakhe u-Elihu loSemakhiya lazo zazingamadoda ayesenelisa. 
\li4  
\v 8 Bonke laba babengabosendo luka-Obhedi-Edomi; bona kanye lamadodana abo lezihlobo zabo babengamadoda enelisayo belamandla okwenza umsebenzi, bengabosendo luka-Obhedi-Edomi, babengamatshumi ayisithupha lambili (62) sebendawonye. 
\li4  
\v 9 UMeshelemiya wayelamadodana lezihlobo, amadoda ayekhaliphile ayelitshumi lasificaminwembili (18) esendawonye. 
\b  
\li1  
\v 10 UHosa ongumʼMerari wayelamadodana: 
\li2 uShimiri engowakuqala (loba wayengasuye izibulo, uyise wayembeke kulesosikhundla sokuba ngowokuqala), 
\li2  
\v 11 loHilikhiya engowesibili, loThabhaliya engowesithathu kanye 
\li2 loZekhariya engowesine. 
\li4 Amadodana lezihlobo zikaHosa sebendawonye babelitshumi lantathu (13). 
\b  
\li4  
\v 12 Izigaba zabalindi bamasango, kusiya ngabakhokheli bazo, zazilomlandu wokwenza umsebenzi ethempelini \nd likaThixo\nd*, njengokwakusenziwa yizihlobo zabo.  
\v 13 Benza inkatho isango lilinye, kusiya ngemuli, abatsha labadala kufanana. 
\li1  
\v 14 Inkatho yeSango langaseMpumalanga yawela kuShelemiya. 
\li1 Basebesenzela inkatho indodana yakhe uZakhariya owayengumcebisi okhaliphileyo, inkatho yeSango langaseNyakatho yawela kuye. 
\li1  
\v 15 Inkatho yeSango langaseZansi lawela ku-Obhedi-Edomi, amadodana akhe kwathiwa kawalinde isiphala. 
\li1  
\v 16 Inkatho yeSango langaseNtshonalanga kanye leSango leShalekhethi emgwaqweni ongaphezulu laya kuShuphimu loHosa. 
\b  
\li4 Kwalinda abalindi ngabalindi: 
\li1  
\v 17 Kwakusiba labaLevi abayisithupha ngelanga empumalanga, 
\li1 abane ngelanga enyakatho, 
\li1 abane ezansi ngelanga 
\li1 kuthi esiphaleni kube lababili lakhona ngazozonke izikhathi. 
\li1  
\v 18 Phambili ngentshonalanga, kwakulabane emgwaqweni, ababili besegumeni uqobo. 
\b  
\li4  
\v 19 Lezi yizigaba zabalindi bamasango ababengabosendo lukaKhora loMerari. 
\s1 Abagcinisikhwama Lezinye Izikhulu 
\p  
\v 20 Abanye babaLevi babephatha inotho yethempeli likaNkulunkulu leziligugu ezingcwele. 
\p  
\v 21 Abosendo lukaLadani, ababe ngamaGeshoni ngoLadani njalo ababezinhloko zabakaLadani umGeshoni, kwakunguJehiyeli,  
\v 22 amadodana kaJehiyeli, loZethami lomfowabo uJoweli. Laba yibo ababephethe inotho yethempeli \nd likaThixo\nd*. 
\b  
\li4  
\v 23 Kuma-Amramu, ama-Izihari, lamaHebhroni lama-Uziyeli babemi ngalindlela: 
\b  
\li2  
\v 24 uShubhayeli, owosendo lukaGeshomu indodana kaMosi, wayeyisikhulu esasiphethe ezenotho.  
\v 25 Izihlobo zakhe ngo-Eliyezari yilezi: nguRehabhiya indodana yakhe, loJeshaya indodana yakhe, loJoramu indodana yakhe, loZikhiri indodana yakhe loShelomithi indodana yakhe. 
\li2  
\v 26 (UShelomithi lezihlobo zakhe babephethe zonke ezenotho ezingcwele ezazinikelwe yinkosi uDavida, labayizinhloko zezindlu ababengabalawuli bezinkulungwane labalawuli bamakhulu, langabanye abalawuli bamabutho.  
\v 27 Eyinye impango eyayithunjwe ekulweni bayinikela ekulungisweni kwethempeli \nd likaThixo\nd*.  
\v 28 Lakho konke okwakunikelwe nguSamuyeli umboni loSawuli indodana kaKhishi, lo-Abhineri indodana kaNeri loJowabi indodana kaZeruya, lazozonke ezinye ezazinikelwe zazisesandleni sikaShelomithi kanye lezihlobo zakhe.) 
\li2  
\v 29 Kwabaka-Izihari yilaba: 
\li2 UKhenaniya lamadodana akhe baphiwa umsebenzi ngaphandle kwethempeli, beyizikhulu labehluleli kwabako-Israyeli. 
\li2  
\v 30 KwabakaHebhroni yilaba: 
\li2 UHashabhiya lezihlobo zakhe, amadoda enelisayo ayengamakhulu alitshumi layisikhombisa ayekhangele ingxenye ka-Israyeli entshonalanga yeJodani kuwo wonke umsebenzi \nd kaThixo\nd* lokuba yizinceku zenkosi.  
\v 31 AmaHebhroni wona, umkhokheli wawo kwakunguJeriya kusiya ngokulotshwa koluhlu lokuzalana kwezimuli zawo. 
\li2 Kwathi ngomnyaka wamatshumi amane wokubusa kukaDavida kwahlolisiswa kuloluluhlu lwemibhalo, kwafunyanwa ukuthi amadoda akhaliphileyo phakathi kwamaHebhroni ayeseJazeri ngaseGiliyadi.  
\v 32 UJeriya wayelezihlobo ezingamakhulu angamatshumi amabili lesikhombisa, ezazikhaliphile njalo zizinhloko zezimuli zazo, ngakho inkosi uDavida wazibeka ukuthi ziphathe abakoRubheni, abakoGadi lengxenye yesizwana sikaManase kukho konke okwakungokukaNkulunkulu lokuyizindaba zenkosi. 
\c 27  
\s1 Amaviyo Empi 
\li4  
\v 1 Nantu uluhlu lwabako-Israyeli, inhloko zezimuli, abalawuli bezinkulungwane labalawuli bamakhulu, ababesebenzela inkosi kulokho okuqondane lamaviyo empi ayefanele ukuzophisana ngenyanga kuze kuyephela umnyaka. Iviyo lilinye lalilamadoda azinkulungwane ezingamatshumi amabili lane (24,000). 
\b  
\li1  
\v 2 Owayephethe iviyo lakuqala, ngenyanga yakuqala, kwakunguJashobheyamu indodana kaZabhidiyeli. Kwakulamadoda azinkulungwane ezingamatshumi amabili lane (24,000) esigabeni sakhe.  
\v 3 Yena wayengowosendo lukaPherezi njalo eyinduna yezikhulu zonke zamabutho okwenyanga yakuqala. 
\li1  
\v 4 Owayephethe iviyo ngenyanga yesibili kwakunguDodayi wako-Ahohi; uMikhilothi engumkhokheli weviyo lakhe. Kwakulamadoda azinkulungwane ezingamatshumi amabili lane (24,000) eviyweni lakhe. 
\li1  
\v 5 Umlawuli wamabutho wesithathu, owezopho lesithathu, kwakunguBhenaya indodana kaJehoyada umphristi. Wayeyinduna, njalo esigabeni sakhe kwakulamadoda azinkulungwane ezingamatshumi amabili lane (24,000).  
\v 6 Nguyenalo uBhenaya owayeliqhawe phakathi kwamaTshumi amaThathu njalo eyinduna yamaTshumi amaThathu. Indodana yakhe u-Amizabhadi yayiphethe iviyo lakhe. 
\li1  
\v 7 Owesine, owezopho lenyanga yesine, kwakungu-Asaheli umfowabo kaJowabi; indodana yakhe uZebhadiya wasala esethatha isikhundla sakhe. Kwakulamadoda azinkulungwane ezingamatshumi amabili lane (24,000) eviyweni lakhe. 
\li1  
\v 8 Owesihlanu, owezopho lenyanga yesihlanu, kwakungumlawuli uShamihuthi owako-Izira. Kwakulamadoda azinkulungwane ezingamatshumi amabili lane (24,000) eviyweni lakhe. 
\li1  
\v 9 Owesithupha, owezopho lenyanga yesithupha, kwakungu-Ira indodana ka-Ikheshi waseThekhowa. Kwakulamadoda azinkulungwane ezingamatshumi amabili lane (24,000) eviyweni lakhe. 
\li1  
\v 10 Owesikhombisa, owezopho lenyanga yesikhombisa, kwakunguHelezi umPheloni, owako-Efrayimi. Kwakulamadoda azinkulungwane ezingamatshumi amabili lane (24,000) eviyweni lakhe. 
\li1  
\v 11 Owesificaminwembili, owezopho lenyanga yesificaminwembili, kwakunguSibhekhayi umHushathi wakoZera. Kwakulamadoda azinkulungwane ezingamatshumi amabili lane (24,000) eviyweni lakhe. 
\li1  
\v 12 Owesificamunwemunye, owezopho lesificamunwemunye, kwakungu-Abhiyezeri umʼAnathothi owakoBhenjamini. Kwakulamadoda azinkulungwane ezingamatshumi amabili lane (24,000) eviyweni lakhe. 
\li1  
\v 13 Owetshumi, owezopho lenyanga yetshumi, kwakunguMaharayi umNethofa wakoZera. Kwakulamadoda azinkulungwane ezingamatshumi amabili lane (24,000) eviyweni lakhe. 
\li1  
\v 14 Owetshumi lanye, owezopho lenyanga yetshumi lanye, kwakunguBhenaya umPhirathoni wako-Efrayimi. Kwakulamadoda azinkulungwane ezingamatshumi amabili lane (24,000) eviyweni lakhe. 
\li1  
\v 15 Owetshumi lambili, owezopho lenyanga yetshumi lambili, kwakunguHelidayi umNethofa, owemuli ka-Othiniyeli. Kwakulamadoda azinkulungwane ezingamatshumi amabili lane (24,000) eviyweni lakhe. 
\s1 Izikhulu Zezizwana 
\li4  
\v 16 Izikhulu ezizwaneni zako-Israyeli yilezi: 
\b  
\li1 KwabakoRubheni: ngu-Eliyezari indodana kaZikhiri; 
\li1 kwabakoSimiyoni, nguShefathiya indodana kaMahakha; 
\li1  
\v 17 kwabakoLevi: nguHashabhiya indodana kaKhemuweli; 
\li1 kwabako-Aroni: nguZadokhi; 
\li1  
\v 18 kwabakoJuda: ngu-Elihu, umfowabo kaDavida; 
\li1 kwabaka-Isakhari: ngu-Omri indodana kaMikhayeli; 
\li1  
\v 19 kwabakoZebhuluni: ngu-Ishimaya indodana ka-Obhadaya; 
\li1 kwabakoNafithali: nguJerimothi indodana ka-Aziriyeli 
\li1  
\v 20 kwabako-Efrayimi: nguHosheya indodana ka-Azaziya; 
\li1 kwabayingxenye yesizwana sikaManase: nguJoweli indodana kaPhedaya; 
\li1  
\v 21 kwabayingxenye yesizwana sikaManase eGiliyadi: ngu-Ido indodana kaZakhariya; 
\li1 kwabakoBhenjamini: nguJasiyeli indodana ka-Abhineri; 
\li1  
\v 22 kwabakoDani: ngu-Azareli indodana kaJerohamu. 
\b  
\li4 Laba babeyizikhulu ezizwaneni zako-Israyeli. 
\b  
\p  
\v 23 UDavida kazange abhale phansi inani lamadoda ayeleminyaka engamatshumi amabili lababengaphansi kwaleyo, ngoba \nd uThixo\nd* wayethembise ukuthi wayezakwandisa u-Israyeli abe njengezinkanyezi emkhathini.  
\v 24 UJowabi indodana kaZeruya waqalisa ukubala amadoda kodwa kaqedanga. Ulaka lwehlela u-Israyeli ngenxa yalokho kubalwa ngakho inani lelo alibhalwanga encwadini yezindaba zeNkosi uDavida. 
\s1 Abacebisi BeNkosi 
\li1  
\v 25 U-Azimavethi indodana ka-Adiyeli wayephethe iziphala zesikhosini. 
\li1 UJonathani indodana ka-Uziya wayephethe iziphala emaphandleni ezabelweni, emadolobheni, emizini kanye lasezilindweni. 
\li1  
\v 26 U-Eziri indodana kaKhelubi wayephethe izisebenzi emaphandleni ezazilima amasimu. 
\li1  
\v 27 UShimeyi umʼRamathi wayephethe izivini. 
\li1 UZabhidi waseShefama wayephethe izithelo zezivini zokwenza iwayini. 
\li1  
\v 28 UBhali-Hanani umGederi wayephethe izihlahla zama-oliva lomkhiwane wesikhamore emawatheni ezintatshana zasentshonalanga. 
\li1 UJowashi wayephethe amafutha e-oliva. 
\li1  
\v 29 UShithirayi umSharoni wayephethe imihlambi eyayisemadlelweni aseSharoni. 
\li1 UShafathi indodana ka-Adilayi, wayephethe imihlambi ezihotsheni. 
\li1  
\v 30 U-Obhili owako-Ishumayeli wayephethe amakamela, 
\li1 uJehideya owakoMeronothi ephethe ezabobabhemi. 
\li1  
\v 31 UJazizi umHagari wayephethe ezemihlambi yezimvu. 
\li4 Bonke laba babeyizikhulu ezaziphethe impahla zenkosi uDavida. 
\b  
\li1  
\v 32 UJonathani, isihlobo sikaDavida, wayengumcebisi, indoda ehlakaniphileyo njalo engumbhali. 
\li1 UJehiyeli indodana kaHakhimoni wayephethe amadodana enkosi. 
\li1  
\v 33 U-Ahithofeli wayengumcebisi wenkosi. 
\li1 UHushayi owako-Arikhi wayengumngane wenkosi. 
\li4  
\v 34 UJehoyada indodana kaBhenaya nguye owathatha isikhundla sika-Ahithofeli kwalandela u-Abhiyathari. 
\li1 UJowabi wayengumlawuli webutho lenkosi. 
\c 28  
\s1 Amacebo KaDavida Ngokwakhiwa KweThempeli 
\p  
\v 1 UDavida wamema zonke izikhulu zako-Israyeli zabuthana eJerusalema: izikhulu zezizwana, abalawuli bamaviyo emsebenzini wenkosi, abalawuli bezinkulungwane kanye labalawuli bamakhulu, lezikhulu ezaziphethe ezezimpahla lezifuyo zenkosi lamadodana ayo, kanye lezikhulu zesigodlweni, amaqhawe labo bonke ababelezibindi empini. 
\p  
\v 2 Inkosi uDavida yasukuma yathi: “Lalelani, zihlobo labantu bami, bengizimisele ukwakhela ibhokisi lesivumelwano \nd sikaThixo\nd*, indlu yokuhlala njalo kuyisenabelo sikaNkulunkulu wethu, ngaze ngenza amalungiselelo okukufeza lokho.  
\v 3 Kodwa uNkulunkulu wathi kimi: ‘Awuyikulakhela indlu iBizo lami, ngoba wena ungowempi njalo usuchithe igazi.’ 
\p  
\v 4 Kodwa \nd uThixo\nd*, uNkulunkulu ka-Israyeli, wakhetha mina kuyo yonke indlu yakwethu ukuba yinkosi yako-Israyeli kuze kube nininini. Wakhetha uJuda ukuba abe ngumkhokheli, kwathi khona endlini kaJuda wakhetha imuli yakwethu, kwazakuthi emadodaneni kababa kumthokozisile ukungibeka ngibe yinkosi kulolonke elako-Israyeli.  
\v 5 Kuwo wonke amadodana ami njengoba \nd uThixo\nd* engiphe amanengi, umkhethile uSolomoni indodana yami ukuba ahlale esihlalweni sobukhosi esikhosini sombuso \nd kaThixo\nd* ko-Israyeli.  
\v 6 Wathi kimi: ‘USolomoni indodana yakho yiyo ezangakhela indlu yami ilungise lamaguma ami, ngoba ngimkhethile ukuba abe yindodana yami, lami ngizakuba nguyise.  
\v 7 Ngizawuqinisa umbuso wakhe kuze kube nininini nxa eqina ekugcineni imilayo yami lemithetho yami njengalokhu okwenzakalayo lamuhla.’ 
\p  
\v 8 Ngakho-ke phambi kwakhe wonke u-Israyeli, lebandla \nd likaThixo\nd* uNkulunkulu, laphambi kukaNkulunkulu wethu: gcinani linanzelele imilayo \nd kaThixo\nd* uNkulunkulu wenu, ukuze libe lelizwe elihle elizalitshiyela izizukulwane kube yilifa lazo kuze kube nininini. 
\p  
\v 9 Njalo wena ndodana yami, Solomoni, mamukele uNkulunkulu kayihlo, umkhonze ngokuzinikela ngenhliziyo yakho yonke langengqondo yokuvuma, ngoba \nd uThixo\nd* uyihlola yonke inhliziyo kanti uyayazi iminakano lezenzo zonke. Nxa umdinga \nd uThixo\nd*, uzamthola wena, kodwa nxa umfulathela, uzakufulathela yena kuze kube nininini.  
\v 10 Nanzelela-ke ngoba \nd uThixo\nd* ukukhethile ukuba umakhele ithempeli libe yindawo yokukhonzela. Qina wenze umsebenzi.” 
\p  
\v 11 Ngakho uDavida wasenika uSolomoni indodana yakhe umdwebo wesakhiwo sethempeli, lowezindlu zalo, lowezindlu zenotho, lowezindlu zangaphezulu, lowezindlu zangaphakathi, lowendlu yesihlalo somusa.  
\v 12 Wamnika umdwebo wakho konke ayekutshengiswe nguMoya engqondweni yakhe ngamaguma ethempeli \nd likaThixo\nd*, lowezindlu eziwazingelezeleyo, lowendlu yenotho yethempeli, lowendlu yenotho yezinto ezingcwele.  
\v 13 Wamtshela langesimo sezigaba zabaphristi lezabaLevi, langawo wonke umsebenzi wasethempelini \nd likaThixo\nd*, langezitsha zonke zenkonzo,  
\v 14 langesisindo segolide lazozonke izitsha zegolide zaleyo laleyo nkonzo, langesisindo sezitsha zesiliva zaleyo laleyo nkonzo:  
\v 15 langesisindo sezinti zezibane zegolide kanye lezibane zazo, langesisindo segolide salolo lalololuthi lwesibane lezibane zalo, lobunzima besiliva balolo lalololuthi lwesibane lezibane zalo, njengokusetshenziswa kwazo enkonzweni;  
\v 16 langesisindo segolide saleyotafula lezinkwa ezahlukaniselwe uNkulunkulu lesisindo sesiliva esamatafula enziwe ngesiliva;  
\v 17 isisindo segolide elicengekileyo lezinti, imiganu yokuchelisa lezinkezo zakhona, lesisindo saleso lalesositsha segolide, kanye lesaleso lalesositsha sesiliva.  
\v 18 Wamtshela langesimo se-alithare lempepha elenziwe ngegolide elicengekileyo lesisindo salo, langomfanekiso wesihlalo esingamakherubhi egolide achaye amaphiko awo egubuzele ibhokisi lesivumelwano \nd sikaThixo\nd*. 
\p  
\v 19 UDavida wasesithi: “Konke lokhu ngilakho kulotshwe ngesandla \nd sikaThixo\nd* phezu kwami, njalo wanginika ukuzwisisa kukho konke lokhu langokuphelela kwesimo sakhona.” 
\p  
\v 20 Okunye okwatshiwo nguDavida kuSolomoni indodana yakhe yikuthi, “Qina ube lesibindi, njalo uwenze lumsebenzi. Ungesabi njalo ungalahli ithemba ngoba \nd uThixo\nd* uNkulunkulu, uNkulunkulu wami, ulawe. Kawuyikwehluleka njalo kayikukufulathela kuze kube sekupheleni komsebenzi wethempeli \nd likaThixo\nd*.  
\v 21 Izigaba zabaphristi labaLevi sebelindele wonke umsebenzi wethempeli likaNkulunkulu, njalo kuzakuthi bonke abazinikeleyo bakuphathise ngobungcitshi babo obupheleleyo kuyo yonke imisebenzi. Izikhulu labantu bonke zizayamukela yonke imilayo yakho.” 
\c 29  
\s1 Izipho Zokwakha IThempeli 
\p  
\v 1 Inkosi uDavida yathi ebandleni lonke: “Indodana yami uSolomoni, yena kanye osekhethwe nguNkulunkulu, usesengumfana njalo usesemutsha. Umsebenzi mkhulu, ngoba lesisakhiwo sobukhosi ayisiso esomuntu kodwa \nd ngesikaThixo\nd* uNkulunkulu.  
\v 2 Sengilungiselele ngayo yonke inzuzo engilayo ukwakhiwa kwethempeli likaNkulunkulu wami, igolide lokwenza izinto zegolide, isiliva sokwenza izinto zesiliva, ithusi lokwenza izinto zethusi, lensimbi yokwenza izinto zensimbi, lezigodo zokwenza izinto zezigodo, kanye lohlobo lwamatshe e-onikisi, lamatshe okubekwa, lamatshe okucecisa, lalemibala, lenhlobonhlobo zonke zamatshe amahle lamatshe alukhuni amanengi, konke lokhu ngikubuthelele ngakunengi.  
\v 3 Ngaphandle kwalokho, ngenxa yokutshisekela kwami ithempeli likaNkulunkulu wami, manje senginikela inotho yami yegolide lesiliva ethempelini likaNkulunkulu wami ngaphezu kwakho konke engikulethileyo ethempelini leli elingcwele:  
\v 4 ngamathalenta egolide azinkulungwane ezintathu egolide (igolide lase-Ofiri) lamathalenta esiliva esicengekileyo azinkulungwane eziyisikhombisa okokugudula ngalo imiduli yezindlu,  
\v 5 okomsebenzi wegolide lokomsebenzi wesiliva lokwawo wonke umsebenzi ozakwenziwa yizingcitshi. Ngakho, ngubani ofuna ukuzinikela \nd kuThixo\nd* lamuhla?” 
\p  
\v 6 Abazinhloko zezindlu, izikhulu zezizwana zako-Israyeli, abalawuli bezinkulungwane labalawuli bamakhulu, lezikhulu ezazikhangele ngokuqhutshwa komsebenzi wenkosi bapha ngokuzinikela.  
\v 7 Banikela emsebenzini wethempeli likaNkulunkulu amathalenta azinkulungwane ezinhlanu lezinhlamvu zegolide ezizinkulungwane ezilitshumi, lamathalenta esiliva azinkulungwane ezilitshumi, amathalenta ethusi azinkulungwane ezilitshumi lasificaminwembili mibili, lamathalenta azinkulungwane ezilikhulu ensimbi.  
\v 8 Loba ngubani owayelamatshe aligugu wawanikela endlini yenotho yethempeli \nd likaThixo\nd* yona eyayiphethwe nguJehiyeli umGeshoni.  
\v 9 Abantu baba lokujabula okukhulu bebona ukuzinikela kwabakhokheli babo, ngoba banikela \nd kuThixo\nd* ngokukhululeka langezinhliziyo zabo zonke. UDavida inkosi laye wajabula kakhulu. 
\s1 Umkhuleko KaDavida 
\p  
\v 10 UDavida wamdumisa \nd uThixo\nd* phambi kwebandla lonke esithi: 
\q1 “Kawudunyiswe, Wena \nd Thixo\nd*, 
\q2 Nkulunkulu ka-Israyeli ukhokho, 
\q2 kusukela nininini kuze kube nininini. 
\q1  
\v 11 Bungobakho, Oh \nd Thixo\nd*, ubukhulu lamandla 
\q2 lodumo lobukhosi lenkazimulo, 
\q2 ngoba konke okusezulwini lokusemhlabeni kungokwakho. 
\q1 Bungobakho, Oh \nd Thixo\nd*, ubukhosi; 
\q2 uphakeme wena phezu konke. 
\q1  
\v 12 Inotho lodumo kuvela kuwe; 
\q2 ungumbusi wazo zonke izinto. 
\q1 Esandleni sakho kukhona ukuqina lamandla. 
\q2 Kukuwe ukuphakamisa lokupha amandla kubo bonke. 
\q1  
\v 13 Siyakubonga khathesi, Nkulunkulu wethu, 
\q2 silidumisa ibizo lakho elilodumo. 
\p  
\v 14 Kodwa mina ngiyini, bayini abantu bami, ukuthi sinikele ngenhliziyo yonke na? Konke kuvela kuwe, thina sikunike kuphela lokho okuvela esandleni sakho.  
\v 15 Singabezizweni lezethekeli emehlweni akho, njengoba labokhokho bethu bonke babenjalo. Insuku zethu emhlabeni ziyafanana lesithunzi, asisilutho, kalikho ithemba.  
\v 16 Oh \nd Thixo\nd* Nkulunkulu wethu, lokhu esesikunikele ngobunengi bakho ekwakhiweni kwethempeli eliyindawo yeBizo lakho eliNgcwele, kuvela esandleni sakho, njalo konke kuvele kungokwakho.  
\v 17 Ngiyazi, Nkulunkulu wami, uhlola inhliziyo njalo uyabuthanda ubuqotho. Zonke lezizinto ngizinikele ngokufisa langenhliziyo yobuqotho. Khathesi ngikhangele ngentokozo abantu bakho abalapha ukuthi banikele ngesifiso kuwe.  
\v 18 Oh \nd Thixo\nd*, Nkulunkulu wabobaba o-Abhrahama, lo-Isaka lo-Israyeli, yenza inhliziyo zabantu bakho zime ngalokhu kulangatha, njalo inhliziyo zabo zibe kuwe kuze kube nininini.  
\v 19 Phana uSolomoni, indodana yami, inhliziyo epheleleyo ukuze agcine imilayo yakho lemithetho yakho lezimiso zakho, lokuthi akhe lesisakhiwo esiyisigodlo mina esengisilungiselele.” 
\p  
\v 20 UDavida wasesithi kulolonke ibandla, “Dumisani \nd uThixo\nd* uNkulunkulu wenu.” Ngakho bonke bamdumisa \nd uThixo\nd*, uNkulunkulu wabokhokho babo, bathi mbo ngobuso phansi, bekhonza \nd uThixo\nd*, behlonipha lenkosi. 
\s1 USolomoni Ugcotshwa Ubukhosi 
\p  
\v 21 Ngosuku olulandelayo banikela imihlatshelo \nd kuThixo\nd* leminikelo yokutshiswa: inkunzi eziyinkulungwane, lenqama eziyinkulungwane lamazinyane amaduna ayinkulungwane, leminikelo yokunathwayo, layo yonke eminye imihlatshelo banikela ngokunengi benikelela bonke abako-Israyeli.  
\v 22 Badla banatha ngokujabula okukhulu ngalolosuku phambi \nd kukaThixo\nd*. 
\p Basebememukela okwesibili uSolomoni indodana kaDavida, bamgcoba phambi \nd kukaThixo\nd* ukuthi abe ngumbusi, kuthi uZadokhi abe ngumphristi.  
\v 23 USolomoni wasebusa embusweni \nd kaThixo\nd* esikhundleni sikayise uDavida. Waphumelela njalo wonke u-Israyeli wamlalela.  
\v 24 Izikhulu zonke kanye lamaqhawe, ndawonye lamadodana eNkosi uDavida bazinikela ngaphansi kombuso weNkosi uSolomoni. 
\p  
\v 25 \nd UThixo\nd* wamphakamisa kakhulu uSolomoni wamnika isithunzi phezu kwabo bonke abako-Israyeli, njalo wamnika ubukhosi obungazange bube khona esikhosini kwabako-Israyeli. 
\s1 Ukufa KukaDavida 
\p  
\v 26 UDavida indodana kaJese wayeyinkosi yabo bonke abako-Israyeli.  
\v 27 Wabusa kwabako-Israyeli iminyaka engamatshumi amane, eyisikhombisa eHebhroni kwathi engamatshumi amathathu lantathu eJerusalema.  
\v 28 Wafa eseluphele eseleminyaka eminengi kakhulu lenotho lodumo; uSolomoni indodana yakhe waba yinkosi esikhundleni sakhe. 
\p  
\v 29 Izehlakalo zombuso weNkosi uDavida kusukela ekuqaleni kuze kube sekupheleni, zilotshiwe egwalweni lwembali kaSamuyeli umboni, egwalweni lwembali kaNathani umphrofethi kanye lasegwalweni lwembali kaGadi umboni.  
\v 30 Kubalwa ukubusa kwakhe ngokugcweleyo, amandla lakho konke okwakusenzakala kuye lakwabako-Israyeli leminye imibuso yawo wonke amanye amazwe.