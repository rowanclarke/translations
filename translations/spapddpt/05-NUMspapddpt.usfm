\s1 Ley sobre los votos  
\p
\v 1 \w Moisés|strong="H4872"\w* habló \w a|strong="H3068"\w* \w los|strong="H1121"\w* jefes \w de|strong="H1121"\w* las tribus \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*: Esta es \w la|strong="H3605"\w* Palabra \w que|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w*:  
\v 2 \wj Cuando un \+w hombre|strong="H1121"\+w* haga voto \+w a|strong="H3068"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*, \+w o|strong="H3068"\+w* jure para imponerse una promesa, no quebrantará su \+w palabra|strong="H1697"\+w*. Todo \+w lo|strong="H1697"\+w* \+w que|strong="H1697"\+w* salga \+w de|strong="H1121"\+w* su boca \+w lo|strong="H1697"\+w* cumplirá.\wj*   
\p
\v 3 \wj \+w También|strong="H3318"\+w*, \+w si|strong="H3588"\+w* una mujer \+w hace|strong="H6213"\+w* un \+w voto|strong="H5087"\+w* \+w a|strong="H3068"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*, \+w y|strong="H3588"\+w* \+w se|strong="H5921"\+w* impone una obligación \+w en|strong="H5921"\+w* \+w su|strong="H3588"\+w* juventud \+w mientras|strong="H3588"\+w* \+w está|strong="H5921"\+w* \+w en|strong="H5921"\+w* casa \+w de|strong="H5921"\+w* \+w su|strong="H3588"\+w* padre,\wj*  
\v 4 \wj \+w y|strong="H3588"\+w* \+w su|strong="H3588"\+w* padre escucha \+w su|strong="H3588"\+w* \+w voto|strong="H5087"\+w* \+w y|strong="H3588"\+w* \+w la|strong="H3588"\+w* obligación \+w que|strong="H3588"\+w* se impuso, \+w y|strong="H3588"\+w* \+w su|strong="H3588"\+w* padre nada le dice, \+w entonces|strong="H3588"\+w* todos \+w los|strong="H3588"\+w* \+w votos|strong="H5087"\+w* \+w de|strong="H3588"\+w* ella \+w y|strong="H3588"\+w* toda \+w promesa|strong="H5087"\+w* \+w que|strong="H3588"\+w* se impuso serán firmes.\wj*  
\v 5 \wj Pero \+w si|strong="H5921"\+w* su padre \+w se|strong="H5921"\+w* \+w lo|strong="H5921"\+w* prohíbe \+w el|strong="H5921"\+w* día cuando \+w se|strong="H5921"\+w* entera, \+w ninguno|strong="H3605"\+w* \+w de|strong="H5921"\+w* sus \+w votos|strong="H5088"\+w* \+w o|strong="H3068"\+w* promesas \+w que|strong="H5921"\+w* \+w se|strong="H5921"\+w* impuso será \+w firme|strong="H6965"\+w*. \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w la|strong="H5921"\+w* perdonará \+w por|strong="H5921"\+w* \+w cuanto|strong="H5921"\+w* su padre \+w se|strong="H5921"\+w* opuso.\wj*   
\p
\v 6 \wj \+w Pero|strong="H3588"\+w* \+w si|strong="H3588"\+w* \+w es|strong="H3588"\+w* casada \+w y|strong="H3588"\+w* hace \+w votos|strong="H5088"\+w*, \+w o|strong="H3068"\+w* pronuncia \+w con|strong="H5921"\+w* sus labios \+w cosa|strong="H3605"\+w* \+w con|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w cual|strong="H5315"\+w* obligue \+w su|strong="H3588"\+w* \+w alma|strong="H5315"\+w*,\wj*  
\v 7 \wj \+w y|strong="H5921"\+w* su esposo oye, \+w y|strong="H5921"\+w* \+w cuando|strong="H1961"\+w* oye \+w se|strong="H1961"\+w* calla, \+w los|strong="H5921"\+w* \+w votos|strong="H5088"\+w* \+w de|strong="H5921"\+w* \+w ella|strong="H5921"\+w* \+w y|strong="H5921"\+w* \+w la|strong="H5921"\+w* obligación \+w que|strong="H5921"\+w* \+w se|strong="H1961"\+w* impuso \+w serán|strong="H1961"\+w* firmes.\wj*  
\v 8 \wj Pero \+w si|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w día|strong="H3117"\+w* \+w cuando|strong="H3117"\+w* su esposo \+w la|strong="H5921"\+w* \+w oye|strong="H8085"\+w*, \+w se|strong="H5921"\+w* \+w lo|strong="H5921"\+w* prohíbe, \+w entonces|strong="H3117"\+w* anulará \+w el|strong="H5921"\+w* \+w voto|strong="H5088"\+w* bajo \+w el|strong="H5921"\+w* \+w cual|strong="H5315"\+w* \+w ella|strong="H5921"\+w* \+w está|strong="H6965"\+w* \+w y|strong="H5921"\+w* \+w la|strong="H5921"\+w* declaración imprudente \+w de|strong="H5921"\+w* sus labios \+w con|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w cual|strong="H5315"\+w* \+w se|strong="H5921"\+w* comprometió, \+w y|strong="H5921"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w la|strong="H5921"\+w* perdonará.\wj*   
\p
\v 9 \wj Pero \+w el|strong="H5921"\+w* \+w voto|strong="H5088"\+w* \+w de|strong="H5921"\+w* una viuda \+w o|strong="H3068"\+w* una repudiada, todo aquello \+w con|strong="H5921"\+w* \+w lo|strong="H5921"\+w* \+w cual|strong="H5315"\+w* \+w se|strong="H5921"\+w* comprometió, será firme \+w para|strong="H5921"\+w* \+w ella|strong="H5921"\+w*.\wj*   
\p
\v 10 \wj Sin embargo, \+w si|strong="H5921"\+w* \+w hizo|strong="H5088"\+w* \+w voto|strong="H5088"\+w* cuando estaba \+w en|strong="H5921"\+w* casa \+w de|strong="H5921"\+w* su esposo, \+w y|strong="H5921"\+w* ligó su \+w alma|strong="H5315"\+w* \+w con|strong="H5921"\+w* obligación \+w de|strong="H5921"\+w* juramento,\wj*  
\v 11 \wj \+w y|strong="H5921"\+w* su esposo oyó, \+w y|strong="H5921"\+w* calló ante ello, \+w y|strong="H5921"\+w* \+w no|strong="H5921"\+w* \+w se|strong="H5921"\+w* \+w lo|strong="H5921"\+w* prohibió, entonces todos sus \+w votos|strong="H5087"\+w* \+w y|strong="H5921"\+w* \+w toda|strong="H5921"\+w* obligación \+w con|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w cual|strong="H5315"\+w* ligó su \+w alma|strong="H5315"\+w* serán firmes.\wj*  
\v 12 \wj Pero \+w si|strong="H3808"\+w* su esposo \+w en|strong="H5921"\+w* verdad \+w los|strong="H5921"\+w* anula \+w el|strong="H5921"\+w* día cuando \+w los|strong="H5921"\+w* \+w oye|strong="H8085"\+w*, \+w todo|strong="H3605"\+w* \+w lo|strong="H3808"\+w* \+w que|strong="H3808"\+w* salió \+w de|strong="H5921"\+w* sus labios \+w en|strong="H5921"\+w* \+w cuanto|strong="H5921"\+w* \+w a|strong="H3068"\+w* sus \+w votos|strong="H5088"\+w*, \+w o|strong="H3068"\+w* \+w en|strong="H5921"\+w* \+w cuanto|strong="H5921"\+w* \+w a|strong="H3068"\+w* obligarse \+w a|strong="H3068"\+w* \+w ella|strong="H5921"\+w* misma, \+w será|strong="H3808"\+w* nulo. Su esposo \+w los|strong="H5921"\+w* anuló, \+w y|strong="H5921"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w la|strong="H5921"\+w* perdonará.\wj*  
\v 13 \wj \+w Todo|strong="H3605"\+w* \+w voto|strong="H5088"\+w* y \+w todo|strong="H3605"\+w* juramento \+w que|strong="H3808"\+w* \+w la|strong="H3605"\+w* obligue \+w a|strong="H3068"\+w* humillarse \+w a|strong="H3068"\+w* \+w ella|strong="H3605"\+w* misma, su esposo \+w lo|strong="H3808"\+w* confirmará \+w o|strong="H3068"\+w* anulará.\wj*  
\v 14 \wj Pero \+w si|strong="H5315"\+w* su esposo calla ante ello de día en día, entonces \+w confirmó|strong="H6965"\+w* \+w todos|strong="H3605"\+w* sus \+w votos|strong="H5088"\+w* y \+w todas|strong="H3605"\+w* las obligaciones \+w que|strong="H3605"\+w* están sobre \+w ella|strong="H3605"\+w*. Las \+w confirma|strong="H6965"\+w* por cuanto calló ante ello \+w el|strong="H3605"\+w* día cuando \+w lo|strong="H3605"\+w* oyó.\wj*  
\v 15 \wj \+w Si|strong="H3588"\+w* \+w los|strong="H5921"\+w* anula \+w después|strong="H5921"\+w* \+w de|strong="H5921"\+w* oírlos, \+w entonces|strong="H3117"\+w* \+w él|strong="H5921"\+w* llevará \+w la|strong="H5921"\+w* iniquidad \+w de|strong="H5921"\+w* \+w ella|strong="H5921"\+w*.\wj*   
\p
\v 16 Estos son los Estatutos que \nd \+w Yavé|strong="H3068"\+w*\nd* ordenó \w a|strong="H3068"\w* Moisés sobre las relaciones entre el esposo y su esposa, y entre el padre y su hija durante la juventud de ésta en casa de su padre.   
\c 31  
\s1 Derrota de los madianitas  
\p
\v 1 \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*:  
\v 2 \wj Toma \+w venganza|strong="H5360"\+w* completa \+w de|strong="H1121"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w* \+w contra|strong="H3478"\+w* \+w los|strong="H1121"\+w* madianitas. Después serás reunido \+w a|strong="H3068"\+w* tu \+w pueblo|strong="H5971"\+w*.\wj*   
\p
\v 3 Entonces \w Moisés|strong="H4872"\w* \w habló|strong="H1696"\w* \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w*: Armen \w a|strong="H3068"\w* algunos hombres \w de|strong="H5921"\w* \w entre|strong="H5921"\w* ustedes \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w guerra|strong="H6635"\w*, \w y|strong="H5921"\w* vayan \w contra|strong="H5921"\w* \w Madián|strong="H4080"\w* \w para|strong="H5921"\w* ejecutar \w la|strong="H5921"\w* \w venganza|strong="H5360"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w contra|strong="H5921"\w* \w Madián|strong="H4080"\w*.  
\v 4 \w Enviarán|strong="H7971"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w guerra|strong="H6635"\w* 1.000 de \w cada|strong="H3605"\w* \w tribu|strong="H4294"\w*, de \w todas|strong="H3605"\w* las \w tribus|strong="H4294"\w* de \w los|strong="H3605"\w* hijos de \w Israel|strong="H3478"\w*.  
\v 5 Así fueron dados de los millares de \w Israel|strong="H3478"\w* 1.000 de cada \w tribu|strong="H4294"\w*, 12.000 en pie de \w guerra|strong="H6635"\w*.  
\v 6 \w Moisés|strong="H4872"\w* \w los|strong="H1121"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* la \w guerra|strong="H6635"\w*, 1.000 \w de|strong="H1121"\w* cada \w tribu|strong="H4294"\w*. Finees, \w hijo|strong="H1121"\w* del \w sacerdote|strong="H3548"\w* Eleazar, \w fue|strong="H6635"\w* con \w ellos|strong="H3027"\w*, con \w los|strong="H1121"\w* objetos \w sagrados|strong="H6944"\w* y con las \w trompetas|strong="H2689"\w* en su \w mano|strong="H3027"\w* para la \w alarma|strong="H8643"\w*.   
\p
\v 7 \w Como|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, hicieron guerra \w contra|strong="H5921"\w* \w Madián|strong="H4080"\w* \w y|strong="H5921"\w* \w mataron|strong="H2026"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w varones|strong="H2145"\w*.  
\v 8 \w Entre|strong="H5921"\w* \w el|strong="H5921"\w* resto \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w muertos|strong="H2491"\w*, \w mataron|strong="H2026"\w* también \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Madián|strong="H4080"\w*: Evi, Requem, Zur, \w Hur|strong="H2354"\w* \w y|strong="H5921"\w* Reba, \w cinco|strong="H2568"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Madián|strong="H4080"\w*. También \w mataron|strong="H2026"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w Balaam|strong="H1109"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Beor.  
\v 9 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* tomaron cautivas \w a|strong="H3068"\w* las mujeres \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w madianitas|strong="H4080"\w*, \w a|strong="H3068"\w* sus pequeños, \w todo|strong="H3605"\w* su \w ganado|strong="H4735"\w* y \w todos|strong="H3605"\w* sus rebaños. Arrebataron \w toda|strong="H3605"\w* su riqueza.  
\v 10 Incendiaron también \w todas|strong="H3605"\w* sus \w ciudades|strong="H5892"\w*, \w aldeas|strong="H2918"\w* y \w campamentos|strong="H2918"\w*.  
\v 11 \w Tomaron|strong="H3947"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w despojo|strong="H7998"\w* y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* botín, tanto de personas como de animales.  
\v 12 Llevaron \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w cautivos|strong="H7628"\w*, \w el|strong="H5921"\w* botín \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w despojo|strong="H7998"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w al|strong="H5921"\w* \w sacerdote|strong="H3548"\w* Eleazar \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* congregación \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w al|strong="H5921"\w* \w campamento|strong="H4264"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* llanuras \w de|strong="H5921"\w* \w Moab|strong="H4124"\w* \w que|strong="H5921"\w* están \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w Jordán|strong="H3383"\w*, frente \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w*.   
\p
\v 13 Entonces \w Moisés|strong="H4872"\w*, \w el|strong="H3605"\w* \w sacerdote|strong="H3548"\w* Eleazar y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* jefes de \w la|strong="H3605"\w* congregación \w salieron|strong="H3318"\w* \w a|strong="H3068"\w* recibirlos \w en|strong="H3318"\w* las afueras del \w campamento|strong="H4264"\w*.  
\v 14 \w Moisés|strong="H4872"\w* \w se|strong="H5921"\w* enojó \w contra|strong="H5921"\w* \w los|strong="H5921"\w* oficiales \w del|strong="H5921"\w* \w ejército|strong="H2428"\w*, \w los|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* miles \w y|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* cientos \w que|strong="H5921"\w* regresaron \w del|strong="H5921"\w* servicio \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w guerra|strong="H4421"\w*.   
\p
\v 15 \w Moisés|strong="H4872"\w* les preguntó: ¿Dejaron con \w vida|strong="H2421"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las mujeres?  
\v 16 ¡Miren! \w Ellas|strong="H2007"\w* \w fueron|strong="H1961"\w* \w las|strong="H5921"\w* \w que|strong="H5921"\w*, \w por|strong="H5921"\w* \w consejo|strong="H1697"\w* \w de|strong="H5921"\w* \w Balaam|strong="H1109"\w*, indujeron \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* apostatar \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w asunto|strong="H1697"\w* \w de|strong="H5921"\w* Peor, \w por|strong="H5921"\w* \w lo|strong="H1697"\w* cual \w hubo|strong="H1961"\w* \w mortandad|strong="H4046"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* congregación \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 17 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w maten|strong="H2026"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w varones|strong="H2145"\w* entre \w los|strong="H3605"\w* \w niños|strong="H2945"\w* de ellas y \w maten|strong="H2026"\w* \w a|strong="H3068"\w* \w toda|strong="H3605"\w* mujer \w que|strong="H6258"\w* tuvo contacto carnal \w con|strong="H4904"\w* \w varón|strong="H2145"\w*.  
\v 18 Pero dejen \w con|strong="H4904"\w* \w vida|strong="H2421"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las jóvenes \w que|strong="H3808"\w* \w no|strong="H3808"\w* tuvieron contacto carnal \w con|strong="H4904"\w* \w varón|strong="H2145"\w*.   
\p
\v 19 En cuanto \w a|strong="H3068"\w* ustedes, permanezcan \w fuera|strong="H2351"\w* del \w campamento|strong="H4264"\w* durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w*. \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3117"\w* \w mataron|strong="H2026"\w* \w a|strong="H3068"\w* una \w persona|strong="H5315"\w*, y \w los|strong="H3605"\w* \w que|strong="H3117"\w* tocaron un cadáver, se purificarán en \w el|strong="H3605"\w* \w tercero|strong="H7992"\w* y \w el|strong="H3605"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w*, tanto ustedes \w como|strong="H5060"\w* sus prisioneros.  
\v 20 Purifiquen también \w toda|strong="H3605"\w* ropa, \w todo|strong="H3605"\w* objeto de \w piel|strong="H5785"\w*, \w toda|strong="H3605"\w* \w obra|strong="H4639"\w* de pelo de \w cabra|strong="H5795"\w* y \w todo|strong="H3605"\w* utensilio de \w madera|strong="H6086"\w*.   
\p
\v 21 El \w sacerdote|strong="H3548"\w* Eleazar dijo \w a|strong="H3068"\w* los hombres del \w ejército|strong="H6635"\w* que llegaron de \w la|strong="H2063"\w* \w guerra|strong="H4421"\w*: \w Este|strong="H2063"\w* \w es|strong="H2063"\w* el \w estatuto|strong="H2708"\w* de \w la|strong="H2063"\w* \w Ley|strong="H8451"\w* que \nd \+w Yavé|strong="H3068"\+w*\nd* \w mandó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*:  
\v 22 Solo el \w oro|strong="H2091"\w*, la \w plata|strong="H3701"\w*, el bronce, el \w hierro|strong="H1270"\w*, el estaño y el plomo,  
\v 23 \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H3808"\w* resiste \w el|strong="H3605"\w* fuego, \w lo|strong="H1697"\w* harán \w pasar|strong="H5674"\w* \w por|strong="H1697"\w* fuego y \w será|strong="H3808"\w* puro. \w Sin|strong="H3808"\w* embargo \w será|strong="H3808"\w* purificado con las \w aguas|strong="H4325"\w* para limpiar \w la|strong="H3605"\w* impureza. \w Todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* resista \w el|strong="H3605"\w* fuego, \w lo|strong="H1697"\w* harán \w pasar|strong="H5674"\w* \w por|strong="H1697"\w* \w el|strong="H3605"\w* \w agua|strong="H4325"\w*.  
\v 24 \w El|strong="H4264"\w* \w día|strong="H3117"\w* \w séptimo|strong="H7637"\w* lavarán sus ropas y quedarán puros. Después podrán entrar en \w el|strong="H4264"\w* \w campamento|strong="H4264"\w*.   
\s1 Ley sobre el botín  
\p
\v 25 También \nd \+w Yavé|strong="H3068"\+w*\nd* habló \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*:  
\v 26 \wj Tú, el \+w sacerdote|strong="H3548"\+w* Eleazar y los \+w jefes|strong="H7218"\+w* de las casas paternas de la congregación hagan el recuento del botín \+w que|strong="H5712"\+w* se capturó, tanto de personas como de animales.\wj*  
