\id LAM  - Guajajara Bible -Brazil 2007 (DBL 2013) 
\h ZEMUMIKAHY HAW 
\toc1 Zemumikahy haw 
\toc2 Lamentações de Jeremias 
\toc3 Lm 
\mt1 ZEMUMIKAHY HAW  
\c 1  
\s1 Zeruzarez pe har wazemumikahy haw  
\q1
\v 1 Azeharomoete naheta kwaw teko Zeruzarez pe wà.  
\q1 Kwehe mehe heta tetea'u teko a'e pe wà.  
\p Teko ywy nànànar uzeruze'eg a'e tawhu rehe wà.  
\q1 Ko 'ar rehe nuzawy kwaw kuzà imen umàno ma'e kwer.  
\q1 Kwehe mehe nuzawy kwaw tuwihawete kuzà.  
\q1 Ko 'ar rehe nuzawy kwaw amo pe uma'ereko e ma'e.   
\b  
\q1
\v 2 Umumaw pytun gatu uzai'o pà.  
\q1 Hehaykwer uwyryk huwa rehe.  
\q1 Kwehe mehe heta imyrypar tetea'u wà.  
\q1 Ni pitài nupyta kwaw imurywete kar har romo kutàri wà. Paw rupi weityk wà.  
\q1 Wiko iàmàtyry'ymar romo wà kury.   
\b  
\q1
\v 3 Zauxiapekwer weraha teko Zuta ywy rehe har muite waiwy wi wà.  
\q1 Upuraraw kar ma'erahy wanupe amo pe uma'ereko e ma'e ài wà. Nupuner kwaw uma'erekoahy haw wi uhemaw rehe wà.  
\q1 Wiko amo ywy rehe wà.  
\q1 Nupytu'u kwaw wà.  
\q1 Wanehe ipuruzuka wer ma'e umàmàn waiwyr wà.  
\q1 Nupuner kwaw wanuwi uhemaw rehe wà.   
\q1
\v 4 Xiàw piarer uzemumikahy wà.  
\q1 Ta'e naheta kwaw wanupi mynykaw Tupàn imuwete haw pe wata ma'e wà xe.  
\q1 Kuzàwaza Tupàn Hàpuzuhu pupe uzegar ma'e uzemumikahy wà.  
\q1 Xaxeto ikuhem tuweharupi wà.  
\q1 Tawhu upuraraw ma'erahy tuweharupi.  
\q1 Naheta kwaw teko ipupe nahu rupi katu pe uzemono'og ma'e ràm wà.   
\b  
\q1
\v 5 Waàmàtyry'ymar wiko wazar romo wà.  
\q1 Waàmàtyry'ymar waneko haw ikatuahy.  
\q1 Ta'e Tupàn Tuweharupi Wiko Ma'e upuraraw kar ma'erahy Zeruzarez pe a'e xe.  
\q1 Ta'e ipupe har uzapo ikatu 'ym ma'e tetea'u henataromo a'e wà xe.  
\q1 Waàmàtyry'ymar upyhyk wana'yr wà.  
\q1 Weraha muite waiwy wi wà.   
\q1
\v 6 Zeruzarez ipuràg eteahy haw upaw.  
\q1 Ipupe har wanuwihaw nuzawy kwaw miar wà.  
\q1 Nuzawy kwaw miar ima'uhez ma'e ikàg 'ym ma'e wà.  
\q1 Uzàwehem uzuka àràm wanuwi wà.   
\q1
\v 7 Ko 'ar rehe uzemumikahy ma'e rehe, 'ar ma'erahy ipuraraw paw rehe,  
\q1 Zeruzarez ima'enukwaw wemetarer paw rehe,  
\q1 wemetarer kwehe arer rehe.  
\q1 — Ni amo nur kwaw hepytywà pà a'e wà, i'i u'ar awer rehe ima'enukwaw pà.  
\q1 U'ar wàmàtyry'ymar wapuner haw pe.  
\q1 Iàmàtyry'ymar upuka hehe i'ar mehe wà.   
\b  
\q1
\v 8 Ikàgaw uhem izuwi.  
\q1 Wiko kamir 'ym ma'e romo. Teko paw uze'eg zemueteahy hehe wà.  
\q1 Ikuhem iko tuweharupi.  
\q1 Upyk uwa umaranugar pà.  
\q1 Zeruzarez uzeapo ikatu 'ym ma'e Tupàn henataromo kury.  
\q1 Ta'e uzapo ikatu 'ym ma'e tetea'u Tupàn henataromo xe.   
\b  
\q1
\v 9 Hemiapo kwer ikatu 'ym ma'e nuzawy kwaw ipihunaw ikamir rehe har. Nazawaiw kwaw hexakaw.  
\q1 Zeruzarez na'ima'enukwaw kwaw uzeapo ma'e ràm rehe.  
\q1 U'araiwete tuwe.  
\q1 Naheta kwaw imurywete kar àràm.  
\q1 Iàmàtyry'ymar weityk wà.  
\q1 — Hepuhareko pe nehe, i'i Tupàn Tuweharupi Wiko Ma'e pe.   
\b  
\q1
\v 10 Iàmàtyry'ymar weraha hemetarer paw izuwi wà.  
\q1 Teko wexak uzeruzar 'ym ma'e tàpuzuhu pupe waneixe mehe wà.  
\q1 — Pemuixe kar zo uzeruzar 'ym ma'e heràpuzuhu pupe pe wà nehe, i'i Tupàn wanupe kwehe mehe.   
\b  
\q1
\v 11 Teko Zeruzarez pupe har ukuhem waiko wà.  
\q1 Wekar wemi'u ràm oho waiko wà.  
\q1 Omono wemetarer paw temi'u hekuzaromo wà.  
\q1 Nezewe mehe wikuwe wiwi wà.  
\q1 Tawhu pe har uze'eg nezewe a'e wà.  
\q1 — O Tupàn Tuweharupi Wiko Ma'e eme'e urerehe  
\q1 ureaiw haw hexak pà nehe, i'i wà.   
\q1
\v 12 Uze'eg nezewe uzeiwyr wata ma'e wanupe wà.  
\q1 — Peme'e urerehe nehe.  
\q1 Aipo heta amo tahy haw urerahy haw zàwenugar.  
\q1 Wikwahy mehe  
\q1 Tupàn Tuweharupi Wiko Ma'e uzepyk urerehe ko ma'erahy ipuraraw kar pà a'e.   
\b  
\q1
\v 13 'A ywate wi Tupàn umur kar amo tata urerehe.  
\q1 Ukaz urepupe.  
\q1 Uzapo puruzuka haw urepyhyk pà.  
\q1 Urereityk ywy rehe no.  
\q1 A'e re upuir urewi ma'erahy pupe urerezar pà.  
\q1 A'e ma'erahy nupaw kwaw.   
\b  
\q1
\v 14 Wexak ureremiapo kwer ikatu 'ym ma'e.  
\q1 Uzàpixipixi wamono'ono'og pà.  
\q1 Umuzaiko ureazuromo iàpixi pà.  
\q1 Wapuhuz haw umumaw urekàgaw.  
\q1 Urezar uremono ureàmàtyry'ymar wanupe.  
\q1 Nurupuner kwaw wanuwi urehemaw rehe.   
\b  
\q1
\v 15 Urezar umumaw zauxiapekwer ureremiruze'eg na'arewahy a'e wà.  
\q1 Umur kar zauxiapekwer tetea'u kwàkwàmo ureremiruze'eg wazuka kar pà a'e.  
\q1 Ukamikamik teko tawhu pupe har ikatu ma'e wà. Teko ukamikamik ma'ywa uwà itykwer iapo pà wà.  
\q1 Nezewegatete zauxiapekwer umumaw teko paw rupi wà.   
\q1
\v 16 A'e ma'e paw uremuzai'o kar.  
\q1 Umynehem urereha urerehay kwer pupe.  
\q1 Naheta kwaw uremurywete kar har wà.  
\q1 Naheta kwaw uremukàg kar har wà.  
\q1 Ureàmàtyry'ymar urereityk wà.  
\q1 Teko tawhu pe har upyta heityk pyrer inuinuromo wà.   
\b  
\q1
\v 17 Urupyho urepo.  
\q1 Nezewe rehe we ni amo na'urepytywà kwaw wà.  
\q1 Tupàn Tuweharupi Wiko Ma'e umur kar ureàmàtyry'ymar urekutyr ma'ema'e wi a'e wà.  
\q1 Urerereko ma'e purumuzewaru kar haw ài wà.   
\b  
\q1
\v 18 Tupàn Tuweharupi Wiko Ma'e ikatu a'e. Uzepyk urerehe.  
\q1 Ta'e nureruzar kwaw ize'eg ure xe.  
\q1 Pezeapyaka katu nehe, teko paw wà.  
\q1 Pexak urerahy haw nehe.  
\q1 Zauxiapekwer weraha Tupàn hemiaihu muitea'u xe wi wà: kwàkwàmo wà, kuzàwaza wà no.   
\b  
\q1
\v 19 — Urepytywà pe nehe, uru'e uremyrypar wanupe.  
\q1 Wiko ureàmàtyry'ymar wamyrypar romo wà.  
\q1 Xaxeto a'e wà, tuwihaw a'e wà no, umàno nahu rupi wà wemi'u ràm hekar mehe wà.  
\q1 Na'imàno wer kwaw wà.  
\q1 Hekar mehe zauxiapekwer uzuka wà.   
\b  
\q1
\v 20 O Tupàn Tuweharupi Wiko Ma'e exak ma'erahy ureremipuraraw nehe.  
\q1 Uruzemumikahy tuwe.  
\q1 Urezemumikahy haw hahy urepy'a pe.  
\q1 Ta'e urema'enukwaw neze'eg heruzar 'ym awer rehe ure xe.  
\q1 Teko uzuka amo teko nahu rupi wà.  
\q1 Te tàpuz pupe uzuka wà, i'i Zeruzarez pe har wà.   
\b  
\q1
\v 21 O Tupàn, urereinu pe urekuhem mehe nehe.  
\q1 Ta'e naheta kwaw uremurywete kar har wà xe.  
\q1 Ureàmàtyry'ymar paw ukwaw iaiw haw urewe uhem ma'e kwer wà.  
\q1 Hurywete wà, ta'e erepuraraw kar ma'erahy urewe ne xe.  
\q1 Emur kar 'ar neremimume'u kwer nehe.  
\q1 A'e 'ar mehe ureàmàtyry'ymar upuraraw putar ma'erahy urezàwegatete a'e wà nehe no.   
\b  
\q1
\v 22 Emume'u wanehe nezepyk àwàm nehe. Ta'e uzapo ikatu 'ym ma'e tetea'u wà xe.  
\q1 Erezepyk urerehe ureremiapo kwer ikatu 'ym ma'e hekuzaromo. Ezepyk wanehe nezewegatete nehe no.  
\q1 Nurupytu'u kwaw urekuhem ire.  
\q1 Urepy'a ima'eahy, i'i wà.   
\c 2  
\s1 Tupàn uzepyk Zeruzarez pe har wanehe  
\q1
\v 1 Wikwahy mehe  
\q1 zanezar upyk Zeruzarez ipytunahy haw pupe a'e.  
\q1 Zeruzarez tawhu nuzawy kwaw ywak a'e 'ym mehe.  
\q1 Na'e Tupàn uzapo a'e tawhu heityk pyrer ywytyr romo a'e.  
\q1 A'e 'ym mehe Izaew izuapyapyr umume'u tawhu ikatu haw amogwer wanupe wà.  
\q1 Wekwahy haw 'ar mehe  
\q1 Tupàn weityk te wàpuzuhu no.   
\q1
\v 2 Zanezar umumaw tawhu Zuta ywy rehe har paw a'e wà,  
\q1 purupuhareko 'ym pà a'e.  
\q1 Wekwahy haw pupe umumaw hàpuztàtà paw rupi wà.  
\q1 Weityk Zuta ywy rehe har ywy rehe ikàg 'ym ma'e romo wamuigo kar pà wà, wanuwihaw wanehe we wà.   
\b  
\q1
\v 3 Hakuahy ikwahy haw.  
\q1 A'e rupi umumaw Izaew wapuner haw no.  
\q1 Zaneàmàtyry'ymar wahem mehe  
\q1 na'ipurupytywà wer kwaw zanerehe.  
\q1 Zaneàmàtyry'ym a'e.  
\q1 Nuzawy kwaw tata uzeake har paw hapy har.   
\b  
\q1
\v 4 Wagaw u'yw zanekutyr  
\q1 zaneàmàtyry'ymar ài.  
\q1 Ukàgaw rupi uzuka zaneànàm zaneremiamutar upuner wera'u ma'e wà.  
\q1 Uzakook wekwahy haw  
\q1 Zeruzarez pupe har wanehe tata ài.   
\b  
\q1
\v 5 Zanezar nuzawy kwaw zaneàmàtyry'ymar.  
\q1 Umumaw Izaew wà.  
\q1 Weityk wanàpuztàtà paw.  
\q1 Umuaiw wanàpuzuhu paw no.  
\q1 Nezewe mehe werur zemumikahy haw upaw 'ym ma'e teko Zuta ywy rehe har wanupe. Werur zai'o haw upaw 'ym ma'e wanupe no.   
\b  
\q1
\v 6 Tupàn umumew wàpuzuhu ma'etymaw ài.  
\q1 Teko umuwete katu Tupàn a'e pe wà. Nezewe rehe we umumaw.  
\q1 Zanemueharaz kar mynykaw wi a'e, mytu'u haw 'ar wi a'e no.  
\q1 Wekwahy haw hakuahy mehe weityk tuwihawete wà, weityk xaxeto wà no.  
\q1 Ikàg 'ym ma'e romo wanekon henataromo wà kury.   
\b  
\q1
\v 7 Zanezar weityk ma'ea'yr hapy haw wenataromo har a'e.  
\q1 Upuir wàpuzuhu wi.  
\q1 Weityk kar ywyok tàtà ma'e zaneàmàtyry'ymar wanupe no.  
\q1 Uhapukaz urywete haw rehe a'e pe wà, ta'e zanereityk a'e wà xe.  
\q1 A'e 'ym mehe xihapukaz a'e pe mynykaw 'ar mehe.   
\b  
\q1
\v 8 Amumew putar Zeruzarez pàrirogawtàtà ihe nehe, i'i Tupàn Tuweharupi Wiko Ma'e uzeupe.  
\q1 Umume'u imumaw pàwàm.  
\q1 Na'e umumaw tuwe.  
\q1 Pàrirogawtàtà, ywyok no, uzeka a'e wà.  
\q1 U'ar a'e 'ar mehe we wà.   
\b  
\q1
\v 9 U'ar ma'e kwer upyk ukenawhu wà.  
\q1 Iwàpytymaw uzekazeka wà no.  
\q1 Tuwihawete a'e, amo tuwihaw a'e wà no, uhàuhàz ywy nànàn uzeruzar 'ym ma'e wainuinuromo wà.  
\q1 Ni amo nupurumu'e kwaw Tupàn ze'eg rehe a'e wà.  
\q1 Tupàn Tuweharupi Wiko Ma'e nuexak kar kwaw ma'e wapuahu zàwenugar uze'eg imume'u har wanupe kury.   
\b  
\q1
\v 10 Zeruzarez pe har tua'u wera'u ma'e a'e wà,  
\q1 wapyk ywy rehe uze'eg 'ym pà wà.  
\q1 Umur ywy wàkàg rehe uzemumikahy haw hexak kar pà wà.  
\q1 Umunehew ma'eryru pàn iànàm ma'e iapo pyrer ukamir romo wà.  
\q1 Kuzàwaza wapyk uzemumew pà upenàràg rehe wà.  
\q1 Umuhyk wàkàg ywy rehe wà no.   
\b  
\q1
\v 11 Hereha ikene'o ta'e azai'o tetea'u ihe xe.  
\q1 Azemumikahy tuwe.  
\q1 Hezemumikahy haw hemumaw a'e.  
\q1 Ta'e amo umumaw heremiaihu a'e wà xe.  
\q1 Aexak kwarer tawhu pupe nahu rupi ima'uhez ma'e umàno ma'e ihe wà. Aexak kwarera'i wamàno mehe ihe wà no.   
\b  
\q1
\v 12 Uze'eg nezewe wà.  
\q1 — Màmàz, hema'uhez, màmàz, i'i wà.  
\q1 — Màmàz, heiwez, màmàz, i'i wà.  
\q1 U'ar nahu rupi ikutuk pyrer ài wà.  
\q1 Mewe katu umàno uhy zywa rehe wà.   
\b  
\q1
\v 13 Zeruzarez heremiamutar, ma'e apuner newe imume'u haw rehe.  
\q1 Ma'e azapo putar nemurywete kar pà nehe.  
\q1 Ni amo nupuraraw pixik kwaw ma'erahy nezàwe wà.  
\q1 Iaiw haw nerehe u'ar ma'e uhua'u yryhu ài a'e.  
\q1 Mo upuner nepyro àwàm herur haw rehe.   
\b  
\q1
\v 14 Tupàn ze'eg imume'u har wexak e upuahu haw zàwenugar wà. Xo temu'emaw zo wexak wà. Nukwaw kwaw uzeapo ma'e ràm azeharomoete har wà.  
\q1 Aze mo umume'u tuwe teko wanemiapo kwer ikatu 'ym ma'e wanupe wà,  
\q1 ikatu ma'e uzeapo mo newe.  
\q1 A'e Tupàn ze'eg imume'u har hemu'em newe wà, temu'emaw imume'u pà newe wà.   
\b  
\q1
\v 15 Neruwake ukwaw ma'e uze'eg urywahyahy nerehe wà.  
\q1 Uzeàkàmuawawak upuka pà uzehezehe upuranu pà wà.  
\q1 — Puràg eteahy haw ikatuahy ma'e, aipo teko i'i 'aw tawhu pe kwehe mehe wà.  
\q1 — Ikatuahy a'e, aipo i'i teko ywy nànànar izupe wà, i'i wà.   
\b  
\q1
\v 16 Neàmàtyry'ymar paw uze'eg zemueteahy nerehe upuka pà wà.  
\q1 Na'iakatuwawahy kwaw nerehe wà.  
\q1 A'e rupi — Ximumaw Zeruzarez zane, i'i wà.  
\q1 — Uhem 'ar zaneremiàro kwez kury, i'i wà.  
\q1 — Xixak uzeapo ma'e kwer paw rupi zane, i'i wà.   
\b  
\q1
\v 17 Tupàn Tuweharupi Wiko Ma'e uzapo wemimume'u kwer.  
\q1 — Iaiw ma'e azapo putar nehe, i'i kwehe mehe.  
\q1 Uzapo ma'e uze'eg rupi katete a'e.  
\q1 Zanemumaw zanepuhareko 'ym pà.  
\q1 Zanereityk kar zaneàmàtyry'ymar wanupe.  
\q1 Umurywete kar zanemumaw pawer rehe wà no.   
\b  
\q1
\v 18 O Zeruzarez, tuwe nepàrirogaw tàtà wenoz uzepyro àwàm zanezar pe nehe.  
\q1 Tuwe nerehay kwer uwyryk yryhu ài nehe, 'aromo nehe, pyhaw nehe no.  
\q1 Epytu'u zo nehe. Ezai'o nepytu'u 'ym pà nehe.   
\b  
\q1
\v 19 Epu'àm tetea'u pyhaw Tupàn pe neze'eg pà nehe.  
\q1 — Hepyro pe nehe, ere izupe nehe.  
\q1 Ezakook nepy'a henataromo nehe.  
\q1 Nera'yr umàno waiko nahu za'akaw pe wà uma'uhez pà wà.  
\q1 Epyro wamàno haw wi ne wà nehe, ere izupe nehe.   
\b  
\q1
\v 20 Eme'e nema'enukwaw pà nehe, o Tupàn Tuweharupi Wiko Ma'e.  
\q1 Aipo amo 'ar mehe erereko amo teko nezewe ne wà.  
\q1 Kuzà uzamutar katu umemyr wà. Aipo uzuka putar umemyr i'u pà wà nehe.  
\q1 Aipo teko uzuka putar neze'eg imume'u har a'e wà nehe. Aipo uzuka putar xaxeto a'e wà nehe no, neràpuzuhu pupe a'e wà nehe.   
\b  
\q1
\v 21 Heta umàno ma'e kwer heityk pyrer nahu rupi wà: kwàkwàmo wà, tua'uhez ma'e wà no.  
\q1 Zauxiapekwer uzuka kwàkwàmo heremiaihu takihepuku pupe a'e wà.  
\q1 Uzuka kuzàwaza heremiaihu a'e wà no.  
\q1 Nekwahy haw 'ar mehe erezuka kar wapuhareko 'ym pà ne wà.   
\b  
\q1
\v 22 Eremur kar heàmàtyry'ymar iaiw ma'e ywy nànàn ne wà.  
\q1 Utupàn imuwete haw zàwenugar pe ur wà.  
\q1 O Tupàn Tuweharupi Wiko Ma'e nekwahy haw 'ar mehe ni amo nuzepyro kwaw wà.  
\q1 Ni amo nuikuwe kwaw wà.  
\q1 Amugakwaw hera'yr wamutar katu haw rupi ihe wà.  
\q1 Heàmàtyry'ymar umumaw hera'yr a'e wà.   
\c 3  
\s1 Tupàn purehe zepykaw, teko wazemumikahy haw, hàro haw no  
\q1
\v 1 Tupàn upetek amo teko wekwahy haw pupe a'e wà. Amo teko ukwaw upetekaw ipuraraw mehe wà. Aiko amo a'e teko romo ihe.   
\q1
\v 2 Hereraha ipytunahy haw pupe a'e.  
\q1 Hemuata kar pe rupi tatainy heta 'ymaw pe.   
\q1
\v 3 Ukwaukwar tetea'u herehe opo pupe.  
\q1 Umumaw 'ar katu nezewe iapo pà.   
\b  
\q1
\v 4 Tupàn umuzemàner hero'o hepir rehe we a'e.  
\q1 Uhaw hekàgwer no.   
\q1
\v 5 Uma'ema'e ma'erahy a'e, iro haw a'e no, pàrirogawtàtà zàwenugar romo heywyr a'e.   
\q1
\v 6 Hemuigo kar ipytunahy haw pupe no.  
\q1 Herereko kwehe umàno ma'e kwer ài.   
\b  
\q1
\v 7 Tupàn heàpixipixi kyhàhàmtàtà ipuhuz ma'e pupe.  
\q1 Aiko zemunehew paw pupe. Napuner kwaw hehemaw rehe.   
\q1
\v 8 Ahapukaz hepytywà àwàm henoz pà.  
\q1 Na'ipurenu wer kwaw heze'eg rehe.   
\q1
\v 9 Napuner kwaw herenataromo heho haw rehe.  
\q1 Ta'e uwàpytym herape ràm itahu pupe a'e xe.   
\b  
\q1
\v 10 Tupàn nuzawy kwaw zàwàruhu iriàw miar hàro har a'e, ihewe a'e.  
\q1 Nuzawy kwaw zàwàruhu uruxu her ma'e herehe ipuruzuka wer ma'e no.   
\q1
\v 11 Hemunyryk kar pe wi.  
\q1 Hepei'ài'àg no. A'e re hereityk.   
\q1
\v 12 Omono ihàm uwyrapar rehe imuàgà'ym pà.  
\q1 Na'e hezywà kury.   
\b  
\q1
\v 13 Tupàn hu'yw imomor pyrer  
\q1 ukutuk katu hero'o.   
\q1
\v 14 Teko umumaw 'ar katu herehe upuka pà wà.  
\q1 Uzegar mehe uze'eg urywahyahy herehe wà.   
\q1
\v 15 Tupàn hemynehem temi'u iro ma'e pupe.  
\q1 Hemui'u kar iroahy ma'e pupe no.  
\q1 Napuner kwaw amo iro ma'e i'u wi haw rehe kury.   
\b  
\q1
\v 16 Ukytykytyk heruwa ywy rehe.  
\q1 Uzukazuka heràz ita rehe no.   
\q1
\v 17 Nakwaw kwaw zeàmàtyry'ymaw heta 'ymaw ihe kury.  
\q1 Hereharaz turywete haw wi no.   
\q1
\v 18 Àmàno etea'i kury.  
\q1 Tupàn Tuweharupi Wiko Ma'e hàro haw upaw ihewi kury.   
\b  
\q1
\v 19 Hema'enukwaw hezemumikahy haw rehe, ihe zutyka'i hereko haw rehe no.  
\q1 Hema'enukwaw iro haw rehe, ma'erahy rehe no.   
\q1
\v 20 Tuweharupi hema'enukwaw hehe.  
\q1 Na'e azemumikahy.   
\q1
\v 21 Nezewe rehe we ikatu ma'e hàro haw uzewyr ihewe,  
\q1 ko ma'e rehe hema'enukwaw mehe:   
\b  
\q1
\v 22 Tupàn puruamutar katu haw nupaw kwaw a'e.  
\q1 Ikatu haw nupaw pixik kwaw.   
\q1
\v 23 Ipuruamutar katu haw a'e, ikatu haw a'e no, ipyahu tuweharupi ku'em mehe a'e wà.  
\q1 Uzapo tuwe wemimume'u. Uzapo tuwe a'e.   
\q1
\v 24 Areko tuwe Tupàn ihe. Naheta kwaw amo ma'e ihewe.  
\q1 A'e rupi azeruzar hehe ihe.   
\b  
\q1
\v 25 Aze amo uzeruzar Tupàn Tuweharupi Wiko Ma'e rehe wà, ikatu wanupe a'e.   
\q1
\v 26 Tuwe xiàro Tupàn Tuweharupi Wiko Ma'e hemiapo ràm ikatu ma'e nehe.  
\q1 Tuwe xiàro zanepytywà àwàm zaneze'eg 'ym pà nehe.   
\q1
\v 27 Tuwe teko uzemu'e ma'erahy ipuraraw paw rehe wà nehe,  
\q1 ukwarer mehe arer we wà nehe.   
\b  
\q1
\v 28 Tupàn ma'erahy zanewe ipuraraw kar mehe,  
\q1 tuwe zaiko zane zutyka'i hàro pà  
\q1 zaneze'eg 'ym pà nehe.   
\q1
\v 29 Zazemumew ikàg 'ym ma'e ài nehe,  
\q1 ta'e Tupàn upuner zanepyro haw rehe a'e nehe xe.   
\q1
\v 30 Aze amo uze'eg zemueteahy zanerehe wà nehe, zaze'eg zo wanupe nehe. Tuwe uze'eg zemueteahy zanerehe nehe.  
\q1 Nazaze'eg kwaw wanupe nehe.   
\b  
\q1
\v 31 Tupàn Tuweharupi Wiko Ma'e nuweityk kwaw amo wamuzewyr pixik 'ym pà a'e wà.   
\q1
\v 32 Upuner ma'erahy zanewe ipuraraw kar pà a'e.  
\q1 Nezewe rehe we zanepuhareko katu a'e no.  
\q1 Ta'e upuruamutar katu tuwe a'e xe.   
\q1
\v 33 Aze upuraraw kar ma'erahy zanewe a'e, aze zanemuahy kar a'e, nahurywete kwaw a'e.   
\b  
\q1
\v 34 Aze amo uzuka zemunehew paw pupe har wapuhareko 'ym pà ko ywy rehe a'e wà,  
\q1 Tupàn ukwaw a'e.   
\q1
\v 35 Tupàn uzapo kar ma'e teko wanupe a'e.  
\q1 Aze amo umupytu'u kar teko a'e ma'e iapo re, Tupàn ukwaw a'e.   
\q1
\v 36 Aze amo imunar amo rehe tuwihaw wanehe we, ukwaw a'e no.   
\b  
\q1
\v 37 Ni amo nupuner kwaw ma'e iapo kar haw rehe a'e wà,  
\q1 aze Tupàn nuputar kwaw a'e ma'e iapo kar haw nehe.   
\q1
\v 38 Tupàn Ywate Wera'u Ma'e uzapo kar ikatu ma'e a'e. Uzapo kar ikatu 'ym ma'e a'e no.   
\q1
\v 39 Aze Tupàn uzepyk zanerehe zaneremiapo kwer hekuzaromo a'e,  
\q1 màràzàwe tuwe zaze'eg zemueteahy zanereko haw rehe.   
\b  
\q1
\v 40 Xixak tuwe zaneremiapo kwer nehe.  
\q1 Zazewyr Tupàn Tuweharupi Wiko Ma'e pe nehe no.   
\q1
\v 41 Xiwàpytymawok zanepy'a Tupàn ywak rehe har pe no.  
\q1 Zaze'eg izupe nehe.   
\q1
\v 42 — O Tupàn, uruzapo ikatu 'ym ma'e ure. Urupytu'u nereruzar ire.  
\q1 A'e rupi nanereharaz kwaw ureremiapo kwer wi.   
\b  
\q1
\v 43 Erekwahy urerehe.  
\q1 Erezur ureraikweromo.  
\q1 Urezuka pe urepuhareko 'ym pà.   
\q1
\v 44 Eremàmàn nezeywyr ywàkun pupe.  
\q1 Nezewe mehe ureze'egaw nuhem kwaw neruwake.   
\q1
\v 45 Eremume'e kar teko amo ywy rehe har urerehe ne wà.  
\q1 Uruiko ywytyr ma'e heityk pyrer iapo pyrer zàwenugar romo.   
\b  
\q1
\v 46 Ureàmàtyry'ymar paw uze'eg zemueteahy urerehe wà.   
\q1
\v 47 Uruiko urekyze haw myter pe, ikatu 'ymaw inuromo, iaiw haw ipupe, uremumaw paw inuromo.   
\q1
\v 48 Herehay kwer uwyryk hereha wi yrykawhu ài.  
\q1 Ta'e teko heremiaihu upaw wà xe.   
\b  
\q1
\v 49 Hereha uzakook putar herehay kwer upaw 'ym pà nehe.   
\q1
\v 50 Te Tupàn Tuweharupi Wiko Ma'e ume'e putar ywak wi  
\q1 urerexak pà a'e nehe.   
\q1
\v 51 Hepy'a upuraraw ma'erahy tetea'u a'e,  
\q1 kuzà hereko haw pe har wanupe uzeapo ma'e kwer rehe hema'enukwaw mehe ihe.   
\b  
\q1
\v 52 Màràzàwe tuwe heàmàtyry'ymar na'iakatuwawahy kwaw herehe wà.  
\q1 Heruwà.  
\q1 Ipuruzuka wer herehe wiràmiri izuka haw ài wà.   
\q1
\v 53 Hereityk hemàno 'ym mehe yzygwar pupe wà.  
\q1 Uwàpytym itahu pupe wà.   
\q1
\v 54 'Y uhem heàkàg pe.  
\q1 — Amàno putar kury, a'e hezeupe.   
\b  
\q1
\v 55 'Yzygwar wi ahapukaz Tupàn Tuweharupi Wiko Ma'e pe.  
\q1 — Hepytywà pe nehe, a'e izupe.   
\q1
\v 56 — Herenu pe nehe, a'e newe.  
\q1 Herenu pe herehapukaz mehe.   
\q1
\v 57 Nerenoz haw 'ar mehe,  
\q1 erehem heruwake ihewe neze'eg pà.  
\q1 — Ekyze zo nehe, ere ihewe.   
\b  
\q1
\v 58 O Tupàn Tuweharupi Wiko Ma'e erezur hepytywà pà.  
\q1 Hepyro pe ne.   
\q1
\v 59 Emume'u hekatu haw nehe, o Tupàn Tuweharupi Wiko Ma'e.  
\q1 Ta'e erekwaw ikatu 'ymaw heremipuraraw kwer ne xe.   
\q1
\v 60 Heàmàtyry'ymar izepyk wer herehe wà. Erekwaw waneko haw.  
\q1 Umume'u ikatu 'ym ma'e ihewe wemiapo ràm wà.  
\q1 Erekwaw wanemimume'u kwer no.   
\q1
\v 61 O Tupàn Tuweharupi Wiko Ma'e, erenu herehe waze'eg zemueteahy mehe ne wà.  
\q1 Erekwaw wanemiapo ràm paw no.   
\q1
\v 62 Tuweharupi umumaw 'ar katu hekutyr uze'eg pà wà.  
\q1 — Xiapo ikatu 'ym ma'e izupe nehe, i'i uzeupeupe herehe wà.   
\q1
\v 63 'Ar nànàn uze'eg urywahyahy herehe wà.  
\q1 Erexak waze'eg mehe ne wà.   
\b  
\q1
\v 64 O Tupàn Tuweharupi Wiko Ma'e, ezapo ikatu 'ym ma'e wanupe nehe, wanemiapo kwer hekuzaromo nehe.  
\q1 Ezepyk wanehe wanemiapo kwer rehe nehe.   
\q1
\v 65 Emono neze'egaiw wanehe nehe.  
\q1 Emu'ar kar iaiw haw rehe ne wà nehe no.   
\q1
\v 66 Nekwahy haw rupi eho wanaikweromo nehe, o Tupàn Tuweharupi Wiko Ma'e.  
\q1 Emumaw ko ywy rehe ne wà nehe no.   
\c 4  
\s1 Zeruzarez imumew pyrer  
\q1
\v 1 Itazu or uzeapo ipihun ma'e romo azeharomoete a'e.  
\q1 Or ikatuahy ma'e naheny kwaw kury.  
\q1 Ita hekuzar katu ma'e tàpuzuhu pupe arer uhàuhàz nahu za'akaw pe kury.   
\b  
\q1
\v 2 Kwàkwàmo Zeruzarez pe har ikatuahy zanewe or ikatuahy ma'e ài a'e wà.  
\q1 Ko 'ar rehe nuzawy kwaw ywy'a teko wanupe wà kury. Nuzeruze'eg kwaw wanehe wà kury.   
\b  
\q1
\v 3 Te awarahu umukamu kar umemyr wà.  
\q1 Heremiaihu nuzawy kwaw wiranu zàwenugar wà.  
\q1 Upuraraw kar ma'erahy umemyr wanupe wà.   
\b  
\q1
\v 4 Kwarera'i Zeruzarez pe har umàno waiko wà, ta'e naheta kwaw 'y wanupe xe.  
\q1 — Temi'u, i'i kwarer wà.  
\q1 Ni amo nomono kwaw wanupe wà.   
\b  
\q1
\v 5 Temi'u ikatuahy ma'e i'u arer  
\q1 umàno nahu rupi umai'u 'ym pà wà kury.  
\q1 Kamir hekuzar katu ma'e imunehew arer  
\q1 wiko ity i'aromo wà kury.   
\b  
\q1
\v 6 Kwehe mehe Tupàn uzepyk Xotom pe har wanehe.  
\q1 Na'arewahy Tupàn umumaw a'e.  
\q1 Uzepyk wera'u heremiaihu wanehe kury.   
\b  
\q1
\v 7 Zaneruwihaw ta'yr ikatuahy ma'ekamy kwer ài wà.  
\q1 Naheta kwaw ipihunaw wanehe. Nuzawy kwaw àmàn tàtà xig ma'e wà.  
\q1 Ikàg wà, tynehem ukàgaw pupe wà.  
\q1 Waneha heny katu ima'eahy 'ym ma'e ài wà.   
\b  
\q1
\v 8 Ko 'ar rehe wanuwa ipihun tàtàpyzgwer ài.  
\q1 Nahu rupi wata mehe ni amo nukwaw kwaw wà.  
\q1 Wapir uxinig ywyra ài.  
\q1 Ururururu katu wàkàgwer rehe.   
\b  
\q1
\v 9 Zeàmàtyry'ymawhu pe umàno ma'e kwer  
\q1 hurywete wera'u wà, amo a'e re umàno ma'e kwer wanuwi wà.  
\q1 Ta'e umàno oho waiko mewe katu a'e wà xe.  
\q1 Ta'e naheta kwaw wanemi'u wanupe xe.   
\b  
\q1
\v 10 Kuzà Zeruzarez pe har  
\q1 umemyr iamutar katu har a'e wà,  
\q1 tawhu imumaw mehe  
\q1 umimoz umemyr i'u pà a'e wà kury.   
\b  
\q1
\v 11 Tupàn Tuweharupi Wiko Ma'e uzakook wekwahy haw a'e,  
\q1 uzuhen wekwahy haw haku haw a'e no.  
\q1 Umunyk tata Zeruzarez rehe,  
\q1 ywy rehe imumew pà no.   
\b  
\q1
\v 12 — Ni amo iàmàtyry'ymar nupuner kwaw Zeruzarez ukenawhu rupi wixe haw rehe wà nehe,  
\q1 i'i teko paw wà.  
\q1 Te wanuwihawete uze'eg nezewe wà.   
\b  
\q1
\v 13 A'e ma'e paw uzeapo a'e, ta'e ipupe har uzapo ikatu 'ym ma'e Tupàn henataromo a'e wà xe.  
\q1 Tupàn ze'eg imume'u har a'e pe har uzapo ikatu 'ym ma'e wà. Xaxeto a'e pe har uzapo ikatu 'ym ma'e wà no.  
\q1 Uzuka kar teko ikatu ma'e wà.   
\b  
\q1
\v 14 Xaxeto a'e wà, Tupàn ze'eg imume'u har a'e wà no, wata nahu rupi hehàpyhà 'ym ma'e ài wà.  
\q1 Wanemizuka kwer wanuwy kwer umuzipiw a'e wà. A'e rupi ni amo nopokok kwaw wakamir rehe wà.   
\b  
\q1
\v 15 Teko uhapukaz wà.  
\q1 — Peho xe wi nehe.  
\q1 Napekatu kwaw.  
\q1 Pepokok zo urerehe nehe, i'i wanupe wà.  
\q1 Wazàwehem mehe wà, ywy nànàn wata mehe wà, te uzeruzar 'ym ma'e uze'eg nezewe wanupe wà.  
\q1 — 'Aw awa nupuner kwaw xe weko haw rehe wà nehe, i'i wanupe wà.   
\b  
\q1
\v 16 Tupàn Tuweharupi Wiko Ma'e nuzekaiw kwaw wanehe.  
\q1 Umuhàmuhàz wà.  
\q1 Nuzekaiw kwaw xaxeto zanerehe we har wanehe.  
\q1 Nupuhareko kwaw zaneruwihaw wà.   
\b  
\q1
\v 17 Zame'e, te zanekene'o.  
\q1 Xiàro zanepytywà haw. Nuhem pixik kwaw.  
\q1 Zazeruzar teko amo ywy rehe har wanehe. — Zanepytywà putar a'e wà nehe, za'e zepe wanupe.  
\q1 Nupuner kwaw wà.   
\b  
\q1
\v 18 Zaneàmàtyry'ymar ume'e waiko zanerehe.  
\q1 Ni nahu rupi nazapuner kwaw zaneata haw rehe.  
\q1 Zane'ar upaw etea'i.  
\q1 Zanemumaw pàwàm uhem etea'i.   
\b  
\q1
\v 19 Zanekutyr ur ma'e uzàn wera'u wiràhu ywak rehe har wanuwi wà.  
\q1 Ur zaneraikweromo ywytyruhu rehe wà.  
\q1 Na'arewahy zaneàmàtyry'ym ywyxiguhu rehe zanemupytuhegatu kar pà wà.   
\b  
\q1
\v 20 Upyhyk zanereko haw imur har wà.  
\q1 Tupàn Tuweharupi Wiko Ma'e wexaexak zaneruwihawete a'e. Zauxiapekwer upyhyk a'e tuwihawete wà.  
\q1 — Zanepyro putar zauxiapekwer zaneywy rehe wixe ma'e wanuwi a'e nehe, za'e izupe. Nazanepyro kwaw a'e.   
\b  
\q1
\v 21 Pe teko Enom ywy rehe har wà, pe Uz ywy rehe har wà no, pepuner pepuka haw rehe.  
\q1 Penurywete pekatu mehe nehe.  
\q1 Ta'e iaiw haw penehe u'ar ma'e ràm uhem wà iko kury xe.  
\q1 Peka'u putar nehe. Peiko putar kamir 'ym pà nehe no.   
\b  
\q1
\v 22 Tupàn uzepyk Zeruzarez pe har wanehe wanemiapo kwer hekuzaromo a'e.  
\q1 Uhàuhàz ywy tetea'u wanehe wà.  
\q1 Tupàn Tuweharupi Wiko Ma'e numupyta kar kwaw a'e ywy rehe wà nehe.  
\q1 Tupàn uzepyk putar penehe a'e nehe, teko Enom ywy rehe har wà.  
\q1 Ukwaw kar putar penemiapo kwer ikatu 'ym ma'e teko nànàn a'e nehe.   
\c 5  
\s1 Uze'eg Tupàn pe upuhareko haw henoz pà  
\q1
\v 1 O Tupàn Tuweharupi Wiko Ma'e, nema'enukwaw urewe uzeapo ma'e kwer rehe nehe.  
\q1 Eme'e urerehe iaiw haw urewe u'ar ma'e kwer hexak pà nehe.   
\b  
\q1
\v 2 Amo ywy rehe har wiko ureywy izar romo wà.  
\q1 Teko ureremigwaw 'ym wiko ureràpuz pupe wà.   
\b  
\q1
\v 3 Uruiko tu 'ym ma'e romo.  
\q1 Urehy wiko imen umàno ma'e kwer romo wà.   
\b  
\q1
\v 4 Te 'y urei'u àwàm urume'eg kar ure.  
\q1 Urumekuzar zepe'aw urerata rehe àràm no.   
\b  
\q1
\v 5 Ureàmàtyry'ymar upuraraw kar ma'erahy urewe urereko mehe a'e wà.  
\q1 Urekene'oahy ta'e na'uremupytu'u kar kwaw wà xe.   
\b  
\q1
\v 6 Aze uremai'u wer, urenoz ureremi'u ràm amo wanupe,  
\q1 Ezit ywy rehe har wanupe, Axir ywy rehe har wanupe no.   
\b  
\q1
\v 7 Ureipy uzapo ikatu 'ym ma'e wà. Nuiko kwaw wà kury.  
\q1 Urupuraraw ma'erahy ure, ta'e ureipy uzapo ikatu 'ym ma'e a'e wà xe.   
\b  
\q1
\v 8 Amo pe uma'ereko e ma'e wiko ureruwihaw romo wà.  
\q1 Naheta kwaw wapo wi urepyro àràm wà.   
\b  
\q1
\v 9 Na'ikatuahy kwaw urewe aze urekar ureremi'u ràm.  
\q1 Ta'e imunar ma'e ywyxiguhu rehe har ureàmàtyry'ym urepuhareko 'ym pà wà xe.   
\b  
\q1
\v 10 Urema'uhez haw uremuakuahy a'e.  
\q1 Urepir haku zepehe ài.   
\b  
\q1
\v 11 Zeruzarez pe, tawhu Zuta ywy rehe har pe,  
\q1 zauxiapekwer upyhykahyahy kuzà wà, kuzàwaza wà no.   
\q1
\v 12 Ureàmàtyry'ymar u'azuwyk ureruwihaw wà.  
\q1 Nuzeruze'eg kwaw ureràmuzgwer wanehe wà no.   
\b  
\q1
\v 13 Umuma'erekoahy kar kwàkwàmo urera'yr arozràn imuku'i haw pe wà.  
\q1 Uzepyapi zepe'aw heraha mehe wà.   
\b  
\q1
\v 14 Tua'uhez ma'e nuzemono'og kwaw nahu rupi wà kury.  
\q1 Kwàkwàmo nuzegar kwaw wà kury.   
\b  
\q1
\v 15 Urerurywete haw uhem urepy'a wi.  
\q1 Urezemumikahy haw upyta urepynykaw hekuzaromo kury.   
\b  
\q1
\v 16 Ni urekàgaw ipixika'i nupyta kwaw.  
\q1 Uruzapo ikatu 'ym ma'e ure. A'e rupi Tupàn umume'u urerehe uzepykaw a'e.   
\b  
\q1
\v 17 Urepy'a ima'eahy.  
\q1 Urerehay kwer uremupytu'u kar ma'e hexak ire a'e.   
\b  
\q1
\v 18 Ta'e naheta kwaw teko Xiàw ywytyr rehe wà kury xe.  
\q1 Awara wata tàpuz imuaiw pyrer myteromo wà.   
\b  
\q1
\v 19 Nezewe rehe we ne o Tupàn Tuweharupi Wiko Ma'e ereiko ureruwihawete romo tuweharupi nehe.  
\q1 Ereiko teko wazar romo tuweharupi har romo.   
\b  
\q1
\v 20 Màràzàwe tuwe eremumaw kwarahy tetea'u urerehe nezekaiw 'ym pà.  
\q1 Aipo nema'enukwaw wi putar urerehe nehe.   
\b  
\q1
\v 21 Uremuzewyr kar pe newe nehe, o Tupàn Tuweharupi Wiko Ma'e.  
\q1 Azeharomoete, uremuzewyr kar nehe.  
\q1 Ezapo urereko àwàm urereko awer zàwe nehe.   
\b  
\q1
\v 22 Aipo urereityk pe azeharomoete.  
\q1 Aipo urewe nekwahy haw nupaw pixik kwaw nehe.  
\p Upaw.   