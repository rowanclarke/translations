\v 1 \w Yahweh|strong="H3068"\w* \w gave|strong="H1961"\w* \w me|strong="H1697"\w* another \w message|strong="H1697"\w*. \w He|strong="H3068"\w* \w said|strong="H1697"\w*,  
\v 2 “\w You|strong="H5921"\w* human, \w prophesy|strong="H5012"\w* \w about|strong="H1961"\w* \w the|strong="H5921"\w*\add leaders\add* \w of|strong="H1121"\w* \w Israel|strong="H3478"\w*. \add They should be taking care of my people like\add* [MET] \w shepherds|strong="H7462"\w* \add take care of their sheep\add*. \w Say|strong="H3478"\w* \w to|strong="H3478"\w* \w them|strong="H5921"\w*, ‘\w This|strong="H3541"\w* \w is|strong="H3478"\w* \w what|strong="H3541"\w* \w Yahweh|strong="H3068"\w* \w the|strong="H5921"\w* \w Lord|strong="H3069"\w* \w says|strong="H3541"\w*: Terrible \w things|strong="H1961"\w* \w will|strong="H1961"\w* \w happen|strong="H1961"\w* \w to|strong="H3478"\w* \w you|strong="H5921"\w* leaders [MET] \w of|strong="H1121"\w* \w Israel|strong="H3478"\w* \w who|strong="H1121"\w* only \w take|strong="H1961"\w* \w care|strong="H5921"\w* \w of|strong="H1121"\w* \w yourselves|strong="H5921"\w*! \w You|strong="H5921"\w* \w should|strong="H3478"\w* \w certainly|strong="H3808"\w* [RHQ] \w take|strong="H1961"\w* \w care|strong="H5921"\w* \w of|strong="H1121"\w* \add your people like\add* [MET] \w a|strong="H3068"\w* \w shepherd|strong="H7462"\w* takes \w care|strong="H5921"\w* \w of|strong="H1121"\w* \w his|strong="H5921"\w* \w flock|strong="H6629"\w* \w of|strong="H1121"\w* \w sheep|strong="H6629"\w*!  
