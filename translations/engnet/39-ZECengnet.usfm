\p 
\v 1 \w The|strong="H7725"\w* \w angelic|strong="H4397"\w* \w messenger|strong="H4397"\w* \w who|strong="H4397"\w* had been \w speaking|strong="H1696"\w* \w with|strong="H1696"\w* \w me|strong="H7725"\w* \w then|strong="H1696"\w* \w returned|strong="H7725"\w* \w and|strong="H7725"\w* woke \w me|strong="H7725"\w*, \w as|strong="H1696"\w* \w a|strong="H3068"\w* \w person|strong="H1696"\w* \w is|strong="H1696"\w* \w wakened|strong="H5782"\w* \w from|strong="H7725"\w* \w sleep|strong="H8142"\w*.
