\b
\lh 
\v 36 Luboota:
\li1 Sanyiin Yedaaʼiyaa warri karaa maatii Yeeshuuʼaan dhufan 973,
\li1 
\v 37 sanyiin Imeer 1,052,
\li1 
\v 38 sanyiin Phaashihuur 1,247,
\li1 
\v 39 sanyiin Haariim 1,017.
\b
\lh 
