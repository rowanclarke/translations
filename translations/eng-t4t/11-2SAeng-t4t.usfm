\v 2 \add They told him that\add* \w there|strong="H8034"\w* \w was|strong="H8034"\w* \add in Jerusalem\add* \w a|strong="H3068"\w* man \w named|strong="H7121"\w* \w Ziba|strong="H6717"\w* \w who|strong="H5650"\w* \w had|strong="H1732"\w* been \w a|strong="H3068"\w* \w servant|strong="H5650"\w* \w of|strong="H4428"\w* \w Saul|strong="H7586"\w*’s \w family|strong="H1004"\w*. \w So|strong="H7121"\w* \add David sent messengers to summon Ziba. When he arrived\add*, \w the|strong="H7121"\w* \w king|strong="H4428"\w* asked \w him|strong="H7121"\w*, “\w Are|strong="H5650"\w* \w you|strong="H7121"\w* \w Ziba|strong="H6717"\w*?” \w He|strong="H1004"\w* replied, “Yes, \w your|strong="H1732"\w* majesty, \w I|strong="H5650"\w* am.”
\p 
\v 3 \w The|strong="H6213"\w* \w king|strong="H4428"\w* asked \w him|strong="H6213"\w*, “\w Is|strong="H2617"\w* there anyone \w in|strong="H1004"\w* \w Saul|strong="H7586"\w*’s \w family|strong="H1004"\w* \w to|strong="H6213"\w* whom \w I|strong="H1121"\w* \w can|strong="H6213"\w* \w be|strong="H5750"\w* kind, \add as I promised Jonathan that I would do\add*?” \w Ziba|strong="H6717"\w* replied, “Yes, there \w is|strong="H2617"\w* \w one|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Jonathan|strong="H3083"\w* \w who|strong="H1121"\w* \w is|strong="H2617"\w* \w still|strong="H5750"\w* \add alive\add*. \w His|strong="H6213"\w* \w feet|strong="H7272"\w* \w are|strong="H1121"\w* \w crippled|strong="H5223"\w*.”
\p 
\v 4 \w The|strong="H2009"\w* \w king|strong="H4428"\w* asked \w him|strong="H1931"\w*, “\w Where|strong="H1004"\w* \w is|strong="H1931"\w* \w he|strong="H1931"\w*?” \w Ziba|strong="H6717"\w* replied, “\w He|strong="H1931"\w* \w is|strong="H1931"\w* \add living\add* \w in|strong="H1004"\w* \w the|strong="H2009"\w* \w house|strong="H1004"\w* \w of|strong="H1121"\w* \w Machir|strong="H4353"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Ammiel|strong="H5988"\w*, \w in|strong="H1004"\w* \w Lo-Debar|strong="H3810"\w* \add city east of the Jordan River\add*.”
\p 
\v 5 \w So|strong="H3947"\w* \w King|strong="H4428"\w* \w David|strong="H1732"\w* \w sent|strong="H7971"\w* \add messengers\add* \w to|strong="H7971"\w* \w bring|strong="H3947"\w* Mephibosheth \add to Jerusalem\add*.
\p 
\v 6 \w When|strong="H1121"\w* \w Mephibosheth|strong="H4648"\w* \w came|strong="H7586"\w* \w to|strong="H5921"\w* \w David|strong="H1732"\w*, \w he|strong="H1732"\w* \w knelt|strong="H5307"\w* \w down|strong="H5307"\w* \w with|strong="H5921"\w* \w his|strong="H1732"\w* \w face|strong="H6440"\w* \w on|strong="H5921"\w* \w the|strong="H6440"\w* \w ground|strong="H6440"\w*, \w to|strong="H5921"\w* show \w respect|strong="H5921"\w*. \w Then|strong="H2009"\w* \w David|strong="H1732"\w* said, “\w Mephibosheth|strong="H4648"\w*!” \w He|strong="H1732"\w* replied, “\w Yes|strong="H2009"\w*, \w your|strong="H5921"\w* majesty, \w how|strong="H2009"\w* \w may|strong="H1121"\w* \w I|strong="H2009"\w* \w serve|strong="H6440"\w* \w you|strong="H6440"\w*?”
\p 
\v 7 \w David|strong="H1732"\w* said \w to|strong="H7725"\w* \w him|strong="H5921"\w*, “\w Do|strong="H6213"\w* \w not|strong="H6213"\w* \w be|strong="H3372"\w* \w afraid|strong="H3372"\w*; \w I|strong="H3588"\w* \w will|strong="H7704"\w* \w be|strong="H3372"\w* kind \w to|strong="H7725"\w* \w you|strong="H3588"\w* \w because|strong="H3588"\w* \w Jonathan|strong="H3083"\w* \w your|strong="H3605"\w* father \add was my loyal friend\add*. \w I|strong="H3588"\w* \w will|strong="H7704"\w* \w give|strong="H7725"\w* \w back|strong="H7725"\w* \w to|strong="H7725"\w* \w you|strong="H3588"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w land|strong="H7704"\w* \w that|strong="H3588"\w* belonged \w to|strong="H7725"\w* \w your|strong="H3605"\w* grandfather \w Saul|strong="H7586"\w*. \w And|strong="H7725"\w* \add I want\add* \w you|strong="H3588"\w* \w to|strong="H7725"\w* \w always|strong="H3605"\w* \w eat|strong="H3899"\w* \w with|strong="H5973"\w* \w me|strong="H7725"\w* \w at|strong="H5921"\w* \w my|strong="H3605"\w* house [MTY].”
\p 
