\v 8 \w For|strong="G1063"\w* \w we|strong="G1063"\w* \w cannot|strong="G1410"\w* \w do|strong="G1410"\w* \w anything|strong="G5100"\w* \w against|strong="G2596"\w* \w the|strong="G2596"\w* Truth, \w but|strong="G1063"\w* \w only|strong="G3756"\w* \w for|strong="G1063"\w* \w the|strong="G2596"\w* Truth.
\v 9 \w Now|strong="G1161"\w* \w we|strong="G2249"\w* \w are|strong="G1510"\w* \w glad|strong="G5463"\w* \w when|strong="G3752"\w* \w we|strong="G2249"\w* \w are|strong="G1510"\w* weak \w and|strong="G2532"\w* \w you|strong="G5210"\w* \w are|strong="G1510"\w* \w strong|strong="G1415"\w*. \w And|strong="G2532"\w* \w we|strong="G2249"\w* \w also|strong="G2532"\w* \w pray|strong="G2172"\w* \w for|strong="G1063"\w* \w this|strong="G3778"\w*, \w your|strong="G2532"\w* perfecting.
\v 10 \w This|strong="G3778"\w* \w is|strong="G3588"\w* \w why|strong="G1223"\w* \w I|strong="G1473"\w* \w write|strong="G1125"\w* \w these|strong="G3778"\w* \w things|strong="G3778"\w* \w while|strong="G3739"\w* absent, \w so|strong="G2443"\w* \w that|strong="G2443"\w* \w when|strong="G2532"\w* \w present|strong="G3918"\w* \w I|strong="G1473"\w* \w may|strong="G2532"\w* \w not|strong="G3756"\w* \w have|strong="G2532"\w* \w to|strong="G1519"\w* deal harshly, \w according|strong="G2596"\w* \w to|strong="G1519"\w* \w the|strong="G2532"\w* \w authority|strong="G1849"\w* \w that|strong="G2443"\w* \w the|strong="G2532"\w* \w Lord|strong="G2962"\w* \w gave|strong="G1325"\w* \w me|strong="G1325"\w*, \w for|strong="G1519"\w* \w building|strong="G3619"\w* \w up|strong="G1519"\w* \w and|strong="G2532"\w* \w not|strong="G3756"\w* \w for|strong="G1519"\w* \w tearing|strong="G2506"\w* \w down|strong="G2596"\w*.
\ms1 Conclusion
\p 
\v 11 \w Finally|strong="G3063"\w*, brothers, \w rejoice|strong="G5463"\w*; \w restore|strong="G2675"\w* \w each|strong="G3326"\w* \w other|strong="G3588"\w*; \w encourage|strong="G3870"\w* \w one|strong="G3588"\w* \w another|strong="G3588"\w*; \w be|strong="G1510"\w* \w of|strong="G2316"\w* \w one|strong="G3588"\w* \w mind|strong="G5426"\w*; \w live|strong="G2532"\w* \w in|strong="G2532"\w* \w peace|strong="G1515"\w*; \w and|strong="G2532"\w* \w the|strong="G2532"\w* \w God|strong="G2316"\w* \w of|strong="G2316"\w* \w the|strong="G2532"\w* love \w and|strong="G2532"\w* \w the|strong="G2532"\w* \w peace|strong="G1515"\w* \w will|strong="G2316"\w* \w be|strong="G1510"\w* \w with|strong="G3326"\w* \w you|strong="G5210"\w*.
\p 
\v 12 Greet \w one|strong="G3956"\w* \w another|strong="G3588"\w* \w with|strong="G1722"\w* \w a|strong="G1722"\w* holy \w kiss|strong="G5370"\w*.
\p 
\v 13 \w All|strong="G3956"\w* \w the|strong="G2532"\w* saints greet \w you|strong="G5210"\w*.
\p 
\v 14 The grace of our Lord Jesus Christ, and the love of God, and the fellowship of the Holy Spirit be with you all.\f + \fr 13:14 \ft Here we have a clear reference to the Trinity.\f*
\p Amen. 
